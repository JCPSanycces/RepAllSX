#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################################################################
# Gestion du masque TRTSALMED
# JML 15/07/10 Compute median salary on JOBTYP (parameter TYPCOD=1) or POSTE (TYPCOD=2) LOT P01
# Modification :
#     SEGAY - 10/05/11 - 73752
#         Salaire médian : flag à isoler = oui, ne jamais le calculer
#########################################################################################################################
Local Char     PARAM(10)(1..3) , VALEUR(10)
#PARAM(1) = "DEVPAY"   : # JOBTYP
PARAM(1) = "SANSCPY"   : # POSTE
PARAM(2) = "2"        : # 1=JOBTYP, 2=POSTE
PARAM(3) = "2"        : # Detail 1=Non, 2=Oui
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTSALMED","TRTSALMED",4,"") From GTRAITE
End

#########################################
## Traitement des actions : TRTIJSS
#########################################
$ACTION
Case ACTION
 When "INIT"        :
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" :
 When "TITRE"       : Gosub TIT
 When "DEBUT"       : Gosub TIT
 When "OK"          : Gosub OK
 When "END"         : FIN = 1
 When "CONTROLE"    :
 When "EXEC"        :
Endcase
Return


#########################################
$OUVRE
Gosub OUVFIC
Return

######################################################
$OUVFIC
If !clalev([F:JOT])  : Local File JOBTYP     [JOT]  : Endif
If !clalev([F:POT])  : Local File POSTE      [POT]  : Endif

Gosub OUVRE From WPDEFTABLE

Local Char     L_CRITERE(GDIMFIC)
Local Char     L_TIT(80)
Local Integer  L_NBPCE
Local Decimal  L_CALCUL
Local Char     COD_CUMUL(50)                   : # Code paramètre pour salaire mensuel

Call PARAM(GCURLEG,"SALAIREM",COD_CUMUL)From ADOVAL

L_TIT = mess(27,9004,1) : # Calcul salaire médian
Return

######################################################
$TIT
[M:DIA]COD = PARAM(1)
[M:DIA]DET = val(PARAM(3))
# segay 10/05/11 73752
[M:DIA]CLCALL = 1
Affzo [M:DIA]DET
Return

#########################################
$OK
Gosub EXEC
Return

#########################################
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(L_TIT) From LECFIC
Endif
Call ECR_TRACE(L_TIT-"COD="+PARAM(1)-"TYPCOD="+PARAM(2)-"TRACE="+PARAM(3)-format$("D:"+GFMDAT4,GMOIPAY),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
L_NBPCE = 0
If [M:DIA]CLCALL=2
 L_CRITERE = "1=1"
Else
 L_CRITERE = "[F]COD=[M:DIA]COD"
Endif
# segay 10/05/11 73752
L_CRITERE -= "& [F]FLGSAL<>2"
Gosub TR1

If !L_NBPCE
 Case PARAM(2)
  When "1"
             Call ECR_TRACE(mess(25,10720,1),0) From GESECRAN : # Aucun emploi type à traiter
  When "2"
             Call ECR_TRACE(mess(27,10720,1),0) From GESECRAN : # Aucun poste à traiter
 Endcase
Else
 Call ECR_TRACE(mess(2,9003,1)-num$(L_NBPCE),0) From GESECRAN : # Calcul :
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
Return

#########################################

$TR1
GOK = 1
Trbegin [JOT], [POT]
 Case PARAM(2)
  When "1" Gosub JOT
  When "2" Gosub POT
 Endcase
Commit
Return
#########################################
$JOT
For [JOT]JOT0 Where evalue(L_CRITERE)
 L_CALCUL = func TRTSALMED.CAL_SALMED([F:JOT]COD,[M:DIA]DET,val(PARAM(2)),COD_CUMUL)
 #70358
 #If L_CALCUL
 If L_CALCUL<0
  GOK=0 : Break
 Elsif L_CALCUL>0
 #
  L_NBPCE += 1
  [F:JOT]SALMED = L_CALCUL
  Rewrite [JOT]
  If fstat
   GOK = 0 : Call FSTA("JOT") From GLOCK : Break
  Endif
 Endif
Next : # [JOT]JOT0
If GOK<1 : Return : Endif
Return
#########################################
$POT
For [POT]POT0 Where evalue(L_CRITERE)
 L_CALCUL = func TRTSALMED.CAL_SALMED([F:POT]COD,[M:DIA]DET,val(PARAM(2)),COD_CUMUL)
 #70358
 #If L_CALCUL
 If L_CALCUL<0
  GOK=0 : Break
 Elsif L_CALCUL>0
 #
  L_NBPCE += 1
  [F:POT]SALMED = L_CALCUL
  Rewrite [POT]
  If fstat
   GOK = 0 : Call FSTA("POT") From GLOCK : Break
  Endif
 Endif
Next : # [POT]POT0
If GOK<1 : Return : Endif
Return
#########################################
$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else: Goto TR1 : Endif

######################################################################################
Funprog CAL_SALMED(L_COD, L_DETAIL,L_TYP,COD_CUMUL)
Value   Char    L_COD()        : # COD of JOBTYP or POSTE wanted
Value   Integer L_DETAIL       : # 1=Non, 2=Oui
Value   Integer L_TYP          : # 1=TYPJOB, 2=POSTE
Value   Char    COD_CUMUL()    : # Parameter for mensual salary

If !clalev([F:HRCTR])  : Local File EMPLOCTR    [HRCTR] : Endif

Local Decimal  L_SALAIRE(0..), L_SALMED
Local Integer  L_NB_CTR

If COD_CUMUL=""
 Call PARAM(GCURLEG,"SALAIREM",COD_CUMUL)From ADOVAL
Endif
If COD_CUMUL=""
 Call ECR_TRACE("SALAIREM"-mess(141,105,1),1) From GESECRAN
 #### Paramètre non défini
 #70358
 #End
 End -1
Endif

Raz L_SALMED, L_NB_CTR, L_SALAIRE

Case L_TYP
 When 1 : # TYPJOB
            Gosub TYPJOB
 When 2 : # POSTE
            Gosub POSTE
Endcase

If L_NB_CTR
 # Faudra voir avec Denis/Grenoble Pourquoi MAXTAB renvoi dim()-1 ?
 Sorta maxtab(L_SALAIRE)+1 L_SALAIRE
 If !mod(maxtab(L_SALAIRE)+1,2)
  # Pair
  L_SALMED = L_SALAIRE(((maxtab(L_SALAIRE)+1)/2)-1) + L_SALAIRE((maxtab(L_SALAIRE)+1)/2)
  L_SALMED = ar2(L_SALMED/2)
 Else
  # Impair
  L_SALMED = L_SALAIRE((maxtab(L_SALAIRE)+1)/2)
 Endif
Endif

If L_DETAIL=2 & GTRACE<>""
 Call ECR_TRACE(mess(28,9004,1)+L_COD-mess(27,9004,1)-format$("N3:6.2",L_SALMED),0) From GESECRAN
 #### Emploi=xxx Calcul salaire médian xxx.xx
Endif
End L_SALMED

######################################################################################
$TYPJOB
For [HRCTR]CTR0 Where [F:HRCTR]JOBPOT=L_COD & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>eomonth(GMOIPAY))
 GBIDC3 = func TRTSALMED.SALAIRE_MTH_CTR([F:HRCTR]REFNUM, GMOIPAY, COD_CUMUL, L_SALAIRE, L_NB_CTR, L_DETAIL)
Next : # [HRCTR]CTR0
Return
######################################################################################
$POSTE
For [HRCTR]CTR0 Where [F:HRCTR]POT=L_COD & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>eomonth(GMOIPAY))
 GBIDC3 = func TRTSALMED.SALAIRE_MTH_CTR([F:HRCTR]REFNUM, GMOIPAY, COD_CUMUL, L_SALAIRE, L_NB_CTR, L_DETAIL)
Next : # [HRCTR]CTR0
Return
######################################################################################
# Monthly salary for 1 contract
Funprog SALAIRE_MTH_CTR(L_REFNUM, MTH_PAY, COD_CUMUL, L_SALAIRE, L_NB_CTR, L_DETAIL)
Value    Char     L_REFNUM()       : # Code Employee
Value    Date     MTH_PAY          : # Month of Pay
Value    Char     COD_CUMUL()      : # Code parameter for Monthly salary
Variable Decimal  L_SALAIRE()      : # Individual salary
Variable Integer  L_NB_CTR         : # Number of contract
Value    Integer  L_DETAIL         : # 1=Non, 2=Oui

If !clalev([F:HSP])  : Local File HISTOPAYE   [HSP] : Endif
If !clalev([F:VEP])  : Local File VALEMP      [VEP] : Endif

# Dernière en-tête de paie
Filter [VEP] Where [F:VEP]EMP=L_REFNUM & [F:VEP]PYRMON=gdat$(01,month(MTH_PAY),year(MTH_PAY))
# VEP1*EMP+PYRMON
Read [VEP]VEP1 Last
If fstat>=4 : Raz [F:VEP] : Endif
Filter [VEP]

Filter [HSP] Where [F:HSP]BUL=[F:VEP]BUL & [F:HSP]RUB=COD_CUMUL & [F:HSP]TYP=6
# Salaire Médian
L_SALAIRE(L_NB_CTR)  = 0
# HSP3*BUL+RUB+TYP
Read [HSP]HSP3 Last
If fstat<4
 L_SALAIRE(L_NB_CTR)  = [F:HSP]AMT
 If L_DETAIL=2 & GTRACE<>""
  Call ECR_TRACE("REFNUM$"+L_REFNUM-"BUL="+[F:HSP]BUL-"DAT="+format$("D:"+GFMDAT4,[F:HSP]DAT)+":"-format$("N3:6.2",[F:HSP]AMT)
&               ,0) From GESECRAN
 Endif : # If L_DETAIL=2 & GTRACE<>""
 L_NB_CTR += 1
Endif
Filter [HSP]

End ""
######################################################################################
## Etiquette écran TRTSALMED
######################################################################################
