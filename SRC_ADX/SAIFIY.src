#<AdxTL>@(#)5.0.0.0 $Revision$
Call OBJET("FIY",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"
  Local Char    SOCIETE(GLONCPY)
  Local Integer EXERCICE , NBPER , DEL , JOUR , I_J , J_K
  Local Date    DEBEX , FINEX
 When "DEBUT"
  Case BOITE
   When "FFIYCRE"
    If [M:FIY1]BASTAB=0  | [F:CPY]CPYLEGFLG<>2
     FIN = 1 : Return
    Endif
    Gosub CHARGE_CRE From SUBFIY
    Affzo [M:DIA]
   When "FFIYOUV"
    If [M:FIY1]BASTAB=0
     FIN = 1 : Return
    Endif
    Gosub CHARGE_OUV From SUBFIY
    Affzo [M:DIA]
  Endcase
 When "OK"
  Case BOITE
   When "FFIYCRE"
    Gosub VALID_CRE From SUBFIY
    FIN = 1
   When "FFIYOUV"
    Gosub VALID_OUV From SUBFIY
    FIN = 1
    If GERR=1 : FIN = 0 : Endif
  Endcase
Endcase
Return



