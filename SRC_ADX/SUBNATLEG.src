#MIPEA - 2016-11-17 - X3PEOP-1200- START
$GET_MTTITLES
Local Char NEWTITLE(GLONAX3)

If !clalev([F:ADI])  : Local File ATABDIV [ADI]    : Endif
#mess(1,10403,1)
Filter [F:ADI] Where [F:ADI]NUMTAB  = 10414 & [F:ADI]LEG = GCURLEG

If rowcount([F:ADI])=4

  nolign=1
  For [F:ADI]
      If nolign = 1
         Call LECTEXTRA(NEWTITLE,"ATABDIV","LNGDES","10414",[F:ADI]CODE) From ATEXTRA
         Chgtzn [M:NAT1]QTY1 With NEWTITLE
      Endif
      If nolign = 2
         Call LECTEXTRA(NEWTITLE,"ATABDIV","LNGDES","10414",[F:ADI]CODE) From ATEXTRA
         Chgtzn [M:NAT1]QTY2 With NEWTITLE
      Endif
      If nolign = 3
         Call LECTEXTRA(NEWTITLE,"ATABDIV","LNGDES","10414",[F:ADI]CODE) From ATEXTRA
         Chgtzn [M:NAT1]FLD1 With NEWTITLE
      Endif
      If nolign = 4
         Call LECTEXTRA(NEWTITLE,"ATABDIV","LNGDES","10414",[F:ADI]CODE) From ATEXTRA
         Chgtzn [M:NAT1]FLD2 With NEWTITLE
      Endif
    nolign += 1
  Next
Else
 Chgtzn [M:NAT1]QTY1 With mess(1,10403,1)
 Chgtzn [M:NAT1]QTY2 With mess(2,10403,1)
 Chgtzn [M:NAT1]FLD1 With mess(3,10403,1)
 Chgtzn [M:NAT1]FLD2 With mess(4,10403,1)
Endif

Filter [F:ADI]

Return

#MIPEA - 2016-11-17 - X3PEOP-1200- END

Return

