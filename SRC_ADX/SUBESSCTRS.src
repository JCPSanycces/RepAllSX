#<AdxTL>@(#)0.0.0.0 $Revision$ Object management ESSCTRS
######################################################################################
## Section automatically added (Object ESSCTRS) 10/09/2018 07:53:22 (FRLAA)
######################################################################################



$ACTION
Case ACTION
 When "SEL_TABLE" : Gosub SEL_TABLE
Endcase
Return


$SEL_TABLE
Case TABLE
  When "SELCTRESS"
  #PARAM(1) - REFNUM
  #PARAM(2) - ENDDAT
  #PARAM(3) - STRDAT
  Local Char CRIT1(250)
  If clalev ([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  Filter [F:HRCTR]
  OBJET     = "ESSCTRS"
  CRIT1 -= '[F:HRCTR]REFNUM="'+PARAM(1)+'"'
  CRIT1 -= "& (CTRDAT<=["+format$(GFMD,PARAM(2))+"] | (FLGRET=2 & RETDATEFF<= ["+format$(GFMD,PARAM(2))+"]"
  CRIT1 -= "& (XITDAT=[0/0/0] | XITDAT>= ["+format$(GFMD,PARAM(2))+")"

  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRCTR]REFNUM="'+PARAM(1)+'")',"&") From GOBJSUB
Endcase
Return

