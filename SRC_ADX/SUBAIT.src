   VARICOD(VARINB) = VARCOD
   Call LECTEXTRA(CHAINE,"GTABACC","INTIT",[F:GTC]CNSCOD,[F:GTC]COD) From ATEXTRA 
   VARITEX(VARINB) = format$("K:8X",VARCOD)+CHAINE
   If [L]CODF1=VARICOD(VARINB) : VARIREP = VARINB : Endif
  Endif
 Endif
Next GTC

If VARINB=0
  Call MESSAGE(mess(4,126,1)) From GESECRAN : # Aucune transaction autorisée
Elsif VARINB=1
  SCRCOD = VARICOD(1)
  WINCOD = VARIBOI(1)
  [M:AIT1]CODTRA = '"' + SCRCOD + '"' 
  Affzo [M:AIT1]CODTRA
Else
 If VARIREP=0 : VARIREP=1 : Endif
 Call SAITRANS(VARINB,VARITEX,VARIREP,mess(86,125,1)) From GOBJACT
 If status<>7 & VARIREP<>0
  SCRCOD = VARICOD(VARIREP)
  WINCOD = VARIBOI(VARIREP)
  [M:AIT1]CODTRA = '"' + SCRCOD + '"' 
  Affzo [M:AIT1]CODTRA
 Else
  SCRCOD = ""
  WINCOD = ""
 Endif
Endif
End

#################################################################
Funprog GET_STRING_VALUE(VALEUR)
Variable Char    VALEUR()
Local Char NEWCOD : [L]NEWCOD = VALEUR
If   instr(1, VALEUR, '"') > 0 and instr(len(VALEUR) - 1, VALEUR, '"') > 0
& or instr(1, VALEUR, "'") > 0 and instr(len(VALEUR) - 1, VALEUR, "'") > 0
  [L]NEWCOD = mid$(VALEUR, 2, len(VALEUR) - 2)
  If instr(1, [L]NEWCOD, '"') > 0 or instr(1, [L]NEWCOD, "'") > 0
    [L]NEWCOD = ""
  Endif
Endif
End [L]NEWCOD


#################################################################
Funprog GET_TABLE_ABREV(VALEUR)
Variable Char    VALEUR()
Local Char ABREV : [L]ABREV = ""
Read [F:AOB]ABREV = VALEUR
If fstat = 0
  Read [F:ATB]CODFIC = [F:AOB]NOMFIC
  If fstat = 0
    [L]ABREV = [F:ATB]ABRFIC
  Endif
Endif
End [L]ABREV


#################################################################
# Selection on transaction codes
Subprog B4_CODTRA(VALEUR)
Variable Char    VALEUR()
If GISTRANSACTION
  Call SHOW_TRS_SELECT([M:AIT1]CODTRA)
Else
  Call SHOW_SCREEN_SELECT([M:AIT1]CODTRA)
Endif
End

#################################################################
# Selection on key values
Subprog B4_KEYVAL(VALEUR)
Variable Char    VALEUR()
Call SHOW_KEY_SELECT([M:AIT1]KEYVAL)
End

#################################################################
# Selection on left lists
Subprog B1_LFTLST(VALEUR)
Variable Char    VALEUR()
Call SHOW_LEFTLIST_SELECT([M:AIT1]LFTLST)
End

#################################################################
Subprog AM_CODTRA(VALEUR)
Variable Char    VALEUR()
If GISTRANSACTION
  Local Char TRANSACTION(250)
  [L]TRANSACTION = func GET_STRING_VALUE(VALEUR)
  If [L]TRANSACTION <> ""
    Read [F:AWI]AWI2 >= GCURRENTOBJECT;[L]TRANSACTION;""
    If fstat and [F:AWI]OBJ = GCURRENTOBJECT and [F:AWI]TRN = [L]TRANSACTION
      # ok
    Else
      [L]TRANSACTION = "" # not ok !
    Endif
  Endif
  
  If [L]TRANSACTION = ""
    Effzo LFTLST
    Grizo LFTLST
  Else
    Actzo LFTLST
  Endif
Endif
End

