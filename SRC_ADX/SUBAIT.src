#<AdxTL>@(#)6.0.0.0 $Revision$
#################################################################

# Gestion du masque AIT1
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AIT", GBIDC1, GBIDC2) From GOBJET
End


#################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "FERME"        : Gosub FERME
 When "LIENS"        : Gosub LIENS
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
 When "CREATION"     : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "ANNULE"       : Gosub ANNULE
 When "CHANGE"       : Gosub CHANGE
 When Default
Endcase
Return

#################################################################
$OUVRE
If clalev([F:AXX]) = 0 : Local File ATEXTRA [AXX] : Endif
If clalev([F:AFC]) = 0 : Local File AFONCTION [AFC] : Endif
If clalev([F:ACT]) = 0 : Local File ACTION [ACT] : Endif
If clalev([F:AOB]) = 0 : Local File AOBJET [AOB] : Endif
If clalev([F:ALD]) = 0 : Local File ALISTED [ALD] : Endif
If clalev([F:ACV]) = 0 : Local File ACTIV   [ACV] : Endif
If clalev([F:ACN]) = 0 : Local File ACONSULT [ACN] : Endif
If clalev([F:ATB]) = 0 : Local File ATABLE [ATB] : Endif
If dim(GCURRENTOBJECT) < 0 : Global Char GCURRENTOBJECT(32) : Endif
If dim(GCURRENTINQUIRY) < 0 : Global Char GCURRENTINQUIRY(32) : Endif
If dim(GISTRANSACTION) < 0 : Global Integer GISTRANSACTION : Endif : GISTRANSACTION = 0
If dim(GISSCREEN) < 0 : Global Integer GISSCREEN : Endif : GISSCREEN = 0
Return

#################################################################
$FERME
If dim(GCURRENTOBJECT) > 0 : Kill GCURRENTOBJECT : Endif
If dim(GCURRENTINQUIRY) > 0 : Kill GCURRENTINQUIRY : Endif
If dim(GISTRANSACTION) > 0 : Kill GISTRANSACTION : Endif
If dim(GISSCREEN) > 0 : Kill GISSCREEN : Endif
Return

#################################################################
$LIENS
# Load dimensioned fields
nolign=1
For I=0 To dim([F:AIT]CODCOL)-1
  If [M:AIT1]CODCOL(I)<>"" Then
    [M:AIT1]CODVAL(nolign-1)=[F:AIT]CODVAL(I)
    [M:AIT1]CODCOL(nolign-1)=[F:AIT]CODCOL(I)
    [M:AIT1]CODSHP(nolign-1)=[F:AIT]CODSHP(I)
    nolign+=1
  Endif
Next
[M:AIT1]NBRVAL=nolign-1
# Set default fields access
Call ON_FUNCTION_CHANGE([M:AIT1]CODFUN, 0)
Call AM_CODTRA([M:AIT1]CODTRA)
Return

#################################################################
$INICRE
Gosub SAVE_DIM
Return

#################################################################
$INIMOD
Gosub SAVE_DIM
Return

#################################################################
# Initialize dimensioned fields
$SAVE_DIM
Raz [F:AIT]CODVAL, [F:AIT]CODCOL, [F:AIT]CODSHP
For I=0 To [M]NBRVAL-1
 [F:AIT]CODVAL(I) = [M:AIT1]CODVAL(I)
 [F:AIT]CODCOL(I) = [M:AIT1]CODCOL(I)
 [F:AIT]CODSHP(I) = [M:AIT1]CODSHP(I)
Next I
Return

#################################################################
$CREATION
Gosub ECRIRE
Return

#################################################################
$MODIF
Gosub ECRIRE
Return

#################################################################
# Write record
$ECRIRE
Call MAJTEXTRA([M:AIT0]INTIT,"AITRLNK","INTIT",[M:AIT0]CODLNK,"") From ATEXTRA
Call MAJTEXTRA([M:AIT1]TIPTEX,"AITRLNK","TIPTEX",[M:AIT0]CODLNK,"") From ATEXTRA
Return

#################################################################
# Delete record
$ANNULE

# Delete translatable text
Delete [AXX] Where CODFIC="AITRLNK" & ZONE = "INTIT" & IDENT1=[M]CODLNK
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODLNK) From GLOCK 
Endif
Delete [AXX] Where CODFIC="AITRLNK" & ZONE = "TIPTEX" & IDENT1=[M]CODLNK
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODLNK) From GLOCK 
Endif

Return

$CHANGE
Update [AXX] Where CODFIC="AITRLNK" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1  GOK=-1 : GLOCK="$ATEXTRA AITRLNK"-[L]OCODE : Return
Elsif fstat  GOK=0 : Call RSTA("AXX", [L]OCODE) From GLOCK : Return
Endif
Return


#################################################################
Subprog C_INTIT(VALEUR)
Variable Char    VALEUR()
If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [F:ADS]DOSSIER = nomap
If !fstat
 Read [F:AXX]AXX0 = "AITRLNK";"INTIT";[F:ADS]LANDEF;[M]CODLNK;""
 If !fstat & [F:AXX]TEXTE<>"" & [F:ADS]LANDEF<>GLANGUE
  [M]INTIT = [F:AXX]TEXTE
 Else 
  [M]INTIT = VALEUR
 Endif
Endif
End

#################################################################
Subprog C_TIPTEX(VALEUR)
Variable Char    VALEUR()
If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [F:ADS]DOSSIER = nomap
If !fstat
 Read [F:AXX]AXX0 = "AITRLNK";"TIPTEX";[F:ADS]LANDEF;[M]CODLNK;""
 If !fstat & [F:AXX]TEXTE<>"" & [F:ADS]LANDEF<>GLANGUE
  [M:AIT1]TIPTEX = [F:AXX]TEXTE
 Else 
  [M:AIT1]TIPTEX = VALEUR
 Endif
Endif
End

#################################################################
Subprog AM_CODFUN(VALEUR)
Variable Char    VALEUR()
Call ON_FUNCTION_CHANGE(VALEUR, 1)
End

#################################################################
Subprog ON_FUNCTION_CHANGE(VALEUR, NEED_INIT)
Value Char    VALEUR()
Value Integer NEED_INIT

Local Integer ISOBJECT : [L]ISOBJECT = 0
Local Integer ISINQUIRY : [L]ISINQUIRY = 0
GISTRANSACTION = 0
GISSCREEN = 0

Read [F:AFC]CODINT=VALEUR
If fstat = 0
  If NEED_INIT
    # Init function dependent fields
    Effzo CNTFRM, SELFRM, CODTRA, KEYVAL, REDOLY, LFTLST, PARVAL, PARLBL
  Endif
  Raz [M:AIT1]HLPFOR
  If [F:AFC]ACTION = "GOBJET"
    [L]ISOBJECT = 1
    # Search for object code in "Function" record, and set table code for formula
    Local Integer I, LG
    [L]LG = dim([F:AFC]VALPAR) - 1
    For [L]I = 0 To [L]LG
      If [F:AFC]CODPAR([L]I) = "OBJET"
        Call SET_CURRENT_OBJECT(func GET_STRING_VALUE([F:AFC]VALPAR([L]I)), 1) 
        Read [F:AOB]ABREV = GCURRENTOBJECT
        If fstat = 0
          [M:AIT1]HLPFOR(0) = [F:AOB]NOMFIC
        Endif
        Break 
      Endif
    Next [L]I
  Else
    # Search for inquiry code
    Read [F:ACT]ACTION = [F:AFC]ACTION
    If fstat=0 and [F:ACT]TYP = 2
      [L]ISINQUIRY = 1
      Call SET_CURRENT_INQUIRY(func GET_STRING_VALUE([F:ACT]PARAM1), 1)
      Read [F:ACN]ACN0 = GCURRENTINQUIRY
      If fstat=0
        Call SET_CURRENT_OBJECT(func GET_STRING_VALUE([F:ACN]OBJET), 0)
        Local Integer I, LG
        [L]LG = dim([F:ACN]FILOPN) - 1
        For [L]I = 0 To [L]LG
          #Call B1_FORMULE(VALMSK,"=[M:AIT1]HLPFOR","[L]WRK","","","") From AFORMULE
          [M:AIT1]HLPFOR([L]I) = [F:ACN]FILOPN([L]I)
        Next [L]I
      Endif  
    Endif  
  Endif
Endif

If [L]ISOBJECT
  Local Char TRANSAC(30)
  Local Integer TRS_NB
  [L]TRS_NB = func GET_TRS_NB(GCURRENTOBJECT, TRANSAC)
  If [L]TRS_NB > 1
    Actzo CODTRA, KEYVAL
    GISTRANSACTION = 1
  Elsif [L]TRS_NB = 1
    If TRANSAC <> ""
      [M:AIT1]CODTRA = '"' + TRANSAC + '"'
    Else
      [M:AIT1]CODTRA = ""
    Endif
    Affzo CODTRA
    Grizo CODTRA
    Actzo KEYVAL
  Else
    Grizo CODTRA, KEYVAL
  Endif
  Actzo REDOLY
Elsif [L]ISINQUIRY
  Local Char SCREEN(30)
  Local Integer SCREEN_NB
  [L]SCREEN_NB = func GET_SCREEN_NB(GCURRENTINQUIRY, [L]SCREEN)
  If [L]SCREEN_NB > 1
    Actzo CODTRA, KEYVAL
    GISSCREEN = 1
  Elsif [L]SCREEN_NB = 1
    If [L]SCREEN <> ""
      [M:AIT1]CODTRA = '"' + [L]SCREEN + '"'
    Else
      [M:AIT1]CODTRA = ""
    Endif
    Affzo CODTRA
    Grizo CODTRA
    Actzo KEYVAL
  Else
    Grizo CODTRA, KEYVAL
  Endif
  Actzo REDOLY
Else
  Grizo CODTRA, KEYVAL, REDOLY
Endif

# Default : left list in not enable
Grizo LFTLST

# Transaction / Screen field label, depending on function
If GISSCREEN
  Chgtzn [M:AIT1]CODTRA With mess(90,105,1)
Elsif GISTRANSACTION
  Chgtzn [M:AIT1]CODTRA With mess(193,124,1)
Else
  Chgtzn [M:AIT1]CODTRA With ""
Endif

# Parameter field
Local Char PARAM_LABEL(250) : [L]PARAM_LABEL = ""
If fstat = 0 and [F:AFC]AIDE > 0
  Call TEXTE([F:AFC]AIDE, [L]PARAM_LABEL) From OBJDIV
Endif
If [L]PARAM_LABEL <> ""
  [M:AIT1]PARLBL = [L]PARAM_LABEL 
  Affzo [M:AIT1]PARLBL
  Actzo PARVAL
Else
  Grizo PARVAL
Endif

End


Subprog SET_CURRENT_OBJECT(CODE, INIT)
Value Char CODE()
Value Integer INIT
GCURRENTOBJECT = CODE
If INIT
  GCURRENTINQUIRY = ""
Endif
End

Subprog SET_CURRENT_INQUIRY(CODE, INIT)
Value Char CODE()
Value Integer INIT
GCURRENTINQUIRY = CODE
If INIT
  GCURRENTOBJECT = ""
Endif
End

#################################################################
#Subprog C_CODTRA(VALEUR)
#Variable Char    VALEUR()
#If VALEUR <> "" and parse(VALEUR)
#  GERR=1 : GMESSAGE = mess(37,124,1) : mkstat=2
#Endif
#End

#################################################################
#**
#* Get number of transaction for an object.
#* If there is only one transaction, its code is returned in second param (TRANSAC).
#*!
Funprog GET_TRS_NB(OBJCOD, TRANSAC)
Value Char    OBJCOD()
Variable Char TRANSAC()

Local Integer TRSNB
Local Char    TRSCOD(GLONATN)
Local Integer OK
Local Char    CHAINE(255)
Local Char    PROGOBJ(GLONADC)
[L]PROGOBJ = "WO" + OBJCOD

[L]TRSNB = 0
If clalev([F:AWI]) = 0 : Local File AWINDOW [AWI] : Endif
For [F:AWI]AWI1 Where OBJ=OBJCOD & ENAFLG=2 & MDL<>2
 [L]OK = 1
 If [F:AWI]CODACT<>""
  If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
  Read [ACV]CODACT = [F:AWI]CODACT
  If fstat | [F:ACV]FLACT<>2
   [L]OK = 0
  Endif
 Endif
 If [L]OK & [F:AWI]ACS<>"" & GUSRACS<>2
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [ACC]CODACC = GUSER;[F:AWI]ACS
  If fstat | [F:ACC]EXEC<>2
   [L]OK = 0
  Endif
 Endif
 If [L]OK
  [L]TRSCOD = [F:AWI]TRN
  CHAINE = ""
  Call TITTRN([L]TRSCOD, [L]CHAINE) From =PROGOBJ
  If [L]CHAINE<>"!"
    [L]TRSNB += 1
    If [L]TRSNB = 1
      TRANSAC = [L]TRSCOD
    Endif
  Endif
 Endif
Next AWI

End [L]TRSNB

#################################################################
#**
#* Get number of screen for an inquiry.
#* If there is only one screen, its code is returned in second param (SCREEN).
#*!
Funprog GET_SCREEN_NB(OBJCOD, SCREEN)
Value Char    OBJCOD()
Variable Char SCREEN()

Local Integer SCREENNB
Local Integer OK

[L]SCREENNB = 0
If clalev([F:GTC]) = 0 : Local File GTABACC [GTC] : Endif
For [F:GTC]GTC0 Where CNSCOD=OBJCOD & ENAFLG=2
  [L]OK = 1
  If [F:GTC]ACS<>"" & GUSRACS<>2
    If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
    Read [ACC]CODACC = GUSER;[F:GTC]ACS
    If fstat | [F:ACC]EXEC<>2
      [L]OK = 0
    Endif
  Endif
  If [L]OK
    [L]SCREENNB += 1
    If [L]SCREENNB = 1
      SCREEN = [F:GTC]COD
    Endif
  Endif
Next GTC

End SCREENNB


#################################################################
#**
#* Show transactions selection dialog
#*
#* @param VALEUR trasaction code
#*!
Subprog SHOW_TRS_SELECT(VALEUR)
Variable Char    VALEUR()

Local Integer VARINB , VARIREP
Local Char    VARITEX(GLONDES+10)(200)
Local Char    VARICOD(GLONATN)(200)
Local Char    VARIBOI(GLONFEN)(200)
Local Char    VARCOD(GLONATN)
Local Integer OK
Local Char    CHAINE(255)
Local Char    PROGOBJ(GLONADC)
[L]PROGOBJ = "WO" + GCURRENTOBJECT

Local Char TRSCOD(GLONATN)
Local Char WINCOD(GLONFEN)

Local Char CODF1 : [L]CODF1 = func GET_STRING_VALUE(VALEUR)

VARINB = 0
#GFLAG = right$(GFLAG,2)
If clalev([F:AWI]) = 0 : Local File AWINDOW [AWI] : Endif
For [AWI]AWI1 Where OBJ=GCURRENTOBJECT & ENAFLG=2 & MDL<>2
 OK = 1
 If [F:AWI]CODACT<>""
  If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
  Read [ACV]CODACT = [F:AWI]CODACT
  If fstat | [F:ACV]FLACT<>2
   OK = 0
  Endif
 Endif
 If OK & [F:AWI]ACS<>"" & GUSRACS<>2
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [ACC]CODACC = GUSER;[F:AWI]ACS
  If fstat | [F:ACC]EXEC<>2
   OK = 0
  Endif
 Endif
 If OK
  VARCOD = [F:AWI]TRN
  ###ACTION = "VARIANTE" : Gosub ACTION
 Endif
 If OK
  If VARINB<dim(VARIBOI)-2
   CHAINE = ""
   Call TITTRN(VARCOD,CHAINE) From =PROGOBJ
   If CHAINE<>"!"
    VARINB += 1
    VARIBOI(VARINB) = [F:AWI]WIN
    VARICOD(VARINB) = VARCOD
    If CHAINE<>""
     VARITEX(VARINB) = format$("K:8X",VARCOD)+CHAINE
    Elsif dim([F:AWI]LIBEL)>0 & [F:AWI]LIBEL<>""
     VARITEX(VARINB) = format$("K:8X",VARCOD)+[F:AWI]LIBEL
    Else
     Call TEXTE([F:AWI]DES,CHAINE) From OBJDIV
     VARITEX(VARINB) = format$("K:8X",VARCOD)+CHAINE
    Endif 
    If [L]CODF1=VARICOD(VARINB) : VARIREP = VARINB : Endif
   Endif
  Endif
 Endif
Next AWI
If VARINB=0
  Call MESSAGE(mess(4,126,1)) From GESECRAN : # Aucune transaction autorisée
Elsif VARINB=1
  TRSCOD = VARICOD(1)
  WINCOD = VARIBOI(1)
  [M:AIT1]CODTRA = '"' + TRSCOD + '"' 
  Affzo [M:AIT1]CODTRA
Else
 If VARIREP=0 : VARIREP=1 : Endif
 Call SAITRANS(VARINB,VARITEX,VARIREP,mess(3,126,1)) From GOBJACT
 If status<>7 & VARIREP<>0
  TRSCOD = VARICOD(VARIREP)
  WINCOD = VARIBOI(VARIREP)
  [M:AIT1]CODTRA = '"' + TRSCOD + '"' 
  Affzo [M:AIT1]CODTRA
 Else
  TRSCOD = ""
  WINCOD = ""
 Endif
Endif
End

#################################################################
#**
#* Show keys selection dialog
#*
#* @param VALEUR key
#*!
Subprog SHOW_KEY_SELECT(VALEUR)
Variable Char    VALEUR()
Local Char CODF1 : CODF1 = func GET_STRING_VALUE(VALEUR)
Local Char TABLE_ABREV(20)
[L]TABLE_ABREV = func GET_TABLE_ABREV(GCURRENTOBJECT)
Call SELECT([L]TABLE_ABREV,"",CODF1,"") From SELOBJ
# TODO : how to make it work when key has more than one split ?...
If CODF1 <> "" 
  [M:AIT1]KEYVAL = '"' + CODF1 + '"'
  Affzo KEYVAL
Endif
End

#################################################################
#**
#* Show inquiry screens selection dialog
#*
#* @param VALEUR screen code
#*!
Subprog SHOW_SCREEN_SELECT(VALEUR)
Variable Char    VALEUR()

Local Integer VARINB , VARIREP
Local Char    VARITEX(GLONDES+10)(200)
Local Char    VARICOD(GLONATN)(200)
Local Char    VARIBOI(GLONFEN)(200)
Local Char    VARCOD(GLONATN)
Local Integer OK
Local Char    CHAINE(255)

Local Char SCRCOD(GLONATN)
Local Char WINCOD(GLONFEN)

Local Char CODF1 : [L]CODF1 = func GET_STRING_VALUE(VALEUR)

VARINB = 0
If clalev([F:GTC]) = 0 : Local File GTABACC [GTC] : Endif
For [F:GTC]GTC0 Where CNSCOD=GCURRENTINQUIRY & ENAFLG=2
 OK = 1
 If [F:GTC]ACS<>"" & GUSRACS<>2
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [ACC]CODACC = GUSER;[F:GTC]ACS
  If fstat | [F:ACC]EXEC<>2
   OK = 0
  Endif
 Endif
 If OK
  VARCOD = [F:GTC]COD
 Endif
 If OK
  If VARINB<dim(VARIBOI)-2
   VARINB += 1
   VARIBOI(VARINB) = [F:GTC]CNSCOD
   VARICOD(VARINB) = VARCOD
   Call LECTEXTRA(CHAINE,"GTABACC","INTIT",[F:GTC]CNSCOD,[F:GTC]COD) From ATEXTRA 
   VARITEX(VARINB) = format$("K:8X",VARCOD)+CHAINE
   If [L]CODF1=VARICOD(VARINB) : VARIREP = VARINB : Endif
  Endif
 Endif
Next GTC

If VARINB=0
  Call MESSAGE(mess(4,126,1)) From GESECRAN : # Aucune transaction autorisée
Elsif VARINB=1
  SCRCOD = VARICOD(1)
  WINCOD = VARIBOI(1)
  [M:AIT1]CODTRA = '"' + SCRCOD + '"' 
  Affzo [M:AIT1]CODTRA
Else
 If VARIREP=0 : VARIREP=1 : Endif
 Call SAITRANS(VARINB,VARITEX,VARIREP,mess(86,125,1)) From GOBJACT
 If status<>7 & VARIREP<>0
  SCRCOD = VARICOD(VARIREP)
  WINCOD = VARIBOI(VARIREP)
  [M:AIT1]CODTRA = '"' + SCRCOD + '"' 
  Affzo [M:AIT1]CODTRA
 Else
  SCRCOD = ""
  WINCOD = ""
 Endif
Endif
End


#################################################################
# TODO : show left lists
