#######################################

# Exgience 73847
#########################################

# open the function associated to the given BI
Subprog OPEN_FUNC(BI_CODE, RES_OK, RES_ERRMSG)
Value Char BI_CODE()
Variable Integer RES_OK
Variable Char RES_ERRMSG
  Local Char T_FUN(30)
  Local Char T_SEL(100)
  Local Char T_TAN(30)
  Local Char T_OBJ(30)
  Local Integer T_NB_KEY
  Local Char T_KEY(100)(1..)
  Local Char T_KEY1(100)
  Local Char T_KEY2(100)
  Local Integer T_REDOLY
  If clalev([F:AIT])=0 : Local File AITRLNK [AIT] : Endif

  RES_OK = 1
  T_REDOLY = 1
  Raz RES_ERRMSG
  Read[AIT]AIT0=BI_CODE
  If fstat<>0
   RES_ERRMSG=mess(296,123,1) : RES_OK = 0 : End
  Endif 
  
  Onerrgo L_ERROR
  T_FUN = [F:AIT]CODFUN
  T_SEL = [F:AIT]SELFRM
  T_REDOLY = [F:AIT]REDOLY
  If [F:AIT]CODTRA <> "" : T_TAN = evalue([F:AIT]CODTRA) : Endif
  Call DECODE_KEY([F:AIT]KEYVAL,T_NB_KEY,T_KEY)
  If T_NB_KEY > 0 and T_KEY(1) <> ""
   T_KEY1 = evalue(T_KEY(1)) 
  Endif
  If T_NB_KEY > 1 and T_KEY(2) <> ""
   T_KEY2 = evalue(T_KEY(2)) 
  Endif  
  # get the object associated to the given function
  Call GET_OBJ(T_FUN, T_OBJ)
  # open the object and apply the filter
  Call OBJET_FILTRE(T_OBJ,T_KEY1,T_KEY2,T_SEL,T_TAN,T_REDOLY) From GOBJET
  Onerrgo
End


# get the value/state/tooltip of the given BI
Subprog GET_VALUE(BI_CODE, RES_VAL, RES_STA, RES_TIP, RES_OK, RES_ERRMSG)
Value Char BI_CODE()
Variable Integer RES_VAL
Variable Integer RES_STA
Variable Char RES_TIP()
Variable Integer RES_OK
Variable Char RES_ERRMSG

  Local Integer I 
  Local Integer LFILCOUNT
  Local Integer LRESCOUNT
  Local Char T_FUN(30)
  Local Char T_SEL(100)
  Local Char T_CNT(100)
  Local Char T_OBJ(30)
  If clalev([F:AIT])=0 : Local File AITRLNK [AIT] : Endif

  Raz RES_VAL
  Raz RES_STA
  Raz RES_TIP
  RES_OK = 1

  Read[AIT]AIT0=BI_CODE
  If fstat<>0
    RES_ERRMSG=mess(296,123,1) : RES_OK = 0 : End
  Endif 

  Onerrgo L_ERROR
  # get the value of indicator
  T_FUN = [F:AIT]CODFUN
  T_SEL = [F:AIT]SELFRM
  T_CNT = [F:AIT]CNTFRM
  Call GET_OBJ(T_FUN, T_OBJ)
  Gosub OUVFIC From ="WO"+T_OBJ
  Gosub OUVFIC_LISTE From ="WO"+T_OBJ
  Gosub DEFAUT_LISTE From ="WO"+T_OBJ 
  If T_SEL<>""
    Filter [F] Where evalue(T_SEL)
  Endif
  RES_VAL=rowcount([F])
  LFILCOUNT = RES_VAL
  If T_CNT<>""
    RES_VAL = evalue(T_CNT)
  Endif
  Onerrgo
  
  LRESCOUNT = RES_VAL
  
  # continue if still OK
  If RES_OK
    # calculate state with the value
    For I = 1 To [F:AIT]NBRVAL
      If RES_VAL <= [F:AIT]CODVAL(I-1)
        RES_STA = I : Break
      Endif
    Next
    If RES_STA = 0 : RES_STA = [F:AIT]NBRVAL+1 : Endif
    # calculate the tip
    Call LECTEXTRA(RES_TIP,"AITRLNK","TIPTEX",BI_CODE,"") From ATEXTRA 
    If RES_TIP <> ""
      RES_TIP = evalue(RES_TIP)
    Else
      RES_TIP = num$(LRESCOUNT)
    Endif
  Endif
End

# Can be used only in context of GET_VALUE/OPEN_FUNC 
$L_ERROR
Local Integer T_ER
T_ER = errn
RES_ERRMSG = errmes$(T_ER)
RES_OK=0 
Resume

# return the associated object from a function
Subprog GET_OBJ(FUN,RES_OBJ)
Value Char FUN
Variable Char RES_OBJ
  If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
  Raz RES_OBJ
  Read [AFC]CODINT = FUN
  If !fstat
    If [F:AFC]ACTION = "GOBJET"
      Local Integer I
      For I = 0 To dim([F:AFC]VALPAR)-1
        If [F:AFC]CODPAR(I) = "OBJET"
          If [F:AFC]VALPAR(I) <> ""
            RES_OBJ = evalue([F:AFC]VALPAR(I)) : Break
          Endif
        Endif
      Next
    Endif
  Endif
End

# extract the keys from a string using ";" as seperator
Subprog DECODE_KEY(KEYS,NBKEY,KEYVAL)
Value Char KEYS
Variable Integer NBKEY
Variable Char KEYVAL()(1..)
  Local Char CHAINE(250)
  Local Integer K
  CHAINE = KEYS
  NBKEY = 0
  While CHAINE<>""
   NBKEY += 1
   K = instr(1,CHAINE,";")
   If K
    KEYVAL(NBKEY) = left$(CHAINE,K-1)
    CHAINE = right$(CHAINE,K+1)
   Else
    KEYVAL(NBKEY) = CHAINE
    CHAINE = ""
   Endif
  Wend
End
###################################################
# End Exigence 73847



