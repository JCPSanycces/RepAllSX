#<AdxTL>@(#)3.0.0.0 $Revision$

Call OBJET ("UGD" , GBIDC1,GBIDC2) From GOBJET
End



$ACTION
Case ACTION
 When "VERIF_CRE"    : Gosub VERIF_CRE    
 When "ANNULE"       : Gosub ANNULE   
 When "CREATION"     : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "CHANGE"       : Call CHANGE_AXX ("USERGUIDES", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When default
Endcase
Return

$VERIF_CRE 

#--- astuce pour éviter certains problèmes d'enreg de texte
#--- suite a des manip du type : enreg de la fiche sans avoir saisi de texte
#--- ensuite on vient saisir le champs texte mais comme le bouton enreg reste grisé 
#--  (car pas de tab pour passer au champs suivant), dans ce cas le champs n'est pas réecrit.
#--
#-- on force donc toujours quelque chose dans la zone
If [M:UGD1]UGDTEX = ""
     [M:UGD1]UGDTEX = "UGD_"+[M:UGD1]UGD+"_1"
Endif


Return 

$ANNULE  

Local Char TRTANU(GDIMFIC) 
Local Char FICANU(GDIMFIC) 
Local Integer STAT 

If GREP = "C" | GREP = "D"
      TRTANU = "UGD_"+[M:UGD1]UGD+"_1" 
Else
      TRTANU = "UGD_"+[F:UGD]UGD+"_1"
Endif
FICANU = filpath("TXT",TRTANU,"rtf") 
While filinfo(FICANU,0) >= 0 
      Call EFFACE(FICANU,STAT) From ORDSYS 
      FICANU = filpath("TXT",TRTANU,"txt") 
Wend 
#---Pour les libellés traduisibles
Delete [AXX] Where CODFIC="USERGUIDES" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif 

Return 
#############################################################
$CREATION
Call MAJTEXTRA([M]UGDDESAXX,"USERGUIDES","UGDDESAXX",[M]UGD,"") From ATEXTRA
Call MAJTEXTRA([M]UGDSHOAXX,"USERGUIDES","UGDSHOAXX",[M]UGD,"") From ATEXTRA

Return
#############################################################
$MODIF
Call MAJTEXTRA([M]UGDDESAXX,"USERGUIDES","UGDDESAXX",[M]UGD,"") From ATEXTRA
Call MAJTEXTRA([M]UGDSHOAXX,"USERGUIDES","UGDSHOAXX",[M]UGD,"") From ATEXTRA

Return

########################################
Subprog AS_UGDTEX(VALEUR)
Variable Char    VALEUR()

If !GIMPORT : VALEUR = "UGD_"+[M:UGD1]UGD+"_1" : Endif

End

