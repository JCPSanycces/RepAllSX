#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
#                                                                       #
#     Resynchronisation STOREO                                          #
#                                                                       #
#     - Traitement   : FUNSYNREO                                        #
#     - Action       : TRTSYNREO  (Traitement standard)                 #
#                                                                       #
#  Au 29 12 03 verification qu il ni ai pas de STAFLG à 2 à tord        #
#                                                                       #
#########################################################################

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard 
Case ACTION
When "OUVRE_BATCH" : Gosub OUVRE_BATCH
When "INIT"        : Gosub INIT
When "EXEC"        : Gosub EXEC
When "TERMINE"     : Gosub TERMINE
When Default
Endcase
Return

#########################################################################
$INIT
Gosub OPEN_FILE

Local Integer I, J
Local Integer WADXUID(1..500)
Local Integer WDIM
Local Char    WSTOFCY(GLONFCY)
Local Char    WCRIT(80)
WSTOFCY=PARAM(1)

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Return
############################################################
$OUVRE_BATCH
Gosub OPEN_FILE
Return
############################################################
$OPEN_FILE
Local File STOREO   [REO]
Return

#########################################################################
$EXEC
Local Integer WTRBEGIN : Raz WTRBEGIN

Call UIDADX(WADXUID,WDIM) From TRTX3

If !GSERVEUR  & GFONCTION1="FUNSYNREO"
# Ouverture de la trace
    Call OUVRE_TRACE("TRTSYNREO") From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
    Call ECR_TRACE(mess(877,196,1),0) From GESECRAN   # Resynchronisation fichiers STOREO
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN 
Endif

If WSTOFCY<>""
   WCRIT='STAFLG=2 & STOFCY=WSTOFCY'
Else
   WCRIT='STAFLG=2'
Endif

# Si pas de transaction en cours
If adxlog<>1 
   Trbegin [REO]
   GOK=1 
   WTRBEGIN=1
Endif
Lock [REO]
If !fstat
   Raz I, J
   For [REO] Hint Key REO0 Where evalue(WCRIT)
   SYMBOLE2 = "REO"+[F:REO]STOFCY+"\"+[F:REO]LOC+"\"+[F:REO]ITMREF
   Lock = SYMBOLE2
# modification en cours sur un autre poste
   If fstat
      GERR=1
      Call ECR_TRACE([F:REO]STOFCY+":"+[F:REO]LOC+":"+[F:REO]ITMREF-":"-mess(10,100,1),0) From GESECRAN
      Goto NEXTREO
   Endif
   Readlock [REO]Curr
      If !fstat
         [F:REO]STAFLG = 1
          Rewrite [REO]
         J+=1
      Endif
   SYMBOLE2 = "REO"+[F:REO]STOFCY+"\"+[F:REO]LOC+"\"+[F:REO]ITMREF
   Unlock = SYMBOLE2
$NEXTREO

   Next

   If GFONCTION1="FUNSYNREO"
      Call ECR_TRACE(mess(878,196,1)-num$(J),0)   From GESECRAN   # Nombre de lignes  STOREO corrigées  :
   Endif
Else
   If GFONCTION1="FUNSYNREO"
      Call ECR_TRACE(mess(879,196,1),1)   From GESECRAN  # Traitement impossible table STOREO en cours d utilisation !
   Endif
Endif

Unlock [REO]

# Si on a ouvert une transaction
If WTRBEGIN=1 
   Commit
   Raz WTRBEGIN
Endif

If !GSERVEUR & GFONCTION1="FUNSYNREO"
   Call FERME_TRACE From LECFIC
   TRA=1
Endif

Return

#########################################################################
$TERMINE
Close File [REO]

Return

#########################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

