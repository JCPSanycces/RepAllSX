#<AdxTL>@(#)2.0.0.0 $Revision$
###################################################################
## DOSDIC  Mise à jour du dictionnaire
###################################################################
Subprog DICO(TRADIF,FORDIF)
Value Integer TRADIF , FORDIF

Onerrgo ERRDIC

Local Integer J , K , V
Local Integer VV(1..50) , PP(50)
Local Integer NEWREC , OLD , SPEC , ERR , NEWREC2
Local Integer DIFF , RW , RWO , OLDENREG , NEWENREG
Local Char    FORMULE(80) , VARIA(GLONAVA) , NEWVAR(GLONAVA)
Local Char    ACCES(GLONACS) , CONTR(GLONACL) , AIDE(GLONADZ), MSKCOD(GLONAMK)
Local Char    STORAGE(250)
Local Integer VERT      : VERT = (GDOSREF<>GDOSX3)

## Pour les écrans

Local Integer MAXZONE   : MAXZONE = 500     : # Max de zones par écrans
Local Integer MAXACT    : MAXACT  = 50      : # Max d'actions par zone

Local Integer NBZONE , NBACT , ONBACT , NUMACT , MODACT
Local Schar   TBZONE(GLONAVA)(1..MAXZONE)
Local Schar   TBACT(GLONACT)(1..MAXACT) , OTBACT(GLONACT)(1..MAXACT)
Local Integer TBNUM(1..MAXACT) , OTBNUM(1..MAXACT)
Local Integer TBTYP(1..MAXACT) , OTBTYP(1..MAXACT)
Local Integer TBINT(1..MAXACT) , OTBINT(1..MAXACT)
Local Libelle TBWEB(1..MAXACT) , OTBWEB(1..MAXACT)
Local Libelle TBDIS(1..MAXACT) , OTBDIS(1..MAXACT)
Local Integer OTBVER(1..MAXACT)
Local Schar   TBAAA(20)(1..MAXACT) , OTBAAA(20)(1..MAXACT)
Local Schar   TBACV(GLONACV)(1..MAXACT) , OTBACV(GLONACV)(1..MAXACT)
Local Schar   TBASM(GLONASM)(1..MAXACT) , OTBASM(GLONASM)(1..MAXACT)
Local Char    TRAIT(GLONADC)
Local Integer ACTIV , IACT , JACT , KACT , NEWLIG , SPELIG

## Pour les fenêtres

Local Integer MAXBOUT    : MAXBOUT = 100     : # Max de boutons par fenêtre
Local Integer MAXPAR     : MAXPAR  = 500     : # Max de paramètres par fenêtre

Local Integer P , P1 , B , BB , OKPAR , EXPLORE , INTEXPLO , RGEXPLO
Local Integer NPAR , NEWPAR , NBOUT , NEWBOUT
Local Char    BOUTCOD(3)(1..MAXBOUT) , BOUTACT(GLONACT)(1..MAXBOUT) , BOUTACV(GLONACV)(1..MAXBOUT)
Local Integer BOUTNUM(1..MAXBOUT) , BOUTTYP(1..MAXBOUT) , BOUTVAL(1..MAXBOUT) , BOUTTXT(1..MAXBOUT)
Local Char    NBOUTCOD(3)(1..MAXBOUT) , NBOUTACT(GLONACT)(1..MAXBOUT) , NBOUTACV(GLONACV)(1..MAXBOUT)
Local Integer NBOUTNUM(1..MAXBOUT) , NBOUTTYP(1..MAXBOUT) , NBOUTVAL(1..MAXBOUT) , NBOUTTXT(1..MAXBOUT)
Local Integer PARNUM(1..MAXPAR) , PARNO(1..MAXPAR)
Local Char    PARAM(GLONAAR)(1..MAXPAR) , PARVAL(80)(1..MAXPAR) , PARCOD(GLONAAR)(1..MAXPAR)
Local Integer NPARNUM(1..MAXPAR) , NPARNO(1..MAXPAR)
Local Char    NPARAM(GLONAAR)(1..MAXPAR) , NPARVAL(80)(1..MAXPAR) , NPARCOD(GLONAAR)(1..MAXPAR)

## Pour les tables diverses

Local Char    CHAMP(20)

## Pour les vues

Local Char    FICREF(GDIMFIC) , FICDES(GDIMFIC)
Local Integer STAT

## Pour les paramètres

Local Char TBLEG(GLONADI)(1..dim(GDOSLEG))
Local Integer NBLEG , OKLEG
Call SETLEG([F:ADS]DOSSIER,TBLEG,NBLEG) From DOSCONT
OKLEG = 0
Read [ADA]ADA0=GDOSREF;"LEG"
If !fstat & [F:ADA]FLACT=2
 Read [ADA]ADA0=[F:ADS]DOSSIER;"LEG"
 If !fstat & [F:ADA]FLACT=2
  OKLEG = 1
 Endif
Endif

Local Integer MODLEG
If !GCRE & val(DOSVERS)>=30 : # mb 24.9.12 bug 82782
 Call DIFFACT([F:ADS]DOSSIER,"LEG",MODLEG) From DOSSUB
Endif

# Pour les tables

Local Integer AUD1 , AUD2 , AUD3 , AUD4 , AUD5 , AUD6 , GEN
Local Integer AUDIT
Local Char    AUDC(GLONANX)
AUDIT = 0
If filinfo(filpath("FIL","ATABAUD","fde",GDOSREF),0)>0
 Read [ADA]ADA0=GDOSREF;"AUDIT"
 If !fstat & [F:ADA]FLACT=2
  Read [ADA]ADA0=[F:ADS]DOSSIER;"AUDIT"
  If !fstat & [F:ADA]FLACT=2
   AUDIT = 1
  Endif
 Endif
Endif

Local Integer ABI
ABI = 0
Read [ADA]ADA0=GDOSREF;"ABI"
If !fstat & [F:ADA]FLACT=2
 Read [ADA]ADA0=[F:ADS]DOSSIER;"ABI"
 If !fstat & [F:ADA]FLACT=2
  ABI = 1
 Endif
Endif

#104160 pb si S-data désactivé
Local Integer ASD
ASD = 0
Read [ADA]ADA0=GDOSREF;"ASD"
If !fstat & [F:ADA]FLACT=2
 Read [ADA]ADA0=[F:ADS]DOSSIER;"ASD"
 If !fstat & [F:ADA]FLACT=2
  ASD = 1
 Endif
Endif

## Divers

Local Integer DICTAB , DICVUE , DICMSK , DICOBJ , DICACT , DICTYP
Local Integer DICPAR , DICFNC , DICETA , DICTXT , DICAPL , DICADO
Local Integer DICACV , DICSTR , DICGEN , DICDIV , DICTRN , DICAGB
Local Integer DICEPU , DICAMI , DICWIN , DICCNS , DICNAV , DICASU
Local Integer DICAVR , DICURL , DICAWM , DICABM , DICAHH , DICAII
Local Integer DICABV , DICABO , DICABF , DICABI , DICAPE , DICMEM
Local Integer DICACLA, DICASW , DICAMC, DICACTX, DICATYP, DICACST,DICATYPACLA
Local Integer DICAUTIL

DICSTR = 1
DICTAB = 1
DICVUE = 1
DICMSK = 1
DICOBJ = 1
DICACT = 1
DICTYP = 1
DICPAR = 1
DICFNC = 1
DICETA = 1
DICTXT = 1
DICAPL = 1
DICACV = 1
DICGEN = 1
DICDIV = 1
DICTRN = 1
DICMEM = 1
DICEPU = 1
DICAMI = 1
DICWIN = 1
DICCNS = 1
DICNAV = 1
DICADO = 1
DICASU = 1
DICAGB = 1
DICACST = 1
DICATYP = 1
DICAVR = 1
DICURL = 1
DICAPE = 1
DICAWM = 1
DICABM = 1
DICAHH = 1
DICAII = 1
DICABV = 1
DICABO = 1
DICABF = 1
DICABI = 1
DICACLA= 1
DICASW = 1
DICACTX = 1
DICAMC = 1
DICATYPACLA = 1
DICAUTIL = 1

# jira X3-85172
# utilities dictionnary
# here to can launch uti before update the structure of file
# caution if the structure of this file changes.
# we must in this case invent something....
# we have to test the present of file autility...
# at the moment not implemented


# Mise à jour structure
If DICSTR : Gosub DICSTR : Endif
If GERRDOS : End : Endif

# jira X3-85172
# utilities dictionnary (file must exist before)
# caution if the structure of this file changes.
# we must in this case invent something....
# in case of creation of a folder update the file with status not active.

If DICAUTIL : Gosub DICAUTIL From DOSDICDIV : Endif

# Remplissage du dico des textes
If DICTXT : Gosub DICTXT From DOSTXT : Endif

# Remplissage du dico des messages
If DICAPL : Gosub DICAPL From DOSTXT : Endif

# Différence d'objet
If TRADIF & !GCRE
 Call COMPDOS(FORDIF) From ACOMPOBJ : # Génération d'un fichier des différences objets
Endif

# Remplissage du dico des tables
If DICTAB : Gosub DICTAB From DOSDICTAB : Endif

# Remplissage du dico des vues
If DICVUE : Gosub DICVUE From DOSDICVUE : Endif

# Remplissage du dico des actions
If DICACT : Gosub DICACT From DOSDICDIV : Endif

# Remplissage du dico des écrans
If DICMSK : Gosub DICMSK From DOSDICMSK : Endif

# Remplissage du dico des objets
If DICOBJ : Gosub DICOBJ From DOSDICOBJ : Endif

# Remplissage du dico des fenêtres
If DICWIN : Gosub DICWIN From DOSDICWIN : Endif

# Remplissage du dico des types
If DICTYP : Gosub DICTYP From DOSDICDIV : Endif

# Remplissage du dico des paramètres
If DICPAR : Gosub DICPAR From DOSDICDIV : Endif

# Remplissage du dico des fonctions
If DICFNC : Gosub DICFNC From DOSDICFNC : Endif

# Remplissage du dico des états
If DICETA : Gosub DICETA From DOSDICETA : Endif

# Remplissage du dico des codes activités
If DICACV : Gosub DICACV From DOSDICDIV : Endif

# Remplissage du dico des paramètres
If DICGEN : Gosub DICGEN From DOSDICDIV : Endif

# Dico des tables diverses
If DICDIV : Gosub DICDIV From DOSDICDIV : Endif

# Dico des formules d'épuration
If DICEPU : Gosub DICEPU From DOSDICDIV : Endif

# Dico des transactions systèmes
If DICAMI : Gosub DICAMI From DOSDICDIV : Endif

# Dico des consultations
If DICCNS : Gosub DICCNS From DOSDICDIV : Endif

# Dico des navigations
If DICNAV : Gosub DICNAV From DOSDICDIV : Endif

# Dico des transactions
If DICTRN : Gosub DICTRN From DOSDICDIV : Endif

# Codes mémos
If DICMEM : Gosub DICMEM From DOSDICDIV : Endif

# Type prototype
If DICATYP : Gosub DICATYP From DOSDICDIV : Endif

# Dico des variables globales
If DICAGB : Gosub DICAGB From DOSDICDIV : Endif

# Dico des variables constantes
If DICACST : Gosub DICACST From DOSDICDIV : Endif

# Dico des Variables contextes
If DICACTX : Gosub DICACTX From DOSDICDIV : Endif

# Dico des sous programmes
If DICASU : Gosub DICASU From DOSDICDIV : Endif

# Dico du contexte assistant formule
If DICAVR : Gosub DICAVR From DOSDICDIV : Endif

# Dico des URL
If DICURL : Gosub DICURL From DOSDICDIV : Endif

# Dico des documentations
If DICADO : Gosub DICADO From DOSDICDIV : Endif
If DICADO : Gosub DICADF From DOSDICDIV : Endif

# Dico des modeles de workflow
If DICAWM : Gosub DICAWM From DOSDICDIV : Endif

# Dico des classes données
If DICACLA : Gosub DICACLA From DOSDICACLA : Endif

# Dico des classes représentations
If DICASW : Gosub DICASW From DOSDICASW : Endif

# Mise a jour type de donnée suite modification classes et représentation
If DICATYPACLA : Gosub DICTYPACLA From DOSDICDIV : Endif

# Dico des mots clés d'aide: ATTENTION: après tables, écrans, classes et représentations
If DICAMC : Gosub DICAMC From DOSDICAMC : Endif

# Table des points d'entrée
If DICAPE : Gosub DICAPE From DOSDICDIV : Endif

If ABI : # Business Object
 # Dico des datamarts
 If DICABM : Gosub DICABM From DOSDICABI : Endif

 # Dico des hierarchie
 If DICAHH : Gosub DICAHH From DOSDICABI : Endif

 # Dico des conditions predéfinies
 If DICAII : Gosub DICAII From DOSDICABI : Endif

 # Dico des Règles synchronisation
 If DICABV : Gosub DICABV From DOSDICABI : Endif

 # Dico des Etats Business Objects
 If DICABO : Gosub DICABO From DOSDICABI : Endif

 # Dico des table de faits
 If DICABF : Gosub DICABF From DOSDICABI : Endif

 # Dico des dimensions
 If DICABI : Gosub DICABI From DOSDICABI : Endif

Endif

Onerrgo
End

$ERRDIC
GERREUR = errn
# Erreur...ligne no...
GMESSAGE = errp+"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)+"\"+errmes$(GERREUR)+"\|"+errm+"|\|"
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Raz GMESSAGE , GERREUR
Resume

##############################################################
$DICSTR
# Création/MAJ des structures de table du dico
Local File =GDOSREF+".ATABLE"  [ATB]
&         ,=GDOSREF+".ATABIND" [ATI]
&         ,=GDOSREF+".ATABZON" [ATZ]
&         ,=GDOSREF+".AMSKPAR" [AMP]
&         ,=GDOSREF+".AINDEX"  [ANX]
&         ,=GDOSREF+".ACTIV"   [ACV]
&         ,=GDOSREF+".ATEXTE"  [ATX]
&         ,=GDOSREF+".ATYPE"   [ATY]

Call ECR_TIME(mess(14,125,1)) From DOSSUB
If GINFO
 # MAJ structure dictionnaire
 Call AFF_VLC(mess(14,125,1),"") From GESECRAN
Endif

# Mise à jour table ATABLE

Read [ATB]CODFIC = "ATABLE"
Call MAJTAB([F:ATB]CODFIC,0) From DOSTAB

# Mise à jour autres tables

For [ATB] Where TYPFIC=4 & CODFIC<GXX & CODFIC<>"ATABLE"
 If GINFO
  # MAJ structure dictionnaire/Table
  Call AFF_VLC(mess(14,125,1),mess(56,123,1)-[F:ATB]CODFIC) From GESECRAN
 Endif
 If [F:ATB]CODACT<>"ABI" or ABI
  Call MAJTAB([F:ATB]CODFIC,0) From DOSTAB
 Endif
 If GERRDOS : Break : Endif
Next ATB

# Création de la table ATABAUD (si inexistante) pour la mise à jour du dico
If AUDIT & filinfo(filpath("FIL","ATABAUD","fde",[F:ADS]DOSSIER),0)<=0
 Read [ATB]CODFIC="ATABAUD"
 If GINFO
  # MAJ structure dictionnaire/Table
  Call AFF_VLC(mess(14,125,1),mess(56,123,1)-[F:ATB]CODFIC) From GESECRAN
 Endif
 Call MAJTAB([F:ATB]CODFIC,0) From DOSTAB
Endif

Close Local File [ATB] , [ATI] , [ATZ] , [AMP] , [ANX] , [ACV] , [ATY] , [ATX]
Return

$RIEN
Resume

############################################################
Subprog ERREUR(TABLE,COD)
Value Char    TABLE
Value Integer COD
Case COD
 When 1 : Call ECR_TRACE(mess(26,125,1)-TABLE-num$(fstat),1) From GESECRAN : # Erreur d'écriture
 When 2 : Call ECR_TRACE(mess(27,125,1)-TABLE-num$(fstat),1) From GESECRAN : # Erreur de réécriture
 When 3 : Call ECR_TRACE(mess(28,125,1)-TABLE-num$(fstat),1) From GESECRAN : # Erreur d'effacement
 When 4 : Call ECR_TRACE(mess(49,125,1)-TABLE-num$(fstat),1) From GESECRAN : # Erreur de lecture
 When 5 : Call ECR_TRACE(mess(58,134,1)-TABLE-num$(fstat),1) From GESECRAN : # Erreur de verrouillage
Endcase
End

