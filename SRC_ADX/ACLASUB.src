#-------------------------------------------------------#
Subprog STC_VERF(NOMSTC,IDENTSTC,APPLI,MACHINE,TYPTRT,OK,AERR)
Value Char NOMSTC
Value Char IDENTSTC
Value Char APPLI
Value Char MACHINE
Value Char TYPTRT
Variable Integer OK
Variable  Instance  AERR(1..) Using C_AERROR

Local Char FICSRC(250),LIGNE(255)
Local Integer I,VIDE

FICSRC = filpath(toupper(TYPTRT),NOMSTC,tolower(TYPTRT),APPLI,"",MACHINE)
If filinfo(FICSRC,7)>0
 Openi FICSRC Using [SSS_]
 Iomode adxifs "" Using [SSS_]
 Iomode adxirs chr$(10) Using [SSS_]
 Iomode adxium GUTF8 Using [SSS_]
 Raz I, OK
 VIDE = 1
 Rdseq LIGNE Using [SSS_]
 While !fstat
  I += 1 : If I>5 : Break : Endif
  If left$(LIGNE,len(IDENTSTC))=IDENTSTC
   OK = 1 : Break
  Elsif LIGNE<>""
   VIDE = 0
  Endif
  Rdseq LIGNE Using [SSS_]
 Wend
 Openi Using [SSS_]
 If VIDE
  OK = 1
 Elsif !OK
  OK = 1
  If 0
  I = maxtab(AERR)+1
  AERR(I) = NewInstance C_AERROR AllocGroup AERR
  AERR(I).STA = [V]CST_AERROR
  AERR(I).MES = NOMSTC-":"-mess(215,139,1) :   # Ce traitement est déjà utilisé par un autre paramètrage
  AERR(I).NUM = 9101
  Return
  Endif
 Endif
Else
 OK  = 1
Endif
End

#-------------------------------------------------------#
Subprog STC_DEB(APPLI,MACHINE,NOMPRG,IDENTSTC,CODE,INTIT,MAGIC,TITETA,TYPTRT)
Value Char APPLI,MACHINE,NOMPRG,IDENTSTC,CODE,INTIT,MAGIC,TITETA,TYPTRT
Local Char FICSRC(250)
If TYPTRT="STC" :
 FICSRC = filpath("STC",NOMPRG,"stc",APPLI,"",MACHINE)
Else
 FICSRC = filpath("TRT",NOMPRG,"src",APPLI,"",MACHINE)
Endif
Local Integer ER,STAT
#Onerrgo ERFIC
Onerrgo ERREUR From ACLAVAL
Openo FICSRC , 0 Using [SSS_]
Onerrgo ERREUR From ACLAVAL
#If ER & TYPTRT="STC"
# Call SYSTEME(MACHINE,'ae_mkdir'-'"'+filpath("STC","","",APPLI)+'"',"",STAT) From ORDSYS
# Openo FICSRC , 0 Using [SSS_]
#Endif
Iomode adxifs "" Using [SSS_]
Iomode adxirs chr$(10) Using [SSS_]
Iomode adxium GUTF8 Using [SSS_]
Wrseq TITETA+mess(3,140,1)-INTIT Using [SSS_] : # Classe
Wrseq "#"-MAGIC Using [SSS_]
Wrseq IDENTSTC-CODE Using [SSS_]
Wrseq "#"-func SUBADC.CNVMIL(timestamp$) Using [SSS_]
Wrseq Using [SSS_]
End

#-------------------------------------------------------#
$ERFIC
ER = errn
Resume

#-------------------------------------------------------#
Subprog STC_FIN(CLOB,NOMSTC,ISACTX,DOSSIER,TYPTRT,VALP,TYPAGE,OK,AERR)
Value Clbfile CLOB
Value Char NOMSTC
Value Integer ISACTX
Value Char DOSSIER,TYPTRT
Value Integer VALP
Variable Integer TYPAGE
Variable Integer OK
Variable Instance AERR(1..) Using C_AERROR

Wrseq CLOB Using [SSS_]
Wrseq Using [SSS_]
Openo Using [SSS_]
Call VALID(TYPTRT,NOMSTC,ISACTX,DOSSIER,VALP,TYPAGE,OK,AERR) From ACLAVALSUB
End

#-------------------------------------------------------#
Subprog TRT_FIN(CLOB,NOMSTC,ISACTX,DOSSIER,TYPTRT,OK,AERR)
Value Clbfile CLOB
Value Char NOMSTC
Value Integer ISACTX
Value Char DOSSIER,TYPTRT
Variable Integer OK
Variable Instance AERR(1..) Using C_AERROR
Local Integer TYPAGE
Wrseq CLOB Using [SSS_]
Wrseq Using [SSS_]
Openo Using [SSS_]
Call VALID(TYPTRT,NOMSTC,ISACTX,DOSSIER,0,TYPAGE,OK,AERR) From ACLAVALSUB
End

#-------------------------------------------------------#
Subprog STC_FIN_TECH(CLOB,NOMSTC,DOSSIER,TYPTRT,VALP,TYPAGE,OK,MES)
Value Clbfile CLOB
Value Char NOMSTC,DOSSIER,TYPTRT
Value Integer VALP
Variable Integer TYPAGE
Variable Integer OK
Variable  Char MES

Wrseq CLOB Using [SSS_]
Wrseq Using [SSS_]
Openo Using [SSS_]
Call VALID_TECH(TYPTRT,NOMSTC,0,DOSSIER,VALP,TYPAGE,OK,MES) From ACLAVALSUB
End

#-------------------------------------------------------#
Subprog LECMERE(DOSSIER,NBMERE,TBMERE)
Value Char DOSSIER
Variable Integer NBMERE
Variable Char TBMERE()(1..)

Raz TBMERE,NBMERE

Local Char FICAPL(250),LIGNE(250)

Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

If NBMERE = 0
 FICAPL = filpath("","APL","ini",APPLI)
 If filinfo(FICAPL,0)>=0
  Openi FICAPL Using [FAPL]
  Rdseq LIGNE Using [FAPL]
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   If left$(LIGNE,10)="adxmother("
    J = instr(1,LIGNE,"=")
    If J
     LIGNE = vireblc(right$(LIGNE,J+1),2)
     LIGNE = seg$(LIGNE,2,len(LIGNE)-1)
     If LIGNE<>APPLI & !find(LIGNE,TBMERE(1..NBMERE)) & filinfo(filpath("","","",LIGNE),0)>=0
      NBMERE += 1
      TBMERE(NBMERE) = LIGNE
     Endif
    Endif
   Endif
   Rdseq LIGNE Using [FAPL]
  Wend
  Openi Using [FAPL]
 Endif
Endif
End


#-------------------------------------------------------#

Subprog VALID_TRTSTD(NOMSTC,DOSSIER,CODCLA,ISACTX,COMMENT,MODULE,ACTIV,TITETA,CODTRT,TYPTRT,AERR)
Value Char NOMSTC
Value Char DOSSIER
Value Char CODCLA
Value Integer ISACTX
Value Char COMMENT
Value Integer MODULE
Value Char ACTIV
Value Char TITETA
Value Char CODTRT
Value Integer TYPTRT
Variable  Instance  AERR(1..) Using C_AERROR

Local Char      FICSRC(250),FICNEW(250)
Local Integer   NBMERE,J,FLVALMET,FLVALPRO,OKTRT,STAT,OK,TYPAGE,FLVALEVENT,FLVALOPE
Local Char      TBMERE(GLONADS)(1..10),LIGNE(250)
Local Char      MACHINE(GDIMFIC), APPLI(GDIMFIC)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

Local File =DOSSIER+".ADOVAL" [ADW_]

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

Read [ADW_]ADW0 = "";"";"SUPDOS"
If !fstat
 If [L]TYPTRT=1 & [F:ADW_]VALEUR<>APPLI
  Close Local File [ADW_]
  End
 Endif
Endif


If DOSSIER=nomap
 FICSRC = filpath("TRT",CODTRT,"src")
Else
 FICSRC = filpath("TRT",CODTRT,"src",[L]APPLI,"",[L]MACHINE)
 If filinfo(FICSRC,0)<0
  Call LECMERE(DOSSIER,NBMERE,TBMERE) From ACLASUB
  For J=1 To NBMERE
   FICSRC = filpath("TRT",CODTRT,"src",TBMERE(J),"",[L]MACHINE)
   If filinfo(FICSRC,0)>=0 : Break : Endif
  Next J
 Endif
Endif

If filinfo(FICSRC,0)<0
 FLVALMET = 0
 FLVALPRO = 0
 If DOSSIER=nomap
  Call EXISTE_ADX("","",CODTRT,OKTRT) From ASYRSYS
 Else
  Call EXISTE_ADX(MACHINE,APPLI,CODTRT,OKTRT) From ASYRSYS
  If !OKTRT
   Call LECMERE(DOSSIER,NBMERE,TBMERE) From ACLASUB
   For J=1 To NBMERE
    Call EXISTE_ADX(MACHINE,TBMERE(J),CODTRT,OKTRT) From ASYRSYS
    If OKTRT>0 : Break : Endif
   Next J
  Endif
 Endif
 If !OKTRT
  FLVALMET = 2
  FLVALPRO = 2
  FLVALEVENT = 2
  FLVALOPE = 2
 Endif
Else
 Gosub TEST_ACTION
Endif

If FLVALMET or FLVALPRO or FLVALEVENT or FLVALOPE
 Gosub ADD_ACTION
 Call MAJDICTRT(CODTRT,DOSSIER,COMMENT,MODULE,ACTIV) From SUBADC
 Call VALID("TRT",CODTRT,ISACTX,DOSSIER,0,TYPAGE,OK,AERR) From ACLAVALSUB
Endif
End
#------------------------------------------------#

$TEST_ACTION
FLVALMET = 1
FLVALPRO = 1
FLVALEVENT = 1
FLVALOPE = 1
Openi FICSRC Using [FSRC]
Rdseq LIGNE Using [FSRC]
While fstat=0
 If left$(vireblc(LIGNE,2),8)="$METHODS"
  FLVALMET = 0
 Endif
 If left$(vireblc(LIGNE,2),11)="$PROPERTIES"
  FLVALPRO = 0
 Endif
 If left$(vireblc(LIGNE,2),11)="$EVENTS"
  FLVALEVENT = 0
 Endif
 If left$(vireblc(LIGNE,2),11)="$OPERATIONS"
  FLVALOPE = 0
 Endif
 Rdseq LIGNE Using [FSRC]
Wend
Openi Using [FSRC]
If dim(NOMSTC)>0 and len(NOMSTC)>1 and left$(NOMSTC,1)="R"
 FLVALOPE = 0
Endif
Return

#------------------------------------------------#

$ADD_ACTION
FICNEW = filpath("TRT",CODTRT,"new",APPLI,"",MACHINE)
If dim(NOMSTC)>0 and len(NOMSTC)>1 and left$(NOMSTC,1)="R"
 FLVALOPE = 0
Endif
Openo FICNEW , 0
If FLVALMET=2
 Wrseq TITETA
 Wrseq "#"-mess(3,140,1)-CODCLA : # Classe
 Wrseq
 Gosub ACTION
Else
 Openi FICSRC Using [FSRC]
 Rdseq LIGNE Using [FSRC]
 While fstat=0
  Wrseq LIGNE
  Rdseq LIGNE Using [FSRC]
 Wend
 Openi Using [FSRC]
 Gosub ACTION
Endif
Openo
FICSRC = filpath("TRT",CODTRT,"src",DOSSIER)
Call _MOVE(FICNEW,FICSRC,STAT) From ASYRSYS
If STAT
 I = maxtab(AERR)+1
 AERR(I) = NewInstance C_AERROR AllocGroup AERR
 AERR(I).STA = [V]CST_AERROR
 AERR(I).MES = mess(6,123,1)+num$(STAT)-"MOVE"+"\|"+FICNEW+"\|"+FICSRC : # Erreur
 AERR(I).NUM = 9101
Endif
Return

#------------------------------------------------#
ACTION
If FLVALEVENT>0
 Wrseq
 Wrseq "#**"
 Wrseq "#* Label for coding event of CRUD"
 Wrseq "#* @param CURPTH Local Char(250), contains the class path"
 Wrseq "#* @param AEVENT Local Char(20), contains the event code"
 Wrseq "#* @return ASTATUS Local Integer"
 Wrseq "#*!"
 Wrseq "$EVENTS"
 Wrseq "#Case [L]CURPTH"
 Wrseq '#   When ""'
 Wrseq "#    Case [L]AEVENT"
 Wrseq "#    Endcase"
 Wrseq "#Endcase"
 Wrseq "Return"
 Wrseq
Endif
If FLVALPRO>0
 Wrseq
 Wrseq "#**"
 Wrseq "#* Label for coding action on INIT, GET, CONTROL and PROPAGATE"
 Wrseq "#* @param CURPRO Local Char(50), contains the property code"
 Wrseq "#* @param ARULE Local Char(20), contains the action code requested"
 Wrseq "#* @return ASTATUS Local Integer"
 Wrseq "#*!"
 Wrseq "$PROPERTIES"
 Wrseq "#Case [L]CURPRO"
 Wrseq "#   Case [L]ARULE"
Wrseq  "#   Endcase"
 Wrseq "#Endcase"
 Wrseq "Return"
 Wrseq
Endif
If FLVALMET>0
 Wrseq
 Wrseq "#**"
 Wrseq "#* Label for coding your methods"
 Wrseq "#* @param AMETHOD Local Char(20), contains the method code"
 Wrseq "#* @return ARET_VALUE (the type of the return value is declared in the method)"
 Wrseq "#*!"
 Wrseq "$METHODS"
 Wrseq '#Case [L]AMETHOD'
 Wrseq '#Endcase'
 Wrseq "Return"
 Wrseq
Endif
If FLVALOPE>0
 Wrseq
 Wrseq "#**"
 Wrseq "#* Label for coding your operations"
 Wrseq "#* @param AOPERATION Local Char(20), contains the operation code"
 Wrseq "#* @return ARET_VALUE (the type of the return value is declared in the method)"
 Wrseq "#*!"
 Wrseq "$OPERATIONS"
 Wrseq "#Case [L]AOPERATION"
 Wrseq "#Endcase"
 Wrseq "Return"
 Wrseq
Endif
Return


#---------------------------------------------------------------#
# Return the default index(internal type also) of a given table
#---------------------------------------------------------------#
Subprog GET_INDEX(DOSSIER,TABLE,NUMLIG,NBKEY,KEYVAL,KEYTYP)
Value Char DOSSIER
Value Char TABLE
Value Integer NUMLIG
Variable Integer NBKEY,KEYTYP(1..)
Variable Char KEYVAL()(1..)

Local Integer NBCLE , POS , TYP(1..16), I,J
Local Char CHAINE(120)
If filinfo(filpath("FIL","AVIEWFLD","fde",DOSSIER),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",DOSSIER),0)<0
 Local File =DOSSIER+".ATABZON" [ATZ]
 Local File =DOSSIER+".ATABIND" [ATI]
Else
 Local File =DOSSIER+".AVIEWFLD" [ATZ]
 Local File =DOSSIER+".AVIEWIND" [ATI]
Endif
Local File =DOSSIER+".ATYPE" [ATY]

 Raz NBKEY, KEYVAL, KEYTYP
 Read [ATI]NUMLIG = TABLE;NUMLIG
 If !fstat
  CHAINE = [F:ATI]DESCRIPT
  While CHAINE<>""
   NBKEY += 1
   I = instr(1,CHAINE,"+")
   J = instr(1,CHAINE,"-")
   If I & J
    I = min(I,J)
   Elsif J & !I
    I = J
   Endif
   If I
    KEYVAL(NBKEY) = left$(CHAINE,I-1)
    CHAINE = right$(CHAINE,I+1)
   Else
    KEYVAL(NBKEY) = CHAINE
    CHAINE = ""
   Endif
   Read [ATZ]CODZONE=TABLE;KEYVAL(NBKEY)
   Read [ATY]CODTYP=[F:ATZ]CODTYP
   KEYTYP(NBKEY) = [F:ATY]TYPTYP
  Wend
 Endif

 Close Local File [ATI],[ATY],[ATZ]
End

