#-- SCHELPER.src
#=================================================================================
# Sage, Written by R&D 09-2013
# SCHELPER.src see also SCDAOHELPER.src
#=================================================================================
# Duplication instance with all levels
# Call
# WCHR=func SCHELPER.DUPINSTANCE (SRCCLAS.ObjectType,SRCCLAS,DESTCL,650,"")
# Or
# WCHR=func SCHELPER.DUPINSTANCE (SRCCLAS.ObjectType,SRCCLAS,DESTCL,0,"NEWKEY002")
#=================================================================================
#**
#*
#* @return number of word (0..N-1)
#* @param ASTRING input string
#* @param ASEP    separator
#* @param PWORDS  out tabs char variable
#*!
Funprog SPLIT_STRING(ASTRING,ASEP,PWORDS)
Value   Char    ASTRING
Value   Char    ASEP
Variable Char   PWORDS()(0..)
#--------------------------------------------------
Local Integer J,I,H1,CPT,K : J=0
Local Integer WIND(0..)

    #--- if not found separator -------------------
    If instr(1,ASTRING,ASEP)<=0 or ASTRING=""
       PWORDS(0)=ASTRING
       End 1: #-- out of process
    Endif
    #----------------------------------------------
    CPT=-1 : I=0 : K=0
    Repeat
      I = instr(I+1, ASTRING,ASEP) : CPT += 1 :
      WIND(K)=I  : K+=1
    Until I = 0
    H1=1 :
    For K=0 To CPT-1
      PWORDS(J)= seg$(ASTRING,H1,WIND(K)-1)
      H1=WIND(K)+1
      J+=1
    Next
    PWORDS(J)= seg$(ASTRING,H1,len(ASTRING))
End J+1 : #-- number of elements return
#=======================================================================
#=======================================================================
#**
#*
#* @param PTMP
#* @param PTYPE
#* @param PFIELD
#* @param PCLASSNAME
#* @param POBJSRC   Instance source
#* @param POBJDEST  Instance dest
#* @param PKEYNAME  Name of key (Index key name)
#* @param PKNEWINT  Destination value of key Integer type
#* @param PKNEWCHR  Destination value of key Char type
#*!
Subprog SETPROPERTIES(PTMP,PTYPE,PFIELD,PCLASSNAME,POBJSRC,POBJDEST,PKEYNAME,PKNEWINT,PKNEWCHR)
Value Char        PTMP   : #----------------------
Value Char        PTYPE  : #- type of property
Value Char        PFIELD : #- field name
Value Char        PCLASSNAME
Variable Instance POBJSRC Using OBJECT
Variable Instance POBJDEST Using OBJECT
Value    Char     PKEYNAME  : #-- Key name of index
Value    Integer  PKNEWINT  : #-- value
Value    Char     PKNEWCHR  : #-- value

  Local Char    WCLASSNAME(40),WTEXT(60)
  Local Integer N
  #---------------- variable name of descriptor class ----
  WCLASSNAME="C_"+PCLASSNAME

  Local Instance    WCLASRC Using =WCLASSNAME
  Local Instance    WCLADES Using =WCLASSNAME
  #---- Cast for all classes, and copy now ---------------
  WCLASRC=cast(POBJSRC,=WCLASSNAME)
  WCLADES=cast(POBJDEST,=WCLASSNAME)
  #--------------------------------------------------------------------
  #-- type AXX, AX1, AX3 ,AX2 -----------------------------------------
  #--------------------------------------------------------------------
  If (PTYPE="AXX" or PTYPE="AX1" or PTYPE="AX3" or PTYPE="AX2")
     #-- Get and Set text dynamic
     Assign("WTEXT") With evalue("fmet WCLASRC."+PTMP+".AGETTEXT()")
     If (WTEXT<>"")
       Assign("N") With evalue ("fmet WCLADES."+PTMP+".ASETTEXT(WTEXT)")
     Endif
  Else : #-- Not type AXX
   #---- not dup : AUUID, CREDATTIM, UPDDATTIM,CREUSR,UPDUSR,CREDAT,UPDDAT ----------
   Case PFIELD :
    When "AUUID","CREDATTIM","UPDDATTIM","CREUSR","UPDUSR" :
    When "CREDAT","UPDDAT" :
    When Default :
      If ((PKEYNAME=PFIELD) and (PKNEWINT>0 or PKNEWCHR<>""))
         If (PKNEWINT>0)
           #-- if destination key property is the integer type -----------
           Assign("WCLADES."+PFIELD) With PKNEWINT
         Else
           #--- if destination key property is the char type -------------
           Assign("WCLADES."+PFIELD) With PKNEWCHR
         Endif
      Else : #--- others fields ------------------------------------------
        Assign("WCLADES."+PTMP) With evalue("WCLASRC."+PTMP)
      Endif
   Endcase
  Endif : #-- endif else PTYPE="AXX"
End
#======================================================================================
###########################################################################
#**
#*
#* Recursive process
#* @param PCLASSNAME
#* @param POBJSRC   Instance source
#* @param POBJDEST  Instance dest
#* @param PWORDS
#* @param PWTMP
#* @param PKEYNAME  Name of key (Index key name)
#* @param PKNEWINT  Destination value of key Integer type
#* @param PKNEWCHR  Destination value of key Char type
#*!
Subprog SETLEVEL(PCLASSNAME,POBJSRC,POBJDEST,PWORDS,PWTMP,PKEYNAME,PKNEWINT,PKNEWCHR)
Value Char        PCLASSNAME
Variable Instance POBJSRC Using OBJECT
Variable Instance POBJDEST Using OBJECT
Variable     Char PWORDS()()
Variable     Char PWTMP()()
Value    Char     PKEYNAME  : #-- Key name of index
Value    Integer  PKNEWINT  : #-- value
Value    Char     PKNEWCHR  : #-- value

  Local Integer WCH,XNB,WLINE3
  Local Integer J,W
  Local Char    WFIELD(40),WWTYPEN(40),WLNKNAME(40),WTMP(80),WWTMP(80)(3)
  Local Char    WFIELD3(40),WWTYPEN3(40),WCLASSNAME(40)
  Local Char    XWDATAS5(40)(0..),XWWORDS5(40)(0..)

  #---------------- variable name of descriptor class ----
  WCLASSNAME="C_"+PCLASSNAME
  Local Instance    WCLASRC Using =WCLASSNAME
  Local Instance    WCLADES Using =WCLASSNAME
  #---- Cast for all classes, and copy now ---------------
  WCLASRC=cast(POBJSRC,=WCLASSNAME)
  WCLADES=cast(POBJDEST,=WCLASSNAME)
  #=======================================================
  Raz WFIELD : Raz WWTYPEN : Raz WLNKNAME
  WFIELD=PWORDS(0)    : #-- name field or reference name for class linked
  WWTYPEN=PWORDS(1)   : #-- type field
  WLNKNAME=PWORDS(2)  : #-- link class name for level n+1
  # -----------------------------------------------------------------------------
  #------------------ Level three -----------------------------------------------
  # -----------------------------------------------------------------------------
  Raz WTMP :
  #--- Number of lines to get --------------
  WTMP="maxtab(WCLASRC."+PWTMP(0)+WFIELD+")"
  Assign("WCH") With evalue(WTMP)
  If WCH>0
    # ---------------------------------------------------------------------------
    #--- all properties get : XWDATAS5(2) class data name
    #--- XNB number of properties
    # ---------------------------------------------------------------------------
    Raz XWDATAS5
    XNB = func SCDAOHELPER.GETFIELDNAME(WLNKNAME,XWDATAS5)
    For J=1 To WCH :#-- number of lines to dup
       #--- Buil level ---------------------
       #-- create a line for destination ---
       WTMP="" : WTMP=PWTMP(1)
       Assign("WLINE3") With evalue("fmet WCLADES."+WTMP)
       #-- properties set -------------------------------------------------------
       For W=0 To XNB-1
          Raz XWWORDS5 : Raz WFIELD3 : Raz WWTYPEN3
          X = func SPLIT_STRING(XWDATAS5(W),"|",XWWORDS5)
          WFIELD3=XWWORDS5(0)    : #-- name field or reference name for classe linked
          WWTYPEN3 = XWWORDS5(1) : #-- type field
          If WWTYPEN3<>""
           #--- Properties set---------------------------------------------------
           WTMP=""
           WTMP=PWTMP(2)+"("+num$(WLINE3)+")."+WFIELD3
           #---- dup all properties ---------------------------------------------
           Call SETPROPERTIES(WTMP,WWTYPEN3,WFIELD3,PCLASSNAME,WCLASRC,WCLADES,PKEYNAME,PKNEWINT,PKNEWCHR)
          Else
            #--------------------------------------------------------------------
            #-- Reference level 4,5,6,n Recursive loop --------------------------
            #--------------------------------------------------------------------
            If (XWWORDS5(2)<>"") : #-- class name linked
              Raz WWTMP
              WWTMP(0)=PWTMP(0)+WFIELD+"("+num$(WLINE3)+")."
              WWTMP(1)=PWTMP(0)+WFIELD+"("+num$(WLINE3)+")."+"ADDLINE(WFIELD,CST_ALASTPOS)"
              WWTMP(2)=PWTMP(2)+"("+num$(WLINE3)+")."+WFIELD3
              #--------------------------------------------------------------------
              #-- Recursive (Call myself) -----------------------------------------
              #--------------------------------------------------------------------
              Call SETLEVEL(PCLASSNAME,WCLASRC,WCLADES,XWWORDS5,WWTMP,PKEYNAME,PKNEWINT,PKNEWCHR)
            Endif
          Endif
       Next W
    Next J
 Endif : #-- end If WCH>0
End
#=================================================================================
#**
#*
#*
#* @param PROOT
#* @param PLINE
#* @param PWORDS
#* @param POBJSRC   Instance source
#* @param POBJDEST  Instance dest
#* @param PKEYNAME  Name of key (Index key name)
#* @param PKNEWINT  Destination value of key Integer type
#* @param PKNEWCHR  Destination value of key Char type
#*!
Funprog CHECKLEVEL(PROOT,PLINE,PWORDS,POBJSRC,POBJDEST,PKEYNAME,PKNEWINT,PKNEWCHR)
Value Char        PROOT  : #-- namef
Value Integer     PLINE  :
Variable Char     PWORDS()(0..) :
Variable Instance POBJSRC Using OBJECT
Variable Instance POBJDEST Using OBJECT
Value    Char     PKEYNAME  : #-- Key name of index
Value    Integer  PKNEWINT  : #-- value
Value    Char     PKNEWCHR  : #-- value

  Local Char    WDATAS4(40)(0..),WWORDS(40)(0..),XWDATAS4(40)(0..),XWWORDS(40)(0..)
  Local Integer WCH,WCH3, WLINE,WI,I,XNB
  Local Char    XFIELD(40), WFIELD(40),WWTYPEN(40)
  Local Char    WCLASSNAME(40),WLNKNAME(40),WTMP(80)

  #-------Variable name of descriptor class--------------
  WLNKNAME=PWORDS(2)  : #-- link class name for level n+1
  WCLASSNAME="C_"+WLNKNAME

  Local Instance    WCLASRC Using =WCLASSNAME
  Local Instance    WCLADES Using =WCLASSNAME

  #---- Cast for all classes, and copy now --------------
  WCLASRC=cast(POBJSRC,=WCLASSNAME)
  WCLADES=cast(POBJDEST,=WCLASSNAME)

  Raz WDATAS4  : Raz WWORDS : Raz XWDATAS4 : Raz WTMP
  WCH=0 : Raz XFIELD : Raz WWTYPEN
  XFIELD=PWORDS(0)    : #-- name field or reference name for class linked
  WWTYPEN=PWORDS(1)   : #-- type field
  #--- Number of lines to get ------------------------------------------
  WTMP="maxtab(WCLASRC."+PROOT+"("+num$(PLINE)+")."+XFIELD+")"
  Assign("WCH") With evalue(WTMP)
  #--- loop for the number of lines and dup it -------------------------
  If WCH>0
    #---get all fields name
    XNB = func SCDAOHELPER.GETFIELDNAME(WLNKNAME,XWDATAS4)
    # =======================================================
    #-- Loop on number of lines to dup
    # =======================================================
    For WI=1 To WCH  :
    #---------------------------------------------
    #-- create a line for destination instance ---
    #---------------------------------------------
    WTMP="" : WTMP=PROOT+"("+num$(PLINE)+")."
    Assign("WLINE") With evalue("fmet WCLADES."+WTMP+"ADDLINE(XFIELD,CST_ALASTPOS)")
    #-- loop on the fields: XNB number of fields
    For I=0 To XNB-1
      Raz XWWORDS : WTMP=""
      X = func SPLIT_STRING(XWDATAS4(I),"|",XWWORDS)
      WFIELD=XWWORDS(0)    : #-- name field or reference name for class linked
      WWTYPEN = XWWORDS(1) : #-- type field
      If WWTYPEN<>""
        #--- Properties set --------------------------------------------------------
        WTMP=""
        WTMP=PROOT+"("+num$(PLINE)+")."+XFIELD+"("+num$(WLINE)+")."+WFIELD
        Call SETPROPERTIES(WTMP,WWTYPEN,WFIELD,WLNKNAME,WCLASRC,WCLADES,PKEYNAME,PKNEWINT,PKNEWCHR)
        #----End   fere
      Else : #-- WWTYPEN="" : the WFIELD contains the Reference name,XWWORDS(2)=class
        If (XWWORDS(2)<>"")  : #-- class name
          Local Char    WWTMP(80)(3)
          #==========================================================================
          #----level 3 Reference field name -----------------------------------------
          #==========================================================================
          #-- number of lines search by collection name WFIELD
          WTMP="" : Raz WWTMP
          WWTMP(0)=PROOT+"("+num$(PLINE)+")."+XFIELD+"("+num$(WLINE)+")."  :
          WWTMP(1)=PROOT+"("+num$(PLINE)+")."+XFIELD+"("+num$(WLINE)+")."+"ADDLINE(WFIELD,CST_ALASTPOS)"
          WWTMP(2)=PROOT+"("+num$(PLINE)+")."+XFIELD+"("+num$(WLINE)+")."+WFIELD
          #----- Recursive call ------------------------------------------------
          Call SETLEVEL(WLNKNAME,WCLASRC,WCLADES,XWWORDS,WWTMP,PKEYNAME,PKNEWINT,PKNEWCHR)
        Endif : #-- end If XWWORDS(2)<>""
      Endif
    Next I
    Next WI
  Endif
End WCH
#=====================================================================================
#=====================================================================================
#**
#* Call
#* WCHR=func SCHELPER.DUPINSTANCE (SRCCLAS.ObjectType,SRCCLAS,DESTCL,650,"")
#* Or
#* WCHR=func SCHELPER.DUPINSTANCE (SRCCLAS.ObjectType,SRCCLAS,DESTCL,0,"NEWKEY002")
#* Sage R&D 2014 Ltr
#* We take only PKNEWINT or PKNEWCHR not a both
#* If PKNEWINT=0 and PKNEWCHR="" then the destination key is the key of instance source
#* @return table name else null error
#* @param PCLANAME    :  Descriptor name of class (like: C_CLASSNAME)
#* @param POBJECTSRC  :  Instance source
#* @param POBJECTDES  :  Instance destination
#* @param PKNEWINT    :  Destination root key for destination instance type integer
#* @param PKNEWCHR    :  Destination root key for destination instance type char
#*====================================================================================
#*!
Funprog DUPINSTANCE (PCLANAME,POBJECTSRC,POBJECTDES,PKNEWINT,PKNEWCHR)
Value    Char     PCLANAME
Variable Instance POBJECTSRC Using OBJECT
Variable Instance POBJECTDES Using OBJECT
Value    Integer  PKNEWINT   : #--- Destination key if 0  then We take PKNEWCHR
Value    Char     PKNEWCHR   : #--- Destination key if "" then We take PKNEWINT
#-----------------------------------------------------------------------------------
Local Char        WTEXT(60),WTABNAME(30) :
Local Char        WTYPEN(30), NAMEF(30),WBUFF(100)
Local Integer     WNB,I,II,J,K,KK, FOUND,NB,WOK
Local Integer     WNBLK,WNBCO,WMX,JJ,WLINE
Local Char        WDATAS(80)(0..),WSAVELINK(40)(20),WSAVETABLELNK(40)(20)
Local Char        WWORDS(40)(10), WCOLLECT(40)(20)
Local Char        WKEYNAME(40)
#---------------- variable name of descriptor class --------------------------------
Local Instance    WCLASRC Using =PCLANAME
Local Instance    WCLADES Using =PCLANAME

  #-- Table name extract -----------
  WTABNAME=right$(PCLANAME,3)
  #-- Out of process --------------------------------------
  If (POBJECTSRC=null or POBJECTDES=null) : End ""  : Endif
  # -------------------------------------------------------
  # ---- Cast for all classes, and dup now ----------------
  # -------------------------------------------------------
  WCLASRC=cast(POBJECTSRC,=PCLANAME)
  WCLADES=cast(POBJECTDES,=PCLANAME)
  If (WCLASRC=null or WCLADES=null)
    WTABNAME="" : End WTABNAME : #-- end process
  Endif
  # ------------------------------------------------------------------
  #--- Get Key principal name(Index Code) source instance ------------
  # ------------------------------------------------------------------
  If (maxtab(WCLASRC.AKEYS)> 0)
     WKEYNAME=WCLASRC.AKEYS(1)
  Endif
  # -----------------------------------------------------------------
  #-- search link reference
  #------------------------------------------------------------------
  WNB = func SCDAOHELPER.GETLNKCLASS(WTABNAME,WDATAS)
  WNBLK=0
  For I=0 To WNB-1 : #--- number of link reference
    Raz WWORDS
    NB = func SPLIT_STRING(WDATAS(I),"|",WWORDS)
    #---- Search link reference -----------------
    If (NB>0 and WWORDS(0)<>"")
      #---  save ref name ----------
      WSAVELINK(WNBLK)=WWORDS(0) :
      #--- class name if exist------
      WSAVETABLELNK(WNBLK)=WWORDS(2)
      WNBLK+=1
    Endif
  Next : #-- next I
  Raz WWORDS : WNBCO=0 : Raz WDATAS : Raz WCOLLECT
  #----------------------------------------------------------
  #--- Get collection codename ------------------------------
  #----------------------------------------------------------
  WNB = func SCDAOHELPER.GETCOLLECTNAME(WTABNAME,WDATAS)
  For I=0 To WNB-1
    If (WDATAS(I)<>"")
      #---  save ref name -----------------------------------
      KK=0 : FOUND=0
      While ((KK < WNBLK) and (!FOUND) )
         If (WDATAS(I)=WSAVELINK(KK)) :  FOUND = 1 :
         Else
           #----Only collection code, not reference linked---
           WCOLLECT(WNBCO)=WDATAS(I) :
           WNBCO +=1
         Endif
         KK +=1
      Wend
    Endif
  Next I
  #============================================================================
  Raz WDATAS
  #-- get all field name of first instance (record principal)   ---------------
  WNB = func SCDAOHELPER.GETFIELDNAME(WTABNAME,WDATAS)
  #============================================================================
  #--- Loop on all properties -------------------------------------------------
  # of the root record.
  #============================================================================
  For I=0 To WNB-1
    Raz WWORDS : WOK=1
    #--------------------------------------------------------------------------
    #---WWORDS(0)=field name, WWORDS(1)=type field, WWORDS(2)= link table name
    #-- WWORDS(3)= group-collection
    NB = func SPLIT_STRING(WDATAS(I),"|",WWORDS)
    NAMEF=WWORDS(0) :
    #----------------------------------------------
    KK=0 : FOUND=0
    #---- Search ref name -------------------------
    While (KK < WNBLK and !FOUND)
      #---- reference name like a property
      If (WSAVELINK(KK)<>"" and NAMEF=WSAVELINK(KK))
          Local Integer X,XI,XJ, XNB, WCH
          Local Integer RET0 :
          Local Char    XFIELD(30),WTABLNK(30),XWTYPEN(30),WTMP(80)
          Local Char    XWDATAS(60)(0..),XWWORDS(80)(8)
          #-- Tablename linked
          WTABLNK=WSAVETABLELNK(KK)
          WOK=0 :  FOUND=1
          #---- dup collection reference  level 1
          #--- Get Column name of reference class --------------------------------
          XNB = func SCDAOHELPER.GETFIELDNAME(WTABLNK,XWDATAS)
          Assign("WMX") With evalue("maxtab(WCLASRC."+NAMEF+")")
          #====== Loop on number of lines of level 1 =============================
          For JJ = 1 To WMX : #-- number of lines to create
            #--- Create all lines of collection object for destination
            Assign("WLINE") With evalue("fmet WCLADES.ADDLINE(NAMEF,CST_ALASTPOS)")
            If WLINE>0
                For XI=0 To XNB-1  : #--Loop on the number of properties (fields)
                 WTMP="" : Raz XWWORDS
                 X = func SPLIT_STRING(XWDATAS(XI),"|",XWWORDS)
                 XFIELD=XWWORDS(0)    : #-- name field or reference name for classe linked
                 XWTYPEN = XWWORDS(1) : #-- type field
                 #-- Reference name level 2 if exist ------------------------------------
                 If (XWTYPEN="" and XWWORDS(2)<>"")
                   #--- Here,we check level n  : XWWORDS(2)=class name = tablename link
                   RET0 = func CHECKLEVEL(NAMEF,WLINE,XWWORDS,WCLASRC,WCLADES,WKEYNAME,PKNEWINT,PKNEWCHR)
                 Else
                  #----------------------------------------------------------------------
                  WTMP=NAMEF+"("+num$(WLINE)+")."+XFIELD
                  Call SETPROPERTIES(WTMP,XWTYPEN,XFIELD,WTABNAME,WCLASRC,WCLADES,WKEYNAME,PKNEWINT,PKNEWCHR)
                 Endif : #-- end if else XWTYPEN=""
                Next XI
            Endif : #- end WLINE > 0
          Next JJ
          #-----
      Endif : #-- end link
      KK +=1
    Wend
    #==========================================================================
    If WOK<>0 : #-- 1
      FOUND=0 : II=0
      Local Char COLLECTGRP(40)
      #---- collection name = groupe
      COLLECTGRP=WWORDS(3)
      While (II < WNBCO and !FOUND)
        If ((WCOLLECT(II)<>"") and (COLLECTGRP=WCOLLECT(II)))
          # field=collection name
          FOUND=1 :
        Endif
        II +=1
      Wend
      #------------------------------------------------------------------------
      If WOK<>0  : #-- 2
        WTYPEN = WWORDS(1) : #-- type field
        #-- type AXX, AX1, AX3 ,AX2 -------------------------------------------
        If (WTYPEN="AXX" or WTYPEN="AX1" or WTYPEN="AX3" or WTYPEN="AX2")
          #-- Get and Set text
          WOK=0
          Assign("WTEXT") With evalue("fmet WCLASRC."+NAMEF+".AGETTEXT()")
          If (WTEXT<>"")
            Assign("NB") With evalue ("fmet WCLADES."+NAMEF+".ASETTEXT(WTEXT)")
          Endif
        Else

         #--- Collection normal (not reference class) -------------------------
         If FOUND
          #--------------------------------------------------------------------
          #--- Record root level dupli the collection normal--
          #-   This collection does not have a reference class name
          #--------------------------------------------------------------------
          Assign("NB") With evalue("maxtab(WCLASRC."+COLLECTGRP+")")
          For II=1 To NB
             Assign("WLINE") With evalue("fmet WCLADES.ADDLINE(COLLECTGRP,CST_ALASTPOS)")
             If WLINE>0
               WTMP=COLLECTGRP+"("+num$(WLINE)+")."+NAMEF
               Assign("WCLADES."+WTMP) With evalue("WCLASRC."+WTMP)
             Endif
          Next II
         Endif : #-- end FOUND
         If (COLLECTGRP=NAMEF) FOUND=0 : WOK=0 : Endif
        Endif
        #-- not dup -----
        If WOK<>0 : #-- 3
          Case NAMEF :
            When "AUUID","CREDATTIM","UPDDATTIM","CREUSR","UPDUSR" : WOK=0 :
            When "CREDAT","UPDDAT" : WOK=0 :
            When Default :
          Endcase
          #------------------------------------------------------------------
        Endif : #-- end of WOK<>0 : 3
      Endif : #-- end of WOK<>0 : 2
    Endif : #--end of WOK<>0 : 1
    #------------------------------------------------------------------------
    #---------Record principal Assign properties-----------------------------
    #------------------------------------------------------------------------
    If (WOK=1)
       #---- Dup only a simple property of principal record -----------------
       If (WWORDS(3)="" and WWORDS(2)="")
         #----- new key value destination set---
         If ((WKEYNAME=NAMEF) and (PKNEWINT>0 or PKNEWCHR<>"") )
            If (PKNEWINT>0)
              #-- if key property is the integer type -----------
              Assign("WCLADES."+NAMEF) With PKNEWINT
            Else
              #--- if key property is the char type -------------
              Assign("WCLADES."+NAMEF) With PKNEWCHR
            Endif
         Else : #--- others fields
           Assign("WCLADES."+NAMEF) With evalue("WCLASRC."+NAMEF)
         Endif
       Endif
    Endif : #-- end if WOK=1
  Next I : #--- for I
End WTABNAME
#==============================================================================
#**
#*
#*
#* @param PLOG
#* @param PTITLE
#*!
Funprog INITLOG(PLOG,PTITLE)
Variable Instance     PLOG Using C_ALOG
Value    Char         PTITLE
#------------------------------------------------------------------------------
  Local Integer WSTAT,WMEM

  WMEM = (freeheap/1024)
  If (PLOG=null)
     Local Char         WPATH(100)
     PLOG = NewInstance C_ALOG AllocGroup null
     WSTAT = fmet PLOG.ABEGINLOG(PTITLE+"  "+date$+"\")
     #------ set  my name file log --------------------------------------------
     WSTAT = fmet PLOG.ASETNAME("MTCollectLogX3_3")
     #----- allow us to add lines with PLOG.OPENFLG=2 ------------------------
     PLOG.OPENFLG=2 :
     #--- get path of log file in server with AGETNAME
     #WPATH = filpath("TRA",fmet PLOG.AGETNAME,"tra",0)
     #WSTAT = fmet PLOG.APUTLINE("Path and File name by AGETNAME=>"+WPATH+"\",[V]CST_AINFO)
     WSTAT = fmet PLOG.APUTLINE("\==>>>INITLOG date=>"+format$("D:DD[/]MM[/]YYYY[ ]hh[:]mm[:]ss",date$)+"===>Memory init="+num$(WMEM)+"\",[V]CST_AINFO)
     WSTAT = fmet PLOG.AFLUSHLOG
  Endif
End WSTAT
#------------------------------------------------------------------------------------------
Funprog WRITELOG(PLOG,PFLAG,PMESS)
Variable Instance     PLOG Using C_ALOG
Value Integer         PFLAG
Value Char            PMESS
  Local Integer       WSTAT
  #If (PLOG<>null)
  If PFLAG=0
        WSTAT = fmet PLOG.APUTLINE("\***===>"+PMESS,[V]CST_AINFO)
  Else
    If PFLAG=1
      WSTAT = fmet PLOG.APUTLINE("\***===>"+PMESS,[V]CST_AERROR)
    Endif
  Endif
  WSTAT = fmet PLOG.AFLUSHLOG
  If (PFLAG=3)
     #FreeGroup PLOG
  Endif
  #Endif
End WSTAT
#-----------------------------------------------------------------------------------------

Funprog OLDWRITELOG (PLOG,PMESS)
Variable Instance     PLOG Using C_ALOG
Value Char            PMESS

  Local Char         NAMEF(80)
  Local Integer      WSTAT

  If (PLOG=null)
     PLOG = NewInstance C_ALOG AllocGroup null
     #----- allow us to add lines with PLOG.OPENFLG=2 ------------------------
     If PFLAG<>0 : PLOG.OPENFLG=2 : Endif
     WSTAT = fmet PLOG.ABEGINLOG("My title for log date="+date$+"\")
     WSTAT = fmet PLOG.ASETNAME("MyServLogTest")
     #--- get path of log file in server with AGETNAME
     NAMEF = filpath("TRA",fmet PLOG.AGETNAME,"tra",0)
     WSTAT = fmet PLOG.APUTLINE("\Path and File name by AGETNAME=>"+NAMEF,[V]CST_AINFO)
  Endif
  WSTAT = fmet PLOG.APUTLINE("\"+PMESS,[V]CST_AINFO)
End WSTAT
