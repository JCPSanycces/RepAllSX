#<AdxTL>@(#)0.0.0.0 $Revision$Class Employee ID
# Supervisor
## ATY-ATYPE ## EML
# 2018-11-09 07:14:11 765

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,REFNUM,AENABLE,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char REFNUM
Value Tinyint AENABLE
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File EMPLOID [ID]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".EMPLOID" [ID]
Endif

Default File [F:ID]
Read [F:ID]ID0 = [L]REFNUM
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]REFNUM)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]REFNUM)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

If dim([F:ID]ENAFLG) & [F:ID]ENAFLG<>2 : # Inactive record
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]REFNUM)-":"-mess(2,126,1),[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


