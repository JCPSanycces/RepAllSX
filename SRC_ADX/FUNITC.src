#<AdxTL>@(#)10.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
# Gestion des coûts standard - standard actualisé - budget - simulé
# ------------------------------------------------------------------------------------------# 
# Colonne 1 (coût standard) Table principale de l'objet    Zone STDCST 
# Colonne 2 (coût actualisé)                               Zone ACTCST 
# Colonne 3 (coût budget)                                  Zone BUDCST 
# Colonne 4 (coût simulé)                                  Zone SIMCST 
 
$ACTION
#If GTRACE=""
#    Call OUVRE_TRACE("ITC") From LECFIC
#Endif
#Call ECR_TRACE(ACTION,0) From GESECRAN

If dim(GCCTEST)<=0
    Global Char GCCTEST
Endif
Case ACTION
 When "AFFMASK"    Gosub AFFMASK
 When "SETBOUT"    Gosub SETBOUT 
 When "AVANTBOUT"  Gosub AVANTBOUT 
 When "EXEBOUT"    Gosub EXEBOUT
 When "LIENS"      Gosub LIENS
 When "FILTRE"     Gosub FILTRE
 When "OUVRE"      Gosub OUVRE
 When "AFFMASK"    Gosub AFFMASK
 When "FERME"      Gosub FERME : Call SUPP_TRACE From LECFIC : Kill GCCTEST
 When "INICRE"     Gosub INICRE
 When "INIMOD"     Gosub INIMOD 
 When "CREATION"   Gosub CREATION
#                   Gosub APRES_MOD  # rétablir ici la classe F Bug 18928 (29/07/03)
 When "RAZCRE"     Gosub RAZCRE 
 When "RAZDUP"     Gosub RAZDUP 
 When "VERIF_CRE"  Gosub VERIF_CRE 
 When "VERIF_MOD"  Gosub VERIF_CRE 
 When "APRES_MODIF" Gosub APRES_MODIF 
 When "APRES_MOD"  Gosub APRES_MOD # pas ici car AFF_CLE est déjà fait ! 29/07/03
 When "APRES_CRE"  Gosub APRES_MOD 
 When "MODIF"      Gosub MODIF
#                   Gosub APRES_MOD  # rétablir ici la classe F Bug 18928 (29/07/03)
 When "ABANDON"    Gosub ABANDON
 When "VERF_ANU"   Gosub VERF_ANU     # (TB 04/12/02) Bug 8304...
 When "FIN_ACTION" If REPONSE=GSTAANU
                      Raz [M:ITC1]STDUPD, [M:ITC1]ACTUPD, [M:ITC1]BUDUPD, [M:ITC1]SIMUPD
                      # pas connues dans le sous-pro ANU
                   Endif
 When Default
Endcase
Return

$AFFMASK
#   Chgfmt [M:ITC5]BUD2 With "-N:6.2"
#    Titcol [M:ITC5]NBLIG4 "std","act","","sim"
#Affzo [M:ITC5]
   Diszo [M:ITC1]STDCST(5)
   Diszo [M:ITC1]STDCST(6)
   Diszo [M:ITC1]ACTCST(5)
   Diszo [M:ITC1]ACTCST(6)
   Diszo [M:ITC1]BUDCST(5)
   Diszo [M:ITC1]BUDCST(6)
   Diszo [M:ITC1]SIMCST(5)
   Diszo [M:ITC1]SIMCST(6)
Return

$SETBOUT 
CHMEN += "S"
Gosub SET_BOUT_SPE From GSAISIE
#If CLECUR = 0  
#    Call VIREBOUT(CHAINE,"123") From GOBJET  
#Endif  
# Accès à l'historique seulement hors d'une modif 
If GREP <> "" 
    Call VIREBOUT(CHAINE,"1") From GOBJET   
Endif 
If GCONSULT
    Call VIREBOUT(CHAINE,"23") From GOBJET  
Endif
# Objet à 5 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré ! 04/12/02
# (s'il n'y a pas d'interface comptable des variations de coûts et si l'user a le droit)

#If CLECUR & SUPPR
# # If GACCCSTIFA < 2  
#  If GACCCSTENT = "" # seule condition en v 140: code pièce auto
#    CHAINE+="A"  
#  Endif
#Endif
If REP<>""
    If [M:ITC1]STDUPD>=1
        Chgtbk [M:ITC1]15 With mess(1,219,1)-"*"
    Endif
    If [M:ITC1]ACTUPD>=1
        Chgtbk [M:ITC1]20 With mess(2,219,1)-"*"
    Endif
    If [M:ITC1]BUDUPD>=1
        Chgtbk [M:ITC1]25 With mess(3,219,1)-"*"
    Endif
    If [M:ITC1]SIMUPD>=1
        Chgtbk [M:ITC1]30 With mess(4,219,1)-"*"
    Endif
Endif
Return  

$AVANTBOUT
# positionner les var globales que si on vient du menu Couts standard
If BOUT = "1" & GFONC1 = "GESITC"  
   GFLTITM = [M:ITC0]ITMREF  # pour historique
   GFLTFCY = [M:ITC0]STOFCY   
Endif 
Return

$EXEBOUT
Case REP
  When "1"  
      ## Gosub HISTO   # v 140 : remplacé par action GOBJETC0
      If GFONC1 = "GESITC"  
        GFLTITM = ""  
        GFLTFCY = ""  
      Endif  
  When "2"       
   #  création d'un nouveau cout actual. incrément du n° de séquence
      Effzo [M:ITC1]ACTCST
      Raz [M:ITCA]
      [M:ITCA] = [M:ITC0]
      EXI_ACT = 0 : # pour revenir à un cas de création
#      Disable GSTABOU+1 OU Call SETBOUT(GETABOU) ou Gosub SETBOUT From GOBJSUB
#      n'ont pas d'effet car ne rafraichissent pas aussitôt les btn !!!
      SUIZON = "ACTSTR"
  When "3" 
   #  création d'un nouveau cout simulé incrément du n° de séquence
      Effzo [M:ITC1]SIMCST
      Raz [M:ITCS]
      [M:ITCS] = [M:ITC0]
      EXI_SIM = 0 : # pour revenir à un cas de création
      SUIZON = "SIMSTR"
Endcase
Return

$HISTO 
CLE_ITC(0) = [M:ITC0]STOFCY 
CLE_ITC(1) = "2" 
CLE_ITC(2) = num$([M:ITC0]ITCSEQ)  
CLE_ART    = [M:ITC0]ITMREF : # pour ne pas ecraser itmref au retour  
# positionner les var globales que si on vient du menu Couts standard 
If GFONC1 = "GESITC"
   GFLTITM = [M:ITC0]ITMREF 
   GFLTFCY = [M:ITC0]STOFCY   
Endif 
Call OBJET("HIC",CLE_ART,CLE_ITC) From GOBJET   #>> voir si ça marche en Web (?)
# ATTENTION aux var globales pour le prochain filtre !  
If GFONC1 = "GESITC"  
   GFLTITM = ""  
   GFLTFCY = ""  
Endif  
Return 
 
$OUVRE
Local Integer I, IMAT, CREE_OK
Local Integer ICN_UPD  # mise à jour détail nature après modif FG Bug 20372 (04/12/03)
#Local Integer EXI_ACT, EXI_BUD, EXI_SIM  
Local Char    TYP(3)
Local Char    CLE_ITC(4)(4), CLE_ART(GLONITM) 

Local Char    CLE_FIC(30)(1..5)  : # pour interface compta
Local Char    MSG_CPTA(250)
Local Integer WRETOUR

Local Decimal OLD_CST
Local Date    OLD_DAT      : # pour l'interface des coûts std (29/03/01)
Local Integer DIFF_CST     : # 1 : il y a une différence à passer en compta

Local Date    LDATREF

If dim(GSAIDECPRI)<=0
    Global Integer GSAIDECPRI    # Passée en paramètre AFFMSK de l'action SAIDECPRI. Détermine ce qui peut être saisi
Endif

Local Mask SAIDECPRI  [SDP]  : # pour détails de coûts std  (ABV <> de celle du dico !)
Local Mask SAIDECPRI  [ITCD]  : # pour détails de coûts std  (ABV <> de celle du dico !)
Local Mask SAIDECPRI  [ITCA]  : # pour détails de coûts actualisés 
Local Mask SAIDECPRI  [ITCB]  : # pour détails de coûts budget 
Local Mask SAIDECPRI  [ITCS]  : # pour détails de coûts simulés 

Local Mask SAIDECPRI  [ICLD]  : # pour détails de coûts niveau std  (ABV <> de celle du dico !)
Local Mask SAIDECPRI  [ICLA]  : # pour détails de coûts niveau actualisés 
Local Mask SAIDECPRI  [ICLB]  : # pour détails de coûts niveau budget 
Local Mask SAIDECPRI  [ICLS]  : # pour détails de coûts niveau simulés 

If !clalev([F:ITC])  : Local File ITMCOST [ITC]   : Endif  : # Pour std
If !clalev([F:ITCA]) : Local File ITMCOST [ITCA]  : Endif  : # Pour std Actualisé
If !clalev([F:ITCB]) : Local File ITMCOST [ITCB]  : Endif  : # Pour std Budget
If !clalev([F:ITCS]) : Local File ITMCOST [ITCS]  : Endif  : # Pour Simulation
If !clalev([F:ITC2]) : Local File ITMCOST [ITC2]  : Endif  : # pour lire l'ancien coût (pour passage compta)
If !clalev([F:ITF])  : Local File ITMFACILIT [ITF]: Endif
If !clalev([F:TCU])  : Local File TABCUR  [TCU]   : Endif
If !clalev([F:ITV])  : Local File ITMMVT  [ITV]   : Endif
If !clalev([F:ITH])  : Local File ITMMVTHIS  [ITH]: Endif
If !clalev([F:TCM])  : Local File TABCOSTMET [TCM]: Endif
If !clalev([F:ICN])  : Local File ITCNAT  [ICN]   : Endif   : # natures à mettre en phase 20372  (04/12/03)
If !clalev([F:STJ])  : Local File STOJOU  [STJ]   : Endif   : # pour mvt chgt de valeur v140
If !clalev([F:STJ1]) : Local File STOJOU  [STJ1]  : Endif  : # pour sous-pro d'écriture de stock
If !clalev([F:PER])  : Local File PERIOD     [PER]: Endif  # pour lire FIY et ITH
If !clalev([F:FIY])  : Local File FISCALYEAR [FIY]: Endif

# Indices des lignes pour les différentes composantes
Local Integer LINDSTR, LINDEND, LINDMAT, LINDMAC, LINDLAB, LINDSCO, LINDOVE, LINDCST, LINDVLT

Local Integer ITF_UPD

#[M:ITC1]FMTLIG(0) = "N3z:11."+num$(GDECPRI) : # pour que les formats variables soient
                             # numériques dès l'ouverture (GDECPRI  07/02/02)
Return


$FERME 
If clalev([M:HIC2]) & dim(GFLTDAT)>0
    Raz GFLTDAT
Endif
If GFONC1 = "GESITC" Raz GFONC1 : Endif 
Kill GSAIDECPRI
Return 
 
$FILTRE
# pour éviter de filtrer depuis la Comparaison des coûts :
If clalev ([M:ICM0]) > 0 : Return : Endif
Raz IFILTSUP
Call ADDCRIT(FILTSUP,IFILTSUP,"","CSTTYP=1","&") From GOBJSUB
Call ADDCRIT(FILTSUP,IFILTSUP,"","UID=0","&") From GOBJSUB
If GFLTITM <> ""
    Call ADDCRIT(FILTSUP,IFILTSUP,"","ITMREF=GFLTITM","&") From GOBJSUB
Endif
If GFLTFCY <> ""
    Call ADDCRIT(FILTSUP,IFILTSUP,"","STOFCY=GFLTFCY","&") From GOBJSUB
Endif
If clalev([M:HIC2]) & dim(GFLTDAT)>0 & GFLTDAT>[0/0/0]
    Call ADDCRIT(FILTSUP,IFILTSUP,"","ITMREF=[M:HIC0]ITMREF","&") From GOBJSUB
    Call ADDCRIT(FILTSUP,IFILTSUP,"","STOFCY=[M:HIC0]STOFCY","&") From GOBJSUB
    Filter [ITC] Where ITMREF = [M:HIC0]ITMREF
&                    & STOFCY = [M:HIC0]STOFCY
&                    & UID    = 0
&                    & CSTTYP = 1
&                    & ITCSTRDAT<=GFLTDAT
    Read [ITC] First
    [M:ITC0]DATREF = GFLTDAT
    Filter [ITC]
Endif
Return

$RAZCRE 
# Vider obligatoirement les écrans annexes car ce ne sont pas des écrans de l'objet 
Raz [M:ITCA], [M:ITCB], [M:ITCS], [M:ITCD] 
Raz OLD_CST, OLD_DAT, DIFF_CST
For nolign=1 To 7
  [M:ITC1]FMTLIG(nolign-1) = "N3z:11."+num$(GDECPRI) # (correction 25/06/01 pour tunnel)
Next
# v 140 Depuis article ou art-site on passe en création en mettant l'année
If GFLTITM <> ""
  If [F:ITM]ITMREF <> GFLTITM
     Read [ITM]ITM0=GFLTITM
  Endif
  [M:ITC0] = [F:ITM] # pour TCLCOD,BRDCOD, STU #CCC (30/07/04) bug 23924 :et PRIDIV
  If [M:ITC0]STOFCY <> ""
     Read [ITF]ITF0=GFLTITM;[M:ITC0]STOFCY
     # alimenter les zones reprises de ITF
     [M:ITC0] = [F:ITF]    # 17/04/03 (résoudrait le 17728) v 140 ? > aussi en razdup ?
  Endif
  Affzo [M:ITC0]10,15
Endif
#---- Sections ana saisissables ------#
[M:ITC0]CCECODS = 1

Return  

$RAZDUP
Raz OLD_CST, OLD_DAT, DIFF_CST
#---- Sections ana saisissables ------#
[M:ITC0]CCECODS = 1

Return
 
$LIENS
Chgtbk [M:ITC1]15 With mess(1,219,1)
Chgtbk [M:ITC1]20 With mess(2,219,1)
Chgtbk [M:ITC1]25 With mess(3,219,1)
Chgtbk [M:ITC1]30 With mess(4,219,1)

Diszo [M:ITC2]STDCST,ACTCST,BUDCST,SIMCST
Diszo [M:ITC2]STDSTR,ACTSTR,BUDSTR,SIMSTR
Diszo [M:ITC2]STDEND,ACTEND,BUDEND,SIMEND

# On décharge le coût précédent
Raz [M:ITCD],[M:ITCA],[M:ITCB],[M:ITCS]
Raz [M:ICLD],[M:ICLA],[M:ICLB],[M:ICLS]

#Chargement article et site
[M:ITCD] = [M:ITC0]
[M:ITCA] = [M:ITC0]
[M:ITCB] = [M:ITC0]
[M:ITCS] = [M:ITC0]
[M:ICLD] = [M:ITC0]
[M:ICLA] = [M:ITC0]
[M:ICLB] = [M:ITC0]
[M:ICLS] = [M:ITC0]

# Affectation de la date de référence 
If [M:ITC0]DATREF=[0/0/0] & LDATREF=[0/0/0]
    If [F:ITC]ITCSTRDAT<>[0/0/0]
        [M:ITC0]DATREF = [F:ITC]ITCSTRDAT
    Elsif [F:ITC]ITCENDDAT>date$
        [M:ITC0]DATREF = date$
    Else
        [M:ITC0]DATREF = [F:ITC]ITCENDDAT
    Endif
    LDATREF=[M:ITC0]DATREF
Else
    If LDATREF<[F:ITC]ITCSTRDAT
        [M:ITC0]DATREF=[F:ITC]ITCSTRDAT
    Elsif LDATREF>[F:ITC]ITCENDDAT
        [M:ITC0]DATREF=[F:ITC]ITCENDDAT
    Else
        [M:ITC0]DATREF=LDATREF
    Endif
Endif

Read [ITM]ITM0 = [F:ITC]ITMREF
#CCC (30/07/04) bug 23924 :[M:ITC0]PRIDIV = [F:ITM]PRIDIV
[M:ITC0]TCLCOD = [F:ITM]TCLCOD
[M:ITC0]BRDCOD = [F:ITM]BRDCOD
[M:ITC0]STU    = [F:ITM]STU

Read [ITF]ITF0 = [F:ITC]ITMREF;[F:ITC]STOFCY
If !fstat
# alimenter codes màj coûts    ## >> rajouter méthode de valo ?
   [M:ITC0] = [F:ITF]          #17/04/03
Endif
# Affectation du Format des numériques selon ligne : 7 montants puis qté
Call GETDEV([M:ITC0]STOFCY) From DEVSUB  # charge GLOCALDEV
For nolign =1 To 7
   [M:ITC1]FMTLIG(nolign-1) = "N3z:11."+num$(GDECPRI) # Utilisation de GDECPRI pour correction bug 7164  (30/01/01)
   [M:ITC2]FMTLIG(nolign-1) = "N3z:11."+num$(GDECPRI)
Next
Call FMTQTY([F:ITM]STU) From TRTDIV
[M:ITC1]FMTLIG(7) = "Nz:" + GFMTQTY

[M:ITCD] = [F:ITC] :  # écran détail
[M:ITCD]QTY = [F:ITC]CLCQTY
[M:ITCD]UOM = [F:ITM]STU
[M:ITCD]PRI = [F:ITC]VLTTOT
[M:ITCD]CUR = GLOCALDEV

Link [ICN] With [ONA]ONA0=[F:ICN]OVENAT
&          As [LNK]
&          Where ITMREF = [F:ITC]ITMREF
&              & STOFCY = [F:ITC]STOFCY
&              & CSTTYP = [F:ITC]CSTTYP
&              & ITCSEQ = [F:ITC]ITCSEQ
&              & UID    = [F:ITC]UID
For [LNK]
    [M:ITCD]OVENAT([M:ITCD]NBONA) = [F:ICN]OVENAT
    [M:ITCD]ONATYP([M:ITCD]NBONA) = [F:ONA]TYPCST
    [M:ITCD]ONAAMT([M:ITCD]NBONA) = [F:ICN]NATAMTSSE+[F:ICN]NATAMTLEV
    [M:ITCD]NBONA += 1
Next

# Chargement de la colonne Cout STANDARD
[M:ITC1]STDSTR    = [F:ITC]ITCSTRDAT
[M:ITC1]STDEND    = [F:ITC]ITCENDDAT
[M:ITC1]STDSEQ    = [F:ITC]ITCSEQ
Call DET2ITC1(1)    # Charge STDCST(0..6) à partir de M:ITCD
[M:ITC1]STDCST(7) =     [F:ITC]CLCQTY   : # Qté de calcul

# Chargement de la colonne Cout STANDARD coût niveau
[M:ICLD] = [F:ITC]
Call LEV2MSK("ICLD","ITC")
[M:ITC2]STDSTR    = [F:ITC]ITCSTRDAT
[M:ITC2]STDEND    = [F:ITC]ITCENDDAT
Call DET2ITC2(1)    # Charge STDCST(0..6) à partir de M:ICLD
[M:ITC2]STDCST(7) =     [F:ITC]CLCQTY   : # Qté de calcul

# Paramètres de calcul du coût standard
[M:ITC3]ITCDATSTD = [F:ITC]ITCDAT
[M:ITC3]ROUALTSTD = [F:ITC]ROUALT
[M:ITC3]BOMALTSTD = [F:ITC]BOMALT
[M:ITC3]SLTMATSTD = [F:ITC]SLTMATCST
[M:ITC3]VLTCCESTD = [F:ITC]VLTCCERAT
[M:ITC3]FXDCSTSTD = [F:ITC]FXDCSTDSP
[M:ITC3]SLTOVESTD = [F:ITC]SLTOVECOL
[M:ITC3]DESCSTD   = [F:ITC]DESCEND

# Chargement des couts type std actualisés
Filter [ITCA] Where STOFCY=[F:ITC]STOFCY & ITMREF=[F:ITC]ITMREF
&                 & CSTTYP = 2 & ITCSTRDAT<=[M:ITC0]DATREF & [M:ITC0]DATREF<=ITCENDDAT
&                 & UID = 0
Read [ITCA]ITC0 First
Filter [ITCA]
If !fstat
    [M:ITCA] = [F:ITCA] :  # écran détail 
    [M:ITCA]QTY = [F:ITCA]CLCQTY
    [M:ITCA]UOM = [F:ITM]STU
    [M:ITCA]PRI = [F:ITCA]VLTTOT
    [M:ITCA]CUR = GLOCALDEV
    Link [ICN] With [ONA]ONA0=[F:ICN]OVENAT
&              As [LNK]
&              Where ITMREF = [F:ITCA]ITMREF
&                  & STOFCY = [F:ITCA]STOFCY
&                  & CSTTYP = [F:ITCA]CSTTYP
&                  & ITCSEQ = [F:ITCA]ITCSEQ
&                  & UID    = [F:ITCA]UID
    For [LNK]
        [M:ITCA]OVENAT([M:ITCA]NBONA) = [F:ICN]OVENAT
        [M:ITCA]ONATYP([M:ITCA]NBONA) = [F:ONA]TYPCST
        [M:ITCA]ONAAMT([M:ITCA]NBONA) = [F:ICN]NATAMTSSE+[F:ICN]NATAMTLEV
        [M:ITCA]NBONA += 1
    Next

    [M:ITC1]ACTSTR    = [F:ITCA]ITCSTRDAT
    [M:ITC1]ACTEND    = [F:ITCA]ITCENDDAT
    [M:ITC1]ACTSEQ    = [F:ITCA]ITCSEQ
    Call DET2ITC1(2)    # Charge ACTCST(0..6) à partir de M:ITCA
    [M:ITC1]ACTCST(7) =     [F:ITCA]CLCQTY   : # Qté de calcul

    #--- Chargement masque Coût du niveau ---#
    Call LEV2MSK("ICLA","ITCA")
    [M:ITC2]ACTSTR    = [F:ITCA]ITCSTRDAT
    [M:ITC2]ACTEND    = [F:ITCA]ITCENDDAT
    Call DET2ITC2(2)    # Charge ACTCST(0..6) à partir de M:ICLA
    [M:ITC2]ACTCST(7) =     [F:ITCA]CLCQTY   : # Qté de calcul

    # Paramètres de calcul du coût standard
    [M:ITC3]ITCDATACT = [F:ITCA]ITCDAT
    [M:ITC3]ROUALTACT = [F:ITCA]ROUALT
    [M:ITC3]BOMALTACT = [F:ITCA]BOMALT
    [M:ITC3]SLTMATACT = [F:ITCA]SLTMATCST
    [M:ITC3]VLTCCEACT = [F:ITCA]VLTCCERAT
    [M:ITC3]FXDCSTACT = [F:ITCA]FXDCSTDSP
    [M:ITC3]SLTOVEACT = [F:ITCA]SLTOVECOL
    [M:ITC3]DESCACT   = [F:ITCA]DESCEND
    
#    EXI_ACT = 1 
Else  
    Raz [M:ITC1]ACTCST
    Raz [M:ITC2]ACTCST
    [M:ITC3]ITCDATACT = [00/00/00]
    [M:ITC3]ROUALTACT = 0
    [M:ITC3]BOMALTACT = 0
    [M:ITC3]SLTMATACT = 0
    [M:ITC3]VLTCCEACT = 0
    [M:ITC3]FXDCSTACT = 0
    [M:ITC3]SLTOVEACT = 0
    [M:ITC3]DESCACT   = 0
#    EXI_ACT = 0  
Endif

# Chargement des couts type Budget
Filter [ITCB] Where STOFCY=[F:ITC]STOFCY & ITMREF=[F:ITC]ITMREF
&      & CSTTYP = 3 & ITCSTRDAT<=[M:ITC0]DATREF & [M:ITC0]DATREF<=ITCENDDAT
&      & UID = 0
Read [ITCB]ITC0 First
Filter [ITCB]
If !fstat
    [M:ITCB] = [F:ITCB] :  # écran détail 
    [M:ITCB]QTY = [F:ITCB]CLCQTY
    [M:ITCB]UOM = [F:ITM]STU
    [M:ITCB]PRI = [F:ITCB]VLTTOT
    [M:ITCB]CUR = GLOCALDEV
    Link [ICN] With [ONA]ONA0=[F:ICN]OVENAT
&              As [LNK]
&              Where ITMREF = [F:ITCB]ITMREF
&                  & STOFCY = [F:ITCB]STOFCY
&                  & CSTTYP = [F:ITCB]CSTTYP
&                  & ITCSEQ = [F:ITCB]ITCSEQ
&                  & UID    = [F:ITCB]UID
    For [LNK]
        [M:ITCB]OVENAT([M:ITCB]NBONA) = [F:ICN]OVENAT
        [M:ITCB]ONATYP([M:ITCB]NBONA) = [F:ONA]TYPCST
        [M:ITCB]ONAAMT([M:ITCB]NBONA) = [F:ICN]NATAMTSSE+[F:ICN]NATAMTLEV
        [M:ITCB]NBONA += 1
    Next

    [M:ITC1]BUDSTR    = [F:ITCB]ITCSTRDAT
    [M:ITC1]BUDEND    = [F:ITCB]ITCENDDAT
    [M:ITC1]BUDSEQ    = [F:ITCB]ITCSEQ
    Call DET2ITC1(3)    # Charge BUDCST(0..6) à partir de M:ITCB
    [M:ITC1]BUDCST(7) =     [F:ITCB]CLCQTY   : # Qté de calcul

    #--- Chargement masque Coût du niveau ---#
    Call LEV2MSK("ICLB","ITCB")
    [M:ITC2]BUDSTR    = [F:ITCB]ITCSTRDAT
    [M:ITC2]BUDEND    = [F:ITCB]ITCENDDAT
    Call DET2ITC2(3)    # Charge BUDCST(0..6) à partir de M:ICLB
    [M:ITC2]BUDCST(7) =     [F:ITCB]CLCQTY   : # Qté de calcul

    # Paramètres de calcul du coût standard
    [M:ITC3]ITCDATBUD = [F:ITCB]ITCDAT
    [M:ITC3]ROUALTBUD = [F:ITCB]ROUALT
    [M:ITC3]BOMALTBUD = [F:ITCB]BOMALT
    [M:ITC3]SLTMATBUD = [F:ITCB]SLTMATCST
    [M:ITC3]VLTCCEBUD = [F:ITCB]VLTCCERAT
    [M:ITC3]FXDCSTBUD = [F:ITCB]FXDCSTDSP
    [M:ITC3]SLTOVEBUD = [F:ITCB]SLTOVECOL
    [M:ITC3]DESCBUD   = [F:ITCB]DESCEND

#  EXI_BUD = 1 
Else  
    Raz [M:ITC1]BUDCST
    [M:ITC3]ITCDATBUD = [00/00/00]
    [M:ITC3]ROUALTBUD = 0
    [M:ITC3]BOMALTBUD = 0
    [M:ITC3]SLTMATBUD = 0
    [M:ITC3]VLTCCEBUD = 0
    [M:ITC3]FXDCSTBUD = 0
    [M:ITC3]SLTOVEBUD = 0
    [M:ITC3]DESCBUD   = 0
#    EXI_BUD = 0  
Endif

# Chargement des couts type simulés
Filter [ITCS] Where STOFCY=[F:ITC]STOFCY & ITMREF=[F:ITC]ITMREF
&      & CSTTYP = 4 & ITCSTRDAT<=[M:ITC0]DATREF & [M:ITC0]DATREF<=ITCENDDAT
&      & UID=0
Read [ITCS]ITC0 First
Filter [ITCS]
If !fstat
    [M:ITCS] = [F:ITCS] :  # écran détail 
    [M:ITCS]QTY = [F:ITCS]CLCQTY
    [M:ITCS]UOM = [F:ITM]STU
    [M:ITCS]PRI = [F:ITCS]VLTTOT
    [M:ITCS]CUR = GLOCALDEV
    Link [ICN] With [ONA]ONA0=[F:ICN]OVENAT
&              As [LNK]
&              Where ITMREF = [F:ITCS]ITMREF
&                  & STOFCY = [F:ITCS]STOFCY
&                  & CSTTYP = [F:ITCS]CSTTYP
&                  & ITCSEQ = [F:ITCS]ITCSEQ
&                  & UID    = [F:ITCS]UID
    For [LNK]
        [M:ITCS]OVENAT([M:ITCS]NBONA) = [F:ICN]OVENAT
        [M:ITCS]ONATYP([M:ITCS]NBONA) = [F:ONA]TYPCST
        [M:ITCS]ONAAMT([M:ITCS]NBONA) = [F:ICN]NATAMTSSE+[F:ICN]NATAMTLEV
        [M:ITCS]NBONA += 1
    Next

    [M:ITC1]SIMSTR    = [F:ITCS]ITCSTRDAT
    [M:ITC1]SIMEND    = [F:ITCS]ITCENDDAT
    [M:ITC1]SIMSEQ    = [F:ITCS]ITCSEQ
    Call DET2ITC1(4)    # Charge SIMCST(0..6) à partir de M:ITCS
    [M:ITC1]SIMCST(7) =     [F:ITCS]CLCQTY   : # Qté de calcul
    
    #--- Chargement masque Coût du niveau ---#
    Call LEV2MSK("ICLS","ITCS")
    [M:ITC2]SIMSTR    = [F:ITCS]ITCSTRDAT
    [M:ITC2]SIMEND    = [F:ITCS]ITCENDDAT
    Call DET2ITC2(4)    # Charge SIMCST(0..6) à partir de M:ICLS
    [M:ITC2]SIMCST(7) =     [F:ITCS]CLCQTY   : # Qté de calcul

    # Paramètres de calcul du coût standard
    [M:ITC3]ITCDATSIM = [F:ITCS]ITCDAT
    [M:ITC3]ROUALTSIM = [F:ITCS]ROUALT
    [M:ITC3]BOMALTSIM = [F:ITCS]BOMALT
    [M:ITC3]SLTMATSIM = [F:ITCS]SLTMATCST
    [M:ITC3]VLTCCESIM = [F:ITCS]VLTCCERAT
    [M:ITC3]FXDCSTSIM = [F:ITCS]FXDCSTDSP
    [M:ITC3]SLTOVESIM = [F:ITCS]SLTOVECOL
    [M:ITC3]DESCSIM   = [F:ITCS]DESCEND

#  EXI_SIM = 1 
Else  
    Raz [M:ITC1]SIMCST
    [M:ITC3]ITCDATSIM = [00/00/00]
    [M:ITC3]ROUALTSIM = 0
    [M:ITC3]BOMALTSIM = 0
    [M:ITC3]SLTMATSIM = 0
    [M:ITC3]VLTCCESIM = 0
    [M:ITC3]FXDCSTSIM = 0
    [M:ITC3]SLTOVESIM = 0
    [M:ITC3]DESCSIM   = 0
#    EXI_SIM = 0  
Endif


# Art fabriqué : on saisit tout
If [F:ITM]MFGFLG=2
   GSAIDECPRI = 1
   Actzo [M:ITC1]STDCST(1)
   Actzo [M:ITC1]STDCST(2)
   Actzo [M:ITC1]STDCST(3)
   Actzo [M:ITC1]ACTCST(1)
   Actzo [M:ITC1]ACTCST(2)
   Actzo [M:ITC1]ACTCST(3)
   Actzo [M:ITC1]BUDCST(1)
   Actzo [M:ITC1]BUDCST(2)
   Actzo [M:ITC1]BUDCST(3)
   Actzo [M:ITC1]SIMCST(1)
   Actzo [M:ITC1]SIMCST(2)
   Actzo [M:ITC1]SIMCST(3)
# si article sous-traité on saisit matière + ss-trait + fg
Elsif [F:ITM]SCPFLG=2
   GSAIDECPRI = 4+32+64+128    # Matière + sous-traitance + FG + natures
   Grizo [M:ITC1]STDCST(1)
   Grizo [M:ITC1]STDCST(2)
   Actzo [M:ITC1]STDCST(3)
   Grizo [M:ITC1]ACTCST(1)
   Grizo [M:ITC1]ACTCST(2)
   Actzo [M:ITC1]ACTCST(3)
   Grizo [M:ITC1]BUDCST(1)
   Grizo [M:ITC1]BUDCST(2)
   Actzo [M:ITC1]BUDCST(3)
   Grizo [M:ITC1]SIMCST(1)
   Grizo [M:ITC1]SIMCST(2)
   Actzo [M:ITC1]SIMCST(3)
#sinon seuls le cout matière et les FG sont saisis
Else
   GSAIDECPRI = 4+64+128    # Matière + FG + natures
   Grizo [M:ITC1]STDCST(1)
   Grizo [M:ITC1]STDCST(2)
   Grizo [M:ITC1]STDCST(3)
   Grizo [M:ITC1]ACTCST(1)
   Grizo [M:ITC1]ACTCST(2)
   Grizo [M:ITC1]ACTCST(3)
   Grizo [M:ITC1]BUDCST(1)
   Grizo [M:ITC1]BUDCST(2)
   Grizo [M:ITC1]BUDCST(3)
   Grizo [M:ITC1]SIMCST(1)
   Grizo [M:ITC1]SIMCST(2)
   Grizo [M:ITC1]SIMCST(3)
Endif 

#--------- Initialisation des sections ana en cas modif ------------#
Call INITCCE


Gosub CHARG_GRAPH From SUBITCG

Return

#######################################################
$ABANDON
Raz [M:ITC1]STDUPD, [M:ITC1]ACTUPD, [M:ITC1]BUDUPD, [M:ITC1]SIMUPD
Return
 
#######################################################
# Annulation des enreg coûts pour autant que le paramétrage le permette 04/12/02 (bug 8304)
$VERF_ANU
# >>  rajouter un message de confirmation 'Tous les types seront supprimés...'
If !clalev([ICN]) Local File ITCNAT [ICN] Endif # ouvert en OUVRE (04/12/03)
Call DEBTRANS From GLOCK
Trbegin [ITC]
Delete [ITC] Where STOFCY=[M:ITC0]STOFCY & ITMREF=[M:ITC0]ITMREF & ITCSEQ=[M:ITC0]ITCSEQ & UID=0
If fstat = 1  : # enreg locké
   GLOCK = "$ITMCOST" : Goto ROLL_ANN
Endif

# suppression des détails nature
Delete [ICN] Where STOFCY=[M:ITC0]STOFCY & ITMREF=[M:ITC0]ITMREF & ITCSEQ=[M:ITC0]ITCSEQ & UID=0
If fstat = 1  : # enreg locké
   GLOCK = "$ITCNAT" : Goto ROLL_ANN
Endif

Commit
Call MESSAGE(mess(411,197,1)) From GESECRAN
Effzo [M:ITC0]
Effzo [M:ITC1]
OK = 0 :# pour ne pas passer dans la suppression standard
Return

#######################################################
$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL 
  OK = 0 :# pour ne pas passer dans la suppression standard
  Return 
Else 
  Goto VERF_ANU 
Endif

#######################################################
$AB_ANN
Rollback
Call ERREUR(mess(14,100,1)) From GESECRAN
OK = 0 :# pour ne pas passer dans la suppression standard
Return

#######################################################
$VERIF_CRE 
If sigma(I=0,6,[M:ITC1]STDCST(I)) = 0 
    Call OUINON(mess(202,199,1),CREE_OK) From GESECRAN 
    If CREE_OK = 1
      OK = 0 
    Endif
Endif
# Vérifier que la quantité est renseignée quand le total est non nul: 
If [M:ITC1]STDCST(6) <>0 & [M:ITC1]STDCST(7) = 0 
&  | ([M:ITC1]ACTCST(6) <>0 & [M:ITC1]ACTCST(7) = 0) 
&  | ([M:ITC1]BUDCST(6) <>0 & [M:ITC1]BUDCST(7) = 0) 
&  | ([M:ITC1]SIMCST(6) <>0 & [M:ITC1]SIMCST(7) = 0) 
    GMESSAGE = mess(203,199,1)
    OK = 0 
    SUIZON = "STDCST(7)"  :# rajouté le 13/09/99
Endif 
Return 
 
#######################################################
$APRES_MODIF  
# colonne modifiée et flag EXI=0 <=> création : xxx_UPD = 2 
# flag pour std inutile car si l'on passe dans cette étiquette, c'est que l'on est 
# en mode Modif, et donc que l'enreg cout std existe déjà
  ## >> en modif art ou site pour duplic : recharger les infos issues de ITM et ITF ??
# en création de coût on alimente la date
Case COUZON
    When "STOFCY"
        If !func LOADITC(CZ,[M:ITC0]ITMREF,[M:ITC0]DATREF)
            [M:ITC0]ITCSEQ = 0
        Endif
        Affzo [M:ITC0]ITCSEQ
    When "ITMREF"
        If !func LOADITC([M:ITC0]STOFCY,CZ,[M:ITC0]DATREF)
            [M:ITC0]ITCSEQ = 0
        Endif
        Affzo [M:ITC0]ITCSEQ
    When "DATREF"
        LDATREF=CZ
        If func LOADITC([M:ITC0]STOFCY,[M:ITC0]ITMREF,CZ)
            [M:ITC0]ITCSEQ = [F:ITC]ITCSEQ
            COUZON = "ITCSEQ"
            CZ = num$([M:ITC0]ITCSEQ)
#            CLECUR = 1
#            CLECUR1(0) = [M:ITC0]ITMREF
#            CLECUR2(0) = [M:ITC0]STOFCY
#            CLECUR2(1) = "1"    # Coût standard
#            CLECUR2(2) = num$([M:ITC0]ITCSEQ)
#            CLECUR2(3) = "0"    # Coût standard définitif
#            Gosub RELIT From GOBJSUB
#            If REP=""
#                OK=-1    # Evite de passer en modif
#            Else
#                COUZON = "ITCSEQ"
#                CZ = num$([M:ITC0]ITCSEQ)
#            Endif
        Else
            Local Integer LOK: LOK=1
            Call OUINON(mess(12,126,1),LOK) From GESECRAN
            If LOK=1
                OK = 0    # On reste sur la zone
            Else    # Passage en duplication
                Call INITDAT(LDATREF)
                [M:ITC0]ITCSEQ = 0
                COUZON = "ITCSEQ"
                CZ = num$([M:ITC0]ITCSEQ)
            Endif
        Endif
        [M:ITC0]DATREF = LDATREF
        Affzo [M:ITC0]DATREF
        Affzo [M:ITC0]ITCSEQ
    When "OVECOD", "STDCSTUPD", "CUTCSTUPD", "BUDCSTUPD", "SIMCSTUPD" 
        ITF_UPD = 1 

#------ ITC1 ----------#
    When "STDSTR","STDEND"
        Assign "[M:ITC2]"+COUZON With CZ
        Affzo [M:ITC2]STDSTR,STDEND
        [M:ITC1]STDUPD = 1
    When "ACTSTR","ACTEND"
        Assign "[M:ITC2]"+COUZON With CZ
        Affzo [M:ITC2]ACTSTR,ACTEND
        [M:ITC1]ACTUPD = 1
    When "BUDSTR","BUDEND"
        Assign "[M:ITC2]"+COUZON With CZ
        Affzo [M:ITC2]BUDSTR,BUDEND
        [M:ITC1]BUDUPD = 1
    When "SIMSTR","SIMEND"
        Assign "[M:ITC2]"+COUZON With CZ
        Affzo [M:ITC2]SIMSTR,SIMEND
        [M:ITC1]SIMUPD = 1

    When "STDCST"
        [M:ITC1]STDUPD = 1 
    When "ACTCST" 
        If [M:ITC1]ACTUPD = 0
            [M:ITC1]ACTUPD = 1 
        Endif 
    When "BUDCST" 
        If [M:ITC1]BUDUPD = 0
            [M:ITC1]BUDUPD = 1
        Endif 
    When "SIMCST" 
        If [M:ITC1]SIMUPD = 0
            [M:ITC1]SIMUPD = 1 
        Endif 
Endcase  
Return 

Funprog LOADITC(PFCY, PITM, PDAT)
Value Char PFCY
Value Char PITM
Value Date PDAT

Local Integer LOK
LOK = 0
If PFCY<>"" & PITM<>"" & PDAT<>[0/0/0]
    Filter [ITC] Where STOFCY= PFCY
&                    & ITMREF= PITM
&                    & CSTTYP= 1
&                    & UID   = 0
&                    & ITCSTRDAT<=PDAT & PDAT<=ITCENDDAT
    For [ITC]
        [M:ITC0]ITCSEQ = [F:ITC]ITCSEQ
        LOK = 1
        Break
    Next
    Filter [ITC]
Endif
End LOK


#######################################################
$INICRE
# Chargement des zones Cout STANDARD
[F:ITC]CSTTYP    = 1
[F:ITC]ITCDAT    = date$
Raz [F:ITC2]
For [ITC2]ITC0 Where STOFCY=[M:ITC0]STOFCY
&                  & ITMREF=[M:ITC0]ITMREF
&                  & CSTTYP=1
&                  & UID=0       # !! ordre de ITCSEQ inversé
    Break
Next
[F:ITC]ITCSEQ = func GETITCSEQ([M:ITC0]STOFCY,[M:ITC0]ITMREF,1)
[M:ITC0]ITCSEQ = [F:ITC]ITCSEQ    # Pour la relecture

TYP = "STD"
IMAT = [M:ITC0]BRDCOD - 1  : # indice famille coût pour matière

If [M:ITC1]STDCST(7) = 0
  [M:ITC1]STDCST(7) = 1  # par sécurité si on veut enregistrer un cout nul
Endif
Gosub MAJ_COUT 
Raz [F:ITC2]
# lecture du précédent (année -1) pour charger les zones pour interface
# ATTENTION si anachronisme : lire le dernier en DATE
#If GMODU(2) = 2 & GACCCSTIFA=2 & GACCCSTENT <> ""
   Filter [ITC2] Where STOFCY=[M:ITC0]STOFCY & ITMREF=[M:ITC0]ITMREF & CSTTYP=1 & ITCSTRDAT<[M:ITC1]STDSTR
   Read [ITC2]ITC1 Last
   If !fstat & [F:ITC]VLTTOT <> [F:ITC2]VLTTOT
     [F:ITC]OLDCST = [F:ITC2]VLTTOT
     [F:ITC]OLDDAT = [F:ITC2]ITCDAT
     DIFF_CST = 1
   Endif
   # CCC (22/09/04) Bug 25184 : Il fallait tester fstat=4 et pas =5
   If find(fstat,4,5) DIFF_CST=1 Endif # pour passer aussi un éventuel actualisé
 
   Read [ITV]ITV0 = [M:ITC0]ITMREF;[M:ITC0]STOFCY
   If !fstat
     [F:ITC]PHYSTO = [F:ITV]PHYSTO+[F:ITV]CTLSTO+[F:ITV]REJSTO
&                   +[F:ITV]BPRPHYSTO+[F:ITV]SCOPHYSTO
   Endif
   Filter [ITC2]
#Endif
Return

#######################################################
$CREATION
Local Char    TABCCE(GLONCCE)(max(GOPTCANA,1))
Local Integer I

Read [ITM]ITM0 = [M:ITC0]ITMREF 
If !fstat
 If [F:ITM]BRDCOD <> [M:ITC0]BRDCOD 
  [F:ITM]BRDCOD = [M:ITC0]BRDCOD 
  Rewrite [ITM] 
  If fstat=1  
     GOK = -1 : GLOCK= "$ITMMASTER" + [ITM]ITMREF : Return
  Endif
 Endif
Endif
 
Gosub MOD_ITF 
If GOK < 1 : Return : Endif  
Read [ITF]ITF0=[M:ITC0]ITMREF;[M:ITC0]STOFCY  # il n'a pas forcément été lu dans MOD_ITF
Read [ITG]ITG0="";[M:ITC0]TCLCOD # enreg utile pour la màj stock (chgt valeur)
Call GETTCM([F:ITF]ITMREF,[F:ITF]STOFCY,GBIDC1,GBIDI1) From STKVAL    #GETTCM se positionne sur [F:TCM], nécessaire pour conditionner le mvt chgt valeur

# Mise en phase des natures de frais Bug 20372 (04/12/03)
If [M:ITC1]STDCST(4) <> 0
  Gosub CRE_ICN
Endif
If GOK = 0 : Return : Endif 

If [F:TCM]ISSVLTCOD=1 | [F:TCM]ISSVLT2=1
  If [F:ITC]VLTTOT > 0 & DIFF_CST = 1 # seulement si c'est un "vrai" coût  (29/07/03)
    # CCC (27/06/05) Bug 30974 : Si pas d'axe analytique [m:itc0]CCE n'existe pas => il faut passer par un tableau intermédiaire
    For I=0 To GOPTCANA-1
        TABCCE(I) = [M:ITC0]CCE(I)
    Next
    Call STK_CHG_VAL(([F:TCM]ISSVLTCOD=1 xor [F:TCM]ISSVLT2=1)+[F:TCM]ISSVLT2=1,TABCCE) From SUBITCB
    If GOK < 1
        # "Erreur à la génération du mouvement de changement de valeur"
        GMESSAGE = mess(200,199,1)
        Return
    Endif
    For I=0 To GOPTCANA-1
        [M:ITC0]CCE(I) = TABCCE(I)
    Next
  Endif
Endif

# Création des enreg coûts act / bud et sim
Raz [F:ITC]     : # Classe ITC utilisée chaque fois pour GENERALISER POUR TOUS TYPES
[F:ITC] = [M:ITC0]
If [M:ITC1]ACTCST(6) <> 0 
  [F:ITC]CSTTYP    = 2
  [F:ITC]ITCSEQ    = func GETITCSEQ([M:ITC0]STOFCY,[M:ITC0]ITMREF,2)
  TYP = "ACT" 
  Gosub MAJ_COUT 

  Write [ITC]
  If fstat : GOK = 0 : Return : Endif

  # Mise en phase des natures de frais Bug 20372 (04/12/03)
  If [M:ITC1]ACTCST(4) <> 0
    Gosub CRE_ICN
  Endif
  If GOK = 0 : Return : Endif 

  # interface compta du coût actualisé créé 
  If [F:TCM]ISSVLTCOD=2 | [F:TCM]ISSVLT2=2
    # CCC (27/06/05) Bug 30974 : Si pas d'axe analytique [m:itc0]CCE n'existe pas => il faut passer par un tableau intermédiaire
    For I=0 To GOPTCANA-1
        TABCCE(I) = [M:ITC0]CCE(I)
    Next
    Call STK_CHG_VAL(([F:TCM]ISSVLTCOD=1 xor [F:TCM]ISSVLT2=1)+[F:TCM]ISSVLT2=1,TABCCE) From SUBITCB
    If GOK < 1
        # "Erreur à la génération du mouvement de changement de valeur"
        GMESSAGE = mess(200,199,1)
        Return
    Endif
    For I=0 To GOPTCANA-1
        [M:ITC0]CCE(I) = TABCCE(I)
    Next
  Endif

Endif 
 
If [M:ITC1]BUDCST(6) <> 0 
  [F:ITC]CSTTYP    = 3 
  [F:ITC]ITCSEQ    = func GETITCSEQ([M:ITC0]STOFCY,[M:ITC0]ITMREF,3)
  TYP = "BUD" 
  Gosub MAJ_COUT  
  Write [ITC] 
  If fstat : GOK = 0 : Return : Endif 

  # Mise en phase des natures de frais Bug 20372 (04/12/03)
  If [M:ITC1]BUDCST(4) <> 0
    Gosub CRE_ICN
  Endif
  If GOK = 0 : Return : Endif 

Endif
 
If [M:ITC1]SIMCST(6) <> 0 
  [F:ITC]CSTTYP    = 4 
  [F:ITC]ITCSEQ    = func GETITCSEQ([M:ITC0]STOFCY,[M:ITC0]ITMREF,4)
  TYP = "SIM" 
  Gosub MAJ_COUT  
  Write [ITC] 
  If fstat : GOK = 0 : Return : Endif 

  # Mise en phase des natures de frais Bug 20372 (04/12/03)
  If [M:ITC1]SIMCST(4) <> 0
    Gosub CRE_ICN
  Endif
  If GOK = 0 : Return : Endif 

Endif 
Raz [M:ITC1]STDUPD, [M:ITC1]ACTUPD, [M:ITC1]BUDUPD, [M:ITC1]SIMUPD
Return

#######################################################
$APRES_MOD
If !GIMPORT & !GVTMOD
    Gosub RELIT From GOBJSUB
Endif
Affzo [M:ITC1]
Affzo [M:ITC2]
Return

#######################################################
$MAJ_COUT
  [F:ITC]ITCDAT    = date$  # 15/06/01
  [F:ITC]ITCSTRDAT = evalue("[M:ITC1]"+TYP+"STR") : # Date début validité
  [F:ITC]ITCENDDAT = evalue("[M:ITC1]"+TYP+"END") : # Date début validité
  [F:ITC]MATCST(IMAT) = evalue("[M:ITC1]"+TYP+"CST(0)") : # sous-total matière 
  [F:ITC]MATTOT    = evalue("[M:ITC1]"+TYP+"CST(0)") : # matière total 
  [F:ITC]MATLEVCST(IMAT) = evalue("[M:ITC1]"+TYP+"CST(0)") : # matière niveau # CCC (14/12/04) ajout famille de coût
  [F:ITC]MACCST(0) = evalue("[M:ITC1]"+TYP+"CST(1)") : # machine premier sous-total 
  [F:ITC]MACTOT    = evalue("[M:ITC1]"+TYP+"CST(1)") 
  [F:ITC]MACLEVCST(0) = evalue("[M:ITC1]"+TYP+"CST(1)")      # CCC (14/12/04) ajout famille de coût
  [F:ITC]LABCST(0) = evalue("[M:ITC1]"+TYP+"CST(2)") : # main d'oeuvre 
  [F:ITC]LABTOT    = evalue("[M:ITC1]"+TYP+"CST(2)") 
  [F:ITC]LABLEVCST(0) = evalue("[M:ITC1]"+TYP+"CST(2)")      # CCC (14/12/04) ajout famille de coût
  [F:ITC]SCOCST    = evalue("[M:ITC1]"+TYP+"CST(3)") : # sous-traitance 
  [F:ITC]SCOTOT    = evalue("[M:ITC1]"+TYP+"CST(3)") : # sous-traitance 
  [F:ITC]SCOLEVCST = evalue("[M:ITC1]"+TYP+"CST(3)") : # sous-traitance niveau 
  [F:ITC]OVETOT    = evalue("[M:ITC1]"+TYP+"CST(4)") : # FG 
  [F:ITC]OVEMATCST = evalue("[M:ITC1]"+TYP+"CST(4)") : # FG considérés comme FG matière 
  [F:ITC]OVELEVCST = evalue("[M:ITC1]"+TYP+"CST(4)") : # FG niveau 
  [F:ITC]OVEMATLEV = evalue("[M:ITC1]"+TYP+"CST(4)") : # FG matière du niveau (v 140)
  [F:ITC]CSTTOT    = evalue("[M:ITC1]"+TYP+"CST(5)") : # total sans FG 
  [F:ITC]CLCQTY    = evalue("[M:ITC1]"+TYP+"CST(7)") : # Qté de calcul 
  [F:ITC]VLTTOT    = [F:ITC]CSTTOT + [F:ITC]OVETOT
  [F:ITC]CREDAT    = date$ 
  [F:ITC]CREUSR    = GUSER  
  [F:ITC]EXPNUM    = [C]EXPORT  
Return

#######################################################
$INIMOD 
# récupération des données de coût STANDARD depuis l'écran détail 
# et CSTTOT, OVETOT doivent être affectés puisque absents de l'écran 
Raz ICN_UPD # correction 20372 (04/12/03)
If [M:ITC1]STDCST(4) <> [F:ITC]OVETOT
    ICN_UPD = 1 # frais modifiés à la main implique une mise à jour détails (04/12/03)
Endif

[F:ITC] = [M:ITCD]
If [M:ITC1]STDMOD(0)>0
    For I=0 To dim([M:ICLD]MATCST)-1
        [F:ITC]MATLEVCST(I) = [M:ICLD]MATCST(I)
    Next
    Raz [F:ITC]FXDMATCST,[F:ITC]FXDMATLEV
Endif
If [M:ITC1]STDMOD(1)>0
    For I=0 To dim([M:ICLD]MACCST)-1
        [F:ITC]MACLEVCST(I) = [M:ICLD]MACCST(I)
    Next
    Raz [F:ITC]FXDMACCST,[F:ITC]FXDMACLEV
Endif
If [M:ITC1]STDMOD(2)>0
    For I=0 To dim([M:ICLD]LABCST)-1
        [F:ITC]LABLEVCST(I) = [M:ICLD]LABCST(I)
    Next
    Raz [F:ITC]FXDLABCST,[F:ITC]FXDLABLEV
Endif
If [M:ITC1]STDMOD(3)>0
    [F:ITC]SCOLEVCST = [M:ICLD]SCOTOT
    Raz [F:ITC]FXDSCOCST,[F:ITC]FXDSCOLEV
Endif
If [M:ITC1]STDMOD(4)>0
    [F:ITC]OVEMATLEV = [M:ICLD]OVEMATCST
    [F:ITC]OVEMACLEV = [M:ICLD]OVEMACCST
    [F:ITC]OVELABLEV = [M:ICLD]OVELABCST
    [F:ITC]OVESCOLEV = [M:ICLD]OVESCOCST
    Raz [F:ITC]FXDOVEMAT,[F:ITC]FXDOVELAB,[F:ITC]FXDOVEMAC,[F:ITC]FXDOVESCO
    Raz [F:ITC]FXDOVEMATL,[F:ITC]FXDOVELABL,[F:ITC]FXDOVEMACL,[F:ITC]FXDOVESCOL
Endif
[F:ITC]ITCSTRDAT = [M:ITC1]STDSTR
[F:ITC]ITCENDDAT = [M:ITC1]STDEND
[F:ITC]CLCQTY = [M:ITC1]STDCST(7) 
[F:ITC]OVETOT = [M:ITC1]STDCST(4)  
[F:ITC]CSTTOT = [M:ITC1]STDCST(5)  
[F:ITC]VLTTOT = [F:ITC]CSTTOT + [F:ITC]OVETOT

# interface comptable si le std a changé  (02/04/01)
# DIFF_CST à 1 (positionné dans LIENS)signifie qu'il faut interfacer si le cout tot a évolué

If [F:ITC]VLTTOT <> OLD_CST & [F:ITC]VLTTOT <> 0 & DIFF_CST <> 0
  [F:ITC]OLDCST = OLD_CST
  [F:ITC]OLDDAT = OLD_DAT
  Read [ITV]ITV0 = [M:ITC0]ITMREF;[M:ITC0]STOFCY
  If !fstat
     ##[F:ITC]PHYSTO = [F:ITV]PHYSTO # remplacé pour correction 18015 (19/05/03)
     [F:ITC]PHYSTO = [F:ITV]PHYSTO+[F:ITV]CTLSTO+[F:ITV]REJSTO
&                   +[F:ITV]BPRPHYSTO+[F:ITV]SCOPHYSTO # (étaient dans PHYSTO en 130)
  Endif
  # CCC (01/09/04) Bug 24509
  #--- S'il y a eu évolution du prix standard on change la date de calcul ---#
  #!! Cette date est reprise pour la date d'imputation du mouvement de chgt de valeur !!#
  [F:ITC]ITCDAT=date$
Endif

Return  
 
#######################################################
$MOD_ITF 
# Mise à jour zones d'article-site 
If ITF_UPD = 1 
  Read [ITF]ITF0=[M:ITC0]ITMREF;[M:ITC0]STOFCY 
  [F:ITF] = [M:ITC0] : # pour Code FG et codes Màj 
  Rewrite [ITF] 
  If fstat=1 
     GOK = -1 : GLOCK= "$ITMFACILIT" + [ITF]ITMREF + [ITF]STOFCY 
  Endif 
Endif 
Return 
 
#######################################################
$MODIF
Local Char    TABCCE(GLONCCE)(max(GOPTCANA,1))
Local Integer I
# correction 20372 (04/12/03)
If ICN_UPD = 1 
 Call MAJ_ICN(1,[F:ITC]ITCSEQ,"ITC")
Endif
If GOK < 1 : Return : Endif 

Read [ITM]ITM0=[M:ITC0]ITMREF 
Read [ITF]ITF0=[M:ITC0]ITMREF;[M:ITC0]STOFCY 
Read [ITG]ITG0="";[M:ITC0]TCLCOD # enreg utile pour la màj stock (chgt valeur)
Call GETTCM([F:ITF]ITMREF,[F:ITF]STOFCY,GBIDC1,GBIDI1) From STKVAL    #GETTCM se positionne sur [F:TCM], nécessaire pour conditionner le mvt chgt valeur

If DIFF_CST <> 0 & ( [F:TCM]ISSVLTCOD=1 | [F:TCM]ISSVLT2=1)
    # CCC (27/06/05) Bug 30974 : Si pas d'axe analytique [m:itc0]CCE n'existe pas => il faut passer par un tableau intermédiaire
    For I=0 To GOPTCANA-1
        TABCCE(I) = [M:ITC0]CCE(I)
    Next
    Call STK_CHG_VAL(([F:TCM]ISSVLTCOD=1 xor [F:TCM]ISSVLT2=1)+[F:TCM]ISSVLT2=1,TABCCE) From SUBITCB
    If GOK < 1
        # "Erreur à la génération du mouvement de changement de valeur"
        GMESSAGE = mess(200,199,1)
        Return
    Endif
    For I=0 To GOPTCANA-1
        [M:ITC0]CCE(I) = TABCCE(I)
    Next
Endif

Gosub MOD_ITF 
If GOK < 1 : Return : Endif 
# 
# Pas de mise à jour zones d'article en modif
Read [ITG]ITG0="";[M:ITC0]TCLCOD # enreg utile pour la màj stock (chgt valeur)
DIFF_CST = 0 
# Mise à jour /OU CREATION des enreg ITMCOST s'ils ont été modifiés/ renseignés
# --> Ecraser aussi les couts niveau en cas de modif
If [M:ITC1]ACTUPD = 1 
  ## >> ATTENTION si un total est modifié màj les xxLEV ! et les FXD 
    Raz ICN_UPD # correction 20372 (04/12/03)
    If [M:ITC1]ACTCST(4) <> [F:ITCA]OVETOT
        ICN_UPD = 1 # frais modifiés à la main implique une mise à jour détails (04/12/03)
      # mettre en phase les autres zones
      Raz [F:ITCA]FXDOVEMAT,[F:ITCA]FXDOVEMAC,[F:ITCA]FXDOVELAB,[F:ITCA]FXDOVESCO,[F:ITCA]FXDOVELEV
      [F:ITCA]OVELEVCST = [M:ITC1]ACTCST(4) # (façon 130)  >>en 140 tout ça est dans l'écran ITCDET
    Endif

    [F:ITCA] = [M:ITCA] 
    [F:ITCA]ITCSTRDAT = [M:ITC1]ACTSTR
    [F:ITCA]ITCENDDAT = [M:ITC1]ACTEND

    If [M:ITC1]ACTMOD(0)>0
        Raz [F:ITCA]FXDMATCST,[F:ITCA]FXDMATLEV
    Endif
    If [M:ITC1]ACTMOD(1)>0
        Raz [F:ITCA]FXDMACCST,[F:ITCA]FXDMACLEV
    Endif
    If [M:ITC1]ACTMOD(2)>0
        Raz [F:ITCA]FXDLABCST,[F:ITCA]FXDLABLEV
    Endif
    If [M:ITC1]ACTMOD(3)>0
        Raz [F:ITCA]FXDSCOCST,[F:ITCA]FXDSCOLEV
    Endif
    If [M:ITC1]ACTMOD(4)>0
        Raz [F:ITCA]FXDOVEMAT,[F:ITCA]FXDOVELAB,[F:ITCA]FXDOVEMAC,[F:ITCA]FXDOVESCO
        Raz [F:ITCA]FXDOVEMATL,[F:ITCA]FXDOVELABL,[F:ITCA]FXDOVEMACL,[F:ITCA]FXDOVESCOL
    Endif
    [F:ITCA]CLCQTY    = [M:ITC1]ACTCST(7) 
    [F:ITCA]OVETOT    = [M:ITC1]ACTCST(4)  
    [F:ITCA]CSTTOT    = [M:ITC1]ACTCST(5)  
    [F:ITCA]VLTTOT    = [F:ITCA]CSTTOT + [F:ITCA]OVETOT
    [F:ITCA]UPDDAT    = date$ 
    [F:ITCA]UPDUSR    = GUSER  
    [F:ITCA]EXPNUM    = [C]EXPORT  
    
    # si on a modifié le coût actualisé et que l'article est valorisé  à ce cout : générer le mvt
    If DIFF_CST = 1  & ([F:TCM]ISSVLTCOD=2 | [F:TCM]ISSVLT2=2)
      [F:ITC2] = [F:ITC]
      [F:ITC] = [F:ITCA]
      # CCC (27/06/05) Bug 30974 : Si pas d'axe analytique [m:itc0]CCE n'existe pas => il faut passer par un tableau intermédiaire
      For I=0 To GOPTCANA-1
          TABCCE(I) = [M:ITC0]CCE(I)
      Next
      Call STK_CHG_VAL(([F:TCM]ISSVLTCOD=1 xor [F:TCM]ISSVLT2=1)+[F:TCM]ISSVLT2=1,TABCCE) From SUBITCB
      If GOK < 1
        # "Erreur à la génération du mouvement de changement de valeur"
        GMESSAGE = mess(200,199,1)
        Return
      Endif
      For I=0 To GOPTCANA-1
          [M:ITC0]CCE(I) = TABCCE(I)
      Next
      [F:ITCA] = [F:ITC]
      [F:ITC]  = [F:ITC2]
    Endif
    Rewrite [ITCA] 
    If fstat=1 
     GOK=-1 : GLOCK="$ITMCOST"+[ITC]STOFCY+[ITC]ITMREF+"2"+num$([ITC]ITCSEQ)
     Return 
    Endif 

    If ICN_UPD = 1
       Call MAJ_ICN(2,[F:ITCA]ITCSEQ,"ITCA")  # corr 20372  (04/12/03)
       If GOK < 1 : Return : Endif 
    Endif

Elsif [M:ITC1]ACTUPD = 2 
    Raz [F:ITCA]

    [F:ITCA] = [M:ITC0] # pour site, article, année, CFGVCRNUM
    [F:ITCA] = [M:ITCA]
    [F:ITCA]ITCSEQ    = func GETITCSEQ([M:ITC0]STOFCY,[M:ITC0]ITMREF,2)
    [F:ITCA]CSTTYP    = 2  
    [F:ITCA]ITCSTRDAT = [M:ITC1]ACTSTR
    [F:ITCA]ITCENDDAT = [M:ITC1]ACTEND
    [F:ITCA]CLCQTY    = [M:ITC1]ACTCST(7) 
    [F:ITCA]OVETOT    = [M:ITC1]ACTCST(4)  
    [F:ITCA]CSTTOT    = [M:ITC1]ACTCST(5)  
    [F:ITCA]VLTTOT    = [F:ITCA]CSTTOT + [F:ITCA]OVETOT
    [F:ITCA]MATLEVCST([M:ITC0]BRDCOD-1) = [M:ITCA]MATTOT 
    [F:ITCA]MACLEVCST(0) = [M:ITCA]MACTOT 
    [F:ITCA]LABLEVCST(0) = [M:ITCA]LABTOT 
    [F:ITCA]SCOLEVCST = [M:ITCA]SCOTOT 
    [F:ITCA]OVELEVCST = [F:ITCA]OVETOT : # (car OVETOT n'est pas dans l'écran détail!) 
    [F:ITCA]OVEMATLEV = [F:ITCA]OVETOT : # v 140
    [F:ITCA]CREDAT    = date$ 
    [F:ITCA]CREUSR    = GUSER  
    [F:ITCA]EXPNUM    = [C]EXPORT  

    # si on a créé le coût actualisé et que l'article est valorisé à ce cout : générer le mvt
    If [F:TCM]ISSVLTCOD=2
      # CCC (27/06/05) Bug 30974 : Si pas d'axe analytique [m:itc0]CCE n'existe pas => il faut passer par un tableau intermédiaire
      For I=0 To GOPTCANA-1
          TABCCE(I) = [M:ITC0]CCE(I)
      Next
      [F:ITC2] = [F:ITC]
      [F:ITC] = [F:ITCA]
      Call STK_CHG_VAL(([F:TCM]ISSVLTCOD=1 xor [F:TCM]ISSVLT2=1)+[F:TCM]ISSVLT2=1,TABCCE) From SUBITCB
      If GOK < 1
        # "Erreur à la génération du mouvement de changement de valeur"
        GMESSAGE = mess(200,199,1)
        Return
      Endif
      For I=0 To GOPTCANA-1
          [M:ITC0]CCE(I) = TABCCE(I)
      Next
      [F:ITCA] = [F:ITC]
      [F:ITC]  = [F:ITC2]
    Endif

    Write [ITCA]
    If fstat : GOK = 0 : Return : Endif

    If [F:ITCA]OVETOT <> 0
       Call MAJ_ICN(2,[F:ITCA]ITCSEQ,"ITCA")  # corr 20372  (04/12/03) <<<<< on créé donc forcément  
       If GOK < 1 : Return : Endif 
    Endif

Endif 

If [M:ITC1]BUDUPD = 1 
    Raz ICN_UPD # correction 20372 (04/12/03)
    If [M:ITC1]BUDCST(4) <> [F:ITCB]OVETOT
        ICN_UPD = 1 # frais modifiés à la main implique une mise à jour détails (04/12/03)
    Endif

    [F:ITCB] = [M:ITCB] 
    [F:ITCB]ITCSTRDAT = [M:ITC1]BUDSTR
    [F:ITCB]ITCENDDAT = [M:ITC1]BUDEND
    If [M:ITC1]BUDMOD(0)>0
        Raz [F:ITCB]FXDMATCST,[F:ITCB]FXDMATLEV
    Endif
    If [M:ITC1]BUDMOD(1)>0
        Raz [F:ITCB]FXDMACCST,[F:ITCB]FXDMACLEV
    Endif
    If [M:ITC1]BUDMOD(2)>0
        Raz [F:ITCB]FXDLABCST,[F:ITCB]FXDLABLEV
    Endif
    If [M:ITC1]BUDMOD(3)>0
        Raz [F:ITCB]FXDSCOCST,[F:ITCB]FXDSCOLEV
    Endif
    If [M:ITC1]BUDMOD(4)>0
        Raz [F:ITCB]FXDOVEMAT,[F:ITCB]FXDOVELAB,[F:ITCB]FXDOVEMAC,[F:ITCB]FXDOVESCO
        Raz [F:ITCB]FXDOVEMATL,[F:ITCB]FXDOVELABL,[F:ITCB]FXDOVEMACL,[F:ITCB]FXDOVESCOL
    Endif
    [F:ITCB]CLCQTY = [M:ITC1]BUDCST(7) 
    [F:ITCB]OVETOT = [M:ITC1]BUDCST(4)  
    [F:ITCB]CSTTOT = [M:ITC1]BUDCST(5)  
    [F:ITCB]VLTTOT = [F:ITCB]CSTTOT + [F:ITCB]OVETOT
    [F:ITCB]UPDDAT = date$ 
    [F:ITCB]UPDUSR = GUSER  
    [F:ITCB]EXPNUM = [C]EXPORT  
    Rewrite [ITCB]  
    If fstat=1  
     GOK=-1 : GLOCK="$ITMCOST"+[ITC]STOFCY+[ITC]ITMREF+"3"+num$([ITC]ITCSEQ) 
     Return 
    Endif  
    If ICN_UPD = 1
       Call MAJ_ICN(3,[F:ITCB]ITCSEQ,"ITCB")  # corr 20372  (04/12/03)
       If GOK < 1 : Return : Endif 
    Endif

Elsif [M:ITC1]BUDUPD = 2 
    Raz [F:ITCB]

    [F:ITCB] = [M:ITC0]  # pour site, article, année, CFGVCRNUM
    [F:ITCB] = [M:ITCB]  
    [F:ITCB]ITCSEQ    = func GETITCSEQ([M:ITC0]STOFCY,[M:ITC0]ITMREF,3)
    [F:ITCB]CSTTYP    = 3  
    [F:ITCB]ITCSTRDAT = [M:ITC1]BUDSTR
    [F:ITCB]ITCENDDAT = [M:ITC1]BUDEND
    [F:ITCB]CLCQTY    = [M:ITC1]BUDCST(7) 
    [F:ITCB]OVETOT    = [M:ITC1]BUDCST(4)  
    [F:ITCB]CSTTOT    = [M:ITC1]BUDCST(5)  
    [F:ITCB]VLTTOT    = [F:ITCB]CSTTOT + [F:ITCB]OVETOT
    [F:ITCB]MATLEVCST([M:ITC0]BRDCOD-1) = [M:ITCB]MATTOT 
    [F:ITCB]MACLEVCST(0) = [M:ITCB]MACTOT 
    [F:ITCB]LABLEVCST(0) = [M:ITCB]LABTOT 
    [F:ITCB]SCOLEVCST = [M:ITCB]SCOTOT 
    [F:ITCB]OVELEVCST = [F:ITCB]OVETOT : # (car OVETOT n'est pas dans l'écran détail!) 
    [F:ITCB]OVEMATLEV = [F:ITCB]OVETOT : # v 140
    [F:ITCB]CREDAT    = date$  
    [F:ITCB]CREUSR    = GUSER   
    [F:ITCB]EXPNUM    = [C]EXPORT  
    Write [ITCB]   
    If fstat : GOK = 0 : Return : Endif

    If [F:ITCB]OVETOT <> 0
       Call MAJ_ICN(3,[F:ITCB]ITCSEQ,"ITCB")  # corr 20372  (04/12/03)
       If GOK < 1 : Return : Endif 
    Endif

Endif  
If [M:ITC1]SIMUPD = 1 
    Raz ICN_UPD # correction 20372 (04/12/03)
    If [M:ITC1]SIMCST(4) <> [F:ITCS]OVETOT
        ICN_UPD = 1 # frais modifiés à la main implique une mise à jour détails (04/12/03)
    Endif

    [F:ITCS] = [M:ITCS] 
    [F:ITCS]ITCSTRDAT = [M:ITC1]SIMSTR
    [F:ITCS]ITCENDDAT = [M:ITC1]SIMEND
    If [M:ITC1]SIMMOD(0)>0
        Raz [F:ITCS]FXDMATCST,[F:ITCS]FXDMATLEV
    Endif
    If [M:ITC1]SIMMOD(1)>0
        Raz [F:ITCS]FXDMACCST,[F:ITCS]FXDMACLEV
    Endif
    If [M:ITC1]SIMMOD(2)>0
        Raz [F:ITCS]FXDLABCST,[F:ITCS]FXDLABLEV
    Endif
    If [M:ITC1]SIMMOD(3)>0
        Raz [F:ITCS]FXDSCOCST,[F:ITCS]FXDSCOLEV
    Endif
    If [M:ITC1]SIMMOD(4)>0
        Raz [F:ITCS]FXDOVEMAT,[F:ITCS]FXDOVELAB,[F:ITCS]FXDOVEMAC,[F:ITCS]FXDOVESCO
        Raz [F:ITCS]FXDOVEMATL,[F:ITCS]FXDOVELABL,[F:ITCS]FXDOVEMACL,[F:ITCS]FXDOVESCOL
    Endif
    [F:ITCS]CLCQTY = [M:ITC1]SIMCST(7) 
    [F:ITCS]OVETOT = [M:ITC1]SIMCST(4)  
    [F:ITCS]CSTTOT = [M:ITC1]SIMCST(5)  
    [F:ITCS]VLTTOT = [F:ITCS]CSTTOT + [F:ITCS]OVETOT
    [F:ITCS]UPDDAT = date$ 
    [F:ITCS]UPDUSR = GUSER  
    [F:ITCS]EXPNUM = [C]EXPORT  
    Rewrite [ITCS]  
    If fstat=1  
     GOK=-1 : GLOCK="$ITMCOST"+[ITC]STOFCY+[ITC]ITMREF+"4"+num$([ITC]ITCSEQ) 
     Return 
    Endif  
    If ICN_UPD = 1
       Call MAJ_ICN(4,[F:ITCS]ITCSEQ,"ITCS")  # corr 20372  (04/12/03)
       If GOK < 1 : Return : Endif 
    Endif

Elsif [M:ITC1]SIMUPD = 2  
    Raz [F:ITCS]

    [F:ITCS] = [M:ITC0]  # pour site, article, année, CFGVCRNUM
    [F:ITCS] = [M:ITCS]  
    [F:ITCS]ITCSEQ    = func GETITCSEQ([M:ITC0]STOFCY,[M:ITC0]ITMREF,4)
    [F:ITCS]CSTTYP    = 4  
    [F:ITCS]ITCSTRDAT = [M:ITC1]SIMSTR
    [F:ITCS]ITCENDDAT = [M:ITC1]SIMEND
    [F:ITCS]CLCQTY    = [M:ITC1]SIMCST(7) 
    [F:ITCS]OVETOT    = [M:ITC1]SIMCST(4)  
    [F:ITCS]CSTTOT    = [M:ITC1]SIMCST(5)  
    [F:ITCS]VLTTOT    = [F:ITCS]CSTTOT + [F:ITCS]OVETOT
    [F:ITCS]MATLEVCST([M:ITC0]BRDCOD-1) = [M:ITCS]MATTOT 
    [F:ITCS]MACLEVCST(0) = [M:ITCS]MACTOT 
    [F:ITCS]LABLEVCST(0) = [M:ITCS]LABTOT 
    [F:ITCS]SCOLEVCST = [M:ITCS]SCOTOT 
    [F:ITCS]OVELEVCST = [F:ITCS]OVETOT : # (car OVETOT n'est pas dans l'écran détail!) 
    [F:ITCS]OVEMATLEV = [F:ITCS]OVETOT : # v 140
    [F:ITCS]CREDAT    = date$  
    [F:ITCS]CREUSR    = GUSER   
    [F:ITCS]EXPNUM    = [C]EXPORT  
    Write [ITCS]
    If fstat : GOK = 0 : Return : Endif

    If [F:ITCS]OVETOT <> 0
       Call MAJ_ICN(4,[F:ITCS]ITCSEQ,"ITCS")  # corr 20372  (04/12/03)
       If GOK < 1 : Return : Endif 
    Endif

Endif  
Raz [M:ITC1]STDUPD, [M:ITC1]ACTUPD, [M:ITC1]BUDUPD, [M:ITC1]SIMUPD
Return

#######################################################
# Création des natures de frais Bug 20372 (04/12/03)
$CRE_ICN
Delete [ICN] Where STOFCY=[M:ITC0]STOFCY & ITMREF=[M:ITC0]ITMREF & CSTTYP=[F:ITC]CSTTYP
&          & ITCSEQ=[F:ITC]ITCSEQ & UID=0
Raz [F:ICN]
[F:ICN] = [F:ITC]
[F:ICN]OVENAT    = "ZZZ" # arbitrairement sur une nature diverse
[F:ICN]NATAMTLEV = [F:ITC]OVETOT # les parties fixes ne sont pas affectées
Write [ICN]
If fstat 
  # erreur d'écriture sur le fichier ITCNAT std... nature de FG : ZZZ
  GMESSAGE = num$(fstat)-mess(13,100,1)-"ITCNAT"-mess([F:ITC]CSTTYP,219,1)-mess(309,197,1)+": ZZZ"
  GOK = 0 
  Return 
Endif

Return

# sous-pro de mise à jour des détails natures corr 20372 (04/12/03)
######################################################################
Subprog MAJ_ICN(TYP,SEQ,ABV)
Value Integer TYP
Value Integer SEQ
Value Char    ABV # abréviation de la table ITC écrite (selon le type)

Local Char LABRMSK

Case TYP
    When 1 : LABRMSK = "ITCD"
    When 2 : LABRMSK = "ITCA"
    When 3 : LABRMSK = "ITCB"
    When 4 : LABRMSK = "ITCS"
Endcase

# deleter les éventuels détails existant et (re)créer la nature "ZZZ"
Delete [ICN] Where STOFCY=[M:ITC0]STOFCY & ITMREF=[M:ITC0]ITMREF & CSTTYP=TYP
&          & ITCSEQ=SEQ & UID=0
If fstat=1
   GMESSAGE = mess(13,100,1)-"ITCNAT" # erreur d'écriture sur le fichier ITCNAT
   GMESSAGE -= [F:ITC]STOFCY-[F:ITC]ITMREF-mess(TYP,219,1)-num$(SEQ)
   GOK = 0
   End
Endif

# créer un seul détail nature à moins qu'on ait passé les frais à zéro
If evalue("[F:"+ABV+"]OVETOT") <> 0
    Raz [F:ICN]
    [F:ICN]          = [M:ITC0]  # pour site, article, année, CFGVCRNUM
    [F:ICN]CSTTYP    = TYP
    [F:ICN]ITCSEQ    = SEQ
    [F:ICN]ITCDAT    = evalue("[F:"+ABV+"]ITCDAT")
    [F:ICN]CLCQTY    = evalue("[F:"+ABV+"]CLCQTY")
    [F:ICN]CREDAT    = date$ 
    [F:ICN]CREUSR    = GUSER  
    [F:ICN]EXPNUM    = [C]EXPORT
    For I=0 To [M:ITCD]NBONA-1
        [F:ICN]OVENAT    = evalue("[M:"+LABRMSK+"]OVENAT(I)")
        [F:ICN]NATAMTLEV = evalue("[M:"+LABRMSK+"]ONAAMT(I)")
        # les parties fixes et sous-niveau ne sont pas affectées
        Write [ICN]
    Next
    If fstat  
      # erreur d'écriture sur le fichier ITCNAT std... AAAA #### nature de FG : ZZZ
      GMESSAGE = mess(13,100,1)-"ITCNAT"-mess(TYP,219,1)-num$(SEQ)-mess(309,197,1)+":"+[F:ICN]OVENAT
      GOK = 0
    Endif
Endif
End

####################################################
# Sous-pro des zones écran
####################################################
Subprog AV_FMTLIG(VALEUR)
Variable Char     VALEUR
# Format des numériques selon ligne : 7 montants puis qté
If indice < 7
  ## Call GETDEV([M:ITC0]STOFCY) From DEVSUB
   VALEUR = "N3z:11."+num$(GDECPRI)  # correction bug 7164
Elsif indice < 8
   Call FMTQTY([F:ITM]STU) From TRTDIV
   VALEUR = "Nz:" + GFMTQTY
Endif
End

######################################################################
Subprog AV_CUR(VALEUR)
Variable Char     VALEUR
# Affichage de la devise d'après le site
Call GETDEV([M:ITC0]STOFCY) From DEVSUB
VALEUR = [F:TCU]CUR
End
 
Subprog AV_STDCST(VALEUR)
Variable Decimal  VALEUR
If indice = 5
   VALEUR = sigma(I=0,3, [M]STDCST(I))
Elsif indice = 6
   VALEUR = sigma(I=0,4, [M]STDCST(I))
Endif
End
 
Subprog AV_ACTCST(VALEUR)
Variable Decimal  VALEUR
If indice = 5
   VALEUR = sigma(I=0,3, [M]ACTCST(I))
Elsif indice = 6
   VALEUR = sigma(I=0,4, [M]ACTCST(I))
Endif
End

Subprog AV_BUDCST(VALEUR)
Variable Decimal  VALEUR
If indice = 5
   VALEUR = sigma(I=0,3, [M]BUDCST(I))
Elsif indice = 6
   VALEUR = sigma(I=0,4, [M]BUDCST(I))
Endif
End

Subprog AV_SIMCST(VALEUR)
Variable Decimal  VALEUR
If indice = 5
   VALEUR = sigma(I=0,3, [M]SIMCST(I))
Elsif indice = 6
   VALEUR = sigma(I=0,4, [M]SIMCST(I))
Endif
End
########################################
Subprog AS_STDCST(VALEUR)
Variable Decimal VALEUR
If indice<>7
    Raz GBOUT2
Endif
End

########################################
Subprog AM_STDCST(VALEUR)
Variable Decimal VALEUR
Local Decimal LDIFPRI
If indice < 5
    If GREP <> "C" & GREP <> "D" & indice <> 3 & [M:ITC1]STDCST(indice) <> 0
        # "Cette valeur sera répercutée globalement dans un sous-total et les autres sous-totaux seront annulés !" 
        Call MESSAGE(mess(201,199,1)) From GESECRAN  
    Endif  
    [M:ITC1]STDMOD(indice) = 1 # flag technique pour màj les valeurs fixes à l'enregistrement

#   Affecter la variable [M:ITC1] pour que le calcul d'Avant-zone du total soit juste 
    [M:ITC1]STDCST(indice) = VALEUR
    Call MODCST(indice,"STD")
    Affzo STDCST(5), STDCST(6)
Elsif indice=7
    [M:ITCD]QTY = VALEUR
Endif
End
# v 140 : pas de modif d'écran de détail : si on échappait la ligne 
# l'écran détail resterait modifié et mettrait à jour la classe [F] !
########################################
Subprog AS_ACTCST(VALEUR)
Variable Decimal VALEUR
If indice<>7
    Raz GBOUT2
Endif
End

########################################
Subprog AM_ACTCST(VALEUR)
Variable Decimal VALEUR
Local Decimal LDIFPRI
If indice < 5 
    LDIFPRI=VALEUR-[M:ITC1]ACTCST(indice)
    [M:SDP] = [M:ITCA]
#    Gosub REPARTIR From SUBSDP
    [M:ITCA] = [M:SDP]
   If GREP <> "C" & GREP <> "D" & indice <> 3 & [M:ITC1]ACTCST(indice) <> 0
# "Cette valeur sera répercutée globalement dans un sous-total et les autres sous-totaux seront annulés !" 
        Call MESSAGE(mess(201,199,1)) From GESECRAN  
   Endif  

   [M:ITC1]ACTMOD(indice) = 1 # flag technique pour màj l'écran détail en après ligne
#   Affecter la variable [M:ITC1] pour que le calcul d'Avant-zone du total soit juste 
   [M:ITC1]ACTCST(indice) = VALEUR : Affzo ACTCST(5), ACTCST(6)  
    Call MODCST(indice,"ACT")
Elsif indice=7
    [M:ITCA]QTY = VALEUR
Endif  
End

########################################
Subprog AS_BUDCST(VALEUR)
Variable Decimal VALEUR
If indice<>7
    Raz GBOUT2
Endif
End
########################################
Subprog AM_BUDCST(VALEUR)
Variable Decimal VALEUR
Local Decimal LDIFPRI
If indice < 5 
    LDIFPRI=VALEUR-[M:ITC1]BUDCST(indice)
    [M:SDP] = [M:ITCB]
#    Gosub REPARTIR From SUBSDP
    [M:ITCB] = [M:SDP]

   If GREP <> "C" & GREP <> "D" & indice <> 3 & [M:ITC1]BUDCST(indice) <> 0
# "Cette valeur sera répercutée globalement dans un sous-total et les autres sous-totaux seront annulés !" 
        Call MESSAGE(mess(201,199,1)) From GESECRAN  
   Endif  

   [M:ITC1]BUDMOD(indice) = 1 # flag technique pour màj l'écran détail en après ligne
#   Affecter la variable [M:ITC1] pour que le calcul d'Avant-zone du total soit juste 
   [M:ITC1]BUDCST(indice) = VALEUR : Affzo BUDCST(5), BUDCST(6)  
    Call MODCST(indice,"BUD")
Elsif indice=7
    [M:ITCB]QTY = VALEUR
Endif  
End

########################################
Subprog AS_SIMCST(VALEUR)
Variable Decimal VALEUR
If indice<>7
    Raz GBOUT2
Endif
End

########################################
Subprog AM_SIMCST(VALEUR)
Variable Decimal VALEUR
Local Decimal LDIFPRI
If indice < 5 
    LDIFPRI=VALEUR-[M:ITC1]SIMCST(indice)
    [M:SDP] = [M:ITCS]
#    Gosub REPARTIR From SUBSDP
    [M:ITCS] = [M:SDP]

   If GREP <> "C" & GREP <> "D" & indice <> 3 & [M:ITC1]SIMCST(indice) <> 0
# "Cette valeur sera répercutée globalement dans un sous-total et les autres sous-totaux seront annulés !" 
        Call MESSAGE(mess(201,199,1)) From GESECRAN  
   Endif  

   [M:ITC1]SIMMOD(indice) = 1 # flag technique pour màj l'écran détail en après ligne
#   Affecter la variable [M:ITC1] pour que le calcul d'Avant-zone du total soit juste 
   [M:ITC1]SIMCST(indice) = VALEUR : Affzo SIMCST(5), SIMCST(6)  
    Call MODCST(indice,"SIM")
Elsif indice=7
    [M:ITCS]QTY = VALEUR
Endif  
End
 
########################################
Subprog AS_STOFCY(VALEUR)
Variable Char     VALEUR
If GFLTFCY <> ""
  mkstat = 2
  VALEUR = GFLTFCY
Endif
End
 
Subprog C_STOFCY(VALEUR)
Variable Char     VALEUR
Call CONTROLE("ITF","",VALEUR,[M:ITC0]ITMREF,mkstat) From CONTOBJ
End
 
Subprog AP_STOFCY(VALEUR)
Variable Char    VALEUR()
# Format des colonnes selon ligne : 7 montants puis qté
Call GETDEV(VALEUR) From DEVSUB
For I=0 To 6
 ##   [M:ITC1]FMTLIG(I) = "N3z:" + [F:TCU]CURFMT1
   [M:ITC1]FMTLIG(I) = "N3z:11."+num$(GDECPRI) # correction bug 7164
Next

Call FMTQTY([F:ITM]STU) From TRTDIV
[M:ITC1]FMTLIG(7) = "Nz:" + GFMTQTY
End

########################################
Subprog C_OVECOD(VALEUR)
Variable Char     VALEUR
If VALEUR <> "" & [M:ITC0]CUR <> [F:OVE]CUR 
   GMESSAGE = mess(204,199,1)
   mkstat = 2
Endif 
End
 
########################################
Subprog AS_BRDCOD(VALEUR)
Variable Integer  VALEUR
If GREP <> "C"
  mkstat = 2  
Endif
End

Subprog C_BRDCOD(VALEUR)
Variable Integer  VALEUR
# "Modification interdite : des enregistrements de coûts existent déjà pour cet article" 
# zone saisie qu'en création de coût 
If VALEUR <> [F:ITM]BRDCOD & GREP = "C" 
    Local File ITMCOST [ITC2]  
    For [ITC2] Where ITMREF = [M:ITC0]ITMREF 
      GERR = 3  # avertissement au lieu de mkstat = 2 (26/11/01)
      GMESSAGE = mess(207,199,1) 
      Break 
    Next 
Endif 
End
 
########################################
Subprog AP_ITMREF(VALEUR)
Variable Char     VALEUR
Call LECTURE("ITM",VALEUR,"") From CONTOBJ
Call FMTQTY([F:ITM]STU) From TRTDIV # rajouté 25/06/01
[M:ITC1]FMTLIG(7) = "Nz:" + GFMTQTY
End
 
Subprog AS_ITMREF(VALEUR)
Variable Char     VALEUR
If GFLTITM <> ""
  VALEUR = GFLTITM
  mkstat = 2
  Call LECTURE("ITM",GFLTITM,"") From CONTOBJ
  Call FMTQTY([F:ITM]STU) From TRTDIV
  [M:ITC1]FMTLIG(7) = "Nz:" + GFMTQTY # rajouté 25/06/01(car AP_ pas fait)
Endif
End

Subprog AM_ITMREF(VALEUR)
Variable Char     VALEUR
# en création ou en duplication
If [F:ITM]ITMREF <> VALEUR
     Read [ITM]ITM0=VALEUR
Endif
[M:ITC0] = [F:ITM] # pour TCLCOD,BRDCOD, STU et PRIDIV
If [M:ITC0]STOFCY <> ""
     Read [ITF]ITF0=VALEUR;[M:ITC0]STOFCY
     # alimenter les zones reprises de ITF
     If !fstat
         [M:ITC0] = [F:ITF]    # 17/04/03 (résoudrait le 17728) v 140
     Endif
Endif
Affzo [M:ITC0]10,15

Call INITCCE
End

#####################################################################" 
Subprog INIQTY(VALEUR) 
Variable Decimal VALEUR 
If indice = 7 
  Call LECTURE("ITF",[M:ITC0]STOFCY,[M:ITC0]ITMREF) From CONTOBJ 
  If [F:ITF]REOMINQTY <> 0 
    VALEUR = [F:ITF]REOMINQTY 
  Else 
    VALEUR = 1 
  Endif 
Endif 
End

#----------------------------------------#
# Affichage des détails de FG par nature # v 140 remplacé par Action SAIITCNAT
#----------------------------------------#

##########################################################################
Subprog APRES_BASTAB
#  si on abandonne la ligne : recalculer les totaux pour les 4 colonnes !! 
#  l'affichage suffit !!(AV_ fait la somme) 
If indice < 5 
  Affzo STDCST(5), STDCST(6),ACTCST(5), ACTCST(6), BUDCST(5), BUDCST(6), SIMCST(5), SIMCST(6)
  If adxgtb <> 1
   # Quand on valide une ligne où l'on a modifié un montant global : 
   # selon le flag mis à jour en AM_xxx, modifier l'écran détail associé (éviter déphasage).
     # (mettre aussi à jour le mask ITCLEV ??)
   # Valeur répercutée globalement dans un sous-total et raz des autres sous-totaux 
   # > v 140 raz aussi les ...LEV et màj le niveau matière mais ils ne sont pas ds l'écran !!>> et les FXD
   Case indice 
    When 0
      If [M:ITC1]STDMOD(indice)=1
        Raz [M:ITCD]MATCST : [M:ITCD]MATCST([M:ITC0]BRDCOD-1) = [M:ITC1]STDCST(indice)
        [M:ITCD]MATTOT = [M:ITC1]STDCST(indice)
        # mettre en phase les autres zones : partie fixe n'ont plus de sens
#        Raz [M:ITCD]FXDMATCST,[M:ITCD]FXDMATLEV
      Endif
      If [M:ITC1]ACTMOD(indice)=1
        Raz [M:ITCA]MATCST : [M:ITCA]MATCST([M:ITC0]BRDCOD-1) = [M:ITC1]ACTCST(indice)
        [M:ITCA]MATTOT = [M:ITC1]ACTCST(indice)
#        [M:ITCA]MATLEVCST([M:ITC0]BRDCOD-1) = [M:ITC1]ACTCST(indice) # màj pour cohérence
#        Raz [M:ITCA]FXDMATCST,[M:ITCA]FXDMATLEV
      Endif
      If [M:ITC1]BUDMOD(indice)=1
        Raz [M:ITCB]MATCST : [M:ITCB]MATCST([M:ITC0]BRDCOD-1) = [M:ITC1]BUDCST(indice)
        [M:ITCB]MATTOT = [M:ITC1]BUDCST(indice)
#        [M:ITCB]MATLEVCST([M:ITC0]BRDCOD-1) = [M:ITC1]BUDCST(indice) # màj pour cohérence
#        Raz [M:ITCB]FXDMATCST,[M:ITCB]FXDMATLEV
      Endif
      If [M:ITC1]SIMMOD(indice)=1
        Raz [M:ITCS]MATCST : [M:ITCS]MATCST([M:ITC0]BRDCOD-1) = [M:ITC1]SIMCST(indice)
        [M:ITCS]MATTOT = [M:ITC1]SIMCST(indice)
#        [M:ITCS]MATLEVCST([M:ITC0]BRDCOD-1) = [M:ITC1]SIMCST(indice) # màj pour cohérence
#        Raz [M:ITCS]FXDMATCST,[M:ITCS]FXDMATLEV
      Endif
    When 1 
      If [M:ITC1]STDMOD(indice)=1
        Raz [M:ITCD]MACCST : [M:ITCD]MACCST(0) = [M:ITC1]STDCST(indice)
        [M:ITCD]MACTOT = [M:ITC1]STDCST(indice)
#        [M:ITCD]MACLEVCST(0) = [M:ITC1]STDCST(indice) # màj pour cohérence
#        Raz [M:ITCD]FXDMACCST,[M:ITCD]FXDMACLEV
      Endif
      If [M:ITC1]ACTMOD(indice)=1
        Raz [M:ITCA]MACCST : [M:ITCA]MACCST(0) = [M:ITC1]ACTCST(indice)
        [M:ITCA]MACTOT = [M:ITC1]ACTCST(indice)
#        [M:ITCA]MACLEVCST(0) = [M:ITC1]ACTCST(indice) # màj pour cohérence
#        Raz [M:ITCA]FXDMACCST,[M:ITCA]FXDMACLEV
      Endif
      If [M:ITC1]BUDMOD(indice)=1
        Raz [M:ITCB]MACCST : [M:ITCB]MACCST(0) = [M:ITC1]BUDCST(indice)
        [M:ITCB]MACTOT = [M:ITC1]BUDCST(indice)
#        [M:ITCB]MACLEVCST(0) = [M:ITC1]BUDCST(indice) # màj pour cohérence
#        Raz [M:ITCB]FXDMACCST,[M:ITCB]FXDMACLEV
      Endif
      If [M:ITC1]SIMMOD(indice)=1
        Raz [M:ITCS]MACCST : [M:ITCS]MACCST(0) = [M:ITC1]SIMCST(indice)
        [M:ITCS]MACTOT = [M:ITC1]SIMCST(indice)
#        [M:ITCS]MACLEVCST = [M:ITC1]SIMCST(indice) # màj pour cohérence
#        Raz [M:ITCS]FXDMACCST,[M:ITCS]FXDMACLEV
      Endif
    When 2 
      If [M:ITC1]STDMOD(indice)=1
        Raz [M:ITCD]LABCST : [M:ITCD]LABCST(0) = [M:ITC1]STDCST(indice)
        [M:ITCD]LABTOT = [M:ITC1]STDCST(indice)
#        [M:ITCD]LABLEVCST(0) = [M:ITC1]STDCST(indice) # màj pour cohérence
#        Raz [M:ITCD]FXDLABCST,[M:ITCD]FXDLABLEV
      Endif
      If [M:ITC1]ACTMOD(indice)=1
        Raz [M:ITCA]LABCST : [M:ITCA]LABCST(0) = [M:ITC1]ACTCST(indice)
        [M:ITCA]LABTOT = [M:ITC1]ACTCST(indice)
#        [M:ITCA]LABLEVCST(0) = [M:ITC1]ACTCST(indice) # màj pour cohérence
#        Raz [M:ITCA]FXDLABCST,[M:ITCA]FXDLABLEV
      Endif
      If [M:ITC1]BUDMOD(indice)=1
        Raz [M:ITCB]LABCST : [M:ITCB]LABCST(0) = [M:ITC1]BUDCST(indice)
        [M:ITCB]LABTOT = [M:ITC1]BUDCST(indice)
#        [M:ITCB]LABLEVCST(0) = [M:ITC1]BUDCST(indice) # màj pour cohérence
#        Raz [M:ITCB]FXDLABCST,[M:ITCB]FXDLABLEV
      Endif
      If [M:ITC1]SIMMOD(indice)=1
        Raz [M:ITCS]LABCST : [M:ITCS]LABCST(0) = [M:ITC1]SIMCST(indice)
        [M:ITCS]LABTOT = [M:ITC1]SIMCST(indice)
#        [M:ITCS]LABLEVCST(0) = [M:ITC1]SIMCST(indice) # màj pour cohérence
#        Raz [M:ITCS]FXDLABCST,[M:ITCS]FXDLABLEV
      Endif
    When 3 
      If [M:ITC1]STDMOD(indice)=1
        Raz [M:ITCD]SCOCST : [M:ITCD]SCOCST = [M:ITC1]STDCST(indice)
        [M:ITCD]SCOTOT = [M:ITC1]STDCST(indice)
#        [M:ITCD]SCOLEVCST = [M:ITC1]STDCST(indice)
#        Raz [M:ITCD]FXDSCOCST,[M:ITCD]FXDSCOLEV
      Endif
      If [M:ITC1]ACTMOD(indice)=1
        Raz [M:ITCA]SCOCST : [M:ITCA]SCOCST = [M:ITC1]ACTCST(indice)
        [M:ITCA]SCOTOT = [M:ITC1]ACTCST(indice)
#        [M:ITCA]SCOLEVCST = [M:ITC1]ACTCST(indice)
#        Raz [M:ITCA]FXDSCOCST,[M:ITCA]FXDSCOLEV
      Endif
      If [M:ITC1]BUDMOD(indice)=1
        Raz [M:ITCB]SCOCST : [M:ITCB]SCOCST = [M:ITC1]BUDCST(indice)
        [M:ITCB]SCOTOT = [M:ITC1]BUDCST(indice)
#        [M:ITCB]SCOLEVCST = [M:ITC1]BUDCST(indice)
#        Raz [M:ITCB]FXDSCOCST,[M:ITCB]FXDSCOLEV
      Endif
      If [M:ITC1]SIMMOD(indice)=1
        Raz [M:ITCS]SCOCST : [M:ITCS]SCOCST = [M:ITC1]SIMCST(indice)
        [M:ITCS]SCOTOT = [M:ITC1]SIMCST(indice)
#        [M:ITCS]SCOLEVCST = [M:ITC1]SIMCST(indice)
#        Raz [M:ITCS]FXDSCOCST,[M:ITCS]FXDSCOLEV
      Endif
    When 4 
      If [M:ITC1]STDMOD(indice)=1
        Raz [M:ITCD]OVEMACCST,OVESCOCST,OVELABCST : [M:ITCD]OVEMATCST = [M:ITC1]STDCST(indice)
        # mettre en phase les autres zones : partie fixe n'ont plus de sens
#        Raz [M:ITCD]FXDOVEMAT,[M:ITCD]FXDOVEMAC,[M:ITCD]FXDOVELAB,[M:ITCD]FXDOVESCO
      Endif
      If [M:ITC1]ACTMOD(indice)=1
        Raz [M:ITCA]OVEMACCST,OVESCOCST,OVELABCST : [M:ITCA]OVEMATCST = [M:ITC1]ACTCST(indice)
#        Raz [M:ITCA]OVEMACLEV,OVESCOLEV,OVELABLEV : [M:ITCA]OVEMATLEV = [M:ITC1]ACTCST(indice)
#        [M:ITCA]OVELEVCST = [M:ITC1]ACTCST(indice)
#        Raz [M:ITCA]FXDOVEMAT,[M:ITCA]FXDOVEMAC,[M:ITCA]FXDOVELAB,[M:ITCA]FXDOVESCO,[M:ITCA]FXDOVELEV
#        Raz [M:ITCA]FXDOVEMATL,[M:ITCA]FXDOVEMACL,[M:ITCA]FXDOVELABL,[M:ITCA]FXDOVESCOL
      Endif
      If [M:ITC1]BUDMOD(indice)=1
        Raz [M:ITCB]OVEMACCST,OVESCOCST,OVELABCST : [M:ITCB]OVEMATCST = [M:ITC1]BUDCST(indice)
#        Raz [M:ITCB]OVEMACLEV,OVESCOLEV,OVELABLEV : [M:ITCB]OVEMATLEV = [M:ITC1]BUDCST(indice)
#        [M:ITCB]OVELEVCST = [M:ITC1]BUDCST(indice)
#        Raz [M:ITCB]FXDOVEMAT,[M:ITCB]FXDOVEMAC,[M:ITCB]FXDOVELAB,[M:ITCB]FXDOVESCO,[M:ITCB]FXDOVELEV
#        Raz [M:ITCB]FXDOVEMATL,[M:ITCB]FXDOVEMACL,[M:ITCB]FXDOVELABL,[M:ITCB]FXDOVESCOL
      Endif
      If [M:ITC1]SIMMOD(indice)=1
        Raz [M:ITCS]OVEMACCST,OVESCOCST,OVELABCST : [M:ITCS]OVEMATCST = [M:ITC1]SIMCST(indice)
#        Raz [M:ITCS]OVEMACLEV,OVESCOLEV,OVELABLEV : [M:ITCS]OVEMATLEV = [M:ITC1]SIMCST(indice)
#        [M:ITCS]OVELEVCST = [M:ITC1]SIMCST(indice)
#        Raz [M:ITCS]FXDOVEMAT,[M:ITCS]FXDOVEMAC,[M:ITCS]FXDOVELAB,[M:ITCS]FXDOVESCO,[M:ITCS]FXDOVELEV
#        Raz [M:ITCS]FXDOVEMATL,[M:ITCS]FXDOVEMACL,[M:ITCS]FXDOVELABL,[M:ITCS]FXDOVESCOL
      Endif
   Endcase

    If [M:ITC1]STDMOD(indice)=1
        [M:ITC2]STDCST = [M:ITC1]STDCST
        [M:ICLD] = [M:ITCD]

#        Raz [M:ITCD]MATLEVCST
#        [M:ITCD]MATLEVCST([M:ITC0]BRDCOD-1) = [M:ITC1]STDCST(0)
#        Raz [M:ITCD]FXDMATLEV

#        Raz [M:ITCD]MACLEVCST
#        [M:ITCD]MACLEVCST(0) = [M:ITC1]STDCST(1)
#        Raz [M:ITCD]FXDMACLEV

#        Raz [M:ITCD]LABLEVCST
#        [M:ITCD]LABLEVCST(0) = [M:ITC1]STDCST(2)
#        Raz [M:ITCD]FXDLABLEV

#        [M:ITCD]SCOLEVCST    = [M:ITC1]STDCST(3)
#        Raz [M:ITCD]FXDSCOLEV

#        Raz [M:ITCD]OVEMACLEV,OVESCOLEV,OVELABLEV
#        Raz [M:ITCD]FXDOVELEV,[M:ITCD]FXDOVEMATL,[M:ITCD]FXDOVEMACL,[M:ITCD]FXDOVELABL,[M:ITCD]FXDOVESCOL
#        [M:ITCD]OVEMATLEV = [M:ITC1]STDCST(4)
#        [M:ITCD]OVELEVCST = [M:ITC1]STDCST(4)

    Endif

    If [M:ITC1]ACTMOD(indice)=1
        [M:ITC2]ACTCST = [M:ITC1]ACTCST
        [M:ICLA] = [M:ITCA]

#        Raz [M:ITCA]MATLEVCST
#        [M:ITCA]MATLEVCST([M:ITC0]BRDCOD-1) = [M:ITC1]ACTCST(0)
#        Raz [M:ITCA]FXDMATLEV

#        Raz [M:ITCA]MACLEVCST
#        [M:ITCA]MACLEVCST(0) = [M:ITC1]ACTCST(1)
#        Raz [M:ITCA]FXDMACLEV

#        Raz [M:ITCA]LABLEVCST
#        [M:ITCA]LABLEVCST(0) = [M:ITC1]ACTCST(2)
#        Raz [M:ITCA]FXDLABLEV

#        [M:ITCA]SCOLEVCST    = [M:ITC1]ACTCST(3)
#        Raz [M:ITCA]FXDSCOLEV

#        Raz [M:ITCA]OVEMACLEV,OVESCOLEV,OVELABLEV
#        Raz [M:ITCA]FXDOVELEV,[M:ITCA]FXDOVEMATL,[M:ITCA]FXDOVEMACL,[M:ITCA]FXDOVELABL,[M:ITCA]FXDOVESCOL
#        [M:ITCA]OVEMATLEV = [M:ITC1]ACTCST(4)
#        [M:ITCA]OVELEVCST = [M:ITC1]ACTCST(4)

    Endif

    If [M:ITC1]BUDMOD(indice)=1
        [M:ITC2]BUDCST = [M:ITC1]BUDCST
        [M:ICLB] = [M:ITCB]

#        Raz [M:ITCB]MATLEVCST
#        [M:ITCB]MATLEVCST([M:ITC0]BRDCOD-1) = [M:ITC1]BUDCST(0)
#        Raz [M:ITCB]FXDMATLEV

#        Raz [M:ITCB]MACLEVCST
#        [M:ITCB]MACLEVCST(0) = [M:ITC1]BUDCST(1)
#        Raz [M:ITCB]FXDMACLEV

#        Raz [M:ITCB]LABLEVCST
#        [M:ITCB]LABLEVCST(0) = [M:ITC1]BUDCST(2)
#        Raz [M:ITCB]FXDLABLEV

#        [M:ITCB]SCOLEVCST    = [M:ITC1]BUDCST(3)
#        Raz [M:ITCB]FXDSCOLEV

#        Raz [M:ITCB]OVEMACLEV,OVESCOLEV,OVELABLEV
#        Raz [M:ITCB]FXDOVELEV,[M:ITCB]FXDOVEMATL,[M:ITCB]FXDOVEMACL,[M:ITCB]FXDOVELABL,[M:ITCB]FXDOVESCOL
#        [M:ITCB]OVEMATLEV = [M:ITC1]BUDCST(4)
#        [M:ITCB]OVELEVCST = [M:ITC1]BUDCST(4)

    Endif

    If [M:ITC1]SIMMOD(indice)=1
        [M:ITC2]SIMCST = [M:ITC1]SIMCST
        [M:ICLS] = [M:ITCS]

#        Raz [M:ITCS]MATLEVCST
#        [M:ITCS]MATLEVCST([M:ITC0]BRDCOD-1) = [M:ITC1]SIMCST(0)
#        Raz [M:ITCS]FXDMATLEV

#        Raz [M:ITCS]MACLEVCST
#        [M:ITCS]MACLEVCST(0) = [M:ITC1]SIMCST(1)
#        Raz [M:ITCS]FXDMACLEV

#        Raz [M:ITCS]LABLEVCST
#        [M:ITCS]LABLEVCST(0) = [M:ITC1]SIMCST(2)
#        Raz [M:ITCS]FXDLABLEV

#        [M:ITCS]SCOLEVCST    = [M:ITC1]SIMCST(3)
#        Raz [M:ITCS]FXDSCOLEV

#        Raz [M:ITCS]OVEMACLEV,OVESCOLEV,OVELABLEV
#        Raz [M:ITCS]FXDOVELEV,[M:ITCS]FXDOVEMATL,[M:ITCS]FXDOVEMACL,[M:ITCS]FXDOVELABL,[M:ITCS]FXDOVESCOL
#        [M:ITCS]OVEMATLEV = [M:ITC1]SIMCST(4)
#        [M:ITCS]OVELEVCST = [M:ITC1]SIMCST(4)

    Endif

  Endif
Endif
End

##########################################################################
Subprog D_STOFCY(VALEUR)
Variable Char    VALEUR()
VALEUR = GFCYDEF(0)
End

##########################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
# pour la création depuis le menu et la duplication
Read [ITF]ITF0=[M:ITC0]ITMREF;VALEUR
# alimenter les zones reprises de ITF
[M:ITC0] = [F:ITF]    # 17/04/03 (résoudrait le 17728) v 140

Affzo [M:ITC0]10,15

Call INITCCE
End

##########################################################################

##########################################################################
Subprog INITCCE
Local Integer I
Local Char    LSEC(GLONCCE)

    For I=1 To max(GNBDIE,GOPTCANA)
        If dim([M:ITC0]CCE)>I-1
            Call INISEC (LSEC, "STJVAL", I) From TRTX3CPT
            [M:ITC0]CCE(I-1) = LSEC
        Else
            Break
        Endif
    Next
End

######################################################################################
Subprog C_STDSTR(VALEUR)
Variable Date    VALEUR
Call CTRITCDAT(1,1,VALEUR,[M:ITC1]STDSEQ)
End

Subprog C_STDEND(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]STDSTR
    mkstat = 2
    End
Endif
Call CTRITCDAT(1,2,VALEUR,[M:ITC1]STDSEQ)
End

Subprog C_ACTSTR(VALEUR)
Variable Date    VALEUR
Call CTRITCDAT(2,1,VALEUR,[M:ITC1]ACTSEQ)
End

Subprog C_ACTEND(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]ACTSTR
    mkstat = 2
Endif
Call CTRITCDAT(2,2,VALEUR,[M:ITC1]ACTSEQ)
End

Subprog C_BUDSTR(VALEUR)
Variable Date    VALEUR
Call CTRITCDAT(3,1,VALEUR,[M:ITC1]BUDSEQ)
End

Subprog C_BUDEND(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]BUDSTR
    mkstat = 2
Endif
Call CTRITCDAT(3,2,VALEUR,[M:ITC1]BUDSEQ)
End

Subprog C_SIMSTR(VALEUR)
Variable Date    VALEUR
End

Subprog C_SIMEND(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]SIMSTR
    mkstat = 2
Endif
End

######################################################################################
Subprog CTRITCDAT(PTYP, PSTREND, PDAT, PSEQ)
Value Integer PTYP
Value Integer PSTREND
Value Date    PDAT
Value Integer PSEQ

Local Integer LRET
Local Date LDAT

If PDAT=[0/0/0]
    LDAT=[02/01/1900]
Else
    LDAT = PDAT
Endif
# Date de référence comprise entre les dates début et fin
Case PSTREND
    When 1:    # STR
        If LDAT>[M:ITC0]DATREF
            mkstat=2
            LRET = 1
            End
        Endif
        # Continuité des coûts
        # Existe-t-il un coût avec une date de fin = date saisie - 1 ? ...
        Filter [ITC2] Where STOFCY=[M:ITC0]STOFCY
&                         & ITMREF=[M:ITC0]ITMREF
&                         & CSTTYP=PTYP
&                         & ITCSEQ<>0 & ITCSEQ<>PSEQ
&                         & UID=0
&                         & ITCENDDAT=LDAT-1
        LRET=2
        For [ITC2]
            LRET=0
            Break
        Next
        If LRET=2
            # Si non, est-ce qu'il existe des coûts avec une date de validité inférieure
            Filter [ITC2] Where STOFCY=[M:ITC0]STOFCY
&                             & ITMREF=[M:ITC0]ITMREF
&                             & CSTTYP=PTYP
&                             & ITCSEQ<>0 & ITCSEQ<>PSEQ
&                             & UID=0
&                             & ITCSTRDAT<LDAT
            LRET = 0
            For [ITC2]
                LRET=2
                Break
            Next
        Endif
        Filter [ITC2]
        If LRET
            GMESSAGE = mess(909,196,1)
            GERR = 3
            End
        Endif
    When 2:    # END
        If LDAT<[M:ITC0]DATREF & PDAT<>[0/0/0]
            mkstat=2
            LRET = 1
            End
        Endif
        # Continuité des coûts
        # Existe-t-il un coût avec une date de fin = date saisie - 1 ? ...
        Filter [ITC2] Where STOFCY=[M:ITC0]STOFCY
&                         & ITMREF=[M:ITC0]ITMREF
&                         & CSTTYP=PTYP
&                         & ITCSEQ<>0 & ITCSEQ<>PSEQ
&                         & UID=0
&                         & ITCSTRDAT=LDAT+1
        LRET=2
        For [ITC2]
            LRET=0
            Break
        Next
        If LRET=2
            # ...Si non, est-ce qu'il existe des coûts avec une date de validité supérieure
            Filter [ITC2] Where STOFCY=[M:ITC0]STOFCY
&                             & ITMREF=[M:ITC0]ITMREF
&                             & CSTTYP=PTYP
&                             & ITCSEQ<>0 & ITCSEQ<>PSEQ
&                             & UID=0
&                             & ITCENDDAT>LDAT
            LRET = 0
            For [ITC2]
                LRET=2
                Break
            Next
        Endif
        Filter [ITC2]
        If LRET
            GMESSAGE = mess(909,196,1)
            GERR = 3
            End
        Endif
Endcase

# Chevauchement de coûts
Filter [ITC2] Where STOFCY=[M:ITC0]STOFCY
&                 & ITMREF=[M:ITC0]ITMREF
&                 & CSTTYP=PTYP
&                 & ITCSEQ<>0 & ITCSEQ<>PSEQ
&                 & UID=0
&                 & ITCSTRDAT<=LDAT & LDAT<=ITCENDDAT
For [ITC2]
    LRET=3
    Break
Next
Filter [ITC2]
If LRET<>0
    GERR = 1
    End
Endif

End


###############################################################
Subprog INITDAT(PDAT)
Value Date PDAT

Local Decimal LEXE, LPER

Filter [ITC2] Where STOFCY=[M:ITC0]STOFCY
&                 & ITMREF=[M:ITC0]ITMREF
&                 & CSTTYP=1
&                 & ITCSEQ<>0
&                 & UID=0
&                 & ITCENDDAT<PDAT
Read [ITC2]ITC1 Last
Filter [ITC2]
If fstat
    Raz [M:ITC1]STDSTR
Else
    [M:ITC1]STDSTR = [F:ITC2]ITCENDDAT+1
Endif

Filter [ITC2] Where STOFCY=[M:ITC0]STOFCY
&                 & ITMREF=[M:ITC0]ITMREF
&                 & CSTTYP=1
&                 & ITCSEQ<>0
&                 & UID=0
&                 & ITCSTRDAT>PDAT
Read [ITC2]ITC1 First
Filter [ITC2]
If fstat
    Call GETSOC([M:ITC0]STOFCY) From DEVSUB
    Call GETPER([M:ITC0]STOFCY,GTYPGEN,PDAT,LEXE,LPER) From CPTSUB
    Read [FIY]FIY0=[F:PER]CPY;1;LEXE
    [M:ITC1]STDEND=[F:FIY]FIYEND
Else
    [M:ITC1]STDEND = max([M:ITC1]STDSTR,[F:ITC2]ITCSTRDAT-1)
Endif
Affzo [M:ITC1]STDSTR,STDEND
[M:ITC2]STDSTR = [M:ITC1]STDSTR
[M:ITC2]STDEND = [M:ITC1]STDEND
Affzo [M:ITC2]STDSTR,STDEND
End

##################################################################
Funprog GETITCSEQ(PFCY,PITM,PTYP)
Value Char    PFCY
Value Char    PITM
Value Integer PTYP

    Raz [F:ITC2]
    Columns [ITC2] (ITCSEQ)
    For [ITC2]ITC0 Where STOFCY=PFCY
&                      & ITMREF=PITM
&                      & CSTTYP=PTYP
&                      & UID=0       # !! ordre de ITCSEQ inversé
        Break
    Next
    Columns [ITC2]
End [F:ITC2]ITCSEQ+1


##################################################################
Subprog DET2ITC1(PTYPCST)
Value Integer PTYPCST

Case PTYPCST
    When 1 :
        If [M:ITC1]STDCST(0) <> sum([M:ITCD]MATCST)
            [M:ITC1]STDCST(0) = sum([M:ITCD]MATCST)  : # matière
            [M:ITC1]STDMOD(0) = 1 * (GACTION<>"GOBJET")    # Lorsque c'est GOBJET on est en train de charge le coût (action LIENS)
        Endif
        If [M:ITC1]STDCST(1) <> sum([M:ITCD]MATCST)
            [M:ITC1]STDCST(1) = sum([M:ITCD]MACCST)  : # machine
            [M:ITC1]STDMOD(1) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]STDCST(2) <> sum([M:ITCD]MATCST)
            [M:ITC1]STDCST(2) = sum([M:ITCD]LABCST)  : # main d'oeuvre
            [M:ITC1]STDMOD(2) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]STDCST(3) <> sum([M:ITCD]MATCST)
            [M:ITC1]STDCST(3) =     [M:ITCD]SCOTOT   : # sous-traitance
            [M:ITC1]STDMOD(3) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]STDCST(4) <> sum([M:ITCD]MATCST)
            [M:ITC1]STDCST(4) =     [M:ITCD]OVEMATCST+[M:ITCD]OVEMACCST+[M:ITCD]OVELABCST+[M:ITCD]OVESCOCST   : # FG
            [M:ITC1]STDMOD(4) = 1 * (GACTION<>"GOBJET")
        Endif
        [M:ITC1]STDCST(5) = sum([M:ITC1]STDCST(0..3))   : # Tot sans FG
        [M:ITC1]STDCST(6) = sum([M:ITC1]STDCST(0..4))   : # Tot avec FG
    When 2:
        If [M:ITC1]ACTCST(0) <> sum([M:ITCA]MATCST)
            [M:ITC1]ACTCST(0) = sum([M:ITCA]MATCST)  : # matière
            [M:ITC1]ACTMOD(0) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]ACTCST(1) <> sum([M:ITCA]MATCST)
            [M:ITC1]ACTCST(1) = sum([M:ITCA]MACCST)  : # machine
            [M:ITC1]ACTMOD(1) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]ACTCST(2) <> sum([M:ITCA]MATCST)
            [M:ITC1]ACTCST(2) = sum([M:ITCA]LABCST)  : # main d'oeuvre
            [M:ITC1]ACTMOD(2) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]ACTCST(3) <> sum([M:ITCA]MATCST)
            [M:ITC1]ACTCST(3) =     [M:ITCA]SCOTOT   : # sous-traitance
            [M:ITC1]ACTMOD(3) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]ACTCST(4) <> sum([M:ITCA]MATCST)
            [M:ITC1]ACTCST(4) =     [M:ITCA]OVEMATCST+[M:ITCA]OVEMACCST+[M:ITCA]OVELABCST+[M:ITCA]OVESCOCST   : # FG
            [M:ITC1]ACTMOD(4) = 1 * (GACTION<>"GOBJET")
        Endif
        [M:ITC1]ACTCST(5) = sum([M:ITC1]ACTCST(0..3))   : # Tot sans FG
        [M:ITC1]ACTCST(6) = sum([M:ITC1]ACTCST(0..4))   : # Tot avec FG
    When 3:
        If [M:ITC1]BUDCST(0) <> sum([M:ITCB]MATCST)
            [M:ITC1]BUDCST(0) = sum([M:ITCB]MATCST)  : # matière
            [M:ITC1]BUDMOD(0) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]BUDCST(1) <> sum([M:ITCB]MATCST)
            [M:ITC1]BUDCST(1) = sum([M:ITCB]MACCST)  : # machine
            [M:ITC1]BUDMOD(1) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]BUDCST(2) <> sum([M:ITCB]MATCST)
            [M:ITC1]BUDCST(2) = sum([M:ITCB]LABCST)  : # main d'oeuvre
            [M:ITC1]BUDMOD(2) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]BUDCST(3) <> sum([M:ITCB]MATCST)
            [M:ITC1]BUDCST(3) =     [M:ITCB]SCOTOT   : # sous-traitance
            [M:ITC1]BUDMOD(3) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]BUDCST(4) <> sum([M:ITCB]MATCST)
            [M:ITC1]BUDCST(4) =     [M:ITCB]OVEMATCST+[M:ITCB]OVEMACCST+[M:ITCB]OVELABCST+[M:ITCB]OVESCOCST   : # FG
            [M:ITC1]BUDMOD(4) = 1 * (GACTION<>"GOBJET")
        Endif
        [M:ITC1]BUDCST(5) = sum([M:ITC1]BUDCST(0..3))   : # Tot sans FG
        [M:ITC1]BUDCST(6) = sum([M:ITC1]BUDCST(0..4))   : # Tot avec FG
    When 4:
        If [M:ITC1]SIMCST(0) <> sum([M:ITCS]MATCST)
            [M:ITC1]SIMCST(0) = sum([M:ITCS]MATCST)  : # matière
            [M:ITC1]SIMMOD(0) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]SIMCST(1) <> sum([M:ITCS]MATCST)
            [M:ITC1]SIMCST(1) = sum([M:ITCS]MACCST)  : # machine
            [M:ITC1]SIMMOD(1) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]SIMCST(2) <> sum([M:ITCS]MATCST)
            [M:ITC1]SIMCST(2) = sum([M:ITCS]LABCST)  : # main d'oeuvre
            [M:ITC1]SIMMOD(2) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]SIMCST(3) <> sum([M:ITCS]MATCST)
            [M:ITC1]SIMCST(3) =     [M:ITCS]SCOTOT   : # sous-traitance
            [M:ITC1]SIMMOD(3) = 1 * (GACTION<>"GOBJET")
        Endif
        If [M:ITC1]SIMCST(4) <> sum([M:ITCS]MATCST)
            [M:ITC1]SIMCST(4) =     [M:ITCS]OVEMATCST+[M:ITCS]OVEMACCST+[M:ITCS]OVELABCST+[M:ITCS]OVESCOCST   : # FG
            [M:ITC1]SIMMOD(4) = 1 * (GACTION<>"GOBJET")
        Endif
        [M:ITC1]SIMCST(5) = sum([M:ITC1]SIMCST(0..3))   : # Tot sans FG
        [M:ITC1]SIMCST(6) = sum([M:ITC1]BUDCST(0..4))   : # Tot avec FG
Endcase
End

##################################################################
Subprog DET2ITC2(PTYPCST)
Value Integer PTYPCST

Case PTYPCST
    When 1 :
        [M:ITC2]STDCST(0) = sum([M:ICLD]MATCST)  : # matière
        [M:ITC2]STDCST(1) = sum([M:ICLD]MACCST)  : # machine
        [M:ITC2]STDCST(2) = sum([M:ICLD]LABCST)  : # main d'oeuvre
        [M:ITC2]STDCST(3) =     [M:ICLD]SCOTOT   : # sous-traitance
        [M:ITC2]STDCST(4) =     [M:ICLD]OVEMATCST+[M:ICLD]OVEMACCST+[M:ICLD]OVELABCST+[M:ICLD]OVESCOCST   : # FG
        [M:ITC2]STDCST(5) = sum([M:ITC2]STDCST(0..3))   : # Tot sans FG
        [M:ITC2]STDCST(6) = sum([M:ITC2]STDCST(0..4))   : # Tot avec FG
    When 2:
        [M:ITC2]ACTCST(0) = sum([M:ICLA]MATCST)  : # matière
        [M:ITC2]ACTCST(1) = sum([M:ICLA]MACCST)  : # machine
        [M:ITC2]ACTCST(2) = sum([M:ICLA]LABCST)  : # main d'oeuvre
        [M:ITC2]ACTCST(3) =     [M:ICLA]SCOTOT   : # sous-traitance
        [M:ITC2]ACTCST(4) =     [M:ICLA]OVEMATCST+[M:ICLA]OVEMACCST+[M:ICLA]OVELABCST+[M:ICLA]OVESCOCST   : # FG
        [M:ITC2]ACTCST(5) = sum([M:ITC2]ACTCST(0..3))   : # Tot sans FG
        [M:ITC2]ACTCST(6) = sum([M:ITC2]ACTCST(0..4))   : # Tot avec FG
    When 3:
        [M:ITC2]BUDCST(0) = sum([M:ICLB]MATCST)  : # matière
        [M:ITC2]BUDCST(1) = sum([M:ICLB]MACCST)  : # machine
        [M:ITC2]BUDCST(2) = sum([M:ICLB]LABCST)  : # main d'oeuvre
        [M:ITC2]BUDCST(3) =     [M:ICLB]SCOTOT   : # sous-traitance
        [M:ITC2]BUDCST(4) =     [M:ICLB]OVEMATCST+[M:ICLB]OVEMACCST+[M:ICLB]OVELABCST+[M:ICLB]OVESCOCST   : # FG
        [M:ITC2]BUDCST(5) = sum([M:ITC2]BUDCST(0..3))   : # Tot sans FG
        [M:ITC2]BUDCST(6) = sum([M:ITC2]BUDCST(0..4))   : # Tot avec FG
    When 4:
        [M:ITC2]SIMCST(0) = sum([M:ICLS]MATCST)  : # matière
        [M:ITC2]SIMCST(1) = sum([M:ICLS]MACCST)  : # machine
        [M:ITC2]SIMCST(2) = sum([M:ICLS]LABCST)  : # main d'oeuvre
        [M:ITC2]SIMCST(3) =     [M:ICLS]SCOTOT   : # sous-traitance
        [M:ITC2]SIMCST(4) =     [M:ICLS]OVEMATCST+[M:ICLS]OVEMACCST+[M:ICLS]OVELABCST+[M:ICLS]OVESCOCST   : # FG
        [M:ITC2]SIMCST(5) = sum([M:ITC2]SIMCST(0..3))   : # Tot sans FG
        [M:ITC2]SIMCST(6) = sum([M:ITC2]BUDCST(0..4))   : # Tot avec FG
Endcase
End

##################################################################
Subprog LEV2MSK(PABRMSK,PABRFIL)
Value Char PABRMSK
Value Char PABRFIL

Local Integer I

For I=0 To GACTMAT-1
    Assign "[M:"+PABRMSK+"]MATCST(I)" With evalue("[F:"+PABRFIL+"]MATLEVCST(I)")
Next
For I=0 To GACTMAC-1
    Assign "[M:"+PABRMSK+"]MACCST(I)" With evalue("[F:"+PABRFIL+"]MACLEVCST(I)")
Next
For I=0 To GACTLAB-1
    Assign "[M:"+PABRMSK+"]LABCST(I)" With evalue("[F:"+PABRFIL+"]LABLEVCST(I)")
Next
Assign "[M:"+PABRMSK+"]SCOTOT" With evalue("[F:"+PABRFIL+"]SCOLEVCST")
Assign "[M:"+PABRMSK+"]OVEMATCST" With evalue("[F:"+PABRFIL+"]OVEMATLEV")
Assign "[M:"+PABRMSK+"]OVEMACCST" With evalue("[F:"+PABRFIL+"]OVEMACLEV")
Assign "[M:"+PABRMSK+"]OVELABCST" With evalue("[F:"+PABRFIL+"]OVELABLEV")
Assign "[M:"+PABRMSK+"]OVESCOCST" With evalue("[F:"+PABRFIL+"]OVESCOLEV")
End

##################################################################
# Affecte la saisie de ITC1 dans l'écran détail correpondant
# et modifie ITC2
##################################################################
Subprog MODCST(PIND,PTYPCST)
Value Integer PIND
Value Char    PTYPCST

Local Char LABRDET
Local Integer I
Case PTYPCST
    When "STD" : LABRDET="ITCD"
    When "ACT" : LABRDET="ITCA"
    When "BUD" : LABRDET="ITCB"
    When "SIM" : LABRDET="ITCS"
Endcase

    #---- Affectation des champs de détail en fonction du champ saisi dans ITC1 ----#
    Case PIND 
        When 0
            For I=0 To GACTMAT-1
                Assign "[M:"+LABRDET+"]MATCST(I)" With 0
            Next
            Assign "[M:"+LABRDET+"]MATCST([M:ITC0]BRDCOD-1)" With evalue("[M:ITC1]"+PTYPCST+"CST(PIND)")
            Assign "[M:"+LABRDET+"]MATTOT" With evalue("[M:ITC1]"+PTYPCST+"CST(PIND)")
        When 1 
            For I=0 To GACTMAC-1
                Assign "[M:"+LABRDET+"]MACCST(I)" With 0
            Next
            Assign "[M:"+LABRDET+"]MACCST([M:ITC0]BRDCOD-1)" With evalue("[M:ITC1]"+PTYPCST+"CST(PIND)")
            Assign "[M:"+LABRDET+"]MACTOT" With evalue("[M:ITC1]"+PTYPCST+"CST(PIND)")
        When 2 
            For I=0 To GACTLAB-1
                Assign "[M:"+LABRDET+"]LABCST(I)" With 0
            Next
            Assign "[M:"+LABRDET+"]LABCST([M:ITC0]BRDCOD-1)" With evalue("[M:ITC1]"+PTYPCST+"CST(PIND)")
            Assign "[M:"+LABRDET+"]LABTOT" With evalue("[M:ITC1]"+PTYPCST+"CST(PIND)")
        When 3 
            Assign "[M:"+LABRDET+"]SCOCST([M:ITC0]BRDCOD-1)" With evalue("[M:ITC1]"+PTYPCST+"CST(PIND)")
            Assign "[M:"+LABRDET+"]SCOTOT" With evalue("[M:ITC1]"+PTYPCST+"CST(PIND)")
        When 4 
            Assign "[M:"+LABRDET+"]OVEMATCST" With evalue("[M:ITC1]"+PTYPCST+"CST(PIND)")
            Assign "[M:"+LABRDET+"]OVEMACCST" With 0
            Assign "[M:"+LABRDET+"]OVELABCST" With 0
            Assign "[M:"+LABRDET+"]OVESCOCST" With 0
    Endcase
    Assign "[M:ITC1]"+PTYPCST+"CST(5)" With evalue("sigma(0,3, [M:ITC1]"+PTYPCST+"CST(indcum))")
    Assign "[M:ITC1]"+PTYPCST+"CST(6)" With evalue("sigma(0,4, [M:ITC1]"+PTYPCST+"CST(indcum))")

    #---- Affectation des champs de ITC2 ----#
    For I=0 To evalue("dim([M:ITC1]"+PTYPCST+"CST)")-1
        Assign "[M:ITC2]"+PTYPCST+"CST(I)" With evalue("[M:ITC1]"+PTYPCST+"CST(I)")
    Next

    #---- Affectations des champs du détail niveau -----#
    Case PTYPCST
        When "STD" : [M:ICLD] = [M:ITCD]
        When "ACT" : [M:ICLA] = [M:ITCA]
        When "BUD" : [M:ICLB] = [M:ITCB]
        When "SIM" : [M:ICLS] = [M:ITCS]
    Endcase
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran ITC1) 16/11/2006 10:48:53 (CCC)
######################################################################################
Subprog CL_ACTNEW(VALEUR)
Variable Char    VALEUR()
    Effzo [M:ITC1]ACTCST,ACTSTR,ACTEND
    Effzo [M:ITC2]ACTCST,ACTSTR,ACTEND
    [M:ITC1]ACTSTR = [M:ITC0]DATREF
    [M:ITC2]ACTSTR = [M:ITC1]ACTSTR
    Raz [M:ITCA]
    [M:ITCA] = [M:ITC0]
    [M:ITC1]ACTUPD = 2
End

Subprog CL_BUDNEW(VALEUR)
Variable Char    VALEUR()
    Effzo [M:ITC1]BUDCST,BUDSTR,BUDEND
    Effzo [M:ITC2]BUDCST,BUDSTR,BUDEND
    [M:ITC1]BUDSTR = [M:ITC0]DATREF
    [M:ITC2]BUDSTR = [M:ITC1]BUDSTR
    Raz [M:ITCB]
    [M:ITCB] = [M:ITC0]
    [M:ITC1]SIMUPD=2
End

Subprog CL_SIMNEW(VALEUR)
Variable Char    VALEUR()
    Effzo [M:ITC1]SIMCST,SIMSTR,SIMEND
    Effzo [M:ITC2]SIMCST,SIMSTR,SIMEND
    [M:ITC1]SIMSTR = [M:ITC0]DATREF
    [M:ITC2]SIMSTR = [M:ITC1]SIMSTR
    Raz [M:ITCS]
    [M:ITCS] = [M:ITC0]
    [M:ITC1]SIMUPD = 2
End


