##############################################################################
##  Returns the chart code associated with the main general ledger (CAS=1)  ##
##  or the main analytical ledger (CAS=2) for a company                     ##
##############################################################################
Subprog LECMAINPLAN(CAS,SOCIETE,PLAN)
Value    Integer  CAS       : # CAS=1 : General / CAS=2 : Analytical
Value    Char     SOCIETE() : # Company
Variable Char     PLAN()

Local File COMPANY [CPY]
Local File GACM    [GCM]
Local File GLED    [LED]

Call LEC_CPY(SOCIETE) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
If fstat=[V]CST_AOK
 Case CAS
  When 1 : Read [LED]LED0=[F:GCM]LED([F:GCM]GENLEDTYP-1) : PLAN = [F:LED]COA
  When 2 : Read [LED]LED0=[F:GCM]LED([F:GCM]ANALEDTYP-1) : PLAN = [F:LED]COA
 Endcase
Endif
End

######################################################################################################
## Returns the currency of the main general ledger or of the main analytical ledger for a company   ##
######################################################################################################
Subprog SETCUR(CAS,SOCIETE,DEVISE)
Value    Integer CAS       : # CAS=1 : General / CAS=2 : Analytical
Value    Char    SOCIETE()
Variable Char    DEVISE()

Local File COMPANY [CPY]
Local File GACM    [GCM]

Call LEC_CPY(SOCIETE) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
If fstat=[V]CST_AOK
 Case CAS
   When 1 : DEVISE=[F:GCM]CUR([F:GCM]GENLEDTYP-1)
   When 2 : DEVISE=[F:GCM]CUR([F:GCM]ANALEDTYP-1)
 Endcase
Endif
End

###############################################################################################
##  Position of the currencies (transaction currency and ledger currency) relative to the Euro
###############################################################################################
Subprog SETFLGDEV(DEV,SOC,DAT,CURFLG,LEDFLG)
Value Char       DEV()         : # Currency (transaction)
Value Char       SOC()         : # Company
Value Date       DAT           : # Date
Variable Integer CURFLG        : # Position of the transaction currency
Variable Libelle LEDFLG(1..len(mess(0,2644,1))): # Position of each ledger currency (In ou Out)

Local Integer IREF

Local File COMPANY [CPY]
Local File GACM    [GCM]
Local File TABCUR  [TCU]

# Currency of the transaction
CURFLG = 1
Call LEC_TCU(DEV) From CPTLEC
If fstat<>[V]CST_AOK : CURFLG=0 : End : Endif
If [F:TCU]EURDAT<=DAT & [F:TCU]EURFLG=2 : CURFLG=2 : Endif

# Currencies of the ledgers
Call LEC_CPY(SOC) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC

For IREF=1 To len(mess(0,2644,1))
 LEDFLG(IREF) = 1
 Call LEC_TCU([F:GCM]CUR(IREF-1)) From CPTLEC
 If fstat=[V]CST_AOK
  LEDFLG(IREF)=0
 Else
  If [F:TCU]EURDAT<=DAT & [F:TCU]EURFLG=2 : LEDFLG(IREF)=2 : Endif
 Endif
Next
End


###############################################################################################
##  Returns COURMUL(Multiplier rate) and COURDIV (Divider rate)
###############################################################################################

Subprog INI_COURS2(DEVORG,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
Value    Char    DEVORG
Value    Char    DEVDES
Value    Integer TYPCOURS
Value    Date    DATCOURS
Variable Decimal COURMUL
Variable Decimal COURDIV
Variable Integer STAT

Local File TABCUR    [TCU]
Local File TABCHANGE [TCH]

Local Integer INORG , INDES
Local Decimal EURORG , EURDES
Local Char EURO(GLONCUR)

EURO     = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,"","EURO")

STAT=0
Call LEC_TCU(DEVORG) From CPTLEC
INORG  = [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
EURORG = [F:TCU]EURRAT
Call LEC_TCU(DEVDES) From CPTLEC
INDES  = [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
EURDES = [F:TCU]EURRAT
If DEVORG=DEVDES    : # Cas trivial
 COURMUL = 1
 COURDIV = 1
Elsif DEVORG=EURO
 If INDES           : # In => Euro
  COURMUL = 1
  COURDIV = EURDES
 Else               : # xx => Euro
  Call COURS(EURO,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
 Endif
Elsif DEVDES=EURO
 If INORG           : # Euro => In
  COURMUL = EURORG
  COURDIV = 1
 Else               : # Euro => yy
  Call COURS(DEVORG,EURO,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
 Endif
Elsif INDES & INORG : # In => In
 COURMUL = EURORG
 COURDIV = EURDES
Elsif INORG         : # In => Out
 Call COURS(EURO,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
 COURMUL /= EURORG
Elsif INDES         : # Out => In
 Call COURS(DEVORG,EURO,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
 COURMUL *= EURDES
Else                : # xx => yy
 Call COURS(DEVORG,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
Endif
End


###############################################################################################
##  Returns the right rate
###############################################################################################
Subprog COURS(DEVORG,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
Value    Char    DEVORG
Value    Char    DEVDES
Value    Integer TYPCOURS
Value    Date    DATCOURS
Variable Decimal COURMUL
Variable Decimal COURDIV
Variable Integer STAT

Local File TABCHANGE [TCH]

Filter [TCH] Where CHGTYP=TYPCOURS & CURDEN=DEVDES & CUR=DEVORG & CHGSTRDAT<=DATCOURS
Read [TCH]TCH0 Last
Filter [TCH]
If fstat<=2
 COURMUL = [F:TCH]REVCOURS
 COURDIV = [F:TCH]CHGDIV
 STAT    = 0
Else
 STAT = 1 : # no rate found
Endif
# No entry point in Syracuse  : GPOINT = "RECHTCH" : Gosub ENTREE From EXEFNC
End

#####################################################################
## To convert an amount in a specifiv currency (the currency rate is possibly done)
## V150 : using Subprog COURMNT in TRTDEV
#####################################################################
Subprog CONVERT3(CTX,DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,COURS,STAT)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise de destination
Value    Char    DEVSOC           : # Devise société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Value    Decimal COURS            : # Cours devise -> destination eventuelt donné
Variable Integer STAT             : # Status de retour (0 = OK)

Local  Decimal AMTINT             : # Montant intermédiaire
Local  Integer ORGFLG, DESFLG     : # Flags monnaies origine et destination
Local  Decimal ARRONDI, CTX_RNDEURO
Local  Integer I
Local  Char    CTX_EURO(GLONCUR)

Local File TABCUR [TCU]
If [F:TCU]CUR<>DEVDES
 Read [TCU]TCU0 = DEVDES
Endif
ARRONDI = [F:TCU]CURRND

STAT=0
If DEVORG="" | DEVDES=""
  # Devise inexistante
  ASTATUS = fmet this.ASETERROR("",mess(151,105,1),[V]CST_AERROR)
  STAT = 1
  End
Endif

If DEVORG=DEVDES
 MTDES =MTORG
 End
Endif

ORGFLG=1 : DESFLG=1

If [F:TCU]CUR<>DEVDES
 Read [TCU]TCU0 = DEVDES
Endif
If [F:TCU]EURDAT <= DATCOURS & [F:TCU]EURFLG=2 : DESFLG = 2 : Endif

If [F:TCU]CUR<>DEVORG
 Read [TCU]TCU0 = DEVDES
Endif
If [F:TCU]EURDAT <= DATCOURS & [F:TCU]EURFLG=2 : ORGFLG = 2 : Endif

CTX_EURO    = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"EURO")
CTX_RNDEURO = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,CTX.AFOLDER,"EURORND")

If COURS<>0
  If ORGFLG=1
    #-------- 'Out' --> 'Out'
    If DESFLG=1
       MTDES = arr(MTORG*COURS, ARRONDI)
    Else
      #-------- 'Out' --> 'In'
      If DEVDES = CTX_EURO
         MTDES = arr(MTORG*COURS, ARRONDI)
      Else      : # if there is a rate, it's the rate of the euro
         AMTINT = arr(MTORG*COURS, 10^(-CTX_RNDEURO))
         Call CONVERT(CTX,CTX_EURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,AMTINT,MTDES,STAT) From TRTDEV_SYRA
      Endif
    Endif
  Else
    If DESFLG=1
      #-------- 'In' --> 'Out'
      If DEVORG=CTX_EURO
         MTDES = arr(MTORG*COURS, ARRONDI)
      Else
         Call CONVERT(CTX,DEVORG,CTX_EURO,DEVSOC,TYPCOURS,DATCOURS,MTORG,AMTINT,STAT) From TRTDEV_SYRA
         MTDES = arr(AMTINT*COURS, ARRONDI)
      Endif
    Else
      #-------- 'In' --> 'In'  : # si cours renseigné, on n'en tient pas compte
     Call CONVERT(CTX,DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV_SYRA
    Endif
  Endif
Else
  Call CONVERT(CTX,DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV_SYRA
Endif
End
