#<AdxTL>@(#)1.0.0.0 $Revision$
################################################################################
# UTICPT41   Mise à jour du champ STARPT dans SINVOICE           Module Compta #
#            Menu local 429 "Non imprimé" "Imprimé" "Validé"     (Lot FIL)     #
#                   devient "Non validé" "Validé"                              #                     
################################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Initialization 'STARPT' Field and 'STA' Field (SINVOICE Table)") From LECFIC

  Call MAJ_UTICPT41(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT41(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTICPT41 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:SIH])  =0  Local File =DOSSIER+".SINVOICE"   [SIH] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [SIH]
 For [SIH] 
  Readlock [SIH] Curr    
  If !fstat
   # --- alimentation des champs et réécriture enreg
   If [F:SIH]STA>1
    [F:SIH]STARPT = 2
   Else
    [F:SIH]STARPT = 1
   Endif
   Rewrite [F:SIH]
   If !fstat COMPTEUR += 1 Endif
  Endif
 Next
Commit

Close Local File [SIH]

Call ECR_TRACE("UTICPT41 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : ENDIF
If filinfo(filpath("FIL","SINVOICE","fde",APPLI),0)<=0 : End : Endif  
Call MAJ_UTICPT41(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If filinfo(filpath("FIL","SINVOICE","fde",APPLI),0)<=0 : End : Endif  
Call MAJ_UTICPT41(APPLI)
End
