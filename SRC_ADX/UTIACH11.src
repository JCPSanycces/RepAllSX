#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################
# UTIACH11       Utilitaire de récupération du bug 30086    Module ACHAT #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Resynchroniser l'unité de commande (UOM) avec l'unité d'achat (PUU)  #
#   sur les demandes de livraison générées à partir des plans lorsque    #
#   l'unité d'achat de l'article a été modifiée après la création du     #
#   contrat.                                                             #
##########################################################################

Call MAJ_UTIACH11
End

Subprog MAJ_UTIACH11
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH11 - Récup. Bug 30086") From SAIDOS
If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH11 : Utilitaire de resynchro des unités d'achat sur DL") From LECFIC
  Call EXE_UTIACH11(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End

Subprog EXE_UTIACH11(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Char     WMSG(80), WMSG2(30), CLE1(GLONPOH), CRITERE(100)
Local Integer COMPTEUR, STOP
Local Integer  NBENR, NBCOR, CLE2, CLE3
#-----
Call ECR_TRACE("UTIACH11 : Début traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If !clalev([F:POQ])  Local File =DOSSIER+".PORDERQ"  [POQ] : Endif
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, CLE2, CLE3, NBENR, NBCOR, STOP
#-----
$BOUCLE_POQ
If STOP=1
  STOP=2 : CRITERE='POHNUM="'+CLE1+'"'+' & POPLIN='+num$(CLE2)+' & POQSEQ>'+num$(CLE3)
Elsif STOP=2
  STOP=3 : CRITERE='POHNUM="'+CLE1+'"'+' & POPLIN>'+num$(CLE2)
Elsif STOP=3
  STOP=0 : CRITERE='POHNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
CRITERE+=' & POHTYP=2'
Raz COMPTEUR
Trbegin [POQ]
  For [POQ] POQ0 Where evalue(CRITERE)
    COMPTEUR+=1
    NBENR+=1
    If [F:POQ]PUU<>[F:POQ]UOM  Gosub MAJ_POQ : Endif
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:POQ]POHNUM : CLE2=[F:POQ]POPLIN : CLE3=[F:POQ]POQSEQ : STOP=1 : Break
    Endif
  Next
Commit
If STOP  Goto BOUCLE_POQ : Endif
#----- Fin du traitement -----#
$FIN_UTIACH11
WMSG ="UTIACH11 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TRACE(WMSG,0) From GESECRAN
Close Local File [POQ]
End

$MAJ_POQ
Readlock [POQ] Curr
If fstat
  Call ECR_TRACE("File PORDERQ"-[F:POQ]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
Else
  WMSG="DL"-[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)-"("+num$([F:POQ]QTYUOM)-[F:POQ]UOM
  [F:POQ]UOM   =[F:POQ]PUU 
  [F:POQ]QTYUOM=[F:POQ]QTYPUU
  If [F:POQ]UOMPUUCOE<>1
    WMSG2=", Coef.: "+num$([F:POQ]UOMPUUCOE)+" --> 1"
    [F:POQ]UOMPUUCOE=1
  Else
    Raz WMSG2
  Endif
  Rewrite [POQ]
  If fstat
    Call ECR_TRACE("Erreur réécriture"-[F:POQ]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
  Else
    WMSG-="-->"-num$([F:POQ]QTYUOM)-[F:POQ]UOM+WMSG2+")"
    Call ECR_TRACE(WMSG,0) From GESECRAN
    NBCOR+=1
  Endif
Endif
Return
