#<AdxTL>@(#)3.0.0.0 $Revision$
#
#***********************************************************************************
#
#        SAISIE FENETRE SUR CONTRAT DE LOCATION-FINANCEMENT (LEA)
#
#      LEAACT0  :  Entête  Actualisation du contrat (OAC0)
#      LEAACT   :  ACTUALISATION du contrat (LEAC)
#      CMPACT   :  Maj des biens rattachés  (OCP)
#
#***********************************************************************************
#    Création
#    MDR - V5
#
#**************************************************************************************
#    Modification
# MWA   10.10.2018 X3-84302     Manage the open schedule when changing the end date of the contract
# Issue X3-110500 - 2018-09-27 by CBO : event lea
# MDJ   10.17.2017 X3-39795     Manage ORIGIN and ORICOD fields in GL Entry
# MDJ   12.22.2009 (FQ 61084): Contrat location-financement sans plan IAS
#
#**************************************************************************************
#
ACTION

  #Infbox "TRTLEAACT/"-ACTION
  Case ACTION
    When "DEBUT"                : Gosub DEBUT
    When "APRES_MODIF"          : Gosub APRES_MODIF
    When "AVANT_MODFIC"         : Gosub AVANT_MODFIC
    When "OK"                   : Gosub OK
    When "ABA"                  : Gosub ABA
    When "FIN"                  : Gosub FIN
    When Default
  Endcase

Return
#
#---------------------------------#
# OUVRE                           #
#---------------------------------#
#
$OUVRE

 # Récupération des informations des biens liés au contrat

 If !(clalev([F:FAS])) : Local File FXDASSETS [FAS] : Endif
 Filter [FAS] Where LEAREF=[M:LEA0]LEAREF
 Raz nolign
 For [FAS]
   nolign+=1
   [M:OCP]OBJREF(nolign-1)  = [F:FAS]AASREF
   [M:OCP]OBJDES(nolign-1)  = [F:FAS]AASDES1
   [M:OCP]OBJCPY(nolign-1)  = [F:FAS]CPY
   [M:OCP]OBJTYP(nolign-1)  = PARAM(2)
  Next
  Filter [FAS]

  [M:OCP]NBOBJ=nolign

  Gosub ACTION From TRTOBJACT

  # Si erreur, on sort immediatement de l'action. On détruit donc les masques de l'action.
  If FIN=1
    If clalev([M:OCP])   : Close Mask [OCP]  : Endif
    If clalev([M:LEAC])  : Close Mask [LEAC]  : Endif
    # X3-84302
    # Else
    #  Gosub ACTION From TRTOBJACT
  Endif

Return
#
#====================================================
#
$DEBUT
  Global Integer NUMACT

  Raz  [M:LEAC]
  # Récupération des informations du contrat
  If [M:LEA1]CUTDAT > [0/0/0]
    [M:LEAC]CUTDAT=[M:LEA1]CUTDAT
  Else
    [M:LEAC]CUTDAT  = date$
  Endif

  [M:LEAC]ENDLEADAT      = [M:LEA1]ENDLEADAT
  # Valeur achat actualisée
  [M:LEAC]RPUVAL         = [M:LEA1]RPUVAL
  [M:LEAC]RPUVALDEV      = [M:LEA1]RPUVALDEV
  [M:LEAC]RPUDAT         = [M:LEA1]RPUDAT
  [M:LEAC]LEAAMTOLD      = [M:LEA1]LEAAMT
  # Capital actualisé
  [M:LEAC]LEAAMTNEW      = [M:LEA1]LEAAMT
  [M:LEAC]LEAAMTNEWS     = [M:LEA1]LEAAMTDEV
  # cours actuel
  [M:LEAC]LEACUR         = [M:LEA1]LEACUR
  [M:LEAC]CUR            = [M:LEA1]CUR
  [M:LEAC]RATCUR         = [M:LEA1]RATCUR
  [M:LEAC]CURTYP         = [M:LEA1]CURTYP
  # cours historique
  [M:LEAC]RATCUR2        = [F:LEA]RATCUR
  [M:LEAC]RATCUR3        = [F:LEA]RATCUR
  [M:LEAC]ACCCOD         = [F:LEA]ACCCOD

  If GCNXPROIAS = G_OUI
    [M:LEAC]RPUVALIAS      = [M:LEA1]RPUVALIAS
    [M:LEAC]LEAAMTNEWI     = [M:LEA1]LEAAMTIAS
    [M:LEAC]IASCUR         = [M:LEA1]IASCUR
    [M:LEAC]IASRATCUR      = [M:LEA1]IASRATCUR
    [M:LEAC]IASCURTYP      = [M:LEA1]IASCURTYP
    [M:LEAC]IASRATCUR2     = [F:LEA]IASRATCUR
    [M:LEAC]IASRATCUR3     = [F:LEA]IASRATCUR
  Endif    #*Fq-61084

  Actzo [M:LEAC]
  Affzo [M:LEAC]

  Gosub APPLIQUER_FORMAT

  #=> Détermination / alimentation du numéro de traitement
  NUMACT+=1

  #==> Appel du traitement d'init commun à toutes les actions
  Gosub ACTION From TRTOBJACT
  Setmok [M:LEAC] With 0
Return
#
#====================================================
#
$APRES_MODIF

  REP="M"

Return
#-------------------------------------------------------------------------------
$AVANT_MODFIC
Global Integer  N_I
Local  Char     LCDINT (30)
Local  Date     WDATEFF
Local  Date     WDATCPTINT
Local  Integer  LCDRET, I
Local  Integer  L_RET
Local  Date     L_CNXDAT(1..5)
Local  Char     LPIECE

  GREASON = mess(92,7771,1)
  WDATEFF=[M:LEAC]CUTDAT
  # Génération d'un évènement de type "LEAACTU" plan Comptable
  LCDINT = "LEAACTU"+num$(G301CPT)
  LPIECE = "LCACT"
  WDATCPTINT=max([M:LEAC]CUTDAT,  [M:LEA0]PERENDCPT)
  Call GENER_EVE (GVML_OMLOCFI,[M:LEA0]CPY,[M:LEA0]FCY,[M:LEA0]LEAREF,0,LCDINT ,WDATEFF,WDATCPTINT,LCDRET) From GENEVE
  If (LCDRET > 20 )
    GOK = 0
    Call FSTA("ELEAACTU") From GLOCK : Return
  Endif

  # Issue X3-83749 X3-84302
  #If GCNXPROIAS = G_OUI & ([M:LEA0]LEATYP = GVML_CREBAIL or [M:LEA0]LEATYP = GVML_LOCATION )
  If GCNXPROIAS = G_OUI
    # Génération d'un évènement de type "LEAACTU" plan IAS
    LCDINT = "LEAACTU"+num$(G301IAS)
    LPIECE = "0LACT"   #*42571
    WDATCPTINT=max([M:LEAC]CUTDAT, [M:LEA0]PERENDIAS)
    Call GENER_EVE (GVML_OMLOCFI,[M:LEA0]CPY,[M:LEA0]FCY,[M:LEA0]LEAREF,0,LCDINT ,WDATEFF,WDATCPTINT,LCDRET) From GENEVE
    If (LCDRET > 20 )
      GOK = 0
      Call FSTA("ELEAACTU") From GLOCK : Return
    Endif
  Endif
Return
#==========================================================
# Comptabilisation actualisation du contrat

$CPTLEA
  If !clalev([F:E41]) : Local File ELEAACTU[E41] : Endif
  Local Char    IDENT(20)(7)
  Local Integer STAT
  Local Char    MESSA(255)

  Local Char     TZONE(10)(1..10) : # Table des zones à forcer (Ex: type de pièce)
  Local Char     TVAL (30)(1..10) : # Table des valeurs des zones à forcer
  IDENT(0) = [M:LEA0]CPY
  IDENT(1) = "LEAACTU"
  IDENT(2) = num$(G301AUC)
  IDENT(3) = [M:LEA0]FCY
  IDENT(4) = [M:LEA0]LEAREF
  IDENT(5) = func GENEVE.BUILD_TIMSTP(date$, time)
  IDENT(6) = GUSER

  TZONE(1)= "REFINT"    : TVAL(1)= "D-"+num$(NUMACT)
  TZONE(2)= "ORIGIN"    : TVAL(2)= "2"        :#Automatic loading  #*X3-39795
  TZONE(3)= "ORICOD"    : TVAL(3)= LPIECE                          #*X3-39795
  Call VALPCE3(LPIECE,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO

  If STAT
    Infbox num$(STAT)-MESSA
  Else
    Update [ELA] Where CPY    = IDENT(0) and EVT    = IDENT(1) and PLN = G301AUC and FCY = IDENT(3) and REF = IDENT(4) and
&                      TIMSTP = IDENT(5) and CREUSR = IDENT(6)
&                With CPTFLG = G_OUI, UPDUSR = GUSER, UPDDAT = date$
    If fstat
      GOK=0 : Return
    Else
      #Infbox "enregistrements modifiés"-num$(adxuprec)
    Endif
 Endif

Return
#====================================================
#
$OK

#Vérification qu'il y a bien eu des modifications

  If ( [M:LEAC]ACCCOD    = [M:LEA1]ACCCOD    and
&      [M:LEAC]ENDLEADAT = [M:LEA1]ENDLEADAT and
&      [M:LEAC]LEAAMTNEW = [M:LEA1]LEAAMT    and
&      [M:LEAC]RPUVAL    = [M:LEA1]RPUVAL    and
&      [M:LEAC]RPUDAT    = [M:LEA1]RPUDAT ) Then

    G_ACT_MOD=0

  Else
    [M:LEA1]CUTDAT      =    [M:LEAC]CUTDAT     :  Affzo   [M:LEA1]CUTDAT
    [M:LEA1]ACCCOD      =    [M:LEAC]ACCCOD     :  Affzo   [M:LEA1]ACCCOD
    [M:LEA1]ENDLEADATO  =    [M:LEA1]ENDLEADAT
    [M:LEA1]ENDLEADAT   =    [M:LEAC]ENDLEADAT  :  Affzo   [M:LEA1]ENDLEADAT
    [M:LEA1]LEAAMT      =    [M:LEAC]LEAAMTNEW  :  Affzo   [M:LEA1]LEAAMT
    [M:LEA1]RPUVAL      =    [M:LEAC]RPUVAL     :  Affzo   [M:LEA1]RPUVAL
    [M:LEA1]RPUVALDEV   =    [M:LEAC]RPUVALDEV  :  Affzo   [M:LEA1]RPUVALDEV
    If GCNXPROIAS = G_OUI :  [M:LEA1]RPUVALIAS   =    [M:LEAC]RPUVALIAS  :  Affzo   [M:LEA1]RPUVALIAS : Endif
    [M:LEA1]RPUDAT      =    [M:LEAC]RPUDAT     :  Affzo   [M:LEA1]RPUDAT
    [M:LEA1]LEAAMTDEV   =    [M:LEAC]LEAAMTNEWS :  Affzo   [M:LEA1]LEAAMTDEV
    If GCNXPROIAS = G_OUI :  [M:LEA1]LEAAMTIAS   =    [M:LEAC]LEAAMTNEWI :  Affzo   [M:LEA1]LEAAMTIAS : Endif
    G_ACT_MOD=1
  Endif

  mkstat = 4
  FIN=1

  Affzo   [M:LEAC]

  # Issue X3-56289
  Diszo [M:LEA0]
  Diszo [M:LEA1]
  # Issue X3-84302
  #Diszo [M:LEA2]
  Diszo [M:LEA3]
  Diszo [M:LEA4]
  Diszo [M:LEA5]
  Diszo [M:LEA9]
  # X3-84302
  Actzo [M:LEA0]EVTLIST

  If G_ACT_MOD and !( [M:OCP]NBOBJ = 0 )  # S'il y a des modifs à reporter et si il y a des objets liés
    Global Char G_ACT_NAM                 # On crée la variable G_ACT_NAM
    G_ACT_NAM = "LEAACT"                  # On l'alimente avec le nom de l'action en cours
  Endif

  # X3-110500
  If ([M:LEA2]NBPER2 <> 0) Then
    # Issue X3-84302 start
    If ([M:LEA1]ENDLEADAT < [M:LEA1]ENDLEADATO) Then
      # Suppression de lignes
      Local Integer I_LIG
      I_LIG = 0
      While I_LIG <= [M:LEA2]NBPER2-1
        If  [M:LEA2]STRPERDAT(I_LIG) >= [M:LEA1]ENDLEADAT
          [M:LEA2]CUMRNTAMT -= [M:LEA2]RNTAMT(I_LIG) : # Issue X3-84300
          Dela I_LIG, 1, [M:LEA2]NBPER2-1 [M:LEA2]NBPER2
          [M:LEA2]NBPER2-= 1
        Else
          I_LIG += 1
        Endif
      Wend
      [M:LEA2]NBPER2 = I_LIG
      [M:LEA2]ENDPERDAT([M:LEA2]NBPER2-1) = [M:LEA1]ENDLEADAT

      Call EVALUE_SUMPAY_ARRAY([M:LEA0]LEATYP) From SUBLEA
      Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0) From SUBLEA
      Affzo [M:LEA2]


    Elsif ([M:LEA1]ENDLEADAT > [M:LEA1]ENDLEADATO) Then
      # Ajout des lignes
      nolign = [M:LEA2]NBPER2

      While [M:LEA1]ENDLEADAT > [M:LEA2]ENDPERDAT(nolign-1)
        If [M:LEA2]STRPERDAT(nolign-1) <> [0/0/0] & [M:LEA2]ENDPERDAT(nolign-1) <> [0/0/0]
          Call PER_CALCUL_POIDS () From SUBLEA
          Call CALCUL_DATES_ECHEANCE ([M]STRPERDAT(nolign-1),[M]ENDPERDAT(nolign-1),[M]NBRMONPER(nolign-1)) From SUBLEA
        Endif
      Wend

      [M:LEA2]NBPER2 = nolign
      [M:LEA2]ENDPERDAT([M:LEA2]NBPER2-1) = [M:LEA1]ENDLEADAT

      Call EVALUE_SUMPAY_ARRAY([M:LEA0]LEATYP) From SUBLEA
      Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0) From SUBLEA
      Affzo [M:LEA2]
    Endif
    # End issue X3-84302
  Endif

  Gosub ACTION From TRTOBJACT

Return
#
#====================================================
#
$ABA
  Gosub DEBUT # Clic sur abandon, on recharge toutes les valeurs d'origine
Return
#
#====================================================
#
$FIN
  # On détruit les globales (à l'action) de gestion des habilitations en sortant
  Gosub ACTION From TRTOBJACT
Return
#
#
#==============================================================#
# Traitement de mise à jour et de génération d'événement       #
# des biens liés lors d'un transfert                           #
#==============================================================#
$ACTMET
  Case ACTMET
    When "CRITMEN"      : Gosub CRITMEN       # Critère d'activation du menu.
    When "FILL_HEA"     : Gosub FILL_HEA      # Alimentation zone spé à l'action de l'en-tête [OAC0]
    When "MAJ_LNK"      : Gosub MAJ_LNK       # Mise à jour et alimentation des objets liés
    When "INIT_OBJ_DIV" : Gosub INIT_OBJ_DIV  # Ouvertures tables à mettre à jour dans MAJ_LNK
    When Default
  Endcase
Return

$CRITMEN
 # Permet d'alimenter la variable CRITMEN, condition d'activation du menu
 CRITMEN='REP="" & [M:LEA0]LEASTA = GVML_STENCOU'
Return

$FILL_HEA
 # Permet d'alimenter d'autre élément de l'en-tête
Return

$INIT_OBJ_DIV
Return

$MAJ_LNK
Return

$EVT_LNK
Return

#====================================================
Subprog AM_LEAAMTVAR(VALEUR)
Variable Decimal VALEUR

  If VALEUR <> [M:LEAC]LEAAMTVAR
    [M:LEAC]LEAAMTNEW    = [M:LEA1]LEAAMT + VALEUR
    [M:LEAC]LEAAMTVAR    = VALEUR
    [M:LEAC]LEAAMTNEWS     = [M:LEA1]LEAAMTDEV
    If GCNXPROIAS = G_OUI :[M:LEAC]LEAAMTNEWI     = [M:LEA1]LEAAMTIAS : Endif
    If VALEUR = 0
      [M:LEAC]LEAAMTVARS   = 0
      If GCNXPROIAS = G_OUI : [M:LEAC]LEAAMTVARI   = 0 : Endif
      [M:LEAC]LEAAMTNEW      = [M:LEA1]LEAAMT
    Else
      Gosub CALCUL_MTDES_AMTVAR
      [M:LEAC]LEAAMTNEWS   = [M:LEAC]LEAAMTNEWS + [M:LEAC]LEAAMTVARS
      If GCNXPROIAS = G_OUI : [M:LEAC]LEAAMTNEWI   = [M:LEAC]LEAAMTNEWI + [M:LEAC]LEAAMTVARI : Endif
    Endif
  Endif

  Affzo [M:LEAC]LEAAMTNEW
  Affzo [M:LEAC]LEAAMTNEWS
End

#====================================================
Subprog AM_CUTDAT(VALEUR)
Variable Date    VALEUR
Local Integer OK

# La date d'actualisation  doit être >= à la date d'actualisation précédente
#
  If VALEUR < [F:LEA]CUTDAT
    GERR= 1
    GMESSAGE= mess(53, 7771, 1)
    mkstat = 2
    End
  Endif

# La date d'actualisation  doit être >= à la date de début du contrat
#
  If VALEUR < [M:LEA1]STRLEADAT
    GERR= 1
    GMESSAGE= mess(52, 7771, 1)
    mkstat = 2
    End
  Endif

# Si date < date du jour : demande confirmation
#
  If VALEUR < date$
    Call OUINON (mess(54,7771,1), OK) From GESECRAN
    If OK = 1 : mkstat=2 : Endif
  Endif
End

#====================================================
Subprog AM_ENDLEADAT(VALEUR)
Variable Date    VALEUR

  #
  # La date de fin doit être > à la date de début
  #
  If ( VALEUR <= [M:LEA1]STRLEADAT ) Then
    GERR = 1
    GMESSAGE= mess(33, 7771, 1)
    mkstat = 2
    End
  Endif

  # X3-110500 Si pas d'échéancier on sort
  If ([M:LEA2]NBPER2 = 0 ) Then : End : Endif

  # X3-84302
  If (VALEUR < [M:LEA1]ENDLEADAT) Then
    Local Integer I_LIG
    I_LIG = 1
    While VALEUR > [M:LEA2]ENDPERDAT(I_LIG-1) and I_LIG < [M:LEA2]NBPER2
      I_LIG += 1
    Wend
    If (I_LIG < [M:LEA2]NBPER2) Then
      For I_LIG = I_LIG To [M:LEA2]NBPER2
        If ([M:LEA2]FARFLG(I_LIG-1) = G_OUI     or [M:LEA2]FARFLGI(I_LIG-1) = G_OUI ) Then
        # X3-84302 (later)
        #If ([M:LEA2]FARFLG(I_LIG-1) = G_OUI     or [M:LEA2]FARFLGI(I_LIG-1) = G_OUI or
        #&   [M:LEA2]PAYDAT(I_LIG-1) <> [0/0/0]  or [M:LEA2]PAYREF(I_LIG-1) <> "") Then
          GERR = 1
          GMESSAGE = mess(124, 7771, 1)
          mkstat = 2
          End
        Endif
      Next
    Endif

    Local Integer L_REP
    Call OUINON (mess(62,GML_MSGGRT,1), L_REP) From GESECRAN
    If ( L_REP = G_NON ) Then
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif

  # X3-84302
  If (VALEUR > [M:LEA1]ENDLEADAT) Then
    Local Integer L_REP
    Call AVERTIR (mess(63,GML_MSGGRT,1), L_REP) From GESECRAN
    If ( L_REP = G_NON ) Then
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End
#====================================================
Subprog AM_RPUVAL(VALEUR)
Variable Decimal VALEUR

  [M:LEAC]RPUVAL = VALEUR
  Affzo [M:LEAC]RPUVAL
  Gosub CALCUL_MTDES_RPUVAL
End



#=============================================================================
#
$CALCUL_MTDES_AMTVAR
Local Decimal MTDES
Local Integer STAT

  # ------------- Conversion en devise société
  Call CONVERT3([M:LEAC]LEACUR, [M:LEAC]CUR, GCOUDEV, [M:LEAC]CURTYP, [M:LEA1]STRLEADAT,
&               [M:LEAC]LEAAMTVAR, MTDES, [M:LEAC]RATCUR, STAT) From CPTSUB
  If STAT = 0 Then
    Call GET_MNT_ARRONDI (MTDES, [M:LEAC]CUR, MTDES) From GLOBIENS
                         [M:LEAC]LEAAMTVARS = MTDES : Affzo [M:LEAC]LEAAMTVARS
  Else
    GMESSAGE = mess(18,7773,1)
    GERR=1
    mkstat = 2
    End
  Endif

  If ( GCNXPROIAS = G_OUI )
    # ------------- Conversion en devise IAS
    Call CONVERT3([M:LEAC]LEACUR, [M:LEAC]IASCUR, GCOUDEV, [M:LEAC]IASCURTYP, [M:LEA1]STRLEADAT,
&                 [M:LEAC]LEAAMTVAR, MTDES, [M:LEAC]IASRATCUR, STAT) From CPTSUB
    If STAT = 0
      Call GET_MNT_ARRONDI (MTDES, [M:LEAC]IASCUR, MTDES) From GLOBIENS
      [M:LEAC]LEAAMTVARI= MTDES : Affzo [M:LEAC]LEAAMTVARI
    Else
      GMESSAGE = mess(18,7773,1)
      GERR=1
      mkstat = 2
      End
    Endif
  Endif
Return

#=============================================================================
#
$CALCUL_MTDES_RPUVAL

Local Decimal MTDES
Local Integer STAT
  # ------------- Conversion en devise société
  Call CONVERT3([M:LEAC]LEACUR, [M:LEAC]CUR, GCOUDEV, [M:LEAC]CURTYP, [M:LEA1]STRLEADAT,
&               [M:LEAC]RPUVAL, MTDES, [M:LEAC]RATCUR, STAT) From CPTSUB
  If STAT = 0 Then
    Call GET_MNT_ARRONDI (MTDES, [M:LEAC]CUR, MTDES) From GLOBIENS
    [M:LEAC]RPUVALDEV = MTDES : Affzo [M:LEAC]RPUVALDEV

  Else
    GMESSAGE = mess(18,7773,1)
    GERR=1
    mkstat = 2
    End
  Endif

  If ( GCNXPROIAS = G_OUI )
    # ------------- Conversion en devise IAS
    Call CONVERT3([M:LEAC]LEACUR, [M:LEAC]IASCUR, GCOUDEV, [M:LEAC]IASCURTYP, [M:LEA1]STRLEADAT,
&                 [M:LEAC]RPUVAL, MTDES, [M:LEAC]IASRATCUR, STAT) From CPTSUB
    If STAT = 0
      Call GET_MNT_ARRONDI (MTDES, [M:LEAC]IASCUR, MTDES) From GLOBIENS
      [M:LEAC]RPUVALIAS= MTDES : Affzo RPUVALIAS
    Else
      GMESSAGE = mess(18,7773,1)
      GERR=1
      mkstat = 2
      End
    Endif
  Endif

Return

#=============================================================================
#
$APPLIQUER_FORMAT

#  If GCNXPROIAS = G_OUI
#     Chgfmt [M:LEAC]IASCUR       With "KP:3#"
#     Chgfmt [M:LEAC]ZIASCUR      With "KP:20#"
#     Chgfmt [M:LEAC]IASRATCUR    With "NP:11.2#"
#     Chgfmt [M:LEAC]ZIASRATCUR   With "KP:20#"
#     Chgfmt [M:LEAC]LEAAMTVARI   With "NZ3P:13.2#"
#     Chgfmt [M:LEAC]IASRATCUR2   With "NP:11.2#"
#     Chgfmt [M:LEAC]ZIASRATCUR2  With "KP:20#"
#     Chgfmt [M:LEAC]LEAAMTNEWI   With "NZ3P:13.2#"
#     Chgfmt [M:LEAC]IASRATCUR3   With "NP:11.2#"
#     Chgfmt [M:LEAC]ZIASRATCUR3  With "KP:20#"
#     Chgfmt [M:LEAC]RPUVALIAS    With "NZ3P:13.2#"
#  Else
#     Chgfmt [M:LEAC]IASCUR       With "-KX:3#"
#     Chgfmt [M:LEAC]ZIASCUR      With "-KX:20#"
#     Chgfmt [M:LEAC]IASRATCUR    With "-NX:11.2#"
#     Chgfmt [M:LEAC]ZIASRATCUR   With "-KX:20#"
#     Chgfmt [M:LEAC]LEAAMTVARI   With "-NZ3X:13.2#"
#     Chgfmt [M:LEAC]IASRATCUR2   With "-NX:11.2#"
#     Chgfmt [M:LEAC]ZIASRATCUR2  With "-KX:20#"
#     Chgfmt [M:LEAC]LEAAMTNEWI   With "-NZ3X:13.2#"
#     Chgfmt [M:LEAC]IASRATCUR3   With "-NX:11.2#"
#     Chgfmt [M:LEAC]ZIASRATCUR3  With "-KX:20#"
#     Chgfmt [M:LEAC]RPUVALIAS    With "-NZ3X:13.2#"
#  Endif

  # X3-84302
  If (GDEVFMTI = "") Then : GDEVFMTI = "13.2" : Endif
  Gosub EVALUE_RATCUR_FMT From SUBLEA : # => L_RATCURFMT

  If GCNXPROIAS = G_OUI
    Chgfmt [M:LEAC]IASCUR       With "KP:3#"
    Chgfmt [M:LEAC]IASRATCUR    With L_RATCURFMT
    Chgfmt [M:LEAC]LEAAMTVARI   With "Nz3:"+GDEVFMTI
    Chgfmt [M:LEAC]IASRATCUR2   With L_RATCURFMT
    Chgfmt [M:LEAC]LEAAMTNEWI   With "Nz3:"+GDEVFMTI
    Chgfmt [M:LEAC]IASRATCUR3   With L_RATCURFMT
    Chgfmt [M:LEAC]RPUVALIAS    With "Nz3:"+GDEVFMTI
  Else
    Chgfmt [M:LEAC]IASCUR       With "-KX:3#"
    Chgfmt [M:LEAC]IASRATCUR    With "-N:11F#"
    Chgfmt [M:LEAC]LEAAMTVARI   With "-NX:13.2#"
    Chgfmt [M:LEAC]IASRATCUR2   With "-N:11F#"
    Chgfmt [M:LEAC]LEAAMTNEWI   With "-NX:13.2#"
    Chgfmt [M:LEAC]IASRATCUR3   With "-N:11F#"
    Chgfmt [M:LEAC]RPUVALIAS    With "-NX:13.2#"
  Endif
Return

