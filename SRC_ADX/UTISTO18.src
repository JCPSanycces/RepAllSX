#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################
# UTISTO18   Resynchronisation du détail des derniers prix                   #
##############################################################################
# Issue 79710 - 2012-01-30 by CCC
##############################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Sync last price detail") From LECFIC
    Call MAJ_UTISTO18(DOSSIER) 
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTISTO18(DOSSIER)
Value Char DOSSIER

  Call ECR_TRACE("UTISTO18: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER+".ITMMVT"
  Local Mask =DOSSIER+".SAIDECPRI"
  Local Char CRIT(250), CRITSUP(250)
  Local Decimal LDIFPRI
  Local Integer STOP,LNB
  Local Char    LITM(GLONITM)
  Local Char LFCY(GLONFCY)
  If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
  If GRNDVAL=0 : GRNDVAL=10^-GDECPRI : Endif
  
  ####################################
  CRITSUP = ''
  ####################################
  
  $LOOP_ITV
  Raz LNB
  If STOP=1
      CRIT  = 'ITMREF="'+LITM+'" & STOFCY>"'+LFCY+'"'
      STOP=2
  Elsif STOP=2
      CRIT  = 'ITMREF>"'+LITM+'"'
      STOP=0
  Else
    CRIT="1=1"
  Endif
  
  If CRITSUP="" :
      CRITSUP="1=1"
  Else
      Call ECR_TRACE("CRITSUP = "+CRITSUP,0) From GESECRAN
  Endif
  
  Trbegin [ITV]
  For [ITV] Where evalue(CRIT) & evalue(CRITSUP)
      #Call ECR_TRACE("ITMREF="+[F:ITV]ITMREF-"STOFCY="+[F:ITV]STOFCY,0) From GESECRAN
      Raz [M:SDP]
      [M:SDP]PRI = [F:ITV]LASRCPPRI
      Call LOADSDP("[F:ITV]", "L", 1) From STKVAL
  
      Raz LDIFPRI
  
      Gosub REPARTIR
      [M:SDP]SCOTOT = [M:SDP]SCOCST
        
      Call SDP2FIL("[F:ITV]", "L", 1) From SUBSDPCOM  # Affecte uniquement le détail
      
      Call REWITV From STKLIB
      LNB+=1
      If LNB>GMAXUPDTRS
          LITM = [F:ITV]ITMREF
          LFCY = [F:ITV]STOFCY
          STOP=1
          Break
      Endif
  Next
  Commit
  If STOP
      Goto LOOP_ITV
  Endif
  Close Local File [ITV]
  Call ECR_TRACE("UTISTO18 : finish",0) From GESECRAN
End


$REPARTIR
Local Integer I
Local Decimal LREP, LDELTA, LVALMAX
Local Char    LZON1(GLONAVA+4) : Raz LZON1
Local Char    LZONMAX(GLONAVA+4) : Raz LZONMAX
Local Integer LBRDCOD : Raz LBRDCOD

# Si la somme des composantes n'est pas égale au prix total, on calcule la différence supplémentaire à appliquer
LSDPTOT = func SUBSDPCOM.SUMCST("SDP")
LDIFPRI += [M:SDP]PRI-LSDPTOT


    #------- MATIERE ---------#
    For I=0 To GACTMAT-1
        If [M:SDP]PRI=0
            LDELTA = -[M:SDP]MATCST(I)
            Raz [M:SDP]MATCST(I)
        Elsif [M:SDP]MATCST(I)<>0
            LDELTA = arr([M:SDP]MATCST(I)*LDIFPRI/LSDPTOT,10^-GDECPRI)
            [M:SDP]MATCST(I) += LDELTA
            If LZON1=""
                LZON1 = "MATCST("+num$(I)+")"
            Endif
        Endif
        If LZONMAX="" & [M:SDP]MATCST(I)>0 | LZONMAX<>"" & [M:SDP]MATCST(I)>LVALMAX
            LZONMAX="MATCST("+num$(I)+")"
            LVALMAX=[M:SDP]MATCST(I)
        Endif
        LREP += LDELTA
        Raz LDELTA
    Next
    If [M:SDP]PRI=0
        LDELTA = -[M:SDP]OVEMATCST
        Raz [M:SDP]OVEMATCST
    Elsif [M:SDP]OVEMATCST<>0
        LDELTA = arr([M:SDP]OVEMATCST*LDIFPRI/LSDPTOT,10^-GDECPRI)
        [M:SDP]OVEMATCST += LDELTA
        If LZON1=""
            LZON1 = "OVEMATCST"
        Endif
    Endif
    If LZONMAX="" & [M:SDP]OVEMATCST>0 | LZONMAX<>"" & [M:SDP]OVEMATCST>LVALMAX
        LZONMAX="OVEMATCST"
        LVALMAX=[M:SDP]OVEMATCST
    Endif
    LREP += LDELTA
    Raz LDELTA

    #------- MACHINE ---------#
    For I=0 To GACTMAC-1
        If [M:SDP]PRI=0
            LDELTA = -[M:SDP]MACCST(I)
            Raz [M:SDP]MACCST(I)
        Elsif [M:SDP]MACCST(I)<>0
            LDELTA = arr([M:SDP]MACCST(I)*LDIFPRI/LSDPTOT,10^-GDECPRI)
            [M:SDP]MACCST(I) += LDELTA
            If LZON1=""
                LZON1 = "MACCST("+num$(I)+")"
            Endif
        Endif
        LREP += LDELTA
        Raz LDELTA
        If LZONMAX="" & [M:SDP]MACCST(I)>0 | LZONMAX<>"" & [M:SDP]MACCST(I)>LVALMAX
            LZONMAX="MACCST("+num$(I)+")"
            LVALMAX=[M:SDP]MACCST(I)
        Endif
    Next
    If [M:SDP]PRI=0
        LDELTA = -[M:SDP]OVEMACCST
        Raz [M:SDP]OVEMACCST
    Elsif [M:SDP]OVEMACCST<>0
        LDELTA = arr([M:SDP]OVEMACCST*LDIFPRI/LSDPTOT,10^-GDECPRI)
        [M:SDP]OVEMACCST += LDELTA
        If LZON1=""
            LZON1 = "OVEMACCST"
        Endif
    Endif
    If LZONMAX="" & [M:SDP]OVEMACCST>0 | LZONMAX<>"" & [M:SDP]OVEMACCST>LVALMAX
        LZONMAX="OVEMACCST"
        LVALMAX=[M:SDP]OVEMACCST
    Endif
    LREP += LDELTA
    Raz LDELTA

    #------- MAIN D'OEUVRE ---------#
    For I=0 To GACTLAB-1
        If [M:SDP]PRI=0
            LDELTA = -[M:SDP]LABCST(I)
            Raz [M:SDP]LABCST(I)
        Elsif [M:SDP]LABCST(I)<>0
            LDELTA = arr([M:SDP]LABCST(I)*LDIFPRI/LSDPTOT,10^-GDECPRI)
            [M:SDP]LABCST(I) += LDELTA
            If LZON1=""
                LZON1 = "LABCST("+num$(I)+")"
            Endif
        Endif
        LREP += LDELTA
        Raz LDELTA
        If LZONMAX="" & [M:SDP]LABCST(I)>0 | LZONMAX<>"" & [M:SDP]LABCST(I)>LVALMAX
            LZONMAX="LABCST("+num$(I)+")"
            LVALMAX=[M:SDP]LABCST(I)
        Endif
    Next
    Raz LDELTA
    If [M:SDP]PRI=0
        LDELTA = -[M:SDP]OVELABCST
        Raz [M:SDP]OVELABCST
    Elsif [M:SDP]OVELABCST<>0
        LDELTA = arr([M:SDP]OVELABCST*LDIFPRI/LSDPTOT,10^-GDECPRI)
        [M:SDP]OVELABCST += LDELTA
        If LZON1=""
            LZON1 = "OVELABCST"
        Endif
    Endif
    If LZONMAX="" & [M:SDP]OVELABCST>0 | LZONMAX<>"" & [M:SDP]OVELABCST>LVALMAX
        LZONMAX="OVELABCST"
        LVALMAX=[M:SDP]OVELABCST
    Endif
    LREP += LDELTA
    Raz LDELTA


    #------- SOUS-TRAITANCE ---------#
    Raz LDELTA
    If [M:SDP]PRI=0
        LDELTA = -[M:SDP]SCOCST
        Raz [M:SDP]SCOCST
    Elsif [M:SDP]SCOCST<>0
        LDELTA = arr([M:SDP]SCOCST*LDIFPRI/LSDPTOT,10^-GDECPRI)
        [M:SDP]SCOCST += LDELTA
        If LZON1=""
            LZON1 = "SCOCST"
        Endif
    Endif
    If LZONMAX="" & [M:SDP]SCOCST>0 | LZONMAX<>"" & [M:SDP]SCOCST>LVALMAX
        LZONMAX="SCOCST"
        LVALMAX=[M:SDP]SCOCST
    Endif
    LREP += LDELTA

    Raz LDELTA
    If [M:SDP]PRI=0
        LDELTA = -[M:SDP]OVESCOCST
        Raz [M:SDP]OVESCOCST
    Elsif [M:SDP]OVESCOCST<>0
        LDELTA = arr([M:SDP]OVESCOCST*LDIFPRI/LSDPTOT,10^-GDECPRI)
        [M:SDP]OVESCOCST += LDELTA
        If LZON1=""
            LZON1 = "OVESCOCST"
        Endif
    Endif
    If LZONMAX="" & [M:SDP]OVESCOCST>0 | LZONMAX<>"" & [M:SDP]OVESCOCST>LVALMAX
        LZONMAX="OVESCOCST"
        LVALMAX=[M:SDP]OVESCOCST
    Endif
    LREP += LDELTA

    #---------- Eléments de facturation -------------#
    Raz LDELTA
    If [M:SDP]PRI=0
        LDELTA = -[M:SDP]INVDTACST
        Raz [M:SDP]INVDTACST
    Elsif [M:SDP]INVDTACST<>0
        LDELTA = arr([M:SDP]INVDTACST*LDIFPRI/LSDPTOT,10^-GDECPRI)
        [M:SDP]INVDTACST += LDELTA
        If LZON1=""
            LZON1 = "INVDTACST"
        Endif
    Endif
    If LZONMAX="" & [M:SDP]INVDTACST>0 | LZONMAX<>"" & [M:SDP]INVDTACST>LVALMAX
        LZONMAX="INVDTACST"
        LVALMAX=[M:SDP]INVDTACST
    Endif
    LREP += LDELTA


    Effzo [M:SDP]30
    If [M:SDP]OVEMATCST+[M:SDP]OVEMACCST+[M:SDP]OVELABCST+[M:SDP]OVESCOCST<>0
        [M:SDP]OVENAT(0) = "ZZZ"
        [M:SDP]ONATYP(0) = 2
        [M:SDP]ONAAMT(0) = [M:SDP]OVEMATCST+[M:SDP]OVEMACCST+[M:SDP]OVELABCST+[M:SDP]OVESCOCST
        [M:SDP]NBONA = 1
    Endif

If LREP=0
    If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
    If [F:ITM]ITMREF<>[M:SDP]ITMREF
        Read [ITM]ITM0 = [M:SDP]ITMREF
    Endif
    LBRDCOD = [F:ITM]BRDCOD
    [M:SDP]MATCST(max(0,LBRDCOD-1)) += LDIFPRI
Elsif LZONMAX<>"" & LREP<>LDIFPRI
    Assign "[M:SDP]"+LZONMAX With evalue("[M:SDP]"+LZONMAX)+(LDIFPRI-LREP)
Endif

Return
