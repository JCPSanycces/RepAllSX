#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation script: NCSCAUSPLA_RSTD, Planners
###############################################################################
# Issue 110210/8 - 2015-12-14 by JUSYN : New labels for supervisor update
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AQUERY_CRITERIA_AFTER" : Gosub AQUERY_CRITERIA_AFTER
        When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return
###############################################################################

# --------------------------------------------------
# Add filter to Users [AUS] to return Planners.
$AQUERY_CRITERIA_AFTER
  Local Integer PLANNER_COUNT
  Local Char NCSPLANNER(30)
  Local Char PLANNER(10)(1..)
  Local Integer I

  If (clalev([AUS]) = 0) : Local File AUTILIS [AUS] : Endif

  # Build array (PLANNER) of Planner users ...
  PLANNER_COUNT = 0
  For [AUS] Where ENAFLG = 2
    Call PARAMUTIL("NCSPLANNER", NCSPLANNER, [F:AUS]USR, "") From SUBAUS
    If (NCSPLANNER = "2")
      PLANNER_COUNT += 1
      PLANNER(PLANNER_COUNT) = [F:AUS]USR
    Endif
  Next


  # Build 'where clause' (PQRY.QWHERE) from array (above) ...
  If (PLANNER_COUNT = 0)
    If (PQRY.QWHERE <> "")
      PQRY.QWHERE = "(" +PQRY.QWHERE +") and 1 eq 0"
    Else
      PQRY.QWHERE = "1 eq 0"
    Endif
  Else
    For I = 1 To PLANNER_COUNT
      If (I = 1)
        If (PQRY.QWHERE <> "")
          PQRY.QWHERE = "(" +PQRY.QWHERE +") and USR in ('" +PLANNER(1) +"'"
        Else
          PQRY.QWHERE = "USR in ('" +PLANNER(1) +"'"
        Endif
      Else
        PQRY.QWHERE = PQRY.QWHERE +", '"+PLANNER(I)+"'"
      Endif
    Next I
    PQRY.QWHERE = PQRY.QWHERE +")"
  Endif

Return

# --------------------------------------------------
# Populate role and department.
$AQUERY_TRANS_AFTER

  Local Char ROLE(30), DEPT(30)

  Call PARAMUTIL("CCMROLE", ROLE, this.AUS.USR, "") From SUBAUS
  Call PARAMUTIL("CCMDEPT", DEPT, this.AUS.USR, "") From SUBAUS
  If (ROLE <> "" & ROLE <> "1")
    this.ROLE = mess(val(ROLE), 2036, 1)
  Else
    this.ROLE = ""
  Endif
  If (DEPT <> "" & DEPT <> "1")
    this.DEPARTMENT = mess(val(DEPT), 2037, 1)
  Else
    this.DEPARTMENT = ""
  Endif

Return

