#<AdxTL>@(#)12.0.0.0 $Revision$
######################################################################################################
#   Gestion du paramétrage d'un champs Tiers divers                 Module CRM         20 juillet 2000
######################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "STATUT"       : Gosub STATUT
 When Default
Endcase
Return


$OUVRE
# PARAM(1) : Code du champs à paramétrer
# PARAM(2) : Type de paramétrage à réaliser
Global Char GSZTTRFLD
Local Char SZTTRFLD
Local Integer OUTFLG
GSZTTRFLD = ""
SZTTRFLD = ""
OUTFLG = 0

Case val(PARAM(2))
    When 1
        SZTTRFLD = GSZTTRBLC(val(left$(PARAM(1), 1)) - 2)
        GSZTTRFLD = mess(232, 196, 2)  # Titre du bloc
    When 2
        GSZTTRFLD = mess(233, 196, 2)  #Titre du champs
        Case val(left$(PARAM(1), 1))
            When 3
                SZTTRFLD = GSZDAT(val(mid$(PARAM(1), 2, 1)))
            When 4
                SZTTRFLD = GSZINT(val(mid$(PARAM(1), 2, 1)))
            When 5
                SZTTRFLD = GSZDCB(val(mid$(PARAM(1), 2, 1)))
            When Default
        Endcase
        If SZTTRFLD <> "" : Gosub ASKCONTINUE : Endif
    When 3
    When Default
Endcase

Return

$DEFBOUT
Return

$SETBOUT
Return

$OUVRE_BOITE
Return

$DEBUT
[M:CUS1]TTRFLD = SZTTRFLD
Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$FINSAI
Return

$FIN
If !OUTFLG
Case val(PARAM(2))
    When 1
        GSZTTRBLC(val(left$(PARAM(1), 1)) - 2) = [M:CUS1]TTRFLD
    When 2
        Case val(left$(PARAM(1), 1))
            When 3
                GSZDAT(val(mid$(PARAM(1), 2, 1))) = [M:CUS1]TTRFLD
            When 4
                GSZINT(val(mid$(PARAM(1), 2, 1))) = [M:CUS1]TTRFLD
            When 5
                GSZDCB(val(mid$(PARAM(1), 2, 1))) = [M:CUS1]TTRFLD
            When Default
        Endcase
    When 3
    When Default
Endcase

#Nettoie l'écran avant de partir.
Raz [M:CUS1]
Endif
Return

$ABANDON
Return

$APRES_MODIF
Return

$BOUTON
Return

$STATUT
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################################################
# Gestion d'un champs déjà paramétré.
$ASKCONTINUE
Local Integer IRESULT
Local Integer ICOUNT2
ICOUNT2 = 0
IRESULT = 0
#Ce champs est déjà utilisé en tant que TITRE DU CHAMPS. Voulez-vous supprimer son contenu ?
Call OUINON(mess(236, 196, 2) + SZTTRFLD + mess(237, 196, 2), IRESULT) From GESECRAN
If IRESULT = 2
    Call DEBTRANS From GLOCK
    #Supprime les données
    For [BPM]
        Case val(left$(PARAM(1), 1))
            When 3
                [F:BPM]DATX(val(mid$(PARAM(1), 2, 1))) = [00/00/00]
            When 4
                [F:BPM]INTX(val(mid$(PARAM(1), 2, 1))) = 0
            When 5
                [F:BPM]DCBX(val(mid$(PARAM(1), 2, 1))) = 0
            When Default
        Endcase
        Trbegin [BPM]
        Rewrite [BPM]    
        If fstat
            Rollback
        Else
            Commit
        Endif
    Next
    #Supprime les données de configuration
    If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
    Read [ADS] DOSSIER = nomap
    If fstat : Return : Endif
    For ICOUNT2 = 0 To dim([F:ADS]LAN) - 1
        Read [BPG] BPG0 = "DOO";[F:ADS]LAN(ICOUNT2)
        If !fstat
            Case val(left$(PARAM(1), 1))
                When 3
                    [F:BPG]TTRDAT(val(mid$(PARAM(1), 2, 1))) = ""
                    If GSZDAT <> "" : GSZDAT(val(mid$(PARAM(1), 2, 1))) = "" : Endif
                When 4
                    [F:BPG]TTRINT(val(mid$(PARAM(1), 2, 1))) = ""
                    If GSZINT <> "" : GSZINT(val(mid$(PARAM(1), 2, 1))) = "" : Endif
                When 5
                    [F:BPG]TTRDCB(val(mid$(PARAM(1), 2, 1))) = ""
                    If GSZDCB <> "" : GSZDCB(val(mid$(PARAM(1), 2, 1))) = "" : Endif
                When Default
            Endcase
            Trbegin [BPG]
            Rewrite [BPG]    
            If fstat
                Rollback
            Else
                Commit
            Endif
        Endif
    Next
    SZTTRFLD = ""
Elsif IRESULT = 1
    FIN = 1
    OUTFLG = 1
Endif
Return
