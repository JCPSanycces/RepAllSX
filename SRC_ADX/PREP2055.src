#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################################
# Programme : PREP2055                                                                  #
#                                                                                       #
# Fonction  :                                                                           #
#      1- Maj de la table TMP2055  pour l'état FAS2055                                  #
# Création     : 01/06/2011                                                             #
# Modifications
# Issue X3-68907 - 2018-01-12 by MDJ : mess=60,7784 replaced by mess=106,7784 (NEW)
# MDJ   03.02.2016 114175    Cas des biens sortis dans l'année avec reprise de dérogatoire
# MDJ   11.05.2015 FQ107751  Prise en compte des biens de type Avoir
# MDJ   14.01.2014 FQ94754   FCY2055 col 6 (Amort fiscal exceptionnel) diff. FAS2055
# MDJ   27.11.2013 FQ92637   Etat sur périodes cumulées
# MDJ   10.10.2011 FQ76985   Ajout critère référentiel/plan de compte (COA)
#########################################################################################
$ACTION
    Case ACTION
        When "OUVRE" :   Gosub OUVRE
        When "FIN"   :   Gosub FIN
    Endcase
Return
######################################################################################
$OUVRE

If clalev([F:FAS])=0    :    Local File FXDASSETS       [FAS]    : Endif
If clalev([F:T55])=0    :    Local File TMP2055         [T55]    : Endif
If clalev([F:T55M])=0   :    Local File TMP2055         [T55M]   : Endif
If clalev([F:T55C])=0   :    Local File TMP2055         [T55C]   : Endif #*FQ92637
If clalev([F:CNX])=0    :    Local File CONTEXT         [CNX]    : Endif
If clalev([F:FIY])=0    :    Local File FISCYEAR        [FIY]    : Endif
If clalev([F:FIS])=0    :    Local File FISCYEAR        [FIS]    : Endif #*FQ92637


SYMBOLE = "PREP2055"
Lock SYMBOLE With lockwait = 3
If fstat
   Return
Endif

 If dim(G_CRITERE)<0  : Global Char    G_CRITERE  (250)  : Endif  # Critère de sélection : Endif
 If dim(G_CRITERE2)<0 : Global Char    G_CRITERE2 (250)  : Endif  # Critère de sélection : Endif
 #*FQ92637

Return
######################################################################################
$FIN

Unlock=SYMBOLE

Return
#=============================================================================
# traitement PREP2055 : alimentation de la table TMP2055
#=============================================================================
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Char       PARAM(30)
Local Char       VALEUR(30)

Gosub OUVRE
Gosub MAJ_TMP2055
End
###################################################
$MAJ_TMP2055
#------------------------------------------#
#--- Création table temporaire TMP2055  ---#
#------------------------------------------#
  Local Integer I                # Compteur de paramètres
  Local Char    LCPY (5)         # Société
  Local Integer LPLAN            # Plan
  Local Integer LLED             # Référentiel #Fq-76985
  Local Char    LTYPFLUX         # Type de flux
  Local Char    LCODFLUX         # Code flux
  Local Char    LTYPLIASSE       # Exercice ou Périodique
  Local Integer LSITUAT          # Situation
  Local Date    LDATDEB          # Date deb
  Local Date    LDATFIN          #      fin
  Local Char    LREFDEB          # réf deb
  Local Char    LREFFIN          #     fin

  Local Date    LDATNULL         : LDATNULL = [01/01/1900]

  Local Integer LEDTNUM          # Identifiant session
  Local Char    LCRITERE  (250)   # Critère de sélection
  Local Char    LCRITERE2 (250)   # Critère de sélection

  Local Char    SCPY
  Local Char    WCOA (3)          # plan de compte  général de la société
  Local Integer RCNX              # contexte du plan passé en paramètre
  Local Date    RCNXDAT(1..5)     # date d'un contexte
  Local  Char   SAASREF           #*FQ92637

  Local Decimal SGNMNT            #*FQ107751 signe du montant de référence : 1=Facture, -1=Avoir

  Global Date   G_FLUSTRDAT       #*FQ92637
  Global Date   G_FLUENDDAT       #*FQ92637


  If clalev([T55])=0 : Local File TMP2055 [T55] : Endif
  Trbegin [T55]
  ##Fq-76985     Delete [T55] Where CREUSR = GUSER & CREDAT < date$
  Delete [T55] Where CREUSR = GUSER
  If fstat = 1
    Rollback
    #  "Problème à l'effacement du fichier temporaire"
       Call MESSAGE (mess(155,197,1)) From GESECRAN
    Return
  Else
     Commit
  Endif

   Call GETPARAM("societe",NBPAR,PARAMETRE,LCPY)
   Call GETPARAM("plan",NBPAR,PARAMETRE,PARAM)       : LPLAN    = val(PARAM)
   Call GETPARAM("referentiel",NBPAR,PARAMETRE,PARAM)  : LLED      = val(PARAM) #Fq-76985
   Call GETPARAM("typflux",NBPAR,PARAMETRE,LTYPFLUX)
   Call GETPARAM("codflux",NBPAR,PARAMETRE,LCODFLUX)
   Call GETPARAM("typliasse",NBPAR,PARAMETRE,PARAM)    : LSITUAT    = val(PARAM)
   Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM)       : LDATDEB  = PARAM :  G_FLUSTRDAT = LDATDEB #*FQ92637
   Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM)       : LDATFIN  = PARAM :  G_FLUENDDAT = LDATFIN #*FQ92637
   Call GETPARAM("refdeb",NBPAR,PARAMETRE,LREFDEB)
   Call GETPARAM("reffin",NBPAR,PARAMETRE,LREFFIN)
   Call GETPARAM("impselections",NBPAR,PARAMETRE,PARAM) :  LIMPSEL   = val(PARAM)
   Call GETPARAM("edtnum",NBPAR,PARAMETRE,PARAM)        :  LEDTNUM   = val(PARAM)

   LCRITERE  = "1=1"
   For I=1 To NBPAR
      J=instr(1,[L]PARAMETRE(I),"=")
      If J
         [L]PARAM  = left$([L]PARAMETRE(I),J-1)
         [L]VALEUR = right$([L]PARAMETRE(I),J+1)
         Case [L]PARAM
            When "societe"     :     LCRITERE   =  "CPY='"+LCPY+"'"
            When "codflux"     :     LCRITERE  += "& CODTXS='"+LCODFLUX+"'"
            When "plan"        :     LCRITERE  += "& DPRPLN="+num$(LPLAN)
            When "typflux"     :     LCRITERE  += "& TYP="+num$(LTYPFLUX)
            When "refdeb"      :     LCRITERE  += "& AASREF>='"+LREFDEB+"'"
            When "reffin"      :     LCRITERE  += "& AASREF<='"+LREFFIN+"'"
         Endcase
      Endif
   Next

   G_CRITERE = LCRITERE

   #*FQ92637 If LSITUAT = 1
   #*FQ92637    LCRITERE2 =     "FIYSTRDAT=["+format$(GFMD,LDATDEB)+"]"
   #*FQ92637     LCRITERE2 +=  "& FIYENDDAT=["+format$(GFMD,LDATFIN)+"]"
   #*FQ92637     LCRITERE2 +=  "& PERSTRDAT<=["+format$(GFMD,LDATNULL)+"]"
   #*FQ92637     LCRITERE2 +=  "& PERENDDAT<=["+format$(GFMD,LDATNULL)+"]"
   #*FQ92637   Else
   #*FQ92637    LCRITERE2 =     "PERSTRDAT=["+format$(GFMD,LDATDEB)+"]"
   #*FQ92637     LCRITERE2 +=  "& PERENDDAT=["+format$(GFMD,LDATFIN)+"]"
   #*FQ92637   Endif

   Case LSITUAT
   When 1
     LCRITERE2 =     "FIYSTRDAT=["+format$(GFMD,LDATDEB)+"]"
     LCRITERE2 +=  "& FIYENDDAT=["+format$(GFMD,LDATFIN)+"]"
     LCRITERE2 +=  "& PERSTRDAT<=["+format$(GFMD,LDATNULL)+"]"
     LCRITERE2 +=  "& PERENDDAT<=["+format$(GFMD,LDATNULL)+"]"
   When 2
     LCRITERE2 =     "PERSTRDAT=["+format$(GFMD,LDATDEB)+"]"
     LCRITERE2 +=  "& PERENDDAT=["+format$(GFMD,LDATFIN)+"]"
   When 3
     LCRITERE2 =     "PERSTRDAT>=["+format$(GFMD,LDATDEB)+"]"
     LCRITERE2 +=  "& PERSTRDAT<=["+format$(GFMD,LDATFIN)+"]"
     G_CRITERE2 = LCRITERE2
   Endcase

   If clalev([F:T55])=0    :    Local File TMP2055         [T55]    : Endif
   #--------------------------------
   Call DEBTRANS From GLOCK
   Trbegin [T55]
   Delete [T55] Where  (CREUSR =  GUSER)
   If fstat=1 | fstat>5
      GOK = 0
      Call RSTA("T55","") From GLOCK
      Rollback
      Return
   Endif
   Commit

   If !GOK : Return : Endif

   If clalev([F:PFL])=0    :    Local File PARFLUX          [PFL]    : Endif
   If clalev([F:PFD])=0    :    Local File PARFLUXDET       [PFD]    : Endif
   If clalev([F:FLU])=0    :    Local File FXDLIFL          [FLU]    : Endif
   If clalev([F:FLUD])=0   :    Local File FXDLIFL          [FLUD]   : Endif   #*FQ92637 Enreg. de travail flux pour périodes cumulées
   If clalev([F:WFLU])=0   :    Local File FXDLIFL          [WFLU]   : Endif   #*FQ92637 Enreg. de travail flux pour périodes cumulées
   If clalev([F:E28])=0    :    Local File EFASREEVAL       [E28]    : Endif   #*FQ92637 Enreg. de travail flux pour périodes cumulées
   If clalev([F:CPY])=0    :    Local File COMPANY          [CPY]    : Endif
   If clalev([F:CNX])=0    :    Local File CONTEXT          [CNX]    : Endif
   If clalev([F:FIY])=0    :    Local File FISCYEAR         [FIY]    : Endif
   If clalev([F:DEPF])= 0  :    Local File DEPREC           [DEPF]   : Endif : #*FQ92637 Plans d'amortissements pour les flux
   If clalev([F:DEPC])= 0  :    Local File DEPREC           [DEPC]   : Endif : #*FQ92637 Plans d'amortissements pour les flux

   # Lecture contexte du plan d'amortissement pour récupérer le plan de compte lié
   Call GET_CNX_FROM_PLAN (LCPY, LPLAN, RCNX) From GLOBIENS
   If RCNX <=0
      GOK=0 : Return
   Endif
   Read[CNX]CNX0= LCPY;RCNX
   Local Integer I_COA
   If fstat=0
      I_COA = find(LPLAN,[F:CNX]PLNCAA(0..[F:CNX]NBPLC-1))
      If I_COA > 0
         WCOA= [F:CNX]COA(I_COA-1)
      Endif
   Endif

  # #*FQ92637  Récupération des dates d'un contexte dans la variable dimensionnée RCNXDAT
  Local Integer RCRET
  Call GET_CNX_DAT(LCPY,RCNX,RCNXDAT,RCRET) From GLOBIENS

   #*FQ92637 Si Liasse sur périodes cumulées, date début et date fin appartiennent au même exercice
   Local Date RFIYENDDATD, RFIYENDDATF
   Local Date RPERENDDATD, RPERENDDATF
   Local Integer RCOD
   If LSITUAT = 3
      Call GET_FIY_PER(LDATDEB,LCPY,RCNX,RFIYENDDATD,RPERENDDATD,RCOD)  From GLOBIENS
      Call GET_FIY_PER(LDATFIN,LCPY,RCNX,RFIYENDDATF,RPERENDDATF,RCOD)  From GLOBIENS
      If  LDATDEB <> RCNXDAT(1)
         GOK=0
         #  "La date de début doit être égale à la date de début de l'exercice courant."
         Call MESSAGE (mess(62,GML_MSGMIS,1)) From GESECRAN
         Return
      Endif
      If  RFIYENDDATD <> RFIYENDDATF
         GOK=0
         #  "Les dates de début et de fin doivent appartenir au même exercice."
         Call MESSAGE (mess(59,GML_MSGMIS,1)) From GESECRAN
         Return
      Endif
   Endif #*FQ92637 END

   Call DEBTRANS From GLOCK
   Trbegin [T55], [T55M], [PFL], [PFD], [FLU]
   #*Fq-76985 Filter [PFL] Where (OUTFUNDS < 2 and CLATXS < 4 and CODTXS = LCODFLUX  )
   For [PFL] Where ( OUTFUNDS < 2 )  and ( CLATXS < 4 ) and ( CODTXS = LCODFLUX ) and ( COA=WCOA )
      Raz[T55]
      Raz[T55M]
      Raz[T55C] #*FQ92637
      #*Fq-76985  Filter [PFD] Where (CODTXS = [F:PFL]CODTXS and POSTXS = [F:PFL]POSTXS)
      For [PFD]  Where ( CODTXS = [F:PFL]CODTXS ) and ( POSTXS = [F:PFL]POSTXS ) and ( COA=WCOA)
         If LSITUAT <> 3
            #*FQ92637  ----- Situations Exercice ou période -----
            Filter [FLU] Where ( evalue(LCRITERE) & evalue (LCRITERE2)) and
&                              ( TXSCAT=num$([F:PFD]POSTXS) and GAC=[F:PFD]GAC and COA=WCOA) Order By TXSCAT Asc; GAC Asc
            For [FLU]
              GOK=1
              #*FQ107751 On regarde quel montant est significatif pour le signe du bien comptable
              If [F:FLU]BSEVALSTR < 0 or [F:FLU]DPRBASSTR < 0 or  [F:FLU]DPRCUMSTR < 0 or
&                [F:FLU]INCDPRFCY < 0 or [F:FLU]INCDPRTRF < 0
                SGNMNT = -1
              Else
                SGNMNT = 1
              Endif
              #1------------
              [F:T55M]TXSCAT     = [F:FLU]TXSCAT
              [F:T55M]FCY        = [F:FLU]FCY
              [F:T55M]TYP        = [F:FLU]TYP
              [F:T55M]FLGSTATXS  = [F:FLU]FLGSTATXS
              [F:T55M]CNX        = [F:FLU]CNX
              [F:T55M]GAC        = [F:FLU]GAC
              [F:T55M]CODTXS     = [F:FLU]CODTXS
              [F:T55M]PERSTRDAT  = [F:FLU]PERSTRDAT
              [F:T55M]PERENDDAT  = [F:FLU]PERENDDAT
              Gosub CHARGE_T55M
              #========================================================
            Next # [FLU]
            Filter[FLU]
         Else
           #*FQ92637  ----- Situation périodes cumulées -----
           SAASREF = ""
           Filter [FLU] Where ( evalue(LCRITERE) & evalue (LCRITERE2)) &( TXSCAT=num$([F:PFD]POSTXS) )&
&                           ( GAC=[F:PFD]GAC and COA=WCOA )
&                            Order By TXSCAT Asc; GAC Asc; AASREF Asc; PERSTRDAT Asc
            For [FLU]
              GOK=1
              If [F:FLU]AASREF <> SAASREF
                 SAASREF = [F:FLU]AASREF
              Else
                 Goto NEXTFLU
              Endif
              #*FQ107751 On regarde quel montant est significatif pour le signe du bien comptable
              If [F:FLU]BSEVALSTR < 0 or [F:FLU]DPRBASSTR < 0 or  [F:FLU]DPRCUMSTR < 0 or
&                [F:FLU]INCDPRFCY < 0 or [F:FLU]INCDPRTRF < 0
                SGNMNT = -1
              Else
                SGNMNT = 1
              Endif
              [F:T55C]TXSCAT     = [F:FLU]TXSCAT
              [F:T55C]FCY        = [F:FLU]FCY
              [F:T55C]TYP        = [F:FLU]TYP
              [F:T55C]FLGSTATXS  = [F:FLU]FLGSTATXS
              [F:T55C]CNX        = [F:FLU]CNX
              [F:T55C]GAC        = [F:FLU]GAC
              [F:T55C]CODTXS     = [F:FLU]CODTXS
              [F:T55C]PERSTRDAT  = LDATDEB
              [F:T55C]PERENDDAT  = LDATFIN
              [F:FLUD] = [F:FLU]
              Gosub GENERE_FLUX_CUMULES_T55
              If !GOK  : Break 3 : Endif
              Gosub CHARGE_T55CUM
              $NEXTFLU
            Next   # [FLU]
            Filter[FLU]
            [F:T55M]=[F:T55C]
         Endif
      Next # [PFD]
      Filter[PFD]
      [F:T55]=[F:T55M]
      [F:T55]EDTNUM = LEDTNUM
      [F:T55]CREUSR = GUSER
      [F:T55]CREDAT = date$
      [F:T55]CLATXS     =  [F:PFL]CLATXS
      [F:T55]POSTXS     =  [F:PFL]POSTXS
      [F:T55]POSTXSDES  =  [F:PFL]DES
      [F:T55]CPY        =  LCPY
      [F:T55]DPRPLN     =  LPLAN
      If LEDTNUM <> 0
         Write [F:T55]
         If fstat : GOK=0 : Call FSTA("T55") From GLOCK : Endif
         If !GOK : Break :  Goto ROLL_TR1 : Endif
      Endif
   Next  # [PFL]
    If GOK : Commit : Else Gosub ROLL_TR1 : Endif

 If dim(G_FLUSTRDAT)  >0   : Kill G_FLUSTRDAT  : Endif #*FQ92637
 If dim(G_FLUENDDAT)  >0   : Kill G_FLUENDDAT  : Endif #*FQ92637
 If dim(G_CRITERE)    >0   : Kill G_CRITERE    : Endif #*FQ92637
 If dim(G_CRITERE2)   >0   : Kill G_CRITERE2   : Endif #*FQ92637

Return
######################################################################################
$CHARGE_T55M

    [F:T55M]A1    += [F:FLU]DPRCUMSTR
    [F:T55M]A2    += [F:FLU]DPE +[F:FLU]INCDPRTRF+[F:FLU]EXCDPR
    [F:T55M]A3    += [F:FLU]DCRDPEOUT + [F:FLU]DCRDPRTRF
    [F:T55M]A4    =  [F:T55M]A1 + [F:T55M]A2 - [F:T55M]A3
    #----------------------------------------------
     # Si Dotation due à un différentiel de durée
    #----------------------------------------------
    #*FQ107751 If  ( [F:FLU]DERFLGDF < 2 and [F:FLU]DERFLGEXC < 2 ) and ( [F:FLU]DERDPR  > [F:FLU]DERRVE)
    If  ( [F:FLU]DERFLGDF < 2 and [F:FLU]DERFLGEXC < 2 ) and
&       func GLOBB9.CAL_CMP_MNT ([F:FLU]DERDPR, ">", [F:FLU]DERRVE, SGNMNT)
          [F:T55M]B1 +=  [F:FLU]DERDPR-[F:FLU]DERRVE-[F:FLU]DERISS
      Endif
    #----------------------------------------------
    #  Si Dotation due à un un Mode dégressif
    #----------------------------------------------
    #*FQ107751 If  ( [F:FLU]DERFLGDF = 2 and [F:FLU]DERFLGEXC < 2 ) and ( [F:FLU]DERDPR  > [F:FLU]DERRVE )
    If  ( [F:FLU]DERFLGDF = 2 and [F:FLU]DERFLGEXC < 2 ) and
&      func GLOBB9.CAL_CMP_MNT ([F:FLU]DERDPR, ">", [F:FLU]DERRVE, SGNMNT)
        [F:T55M]B2 +=  [F:FLU]DERDPR-[F:FLU]DERRVE-[F:FLU]DERISS
      Endif
    #-------------------------------------------------------
    # si Dotation due à un amortissement fiscal exceptionnel
    #--------------------------------------------------------
    #*FQ107751 If  (  [F:FLU]DERFLGEXC = 2 ) and ( [F:FLU]DERDPR  > [F:FLU]DERRVE )
    If  (  [F:FLU]DERFLGEXC = 2 ) and
&     func GLOBB9.CAL_CMP_MNT ([F:FLU]DERDPR, ">", [F:FLU]DERRVE, SGNMNT)
        [F:T55M]B3 += [F:FLU]DERDPR-[F:FLU]DERRVE-[F:FLU]DERISS
      Endif
    #----------------------------------------------
     # Si Reprise due à un différentiel de durée
    #----------------------------------------------
    #*FQ107751 If  ( [F:FLU]DERFLGDF < 2 and [F:FLU]DERFLGEXC < 2 ) and ( [F:FLU]DERDPR  < [F:FLU]DERRVE )
    If  ( [F:FLU]DERFLGDF < 2 and [F:FLU]DERFLGEXC < 2 ) and
&      func GLOBB9.CAL_CMP_MNT ([F:FLU]DERDPR, "<", [F:FLU]DERRVE, SGNMNT)
       # Issue 114175  [F:T55M]B4 += [F:FLU]DERISS
       [F:T55M]B4 += ( [F:FLU]DERRVE - [F:FLU]DERDPR ) + [F:FLU]DERISS
    Endif
    #----------------------------------------------
    # Si Reprise due à un un Mode dégressif
    #----------------------------------------------
    #*FQ107751 If  ( [F:FLU]DERFLGDF = 2 and [F:FLU]DERFLGEXC < 2 ) and ( [F:FLU]DERDPR  < [F:FLU]DERRVE )
    If  ( [F:FLU]DERFLGDF = 2 and [F:FLU]DERFLGEXC < 2 ) and
&      func GLOBB9.CAL_CMP_MNT ([F:FLU]DERDPR, "<", [F:FLU]DERRVE, SGNMNT)
       # Issue 114175  [F:T55M]B5 += [F:FLU]DERISS
       [F:T55M]B5 += ( [F:FLU]DERRVE - [F:FLU]DERDPR ) + [F:FLU]DERISS
    Endif
    #----------------------------------------------
    # Si Reprise due à un amortissement fiscal exceptionnel
    #----------------------------------------------
     #*FQ107751 If  (  [F:FLU]DERFLGEXC = 2 ) and ( [F:FLU]DERDPR  < [F:FLU]DERRVE )
    If  (  [F:FLU]DERFLGEXC = 2 ) and
&      func GLOBB9.CAL_CMP_MNT ([F:FLU]DERDPR, "<", [F:FLU]DERRVE, SGNMNT)
       # Issue 114175 [F:T55M]B6 += [F:FLU]DERISS
       [F:T55M]B6 += ( [F:FLU]DERRVE - [F:FLU]DERDPR ) + [F:FLU]DERISS
    Endif

    [F:T55M]TOTB = ([F:T55M]B1+[F:T55M]B2+[F:T55M]B3) - ([F:T55M]B4+[F:T55M]B5+[F:T55M]B6)

Return
###*FQ92637  ####################################################################################
 $GENERE_FLUX_CUMULES_T55
Local Integer PSTA : PSTA=2  # Flux provisoires
Local Integer PRPT : PRPT=1  # Pour dire au TRTFLUX que l'on vient des traitements préparatoirs aux éditions
Local Integer PPLN : PPLN=LPLAN  # Passage du plan au TRTFLUX
Local Integer RERROR

  # On appelle le sous-pro qui génère un flux exercice à partir des périodes de l'exercice
  # On s'en sert ici pour générer un flux de périodes cumulées qui sera chargé dans la table TMP2055 (T55C]
  # Dans [FLUD] on a le flux de la 1ère période traitée
  # Les classes [F:FAS] et [F:DEPF] doivent être ouvertes
  # Les classes [F:CNX] et [F:FIS] doivent être ouvertes
  # Lecture exercice courant

   Read[FIS]FIY1=LCPY;RCNX;GVML_TECOURA
   Call GENERE_FLUX_EXERCICE (GML_TFPLIASS, PSTA, PRPT, PPLN, RERROR) From TRTFLUX
   If RERROR <> 0
       # Pas de flux période, c'est anormal : "Veuillez vérifier les bornes de dates".
       #*X3-68907 Call ECR_TRACE(mess(60,GML_MSGMIS,1)-""-"RERROR = "-num$(RERROR),1) From GESECRAN
       Call ECR_TRACE(mess(106,GML_MSGMIS,1)-""-"RERROR = "-num$(RERROR),1) From GESECRAN
       GOK=0
       Return
    Endif

Return
###*FQ92637  ####################################################################################
$CHARGE_T55CUM

   [F:T55C]A1    += [F:FLUD]DPRCUMSTR
   [F:T55C]A2    += (([F:WFLU]DPE +[F:WFLU]INCDPRTRF+[F:WFLU]EXCDPR) )
   [F:T55C]A3    += [F:WFLU]DCRDPEOUT + [F:WFLU]DCRDPRTRF
   [F:T55C]A4    =  [F:T55C]A1 + [F:T55C]A2 - [F:T55C]A3
    #----------------------------------------------
    # SI Dotation due à un différentiel de durée
    #----------------------------------------------
    #*FQ107751 If  ( [F:WFLU]DERFLGDF < 2 and [F:WFLU]DERFLGEXC < 2 ) and ( [F:WFLU]DERDPR  > [F:WFLU]DERRVE)
    If  ( [F:WFLU]DERFLGDF < 2 and [F:WFLU]DERFLGEXC < 2 ) and
&       func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERDPR, ">", [F:WFLU]DERRVE, SGNMNT)
       [F:T55C]B1 +=  [F:WFLU]DERDPR-[F:WFLU]DERRVE
     Else
        [F:T55C]B1  += 0
     Endif
    #----------------------------------------------
    #  SI Dotation due à un un Mode dégressif
    #----------------------------------------------
     #*FQ107751 If  ( [F:WFLU]DERFLGDF = 2 and [F:WFLU]DERFLGEXC < 2 ) and ( [F:WFLU]DERDPR  > [F:WFLU]DERRVE )
      If  ( [F:WFLU]DERFLGDF = 2 and [F:WFLU]DERFLGEXC < 2 ) and
&       func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERDPR, ">", [F:WFLU]DERRVE, SGNMNT)
         [F:T55C]B2 +=  [F:WFLU]DERDPR-[F:WFLU]DERRVE
      Else
         [F:T55C]B2  += 0
      Endif
   #----------------------------------------------
    # si Dotation due à un amortissement fiscal exceptionnel
    #----------------------------------------------
    #*FQ107751 If  (  [F:WFLU]DERFLGEXC = 2 ) and ( [F:WFLU]DERDPR  > [F:WFLU]DERRVE )
    If  (  [F:WFLU]DERFLGEXC = 2 ) and
&       func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERDPR, ">", [F:WFLU]DERRVE, SGNMNT)
       [F:T55C]B3 +=  [F:WFLU]DERDPR-[F:WFLU]DERRVE
      Else
         [F:T55C]B3  += 0
      Endif
    #----------------------------------------------
    # SI Reprise due à un différentiel de durée
    #----------------------------------------------
    If  ( [F:WFLU]DERFLGDF < 2 and [F:WFLU]DERFLGEXC < 2 )
    #*FQ107751    If ( [F:WFLU]DERDPR  < [F:WFLU]DERRVE )
       If func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERDPR, "<", [F:WFLU]DERRVE, SGNMNT)
          If [F:WFLU]DERISS = 0
             [F:T55C]B4 +=  [F:WFLU]DERRVE  - [F:WFLU]DERDPR
          Else
             #*FQ107751 If [F:WFLU]DERISS >  0
             If func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERISS, ">", 0, SGNMNT)
               [F:T55C]B4 += ([F:WFLU]DERISS+ [F:WFLU]DERRVE- [F:WFLU]DERDPR )
             Else
                #*FQ107751 If [F:WFLU]DERISS < 0
                If func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERISS, "<", 0, SGNMNT)
                [F:T55C]B4 += 0
             Endif
          Endif
          Endif
       Else
          #*FQ107751 If  [F:WFLU]DERISS <= 0
          If func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERISS, "<=", 0, SGNMNT)
             [F:T55C]B4 += 0
          Else
             [F:T55C]B4 +=  [F:WFLU]DERISS
          Endif
       Endif
    Endif
    #----------------------------------------------
    # SI Reprise due à un un Mode dégressif
    #----------------------------------------------
    If  ( [F:WFLU]DERFLGDF = 2 and [F:WFLU]DERFLGEXC < 2 )
    #*FQ107751    If ( [F:WFLU]DERDPR  < [F:WFLU]DERRVE )
       If func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERDPR, "<", [F:WFLU]DERRVE, SGNMNT)
          If [F:WFLU]DERISS = 0
             [F:T55C]B5 +=  [F:WFLU]DERRVE  - [F:WFLU]DERDPR
          Else
             #*FQ107751 If [F:WFLU]DERISS >  0
             If func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERISS, ">", 0, SGNMNT)
               [F:T55C]B5 += ([F:WFLU]DERISS+ [F:WFLU]DERRVE- [F:WFLU]DERDPR )
             Else
                #*FQ107751 If [F:WFLU]DERISS < 0
                If func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERISS, "<", 0, SGNMNT)
                [F:T55C]B5 += 0
             Endif
          Endif
          Endif
       Else
          #*FQ107751 If  [F:WFLU]DERISS <= 0
          If func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERISS, "<=", 0, SGNMNT)
             [F:T55C]B5 += 0
          Else
             [F:T55C]B5 +=  [F:WFLU]DERISS
          Endif
       Endif
    Endif
    #----------------------------------------------
    # si Reprise due à un amortissement fiscal exceptionnel
    #----------------------------------------------
    If  ( [F:WFLU]DERFLGEXC = 2 )
    #*FQ107751    If ( [F:WFLU]DERDPR  < [F:WFLU]DERRVE )
       If func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERDPR, "<", [F:WFLU]DERRVE, SGNMNT)
          If [F:WFLU]DERISS = 0
             [F:T55C]B6 +=  [F:WFLU]DERRVE  - [F:WFLU]DERDPR
          Else
             #*FQ107751 If [F:WFLU]DERISS >  0
             If func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERISS, ">", 0, SGNMNT)
               [F:T55C]B6 += ([F:WFLU]DERISS+ [F:WFLU]DERRVE- [F:WFLU]DERDPR )
             Else
                #*FQ107751 If [F:WFLU]DERISS < 0
                If func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERISS, "<", 0, SGNMNT)
                [F:T55C]B6 += 0
             Endif
          Endif
          Endif
       Else
          #*FQ107751 If  [F:WFLU]DERISS <= 0
          If func GLOBB9.CAL_CMP_MNT ([F:WFLU]DERISS, "<=", 0, SGNMNT)
             [F:T55C]B6 += 0
          Else
             [F:T55C]B6 +=  [F:WFLU]DERISS
          Endif
       Endif
    Endif

     [F:T55C]TOTB = ([F:T55C]B1+[F:T55C]B2+[F:T55C]B3) - ([F:T55C]B4+[F:T55C]B5+[F:T55C]B6)

Return
####################################################
#================================================================
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L

   Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
   L = len(PARAM)
   If right$(PARAM,L-2)="deb"
      If VALEUR=string$(len(VALEUR)," ")
          VALEUR = ""
      Endif
   Endif

End
######################################################################################
$ROLL_TR1

 If dim(G_FLUSTRDAT)  >0   : Kill G_FLUSTRDAT  : Endif #*FQ92637
 If dim(G_FLUENDDAT)  >0   : Kill G_FLUENDDAT  : Endif #*FQ92637
 If dim(G_CRITERE)    >0   : Kill G_CRITERE    : Endif #*FQ92637
 If dim(G_CRITERE2)   >0   : Kill G_CRITERE2   : Endif #*FQ92637
Rollback : Call ROLL From GLOCK
If GROLL : Return  : Endif
Return

