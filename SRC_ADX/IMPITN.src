#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
# IMPITN : Import/Export Interventions
# --------------------------------------------------------------------- #
# Traitements des actions spécifiques à l'import/export                 #
# avec import/exports des textes sous formes clobs
#########################################################################
$ACTION
  Case ACTION
    When "IMPORT"
      Gosub IMPORT
  Endcase
Return

##########################################################################################################
#                                  IMPORT                                #
##########################################################################
#-----------------------------------------------------#
# Après lecture d'un enregistrement (entête ou ligne) #
#                                                     #
# IMPFIC : Abréviation du fichier en cours            #
#-----------------------------------------------------#
$IMPORT
  Case IMPFIC
    When "HD6"      
      #Affectation clob complément d'informations
      [M:ITN1]FULOBJ = [F:HD6]CLOB
    When "HD2"      
      #Affectation clob compte rendu
      [M:ITN4]FULRPO = [F:HD2]CLOB
  Endcase
Return
