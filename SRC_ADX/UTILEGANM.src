#<AdxTL>@(#)7.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Initialisation champ LEG table ACODNUM dans les dossiers mono
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update LEG in ACODNUM Table for mono legislation folders") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJANM
End

#-------------------#
$MAJANM

If DOSSIER=GDOSX3
 Return
Endif

Local Integer MONO , UPD

Local File ADOSSIER [ADS_U] , ADOSACT [ADA_U]
Read [ADS_U]DOSSIER = [L]DOSSIER
Read [ADA_U]ADA0 = [L]DOSSIER;"LEG"
If fstat or [F:ADA_U]FLACT<>2
 MONO = 1
Endif
If !MONO : Goto FIN : Endif

# Mise à jour de la table ACODNUM

Call ECR_TRACE(mess(81,125,1)-"ACODNUM:"-time$,0) From GESECRAN

Local File =DOSSIER+".ACODNUM" [ANM]

Trbegin [ANM]

 For [ANM]
  If [F:ANM]LEG=""
   [F:ANM]LEG = [F:ADS_U]DOSLEG
   Rewrite [ANM]
   If fstat
    Call ERREUR("ACODNUM"-[F:ANM]CODNUM,2) From DOSDIC
   Endif
  Endif
 Next ANM

Commit

#----------------#
$FIN

Close Local File

Return

