#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DKJ1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:57"
A_USER  = "DOC"
A_STAMP = "20181109230357"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask DKJ1 [DKJ1]
Gosub HORODAT
Local Inpbox "DKJ1" From GFONCTION At A_STAMP With A_WINDPREV Mask [DKJ1] As [SIM_]
Grizo [DKJ1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DKJ1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=25 : X2(0)=88 : Y1(0)=7 : Y2(0)=22
Return

$ON_KEYCODE
Onevent CONTROL Call C_KEYCODE(zc) From W1DKJ1
Return

Subprog C_KEYCODE(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "KEYCODE" : GZNUM = 5296 : Endif
If !mkstat
 ## Action STD
 Call C_KEYCODE(VALEUR) From SUBDKJ
 If mkstat : GERR = 1 : GZONE = "KEYCODE" : GZNUM = 5296 : Endif
Endif
Gosub _AFF
End

$ON_SRVJAVA
Onevent CONTROL Call C_SRVJAVA(zc) From W1DKJ1
Return

Subprog C_SRVJAVA(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SRVJAVA" : GZNUM = 41346 : Endif
Gosub _AFF
End

$ON_TYPDBA
Onevent INIT_AREA Call D_TYPDBA(zc) From W1DKJ1
Onevent BEFORE_INPUT Call AS_TYPDBA(zc) From W1DKJ1
Onevent CONTROL Call C_TYPDBA(zc) From W1DKJ1
Return

Subprog D_TYPDBA(VALEUR)
Variable Integer VALEUR
If varinit([M]TYPDBA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TYPDBA(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_TYPDBA(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TYPDBA" : GZNUM = 710 : Endif
Gosub _AFF
End

$ON_MODIF
Onevent INIT_AREA Call D_MODIF(zc) From W1DKJ1
Return

Subprog D_MODIF(VALEUR)
Variable Integer VALEUR
If varinit([M]MODIF,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_UPDUSR
Return

$ON_CREUSR
Return

$CHG_STY
Return


