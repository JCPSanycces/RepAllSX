##########################################################################################################
Funprog DELETE_RPT_TABLES(SKEYEXT, SSHOWGRP, SOPPNUM)
Value Char SKEYEXT
Value Char SSHOWGRP
Value Char SOPPNUM

Local Integer IARENDRE
Local Integer IADXLOG

  # Issue X3-64481 - 2018-01-11 by FGR
  IARENDRE = [V]CST_AOK
  #--------------------------------
  Local File PJMFINOVRRPT [PJMRPT]
  Local File PJMFINCTORPT [PJMCTO]
  #--------------------------------
  IADXLOG = (adxlog = 1)
  If IADXLOG = [V]CST_AFALSE Then
    Trbegin [PJMRPT]
  Endif
  #--------------------------------
  Delete [PJMRPT] Where [F:PJMRPT]KEYEXT = SKEYEXT and [F:PJMRPT]SHOWGRP = SSHOWGRP and [F:PJMRPT]OPPNUM = SOPPNUM
  If fstat Then
    IARENDRE = [V]CST_AERROR
    GOK = 0
    GMESSAGE = mess(1031,2260,1) - "(a)"
  Else
    Delete [PJMCTO] Where [F:PJMCTO]KEYEXT = SKEYEXT and [F:PJMCTO]SHOWGRP = SSHOWGRP and [F:PJMCTO]OPPNUM = SOPPNUM
    If fstat Then
      IARENDRE = [V]CST_AERROR
      GOK = 0
      GMESSAGE = mess(1031,2260,1) - "(b)"
    Else
      IARENDRE = max(IARENDRE, func DELETE_ATEXTRA(func GET_CODFIC_VALUE(), SKEYEXT))
    Endif
  Endif
  #--------------------------------
  If IADXLOG = [V]CST_AFALSE Then
    If IARENDRE = [V]CST_AOK Then
      Commit
    Else
      Rollback
    Endif
  Endif
  #--------------------------------
End IARENDRE

##########################################################################################################
Funprog GET_CODFIC_VALUE()

Local Char SARENDRE(GLONATB)

  SARENDRE = "PJMFINOVRRPT"
End SARENDRE

##########################################################################################################
Funprog GET_ZONE_VALUE(SFIELD)
Value Char SFIELD

Local Char SARENDRE(GLONAVA)

  # Issue X3-84952 - 2018-06-05 by FGR
  Raz SARENDRE
  Case SFIELD
    When "OPPNUM", "PBUCOD", "PCCCOD", "PCCGRP"
      SARENDRE = SFIELD
  Endcase
End SARENDRE

##########################################################################################################
Funprog LOAD_FOLDER_LANGUAGES(ACTX, STBLAN)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Char STBLAN()(0..)

Local Integer IARENDRE
Local Integer NLAN
Local Integer NI

  # Issue X3-84952 - 2018-06-05 by FGR
  # STABLAN contain list of languages managed on the folder
  # Index 1 to maxtab(STABLAN) are managed languages
  # STABLAN(0) is the default language of the folder
  #--------------------------------
  IARENDRE = [V]CST_AOK
  #--------------------------------
  Local File ADOSSIER [ADS]
  #--------------------------------
  Raz STBLAN
  Read [ADS]DOSSIER=ACTX.AFOLDER
  NLAN = 0
  STBLAN(NLAN) = [F:ADS]LANDEF
  For NI = 0 To dim([F:ADS]LAN)
    If [F:ADS]LAN(NI) = AVOID.ACHAR Then
      Break
    Else
      NLAN += 1
      STBLAN(NLAN) = [F:ADS]LAN(NI)
    Endif
  Next NI
End IARENDRE

##########################################################################################################
Funprog LOAD_ATEXTRA(ACTX, STBLAN, STABLEF, SZONEF, SIDENT1F, SIDENT2F, STABLET, SZONET, SIDENT2T)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char STBLAN()(0..)
Value Char STABLEF
Value Char SZONEF
Value Char SIDENT1F
Value Char SIDENT2F
Value Char STABLET
Value Char SZONET
Value Char SIDENT2T

Local Integer IARENDRE
Local Integer IADXLOG
Local Integer ITBLAN
Local Datetime DDATFIRST
Local Char SLANFIRST(GLONLAN)
Local Char SLANDEF(GLONLAN)
Local Integer IEXIST

  # Issue X3-84952 - 2018-06-05 by FGR
  # At this level, to not have not have missing translation, regarding managed languages on the folder
  # texts are going to be created in the existing languages.
  # If not existing, texts will be created in the default language
  # If not existing, texts will be created with the older created text
  #--------------------------------
  IARENDRE = [V]CST_AOK
  #--------------------------------
  Local File ATEXTRA [AXXF]  # From
  Local File ATEXTRA [AXXT]  # To
  #--------------------------------
  IADXLOG = (adxlog = 1)
  If IADXLOG = [V]CST_AFALSE Then
    Trbegin [AXXT]
  Endif
  #--------------------------------
  IEXIST = [V]CST_ANO
  Raz SLANFIRST
  Raz SLANDEF
  DDATFIRST =  datetime$
  #--------------------------------
  # 1°) Create texts in existing languages
  Filter [AXXF] Where [F:AXXF]CODFIC = STABLEF and [F:AXXF]ZONE = SZONEF and [F:AXXF]IDENT1 = SIDENT1F and [F:AXXF]IDENT2 = SIDENT2F
  For [AXXF]
    Raz [F:AXXT]
    [F:AXXT]       = [F:AXXF]
    [F:AXXT]CODFIC = STABLET
    [F:AXXT]ZONE   = SZONET
    If SIDENT2F <> AVOID.ACHAR Then
      [F:AXXT]IDENT1 = func CONCAT_KEYS(SIDENT1F, SIDENT2F)
    Endif
    [F:AXXT]IDENT2 = SIDENT2T
    Write [AXXT]
    If fstat Then
      # If record is existing, not necessary to continue
      IEXIST = [V]CST_AYES
      Break
    Endif
    #
    ITBLAN = find([F:AXXT]LANGUE, STBLAN(1..maxtab(STBLAN)))
    Raz STBLAN(ITBLAN) # Erase in the (local) array managed languages
    If [F:AXXF]LANGUE = STBLAN(0) Then
      SLANDEF = [F:AXXF]LANGUE
    Elsif [F:AXXF]CREDATTIM < DDATFIRST Then
      DDATFIRST = [F:AXXF]CREDATTIM
      SLANFIRST = [F:AXXF]LANGUE
    Endif
  Next
  Filter [AXXF]
  If IEXIST = [V]CST_ANO Then
    # 2°) create text in not yet translated languages with the SLANDEF if existing, or with SLNANFIRST if not
    If SLANDEF = AVOID.ACHAR Then
      SLANDEF = SLANFIRST
    Endif
    Read [AXXF]AXX0=STABLEF;SZONEF;SLANDEF;SIDENT1F;SIDENT2F
    For NI = 1 To maxtab(STBLAN)
      If STBLAN(NI) <> AVOID.ACHAR Then
        [F:AXXT]       = [F:AXXF]
        [F:AXXT]CODFIC = STABLET
        [F:AXXT]ZONE   = SZONET
        [F:AXXT]LANGUE = STBLAN(NI)
        If SIDENT2F <> AVOID.ACHAR Then
          [F:AXXT]IDENT1 = func CONCAT_KEYS(SIDENT1F, SIDENT2F)
        Endif
        [F:AXXT]IDENT2 = SIDENT2T
        Write [AXXT]
      Endif
    Next NI
  Endif
  #--------------------------------
  If IADXLOG = [V]CST_AFALSE Then
    If IARENDRE = [V]CST_AOK Then
      Commit
    Else
      Rollback
    Endif
  Endif
  #--------------------------------
End IARENDRE

##########################################################################################################
Funprog CONCAT_KEYS(SIDENT1, SIDENT2)
Value Char SIDENT1
Value Char SIDENT2

Local Char SARENDRE(GLONDCO)

  # Issue X3-84952 - 2018-06-05 by FGR
  SARENDRE = SIDENT1 + "~" + SIDENT2
End SARENDRE

##########################################################################################################
Funprog GET_ADI_PCCGRP()

Local Char SARENDRE(GLONADI)

  # Issue X3-84952 - 2018-06-05 by FGR
  SARENDRE = "386"
End SARENDRE

##########################################################################################################
Funprog DELETE_ATEXTRA(STABLE, SIDENT2)
Value Char STABLE
Value Char SIDENT2

Local Integer IARENDRE
Local Integer IADXLOG

  # Issue X3-84952 - 2018-06-05 by FGR
  #--------------------------------
  IARENDRE = [V]CST_AOK
  #--------------------------------
  Local File ATEXTRA [AXX]
  #--------------------------------
  IADXLOG = (adxlog = 1)
  If IADXLOG = [V]CST_AFALSE Then
    Trbegin [AXX]
  Endif
  #--------------------------------
  Delete [AXX] Where [F:AXX]CODFIC = STABLE and [F:AXX]IDENT2 = SIDENT2
  If fstat Then
    IARENDRE = [V]CST_AERROR
    GOK = 0
    GMESSAGE = mess(1031,2260,1) - "(axx)"
  Endif
  #--------------------------------
  If IADXLOG = [V]CST_AFALSE Then
    If IARENDRE = [V]CST_AOK Then
      Commit
    Else
      Rollback
    Endif
  Endif
  #--------------------------------
End IARENDRE

##########################################################################################################
Funprog GET_DESC_OPPNUM(ACTX, SKEYEXT, SOPPNUM)
Variable Instance ACTX Using OBJECT
Value Char SKEYEXT
Value Char SOPPNUM

Local Char SARENDRE(GLONDCO)

  # Issue X3-84952 - 2018-06-05 by FGR
  Call LECTEXTRA(ACTX, AVOID.ACHAR,
&                SARENDRE,
&                func GET_CODFIC_VALUE(),
&                func GET_ZONE_VALUE("OPPNUM"),
&                SOPPNUM,
&                SKEYEXT) From ASYRFNC
End SARENDRE

