#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# ACTION - PJMRPTEXT
##########################################################################################################
# Reporting Extracts
##########################################################################################################
$ACTION
  Case ACTION
    When "INIT_DIA"  :  Gosub INIT_DIA
    When "CONTROL"   :  Gosub CONTROL
    When "EXEC"      :  Gosub EXEC
    When "SORTIE"    :  Gosub SORTIE
    When Default
  Endcase
Return

##########################################################################################################
$INIT_DIA
Local Instance TECFINOVE Using C_TECFINOVE
Local Integer IRET

  TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
  IRET = fmet TECFINOVE._GET_DEFAULT_GRP()
  [M:DIA]PCCGRP    = TECFINOVE.SHOWGRP
  [M:DIA]ALLCPY    = [V]CST_AYES
  [M:DIA]ALLPCCGRP = [V]CST_AYES
  [M:DIA]ALLPRJ    = [V]CST_AYES
  [M:DIA]LOGFILE   = [V]CST_ANO
  Affzo [M:DIA]1-99
  # -----------------------------
  NAVIG = GACTION
  GOK = 1
  # -----------------------------
Return

##########################################################################################################
$CONTROL
  # Add control to be sure that all the screen information are true
Return

##########################################################################################################
$EXEC
Local Char CRITERE(250)(10)
Local Integer ICRITERE
Local Integer IRET
Local Date DDELAY

  Local File OPPOR [OPP]
  Local File OPPORPJM [OPPPJM]
  Local File PIMPL [PIM]
  #Local File ATABDIV [ADI] Where NUMTAB = 388                                           # Issue X3-111580 - 2018-10-16 by FGR
  Local File ATABDIV [ADI] Where [F:ADI]NUMTAB = 388 and [F:ADI]ENAFLG = [V]CST_AYES     # Issue X3-111580 - 2018-10-16 by FGR
  #--------------------------------
  Link [PIM] With [OPPPJM]OPPPJM0=[F:PIM]OPPNUM,
&                 [OPP]OPP0=[F:PIM]OPPNUM
&              As [NEW]
&              Where ([F:PIM]PIMTYP = 2 or [F:PIM]PIMTYP = 3)
&              Order By Key KEY1=[F:PIM]CPY;[F:PIM]OPPNUM
  #--------------------------------
  Raz CRITERE
  ICRITERE = 0
  #-------------------
  #Set Criteria Values
  #-------------------
  CRITERE(ICRITERE) -= "([F:PIM]PIMTYP = 2 or [F:PIM]PIMTYP = 3)"
  If [M:DIA]CPY <> "" Then
    CRITERE(ICRITERE) -= "and [F:PIM]CPY = [M:DIA]CPY"
  Endif
  If [M:DIA]OPPNUMF <> "" Then
    CRITERE(ICRITERE) -= "and [F:PIM]OPPNUM >= [M:DIA]OPPNUMF"
  Endif
  If [M:DIA]OPPNUMT <> "" Then
    CRITERE(ICRITERE) -= "and [F:PIM]OPPNUM <= [M:DIA]OPPNUMT"
  Endif
  ICRITERE += 1
  CRITERE(ICRITERE) -= "and ([F:PIM]PIMSTA = [V]CST_AYES"
  If [M:DIA]DELAY <> 0 Then
    # Add code to handle the Delay Field
    DDELAY = date$-(30*10)
    CRITERE(ICRITERE) -= "or ([F:PIM]PIMSTA = [V]CST_ANO and [F:OPPPJM]OPPDATS >= DDELAY)"
  Endif
  CRITERE(ICRITERE) += ")"
  #--------------------------------
  If [M:DIA]LOGFILE = [V]CST_AYES
    Call OUVRE_TRACE(mess(410,2260,1)) From LECFIC
    Call PRTSCR("PJMRPTEXT", "DIA", "", 0, 1) From ATRTX3
  Endif
  #--------------------------------
  If [M:DIA]ALLPCCGRP = [V]CST_ANO Then
    Filter [ADI] Where CODE = [M:DIA]PCCGRP
  Else
    Filter [ADI]
  Endif
  #--------------------------------
  For [ADI]
    #--------------------------------
    Call ECR_TRACE(string$(50,"-"), 0)
    Call ECR_TRACE(func AFNC.MES1(mess(409,2260,1), [F:ADI]CODE), 0)
    #--------------------------------
    #Extract values based on Criteria
    #--------------------------------
    Filter [F:NEW] Where evalue(CRITERE)
    For [NEW]KEY1
      If TECFINOVE <> null Then
        FreeGroup TECFINOVE
      Endif
      TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
      TECFINOVE.ISBUDUPD = [V]CST_ANO            # Note FGR : set to [V]CST_ANO in financial overview
      TECFINOVE.OPPNUM   = [F:PIM]OPPNUM
      If [M:DIA]PSCUR = AVOID.ACHAR
        TECFINOVE.CUR = [F:OPPPJM]CUROPP
      Else
        TECFINOVE.CUR = [M:DIA]PSCUR
      Endif
      TECFINOVE.UOM      = fmet TECFINOVE.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, [F:PIM]FCY, "UNITWORK")
      TECFINOVE.SHOWGRP  = [F:ADI]CODE
      TECFINOVE.MULPRJ   = [V]CST_ANO  # Issue X3-111580 - 2018-10-19 by FGR
      #--------------------------------
      If TECFINOVE.UOM = AVOID.ACHAR Then
        GMESSAGE = func AFNC.MES1(mess(398,2260,1), [F:PIM]FCY)
        GOK = 0
        Break
      Endif
      #--------------------------------
      Call ECR_TRACE(func AFNC.MES1(mess(408,2260,1), [F:PIM]OPPNUM), 0)
      IRET = func COMPUTE_TECFINOVE(TECFINOVE, "PJMRPTEXT")
      If IRET >= [V]CST_AERROR Then
        # Issue X3-111580 - 2018-10-16 by FGR : BEGIN
        #If GMESSAGE <> AVOID.ACHAR Then
        #  Break
        #Else
        #  If [M:DIA]LOGFILE = [V]CST_ANO Then
        #    # If the log file is not checked : checked by script to have in the log file the project with its errors
        #    [M:DIA]LOGFILE = [V]CST_AYES
        #    Call OUVRE_TRACE(mess(410,2260,1)) From LECFIC
        #    Call PRTSCR("PJMRPTEXT", "DIA", "", 0, 1) From ATRTX3
        #    Call ECR_TRACE(func AFNC.MES1(mess(409,2260,1), TECFINOVE.SHOWGRP), 0)
        #    Call ECR_TRACE(string$(50,"-"), 0)
        #    Call ECR_TRACE(func AFNC.MES1(mess(408,2260,1), [F:PIM]OPPNUM), 0)
        #  Endif
        #  Call MSGSTACK_DUMP_FILTERED_MESSAGES_INTO_CLASSIC_LOG(TECFINOVE, -1, -1) From SYRSTACKTOOLS
        #  If GMESSAGE <> AVOID.ACHAR Then
        #    Call ECR_TRACE("->" - GMESSAGE, 1)
        #  Endif
        #Endif
        If [M:DIA]LOGFILE = [V]CST_ANO Then
          # If the log file is not checked : checked by script to have in the log file the project with its errors
          [M:DIA]LOGFILE = [V]CST_AYES
          Call OUVRE_TRACE(mess(410,2260,1)) From LECFIC
          Call PRTSCR("PJMRPTEXT", "DIA", "", 0, 1) From ATRTX3
          Call ECR_TRACE(func AFNC.MES1(mess(409,2260,1), TECFINOVE.SHOWGRP), 0)
          Call ECR_TRACE(string$(50,"-"), 0)
          Call ECR_TRACE(func AFNC.MES1(mess(408,2260,1), [F:PIM]OPPNUM), 0)
        Endif
        Call MSGSTACK_DUMP_FILTERED_MESSAGES_INTO_CLASSIC_LOG(TECFINOVE, -1, -1) From SYRSTACKTOOLS
        If GMESSAGE <> AVOID.ACHAR Then
          Call ECR_TRACE("->" - GMESSAGE, 1)
        Endif
        # Issue X3-111580 - 2018-10-16 by FGR : END
      Endif
    Next
    Filter [F:NEW]
  Next
  Filter [F:ADI]
  #--------------------------------
  Call ECR_TRACE(string$(50,"-"), 0)
  If [M:DIA]LOGFILE = [V]CST_AYES Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #--------------------------------
Return

##########################################################################################################
$SORTIE
Local Integer IRET

  If TECFINOVE <> null Then
    IRET = fmet TECFINOVE.DELETE_ALL()
    FreeGroup TECFINOVE
    Raz TECFINOVE
  Endif
Return

##########################################################################################################
# SCREENS
##########################################################################################################
##########################################################################################################
Subprog AM_OPPNUMF(VALEUR)
Variable Char    VALEUR()

  If [M:DIA]OPPNUMT = AVOID.ACHAR or [M:DIA]OPPNUMT < VALEUR Then
    [M:DIA]OPPNUMT = VALEUR
    Affzo [M:DIA]OPPNUMT
  Endif
End

##########################################################################################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES
    Grizo [M:DIA]CPY
  Else
    Actzo [M:DIA]CPY
  Endif
End

##########################################################################################################
Subprog C_ALLPCCGRP(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES
    Grizo [M:DIA]PCCGRP
  Else
    Actzo [M:DIA]PCCGRP
  Endif
End

##########################################################################################################
Subprog C_ALLPRJ(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES
    Grizo [M:DIA]OPPNUMF
    Grizo [M:DIA]OPPNUMT
  Else
    Actzo [M:DIA]OPPNUMF
    Actzo [M:DIA]OPPNUMT
  Endif
End

##########################################################################################################
# WINDOWS SUBROUTINES/FUNCTIONS
##########################################################################################################
#########################################################################################################
Subprog ECR_TRACE(TEX, ERR)
Value Char    TEX() : # Texte du message
Value Integer ERR

  If [M:DIA]LOGFILE = [V]CST_AYES Then
    Call ECR_TRACE (TEX, ERR) From GESECRAN
  Endif
End

##########################################################################################################
# GENERIC SUBROUTINES/FUNCTIONS
##########################################################################################################
Funprog COMPUTE_TECFINOVE(TECFINOVE, SKEYEXT)
Variable Instance TECFINOVE Using C_TECFINOVE
Value Char SKEYEXT

Local Integer IARENDRE

  If TECFINOVE = null Then
    GMESSAGE = mess(560,2260,1)
    IARENDRE = [V]CST_AERROR
  Else
    IARENDRE = fmet TECFINOVE.EXTRACT_ALL()
    If IARENDRE = [V]CST_AOK Then
      IARENDRE = func LOAD_RPT_TABLES(TECFINOVE, SKEYEXT)
      # Issue X3-111580 - 2018-10-16 by FGR : BEGIN : Table are only delete if there is not error on the previous line
      #If IARENDRE = [V]CST_AOK Then
      #  IARENDRE = fmet TECFINOVE.DELETE_ALL()
      #Endif
      IARENDRE = max(IARENDRE, fmet TECFINOVE.DELETE_ALL())
      # Issue X3-111580 - 2018-10-16 by FGR : END
    Endif
  Endif
End IARENDRE

##########################################################################################################
# Issue X3-84952 - 2018-06-05 by FGR : BEGIN
Funprog LOAD_RPT_TABLES(TECFINOVE, SKEYEXT)
Variable Instance TECFINOVE Using C_TECFINOVE
Value Char SKEYEXT

Local Integer IARENDRE
Local Integer IADXLOG
Local Char STBLAN(GLONLAN)(0..)
Local Integer IRET

  IARENDRE = [V]CST_AOK
  #--------------------------------
  Local File PJMSC [PJC]
  Local File PJMSCCT [PJCCT]
  Local File PJMFINOVRRPT [PJMRPT]
  Local File PJMFINCTORPT [PJMCTO]
  Local File PJMCOSTCTR [PJCC]
  #--------------------------------
  IADXLOG = (adxlog = 1)
  If IADXLOG = [V]CST_AFALSE Then
    Trbegin [PJC]
  Endif
  #--------------------------------
  IRET = func LOAD_FOLDER_LANGUAGES(TECFINOVE.ACTX, STBLAN)
  #
  IARENDRE = func DELETE_RPT_TABLES(SKEYEXT, TECFINOVE.SHOWGRP, TECFINOVE.OPPNUM)
  If IARENDRE = [V]CST_AOK Then
    Link [F:PJC] With [F:PJCC]PCC0=[F:PJC]PCCCOD
&                  As [LNK]
&            Order By Key KEY0=[F:PJC]PSCSSS;[F:PJC]OPPNUM;[F:PJC]PBUCOD
    #
    Filter [F:LNK] Where [F:PJC]PSCSSS = TECFINOVE.SESSION
    For [F:LNK]KEY0
      [F:PJMRPT] = [F:PJC]
      [F:PJMRPT]KEYEXT = SKEYEXT
      [F:PJMRPT]SHOWGRP = TECFINOVE.SHOWGRP
      [F:PJMRPT]PSCUR = TECFINOVE.CUR
      Write [F:PJMRPT]
      If fstat Then
        IARENDRE = [V]CST_AERROR
        GOK = 0
        GMESSAGE = mess(399,2260,1) - "(a)"
        Break
      Endif
      #--------------------------------
      # Manage translated texts
      If [F:PJMRPT]OPPNUM <> AVOID.ACHAR Then
        IRET = func LOAD_ATEXTRA(TECFINOVE.ACTX, STBLAN,
&                                "PIMPL", "PIMDESAX1", [F:PJMRPT]OPPNUM, AVOID.ACHAR,
&                                func GET_CODFIC_VALUE(), func GET_ZONE_VALUE("OPPNUM"), SKEYEXT)
      Endif
      If [F:PJMRPT]OPPNUM <> AVOID.ACHAR and [F:PJMRPT]PBUCOD <> AVOID.ACHAR Then
        IRET = func LOAD_ATEXTRA(TECFINOVE.ACTX, STBLAN,
&                                "PIMPL", "PIMDESAX1", func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(TECFINOVE.ACTX, [F:PJMRPT]OPPNUM, [F:PJMRPT]PBUCOD), AVOID.ACHAR,
&                                func GET_CODFIC_VALUE(), func GET_ZONE_VALUE("PBUCOD"), SKEYEXT)
      Endif
      If [F:PJMRPT]PCCCOD <> AVOID.ACHAR Then
        IRET = func LOAD_ATEXTRA(TECFINOVE.ACTX, STBLAN,
&                                "PJMCOSTCTR", "DESAXX", [F:PJMRPT]PCCCOD, AVOID.ACHAR,
&                                func GET_CODFIC_VALUE(), func GET_ZONE_VALUE("PCCCOD"), SKEYEXT)
      Endif
      If [F:PJCC]PCCGRP <> AVOID.ACHAR Then
        IRET = func LOAD_ATEXTRA(TECFINOVE.ACTX, STBLAN,
&                                "ATABDIV", "LNGDES", func GET_ADI_PCCGRP(), [F:PJCC]PCCGRP,
&                                func GET_CODFIC_VALUE(), func GET_ZONE_VALUE("PCCGRP"), SKEYEXT)
      Endif
      #--------------------------------
    Next
    Filter [F:LNK]
  Endif
  #--------------------------------
  If IARENDRE = [V]CST_AOK Then
    Filter [F:PJCCT] Where [F:PJCCT]PSCSSS = TECFINOVE.SESSION
    For [F:PJCCT]
      [F:PJMCTO] = [F:PJCCT]
      [F:PJMCTO]KEYEXT = SKEYEXT
      [F:PJMCTO]SHOWGRP = TECFINOVE.SHOWGRP
      [F:PJMCTO]PSCUR = TECFINOVE.CUR
      Write [F:PJMCTO]
      If fstat Then
        IARENDRE = [V]CST_AERROR
        GOK = 0
        GMESSAGE = mess(399,2260,1) - "(b)"
        Break
      Endif
    Next
    Filter [F:PJCCT]
  Endif
  #--------------------------------
  If IADXLOG = [V]CST_AFALSE Then
    If IARENDRE = [V]CST_AOK Then
      Commit
    Else
      Rollback
    Endif
  Endif
  #--------------------------------
End IARENDRE

