####################################################################################
# Code from SUBGA0
Subprog AS_SAC1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto SAISAC
Subprog AS_SAC2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto SAISAC
Subprog AS_SAC3(VALEUR)
Variable Char    VALEUR()
TYD = 3 : Goto SAISAC
Subprog AS_SAC4(VALEUR)
Variable Char    VALEUR()
TYD = 4 : Goto SAISAC
Subprog AS_SAC5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto SAISAC
Subprog AS_SAC6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto SAISAC
Subprog AS_SAC7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto SAISAC
Subprog AS_SAC8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto SAISAC
Subprog AS_SAC9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto SAISAC
Subprog AS_SAC10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : Goto SAISAC

# Cannot use the call to SUBGA0 because of fields accessed that are not part of this screen
$SAISAC
If GIMPORT & TYD>1 : mkstat=2 : End : Endif
If VALEUR="" & !find(status,5,31,75) : mkstat=2 : End : Endif
Gosub SETNOL
# Intercompany enhancement to reset the global variables
If GCURINTCPY <> [M]CPYLIN(NOL)
  Call RESET_INTCPYCOA ([M]CPYLIN(NOL),[M]FCYLIN(NOL)) From INTCPYLIB
Endif

# Controls : # Fiscal years & Fiscal periods
Call CONTPER([M]ACCDAT,[M:HAEF]LEDTYP(TYD-1),[M]FCYLIN(nolign-1)) From CPTSUB
If mkstat=2 : mkstat=1 : End : Endif

# Rules propogation access AS_SAC (ditto for AS_ACC - 88148 / 92938 for SUBGIC)
# Save the structure
Gosub AVT_SAIACC From SUBGA0

Local Integer I,IND, WTYP, WNBRLED
Local Char ABR(10) : ABR="GIC1"
Local Char WCOA(GLONCOA),WACC(GLONGAC),WSAC(GLONSAC),WACC(GLONGAC),SVGSAC(GLONSAC)
Call MSKABR("ACC"+num$(TYD),ABR) From SUBGASA
If GNBSTR>=1
 WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
 WNBRLED=0
 If WTYP>0
  For I=1 To TYD-1
   WSAC = evalue("[M:"+ABR+"]SAC"+num$(I)+"(NOL)")
   WCOA = evalue("[M:HAEF]COA("+num$(I-1)+")")
   If [F:GAC]COA<>WCOA or [F:GAC]ACCSHO<>WSAC
    Read [GAC]GAC1 = WCOA;WSAC
   Endif
   WACC = [F:GAC]ACC
   If WACC<>""
    If WCOA<>[F:GAC]COA
     If !find(WCOA,[F:GAC]OTHCOA(0..[F:GAC]COANBR-1)) & [F:GTE]AUZLED(WTYP-1)<>3 : mkstat = 1 : Break :  Endif
    Endif
   Else
    If I>1 : WNBRLED+=1 : Endif
   Endif
  Next
 Endif
 WCOA = [M:HAEF]COA(TYD-1)

 If WTYP<1 : mkstat = 1 : Endif
 If mkstat=1 : End : Endif

 # If the Target company does not have an Analytical entry then do not default the Analytical account as would be done in Call INIPRO below
 If VALEUR="" and TYD=2 and GTYPGEN=GTYPANA : mkstat=2 : End : Endif
 If VALEUR=""
  Call INIPRO(WCOA,WACC) From SUBGA1
  Call LEC_GAC(WACC,WCOA) From CPTLEC
  If [F:GAC]SAC=2 : VALEUR = [F:GAC]ACCSHO : Endif
 Elsif TYD>1
  SVGSAC = VALEUR
  VALEUR = ""
  Call UPDPRO(TYD,WCOA,VALEUR) From SUBGA1
  If mkstat = 2
   Call LEC_GAC(VALEUR,WCOA) From CPTLEC
   If [F:GAC]SAC=2
    VALEUR = [F:GAC]ACCSHO
   Else
    VALEUR = ""
   Endif
  Else
   VALEUR = SVGSAC
  Endif
 Endif
Endif

End

