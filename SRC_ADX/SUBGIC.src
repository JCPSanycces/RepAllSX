####################################################################################
# Code from SUBGA0 and we cannot do a call to SUBGA0 because of other variables not defined in this screen
Subprog AS_BPR(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Gosub SETNOL
Local Char WCOA(GLONCOA),WACC(GLONGAC),WSAC(GLONSAC)
Raz OK
For I=1 To [M:HAEF]NBRLED
 WCOA = [M:HAEF]COA(I-1)
 WACC = evalue("[M:GIC1]ACC"+num$(I)+"(NOL)")
 WSAC = evalue("[M:GIC1]SAC"+num$(I)+"(NOL)")
 If WACC<>""
  Call LEC_GAC(WACC,WCOA) From CPTLEC
  If [F:GAC]SAC=2 : OK=-1 : Break : Endif
 Else
  OK+=1
 Endif
Next
If OK<>[M:HAEF]NBRLED and OK>-1 : mkstat=1 : Endif
Gosub AFF_BPR From SUBGA0
End

Subprog C_BPR(VALEUR)
Variable Char    VALEUR()
 Call C_BPR(VALEUR) From SUBGA0
End

Subprog AP_BPR(VALEUR)
Variable Char     VALEUR
 Call AP_BPR(VALEUR) From SUBGA0
End

####################################################################################
Subprog D_DOCNUMLIN(VALEUR)
Variable Char    VALEUR()
Local Integer    CPYLINE, NEWNOL #109877.n
Gosub SETNOL
# Sets the line Document no. if the header company was already entered
If [M]DOCNUMLIN(NOL)=""

  #CPYLINE = find([M]CPYLIN(NOL),[M]CPYLIN(0..NOL-1),[M]CPYLIN(NOL+1..[M]NBLIG))#109877.o
  #109877.sn
  #CPYLINE (1) is used to check for existence [M]CPYLIN on the other lines and (2) is used as an index
  Raz CPYLINE
  Raz NEWNOL

  If NOL<>0
    NEWNOL =  find([F:FCY]LEGCPY,[M]CPYLIN(0..NOL-1))
  Endif

  If NEWNOL
    CPYLINE = NEWNOL
  Else
    NEWNOL = find([F:FCY]LEGCPY,[M]CPYLIN(NOL+1..[M]NBLIG))
    If NEWNOL
      CPYLINE = NEWNOL + NOL + 1
    Endif
  Endif
  #109877.en

  If CPYLINE
    VALEUR = [M]DOCNUMLIN(CPYLINE-1)
  Endif
Endif
End

Subprog AS_DOCNUMLIN(VALEUR)
Variable Char     VALEUR
Call LEC_GTE_LEG(GCURLEG,[M]TYPLIN(nolign-1)) From CPTLEC
# If the Line Type does not allow mannual numbers then skip this field
If [F:GTE]MANNUM<>2 : mkstat = 2 : End  :  Endif
End

# From SUBLO0; C_NUM
Subprog C_DOCNUMLIN(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
If VALEUR<>""
 If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif
 Look [HAE]HAE0 = [M]TYPLIN(NOL) ; VALEUR
 If !fstat
  GMESSAGE = mess(22,100,1) : # Already exists
  mkstat = 2
 Endif
Elsif [F:GTE]COU=""
  GMESSAGE = mess(532,177,1) : # Mandatory if Manual number is Yes and sequence counter is blank
  mkstat = 2
Endif
End

Subprog AM_DOCNUMLIN(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
# If there are any lines with the same Company as the then all of those lines must be updated
If [M]DOCNUMLIN <> VALEUR
  Local Integer I
  For I=0 To [M]NBLIG-1
    If I<>NOL and [M]CPYLIN(NOL) = [M]CPYLIN(I)
      [M]DOCNUMLIN(I) = VALEUR
      Affzo [M]DOCNUMLIN(I)
    Endif
  Next I
Endif
End

####################################################################################
# Code from SUBGA0 and we cannot do a call to SUBGA0 because of variables not on this screen
Subprog AS_DEB(VALEUR)
Variable Decimal VALEUR
Local Char ABR(10) : ABR="GIC1"
Local Char WCOA(GLONCOA),WSAC(GLONSAC),WACC(GLONGAC)
Gosub SETNOL
If [M]CDT(NOL)<>0
 mkstat = 1 : End
Endif
# Initialization
If !GIMPORT & VALEUR=0 & !varinit([M]CDT,NOL)
   For I=1 To [M:HAEF]NBRLED
    WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
    If WACC<>""
     WCOA = [M:HAEF]COA(I-1)
     Call LEC_GAC(WACC,WCOA) From CPTLEC
     Case [F:GAC]SNSDEF
      When 2 : mkstat = 2 : # Credit
      When 3 : If [M]TOTDEB-[M]TOTCDT>0 : mkstat=2  : Endif
     Endcase
     Break
    Endif
   Next
 If mkstat : End: Endif
Endif
Local Integer TYD : TYD=[M:HAEF]NBRLED
Gosub AVT_SAIACC From SUBGA0
End

