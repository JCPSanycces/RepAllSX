####################################################################################
Subprog AS_ACC1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto SAIACC
Subprog AS_ACC2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto SAIACC
Subprog AS_ACC3(VALEUR)
Variable Char    VALEUR()
TYD = 3 : Goto SAIACC
Subprog AS_ACC4(VALEUR)
Variable Char    VALEUR()
TYD = 4 : Goto SAIACC
Subprog AS_ACC5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto SAIACC
Subprog AS_ACC6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto SAIACC
Subprog AS_ACC7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto SAIACC
Subprog AS_ACC8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto SAIACC
Subprog AS_ACC9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto SAIACC
Subprog AS_ACC10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : Goto SAIACC

$SAIACC
Local Char ABR(10) : ABR="GIC1"
# Cannot use the call to SUBGA0 because of fields accessed that are not part of this screen
# Per the PRD ONLY the MAIN and ANA General ledger accounts are entered
If GIMPORT & TYD>1 : mkstat=2 : End : Endif
Gosub SETNOL
# Intercompany enhancement to reset the global variables
If GCURINTCPY <> [M]CPYLIN(NOL)
  Call RESET_INTCPYCOA ([M]CPYLIN(NOL),[M]FCYLIN(NOL)) From INTCPYLIB
Endif
Local Integer I,IND, WTYP, WNBRLED
Local Char WLED(GLONLED),WCOA(GLONCOA),WSAC(GLONSAC),WCUR(GLONCUR),WACC(GLONGAC),SVGACC(GLONGAC)
WSAC = evalue("[M:GIC1]SAC"+num$(TYD)+"(NOL)")
If WSAC<>"" & !find(status,5,31,75) : mkstat = 2 : End : Endif
WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
Call CONTPER([M]ACCDAT,WTYP,[M]FCYLIN(nolign-1)) From CPTSUB
If mkstat=2
  If WSAC<>""
    Assign "[M:GIC1]SAC"+num$(TYD)+"(NOL)" With ""
  Endif
  mkstat=1 : Raz GMESSAGE : End
Endif
Gosub AVT_SAIACC From SUBGA0

If GNBSTR>=1
 WCOA = [M:HAEF]COA(TYD-1)
 WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
 WNBRLED=0
 If WTYP>0
  For I=1 To TYD-1
   WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
   If WACC<>""
    Call LEC_GAC(WACC,evalue("[M:HAEF]COA("+num$(I-1)+")")) From CPTLEC
    If WCOA<>[F:GAC]COA
     If !find(WCOA,[F:GAC]OTHCOA(0..[F:GAC]COANBR-1)) & [F:GTE]AUZLED(WTYP-1)<>3 : mkstat = 1 : Break :  Endif
    Endif
   Else
    If I>1 : WNBRLED+=1 : Endif
   Endif
  Next
 Endif
 If WTYP<1 : mkstat = 1 : Endif
 If mkstat=1 : End : Endif
 # If the Target company does not have an Analytical entry then do not default the Analytical account as would be done in Call INIPRO below
 If VALEUR="" and TYD=2 and GTYPGEN=GTYPANA : mkstat=2 : End : Endif
 If VALEUR=""
  Call INIPRO(WCOA,VALEUR) From SUBGA1
  If VALEUR<>""
   Call LEC_GAC(VALEUR,WCOA) From CPTLEC
   If [F:GAC]SAC=2
    Assign "[M:GIC1]SAC"+num$(TYD)+"(NOL)" With [F:GAC]ACCSHO
   Else
    Assign "[M:GIC1]SAC"+num$(TYD)+"(NOL)" With ""
   Endif
  Endif
 Elsif TYD>1
  SVGACC = VALEUR
  VALEUR = ""
  Call UPDPRO(TYD,WCOA,VALEUR) From SUBGA1
  If mkstat = 2
   Call LEC_GAC(VALEUR,WCOA) From CPTLEC
   If [F:GAC]SAC=2
    Assign "[M:GIC1]SAC"+num$(TYD)+"(NOL)" With [F:GAC]ACCSHO
   Else
    Assign "[M:GIC1]SAC"+num$(TYD)+"(NOL)" With ""
   Endif
  Else
   VALEUR = SVGACC
  Endif
 Endif
Endif

If VALEUR<>"" : Gosub AFF_ACC From SUBGA0 : Endif

End

####################################################################################
Subprog C_ACC1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto CONTACC
Subprog C_ACC2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto CONTACC
Subprog C_ACC3(VALEUR)
Variable Char    VALEUR()
TYD = 3 : Goto CONTACC
Subprog C_ACC4(VALEUR)
Variable Char    VALEUR()
TYD = 4 : Goto CONTACC
Subprog C_ACC5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto CONTACC
Subprog C_ACC6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto CONTACC
Subprog C_ACC7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto CONTACC
Subprog C_ACC8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto CONTACC
Subprog C_ACC9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto CONTACC
Subprog C_ACC10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : Goto CONTACC

$CONTACC
# Code from SUBGA0 and we cannot do the call below because of other mask variables not in this screen
Local Integer     I, OK
Local Libelle     FLG, BPRNSAI
Local Char        CPT(GLONGAC)
If clalev([F:JCO])=0  : Local File GJOUCOA     [JCO] : Endif
Gosub SETNOL
Local Char WLED(GLONLED),WCOA(GLONCOA),WSAC(GLONSAC),WACC(GLONGAC),WCUR(GLONCUR),CURSAI(GLONCUR)
WSAC = evalue("[M:GIC1]SAC"+num$(TYD)+"(NOL)")
Assign "[M:GIC1]ACC"+num$(TYD)+"(NOL)" With VALEUR
If GCOMPTA<>3
   WCOA = [M:HAEF]COA(TYD-1)
   If FLG=1
    BPRNSAI=1
    Raz OK, FLG
    If !OK : # Last possible account
     OK = 0
     For I=1 To TYD-1
      WACC = evalue("[M:GIC1]ACC"+num$(I)+"(NOL)")
      If WACC<>"" : OK = 1 : Break : Endif
     Next
     If !OK & VALEUR=""
      GMESSAGE = mess(115,106,1)
      mkstat = 2 : End
     Endif
    Endif
   Endif
   If VALEUR=""
    If !BPRNSAI : Assign "[M:GIC1]SAC"+num$(TYD)+"(NOL)" With "" : Endif
   Endif
   # Initialize account
   If VALEUR=""
    For I=1 To [M:HAEF]NBRLED
      WACC = evalue("[M:GIC1]ACC"+num$(I)+"(NOL)")
      If WACC<>"" : Break : Endif
    Next
    If !BPRNSAI & [M:HAEF]NBRLED=I-1 and evalue("[M:GIC1]BPR("+num$(NOL)+")")="" : End : Endif
   Endif
Endif
If VALEUR<>""
 CPT = VALEUR
 # Reporting criteria reference : useful fo Sales and Curreny buttons
 If dim(GLEDREF)>0 & GLEDREF=0
   GLEDREF=[M:HAEF]LEDTYP(TYD-1)
 Endif
 # Find the code
 Call LEC_JCO_LEG(GCURLEG,[L]WCOA,[F:JOU]JOU) From CPTLEC
 If GCOMPTA<>3 : I = find(CPT,[F:JCO]FRQCOD(0..[F:JCO]FRQNBR-1)) : Endif
 If I
  # Call Journal
  CPT = [F:JCO]FRQACC(I-1)
 Else
  # Call Account
  Read [GAC]GAC1 = WCOA;CPT
  If !fstat : CPT = [F:GAC]ACC : Endif
 Endif
 Read [GAC]GAC0 >= WCOA;CPT
 If fstat>2 | left$([F:GAC]ACC,len(CPT))<>CPT
  GMESSAGE = CPT-mess(38,106,1)
  mkstat = 2 : End
 Endif
 If [F:GAC]ENAFLG<>2
  GMESSAGE = mess(2,126,1)
  mkstat = 2 : End
 Endif
 If BPRNSAI & [F:GAC]SAC=2
  GMESSAGE = mess(19,104,1) : mkstat = 2 : End
 Endif
Else
 Raz [F:GAC]
Endif

If [F:GAC]SAC=2
 Assign "[M:GIC1]SAC"+num$(TYD)+"(NOL)" With [F:GAC]ACCSHO
Else
 Assign "[M:GIC1]SAC"+num$(TYD)+"(NOL)" With ""
Endif
Assign "[M:GIC1]ACC"+num$(TYD)+"(NOL)" With [F:GAC]ACC
VALEUR = [F:GAC]ACC
Gosub AVT_SAIACC From SUBGA0
[L]CURSAI=[M]CUR
Call CONTACC([F:GAC]ACC,[M:HAEF]LEDTYP(TYD-1),[M:HAEF]LED(TYD-1),[M]FCYLIN(NOL),[L]CURSAI,[M]ACCDAT) From SUBGA1
If mkstat : End : Endif
# Standard checking includes if the account classification type = Exceptional (TYP=2) then do not allow the account
End

