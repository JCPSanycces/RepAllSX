AXE = 17 : Goto DEFCCE
Subprog D_CCE18(VALEUR)
Variable Char    VALEUR()
AXE = 18 : Goto DEFCCE
Subprog D_CCE19(VALEUR)
Variable Char    VALEUR()
AXE = 19 : Goto DEFCCE
Subprog D_CCE20(VALEUR)
Variable Char    VALEUR()
AXE = 20 : Goto DEFCCE


# Code from SUBGA0 and we cannot do a call to SUBGA0 because of the call LEC_GDE and INICCE using GDE
$DEFCCE
Gosub SETNOL
If AXE>[M:HAEF]NBRAXI : End : Endif
If [M]DSP(NOL)<>"" : mkstat=1 : End : Endif
If VALEUR<>""
 Call ="AS_CCE"+num$(AXE) With VALEUR From SUBGIC
 If mkstat
  Raz VALEUR, mkstat
 Else
  End
 Endif
Endif

If !clalev([F:GAC2]) : Local File =GTABCPT+"GACCOUNT"     [GAC2] : Endif
Local Char WACC(GLONGAC), WCOA(GLONCOA), CRIBLE(30)
Local Integer NB,I
Local Integer TYD : TYD=[M:HAEF]NBRLED
Gosub AVT_SAIACC From SUBGA0
NB=1
While NB<=GNBSTR
 If GSTRACC(NB)<>""
  # For the default dimension code we are using blanks because we do not have [F:GDE]CDE
  Call INICCE(VALEUR,[M:HAEF]DIE(AXE-1),GSTRLED(NB),GSTRACC(NB),"") From CPTINI
  If VALEUR<>"" : Raz mkstat : Break : Endif
  If [F:GAC2]COA<>GSTRCOA(NB) | [F:GAC2]ACC<>GSTRACC(NB) :
   Read [GAC2]GAC0 = GSTRCOA(NB);GSTRACC(NB)
  Endif
  For I=0 To [F:GAC2]COANBR-1
   WCOA = [F:GAC2]OTHCOA(I)
   If !find(WCOA,GSTRCOA(1..GNBSTR)) & find(WCOA,GPLAN(1..10))
    Call INIACC(GSTRCOA(NB),GSTRACC(NB),WCOA,WACC,CRIBLE) From CPTINI
    If WACC<>""
     # For the default dimension code we are using blanks because we do not have [F:GDE]CDE
     Call INICCE(VALEUR,[M:HAEF]DIE(AXE-1),WCOA,WACC,"") From CPTINI
     If VALEUR<>"" : Raz mkstat : Break 2 : Endif
     GNBSTR+=1 :  GSTRCOA(GNBSTR)=WCOA :  GSTRACC(GNBSTR) = WACC
     J=find(WCOA,GPLAN(1..10)) : GSTRTYP(GNBSTR) = GTYPLED(J) : GSTRLED(GNBSTR) = GCODLED(J) : GSTRIDT(GNBSTR) = GSTRIDT(NB)
    Endif
   Endif
  Next
 Endif
 NB+=1
Wend

# Default the Dimension from the previous line if the companies are the same
If VALEUR="" & NOL>0 & [M]CPYLIN(NOL)=[M]CPYLIN(NOL-1)
 VALEUR = evalue("[M]CCE"+num$(AXE)+"("+num$(NOL-1)+")")
Endif

End

