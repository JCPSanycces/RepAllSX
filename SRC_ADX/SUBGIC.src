Subprog AM_ACC1(VALEUR)
Value Char    VALEUR()
TYD = 1 : Goto MODACC
Subprog AM_ACC2(VALEUR)
Value Char    VALEUR()
TYD = 2 : Goto MODACC
Subprog AM_ACC3(VALEUR)
Value Char    VALEUR()
TYD = 3 : Goto MODACC
