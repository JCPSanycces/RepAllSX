# Code from SUBGA0 and we cannot do a call to SUBGA0 because of variables not on this screen; [M]STA (1=temp,2=final)
Subprog AS_QTY(VALEUR)
Variable Decimal VALEUR
Local Char ABR(10) : ABR="GIC1"
Local Char WLED(GLONLED),WCOA(GLONCOA),WACC(GLONGAC),WCUR(GLONCUR)
Local Integer I,IND, TYD, WTYP
Gosub SETNOL
mkstat = 1
  For TYD=1 To [M:HAEF]NBRLED
   WACC = evalue("[M:"+ABR+"]ACC"+num$(TYD)+"(NOL)")
   If WACC<>""
    WCOA = [M:HAEF]COA(TYD-1)
    Call LEC_GAC(WACC,WCOA) From CPTLEC
    If [F:GAC]FLGUOM=2 : Raz mkstat : Break : Endif
   Endif
  Next
If mkstat : End : Endif
Call AROQTE(VALEUR,[F:GAC]UOM) From CPTINI
End

