Subprog D_DSP(VALEUR)
Variable Char    VALEUR()
Call D_DSP(VALEUR) From SUBGA0
End

# Code from SUBGA0 and we cannot do a call to SUBGA0 because of variables not on this screen; [M]STA (1=temp,2=final)
Subprog AS_DSP(VALEUR)
Variable Char    VALEUR()
Local Char WLED(GLONLED),WCOA(GLONCOA),WACC(GLONGAC),WCUR(GLONCUR)
Local Integer I,IND, TYD, WTYP
Gosub SETNOL
mkstat = 1
  For TYD=1 To [M:HAEF]NBRLED
   WLED = evalue("[M:HAEF]LED("+num$(TYD-1)+")")
   WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
   Call INDLED(WLED,"",IND,I) From CPTDIV
   If GLEDFLGANA(IND)=2 : Raz mkstat : Break : Endif
  Next
If mkstat=2 : End : Endif
Raz mkstat
Gosub AVT_SAIDSP From SUBGA0
If [M]ACCDSP="" : mkstat=1 : End : Endif
Gosub AFF_DSP From SUBGA0
End

#Subprog C_DSP(VALEUR)
#Variable Char    VALEUR()
#Call C_DSP(VALEUR) From SUBGA0
#End
# Code from SUBGA0 and we cannot do a call to SUBGA0 because of variables not on this screen; [M:HAE1]
Subprog C_DSP(VALEUR)
Variable Char     VALEUR
Local Char    BID(20)
Local Integer I, OK
Gosub SETNOL
#CHECK IGNORE_BEGIN
If VALEUR=""
 If dim([M:GIC1]DSP)>0
  If [M:GIC1]PTF(NOL)<>0 : VALEUR="$" : Endif
 Endif
Endif
#CHECK IGNORE_END
Case VALEUR
 When ""
  End
 When "$"
  If !GIMPORT
   OK  = 1
   OK *= [M]DEB(NOL)+[M]CDT(NOL)=sum([M:VT2]TBAMT([M]PTV(NOL)..[M]PTF(NOL)))
   OK *= [M]QTY(NOL)=sum([M:VT2]TBQTY([M]PTV(NOL)..[M]PTF(NOL)))
   If !OK
    GMESSAGE = mess(28,106,1)
    mkstat = 2 : End
   Endif
   Gosub RAZCCE From SUBGA0
  Endif
 When Default
  Call CONTDSP(VALEUR,[M]FCYLIN(NOL),[M]ACCDAT) From SUBGA1
  If mkstat : End : Endif
  [M:VTL]TOTREP = [M]DEB(NOL)+[M]CDT(NOL)
  Call CHARGE_VTE_STR(VALEUR,[M]UOM(NOL),[M]LEDDSP,[M]ACCDSP,"") From VENTILE
  Call CONTVENT([M]FCYLIN(NOL),[M]ACCDAT) From SAIVENTILE
  If mkstat : End : Endif
 [M]PTV(NOL) = 0 : [M]PTF(NOL) = 0
 Gosub RAZCCE From SUBGA0
Endcase
End

Subprog AP_DSP(VALEUR)
Variable Char    VALEUR()
Call AP_DSP(VALEUR) From SUBGA0
End

