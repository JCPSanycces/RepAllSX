####################################################################################
Subprog D_TAX(VALEUR)
Variable Char    VALEUR()
Local Char ABR(10) : ABR="GIC1"
# Intercompany enhancement - reset variables if click from another line into this field
Gosub SETNOL
If GCURINTCPY <> [M]CPYLIN(NOL)
  Call RESET_INTCPYCOA ([M]CPYLIN(NOL),[M]FCYLIN(NOL)) From INTCPYLIB
Endif
Call D_TAX(VALEUR) From SUBGA0
End

# Code from SUBGA0 and we cannot do a call to SUBGA0 because of variables not on this screen; GDE:FLGLOT
Subprog AS_TAX(VALEUR)
Variable Char    VALEUR()
If !clalev([F:COA])  : Local File =GTABCPT+"GCOA"       [COA] : Endif
Local Char WCOA(GLONCOA),WACC(GLONGAC)
Local Integer I
Local Char ABR(10) : ABR="GIC1"
Gosub SETNOL
# Intercompany enhancement - reset variables if click from another line into this field
If GCURINTCPY <> [M]CPYLIN(NOL)
  Call RESET_INTCPYCOA ([M]CPYLIN(NOL),[M]FCYLIN(NOL)) From INTCPYLIB
Endif
mkstat = 1
  For I=1 To [M:HAEF]NBRLED
   WCOA = [M:HAEF]COA(I-1)
   If WCOA<>""
    Call LEC_COA(WCOA) From CPTLEC
    If [F:COA]TAXMGT = 2 :
     WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
     Call LEC_GAC(WACC,WCOA) From CPTLEC
     If [F:GAC]FLGVAT>1 : Raz mkstat : Break : Endif
    Endif
   Endif
  Next
If mkstat : End : Endif
End

Subprog C_TAX(VALEUR)
Variable Char    VALEUR()
Call C_TAX(VALEUR) From SUBGA0
End

