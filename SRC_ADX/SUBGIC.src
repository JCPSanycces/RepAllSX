#<AdxTL>@(#)3.0.0.0 $Revision$
# Mask Management GACCINTCPY
######################################################################################
## Section automatically added (screen GACCINTCPY) 06/10/2013 20:59:20 (BESPR)
######################################################################################
#    Process Name:    SUBGIC - Intercompany journal entry  SAM #88747
#
#    Authors:         BeSpr   Jun-Jul, 2013
#
#    Modifications:
#                     BeSpr   Jun xx, 2013   xxxx
######################################################################################
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "STATUT"      : Gosub STATUT
 When "VERF_ANU"    : Gosub VERF_ANU
 When "VERF_CHG"    : Gosub VERF_CHG
 When "ANNULE"      : Gosub ANNULE
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "VERIF_CRE"   : Gosub VERIF
 When "VERIF_MOD"   : Gosub VERIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "AVANT_SUITE" : Gosub AVANT_SUITE
 When "ABANDON"     : Gosub ABANDON
 When "FERME"       : Gosub FERME
 When Default
Endcase
Return

####################################################################################
$OUVRE
If clalev([M:VTL])  = 0 : Local Mask VENTILE  [VTL]  : Endif
If clalev([M:VT2])  = 0 : Local Mask VENTILE2 [VT2]  : Endif
Gosub SETMASK From GOBJET
Local Integer MAXLIG , MAXVTL
MAXLIG = dim([M:GIC1]SAC1)
MAXVTL = dim([M:VTL]AMT)

# Screens of working
Local Mask GACCENTFMT  [HAEF]        # Openning of screen for miscellaneous informations
Local Mask SAICURLED   [SCL]         # Openning of screen for management of currencies

If clalev([F:CPY]) = 0  : Local File  COMPANY   [CPY]  : Endif
If clalev([F:GCM]) = 0  : Local File  GACM      [GCM]  : Endif
If clalev([F:LED]) = 0  : Local File  GLED      [LED]  : Endif
If clalev([F:COA]) = 0  : Local File  GCOA      [COA]  : Endif
If clalev([F:GAC]) = 0  : Local File  GACCOUNT  [GAC]  : Endif

# Management of currency rates
Local Char    DEVORG(GLONCUR), DEVDES(GLONCUR)
Local Char    TBCUR(GLONCUR)(1..4), MESSA(255)
Local Decimal MONTANT
Local Decimal COURS
Local Char    AFF_TBCUR(GLONCUR)(1..10)  # Currencies totals : currency displayed
Local Integer AFF_TBLED(1..10)           # Currencies totals : ledger displayed
Local Integer NBCUR, CONSCUR
Local Integer NLIG
Local Char    LOTCPT(GLONANM)

Local Char    ABR(10)    : ABR="GIC1"

# Global variables
# Data structure "manual/propaged" (Type of Ledger, ledger, account...)
Global Integer GNBSTR
Global Integer GCHKCPYLIN #109877.n
Global Integer GSTRTYP(1..MAXLIG)
Global Char    GSTRIDT(5)(1..MAXLIG)
Global Char    GSTRLED(GLONLED)(1..MAXLIG)
Global Char    GSTRCOA(GLONCOA)(1..MAXLIG)
Global Char    GSTRACC(GLONGAC)(1..MAXLIG)

# Useful BP... Data stucture linked of to the Account Core Model
Global Integer GNBPLAN                               : # Number of plans / charts
Global Integer GNBAXE                                : # Number of dimensions (max 20)
Global Char    GAXE(GLONDIE)(1..max(GOPTCANA,20))    : # Axes (DIE)
Global Integer GOBLIG(1..max(GOPTCANA,20))           : # Required?

Global Integer GNBTYPLED                             : # Number of ledger for the company
Global Integer GTYPLED(1..10)                        : # Types of ledger linked to the company
Global Char    GCODLED(GLONLED)(1..10)               : # Ledger  (LED)
Global Char    GPLAN(GLONCOA)(1..10)                 : # Chart of Account (COA)

Gosub INTCPY_OUVRE From INTCPYLIB : ##### BESPR 87307 05/14/2013 # Intercompany enhancement
Gosub GL_INTCPY_OUVRE From INTCPYLIB


$DECLARE_B
Local Integer I,J,K,IND,INDAXE,AXE,STAT,WSAI,WOK,INDLIN,AXI
Local Integer NBLED, WLEDTYP    # Management of ledger by Journal entry transaction (Column or Row)
Local Integer AUT, TYPREF, ORITYP, WTYP
Local Char    WLED(GLONLED)
Local Integer ACCFCY
Local Char    AUZFCY(15)
Local Char    VALC1(20), VALC2(20), VALC3(20)

If dim(MESSA)<=0 : Local Char MESSA(255) : Endif

Local Integer CAS               # Ledger type 1=Customer, 2=Supplier, 3 or 0=GL Journal
Local Integer INDLED            # Ledger
Local Integer INDGCM            # Indice of Account Core Model to read Global variable
Local Char    CRIBLE(30)        # Account screening / Crible du compte
Local Integer NBLIN             # Number of lines "manual/propagated"

Local Integer PEROK
Local Decimal EXERCICE, PERIODE # Management fiscalyear and fiscal period

Local Char    WACC(GLONGAC)     # Account generated
Local Char    WSAC(GLONSAC)     # Collective generated
Local Char    WCOA(GLONCOA)     # Chart of Account generated
Local Char    WDIE(GLONDIE)     # Dimention Type  (variable of work for "inter site" management & "Roudind variance" management)
Local Char    WCCE(GLONCCE)     # Dimention       (variable of work for "inter site" management & "Roudind variance" management)
Local Char    WCCEDEF(GLONCCE)
Local Char    WSOC(GLONCPY)     # Journal Company
Local Char    WCUR(GLONCPY)     # Journal Currency / Devise de transaction
Local Integer AFF               # Variable to refresh the lines'screen

# Management of common fields in Column entry
Local Integer NOL
Local Integer OKTCA

$DECLARE_C
# Management of analytics records
Local Integer INDANA
Local Decimal TMPLED(dim([M:VT2]TBAMT)),COURS, AROLED
Local Decimal TMPAMT(dim([M:VT2]TBAMT))
Local Decimal TOTANA

Return

####################################################################################
$FERME
GTUNCPT(5) = 0
Gosub INTCPY_FERME From INTCPYLIB
Gosub GL_INTCPY_FERME From INTCPYLIB

Return

####################################################################################
$LIENS

Gosub SETMSK

Call RESET_CPY_PARAMS([F:GIC]CPY,[F:GIC]FCY)
Call RESET_COMPANY([F:GIC]CPY,[F:GIC]FCY,[F:GIC]JOU,[F:GIC]TYP,[F:GIC]CUR)

Raz nolign, [M:VTL], [M:VT2], K

Raz [M:GIC1]
[M] = [F:GIC]

# Initialization (the errors messages linked to STAT are treated under the label $DROIT)
If !GIMPORT
 Call INIMSKFMT([F:GIC]FCY,[F:GIC]TYP,[F:GIC]ACCDAT,STAT)  From SUBGICA
 If STAT
  GMESSAGE=""
  Gosub MESSAGE From CPTAUTO
  GERR = 1 : CLECUR  = 0  : Return
 Endif
Else
 Call INIMSKFMT([F:GIC]FCY,[F:GIC]TYP,[F:GIC]ACCDAT,STAT)  From SUBGICA
 For I=1 To [M:HAEF]NBRLED
   Assign "[M:GIC1]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
 Next
Endif

For [GID]GID0 Where NUM=[F:GIC]NUM
  nolign += 1
  [M] = [F:GID]

  # We need to re-set the global variables to the target company
  If GCURINTCPY <> [M]CPYLIN(nolign-1)
    Call RESET_INTCPYCOA ([M]CPYLIN(nolign-1),[M]FCYLIN(nolign-1)) From INTCPYLIB
  Endif

  # The screen (HAEF) stores everything in ACC1 or ACC2 but the tables need to be stored by ledger ACC(ledger)
  # Main general
  If [F:GID]LEDTYP(0) > 0
    Assign "[M]COA1("+num$(nolign-1)+")"  With [F:GID]COA([F:GID]LEDTYP(0)-1)
    Assign "[M]ACC1("+num$(nolign-1)+")"  With [F:GID]ACC([F:GID]LEDTYP(0)-1)
    Assign "[M]SAC1("+num$(nolign-1)+")"  With [F:GID]SAC([F:GID]LEDTYP(0)-1)
  Endif
  # Main analytical
  If [F:GID]LEDTYP(1) > 0 and [F:GID]LEDTYP(0) <> [F:GID]LEDTYP(1)
    Assign "[M]COA2("+num$(nolign-1)+")"  With [F:GID]COA([F:GID]LEDTYP(1)-1)
    Assign "[M]ACC2("+num$(nolign-1)+")"  With [F:GID]ACC([F:GID]LEDTYP(1)-1)
    Assign "[M]SAC2("+num$(nolign-1)+")"  With [F:GID]SAC([F:GID]LEDTYP(1)-1)
  Endif
  # [M]RATDIV(ledger)/[M]RATMLT(ledger) and [M:HAEF]RATDIVC(ledger)/[M:HAEF]RATMLTC(ledger) are stored in [F:GIC]RATDIV(ledger) and [F:GIC]RATMLT(ledger)
  # [M:HAEF]RATDIV#(line)/[M:HAEF]RATMLT#(line) are stored in [F:GID]RATDIV(#ledger) and [F:GID]RATMLT(#ledger)
  # However, if the target company currency <> source currency then currency rates are entered by line
  If [F:GIC]CUR<>[M]CURAFF and [M]CURAFF<>""
   Call LEC_GTE_LEG(GCURLEG,[F:GIC]TYP) From CPTLEC
   If [F:GIC]RATDIV(GTYPGEN-1)>0 : COURS =  [F:GIC]RATMLT(GTYPGEN-1)/[F:GIC]RATDIV(GTYPGEN-1) : Endif
   Call CONVERT3([F:GIC]CUR,[M]CURAFF,[M]CURAFF,[F:GTE]TYPRAT,[F:GIC]RATDAT,
&                [F:GID]AMTCUR,MONTANT,COURS,STAT) From CPTSUB
  Else
   MONTANT = [F:GID]AMTCUR
  Endif
  If STAT : MONTANT=0 : Endif
  If [F:GID]SNS=1
   [M]DEB(nolign-1) = [F:GID]AMTCUR
   [M]TOTDEB += MONTANT
  Else
   [M]CDT(nolign-1) = [F:GID]AMTCUR
   [M]TOTCDT += MONTANT
  Endif

  # Forced initialization to empty ... otherwise the label D_ are made
  If varinit([M]CCE1,nolign-1)=0
   For AXE=1 To 20
    Assign "[M]CCE"+num$(AXE)+"("+num$(nolign-1)+")" With ""
   Next AXE
  Endif

  If [F:GID]DSP=""
   OK = 0
   For [F:GIA]GIA0 Where NUM=[F:GID]NUM & LIN=[F:GID]LIN
    K += 1
    If !OK : OK = K : Endif
      [M:VT2]TBAMT(K) = [F:GIA]AMTCUR
      [M:VT2]TBQTY(K) = [F:GIA]QTY
    For I=1 To dim([F:GIA]CCE)-1
      Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")" With [F:GIA]CCE(I-1)
    Next I
   Next
   If OK
    If OK=K
     For I=1 To dim([F:GIA]CCE)-1
      Assign "[M]CCE"+num$(I)+"("+num$(nolign-1)+")"
&     With   evalue("[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")")
      Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")" With ""
     Next I
     K -= 1
    Else
     [M]PTV(nolign-1) = OK
     [M]PTF(nolign-1) = K
     [M]DSP(nolign-1) = "$"
    Endif
   Endif
  Endif

  # Needs to be for all ledgers not just those entered [M:HAEF]NBRLED
  For I=1 To len(mess(0,2644,1))
   Assign "[M]RATDIV"+num$(I)+"("+num$(nolign-1)+")" With [F:GID]RATDIV(I-1)
   Assign "[M]RATMLT"+num$(I)+"("+num$(nolign-1)+")" With [F:GID]RATMLT(I-1)
  Next

Next

# Intercompany enhancement Re-initialization of the Global Variables
# In case the last CPYLIN <> CPY then the global variables are not correct
Call RESET_INTCPYCOA([M]CPY,[M]FCY) From INTCPYLIB

[M:VT2]PTVENT = K+1
[M]NBLIG = nolign
[M]CURAFF = [M]CUR : [M]CURAFF2 = [M]CUR

If !GIMPORT
 Gosub CHARG_ZONES_DEV From SUBGIC
Endif

Return

####################################################################################
$SETBOUT
If [M]FLGPST=3 or REP<>"" or CLECUR=0 or !VERROU
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif

#109558.sn
#Remove delete button if status is posted
If [M]FLGPST=3
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
#109558.en

If CLECUR
 Call DROITSITE([M]FCY,[L]AUZFCY,[L]ACCFCY) From CPTSUB
 If ![L]ACCFCY | !instr(1,[L]AUZFCY,"V")
  Call VIREBOUT(CHAINE,"V") From GOBJET
 Endif
 If [M]FLGPST=3
  Call VIREBOUT(CHAINE,"M") From GOBJET
 Endif
 If [M]FLGPST>1
  CHMEN += "1"
 Endif
Endif

Raz GMESSAGE
Return


####################################################################################
$EXEBOUT
Case REP
 When "V"
  Gosub OUVRE From ="WO"+ABREV
  Gosub RELIT From GOBJSUB
Endcase
Return


####################################################################################
$AVANTBOUT
Case BOUT
 When "1" : SAVCONS=GCONSULT
Endcase
Return


####################################################################################
$STATUT
Case BOUT
 When "1" : GCONSULT=SAVCONS
Endcase
Return


####################################################################################
$AVANT_SUITE
If BOUT="1"
 Gosub AVANT_SUITE From GICVAL
Endif
Return


####################################################################################
$VERF_CHG
$VERF_ANU
# User presses DELETE and before transaction start and after standard controls
If !clalev([F:GIC]) : Local File GACCINTCPY [GIC] : Endif
If !clalev([F:GID]) : Local File GACCINTCPYD [GID] : Endif
If !clalev([F:GIA]) : Local File GACCINTCPYA [GIA] : Endif

Return

####################################################################################
$ANNULE
# Before delete statement and after VERF_ANU

Delete [GID] Where NUM=[F:GIC]NUM
If fstat=1 : GOK=-1 : GLOCK="$GACCINTCPYD"-[F:GIC]NUM : Return
Elsif fstat : GOK=0 : Call RSTA("GID",[F:GIC]NUM) From GLOCK : Return
Endif

Delete [GIA] Where NUM=[F:GIC]NUM
If fstat=1 : GOK=-1 : GLOCK="$GACCINTCPYA"-[F:GIC]NUM : Return
Elsif fstat : GOK=0 : Call RSTA("GIA",[F:GIC]NUM) From GLOCK : Return
Endif

Call UPD_INTCOFLO(3,3,[F:GIC]NUM,[F:GIC]NBRCPY) From INTCPYLIB2
If GOK<1 : Return : Endif

Return

####################################################################################
$RAZCRE
# User clicks the New button.  Fields are erased and before field entry.
Raz [M]FLGPST
Raz [M:VTL]
If [M]TYP="" : Raz [M:VT2] : Endif
Gosub DEVSOC From SUBGAS
Gosub GRISE_CLE

Return

####################################################################################
$RAZDUP
# User modified the key.  Screens are reset (erased) and before user entry.
Raz [M]FLGPST
Gosub SETMSK
Gosub DEVSOC From SUBGAS
Raz [M]NUM
Gosub GRISE_CLE
Affzo DEB, CDT
Raz [M]DOCNUMLIN : Affzo [M]DOCNUMLIN

Return

####################################################################################
$GRISE_CLE
Gosub GRISE_CLE From =WINPROG

Return

####################################################################################
$VERF_CRE
# User modified screen fields and presses CREATE button, called before transaction started
$VERF_MOD
# User presses SAVE button, called before transaction started
$VERIF

If [M]NBLIG=0
 GMESSAGE = mess(17,106,1) : # There is no line entered
 OK = 0 : Return
Endif
If [M]SOLDE<>0
 GMESSAGE = mess(16,106,1) : # Unbalanced journal
 OK = 0 : Return
Endif

# Issue X3-58865 - 2017-10-18 by VAVIL : Control GESGIC function for POR legislation
# Issue X3-58865
Local Integer I
Local Char LASTCPY : [L]LASTCPY = ""
For I=0 To [M]NBLIG-1
  If [L]LASTCPY <> [M]CPYLIN(I)
    If func PORLEGLIB.DIGSIGN("",[M]CPYLIN(I))
      If !func PORLEGLIB.CREGASOK([M]JOULIN(I),"",GMESSAGE)
        OK  = 0  : Break
      Endif
    Endif
  Endif
  [L]LASTCPY = [M]CPYLIN(I)
Next I
If OK = 0 : Return : Endif
# End issue X3-58865

Return

####################################################################################
$INICRE
# NEW button pressed; After [F] class is populated with data BEFORE rewrite statement
# Sequence counter is 'INTCO' and set up in Sequence assignments, line type seq counter is used for posting
# From SUBLOT; INICRE
LOTCPT = ""
Call GETSOC([M]FCY) From DEVSUB
Call LECTCA(2,OKTCA) From SUBTCA
If OKTCA : LOTCPT = [F:TCA]CODNUM(14) : Endif
If LOTCPT="" : LOTCPT = "INTCO" : Endif
Call NUMERO(LOTCPT,[M]FCY,[M]ACCDAT,"",[F:GIC]NUM,STAT) From SUBANM
If GOK<1 | STAT
 GOK =0
 If STAT
  # Problem recovering the sequence number
  Gosub MESSAGE From SUBANM
  GMESSAGE=mess(60,199,1)-"("+LOTCPT+") : "+MESSA
 Endif
 Return
Endif
[M]NUM = [F:GIC]NUM
If dim([M:GIC1]NUM)>0 : Affzo [GIC1]NUM : Endif

# In SUBGAS there is NO return here it goes into INIMOD

####################################################################################
$INIMOD
# SAVE button pressed; After [F] class is populated with data BEFORE rewrite statement
# Lines set to zero prohibited
If dim(GSIVNULL)>0 & GSIVNULL=2
 If sum([M]CDT)=0 & sum([M]DEB)=0 & sigma(0,[M]NBLIG-1,abs([M]CDT(indcum)))=0 & sigma(0,[M]NBLIG-1,abs([M]DEB(indcum)))=0
   GMESSAGE = mess(91,106,1)
   GERR=1 : GOK=0
   zonsui = "NBLIG"
   Return
 Endif
Endif
# At least one line company (target) must be the same as the source company per Pascale August 21, 2013
If !find([M]CPY,[M]CPYLIN(0..[M]NBLIG))
  GMESSAGE = mess(145,7780,1)
  GERR=1 : GOK=0
  zonsui = "NBLIG"
  Return
Else
  TMPCPYLIN = find([M]CPY,[M]CPYLIN(0..[M]NBLIG))
  Call LEC_GTE_LEG(GCURLEG,[M]TYPLIN(TMPCPYLIN-1)) From CPTLEC
  # Also check to see if the TYP has been changed to Manual Mandatory and no document numbers have been entered per Christine August 23, 2013
  If [F:GTE]MANNUM=2 and [F:GTE]COU="" and [M]DOCNUMLIN(TMPCPYLIN-1)=""
    GMESSAGE = mess(47,106,1)-num$(TMPCPYLIN)+"\"+mess(64,182,1)+"\"+mess(532,177,1)
    GERR=1 : GOK=0
    zonsui = "NBLIG"
    Return
  Endif
Endif
# At least one line company (target) must be different than the source company per Pascale August 21, 2013
Local Integer I, TARGETOK, MANUALOK
For I=0 To [M]NBLIG-1
  If [M]CPY <> [M]CPYLIN(I)
    TARGETOK = 1 : Break
  Endif
Next I
If !TARGETOK
  GMESSAGE = mess(148,7780,1)
  GERR=1 : GOK=0
  zonsui = "NBLIG"
  Return
Endif
# GTYPPCE is used in the screen as the default value for field TYP
GTYPPCE = [M]TYP
GNUMPCE = [M]NUM
Raz OK

# We need to re-set the global variables to the source company
If GCURINTCPY <> [M]CPY
  Call RESET_INTCPYCOA ([M]CPY,[M]FCY) From INTCPYLIB
Endif
# Management of currencies  (Fields sized of 10 : LED, CURLED, RATMLT, RAMDIV)
For I=0 To dim([F:GIC]LED)-1
 [F:GIC]LED(I)    = [M:HAEF]LEDC(I)
 [F:GIC]CURLED(I) = [M:HAEF]CURC(I)
 [F:GIC]RATDIV(I) = [M:HAEF]RATDIVC(I)
 [F:GIC]RATMLT(I) = [M:HAEF]RATMLTC(I)
Next

# Fiscal and period year
Call GETPERSOC([M]CPY,GTYPGEN,[M]ACCDAT,EXERCICE,PERIODE) From CPTSUB
[F:GIC]FIY=EXERCICE
[F:GIC]PER=PERIODE
Case [F:GTE]PER
 When 1       :
 When 2       : [F:GIC]PER  = 0
 When Default : [F:GIC]PER += [F:GTE]PER-2
Endcase

Return

####################################################################################
$CREATION
# NEW button pressed; after everything is entered and after [F] class is written to the database

Gosub SETMSK

NLIG = 0

For nolign=1 To [M]NBLIG
  Raz [F:GID]
  [F:GID] = [F:GIC]
  [F:GID] = [M]

  # Do not default from GIC (source) for GID (target) fields
  Raz [F:GID]LED
  Raz [F:GID]COA

  # We need to re-set the global variables to the target company
  If GCURINTCPY <> [M]CPYLIN(nolign-1)
    Call RESET_INTCPYCOA ([M]CPYLIN(nolign-1),[M]FCYLIN(nolign-1)) From INTCPYLIB
  Endif

  # Needs to be for all ledgers not just those entered [M:HAEF]NBRLED
  For I=0 To len(mess(0,2644,1))-1
    [F:GID]LEDTYP(I) = [M:HAEF]LEDTYP(I)
    If [M]CPYLIN(nolign-1) <> [M]CPY
      [F:GID]RATMLT(I) = evalue("[M]RATMLT"+num$(I+1)+"("+num$(nolign-1)+")")
      [F:GID]RATDIV(I) = evalue("[M]RATDIV"+num$(I+1)+"("+num$(nolign-1)+")")
    Else
    # If target = source company always update the lines from the source / header data in case the rates were changed
      [F:GID]RATMLT(I) = evalue("[M:HAEF]RATMLTC("+num$(I)+")")
      [F:GID]RATDIV(I) = evalue("[M:HAEF]RATDIVC("+num$(I)+")")
    Endif
  Next I
  Raz I

  # The screen (HAEF) stores everything in ACC1 or ACC2 but the tables need to be stored by ledger ACC(ledger)
  # Main general
  If [F:GID]LEDTYP(0) > 0
    [F:GID]LED([F:GID]LEDTYP(0)-1) = [M:HAEF]LED(0)
    [F:GID]COA([F:GID]LEDTYP(0)-1) = evalue("[M]COA1("+num$(nolign-1)+")")
    [F:GID]ACC([F:GID]LEDTYP(0)-1) = evalue("[M]ACC1("+num$(nolign-1)+")")
    [F:GID]SAC([F:GID]LEDTYP(0)-1) = evalue("[M]SAC1("+num$(nolign-1)+")")
  Endif
  # Main analytical
  If [F:GID]LEDTYP(1) > 0 and [F:GID]LEDTYP(0) <> [F:GID]LEDTYP(1)
    [F:GID]LED([F:GID]LEDTYP(1)-1) = [M:HAEF]LED(1)
    [F:GID]COA([F:GID]LEDTYP(1)-1) = evalue("[M]COA2("+num$(nolign-1)+")")
    [F:GID]ACC([F:GID]LEDTYP(1)-1) = evalue("[M]ACC2("+num$(nolign-1)+")")
    [F:GID]SAC([F:GID]LEDTYP(1)-1) = evalue("[M]SAC2("+num$(nolign-1)+")")
  Endif

  NLIG += 1
  [F:GID]LIN = NLIG
  If [M]DEB(nolign-1)<>0
    [F:GID]SNS = 1
    [F:GID]AMTCUR = [M]DEB(nolign-1)
  Else
    [F:GID]SNS = -1
    [F:GID]AMTCUR = [M]CDT(nolign-1)
  Endif

  If [M]DSP(nolign-1)="$" : [F:GID]DSP = "" : Endif
  Write [GID]
  If fstat
  GOK = 0 : Call FSTA("GID") From GLOCK : Break
  Endif

  # Manual allocations
  If [M]DSP(nolign-1)="$"
    K = 0
    For I=[M]PTV(nolign-1) To [M]PTF(nolign-1)
      K += 1
      Raz [F:GIA]
      # Do not default from GIC (source) for GIA (ana target) fields only default from GID (target)
      [F:GIA] = [F:GID]
      [F:GIA]AMTCUR = [M:VT2]TBAMT(I)
      [F:GIA]QTY    = [M:VT2]TBQTY(I)
      [F:GIA]ANALIN = K
      For J=1 To dim([F:GIA]CCE)-1
        [F:GIA]DIE(J-1) = evalue("[M:VT2]TBDIE("+num$(J-1)+")")
        [F:GIA]CCE(J-1) = evalue("[M:VT2]TBCCE"+num$(J)+"("+num$(I)+")")
      Next J
      Write [GIA]
      If fstat
        GOK = 0 : Call FSTA("GIA") From GLOCK : Break 2
      Endif
    Next I

  # Standard allocations
  Elsif [M]DSP(nolign-1)<>""
    [M:VTL]TOTREP  = [F:GID]AMTCUR
    [M:VTL]QTOTREP = [F:GID]QTY

    # Loading of the allocation
    Call LECTURE("TCU",[F:GIC]CUR,"") From CONTOBJ
    Call LECTURE("GAC",[F:GID]ACC,[F:GID]COA) From CONTOBJ
    # change CPY to CPYLIN below
    Call LECLED([F:GID]CPYLIN,[F:GID]LEDTYP(INDLED),WLED,WCUR) From CPTDIV
    Call INDLED(WLED,"",IND,AXI) From CPTDIV
    Call CHARGE_VTE_STR([F:GID]DSP,[M]UOM(nolign-1),WLED,[F:GID]ACC,"") From VENTILE

    Raz [F:GIA]
    # Do not default from GIC (source) for GIA (ana target) fields only default from GID (target)
    [F:GIA] = [F:GID]
    K = 0
    For I=0 To [M:VTL]BAS-1
      K += 1
      [F:GIA]AMTCUR = [M:VTL]AMT(I)
      [F:GIA]QTY    = [M:VTL]QTY(I)
      [F:GIA]ANALIN = K
      For J=1 To dim([F:GIA]CCE)
        [F:GIA]DIE(J-1) = evalue("[M:VTL]DIE("+num$(J-1)+")")
        If find([F:GIA]DIE(J-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
          [F:GIA]CCE(J-1) = evalue("[M:VTL]CCE"+num$(J)+"("+num$(I)+")")
        Endif
      Next J
      Write [GIA]
      If fstat
        GOK = 0 : Call FSTA("GIA") From GLOCK : Break 2
      Endif
    Next I

  # Distribution (Allocation) on the input line general writing (write access)
  Else
   Raz [F:GIA]
   # Do not default from GIC (source) for GIA (ana target) fields only default from GID (target)
   [F:GIA] = [F:GID]
   [F:GIA]ANALIN = 1
   For J=1 To dim([F:GIA]CCE)-1
     [F:GIA]DIE(J-1) = evalue("[M:HAEF]DIE("+num$(J-1)+")")
     [F:GIA]CCE(J-1) = evalue("[M]CCE"+num$(J)+"("+num$(nolign-1)+")")
   Next J
   If sum([F:GIA]CCE(0..dim([F:GIA]CCE)-1))<>""
     Write [GIA]
     If fstat
       GOK = 0 : Call FSTA("GIA") From GLOCK : Break
     Endif
   Endif
  Endif

Next nolign

# Intercompany enhancement Re-initialization of the Global Variables
# In case the last CPYLIN <> CPY then the global variables are not correct
Call RESET_INTCPYCOA([M]CPY,[M]FCY) From INTCPYLIB

If GOK<1 : Return : Endif

If [M]FLGPST<3
 Call UPD_INTCOFLO(3,2,[F:GIC]NUM,[F:GIC]NBRCPY) From INTCPYLIB2
 If GOK<0 : Return : Endif
Endif
Return

####################################################################################
$MODIF
# SAVE button pressed / modification mode - After re-write statement BEFORE commit
Gosub ANNULE
If GOK<1 : Return : Endif
Gosub CREATION
Return

####################################################################################
$APRES_CRE
# NEW button pressed / modification mode - When databased transaction has been committed
Gosub AFFTAB
Affzo [GIC1]NUM
Gosub DEGRISE_CLE From =WINPROG

####################################################################################
$APRES_MOD
# SAVE button pressed / modification mode - When databased transaction has been committed
Gosub AFFTAB
Call UNLOCKCPY From AX3MONO
Return

####################################################################################
$ABANDON
# CANCEL button pressed
Gosub DEGRISE_CLE From =WINPROG
Return

####################################################################################
$DEGRISE_CLE
Gosub DEGRISE_CLE From =WINPROG
Return

####################################################################################
# Code is from SUBGAS
$AFFTAB
If AFF
 AFFICHE=1 : Gosub RELIT From GOBJSUB
Endif
Return

####################################################################################
$SETMSK
Default Mask [GIC1]
Return

####################################################################################
Subprog INI_GLOBAL(SOCIETE,SETSITE)
Value Char    SOCIETE     : # Company
Value Char    SETSITE     : # Site to reset the Global variables for
Local Integer STAT        : # Status error

Call SETLED(SOCIETE) From SUBGIC
Call SETPLANAXE2(SOCIETE,GNBTYPLED,GTYPLED,GNBPLAN,GPLAN,GNBAXE,GAXE,GOBLIG) From CPTDIV
# In GL the other CALLs are not necessary as it is handled differently
#GNBTYPLED = GNBPLAN
#Call SETMAINREF(SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
GSOCIETE = SOCIETE
Call RESET_INIMSKFMT(SETSITE,STAT)  From SUBGICA
End

####################################################################################
Subprog SETLED(SOCIETE)
Value Char    SOCIETE            : # Company
Local Integer IMOD               : # Local variables
Local Char    MODELE(GLONGCM)    : # Account core model

Call SETGCM(SOCIETE,MODELE) From CPTDIV
IMOD= find(MODELE,GGCM(1..GGCMNBR))
If !IMOD
  Call GLOBVAR From SETGLBGCM
  IMOD   = find(MODELE,GGCM(1..GGCMNBR))
Endif
End

####################################################################################
####################################################################################
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If [M]NBLIG<>0 : mkstat = 2 : Endif
End

Subprog C_FCY(VALEUR)
Variable Char     VALEUR
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
[M]CPY = [F:FCY]LEGCPY
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
Call GETSOC(VALEUR) From DEVSUB
Call SETCUR(1,[M]CPY,[M]CURAFF) From CPTDIV
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(GLONADW)
Local Integer OK, STAT, RESETCPY
Call LEC_FCY(VALEUR) From CPTLEC
[M]CPY = [F:FCY]LEGCPY
# Must be done here as this is set by Company's legislation
Call LEC_CPY([M]CPY) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
#--- Management single-company - Lock company
Call UNLOCKCPY() From AX3MONO
Call LOCKCPY([M]CPY,OK) From AX3MONO
If !OK
  OK = 2 : Call AVERTIR(mess(216,126,1)-[M]CPY,OK) From GESECRAN
  If OK<>2 : mkstat = 2 : End : Endif
Endif
Call UNLOCKCPY From AX3MONO
Call RESET_CPY_PARAMS([F:FCY]LEGCPY,VALEUR)
#--- Initialization and controls of screens.
If [M]TYP<>""
 Call INIMSKFMT(VALEUR,[M]TYP,[M]ACCDAT,STAT)  From SUBGICA
 If STAT
  GMESSAGE=""
  Gosub MESSAGE From CPTAUTO
  GMESSAGE -= mess(86,105,1)+"\"+MESSA
  mkstat =2 : End
 Endif
Endif
#--- Itialization of currency rates
If [M]RATDAT<>[0/0/0] & [M]CUR<>""
 Gosub CHARG_ZONES_DEV From SUBGIC
 Gosub INIT_COURS From SUBGIC
Endif
Call GETSOC(VALEUR) From DEVSUB
GCURINTCPY = VALEUR
End

Subprog D_CPY(VALEUR)
Variable Char    VALEUR()
Call LEC_FCY([M]FCY) From CPTLEC
VALEUR = [F:FCY]LEGCPY
Call LEC_CPY(VALEUR) From CPTLEC
End

# Code is from SUBGAS; LIENS and SUBGA0; AM_FCY
Subprog RESET_CPY_PARAMS(RE_COMP,RE_FCY)
Value Char RE_COMP, RE_FCY
# GETSOC sets all company global variables, including GSOCIETE, GFINRSP (financial site), and GCURFCY
# note: GETSOC also calls SETMAINREF
Call GETSOC(RE_FCY) From DEVSUB
#--- Reading of parameters
Local Char PARAMETRE(10)

# Issue 114426 - 2016-03-18 by RICAR : SIVSUP parameter to split in PIVSUP and GASSUP
# Issue 114426
#--- Parameter "Delete accounting entry" (Use to Delete button)
Call PARAM(RE_COMP,"GASSUP",PARAMETRE) From ADOVAL
GGASSUP = val(PARAMETRE)
# End issue 114426
#--- Parameter "Lines set to zero prohibited"
Call PARAM(RE_COMP,"SIVNULL",PARAMETRE) From ADOVAL
GSIVNULL = val(PARAMETRE)
#--- Mandatory tax code
If dim(GSAITAX)>0
 Call PARAM(RE_COMP,"SAITAX",PARAMETRE) From ADOVAL
 GSAITAX  = val(PARAMETRE)
Endif
#--- Exempt tax code
If dim(GEXETAX)>0
 Call PARAM(RE_COMP,"EXETAX",PARAMETRE) From ADOVAL
 GEXETAX  = PARAMETRE
Endif
End

# Code is from SUBGAS; LIENS and SUBGA0; AM_FCY
Subprog RESET_COMPANY(RE_CPY, RE_FCY, RE_JOU, RE_TYP, RE_CUR)
Value Char RE_CPY, RE_FCY, RE_JOU, RE_TYP, RE_CUR
Call LEC_JOU_LEG(GCURLEG,RE_JOU) From CPTLEC
Call LEC_GTE_LEG(GCURLEG,RE_TYP) From CPTLEC
Call LEC_TCU(RE_CUR) From CPTLEC
Call LEC_FCY(RE_FCY) From CPTLEC
Call LEC_CPY(RE_CPY) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
# GETSOC sets all company global variables, including GSOCIETE, GFINRSP (financial site), and GCURFCY
# note: GETSOC also calls SETMAINREF
Call GETSOC(RE_FCY) From DEVSUB
End

####################################################################################
Subprog AS_TYP(VALEUR)
Variable Char     VALEUR
# In case modifying an existing entry
If [M]CPY<>GCURINTCPY and GCURINTCPY<>"" : Call RESET_INTCPYCOA([M]CPY,[M]FCY) From INTCPYLIB : Endif
End

Subprog C_TYP(VALEUR)
Variable Char    VALEUR
Local Char IDENT(GLONGTE), TMPJOU(GLONJOU)
Call CONTEXE([F:GTE]ACS) From CPTSUB
If mkstat : End : Endif
If [F:GTE]PER>1 & find(GREP,"C","D") : Gosub SETDAT From SUBGA0 : Endif
TMPJOU = [M]JOU
IDENT = VALEUR : Gosub CONT_GTE
End

Subprog AM_TYP(VALEUR)
Variable Char    VALEUR
If GIMPORT : End : Endif
If find(GREP,"C","D")
 Raz [M]ACCDAT
 [M:GIC1]TYPRAT = [F:GTE]TYPRAT
Endif
Local Integer STAT
# Initialization and controls of screens.
Call INIMSKFMT([M]FCY,VALEUR,[M]ACCDAT,STAT)  From SUBGICA
If STAT
  GMESSAGE=""
  Gosub MESSAGE From CPTAUTO
  GMESSAGE -= mess(86,105,1)+"\"+MESSA
  mkstat = 2 : End
Endif
# If the TYP does not have the Source Company's Main Ledger Authorized or Mandatory then do not allow
If [M:HAEF]LEDTYP(0) <> GTYPGEN
  GMESSAGE=""
  STAT = 43 : Gosub MESSAGE From CPTAUTO
  GMESSAGE -= mess(143,104,1)+"\"+MESSA
  mkstat = 2 : End
Endif
# If the Source Company uses Analytical and TYP does not have the Source Company's Analytical Ledger Authorized or Mandatory then do not allow
If [M:HAEF]LEDTYP(1) <> GTYPANA and GTYPGEN <> GTYPANA
  GMESSAGE=""
  STAT = 43 : Gosub MESSAGE From CPTAUTO
  GMESSAGE -= mess(144,104,1)+"\"+MESSA
  mkstat = 2 : End
Endif
If [F:GTE]PER>1 & find(GREP,"C","D") : Gosub SETDAT From SUBGA0 : Endif
# Initialize currency rates
If [M]CUR<>""
 Gosub INIT_COURS From SUBGIC
Endif
# If there are any lines with the same Company as the source then all of those lines TYPLIN must be updated
If [M]TYP <> VALEUR
  Local Integer I
  For I=0 To [M]NBLIG-1
    If [M]CPY = [M]CPYLIN(I)
      [M]TYPLIN(I) = VALEUR
      Affzo [M]TYPLIN(I)
      # If manual number is not an option then clear out the manual document number
      If [F:GTE]MANNUM<>2 and [M]DOCNUMLIN(I)<>""
        [M]DOCNUMLIN(I) = ""
        Affzo [M]DOCNUMLIN(I)
      Endif
    Endif
  Next I
Endif
End

####################################################################################
Subprog C_NUM(VALEUR)
Variable Char     VALEUR
Local Integer OKTCA
Call LECTCA(2,OKTCA) From SUBTCA
# Intercompany sequence counter INTCO is (11) / line 12 in the Financials module
If !GIMPORT
 If VALEUR<>""
  Read [GIC]GIC0 = VALEUR
  If fstat & [F:TCA]MANCOU(11)<>2 : Raz VALEUR : Endif
 Elsif [F:TCA]MANCOU(11)=2
  GMESSAGE = mess(10,123,1) : mkstat = 1
 Endif
Else
 If VALEUR<>""
  If clalev([F:GIC2])=0 : Local File =GTABCPT+"GACCINTCPY" [GIC2] : Endif
  Read [GIC]GIC0 = VALEUR
  If fstat & [F:TCA]MANCOU(11)<>2 : Raz VALEUR : Endif
 Elsif [F:TCA]MANCOU(11)=2
  GMESSAGE = mess(10,123,1) : mkstat = 1
 Endif
Endif
End

Subprog AP_NUM(VALEUR)
Variable Char     VALEUR
If VALEUR="" : If !GIMPORT : mkstat = 4 : Endif : Endif
End

####################################################################################
Subprog AS_ACCDAT(VALEUR)
Variable Date     VALEUR
If VALEUR=[0/0/0] | ([F:GTE]PER>1 & find(GREP,"C","D"))
 Gosub SETDAT From SUBGA0
 VALEUR = DAT
Endif
If [F:GTE]PER>1
 For I=1 To 10
  Call GETPERSOC([M]CPY,I,VALEUR,[M:HAEF]FIY(I-1),[M:HAEF]PER(I-1)) From CPTSUB
  Case [F:GTE]PER
   When 1       :
   When 2       : [M:HAEF]PER(I-1)  = 0
   When Default : [M:HAEF]PER(I-1) += [F:GTE]PER-2
  Endcase
 Next
 mkstat=2 : End
Endif
End

# From SUBGA0 with modifications
Subprog C_ACCDAT(VALEUR)
Variable Date     VALEUR
# Check the date for the target companies
Local Char    RETCPY(GLONCPY)
Local Integer RETVAL
Raz RETCPY
Raz RETVAL
RETVAL = func INTCPYLIB.CHKFIYPER(VALEUR,RETCPY)
If RETVAL = -1
  ##The fiscal year for company XX is not open
  GMESSAGE = func AFNC.MES1(mess(71,101,1),RETCPY)
  mkstat = 2 : End
Elsif RETVAL = -2
  ##The period for company XX is not open
  GMESSAGE = func AFNC.MES1(mess(72,101,1),RETCPY)
  mkstat = 2 : End
Endif
Gosub CONT_DAT From SUBGIC
If mkstat : End : Endif
If [M]ACCDAT=VALEUR
 If !find(GREP,"C","D") : mkstat=0 : Endif
Endif
# Dates by modules
If clalev([F:AOB])  = 0 : Local File AOBJET [AOB] : Endif
If find(GREP,"C","D")
 Call LECTURE("AOB",GABREV,"") From CONTOBJ
 Local Integer MODULE
 MODULE = [F:AOB]MODULE
 Call CTLDATMOD(MODULE,VALEUR,[M]CPY) From CPTSUB
 If mkstat : End : Endif
Endif
# 2018-10-12 DNE REMOVED BEGIN (X3-112167)
#
# NOTE (DNE): This code chunk is a copy from above so the checks are already done when coming to the
#             commented lines. For QA reasons I keep these lines for just a few days.
#
## Check the date for the target companies
#Local Char    RETCPY(GLONCPY)
#Local Integer RETVAL
#Raz RETCPY
#Raz RETVAL
#RETVAL = func INTCPYLIB.CHKFIYPER(VALEUR,RETCPY)
#If RETVAL = -1
#  ##The fiscal year for company XX is not open
#  GMESSAGE = func AFNC.MES1(mess(71,101,1),RETCPY)
#  mkstat = 2 : End
#Elsif RETVAL = -2
#  ##The period for company XX is not open
#  GMESSAGE = func AFNC.MES1(mess(72,101,1),RETCPY)
#  mkstat = 2 : End
#Endif
# 2018-10-12 DNE REMOVED END
# Intialization of currency rates
If [M]RATDAT=[0/0/0]
 [M]ACCDAT=VALEUR
 Call D_RATDAT([M]RATDAT)
 If [M]CUR<>""
  Gosub CHARG_ZONES_DEV From SUBGIC
  Gosub INIT_COURS From SUBGIC
 Endif
Endif
End

Subprog AP_ACCDAT(VALEUR)
Variable Date     VALEUR
# Fiscal years & Fiscal periods
[M]ACCDAT = VALEUR
For I=1 To 10
 Call GETPERSOC([M]CPY,I,VALEUR,[M:HAEF]FIY(I-1),[M:HAEF]PER(I-1)) From CPTSUB
 Case [F:GTE]PER
  When 1       :
  When 2       : [M:HAEF]PER(I-1)  = 0
  When Default : [M:HAEF]PER(I-1) += [F:GTE]PER-2
 Endcase
Next
End

# Code is from SUBGA1 with modifications
$CONT_DAT
Local Char BID(30),BID1(30),BID2(30)
Local Decimal OFIY
Local Integer I, J, IND, TYD, WTYP, AXI
# Check that at least one year has an open period.
mkstat=0
For I=0 To [M:HAEF]NBRLED-1
 Call CONTPER(VALEUR,[M:HAEF]LEDTYP(I),[M]FCY) From CPTSUB
 If !mkstat : Break : Endif
Next
If mkstat
 GMESSAGE = mess(1,104,1)-"\"-GMESSAGE : # Date incorrecte
 mkstat = 2 : Return
Endif
If dim([F:GTE]VLYSTR)>0
 Call CTLVLYDAT(VALEUR,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
 If mkstat : GMESSAGE = [F:GTE]TYP-GMESSAGE : Return : Endif
Endif
If VALEUR<>[M]ACCDAT
 # Fiscal year check
 If !clalev([F:GID3]) : Local File GACCINTCPYD  [GID3] : Endif
 For I=0 To [M:HAEF]NBRC-1
  Call GETEXE([M]CPY,[M:HAEF]TYPC(I),VALEUR,OFIY) From CPTSUB
  If GREP<>"D" & [M:HAEF]FIY(I)<>OFIY
   Filter [GID3] Where TYP=[M]TYP & NUM=[M]NUM & LEDTYP=[M:HAEF]TYPC(I)
   Read [GID3]First
   If !fstat
    GMESSAGE = mess(5,106,1) : # Changement d'exercice interdit
    mkstat = 2 : Break
   Endif
  Endif
 Next
 Filter [GID3]
 If mkstat : Return : Endif
 # Control for valid dates, accounts and controls
 For I=0 To [M]NBLIG-1
  For J=1 To [M:HAEF]NBRLED
   # Control / Account
   BID1= evalue("[M]SAC"+num$(J)+"("+num$(I)+")")
   If BID1<>""
    BID2 = evalue("[M]COA"+num$(J)+"("+num$(I)+")")
    Read [F:GAC]GAC1=BID2;BID1
    Call CTLVLYDAT(VALEUR,[F:GAC]VLYSTR,[F:GAC]VLYEND) From CPTSUB
    If mkstat : GMESSAGE=mess(27,102,1)-[F:GAC]ACC-GMESSAGE : Break 2: Endif : # Collectif
   Else
    BID= evalue("[M]ACC"+num$(J)+"("+num$(I)+")")
    If BID<>""
     BID2 = evalue("[M]COA"+num$(J)+"("+num$(I)+")")
     Call LEC_GAC(BID,BID2) From CPTLEC
     Call CTLVLYDAT(VALEUR,[F:GAC]VLYSTR,[F:GAC]VLYEND) From CPTSUB
     If mkstat : GMESSAGE=mess(2,113,1)-BID-GMESSAGE : Break 2 : Endif : # Compte
    Endif
   Endif
   # Distribution
   Case [M]DSP(I)
    When ""
    When "$"
     For K=[M]PTV(I) To [M]PTF(I)
      For AXI=1 To 20
       BID = evalue("[M:VT2]TBCCE"+num$(AXI)+"("+num$(K)+")")
       If BID<>""
        Call LEC_CCE(BID,[M:HAEF]DIE(AXI-1)) From CPTLEC
        Call CTLVLYDAT(VALEUR,[F:CCE]VLYSTR,[F:CCE]VLYEND) From CPTSUB
        If mkstat : GMESSAGE=mess(48,105,1)-BID-GMESSAGE : Break 2 : Endif : # Section
       Endif
      Next
     Next
    When Default
     Call LEC_DSP([M]DSP(I)) From CPTLEC
     Call CTLVLYDAT(VALEUR,[F:DSP]VLYSTR,[F:DSP]VLYEND) From CPTSUB
     If mkstat : GMESSAGE=mess(23,106,1)-[M]DSP(I)-GMESSAGE : Endif : # Répartition ana
   Endcase
   If mkstat : Break 2 : Endif
   # Sections
   For AXI=1 To 20
    BID=evalue("[M]CCE"+num$(AXI)+"("+num$(I)+")")
    If BID<>""
     Call LEC_CCE(BID,[M:HAEF]DIE(AXI-1)) From CPTLEC
     Call CTLVLYDAT(VALEUR,[F:CCE]VLYSTR,[F:CCE]VLYEND) From CPTSUB
     If mkstat : GMESSAGE=mess(48,105,1)-BID-GMESSAGE : Break 2 : Endif : # Section
    Endif
   Next AXI
  Next J
 Next I
 If mkstat : Return : Endif
Endif
Return

####################################################################################
Subprog D_JOU(VALEUR)
Variable Char     VALEUR
If VALEUR="" : VALEUR = [F:GTE]DEFJOU : Endif
End

Subprog AS_JOU(VALEUR)
Variable Char     VALEUR
# In case modifying an existing entry
If [M]CPY<>GCURINTCPY and GCURINTCPY<>"" : Call RESET_INTCPYCOA([M]CPY,[M]FCY) From INTCPYLIB : Endif
End

Subprog C_JOU(VALEUR)
Variable Char     VALEUR
Local Char        SAVJOU(GLONJOU)
# Code from SUBGA0; C_JOU
Call LEC_JOU_LEG(GCURLEG,VALEUR) From CPTLEC
# Code from SUBGA1; CONTJOU
# Journal compatible with the site/company
Call VERIF([F:JOU]FCY,[M]FCY,[F:JOU]JOU) From CFYSUB
If mkstat : End : Endif
SAVJOU=[M]JOU
Call CONT_JOU (VALEUR,"[M]FCY",[M]FCY,[M]CPY)
If !mkstat and VALEUR <> SAVJOU
  # Check the accounts on the lines that have changed
  Gosub CHECK_JOU_LINES
  If !mkstat
    Gosub CHANGE_JOU_LINES
  Endif
Endif
# Issue X3-58865 - 2017-10-18 by VAVIL : Control GESGIC function for POR legislation
# Issue X3-58865
If func PORLEGLIB.DIGSIGN("",[M]CPY) & GREP<>""
  If !func PORLEGLIB.CREGASOK(VALEUR,"",GMESSAGE)
     mkstat = 2 : End
  Endif
Endif
# End issue X3-58865
End

# If there are any lines with the same Company as the source then all of those lines JOULIN must be updated
$CHANGE_JOU_LINES
Local Integer I
For I=0 To [M]NBLIG-1
  If [M]CPY = [M]CPYLIN(I)
    [M]JOULIN(I) = VALEUR
    Affzo [M]JOULIN(I)
  Endif
Next I
Return

$CHECK_JOU_LINES
Local Integer I, K, NOL,NBLED, IND
Local Char WLED(GLONLED),WACC(GLONGAC), WCUR(GLONCUR)
NBLED = [M:HAEF]NBRLED
For NOL=0 To [M]NBLIG-1
 For J=1 To [L]NBLED
  WACC=evalue("[M]ACC"+num$(J)+"("+num$(NOL)+")")
  # Only check the lines / accounts where the JOU has changed so where source = target
  If WACC<>"" and [M]CPY = [M]CPYLIN(NOL)
   Call LECLED([M]CPY,[M:HAEF]LEDTYP(J-1),WLED,WCUR) From CPTDIV
   Call INDLED(WLED,"",IND,K) From CPTDIV
   Call LEC_JCO_LEG(GCURLEG,GLEDCOA(IND),[F:JOU]JOU) From CPTLEC
   If !find(WACC,[F:JCO]ACC,[F:JCO]FRQACC(0..[F:JCO]FRQNBR-1))
    For I=0 To dim([F:JCO]FBDACC)-1
     If pat(WACC,[F:JCO]FBDACC(I))
      # Account not compatible with the journal JOU
      GMESSAGE = mess(47,106,1)-num$(NOL+1)-"\"+WACC-mess(14,106,1)-VALEUR-"("+GLEDCOA(IND)+")"
      mkstat = 2 : Break 3
     Endif
    Next I
   Endif
  Endif
 Next J
Next NOL
Return

Subprog CONT_JOU (JOURNAL,FCYNAM,FCY,CPY)
Variable Char JOURNAL
Value Char FCYNAM, FCY, CPY
If !clalev([F:JOU]) : Local File GJOURNAL [JOU] : Endif
Call CONTJOU(JOURNAL,GCURLEG,"") From SUBJOU
If mkstat : Raz mkstat : GOK=0 : End : Endif
If [F:JOU]ENAFLG<>2    # Inactive Journal code
 If !GIMPORT : GMESSAGE = mess(13,105,1)-":"-JOURNAL+"\"+mess(2,126,1)
 Else        : GMESSAGE = mess(13,105,1)-JOURNAL-":"-mess(2,126,1)
 Endif
 mkstat = 2 : End
Elsif [F:JOU]ACS<>""   # Access code
 Call CONTEXE([F:JOU]ACS) From CPTSUB
 If mkstat
  GMESSAGE = [F:JOU]ACS-GMESSAGE
  mkstat = 2 : End
 Endif
Endif
If [F:JOU]FCY<>""      # site
 Call VERSOC([F:JOU]FCY,CPY,FCY,[F:JOU]JOU) From CFYSUB
 If mkstat
  mkstat = 2 : End
 Endif
Endif
If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
 GMESSAGE = [F:JOU]JOU-mess(8,106,1)-[F:GTE]TYP : # Journal not authorized for this Document type
 mkstat = 2 : End
Endif
End

####################################################################################
Subprog AS_TYPRAT(VALEUR)
Variable Integer VALEUR
End

Subprog AM_TYPRAT(VALEUR)
Variable Integer VALEUR
[M]TYPRAT=VALEUR
If [M]RATDAT<>[0/0/0] & [M]CUR<>""
 Gosub CHARG_ZONES_DEV From SUBGIC
 Gosub INIT_COURS From SUBGIC
 If [M]NBLIG>0
  Local Integer TMPI, TMPI2
  For TMPI=0 To [M]NBLIG-1
   Call INIT([M:GIC1]CUR,[M]CPYLIN(TMPI),VALEUR,[M:GIC1]RATDAT,0) From SUBSCL
   Gosub INIT_RATLIN
  Next
 Endif
Endif
End

####################################################################################
Subprog D_RATDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 Call LEC_GTE_LEG(GCURLEG,[M]TYP) From CPTLEC
 VALEUR = [M]ACCDAT
Endif
End

Subprog AM_RATDAT(VALEUR)
Variable Date    VALEUR
# Intialize currency rates
If [M]CUR<>""
 [M]RATDAT=VALEUR
 Gosub CHARG_ZONES_DEV From SUBGIC
 Gosub INIT_COURS From SUBGIC
 If [M]NBLIG>0
  Local Integer TMPI, TMPI2
  For TMPI=0 To [M]NBLIG-1
   Call INIT([M:GIC1]CUR,[M]CPYLIN(TMPI),[M:GIC1]TYPRAT,VALEUR,0) From SUBSCL
   Gosub INIT_RATLIN
  Next
 Endif
Endif
End

$INIT_RATLIN
Gosub CHARG_ZONES_DEV From SUBSCL
Gosub INIT_COURS From SUBSCL
For TMPI2=0 To len(mess(0,2644,1))-1
 If [F:GCM]LED(TMPI2)<>""
  If [F:GCM]CUR(TMPI2)=[M:SCL]CURENT
   Assign "[M:GIC1]RATMLT"+num$(TMPI2+1)+"("+num$(TMPI)+")" With 1
   Assign "[M:GIC1]RATDIV"+num$(TMPI2+1)+"("+num$(TMPI)+")" With 1
  Elsif [F:GCM]CUR(TMPI2)=[M:SCL]CURLED([M:SCL]LIGLED(TMPI2)-1)
   Assign "[M:GIC1]RATMLT"+num$(TMPI2+1)+"("+num$(TMPI)+")" With [M:SCL]RATMLT([M:SCL]LIGLED(TMPI2)-1)
   Assign "[M:GIC1]RATDIV"+num$(TMPI2+1)+"("+num$(TMPI)+")" With [M:SCL]RATDIV([M:SCL]LIGLED(TMPI2)-1)
  Endif
 Endif
Next TMPI2
Return

####################################################################################
Subprog AV_CUR(VALEUR)
Variable Char    VALEUR()
If !GIMPORT
 If [M]NBLIG & GREP<>"C" & GREP<>"D"
  Diszo [M]CUR
 Else
  Actzo [M]CUR
 Endif
Endif
End

Subprog D_CUR(VALEUR)
Variable Char     VALEUR
If VALEUR="" & [M]JOU<>""
 Call LEC_JOU_LEG(GCURLEG,[M]JOU) From CPTLEC
 If [F:JOU]TYP=3
  Local Char WCOA(GLONCOA)
  If !clalev([F:BAN]) : Local File BANK    [BAN] : Endif
  If !clalev([F:JCO]) : Local File GJOUCOA [JCO] : Endif
  Call LECMAINPLAN(1,[M]CPY,[L]WCOA) From CPTDIV
  Call LEC_JCO_LEG(GCURLEG,[L]WCOA,[M]JOU) From CPTLEC
  Call LEC_GAC([F:JCO]ACC,[L]WCOA) From CPTLEC
  If [F:GAC]CUR<>""
   [M]CUR = [F:GAC]CUR
   Filter [BAN] Where BANACC=[F:JCO]ACC
   Read [BAN]BAN0 First
   Filter [BAN]
   If !fstat
    If [F:BAN]CHGDAT<>[0/0/0] & [M]ACCDAT < [F:BAN]CHGDAT
     If [F:BAN]OLDCUR<>"" : [M]CUR = [F:BAN]OLDCUR : Endif
    Endif
   Endif
   Call LEC_TCU([M]CUR) From CPTLEC
   VALEUR = [M]CUR : Affzo [M:GIC1]CUR
   Call AM_CUR([M]CUR) : End
  Endif
 Endif
Endif
If VALEUR=""
 Call LEC_CPY([M]CPY) From CPTLEC
 If !fstat : VALEUR = [F:CPY]ACCCUR : Endif
Endif
If varmode([M]CUR)=3
 [M]CUR=VALEUR
 Gosub CHARG_ZONES_DEV From SUBGIC
 Gosub INIT_COURS From SUBGIC
Endif
If VALEUR<>"" : [M:GIC1]CURAFF = VALEUR : Affzo [M:GIC1]CURAFF : Endif
End

Subprog C_CUR(VALEUR)
Variable Char VALEUR()
Call CONTDEV(VALEUR,[M]ACCDAT) From TRTDEV
If mkstat : End : Endif
End

Subprog AM_CUR(VALEUR)
Variable Char     VALEUR
Local Integer STAT
Local Char OLDCUR
If !GIMPORT
 OLDCUR=[M]CUR
 [M]CUR=VALEUR : Affzo [M:GIC1]CUR
 [M:GIC1]CURAFF = VALEUR : Affzo [M:GIC1]CURAFF
 [M:GIC1]CURAFF2 = VALEUR : Affzo [M:GIC1]CURAFF2
 Gosub CHARG_ZONES_DEV From SUBGIC
 Gosub INIT_COURS From SUBGIC
 # Update all lines with the new CUR and reset the rates when target company <> source company
 If OLDCUR <> VALEUR and [M]NBLIG > 0
  Local Integer TMPI, TMPI2
  For TMPI=0 To [M]NBLIG-1
    [M]CURLIN(TMPI) = VALEUR
    Affzo [M]CURLIN(TMPI)
    If [M]CPY <> [M]CPYLIN(TMPI)
      Call RESET_INTCPYCOA ([M]CPYLIN(TMPI),[M]FCYLIN(TMPI)) From INTCPYLIB
      Call INIT([M:GIC1]CUR,[M]CPYLIN(TMPI),[M:GIC1]TYPRAT,[M:GIC1]RATDAT,0) From SUBSCL
      Gosub CHARG_ZONES_DEV From SUBSCL
      Gosub INIT_COURS From SUBSCL
      For TMPI2=0 To len(mess(0,2644,1))-1
        If [F:GCM]LED(TMPI2)<>""
          If [F:GCM]CUR(TMPI2)=[M:SCL]CURENT
            Assign "[M:GIC1]RATMLT"+num$(TMPI2+1)+"("+num$(TMPI)+")" With 1
            Assign "[M:GIC1]RATDIV"+num$(TMPI2+1)+"("+num$(TMPI)+")" With 1
          Elsif [F:GCM]CUR(TMPI2)=[M:SCL]CURLED([M:SCL]LIGLED(TMPI2)-1)
            Assign "[M:GIC1]RATMLT"+num$(TMPI2+1)+"("+num$(TMPI)+")" With [M:SCL]RATMLT([M:SCL]LIGLED(TMPI2)-1)
            Assign "[M:GIC1]RATDIV"+num$(TMPI2+1)+"("+num$(TMPI)+")" With [M:SCL]RATDIV([M:SCL]LIGLED(TMPI2)-1)
          Endif
        Endif
      Next TMPI2
    Endif
  Next TMPI
 Endif
 Call RESET_INTCPYCOA ([M]CPY,[M]FCY) From INTCPYLIB
Endif
End


# Code is from SUBA0; Init_Cours
$CHARG_ZONES_DEV
# Initialize the commun screen SAICURLED
# CUR cannot be changed on the line, but the rate can be entered
Call INIT([M:GIC1]CUR,[M:GIC1]CPY,[M:GIC1]TYPRAT,[M:GIC1]RATDAT,0) From SUBSCL
Gosub CHARG_ZONES_DEV From SUBSCL
For J=0 To min([M:HAEF]NBRC,len(mess(0,2644,1))-1)
 [M:HAEF]RATDIVC(J) = [F:GIC]RATDIV(J)
 [M:HAEF]RATMLTC(J) = [F:GIC]RATMLT(J)
Next
Return

# Code is from SUBA0; Init_Cours
$INIT_COURS
Gosub INIT_COURS From SUBSCL
For I=0 To len(mess(0,2644,1))-1
 If [F:GCM]LED(I)<>""
  If [F:GCM]CUR(I)=[M:SCL]CURENT
   Assign "[M:HAEF]RATMLTC("+num$(I)+")" With 1
   Assign "[M:HAEF]RATDIVC("+num$(I)+")" With 1
  Elsif [F:GCM]CUR(I)=[M:SCL]CURLED([M:SCL]LIGLED(I)-1)
   Assign "[M:HAEF]RATMLTC("+num$(I)+")" With [M:SCL]RATMLT([M:SCL]LIGLED(I)-1)
   Assign "[M:HAEF]RATDIVC("+num$(I)+")" With [M:SCL]RATDIV([M:SCL]LIGLED(I)-1)
  Endif
 Endif
Next
If dim([M:GIC1]RAT1)>0
 For J=0 To min([M:SCL]NBRC,len(mess(0,2644,1)))-1
  If J<dim([M]CURMLT)
   [M:GIC1]RAT1(J) = [M:SCL]RATDIV(J)
   [M:GIC1]RAT2(J) = [M:SCL]RATMLT(J)
  Endif
 Next
 Gosub GRISE_COURS
Endif
Return

# [M]RAT1 : Rate divider
# [M]RAT2 : Rate multiplier
$GRISE_COURS
For I=0 To [M:SCL]NBRC-1
 If I>dim([M:GIC1]CURMLT)-1 : Break : Endif
 Case [F:GCM]DACRAT([M:SCL]LEDTYP(I)-1)
  When 1 :
   # Multiplicateur
   [M:GIC1]RAT1(I) = 1  : Diszo [M:GIC1]RAT1(I)
  When 2 :
   # Diviseur
   [M:GIC1]RAT2(I)  = 1 : Diszo [M:GIC1]RAT2(I)
  When 3 :
   # Les deux
   Actzo [M:GIC1]RAT1(I), RAT2(I)
 Endcase
 # Devise IN
 If GCURFLG=2 and GLEDFLG([M:SCL]LEDTYP(I))=2
   Diszo [M:GIC1]RAT1(I), RAT2(I)
 Endif
Next
Return

####################################################################################
$AFFICHE
If !GIMPORT : Affzo AFFICHE : Endif
Return

####################################################################################
#### Grid  #############################################
####################################################################################
$SETNOL
Local Integer NOL
NOL = nolign-1
Return

####################################################################################
Subprog IB_NBLIG
Raz GBOUT1,GBOUT2,GBOUT3,GBOUT4
# Intercompany enhancement - GBOUT6 = right click Dimensions option / button
Raz GBOUT6
If [M]CPYLIN(nolign-1)<>[M]CPY and [M]CPYLIN(nolign-1)<>"" : Call INTCPY_IB_NBLIG ([M]CPYLIN(nolign-1),[M]FCYLIN(nolign-1),3) From INTCPYLIB : Endif
# If it is decided to add the Other buttons - use SUBGA0; IB_NBLIG
End

Subprog B6_NBLIG
# Dimensions button
Affzo [M:GIC1]CCE1(nolign-1),CCE2(nolign-1),CCE3(nolign-1),CCE4(nolign-1),CCE5(nolign-1),CCE6(nolign-1),CCE7(nolign-1),CCE8(nolign-1),CCE9(nolign-1),CCE10(nolign-1)
Affzo [M:GIC1]CCE11(nolign-1),CCE12(nolign-1),CCE13(nolign-1),CCE14(nolign-1),CCE15(nolign-1),CCE16(nolign-1),CCE17(nolign-1),CCE18(nolign-1),CCE19(nolign-1),CCE20(nolign-1)
# Must reset mkstat to 4 here to enable the SAVE button because the Affzo clears it from INTCPYCCE
mkstat = 4
End

Subprog AS_NBLIG
[M:HAEF]TYPENT = 1
Gosub AFF_NBLIG From SUBGA0
End

Subprog C_NBLIG
# Dimension flag
GCCEMODIF = 0
If find(status,73,82) # Only new and inserted lines
  GCCEMODIF = 1
Endif
End

Subprog AVANT_NBLIG
Local Integer I
Gosub SETNOL
If [M]FCYLIN(NOL)="" : [M]FCYLIN(NOL) = [M]FCY : Endif
#109877.sn
If [M]CPYLIN(NOL)=""
  GCHKCPYLIN = 0
  [M]CPYLIN(NOL) = [M]CPY
Else
  GCHKCPYLIN = 1
Endif
#109877.en
If [M]TYPLIN(NOL)="" : [M]TYPLIN(NOL) = [M]TYP : Endif
If [M]JOULIN(NOL)="" : [M]JOULIN(NOL) = [M]JOU : Endif
If [M]CURLIN(NOL)="" : [M]CURLIN(NOL) = [M]CUR : Endif
# Need to reset the Global variables due to the AFF_NBLIG call
If [M]CPYLIN(NOL)<>GCURINTCPY : Call RESET_INTCPYCOA([M]CPYLIN(NOL),[M]FCYLIN(NOL)) From INTCPYLIB : Endif
Gosub AFF_NBLIG From SUBGA0
If !GIMPORT : Assign "[M:GIC1]COA"+num$(I)+"("+num$(NOL)+")" With [M:HAEF]COA(I-1) : Endif
If evalue("[M]ACC1("+num$(NOL)+")") <>""
  [M]TOTDEB -= [M]DEB(NOL)
  [M]TOTCDT -= [M]CDT(NOL)
Endif
End

Subprog APRES_NBLIG
Local Integer I
Gosub SETNOL
If !find(status,65,68,83)
 If evalue("[M]ACC1("+num$(NOL)+")") <>""
   [M]TOTDEB += [M]DEB(NOL)
   [M]TOTCDT += [M]CDT(NOL)
 Endif
 If GIMPORT : End : Endif  # 100597.n
 Affzo TOTDEB, TOTCDT, CURAFF
 If dim([M]SOLDE)>0   : Affzo SOLDE   : Endif
 If dim([M]CURAFF2)>0 : Affzo CURAFF2 : Endif
 # Display dimension screen if needed - not executed for a deleted line or lines
 If [M]CPY <> [M]CPYLIN(NOL)
  Call INTCPY_APRES_NBLIG (3, [M]CPYLIN(NOL), [M]FCYLIN(NOL)) From INTCPYLIB
 Endif
Endif
# Note: the status field is set to 0 after the first affzo is done below
If find(status,65,68,83)
 If GIMPORT : End : Endif  # 100597.n
 Affzo TOTDEB, TOTCDT, CURAFF
 If dim([M]SOLDE)>0   : Affzo SOLDE   : Endif
 If dim([M]CURAFF2)>0 : Affzo CURAFF2 : Endif
Endif
# Set it back to the header type in case clicking on header fields
Call LEC_GTE_LEG(GCURLEG,[M]TYP) From CPTLEC
End

####################################################################################
Subprog D_FCYLIN(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_FCYLIN(VALEUR)
Variable Char     VALEUR
End

Subprog C_FCYLIN(VALEUR)
Variable Char    VALEUR()
Local Decimal EXERCICE , PERIODE, I
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
#109877.sn
If GCHKCPYLIN = 1
  If [M]CPYLIN(nolign-1) <> [F:FCY]LEGCPY
    ##The site must belong to XX company
    GMESSAGE = func AFNC.MES1(mess(171,104,1),[M]CPYLIN(nolign-1))
    mkstat = 2 : End
  Endif
Endif
#109877.en

# Intercompany enhancement - Control GL and Dimensions
[M]CPYLIN(nolign-1) = [F:FCY]LEGCPY
Local Integer INTCPYOK  :  INTCPYOK = 1
  Call INTCPY_FCYLIN ([F:FCY]LEGCPY) From INTCPYLIB
  If mkstat : INTCPYOK = 0 : GMESSAGE = mess(159,104,1) : End  : Endif
  Call RESET_INTCPYCOA ([F:FCY]LEGCPY, VALEUR) From INTCPYLIB
  #### CATUA 87307 07/01/2013 - Check fiscal year/period for the target company
  If [M]CPYLIN(nolign-1)<>"" & [M]ACCDAT<>[0/0/0] & [M]CPYLIN(nolign-1)<>[M]CPY
    Call GETPERSOC([M]CPYLIN(nolign-1),GTYPGEN,[M]ACCDAT,EXERCICE,PERIODE) From CPTSUB
    Read [FIY]FIY0 = [M]CPYLIN(nolign-1);GTYPGEN;EXERCICE
    If fstat | [F:FIY]FIYSTA<>2
      ##The fiscal year for company XX is not open
      GMESSAGE = func AFNC.MES1(mess(71,101,1),[M]CPYLIN(nolign-1))
      mkstat = 2 : End
    Endif
    If [F:PER]PERSTA<>2
      ##The period for company XX is not open
      GMESSAGE = func AFNC.MES1(mess(72,101,1),[M]CPYLIN(nolign-1))
      mkstat = 2 : End
    Endif
  Endif
#####
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
End

Subprog AM_FCYLIN(VALEUR)
Variable Char    VALEUR()
Local Integer    CPYLINE, STAT, I, NEWNOL #109877.n
Local Decimal    WRAT
# If company exists on a line already then use that Document type, Journal code, and line Document no.
Gosub SETNOL
#CPYLINE = find([F:FCY]LEGCPY,[M]CPYLIN(0..NOL-1),[M]CPYLIN(NOL+1..[M]NBLIG)) #109877.o

#109877.sn
#CPYLINE (1) is used to check for existence [M]CPYLIN on the other lines and (2) is used as an index
Raz CPYLINE
Raz NEWNOL

If NOL<>0
  NEWNOL =  find([F:FCY]LEGCPY,[M]CPYLIN(0..NOL-1))
Endif

If NEWNOL
  CPYLINE = NEWNOL
Else
  NEWNOL = find([F:FCY]LEGCPY,[M]CPYLIN(NOL+1..[M]NBLIG))
  If NEWNOL
    CPYLINE = NEWNOL + NOL + 1
  Endif
Endif
#109877.en

If CPYLINE
  [M]JOULIN(nolign-1) = [M]JOULIN(CPYLINE-1)
  [M]TYPLIN(nolign-1) = [M]TYPLIN(CPYLINE-1)
  [M]DOCNUMLIN(nolign-1) = [M]DOCNUMLIN(CPYLINE-1)
  Affzo [M]TYPLIN(nolign-1),JOULIN(nolign-1),DOCNUMLIN(nolign-1)
  # If the company exists also assign the currency rates
  For I=0 To len(mess(0,2644,1))-1
    WRAT = evalue("[M]RATMLT"+num$(I+1)+"("+num$(CPYLINE-1)+")")
    Assign "[M]RATMLT"+num$(I+1)+"("+num$(nolign-1)+")" With WRAT
    WRAT = evalue("[M]RATDIV"+num$(I+1)+"("+num$(CPYLINE-1)+")")
    Assign "[M]RATDIV"+num$(I+1)+"("+num$(nolign-1)+")" With WRAT
  Next
# If the target company <> source and it is the first time entered then clear these fields so the validations take place
Elsif [M]CPY <> [M]CPYLIN(NOL)
  [M]TYPLIN(nolign-1) = "" : [M]JOULIN(nolign-1) = ""
  Affzo [M]TYPLIN(nolign-1),JOULIN(nolign-1)
Endif
# Must be done here as this is set by Company's legislation
Call LEC_CPY([M]CPY) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
#--- Initialization and controls of screens.
If [M]TYPLIN(nolign-1)<>""
  Call LEC_GTE_LEG(GCURLEG,[M]TYPLIN(nolign-1)) From CPTLEC
  Call RESET_INIMSKFMT(VALEUR,STAT)  From SUBGICA
  If STAT
    GMESSAGE=""
    Gosub MESSAGE From CPTAUTO
    GMESSAGE -= mess(86,105,1)+"\"+MESSA
    [M]TYPLIN(nolign-1) = "" : [M]JOULIN(nolign-1) = ""
    Affzo [M]TYPLIN(nolign-1),JOULIN(nolign-1)
  Endif
Endif
Call GETSOC(VALEUR) From DEVSUB
End

Subprog D_CPYLIN(VALEUR)
Variable Char    VALEUR()
Call LEC_FCY([M]FCY) From CPTLEC
VALEUR = [F:FCY]LEGCPY
Call LEC_CPY(VALEUR) From CPTLEC
End

####################################################################################
Subprog D_TYPLIN(VALEUR)
Variable Char    VALEUR()
# Sets the line Document Type to the header
If [M]TYPLIN(nolign-1)="" : VALEUR = [M]TYP : Endif
End

Subprog AS_TYPLIN(VALEUR)
Variable Char     VALEUR
# If the Line / Target company = the Header / Source company then skip this field
If [M]CPY = [M]CPYLIN(nolign-1) : mkstat = 2 : End  :  Endif
# If this company has already been entered then skip this field
Gosub SETNOL
If find([M]CPYLIN(nolign-1),[M]CPYLIN(0..NOL-1),[M]CPYLIN(NOL+1..[M]NBLIG)) : mkstat = 2 : End  :  Endif
End

Subprog C_TYPLIN(VALEUR)
Variable Char    VALEUR
Local Char IDENT(GLONGTE), TMPJOU(GLONJOU)
Call CONTEXE([F:GTE]ACS) From CPTSUB
If mkstat : End : Endif
If [F:GTE]PER>1 & find(GREP,"C","D") : Gosub SETDAT From SUBGA0 : Endif
If VALEUR <> [M]TYPLIN(nolign-1)
  [M]JOULIN(nolign-1) = [F:GTE]DEFJOU : Affzo [M]JOULIN(nolign-1)
Endif
TMPJOU = [M]JOULIN(nolign-1)
IDENT = VALEUR : Gosub CONT_GTE
If !mkstat
  # If manual number is not an option then clear out the manual document number
  If [F:GTE]MANNUM<>2 and [M]DOCNUMLIN(nolign-1)<>""
    [M]DOCNUMLIN(nolign-1) = ""
    Affzo [M]DOCNUMLIN(nolign-1)
  Endif
Endif
End

Subprog AM_TYPLIN(VALEUR)
Variable Char    VALEUR
If GIMPORT : End : Endif
Local Integer STAT
Call RESET_INIMSKFMT([M]FCYLIN(nolign-1),STAT)  From SUBGICA
If STAT
  GMESSAGE=""
  Gosub MESSAGE From CPTAUTO
  GMESSAGE -= mess(86,105,1)+"\"+MESSA
  mkstat = 2 : End
Endif
# If the Target Company uses Main and TYP's Main Ledger = None then do not allow
If GTYPGEN > 0 and [F:GTE]AUZLED(GTYPGEN-1) = 1
  GMESSAGE=""
  STAT = 43 : Gosub MESSAGE From CPTAUTO
  GMESSAGE -= mess(143,104,1)+"\"+MESSA
  mkstat = 2 : End
Endif
# If the Target Company uses Analytical and TYP's Analytical ledger = None then do not allow this TYP
If GTYPANA > 0 and [F:GTE]AUZLED(GTYPANA-1) = 1 and GTYPGEN <> GTYPANA
  GMESSAGE=""
  STAT = 43 : Gosub MESSAGE From CPTAUTO
  GMESSAGE -= mess(144,104,1)+"\"+MESSA
  mkstat = 2 : End
Endif
End

# From SUBLO1 with modifications
$CONT_GTE
# Journal compatible with this document type
If TMPJOU<>""
  Call LEC_JOU_LEG(GCURLEG,TMPJOU) From CPTLEC
  If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
    GMESSAGE = [F:JOU]JOU-mess(8,106,1)
    # Journal not authorized
    mkstat = 2 : Return
  Endif
Endif
Call CONTGTE(IDENT,GCURLEG,"") From SUBGTE
If mkstat : Raz mkstat : GOK=0 : Return : Endif
If [F:GTE]ENAFLG<>2    # Inactive Document type
 If !GIMPORT  : GMESSAGE = mess(22,107,1)-":"-IDENT+"\"+mess(2,126,1)
 Else         : GMESSAGE = mess(22,107,1)-IDENT-":"-mess(2,126,1)
 Endif
 mkstat = 2 : Return
Elsif [F:GTE]ACS<>""   # Access code
 Call CONTEXE([F:GTE]ACS) From CPTSUB
 If mkstat
  GMESSAGE = [F:GTE]ACS-GMESSAGE    # No execute permission
  mkstat = 2 : Return
 Endif
Endif
If [F:GTE]VCRREA<>2 & [F:GTE]VCRSIM<>2 : # Journal type not actual nor simulated - check per Christine
 GMESSAGE = [F:GTE]TYP-mess(43,106,1) : # Unauthorized journal type
 mkstat = 2 : Return
Endif
Return

####################################################################################
Subprog D_JOULIN(VALEUR)
Variable Char    VALEUR()
# Sets the line Journal code to the line type's default journal
If VALEUR="" : VALEUR = [F:GTE]DEFJOU : Endif
End

Subprog AS_JOULIN(VALEUR)
Variable Char     VALEUR
# Sets the line Journal code to the line type's default journal
If VALEUR="" : VALEUR = [F:GTE]DEFJOU : Endif
# If the Line / Target company = the Header / Source company then skip this field
If [M]CPY = [M]CPYLIN(nolign-1) : mkstat = 2 : End  :  Endif
# If this company has already been entered then skip this field
Gosub SETNOL
If find([M]CPYLIN(nolign-1),[M]CPYLIN(0..NOL-1),[M]CPYLIN(NOL+1..[M]NBLIG)) : mkstat = 2 : End  :  Endif
End

Subprog C_JOULIN(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
[M]JOULIN(NOL)=VALEUR
Call CONT_JOU (VALEUR,"[M]FCYLIN",[M]FCYLIN(NOL),[M]CPYLIN(NOL))

# Issue X3-58865 - 2017-10-18 by VAVIL : Control GESGIC function for POR legislation
# Issue X3-58865
If func PORLEGLIB.DIGSIGN("",[M]CPYLIN(NOL))
  If !func PORLEGLIB.CREGASOK(VALEUR,"",GMESSAGE)
     mkstat = 2 : End
  Endif
Endif
# End issue X3-58865
End

####################################################################################
Subprog IB_CURLIN
Gosub SETNOL
# The line currency cannot be changed, only the rate can be entered via the right click option
# The right click option is NOT available if source company = target company OR if the company has already been entered because of rate change
If [M]CPY = [M]CPYLIN(nolign-1) or find([M]CPYLIN(nolign-1),[M]CPYLIN(0..NOL-1),[M]CPYLIN(NOL+1..[M]NBLIG))
  Raz GBOUT2
Else
  GBOUT2 = mess(21,129,1) # Currency rate
Endif
End

Subprog AV_CURLIN(VALEUR)
Variable Char    VALEUR()
Local Integer I
# The line currency cannot be changed, only the rate can be entered via the right click option
Diszo [M]CURLIN(nolign-1)
# Code is from SUBA0; Charg_zones_dev
# Initialize the common screen SAICURLED for a new line
# CUR cannot be changed on the line, but the rate can be entered
Gosub SETNOL
If GCCEMODIF
  If [M]CPY <> [M]CPYLIN(nolign-1) and !find([M]CPYLIN(nolign-1),[M]CPYLIN(0..NOL-1),[M]CPYLIN(NOL+1..[M]NBLIG))
    Call INIT([M:GIC1]CUR,[M:GIC1]CPYLIN(nolign-1),[M:GIC1]TYPRAT,[M:GIC1]RATDAT,0) From SUBSCL
    Gosub CHARG_ZONES_DEV From SUBSCL
    Gosub INIT_COURS From SUBSCL
    For I=0 To len(mess(0,2644,1))-1
      If [F:GCM]LED(I)<>""
        If [F:GCM]CUR(I)=[M:SCL]CURENT
          Assign "[M:GIC1]RATMLT"+num$(I+1)+"("+num$(nolign-1)+")" With 1
          Assign "[M:GIC1]RATDIV"+num$(I+1)+"("+num$(nolign-1)+")" With 1
        Elsif [F:GCM]CUR(I)=[M:SCL]CURLED([M:SCL]LIGLED(I)-1)
          Assign "[M:GIC1]RATMLT"+num$(I+1)+"("+num$(nolign-1)+")" With [M:SCL]RATMLT([M:SCL]LIGLED(I)-1)
          Assign "[M:GIC1]RATDIV"+num$(I+1)+"("+num$(nolign-1)+")" With [M:SCL]RATDIV([M:SCL]LIGLED(I)-1)
        Endif
      Endif
    Next
  Endif
Endif
If [M]CPY = [M]CPYLIN(nolign-1)
# Always default the Source rates if the target company is the same as the source company
  For I=0 To len(mess(0,2644,1))-1
    Assign "[M:GIC1]RATMLT"+num$(I+1)+"("+num$(nolign-1)+")" With [M:HAEF]RATMLTC(I)
    Assign "[M:GIC1]RATDIV"+num$(I+1)+"("+num$(nolign-1)+")" With [M:HAEF]RATDIVC(I)
  Next
Endif
End

Subprog C_CURLIN(VALEUR)
Variable Char     VALEUR
# The line currency cannot be changed, only the rate can be entered via the right click option
End

