########################################
Funprog RATFMT(COL)
Value Libelle COL
#DIRAS - JIRA X3-35889 - 2017/05/15 - START
If mess([L]COL,10553,1)="" : End "-N:#" : Else : End "Nz+:2.3#" : Endif
#If mess([L]COL,553,1)="" : End "-N:#" : Else : End "Nz+:2.3#" : Endif
#DIRAS - JIRA X3-35889 - 2017/05/15 - END

########################################
Funprog CNSFMT(COL)
Value Libelle COL
#DIRAS - JIRA X3-35889 - 2017/05/15 - START
If mess([L]COL,10553,1)="" : End "-N:#" : Else : End "Nz+:5#" : Endif
#If mess([L]COL,553,1)="" : End "-N:#" : Else : End "Nz+:5#" : Endif
#DIRAS - JIRA X3-35889 - 2017/05/15 - END

########################################
Subprog D_ENDVLY(VALEUR)
Variable Date    VALEUR

#DIRAS - JIRA X3-35889 - 2017/05/15 - START
Filter [HREXK] Where DAT>[M:HREXK1]DAT & CPY=[M:HREXK1]CPY & FCY=[M:HREXK1]FCY
&     Order By Key CLE=DAT
Read [HREXK] First
Filter [HREXK]
If fstat : [L]VALEUR=[0/0/0] : Else [L]VALEUR=[F:HREXK]DAT : Endif

#Filter [EXK] Where DAT>[M:EXK1]DAT & CPY=[M:EXK1]CPY & FCY=[M:EXK1]FCY
#&     Order By Key CLE=DAT
#Read [EXK] First
#Filter [EXK]
#If fstat : [L]VALEUR=[0/0/0] : Else [L]VALEUR=[F:EXK]DAT : Endif
#DIRAS - JIRA X3-35889 - 2017/05/15 - END


End
