#&            - mess(J,554,1)+"\"+mess(10,123,1)
#  #            Tranche kilométrique :
#  #            Catégorie véhicule :
#  #            Zone obligatoire
#  [L]SUIZON   ="RAT"+num$(I)+"(J-1)"
#  [L]OK       =0
#  Break
# Endif
#Next
#DIRAS - JIRA X3-35889 - 2017/05/15 - END

Return

$DEVERROU
# le superviseur ne sait pas supprimer si la première composante de clef est vide !
#DIRAS - JIRA X3-35889 - 2017/05/15 - START
If [L]BOUT="S" & [L]CLECUR2(0)="_"
 Trbegin [HREXK]
  Update [HREXK] Where FCY=[L]CLECUR1 & CPY=[L]CLECUR2(0)
&                  & DAT=evalue("["+[L]CLECUR2(1)+"]")
&               With FCY=string$([L]CLECUR1<>"_",[L]CLECUR1)
&                  , CPY=string$([L]CLECUR2(0)<>"_",[L]CLECUR2(0))
  If [L]CLECUR1   ="_" : [L]CLECUR1   ="" : Endif
  If [L]CLECUR2(0)="_" : [L]CLECUR2(0)="" : Endif
 Commit
Endif

#If [L]BOUT="S" & [L]CLECUR2(0)="_"
# Trbegin [EXK]
#  Update [EXK] Where FCY=[L]CLECUR1 & CPY=[L]CLECUR2(0)
#&                  & DAT=evalue("["+[L]CLECUR2(1)+"]")
#&               With FCY=string$([L]CLECUR1<>"_",[L]CLECUR1)
#&                  , CPY=string$([L]CLECUR2(0)<>"_",[L]CLECUR2(0))
#  If [L]CLECUR1   ="_" : [L]CLECUR1   ="" : Endif
#  If [L]CLECUR2(0)="_" : [L]CLECUR2(0)="" : Endif
# Commit
#Endif
#DIRAS - JIRA X3-35889 - 2017/05/15 - END

Return

$EXEACT
# le superviseur ne sait pas supprimer si la première composante de clef est vide !
#DIRAS - JIRA X3-35889 - 2017/05/15 - START
If [L]BOUT="S" & [L]CLECUR2(0)=""
 Trbegin [HREXK]
  Update [HREXK] Where FCY=[L]CLECUR1 & CPY=[L]CLECUR2(0)
&                  & DAT=evalue("["+[L]CLECUR2(1)+"]")
&               With FCY=[L]CLECUR1+string$([L]CLECUR1="","_")
&                  , CPY=[L]CLECUR2(0)+string$([L]CLECUR2(0)="","_")
  If [L]CLECUR1   ="" : [L]CLECUR1   ="_" : Endif
  If [L]CLECUR2(0)="" : [L]CLECUR2(0)="_" : Endif
 Commit
Endif

#If [L]BOUT="S" & [L]CLECUR2(0)=""
