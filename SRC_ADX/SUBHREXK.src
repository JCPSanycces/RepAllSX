######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  GCURLEG=VALEUR
End


######################################################################################

######################################################################################
## Section automatically added (screen HREXK1) 05/25/2017 12:31:36 (DIRAS)
######################################################################################
Subprog AP_CPY(VALEUR)
Variable Char    VALEUR()

  If clalev([F:CPY])=0 : Local File COMPANY [CPY]  : Endif

  Read [CPY]CPY0 = VALEUR
  [M:HREXK1]LEG = [F:CPY]LEG
  Affzo [M:HREXK1]LEG

End
