#<AdxTL>@(#)0.0.0.0 $Revision$
Raz [V]GPILOBJ, [V]GBIDC1
#DIRAS - JIRA X3-35889 - 2017/05/15 - START
Call OBJET("HREXK",[V]GBIDC1,"") From GOBJET
#Call OBJET("EXK",[V]GBIDC1,"") From GOBJET
#DIRAS - JIRA X3-35889 - 2017/05/15 - End

End

$ACTION
#DIRAS - JIRA X3-35889 - 2017/05/15 - START
Case [L]ACTION
 When "OUVRE"        : Gosub OUVRE
 When "FREME"        : Gosub FREME
# When "OUVRE"        : Local Decimal RAT : Local Integer CNS
#DIRAS - JIRA X3-35889 - 2017/05/15 - END
 When "SETBOUT"      : [L]CHAINE+="A"

#DIRAS - JIRA X3-35889 - 2017/05/15 - START
 When "EFFMASK"      : Affzo [HREXK1] 20
 When "AFFMASK"      : Affzo [HREXK1] 20
 When "RAZCRE"       : Affzo [HREXK1] 20
 When "RAZDUP"       : Raz [HREXK1]ENDVLY

# When "EFFMASK"      : Affzo [EXK1] 20
# When "AFFMASK"      : Affzo [EXK1] 20
# When "RAZCRE"       : Affzo [EXK1] 20
# When "RAZDUP"       : Raz [EXK1]ENDVLY
#DIRAS - JIRA X3-35889 - 2017/05/15 - END

 When "LIENS"        : Gosub LIENS
 When "FILGAUCHE"    : [L]FILGAUCHE="BKT=1 & CAT=1"
 When "CLE_GAUCHE"   : [L]CLELISTE="DAT Desc;CPY;FCY"
 When "DEVERROU"     : Gosub DEVERROU
 When "EXEACT"       : Gosub EXEACT
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "CREATION"     : Gosub CREATION
 When "VERIF_MOD"    : Gosub VERIF_MOD

#DIRAS - JIRA X3-35889 - 2017/05/15 - START
 When "INIMOD"       : Read [HREXK] Curr
# When "INIMOD"       : Read [EXK] Curr
#DIRAS - JIRA X3-35889 - 2017/05/15 - END

 When "MODIF"        : Gosub MODIF
Endcase
Return

#DIRAS - JIRA X3-35889 - 2017/05/15 - START
$OUVRE
  Local Decimal RAT : Local Integer CNS
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FREME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
#DIRAS - JIRA X3-35889 - 2017/05/15 - END

$LIENS
#DIRAS - JIRA X3-35889 - 2017/05/15 - START
For [HREXK]reckey Where DAT=[M:HREXK1]DAT & CPY=[M:HREXK1]CPY & FCY=[M:HREXK1]FCY
 Assign "[M:HREXK1]RAT"+num$([F:HREXK]BKT)+"([F:HREXK]CAT-1)" With [F:HREXK]RAT
 Assign "[M:HREXK1]CNS"+num$([F:HREXK]BKT)+"([F:HREXK]CAT-1)" With [F:HREXK]CNS
Next

GCURLEG = [F:HREXK]LEG

#For [EXK]reckey Where DAT=[M:EXK1]DAT & CPY=[M:EXK1]CPY & FCY=[M:EXK1]FCY
# Assign "[M:EXK1]RAT"+num$([F:EXK]BKT)+"([F:EXK]CAT-1)" With [F:EXK]RAT
# Assign "[M:EXK1]CNS"+num$([F:EXK]BKT)+"([F:EXK]CAT-1)" With [F:EXK]CNS
#Next
#DIRAS - JIRA X3-35889 - 2017/05/15 - END

Return

$VERIF_CRE
$VERIF_MOD
#DIRAS - JIRA X3-35889 - 2017/05/15 - START ::DIRAS Query LM200::
For I=1 To len(mess(0,10553,1))
 J=evalue("find(0,[M:HREXK1]RAT"+num$(I)+"(0..[M:HREXK1]NBLIG-1))")
 If J
  [V]GMESSAGE =mess(353,200,1)-":"-mess(I,10553,1)+"\"+mess(354,200,1)-":"
&            - mess(J,10554,1)+"\"+mess(10,123,1)
  #            Tranche kilométrique :
  #            Catégorie véhicule :
  #            Zone obligatoire
  [L]SUIZON   ="RAT"+num$(I)+"(J-1)"
  [L]OK       =0
  Break
 Endif
Next

#For I=1 To len(mess(0,553,1))
# J=evalue("find(0,[M:EXK1]RAT"+num$(I)+"(0..[M:EXK1]NBLIG-1))")
# If J
