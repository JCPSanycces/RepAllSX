#&                  , CPY=[L]CLECUR2(0)+string$([L]CLECUR2(0)="","_")
#  If [L]CLECUR1   ="" : [L]CLECUR1   ="_" : Endif
#  If [L]CLECUR2(0)="" : [L]CLECUR2(0)="_" : Endif
# Commit
#Endif
#DIRAS - JIRA X3-35889 - 2017/05/15 - END

Return

$CREATION
#DIRAS - JIRA X3-35889 - 2017/05/15 - START
Delete [HREXK] =
If fstat=1
 [V]GOK  =-1
 [V]GLOCK="$HREXSKMETRE"-[M:HREXK1]CPY-[M:HREXK1]FCY-[M:HREXK1]DAT
 Return
Endif

For I=1 To len(mess(0,10553,1))
 For J=1 To [M:HREXK1]NBLIG
  [F:HREXK]   =[M:HREXK1]
  [F:HREXK]BKT=I
  [F:HREXK]CAT=J
  [F:HREXK]RAT=evalue("[M:HREXK1]RAT"+num$(I)+"(J-1)")
  [F:HREXK]CNS=evalue("[M:HREXK1]CNS"+num$(I)+"(J-1)")
  Gosub INICRE From GOBJSUB

  Write [HREXK]
  If fstat
   [V]GOK=0
   Call FSTA("HREXK") From GLOCK
   Break 2
  Endif
 Next
Next

