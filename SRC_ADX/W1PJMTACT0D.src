#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTACT0D 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:55"
A_USER  = "DOC"
A_STAMP = "20181109230555"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMTACT0D [PJTAC0D]
Gosub HORODAT
Local Inpbox "PJMTACT0D" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTAC0D] As [SIM_]
Grizo [PJTAC0D]45
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJTAC0D]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=25 : X2(0)=86 : Y1(0)=1 : Y2(0)=20
Return

$ON_OPECOMTEX
Onevent AFTER_CHANGE Gosub AMM_OPECOMTEX From W1PJMTACT0D
Return

$AMM_OPECOMTEX
Call AM_OPECOMTEX(zc)
If !mkstat & GOBJET
 zoncou = "OPECOMTEX" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OPECOMTEX(VALEUR)
Variable Clbfile VALEUR
## Action STD
Call AM_OPECOMTEX(VALEUR) From SUBPJTAC
If mkstat : GERR = 1 : GZONE = "OPECOMTEX" : GZNUM = 0 : Endif
Gosub _AFF
End

$CHG_STY
Return


