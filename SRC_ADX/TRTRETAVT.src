#<AdxTL>@(#)0.0.0.0 $Revision$
#--------------------------------------------------------------------------------------
# TRTRETAVT : Génération d'un avenant (copie du contrat) avec infos pour rétroactivité
#--------------------------------------------------------------------------------------
######################################################################################
# Modifications :
#     #FQ82073 - Initialisation de TIP.CTRDAT selon règle métier
######################################################################################

End

$ACTION
Case [L]ACTION
 When "OUVRE" :  Gosub OUVRE
 When "DEBUT" :  Gosub DEBUT
 When "OK"    :  Gosub OK
 When "FIN"   :  Gosub FIN
Endcase
Return

$OUVRE
Local Integer I, TYP, OK_CONTRAT
Local Char NOMVAR(250), WCTRNUM([V]GLONHRCTR), MESSAGE(250), TPARAM(250)(1..100)
Local Char SPLIT_SEP(1)
Local Date WCTRDAT
If !clalev([F:ID3])  : Local File EMPLOID   [ID3]  : Endif # FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom
[L]SPLIT_SEP = chr$(1)
Return

$DEBUT
Raz [M:DIA]
[L]I = 1    :  # On saute le premier paramètre "Origine"
For [L]NOMVAR = "REFNUM", "CTRNUM", "CTRDAT"
 [L]I += 1
 If [L]PARAM([L]I) <> ""
  [L]TYP = evalue("type([M:DIA]"+[L]NOMVAR+")")
  Case [L]TYP
   When -1
    # Ignorer
   When 1, 2, 4, 5, 6, 7, 9
    Assign "[M:DIA]"+[L]NOMVAR With val([L]PARAM([L]I))
   When 3
    Assign "[M:DIA]"+[L]NOMVAR With [L]PARAM([L]I)
   When Default
    Assign "[M:DIA]"+[L]NOMVAR With [L]PARAM([L]I)
  Endcase
# FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom
  If [L]NOMVAR = "REFNUM"
     Call UPD_NAMSRN(evalue("[M:DIA]"+[L]NOMVAR),"[M:DIA]","","SRN",0,0) From DIVPAYE
  Endif
 Endif
Next
Affzo [M:DIA]
Return

###########################
$OK
Gosub CONTROLE
If GOK
 Trbegin [HRCTR]
 Gosub TR1
 If GOK<=0
  [L]PARAM(5) = ""
  [L]PARAM(6) = ""
  Rollback
 Else
  [L]PARAM(5) = [L]WCTRNUM
  [L]PARAM(6) = num$([L]WCTRDAT)
  Commit
 Endif
Else
 Call ERREUR([L]MESSAGE) From GESECRAN
 FIN = 0 : Return
Endif
Return

###########################
$FIN
If GSTATUT<>GSTAOK
 [L]PARAM(5) = ""
 [L]PARAM(6) = ""
Endif
Return

#################
# Contrôle que le contrat a dupliquer est "compatible" avec les règles que l'on s'est imposé :
# Il ne doit pas y avoir de contrat "après" : en effet on va fermer ce contrat et ouvrir notre nouveau
#                                             contrat
# Mais on pourrait imaginer qu'il soit déjà fermé : contrat du 01/07 au 30/08 , on veut faire un contrat
#                                                   au 01/09 avec prise d'effet au 01/07 jusqu'au 30/08
#                                                   => dans ce cas date de contrat > date de fin ????
#################
$CONTROLE
GOK=1
[L]WCTRNUM = [M:DIA]CTRNUM    : # Permettrait de changer de numéro de contrat - non prévu pour l'instant
[L]WCTRDAT = [M:DIA]AVTCTRDAT : # Date de l'avenant (nouveau contrat)
Call CONTROLE_CONTRAT([M:DIA]REFNUM, [M:DIA]CTRNUM, [M:DIA]CTRDAT, [L]WCTRNUM, [L]WCTRDAT, [L]OK_CONTRAT, [L]MESSAGE)
If ![L]OK_CONTRAT
 GOK=0 : Return
Endif
Return

########################
# Génération d'un nouveau contrat par duplication .... TPARAM contient les valeurs à changer
#                                                      sous la forme NOMVAR=VALVAR , Séparateur
#                                                      libre (split_sep => chr$(1))
##################
$TR1
Raz [L]TPARAM, [L]I

[L]I += 1
[L]TPARAM([L]I) = "[F:HRCTR]RETTYP" + [L]SPLIT_SEP + num$([M:DIA]AVTRETTYP)

[L]I += 1
[L]TPARAM([L]I) = "[F:HRCTR]FLGRET" + [L]SPLIT_SEP + num$(2)

[L]I += 1
[L]TPARAM([L]I) = "[F:HRCTR]RETDATEFF" + [L]SPLIT_SEP + format$("D:YYYYMMDD", [M:DIA]AVTRETDATEFF)

[L]I += 1
[L]TPARAM([L]I) = "[F:HRCTR]RETSTATUT" + [L]SPLIT_SEP + num$(2)

[L]I += 1
[L]TPARAM([L]I) = "[F:HRCTR]RETCTRNUMORI" + [L]SPLIT_SEP + [M:DIA]CTRNUM

[L]I += 1
[L]TPARAM([L]I) = "[F:HRCTR]RETCTRDATORI" + [L]SPLIT_SEP + format$("D:YYYYMMDD", [M:DIA]CTRDAT)

[L]I += 1
[L]TPARAM([L]I) = "[F:HRCTR]RETGRD" + [L]SPLIT_SEP + [M:DIA]AVTRETGRD

Call DUPLICATION_CONTRAT([M:DIA]REFNUM, [M:DIA]CTRNUM, [M:DIA]CTRDAT, [L]TPARAM, [L]SPLIT_SEP,
&                        [L]WCTRNUM, [L]WCTRDAT,[M:DIA]AVTCTRGRD, 1)
If GOK<=0 : Return : Endif
Return


#######################
Subprog CONTROLE_CONTRAT(REFNUM, CTRNUM, CTRDAT, NEW_CTRNUM, NEW_CTRDAT, OK_CONTRAT, MESSAGE)
Value Char REFNUM(), CTRNUM()
Value Date CTRDAT
Value Char NEW_CTRNUM()
Value Date NEW_CTRDAT()
Variable Integer OK_CONTRAT
Variable Char MESSAGE()

# Rien de précisé dans le CDC concernant les contrôles à effectuer ... On prévoit l'étiquette, charge à
# l'analyse de préciser ce qu'il faut y mettre.

[L]OK_CONTRAT = 0

# MESSTAG
# [L]MESSAGE = "Contrat non éligible à un avenant avec rétroactivité"

[L]OK_CONTRAT = 1

End

###################
Subprog DUPLICATION_CONTRAT(REFNUM, CTRNUM, CTRDAT, TPARAM, SPLIT_SEP, NEW_CTRNUM, NEW_CTRDAT,NEW_CTRGRD, MODE)
Value Char REFNUM(), CTRNUM()
Value Date CTRDAT ()
Value Char TPARAM()(1..)
Value Char SPLIT_SEP()
Variable Char NEW_CTRNUM()
Variable Date NEW_CTRDAT
Variable Char NEW_CTRGRD()
Value Integer MODE

Local Integer I
Local Char NOMVAR(250), VALVAR(250)

If clalev([F:MOE])=0  : Local File MOTENT   [MOE]  : Endif
If clalev([F:ID])=0   : Local File EMPLOID   [ID]  : Endif

Readlock [F:HRCTR]CTR0 = [L]REFNUM ; [L]CTRNUM ; [L]CTRDAT
If fstat = 1
 [V]GOK = -1
 [V]GLOCK = "$EMPLOCTR"
 End
Elsif fstat <> 0
 [V]GOK = 0
 Call RSTA("HRCTR", [L]REFNUM + "/" + [L]CTRNUM + "/" + [L]CTRDAT) From GLOCK
 End
Endif

# Renseigner une date & un motif de "sortie" pour ce contrat
###############
##**72216
# Avant retro sur N contrat : Date de fin du contrat d'origine = date d'effet de l'avenant-1 (si vide)
# Désormais la date de fin du contrat d'origine = date de début de l'avenant-1 (si vide)
#####################################""
If [F:HRCTR]XITDAT=[0/0/0]
 ##**[F:HRCTR]XITDAT = max([M:DIA]AVTRETDATEFF-1,[L]CTRDAT)
 [F:HRCTR]XITDAT = [L]NEW_CTRDAT - 1
 [F:HRCTR]XITFNL = 1
 Read [MOE]MOE0=[L]NEW_CTRGRD
 If !fstat & [F:MOE]CTRXITAUT=2 & [F:MOE]CTRXITGRD<>""
  [F:HRCTR]XITGRD = [F:MOE]CTRXITGRD
 Else
  [F:HRCTR]XITGRD = "ACT"        :#Par défaut au cas où
 Endif
 # Réénregistrer ce contrat
 Rewrite [F:HRCTR]
 If fstat <> 0
  [V]GOK = 0
  Call FSTA("HRCTR") From GLOCK
 Endif
Endif

Read [F:HRCTR]CTR0 = [L]REFNUM ; [L]CTRNUM ; [L]CTRDAT
If fstat <> 0
 [V]GOK = 0
 Call RSTA("HRCTR", [L]REFNUM + "/" + [L]CTRNUM + "/" + [L]CTRDAT) From GLOCK
 End
Endif

If GINTMT
 Read [F:ID]ID0 = [L]REFNUM
 If fstat <> 0
  [V]GOK = 0
  Call RSTA("ID", [L]REFNUM ) From GLOCK
  End
 Endif
Endif

# Duplication
If [L]NEW_CTRNUM <> ""
 [F:HRCTR]CTRNUM = [L]NEW_CTRNUM
Endif
[F:HRCTR]CTRDAT = [L]NEW_CTRDAT
[F:HRCTR]CTRGRD = [L]NEW_CTRGRD
#LIPET - 2018-02-19 - X3-76984 - START
#Always check for backpay
If GPAYE & dim([F:HRCTR]FLGCREBUL)>=0 : [F:HRCTR]FLGCREBUL=2 : Endif
#LIPET - 2018-02-19 - X3-76984 - END
If GINTMT & [F:ID]FLGINT=2
 # Réaffectation des dates de fin avec la date de début de l'avenant
 [F:HRCTR]XITDAT=[L]NEW_CTRDAT
 If [F:HRCTR]ENDCON<>[0/0/0]
  [F:HRCTR]ENDCON=max([F:HRCTR]HRENDCON,[L]NEW_CTRDAT)
 Endif
 If [F:HRCTR]ENDTRY<>[0/0/0]
  [F:HRCTR]ENDTRY=max([F:HRCTR]ENDTRY,[L]NEW_CTRDAT)
 Endif
Else
 Raz [F:HRCTR]XITDAT, [F:HRCTR]XITGRD
 Raz [F:HRCTR]ENDCON, [F:HRCTR]ENDTRY
Endif

# Modification des valeurs au moment de la dupli - Exploitation de TPARAM
For [L]I = 1 To dim([L]TPARAM)
 If [L]TPARAM([L]I) = "" : Break : Endif
 Raz [L]NOMVAR, [L]VALVAR
 Call SPLIT([L]TPARAM([L]I), [L]NOMVAR, [L]VALVAR, [L]SPLIT_SEP)
 Case evalue("type("+[L]NOMVAR+")")
  When -1
   # Tiens, la variable n'existe pas , on ignore
  When 1, 2, 4, 5, 6, 7, 9
    Assign [L]NOMVAR With val([L]VALVAR)
  When 3
   # Date
   Assign [L]NOMVAR With [L]VALVAR
  When Default
   Assign [L]NOMVAR With [L]VALVAR
 Endcase
Next

If GINTMT & [F:ID]FLGINT=2
 Raz [F:HRCTR]NBRPSN
 Gosub DUP_PRESTATION
 If [V]GOK < 1 : End : Endif
Endif

Write [F:HRCTR]
If fstat <> 0
 [V]GOK = 0
 Call FSTA("HRCTR") From GLOCK
 End
Endif

Gosub DUP_CTRCPT
If [V]GOK < 1 : End : Endif

# X3-38103 - Duplication of EMPLOCTRFRA
Gosub DUP_CTRFRA
If [V]GOK < 1 : End : Endif

#114651
Gosub DUP_EMPSBD
If [V]GOK < 1 : End : Endif

Call SET_EMPCTR([F:HRCTR]REFNUM, [F:HRCTR]CTRNUM, 0) From TRTRETAVT    : # Recalcul EMPCTR
If [V]GOK < 1 : End : Endif

#114651
#JOJAC - 2016-07-28 - REQ114309 - START
#Call SET_EMPLOID([F:CTR]REFNUM)
Call SET_EMPLOID([F:HRCTR]REFNUM)
#JOJAC - 2016-07-28 - REQ114309 - END
If [V]GOK < 1 : End : Endif

End

######################################
$DUP_CTRCPT
If clalev([F:CPR])=0 : Local File EMPLOCTRCPT [CPR] : Endif
If clalev([F:CPR2])=0 : Local File EMPLOCTRCPT [CPR2] : Endif

Read [F:CPR2]CPR0= [L]REFNUM ; [L]CTRNUM ; [L]CTRDAT
If !fstat
 Raz [F:CPR]
 [F:CPR] = [F:CPR2]
 [F:CPR]REFNUM = [L]REFNUM
 [F:CPR]CTRNUM = [L]CTRNUM
 [F:CPR]CTRDAT = [F:HRCTR]CTRDAT
 Write [F:CPR]
 If fstat
   [V]GOK = 0
   Call FSTA("CPR") From GLOCK
   Return
 Endif
Endif
Return

# X3-38103 - Duplication of EMPLOCTRFRA
$DUP_CTRFRA
If !func AFNC.ACTIV("FFRPH") Then Return : Endif

If clalev([F:CTRFRA])=0  : Local File EMPLOCTRFRA [CTRFRA] : Endif
If clalev([F:CTRFRA2])=0 : Local File EMPLOCTRFRA [CTRFRA2] : Endif

Read [F:CTRFRA2]CTRFRA0=[L]REFNUM;[L]CTRNUM;[L]CTRDAT
If !fstat
 Raz [F:CTRFRA]
 [F:CTRFRA] = [F:CTRFRA2]
 [F:CTRFRA]REFNUM = [L]REFNUM
 [F:CTRFRA]CTRNUM = [L]CTRNUM
 [F:CTRFRA]CTRDAT = [F:HRCTR]CTRDAT

 # Entry point to update EMPLOCTRFRA
 GPOINT = "DUP_CTRFRA" : Gosub ENTREE From EXEFNC

 Write [F:CTRFRA]
 If fstat
   [V]GOK = 0
   Call FSTA("CTRFRA") From GLOCK
   Return
 Endif
Endif
Return

#114651
######################################
$DUP_EMPSBD
  If !clalev([F:ESB]) : Local File EMPSBD [ESB] : Endif
  If !clalev([F:ESB2]): Local File EMPSBD [ESB2] : Endif

  Filter [F:ESB2] Where [F:ESB2]REFNUM=[L]REFNUM & [F:ESB2]CTRNUM=[L]CTRNUM & [F:ESB2]CTRDAT=[L]CTRDAT
  For [ESB2]ESB0
    Raz [F:ESB]
   [F:ESB] = [F:ESB2]
   [F:ESB]REFNUM = [L]REFNUM
   [F:ESB]CTRNUM = [L]CTRNUM
   #LIPET - 2018-02-19 - X3-76984 - START
   #JOJAC - 2016-07-28 - REQ114309 - START
   #[F:ESB]CTRDAT = [F:CTR]CTRDAT
   #[F:ESB]CTRDAT = [F:CTR1]CTRDAT
   [F:ESB]CTRDAT = [F:HRCTR]CTRDAT
   #JOJAC - 2016-07-28 - REQ114309 - END
   #LIPET - 2018-02-19 - X3-76984 - END
   If dim([F:ESB]CREDAT)>0 : [F:ESB]CREDAT = date$     : Endif
    If dim([F:ESB]CRETIM)>0 : [F:ESB]CRETIM = time      : Endif
    If dim([F:ESB]CREUSR)>0 : [F:ESB]CREUSR = GUSER     : Endif
    Write [F:ESB]
    If fstat
      GOK = 0 : Call FSTA("ESB") From GLOCK
      Break
    Endif
  Next
  Filter [F:ESB2]
Return

######################################
$DUP_PRESTATION
If clalev([F:PSN])=0 : Local File PRESTATION [PSN] : Endif
If clalev([F:PSN2])=0 : Local File PRESTATION [PSN2] : Endif
Local Integer I
For [PSN2]PSN0 Where CTRNUM=[L]CTRNUM & CTRDAT=[L]CTRDAT & PSNSTRDAT>=[F:HRCTR]RETDATEFF
 I+=1
 Raz [F:PSN]
 [F:PSN] = [F:PSN2]
 [F:PSN]REFNUM = [L]REFNUM
 [F:PSN]CTRNUM = [L]CTRNUM
 [F:PSN]CTRDAT = [F:HRCTR]CTRDAT
 [F:PSN]PSNNUM = I
 Raz [F:PSN]BUL
 Write [F:PSN]
 If fstat
   [V]GOK = 0
   Call FSTA("PSN") From GLOCK
   Break
 Endif
 If [F:PSN2]BUL=""
  [F:PSN2]BUL=mess(1,303,1)
  Rewrite [F:PSN2]
  If fstat
   [V]GOK = 0
   Call FSTA("PSN2") From GLOCK
   Break
  Endif
 Endif
Next
If [V]GOK < 1 : Return : Endif
[F:HRCTR]NBRPSN=I
Return

#114651
#---------------------------------------------------------------
# Mise à jour du Nb CTR dans EMPLOID
#---------------------------------------------------------------
Subprog SET_EMPLOID(REFNUM)
Value Char REFNUM()

  If !clalev([F:CTR1]) : Local File EMPLOCTR [CTR1] : Endif
  If !clalev([F:ID2])  : Local File EMPLOID   [ID2] : Endif

  Filter [F:CTR1]  Where [F:CTR1]REFNUM = [L]REFNUM
  If rowcount([CTR1])
    Readlock [F:ID2]ID0 = [F:CTR1]REFNUM
    If fstat=1
      [V]GOK=-1 : [V]GLOCK="$EMPLOID"-[L]REFNUM
    Elsif !fstat
      [F:ID2]NBRCTR = rowcount([CTR1])
      Rewrite [ID2]
      If fstat
        GOK=0 : Call FSTA("ID2") From GLOCK
      Endif
    Endif
  Endif
End

#---------------------------------------------------------------
# Recopie de la mise à jour de EMPCTR dans le traitement SUBCTR
#---------------------------------------------------------------
Subprog SET_EMPCTR(REFNUM, CTRNUM, FLGVAR)
Value Char REFNUM(), CTRNUM()
Value Integer FLGVAR

If not clalev([F:CTR1]) : Local File EMPLOCTR [CTR1] : Endif
If not clalev([F:ECT]) : Local File EMPCTR [ECT] : Endif

Local Integer I

Filter [F:CTR1]  Where [F:CTR1]REFNUM = [L]REFNUM & [F:CTR1]CTRNUM=[L]CTRNUM
Read [F:CTR1]CTR0 Last

If fstat : Raz [F:CTR1] : Endif
Readlock [F:ECT]ECT0 = [L]REFNUM ; [L]CTRNUM
If fstat=1
 [V]GOK=-1 : [V]GLOCK="$EMPCTR"-[L]REFNUM-[L]CTRNUM
Elsif fstat
 [F:ECT]REFNUM = [L]REFNUM
 [F:ECT]CTRNUM = [L]CTRNUM
 [F:ECT]NBRCTR = rowcount([CTR1])
 [F:ECT]FCY    = [F:CTR1]ETRFCY
 [F:ECT]SRV    = [F:CTR1]ETRSRV
 [F:ECT]PRF    = [F:CTR1]PROPRF
 [F:ECT]CREUSR = [V]GUSER
 [F:ECT]CREDAT = date$
 [F:ECT]CRETIM = time
 Write [F:ECT]
 If fstat
    [V]GOK=0 : Call FSTA("ECT") From GLOCK
 Endif
Else
 [F:ECT]NBRCTR = rowcount([CTR1])
 If !FLGVAR
  [F:ECT]FCY    = [F:CTR1]ETRFCY
  [F:ECT]SRV    = [F:CTR1]ETRSRV
  [F:ECT]PRF    = [F:CTR1]PROPRF
 Endif
 [F:ECT]UPDUSR = [V]GUSER
 [F:ECT]UPDDAT = date$
 [F:ECT]UPDTIM = time
 If [F:ECT]NBRCTR>0
     Rewrite [ECT]
     If fstat
         GOK=0 : Call FSTA("ECT") From GLOCK
     Endif
 Else
     Delete [ECT]ECT0 = [L]REFNUM ; [L]CTRNUM
     If fstat=1 | fstat>5
         GOK=0 : Call RSTA("ECT",[L]REFNUM-[L]CTRNUM) From GLOCK
     Endif
 Endif
Endif
If GOK=1
 I = 0
 For [CTR1]CTR0
  I +=1
  [F:CTR1]NUMLIG = I
  Rewrite [CTR1]Curr
  If fstat
    GOK=0 : Call FSTA("HRCTR") From GLOCK : Break
  Endif
 Next
Endif
Filter [F:CTR1]
#ADNGO - 2017-02-16 - START
##** Waiting time management**#
# FQ82073 -  Initialisation de TIP.CTRDAT selon règle métier
#Local Char W_TIP_REFNUM(GLONMAT)
#Local Char W_TIP_CTRNUM(GLONCTR)
#Local Date W_TIP_CTRDAT
#Local Date W_TIP_XITDAT
# #Local Date W_TIP_RETDATEFF : # BUG90196
# #Local Integer W_TIP_FLGRET :  # BUG90196

#Local Char WACTION(30)
#Local Char CRITCTRL (250)
#WACTION="APRES_CRE"
#Filter [F:CTR1]  Where [F:CTR1]REFNUM = [L]REFNUM & [F:CTR1]CTRNUM=[L]CTRNUM
#Read [F:CTR1]CTR0 Last
#Filter [F:CTR1]
#If !fstat
#  W_TIP_REFNUM=[L]REFNUM
#  W_TIP_CTRNUM=[L]CTRNUM
#  W_TIP_CTRDAT=[M]AVTCTRDAT
#  #W_TIP_CTRDAT=[M]AVTRETDATEFF # BUG90196
#  Raz W_TIP_XITDAT
#  #Raz W_TIP_RETDATEFF # BUG90196
#  Gosub MAJ_TIMEMP2 From SUBCTR
#  GMESSAGE=""
#  If GOK<0   : End : Endif
#Endif

Local Char W_TIP_REFNUM(GLONEML)
Local Char W_TIP_CTRNUM(GLONHRCTR)
Local Date W_TIP_CTRDAT
Local Date W_TIP_XITDAT
 #Local Date W_TIP_RETDATEFF : # BUG90196
 #Local Integer W_TIP_FLGRET :  # BUG90196

Local Char WACTION(30)
Local Char CRITCTRL (250)
WACTION="APRES_CRE"
Filter [F:CTR1]  Where [F:CTR1]REFNUM = [L]REFNUM & [F:CTR1]CTRNUM=[L]CTRNUM
Read [F:CTR1]CTR0 Last
Filter [F:CTR1]
If !fstat
  W_TIP_REFNUM=[L]REFNUM
  W_TIP_CTRNUM=[L]CTRNUM
  W_TIP_CTRDAT=[M]AVTCTRDAT
  #W_TIP_CTRDAT=[M]AVTRETDATEFF # BUG90196
  Raz W_TIP_XITDAT
  #Raz W_TIP_RETDATEFF # BUG90196
  Gosub MAJ_TIMEMP2 From SUBCTR
  GMESSAGE=""
  If GOK<0   : End : Endif
Endif
#ADNGO - 2017-02-16 - END
End

#-----------------
# SPLIT classique
#-----------------
Subprog SPLIT(PARAM, NOMVAR, VALVAR, SEP)
Value Char PARAM()
Variable Char NOMVAR(), VALVAR()
Value Char SEP

Local Integer POS

Raz [L]NOMVAR, [L]VALVAR

If vireblc([L]PARAM, 4) = "" : End : Endif
[L]POS = instr(1, [L]PARAM, [L]SEP)
If [L]POS
[L]NOMVAR = left$([L]PARAM, [L]POS-1)
[L]VALVAR = right$([L]PARAM, [L]POS+1)
Endif

End

#--------------------------------------------------------
# Suppression d'avenant de type rétroactivité collective
#--------------------------------------------------------
Subprog AS_AVTRETTYP(VALEUR)
Variable Integer  VALEUR
[V]GMENLOC(2) = 1
If GINTMT
 If clalev([F:ID])=0   : Local File EMPLOID   [ID]  : Endif
 If [M:DIA]REFNUM<>[F:ID]REFNUM
  Read [ID]ID0=[M:DIA]REFNUM
  If fstat : End : Endif
 Endif
 If [F:ID]FLGINT=2 : [V]GMENLOC(1) = 1 : Endif
Endif
End

Subprog C_AVTCTRDAT(VALEUR)
Variable Date    VALEUR
# Date de "début" de contrat
# => Ne peut être antérieure au début du contrat "dupliqué" ,
If [L]VALEUR <= [M:DIA]CTRDAT
 # mess(100,10701,1) : La date du nouveau contrat ne peut pas être antérieure à la date de contrat d'origine
 [V]GMESSAGE = mess(100,10701,1)
 mkstat = 2 : End
Endif

##**72216
# Date de "fin" de contrat
# => Ne peut être antérieure à la fin du contrat "dupliqué" ,
Local File EMPLOCTR [CTRW]
Read [F:CTRW]CTR0=[M:DIA]REFNUM;[M:DIA]CTRNUM;[M:DIA]CTRDAT
If !fstat & [F:CTRW]XITDAT<>[0/0/0]
 If [L]VALEUR <= [F:CTRW]XITDAT
  # mess(100,10701,1) : La date du nouveau contrat ne peut pas être antérieure à la date de contrat d'origine
  Close Local File [CTRW]
  [V]GMESSAGE = mess(100, 10701, 1)
  mkstat = 2 :  End
 Endif
Endif

#Le nouveau contrat (avenant retro) doit être le "dernier"
Filter [F:CTRW] Where [F:CTRW]REFNUM = [M:DIA]REFNUM & [F:CTRW]CTRNUM = [M:DIA]CTRNUM
&                & [F:CTRW]CTRDAT >= [L]VALEUR
Read [F:CTRW]CTR0 First
Filter [F:CTRW]
If fstat <= 2
 # mess(103,10701,1) : Il existe déjà un contrat postérieur à la date demandée
 Close Local File [CTRW]
 [V]GMESSAGE = mess(103,10701,1)
 mkstat = 2 : End
Endif

# Il ne doit pas y avoir de bulletins sur une période > à la date de début de l'avenant
Local File VALEMP [VEPW]
Filter [F:VEPW] Where [F:VEPW]EMP = [M:DIA]REFNUM & [F:VEPW]CTRNUM = [M:DIA]CTRNUM
&                        & [F:VEPW]ENDDAT >= [L]VALEUR
Read [F:VEPW]VEP0 First
Filter [F:VEPW]
If fstat <= 2
 Close Local File [VEPW]
 # mess(104,10701,1) : Il existe déjà des bulletins au delà de la date demandée
 [V]GMESSAGE = mess(104,10701,1)
 mkstat = 2 : End
Endif

Close Local File [CTRW], [VEPW]
End

Subprog C_AVTRETDATEFF(VALEUR)
Variable Date    VALEUR
If [L]VALEUR >= [M:DIA]AVTCTRDAT
# mess(101,10701,1) : La date de prise d'effet est incohérente par rapport à la date de contrat
 [V]GMESSAGE = mess(101, 10701, 1)
 mkstat = 2 : End
Endif

# On autorise désormais à faire de la retro sur N contrat sauf pour les intermittents
If GINTMT
 If clalev([F:PSNW])=0 : Local File PRESTATION [PSNW] : Endif
 If clalev([F:ID])=0   : Local File EMPLOID   [ID]  : Endif
 If [M:DIA]REFNUM<>[F:ID]REFNUM
  Read [ID]ID0=[M:DIA]REFNUM
  If fstat : End : Endif
 Endif
 If [F:ID]FLGINT=2
  If [L]VALEUR < [M:DIA]CTRDAT
   #mess(102,701,1) : La date de prise d'effet ne peut pas être antérieure à la date de contrat d'origine
   [V]GMESSAGE = mess(102, 701, 1)
   mkstat = 2 : End
  Endif
  Filter[PSNW] Where CTRNUM=[M:DIA]CTRNUM & CTRDAT=[M:DIA]CTRDAT & PSNSTRDAT=VALEUR
  Look [PSNW]PSN0 First
  Filter[PSNW]
  If fstat
   #Aucune prestation débutant à cette date
   [V]GMESSAGE = mess(175,701,1)
   mkstat = 2 : End
  Endif
 Endif
 Close File [PSNW]
Endif
End

Subprog AS_AVTRETDATEFF(VALEUR)
Variable Date     VALEUR
If GINTMT  & [L]VALEUR = [0/0/0]
 If clalev([F:PSNW])=0 : Local File PRESTATION [PSNW] : Endif
 If clalev([F:ID])=0   : Local File EMPLOID   [ID]  : Endif
 Local Char MAXBUL (GLONVCR)
 If [M:DIA]REFNUM<>[F:ID]REFNUM
  Read [ID]ID0=[M:DIA]REFNUM
  If fstat : End : Endif
 Endif
 If [F:ID]FLGINT=2
  # Propose par défaut la première prestation du contrat d'origine du dernier bulletin existant
  For [PSNW] Where CTRNUM=[M:DIA]CTRNUM & CTRDAT=[M:DIA]CTRDAT & BUL<>""
   If MAXBUL<>[F:PSNW]BUL
    VALEUR=[F:PSNW]PSNSTRDAT
    MAXBUL=[F:PSNW]BUL
   Endif
  Next
 Endif
 Close File [PSNW]
Endif
If [L]VALEUR = [0/0/0] : [L]VALEUR = [M:DIA]CTRDAT : Endif
End

Subprog AS_AVTCTRDAT(VALEUR)
Variable Date     VALEUR
If GINTMT  & [L]VALEUR = [0/0/0]
 If clalev([F:CTRW])=0   : Local File EMPLOCTR   [CTRW]  : Endif
 If clalev([F:ID])=0   : Local File EMPLOID   [ID]  : Endif
 If [M:DIA]REFNUM<>[F:ID]REFNUM
  Read [ID]ID0=[M:DIA]REFNUM
  If fstat : End : Endif
 Endif
 If [F:ID]FLGINT=2
  Read [F:CTRW]CTR0 = [M:DIA]REFNUM ; [M:DIA]CTRNUM ; [M:DIA]CTRDAT
  If !fstat & [F:CTRW]XITDAT<>[0/0/0]
   [L]VALEUR=[F:CTRW]XITDAT+1
  Endif
 Endif
 Close File [CTRW]
Endif
If [L]VALEUR = [0/0/0] : [L]VALEUR = datesyst : Endif
End
