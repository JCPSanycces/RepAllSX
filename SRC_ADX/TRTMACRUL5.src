#<AdxTL>@(#)9.0.0.0 $Revision$
######################################################################################################################
# Affectation des valeurs pour la création d'un contrat de garantie depuis la saisie d'une facture de vente (Prêt)
######################################################################################################################
$SET_HEA_INFO
  Case IMPZON
     When "CONNAM"     
       [M:CON1]CONNAM = GSZWARNAMRULE
       [M:CON0]COVLOWLEV = 1
       [M:CON1]CONORI = 4
       [M:CON1]CONORIVCR = [M:MACW]MACORIVCR
       [M:CON1]CONORIVCRL = [M:MACW]MACORIVCRL
     When "SALFCY"
       [M:CON0]SALFCY = [M:MACW]SALFCY
     When "CONBPC"
       [M:CON0]CONBPC = [M:MACW]BPCNUM
     When "CONCOT"
       [M:CON1]CONCOT = GSZWARMACRULE
     When "SIUDAT"
       [M:CON4]SIUDAT = [M:MACW]MACPURDAT
     When "CONAMT"
       [M:CON4]CONAMT = 0
     When "CUR"
       [M:CON0]CUR = [M:MACW]CUR
  Endcase
Return
