#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End

#----------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "FILTRE"  : Gosub FILTRE
 When "EPURE"   : Gosub EPURE
 When "FERME"   : Gosub FERME
Endcase
Return

$OUVRE
Case TABLE
 When "AWRKHISSUI"
 When "AWRKHISMES"
  If clalev([F:AWO])=0  : Local File AWRKHISDES [AWO]  : Endif
  If clalev([F:AWJ])=0  : Local File AWRKHISJOI [AWJ]  : Endif
 When Default
  Local Integer OK , I , STAT , SECONDES , NBEPU , NBTOT
  Local Date    DATFIC
  Local Char    REP(10) , EXT(10) , SERVEUR(GLONADS) , DOSSIER(GLONADS)
  Local Char    ORDSYS(250) , FICTRA(GDIMFIC) , RAC(50)
Endcase
Return

$EPURE
Case TABLE
 When "AWRKHISSUI"
 When "AWRKHISMES"
  If !SIMUL
   Delete [AWO] Where CHRONO=[F:F1]CHRONO
   If fstat=1
    GOK = -1 : GLOCK = "$AWRKHISDES"-[F:F1]CHRONO : Return
   Endif
   Delete [AWJ] Where CHRONO=[F:F1]CHRONO
   If fstat=1
    GOK = -1 : GLOCK = "$AWRKHISJOI"-[F:F1]CHRONO : Return
   Endif
  Endif
Endcase
Return

$FILTRE
Case TABLE
 When "AWRKHISMES"
 When "AWRKHISSUI"
 When Default   : FILTSUP = '1=0'
Endcase
Return

$FERME
Case TABLE
 When "AWRKHISMES"
 When "AWRKHISSUI"
 When Default
  Gosub EPURE_TMP
  NRDEL = NBEPU
  NBRES = NBTOT
Endcase
Return

$EPURE_TMP
If clalev([F:ABP])=0 : Local File ABATPAR [ABP] : Endif
Read [ABP] First
# On épure aussi dans le serveur batch
SERVEUR = [F:ABP]APPLI :#109897 OK
Close Local File [ABP]

# Epuration des fichiers temporaires utilisés par meladx
REP = "tmp"
For DOSSIER=nomap,SERVEUR
 For EXT = "txt" , "jnt" , "tra"
  If filinfo(filpath(REP,"","",DOSSIER),0)>=0 :#109897
   Gosub EPUR1
  Endif
 Next EXT
Next DOSSIER

#109897
REP = GBATCHDIR+"/tmp"
For DOSSIER=GDOSX3
 For EXT = "txt" , "jnt" , "tra"
  If filinfo(filpath(REP,"","",DOSSIER),0)>=0 :#109897
   Gosub EPUR1
  Endif
 Next EXT
Next DOSSIER

# Epuration des fichiers temporaires utilisés par AIMP/meladx
Local Char    FICTMP(GDIMFIC)
REP = "tmp"
RAC = "jobrpt" : # Superviseur
For DOSSIER=nomap,SERVEUR
 If filinfo(filpath(REP,"","",DOSSIER),0)>=0 :#109897
  Gosub EPUR2
 Endif
Next DOSSIER

#109897
REP = GBATCHDIR+"/tmp"
RAC = "jobrpt" : # Superviseur
For DOSSIER=GDOSX3
 If filinfo(filpath(REP,"","",DOSSIER),0)>=0 :#109897
  Gosub EPUR2
 Endif
Next DOSSIER

Return


$EPUR1
   ORDSYS = 'lsadx -a "'+DOSSIER+'" '+REP+' '+EXT
   Local File (FIC(250)) From System ORDSYS As [ENR]
   For [ENR]
    If pat([F:ENR]FIC,"M*")
     NBTOT += 1
     FICTRA = filpath(REP,[F:ENR]FIC,EXT,DOSSIER)
     SECONDES  = filinfo(FICTRA,9)
     DATFIC = [01/01/1970]+int(SECONDES/(24*3600))
     If DATFIC<=REFDAT
      If TRACEDET
       Call ECR_TRACE(DOSSIER-[F:ENR]FIC+"."+EXT-":"-format$("D:",DATFIC),0) From GESECRAN
      Endif
      NBEPU += 1
      If !SIMUL
       Call EFFACE(FICTRA,STAT) From ORDSYS
      Endif
     Endif
    Endif
   Next ENR
   Close Local File [ENR]
Return

$EPUR2
  ORDSYS = 'lsadx -a "'+DOSSIER+'" '+REP+' '+RAC+'*'
  Local File (FIC(250)) From System ORDSYS As [ENR]
  For [ENR]
   NBTOT += 1
   # Issue 86266 - 2012-12-04 by VPO : decouper nom de fichier pour filpath
   #FICTRA = filpath(REP,[F:ENR]FIC,"",DOSSIER)
   FICTMP=func AFNC.PARTSEP([F:ENR]FIC,1,".")
   EXT=func AFNC.PARTSEP([F:ENR]FIC,2,".")
   FICTRA = filpath(REP,FICTMP,EXT,DOSSIER)
   #
   SECONDES  = filinfo(FICTRA,9)
   DATFIC = [01/01/1970]+int(SECONDES/(24*3600))
   If DATFIC<=REFDAT
    If TRACEDET
     Call ECR_TRACE(DOSSIER-[F:ENR]FIC-":"-format$("D:",DATFIC),0) From GESECRAN
    Endif
    NBEPU += 1
    If !SIMUL
     Call EFFACE(FICTRA,STAT) From ORDSYS
    Endif
   Endif
  Next ENR
  Close Local File [ENR]
Return

