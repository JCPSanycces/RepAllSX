#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
## Section automatically added (Object INVEXT) 01/14/2015 18:45:00 (RICAR)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "SETBOUT"   : Gosub SETBOUT
 When "EXEBOUT"   : Gosub EXEBOUT
 When "LIENS"     : Gosub LIENS
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "RAZDUP"    : Gosub RAZDUP
 When "APRES_CRE" : Gosub APRES_CRE
 When "ANNULE"    : Gosub ANNULE
 When Default
Endcase
Return

######################################################################################
######################################################################################
$OUVRE
#Tables
If !clalev([F:CUN])   : Local File CUNSESSION [CUN] : Endif
If !clalev([F:CUD])   : Local File CUNLISDET  [CUD] : Endif
If !clalev([F:CUL])   : Local File CUNLISTE   [CUL] : Endif
If !clalev([F:FCY])   : Local File FACILITY   [FCY] : Endif
If !clalev([F:ITV])   : Local File ITMMVT     [ITV] : Endif
If !clalev([F:STJ])   : Local File STOJOU     [STJ] : Endif
If !clalev([F:ITF])   : Local File ITMFACILIT [ITF] : Endif
If !clalev([F:ITM])   : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:INVD1]) : Local File INVENTD    [INVD1] : Endif
If !clalev([F:FIY])   : Local File FISCALYEAR [FIY] : Endif
If !clalev([F:PER])   : Local File PERIOD     [PER] : Endif
# BRBAN 104427#US2
If !clalev([F:ORD])   : Local File ORDERS     [ORD] : Endif
# -

#Variables
Local Char I_ITMREF(255),I_STOFCY(255),I_LOT(255),I_SLO(255),I_SERNUM(255),I_PALNUM(255)
Local Char I_CTRNUM(255),I_PCU(255),I_STA(255),I_PCUSTUCOE(255),I_OWNER(255),I_LOC(255)
Local Char I_QLYCTLDEM(255),I_CUNSSSNUM(255),I_CUNLISNUM(255),I_CUNSSSDES(255),I_STU(5),I_CUNLISDES(255)
Local Integer I_NUMLIN,I_ITMLISNUM,I_ERR,I_CUNSSSSTA,I_ICON,LEDT,ANSWER
Local Decimal I_QTY,I_PCUSTUCOE,I_PHY,I_CTL,I_REJ,I_POT,I_ACT,I_COE,I_ITV_PHY,I_ITV_CTL,I_ITV_REJ
#Licence control
Local Integer PFIN, PCTRADDON, PCTRADDONV

Return
######################################################################################
######################################################################################
$SETBOUT

If !find([M:INV1]ICO2,'128','129') | GREP='M'
  Call VIREBOUT(CHAINE,"l") From GOBJET
Endif

If [M:INV1]ICO1<>'128'| [F:FIY]FIYEND <> [M:INV1]REFDAT | [M:INV1]ICO2<>'128' | GREP='M'
  Call VIREBOUT(CHAINE,"x") From GOBJET
Endif
Return
######################################################################################
######################################################################################
$EXEBOUT
Case BOUT
  When 'l'
    If !find([M:INV1]ICO2,'128','129') | GREP='M'
      Return
    Endif
    Gosub LOAD_DATA
  When 'x'
    If [M:INV1]ICO1<>'128'| [F:FIY]FIYEND <> [M:INV1]REFDAT | [M:INV1]ICO2<>'128' | GREP='M'
      Return
    Else
      Gosub RELIT From GOBJSUB
    Endif
Endcase
Return
######################################################################################
######################################################################################
$LOAD_DATA

Call OUVRE_TRACE (mess(1,2927,1)-':'-mess([M:INV1]ORIGIN,2052,1)) From LECFIC
Call TEMPON('O') From GESECRAN
Call ECR_TRACE(mess(195,195,1)-'-'-mess(144,141,1)-'-'-format$('DD4',date$),0) From GESECRAN

Case [M:INV1]ORIGIN
  When 1  : Gosub INVENT
  When 2  : Gosub STOCKDAY
Endcase

# Update CALCDAT field
Trbegin [F:INV]
[F:INV]CALCDAT = date$
Rewrite [F:INV]
If !fstat : Commit : Else : Call FSTA('INV') From GLOCK : Rollback : Endif

[M:INV1]CALCDAT = [F:INV]CALCDAT
Affzo [M:INV1]CALCDAT
# -

Gosub LOAD_SCREEN

Call ECR_TRACE(mess(195,195,1)-'-'-mess(124,100,1)-'-'-format$('DD4',date$),0) From GESECRAN
Call TEMPOFF From GESECRAN
Call LEC_TRACE   From LECFIC
Call FERME_TRACE From LECFIC

Gosub RELIT From GOBJSUB
Return
######################################################################################
######################################################################################
$INVENT

# Reset Variables
Gosub RAZ_VAR

# Check the inventories that aren't closed and show them in trace
Link [F:CUN] With  [F:FCY]FCY0=[F:CUN]STOFCY As [STK] Where [F:FCY]LEGCPY=[M:INV1]CPY & ([F:CUN]CUNSSSDAT>=[M:INV1]STRDAT & [F:CUN]CUNSSSDAT<=[M:INV1]ENDDAT) #& [F:CUN]CUNSSSDAT=[M:INV1]REFDAT
For [STK]
  If [F:CUN]CUNSSSSTA<>3 : Call ECR_TRACE(mess(7,21,1)-[F:CUN]CUNSSSNUM-":"-mess(2522,200,1)-mess([F:CUN]CUNSSSSTA,2722,1),-1) From GESECRAN : Endif
Next
Close File [STK]
# -

Delete [F:INVD] Where [F:INVD]CPY = [M:INV1]CPY & [F:INVD]REFDAT=[M:INV1]REFDAT

Link [F:CUD] With [F:CUL]CUL0=[F:CUD]CUNSSSNUM;[F:CUD]CUNLISNUM , [F:CUN]CUN0=[F:CUL]CUNSSSNUM, [F:FCY]FCY0=[F:CUN]STOFCY, [F:ITM]ITM0=[F:CUD]ITMREF As [STK]
Filter [STK] Where [F:FCY]LEGCPY=[M:INV1]CPY & ([F:CUN]CUNSSSDAT>=[M:INV1]STRDAT & [F:CUN]CUNSSSDAT<=[M:INV1]ENDDAT) & [F:CUN]CUNSSSSTA=3 & [F:CUD]CUNLISSTA<>3
& Order By [F:CUD]ITMREF;[F:CUD]STOFCY;[F:CUD]LOT;[F:CUD]SLO;[F:CUD]SERNUM;[F:CUD]PALNUM;[F:CUD]CTRNUM;[F:CUD]PCU;[F:CUD]STA;[F:CUD]PCUSTUCOE;[F:CUD]QLYCTLDEM;[F:CUD]OWNER;[F:CUD]LOC;[F:CUN]CUNSSSNUM;
& [F:CUL]CUNLISNUM;[F:CUD]ITMLISNUM Asc
For [STK]
  If (([L]I_ITMREF<>[F:CUD]ITMREF) | ([L]I_STOFCY<>[F:CUD]STOFCY) | ([L]I_LOT<>[F:CUD]LOT) | ([L]I_SLO<>[F:CUD]SLO) |
&    ([L]I_SERNUM<>[F:CUD]SERNUM) | ([L]I_PALNUM<>[F:CUD]PALNUM) | ([L]I_CTRNUM<>[F:CUD]CTRNUM) | ([L]I_PCU<>[F:CUD]PCU)| ([L]I_STA<>[F:CUD]STA) |
&    ([L]I_PCUSTUCOE<>[F:CUD]PCUSTUCOE) | ([L]I_QLYCTLDEM<>[F:CUD]QLYCTLDEM) | ([L]I_OWNER<>[F:CUD]OWNER) | ([L]I_LOC<>[F:CUD]LOC)) & [L]I_ITMREF<>''
    Trbegin [F:INVD]
    [F:INVD]ITMREF = [L]I_ITMREF
    [F:INVD]STOFCY = [L]I_STOFCY
    [F:INVD]LOT    = [L]I_LOT
    [F:INVD]SLO    = [L]I_SLO
    [F:INVD]SERNUM = [L]I_SERNUM
    [F:INVD]PALNUM = [L]I_PALNUM
    [F:INVD]CTRNUM = [L]I_CTRNUM
    [F:INVD]PCU    = [L]I_PCU
    [F:INVD]STA    = [L]I_STA
    [F:INVD]STU    = [L]I_STU
    [F:INVD]PCUSTUCOE = [L]I_PCUSTUCOE
    [F:INVD]QLYCTLDEM = [L]I_QLYCTLDEM
    [F:INVD]OWNER  = [L]I_OWNER
    [F:INVD]LOC    = [L]I_LOC
    [F:INVD]CUNSSSNUM = [L]I_CUNSSSNUM
    [F:INVD]CUNLISNUM = [L]I_CUNLISNUM
    [F:INVD]ITMLISNUM = [L]I_ITMLISNUM
    [F:INVD]CUNSSSDES = [L]I_CUNSSSDES
    [F:INVD]CPY       = [F:INV]CPY
    [F:INVD]REFDAT    = [F:INV]REFDAT
    [F:INVD]QTY       = [L]I_QTY
    [F:INVD]CUNLISDES = [L]I_CUNLISDES
    #BRBAN 104427#US2
    [F:INVD]WIP    = 1
    # -
    [L]I_NUMLIN +=1
    [F:INVD]NUMLIN = [L]I_NUMLIN
    Write [F:INVD]
    If !fstat : Commit : Else : Call FSTA('INVD') From GLOCK : Rollback : Endif
    #Reset qty
    [L]I_QTY = 0
  Endif

  # Write null content to check if all inventorys were considered
  If [L]I_CUNSSSNUM<>[F:CUD]CUNSSSNUM & [L]I_CUNSSSNUM<>''
    Read [F:INVD1]INVD3=[M:INV1]CPY;[M:INV1]REFDAT;[L]I_CUNSSSNUM
    If fstat
      Raz [INVD1]
      Trbegin [INVD1]
      [L]I_NUMLIN +=1
      [INVD1]NUMLIN    = [L]I_NUMLIN
      [INVD1]CPY       = [M:INV1]CPY
      [INVD1]REFDAT    = [M:INV1]REFDAT
      [INVD1]CUNSSSNUM = [L]I_CUNSSSNUM
      [INVD1]CUNLISNUM = [L]I_CUNLISNUM
      [INVD1]CUNLISDES = [L]I_CUNLISDES
      [INVD1]ITMLISNUM = [L]I_ITMLISNUM
      Write [INVD1]
      If !fstat : Commit : Else : Call FSTA('INVD1') From GLOCK : Rollback : Endif
    Endif
  Endif
  If [L]I_CUNLISNUM <> [F:CUL]CUNLISNUM
    [L]I_QTY = [F:CUD]QTYSTUNEW
  Else
    [L]I_QTY += [F:CUD]QTYSTUNEW
  Endif
  [L]I_ITMREF     = [F:CUD]ITMREF
  [L]I_STOFCY     = [F:CUD]STOFCY
  [L]I_LOT        = [F:CUD]LOT
  [L]I_SLO        = [F:CUD]SLO
  [L]I_SERNUM     = [F:CUD]SERNUM
  [L]I_PALNUM     = [F:CUD]PALNUM
  [L]I_CTRNUM     = [F:CUD]CTRNUM
  [L]I_PCU        = [F:CUD]PCU
  [L]I_STA        = [F:CUD]STA
  [L]I_PCUSTUCOE  = [F:CUD]PCUSTUCOE
  [L]I_QLYCTLDEM  = [F:CUD]QLYCTLDEM
  [L]I_OWNER      = [F:CUD]OWNER
  [L]I_LOC        = [F:CUD]LOC
  [L]I_CUNSSSNUM  = [F:CUL]CUNSSSNUM
  [L]I_CUNLISNUM  = [F:CUL]CUNLISNUM
  [L]I_ITMLISNUM  = [F:CUD]ITMLISNUM
  [L]I_CUNSSSDES  = [F:CUN]CUNSSSDES
  [L]I_CUNSSSSTA  = [F:CUN]CUNSSSSTA
  [L]I_STU        = [F:ITM]STU
  [L]I_CUNLISDES  = [F:CUL]CUNLISDES
Next
Filter [STK]
Close File [STK]

# Write last record
Trbegin [F:INVD]
[F:INVD]ITMREF = [L]I_ITMREF
[F:INVD]STOFCY = [L]I_STOFCY
[F:INVD]LOT    = [L]I_LOT
[F:INVD]SLO    = [L]I_SLO
[F:INVD]SERNUM = [L]I_SERNUM
[F:INVD]PALNUM = [L]I_PALNUM
[F:INVD]CTRNUM = [L]I_CTRNUM
[F:INVD]PCU    = [L]I_PCU
[F:INVD]STA    = [L]I_STA
[F:INVD]STU    = [L]I_STU
[F:INVD]PCUSTUCOE = [L]I_PCUSTUCOE
[F:INVD]QLYCTLDEM = [L]I_QLYCTLDEM
[F:INVD]OWNER  = [L]I_OWNER
[F:INVD]LOC    = [L]I_LOC
[F:INVD]CUNSSSNUM = [L]I_CUNSSSNUM
[F:INVD]CUNLISNUM = [L]I_CUNLISNUM
[F:INVD]ITMLISNUM = [L]I_ITMLISNUM
[F:INVD]CUNSSSDES = [L]I_CUNSSSDES
[F:INVD]CUNLISDES = [L]I_CUNLISDES
[F:INVD]CPY       = [F:INV]CPY
[F:INVD]REFDAT    = [F:INV]REFDAT
[F:INVD]QTY       = [L]I_QTY
[F:INVD]CUNLISDES = [L]I_CUNLISDES
#BRBAN 104427#US2
[F:INVD]WIP    = 1
# -
[L]I_NUMLIN +=1
[F:INVD]NUMLIN = [L]I_NUMLIN
Write [F:INVD]
If !fstat : Commit : Else : Call FSTA('INVD') From GLOCK : Rollback : Endif
#-

# Write null content to check if all inventorys were considered
If [L]I_CUNSSSNUM<>[F:CUD]CUNSSSNUM & [L]I_CUNSSSNUM<>''
  Read [F:INVD1]INVD3=[M:INV1]CPY;[M:INV1]REFDAT;[L]I_CUNSSSNUM
  If fstat
    Raz [INVD1]
    Trbegin [INVD1]
    [L]I_NUMLIN +=1
    [INVD1]NUMLIN    = [L]I_NUMLIN
    [INVD1]CPY       = [M:INV1]CPY
    [INVD1]REFDAT    = [M:INV1]REFDAT
    [INVD1]CUNSSSNUM = [L]I_CUNSSSNUM
    [INVD1]CUNLISNUM = [L]I_CUNLISNUM
    [INVD1]ITMLISNUM = [L]I_ITMLISNUM
    [INVD1]CUNLISDES = [L]I_CUNLISDES
    Write [INVD1]
    If !fstat : Commit : Else : Call FSTA('INVD1') From GLOCK : Rollback : Endif
  Endif
Endif
# BRBAN 104427#US2 Write WIP Items
If [M:INV1]WIPFLG=2
  Gosub WIP_ITMREF
Endif
# -
Return
######################################################################################
######################################################################################
$STOCKDAY

Gosub RAZ_VAR

Delete [F:INVD] Where [F:INVD]CPY = [M:INV1]CPY & [F:INVD]REFDAT=[M:INV1]REFDAT

Link [F:ITV] With [F:FCY]FCY0=[F:ITV]STOFCY, [F:ITF]ITF0 = [F:ITV]ITMREF;[F:ITV]STOFCY, [F:ITM]ITM0 = [F:ITV]ITMREF  As [STK]
Filter [STK] Where [F:FCY]LEGCPY=[M:INV1]CPY
For [STK]
  Raz [L]I_PHY, [L]I_CTL, [L]I_REJ
  Filter [F:STJ] Where [F:STJ]ITMREF=[F:ITV]ITMREF & [F:STJ]STOFCY=[F:ITV]STOFCY & [F:STJ]IPTDAT>[M:INV1]REFDAT & [F:STJ]UPDCOD = 2 & [F:STJ]REGFLG <> 2
  For [F:STJ]
    [L]I_COE = 1
    If find([F:ITF]STOMGTCOD,3,4)
      [L]I_POT = [F:STJ]POT
      [L]I_ACT = [F:STJ]ACT
      If [L]I_POT = 0 : [L]I_POT = 100 : Endif
      If [L]I_ACT = 0 : [L]I_ACT = 1   : Endif
      Case [F:ITF]STOMGTCOD
        When 3 : [L]I_COE = ([L]I_POT/100)
        When 4 : [L]I_COE = [L]I_ACT
      Endcase
    Endif
    Case mid$([F:STJ]STA,1,1)
      When "A" : [L]I_PHY += ([F:STJ]QTYSTU*[L]I_COE)
      When "Q" : [L]I_CTL += ([F:STJ]QTYSTU*[L]I_COE)
      When "R" : [L]I_REJ += ([F:STJ]QTYSTU*[L]I_COE)
    Endcase
  Next
  Filter [F:STJ]

  [L]I_ITV_PHY= ([F:ITV]PHYSTO+[F:ITV]PLFPHYSTO+[F:ITV]BPRPHYSTO+[F:ITV]SCOPHYSTO)
  [L]I_ITV_CTL= ([F:ITV]CTLSTO+[F:ITV]PLFCTLSTO+[F:ITV]BPRCTLSTO+[F:ITV]SCOCTLSTO)
  [L]I_ITV_REJ= ([F:ITV]REJSTO+[F:ITV]PLFREJSTO+[F:ITV]BPRREJSTO+[F:ITV]SCOREJSTO)

  [L]I_QTY = ([L]I_ITV_PHY+[L]I_ITV_CTL+[L]I_ITV_REJ)-([L]I_PHY+[L]I_CTL+[L]I_REJ)

  Trbegin [F:INVD]
  [F:INVD]CPY    = [F:INV]CPY
  [F:INVD]REFDAT = [F:INV]REFDAT
  [F:INVD]ITMREF = [F:ITV]ITMREF
  [F:INVD]STOFCY = [F:ITV]STOFCY
  [F:INVD]PCU    = [F:ITM]PCU
  [F:INVD]STU    = [F:ITM]STU
  [F:INVD]QTY    = [L]I_QTY
  #BRBAN 104427#US2
  [F:INVD]WIP    = 1
  # -
  [L]I_NUMLIN +=1
  [F:INVD]NUMLIN = [L]I_NUMLIN
  Write [F:INVD]
  If !fstat
    Commit
  Else
    Call FSTA('INVD') From GLOCK
    Rollback
  Endif
Next
Filter [STK]
Close File [STK]

# BRBAN 104427#US2 Write WIP Items
If [M:INV1]WIPFLG=2
  Gosub WIP_ITMREF
Endif
# -
Return
######################################################################################
######################################################################################
$LOAD_SCREEN
#Screen Reset
Gosub GRID_RESET

Gosub SET_ICONS

If [M:INV1]ORIGIN=2 : Return : Endif
# Fill grid with CUNSSSNUM
Filter [F:INVD] Where [F:INVD]CPY = [M:INV1]CPY & [F:INVD]REFDAT=[M:INV1]REFDAT
& Order By [F:INVD]CUNSSSNUM;[F:INVD]CUNLISNUM Asc
For [F:INVD]
  If [L]I_CUNLISNUM <> [F:INVD]CUNLISNUM & [L]I_CUNLISNUM<>'' & [L]I_ITMREF <> ''
    [M:INV1]CUNSSSNUM([L]I_NUMLIN) =  [L]I_CUNSSSNUM
    [M:INV1]CUNSSSDES([L]I_NUMLIN) =  [L]I_CUNSSSDES
    [M:INV1]CUNLISNUM([L]I_NUMLIN) =  [L]I_CUNLISNUM
    [M:INV1]CUNLISDES([L]I_NUMLIN) =  [L]I_CUNLISDES
    [L]I_NUMLIN += 1
  Endif
  [L]I_CUNSSSNUM = [F:INVD]CUNSSSNUM
  [L]I_CUNSSSDES = [F:INVD]CUNSSSDES
  [L]I_CUNLISNUM = [F:INVD]CUNLISNUM
  [L]I_CUNLISDES = [F:INVD]CUNLISDES
  [L]I_ITMREF    = [F:INVD]ITMREF
Next
Filter [F:INVD]

If [L]I_CUNLISNUM = [F:INVD]CUNLISNUM & [L]I_CUNLISNUM<>'' & [L]I_ITMREF <> ''
  [M:INV1]CUNSSSNUM([L]I_NUMLIN) =  [L]I_CUNSSSNUM
  [M:INV1]CUNSSSDES([L]I_NUMLIN) =  [L]I_CUNSSSDES
  [M:INV1]CUNLISNUM([L]I_NUMLIN) =  [L]I_CUNLISNUM
  [M:INV1]CUNLISDES([L]I_NUMLIN) =  [L]I_CUNLISDES
  [L]I_NUMLIN += 1
Endif
[M:INV1]NBLIG = [L]I_NUMLIN
Affzo [M:INV1]

Return
######################################################################################
######################################################################################
$RAZ_VAR

Raz I_ITMREF,I_STOFCY,I_LOT,I_SLO,I_SERNUM,I_PALNUM,I_CTRNUM
Raz I_PCU,I_STA,I_PCUSTUCOE,I_OWNER,I_LOC,I_QLYCTLDEM,I_NUMLIN
Raz I_ITMLISNUM,I_QTY,I_PCUSTUCOE,I_CUNSSSNUM,I_CUNLISNUM,I_CUNSSSDES,I_CUNLISDES
Raz I_ERR,I_CUNSSSSTA,I_STU

Return
######################################################################################
######################################################################################
$GRID_RESET
Raz I_CUNSSSNUM,I_CUNSSSDES,I_NUMLIN,I_ITMREF
For I=0 To [M:INV1]NBLIG-1
  Raz [M:INV1]CUNSSSNUM(I),[M:INV1]CUNSSSDES(I)
Next
Raz [M:INV1]NBLIG
Affzo [M:INV1]
Return
######################################################################################
######################################################################################
$SET_ICONS
# Icon change
#ICO1 - Calculado
#ICO2 - Período de fecho
#127 - red; 128 - green ; 129 - yellow

# Get the main general ledger
Call LECLEDMAIN(1,[M:INV1]CPY,[L]LEDT) From CPTDIV
# Get fiscal year
Filter [F:FIY] Where [F:FIY]FIYSTR<=[M:INV1]REFDAT & [F:FIY]FIYEND>=[M:INV1]REFDAT & [F:FIY]LEDTYP=[L]LEDT & [F:FIY]CPY=[M:INV1]CPY
Read [F:FIY] First
If fstat
    Call ECR_TRACE(mess(7,101,1), 1) From GESECRAN  #Fiscal year not yet defined
    Filter [F:FIY]
    [M:INV1]ICO2='127'
    Return
Endif
Filter [F:FIY]

Filter [F:PER] Where [F:PER]PERSTR<=[M:INV1]REFDAT & [F:PER]PEREND>=[M:INV1]REFDAT & [F:PER]FIYNUM=[F:FIY]FIYNUM & [F:PER]CPY=[F:FIY]CPY & [F:PER]LEDTYP= [F:FIY]LEDTYP
Read [F:PER] First
If !fstat
  If [F:PER]PERSTOSTA=4
    If [F:PER]PEREND = [M:INV1]REFDAT
      [M:INV1]ICO2='128'
    Else
      [M:INV1]ICO2='129'
    Endif
  Else
    [M:INV1]ICO2='127'
  Endif
Else
  [M:INV1]ICO2='127'
Endif
Affzo [M:INV1]ICO2

Filter [F:INVD] Where [F:INVD]CPY=[M:INV1]CPY & [F:INVD]REFDAT =[M:INV1]REFDAT
Read [F:INVD] First
If fstat
  [M:INV1]ICO1 = '127' #Red light
  Affzo [M:INV1]ICO1
  Return
Endif

[L]I_ICON=0
If [M:INV1]ORIGIN=1
  Link [F:CUN] With  [F:FCY]FCY0=[F:CUN]STOFCY As [STK]
  #Filter [STK] Where [F:FCY]LEGCPY=[M:INV1]CPY & [F:CUN]CUNSSSDAT=[M:INV1]REFDAT
  Filter [STK] Where [F:FCY]LEGCPY=[M:INV1]CPY & [F:CUN]CUNSSSDAT>=[M:INV1]STRDAT & [F:CUN]CUNSSSDAT<=[M:INV1]ENDDAT
  For [F:STK]
    Read [F:INVD]INVD2(2)=[M:INV1]CPY;[F:CUN]CUNSSSNUM
    If !fstat
      [L]I_ICON=2
    Else
      Link [F:CUD] With [F:CUL]CUL0=[F:CUD]CUNSSSNUM;[F:CUD]CUNLISNUM As [STK2] Where [F:CUL]CUNSSSNUM=[F:CUN]CUNSSSNUM #& [F:CUN]CUNSSSSTA <> 3
      Read [STK2] First
      If !fstat
        [L]I_ICON=1 : Close File [STK2]
        Break
      Endif
      If clalev([STK2]) : Close File [STK2] : Endif
    Endif
  Next
  Filter [STK]
  Close File [STK]
Else
  Read [F:INVD]INVD0=[M:INV1]CPY;[M:INV1]REFDAT
  If !fstat
    [L]I_ICON=2
  Endif
Endif

Case [L]I_ICON
 When 0 : [M:INV1]ICO1 = '127' #Red light
 When 1 : [M:INV1]ICO1 = '129' #Yellow light
 When 2 : [M:INV1]ICO1 = '128' #Green light
Endcase
Affzo [M:INV1]ICO1
# -

Return
######################################################################################
######################################################################################
$LIENS

If [M:INV1]ORIGIN = 2
  Diszo [M:INV1]STRDAT,ENDDAT
Else
  Actzo [M:INV1]STRDAT,ENDDAT
Endif
Affzo [M:INV1]STRDAT,ENDDAT

Gosub LOAD_SCREEN

Return
######################################################################################
######################################################################################
$VERIF_MOD
Gosub VERIF
If OK<=0 : Return : Endif

If [M:INV1]ORIGIN<>[F:INV]ORIGIN
  [L]ANSWER = 1
  Call OUINON(mess(176,7711,1),[L]ANSWER) From GESECRAN
  If [L]ANSWER = 1
    OK = 0
  Else
    Delete [F:INVD] Where [F:INVD]CPY=[M:INV1]CPY & [F:INVD]REFDAT=[M:INV1]REFDAT
    Gosub LOAD_SCREEN
  Endif
Endif
Return
######################################################################################
######################################################################################
$VERIF

If [M:INV1]ORIGIN=1
  If ([M:INV1]STRDAT>[M:INV1]REFDAT | [M:INV1]ENDDAT<[M:INV1]REFDAT)
    Call ERREUR(mess(72,104,1)-format$('DD2',[M:INV1]REFDAT)-":"-mess(135,141,1)-format$('DD2',[M:INV1]STRDAT)-'-'-format$('DD2',[M:INV1]ENDDAT)) From GESECRAN
    OK =0
  Endif

  If [M:INV1]ENDDAT - [M:INV1]STRDAT > 10
    Call ERREUR(mess(1,274,1)-mess(2,147,1)-"10"-mess(38,104,1)) From GESECRAN
    OK =0
  Endif
Endif

Return
######################################################################################
######################################################################################
$VERIF_CRE
Gosub VERIF
If OK<=0 : Return : Endif
Return
######################################################################################
######################################################################################
$RAZDUP
[M:INV1]ICO1 = '127'
[M:INV1]ICO2 = '127'
Affzo [M:INV1]ICO1,ICO2
#Screen Reset
Gosub GRID_RESET
Return
######################################################################################
######################################################################################
$APRES_CRE

Gosub SET_ICONS

Return
######################################################################################
######################################################################################
$ANNULE
Delete [F:INVD] Where [F:INVD]CPY=[F:INV]CPY & [F:INVD]REFDAT=[F:INV]REFDAT
Return
######################################################################################
######################################################################################
$WIP_ITMREF
# BRBAN 104427#US2
Link [ORD] With [ITM]ITM0=[F:ORD]ITMREF, [F:FCY]FCY0=[F:ORD]STOFCY As [LNK]
Filter [F:LNK] Where find([F:ORD]WIPSTA,1,2) & [F:ORD]WIPTYP=5 & [F:FCY]LEGCPY=[M:INV1]CPY &
& [F:ORD]ENDDAT>=gdat$(01,01,year([M:INV1]REFDAT)) & [F:ORD]ENDDAT<=[M:INV1]REFDAT
& Order By Key ORD1


For [LNK]
  Trbegin [F:INVD]
  [F:INVD]CPY    = [F:INV]CPY
  [F:INVD]REFDAT = [F:INV]REFDAT
  [F:INVD]ITMREF = [F:ORD]ITMREF
  [F:INVD]STOFCY = [F:ORD]STOFCY
  [F:INVD]PCU    = [F:ITM]PCU
  [F:INVD]STU    = [F:ITM]STU
  [F:INVD]QTY    = [F:ORD]RMNEXTQTY
  [F:INVD]WIP    = 2
  [L]I_NUMLIN +=1
  [F:INVD]NUMLIN = [L]I_NUMLIN
  Write [F:INVD]
  If !fstat
    Commit
  Else
    Call FSTA('INVD') From GLOCK
    Rollback
  Endif
Next
Filter [F:LNK]
Close File [F:LNK]
Return

