#<AdxTL>@(#)10.0.0.0 $Revision$
################################################################################################
#                                                                                              #
# Traitement standard de saisie des critères sur résultat de nomenclatures                     #                                                                                              #
# Traitement TRTCRITBOD / Action TRTCRITBOD                                                    #
#                                                                                              #
################################################################################################
# Appelée en affichage d'articles via les nomenclatures sur saisie d'un composé                #
################################################################################################

$ACTION
#--- Actions liées à la fenêtre de saisie ICRITBOD
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : REP="M"
 When "OK"          : Gosub OK
 When "ABA"         : Gosub ABA
Endcase
Return

#---------------------------------------------------------#
# Chargement du masque critères de picking                #
#---------------------------------------------------------#
$DEBUT
 Local Integer WCAS_CTRL 
 REP = ""
 Raz [M:SSBO]
 [M:SSBO]WCRITSUP1 = ''
 [M:SSBO]WCRITSUP2 = ''
 [M:SSBO]WCRITSUP3 = ''
 Affzo [M:SCRB]
Return

###########################################################
# $OK : Sauvergarde des critères de picking saisis        #
###########################################################
$OK
Local Integer WOK 

Gosub CTRL_SAISIE

If WOK<>2
 FIN = 0
 Return
Endif  

#-- Gestion dans le cas d'une formule
Gosub CRIT_FORMULE

#-- Gestion dans le cas de lecture BOD
Gosub CRIT_BOD

FIN = 1
Return


###########################################################
# $CTRL_SAISIE : Gestion dans le cas d'une formule       #
###########################################################
$CTRL_SAISIE
WOK=2
WCAS_CTRL=0
 

#---------- Borne d'Articles ---------#
If (                             [M:SCRB]ITMREF1    >  [M:SCRB]ITMREF2    & [M:SCRB]ITMREF2   <>'') 
 WCAS_CTRL=1
Endif 

If (                             [M:SCRB]TCLCOD1    >  [M:SCRB]TCLCOD2    & [M:SCRB]TCLCOD2   <>'') 
 WCAS_CTRL=2
Endif 

If (                             [M:SCRB]EANCOD1    >  [M:SCRB]EANCOD2    & [M:SCRB]EANCOD2   <>'') 
 WCAS_CTRL=3
Endif 

If (                             [M:SCRB]SEAKEY1    >  [M:SCRB]SEAKEY2    & [M:SCRB]SEAKEY2   <>'') 
 WCAS_CTRL=4
Endif 

If (                             [M:SCRB]CFGLIN1    >  [M:SCRB]CFGLIN2    & [M:SCRB]CFGLIN2   <>'') 
 WCAS_CTRL=5
Endif 

If (dim([M:SCRB]TSICOD1)>0 &  [M:SCRB]TSICOD1(0) >  [M:SCRB]TSICOD2(0) & [M:SCRB]TSICOD2(0)<>'') 
 WCAS_CTRL=6
Endif 

If (dim([M:SCRB]TSICOD1)>1 &  [M:SCRB]TSICOD1(1) >  [M:SCRB]TSICOD2(1) & [M:SCRB]TSICOD2(1)<>'') 
 WCAS_CTRL=7
Endif 

If (dim([M:SCRB]TSICOD1)>2 &  [M:SCRB]TSICOD1(2) >  [M:SCRB]TSICOD2(2) & [M:SCRB]TSICOD2(2)<>'') 
 WCAS_CTRL=8
Endif 

If (dim([M:SCRB]TSICOD1)>3 &  [M:SCRB]TSICOD1(3) >  [M:SCRB]TSICOD2(3) & [M:SCRB]TSICOD2(3)<>'') 
 WCAS_CTRL=9
Endif 

If (dim([M:SCRB]TSICOD1)>4 &  [M:SCRB]TSICOD1(4) >  [M:SCRB]TSICOD2(4) & [M:SCRB]TSICOD2(4)<>'')  
 WCAS_CTRL=10
Endif 

If WCAS_CTRL>0
 Call MESSAGE(mess(586,199,1) ) From GESECRAN : #   Critère 1 > Critère 2 
 WOK=1
Endif

If WCAS_CTRL=1  :           SUIZON = "[M:SCRB]ITMREF1"          : Endif 
If WCAS_CTRL=2  :           SUIZON = "[M:SCRB]TCLCOD1"          : Endif 
If WCAS_CTRL=3  :           SUIZON = "[M:SCRB]EANCOD1"          : Endif 
If WCAS_CTRL=4  :           SUIZON = "[M:SCRB]SEAKEY1"          : Endif 
If WCAS_CTRL=5  :           SUIZON = "[M:SCRB]CFGLIN1"          : Endif 
If WCAS_CTRL=6  :           SUIZON = "[M:SCRB]TSICOD1(0)"       : Endif 
If WCAS_CTRL=7  :           SUIZON = "[M:SCRB]TSICOD1(1)"       : Endif 
If WCAS_CTRL=8  :           SUIZON = "[M:SCRB]TSICOD1(2)"       : Endif 
If WCAS_CTRL=9  :           SUIZON = "[M:SCRB]TSICOD1(3)"       : Endif 
If WCAS_CTRL=10 :           SUIZON = "[M:SCRB]TSICOD1(4)"       : Endif 

Return  

###########################################################
# $CRIT_BOD : Gestion dans le cas de lecture BOD          #
###########################################################
$CRIT_BOD

#---------- Borne d'Articles ---------#
[M:SSBO]ITMREF1  =  [M:SCRB]ITMREF1 
[M:SSBO]ITMREF2  =  [M:SCRB]ITMREF2 

#---------- Borne code EAN  ----------#
[M:SSBO]EANCOD1  =  [M:SCRB]EANCOD1 
[M:SSBO]EANCOD2  =  [M:SCRB]EANCOD2 

#---------- Borne clé recherche-------#
[M:SSBO]SEAKEY1  =  [M:SCRB]SEAKEY1 
[M:SSBO]SEAKEY2  =  [M:SCRB]SEAKEY2 

#---------- Borne catégorie articles -#
[M:SSBO]TCLCOD1  =  [M:SCRB]TCLCOD1 
[M:SSBO]TCLCOD2  =  [M:SCRB]TCLCOD2 

#---------- Borne lignes produit  ----#
[M:SSBO]CFGLIN1  =  [M:SCRB]CFGLIN1 
[M:SSBO]CFGLIN2  =  [M:SCRB]CFGLIN2 

#---------- Borne famille statistique (5 occurences) ----#
For I=0 To 4 
 If dim([M:SCRB]TSICOD1)>I
  [M:SSBO]TSICOD1(I)=  [M:SCRB]TSICOD1(I)
  [M:SSBO]TSICOD2(I)=  [M:SCRB]TSICOD2(I)
 Endif 
Next 

Return 


###########################################################
# $CRIT_FORMULE : Gestion dans le cas d'une formule       #
###########################################################
$CRIT_FORMULE

#---------- Borne d'Articles ---------#
If [M:SCRB]ITMREF1 <> ""
  [M:SSBO]WCRITSUP1+='[F:ITM]ITMREF>="' +[M:SCRB]ITMREF1 + '" & '
Endif


If [M:SCRB]ITMREF2 <> ""
  [M:SSBO]WCRITSUP1+='[F:ITM]ITMREF<="' +[M:SCRB]ITMREF2 + '" & '
Endif

#---------- Borne Catégorie Articles ---------#
If [M:SCRB]TCLCOD1 <> ""
  [M:SSBO]WCRITSUP1+='[F:ITM]TCLCOD>="' +[M:SCRB]TCLCOD1 + '" & '
Endif


If [M:SCRB]TCLCOD2 <> ""
  [M:SSBO]WCRITSUP1+='[F:ITM]TCLCOD<="' +[M:SCRB]TCLCOD2 + '" & '
Endif

#---------- Borne Code EAN  ---------#
If [M:SCRB]EANCOD1 <> ""
  [M:SSBO]WCRITSUP1+='[F:ITM]EANCOD>="' +[M:SCRB]EANCOD1 + '" & '
Endif


If [M:SCRB]EANCOD2 <> ""
  [M:SSBO]WCRITSUP1+='[F:ITM]EANCOD<="' +[M:SCRB]EANCOD2 + '" & '
Endif

#---------- Borne Clé de recherche ---------#
If [M:SCRB]SEAKEY1 <> ""
  [M:SSBO]WCRITSUP1+='[F:ITM]SEAKEY>="' +[M:SCRB]SEAKEY1 + '" & '
Endif


If [M:SCRB]SEAKEY2 <> ""
  [M:SSBO]WCRITSUP1+='[F:ITM]SEAKEY<="' +[M:SCRB]SEAKEY2 + '" & '
Endif

#---------- Borne Ligne de produit  ---------#
If [M:SCRB]CFGLIN1 <> ""
  [M:SSBO]WCRITSUP2+='[F:ITM]CFGLIN>="' +[M:SCRB]CFGLIN1 + '" & '
Endif

If [M:SCRB]CFGLIN2 <> ""
  [M:SSBO]WCRITSUP2+='[F:ITM]CFGLIN<="' +[M:SCRB]CFGLIN2 + '" & '
Endif

#---------- Borne famille statitiques (5 Champs dans ITMMASTER)  ---------#

For I= 0 To 2 

 If dim([M:SCRB]TSICOD1)>I &  [M:SCRB]TSICOD1(I) <> ""
  [M:SSBO]WCRITSUP2+='[F:ITM]TSICOD(' + num$(I) + ')>="' +[M:SCRB]TSICOD1(I) + '" & '
 Endif

 If dim([M:SCRB]TSICOD2)>I & [M:SCRB]TSICOD2(I) <> ""
  [M:SSBO]WCRITSUP2+='[F:ITM]TSICOD(' + num$(I) + ')<="' +[M:SCRB]TSICOD2(I) + '" & '
 Endif

Next  

For I= 3 To 4 

 If dim([M:SCRB]TSICOD1)>I &  [M:SCRB]TSICOD1(I) <> ""
  [M:SSBO]WCRITSUP3+='[F:ITM]TSICOD(' + num$(I) + ')>="' +[M:SCRB]TSICOD1(I) + '" & '
 Endif

 If dim([M:SCRB]TSICOD2)>I & [M:SCRB]TSICOD2(I) <> ""
  [M:SSBO]WCRITSUP3+='[F:ITM]TSICOD(' + num$(I) + ')<="' +[M:SCRB]TSICOD2(I) + '" & '
 Endif

Next  


#---------- Fin de critères ----------#
If [M:SSBO]WCRITSUP1="" : [M:SSBO]WCRITSUP1="1=1"
Else              : [M:SSBO]WCRITSUP1=left$([M:SSBO]WCRITSUP1,len([M:SSBO]WCRITSUP1)-3)
Endif

#---------- Fin de critères ----------#
If [M:SSBO]WCRITSUP2="" : [M:SSBO]WCRITSUP2="1=1"
Else              : [M:SSBO]WCRITSUP2=left$([M:SSBO]WCRITSUP2,len([M:SSBO]WCRITSUP2)-3)
Endif

#---------- Fin de critères ----------#
If [M:SSBO]WCRITSUP3="" : [M:SSBO]WCRITSUP3="1=1"
Else              : [M:SSBO]WCRITSUP3=left$([M:SSBO]WCRITSUP3,len([M:SSBO]WCRITSUP3)-3)
Endif

Return 


#---------------------------------------------------------#
#   Abandon : Réalimentation des valeurs initiales        #
#---------------------------------------------------------#
$ABA
 Raz REP
 Gosub DEBUT
 REP = ""
 Affzo [M]1-99
Return


#######################################################################
#                     ACTIONS CHAMPS COMMUNES                         #
#######################################################################
######################################################################################
Subprog AM_CRIITMREF(VALEUR)
Variable Char    VALEUR()

Raz [M]CRIITMDES
If VALEUR<>""
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITS]ITMREF,[M]CRIITMDES, "[F:ITS]") From TRTX3 
Endif
Affzo [M]CRIITMDES
End


# -------------------------------------------------------------------- #
# Contrôle d'appartenance à la même société juridique                  #
# -------------------------------------------------------------------- #
######################################################################################
$CTLLEGCPY

Read [FCY] FCY0=WFCY : If fstat Raz [F:FCY] : Endif
If [F:FCY]LEGCPY<>GSOCIETE GMESSAGE=mess(2,194,1) : mkstat=2 : Return : Endif

Return


