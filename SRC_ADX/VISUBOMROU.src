#<AdxTL>@(#)10.0.0.0 $Revision$
# Action VISUBOMROU   : Visualisation nomenclature multiniveaux
############################################################
$ACTION
  Case GACTION
    When "VISUBOMROU"
    Case ACTION
      When "OUVRE"        : Gosub OUVRE
      When "DEBUT"        : Gosub DEBUT
      When "FIN"          : Gosub FIN
      When "SETBOUT"      : Gosub SETBOUT
      When "BOUTON"       : Gosub BOUTON
      When "FIR"          : Gosub PREMIER
      When "LAS"          : Gosub DERNIER
      When "AVANT_PRE"    : Gosub AVANT_PREVIOUS
      When "PRE"          : Gosub PREVIOUS
      When "AVANT_SUI"    : Gosub AVANT_NEXT
      When "SUI"          : Gosub NEXT_REC
      When "APRES_MODIF"  : Gosub APRES_MODIF
    Endcase
  Endcase
Return

############################################################
# Visualisation nomenclatures
############################################################
$OUVRE
Local Integer IITM, IITF,IITS, IBOH, IBOD, ITBO, ICBB, ITXC, IROH, IMWS

If clalev([F:BOH4]) = 0 : Local File BOM           [BOH4]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT    [ITF]   : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER     [ITM]   : Endif
If clalev([F:ITM1]) = 0 : Local File ITMMASTER     [ITM1]  : IITM = 1 : Endif
If clalev([F:ITF1]) = 0 : Local File ITMFACILIT    [ITF1]  : IITF = 1 : Endif
If clalev([F:ITS1]) = 0 : Local File ITMSALES      [ITS1]  : IITS = 1 : Endif
If clalev([F:BOH1]) = 0 : Local File BOM           [BOH1]  : IBOH = 1 : Endif
If clalev([F:BOD1]) = 0 : Local File BOMD          [BOD1]  : IBOD = 1 : Endif
If clalev([F:TBO1]) = 0 : Local File TABBOMALT     [TBO1]  : ITBO = 1 : Endif
If clalev([F:CBB1]) = 0 : Local File CBLOB         [CBB1]  : ICBB = 1 : Endif
If clalev([F:TXC1]) = 0 : Local File TEXCLOB       [TXC1]  : ITXC = 1 : Endif
If clalev([F:ROH])  = 0 : Local File ROUTING       [ROH]   : Endif
If clalev([F:ROH1]) = 0 : Local File ROUTING       [ROH1]  : IROH = 1 : Endif
If clalev([F:MWS1]) = 0 : Local File WORKSTATIO    [MWS1]  : IMWS = 1 : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY      [FCY]   : Endif : # FQ58840 - 15/10/09 MABON
If clalev([F:ROO])  = 0 : Local File ROUOPE        [ROO]   : Endif

Local Integer OK, L, WLEVEL, WLIGNE, WPLIGNE,WROUALT
Local Char  WROU, SAVFONCTION(GLONAFC)
Global Char WICO_PRODR(30),WICO_SSPRODR(30),WICO_SCPR(30),WICO_SCSR(30),WICO_ENDR(30)
Global Char WICO_OPER1(30), WICO_OPER2(30), WICO_OPER3(30) : # WICO_OPER(30) : # GH 07/02/2014 bug 96217
Global Char WICO_WSTR(30),WICO_LABWSTR(30),WICO_EQUNR(30), WICO_TXTR(30),WICO_VALR(30),WICO_SCOWSTR(30)
Global Char WICO_MATR(30),WICO_GHOSTR(30)
Global Integer GROUFLG
# Global Char GKEYMAT : # GH 10/09/2014 bug 102531

Gosub LISTE_ICONES

# GH 21/01/2014 bug 95091
SAVFONCTION = GFONCTION
GFONCTION = "VISUROUBOM" : # pour l'aide sur fonction dans la fonction VISUBOMROU # GH 09/11/11 bug 77760
Call AUTORIS From EXEFNC
If GNBAUZ=0
   GERR=1 : GMESSAGE = GFONCTION-":"-mess(1,123,1) : # Fonction non autorisée
   FIN=1 : Return
Endif
# appel en tunnel avec un site précis
If [L]PARAM(1)<>"" & [L]PARAM(4)<>"" & GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE & !find([L]PARAM(4),GUSRFCY(1..GNBAUZ))
   GERR=1 : GMESSAGE = mess(175,123,1)-[L]PARAM(4) : # Fonction non autorisée pour ce site
   FIN=1 : Return
Endif
Return

############################################################
$FIN
If IITM = 1
  IITM = 0
  Close Local File [ITM1]
Endif
If IITF = 1
  IITF = 0
  Close Local File [ITF1]
Endif
If IITS = 1
  IITS = 0
  Close Local File [ITS1]
Endif
If IBOH = 1
  Filter [BOH1]
  IBOH = 0
  Close Local File [BOH1]
Endif
If IBOD = 1
  IBOD = 0
  Close Local File [BOD1]
Endif
If ITBO = 1
  ITBO = 0
  Close Local File [TBO1]
Endif
If ICBB = 1
  ICBB = 0
  Close Local File [CBB1]
Endif
If ITXC = 1
  ITXC = 0
  Close Local File [TXC1]
Endif
If IMWS = 1
  IMWS = 0
  Close Local File [MWS1]
Endif

If dim([V]WICO_PRODR) > 0   : Kill [V]WICO_PRODR   : Endif
If dim([V]WICO_SSPRODR) > 0 : Kill [V]WICO_SSPRODR : Endif
If dim([V]WICO_SCPR) > 0    : Kill [V]WICO_SCPR    : Endif
If dim([V]WICO_SCSR) > 0    : Kill [V]WICO_SCSR    : Endif
If dim([V]WICO_ENDR) > 0    : Kill [V]WICO_ENDR    : Endif
If dim([V]GROUFLG) > 0      : Kill [V]GROUFLG      : Endif
If dim([V]WICO_WSTR) > 0    : Kill [V]WICO_WSTR    : Endif
If dim([V]WICO_LABWSTR) > 0 : Kill [V]WICO_LABWSTR : Endif
If dim([V]WICO_EQUNR) > 0   : Kill [V]WICO_EQUNR   : Endif
If dim([V]WICO_SCOWSTR) >0  : Kill [V]WICO_SCOWSTR : Endif
If dim([V]WICO_TXTR) > 0    : Kill [V]WICO_TXTR    : Endif
If dim([V]WICO_VALR) > 0    : Kill [V]WICO_VALR    : Endif
If dim([V]WICO_MATR) > 0    : Kill [V]WICO_MATR    : Endif
If dim([V]WICO_GHOSTR) > 0  : Kill [V]WICO_GHOSTR  : Endif
If dim([V]WICO_OPER1) > 0   : Kill [V]WICO_OPER1   : Endif
If dim([V]WICO_OPER2) > 0   : Kill [V]WICO_OPER2   : Endif
If dim([V]WICO_OPER3) > 0   : Kill [V]WICO_OPER3   : Endif
If dim([V]GKEYMAT) > 0      : Kill [V]GKEYMAT      : Endif

# GH 21/01/2014 bug 95091
If SAVFONCTION<>GFONCTION
   GFONCTION=SAVFONCTION
   Call AUTORIS From EXEFNC
Endif
Return

############################################################
$SETBOUT
# Bouton GSPE1 = premier niveau
# Bouton GSPE2 = multi niveau
If [M:VBOR]BOMFLG = 0
  ETABOU(GSPE1) = 0
  ETABOU(GSPE2) = 1
Else
  ETABOU(GSPE1) = 1
  ETABOU(GSPE2) = 0
Endif

If [M:VBOR]PARITMREF = "" | [M:VBOR]BOMALT = 0
  ETABOU(GSPE1) = 0
  ETABOU(GSPE2) = 0
Endif
If [M:VBOR]BOMALT = 0
  Call VIREBOUT(CHBOU,"<>") From GOBJET
Endif
Return

############################################################
$DEBUT
Global Char GKEYMAT(type([M:VBOR]KEYC)-10) : # GH 10/09/2014 bug 102531

Raz [M:VBOR]
[M:VBOR]PARITMREF = PARAM(1)
[M:VBOR]BOMALT    = val(PARAM(2))
[M:VBOR]DATREF    = PARAM(3)    # !!! peut être 0/0/0 !!!

If val(PARAM(5))>0
   [M:VBOR]BOMALTTYP = val(PARAM(5)) : # GA 08/2007 ajout V6
Else
   [M:VBOR]BOMALTTYP = 2             : # Nomenclature de production par défaut
Endif

If [M:VBOR]BOMALT <> 0
   Grizo [VBOR]BOMALT : # GH 29/12/14 bug 103595
Elsif PARAM(1) <> ""
   # si l'on vient d'un tunnel article ou article site, on prend la premiere alternative de la nomenclature
   Filter [BOH1] Where ITMREF=PARAM(1) & BOMALTTYP=[M:VBOR]BOMALTTYP
   Read [BOH1]BOH0 First
   If fstat = 0 : [M:VBOR]BOMALT = [F:BOH1]BOMALT : Endif
   Filter [BOH1]
Endif

If PARAM(4) <> ""
   [M:VBOR]STOFCY = PARAM(4)
Else
   Case [M:VBOR]BOMALTTYP
      When 1 :     Call FIND_GFCYDEF(5) From TRTX3 : # Site Ventes par défaut
      When 2 :     Call FIND_GFCYDEF(8) From TRTX3 : # Site GP     par défaut
      When 3 :     Call FIND_GFCYDEF(6) From TRTX3 : # Site Achats par défaut
   Endcase
   [M:VBOR]STOFCY = GFCY
Endif

If PARAM(1) <> ""
   Call AM_PARITMREF(PARAM(1)) From SUBBOMROU
   Grizo [VBOR]PARITMREF : # GH 29/12/14 bug 103595
Endif

## GH 20/03/2013 bug 86834
If dim([M:VBOR]LIKQTY2)>0 & dim([M:VBOR]FMTQTY2)>0
  # détermination de FMTQTY2 selon le type de donnée du champ LIKQTY de l'écran
  Local Decimal LNG

  If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
  If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif

  Read [AMZ]CODE = "VISUBOMROU";"LIKQTY"
  If !fstat
    If [F:ATY]CODTYP<>[F:AMZ]CODTYP
      Read [ATY]CODTYP = [F:AMZ]CODTYP
    Endif
    LNG=[F:AMZ]LONG
  Endif
  If fstat
    Read [ATY]CODTYP = ""
    If fstat : Raz [F:ATY] : Endif
  Endif
  If [F:ATY]LNGTYP<>0 : LNG = [F:ATY]LNGTYP : Endif

  If LNG=0
    [M:VBOR]FMTQTY2 = "N:"+num$(type([M:VBOR]LIKQTY2)-10)+"F"
  Elsif int(LNG)=LNG
    [M:VBOR]FMTQTY2 = "N:"+num$(LNG)+"F"
  Else
    [M:VBOR]FMTQTY2 = "N:"+num$(LNG)+"#"
  Endif
Endif

If (dim([M:VBOR]SETTIM2)>0 | dim([M:VBOR]OPETIM2)>0) & dim([M:VBOR]FMTTIM2)>0
  # détermination de FMTTIM2 selon le type de donnée du champ OPETIM de l'écran
  Local Decimal LNG

  If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
  If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif

  Read [AMZ]CODE = "VISUBOMROU";"OPETIM"
  If !fstat
    If [F:ATY]CODTYP<>[F:AMZ]CODTYP
      Read [ATY]CODTYP = [F:AMZ]CODTYP
    Endif
    LNG=[F:AMZ]LONG
  Endif
  If fstat
    Read [ATY]CODTYP = ""
    If fstat : Raz [F:ATY] : Endif
  Endif
  If [F:ATY]LNGTYP<>0 : LNG = [F:ATY]LNGTYP : Endif

  If LNG=0
    [M:VBOR]FMTTIM2 = "N:"+num$(type([M:VBOR]OPETIM2)-10)+"F"
  Elsif int(LNG)=LNG
    [M:VBOR]FMTTIM2 = "N:"+num$(LNG)+"F"
  Else
    [M:VBOR]FMTTIM2 = "N:"+num$(LNG)+"#"
  Endif
Endif

[M:VBOR]XROOTIMCOD = 0
If [M:VBOR]BOMALT <> 0 & [M:VBOR]BOMALTTYP <> 0 & [M:VBOR]PARITMREF <> "" & [M:VBOR]STOFCY<>""
  #Grizo [VBOR]BOMALT,PARITMREF,STOFCY : # GH 29/12/14 bug 103595
  Gosub TRT_AFFBOM
Else
  Affzo [VBOR]
Endif
Return

############################################################
$APRES_MODIF
#Case COUZON
#  When "STOFCY"    : [M:VBOR]STOFCY = CZ
#  When "DATREF"    : [M:VBOR]DATREF = CZ
#  When "BOMALT"    : [M:VBOR]BOMALT = val(CZ)
#  When "BOMALTTYP" : [M:VBOR]BOMALTTYP = val(CZ)
#Endcase
If COUZON="DATREF" & [M:VBOR]BOMALT <> 0 & [M:VBOR]BOMALTTYP <> 0 & [M:VBOR]PARITMREF <> "" & [M:VBOR]STOFCY<>""
  [M:VBOR]DATREF = CZ
  Gosub TRT_AFFBOM
Endif
Return

############################################################
$TRT_AFFBOM
# Lecture alternative
Read [TBO1]TBO0=[M:VBOR]BOMALTTYP;[M:VBOR]BOMALT
If fstat
  FIN = 1
  Return
Endif
#
Read [BOH1]BOH0=[M:VBOR]PARITMREF;[M:VBOR]BOMALT;[M:VBOR]BOMALTTYP
#lecture de l'entete pour la navigation
Read [BOH4]BOH0=[M:VBOR]PARITMREF;[M:VBOR]BOMALT;[M:VBOR]BOMALTTYP
If fstat
  GMESSAGE = mess(95,193,1)
  GERR     = 1
  FIN      = 1
  Return
Endif

[M:VBOR] = [F:BOH1]
Affzo [VBOR]5-20

# Contrôle validité entête
If [F:BOH1]BOHENDDAT = [0/0/0]
   [F:BOH1]BOHENDDAT = [31/12/2999]
Endif
If ([M:VBOR]DATREF >= [F:BOH1]BOHSTRDAT | [M:VBOR]DATREF=[0/0/0]) & [M:VBOR]DATREF <= [F:BOH1]BOHENDDAT
  Gosub DISPLAY_BOMG
Else
  Gosub DISPLAY_BOMG :  ## GH 07/03/2013 bug 88514
  If GERR=0
     GMESSAGE = mess(54,199,1) : # Cette nomenclature n'est pas valide à la date indiquée
     GERR     = 2
  Endif
Endif
[M:VBOR]BOMFLG = 0   : # Seul le 1er niveau est déplié
Return

############################################################
$DISPLAY_BOMG
## GH 07/03/2013 bug 88514
Read [ITM1]ITM0=[M:VBOR]PARITMREF
If fstat : Raz [F:ITM1] : Endif
[M:VBOR]BOMSTU  = [F:ITM1]STU : Affzo [VBOR]BOMSTU

Call LECTEXTRA([M:VBOR]BOMDES,"BOM", "BOMDESAXX", [M:VBOR]PARITMREF+"~"+num$([M:VBOR]BOMALT),num$([M:VBOR]BOMALTTYP)) From ATEXTRA
Affzo [VBOR]BOMDES
##

If [M:VBOR]BOMALT = 0 | [M:VBOR]BOMALTTYP = 0 | [M:VBOR]PARITMREF = "" | [M:VBOR]STOFCY = ""
    Return
Endif

# Vider le XSL des composants
Effzo [VBOR]25

## GH 07/03/2013 bug 88522
If [F:TBO1]BOMALT <> [M:VBOR]BOMALT | [F:TBO1]BOMALTTYP <> [M:VBOR]BOMALTTYP
   Read [TBO1]TBO0=[M:VBOR]BOMALTTYP;[M:VBOR]BOMALT
   If fstat : Raz [F:TBO1] : Endif
Endif
If [F:TBO1]FCY<>""
   If  GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE & !find([F:TBO1]FCY,GUSRFCY(1..GNBAUZ))
     GERR=1 : GMESSAGE = mess(48,193,1) : # Alternative non valide sur ce site !
     Return
   Endif
   [M:VBOR]STOFCY = [F:TBO1]FCY : Affzo [VBOR]STOFCY :  Diszo [VBOR]STOFCY
Else
   Actzo [VBOR]STOFCY
Endif
##

nolign  = 1
L       = nolign -1
WLEVEL  = 0
WLIGNE  = 0
WPLIGNE = 0
# on affiche le composé père
Gosub ADD_PROD
# génération de la liste

Call GEN_LISTE_RECETTE(L, WLEVEL, WLIGNE, WPLIGNE,[M:VBOR]DATREF,[M:VBOR]PARITMREF, [M:VBOR]BOMALT, [M:VBOR]BOMALTTYP,[M:VBOR]STOFCY,WROU,WROUALT)
nolign  = 1
# tri du tableau composant par parent et par poids
Sorta [M]NBLIG [M]NBLIG Order By PARKEY([S]indice),POIDS([S]indice),[S]indice
Call AS_NBLIG From SUBBOMROU
#Affzo [VBOR]25   # Issue 83450 & 82418 GA 07/2012 déplacé idem VISUBOMG
Affzo [VBOR] : ## GH 07/03/2013 bug 88514 l'arborescence ne s'affichait pas à l'entrée dans la fonction
Return

############################################################
# Gestion des boutons suivant précédent premier et dernier #
############################################################
$CHARGE_DATA
[M:VBOR] = [F:BOH4]
[M:VBOR]PARITMREF = [F:BOH4]ITMREF
Affzo [VBOR]5-20
# Contrôle validité entête
If [F:BOH4]BOHENDDAT = [0/0/0]
   [F:BOH4]BOHENDDAT = [31/12/2999]
Endif
Gosub DISPLAY_BOMG
[M:VBOR]BOMFLG = 0   : # Seul le 1er niveau est déplié
Return

$DROIT
If [F:TBO1]BOMALT <> [F:BOH4]BOMALT | [F:TBO1]BOMALTTYP <> [F:BOH4]BOMALTTYP
   Read [TBO1]TBO0=[F:BOH4]BOMALTTYP;[F:BOH4]BOMALT
   If fstat : Raz [F:TBO1] : Endif
Endif
OK = ([F:TBO1]FCY="" |  GUSRFCY(1)="\"  | GNBAUZ=GNBSITE | find([F:TBO1]FCY,GUSRFCY(1..GNBAUZ)))
Return

$PREMIER
  Read [BOH4]BOH0 First
  If fstat > 2 and [F:BOH4]BOMALTTYP <> [M:VBOR]BOMALTTYP
    Call MESSAGE(mess(11,100,1)) From GESECRAN
    Return
  Endif
  Gosub DROIT
  If !OK : Goto NEXT_REC : Endif
  Gosub CHARGE_DATA
Return

$DERNIER
  Read [BOH4]BOH0 Last
  If fstat > 2 and [F:BOH4]BOMALTTYP <> [M:VBOR]BOMALTTYP
    Call MESSAGE(mess(11,100,1)) From GESECRAN
    Return
  Endif
  Gosub DROIT
  If !OK : Goto PREVIOUS : Endif
  Gosub CHARGE_DATA
Return

$AVANT_PREVIOUS
  If ETABOU(GENRE) = 1
    GERR=3
    GMESSAGE=mess(60,191,1)
  Endif
Return

$PREVIOUS
  Read [BOH4]BOH0 Prev
  If fstat > 2
    Call MESSAGE(mess(11,100,1)) From GESECRAN
    SUIZON = "PARITMREF"
    Return
  Endif
  Gosub DROIT
  If !OK : Goto PREVIOUS : Endif
  Gosub CHARGE_DATA
Return

$AVANT_NEXT
  If ETABOU(GENRE) = 1
    GERR=3
    GMESSAGE=mess(60,191,1)
  Endif
Return

$NEXT_REC
  Read [BOH4]BOH0 Next
  If fstat > 2
    Call MESSAGE(mess(11,100,1)) From GESECRAN
    SUIZON = "PARITMREF"
    Return
  Endif
  Gosub DROIT
  If !OK : Goto NEXT_REC : Endif
  Gosub CHARGE_DATA
Return

############################################################

Subprog GEN_LISTE_RECETTE (L, LEVEL, LIGNE, PLIGNE, LDAT, LITM , LBOMALT, LBOMALTTYP, WFCY,WROU,WROUALT)
Variable Integer L
Variable Integer LEVEL
Variable Integer LIGNE
Variable Integer PLIGNE
Value    Date    LDAT
Value    Char    LITM
Value    Integer LBOMALT
Value    Integer LBOMALTTYP
Value    Char    WFCY
Variable Char    WROU
Variable Integer WROUALT

Local    Integer WMEMPL
  # lecture entête
  Gosub LEC_FILES
  #If [F:ITM]PHAFLG <> 2
    LEVEL  += 1
    PLIGNE = LIGNE
  #Endif
  # selection des articles valides
  If LDAT =[0/0/0]
    Local File BOMD[BOD1] Where ITMREF=LITM & BOMALT=LBOMALT & BOMALTTYP = LBOMALTTYP
  Else
    Local File BOMD[BOD1] Where ITMREF=LITM & BOMALT=LBOMALT & BOMALTTYP = LBOMALTTYP &
&                               (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= LDAT)) &
&                               (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= LDAT))
  Endif
  # FQ60780 - MABON 10/12/09 - Il peut y avoir des articles avec une nomenclature sans Composants, mais avec des opérations de gammes
  If rowcount([F:BOD1])>0
  # Fin MABON
    # lecture premier enregistrement
    Read [BOD1]BOD0 First
    While !fstat
      # lecture article
      If [F:ITM]ITMREF <> [F:BOD1]CPNITMREF
        Read [ITM]ITM0=[F:BOD1]CPNITMREF
        If fstat : Raz [F:ITM] : Endif
      Endif
      If [F:ITF]ITMREF <> [F:BOD1]CPNITMREF | [F:ITF]STOFCY <> WFCY
        Read [ITF]ITF0=[F:BOD1]CPNITMREF;WFCY
        If fstat : Raz [F:ITF] : Endif
      Endif
      # si on a la nomenclature du pére on l'affiche.
      If GROUFLG
        Gosub ADD_LINE_OP
        GROUFLG = 0
        WROU ="" : WROUALT=0
      Endif
     # If [F:ITM]PHAFLG <> 2
        Gosub ADD_LINE
     # Endif
      # Si on est sur un composé de type sous produit on ne déplie pas.
      # On n'affiche pas sa gamme non plus
      If [F:BOD1]CPNTYP=4
        WROU ="" : WROUALT=0
        Goto NEXT_BOD
      Endif
      If !GROUFLG   # si l'on a pas une gamme en cours pour le composé
        WROU ="" : WROUALT=0
        If [F:ITM]MFGFLG = 2   # Article fabriqué
          Call SEARCH_ROU([F:BOD1]CPNITMREF,WFCY,[M:VBOR]ROUALT,LDAT,WROU,WROUALT)
          If WROU<>"" & WROUALT<>0
            # GH 07/02/2014 controle de validité de gamme inclus dans la recherche de gamme
            # Gamme du sous-produit valide ?
            # Read [ROH1]ROH1 = WFCY;WROU;WROUALT
            # If fstat
            #  Gosub NEXT_ITM
            # Else
               GROUFLG = 1
            #  # Controle de validité de l'entête de gamme du sous-produit
            #  If ([F:ROH1]ROUSTRDAT = [0/0/0] | ([F:ROH1]ROUSTRDAT<> [0/0/0] & [F:ROH1]ROUSTRDAT <=LDAT ))&
            #   & ([F:ROH1]ROUENDDAT = [0/0/0] | ([F:ROH1]ROUENDDAT<> [0/0/0] & [F:ROH1]ROUENDDAT>= LDAT))
            #    GROUFLG = 1
            #  Else
            #    GMESSAGE =[F:BOD1]CPNITMREF+"/"+num$(WROUALT)-":"-mess(8,193,1)
            #    GERR = 2
            #    Goto NEXT_BOD
            #  Endif
           # Endif
          Else
            # Nomenclature du sous-produit valide ?
            Read [BOH1]BOH0 =[F:BOD1]CPNITMREF;LBOMALT;2
            If  LDAT <>[0/0/0]
              If ([F:BOH1]BOHSTRDAT <> [0/0/0] & LDAT < [F:BOH1]BOHSTRDAT)
&               |([F:BOH1]BOHENDDAT <> [0/0/0] & LDAT > [F:BOH1]BOHENDDAT)
                Goto NEXT_BOD
              Endif
            Endif
          Endif
        Elsif [F:ITM]SCPFLG = 2   # Article sous-traité: gamme des composants ?
          # Nomenclature du sous-produit valide ?
          Read [BOH1]BOH0 =[F:BOD1]CPNITMREF;LBOMALT;3
            If LDAT <>[0/0/0]
              If ([F:BOH1]BOHSTRDAT <> [0/0/0] & LDAT < [F:BOH1]BOHSTRDAT)
&               |([F:BOH1]BOHENDDAT <> [0/0/0] & LDAT > [F:BOH1]BOHENDDAT)
                Goto NEXT_BOD
              Endif
            Endif
        Else
        # l'article n'est pas fabriqué, donc pas de gamme de fabrication à afficher
          Goto NEXT_ITM
        Endif
      Else
        Gosub ADD_LINE_OP
        WROU ="" : WROUALT=0
        GROUFLG = 0
      Endif
  $NEXT_ITM
    Case [F:ITF]REOCOD
      When 3  : LBOMALTTYP=2                  : # Production
      When 5  : LBOMALTTYP=3                  : # Sous-traitance
      When Default : LBOMALTTYP=[M:VBOR]BOMALTTYP  : # Pas de suggestion
    Endcase

    #If [F:ITM]PHAFLG <> 2 & !find([F:ITF]REOCOD,1,3,5) : Goto NEXT_BOD : Endif
    GPE = ([F:ITM]PHAFLG <> 2 & !find([F:ITF]REOCOD,1,3,5))
    # GPE can be changed to 0 for forcing BOM drill (in case suggestion = purchase per ex.)
    # GPE can be changed to 1 for cutting short BOM drill
    GPOINT = "BOMDRL" : Gosub ENTREE From EXEFNC : # Issue 121175 GH 24/04/2017 - Entry point added
    # Possibility to change LBOMALTTYP (according if production or subcontracting BOM exists per ex.)
    If GPE : Goto NEXT_BOD : Endif

    WMEMPL = PLIGNE

    # descente récursive
    Call GEN_LISTE_RECETTE (L, LEVEL, LIGNE, PLIGNE, LDAT, [F:BOD1]CPNITMREF , [F:BOD1]BOMALT, LBOMALTTYP, WFCY,WROU,WROUALT)

    Gosub LEC_FILES
    #If [F:ITM]PHAFLG <> 2
      LEVEL -= 1
      PLIGNE = WMEMPL
    #Endif
  $NEXT_BOD
     WROU ="" : WROUALT=0
      Read [BOD1] Next
    Wend
  # FQ60780 - MABON 10/12/09 - Il peut y avoir des articles avec une nomenclature sans Composants, mais avec des opérations de gammes
  Else
    Call SEARCH_ROU(LITM,WFCY,[M:VBOR]ROUALT,LDAT,WROU,WROUALT)
    If WROU<>"" & WROUALT<>0
      Read [ROH1]ROH1 = WFCY;WROU;WROUALT
      If !fstat
        GROUFLG = 1
        Gosub ADD_LINE_OP
      Endif
    Endif
  Endif
  # Fin MABON
  # Affzo [VBOR]  # Issue 83450 & 82418 GA 07/2012 Pb Performances idem VISUBOMG
  Close Local File
End

#----------------------------------------------------------------------
# programme de recherche de gamme d'un semi fini
#----------------------------------------------------------------------
#RECUPERE GAMME+ALTERNATIVE PERMETTANT DE FABRIQUER CHAQUE PRODUIT SEMI-FINI
Subprog SEARCH_ROU(COMPOSANT, FCY, LALT, LDAT, WROU, WROUALT)
# COMPOSANT = article pour lequel on cherche gamme+alt
# FCY       = site de la gamme initiale
# LALT      = gamme initiale
# LDAT      = date de validité à vérifier pour la gamme trouvée
# WROUALT   = gamme à déterminer
# WROU      = alt de gamme à déterminer
Value    Char    COMPOSANT
Value    Char    FCY
Value    Integer LALT
Value    Date    LDAT
Variable Char    WROU
Variable Integer WROUALT

Local File ITMFACILIT [ITFT]

# recherche de la gamme mère du composant
Read [ITFT]ITF0 = COMPOSANT;FCY
If !fstat
  WROUALT = [F:ITFT]MFGROUALT
  WROU    = [F:ITFT]MFGROU
Endif
If (WROU = "" | WROUALT = 0) & LALT<>0
  WROU    = COMPOSANT
  WROUALT = LALT
Endif
If WROU = "" | WROUALT = 0 : End : Endif

If func CTL_ROU(WROU,WROUALT,FCY,LDAT)<1
   WROU ="" : WROUALT=0
Endif
End

############################################################
## GH 07/02/2014 bug 96664 controle de validité de la gamme trouvée à LDAT

Funprog CTL_ROU(WROU, WROUALT, FCY, LDAT)
Value    Char    WROU
Value    Integer WROUALT
Value    Char    FCY
Value    Date    LDAT

If !clalev([F:ROHT]) : Local File ROUTING [ROHT] : Endif
If LDAT=[0/0/0]
   Look [ROHT]ROH0 = WROU;WROUALT;FCY
Else
   Read [ROHT]ROH0 = WROU;WROUALT;FCY
Endif
If fstat > 0
   End 0
Elsif LDAT<>[0/0/0]
&     & (([F:ROHT]ROUSTRDAT <> [0/0/0] & LDAT < [F:ROHT]ROUSTRDAT)
&       |([F:ROHT]ROUENDDAT <> [0/0/0] & LDAT > [F:ROHT]ROUENDDAT))
   End -1
Else
   Local File TABROUALT [TRO]
   Read [TRO]TRO0=WROUALT
   If fstat | !find([M:VBOR]BOMALT,[F:TRO]BOMALT1,[F:TRO]BOMALT2,[F:TRO]BOMALT3)
     End -2
   Else
     End 1
   Endif
Endif
End

############################################################
# alimentation du composé - nomenclature verticale
$ADD_PROD

# FQ 59912
If [M:VBOR]NBLIG>=dim([M:VBOR]CPNITMREF) Return Endif

[M:VBOR]LIGNE(L)     = WLIGNE
[M:VBOR]PARLIN(L)    = -1
[M:VBOR]LEV(L)       = WLEVEL
[M:VBOR]ITMREF(L)    = [M:VBOR]PARITMREF
[M:VBOR]CPNITMREF(L) = [M:VBOR]PARITMREF
[M:VBOR]GRPITMREF(L) = [M:VBOR]PARITMREF
[M:VBOR]ALTTYPR(L)   = [M:VBOR]BOMALTTYP
[M:VBOR]BOMSEQ(L)    = 0
[M:VBOR]LIB(L)       = mess(222,184,1)
[M:VBOR]LIBSH(L)     = mess(222,184,1)
Read [ITM]ITM0=[M:VBOR]ITMREF(L)
If fstat : Raz [F:ITM]  : Endif
Read [ITF]ITF0=[M:VBOR]ITMREF(L);[M:VBOR]STOFCY
If fstat : Raz [F:ITF]  : Endif
Read [BOH1]BOH0=[M:VBOR]ITMREF(L);[M:VBOR]BOMALT;[M:VBOR]BOMALTTYP
If fstat : Raz [F:BOH1]  : Endif

[M:VBOR]LIKQTY(L)    = [F:BOH1]BASQTY
[M:VBOR]STU(L)       = [F:ITM]STU
#[M:VBOR]ITMDES1(L)   = [F:ITM]ITMDES1
# Issue 83628 GA 07/2012
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:VBOR]ITMDES1(L), "[F:ITM]") From TRTX3
[M:VBOR]REOCOD(L)    = [F:ITF]REOCOD
If dim([M:VBOR]LIBREOCOD(L))>0 & [F:ITF]REOCOD>1
   [M:VBOR]LIBREOCOD(L)=mess([F:ITF]REOCOD,250,1)
Endif

Gosub ADD_VNOM

GROUFLG=0 : WROU="" : WROUALT=0
If [M:VBOR]ROUALT<>0
   # on essaie de respecter l'alt.gamme quand elle est précisée
   If find([F:ITF]MFGROUALT,0,[M:VBOR]ROUALT) & [F:ITF]MFGROU<>""
&     & func CTL_ROU([F:ITF]MFGROU,[M:VBOR]ROUALT,[M:VBOR]STOFCY,[M:VBOR]DATREF)>0
      # avec la gamme de l'article-site si les alt.gammes sont compatibles
      WROU    = [F:ITF]MFGROU
      WROUALT = [M:VBOR]ROUALT
      GROUFLG=1
   Else
      # avec le composé saisi sinon : # GH 30/12/2014 bug 104052
      Case func CTL_ROU([M:VBOR]PARITMREF,[M:VBOR]ROUALT,[M:VBOR]STOFCY,[M:VBOR]DATREF)
        When 0   : GERR=2 : GMESSAGE=mess(153,196,1) : # Gamme inexistante
        When -1  : GERR=2 : GMESSAGE=mess(8,193,1)   : # Gamme non valide à la date indiquée
        When -2  : GERR=2 : GMESSAGE=mess(53,193,1)  : # Incohérence entre alternative de nomenclature et de gamme
        When Default :
                   WROU    = [M:VBOR]PARITMREF
                   WROUALT = [M:VBOR]ROUALT
                   GROUFLG=1
      Endcase
   Endif
Else
   # si l'alt.gamme n'est pas précisée, on prend l'alt.gamme de l'article-site et par défaut alt. nomenclature
   Call SEARCH_ROU([M:VBOR]PARITMREF,[M:VBOR]STOFCY,[M:VBOR]BOMALT,[M:VBOR]DATREF,WROU,WROUALT)
   If WROU <>"" & WROUALT <> 0
     GROUFLG = 1
   Else
     # en dernier recours, on prend la 1ère gamme du composé compatible avec les site et date
     For [ROH1]ROH1 Where FCY=[M:VBOR]STOFCY & ITMREF=[M:VBOR]PARITMREF
         If func CTL_ROU([F:ROH1]ITMREF, [F:ROH1]ROUALT,[M:VBOR]STOFCY,[M:VBOR]DATREF)>0
          GROUFLG=1 : WROU=[F:ROH1]ITMREF : WROUALT=[F:ROH1]ROUALT : Break
       Endif
     Next
   Endif
Endif

L += 1
[M:VBOR]NBLIG = L

Return
#----------------------------------------------------------------------
# alimentation du tableau recette avec les opés de la gamme
$ADD_LINE_OP
Local Integer SUBLVL
Local Decimal PSEQ
Local Integer IND, IND2

Read [ROH1]ROH1 = WFCY;WROU;WROUALT
If fstat
   Return
Elsif LDAT<>[0/0/0]
&  If ([F:ROH1]ROUSTRDAT <> [0/0/0] & LDAT < [F:ROH1]ROUSTRDAT)
&    |([F:ROH1]ROUENDDAT <> [0/0/0] & LDAT > [F:ROH1]ROUENDDAT)
     Return
   Endif
Endif

If LDAT<>[0/0/0]
   Filter [ROO] Where VALSTRDAT <= LDAT & (VALENDDAT = [0/0/0] | VALENDDAT >= LDAT)
Else
   Filter [ROO]
Endif
For [ROO] Where FCY=WFCY & ITMREF = WROU & ROUALT = WROUALT
  If [M:VBOR]NBLIG>=dim([M:VBOR]CPNITMREF)
    Break
  Endif
  #[M:VBOR]CPNITMREF(L) = "OPÉ" - num$([F:ROO]OPENUM) # FQ 74948
  [M:VBOR]CPNITMREF(L) = mess(701,197,1) - num$([F:ROO]OPENUM)
  LIGNE += 1
  [M:VBOR]LIGNE(L)     = LIGNE
  [M:VBOR]PARLIN(L)    = PLIGNE
  [M:VBOR]LEV(L)       = LEVEL
  #[M:VBOR]GRPITMREF(L) = "OPÉ" - num$([F:ROO]OPENUM) # FQ 74948
  [M:VBOR]GRPITMREF(L) = mess(701,197,1) - num$([F:ROO]OPENUM)
  [M:VBOR]ITMDES1(L)   = [F:ROO]ROODES
  [M:VBOR]ITMREF(L)    = LITM
  [M:VBOR]OPENUM(L)    = [F:ROO]OPENUM
  [M:VBOR]BOMSEQ(L)    = [F:ROO]OPENUM
  [M:VBOR]LIKQTY(L)    = 0
  [M:VBOR]ALTTYPR(L)   = 0
  [M:VBOR]LIB(L)       = mess(209,197,1)
  #[M:VBOR]ICO(L)       = WICO_OPER : # GH 07/02/2014 bug 96217
  Case [F:ROO]ROOTIMCOD
     When 2       : [M:VBOR]ICO(L)       = WICO_OPER2
     When 3       : [M:VBOR]ICO(L)       = WICO_OPER3
     When Default : [M:VBOR]ICO(L)       = WICO_OPER1
  Endcase
  [M:VBOR]PRPTIM(L)    = [F:ROO]PRPTIM
  [M:VBOR]WAITIM(L)    = [F:ROO]WAITIM
  [M:VBOR]PSPTIM(L)    = [F:ROO]PSPTIM
  [M:VBOR]CBASQTY(L)   = [F:ROO]BASQTY
  [M:VBOR]OPEUOM(L)    = [F:ROO]OPEUOM
  [M:VBOR]ROOTIMCOD(L) = [F:ROO]ROOTIMCOD
  [M:VBOR]TIMCOD(L)    = [F:ROO]TIMCOD
  [M:VBOR]CAD(L)       = [F:ROO]CAD
  [M:VBOR]STRDAT(L)    = [F:ROO]VALSTRDAT : # GH 07/01/2014 bug 96664
  [M:VBOR]ENDDAT(L)    = [F:ROO]VALENDDAT : # GH 07/01/2014 bug 96664
  Case [F:ROH1]TIMUOMCOD
   When 1 : [M:VBOR]TIMUOM(L) = mess(30,197,1) : # h
   When 2 : [M:VBOR]TIMUOM(L) = mess(32,197,1) : # min
  Endcase
  If [F:ROO]ROOTIMCOD = 2  : # GH 07/02/2014 bug 96217 Unité Qté/ Unité Tps pour la cadence
    [M:VBOR]TIMUOM2(L) = [M:VBOR]OPEUOM(L)+"/"+[M:VBOR]TIMUOM(L)
    [M:VBOR]OPETIM2(L) = format$("N:6.4#",[F:ROO]CAD)
  Else
    [M:VBOR]TIMUOM2(L) = [M:VBOR]TIMUOM(L)
  Endif
  If [F:ROO]ROOTIMCOD = 1 & dim([M:VBOR]LIKQTY2)>0 & dim([M:VBOR]FMTQTY2)>0
        [M:VBOR]LIKQTY2(L) = format$([M:VBOR]FMTQTY2,[F:ROO]BASQTY)
        [M:VBOR]STU(L)     = [F:ROO]OPEUOM
  Endif
  If [M:VBOR]BOMSEQ(L) > 0
    PSEQ = [M:VBOR]BOMSEQ(L) / 100
  Else
    PSEQ = 1/100
  Endif
  [M:VBOR]POIDS(L)     = LEVEL+20+PSEQ
  If dim([M:VBOR]LIBSH)>0
    [M:VBOR]LIBSH(L) = mess(209,197,1) : # Opération
  Endif
  Gosub ADD_VNOM_OP
  L += 1
  [M:VBOR]NBLIG = L
  SUBLVL = LIGNE    #on sauvegarde la ligne de l'opération qui servira de ligne parent pour les postes et l'outillage
  Gosub ADD_WST     #recherche et affichage du poste principal
  Gosub ADD_LABWST  #recherche et affichage du poste de main d'oeuvre
  Gosub ADD_SCOWST  #recherche et affichage du poste de sous traitance
  Gosub ADD_EQUNUM  #recherche et affichage de l'outillage
  ## GH 20/03/2013 bug 86834
  [M:VBOR]SETTIM(SUBLVL) =max([M:VBOR]SETTIM(SUBLVL+1..[M:VBOR]NBLIG-1))
  [M:VBOR]OPETIM(SUBLVL) =max([M:VBOR]OPETIM(SUBLVL+1..[M:VBOR]NBLIG-1))
  If dim([M:VBOR]SETTIM2)>0 & dim([M:VBOR]FMTTIM2)>0
    [M:VBOR]SETTIM2(SUBLVL)=format$(FMTTIM2,[M:VBOR]SETTIM(SUBLVL))
  Endif
  #If dim([M:VBOR]OPETIM2)>0 & dim([M:VBOR]FMTTIM2)>0 : # GH 07/02/2014 bug 96217
  If dim([M:VBOR]OPETIM2)>0 & dim([M:VBOR]FMTTIM2)>0 & [M:VBOR]ROOTIMCOD(SUBLVL)<>2
    [M:VBOR]OPETIM2(SUBLVL)=format$(FMTTIM2,[M:VBOR]OPETIM(SUBLVL))
  Endif
Next
Filter [ROO]
Return

#----------------------------------------------------------------------
# alimentation du tableau - nomenclature verticale
$ADD_LINE
Local Integer PTRI : PTRI = 10
Local Decimal PSEQ
Local Integer IND, IND1, CPT
Local Char    ITMNAME
Local Decimal LQTN, LQTNA, LQTB, LQTBA

# FQ 59912
If [M:VBOR]NBLIG>=dim([M:VBOR]CPNITMREF) Return Endif

# si le composant est une matière liée à l'opération
  ITMNAME =[F:BOD1]CPNITMREF
  If [F:BOD1]CPNOPE > 0

      # on cherche si le pére du composant à une nomenclature
      Call SEARCH_ROU([F:BOD1]ITMREF, WFCY,[M:VBOR]ROUALT,LDAT,WROU,WROUALT)
      If WROU <> "" & WROUALT <> 0
          # If !clalev([F:ROO]) Local File ROUOPE [ROO] Where FCY=WFCY & ITMREF = WROU & ROUALT = WROUALT  Endif
          If LDAT<>[0/0/0] : # GH 07/02/2014 bug 96664 vérification de la validité de l'opération de gamme
             Filter [ROO] Where VALSTRDAT <= LDAT & (VALENDDAT = [0/0/0] | VALENDDAT >= LDAT)
          Else
             Filter [ROO]
          Endif
          Read [ROO]ROO0 = WFCY;WROU;WROUALT;[F:BOD1]CPNOPE
          Filter [ROO]
          If !fstat
            If [F:BOD1]CPNITMREF <> ""
              IND = find([F:BOD1]ITMREF,[M]GRPITMREF(0..NBLIG))
              While IND > 1
                CPT +=1
                IND1 = find([F:BOD1]ITMREF,[M]GRPITMREF(IND..NBLIG))
                # Issue 84483 GA 09/2012
                #If IND1 > IND
                #   IND = IND1
                #Else
                #   Break
                #Endif
                If IND1 > 0
                   IND += IND1
                Else
                   ITMNAME += " %"-num$(IND)
                  Break
                Endif
              Wend
              # If CPT > 1
              #   ITMNAME += " %"-num$(IND1)
              # Endif
            Endif
            #GKEYMAT =[M:VBOR]KEYC(PLIGNE) +"-"+"OPÉ"-num$([F:BOD1]CPNOPE)+"-"+num$([F:BOD1]CPNOPE) # FQ 74948
            GKEYMAT =[M:VBOR]KEYC(PLIGNE) +"-"+mess(701,197,1)-num$([F:BOD1]CPNOPE)+"-"+num$([F:BOD1]CPNOPE)
            If [F:ROO]RPLIND<>0 : GKEYMAT+="."+num$([F:ROO]RPLIND) : Endif : # GH 07/02/2014 bug 96664
          Else
           GKEYMAT = [M:VBOR]KEYC(PLIGNE)
          Endif
      Endif
  Endif

# on regarde si le composé à ajouter n'existe pas deja dans le tableau
  If [F:BOD1]CPNITMREF <> "" & GKEYMAT = ""
    IND = find([F:BOD1]CPNITMREF,[M]CPNITMREF(0..NBLIG))
    While IND > 0
      IND1 = find([F:BOD1]CPNITMREF,[M]GRPITMREF(IND..NBLIG))
      If IND1 > 0
        IND += IND1
      Else
        ITMNAME += " %"-num$(IND)
        Break
      Endif
    Wend
  Endif
Case [F:ITF]STOCOD
  When 1 : PTRI = 10
  When 2 : PTRI = 30
Endcase
LIGNE += 1
[M:VBOR]LIGNE(L)     = LIGNE
[M:VBOR]PARLIN(L)    = PLIGNE
[M:VBOR]LEV(L)       = LEVEL
[M:VBOR]ITMREF(L)    = [F:BOD1]ITMREF
[M:VBOR]ALTTYPR(L)   = [F:BOD1]BOMALTTYP
[M:VBOR]BOMSEQ(L)    = [F:BOD1]BOMSEQ
[M:VBOR]CPNTYP(L)    = [F:BOD1]CPNTYP
[M:VBOR]STU(L)       = [F:ITM]STU
[M:VBOR]REOCOD(L)    = [F:ITF]REOCOD
If dim([M:VBOR]LIBREOCOD(L))>0 & [F:ITF]REOCOD>1
   [M:VBOR]LIBREOCOD(L)=mess([F:ITF]REOCOD,250,1)
Endif
[M:VBOR]STRDAT(L)    = [F:BOD1]BOMSTRDAT : # GH 07/01/2014 bug 96664
[M:VBOR]ENDDAT(L)    = [F:BOD1]BOMENDDAT : # GH 07/01/2014 bug 96664

## GH 20/10/2011 bug 77219
# [M:VBOR]LIKQTY(L)    = [F:BOD1]LIKQTY
If clalev([F:BOHW])=0 : Local File BOM [BOHW] : Endif
Read [BOHW]BOH0=[F:BOD1]ITMREF;[F:BOD1]BOMALT;[F:BOD1]BOMALTTYP
If !fstat & [F:BOD1]LIKQTY<>0 & [M:VBOR]LIKQTY(PLIGNE)<>0
 Call LIKQTY([M:VBOR]LIKQTY(PLIGNE),[F:ITM]STU,[F:BOHW]BASQTY,[F:BOD1]LIKQTYCOD,
&            [F:BOD1]LIKQTY,[F:BOD1]QTYRND,[F:BOD1]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
 If LQTNA=0 : # GH 19/12/12 Bug 85968 si la qté avec arrondi rend 0, on refait le calcul sans arrondi
    GCLE=""
    Call LIKQTY([M:VBOR]LIKQTY(PLIGNE),GCLE,[F:BOHW]BASQTY,[F:BOD1]LIKQTYCOD,
&               [F:BOD1]LIKQTY,[F:BOD1]QTYRND,[F:BOD1]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
 Endif
 [M:VBOR]LIKQTY(L)    = LQTNA
Else
 [M:VBOR]LIKQTY(L)    = 0
Endif
## Fin GH

# Gestion du type texte
If [F:BOD1]CPNTYP = 5
  [M:VBOR]CPNITMREF(L) = "TEXTE"
  [M:VBOR]GRPITMREF(L) = "TEXTE"
  [M:VBOR]ITMDES1(L) = [F:BOD1]BOMSHO
  #[M:VBOR]BOMSHO(L) = [F:BOD1]BOMSHO : # Issue 76687 selon GH 29/09/11 bug 76687
  [M:VBOR]LIB(L)       = mess(04,38,1)
  PTRI = 50
Else
  [M:VBOR]CPNITMREF(L) = ITMNAME
  [M:VBOR]GRPITMREF(L) = [F:BOD1]CPNITMREF
 # [M:VBOR]ITMDES1(L)   = [F:ITM]ITMDES1
 # Issue 83628 GA 07/2012
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:VBOR]ITMDES1(L), "[F:ITM]") From TRTX3
  [M:VBOR]BOMSHO(L) = [F:BOD1]BOMSHO : # Issue 76687 selon GH 29/09/11 bug 76687
Endif

# bulle d'aide en fonction du type de composant
If [F:BOD1]CPNTYP > 1
  [M:VBOR]LIBSH(L)  = mess([F:BOD1]CPNTYP,438,1)
Else
  If func VISUBOMG.HAS_NOMP([F:BOD1]CPNITMREF,[M]BOMALT)
    [M:VBOR]LIBSH(L)  = mess(222,184,1)
    [M:VBOR]LIB(L)    = mess(222,184,1)
  Else
    [M:VBOR]LIBSH(L)  = mess(35,197,1)
    [M:VBOR]LIB(L)    = mess(35,197,1)
  Endif
Endif
If [F:BOD1]CPNTYP = 6 : PTRI= 40 : Endif

If [M:VBOR]BOMSEQ(L) > 0
  PSEQ = [M:VBOR]BOMSEQ(L) / 100
Else
  PSEQ = 1/100
Endif
[M:VBOR]POIDS(L)     =LEVEL + PTRI+PSEQ

Gosub ADD_VNOM
L += 1
[M:VBOR]NBLIG = L

Return
#----------------------------------------------------------------------
# GA 02/2008 nomenclature verticale
# NBLIG  : variable <Bas de tableau>
# PARKEY : clé père         (composé)
# KEYC   : clé              (composant)
# LIBL1  : libellé long
# LIBSH  : info-bulle       (facultatif)
# EXPFLG : ouvrir le niveau (facultatif)
# ICO    : icone associée   (facultatif)
#----------------------------------------------------------------------
$ADD_VNOM_OP
[M:VBOR]KEYC(L) = [M:VBOR]KEYC([M:VBOR]PARLIN(L))+"-"+[M:VBOR]CPNITMREF(L)+"-"+num$([M:VBOR]OPENUM(L))
If [F:ROO]RPLIND<>0 : [M:VBOR]KEYC(L)+="."+num$([F:ROO]RPLIND) : Endif : # GH 07/02/2014 bug 96664
If [M:VBOR]PARLIN(L)<>-1
   [M:VBOR]PARKEY(L) = [M:VBOR]KEYC([M:VBOR]PARLIN(L))
Else
   [M:VBOR]PARKEY(L) = ""
Endif

# Niveau plié/déplié
If dim([M:VBOR]EXPFLG)>0
   If [M:VBOR]PARLIN(L) =-1
      [M:VBOR]EXPFLG(L) = 2
   Else
      # FQ65148 : le niveau sera présenté Plié avec la valeur 1, et non 0
#       [M:VBOR]EXPFLG(L) = 0
      [M:VBOR]EXPFLG(L) = 1
   Endif
   [M:VBOR]BOMFLG = 0   : # Seul le 1er niveau est déplié
Endif
Return

#----------------------------------------------------------------------
# GA 02/2008 nomenclature verticale
# NBLIG  : variable <Bas de tableau>
# PARKEY : clé père         (composé)
# KEYC   : clé              (composant)
# LIBL1  : libellé long
# LIBSH  : info-bulle       (facultatif)
# EXPFLG : ouvrir le niveau (facultatif)
# ICO    : icone associée   (facultatif)
#----------------------------------------------------------------------
$ADD_VNOM
If dim([M:VBOR]LIKQTY2)>0 & dim([M:VBOR]FMTQTY2)>0 & [M:VBOR]STU(L)<>""
   [M:VBOR]LIKQTY2(L) = format$([M:VBOR]FMTQTY2,[M:VBOR]LIKQTY(L))
Endif

[M:VBOR]KEYC(L)      = [M:VBOR]CPNITMREF(L) +"-"+ num$([M:VBOR]BOMSEQ(L))
If [M:VBOR]PARLIN(L)<>-1
   [M:VBOR]PARKEY(L) =[M:VBOR]KEYC([M:VBOR]PARLIN(L))
Else
   [M:VBOR]PARKEY(L) = ""
Endif
If GKEYMAT <> ""
  [M:VBOR]PARKEY(L) = GKEYMAT
  GKEYMAT =""
Endif
# icône associée nomenclature verticale
If dim([M:VBOR]ICO)>0
    If [M:VBOR]ALTTYPR(L)>1
       Case [M:VBOR]REOCOD(L)
         When 3          # Production
           [M:VBOR]ICO(L) = WICO_PRODR
         When 5           # Sous-traité
           [M:VBOR]ICO(L) = WICO_SCSR
       Endcase
       Case [M:VBOR]CPNTYP(L)
         When 4           # Sous-produit
           [M:VBOR]ICO(L) = WICO_SSPRODR
         When 7           # Service
           [M:VBOR]ICO(L) = WICO_SCOWSTR
        When 5            # texte
          [M:VBOR]ICO(L)  = WICO_TXTR
        When 6            # valorisation
          [M:VBOR]ICO(L)  = WICO_VALR
        When 7            # service
          [M:VBOR]ICO(L)  = WICO_SCOWSTR
       Endcase
       If [M:VBOR]PARLIN(L)>-1 & [M:VBOR]CPNTYP([M:VBOR]PARLIN(L))<>4 & [M:VBOR]ICO([M:VBOR]PARLIN(L))=""
          [M:VBOR]ICO([M:VBOR]PARLIN(L)) = WICO_PRODR
       Endif
    Endif
    If [M:VBOR]PARLIN(L)<>-1 & find([M:VBOR]ICO([M:VBOR]PARLIN(L)),"",WICO_ENDR)
       [M:VBOR]ICO([M:VBOR]PARLIN(L))="Folder.gif"
    Endif
    If [F:ITM]PHAFLG = 2  #fantome
      [M:VBOR]ICO(L)= WICO_GHOSTR
    Endif
Endif
# icone par default pour les matière premières
If [M:VBOR]ICO(L) = ""
  [M:VBOR]ICO(L)=WICO_MATR
Endif

# Niveau plié/déplié
If dim([M:VBOR]EXPFLG)>0
   If [M:VBOR]PARLIN(L) =-1
      [M:VBOR]EXPFLG(L) = 2
   Else
      # FQ65148 : le niveau sera présenté Plié avec la valeur 1, et non 0
#       [M:VBOR]EXPFLG(L) = 0
      [M:VBOR]EXPFLG(L) = 1
   Endif
   [M:VBOR]BOMFLG = 0   : # Seul le 1er niveau est déplié
Endif
Return

#----------------------------------------------------------------------
# alimentation du tableau - nomenclature verticale - Poste principal
$ADD_WST
If [F:ROO]SCOWST = "" | [F:ROO]SCOWST <> [F:ROO]WST
  # FQ 59912
  If [M:VBOR]NBLIG>=dim([M:VBOR]CPNITMREF) Return Endif

  Read [MWS1]WST0=[F:ROO]WST;WFCY
  If !fstat
    LIGNE += 1
    [M:VBOR]LIGNE(L)     = LIGNE
    [M:VBOR]PARLIN(L)    = SUBLVL
    [M:VBOR]LEV(L)       = LEVEL+1
    [M:VBOR]CPNITMREF(L) = [F:ROO]WST
    [M:VBOR]GRPITMREF(L) = [F:ROO]WST
    [M:VBOR]ITMREF(L)    = LITM
    [M:VBOR]OPENUM(L)    = [F:ROO]OPENUM
    [M:VBOR]WST(L)       = [F:ROO]WST
    [M:VBOR]ICO(L)       = WICO_WSTR
 [M:VBOR]ALTTYPR(L)   = 0

    [M:VBOR]SETTIM(L)    = [F:ROO]SETTIM
    [M:VBOR]OPETIM(L)    = [F:ROO]OPETIM
    [M:VBOR]ROOTIMCOD(L) = [F:ROO]ROOTIMCOD
    [M:VBOR]TIMCOD(L)    = [F:ROO]TIMCOD
    [M:VBOR]CAD(L)       = [F:ROO]CAD
    [M:VBOR]CBASQTY(L)   = [F:ROO]BASQTY
    [M:VBOR]OPEUOM(L)    = [F:ROO]OPEUOM
    If dim([M:VBOR]SETTIM2)>0 & dim([M:VBOR]FMTTIM2)>0
      [M:VBOR]SETTIM2(L)   = format$([M:VBOR]FMTTIM2,[M:VBOR]SETTIM(L))
    Endif
    If dim([M:VBOR]OPETIM2)>0 & dim([M:VBOR]FMTTIM2)>0
      [M:VBOR]OPETIM2(L)   = format$([M:VBOR]FMTTIM2,[M:VBOR]OPETIM(L))
    Endif

    [M:VBOR]LIB(L)       = mess(243,190,1)
    #[M:VBOR]ITMDES1(L)   = [F:MWS1]WSTDES bug 68586 26/10/10
    Call LECTEXTRA([M:VBOR]ITMDES1(L),"WORKSTATIO","WSTDESAXX",[F:MWS1]WST,[F:MWS1]WCRFCY) From ATEXTRA
    # info bulle
    [M:VBOR]BOMSEQ(L)    = 2
    If [M:VBOR]BOMSEQ(L) > 0
      PSEQ = [M:VBOR]BOMSEQ(L) / 100
    Else
      PSEQ = 1/100
    Endif
    [M:VBOR]POIDS(L)     = LEVEL+2+PSEQ
    If dim([M:VBOR]LIBSH)>0
       [M:VBOR]LIBSH(L) = mess(243,190,1) : # Poste pal
    Endif
    [M:VBOR]KEYC(L)      = num$([M:VBOR]LEV(L))+"-"+[M:VBOR]ITMREF(L) +"-"+ num$([M:VBOR]OPENUM(L))+"-"+[M:VBOR]WST(L)
    [M:VBOR]PARKEY(L) = [M:VBOR]KEYC([M:VBOR]PARLIN(L))
    L += 1
    [M:VBOR]NBLIG = L
  Endif
Endif
Return

#----------------------------------------------------------------------
# alimentation du tableau - nomenclature verticale - Poste main d'oeuvre
$ADD_LABWST
# recherche du type + centre des postes M-O
If [F:ROO]LABWST <> ""

  # FQ 59912
  If [M:VBOR]NBLIG>=dim([M:VBOR]CPNITMREF) Return Endif

  Read [MWS1]WST0=[F:ROO]LABWST;WFCY
  If !fstat
    LIGNE += 1
    [M:VBOR]LIGNE(L)     = LIGNE
    [M:VBOR]PARLIN(L)    = SUBLVL
    [M:VBOR]LEV(L)       = LEVEL+1
    [M:VBOR]CPNITMREF(L) = [F:ROO]LABWST
    [M:VBOR]GRPITMREF(L) = [F:ROO]LABWST
    [M:VBOR]ITMREF(L)    = LITM
    [M:VBOR]OPENUM(L)    = [F:ROO]OPENUM
    [M:VBOR]WST(L)       = [F:ROO]LABWST
    [M:VBOR]ICO(L)       = WICO_LABWSTR
 [M:VBOR]ALTTYPR(L)   = 0

    [M:VBOR]SETTIM(L)    = [F:ROO]SETTIM * [F:ROO]SETLABCOE
    [M:VBOR]OPETIM(L)    = [F:ROO]OPETIM * [F:ROO]OPELABCOE
    [M:VBOR]ROOTIMCOD(L) = [F:ROO]ROOTIMCOD
    [M:VBOR]TIMCOD(L)    = [F:ROO]TIMCOD
    [M:VBOR]CAD(L)       = [F:ROO]CAD
    [M:VBOR]CBASQTY(L)   = [F:ROO]BASQTY
    [M:VBOR]OPEUOM(L)    = [F:ROO]OPEUOM
    If dim([M:VBOR]SETTIM2)>0 & dim([M:VBOR]FMTTIM2)>0
      [M:VBOR]SETTIM2(L)   = format$([M:VBOR]FMTTIM2,[M:VBOR]SETTIM(L))
    Endif
    If dim([M:VBOR]OPETIM2)>0 & dim([M:VBOR]FMTTIM2)>0
      [M:VBOR]OPETIM2(L)   = format$([M:VBOR]FMTTIM2,[M:VBOR]OPETIM(L))
    Endif

    [M:VBOR]LIB(L)       = mess(244,190,1)
    #[M:VBOR]ITMDES1(L)   = [F:MWS1]WSTDES bug 68586 26/10/10
    Call LECTEXTRA([M:VBOR]ITMDES1(L),"WORKSTATIO","WSTDESAXX",[F:MWS1]WST,[F:MWS1]WCRFCY) From ATEXTRA
    [M:VBOR]BOMSEQ(L)    = 3
    If [M:VBOR]BOMSEQ(L) > 0
      PSEQ = [M:VBOR]BOMSEQ(L) / 100
    Else
      PSEQ = 1/100
    Endif
    [M:VBOR]POIDS(L)     = LEVEL+2+PSEQ
    # info bulle
    If dim([M:VBOR]LIBSH)>0
       [M:VBOR]LIBSH(L) = mess(244,190,1) : # Poste de Mo
    Endif
    [M:VBOR]KEYC(L)      = num$([M:VBOR]LEV(L))+"-"+[M:VBOR]ITMREF(L) +"-"+ num$([M:VBOR]OPENUM(L))+"-"+[M:VBOR]WST(L)
    [M:VBOR]PARKEY(L) = [M:VBOR]KEYC([M:VBOR]PARLIN(L))
  Endif
  L += 1
  [M:VBOR]NBLIG = L
Endif
Return
#----------------------------------------------------------------------
# alimentation du tableau - nomenclature verticale - Sous-traitance
$ADD_SCOWST
# recherche du type + centre des postes SST
If [F:ROO]SCOCOD=2 & [F:ROO]SCOWST<>""

  # FQ 59912
  If [M:VBOR]NBLIG>=dim([M:VBOR]CPNITMREF) Return Endif

   Read [MWS1]WST0=[F:ROO]SCOWST;WFCY
   If !fstat
      LIGNE += 1
      [M:VBOR]LIGNE(L)     = LIGNE
      [M:VBOR]PARLIN(L)    = SUBLVL
      [M:VBOR]LEV(L)       = LEVEL+1
      [M:VBOR]ITMREF(L)    = LITM
      [M:VBOR]OPENUM(L)    = [F:ROO]OPENUM
      [M:VBOR]ITMSST(L)    = [F:ROO]SCOITMREF
      [M:VBOR]WST(L)       = [F:ROO]SCOWST
      [M:VBOR]ICO(L)       = WICO_SCOWSTR
      [M:VBOR]CPNITMREF(L) = [F:ROO]SCOWST
      [M:VBOR]GRPITMREF(L) = [F:ROO]SCOWST
      [M:VBOR]ALTTYPR(L)   = 0

      [M:VBOR]SETTIM(L)    = [F:ROO]SETTIM
      [M:VBOR]OPETIM(L)    = [F:ROO]OPETIM
      [M:VBOR]ROOTIMCOD(L) = [F:ROO]ROOTIMCOD
      [M:VBOR]TIMCOD(L)    = [F:ROO]TIMCOD
      [M:VBOR]CAD(L)       = [F:ROO]CAD
      [M:VBOR]CBASQTY(L)   = [F:ROO]BASQTY
      [M:VBOR]OPEUOM(L)    = [F:ROO]OPEUOM
      If dim([M:VBOR]SETTIM2)>0 & dim([M:VBOR]FMTTIM2)>0
        [M:VBOR]SETTIM2(L)   = format$([M:VBOR]FMTTIM2,[M:VBOR]SETTIM(L))
      Endif
      If dim([M:VBOR]OPETIM2)>0 & dim([M:VBOR]FMTTIM2)>0
        [M:VBOR]OPETIM2(L)   = format$([M:VBOR]FMTTIM2,[M:VBOR]OPETIM(L))
      Endif

      [M:VBOR]LIB(L)       = mess(245,190,1)
      #[M:VBOR]ITMDES1(L)   = [F:MWS1]WSTDES  bug 68586 26/10/10
      Call LECTEXTRA([M:VBOR]ITMDES1(L),"WORKSTATIO","WSTDESAXX",[F:MWS1]WST,[F:MWS1]WCRFCY) From ATEXTRA
      [M:VBOR]BOMSEQ(L)    = 4
      If [M:VBOR]BOMSEQ(L) > 0
        PSEQ = [M:VBOR]BOMSEQ(L) / 100
      Else
        PSEQ = 1/100
      Endif
      [M:VBOR]POIDS(L)     = LEVEL+2+PSEQ
      # info bulle
      If dim([M:VBOR]LIBSH)>0
         [M:VBOR]LIBSH(L) = mess(245,190,1) : # Poste de sous-traitance
      Endif
   Endif
   [M:VBOR]KEYC(L)      = num$([M:VBOR]LEV(L))+"-"+[M:VBOR]ITMREF(L) +"-"+ num$([M:VBOR]OPENUM(L))+"-"+[M:VBOR]WST(L)
   [M:VBOR]PARKEY(L) = [M:VBOR]KEYC([M:VBOR]PARLIN(L))

   L += 1
  [M:VBOR]NBLIG = L
Endif
Return

#----------------------------------------------------------------------
# alimentation du tableau - nomenclature verticale - Outillage
$ADD_EQUNUM

If [F:ROO]EQUNUM<>""

  # FQ 59912
  If [M:VBOR]NBLIG>=dim([M:VBOR]CPNITMREF) Return Endif

   Read [ITM1]ITM0=[F:ROO]EQUNUM
   If !fstat
      LIGNE += 1
      [M:VBOR]LIGNE(L)     = LIGNE
      [M:VBOR]PARLIN(L)    = SUBLVL
      [M:VBOR]LEV(L)       = LEVEL+1
      [M:VBOR]ALTTYPR(L)   = 0
      [M:VBOR]ITMREF(L)    = LITM
      #[M:VBOR]OPENUM(L)    = [F:ROO]OPENUM
      [M:VBOR]CPNITMREF(L) = [F:ROO]EQUNUM
      [M:VBOR]GRPITMREF(L) = [F:ROO]EQUNUM
      #[M:VBOR]ITMDES1(L)   = [F:ITM1]ITMDES1
      # Issue 83628 GA 07/2012
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:VBOR]ITMDES1(L), "[F:ITM1]") From TRTX3
      [M:VBOR]LIB(L)       = mess(78,198,1)
      [M:VBOR]BOMSEQ(L)    = 5
      [M:VBOR]ICO(L)       = WICO_EQUNR
      If [M:VBOR]BOMSEQ(L) > 0
        PSEQ = [M:VBOR]BOMSEQ(L) / 100
      Else
        PSEQ = 1/100
      Endif
      [M:VBOR]POIDS(L)     = LEVEL+2+PSEQ
      # info bulle
      If dim([M:VBOR]LIBSH)>0
         [M:VBOR]LIBSH(L) = mess(78,198,1) : # Outillage
      Endif
   Endif
   [M:VBOR]KEYC(L)      = num$([M:VBOR]LEV(L))+"-"+[M:VBOR]ITMREF(L) +"-"+ num$([M:VBOR]OPENUM(L))+"-"+[M:VBOR]WST(L)
   [M:VBOR]PARKEY(L) = [M:VBOR]KEYC([M:VBOR]PARLIN(L))

  L += 1
  [M:VBOR]NBLIG = L
Endif
Return

#----------------------------------------------------------------------
# lecture fichiers
$LEC_FILES
# lecture entete nomenclature

Read [BOH1]BOH0=LITM;LBOMALT;LBOMALTTYP
If fstat : Raz [F:BOH1] : Endif
# on ne prend pas les nomenclature en élaboration.
If [F:BOH1]USESTA <> 2 : Raz [F:BOH1] : Endif

# lecture article composé
If [F:ITM]ITMREF <> LITM
    Read [ITM]ITM0=LITM
    If fstat : Raz [F:ITM] : Endif
Endif

# lecture article/site composé
If [F:ITF]ITMREF <> LITM | [F:ITF]STOFCY <> WFCY
    Read [ITF]ITF0=LITM;WFCY
    If fstat : Raz [F:ITF] : Endif
Endif

Return

######################################################################################
# NOL doit être préalablement chargée - appelé par SUBBOMROU en AS_NBLIG
$CHARGE_BOD
If dim(WBOMALTTYP)<0 : Local Integer WBOMALTTYP : Endif

# Affichage du composant courant
#[M:VBOR]XCPNITMREF  = [M:VBOR]CPNITMREF(NOL)
 [M:VBOR]XCPNITMREF  = [M:VBOR]GRPITMREF(NOL)
 [M:VBOR]XLIB        = [M:VBOR]LIB(NOL)
 [M:VBOR]XDES        = [M:VBOR]ITMDES1(NOL)
 [M:VBOR]XITMSST     = [M:VBOR]ITMSST(NOL)
 [M:VBOR]XITMSSTDES  = [M:VBOR]ZITMSST(NOL)
 [M:VBOR]XBOMSTRDAT  = [M:VBOR]STRDAT(NOL)
 [M:VBOR]XBOMENDDAT  = [M:VBOR]ENDDAT(NOL)
 If [M:VBOR]OPENUM(NOL)<>0
   # Affichage des informations liés aux gammes
   [M:VBOR]XSETTIM     = [M:VBOR]SETTIM(NOL)    : [M:VBOR]XTIMUOM1    = [M:VBOR]TIMUOM(NOL)
   If [M:VBOR]XTIMUOM1="" & [M:VBOR]PARKEY(NOL)<>""
      I=find([M:VBOR]PARKEY(NOL),[M:VBOR]KEYC(0..[M:VBOR]NBLIG-1))
      If I>0 : [M:VBOR]XTIMUOM1 = [M:VBOR]TIMUOM(I-1) : Endif
   Endif
   [M:VBOR]XPRPTIM     = [M:VBOR]PRPTIM(NOL)    : [M:VBOR]XTIMUOM2    = mess(30,197,1) : # h
   [M:VBOR]XOPETIM     = [M:VBOR]OPETIM(NOL)    : [M:VBOR]XTIMUOM3    = [M:VBOR]XTIMUOM1
   [M:VBOR]XWAITIM     = [M:VBOR]WAITIM(NOL)    : [M:VBOR]XTIMUOM4    = [M:VBOR]XTIMUOM2
   [M:VBOR]XPSPTIM     = [M:VBOR]PSPTIM(NOL)    : [M:VBOR]XTIMUOM5    = [M:VBOR]XTIMUOM2
   [M:VBOR]XBASQTY     = [M:VBOR]CBASQTY(NOL)   : [M:VBOR]XOPEUOM     = [M:VBOR]OPEUOM(NOL)
   [M:VBOR]XROOTIMCOD  = [M:VBOR]ROOTIMCOD(NOL)
   Case [M:VBOR]XROOTIMCOD
     When 1       : [M:VBOR]XTIMCOD = mess([M:VBOR]TIMCOD(NOL),303,1) : # GH 07/02/2014 bug 96664 mess([M:VBOR]ROOTIMCOD(NOL),303,1)
     When 2       : [M:VBOR]XTIMCOD = num$([M:VBOR]CAD(NOL))-"/"-[M:VBOR]XTIMUOM1
     When Default : [M:VBOR]XTIMCOD = ""
   Endcase
 Else
  Effzo [VBOR]35
  [M:VBOR]XROOTIMCOD  = 0
  [M:VBOR]XTIMCOD = ""
 Endif

# Affichage des autres informations du composant
If [M:VBOR]ALTTYPR(NOL) <> 0
  [M:VBOR]XCPNTYP    = [M:VBOR]CPNTYP(NOL)
  [M:VBOR]XREOCOD    = [M:VBOR]REOCOD(NOL)
  Read [BOD1]BOD0 = vireblc([M:VBOR]ITMREF(NOL),2);[M:VBOR]BOMALT;[M:VBOR]BOMSEQ(NOL);vireblc([M:VBOR]GRPITMREF(NOL),2);[M:VBOR]ALTTYPR(NOL)
  If fstat : Raz [F:BOD1]  : Endif
  Read [ITM]ITM0=[M:VBOR]GRPITMREF(NOL)
  If fstat : Raz [F:ITM]  : Endif
  Read [ITF1]ITF0=[M:VBOR]GRPITMREF(NOL);[M:VBOR]STOFCY
  If fstat : Raz [F:ITF1]  : Endif
Else
  [M:VBOR]XREOCOD    = 0
  [M:VBOR]XCPNTYP    = 0
  Raz [F:BOD1], [F:ITM], [F:ITF1]
Endif
# [M:VBOR]XCPNTYP    = [F:BOD1]CPNTYP
If dim([M]XBOMUOM)> 0  #code activité UML actif
  [M:VBOR]XBOMUOM    = [F:BOD1]BOMUOM
  [M:VBOR]XBOMQTY    = [F:BOD1]BOMQTY
  [M:VBOR]XBOMSTUCOE = [F:BOD1]BOMSTUCOE
Endif
[M:VBOR]XLIKQTY    = [F:BOD1]LIKQTY
[M:VBOR]XLIKQTYCOD = [F:BOD1]LIKQTYCOD
[M:VBOR]XQTYRND    = [F:BOD1]QTYRND
[M:VBOR]XBOMSHO    = [F:BOD1]BOMSHO
[M:VBOR]XSCA       = [F:BOD1]SCA
[M:VBOR]XCPNSTU    = [F:ITM]STU
If [F:ITF1]STOMGTCOD>0
   [M:VBOR]STOMGTCOD = [F:ITF1]STOMGTCOD
Else
   [M:VBOR]STOMGTCOD = [F:ITM]STOMGTCOD
Endif

Affzo [VBOR]27,30,35

If [M:VBOR]ALTTYPR(NOL)=1
   Read [ITS1]ITS0=[M:VBOR]GRPITMREF(NOL)
   If fstat Raz [F:ITS1] Endif
   [M:VBOR]BOMTEXNUM     = [F:ITS1]ITSTEX     : # Texte vente
Else
   [M:VBOR]BOMTEXNUM     = [F:ITM]MFGTEX     : # Texte production
Endif

Gosub CHARGE_TEX    : # Texte
Gosub CHARGE_IMG    : # CLOB Image

Affzo [VBOR]40,45

Return

######################################################################################
# NOL doit être préalablement chargée - appelé par SUBBOMROU en AS_NBLIG
$CHARGE_BOH
Effzo [VBOR]35

# Affichage du composé
[M:VBOR]XCPNITMREF  = [M:VBOR]GRPITMREF(NOL)
[M:VBOR]XDES        = [M:VBOR]ITMDES1(NOL)
[M:VBOR]XREOCOD     = [M:VBOR]REOCOD(NOL)
[M:VBOR]XLIB        = [M:VBOR]LIB(NOL)
[M:VBOR]XOPEUOM     = [M:VBOR]OPEUOM(NOL)
Read [ITM]ITM0=[M:VBOR]GRPITMREF(NOL)
If fstat : Raz [F:ITM]  : Endif
Read [ITF1]ITF0=[M:VBOR]GRPITMREF(NOL);[M:VBOR]STOFCY
If fstat : Raz [F:ITF1]  : Endif
[M:VBOR]XCPNSTU   = [F:ITM]STU
If [F:ITF1]STOMGTCOD>0
   [M:VBOR]STOMGTCOD = [F:ITF1]STOMGTCOD
Else
   [M:VBOR]STOMGTCOD = [F:ITM]STOMGTCOD
Endif

[M:VBOR]XCPNTYP = 0
[M:VBOR]XLIKQTYCOD = 0
[M:VBOR]XQTYRND = 0

If [M:VBOR]BOMALTTYP=1
   Read [ITS1]ITS0=[M:VBOR]GRPITMREF(NOL)
   If fstat Raz [F:ITS1] Endif
   [M:VBOR]BOMTEXNUM     = [F:ITS1]ITSTEX     : # Texte vente
Else
   [M:VBOR]BOMTEXNUM     = [F:ITM]MFGTEX     : # Texte production
Endif
Gosub CHARGE_TEX    : # Texte
Gosub CHARGE_IMG    : # CLOB Image

Affzo [VBOR]27,30,40,45

Return

############################################################
$CHARGE_TEX
Raz [M:VBOR]TEXTE
If [M:VBOR]BOMTEXNUM<>""
   Read [TXC1]TXC0=[M:VBOR]BOMTEXNUM
   If !fstat   [M:VBOR]TEXTE = [F:TXC1]TEXTE Endif
Endif

Return
############################################################
$CHARGE_IMG
Read [CBB1]CBB0="ITM";[F:ITM]ITMREF;""
If !fstat
   [M:VBOR]IMG=[F:CBB1]BLOB
Else
   Raz [M:VBOR]IMG
Endif

Return

############################################################
$BOUTON

Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

Case BOUT
  When "a" :
    Gosub FIRST_LEV_BOMG
  When "b" :
    Gosub ALL_LEV_BOMG
 Endcase
Return
############################################################
$FIRST_LEV_BOMG
# Replier tout, sauf 1er niveau
Local Integer K
If dim([M:VBOR]EXPFLG)>0
  For K=0 To [M:VBOR]NBLIG-1
    If [M:VBOR]PARLIN(K)=-1
     [M:VBOR]EXPFLG(K) = 2
    Else
      # FQ65148 : le niveau sera présenté Plié avec la valeur 1, et non 0
#      [M:VBOR]EXPFLG(K) = 0
     [M:VBOR]EXPFLG(K) = 1
    Endif
  Next
Endif

[M:VBOR]BOMFLG = 0   : # Seul le 1er niveau est déplié
Affzo [VBOR]
Return

############################################################
$ALL_LEV_BOMG
# Deplier toute l'arborescence
Local Integer K
If dim([M:VBOR]EXPFLG)>0
  For K=0 To [M:VBOR]NBLIG-1
    [M:VBOR]EXPFLG(K) = 2
  Next
Endif
[M:VBOR]BOMFLG = 1   : # Toute l'arborescence est dépliée
Affzo [VBOR]
Return

############################################################
$LISTE_ICONES
# Production
If func CTL_FIC_ICONE("folder_gear.png")=2
   WICO_PRODR = "folder_gear.png"
Else
   WICO_PRODR = "produit.png"
Endif

# Sous-produit
If func CTL_FIC_ICONE("folder_add.png")=2
   WICO_SSPRODR = "folder_add.png"
Else
   WICO_SSPRODR = "sousproduit.png"
Endif

# Sous-traité
If func CTL_FIC_ICONE("folder_gear.png")=2
   WICO_SCPR = "folder_gear.png"
Else
   WICO_SCPR = "soustraitance.png"
Endif

# Sous-traitance
If func CTL_FIC_ICONE("folder_time.png")=2
   WICO_SCSR = "folder_time.png"
Else
   WICO_SCSR = "produitsoustraite.png"
Endif

# feuilles de l'arborescence
If func CTL_FIC_ICONE("folder_into.png")=2
   WICO_ENDR = "folder_into.png"
Else
   WICO_ENDR = "box_closed.gif"
Endif
# Poste principal
If func CTL_FIC_ICONE("folder_out.png")=2
   WICO_WSTR = "folder_out.png"
Else
   WICO_WSTR = "machine.png"
Endif
# Poste main d'oeuvre
If func CTL_FIC_ICONE("folder_time.png")=2
   WICO_LABWSTR = "folder_time.png"
Else
   WICO_LABWSTR = "maindoeuvre.png"
Endif
#outils
WICO_EQUNR = "outils.png"
# opérations
#WICO_OPER = "operation.png" : # GH 07/02/2014 bug 96217
# opérations proportionelles
WICO_OPER1 = "operation.png"
# opérations cadencées
WICO_OPER2 = "operation-vert.png"
# opérations forfaitaires
WICO_OPER3 = "operation-bleu.png"
#texte
WICO_TXTR = "texte.png"
#valorisation
WICO_VALR = "valorisation.png"
#matière
WICO_MATR = "matierepremiere.png"
# post de sous traitance & Service
WICO_SCOWSTR = "soustraitance.png"
#Fantômes
WICO_GHOSTR = "fantome.png"
Return

############################################################
Funprog CTL_FIC_ICONE (LNOMICON)
Value Char LNOMICON
Local Integer WOK : WOK=2

Local Char WREPERT(200),WDIRSEP
Case GOS(1)
 When "dos"  : WDIRSEP="\"
 When Default : WDIRSEP="/"
Endcase

WREPERT=filpath("X3_ROOT"+WDIRSEP+"RESSTD"+WDIRSEP+"IMG","","","X3_PUB")
If LNOMICON<>"" & filinfo(WREPERT+WDIRSEP+LNOMICON,0)<0
   WOK = 1
Endif

End WOK

