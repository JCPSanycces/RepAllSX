#--------------------------------------------------------------------------------------
#lit la table TABPAYTERM en fonction de la législation passée en paramètre
#La table TABPAYTERM doit être ouverte par l'appelant
#--------------------------------------------------------------------------------------
Subprog LEC_TPT_LEG(CTX, LEG, PTE, LIN, GRET)
Value Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value  Char    LEG
Value  Char    PTE
Value  Integer LIN
Variable Integer GRET

  fstat = 0
  GRET = 0
  #Local File TABPAYTERM [TPT] :#--CPO 09/12/2013 Il ne sert à rien car en sortie on perd l'enreg lu
  Gosub LEG_FOLDER
  If [F:TPT]PTE <> PTE or [F:TPT]PTELIN <> LIN or [F:TPT]LEG <> LEG Then
    Read [TPT]TPT0 = PTE;LEG;LIN
    If fstat Then
      Read [TPT]TPT0 = PTE;"";LIN
    Endif
  Endif
  GRET=fstat
End

