#--------------------------------------------------------------------------------------
# Trt TRTLECLEG_SYRA : traitement de lecture des tables ayant la législation dans la clé primaire
# Cf. TRT CPTLEC pour les objets finances et TC utilisés par la finance.
#--------------------------------------------------------------------------------------
#  GETLEG(SOC,ORILEG,LEG)
#  LEC_JOU_LEG(LEG,JOUCOD)  : lit la table GJOURNAL
#  LEC_GTE_LEG(LEG,TYP)     : lit la table GTYPACCENT
#  LEC_TSO_LEG(LEG,TSO)     : lit la table TABSOHTYP
#  LEC_TSQ_LEG(LEG,TSO)     : lit la table TABSQHTYP     # FGR 20/02/2015 : X3SUIVI104383
#  LEC_TSV_LEG(LEG,TSV)     : lit la table TABSIVTYP
#  LEC_TPT_LEG(LEG,PTE,LIN) : lit la table TABPAYTERM
#  LEC_TSD_LEG(LEG,TSD,GRET): lit la table TABSDHTYP
#  LEC_TAM_LEG(LEG,DEP,GRET): lit la table TABPAM
#  LEC_TRE_LEG(LEG,TRE,GRET): lit la table TABSRHTYP
#  LEC_TVT_LEG(LEG,TVT,GRET): lit la table TABVAT
#  LEC_TVB_LEG(LEG,TVB,GRET): lit la table TABVACBPR
#  LEC_TVI_LEG(LEG,TVI,GRET): lit la table TABVACITM
#  LEC_TDA_LEG(LEG,DEP,GRET): lit la table TABDEPAGIO
#  LEC_TEC_LEG(LEG,TEC,RET) : lit la table TABEECNAT
#  LEC_TSC_LEG(LEG,TSC,RET) : lit la table TABEECSCH
#--------------------------------------------------------------------------------------
#--------------------------------------------------------------------------------------
#sous-pro qui renvoie la législation de la sté passé en paramètre
#ORILEG=G : on va chercher dans les variables globales qui doivent être renseignées
#ORILEG=T : on va chercher dans la table COMPANY
#--------------------------------------------------------------------------------------
Subprog GETLEG(SOC, LEG)
Value    Char    SOC
Variable Char    LEG

  LEG = func FGETLEG(SOC)
End

#--------------------------------------------------------------------------------------
#sous-pro qui renvoie la législation de la sté passé en paramètre
#ORILEG=G : on va chercher dans les variables globales qui doivent être renseignées
#ORILEG=T : on va chercher dans la table COMPANY
#--------------------------------------------------------------------------------------
Funprog FGETLEG(SOC)
Value    Char    SOC

Local Integer ISOC
Local Char    RLEG

  Raz RLEG
  If SOC <> "" Then
    Local File COMPANY [CPY]
    Read [CPY]CPY0=SOC
    If fstat Then
      End RLEG
    Endif
    RLEG = [F:CPY]LEG
  Endif
End RLEG

#--------------------------------------------------------------------------------------
# Législation du dossier si mono-législation
$LEG_FOLDER
  If CTX.AFOLD.ANBLEG = 1 Then
    LEG = CTX.AFOLD.ALISTLEG(1)
  Endif
Return

#--------------------------------------------------------------------------------------
#lit la table GJOURNAL en fonction de la législation passée en paramètre
#La table GJOURNAL doit être ouverte par l'appelant
#--------------------------------------------------------------------------------------
Subprog LEC_JOU_LEG(CTX, LEG, JOUCOD, GRET)
Value Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value Char LEG
Value Char JOUCOD
Variable Integer GRET

  fstat = 0
  GRET = 0
  #Local File GJOURNAL [JOU] :#--CPO 09/12/2013 Il ne sert à rien car en sortie on perd l'enreg lu
  Gosub LEG_FOLDER
  If [F:JOU]JOU <> JOUCOD or [F:JOU]LEG <> LEG Then
    Read [JOU]JOU0=JOUCOD;LEG
    If fstat Then
      Read [JOU]JOU0=JOUCOD;""
    Endif
  Endif
  GRET = fstat
End

