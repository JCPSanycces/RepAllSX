####################################################################
$SOHNUM_CONTROL
  Local Char WERR(250)
  #tester qu'il y a une commande de vente
  If this.SOHNUM=""
    WERR = mess(103,2006,1) #"Valeur obligatoire" "Commande de vente non renseignée"
    ASTATUS = fmet this.ASETERROR("SOHNUM", WERR, [V]CST_AERROR)
  Else
    Local File SORDER [SOH]
    Read [SOH]SOH0 = this.SOHNUM
    If !fstat
      #OK
    Else
      WERR = mess(380,192,1) #"Valeur inconnue" "Commande de vente inexistant"
      ASTATUS = fmet this.ASETERROR("SOHNUM", WERR, [V]CST_AERROR)
    Endif
    LogicClose File [SOH]
  Endif
Return

