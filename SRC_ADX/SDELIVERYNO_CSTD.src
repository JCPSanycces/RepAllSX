####################################################################
$RCPDAT_CONTROL
  Local Char WERR(250)
  #tester qu'il y a une date de reception
  If this.RCPDAT=[0/0/0]
    WERR = mess(103,2006,1) #"Valeur obligatoire" "Date de réception non renseignée"
    ASTATUS = fmet this.ASETERROR("RCPDAT", WERR, [V]CST_AERROR)
  Endif
Return

####################################################################
$NOTDAT_CONTROL
  Local Char WERR(250)
  #tester qu'il y a une date de notification
  If this.NOTDAT=[0/0/0]
    WERR = mess(103,2006,1) #"Valeur obligatoire" "Date de notification non renseignée"
    ASTATUS = fmet this.ASETERROR("NOTDAT", WERR, [V]CST_AERROR)
  Endif
Return


####################################################################
$SDND_ITMREF_CONTROL
  Local Char WERR(250)
  #tester qu'il y a un article
  If this.ITMREF = ""
    WERR = mess(103,2006,1) #"Valeur obligatoire" "L'article n'est pas renseigné"
    ASTATUS = fmet this.ASETERROR("ITMREF", WERR, [V]CST_AERROR)
  Else
    Local File ITMMASTER [ITM]
    Read [ITM]ITM0 = this.ITMREF
    If !fstat
      #OK
    Else
      WERR = mess(380,192,1) #"Valeur inconnue" "Article inexistant"
      ASTATUS = fmet this.ASETERROR("ITMREF", WERR, [V]CST_AERROR)
    Endif
    LogicClose File [ITM]
  Endif
Return

####################################################################
$SDND_RCPQTY_CONTROL
  Local Char WERR(250)
  #tester qu'il y a une quantité
  If this.RCPQTY <= 0
    WERR = mess(103,2006,1) #"Valeur obligatoire" "Quantité non renseignée"
    ASTATUS = fmet this.ASETERROR("RCPQTY", WERR, [V]CST_AERROR)
  Endif
Return

####################################################################
$SDND_RCPSAU_CONTROL
  Local Char WERR(250)
  #tester qu'il y a une unité
  If this.RCPQTY > 0 and this.RCPSAU = ""
    WERR = mess(103,2006,1) #"Valeur obligatoire" "Unité non renseignée"
    ASTATUS = fmet this.ASETERROR("RCPSAU", WERR, [V]CST_AERROR)
  Endif
Return



####################################################################
$SDND_ADDLINE_BEFORE
  Local Char WERR(250)
  If this.SDHNUM = ""
    WERR = mess(103,2006,1) #"Valeur obligatoire" "Le N° de livraison n'est pas renseigné"
    ASTATUS = fmet this.ASETERROR("SDHNUM", WERR, [V]CST_AERROR)
  Else
    #tester qu'il existe bien dans la table
    Local File SDELIVERY [SDH]
    Read [SDH]SDH0 = this.SDHNUM
    If !fstat
      #OK
    Else
      WERR = mess(380,192,1) #"Valeur inconnue" "Livraison inexistante"
      ASTATUS = fmet this.ASETERROR("SDHNUM", WERR, [V]CST_AERROR)
    Endif
    LogicClose File [SDH]
  Endif
Return

####################################################################
$SDND_ADDLINE_AFTER
  this.SDNLIN    = 1 + max(this.APARENT.SDND(1..maxtab(this.APARENT.SDND)).SDNLIN)
  this.SDNNUMREF = this.APARENT.SDNNUMREF
  this.SDHNUM    = this.APARENT.SDHNUM
  this.SOHNUM    = this.APARENT.SOHNUM
Return

