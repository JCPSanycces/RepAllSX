# Classe SDELIVERYNO


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER
      Endcase
    When "SDND"
      Case [L]AEVENT
        When "ADDLINE_BEFORE"         : Gosub SDND_ADDLINE_BEFORE
        When "ADDLINE_AFTER"          : Gosub SDND_ADDLINE_AFTER
      Endcase
  Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "SDNNUM"
      Case [L]ARULE
        When "INIT"            : Gosub SDNNUM_INIT
      Endcase
    When "SDHNUM"
      Case [L]ARULE
        When "CONTROL"         : Gosub SDHNUM_CONTROL
      Endcase
    When "BPCORD"
      Case [L]ARULE
        When "CONTROL"         : Gosub BPCORD_CONTROL
      Endcase
    When "BPAADD"
      Case [L]ARULE
        When "CONTROL"         : Gosub BPAADD_CONTROL
      Endcase
    When "FCY"
      Case [L]ARULE
        When "PROPAGATE"       : Gosub FCY_PROPAGATE
      Endcase
    When "SOHNUM"
      Case [L]ARULE
        When "CONTROL"         : Gosub SOHNUM_CONTROL
      Endcase
    When "RCPDAT"
      Case [L]ARULE
        When "CONTROL"         : Gosub RCPDAT_CONTROL
      Endcase
    When "NOTDAT"
      Case [L]ARULE
        When "CONTROL"         : Gosub NOTDAT_CONTROL
      Endcase

    When "SDND.ITMREF"
      Case [L]ARULE
        When "CONTROL"         : Gosub SDND_ITMREF_CONTROL
      Endcase
    When "SDND.RCPQTY"
      Case [L]ARULE
        When "CONTROL"         : Gosub SDND_RCPQTY_CONTROL
      Endcase
    When "SDND.RCPSAU"
      Case [L]ARULE
        When "CONTROL"         : Gosub SDND_RCPSAU_CONTROL
      Endcase


  Endcase
Return

#    When "SOPLIN"
#      Case [L]ARULE
#        When "CONTROL"         : Gosub SOPLIN_CONTROL
#      Endcase
#

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


####################################################################
$SDNNUM_INIT
  this.SDNNUM = func GET_NOTIFICATION_COUNTER()
Return

####################################################################
$SDHNUM_CONTROL
  Local Char WERR(250)
  #tester qu'il y a un n° de livraison
  If this.SDHNUM = ""
    WERR = mess(103,2006,1) #"Valeur obligatoire" #"Le N° de livraison n'est pas renseigné"
    ASTATUS = fmet this.ASETERROR("SDHNUM", WERR, [V]CST_AERROR)
  Else
    #tester qu'il existe bien dans la table
    Local File SDELIVERY [SDH]
    Read [SDH]SDH0 = this.SDHNUM
    If !fstat
      #OK
    Else
      WERR = mess(380,192,1) #"Valeur inconnue" "Livraison inexistante"
      ASTATUS = fmet this.ASETERROR("SDHNUM", WERR, [V]CST_AERROR)
    Endif
    LogicClose File [SDH]
  Endif
Return

####################################################################
$BPCORD_CONTROL
  Local Char WERR(250)
  #tester qu'il y a un client
  If this.BPCORD = ""
    WERR = mess(103,2006,1) #"Valeur obligatoire" "Le client n'est pas renseigné"
    ASTATUS = fmet this.ASETERROR("BPCORD", WERR, [V]CST_AERROR)
  Else
    Gosub TEST_CLI_ADD
  Endif
Return

####################################################################
$BPAADD_CONTROL
  Local Char WERR(250)
  #tester qu'il y a une adresse
  If this.BPAADD = ""
    WERR = mess(103,2006,1) #"Valeur obligatoire" "L'adresse n'est pas renseignée"
    ASTATUS = fmet this.ASETERROR("BPAADD", WERR, [V]CST_AERROR)
  Else
    Gosub TEST_CLI_ADD
  Endif
Return

####################################################################
$TEST_CLI_ADD
  If this.BPCORD <> ""
    #tester le client
    Local File BPCUSTOMER [BPC]
    Read [BPC]BPC0 = this.BPCORD
    If !fstat
      #OK
      If this.BPAADD <> ""
        #tester qu'il existe bien l'adresse
        Local File BPADDRESS [BPA]
        Read [BPA]BPA0 = 1;this.BPCORD;this.BPAADD
        If !fstat
          #OK
        Else
          WERR = mess(380,192,1) #"Valeur inconnue" "Adresse inexistante"
          ASTATUS = fmet this.ASETERROR("BPAADD", WERR, [V]CST_AERROR)
        Endif
        LogicClose File [BPA]
      Endif
    Else
      WERR = mess(380,192,1) #"Valeur inconnue" "Client inexistant"
      ASTATUS = fmet this.ASETERROR("BPCORD", WERR, [V]CST_AERROR)
    Endif
    LogicClose File [BPC]
  Endif
Return

