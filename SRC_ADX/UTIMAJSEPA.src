#<AdxTL>@(#)3.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Initialisation du champ FLGSEPA dans la table TABCOUNTRY
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update FLGSEPA field on TABCOUNTRY file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJSEPA
End

#-------------------#
$MAJSEPA

Local Char    TBCRY(GLONCRY)(1..99)
Local Integer T

Local File =DOSSIER+".TABCOUNTRY"   [TCY] 

If dim([F:TCY]FLGSEPA)<=0
 Close Local File [TCY] : Return
Endif

# Mise à jour de la table TABCOUNTRY
Call ECR_TRACE(mess(81,125,1)-"TABCOUNTRY:"-time$,0) From GESECRAN

T = 0
T += 1 : TBCRY(T) = "DE"
T += 1 : TBCRY(T) = "AT"
T += 1 : TBCRY(T) = "BE"
T += 1 : TBCRY(T) = "BG"
T += 1 : TBCRY(T) = "CY"
T += 1 : TBCRY(T) = "DA"
T += 1 : TBCRY(T) = "ES"
T += 1 : TBCRY(T) = "EE"
T += 1 : TBCRY(T) = "FI"
T += 1 : TBCRY(T) = "FR"
T += 1 : TBCRY(T) = "GR"
T += 1 : TBCRY(T) = "HU"
T += 1 : TBCRY(T) = "IE"
T += 1 : TBCRY(T) = "IS"
T += 1 : TBCRY(T) = "IT"
T += 1 : TBCRY(T) = "LV"
T += 1 : TBCRY(T) = "LI"
T += 1 : TBCRY(T) = "LT"
T += 1 : TBCRY(T) = "LU"
T += 1 : TBCRY(T) = "MT"
T += 1 : TBCRY(T) = "MC"
T += 1 : TBCRY(T) = "NO"
T += 1 : TBCRY(T) = "NL"
T += 1 : TBCRY(T) = "PL"
T += 1 : TBCRY(T) = "PT"
T += 1 : TBCRY(T) = "CZ"
T += 1 : TBCRY(T) = "RO"
T += 1 : TBCRY(T) = "GB"
T += 1 : TBCRY(T) = "SK"
T += 1 : TBCRY(T) = "SI"
T += 1 : TBCRY(T) = "SE"
T += 1 : TBCRY(T) = "CH"

Trbegin [TCY]
 For [TCY]TCY0 Where FLGSEPA=0
  If find([F:TCY]CRY,TBCRY(1..T))
   [F:TCY]FLGSEPA = 2
  Else
   [F:TCY]FLGSEPA = 1
  Endif
  Rewrite [TCY] 
  If fstat
   Call ERREUR("TABCOUNTRY"-[F:TCY]CRY,2) From DOSDIC
  Endif
 Next TCY
Commit

Close Local File [TCY]

Return
