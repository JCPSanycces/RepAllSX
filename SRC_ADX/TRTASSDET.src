#<AdxTL>@(#)3.0.0.0 $Revision$
############################################################################
# Test de la saisie du code paramètre SREASSDET
#
# Module CRM                                                 8 Octobre 2003
############################################################################

Subprog VERF_PARAM(PARAM, TSTVALEUR, OK)
Value Char PARAM
Value Char TSTVALEUR
Variable Integer OK
OK= 1

#Malheureusement, on ne peut pas utiliser ce traitement de contrôle
End

If PARAM <> "SREASSDET"
    #Erreur dans le code paramètre
    GMESSAGE = mess(204, 196, 2)
    GERR = 1
    OK = 0
    End
Endif

If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
If !clalev([F:QUE]) : Local File QUEUE [QUE] : Endif

If GSREASSDEF = 1
    If TSTVALEUR <> ""
        Read [FCY] FCY0 = TSTVALEUR
        If fstat
            #La valeur saisie pour ce paramètre ne correspond pas à un site.
            GMESSAGE = mess(524, 182, 2)
            GERR = 1
            OK = 0
            End
        Endif
    Endif
Endif

If GSREASSDEF = 2
    If TSTVALEUR <> ""
        Read [AUS] CODUSR = TSTVALEUR
        If fstat
            #La valeur saisie pour ce paramètre ne correspond pas à un utilisateur.
            GMESSAGE = mess(525, 182, 2)
            GERR = 1
            OK = 0
            End
        Endif
    Endif
Endif

If GSREASSDEF = 3
    If TSTVALEUR <> ""
        Read [QUE] QUE0 = TSTVALEUR
        If fstat
            #La valeur saisie pour ce paramètre ne correspond pas à une queue.
            GMESSAGE = mess(526, 182, 2)
            GERR = 1
            OK = 0
            End
        Endif
    Endif
Endif

OK = 1
End






