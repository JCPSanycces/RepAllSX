#<AdxTL>@(#)0.0.0.0 $Revision$

#=====================================================================
#
$LIENS 
  # La modification du plan de saisonnalité est interdite lorsque
  # le mode est utilisé par au moins un bien comptable.
  If ( [M:PSE0]UTILISE = G_OUI  ) Then :  Diszo [M:PSE1]1-99  :  Endif
Return 

#=====================================================================
#
$VERIF_MOD
Return 

#=====================================================================
#
$MODIF
Return 

######################################################################################
## Ecran PSE0
######################################################################################

#----------------------------------------------
$AM_CPY
  # Le type du plan de saisonnalité n'est pas à renseigner pour la législation russe
  Chgfmt [M:PSE1]SESTYP With "-N+:1#"
Return

#----------------------------------------------
$AV_SESTYP
  # Le type du plan de saisonnalité n'est pas à renseigner pour la législation russe
  Chgfmt [M:PSE1]SESTYP With "-N+:1#"    
Return
