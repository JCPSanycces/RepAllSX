#<AdxTL>@(#)10.0.0.0 $Revision$ Imputation comptable
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "EXEC"       : Gosub EXEC
Endcase
Return

#########################################################
$INIT
#########################################################
Local Integer IND : IND=val(PARAM(1))
Local Integer DELAI
Local Decimal BIDON
Local Char    DEP(GLONTDA)
Local Char ODEFMASK(200), ODEFMASK2(200) : ODEFMASK=dbgstr(1)
If !clalev([F:ACV]) : Local File ACTIV      [ACV] : Endif
If !clalev([F:TDA]) : Local File TABDEPAGIO [TDA] : Endif
If !clalev([F:DUD]) : Local File GACCDUDATE [DUD] : Endif
Return

#########################################################
$INIT_DIA
#########################################################
TIT=mess(44,121,1)    # Escomptes
# Initialisation du code escompte
ODEFMASK2=dbgstr(1) : Default Mask ODEFMASK
Read [DUD]DUD1 = [M]DUDNUM(IND);[M]DUDLIG(IND)
Default Mask ODEFMASK2
[M:DIA]DEP = [F:DUD]DEP        

# Demande de modifications (14677)
Raz DELAI
Call ESC_AGIO([M:DIA]DEP,0,[M:PAY1]ACCDAT,[F:DUD]DUDDAT,DELAI,[M:DIA]TAUX,BIDON,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From TRTDIV #CHECK IGNORE_LINE
[M:DIA]NBJ = DELAI
[L]DEP=[M:DIA]DEP
Gosub AFFICHE
Return

#########################################################
$EXEC
#########################################################
Local Decimal AMTESC # Montant avec escompte/agio
Local Decimal AMTDEP # Montant de l'escompte/agio        # (AMTESC+AMTDEP)*TAUX = AMTDEP

If [M:DIA]TAUX = 0 : Return : Endif
ODEFMASK2=dbgstr(1) : Default Mask ODEFMASK
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
Call LECTURE("TCU",[M]CURLIN(IND),"") From CONTOBJ
# Recherche du montant
Gosub MNT_ESC
Default Mask ODEFMASK2

# Demande de modifications (14677)
DELAI = [M:DIA]NBJ
Call ESC_AGIO([M:DIA]DEP,[L]AMTESC,[M:PAY1]ACCDAT,[F:DUD]DUDDAT,DELAI,[M:DIA]TAUX,AMTDEP,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From TRTDIV #CHECK IGNORE_LINE
If TAUX<0 : # Escompte
 AMTDEP = arr(AMTDEP/(1+TAUX/100),[F:TCU]CURRND)
 If AMTDEP<0 : AMTDEP*=-1 : Endif     # Escompte positif (au niveau du calcul du solde d'une échéance)
Elsif TAUX>0 : # Agio 
 AMTDEP = arr((AMTDEP*365)/(365+DELAI*TAUX/100),[F:TCU]CURRND)
 If AMTDEP>0 : AMTDEP*=-1 : Endif            # Agio négatif (au niveau du calcul du solde d'une échéance)
Endif

# Si les échéances sont négatives, on inverse
If [L]AMTESC<0 : AMTDEP*=-1 : Endif 

VALEUR = AMTDEP
Return


$MNT_ESC
Local Integer SIGN
Raz AMTESC,SIGN
Read [DUD]DUD1=[M]DUDNUM(IND);[M]DUDLIG(IND)
For I=0 To [M]NBLIG-1
 If I<>IND & [M]DUDNUM(I)=[F:DUD]ACCNUM & [M]DUDLIG(I)=[F:DUD]DUDLIG
  Call SNSPAYECH([M]ACCSNS(I),[M:PAY1]SNS,[F:DUD]SNS,SIGN) From SUBPAY2 #CHECK IGNORE_LINE
  AMTESC+=[M]AMTLIN(I)*SIGN
 Endif
Next I
Return


########################################
Subprog AM_DEP(VALEUR)
Variable Char    VALEUR()
Call MAJ_ESC(VALEUR,[M:DIA]NBJ,[M:DIA]TAUX)
Affzo [M:DIA]TAUX
End

########################################
Subprog AM_NBJ(VALEUR)
Variable Decimal VALEUR
Call LITTABDEP ([M:DIA]DEP,VALEUR,[M:DIA]TAUX) From TRTDIV
Affzo [M:DIA]TAUX
End


#########################################################
Subprog MAJ_ESC(DEP,NBJ,TX)
Value Char DEP
Variable Decimal NBJ,TX

If clalev([F:TDA]) = 0 : Local File TABDEPAGIO : Endif
Gosub AFFICHE
End 

$AFFICHE
Call LEC_TDA(GCURLEG,[L]DEP) From CPTLEC
If fstat : Return : Endif
For I = 0 To dim([F:TDA]DEPRAT)-1
 [M:DIA]DEPDAY(I) = [F:TDA]DEPDAY(I)
 [M:DIA]DEPRAT(I) = [F:TDA]DEPRAT(I)
Next
[M:DIA]NBDEP = 12 : Affzo [M:DIA]15
Return
