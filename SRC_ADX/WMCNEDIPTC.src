#<AdxTL>@(#)0.0.0.0 $Revision$Class Protocol
# Supervisor
## ACLA-CLASSE ## EDIPTC
# 2018-11-06 07:04:56 189

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EDIPTC
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_PTCCOD From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub INIT_PTCTYP From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub INIT_VALID From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub INIT_CODACT From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub INIT_PTCDES From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub INIT_CACHEUUID From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub AINIT From WMC0EDIPTC : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EDIPTC
Gosub _ALOADATTRIBUTE_PTCCOD From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_PTCTYP From WMC1EDIPTC : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EDIPTC
Gosub LNKPRO_PTCCOD From WMC1EDIPTC : Gosub TESTALLSTAT
Gosub LNKPRO_CODACT From WMC1EDIPTC : Gosub TESTALLSTAT
For AINDCLA=1 To maxtab(this.EPTD)
 If this.EPTD(AINDCLA)<>null& find(this.EPTD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EPTD(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EPTM)
 If this.EPTM(AINDCLA)<>null& find(this.EPTM(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EPTM(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



