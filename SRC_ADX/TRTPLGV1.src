#<AdxTL>@(#)1.0.0.0 $Revision$
#######################################################################################################################
#  Affichage XML du planning marketing                                        Module CRM          15 Septembre 2004   #
#######################################################################################################################
##########################################################
#
# Détail des paramètres 
#
# PARAM(1) : Site.
# PARAM(2) : Devise.
# PARAM(3) : Feuille XSLT.
# PARAM(4) : Contexte d'exécution.
#
#########################################################

$ACTION
Case ACTION
 When "INIT"        : Gosub INITPLG
 When "EXEC"        : Gosub EXECPLG
 When Default
Endcase
Return

#########################################################
$INITPLG
Local Char SZXSLTSHEET
SZXSLTSHEET = PARAM(2)

If PARAM(1) <> ""
    If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
    Read [FCY] FCY0 = PARAM(1)
    If fstat
        #Le site indiqué est incorrect. Action abandonnée.
        GMESSAGE = mess(160, 177, 2)
        GERR = 1
        FIN = 1
        Return
    Endif
Endif

If PARAM(2) <> ""
    If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
    Read [TCU] TCU0 = PARAM(2)
    If fstat
        #La devise indiquée est incorrecte. Action abandonnée.
        GMESSAGE = mess(161, 177, 2)
        GERR = 1
        FIN = 1
        Return
    Endif
Endif

Gosub CHECKXSL From TRTMGGXSL1
If FIN = 1 : Return : Endif

Return

#########################################################
$EXECPLG
Local Char RETOUR
Local Char SZFULLFILENAME(250)
Local Char SZFILENAME(250)
Local Integer ICHAPTER
Local Integer IERRINF
IERRINF = 0
ICHAPTER = 0

If PARAM(3) = ""
    Call PLGINXML(PARAM(1), PARAM(2), 1, "STD", PARAM(4), SZFULLFILENAME, SZFILENAME, ICHAPTER, IERRINF) From SUBPLGXML
Else
    Call PLGINXML(PARAM(1), PARAM(2), 1, PARAM(3), PARAM(4), SZFULLFILENAME, SZFILENAME, ICHAPTER, IERRINF) From SUBPLGXML
Endif

If IERRINF = 0
    Callui RETOUR = "" With   "UIAction="+chr$(1)+"OpenFile",
&                          "UILocalDir="+ chr$(1) + "Report",
&                          "UILocalFile="+ chr$(1) + SZFILENAME
Endif

Return



