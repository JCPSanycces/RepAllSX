#<AdxTL>@(#)0.0.0.0 $Revision$
Call SQLTRA
End

###################################################################################################
Subprog SQLTRA
If dim(GSQLTRA)<0 : End : Endif
If dim(GSQLIDTRA)<0 : End : Endif
If GSQLIDTRA = 0 : GSQLTRA="" : Endif
If GSQLTRA="" : Call ACTIVE : End : Endif
Call ARRET
End
###################################################################################################
Subprog ACTIVE
Local Char PARAM(30)(1..4) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","SQLTRA","SQLTRA",3,"SPESQLTRA") From GTRAITE
End

$ACTION
#Infbox "action="+ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "INIT_DIA" : Gosub INIT_DIA
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When "SORTIE"   : Gosub SORTIE
Endcase
Return

$INIT
If GACTION<>"SQLTRA1"
    # Test que la trace n'est pas déjà en route
    If GSQLIDTRA<>0
        Call ERREUR(mess(107,115,1)) From GESECRAN : # Trace déjà en cours de constitution
        FIN=1
        Return
    Endif

    # Vérifier que la base de données est bien sqlserver (optionnel)
# Issue 83278 - 2012-07-03 by VPO : pb sur recherche type de base
#    Local Integer BASE_DONNEES
#    Call TEST_BDD(BASE_DONNEES)
#    If BASE_DONNEES<>4
    If GTYPDBA<>2
        Call ERREUR(mess(185,115,1)) From GESECRAN : # La base de données n'est pas SQLSERVER
        FIN=1
        Return
    Endif

    Local Char REPTRA(GDIMFIC)
    Call RECH_REP(REPTRA,FIN)
Endif
Return

$INIT_DIA
If GACTION<>"SQLTRA1"
    Local Integer NB_EVT
    Local Integer MAX_EVT : MAX_EVT=100
    Local Char EVT_CODE(3)(1..MAX_EVT),EVT_NAME(30)(1..MAX_EVT)
    Local Integer EVT_CLASS(1..MAX_EVT),EVT_STDFLG(1..MAX_EVT),EVT_TUNFLG(1..MAX_EVT)
    Gosub INIT_INFOSEVT

    Local Mask SQLTRA1 [SQL2]
    Gosub INIT_MSQL2
Else
    If [M:SQL0]RECUP<>3
        Local Integer NB_EVT
        Local Integer MAX_EVT : MAX_EVT=100
        Local Char EVT_CODE(3)(1..MAX_EVT),EVT_NAME(30)(1..MAX_EVT)
        Local Integer EVT_CLASS(1..MAX_EVT),EVT_STDFLG(1..MAX_EVT),EVT_TUNFLG(1..MAX_EVT)
        Gosub INIT_INFOSEVT

       Raz [M:SQL2]
       Gosub INIT_MSQL2
    Endif
    [M:SQL1]=[M:SQL2]
Endif
Return

$INIT_MSQL2
nolign = 0
Local File APLSTD  [AST]
For [AST]CLE Where LAN=GLANGUE & LANCHP=153 & LANNUM>500 & LANNUM<520
    nolign +=1
    Raz [M:SQL2]APRENDRE(nolign-1)
    [M:SQL2]GROUPE(nolign-1)=[F:AST]LANMES
    Gosub EVT_LANNUM
Next AST
[M:SQL2]NBEVT = nolign
Return

$EVT_LANNUM
Local Integer I_I
For I_I=1 To NB_EVT
  If EVT_CLASS(I_I)=[F:AST]LANNUM
    nolign +=1
    [M:SQL2]APRENDRE(nolign-1)=1
    [M:SQL2]CODE(nolign-1)=EVT_CODE(I_I)
    [M:SQL2]NAME(nolign-1)=EVT_NAME(I_I)
    [M:SQL2]STDFLG(nolign-1)=EVT_STDFLG(I_I)
    [M:SQL2]TUNFLG(nolign-1)=EVT_TUNFLG(I_I)
    #If [M:SQL0]RECUP=1 and [M:SQL2]STDFLG(nolign-1)=2
    #   [M:SQL2]APRENDRE(nolign-1)=2
    #Endif
    #If [M:SQL0]RECUP=2 and [M:SQL2]TUNFLG(nolign-1)=2
    #   [M:SQL2]APRENDRE(nolign-1)=2
    #Endif
  Endif
Next I_I
Return


$CONTROLE
If GACTION<>"SQLTRA1"
    If [M:SQL0]RECUP=3
       If find(2,[M:SQL2]APRENDRE(0..[M:SQL2]NBEVT-1))<=0
           GERR = 1
           GMESSAGE = mess(190,115,1)
           SAI=1
           Return
       Endif
    Endif
    If [M:SQL0]PRES=2 and [M:SQL0]NBPRES=0
        GERR = 1
        GMESSAGE = mess(191,115,1)
        SAI=1
    Endif
Else
    If find(2,[M:SQL1]APRENDRE(0..[M:SQL1]NBEVT-1))<=0
           GERR = 1
           GMESSAGE = mess(190,115,1)
           SAI=1
           Return
    Endif
Endif
Return

$EXEC
If GACTION<>"SQLTRA1"
    Call EXEC_ACTIVE(FIN)
Else
    [M:SQL2]=[M:SQL1]
    [M:SQL0]RECUP=3
    Affzo [M:SQL0]RECUP
Endif
Return

$SORTIE
If GACTION<>"SQLTRA1"
    If clalev([M:SQL2])>0 : Close Local Mask [SQL2] : Endif
Endif
Return

###################################################################################################
$INIT_INFOSEVT
NB_EVT = 0
Raz EVT_CODE,EVT_NAME
Raz EVT_CLASS,EVT_STDFLG,EVT_TUNFLG

NB_EVT+=1 : EVT_CODE(NB_EVT)="10"  : EVT_NAME(NB_EVT)="RPC:Completed"                    : EVT_CLASS(NB_EVT)=508 : EVT_TUNFLG(NB_EVT)=2
NB_EVT+=1 : EVT_CODE(NB_EVT)="11"  : EVT_NAME(NB_EVT)="RPC:Starting"                     : EVT_CLASS(NB_EVT)=508
NB_EVT+=1 : EVT_CODE(NB_EVT)="12"  : EVT_NAME(NB_EVT)="SQL:BatchCompleted"               : EVT_CLASS(NB_EVT)=512 : EVT_TUNFLG(NB_EVT)=2
