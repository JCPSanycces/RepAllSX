###################################################################################################
Subprog EXEC_ACTIVE(ERR)
Variable Integer ERR

Local Char MESSINIT(100)
Local Char FICTRA(GDIMFIC)

GSQLTRAOPT = [M:SQL0]TRI
GSQLTRAOPP = [M:SQL0]NBPRES

# Rechercher le nom du fichier de trace
Call RECH_FIC(GSQLTRA,GSQLTRASPID,ERR)
If ERR
    Call ERREUR(mess(110,115,1)) From GESECRAN : # Trace non lancée
    End
Endif

# Effacement du contenu de la trace précédente
If GSQLTRAMAC<>""
    FICTRA=GSQLTRAMAC+"@"
Else
    FICTRA=adxmac(-1)+"@"
Endif
FICTRA+=GSQLTRA
If filinfo(FICTRA+".trc",0)>0
 Call EFFACE(FICTRA+".trc",ERR) From ORDSYS
Endif

MESSINIT=mess(109,115,1)

Gosub INIT_TRA
If ERR
    Call ERREUR(mess(110,115,1)) From GESECRAN : # Trace non lancée
    End
Endif

If dim(GSTAOR1)>0
 Disable GSTAOR1 : # Menu Activation trace
 Enable  GSTAOR2 : # Menu désactivation
Endif

# Tout est OK
Call MESSAGE(MESSINIT) From GESECRAN : #  Trace activée
End

###################################################################################################
Subprog ARRET
Local Integer ERR
Local Char FICTRA(GDIMFIC)

# Test que la trace est bien en route
If GSQLTRA="" or GSQLIDTRA=0
    Call ERREUR(mess(110,115,1)) From GESECRAN : # Trace non lancée
    End
Endif

Gosub END_TRA
If ERR
    Call ERREUR(mess(187,115,1)) From GESECRAN : # Erreur lors de l'arrêt de la trace
    End
Endif

# On ouvre (et on réserve) un fichier de trace (le fichier trace est fermé dans le Call SYSTEME)
Call OUVRE_TRACE(mess(186,115,1)) From LECFIC : # Trace SqlServer
FICTRA=GSQLTRA+".trc"
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE("|"+mess(186,115,1)-":"-FICTRA,0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(mess(192,115,1)-":"-mess(GSQLTRAOPT,2949,1),0) From GESECRAN
If GSQLTRAOPP>0
    Call ECR_TRACE(mess(2,2947,1)-":"-num$(GSQLTRAOPP),0) From GESECRAN
Else
    Call ECR_TRACE(mess(1,2947,1),0) From GESECRAN
Endif

# Rechercher le nom du fichier de trace
Gosub RECUP_TRA
If ERR
    Call ERREUR(mess(187,115,1)) From GESECRAN : # Erreur lors de l'arrêt de la trace
    End
Endif


$SUITE_ARRET
If dim(GSTAOR1)>0
 Disable GSTAOR2 # Menu désactivation
 Enable  GSTAOR1 # Menu Activation trace
Endif

Call LEC_TRACE From LECFIC

GSQLTRA = ""
GSQLIDTRA = 0
End


###################################################################################################
# Algorithme de recherche du répertoire du fichier de trace
###################################################################################################
Subprog RECH_REP(REPTRA,ERR)
Variable Char REPTRA
Variable Integer ERR
#########
Local Char PROPERTY(100)
Local Char REPDUMP(GDIMFIC)
Local Integer MODE_REP
Local Char TEXT(250)(3)

GSQLTRAMAC = ""
PROPERTY="component.database.servername"
Call RECHPROP(PROPERTY,GSQLTRAMAC,ERR) From INTRUTILA
If ERR <> 0
    TEXT(0)=mess(228,100,1)-"<"+PROPERTY+">"
    TEXT(1)=""
    TEXT(2)=mess(227,100,1)
    Errbox  TEXT(0..2)
    End
Endif
PROPERTY="database.adonix.dbdirtra"
Call RECHPROP(PROPERTY,REPTRA,ERR) From INTRUTILA
If ERR <> 0
    TEXT(0)=mess(228,100,1)-"<"+PROPERTY+">"
    TEXT(1)=""
    TEXT(2)=mess(227,100,1)
    Errbox  TEXT(0..2)
    End
Endif
REPDUMP=GSQLTRAMAC+"@"+REPTRA
MODE_REP = filinfo(REPDUMP,0)
If MODE_REP < 0
   Call ERREUR(mess(188,115,1)-"("+num$(MODE_REP)+")") From GESECRAN
   #Erreur lors de l'accès au serveur de la base de données
   ERR=1
   End
Endif
#cf doc de filinfo
PFIF = 1 : PCAR = 2 : PDIR = 4 : PBLO = 6 : PFI1 = 0 : PFI2 = 8
If int(mod(MODE_REP/(2 ^ 12), 16))<> PDIR
   Call ERREUR(mess(189,115,1)) From GESECRAN
   #Erreur d'accès au répertoire des traces de la base de données
   ERR=1
   End
Endif

# on regarde si on est sur le bon serveur, on compare avec adxmac(-1)
If toupper(GSQLTRAMAC)=toupper(adxmac(-1))
   # c'est la meme machine, on annule
   GSQLTRAMAC = ""
Endif
End

###################################################################################################
# Algorithme de determination du fichier de trace
###################################################################################################
Subprog RECH_FIC(GFICTRA,SPID,ERR)
Variable Char GFICTRA
Variable Integer SPID
Variable Integer ERR
#########
Local Char REQSQL(200)
Local Char REPTRA(GDIMFIC)

Call RECH_REP(REPTRA,ERR)
If ERR : End : Endif

Onerrgo ERR_SQL

REQSQL="SELECT REPLACE(REPLACE (CONVERT(varchar(23), getdate(), 126), ':', '-'), '.', '-'),@@SPID"

For (Char CODUNIQ(50),Integer PROCID) From '5' Sql REQSQL
&   As [BZZ]
        #GFICTRA =REPTRA+"\"+"SQLTRC"+num$([BZZ]PROCID)
        GFICTRA =REPTRA+"\"+"SQLTRC"+num$([BZZ]PROCID)+"-"+[BZZ]CODUNIQ
        SPID=[BZZ]PROCID
  Break
Next
Onerrgo

End

$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ERREUR(GMESSAGE) From GESECRAN
End

###################################################################################################
# Algorithme de demarrage de la trace
###################################################################################################
$INIT_TRA
Local Char APPLI(100), XBASE(20) ,MACBID(GDIMFIC)
Local Char BASE(30), USER(30), PASSE(30)
Local Char TBIDX(30)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC), FICCMD(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC), CMDFIC(GDIMFIC)
Local Char    WORDRE(250),LIGNE(250)
Local Integer ER
Local Char    PROPERTY(100),VPROP(200),VPWD(200)
Local Integer OK
#Local Char SQLHOME(GDIMFIC)
Local Char REPTMP(GDIMFIC)
Local Char COMMANDE(250)
Local Char TEXT(250)(3)
Local Char AUTHEN_LOGIN(200)
Local Char XINSTANCE(200)
Local Char XHOSTNAME(200) : # Hostname (, port) where the SQL Server is running. Could be "." for local host

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = chr$(13)+chr$(10) : adxium = GASCII

Call GETENV(GSQLTRAMAC,"ADXDIR",REPTMP ) From ORDSYS
#
# jira X3-86047 86048 86049
# Récupération du passwd authenfication login (crypté)
PROPERTY="database.software.sqlinternalpwd"
Call PASSWD(PROPERTY,VPWD,OK) From DOSBASE
If OK <> 0
    OK=1
    Goto FIN_INIT_TRA
Endif
# recup authentification login sa si
Call PASSWD("database.software.sqlinternallogin",AUTHEN_LOGIN,OK) From DOSBASE
If OK <> 0
    OK=1
    Goto FIN_INIT_TRA
Endif
# instance ?
Call RECH_PROPERTY("database.adonix.sqlinstance",XINSTANCE,OK) From DOSBASE
If OK <> 0
    OK=1
    Goto FIN_INIT_TRA
Endif
# Get the SQL Server hostname from CONNECTSTR. Remove # and \ right part if exist
XHOSTNAME = getenv$("CONNECTSTR")
If (instr(0,XHOSTNAME,"\") > 0)
         XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"\")-1)
Endif
If (instr(0,XHOSTNAME,"#") > 0)
        XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"#")-1)
Endif
#XINSTANCE = ".\"+XINSTANCE
XINSTANCE = XHOSTNAME+'\'+XINSTANCE

#
If adxmac(0)=""
    APPLI=nomap
Else
    APPLI=adxmac(0)+"@"+nomap
Endif
Call PASSE(APPLI,XBASE,USER,PASSE,BASE,TBIDX) From ORAPASSE
If BASE<>""
 #preparation ordre de fin
 FICSQL = filpath(REPTMP+"/tmp","sqletr"+num$(GSQLTRASPID),"sql","","",GSQLTRAMAC)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath(REPTMP+"/tmp","sqletr"+num$(GSQLTRASPID),"log","","",GSQLTRAMAC)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 ##42936 VPO 10/09/07 ano sur lancement trace SQL
 #
 # # jira X3-86047 86048 86049
 If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
      GSQLTRAORD = '%SQLCMD_EXE%'-'-S'-XINSTANCE-'-d'-XBASE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -w250 -U'-AUTHEN_LOGIN-'-P'-VPWD
 Else
      GSQLTRAORD = '%OSQL_EXE%'-'-D'-BASE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -n -w250 -U sa -P'-VPWD
 Endif
 #
 FICSQL = filpath(REPTMP+"/tmp","sqlbtr"+num$(GSQLTRASPID),"sql","","",GSQLTRAMAC)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath(REPTMP+"/tmp","sqlbtr"+num$(GSQLTRASPID),"log","","",GSQLTRAMAC)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 FICCMD = filpath(REPTMP+"/tmp","sqlbtr"+num$(GSQLTRASPID),"BAT","","",GSQLTRAMAC)
 Call MACHINE(FICCMD,MACBID,CMDFIC) From ORDSYS
 Openo FICSQL , 0
 Wrseq "DECLARE @rc int"
 Wrseq "DECLARE @DBName nvarchar(50)"
 Wrseq "DECLARE @FileName nvarchar(256)"
 Wrseq "DECLARE @SPID int"
 Wrseq "DECLARE @TraceID int"
 Wrseq "declare @maxfilesize bigint"
 Wrseq ""
 Wrseq "set @SPID="+num$(GSQLTRASPID)
 Wrseq "set @DBName='["+XBASE+"]'"
 Wrseq "set @FileName='"+GSQLTRA+"'"
 ##VPO 02/10/09 58320 pb taille fichier trace SQL Server
 ##Wrseq "set @maxfilesize = 5 "
 Wrseq "set @maxfilesize = 2000 "
 Wrseq ""
 Wrseq "exec @rc = sp_trace_create @TraceID output, 0, @FileName, @maxfilesize, NULL "
 Wrseq "if (@rc != 0) goto error"
 Wrseq ""
 Wrseq "-- Set the events"
 Wrseq "declare @on bit"
 Wrseq "set @on = 1"
 Local Integer I_I
 For I_I=1 To [M:SQL2]NBEVT-1
    If [M:SQL2]GROUPE(I_I)=""
       If ([M:SQL0]RECUP=1 and [M:SQL2]STDFLG(I_I)=2) or
&          ([M:SQL0]RECUP=2 and [M:SQL2]TUNFLG(I_I)=2) or
&          ([M:SQL0]RECUP=3 and [M:SQL2]APRENDRE(I_I)=2 )
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 1, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 13, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 14, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 15, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 16, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 17, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 18, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 21, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 22, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 23, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 28, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 29, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 31, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 32, @on"
          Wrseq "exec sp_trace_setevent @TraceID, "+[M:SQL2]CODE(I_I)+", 34, @on"
       Endif
    Endif
 Next I_I
 Wrseq ""
 Wrseq ""
 Wrseq "-- Set the Filters"
 Wrseq "declare @intfilter int"
 Wrseq "declare @bigintfilter bigint"
 Wrseq ""
 Wrseq "exec sp_trace_setfilter @TraceID, 10, 0, 7, N'SQL Profiler'"
 Wrseq "set @intfilter = @SPID"
 Wrseq "exec sp_trace_setfilter @TraceID, 12, 1, 0, @intfilter"
 Wrseq ""
 Wrseq "exec sp_trace_setfilter @TraceID, 35, 1, 6, @DBName"
 Wrseq ""
 Wrseq "-- Set the trace status to start"
 Wrseq "exec sp_trace_setstatus @TraceID, 1"
 Wrseq ""
 Wrseq "goto finish"
 Wrseq ""
 Wrseq "error: "
 Wrseq ""
 Wrseq "finish: "
 Wrseq ""
 Wrseq "select RC=@rc,TRACEID=@TraceID"
 Wrseq "GO"
 Wrseq "EXIT"
 Openo
 ##42936 VPO 10/09/07 ano sur lancement trace SQL

 Openo FICCMD , 0
 Wrseq "@ECHO OFF"
 Wrseq "BREAK OFF"
 # # jira X3-86047 86048 86049
 If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        SQLDBA = "sqlcmd"
        Wrseq "SET SQLCMD_EXE="+SQLDBA
        WORDRE = 'IF EXIST "%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE" SET SQLCMD_EXE="%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE"'
        Wrseq WORDRE
        WORDRE = '%SQLCMD_EXE%'-'-S'-XINSTANCE-'-d'-XBASE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -w250 -U'-AUTHEN_LOGIN-'-P'-VPWD
        Wrseq WORDRE
 Else
        SQLDBA = "osql"
        Wrseq "SET OSQL_EXE="+SQLDBA
        WORDRE = 'IF EXIST "%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE"'
        Wrseq WORDRE
        WORDRE = '%OSQL_EXE%'-'-D'-BASE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -n -w250 -U sa -P'-VPWD
        Wrseq WORDRE
 Endif
 Wrseq "BREAK ON"
 Openo
 System COMMANDE = GSQLTRAMAC+'@'+CMDFIC

 If filinfo(FICTRA,0)>=0
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   If len(LIGNE)>0
    J = instr(1,LIGNE," ")
    If J
     RESU = left$(LIGNE,J-1)
     RESTE= right$(LIGNE,J)
     RESTE = vireblc(RESTE,2)
     If RESU <> "0" or RESTE="0" Then
       # on a une erreur
        GMESSAGE = mess(6,123,1)+"\"-LIGNE
        Call ERREUR(GMESSAGE) From GESECRAN
        ERR=1
     Else
        GSQLIDTRA = val(RESTE)
     Endif
    Endif
    Break
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Else
    ERR=1
 Endif
 System COMMANDE = GSQLTRAMAC+'@ae_rm'-'"'+TRAFIC+'"'
 System COMMANDE = GSQLTRAMAC+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = GSQLTRAMAC+'@ae_rm'-'"'+CMDFIC+'"'
Endif

$FIN_INIT_TRA
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Return

###################################################################################################
# Algorithme de demarrage de la trace
###################################################################################################
$END_TRA
Local Char MACBID(GDIMFIC)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC), FICCMD(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC), CMDFIC(GDIMFIC)
Local Char    WORDRE(250),LIGNE(250)
Local Integer ER
Local Char REPTMP(GDIMFIC)
Local Char    COMMANDE(250)


Call GETENV(GSQLTRAMAC,"ADXDIR",REPTMP ) From ORDSYS

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = chr$(13)+chr$(10) : adxium = GASCII


If GSQLTRAORD<>""
 FICSQL = filpath(REPTMP+"/tmp","sqletr"+num$(GSQLTRASPID),"sql","","",GSQLTRAMAC)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath(REPTMP+"/tmp","sqletr"+num$(GSQLTRASPID),"log","","",GSQLTRAMAC)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 FICCMD = filpath(REPTMP+"/tmp","sqletr"+num$(GSQLTRASPID),"BAT","","",GSQLTRAMAC)
 Call MACHINE(FICCMD,MACBID,CMDFIC) From ORDSYS
 Openo FICSQL , 0
 Wrseq "DECLARE @RC1 int"
 Wrseq "DECLARE @RC2 int"
 Wrseq "DECLARE @TraceID int"
 Wrseq "set @TraceID="+num$(GSQLIDTRA)
 Wrseq "-- Stop trace (status 0 = stop)."
 Wrseq "-- The function fn_trace_getinfo() will still show the trace and"
 Wrseq "--    you can restart it if you set the status back to 1."
 Wrseq "EXEC @RC1 = sp_trace_setstatus @TraceID, 0"
 Wrseq ""
 Wrseq "-- Remove trace (status 2 = remove)."
 Wrseq "-- The function fn_trace_getinfo() will no longer show the trace"
 Wrseq "--    and you can't restart it."
 Wrseq "EXEC @RC2 = sp_trace_setstatus @TraceID, 2"
 Wrseq "select RC1=@RC1,RC2=@RC2"
 Wrseq "GO"
 Wrseq ""
 Wrseq "EXIT"
 Openo


 Openo FICCMD , 0
 Wrseq "@ECHO OFF"
 Wrseq "BREAK OFF"
 # # jira X3-86047 86048 86049
 If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
      SQLDBA = "sqlcmd"
      Wrseq "SET SQLCMD_EXE="+SQLDBA
      WORDRE = 'IF EXIST "%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE" SET SQLCMD_EXE="%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE"'
      Wrseq WORDRE
 Else
      SQLDBA = "osql"
      Wrseq "SET OSQL_EXE="+SQLDBA
      WORDRE = 'IF EXIST "%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE"'
      Wrseq WORDRE
 Endif
 Wrseq GSQLTRAORD
 Wrseq "BREAK ON"
 Openo
 System COMMANDE = GSQLTRAMAC+'@'+CMDFIC

 If filinfo(FICTRA,0)>=0
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   If len(LIGNE)>0
    J = instr(1,LIGNE," ")
    If J
     RESU = left$(LIGNE,J-1)
     RESTE= right$(LIGNE,J)
     RESTE = vireblc(RESTE,2)
     If RESU <> "0" or RESTE<>"0" Then
       # on a une erreur
        GMESSAGE = mess(6,123,1)+"\"-LIGNE
        Call ERREUR(GMESSAGE) From GESECRAN
        ERR=1
     Endif
    Endif
    Break
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Endif
 System COMMANDE = GSQLTRAMAC+'@ae_rm'-'"'+TRAFIC+'"'
 System COMMANDE = GSQLTRAMAC+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = GSQLTRAMAC+'@ae_rm'-'"'+CMDFIC+'"'
Endif

adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Return

###################################################################################################
# Algorithme de lecture de la trace pour creer fichier de trace : filpath('TRA',GTRACE,"tra")
###################################################################################################
$RECUP_TRA
Local Char APPLI(100), XBASE(20) ,MACBID(GDIMFIC)
Local Char BASE(30), USER(30), PASSE(30)
Local Char TBIDX(30)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC), FICCMD(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC), CMDFIC(GDIMFIC)
Local Char    WORDRE(250),LIGNE(250)
Local Char    CODE(250)
Local Char PROPERTY(100),VPROP(200),VPWD(200)
Local Integer OK,DEBUT,CPT,NB_PRES
Local Integer ER
Local Char REPTMP(GDIMFIC)
Local Char    COMMANDE(250)
Local Char TEXT(250)(3)
Local Char AUTHEN_LOGIN(200)
Local Char XINSTANCE(200)
Local Char XHOSTNAME(200) : # Hostname (, port) where the SQL Server is running. Could be "." for local host
Local Integer OK

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = chr$(13)+chr$(10) : adxium = GASCII

Call GETENV(GSQLTRAMAC,"ADXDIR",REPTMP ) From ORDSYS

# jira X3-86047 86048 86049
# Récupération du passwd authenfication login
#Call RECHPROP(PROPERTY,VPROP,OK) From INTRUTILA
PROPERTY="database.software.sqlinternalpwd"
Call PASSWD(PROPERTY,VPWD,OK) From DOSBASE
If OK <> 0
    ERR=1
    Goto FIN_READ_TRA
Endif
#Call DECRYPTO(VPROP,VPWD) From GESUSER
# recup authentification login sa si
Call PASSWD("database.software.sqlinternallogin",AUTHEN_LOGIN,OK) From DOSBASE
If OK <> 0
    ERR=1
    Goto FIN_READ_TRA
Endif

# instance ?
Call RECH_PROPERTY("database.adonix.sqlinstance",XINSTANCE,OK) From DOSBASE
If OK <> 0
    ERR=1
    Goto FIN_INIT_TRA
Endif
# Get the SQL Server hostname from CONNECTSTR. Remove # and \ right part if exist
XHOSTNAME = getenv$("CONNECTSTR")
If (instr(0,XHOSTNAME,"\") > 0)
         XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"\")-1)
Endif
If (instr(0,XHOSTNAME,"#") > 0)
        XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"#")-1)
Endif
#XINSTANCE = ".\"+XINSTANCE
XINSTANCE = XHOSTNAME+'\'+XINSTANCE

If adxmac(0)=""
    APPLI=nomap
Else
    APPLI=adxmac(0)+"@"+nomap
Endif
Call PASSE(APPLI,XBASE,USER,PASSE,BASE,TBIDX) From ORAPASSE
If BASE=""
    ERR=1
    Goto FIN_READ_TRA
Endif

FICSQL = filpath(REPTMP+"/tmp","sqlrtr"+num$(GSQLTRASPID),"sql","","",GSQLTRAMAC)
Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
FICTRA = filpath(REPTMP+"/tmp","sqlrtr"+num$(GSQLTRASPID),"log","","",GSQLTRAMAC)
Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
FICCMD = filpath(REPTMP+"/tmp","sqlrtr"+num$(GSQLTRASPID),"BAT","","",GSQLTRAMAC)
Call MACHINE(FICCMD,MACBID,CMDFIC) From ORDSYS
Openo FICSQL , 0
Wrseq "Select identity(int) as TrcKey,[EventClass],[EventSubClass],"
Wrseq "[StartTime],[EndTime],[CPU],[Reads],[Writes],[Duration],"
Wrseq "[NestLevel],[ObjectID],[ObjectName],[ObjectType],"
Wrseq "[Error],[Success],[Mode],[TextData]"
Wrseq "INTO #TrcData"
Wrseq "FROM ::fn_trace_gettable(N'"+GSQLTRA+".trc', default)"
Wrseq ""
Wrseq "SELECT '[EventClass]='+cast(EventClass as varchar)+CHAR(10),"
Wrseq "'[EventSubClass]='+ISNULL(cast(EventSubClass as varchar),' ')+CHAR(10),"
Wrseq "cast('[StartTime]='+ISNULL(convert(varchar,StartTime,120),'-')+REPLICATE(' ',50-DATALENGTH('[StartTime]='+ISNULL(convert(varchar,StartTime,120),'-')))+"
Wrseq "'[EndTime]='+ISNULL(convert(varchar,EndTime,120),'-') as varchar(100))+CHAR(10),"
Wrseq "cast('[Duration]='+cast(ISNULL(Duration,0) as varchar)+REPLICATE(' ',25-DATALENGTH('[Duration]='+cast(ISNULL(Duration,0) as varchar)))+"
Wrseq "'[CPU]='+cast(ISNULL(CPU,0) as varchar)+REPLICATE(' ',25-DATALENGTH('[CPU]='+cast(ISNULL(CPU,0) as varchar)))+"
Wrseq "'[Reads]='+cast(ISNULL(Reads,0) as varchar)+REPLICATE(' ',25-DATALENGTH('[Reads]='+cast(ISNULL(Reads,0) as varchar)))+"
Wrseq "'[Writes]='+cast(ISNULL(Writes,0) as varchar) as varchar(100))+CHAR(10),"
Wrseq "cast('[ObjectID]='+cast(ISNULL(ObjectID,0) as varchar)+REPLICATE(' ',25-DATALENGTH('[ObjectID]='+cast(ISNULL(ObjectID,0) as varchar)))+"
Wrseq "'[ObjectType]='+cast(ISNULL(ObjectType,0) as varchar)+REPLICATE(' ',25-DATALENGTH('[ObjectType]='+cast(ISNULL(ObjectType,0) as varchar)))+"
Wrseq "'[ObjectName]='+ISNULL(cast(ObjectName as varchar),' ') as varchar(100))+CHAR(10),"
Wrseq "cast('[NestLevel]='+cast(ISNULL(NestLevel,0) as varchar)+REPLICATE(' ',25-DATALENGTH('[NestLevel]='+cast(ISNULL(NestLevel,0) as varchar)))+"
Wrseq "'[Success]='+cast(ISNULL(Success,0) as varchar)+REPLICATE(' ',25-DATALENGTH('[Success]='+cast(ISNULL(Success,0) as varchar)))+"
Wrseq "'[Error]='+cast(ISNULL(Error,0) as varchar)+REPLICATE(' ',25-DATALENGTH('[Error]='+cast(ISNULL(Error,0) as varchar)))+"
Wrseq "'[Mode]='+cast(ISNULL(Mode,0) as varchar) as varchar(100))+CHAR(10),"
Wrseq "ISNULL(TextData,'-')"
Wrseq "FROM #TrcData"
If GSQLTRAOPT = 2 : #duree
    Wrseq "ORDER BY Duration desc,TrcKey asc"
Elsif GSQLTRAOPT = 3 : #CPU
    Wrseq "ORDER BY CPU desc,TrcKey asc"
Elsif GSQLTRAOPT = 4 : # WRITES
    Wrseq "ORDER BY Writes desc,TrcKey asc"
Elsif GSQLTRAOPT = 5 : # READS
    Wrseq "ORDER BY Reads desc,TrcKey asc"
Else
    Wrseq "ORDER BY TrcKey asc"
Endif
Wrseq "GO"
Wrseq "EXIT"
Openo

 Openo FICCMD , 0
 Wrseq "@ECHO OFF"
 Wrseq "BREAK OFF"
 # jira X3-86047 86048 86049
 If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
      SQLDBA = "sqlcmd"
      Wrseq "SET SQLCMD_EXE="+SQLDBA
      WORDRE = 'IF EXIST "%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE" SET SQLCMD_EXE="%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE"'
      Wrseq WORDRE
      WORDRE = '%SQLCMD_EXE%'-'-S'-XINSTANCE-'-d'-XBASE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -w10000 -s -U'-AUTHEN_LOGIN-'-P'-VPWD
      Wrseq WORDRE
 Else
      SQLDBA = "osql"
      Wrseq "SET OSQL_EXE="+SQLDBA
      WORDRE = 'IF EXIST "%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE"'
      Wrseq WORDRE
      WORDRE = '%OSQL_EXE%'-'-D'-BASE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -n -w10000 -s -U sa -P'-VPWD
      Wrseq WORDRE
 Endif
 Wrseq "BREAK ON"
 Openo
 System COMMANDE = GSQLTRAMAC+'@'+CMDFIC

If filinfo(FICTRA,0)>=0
    Local Integer NB_EVT
    Local Integer MAX_EVT : MAX_EVT=100
    Local Char EVT_CODE(3)(1..MAX_EVT),EVT_NAME(30)(1..MAX_EVT)
    Local Integer EVT_CLASS(1..MAX_EVT),EVT_STDFLG(1..MAX_EVT),EVT_TUNFLG(1..MAX_EVT)
    Gosub INIT_INFOSEVT

    adxifs = "" : adxirs = chr$(10) : adxium = GASCII
    Openi FICTRA
    Rdseq LIGNE
    CPT=0
    DEBUT=0
    NB_PRES=0
    While fstat=0
        If DEBUT=0 and left$(vireblc(LIGNE,0),13)="[EventClass]=" : DEBUT=1 : Endif
        If DEBUT=1
           If left$(vireblc(LIGNE,0),13)="[EventClass]=" Then
              LIGNE = vireblc(LIGNE,2)
              CODE=right$(LIGNE,14)
              IDX=find(CODE,EVT_CODE(1..NB_EVT))
              ##38949 VPO 10/09/07 ano liste evt récupérés
              If IDX<=0 & val(CODE)>500 : DEBUT=0 : Endif
              If DEBUT=1
                  If IDX>0 : CODE=LIGNE-EVT_NAME(IDX) : Else : CODE=LIGNE : Endif
                  CPT=1
                  NB_PRES+=1
                  If GSQLTRAOPP > 0 and NB_PRES>GSQLTRAOPP : Break : Endif
              Endif
           Elsif CPT=2 Then : # [EventSubClass]
              LIGNE = vireblc(LIGNE,2)
              Call ECR_TRACE(string$(100,"*"),0) From GESECRAN
              Call ECR_TRACE_F(CODE,LIGNE,"","","",60,40,0,0,0,0) From GESECRAN
              Call ECR_TRACE(string$(len(CODE),"*"),0) From GESECRAN
           Elsif CPT=3 Then : # [StartTime]+[EndTime]
              LIGNE = vireblc(LIGNE,2)
              Call ECR_TRACE(LIGNE,0) From GESECRAN
           Elsif CPT=4 Then  : # [Duration]+[CPU]+[Reads]+[Writes]
              LIGNE = vireblc(LIGNE,2)
              Call ECR_TRACE(LIGNE,0) From GESECRAN
           Elsif CPT=5 Then : # [ObjectID]+[ObjectType]+[ObjectName]
              LIGNE = vireblc(LIGNE,2)
              Call ECR_TRACE(LIGNE,0) From GESECRAN
           Elsif CPT=6 Then : # [NestLevel]+[Success]+[Error]+[Mode]
              LIGNE = vireblc(LIGNE,2)
              Call ECR_TRACE(LIGNE,0) From GESECRAN
           Elsif CPT=7 Then
              LIGNE = vireblc(LIGNE,2)
              If LIGNE<>"-" Then
                  Call ECR_TRACE(string$(len(CODE),"*"),0) From GESECRAN
                  Call ECR_TRACE(LIGNE,0) From GESECRAN
              Endif
           Else
              LIGNE = vireblc(LIGNE,1)
              If LIGNE<>"" Then
                  LIGNE=ctrans(LIGNE,"|","!")
                  Call ECR_TRACE(LIGNE,0) From GESECRAN
              Endif
           Endif
           CPT+=1
       Endif
       Rdseq LIGNE
    Wend
    Openi
Endif
System COMMANDE = GSQLTRAMAC+'@ae_rm'-'"'+TRAFIC+'"'
System COMMANDE = GSQLTRAMAC+'@ae_rm'-'"'+SQLFIC+'"'
System COMMANDE = GSQLTRAMAC+'@ae_rm'-'"'+CMDFIC+'"'

$FIN_READ_TRA
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Return



######################################################################################
Subprog AP_PRES(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
   [M:SQL0]NBPRES=0
   Affzo [M:SQL0]NBPRES
Endif
End

######################################################################################
Subprog AV_NBPRES(VALEUR)
Variable Decimal VALEUR
If [M:SQL0]PRES<>2
   [S]mkstat=2
Endif
End


######################################################################################
Subprog AV_APRENDRE(VALEUR)
Variable Integer VALEUR
If [M:SQL1]GROUPE(nolign-1)<>""
   [S]mkstat=1
Endif
End


######################################################################################

Subprog B1_NBEVT
 Local Integer I_I
 For I_I=1 To [M:SQL1]NBEVT
    If [M:SQL1]GROUPE(I_I)="" and [M:SQL1]APRENDRE(I_I)<>2
         [M:SQL1]APRENDRE(I_I)=2
    Endif
 Next I_I
 Affzo [M:SQL1]10
End

Subprog B2_NBEVT
 Local Integer I_I
 For I_I=1 To [M:SQL1]NBEVT
    If [M:SQL1]GROUPE(I_I)="" and [M:SQL1]APRENDRE(I_I)<>1
         [M:SQL1]APRENDRE(I_I)=1
    Endif
 Next I_I
 Affzo [M:SQL1]10
End


######################################################################################

