#** #############################################################################################
#* Treats the "Date selection mode" of the Payment proposal screen and/or
#* the visibility of the Due date fields in the discount section of the
#* Payment proposal screen
#*
#*  @param COMPANY      Value Char     Company
#*
#*  @param MODE         Value Integer   Date selection mode.
#*                      Possible values: (1 = Due date) (2 = Discount) (3 = Both)
#*
#*! #############################################################################################

Subprog SETSELECTIONSETTINGS(COMPANY, MODE)
  Value Char COMPANY
  Value Integer MODE
  #If MODE is not 0 -> call the Method witch treats the "Date selection mode" of the Payment proposal screen
  If MODE <> 0 : Call SETDATESELMODE(MODE): Endif

  #If COMPANY is not empty -> call the Method witch sets the visibility of the
  #Due Date fields in the discount section of the Payment proposal screen
  If COMPANY <> "" : Call SETDSCDUEVISIBILITY(COMPANY) : Endif
End


#** #############################################################################################
#* Treats the Discount settings "Allowance days" and "Allways use discount". If "Allways use
#* discount" is ticked then the field "Allowance days" is disabled. Otherwise if addtional
#* allowance days are entered the checkbox for allways use discount is disabled
#*
#*  @param ALLDAYS      Value Integer   Allowance days
#*  @param AllWAYSDIS   Value Integer   Value of "Allways discount" checkbox
#*                      Possible values: (1 = not ticked) (2 = ticked)
#*
#*! #############################################################################################

Subprog SETDISCOUNTSETTINGS(ALLDAYS, ALLWAYSDIS)
  Value Integer ALLDAYS
  Value Integer ALLWAYSDIS
  If ALLWAYSDIS = 2
    #If Allways use discount is ticked => Disable Additional Allowance days
    [M:DIA]ADDALLDAY = 0 : Grizo [M:DIA]ADDALLDAY
  Else
    #if Additional Allowance days are entered
    If ALLDAYS > 0 Then
      #If not 0 => disable allways use discount
      Grizo [M:DIA]ALWDISFLG
    Else
      #If 0 => enable allways use discount and/or additional allowance days
     Actzo  [M:DIA]ADDALLDAY
     Actzo  [M:DIA]ALWDISFLG
     Affzo  [M:DIA]ALWDISFLG
     Affzo [M:DIA]ADDALLDAY
    Endif
  Endif
End





#** #############################################################################################
#*Sets the visibility of the Due date fields in the discount section of the
#*Payment proposal screen depending on the parameter "DEPDUDDAT". The values of the
#*parameter can be "activated" or "deactivated"
#*
#* @param COMPANY      Value Char     Company
#*
#*! #############################################################################################
Subprog SETDSCDUEVISIBILITY(COMPANY)
  Value Char COMPANY
  Local Char DEPDUDDAT(1)
  Call PARAM(COMPANY,"DEPDUDDAT",DEPDUDDAT) From ADOVAL
  #set due date range in the discount section to visible
  #Note: The field FMTDATDIS is a hidden field that is assigned to the
  #fields DATDISDUDMIN and DATDISDUDMAX as format.
# 2012-09-17 DN MODIF BEGIN
  # Note: If the parameter DEPDUDDAT is not set at all we assume it
  #       as activated.
  If DEPDUDDAT <> "2"
# 2012-09-17 DN MODIF ORIG
#  If DEPDUDDAT = "1"
# 2012-09-17 DN MODIF END
    [M]FMTDATDIS = "DZ:"+GFMDAT
  Else
    [M]FMTDATDIS = "-DZ:"+GFMDAT
  Endif
  #refresh the two fields to make changes visible.
  Affzo [M:DIA]DATDISDUDMIN
  Affzo [M:DIA]DATDISDUDMAX
End



#** #############################################################################################
#* Treats the "Date selection mode" of the Payment proposal screen. Depending on
#* the selection blocks or ranges will be greyed out or set to active.
#*
#*  @param MODE         Value Integer   Date selection mode.
#*                      Possible values: (1 = Due date) (2 = Discount) (3 = Both)
#*
#*! #############################################################################################
Subprog SETDATESELMODE(MODE)
    Value Integer MODE
    Case MODE
        When 1
          Diszo [DIA]9 : Actzo [DIA]8 #: Effzo [DIA]9
          [M:DIA]DATDISDUDMIN = [0/0/0] : [M:DIA]DATDISDUDMAX = [0/0/0]
          [M:DIA]DATDISMIN = [0/0/0] : [M:DIA]DATDISMAX = [0/0/0]
          [M:DIA]ADDALLDAY = 0: [M:DIA]ALWDISFLG = 1
          Affzo [DIA]9
        When 2 :
          Diszo [DIA]8 : Actzo [DIA]9 #: Effzo [DIA]8
          [M:DIA]DATMIN = [0/0/0] : [M:DIA]DATMAX = [0/0/0]
        When 3 : Actzo [DIA]8-9
    Endcase
End


#** ##################################################################################################
#*  Return the combined querystring for due date criteria in due date section and/or discount section
#*
#* @return RESULT      Local char   Querystring
#*
#* @param MODE         Value Integer   Date selection mode.
#*                     Possible values: (1 = Due date) (2 = Discount) (3 = Both)
#*
#*! ##################################################################################################
Funprog GETDUEDATEQUERYSTRING(MODE)
  Value Integer MODE
  Local Char RESULT(255)
  Case MODE
      When 1 :
        #when 'Due date' is selected call the function that provides the query string
        #for 'Due date' criteria in the 'Due date' section
        RESULT = func DUEDATEQUERYSTRING()
      When 2:
        #when 'Discount' is selected call the function that provides the query string
        #for 'Due date' criteria in the 'Discount' section
        RESULT = func DSCDUEDATEQUERYSTRING()
      When 3:
        #when 'Both' is selected call the function that provides the combined query string
        #for both, the 'Due date' criteria in the 'Due date' section
        #and the 'Due date' criteria in the 'Discount' section
        RESULT = func COMBINEDUEDATEQUERYSTRING()
  Endcase
  #If the result is not empty add a 'AND' in front of the result string
  #to ensure the correctnes of the complete criteria query string.
  If RESULT <> "" Then : RESULT = "& " + RESULT : Endif
End RESULT

#** ##########################################################################################################
#*  Return the querystring for due date criteria in due date section in the payment proposal screen
#*
#* @return    RESULT      Local char   Querystring
#*
#*! ##########################################################################################################
Funprog DUEDATEQUERYSTRING()
  Local Char RESULT(255)
  Local Char ADDAND(3)

  #check 'Due date from' criteria in the 'Due date' section
  If [M:DIA]DATMIN<>[0/0/0]
    RESULT += "DUDDAT>=["+format$(GFMD,[M:DIA]DATMIN)+"]"
    #set 'ADDAND' to combine the parts of the querystring
    ADDAND = " & "
  Endif
  #check 'Due date to' criteria in the 'Due date' section
  If [M:DIA]DATMAX<>[0/0/0]
    RESULT += ADDAND + "DUDDAT<=["+format$(GFMD,[M:DIA]DATMAX)+"]"
  Endif
End RESULT

#** ##########################################################################################################
#*
#* Return the querystring for due date criteria in Discount section of the payment proposal screen
#*
#* @return    RESULT      Local char   Querystring
#*
#*! ##########################################################################################################
Funprog DSCDUEDATEQUERYSTRING()
  Local Char RESULT(255)
  Local Char ADDAND

  #check 'Due date from' criteria in the 'Discount' section
  If [M:DIA]DATDISDUDMIN<>[0/0/0]
    RESULT += "DUDDAT>=["+format$(GFMD,[M:DIA]DATDISDUDMIN)+"]"
    #set 'ADDAND' to combine the parts of the querystring
    ADDAND = " & "
  Endif
  #check 'Due date to' criteria in the 'Discount' section
  If [M:DIA]DATDISDUDMAX<>[0/0/0]
    RESULT += ADDAND + "DUDDAT<=["+format$(GFMD,[M:DIA]DATDISDUDMAX)+"]"
    ADDAND = " & "
  Endif

  # select only open items with an assigned discount term.
  RESULT += ADDAND + "DEP <> ''"

End RESULT

#** #########################################################################################################
#*  Return the combination of querystrings for due date criteria in due date section and the due date
#*  criteria in Discount section of the payment proposal screen
#*
#* @return    RESULT      Local char   Querystring
#*
#*! ##########################################################################################################
Funprog COMBINEDUEDATEQUERYSTRING()
  Local Char RESULT(255)
  #Get the querystring for the 'Due date' criteria in the 'Due date' section
  Local Char DUEDATESTRING(255) : DUEDATESTRING = func DUEDATEQUERYSTRING()
  If [L]DUEDATESTRING <> ""
    #If DUEDATESTRING not empty then combine it with the discount querystring by an OR condition.

    RESULT = "(" + DUEDATESTRING + " | (" + func DSCDUEDATEQUERYSTRING + "))"
  Endif
  #if DUEDATESTRING is empty we don't need to limitate the result because in this case every open item
  #is in the selection. This is because it is a logical OR relation between due date section and discount section

End RESULT



#** #############################################################################################
#*
#*Return the Information wether the open items matches the discount terms or not
#*
#* @return:RESULT      Local Integer   1 if matching else 0
#* @param DUEDATE      Value Date()     Duedate of the open item
#* @param DEP          Value Char()     Code of the discount terms of the open item
#* @param NUM          Value Char()     Journal number of the open item
#* @param TYP          Value Char()     Journal type of the open item
#* @param BPRTYP       Value integer()  Business partner type (1 => customer ; 2 => supplier)
#* @param DISCBASE     Value Char()     Parameter that indicates if discount terms refer on
#*                                          invoice data or duedate (1 if duedate else invoice date)
#*
#*! #############################################################################################

Funprog MATCHDISCOUNTTERMS(MODE, DEP, DUEDATE, NUM, TYP, BPRTYPE, DISCBASE)
  Value Integer MODE
  Value Char DEP
  Value Date DUEDATE
  Value Char TYP
  Value Char NUM
  Value Integer BPRTYPE
  Value Char DISCBASE
  Local Integer RESULT
  Local Date DISCOUNTDATE
  Local Date REFERENCEDATE

  #This function detects if a check for discount date is necessary
  If func NOCHECKNECESSARY(DEP, DUEDATE, MODE) Then : RESULT = 1 : End RESULT : Endif


  If !clalev([F:TDP]) : Local File TABDEPAGIO[TDP] : Endif
  Read [F:TDP]TDA0 = DEP

  If fstat : RESULT = 0 : End RESULT: Endif
  #DEPENDING ON DISCBASE the due date or the invoice Date
  #
  #angre 07/26/12 a new GETREFERENCEDATE function is called. this functions differentiate between customer and supplier (BPRTYPE)
  #REFERENCEDATE = func GETREFERENCEDATE(DUEDATE, NUM, TYP, DISCBASE)
  REFERENCEDATE = func PAYDEPLIB3.GETREFERENCEDATE(DUEDATE, BPRTYPE, TYP, NUM, DISCBASE)

  #loop through the discount rates
  For I = 0 To dim([F:TDP]DEPRAT)-1
    Raz DISCOUNTDATE

    If [F:TDP]DEPRAT(I) <0
      If DISCBASE = "1"
        #If the reference date is the due date we add the discount days.
        #in fact we substract the absolute number of days because the values
        #in the database are negative in this case
        DISCOUNTDATE = REFERENCEDATE + [F:TDP]DEPDAY(I)
      Else
        #if the reference date is the invoice date we add the discount days.
        #we add one day less than in the database because reference date + the value
        #of discount days results the date from that on no more discount is granted.
        #But we need the last day discount is granted. Sounds complicated but it is not ;-)
        DISCOUNTDATE = REFERENCEDATE + [F:TDP]DEPDAY(I+1) - 1
      Endif

        #once the discount date is determined it can be checked if it matches the
        #'Discount date' criteria in the 'Discount' section
      If [M:DIA]DATDISMIN = [0/0/0] & [M:DIA]DATDISMAX <> [0/0/0]

        If DISCOUNTDATE <= [M:DIA]DATDISMAX: RESULT = 1 : Break : Endif

      Elsif [M:DIA]DATDISMIN <> [0/0/0] & [M:DIA]DATDISMAX = [0/0/0]

        If DISCOUNTDATE >= [M:DIA]DATDISMIN : RESULT = 1 : Break : Endif

      Elsif [M:DIA]DATDISMIN <> [0/0/0] & [M:DIA]DATDISMAX <> [0/0/0]

        If DISCOUNTDATE >= [M:DIA]DATDISMIN & DISCOUNTDATE <= [M:DIA]DATDISMAX : RESULT = 1 : Break : Endif

      Endif
    Endif
  Next
End RESULT


#** #############################################################################################
#*
#*Detects if a check of discount date in the discount section is necessary
#*
#* @return:RESULT      Local Integer   1 not necessary 0 if necessary
#* @param DUEDATE      Value Date()   Duedate of the open item
#* @param DEP          Value Char()   Code of the discount terms of the open item
#* @param MODE         Value Integer     Date selection mode
#*
#*! #############################################################################################

Funprog NOCHECKNECESSARY(DEP,DUEDATE, MODE)
  Value Integer MODE
  Value Char DEP
  Value Date DUEDATE
  Local Integer RESULT
  #if mode is "Due date" or the open item is not assigned to a discount term or Discount date (from and to) is empty we don't need to check
  If MODE = 1 | DEP = '' | ([M:DIA]DATDISMAX = [0/0/0] &  [M:DIA]DATDISMIN = [0/0/0]) : RESULT = 1 : End RESULT : Endif

  #if mode is "Both" and due date match the selection criteria in the due date section we don't
  #need to check the discount selection criteria because it is a logical OR relation between due date section
  #and discount section. Therefore every open item is selected.
  If MODE = 3 : RESULT = func MATCHDUEDATETERMS(DUEDATE) : End RESULT
  Endif

  #If the due date of the open item is not in the due date range of the discount section, we don`t need to check
#  If ([M:DIA]DATDISDUDMIN<>[0/0/0] & DUEDATE < [M:DIA]DATDISDUDMIN) | ([M:DIA]DATDISDUDMAX<>[0/0/0] & DUEDATE > [M:DIA]DATDISDUDMAX )
#    RESULT = 1
#  End

End RESULT

#** #############################################################################################
#*
#*Return the Information wether the open items matches the due date terms in the due date section or not
#*
#* @return:RESULT      Local Integer   1 if matching else 0
#* @param DUEDATE      Value Date()   Duedate of the open item
#*
#*! #############################################################################################
Funprog MATCHDUEDATETERMS(DUEDATE)
  Value Date DUEDATE
  Local Integer RESULT
  #if both dates are empty => terms matched
  If [M:DIA]DATMIN = [0/0/0] & [M:DIA]DATMAX = [0/0/0] : RESULT = 1
  Elsif [M:DIA]DATMIN = [0/0/0] & [M:DIA]DATMAX <> [0/0/0]
    If DUEDATE <= [M:DIA]DATMAX: RESULT = 1 : Endif
  Elsif [M:DIA]DATMIN <> [0/0/0] & [M:DIA]DATMAX = [0/0/0]
    If DUEDATE >= [M:DIA]DATMIN : RESULT = 1 : Endif
  Elsif [M:DIA]DATMIN <> [0/0/0] & [M:DIA]DATMAX <> [0/0/0]
    If DUEDATE >= [M:DIA]DATMIN & DUEDATE <= [M:DIA]DATMAX : RESULT = 1 : Endif
  Endif

End RESULT

#** #############################################################################################
#*Return the Date on wich the discount terms refers.
#*This depends on the Parameter DISCDEP.
#*
#* @return RESULT         Local Date        Date on wich the discount terms refers
#* @param DUEDATE         Value Date()   Duedate of the open item
#* @param NUM             Value Char()   Journal number of the open item
#* @param TYP             Value Char()   Journal type of the open item
#* @param DISCPARAM       Value Char()   Parameter that indicates if discount terms refer on
#*                                          invoice data or duedate (1 if duedate else invoice date)
#*
#* This function is not called at the moment!
#*! #############################################################################################

Funprog GETREFERENCEDATE(DUEDATE, NUM, TYP, DISCBASE)
  Value Date DUEDATE
  Value Char NUM
  Value Char TYP
  Value Char DISCBASE
  Local Date RESULT

  #If reference date is duedate then it is the result
  If DISCBASE = "1"
      RESULT = DUEDATE
  #If reference date is invoice date
  #we look for the accounting date of the invoice
  Else
    If !clalev([F:SIH]) : Local File SINVOICE  [SIH] : Endif
    Read [F:SIH]SIH0 = NUM
    If !fstat
      RESULT = [F:SIH]ACCDAT
    Else
      If !clalev([F:PIH]) : Local File PINVOICE  [PIH] : Endif
      Read [F:PIH]PIH0 = NUM
      If !fstat
        RESULT = [F:PIH]ACCDAT
      Else
        If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : Endif
        Read [F:HAE] = TYP;NUM
        If !fstat
          RESULT = [F:HAE]ACCDAT
        Endif
      Endif
    Endif
  Endif

 End RESULT






#** #############################################################################################
#*Handles the additional allownance days by subtracting them from the accounting date.
#*
#* @return RESULT         Local Date        Accounting date minus the additional allowance days
#* @param ACCDATE         Value Date()   Accounting Date
#*
#*! #############################################################################################

Funprog  DATEINCLALLOWANCEDAYS(ACCDATE)
  Value Date ACCDATE
  Local Date RESULT

  #If no additional allowance days return the original accounting date
  If [M:DIA]ADDALLDAY <= 0 Then : End ACCDATE : Endif

  #if there are additional allowance days,
  #they must be subtracted from the accounting date
  RESULT = ACCDATE - [M:DIA]ADDALLDAY

End RESULT

#** ############################################################################################################
#* Detect, depending on Parameter "DATSELDEP", the highest or lowest discountrate
#*
#* @return RESULT         Local Decimal  Depending on Parameter "DATSELDEP" the highest or lowest discountrate
#* @param  DEP            Variable Char()   Code of the discount terms of the open item
#* @param  DISCOUNTRATE   Variable Decimal  Discountrate for open item
#*
#*! #############################################################################################################

Funprog  ALWAYSUSEDISCOUNT(DEP,DISCOUNTRATE,ALWDISFLG)
  Value Char DEP
  Value Decimal DISCOUNTRATE
  Value Integer ALWDISFLG

  Local Decimal RESULT
  Local Char DATSELDEP

  If DISCOUNTRATE <> 0 | [L]ALWDISFLG <> 2
    End DISCOUNTRATE
  Endif
  #Parameter DATSELDEP indicates if we use min or max deprate for "Always use discount"
  Call PARAML([F:DUD]CPY,"DATSELDEP",DATSELDEP) From ADOVAL

  #If !clalev([F:TDP]) : Local File TABDEPAGIO[TDP] : Endif
  If !clalev([F:TDA]) : Local File TABDEPAGIO[TDA] : Endif
  #Read [F:TDA]TDA0 = DEP
  Call LEC_TDA(GCURLEG,DEP) From CPTLEC
  #Call LEC_TDA(DEP) From CPTLEC

  If fstat : RESULT = 0 : End RESULT: Endif
  For I = 0 To dim([F:TDA]DEPRAT)-1
      # Get discount rate (please be aware that the discount rate is a
      # negative value. That means the less the rate, the higher is the discount),
      # depending on parameter DATSELDEP we get the min. or max discount rate.
    If [F:TDA]DEPRAT(I) < 0
      If RESULT = 0 | (DATSELDEP = "1" & [F:TDA]DEPRAT(I) < RESULT) | (DATSELDEP = "2" & [F:TDA]DEPRAT(I) > RESULT)
        RESULT = [F:TDA]DEPRAT(I)
      Endif
    Endif

  Next

End RESULT
