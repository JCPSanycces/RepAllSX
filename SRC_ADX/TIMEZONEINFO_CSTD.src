#<AdxTL>@(#)0.0.0.0 $Revision$
# Class TIMEZONEINFO


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
    When "SET_TIMEADJUST" : Gosub SET_TIMEADJUST
    When "GET_OFFSET"     : Gosub GET_OFFSET
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

$SET_TIMEADJUST
If [L]TADCOD<>""
    Local Integer I
    Local Instance TIMEADJUST Using C_TIMEADJUST

    TIMEADJUST  = NewInstance C_TIMEADJUST AllocGroup TIMEADJUST
    # Check if the code exists
    ARET_VALUE = func TIMEADJUST_CSTD.EXISTS([L]TADCOD)
    If [L]ARET_VALUE<>[V]CST_AOK
        For I=1 To maxtab(TIMEADJUST.AERROR)
            If  TIMEADJUST.AERROR(I)<>null & TIMEADJUST.AERROR(I).DEL<>2
                ARET_VALUE = max(ARET_VALUE,fmet this.ASETERROR(TIMEADJUST.AERROR(I).PRO-":"-TIMEADJUST.AERROR(I).MES,TIMEADJUST.AERROR(I).STA))
            Endif
        Next
    Else
        this.TADCOD = [L]TADCOD
    Endif

    FreeGroup TIMEADJUST
Else
    this.TADCOD = [L]TADCOD
Endif
Return

#**
#* GET_OFFSET : Return Offset for the current time zone by taking into account daylight saving time if present
#* @param DATTIM : Datetime to calculate the offset
#* @param OFFSET : Offset
#* @return Error code
#*!
$GET_OFFSET
Raz OFFSET
If this.TADCOD<>""
    Local Instance TIMEADJUST Using C_TIMEADJUST
    TIMEADJUST = NewInstance C_TIMEADJUST AllocGroup TIMEADJUST
    ARET_VALUE = fmet TIMEADJUST.GET_OFFSET(this.TADCOD,[0/0/0],DATTIM,OFFSET)
    FreeGroup TIMEADJUST
Endif
OFFSET += this.UTCOFFSET
Return

