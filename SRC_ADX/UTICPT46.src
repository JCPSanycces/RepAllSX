#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTICPT46   Squelette pour Moulinette                      Module CPT   #
#            description de la moulinette                                #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTICPT46(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT46(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTICPT46 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:CCE])  =0  Local File =DOSSIER+".CACCE"   [CCE] : Endif
If dim([F:CCE]IPT)<=0 : Goto FIN : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [CCE]
For [CCE] Where [F:CCE]IPT=0
 Readlock [CCE] Curr    
 If !fstat
  # --- alimentation des champs et réécriture enreg
  [F:CCE]IPT=2
  Rewrite [F:CCE]
  If !fstat COMPTEUR += 1 Endif
 Endif
Next
Commit

Close Local File [CCE]

$FIN
Call ECR_TRACE("UTICCE46 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : ENDIF
If filinfo(filpath("FIL","CACCE","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTICPT46(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If filinfo(filpath("FIL","CACCE","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTICPT46(APPLI)
End

