#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
End


$OUVRE
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif : # Fiscal Periods
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif : # Fiscal Years

Return


Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char    SOCIETE(GLONCPY) , SOC(GLONCPY) 
Local Char    ETAT(GLONARP) , TYP_ETAT(GLONARP)
Local Char    RACINE(10) , VALEUR(30) , PARAM(50) , PARAM2(50)
Local Date    DATDEB , DATFIN , DDEB , DFIN 
Local Integer EDEB , EFIN , K , NODATE 
Local Decimal EXE , PER 
Local Date    DATEDEBPER, DATEFINPER

Gosub OUVRE

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT) From ETAT
K = instr(1,ETAT,".")
If K
 ETAT = left$(ETAT,K-1)
Endif
## Pour ne plus tester l'état en dur
Call GETPARAM("typetat",NBPAR,PARAMETRE,TYP_ETAT) From ETAT
If TYP_ETAT="?????" : TYP_ETAT = ETAT : Endif

## Vérif de la société
Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT

Read [CPY]CPY0 = SOCIETE
If fstat
 # Société incorrecte
 Call ECR_TRACE(mess(81,116,1),1) From GESECRAN
 GOK = 0 : End
Endif

## Récup référentiel
Call SETMAINREF(SOCIETE,GTYPGEN,GTYPANA) From CPTDIV


## Vérif et recadrage des périodes

RACINE = "dat" : Gosub PERIODE
If GOK=0 : End : Endif


End


$PERIODE
NODATE = 0
Call GETPARAM(RACINE+"deb",NBPAR,PARAMETRE,VALEUR) From ETAT
If VALEUR<>"?????"
 DATDEB = VALEUR
Else
 NODATE = 1
Endif
Call GETPARAM(RACINE+"fin",NBPAR,PARAMETRE,VALEUR) From ETAT
If VALEUR<>"?????"
 DATFIN = VALEUR
Else
 NODATE = 1
Endif
If NODATE : Return : Endif

If DATDEB=[0/0/0] or DATFIN=[0/0/0]
 Call ECR_TRACE(mess(10,116,1),1) From GESECRAN : # Période incorrecte
 GOK = 0 : Return
Endif

Read [CPY]CPY0 = SOCIETE
If [F:CPY]CPYLEGFLG=2 : # Juridique
 SOC = SOCIETE : Gosub DEFPER
 If GOK<1 : Return : Endif
Endif


Return

$DEFPER

Call GETPERSOC(SOC,GTYPGEN,DATDEB,EXE,PER) From CPTSUB
If EXE=0 or PER=0
 Call ECR_TRACE(mess(10,116,1),1) From GESECRAN : # Période incorrecte
 GOK = 0 : Return
Endif
Call DATPER(SOC,GTYPGEN,EXE,PER,DATEDEBPER,DATEFINPER) From CPTSUB
If DATEDEBPER<>DATDEB
 ## The date is not a period start date
 Call ECR_TRACE(mess(49,108,1),1) From GESECRAN : # Période incorrecte
 GOK = 0 : Return
Endif

Call GETPERSOC(SOC,GTYPGEN,DATFIN,EXE,PER) From CPTSUB
If EXE=0 or PER=0
 Call ECR_TRACE(mess(10,116,1),1) From GESECRAN : # Période incorrecte
 GOK = 0 : Return
Endif
Call DATPER(SOC,GTYPGEN,EXE,PER,DATEDEBPER,DATEFINPER) From CPTSUB
If DATEFINPER<>DATFIN
 ## The date is not a period end date
 Call ECR_TRACE(mess(50,108,1),1) From GESECRAN : # Période incorrecte
 GOK = 0 : Return
Endif

Return

