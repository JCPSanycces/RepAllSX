#<AdxTL>@(#)6.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("TCY",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "LIENS"       : Gosub LIENS
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Gosub CHANGE
Endcase
Return

$INICRE
$INIMOD
# Initialisation des formats CP et RIB pour Crystal Report
Call FMTREPORT([F:TCY]POSCODFMT,[F:TCY]POSCODCRY) From SUBTCY
Call FMTREPORT([F:TCY]BIDFMT,[F:TCY]BIDCRY) From SUBTCY
Return

$LIENS
Gosub GRISE_EECFLG
Gosub GRISE_POSCODCTL
Gosub GRISE_BIDCTL
Gosub GRISE_CRTFMT
Gosub GRISE_CRNFMT
Gosub GRISE_NAFFMT
Gosub GRISE_EECFMT
Gosub GRISE_NIDFMT
Gosub GRISE_ETATFLG
Gosub GRISE_ETATFLG2
Gosub GRISE_ETATCTL           # FGR 02/03/2012 : X3SUIVI79830
# Issue X3-41872 - 2017-07-04 by CCC : hide with PYS activity code
## FQ86274 - MABON 08/01/13
#Gosub GRISE_SOCNUM
## Fin MABON
# FQ83632 - MABON 02/10/12
Gosub GRISE_SOCNUMFMT1
Gosub GRISE_SOCNUMFMT2
# Fin MABON
Gosub GRISE_CRNOBL
Gosub GRISE_CRTOBL
#110921 champ FLGDUE uniquement pour la paie en législation FRA.
# Le champ a déjà le code activité à KFR
If dim([M:TCY1]FLGDUE)>=0 & GPRODUIT<>2
  Chgfmt [M:TCY1]FLGDUE With "-LA:1"  : Raz [M:TCY1]FLGDUE
Endif
Return

$CREATION
$MODIF
Call MAJTEXTRA([M:TCY0]CRYDES,"TABCOUNTRY","CRYDES",[M:TCY0]CRY,"") From ATEXTRA          # 05/03/2012 FGR : X3SUIVI79830 : [M:TCY0] added
Call MAJTEXTRA([M:TCY2]ETATNAM,"TABCOUNTRY","ETATNAM",[M:TCY0]CRY,"") From ATEXTRA        # 05/03/2012 FGR : X3SUIVI79830 : [M:TCY2][M:TCY0] added
Call MAJTEXTRA([M:TCY2]ETATNAM2,"TABCOUNTRY","ETATNAM2",[M:TCY0]CRY,"") From ATEXTRA      # 05/03/2012 FGR : X3SUIVI79830 : [M:TCY2][M:TCY0] added
Return

$ANNULE
Delete [AXX] Where CODFIC="TABCOUNTRY" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="TABCOUNTRY" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA TABCOUNTRY"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

