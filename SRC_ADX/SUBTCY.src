# FQ59624 - MABON 06/11/09 - Si "Gestion de l'IBAN" est coché pour le pays, message d'avertissement
# sur le champ Code ISO
Subprog C_FLIBAN(VALEUR)
Variable Integer VALEUR
  If VALEUR=2 and [M:TCY1]ISO="" Then                       # 05/03/2012 FGR : X3SUIVI79830 : [M:TCY1] added
    GMESSAGE = mess(8,143,1) : # Pour gérer l'IBAN, renseignez un code ISO
    mkstat = 1 : End
  Endif
End

Subprog C_ISO(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & len(VALEUR)<2
 mkstat = 2 : End
Endif
End

Subprog C_ISOA3(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & len(VALEUR)<3
 mkstat = 2 : End
Endif
End

Subprog C_ISONUM(VALEUR)
Variable Char    VALEUR()
End

Subprog C_TELTCY(VALEUR)
Variable Char    VALEUR()
Gosub SET_CTL
End

Subprog C_TELREG(VALEUR)
Variable Char    VALEUR()
Gosub SET_CTL
If !mkstat & VALEUR<>"" & VALEUR=[M:TCY2]TELTCY             # 05/03/2012 FGR : X3SUIVI79830 : [M:TCY2] added
 GMESSAGE = VALEUR-":"-mess(63,143,1) : # La position du pays ne peut pas être la même que celle de la région
 mkstat = 2
Endif
End

$SET_CTL
Local Integer K , D , F
If VALEUR<>""
 K = instr(1,VALEUR,"-")
 If K>0
  D = val(left$(VALEUR,K-1))
  F = val(right$(VALEUR,K+1))
  If D=0 or F=0 or F<D
   K = 0
  Endif
 Endif
 If !K
  GMESSAGE = VALEUR-":"-mess(37,124,1) : # Expression incorrecte
  mkstat = 2
 Endif
Endif
Return

Subprog C_FLGSEPA(VALEUR)
Variable Integer  VALEUR
If [M:TCY1]EECFLG=2 & VALEUR=1                              # 05/03/2012 FGR : X3SUIVI79830 : [M:TCY1] added
 # Un pays appartenant à l'UE appartient obligatoirement à la zone SEPA
 GMESSAGE = mess(69,143,1)
 mkstat = 1 : End
Endif
End

