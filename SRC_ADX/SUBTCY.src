Subprog C_MINZIP(VALEUR)
Variable Decimal VALEUR

  # FGR 02/03/2012 : X3SUIVI79830
  If VALEUR >= GLONPOS Then
    GMESSAGE = mess(97,143,1) - "(" + num$(GLONPOS) + ")"
    mkstat = 1
    End
  Endif
End

