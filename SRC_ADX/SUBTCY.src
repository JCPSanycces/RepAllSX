## Fin MABON

$GRISE_SOCNUMFMT1
If dim([M:TCY1]SOCNUMFLG1)>0 & [M:TCY1]SOCNUMFLG1<>2
 Raz   [M:TCY1]SOCNUMFMT
 Affzo [M:TCY1]SOCNUMFMT
 Grizo [M:TCY1]SOCNUMFMT
Else
 If dim([M:TCY1]SOCNUMFMT)>0 Then Actzo [M:TCY1]SOCNUMFMT : Endif
Endif
Return

$GRISE_SOCNUMFMT2
If dim([M:TCY1]SOCNUMFLG2)>0 & [M:TCY1]SOCNUMFLG2<>2
 Raz   [M:TCY1]SOCNUMFMT2
 Affzo [M:TCY1]SOCNUMFMT2
 Grizo [M:TCY1]SOCNUMFMT2
Else
 If dim([M:TCY1]SOCNUMFMT2)>0 Then Actzo [M:TCY1]SOCNUMFMT2 : Endif
Endif
Return
