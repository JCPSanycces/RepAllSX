Subprog FORMA(FMT,LNG)
Variable Char    FMT()
Value    Integer LNG
If FMT="" : mkstat=1 : End : Endif
Local Decimal L , D , E , COM
Local Char    C(1)
COM = 0 : D = 0
For I=1 To len(FMT)
 C = mid$(FMT,I,1)
 If C="["
  If COM=0 & D=0 : COM = 1 : Else : E = 1 : Break : Endif
 Elsif C="]"
  If COM=1 & D=0 : COM = 0 : Else : E = 1 : Break : Endif
 Elsif COM=1
  L += 1
 Elsif instr(1,"0123456789",C)
  D = 10*D+val(C)
 Elsif !instr(1,"AaBbCLX#",C)
  E = 1 : Break
 Else
  If D=0 : L += 1
  Else   : L += D
  Endif
  D = 0
 Endif
Next I
If D<>0 or COM=1 : E = 1 : Endif
If E
# format incorrect
 GERR=1 : GMESSAGE = mess(149,100,1) : mkstat=2 : End
Elsif L>LNG
# format trop long
 GERR=1 : GMESSAGE = mess(150,100,1) : mkstat=2 : End
Endif
End

Subprog LECPAY(PAYS)
Value Char PAYS
If PAYS="" : PAYS = GPAYS : Endif
Call LECTURE("TCY",PAYS,"") From CONTOBJ
End

Subprog SAIPAYS(PAY)
Value    Char PAY
If PAY<>"" : mkstat=2 : End : Endif
End

Subprog INIPAYS(PAY,NOMPAY)
Value    Char PAY
Variable Char NOMPAY
If PAY<>""
 Call LECTEXTRA(NOMPAY,"TABCOUNTRY","CRYDES",PAY,"") From ATEXTRA
Endif
End

Subprog FMTREPORT(FMT1,FMT2)
Value    Char FMT1()
Variable Char FMT2()

Local Integer I, J, L
Local Libelle CMT
Local Char    LETTRE(1)
I = 1 : L = len(FMT1) : FMT2 = ""
While I<=L
 LETTRE = mid$(FMT1,I,1)
 If LETTRE="[" & !CMT   : CMT = 1
 Elsif LETTRE="]" & CMT : CMT = 0
 Elsif CMT : FMT2 += LETTRE
 Else
  J = 0
  While instr(1,"0123456789",LETTRE)
   J = J*10+val(LETTRE)
   I += 1 : If I>L : Break : Endif
   LETTRE = mid$(FMT1,I,1)
  Wend
  If !J : FMT2 += "x" : Else : FMT2 += string$(J,"x") : Endif
 Endif
 I += 1
Wend
FMT2 = vireblc(FMT2,1)
End

