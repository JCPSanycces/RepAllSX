#<AdxTL>@(#)0.0.0.0 $Revision$
## GPROG    = Traitement
## GWINDOW  = Ecran de saisie

Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"DCRITBAI","CALBAS","") From GSAISIE

End

######################################################################################

$ACTION
Case ACTION
 When "DEBUT" : Gosub DEBUT
 When "OK"    : Gosub OK
 When Default
Endcase
Return


$DEBUT
If clalev([F:CPY])=0   : Local File COMPANY   [CPY]   : Endif
If clalev([F:FCY])=0   : Local File FACILITY  [FCY]   : Endif
If clalev([F:FGR])=0   : Local File FACGROUP  [FGR]   : Endif
If clalev([F:HRPOA])=0 : Local File POPULA    [HRPOA] : Endif
If clalev([F:BAS])=0   : Local File BASGEN    [BAS]   : Endif
If clalev([F:HSP])=0   : Local File HISTOPAYE [HSP]   : Endif
If clalev([F:VEP])=0   : Local File VALEMP    [VEP]   : Endif
If clalev([F:VLA])=0   : Local File VALEUR    [VLA]   : Endif
If clalev([F:HRBAI])=0 : Local File BASIND    [HRBAI] : Endif
If clalev([F:CTR2])=0  : Local File EMPLOCTR  [CTR2]  : Endif

Gosub OUVRE From WPDEFTABLE
Local Integer MAXFRM
MAXFRM = 100
Local Char    SOC(GLONCPY), OLDSOC(GLONCPY)
Local Char    CRITSOC(250), CRITENT(250), CRITPAR(250), CRITID(250), CRITBAI(250)
Local Char    SOCGRP(GLONCPY)(1..30)
Local Char    FORMULE(250), EXPR(250) , OPE(2) , CODE(20) , REMPL(30)
Local Integer PRESTOT, PRES, PRESENCE, NBBASE
Local Integer NRUB , NCUM , NVAR , NPAT
Local Decimal RU(1..MAXFRM) , CU(1..MAXFRM) , VA(1..MAXFRM) , PA(1..MAXFRM)
Local Char    CRUB(GLONRUB)(1..MAXFRM) , CCUM(GLONCUM)(1..MAXFRM)
Local Char    CVAR(GLONVRA)(1..MAXFRM) , CPAT(GLONRUB)(1..MAXFRM)
Local Integer I, J, L, K, II
Local Date ENTREE, SORTIE
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","bai") From GMEMO
Affzo [M:DIA]
Setmok [DIA] With 0
Return


$OK
Sorta [M:DIA]NBLIG [M:DIA]NBLIG Order By [M:DIA]CODBAS([S]indice)
Link [HRCTR] With
& [FCY]FCY0 = [F:HRCTR]ETRFCY
& As [LNK]
TIT = mess(1,10706,1) : # Calcul des bases de répartitions
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

# Exercice XXXX du xx/xx/xx au xx/xx/xx
Call ECR_TRACE(mess(18,10706,1)-[M:DIA]EXO-mess(40,101,1)-num$([M:DIA]DATSTR)
&                            -mess(41,101,1)-num$([M:DIA]DATEND),0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(mess(2,10702,1)+space$(10)+mess(130,10703,1)+space$(2)+mess(59,116,1),0) From GESECRAN
For I=0 To [M:DIA]NBLIG-1
 Call ECR_TRACE(format$("K:10X",[M:DIA]CODBAS(I))+space$(4)
&              +num$([M:DIA]DATDEB(I))-mess(41,101,1)-num$([M:DIA]DATFIN(I)),0) From GESECRAN
Next


Call ECR_TRACE("",0) From GESECRAN

## Critère sur le fichier COMPANY + critère d'annulation
If [M:DIA]ALLCPY=2
 CRITSOC = '[F:CPY]CPYLEGFLG = '+num$(2)
 CRITBAI = '1=1'
Else
 Read [CPY]CPY0=[M:DIA]CPY
 If [F:CPY]CPYLEGFLG=1 : # Société non juridique
  I=1
  For [FGR]FGR0 Where CPY=[M:DIA]CPY
   Read [FCY]FCY0=[F:FGR]FCY
   If !fstat & !find([F:FCY]LEGCPY,SOCGRP(1..I))
    SOCGRP(I) = [F:FCY]LEGCPY
    I +=1
   Endif
  Next
  If I>1
   CRITSOC = 'find([F:CPY]CPY,SOCGRP(1..'+num$(I-1)+'))'
   CRITBAI = 'find([F:HRBAI]CPY,SOCGRP(1..'+num$(I-1)+'))'
  Else
   # Aucune société juridique n'est rattachée à la société XXX
   Call ECR_TRACE(mess(8,10706,1)-[M:DIA]CPY,1) From GESECRAN
   GOK = 0 : Return
  Endif
 Else : # Société juridique
  CRITSOC = '[F:CPY]CPY = "'+[M:DIA]CPY+'"'
  CRITBAI = '[F:HRBAI]CPY = "'+[M:DIA]CPY+'"'
 Endif
Endif

## Critère sur le fichier EMPLOPAR
CRITPAR  = '([F:PAR]FLGPAR = '+num$(2)
CRITPAR -= '| [F:PAR]FLGITS = '+num$(2)+')'
CRITPAR -= '& PARDAT<=[M:DIA]DATEND'

## Critère sur le fichier EMPLOID
CRITID = '[F:ID]FLGNEWSAL<>'+num$(2)
If [M:DIA]MATDEB<>"" : # Borne début matricule
 CRITID  -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
 CRITBAI -= '& [F:HRBAI]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" : # Borne fin du matricule
 CRITID  -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
 CRITBAI -= '& [F:HRBAI]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif

# Critère sur le fichier EMPLOCTR
CRITENT = "1=1"
If [M:DIA]ALLSRV<>2  : # service
 CRITENT -= '& [F:HRCTR]ETRSRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLFCY<>2  : # site
 CRITENT -= '& [F:HRCTR]ETRFCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLPRF<>2 : # profil
 CRITENT -= '& [F:HRCTR]PROPRF = "'+[M:DIA]PRF+'"'
Endif

## Temps de présence globale
PRESTOT = [M:DIA]DATEND-[M:DIA]DATSTR+1

## Calcul
Call DEBTRANS From GLOCK
Gosub TR_CALCUL_BASE
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
FIN = 1
Call LEC_TRACE From LECFIC
Return


$TR_CALCUL_BASE
GOK = 1
Trbegin [HRBAI]
 For [HRBAI]BAI0 Where evalue(CRITBAI) & EXO=[M:DIA]EXO
  OK = 1
  ## Vérification du critère population
  If [M:DIA]POP<>"" : # population
   Read[HRPOA]POA0=[M:DIA]POP;[F:HRBAI]REFNUM
   If fstat :  OK = 0 : Endif
  Endif
  If OK
   # FQ81491 - 17/10/13 - On doit prendre la date de rétroactivité au lieu de la date du contrat
#   Filter [LNK] Where REFNUM=[F:HRBAI]REFNUM  & CTRNUM=[F:HRBAI]CTRNUM & CTRDAT<=[M:DIA]DATEND & [FCY]LEGCPY=[F:HRBAI]CPY & evalue(CRITENT)
#&& (XITDAT=[0/0/0] | XITDAT>[M:DIA]DATSTR)
   Filter [LNK] Where REFNUM=[F:HRBAI]REFNUM  & CTRNUM=[F:HRBAI]CTRNUM & (CTRDAT<=[M:DIA]DATEND | (FLGRET=2 & RETDATEFF<=[M:DIA]DATEND))
&    & [FCY]LEGCPY=[F:HRBAI]CPY  & evalue(CRITENT)
&    & (XITDAT=[0/0/0] | XITDAT>[M:DIA]DATSTR)
   Read [LNK]CTR1 Last
   Filter [LNK]
   If fstat : OK = 0 : Endif
  Endif
  If OK
   Delete [HRBAI]BAI0 Curr
   If fstat=1 | fstat>5
    GOK = 0
    Call RSTA("HRBAI",[M:DIA]EXO) From GLOCK
    Break
   Endif
  Endif
 Next
 If GOK<1 : Goto AB_TR_CALCUL_BASE : Return : Endif

 For [CPY] Where evalue(CRITSOC)
  SOC = [F:CPY]CPY
  For [ID]ID0 Where evalue(CRITID)
   OK = 0
   Filter [PAR] Where REFNUM=[F:ID]REFNUM & evalue(CRITPAR)
   Read[PAR]PAR1 Last
   Filter [PAR]
   If !fstat : Gosub  VERFEMP :  Endif
   If OK
    # FQ81491 - 17/10/13 - On doit prendre la date de rétroactivité au lieu de la date du contrat
#    Filter [LNK] Where REFNUM=[F:ID]REFNUM & CTRDAT<=[M:DIA]DATEND & [FCY]LEGCPY=SOC & evalue(CRITENT)
#&                       & (XITDAT=[0/0/0] | XITDAT>[M:DIA]DATSTR)
    Filter [LNK] Where REFNUM=[F:ID]REFNUM & (CTRDAT<=[M:DIA]DATEND | (FLGRET=2 & RETDATEFF<=[M:DIA]DATEND)) & [FCY]LEGCPY=SOC & evalue(CRITENT)
&                       & (XITDAT=[0/0/0] | XITDAT>[M:DIA]DATSTR)
    For [LNK]CTR0 (2)
     Gosub CALPRESENCE
     Raz [F:HRBAI]
     NBBASE = 0
     For II=0 To [M:DIA]NBLIG-1
      OK = 1
      Read [BAS]BAS0=[M:DIA]CODBAS(II) : # on ne devrait jamais être dans ce cas
      If fstat
       # Base inexistante
       Call ECR_TRACE([F:HRCTR]REFNUM-"("+mess(156,10702,1)-[F:HRCTR]CTRNUM+") :"-mess(3,10706,1)-[M:DIA]CODBAS(II),-1) From GESECRAN
       OK = 0
      Endif
      If OK & [F:BAS]CNDCLC<>""
       FORMULE = vireblc(format$("KT:250X",[F:BAS]CNDCLC),2)
       Gosub DECODE_FORMULE
       If GERR
        Call ERREUR(GMESSAGE) From GESECRAN
        GOK = 0 : Break 2
       Endif
       Gosub EVAL
       OK = evalue(EXPR)
       If OK=0
        # Condition de calcul non remplie dans la base
        Call ECR_TRACE([F:HRCTR]REFNUM-"("+mess(156,10702,1)-[F:HRCTR]CTRNUM+") :"-mess(4,10706,1)-[M:DIA]CODBAS(II),-1) From GESECRAN
        OK = 0
       Endif
      Endif
      If OK & [F:BAS]FORCLC<>""
       FORMULE = vireblc(format$("KT:250X",[F:BAS]FORCLC),2)
       Gosub DECODE_FORMULE
       If GERR
        Call ERREUR(GMESSAGE) From GESECRAN
        GOK = 0 : Break 2
       Endif
       Gosub EVAL
       [F:HRBAI]CODBAS(NBBASE) = [M:DIA]CODBAS(II)
       [F:HRBAI]AMTBAS(NBBASE) = evalue(EXPR)
       NBBASE +=1
       If SOC<>OLDSOC
        OLDSOC = SOC
        Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
        Call ECR_TRACE(mess(42,10702,1)-SOC,0) From GESECRAN : # Société xxxx
        Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
       Endif
       If NBBASE=1
        [F:HRBAI]PPN = min(arr(PRES/PRESTOT,0.000001),1.000000)
        # prorata présence
        Call ECR_TRACE(format$("K:15X",[F:HRCTR]REFNUM)-"("+mess(156,10702,1)-[F:HRCTR]CTRNUM+")"-mess(21,10706,1)-format$("N:1.6",[F:HRBAI]PPN),0) From GESECRAN
       Endif
        # base de répartition
       Call ECR_TRACE(space$(16)+format$("K:10X",[F:HRBAI]CODBAS(NBBASE-1))-format$("N:9.2",[F:HRBAI]AMTBAS(NBBASE-1)),0) From GESECRAN
      Endif
     Next II
     If GOK = 1 & NBBASE>0
      [F:HRBAI]CPY    = SOC
      [F:HRBAI]EXO    = [M:DIA]EXO
      [F:HRBAI]REFNUM = [F:HRCTR]REFNUM
      [F:HRBAI]CTRNUM = [F:HRCTR]CTRNUM
      [F:HRBAI]DATSTR = [M:DIA]DATSTR
      [F:HRBAI]DATEND = [M:DIA]DATEND
      [F:HRBAI]NBRBAS = NBBASE
      #73084
      GPOINT = "CREBAI" : Gosub ENTREE From EXEFNC
      Write [HRBAI]
      If fstat
       GOK = 0 : Call FSTA("HRBAI") From GLOCK
       Goto AB_TR_CALCUL_BASE
      Endif
     Endif
    Next
    Filter [LNK]
   Endif
  Next
 Next
If GOK<1 : Goto AB_TR_CALCUL_BASE : Endif
Commit
Return

######################################
$VERFEMP
OK = 1
## Vérification du critère population
If [M:DIA]POP<>"" : # population
 Read[HRPOA]POA0=[M:DIA]POP;[F:PAR]REFNUM
 If fstat
  OK = 0 : Return
 Endif
Endif
Return

######################################
$CALPRESENCE
Local Date DATREF
PRES = 0
PRESENCE = 0
For [LNK]CTR0
 # FQ81491 - 17/10/13 - Prise en compte de la date d'effet
# If [F:HRCTR]CTRDAT<>[0/0/0] & [F:HRCTR]CTRDAT<=[M:DIA]DATEND
#  If [F:HRCTR]CTRDAT<[M:DIA]DATSTR
#   PRES = [M:DIA]DATEND-[M:DIA]DATSTR+1
#  Else
#   PRES = [M:DIA]DATEND-[F:HRCTR]CTRDAT+1
#  Endif
# Endif
 DATREF=[F:HRCTR]CTRDAT
 If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then DATREF=[F:HRCTR]RETDATEFF : Endif
 If DATREF<>[0/0/0] & DATREF<=[M:DIA]DATEND
  If DATREF<[M:DIA]DATSTR
   PRES = [M:DIA]DATEND-[M:DIA]DATSTR+1
  Else
   PRES = [M:DIA]DATEND-DATREF+1
  Endif
 Endif
 # Fin FQ81491
 If [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT<=[M:DIA]DATEND
  If [F:HRCTR]XITDAT<[M:DIA]DATSTR
   PRES = 0
  Else
   #72787
   #PRES -=[M:DIA]DATEND-[F:HRCTR]XITDAT+1
   PRES -=[M:DIA]DATEND-[F:HRCTR]XITDAT
  Endif
 Endif
 PRESENCE += PRES
Next
PRES = PRESENCE
GPOINT = "CALPRES" : Gosub ENTREE From EXEFNC
Return

$ROLL_TR_CALCUL_BASE
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_CALCUL_BASE : Endif
Return

$AB_TR_CALCUL_BASE
Rollback
Return

###############################################################################
## Décodage des formules
###############################################################################
$DECODE_FORMULE
Raz NRUB,NCUM,NVAR,NPAT
EXPR = FORMULE
I = 1
While I<=len(EXPR)
 OPE = mid$(EXPR,I,2)
 If find(OPE,"R_","V_","C_")
  J = I+2 : I += 2
  While I<len(EXPR) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(EXPR,I+1,1))
   I += 1
  Wend
  CODE = seg$(EXPR,J,I)
  If OPE="R_"
   If mid$(EXPR,I+1,3)="(1)"
    I += 3
   Elsif mid$(EXPR,I+1,3)="(2)"
    OPE = "P_" : I += 3
   Endif
  Endif
  Case OPE
   When "R_"
    L = find(CODE,CRUB(1..NRUB))
    If L=0
     NRUB += 1
     CRUB(NRUB) = CODE
     L = NRUB
    Endif
    REMPL = "RU("+num$(L)+")"
   When "P_"
    L = find(CODE,CPAT(1..NPAT))
    If L=0
     NPAT += 1
     CPAT(NPAT) = CODE
     L = NPAT
    Endif
    REMPL = "PA("+num$(L)+")"
   When "C_"
    L = find(CODE,CCUM(1..NCUM))
    If L=0
     NCUM += 1
     CCUM(NCUM) = CODE
     L = NCUM
    Endif
    REMPL = "CU("+num$(L)+")"
   When "V_"
    L = find(CODE,CVAR(1..NVAR))
    If L=0
     NVAR += 1
     CVAR(NVAR) = CODE
     L = NVAR
    Endif
    REMPL = "VA("+num$(L)+")"
  Endcase
  If (J-3)+len(REMPL)+len(right$(EXPR,I+1))>250
   GERR = 1
   GMESSAGE =  mess(109,10702,1)-":"-FORMULE : # L'évaluation de la formule dépasse les 250 caractères
   Break
  Endif
  EXPR = left$(EXPR,J-3)+REMPL+right$(EXPR,I+1)
  I = (J-3)+len(REMPL)
 Endif
 I += 1
Wend
Return

$EVAL
Local Date DATREF
For TABLE = "EMPLOCPT","EMPLOAD","EMPLOCUM","EMPLOID","EMPLOCTR","EMPLOEXM","EMPLOCHD","EMPLOMED","EMPLOTRY","EMPLORIB","EMPLOSAL", "EMPLOPAR"
 Gosub DEFAUT From WPDEFTABLE
Next
Raz RU,CU,VA,PA

For [F:CTR2]CTR0 Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM
 # FQ81491 - 17/10/13 - Prise en compte de la date d'effet
# If [F:CTR2]CTRDAT>[M:DIA]DATDEB(II) : ENTREE=[F:CTR2]CTRDAT : Else : ENTREE=[M:DIA]DATDEB(II) : Endif
 DATREF=[F:CTR2]CTRDAT
 If [F:CTR2]FLGRET=2 & [F:CTR2]RETDATEFF<>[0/0/0] Then DATREF=[F:CTR2]RETDATEFF : Endif
 If DATREF>[M:DIA]DATDEB(II) : ENTREE=DATREF : Else : ENTREE=[M:DIA]DATDEB(II) : Endif
 # Fin FQ81491
 If [F:CTR2]XITDAT<>[0/0/0] & [F:CTR2]XITDAT<[M:DIA]DATFIN(II) : SORTIE=[F:CTR2]XITDAT : Else : SORTIE=[M:DIA]DATFIN(II) : Endif
 If NRUB
  For [VEP]VEP0 Where EMP=[F:CTR2]REFNUM & CTRNUM=[F:CTR2]CTRNUM & FCY=[F:CTR2]ETRFCY & ENDDAT>=ENTREE & ENDDAT<=SORTIE
   For [HSP]HSP0 Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & (TYP=1 |TYP=7)
    K = find([F:HSP]RUB,CRUB(1..NRUB))
    If K
     RU(K) += [F:HSP]AMT
    Endif
   Next
  Next
 Endif
 If NPAT
  For [VEP]VEP0 Where EMP=[F:CTR2]REFNUM & CTRNUM=[F:CTR2]CTRNUM & FCY=[F:CTR2]ETRFCY & ENDDAT>=ENTREE & ENDDAT<=SORTIE
   For [HSP]HSP0 Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & (TYP=2 |TYP=8)
    K = find([F:HSP]RUB,CPAT(1..NPAT))
    If K
     PA(K) += [F:HSP]AMT
    Endif
   Next
  Next
 Endif
 If NCUM
  Filter [VEP] Where EMP=[F:CTR2]REFNUM & CTRNUM=[F:CTR2]CTRNUM & FCY=[F:CTR2]ETRFCY & ENDDAT>=ENTREE & ENDDAT<=SORTIE
  Read [F:VEP]VEP0 Last
  Filter [VEP]
  If !fstat
   #72747 : sinon on cumule un cumul !
   Raz CU
   For [HSP]HSP0 Where EMP=[F:CTR2]REFNUM & CTRNUM=[F:CTR2]CTRNUM & DAT=[F:VEP]PYRDAT & TYP=6
    K = find([F:HSP]RUB,CCUM(1..NCUM))
    If K
     CU(K) += [F:HSP]AMT
    Endif
   Next
  Endif
 Endif
 If NVAR
  For [VEP]VEP0 Where EMP=[F:CTR2]REFNUM & CTRNUM=[F:CTR2]CTRNUM & FCY=[F:CTR2]ETRFCY & ENDDAT>=ENTREE & ENDDAT<=SORTIE
   For [VLA]VLA0 Where TYP=4 & CPY="" & FCY="" & EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL
    K = find([F:VLA]VARCOD,CVAR(1..NVAR))
    If K
     VA(K) += [F:VLA]VARVAL
    Endif
   Next
  Next
 Endif
Next
Return

######################################################################################
## Etiquettes Ecran CRITBAI
######################################################################################

Subprog D_DATSTR(VALEUR)
Variable Date   VALEUR
VALEUR = gdat$(01,01,year(GMOIPAY)-1)
End

Subprog AM_DATSTR(VALEUR)
Variable Date    VALEUR
Local Integer I
For I=0 To [M]NBLIG-1
 [M]DATDEB(I) = VALEUR
 Affzo [M]DATDEB(I)
Next
End

Subprog D_DATEND(VALEUR)
Variable Date   VALEUR
VALEUR = gdat$(31,12,year(GMOIPAY)-1)
End

Subprog AM_DATEND(VALEUR)
Variable Date    VALEUR
Local Integer I
For I=0 To [M]NBLIG-1
 [M]DATFIN(I) = VALEUR
 Affzo [M]DATFIN(I)
Next
End

Subprog D_DATDEB(VALEUR)
Variable Date    VALEUR
If [M]DATSTR<>[0/0/0]
 VALEUR = [M]DATSTR
Endif
End

Subprog D_DATFIN(VALEUR)
Variable Date    VALEUR
If [M]DATEND<>[0/0/0]
 VALEUR = [M]DATEND
Endif
End

