#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DIE1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COLHEA
mkstat = 0
zoncou = "COLHEA"
indice = 0
If varinit([M]COLHEA,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]COLHEA,"GDIE","COLHEA",[M:DIE0]DIE,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]COLHEA,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "COLHEA" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]COLHEA,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "COLHEA" : GZNUM = 29367 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ACS
mkstat = 0
zoncou = "ACS"
indice = 0
If varmode([M]ACS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACS" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACS","!",[M]ACS,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ACS" : GZNUM = 71 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone CCEFMT
mkstat = 0
zoncou = "CCEFMT"
indice = 0
If varinit([M]CCEFMT,indice)=0
 [M]CCEFMT = "10#"
Endif
If varmode([M]CCEFMT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CCEFMT" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CCEFMT,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CCEFMT" : GZNUM = 29368 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_CCEFMT([M]CCEFMT) From SUBDIE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CCEFMT" : GZNUM = 29368 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone CREAUT
mkstat = 0
zoncou = "CREAUT"
indice = 0
IMPENT = [M]CREAUT
If varinit([M]CREAUT,indice)=0
 IMPENT = 1
Endif
If varmode([M]CREAUT,indice)=0
 [M]CREAUT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CREAUT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CREAUT(indice)
 Endif
Endif
[M]CREAUT = IMPENT

## Zone PRJMGT
mkstat = 0
zoncou = "PRJMGT"
indice = 0
IMPENT = [M]PRJMGT
If varinit([M]PRJMGT,indice)=0
 IMPENT = 1
Endif
If varmode([M]PRJMGT,indice)=0
 [M]PRJMGT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRJMGT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PRJMGT(indice)
 Endif
Endif
[M]PRJMGT = IMPENT

## Zone FLGMODACE
mkstat = 0
zoncou = "FLGMODACE"
indice = 0
IMPENT = [M]FLGMODACE
If varinit([M]FLGMODACE,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGMODACE,indice)=0
 [M]FLGMODACE(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGMODACE" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGMODACE(indice)
 Endif
Endif
[M]FLGMODACE = IMPENT

## Zone ENT
mkstat = 0
zoncou = "ENT"
indice = 0
IMPENT = [M]ENT
If varinit([M]ENT,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENT,indice)=0
 [M]ENT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENT(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ENT(IMPENT) From SUBDIE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ENT" : GZNUM = 3657 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]ENT = IMPENT

## Zone ENV
mkstat = 0
zoncou = "ENV"
indice = 0
IMPENT = [M]ENV
If varinit([M]ENV,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENV,indice)=0
 [M]ENV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENV(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ENV(IMPENT) From SUBDIE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ENV" : GZNUM = 33562 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]ENV = IMPENT

## Zone PJMFLG
mkstat = 0
zoncou = "PJMFLG"
indice = 0
IMPENT = [M]PJMFLG
If varinit([M]PJMFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]PJMFLG,indice)=0
 [M]PJMFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PJMFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PJMFLG(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_PJMFLG(IMPENT) From SUBDIE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PJMFLG" : GZNUM = 41589 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]PJMFLG = IMPENT

## Zone PCCFLG
mkstat = 0
zoncou = "PCCFLG"
indice = 0
IMPENT = [M]PCCFLG
If varinit([M]PCCFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]PCCFLG,indice)=0
 [M]PCCFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PCCFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PCCFLG(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_PCCFLG(IMPENT) From SUBDIE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PCCFLG" : GZNUM = 43998 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]PCCFLG = IMPENT

## Zone OPRJMGT
mkstat = 0
zoncou = "OPRJMGT"
indice = 0
IMPENT = [M]OPRJMGT
If varinit([M]OPRJMGT,indice)=0
 IMPENT = 1
Endif
[M]OPRJMGT = IMPENT

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone CCECRE
mkstat = 0
zoncou = "CCECRE"
indice = 0
If varinit([M]CCECRE,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]CCECRE,"326","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]CCECRE,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CCECRE" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]CCECRE,"326","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CCECRE" : GZNUM = 29369 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]CCECRE,"326",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CCECRE" : GZNUM = 29369 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CCECRE([M]CCECRE) From SUBDIE
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CCECRE" : GZNUM = 29369 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone EXECUTE
mkstat = 0
zoncou = "EXECUTE"
indice = 0
If varinit([M]EXECUTE,indice)=0
 [M]EXECUTE = 258
Endif
If varmode([M]EXECUTE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXECUTE" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "DIE1"
Return

