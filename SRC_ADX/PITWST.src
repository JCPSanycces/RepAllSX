#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : centres de charge et postes de charges
#                             cf AML 2240 : 7->12
###################################################
# Subprog TRT_WST remplace OPTWST de OPTLIB
######################################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables CDCWPIV devient WK
#                                                   WSTWPIV devient  SWK
#                                                   CWSTWPIV devient CSWK
#                                                   SWSTWPIV devient SSWK
#                                                   RWSTWPIV devient RSWK
#                                                   CPVWPIV devient  CWK
######################################################################
$OUVTAB_WST
If !clalev([F:AXX]) Local File ATEXTRA [AXX] Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif

# Issue 73734 - 2012-03-02 by RBA
#If clalev([F:MWS2]) = 0 : Local File WORKSTATIO [MWS1] : Endif
If clalev([F:MWS1]) = 0 : Local File WORKSTATIO [MWS1] : Endif
If clalev([F:MWS2]) = 0 : Local File WORKSTATIO [MWS2] : Endif

# Issue 73734 - 2012-03-02 by RBA
If clalev([F:MWS3]) = 0 : Local File WORKSTATIO [MWS3] : Endif

If clalev([F:TWC])  = 0 : Local File TABWRKCTR  [TWC]  : Endif
If clalev([F:RPW])  = 0 : Local File RPLWST     [RPW]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR     [CPV]  : Endif
If clalev([F:MFO2]) = 0 : Local File MFGOPE     [MFO2] : Endif        # distinction
Return

######################################################################
Subprog TRT_WST(ID,CLETRT,P_MFGFCY,PITCDC,PITWST,PITCWST,PITRWST,PITCPV,OK)
Value Char ID()
Value Char CLETRT () 
Value Char P_MFGFCY () 
Value Char PITCDC () 
Value Char PITWST () 
Value Char PITCWST () 
Value Char PITRWST() 
Value Char PITCPV() 
Variable Integer OK

# Issue 73734 - 2012-03-02 by RBA
Local Char    SOURCEWST(70)
Local Char    ORIGINEWST(70) 


Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
If ID='ORP' | ID='ORO'
adxium = GASCII
Else
adxium = GUTF8
Endif
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub OUVTAB_WST
Gosub OUVREPIVOT From CONNECTFCT

If PITCDC <>""
    Local Char    WCDCREF(GLONWCR)
    Local Integer WNBCDC  : Raz WNBCDC 
    Local Integer WPRECDC : Raz WPRECDC 
    Local Char    OPTCDC(200)
    Local Char    OPTCDCTMP(200)
    OPTCDC = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilcdc")
    OPTCDCTMP = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilcdctmp")
    Openo OPTCDCTMP,0 Using [FPIV]
    Openo Using [FPIV]
    
    Local Integer WKNBZON        : Raz WKNBZON
    Local Char    WKNORECMES (50): Raz WKNORECMES 
    Local Integer WKHEATYP       : Raz WKHEATYP 
    Local Char    WKHEADMES (250): Raz WKHEADMES 
    
    Call READPIT(PITCDC,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
    Local Char    WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
    Local Char    WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
    Local Char    WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
    Local Char    WKFRM(150)(1..WKNBZON) : Raz WKFRM
    Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
    Local Char    WKVAL(255)(1..WKNBZON) : Raz WKVAL
    Local Char    WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
    Call LOADPIVZON(PITCDC,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITCDC,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPRECDC,OPTCDC) From CONNECTFCT
Endif

If PITWST <>""
    Local Integer WNBWST  : Raz WNBWST 
    Local Integer WPREWST : Raz WPREWST
    Local Char    OPTWST(200)
    OPTWST = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilwst")
    Local Integer SWKNBZON : Raz SWKNBZON
    Local Char    SWKNORECMES (50): Raz SWKNORECMES 
    Local Integer SWKHEATYP : Raz SWKHEATYP 
    Local Char    SWKHEADMES (250): Raz SWKHEADMES 
    
    Call READPIT(PITWST,SWKNBZON,SWKNORECMES,SWKHEATYP ,SWKHEADMES ) From CONNECTFCT
    Local Char    SWKTABZON(GLONATB+GLONAVA+2)(1..SWKNBZON) : Raz SWKTABZON
    Local Char    SWKTABABR(GLONABR)(1..SWKNBZON) : Raz SWKTABABR
    Local Char    SWKZON(GLONAVA)(1..SWKNBZON) : Raz SWKTABZON
    Local Char    SWKFRM(150)(1..SWKNBZON) : Raz SWKFRM
    Local Integer SWKWRK(1..SWKNBZON) : Raz SWKWRK
    Local Char    SWKVAL(255)(1..SWKNBZON) : Raz SWKVAL
    Local Char    SWKVALFIC(GLONAVA)(1..SWKNBZON) : Raz SWKVALFIC
    Call LOADPIVZON(PITWST,SWKNBZON,SWKTABZON,SWKTABABR,SWKZON,SWKFRM,SWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITWST,SWKNBZON,SWKTABZON,SWKTABABR,SWKZON,SWKWRK,SWKHEATYP,SWKHEADMES,WPREWST,OPTWST) From CONNECTFCT
Endif

If PITCWST <>""
    Local Char    WCWSTREF(GLONWCR)
    Local Integer WNBCWST  : Raz WNBCWST 
    Local Integer WPRECWST : Raz WPRECWST 
    Local Char    OPTCWST(200)
    Local Char    OPTCWSTTMP(200)
    OPTCWST = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilcwst")
    OPTCWSTTMP = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilcwsttmp")
    Openo OPTCWSTTMP,0 Using [FPIV]
    Openo Using [FPIV]
    
    Local Integer CSWKNBZON : Raz CSWKNBZON
    Local Char    CSWKNORECMES (50): Raz CSWKNORECMES 
    Local Integer CSWKHEATYP : Raz CSWKHEATYP 
    Local Char    CSWKHEADMES (250): Raz CSWKHEADMES 
    
    Call READPIT(PITCWST,CSWKNBZON,CSWKNORECMES,CSWKHEATYP ,CSWKHEADMES ) From CONNECTFCT
    Local Char    CSWKTABZON(GLONATB+GLONAVA+2)(1..CSWKNBZON) : Raz CSWKTABZON
    Local Char    CSWKTABABR(GLONABR)(1..CSWKNBZON) : Raz CSWKTABABR
    Local Char    CSWKZON(GLONAVA)(1..CSWKNBZON) : Raz CSWKTABZON
    Local Char    CSWKFRM(150)(1..CSWKNBZON) : Raz CSWKFRM
    Local Integer CSWKWRK(1..CSWKNBZON) : Raz CSWKWRK
    Local Char    CSWKVAL(255)(1..CSWKNBZON) : Raz CSWKVAL
    Local Char    CSWKVALFIC(GLONAVA)(1..CSWKNBZON) : Raz CSWKVALFIC
    Call LOADPIVZON(PITCWST,CSWKNBZON,CSWKTABZON,CSWKTABABR,CSWKZON,CSWKFRM,CSWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITCWST,CSWKNBZON,CSWKTABZON,CSWKTABABR,CSWKZON,CSWKWRK,CSWKHEATYP,CSWKHEADMES,WPRECWST,OPTCWST) From CONNECTFCT
Endif

If PITRWST <>""
    Local Integer WPRERWST : Raz WPRERWST
    Local Integer WNBRWST : Raz WNBRWST 
    Local Char    OPTRWST(200)
    OPTRWST = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilrpw")
    Local Integer RSWKNBZON        : Raz RSWKNBZON
    Local Char    RSWKNORECMES (50): Raz RSWKNORECMES 
    Local Integer RSWKHEATYP       : Raz RSWKHEATYP 
    Local Char    RSWKHEADMES (250): Raz RSWKHEADMES 
    
    Call READPIT(PITRWST,RSWKNBZON,RSWKNORECMES,RSWKHEATYP ,RSWKHEADMES ) From CONNECTFCT
    Local Char    RSWKTABZON(GLONATB+GLONAVA+2)(1..RSWKNBZON) : Raz RSWKTABZON
    Local Char    RSWKTABABR(GLONABR)(1..RSWKNBZON) : Raz RSWKTABABR
    Local Char    RSWKZON(GLONAVA)(1..RSWKNBZON) : Raz RSWKTABZON
    Local Char    RSWKFRM(150)(1..RSWKNBZON) : Raz RSWKFRM
    Local Integer RSWKWRK(1..RSWKNBZON) : Raz RSWKWRK
    Local Char    RSWKVAL(255)(1..RSWKNBZON) : Raz RSWKVAL
    Local Char    RSWKVALFIC(GLONAVA)(1..RSWKNBZON) : Raz RSWKVALFIC
    Call LOADPIVZON(PITRWST,RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKFRM,RSWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITRWST,RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKWRK,RSWKHEATYP,RSWKHEADMES,WPRERWST,OPTRWST) From CONNECTFCT
Endif

If PITCPV <>""
    #Local Integer WPRECPW : Raz WPRECPV
    Local Integer WPRECPV : Raz WPRECPV
    Local Integer WNBCPV : Raz WNBCPV
    Local Char    OPTCPV(200)
    OPTCPV = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilcpv")
    Local Integer CWKNBZON        : Raz CWKNBZON
    Local Char    CWKNORECMES (50): Raz CWKNORECMES 
    Local Integer CWKHEATYP       : Raz CWKHEATYP 
    Local Char    CWKHEADMES (250): Raz CWKHEADMES 
    
    Call READPIT(PITCPV,CWKNBZON,CWKNORECMES,CWKHEATYP ,CWKHEADMES ) From CONNECTFCT
    Local Char    CWKTABZON(GLONATB+GLONAVA+2)(1..CWKNBZON) : Raz CWKTABZON
    Local Char    CWKTABABR(GLONABR)(1..CWKNBZON) : Raz CWKTABABR
    Local Char    CWKZON(GLONAVA)(1..CWKNBZON) : Raz CWKTABZON
    Local Char    CWKFRM(150)(1..CWKNBZON) : Raz CWKFRM
    Local Integer CWKWRK(1..CWKNBZON) : Raz CWKWRK
    Local Char    CWKVAL(255)(1..CWKNBZON) : Raz CWKVAL
    Local Char    CWKVALFIC(GLONAVA)(1..CWKNBZON) : Raz CWKVALFIC
    Call LOADPIVZON(PITCPV,CWKNBZON,CWKTABZON,CWKTABABR,CWKZON,CWKFRM,CWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITCPV,CWKNBZON,CWKTABZON,CWKTABABR,CWKZON,CWKWRK,CWKHEATYP,CWKHEADMES,WPRECPV,OPTCPV) From CONNECTFCT
Endif

# distinction des exemplaires
Local Integer NBSBB : NBSBB = 0
Local Char    XSBBT(15)(100)
Local Char    XSBB
Global Char    XSBBWST, XSBBWSTB
Global Char    XWST
Local Integer XIND, XINDB
Local Integer XWSTNBR 
Local Integer K,L,M             

# parcours l'ensemble des postes du site
Filter [F:MWS1] Where WCRFCY = P_MFGFCY
For [F:MWS1]
    Raz [MWS] : [MWS]=[MWS1]
    Raz [TWC]
    If [F:TWC]WCR <> [F:MWS]WCR
      Read [TWC]TWC0=[F:MWS]WCR
      If !fstat
        ################################
        # fichiers CDC
        ################################
        If PITCDC<>""
            ECRCDC=1
            If WPRECDC = 0
              Openo OPTCDCTMP,0 Using [FPIV]
              Wrseq [F:TWC]WCR Using [FPIV]
              Openo Using [FPIV]
              Openo OPTCDC,0 Using [FPIV]
              WPRECDC = 1
            Else
              Openi OPTCDCTMP Using [FPIV]
              Rdseq WCDCREF Using [FPIV]
              While fstat=0
                    If WCDCREF=[F:TWC]WCR
                        ECRCDC=0
                        Break
                    Endif
                    Rdseq WCDCREF Using [FPIV]
              Wend
              Openi Using [FPIV]
              If ECRCDC
                  Openo OPTCDCTMP Using [FPIV]
                  Wrseq [F:TWC]WCR Using [FPIV]
                  Openo Using [FPIV]
                  Openo OPTCDC Using [FPIV]
              Endif
            Endif
            
            
            If ECRCDC
                WNBCDC += 1
                Call RAZVALPIVOT(PITCDC,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
                Call EVALPIVOT(PITCDC,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
                Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
                #     fermeture du fichier
                Openo Using [FPIV]
            Endif
        Endif
        ################################
        # fichiers CWST
        ################################
        If PITCWST<>""
            ECRCWST=1
            If WPRECWST = 0
              Openo OPTCWSTTMP,0 Using [FPIV]
              Wrseq [F:TWC]WCR Using [FPIV]
              Openo Using [FPIV]
              Openo OPTCWST,0 Using [FPIV]
              WPRECWST = 1
            Else
              Openi OPTCWSTTMP Using [FPIV]
              Rdseq WCWSTREF Using [FPIV]
              While fstat=0
                    If WCWSTREF=[F:TWC]WCR
                        ECRCWST=0
                        Break
                    Endif
                    Rdseq WCWSTREF Using [FPIV]
              Wend
              Openi Using [FPIV]
              If ECRCWST
                  Openo OPTCWSTTMP Using [FPIV]
                  Wrseq [F:TWC]WCR Using [FPIV]
                  Openo Using [FPIV]
                  Openo OPTCWST Using [FPIV]
              Endif
            Endif
            
            
            If ECRCWST
                For [MWS2]WST4 Where WCRFCY=P_MFGFCY & WCR=[F:TWC]WCR
                  WNBCWST += 1
                  Raz [MWS] : [MWS]=[MWS2]
                  Call RAZVALPIVOT(PITCWST,CSWKNBZON,CSWKVAL,CSWKVALFIC) From CONNECTFCT
                  Call EVALPIVOT(PITCWST,CSWKNBZON,CSWKTABZON,CSWKTABABR,CSWKZON,CSWKFRM,CSWKWRK,CSWKVAL,CSWKVALFIC) From CONNECTFCT
                  Call WRPIVOT(CSWKNBZON,CSWKTABZON,CSWKTABABR,CSWKZON,CSWKFRM,CSWKWRK,CSWKVAL,CSWKVALFIC) From CONNECTFCT

                  ###
                  # Issue 78437 - 2011-12-05 by VPO : gestion des distinctions
                  # distinction des exemplaires
                  If !pat(GVERSION,"1.5.*")
                      WSBBFLG = [F:MWS]SBBFLG
                  Else
                      WSBBFLG=1
                  Endif
                  If WSBBFLG = 2
                      Gosub SBB_EXTRACT From PITMFG
                      Gosub SBB_GEN_CWST
                  Endif
                  ###

                Next
                #     fermeture du fichier
                Openo Using [FPIV]
            Endif
        Endif
      Endif
    Endif
    Raz [MWS] : [MWS]=[MWS1]

    ################################
    # fichiers WST
    ################################
    If PITWST<>""
        #     Ouverture du fichier OPTWST en écriture
        If WPREWST = 0
          Openo OPTWST,0 Using [FPIV]
          WPREWST = 1
        Else
          Openo OPTWST Using [FPIV]
        Endif

        ###
        # Issue 78437 - 2011-12-05 by VPO : gestion des distinctions
        # distinction des exemplaires
        If !pat(GVERSION,"1.5.*")
            WSBBFLG = [F:MWS]SBBFLG
        Else
            WSBBFLG=1
        Endif
    
        If WSBBFLG = 1
            Gosub WRITE_WST
        Else
            Gosub SBB_EXTRACT From PITMFG
            Gosub SBB_GEN_WST
        Endif
        ###

        #     fermeture du fichier
        Openo Using [FPIV]
    Endif

    ################################
    # fichiers RWST
    ################################
    # Issue 73734 - 2012-03-02 by RBA Réécriture pour integrer le cas des ditinctions
    If PITRWST<>""
      # Ouverture du fichier OPTRWST en écriture
      If WPRERWST = 0
        Openo OPTRWST,0 Using [FPIV]
        WPRERWST = 1
      Else
        Openo OPTRWST Using [FPIV]
      Endif

      ORIGINEWST = [F:MWS]WST
      
      # Si le poste courant a des Distinction, pour chaque Distinction Ecrire Poste / Distinction
      If !pat(GVERSION,"1.5.*")
          WSBBFLG = [F:MWS]SBBFLG
      Else
          WSBBFLG=1
      Endif          
      If WSBBFLG = 2
        Gosub SBB_EXTRACT From PITMFG
        If NBSBB <> 0
          For K = 1 To NBSBB - 1
            # constitution pseudo code sous-poste
            XIND = K
            XSBB = XSBBT(XIND)
            XWST = [F:MWS]WST
            Gosub SBB_NAME From PITMFG
            # ecrire poste / distinction
            #Raz [F:RPW]
            I=0
            Raz XWST
            ##[F:RPW]RPLWST(I)=XSBBWST
            WNBRWST += 1
            Call RAZVALPIVOT(PITRWST,RSWKNBZON,RSWKVAL,RSWKVALFIC) From CONNECTFCT
            Call  SETVAL ("RPLWST","I",RSWKNBZON,RSWKTABZON,RSWKVAL,RSWKVALFIC,num$(I)) From CONNECTFCT
            Call EVALPIVOT(PITRWST,RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKFRM,RSWKWRK,RSWKVAL,RSWKVALFIC) From CONNECTFCT
            Call  SETVAL ("RPLWST","RPLWST",RSWKNBZON,RSWKTABZON,RSWKVAL,RSWKVALFIC,XSBBWST) From CONNECTFCT
            Call WRPIVOT(RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKFRM,RSWKWRK,RSWKVAL,RSWKVALFIC) From CONNECTFCT
          Next K
          Raz XWST
          Raz XSBBWST
        Endif
      Endif

      # Si le poste courant a des Remplacants, pour chaque Remplacant Ecrire Poste / Remplacant
      # Puis, si ces postes de Remplacement ont des Distinctions, ecrire Poste / Distinction du poste Remplacant 
      Read [RPW]RPW0=[F:MWS]WST;[F:MWS]WCRFCY
      If fstat : Raz [RPW] : Endif
      For I = 0 To 24
        If [F:RPW]RPLWST(I) <> ""
          # ecrire Poste / Remplacant
          WNBRWST += 1
          Call RAZVALPIVOT(PITRWST,RSWKNBZON,RSWKVAL,RSWKVALFIC) From CONNECTFCT
          Call  SETVAL ("RPLWST","I",RSWKNBZON,RSWKTABZON,RSWKVAL,RSWKVALFIC,num$(I)) From CONNECTFCT
          Call EVALPIVOT(PITRWST,RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKFRM,RSWKWRK,RSWKVAL,RSWKVALFIC) From CONNECTFCT
          Call WRPIVOT(RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKFRM,RSWKWRK,RSWKVAL,RSWKVALFIC) From CONNECTFCT

          # Puis, si ce postes de Remplacement a des Distinctions, 
          # ecrire Poste / Distinction du poste de Remplacement 
          Read [MWS3]WST0=[F:RPW]RPLWST(I);[F:MWS]WCRFCY
          If fstat : Raz [MWS3] : Endif
                     
          If !pat(GVERSION,"1.5.*")
              WSBBFLG = [F:MWS3]SBBFLG
          Else
              WSBBFLG=1
          Endif
          If WSBBFLG=2
            Gosub SBB_EXTRACTR
            If NBSBB <> 0
              For K = 1 To NBSBB - 1
                # constitution pseudo code sous-poste
                XIND = K
                XSBB = XSBBT(XIND)
                XWST = [MWS3]WST
                Gosub SBB_NAME From PITMFG
                # ecrire Poste / Distinction du poste de Remplacement 
                #Raz [F:RPW]
                Raz XWST
                #I = 0
                WNBRWST += 1
                Call RAZVALPIVOT(PITRWST,RSWKNBZON,RSWKVAL,RSWKVALFIC) From CONNECTFCT
                Call  SETVAL ("RPLWST","I",RSWKNBZON,RSWKTABZON,RSWKVAL,RSWKVALFIC,num$(I)) From CONNECTFCT
                Call EVALPIVOT(PITRWST,RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKFRM,RSWKWRK,RSWKVAL,RSWKVALFIC) From CONNECTFCT
                Call  SETVAL ("RPLWST","RPLWST",RSWKNBZON,RSWKTABZON,RSWKVAL,RSWKVALFIC,XSBBWST) From CONNECTFCT
                Call WRPIVOT(RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKFRM,RSWKWRK,RSWKVAL,RSWKVALFIC) From CONNECTFCT
              Next K
              Raz XWST
              Raz XSBBWST
            Endif
          Endif
        Endif
      Next I

      # Si le poste courant a des Distinction, pour chaque Distinction Ecrire Distinction / Poste courant
      # puis Distinction / autre Distinction du même poste courant
      If !pat(GVERSION,"1.5.*")
          WSBBFLG = [F:MWS]SBBFLG
      Else
          WSBBFLG=1
      Endif          
      If WSBBFLG = 2
        Gosub SBB_EXTRACT From PITMFG    
        If NBSBB <> 0
          For K = 1 To NBSBB - 1
            # constitution pseudo code sous-poste
            XIND = K
            XSBB = XSBBT(XIND)
            XWST = [F:MWS]WST
            Gosub SBB_NAME From PITMFG
            # ecrire Distinction / Poste courant
            #Raz [F:RPW]
            #Raz XWST
            I = 0
            WNBRWST += 1    
            Call RAZVALPIVOT(PITRWST,RSWKNBZON,RSWKVAL,RSWKVALFIC) From CONNECTFCT
            Call  SETVAL ("RPLWST","I",RSWKNBZON,RSWKTABZON,RSWKVAL,RSWKVALFIC,num$(I)) From CONNECTFCT
            Call EVALPIVOT(PITRWST,RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKFRM,RSWKWRK,RSWKVAL,RSWKVALFIC) From CONNECTFCT
            Call  SETVAL ("RPLWST","RPLWST",RSWKNBZON,RSWKTABZON,RSWKVAL,RSWKVALFIC,XWST) From CONNECTFCT
            Call WRPIVOT(RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKFRM,RSWKWRK,RSWKVAL,RSWKVALFIC) From CONNECTFCT

            SOURCEWST = XSBBWST

            # distinction / autre distinction
            For L = 1 To NBSBB - 1
              # constitution pseudo code sous-poste
              XIND = L
              XSBB = XSBBT(XIND)
              XWST = XSBBWST
              Gosub SBB_NAME From PITMFG
              If SOURCEWST <> XSBBWST
                # ecrire distinction / autre distinction
                #Raz [F:RPW]
                #Raz XWST
                #I = 0
                WNBRWST += 1
                Call RAZVALPIVOT(PITRWST,RSWKNBZON,RSWKVAL,RSWKVALFIC) From CONNECTFCT
                Call  SETVAL ("RPLWST","WST",RSWKNBZON,RSWKTABZON,RSWKVAL,RSWKVALFIC,SOURCEWST) From CONNECTFCT
                Call  SETVAL ("RPLWST","RPLWST",RSWKNBZON,RSWKTABZON,RSWKVAL,RSWKVALFIC,XSBBWST) From CONNECTFCT
                Call WRPIVOT(RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKFRM,RSWKWRK,RSWKVAL,RSWKVALFIC) From CONNECTFCT    
              Endif 
            Next L
            
            # distinction / poste remplacant du poste d'origine
            Read [RPW]RPW0=ORIGINEWST;[F:MWS]WCRFCY
            If fstat : Raz [RPW] : Endif
            For L = 0 To 24
              If [F:RPW]RPLWST(L) <> ""
              # constitution pseudo code sous-poste
                XIND = K
                XSBB = XSBBT(XIND)
                XWST = ORIGINEWST
                Gosub SBB_NAME From PITMFG
                # ecrire distinction / poste remplacant du poste d'origine
                #Raz [F:RPW]
                #Raz XWST
                I = 0
                WNBRWST += 1    
                Call RAZVALPIVOT(PITRWST,RSWKNBZON,RSWKVAL,RSWKVALFIC) From CONNECTFCT
                Call  SETVAL ("RPLWST","I",RSWKNBZON,RSWKTABZON,RSWKVAL,RSWKVALFIC,num$(I)) From CONNECTFCT
                Call EVALPIVOT(PITRWST,RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKFRM,RSWKWRK,RSWKVAL,RSWKVALFIC) From CONNECTFCT
                Call  SETVAL ("RPLWST","RPLWST",RSWKNBZON,RSWKTABZON,RSWKVAL,RSWKVALFIC,[F:RPW]RPLWST(L)) From CONNECTFCT
                Call WRPIVOT(RSWKNBZON,RSWKTABZON,RSWKTABABR,RSWKZON,RSWKFRM,RSWKWRK,RSWKVAL,RSWKVALFIC) From CONNECTFCT
              Endif
            Next L  
          Next K
          Raz XWST
          Raz XSBBWST
        Endif
      Endif  

      #     fermeture du fichier
      Openo Using [FPIV]
    Endif


    If PITCPV<>""
        # lecture et écriture variations
        Read [CPV]CPV0=[F:MWS]WST;[F:MWS]WCRFCY
        If fstat : Raz [CPV] : Endif
  
        #     Ouverture du fichier OPTCPV en écriture
        If WPRECPV = 0
          Openo OPTCPV,0 Using [FPIV]
          WPRECPV = 1
        Else
          Openo OPTCPV Using [FPIV]
        Endif

        # Issue 73734 - 2012-03-02 by RBA Variations
        For J = 0 To 24
            If [F:CPV]STRDAT(J) <> [0/0/0]
                WNBCPV += 1
                Call RAZVALPIVOT(PITCPV,CWKNBZON,CWKVAL,CWKVALFIC) From CONNECTFCT
                Call  SETVAL ("CAPVAR","I",CWKNBZON,CWKTABZON,CWKVAL,CWKVALFIC,num$(J)) From CONNECTFCT
                Call EVALPIVOT(PITCPV,CWKNBZON,CWKTABZON,CWKTABABR,CWKZON,CWKFRM,CWKWRK,CWKVAL,CWKVALFIC) From CONNECTFCT
                Call WRPIVOT(CWKNBZON,CWKTABZON,CWKTABABR,CWKZON,CWKFRM,CWKWRK,CWKVAL,CWKVALFIC) From CONNECTFCT
                ###Wrseq WWST;I+1;[F:CPV]STRDAT(I);[F:CPV]ENDDAT(I);[F:CPV]CODVAR(I);[F:CPV]TWD(I);[F:CPV]WSTNBR(I);WEXTDAT;WFLGMAJ  Using [OPTCPV]
                ###WNBCPV += 1
                
                #Si ce poste de charge [F:RPW]WST est une distinction des exemplaires SBBFLG=2 alors 
                #gestion des distinctions
                If !pat(GVERSION,"1.5.*")
                    WSBBFLG = [F:MWS]SBBFLG
                Else
                    WSBBFLG=1
                Endif
                If WSBBFLG = 2    
                   Gosub SBB_EXTRACT From PITMFG
                   Gosub SBB_GEN_VWST
                Endif
                
            Endif
        Next J
    Openo
    Endif
Next




# Issue 80230 - 2012-02-20 by RBA
Filter [F:MWS1]

If PITCDC <>"" : Call WRPIVOT_END(PITCDC ,WNBCDC ,WKNORECMES ,WPRECDC ,OPTCDC) From CONNECTFCT : Endif
If PITWST <>"" : Call WRPIVOT_END(PITWST ,WNBWST ,SWKNORECMES ,WPREWST ,OPTWST) From CONNECTFCT : Endif
If PITRWST<>"" : Call WRPIVOT_END(PITRWST,WNBRWST,RSWKNORECMES,WPRERWST,OPTRWST) From CONNECTFCT : Endif
If PITCWST<>"" : Call WRPIVOT_END(PITCWST,WNBCWST,CSWKNORECMES,WPRECWST,OPTCWST) From CONNECTFCT : Endif
If PITCPV <>"" : Call WRPIVOT_END(PITCPV ,WNBCPV ,CWKNORECMES ,WPRECPV ,OPTCPV) From CONNECTFCT : Endif

adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
Kill XWST
Kill XSBBWST
End


# Issue 73734 - 2012-03-02 by RBA
#########################################################################
# recherche des critères de distinction sur le poste
$SBB_EXTRACTR
Filter [MFO2] Where MFGFCY = [F:MWS]WCRFCY & 
&   EXTWST = [F:RPW]RPLWST(I) &
&   SCHSBB <> ""
&    Order By Key MFO2(3)
NBSBB  = 0
XSBBT(NBSBB) = ""

NBSBB += 1
For [MFO2]
    If NBSBB >= [MWS3]WSTNBR : Break : Endif
    XSBBT(NBSBB) = [F:MFO2]SCHSBB
    NBSBB       += 1
Next
Filter [MFO2]           
Return

#########################################################################
# distinction des exemplaires
$SBB_GEN_CWST
If NBSBB = 0 : Return : Endif

For K = 1 To NBSBB - 1
    # constitution pseudo code sous-poste
    XWST = [F:MWS]WST
    XIND = K
    XSBB = XSBBT(XIND)
    Gosub SBB_NAME From PITMFG

    Call RAZVALPIVOT(PITCWST,CSWKNBZON,CSWKVAL,CSWKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITCWST,CSWKNBZON,CSWKTABZON,CSWKTABABR,CSWKZON,CSWKFRM,CSWKWRK,CSWKVAL,CSWKVALFIC) From CONNECTFCT
    Call WRPIVOT(CSWKNBZON,CSWKTABZON,CSWKTABABR,CSWKZON,CSWKFRM,CSWKWRK,CSWKVAL,CSWKVALFIC) From CONNECTFCT
Next K

Raz XWST
Raz XSBBWST
Return

#########################################################################
# Issue 73734 - 2012-02-22 by RBA Variation
# distinction des exemplaires - Variation
$SBB_GEN_VWST
If NBSBB = 0 : Return : Endif
For K = 1 To NBSBB - 1
    XWST = [F:MWS]WST
    # constitution pseudo code sous-poste
    XIND = K
    XSBB = XSBBT(XIND)
    Gosub SBB_NAME From PITMFG
  
    WNBCPV += 1
    Call RAZVALPIVOT(PITCPV,CWKNBZON,CWKVAL,CWKVALFIC) From CONNECTFCT
    Call  SETVAL ("CAPVAR","I",CWKNBZON,CWKTABZON,CWKVAL,CWKVALFIC,num$(J)) From CONNECTFCT
    Call EVALPIVOT(PITCPV,CWKNBZON,CWKTABZON,CWKTABABR,CWKZON,CWKFRM,CWKWRK,CWKVAL,CWKVALFIC) From CONNECTFCT
    Call  SETVAL ("CAPVAR","WST",CWKNBZON,CWKTABZON,CWKVAL,CWKVALFIC,XSBBWST) From CONNECTFCT
    Call WRPIVOT(CWKNBZON,CWKTABZON,CWKTABABR,CWKZON,CWKFRM,CWKWRK,CWKVAL,CWKVALFIC) From CONNECTFCT
Next K
Raz XWST
Raz XSBBWST
Return

#########################################################################
# distinction des exemplaires
$SBB_GEN_WST
If NBSBB = 0 : Return : Endif

# pseudo code sous-poste 0
XWST = [F:MWS]WST
XIND = 0
Gosub SBB_NAME From PITMFG

# écriture sous-poste 0
If NBSBB >= [F:MWS]WSTNBR
    XWSTNBR = 1
Else
    XWSTNBR = [F:MWS]WSTNBR - NBSBB + 1
Endif
Gosub WRITE_WST

For K = 1 To NBSBB - 1
    # constitution pseudo code sous-poste
    XIND = K
    XSBB = XSBBT(XIND)
    Gosub SBB_NAME From PITMFG

    # écriture
    XWSTNBR = 1
    Gosub WRITE_WST
Next K

Raz XWST
Raz XSBBWST
Return

#############################################################################
$WRITE_WST
    WNBWST += 1
    Call RAZVALPIVOT(PITWST,SWKNBZON,SWKVAL,SWKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITWST,SWKNBZON,SWKTABZON,SWKTABABR,SWKZON,SWKFRM,SWKWRK,SWKVAL,SWKVALFIC) From CONNECTFCT
    Call WRPIVOT(SWKNBZON,SWKTABZON,SWKTABABR,SWKZON,SWKFRM,SWKWRK,SWKVAL,SWKVALFIC) From CONNECTFCT
Return
#############################################################################
Funprog WST_GETWWCRDSP
If [F:TWC]WCR = [F:MWS]WCR : End [F:TWC]DSPLEV : Endif
End "1"
#############################################################################
Funprog WST_GETWLIMCAP
Local Integer WLIMCAP                    
    # si poste de sous-traitance : force capa à 1 H/J
    If [F:MWS]WSTTYP = 3 : WLIMCAP = 1 : Else : WLIMCAP = [F:MWS]CONSTRAINT : Endif
    If !find(WLIMCAP, 1, 2) : WLIMCAP = 1 : Endif
End WLIMCAP                    
#############################################################################
Funprog WST_GETWCONSTRAINT
If [F:MWS]CONSTRAINT=2
    End "1"
Else
    End "0"
Endif
End "0"
#############################################################################
Funprog WST_GETWST
Local Char WST
Raz WST
If [F:MWS]WST<>""
    If dim(XSBBWST)>0 & XSBBWST<>"" & dim(XWST)>0 & XWST<>""
        WST = XSBBWST
    Else
        WST = [F:MWS]WST
    Endif
Endif
End WST
#############################################################################
Funprog WST_GETDES
Local Char LDES(GLONDES)
Raz LDES
If [F:MWS]WST<>""
    If !pat(GVERSION,"1.5.*")
        If !clalev([F:AXX]) Local File ATEXTRA [AXX] Endif
        If dim(XWST)>0 & XWST<>""
        Read [AXX]AXX0="WORKSTATIO";"WSTDESAXX";GLANGUE;XWST;[F:MWS]WCRFCY
        Else
        Read [AXX]AXX0="WORKSTATIO";"WSTDESAXX";GLANGUE;[F:MWS]WST;[F:MWS]WCRFCY
        Endif
        If !fstat  LDES=[F:AXX]TEXTE : Endif
    Endif
    If LDES=""
        End [F:MWS]WSTDES
    Endif
Endif
End LDES
#############################################################################
Funprog TWC_GETDES
Local Char LDES(GLONDES)
Raz LDES
If [F:TWC]WCR<>""
    If !pat(GVERSION,"1.5.*")
        If !clalev([F:AXX]) Local File ATEXTRA [AXX] Endif
        Read [AXX]AXX0="TABWRKCTR";"WCRDESAXX";GLANGUE;[F:TWC]WCR;""
        If !fstat  LDES=[F:AXX]TEXTE : Endif
    Endif
    If LDES=""
        End [F:TWC]WCRDES
    Endif
Endif
End LDES
#############################################################################


