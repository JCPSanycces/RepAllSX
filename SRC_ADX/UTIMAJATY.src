#<AdxTL>@(#)2.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour ATYPE
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update fields on ATYPE table") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
 Local File ATYPE [ATY]
Else
 Local File =DOSSIER+".ATYPE"  [ATY]
Endif
Filter [ATY]

If dim([F:ATY]TYPSELSYR)>0
Gosub ATY_UPD1
Endif

Close Local File
End

#-------------------#
$ATY_UPD1

# Mise à jour de la table ATYPE
#Call ECR_TRACE("ATY_UPD1"-mess(81,125,1)-DOSSIER+".ATYPE:"-time$,0) From GESECRAN

Trbegin [ATY]
For [ATY] Where TYPSELSYR=0 or TYPPROSYR="" or FMTPROSYR=0 or SUPFLG=0

  If [F:ATY]TYPSELSYR=0
    If [F:ATY]CODCLA<>""
      [F:ATY]TYPSELSYR=2
    Elsif find([ATY]TYPTYP,9,10) : #Blob/Clob
      [F:ATY]TYPSELSYR=3
    Else
      [F:ATY]TYPSELSYR=1
    Endif
  Endif

  If [F:ATY]TYPPROSYR=""
    If [F:ATY]TYPTYP=1
      If [F:ATY]NOLIB=1 : [F:ATY]TYPPROSYR = "ATYPE0" : Else : [F:ATY]TYPPROSYR = "ATYPE1" : Endif
    #Elsif find([F:ATY]TYPTYP,9,10)=0
    Else
      [F:ATY]TYPPROSYR = "ATYPE"+num$([F:ATY]TYPTYP)
    Endif
  Endif

  If [F:ATY]FMTPROSYR=0 : [F:ATY]FMTPROSYR=1 : Endif
  If [F:ATY]SUPFLG=0 & find([F:ATY]TYPTYP,9,10)<>0 : [F:ATY]SUPFLG=2 : Endif
  If [F:ATY]SUPFLG=0 : [F:ATY]SUPFLG=1 : Endif

  Rewrite [ATY]
  If fstat
   Call ERREUR("ATYPE"-[F:ATY]CODTYP,2) From DOSDIC
  Endif
Next ATY
Commit
Return
