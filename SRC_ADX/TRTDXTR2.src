  If fstat<>0
   GOK = 0 : Call FSTA("DNE") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-mess([F:ID5]DNACODIND,10969,1),0) From GESECRAN
  # Code indemnité
 Elsif !fstat
  [F:DNE]DNAAMTIND+=[F:ID5]DNAAMTIND
  Rewrite [F:DNE]
  If fstat<>0
   GOK = 0 : Call FSTA("DNE") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-mess([F:ID5]DNACODIND,10969,1),0) From GESECRAN
  # Code indemnité
 Else
  Call ECR_TRACE(space$(5)-space$(5)-mess([F:ID5]DNACODIND,10969,1)-":"-mess(90,10705,1),1) From GESECRAN
  # Code indemnité : Intégration des informations dads-u importées impossible
 Endif
Next
Return

