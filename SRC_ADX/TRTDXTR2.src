  Write [DNA]
  If fstat<>0
   GOK = 0 : Call FSTA("DNA") From GLOCK
  Endif
 Else
  If [F:DNA]DNAPAYDAT =[0/0/0] : [F:DNA]DNAPAYDAT=[F:IDN]DNAPAYDAT : Endif
  If ![F:DNA]DNACCP           : [F:DNA]DNACCP    =[F:IDN]DNACCP    : Endif
  If [F:DNA]DNACCP    =1
   If [F:DNA]DNACCPNUM=""     : [F:DNA]DNACCPNUM =[F:IDN]DNACCPNUM : Endif
  Endif
  If [F:DNA]NUMCON    =""      : [F:DNA]NUMCON   =[F:IDN]NUMCON    : Endif
  If [F:DNA]DNAENDCDD =[0/0/0] : [F:DNA]DNAENDCDD=[F:IDN]DNAENDCDD : Endif
  If [F:DNA]DNASTRCAE =[0/0/0] : [F:DNA]DNASTRCAE=[F:IDN]DNASTRCAE : Endif
  If [F:DNA]DNAREFCAE =""      : [F:DNA]DNAREFCAE=[F:IDN]DNAREFCAE : Endif
  [F:DNA]LNK          = max([F:DNA]LNK,[F:IDN]LNK)                              :#ML n°1
  If [F:DNA]LNK=2
    If ![F:DNA]TYPLNK          : [F:DNA]TYPLNK   =[F:IDN]TYPLNK       : Endif
  Endif
  [F:DNA]DNANBRTPS   +=[F:IDN]DNANBRTPS

  If GINTMT
   If [F:DNA]NUMOBJ  =""      : [F:DNA]NUMOBJ   =[F:IDN]NUMOBJ    : Endif
   [F:DNA]TRUNBRDAYWRK+=[F:IDN]TRUNBRDAYWRK
   [F:DNA]HRSREP    +=[F:IDN]HRSREP
  Endif

  Rewrite [DNA]
  If fstat<>0
   GOK = 0 : Call FSTA("DNA") From GLOCK
  Endif
 Endif
Endif
Return

####################
$TR_DNB
For [ID2]ID20 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM
&                 & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA

 Filter [F:DNB] Where YEAEMPDDS=[F:ID2]YEAEMPDDS & EMPDDS=[F:ID2]EMPDDS & ETRDAT=[F:ID2]ETRDAT & CTRNUM=[F:ID2]CTRNUM
&                 & TYPDAE=[F:ID2]TYPDAE & DNACODPRM=[F:ID2]DNACODPRM
 Readlock [F:DNB]DNB0 Last
 Filter [F:DNB]
 If fstat>=2
  Raz [F:DNB]
  [F:DNB]=[F:ID2]
  [F:DNB]NUMLIG=[F:ID2]NUMLIG*10
  Write [F:DNB]
  If fstat<>0
   GOK = 0 : Call FSTA("DNB") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-mess([F:ID2]DNACODPRM,10968,1),0) From GESECRAN
  # Code prime
 Elsif !fstat
  [F:DNB]DNAAMTPRM+=[F:ID2]DNAAMTPRM
  If [F:DNB]DNASTRPRM<>[0/0/0] & [F:ID2]DNASTRPRM<>[0/0/0]
   [F:DNB]DNASTRPRM = min([F:DNB]DNASTRPRM,[F:ID2]DNASTRPRM)
  Else
   [F:DNB]DNASTRPRM = max([F:DNB]DNASTRPRM,[F:ID2]DNASTRPRM)
  Endif
  [F:DNB]DNAENDPRM = max([F:DNB]DNAENDPRM,[F:ID2]DNAENDPRM)
  Rewrite [F:DNB]
  If fstat<>0
   GOK = 0 : Call FSTA("DNB") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-mess([F:ID2]DNACODPRM,10968,1),0) From GESECRAN
  # Code prime
 Else
  Call ECR_TRACE(space$(5)-space$(5)-mess([F:ID2]DNACODPRM,10968,1)-":"-mess(90,10705,1),1) From GESECRAN
  # Code prime: Intégration des informations dads-u importées impossible
 Endif
Next
Return

