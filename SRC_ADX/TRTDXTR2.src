#<AdxTL>@(#)8.0.0.0 $Revision$
########################################################################################
                                        #IMPORT DADS-U
########################################################################################
$TR2
Local Char CHAMP (30), CHAMP2 (30)
Local Char TCHAMP (30) (1..50)
Local Integer NBCHAMP
#70205
Local Char CRITSAL (250)

Gosub OUVRE From SUBIDA
If clalev([F:ATZB])=0 : Local File ATABZON     [ATZB] : Endif

#70143
Gosub LIST_CHAMP

Call ECR_TRACE(space$(1),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

GOK=1

#70205
CRITSAL="1=1"
If [M:DIA]EMPDDS<>""
 CRITSAL -= '& EMPDDS="'+[M:DIA]EMPDDS+'"'
Endif
If [M:DIA]CTRNUM<>""
 CRITSAL -= '& CTRNUM="'+[M:DIA]CTRNUM+'"'
Endif

#Un site donné
If [M:DIA]FCYDDS<>""
 Read [F:FCY]FCY0=[M:DIA]FCYDDS
 If !fstat
  Gosub TR_IMPORT
 Endif
Else
 #Tous les sites d'une société donnée ou groupe de site (63097)
 For [F:FGR]FGR0 Where CPY=[M:DIA]CPYDDS
  Read[FCY]FCY0=[F:FGR]FCY
  If !fstat
   Gosub TR_IMPORT
  Endif
 Next
Endif
Return

###########################
$TR_IMPORT
GOK=1
#70143
#Gosub LIST_CHAMP
For [IDA]IDA0 Where YEAEMPDDS=[M:DIA]YEADDS & ETRFCY=[F:FCY]FCY & ETRDAT>=[M:DIA]STRDAT & XITDAT<=[M:DIA]ENDDAT
&                   & TYPDAE=VTYPDEC & FLGDNA=VDNA & evalue(CRITSAL)
 #70205
 Call ECR_TRACE(space$(1),0) From GESECRAN
 #Intégration des informations Dads-u importées
 Call ECR_TRACE(mess(91,10705,1),0) From GESECRAN
 #Données salariées : XXXXXXX
 Call ECR_TRACE(mess(69,10711,1)-":"-[F:IDA]YEAEMPDDS-[F:IDA]EMPDDS-[F:IDA]CTRNUM-num$([F:IDA]ETRDAT),0) From GESECRAN
 #
 Readlock [DAE]DAE0=[F:IDA]YEAEMPDDS;[F:IDA]EMPDDS;[F:IDA]CTRNUM;[F:IDA]ETRDAT;[F:IDA]TYPDAE;[F:IDA]FLGDNA
 If fstat=5
  Raz [F:DAE]
  [F:DAE]=[F:IDA]
  Write [F:DAE]
  If fstat<>0
   GOK = 0 : Call FSTA("DAE") From GLOCK
  Endif
 Elsif !fstat & [F:DAE]FLG<>2
  Gosub TR_DAE
 Else
  Call ECR_TRACE(mess(90,10705,1),1) From GESECRAN
  #Intégration des informations dads-u importées impossible
  Break
 Endif
 If !GOK : Break : Endif
 Gosub TR_DAS
 If !GOK : Break : Endif
 Gosub TR_DAC
 If !GOK : Break : Endif
 Gosub TR_DAG
 If !GOK : Break : Endif
 Gosub TR_DAH
 If !GOK : Break : Endif
 Gosub TR_DAI
 If !GOK : Break : Endif
 Gosub TR_DAJ
 If !GOK : Break : Endif
 Gosub TR_DAK
 If !GOK : Break : Endif
 Gosub TR_DAL
 If !GOK : Break : Endif
 Gosub TR_DAM
 If !GOK : Break : Endif
 Gosub TR_DAQ
 If !GOK : Break : Endif
 Gosub TR_DQE
 If !GOK : Break : Endif
 Gosub TR_DAP
 If !GOK : Break : Endif
 Gosub TR_DPE
 If !GOK : Break : Endif
 Gosub TR_DPP
 If !GOK : Break : Endif
 Gosub TR_DMU
 If !GOK : Break : Endif
 Gosub TR_DME
 If !GOK : Break : Endif
 Gosub TR_DMP
 If !GOK : Break : Endif
 Gosub TR_DNA
 If !GOK : Break : Endif
 Gosub TR_DNB
 If !GOK : Break : Endif
 Gosub TR_DNE
 If !GOK : Break : Endif
 Gosub TR_DNF
 If !GOK : Break : Endif
Next
If !GOK : Return : Endif
Return

##########################
# Liste des champs de DADEMP de type C et DCB non fusionnable
$LIST_CHAMP
# Decimal (DCB)
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]RATWAC"
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]BUIHRSEMP"
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]BUIHRSFCY"
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]LSTMTH"
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]DED"
####Short (C)
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]MTHWRK"
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]TRMWRK"
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]YEAWRK"
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]ROWBRN"
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]BUIRATEXS"
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]BUINBRYEA"
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]TRMWRKFIR"
NBCHAMP+=1
TCHAMP(NBCHAMP)="[F:DAE]MTHWRKFIR"
Return

############################
$TR_DAE
For [F:ATZB]CODZONE Where CODFIC="DADEMP"
 If [F:ATZB]CODZONE="RATSPE" | [F:ATZB]CODZONE="EXPNUM" | left$([F:ATZB]CODZONE,3)="CRE" | left$([F:ATZB]CODZONE,3)="UPD"
&                            | [F:ATZB]CODZONE="FLG"
  Gosub RIEN
 Elsif left$([F:ATZB]CODZONE,5)="BSPCE"
  Gosub FUS_BSPCE
 Elsif right$([F:ATZB]CODZONE,4)="STK"
  Gosub FUS_STK
 Elsif right$([F:ATZB]CODZONE,4)="ANC" & [F:ATZB]CODZONE<>"DATANC"
  Gosub FUS_ANC
 Elsif [F:ATZB]DIME>1
  For IFLD=0 To [F:ATZB]DIME-1
   CHAMP2= "[F:IDA]"+[F:ATZB]CODZONE+"("+num$(IFLD)+")"
   CHAMP = "[F:DAE]"+[F:ATZB]CODZONE+"("+num$(IFLD)+")"
   Gosub TR_FUSION
  Next
 Else
  CHAMP2= "[F:IDA]"+[F:ATZB]CODZONE
  CHAMP = "[F:DAE]"+[F:ATZB]CODZONE
  Gosub TR_FUSION
 Endif
Next
Rewrite [F:DAE]
If fstat<>0
 GOK = 0 : Call FSTA("DAE") From GLOCK
Endif
Return

######################################
$RIEN
Return

######################################
$TR_FUSION
Case [F:ATZB]CODTYP
 When"DCB","C","L" :#79445 : Add "L"
  If !find (CHAMP, TCHAMP(1..NBCHAMP)) | evalue(CHAMP)=0
   Assign CHAMP With evalue(CHAMP)+ evalue(CHAMP2)
  Endif
 When "M","RAT" :
  If evalue(CHAMP)=0       : Assign CHAMP With evalue(CHAMP2) : Endif
 When "D" :
  If evalue(CHAMP)=[0/0/0] : Assign CHAMP With evalue(CHAMP2) : Endif
 When Default
  If evalue(CHAMP)="" & left$(CHAMP,13)<>"[F:DAE]DECNUM"     : Assign CHAMP With evalue(CHAMP2) : Endif
Endcase
Return

####################
$FUS_STK
# Just 1 time for the 3 fiels *STK
If [F:ATZB]CODZONE<>"VALSTK" : Return : Endif
For I=0 To dim([F:DAE]VALSTK)-1
 If [F:DAE]VALSTK(I)=0 : Break : Endif
Next
#Exit with a good I
For J=0 To dim([F:IDA]VALSTK)-1
 If [F:IDA]VALSTK(J)=0 : Break : Endif
 K=find([F:IDA]VALSTK(J),[F:DAE]VALSTK(0..I))
 #If not exist or exit with a other price
 If !K | ([F:DAE]CTXSTK(K-1)<>[F:IDA]CTXSTK(J) & [F:DAE]PRISTK(K-1)<>[F:IDA]PRISTK(J))
  [F:DAE]CTXSTK(I)=[F:IDA]CTXSTK(J)
  [F:DAE]VALSTK(I)=[F:IDA]VALSTK(J)
  [F:DAE]PRISTK(I)=[F:IDA]PRISTK(J)
  [F:DAE]NBRSTK(I)=[F:IDA]NBRSTK(J)
  [F:DAE]FRGSTK(I)=[F:IDA]FRGSTK(J)
  [F:DAE]ATTSTK(I)=[F:IDA]ATTSTK(J)
  [F:DAE]LEVSTK(I)=[F:IDA]LEVSTK(J)
  I+=1
 Else
  [F:DAE]NBRSTK(K-1)+=[F:IDA]NBRSTK(J)
  [F:DAE]VALSTK(K-1)=max([F:DAE]VALSTK(K-1),[F:IDA]NBRSTK(J))
  [F:DAE]FRGSTK(K-1)=max([F:DAE]FRGSTK(K-1),[F:IDA]FRGSTK(J))
  [F:DAE]ATTSTK(K-1)=max([F:DAE]ATTSTK(K-1),[F:IDA]ATTSTK(J))
  [F:DAE]LEVSTK(K-1)=max([F:DAE]LEVSTK(K-1),[F:IDA]LEVSTK(J))
 Endif
Next
Return

####################
$FUS_ANC
# Just 1 time for the 3 fiels *ANC
If [F:ATZB]CODZONE<>"TYPANC" : Return : Endif
For I=0 To dim([F:DAE]TYPANC)-1
 If [F:DAE]TYPANC(I)=0 : Break : Endif
Next
#Exit with a good I
For J=0 To dim([F:IDA]TYPANC)-1
 If [F:IDA]TYPANC(J)=0 : Break : Endif
 If !find([F:IDA]TYPANC(J),[F:DAE]TYPANC(0..I))
  [F:DAE]UOMANC(I)=[F:IDA]UOMANC(J)
  [F:DAE]AMTANC(I)=[F:IDA]AMTANC(J)
  [F:DAE]TYPANC(I)=[F:IDA]TYPANC(J)
  I+=1
 Endif
Next
Return

$FUS_BSPCE
# Just 1 time for the 5 fiels BSPCE*
If [F:ATZB]CODZONE<>"BSPCENBRTI" : Return : Endif
For I=0 To dim([F:DAE]BSPCENBRTI)-1
 If [F:DAE]BSPCENBRTI(I)=0 : Break : Endif
Next
#Exit with a good I
For J=0 To dim([F:IDA]BSPCENBRTI)-1
 If [F:IDA]BSPCENBRTI(J)=0 : Break : Endif
 K=find([F:IDA]BSPCENBRTI(J),[F:DAE]BSPCENBRTI(0..I))
 #If not exist or exit with a other price
 If !K | [F:DAE]BSPCEPRITI(K-1)<>[F:IDA]BSPCEPRITI(J)
  [F:DAE]BSPCENBRTI(I)=[F:IDA]BSPCENBRTI(J)
  [F:DAE]BSPCEPRITI(I)=[F:IDA]BSPCEPRITI(J)
  [F:DAE]BSPCEFRGTI(I)=[F:IDA]BSPCEFRGTI(J)
  [F:DAE]BSPCEDATTI(I)=[F:IDA]BSPCEDATTI(J)
  [F:DAE]BSPCEDURTI(I)=[F:IDA]BSPCEDURTI(J)
  I+=1
 Else
  [F:DAE]BSPCENBRTI(K-1)+=[F:IDA]BSPCENBRTI(J)
  [F:DAE]BSPCEFRGTI(K-1)=max([F:DAE]BSPCEFRGTI(J),[F:IDA]BSPCEFRGTI(K-1))
  [F:DAE]BSPCEDATTI(K-1)=max([F:DAE]BSPCEDATTI(J),[F:IDA]BSPCEDATTI(K-1))
  [F:DAE]BSPCEDURTI(K-1)=max([F:DAE]BSPCEDURTI(J),[F:IDA]BSPCEDURTI(K-1))
 Endif
Next
Return

####################
$TR_DAS
Read[IDS]IDS0=[F:IDA]YEAEMPDDS;[F:IDA]EMPDDS;[F:IDA]CTRNUM;[F:IDA]ETRDAT;[F:IDA]TYPDAE;[F:IDA]FLGDNA
If !fstat
 Readlock[DAS]DAS0=[F:IDS]YEAEMPDDS;[F:IDS]EMPDDS;[F:IDS]CTRNUM;[F:IDS]ETRDAT;[F:IDS]TYPDAE;[F:IDS]FLGDNA
 If fstat=5
  Raz [F:DAS]
  [F:DAS]=[F:IDS]
  Write [DAS]
  If fstat<>0
   GOK = 0 : Call FSTA("DAS") From GLOCK
  Endif
 Elsif !fstat
  If [F:IDS]NBRRGM
   For I=0 To [F:IDS]NBRRGM-1
    If [F:IDS]RGMCOD(I)="" : Break : Endif
    K=find([F:IDS]RGMCOD(I),[F:DAS]RGMCOD(0..dim([F:DAS]RGMCOD)-1))
    If !K
     [F:DAS]RGMCOD([F:DAS]NBRRGM)=[F:IDS]RGMCOD(I)
     [F:DAS]RGMNUM([F:DAS]NBRRGM)=[F:IDS]RGMNUM(I)
     [F:DAS]NBRRGM+=1
    Else
     If [F:DAS]RGMNUM(K-1)="" : [F:DAS]RGMNUM(K-1)=[F:IDS]RGMNUM(I) : Endif
    Endif
   Next
  Endif

  If [F:IDS]NBRSPEBAS
   For I=0 To [F:IDS]NBRSPEBAS-1
    If [F:IDS]SPEBASCOD(I)="" : Break : Endif
    K=find([F:IDS]SPEBASCOD(I),[F:DAS]SPEBASCOD(0..dim([F:DAS]SPEBASCOD)-1))
    If !K
     [F:DAS]SPEBASCOD([F:DAS]NBRSPEBAS)=[F:IDS]SPEBASCOD(I)
     [F:DAS]SPEBASAMT([F:DAS]NBRSPEBAS)=[F:IDS]SPEBASAMT(I)
     [F:DAS]NBRSPEBAS+=1
    Else
     [F:DAS]SPEBASAMT(K-1)+=[F:IDS]SPEBASAMT(I)
    Endif
   Next
  Endif

  If [F:IDS]NBRSPECLG
   For I=0 To [F:IDS]NBRSPECLG-1
    If [F:IDS]SPECLGCOD(I)="" : Break : Endif
    K=find([F:IDS]SPECLGCOD(I),[F:DAS]SPECLGCOD(0..dim([F:DAS]SPECLGCOD)-1))
    If !K
     [F:DAS]SPECLGCOD([F:DAS]NBRSPECLG)=[F:IDS]SPECLGCOD(I)
     [F:DAS]SPECLGAMT([F:DAS]NBRSPECLG)=[F:IDS]SPECLGAMT(I)
     [F:DAS]NBRSPECLG+=1
    Else
     [F:DAS]SPECLGAMT(K-1)+=[F:IDS]SPECLGAMT(I)
    Endif
   Next
  Endif

  If [F:IDS]NBRALO
   For I=0 To [F:IDS]NBRALO-1
    If [F:IDS]ALOAMTCOD(I)="" : Break : Endif
    K=find([F:IDS]ALOAMTCOD(I),[F:DAS]ALOAMTCOD(0..dim([F:DAS]ALOAMTCOD)-1))
    If !K  | [F:DAS]ALOAMTYEA(K-1)<>[F:IDS]ALOAMTYEA(I)
     [F:DAS]ALOAMTCOD([F:DAS]NBRALO)=[F:IDS]ALOAMTCOD(I)
     [F:DAS]ALOAMTYEA([F:DAS]NBRALO)=[F:IDS]ALOAMTYEA(I)
     [F:DAS]ALOAMTBAS([F:DAS]NBRALO)=[F:IDS]ALOAMTBAS(I)
     [F:DAS]ALOAMTCLG([F:DAS]NBRALO)=[F:IDS]ALOAMTCLG(I)
     [F:DAS]NBRALO+=1
    Else
     [F:DAS]ALOAMTBAS(K-1)+=[F:IDS]ALOAMTBAS(I)
     [F:DAS]ALOAMTCLG(K-1)+=[F:IDS]ALOAMTCLG(I)
    Endif
   Next
  Endif

  If [F:IDS]NBRSPEEXO
   For I=0 To [F:IDS]NBRSPEEXO-1
    If [F:IDS]SPEEXOCOD(I)="" : Break : Endif
    K=find([F:IDS]SPEEXOCOD(I),[F:DAS]SPEEXOCOD(0..dim([F:DAS]SPEEXOCOD)-1))
    If !K
     [F:DAS]SPEEXOCOD([F:DAS]NBRSPEEXO)=[F:IDS]SPEEXOCOD(I)
     [F:DAS]SPEEXOBAS([F:DAS]NBRSPEEXO)=[F:IDS]SPEEXOBAS(I)
     [F:DAS]SPEEXOCLG([F:DAS]NBRSPEEXO)=[F:IDS]SPEEXOCLG(I)
     [F:DAS]NBRSPEEXO+=1
    Else
     [F:DAS]SPEEXOBAS([F:DAS]NBRSPEEXO)+=[F:IDS]SPEEXOBAS(I)
     [F:DAS]SPEEXOCLG([F:DAS]NBRSPEEXO)+=[F:IDS]SPEEXOCLG(I)
    Endif
   Next
  Endif

  Rewrite [DAS]
  If fstat<>0
   GOK = 0 : Call FSTA("DAS") From GLOCK
  Endif
 Endif
Endif
Return

####################
$TR_DAC
For [IDC]IDC0 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA
& & (ETRDAT>=[F:IDA]ETRDAT | (ETRDAT>=addmonth([F:IDA]ETRDAT,-2) & OLDSPE>1)) & ETRDAT<=[F:IDA]XITDAT
& & XITDAT<=[F:IDA]XITDAT
 Readlock [F:DAC]DAC0=[F:IDC]YEAEMPDDS;[F:IDC]EMPDDS;[F:IDC]CTRNUM;[F:IDC]ETRDAT;[F:IDC]TYPDAE;[F:IDC]FLGDNA
 If fstat=5
  Raz [F:DAC]
  [F:DAC]=[F:IDC]
  Write [F:DAC]
  If fstat<>0
   GOK = 0 : Call FSTA("DAC") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-mess(9,10705,1),0) From GESECRAN
  #Situations particulières
 Elsif !fstat
  If [F:DAC]SPETIMEVE=[F:IDC]SPETIMEVE
   [F:DAC]SPEHRSEVE+=[F:IDC]SPEHRSEVE
   [F:DAC]SPEAMT+=[F:IDC]SPEAMT
  Endif
  If [F:DAC]XITDAT=[0/0/0]  : [F:DAC]XITDAT      = [F:IDC]XITDAT       : Endif
  If [F:DAC]GRDSPE=""       : [F:DAC]GRDSPE      = [F:IDC]GRDSPE       : Endif
  If [F:DAC]OLDSPE=0  : [F:DAC]OLDSPE=[F:IDC]OLDSPE : Endif
  If [F:DAC]DAYTYP=0  : [F:DAC]DAYTYP=[F:IDC]DAYTYP : Endif
  If [F:DAC]NUMCTR="" : [F:DAC]NUMCTR=[F:IDC]NUMCTR : Endif
  Rewrite [DAC]
  If fstat<>0
   GOK = 0 : Call FSTA("DAC") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-mess(9,10705,1),0) From GESECRAN
  #Situations particulières
 Else
  Call ECR_TRACE(space$(5)-mess(9,10705,1)-":"-mess(90,10705,1),1) From GESECRAN
  #Situations particulières : Intégration des informations dads-u importées impossible
 Endif
Next
Return

####################
$TR_DAG
For [IDG]IDG0 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM
&                 & TYPDAE=[F:IDA]TYPDAE
 Filter [F:DAG] Where YEAEMPDDS=[F:IDG]YEAEMPDDS & EMPDDS=[F:IDG]EMPDDS & ETRDAT=[F:IDG]ETRDAT & CTRNUM=[F:IDG]CTRNUM
&                 & TYPDAE=[F:IDG]TYPDAE & CODDAG=[F:IDG]CODDAG
 Readlock [F:DAG]DAG0 Last
 Filter [F:DAG]
 If fstat>=2
  Raz [F:DAG]
  [F:DAG]=[F:IDG]
  [F:DAG]NUMLIG=[F:IDG]NUMLIG*10
  Write [F:DAG]
  If fstat<>0
   GOK = 0 : Call FSTA("DAG") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-mess([F:IDG]CODDAG,10954,1) ,0) From GESECRAN
  #Type d'epargne
 Elsif !fstat
  [F:DAG]AMTDAG+=[F:IDG]AMTDAG
  Rewrite [DAG]
  If fstat<>0
   GOK = 0 : Call FSTA("DAG") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-mess([F:IDG]CODDAG,10954,1) ,0) From GESECRAN
  #Type d'epargne
 Else
  Call ECR_TRACE(space$(5)-mess([F:IDG]CODDAG,10954,1)-":"-mess(90,10705,1),1) From GESECRAN
  #Type d'epargne : Intégration des informations dads-u importées impossible
 Endif
Next
Return

####################
$TR_DAH
For [IDH]IDH0 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM
&                 & TYPDAE=[F:IDA]TYPDAE
 Filter [F:DAH] Where YEAEMPDDS=[F:IDH]YEAEMPDDS & EMPDDS=[F:IDH]EMPDDS & ETRDAT=[F:IDH]ETRDAT & CTRNUM=[F:IDH]CTRNUM
&                 & TYPDAE=[F:IDH]TYPDAE & VALACT=[F:IDH]VALACT
 Readlock [F:DAH]DAH0 Last
 Filter [F:DAH]
 If fstat>=2
  Raz [F:DAH]
  [F:DAH]=[F:IDH]
  [F:DAH]NUMLIG=[F:IDH]NUMLIG*10
  Write [F:DAH]
  If fstat<>0
   GOK = 0 : Call FSTA("DAH") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-"Action de valeur unitaire"- num$([F:IDH]VALACT) ,0) From GESECRAN
  #Valeur unitaire de l'action
 Elsif !fstat
  [F:DAH]NBRACT+=[F:IDH]NBRACT
  Rewrite [DAH]
  If fstat<>0
   GOK = 0 : Call FSTA("DAH") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-"Action de valeur unitaire"- num$([F:IDH]VALACT) ,0) From GESECRAN
  #Valeur unitaire de l'action
 Else
  Call ECR_TRACE(space$(5)-"Action de valeur unitaire"- num$([F:IDH]VALACT)-":"-mess(90,10705,1),1) From GESECRAN
  #Valeur unitaire de l'action : Intégration des informations dads-u importées impossible
  Endif
Next
Return

####################
$TR_DAI
For [IDI]IDI0 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM
&                 & TYPDAE=[F:IDA]TYPDAE
 Filter [F:DAI] Where YEAEMPDDS=[F:IDI]YEAEMPDDS & EMPDDS=[F:IDI]EMPDDS & ETRDAT=[F:IDI]ETRDAT & CTRNUM=[F:IDI]CTRNUM
&                 & TYPDAE=[F:IDI]TYPDAE & CODDAI=[F:IDI]CODDAI
 Readlock [F:DAI]DAI0 Last
 Filter [F:DAI]
 If fstat>=2
  Raz [F:DAI]
  [F:DAI]=[F:IDI]
  [F:DAI]NUMLIG=[F:IDI]NUMLIG*10
  Write [F:DAI]
  If fstat<>0
   GOK = 0 : Call FSTA("DAI") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-mess([F:IDI]CODDAI,10955,1) ,0) From GESECRAN
  #Type avantage part
 Elsif !fstat
  [F:DAI]AMTDAI+=[F:IDI]AMTDAI
  Rewrite [DAI]
  If fstat<>0
   GOK = 0 : Call FSTA("DAI") From GLOCK : Break
  Endif
