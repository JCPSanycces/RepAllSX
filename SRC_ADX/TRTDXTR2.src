$TR_DNF
For [ID6]ID60 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM
&                 & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA

 Readlock [F:DNF]DNF0=[F:ID6]YEAEMPDDS;[F:ID6]EMPDDS;[F:ID6]ETRDAT;[F:ID6]CTRNUM;[F:ID6]TYPDAE;1
 If fstat>=2
  Raz [F:DNF]
  [F:DNF]=[F:ID6]
  Write [F:DNF]
  If fstat<>0
   GOK = 0 : Call FSTA("DNF") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-mess([F:ID6]DNACODTIM,10966,1),0) From GESECRAN
  # Durée du temps de travail
 Elsif !fstat & [F:ID6]DNACODTIM=[F:DNF]DNACODTIM
  If ![F:DNF]DNAHORCPY : [F:DNF]DNAHORCPY=[F:ID6]DNAHORCPY : Endif
  If ![F:DNF]DNAHORCTR : [F:DNF]DNAHORCTR=[F:ID6]DNAHORCTR : Endif
  Rewrite [F:DNF]
  If fstat<>0
   GOK = 0 : Call FSTA("DNF") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-mess([F:ID6]DNACODTIM,10966,1),0) From GESECRAN
  # Durée du temps de travail
 Else
  Call ECR_TRACE(space$(5)-space$(5)-mess([F:ID6]DNACODTIM,10966,1)-":"-mess(90,10705,1),1) From GESECRAN
  # Durée du temps de travail : Intégration des informations dads-u importées impossible
 Endif
Next
Return
