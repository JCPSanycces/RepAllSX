####################
$TR_DPP
For [IDR]IDR0 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM
&                 & TYPDAE=[F:IDA]TYPDAE
 Filter [F:DPP] Where YEAEMPDDS=[F:IDR]YEAEMPDDS & EMPDDS=[F:IDR]EMPDDS & ETRDAT=[F:IDR]ETRDAT & CTRNUM=[F:IDR]CTRNUM
&                 & TYPDAE=[F:IDR]TYPDAE & REFCTR=[F:IDR]REFCTR & STRDATCTR=[F:IDR]STRDATCTR
 Readlock [F:DPP]DPP0 Last
 Filter [F:DPP]
 If fstat>=2
  Raz [F:DPP]
  [F:DPP]=[F:IDR]
  Write [F:DPP]
  If fstat<>0
   GOK = 0 : Call FSTA("DPP") From GLOCK : Break
  Endif
 Elsif !fstat
  If [F:DPP]XITDAT=[0/0/0]    : [F:DPP]XITDAT=[F:IDR]XITDAT       : Endif
  If [F:DPP]ETRFCY=""         : [F:DPP]ETRFCY=[F:IDR]ETRFCY       : Endif
  If [F:DPP]ENDDATCTR=[0/0/0] : [F:DPP]ENDDATCTR=[F:IDR]ENDDATCTR : Endif
  For I=1 To 9
   CHAMP ="[F:DPP]AMTPRV"+num$(I)
   CHAMP2="[F:IDR]AMTPRV"+num$(I)
   Assign CHAMP With evalue(CHAMP)+ evalue(CHAMP2)
  Next
  For I=1 To 4
   CHAMP ="[F:DPP]NBRPEO"+num$(I)
   CHAMP2="[F:IDR]NBRPEO"+num$(I)
   Assign CHAMP With max(evalue(CHAMP),evalue(CHAMP2))
  Next
  For I=0 To dim([F:DPP]CODTYPBAS)-1
   If [F:DPP]CODTYPBAS(I)=0 : Break : Endif
  Next
  #Exit with a good I
  For J=0 To dim([F:IDR]CODTYPBAS)-1
   If [F:IDR]CODTYPBAS(J)=0 : Break : Endif
   K=find([F:IDR]CODTYPBAS(J),[F:DPP]CODTYPBAS(0..I))
   If !K
    [F:DPP]CODTYPBAS(I)=[F:IDR]CODTYPBAS(J)
    [F:DPP]AMTBAS(I)   =[F:IDR]AMTBAS(J)
    I+=1
   Else
    [F:DPP]AMTBAS(K-1)+=[F:IDR]AMTBAS(J)
   Endif
  Next
  Rewrite [DPP]
  If fstat<>0
   GOK = 0 : Call FSTA("DPP") From GLOCK : Break
  Endif
 Endif
Next
Return

