 Readlock [F:DAQ]DAQ0 Last
 Filter [F:DAQ]
 If fstat>=2
  Raz [F:DAQ]
  [F:DAQ]=[F:IDQ]
  [F:DAQ]NUMLIG=[F:IDQ]NUMLIG*10
  Write [F:DAQ]
  If fstat<>0
   GOK = 0 : Call FSTA("DAQ") From GLOCK : Break
  Endif
  Call ECR_TRACE(space$(5)-mess(70,10711,1)-mess([F:IDQ]TYPBNF,10980,1) ,0) From GESECRAN
  #Ayant droit
 Elsif !fstat
  If [F:DAQ]XITDAT=[0/0/0]  : [F:DAQ]XITDAT      = [F:IDQ]XITDAT       : Endif
  If [F:DAQ]ETRFCY=""       : [F:DAQ]ETRFCY      = [F:IDQ]ETRFCY       : Endif
  If [F:DAQ]NUMSSEBNF(0)="" : [F:DAQ]NUMSSEBNF(0)= [F:IDQ]NUMSSEBNF(0) : Endif
  If [F:DAQ]NUMSSEBNF(1)="" : [F:DAQ]NUMSSEBNF(1)= [F:IDQ]NUMSSEBNF(1) : Endif
  If [F:DAQ]NAMBNF=""       : [F:DAQ]NAMBNF      = [F:IDQ]NAMBNF       : Endif
  If [F:DAQ]SRNBNF=""       : [F:DAQ]SRNBNF      = [F:IDQ]SRNBNF       : Endif
  If [F:DAQ]ORGMALBNF=""    : [F:DAQ]ORGMALBNF   = [F:IDQ]ORGMALBNF    : Endif
  For I=1 To 4
   CHAMP ="[F:DAQ]FLGBNF"+num$(I)
   CHAMP2="[F:IDQ]FLGBNF"+num$(I)
   Assign CHAMP With max(evalue(CHAMP),evalue(CHAMP2))
  Next
  Rewrite [F:DAQ]
  If fstat<>0
   GOK = 0 : Call FSTA("DAQ") From GLOCK : Break
