#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACOPDOC","ACOPDOC",3,"") From GTRAITE
End

###############################################################
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "EXEC"       : Gosub EXEC
Endcase
Return

###################################################################
$INIT
Local Mask ACOPDOC [COP]
Raz [M:COP]
[M:COP]ALLLAN  = 1
[M:COP]ALLTYP  = 1
[M:COP]ALLCOD  = 1
[M:COP]LAN     = PARAM(1)
[M:COP]TYP     = PARAM(2)
[M:COP]COD     = PARAM(3)
If [M:COP]LAN="" : [M:COP]LAN = GLANGUE : Endif
Return

$EXEC
Call COPOBJ([M:COP]DOSORG,[M:COP]DOSDES,"ADO",[M:COP]LAN,[M:COP]TYP,[M:COP]COD,"") From ACOPIE
Return

######################################################################################
Subprog C_ALLLAN(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]LAN = "" : Affzo LAN : Grizo LAN
Else
 Actzo LAN
Endif
End

Subprog AS_LAN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = GLANGUE
Endif
End

Subprog C_ALLTYP(VALEUR)
Variable Integer  VALEUR
If VALEUR=2
 [M]TYP = "" : Affzo TYP : Grizo TYP
Else
 Actzo TYP
Endif
End

Subprog C_ALLCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]COD = "" : Affzo COD : Grizo COD
Else
 Actzo COD
Endif
End

Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
Call D_DOSORG(VALEUR) From ACOPIE
End

Subprog AV_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AV_DOSORG(VALEUR) From ACOPIE
End

Subprog AM_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AM_DOSORG(VALEUR) From ACOPIE
End

Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AS_DOSORG(VALEUR) From ACOPIE
End

Subprog IB_DOSDES
Call IB_DOSDES From ACOPIE
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
Call AS_DOSDES(VALEUR) From ACOPIE
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call C_DOSDES(VALEUR) From ACOPIE
End

