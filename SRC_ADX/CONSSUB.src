#<AdxTL>@(#)8.0.0.0 $Revision$
############################################################################################################
# Traitement qui regroupe les contrôles les plus communs pour les écrans de consultations de la comptabilité
# ainsi que le zoom sur les échéances et les répartitions analytiques.
############################################################################################################

$ACTION
Case ACTION
 When "TRT_DIV" : Gosub TRT_DIV
Endcase
Return


$TRT_DIV
Case TRAIT
 When "CONSSUB3" : Gosub B3_NBLIG
 When "CONSSUB4" : Gosub B4_NBLIG
 When "ZOOM"     : Gosub ZOOM
Endcase
Return

#####################
Subprog C_CPY(VALEUR)
#####################
Variable Char    VALEUR()
Local Char SOCIETE(GLONCPY)
If VALEUR<>"" & VALEUR<>[M]CPY
 [M]CPY = VALEUR
 Gosub SETSOC
Endif
End

########################
Subprog C_LEDTYP(VALEUR)
Value Integer VALEUR
# Vérification qu'un référentiel du type indiqué est défini dans le modèle comptable de la société
If clalev([GCM])=0 : Local File GACM [GCM] : Endif
If [M]CPY<>""
 If !clalev([DAA]) : Local File GACCENTRYA [DAA] : Endif
 Local Integer NBAXE
 Local Char    LSTAXE(GLONDIE)(1..dim([F:DAA]DIE))
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 If [F:CPY]CPYLEGFLG=2
  # Société Juridique
  Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
  If [F:GCM]LED(VALEUR-1) = ""
   # Type de référentiel non défini pour la société
   GMESSAGE = mess(105,104,1)
   mkstat = 2 : End
  Else
   [M]LED    = [F:GCM]LED(VALEUR-1)
   [M]CURLED = [F:GCM]CUR(VALEUR-1)
   If clalev([LED])=0 : Local File GLED [LED] : Endif
   Call LECTURE("LED",[F:GCM]LED(VALEUR-1),"") From CONTOBJ
   If [F:LED]COA<>"" : [M]COA=[F:LED]COA : Endif
   Affzo [M]
  Endif
 Else
  # Société non juridique => Groupement de site/société
  #  Les différents Contrôles de cohérence /t aux différentes les sociétés du groupe
  # [COA plan de compte identique]
  # [LED référentiel identique]
  # [DEVLED devise de référentiel identique]
  # [PER découpage période exercice identique]
  #
  # CONSBAL => COA + DEVLED + PER
  # CONSCPT => COA + DEVLED + PER
  # CONSBAF => COA + LED + PER
  # CONSNAT => LED + DEVLED + PER
  # CONSSEC => LED + DEVLED + PER
  # CONSPCE => LED
  # Le contrôle sur les période est fait en contrôle de la date de fin C_DATFIN...

  Local Integer STAT
  Local Char MESSA(250),CODLED(GLONLED),DEVLED(GLONCUR),PLAN(GLONCOA)
  Case GFONCTION
   When "CONSBAL" : Gosub CONTCOA : Gosub CONTDEVLED
   When "CONSCPT" : Gosub CONTCOA : Gosub CONTDEVLED
   When "CONSNAT" : Gosub CONTLED : Gosub CONTDEVLED
   When "CONSBAF" : Gosub CONTCOA : Gosub CONTLED
   When "CONSSEC" : Gosub CONTLED : Gosub CONTDEVLED
   When "CONSPCE" : Gosub CONTLED
   When "CONSBSE" : Gosub CONTCOA : Gosub CONTDEVLED
  Endcase
  Affzo [M]
 Endif
 ##Gestion de l'affichage des colonnes sections
 # Pour Initialisation des champs invisibles DIE et INTITDIE
 Call GETLSTAXE([M]CPY,VALEUR,NBAXE,LSTAXE) From CPTDIV
 #Initialisation des champs invisibles DIE et INTITDIE
 For I=1 To NBAXE
  [M]DIE(I-1)=LSTAXE(I)
  Call LECTEXTRA([M]INTITDIE(I-1),"GDIE","COLHEA",LSTAXE(I),"") From ATEXTRA
 Next
 If GFONCTION="CONSCPT" | GFONCTION="CONSNAT" | GFONCTION="CONSPCE"
  For I=1 To NBAXE
   Assign "[M]FMTDIE("+num$(I-1)+")" With "KP:15X"
  Next
  For I=NBAXE+1 To 9
   Assign "[M]FMTDIE("+num$(I-1)+")" With "-K:15X"
  Next
 Endif
Endif
End

$CONTCOA
 Call CNTCOHCOA([M]CPY,VALEUR,PLAN,STAT,MESSA) From CPTCNT
 If !STAT
  Call MESSAGE([L]MESSA) From GESECRAN
  zonsui = "[M]CPY"
  mkstat = 0 : End
 Else
  [M]COA=PLAN
 Endif
Return

$CONTDEVLED
  Call CNTCOHDEV([M]CPY,VALEUR,CODLED,DEVLED,STAT,MESSA) From CPTCNT
  If !STAT
   Call MESSAGE([L]MESSA) From GESECRAN
   zonsui = "[M]CPY"
   mkstat = 0 : End
  Else
   [M]LED=CODLED
   [M]CURLED=DEVLED
   # pour Initialisation des champs invisibles DIE et INTITDIE
   Call LECTURE("LED",CODLED,"") From CONTOBJ
   NBAXE = [F:LED]DIENBR
   For I=1 To dim([F:LED]DIE)
    LSTAXE(I) = [F:LED]DIE(I-1)
   Next
   [M]COA=[F:LED]COA
  Endif
Return

$CONTLED
 Call CNTCOHLED([M]CPY,VALEUR,CODLED,DEVLED,STAT,MESSA) From CPTCNT
 If !STAT
  Call MESSAGE([L]MESSA) From GESECRAN
  zonsui = "[M]CPY"
  mkstat = 0 : End
 Else
  [M]LED=CODLED
  [M]CURLED=DEVLED
  # pour Initialisation des champs invisibles DIE et INTITDIE
  Call LECTURE("LED",CODLED,"") From CONTOBJ
  NBAXE = [F:LED]DIENBR
  For I=1 To dim([F:LED]DIE)
   LSTAXE(I) = [F:LED]DIE(I-1)
  Next
  [M]COA=[F:LED]COA
 Endif
Return


######################
Subprog AS_FCY(VALEUR)
######################
Variable Char    VALEUR()
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=1
 # Si c'est une société non juridique, il s'agit d'un groupement de sites
 GCURLEG=""
 mkstat=1
Else
 If VALEUR<>""
  Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
  If [F:FCY]LEGCPY<>[M]CPY
   [M]FCY = [F:CPY]MAIFCY
   Affzo [M]FCY
  Endif
 Endif
Endif
End

#####################
Subprog C_FCY(VALEUR)
#####################
Variable Char VALEUR()
Local Char SOCIETE(GLONCPY)
If VALEUR<>""
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 # le site n'est pas financier on sort.
 If [F:FCY]FINFLG<>2
  #Le site n'est pas un site financier.
  GMESSAGE = mess(217,107,1)
  mkstat=2 : End
 Endif
 Call CONTFCY(VALEUR) From CPTSUB
 If mkstat : End : Endif
 If [M]CPY<>[F:FCY]LEGCPY : [M]CPY = [F:FCY]LEGCPY : Affzo CPY : #Gosub SETSOC
  Endif
 Call GETSOC(VALEUR) From DEVSUB
 If dim([M]ZCPY)>0
  Onerrgo CHUT From CONSSUB
  Affzo ZCPY
  Onerrgo
 Endif
Elsif [M]CPY=""
 # Vous devez saisir une société ou un site
 GMESSAGE = mess(9,109,1)
 mkstat = 2
Else
 Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

#####################
Subprog C_AXE(VALEUR)
#####################
Variable Char VALEUR()
Local Integer I,RES
If clalev([LED])=0 : Local File GLED [LED] : Endif
If clalev([GCM])=0 : Local File GACM [GCM] : Endif
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 Call LECTURE("GCM",[F:CPY]ACM,"")  From CONTOBJ
 Call LECTURE ("LED",[F:GCM]LED([M]LEDTYP-1),"") From CONTOBJ
 If find(VALEUR,[F:LED]DIE(0..[F:LED]DIENBR-1))
  RES = 1
 Else
  RES = 0
 Endif
Else
 RES = 1
 For [FGR]FGR0 Where CPY=[M]CPY
  Read [FCY]FCY0 = [F:FGR]FCY
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  Call LECTURE("GCM",[F:CPY]ACM,"")  From CONTOBJ
  Call LECTURE ("LED",[F:GCM]LED([M]LEDTYP-1),"") From CONTOBJ
  If !find(VALEUR,[F:LED]DIE(0..[F:LED]DIENBR-1))
   RES = 0 : Break
  Endif
 Next
Endif
If RES=0
 # Cet axe n'est pas défini dans le référentiel choisi
 GMESSAGE = mess(111,104,1)-"("+mess(26,113,1)-[F:CPY]CPY+")"
 mkstat = 2 : End
Endif
Local Integer DROIT
Call CONSACC([F:DIE]ACS,DROIT) From CPTSUB
If !DROIT
 ## Vous n'avez pas les droits pour ce code
 GMESSAGE = mess(4,104,1)
 mkstat = 2 : End
Endif
End

$CHUT
Resume

$SETSOC
If [M]DATFIN<[M]DATDEB : mkstat=2
Else
 Call C_DATDEB([M]DATDEB)
 If !mkstat : Call C_DATFIN([M]DATFIN) : Endif
Endif
If mkstat
 mkstat = 0
 Raz GMESSAGE
 Call DATDEFSOC([M]CPY,[M]DATDEB,[M]DATFIN)
 Affzo DATDEB, DATFIN
Endif
If dim([M]CURAFF)>0
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 Onerrgo CHUT From CONSSUB
 [M]CURAFF = [F:CPY]ACCCUR
 Affzo CURAFF
 Onerrgo
Elsif dim([M]CUR)>0
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 Onerrgo CHUT From CONSSUB
 [M]CUR = [F:CPY]ACCCUR
 Affzo CUR
 Onerrgo
Endif
#Ajout pour legislation
If dim([M]FCY)>0 & [M]FCY<>""
 Call GETSOC([M]FCY) From DEVSUB
Else
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 Call GETSOC([F:CPY]MAIFCY) From DEVSUB
 If [F:CPY]CPYLEGFLG <> 2 : GCURLEG="" : Endif
Endif
Return

##############################################################
# Dates et société proposées à l'entrée dans la consultation #
##############################################################
Subprog INIT(DEBDAT,FINDAT)
Variable Date DEBDAT, FINDAT
Local Integer I

If [M]FCY="" & [M]CPY="" & (GUSRFCY="\" | find(GFCYDEF(0),GUSRFCY(1..GNBAUZ)))
 [M]FCY = GFCYDEF
 Call LECTURE("FCY",GFCYDEF,"") From CONTOBJ
 [M]CPY = [F:FCY]LEGCPY
 #Ajout pour legislation
 #Call GETSOC([M]CPY) From DEVSUB #DdM54644
 Call GETSOC([M]FCY) From DEVSUB
Endif

I = 1
Repeat
 If [M]DATDEB<>[0/0/0] & [M]DATFIN<>[0/0/0] & [M]DATFIN>=[M]DATDEB
  Break
 Endif
 I += 1
 Case I
  When 1 : # Paramètre
  When 2 : # GDATEDEB/GDATEFIN
   [M]DATDEB = GDATEDEB : [M]DATFIN=GDATEFIN
  When 3 : # Dernier exercice ouvert
   If [M]CPY<>""
    Call DATDEFSOC([M]CPY,[M]DATDEB,[M]DATFIN) From CONSSUB
   Endif
  When 4 : # Memo
   [M]DATDEB = DEBDAT
   [M]DATFIN = FINDAT
  When 5
   Raz [M]DATDEB, [M]DATFIN
 Endcase
Until I=5
Raz DEBDAT, FINDAT
End

#################################################################
#   Dates début et fin de dernier exercice ouvert ou fermé      #
#   d'une société jurique ou non                                #
#################################################################
Subprog DATDEFSOC(SOC,DATDEB,DATFIN)
Value Char SOC()
Variable Date DATDEB, DATFIN
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:FIY]) : Local File FISCALYEAR [FIY] : Endif
If !clalev([F:FGR]) : Local File FACGROUP   [FGR] : Endif
Raz DATDEB, DATFIN
Call LECTURE("CPY",SOC,"") From CONTOBJ
If [F:CPY]CPYLEGFLG<>1
 Filter [FIY] Where CPY=SOC & FIYSTA>1
 Read [FIY] Last
 If fstat<=2
  DATDEB = [F:FIY]FIYSTR
  DATFIN = [F:FIY]FIYEND
 Endif
Else
 For [FGR]FGR0 Where CPY=SOC
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
  Filter [FIY] Where CPY=[F:FCY]LEGCPY & FIYSTA>1
  Read [FIY] Last
  If fstat<=2
   If DATDEB=[0/0/0] or DATDEB>[F:FIY]FIYSTR
    DATDEB = [F:FIY]FIYSTR
   Endif
   If DATFIN=[0/0/0] or DATFIN<[F:FIY]FIYEND
    DATFIN = [F:FIY]FIYEND
   Endif
  Endif
 Next
 If DATFIN<DATDEB : Raz DATFIN,DATDEB : Endif
Endif
Filter [FIY]
End

########################
Subprog C_DATDEB(VALEUR)
########################
Variable Date    VALEUR
Local Decimal EXERCICE , PERIODE
Local Char    MODELE(GLONGCM)
Local Integer TYPLED
If VALEUR=[0/0/0]
 #Obligatoire
 GMESSAGE=mess(4,65,1)
 mkstat=2 : End
Endif
If dim([M]LEDTYP)>0
 TYPLED = [M]LEDTYP
Else
 Call LECLEDMAIN(1,[M]CPY,TYPLED) From CPTDIV
Endif
Call GETPERSOC([M]CPY,TYPLED,VALEUR,EXERCICE,PERIODE) From CPTSUB
If EXERCICE=0 | PERIODE=0
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 If [F:CPY]CPYLEGFLG<>1
  GMESSAGE = mess(10,109,1) : mkstat = 2 : # Date incorrecte
 Endif
Endif
End

########################
Subprog C_DATFIN(VALEUR)
########################
Variable Date    VALEUR
Call C_DATDEB(VALEUR) From CONSSUB
If GFONCTION="CONSBAL" | GFONCTION="CONSCPT" | GFONCTION="CONSNAT" | GFONCTION="CONSSEC"
 Local Integer STAT
 Local Char MESSA(250)
 #Vérif cohérence période
 Call CNTCOHPERV6([M]CPY,[M]LEDTYP,[M]DATDEB,VALEUR,STAT,MESSA) From CPTCNT
 If !STAT
  Call MESSAGE(MESSA) From GESECRAN
  zonsui = "[M]CPY"
  mkstat = 0 : End
 Endif
Endif
End

##############################################
Subprog CONTEXE(SOC,LED,DATDEB,DATFIN,OKPER)
##############################################
Value    Char    SOC()
Value    Integer LED
Value    Date    DATDEB
Variable Date    DATFIN
Variable Integer OKPER
Local Integer NBSOC, NBPER
# GH 02/02/00 bug 4189
NBSOC = max(1,GNBSOC)
Local Char TSOC(GLONCPY)(1..NBSOC) : # Table des sociétés juridiques des sites du groupement
NBSOC = 0
Local Date TDATDEB(1..999)
Local Decimal EXERCICE, PERIODE, EDEB, EFIN
OKPER = 1
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
Call LECTURE("CPY",SOC,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=1
 NBSITE = 0 : NBSOC = 0
 For [FGR]FGR0 Where CPY = [F:CPY]CPY
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
  If !find([F:FCY]LEGCPY,TSOC(1..NBSOC))
   NBPER=0
   NBSOC += 1 : TSOC(NBSOC)=[F:FCY]LEGCPY
   Call GETPERSOC(TSOC(NBSOC),LED,DATDEB,EXERCICE,PERIODE) From CPTSUB
   EDEB = EXERCICE
   Call GETPERSOC(TSOC(NBSOC),LED,DATFIN,EXERCICE,PERIODE) From CPTSUB
   EFIN = EXERCICE
   If EFIN=0
    Filter [FIY] Where CPY=TSOC(NBSOC)
    Read [FIY]FIY0 Last
    Filter [FIY]
    If fstat<=2 & DATFIN>[F:FIY]FIYEND : EFIN=[F:FIY]FIYNUM : Endif
   Endif
   For EXERCICE=EDEB To EFIN
    For [PER]PER0 Where CPY=TSOC(NBSOC) & FIYNUM=EXERCICE
     NBPER += 1
     If NBSOC=1
      TDATDEB(NBPER) = [F:PER]PERSTR
     Elsif TDATDEB(NBPER)<>[F:PER]PERSTR
      # Les périodes ne sont pas les mêmes
      OKPER = 0 : Break 3
     Endif
    Next
   Next
  Endif
 Next : # [FGR]
Endif
End

#########################
Subprog AS_TRIANA(VALEUR)
#########################
Variable Char    VALEUR()
If [M]TRI<>3 : mkstat=1 : Endif
End

################
Subprog IB_NBLIG
################
Local Char    SOCSIT(3)
Local Integer NOL

Raz GBOUT1,GBOUT2,GBOUT3,GBOUT4

If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif

If GMODU(5)=2
 If clalev([F:SIV])=0 : Local File SINVOICEV [SIV] : Endif
Endif

NOL = nolign-1
mkstat = 0

If NOL>=[M]NBLIG | [M]NBLIG=0 : End : Endif

If [M]FCY<>"" : SOCSIT = [M]FCY : Else : SOCSIT = [M]CPY : Endif
If !GTUNCPT(5) & dim([M]TYP)>0 & dim([M]NUM)>0 & [M]NUM(NOL)<>"" & [M]TYP(NOL)<>""
 Read [HAE]HAE0 = [M]TYP(NOL);[M]NUM(NOL)
 If !fstat
  GBOUT1 = mess(18,109,1) : #  Pièce
  Call GETSOC([F:HAE]FCY) From DEVSUB
  # Bug 11180 : Dmd Amélioration : Ajout d'un Tunnel sur échéances depuis Pièce.
  If [M]ACCNUM(NOL)<>0
   Read [DAE]DAE2 = [M]ACCNUM(NOL)
   If !fstat and [F:DAE]SAC<>""
    Call LEC_GTE_LEG(GCURLEG,[F:DAE]TYP) From CPTLEC
    If [F:GTE]DUDDATFLG=2
     GBOUT3 = mess(39,117,1) : # Echéances
    Endif
   Endif
  Endif
 Endif
Endif

If dim([M]TYP)>0 & dim([M]NUM)>0
 Read [HAE]HAE0=[M]TYP(NOL);[M]NUM(NOL)
 If fstat : End : Endif
 If !GTUNCPT(8) & left$([F:HAE]REFINT,3)="PYH"
  GBOUT2 = mess(47,109,1) : # Règlement
 Elsif [F:HAE]ORIMOD=3
  If !GTUNCPT(6)
   Look [SIH]SIH2 = [M]TYP(NOL);[M]NUM(NOL)
   If !fstat
    GBOUT2 = mess(43,109,1) : # Facture tiers client
    GBOUT3 = mess(39,117,1) : # Echéances
   Endif
  Endif
  If !GTUNCPT(7) & (GBOUT2="" | GBOUT3="")
   Look [PIH]PIH2 = [M]TYP(NOL);[M]NUM(NOL)
   If !fstat
    GBOUT2 = mess(44,109,1) : # Facture tiers fournisseur
    GBOUT3 = mess(39,117,1) : # Echéances
   Endif
  Endif
 Elsif !GTUNCPT(9) & [F:HAE]ORIMOD=5 & GMODU(5)=2
  Look [SIV]SIV0 = [M]NUM(NOL)
  If !fstat
   GBOUT2 = mess(45,109,1) : # Facture vente
   GBOUT3 = mess(39,117,1) : # Echéances
  Endif
 Elsif !GTUNCPT(10) & [F:HAE]ORIMOD=6 & GMODU(6)=2
  Look [PIH]PIH2 = [M]TYP(NOL);[M]NUM(NOL)
  If !fstat
   GBOUT2 = mess(46,109,1) : # Facture achat
   GBOUT3 = mess(39,117,1) : # Echéances
  Endif
 Endif
 If dim([M]DSP)>1
  If [M]DSP(NOL)<>"" : GBOUT4 = mess(49,109,1) : Endif : # Analytique
 Endif
Endif
End

##########################
## Tunnel vers les pièces
##########################
Subprog B1_NBLIG
Read [HAE]HAE0 = [M]TYP(nolign-1);[M]NUM(nolign-1)
GFLAG  = [F:HAE]DACDIA
GBIDC1 = "GAS"
GBIDC2 = [M]NUM(nolign-1)
GBIDC3 = [M]TYP(nolign-1)
End

#########################################
## Tunnel vers les factures et règlements
#########################################
Subprog B2_NBLIG
Local Char PYHNUM(GLONVCR)
Raz GBIDC1, GBIDC2, GBIDC3
GCONSULT = 1
Case GBOUT2
    When mess(43,109,1) : # Facture tiers client
        If clalev([F:SIH])=0 : Local File SINVOICE  [SIH] : Endif
        Call LECTURE("BIC",[M]NUM(nolign-1),"") From CONTOBJ
        If fstat=0        # Call OBJET ("BIC",[M]NUM(nolign-1),"") From GOBJET : Endif
         GBIDC1 = "BIC"
         GBIDC2 = [M]NUM(nolign-1)
         If func AFNC.ACTIV("INTCO")
          If clalev([F:ICF])=0 : Local File INTCOFLO [ICF]  : Endif
          Filter [ICF] Where ABRFIC="SIH" & NUM=[M]NUM(nolign-1)
          Read [ICF] First
          Filter [ICF]
          If !fstat
           GFONC1 = "GESBICI"
          Else
           GFONC1 = "" : fstat = 0
          Endif
         Endif
        Endif
    When mess(44,109,1) : # Facture tiers fournisseur
        If clalev([F:PIH])=0 : Local File PINVOICE  [PIH] : Endif
        Call LECTURE("BIS",[M]NUM(nolign-1),"") From CONTOBJ
        If fstat=0        # Call OBJET ("BIS",[M]NUM(nolign-1),"") From GOBJET : Endif
         GBIDC1="BIS"
         GBIDC2 = [M]NUM(nolign-1)
         If func AFNC.ACTIV("INTCO")
          If clalev([F:ICF])=0 : Local File INTCOFLO [ICF]  : Endif
          Filter [ICF] Where ABRFIC="PIH" & NUM=[M]NUM(nolign-1)
          Read [ICF] First
          Filter [ICF]
          If !fstat
           GFONC1 = "GESBISI"
          Else
           GFONC1 = "" : fstat = 0
          Endif
         Endif
        Endif
    When mess(45,109,1) : # Facture vente
        If clalev([F:SIV])=0 : Local File SINVOICEV [SIV] : Endif
        Call LECTURE("SIH",[M]NUM(nolign-1),"") From CONTOBJ
        If fstat=0        # Call OBJET ("SIH",[M]NUM(nolign-1),"") From GOBJET : Endif
            GBIDC1="SIH"
            GBIDC2 = [M]NUM(nolign-1)
        Endif
    When mess(46,109,1) : # Facture achat
        If clalev([F:PIH])=0 : Local File PINVOICE [PIH] : Endif
        Call LECTURE("PIH",[M]NUM(nolign-1),"") From CONTOBJ
        If fstat=0        # Call OBJET ("PIH",[M]NUM(nolign-1),"") From GOBJET : Endif
            GBIDC1="PIH"
            GBIDC2 = [M]NUM(nolign-1)
        Endif
    When mess(47,109,1) : # Réglement
        If clalev([F:PYH])=0 : Local File PAYMENTH  [PYH] : Endif
        PYHNUM = right$([F:HAE]REFINT,5)
        Read [PYH]PYH0 = PYHNUM
        If fstat=0
            #Call OBJET("PAY",PYHNUM,"") From GOBJET
            GBIDC1="PAY"
            GBIDC2 = PYHNUM
        Endif
Endcase
End

#########################################
## Tunnel vers les échéances
#########################################
$B3_NBLIG
Raz GBIDD1, GBIDI1

Case GBOUT2
    When mess(43,109,1),mess(45,109,1)    # Facture tiers client ou vente
     If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif
        If [F:SIH]NUM<>[M]NUM(nolign-1)
            Read [SIH]SIH0 = [M]NUM(nolign-1)
            If fstat : OK = 0 : Return : Endif
        Endif
        GBIDD1  = [F:SIH]AMTATI
        GBIDI1  = [F:SIH]ACCNUM

    When mess(44,109,1), mess(46,109,1)    # Facture tiers fournisseur ou achat
        If clalev([F:PIH])=0 : Local File PINVOICE [PIH] : Endif
        If [F:PIH]NUM<>[M]NUM(nolign-1)
            Read [PIH]PIH0 = [M]NUM(nolign-1)
            If fstat : OK = 0 : Return : Endif
        Endif
        GBIDD1  = [F:PIH]AMTATI
        GBIDI1  = [F:PIH]ACCNUM

    When Default                            # Pièce comptable directe
        # Bug 11180 : Dmd Amélioration : Ajout d'un Tunnel sur échéances depuis Pièce
        If GBOUT1 <> mess(18,109,1) :  OK = 0 : Return : Endif  #  Pièce
        If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
        If [F:DAE]ACCNUM<>[M]ACCNUM(nolign-1)
            Read [DAE]DAE2 = [M]ACCNUM(nolign-1)
            If fstat : OK = 0 : Return  : Endif
        Endif

        GBIDD1  = [F:DAE]AMTCUR
        GBIDI1  = [F:DAE]ACCNUM
Endcase
Return

######################################
## Tunnel sur répartition analytique
######################################
$B4_NBLIG
Local Decimal PTV(1),PTF(1)
Local Integer NOL,PV,PF, CPTACCNUM
Local Shortint STAT
Local Char CPTNUM(GLONVCR),CPTTYP(GLONGTE)

NOL=nolign-1
CPTTYP   = [M]TYP(NOL)
CPTNUM   = [M]NUM(NOL)
CPTACCNUM= [M]ACCNUM(NOL)

If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:DAA])=0 : Local File GACCENTRYA [DAA] : Endif

#Local Mask VENTILE [VTL]
# ouvert dans l'action OUVRE des CNSxxxSTD

PV = 0
PF = 0
Raz [M:VTL], [M:VT2]
Read [DAE]DAE2=[L]CPTACCNUM
For [DAA]DAA0 Where TYP=[L]CPTTYP & NUM=[L]CPTNUM & ACCNUM=[L]CPTACCNUM
 PF += 1
 If !PV : PV = PF : Endif
 [M:VT2]TBAMT(PF) = [F:DAA]AMTCUR
 [M:VT2]TBQTY(PF) = [F:DAA]QTY
 #JHA 070509 Bug 54064 rmq 3
 # For I=1 To GOPTCANA
 For I=1 To dim([F:DAA]DIE)
  Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(PF)+")" With [F:DAA]CCE(I-1)
  Assign "[M:VT2]TBDIE"+"("+num$(I-1)+")" With [F:DAA]DIE(I-1)
 Next I
Next
[M:VT2]PTVENT = PF+1
PTV(0) = PV
PTF(0) = PF

# initialisation des paramètres
GBIDI1 = PF
GBIDD2 = PTV
GBIDD3 = PTF
GBIDD1 = [F:DAE]AMTCUR    # affectation ogligatoire du à un nom de paramètres utilisé +sieurs fois.
Return

$SAV_CONSULT
Local Integer OCONSULT, I
Local Char    OBOUT(50)(1..12)
OCONSULT = GCONSULT
For I=1 To dim(OBOUT)
 OBOUT(I) = evalue("GBOUT"+num$(I))
Next I
Return

$RST_CONSULT
GCONSULT = OCONSULT
For I=1 To dim(OBOUT)
 Assign "GBOUT"+num$(I) With OBOUT(I)
Next I
Return

$ZOOM
Gosub SAV_CONSULT
GCONSULT=1
Call OBJET_CHAR(PARAM(1),PARAM(2),PARAM(3)) From GOBJET
Gosub RST_CONSULT
Return

#CHECK IGNORE_BEGIN
##########################################################
# Sous-progs communs BUDDET/BUDNAT/BUDSEC/CONSLIA/CTLLIA #
##########################################################
Subprog CRITERE(ABREV,EXT,CHANGE)
Value    Char    ABREV
Value    Char    EXT
Variable Integer CHANGE
Local Integer NBTEX , SAVOBJET , REPONSE , STAT
Local Char    CHAINE(30) , REP(1) , TEX(20)(20)
Local Char    CMEM(1) , CRAP(1) , CFIL(1) , CTET(1) , CLIG(1)
Local Char    SAVPROG(10)
Local Integer ETABOU(1..GNBBOU)

Boxact [CRIT]
Affzo
CHANGE = 0
SAVOBJET = GOBJET
SAVPROG = GPROGRAMME
GOBJET = 1
GPROGRAMME = "CONSSUB"
Call SAVBOUT From GESECRAN
Raz ETABOU
ETABOU(GABAN) = 1
ETABOU(GVALI) = 1
ETABOU(GBFIN) = 1
ETABOU(GSPE1) = 1
ETABOU(GSPE2) = 1
ETABOU(GSPE3) = 1
Call SETBOUT(ETABOU) From GESECRAN

$CHCRIT
Onevent AFTER_CHANGE Gosub APRES_MODIF
Boxinp [CRIT] Using REPONSE
Onevent AFTER_CHANGE
Case REPONSE
    When GSTABOU+1 : # Mémo
        Local Char PARBOUT(30)(1..3)
        Local Char VALBOUT(10)
        PARBOUT(1) = ABREV
        PARBOUT(2) = EXT
        PARBOUT(3) = "1"
        Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO","GMEMO","") From GSAISIE
        Affzo
    When GSTABOU2+2 : # Rappel
        Local Char PARBOUT(30)(1..3)
        Local Char VALBOUT(10)
        PARBOUT(1) = ABREV
        PARBOUT(2) = EXT
        PARBOUT(3) = "2"
        Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO","GMEMO","") From GSAISIE
        CHANGE = 1
        Affzo
    When GSTABOU2+3  :# Eff mémo
        Local Char PARBOUT(30)(1..3)
        Local Char VALBOUT(10)
        PARBOUT(1) = ABREV
        PARBOUT(2) = EXT
        PARBOUT(3) = "3"
        Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO","GMEMO","") From GSAISIE
    When GSTAOK, GSTARET, GSTAFIN , GSTAESC , GSTAEND
        Boxclr [CRIT]
        GOBJET = SAVOBJET
        GPROGRAMME = SAVPROG
        Call RESTBOUT From GESECRAN
        End
    Endcase
Goto CHCRIT

$APRES_MODIF
[L]CHANGE = 1
If zoncou<>"MEMO" & dim([M]MEMO)>0
 [M]MEMO = "" : Affzo MEMO
Endif
Return

#CHECK IGNORE_END

