####################################################################
# 4 : DESLNG Description ( Field ACRTF 1)
####################################################################

$GET_DESLNG
Gosub DECLARE_VAR From WMC0PROJET
[L]CURPRO = "DESLNG"
Local Char _CNT(100)
Local Tinyint _EXI : [L]_EXI=1
[L]ASTATUS = fmet this.AREAD_CLB("DESLNG",
& this.PRJ
& ,[L]_CNT,this.DESLNG)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isLoaded")<>"true"
 [L]ASTATUS = fmet this.ASETATTRIBUTE([L]CURPRO,"$isLoaded","true")
Endif
[L]ARULE = "GET" : [L]ACTION = "GET" : Gosub ACTION From ASYRSUB
Return

$SET_DESLNG
If fmet this.AGETATTRIBUTE("DESLNG","$isLoaded")<>"true" or [L]_AOLDVAL<>this.DESLNG
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_DESLNG
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If fmet this.AGETATTRIBUTE("DESLNG","$isLoaded")<>"true" or [L]_AOLDVAL<>this.DESLNG
 Gosub PROPAGATE_DESLNG
Endif
Return

$INIT_DESLNG
Gosub DECLARE_VAR From WMC0PROJET
[L]CURPRO = "DESLNG"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_DESLNG
Gosub DECLARE_VAR From WMC0PROJET
[L]CURPRO = "DESLNG"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_DESLNG                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_DESLNG                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_DESLNG
[L]CURPRO = "DESLNG"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & len(this.DESLNG)=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_DESLNG
[L]CURPRO = "DESLNG"
Return

$_AOTHERS_DESLNG
[L]CURPRO = "DESLNG"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_DESLNG
[L]CURPRO = "DESLNG"
Return

$PROPAGATE_DESLNG
this.isReadonly = 0
[L]CURPRO = "DESLNG"
[L]ASTATUS = fmet this.ASETATTRIBUTE([L]CURPRO,"$isLoaded","true")
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_DESLNG
Gosub DECLARE_VAR From WMC0PROJET
[L]CURPRO = "DESLNG"
$_LNKPRO_DESLNG
Local Tinyint _EXI : [L]_EXI=1
Gosub READ_EXI_DESLNG From WMC0PROJET
[L]ASTATUS = fmet this.ASETATTRIBUTE("DESLNG","$isLobFound",func ASYRSUB.BOOLEAN_TO_SYR([L]_EXI+1))
Return


