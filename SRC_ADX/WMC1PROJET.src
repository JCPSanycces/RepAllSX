####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : PRJ Project ( Field PRJ 15)
####################################################################

$SET_PRJ
If [L]_AOLDVAL<>this.PRJ
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_PRJ
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.PRJ
 Gosub PROPAGATE_PRJ
Endif
Return

$INIT_PRJ
Gosub DECLARE_VAR From WMC0PROJET
[L]CURPRO = "PRJ"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_PRJ
Gosub DECLARE_VAR From WMC0PROJET
[L]CURPRO = "PRJ"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_PRJ                   : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_PRJ                   : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_PRJ
[L]CURPRO = "PRJ"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.PRJ,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_PRJ
[L]CURPRO = "PRJ"
If vireblc(this.PRJ,2)<>vireblc(format$("K:15c",this.PRJ),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_PRJ
[L]CURPRO = "PRJ"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_PRJ
[L]CURPRO = "PRJ"
Return

$PROPAGATE_PRJ
this.isReadonly = 0
[L]CURPRO = "PRJ"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_PRJ
Gosub DECLARE_VAR From WMC0PROJET
[L]CURPRO = "PRJ"
$_LNKPRO_PRJ
Return

$_ALOADATTRIBUTE_PRJ
[L]ASTATUS = fmet this.ASETATTRIBUTE("PRJ","$isMandatory","true")
Return


