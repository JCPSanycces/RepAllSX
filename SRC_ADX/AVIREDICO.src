#<AdxTL>@(#)11.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("ADC",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------#
# Suppression des traitements sans .adx
#----------------------------------------------#

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "EXEC"     : Gosub EXEC
Endcase
Return

$INIT
Local Mask ADCX [DIA]
Local Integer I , OK
Local Decimal TAILLE , PROPRIO
Local Date    DATMOD
Local Char    HREMOD(10) , IDUSR(50) , ORDRE(250)
Local Char    TRAIT(GLONADC)(1..30000)
Local Integer NBTRT
ORDRE = adxmac(0)+'@lsadx -a '+nomap-' TRT adx'
Local File (TRT(GLONADC)) From System ORDRE As [TRT_]
Raz [M:DIA]
NBTRT = 0
For [TRT_]
 OK = ([TRT_]TRT<"W")
 OK *= (left$([TRT_]TRT,3)<>"SPE")
 OK *= (!find(right$([TRT_]TRT,len([TRT_]TRT)-2),"STD","SPE","SPV") or !find(left$([TRT_]TRT,4),"CNSX","CNSY","CNSZ"))
 OK *= (left$([TRT_]TRT,3)<>"CNS" or right$([TRT_]TRT,len([TRT_]TRT)-2)<>"SPE")
 OK *= (!find(left$([TRT_]TRT,4),"SUBX","SUBY","SUBZ","IMPX","IMPY","IMPZ","FUNX","FUNY","FUNZ"))
 #OK += (GPRODUIT=-1 & [TRT_]TRT<>"" & left$([TRT_]TRT,1)<>"W")
 If OK
  If NBTRT<dim(TRAIT)
   NBTRT += 1
   TRAIT(NBTRT) = [TRT_]TRT
  Endif
 Endif
Next TRT_
For [ADC]ADC0
 OK = ([F:ADC]CODTRT<"W")
 OK *= (left$([F:ADC]CODTRT,3)<>"SPE")
 OK *= (!find(right$([F:ADC]CODTRT,len([F:ADC]CODTRT)-2),"STD","SPE","SPV") or !find(left$([F:ADC]CODTRT,4),"CNSX","CNSY","CNSZ"))
 OK *= (left$([F:ADC]CODTRT,3)<>"CNS" or right$([F:ADC]CODTRT,len([F:ADC]CODTRT)-2)<>"SPE")
 OK *= (!find(left$([F:ADC]CODTRT,4),"SUBX","SUBY","SUBZ","IMPX","IMPY","IMPZ","FUNX","FUNY","FUNZ"))
 #OK += (GPRODUIT=-1 & [F:ADC]CODTRT<>"" & left$([F:ADC]CODTRT,1)<>"W")
 OK *= (!find([F:ADC]CODTRT,TRAIT(1..NBTRT)))
 If OK
  [M]NBLIG += 1
  [M]CODTRT([M]NBLIG-1) = [F:ADC]CODTRT
  [M]MODULE([M]NBLIG-1) = [F:ADC]MODULE
  [M]USR([M]NBLIG-1)    = [F:ADC]CREUSR-"("+format$(GFMD,[F:ADC]CREDAT)+")"
  [M]DES([M]NBLIG-1)    = [F:ADC]DES
  If [M]NBLIG>=dim([M]CODTRT) : Break : Endif
 Endif
Next ADC
Affzo
Return

$EXEC
# Voulez-vous réellement supprimer ces traitements du dictionnaire
Call AVERTIR(mess(199,139,1),OK) From GESECRAN
If OK<>2 : FIN =1 : Return : Endif 
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [ADC]
 For nolign=1 To [M]NBLIG
  Call DEL([M]CODTRT(nolign-1)) From SUBADC
  If GOK<>1 : Break : Endif
 Next nolign
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return
