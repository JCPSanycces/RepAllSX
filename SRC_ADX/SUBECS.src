#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
## Etiquette ajoutée par le superviseur (Objet ECS) 10/02/2015 11:21:40 (SR)
######################################################################################
$ACTION
Case ACTION
  When "OUVRE"    : Gosub OUVRE
  When "FILTRE"   : Gosub FILTRE
  When "RAZCRE"   : Gosub RAZCRE
  When "SETBOUT"  : Gosub SETBOUT
  When "LIENS"    : Gosub LIENS
  When "LIENS2"   : Gosub LIENS2
  When "VERIF_CRE": Gosub VERIF_CRE
  When "INICRE"   : Gosub INICRE
  When "CREATION" : Gosub CREATION
  When "APRES_CRE": Gosub APRES_CRE
  When "VERIF_MOD": Gosub VERIF_CRE
  When "DEBUT_MOD": Gosub DEBUT_MOD
  When "APRES_MOD": Gosub APRES_CRE
  When "ABANDON"  : Gosub ABANDON
  When "VERF_ANU" : Gosub VERF_ANU
  When "ANNULE"   : Gosub ANNULE
  When "FERME"    : Gosub FERME   # Issue 110585 - 2015-08-27 by SR : Restore GFLTITM
  When Default
Endcase
Return

####################################
$OUVRE
# Issue 110585 - 2015-08-27 by SR
Local Char WFLTITM(GLONITM)
If dim(GFLTITM)>0 : WFLTITM = GFLTITM : Endif
#--- TS
If dim(SAVCLE1)>0 & SAVCLE1<>""
   If dim(GFLTITM)>0
      GFLTITM = SAVCLE1
   Endif
Endif
Return
####################################
#---

$FILTRE
If dim(GFLTITM)>0 & GFLTITM<>""
   FILTSUP = "ITMREF = GFLTITM"
Endif
Return

####################################
$RAZCRE
If [M:ECS1]NBLIG = 0 & dim(GFLTITM)>0 & GFLTITM<>""
   [M:ECS1]ITMREF = GFLTITM
   If [F:ITM]CFGITMREF <> GFLTITM
    Read [F:ITM]ITM0 = [M:ECS1]ITMREF
    If fstat : Raz [F:ITM] : Endif
   Endif
   [M:ECS1]ECCMAJ = [F:ITM]ECCMAJ
   [M:ECS1]ECCSTO = [F:ITM]ECCSTO
Endif
Return

####################################
$SETBOUT
If dim(GFLTITM)>0 & GFLTITM<>""
   Filter [F:ECS] Where ITMREF = GFLTITM
   Look [F:ECS]ECS0 First
   Filter [F:ECS]
   If !fstat : Call VIREBOUT(CHAINE,"C") From GOBJET : Endif
Endif

If CLECUR
  If [F:ITM]ITMREF <> [M:ECS1]ITMREF
    Read [F:ITM]ITM0 = [M:ECS1]ITMREF
    If fstat : Raz [F:ITM] : Endif
  Endif
  If [F:ITM]ECCSTO < 2 : Call VIREBOUT (CHAINE,"A") From GOBJET : Endif
Endif
Return
####################################
$LIENS
# just for the first record
If nolign = 1
  Read [F:ITM]ITM0 = [M:ECS1]ITMREF
  If fstat : Raz [F:ITM] : Endif
  [M:ECS1]ECCMAJ = [F:ITM]ECCMAJ
  [M:ECS1]ECCSTO = [F:ITM]ECCSTO
Endif
[M:ECS1]CREFLG(nolign-1)     = 1
Call LECTEXTRA([M:ECS1]ECCDESAXX(nolign-1),"ECCSTA","ECCDESAXX",[F:ECS]ITMREF,[F:ECS]ECCVALMAJ) From ATEXTRA
Call LECTEXTRA([M:ECS1]ECCSHOAXX(nolign-1),"ECCSTA","ECCSHOAXX",[F:ECS]ITMREF,[F:ECS]ECCVALMAJ) From ATEXTRA
[M:ECS1]SAVDESAXX(nolign-1)  = [M:ECS1]ECCDESAXX(nolign-1)
[M:ECS1]SAVSHOAXX(nolign-1)  = [M:ECS1]ECCSHOAXX(nolign-1)
If [M:ECS1]TEX(nolign-1) <> ""
   [M:ECS1]TXTICO(nolign-1) = "132"
Else
   [M:ECS1]TXTICO(nolign-1) = ""
Endif
Return

###################################
$LIENS2
Sorta [M:ECS1]NBLIG [M:ECS1]NBLIG Order By [M:ECS1]ECCVALMAJ(indice) Desc
For nolign = 1 To  [M:ECS1]NBLIG
  Gosub AFFECT_FORMAT
Next
# If GFLTITM loaded and versions already exist, no access to ITMREF field
If dim(GFLTITM)>0 & GFLTITM<>"" & GREP <> "C" & [M:ECS1]NBLIG <> 0
  Grizo [M:ECS1]ITMREF
Endif
Return

####################################
$VERIF_CRE
Local Integer I,J
# find for lines without Major version
J = sigma(I=0,[M:ECS1]NBLIG-1,[M:ECS1]ECCVALMAJ(I) = "")
If J
  # Des lignes existent sans numéro de version
  GMESSAGE=mess(187,210,1) : GERR=1 : OK=0 : Return
Endif
Return

####################################
$INICRE
Gosub CHARG_TEX
# Init fields existent line, Minor version Icon and Text Icon
[M:ECS1]CREFLG(nolign-1) = 1
If [M:ECS1]ECCSTO = 3
  [M:ECS1]ECCVAL(nolign-1) = "210"
Else
  [M:ECS1]ECCVAL(nolign-1) = ""
Endif
If [M:ECS1]TEX(nolign-1) <> ""
   [M:ECS1]TXTICO(nolign-1) = "132"
Else
   [M:ECS1]TXTICO(nolign-1) = ""
Endif
Return

####################################
$CREATION
#Translated texts
Gosub MAJ_AXX
# create ECCVAL record if minor version not managed
If [M:ECS1]ECCSTO = 2
  Gosub CREATE_ECCVAL
Endif
Return

####################################
$APRES_CRE
Gosub LIENS2
If ! GIMPORT
  Affzo [M:ECS1]1-99
Endif
Gosub SETBOUT From GOBJSUB
Return

####################################
$DEBUT_MOD
#Supressed lines : Supress translated texts,CLOB and Minor versions
For [ECS] Where ITMREF = [M:ECS1]ITMREF
 If !find([F:ECS]ECCVALMAJ,[M:ECS1]ECCVALMAJ(0..[M:ECS1]NBLIG-1))
    Delete [AXX] Where CODFIC="ECCSTA" & IDENT1=[F:ECS]ITMREF & IDENT2=[F:ECS]ECCVALMAJ
    If fstat=1 | fstat>5
     GOK=0 : Call RSTA("AXX",[F:ECS]ITMREF-[F:ECS]ECCVALMAJ) From GLOCK : Break
    Endif
    Call SUP_CLOB([F:ECS]TEX,GBIDI1) From TRTX3TEX
    If [M:ECS1]ECCSTO = 2
      # Delete all Type 4 ECCVAL records : all verifications have been done on Suppress button
      Delete [F:EVL] Where ITMREF = [F:ECS]ITMREF & ECCVALMAJ = [F:ECS]ECCVALMAJ & ECCTYP = 4
    Endif
 Endif
Next
If GOK<1 : Return : Endif
Return

####################################
$VERF_ANU
Local Integer I
For I =0 To [M:ECS1]NBLIG-1
    Gosub TEST_ANU
    If OK = 0 : Break : Endif
Next
Return

####################################
$ANNULE
Local Integer I
#CLOB
For I=0 To [M:ECS1]NBLIG-1
  Call SUP_CLOB([M:ECS1]TEX(I),GBIDI1) From TRTX3TEX
Next I
#-----
Call RAZ_CLOB From ACLOB
#Translated texts
Delete [AXX] Where CODFIC="ECCSTA" & IDENT1=[M:ECS1]ITMREF
# Delete all Type 4 ECCVAL records: all verifications have been done on VERF_ANU
If [M:ECS1]ECCSTO = 2
  Delete [F:EVL] Where ITMREF = [M:ECS1]ITMREF & ECCTYP = 4
Endif
Return

####################################
$ABANDON
Local Integer I
#CLOB and Translated texts for new lines not recorded yet
For I=0 To [M:ECS1]NBLIG-1
  If [M:ECS1]CREFLG(I)=0
    Call SUP_CLOB([M:ECS1]TEX(I),GBIDI1) From TRTX3TEX

    Delete [AXX] Where CODFIC="ECCSTA" & IDENT1=[M:ECS1]ITMREF & IDENT2 = [M:ECS1]ECCVALMAJ(nolign-1)
  Endif

Next I
#-----
Call RAZ_CLOB From ACLOB

Return

# Issue 110585 - 2015-08-27 by SR : Restore GFLTITM
####################################
$FERME
If dim(GFLTITM)>0 : GFLTITM = WFLTITM : Endif
Return

#----------------------------------------------------------------------------------#
$AFFECT_FORMAT
Case [M:ECS1]ECCSTA(nolign-1)
  When 3
     # Exemption flag accessible
     Actzo [M:ECS1]EXNFLG(nolign-1)
     If [M:ECS1]EXNFLG(nolign-1) = 2
        Actzo [M:ECS1]EXNDAT(nolign-1)
     Else
        Grizo [M:ECS1]EXNDAT(nolign-1)
     Endif
     # suspended flag not accessible
     Grizo [M:ECS1]SPSFLG(nolign-1)
  When Default
   # suspended flag accessible
    Actzo [M:ECS1]SPSFLG(nolign-1)
    # Exemption flag not accessible
    Grizo [M:ECS1]EXNFLG(nolign-1)
    Grizo [M:ECS1]EXNDAT(nolign-1)
Endcase
If [M:ECS1]ECCSTO = 3
  [M:ECS1]ECCVAL(nolign-1) = "210"
Else
  [M:ECS1]ECCVAL(nolign-1) = "191"
Endif
Return
#-----------------------------------------------------------------------------------#
$CHARG_TEX
If [M:ECS1]TEX(nolign-1)<>""
    Call CRE_CLOB([M:ECS1]TEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
Endif
Return

#-----------------------------------------------------------------------------------#
$MAJ_AXX
If ([M:ECS1]SAVDESAXX(nolign-1)<>[M:ECS1]ECCDESAXX(nolign-1)) | [M:ECS1]CREFLG(nolign-1) = 0
  Call MAJTEXTRA([M:ECS1]ECCDESAXX(nolign-1),"ECCSTA","ECCDESAXX",[M:ECS1]ITMREF,[M:ECS1]ECCVALMAJ(nolign-1)) From ATEXTRA
Endif
If ([M:ECS1]SAVSHOAXX(nolign-1)<>[M:ECS1]ECCSHOAXX(nolign-1)) | [M:ECS1]CREFLG(nolign-1) = 0
  Call MAJTEXTRA([M:ECS1]ECCSHOAXX(nolign-1),"ECCSTA","ECCSHOAXX",[M:ECS1]ITMREF,[M:ECS1]ECCVALMAJ(nolign-1)) From ATEXTRA
Endif
Return

#-----------------------------------------------------------------------------------#
$CREATE_ECCVAL
Local Integer WSTA, WECCSEQ
Local Char    WMESSAGE (80)
# Is a type 4 record already exists for this version ?
Filter [F:EVL] Where ITMREF = [F:ECS]ITMREF & ECCVALMAJ = [F:ECS]ECCVALMAJ & ECCTYP = 4
Look [F:EVL]EVL0 First
Filter [F:EVL]
# If no type 4 record exists for this version
If fstat
  # Find the new sequence number  to use for this Item
  Filter [EVL] Where ITMREF=[M:ECS1]ITMREF  & ECCTYP=4
  Read [EVL]EVL0 Last
  Filter [F:EVL]
  If fstat
     WECCSEQ = 1
  Else
    WECCSEQ = [F:EVL]ECCSEQ+1
  Endif
  Filter [EVL]
  Raz [F:EVL]
  [F:EVL]       = [F:ECS]
  [F:EVL]ECCSEQ = WECCSEQ
  [F:EVL]USESTA = 2
  [F:EVL]EXNFLG = 1
  [F:EVL]ECCTYP = 4
  Write [F:EVL]
  If fstat GOK=0 : Call FSTA("EVL") From GLOCK : Return : Endif
Endif
Return

#-----------------------------------------------------------------------------------#
$TEST_ANU
#----------------------------------------------------#
# Test for line suppression                          #
#----------------------------------------------------#
# If management by Major and Minor version : No record in ECCVAL
If [M:ECS1]ECCSTO = 3
  Filter [F:EVL] Where ITMREF = [M:ECS1]ITMREF & ECCVALMAJ = [M:ECS1]ECCVALMAJ(I)
  Look [F:EVL]EVL0 First
  Filter [F:EVL]
  If !fstat
     #Des versions mineure existent  : Suppression impossible
     GMESSAGE = [M:ECS1]ECCVALMAJ(I) - mess(211,187,1)
     OK = 0
     Return
  Endif
Else
# If management only by major version : Only Type 4 records in ECCVAL
  Filter [F:EVL] Where ITMREF = [M:ECS1]ITMREF & ECCVALMAJ = [M:ECS1]ECCVALMAJ(I) & ECCTYP <> 4
  Look [F:EVL]EVL0 First
  Filter [F:EVL]
  If !fstat
     #Des versions mineure existent  : Suppression impossible
     GMESSAGE = [M:ECS1]ECCVALMAJ(I) - mess(211,187,1)
     OK = 0
     Return
  Endif
Endif

# Not USED in STOLOT
Filter [STL] Where ITMREF = [M:ECS1]ITMREF & ECCVALMAJ = [M:ECS1]ECCVALMAJ(I)
Look [STL]STL0 First
Filter [STL]
If !fstat
   # Version utilisée dans au moins un lot : Suppression impossible
   GMESSAGE =  [M:ECS1]ECCVALMAJ(I) - mess(207,187,1)-mess(217,187,1)
   OK = 0
   Return
Endif

# Not USED in ORDERS
Filter [ORD] Where ITMREF = [M:ECS1]ITMREF & ECCVALMAJ = [M:ECS1]ECCVALMAJ(I)
Look [ORD]ORD0 First
Filter [ORD]
If !fstat
   # Version utilisée dans au moins un document : Suppression impossible
   GMESSAGE = [M:ECS1]ECCVALMAJ(I) - mess(208,187,1)-mess(217,187,1)
   OK = 0
   Return
Endif
Return


#------------------------------------- Screen management ----------------------------

################################ ITMREF ##############################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

# Coming from Item Management function :  "New" button Mandatory
If dim(GFLTITM)>0 & GFLTITM<>"" & GREP <> "C"
  GMESSAGE=mess(218,194,1)
  mkstat = 1
  End
Endif

# If records already exist
If !clalev([F:ECS1]) : Local File ECCSTA [ECS1] : Endif
Filter [F:ECS1] Where ITMREF = VALEUR
Look [F:ECS1]ECS0 First
Filter [F:ECS1]
If !fstat : End : Endif


Read [F:ITG]ITG0 = "";[F:ITM]TCLCOD
If fstat : Raz [F:ITG] : Endif
If [F:ITG]PURFLG <> 2
   GMESSAGE =  mess(70,197,1) #Article non acheté
   mkstat = 1
   End
Endif
If [F:ITM]ECCSTO < 2
   # Article non géré en version Stock
   GMESSAGE = VALEUR+"\"+mess(215,187,1)
   mkstat = 2
   End
Endif

End

#-------------------------------
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:ECS1]ECCMAJ = [F:ITM]ECCMAJ
[M:ECS1]ECCSTO = [F:ITM]ECCSTO
End


############################## NBLIG #################################################
Subprog IB_NBLIG
If [F:ITM]ITMREF <> [M:ECS1]ITMREF
  Read [F:ITM]ITM0 = [M:ECS1]ITMREF
  If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]ECCSTO < 2 | [M:ECS1]ECCVALMAJ(nolign-1) = ""  Raz GBOUT1 : Endif      : # Text
If GREP <> "" | [M:ECS1]ECCSTO = 2 | [M:ECS1]ECCVALMAJ(nolign-1) = ""
 Raz GBOUT2                 : # Minor versions
Endif
End


#-------------------------------
Subprog C_NBLIG
Local Integer I, OK

If status = 20 : End : Endif
If [F:ITM]ITMREF <> [M:ECS1]ITMREF
  Read [F:ITM]ITM0 = [M:ECS1]ITMREF
  If fstat : Raz [F:ITM] : Endif
Endif
# Article non géré en version Stock
If [F:ITM]ECCSTO < 2
   GMESSAGE = mess(215,187,1)
   mkstat = 2
   End
Endif
OK = 1
If    status=65             : # Simple suppression
      I=nolign-1
      Gosub TEST_ANU
      If OK = 0 : mkstat = 2 : Endif
Elsif status=68 | status=83 : # Multiple suppression
      For I=nolign-1 To nolign1-1
          Gosub TEST_ANU
          If OK = 0 : mkstat = 2 : Break : Endif
      Next
Endif
End


#-------------------------------
Subprog APRES_NBLIG
Local Char    WMESSAGE(80)
Local Integer WSTA
Local Integer NOL : NOL = nolign-1
Local Char    WLASTECC(GLONECS)
Local Integer WRECUP
#-----  escape -----#
If status=6 | status=7 | status=27 | status=28 | [M:ECS1]ECCSTA(nolign-1) < 1
 Gosub AFFECT_FORMAT
 End
Endif
#if version non loaded
If [M:ECS1]ECCMAJ <> "" & [M:ECS1]ECCVALMAJ(NOL) =""
    # What is the last version number ?
    WLASTECC = max([M:ECS1]ECCVALMAJ(0..[M:ECS1]NBLIG-1))
   # Sequence number affectation
   Raz WSTA, WMESSAGE,WRECUP
   While WRECUP <> 2
       Call CALCUL([M:ECS1]ECCMAJ, WLASTECC, [M:ECS1]ECCVALMAJ(NOL), WMESSAGE, WSTA) From SUBICV
       If WSTA <> 0
          GMESSAGE = WMESSAGE
          mkstat   = 1
          Break
       Endif
       Raz GMESSAGE
       Call UNICITE([M:ECS1]ECCVALMAJ(NOL),[M:ECS1]ECCVALMAJ(0..[M:ECS1]NBLIG-1)) From OBJDIV
       If GMESSAGE <> ""
          WLASTECC = [M:ECS1]ECCVALMAJ(NOL)
          Raz GMESSAGE
       Else
          WRECUP = 2
       Endif
   Wend
Endif
If [M:ECS1]ECCVALMAJ(NOL) = ""
   GMESSAGE = "ECCVALMAJ" - mess(10,123,1)
   mkstat = 1
   End
Endif
If !GIMPORT : Affzo [M:ECS1]ECCVALMAJ(NOL) : Endif
End

############################# TXTICO #################################################
Subprog AS_TXTICO(VALEUR)
Variable Char    VALEUR()
If [M:ECS1]ECCVALMAJ(nolign-1) = "" : mkstat = 2 : Endif
End


########################### ECCVAL ###################################################
# Before Minor Versions Action
Subprog AS_ECCVAL(VALEUR)
Variable Char    VALEUR()
If [M:ECS1]CREFLG(nolign-1) <> 1  | [M:ECS1]ECCSTO = 2
  mkstat = 2
Endif
End


########################## ECCVALMAJ #################################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
# if no Major counter , field must not be empty
If [M:ECS1]ECCMAJ = "" & VALEUR = ""
   GMESSAGE = "ECCVALMAJ" - mess(10,123,1)
   mkstat = 1
   End
Endif
If VALEUR <> ""
  Call UNICITE(VALEUR,[M:ECS1]ECCVALMAJ(0..[M:ECS1]NBLIG-1)) From OBJDIV
Endif
End


######################### ECCSTA #####################################################
Subprog C_ECCSTA(VALEUR)
Variable Integer VALEUR
Local    Integer NOL : NOL = nolign-1
If VALEUR = 4 & [M:ECS1]ECCVALMAJ(NOL) <> ""
  # Not USED in STOLOT
  Filter [STL] Where ITMREF = [M:ECS1]ITMREF & ECCVALMAJ = [M:ECS1]ECCVALMAJ(NOL)
  Look [STL]STL0 First
  Filter [STL]
  If !fstat
     # Version utilisée dans au moins un lot : modification impossible
     GMESSAGE =  [M:ECS1]ECCVALMAJ(NOL) - mess(207,187,1)-mess(218,187,1)
     mkstat = 1
     ENR
  Endif

  # Not USED in ORDERS
  Filter [ORD] Where ITMREF = [M:ECS1]ITMREF & ECCVALMAJ = [M:ECS1]ECCVALMAJ(NOL)
  Look [ORD]ORD0 First
  Filter [ORD]
  If !fstat
     # Version utilisée dans au moins un document : modification impossible
     GMESSAGE = [M:ECS1]ECCVALMAJ(NOL) - mess(208,187,1)-mess(218,187,1)
     mkstat = 1
     End
  Endif
Endif
End

#-----------------------------------------------
Subprog AM_ECCSTA(VALEUR)
Variable Integer VALEUR
# to be activated
If VALEUR = 4
  # Exemption flag not accessible
  [M:ECS1]EXNFLG(nolign-1) = 1
  Raz[M:ECS1]EXNDAT(nolign-1)
  Grizo [M:ECS1]EXNFLG(nolign-1)
  Grizo [M:ECS1]EXNDAT(nolign-1)
  # suspended flag not accessible
  [M:ECS1]SPSFLG(nolign-1) = 1
  Grizo [M:ECS1]SPSFLG(nolign-1)
#Stopped Version
Elsif VALEUR = 3
   # Exemption flag accessible
   [M:ECS1]EXNFLG(nolign-1) = 1
   Actzo [M:ECS1]EXNFLG(nolign-1)
   # suspended flag not accessible
   [M:ECS1]SPSFLG(nolign-1) = 1
   Grizo [M:ECS1]SPSFLG(nolign-1)
#Active or Prototype Version
Else
 # suspended flag accessible
  [M:ECS1]SPSFLG(nolign-1) = 1
  Actzo [M:ECS1]SPSFLG(nolign-1)
  # Exemption flag not accessible
  [M:ECS1]EXNFLG(nolign-1) = 1
  Raz[M:ECS1]EXNDAT(nolign-1)
  Grizo [M:ECS1]EXNFLG(nolign-1)
  Grizo [M:ECS1]EXNDAT(nolign-1)
Endif
If !GIMPORT : Affzo [M:ECS1]EXNFLG(nolign-1),EXNDAT(nolign-1), SPSFLG(nolign-1) : Endif
End


###################### EXNFLG ########################################################
Subprog AM_EXNFLG(VALEUR)
Variable Integer VALEUR
#Exemption date allowed Only if Exemption flag
If VALEUR = 1
  Diszo [M:ECS1]EXNDAT(nolign-1)
  # Issue 112413 - 2015-11-10 by MAE : Raz de la date de dérogation
  [M:ECS1]EXNDAT(nolign-1) = AVOID.ADATE
Else Actzo [M:ECS1]EXNDAT(nolign-1) : Endif
If !GIMPORT : Affzo [M:ECS1]EXNDAT(nolign-1) : Endif
End

###################### EXNDAT ########################################################
Subprog AS_EXNDAT(VALEUR)
Variable Date    VALEUR
If [M:ECS1]EXNFLG(nolign-1) <> 2 : mkstat = 2 : Endif
End


#-------------------------------
Subprog C_EXNDAT(VALEUR)
Variable Date    VALEUR
Local Integer OK : OK=2
If VALEUR=[0/0/0]
    mkstat = 1 : GMESSAGE = mess(10,123,1)
Elsif VALEUR < date$
    # Date inférieure à la date du jour : voulez-vous continuer ?
    Call AVERTIR(mess(65,194,1)-":"-mess(205,100,1),OK) From GESECRAN
    If OK=1 mkstat=2 : End : Endif
Endif
End

