$MOTIVE

If APPLI = adxmother(0) : Return : Endif

If dim ([L]MOTIVE) > 0 & func AFNC.ACTIV("KPO")>0
  If !clalev([BREN]) : Local File = APPLI+".BCKITOREN" [BREN] : Endif

  [F:BREN]DOSSIER = APPLI
  [F:BREN]FICHIER = LISTEFIC(I)
  [F:BREN]INTMOT = [L]MOTIVE
  [F:BREN]SEQID = uniqid([F:BREN])

  Write [F:BREN]
  Close Local File [BREN]
Endif

Return
