#<AdxTL>@(#)2.0.0.0 $Revision$
GFONCTION="EDITBLA"
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","PRTBLA","",1,"") From GTRAITE
End

$ACTION
Case ACTION
 When "DEBUT"     : Gosub DEBUT
 When "INIT"      : Gosub INIT
 When "EXEC"      : Gosub EXEC
 When "BOUTON"    : Gosub BOUTON
 When "SEL_LISTE" : Gosub SEL_LISTE
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "FIN_TABLE" : Gosub FIN_TABLE
 When "OK"        : Gosub OK
Endcase
Return

$DEBUT
Local Integer OBLIG
If GOK<>2
 Raz [M:EDA]
 [M:EDA]CPY    = GDEFSOC
 Call SETMAINREF([M:EDA]CPY,GTYPGEN,GTYPANA) From CPTDIV
 [M:EDA]LEDTYP = GTYPANA
 [M:EDA]NBPER  = 1
 [M:EDA]DATDEB(0) = GDATEDEB
 [M:EDA]DATFIN(0) = GDATEFIN
 [M:EDA]NBCOL     = 6
 For I=1 To 6
  [M:EDA]TYPCOL(I-1) = I+1
  [M:EDA]PERCOL(I-1) = 1
 Next I
 [M:EDA]COURANA = 1
 [M:EDA]COURBUD = 1
 [M:EDA]SENS    = 1
 [M:EDA]DETSIT  = 1
 [M:EDA]ANOUVO  = 2
 [M:EDA]CLOTURE = 2
 [M:EDA]DIVISE  = 1
 Call DEFIMP("BALANA",GUSER,"",[M:EDA]IMPRIME,OBLIG) From IMPRIME
 Call LECMEMO("STD","[M:EDA]","bla") From GMEMO
 If [M:EDA]BUD<>""
  Call LECTURE("BUP",[M:EDA]BUD,"") From CONTOBJ
  [M]DEVBUD = [F:BUP]CUR
 Endif
 If [M:EDA]CPY<>"" & [M:EDA]LEDTYP>0
  Call LEDCUR([M:EDA]CPY,[M:EDA]LEDTYP)
  [M:EDA]DEVIMP = [M:EDA]CUR
 Endif
Endif
Gosub GRISE
Affzo
GOK = 1
Return

$INIT
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:DIE])=0 : Local File GDIE       [DIE] : Endif
If clalev([F:GYM])=0 : Local File GACCPYM    [GYM] : Endif
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:CYM])=0 : Local File GCCEPYM    [CYM] : Endif
If clalev([F:CRY])=0 : Local File GCCEGRUPYM [CRY] : Endif
If clalev([F:BUP])=0 : Local File BUDPAR     [BUP] : Endif
If clalev([F:BUV])=0 : Local File BUDVER     [BUV] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
If clalev([F:ACN])=0 : Local File ACONSULT   [ACN] : Endif
Local Mask EDITBLA [EDA]
## MB/CP/PP
If BOITE=""
 GOK = 0
 Gosub DEBUT
 GSTATUT = GSTAOK
Endif
## MB/CP/PP
Return

$EXEC
If GSTATUT<>GSTAOK
 Return
Endif
If [M:EDA]DESTIN=1
 Local Integer CALCUL : CALCUL = 0
 Gosub IMPRIME
Else
 Gosub CONSULT
Endif
Return

$BOUTON
If BOUT="2"
 Gosub GRISE
Endif
Return

$GRISE
If [M:EDA]BUD=""
 Grizo VER
Else
 Actzo VER
Endif
If [M:EDA]DEVIMP=[M:EDA]CUR or [M:EDA]DEVIMP=[M:EDA]DEVORG
 [M:EDA]COURANA = 1
 Affzo COURANA
 Grizo COURANA
 Effzo LIBCUR
Else
 Actzo COURANA
Endif
If [M:EDA]BUD=""
 [M:EDA]COURBUD = 1
 Affzo COURBUD
 Grizo COURBUD
 Effzo LIBBUD
Else
 Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
 If [F:BUP]CUR=[M:EDA]DEVIMP
  [M:EDA]COURBUD = 1
  Affzo COURBUD
  Grizo COURBUD
  Effzo LIBBUD
 Else
  Actzo COURBUD
 Endif
Endif
If [M:EDA]DESTIN=2
 Grizo IMPRIME
Else
 Grizo ECRAN
Endif
If [M:EDA]TAXE=2
 Grizo AAXE
Else
 Actzo AAXE
Endif
Return

$OK
If [M]NBAXE=0
 GERR = 1
 # Critères incomplets: niveaux de totalisation vides
 GMESSAGE = mess(112,103,1)
 FIN = 0
Endif

Local Integer MAXCLE, MAXLNK, NBLNK, NBCLE, GROUPE, GRPSOC
MAXCLE = 16 : # Nb de parties de clé
MAXLNK = 12 : # Nb de tables dans un link

NBLNK  = 3  : # Comptes GAC, Code accès ACC, Autorsite AFF
NBCLE  = 2  : # Sites FCY, Devises CUR

GROUPE = 0
GRPSOC = 0
Call LEC_CPY([M]CPY) From CPTLEC
If [F:CPY]CPYLEGFLG<>2
 GROUPE = 1
 Read [AGF]AGF0 = [M]CPY
 If [F:AGF]FLGCPY=2
  GRPSOC = 1
 Endif
Endif

If GROUPE & !GRPSOC
 NBLNK += 1 : # si groupe de société
Endif
For I=0 To [M]NBAXE-1
 If [M]TYP(I)=3
  NBLNK += 1
  NBCLE += 1
 Elsif [M]PYRSEC(I)<>""
  NBCLE += 2
  NBLNK += 1
 Else
  NBCLE += 1
 Endif
Next I
If NBCLE>MAXCLE or NBLNK>MAXLNK
 GMESSAGE = func AFNC.MES4(mess(179,104,1), num$(NBCLE), num$(MAXCLE), num$(NBLNK), num$(MAXLNK))+" - "+mess(180,104,1)
 GERR=1 : FIN = 0
Endif
Return

###################################################################################
## Impression état BALANA
###################################################################################
$IMPRIME
Local Char    TBPAR(20)(1..200) , TBVAL(50)(1..200)
Local Integer NBPAR
NBPAR = 0
NBPAR += 1 : TBPAR(NBPAR) = "societe"        : TBVAL(NBPAR) = [M:EDA]CPY
NBPAR += 1 : TBPAR(NBPAR) = "referentiel"    : TBVAL(NBPAR) = num$([M:EDA]LEDTYP)
NBPAR += 1 : TBPAR(NBPAR) = "sitedeb"        : TBVAL(NBPAR) = [M:EDA]FCYDEB
NBPAR += 1 : TBPAR(NBPAR) = "sitefin"        : TBVAL(NBPAR) = [M:EDA]FCYFIN
NBPAR += 1 : TBPAR(NBPAR) = "nbper"          : TBVAL(NBPAR) = num$([M:EDA]NBPER)
For I=1 To [M:EDA]NBPER
 NBPAR += 1 : TBPAR(NBPAR) = "dat"+num$(I)+"deb" : TBVAL(NBPAR) = [M:EDA]DATDEB(I-1)
 NBPAR += 1 : TBPAR(NBPAR) = "dat"+num$(I)+"fin" : TBVAL(NBPAR) = [M:EDA]DATFIN(I-1)
Next I
NBPAR += 1 : TBPAR(NBPAR) = "budget"         : TBVAL(NBPAR) = [M:EDA]BUD
NBPAR += 1 : TBPAR(NBPAR) = "version"        : TBVAL(NBPAR) = [M:EDA]VER
NBPAR += 1 : TBPAR(NBPAR) = "nbaxe"          : TBVAL(NBPAR) = num$([M:EDA]NBAXE)
#
# 5 niveaux de totalisation sur l'état
#
For I=1 To min(5,[M:EDA]NBAXE)
 NBPAR += 1 : TBPAR(NBPAR) = "typ"+num$(I)          : TBVAL(NBPAR) = num$([M:EDA]TYP(I-1))
 NBPAR += 1 : TBPAR(NBPAR) = "axe"+num$(I)          : TBVAL(NBPAR) = [M:EDA]AXE(I-1)
 NBPAR += 1 : TBPAR(NBPAR) = "sec"+num$(I)+"deb"    : TBVAL(NBPAR) = [M:EDA]SECDEB(I-1)
 NBPAR += 1 : TBPAR(NBPAR) = "sec"+num$(I)+"fin"    : TBVAL(NBPAR) = [M:EDA]SECFIN(I-1)
 NBPAR += 1 : TBPAR(NBPAR) = "pyrsec"+num$(I)       : TBVAL(NBPAR) = [M:EDA]PYRSEC(I-1)
 NBPAR += 1 : TBPAR(NBPAR) = "nivsec"+num$(I)       : TBVAL(NBPAR) = num$([M:EDA]NIVSEC(I-1))
 NBPAR += 1 : TBPAR(NBPAR) = "rngsec"+num$(I)+"deb" : TBVAL(NBPAR) = num$([M:EDA]RNGSECDEB(I-1))
 NBPAR += 1 : TBPAR(NBPAR) = "rngsec"+num$(I)+"fin" : TBVAL(NBPAR) = num$([M:EDA]RNGSECFIN(I-1))
Next I
NBPAR += 1 : TBPAR(NBPAR) = "devorg"         : TBVAL(NBPAR) = [M:EDA]DEVORG
NBPAR += 1 : TBPAR(NBPAR) = "devimp"         : TBVAL(NBPAR) = [M:EDA]DEVIMP
NBPAR += 1 : TBPAR(NBPAR) = "courana"        : TBVAL(NBPAR) = num$([M:EDA]COURANA)
NBPAR += 1 : TBPAR(NBPAR) = "courbud"        : TBVAL(NBPAR) = num$([M:EDA]COURBUD)
For I=1 To [M:EDA]NBCOL
 NBPAR += 1 : TBPAR(NBPAR) = "typcol"+num$(I) : TBVAL(NBPAR) = num$([M:EDA]TYPCOL(I-1))
 NBPAR += 1 : TBPAR(NBPAR) = "percol"+num$(I) : TBVAL(NBPAR) = num$([M:EDA]PERCOL(I-1))
Next I
For I=[M:EDA]NBCOL+1 To 6
 NBPAR += 1 : TBPAR(NBPAR) = "typcol"+num$(I) : TBVAL(NBPAR) = num$(1)
 NBPAR += 1 : TBPAR(NBPAR) = "percol"+num$(I) : TBVAL(NBPAR) = num$(1)
Next I
NBPAR += 1 : TBPAR(NBPAR) = "sens"           : TBVAL(NBPAR) = num$([M:EDA]SENS)
NBPAR += 1 : TBPAR(NBPAR) = "detail_site"    : TBVAL(NBPAR) = num$([M:EDA]DETSIT)
NBPAR += 1 : TBPAR(NBPAR) = "toutaxe"        : TBVAL(NBPAR) = num$([M:EDA]TAXE)
NBPAR += 1 : TBPAR(NBPAR) = "aucaxe"         : TBVAL(NBPAR) = num$([M:EDA]AAXE)
NBPAR += 1 : TBPAR(NBPAR) = "anouveau"       : TBVAL(NBPAR) = num$([M:EDA]ANOUVO)
NBPAR += 1 : TBPAR(NBPAR) = "cloture"        : TBVAL(NBPAR) = num$([M:EDA]CLOTURE)
NBPAR += 1 : TBPAR(NBPAR) = "intcourt"       : TBVAL(NBPAR) = num$([M:EDA]INTCOURT)
If [M:EDA]DIVISE=0
 [M:EDA]DIVISE = 1
Endif
NBPAR += 1 : TBPAR(NBPAR) = "divise"         : TBVAL(NBPAR) = num$([M:EDA]DIVISE)
NBPAR += 1 : TBPAR(NBPAR) = "calcul"         : TBVAL(NBPAR) = num$(CALCUL)
#
# Attention le masque AIMP0 limite le nb de paramètres à 100
#
If NBPAR>100
 Call MESSAGE(mess(131,102,1)) From GESECRAN : # Trop de paramètres
Endif

Call ETAT("BALANA",[M:EDA]IMPRIME,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
If GOK=0
 SAI = 1
Endif
Return

###################################################################################
## Consultation CNSBLA
###################################################################################
$CONSULT
Local Integer NUMREQ
If clalev([F:ARP])=0 : Local File AREPORT [ARP] : Endif
NUMREQ = uniqid([ARP])
Call TEMPON("O") From GESECRAN
Call BALANA("BALANA","BALANA",[M:EDA]CPY,[M:EDA]LEDTYP,[M:EDA]BUD,[M:EDA]VER,[M:EDA]FCYDEB,[M:EDA]FCYFIN
&          ,[M:EDA]NBPER,[M:EDA]DATDEB,[M:EDA]DATFIN
&          ,[M:EDA]NBAXE,[M:EDA]TYP,[M:EDA]AXE,[M:EDA]SECDEB,[M:EDA]SECFIN,[M:EDA]PYRSEC,[M:EDA]NIVSEC,[M:EDA]RNGSECDEB,[M:EDA]RNGSECFIN
&          ,[M:EDA]DEVORG,[M:EDA]DEVIMP,[M:EDA]COURANA,[M:EDA]COURBUD,[M:EDA]TYPCOL,[M:EDA]PERCOL
&          ,[M:EDA]SENS,[M:EDA]DETSIT=2,[M:EDA]TAXE=2,[M:EDA]AAXE=2,[M:EDA]ANOUVO=2,[M:EDA]CLOTURE=2
&          ,[M:EDA]INTCOURT=2,GPROFIL,GFONCTION,GUSER,NUMREQ) From EDITBLA
Call TEMPOFF From GESECRAN
If GOK=0
 SAI = 1 : FIN = 0 : GOK = 2
Else
 PARAM(1) = num$(NUMREQ)
 Call SAISIE_CHAR(VALEUR,PARAM,"WMBLA"+[M:EDA]ECRAN,"CNSBLA","SPECNSBLA") From GSAISIE
 If GOK=2
  SAI = 1 : FIN = 0
 Endif
Endif
Return

######################################################################################
## Ecran EDITBLA
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If [M:EDA]LEDTYP>0
 Call LEDCUR(VALEUR,[M]LEDTYP)
Endif
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
OPTION=3 : # Référentiels flagués 'Analytique'
Call LEDTYP_CHOICE([M:EDA]CPY,OPTION) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Char OCUR(GLONCUR)
OCUR = [M]CUR
Read [CPY]CPY0 = [M]CPY
If [F:CPY]CPYLEGFLG<>2
 [M]LED = ""
 For [FGR]FGR0 Where CPY=[M]CPY
  Read [FCY]FCY0 = [F:FGR]FCY
  Read [CPY]CPY0 = [F:FCY]LEGCPY
  Read [GCM]GCM0 = [F:CPY]ACM
  If [M]LED=""
   If [F:GCM]LED(VALEUR-1)=""
    GMESSAGE = [F:FGR]FCY-":"-mess(105,104,1) : # Référentiel non défini
    mkstat = 2 : Break
   Else
    [M]LED = [F:GCM]LED(VALEUR-1)
    [M]CUR = [F:GCM]CUR(VALEUR-1)
   Endif
  Elsif [M]CUR<>[F:GCM]CUR(VALEUR-1)
   GMESSAGE = [F:FGR]FCY-":"-mess(90,103,1)-"("+[F:GCM]CUR(VALEUR-1)+")" : # Devise incompatible
   mkstat = 2 : Break
  Endif
 Next
 If mkstat : End : Endif
Else
 Read [GCM]GCM0 = [F:CPY]ACM
 If [F:GCM]LED(VALEUR-1)=""
  GMESSAGE = [M]CPY-":"-mess(105,104,1) : # Référentiel non défini
  mkstat = 2 : End
 Endif
 [M]LED = [F:GCM]LED(VALEUR-1)
 [M]CUR = [F:GCM]CUR(VALEUR-1)
Endif
Read [LED]LED0 = [M]LED
[M]COA = [F:LED]COA
If OCUR<>[M]CUR
 Call COURANA([M]CUR,[M]DEVORG,[M]DEVIMP)
 Call COURBUD([M]BUD,[M]DEVBUD,[M]DEVIMP)
Endif
End

Subprog LEDCUR(SOCIETE,TYPREF)
Value Char    SOCIETE
Value Integer TYPREF
Local Char OCUR(GLONCUR)
OCUR = [M]CUR
Read [CPY]CPY0 = SOCIETE
If [F:CPY]CPYLEGFLG<>2
 For [FGR]FGR0 Where CPY=[M]CPY
  Read [FCY]FCY0 = [F:FGR]FCY
  Read [CPY]CPY0 = [F:FCY]LEGCPY
  Read [GCM]GCM0 = [F:CPY]ACM
  Break
 Next
Else
 Read [GCM]GCM0 = [F:CPY]ACM
Endif
If [F:GCM]LED(TYPREF-1)<>""
 [M]LED = [F:GCM]LED(TYPREF-1)
 [M]CUR = [F:GCM]CUR(TYPREF-1)
 Read [LED]LED0 = [M]LED
 [M]COA = [F:LED]COA
 If OCUR<>[M]CUR
  Call COURANA([M]CUR,[M]DEVORG,[M]DEVIMP)
  Call COURBUD([M]BUD,[M]DEVBUD,[M]DEVIMP)
 Endif
Endif
End

Subprog C_FCYFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]FCYDEB
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Endif
End

Subprog C_DATDEB(VALEUR)
Variable Date VALEUR
Local Integer OK
Local Decimal EDEB,PDEB
Read [CPY]CPY0 = [M]CPY
If [F:CPY]CPYLEGFLG=2
 Call GETPERSOC([M]CPY,[M]LEDTYP,VALEUR,EDEB,PDEB) From CPTSUB
 If EDEB=0 or PDEB=0
  GMESSAGE = [M]CPY-format$("D:"+GFMDAT4,VALEUR)-":"-mess(10,116,1) : # Période incorrecte
  mkstat = 2 : End
 Else
  VALEUR = [F:PER]PERSTR
 Endif
Else
 OK = 0
 For [FGR]FGR0 Where CPY=[M]CPY
  Read [FCY]FCY0 = [F:FGR]FCY
  Call GETPERSOC([F:FCY]LEGCPY,[M]LEDTYP,VALEUR,EDEB,PDEB) From CPTSUB
  If EDEB<>0 & PDEB<>0
   OK = 1 : Break
  Endif
 Next
 If !OK
  GMESSAGE = CPY-format$("D:"+GFMDAT4,VALEUR)-":"-mess(10,116,1) : # Période incorrecte
  mkstat = 2
 Endif
Endif
End

Subprog C_DATFIN(VALEUR)
Variable Date VALEUR
Local Decimal EFIN,PFIN
Local Integer OK
Read [CPY]CPY0 = [M]CPY
If [F:CPY]CPYLEGFLG=2
 Call GETPERSOC([M]CPY,[M]LEDTYP,VALEUR,EFIN,PFIN) From CPTSUB
 If EFIN=0 or PFIN=0
  GMESSAGE = [M]CPY-format$("D:"+GFMDAT4,VALEUR)-":"-mess(10,116,1) : # Période incorrecte
  mkstat = 2 : End
 Else
  VALEUR = [F:PER]PEREND
 Endif
Else
 OK = 0
 For [FGR]FGR0 Where CPY=[M]CPY
  Read [FCY]FCY0 = [F:FGR]FCY
  Call GETPERSOC([F:FCY]LEGCPY,[M]LEDTYP,VALEUR,EFIN,PFIN) From CPTSUB
  If EFIN<>0 & PFIN<>0
   OK = 1 : Break
  Endif
 Next
 If !OK
  GMESSAGE = [F:FCY]LEGCPY-format$("D:"+GFMDAT4,VALEUR)-":"-mess(10,116,1) : # Période incorrecte
  mkstat = 2
 Endif
Endif
End

Subprog AS_TYP(VALEUR)
Variable Integer VALEUR
If [M]BUD<>""
 GMENLOC(3) = 1
Endif
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
Local Char PLAN(GLONCOA)
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If VALEUR=1 & [F:CPY]CPYLEGFLG<>2
 For [FGR]FGR0 Where CPY=[M]CPY
  Read [FCY]FCY0 = [F:FGR]FCY
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
  Call LECTURE("LED",[F:GCM]LED([M]LEDTYP-1),"") From CONTOBJ
  If PLAN=""
   PLAN = [F:LED]COA
  Elsif PLAN<>[F:LED]COA
   GMESSAGE = mess(136,104,1) : # Plans de comptes incompatibles
   mkstat = 2 : Break
  Endif
 Next
Endif
End

Subprog AS_AXE(VALEUR)
Variable Char    VALEUR()
If [M]TYP(nolign-1)<>2
 mkstat = 1 : End
Endif
End

Subprog C_AXE(VALEUR)
Variable Char    VALEUR()
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
 Call LECTURE("LED",[F:GCM]LED([M]LEDTYP-1),"") From CONTOBJ
 If !find(VALEUR,[F:LED]DIE(0..[F:LED]DIENBR-1))
  GMESSAGE = mess(81,103,1) : # Axe non défini sur le référentiel
  mkstat = 2 : End
 Endif
Else
 For [FGR]FGR0 Where CPY=[M]CPY
  Read [FCY]FCY0 = [F:FGR]FCY
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
  Call LECTURE("LED",[F:GCM]LED([M]LEDTYP-1),"") From CONTOBJ
  If !find(VALEUR,[F:LED]DIE(0..[F:LED]DIENBR-1))
   GMESSAGE = [F:CPY]CPY-":"-mess(81,103,1)-[F:LED]LED : # Axe non défini sur le référentiel
   mkstat = 2 : Break
  Endif
 Next
 If mkstat=2 : End : Endif
Endif
If [M]BUD<>""
 Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
 If !find(VALEUR,[F:BUP]DIE(0..dim([F:BUP]DIE)-1))
  GMESSAGE = VALEUR-":"-mess(84,103,1)-[M]BUD : # Axe non défini pour le budget
  mkstat = 2 : End
 Endif
Endif
Local Integer DROIT
Call CONSACC([F:DIE]ACS,DROIT) From CPTSUB
If !DROIT
 ## Vous n'avez pas les droits pour ce code
 GMESSAGE = mess(4,104,1)
 mkstat = 2 : End
Endif
End

Subprog S_AXE(VALEUR)
Variable Char    VALEUR()
Filter [DIE] Where find(DIE,[F:LED]DIE(0..[F:LED]DIENBR-1))<>0
Call SELECT("DIE","",VALEUR,"") From SELOBJ
Filter [DIE]
End

Subprog AS_PYRSEC(VALEUR)
Variable Char    VALEUR()
If [M]TYP(nolign-1)=3
 mkstat = 1 : End
Endif
If [M]BUD<>""
 Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
 Case [M]TYP(nolign-1)
  When 1
   If [F:BUP]PYMACC<>""
    VALEUR = [F:BUP]PYMACC
    mkstat = 2 : End
   Endif
  When 2
   Local Integer IAXE
   IAXE = find([M]AXE(nolign-1),[F:BUP]DIE(0..dim([F:BUP]DIE)-1))-1
   If IAXE>=0 & [F:BUP]PYMCCE(IAXE)<>""
    VALEUR = [F:BUP]PYMCCE(IAXE)
    mkstat = 2 : End
   Endif
 Endcase
Endif
End

Subprog C_PYRSEC(VALEUR)
Variable Char    VALEUR()
Local Integer I , IAXE , OK
Case [M]TYP(nolign-1)
 When 1
  If VALEUR<>""
   Call LECTURE("GYM",VALEUR,"") From CONTOBJ
   If fstat
    GMESSAGE = mess(96,102,1) : # Pyramide inexistante
    mkstat = 2 :  End
   Endif
   If [F:GYM]COA<>[M]COA
    GMESSAGE = [F:GYM]COA-":"-mess(87,103,1) : # Plan de compte incompatible
    mkstat = 2 : End
   Endif
  Endif
  If [M]BUD<>""
   Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
   If [F:BUP]PYMACC<>"" & [F:BUP]PYMACC<>VALEUR
    GMESSAGE = [M]BUD-":"-mess(85,103,1)-[F:BUP]PYMACC : # Budget défini sur la pyramide de comptes
    mkstat = 2 : End
   Endif
  Endif
  OK = 1
  For I=0 To nolign-2
   If [M]TYP(I)=1
    If [M]PYRSEC(I)=""
     GMESSAGE = mess(130,102,1)-num$(I+1) : # Niveau incompatible avec la ligne
     OK = 0 : Break
    Elsif VALEUR<>"" & VALEUR<>[M]PYRSEC(I)
     GMESSAGE = mess(130,102,1)-num$(I+1) : # Niveau incompatible avec la ligne
     OK = 0 : Break
    Endif
   Endif
  Next I
  If OK
   For I=nolign To [M]NBAXE-1
    If [M]TYP(I)=1
     If VALEUR="" or ([M]PYRSEC(I)<>"" & [M]PYRSEC(I)<>VALEUR)
      GMESSAGE = mess(130,102,1)-num$(I+1) : # Niveau incompatible avec la ligne
      OK = 0 : Break
     Endif
    Endif
   Next I
  Endif
 When 2
  If VALEUR<>""
   Call LECTURE("CYM",VALEUR,"") From CONTOBJ
   If fstat
    GMESSAGE = mess(96,102,1) : # Pyramide inexistante
    mkstat = 2 : End
   Endif
   If [F:CYM]DIE<>[M]AXE(nolign-1)
    GMESSAGE = [F:CYM]DIE-":"-mess(88,103,1) : # Axe incompatible
    mkstat = 2 : End
   Endif
  Endif
  If [M]BUD<>""
   Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
   IAXE = find([M]AXE(nolign-1),[F:BUP]DIE(0..dim([F:BUP]DIE)-1))-1
   If IAXE>=0 & [F:BUP]PYMCCE(IAXE)<>"" & [F:BUP]PYMCCE(IAXE)<>VALEUR
    GMESSAGE = [M]BUD-":"-mess(86,103,1)-[F:BUP]PYMCCE(IAXE) : # Budget défini sur la pyramide de comptes
    mkstat = 2 : End
   Endif
  Endif
  OK = 1
  For I=0 To nolign-2
   If [M]TYP(I)=2 & [M]AXE(I)=[M]AXE(nolign-1)
    If [M]PYRSEC(I)=""
     GMESSAGE = mess(130,102,1)-num$(I+1) : # Niveau incompatible avec la ligne
     OK = 0 : Break
    Elsif VALEUR<>"" & VALEUR<>[M]PYRSEC(I)
     GMESSAGE = mess(130,102,1)-num$(I+1) : # Niveau incompatible avec la ligne
     OK = 0 : Break
    Endif
   Endif
  Next I
  If OK
   For I=nolign To [M]NBAXE-1
    If [M]TYP(I)=2 & [M]AXE(I)=[M]AXE(nolign-1)
     If VALEUR="" or ([M]PYRSEC(I)<>"" & [M]PYRSEC(I)<>VALEUR)
      GMESSAGE = mess(130,102,1)-num$(I+1) : # Niveau incompatible avec la ligne
      OK = 0 : Break
     Endif
    Endif
   Next I
  Endif
Endcase
If OK=0
 GMESSAGE = mess(67,103,1)+"\"+GMESSAGE : # Paramètres incompatibles
 mkstat = 2 : End
Endif
End

Subprog IB_PYRSEC
If [M]TYP(nolign-1)>2
 Raz GBOUT1
Endif
End

Subprog B1_PYRSEC(VALEUR)
Variable Char    VALEUR()
Case [M]TYP(nolign-1)
 When 1
  Call OBJET("GYM",VALEUR,"") From GOBJET
 When 2
  Call OBJET("CYM",VALEUR,"") From GOBJET
Endcase
End

Subprog S_PYRSEC(VALEUR)
Variable Char    VALEUR()
Case [M]TYP(nolign-1)
 When 1
  Filter [GYM] Where COA=[M]COA
  Call SELECT("GYM","",VALEUR,"") From SELOBJ
  Filter [GYM]
 When 2
  Filter [CYM] Where DIE=[M]AXE(nolign-1)
  Call SELECT("CYM","",VALEUR,"") From SELOBJ
  Filter [CYM]
Endcase
End

Subprog AS_NIVSEC(VALEUR)
Variable Decimal VALEUR
If [M]PYRSEC(nolign-1)=""
 mkstat = 1 : End
Endif
If VALEUR=0
 Case [M]TYP(nolign-1)
  When 1
   If nolign>1 & [M]TYP(nolign-2)=1 & [M]PYRSEC(nolign-2)=[M]PYRSEC(nolign-1)
    Filter [GRY] Where PYM=[M]PYRSEC(nolign-1) & LEV>[M]NIVSEC(nolign-2)
   Else
    Filter [GRY] Where PYM=[M]PYRSEC(nolign-1)
   Endif
   Read [GRY]GRY1 First
   Filter [GRY]
   VALEUR = [F:GRY]LEV
  When 2
   If nolign>1 & [M]TYP(nolign-2)=2 & [M]PYRSEC(nolign-2)=[M]PYRSEC(nolign-1)
    Filter [CRY] Where PYM=[M]PYRSEC(nolign-1) & LEV>[M]NIVSEC(nolign-2)
   Else
    Filter [CRY] Where PYM=[M]PYRSEC(nolign-1)
   Endif
   Read [CRY]CRY1 First
   Filter [CRY]
   VALEUR = [F:CRY]LEV
 Endcase
Endif
End

Subprog C_NIVSEC(VALEUR)
Variable Decimal VALEUR
Local Integer I , IAXE , OK
Case [M]TYP(nolign-1)
 When 1
  Read [GRY]GRY1(2) = [M]PYRSEC(nolign-1);VALEUR
  If fstat
   GMESSAGE = mess(98,102,1) : # Niveau incorrect
   mkstat = 2 : End
  Endif
  If [M]BUD<>""
   Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
   If [F:BUP]PYMACC<>"" & [F:BUP]PYMACCLEV<VALEUR
    GMESSAGE = [M]BUD-":"-mess(89,103,1)-num$([F:BUP]PYMACCLEV)-"("+[F:BUP]PYMACC+")" : # Budget défini au niveau
   mkstat = 2 : End
   Endif
  Endif
  OK = 1
  For I=0 To nolign-2
   If [M]TYP(I)=1 & [M]PYRSEC(I)=[M]PYRSEC(nolign-1) & [M]NIVSEC(I)>=VALEUR
    GMESSAGE = mess(130,102,1)-num$(I+1) : # Niveau incompatible avec la ligne
    OK = 0 : Break
   Endif
  Next I
  If OK
   For I=nolign To [M]NBAXE-1
    If [M]TYP(I)=1 & [M]PYRSEC(I)=[M]PYRSEC(nolign-1) & [M]NIVSEC(I)<=VALEUR
     GMESSAGE = mess(130,102,1)-num$(I+1) : # Niveau incompatible avec la ligne
     OK = 0 : Break
    Endif
   Next I
  Endif
 When 2
  Read [CRY]CRY1(2) = [M]PYRSEC(nolign-1);VALEUR
  If fstat
   GMESSAGE = mess(98,102,1) : # Niveau incorrect
   mkstat = 2 : End
  Endif
  If [M]BUD<>""
   Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
   IAXE = find([M]AXE(nolign-1),[F:BUP]DIE(0..dim([F:BUP]DIE)-1))-1
   If IAXE>=0 & [F:BUP]PYMCCE(IAXE)<>"" & [F:BUP]PYMCCELEV(IAXE)<VALEUR
    GMESSAGE = [M]BUD-":"-mess(89,103,1)-num$([F:BUP]PYMCCELEV(IAXE))-"("+[F:BUP]PYMCCE(IAXE)+")" : # Budget défini au niveau
    mkstat = 2 : End
   Endif
  Endif
  OK = 1
  For I=0 To nolign-2
   If [M]TYP(I)=2 & [M]AXE(I)=[M]AXE(nolign-1) & [M]PYRSEC(I)=[M]PYRSEC(nolign-1) & [M]NIVSEC(I)>=VALEUR
    GMESSAGE = mess(130,102,1)-num$(I+1) : # Niveau incompatible avec la ligne
    OK = 0 : Break
   Endif
  Next I
  If OK
   For I=nolign To [M]NBAXE-1
    If [M]TYP(I)=2 & [M]AXE(I)=[M]AXE(nolign-1) & [M]PYRSEC(I)=[M]PYRSEC(nolign-1) & [M]NIVSEC(I)<=VALEUR
     GMESSAGE = mess(130,102,1)-num$(I+1) : # Niveau incompatible avec la ligne
     OK = 0 : Break
    Endif
   Next I
  Endif
Endcase
If OK=0
 GMESSAGE = mess(67,103,1)+"\"+GMESSAGE : # Paramètres incompatibles
 mkstat = 2 : End
Endif
End

Subprog AS_SECDEB(VALEUR)
Variable Char    VALEUR()
If [M]PYRSEC(nolign-1)<>""
 mkstat = 1 : End
Endif
End

Subprog AS_SECFIN(VALEUR)
Variable Char    VALEUR()
If [M]PYRSEC(nolign-1)<>""
 mkstat = 1 : End
Endif
End

Subprog C_SECFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]SECDEB(nolign-1)
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Endif
End

Subprog S_SECDEB(VALEUR)
Variable Char    VALEUR()
Case [M]TYP(nolign-1)
 When 1 : Call SELECT("GAC","",VALEUR,[M]COA) From SELOBJ
 When 2 : Call SELECT("CCE","",VALEUR,[M]AXE(nolign-1)) From SELOBJ
 When 3 : Call SELECT("BPR","",VALEUR,"") From SELOBJ
Endcase
End

Subprog S_SECFIN(VALEUR)
Variable Char    VALEUR()
Call S_SECDEB(VALEUR)
End

Subprog AS_RNGSECDEB(VALEUR)
Variable Decimal VALEUR
If [M]PYRSEC(nolign-1)=""
 mkstat = 1 : End
Endif
End

Subprog AS_RNGSECFIN(VALEUR)
Variable Decimal VALEUR
If [M]PYRSEC(nolign-1)=""
 mkstat = 1 : End
Endif
End

Subprog C_RNGSECFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR<[M]RNGSECDEB(nolign-1)
 mkstat = 2 : End
Endif
End

Subprog AS_PERCOL(VALEUR)
Variable Decimal VALEUR
If [M]NBPER<2
 VALEUR = 1 : mkstat = 2
 End
Endif
End

Subprog C_PERCOL(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 or VALEUR>[M]NBPER
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Endif
End

Subprog C_BUD(VALEUR)
Variable Char    VALEUR()
Local Integer I
If VALEUR<>""
 Call LECTURE("BUP",VALEUR,"") From CONTOBJ
 If [F:BUP]COA<>[M]COA
  GMESSAGE = VALEUR-":"-mess(83,103,1)-[F:BUP]COA-"("+[M]COA+")" : # Budget sur le plan comptable
  mkstat = 2 : End
 Endif
 If [F:BUP]LEV<>2
  Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
  If [F:CPY]CPYLEGFLG<>2
   GMESSAGE = VALEUR-":"-mess(33,108,1)+"\"+mess(219,108,1) : # Budget défini au niveau société
   mkstat = 2 : End
  Elsif [M]FCYDEB<>"" or [M]FCYFIN<>""
   GMESSAGE = VALEUR-":"-mess(33,108,1)+"\"+mess(220,108,1) : # Budget défini au niveau société
   mkstat = 2 : End
  Endif
 Endif
 If find(3,[M]TYP(0..[M]NBAXE-1))
  GMESSAGE = mess(103,103,1) : # Pas de budget avec un regroupement par tiers
  mkstat = 2 : End
 Endif
 For I=0 To [M]NBAXE-1
  If [M]TYP(I)=2 & !find(AXE(I),[F:BUP]DIE(0..dim([F:BUP]DIE)-1))
   GMESSAGE = [M]AXE(I)-":"-mess(84,103,1)-VALEUR : # Axe non défini pour le budget
   mkstat = 2 : End
  Endif
 Next I
Endif
[M]DEVBUD = [F:BUP]CUR
If VALEUR=""
 Effzo VER
 Grizo VER
 For I=1 To [M]NBCOL
  If [M]TYPCOL(I-1)=10 or [M]TYPCOL(I-1)>16
   [M]TYPCOL(I-1) = 1
   Affzo TYPCOL(I-1)
  Endif
 Next I
Else
 Actzo VER
Endif
If VALEUR<>[M]BUD
 Call COURBUD(VALEUR,[F:BUP]CUR,[M]DEVIMP)
 Filter [BUV] Where BUD=VALEUR & DEF=2
 Read [BUV] First
 Filter [BUV]
 [M]VER = [F:BUV]VER
Endif
End

Subprog AS_VER(VALEUR)
Variable Char    VALEUR()
End

Subprog C_VER(VALEUR)
Variable Char    VALEUR()
End

Subprog C_DEVORG(VALEUR)
Variable Char VALEUR()
If VALEUR<>[M]DEVORG
 Call COURANA([M]CUR,VALEUR,[M]DEVIMP)
Endif
End

Subprog C_DEVIMP(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = [M]CUR
Endif
If [M]DEVIMP<>VALEUR
 Call COURANA([M]CUR,[M]DEVORG,VALEUR)
 Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
 Call COURBUD([M]BUD,[F:BUP]CUR,VALEUR)
Endif
End

Subprog COURANA(DEVISE,DEVORG,DEVIMP)
Value Char DEVISE
Value Char DEVORG
Value Char DEVIMP
Local Decimal COURMUL , COURDIV
Local Char    VALPAR(10)
Local Integer TYPCOURS
If DEVIMP=DEVISE or DEVIMP=DEVORG
 [M]COURANA = 1
 Affzo COURANA
 Grizo COURANA
 Effzo LIBCUR
Else
 Actzo COURANA
 [M]LIBCUR = "("+DEVISE-"=>"-DEVIMP+")"
 Affzo LIBCUR
 Call PARAM([M]CPY,"CNSTYPCUR",VALPAR) From ADOVAL
 TYPCOURS = max(1,val(VALPAR))
 Call INI_COURS(DEVISE,DEVIMP,TYPCOURS,date$,COURMUL,COURDIV) From AINICOURS
 [M]COURANA = arr(COURDIV/COURMUL,0.00000001)
 Affzo COURANA
Endif
End

Subprog COURBUD(CODBUD,DEVBUD,DEVIMP)
Value Char CODBUD
Value Char DEVBUD
Value Char DEVIMP
Local Decimal COURMUL , COURDIV
Local Char    VALPAR(10)
Local Integer TYPCOURS
If CODBUD=""
 Effzo COURBUD
 Grizo COURBUD
 Effzo LIBBUD
Elsif DEVBUD=DEVIMP
 [M]COURBUD = 1
 Affzo COURBUD
 Grizo COURBUD
 Effzo LIBBUD
Else
 [M]LIBBUD = "("+DEVBUD-"=>"-DEVIMP+")"
 Affzo LIBBUD
 Actzo COURBUD
 Call PARAM([M]CPY,"BUDTYPCUR",VALPAR) From ADOVAL
 TYPCOURS = max(1,val(VALPAR))
 Call INI_COURS(DEVBUD,DEVIMP,TYPCOURS,date$,COURMUL,COURDIV) From AINICOURS
 [M]COURBUD = arr(COURDIV/COURMUL,0.00000001)
 Affzo COURBUD
Endif
End

Subprog AS_TYPCOL(VALEUR)
Variable Integer VALEUR
Local Integer I
GMENLOC(len(mess(0,637,1))) = 1
If [M]BUD=""
 GMENLOC(10) = 1
 For I=16 To len(mess(0,637,1))-1
  GMENLOC(I) = 1
 Next I
Endif
End

Subprog C_TAXE(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]AAXE = 1
 Affzo AAXE
 Grizo AAXE
Else
 Actzo AAXE
Endif
End

Subprog C_DESTIN(VALEUR)
Variable Integer VALEUR
Local Integer OBLIG
If VALEUR=2
 Effzo IMPRIME
 Grizo IMPRIME
 Actzo ECRAN
Else
 Effzo ECRAN
 Grizo ECRAN
 Actzo IMPRIME
 If [M]IMPRIME=""
  Call DEFIMP("BALANA",GUSER,"",[M]IMPRIME,OBLIG) From IMPRIME
 Endif
Endif
End

Subprog AS_ECRAN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call LECTURE("ACN","BLA","") From CONTOBJ
 VALEUR = [F:ACN]SCRCOD
Endif
End


######################################################################################
## Sélections
######################################################################################
$SEL_LISTE
Local Char DESIG(GLONAX3)
Case PARAM(1)
 When "NIVSEC"
  TIT = mess(102,103,1) : # Choix niveau pyramide
  Case [M]TYP(nolign-1)
   When 1
    For [GRY]GRY1(2) Where PYM=[M]PYRSEC(nolign-1)
     NBTEX += 1
     TEX(NBTEX)   = num$([F:GRY]LEV)
     Call LECTEXTRA(DESIG,"GACCGRUPYM","DESTRA",[M]PYRSEC(nolign-1),[F:GRY]GRU) From ATEXTRA
     TEXTE(NBTEX) = TEX(NBTEX)-"("+[F:GRY]GRU-DESIG+")"
    Next
   When 2
    For [CRY]CRY1(2) Where PYM=[M]PYRSEC(nolign-1)
     NBTEX += 1
     TEX(NBTEX)   = num$([F:CRY]LEV)
     Call LECTEXTRA(DESIG,"GCCEGRUPYM","DESTRA",[M]PYRSEC(nolign-1),[F:CRY]GRU) From ATEXTRA
     TEXTE(NBTEX) = TEX(NBTEX)-"("+[F:CRY]GRU-DESIG+")"
    Next
  Endcase
Endcase
Return

$SEL_TABLE
Case TABLE
 When "SELPYA"
  Local Integer NOL
  NOL=nolign-1
  Case [M]TYP(NOL)
   When 1
    OBJET  = "GRY"
    CRITERE = 'PYM="'+[M]PYRSEC(NOL)+'" & LEV='+num$([M]NIVSEC(NOL))
   When 2
    OBJET  = "CRY"         # Sections
    CRITERE = 'PYM="'+[M]PYRSEC(NOL)+'" & LEV='+num$([M]NIVSEC(NOL))
  Endcase
  ORDRE = "PRNROW"
Endcase
Return

$FIN_TABLE
Case TABLE
 When "SELPYA"
  Local Integer NOL
  NOL = nolign-1
  Case [M]TYP(NOL)
   When 1 : VALEUR = num$([F:GRY]PRNROW)
   When 2 : VALEUR = num$([F:CRY]PRNROW)
  Endcase
Endcase
Return

