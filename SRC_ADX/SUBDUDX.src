#<AdxTL>@(#)191.0.0.0 $Revision$
# Issue 120497 - 20170202 by LD : Commande ayant comme condition de paiement 2 acomptes
# Issue 121506 - 20170405 by LD : Gestion des acomptes : collectif non récupéré.
# Issue X3-38683 - 20170524 by LD : BPAPAY empty in GACCDUDATE

#######################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE  : # Sélection
 When Default
Endcase
Return
########################################
$SEL_TABLE
#---------------------#
# Sélection sur champ #
#---------------------#
Case COUZON
  When "NUM"   : # Numéro de pièce
    Case GMODULE
        When 5 : OBJET="SOH" : OPTIONS="BC"    : # 104227 : Les cdes ne doivent pas être soldées (ajout option B)
        When 6 : OBJET="POH"
    Endcase
Endcase
Return
########################################
Subprog AS_NUM(VALEUR)
Variable Char    VALEUR()

#----- Si modif non autorisée, grisage de l'écran -----#
If [M:DIA]FLAG=0 & [M:DIA]NUM<>"" & GFCY<>""
  [M:DIA]FLAG=1
  If GREP<>"C" & GREP<>"D"
    GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2  Diszo [DIA]1-99 : Endif
  Endif
Endif
#-----

If GNUMCDE <> "" mkstat = 2 Endif

If GFONEMI <> "VEN"
    Grizo [M]SNSFLG, SNSNAM
Else
    Actzo [M]SNSFLG
    If [M]SNSFLG = 2
        Actzo [M]SNSNAM
    Else
        Grizo [M]SNSNAM
    Endif
Endif

End

########################################
Subprog C_NUM(VALEUR)
Variable Char    VALEUR()
Case GMODULE
     When 5 : Call CONTROLE("SOH","BC",VALEUR,"",mkstat) From CONTOBJ : # 104227 : Les cdes ne doivent pas être soldées (ajout option B)
     When 6 : Call CONTROLE("POH","",VALEUR,"",mkstat) From CONTOBJ
     When Default
Endcase
End
#########################################
Subprog AM_NUM(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(10)
Local Char CODCPT(GLONCAC)

Case GMODULE
     When 5 : Call LECTURE("SOH",VALEUR,"") From CONTOBJ
              [M:DIA]NUM = [F:SOH]SOHNUM
              [M:DIA]CUR = [F:SOH]CUR
              [M:DIA]TTVORD = [F:SOH]ORDINVATI
              [M:DIA]TOTORD = [F:SOH]ORDINVNOT
              TFACT     = [F:SOH]BPCINV
              TPAYE     = [F:SOH]BPCPYR
              TYPCOURS  = [F:SOH]CHGTYP
              DEPECHE   = [F:SOH]ORDDAT
              # Issue X3-38683
              ADRPAY    = [F:SOH]BPAPYR
              # End issue X3-38683
     When 6 : Call LECTURE ("POH",VALEUR,"") From CONTOBJ
              [M:DIA]NUM = [F:POH]POHNUM
              [M:DIA]CUR = [F:POH]CUR
              [M:DIA]TTVORD = [F:POH]TTVORD
              [M:DIA]TOTORD = [F:POH]TOTORD
              TFACT     = [F:POH]BPSINV
              TPAYE     = [F:POH]BPRPAY
              TYPCOURS  = [F:POH]CHGTYP
              DEPECHE   = [F:POH]ORDDAT
              # Issue 88968 - 2013-03-27 by MUARN : acompte saisi dans FUNPNS
              ADRPAY    = [F:POH]BPAPAY

     When Default
Endcase

# Issue 108348 - 2016-02-04 by CPO : SAC populating on prepayment DUDX screen
#--This has to be called further bellow, after populating general parameters
##----- Chargement du code comptable par société -----#
#Case GMODULE
#     When 5 : Read [F:BPC]BPC0 = TFACT
#              Call INIT_COMPTE([F:BPC]BPCNUM,GSOCIETE,"C",[L]CODCPT) From CPTSUB
#              Call LECTURE("CAC",[L]CODCPT,"3~"+GCOA(1))             From CONTOBJ
#              Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(1))              From CONTOBJ
#     When 6 : Read [F:BPS]BPS0 = TFACT
#              Call INIT_COMPTE([F:BPS]BPSNUM,GSOCIETE,"F",[L]CODCPT) From CPTSUB
#              Call LECTURE("CAC",[L]CODCPT,"3~"+GCOA(1))             From CONTOBJ
#              Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(1))              From CONTOBJ
#     When Default
#Endcase
# End issue 108348

#Lecture de la devise
Call LECDEV([M]CUR) From TRTDIV
#Quel que soit le module : Si traitement par entrée séparée
#Il faut lire les paramètres généraux SOCIETE,SITE FINANCIER, DEVISES
#SOCIETE ET DOSSIER
#Si on vient de la fonction indépendante de gestion des acomptes
#et Module = vente, il faut aller lire le paramètre disant le nombre
#de jour à enlever à la date d'échéance pour obtenir la date prévue
#d'émission
#Si on vient de la gestion des commandes, ce paramètre est déjà chargé
#Si on vient des achats on n'en a pas besoin
If GMODULE = 5 & GNUMCDE = ""
   # Issue 108348 - 2016-02-04 by CPO : SAC populating on prepayment DUDX screen
   #Call GETDEV([F:SOH]SALFCY) From DEVSUB
   Call GETCPY([F:SOH]SALFCY,"SLT",2,"") From TRTX3CPT
   # End issue 108348

   Global Decimal GDAYNBR : # nbre pour calcul dte émission
   Call PARAM([F:SOH]SALFCY,"DAYNBR",PARAM) From ADOVAL
   GDAYNBR = val(PARAM)
Endif

If GMODULE = 6 & GNUMCDE = ""
   Call GETDEV([F:POH]POHFCY) From DEVSUB
Endif

# Issue 108348 - 2016-02-04 by CPO : SAC populating on prepayment DUDX screen
#--This has to be called further bellow, after populating general parameters
#----- Chargement du code comptable par société -----#
Case GMODULE
     When 5 : Read [F:BPC]BPC0 = TFACT
              Call INIT_COMPTE([F:BPC]BPCNUM,GSOCIETE,"C",[L]CODCPT) From CPTSUB
              # Issue 121506
              #Call LECTURE("CAC",[L]CODCPT,"3~"+GCOA(1))             From CONTOBJ
              Call LECTURE("CAC",[L]CODCPT,"2~"+GCOA(1))             From CONTOBJ
              # End issue 121506
              Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(1))              From CONTOBJ
     When 6 : Read [F:BPS]BPS0 = TFACT
              Call INIT_COMPTE([F:BPS]BPSNUM,GSOCIETE,"F",[L]CODCPT) From CPTSUB
              Call LECTURE("CAC",[L]CODCPT,"3~"+GCOA(1))             From CONTOBJ
              Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(1))              From CONTOBJ
     When Default
Endcase
# End issue 108348

Gosub LIRE From TRTTPT
Affzo [M:DIA]1-99

End
########################################
Subprog AM_SNSFLG(VALEUR)
Variable Integer VALEUR
If VALEUR <> 2
    Grizo [M]SNSNAM
Else
    If GFONEMI = "VEN" Actzo [M]SNSNAM Endif
Endif
End
########################################
Subprog AS_NBLIG

GMODIF = 2
If [M]PAMTYP(nolign-1) <> 0
    Case GMODULE
         When 5 :
            If [M]SENINS(nolign-1) = 2 GMODIF = 1 : End  : Endif
            If [M]PAYCUR(nolign-1)<>0 | [M]TMPCUR(nolign-1)<>0  GMODIF=1 : End : Endif
         When 6 :
            If [M]PAYCUR(nolign-1)<>0 | [M]TMPCUR(nolign-1)<>0  GMODIF=1 : Endif
         When Default
    Endcase
    If [M]PAMTYP(nolign-1) = 1 : GMODIF = 1 : Endif
Endif
[M]DCUR(nolign-1)= [M]CUR
End
########################################
Subprog IB_NBLIG
If [M]PAMTYP(nolign-1) <> 0
    Case GMODULE
         When 5 :
            If clalev ([F:SOH]) <= 0 : Local File SORDER [SOH] : Endif
            If [F:SOH]SOHNUM <> [M]NUM
                Read [F:SOH]SOH0 = [M]NUM
                If fstat Raz [F:SOH] : Endif
            Endif
            If [F:SOH]APPFLG>2
                If [M]SENINS(nolign-1) <> 2
                    Raz GBOUT4
                    If [M]PAMTYP(nolign-1) = 1 : Raz GBOUT3 : Endif
                Else
#                   Bouton reimpression si l'acompte est déjà émis et on a l'impression automatique
                    If [M]SNSFLG<>2 Raz GBOUT4 : Endif
                    Raz GBOUT3
                Endif
            Else
                Raz GBOUT3, GBOUT4
            Endif
         When 6 :
            Raz GBOUT3, GBOUT4
         When Default
    Endcase
Else
    Raz GBOUT3, GBOUT4
Endif
End
########################################
#Emission de l'acompte
Subprog B3_NBLIG
If    [M]SENINS(nolign-1) = 1 & [M]AEMETTRE(nolign-1) = 1
      [M]AEMETTRE(nolign-1) = 2
Elsif [M]SENINS(nolign-1) = 1 & [M]AEMETTRE(nolign-1) = 2
      [M]AEMETTRE(nolign-1) = 1
Else  [M]AEMETTRE(nolign-1) = 1
Endif
Affzo [M]AEMETTRE(nolign-1)
End
########################################
Subprog B4_NBLIG
# Reimpression d'un acompte
If [M]AEMETTRE (nolign-1) = 1
    [M]AEMETTRE (nolign-1) = 2
Else
    [M]AEMETTRE (nolign-1) = 1
Endif
Affzo [M]AEMETTRE(nolign-1)
End
########################################
Subprog C_NBLIG

If GMODULE=5 & find(status,73,82) & [M]NBLIG>3
#   Si insertion de ligne on ne peut pas mettre plus de 4 acomptes / retenue de garantie
  GMESSAGE=mess(240,192,1) : mkstat=2 : End
Endif
# On ne peut pas supprimer l'acompte s'il y a un règlement (41822)
If find(status,65,68,83) & ([M]PAYCUR(nolign-1)<>0 | [M]TMPCUR(nolign-1)<>0)
    GMESSAGE=mess(50,117,1) : mkstat=2 : End
Endif
If GMODULE=5 & find(status,65,68,73,75,82,83)
#    Si la commande est facturée on ne peut plus faire de modif,suppression,insertion
     If clalev ([F:SOH]) <= 0 : Local File SORDER [SOH] : Endif
     If [F:SOH]SOHNUM <> [M]NUM
         Read [F:SOH]SOH0 = [M]NUM
         If fstat Raz [F:SOH] : Endif
     Endif
     If [F:SOH]INVSTA <> 1 GMESSAGE=mess(170,192,1) : mkstat=2 : Endif
Endif

If GMODULE=6 & find(status,65,68,73,75,82,83)
#    Si la commande est facturée on ne peut plus faire de modif,suppression,insertion
     If clalev ([F:POH]) <= 0 : Local File PORDER [POH] : Endif
     If [F:POH]POHNUM <> [M]NUM
         Read [F:POH]POH0 = [M]NUM
         If fstat Raz [F:POH] : Endif
     Endif
     If [F:POH]INVFLG <> 1 GMESSAGE=mess(170,192,1) : mkstat=2 : Endif
Endif

End
########################################
Subprog AS_PAMTYP(VALEUR)
Variable Integer VALEUR
If GMODIF <> 2 mkstat=2 Endif
If [M]PAM(nolign-1) <> "" : mkstat = 2 : Endif
GMENLOC(1) = 1
End
########################################
Subprog AM_PAMTYP(VALEUR)
Variable Integer VALEUR
[M]DCUR(nolign-1)=[M]CUR
Affzo [M]DCUR(nolign-1)
End
########################################
Subprog AS_PAM(VALEUR)
Variable Char    VALEUR()
If GMODIF <> 2 mkstat=2 Endif
End
########################################
Subprog AS_AMTCUR(VALEUR)
Variable Decimal VALEUR
If GMODIF <> 2 mkstat=2 Endif
End
########################################
Subprog C_AMTCUR(VALEUR)
Variable Decimal VALEUR
Local Decimal WMONTANT, WMONTORD
Local Integer OK
If VALEUR < [M]DINAMT(nolign-1)
   GMESSAGE= (mess(110,196,1)- num$([M]DINAMT(nolign-1)))
   mkstat = 1
   End
Endif

#VPO 07/02/11 71377 saisie acompte > commande : bloquant
#WMONTANT = sum([M]AMTCUR(0..NBLIG-1))-[M]AMTCUR(nolign-1)+VALEUR
If nolign<=[M]NBLIG
WMONTANT = sum([M]AMTCUR(0..[M]NBLIG-1))-[M]AMTCUR(nolign-1)+VALEUR
Else
WMONTANT = sum([M]AMTCUR(0..[M]NBLIG-1))+VALEUR
Endif

# Bug 42853 : Acompte calculé sur le montant HT ou TTC en fonction du code activité TPT
# (Si Code activité TPT activé et %TVA de la 1ère ligne de la condition paiement à 0 : Acompte calculé sur HT
# Sinon Acompte calculé sur TTC)
# Issue 120497
# Code activité TPT activé :
# - Condition de paiement renseignée sur la cde et %TVA 1ère ligne à 0
#   --> Contrôle par rapport au montant HT
# - Sinon
#   Condition de paiement non renseignée sur la cde ou non accessible
#   Condition de paiement renseignée sur la cde et %TVA 1ère ligne <> 0
#   --> Contrôle par rapport au montant TTC
# Code activité TPT non activé :
#   --> Contrôle par rapport au montant TTC
#If !GTPTTVA WMONTORD=[M]TTVORD Else WMONTORD=[M]TOTORD Endif
Local Char WPTE(GLONPTE)
# Par défaut Contrôle par rapport au montant TTC
WMONTORD=[M]TTVORD
If GTPTTVA
    Case GMODULE
      When 5 :
         If clalev ([F:SOH]) <= 0 : Local File SORDER [SOH] : Endif
         If [F:SOH]SOHNUM <> [M]NUM
             Read [F:SOH]SOH0 = [M]NUM
             If fstat Raz [F:SOH] : Endif
         Endif
         WPTE=[F:SOH]PTE
      When 6 :
         If clalev ([F:POH]) <= 0 : Local File PORDER [POH] : Endif
         If [F:POH]POHNUM <> [M]NUM
             Read [F:POH]POH0 = [M]NUM
             If fstat Raz [F:POH] : Endif
         Endif
         WPTE=[F:POH]PTE
    Endcase
    Filter [TPT] Where PTE=WPTE & PAMTYP=2 & (LEG=GCURLEG or LEG ="")
&          Order By Key CLE=[F:TPT]PTE Asc; [F:TPT]LEG Desc

    Read [TPT]CLE First
    # Il y a une Condition de paiement, 1 ère ligne avec %TVA=0
    # Contrôle par rapport au montant HT
    If fstat = 0 & [F:TPT]VATPRC=0 WMONTORD=[M]TOTORD Endif
    Filter [TPT]
Endif
# End issue 120497

If WMONTANT > WMONTORD
#- Bug 69311 Rendre ce contrôle bloquant car les éléments de facturatioon sont inclus -#
#   OK=1
#   Call AVERTIR(mess(71,196,1)-"="-num$(WMONTANT)+"\"+mess(72,196,1)-"="
#&              -num$(WMONTORD)+"\"+mess(205,100,1),OK) From GESECRAN
#   If OK<>2 mkstat=1 : End : Endif
  GMESSAGE =mess(71,196,1)-"="-num$(WMONTANT)+"\"+mess(72,196,1)-"="-num$(WMONTORD)
  mkstat=1 : End
Endif
If varinit([M]IBDAMT,nolign-1)<>0 & [M]AMTCUR(nolign-1)<>VALEUR
  [M]IBDAMT(nolign-1)=VALEUR : Affzo IBDAMT(nolign-1)
Endif
End
########################################
Subprog AS_DUDDAT(VALEUR)
Variable Date    VALEUR
If GMODIF <> 2 mkstat=2 Endif
End
########################################
Subprog AM_DUDDAT(VALEUR)
Variable Date    VALEUR
Case GMODULE
    When 5 : [M]EXPSENDAT(nolign-1) = VALEUR - GDAYNBR
    When 6 : [M]EXPSENDAT(nolign-1) = min([F:POH]ORDDAT,VALEUR)
    When Default
Endcase
End
########################################
Subprog AS_VAT(VALEUR)
Variable Char    VALEUR()
If GMODIF <> 2 mkstat=2 Endif
End
########################################
Subprog AS_EXPSENDAT(VALEUR)
Variable Date    VALEUR
If GMODIF <> 2 mkstat=2 Endif
#     When 5 : VALEUR = [M]DUDDAT(nolign-1) -GDAYNBR
#              If VALEUR < date$ : VALEUR = date$
#              Endif
#Case GMODULE
#     When 6 : VALEUR = date$
#     When Default
#Endcase
End
########################################
Subprog C_EXPSENDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [M]DUDDAT(nolign-1) mkstat = 2 : GMESSAGE=mess(211,192,1) Endif
End
########################################
Subprog D_IBDAMT(VALEUR)
Variable Decimal VALEUR
VALEUR=[M]AMTCUR(nolign-1)
End
########################################
#Controle que le montant à déduire n'est pas supérieur a
#(Montant demandé - montant déjà déduit)
Subprog C_IBDAMT(VALEUR)
Variable Decimal VALEUR
Local Decimal MONTMAX
MONTMAX = [M]AMTCUR(nolign-1) - [M]DINAMT(nolign-1)
If VALEUR > MONTMAX : GMESSAGE = (mess(76,196,1)- num$(MONTMAX)) : mkstat = 1 : Endif
End
########################################
Subprog D_SAC(VALEUR)
Variable Char    VALEUR()
VALEUR=[F:GAC]ACCSHO
End

########################################
Subprog D_PAMTYP(VALEUR)
Variable Integer VALEUR
VALEUR=2
End

