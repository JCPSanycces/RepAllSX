#<AdxTL>@(#)0.0.0.0 $Revision$
Gosub TEST From ACLAVAL
End

$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
# Programme Update
#-------------------------------------------------------#
$TRT_REWRITE
If ACLA.TEST : Call ECR_TRACE("- aupdate PRG : REWRITE",0) From GESECRAN  : Endif
Gosub _TRTREWRITE
Gosub TRTREWRITE
Return

#-------------------------------------------------------#
$_TRTREWRITE
PROGRAM = "_"+[V]CST_APRGAUPDATE : # Update
Gosub ENTETE_SUBPROG From ACLASUBCRUD
Gosub AJOUT_ACCES_SITE From ACLASUBCRUD

PROGRAM = [V]CST_APRGAUPDATE : # Update

#LIGNE = "If adxlog"   : Gosub ADDCLB
#DIF +=1
LIGNE = "Gosub "+PROGRAM+"_"+[L]ROOTNAM  : Gosub ADDCLB
#DIF-= 1
#LIGNE = "Endif"   : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB
LIGNE = "End"   : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB
LIGNE = "#-----------------------------------------------------#"  : Gosub ADDCLB
Return

#-------------------------------------------------------#
$TRTREWRITE
PROGRAM = [V]CST_APRGAUPDATE : # Update
Gosub ENTETE_SUBPROG From ACLASUBCRUD
Gosub AJOUT_ACCES_SITE From ACLASUBCRUD

LIGNE = [L]ROOTCLA+".ASTALIN = [V]CST_AUPD" : Gosub ADDCLB

## A_Control
LIGNE ="Gosub "+PROGRAM+"_CONTROL"  : Gosub ADDCLB
Gosub ERREUR_ACTION_GOTO From ACLASUBCRUD
LIGNE = ""   : Gosub ADDCLB

DIF = 0
NIVEAU = 1
ISFOR = 0
NBFOR = 0
NIVPARCOURS = 0

LIGNE = "If !adxlog"   : Gosub ADDCLB
DIF +=1 : LIGNE = "Gosub "+PROGRAM+"_TR_"+[L]ROOTNAM : Gosub ADDCLB : DIF -= 1
LIGNE = "Else"   : Gosub ADDCLB
DIF +=1 : LIGNE = "Gosub "+PROGRAM+"_"+[L]ROOTNAM   : Gosub ADDCLB : DIF-= 1
LIGNE = "Endif"   : Gosub ADDCLB
Gosub ERREUR_ACTION_GOTO From ACLASUBCRUD
LIGNE = ""   : Gosub ADDCLB

LIGNE = "Gosub _"+PROGRAM+"_AFTER"  : Gosub ADDCLB

Gosub INIT_SNAPSHOT From ACLASUBCRUD

LIGNE = "$"+PROGRAM+"_END" : Gosub ADDCLB
LIGNE = "End"   : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB

Gosub A_CONTROL From ACLASUBMAJCRUD

Gosub TR_BEGIN From ACLASUBMAJCRUD

## Transaction
NIVEAU = 1
LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$"+PROGRAM+"_"+[L]ROOTNAM : Gosub ADDCLB

If ACLA.TYPCLA=2 : Gosub DELETE_FLGV : Endif

Call DECLARE_ACTION([L]ROOTCLA,PROGRAM+"_BEFORE","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
LIGNE = ""   : Gosub ADDCLB

If ACLA.ACLAK(NIVEAU).FLGU = 2 & ACLA.TYPCLA=2
 Gosub MAJSQL_RICHMEDIA From ACLASUBMAJCRUD
 LIGNE ="[L]ASTATUS = max([L]ASTATUS,func "+ACLA.ACLAV.TRTCRUD+"._MAJSQL_"+ACLA.ACLAK(NIVEAU).TABLNK+"("+[L]ROOTCLA+"))" :  Gosub ADDCLB
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Else
 Call DECLARE_ACTION([L]ROOTCLA,PROGRAM,"","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Endif
LIGNE = ""   : Gosub ADDCLB

If maxtab(ACLA.ACLAK)>1
 LIGNE = "For [L]A_TYPMAJ=[V]CST_ADEL,[V]CST_AUPD,[V]CST_ANEW" : Gosub ADDCLB
 DIF += 1
 NBFOR += 1
 ISFOR = 1
 Raz TABPARCOURS
 For I=2 To maxtab(ACLA.ACLAK)
  If !find(ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK-ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,TABPARCOURS)
   ATBDES    = ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK
   ATBORI    = ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI
   NIVPARCOURS = 2
   Call PRG_AINSERT(ATBORI,ATBDES,ACLA,PROGRAM,I,NIVPARCOURS,TABPARCOURS,NBFOR,ISFOR ,CLOB,DIF)  From ACLASUBMAJCRUD
  Endif
 Next I
 DIF -= 1
 LIGNE = "Next" : Gosub ADDCLB
 ISFOR = 0
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Endif

LIGNE = "" : Gosub ADDCLB
Call DECLARE_ACTION([L]ROOTCLA,PROGRAM+"_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD

NIVEAU = 1
LIGNE = "Return"  : Gosub ADDCLB
LIGNE = ""  : Gosub ADDCLB
Gosub ABORT From ACLASUBCRUD
LIGNE = "" : Gosub ADDCLB
NIVEAU = 1
LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
Gosub TRT_AFTERREWRITE_OK From ACLAREWRITECRUD
Return


#-------------------------------------------------------#
# On remet les status a ALL pour tout et on vire les DEL et NEWDEL
#-------------------------------------------------------#
$TRT_AFTERREWRITE_OK
LIGNE = "$_"+PROGRAM+"_AFTER" : Gosub ADDCLB
If PROGRAM<>"ADELETE"
 NIVPARCOURS = 1
 #106394 don't assign [V]CST_ALL if it's already [V]CST_ALL
 LIGNE = "If find("+[L]ROOTCLA+".ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0" : Gosub ADDCLB
 DIF += 1 : LIGNE = [L]ROOTCLA+".ASTALIN = [V]CST_ALL" : Gosub ADDCLB : DIF -=1
 LIGNE = "Endif"   : Gosub ADDCLB
 Call TRT_AFTERREWRITE_COLLECTION(ACLA,1,PROGRAM,"OK",0,NBFOR,NIVPARCOURS,LIGNE,DIF,CLOB) From ACLASUBMAJCRUD
 Raz LIGNE
 Raz TABPARCOURS,NBFOR
 For I=2 To maxtab(ACLA.ACLAK)
  If !find(ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK-ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,TABPARCOURS)
   ATBDES    = ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK
   ATBORI    = ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI
   NIVPARCOURS = 2
   Call PRG_AFTERREWRITE(ATBORI,ATBDES,ACLA,PROGRAM,"OK",I,NIVPARCOURS,TABPARCOURS,NBFOR ,CLOB,DIF) From ACLASUBMAJCRUD
  Endif
 Next I
Endif
NIVEAU = 1
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

$TRT_AFTERREWRITE_KO
Raz LIGNE
Raz TABPARCOURS,NBFOR
DIF =0
For I=2 To maxtab(ACLA.ACLAK)
 If !find(ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK-ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,TABPARCOURS)
  ATBDES    = ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK
  ATBORI    = ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI
  NIVPARCOURS = 2
  Call PRG_AFTERREWRITE(ATBORI,ATBDES,ACLA,PROGRAM,"KO",I,NIVPARCOURS,TABPARCOURS,NBFOR ,CLOB,DIF) From ACLASUBMAJCRUD
 Endif
Next I
NIVEAU = 1
LIGNE = "" : Gosub ADDCLB
Return

#-------------------------------------------------------#
$DELETE_FLGV
I=0
For J=1 To maxtab(ACLA.ACLAK)
 If ACLA.ACLAK(J).FLGV=2
  I= 1
 Endif
Next
If !I : Return : Endif
LIGNE = "Read [F:"+ACLA.ACLAK(1).ABRLNK+"]"+ACLA.ACLAK(1).CLELNK-"= "+ACLA.ACLAK(1).STRCUR+"."+ACLA.ACLAK(1).INDEX(1)
For I=2 To ACLA.ACLAK(1).NBRIND
 LIGNE += ";"+ACLA.ACLAK(1).STRCUR+"."+ACLA.ACLAK(1).INDEX(I)
Next I
Gosub ADDCLB
LIGNE = "If !fstat" : Gosub ADDCLB
DIF += 1
Raz TABPARCOURS
For I=2 To maxtab(ACLA.ACLAK)
 If !find(ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK-ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,TABPARCOURS)
  ATBDES    = ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK
  ATBORI    = ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI
  NIVPARCOURS = 2
  Call PRG_DELETE_FLGV(ATBORI,ATBDES,ACLA,PROGRAM,I,NIVPARCOURS,TABPARCOURS,NBFOR,CLOB,DIF)
 Endif
Next I
DIF -=1
LIGNE = "Endif"   : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Sous-programme recusive lecture
#-------------------------------------------------------#
Subprog PRG_DELETE_FLGV(ATBORI,ATBDES,ACLA,PROGRAM,NIVEAU,NIVPARCOURS,TABPARCOURS,NBFOR,CLOB,DIF)
Value    Char     ATBORI
Value    Char     ATBDES
Value    Instance ACLA Using C_ACLA
Value    Char     PROGRAM
Value    Integer  NIVEAU
Variable Integer  NIVPARCOURS
Variable Char     TABPARCOURS
Variable Integer  NBFOR
Variable Clbfile  CLOB
Variable Integer DIF

Local Char WCLASSE(80)

Gosub PRG_DEB From ACLAVALCRUD

LIGNE = "If [L]A_LEVEL>="+num$(NIVPARCOURS) : Gosub ADDCLB
DIF += 1


If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4) : #  For
 ISFOR = 1 : NBFOR +=1
 If ACLA.ACLAK(NIVEAU).EXPSEL<>"" : LIGNE = "Filter [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"] Where"-ACLA.ACLAK(NIVEAU).EXPSEL : Gosub ADDCLB : Endif
 LIGNE = "For ["+ACLA.ACLAK(NIVEAU).ABRLNK+"]"
 LIGNE += ACLA.ACLAK(NIVEAU).CLELNK-"Where"-ACLA.ACLAK(NIVEAU).INDEX(1)+"="+ACLA.ACLAK(NIVEAU).EXPR(1)
 If ACLA.ACLAK(NIVEAU).NBREXP> 1
  For I=2 To ACLA.ACLAK(NIVEAU).NBREXP
   LIGNE += " &"-ACLA.ACLAK(NIVEAU).INDEX(I)+"="+ACLA.ACLAK(NIVEAU).EXPR(I)
  Next I
 Endif
 Gosub ADDCLB
 DIF += 1
Elsif find(ACLA.ACLAK(NIVEAU).TYPLNK,1,3) : # Read
 ISFOR = 0
 If ACLA.ACLAK(NIVEAU).EXPSEL<>"" : LIGNE = "Filter [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"] Where"-ACLA.ACLAK(NIVEAU).EXPSEL : Gosub ADDCLB : Endif
 LIGNE = "[L]A_N"+num$(NIVPARCOURS)+"="
 If ACLA.ACLAK(NIVEAU).DIMCLALNK=2
  LIGNE += "0"
 Else
  LIGNE += "1"
 Endif
 Gosub ADDCLB
 LIGNE = "Read ["+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).CLELNK-"="-ACLA.ACLAK(NIVEAU).EXPR(1)
 If ACLA.ACLAK(NIVEAU).NBREXP> 1
  For I=2 To ACLA.ACLAK(NIVEAU).NBREXP
   LIGNE += ";"+ACLA.ACLAK(NIVEAU).EXPR(I)
  Next I
 Endif
 Gosub ADDCLB
 LIGNE = "If !fstat"  : Gosub ADDCLB
 DIF += 1
Endif

### Boucle récusivre vers les sous-structures
For I=1 To maxtab(ACLA.ACLAK)
 If ACLA.ACLAK(I).TABORI=func ACLASUBCRUD.TABLE(ATBDES) & ACLA.ACLAK(I).ABRORI=func ACLASUBCRUD.ABREV(ATBDES)
  NIVPARCOURS +=1
  Call PRG_DELETE_FLGV(ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK,ACLA,PROGRAM,I,NIVPARCOURS,TABPARCOURS,NBFOR,CLOB,DIF)
  NIVPARCOURS -=1
 Endif
Next I

If ACLA.ACLAK(NIVEAU).FLGV=2 & ACLA.ACLAK(NIVEAU).FLGA<>2
 LIGNE = "Delete [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"] Curr" : Gosub ADDCLB
 [L]WCLASSE = ACLA.ACLAK(1).STRCUR
 Gosub ERREUR_FSTA From ACLASUBMAJCRUD
Else
 LIGNE = "#" : Gosub ADDCLB
Endif

If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4)  : #  For
 DIF -= 1 : LIGNE = "Next"-ACLA.ACLAK(NIVEAU).ABRLNK : Gosub ADDCLB
 ISFOR = (find(ACLA.ACLAK(find(ACLA.ACLAK(NIVEAU).TABORI,ACLA.ACLAK(1..maxtab(ACLA.ACLAK)).TABLNK)).TYPLNK,2,4)) :  NBFOR -= 1
 LIGNE ='If [L]ASTATUS=[V]CST_AERROR :'
 If ISFOR>0
  LIGNE += 'Break'- string$(NBFOR>1,num$(NBFOR))
 Else
  LIGNE += "Return"
 Endif
 LIGNE += ' : Endif' : Gosub ADDCLB
Elsif find(ACLA.ACLAK(NIVEAU).TYPLNK,1,3) : # read
 DIF -= 1 : LIGNE = "Endif" : Gosub ADDCLB
Endif

If ACLA.ACLAK(NIVEAU).EXPSEL<>"" :  LIGNE = "Filter [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]" : Gosub ADDCLB : Endif

DIF -=1 : LIGNE = "Endif" :  Gosub ADDCLB

If DIF=0
 LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
Else
 LIGNE = "#-----------------------#" : Gosub ADDCLB
Endif

End
