#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion objet ACD
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ACD",GBIDC1,GBIDC2) From GOBJET
End

#-----------------------------------------------#
$ACTION
Case ACTION
 When "AVANT_OUVRE" : Gosub AVANT_OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "LIENS"       : Gosub LIENS
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Gosub CHANGE
Endcase
Return

#-----------------------------------------------#
$AVANT_OUVRE
If nomap<>GDOSX3
 Local File =GDOSX3+".ATEXTRA" [AXX]
Endif
Return

#-----------------------------------------------#
$SETBOUT
If nomap<>GDOSX3
 Call VIREBOUT(CHAINE,"CMA2H") From GOBJET
Endif
If CLECUR & REP<>"M" & VERROU & nomap=GDOSX3
 CHMEN += "4" : # Copie globale
Endif
Return

#-----------------------------------------------#
$LIENS
For I=1 To [M]NBLIG
 [M]NUMLIG(I-1) = I
 Call LECTEXTRA([M]INTRAN(I-1),"ACTLDEV","INTRAN",[M]COD,num$([M]NUMLIG(I-1)-1)) From ATEXTRA
Next I
Return

#-----------------------------------------------#
$CREATION
$MODIF
Call MAJTEXTRA([M]INTCOD,"ACTLDEV","INTCOD",[M]COD,"") From ATEXTRA
If GOK<1 : Return : Endif
For I=1 To [M]NBLIG
 Call MAJTEXTRA([M]INTRAN(I-1),"ACTLDEV","INTRAN",[M]COD,num$([M]NUMLIG(I-1)-1)) From ATEXTRA
 If GOK<1 : Break : Endif
Next I
If GOK<1 : Return : Endif
For I=1 To [M]NBLIG
 Call CHGTEXTRA("ACTLDEV","INTRAN",[M]COD,num$([M]NUMLIG(I-1)-1),[M]COD,num$(100+I)) From ATEXTRA
 If GOK<1 : Break : Endif
Next I
If GOK<1 : Return : Endif
Delete [AXX] Where CODFIC="ACTLDEV" & ZONE="INTRAN" & IDENT1=[M]COD & val(IDENT2)<=100
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
For I=1 To [M]NBLIG
 [M]NUMLIG(I-1) = I
 Call CHGTEXTRA("ACTLDEV","INTRAN",[M]COD,num$(100+I),[M]COD,num$([M]NUMLIG(I-1)-1)) From ATEXTRA
 If GOK<1 : Break : Endif
Next I
If GOK<1 : Return : Endif
Return

#-----------------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="ACTLDEV" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

#-----------------------------------------------#
$CHANGE
Update [AXX] Where CODFIC="ACTLDEV" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ACTLDEV"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#------------------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap 
 Local File ACTLDEV   [ACD1]
 Local File ATEXTRA   [AXX1]
Else 
 Local File =[M]DOSORG+".ACTLDEV"   [ACD1] 
 Local File =[M]DOSORG+".ATEXTRA"   [AXX1] 
Endif 
If [M]DOSDES=nomap 
 Local File ACTLDEV   [ACD2] 
 Local File ATEXTRA   [AXX2] 
Else 
 Local File =[M]DOSDES+".ACTLDEV"   [ACD2]
 Local File =[M]DOSDES+".ATEXTRA"   [AXX2] 
Endif 
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ACD1], [ACD2], [AXX1] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [ACD2]
 Delete [ACD2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACTLDEV" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACD2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ACD1]ACD0 Where COD=TABLE
  [F:ACD2] = [F:ACD1]
  Call COPTEXTRA("ACTLDEV","INTCOD",TABLE,"") From ATEXTRA
  If dim([F:ACD2]UPDUSR)>0 : [F:ACD2]UPDUSR = GUSER : Endif
  If dim([F:ACD2]UPDDAT)>0 : [F:ACD2]UPDDAT = date$ : Endif
  If dim([F:ACD2]UPDTIM)>0 : [F:ACD2]UPDTIM = time  : Endif
  For I=1 To [F:ACD1]NBLIG
   Call COPTEXTRA("ACTLDEV","INTRAN",TABLE,num$(I-1)) From ATEXTRA
  Next I
  Write [ACD2]
  If fstat
   GOK=0 : Call FSTA("ACD2") From GLOCK : Break
  Endif
 Next ACD1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
ROLLBACK
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#------------------------------------------------------------------------------------#
Subprog AS_TYP(VALEUR)
Variable Integer GVALEUR
If [M]NUMLIG(nolign-1)=0
 If [M]NBLIG=0
  [M]NUMLIG(nolign-1) = 1
 Else
  [M]NUMLIG(nolign-1) = max([M]NUMLIG(0..dim([M]NUMLIG)-1))+1
 Endif
Endif
End

Subprog C_RAN(VALEUR)
Variable Char VALEUR
Local Integer I , K , OK
Local Char    DEB(20) , FIN(20) , RANDEB(20) , RANFIN(20)
If VALEUR="" : End : Endif
K = instr(1,VALEUR,"-")
If !K
 GMESSAGE = mess(134,141,1) : # Erreur de SYNTAXE
 mkstat = 1 : End
Endif
RANDEB = left$(VALEUR,K-1)
RANFIN = right$(VALEUR,K+1)
OK = 1
For [ACD] Where COD<>[M]COD
 For I=1 To [F:ACD]NBLIG
  If [F:ACD]TYP(I-1)=[M]TYP(nolign-1)
   K = instr(1,[F:ACD]RAN(I-1),"-")
   If K
    DEB = left$([F:ACD]RAN(I-1),K-1)
    FIN = right$([F:ACD]RAN(I-1),K+1)
    Case [F:ACD]TYP(I-1)
     When 1 , 4 : # Objets/Champs
      OKPLG  = (RANDEB>=DEB & RANDEB<=FIN)
      OKPLG += (RANFIN>=DEB & RANFIN<=FIN)
      OKPLG += (DEB>=RANDEB & DEB<=RANFIN)
      OKPLG += (FIN>=RANDEB & FIN<=RANFIN)
      OKPLG = !OKPLG
     When 2 , 3 : # Menus locaux/Tables diverse
      OKPLG  = (val(RANDEB)>=val(DEB) & val(RANDEB)<=val(FIN))
      OKPLG += (val(RANFIN)>=val(DEB) & val(RANFIN)<=val(FIN))
      OKPLG += (val(DEB)>=val(RANDEB) & val(DEB)<=val(RANFIN))
      OKPLG += (val(FIN)>=val(RANDEB) & val(FIN)<=val(RANFIN))
      OKPLG = !OKPLG
    Endcase   
    If !OKPLG
     # Plage déjà utilisée
     MESSA = mess(207,133,1)-func AFNC.TEXTRA("ACTLDEV","INTCOD",[F:ACD]COD,"")-"("+[F:ACD]COD+")"
     MESSA += "\"+[F:ACD]RAN(I-1)-func AFNC.TEXTRA("ACTLDEV","INTRAN",[F:ACD]COD,num$(I-1))
     OK = 0 : Break 2
    Endif
   Endif 
  Endif
 Next I
Next ACB
If OK
 For I=1 To dim([M]RAN)
  If [M]TYP(I-1)=[M]TYP(nolign-1) & I<>nolign
   K = instr(1,[M]RAN(I-1),"-")
   If K
    DEB = left$([M]RAN(I-1),K-1)
    FIN = right$([M]RAN(I-1),K+1)
    Case [M]TYP(I-1)
     When 1 , 4 : # Objets/Champs
      OKPLG  = (RANDEB>=DEB & RANDEB<=FIN)
      OKPLG += (RANFIN>=DEB & RANFIN<=FIN)
      OKPLG += (DEB>=RANDEB & DEB<=RANFIN)
      OKPLG += (FIN>=RANDEB & FIN<=RANFIN)
      OKPLG = !OKPLG
     When 2 , 3 : # Menus locaux/Tables diverse
      OKPLG  = (val(RANDEB)>=val(DEB) & val(RANDEB)<=val(FIN))
      OKPLG += (val(RANFIN)>=val(DEB) & val(RANFIN)<=val(FIN))
      OKPLG += (val(DEB)>=val(RANDEB) & val(DEB)<=val(RANFIN))
      OKPLG += (val(FIN)>=val(RANDEB) & val(FIN)<=val(RANFIN))
      OKPLG = !OKPLG
    Endcase   
    If !OKPLG
     # Plage déjà utilisée/Ligne no
     MESSA = mess(207,133,1)-mess(61,100,1)-num$(I)
     OK = 0 : Break
    Endif
   Endif 
  Endif
 Next I
Endif
If !OK
 Call ERREUR(VALEUR-":"-MESSA) From GESECRAN
 mkstat = 1 : End
Endif
End
