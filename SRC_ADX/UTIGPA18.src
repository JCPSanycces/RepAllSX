#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UTIGPA18   Mise à jour champs FMI de la table MTOLINK                  #
# ---------------------------------------------------------------------- #
##########################################################################

#################################
Call MAJ_UTIGPA18
End

#################################
Subprog MAJ_UTIGPA18
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
Call OUVRE_TRACE("UTIGPA18: Update field FMI of MTOLINK table") From LECFIC
Call TEMPON("O") From GESECRAN
If DOSSIER<>"" Call EXE_UTIGPA18(DOSSIER) : Endif
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End


#################################
Subprog EXE_UTIGPA18(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIGPA18: Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:MTO])=0  Local File =DOSSIER+".MTOLINK"  [MTO] : Endif
If clalev([F:ORD])=0  Local File =DOSSIER+".ORDERS"   [ORD] : Endif

Call DEBTRANS From GLOCK
Trbegin [MTO]
For [MTO] 
    Readlock [MTO] Curr
    [F:MTO]FMIFLG = func MTOLINKLIB.IS_DIRECT_ORDER([F:MTO]STOFCY, [F:MTO]DEMTYP, [F:MTO]DEMNUM, [F:MTO]DEMLIN, [F:MTO]DEMSEQ) + 1
    Rewrite [MTO]
    If fstat
        Call ECR_TRACE("File MTOLINK"-[F:MTO]STOFCY-num$([F:MTO]DEMTYP)-[F:MTO]DEMNUM-num$([F:MTO]DEMLIN)-num$([F:MTO]DEMSEQ)+
&                       ", ERROR ="-num$(fstat),1) From GESECRAN
    Endif
Next

Commit

Call ECR_TRACE("UTIGPA18 : End Process",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call EXE_UTIGPA18(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

# test des ficheirs car motlink tronc commun
If filinfo(filpath("FIL","MTOLINK","fde",APPLI),0) < 0 : End : Endif
If filinfo(filpath("FIL","ORDERS","fde",APPLI),0) < 0 : End : Endif
Call EXE_UTIGPA18(APPLI)       
End



