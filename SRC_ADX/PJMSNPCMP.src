###################################################################################################
Subprog DISPLAY_COST_TYPES(NE, SELBUD)
Value Integer NE
Value Char SELBUD

Local Char WRKPIMNUM(GLONVPJ)
Local Char WRKDESC(GLONDCO)

  # Issue X3-80902 - 2018-04-06 by ALMON
  [M:PJSC2]PCCCOD(NE) = AVOID.ACHAR
  If NE = 0 Then
    [M:PJSC2]EXPFLG(NE) = [V]CST_AYES
    [M:PJSC2]ICO(NE)    = "Folder.gif"
    If SELBUD = AVOID.ACHAR Then
      [M:PJSC2]OBJDES(NE) = [F:PSW1]OPPNUM - func PIMPL_CSTD_PROGS.GET_PIMDESAXX(TECFINOVET, [F:PSW1]OPPNUM)
      [M:PJSC2]KEYC(NE)   = [F:PSW1]OPPNUM
    Else
      WRKPIMNUM = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(TECFINOVET.ACTX, [F:PSW1]OPPNUM, [F:PSW1]PBUCOD)
      WRKDESC = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(TECFINOVET, WRKPIMNUM)
      If WRKDESC = AVOID.ACHAR Then
        WRKDESC = mess(1066,2260,1)
      Endif
      [M:PJSC2]KEYC(NE)   = [F:PSW1]PBUCOD
      [M:PJSC2]OBJDES(NE) = [F:PSW1]PBUCOD - WRKDESC
      [M:PJSC2]BUDCOD(NE) = [F:PSW1]PBUCOD
    Endif
  Else
    [M:PJSC2]EXPFLG(NE) = [V]CST_ANO
    [M:PJSC2]PBUIMP(NE) = func PJMBUD_CSTD_PROGS.GET_PBUIMP([F:PSW1]OPPNUM, [F:PSW1]PBUCOD)
    If [F:PSW1]PCCCOD <> AVOID.ACHAR Then
      [M:PJSC2]PARKEY(NE) = [F:PSW1]PCCGRP
      [M:PJSC2]OBJDES(NE)   = [F:PSW1]PCCCOD - func PJMCOSTCTR_CSTD_PROGS.GET_DESAXX(TECFINOVET, [F:PSW1]PCCCOD)
      [M:PJSC2]KEYC(NE)     = [F:PSW1]PCCCOD + "~" + [F:PSW1]PCCCOD
      [M:PJSC2]ICO(NE)      = "Book.gif"
      [M:PJSC2]PCCCOD(NE)   = [F:PSW1]PCCCOD
    Else
      If [F:PSW1]PCCGRP <> AVOID.ACHAR Then
        [M:PJSC2]KEYC(NE)   = [F:PSW1]PCCGRP
        [M:PJSC2]PCCCOD(NE) = AVOID.ACHAR
        [M:PJSC2]PARKEY(NE) = [M:PJSC2]KEYC(0)
        [M:PJSC2]ICO(NE)    = "Folder.gif"
        [M:PJSC2]OBJDES(NE) = [F:PSW1]PCCGRP - func OPPOR_CSTD_OUTTOOLS.GET_ADI_LNGDES(TECFINOVET, "386", [F:PSW1]PCCGRP)
      Endif
    Endif
  Endif
End

###################################################################################################
Funprog COLGETFMT(INDEX)
Value Integer INDEX

Local Char SARENDRE(250)

  # Issue X3-80902 - 2018-04-06 by FGR/ALMON
  Raz SARENDRE
  If TECFINOVET <> null Then
    SARENDRE = func TECFINOVE_CSTD_PROGS.GET_FMT_DYN(TECFINOVET, INDEX, [M:PJSC0]SHOWAMT, [M:PJSC0]SHOWCUR, [M:PJSC0]SHOWQTY, [M:PJSC0]SHOWUOM)
  Endif
End SARENDRE

###################################################################################################
Funprog COLGETTIT(INDEX, ICMP)
Value Integer INDEX
Value Integer ICMP

Local Char SARENDRE(250)

  # Issue X3-80902 - 2018-04-06 by FGR/ALMON
  SARENDRE = func TECFINOVE_CSTD_PROGS.COL_GET_TITLE(TECFINOVET, INDEX)
  Case ICMP
    When 1
      SARENDRE -= mess(1085,2260,1) #"N"
    When 2
      SARENDRE -= mess(1086,2260,1) #"N-1"
    When 3
      SARENDRE -= mess(1087,2260,1) #"Variance"
  Endcase
End SARENDRE

###################################################################################################
Subprog DSPCS_WITH_STYLE()
Local Integer NI

  # Issue X3-93182 - 2018-06-05 by ALMON : Display column styling with new requirements
  Affzo [M:PJSC1]10
  For NI = 0 To [M:PJSC1]NBLIG-1
    If [M:PJSC1]PBUIMP(NI) = [V]CST_AYES Then
      Chgstl [M:PJSC1]NBLIG(NI)   With ""
      Chgstl [M:PJSC1]QTY1N1(NI)  With "PJMBUD"
