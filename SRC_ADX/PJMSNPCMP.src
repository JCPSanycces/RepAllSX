#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# PJMSNPCMP
###################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    When "BOUTON"                      : Gosub BOUTON
    When "FIN"                         : Gosub FIN        # Issue X3-80902 - 2018-04-06 by ALMON : Clear Work table
    When Default
  Endcase
Return

###################################################################################################
$OUVRE
  NAVIG = GACTION
  GOK = 1
Return

###################################################################################################
$DEBUT
Global Instance TECFINOVET Using C_TECFINOVE   # Needed to load titles
Global Instance TECFINOVE Using C_TECFINOVE

Local Integer IRET

  # PARAM Work
  # ----------
  Raz [M:PJSC0]
  [M:PJSC0]SHOWQTY  = [V]CST_AYES
  [M:PJSC0]SHOWAMT  = [V]CST_AYES
  [M:PJSC0]CURRSIT  = [V]CST_AYES
  #[M:PJSC0]KEYEXTN  = AVOID.ACHAR
  #[M:PJSC0]SNPCODN  = AVOID.ACHAR
  Diszo [M:PJSC0]KEYEXTN
  If PARAM(1) <> AVOID.ACHAR Then
    [M:PJSC0]CALLBY = "SNP"
    [M:PJSC0]KEYEXTN1 = PARAM(1)
    [M:PJSC0]OPPNUM   = PARAM(2)
    [M:PJSC0]SNPCODN1 = PARAM(3)
    [M:PJSC0]KEYEXTN  = AVOID.ACHAR
    [M:PJSC0]SNPCODN  = AVOID.ACHAR
    [M:PJSC0]CURRSIT  = [V]CST_AYES
    Diszo [M:PJSC0]KEYEXTN1
  Elsif PARAM(2) <> AVOID.ACHAR Then
    [M:PJSC0]CALLBY = "PJM"
    [M:PJSC0]KEYEXTN1 = AVOID.ACHAR
    [M:PJSC0]SNPCODN1 = AVOID.ACHAR
    [M:PJSC0]OPPNUM   = PARAM(2)
    [M:PJSC0]KEYEXTN  = AVOID.ACHAR
    [M:PJSC0]SNPCODN  = AVOID.ACHAR
    [M:PJSC0]CURRSIT  = [V]CST_AYES
  Endif
  # -------------------------------------------------------
  If [M:PJSC0]KEYEXTN1 <> AVOID.ACHAR Then
    # Issue X3-107215 - 2018-10-05 by FGR : BEGIN : Undo X3-106683 which is wrong !
    ## X3-106683 Enhancement ALMON 09-13-2018 : Add QTY and AMT as show params
    #If func SUBPJMSNP.GET_SNAPSHOT_HEADER([M:PJSC0]KEYEXTN1, [M:PJSC0]OPPNUM, [M:PJSC0]SNPCODN1, [M:PJSC0]SHOWGRP, [M:PJSC0]SHOWUOM, [M:PJSC0]SHOWCUR, [M:PJSC0]SNPDTEN1,
    #&                                         [M:PJSC0]SHOWQTY, [M:PJSC0]SHOWAMT, GMESSAGE) = [V]CST_AERROR Then
    #  GERR = 1
    #  GOK = 0
    #  FIN = 1
    #  Return
    #Endif
    If func SUBPJMSNP.GET_SNAPSHOT_HEADER([M:PJSC0]KEYEXTN1, [M:PJSC0]OPPNUM, [M:PJSC0]SNPCODN1, [M:PJSC0]SHOWGRP, [M:PJSC0]SHOWUOM, [M:PJSC0]SHOWCUR, [M:PJSC0]SNPDTEN1,
&                                         GMESSAGE) = [V]CST_AERROR Then
      GERR = 1
      GOK = 0
      FIN = 1
      Return
    Endif
    IRET = func TECFINOVE_CSTD_PROGS.GET_DEFAULT_SHOWQTY_SHOWAMT(GACTX, [M:PJSC0]SHOWGRP, [M:PJSC0]SHOWQTY, [M:PJSC0]SHOWAMT)
    # Issue X3-107215 - 2018-10-05 by FGR : END
  Endif
  #[M:PJSC0]CURRSIT = [V]CST_ANO
  Call AM_CURRSIT([M:PJSC0]CURRSIT)
  # -------------------------------------------------------
  [M:PJSC0]PRONUM = num$(getUuid)
  # -------------------------------------------------------
  Affzo [M:PJSC0]1-99
Return

###################################################################################################
$BOUTON
  Case BOUT
    When "1"
      If func VALIDATE_KEYEXTN([M:PJSC0]KEYEXTN) = [V]CST_AERROR Then
        GERR = 1
        GOK = 1
        Return
      Endif
      Call LOAD_TREE(TECFINOVE, [M:PJSC0]PRONUM)
      If GERR = 1 Then
        Return
      Endif
  Endcase
Return

###################################################################################################
$FIN
Local Integer IRET

  # Issue X3-80902 - 2018-04-06 by ALMON : Clear Work table
  If TECFINOVE <> null Then
    IRET = fmet TECFINOVE.DELETE_ALL()
    FreeGroup TECFINOVE
  Endif
  Kill TECFINOVE
  If TECFINOVET <> null Then
    FreeGroup TECFINOVET
  Endif
  Kill TECFINOVET
  Call DELETE_WORK_TABLES([M:PJSC0]PRONUM)
Return

###################################################################################################
# Screens fields
###################################################################################################
# PJMSNPCMP0
###################################################################################################
Subprog AM_KEYEXTN1(VALEUR)
Variable Char    VALEUR()

Local Integer IRET # Issue X3-107215 - 2018-10-05 by FGR

  If VALEUR <> AVOID.ACHAR Then
    # Issue X3-107215 - 2018-10-05 by FGR : BEGIN : Undo X3-106683 which is wrong !
    ## X3-106683 Enhancement ALMON 09-13-2018 : Add QTY and AMT as show params
    #If func SUBPJMSNP.GET_SNAPSHOT_HEADER(VALEUR, [M:PJSC0]OPPNUM, [M:PJSC0]SNPCODN1, [M:PJSC0]SHOWGRP, [M:PJSC0]SHOWUOM, [M:PJSC0]SHOWCUR, [M:PJSC0]SNPDTEN1,
#&                                         [M:PJSC0]SHOWQTY, [M:PJSC0]SHOWAMT,GMESSAGE) = [V]CST_AERROR Then
    #  GERR = 1
    #  GOK = 1
    #  mkstat = 2
    #  End
    #Endif
    If func SUBPJMSNP.GET_SNAPSHOT_HEADER(VALEUR, [M:PJSC0]OPPNUM, [M:PJSC0]SNPCODN1, [M:PJSC0]SHOWGRP, [M:PJSC0]SHOWUOM, [M:PJSC0]SHOWCUR, [M:PJSC0]SNPDTEN1,
&                                         GMESSAGE) = [V]CST_AERROR Then
      GERR = 1
      GOK = 1
      mkstat = 2
      End
    Endif
    IRET = func TECFINOVE_CSTD_PROGS.GET_DEFAULT_SHOWQTY_SHOWAMT(GACTX, [M:PJSC0]SHOWGRP, [M:PJSC0]SHOWQTY, [M:PJSC0]SHOWAMT)
    # Issue X3-107215 - 2018-10-05 by FGR : END
    If func VALIDATE_KEYEXTN([M:PJSC0]KEYEXTN) = [V]CST_AERROR Then
      mkstat = 2
      End
    Endif
  Endif
  Affzo [M:PJSC0]1-99 # X3-106683 Enhancement ALMON 09-13-2018 : Refresh to show defaults
End

###################################################################################################
Subprog AM_KEYEXTN(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> AVOID.ACHAR Then
    If func VALIDATE_KEYEXTN(VALEUR) = [V]CST_AERROR Then
      mkstat = 2
      End
    Endif
    [M:PJSC0]CURRSIT = [V]CST_ANO
  Else
    [M:PJSC0]CURRSIT = [V]CST_AYES
    Raz [M:PJSC0]SNPCODN
    Raz [M:PJSC0]SNPDTEN
    Diszo [M:PJSC0]KEYEXTN
  Endif
End

###################################################################################################
Subprog AM_CURRSIT(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_ANO Then
    Actzo [M:PJSC0]KEYEXTN
  Else
    Raz [M:PJSC0]KEYEXTN
    Raz [M:PJSC0]SNPCODN
    Raz [M:PJSC0]SNPDTEN
    Diszo [M:PJSC0]KEYEXTN
  Endif
  Affzo [M:PJSC0]1-99
End

###################################################################################################
Subprog AM_SHOWQTY(VALEUR)
Variable Integer    VALEUR()

  [M:PJSC0]SHOWQTY = VALEUR
  If TECFINOVET <> null Then
    # Issue X3-106367 - 2018-08-28 by FGR
    #Affzo [M:PJSC1]1-99
    #Affzo [M:PJSC2]1-99
    Call CHGSTL_PJSC1()
    Call CHGSTL_PJSC2()
    # Issue X3-106367 - 2018-08-28 by FGR
  Endif
End

###################################################################################################
Subprog AM_SHOWAMT(VALEUR)
Variable Integer    VALEUR()

  [M:PJSC0]SHOWAMT = VALEUR
  If TECFINOVET <> null Then
    # Issue X3-106367 - 2018-08-28 by FGR
    #Affzo [M:PJSC1]1-99
    #Affzo [M:PJSC2]1-99
    Call CHGSTL_PJSC1()
    Call CHGSTL_PJSC2()
    # Issue X3-106367 - 2018-08-28 by FGR
  Endif
End

###################################################################################################
# PJMSNPCMP1
###################################################################################################
# Issue X3-87311 - 2018-05-22 by ALMON : Display Cost Types for Selected Budget
Subprog IB_NBLIG
  If [M:PJSC1]OBJDES(nolign-1) <> AVOID.ACHAR and TECFINOVE <> null Then
    Call LOAD_TREE_PJSC2(TECFINOVE, [M:PJSC0]PRONUM, [M:PJSC1]BUDCOD(nolign-1))
  Endif
End

###################################################################################################
# Subroutines
###################################################################################################
Funprog VALIDATE_KEYEXTN(SKEYEXTN)
Value Char SKEYEXTN

Local Integer IRET
Local Char RETPRJ(GLONPIM)
Local Char RETSNP(GLONSNP)
Local Char RETGRP(GLONADI)
Local Char RETUOM(GLONUOM)
Local Char RETCUR(GLONCUR)
Local Date WRKSDTE

  IRET = [V]CST_AOK
  Raz [M:PJSC0]SNPCODN
  Raz [M:PJSC0]SNPDTEN
  If SKEYEXTN <> AVOID.ACHAR Then
    [M:PJSC0]KEYEXTN = SKEYEXTN
    # Issue X3-107215 - 2018-10-05 by FGR : BEGIN : Undo X3-106683 which is wrong !
    ## X3-106683 Enhancement ALMON 09-13-2018 : Add QTY and AMT as show params
    #If func SUBPJMSNP.GET_SNAPSHOT_HEADER(SKEYEXTN, RETPRJ, RETSNP, RETGRP, RETUOM, RETCUR, WRKSDTE, [M:PJSC0]SHOWQTY, [M:PJSC0]SHOWAMT, GMESSAGE) = [V]CST_AERROR Then
    #  IRET = [V]CST_AERROR
    #  GERR = 1
    #  GOK = 1
    #Endif
    If func SUBPJMSNP.GET_SNAPSHOT_HEADER(SKEYEXTN, RETPRJ, RETSNP, RETGRP, RETUOM, RETCUR, WRKSDTE, GMESSAGE) = [V]CST_AERROR Then
      IRET = [V]CST_AERROR
      GERR = 1
      GOK = 1
    Endif
    # Issue X3-107215 - 2018-10-05 by FGR : END
    If IRET = [V]CST_AOK and RETGRP <> [M:PJSC0]SHOWGRP Then
      IRET = [V]CST_AERROR
      GERR = 1
      GOK = 1
      GMESSAGE = func AFNC.MES(mess(1057,2260,1),RETGRP)
    Endif
    If IRET = [V]CST_AOK and RETUOM <> [M:PJSC0]SHOWUOM Then
      IRET = [V]CST_AERROR
      GERR = 1
      GOK = 1
      GMESSAGE = func AFNC.MES(mess(1058,2260,1),RETUOM)
    Endif
    If IRET = [V]CST_AOK and RETCUR <> [M:PJSC0]SHOWCUR Then
      IRET = [V]CST_AERROR
      GERR = 1
      GOK = 1
      GMESSAGE = func AFNC.MES(mess(1059,2260,1),RETCUR)
    Endif
    If IRET = [V]CST_AOK Then
      [M:PJSC0]SNPCODN = RETSNP
      [M:PJSC0]SNPDTEN = WRKSDTE
    Endif
  Endif
End IRET

###################################################################################################
Subprog LOAD_CLASS_TECFINOVE(TECFINOVE, IEXTRACT)
Variable Instance TECFINOVE Using C_TECFINOVE
Value Integer IEXTRACT

Local Integer IRET

  # Issue X3-80902 - 2018-04-06 by ALMON
  If IEXTRACT = [V]CST_AYES Then
    If TECFINOVE <> null Then
      IRET = fmet TECFINOVE.DELETE_ALL()
      FreeGroup TECFINOVE
    Endif
  Endif
  TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
  TECFINOVE.ISBUDUPD = [V]CST_ANO
  TECFINOVE.SHOWGRP  = [M:PJSC0]SHOWGRP
  # X3-106683 ENHANCEMENT ALMON 09-13-2018 : Start : Load QTY and AMT defaults
  #TECFINOVE.SHOWQTY  = [V]CST_AYES
  #TECFINOVE.SHOWMNT  = [V]CST_AYES
  TECFINOVE.SHOWQTY  = [M:PJSC0]SHOWQTY
  TECFINOVE.SHOWMNT  = [M:PJSC0]SHOWAMT
  # X3-106683 ENHANCEMENT ALMON 09-13-2018 : End
  TECFINOVE.OPPNUM   = [M:PJSC0]OPPNUM
  TECFINOVE.CUR      = [M:PJSC0]SHOWCUR
  TECFINOVE.UOM      = [M:PJSC0]SHOWUOM
  TECFINOVE.ADVINCL  = [V]CST_ANO
  TECFINOVE.MULPRJ   = [V]CST_ANO
  TECFINOVE.PBUCOD   = ""
  #
  If IEXTRACT = [V]CST_AYES Then
    IRET = fmet TECFINOVE.EXTRACT_ALL()
  Else
    IRET = fmet TECFINOVE.TITLE_EXTRACT()
  Endif
  If IRET <> [V]CST_AOK Then
    IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(TECFINOVE, GMESSAGE)
    GERR = 1
    GOK = 0
    End
  Endif
End

###################################################################################################
Subprog DELETE_WORK_TABLES(SPRONUM)
Value Char SPRONUM

Local Integer IADXLOG

  # Issue X3-80902 - 2018-04-06 by ALMON
  # Issue X3-80904 - 2018-04-11 by ALMON
  Local File PJMSNPW0 [PSW0]
  Local File PJMSNPW1 [PSW1]
  # ------------------------
  IADXLOG = (adxlog = 1)
  If IADXLOG = [V]CST_AFALSE Then
    Trbegin [PSW0]
  Endif
  # ------------------------
  Delete [PSW0] Where [F:PSW0]PRONUM = SPRONUM or [F:PSW0]CREDATTIM < date$-2
  If fstat <> [V]CST_AOK Then
    GERR = 1
    GOK = 1
    GMESSAGE = func AFNC.MES(mess(1065,2260,1), [M:PJSC0]PRONUM)
  Else
    Delete [PSW1] Where [F:PSW1]PRONUM = SPRONUM or [F:PSW1]CREDATTIM < date$-2
    If fstat <> [V]CST_AOK Then
      GERR = 1
      GOK = 1
      GMESSAGE = func AFNC.MES(mess(1065,2260,1), [M:PJSC1]PRONUM)
    Endif
  Endif
  # ------------------------
  If IADXLOG = [V]CST_AFALSE Then
    If GERR = 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

###################################################################################################
Subprog LOAD_WORK_TABLES(TECFINOVE, SPRONUM)
Variable Instance TECFINOVE Using C_TECFINOVE
Value Char SPRONUM

Local Integer IADXLOG

  # Issue X3-80902 - 2018-04-06 by ALMON
  Local File PJMSNPW0 [PSW0]
  Local File PJMSC [PJSC]
  Local File PJMFINOVRRPT [PJR1]
  # Issue X3-80904 - 2018-04-11 by ALMON : Populate Work table PSW1 with Cost Types
  Local File PJMSNPW1 [PSW1]
  Local File PJMSCCT  [PJCT]
  Local File PJMFINCTORPT [PJR2]
  # ------------------------------------------------------------------------------------
  IADXLOG = (adxlog = 1)
  If IADXLOG = [V]CST_AFALSE Then
    Trbegin [PSW0]
  Endif
  # ------------------------------------------------------------------------------------
  Call DELETE_WORK_TABLES(SPRONUM)
  # ------------------------------------------------------------------------------------
  If GERR <> 1 Then
    Call LOAD_CLASS_TECFINOVE(TECFINOVET, [V]CST_ANO)
  Endif
  # ------------------------------------------------------------------------------------
  If GERR <> 1 Then
    # MANAGE CASE N PART
    If [M:PJSC0]CURRSIT = [V]CST_AYES Then
      # Compute TECFINOVE values
      Call LOAD_CLASS_TECFINOVE(TECFINOVE, [V]CST_AYES)
    Endif
  Endif
  #
  If GERR <> 1 Then
    If [M:PJSC0]CURRSIT = [V]CST_AYES Then
      Filter [PJSC] Where [F:PJSC]PSCSSS = TECFINOVE.SESSION
      For [PJSC]
        Read [PSW0]PSW0=SPRONUM;[F:PJSC]OPPNUM;[F:PJSC]PBUPAE;[F:PJSC]PBUCOD
        If fstat Then
          Raz [F:PSW0]
          [F:PSW0]PRONUM = SPRONUM
          [F:PSW0]OPPNUM = [F:PJSC]OPPNUM
          [F:PSW0]PBUPAE = [F:PJSC]PBUPAE
          [F:PSW0]PBUCOD = [F:PJSC]PBUCOD
          [F:PSW0]PBUSOR = [F:PJSC]PBUSOR        # Issue X3-91329 - 2018-06-01 by FGR
          #
          [F:PSW0]OPPNUMN = [F:PJSC]OPPNUM
          [F:PSW0]PBUPAEN = [F:PJSC]PBUPAE
          [F:PSW0]PBUCODN = [F:PJSC]PBUCOD
          [F:PSW0]PBUSORN = [F:PJSC]PBUSOR       # Issue X3-91329 - 2018-06-01 by FGR
          #
          Write [PSW0]
          If fstat <> [V]CST_AOK Then
            GMESSAGE = func AFNC.MES(mess(1064,2260,1),[F:PJR1]PBUCOD)
            GERR = 1
            GOK = 0
            Break
          Endif
        Else
          [F:PSW0]OPPNUMN = [F:PJSC]OPPNUM
          [F:PSW0]PBUPAEN = [F:PJSC]PBUPAE
          [F:PSW0]PBUCODN = [F:PJSC]PBUCOD
          [F:PSW0]PBUSORN = [F:PJSC]PBUSOR       # Issue X3-91329 - 2018-06-01 by FGR
          #
          Rewrite [PSW0]
          If fstat <> [V]CST_AOK Then
            GMESSAGE = func AFNC.MES(mess(1064,2260,1),[F:PJR1]PBUCOD)
            GERR = 1
            GOK = 0
            Break
          Endif
        Endif
      Next
      Filter [PJSC]
    Else
      Filter [PJR1] Where [F:PJR1]KEYEXT = [M:PJSC0]KEYEXTN
      For [PJR1]
        Read [PSW0]PSW0=SPRONUM;[F:PJR1]OPPNUM;[F:PJR1]PBUPAE;[F:PJR1]PBUCOD
        If fstat Then
          Raz [F:PSW0]
          [F:PSW0]PRONUM = SPRONUM
          [F:PSW0]OPPNUM = [F:PJR1]OPPNUM
          [F:PSW0]PBUPAE = [F:PJR1]PBUPAE
          [F:PSW0]PBUCOD = [F:PJR1]PBUCOD
          [F:PSW0]PBUSOR = [F:PJR1]PBUSOR        # Issue X3-91329 - 2018-06-01 by FGR
          #
          [F:PSW0]OPPNUMN = [F:PJR1]OPPNUM
          [F:PSW0]PBUPAEN = [F:PJR1]PBUPAE
          [F:PSW0]PBUCODN = [F:PJR1]PBUCOD
          [F:PSW0]PBUSORN = [F:PJR1]PBUSOR       # Issue X3-91329 - 2018-06-01 by FGR
          #
          Write [PSW0]
          If fstat <> [V]CST_AOK Then
            GMESSAGE = func AFNC.MES(mess(1064,2260,1),[F:PJR1]PBUCOD)
            GERR = 1
            GOK = 0
            Break
          Endif
        Else
          [F:PSW0]OPPNUMN = [F:PJR1]OPPNUM
          [F:PSW0]PBUPAEN = [F:PJR1]PBUPAE
          [F:PSW0]PBUCODN = [F:PJR1]PBUCOD
          [F:PSW0]PBUSORN = [F:PJR1]PBUSOR       # Issue X3-91329 - 2018-06-01 by FGR
          #
          Rewrite [PSW0]
          If fstat <> [V]CST_AOK Then
            GMESSAGE = func AFNC.MES(mess(1064,2260,1),[F:PJR1]PBUCOD)
            GERR = 1
            GOK = 0
            Break
          Endif
        Endif
      Next
      Filter [PJR1]
    Endif
  Endif
  # ------------------------------------------------------------------------------------
  If GERR <> 1 Then
    # MANAGE CASE N-1 PART
    Filter [PJR1] Where [F:PJR1]KEYEXT = [M:PJSC0]KEYEXTN1
    For [PJR1]
      Read [PSW0]PSW0=SPRONUM;[F:PJR1]OPPNUM;[F:PJR1]PBUPAE;[F:PJR1]PBUCOD
      If fstat Then
        Raz [F:PSW0]
        [F:PSW0]PRONUM = SPRONUM
        [F:PSW0]OPPNUM = [F:PJR1]OPPNUM
        [F:PSW0]PBUPAE = [F:PJR1]PBUPAE
        [F:PSW0]PBUCOD = [F:PJR1]PBUCOD
        [F:PSW0]PBUSOR = [F:PJR1]PBUSOR          # Issue X3-91329 - 2018-06-01 by FGR
        #
        [F:PSW0]OPPNUMN1 = [F:PJR1]OPPNUM
        [F:PSW0]PBUPAEN1 = [F:PJR1]PBUPAE
        [F:PSW0]PBUCODN1 = [F:PJR1]PBUCOD
        [F:PSW0]PBUSORN1 = [F:PJR1]PBUSOR        # Issue X3-91329 - 2018-06-01 by FGR
        #
        Write [PSW0]
        If fstat <> [V]CST_AOK Then
          GMESSAGE = func AFNC.MES(mess(1064,2260,1),[F:PJR1]PBUCOD)
          GERR = 1
          GOK = 0
          Break
        Endif
      Else
        [F:PSW0]OPPNUMN1 = [F:PJR1]OPPNUM
        [F:PSW0]PBUPAEN1 = [F:PJR1]PBUPAE
        [F:PSW0]PBUCODN1 = [F:PJR1]PBUCOD
        [F:PSW0]PBUSORN1 = [F:PJR1]PBUSOR        # Issue X3-91329 - 2018-06-01 by FGR
        #
        Rewrite [PSW0]
        If fstat <> [V]CST_AOK Then
          GMESSAGE = func AFNC.MES(mess(1064,2260,1),[F:PJR1]PBUCOD)
          GERR = 1
          GOK = 0
          Break
        Endif
      Endif
    Next
    Filter [PJR1]
  Endif
  # ------------------------------------------------------------------------------------
  If GERR <> 1 Then
    # MANAGE CASE N PART
    If [M:PJSC0]CURRSIT = [V]CST_AYES Then
      Filter [PJCT] Where [F:PJCT]PSCSSS = TECFINOVE.SESSION
      For [PJCT]
        Read [PSW1]PSW1=SPRONUM;[F:PJCT]OPPNUM;[F:PJCT]PBUPAE;[F:PJCT]PBUCOD;[F:PJCT]PCCGRPSOR;[F:PJCT]PCCGRP;[F:PJCT]PCCCOD
        If fstat Then
          Raz [F:PSW1]
          [F:PSW1]PRONUM    = SPRONUM
          [F:PSW1]OPPNUM    = [F:PJCT]OPPNUM
          [F:PSW1]PBUPAE    = [F:PJCT]PBUPAE
          [F:PSW1]PBUCOD    = [F:PJCT]PBUCOD
          [F:PSW1]PCCGRPSOR = [F:PJCT]PCCGRPSOR
          [F:PSW1]PCCGRP    = [F:PJCT]PCCGRP
          [F:PSW1]PCCCOD    = [F:PJCT]PCCCOD
          #
          [F:PSW1]OPPNUMN    = [F:PJCT]OPPNUM
          [F:PSW1]PBUPAEN    = [F:PJCT]PBUPAE
          [F:PSW1]PBUCODN    = [F:PJCT]PBUCOD
          [F:PSW1]PCCGRPSORN = [F:PJCT]PCCGRPSOR
          [F:PSW1]PCCGRPN    = [F:PJCT]PCCGRP
          [F:PSW1]PCCCODN    = [F:PJCT]PCCCOD
          #
          Write [PSW1]
          If fstat <> [V]CST_AOK Then
            GMESSAGE = func AFNC.MES(mess(1064,2260,1),[F:PJR2]PBUCOD)
            GERR = 1
            GOK = 0
            Break
          Endif
        Else
          [F:PSW1]OPPNUMN    = [F:PJCT]OPPNUM
          [F:PSW1]PBUPAEN    = [F:PJCT]PBUPAE
          [F:PSW1]PBUCODN    = [F:PJCT]PBUCOD
          [F:PSW1]PCCGRPSORN = [F:PJCT]PCCGRPSOR
          [F:PSW1]PCCGRPN    = [F:PJCT]PCCGRP
          [F:PSW1]PCCCODN    = [F:PJCT]PCCCOD
          #
          Rewrite [PSW1]
          If fstat <> [V]CST_AOK Then
            GMESSAGE = func AFNC.MES(mess(1064,2260,1),[F:PJR2]PBUCOD)
            GERR = 1
            GOK = 0
            Break
          Endif
        Endif
      Next
      Filter [PJCT]
    Else
      Filter [PJR2] Where [F:PJR2]KEYEXT = [M:PJSC0]KEYEXTN
      For [PJR2]
        Read [PSW1]PSW1=SPRONUM;[F:PJR2]OPPNUM;[F:PJR2]PBUPAE;[F:PJR2]PBUCOD;[F:PJR2]PCCGRPSOR;[F:PJR2]PCCGRP;[F:PJR2]PCCCOD
        If fstat Then
          Raz [F:PSW1]
          [F:PSW1]PRONUM    = SPRONUM
          [F:PSW1]OPPNUM    = [F:PJR2]OPPNUM
          [F:PSW1]PBUPAE    = [F:PJR2]PBUPAE
          [F:PSW1]PBUCOD    = [F:PJR2]PBUCOD
          [F:PSW1]PCCGRPSOR = [F:PJR2]PCCGRPSOR
          [F:PSW1]PCCGRP    = [F:PJR2]PCCGRP
          [F:PSW1]PCCCOD    = [F:PJR2]PCCCOD
          #
          [F:PSW1]OPPNUMN    = [F:PJR2]OPPNUM
          [F:PSW1]PBUPAEN    = [F:PJR2]PBUPAE
          [F:PSW1]PBUCODN    = [F:PJR2]PBUCOD
          [F:PSW1]PCCGRPSORN = [F:PJR2]PCCGRPSOR
          [F:PSW1]PCCGRPN    = [F:PJR2]PCCGRP
          [F:PSW1]PCCCODN    = [F:PJR2]PCCCOD
          #
          Write [PSW1]
          If fstat <> [V]CST_AOK Then
            GMESSAGE = func AFNC.MES(mess(1064,2260,1),[F:PJR2]PBUCOD)
            GERR = 1
            GOK = 0
            Break
          Endif
        Else
          [F:PSW1]OPPNUMN    = [F:PJR2]OPPNUM
          [F:PSW1]PBUPAEN    = [F:PJR2]PBUPAE
          [F:PSW1]PBUCODN    = [F:PJR2]PBUCOD
          [F:PSW1]PCCGRPSORN = [F:PJR2]PCCGRPSOR
          [F:PSW1]PCCGRPN    = [F:PJR2]PCCGRP
          [F:PSW1]PCCCODN    = [F:PJR2]PCCCOD
          #
          Rewrite [PSW1]
          If fstat <> [V]CST_AOK Then
            GMESSAGE = func AFNC.MES(mess(1064,2260,1),[F:PJR2]PBUCOD)
            GERR = 1
            GOK = 0
            Break
          Endif
        Endif
      Next
      Filter [PJR2]
    Endif
  Endif
  # ------------------------------------------------------------------------------------
  If GERR <> 1 Then
    # MANAGE CASE N-1 PART
    Filter [PJR2] Where [F:PJR2]KEYEXT = [M:PJSC0]KEYEXTN1
    For [PJR2]
      Read [PSW1]PSW1=SPRONUM;[F:PJR2]OPPNUM;[F:PJR2]PBUPAE;[F:PJR2]PBUCOD;[F:PJR2]PCCGRPSOR;[F:PJR2]PCCGRP;[F:PJR2]PCCCOD
      If fstat Then
        Raz [F:PSW1]
        [F:PSW1]PRONUM    = SPRONUM
        [F:PSW1]OPPNUM    = [F:PJR2]OPPNUM
        [F:PSW1]PBUPAE    = [F:PJR2]PBUPAE
        [F:PSW1]PBUCOD    = [F:PJR2]PBUCOD
        [F:PSW1]PCCGRPSOR = [F:PJR2]PCCGRPSOR
        [F:PSW1]PCCGRP    = [F:PJR2]PCCGRP
        [F:PSW1]PCCCOD    = [F:PJR2]PCCCOD
        #
        [F:PSW1]OPPNUMN1    = [F:PJR2]OPPNUM
        [F:PSW1]PBUPAEN1    = [F:PJR2]PBUPAE
        [F:PSW1]PBUCODN1    = [F:PJR2]PBUCOD
        [F:PSW1]PCCGRPSORN1 = [F:PJR2]PCCGRPSOR
        [F:PSW1]PCCGRPN1    = [F:PJR2]PCCGRP
        [F:PSW1]PCCCODN1    = [F:PJR2]PCCCOD
        #
        Write [PSW1]
        If fstat <> [V]CST_AOK Then
          GMESSAGE = func AFNC.MES(mess(1064,2260,1),[F:PJR2]PBUCOD)
          GERR = 1
          GOK = 0
          Break
        Endif
      Else
        [F:PSW1]OPPNUMN1    = [F:PJR2]OPPNUM
        [F:PSW1]PBUPAEN1    = [F:PJR2]PBUPAE
        [F:PSW1]PBUCODN1    = [F:PJR2]PBUCOD
        [F:PSW1]PCCGRPSORN1 = [F:PJR2]PCCGRPSOR
        [F:PSW1]PCCGRPN1    = [F:PJR2]PCCGRP
        [F:PSW1]PCCCODN1    = [F:PJR2]PCCCOD
        #
        Rewrite [PSW1]
        If fstat <> [V]CST_AOK Then
          GMESSAGE = func AFNC.MES(mess(1064,2260,1),[F:PJR2]PBUCOD)
          GERR = 1
          GOK = 0
          Break
        Endif
      Endif
    Next
    Filter [PJR2]
  Endif
  # ------------------------------------------------------------------------------------
  If IADXLOG = [V]CST_AFALSE Then
    If GERR = 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
  # Issue X3-80904 - 2018-04-11 by ALMON : END
End

###################################################################################################
Subprog LOAD_TREE(TECFINOVE, SPRONUM)
Variable Instance TECFINOVE Using C_TECFINOVE
Value Char SPRONUM

  Call LOAD_WORK_TABLES(TECFINOVE, SPRONUM)
  Call LOAD_TREE_PJSC1(TECFINOVE, SPRONUM)
  Call LOAD_TREE_PJSC2(TECFINOVE, SPRONUM, AVOID.ACHAR)
End

###################################################################################################
Subprog LOAD_TREE_PJSC1(TECFINOVE, SPRONUM)
Variable Instance TECFINOVE Using C_TECFINOVE
Value Char SPRONUM

Local Integer NI
Local Integer NE
Local Char SKEYCONCAT(250)

  # Issue X3-80902 - 2018-04-06 by ALMON
  Local File PJMSNPW0     [PSW0]
  Local File PJMFINOVRRPT [PJRN1]
  # ------------------------
  # Issue X3-87307 - 2018-05-10 by ALMON : Link work table to 2 source tables
  # Issue X3-106653 - 2018-09-04 by ALMON : Start : Refined the "Where" clauses in the "Links" to include PCCCOD
  If [M:PJSC0]CURRSIT = [V]CST_AYES Then
    [M:PJSC0]PSCSSS = TECFINOVE.SESSION
    Local File PJMSC [PJRN]
    # ------------------------
    Link [PSW0] With [F:PJRN]PJC1=TECFINOVE.SESSION;[F:PSW0]OPPNUM;[F:PSW0]PBUPAE;[F:PSW0]PBUCOD,
&                    [F:PJRN1]PJMR1=[M:PJSC0]KEYEXTN1;[M:PJSC0]SHOWGRP;[F:PSW0]OPPNUM;[F:PSW0]PBUPAE;[F:PSW0]PBUCOD
&                 As [LNKPJW0]
&              Where [F:PJRN]PSCSSS=TECFINOVE.SESSION and [F:PSW0]PRONUM = SPRONUM and [PJRN1]PCCCOD = AVOID.ACHAR and [PJRN]PCCCOD = AVOID.ACHAR
&       Order By Key KEY1=[F:PSW0]OPPNUM;[F:PSW0]PBUPAE;[F:PSW0]PBUSOR;[F:PSW0]PBUCOD
#&       Order By Key KEY1=[F:PSW0]OPPNUM;[F:PSW0]PBUPAE;[F:PSW0]PBUCOD  # Issue X3-91329 - 2018-06-01 by FGR
    Filter [LNKPJW0] Where (
&                    (([F:PJRN]OPPNUM = AVOID.ACHAR) or ([F:PJRN]OPPNUM <> AVOID.ACHAR and [F:PJRN]PCCCOD = AVOID.ACHAR)) or
&                    (([F:PJRN1]OPPNUM = AVOID.ACHAR) or ([F:PJRN1]OPPNUM <> AVOID.ACHAR and [F:PJRN1]PCCCOD = AVOID.ACHAR))
&                          )
  Else
    Local File PJMFINOVRRPT [PJRN]
    # ------------------------
    Link [PSW0] With [PJRN]PJMR1=[M:PJSC0]KEYEXTN;[M:PJSC0]SHOWGRP;[F:PSW0]OPPNUM;[F:PSW0]PBUPAE;[F:PSW0]PBUCOD,
&                    [PJRN1]PJMR1=[M:PJSC0]KEYEXTN1;[M:PJSC0]SHOWGRP;[F:PSW0]OPPNUM;[F:PSW0]PBUPAE;[F:PSW0]PBUCOD
&                 As [LNKPJW0]
&              Where [F:PSW0]PRONUM = SPRONUM and [PJRN1]PCCCOD = AVOID.ACHAR and [PJRN]PCCCOD = AVOID.ACHAR
&       Order By Key KEY1=[F:PSW0]OPPNUM;[F:PSW0]PBUPAE;[F:PSW0]PBUSOR;[F:PSW0]PBUCOD
#&       Order By Key KEY1=[F:PSW0]OPPNUM;[F:PSW0]PBUPAE;[F:PSW0]PBUCOD  # Issue X3-91329 - 2018-06-01 by FGR
    Filter [LNKPJW0] Where (
&                    (([F:PJRN]OPPNUM = AVOID.ACHAR) or ([F:PJRN]OPPNUM <> AVOID.ACHAR and [F:PJRN]PCCCOD = AVOID.ACHAR)) or
&                    (([F:PJRN1]OPPNUM = AVOID.ACHAR) or ([F:PJRN1]OPPNUM <> AVOID.ACHAR and [F:PJRN1]PCCCOD = AVOID.ACHAR))
&                          )
  Endif
  # Issue X3-106653 - 2018-09-04 by ALMON : End
  # Issue X3-87307 - 2018-05-10 by ALMON : End
  NE = 0
  Effzo [M:PJSC1]10
  Call CHGSTL_PJSC1()        # Issue X3-106367 - 2018-08-28 by FGR
  Raz SKEYCONCAT
  For [LNKPJW0]KEY1
    If SKEYCONCAT = AVOID.ACHAR Then
      # To initialize first loop
      SKEYCONCAT = [F:PSW0]OPPNUM + "~" + [F:PSW0]PBUCOD
      Call DISPLAY_COST_STRUCTURE(TECFINOVE, NE)
    Elsif SKEYCONCAT <> [F:PSW0]OPPNUM + "~" + [F:PSW0]PBUCOD Then
      NE += 1
      SKEYCONCAT = [F:PSW0]OPPNUM + "~" + [F:PSW0]PBUCOD
      Call DISPLAY_COST_STRUCTURE(TECFINOVE, NE)
    Endif
    # ------------------------
    If [F:PJRN1]OPPNUM  <> AVOID.ACHAR Then
      Call DISPCS_MNT_QTY_N1(TECFINOVE, NE)
    Endif
    If [F:PJRN]OPPNUM  <> AVOID.ACHAR Then
      Call DISPCS_MNT_QTY_N(TECFINOVE, NE)
    Endif
  Next
  Filter [LNKPJW0]
  [M:PJSC1]NBLIG = NE + 1
  # ------------------------
  For NI = 0 To [M:PJSC1]NBLIG-1
    Call DISPCS_MNT_QTY_VARIANCE(TECFINOVE, NI)
  Next NI
  # ------------------------
  Call DSPCS_WITH_STYLE()
  Affzo [M:PJSC1]10
  # ------------------------
End

###################################################################################################
Subprog LOAD_TREE_PJSC2(TECFINOVE, SPRONUM, SELBUD)
Variable Instance TECFINOVE Using C_TECFINOVE
Value Char SPRONUM
Value Char SELBUD

Local Integer NI
Local Integer NE
Local Char SKEYCONCAT(250)

  # Issue X3-80902 - 2018-04-06 by ALMON
  Local File PJMSNPW1     [PSW1]    # Issue X3-80904 - 2018-04-11 by ALMON
  Local File PJMFINCTORPT [PJ1N1]
  # ------------------------
  # Issue X3-87311 - 2018-05-22 by ALMON : Display Cost Types
  If [M:PJSC0]CURRSIT = [V]CST_AYES Then
    Local File PJMSCCT [PJ1N]
    # ------------------------
    Link [PSW1] With [F:PJ1N]PJC1=TECFINOVE.SESSION;[F:PSW1]OPPNUM;[F:PSW1]PBUPAE;[F:PSW1]PBUCOD;[F:PSW1]PCCGRPSOR;[F:PSW1]PCCGRP;[F:PSW1]PCCCOD,
&                    [F:PJ1N1]PJC1=[M:PJSC0]KEYEXTN1;[M:PJSC0]SHOWGRP;[F:PSW1]OPPNUM;[F:PSW1]PBUPAE;[F:PSW1]PBUCOD;[F:PSW1]PCCGRPSOR;[F:PSW1]PCCGRP;[F:PSW1]PCCCOD
&                 As [LNKPJW1]
&              Where [F:PJ1N]PSCSSS=TECFINOVE.SESSION and [F:PSW1]PRONUM = SPRONUM
&       Order By Key KEY1=[F:PSW1]OPPNUM;[F:PSW1]PBUPAE;[F:PSW1]PBUCOD;[F:PSW1]PCCGRPSOR;[F:PSW1]PCCGRP;[F:PSW1]PCCCOD
  Else
    Local File PJMFINCTORPT [PJ1N]
    # ------------------------
    Link [PSW1] With [PJ1N]PJC1=[M:PJSC0]KEYEXTN;[M:PJSC0]SHOWGRP;[F:PSW1]OPPNUM;[F:PSW1]PBUPAE;[F:PSW1]PBUCOD;[F:PSW1]PCCGRPSOR;[F:PSW1]PCCGRP;[F:PSW1]PCCCOD,
&                    [PJ1N1]PJC1=[M:PJSC0]KEYEXTN1;[M:PJSC0]SHOWGRP;[F:PSW1]OPPNUM;[F:PSW1]PBUPAE;[F:PSW1]PBUCOD;[F:PSW1]PCCGRPSOR;[F:PSW1]PCCGRP;[F:PSW1]PCCCOD
&                 As [LNKPJW1]
&              Where [F:PSW1]PRONUM = SPRONUM
&       Order By Key KEY1=[F:PSW1]OPPNUM;[F:PSW1]PBUPAE;[F:PSW1]PBUCOD;[F:PSW1]PCCGRPSOR;[F:PSW1]PCCGRP;[F:PSW1]PCCCOD
  Endif
  # ------------------------
  If SELBUD <> AVOID.ACHAR Then
    If [M:PJSC0]CURRSIT = [V]CST_AYES Then
      Filter [LNKPJW1] Where (
&                    ([F:PSW1]PRONUM = [M:PJSC0]PRONUM and [F:PJ1N]PSCSSS = [M:PJSC0]PSCSSS and [F:PJ1N]OPPNUM = [F:PSW1]OPPNUM and [F:PJ1N]PBUPAE = [F:PSW1]PBUPAE and [F:PJ1N]PBUCOD = SELBUD) or
&                    ([F:PSW1]PRONUM = [M:PJSC0]PRONUM and [F:PJ1N1]KEYEXT = [M:PJSC0]KEYEXTN1 and [F:PJ1N1]OPPNUM = [F:PSW1]OPPNUM and [F:PJ1N1]PBUPAE = [F:PSW1]PBUPAE and [F:PJ1N1]PBUCOD = SELBUD)
&                            )
    Else
      Filter [LNKPJW1] Where (
&                    ([F:PSW1]PRONUM = [M:PJSC0]PRONUM and [F:PJ1N]KEYEXT = [M:PJSC0]KEYEXTN and [F:PJ1N]OPPNUM = [F:PSW1]OPPNUM and [F:PJ1N]PBUPAE = AVOID.ACHAR and [F:PJ1N]PBUCOD = SELBUD) or
&                    ([F:PSW1]PRONUM = [M:PJSC0]PRONUM and [F:PJ1N1]KEYEXT = [M:PJSC0]KEYEXTN1 and [F:PJ1N1]OPPNUM = [F:PSW1]OPPNUM and [F:PJ1N1]PBUPAE = AVOID.ACHAR and [F:PJ1N1]PBUCOD = SELBUD)
&                            )
    Endif
  Else
    If [M:PJSC0]CURRSIT = [V]CST_AYES Then
      Filter [LNKPJW1] Where (
&                    ([F:PSW1]PRONUM = [M:PJSC0]PRONUM and [F:PJ1N]PSCSSS = [M:PJSC0]PSCSSS and [F:PJ1N]OPPNUM = [F:PSW1]OPPNUM and [F:PJ1N]PBUPAE = AVOID.ACHAR and [F:PJ1N]PBUCOD = AVOID.ACHAR) or
&                    ([F:PSW1]PRONUM = [M:PJSC0]PRONUM and [F:PJ1N1]KEYEXT = [M:PJSC0]KEYEXTN1 and [F:PJ1N1]OPPNUM = [F:PSW1]OPPNUM and [F:PJ1N1]PBUPAE = AVOID.ACHAR and [F:PJ1N1]PBUCOD = AVOID.ACHAR)
&                            )
    Else
      Filter [LNKPJW1] Where (
&                    ([F:PSW1]PRONUM = [M:PJSC0]PRONUM and [F:PJ1N]KEYEXT = [M:PJSC0]KEYEXTN and [F:PJ1N]OPPNUM = [F:PSW1]OPPNUM and [F:PJ1N]PBUPAE = AVOID.ACHAR and [F:PJ1N]PBUCOD = AVOID.ACHAR) or
&                    ([F:PSW1]PRONUM = [M:PJSC0]PRONUM and [F:PJ1N1]KEYEXT = [M:PJSC0]KEYEXTN1 and [F:PJ1N1]OPPNUM = [F:PSW1]OPPNUM and [F:PJ1N1]PBUPAE = AVOID.ACHAR and [F:PJ1N1]PBUCOD = AVOID.ACHAR)
&                            )
    Endif
  Endif
  # ------------------------
  NE = 0
  Effzo [M:PJSC2]10
  Call CHGSTL_PJSC2()        # Issue X3-106367 - 2018-08-28 by FGR
  Raz SKEYCONCAT
  For [LNKPJW1]KEY1
    If SKEYCONCAT = AVOID.ACHAR Then
      # To initialize first loop
      SKEYCONCAT = [F:PSW1]OPPNUM + "~" + [F:PSW1]PBUPAE + "~" + [F:PSW1]PBUCOD + "~" + num$([F:PSW1]PCCGRPSOR) + "~" + [F:PSW1]PCCGRP + "~" + [F:PSW1]PCCCOD
      Call DISPLAY_COST_TYPES(NE, SELBUD)
      If [F:PJ1N1]OPPNUM  <> AVOID.ACHAR Then
        Call DISPCT_MNT_QTY_N1(TECFINOVE,NE)
      Endif
      If [F:PJ1N]OPPNUM  <> AVOID.ACHAR Then
        Call DISPCT_MNT_QTY_N(TECFINOVE,NE)
      Endif
    Elsif SKEYCONCAT <> [F:PSW1]OPPNUM + "~" + [F:PSW1]PBUPAE + "~" + [F:PSW1]PBUCOD + "~" + num$([F:PSW1]PCCGRPSOR) + "~" + [F:PSW1]PCCGRP + "~" + [F:PSW1]PCCCOD Then
      NE += 1
      SKEYCONCAT = [F:PSW1]OPPNUM + "~" + [F:PSW1]PBUPAE + "~" + [F:PSW1]PBUCOD + "~" + num$([F:PSW1]PCCGRPSOR) + "~" + [F:PSW1]PCCGRP + "~" + [F:PSW1]PCCCOD
      Call DISPLAY_COST_TYPES(NE, SELBUD)
      If [F:PJ1N1]OPPNUM  <> AVOID.ACHAR Then
        Call DISPCT_MNT_QTY_N1(TECFINOVE,NE)
      Endif
      If [F:PJ1N]OPPNUM  <> AVOID.ACHAR Then
        Call DISPCT_MNT_QTY_N(TECFINOVE,NE)
      Endif
    Endif
  Next
  Filter [LNKPJW1]
  [M:PJSC2]NBTYP = NE+1
  # ------------------------
  For NI = 0 To [M:PJSC2]NBTYP-1
    Call DISPCT_MNT_QTY_VARIANCE(TECFINOVE,NI)
  Next NI
  # Issue X3-87311 - 2018-05-22 by ALMON : END
  # ------------------------
  Call DSPCT_WITH_STYLE()
  Affzo [M:PJSC2]10
  # ------------------------
End

###################################################################################################
Subprog DISPLAY_COST_STRUCTURE(TECFINOVE, NE)
Variable Instance TECFINOVE Using C_TECFINOVE
Value Integer NE

Local Char WRKPIMNUM(250)
Local Char WRKDESC(40)

  # Issue X3-80902 - 2018-04-06 by ALMON
  [M:PJSC1]PBUIMP(NE) = [V]CST_ANO
  If [F:PSW0]OPPNUM <> AVOID.ACHAR and [F:PSW0]PBUPAE = AVOID.ACHAR and [F:PSW0]PBUCOD = AVOID.ACHAR Then
    [M:PJSC1]PARKEY(NE) = AVOID.ACHAR
    [M:PJSC1]OBJDES(NE) = [F:PSW0]OPPNUM - func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:PSW0]OPPNUM)
    [M:PJSC1]KEYC(NE)   = [F:PSW0]OPPNUM
    [M:PJSC1]EXPFLG(NE) = [V]CST_AYES
    [M:PJSC1]ICO(NE)    = "Folder.gif"
    [M:PJSC1]BUDCOD(NE) = AVOID.ACHAR
  Else
    [M:PJSC1]PBUIMP(NE) = func PJMBUD_CSTD_PROGS.GET_PBUIMP([F:PSW0]OPPNUM, [F:PSW0]PBUCOD)
    If [F:PSW0]PBUCOD <> AVOID.ACHAR Then
      WRKPIMNUM = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(GACTX, [F:PSW0]OPPNUM, [F:PSW0]PBUCOD)
      WRKDESC = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, WRKPIMNUM)
      If WRKDESC = AVOID.ACHAR Then
        WRKDESC = mess(1066,2260,1)
        [M:PJSC1]PBUIMP(NE) = [V]CST_AYES
      Endif
      [M:PJSC1]OBJDES(NE) = [F:PSW0]PBUCOD - WRKDESC
      [M:PJSC1]BUDCOD(NE) = [F:PSW0]PBUCOD
      [M:PJSC1]EXPFLG(NE) = [V]CST_ANO # No expanded nodes by default
      #
      [M:PJSC1]KEYC(NE)   = [F:PSW0]PBUCOD
      If [F:PSW0]PBUPAE = AVOID.ACHAR Then
        [M:PJSC1]PARKEY(NE) = [F:PSW0]OPPNUM
      Else
        [M:PJSC1]PARKEY(NE) = [F:PSW0]PBUPAE
      Endif
      #
      If [M:PJSC1]PBUIMP(NE) = [V]CST_ANO Then
        [M:PJSC1]ICO(NE)  = "Folder.gif"
      Else
        [M:PJSC1]ICO(NE)  = "Book.gif"
      Endif
    Else
      If [F:PSW0]PBUPAE <> AVOID.ACHAR Then
        WRKPIMNUM = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(GACTX, [F:PSW0]OPPNUM, [F:PSW0]PBUPAE)
        WRKDESC = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, WRKPIMNUM)
        If WRKDESC = AVOID.ACHAR Then
          WRKDESC = mess(1066,2260,1)
          [M:PJSC1]PBUIMP(NE) = [V]CST_AYES
        Endif
        [M:PJSC1]OBJDES(NE) = [F:PSW0]PBUPAE - WRKDESC
        [M:PJSC1]KEYC(NE)   = [F:PSW0]PBUPAE
        [M:PJSC1]BUDCOD(NE) = [F:PSW0]PBUCOD
        [M:PJSC1]EXPFLG(NE) = [V]CST_AYES
        If [M:PJSC1]PBUIMP(NE) = [V]CST_ANO Then
          [M:PJSC1]PARKEY(NE) = [F:PSW0]OPPNUM
          [M:PJSC1]ICO(NE)  = "Folder.gif"
        Else
          [M:PJSC1]PARKEY(NE) = [F:PSW0]OPPNUM
          [M:PJSC1]ICO(NE)  = "Book.gif"
        Endif
      Endif
    Endif
  Endif
End

