###################################################################################################
# Issue X3-87311 - 2018-05-22 by ALMON : Display Cost Types Styles
Subprog DSPCT_WITH_STYLE()

Local Integer NI

  # Issue X3-93182 - 2018-06-05 by ALMON : Display column styling with new requirements
  Affzo [M:PJSC2]10
  For NI = 0 To [M:PJSC2]NBTYP-1
    If [M:PJSC2]PCCCOD(NI) <> AVOID.ACHAR Then
      Chgstl [M:PJSC2]NBTYP(NI)   With ""
      Chgstl [M:PJSC2]QTY1N1(NI)  With "PJMBUD"
      Chgstl [M:PJSC2]QTY1N(NI)   With "PJMBUD"
      Chgstl [M:PJSC2]AMT1N1(NI)  With "PJMBUD"
      Chgstl [M:PJSC2]AMT1N(NI)   With "PJMBUD"
      Chgstl [M:PJSC2]QTY7N1(NI)  With "PJMREMAINS"
      Chgstl [M:PJSC2]QTY7N(NI)   With "PJMREMAINS"
      Chgstl [M:PJSC2]AMT7N1(NI)  With "PJMREMAINS"
      Chgstl [M:PJSC2]AMT7N(NI)   With "PJMREMAINS"
      Chgstl [M:PJSC2]QTY8N1(NI)  With "PJMREMAINS"
      Chgstl [M:PJSC2]QTY8N(NI)   With "PJMREMAINS"
      Chgstl [M:PJSC2]AMT8N1(NI)  With "PJMREMAINS"
      Chgstl [M:PJSC2]AMT8N(NI)   With "PJMREMAINS"
      Chgstl [M:PJSC2]QTY9N1(NI)  With "PJMTOTAL"
      Chgstl [M:PJSC2]QTY9N(NI)   With "PJMTOTAL"
      Chgstl [M:PJSC2]AMT9N1(NI)  With "PJMTOTAL"
      Chgstl [M:PJSC2]AMT9N(NI)   With "PJMTOTAL"
      If [M:PJSC2]QVAR1(NI) < 0 Then
        Chgstl [M:PJSC2]QVAR1(NI) With "PJMBUDVARR"
      Else
        Chgstl [M:PJSC2]QVAR1(NI) With "PJMBUDVARG"
      Endif
      If [M:PJSC2]AVAR1(NI) < 0 Then
        Chgstl [M:PJSC2]AVAR1(NI) With "PJMBUDVARR"
      Else
        Chgstl [M:PJSC2]AVAR1(NI) With "PJMBUDVARG"
      Endif
      If [M:PJSC2]QVAR7(NI) < 0 Then
        Chgstl [M:PJSC2]QVAR7(NI) With "PJMREMVARR"
      Else
        Chgstl [M:PJSC2]QVAR7(NI) With "PJMREMVARG"
      Endif
      If [M:PJSC2]AVAR7(NI) < 0 Then
