#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################
# FUNSCOMVT : Resynchronisation sous-traitance en cours                  #
#    Contrôle et correction des tables SCOxxx [SCx]                      #
#       - ORDQTY    : Quantité en commande                               #
#       - LASORDDAT : Date dernière commande                             #
#       - LASPOHNUM : Numéro dernière commande                           #
#       - CPLQTY    : Quantité réceptionné                               #
#       - LASRCPDAT : Date dernière réception                            #
#       - LASPTHNUM : Numéro dernière réception                          #
#       - INVQTY    : Quantité facturé                                   #
#       - LASINVDAT : Date dernière facture                              #
#       - LASINVNUM : Numéro dernière facture                            #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais une fonction                     #
# ---------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                 #
#   - TRTSCOMVT : Fonction de resynchronisation sous-traitance en cours  #
##########################################################################

$ACTION
#---------------------------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)                        #
# TRTSCOMVT  : Fonction de resynchronisation des encours fournisseurs #
#---------------------------------------------------------------------#
Case ACTION
 When "OUVRE_BATCH" : Gosub INIT
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Affzo [DIA]1-99 : Gosub GRISAGE
 When "BOUTON"      : Gosub BOUTON
 When "OK"          : GOK=1
 When "END"         : GOK=0
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return


#################################################
# Initialisations avant exécution du traitement #
#################################################
$INIT
If GSERVEUR
  Onerrgo ERRBATCH : # En batch, il vaut mieux mettre onerrgo
Endif
Gosub OUVRE        : # Ouverture fichiers et déclaration variables locales
Local Mask SCOMVT [DIA]
Raz [M:DIA]
[M:DIA]XFCYFLG=2
[M:DIA]XBPSFLG=2
[M:DIA]TRACE  =2
#GA ??? Call LECMEMO("STD","[M:DIA]","pm6") From GMEMO
TIT=mess(332,197,1) : # Titre de la boite de dialogue et message de temporisation
TMP=1               : # Affichage d'un message de temporisation
Return


###############################
# Après exécution d'un bouton #
###############################
$BOUTON
Case BOUT
  When "R" : Gosub GRISAGE
Endcase
Return


##########################################
# Contrôle avant exécution du traitement #
##########################################
$CONTROLE
If GOK<1  FIN=1 : Endif
Return


###########################
# Exécution du traitement #
###########################
$EXEC
If !GSERVEUR
  #----- Ouverture fichier trace et écriture des sélections -----#
  If [M:DIA]TRACE=2 
    Call OUVRE_TRACE(mess(332,197,1))  From LECFIC
    Call ECR_TRACE(" ",0)              From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0)  From GESECRAN
    Call PRTSCR("SCOMVT","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0)  From GESECRAN
    Call ECR_TRACE(" ",0)              From GESECRAN
  Endif 
Endif
#-----------------------------------------#
# Vérification si ???                     #
#-----------------------------------------#
##If [M:DIA]TRACE=2
##  WMSG="- "+mess(410,197,1)+" "
##  WMSG+=string$(70-len(WMSG),"-")
##  Call ECR_TRACE(WMSG,0) From GESECRAN
##Endif
##GA quels contrôles ???
If GOK<1  Return : Endif

#--------------------------------------------#
# Recherche des commandes pour réajustement  #
#     - Qté en commande      (ORDQTY)        #
#     - Date dernière cde    (LASORDDAT)     #
#     - Numéro dernière cde  (LASPOHNUM)     #
#--------------------------------------------#
If [M:DIA]TRACE=2
  WMSG="- "+mess(333,197,1)+" "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#----- Vérification des qtés en commande pour les ordres de sous-traitance fermes (non soldés) -----#
CRITERE="[F:SCO]SCOSTA=1 & [F:SCO]SCOTRKFLG<>5 "
If [M:DIA]XCPYFLG<>2 CRITERE+=" & [F:SCO]CPY=[M:DIA]CPY"    : Endif
If [M:DIA]XFCYFLG<>2 CRITERE+=" & [F:SCO]POHFCY=[M:DIA]FCY" : Endif
If [M:DIA]XBPSFLG<>2 CRITERE+=" & [F:SCO]BPRNUM=[M:DIA]BPSNUM" : Endif
Raz WORDQTY, WLASORDDAT, WLASPOHNUM, WBPRNUM, WINVFCY, COMPTEUR
GOK=1 : INDIC=1
For [SCO]SCO0 Where evalue(CRITERE)
  If WBPRNUM=""
    WBPRNUM=[F:SCO]BPRNUM
    WINVFCY=[F:SCO]INVFCY
    GFCY=[F:SCO]POHFCY
  Endif
  #-----
  Raz WNBLIG
  Raz WORDQTY
  For [SCI]SCI0 Where SCONUM=[F:SCO]SCONUM
   #----- Ne prendre que les lignes liées à un article lancé de l'ordre de sous-traitance -----#
    For [POQ] POQ0 Where VCRTYPORI=36 & VCRNUMORI=[F:SCI]SCONUM 
&                      & VCRLINORI=[F:SCI]SCILIN & LINTYP=2
        WORDQTY += [F:POQ]QTYSTU
        #----- compter lignes de commande traitées -----#
        WNBLIG+=1
    Next
    WLASPOHNUM=[F:POQ]POHNUM
    WLASPOPLIN=[F:POQ]POPLIN
    Gosub MAJ_SCI_ORDQTY
  Next
  Raz WORDQTY
  For [SCS]SCS0 Where SCONUM=[F:SCO]SCONUM
   #----- Ne prendre que les lignes liées à Service de l'ordre de sous-traitance -----#
    For [POQ] POQ0 Where VCRTYPORI=36 & VCRNUMORI=[F:SCS]SCONUM 
&                      & VCRLINORI=[F:SCS]SCILIN & VCRSEQORI=[F:SCS]SCSLIN & LINTYP=3
        WORDQTY += [F:POQ]QTYSTU
        #----- compter lignes de commande traitées -----#
        WNBLIG+=1
    Next
    WLASPOHNUM=[F:POQ]POHNUM
    WLASPOPLIN=[F:POQ]POPLIN
    Gosub MAJ_SCS_ORDQTY
  Next
  Raz WORDQTY
  For [SCM]SCM0 Where SCONUM=[F:SCO]SCONUM
   #----- Ne prendre que les lignes liées à une matière de l'ordre de sous-traitance -----#
    For [POQ] POQ0 Where VCRTYPORI=36 & VCRNUMORI=[F:SCM]SCONUM 
&                      & VCRLINORI=[F:SCM]SCILIN & VCRSEQORI=[F:SCM]SCMLIN & LINTYP=4
        WORDQTY += [F:POQ]QTYSTU
        #----- compter lignes de commande traitées -----#
        WNBLIG+=1
    Next
    WLASPOHNUM=[F:POQ]POHNUM
    WLASPOPLIN=[F:POQ]POPLIN
    Gosub MAJ_SCM_ORDQTY
  Next
  COMPTEUR+=WNBLIG
Next
If [M:DIA]TRACE=2
  WMSG="- ("+num$(COMPTEUR)+") "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
  Call ECR_TRACE(" ",0)  From GESECRAN
Endif
If GOK<1  Return : Endif

#----------------------------------------------#
# Traitement des réceptions pour réajustement  #
#     - Qté réceptionnée           (CPLQTY)    #
#     - Date dernière réception    (LASRCPDAT) #
#     - Numéro dernière réception  (LASPTHNUM) #
#----------------------------------------------#
If [M:DIA]TRACE=2
  WMSG="- "+mess(334,197,1)+" "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#----- Vérification des qtés réceptionnées pour les ordres de sous-traitance fermes (non soldés) -----#
CRITERE="[F:SCO]SCOSTA=1 & [F:SCO]SCOTRKFLG<>5 "
If [M:DIA]XCPYFLG<>2 CRITERE+=" & [F:SCO]CPY=[M:DIA]CPY"    : Endif
If [M:DIA]XFCYFLG<>2 CRITERE+=" & [F:SCO]POHFCY=[M:DIA]FCY" : Endif
If [M:DIA]XBPSFLG<>2 CRITERE+=" & [F:SCO]BPRNUM=[M:DIA]BPSNUM" : Endif
Raz WCPLQTY, WLASORDDAT, WLASPTHNUM, WBPRNUM, WINVFCY, COMPTEUR
GOK=1 : INDIC=1
For [SCO]SCO0 Where evalue(CRITERE)
  If WBPRNUM=""
    WBPRNUM=[F:SCO]BPRNUM
    WINVFCY=[F:SCO]INVFCY
    GFCY=[F:SCO]POHFCY
  Endif
  #-----
  Raz WNBLIG
  Raz WCPLQTY
  For [SCI]SCI0 Where SCONUM=[F:SCO]SCONUM
##   #----- Ne prendre que les lignes liées à un article lancé de l'ordre de sous-traitance -----#
##    For [PTD] PTD0 Where VCRTYPORI=36 & VCRNUMORI=[F:SCI]SCONUM 
##&                      & VCRLINORI=[F:SCI]SCILIN & LINTYP=2
##        WCPLQTY += [F:PTD]QTYSTU
##        #----- compter lignes de commande traitées -----#
##        WNBLIG+=1
##    Next
##    WLASPTHNUM=[F:PTD]PTHNUM
##    WLASPTDLIN=[F:PTD]PTDLIN
   #----- Ne prendre que les lignes liées à un article lancé de l'ordre de sous-traitance -----#
    For [POQ] POQ0 Where VCRTYPORI=36 & VCRNUMORI=[F:SCI]SCONUM 
&                      & VCRLINORI=[F:SCI]SCILIN & LINTYP=2 & RCPQTYSTU<>0
        WCPLQTY += [F:POQ]RCPQTYSTU
        #----- compter lignes de commande traitées -----#
        WNBLIG+=1
    Next
    Gosub MAJ_SCI_CPLQTY
  Next
  COMPTEUR+=WNBLIG
Next
If [M:DIA]TRACE=2
  WMSG="- ("+num$(COMPTEUR)+") "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
  Call ECR_TRACE(" ",0)  From GESECRAN
Endif
If GOK<1  Return : Endif

#--------------------------------------------#
# Traitement des factures pour réajustement  #
#     - Qté facturée             (INVQTY)    #
#     - Date dernière facture    (LASINVDAT) #
#     - Numéro dernière facture  (LASINVNUM) #
#--------------------------------------------#
If [M:DIA]TRACE=2
  WMSG="- "+mess(335,197,1)+" "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#----- Vérification des qtés facturées pour les ordres de sous-traitance fermes (non soldés) -----#
CRITERE="[F:SCO]SCOSTA=1 & [F:SCO]SCOTRKFLG<>5 "
If [M:DIA]XCPYFLG<>2 CRITERE+=" & [F:SCO]CPY=[M:DIA]CPY"    : Endif
If [M:DIA]XFCYFLG<>2 CRITERE+=" & [F:SCO]POHFCY=[M:DIA]FCY" : Endif
If [M:DIA]XBPSFLG<>2 CRITERE+=" & [F:SCO]BPRNUM=[M:DIA]BPSNUM" : Endif
Raz WCPLQTY, WLASORDDAT, WLASPTHNUM, WBPRNUM, WINVFCY, COMPTEUR
GOK=1 : INDIC=1
For [SCO]SCO0 Where evalue(CRITERE)
  If WBPRNUM=""
    WBPRNUM=[F:SCO]BPRNUM
    WINVFCY=[F:SCO]INVFCY
    GFCY=[F:SCO]POHFCY
  Endif
  #-----
  Raz WNBLIG
  Raz WINVQTY
  For [SCS]SCS0 Where SCONUM=[F:SCO]SCONUM
   #----- Ne prendre que les lignes liées à un Service de l'ordre de sous-traitance -----#
    For [POQ] POQ0 Where VCRTYPORI=36 & VCRNUMORI=[F:SCS]SCONUM 
&                      & VCRLINORI=[F:SCS]SCILIN & VCRSEQORI=[F:SCS]SCSLIN & LINTYP=3 & INVQTYSTU<>0
        WINVQTY += [F:POQ]INVQTYSTU
        #----- compter lignes de commande traitées -----#
        WNBLIG+=1
    Next
    Gosub MAJ_SCS_INVQTY
  Next
  Raz WINVQTY
  For [SCM]SCM0 Where SCONUM=[F:SCO]SCONUM
   #----- Ne prendre que les lignes liées à une matière de l'ordre de sous-traitance -----#
    For [POQ] POQ0 Where VCRTYPORI=36 & VCRNUMORI=[F:SCM]SCONUM 
&                      & VCRLINORI=[F:SCM]SCILIN & VCRSEQORI=[F:SCM]SCMLIN & LINTYP=4 & INVQTYSTU<>0
        WINVQTY += [F:POQ]INVQTYSTU
        #----- compter lignes de commande traitées -----#
        WNBLIG+=1
    Next
    Gosub MAJ_SCM_INVQTY
  Next
  COMPTEUR+=WNBLIG
Next
If [M:DIA]TRACE=2
  WMSG="- ("+num$(COMPTEUR)+") "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
  Call ECR_TRACE(" ",0)  From GESECRAN
Endif
If GOK<1  Return : Endif
Return


#####################################
# Fin après exécution du traitement #
#####################################
$TERMINE
TRA=0
If !GSERVEUR
  #----- Fermeture et affichage de la trace -----#
  If [M:DIA]TRACE=2
    Call FERME_TRACE From LECFIC : TRA=1
  Endif
Endif
Return


#######################################################
# Traitement du grisage et dégrisage des champs écran #
#######################################################
$GRISAGE
If [M:DIA]XCPYFLG=2 Diszo [DIA]CPY, XFCYFLG Else Actzo [DIA]CPY, XFCYFLG : Endif
If [M:DIA]XFCYFLG=2 Diszo [DIA]FCY          Else Actzo [DIA]FCY          : Endif
If [M:DIA]XBPSFLG=2 Diszo [DIA]BPSNUM       Else Actzo [DIA]BPSNUM       : Endif
Return

#----------------------------------------------------------#
# Variables locales + ouverture des fichiers et de l'écran #
#----------------------------------------------------------#
$OUVRE
#----- Variables locales -----#
Local Libelle  LASFLG
Local Shortint INDIC, CREFLG, UPDFLG
Local Integer  OK, STAT, COMPTEUR, WNBLIG
Local Char     CRITERE(170)
Local Char     WBPRNUM(GLONBPS), WINVFCY(GLONFCY), WMSG(100)
Local Decimal  WORDQTY, WCPLQTY, WINVQTY
Local Date     WLASINVDAT, WLASORDDAT, WLASPQHDAT, WLASRCPDAT
Local Char     WLASINVNUM(GLONPIH), WLASPOHNUM(GLONPOH), WLASPTHNUM(GLONPTH)
Local Integer  WLASINVLIN, WLASPOPLIN, WLASPTDLIN
Local Char     TIT (50) : TIT=mess(332,197,1)

#----- Ouverture des fichiers -----#
If clalev([F:CPY])=0  Local File COMPANY   [CPY]  : Endif
If clalev([F:FCY])=0  Local File FACILITY  [FCY]  : Endif
If clalev([F:POH])=0  Local File PORDER    [POH]  : Endif
If clalev([F:POP])=0  Local File PORDERP   [POP]  : Endif
If clalev([F:POQ])=0  Local File PORDERQ   [POQ]  : Endif
If clalev([F:PTH])=0  Local File PRECEIPT  [PTH]  : Endif
If clalev([F:PTD])=0  Local File PRECEIPTD [PTD]  : Endif
If clalev([F:PIH])=0  Local File PINVOICE  [PIH]  : Endif
If clalev([F:BPR])=0  Local File BPARTNER  [BPR]  : Endif
Gosub OPEN_FILES_SCO From SCOLIB
Return


################################################################################
#             Actions sur champ pour gestion de l'écran SCOMVT                 #
################################################################################

Subprog AV_XCPYFLG(VALEUR)
#--------------------------------------#
# Avant saisie du flag toutes sociétés #
# ------------------------------------ #
# Complément de l'initialisation des   #
# champs faite dans INIT_DIA et        #
# grisage des champs                   #
#--------------------------------------#
Variable Integer VALEUR
If varinit([M]XCPYFLG) End : Endif : # Pour n'exécuter qu'une seule fois
#----- Traitement des champs société -----#
[M]XCPYFLG=2 : VALEUR=2
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  VALEUR=1 : [M]XCPYFLG=2 : Grizo XCPYFLG
  Call INICPY([M]CPY) From CPTSUB : Affzo CPY : If dim([M]ZCPY)>0  Affzo ZCPY : Endif
  If GNBAUZ=1 Diszo CPY : Endif
Else
  Diszo CPY
Endif
#----- Traitement des champs site -----#
If VALEUR=2
  Grizo XFCYFLG : Diszo FCY, FCYNAM
Else
  Call INIALLFCY([M]XFCYFLG,[M]CPY) From FUNPTH
  If mkstat
    Grizo XFCYFLG : Raz mkstat
    Call INIFCY([M]FCY,[M]CPY) From CPTSUB
    Read [FCY] FCY0 = [M]FCY
    If fstat : Raz [F:FCY] : Endif
    [M:DIA]FCYNAM = [F:FCY]FCYNAM   
    [M]FCYNAM=[F:FCY]FCYNAM : Affzo FCY, FCYNAM
    If GNBAUZ=1 Diszo FCY, FCYNAM : Endif
  Else
    Diszo FCY, FCYNAM
  Endif
Endif
#----- traitement du champ fournisseur -----#
If [M]XBPSFLG=2 : Diszo BPSNUM : Endif
End


Subprog AM_XCPYFLG(VALEUR)
#-------------------------------------#
# Après modif du flag toutes sociétés #
#-------------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo CPY
  Call INICPY([M]CPY) From CPTSUB : Affzo CPY : If dim([M]ZCPY)>0  Affzo ZCPY : Endif
  If GNBAUZ=1 Diszo CPY : Endif
  Call INIALLFCY([M]XFCYFLG,[M]CPY) From FUNPTH
  If mkstat
    Grizo XFCYFLG : Actzo FCY, FCYNAM : Raz mkstat
    Call INIFCY([M]FCY,[M]CPY) From CPTSUB
    [M]FCYNAM=[F:FCY]FCYNAM : Affzo FCY, FCYNAM
    If GNBAUZ=1 Diszo FCY, FCYNAM : Endif
  Else
    Actzo XFCYFLG
    If [M]XFCYFLG=1
      Call INIFCY([M]FCY,[M]CPY) From CPTSUB
      [M]FCYNAM=[F:FCY]FCYNAM : Affzo FCY, FCYNAM
    Endif
  Endif
Else
  [M]XFCYFLG=2 : Affzo XFCYFLG : Grizo XFCYFLG
  Effzo CPY, FCY, FCYNAM : If dim([M]ZCPY)>0  Effzo ZCPY : Endif
  Diszo CPY, FCY, FCYNAM
Endif
End


Subprog C_CPY(VALEUR)
#------------------------------------------------------------------#
# Contrôle société : Obligatoire si flag toutes sociétés non coché #
#------------------------------------------------------------------#
Variable Char    VALEUR()
If [M]XCPYFLG<>2 & VALEUR="" mkstat=1 : End : Endif
End


Subprog AM_CPY(VALEUR)
#----------------------------------#
# Après modification de la société #
#----------------------------------#
Variable Char    VALEUR()
Call INIALLFCY([M]XFCYFLG,VALEUR) From FUNPTH
If mkstat
  Grizo XFCYFLG : Actzo FCY, FCYNAM : Raz mkstat
  Call INIFCY([M]FCY,VALEUR) From CPTSUB : Affzo FCY
  If GNBAUZ=1 Diszo FCY, FCYNAM : Endif
Else
  Actzo XFCYFLG
  If [M]XFCYFLG=1
    Call INIFCY([M]FCY,VALEUR) From CPTSUB
    [M]FCYNAM=[F:FCY]FCYNAM : Affzo FCY, FCYNAM
  Endif
Endif
End


Subprog AM_XFCYFLG(VALEUR)
#--------------------------------#
# Après modif du flag tous sites #
#--------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo FCY, FCYNAM
  Call INIFCY([M]FCY,[M]CPY) From CPTSUB
  If [F:FCY]FCY<>[M]FCY
    Read [FCY] FCY0=[M]FCY : If fstat  Raz [F:FCY] : Endif
  Endif
  [M]FCYNAM=[F:FCY]FCYNAM
  Affzo FCY, FCYNAM
  If GNBAUZ=1 Diszo FCY, FCYNAM : Endif
Else
  Effzo FCY, FCYNAM
  Diszo FCY, FCYNAM
Endif
End


Subprog C_FCY(VALEUR)
#-----------------------------------------------------#
# Contrôle site : Obligatoire si tous sites non coché #
#-----------------------------------------------------#
Variable Char    VALEUR()
If [M]XFCYFLG<>2 & VALEUR="" mkstat=1 : End : Endif
End


Subprog AM_FCY(VALEUR)
#---------------------#
# Après modif du site #
#---------------------#
Variable Char    VALEUR()
[M]FCYNAM=[F:FCY]FCYNAM : Affzo FCYNAM
End


Subprog AM_XBPSFLG(VALEUR)
#---------------------------------------#
# Après modif du flag tous fournisseurs #
#---------------------------------------#
Variable Integer VALEUR
If VALEUR=2
  Effzo BPSNUM : If dim([M]ZBPSNUM)>0  Effzo ZBPSNUM : Endif
  Diszo BPSNUM
Else
  Actzo BPSNUM
Endif
End


Subprog C_BPSNUM(VALEUR)
#------------------------------------------------------------------------#
# Contrôle fournisseur : Obligatoire si flag tous fournisseurs non coché #
#------------------------------------------------------------------------#
Variable Char    VALEUR()
If [M]XBPSFLG<>2 & VALEUR="" mkstat=1 : End : Endif
End


###################
# Erreur en Batch #
###################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End


###################
# Qté commandée   #
###################
$MAJ_SCI_ORDQTY
  Readlock [F:SCI] Curr
  If fstat : GOK=0 : Raz [F:SCI] : Call FSTA ("SCI") From GLOCK  : Return : Endif
  [F:SCI]POHNUM=WLASPOHNUM
  [F:SCI]POPLIN=WLASPOPLIN
  [F:SCI]ORDQTY=WORDQTY
  Gosub REWRITE_SCI From SCOLIB
Return

###################
# Qté commandée   #
###################
$MAJ_SCS_ORDQTY
# donnée non stockée dans SCOSRV
Return

###################
# Qté commandée   #
###################
$MAJ_SCM_ORDQTY
# donnée non stockée dans SCOMAT
Return

###########################
# Qté réceptionnée SCOITM #
###########################
$MAJ_SCI_CPLQTY
  Readlock [F:SCI] Curr
  If fstat : GOK=0 : Raz [F:SCI] : Call FSTA ("SCI") From GLOCK  : Return : Endif
  [F:SCI]CPLQTY=WCPLQTY
  Gosub REWRITE_SCI From SCOLIB
Return

#######################
# Qté facturée SCOSRV #
#######################
$MAJ_SCS_INVQTY
  Readlock [F:SCS] Curr
  If fstat : GOK=0 : Raz [F:SCS] : Call FSTA ("SCS") From GLOCK : Return : Endif
  [F:SCS]INVQTY=WINVQTY
  Gosub REWRITE_SCS From SCOLIB
Return

#######################
# Qté facturée SCOMAT #
#######################
$MAJ_SCM_INVQTY
  Readlock [F:SCM] Curr
  If fstat : GOK=0 : Raz [F:SCM] : Call FSTA ("SCM") From GLOCK  : Return : Endif
  [F:SCM]INVQTY=WINVQTY
  Gosub REWRITE_SCM From SCOLIB
Return
