# Gestion du masque TDUCLO1

##########################################################################
## Etiquette ajoutée par le superviseur 07/11/2003 13:15:04 (MM)
##########################################################################
Subprog AM_WCRFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   
    GFCY=VALEUR                     
    Gosub CHARG_PARAM From FUNTDUCLO
Endif                              
End

Subprog IB_MFGNUMDEB
GBOUT1 = mess(312,198,1)
End

Subprog IB_MFGNUMFIN
GBOUT1 = mess(312,198,1)
End

Subprog C_MFGNUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]MFGNUMDEB : GMESSAGE= mess(44,199,1) : mkstat = 2 : End : Endif
End

Subprog AM_WCRDEB(VALEUR)
Variable Char    VALEUR()
If [M]WCRDEB="" : [M]WCRFIN = VALEUR : Endif
If [M]WCRFIN < VALEUR : [M]WCRFIN = VALEUR : Endif
End

Subprog AM_WSTTYPDEB(VALEUR)
Variable Integer VALEUR
If VALEUR<> 0 : [M]WSTTYPFIN = VALEUR : Endif
End

Subprog C_WSTTYPFIN(VALEUR)
Variable Integer VALEUR
If VALEUR < [M]WSTTYPDEB : GMESSAGE = mess(44,199,1) : mkstat=2 : Endif
End

Subprog AM_WSTDEB(VALEUR)
Variable Char    VALEUR()
If [M]WSTDEB="" : [M]WSTFIN = VALEUR : Endif
If [M]WSTFIN < VALEUR : [M]WSTFIN = VALEUR : Endif
End




##########################################################################

