Subprog C_FILREF6(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If [M]NATPAY>1
 Filter [TFB] Where COD=VALEUR and NATPAY=[M]NATPAY
 Read [TFB]TFB0 First
 Filter [TFB]
 If fstat
  GMESSAGE = mess(36,115,1) : # Struture de fichier incorrect
  mkstat = 2 : End
 Endif
Endif
Gosub CONT_FILREF
If mkstat=2 : End : Endif
Raz [M]FILREF71
End

$CONT_FILREF
If GCURLEG<>""
 Filter [TFB] Where COD=VALEUR and (LEG=GCURLEG | LEG="")
 Read [TFB]TFB0 First
 Filter [TFB]
 If fstat
  Filter [TFB] Where COD=VALEUR
  Read [TFB]TFB0 First
  Filter [TFB]
  If !fstat
   # Fiche inexistante pour la législation courante
   GMESSAGE = VALEUR-":"-mess(232,107,1)-"["+[M]LEG+"]"
   mkstat = 2 : Return
  Else
   # Fiche inexistante
   GMESSAGE = VALEUR-":"-mess(23,100,1)
   mkstat = 2 : Return
  Endif
 Endif
Else
 Filter [TFB] Where COD=VALEUR
 Read [TFB]TFB0 First
 Filter [TFB]
 If fstat
  # Fiche inexistante
  GMESSAGE = VALEUR-":"-mess(23,100,1)
  mkstat = 2 : Return
 Endif
Endif
Return

