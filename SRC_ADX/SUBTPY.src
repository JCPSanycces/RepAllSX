######################################################################################
Subprog AM_BANCSH(VALEUR)
#Issue 33454 – 2017-05-12  by MADOR/MRDAB - As as treasury manager I want to be able to define
# WHICH PAYMENTS WILL BE USED IN CASH/BANK REGISTERS and THE ONES To USE IN STANDARD GESPAY FUNCTION
Variable Integer VALEUR

If func AFNC.ACTIV("REGBC")
  [M:TPY2]DACPAYTYP = 1
  Affzo [M:TPY2]DACPAYTYP
  Gosub UNTICK_DACREGNUM
Endif
#Issue End

End


######################################################################################

######################################################################################
## Section automatically added (screen TPY2) 05/12/2017 15:54:54 (MADOR)
######################################################################################
Subprog AS_DACPAYTYP(VALEUR)
Variable Integer VALEUR
#Issue 33454 – 2017-05-18  by MADOR - As as treasury manager I want to be able to define
# WHICH PAYMENTS WILL BE USED IN CASH/BANK REGISTERS and THE ONES To USE IN STANDARD GESPAY FUNCTION
Local Char P_PROBALCTL(1) : P_PROBALCTL = ""
Call PARAM([M:TPY0]LEG,"PROBALCTL",P_PROBALCTL) From ADOVAL #Enable/Disable fields for balance control

If (dim([M:TPY1]FLGEND) > 0 and [M:TPY1]FLGEND = 2) or P_PROBALCTL = "2"
  GMENLOC(2) = 1
  GMENLOC(3) = 1
Elsif [M:TPY1]BANCSH = 1
  GMENLOC(2) = 1
  GMENLOC(3) = 0
Elsif [M:TPY1]BANCSH = 2
  GMENLOC(2) = 0
  GMENLOC(3) = 1
Endif
#Issue End
End


######################################################################################

######################################################################################
## Section automatically added (screen TPY2) 05/15/2017 13:08:24 (MADOR)
######################################################################################
Subprog AM_DACPAYTYP(VALEUR)
Variable Integer VALEUR
#Issue 33454 – 2017-05-18  by MADOR - As as treasury manager I want to be able to define
# WHICH PAYMENTS WILL BE USED IN CASH/BANK REGISTERS and THE ONES To USE IN STANDARD GESPAY FUNCTION
If VALEUR = 2 or VALEUR = 3
    Gosub TICK_DACREGNUM
Else
    Gosub UNTICK_DACREGNUM
Endif
#Issue End
End

Subprog CHANGE_SECTIONS_STATE(SET_ENABLED)
#Issue 33454 – 2017-05-18  by MADOR - As as treasury manager I want to be able to define
# WHICH PAYMENTS WILL BE USED IN CASH/BANK REGISTERS and THE ONES To USE IN STANDARD GESPAY FUNCTION
Value Integer SET_ENABLED
If SET_ENABLED = 0
    Effzo [M:TPY3]10-40
    Effzo [M:TPY3]60
    Effzo [M:TPY3]80

    Grizo [M:TPY3]10-40
    Grizo [M:TPY3]60
    Grizo [M:TPY3]80
Else
    Actzo [M:TPY3]10-40
    Actzo [M:TPY3]60
    Actzo [M:TPY3]80
Endif
#Issue End
End

$UNTICK_DACREGNUM
#Issue 33454 – 2017-05-18  by MADOR - As as treasury manager I want to be able to define
# WHICH PAYMENTS WILL BE USED IN CASH/BANK REGISTERS and THE ONES To USE IN STANDARD GESPAY FUNCTION
Effzo [M:TPY2]DACREGNUM
Call CHANGE_SECTIONS_STATE(1)
#Issue End
Return

$TICK_DACREGNUM
#Issue 33454 – 2017-05-18  by MADOR - As as treasury manager I want to be able to define
# WHICH PAYMENTS WILL BE USED IN CASH/BANK REGISTERS and THE ONES To USE IN STANDARD GESPAY FUNCTION
[M:TPY2]DACREGNUM = 2
Affzo [M:TPY2]DACREGNUM
Call CHANGE_SECTIONS_STATE(0)
#Issue End
Return

