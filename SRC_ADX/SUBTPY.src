########################################
## Ecran TPY1                         ##
########################################
Subprog C_PAM(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]PAM(0..[M]NBRPAM-1)) From OBJDIV
#
#
# Localization Switzerland, 2015-05-08 Bader
# FQ122663
#Local Integer OK
#If dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2  # parameter "Swiss checks in payments" = yes?
#  Call EXISTE_ADX("","","SUBTPYSWI",OK) From ORDSYS
#  If OK : Call C_PAM(VALEUR) From SUBTPYSWI : Endif
#Endif
If dim(GSWIPAYBVR) > 0
  Local Integer OK
  Local Char VALPAR(1)
  If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
  Read [ADW]ADW0 = "*";"SWI";"SWIPAYBVR"
  If fstat
    Read [ADW]ADW0 = "";"";"SWIPAYBVR"
  Endif
  If !fstat
   VALPAR = [F:ADW]VALEUR
  Else
   VALPAR = ""
  Endif
  If val(VALPAR) = 2
    Call EXISTE_ADX("","","SUBTPYSWI",OK) From ORDSYS
    If OK : Call C_PAM(VALEUR) From SUBTPYSWI : Endif
  Endif
Endif
# End Localization Switzerland
End

Subprog C_NBRPAM
If [M]NBRPAM=0 & status<>7 & (status<60 or status>1024)
