PARMSK(1) = LEG
If GNBLEG=1 : PARMSK(1) = GDOSLEG : Endif
PARMSK(2) = GFY
Call S_TAB_CHAR(COD,PARMSK,"SELTPY","SELTPY","") From GACTION
End

Subprog C_SNS(VALEUR)
Variable Integer VALEUR
#ISSUE 60081 - 2017-10-20 by MRDAB - refactored to be protected by REGBC activity code
If VALEUR=3
 Raz [M:TPY3]EPACDTTRF, FILREF8 : Grizo [M:TPY3]EPACDTTRF, FILREF8
Elsif func AFNC.ACTIV("REGBC")
  If [M:TPY2]DACPAYTYP <> 1
    Raz [M:TPY3]EPACDTTRF, FILREF8 : Grizo [M:TPY3]EPACDTTRF, FILREF8
  Endif
Else
 Actzo [M:TPY3]EPACDTTRF
Endif
End
#ISSUE END

