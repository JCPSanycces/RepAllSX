######################################################################################
## Section automatically added (screen TPY1) 21.08.2015 09:13:27 (UBA)
######################################################################################
Subprog D_SWIPAYTYP(VALEUR)
Variable Integer VALEUR
# Swiss Localization: init Swiss payment type with "Normal"
If dim([M:TPY1]SWIPAYTYP) > 0 and [M:TPY1]SWIPAYTYP = 0
   [M:TPY1]SWIPAYTYP = 1
Endif
End

