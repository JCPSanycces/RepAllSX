#<AdxTL>@(#)11.0.0.0 $Revision$
Call OBJET("TPY",GBIDC1,GBIDC2) From GOBJET
End

# Issue X3-70924 - 2018-01-15 - MDJ : Replace the call to VALID from VALMSK by a call to VALIDFULL from VALMSK
# Issue X3-81544 - 2018-04-05 - DNE : Some characters should not be allowed for the TPY code.
#                                     Especially "/" and "\" lead to problems when code is generated on validation.
#                                     They are interpreted as directory dividers.

$ACTION
Case ACTION
 When "AVANT_OUVRE" : Gosub AVANT_OUVRE
 When "OUVRE"       : Gosub OUVRE
 When "AFFMASK"     : Gosub AFFMASK
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "APRES_CRE"   : Gosub VALID
 When "APRES_MOD"   : Gosub VALID
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "ANNULE"      : Gosub ANNULE
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "FERME"       : Gosub FERME
 When "CHGCOD"      : Gosub CHGCOD
 When "AB1_AUTACE3", "AB1_AUTACE8", "AB1_AUTACE9", "AB1_AUTACE10" : Gosub AB1_AUTACE
 When "BB1_AUTACE3", "BB1_AUTACE8", "BB1_AUTACE9", "AB1_AUTACE10" : Gosub BB1_AUTACE
 When "SEL_LISTE"   : Case COUZON
                       When "FILREF71" : Gosub S_FILREF71
                       When "FILREF6"  : Gosub S_FILREF6
                       When "FILREF8"  : Gosub S_FILREF8
                       When "CODCAS"   : Gosub S_CODCAS
                      Endcase
 When "AS_PAYTYP"   : Raz GCURLEG
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
Endcase
Return

$AVANT_OUVRE
#Pour l'acces en tunnel via GOBJETC0 dans le boutons/menus par ex.
Call LEC_TPY_LEG(CLE1,CLE2) From CPTLEC
CLE1=[F:TPY]LEG
Return

$OUVRE
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
If !clalev([F:TED]) : Local File TABCODEDT [TED] : Endif
Local Integer C1 , C2 , C3, REGBC_ACTIVE
Local Char    ZONE(10)

[L]REGBC_ACTIVE = 0

If func AFNC.ACTIV("CASIN") : Gosub TPY_OUVRE From EXPCASPAY : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$AFFMASK
If dim([M:TPY0]LEG)>0
 If func AFNC.ACTIV("LEG")=0
  Chgfmt [M:TPY0]LEG With "-K:"+num$(GLONADI)+"B"
  If dim([M:TPY0]ZLEG)>0
   Chgfmt [M:TPY0]ZLEG With "-K:"+num$(type([M:TPY0]ZLEG)-10)+"X"
  Endif
 Endif
Endif
Gosub GRILEG
Return

$GRILEG
If func AFNC.ACTIV("LEG")=0
  Diszo [M:TPY0]LEG
  [M:TPY0]LEG=GDOSLEG(1)
  Affzo [M:TPY0]LEG
Endif
Return

$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET : # Trop compliqué!!
If !CLECUR | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"VU") From GOBJET
Endif
# If GINTRA
#  Call VIREBOUT(CHAINE,"V") From GOBJET
# Endif

# SAM 81743: visibility of LOTPROBALCTL depends on parameter PROBALCTL
Local Char P_PROBALCTL(1) : P_PROBALCTL = ""
Call PARAM([M:TPY0]LEG,"PROBALCTL",P_PROBALCTL) From ADOVAL
If P_PROBALCTL <> "2"
  Chgfmt [M:TPY2]LOTPROBALCTL With "-K:1X"
  Affzo [M:TPY2]LOTPROBALCTL
Endif

Return

$EXEBOUT
Case REP
 When "V" : Gosub VALID
Endcase
Return

$SEL_TABLE
Case TABLE
 When "TPYSELTFB"
  If clalev([F:TFB])=0 : Local File TABFILBAN [TFB] : Endif
  Default File [TFB]
  CRITERE = 'BAN="" & RECTYP=1'
  Call SELOBJ("TFB","",NBCOL,COL,TIT) From CONTOBJ
Endcase
Return

$RAZCRE
Gosub CHARGE_SUP
For I=0 To [M]NBRSUP-1
 [M]DACSUP(I)=1
Next I
Affzo [TPY2]15
Gosub GRILEG
Return

$CHARGE_SUP
[M]NBRSUP=0
For [AMZ]CODE Where CODMSK="PAY2"
 Gosub TST_SUP
 If OK & !find([F:AMZ]CODZON,[M]ZONSUP(0..[M]NBRSUP-1))
  [M]ZONSUP([M]NBRSUP) = [F:AMZ]CODZON
  Call TEXTE([F:AMZ]INTIT,[M]LIBSUP([M]NBRSUP)) From OBJDIV
  [M]NBRSUP += 1
 Endif
Next
Return

$LIENS
If dim([M:TPY0]LEG)>0 : Affzo [M:TPY0]LEG : Endif
GCURLEG = [F:TPY]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Call LECTEXTRA([M:TPY0]DESTRA,"TABPAYTYP","DESTRA",[M:TPY0]PAYTYP,GCURLEG) From ATEXTRA
Call LECTEXTRA([M:TPY0]SHOTRA,"TABPAYTYP","SHOTRA",[M:TPY0]PAYTYP,GCURLEG) From ATEXTRA
Gosub CHARGE_SUP
For I=0 To [M]NBRSUP-1
 Case [F:TPY]DACSUP(I)
  When 1       : [M]DACSUP(I) = 2 : [M]SUPOBL(I) = 2
  When 2       : [M]DACSUP(I) = 2 : [M]SUPOBL(I) = 1
  When Default : [M]DACSUP(I) = 1 : [M]SUPOBL(I) = 1
 Endcase
Next I
For ZONE="BAN","CPY","REF","FRMREF","DES","DESLIN","PAM","ORIDAT","DUDDAT","BANDAT","VALDAT",
&        "BILDAT","BID","PAB1","PAB2","BPRREF","CHQTYP","CHQNUM","CHQBAN","FRMTYP","CRDNUM",
&        "CRDAUZ","PURTYP","AMTBAN","CURRAT"
 Case evalue("[F:TPY]DAC"+ZONE)
  When 1       : C1 = 2 : C2 = 2
  When 2       : C1 = 2 : C2 = 1
  When Default : C1 = 1 : C2 = 1
 Endcase
 If evalue("dim([M]DAC"+ZONE+")")>0
  Assign "[M]DAC"+ZONE With C1
 Endif
 If evalue("dim([M]"+ZONE+"OBL)")>0
  Assign "[M]"+ZONE+"OBL" With C2
 Endif
Next ZONE
Call LEC_TED(GCURLEG,[M]CODEDT) From CPTLEC
If find([F:TED]TRT,"CHE","CHR")
 [M:TPY3]ACETYP92 = 0 : Grizo [M:TPY3]ACETYP92
 [M:TPY3]JOU82 = 0 : Grizo [M:TPY3]JOU82
Else
 Actzo [M:TPY3]ACETYP92
 Actzo [M:TPY3]JOU82
Endif
If func AFNC.ACTIV("CASIN") : Gosub TPY_LIENS From EXPCASPAY : Endif

# SAM 81743: Get PROBALCTL parameter and enable balance control if needed
Gosub CHK_PROBALCTL
# Disable Balance control if entry batch (DACPYL) is deactivated
If [M:TPY2]DACPYL = 2
  Actzo [M:TPY2]LOTPROBALCTL
Else
  Grizo [M:TPY2]LOTPROBALCTL
Endif
Affzo [M:TPY2]LOTPROBALCTL

#ISSUE 60081 - 2017-10-20 by MRDAB - refactored to be protected by REGBC activity code
If func AFNC.ACTIV("REGBC")
  [L]REGBC_ACTIVE = 1
Endif

If [F:TPY]SNS=3
 Raz [M:TPY3]EPACDTTRF, FILREF8 : Grizo [M:TPY3]EPACDTTRF, FILREF8 : Affzo [M:TPY3]EPACDTTRF, FILREF8
Elsif [L]REGBC_ACTIVE = 1
 If [M:TPY2]DACPAYTYP <> 1
   Raz [M:TPY3]EPACDTTRF, FILREF8 : Grizo [M:TPY3]EPACDTTRF, FILREF8 : Affzo [M:TPY3]EPACDTTRF, FILREF8
 Endif
Else
 Actzo [M:TPY3]EPACDTTRF, FILREF8
Endif
#END ISSUE

#Issue 31726 – 2017-04-03  by MADOR - As a treasury administrator I want to enable
#and disable the fields regarding currency rates
Call CHANGEDACCURRAT([M:TPY1]RATINV)
Call CHANGERATINV([M:TPY2]DACCURRAT)
#Issue End

#ISSUE 33454 – 2017-05-18  by MADOR/MRDAB - As as treasury manager I want to be able to define
# WHICH PAYMENTS WILL BE USED IN CASH/BANK REGISTERS and THE ONES To USE IN STANDARD GESPAY FUNCTION
If [L]REGBC_ACTIVE = 1
  Call CHANGE_PAYENTTYP_STATE([M:TPY0]LEG)
Endif
#ISSUE END

Return

$CREATION

#X3-42495 DATEV Compliancy
Local Integer DATCOMP : DATCOMP = 0
Call CHECK_DATEV_COMP(DATCOMP)
If DATCOMP = 1 : Return : Endif
#X3-42495 DATEV Compliancy End

Call CTL_LEG([F:TPY]PAYTYP,GOK) From SUBTPY
If GOK<1 : Return : Endif

$MODIF
#X3-42495 DATEV Compliancy
Local Integer DATCOMP : DATCOMP = 0
Call CHECK_DATEV_COMP(DATCOMP)
If DATCOMP = 1 : Return : Endif
#X3-42495 DATEV Compliancy End
Gosub TEXTRA
If GOK<1 : Return : Endif
If func AFNC.ACTIV("CASIN") : Gosub TPY_CREATION From EXPCASPAY : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("TABPAYTYP","DESTRA",CLECUR2,CLECUR1,"TABPAYTYP","DESTRA",[F:TPY]PAYTYP,[F:TPY]LEG)  From ATEXTRA
 Call DUPTEXTRA("TABPAYTYP","SHOTRA",CLECUR2,CLECUR1,"TABPAYTYP","SHOTRA",[F:TPY]PAYTYP,[F:TPY]LEG)  From ATEXTRA
Endif
Call MAJTEXTRA([M:TPY0]DESTRA,"TABPAYTYP","DESTRA",[F:TPY]PAYTYP,[F:TPY]LEG) From ATEXTRA
Call MAJTEXTRA([M:TPY0]SHOTRA,"TABPAYTYP","SHOTRA",[F:TPY]PAYTYP,[F:TPY]LEG) From ATEXTRA
Return

$VERIF_CRE
$VERIF_MOD
Local Integer N
If !clalev([F:TAM]) : Local File TABPAM [TAM] : Endif
If [M:TPY3]EPACDTTRF=2
 For N=0 To [M:TPY1]NBRPAM-1
  Call LEC_TAM([M:TPY0]LEG, [M:TPY1]PAM(N)) From CPTLEC
  If ([M:TPY1]SNS=1 and [F:TAM]SDDFLG=2) or ([M:TPY1]SNS=2 and [F:TAM]SDDFLG<>2)
   OK=0 : GERR=1 : GMESSAGE=func AFNC.MES1(mess(266,117,1), [M:TPY1]PAM(N)) : Break
  Endif
 Next
 If OK=0 : Return : Endif
Endif

# 113582.n - For Sage Exchange/Sage Pay - require intermediate posting if payment grouping not used.
If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC_PAY_TYP()
  If [M]STA5=[V]CST_AYES & [M]ACETYP91<>1 & [M]STA8<>[V]CST_AYES
   OK=0 : GERR=1 : GMESSAGE=mess(58,2092,1)
  Endif
  If OK=0 : Return : Endif
Endif

Return

$INIMOD
$INICRE
If func AFNC.ACTIV("LEG")=0 : [F:TPY]LEG = GDOSLEG(1) : Endif

#Fichier pivot xml : Zone référence cochée obligatoire
If left$([M:TPY3]FILREF8,7)="SAGEXML" | left$([M:TPY3]FILREF6,7)="SAGEXML"
 [M:TPY2]REFOBL = 2
Endif
If dim([F:TPY]DES)>0
 [F:TPY]DES = [M:TPY0]DESTRA
Endif
For I=0 To [M]NBRSUP-1
 If [M]DACSUP(I)=2
  If [M]SUPOBL(I)=2
   [F:TPY]DACSUP(I) = 1
  Else
   [F:TPY]DACSUP(I) = 2
  Endif
 Else
  [F:TPY]DACSUP(I) = 3
 Endif
Next I
For ZONE="BAN","CPY","REF","FRMREF","DES","DESLIN","PAM","ORIDAT","DUDDAT","BANDAT","VALDAT",
&        "BILDAT","BID","PAB1","PAB2","BPRREF","CHQTYP","CHQNUM","CHQBAN","FRMTYP","CRDNUM",
&        "CRDAUZ","PURTYP","AMTBAN","CURRAT"
 C1 = 1 : C2 = 1
 If evalue("dim([M]DAC"+ZONE+")")>0
  C1 = evalue("[M]DAC"+ZONE)
 Endif
 If evalue("dim([M]"+ZONE+"OBL)")>0
  C2 = evalue("[M]"+ZONE+"OBL")
 Endif
 If C1=2 & C2=2
  C3 = 1
 Elsif C1=2
  C3 = 2
 Else
  C3 = 3
 Endif
 If evalue("dim([F:TPY]DAC"+ZONE+")")>0
  Assign "[F:TPY]DAC"+ZONE With C3
 Endif
Next ZONE

Return

$TST_SUP
OK = 1
If find([F:AMZ]CODZON,"CPY","ACCDAT","PAM","BAN","FRMREF","REF","DES"
&  ,"SNS","CUR","AMTCUR","AMTBAN","CURRAT","CHQTYP","CHQNUM","CHQBAN","DUDDAT"
&  ,"FRMTYP","ORIDAT","BPRREF","BANDAT","VALDAT","BILDAT","CRDTYP","CRDNUM"
&  ,"CRDEXYDAT","CRDAUZ","PURTYP","BIDCRY","BID","PAB1","PAB2","EPANATPAY","EPARENPAY")
 OK = 0
Endif
Return

$VALID
If !GIMPORT
 Call VALIDATION([F:TPY]PAYTYP,nomap)
Endif
Call VALID("PAY",nomap,1,OK) From VALOBJ
Return

$ANNULE
#Annulations des textes traduisibles
Call SUPTEXTRA("TABPAYTYP","DESTRA",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("TABPAYTYP","SHOTRA",SUPP,[L]CODE) From ATEXTRA
# Annulation des écrans
Local Char MASQUE1(12) , MASQUE2(12)
MASQUE1 = "WMP1"+SUPP+CODE
MASQUE2 = "WMP2"+SUPP+CODE
Call DELMSK(MASQUE1,nomap) From MSKDIV
If GOK<1 : Return : Endif
Call DELMSK(MASQUE2,nomap) From MSKDIV
If GOK<1 : Return : Endif
Local Char NOMWIN(12)
NOMWIN = "WOPY"+SUPP+CODE
Call DELWIN(NOMWIN,nomap) From MSKDIV
If GOK<1 : Return : Endif
Return

$AP_ANNULE
Call VALID("PAY",nomap,1,OK) From VALOBJ
Return

$CHANGE
# Annulation anciens écrans
Local Char MASQUE1(12) , MASQUE2(12)
MASQUE1 = "WMP1"+SUPP+OCODE
MASQUE2 = "WMP2"+SUPP+OCODE
Call TR_DELMSK(MASQUE1,nomap) From MSKDIV
Call TR_DELMSK(MASQUE2,nomap) From MSKDIV
Local Char NOMWIN(12)
NOMWIN = "WOPY"+SUPP+OCODE
Call TR_DELWIN(NONWIN,nomap) From MSKDIV
# Validation des nouveaux
Read [TPY]TPY0 = NCODE;SUPP
Call VALIDATION(NCODE,nomap)
Return

$AP_CHANGE
Call CHGTEXTRA("TABPAYTYP","DESTRA",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("TABPAYTYP","SHOTRA",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# To manage the Tunnel button
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONTPY) : Endif
VCOD = CLE2
Return

$AB1_AUTACE
Local Integer OPTACE
OPTACE = GBIDI1
GBIDI1 = 2
Return

$BB1_AUTACE
GBIDI1 = OPTACE
Return

######################################################
Subprog CTL_LEG(TPY,STAT)
Value    Char TPY()
Variable Integer STAT
STAT = 1

If [L]TPY<>"" & GCURLEG<>""

 # Enregistrement d'une transaction avec la législation différente de vide.
 # Message d'avertissement à afficher si le code transaction existe déjà avec une législation vide.
 # Exemple :
 #    CCHQ/vide, des règlements ont déjà été saisis sur une société de législation FRA
 #    Lorsque l'utilisateur définira une nouvelle transaction CCHQ/FRA, le message doit s'afficher :
 #    "Réglements existants sur la législation FRA. Voulez vous continuer ?"

 If !clalev([F:PYH])  : Local File PAYMENTH  [PYH]  : Endif
 If !clalev([F:CPY])  : Local File COMPANY   [CPY]  : Endif
 If !clalev([F:TPY2]) : Local File TABPAYTYP [TPY2] : Endif
 Local Integer OK

 Look [TPY2]TPY0(1) = [L]TPY
 If !fstat

  Filter [CPY] Where LEG=GCURLEG
  Link [PYH] With [CPY]CPY0~=[F:PYH]CPY  As [LNK] Where [F:PYH]PAYTYP=[L]TPY & [F:CPY]LEG=GCURLEG
  If rowcount([F:LNK])>0
   Call AVERTIR(mess(265,117,1)-GCURLEG-"\"-mess(205,100,1),OK) From GESECRAN
   If OK<>2 : STAT=0 : Endif
  Endif
  Filter [CPY]
 Endif
Endif
End

######################################################
Subprog PATCH(APPLI)
Value Char APPLI()

If APPLI="X3" : End : Endif
Onerrgo CHUT From CONTROLE
Local File =APPLI+".ADOVAL" [ADW]
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Read [ADW]ADW0 = "";"";"MODULE1"
If fstat=0 & ([F:ADW]VALEUR="" | mid$([F:ADW]VALEUR,3,1)="2") : # si module Tiers
 Call GENDOS(APPLI) From SUBTPY
Endif
End

Subprog GENDOS(APPLI)
Value Char APPLI
Local Integer OK

Local File =APPLI+".AMSK"    [AMK] , =APPLI+".AMSK"    [AMK2]
Local File =APPLI+".AMSKZON" [AMZ] , =APPLI+".AMSKZON" [AMZ2]
Local File =APPLI+".AMSKZON" [AMZ3]

Local File =APPLI+".AMSKACT" [AMA] , =APPLI+".AMSKACT" [AMA2]
Local File =APPLI+".AMSKPAR" [AMP] , =APPLI+".AMSKPAR" [AMP2]
Local File =APPLI+".TABPAYTYP" [TPY]
Local File =APPLI+".AWINDOW"  [AWI]
Local File =APPLI+".AWINPAR"  [AWP]
Local File =APPLI+".AWINBOUT" [AWT]
Local File =APPLI+".AWINBRO"  [AWB]
Local File =APPLI+".AOBJET"  [AOB] , =APPLI+".AOBJTAB" [AOT] , =APPLI+".AOBJLST" [AOL]
For [TPY]TPY0
 If GTRACE<>"" : Call ECR_TRACE([F:TPY]PAYTYP,0) From GESECRAN : Endif
 Call VALIDATION([F:TPY]PAYTYP,APPLI)
Next
Call VALID("PAY",APPLI,1,OK) From VALOBJ
End

Subprog VALIDATION(COD,APPLI)
Value Char COD
Value Char APPLI
If clalev([F:AMK2])=0 : Local File AMSK    [AMK2] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
If clalev([F:AMZ2])=0 : Local File AMSKZON [AMZ2] : Endif
If clalev([F:AMZ3])=0 : Local File AMSKZON [AMZ3] : Endif
If clalev([F:AMA])=0 : Local File AMSKACT [AMA] : Endif
If clalev([F:AMA2])=0 : Local File AMSKACT [AMA2] : Endif
If clalev([F:AMP])=0 : Local File AMSKPAR [AMP] : Endif
If clalev([F:AMP2])=0 : Local File AMSKPAR [AMP2] : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If clalev([F:AWI])=0  : Local File AWINDOW  [AWI] : Endif
If clalev([F:AWP])=0  : Local File AWINPAR  [AWP] : Endif
If clalev([F:AWT])=0  : Local File AWINBOUT [AWT] : Endif
If clalev([F:AWB])=0  : Local File AWINBRO  [AWB] : Endif
Local Char    MASKREF1(12) , MASKREF2(12) , MASKREF3(12)
Local Char    MASKDES1(12) , MASKDES2(12) , SAVLAN(3)
Local Integer NZON , NRIB , NBECR , LANCUR, NLNG
Local Integer I, J, Y4 , NUMFIN , ZONFIN
Local Integer N1 , N2 , N3 , N4 , N5
Local Integer NZ , BL , M1 , M2 , M3
Local Integer OK
Global Integer GCALL_PT : Raz GCALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("SUBTPY",GENTSTD(1..GNBENTREE)) : GCALL_PT=1 : Endif
Call TEMPON("V") From GESECRAN
Call DEBTRANS From GLOCK
MASKREF1 = "PAY1"
MASKREF2 = "PAY2"
MASKREF3 = "PAY3"
MASKDES1 = "WMP1"+[F:TPY]PAYTYP+[F:TPY]LEG
MASKDES2 = "WMP2"+[F:TPY]PAYTYP+[F:TPY]LEG
# Effacements des masques précédents
Call TR_DELMSK(MASKDES1,APPLI) From MSKDIV
Call TR_DELMSK(MASKDES2,APPLI) From MSKDIV
Gosub TR1
Call TEMPOFF From GESECRAN
If GOK=1
 If [F:TPY]ENAFLG=2
  Read [ADS]DOSSIER = APPLI
  #*X3-70924  Call VALID(MASKDES1,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
  Call VALIDFULL(MASKDES1,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
  Read [AMK2]CODMSK = MASKDES2
  If !fstat
   #*X3-70924  Call VALID(MASKDES2,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
   Call VALIDFULL(MASKDES2,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
  Endif
 Endif
Endif
Local Char    NOMWIN(12) , WINREF(12)
Local Integer OK
NOMWIN = "WOPY"+[F:TPY]PAYTYP+[F:TPY]LEG
WINREF = "OPAY"
Call DEBTRANS From GLOCK
Gosub TR2
If GOK>0
 If [F:TPY]ENAFLG=2
  Call VALID(NOMWIN,APPLI,1,OK) From VALWIN
 Else
  Local Char TRTWIN(12)
#  Call NOMTRTWIN(NOMWIN,TRTWIN) From MSKDIV
  If NOMWIN<>"" : TRTWIN="WG"+NOMWIN : Endif
  Call EFFACE_ADX("",APPLI,TRTWIN,OK) From ORDSYS
  Call EFFACE(filpath("TRT",TRTWIN,"src",APPLI),OK) From ORDSYS
 Endif
Endif
# Demande 30010
If GCALL_PT : GPOINT = "MGTTPY" : Gosub ENTREE From EXEFNC : Endif
Kill GCALL_PT
End

$TR1
GOK = 1
Trbegin [AMK2] , [AMZ2] , [AMA2] , [AMP2] , [AMZ3]

# Construction des masques

 If [F:TPY]ENAFLG=2

# 1ère passe, on compte les zones

  NZON = 3 : # Date, devise, montant
  NRIB = 0 : NLNG = 1
  If [F:TPY]DACCPY<>3       : NZON += 1 : Endif : # Société
  If [F:TPY]DACPAM<>3       : NZON += 1 : Endif : # Mode règlement
  If [F:TPY]DACBAN<>3       : NZON += 1 : Endif : # Banque
  If [F:TPY]DACFRMREF<>3    : NZON += 1 : Endif : # Réf bordereau
  If [F:TPY]DACREF<>3       : NZON += 1 : Endif : # Réf pièce
  If [F:TPY]DACDES<>3       : NZON += 1 : NLNG += 1 : Endif : # Libellé
  If [F:TPY]SNS= 3          : NZON += 1 : Endif : # Sens
  If [F:TPY]DACAMTBAN<>3    : NZON += 1 : NLNG += 1 : Endif : # Montant banque
  If [F:TPY]DACCURRAT<>3    : NZON += 1 : Endif : # Curret rates
  If [F:TPY]DACCHQTYP<>3    : NZON += 1 : Endif : # Type chèque
  If [F:TPY]DACCHQNUM<>3    : NZON += 1 : Endif : # Numéro chèque
  If [F:TPY]DACCHQBAN<>3    : NZON += 1 : Endif : # Etab payeur
  If [F:TPY]DACDUDDAT<>3    : NZON += 1 : Endif : # Date échéance
  If [F:TPY]DACBANDAT<>3    : NZON += 1 : Endif : # Date banque
  If [F:TPY]DACVALDAT<>3    : NZON += 1 : Endif : # Date valeur
  If [F:TPY]DACBILDAT<>3    : NZON += 1 : Endif : # Date création
  If [F:TPY]DACORIDAT<>3    : NZON += 1 : Endif : # Date origine
  If [F:TPY]DACFRMTYP<>3    : NZON += 1 : Endif : # Type de remise
  If [F:TPY]DACBPRREF<>3    : NZON += 1 : Endif : # Référence tiré
  If [F:TPY]DACCRDNUM<>3    : NZON += 3 : Endif : # Infos carte bleue
  If [F:TPY]DACCRDAUZ<>3    : NZON += 1 : Endif : # No autorisation
  If [F:TPY]DACPURTYP<>3    : NZON += 1 : Endif : # Type d'achat
  If [F:TPY]DACBID<>3       : NRIB += 1 : Endif : # RIB
  If [F:TPY]DACPAB1<>3      : NRIB += 1 : Endif : # Domi 1
  If [F:TPY]DACPAB2<>3      : NRIB += 1 : Endif : # Domi 2
  If [F:TPY]EPACDTTRF=2     : NZON += 2 : Endif : # Nature SEPA
  If [F:TPY]EPACDTTRF=2 & [F:TPY]SNS= 2 : NZON += 1 : Endif : # Référence mandat
  For I=0 To [F:TPY]NBRSUP-1
   If [F:TPY]DACSUP(I)<>3 : NZON += 1 : Endif
  Next I

# Combien va-t-on faire d'écrans ??
  If NRIB=0 & NZON<=11 : # Pas de rib, on peut mettre 13 infos
   NBECR = 1
  Elsif 2*NRIB+NZON<=10 : # Les zones rib comptent pour 2 + le trait
   NBECR = 1
  Else
   NBECR = 2
  Endif
  If NBECR=1 : # Cas où il n'y qu'un écran
   Read [AMK]CODMSK = MASKREF1
   [F:AMK2] = [F:AMK]
   [F:AMK2]CODMSK  = MASKDES1
   [F:AMK2]INTMSK  = 0
   [F:AMK2]MDL     = 1
   ###Le bloc no 3 ne contient pas toujours de zone et pour des
   ###raisons esthétiques, on le met en invisible par défaut et
   ###on le rendra visible que si cela est necessaire
   [F:AMK2]TYPBLOC(2) = 5 :# invisible
   ###
   If NRIB=0
    Case NZON
     When 5       : Y4 = 11
     When 6,7     : Y4 = 12
     When 8,9     : Y4 = 13
     When 10,11   : Y4 = 14
     When 12,13   : Y4 = 15
     When Default : Y4 = 10
    Endcase
    ###Si il y a plus de 6 zones à mettre dans le bloc n°2
    ###on est obligé de lui ajouter une ligne pour que toutes les zones rentrent...
    ###Du coup, on enlève une colonne au bloc n°3 afin que la hauteur du bloc n°2
    ###ne viennent pas chevaucher la largeur du bloc n°3.
    ###Exemple avec la transaction de code CCHQ.
    If Y4>12
     [F:AMK2]LINBLOC(1)+=1 :#On ajoute une ligne
     [F:AMK2]COLBLOC(2)-=1 :#On enlève une colonne
    Endif
    ###
    M2 = 4+(Y4-10)
    M3 = (Y4-11)
   Else
    M2 = 4
    M3 = 4
    Y4 = 15
   Endif
   [F:AMK2]RANG(0) = 5
   [F:AMK2]RANG(1) = 10
   [F:AMK2]RANG(2) = 15
   [F:AMK2]RANG(3) = 25
   [F:AMK2]RANG(4) = 30
   For [AMZ]CODZON Where CODMSK=MASKREF1 & NUMBLOC<>4
    [F:AMZ2] = [F:AMZ]
    [F:AMZ2]CODMSK = MASKDES1
    Gosub SPECIAL
    Write [AMZ2]
    If fstat
     GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
    Endif
    Call COPIE_ACTION(MASKREF1,MASKDES1,[F:AMZ]CODZON)
    If GOK<1 : Break : Endif
    Gosub AFFDEV
    If GOK<1 : Break : Endif
   Next
   If   GOK<0 : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
   For [AMZ]CODZON Where CODMSK=MASKREF3
    [F:AMZ2] = [F:AMZ]
    [F:AMZ2]CODMSK = MASKDES1
    [F:AMZ2]NUMBLOC = 4
    Gosub SPECIAL
    Write [AMZ2]
    If fstat
     GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
    Endif
    Call COPIE_ACTION(MASKREF3,MASKDES1,[F:AMZ]CODZON)
    If GOK<1 : Break : Endif
    Gosub AFFDEV
    If GOK<1 : Break : Endif
   Next
   If   GOK<0 : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
   N2 = 1 : N3 = 1 : N5 = 1 : N4 = 0

   For [AMZ]CODZON Where CODMSK=MASKREF2
    [F:AMZ2] = [F:AMZ]
    [F:AMZ2]CODMSK = MASKDES1
    Gosub SET_OK
    If OK
     If find([F:AMZ]CODZON,"BID","BIDCRY","PAB1","PAB2")
      If NRIB>0 & N4=1
       N4 = 0 : N3 += 1
      Endif
      ###DBA le 14/05/03 : Le bloc n°3 va contenir des zones, on le repasse en bloc visible
      [F:AMK2]TYPBLOC(2) = 2 :# Liste
      BL = 3
      NZ = N3 : If [F:AMZ]CODZON<>"BIDCRY" : N3 += 1 : Endif
     Elsif find([F:AMZ]CODZON,"DES","CUR","AMTCUR","AMTBAN")
         BL = 2
         NZ = N2 : N2 += 1
         NLNG -= 1
     Else
      If N2+NLNG<=M2
       BL = 2
       NZ = N2 : N2 += 1
      Else
      ###Le bloc n°3 va contenir des zones, on le repasse en bloc visible
      [F:AMK2]TYPBLOC(2) = 2 :#Liste
       BL = 3
       If NRIB>0 & N4=0
        NZ = N3+.1 : N4 = 1
       Elsif NRIB>0
        NZ = N3+.2 : N3 += 1 : N4 = 0
       Else
        NZ = N3 : N3 += 1
       Endif
      Endif
     Endif
     [F:AMZ2]SAIAFF = AFF
     [F:AMZ2]OBLIG  = OBL
    Else
     BL = 5
     NZ = N5 : N5 += 1
     [F:AMZ2]SAIAFF = 3
    Endif
    [F:AMZ2]NUMBLOC = BL
     Case [F:AMZ]CODZON
      When "BIDCRY"
       [F:AMZ2]NOZONE  = NZ+.1
      When "BID", "CURRAT"
       [F:AMZ2]NOZONE  = NZ+.2
      When Default
       [F:AMZ2]NOZONE  = NZ
     Endcase
    Gosub SPECIAL
    Write [AMZ2]
    If fstat
     GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
    Endif
    Call COPIE_ACTION(MASKREF2,MASKDES1,[F:AMZ]CODZON)
    If GOK<1 : Break : Endif
    Gosub AFFDEV
    If GOK<1 : Break : Endif
   Next
   If   GOK<0 : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
   Read [AMK]CODMSK = MASKREF3
   [F:AMK2]NBLIGT(3) = [F:AMK]NBLIGT(0)
   [F:AMK2]BASPAG(3) = [F:AMK]BASPAG(0)
   [F:AMK2]OPTION(3) = [F:AMK]OPTION(0)
   If [F:TPY]NBRCOL>0
    [F:AMK2]OPTION(3) += num$([F:TPY]NBRCOL)
   Endif
   [F:AMK2]TITBLOC(3) = [F:AMK]TITBLOC(0)
   Write [AMK2]
   If fstat
    GOK=0 : Call FSTA("AMK2") From GLOCK : Goto AB_TR1
   Endif
  Else : # Y'a malheureusement 2 écrans
#  Le premier
   Read [AMK]CODMSK = MASKREF1
   [F:AMK2] = [F:AMK]
   [F:AMK2]CODMSK  = MASKDES1
   [F:AMK2]INTMSK  = 0
   [F:AMK2]MDL     = 1
   [F:AMK2]TYPBLOC(3) = 2 : # Liste
   [F:AMK2]ACTBLOC(3) = ""
   [F:AMK2]NBLIGT(3)  = 0
   [F:AMK2]OPTION(3)  = ""
   [F:AMK2]BASPAG(3)  = ""
   [F:AMK2]LNGLIB(3)  = 18
   [F:AMK2]RANG(0) = 5
   [F:AMK2]RANG(1) = 10
   [F:AMK2]RANG(2) = 15
   [F:AMK2]RANG(3) = 20
   ###Le bloc no 3 ne contient pas toujours de zone et pour des
   ###raisons esthétiques, on le met en invisible par défaut et
   ###on le rendra visible que si cela est necessaire
      [F:AMK2]TYPBLOC(2) = 5 :# invisible
   ###
   If NRIB=0
    ###Ici on veut 4 blocs, 2 sur la 1ère ligne, 2 sur la 2ème ligne.
    ###L'écran de ref. PAY1 a bien ces 2 premiers bloc sur la même ligne mais
    ###les 2 suivants, sont l'un en-dessous de l'autre.
    ###Du coup, on enlève une colonne aux blocs 3 et 4 et on repositionne
    ###le 4ème à coté du 3ème.
    ###Exemple avec la transaction de code BAN.
    [F:AMK2]COLBLOC(2)-=1     :#On enlève une colonne
    [F:AMK2]COLBLOC(3)-=1     :#On enlève une colonne
    [F:AMK2]POSBLOC(3)-=0.9   :#On repositionne le bloc 4 sur la même ligne que le n°3
    ###
    M2 = 4 : M3 = 10 : M4 = 10
   Else
    ###il y a beaucoup de zones à mettre dans le bloc n°2
    ###on est obligé de lui ajouter une ligne pour que toutes les zones rentrent...
    ###Du coup, on enlève une colonne au bloc n°3 afin que la hauteur du bloc n°2
    ###ne viennent pas chevaucher la largeur du bloc n°3.
    ###Exemple avec la transaction de code CHR4.
    [F:AMK2]LINBLOC(1)+=1 :#On ajoute une ligne
    [F:AMK2]COLBLOC(2)-=1 :#On enlève une colonne
    ###
    M2 = 11 : M3 = 6 : M4 = 3
   Endif
   [F:AMK2]TYPBLOC(5) = 5
   For [AMZ]CODZON Where CODMSK=MASKREF1 & NUMBLOC<>4 & NUMBLOC<>6
    [F:AMZ2] = [F:AMZ]
    [F:AMZ2]CODMSK = MASKDES1
    Gosub SPECIAL
    Write [AMZ2]
    If fstat
     GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
    Endif
    Call COPIE_ACTION(MASKREF1,MASKDES1,[F:AMZ]CODZON)
    If GOK<1 : Break : Endif
    Gosub AFFDEV
    If GOK<1 : Break : Endif
   Next
   If   GOK<0 : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
   N2 = 1 : N3 = 1 : N4 = 1
   NUMFIN = 0
   For [AMZ]CODZON Where CODMSK=MASKREF2
    [F:AMZ2] = [F:AMZ]
    [F:AMZ2]CODMSK = MASKDES1
    Gosub SET_OK
    If OK
     BL = 0 : NZ = 0
     If find([F:AMZ]CODZON,"BID","BIDCRY","PAB1","PAB2")
      BL = 4
      NZ = N4 : If [F:AMZ]CODZON<>"BIDCRY" : N4 += 1 : Endif
     Elsif NUMFIN=0
      If find([F:AMZ]CODZON,"DES","AMTCUR","AMTBAN")
        If NZON<=M2
         BL = 2
         NZ = N2 : N2 += 1
        Else
         BL = 3
         NZ = N3 : N3 += 1
         [F:AMK2]TYPBLOC(2) = 2
        Endif
      Elsif N2<=M2
       BL = 2
       NZ = N2 : N2 += 1
      Elsif N3<=M3
       ###Le bloc n°3 va contenir des zones, on le repasse en bloc visible
       [F:AMK2]TYPBLOC(2) = 2 :#Liste
       BL = 3
       NZ = N3 : N3 += 1
      Elsif N4<=M4 & NRIB=0
       BL = 4
       NZ = N4 : N4 += 1
      Else
       NUMFIN = [F:AMZ]NUMBLOC
       ZONFIN = [F:AMZ]NOZONE
      Endif
     Endif
     [F:AMZ2]SAIAFF = AFF
     [F:AMZ2]OBLIG  = OBL
    Else
     BL = 5
     NZ = N5 : N5 += 1
     [F:AMZ2]SAIAFF = 3
    Endif
    If BL<>0
     [F:AMZ2]NUMBLOC = BL
     Case [F:AMZ]CODZON
      When "BIDCRY"
       [F:AMZ2]NOZONE  = NZ+.1
      When "BID", "CURRAT"
       [F:AMZ2]NOZONE  = NZ+.2
      When Default
       [F:AMZ2]NOZONE  = NZ
     Endcase
     Gosub SPECIAL
     Write [AMZ2]
     If fstat
      GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
     Endif
     Call COPIE_ACTION(MASKREF2,MASKDES1,[F:AMZ]CODZON)
     If GOK<1 : Break : Endif
     Gosub AFFDEV
     If GOK<1 : Break : Endif
    Endif
   Next
   If   GOK<0 : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
   Write [AMK2]
   If fstat
    GOK=0 : Call FSTA("AMK2") From GLOCK : Goto AB_TR1
   Endif
#  Le deuxième
   Read [AMK]CODMSK = MASKREF1
   [F:AMK2] = [F:AMK]
   [F:AMK2]ABRMSK  = "PAY2"
   [F:AMK2]CODMSK  = MASKDES2
   [F:AMK2]MDL     = 1
   [F:AMK2]INTMSK  = 0
   [F:AMK2]TYPBLOC(2) = 5 : # Invisible
   NZON -= ((N2-1)+(N3-1))
   If NRIB=0 : NZON -= (N4-1) : Endif
   If NZON<0 : NZON = 0 : Endif
   Case NZON
    When 0       : Y4 = 5
                   [F:AMK2]TYPBLOC(0) = 5
                   [F:AMK2]TYPBLOC(1) = 5
    When 1,2     : Y4 = 7
    When 3,4     : Y4 = 8
    When 5,6     : Y4 = 9
    When 7,8     : Y4 = 10
    When 9,10    : Y4 = 11
    When 11,12   : Y4 = 12
    When 13,14   : Y4 = 13
    When 15,16   : Y4 = 14
    When 17,18   : Y4 = 15
   Endcase
   [F:AMK2]RANG(0) = 5
   [F:AMK2]RANG(1) = 10
   [F:AMK2]RANG(2) = 15
   [F:AMK2]RANG(3) = 25
   [F:AMK2]RANG(4) = 30
   M1 = Y4-6 : M2 = M1
   N1 = 1 : N2 = 1 : N5 = 1
   If NUMFIN<>0
    For [AMZ]CODZON Where CODMSK=MASKREF2 & (NUMBLOC>NUMFIN
&                         | (NUMBLOC=NUMFIN & NOZONE>=ZONFIN))
     [F:AMZ2] = [F:AMZ]
     [F:AMZ2]CODMSK = MASKDES2
     If find([F:AMZ]CODZON,"BID","BIDCRY","PAB1","PAB2")
      OK = 0
     Else
      Gosub SET_OK
      If OK
       If N1<=M1
        BL = 1
        NZ = N1 : N1 += 1
       Elsif N2<=M2
        BL = 2
        NZ = N2 : N2 += 1
       Else
       Endif
       [F:AMZ2]SAIAFF = AFF
       [F:AMZ2]OBLIG  = OBL
      Else
       BL = 5
       NZ = N5 : N5 += 1
       [F:AMZ2]SAIAFF = 3
      Endif
      [F:AMZ2]NUMBLOC = BL
      [F:AMZ2]NOZONE  = NZ
      Gosub SPECIAL
      Write [AMZ2]
      If fstat
       GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
      Endif
      Call COPIE_ACTION(MASKREF2,MASKDES2,[F:AMZ]CODZON)
      If GOK<1 : Break : Endif
     Endif
     Gosub AFFDEV
     If GOK<1 : Break : Endif
    Next
    If   GOK<0 : Goto ROLL_TR1
    Elsif !GOK : Goto AB_TR1
    Endif
   Endif
   For [AMZ]CODZON Where CODMSK=MASKREF3
    [F:AMZ2] = [F:AMZ]
    [F:AMZ2]CODMSK = MASKDES2
    [F:AMZ2]NUMBLOC = 4
    Gosub SPECIAL
    Write [AMZ2]
    If fstat
     GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
    Endif
    Call COPIE_ACTION(MASKREF3,MASKDES2,[F:AMZ]CODZON)
    If GOK<1 : Break : Endif
    Gosub AFFDEV
    If GOK<1 : Break : Endif
   Next
   If   GOK<0 : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
   For [AMZ]CODZON Where CODMSK=MASKREF1 & NUMBLOC=6
    [F:AMZ2] = [F:AMZ]
    [F:AMZ2]CODMSK = MASKDES2
    Gosub SPECIAL
    Write [AMZ2]
    If fstat
     GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
    Endif
    Call COPIE_ACTION(MASKREF1,MASKDES2,[F:AMZ]CODZON)
    If GOK<1 : Break : Endif
    Gosub AFFDEV
    If GOK<1 : Break : Endif
   Next
   If   GOK<0 : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
   Read [AMK]CODMSK = MASKREF3
   [F:AMK2]NBLIGT(3) = [F:AMK]NBLIGT(0)
   [F:AMK2]BASPAG(3) = [F:AMK]BASPAG(0)
   [F:AMK2]OPTION(3) = [F:AMK]OPTION(0)
   If [F:TPY]NBRCOL>0
    [F:AMK2]OPTION(3) += num$([F:TPY]NBRCOL)
   Endif
   [F:AMK2]TITBLOC(3) = [F:AMK]TITBLOC(0)
   Write [AMK2]
   If fstat
    GOK=0 : Call FSTA("AMK2") From GLOCK : Goto AB_TR1
   Endif
  Endif

 Endif : # ENAFLG

Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$SPECIAL
Case [F:AMZ2]CODZON
 When "BAN"
  [F:AMZ2]INTIT = 0
  If [F:TPY]BANCSH=1
   [F:AMZ2]CODTYP  = "BAN"
   [F:AMZ2]INTEVAL = "mess(1,653,1)"
  Else
   [F:AMZ2]CODTYP = "CAI"
   [F:AMZ2]INTEVAL = "mess(2,653,1)"
   [F:AMZ2]OBLIG   = 2 : # Caisse en principe obligatoire
  Endif
 When "DESLIN"
  If [F:TPY]DACDESLIN=3 : [F:AMZ2]SAIAFF = 3 : Endif
 When "UMRNUM"
  If [F:TPY]EPACDTTRF<>2 | [F:TPY]SNS<>2 : [F:AMZ2]SAIAFF = 3 : Endif
Endcase
If GCALL_PT : GPOINT = "BEFWRIAMZ" : Gosub ENTREE From EXEFNC : Endif
Return

$AFFDEV
## Affichage devise en inscrustation
If [F:AMZ2]CODZON = "AMTCUR"
 [F:AMZ3] = [F:AMZ2]
 [F:AMZ3]CODZON = "CURAMTCUR"
 [F:AMZ3]CODTYP = "CUR"
 [F:AMZ3]NOZONE = [F:AMZ2]NOZONE+.2
 [F:AMZ3]SAIAFF = 2
 [F:AMZ3]OPTSAI = "W"
 [F:AMZ3]VALDEF = "[M]CUR"
 [F:AMZ3]INTIT  = 0
 [F:AMZ3]PDSZON = 0
 Write [AMZ3]
 If fstat
  GOK=0 : Call FSTA("AMZ3") From GLOCK : Return
 Endif
Elsif [F:AMZ2]CODZON = "AMTBAN"
 [F:AMZ3] = [F:AMZ2]
 [F:AMZ3]CODZON = "CURAMTBAN"
 [F:AMZ3]CODTYP = "CUR"
 [F:AMZ3]NOZONE = [F:AMZ2]NOZONE+.2
 [F:AMZ3]SAIAFF = 2
 [F:AMZ3]OPTSAI = "W"
 [F:AMZ3]VALDEF = "[M]CURBAN"
 [F:AMZ3]INTIT  = 0
 [F:AMZ3]PDSZON = 0
 Write [AMZ3]
 If fstat
  GOK=0 : Call FSTA("AMZ3") From GLOCK : Return
 Endif
#Issue 31729 – 2017-05-19  by MADOR - As a treasury administrator I want to enable
#and disable the fields regarding currency rates
Elsif [F:AMZ2]CODZON = "CURRAT"
   [F:AMZ3] = [F:AMZ2]
   [F:AMZ3]CODZON = "FROCURRAT"
   [F:AMZ3]CODTYP = "CUR"
   [F:AMZ3]NOZONE = NZ + .1 #[F:AMZ2]NOZONE+.1
   [F:AMZ3]SAIAFF = 2
   [F:AMZ3]LONG   = 10
   [F:AMZ3]OPTSAI = "W"
   [F:AMZ3]VALDEF = "'1 ' + [M]CUR + ' ='"
   [F:AMZ3]INTIT  = 0
   [F:AMZ3]PDSZON = 0
   Write [AMZ3]
   If fstat
    GOK=0 : Call FSTA("AMZ3") From GLOCK : Return
   Endif

   [F:AMZ3] = [F:AMZ2]
   [F:AMZ3]CODZON = "CURCURRAT"
   [F:AMZ3]CODTYP = "CUR"
   [F:AMZ3]NOZONE = NZ + .3 #[F:AMZ2]NOZONE+.3
   [F:AMZ3]SAIAFF = 2
   [F:AMZ3]OPTSAI = "W"
   [F:AMZ3]VALDEF = "[M]CURCPY"
   [F:AMZ3]INTIT  = 0
   [F:AMZ3]PDSZON = 0
   Write [AMZ3]
   If fstat
    GOK=0 : Call FSTA("AMZ3") From GLOCK : Return
   Endif
#Issue end
Endif
Return

$SET_OK
OBL = 1 : AFF = 1
Case [F:AMZ]CODZON
 When "CPY"       : OK = [F:TPY]DACCPY : AFF = 2
 When "BAN"       : OK = [F:TPY]DACBAN
 When "PAM"       : OK = [F:TPY]DACPAM : If OK<3 : OK = 1 : Endif
 When "FRMREF"    : OK = [F:TPY]DACFRMREF
 When "REF"       : OK = [F:TPY]DACREF
 When "DES"       : OK = [F:TPY]DACDES
 When "SNS"       : OK = ([F:TPY]SNS=3)
 When "CUR"       : OK = 1
 When "AMTCUR"    : OK = 2
 When "AMTBAN"    : OK = [F:TPY]DACAMTBAN
 When "CURRAT"    : OK = [F:TPY]DACCURRAT
 When "ACCDAT"    : OK = 1
 When "ORIDAT"    : OK = [F:TPY]DACORIDAT
 When "DUDDAT"    : OK = [F:TPY]DACDUDDAT
 When "BANDAT"    : OK = [F:TPY]DACBANDAT
 When "VALDAT"    : OK = [F:TPY]DACVALDAT
 When "BILDAT"    : OK = [F:TPY]DACBILDAT
 When "CRDNUM"    : OK = [F:TPY]DACCRDNUM
 When "CRDEXYDAT" : OK = [F:TPY]DACCRDNUM
 When "CRDTYP"    : OK = [F:TPY]DACCRDNUM
 When "CRDAUZ"    : OK = [F:TPY]DACCRDAUZ
 When "BPRREF"    : OK = [F:TPY]DACBPRREF
 When "CHQTYP"    : OK = [F:TPY]DACCHQTYP
 When "CHQBAN"    : OK = [F:TPY]DACCHQBAN
 When "CHQNUM"    : OK = [F:TPY]DACCHQNUM
 When "FRMTYP"    : OK = [F:TPY]DACFRMTYP
 When "PURTYP"    : OK = [F:TPY]DACPURTYP
 When "BIDCRY"    : OK = [F:TPY]DACBID
 When "BID"       : OK = [F:TPY]DACBID
 When "PAB1"      : OK = [F:TPY]DACPAB1
 When "PAB2"      : OK = [F:TPY]DACPAB2
 When "EPANATPAY" : If [F:TPY]EPACDTTRF=2 : OK = 2 : Else : OK = 3 : Endif
 When "EPARENPAY" : If [F:TPY]EPACDTTRF=2 : OK = 2 : Else : OK = 3 : Endif
 When Default
  K = find([F:AMZ]CODZON,[F:TPY]ZONSUP(0..[F:TPY]NBRSUP-1))
  If K
   OK = [F:TPY]DACSUP(K-1)
  Else
   OK = 3
  Endif
Endcase
Case OK
 When 1       : OK = 1 : OBL = 2
 When 2       : OK = 1 : OBL = 1
 When Default : OK = 0 : OBL = 1
Endcase
Return

# Transfert actions et paramètres
Subprog COPIE_ACTION(MASKORG,MASKDES,ZONE)
Value Char MASKORG
Value Char MASKDES
Value Char ZONE
For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=MASKORG & CODZON=ZONE
 [F:AMA2] = [F:AMA]
 [F:AMA2]CODAFF = MASKDES
 Write [AMA2]
 If fstat
  GOK=0 : Call FSTA("AMA2") From GLOCK : Break
 Endif
Next
If GOK<1 : End : Endif
For [AMP]CODPAR Where TYPAFF=1 & CODAFF=MASKORG & CODZON=ZONE
 [F:AMP2] = [F:AMP]
 [F:AMP2]CODAFF = MASKDES
 Write [AMP2]
 If fstat
  GOK=0 : Call FSTA("AMP2") From GLOCK : Break
 Endif
Next
If GOK<1 : End : Endif
End

######################################################################
## Génération de la fenêtre
######################################################################
$TR2
GOK = 1
Trbegin [AWI] , [AWP] , [AWT] , [AWB]
 Delete [AWI] Where WIN=NOMWIN
 If fstat=1
  GOK = -1 : GLOCK = "$AWINDOW"-NOMWIN : Goto ROLL_TR2
 Endif
 Delete [AWP] Where WIN=NOMWIN
 If fstat=1
  GOK = -1 : GLOCK = "$AWINPAR"-NOMWIN : Goto ROLL_TR2
 Endif
 Delete [AWT] Where WIN=NOMWIN
 If fstat=1
  GOK = -1 : GLOCK = "$AWINBOUT"-NOMWIN : Goto ROLL_TR2
 Endif
 Delete [AWB] Where WIN=NOMWIN
 If fstat=1
  GOK = -1 : GLOCK = "$AWINPRO"-NOMWIN : Goto ROLL_TR2
 Endif
 If [F:TPY]ENAFLG=2
  Read [F:AWI]AWI0 = WINREF
  If !fstat
   [F:AWI]WIN = NOMWIN
#---------- Concerne la gestion d'adresse - onglet AFAC ----------#
#   [F:AWI]NOMMSK(4) = "PAY5"
#   I=find("PAY5",[F:AWI]NOMMSK(0..[F:AWI]NBMSK-1))
#   If I
#    [F:AWI]INTMSK(4) = [F:AWI]INTMSK(I-1)
#   Else
#    Read [AMK]CODMSK = "PAY5"
#    If !fstat : [F:AWI]INTMSK(4) = [F:AMK]INTMSK
#    Else      : [F:AWI]INTMSK(4) = 0
#    Endif
#   Endif
#   If [F:TPY]DACADD=2 : [F:AWI]FLGMSK(4) = 2 : Else [F:AWI]FLGMSK(4) = 1 : Endif
#-------------------------------------------------------------------------------#
# SAM 81743: get parameter for balance control and set extended entry batch (PAY4PBC) for value '2'
# otherwise use standard entry batch (PAY4)
# balance control has to be enabled in payment transaction (LOTPROBALCTL)
   Local Char P_PROBALCTL(1) : P_PROBALCTL = ""
   Call PARAM([F:TPY]LEG,"PROBALCTL",P_PROBALCTL) From ADOVAL
   Local Integer BCACTIVE : BCACTIVE = [F:TPY]LOTPROBALCTL
   If P_PROBALCTL = "2" and BCACTIVE = 2
     #set extended entry batch PAY4PBC
     [F:AWI]NOMMSK(3) = "PAY4PBC"
     I=find("PAY4PBC",[F:AWI]NOMMSK(0..[F:AWI]NBMSK-1))
     If I
      [F:AWI]INTMSK(3) = [F:AWI]INTMSK(I-1)
     Else
      Read [AMK]CODMSK = "PAY4PBC"
      If !fstat : [F:AWI]INTMSK(3) = [F:AMK]INTMSK
      Else      : [F:AWI]INTMSK(3) = 0
      Endif
     Endif
   Else #default PAY4
     [F:AWI]NOMMSK(3) = "PAY4"
     I=find("PAY4",[F:AWI]NOMMSK(0..[F:AWI]NBMSK-1))
     If I
      [F:AWI]INTMSK(3) = [F:AWI]INTMSK(I-1)
     Else
      Read [AMK]CODMSK = "PAY4"
      If !fstat : [F:AWI]INTMSK(3) = [F:AMK]INTMSK
      Else      : [F:AWI]INTMSK(3) = 0
      Endif
     Endif
   Endif
   # /MAGER
   If [F:TPY]DACPYL=2
    [F:AWI]MSKENT = "PAY0"
    [F:AWI]FLGMSK(3) = 2
   Else
    [F:AWI]MSKENT = "PAY00"
    [F:AWI]FLGMSK(3) = 1
   Endif
   If NBECR=1
    [F:AWI]NOMMSK(0) = MASKDES1
    [F:AWI]FLGMSK(0) = 2
   Else
    [F:AWI]NOMMSK(0) = MASKDES1
    [F:AWI]FLGMSK(0) = 2
    [F:AWI]NOMMSK(1) = MASKDES2
    [F:AWI]FLGMSK(1) = 2
   Endif
   For I=NBECR To 2
    [F:AWI]NOMMSK(I) = "PAYBID"+num$(I+1)
    [F:AWI]FLGMSK(I) = 1
   Next I
   [F:AWI]ACS    = [F:TPY]ACS
   #[F:AWI]LIBEL  = [F:TPY]DES #DdM54643
   [F:AWI]LIBEL  = ""
   [F:AWI]ENAFLG = 2
   [F:AWI]OBJ    = "PAY"
   [F:AWI]TRN    = [F:TPY]PAYTYP
   [F:AWI]MDL    = 1
   Write [AWI]
   For [AWP] Where WIN=WINREF
    [F:AWP]WIN = NOMWIN
    Write [AWP]
    If fstat
     GOK = 0 : Call FSTA("AWP") From GLOCK : Break
    Endif
   Next
   For [AWT] Where WIN=WINREF
    [F:AWT]WIN = NOMWIN
    Write [AWT]
    If fstat
     GOK = 0 : Call FSTA("AWT") From GLOCK : Break
    Endif
   Next
   For [AWB] Where WIN=WINREF
    [F:AWB]WIN = NOMWIN
    J=0
    For I=0 To 8
      If [F:AWB]OBJLIS(I)='PYL' & [F:TPY]DACPYL<>2    :# Onglet lot de saisie
       J=1
      Else
       [F:AWB]OBJLIS(I-J) = [F:AWB]OBJLIS(I)
       [F:AWB]INTLIS(I-J) = [F:AWB]INTLIS(I)
       [F:AWB]CLELIS(I-J) = [F:AWB]CLELIS(I)
       [F:AWB]ORDLIS(I-J) = [F:AWB]ORDLIS(I)
       [F:AWB]TRELIS(I-J) = [F:AWB]TRELIS(I)
       [F:AWB]BROLIS(I-J) = [F:AWB]BROLIS(I)
       [F:AWB]CHGLIS(I-J) = [F:AWB]CHGLIS(I)
       [F:AWB]ABRLIS(I-J) = [F:AWB]ABRLIS(I)
       [F:AWB]ACTLIS(I-J) = [F:AWB]ACTLIS(I)
       [F:AWB]EXPLIS(I-J) = [F:AWB]EXPLIS(I)
       [F:AWB]ROWLIS(I-J) = [F:AWB]ROWLIS(I)
      Endif
    Next I
    If J : [F:AWB]NBLIS -= 1 : Endif
    Write [AWB]
    If fstat
     GOK = 0 : Call FSTA("AWB") From GLOCK : Break
    Endif
   Next
   If fstat
    GOK = 0 : Call FSTA("AWI") From GLOCK : Goto AB_TR2
   Endif
  Endif
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

#########################################
## Copie                               ##
#########################################
$TRTCOP
Local Char LEGDEST(250)

If [M]DOSORG=nomap
 Local File TABPAYTYP [TPY1]
 Local File ATEXTRA   [AXX1]
 If filinfo(filpath("FIL","TABFILCASH","fde",""),0)>0 : Local File TABFILCASH [TFC1] : Endif
Else
 Local File =[M]DOSORG+".TABPAYTYP"  [TPY1]
 Local File =[M]DOSORG+".ATEXTRA"    [AXX1]
 If filinfo(filpath("FIL","TABFILCASH","fde",[M]DOSORG),0)>0 : Local File =[M]DOSORG+".TABFILCASH" [TFC1] : Endif
Endif
If [M]DOSDES=nomap
 Local File TABPAYTYP [TPY2]
 Local File ATEXTRA  [AXX2]
 If filinfo(filpath("FIL","TABFILCASH","fde",""),0)>0 : Local File TABFILCASH [TFC2] : Endif
Else
 Local File =[M]DOSDES+".TABPAYTYP"  [TPY2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
 If filinfo(filpath("FIL","TABFILCASH","fde",[M]DOSDES),0)>0 : Local File =[M]DOSDES+".TABFILCASH" [TFC2] : Endif
Endif
Gosub OUVDOS From ATEXTRA
# Multi-Lég... Vérifier que la législation existe dans le dossier destination
# Sous OUVDOS, le fichier ADOSSIER ADS2 du dossier destination est déjà en ligne
If TABLE2<>"" & clalev([F:ADS2])>0 & !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1))
 Call MESSAGE(TABLE2-":"-mess(249,133,1) ) From GESECRAN  # Législation non gérée par le dossier
 Return
Endif

# We can't copy an empty legislation to a single-legislation folder. We have to move the empty legislation
# to the legislation of the destination folder before the copy
LEGDEST = TABLE2
If LEGDEST="" & [F:ADS2]NBLEG=1
 LEGDEST = [F:ADS2]DOSLEG(0)
Endif

Call DEBTRANS From GLOCK
Gosub TR_COP

Close Local File [TPY1], [TPY2], [AXX1], [AXX2]
If clalev([F:TFC2])>0 : Close Local File [TFC2] : Endif
If clalev([F:TFC1])>0 : Close Local File [TFC1] : Endif
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [TPY2]
 Delete [TPY2] Where PAYTYP=TABLE & LEG=LEGDEST
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABPAYTYP" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("TPY2","") From GLOCK : Goto AB_TR_COP
 Endif
 If clalev([TFC2])>0
  Delete [TFC2] Where MODULE=9 & CODPAR=TABLE
  If fstat=1
   GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABFILCASH" : Goto ROLL_TR_COP
  Elsif fstat>5
   GOK = 0 : Call RSTA("TFC2","") From GLOCK : Goto AB_TR_COP
  Endif
 Endif
 For [TPY1] Where PAYTYP=TABLE & LEG=TABLE2
  [F:TPY2] = [F:TPY1]
  [F:TPY2]LEG = LEGDEST
  Call COPTEXTRALEG("TABPAYTYP","DESTRA",TABLE,TABLE2,LEGDEST) From CPTDIV
  Call COPTEXTRALEG("TABPAYTYP","SHOTRA",TABLE,TABLE2,LEGDEST) From CPTDIV
  If dim([F:TPY2]UPDUSR)>0 : [F:TPY2]UPDUSR = GUSER : Endif
  If dim([F:TPY2]UPDDAT)>0 : [F:TPY2]UPDDAT = date$ : Endif
  Write [TPY2]
  If fstat
   GOK = 0 : Call FSTA("TPY2") From GLOCK : Break
  Endif
 Next
 If clalev([TFC1])>0 & clalev([TFC2])>0
  For [TFC1] Where MODULE=9 & CODPAR=TABLE
   [F:TFC2] = [F:TFC1]
   If dim([F:TFC2]UPDUSR)>0 : [F:TFC2]UPDUSR = GUSER : Endif
   If dim([F:TFC2]UPDDAT)>0 : [F:TFC2]UPDDAT = date$ : Endif
   Write [TFC2]
   If fstat
    GOK = 0 : Call FSTA("TFC2") From GLOCK : Break
   Endif
  Next
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

# SAM 81743: Show Balance control field if PROBALCTL parameter is active for current legislation
$CHK_PROBALCTL
Local Char P_PROBALCTL(1) : P_PROBALCTL = ""
Call PARAM([M:TPY0]LEG,"PROBALCTL",P_PROBALCTL) From ADOVAL
If P_PROBALCTL = "2"
  Chgfmt [M:TPY2]LOTPROBALCTL With "LA:1X"
  Affzo  [M:TPY2]LOTPROBALCTL
Endif
Call SETPROBALVAL([M:TPY2]LOTPROBALCTL)
Return

Subprog CHANGERATINV (CHECKVALUE)
#Issue 31726 – 2017-04-03  by MADOR - As a treasury administrator I want to enable
#and disable the fields regarding currency rates
Variable Integer CHECKVALUE

If CHECKVALUE = 2
    Grizo [M:TPY1]RATINV
    [M:TPY1]RATINV = 1
Else
    Actzo[M:TPY1]RATINV
    [M:TPY2]CURRATOBL = 1
Endif
Affzo [M:TPY1]RATINV
Affzo [M:TPY2]CURRATOBL
#Issue end
End

Subprog CHANGEDACCURRAT (CHECKVALUE)
#Issue 31726 – 2017-04-03  by MADOR - As a treasury administrator I want to enable
#and disable the fields regarding currency rates
Variable Integer CHECKVALUE

If CHECKVALUE = 2
    Grizo [M:TPY2]DACCURRAT
    Grizo [M:TPY2]CURRATOBL
    [M:TPY2]DACCURRAT = 1
    [M:TPY2]CURRATOBL = 1
Else
    Actzo [M:TPY2]DACCURRAT
    Actzo [M:TPY2]CURRATOBL
Endif
Affzo [M:TPY2]DACCURRAT
Affzo [M:TPY2]CURRATOBL
#Issue end
End


#X3-42495 DATEV Compliancy
Subprog CHECK_DATEV_COMP(OK)
  Variable Integer OK
   If [M:TPY0]LEG = "GER" or [M:TPY0]LEG = "AUT"# or [M:TPY0]LEG = ""
     If [M:TPY3]ACETYP91 <> 1
      Call OUINON(mess(26,3653,1),OK) From GESECRAN
     Endif
   Endif
End
#X3-42495 DATEV Compliancy end


