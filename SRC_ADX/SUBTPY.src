######################################################################################
## SAM 81743: Control for the progressive balance control
Subprog AP_LOTPROBALCTL(VALEUR)
Variable Integer VALEUR
Call SETPROBALVAL(VALEUR)
End

# SAM 81743: enable/disable Balance control field after leaving entry batch field
Subprog AP_DACPYL(VALEUR)
Variable Integer VALEUR
Local Char P_PROBALCTL(1) : P_PROBALCTL = ""
Call PARAM([M:TPY0]LEG,"PROBALCTL",P_PROBALCTL) From ADOVAL
If P_PROBALCTL = "2"
  If VALEUR = 2
    Actzo [M:TPY2]LOTPROBALCTL
  Else
    Grizo [M:TPY2]LOTPROBALCTL
    [M:TPY2]LOTPROBALCTL = 1
  Endif
  Gosub CHK_PROBALCTL
  Affzo [M:TPY2]LOTPROBALCTL
Endif
End

######################################################################################

##################################################
## Actions of the data type TPY
##################################################

# Control
Subprog CONTTPY(COD,LEG,GFY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    GFY()

Local    Integer CAS

If GFONCTION = "GESTPY" | COD="" : End : Endif
If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

# CAS=1 => Record without Legislation (LEG = "")
# CAS=2 => Record with    Legislation (LEG <>"")

CAS = 1 : # Legislation is empty

If LEG<>""
 Read [TPY]TPY0=COD;LEG
 If fstat
  Read [TPY]TPY0=COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Filter [TPY] Where ENAFLG=2
 Read [TPY]TPY0(1)=COD
 Filter [TPY]
 If !fstat
  LEG = [F:TPY]LEG
  CAS = 2
 Else
  # To display the right message : either the recording is disable either it doesn't exist
  Read [TPY]TPY0(1)=COD
 Endif
Endif

If !fstat & [F:TPY]ENAFLG<>2
 # Transactions de règlements : xxx Fiche inactive
 Gosub TIT From WOTPY
 GMESSAGE = TIT-":"-[L]COD
 GMESSAGE += "\"+mess(2,126,1)
 mkstat = 2 : End
Elsif fstat
 If LEG<>""
  # LEG=FRA and the recording exists for the ITA legislation.
  # The right message isn't "Fiche inexistante" but "Fiche inexistante pour la législation courante"
  Filter [TPY] Where PAYTYP=[L]COD
  Look [TPY]TPY0 First
  Filter [TPY]
  If !fstat
   # Fiche inexistante pour la législation courante
   GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
   mkstat = 2 : End
  Endif
 Endif
 # Fiche inexistante
 GMESSAGE = [L]COD-":"-mess(23,100,1)
 mkstat = 2 : End
Endif

If [L]GFY<>"" & [F:TPY]GFY<>"" & [L]GFY<>[F:TPY]GFY
 Call COMPAT([L]GFY,[F:TPY]GFY,"") From CFYSUB
 If mkstat=2
  Gosub TIT From WOTPY
  GMESSAGE = TIT-":"-[L]COD-[F:TPY]LEG
  GMESSAGE += "\"+mess(23,127,1)-":"-[F:TPY]GFY
  End
 Endif
Endif

If CAS=2
 Call CONTROLE("TPY","",LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("TPY","","",COD,mkstat) From CONTOBJ
Endif
End

# 2018-04-05 DNE X3-81544
# Control for special characters
Subprog CONTTPYCHR( COD )
Variable Char COD()
    Local Integer I
    For I = 1 To len( COD )
        Case mid$( COD, I, 1 )
            When "/" :
                    GMESSAGE = mess(316,139,1) -  mid$( COD, I, 1 ) # 'Invalid characters found'
                    mkstat=2
                    Break
        Endcase
    Next
End


##################################################

## Tunnel Payment entry transactions
Subprog TUNTPY(COD,LEG)
Variable Char    COD()
Value    Char    LEG()
Local Integer O_GNBDERNIER, O_GNBDERCLE
Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONTPY)
 TOKILL = 1
Endif

If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif

# To update the Payment Transaction type code after the tunnel order
VCOD = COD

If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Elsif LEG="" : # If LEG="" then firstly we search a TPY record with LEG="" secondly a TPY record with LEG<>""
 Read [TPY]TPY0 = VCOD;LEG
 If fstat
  Read [TPY]TPY0(1)=VCOD
  If !fstat
   LEG = [F:TPY]LEG
  Endif
 Endif
Endif

Call LEC_TPY_LEG(LEG,VCOD) From CPTLEC
If !fstat
 LEG = [F:TPY]LEG
Else
 Raz VCOD,LEG
Endif

O_GNBDERNIER = GNBDERNIER
O_GNBDERCLE = GNBDERCLE
Raz GNBDERNIER, GNBDERCLE
Call OBJET("TPY",LEG,VCOD) From GOBJET
GNBDERNIER = O_GNBDERNIER
GNBDERCLE = O_GNBDERCLE
If VCOD<>"" : COD = VCOD : Endif
If TOKILL : Kill VCOD : Endif
End

# SAM 81743: checks if progressive balance control is active and sets the appropriate field values
Subprog SETPROBALVAL(VALEUR)
Value Integer VALEUR
Local Char P_PROBALCTL(1) : P_PROBALCTL = ""
Call PARAM([M:TPY0]LEG,"PROBALCTL",P_PROBALCTL) From ADOVAL
#Enable/Disable fields for balance control
If VALEUR = 2 and P_PROBALCTL = "2"
  #set forced values and disable fields
  [M:TPY1]BANCSH = 1
  Grizo [M:TPY1]BANCSH
  [M:TPY1]SNS = 3
  Grizo [M:TPY1]SNS
  [M:TPY2]DACBAN = 2
  Grizo [M:TPY2]DACBAN
  [M:TPY2]BANOBL = 2
  Grizo [M:TPY2]BANOBL
  [M:TPY3]STA3 = 1
  Grizo [M:TPY3]STA3
  [M:TPY3]STA8 = 1
  Grizo [M:TPY3]STA8
  [M:TPY3]STA9 = 2
Else
  #enable fields
  Actzo [M:TPY1]BANCSH
  Actzo [M:TPY1]SNS
  Actzo [M:TPY2]DACBAN
  Actzo [M:TPY2]BANOBL
  Actzo [M:TPY3]STA3
  Actzo [M:TPY3]STA8
Endif
#refresh all tabs
Affzo [M:TPY1]
Affzo [M:TPY2]
Affzo [M:TPY3]
End

