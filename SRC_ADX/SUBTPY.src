Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

#ISSUE X3-45508 by MANOW/MRDAB - 2017-07-03/2017-10-20
If func AFNC.ACTIV("REGBC")
  Call CHANGE_PAYENTTYP_STATE(VALEUR)
Endif
#ISSUE END

End


######################################################################################

Subprog CHANGE_PAYENTTYP_STATE(LEGISLATION)
#Issue 33454 – 2017-07-10  by MADOR - As as treasury manager I want to be able to define
# WHICH PAYMENTS WILL BE USED IN CASH/BANK REGISTERS and THE ONES To USE IN STANDARD GESPAY FUNCTION
Variable Char LEGISLATION()

If func AFNC.PARAM("BCREG", LEGISLATION) = "2"
    Chgfmt [M:TPY2]DACPAYTYP With "K:10X"
    If [M:TPY2]DACPAYTYP = 2 or [M:TPY2]DACPAYTYP = 3
        Gosub TICK_DACREGNUM
    Else
        Gosub UNTICK_DACREGNUM
    Endif
Else
    Effzo [M:TPY2]DACPAYTYP
    Gosub UNTICK_DACREGNUM
    Chgfmt [M:TPY2]DACPAYTYP With "-K:10X"
Endif
#Issue End
End

