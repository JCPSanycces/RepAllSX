Subprog C_FILREF71(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If clalev([F:EDP])=0 : Local File EDIPAR [EDP] : Endif
Filter [EDP] Where MES=VALEUR
Read[EDP]EDP0 First
If fstat
 GMESSAGE = mess(9,136,1) : # Paramétrage inexistant
 mkstat = 2 : End
Endif
If [M]NATPAY>1
 Filter [EDP] Where MES=VALEUR & NATPAY=[M]NATPAY
 Read[EDP]EDP0 First
 If fstat
  GMESSAGE = mess(36,115,1) : # Struture de fichier incorrect
  mkstat = 2 : End
 Endif
Endif
Raz [M]FILREF6 : Affzo [M]FILREF6
Raz [M]FILREF8 : Affzo [M]FILREF8
End

Subprog AP_FILREF71(VALEUR)
Variable Char    VALEUR()
If dim([M:TPY1]SWIPAYTYP) > 0 and find([M:TPY1]SWIPAYTYP,2,3) : End : Endif # Swiss Localization: do check only if not a DTA / EZAG payment
If [M]NATPAY=1 and VALEUR="" and [M]FILREF6=""
 GMESSAGE=mess(147,121,1) : mkstat=2 : End
Endif
End

Subprog C_FILREF8(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If [M]NATPAY>1
 Filter [TFB] Where COD=VALEUR and NATPAY=[M]NATPAY
 Read [TFB]TFB0 First
 Filter [TFB]
 If fstat
  GMESSAGE = mess(36,115,1) : # Struture de fichier incorrect
  mkstat = 2 : End
 Endif
Endif
Gosub CONT_FILREF
If mkstat=2 : End : Endif
End

Subprog AS_FILREF8(VALEUR)
Variable Char    VALEUR()
If [M]EPACDTTRF<>2 | [M]STA6=2 | [M]STA7=2 : mkstat = 1 : Endif
End

$S_FILREF71
Raz NBTEX
TIT(0) = mess(122,124,1) : # Sélection Fichier
If clalev([F:EDP])=0 : Local File EDIPAR [EDP] : Endif
If [M]NATPAY>1
 CRITERE  = "NATPAY=[M]NATPAY & GRP=0 & ORDNUM=1 "
Else
 CRITERE  = "GRP=0 & ORDNUM=1"
Endif
For [EDP]EDP0 Where evalue (CRITERE)
 If NBTEX+1>dim(TEX)-1 : Break : Endif
 If !find([F:EDP]MES,TEX(1..NBTEX))
  NBTEX +=1
  TEX(NBTEX) = [F:EDP]MES
  TEXTE(NBTEX) = format$("K:10X",[F:EDP]MES)-[F:EDP]DES
 Endif
Next
Return

$S_FILREF6
Local Char TEXTRA(250)
Raz NBTEX
TIT(0) = mess(122,124,1) : # Sélection Fichier
If clalev([F:TFB])=0 : Local File TABFILBAN [TFB] : Endif
If [M]NATPAY>1
 CRITERE  = "NATPAY=[M]NATPAY & RECTYP=1 & ORDNUM=0 & NUM=1 & (LEG=GCURLEG | LEG='')"
Else
 CRITERE  = "RECTYP=1 & ORDNUM=0 & NUM=1 & (LEG=GCURLEG | LEG='')"
Endif
For [TFB]TFB0 Where evalue (CRITERE)
 If NBTEX+1>dim(TEX)-1 : Break : Endif
 Call LECTEXTRA(TEXTRA, "TABFILBAN", "DESTRA", [F:TFB]COD, [F:TFB]BAN+"~"+[F:TFB]LEG) From ATEXTRA
# If !find([F:TFB]COD,TEX(1..NBTEX))
 If !find(format$("K:10X",[F:TFB]COD)-TEXTRA,TEXTE(1..NBTEX))
  NBTEX +=1
  TEX(NBTEX) = [F:TFB]COD
#  Call LECTEXTRA(TEXTRA, "TABFILBAN", "DESTRA", [F:TFB]COD, [F:TFB]BAN+"~"+[F:TFB]LEG) From ATEXTRA
  TEXTE(NBTEX) = format$("K:10X",[F:TFB]COD)-TEXTRA
 Endif
Next
Return


$S_FILREF8
Local Char TEXTRA(250)
Raz NBTEX
TIT(0) = mess(122,124,1) : # Sélection Fichier
If clalev([F:TFB])=0 : Local File TABFILBAN [TFB] : Endif
If [M]NATPAY>1
 CRITERE  = "NATPAY=[M]NATPAY & RECTYP=1 & ORDNUM=0 & NUM=1 & (LEG=GCURLEG | LEG='')"
Else
 CRITERE  = "RECTYP=1 & ORDNUM=0 & NUM=1 & (LEG=GCURLEG | LEG='')"
Endif
For [TFB]TFB0 Where evalue (CRITERE)
 If NBTEX+1>dim(TEX)-1 : Break : Endif
 Call LECTEXTRA(TEXTRA, "TABFILBAN", "DESTRA", [F:TFB]COD, [F:TFB]BAN+"~"+[F:TFB]LEG) From ATEXTRA
# If !find([F:TFB]COD,TEX(1..NBTEX))
 If !find(format$("K:10X",[F:TFB]COD)-TEXTRA,TEXTE(1..NBTEX))
  NBTEX +=1
  TEX(NBTEX) = [F:TFB]COD
#  Call LECTEXTRA(TEXTRA, "TABFILBAN", "DESTRA", [F:TFB]COD, [F:TFB]BAN+"~"+[F:TFB]LEG) From ATEXTRA
  TEXTE(NBTEX) = format$("K:10X",[F:TFB]COD)-TEXTRA
 Endif
Next
Return


$S_CODCAS
If !clalev([F:AST]) : Local File APLSTD [AST] : Endif
TIT = mess(12,123,1) :# Choix
NBTEX = 0

If func AFNC.ACTIV("SFRPT")
 Filter [AST] Where LANCHP=2686 & LAN=GLANGUE & LANNUM>0
Elsif func AFNC.ACTIV("T1000")
 Filter [AST] Where LANCHP=2674 & LAN=GLANGUE & LANNUM>0
Else
 Filter [AST] Where LANCHP=2671 & LAN=GLANGUE & LANNUM>0
Endif
For [AST]
 NBTEX += 1
 TEX(NBTEX)   = [F:AST]LANMES
 TEXTE(NBTEX) = [F:AST]LANMES
Next
Filter [AST]
Return

