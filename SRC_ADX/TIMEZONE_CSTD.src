# Class TIMEZONE


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
    When "INITIALIZE"    : Gosub INITIALIZE
    When "TO_LOCAL_TIME" : Gosub TO_LOCAL_TIME
    When "TO_UNIVERSAL_TIME" : Gosub TO_UNIVERSAL_TIME
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**----------------------------------------------------------------<br/>
#* INITIALIZE : Init the instance with time zone and code of daylight adjustment rule
#**<br/>----------------------------------------------------------------<br/>
#* @param TZICOD = Code of Time zone
#* @param TADCOD = Code of daylight adjustment rule (to overload)
#**<br/>----------------------------------------------------------------
#*!
$INITIALIZE
Local Integer LIN
    If [L]TZICOD<>""
        LIN = fmet this.ADDLINE("TZICOL", [V]CST_ALASTPOS)
        If LIN <> [V]CST_ANOTDEFINED
            ASTATUS = fmet this.TZICOL(LIN).AREAD([L]TZICOD)
            If [L]TADCOD<>"" & ASTATUS=[V]CST_AOK
                ASTATUS = fmet this.TZICOL(LIN).SET_TIMEADJUST([L]TADCOD)
            Endif
        Else
            ASTATUS = LIN
        Endif
    Endif
Return

#**----------------------------------------------------------------<br/>
#* TO_LOCAL_TIME : Convert a DateTime from UTC zone to Current Zone
#**<br/>----------------------------------------------------------------<br/>
#* @param UTCTIME = DateTime to convert (UTC)
#* @param LOCALTIME = DateTime converted (Local zone)
#* @return error code
#**<br/>----------------------------------------------------------------
#*!
$TO_LOCAL_TIME
Local Integer LDD, LMM, LYYYY
Local Integer LH, LM, LS
Local Integer UDD, UMM, UYYYY
Local Integer UH, UM, US

Local Decimal OFFSET

[L]LOCALTIME = [L]UTCTIME

If this.TZICOL<>null
    ASTATUS = fmet this.TZICOL(1).GET_OFFSET(UTCTIME,OFFSET)
    If [L]ASTATUS=[V]CST_AOK
        [L]LOCALTIME = func ADD_OFFSET(UTCTIME, OFFSET)
    Endif
Else
    ASTATUS = max(ASTATUS,fmet this.ASETERROR("TZICOL", "Time zone not defined", [V]CST_AWARNING))
Endif

Return

#**----------------------------------------------------------------<br/>
#* TO_UNIVERSAL_TIME : Convert a DateTime from Current Zone to UTC zone
#**<br/>----------------------------------------------------------------<br/>
#* @param LOCALTIME = DateTime to convert (Local zone)
#* @param UTCTIME = DateTime converted (UTC)
#* @return error code
#**<br/>----------------------------------------------------------------
#*!
$TO_UNIVERSAL_TIME
Local Integer LDD, LMM, LYYYY
Local Integer LH, LM, LS
Local Integer UDD, UMM, UYYYY
Local Integer UH, UM, US

Local Decimal OFFSET
Local Integer H, M
Local Char SENS(1)

[L]UTCTIME = [L]LOCALTIME

If this.TZICOL<>null
    ASTATUS = fmet this.TZICOL(1).GET_OFFSET(LOCALTIME,OFFSET)
    If [L]ASTATUS=[V]CST_AOK
        [L]UTCTIME = func ADD_OFFSET(UTCTIME, -OFFSET)  # Invert offset when calculating from Local to UTC
    Endif
Else
    ASTATUS = max(ASTATUS,fmet this.ASETERROR("TZICOL", "Time zone not defined", [V]CST_AWARNING))
Endif

Return


#**----------------------------------------------------------------<br/>
#* CONVERT_FROM_DATETIME : Convert a DateTime to 6 components
#**<br/>----------------------------------------------------------------<br/>
#* @param DATTIM = DateTime to convert
#* @param DD = Day number
#* @param MM = Month number
#* @param YYYY = Year number
#* @param H = Hour
#* @param M = Minutes
#* @param S = seconds
#* @return error code
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_FROM_DATETIME(DATTIM, DD, MM, YYYY, H, M, S)
Value Datetime DATTIM
Variable Integer DD, MM, YYYY
Variable Integer H, M, S

Local Char STR_DATTIM(20)
STR_DATTIM = num$(DATTIM)

YYYY = val(left$(STR_DATTIM,4))
MM   = val(mid$(STR_DATTIM,6,2))
DD   = val(mid$(STR_DATTIM,9,2))
H    = val(mid$(STR_DATTIM,12,2))
M    = val(mid$(STR_DATTIM,15,2))
S    = val(mid$(STR_DATTIM,18,2))

End [V]CST_AOK

#**----------------------------------------------------------------<br/>
#* CONVERT_TO_DATETIME : Convert 6 components to a DateTime
#**<br/>----------------------------------------------------------------<br/>
#* @param DD = Day number
#* @param MM = Month number
#* @param YYYY = Year number
#* @param H = Hour
#* @param M = Minutes
#* @param S = seconds
#* @param DATTIM = DateTime converted
#* @return error code
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_TO_DATETIME(DD, MM, YYYY, H, M, S, DATTIM)
Value Integer DD, MM, YYYY
Value Integer H, M, S
Variable Datetime DATTIM

DATTIM = gdatetime$(num$(YYYY)+"-"+format$("N0:2",MM)+"-"+format$("N0:2",DD)+"T"+format$("N0:2",H)+":"+format$("N0:2",M)+":"+format$("N0:2",S)+"Z")

End [V]CST_AOK

Funprog ADD_OFFSET(DT,OFFSET)
Value Datetime DT
Value Decimal OFFSET

Local Integer H, M
Local Char SENS(1)
Local Datetime DATTIM

H=fix(abs(OFFSET))
M=fix( (abs(OFFSET)-fix(abs(OFFSET))) * 60)
If OFFSET<0
    SENS="-"
Else
    SENS="+"
Endif
[L]DATTIM = func ADD_TIME(DT, SENS, H, M)

End DATTIM

#**
#* Add a time to a datetime
#*
#* @param DT : Origin datetime
#* @param SENS : if "-" then substract, otherwise add
#* @param DELTAH : number of hours to add/substract (must be less than 24)
#* @param DELTAM : number of minutes to add/substract (must be less than 60)
#*!
Funprog ADD_TIME(DT,SENS,DELTAH,DELTAM)
Value Datetime DT
Value Char    SENS
Value Integer DELTAH
Value Integer DELTAM

Local Integer DELTAD
Local Integer DD, MM, YYYY
Local Integer H, M, S
Local Date DAT
Local Datetime DATTIM(20)

RET = func CONVERT_FROM_DATETIME(DT, DD, MM, YYYY, H, M, S)

DAT = gdat$(DD, MM, YYYY)

Case SENS
    When "-"
        If DELTAM>M
            DELTAH +=1
            M = 60-(DELTAM-M)
        Else
            M -= DELTAM
        Endif


        If DELTAH>H
            DELTAD -=1
            H = 24-(DELTAH-H)
        Else
            H -= DELTAH
        Endif
    When Default
        If DELTAM>59-M
            DELTAH +=1
            M = DELTAM-(60-M)
        Else
            M += DELTAM
        Endif

        If DELTAH>23-H
            DELTAD +=1
            H = DELTAH-(24-H)
        Else
            H += DELTAH
        Endif

Endcase

DAT += DELTAD

DD = day(DAT)
MM = month(DAT)
YYYY = year(DAT)
RET = func CONVERT_TO_DATETIME(DD, MM, YYYY, H, M, S, DATTIM)
End DATTIM

#**
#* Return local time corresponding to time zone + DST
#*
#* @param TZICOD = time zone code
#* @param UTC_DT = time to convert (UTC)
#* @return time corresponding to the time zone or "0000-00-00T00:00:00Z" if an error occured
#*!
Funprog TO_LOCAL(TZICOD,UTC_DT)
Value Char TZICOD
Value Datetime UTC_DT

Local Integer RET
Local Datetime LOCAL_DT
Local Instance TIMEZONE Using C_TIMEZONE

Raz LOCAL_DT

TIMEZONE = NewInstance C_TIMEZONE AllocGroup TIMEZONE
RET = fmet TIMEZONE.AINIT()
If RET=[V]CST_AOK
    RET = fmet TIMEZONE.INITIALIZE([L]TZICOD,"")
    If RET=[V]CST_AOK
        RET = fmet TIMEZONE.TO_LOCAL_TIME(UTC_DT, LOCAL_DT)
    Endif
Endif

FreeGroup TIMEZONE

End LOCAL_DT

#**
#* Return UTC time corresponding to time zone + DST
#*
#* @param TZICOD = time zone code
#* @param LOCAL_DT = time to convert (local)
#* @return time corresponding to UTC or "0000-00-00T00:00:00Z" if an error occured
#*!
Funprog TO_UTC(TZICOD,LOCAL_DT)
Value Char TZICOD
Value Datetime LOCAL_DT

Local Integer RET
Local Datetime UTC_DT
Local Instance TIMEZONE Using C_TIMEZONE

Raz UTC_DT

TIMEZONE = NewInstance C_TIMEZONE AllocGroup TIMEZONE
RET = fmet TIMEZONE.AINIT()
If RET=[V]CST_AOK
    RET = fmet TIMEZONE.INITIALIZE([L]TZICOD,"")
    If RET=[V]CST_AOK
        RET = fmet TIMEZONE.TO_UNIVERSAL_TIME(LOCAL_DT, UTC_DT)
    Endif
Endif

FreeGroup TIMEZONE

End UTC_DT

#**
#* Return Offset of time zone
#*
#* @param TZICOD = time zone code
#* @param dattim = local date when calculate offset
#* @return Offset
#*!
Funprog GET_OFFSET(TZICOD, DATTIM)
Value Char TZICOD
Value Datetime DATTIM

Local Integer RET
Local Decimal OFFSET
Local Instance TIMEZONE Using C_TIMEZONE

TIMEZONE = NewInstance C_TIMEZONE AllocGroup TIMEZONE
RET = fmet TIMEZONE.AINIT()
If RET=[V]CST_AOK
    RET = fmet TIMEZONE.INITIALIZE([L]TZICOD,"")
    If RET=[V]CST_AOK
        RET = fmet TIMEZONE.TZICOL(1).GET_OFFSET(DATTIM,OFFSET)
    Endif
Endif

FreeGroup TIMEZONE

End OFFSET

