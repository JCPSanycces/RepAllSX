#<AdxTL>@(#)6.0.0.0 $Revision$
########################################################################
#             GENERATION DU FICHIER MAGNETIQUE DES QUITTANCES          #
#                                                                      #
# -                                                                    #
# -------------------------------------------------------------------- #
#                                                                      #
########################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","GENFIC","FGENFIC",3,"") From GTRAITE
End


$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "TERMINE"    : Gosub FIN
Endcase
Return

$INIT
Local Integer OK, NB
Local Char    DIR_FICBAN(GDIMFIC)
Local Char    MACHIN(GDIMFIC)                      : # Machine
Local Char    IRS(2)                               : # Séparateur
Local Char    OS(20)
If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
Return

$INIT_DIA
Gosub TIT
Call SETPARAM(DIR_FICBAN,MACHIN,IRS,OS,OK) From PARFICBAN
If OK
 If MACHIN<>""
  [M:DIA]FILNAM = MACHIN+"@"
 Endif
 [M:DIA]FILNAM += DIR_FICBAN
 If OS="unix"
  [M:DIA]FILNAM += "/"+GDIRBQE
 Else
  [M:DIA]FILNAM += "\"+GDIRBQE
 Endif
Else
 [M:DIA]FILNAM = filpath(GDIRBQE,"","")
Endif
Return

$TIT
TIT = mess(93,121,1)    # Génération de fichier
Return

$CONTROLE
TMP = 1  :# Pour afficher des tempon/tempoff
Return

$FIN
If !GSERVEUR & [M:DIA]TRACE=2
 TRA = 1
Else
 TRA = 0
Endif
Return

####################################################
$EXEC
If GSERVEUR
 ### batch
 [M:DIA]TRACE = 2
Endif

Gosub TIT
If !GSERVEUR & [M]TRACE=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
If [M:DIA]TRACE=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

#### Génération du fichier
Call ENREG([M:DIA]BPRFCT,[M:DIA]FCTVCR)

If !GSERVEUR & [M:DIA]TRACE=2
 Call FERME_TRACE From LECFIC
Endif

Return


####################################################
Subprog ENREG(FACTOR,NUMQUIT)
Value Char  FACTOR, NUMQUIT

Local Char  NOMFIC(GDIMFIC) , NOM(20) , EXT(3) , LIGNE(250), LEGCUR(GLONADI) , VLEG(GLONADI)
Local Char  SAVIFS(5) ,  SAVIRS(5) , CODE(10)
Local Integer I , TYPENR , LONG , AVR , DECIM , NBFAC , NBAVR
Local Decimal TOTFAC , TOTAVR , TOTAL

Local Char    DIR_FICBAN(GDIMFIC)
Local Char    MACHIN(GDIMFIC)                      : # Machine
Local Char    IRS(2)                               : # Séparateur
Local Char    OS(20)
Local Integer OK, CONDOK
Local Char    SAVDIRBQE(10)

If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:FCT])=0 : Local File FACTOR     [FCT] : Endif
If clalev([F:TFB])=0 : Local File TABFILBAN  [TFB] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev([F:BID])=0 : Local File BID        [BID] : Endif

# Nom du fichier à générer: préfixe + no quittance
Read [FCT]FCT0 = FACTOR
If fstat : End : Endif

EXT = [F:FCT]FILEXT    # Extension du fichier
CODE = [F:FCT]FILNAM   # Code du fichier bancaire paramétré

If CODE<>''
 Read [TFB]TFB0(1) = CODE
 # Préfixe du nom de fichier
 If !fstat : NOM = [F:TFB]FILREF : Else : NOM=left$(CODE,2) : Endif
Else
 NOM='QT'
Endif
NOM += NUMQUIT

SAVDIRBQE = GDIRBQE
GPOINT = "FICBAN" : Gosub ENTREE From EXEFNC

Call SETPARAM(DIR_FICBAN,MACHIN,IRS,OS,OK) From PARFICBAN
If OK
 If OS="unix"
  DIR_FICBAN += "/"+GDIRBQE
 Else
  DIR_FICBAN += "\"+GDIRBQE
 Endif
 If MACHIN<>""
  DIR_FICBAN = MACHIN+"@"+DIR_FICBAN
 Endif
Else
 DIR_FICBAN = filpath(GDIRBQE,"","",0)
 Call MACHINE(DIR_FICBAN,MACHIN,DIR_FICBAN) From ORDSYS
 Call GET_OS(MACHIN,OS) From ORDSYS
Endif

If OS="unix"
 DIR_FICBAN += "/"+NOM+"."+EXT
Else
 DIR_FICBAN += "\"+NOM+"."+EXT
Endif
NOMFIC = DIR_FICBAN

Openo NOMFIC,0
SAVIFS=adxifs
adxifs=""

#Declare variables
NBFAC=0 : NBAVR=0
TOTFAC=0 : TOTAVR=0 : TOTAL=0
[L]VLEG=""
#Take back the LEG from the company of the factor
Read [SIH]SIH4 = FACTOR;NUMQUIT
If !fstat
 Call LEC_CPY([F:SIH]CPY) From CPTLEC
 [L]VLEG = [F:CPY]LEG
Endif

# L'enregistrement Avoir est-il présent ?
Read [TFB]TFB0(3) = CODE;"";5
If !fstat : AVR=1 : Else : AVR=0 : Endif
# Ecriture des enregistrements du fichier
TYPENR=1 : Gosub ECRFIC    # Enreg Début de fichier
Filter [SIH] Where BPRFCT=FACTOR & FCTVCR=NUMQUIT & FCTVCRFLG=1
&  Order By Key CLE=BPRFCT;FCTVCR;FCTVCRFLG;BPR
For [SIH]CLE(4)

  Read [BPR]BPR0 = [F:SIH]BPR
  If !fstat
   Read [BPC]BPC0 = [F:SIH]BPR
   If !fstat
    Read [BPA]BPA0 = 1;[F:BPR]BPRNUM;[F:BPC]BPAADD
    If fstat : Raz [F:BPA] : Endif
   Endif
   Read [BID]BID0 = 1;[F:BPR]BPRNUM;[F:BPR]BIDNUM
   If fstat : Raz [F:BID] : Endif
  Else
   Raz [F:BPR], [F:BPA], [F:BID], [F:BPC]
  Endif
  TYPENR=4 : Gosub ECRFIC   # Enregistrement client
  For [SIH]CLE
   Case [F:SIH]INVTYP
    When 1 :    # Enregistrement Facture
     NBFAC += 1 : TOTFAC += [F:SIH]AMTATI : TOTAL += [F:SIH]AMTATI
     For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM & BPRFCT=FACTOR & FCTVCR=NUMQUIT
      TYPENR=2 : Gosub ECRFIC
     Next
    When 2 :    # Enregistrement Avoir (sinon facture)
     If AVR : TYPENR=5 : Else : TYPENR=2 : Endif
     NBAVR += 1  : TOTAVR += [F:SIH]AMTATI : TOTAL -= [F:SIH]AMTATI
     Gosub ECRFIC
   Endcase
  Next

Next
Filter [SIH]
TYPENR=3 : Gosub ECRFIC    # Fin de fichier
Openo
adxifs=SAVIFS
Call ECR_TRACE(mess(77,121,1)+":"-NUMQUIT+"\"+mess(104,121,1)+":"-"|"+NOMFIC+"|",0) From GESECRAN
#### Quittance XXX Fichier généré YYYY

GDIRBQE = SAVDIRBQE
End

$ECRFIC
GPOINT= "OPENFILE"  : Gosub ENTREE From EXEFNC

Read [TFB]TFB0(5) = CODE;"";TYPENR;0;VLEG
If fstat
 Read [TFB]TFB0(5) = CODE;"";TYPENR;0;""
 If fstat : Raz [F:TFB]
 Else
  [L]LEGCUR=""
 Endif
Else
 [L]LEGCUR=VLEG
Endif

For [TFB]TFB0(5) Where COD=CODE & RECTYP=TYPENR & LEG=[L]LEGCUR
 CONDOK=1
 If [F:TFB]FORCND<>""
  CONDOK = evalue([F:TFB]FORCND)
 Endif
 If CONDOK
  For [TFB]TFB0
   LIGNE = ""
   If [F:TFB]FRM<>""
    Onerrgo ERREUR
    ER = 0
    Case [F:TFB]FLDTYP
     When 3,4,5,6,7 : # Dates pour l'avoir sous forme AAAAMMJJ
      LIGNE = evalue([F:TFB]FRM)
      If LIGNE="000000" : LIGNE="00000000" : Endif
     When Default
      LIGNE = num$(evalue([F:TFB]FRM))
    Endcase
    Onerrgo
   Endif
   LONG = [F:TFB]LNG
   Case [F:TFB]FLDTYP
    When 1 : # Chaîne cadrée à gauche
     LIGNE = toupper(ctrans(left$(LIGNE+space$(LONG),LONG)))
    When 2 : # Numérique cadré à gauche
     LIGNE = right$(string$(LONG,"0")+LIGNE,len(LIGNE)+1)
    When 3 : # Date JJMMAA
     LIGNE = mid$(LIGNE,7,2)+mid$(LIGNE,5,2)+mid$(LIGNE,3,2)
    When 4 : # Date AAMMJJ
     LIGNE = right$(LIGNE,3)
    When 5 : # Année
     Case LONG
      When 1 : LIGNE = mid$(LIGNE,4,1)
      When 2 : LIGNE = mid$(LIGNE,3,2)
      When 4 : LIGNE = mid$(LIGNE,1,4)
     Endcase
    When 6 : # Mois
     LIGNE = mid$(LIGNE,5,2)
    When 7 : # Jour
     LIGNE = mid$(LIGNE,7,2)
    When 8 : # Séquence spéciale (binaire)
    When 9 : # Montant centimes
     Call LECTURE("TCU",[F:SIH]CUR,"") From CONTOBJ
     DECIM = 10^[F:TCU]DECNBR
     LIGNE = num$(arr(DECIM*val(LIGNE),1))
     LIGNE = right$(string$(LONG,"0")+LIGNE,len(LIGNE)+1)
   Endcase
   LIGNE = left$(LIGNE+space$(LONG),LONG)
   Wrseq LIGNE;
  Next
 Endif   :# CONDOK
Next
Return

$ERREUR
Resume


#######################################
## Etiquettes du masque GENFIC
########################################

Subprog AM_BPRFCT(VALEUR)
Variable Char    VALEUR()
Effzo [M]FCTVCR
End

Subprog AS_FCTVCR(VALEUR)
Variable Char    VALEUR()
Local Char CRIT(150)
If VALEUR = ""
 CRIT = "BPRFCT='"+[M]BPRFCT+"' & FCTVCR<>'' & FCTVCRFLG=1"
 If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  CRIT -= "& find(FCY, GUSRFCY(1..GNBAUZ))"
 Endif
 # On propose par défaut la quittance comptabilisée la moins récente
 Filter [SIH] Where evalue(CRIT) Order By Key CLE = FCTVCR
 Read [SIH]CLE First
 If !fstat : VALEUR = [F:SIH]FCTVCR : Endif
 Filter [F:SIH]
Endif
End

Subprog C_FCTVCR(VALEUR)
Variable Char    VALEUR()
Local Integer CPT, NB
Raz CPT, NB
If VALEUR <> ""
 For [F:SIH] Where BPRFCT=[M]BPRFCT & FCTVCR=VALEUR
   NB+=1
   If (GUSRFCY(1)<>"\" & !find([F:SIH]FCY, GUSRFCY(1..GNBAUZ)))
     GMESSAGE = [F:SIH]FCY-":"-mess(2,104,1)  : # Vous n'avez pas les droits pour ce site
     mkstat = 2 : Break
   Endif
   If [F:SIH]FCTVCRFLG=0 : CPT=1 : Break : Endif
 Next
 If !NB : GMESSAGE = mess(79,121,1) : mkstat=2     # Quittance inexistante
 Elsif CPT : GMESSAGE = mess(86,121,1) : mkstat=2  # Quittance non comptabilisée
 Endif
Endif
End

