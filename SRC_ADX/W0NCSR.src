#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSR 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone REJECTCOD
mkstat = 0
zoncou = "REJECTCOD"
indice = 0
If varinit([M]REJECTCOD,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]REJECTCOD,"808","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]REJECTCOD,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "REJECTCOD" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]REJECTCOD,"808","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "REJECTCOD" : GZNUM = 52263 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]REJECTCOD,"808",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "REJECTCOD" : GZNUM = 52263 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_REJECTCOD([M]REJECTCOD) From SUBNCSR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "REJECTCOD" : GZNUM = 52263 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone REJDESC
mkstat = 0
zoncou = "REJDESC"
indice = 0
If varmode([M]REJDESC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "REJDESC" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "NCSR"
Return

