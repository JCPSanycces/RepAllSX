        WGRCPTRSNUM = GRCPTRSNUM
Endif
#If dim(GSMARPER) >=0                # hcb v6per
#        Local Decimal WGSMARPER     # hcb v6per
#        WGSMARPER = GSMARPER        # hcb v6per
#Endif                               # hcb v6per
If dim(GSTODIS) >=0
        Local Libelle WGSTODIS
        WGSTODIS = GSTODIS
Endif

#--------------------------------- AGLOBGPA -------#
If dim(GPLNFLT) >=0               : # filtre gestionnaire (planificateur)
        Local Libelle WGPLNFLT
        WGPLNFLT = GPLNFLT
Endif
If dim(GMTSNUM) >=0               : # numéro transaction suivi/OF
        Local Char WGMTSNUM
        WGMTSNUM = GMTSNUM
Endif
If dim(GMTKMTSNUM) >=0            : # numéro transaction suivi utilisée en réception de SST
        Local Char WGMTKMTSNUM
        WGMTKMTSNUM = GMTKMTSNUM
Endif

Return




