#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
#   Statistiques sur escalades                                      Module CRM          8 janvier 2004
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When "RAF"          : Gosub REFRESH
    When Default
  Endcase
Return

##########################################################################################################
$REFRESH
  Gosub LOADECE2
Return

##########################################################################################################
$OUVRE
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev([F:ECE]) : Local File ESCSRE [ECE] : Endif
  #Initialisation de la navigation désordonnées
  NAVIG = "FUNECE2"
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  #Menu Rafraichissement
  ETABOU(GRAFF) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  #Définition de la période d'analyse
  Gosub SETPERIOD
  Affzo [M:ECE2]1-99
  #Chargement des tableaux
  Gosub LOADECE2
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Raz [M:ECE2]
  Raz [M:ECE3]
  Raz [M:ECE4]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
  FIN = 0
  Gosub LOADECE2
Return

##########################################################################################################
# Sous-programmes
#########################################################

##########################################################################################################
$SETPERIOD
Local Integer ISREFOUND

  ISREFOUND = 0
  Case GESCTYPDAT
    When 1
      Gosub SETYEARDATE
    When 2
      Filter [SRE] Where [F:SRE]SRENUM <> ""
      For [SRE]SRE1
        If [F:SRE]CREDAT <> [00/00/00] Then
          [M:ECE2]ESCSTRDAT = [F:SRE]CREDAT
          ISREFOUND = 1
          Break
        Endif
      Next
      Filter [SRE]
      If ISREFOUND = 0 Then
        Gosub SETYEARDATE
      Endif
    When 3
      If GESCSETDDA = [00/00/00] Then
        Gosub SETYEARDATE
      Else
        [M:ECE2]ESCSTRDAT = GESCSETDDA
      Endif
    When 4
      If GESCSETNDA = 0 Then
        Gosub SETYEARDATE
      Else
        [M:ECE2]ESCSTRDAT = date$ - GESCSETNDA
      Endif
    When Default
      Gosub SETYEARDATE
  Endcase
  [M:ECE2]ESCENDDAT = date$
Return

##########################################################################################################
$SETYEARDATE
  [M:ECE2]ESCSTRDAT = gdat$(1, 1, year(date$))
Return

##########################################################################################################
$LOADECE2
  If [M:ECE2]ESCSTRDAT = [00/00/00] Then
    #La période d'analyse n'est pas précisée.
    GMESSAGE = mess(961,182,1)
    GERR = 2
    Return
  Endif
  If [M:ECE2]ESCENDDAT = [00/00/00] Then
    #La période d'analyse n'est pas précisée.
    GMESSAGE = mess(961,182,1)
    GERR = 2
    Return
  Endif

Local Char SZPRECAT
Local Char SZPREDET
Local Integer IFIRSTREC
Local Integer ITER

  ITER = 0
  IFIRSTREC = 1
  SZPREDET = ""
  SZPRECAT = ""
  Call TEMPON("R") From GESECRAN
  Gosub RAZALL
  #---------------------------------------------------#
  # Escalades sur demandes
  Filter [ECE] Where [F:ECE]ESCDAT >= [M:ECE2]ESCSTRDAT and [F:ECE]ESCDAT <= [M:ECE2]ESCENDDAT and [F:ECE]ESCCAT = ""
  IFIRSTREC = 0
  For [ECE]
    [M:ECE3]SRECATCLA([M:ECE3]NBSRE) = mess(962,182,1) #Sans catégorie
    Case [F:ECE]ESCTYP
      When 2
        [M:ECE3]HIS([M:ECE3]NBSRE) += 1
      When 3
        [M:ECE3]IRT([M:ECE3]NBSRE) += 1
    Endcase
    [M:ECE3]EVR([M:ECE3]NBSRE) += 1
    IFIRSTREC += 1
  Next
  Filter [ECE]
  If IFIRSTREC Then
    [M:ECE3]NBSRE += 1
  Endif
  #---------------------------------------------------#
  #Demandes avec catégorie
  Filter [ECE] Where [F:ECE]ESCDAT >= [M:ECE2]ESCSTRDAT and [F:ECE]ESCDAT <= [M:ECE2]ESCENDDAT and [F:ECE]ESCCAT <> "" Order By [F:ECE]ESCCAT Asc
  IFIRSTREC = 1
  For [ECE]
    If IFIRSTREC Then
      SZPRECAT = [F:ECE]ESCCAT
      IFIRSTREC = 0
    Endif
    If [F:ECE]ESCCAT <> SZPRECAT Then
      [M:ECE3]NBSRE += 1
      SZPRECAT = [F:ECE]ESCCAT
    Endif
    If [M:ECE3]NBSRE >= dim([M:ECE3]SRECAT)-3 Then
      Break
    Endif
    [M:ECE3]SRECAT([M:ECE3]NBSRE) = [F:ECE]ESCCAT
    Call GET_LIB(453, [F:ECE]ESCCAT, [M:ECE3]SRECATCLA([M:ECE3]NBSRE)) From CRM_UTIL
    Case [F:ECE]ESCTYP
      When 2
        [M:ECE3]HIS([M:ECE3]NBSRE) += 1
      When 3
        [M:ECE3]IRT([M:ECE3]NBSRE) += 1
    Endcase
    [M:ECE3]EVR([M:ECE3]NBSRE) += 1
  Next
  Filter [ECE]
  If IFIRSTREC = 0 Then
    [M:ECE3]NBSRE += 1
  Endif
  #---------------------------------------------------#
  #Calcul des totaux
  If [M:ECE3]NBSRE > 1 Then
    If [M:ECE3]NBSRE < dim([M:ECE3]SRECAT)-2 Then
      Call TEXTE(8928, [M:ECE3]SRECATCLA([M:ECE3]NBSRE)) From OBJDIV      #Totaux
      For ITER = 0 To [M:ECE3]NBSRE-1
        [M:ECE3]HIS([M:ECE3]NBSRE) += [M:ECE3]HIS(ITER)
        [M:ECE3]IRT([M:ECE3]NBSRE) += [M:ECE3]IRT(ITER)
        [M:ECE3]EVR([M:ECE3]NBSRE) += [M:ECE3]EVR(ITER)
      Next
      [M:ECE3]NBSRE += 1
    Endif
  Endif
  #---------------------------------------------------#
  # Escalades sur collaborateurs
  Filter [ECE] Where [F:ECE]ESCDAT >= [M:ECE2]ESCSTRDAT and [F:ECE]ESCDAT <= [M:ECE2]ESCENDDAT and [F:ECE]SREASS = 2 and [F:ECE]SREDET <> "" and [F:ECE]ESCTYP = 3
  IFIRSTREC = 1
  For [ECE]ECE2
    If IFIRSTREC Then
      SZPREDET = [F:ECE]SREDET
      IFIRSTREC = 0
    Endif
    If [F:ECE]SREDET <> SZPREDET Then
      [M:ECE4]NBUSR += 1
      SZPREDET = [F:ECE]SREDET
    Endif
    If [M:ECE4]NBUSR >= dim([M:ECE4]USR)-3 Then
      Break
    Endif
    [M:ECE4]USR([M:ECE4]NBUSR) = [F:ECE]SREDET
    [M:ECE4]NBRUSRESC([M:ECE4]NBUSR) += 1
  Next
  Filter [ECE]
  If IFIRSTREC = 0 Then
    [M:ECE4]NBUSR += 1
  Endif
  If [M:ECE4]NBUSR Then
    Call LOADUSRCAT([M:ECE4]USR(0))
  Endif
  Call TEMPOFF From GESECRAN
  Affzo [M:ECE3]1-99
  Affzo [M:ECE4]5
Return

##########################################################################################################
$RAZALL
  Raz [M:ECE3]NBSRE
  Raz [M:ECE3]SRECATCLA
  Raz [M:ECE3]HIS
  Raz [M:ECE3]IRT
  Raz [M:ECE3]EVR
  Raz [M:ECE3]SRECAT
  Raz [M:ECE4]NBUSR
  Raz [M:ECE4]USR
  Raz [M:ECE4]NBRUSRESC
  Gosub RAZUSRCAT
Return

##########################################################################################################
$RAZUSRCAT
  Raz [M:ECE4]NBCAT
  Raz [M:ECE4]USRCATCLA
  Raz [M:ECE4]NBRCATESC
  Raz [M:ECE4]USRCAT
Return

##########################################################################################################
Subprog LOADUSRCAT(SZUSR)
Value Char SZUSR

Local Char SZPRECAT
Local Integer IFIRSTREC

  IFIRSTREC = 1
  SZPRECAT = ""
  Gosub RAZUSRCAT
  #Demandes sans catégorie
  Filter [ECE] Where [F:ECE]ESCDAT >= [M:ECE2]ESCSTRDAT and [F:ECE]ESCDAT <= [M:ECE2]ESCENDDAT and [F:ECE]ESCTYP = 3 and [F:ECE]SREASS = 2
&                and [F:ECE]SREDET = SZUSR and [F:ECE]ESCCAT = ""
  IFIRSTREC = 0
  For [ECE]ECE2
    [M:ECE4]USRCATCLA([M:ECE4]NBCAT) = mess(962,182,1) #Sans catégorie
    [M:ECE4]NBRCATESC([M:ECE4]NBCAT) += 1
    IFIRSTREC += 1
  Next
  Filter [ECE]
  If IFIRSTREC Then
    [M:ECE4]NBCAT += 1
  Endif
  #Demandes avec catégorie
  Filter [ECE] Where [F:ECE]ESCDAT >= [M:ECE2]ESCSTRDAT and [F:ECE]ESCDAT <= [M:ECE2]ESCENDDAT and [F:ECE]ESCTYP = 3 and [F:ECE]SREASS = 2
&                and [F:ECE]SREDET = SZUSR and [F:ECE]ESCCAT <> ""
&           Order By [F:ECE]ESCCAT Asc
  IFIRSTREC = 1
  For [ECE]
    If IFIRSTREC Then
      SZPRECAT = [F:ECE]ESCCAT
      IFIRSTREC = 0
    Endif
    If [F:ECE]ESCCAT <> SZPRECAT Then
      [M:ECE4]NBCAT += 1
      SZPRECAT = [F:ECE]ESCCAT
    Endif
    If [M:ECE4]NBCAT >= dim([M:ECE4]USRCAT)-3 Then
      Break
    Endif
    [M:ECE4]USRCAT([M:ECE4]NBCAT) = [F:ECE]ESCCAT
    Call GET_LIB(453, [F:ECE]ESCCAT, [M:ECE4]USRCATCLA([M:ECE4]NBCAT)) From CRM_UTIL
    [M:ECE4]NBRCATESC([M:ECE4]NBCAT) += 1
  Next
  Filter [ECE]
  If IFIRSTREC = 0 Then
    [M:ECE4]NBCAT += 1
  Endif
  Affzo [M:ECE4]10
End
