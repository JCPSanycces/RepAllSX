#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# ACTION - PJMPSNPEXT - Project snapshot Extracts
# Issue X3-68130 - 2018-01-09 by TEJAC
##########################################################################################################
$ACTION
  Case ACTION
    When "INIT_DIA"          :  Gosub INIT_DIA
    When "EXEC"              :  Gosub EXEC
  Endcase
Return

##########################################################################################################
$INIT_DIA
  NAVIG = GACTION
  GOK = 1
  # Init default values in the screen
  If PARAM(1) = AVOID.ACHAR Then
    [M:DIA]ALLCPY = [V]CST_AYES
    [M:DIA]ALLSNP = [V]CST_AYES
    [M:DIA]ALLPRJ = [V]CST_AYES
  Else
    [M:DIA]SNPCOD = PARAM(1)
    [M:DIA]ALLCPY = [V]CST_AYES
    [M:DIA]ALLSNP = [V]CST_ANO
    [M:DIA]SNPCODF = PARAM(1)
    [M:DIA]SNPCODT = PARAM(1)
    [M:DIA]ALLPRJ = [V]CST_AYES
  Endif
  [M:DIA]LOGFILE = [V]CST_AYES
  [M:DIA]LNCHPRJ = [V]CST_AYES
  [M:DIA]EXLCLSPRJ = [V]CST_AYES
  zonsui = "[M:DIA]LOGFILE"
Return

##########################################################################################################
$EXEC
Local Char CRITERE(250)(10)
Local Integer ICRITERE
Local Integer IRET

  #--------------------------------
  Local File PJMOPSNPH [PJSNPH]
  Local File PIMPL [PIM]
  #--------------------------------
  Link [PJSNPH] With [PIM]PIM4=[F:PJSNPH]OPPNUM
&                 As [NEW]
&               Where ([F:PIM]PIMTYP = 2 or [F:PIM]PIMTYP = 3)
&               Order By Key KEY1=[F:PIM]CPY;[F:PJSNPH]SNPCOD;[F:PJSNPH]OPPNUM
  #--------------------------------
  Raz CRITERE
  ICRITERE = 0
  #-------------------
  #Set Criteria Values
  #-------------------
  CRITERE(ICRITERE) -= "1=1"
  If [M:DIA]CPY <> AVOID.ACHAR Then
    CRITERE(ICRITERE) -= "and [F:PIM]CPY = [M:DIA]CPY"
  Endif
  If [M:DIA]SNPCODF <> AVOID.ACHAR Then
    CRITERE(ICRITERE) -= "and [F:PJSNPH]SNPCOD >= [M:DIA]SNPCODF"
  Endif
  If [M:DIA]SNPCODT <> AVOID.ACHAR Then
    CRITERE(ICRITERE) -= "and [F:PJSNPH]SNPCOD <= [M:DIA]SNPCODT"
  Endif
  If [M:DIA]OPPNUMF <> AVOID.ACHAR Then
    CRITERE(ICRITERE) -= "and [F:PJSNPH]OPPNUM >= [M:DIA]OPPNUMF"
  Endif
  If [M:DIA]OPPNUMT <> AVOID.ACHAR Then
    CRITERE(ICRITERE) -= "and [F:PJSNPH]OPPNUM <= [M:DIA]OPPNUMT"
  Endif
  If [M:DIA]LNCHPRJ = [V]CST_AYES Then
    CRITERE(ICRITERE) -= "and [F:PIM]OPPSTATE <> 1"
  Endif
  If [M:DIA]EXLCLSPRJ = [V]CST_AYES Then
    CRITERE(ICRITERE) -= "and [F:PIM]OPPSTATE <> 4"
  Endif
  #--------------------------------
  If [M:DIA]LOGFILE = [V]CST_AYES Then
    Call OUVRE_TRACE(mess(1026,2260,1)) From LECFIC
    Call PRTSCR("PJMPSNPEXT", "DIA", "", 0, 1) From ATRTX3
  Endif
  Call ECR_TRACE(string$(50,"-"), 0)
  #--------------------------------
  Filter [F:NEW] Where evalue(CRITERE)
  For [NEW]KEY1
    Call ECR_TRACE(func AFNC.MES1(mess(1027,2260,1), [F:PJSNPH]SNPCOD), 0)
    IRET = func PROCESS_PJSNPH_SNPCOD([F:PJSNPH]SNPCOD)
    If IRET = [V]CST_AERROR Then
      Break
    Endif
  Next
  #--------------------------------
  If rowcount([F:NEW]) = 0 Then
    Call ECR_TRACE(func AFNC.MES1(mess(1049,2260,1), AVOID.ACHAR), 0)
  Endif
  Filter [F:NEW]
  #--------------------------------
  Call ECR_TRACE(string$(50,"-"), 0)
  If !GSERVEUR Then
    If [M:DIA]LOGFILE = [V]CST_AYES Then
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Endif
  #--------------------------------
Return

##########################################################################################################
# Screen : PJMPSNPEXT [DIA]
##########################################################################################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Grizo [M:DIA]CPY
  Else
    Actzo [M:DIA]CPY
  Endif
End

##########################################################################################################
Subprog C_ALLSNP(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Grizo [M:DIA]SNPCODF
    Grizo [M:DIA]SNPCODT
  Else
    Actzo [M:DIA]SNPCODF
    Actzo [M:DIA]SNPCODT
  Endif
End

##########################################################################################################
Subprog AM_SNPCODF(VALEUR)
Variable Char    VALEUR()

  If [M:DIA]SNPCODF = AVOID.ACHAR or [M:DIA]SNPCODT < VALEUR Then
    [M:DIA]SNPCODT = VALEUR
    Affzo [M:DIA]SNPCODT
  Endif
End

##########################################################################################################
Subprog C_ALLPRJ(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Grizo [M:DIA]OPPNUMF
    Grizo [M:DIA]OPPNUMT
  Else
    Actzo [M:DIA]OPPNUMF
    Actzo [M:DIA]OPPNUMT
  Endif
  If [M:DIA]SNPCOD <> AVOID.ACHAR Then
    Grizo [M:DIA]ALLCPY
    Grizo [M:DIA]ALLSNP
    Grizo [M:DIA]SNPCODF
    Grizo [M:DIA]ALLPRJ
    Grizo [M:DIA]SNPCODF
    Grizo [M:DIA]SNPCODT
  Endif
End

##########################################################################################################
Subprog AM_OPPNUMF(VALEUR)
Variable Char    VALEUR()

  If [M:DIA]OPPNUMT = AVOID.ACHAR or [M:DIA]OPPNUMT < VALEUR Then
    [M:DIA]OPPNUMT = VALEUR
    Affzo [M:DIA]OPPNUMT
  Endif
End

##########################################################################################################
# Subroutines
##########################################################################################################
Funprog PROCESS_PJSNPH_SNPCOD(SSNPCOD)
Value Char SSNPCOD

Local Integer IARENDRE
Local Integer ISNPSEQ

  IARENDRE = [V]CST_AOK
  # --------------------
  Local File PJMOPSNPH [PJSNPH]
  Read [PJSNPH]PJSNPH0=SSNPCOD
  # --------------------
  If fstat Then
    IARENDRE = [V]CST_AERROR
    GMESSAGE = func AFNC.MES1(mess(1024,2260,1), SSNPCOD)
  Else
    Call ECR_TRACE(func AFNC.MES1(mess(1025,2260,1), SSNPCOD), 0)
    Trbegin [PJSNPH]
    IARENDRE = func PROCESS_PSNP(SSNPCOD)
    If IARENDRE = [V]CST_AOK Then
      Commit
    Else
      If GMESSAGE <> AVOID.ACHAR Then
        Gosub FORCE_LOGFILE
        Call ECR_TRACE(GMESSAGE, 1)
      Endif
      Rollback
    Endif
  Endif
End IARENDRE

##########################################################################################################
Funprog PROCESS_PSNP(SSNPCOD)
Value Char SSNPCOD

Local Integer IARENDRE
Local Integer ISNPSEQ
Local Char SKEYEXT(GLONVPJ)

  IARENDRE = [V]CST_AOK
  # --------------------
  Local File PJMOPSNPH [PJSNPH]
  Read [PJSNPH]PJSNPH0=SSNPCOD
  # --------------------
  ISNPSEQ = func GET_NEXT_SNPSEQ(SSNPCOD)
  SKEYEXT = func GET_KEYEXT(SSNPCOD, ISNPSEQ)
  # --------------------
  IARENDRE = func PROJECT_SNAPSHOT_EXTRACT(SSNPCOD, SKEYEXT)
  If IARENDRE = [V]CST_AOK Then
    IARENDRE = func SAVE_PJMOPSNPD(SSNPCOD, ISNPSEQ, SKEYEXT, [F:PJSNPH]OPPNUM)
  Endif
  # --------------------
End IARENDRE

##########################################################################################################
Funprog SAVE_PJMOPSNPD(SSNPCOD, ISNPSEQ, SKEYEXT, SOPPNUM)
Value Char SSNPCOD
Value Integer ISNPSEQ
Value Char SKEYEXT
Value Char SOPPNUM

Local Integer IARENDRE
Local Char WRKDESC(250)

  IARENDRE = [V]CST_AOK
  # --------------------
  Local File PJMOPSNPD [PJSNPD]
  # --------------------
  Raz [PJSNPD]
  # --------------------
  [F:PJSNPD]SNPCOD = SSNPCOD
  [F:PJSNPD]SNPSEQ = ISNPSEQ
  [F:PJSNPD]DSNPCREDAT = date$
  [F:PJSNPD]KEYEXT = SKEYEXT
  [F:PJSNPD]DEFBAS = func SET_DEFAULT(SOPPNUM)   # Issue X3-76853 - 2018-02-27 by TEJAC
  Write [PJSNPD]
  If fstat Then
    IARENDRE = [V]CST_AERROR
    Gosub FORCE_LOGFILE
    Call ECR_TRACE(mess(1021,2260,1), 1)
  Endif
  If IARENDRE = [V]CST_AOK Then
    WRKDESC = func AFNC.MES1(mess(1028,2260,1), format$(GFMDAT,[F:PJSNPD]DSNPCREDAT))
    Call MAJTEXTRA(WRKDESC, "PJMOPSNPD", "DDESAXX", [F:PJSNPH]SNPCOD, num$([F:PJSNPD]SNPSEQ)) From ATEXTRA
  Endif
End IARENDRE

##########################################################################################################
Funprog SET_DEFAULT(SOPPNUM)
Value Char SOPPNUM

Local Integer IRET

  # Issue X3-76853 - 2018-02-27 by TEJAC
  IRET = [V]CST_ANO
  #---------------------
  Local File PJMOPSNPH [PJSNPH]
  Local File PJMOPSNPD [PJSNPD]
  #---------------------
  Link [PJSNPD] With [F:PJSNPH]PJSNPH0=[F:PJSNPD]SNPCOD
&                 As [NEW]
&              Where [F:PJSNPH]OPPNUM = SOPPNUM and [F:PJSNPD]DEFBAS = [V]CST_AYES
  Read [NEW]First
  If fstat Then
    IRET = [V]CST_AYES
  Endif
End IRET

##########################################################################################################
Funprog PROJECT_SNAPSHOT_EXTRACT(SSNPCOD, SKEYEXT)
Value Char SSNPCOD
Value Char SKEYEXT

Local Integer IARENDRE
Local Char STABLST(GLONATB)(1..,1..2)
Local Integer NI

  IARENDRE = [V]CST_AOK
  # --------------------
  Local File PJMOPSNPH [PJSNPH]
  Read [PJSNPH]PJSNPH0=SSNPCOD
  # --------------------
  Call LOAD_TABLE(STABLST)
  For NI = 1 To maxtab(STABLST)
    If STABLST(NI,1) <> AVOID.ACHAR Then
      IARENDRE = func COPY_TABLE(STABLST(NI,1), STABLST(NI,2), SKEYEXT, [PJSNPH]OPPNUM)
      If IARENDRE = [V]CST_AERROR Then
        Break
      Endif
    Endif
  Next NI
End IARENDRE

##########################################################################################################
Funprog COPY_TABLE(SFROMTBL, STOTBL, SKEYEXT, SOPPNUM)
Value Char SFROMTBL
Value Char STOTBL
Value Char SKEYEXT
Value Char SOPPNUM

Local Integer IARENDRE

  IARENDRE = [V]CST_AOK
  # --------------------
  IARENDRE = func CHECK_TABLES_CONSISTENCY(SFROMTBL, STOTBL)
  If IARENDRE = [V]CST_AOK Then
    Local File =SFROMTBL [FRM]
    Local File =STOTBL   [TTO]
    # --------------------
    Filter [FRM] Where [F:FRM]OPPNUM = SOPPNUM
    For [FRM]
      [F:TTO] = [F:FRM]
      [F:TTO]SNPVCR = SKEYEXT
      # --------------------
      Write [TTO]
      If fstat Then
        IARENDRE = [V]CST_AERROR
        GOK = 0
        GMESSAGE = mess(399,2260,1)
        Break
      Endif
      # --------------------
      IARENDRE = func DUPLICAT_TEXTS(SFROMTBL, STOTBL, SKEYEXT, SOPPNUM)
      If IARENDRE = [V]CST_AERROR Then
        Break
      Endif
    Next
    Filter [FRM]
  Endif
End IARENDRE

##########################################################################################################
Funprog GET_NEXT_SNPSEQ(SSNPCOD)
Value Char SSNPCOD

Local Integer IARENDRE

  IARENDRE = 10
  # --------------------
  Local File PJMOPSNPD [PJSNPD]
  Filter [PJSNPD] Where [F:PJSNPD]SNPCOD = SSNPCOD Order By Key KEY0=SNPCOD;SNPSEQ Desc
  Read [PJSNPD]First
  If !fstat Then
    IARENDRE = [F:PJSNPD]SNPSEQ + 10
  Endif
  Filter [PJSNPD]
  # --------------------
End IARENDRE

##########################################################################################################
Funprog GET_KEYEXT(SSNPCOD, ISNPSEQ)
Value Char SSNPCOD
Value Integer ISNPSEQ

Local Char SARENDRE(GLONVPJ)

  SARENDRE = "PJ" + "~" + SSNPCOD + "~" + num$(ISNPSEQ)
End SARENDRE

##########################################################################################################
Funprog DELETE_SNP_TABLES(SKEYEXT)
Value Char SKEYEXT

Local Integer IARENDRE
Local Integer IADXLOG
Local Char STABLST(GLONATB)(1..,1..2)

  IARENDRE = [V]CST_AOK
  # --------------------
  IADXLOG = (adxlog = 1)
  If adxlog = [V]CST_AFALSE Then
    Trbegin [SNPJ]
  Endif
  # --------------------
  Call LOAD_TABLE(STABLST)
  For NI = 1 To maxtab(STABLST)
    If STABLST(NI,2) <> AVOID.ACHAR Then
      IARENDRE = func DELETE_TABLE(STABLST(NI,2), SKEYEXT)
      If IARENDRE = [V]CST_AERROR Then
        Break
      Endif
    Endif
  Next NI
  # --------------------
  If IADXLOG = [V]CST_AFALSE Then
    If IARENDRE = [V]CST_AOK Then
      Commit
    Else
      Rollback
    Endif
  Endif
  # --------------------
End IARENDRE

##########################################################################################################
Funprog DELETE_TABLE(SSNPTBL, SKEYEXT)
Value Char SSNPTBL
Value Char SKEYEXT

Local Integer IARENDRE

  IARENDRE = [V]CST_AOK
  Local File =SSNPTBL [SNPJ]
  # --------------------
  Delete [SNPJ] Where [F:SNPJ]SNPVCR = SKEYEXT
  If fstat Then
    IARENDRE = [V]CST_AERROR
    GOK = 0
    GMESSAGE = mess(1033,2260,1)
  Endif
  # --------------------
  If IARENDRE = [V]CST_AOK Then
    IARENDRE = func DELETE_TEXTS(SSNPTBL, SKEYEXT)
  Endif
  # --------------------
End IARENDRE

##########################################################################################################
Funprog CHECK_TABLES_CONSISTENCY(SFROMTBL, STOTBL)
Value Char SFROMTBL
Value Char STOTBL

Local Integer IARENDRE

  IARENDRE = [V]CST_AOK
  # --------------------
  Local File ATABZON [ATZF]  # FROM
  Local File ATABZON [ATZT]  # TO
  # --------------------
  Filter [ATZF] Where [F:ATZF]CODFIC = SFROMTBL
  For [ATZF]
    Read [ATZT]CODZONE=STOTBL;[F:ATZF]CODZONE
    If fstat Then
      IARENDRE = [V]CST_AERROR
      GOK = 0
      Gosub FORCE_LOGFILE
      Call ECR_TRACE(func AFNC.MES3(mess(1063,2260,1), SFROMTBL, STOTBL, [F:ATZF]CODZONE), 1)
    Endif
  Next
  Filter [ATZF]
End IARENDRE

##########################################################################################################
Subprog LOAD_TABLE(STABLST)
Variable Char STABLST()(1..,1..2)

Local Integer NI

  NI = 0
  NI += 1 : STABLST(NI,1) = "OPPOR"         : STABLST(NI,2) = "SNPOPPOR"
  NI += 1 : STABLST(NI,1) = "OPPORPJM"      : STABLST(NI,2) = "SNPOPPORPJM"
  NI += 1 : STABLST(NI,1) = "PJMAFF"        : STABLST(NI,2) = "SNPAFF"
  NI += 1 : STABLST(NI,1) = "PJMBUD"        : STABLST(NI,2) = "SNPBUD"
  NI += 1 : STABLST(NI,1) = "PJMBUDLIG"     : STABLST(NI,2) = "SNPBUDLIG"
  NI += 1 : STABLST(NI,1) = "PJMTSK"        : STABLST(NI,2) = "SNPTSK"
  NI += 1 : STABLST(NI,1) = "PJMTSKOPE"     : STABLST(NI,2) = "SNPTSKOPE"
  NI += 1 : STABLST(NI,1) = "PJMTSKLNK"     : STABLST(NI,2) = "SNPTSKLNK"
  NI += 1 : STABLST(NI,1) = "PJMTSKITM"     : STABLST(NI,2) = "SNPTSKITM"
  NI += 1 : STABLST(NI,1) = "PJMTSKOPELNK"  : STABLST(NI,2) = "SNPTSKOPELNK"
  NI += 1 : STABLST(NI,1) = "PJMOPEAFF"     : STABLST(NI,2) = "SNPOPEAFF"
  NI += 1 : STABLST(NI,1) = "PIMPL"         : STABLST(NI,2) = "SNPPIMPL"
End

##########################################################################################################
Funprog DUPLICAT_TEXTS(SFROMTBL, STOTBL, SKEYEXT, SOPPNUM)
Value Char SFROMTBL
Value Char STOTBL
Value Char SKEYEXT
Value Char SOPPNUM

Local Integer IARENDRE

  IARENDRE = [V]CST_AOK
  # --------------------
  Local File ATABZON [ATZ]
  Local File ATEXTRA [AXS]  # AXX Search
  Local File ATEXTRA [AXX]  # Used by DUPTEXTRA
  # --------------------
  Filter [ATZ] Where [F:ATZ]CODFIC = SFROMTBL and left$(CODTYP,2) = "AX"
  For [ATZ]
    Filter [AXS] Where [F:AXS]CODFIC = [F:ATZ]CODFIC and [F:AXS]ZONE = [F:ATZ]CODZONE and left$([F:AXS]IDENT1,len(SOPPNUM)) = SOPPNUM
    For [AXS]
      Call DUPTEXTRA([F:AXS]CODFIC, [F:AXS]ZONE, [F:AXS]IDENT1,                 [F:AXS]IDENT2,
&                    STOTBL,        [F:AXS]ZONE, SKEYEXT + "~" + [F:AXS]IDENT1, [F:AXS]IDENT2)
&          From ATEXTRA
    Next
    Filter [AXS]
  Next
  Filter [ATZ]
  # --------------------
End IARENDRE

##########################################################################################################
Funprog DELETE_TEXTS(STOTBL, SKEYEXT)
Value Char STOTBL
Value Char SKEYEXT

Local Integer IARENDRE

  IARENDRE = [V]CST_AOK
  # --------------------
  Local File ATABZON [ATZ]
  Local File ATEXTRA [AXX]
  # --------------------
  Filter [ATZ] Where [F:ATZ]CODFIC = STOTBL and left$(CODTYP,2) = "AX"
  For [ATZ]
    Delete [AXX] Where [F:AXX]CODFIC = [F:ATZ]CODFIC and [F:AXX]ZONE = [F:ATZ]CODZONE and left$([F:AXX]IDENT1,len(SKEYEXT+"~")) = SKEYEXT
  Next
  Filter [ATZ]
  # --------------------
End IARENDRE

##########################################################################################################
Subprog ECR_TRACE(TEX, ERR)
Value Char    TEX() : # Texte du message
Value Integer ERR

  If [M:DIA]LOGFILE = [V]CST_AYES Then
    Call ECR_TRACE(TEX, ERR) From GESECRAN
  Endif
End

##########################################################################################################
$FORCE_LOGFILE
  If [M:DIA]LOGFILE = [V]CST_ANO Then
    # If the log file is not checked : checked by script to have in the log file the project with its errors
    [M:DIA]LOGFILE = [V]CST_AYES
    Call OUVRE_TRACE(mess(1026,2260,1)) From LECFIC
    Call PRTSCR("PJMPSNPEXT", "DIA", "", 0, 1) From ATRTX3
    Call ECR_TRACE(func AFNC.MES1(mess(1025,2260,1), SSNPCOD), 0)
  Endif
Return

