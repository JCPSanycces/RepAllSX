#*********************************************************************
#
#           SYRCUSE SHIPMENT IMPORT PROCESS
#
#*********************************************************************
# Creation
# MAE   30.05.2016
#
#*********************************************************************
# Updates
#
# XXXXX DD.MM.YYYY FQ000000   : XXX
#
#*********************************************************************

$ACTION
  Case ACTION
    When "IMP_OUVRE"     : Gosub IMP_OUVRE
    When "AP_IMPORT"     : Gosub AP_IMPORT
    When "IMP_FERME"     : Gosub IMP_FERME
    When Default
  Endcase
Return

####################################################################
# At the beginning of import process
####################################################################
$IMP_OUVRE
  Local Integer RET
  Local Integer NBCREA, NBMODIF
  Local Integer WPOS
  Local Integer NBLIG, NBLIGSHIPT, NBLIGSHIPD, NBLIGSHD
  Local Char SAV_SHIPNUM(GLONVCR)

  If !clalev([F:POQ]) : Local File PORDERQ [POQ] : Endif
  If !clalev([F:SHD1]) : Local File SHIPMENTD [SHD1] : Endif
  If !clalev([F:SHH1]) : Local File SHIPMENT [SHH1] : Endif
  If !clalev([F:SHIPD1]) : Local File SHIPDOC [SHIPD1] : Endif
  If !clalev([F:SHIPT1]) : Local File SHIPTRACK [SHIPT1] : Endif

  Local Instance WSHIPMENT Using C_SHIPMENT

  # Set ANOWRITE to 1 to avoid creation/update by the Supervisor import process
  ANOWRITE = 1
Return

####################################################################
# After each line reading
####################################################################
$AP_IMPORT
# In the TEST mode ther's nothing to do
If ([M:IMP2]TEST=[V]CST_AYES) : Return : Endif

If WSHIPMENT<>null
  If IMPFIC="SHH"
    If WSHIPMENT.SHIPNUM<>AVOID.ACHAR & WSHIPMENT.SHIPNUM<>[F:SHH]SHIPNUM
      If GREP ="C"
        Gosub INSERTION
      Elsif GREP="M"
        Gosub MODIFICATION
      Else
        Call ECR_TRACE("GREP = ''",1) From GESECRAN
        Return
      Endif
     #To manage the case of the sequence number (WSHIPMENT & [F:SHH]SHIPNUM are empty)
     Elsif WSHIPMENT.SHIPNUM=AVOID.ACHAR
       If GREP ="C"
        Gosub INSERTION
       Endif
     Endif
  Endif
Endif

# To avoid the supervisor messages in the log
GOK = 0

If IMPFIC="SHH"
  WSHIPMENT=NewInstance C_SHIPMENT AllocGroup null
  [L]RET=fmet WSHIPMENT.AINIT()
  If [L]RET >= [V]CST_AERROR
    Call WRITE_ERRORS(WSHIPMENT)
    Return
  Endif
  # Must set GREP to have the right numbers of created and updated items in the log
  GREP="C"
Endif

# The SHIPMENT exist, passage in modification
If ([M:AOE1]OPTUPD=G_OUI) and ([F:SHH]SHIPNUM<>"") & IMPFIC="SHH"
  Read[SHH1]SHH0=[F:SHH]SHIPNUM
  If (fstat=[V]CST_AOK)
    [L]RET=fmet WSHIPMENT.AREAD([F:SHH]SHIPNUM)
    If [L]RET >= [V]CST_AERROR
      Call WRITE_ERRORS(WSHIPMENT)
      Return
    Else
      GREP="M"
    Endif
  Endif
Endif

If GREP="M"
  Gosub SET_PROPERTIES_UPDATE
Elsif GREP="C"
 Gosub SET_PROPERTIES_CREATE
Else
 Call ECR_TRACE("GREP = ''",1) From GESECRAN
 Return
Endif

If IMPFIC="SHH"
  NBLIG=AVOID.ADEC : NBLIGSHIPD = AVOID.ADEC : NBLIGSHIPT = AVOID.ADEC : NBLIGSHD = AVOID.ADEC
  Call ECR_TRACE(mess(143,141,1)-[F:SHH]SHIPNUM,0) From GESECRAN
Elsif IMPFIC="SHD"
  NBLIGSHD += 1
  Call ECR_TRACE(mess(143,141,1)-"SHD"-WSHIPMENT.SHIPNUM-mess(3,40,1)-num$(NBLIGSHD),0) From GESECRAN
Elsif IMPFIC = "SHIPD"
  NBLIGSHIPD += 1
  Call ECR_TRACE(mess(143,141,1)-"SHIPD"-WSHIPMENT.SHIPNUM-mess(3,40,1)-num$(NBLIGSHIPD),0) From GESECRAN
Elsif IMPFIC = "SHIPT"
  NBLIGSHIPT += 1
  Call ECR_TRACE(mess(143,141,1)-"SHIPT"-WSHIPMENT.SHIPNUM-mess(3,40,1)-num$(NBLIGSHIPT),0) From GESECRAN
Endif

Return

####################################################################
# At the end of import process
####################################################################
$IMP_FERME
# To import the last row of the file
If WSHIPMENT <> null
  If GREP="C"
    Gosub INSERTION
  Elsif  GREP="M"
    Gosub MODIFICATION
  Else
    Call ECR_TRACE("GREP = ''",1) From GESECRAN
    Return
  Endif
Endif

# Write the records number
If NBCREA <> AVOID.ADEC
  Call ECR_TRACE(num$(NBCREA) +" "+ mess(103,141,1),0) From GESECRAN
Endif

If NBMODIF <> AVOID.ADEC
  Call ECR_TRACE(num$(NBMODIF) +" "+ mess(104,141,1),0) From GESECRAN
Endif

Return

####################################################################
# Record insertion
####################################################################
$INSERTION
Trbegin [F:SHH]
# Insertion of the previous record
WSHIPMENT.SHIPTYP = 1       #shipment
[L]RET=fmet WSHIPMENT.AINSERT()

Call WRITE_ERRORS(WSHIPMENT)

If [L]RET>=[V]CST_AERROR
  # Must set GOK to zero in case of error. If not a success message is added to the log.
  GOK=0
  Rollback
Else
  NBCREA +=1
  Commit
Endif


FreeGroup WSHIPMENT
Return

####################################################################
# Record update
####################################################################
$MODIFICATION

Trbegin [F:SHH]
# Update of the previous record

[L]RET=fmet WSHIPMENT.AUPDATE()

Call WRITE_ERRORS(WSHIPMENT)

If [L]RET>=[V]CST_AERROR
  # Must set GOK to zero in case of error. If not a success message is added to the log.
  GOK=0
  Rollback
Else
  NBMODIF +=1
  Commit
Endif

FreeGroup WSHIPMENT
Return

####################################################################
# Assign value to the class property when creating
####################################################################
$SET_PROPERTIES_CREATE
Case IMPFIC
  When "SHH"    Gosub IMPFIC_SHH
  When "SHD"    Gosub IMPFIC_SHD
  When "SHIPD"  Gosub IMPFIC_SHIPD
  #When "SHIPT"  Gosub IMPFIC_SHIPT
Endcase
Return
####################################################################
$IMPFIC_SHH
  SetInstance WSHIPMENT With [F:SHH]
Return
####################################################################
$IMPFIC_SHD
WPOS=fmet WSHIPMENT.ADDLINE("SHD",[V]CST_ALASTPOS)
If WPOS=[V]CST_ANOTDEFINED
  # The insertion was not possible
  Call WRITE_ERROR_STACK_CLASSIC(WSHIPMENT, [V]CST_AERROR) From LCCLIB
  GOK=0
  Return
Endif
# Read the order and tranclass first to keep the imported quantity
Read [POQ] POQ0=[F:SHD]POHNUM;[F:SHD]POPLIN;[F:SHD]POQSEQ
If fstat
  Raz [F:POQ]
Else
  SetInstance WSHIPMENT.SHD(WPOS) With [F:POQ]
Endif
WSHIPMENT.SHD(WPOS).SHIPNUM       = [F:SHH]SHIPNUM
WSHIPMENT.SHD(WPOS).POHNUM        = [F:SHD]POHNUM
WSHIPMENT.SHD(WPOS).POPLIN        = [F:SHD]POPLIN
WSHIPMENT.SHD(WPOS).POQSEQ        = [F:SHD]POQSEQ
WSHIPMENT.SHD(WPOS).CTRNUM        = [F:SHD]CTRNUM
WSHIPMENT.SHD(WPOS).CTRLIN        = [F:SHD]CTRLIN
WSHIPMENT.SHD(WPOS).SHIQTY        = [F:SHD]SHIQTY
WSHIPMENT.SHD(WPOS).QTYWEU        = [F:SHD]QTYWEU
WSHIPMENT.SHD(WPOS).QTYVOU        = [F:SHD]QTYVOU
WSHIPMENT.SHD(WPOS).EXTRCPDAT     = [F:SHD]EXTRCPDAT
Return
####################################################################
$IMPFIC_SHIPD
Local Integer SAV_NUMLIN
WPOS=fmet WSHIPMENT.ADDLINE("SHIPD",[V]CST_ALASTPOS)
If WPOS=[V]CST_ANOTDEFINED
  # The insertion was not possible
  Call WRITE_ERROR_STACK_CLASSIC(WSHIPMENT, [V]CST_AERROR) From LCCLIB
  GOK=0
  Return
Endif
SAV_NUMLIN = WSHIPMENT.SHIPD(WPOS).SDLIN
SetInstance WSHIPMENT.SHIPD(WPOS) With [F:SHIPD]
WSHIPMENT.SHIPD(WPOS).SDLIN = SAV_NUMLIN
WSHIPMENT.SHIPD(WPOS).VCRNUM = [F:SHH]SHIPNUM
WSHIPMENT.SHIPD(WPOS).VCRTYP = 38
Return
####################################################################
#$IMPFIC_SHIPT
#Local Integer SAV_TRKSORT, SAV_NUMLIN
#
#WPOS=fmet WSHIPMENT.ADDLINE("SHIPT",[V]CST_ALASTPOS)
#If WPOS=[V]CST_ANOTDEFINED
#  # The insertion was not possible
#  Call WRITE_ERROR_STACK_CLASSIC(WSHIPMENT, [V]CST_AERROR) From LCCLIB
#  GOK=0
#  Return
#Endif
##Save the TRKSORT and STLIN
#SAV_TRKSORT = WSHIPMENT.SHIPT(WPOS).TRKSORT
#SAV_NUMLIN = WSHIPMENT.SHIPT(WPOS).STLIN
#SetInstance WSHIPMENT.SHIPT(WPOS) With [F:SHIPT]
##restore the TRKSORT and STLIN value
#WSHIPMENT.SHIPT(WPOS).TRKSORT = SAV_TRKSORT
#WSHIPMENT.SHIPT(WPOS).STLIN = SAV_NUMLIN
#WSHIPMENT.SHIPT(WPOS).VCRNUM = [F:SHH]SHIPNUM
#WSHIPMENT.SHIPT(WPOS).VCRTYP = 38
##erreurs dues au propagate de la classe
#If WSHIPMENT.SHIPT(WPOS).AERROR <> null & WSHIPMENT.SHIPT(WPOS).AERROR.STA>=[V]CST_AERROR
#  Call WRITE_ERROR_STACK_CLASSIC(WSHIPMENT.SHIPT(WPOS), [V]CST_AERROR) From LCCLIB
#  [L]RET=fmet WSHIPMENT.ADELLINE("SHIPT", WSHIPMENT.SHIPT(WPOS).AORDER)
#  If [L]RET <> CST_AOK
#     Call WRITE_ERROR_STACK_CLASSIC(WSHIPMENT.SHIPT(WPOS), [V]CST_AERROR) From LCCLIB
#  Endif
#  Return
#Endif
#Return
####################################################################
# Assign value to the class property from the F class
# according the imported fields list when updating
####################################################################
$SET_PROPERTIES_UPDATE
Local Integer N_I, IS_NULL, WIND
For N_I = 0 To [M:AOE2]NBRLIG-1
  If IMPFIC = "SHH"
    If (left$([M:AOE2]FLD(N_I),1)<>"*") &(left$([M:AOE2]FLD(N_I),1)<>"/")
      If (evalue("dim(WSHIPMENT."+[M:AOE2]FLD(N_I)+")>-1")) & (evalue("dim([F:SHH]"+[M:AOE2]FLD(N_I)+")>-1"))
        IS_NULL = 0
        Case evalue("type([F:SHH]"+[M:AOE2]FLD(N_I)+")")
        When 1, 2, 4, 5, 6, 7, 9
         If evalue("[F:SHH]"+[M:AOE2]FLD(N_I)) = 0
           IS_NULL = 1
         Endif
        When 3
          If evalue("[F:SHH]"+[M:AOE2]FLD(N_I)) = [0/0/0]
           IS_NULL = 1
          Endif
        When Default
          If evalue("[F:SHH]"+[M:AOE2]FLD(N_I)) = ""
            IS_NULL = 1
          Endif
        Endcase
        # Filling of the header
        If !IS_NULL
          Assign "WSHIPMENT."+[M:AOE2]FLD(N_I) With evalue("[F:SHH]"+[M:AOE2]FLD(N_I))

        Endif
      Endif
     Endif
  Elsif IMPFIC = "SHD"
    If (left$([M:AOE2]FLD(N_I),1)<>"*")&(left$([M:AOE2]FLD(N_I),1)<>"/")
      If (evalue("dim(WSHIPMENT.SHD(1)."+[M:AOE2]FLD(N_I)+")>-1"))&(evalue("dim([F:SHD]"+[M:AOE2]FLD(N_I)+")>-1"))
        IS_NULL = 0
        Case evalue("type([F:SHD]"+[M:AOE2]FLD(N_I)+")")
        When 1, 2, 4, 5, 6, 7, 9
          If evalue("[F:SHD]"+[M:AOE2]FLD(N_I)) = 0
            IS_NULL = 1
          Endif
        When 3
          If evalue("[F:SHD]"+[M:AOE2]FLD(N_I)) = [0/0/0]
            IS_NULL = 1
          Endif
        When Default
          If evalue("[F:SHD]"+[M:AOE2]FLD(N_I)) = ""
            IS_NULL = 1
          Endif
        Endcase

        # Filling of lines
        If !IS_NULL
          # Use of SHD1 file in order to not crush the one read on the import. SHD1 is only use to find AAUUID
          Filter [SHD1] Where SHIPNUM = [F:SHH]SHIPNUM & POHNUM=[F:SHD]POHNUM & POPLIN=[F:SHD]POPLIN & POQSEQ=[F:SHD]POQSEQ
          Read [SHD1] First
          WIND = find([F:SHD1]AUUID, WSHIPMENT.SHD(1..maxtab(WSHIPMENT.SHD)).AUUID)
          Raz[SHD1]
          # If the line exist, the class is update
          If WIND <> 0
            Assign "WSHIPMENT.SHD("+num$(WIND)+")."+[M:AOE2]FLD(N_I) With evalue("[F:SHD]"+[M:AOE2]FLD(N_I))
          # If the line don't exist, the line is create
          Else
            Gosub SET_PROPERTIES_CREATE
            Break
          Endif
        Endif
      Endif
     Endif
    Endif
  Next
Return

#------------------------------------#
#--- Write the errors                #
#------------------------------------#
Subprog WRITE_ERRORS(WSHIPMENT)
Variable Instance WSHIPMENT Using C_SHIPMENT

Local Integer I
Local Char WMESSAGE(250)

WMESSAGE=AVOID.ACHAR

# Lines errors
For I=1 To maxtab(WSHIPMENT.SHD)
  WMESSAGE=func LCCLIB.MAXMSG(WSHIPMENT.SHD(I))
  If WMESSAGE<>AVOID.ACHAR
    Call WRITE_ERROR_STACK_CLASSIC(WSHIPMENT.SHD(I), 0) From LCCLIB
  Endif
Next I

# Head errors
WMESSAGE=func LCCLIB.MAXMSG(WSHIPMENT)
If WMESSAGE<>AVOID.ACHAR
  Call WRITE_ERROR_STACK_CLASSIC(WSHIPMENT, 0) From LCCLIB
Endif

End

