#<AdxTL>@(#)5.0.0.0 $Revision$
#####################################################################################################
# UTIVEN14                                                                  Module VENTE            #
#                                                                             07/02/2012            #
# Concerne le bug 79420 :                                                                           #
# Création d'un devis à partir d'une affaire :                                                      #
#    Le flag signature APPFLG de la table SQUOTE n'était pas initialisé si pas de gestion des       #
#       signatures pour la société                                                                  #
#                                                                                                   #
# But de l'utilitaire :                                                                             #
#    Si le flag de signature APPFLG n'est pas initialisé pour la table SQUOTE                       #
#       l'initialiser à 4 (Pas de gestion des signatures)                                           #
#                                                                                                   #
#####################################################################################################



Call MAJ_UTIVEN14
End


Subprog MAJ_UTIVEN14
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIVEN14 - Sales Quote Process : Update SQUOTE") From SAIDOS
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIVEN14 - Sales Quote Process : Update SQUOTE") From LECFIC
  Call EXE_UTIVEN14(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIVEN14(DOSSIER)
Value Char    DOSSIER
#-----
Call ECR_TIME("UTIVEN14 : Start folder's process"-DOSSIER) From DOSSUB

#----- Chargement globale GMAXUPDTRS -----#
If dim([V]GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =DOSSIER+".ADOVAL" [ADW] 
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]

#----- Début du traitement -----#
Gosub TRT_SQH    : # Traitement des devis
#----- Fin du traitement -----#

$FIN_UTIVEN14
Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Call ECR_TIME("UTIVEN14 : End folder's process"-DOSSIER) From DOSSUB
End


#----------------------------------------------------------------#
#   Initialisation flag de signature dans les devis              #
# -------------------------------------------------------------- #
# Table SQUOTE   - Entête devis                                  #
#   APPFLG         Flag signature                                #
#----------------------------------------------------------------#
$TRT_SQH
If filinfo(filpath("FIL","SQUOTE","fde", DOSSIER),0) < 0 : Return : Endif
Call ECR_TIME("UTIVEN14 : Sales Quote Process : Update SQUOTE") From DOSSUB
Local File =DOSSIER+".SQUOTE"    [SQH]

Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(GLONSQH), CRITERE(100)

$B_TRT_SQH
If  STOP=1
    CRITERE = '[F:SQH]APPFLG=0 & [F:SQH]NUM>"'+CLE1+'"'
    STOP = 0
Else
    CRITERE = "[F:SQH]APPFLG=0"
Endif
# Pour test
#CRITERE = 'find(NUM,"FCAPN1303000000004","FCAPN1303000000003","FCAPN1211000000002")'

Raz COMPTEUR

Trbegin [SQH]
  For [SQH] SQH0 Where evalue(CRITERE) 

    [F:SQH]APPFLG=4 
    Rewrite [SQH]
    If fstat
        Call ECR_TRACE("File SQUOTE"-[F:SQH]SQHNUM+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    NBENR+=1 : COMPTEUR+=1

    If COMPTEUR>GMAXUPDTRS CLE1=[F:SQH]SQHNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto B_TRT_SQH : Endif

Close Local File [SQH]

Call ECR_TIME("UTIVEN14 : Sales Quote Process : Ended :"+"("-num$(NBENR)-")") From DOSSUB
Return 


Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(4)=2
  Call ECR_TRACE("UTIVEN14 - Sales Quote Process : Update SQUOTE",0) From GESECRAN
  Call EXE_UTIVEN14(DOSSIER)
Endif
#-----
End


#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(4)=2
Call EXE_UTIVEN14(APPLI)
Endif
End


