#<AdxTL>@(#)2.0.0.0 $Revision$
##############################################################################
## copy the  VEN/PRI/PRITYP parameter values on the TC/INV/SALPRITYP Parameter
##############################################################################

Call MAJ_UTICPT53
End
##############################################################################
Subprog MAJ_UTICPT53

Local Char DOSSIER(30) : DOSSIER=nomap
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTICPT53:"-"copy the  PRITYP parameter values on the SALPRITYP Parameter") From LECFIC
Call SAIDOS(DOSSIER,"UTICPT53") From SAIDOS
If DOSSIER<>"" Call EXE_UTICPT53(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End

##############################################################################

Subprog EXE_UTICPT53(APPLI)
Value Char APPLI

Local Integer OK
If filinfo(filpath("FIL","ADOPAR","fde",APPLI),0) < 0 : End : Endif
If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0) < 0 : End : Endif

If clalev([F:ADW])=0  : Local File =APPLI+".ADOVAL"  [ADW]  : Endif
If clalev([F:ADW2])=0 : Local File =APPLI+".ADOVAL"  [ADW2] : Endif
If clalev([F:ADP])=0  : Local File =APPLI+".ADOPAR"  [ADP]  : Endif
If clalev([F:ADP2])=0 : Local File =APPLI+".ADOPAR"  [ADP2] : Endif

Call ECR_TRACE("UTICPT53: Process Start on : "+APPLI,0) From GESECRAN

Call DEBTRANS From GLOCK
Gosub TR_UTICPT53
Call ECR_TRACE("UTICPT53: Process End on : "+APPLI,0) From GESECRAN
End

##############################################################################
#copy the  VEN/PRI/PRITYP parameter values on the SALPRITYP Parameter
##############################################################################
$TR_UTICPT53
Trbegin  [ADW], [ADW2], [ADP], [ADP2]

For [ADP2]ADP1 Where PARAM="PRITYP"
   Read [ADP]ADP1 = "SALPRITYP"
   If fstat
      [F:ADP]         = [F:ADP2]
      [F:ADP]PARAM    = "SALPRITYP"
      [F:ADP]CHAPITRE = "TC"
      [F:ADP]GRPPAR   = "INV"
      Write [ADP]
      If fstat
         GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"ADOPAR"-":"-[F:ADP]PARAM,1) From GESECRAN
         Break
      Endif
            
   Else
      [F:ADP]         = [F:ADP2]
      [F:ADP]PARAM    = "SALPRITYP"
      [F:ADP]CHAPITRE = "TC"
      [F:ADP]GRPPAR   = "INV"
      Rewrite [ADP]
      If fstat
         GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"ADOPAR"-":"-[F:ADP]PARAM,1) From GESECRAN
         Break
      Endif
   Endif
 # to check if the PRITYP parameter values exist  
   Read [ADW2]ADW1(1)=[ADP2]PARAM
   If !fstat
      # if found, delete all SALPRITYP parameter values and create SALPRITYP parameter values as copy of PRITYP parameter values,
      # to have only the customer parameter values
      # If not found, the SALPRITYP parameter values remain unchanged, because they already are in the right chapter
      Delete [ADW] Where PARAM = [ADP]PARAM
      If fstat
         GOK=0 : Call ECR_TRACE(mess(449,177,1)-"ADOVAL"-":"-[ADP]PARAM,1) From GESECRAN
      Endif
      If !GOK : Goto AB_UTICPT53 : Endif
      
      For [ADW2]ADW1 Where PARAM=[ADP2]PARAM
          [F:ADW]      = [F:ADW2]
          [F:ADW]PARAM = [ADP]PARAM
          Write [ADW]
          If fstat
             GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"ADOVAL"-":"-[F:ADW]PARAM-[F:ADW]CMP-[F:ADW]FCY,1) From GESECRAN
             Break
          Endif
      Next   
   
   Endif
Next

Delete [ADP2] Where PARAM = "PRITYP"
If fstat
   GOK=0 : Call ECR_TRACE(mess(449,177,1)-"ADOPAR"-":"-"PRITYP",1) From GESECRAN
Endif
If !GOK : Goto AB_UTICPT53 : Endif

Delete [ADW2] Where PARAM = "PRITYP"
If fstat
   GOK=0 : Call ECR_TRACE(mess(449,177,1)-"ADOVAL"-":"-"PRITYP",1) From GESECRAN
Endif
If !GOK : Goto AB_UTICPT53 : Endif

Commit
Return

##############################################################################
$AB_UTICPT53
Rollback
Return 

########################################################################
# Executed Automatically during patch integration                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call EXE_UTICPT53(APPLI)
End

########################################################################
# Executed during Folder validation                                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI="X3" End : Endif
Call EXE_UTICPT53(APPLI)

End

