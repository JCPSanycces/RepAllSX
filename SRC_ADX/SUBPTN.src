#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion du fichier PURTRS
#######################################################################
# SUBPTN : Transactions de saisie des retours            MBT 02/01/03 #
# ------------------------------------------------------------------- #
# Tables mises à jour : [F:PTR]PURTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWB]AWINBRO  Table des browsers            #
#                       [F:AWT]AWINBOUT Table des boutons             #
#                                                                     #
# Génération de 1 écran de saisie à partir de l'écran de base PNH1    #
#                                                                     #
# Nom des écrans générés : WExyyyyyz                                  #
#                            x = 1 pour appels d'offre                #
#                                2 pour demandes d'achat              #
#                                3 pour commandes standard            #
#                                5 pour commandes ouvertes            #
#                                6 pour réceptions fournisseurs       #
#                                7 pour retours fournisseurs          #
#                                8 pour factures / avoirs             #
#                                                                     #
#                        yyyyy = nom de la transaction (PTRNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                0 et 1 pour appels d'offre           #
#                                1 pour demandes d'achat              #
#                                1, 2 et 3 pour commandes standard    #
#                                9 pour commandes par article         #
#                                0, 1 et 2 pour commandes ouvertes    #
#                                1 pour réceptions fournisseurs       #
#                                1 pour retours fournisseurs          #
#                                0, 1, 2, 3 et 4 pour factures/avoirs #
#######################################################################

Call OBJET("PTN",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="PTR"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=7
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:PTN0]PTRTYP=7
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="PURTRS" & IDENT1=num$([F:PTR]PTRTYP) & IDENT2=[F:PTR]PTRNUM
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="PTR"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "SEL_TABLE"   : Gosub SEL_TABLE : # Sélection sur code pièce auto
 When "FERME"       : Call IMPSCR From ATRTX3
 When Default
Endcase
Return

$SEL_TABLE
#---------------------#
# Sélection sur champ #
#---------------------#
Case COUZON
  When "ENTCOD"   : # Pièce auto de sortie stock
    OBJET="GAU"
    CRITERE="TBL='STJTMP'"
Endcase
Return

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto
Local Char APPLI
APPLI=nomap
Return

#-------------------------------------------------------#
# Ne traiter que les transactions de type facture/avoir #
#-------------------------------------------------------#
$FILTRE
FILTSUP="PTRTYP=7"
Return

#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT
If GREP<>"" | !CLECUR | GHISTO
  Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
#----- Suppression de l'option "Changement de clé" -----#
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case REP
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

#----------------------------------------#
# Après lecture de chaque enregistrement #
#----------------------------------------#
$LIENS
If [M:PTN1]LEDTYPSCR=0  [M:PTN1]LEDTYPSCR=1  : Endif
If dim([M:PTN1]WRHCOD)>0
  If [M:PTN1]WRHCOD=0   [M:PTN1]WRHCOD=3     : Endif
  If [M:PTN1]WRHOBY = 2
    Grizo [M:PTN1]WRHCOD
  Else
    Actzo [M:PTN1]WRHCOD
  Endif
Endif

# Issue 71069 - 2013-07-29 by MAE : PJT en en-tête
If [M:PTN1]PJTHCOD=0   [M:PTN1]PJTHCOD=3     : Endif
#Fin MAE
# Issue 112754 - 2016-12-01 by SR : Services
If [M:PTN2]ITMKNDCOD=0  [M:PTN2]ITMKNDCOD=2  : Endif : # Type d'article
If [M:PTN2]ITMKNDSCR=0  [M:PTN2]ITMKNDSCR=1  : Endif
#-----
If dim([M:PTN1]NBLEDTYP)>0 & len(mess(0,2644,1))>0
  If [M:PTN1]NBLEDTYP=0  [M:PTN1]NBLEDTYP=len(mess(0,2644,1)) : Affzo [PTN1]20 : Endif
  For nolign=1 To [M:PTN1]NBLEDTYP
    If [M:PTN1]LEDTYPCOD(nolign-1)=0  [M:PTN1]LEDTYPCOD(nolign-1)=1 : Endif
    If func TRTX3CPT.TYPLEDAUTO(nolign)
      [M:PTN1]LEDTYPCOD(nolign-1)=3
      Grizo  [PTN1]LEDTYPCOD(nolign-1)
      Chgstl [PTN1]LEDTYPCOD(nolign-1) With "ITALIQUE"
    Endif
  Next nolign
Endif
#-----
[M:PTN2]ITMDES1COD=[F:PTR]ITMDESCOD(1)
[M:PTN2]ITMDES1SCR=[F:PTR]ITMDESSCR(1)
[M:PTN2]VAT1COD   =[F:PTR]VATCOD(0)
[M:PTN2]VAT1SCR   =[F:PTR]VATSCR(0)
[M:PTN2]VAT2COD   =[F:PTR]VATCOD(1)
[M:PTN2]VAT2SCR   =[F:PTR]VATSCR(1)
[M:PTN2]VAT3COD   =[F:PTR]VATCOD(2)
[M:PTN2]VAT3SCR   =[F:PTR]VATSCR(2)
If dim([M:PTN2]TAXRCPCOD)>0
  [M:PTN2]TAXRCPCOD =[F:PTR]VATCOD(3)
  [M:PTN2]TAXRCPSCR =[F:PTR]VATSCR(3)
  [M:PTN2]TAXISSCOD =[F:PTR]VATCOD(4)
  [M:PTN2]TAXISSSCR =[F:PTR]VATSCR(4)
  [M:PTN2]TAXOTH1COD=[F:PTR]VATCOD(5)
  [M:PTN2]TAXOTH1SCR=[F:PTR]VATSCR(5)
  [M:PTN2]TAXOTH2COD=[F:PTR]VATCOD(6)
  [M:PTN2]TAXOTH2SCR=[F:PTR]VATSCR(6)
Endif
If dim([M:PTN3]DISCRGCOD1)>0
  [M:PTN3]DISCRGCOD1=[F:PTR]DISCRGCOD(0)
  [M:PTN3]DISCRGSCR1=[F:PTR]DISCRGSCR(0)
Endif
If dim([M:PTN3]DISCRGCOD2)>0
  [M:PTN3]DISCRGCOD2=[F:PTR]DISCRGCOD(1)
  [M:PTN3]DISCRGSCR2=[F:PTR]DISCRGSCR(1)
Endif
If dim([M:PTN3]DISCRGCOD3)>0
  [M:PTN3]DISCRGCOD3=[F:PTR]DISCRGCOD(2)
  [M:PTN3]DISCRGSCR3=[F:PTR]DISCRGSCR(2)
Endif
If dim([M:PTN3]DISCRGCOD4)>0
  [M:PTN3]DISCRGCOD4=[F:PTR]DISCRGCOD(3)
  [M:PTN3]DISCRGSCR4=[F:PTR]DISCRGSCR(3)
Endif
If dim([M:PTN3]DISCRGCOD5)>0
  [M:PTN3]DISCRGCOD5=[F:PTR]DISCRGCOD(4)
  [M:PTN3]DISCRGSCR5=[F:PTR]DISCRGSCR(4)
Endif
If dim([M:PTN3]DISCRGCOD6)>0
  [M:PTN3]DISCRGCOD6=[F:PTR]DISCRGCOD(5)
  [M:PTN3]DISCRGSCR6=[F:PTR]DISCRGSCR(5)
Endif
If dim([M:PTN3]DISCRGCOD7)>0
  [M:PTN3]DISCRGCOD7=[F:PTR]DISCRGCOD(6)
  [M:PTN3]DISCRGSCR7=[F:PTR]DISCRGSCR(6)
Endif
If dim([M:PTN3]DISCRGCOD8)>0
  [M:PTN3]DISCRGCOD8=[F:PTR]DISCRGCOD(7)
  [M:PTN3]DISCRGSCR8=[F:PTR]DISCRGSCR(7)
Endif
If dim([M:PTN3]DISCRGCOD9)>0
  [M:PTN3]DISCRGCOD9=[F:PTR]DISCRGCOD(8)
  [M:PTN3]DISCRGSCR9=[F:PTR]DISCRGSCR(8)
Endif
#-----
If [M:PTN0]ENAFLG=0  [M:PTN0]ENAFLG=2 : Endif
If [M:PTN4]IDECOD01=0  [M:PTN4]IDECOD01=3 : Endif
If [M:PTN4]IDESCR01=0  [M:PTN4]IDESCR01=1 : Endif
If [M:PTN4]IDECOD02=0  [M:PTN4]IDECOD02=3 : Endif
If [M:PTN4]IDESCR02=0  [M:PTN4]IDESCR02=1 : Endif
#----- Onglet Paramètres -----#
If [M:PTN1]BPSNDEFLG=1    Grizo [PTN1]BPSNDESCR  Else Actzo [PTN1]BPSNDESCR  : Endif
If [M:PTN1]BPSLOTFLG=1    Grizo [PTN1]BPSLOTSCR  Else Actzo [PTN1]BPSLOTSCR  : Endif
If [M:PTN1]PRIFLG=1       Grizo [PTN1]PRISCR     Else Actzo [PTN1]PRISCR     : Endif
If [M:PTN1]LINAMTFLG=1    Grizo [PTN1]LINAMTSCR  Else Actzo [PTN1]LINAMTSCR  : Endif
If [M:PTN1]POHNUMFLG=1    Grizo [PTN1]POHNUMSCR  Else Actzo [PTN1]POHNUMSCR  : Endif
If [M:PTN1]PUUFLG=1       Grizo [PTN1]PUUSCR     Else Actzo [PTN1]PUUSCR     : Endif
#----- Onglet Ligne 1 -----#
If dim([M:PTN2]TAXRCPCOD)>0
  If [M:PTN2]TAXRCPCOD=0  [M:PTN2]TAXRCPCOD=3  : Endif : # Taxe entrée
Endif
If dim([M:PTN2]TAXISSCOD)>0
  If [M:PTN2]TAXISSCOD=0  [M:PTN2]TAXISSCOD=3  : Endif : # Taxe sortie
Endif
If dim([M:PTN2]TAXOTH1COD)>0
  If [M:PTN2]TAXOTH1COD=0 [M:PTN2]TAXOTH1COD=3 : Endif : # Autre taxe 1
Endif
If dim([M:PTN2]TAXOTH2COD)>0
  If [M:PTN2]TAXOTH2COD=0 [M:PTN2]TAXOTH2COD=3 : Endif : # Autre taxe 2
Endif
If dim([M:PTN2]TAXRCPSCR)>0
  If [M:PTN2]TAXRCPSCR=0  [M:PTN2]TAXRCPSCR=1  : Endif
Endif
If dim([M:PTN2]TAXISSSCR)>0
  If [M:PTN2]TAXISSSCR=0  [M:PTN2]TAXISSSCR=1  : Endif
Endif
If dim([M:PTN2]TAXOTH1SCR)>0
  If [M:PTN2]TAXOTH1SCR=0 [M:PTN2]TAXOTH1SCR=1 : Endif
Endif
If dim([M:PTN2]TAXOTH2SCR)>0
  If [M:PTN2]TAXOTH2SCR=0 [M:PTN2]TAXOTH2SCR=1 : Endif
Endif
If [M:PTN2]REFORICOD<>2   Grizo [PTN2]REFORISCR  Else Actzo [PTN2]REFORISCR  : Endif
If [M:PTN2]REFORICOD=3    Grizo [PTN2]REFORIPOS  Else Actzo [PTN2]REFORIPOS  : Endif
If [M:PTN2]ITMDESCOD=3    Grizo [PTN2]ITMDESSCR  Else Actzo [PTN2]ITMDESSCR  : Endif
If [M:PTN2]ITMDES1COD=3   Grizo [PTN2]ITMDES1SCR Else Actzo [PTN2]ITMDES1SCR : Endif
# Issue 112754 - 2016-12-05 by SR : Services
If [M:PTN2]ITMKNDCOD=3    Grizo [PTN2]ITMKNDSCR  Else Actzo [PTN2]ITMKNDSCR  : Endif
If [M:PTN2]PJTCOD=3       Grizo [PTN2]PJTSCR     Else Actzo [PTN2]PJTSCR     : Endif
If GACTDEB=2 & dim([M:PTN2]EECINCCOD)>0 & dim([M:PTN2]EECINCSCR)>0
  If [M:PTN2]EECINCCOD=3  Grizo [PTN2]EECINCSCR  Else Actzo [PTN2]EECINCSCR  : Endif
Endif
If [M:PTN2]ORICRYCOD=3    Grizo [PTN2]ORICRYSCR  Else Actzo [PTN2]ORICRYSCR  : Endif
If [M:PTN2]VAT1COD=3      Grizo [PTN2]VAT1SCR    Else Actzo [PTN2]VAT1SCR    : Endif
If [M:PTN2]VAT2COD=3      Grizo [PTN2]VAT2SCR    Else Actzo [PTN2]VAT2SCR    : Endif
If [M:PTN2]VAT3COD=3      Grizo [PTN2]VAT3SCR    Else Actzo [PTN2]VAT3SCR    : Endif
If dim([M:PTN2]TAXRCPCOD)>0
  If [M:PTN2]TAXRCPCOD=3  Grizo [PTN2]TAXRCPSCR  Else Actzo [PTN2]TAXRCPSCR  : Endif
Endif
If dim([M:PTN2]TAXISSCOD)>0
  If [M:PTN2]TAXISSCOD=3  Grizo [PTN2]TAXISSSCR  Else Actzo [PTN2]TAXISSSCR  : Endif
Endif
If dim([M:PTN2]TAXOTH1COD)>0
  If [M:PTN2]TAXOTH1COD=3 Grizo [PTN2]TAXOTH1SCR Else Actzo [PTN2]TAXOTH1SCR : Endif
Endif
If dim([M:PTN2]TAXOTH2COD)>0
  If [M:PTN2]TAXOTH2COD=3 Grizo [PTN2]TAXOTH2SCR Else Actzo [PTN2]TAXOTH2SCR : Endif
Endif
If [M:PTN2]TRSFAMCOD=3    Grizo [PTN2]TRSFAMSCR  Else Actzo [PTN2]TRSFAMSCR  : Endif
If [M:PTN2]QTYSTUCOD=3    Grizo [PTN2]QTYSTUSCR  Else Actzo [PTN2]QTYSTUSCR  : Endif
If [M:PTN2]UOMCOECOD=3    Grizo [PTN2]UOMCOESCR  Else Actzo [PTN2]UOMCOESCR  : Endif
If [M:PTN2]UNTWEICOD=3    Grizo [PTN2]UNTWEISCR  Else Actzo [PTN2]UNTWEISCR  : Endif
If [M:PTN2]POHFCYCOD=3    Grizo [PTN2]POHFCYSCR  Else Actzo [PTN2]POHFCYSCR  : Endif
#----- Onglet Ligne 2 -----#
If [M:PTN3]GROPRICOD=0  [M:PTN3]GROPRICOD=1 : Endif
If [M:PTN3]GROPRISCR=0  [M:PTN3]GROPRISCR=1 : Endif
If [M:PTN3]GROPRICOD=3    Grizo [PTN3]GROPRISCR  Else Actzo [PTN3]GROPRISCR  : Endif
If dim([M:PTN3]DISCRGCOD1)>0
  If [M:PTN3]DISCRGCOD1=3 Grizo [PTN3]DISCRGSCR1 Else Actzo [PTN3]DISCRGSCR1 : Endif
Endif
If dim([M:PTN3]DISCRGCOD2)>0
  If [M:PTN3]DISCRGCOD2=3 Grizo [PTN3]DISCRGSCR2 Else Actzo [PTN3]DISCRGSCR2 : Endif
Endif
If dim([M:PTN3]DISCRGCOD3)>0
  If [M:PTN3]DISCRGCOD3=3 Grizo [PTN3]DISCRGSCR3 Else Actzo [PTN3]DISCRGSCR3 : Endif
Endif
If dim([M:PTN3]DISCRGCOD4)>0
  If [M:PTN3]DISCRGCOD4=3 Grizo [PTN3]DISCRGSCR4 Else Actzo [PTN3]DISCRGSCR4 : Endif
Endif
If dim([M:PTN3]DISCRGCOD5)>0
  If [M:PTN3]DISCRGCOD5=3 Grizo [PTN3]DISCRGSCR5 Else Actzo [PTN3]DISCRGSCR5 : Endif
Endif
If dim([M:PTN3]DISCRGCOD6)>0
  If [M:PTN3]DISCRGCOD6=3 Grizo [PTN3]DISCRGSCR6 Else Actzo [PTN3]DISCRGSCR6 : Endif
Endif
If dim([M:PTN3]DISCRGCOD7)>0
  If [M:PTN3]DISCRGCOD7=3 Grizo [PTN3]DISCRGSCR7 Else Actzo [PTN3]DISCRGSCR7 : Endif
Endif
If dim([M:PTN3]DISCRGCOD8)>0
  If [M:PTN3]DISCRGCOD8=3 Grizo [PTN3]DISCRGSCR8 Else Actzo [PTN3]DISCRGSCR8 : Endif
Endif
If dim([M:PTN3]DISCRGCOD9)>0
  If [M:PTN3]DISCRGCOD9=3 Grizo [PTN3]DISCRGSCR9 Else Actzo [PTN3]DISCRGSCR9 : Endif
Endif
If [M:PTN3]PURTYPCOD=3    Grizo [PTN3]PURTYPSCR  Else Actzo [PTN3]PURTYPSCR  : Endif
#----- Onglet ligne 3 -----#
If [M:PTN4]LOTCOD=3       Grizo [PTN4]LOTSCR     Else Actzo [PTN4]LOTSCR     : Endif
If [M:PTN4]SLOCOD=3       Grizo [PTN4]SLOSCR     Else Actzo [PTN4]SLOSCR     : Endif
If [M:PTN4]STACOD=3       Grizo [PTN4]STASCR     Else Actzo [PTN4]STASCR     : Endif
If [M:PTN4]LOCCOD=3       Grizo [PTN4]LOCSCR     Else Actzo [PTN4]LOCSCR     : Endif
If [M:PTN4]SERCOD=3       Grizo [PTN4]SERSCR     Else Actzo [PTN4]SERSCR     : Endif
If [M:PTN4]SERECOD=3      Grizo [PTN4]SERESCR    Else Actzo [PTN4]SERESCR    : Endif
If [M:PTN4]IDECOD01=3     Grizo [PTN4]IDESCR01   Else Actzo [PTN4]IDESCR01   : Endif
If [M:PTN4]IDECOD02=3     Grizo [PTN4]IDESCR02   Else Actzo [PTN4]IDESCR02   : Endif
If [M:PTN4]MVTDESCOD=3    Grizo [PTN4]MVTDESSCR  Else Actzo [PTN4]MVTDESSCR  : Endif
If dim([M:PTN4]WRHCOD1)>0
  If [M:PTN4]WRHCOD1=0  [M:PTN4]WRHCOD1=3  : Endif : # Dépôt (invisible)
  #--- Dem 60616
  #If [M:PTN1]WRHOBY =2
  #  Grizo [M:PTN4]WRHCOD1 : Grizo [M:PTN4]WRHSCR1
  #Else
    Actzo [M:PTN4]WRHCOD1
    If [M:PTN4]WRHCOD1=3  Grizo [PTN4]WRHSCR1  Else Actzo [PTN4]WRHSCR1  : Endif
  #Endif
  #---
Endif

# Issue X3-82010 - 2018-05-07 by MUARN : LPN
If dim([M:PTN4]LPNCOD)>0
  If [M:PTN4]LPNCOD=0   [M:PTN4]LPNCOD=3     : Endif
  Actzo [M:PTN4]LPNCOD
  If [M:PTN4]LPNCOD=3  Grizo [PTN4]LPNSCR  Else Actzo [PTN4]LPNSCR  : Endif
Endif

#-----
Gosub PE_PURTRS From SUBPTX
Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
#----- Entête -----#
[M:PTN0]PTRTYP = 7
[M:PTN0]ENAFLG = 2
#----- Onglet Paramètres -----#
# sr revue de code : ajout de la ligne
# Issue 71069 - 2013-07-29 by MAE : PJT en en-tête
[M:PTN1]PJTHCOD=3
[M:PTN1]LEDTYPSCR=1
If dim([M:PTN1]NBLEDTYP)>0
  [M:PTN1]NBLEDTYP=len(mess(0,2644,1)) : Affzo [PTN1]20
  For nolign=1 To [M:PTN1]NBLEDTYP
    [M:PTN1]LEDTYPINT(nolign-1)=nolign
    If func TRTX3CPT.TYPLEDAUTO(nolign)
      [M:PTN1]LEDTYPCOD(nolign-1)=3
      Grizo  [PTN1]LEDTYPCOD(nolign-1)
      Chgstl [PTN1]LEDTYPCOD(nolign-1) With "ITALIQUE"
    Else
      [M:PTN1]LEDTYPCOD(nolign-1)=1
    Endif
  Next nolign
Endif
#-----
[M:PTN1]DOCNAM = ""
[M:PTN1]DOCFLG = 1
[M:PTN1]STAFLG=2
[M:PTN1]BPSNDEFLG=2   : [M:PTN1]BPSNDESCR=1  : Actzo [PTN1]BPSNDESCR
[M:PTN1]BPSLOTFLG=2   : [M:PTN1]BPSLOTSCR=1  : Actzo [PTN1]BPSLOTSCR
[M:PTN1]PRIFLG=1      : [M:PTN1]PRISCR=1     : Grizo [PTN1]PRISCR
[M:PTN1]LINAMTFLG=1   : [M:PTN1]LINAMTSCR=1  : Grizo [PTN1]LINAMTSCR
[M:PTN1]POHNUMFLG=2   : [M:PTN1]POHNUMSCR=1  : Actzo [PTN1]POHNUMSCR
[M:PTN1]PUUFLG=2      : [M:PTN1]PUUSCR=1     : Actzo [PTN1]PUUSCR
[M:PTN1]NBRCOL=1
[M:PTN1]STKFLG=1
#-----
If dim([M:PTN1]WRHCOD)>0
  If [M:PTN1]WRHOBY=2
    [M:PTN1]WRHCOD=1  : # Dépôt (saisi)
    Diszo [M:PTN1]WRHCOD
  Else
    [M:PTN1]WRHCOD=3  : # Dépôt (invisible)
    Actzo [M:PTN1]WRHCOD
  Endif
Endif
#----- Onglet Ligne 1 -----#
[M:PTN2]REFORICOD=1   : [M:PTN2]REFORISCR=1  : Grizo [PTN2]REFORISCR
[M:PTN2]REFORIPOS=3                          : Actzo [PTN2]REFORIPOS
[M:PTN2]ITMDESCOD=1   : [M:PTN2]ITMDESSCR=1  : Actzo [PTN2]ITMDESSCR
[M:PTN2]ITMDES1COD=3  : [M:PTN2]ITMDES1SCR=1 : Grizo [PTN2]ITMDES1SCR
# Issue 112754 - 2016-12-05 by SR : Services
[M:PTN2]ITMKNDCOD=2   : [M:PTN2]ITMKNDSCR=1  : Actzo [PTN2]ITMKNDSCR
[M:PTN2]PJTCOD=3      : [M:PTN2]PJTSCR=1     : Grizo [PTN2]PJTSCR
If GACTDEB=2 & dim([M:PTN2]EECINCCOD)>0 & dim([M:PTN2]EECINCSCR)>0
  [M:PTN2]EECINCCOD=1 : [M:PTN2]EECINCSCR=1  : Actzo [PTN2]EECINCSCR
Endif
[M:PTN2]ORICRYCOD=1   : [M:PTN2]ORICRYSCR=1  : Actzo [PTN2]ORICRYSCR
[M:PTN2]VAT1COD=3     : [M:PTN2]VAT1SCR=1    : Grizo [PTN2]VAT1SCR
[M:PTN2]VAT2COD=3     : [M:PTN2]VAT2SCR=1    : Grizo [PTN2]VAT2SCR
[M:PTN2]VAT3COD=3     : [M:PTN2]VAT3SCR=1    : Grizo [PTN2]VAT3SCR
