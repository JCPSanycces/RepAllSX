[M:PTN4]IDECOD02=3   : [M:PTN4]IDESCR02=1   : Grizo [PTN4]IDESCR02
[M:PTN4]MVTDESCOD=3  : [M:PTN4]MVTDESSCR=1  : Grizo [PTN4]MVTDESSCR
If dim([M:PTN4]WRHCOD1)>0 & dim([M:PTN4]WRHSCR1)>0
  If dim([M:PTN1]WRHOBY)>0
