  [M:PTN3]DISCRGCOD4=3 : [M:PTN3]DISCRGSCR4=1 : Grizo [PTN3]DISCRGSCR4
Endif
If dim([M:PTN3]DISCRGCOD5)>0
  [M:PTN3]DISCRGCOD5=3 : [M:PTN3]DISCRGSCR5=1 : Grizo [PTN3]DISCRGSCR5
Endif
If dim([M:PTN3]DISCRGCOD6)>0
  [M:PTN3]DISCRGCOD6=3 : [M:PTN3]DISCRGSCR6=1 : Grizo [PTN3]DISCRGSCR6
Endif
If dim([M:PTN3]DISCRGCOD7)>0
  [M:PTN3]DISCRGCOD7=3 : [M:PTN3]DISCRGSCR7=1 : Grizo [PTN3]DISCRGSCR7
Endif
If dim([M:PTN3]DISCRGCOD8)>0
  [M:PTN3]DISCRGCOD8=3 : [M:PTN3]DISCRGSCR8=1 : Grizo [PTN3]DISCRGSCR8
Endif
If dim([M:PTN3]DISCRGCOD9)>0
  [M:PTN3]DISCRGCOD9=3 : [M:PTN3]DISCRGSCR9=1 : Grizo [PTN3]DISCRGSCR9
Endif
[M:PTN3]PURTYPCOD=3  : [M:PTN3]PURTYPSCR=1  : Grizo [PTN3]PURTYPSCR
#----- Onglet ligne 3 -----#
[M:PTN4]LOTCOD=2     : [M:PTN4]LOTSCR=1     : Actzo [PTN4]LOTSCR
[M:PTN4]SLOCOD=3     : [M:PTN4]SLOSCR=1     : Grizo [PTN4]SLOSCR
[M:PTN4]STACOD=3     : [M:PTN4]STASCR=1     : Grizo [PTN4]STASCR
[M:PTN4]LOCCOD=3     : [M:PTN4]LOCSCR=1     : Grizo [PTN4]LOCSCR
[M:PTN4]SERCOD=3     : [M:PTN4]SERSCR=1     : Grizo [PTN4]SERSCR
[M:PTN4]SERECOD=3    : [M:PTN4]SERESCR=1    : Grizo [PTN4]SERESCR
