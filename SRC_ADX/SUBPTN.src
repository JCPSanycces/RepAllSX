         If !GIMPORT Affzo [PTN2]PJTSCR     : Grizo [PTN2]PJTSCR     : Endif
       Elsif !GIMPORT
         Actzo [PTN2]PJTSCR
       Endif
  When "EECINCCOD"
       If GACTDEB=2 & dim([M:PTN2]EECINCSCR)>0
         If val(CZ)=3
           [M:PTN2]EECINCSCR=1
           If !GIMPORT Affzo [PTN2]EECINCSCR  : Grizo [PTN2]EECINCSCR  : Endif
         Elsif !GIMPORT
           Actzo [PTN2]EECINCSCR
         Endif
       Endif
  When "ORICRYCOD"
       If val(CZ)=3
