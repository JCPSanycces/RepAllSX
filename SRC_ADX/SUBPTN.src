  [M:PTN2]TAXRCPCOD=3 : [M:PTN2]TAXRCPSCR=1  : Grizo [PTN2]TAXRCPSCR
Endif
If dim([M:PTN2]TAXISSCOD)>0
  [M:PTN2]TAXISSCOD=3 : [M:PTN2]TAXISSSCR=1  : Grizo [PTN2]TAXISSSCR
Endif
If dim([M:PTN2]TAXOTH1COD)>0
  [M:PTN2]TAXOTH1COD=3: [M:PTN2]TAXOTH1SCR=1 : Grizo [PTN2]TAXOTH1SCR
Endif
If dim([M:PTN2]TAXOTH2COD)>0
  [M:PTN2]TAXOTH2COD=3: [M:PTN2]TAXOTH2SCR=1 : Grizo [PTN2]TAXOTH2SCR
Endif
[M:PTN2]TRSFAMCOD=1   : [M:PTN2]TRSFAMSCR=1  : Actzo [PTN2]TRSFAMSCR
