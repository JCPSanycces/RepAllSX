    #If [M:PTN1]WRHOBY = 2
    #  [M:PTN4]WRHCOD1=2      : # Dépôt (affiché)
    #  Diszo [PTN4]WRHCOD1 : Diszo [PTN4]WRHSCR1
    #Else
      [M:PTN4]WRHCOD1=3      : # Dépôt (invisible)
      [M:PTN4]WRHSCR1=1
      Actzo [PTN4]WRHCOD1 : Actzo [PTN4]WRHSCR1
    #Endif
    #---
  Endif
Endif

# Issue X3-82010 - 2018-05-07 by MUARN : LPN
If dim([M:PTN4]LPNCOD)>0 & dim([M:PTN4]LPNSCR)>0
    [M:PTN4]LPNCOD=3
    [M:PTN4]LPNSCR=1
    Actzo [PTN4]LPNCOD : Actzo [PTN4]LPNSCR
Endif

#-----
Gosub PE_PURTRS From SUBPTX
Affzo [PTN0]1-99
Affzo [PTN1]1-99
Affzo [PTN2]1-99
Affzo [PTN3]1-99
Affzo [PTN4]1-99
Affzo [DST]1-99
Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON
  When "BPSNDEFLG"
       If val(CZ)=1
         [M:PTN1]BPSNDESCR=1
         If !GIMPORT Affzo [PTN1]BPSNDESCR  : Grizo [PTN1]BPSNDESCR  : Endif
       Elsif !GIMPORT
         Actzo [PTN1]BPSNDESCR
       Endif
  When "BPSLOTFLG"
       If val(CZ)=1
         [M:PTN1]BPSLOTSCR=1
         If !GIMPORT Affzo [PTN1]BPSLOTSCR  : Grizo [PTN1]BPSLOTSCR  : Endif
       Elsif !GIMPORT
         Actzo [PTN1]BPSLOTSCR
       Endif
  When "PRIFLG"
       If val(CZ)=1
         [M:PTN1]PRISCR=1
         If !GIMPORT Affzo [PTN1]PRISCR     : Grizo [PTN1]PRISCR     : Endif
       Elsif !GIMPORT
         Actzo [PTN1]PRISCR
       Endif
  When "LINAMTFLG"
       If val(CZ)=1
         [M:PTN1]LINAMTSCR=1
         If !GIMPORT Affzo [PTN1]LINAMTSCR  : Grizo [PTN1]LINAMTSCR  : Endif
       Elsif !GIMPORT
         Actzo [PTN1]LINAMTSCR
       Endif
  When "POHNUMFLG"
       If val(CZ)=1
         [M:PTN1]POHNUMSCR=1
         If !GIMPORT Affzo [PTN1]POHNUMSCR  : Grizo [PTN1]POHNUMSCR  : Endif
       Elsif !GIMPORT
         Actzo [PTN1]POHNUMSCR
       Endif
  When "PUUFLG"
       If val(CZ)=1
         [M:PTN1]PUUSCR=1
         If !GIMPORT Affzo [PTN1]PUUSCR     : Grizo [PTN1]PUUSCR     : Endif
       Elsif !GIMPORT
         Actzo [PTN1]PUUSCR
       Endif
  When "REFORICOD"
       If val(CZ)<>2
         [M:PTN2]REFORISCR=1
         If !GIMPORT Affzo [PTN2]REFORISCR  : Grizo [PTN2]REFORISCR  : Endif
       Elsif !GIMPORT
         Actzo [PTN2]REFORISCR
       Endif
       If val(CZ)=1
         [M:PTN2]REFORIPOS=3
         If !GIMPORT Actzo [PTN2]REFORIPOS  : Affzo [PTN2]REFORIPOS  : Endif
       Elsif val(CZ)=2
         If !GIMPORT Actzo [PTN2]REFORIPOS  : Endif
       Else
         [M:PTN2]REFORIPOS=1
         If !GIMPORT Affzo [PTN2]REFORIPOS  : Grizo [PTN2]REFORIPOS  : Endif
       Endif
  When "ITMDESCOD"
       If val(CZ)=3
         [M:PTN2]ITMDESSCR=1
         If !GIMPORT Affzo [PTN2]ITMDESSCR  : Grizo [PTN2]ITMDESSCR  : Endif
       Elsif !GIMPORT
         Actzo [PTN2]ITMDESSCR
       Endif
  When "ITMDES1COD"
       If val(CZ)=3
         [M:PTN2]ITMDES1SCR=1
         If !GIMPORT Affzo [PTN2]ITMDES1SCR : Grizo [PTN2]ITMDES1SCR : Endif
       Elsif !GIMPORT
         Actzo [PTN2]ITMDES1SCR
       Endif
  When "ITMKNDCOD"                                        # Issue 112754 - 2016-12-05 by SR : Services
       If val(CZ)=3
         [M:PTN2]ITMKNDSCR=1
         If !GIMPORT Affzo [PTN2]ITMKNDSCR  : Grizo [PTN2]ITMKNDSCR  : Endif
       Elsif !GIMPORT
         Actzo [PTN2]ITMKNDSCR
       Endif
  When "PJTCOD"
       If val(CZ)=3
