[M:PTN2]POHFCYCOD=1   : [M:PTN2]POHFCYSCR=1  : Actzo [PTN2]POHFCYSCR
#----- Onglet ligne 2 -----#
[M:PTN3]GROPRICOD=3   : [M:PTN3]GROPRISCR=1  : Grizo [PTN3]GROPRISCR
If dim([M:PTN3]DISCRGCOD1)>0
  [M:PTN3]DISCRGCOD1=3 : [M:PTN3]DISCRGSCR1=1 : Grizo [PTN3]DISCRGSCR1
Endif
If dim([M:PTN3]DISCRGCOD2)>0
  [M:PTN3]DISCRGCOD2=3 : [M:PTN3]DISCRGSCR2=1 : Grizo [PTN3]DISCRGSCR2
Endif
