#<AdxTL>@(#)4.0.0.0 $Revision$
GBIDC2="" : GBIDC3="" : GPILCOD=""
Call OBJET("EDP",GBIDC2,GBIDC3) From GOBJET
End


$ACTION
Case ACTION
 When "INIT_DIA" : Gosub INIT_DIA
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When Default 
Endcase
Return


$INIT_DIA
[M]MES = PARAM(1)
[M]BANORI = PARAM(2)
Return

$CONTROLE
If [M:DIA]BANDES = ""
 FIN=1 : Return
Endif
Filter [EDP] Where MES=[M]MES & BAN=[M]BANDES & ([M]ALLGRP=2 | (GRP>=[M]GRPDEB & GRP<=[M]GRPFIN))
Look [EDP]EDP0 First
Filter [EDP]
If !fstat 
 # Le paramétrage existe déjà sur cette banque
 GERR=1 : GMESSAGE=mess(8,136,1)
Endif
Return

$EXEC
Call DEBTRANS From GLOCK
Gosub DUPLI
Return

$DUPLI
Trbegin [EDP]
GOK=1
Gosub ECR
If GOK<1 : Goto AB_DUPLI : Endif
Commit
Return

$AB_DUPLI
Rollback
Return

$ECR
For [EDP]EDP0 Where MES=[M:DIA]MES & BAN=[M:DIA]BANORI
&               & ([M]ALLGRP=2 | (GRP>=[M]GRPDEB & GRP<=[M]GRPFIN))
 [F:EDP]BAN = [M:DIA]BANDES
 Write [EDP]
 If fstat
  GOK=0 : Call FSTA("EDP") From GLOCK : Break
 Endif
Next
Return


#############################################
Subprog C_BANDES(VALEUR)
Variable Char    VALEUR()
If VALEUR = [M]BANORI
  mkstat=2 
Endif
End

Subprog C_ALLGRP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo GRPDEB,GRPFIN : Grizo GRPDEB,GRPFIN
Else
 Actzo GRPDEB,GRPFIN
Endif
End

Subprog AS_GRPDEB(VALEUR)
Variable Decimal VALEUR
If [M]ALLGRP=2 : mkstat = 1 : End : Endif
End

Subprog AS_GRPFIN(VALEUR)
Variable Decimal VALEUR
If [M]ALLGRP=2 : mkstat = 1 : End : Endif
If VALEUR=0 | VALEUR<[M]GRPDEB : VALEUR = [M]GRPDEB : Endif
End

Subprog C_GRPFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M]GRPDEB
  mkstat=2 : GMESSAGE = mess(83,123,1)   :# Valeur incorrecte
Endif
End

