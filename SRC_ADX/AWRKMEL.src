#<AdxTL>@(#)5.0.0.0 $Revision$
# X3PLAT-1475 Workflow link on representation - new ENVOI_BAIL with representation contxt = start
Subprog ENVOI_MAIL_SYRA(TYPMES,REQREC,REQIMP,USER,MAIL,OBJJOI,CLEOBJ
&                 ,CHRONO,ERD,USR_EMAIL,USR_CODE,USR_ENVOI,USR_SUIVI,USR_NB,TEXCLB,TEXOBJ
&                 ,PCEJOI,NBJOI,TYPJOI,CATJOI,CONTXT,CONTXT_DESKTOP,CONTXT_MOBILE)
Value Integer TYPMES
Value Integer REQREC
Value Integer REQIMP
Value Char    USER
Value Char    MAIL
Value Char    OBJJOI
Value Char    CLEOBJ
Value Char    CHRONO
Value Integer ERD
Value Char    USR_EMAIL()(1..)
Value Char    USR_CODE()(1..)
Value Integer USR_ENVOI(1..)
Value Integer USR_SUIVI(1..)
Value Integer USR_NB
Value Clbfile TEXCLB
Value Char    TEXOBJ
Value Char    PCEJOI()(1..)
Value Integer NBJOI
Value Char    TYPJOI
Value Integer CATJOI
Value Char    CONTXT
Value Char    CONTXT_DESKTOP
Value Char    CONTXT_MOBILE

# X3PLAT-1475 Workflow link - start
Local Integer CONTXT_DEST : CONTXT_DEST=0            # CPMTXT_DEST determines if the context is set in AWRKMEL
If instr(1,CONTXT_DESKTOP,"[L]DEST") | instr(1,CONTXT_MOBILE,"[L]DEST")
  CONTXT_DEST=1
Endif
Goto ENVOI_MAIL_PROG
# X3PLAT-1475 Workflow link on representation - new ENVOI_BAIL with representation contxt - end

#---------------------------------------------------------------------------------------#
# Envoi d'un message par "meladx" ou "Send"
#---------------------------------------------------------------------------------------#

Subprog ENVOI_MAIL(TYPMES,REQREC,REQIMP,USER,MAIL,OBJJOI,CLEOBJ
&                 ,CHRONO,ERD,USR_EMAIL,USR_ENVOI,USR_SUIVI,USR_NB,TEXCLB,TEXOBJ
&                 ,PCEJOI,NBJOI,TYPJOI,CATJOI,CONTXT)
Value Integer TYPMES
Value Integer REQREC
Value Integer REQIMP
Value Char    USER
Value Char    MAIL
Value Char    OBJJOI
Value Char    CLEOBJ
Value Char    CHRONO
Value Integer ERD
Value Char    USR_EMAIL()(1..)
Value Integer USR_ENVOI(1..)
Value Integer USR_SUIVI(1..)
Value Integer USR_NB
Value Clbfile TEXCLB
Value Char    TEXOBJ
Value Char    PCEJOI()(1..)
Value Integer NBJOI
Value Char    TYPJOI
Value Integer CATJOI
Value Char    CONTXT

Local Char    CONTXT_DESKTOP(255)                     # X3PLAT-1475 Workflow link on representation - new ENVOI_BAIL with representation contxt
Local Char    CONTXT_MOBILE (255)                     # X3PLAT-1475 Workflow link on representation - new ENVOI_BAIL with representation contxt
Local Integer CONTXT_DEST : CONTXT_DEST=0             # X3PLAT-1475 Workflow link on representation - new ENVOI_BAIL with representation contxt
Local Char    USR_DEST(GLONAUS)(1..)                  # X3PLAT-1475 Workflow link on representation - new ENVOI_BAIL with representation contxt
Local Char    USR_CODE(GLONAUS)(1..)                  # X3PLAT-1475 Workflow link on representation - new ENVOI_BAIL with representation contxt

$ENVOI_MAIL_PROG                                      # X3PLAT-1475 Workflow link on representation - new ENVOI_BAIL with representation contxt

# Ne pas utiliser de variable globale qui ne soit pas déclarée dans le serveur batch

Local Integer  I , J , K , L , M , N , U , D , F , T , OK , ERT , STAT , TRAPCE
Local Integer  NBTEX , NBMES , NBSP , NBCR , NBCLE , VERROU , TRAMEL , MAXTXT
Local Char     MESSAGE(255)(1..150) , ERM(250) , SYMBOLE(250)
Local Char     CLE(255)(1..16) , CHAINE(255) , EXT(10)
Local Char     CLE1(80) , CLE2(80)(0..16) , IDENT(80)
Local Char     REP1(GDIMFIC) , REP2(GDIMFIC)
Local Char     PRERET(10) , SUFRET(10) , NOMRET(30)
Local Char     FIC_MAIL(GDIMFIC) , FIC_JNT(GDIMFIC) , FIC_TRA(GDIMFIC)
Local Char     ORDSYS(255)(1..2) , EXP_MAIL(80) , PIECE(GDIMFIC)
Local Char     ALPHA(52) , CHIFFRE(10) , FORMULE(255) , VERSION(10) , OS(10)
Local Integer  NBTMP , NBHTP , ENVMEL , MAXCAR , PRODUIT , MAXCARCLI
Local Shortint DIME , DIMKEY
Local Char     MACHINE(GDIMFIC) , FICHIER(GDIMFIC)
DIME = type([L]CHRONO)-10
Local Char     CHRLNK(DIME)
Gosub SET_DIM From AWRK
Local Char     PCETMP(250)(1..DIMJOI) , PCENAM(250)(1..DIMJOI) , PCESUF(10)(1..DIMJOI)
Local Integer  PCEBLB(1..DIMJOI) , PCEERR(1..DIMJOI)
Local Clbfile  TEXTMP(DIMCLB)
Local Char     USRHTP(80)(1..DIMUSR)
Local Integer  USRLNK(1..DIMUSR)
Local Integer  NBNIV , USRNIV(1..DIMUSR) , NIV
Local Char    USR_DEST(GLONAUS)(1..)                  # X3PLAT-1475 Workflow link on representation - new ENVOI_BAIL with representation contxt

MAXCAR    = 250 : # Nbre maxi de caractères dans une ligne pour meladx qui plante si la longueur de ligne dépasse cette limite
MAXCARCLI = 200 : # Nbre maxi de caractères dans une ligne pour Send
ERT = 12
ERN = 0
Onerrgo ERR
If clalev([F:AUS2])=0 : Local File AUTILIS [AUS2] : Endif
If clalev([F:AWS])=0  : Local File AWRKHISSUI [AWS]  : Endif     # X3PLAT-1475 Workflow link
Call GET_OS(adxmac(0),OS) From ORDSYS

# Faut-il envoyer par le serveur de traitement (meladx) ou par le client (Send) ?
# TYPMES  Paramètre de la règle workflow (Indifférent/Serveur/Client)
# GTYPMES Paramètre général (Client/Serveur)

ENVMEL = (GBROWS | GSERVEUR | TYPMES=2 | dim(GTYPMES)<=0 | (TYPMES=1 & GTYPMES=2))

# Pour l'icône retour dans un meladx

PRERET  = "_Msg"
If GBROWS | GSERVEUR | dim(GVERCLI)<0 | GVERCLI=""
 VERSION = "0,1,5,0"
Else
 VERSION = vireblc(GVERCLI,4)
Endif
SUFRET = "adx2"

# Trace des meladx

TRAMEL = (func AFNC.PARAM("TRAMEL","")="2")


# Chargement des pièces jointes de l'objet
# Les pièces jointes BLOB/CLOB sont copiées dans le répertoire temporaire du serveur d'application
# Si la pièce jointe est une trace située sur le client, on copie la trace sur le serveur d'appli

Raz NBTMP , PCETMP , PCEBLB , PCEERR
If OBJJOI<>""
 Gosub CHARGE_PIECE
Endif

# Rajout des pièces jointes de la règle workflow (Pièce à joindre/trace)

For I=1 To NBJOI
 FICHIER = func ASYRSYS._GETFULLPATH(PCEJOI(I))
 Gosub SET_PIECE
 If PIECE=""
  NBTMP += 1
  PCETMP(NBTMP) = FICHIER
  PCEERR(NBTMP) = 20
 Else
  If MACHINE="#" : # Exception : cas de la trace envoyée depuis la lecture trace d'un fichier
   NBTMP += 1
   PCEBLB(NBTMP) = 1
   Call SETNAM(PIECE,PCENAM(NBTMP),PCESUF(NBTMP)) From GOBJTXT
   PCETMP(NBTMP) = filpath(GREPTMP(1),PCENAM(NBTMP),PCESUF(NBTMP))
   Call COPIE(FICHIER,PCETMP(NBTMP),STAT) From ORDSYS
  Else
   NBTMP += 1
   PCETMP(NBTMP) = PIECE
   PCEBLB(NBTMP) = 0
   Call SETNAM(PCETMP(NBTMP),PCENAM(NBTMP),PCESUF(NBTMP)) From GOBJTXT
  Endif
 Endif
Next I

# 1) S'il y a un lien http dans le message, il faut :
# - envoyer le mail à un seul destinataire à la fois
# - mettre à jour le lien http dans le message ou virer la ligne si le destinataire n'a pas le pouvoir
# - mettre à jour la table AWRKHISDES avec la clé de lien générée pour gérer la signature
# 2) La ligne des destinataires et des copies est limitée à MAXCAR pour meladx (<17r.20)
# - Si cette limite est dépassée, le mail sera envoyé plusieurs fois.
# - Pour celà on affecte un niveau à chaque destinataire et il y aura autant d'envois que de niveaux.
# - S'il n'y a pas de destinataire principal (nb de destinataires copie>destinatire principal), le destinataire principal
#   recevra plusieurs mail
Local Char DEST(80)
Raz NBHTP
Gosub VERIF_HTTP
If NBHTP=0
 If ENVMEL
  If func AFNC.PARTSEP(ver$(0),2," ")>="17r.120"
   NIV = 0
   # X3PLAT-1475 Workflow link on representation-- if contxt contains [L]DEST to be resolved in representations
   If CONTXT_DEST
     [L]DEST = USR_DEST(1)
   Endif
   # X3PLAT-1475 Workflow link on representation-
   Gosub ENVOI_SERVEUR
  Else
   # Nombre de destinataires limités ~9
   Gosub NIV_DEST
   For NIV=1 To NBNIV
    # X3PLAT-1475 Workflow link on representation-- if contxt contains [L]DEST to be resolved in representations
    If CONTXT_DEST
      [L]DEST = USR_DEST(NIV)
    Endif
    # X3PLAT-1475 Workflow link on representation
    [L]DEST = USR_DEST(NIV)
    Gosub ENVOI_SERVEUR
   Next NIV
  Endif
Else
  # X3PLAT-1475 Workflow link on representation-- if contxt contains [L]DEST to be resolved in representations
  If CONTXT_DEST
    [L]DEST = USR_DEST(1)
  Endif
  # X3PLAT-1475 Workflow link on representation
  Gosub ENVOI_CLIENT
 Endif
Else
 Local Mask AWAX [AWAY]
 [M:AWAY]TEXTE = TEXCLB
 For U=1 To NBHTP
  USR_NB = 1
  USR_ENVOI(USR_NB) = 2
  USR_EMAIL(USR_NB) = USRHTP(U)
  Gosub TRT_HTTP
  # X3PLAT-1475 Workflow link on representation-- if contxt contains [L]DEST to be resolved in representations
  If CONTXT_DEST
    [L]DEST = USR_DEST(1)
  Endif
  # X3PLAT-1475 Workflow link on representation
  If ENVMEL
   NIV = 0
   Gosub ENVOI_SERVEUR
  Else
   Gosub ENVOI_CLIENT
  Endif
 Next U
 Close Local Mask [AWAY]
Endif

# Et on efface les pièces jointes clob et blob du répertoire temporaire

OK = 0
For I=1 To NBTMP
 If PCEBLB(I)<>0 : OK = 1 : Break : Endif
Next I
If OK
 For I=1 To NBTMP
  If PCETMP(I)<>"" & PCEBLB(I)<>0
   Call EFFACE(PCETMP(I),STAT) From ORDSYS
  Endif
 Next I
Endif

Onerrgo
End

#----------------------------------------------------------#
$ENVOI_CLIENT

Raz MESSAGE , NBMES

# Destinataire principal
Raz NBSP
For I=1 To USR_NB
 If USR_ENVOI(I)=2
  NBMES += 1
  NBSP += 1
  MESSAGE(NBMES) = func PARNEWCLI("__TO")+"="+chr$(NBSP)
  If NBSP>1
   MESSAGE(NBMES) += ";"
  Endif
  MESSAGE(NBMES) += USR_EMAIL(I)
 Endif
Next I

# Copie
Raz NBSP
For I=1 To USR_NB
 If USR_ENVOI(I)=3
  NBMES += 1
  NBSP += 1
  MESSAGE(NBMES) = func PARNEWCLI("__CC")+"="+chr$(NBSP)
  If NBSP>1
   MESSAGE(NBMES) += ";"
  Endif
  MESSAGE(NBMES) += USR_EMAIL(I)
 Endif
Next I

# Objet (la longueur du sujet est limité à 63 caractères à cause de Mappi)
NBMES += 1
MESSAGE(NBMES) = func PARNEWCLI("__SUJET")+"="+chr$(1)+TEXOBJ

# Texte
Local Char WCHTMP(255),CHDEC(MAXCARCLI) (1..MAXCARCLI)
Local Integer IDEC,TROUVE
Raz NBSP , NBCR , NBTEX
TEXTMP = TEXCLB
TEXTMP = ctrans(TEXTMP,chr$(13),"") : # On vire les chr$(13)
MAXTXT = len(func PARNEWCLI("__NOTE"))+5

While TEXTMP<>""
 CHAINE = left$(TEXTMP,MAXCARCLI-MAXTXT)
 TEXTMP = right$(TEXTMP,MAXCARCLI-MAXTXT+1)
 Gosub DECOUPE_CH2
 For I=1 To IDEC
  NBMES += 1
  NBSP += 1
  NBCR += len(CHDEC(I))
  If GRELCLI<"15c.015" & (NBSP>=10 or NBCR>1300) : # C'était les limites de l'instruction Send
   MESSAGE(NBMES) = func PARNEWCLI("__NOTE")+"="+chr$(NBSP)+mess(20,75,1) : # Texte du message tronqué
   Break
  Endif
  MESSAGE(NBMES) = func PARNEWCLI("__NOTE")+"="+chr$(NBSP+20)+CHDEC(I)
 Next
Wend

# Accusé de réception
If REQREC=2
 NBMES += 1
 MESSAGE(NBMES) = "__ACKNOWLEDGE="+chr$(1)+"1"
Endif

# Pièces jointes
Raz NBSP
For I=1 To NBTMP
 If PCEERR(I)=0
  If NBSP>1 : Break : Endif : # Avec Send, on ne peut envoyer qu'une seule pièce jointe
  NBMES += 1
  NBSP += 1
  MESSAGE(NBMES) = "__JOINT="+chr$(NBSP)
  If NBSP>1
   MESSAGE(NBMES) += ";"
  Endif
  MESSAGE(NBMES) += PCETMP(I)
 Endif
Next I

# Contexte
NBMES += 1
MESSAGE(NBMES) = "__CONTXT="+chr$(1)+CONTXT

# Point d'entrée permettant d'utiliser un autre outil pour l'envoi du mail (pour crypter le message ou générer du xml, par exemple)
GPE = 0
GPOINT = "SENDMES" : Gosub ENTREE From EXEFNC
If GPE : Return : Endif

# Envoi par le client
Send GSERMES With MESSAGE(1..NBMES)

# Trace envoi message
If ERD
 Call ECR_TRACE("\"+mess(59,75,1),0) From GESECRAN : # Envoi du message
 Call ECR_TRACE("- "+mess(21,151,1)-":|"-GSERMES,0) From GESECRAN : # Serveur
 Call ECR_TRACE("- "+mess(31,124,1),0) From GESECRAN : # Détail
 For I=1 To NBMES
  Call ECR_TRACE("  |"+MESSAGE(I),0) From GESECRAN
 Next I
Endif

Return

#----------------------------------------------------------#
$DECOUPE_CH2
Local Integer J
Raz IDEC
WCHTMP=CHAINE
While WCHTMP<>""
 IDEC += 1
 J = instr(1,WCHTMP,chr$(10))
 If J
  CHDEC(IDEC) = left$(WCHTMP,J-1)
  While right$(CHDEC(IDEC),len(CHDEC(IDEC)))=" "
    CHDEC(IDEC)=left$( CHDEC(IDEC) ,len( CHDEC(IDEC) )-1)
  Wend
  CHDEC(IDEC)=CHDEC(IDEC)+chr$(10)
  If TROUVE
     IDEC += 1
     CHDEC(IDEC)=chr$(10)
      TROUVE=0
  Endif
  WCHTMP = right$(WCHTMP,J+len(chr$(10)))
 Else
  CHDEC(IDEC) = WCHTMP
  WCHTMP = ""
  TROUVE=1
 Endif
Wend
Return
#----------------------------------------------------------#
Funprog PARNEWCLI(OLD)
Value Char OLD
If GRELCLI>="15c012"
 Case OLD
  When "__TO"    : End "_EmailToList"
  When "__CC"    : End "_EmailCCList"
  When "__SUJET" : End "_EmailSubject"
  When "__NOTE"  : End "_EmailMessage"
 Endcase
Endif
End OLD

#----------------------------------------------------------#
# Le texte de l'objet doit être ascii pour meladx
#----------------------------------------------------------#

Funprog OBJET(TEXTE)
Value Char TEXTE
If func AFNC.PARTSEP(ver$(0),2," ")<="16r.219" : # version v6
 TEXTE = ctrans(TEXTE,chr$(8364),"E") : # Remplace le symbole Euro par E
 TEXTE = ctrans(TEXTE) : # Pour éliminer les accents
Endif
End TEXTE

#----------------------------------------------------------#
$ENVOI_SERVEUR

NOMRET = CHRONO+string$(NBHTP>1,"-"+num$(U))+string$(NBNIV>1,"-"+num$(NIV))

FIC_MAIL = filpath("tmp","M"+NOMRET,"txt",0)
Openo FIC_MAIL,0 Using [MES]

Iomode adxifs "" Using [MES]
Iomode adxirs chr$(10) Using [MES]
Iomode adxium GUTF8 Using [MES]

If [L]USER<>""
 Read [AUS2]CODUSR = [L]USER
 EXP_MAIL = [F:AUS2]ADDEML
 If EXP_MAIL=""
  EXP_MAIL = GNOMUSER
 Endif
Elsif [L]MAIL<>""
 EXP_MAIL = [L]MAIL
Else
 EXP_MAIL = GSUPER
Endif

# Point d'entrée
GPOINT = "EMAIL" : Gosub ENTREE From EXEFNC

# Accusé de réception
If REQREC=2 & instr(1,EXP_MAIL,"@")>0 & func AFNC.PARTSEP(ver$(0),2," ")>="16r.114"
 Wrseq "Disposition-Notification-To: ";ctrans(EXP_MAIL) Using [MES]
Endif

# Importance du message
If func AFNC.PARTSEP(ver$(0),2," ")>="16r.114"
 Case REQIMP
  When 1 : Wrseq "Importance: Low" Using [MES]
  When 3 : Wrseq "Importance: High" Using [MES]
 Endcase
Endif

# Expéditeur
Wrseq "From: ";ctrans(EXP_MAIL) Using [MES]

# Destinataire principal
J = 0
For I=1 To USR_NB
 If USR_ENVOI(I)=2 & (NIV=0 or USRNIV(I)=NIV)
  J += 1
  If J=1
   Wrseq "To: "; Using [MES]
  Else
   Wrseq ";"; Using [MES]
  Endif
  Wrseq ctrans(USR_EMAIL(I)); Using [MES]
 Endif
Next I
Wrseq Using [MES]

# Copie
J = 0
For I=1 To USR_NB
 If USR_ENVOI(I)=3 & (NIV=0 or USRNIV(I)=NIV)
  J += 1
  If J=1
   Wrseq "Cc: "; Using [MES]
  Else
   Wrseq ";"; Using [MES]
  Endif
  Wrseq ctrans(USR_EMAIL(I)); Using [MES]
 Endif
Next I
If J>0 : Wrseq Using [MES] : Endif

# Objet
Wrseq "Subject:"-func OBJET(TEXOBJ) Using [MES]
Wrseq Using [MES]

# Texte
TEXTMP = TEXCLB
TEXTMP = ctrans(TEXTMP,chr$(13),"") : # On vire les chr$(13)
While TEXTMP<>""
 K = instr(1,TEXTMP,chr$(10))
 If K=0
  K = len(TEXTMP)
 Endif
 If K<MAXCAR : # La longueur d'une ligne ne doit pas dépasser MAXCAR caractères
  Call WR_TEX(left$(TEXTMP,K))
  TEXTMP = right$(TEXTMP,K+1)
 Else
  # On va tronquer sans couper un mot
  K = 0
  For J=MAXCAR To 1 Step -1
   If mid$(TEXTMP,J,1)=" "
    K = J : Break
   Endif
  Next J
  If !K : # On est obligé de tronquer
   K = MAXCAR-1
  Endif
  Call WR_TEX(left$(TEXTMP,K)+chr$(10)) : # Rajout d'un LF
  TEXTMP = right$(TEXTMP,K+1)
 Endif
Wend
Wrseq Using [MES]

# Pour être sûr d'écrire la suite sur une nouvelle ligne
Wrseq Using [MES]

#X3PLAT-1475 Workflow link on representation - start
#If CONTXT<>"" and (dim(GCLOUD)<0 or toupper(GCLOUD)<>"AMAZON")
# CHAINE = mess(139,127,1)+" " : # Pour visualiser la fiche d'origine, cliquez sur
# Call URLWKF(FICHIER,CONTXT)
# Gosub WR_FIC
# Wrseq Using [MES]
#Endif
#X3PLAT-1475 Workflow link on representation - end - change TRT_CONTXT to manage all return contexts
Gosub SET_CONTXT


# Pièces jointes
For I=1 To NBTMP
 If PCEERR(I)=0 & PCETMP(I)<>""
  If dim(GCLOUD)>0 & toupper(GCLOUD)="AMAZON" : # Demande 93703 CC 14/10/2013 - Modif pour fonctionnement sur Amazon
   Case toupper(PCESUF(I))
    When "PDF","FAC","INV"         : CHAINE = '# Application/pdf ; name="'+PCENAM(I)+"."+PCESUF(I)+'"'
    When "TRA","EXP","TST","TXT"   : CHAINE = '# text/plain ; name="'+PCENAM(I)+"."+PCESUF(I)+'"'
    When "XLS"                     : CHAINE = '# Application/x-msexcel ; name="'+PCENAM(I)+"."+PCESUF(I)+'"'
    When "DOC","COD"               : CHAINE = '# Application/x-msword ; name="'+PCENAM(I)+"."+PCESUF(I)+'"'
    When "PPT"                     : CHAINE = '# application/x-mspowerpoint ; name="'+PCENAM(I)+"."+PCESUF(I)+'"'
    When "XML"                     : CHAINE = '# Application/xml ; name="'+PCENAM(I)+"."+PCESUF(I)+'"'
    When "GIF"                     : CHAINE = '# image/gif ; name="'+PCENAM(I)+"."+PCESUF(I)+'"'
    When "BMP"                     : CHAINE = '# image/bmp ; name="'+PCENAM(I)+"."+PCESUF(I)+'"'
    When "JPG"                     : CHAINE = '# image/jpeg ; name="'+PCENAM(I)+"."+PCESUF(I)+'"'
    When "RTF"                     : CHAINE = '# text/rtf ; name="'+PCENAM(I)+"."+PCESUF(I)+'"'
    When "HTP"                     : CHAINE = '# application/xhtml+xml ; name="'+PCENAM(I)+"."+PCESUF(I)+'"'
    When Default                   : CHAINE = '# Application/octet-stream ; name="'+PCENAM(I)+"."+PCESUF(I)+'"' : # PIC, DIV, MPG cf 902
   Endcase
  Else
   CHAINE = '# Application/others ; name="'+PCENAM(I)+"."+PCESUF(I)+'"'
  Endif
  CHAINE += '['+PCENAM(I)+"."+PCESUF(I)+'] ' : # Pour Lotus Notes
  FICHIER = '"'+PCETMP(I)+'"'
  If ctrans(PCETMP(I))<>PCETMP(I)
   PCEERR(I) = 1 : # Accents
  Endif
  If len(CHAINE+FICHIER)>MAXCAR
   PCEERR(I) += 10 : # Trop long
  Endif
  If PCEERR(I)=0
   Wrseq CHAINE+FICHIER Using [MES]
  Endif
 Endif
Next I

Openo Using [MES]

If sum(PCEERR)<>0
 # Les pièces jointes suivantes ne peuvent pas être jointes au workflow
 If GTRACE="" & !GSERVEUR
  TRAPCE = 1
  Call OUVRE_TRACE(mess(196,75,1)) From LECFIC
 Else
  TRAPCE = 0
  Call ECR_TRACE("\"+mess(196,75,1),-1) From GESECRAN
 Endif
 If GTRACE<>""
  For I=1 To NBTMP
   Case PCEERR(I)
    When 1  : CHAINE = mess(199,75,1)                              : # Le nom du fichier contient des accents
    When 10 : CHAINE = func AFNC.MES1(mess(197,75,1),num$(MAXCAR)) : # Ligne trop longue (>$1$)
    When 11 : CHAINE = func AFNC.MES1(mess(198,75,1),num$(MAXCAR)) : # Ligne trop longue (>$1$) et le nom du fichier contient des accents
    When 20 : CHAINE = mess(200,75,1)                              : # Pièce jointe inaccessible
   Endcase
   If PCEERR(I)<>0
    Call ECR_TRACE("|"+PCETMP(I)-":"-CHAINE,1) From GESECRAN
   Endif
  Next I
 Endif
 If TRAPCE
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
 Endif
Endif

If filinfo(FIC_MAIL,0)<=0
 If ERD
  Call ECR_TRACE(mess(184,124,1)-"\|"+FIC_MAIL,1) From GESECRAN : # Impossible de créer le fichier
 Endif
 Return
Endif

# Point d'entrée permettant d'utiliser un autre outil pour l'envoi du mail (pour crypter le message ou générer du xml, par exemple)
GPE = 0
GPOINT = "SENDMES" : Gosub ENTREE From EXEFNC
If GPE : Return : Endif

# Ordre système
ORDSYS(1) = "meladx"
If ERD or TRAMEL
 ORDSYS(1) -= "-v" : # Trace connection
Endif
If GSERMES<>""
 ORDSYS(1) -= "-s"-GSERMES
Endif
If EXP_MAIL<>"" & instr(1,EXP_MAIL,"@")>0
 ORDSYS(1) -= "-r"-EXP_MAIL
Endif

Call MACHINE(FIC_MAIL,MACHINE,FICHIER) From ORDSYS
ORDSYS(1) -= "<"+FICHIER

FIC_TRA = filpath("tmp","M"+NOMRET,"tra",0)
ORDSYS(2) = FIC_TRA

Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

# Trace envoi message
If ERD
 Call ECR_TRACE("\"+mess(59,75,1),0) From GESECRAN : # Envoi du message
 Call ECR_TRACE("- "+mess(176,100,1)-":|"-ORDSYS,0) From GESECRAN : # Ordre système
 Call ECR_TRACE("- "+mess(31,124,1),0) From GESECRAN : # Détail
 Openi FIC_MAIL Using [TTT]
 Iomode adxifs "" Using [TTT]
 Iomode adxirs chr$(10) Using [TTT]
 Iomode adxium GUTF8 Using [TTT]
 Rdseq CHAINE Using [TTT]
 While !fstat
  Call ECR_TRACE("  |"+CHAINE,0) From GESECRAN
  Rdseq CHAINE Using [TTT]
 Wend
 Openi Using [TTT]
 If filinfo(FIC_TRA,7)>0
  Call ECR_TRACE("\- "+mess(169,139,1),0) From GESECRAN : # Trace de connection
  Openi FIC_TRA Using [TTT]
  Iomode adxifs "" Using [TTT]
  Iomode adxirs chr$(10) Using [TTT]
  Iomode adxium GUTF8 Using [TTT]
  Rdseq CHAINE Using [TTT]
  While !fstat
   Call ECR_TRACE("  |"+CHAINE,0) From GESECRAN
   Rdseq CHAINE Using [TTT]
  Wend
  Openi Using [TTT]
 Endif
Endif

Return

#------------------------------#
Subprog WR_TEX(CHAINE)
Value Char CHAINE
Local Integer M , N
M = instr(1,CHAINE,"#")
While M
 N = 1
 While mid$(CHAINE,M+N,1)="#"
  N += 1
 Wend
 # mb 12.12.13 bug 90725 Un "#" en début de ligne de texte plante meladx
 CHAINE = left$(CHAINE,M-1)+" "+right$(CHAINE,M)
 Break
Wend
Wrseq CHAINE; Using [MES]
End

#-----------------------------------#
$WR_FIC
If len(CHAINE+FICHIER)>MAXCAR
 Wrseq CHAINE Using [MES]
 Wrseq FICHIER Using [MES]
Else
 Wrseq CHAINE+FICHIER Using [MES]
Endif
Return

#----------------------------#
$NIV_DEST
Raz CHAINE , NIV , USRNIV
For I=1 To USR_NB
 If USR_ENVOI(I)=2
  If len(CHAINE)+len(USR_EMAIL(I))+3>MAXCAR
   CHAINE = ""
   NIV += 1
  Endif
  CHAINE += USR_EMAIL(I)+"   "
  USRNIV(I) = NIV+1
 Endif
Next I
Raz CHAINE , NIV
For I=1 To USR_NB
 If USR_ENVOI(I)=3
  If len(CHAINE)+len(USR_EMAIL(I))+3>MAXCAR
   CHAINE = ""
   NIV += 1
  Endif
  CHAINE += USR_EMAIL(I)+"   "
  USRNIV(I) = NIV+1
 Endif
Next I
NBNIV = max(USRNIV)
# Rajout de l'utilisateur principal dans les niveaux qui n'en ont pas
For NIV=1 To NBNIV
 K = 0
 For I=1 To USR_NB
  If USR_ENVOI(I)=2 & USRNIV(I)=NIV
   K = 1 : Break
  Endif
 Next I
 If !K
  K = find(2,USR_ENVOI)
  If K
   USR_NB += 1
   USR_ENVOI(USR_NB) = 2
   USR_EMAIL(USR_NB) = USR_EMAIL(K)
   USRNIV(USR_NB) = NIV
  Endif
 Endif
Next NIV
Return

#-------------------------------------------#
$CHARGE_PIECE

If clalev([F:AOX])=0  : Local File AOBJTXT    [AOX]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV    [ADI]  : Endif
If clalev([F:ABB])=0  : Local File ABLOB      [ABB]  : Endif
If clalev([F:ACB])=0  : Local File ACLOB      [ACB]  : Endif

Raz NBTMP , PCETMP , PCEBLB , PCEERR
Gosub SET_TYPX3 From GOBJTXT
Raz CLE1 , CLE2 , NBCLE
K = instr(1,CLEOBJ,"~")
If K
 CLE1 = left$(CLEOBJ,K-1)
 CHAINE = right$(CLEOBJ,K+1)
 While CHAINE<>""
  K = instr(1,CHAINE,"~")
  If K
   CLE2(NBCLE) = left$(CHAINE,K-1)
   CHAINE = right$(CHAINE,K+1)
   NBCLE += 1
  Else
   CLE2(NBCLE) = CHAINE
   CHAINE = ""
  Endif
 Wend
Else
 CLE1 = CLEOBJ
Endif
Call SETCLE(OBJJOI,IDENT,CLE2) From GOBJTXT
For [AOX]AOX0 Where ABREV=OBJJOI & IDENT1=CLE1 & IDENT2=IDENT
 OK  = (TYPJOI="" | TYPJOI=[F:AOX]TYPDOC)
 OK *= (CATJOI=0 | CATJOI=[F:AOX]CAT)
 If OK
  If find([F:AOX]TYPDOC,CLOBX3,CLOBXT)
   Read [ADI]CODE = 902;[F:AOX]TYPDOC
   Gosub SET_PCE From GOBJTXT
   Read [ACB]ACB0 = [L]CBLOB+[F:AOX]ABREV;[F:AOX]IDENT1;[F:AOX]IDENT2;[F:AOX]IDENT3
   If !fstat
    Gosub CHARGE_FROM_CLOB_TABLE
   Else
    Gosub CHARGE_FROM_ATTACHMENT_DIRECTORY
   Endif
  Elsif find([F:AOX]TYPDOC,BLOBX3)
   Read [ADI]CODE = 902;[F:AOX]TYPDOC
   Gosub SET_PCE From GOBJTXT
   Read [ABB]ABB0 = [L]CBLOB+[F:AOX]ABREV;[F:AOX]IDENT1;[F:AOX]IDENT2;[F:AOX]IDENT3
   If !fstat
    Gosub CHARGE_FROM_BLOB_TABLE
   Else
    Gosub CHARGE_FROM_ATTACHMENT_DIRECTORY
   Endif
  Else
    Gosub CHARGE_FROM_ATTACHMENT_DIRECTORY
  Endif
 Endif
Next AOX
Return

$CHARGE_FROM_CLOB_TABLE
  FICHIER = filpath(GREPTMP(1),[F:AOX]NAM,[F:ADI]A1)
  Gosub SET_PIECE
  If PIECE=""
    NBTMP += 1
    PCETMP(NBTMP) = FICHIER
    PCEERR(NBTMP) = 20
  Else
    Openo PIECE,0 Using [BLB_]
    Iomode adxirs "" Using [BLB_]
    Iomode adxifs "" Using [BLB_]
    Iomode adxium GUTF8 Using [BLB_]
    Wrseq [F:ACB]CLOB Using [BLB_]
    Openo Using [BLB_]
    NBTMP += 1
    PCETMP(NBTMP) = PIECE
    PCEBLB(NBTMP) = 1
    PCENAM(NBTMP) = [F:AOX]NAM
    PCESUF(NBTMP) = [F:ADI]A1
  Endif
Return

$CHARGE_FROM_BLOB_TABLE
  FICHIER = filpath(GREPTMP(1),[F:AOX]NAM,[F:ADI]A1)
  Gosub SET_PIECE
  If PIECE=""
    NBTMP += 1
    PCETMP(NBTMP) = FICHIER
    PCEERR(NBTMP) = 20
  Else
    Openo PIECE,0 Using [BLB_]
    Iomode adxirs "" Using [BLB_]
    Iomode adxifs "" Using [BLB_]
    Iomode adxium GUTF8 Using [BLB_]
    Putseq 1,[F:ABB]BLOB Using [BLB_]
    Openo Using [BLB_]
    NBTMP += 1
    PCETMP(NBTMP) = PIECE
    PCEBLB(NBTMP) = 1
    PCENAM(NBTMP) = [F:AOX]NAM
    PCESUF(NBTMP) = [F:ADI]A1
  Endif
Return

$CHARGE_FROM_ATTACHMENT_DIRECTORY
  If left$([F:AOX]NAM,1)="%"
    Call PARAM("","DIRPCE",FICHIER) From ADOVAL
    If FICHIER=""
      Call PARAM("","DIRPCE1",REP1) From ADOVAL
      Call PARAM("","DIRPCE2",REP2) From ADOVAL
      FICHIER = REP1+REP2
    Endif
    If left$(FICHIER,1)="%"
      FICHIER = filpath(FICHIER,"","",0)
    Endif
    If FICHIER=""
      If OS="unix"
        FICHIER = "/"
      Else
        FICHIER = "\"
      Endif
    Elsif !find(right$(FICHIER,len(FICHIER)),"/","\") & !find(mid$([F:AOX]NAM,2,1),"/","\")
      If instr(1,FICHIER,"/")
        FICHIER += "/"
      Else
        FICHIER += "\"
      Endif
    Endif
    FICHIER += right$([F:AOX]NAM,2)
  Else
    FICHIER = func ASYRSYS._GETFULLPATH([F:AOX]NAM)
  Endif
  J = max(instr(1,FICHIER,"/"),instr(1,FICHIER,"\"))
  If J=0
    FICHIER = filpath("TXT",FICHIER,"txt")
  Endif
  Gosub SET_PIECE
  If PIECE<>"" & MACHINE<>"#" : # Les pièces jointes situées sur le client ne sont pas prises en compte
    NBTMP += 1
    PCETMP(NBTMP) = PIECE
    PCEBLB(NBTMP) = 0
    Call SETNAM(PCETMP(NBTMP),PCENAM(NBTMP),PCESUF(NBTMP)) From GOBJTXT
  Else
    NBTMP += 1
    PCETMP(NBTMP) = FICHIER
    PCEERR(NBTMP) = 20
  Endif
Return

#-----------------------------------------------------------------------------------------------------#
# Il faut que les pièces jointes soient accessibles par le serveur (de traitement ou de messagerie)
#-----------------------------------------------------------------------------------------------------#

$SET_PIECE
Call MACHINE(FICHIER,MACHINE,PIECE) From ORDSYS
If NBTMP>=dim(PCETMP)
 PIECE = ""
Elsif !ENVMEL & instr(1,PIECE,"/")
 PIECE = ""
Elsif !ENVMEL & MACHINE<>""
 PIECE = ""
Elsif ENVMEL & MACHINE="#" & (!GBROWS or GADXLOC) & !GSERVEUR
 # Exception : cas de la trace envoyée depuis la lecture trace d'un fichier
Elsif ENVMEL & GOS(0)="unix" & instr(1,PIECE,"\")
 PIECE = ""
Elsif ENVMEL & GOS(0)="dos" & instr(1,PIECE,"/")
 PIECE = ""
Elsif MACHINE<>"" & !find(MACHINE,adxmac(0),adxmac(-1))
 PIECE = ""
Endif
If ENVMEL & GOS(0)="dos"
 Call SETNAM(PIECE,CHAINE,EXT) From GOBJTXT
 If ctrans(CHAINE)<>CHAINE : # Les accents dans le nom du document plantent meladx
  PIECE = ""
 Endif
Endif
Return

#----------------------------------------------------------------------------------------------------#
# S'il y a un lien http dans le message, il faut envoyer autant de mails qu'il y a de destinataires
#----------------------------------------------------------------------------------------------------#

$VERIF_HTTP
Gosub SET_SEP From SUBAWA
OK = instr(1,TEXCLB,SEP+"SIG/")
If OK & !ERN
 If clalev([F:AWO])=0  : Local File AWRKHISDES [AWO]  : Endif
 DIMKEY = type([F:AWO]LNKHTP)-10
 Local Char LNKKEY(DIMKEY)
 ALPHA   = sigma(0,25,chr$(65+indcum))+sigma(0,25,chr$(97+indcum))
 CHIFFRE = sigma(0,9,chr$(48+indcum))
 NBHTP = 0
 For I=1 To USR_NB
  If USR_ENVOI(I)=2 : # Principal
   NBHTP += 1
   USRHTP(NBHTP) = USR_EMAIL(I)
   USRLNK(NBHTP) = USR_SUIVI(I)
  Endif
 Next I
 For I=1 To USR_NB
  If USR_ENVOI(I)=3 : # Copie
   NBHTP += 1
   USRHTP(NBHTP) = USR_EMAIL(I)
   USRLNK(NBHTP) = USR_SUIVI(I)
  Endif
Next I
Endif
# X3PLAT-1475 Workflow link - set the user detinations

If CONTXT_DEST
  Raz USR_DEST
  For I=1 To USR_NB
    Read [F:AWS]AWS3=[L]CHRONO;USR_EMAIL(I)
    If !fstat
     USR_DEST(I)=[F:AWS]DEST
    Else
     USR_DEST(I)=USR_CODE(I)
    Endif
  Next
Endif
Return

#-------------------------------------------#
$TRT_HTTP
Local Char URLSIGN(250),URLPARAM(250)

# Texte original
TEXCLB = [M:AWAY]TEXTE

# Remplacement du SIG/ par le lien http
Raz CHRLNK , LNKKEY
I = 1
While TEXCLB<>""
 D = instr(I,TEXCLB,SEP)
 If D
  F = instr(D+1,TEXCLB,SEP)
  If !F
   ERM = mess(116,75,1) : # Séparateurs mal définis dans le texte
   ERN = 1 : Gosub TRACE_ERR : Break
  Endif
  FORMULE = format$("Kv2:255X",seg$(TEXCLB,D+1,F-1))
  TEXTMP = ""
  # SIG/code action/Chrono/Texte à mettre devant le lien http
  If toupper(left$(FORMULE,4))="SIG/"
   K = instr(1,FORMULE,"/")
   L = instr(K+1,FORMULE,"/")
   M = instr(L+1,FORMULE,"/")
   If K & L & M
    If CHRLNK<>seg$(FORMULE,L+1,M-1)
     CHRLNK = seg$(FORMULE,L+1,M-1)
     Gosub SETLNK
    Endif
    If LNKKEY<>""
     TEXTMP = right$(FORMULE,M+1)
     #If dim(GFUSION)>0 & GFUSION
      CHAINE = baseUrl
      If CHAINE=""
       CHAINE = func AFNC.PARAM("AWRKSYRA","")
      Endif
      # replace trans by sdata
      T = instr(1,CHAINE,"/trans/")
      If T
       CHAINE = left$(CHAINE,T-1) + "/sdata/"+ right$(CHAINE,T+len("/trans/"))
      Endif
##      SAM : 102973
##      T = instr(1,CHAINE,"/sdata/")
##      URLSIGN = left$(CHAINE,T-1)+ "syracuse-main/html/main.html?url="
##      URLPARAM = right$(CHAINE,T)
##      URLPARAM +=  "/$service/sign"
##      URLPARAM += "?chrono="+CHRLNK+"-"+toupper(seg$(FORMULE,K+1,L-1))
##      URLPARAM += "&key="+LNKKEY
##      URLPARAM += "&language="+GLANGUE
##      URLPARAM += "&directory="+GINSTID+nomap
##      URLSIGN += func ASYRJSO.ENCODE_URL(URLPARAM)
      URLSIGN = CHAINE
      URLSIGN +=  "/$service/sign"
      URLSIGN += "?chrono="+CHRLNK+"-"+toupper(seg$(FORMULE,K+1,L-1))
      URLSIGN += "&key="+LNKKEY
      URLSIGN += "&language="+GLANGUE
      URLSIGN += "&directory="+GINSTID+nomap
      Append TEXTMP," "
      Append TEXTMP,URLSIGN
    # Else
      #Append TEXTMP," "+func SERVEUR_HTTP+"/action.jsp"
      #Append TEXTMP,"?C="+CHRLNK+"-"+toupper(seg$(FORMULE,K+1,L-1))
      #Append TEXTMP,"&K="+LNKKEY
      #Append TEXTMP,"&L="+GLANGUE
      #Append TEXTMP,"&D="+GINSTID+nomap
     #Endif
    Endif
   Endif
  Endif
  TEXCLB = left$(TEXCLB,D-1)+TEXTMP+right$(TEXCLB,F+1)
  I = D+len(TEXTMP)+1
 Else
  Break
 Endif
Wend

Return

#----------------------#
Funprog SERVEUR_HTTP
Local Char    HTTP(10) , CAR(1) , SERV(250)
Local Char    PRE(10)(1..2)
Local Integer I , K
PRE(1) = "http://"
PRE(2) = "https://"
HTTP = ""
SERV = ""
For I=1 To dim(PRE)
 K = instr(1,tolower(GWRKRMTHTT),PRE(I))
 If K
  SERV = GWRKRMTHTT
  Break
 Endif
Next I
If SERV=""
 SERV = PRE(1)+GWRKRMTHTT
Endif
End SERV

#-------------#
$VERROU
Lock =SYMBOLE With lockwait=[S]lockwait
If !fstat
 VERROU = 1
Else
 GLOCK = "%"+SYMBOLE
 Call ROLL From GLOCK
 If GROLL
  VERROU = 0
 Else
  Goto VERROU
 Endif
Endif
Return

#-------------------------------------------------------------------------------------------------#
# Génération d'une clé par chrono avec un lien http de signature dans le texte
# Cette clé unique servira plus tard à identifier l'utilisateur qui a cliqué sur le lien
#-------------------------------------------------------------------------------------------------#

$SETLNK
If USRLNK(U)<>3 : # Signature avec pouvoir
 LNKKEY = ""
Else
 Look [AWO]AWO0 = CHRLNK;USRHTP(U)
 If fstat
  LNKKEY = ""
 Else
  Call DEBTRANS From GLOCK
  SYMBOLE = "AWO"
  Gosub VERROU
  If !VERROU
   LNKKEY = ""
  Else
   LNKKEY = sigma(1,DIMKEY,mid$(ALPHA+CHIFFRE,int(rnd(len(ALPHA+CHIFFRE))+1),1))
   Look [AWO]AWO1(1) = LNKKEY
   While !fstat
    LNKKEY = sigma(1,DIMKEY,mid$(ALPHA+CHIFFRE,int(rnd(len(ALPHA+CHIFFRE))+1),1))
    Look [AWO]AWO1(1) = LNKKEY
   Wend
   If !adxlog
    Call DEBTRANS From GLOCK
    Gosub TR5 : # Mise à jour lien http
   Else
    Gosub MAJ_DEST
   Endif
   Unlock =SYMBOLE
  Endif
 Endif
Endif
Return

#---------------------------#
$TR5
Trbegin [AWO]
 Gosub MAJ_DEST
 If GOK=-1 : Gosub ROLL_TR5
 Elsif GOK=0 : Goto AB_TR5
 Endif
Commit
Return

$AB_TR5
Rollback
Return

$ROLL_TR5
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR5 : Endif

#---------------------------#
$MAJ_DEST
Readlock [AWO]AWO0 = CHRLNK;USRHTP(U)
If fstat=1
 GOK=-1 : GLOCK="$AWRKHISDES" : Return
Elsif fstat
 GOK=0 : Call FSTA("AWO") From GLOCK : Return
Endif
# Pour essayer de retrouver le code utilisateur
If [F:AWO]USER=""
 For [AUS2] Where ADDEML=USRHTP(U)
  [F:AWO]USER = [F:AUS2]USR : Break
 Next AUS2
Endif
[F:AWO]LNKHTP = LNKKEY
Rewrite [AWO]
If fstat
 GOK=0 : Call FSTA("AWO") From GLOCK : Return
Endif
Return

#--------------------#
$ERR
ERN = errn
ERM = "|"+errp-"("+num$(errl)+")"-mess(6,123,1)-num$(ERN)-":"-errmes$(ERN)-errm+"|"
Gosub TRACE_ERR
Resume

#--------------------#
$TRACE_ERR
If ERD
 Case ERT
  When 1  : ERM = mess(56,123,1) +"\"+ERM : # Texte ligne
  When 2  : ERM = mess(55,75,1)  +"\"+ERM : # Règle workflow
  When 3  : ERM = mess(60,75,1)  +"\"+ERM : # Conditions
  When 4  : ERM = mess(27,115,1) +"\"+ERM : # Action
  When 5  : ERM = mess(26,75,1)  +"\"+ERM : # Destinataires
  When 6  : ERM = mess(28,123,1) +"\"+ERM : # Texte
  When 7  : ERM = mess(118,124,1)+"\"+ERM : # Pièces jointes
  When 8  : ERM = mess(57,75,1)  +"\"+ERM : # Contexte retour
  When 9  : ERM = mess(61,117,1) +"\"+ERM : # Suivi
  When 10 : ERM = mess(58,75,1)  +"\"+ERM : # Compteur groupe
  When 11 : ERM = mess(77,105,1) +"\"+ERM : # No Chrono
  When 12 : ERM = mess(59,75,1)  +"\"+ERM : # Envoi du message
  When 13 : ERM = mess(79,75,1)  +"\"+ERM : # Environnement signature
  When 14 : ERM = mess(148,75,1) +"\"+ERM : # Environnement workflow
 Endcase
 If dim([L]TYPEVT)>0
  ERM += "\"+mess(6,123,1)-mess(1,75,1)-mess([L]TYPEVT,988,1)-[L]CODEVT-":"-[F:AWA]CODE : # Erreur/Workflow
  If FORMULE<>""
   ERM += "\"+mess(65,106,1)-":"-FORMULE : # Erreur en évaluation de la formule
  Endif
 Endif
 Call ECR_TRACE(ERM,ERN) From GESECRAN
 If ERN<>0 : GOK = 0 : Endif
Endif
Return

# ---------------------------------------------------------------------------------------------

Subprog URLWKF_V6(URLW,WKFG,SERW1)
Variable Char URLW
Value Char WKFG
Value Char SERW1

#  Construit une URL de workflow web avec la chaine de workflow WKFG

# Recherche sagdx
# Remplace les mots clés par leur valeur
# web    : serveur web              :  premiere partie du paramètre dossier GWRKRMTHTT
# lan    : langue                   :  GLANGUE
# ser    : serveur X3               :  GAPPSERV
# por    : port X3                  :  adxtcp
# dos    : nom de dossier           :  nomap
# sup    : version de superviseur   :  GVERSOL -> func APRODUCT.AGETRELEASESUP()
# sol    : nom de la solution       :  GINSTID
# wkf    : chaine de workflow       :  parametre sous-programme    WKFG

Local Char    SERW(100)  : #  Si il y a http devant l'enlever
Local Char    HTTP(10) , PRE(10)(1..2)
Local Integer I , TOF
SERW=SERW1

PRE(1) = "http://"
PRE(2) = "https://"

HTTP = ""
For I=1 To dim(PRE)
 TOF = instr(1,tolower(SERW),PRE(I))
 If TOF
  SERW = right$(SERW,len(PRE(I))+1)
  HTTP = PRE(I)
  Break
 Endif
Next I
If HTTP=""
 HTTP = PRE(1)
Endif

URLW=HTTP+"sagdxweb/adxwebconnect/CONNECT/directconnect.jsp?c=sagdxlan"
URLW+="&e=sagdxser&f=sagdxpor&g=sagdxdos&SUP=sagdxsup&SOL=sagdxsol&adonix.wkf=sagdxwkf"
URLW+="&adonix.noclose=1"

TOF=1
While TOF<>0
 TOF=instr(TOF,URLW,"sagdx")
 If TOF=0 : Break 1 : Endif
 MCLE=mid$(URLW,TOF+5,3)
 Case MCLE
   When "web"  : VMODIF=SERW           : Gosub MVALUE
   When "lan"  : VMODIF=GLANGUE        : Gosub MVALUE
   When "ser"  : VMODIF=GAPPSERV       : Gosub MVALUE
   When "por"  : VMODIF=num$(adxtcp)   : Gosub MVALUE
   When "dos"  : VMODIF=nomap          : Gosub MVALUE
   When "sup"  : VMODIF=func APRODUCT.AGETRELEASESUP()        : Gosub MVALUE
   When "sol"  : VMODIF=GINSTID        : Gosub MVALUE
   When "wkf"  : VMODIF=WKFG           : Gosub MVALUE
 Endcase
 TOF+=1
Wend

End

$MVALUE
URLW=left$(URLW,TOF-1)+VMODIF+right$(URLW,TOF+8)
Return

#**
#* URLWKF : new URLWKF for convergence
#*
#* @param URLW
#* @param WKFG
#* @param SERW1
#*!

Subprog URLWKF(URLW,WKFG)
Variable Char URLW
Value Char WKFG

#  Construit une URL de workflow web avec la chaine de workflow WKFG
Local Integer AP
Local Char    LURLW(250) , BURL(250)

If baseUrl<>""
 BURL = baseUrl
Else
 BURL = func AFNC.PARAM("AWRKSYRA","")
Endif

#{SAM121756
#Depending on the context baseUrl may contain /sdata or /trans
#In any case the function has to return a url using /trans
# => replace trans by sdata
AP = instr(1,BURL,"/sdata/")
If AP
 BURL = left$(BURL,AP-1) + "/trans/"+ right$(BURL,AP+len("/sdata/"))
Endif
#SAM12156}

AP = instr(8+1,BURL,"/")
If AP>0
 [L]LURLW  = left$(BURL,AP-1)
 [L]LURLW += '/syracuse-main/html/main.html?url='

 [L]LURLW += right$(BURL,AP)
 If right$([L]LURLW,len([L]LURLW))<>"/"
  [L]LURLW += '/'
 Endif
 [L]LURLW += "$sessions?f="
 [L]LURLW += WKFG
 [L]URLW = LURLW
Endif
End

$SET_CONTXT


# X3PLAT-1475 Workflow link on representation - end
If (CONTXT<>"" or CONTXT_DESKTOP<>"" or CONTXT_MOBILE<>"") and (dim(GCLOUD)<0 or toupper(GCLOUD)<>"AMAZON")

  # X3PLAT-1475 Workflow link on representation - start
  If CONTXT_DEST
   Local Integer WII
   WII = instr(1,CONTXT_DESKTOP,"[L]DEST")
   If WII>0
    CONTXT_DESKTOP = left$(CONTXT_DESKTOP,WII-1)+DEST+right$(CONTXT_DESKTOP,WII+7)
   Endif
   WII = instr(1,CONTXT_MOBILE,"[L]DEST")
   If WII>0
    CONTXT_MOBILE = left$(CONTXT_MOBILE,WII-1)+DEST+right$(CONTXT_MOBILE,WII+7)
   Endif
  Endif

  # First classic context
    Raz CHAINE
  If CONTXT<>"" & CONTXT_DESKTOP<>"" & CONTXT_MOBILE<>""    # all 3 links
    CHAINE = mess(204,75,1)+" "             # To select the quick view on your desktop, click:
    FICHIER = CONTXT_DESKTOP
    Gosub WR_FIC
    Wrseq Using [MES]
    CHAINE = mess(205,75,1)+" "             # To select the quick view on your mobile device, click
    FICHIER = CONTXT_MOBILE
    Gosub WR_FIC
    Wrseq Using [MES]
    CHAINE = mess(206,75,1)+" "             # To select the full view on your desktop, click
    Call URLWKF(FICHIER,CONTXT)
    Gosub WR_FIC
    Wrseq Using [MES]
  Elsif CONTXT<>"" & CONTXT_DESKTOP<>"" & CONTXT_MOBILE=""  # classic and syra desktop
    CHAINE = mess(204,75,1)+" "             # To select the quick view on your desktop, click:
    FICHIER=CONTXT_DESKTOP
    Gosub WR_FIC
    Wrseq Using [MES]
    CHAINE = mess(206,75,1)+" "             # To select the full view on your desktop, click
    Call URLWKF(FICHIER,CONTXT)
    Gosub WR_FIC
    Wrseq Using [MES]
  Elsif CONTXT<>"" & CONTXT_DESKTOP="" & CONTXT_MOBILE<>""  # classic and mobile
    CHAINE = mess(205,75,1)+" "             # To select the quick view on your mobile device, click
    FICHIER = CONTXT_MOBILE
    Gosub WR_FIC
    Wrseq Using [MES]
    CHAINE = mess(206,75,1)+" "             # To select the full view on your desktop, click
    Call URLWKF(FICHIER,CONTXT)
    Gosub WR_FIC
    Wrseq Using [MES]
  Elsif CONTXT<>"" & CONTXT_DESKTOP="" & CONTXT_MOBILE=""  # classic
    CHAINE = mess(206,75,1)+" "             # To select the full view on your desktop, click
    Call URLWKF(FICHIER,CONTXT)
    Gosub WR_FIC
    Wrseq Using [MES]
  Elsif CONTXT="" & CONTXT_DESKTOP<>"" & CONTXT_MOBILE<>""  # syra desktop  and mobile
    CHAINE = mess(204,75,1)+" "             # To select the quick view on your desktop, click:
    FICHIER = CONTXT_DESKTOP
    Gosub WR_FIC
    Wrseq Using [MES]
    CHAINE = mess(205,75,1)+" "             # To select the quick view on your mobile device, click
    FICHIER = CONTXT_MOBILE
    Gosub WR_FIC
    Wrseq Using [MES]
  Elsif CONTXT="" & CONTXT_DESKTOP<>"" & CONTXT_MOBILE=""  # desktop
    CHAINE = mess(204,75,1)+" "             # To select the quick view on your desktop, click:
    FICHIER = CONTXT_DESKTOP
    Gosub WR_FIC
    Wrseq Using [MES]
  Elsif CONTXT="" & CONTXT_DESKTOP="" & CONTXT_MOBILE<>""  # mobile
    CHAINE = mess(205,75,1)+" "             # To select the quick view on your mobile device, click
    FICHIER = CONTXT_MOBILE
    Gosub WR_FIC
    Wrseq Using [MES]
  Endif
Endif
Return
# X3PLAT-1475 Workflow link on representation

