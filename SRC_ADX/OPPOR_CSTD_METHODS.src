#######################################################################################
# Classe OPPOR
#######################################################################################
# METHODS                                                                             #
#######################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  # Issue X3-51863 - 2017-08-07 by FGR
  SLEVEL = func AFNC.MES1(mess(939,2260,1), this.OPPNUM)
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

#######################################################################################
$RESET_ERRORS
Local Integer NI

  # Issue X3-96497 - 2018-06-28 by FGR
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.ADELETERRORALL())
  For NI = 1 To maxtab(this.SBB)
    If this.SBB(NI) <> null and find(this.SBB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SBB(NI).ADELETERRORALL())
    Endif
  Next NI
  For NI = 1 To maxtab(this.CPP)
    If this.CPP(NI) <> null and find(this.CPP(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CPP(NI).ADELETERRORALL())
    Endif
  Next NI
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CRM_RESET_ERRORS())
  If this.TCHISPJM = [V]CST_ATRUE Then
#    If maxtab(this.PJM) > 0 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM_RESET_ERRORS())
#    Endif
  Endif
Return

#######################################################################################
$CPP_GET_INDEX
#Value Char SCPP ()
#Local Integer ARET_VALUE

Local Integer NI

  # Issue X3-67352 - 2017-12-11 by FGR
  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.CPP)
    If this.CPP(NI) <> null and find(this.CPP(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.CPP(NI).CPP = SCPP Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

#######################################################################################
$SBB_GET_INDEX
#Value Char SSBBPJT ()
#Local Integer ARET_VALUE

Local Integer NI

  # Issue X3-67352 - 2017-12-11 by FGR
  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.SBB)
    If this.SBB(NI) <> null and find(this.SBB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.SBB(NI).SBBPJT = SSBBPJT Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

