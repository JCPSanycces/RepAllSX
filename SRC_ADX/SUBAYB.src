######################################################################################


######################################################################################
## écran AYB1
######################################################################################

Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR = 2    # Multi
  Actzo [M:AYB1]BLCNBRLIN
  Actzo [M:AYB1]LINNBROBC
  Actzo [M]40
  Effzo [M]20 : Grizo [M]20
Else
  Effzo [M:AYB1]BLCNBRLIN 
  Effzo [M:AYB1]LINNBROBC
  Effzo [M]40 : Grizo [M]40
  Grizo [M:AYB1]BLCNBRLIN
  Grizo [M:AYB1]LINNBROBC
  Actzo [M]20
Endif
End

Subprog D_BLCNBRLIN(VALEUR)
Variable Decimal VALEUR
If [M:AYB1]TYP = 2 
 VALEUR = 10
Endif
End

Subprog D_LINNBROBC(VALEUR)
Variable Decimal VALEUR
If [M:AYB1]TYP = 2 
 VALEUR = 1
Endif
End

Subprog AM_ENTCOD(VALEUR)
Variable Char    VALEUR()
# Appel Gestion AYB2
[M]SELTYP=1 : [M]SRTTYP=1 
Call SETAYB2(VALEUR)
Affzo [AYB2]

# Chgt Interface sur ecran AYB1
[M]INTCOD=[M]INTCODSEL
[M]INTTYP=[M]INTTYPSEL
# Gestion tableau Paramètres
Call SETTABINT( [M]INTCOD, [M]INTTYP)
End

Subprog AS_VALTYP41(VALEUR)
Variable Integer VALEUR
Local Integer LST(len(mess(0,GCOMBO,1))),WI
LST(WI)=1 : WI+=1    # Cst
LST(WI)=2 : WI+=1    # Chp XTend
LST(WI)=3 : WI+=1    # Chp Web
# Suppression Javascript par chp web oblig.
# LST(WI)=4 : WI+=1    # Javascript
Call MNLCHX(GCOMBO,LST) From AYTUTIA
End

Subprog AM_VALTYP41(VALEUR)
Variable Integer VALEUR
Local Integer NOL
NOL=nolign-1
Call SETLIN41(VALEUR, NOL)
End

Subprog AS_VALEUR41(VALEUR)
Variable Char    VALEUR()
Local Char WVAL(GLONAYV)
If [M]VALTYP41(nolign-1)=3 # Chps web
    If VALEUR="" or VALEUR="?"
        WVAL=[M]PARCOD41(nolign-1)
        Call UNICITE(WVAL,[M]VALEUR41) From OBJDIV
        If mkstat
            Local Integer WI
            While mkstat<>0
                mkstat=0 : GERR=0 : GMESSAGE=""
                WVAL=[M]PARCOD41(nolign-1)+num$(WI)
                Call UNICITE(WVAL,[M]VALEUR41) From OBJDIV
                WI+=1
            Wend
        Endif
        VALEUR = WVAL #: mkstat=3
    Endif
Endif
End

Subprog C_VALEUR41(VALEUR)
Variable Char    VALEUR()
If [M]VALTYP41(nolign-1)=3 # Chps web
    Call UNICITE(VALEUR,[M]VALEUR41) From OBJDIV
    If vireblc(VALEUR,2)=""
     mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
Endif
End

Subprog AM_VBLCCOD41(VALEUR)
Variable Char    VALEUR()
Call SETZENTCODCOD41(VALEUR, nolign-1)
End

Subprog AM_VFIEKEY41(VALEUR)
Variable Char    VALEUR()
Call FIEKEY_ANA(VALEUR, [M]VFIELNKE41(nolign-1),[M]VFIECOD41(nolign-1)) From SUBAYF
End

Subprog C_BLCNBRLIN(VALEUR)
Variable Decimal VALEUR
Local Integer WISLIN : WISLIN=1
Gosub C_NBINT
End

Subprog C_LINNBROBC(VALEUR)
Variable Decimal VALEUR
Local Integer WISLIN : WISLIN=0
Gosub C_NBINT
End

$C_NBINT
Local Integer WNBLIN, WNBCEL
If WISLIN 
   WNBLIN=VALEUR : WNBCEL=[M]LINNBROBC
Else
   WNBCEL=VALEUR : WNBLIN=[M]BLCNBRLIN
Endif        
#Dbgaff
If [M]INTWEBSRC = "" : Return : Endif
Gosub GETWS_VAR From SUBAYIACT      # Variables pour GETWS_INF
WS_INTTYP=[M]INTTYPSEL : WS_WSRCOD=[M]INTWEBSRC
Gosub GETWS_INF  From SUBAYIACT 
If WS_RET    #  Traitement si Anomalie GETWS_INF
    Case WS_INTTYP
    When 1,4,2    # Accès généré et Accès Ss-prgm
#        [M]PRG=WS_ASUTRT : [M]SUBPRG=WS_ASUSPG 
        If WS_RET=2     # Pas de trt: non bloquant car affichage à partir des infos d'ASU
        Else
#            Affzo [M:AYI1]PRG,SUBPRG,WWSLIB
            GMESSAGE=WS_MES : mkstat=2
            Return
        Endif
    When 3        # Liste gauche
#        [M]PRG=WS_WXTRT : [M]SUBPRG=WS_WXSPG
        GMESSAGE=WS_MES : mkstat=2
        Return        
    Endcase
Endif

If dim(RUBRESMAX)>0 & (WNBLIN>RUBRESMAX)  
    GMESSAGE=mess(178, 7900, 1)-"("-num$(RUBRESMAX)-")"
    mkstat=2
Else
    If dim(RUBRESMAX)>0 &( WNBLIN*WNBCEL > RUBRESMAX )  
        If WISLIN
            [M]LINNBROBC=int(RUBRESMAX / WNBLIN) : Affzo [M]LINNBROBC
        Else
            If int(RUBRESMAX / WNBCEL)>0
                [M]BLCNBRLIN=int(RUBRESMAX / WNBCEL) : Affzo [M]BLCNBRLIN
            Else
                GMESSAGE=mess(178, 7900, 1)-"("-num$(RUBRESMAX)-")"
                mkstat=2
            Endif
        Endif        
    Endif
Endif
Return


######################################################################################
## écran AYB2
#    Gestion Sélection (écran AYB2) partagé avec les DL 
#        Tableau invisible: zones d'échanges en entrée
#                OBJX3         "AYB", "AYL"
#                LINCOD        Code pour aytlines (code bloc, code DL)
#                ENTCODSEL     Code entité géré par le bloc, DL
#
######################################################################################
Subprog D_ANDOR30(VALEUR)
Variable Integer  VALEUR
If nolign=1 : VALEUR=0 : Else : VALEUR=1 : Endif
End

Subprog AS_ANDOR30(VALEUR)
Variable Integer  VALEUR
If nolign=1
  mkstat=1 
Else
  If [M]INTTYPSEL=3 : VALEUR=1 : mkstat=3 : Endif        # Accès liste gauche
Endif
End

Subprog AS_BRKLFTM30(VALEUR)
Variable Integer VALEUR
If [M]INTTYPSEL=3 : VALEUR=1 : mkstat=3 : Endif        # Accès liste gauche
End

Subprog AS_BRKRGTM30(VALEUR)
Variable Integer VALEUR
If [M]INTTYPSEL=3 : VALEUR=1 : mkstat=3 : Endif        # Accès liste gauche
End

Subprog C_FIEKEY30(VALEUR)
Variable Char    VALEUR()
If [M]INTTYPSEL=3    # Accès liste gauche
    Call UNICITE(VALEUR,[M]FIEKEY30(0..[M]NUM30-1)) From OBJDIV
    If mkstat
        GMESSAGE = mess(117,7900,1)+"\"+GMESSAGE     # Code déjà existant en ligne
    Endif
Endif
End

Subprog AM_VALTYP30(VALEUR)
Variable Integer VALEUR
Local Integer NOL
NOL=nolign-1
Call SETLIN(VALEUR, NOL)
End

Subprog AS_OPE30(VALEUR)
Variable Integer VALEUR
If [M]SELTYP=2 : mkstat=2 : Endif
GMENLOC(1)=1    # Indifférent
Case [M]FIEXTTYP30(nolign-1)
When 2,3,4,5,8
  GMENLOC(8)=1 : GMENLOC(9)=1 : GMENLOC(10)=1
Endcase
End

Subprog AS_VALTYP30(VALEUR)
Variable Integer VALEUR
Local Integer LST(len(mess(0,GCOMBO,1))),WI
LST(WI)=1 : WI+=1    # Cst
LST(WI)=2 : WI+=1    # Chp XTend
LST(WI)=3 : WI+=1    # Chp Web
# Suppression Javascript par chp web oblig.
# LST(WI)=4 : WI+=1    # Javascript
Call MNLCHX(GCOMBO,LST) From AYTUTIA
End

Subprog AM_FIEKEY30(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL=nolign-1
Call FIEKEY_ANA(VALEUR, [M]FLNKENT30(NOL),[M]FIECOD30(NOL)) From SUBAYF
Call SETLIN([M]VALTYP30(NOL), NOL) 
#$$$
#Local Char WFMT
#Call AYF_INFOS([M]FCYCOD, [M]FIECOD30(nolign-1),
#&                [M]FIEXTTYP30(nolign-1),[M]FIEX3TYP30(nolign-1),[M]FIELON30(nolign-1),
#&                [M]FIENOLIB30(nolign-1), WFMT) From SUBAYF
End

Subprog AM_VFIEKEY30(VALEUR)
Variable Char    VALEUR()
Call FIEKEY_ANA(VALEUR, [M]VFIELNKE30(nolign-1),[M]VFIECOD30(nolign-1)) From SUBAYF
End

Subprog AS_SELTYP(VALEUR)
Variable Integer VALEUR
If [M]OBJX3="AYL" # Lien dyn.
    GMENLOC(4)=1    # dernier lien cliqué
Endif
GMENLOC(5)=1    # Détail - non repris vu avec FD
GMENLOC(2)=1    # Accès par code - non actif (dl et bloc) car double emploi avec requête - vu avec FD 26/02/2007
End

Subprog AM_SELTYP(VALEUR)
Variable Integer VALEUR
Call AYL_AYB2(VALEUR)
Affzo [AYB2]
End

Subprog AM_SRTTYP(VALEUR)
Variable Integer VALEUR
#Infbox "AM_SRTTYP"
Call SRT_TAB([M]SELTYP,VALEUR)
Affzo [AYB2]
End

Subprog AS_NUM30
    # Cas sel par code
    If [M]SELTYP=2 and nolign=2 :  mkstat=2 : End : Endif
End

Subprog AVANT_NUM30
# Vérif et/ou sur ligne 2 pour traiter le cas d'une insertion sur 1er ligne
If [M]NUM30 >1 and [M]ANDOR30(1)=0 : [M]ANDOR30(1)=1 : Affzo [M]ANDOR30(1) : Endif 
End

Subprog C_NUM30
# Nota: en ctl sur la variable de bas de tableau, le nb contenu dans ce champs est exact
#        ce qui n'est pas tj le cas en Apres_Ligne

If adxgtb=2
    # Vérif nb ()
    Local Integer WL, WR
    WL=sum([M]BRKLFTM30) : WR=sum([M]BRKRGTM30) 
    If WL<> WR
        mkstat=2 : GMESSAGE = mess(74,7900,1)    #-" '('="+num$(WL)-" ')'="+num$(WR) 
        GERR=1
        End
    Endif

    # Synthèse
    Call RES30()
Endif

End

Subprog C_FIEKEY31(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]FIEKEY31) From OBJDIV
End

Subprog AM_FIEKEY31(VALEUR)
Variable Char    VALEUR()
Call FIEKEY_ANA(VALEUR, [M]FLNKENT31(nolign-1),[M]FIECOD31(nolign-1)) From SUBAYF
End

Subprog AM_VBLCCOD30(VALEUR)
Variable Char    VALEUR()
Call SETZENTCODCOD30(VALEUR, nolign-1)
End

Subprog C_ENTCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  If left$([M:AYB0]BLCCOD,1)="A"
    GERR=2 : GMESSAGE = mess(84,7900,1)
  Else
    mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
Endif
End


Subprog AS_SRTTYP(VALEUR)
Variable Integer VALEUR
If !find([M]INTTYPSEL,1,2,4)  # Accès ss-prgm uniquement
    GMENLOC(3)=1    # Hasard
Endif
End

Subprog AS_VALEUR30(VALEUR)
Variable Char    VALEUR()
Local Char WVAL(GLONAYV)
If [M]VALTYP30(nolign-1)=3 # Chps web
    If VALEUR="" or VALEUR="?"
        WVAL=[M]FIEKEY30(nolign-1)
        Call UNICITE(WVAL,[M]VALEUR30) From OBJDIV
        If mkstat
            Local Integer WI
            While mkstat<>0
                mkstat=0 : GERR=0 : GMESSAGE=""
                WVAL=[M]FIEKEY30(nolign-1)+num$(WI)
                Call UNICITE(WVAL,[M]VALEUR30) From OBJDIV
                WI+=1
            Wend
        Endif
        VALEUR = WVAL 
    Endif
Endif
End

Subprog C_VALEUR30(VALEUR)
Variable Char    VALEUR()
If [M]VALTYP30(nolign-1)<>1     # <> Cst
    If vireblc(VALEUR,2)=""
        mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
Endif
#If [M]VALTYP30(nolign-1)=3 # Chps web
#    Call UNICITE(VALEUR,[M]VALEUR30) From OBJDIV
#Endif
End

