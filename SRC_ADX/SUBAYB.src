#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion objet AYB
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AYB",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
## Xtend:  Gestion Bloc
#       et gestion Sélection (écran AYB2) partagé avec les DL 
#
#   Table AYTLINES  (AYN)
#        LINCODTYP = 2     Blocs  (géré en auto dans AYL_AYB2 à partir du code objet X3)
#        LINTYP (doc Wiki)
#                  = 30    liste sélection
#                  = 31    liste tri
#                  = 41    valeur paramètres interface type accès ss-prgrm
#
#       
#  Version 0001
######################################################################################
$ACTION
Case ACTION
 When "AVANT_OUVRE"    : Gosub AVANT_OUVRE
 When "ANNULE"         : Gosub ANNULE
 When "CREATION"       : Gosub CREATION
 When "EXEACT"         : Gosub EXEACT
 When "FERME"          : Gosub FERME
 When "FILTRE"         : Gosub FILTRE
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "LIENS"          : Gosub LIENS
 When "MODIF"          : Gosub MODIF
 When "OUVRE"          : Gosub OUVRE
 When "RAZCRE"         : Gosub RAZCRE
 When "SETBOUT"        : Gosub SETBOUT
 When "VERIF_MOD"      : Gosub VERIF
 When "VERIF_CRE"      : Gosub VERIF
 When default
Endcase
Return  

#---------------------------------------------------------------#
$AVANT_OUVRE
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Gosub INICTLFCY From SUBAYS
Return

#---------------------------------------------------------------#
$VERIF
If [M]TYP=2 
 If [M]BLCNBRLIN =0 or [M]LINNBROBC =0
  GMESSAGE = mess(38,141,1) :#  Nombre de lignes à 0
  OK=0 : Return
 Endif
Endif

Return

#---------------------------------------------------------------#
$OUVRE
Local Char WSTR1 (250), KEYLNK(30)
Local Integer WI, AYNPOS21
Local Integer SELTYP_MOD
Gosub DSYFCY From SUBAYS     # Infos site
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY From SUBAYS # Clear affichage site
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, copie
Else
 CHMEN+="1"    # Validation avec vérification 
Endif
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$EXEACT
Case BOUT
When "S"
    Call USG_SUPP([M]FCYCOD, GABREV, [M:AYB0]BLCCOD, WI) From CNSAYUSTD
    If WI : OK=0 : Endif
Endcase
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$INICRE
$INIMOD
# Clé browser X3
[F]BRWX3=[F]FCYCOD+"_"+[F]BLCCOD 
Return

#---------------------------------------------------------------#
$CREATION
If GREP="D" : [M]LINCOD = [M]BLCCOD : Endif
$MODIF
# 
# Sup. avant recréation Sélection 
Gosub ANNULE2 : If GOK<>1 : Return : Endif
# Sélection
Call AYB2_AYL()

# Valeur des param Interface
For WI=0 To [M]NUM41-1
 Raz [F:AYN]
 [F:AYN]FCYCOD    = [M]FCYCOD
 [F:AYN]LINCODTYP = 2
 [F:AYN]LINCODSTD = [M]BLCCOD
 [F:AYN]LINCOD    = toupper([M]BLCCOD)
 [F:AYN]LINTYP    = 41
 [F:AYN]LINNUM    = WI

 [F:AYN]PARCOD      = [M]PARCOD41(WI)
 [F:AYN]VALTYP      = [M]VALTYP41(WI)
 Case [F:AYN]VALTYP
 When 1,3    # cste; chp web
    [F:AYN]VALEUR = [M]VALEUR41(WI)
 When 2    # chp xtend
    [F:AYN]VALBLCCOD   = [M]VBLCCOD41(WI)
    [F:AYN]VALFIELNKE  = [M]VFIELNKE41(WI)
    [F:AYN]VALFIECOD   = [M]VFIECOD41(WI)
 Endcase

 Write [AYN]
 If fstat
  GOK=0 : Call FSTA("AYN") From GLOCK : Break
 Endif
Next

#  textes AXX
Call MAJTEXTRA([M]INTIT,"AYTELTBLC","INTIT",[M:AYB0]FCYCOD,[M:AYB0]BLCCOD) From  ATEXTRA

Return

#---------------------------------------------------------------#
$LIENS
Gosub DSYFCY From SUBAYS     # Infos site
#
WI=[F:AYB]TYP : Call AM_TYP(WI)

# Mask Sélection
[M]SELTYPFILE=[F:AYB]SELTYP    # Gestion chgt par utilisateur
[M]SRTTYPFILE=[F:AYB]SRTTYP    #

# Appel Gestion AYB2
Call SETAYB2([F:AYB]ENTCOD)

# Chgt Interface sur ecran AYB1
[M]INTCOD=[M]INTCODSEL
[M]INTTYP=[M]INTTYPSEL
# Gestion tableau Paramètres
Call SETTABINT( [M]INTCOD, [M]INTTYP)

## grisage  AYB1
[M:AYB1]BLCNBRLIN = [F:AYB]BLCNBRLIN
[M:AYB1]LINNBROBC = [F:AYB]LINNBROBC
If [M]TYP = 2    # Multi
  Actzo [M:AYB1]BLCNBRLIN
  Actzo [M:AYB1]LINNBROBC
  Actzo [M]40
  Effzo [M]20 : Grizo [M]20
Else
  Effzo [M:AYB1]BLCNBRLIN 
  Effzo [M:AYB1]LINNBROBC
  Effzo [M]40 : Grizo [M]40
  Grizo [M:AYB1]BLCNBRLIN
  Grizo [M:AYB1]LINNBROBC
  Actzo [M]20
Endif
Return

#---------------------------------------------------------------#
$FILTRE
FILTSUP+=func SUBAYS.FILTFCY
Return

#---------------------------------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="AYTELTBLC" & ZONE = "INTIT"   & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
$ANNULE2
Delete [AYN]AYN0=[M]FCYCOD;2;toupper([M]BLCCOD)
If fstat=1 : GOK=-1 : GLOCK="$AYTLINES ("-[M]FCYCOD-"2"-[M]BLCCOD+")" : Return : Endif
Return

#---------------------------------------------------------------#
$RAZCRE
Gosub DSYFCY From SUBAYS     # Infos site
#[M]CODACT=WFCY_CODACT        # Code activité site
[M]SELTYP = 1 # Défaut sélection: Aucune
Return

######################################################################################
## Utilitaires
######################################################################################
###    Flag code bloc spécial (aMain...)
Funprog BLCSPEXT(BLCCOD, ENTCOD)
Value Char BLCCOD  # Bloc
Value Char ENTCOD  # Entité du bloc
Local Integer WI
If ENTCOD=""
    WI=1        # Cas de "aMain","aPBg","aReqContent")
Else
    If ENTCOD="aSession"  : WI=1 : Endif
Endif
End WI

###    Mise à jour AYB2
Subprog SETAYB2(ENTCOD)
Value Char ENTCOD
# Appel Gestion AYB2
[M]OBJX3    ="AYB"      
[M]LINCOD   =[M:AYB0]BLCCOD      
[M]ENTCODSEL=ENTCOD
Call AYL_AYB2([M]SELTYP)
End

### Synthèse sélection
Subprog RES30
Local Integer WLG
Local Clbfile WRES30
For WLG = 0 To [M]NUM30-1
    If WLG<>0 : WRES30-=mess([M]ANDOR30(WLG),56,1) : Endif
    WRES30-=mess([M]BRKLFTM30(WLG),7930,1)-[M]FIEKEY30(WLG)-mess([M]OPE30(WLG),7926,1)
    Case [M]VALTYP30(WLG)
    When 1 # cst
         Case [M]FIEX3TYP30(WLG)
         When "M","D"
            WRES30-='"'+[M]VALINT30(WLG)+'" ('+[M]VALEUR30(WLG)+')'
         When "L","DCB"
            WRES30-='"'+[M]VALINT30(WLG)+'"'
         When Default
            WRES30-='"'+[M]VALEUR30(WLG)+'"'
         Endcase
    When 2 # Chp Xtend
            WRES30-=[M]VBLCCOD30(WLG)+"."+[M]VFIEKEY30(WLG)
    When 3 # Chp Web
            WRES30-="web:"+[M]VALEUR30(WLG)
    When 4 # Javascript
            WRES30-="JScript"
    Endcase
    WRES30-=mess([M]BRKRGTM30(WLG),7932,1)
Next
If WRES30="" : WRES30=mess(122,7900,1) : Endif
[M]RES30=WRES30 : Affzo [M:AYB2]RES30
End

# Gestion Tableau Paramètres interface (type sous-programme) 
######################################################################################
Subprog SETTABINT(INTCOD, INTTYP)
Value Char INTCOD
Value Integer INTTYP
If INTTYP=2    # Accès sous-programme
    Actzo [M]50
    # AYN: Principal- Table paramètres des actions (type 6 - interface)    - LINTYP = 40
    # AYN: Lié      - Table des valeurs portées par le bloc(type 2 - blocs)- LINTYP = 41
    
    WI=0
    # Liste des paramètres
    For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 6
&                     and LINCOD = toupper([L]INTCOD) and  LINTYP = 40
&                     and VALTYP<>1                # Pas une cste déclaré sur l'interface
          [M]PARCOD41(WI)    = [F:AYN]PARCOD
          [M]VALTYP41(WI)    = 1     # Défaut
          [M]VALEUR41(WI)    = "?"
          WI+=1
    Next
    [M]NUM41=WI
    
    #  Valeurs: LINCODTYP = 2 et LINTYP = 41
    For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 2
&                     and LINCOD = toupper([M]BLCCOD) and  LINTYP = 41
          WI=find([F:AYN]PARCOD,[M]PARCOD41(0..[M]NUM41-1))
          If WI
              WI=WI-1
              [M]VALTYP41(WI)    = [F:AYN]VALTYP
              [M]VALEUR41(WI)    = [F:AYN]VALEUR
              [M]VBLCCOD41(WI)   = [F:AYN]VALBLCCOD : Call SETZENTCODCOD41([F:AYN]VALBLCCOD, WI)
              [M]VFIELNKE41(WI)  = [F:AYN]VALFIELNKE
              [M]VFIECOD41(WI)   = [F:AYN]VALFIECOD
              Call FIEKEY_COD([F:AYN]VALFIELNKE, [F:AYN]VALFIECOD, [M]VFIEKEY41(WI)) From SUBAYF
          Endif
          #
    Next
    # Grisage
    For WI=0 To [M]NUM41-1
      Call SETLIN41([M]VALTYP41(WI) , WI)
    Next
    
Else
  Effzo [M]50 : Grizo [M]50
Endif
Affzo [M]50
End

### Gestion des chps d'une ligne de critère en fonction du type de valeur
Subprog SETLIN41(VALTYP, NOL)    
Value Integer VALTYP
Value Integer NOL
#
Case VALTYP
When 1     # cste
    Effzo [M]VBLCCOD41(NOL),VFIEKEY41(NOL) : Grizo [M]VBLCCOD41(NOL),VFIEKEY41(NOL)
    Actzo [M]VALEUR41(NOL)
When 2    # chp xtend
    #Infbox "num "-num$(NOL)-"nb"-num$([M]NUM41)
    Actzo [M]VBLCCOD41(NOL),VFIEKEY41(NOL)
    Effzo [M]VALEUR41(NOL) : Grizo [M]VALEUR41(NOL)
When 3    # chp web
    Effzo [M]VBLCCOD41(NOL),VFIEKEY41(NOL)
    Grizo [M]VBLCCOD41(NOL),VFIEKEY41(NOL)
    Actzo [M]VALEUR41(NOL)
    # Pour info
    #[M]VALEUR41(NOL)=[M]DLKCOD+":act="+num$(NOL+1) : Diszo [M]VALEUR41(NOL)  
When 4    # javascript
    Effzo [M]VBLCCOD41(NOL),VFIEKEY41(NOL),VALEUR41(NOL)
    Grizo [M]VBLCCOD41(NOL),VFIEKEY41(NOL),VALEUR41(NOL)
Endcase 
End

### Gestion du code entité en fonction du bloc sur la ligne
Subprog SETZENTCODCOD41(BLCCOD, NOL)
Value Char BLCCOD
Value Integer NOL
Local Char WENTCOD(GLONAYE)
If BLCCOD<>""    
    If !clalev([F:AYB1]) : Local File AYTELTBLC [AYB1] : Endif
    Read [AYB1]AYB0 = [M]FCYCOD;[L]BLCCOD
    If !fstat                
        WENTCOD=[F:AYB1]ENTCOD
    Endif
Endif
[M]ZENTCOD41(NOL)=WENTCOD: Affzo [M]ZENTCOD41(NOL)
End


######################################################################################
#
# Utilitaires AYB2
#
######################################################################################

### Gestion des chps d'une ligne de critère en fonction du type de valeur
Subprog SETLIN(VALTYP, NOL)    
Value Integer VALTYP
Value Integer NOL
#
Local Char WFMT
Case VALTYP
When 3    # Champ Web: forcer le type A pour AVV (pb mise en forme sur date)
    [M]FIEX3TYP30(NOL)="A"
    Raz [M]FIELON30(NOL),[M]FIENOLIB30(NOL)
When Default
   Call AYF_INFOS([M]FCYCOD, [M]FIECOD30(NOL),
&                [M]FIEXTTYP30(NOL),[M]FIEX3TYP30(NOL),[M]FIELON30(NOL),
&                [M]FIENOLIB30(NOL), WFMT) From SUBAYF
Endcase
#
Case VALTYP
When 1     # cste
    Effzo [M:AYB2]VBLCCOD30(NOL),VFIEKEY30(NOL) : Grizo [M:AYB2]VBLCCOD30(NOL),VFIEKEY30(NOL)
    Actzo [M:AYB2]VALEUR30(NOL)
When 2    # chp xtend
    #Infbox "num "-num$(NOL)-"nb"-num$([M]NUM30)
    Actzo [M:AYB2]VBLCCOD30(NOL),VFIEKEY30(NOL)
    Effzo [M:AYB2]VALEUR30(NOL) : Grizo [M:AYB2]VALEUR30(NOL)
When 3    # chp web
    Effzo [M:AYB2]VBLCCOD30(NOL),VFIEKEY30(NOL)
    Grizo [M:AYB2]VBLCCOD30(NOL),VFIEKEY30(NOL)
    Actzo [M:AYB2]VALEUR30(NOL)
    # Pour info
    #[M]VALEUR30(NOL)=[M]LINCOD+":crit="+num$(NOL+1) : Diszo [M]VALEUR30(NOL)  
When 4    # javascript
    Effzo [M:AYB2]VBLCCOD30(NOL),VFIEKEY30(NOL),VALEUR30(NOL)
    Grizo [M:AYB2]VBLCCOD30(NOL),VFIEKEY30(NOL),VALEUR30(NOL)
Endcase 
End

### Gestion du code entité en fonction du bloc sur la ligne
Subprog SETZENTCODCOD30(BLCCOD, NOL)
Value Char BLCCOD
Value Integer NOL
Local Char WBLCCOD(GLONAYB)
If BLCCOD<>""    
    If !clalev([F:AYB1]) : Local File AYTELTBLC [AYB1] : Endif
    Read [AYB1]AYB0 = [M]FCYCOD;[L]BLCCOD
    If !fstat                
        WBLCCOD=[F:AYB1]ENTCOD
    Endif
Endif
[M]ZENTCOD30(NOL)=WBLCCOD : Affzo [M:AYB2]ZENTCOD30(NOL)
End

### Gestion du mask AYB2 à partir d'une entité
######################################################################################
#    Nota: Informations invisibles portées dans le premier bloc AYB2
#            OBJX3        Type objet            AYB: sélection sur bloc   AYL: Lien dynamique
#            ENTCODSEL    Code Entité Xtend     Ex: Bank  
#            LINCODTYP    Type de code          Numéro interne associé à OBJX3 (2 pour AYB)
#            LINCOD       Code                  Ex: Bloc1
#            SELTYPFILE   Type de sélection     Type au moment de la lecture de la fiche (aucune, requête..)
#            SRTTYPFILE   Type de tri           Type au moment de la lecture de la fiche (aucune, requête..)
#
Subprog AYL_AYB2(SELTYP)
Value Integer SELTYP        # Type de sélection (7912- aucune, requête..)
Local Integer SELTYPINIT    # Type de sélection porté par l'enregistrement (bloc, dl...)
#Dbgaff  # ***
If [M]ENTCODSEL=""
    Gosub GRIRAZAYB2    # pas de gestion
    End
Else
    Actzo [M:AYB2]SELTYP
Endif

Case [M]OBJX3
When "AYB"
    [M]LINCODTYP=2
When "AYL"
    [M]LINCODTYP=4
When ""
When Default
    Infbox "Xtend - Internal error in AYL_AYB2 / SUBAYB - Type non connu:"-[M]OBJX3
    End
Endcase

# Infos générales entité & interface 
[M]INTCODSEL=""
[M]INTTYPSEL=0
If !clalev([F:AYE]) : Local File AYTENT [AYE] : Endif
Read [AYE]AYE0 = [M]FCYCOD;[M]ENTCODSEL
If !fstat             
  Case [AYE]TYP
  When 3    # Accès   
    [M]INTCODSEL = [AYE]INTCOD
    If clalev([F:AYI])=0 :  Local File AYTINT  [AYI] : Endif 
    Read [AYI]AYI0 = [M]FCYCOD; [AYE]INTCOD
    If !fstat    
        [M]INTTYPSEL=[F:AYI]TYP
        [M]INTWEBSRC=[F:AYI]WEBSRCCOD
    Else
        Gosub GRIRAZAYB2    # pas de gestion
    Endif
  When 1    # Action (FD: forcer requête) 
        # Modif SB problème passage interface accès vers action ou session bug 52233
        [M]INTWEBSRC=""
        # Fin SB
        Gosub GRIRAZSEL
        Gosub GRIRAZSRT
        [M]SELTYP=3
        [M]SRTTYP=1
        Diszo [M:AYB2]SELTYP
        Grizo [M:AYB4]SRTTYP
        Call RES30()
        End
  When Default
    # Modif SB problème passage interface accès vers action ou session bug 52233
    [M]INTWEBSRC=""
    # fin Modif
    Gosub GRIRAZAYB2    # pas de gestion
    End
  Endcase
Else        # pas de gestion   
    Gosub GRIRAZAYB2    # pas de gestion
    End
Endif

# Sélection active uniquement sur les interface de type Accès données
If [M]INTTYPSEL >=20        
    Gosub GRIRAZSEL
    Gosub GRIRAZSRT
    End
Endif
Affzo [M:AYB2]INTCODSEL
Affzo [M:AYB2]INTTYPSEL

# Type sélection sans informations suplémentaires
Case [M]OBJX3
When "AYB"
    If find([L]SELTYP,1,4,5)      # Aucune, Dernier lien, Détail  
        Gosub GRIRAZSEL
        [M]SRTTYP=1
        Grizo [M:AYB4]SRTTYP
        Gosub GRIRAZSRT
        End
    Endif
When "AYL"
    If find([L]SELTYP,4,5)        # Dernier lien, Détail  
        Gosub GRIRAZSEL
        [M]SRTTYP=1
        Grizo [M:AYB4]SRTTYP
        Gosub GRIRAZSRT
        End
    Endif
Endcase

# Gestion optimisation interface
Case [M]OBJX3
When "AYB"
    If find([M]INTTYPSEL,1,2,4)     # Interface généré ou type ss-prgrm 
        Actzo [M:AYB2]INTOPTIMI
    Else
        Effzo [M:AYB2]INTOPTIMI : Grizo [M:AYB2]INTOPTIMI
    Endif
When Default
     Chgfmt [M:AYB2]INTOPTIMI With "-K:10X"
Endcase

# Gestion chps sélection altérable
If [L]SELTYP=3       # Sel requête
    Actzo [M:AYB2]SELDYNALT
Else
    Grizo [M:AYB2]SELDYNALT
Endif

# Gestion chps listes tri
If [L]SELTYP=2 | !find([M]INTTYPSEL,1,2,4)   # (M7916) Sel par code  OU 
    Grizo [M:AYB4]SRTTYP, SRTDYNALT               # (M7912) Interface pas de type Accès gén. ou ss-prgrm      
Else
    Actzo [M:AYB2]SELDYNALT
    Actzo [M:AYB4]SRTTYP
    Actzo [M:AYB4]SRTDYNALT
Endif

# Gestion tableaux
Call SEL_TAB(SELTYP)
Call SRT_TAB(SELTYP,[M]SRTTYP)
End

# Grisage et effacement complet des info sélection du mask AYB2
$GRIRAZAYB2
[M]SELTYP=1
[M]INTCODSEL=""
[M]INTTYPSEL=0

Grizo [M:AYB2]SELTYP
[M:AYB4]SRTTYP=1
Grizo [M:AYB4]SRTTYP
Gosub GRIRAZSEL
Gosub GRIRAZSRT
Return

# Grisage et effacement complet critères sélection 
$GRIRAZSEL
[M:AYB2]INTOPTIMI=1 : Grizo [M:AYB2]INTOPTIMI
[M:AYB2]SELDYNALT=1 : Grizo [M:AYB2]SELDYNALT
[M]NUM30=0
Effzo [M]20,25
Grizo [M]20,25
Return

# Grisage et effacement tri 
$GRIRAZSRT
[M]NUM31=0
[M:AYB4]SRTDYNALT=1
Grizo [M:AYB4]SRTDYNALT
Return



# Gestion Tableau Sélection 
######################################################################################
Subprog SEL_TAB(SELTYP)
Value Integer SELTYP
Local Char WFMT

If [L]SELTYP=1             # Aucune
    Gosub GRIRAZSEL
    End
Endif

Actzo [M]20 : Effzo [M]20,25 # Activation tableau SELECTION
[M]NUM30=dim([M]FIECOD30)    # Pour eviter pb sur grizo (AM_VALTYP30_)

If [L]SELTYP=2 
   Gosub SEL_COD
   Grizo [M:AYB1]BLCNBRLIN
   Grizo [M:AYB1]LINNBROBC
Elsif [L]SELTYP=3
   Gosub SEL_REQ
Endif

Affzo [M]20

# Synthèse
Call RES30()
End


### Chgt mask Sélection cas code
$SEL_COD
WI=0
Read [AYN]AYN0=[M]FCYCOD;1;[M]ENTCODSEL;30;0    # Entité, type sélection, 1er ligne
If !fstat
   [M]FIECOD30(WI)    = [F:AYN]FIECOD
   Call AYF_INFOS([M]FCYCOD, [M]FIECOD30(WI),
&                [M]FIEXTTYP30(WI),[M]FIEX3TYP30(WI),[M]FIELON30(WI),
&                [M]FIENOLIB30(WI), WFMT) From SUBAYF

   [M]FIEKEY30(WI)    = [F:AYN]FIECOD : Diszo [M]FIEKEY30(WI)
   [M]OPE30(WI)       = 2  # Accès code -> =
   [M]ALLSTAR30(WI)   = 1 : Grizo [M:AYB2]ALLSTAR30(WI)
   [M]CRIOBY30(WI)    = 2 : Grizo [M:AYB2]CRIOBY30(WI)
   [M]VALTYP30(WI)    = 1
   [M]VALEUR30(WI)    = "?"
   [M]ANDOR30(WI)     = 0
   [M]BRKLFTM30(WI)   =1  : Grizo [M:AYB2]BRKLFTM30(WI)
   [M]BRKRGTM30(WI)   =1  : Grizo [M:AYB2]BRKRGTM30(WI)

   If [M]SELTYPFILE=[L]SELTYP    # L'utilisateur est ou revient sur son choix initial
     Read [AYN]AYN0=[M]FCYCOD;[M]LINCODTYP;toupper([M]LINCOD);30;0    # Bloc, type sélection, 1er ligne
     If !fstat
       [M]BRKLFTM30(WI)   = [F:AYN]BRKLFT + 1
       [M]BRKRGTM30(WI)   = [F:AYN]BRKRGT + 1
       [M]VALTYP30(WI)    = [F:AYN]VALTYP
       # Champ Web: forcer le type A pour AVV (saisie libre même pour chp non alpha)
       If [M]VALTYP30(WI)=3    
            [M]FIEX3TYP30(WI)="A"
            Raz [M]FIELON30(WI),[M]FIENOLIB30(WI)
       Endif  
       [M]VALEUR30(WI)    = [F:AYN]VALEUR
       If [M]FIEX3TYP30(WI)<>"A"
           Call CONTROLE([M]VALEUR30(WI),[M]FIEX3TYP30(WI),[M]FIENOLIB30(WI),
&                        [M]FIELON30(WI),[M]VALINT30(WI)) From FMTVAR
           mkstat=0
       Endif
       [M]VBLCCOD30(WI)   = [F:AYN]VALBLCCOD : Call SETZENTCODCOD30([F:AYN]VALBLCCOD, WI)
       [M]VFIELNKE30(WI)  = [F:AYN]VALFIELNKE
       [M]VFIECOD30(WI)   = [F:AYN]VALFIECOD
       Call FIEKEY_COD([F:AYN]VALFIELNKE, [F:AYN]VALFIECOD, [M]VFIEKEY30(WI)) From SUBAYF
     Endif
   Endif
   Call SETLIN([M]VALTYP30(WI) , WI)
   [M]NUM30=1
Else
   [M]NUM30=0
Endif
Return

### Chgt mask Sélection cas requete
$SEL_REQ
Raz [F:AYN]
WI=0
If [M]SELTYPFILE=[L]SELTYP    # L'utilisateur est ou revient sur son choix initial
   For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = [M]LINCODTYP
&                     and LINCOD = toupper([M]LINCOD) and  LINTYP = 30
      [M]FIECOD30(WI)    = [F:AYN]FIECOD
      Call AYF_INFOS([M]FCYCOD, [M]FIECOD30(WI),
&                [M]FIEXTTYP30(WI),[M]FIEX3TYP30(WI),[M]FIELON30(WI),
&                [M]FIENOLIB30(WI), WFMT) From SUBAYF
      [M]FLNKENT30(WI)   = [F:AYN]FIELNKENT
      Call FIEKEY_COD([F:AYN]FIELNKENT, [F:AYN]FIECOD, [M]FIEKEY30(WI)) From SUBAYF
      If WI : [M]ANDOR30(WI)     = [F:AYN]ANDOR : Endif
      [M]BRKLFTM30(WI)   = [F:AYN]BRKLFT + 1
      [M]BRKRGTM30(WI)   = [F:AYN]BRKRGT + 1
      [M]OPE30(WI)       = [F:AYN]OPE
      [M]VALTYP30(WI)    = [F:AYN]VALTYP
      # Champ Web: forcer le type A pour AVV (saisie libre même pour chp non alpha)
      If [M]VALTYP30(WI)=3    
            [M]FIEX3TYP30(WI)="A"
            Raz [M]FIELON30(WI),[M]FIENOLIB30(WI)
      Endif  
      [M]VALEUR30(WI)    = [F:AYN]VALEUR
      If [M]FIEX3TYP30(WI)<>"A"
           Call CONTROLE([M]VALEUR30(WI),[M]FIEX3TYP30(WI),[M]FIENOLIB30(WI),
&                        [M]FIELON30(WI),[M]VALINT30(WI)) From FMTVAR
           mkstat=0
      Endif
      [M]VBLCCOD30(WI)   = [F:AYN]VALBLCCOD : Call SETZENTCODCOD30([F:AYN]VALBLCCOD, WI)
      [M]VFIELNKE30(WI)  = [F:AYN]VALFIELNKE
      [M]VFIECOD30(WI)   = [F:AYN]VALFIECOD
      Call FIEKEY_COD([F:AYN]VALFIELNKE, [F:AYN]VALFIECOD, [M]VFIEKEY30(WI)) From SUBAYF
      [M]ALLSTAR30(WI)   = [F:AYN]ALLSTAR
      [M]CRIOBY30(WI)    = [F:AYN]CRIOBY
      #
      Call SETLIN([M]VALTYP30(WI) , WI)
      WI+=1
   Next
Endif
[M]NUM30=WI
Return

# Gestion Tableau Tri 
######################################################################################
Subprog SRT_TAB(SELTYP,SRTTYP)
Value Integer SELTYP
Value Integer SRTTYP
Local Integer W_FLG

If [L]SRTTYP=1             # Aucune
    Gosub GRIRAZSRT
    End
Endif


Case [M]OBJX3
When "AYB"
    # Actif sur Bloc : Type requete et tri chps
    W_FLG= ( SELTYP=3 & SRTTYP=2 )
When "AYL"
    # Actif sur Dyn. link: Tri chps 
    W_FLG= ( SRTTYP=2 )
Endcase

# 
If W_FLG 
   # Activation tableau TRI
    If clalev([M:AYB1])> 0
     Actzo [M:AYB1]BLCNBRLIN
     Actzo [M:AYB1]LINNBROBC
     Effzo [M:AYB1]BLCNBRLIN
     Effzo [M:AYB1]LINNBROBC  
    Endif
    Actzo [M:AYB4]SRTDYNALT
    Raz [F:AYN]
    WI=0
    If [M]SRTTYPFILE=[L]SRTTYP    # L'utilisateur est ou revient sur son choix initial
       For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = [M]LINCODTYP
&                     and LINCOD = toupper([M]LINCOD) and  LINTYP = 31
          [M]FIECOD31(WI)    = [F:AYN]FIECOD
          [M]FLNKENT31(WI)   = [F:AYN]FIELNKENT
          Call FIEKEY_COD([F:AYN]FIELNKENT, [F:AYN]FIECOD, [M]FIEKEY31(WI)) From SUBAYF
          [M]SRTORD31(WI)    = [F:AYN]SRTORD
          WI+=1
       Next
    Endif
    [M]NUM31=WI
Else
    Effzo [M:AYB1]BLCNBRLIN
    Effzo [M:AYB1]LINNBROBC 
    Grizo [M:AYB1]BLCNBRLIN
    Grizo [M:AYB1]LINNBROBC
   [M]SRTDYNALT=1 : Grizo [M:AYB4]SRTDYNALT
Endif
End

######################################################################################
# Chgt AytLines par le mask AYB2
#   La sup. des AYN doit avoir été faites au préalable
Subprog AYB2_AYL()
# 
# Sélection
For WI=0 To [M]NUM30-1
 Raz [F:AYN]
 [F:AYN]FCYCOD    = [M]FCYCOD
 [F:AYN]LINCODTYP = [M]LINCODTYP
 [F:AYN]LINCODSTD = [M]LINCOD
 [F:AYN]LINCOD    = toupper([M]LINCOD)
 [F:AYN]LINTYP    = 30
 [F:AYN]LINNUM    = WI

 [F:AYN]FIECOD      = [M]FIECOD30(WI)
 [F:AYN]FIELNKENT   = [M]FLNKENT30(WI)
 # Forcer et sur 1er ligne ou si valeur incorrecte (cohérence)
 If WI and find([M]ANDOR30(WI),1,2) : [F:AYN]ANDOR       = [M]ANDOR30(WI) : Else : [F:AYN]ANDOR=1 : Endif
 [F:AYN]BRKLFT      = [M]BRKLFTM30(WI)-1
 [F:AYN]BRKRGT      = [M]BRKRGTM30(WI)-1
 [F:AYN]OPE         = [M]OPE30(WI)  
 [F:AYN]VALTYP      = [M]VALTYP30(WI)
 Case [F:AYN]VALTYP
 When 1    # cste
    If [M]FIEX3TYP30(WI)="A"
        [F:AYN]VALEUR = [M]VALEUR30(WI)
    Else
        [F:AYN]VALEUR = [M]VALINT30(WI)
    Endif
 When 2    # chp xtend
    [F:AYN]VALBLCCOD   = [M]VBLCCOD30(WI)
    [F:AYN]VALFIELNKE  = [M]VFIELNKE30(WI)
    [F:AYN]VALFIECOD   = [M]VFIECOD30(WI)
 When 3    # chp web
    [F:AYN]VALEUR = [M]VALEUR30(WI)
 Endcase
 [F:AYN]ALLSTAR     = [M]ALLSTAR30(WI)
 [F:AYN]CRIOBY      = [M]CRIOBY30(WI)

 Write [AYN]
 If fstat
  GOK=0 : Call FSTA("AYN") From GLOCK : Break
 Endif
Next
If GOK<>1 : Goto AYB2_AYL_E : Endif

# Tri
If [M]SRTTYP<>2 : Goto AYB2_AYL_E : Endif
For WI=0 To [M]NUM31-1
 Raz [F:AYN]
 [F:AYN]FCYCOD    = [M]FCYCOD
 [F:AYN]LINCODTYP = [M]LINCODTYP
 [F:AYN]LINCODSTD = [M]LINCOD
 [F:AYN]LINCOD    = toupper([M]LINCOD)
 [F:AYN]LINTYP    = 31
 [F:AYN]LINNUM    = WI

 [F:AYN]FIECOD      = [M]FIECOD31(WI)
 [F:AYN]FIELNKENT   = [M]FLNKENT31(WI)
 [F:AYN]SRTORD      = [M]SRTORD31(WI)

 Write [AYN]
 If fstat
  GOK=0 : Call FSTA("AYN") From GLOCK : Break
 Endif
Next

$AYB2_AYL_E
End



