#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMBUDLIG
###################################################################################################
# EVENTS
###################################################################################################
$AINSERT_CONTROL_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
Return

###################################################################################################
$AUPDATE_CONTROL_BEFORE
Local Char SCUR(GLONCUR)
Local Char SUOM(GLONUOM)
Local Decimal WRATE
Local Integer ISTAT

  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.PLBU <> this.snapshot.PLBU Then
    Call GETRATE_FROMDATE(this.PCCCOD, this.TCHPBUSTRDT, SUOM, SCUR, WRATE) From PJMCOSTCTR_CSTD_PROGS
    If SUOM <> AVOID.ACHAR Then
      If SUOM <> this.PLBU Then
        Call CONVERT_QTY(this.ACTX, this.PLBU, SUOM, WRATE) From TRTX3_SYRA
      Endif
      If SCUR = this.CUR Then
        this.PLBPRIREM = WRATE
      Else
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PCCCOD", mess(236,2260,1), [V]CST_AERROR))
      Endif
    Endif
  Endif
  If (this.PLBQTYREM <> this.snapshot.PLBQTYREM) or (this.PLBPRIREM <> this.snapshot.PLBPRIREM) or (this.PLBAMTREM <> this.snapshot.PLBAMTREM) or (this.PLBFLGREM <> this.snapshot.PLBFLGREM) Then
    # If at least one of them is updated : the PLBDATREM is updated with the current day date
    # => If the PLBDATREM has not yet been updated
    If this.PLBDATREM = this.snapshot.PLBDATREM Then
      this.PLBDATREM = date$
    Endif
  Endif
  If this.PLBDATREM <> this.snapshot.PLBDATREM and this.PLBPRIREM = this.snapshot.PLBPRIREM Then
    # If the date has change, and not the price PLBPRIREM : compute the PLBPRIREM at this date
    Call GETRATE_FROMDATE(this.PCCCOD, this.PLBDATREM, SUOM, SCUR, WRATE) From PJMCOSTCTR_CSTD_PROGS
    If SCUR <> AVOID.ACHAR Then
      # If nothing is done by the subroutine, nothing have to be do in this part
      If SCUR = this.CUR Then
        this.PLBPRIREM = WRATE
      Else
        Call CONVERT(this.ACTX, SCUR, this.CUR, this.CUR, this.TCHCHGTYP, this.PLBDATREM, WRATE, WRATE, ISTAT) From TRTDEV_SYRA
        If ISTAT = 0 Then
          this.PLBPRIREM = arr(WRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))
        Else
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBPRIREM", mess(236,2260,1), [V]CST_AERROR))
        Endif
      Endif
    Endif
  Endif
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
Return

###################################################################################################
$AINSERT_AUPDATE_CONTROL_BEFORE
Local Instance TECFINOVE Using C_TECFINOVE
Local Decimal A_PLBQTYREC
Local Decimal A_PLBAMTREC
Local Char SCUR(GLONCUR)
Local Char SUOM(GLONUOM)
Local Decimal WRATE
Local Integer ISTAT

  If this.PLBDESAXX = AVOID.ACHAR Then
    this.PLBDESAXX = func PJMCOSTCTR_CSTD_PROGS.GET_DESAXX(this, this.PCCCOD)
  Endif
  If (this.PLBQTY <> this.snapshot.PLBQTY) or (this.PLBPRI <> this.snapshot.PLBPRI) or (this.PLBAMT <> this.snapshot.PLBAMT)  Then
    # If QTY, PRI or AMT property is updated : the PLBDATBUD is updated with the current day date if the date is the same as before and PRI is not 0
    If this.PLBDATBUD = this.snapshot.PLBDATBUD Then
      this.PLBDATBUD = date$
    Endif
  Endif
  If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.PLBDATBUD <> this.snapshot.PLBDATBUD and this.PLBPRI = this.snapshot.PLBPRI) Then
    If this.PLBPRIFRC <> [V]CST_AYES Then
      Call GETRATE_FROMDATE(this.PCCCOD, this.PLBDATBUD, SUOM, SCUR, WRATE) From PJMCOSTCTR_CSTD_PROGS
      If SCUR <> AVOID.ACHAR Then
        # If nothing is done by the subroutine, nothing have to be do in this part
        this.PLBU = SUOM
        If SCUR = this.CUR Then
          this.PLBPRI = WRATE
          this.PLBPRIFRC = [V]CST_ANO            # Issue X3-105813 - 2018-08-29 by FGR : if new PCCCOD unforce the unit price
        Else
          Call CONVERT(this.ACTX, SCUR, this.CUR, this.CUR, this.TCHCHGTYP, this.PLBDATBUD, WRATE, WRATE, ISTAT) From TRTDEV_SYRA
          If ISTAT = 0 Then
            this.PLBPRI = arr(WRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR, "CURRND"))
            this.PLBPRIFRC = [V]CST_ANO          # Issue X3-105813 - 2018-08-29 by FGR : if new PCCCOD unforce the unit price
          Else
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PCCCOD", mess(236,2260,1), [V]CST_AERROR))
          Endif
        Endif
      Endif
    Endif
  Endif
  If this.PLBQTY > 0 and this.PLBPRI > 0 Then
    If this.PLBAMT <> arr(this.PLBQTY * this.PLBPRI, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND")) Then
      this.PLBAMT = arr(this.PLBQTY * this.PLBPRI, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))
    Endif
  Endif
  If this.PLBFLGREM = [V]CST_ANO and this.PLBQTYREM > 0 and this.PLBPRIREM > 0 Then
    If this.PLBAMTREM <> arr(this.PLBQTYREM * this.PLBPRIREM, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND")) Then
      this.PLBAMTREM = arr(this.PLBQTYREM * this.PLBPRIREM, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))
    Endif
  Endif
  If this.PLBFLGREM = [V]CST_ANO Then
    If this.TCHFINOVSESS > 0 Then
      # If we have the financial overview data online.
      TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
      TECFINOVE.SESSION = this.TCHFINOVSESS
      # If update on PLBQTYREM
      If this.PLBQTYREM <> this.snapshot.PLBQTYREM Then
        # Update of PLBQTYEST
        A_PLBQTYREC = fmet TECFINOVE.GET_SUM_PSCQTYX(this.OPPNUM, this.PBUCOD, this.PCCCOD)
        this.PLBQTYREC = A_PLBQTYREC
        If this.PLBQTYREM > 0 Then
          this.PLBQTYEST = this.PLBQTYREM + A_PLBQTYREC
        Else
          If this.PLBQTYREM = 0 and this.PLBFLGREM = [V]CST_ANO Then
            this.PLBQTYEST = 0
          Endif
        Endif
      Else
        If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.PLBQTY <> this.snapshot.PLBQTY) Then
          this.PLBQTYEST = this.PLBQTY
        Endif
      Endif
      # If update on PLBAMTREM or PLBQTYREM
      If (this.PLBAMTREM <> this.snapshot.PLBAMTREM) or (this.PLBQTYREM <> this.snapshot.PLBQTYREM) Then
        # Update of PLBAMTEST
        A_PLBAMTREC = fmet TECFINOVE.GET_SUM_PSCAMTX(this.OPPNUM, this.PBUCOD, this.PCCCOD)
        this.PLBAMTREC = A_PLBAMTREC
        If this.PLBAMTREM > 0 Then
          this.PLBAMTEST = this.PLBAMTREM + A_PLBAMTREC
        Else
          If this.PLBAMTREM = 0 and this.PLBFLGREM = [V]CST_ANO Then
            this.PLBAMTEST = 0
          Endif
        Endif
      Else
        If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.PLBAMT <> this.snapshot.PLBAMT) Then
          this.PLBAMTEST = this.PLBAMT
        Endif
      Endif
      If TECFINOVE <> null Then
        FreeGroup TECFINOVE
        Raz TECFINOVE
      Endif
    Else
      # if not financial overview online
      If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.PLBAMT <> this.snapshot.PLBAMT) Then
        this.PLBAMTEST = this.PLBAMT
      Endif
      If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.PLBQTY <> this.snapshot.PLBQTY) Then
        this.PLBQTYEST = this.PLBQTY
      Endif
      If this.ASTALIN = [V]CST_ANEW Then
        this.PLBAMTREC = this.PLBAMT
        this.PLBQTYREC = this.PLBQTY
      Endif
    Endif
  Else
    If this.snapshot.PLBFLGREM <> this.PLBFLGREM Then
      # Only if the PLBFLGREM value has changed only
      Raz this.PLBQTYREM
      Raz this.PLBPRIREM
      Raz this.PLBAMTREM
      Raz this.PLBQTYREC
      Raz this.PLBAMTREC
      Raz this.PLBQTYEST
      Raz this.PLBAMTEST
    Endif
  Endif
Return

###################################################################################################
$ACONTROL
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  Local File PJMCOSTCTR [PJCC]
  # ---------------------
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(192,2260,1), [V]CST_AFATAL))
    Return
  Endif
  If this.PLBQTY > 0 and this.PLBU = AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBU", mess(233,2260,1), [V]CST_AERROR))
  Endif
  If this.PLBU <> this.snapshot.PLBU Then
    If this.PLBFLGREM = [V]CST_AYES Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBU", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  If (this.PLBPRI > 0 or this.PLBAMT > 0) and this.CUR = AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", mess(235,2260,1), [V]CST_AERROR))
  Endif
  Read [PJCC]PCC0=this.PCCCOD
  If [F:PJCC]PCCFCY <> AVOID.ACHAR Then
    If this.PLBFCY <> [F:PJCC]PCCFCY Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PCCCOD", mess(47,102,1) - "(" + this.PLBFCY + "<>" + [F:PJCC]PCCFCY + ")", [V]CST_AERROR))
    Endif
  Endif
  If this.PLBQTY > 0 and this.PLBPRI > 0 and this.PLBAMT <> arr(this.PLBQTY * this.PLBPRI, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND")) Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBAMT", mess(237,2260,1), [V]CST_AERROR))
  Endif
  If this.PLBFLGREM = [V]CST_ANO Then
    If this.PLBQTYREM > 0 and this.PLBPRIREM > 0 and this.PLBAMTREM <> arr(this.PLBQTYREM * this.PLBPRIREM, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND")) Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBAMTREM", mess(237,2260,1), [V]CST_AERROR))
    Endif
  Endif
  If this.PLBFLGREM = [V]CST_AYES Then
    If this.PLBQTYREM > 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBQTYREM", mess(18,9804,1), [V]CST_AERROR))
    Endif
    If this.PLBPRIREM > 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBPRIREM", mess(18,9804,1), [V]CST_AERROR))
    Endif
    If this.PLBAMTREM > 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBAMTREM", mess(18,9804,1), [V]CST_AERROR))
    Endif
    If this.PLBQTYREC > 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBQTYREC", mess(18,9804,1), [V]CST_AERROR))
    Endif
    If this.PLBAMTREC > 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBQTYREC", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$ADELETE_CONTROL_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(193,2260,1), [V]CST_AFATAL))
    Return
  Endif
Return

