#<AdxTL>@(#)5.0.0.0 $Revision$
#############################################
## Intégration d'un écran
#############################################

$ECRAN
Local Integer NACT , IACT , JACT , KACT , OKACT , MACT , MOK , VACT , INUM
Local Integer FLACTION , OTYPAFF , NBOLD , I , J , SPELIG , IBLOC
Local Integer OKSPV , ADDSPV
MACT = 100
Local Char    TBACT(GLONACT)(1..MACT)
Local Libelle TBTYP(1..MACT)
Local Libelle TBEXE(1..MACT)
Local Libelle TBDIS(1..MACT)
Local Integer TBINT(1..MACT)
Local Integer TBNUM(1..MACT)
Local Libelle TBFLG(1..MACT)
Local Libelle TBVER(1..MACT)
Local Datetime TBUPDDATTIM(1..MACT) :#U11 SCM
Local Datetime TBCREDATTIM(1..MACT) :#U11 SCM
Local Char    TBCREUSR(GLONAUS)(1..MACT) :#U11 SCM
Local Char    TBUPDUSR(GLONAUS)(1..MACT) :#U11 SCM
Local Char    OLD_ACTION(GLONACT)(1..MACT)
Local Libelle OLD_TYPACT(1..MACT)

Local Integer NBBLC
Local Integer BLCRANG(1..dim([F:AMK]RANG))
Local Integer BLCANCPOS(1..dim([F:AMK]RANG))
Local Integer BLCNEWPOS(1..dim([F:AMK]RANG))
#
Local File =DOSSIER(D)+".AMSK"      [AMK2]
#
Raz OKSPV , ADDSPV
Read [AMK]CODMSK = NOMOBJ
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_MSK
      Gosub FIN_OBJ From PATCH
  Else
      # Patch not for scm - ISFULLMOD = 2 when SCM
      If [L]ISFULLMOD<>2
          # specific objet ? only on not scm mode and only on header
          If [F:AMK]CODACT>="X" & !find([F:AMK]CODACT,ACTIV(1..NBACT))
              # specific Objet
              Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN
              OKSPE = 1
              Gosub FIN_OBJ From PATCH
          Else
              NEWOBJ = 0
              Gosub SPELIG
              Gosub TR_MSK
          Endif
      Else
          #ISFULLMOD = 2 when SCM always rewrite no test about spe activity code.
          NEWOBJ = 0
          Gosub SPELIG
          Gosub TR_MSK
      Endif
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:AMK]
      Gosub TR_MSK
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif

LogicClose File [AMK2]
Return


#############################
$DEL_MSK
Call DEBTRANS From GLOCK
Trbegin [AMK]
 Delete [AMP] Where TYPAFF=1 & CODAFF=NOMOBJ
 Delete [AMA] Where TYPAFF=1 & CODAFF=NOMOBJ
 Delete [AMZ] Where CODMSK=NOMOBJ
 Delete [AMK] Curr
 If fstat
      GOK = 0 : ER = 99 : ERFIC = "AMSK"-[F:AMK]CODMSK : Rollback : Return
 Endif
Commit
Call DEL_TRTMSK([L]NOMOBJ,DOSSIER(D)) From MSKDIV
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AMK",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

#############################
$TR_MSK
Call DEBTRANS From GLOCK

Trbegin [AMK] , [AMZ] , [AMA] , [AMP] , [ATX]

 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Un bout d'écran
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "AMK"   : Gosub ECR1
     When "AMZ"   : Gosub ECR2
     When "AMA"   : Gosub ECR3
     When "AMP"   : Gosub ECR4
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
 If FLACTION
  Gosub TRAITE_ACTION : # 3.5.2 bug 14177 Pour respecter l'ordre des actions/champs
  If ER : Goto ABORT : Endif
 Endif

## Effacement zones non spécifiques supprimées

 For [AMZ]CODZON Where CODMSK=NOMOBJ
  If !find([F:AMZ]CODZON,ZONE(1..NBZ))
&  & ([F:AMZ]CODACT<"X" or find([F:AMZ]CODACT,ACTIV(1..NBACT)))
&  & ([F:AMK]ACTBLOC([F:AMZ]NUMBLOC-1)<"X"
&  or find([F:AMK]ACTBLOC([F:AMZ]NUMBLOC-1),ACTIV(1..NBACT)))
   For [AMA] Where TYPAFF=1 & CODAFF=[F:AMZ]CODMSK & CODZON=[F:AMZ]CODZON & ACTION="SPV"
    OKSPV += 1
   Next AMA
   Delete [AMA] Where TYPAFF=1 & CODAFF=[F:AMZ]CODMSK & CODZON=[F:AMZ]CODZON
   Delete [AMP] Where TYPAFF=1 & CODAFF=[F:AMZ]CODMSK & CODZON=[F:AMZ]CODZON
   Delete [AMZ]
  Endif
 Next

Commit

Filter [AMZ]
# X3-109647 01.10.2018
# throw an warning if SPE/SPV field has been orpahned by deletion of block
Filter [AMZ] Where CODMSK=NOMOBJ and CODACT>"X" and NUMBLOC > [F:AMK]NBBLOC
For [AMZ]
     Call ECR_TRACE(func AFNC.MES3(mess(358,115,1),[F:AMZ]CODZON,[F:AMZ]CODMSK,num$([F:AMZ]NUMBLOC)),-1) From GESECRAN
Next
Filter [AMZ]


If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AMK",[F:AMK]CODMSK,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
If OKSPV>0 & ADDSPV>0
 # $1$ actions SPV ont été rajouté sur le vertical déjà en place ($2$ actions SPV): vérifier le traitement $3$
 Call ECR_TRACE(func AFNC.MES3(mess(66,143,1),num$(ADDSPV),num$(OKSPV),[F:AMK]TRTSPV),-1) From GESECRAN
Endif

## Validation de l'écran

Gosub SAV_OPENI From PATCH
If [F:AMK]MDL<>2
 # Dans l'appli X3 , on ne valide que les objets des modules Superviseur, tronc commun, développement
 # 119695: si patch SCM, on valide toujours
 If GPRODUIT<>0 or APPLI<>GDOSX3 or find([F:AMK]MODULE,1,9,10) | (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD = 2)
  Call VALID(NOMOBJ,APPLI,NLANP,LANPATCH,1,MOK) From VALMSK
 Endif
Endif
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Gosub REST_OPENI From PATCH
Return

######################################################
## En-tête écran
######################################################

$ECR1
[F:AMK2]=[F:AMK] :#X3PLAT-2092
FICHIER = "AMSK" : ABR = "AMK"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  # Le nombre de bloc peut être supérieur à cause des spécifiques
  If VARIA="NBBLOC"
#X3PLAT-2092
#   If val(VALEUR)>[F:AMK]NBBLOC or sum([F:AMK]ACTBLOC(0..[F:AMK]NBBLOC-1))=""
#    [F:AMK]NBBLOC = val(VALEUR)
#   Endif
#   OK = 0
  Elsif VARIA="NBRLIG"
   If val(VALEUR)>=[F:AMK]NBRLIG or NEWOBJ : # Si le nb de ligne de l'écran de patché est supérieur ou égal à l'écran courant
    [F:AMK]NBRLIG = val(VALEUR)
   Elsif !SPELIG : # Si pas de spé sur l'écran (et que le nb de ligne de l'écran patché est inférieur à l'écran courant)
    [F:AMK]NBRLIG = val(VALEUR)
   Else
    # Le nb de ligne reste inchangé
   Endif
   OK = 0
  Elsif VARIA="NBRCOL"
   [F:AMK]NBRCOL = max([F:AMK]NBRCOL,val(VALEUR))
   OK = 0
#X3PLAT-2092
#{SAM 122604
# Respect des blocs spécifiques
  Elsif find(VARIA,"ACTBLOC", "BASPAG",   "LNGLIB",   "POSBLOC",  "COLBLOC", "LINBLOC"
&                 ,"HTBLOC",  "LGBLOC",   "NBLIGT",   "OPTION",   "RANG"
&                 ,"STYBLOC", "TYPBLOC",  "DETBLC",   "TITBLOC",  "INTBLOC"
&                 ,"BLOCACT1","BLOCTYPT", "BLOCTYPG", "BLOCPOSG", "BLOCGDEF","BLOCAFFD","BLOCREPD"
&                 ,"BLOCVIEW","BLOCLIEN1","BLOCLIEN2","BLOCLIEN3","BLOCPAR1","BLOCPAR2")
   If [F:AMK2]ACTBLOC(IND)>="X" & !find([AMK2]ACTBLOC(IND),ACTIV(1..NBACT))
    OK = 0
    # Issue 47492 - 2017-09-06 by CCC : restore specific values deleted in VIDE_ZONE
    Assign "[F:"+ABR+"]"+VARIA+"("+num$(IND)+")" With evalue("[F:AMK2]"+VARIA+"("+num$(IND)+")")
   Endif
#SAM 122604}
  Endif
  If !NEWOBJ
   If VARIA="TRTSPE" and !(dim([L]ISFULLMOD)>0 & [L]ISFULLMOD=2) :#U11 patch SCM)
    If [F:AMK]TRTSPE<>"" & TYPPTC<>3
     OK = 0
    Endif
   Elsif VARIA="TRTSPV"
    If [F:AMK]TRTSPV<>""& TYPPTC<>4
     OK = 0
    Endif
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:AMK]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
# test about code act on header Doesn't apply to a SCM environ. on root folder
# but no need to test ISFULLMOD here because test with GDOSX3 is done.
ACVOBJ = [F:AMK]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
  Read [ACV]CODACT = ACVOBJ
  If fstat or [F:ACV]FLACT<>2
      OKOBJ = 0 : Return
  Endif
Endif

#X3PLAT-2092
Gosub TRT_BLC
If GOK = 0 : Return : Endif

If NEWOBJ
  If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDCRE("AMK") From OBJDIV
   Endif
   Write [AMK]
   If fstat
        Call LOG_ERROR_DETAILS(1, "AMK",num$([F:AMK]CODMSK),"") From GLOCK
   Endif
Else
  If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDUPD("AMK") From OBJDIV
  Endif
  Rewrite [AMK]
  If fstat
        Call LOG_ERROR_DETAILS(2, "AMK",num$([F:AMK]CODMSK),"") From GLOCK
  Endif
Endif
If fstat
       GOK = 0 : ER = 99 : ERFIC = "AMSK"-[F:AMK]CODMSK : Return
Endif
Return

#################################
$TRT_BLC
Local Integer NOBLK,IBLC,BLC_SPE,BLC_POS
For NOBLK=0 To [F:AMK]NBBLOC-1
 NBBLC+=1 : IBLC=NBBLC
 BLCRANG(IBLC)=[F:AMK]RANG(NOBLK)
 BLCANCPOS(IBLC)=find([F:AMK]RANG(NOBLK),[F:AMK2]RANG)
 BLCNEWPOS(IBLC)=NBBLC
Next
For NOBLK=0 To [F:AMK2]NBBLOC-1
 BLC_SPE=0
 BLC_POS=find([F:AMK2]RANG(NOBLK),BLCRANG(1..NBBLC))
 If !BLC_POS
  If [F:AMK2]ACTBLOC(NOBLK)>="X" & !find([F:AMK2]ACTBLOC(NOBLK),ACTIV(1..NBACT))
   NBBLC+=1 : IBLC=NBBLC
   BLCRANG(IBLC)=[F:AMK2]RANG(NOBLK)
   BLCANCPOS(IBLC)=NOBLK+1
   BLCNEWPOS(IBLC)=NBBLC
   BLC_SPE=1
  Endif
 Elsif [F:AMK2]ACTBLOC(NOBLK)>="X" & !find([F:AMK2]ACTBLOC(NOBLK),ACTIV(1..NBACT))
  BLC_SPE=1
  IBLC=BLC_POS
 Endif
 If BLC_SPE=1
   [F:AMK]RANG         (BLCNEWPOS(IBLC)-1) = [F:AMK2]RANG        (BLCANCPOS(IBLC)-1)
   [F:AMK]STYBLOC      (BLCNEWPOS(IBLC)-1) = [F:AMK2]STYBLOC     (BLCANCPOS(IBLC)-1)
   [F:AMK]TITBLOC      (BLCNEWPOS(IBLC)-1) = [F:AMK2]TITBLOC     (BLCANCPOS(IBLC)-1)
   [F:AMK]OPTION       (BLCNEWPOS(IBLC)-1) = [F:AMK2]OPTION      (BLCANCPOS(IBLC)-1)
   [F:AMK]LGBLOC       (BLCNEWPOS(IBLC)-1) = [F:AMK2]LGBLOC      (BLCANCPOS(IBLC)-1)
   [F:AMK]NBLIGT       (BLCNEWPOS(IBLC)-1) = [F:AMK2]NBLIGT      (BLCANCPOS(IBLC)-1)
   [F:AMK]HTBLOC       (BLCNEWPOS(IBLC)-1) = [F:AMK2]HTBLOC      (BLCANCPOS(IBLC)-1)
   [F:AMK]INTBLOC      (BLCNEWPOS(IBLC)-1) = [F:AMK2]INTBLOC     (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCTYPG     (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCTYPG    (BLCANCPOS(IBLC)-1)
   [F:AMK]DETBLC       (BLCNEWPOS(IBLC)-1) = [F:AMK2]DETBLC      (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCPOSG     (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCPOSG    (BLCANCPOS(IBLC)-1)
   [F:AMK]TYPBLOC      (BLCNEWPOS(IBLC)-1) = [F:AMK2]TYPBLOC     (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCTYPT     (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCTYPT    (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCACT1     (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCACT1    (BLCANCPOS(IBLC)-1)
   [F:AMK]LINBLOC      (BLCNEWPOS(IBLC)-1) = [F:AMK2]LINBLOC     (BLCANCPOS(IBLC)-1)
   [F:AMK]COLBLOC      (BLCNEWPOS(IBLC)-1) = [F:AMK2]COLBLOC     (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCLIEN2    (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCLIEN2   (BLCANCPOS(IBLC)-1)
   [F:AMK]BASPAG       (BLCNEWPOS(IBLC)-1) = [F:AMK2]BASPAG      (BLCANCPOS(IBLC)-1)
   [F:AMK]ACTBLOC      (BLCNEWPOS(IBLC)-1) = [F:AMK2]ACTBLOC     (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCLIEN3    (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCLIEN3   (BLCANCPOS(IBLC)-1)
   [F:AMK]POSBLOC      (BLCNEWPOS(IBLC)-1) = [F:AMK2]POSBLOC     (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCLIEN1    (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCLIEN1   (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCPAR2     (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCPAR2    (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCVIEW     (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCVIEW    (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCGDEF     (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCGDEF    (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCPAR1     (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCPAR1    (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCAFFD     (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCAFFD    (BLCANCPOS(IBLC)-1)
   [F:AMK]LNGLIB       (BLCNEWPOS(IBLC)-1) = [F:AMK2]LNGLIB      (BLCANCPOS(IBLC)-1)
   [F:AMK]BLOCREPD     (BLCNEWPOS(IBLC)-1) = [F:AMK2]BLOCREPD    (BLCANCPOS(IBLC)-1)
 Endif
Next
[F:AMK]NBBLOC=NBBLC

If NEWOBJ=1 : Return : Endif

#fill RANG if not yet filled on old blocks
If dim([F:AMZ]RANG)>0
 For IBLC=1 To NBBLC
  If BLCANCPOS(IBLC)<>0
   Update [AMZ] Where  [AMZ]CODMSK=[AMK]CODMSK & [AMZ]RANG=0 & [AMZ]NUMBLOC=BLCANCPOS(IBLC)
&  With [AMZ]RANG=BLCRANG(IBLC)
   If fstat
    Call ERREUR("AMSKZON"-[AMK]CODMSK-"NUMBLOC="+num$(BLCANCPOS(IBLC))-"RANG->"+num$(BLCRANG(IBLC)),2) From DOSDIC
    GOK = 0 : ER = 99 : ERFIC = "AMSK"-[F:AMK]CODMSK : Return
   Endif
  Endif
 Next IBLC
Endif

#change block position to fill new position on all fields
 For IBLC=1 To NBBLC
  If BLCANCPOS(IBLC)<>0 & BLCANCPOS(IBLC)<>BLCNEWPOS(IBLC)
   Update [AMZ] Where  [AMZ]CODMSK=[AMK]CODMSK & [AMZ]NUMBLOC=BLCANCPOS(IBLC)
&  With [AMZ]NUMBLOC=BLCNEWPOS(IBLC)+50
   If fstat
    Call ERREUR("AMSKZON"-[AMK]CODMSK-"NUMBLOC="+num$(BLCANCPOS(IBLC))-"NUMBLOC->"+num$(BLCNEWPOS(IBLC)+50),2) From DOSDIC
    GOK = 0 : ER = 99 : ERFIC = "AMSK"-[F:AMK]CODMSK : Return
   Endif
  Endif
 Next IBLC

 For IBLC=1 To NBBLC
  If BLCANCPOS(IBLC)<>0 & BLCANCPOS(IBLC)<>BLCNEWPOS(IBLC)
   Update [AMZ] Where  [AMZ]CODMSK=[AMK]CODMSK & [AMZ]NUMBLOC=BLCNEWPOS(IBLC)+50
&  With [AMZ]NUMBLOC=BLCNEWPOS(IBLC)
   If fstat
    Call ERREUR("AMSKZON"-[AMK]CODMSK-"NUMBLOC="+num$(BLCANCPOS(IBLC))-"NUMBLOC->"+num$(BLCNEWPOS(IBLC)),2) From DOSDIC
    GOK = 0 : ER = 99 : ERFIC = "AMSK"-[F:AMK]CODMSK : Return
   Endif
  Endif
 Next IBLC


Return

#################################
$SPELIG
Local Integer SPELIG
SPELIG = 0
If NEWOBJ : # or GADONIX<>2
 SPELIG = 1
Else
 For IBLOC=0 To min([F:AMK]NBLIGT-1,dim([F:AMK]ACTBLOC)-1)
  If [F:AMK]ACTBLOC(IBLOC)<>""
   If [F:AMK]ACTBLOC(IBLOC)>="X" & !find([F:AMK]ACTBLOC(IBLOC),ACTIV(1..NBACT))
    SPELIG = 1 : Break
   Endif
  Endif
 Next IBLOC
 If !SPELIG
  For [AMZ]CODE Where CODMSK=[F:AMK]CODMSK
   If [F:AMZ]CODACT<>""
    If [F:AMZ]CODACT>="X" & !find([F:AMZ]CODACT,ACTIV(1..NBACT))
     SPELIG = 1 : Break
    Endif
   Endif
  Next AMZ
 Endif
Endif
Return

##############################################################
## Zones
##############################################################

$ECR2
Local Integer WFLDRANG : WFLDRANG=0: #X3PLAT-2092
If FLACTION : Gosub TRAITE_ACTION : Endif
NBZ += 1 : ZONE(NBZ) = IDENT
FICHIER = "AMSKZON" : ABR = "AMZ"
Read [AMZ]CODE = NOMOBJ;IDENT
If fstat
 NEWZON = 1
 OLDACT = ""
 Raz [F:AMZ]
Elsif ([F:AMZ]CODACT>="X" & !find([F:AMZ]CODACT,ACTIV(1..NBACT)))
&  | ([F:AMK]ACTBLOC([F:AMZ]NUMBLOC-1)>="X"
&  & !find([F:AMK]ACTBLOC([F:AMZ]NUMBLOC-1),ACTIV(1..NBACT)))
# Zone spécifique
 Call ECR_TRACE([F:AMZ]CODZON-mess(147,126,1)-"("+[F:AMZ]CODACT+")",0) From GESECRAN
# Zone spécifique
 Gosub FIN_FIC From PATCH
 OLDACT = [F:AMZ]CODACT
 Return
Else
 NEWZON = 0
 OLDACT = [F:AMZ]CODACT
Endif
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If VARIA="RANG" : #X3PLAT-2092
  WFLDRANG=val(VALEUR)
 Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
# Respect des codes d'accès, table de contrôle, aide
#  If VARIA="MOTCLE"
#   If [F:AMZ]MOTCLE>="X" & TYPPTC<>3
#    OK = 0
#   Endif
#  Else
  If find(VARIA,"CODACC","CODCTL","STYZON","STYCND","INTSTYL") and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
   If evalue("[F:AMZ]"+VARIA)<>""
    OK = 0
   Endif
  Endif
#  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

#X3PLAT-2092
If WFLDRANG & WFLDRANG>0
 [F:AMZ]NUMBLOC=find(WFLDRANG,BLCRANG(1..NBBLC))
Endif
If dim([F:AMZ]RANG)>0 & [F:AMZ]RANG=0 & [F:AMZ]NUMBLOC<>0
 [F:AMZ]RANG=BLCRANG([F:AMZ]NUMBLOC)
Endif
#

If NEWZON
 Write [AMZ]
Else
 Rewrite [AMZ]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AMSKZON"-[F:AMZ]CODMSK-[F:AMZ]CODZON : Return
Endif

# Chargement du tableau des actions

## Pour garder l'ordre, on numérote (TBNUM) les actions STD 100,200,300...
## et les spécifiques 101,102, 201 ,...

NACT = 0
For [AMA]TYPAFF(4) Where TYPAFF=1 & CODAFF=[F:AMZ]CODMSK & CODZON=[F:AMZ]CODZON
 IACT = 0
 JACT = 0
 For [AMA]TYPAFF
  NACT += 1
  VACT = 0
  If [F:AMA]ACTION="SPE" or [F:AMA]ACTION="SPV"
   JACT += 1
  Else
   Read [ACT]ACTION=[F:AMA]ACTION
   If !fstat & [F:ACT]CODACT>="X" & find([F:ACT]CODACT,ACTIV(1..NBACT))
    VACT = 1
    JACT += 1
   Elsif [F:AMA]ACTION>="X"
    JACT += 1
   Else
    IACT += 1
    JACT  = 0
   Endif
  Endif
  TBACT(NACT) = [F:AMA]ACTION
  TBTYP(NACT) = [F:AMA]TYPACT
  TBEXE(NACT) = [F:AMA]EXEACT
  TBDIS(NACT) = [F:AMA]DISACT
  TBINT(NACT) = [F:AMA]INTITACT
  TBNUM(NACT) = 100*IACT+JACT
  TBVER(NACT) = VACT
  TBFLG(NACT) = 0
  If (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD=2) :#U11 patch SCM
   TBUPDDATTIM(NACT) = [F:AMA]UPDDATTIM
   TBCREDATTIM(NACT) = [F:AMA]CREDATTIM
   TBCREUSR(NACT) = [F:AMA]CREUSR
   TBUPDUSR(NACT) = [F:AMA]UPDUSR
  Endif
 Next AMA
Next AMA(4)
FLACTION = 1
OTYPAFF  = 0
Return

###################################################################
$TRAITE_ACTION
If (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD=2) :#U11 patch SCM
Sorta NACT TBACT,TBTYP,TBEXE,TBINT,TBNUM,TBVER,TBFLG,TBDIS,TBUPDDATTIM,TBCREDATTIM,TBCREUSR,TBUPDUSR Order By TBTYP(indice+1),TBNUM(indice+1)
Else
Sorta NACT TBACT,TBTYP,TBEXE,TBINT,TBNUM,TBVER,TBFLG,TBDIS Order By TBTYP(indice+1),TBNUM(indice+1)
Endif
For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=[F:AMZ]CODMSK & CODZON=[F:AMZ]CODZON
 NBOLD += 1
 OLD_TYPACT(NBOLD) = [F:AMA]TYPACT
 OLD_ACTION(NBOLD) = [F:AMA]ACTION
Next AMA
Delete [AMA] Where TYPAFF=1 & CODAFF=[F:AMZ]CODMSK & CODZON=[F:AMZ]CODZON
For IACT=1 To NACT
 # Type de patch : Nor/Sup/Spé/Vert/Add
 If TBFLG(IACT)=1 or (TBACT(IACT)="SPE" & TYPPTC<>3) or (TBACT(IACT)="SPV" & TYPPTC<>4)
&                 or (TBVER(IACT)=0 & TBACT(IACT)>="X")
  [F:AMA]TYPAFF   = 1
  [F:AMA]CODAFF   = [F:AMZ]CODMSK
  [F:AMA]CODZON   = [F:AMZ]CODZON
  [F:AMA]TYPACT   = TBTYP(IACT)
  [F:AMA]NOACT    = IACT
  [F:AMA]ACTION   = TBACT(IACT)
  [F:AMA]EXEACT   = TBEXE(IACT)
  [F:AMA]DISACT   = TBDIS(IACT)
  [F:AMA]INTITACT = TBINT(IACT)
  If (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD=2) :#U11 patch SCM
   [F:AMA]UPDDATTIM =TBUPDDATTIM(IACT)
   [F:AMA]CREDATTIM =TBCREDATTIM(IACT)
   [F:AMA]CREUSR = TBCREUSR(IACT)
   [F:AMA]UPDUSR =TBUPDUSR(IACT)
  Endif
  Write [AMA]
  If fstat
   GOK = 0 : ER = 99 : Call FSTA("AMA") From GLOCK : Break
  Endif
 Endif
Next IACT
Gosub SAV_OPENI From PATCH
For I=1 To NBOLD
 If TYPPTC<>4 & OLD_ACTION(I)="SPV"
  OKSPV += 1
 Endif
 J = 0
 For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=[F:AMZ]CODMSK & CODZON=[F:AMZ]CODZON & TYPACT=OLD_TYPACT(I) & ACTION=OLD_ACTION(I)
  J = 1 : Break
 Next
 If !J
  # Type de patch : Nor/Sup/Spé/Vert/Add
  If TYPPTC>2
   For IACT=1 To NACT
    If OLD_TYPACT(I)=TBTYP(IACT) & OLD_ACTION(I)=TBACT(IACT)
     If TYPPTC=3 & (TBVER(IACT)>0 or TBACT(IACT)<"X")
      J = -1 : Break
     Elsif TYPPTC=4 & (TBACT(IACT)<"X" & TBVER(IACT)=0)
      J = -1 : Break
     Endif
    Endif
   Next IACT
  Endif
  # Champ/Actions supprimées
  Call ECR_TRACE(" "-mess(36,124,1)-":"-[F:AMZ]CODZON-mess(65,127,1)-"->"-mess(OLD_TYPACT(I),31,1)-OLD_ACTION(I),J) From GESECRAN
 Endif
Next I
If TYPPTC<>4
 For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=[F:AMZ]CODMSK & CODZON=[F:AMZ]CODZON & ACTION="SPV"
  K = 0
  For I=1 To NBOLD
   If [F:AMA]TYPACT=OLD_TYPACT(I) & [F:AMA]ACTION=OLD_ACTION(I)
    K = 1 : Break
   Endif
  Next I
  If !K
   If OKSPV>0 : # on n'affiche le message que s'il y avait déjà une action SPV dans l'écran
    # Champ/Action ajoutée
    Call ECR_TRACE(" "-mess(36,124,1)-":"-[F:AMZ]CODZON-mess(65,143,1)-"->"-mess([F:AMA]TYPACT,31,1)-[F:AMA]ACTION,-1) From GESECRAN
   Endif
   ADDSPV += 1
  Endif
 Next AMA
Endif
Gosub REST_OPENI From PATCH
Raz NBOLD,OLD_TYPACT,OLD_ACTION
FLACTION = 0
Return

##############################################################
## Actions
##############################################################

$ECR3
FICHIER = "AMSKACT" : ABR = "AMA"
Read [AMZ]CODE = NOMOBJ;IDENT
If !fstat & OLDACT>="X" & !find(OLDACT,ACTIV(1..NBACT)): # Zone spécifique
 Gosub FIN_FIC From PATCH
 Return
Endif
Raz [F:AMA]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

## On n'intègre pas les actions inexistantes

Read [ACT]ACTION = [F:AMA]ACTION
If fstat & !find([F:AMA]ACTION,"STD","SPV","ZSPE","ZSPV")
  # Issue 88063 - 2013-03-11 by VPO : message uniquement si dossier mère
  If [F:ADS]DOSSIER=GDOSX3
   If (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD=2) :#U11 patch SCM
    # Issue 86750 - 2013-01-08 by VPO : erreur si action inexistante
    Call ECR_TRACE(" "-mess(36,124,1)-":"-[F:AMZ]CODZON-mess(65,127,1)-"->"-mess([F:AMA]TYPACT,31,1)-[F:AMA]ACTION-"("+mess(84,133,1)+")",-1) From GESECRAN
   Else
    # Issue 86750 - 2013-01-08 by VPO : erreur si action inexistante
    Call ECR_TRACE(" "-mess(36,124,1)-":"-[F:AMZ]CODZON-mess(65,127,1)-"->"-mess([F:AMA]TYPACT,31,1)-[F:AMA]ACTION-"("+mess(84,133,1)+")",1) From GESECRAN
   Endif
  Endif
 Return
Endif

## Grosse astuce pour virer les actions spécifiques (à voir)

If [F:AMA]ACTION="ZSPE" : # On annule toutes les actions SPE de même type
 IACT = 1
 While IACT<=NACT
  If TBTYP(IACT)=[F:AMA]TYPACT & (TBACT(IACT)="SPE" or (TBVER(IACT)=1 & TYPPTC=3))
   If (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD=2) :#U11 patch SCM
    Dela IACT,1,NACT TBACT,TBTYP,TBEXE,TBINT,TBNUM,TBFLG,TBVER,TBDIS,TBUPDDATTIM,TBCREDATTIM,TBCREUSR,TBUPDUSR
   Else
    Dela IACT,1,NACT TBACT,TBTYP,TBEXE,TBINT,TBNUM,TBFLG,TBVER,TBDIS
   Endif
   NACT -= 1
  Else
   IACT += 1
  Endif
 Wend
 Return
Endif

## Grosse astuce pour virer les actions verticales (à voir)

If [F:AMA]ACTION="ZSPV" : # On annule toutes les actions SPV de même type
 IACT = 1
 While IACT<=NACT
  If TBTYP(IACT)=[F:AMA]TYPACT & (TBACT(IACT)="SPV" or (TBVER(IACT)=1 & TYPPTC=4))
   If (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD=2) :#U11 patch SCM
    Dela IACT,1,NACT TBACT,TBTYP,TBEXE,TBINT,TBNUM,TBFLG,TBVER,TBDIS,TBUPDDATTIM,TBCREDATTIM,TBCREUSR,TBUPDUSR
   Else
    Dela IACT,1,NACT TBACT,TBTYP,TBEXE,TBINT,TBNUM,TBFLG,TBVER,TBDIS
   Endif
   NACT -= 1
  Else
   IACT += 1
  Endif
 Wend
 Return
Endif

If [F:AMA]TYPACT<>OTYPAFF
 OTYPAFF = [F:AMA]TYPACT
 JACT = 1
Else
 JACT += 1
Endif
OKACT = 0
For IACT=1 To NACT
 If TBTYP(IACT)=[F:AMA]TYPACT & TBACT(IACT)=[F:AMA]ACTION
  # Type de patch : Nor/Sup/Spé/Vert/Add
  If ([F:AMA]ACTION="SPE" & TYPPTC=3) or ([F:AMA]ACTION="SPV" & TYPPTC=4) or TBVER(IACT)>0
   TBDIS(IACT) = [F:AMA]DISACT
   TBEXE(IACT) = [F:AMA]EXEACT
   TBINT(IACT) = [F:AMA]INTITACT
   TBFLG(IACT) = 1
   If (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD=2) :#U11 patch SCM
    TBUPDDATTIM(IACT) = [F:AMA]UPDDATTIM
    TBCREDATTIM(IACT) = [F:AMA]CREDATTIM
    TBCREUSR(IACT) = [F:AMA]CREUSR
    TBUPDUSR(IACT) = [F:AMA]UPDUSR
   Endif
   OKACT = 1
   Break
  Elsif find([F:AMA]ACTION,"SPE","SPV") or [F:AMA]ACTION>="X" or ([F:ACT]CODACT>="X" & find([F:ACT]CODACT,ACTIV(1..NBACT)))
   OKACT = 1
   Break
  Else
   If TBNUM(IACT)<>100*JACT
    INUM = int(TBNUM(IACT)/100)
    TBNUM(IACT) = 100*JACT
    For KACT=1 To NACT
     If TBTYP(KACT)=[F:AMA]TYPACT & int(TBNUM(KACT)/100)=INUM & mod(TBNUM(KACT),100)<>0
      TBNUM(KACT) = 100*JACT+mod(TBNUM(KACT),100)
     Endif
    Next KACT
   Endif
   TBDIS(IACT) = [F:AMA]DISACT
   TBEXE(IACT) = [F:AMA]EXEACT
   TBINT(IACT) = [F:AMA]INTITACT
   TBNUM(IACT) = 100*JACT
   TBFLG(IACT) = 1
   If (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD=2) :#U11 patch SCM
    TBUPDDATTIM(IACT) = [F:AMA]UPDDATTIM
    TBCREDATTIM(IACT) = [F:AMA]CREDATTIM
    TBCREUSR(IACT) = [F:AMA]CREUSR
    TBUPDUSR(IACT) = [F:AMA]UPDUSR
   Endif
   OKACT = 1
   Break
  Endif
 Endif
Next IACT
If !OKACT
 NACT += 1
 TBACT(NACT) = [F:AMA]ACTION
 TBTYP(NACT) = [F:AMA]TYPACT
 TBDIS(NACT) = [F:AMA]DISACT
 TBEXE(NACT) = [F:AMA]EXEACT
 TBINT(NACT) = [F:AMA]INTITACT
 If [F:ACT]CODACT>="X" & find([F:ACT]CODACT,ACTIV(1..NBACT))
  TBVER(NACT) = 1
 Endif
 TBNUM(NACT) = 100*JACT
 TBFLG(NACT) = 1
 If (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD=2) :#U11 patch SCM
  TBUPDDATTIM(NACT) = [F:AMA]UPDDATTIM
  TBCREDATTIM(NACT) = [F:AMA]CREDATTIM
  TBCREUSR(NACT) = [F:AMA]CREUSR
  TBUPDUSR(NACT) = [F:AMA]UPDUSR
 Endif
Endif
Return

##############################################################
## Paramètres
##############################################################

$ECR4
FICHIER = "AMSKPAR" : ABR = "AMP"
Read [AMZ]CODE = NOMOBJ;IDENT
If !fstat & OLDACT>="X" & !find(OLDACT,ACTIV(1..NBACT)) : # Zone spécifique
 Gosub FIN_FIC From PATCH
 Return
Endif
Raz [F:AMP]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
Delete [AMP2] Where TYPAFF=1 & CODAFF=NOMOBJ & CODZON=[F:AMP]CODZON & CODPAR=[F:AMP]CODPAR
Write [AMP]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AMSKPAR"-[F:AMP]CODAFF-[F:AMP]CODZON : Return
Endif
Return

$ABORT
Rollback
Return

#############################################
## Intégration d'une fenêtre
#############################################
$FENETRE
Local Integer MOK
Read [AWI]AWI0 = NOMOBJ
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_AWI
      Gosub FIN_OBJ From PATCH
  Else
      # Patch not for scm - ISFULLMOD = 2 when SCM
      If [L]ISFULLMOD<>2
          # specific objet ? only on not scm mode and only on header
          If [F:AWI]CODACT>="X" & !find([F:AWI]CODACT,ACTIV(1..NBACT))
              # specific Objet
              Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN
              OKSPE = 1
              Gosub FIN_OBJ From PATCH
          Else
              NEWOBJ = 0
              Gosub TR_FEN
          Endif
      Else
          #ISFULLMOD = 2 when SCM always rewrite no test about spe activity code.
          NEWOBJ = 0
          Gosub TR_FEN
      Endif
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:AWI]
      Gosub TR_FEN
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif
Return

#-------------------#
# deletion at the moment only for scm
#-------------------#
$DEL_AWI
Call DEBTRANS From GLOCK
Trbegin [AWI]
 Delete [AWP] Where WIN=[L]NOMOBJ
 Delete [AWB] Where WIN=[L]NOMOBJ
 Delete [AWT] Where WIN=[L]NOMOBJ
 Delete [AWI] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "AWINDOW"-[L]NOMOBJ : Rollback : Return
 Endif
Commit
Call DEL_TRTWIN([L]NOMOBJ,DOSSIER(D)) From MSKDIV
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AWI",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

#-----------------------------#
#-----------------------------#
$TR_FEN
Call DEBTRANS From GLOCK
Trbegin [AWI] , [AWP] , [AWB] , [AWT] , [ATX]
 Gosub LECWIN
 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Un bout de fenêtre
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "AWI"   : Gosub FEN1
     When "AWP"   : Gosub FEN2
     When "AWB"   : Gosub FEN3
     When "AWT"   : Gosub FEN4
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
 Gosub ECRWIN
 If ER : Goto ABORT : Endif
Commit

## Validation de la fenêtre
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AWI",[F:AWI]WIN,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif

Gosub SAV_OPENI From PATCH
If [F:AWI]MDL<>2
 # Dans l'appli X3 , on ne valide que les objets des modules Superviseur, tronc commun, développement
 If (GPRODUIT<>0 or APPLI<>GDOSX3 or find([F:AWI]MODULE,1,9,10) ) and func AFNC.IS_VALIDATION_ENABLED(APPLI,[F:AWI]CODACT,[F:AWI]MODULE) :#SAM 121394
  Call VALID(NOMOBJ,APPLI,1,MOK) From VALWIN
  If [F:AWI]OBJ<>""
   Call VALID([F:AWI]OBJ,APPLI,1,MOK) From VALOBJ
  Endif
 Endif
Endif
Gosub REST_OPENI From PATCH
Return

##############################################################
## En-tête fenêtre
##############################################################

$FEN1 : # AWI
FICHIER = "AWINDOW" : ABR = "AWI"
[F:AWI2] = [F:AWI]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
# Issue 85605 - 2012-11-05 by VPO : on prend les masques du patch puis on reprend les SPE
## Le nombre de masques peut être supérieur à cause des spécifiques
#  If VARIA="NBMSK"
#   If val(VALEUR)>[F:AWI2]NBMSK or sum([F:AWI2]ACTMSK(0..[F:AWI2]NBMSK-1))=""
#    [F:AWI]NBMSK = val(VALEUR)
#   Endif
#   OK = 0
#  Elsif !NEWOBJ & find(VARIA,"ACS","ENAFLG") : # mb 20.7.6
#   OK = 0
## Respect des masques spécifiques
#  Elsif find(VARIA,"ACTMSK","NOMMSK","INTMSK","FLGMSK","ROWMSK")
#   If [F:AWI2]ACTMSK(IND)>="X" & !find([F:AWI2]ACTMSK(IND),ACTIV(1..NBACT))
#    OK = 0
#   Endif
#  Endif
  If !NEWOBJ & find(VARIA,"ACS","ENAFLG") and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) : # mb 20.7.6
   OK = 0
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

# Issue 85605 - 2012-11-05 by VPO : on prend les masques du patch puis on reprend les SPE
If !NEWOBJ
 Local Integer NOMSK
 For NOMSK=0 To [F:AWI2]NBMSK-1
  If [F:AWI2]ACTMSK(NOMSK)>="X" & !find([F:AWI2]ACTMSK(NOMSK),ACTIV(1..NBACT))
    K=find([F:AWI2]NOMMSK(NOMSK),[F:AWI]NOMMSK(0..[F:AWI]NBMSK-1))
    If K
      [F:AWI]NOMMSK(K-1)=[F:AWI2]NOMMSK(NOMSK)
      [F:AWI]INTMSK(K-1)=[F:AWI2]INTMSK(NOMSK)
      [F:AWI]ACTMSK(K-1)=[F:AWI2]ACTMSK(NOMSK)
      [F:AWI]FLGMSK(K-1)=[F:AWI2]FLGMSK(NOMSK)
      [F:AWI]ROWMSK(K-1)=[F:AWI2]ROWMSK(NOMSK)
      [F:AWI]INTFOLD(K-1)=[F:AWI2]INTFOLD(NOMSK)
    # Issue 86030 - 2012-12-03 by VPO : ajout contrôle nombre d'éléments patchés
    Elsif [F:AWI]NBMSK>=dim([F:AWI]NOMMSK)
      Call ECR_TRACE("[F:AWI]NOMMSK"-mess(26,100,1),1) From GESECRAN : # Tableau plein
      GOK=0
      ER = 99 : Break
    Else
      K=[F:AWI]NBMSK
      [F:AWI]NBMSK+=1
      [F:AWI]NOMMSK(K)=[F:AWI2]NOMMSK(NOMSK)
      [F:AWI]INTMSK(K)=[F:AWI2]INTMSK(NOMSK)
      [F:AWI]ACTMSK(K)=[F:AWI2]ACTMSK(NOMSK)
      [F:AWI]FLGMSK(K)=[F:AWI2]FLGMSK(NOMSK)
      [F:AWI]ROWMSK(K)=[F:AWI2]ROWMSK(NOMSK)
      [F:AWI]INTFOLD(K)=[F:AWI2]INTFOLD(NOMSK)
    Endif
  Endif
 Next NOMSK
Endif
If ER : Return : Endif

MODOBJ = max(1,[F:AWI]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
# test about code act on header Doesn't apply to a SCM environ. on root folder
# but no need to test ISFULLMOD here because test with GDOSX3 is done.
ACVOBJ = [F:AWI]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
  Read [ACV]CODACT = ACVOBJ
  If fstat | [F:ACV]FLACT<>2
      OKOBJ = 0 : Return
  Endif
Endif
For K=0 To dim([F:AWI]ACTSTD)-1
 If [F:AWI]ACTSTD(K)<>""
  Read [ACT]ACTION = [F:AWI]ACTSTD(K)
  If fstat
   [F:AWI]ACTSTD(K) = ""
  Endif
 Endif
Next K
Return

##############################################################
## Paramètres
##############################################################

$FEN2 : # AWP
FICHIER = "AWINPAR" : ABR = "AWP"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
#### Remplissage du tableau des parametres d'action du patch (tous)
If [F:AWP]NUM<100
  P_NBPAR += 1
  P_PARBOU(P_NBPAR) = [F:AWP]NUM
  P_NOPAR(P_NBPAR)  = [F:AWP]NOPAR
  P_PARAM(P_NBPAR)  = [F:AWP]PARAM
  P_VALEUR(P_NBPAR) = [F:AWP]VALEUR
Else
 P_NBPAR += 1
 P_PARBOU(P_NBPAR) = [F:AWP]NUM
 P_NOPAR(P_NBPAR)  = [F:AWP]NOPAR
 P_PARAM(P_NBPAR)  = [F:AWP]PARAM
 P_VALEUR(P_NBPAR) = [F:AWP]VALEUR
Endif
Return

##############################################################
## Browsers
##############################################################

$FEN3 : # AWB
FICHIER = "AWINBRO" : ABR = "AWB"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
For K=0 To [F:AWB]NBLIS-1
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  If !find([F:AWB]OBJLIS(K)+"~"+[F:AWB]ABRLIS(K),P_OBJABR(1..P_NBBRO)) & [F:AWB]OBJLIS(K)<>"ALI"
   ## On n'intègre plus les browsers inexistants
   Read [AOB]ABREV = [F:AWB]OBJLIS(K)
   If !fstat
    P_NBBRO += 1
    P_OBJABR(P_NBBRO) = [F:AWB]OBJLIS(K)+"~"+[F:AWB]ABRLIS(K)
    P_OBJLIS(P_NBBRO) = [F:AWB]OBJLIS(K)
    P_INTLIS(P_NBBRO) = [F:AWB]INTLIS(K)
    P_CLELIS(P_NBBRO) = [F:AWB]CLELIS(K)
    P_ORDLIS(P_NBBRO) = [F:AWB]ORDLIS(K)
    P_TRELIS(P_NBBRO) = [F:AWB]TRELIS(K)
    P_BROLIS(P_NBBRO) = [F:AWB]BROLIS(K)
    P_ROWLIS(P_NBBRO) = [F:AWB]ROWLIS(K)
    P_CHGLIS(P_NBBRO) = [F:AWB]CHGLIS(K)
    P_ABRLIS(P_NBBRO) = [F:AWB]ABRLIS(K)
    P_ACTLIS(P_NBBRO) = [F:AWB]ACTLIS(K)
    P_EXPLIS(P_NBBRO) = [F:AWB]EXPLIS(K)
    P_FLELIS(P_NBBRO) = [F:AWB]FLELIS(K)
   Endif
  Endif
 Else
  If !find([F:AWB]OBJLIS(K)+"~"+[F:AWB]ABRLIS(K),P_OBJABR(1..P_NBBRO))
   ## On n'intègre plus les browsers inexistants
   Read [AOB]ABREV = [F:AWB]OBJLIS(K)
   If !fstat
    P_NBBRO += 1
    P_OBJABR(P_NBBRO) = [F:AWB]OBJLIS(K)+"~"+[F:AWB]ABRLIS(K)
    P_OBJLIS(P_NBBRO) = [F:AWB]OBJLIS(K)
    P_INTLIS(P_NBBRO) = [F:AWB]INTLIS(K)
    P_CLELIS(P_NBBRO) = [F:AWB]CLELIS(K)
    P_ORDLIS(P_NBBRO) = [F:AWB]ORDLIS(K)
    P_TRELIS(P_NBBRO) = [F:AWB]TRELIS(K)
    P_BROLIS(P_NBBRO) = [F:AWB]BROLIS(K)
    P_ROWLIS(P_NBBRO) = [F:AWB]ROWLIS(K)
    P_CHGLIS(P_NBBRO) = [F:AWB]CHGLIS(K)
    P_ABRLIS(P_NBBRO) = [F:AWB]ABRLIS(K)
    P_ACTLIS(P_NBBRO) = [F:AWB]ACTLIS(K)
    P_EXPLIS(P_NBBRO) = [F:AWB]EXPLIS(K)
    P_FLELIS(P_NBBRO) = [F:AWB]FLELIS(K)
   Endif
  Endif
 Endif
Next K
Return

##############################################################
## Boutons
##############################################################

$FEN4 : # AWT
FICHIER = "AWINBOUT" : ABR = "AWT"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
# On raze l'action inexistante
If [F:AWT]ACTBOUT<>""
 Read [ACT]ACTION = [F:AWT]ACTBOUT
 If fstat
  [F:AWT]ACTBOUT = ""
 Endif
Endif
### Remplissage du tableau des boutons du patch(tous)
P_NBBOUT += 1
P_NUMBOUT(P_NBBOUT)    = [F:AWT]NUM
P_CODBOUT(P_NBBOUT)    = [F:AWT]CODBOUT
P_TYPBOUT(P_NBBOUT)    = [F:AWT]TYPBOUT
P_ACTBOUT(P_NBBOUT)    = [F:AWT]ACTBOUT
P_VALBOUT(P_NBBOUT)    = [F:AWT]VALBOUT
P_TXTBOUT(P_NBBOUT)    = [F:AWT]TXTBOUT
P_CODACTBOUT(P_NBBOUT)   = [F:AWT]CODACTBOUT
Return

## Lecture de la fenêtre

$LECWIN
Local Integer FBOUT
FBOUT = 80 : #114910 60->80
#### Tableau des boutons patch(P_)
Local Integer P_NBBOUT
Local Integer P_TYPBOUT(FBOUT)
Local Integer P_TXTBOUT(FBOUT)
Local Integer P_VALBOUT(FBOUT)
Local Integer P_NUMBOUT(FBOUT)
Local Integer P_SPEBOUT
Local Char    P_CODACTBOUT(GLONACV)(FBOUT)
Local Char    P_CODBOUT(3)(FBOUT)
Local Char    P_ACTBOUT(GLONACT)(FBOUT)
#### Tableau des boutons specifiques (S_)
Local Integer S_NBBOUT
Local Integer S_TYPBOUT(FBOUT)
Local Integer S_TXTBOUT(FBOUT)
Local Integer S_VALBOUT(FBOUT)
Local Integer S_NUMBOUT(FBOUT)
Local Char    S_CODACTBOUT(GLONACV)(FBOUT)
Local Char    S_CODBOUT(3)(FBOUT)
Local Char    S_ACTBOUT(GLONACT)(FBOUT)
#### Tableau des boutons finales(F_)
Local Integer F_NBBOUT
Local Integer F_TYPBOUT(FBOUT)
Local Integer F_TXTBOUT(FBOUT)
Local Integer F_VALBOUT(FBOUT)
Local Integer F_NUMBOUT(FBOUT)
Local Char    F_CODACTBOUT(GLONACV)(FBOUT)
Local Char    F_CODBOUT(3)(FBOUT)
Local Char    F_ACTBOUT(GLONACT)(FBOUT)
################################
### Tableau pour les browsers
Local Integer FBROW
FBROW = 30
Local Integer P_NBBRO
Local Char    P_OBJABR(GLONAOB+1+GLONABR)(FBROW)
Local Char    P_OBJLIS(GLONAOB)(FBROW)
Local Integer P_INTLIS(FBROW)
Local Char    P_CLELIS(GLONANX)(FBROW)
Local Integer P_ORDLIS(FBROW)
Local Integer P_TRELIS(FBROW)
Local Integer P_BROLIS(FBROW)
Local Integer P_ROWLIS(FBROW)
Local Integer P_CHGLIS(FBROW)
Local Char    P_ABRLIS(GLONABR)(FBROW)
Local Char    P_ACTLIS(GLONACV)(FBROW)
Local Char    P_EXPLIS(60)(FBROW)
Local Integer P_FLELIS(FBROW)
################################
Local Integer FPAR
FPAR = 500
### Tableau pour les params d'action du patch (P_)
Local Integer P_NBPAR
Local Integer P_PARBOU(FPAR)
Local Integer P_NOPAR(FPAR)
Local Char    P_PARAM(GLONAAR)(FPAR)
Local Char    P_VALEUR(80)(FPAR)
### Tableau pour les params d'action specifiques (S_)
Local Integer S_NBPAR
Local Integer S_PARBOU(FPAR)
Local Integer S_NOPAR(FPAR)
Local Char    S_PARAM(GLONAAR)(FPAR)
Local Char    S_VALEUR(80)(FPAR)
### Tableau pour les params d'action finales (F_)
Local Integer F_NBPAR
Local Integer F_PARBOU(FPAR)
Local Integer F_NOPAR(FPAR)
Local Char    F_PARAM(GLONAAR)(FPAR)
Local Char    F_VALEUR(80)(FPAR)
################################
### Remplissage tableau des boutons specifiques
S_NBBOUT = 0
For [AWT]AWT0 Where WIN=NOMOBJ
 If [F:AWT]CODACTBOUT>="X" & !find([F:AWT]CODACTBOUT,ACTIV(1..NBACT))
  S_NBBOUT += 1
  S_NUMBOUT(S_NBBOUT)    = [F:AWT]NUM
  S_CODBOUT(S_NBBOUT)    = [F:AWT]CODBOUT
  S_TYPBOUT(S_NBBOUT)    = [F:AWT]TYPBOUT
  S_ACTBOUT(S_NBBOUT)    = [F:AWT]ACTBOUT
  S_VALBOUT(S_NBBOUT)    = [F:AWT]VALBOUT
  S_TXTBOUT(S_NBBOUT)    = [F:AWT]TXTBOUT
  S_CODACTBOUT(S_NBBOUT)   = [F:AWT]CODACTBOUT
 Endif
Next
P_SPEBOUT = S_NBBOUT

P_NBBRO = 0
Read [AWB]AWB0 = NOMOBJ
If !fstat
 For K=0 To [F:AWB]NBLIS-1
  If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
   If ([F:AWB]ACTLIS(K)>="X" & !find([F:AWB]ACTLIS(K),ACTIV(1..NBACT))) or [F:AWB]OBJLIS(K)="ALI"
    P_NBBRO += 1
    P_OBJABR(P_NBBRO) = [F:AWB]OBJLIS(K)+"~"+[F:AWB]ABRLIS(K)
    P_OBJLIS(P_NBBRO) = [F:AWB]OBJLIS(K)
    P_INTLIS(P_NBBRO) = [F:AWB]INTLIS(K)
    P_CLELIS(P_NBBRO) = [F:AWB]CLELIS(K)
    P_ORDLIS(P_NBBRO) = [F:AWB]ORDLIS(K)
    P_TRELIS(P_NBBRO) = [F:AWB]TRELIS(K)
    P_BROLIS(P_NBBRO) = [F:AWB]BROLIS(K)
    P_ROWLIS(P_NBBRO) = [F:AWB]ROWLIS(K)
    P_CHGLIS(P_NBBRO) = [F:AWB]CHGLIS(K)
    P_ABRLIS(P_NBBRO) = [F:AWB]ABRLIS(K)
    P_ACTLIS(P_NBBRO) = [F:AWB]ACTLIS(K)
    P_EXPLIS(P_NBBRO) = [F:AWB]EXPLIS(K)
    P_FLELIS(P_NBBRO) = [F:AWB]FLELIS(K)
   Endif
  Else
   If ([F:AWB]ACTLIS(K)>="X" & !find([F:AWB]ACTLIS(K),ACTIV(1..NBACT)))
    P_NBBRO += 1
    P_OBJABR(P_NBBRO) = [F:AWB]OBJLIS(K)+"~"+[F:AWB]ABRLIS(K)
    P_OBJLIS(P_NBBRO) = [F:AWB]OBJLIS(K)
    P_INTLIS(P_NBBRO) = [F:AWB]INTLIS(K)
    P_CLELIS(P_NBBRO) = [F:AWB]CLELIS(K)
    P_ORDLIS(P_NBBRO) = [F:AWB]ORDLIS(K)
    P_TRELIS(P_NBBRO) = [F:AWB]TRELIS(K)
    P_BROLIS(P_NBBRO) = [F:AWB]BROLIS(K)
    P_ROWLIS(P_NBBRO) = [F:AWB]ROWLIS(K)
    P_CHGLIS(P_NBBRO) = [F:AWB]CHGLIS(K)
    P_ABRLIS(P_NBBRO) = [F:AWB]ABRLIS(K)
    P_ACTLIS(P_NBBRO) = [F:AWB]ACTLIS(K)
    P_EXPLIS(P_NBBRO) = [F:AWB]EXPLIS(K)
    P_FLELIS(P_NBBRO) = [F:AWB]FLELIS(K)
   Endif
  Endif
 Next K
Endif

### Remplissage tableau des params d'actions specifiques
S_NBPAR = 0
For [AWP]AWP0 Where WIN=NOMOBJ & [F:AWP]NUM<100
 K = find([F:AWP]NUM,S_NUMBOUT(1..S_NBBOUT))
 If K
  S_NBPAR += 1
  S_PARBOU(S_NBPAR) =  S_NUMBOUT(K)
  S_NOPAR(S_NBPAR)  = [F:AWP]NOPAR
  S_PARAM(S_NBPAR)  = [F:AWP]PARAM
  S_VALEUR(S_NBPAR) = [F:AWP]VALEUR
 Endif
Next
Return

$ECRWIN
### Remplisage des differents tableaux ( boutons et param d'action)
Gosub REMPLIT
### Ecriture fenetre
If NEWOBJ
  If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDCRE("AWI") From OBJDIV
   Endif
   Write [AWI]
   If fstat
        Call LOG_ERROR_DETAILS(1, "AWI",num$([F:AWI]WIN),"") From GLOCK
   Endif
Else
  If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDUPD("AOB") From OBJDIV
  Endif
  [F:AWI]NBMSK  = dim([F:AWI]NOMMSK)
  For IBLOC=0 To dim([F:AWI]NOMMSK)-1
      If [F:AWI]NOMMSK(IBLOC)=""
          [F:AWI]NBMSK  = IBLOC : Break
      Endif
  Next IBLOC
  Rewrite [AWI]
  If fstat
        Call LOG_ERROR_DETAILS(2, "AWI",num$([F:AWI]WIN),"") From GLOCK
  Endif
Endif
If fstat
     GOK = 0 : ER = 99 : ERFIC = "AWINDOW"-NOMOBJ : Return
Endif
### Ecriture boutons
Delete [AWT] Where WIN=NOMOBJ
If fstat=1
    GOK = 0 : ER = 99 : ERFIC = "AWINBOUT"-NOMOBJ : Return
Endif
For K=1 To F_NBBOUT
 [F:AWT]WIN        = NOMOBJ
 [F:AWT]NUM        = F_NUMBOUT(K)
 [F:AWT]CODBOUT    = F_CODBOUT(K)
 [F:AWT]TYPBOUT    = F_TYPBOUT(K)
 [F:AWT]ACTBOUT    = F_ACTBOUT(K)
 [F:AWT]VALBOUT    = F_VALBOUT(K)
 [F:AWT]TXTBOUT    = F_TXTBOUT(K)
 [F:AWT]CODACTBOUT = F_CODACTBOUT(K)
 Write [AWT]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "AWINBOUT"-NOMOBJ : Break
 Endif
Next K

### Ecriture des browsers
If NEWOBJ
 Write [AWB]
Else
 # Issue 86030 - 2012-12-03 by VPO : ajout contrôle nombre d'éléments patchés
 If P_NBBRO>dim([F:AWB]OBJLIS)
    Call ECR_TRACE("[F:AWB]OBJLIS"-mess(26,100,1),1) From GESECRAN : # Tableau plein
    GOK=0
    ER = 99 : Return
 Endif
 For K=1 To P_NBBRO
  [F:AWB]OBJLIS(K-1) = P_OBJLIS(K)
  [F:AWB]INTLIS(K-1) = P_INTLIS(K)
  [F:AWB]CLELIS(K-1) = P_CLELIS(K)
  [F:AWB]ORDLIS(K-1) = P_ORDLIS(K)
  [F:AWB]TRELIS(K-1) = P_TRELIS(K)
  [F:AWB]BROLIS(K-1) = P_BROLIS(K)
  [F:AWB]ROWLIS(K-1) = P_ROWLIS(K)
  [F:AWB]CHGLIS(K-1) = P_CHGLIS(K)
  [F:AWB]ABRLIS(K-1) = P_ABRLIS(K)
  [F:AWB]ACTLIS(K-1) = P_ACTLIS(K)
  [F:AWB]EXPLIS(K-1) = P_EXPLIS(K)
  [F:AWB]FLELIS(K-1) = P_FLELIS(K)
 Next K
 [F:AWB]NBLIS = P_NBBRO
 Rewrite [AWB]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AWINBBRO"-NOMOBJ : Return
Endif

### Ecriture des params d'action
Delete [AWP] Where WIN=NOMOBJ
If fstat=1
 GOK = 0 : ER = 99 : ERFIC = "AWINPAR"-NOMOBJ : Return
Endif
For K=1 To F_NBPAR
 [F:AWP]WIN    = NOMOBJ
 [F:AWP]NUM    = F_PARBOU(K)
 [F:AWP]NOPAR  = F_NOPAR(K)
 [F:AWP]PARAM  = F_PARAM(K)
 [F:AWP]VALEUR = F_VALEUR(K)
 Write [AWP]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "AWINPAR"-NOMOBJ : Break
 Endif
Next K
Return

$REMPLIT
For I=1 To min(dim(P_CODBOUT)-1,sum(P_NBBOUT+S_NBBOUT))
 K=find(P_CODBOUT(I),S_CODBOUT(1..S_NBBOUT))
 If !K  : # si bouton pas protegé, on prend les boutons du patch
  If P_CODBOUT(I)<>"" & F_NBBOUT<dim(F_CODBOUT)-1
   F_NBBOUT +=1
   F_NUMBOUT(F_NBBOUT)    = F_NBBOUT
   F_CODBOUT(F_NBBOUT)    = P_CODBOUT(I)
   F_TYPBOUT(F_NBBOUT)    = P_TYPBOUT(I)
   F_ACTBOUT(F_NBBOUT)    = P_ACTBOUT(I)
   F_VALBOUT(F_NBBOUT)    = P_VALBOUT(I)
   F_TXTBOUT(F_NBBOUT)    = P_TXTBOUT(I)
   F_CODACTBOUT(F_NBBOUT)   = P_CODACTBOUT(I)
   For J=1 To sum(P_NBPAR+S_NBPAR) : # on recupere du coup les params associés aux boutons du patch
    If P_PARBOU(J) = P_NUMBOUT(I) & P_ACTBOUT(I) <> ""
     F_NBPAR += 1
     F_PARBOU(F_NBPAR) = F_NBBOUT
     F_NOPAR(F_NBPAR)  = P_NOPAR(J)
     F_PARAM(F_NBPAR)  = P_PARAM(J)
     F_VALEUR(F_NBPAR) = P_VALEUR(J)
    Endif
   Next
  Endif
 Elsif F_NBBOUT<dim(F_CODBOUT)-1
  ### Sinon le bouton est protégé et on le garde
  F_NBBOUT +=1
  F_NUMBOUT(F_NBBOUT)    = F_NBBOUT
  F_CODBOUT(F_NBBOUT)    = S_CODBOUT(K)
  F_TYPBOUT(F_NBBOUT)    = S_TYPBOUT(K)
  F_ACTBOUT(F_NBBOUT)    = S_ACTBOUT(K)
  F_VALBOUT(F_NBBOUT)    = S_VALBOUT(K)
  F_TXTBOUT(F_NBBOUT)    = S_TXTBOUT(K)
  F_CODACTBOUT(F_NBBOUT)   = S_CODACTBOUT(K)
  For J=1 To sum(P_NBPAR+S_NBPAR) : # on recupere du coup les params associés aux boutons protegés
   If S_PARBOU(J) = S_NUMBOUT(K)
    F_NBPAR += 1
    F_PARBOU(F_NBPAR) = F_NBBOUT
    F_NOPAR(F_NBPAR)  = S_NOPAR(J)
    F_PARAM(F_NBPAR)  = S_PARAM(J)
    F_VALEUR(F_NBPAR) = S_VALEUR(J)
   Endif
  Next
 Endif
Next

#### Ajout des boutons predefinis , cas non traités ci-dessus
For J=1 To P_NBPAR
 If P_PARBOU(J) > 100
  F_NBPAR += 1
  F_PARBOU(F_NBPAR) = P_PARBOU(J)
  F_NOPAR(F_NBPAR)  = P_NOPAR(J)
  F_PARAM(F_NBPAR)  = P_PARAM(J)
  F_VALEUR(F_NBPAR) = P_VALEUR(J)
 Endif
Next

### On regarde si il y a des boutons nouveaux specifiques  qu'on place en derniere position par defaut ?
GBIDI1 = F_NBBOUT
For I=1 To S_NBBOUT
 If !find(S_CODBOUT(I),F_CODBOUT(1..GBIDI1)) & F_NBBOUT<dim(F_CODBOUT)-1
  F_NBBOUT +=1
  F_NUMBOUT(F_NBBOUT)    = F_NBBOUT
  F_CODBOUT(F_NBBOUT)    = S_CODBOUT(I)
  F_TYPBOUT(F_NBBOUT)    = S_TYPBOUT(I)
  F_ACTBOUT(F_NBBOUT)    = S_ACTBOUT(I)
  F_VALBOUT(F_NBBOUT)    = S_VALBOUT(I)
  F_TXTBOUT(F_NBBOUT)    = S_TXTBOUT(I)
  F_CODACTBOUT(F_NBBOUT)   = S_CODACTBOUT(I)
  For J=1 To S_NBPAR
   If S_PARBOU(J)=S_NUMBOUT(I)
    F_NBPAR += 1
    F_PARBOU(F_NBPAR) = F_NBBOUT
    F_NOPAR(F_NBPAR)  = S_NOPAR(J)
    F_PARAM(F_NBPAR)  = S_PARAM(J)
    F_VALEUR(F_NBPAR) = S_VALEUR(J)
   Endif
  Next
 Endif
Next
Return

