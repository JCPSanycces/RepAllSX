#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "AP_IMPORT"     : Gosub AP_IMPORT
  When "IMPORT"        : Gosub IMPORT
  When "IMP_OUVRE"     : Gosub OUVRE
Endcase
Return

$IMPORT
[M:POS1]CRY = "CH"
If [M:POS1]POSCTY=""
 [M:POS1]POSCTY = [F:POS]POSCTY
Endif
If [M:POS1]POSCTYCOD=""
 [M:POS1]POSCTYCOD = [F:POS]POSCTYCOD
Endif

If find(GIMP(1),"FL","I","D") > 0
  OK = 0                # to avoid the insertion
  NBERR -= 1            # to avoid error trace
  Call ECR_TRACE(func AFNC.MES1( mess(3,3648,1), [F:POS]POSCOD), 0) From GESECRAN
Endif
Return

$OUVRE
Local Integer NBDROP_
# delete all existing CH postcodes
  Filter [F:POS] Where CRY="CH"
  NBDROP_=rowcount([F:POS])
  Filter [F:POS]
  Trbegin [F:POS]
  Delete [F:POS] Where CRY="CH"
  If fstat=0
    Call ECR_TRACE(func AFNC.MES1( mess(1,3648,1), num$(NBDROP_)), 0) From GESECRAN
    Commit
  Else
    Call ECR_TRACE(mess(2,3648,1), 1) From GESECRAN
    GOK = -1
    Rollback
  Endif
Return

$AP_IMPORT
  [F:POS]CRY = "CH"
  [F:POS]POSCTYCOD = [F:POS]POSCOD
Return

