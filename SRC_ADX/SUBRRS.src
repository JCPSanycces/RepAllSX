#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du fichier RESRES
Call OBJET ("RRS", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "SETBOUT"      : Gosub SETBOUT
    When "RAZCRE"       : Gosub RAZCRE
    When "LIENS"        : Gosub LIENS
    When "FERME"        : Gosub FERME
    When "INICRE"       : Gosub INICRE
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "CREATION"     : Gosub CREATION
    When "MODIF"        : Gosub MODIF
    When "ANNULE"       : Gosub ANNULE
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "AVANT_CHOI"   : Gosub AVANT_CHOI
    When "BS_RSSNUM"    : Gosub BS_RSSNUM
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer CHGINRED
Global Char GCRRSCPT(GLONANM)   # Code compteur pour réservation de ressource

  CHGINRED = 1
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=13
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(7)
  #  GCRRSCPT = [F:TCA]CODNUM(7)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
Return

##########################################################################################################
$FERME
  Kill CHGINRED
  Kill GCRRSCPT            # Code compteur pour réservation de ressource
Return

##########################################################################################################
$SETBOUT
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$AVANT_CHOI
  If GBCRMFLGNEW = 1 Then
    REPONSE = GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    GBCRMFLGNEW = 0
  Endif
Return

##########################################################################################################
$RAZCRE
  #Origine
  [M:RRS1]CRESNC = date$
  [M:RRS1]CREDAT = date$
  [M:RRS1]CREUSR = GUSER
  [M:RRS1]RRSORI = 1
  Read [REP]REP1=GUSER
  If fstat Then
    Read [AUS]CODUSR=[M:RRS1]CREUSR
    If fstat Then
      [M:RRS1]FULNAMUSR = ""
    Else
      [M:RRS1]FULNAMUSR = [F:AUS]NOMUSR
    Endif
  Else
    [M:RRS1]RERREP = [F:REP]REPNUM
    [M:RRS1]FULNAMUSR = [F:REP]REPNAM
  Endif
  #Si on ne vient pas par des rendez-vous, on initialise rien d'autre
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) <> "GESBAP" and GNAVIG(GPILNAV-1) <> "GESITN" Then
      [M:RRS1]RRSORITYP = ""
      [M:RRS1]RRSORI = 1
      Diszo [M:RRS1]RRSORIVCR
      Affzo [M:RRS0]1-99
      Affzo [M:RRS1]1-99
      Return
    Elsif GNAVIG(GPILNAV-1) = "GESBAP" Then
      #Date de début et date de fin de réservation
      If [M:BAP1]APTDAT = [00/00/00] Then
        [M:RRS1]RERDAT = [M:BAP1]APTDATX
        [M:RRS1]HOUSTR = "0900"
        [M:RRS1]RERDATEND = [M:BAP1]APTDATX + 4
        [M:RRS1]HOUEND = "1800"
      Endif
      If [M:BAP0]APTNUM = "" Then
        [M:RRS1]RRSORI = 1
        [M:RRS1]RRSORIVCR = ""
      Else
        [M:RRS1]RRSORI = 2
        [M:RRS1]RRSORIVCR = [M:BAP0]APTNUM
      Endif
    Elsif GNAVIG(GPILNAV-1) = "GESITN" Then
      If [M:ITN1]DAT = [00/00/00] Then
        [M:RRS1]RERDAT = [M:ITN1]DATX
        [M:RRS1]HOUSTR = "0900"
        [M:RRS1]RERDATEND = [M:ITN1]DATX + 4
        [M:RRS1]HOUEND = "1800"
      Endif
      If [M:ITN0]NUM = "" Then
        [M:RRS1]RRSORI = 1
        [M:RRS1]RRSORIVCR = ""
      Else
        [M:RRS1]RRSORI = 3
        [M:RRS1]RRSORIVCR = [M:ITN0]NUM
      Endif
    Endif
  Endif
  If [M:RRS1]RRSORI = 0 Then
    [M:RRS1]RRSORI = 1
  Endif
  #Définition du type de pièce
  Case [M:RRS1]RRSORI
    When 1
      [M:RRS1]RRSORITYP = ""
    When 2
      [M:RRS1]RRSORITYP = "BAP"
    When 3
      [M:RRS1]RRSORITYP = "ITN"
    When Default
  Endcase
  Diszo [M:RRS1]RRSORIVCR
  Affzo [M:RRS0]1-99
  Affzo [M:RRS1]1-99
Return

##########################################################################################################
$LIENS
Local Char LIBENCLAIR

  #---------------------------------------------------#
  #  Origine
  #---------------------------------------------------#
  If [M:RRS1]RERREP = "" Then
    Read [AUS]CODUSR=[M:RRS1]CREUSR
    If fstat Then
      [M:RRS1]FULNAMUSR = ""
    Else
      [M:RRS1]FULNAMUSR = [F:AUS]NOMUSR
    Endif
  Else
    Read [REP]REP0=[M:RRS1]RERREP
    If fstat Then
      Read [AUS]CODUSR=[M:RRS1]CREUSR
      If fstat Then
        [M:RRS1]FULNAMUSR = ""
      Else
        [M:RRS1]FULNAMUSR = [F:AUS]NOMUSR
      Endif
    Else
      [M:RRS1]FULNAMUSR = [F:REP]REPNAM
    Endif
  Endif
  If [M:RRS1]RRSORI = 0 Then
    [M:RRS1]RRSORI = 1
  Endif
  #Définition du type de pièce
  Case [M:RRS1]RRSORI
    When 1
      [M:RRS1]RRSORITYP = ""
    When 2
      [M:RRS1]RRSORITYP = "BAP"
    When 3
      [M:RRS1]RRSORITYP = "ITN"
    When Default
  Endcase
  Diszo [M:RRS1]RRSORIVCR
  #Initialise le champs "Catégorie en clair"
  Read [RSS]RSS0=[M:RRS1]RSSNUM
  [M:RRS1]CAT = [F:RSS]CAT
  Affzo [M:RRS1]FULNAMUSR
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call READ_COUNTER([M:RRS0]SALFCY, 13, 7, GSOCIETE, GCURLEG, GCRRSCPT, GMANCOU) From CRM_UTIL     # FGR 20/05/2015 : X3SUIVI107775
  # Récupération du compteur de contrat de service.
  If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:RRS0]SALFCY, GCRRSCPT, date$, "", [M:RRS0]NUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:RRS]NUM = [M:RRS0]NUM
      Affzo [M:RRS0]NUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:RRS]CREHOU = left$(time$, 2) + mid$(time$, 4, 2)
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIFDISP
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIFDISP
Return

##########################################################################################################
$CREATION
  # Maj des statistiques
  Call VALSTA("RRS",1) From SUBPS2
Return

##########################################################################################################
$MODIF
  # Maj des statistiques
  Call VALSTA("RRS",-1) From SUBPS2
  Call VALSTA("RRS",1) From SUBPS2
Return

##########################################################################################################
$ANNULE
  # Maj des statistiques
  Call VALSTA("RRS",-1) From SUBPS2
Return

##########################################################################################################
$APRES_CRE
  [M:RRS1]CREHOU = [F:RRS]CREHOU
  Affzo [M:RRS1]1-99
  #---------------------------------------------------#
  # Gestion des valeurs modifiées
  #---------------------------------------------------#
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESBAP" Then
      Gosub SAVEVALINI From SUBBAPB
    Endif
  Endif
Return

##########################################################################################################
$APRES_MOD
  #---------------------------------------------------#
  # Gestion des valeurs modifiées
  #---------------------------------------------------#
  #LSE 09/01/2007
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESBAP" Then
      Gosub SAVEVALINI From SUBBAPB
    Endif
  Endif
Return

##########################################################################################################
$BS_RSSNUM
  Affzo [M:RRS1]RSSNUM
  Affzo [M:RRS1]RERDAT
  Affzo [M:RRS1]HOUSTR
  Affzo [M:RRS1]RERDATEND
  Affzo [M:RRS1]HOUEND
Return

############################################################################################
# Sous-programmes
############################################################################################
#Vérifie la disponibilité de la ressource.
$VERIFDISP
Local Integer ISDISP
Local Integer IFOGGY
Local Char SZPROMPT2(250)
Local Integer IPROMPT2REP
Local Char SZCFL

  ISDISP = 0
  IFOGGY = 0
  SZPROMPT2 = ""
  IPROMPT2REP = 0
  SZCFL = ""
  Call CHKRRSDISP([M:RRS1]RSSNUM, [M:RRS1]RERDAT, [M:RRS1]RERDATEND, [M:RRS0]NUM, [M:RRS1]HOUSTR, [M:RRS1]HOUEND, ISDISP, IFOGGY, SZCFL) From SUBRRSB
  If !ISDISP Then
    If IFOGGY Then
      SZPROMPT2 = mess(178,182,1) - mess(557,196,1)
      Call OUINON(SZPROMPT2, IPROMPT2REP) From GESECRAN
      If IPROMPT2REP <> 2 Then
        OK = 0
      Endif
    Else
      If SZCFL = "" Then
        #Une réservation à déjà été enregistrée pour la période souhaitée.
        GMESSAGE = mess(220,196,1)
      Else
        Read [RRS] RRS0 = SZCFL
        If fstat Then
          #Une réservation à déjà été enregistrée pour la période souhaitée.
          GMESSAGE = mess(220,196,1)
        Else
          #Une réservation à déjà été enregistrée pour la période du :
          SZPROMPT2 = mess(561,196,1)
&                   + day$([F:RRS]RERDAT) - num$(day([F:RRS]RERDAT))
&                   - month$([F:RRS]RERDAT) - num$(year([F:RRS]RERDAT))
&                   - left$([F:RRS]HOUSTR, 2) + ":" + mid$([F:RRS]HOUSTR, 3, 2)
&                   - mess(560,196,1)
&                   + day$([F:RRS]RERDATEND) - num$(day([F:RRS]RERDATEND))
&                   - month$([F:RRS]RERDATEND) - num$(year([F:RRS]RERDATEND))
&                   - left$([F:RRS]HOUEND, 2) + ":" + mid$([F:RRS]HOUEND, 3, 2)
          GMESSAGE = SZPROMPT2
        Endif
      Endif
      GERR = 3
      OK = 0
      Affzo [M:RRS1]1-99
    Endif
  Endif
Return

##########################################################################################################
Subprog CTRL_SITE_RRS_RSS(SFCY, SRSSNUM)
Value Char SFCY
Value Char SRSSNUM

  # FGR 01/09/2011 : X3SUIVI75945
  If SFCY <> "" Then
    Read [RSS]RSS0=SRSSNUM
    If SFCY <> [F:RSS]SALFCY Then
      GMESSAGE = mess(966,196,1) - "(a)"
      mkstat = 2
    Endif
  Else
    # FGR 30/06/2011 : X3SUIVI74675
    Read [RSS]RSS0=SRSSNUM
    If [F:RSS]SALFCY <> "" Then
      GMESSAGE = mess(966,196,1) - "(b)"
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

  # FGR 01/09/2011 : X3SUIVI75945
  If [M:RRS1]RSSNUM <> "" Then
    Call CTRL_SITE_RRS_RSS(VALEUR, [M:RRS1]RSSNUM)
  Endif
End

##########################################################################################################
Subprog C_RSSNUM(VALEUR)
Variable Char    VALEUR()

  # FGR 01/09/2011 : X3SUIVI75945
  Call CTRL_SITE_RRS_RSS([M:RRS0]SALFCY, VALEUR)
  ## FGR 24/07/2009 : X3SUIVI56702
