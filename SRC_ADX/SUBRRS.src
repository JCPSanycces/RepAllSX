  #    mkstat = 2
  #  Endif
  #Else
  #  # FGR 30/06/2011 : X3SUIVI74675
  #  Read [RSS]RSS0=VALEUR
  #  If [F:RSS]SALFCY <> "" Then
  #    GMESSAGE = mess(966,196,1) - "(b)"
  #    mkstat = 2
  #  Endif
  #Endif
End

##########################################################################################################
Subprog AM_RSSNUM(VALEUR)
Variable Char    VALEUR()

  Read [RSS]RSS0=VALEUR
  [M:RRS1]CAT = [F:RSS]CAT
  Affzo [M:RRS1]CAT
End

##########################################################################################################
Subprog AM_RERDAT(VALEUR)
Variable Date    VALEUR

  [M:RRS1]RERDATEND = VALEUR
  [M:RRS1]HOUSTR = "0900"
  [M:RRS1]HOUEND = "1800"
  Affzo [M:RRS1]RERDATEND
  Affzo [M:RRS1]HOUSTR
  Affzo [M:RRS1]HOUEND
End

##########################################################################################################
Subprog AM_HOUSTR(VALEUR)
Variable Char    VALEUR()
End

##########################################################################################################
Subprog AV_RERDAT(VALEUR)
Variable Date    VALEUR

  If CHGINRED Then
    Chgstl [M:RRS1]RERDAT With "AWARNHIGH"
  Else
    Chgstl [M:RRS1]RERDAT With ""
  Endif
End

##########################################################################################################
Subprog AV_HOUSTR(VALEUR)
Variable Char    VALEUR()

  If CHGINRED Then
    Chgstl [M:RRS1]HOUSTR With "AWARNHIGH"
  Else
    Chgstl [M:RRS1]HOUSTR With ""
  Endif
End

##########################################################################################################
Subprog AV_RERDATEND(VALEUR)
Variable Date    VALEUR

  If CHGINRED Then
    Chgstl [M:RRS1]RERDATEND With "AWARNHIGH"
  Else
    Chgstl [M:RRS1]RERDATEND With ""
  Endif
End

##########################################################################################################
Subprog AV_HOUEND(VALEUR)
Variable Char    VALEUR()

  If CHGINRED Then
    Chgstl [M:RRS1]HOUEND With "AWARNHIGH"
  Else
    Chgstl [M:RRS1]HOUEND With ""
  Endif
End

##########################################################################################################
Subprog AM_RERDATEND(VALEUR)
Variable Date    VALEUR

  If VALEUR < [M:RRS1]RERDAT Then
    VALEUR = [M:RRS1]RERDAT
  Endif
  [M:RRS1]RERDATEND = VALEUR
  Affzo [M:RRS1]RERDATEND
End

##########################################################################################################
Subprog IB_RRSORIVCR

  Raz GBOUT1
  If [M:RRS1]RRSORITYP <> "" Then
    #Détail pièce
    GBOUT1 = mess(103,182,1)
  Endif
End

