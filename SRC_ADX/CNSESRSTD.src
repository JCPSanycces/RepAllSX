#<AdxTL>@(#)2.0.0.0 $Revision$ Consultation ESR
######################################################################################
# Gestion des consultations   - Historique des e-Signatures             - GA 10/2007 #
######################################################################################
# Fenêtres/Ecrans
# - FCNSESR : Consultation de l'historique des e-Signatures
# - DCRITESR: Critères de sélection de l'historique des e-Signatures
# Actions
# - SELESREVT: Sélection des groupes de mises à jour (valeurs du compteur dans XCHGNUM) 
# - SELESRLOG: Sélection des logins ayant réalisé des e-Signatures 
######################################################################################

######################################################################################

Local Char PARAM(10)(1..7)
GCONSULT = 0
Call GCONSULT("ESR","",PARAM) From GCONSULT
End

######################################################################################

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LECTURE"     : Gosub LECTURE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "DEB_CRIT"    : Gosub SET_ECRAN
 When "FIN_CRIT"    : Gosub SET_CRIT
 When "APRES_MODIF" : Gosub APRES_MODIF
Endcase
Return

$OUVRE
If clalev([F:AUD])=0 : Local File AUDITH   [AUD] : Endif
If clalev([F:AUL])=0 : Local File AUDITL   [AUL] : Endif
If clalev([F:ATB])=0 : Local File ATABLE   [ATB] : Endif
If clalev([F:AOB])=0 : Local File AOBJET   [AOB] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif
If clalev([F:ACN])=0 : Local File ACONSULT [ACN] : Endif

Local Char    CRITENT(250) , CRITSUI(250)
Local Integer SEQUENCE , MAXLIG , DET, CHGPAG
Local Char    CHAMP(20)
MAXLIG = dim([M:CES2]SEQ)

If [M:CES1]STRDAT=[0/0/0] & [M:CES1]ENDDAT=[0/0/0] 
 [M:CES1]STRDAT = GDATEDEB
 [M:CES1]ENDDAT = GDATEFIN
Endif
Affzo [M:CES1]1-99

# Mail TS du 18/03/08
NAVIG="CONSESR"
Return

$LECTURE
Gosub CRITENT
Gosub CRITSUI
If [M:CES1]DETAIL=2
 DET = 2
Else
 DET = 1
Endif
NOL = 0
SUITE  = 1
RETOUR = 1
Link [AUL] With [AUD]AUD0=[F:AUL]SEQ As [AUDX]
If CHGPAG>0 
 Filter [AUDX] Where evalue(CRITENT) & evalue(CRITSUI)
&              Order By Key CLE=[F:AUL]SEQ;[F:AUL]COL
 NOL = 0
 For [AUDX]CLE(DET)
  If NOL>=MAXLIG
   SUITE = 2 : Break
  Else
   If CHGPAG=2 : RETOUR = 2 : Endif
   NOL += 1
   Gosub CHARGE
  Endif
 Next
 [M:CES2]NBLIG = NOL
Else
 Filter [AUDX] Where evalue(CRITENT) & evalue(CRITSUI)
&              Order By Key CLE=[F:AUL]SEQ Desc;[F:AUL]COL Desc
 NOL = MAXLIG+1
 For [AUDX]CLE(DET)
  If NOL<=1
   RETOUR = 2 : Break
  Else
   If CHGPAG=-2 : SUITE = 2 : Endif
   NOL -= 1
   Gosub CHARGE
  Endif
 Next
 [M:CES2]NBLIG = MAXLIG
Endif
Filter [AUDX]
NOL -= 1
Return

$CHARGE
If NBLU=1
 NBLU = 2
 If CHGPAG=2 or CHGPAG=-2 : Raz [M:CES2] : Endif
Endif
nolign = NOL
If DET<>2
 Raz [F:AUL]
Endif
[M:CES2] = [F:AUL]
[M:CES2] = [F:AUD]
Return

##########################################################

$SET_ECRAN
If [M:CESD]ECRAN = "" 
 #Call LECTURE("ACN","ESR","") From CONTOBJ
 Read [ACN]="ESR"
 If !fstat & [ACN]SCRCOD <> ""
  [M:CESD]ECRAN = [ACN]SCRCOD : Affzo [M:CESD]ECRAN
 Endif
Endif
Return

$SET_CRIT
[M:CES1]=[M:CESD] : Affzo [M:CES1]
Return

##########################################################

$CRITENT
CRITENT = ""
# Cas particulier: on veut tous les changts identifiés par une valeur courante de CHGNUM
If [M:CES1]CHGNUM<>""
 Goto CRIT_CHGNUM
Endif
#
If [M:CES1]STRDAT<>[0/0/0]
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= "[AUD]DAT>=["+format$(GFMD,[M:CES1]STRDAT)+"]"
Endif
If [M:CES1]ENDDAT<>[0/0/0]
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= "[AUD]DAT<=["+format$(GFMD,[M:CES1]ENDDAT)+"]"
Endif
If [M:CES1]TABLE<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AUD]TBL="'+[M:CES1]TABLE+'"'
Endif
If [M:CES1]CHAMP<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= 'pat([AUL]COL,"'+[M:CES1]CHAMP+'") = 1'
Else
# CHAMP caché pour le moment
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= 'find([AUL]COL,"CHGNUM","MOTPWD","XCHGNUM","XMOTPWD")>0'
Endif
If [M:CES1]USER<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AUD]ADOUSR="'+[M:CES1]USER+'"'
Endif
If [M:CES1]LOGIN<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AUD]SYSUSR="'+[M:CES1]LOGIN+'"'
Endif
If [M:CES1]EVENEMENT<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AUD]EVT="'+[M:CES1]EVENEMENT+'"'
Endif
If CRITENT=""
 CRITENT = "1=1"
Endif
Return

$CRIT_CHGNUM
Local Shortint WSECOND
Local Char     WSTRHOU(8)
Local Char     WENDHOU(8)
CRITENT = ""
CRITENT = '[AUL]NVAL="'+[M:CES1]CHGNUM+'"'

Link [AUL] With [AUD]AUD0=[F:AUL]SEQ As [AUDX]
Filter [AUDX] Where evalue(CRITENT) & evalue(CRITSUI)
&             Order By Key CLE=[F:AUL]SEQ;[F:AUL]COL
Read [AUDX] First
If ! fstat
# la ligne lue sert à sélectionner les autres mises à jour simultanées
# quels que soient la table et les champs, 
# mais même date/heure et même user X3/poste client
  Raz CRITENT
  CRITENT  =  "[AUD]DAT>=["+format$(GFMD,[AUD]DAT)+"]"
  # Format de l'heure "hhmiss" 
  # On extrait les secondes pour prendre +/- 5 seconde, 
  # sinon on risque de ne pas avoir l'historique entête/détail
  WSECOND = val(right$([AUD]HOU,len([AUD]HOU)-1))
  WSTRHOU = left$([AUD]HOU,len([AUD]HOU)-2)+num$(WSECOND)
  WENDHOU = left$([AUD]HOU,len([AUD]HOU)-2)+num$(WSECOND+10)
  CRITENT -= '&[AUD]HOU>="'+WSTRHOU+'"'
  CRITENT -= '&[AUD]HOU<="'+WENDHOU+'"'
  CRITENT -= '&[AUD]ADOUSR="'+[AUD]ADOUSR+'"'
  CRITENT -= '&[AUD]SYSUSR="'+[AUD]SYSUSR+'"'
  # on veut toutes les tables mises à jour, elles n'ont pas forcément la même clé
  #CRITENT -= '&[AUD]ID1="'+[AUD]ID1+'"'
Endif
Filter [AUDX]
If CRITENT=""
 CRITENT = "1=1"
Endif
Return


$CRITSUI
CRITSUI = ""
Case CHGPAG
 When 2
  If [M:CES2]NBLIG>0
   SEQUENCE = [M:CES2]SEQ([M:CES2]NBLIG-1)
   CHAMP    = [M:CES2]COL([M:CES2]NBLIG-1)
   CRITSUI = '([AUL]SEQ>'+num$(SEQUENCE)-'or ([AUL]SEQ='+num$(SEQUENCE)
&             -'and [AUL]COL>"'+CHAMP+'"))'
  Endif
 When -2
  If [M:CES2]NBLIG>0
   SEQUENCE = [M:CES2]SEQ(0)
   CHAMP    = [M:CES2]COL(0)
   CRITSUI = '([AUL]SEQ<'+num$(SEQUENCE)-'or ([AUL]SEQ='+num$(SEQUENCE)
&             -'and [AUL]COL<"'+CHAMP+'"))'
  Endif
Endcase
If CRITSUI=""
 CRITSUI = "1=1"
Endif
Return


######################################################################################

$APRES_MODIF
Gosub PAG_PREM From GCONSULT 
Gosub SETBOUT From GCONSULT
Return


######################################################################################
$SEL_LISTE
Case LISTE
 When "SELESREVT"  : Gosub SELESREVT
 When "SELESRLOG"  : Gosub SELESRLOG
Endcase
Return

$SELESREVT
###################################################################
#  sélection des valeurs du compteur CHGNUM pour la table choisie #
###################################################################
Local Char    TEX(GLONVCR)(1..200) , TEXTE(GLONVCR)(1..200,1..2)
Local Char    TIT(30)(0..1)
Local Integer NBTEX
Local Char    WTABLE(GLONVCR)   : WTABLE= PARAM(1)  : # Code TABLE
Local Char    WCHAMP(GLONVCR)   : WCHAMP= "XCHGNUM" : # Code CHAMP
Local Char    WFILX(250)
#
Local Char WREQ(255) : WREQ="" : # Requete générique pour base Oracle et SqlServer 7
Local Char WBASE     : WBASE=" "
If clalev([F:AUD])  = 0 : Local File AUDITH   [AUD] : Endif 
If clalev([F:AUL])  = 0 : Local File AUDITL   [AUL] : Endif 

# Alimentation du type de Database
Gosub ALIM_WBASE

Call TITACTION(LISTE,TIT(0)) From CONTOBJ

# Constitution d'une liste
WREQ ="SELECT distinct NVAL_0 From AUDITH, AUDITL"
WREQ-="Where AUDITH.SEQ_0=AUDITL.SEQ_0 and NVAL_0>' '"
If WTABLE<>""
   WREQ-="and AUDITH.TBL_0='"+WTABLE+"'"
Endif
WREQ-="and AUDITL.COL_0='"+WCHAMP+"'"
If WBASE="3" : # syntaxe Oracle uniquement ?
   WREQ-="order by NVAL_0 desc"
Endif
NBTEX=0
For (Char NVAL(GLONDES)) From WBASE Sql WREQ As [REQ_]
  NBTEX += 1  : TEX(NBTEX) = [REQ_]NVAL : # TEXTE(NBTEX,2) = ??? que peut-on afficher ???
  If fstat | NBTEX>=200 Break Endif
Next

Return

$SELESRLOG
###################################################################
#  sélection des valeurs du LOGIN                                 #
###################################################################
Local Char    TEX(GLONVCR)(1..200) , TEXTE(GLONVCR)(1..200,1..2)
Local Char    TIT(30)(0..1)
Local Integer NBTEX
Local Char    WTABLE(GLONVCR)   : WTABLE= PARAM(1)  : # Code TABLE
Local Char    WCHAMP(GLONVCR)   : WCHAMP= "XCHGNUM" : # Code CHAMP
Local Char    WFILX(250)
#
Local Char WREQ(255) : WREQ="" : # Requete générique pour base Oracle et SqlServer 7
Local Char WBASE     : WBASE=" "
If clalev([F:AUD])  = 0 : Local File AUDITH   [AUD] : Endif 

# Alimentation du type de Database
Gosub ALIM_WBASE

Call TITACTION(LISTE,TIT(0)) From CONTOBJ

# Constitution d'une liste
WREQ ="SELECT distinct SYSUSR_0 From AUDITH, AUDITL"
WREQ-="Where AUDITH.SEQ_0=AUDITL.SEQ_0 and NVAL_0>' '"
If WTABLE<>""
   WREQ-="and AUDITH.TBL_0='"+WTABLE+"'"
Endif
WREQ-="and AUDITL.COL_0='"+WCHAMP+"'"
NBTEX=0
For (Char XLOGIN(GLONVCR)) From WBASE Sql WREQ As [REQ_]
  NBTEX += 1  : TEX(NBTEX) = [REQ_]XLOGIN : # TEXTE(NBTEX,2) = [REQ_]XADOUSR
  If fstat | NBTEX>=200 Break Endif
Next

Return

###################################################################
$TEXTE
Call TEXTFIC(WTABLE,  COL(NBCOL), 1, TIT(NBCOL) ) From OBJDIV
Return

###################################################################
## ALIM_WBASE alimentation de la variable donnant le type de       #
## DATABASE à partir de GTYPDBA                                   #
###################################################################
$ALIM_WBASE
Case GTYPDBA
  When 1 : WBASE = "3" : # Oracle
  When 2 : WBASE = "5" : # Sql
  When 3 : WBASE = "2" : # Cisam
  When 4 : WBASE = "4" : # DB2
Endcase
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSESR1) 08/10/2007 14:09:03 (GA)
######################################################################################
Subprog C_CHAMP(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End

Subprog C_EVENEMENT(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char    ACT(10)
If VALEUR<>""
 mkstat = 2
 For I=6 To 1 Step-1
  For ACT="INSERT","UPDATE","DELETE"
   If left$(VALEUR,I)=left$(ACT,I)
    VALEUR = ACT : mkstat = 0 : Break 2
   Endif
  Next ACT
 Next I
Endif
End

Subprog AM_CHGNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
# dès qu'on a choisi un identifiant CHGNUM, on recharge les lignes
  Raz [M:CES2]
  # Gosub LECTURE
Endif
End


Subprog AS_DETAIL(VALEUR)
Variable Integer VALEUR
If [M]CHAMP<>""
 VALEUR = 2
 mkstat = 2 : End
Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSESR2) 08/10/2007 14:12:25 (GA)
######################################################################################
Subprog B1_NBLIG    : # Bouton 1: tunnel vers l'objet rattaché à cette table ?
Local Integer NOL , I , J , K
Local Char    CLE1(GLONID1) , CLE2(GLONID2)(16)
Local Char    OBJET(GLONAOB)
NOL = nolign-1
Read [AOB]NOMFIC(1) = [M]TBL(NOL)
If fstat
 Call MESSAGE(mess(19,137,1)-[M]TBL(NOL)) From GESECRAN : # Objet non trouvé
 End
Else
 OBJET = [F:AOB]ABREV
Endif
CLE1    = [M]ID1(NOL)
CLE2    = [M]ID2(NOL)
Call OBJET_CHAR(CLE1,OBJET,CLE2) From GOBJET

End

######################################################################################
Subprog B2_NBLIG     : # Bouton 2: Détail des tables mises à jour
Local Integer NOL , I , J , K
Local Char    CLE1(GLONID1) , CLE2(GLONID2)(16)
Local Char    CHAINE(250) , CLE(GLONID1)
NOL = nolign-1
If [M]COL(NOL)="XCHGNUM"
# Appel d'une visu de l'ensemble des changements comportant la même valeur
Endif
End
######################################################################################



######################################################################################
## Etiquette ajoutée par le superviseur (écran CRITESR) 14/11/2007 16:48:01 (GA)
######################################################################################
Subprog C_CHGNUM(VALEUR)
Variable Char    VALEUR()
End


######################################################################################

# FQ 57754 Module Tronc commun GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(9)<>2 End Endif

Call VALGTC(APPLI,"ESR") From SUBGTC

End

