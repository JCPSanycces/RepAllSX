#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional fields
# Supervisor
## CRUD-CLASSE ## EMPLOIDUKI
# 2018-11-06 07:05:57 670


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EMPLOIDUKI [IDUKI_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EMPLOIDUKI") From ASYRCOM : Endif
Local Instance EMPLOIDUKI Using C_EMPLOIDUKI

If !SILENCE : Call TRACE("3 --> New Instance C_EMPLOIDUKI") From ASYRCOM : Endif
EMPLOIDUKI = NewInstance C_EMPLOIDUKI AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [IDUKI_]IDUKI0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EMPLOIDUKI") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.AREAD([IDUKI_]REFNUM))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EMPLOIDUKI.REFNUM ="-num$(EMPLOIDUKI.REFNUM)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EMPLOIDUKI.AKEYS)
  Call TRACE("-"-num$(I)-":"-EMPLOIDUKI.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [IDUKI_]
FreeGroup EMPLOIDUKI
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EMPLOIDUKI,ACLE,ASTATUS,_ETAG)
Variable Instance EMPLOIDUKI Using C_EMPLOIDUKI
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _REFNUM(15)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
Raz [L]_ETAG
Local File EMPLOIDUKI [IDUKI]
Default File [F:IDUKI]
Read [F:IDUKI]IDUKI0 = [L]_REFNUM
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:IDUKI]UPDTICK)>0
 [L]_ETAG = num$([F:IDUKI]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EMPLOIDUKI,ACLE,ASTATUS)
Variable Instance EMPLOIDUKI Using C_EMPLOIDUKI
Value Char ACLE
Variable Integer ASTATUS
Local Char _REFNUM(15)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.AREAD([L]_REFNUM))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EMPLOIDUKI,_REFNUM,ASTATUS)
Variable Instance EMPLOIDUKI Using C_EMPLOIDUKI
Value Char _REFNUM
Variable Integer ASTATUS

If EMPLOIDUKI = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOIDUKI
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EMPLOIDUKI.APARENT=null
 [L]A_I = EMPLOIDUKI.freeSnapshot
 EMPLOIDUKI.snapshotEnabled = 0
 EMPLOIDUKI.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EMPLOIDUKI.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EMPLOIDUKI.APARENT=null
 EMPLOIDUKI.snapshotEnabled = 1
 EMPLOIDUKI.setAccessorEnabled = 1
Endif
LogicClose File [IDUKI]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI._ACTION_PARAM("AREAD_BEFORE",[L]_REFNUM))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:IDUKI]
Read [F:IDUKI]IDUKI0 = [L]_REFNUM
If fstat
[L]A_ERROR = [L]_REFNUM
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EMPLOIDUKI,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:IDUKI]AUUID)>0 & [F:IDUKI]AUUID=NullUuid
 [F:IDUKI]AUUID = getUuid
Endif
SetInstance EMPLOIDUKI With [F:IDUKI]
EMPLOIDUKI.ASTALIN = [V]CST_ALL

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



