#  # COL(NBCOL) = "max(LEV)"
#  COL(NBCOL) = "max(LEV(0),LEV(1),LEV(2),LEV(3),LEV(4),LEV(5),LEV(6),LEV(7),LEV(8),LEV(9))"
#  # Colonne Contrat
