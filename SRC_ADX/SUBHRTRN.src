######################################################################################
# Contrôle du Niveau du formateur
######################################################################################
Subprog C_LEV(VALEUR)
Variable Char    VALEUR()
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  Local Integer LFLAG_TROUVE : LFLAG_TROUVE = 1
  If VALEUR = "" and [M:HRTRN1]CODSCA(nolign-1) <> "" Then
    # Le niveau est obligatoire quand l'échelle est renseignée
    # Zone obligatoire
    GMESSAGE = mess(10,123,1)
    mkstat = 2 : End
  Elsif [M:HRTRN1]CODSCA(nolign-1) <> ""  Then
    # L'échelle est renseignée, vérification de l'existence du niveau
    Read [F:HRSCA]SCA0 = [M:HRTRN1]CODSCA(nolign-1)
    If !fstat Then
      For IND_LEV = 0 To dim([F:HRSCA]LEV)-1
        If [F:HRSCA]LEV(IND_LEV) <> "" and [F:HRSCA]LEV(IND_LEV) = VALEUR Then
          LFLAG_TROUVE = 2
          Call SET_LEVDES([F:HRSCA]COD,IND_LEV+1)
          Break
        Endif
      Next IND_LEV
    Endif
    If LFLAG_TROUVE = 1 Then
      # Valeur incorrecte
      GMESSAGE = mess(8,9137,1)
      mkstat = 2 : End
    Endif
  Endif

#  Local Integer LFLAG_TROUVE : LFLAG_TROUVE = 1
#  If VALEUR = "" and [M:TRN1]CODSCA(nolign-1) <> "" Then
#    # Le niveau est obligatoire quand l'échelle est renseignée
#    # Zone obligatoire
#    GMESSAGE = mess(10,123,1)
#    mkstat = 2 : End
#  Elsif [M:TRN1]CODSCA(nolign-1) <> ""  Then
#    # L'échelle est renseignée, vérification de l'existence du niveau
#    Read [F:SCA]SCA0 = [M:TRN1]CODSCA(nolign-1)
#    If !fstat Then
#      For IND_LEV = 0 To dim([F:SCA]LEV)-1
#        If [F:SCA]LEV(IND_LEV) <> "" and [F:SCA]LEV(IND_LEV) = VALEUR Then
#          LFLAG_TROUVE = 2
#          Call SET_LEVDES([F:SCA]COD,IND_LEV+1)
#          Break
#        Endif
#      Next IND_LEV
#    Endif
#    If LFLAG_TROUVE = 1 Then
#      # Valeur incorrecte
#      GMESSAGE = mess(8,9137,1)
#      mkstat = 2 : End
#    Endif
#  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
End

######################################################################################
# Récupération de l'intitulé du niveau
######################################################################################
Subprog SET_LEVDES(P_SCALE,P_INDLEV)
Value Char P_SCALE
Value Integer P_INDLEV
  # Lecture de SCALED pour récupérer la description
  Read [F:HRSDD]SDD0 = P_SCALE;P_INDLEV
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  If !fstat Then
    [M:HRTRN1]LEVDES = [F:HRSDD]LEVDES
  Else
    Raz [M:HRTRN1]LEVDES
  Endif
  Affzo [M:HRTRN1]LEVDES

#  If !fstat Then
#    [M:TRN1]LEVDES = [F:SDD]LEVDES
#  Else
#    Raz [M:TRN1]LEVDES
#  Endif
#  Affzo [M:TRN1]LEVDES
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
End

######################################################################################
# Récupération du niveau dans SCALE pour en déduire son n° de ligne pour SCALED
######################################################################################
Subprog RECUP_LEVDES(P_SCALE, P_LEVEL)
Value Char P_SCALE,P_LEVEL
  Local Integer LFLAG_TROUVE : LFLAG_TROUVE = 1

  Read [F:HRSCA]SCA0 = P_SCALE
  If !fstat Then
    For IND_LEV = 0 To dim([F:HRSCA]LEV)-1
      If [F:HRSCA]LEV(IND_LEV) <> "" and [F:HRSCA]LEV(IND_LEV) = P_LEVEL Then
        LFLAG_TROUVE = 2
        Call SET_LEVDES([F:HRSCA]COD,IND_LEV+1)
        Break
      Endif
    Next IND_LEV
  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  If LFLAG_TROUVE = 1 Then
    Raz [M:HRTRN1]LEVDES
    Affzo [M:HRTRN1]LEVDES
  Endif

#  If LFLAG_TROUVE = 1 Then
#    Raz [M:TRN1]LEVDES
#    Affzo [M:TRN1]LEVDES
#  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
End

#**
#* SYMEU V6.1 Module Formation - Formateur interne
#* Vérification que le salarié n'est pas renseigné en tant que formateur
#* dans les stages ou les sessions
#*!
$VERIF_STG_SES
  If clalev([F:STG])=0 : Local File STAGE    [STG] : Endif
  If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  Filter [F:STG] Where [F:STG]TCHEMP = [M:HRTRN1]REFNUM
#  Filter [F:STG] Where [F:STG]TCHEMP = [M:TRN1]REFNUM
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
  If rowcount([F:STG]) > 0 Then
    L_OK = 0
  Endif
  Filter [F:STG]
  If L_OK<1 Then Return Endif

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  Filter [F:HRSES] Where [F:HRSES]TCHEMP = [M:HRTRN1]REFNUM
#  Filter [F:SES] Where [F:SES]TCHEMP = [M:TRN1]REFNUM
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
  If rowcount([F:HRSES]) > 0 Then
    L_OK = 0
  Endif
  Filter [F:HRSES]
Return

#LIPET - 2017-05-10 - X3-29536 - START
Subprog GET_LEG(P_CTRNUM)
Value Char P_CTRNUM

If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif
If clalev([F:FCY2])=0 : Local File FACILITY [FCY2]  : Endif

If P_CTRNUM<>""
   Filter  [HRCTR2] Where CTRNUM=P_CTRNUM
   Read [HRCTR2] Last
   Filter [HRCTR2]
    Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
    If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:HRTRN1]LEGORI = GCURLEG
    Affzo [M:HRTRN1]LEGORI
    Endif
  Endif
End
#LIPET - 2017-05-10 - X3-29536 - END

#LIPET - 2017-11-14 - X3-63817 - START
Subprog TUNHRTRN(COD)
Variable Char    COD()

Local Integer TOKILL

  TOKILL = 0
  If dim(VCOD)<1
   Global Char VCOD(GLONHRTRN)
   TOKILL = 1
  Endif

  If clalev([F:STG])=0 : Local File STAGE [STG] : Endif

  VCOD = COD

  If VCOD="" & GCURLEG <> "" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
  Filter [STG] Where LEG=GCURLEG
  Read [F:STG] First
  Filter [STG]
  If !fstat : VCOD=[F:STG]COD : Endif
  Else
   Read [STG]STG0 = VCOD
  Endif
  If GCURLEG <> "" Then
    Call OBJET("HRTRN",VCOD,GCURLEG) From GOBJET
  Else
    Call OBJET("HRTRN",VCOD,"") From GOBJET
  Endif
  COD = VCOD

  If TOKILL : Kill VCOD : Endif
End
#LIPET - 2017-11-14 - X3-63817 - END

