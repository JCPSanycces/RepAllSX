#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
Call OBJET("HRTRN",GBIDC1,GBIDC2) From GOBJET
#Call OBJET("TRN",GBIDC1,GBIDC2) From GOBJET
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
End


######################################################################################
# Gestion des Formateurs internes (SYMEU - Juillet 2010 - V6.1)
#     - EXI 66191 LOT 2
#     - Le formateur interne est dans la table TRAINER et plus dans les salariés
######################################################################################
$ACTION

Case ACTION
  When "OUVRE"          : Gosub OUVRE
  When "OUVRE_BOITE"    : Gosub OUVRE_BOITE
  When "LIENS"          : Gosub LIENS
  When "RAZCRE"         : Gosub RAZCRE
  When "FERME"          : Gosub FERME
  # Sélections
  When "SEL_LISTE"      : Gosub SEL_LISTE
  When "SEL_TABLE"      : Gosub SEL_TABLE
  When "FIN_TABLE"      : Gosub FIN_TABLE
  When "DEGRISE"        : Gosub DEGRISE
  # Navigation
  When "EXEACT"         : Gosub EXEACT
  When "FILTRE"         : Gosub FILTRE
Endcase
Return


######################################################################################
$OUVRE
  If clalev([F:ID])=0  : Local File EMPLOID  [ID]  : Endif
  #LIPET - 2017-05-10 - X3-29536 - START
  #If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
  #If clalev([F:SCA])=0 : Local File SCALE    [SCA] : Endif
  #If clalev([F:SDD])=0 : Local File SCALED   [SDD] : Endif
  If clalev([F:HRSDD])=0 : Local File SCALED   [HRSDD] : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:HRTRN])=0 : Local File TRAINER [HRTRN] : Endif
  If clalev([F:HRSCA])=0 : Local File SCALE    [HRSCA] : Endif
  #LIPET - 2017-05-10 - X3-29536 - END
  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Return

$OUVRE_BOITE
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  If GDOSLEG="POR" Then
    If dim([M:HRTRN1]PSD)>0 Then Chgfmt [M:HRTRN1]PSD With "-K:35X"   : Raz [M:HRTRN1]PSD : Endif
  Endif

#  If GDOSLEG="POR" Then
#    If dim([M:TRN1]PSD)>0 Then Chgfmt [M:TRN1]PSD With "-K:35X"   : Raz [M:TRN1]PSD : Endif
#  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
Return

######################################################################################
$LIENS
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
Call GET_TRAINER([M:HRTRN1]REFNUM)
#Call GET_TRAINER([M:TRN1]REFNUM)
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

  # Recherche site du contrat
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
Filter [F:HRCTR] Where REFNUM=[M:HRTRN1]REFNUM & CTRNUM=[M:HRTRN1]CTRNUM & CTRDAT<=date$ and (XITDAT=[0/0/0] | XITDAT>=date$) Order By CTRDAT Desc
  Read [F:HRCTR] First
  Filter [F:HRCTR]
  If !fstat Then
    [M:HRTRN1]FCY = [F:HRCTR]ETRFCY
    # Recherche société du contrat
    Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
    If !fstat Then
      [M:HRTRN1]CPY = [F:FCY]LEGCPY
    Endif
  Endif

#Filter [F:CTR] Where REFNUM=[M:TRN1]REFNUM & CTRNUM=[M:TRN1]CTRNUM & CTRDAT<=date$ and (XITDAT=[0/0/0] | XITDAT>=date$) Order By CTRDAT Desc
#  Read [F:CTR] First
#  Filter [F:CTR]
#  If !fstat Then
#    [M:TRN1]FCY = [F:CTR]ETRFCY
#    # Recherche société du contrat
#    Read [F:FCY]FCY0=[F:CTR]ETRFCY
#    If !fstat Then
#      [M:TRN1]CPY = [F:FCY]LEGCPY
#    Endif
#  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
If [M:HRTRN1]NBLIG > 0 Then
    Call RECUP_LEVDES([M:HRTRN1]CODSCA(0),[M:HRTRN1]LEV(0))
  Endif

#If [M:TRN1]NBLIG > 0 Then
#    Call RECUP_LEVDES([M:TRN1]CODSCA(0),[M:TRN1]LEV(0))
#  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

  # Mise à jour des derniers lus, quand on se déplace avec les boutons de navigation,
  # à cause de la clé de navigation qui est différente de la clé principale TRN0
  If dim([L]BOUT) > 0
    Case [L]BOUT
      When "<", ">", "0", "9"
        If GNBDERNIER<>0
         CLEPRIM="REFNUM" : CLESEC="CTRNUM"
         Gosub SET_DERLU From GOBJSUB
         CLEPRIM="CTRNUM" : CLESEC="REFNUM"
        Endif
    Endcase
  Endif

#LIPET - 2017-11-14 - X3-63985 - START
 If [M]CTRNUM <> "" Then
  Call GET_LEG([M]CTRNUM)
 Endif
#LIPET - 2017-11-14 - X3-63985 - END
Return

##############################################################################################
# Modifications pour se positionner sur le formateur interne, suivant la clé secondaire HRTRN1
##############################################################################################
$FILTRE

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
If dim([L]BOUT) > 0
    Case [L]BOUT
      When "<", ">" # précédent / suivant
        FILTRE = "[F:HRTRN]REFNUM=[M:HRTRN1]REFNUM & [F:HRTRN]CTRNUM=[M:HRTRN1]CTRNUM"
        If dim(CLEPRIM) > 0 and dim(CLESEC) > 0 Then
          CLEPRIM = "CTRNUM" : CLESEC = "REFNUM"
        Endif
        INDGES = 0
      When "0", "9" # début / fin
        FILTRE = "[F:HRTRN]REFNUM=[M:HRTRN1]REFNUM & [F:HRTRN]CTRNUM=[M:HRTRN1]CTRNUM"
        INDGES = 1
      When Default
        FILTRE=""
    Endcase
  Else
    FILTRE=""
  Endif

#If dim([L]BOUT) > 0
#    Case [L]BOUT
#      When "<", ">" # précédent / suivant
#        FILTRE = "[F:TRN]REFNUM=[M:TRN1]REFNUM & [F:TRN]CTRNUM=[M:TRN1]CTRNUM"
#        If dim(CLEPRIM) > 0 and dim(CLESEC) > 0 Then
#          CLEPRIM = "CTRNUM" : CLESEC = "REFNUM"
#        Endif
#        INDGES = 0
#      When "0", "9" # début / fin
#        FILTRE = "[F:TRN]REFNUM=[M:TRN1]REFNUM & [F:TRN]CTRNUM=[M:TRN1]CTRNUM"
#        INDGES = 1
#      When Default
#        FILTRE=""
#    Endcase
#  Else
#    FILTRE=""
#  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END


  If FILTRE = "" Then
    If dim(CLEPRIM) > 0 and dim(CLESEC) > 0 Then
      CLEPRIM = "REFNUM" : CLESEC = "CTRNUM"
    Endif
    INDGES = 1
  Endif

  If GUSRACS<>2
   FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
   FILTSUP -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))'
  Else
   FILTSUP = "1=1"
  Endif



Return

$FERME
  # To manage the button Tunnel
  If TUNNEL<>1 : Return : Endif
  If dim(VCOD)<1 : Global Char VCOD(GLONHRTRN) : Endif
  VCOD = CLE1
Return

######################################################################################
#**
#* Sélection dans une liste
#*!
$SEL_LISTE
  Case LISTE
    When "SELLEV" : Gosub S_SELLEV
  Endcase
Return


################################################################################
# Action Sélection en table
################################################################################
$SEL_TABLE
Case [L]TABLE
  When "SELFOR"    : Gosub S_SELFOR
  When "SELFORSTG" : Gosub S_SELFORSTG
  When "SELFORDOM" : Gosub S_SELFORDOM
  When "SELFORTHM" : Gosub S_SELFORTHM
Endcase
Return

$FIN_TABLE
Case [L]TABLE
  When "SELFOR", "SELFORSTG", "SELFORDOM", "SELFORTHM"

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
    If [F:HRTRN]REFNUM <> "" Then
      [L]VALEUR=[F:HRTRN]REFNUM
      [M]CTRNUM=[F:HRTRN]CTRNUM
      If dim([M]FCY) > 0 and dim([M]CPY)>0 Then
        # Recherche site du contrat
        Filter [F:HRCTR] Where REFNUM=[F:HRTRN]REFNUM & CTRNUM=[F:HRTRN]CTRNUM & CTRDAT<=date$ and (XITDAT=[0/0/0] | XITDAT>=date$) Order By CTRDAT Desc
        Read [F:HRCTR] First
        Filter [F:HRCTR]
        If !fstat Then
          [M]FCY = [F:HRCTR]ETRFCY
          # Recherche société du contrat
          Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
          If !fstat Then
            [M]CPY = [F:FCY]LEGCPY
          Endif
        Endif
      Endif

#    If [F:TRN]REFNUM <> "" Then
#      [L]VALEUR=[F:TRN]REFNUM
#      [M]CTRNUM=[F:TRN]CTRNUM
#      If dim([M]FCY) > 0 and dim([M]CPY)>0 Then
#        # Recherche site du contrat
#        Filter [F:CTR] Where REFNUM=[F:TRN]REFNUM & CTRNUM=[F:TRN]CTRNUM & CTRDAT<=date$ and (XITDAT=[0/0/0] | XITDAT>=date$) Order By CTRDAT Desc
#        Read [F:CTR] First
#        Filter [F:CTR]
#        If !fstat Then
#          [M]FCY = [F:CTR]ETRFCY
#          # Recherche société du contrat
#          Read [F:FCY]FCY0=[F:CTR]ETRFCY
#          If !fstat Then
#            [M]CPY = [F:FCY]LEGCPY
#          Endif
#        Endif
#      Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

      [M]NAM=[F:ID]NAM
      [M]SRN=[F:ID]SRN
    Endif
Endcase
Return

################################################################################
# Action SELFOR : sélection formateur interne
# Utilisée dans le Formateur interne
################################################################################
$S_SELFOR

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
 [L]OBJET = "HRTRN"
 [L]ORDRE = "[F:HRTRN]REFNUM;[F:HRTRN]CTRNUM"
 [L]EXPSTART = "[F:HRTRN]REFNUM>='"+VALEUR+"' and [F:HRTRN]CTRNUM>='"+[M]CTRNUM+"'"

# [L]OBJET = "TRN"
# [L]ORDRE = "[F:TRN]REFNUM;[F:TRN]CTRNUM"
# [L]EXPSTART = "[F:TRN]REFNUM>='"+VALEUR+"' and [F:TRN]CTRNUM>='"+[M]CTRNUM+"'"
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

Return

################################################################################
# Action SELFORSTG : sélection formateur interne
# Utilisée dans le Stage et la Session
################################################################################
$S_SELFORSTG
  Local Char CODFIC(GLONATB)

  If clalev([F:ID])=0  : Local File EMPLOID  [ID]  : Endif
  #LIPET - 2017-05-10 - X3-29536 - START
#  If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:HRTRN])=0 : Local File TRAINER [HRTRN] : Endif
  #LIPET - 2017-05-10 - X3-29536 - END
  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif

  # Je ne veux que les formateurs actifs qui ne sont pas sortis de la société

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  Link [F:HRTRN] With [F:ID]ID0=[F:HRTRN]REFNUM,
&                   [F:HRCTR]CTR0=[F:HRTRN]REFNUM;[F:HRTRN]CTRNUM,
&                   [F:FCY]FCY0=[F:HRCTR]ETRFCY
&                As [NEW]
&             Where [F:HRTRN]ENAFLG=2
&               and [F:HRCTR]CTRDAT<=date$ and ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)

#  Link [F:TRN] With [F:ID]ID0=[F:TRN]REFNUM,
#&                   [F:CTR]CTR0=[F:TRN]REFNUM;[F:TRN]CTRNUM,
#&                   [F:FCY]FCY0=[F:CTR]ETRFCY
#&                As [NEW]
#&             Where [F:TRN]ENAFLG=2
#&               and [F:CTR]CTRDAT<=date$ and ([F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>=date$)
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  TIT(0)  = mess(103,10717,1) : # Choix formateur interne
  Default File [NEW]
  NBCOL = 0
  CODFIC = "EMPLOID"
  # Colonne Nom
  NBCOL += 1 : TIT(NBCOL)=mess(38,100,1) : COL(NBCOL)="[F:ID]NAM"
  # Colonne Prénom
  NBCOL += 1 : TIT(NBCOL)=mess(69,10701,1) : COL(NBCOL)="[F:ID]SRN"
  # Colonne Société
  NBCOL += 1 : COL(NBCOL) = "CPY"
  Gosub TEXTE
  # COL(NBCOL)="[F:ID]CPY"
  COL(NBCOL)="[F:FCY]LEGCPY"
  # Colonne Site
  NBCOL += 1 : TIT(NBCOL)=mess(7,47,1)
  # COL(NBCOL)="[F:ID]FCY"
  COL(NBCOL)="[F:FCY]FCY"
  # Colonne Contrat
  NBCOL += 1 : COL(NBCOL) = "CTRNUM"
  CODFIC = "TRAINER" : Gosub TEXTE
  # Colonne Date du contrat
  NBCOL += 1 : COL(NBCOL) = "CTRDAT"
#  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:CTR]CTRDAT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]CTRDAT"
  # [L]ORDRE = "[F:ID]NAM;[F:ID]SRN;[F:ID]CPY;[F:ID]FCY;[F:TRN]CTRNUM"
  [L]ORDRE = "[F:ID]NAM;[F:ID]SRN;[F:FCY]LEGCPY;[F:FCY]FCY;[F:HRTRN]CTRNUM"
  [L]EXPSTART = "[F:ID]NAM>='"+evalue([L]PARAM(1))+"' and [F:ID]SRN>='"+evalue([L]PARAM(2))+"'"

#  TIT(0)  = mess(103,717,1) : # Choix formateur interne
#  Default File [NEW]
#  NBCOL = 0
#  CODFIC = "EMPLOID"
#  # Colonne Nom
#  NBCOL += 1 : TIT(NBCOL)=mess(38,100,1) : COL(NBCOL)="[F:ID]NAM"
#  # Colonne Prénom
#  NBCOL += 1 : TIT(NBCOL)=mess(69,701,1) : COL(NBCOL)="[F:ID]SRN"
#  # Colonne Société
#  NBCOL += 1 : COL(NBCOL) = "CPY"
#  Gosub TEXTE
#  # COL(NBCOL)="[F:ID]CPY"
#  COL(NBCOL)="[F:FCY]LEGCPY"
#  # Colonne Site
#  NBCOL += 1 : TIT(NBCOL)=mess(7,47,1)
#  # COL(NBCOL)="[F:ID]FCY"
#  COL(NBCOL)="[F:FCY]FCY"
#  # Colonne Contrat
#  NBCOL += 1 : COL(NBCOL) = "CTRNUM"
#  CODFIC = "TRAINER" : Gosub TEXTE
#  # Colonne Date du contrat
#  NBCOL += 1 : COL(NBCOL) = "CTRDAT"
#  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:CTR]CTRDAT"
#
#  # [L]ORDRE = "[F:ID]NAM;[F:ID]SRN;[F:ID]CPY;[F:ID]FCY;[F:TRN]CTRNUM"
#  [L]ORDRE = "[F:ID]NAM;[F:ID]SRN;[F:FCY]LEGCPY;[F:FCY]FCY;[F:TRN]CTRNUM"
#  [L]EXPSTART = "[F:ID]NAM>='"+evalue([L]PARAM(1))+"' and [F:ID]SRN>='"+evalue([L]PARAM(2))+"'"
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

Return

$RAZCRE
##Reset GCURLEG
 Raz GCURLEG
Return

################################################################################
# Action SELFORDOM : sélection formateur interne filtrée par domaine
# Utilisée dans le Stage et la Session
################################################################################
$S_SELFORDOM
  Local Char CODFIC(GLONATB), L_LIBELLE

  If clalev([F:ID])=0  : Local File EMPLOID  [ID]  : Endif
  #LIPET - 2017-05-10 - X3-29536 - START
  #If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  #LIPET - 2017-05-10 - X3-29536 - END
  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
  # récupération de l'intitulé du Domaine

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
Call LECTEXTRA (L_LIBELLE,"ATABDIV","LNGDES","10381",[M]DOM) From ATEXTRA

#Call LECTEXTRA (L_LIBELLE,"ATABDIV","LNGDES","381",[M]DOM) From ATEXTRA
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

#DIRAS - 27/03/2017 - JIRA X3-29536 - START

  # Je ne veux que les formateurs actifs qui ne sont pas sortis de la société
  # et qui ont dans leur spécialité le domaine
  Link [F:HRTRN] With [F:ID]ID0=[F:HRTRN]REFNUM,
&                   [F:HRCTR]CTR0=[F:HRTRN]REFNUM;[F:HRTRN]CTRNUM,
&                   [F:FCY]FCY0=[F:HRCTR]ETRFCY
&                As [NEW]
&             Where [F:HRTRN]ENAFLG=2
&               and [F:HRCTR]CTRDAT<=date$ and ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)
&               and ([F:HRTRN]DOM(0) = [M]DOM or [F:HRTRN]DOM(1) = [M]DOM
&                or  [F:HRTRN]DOM(2) = [M]DOM or [F:HRTRN]DOM(3) = [M]DOM
&                or  [F:HRTRN]DOM(4) = [M]DOM or [F:HRTRN]DOM(5) = [M]DOM
&                or  [F:HRTRN]DOM(6) = [M]DOM or [F:HRTRN]DOM(7) = [M]DOM
&                or  [F:HRTRN]DOM(8) = [M]DOM or [F:HRTRN]DOM(9) = [M]DOM)

#  Link [F:TRN] With [F:ID]ID0=[F:TRN]REFNUM,
#&                   [F:CTR]CTR0=[F:TRN]REFNUM;[F:TRN]CTRNUM,
#&                   [F:FCY]FCY0=[F:CTR]ETRFCY
#&                As [NEW]
#&             Where [F:TRN]ENAFLG=2
#&               and [F:CTR]CTRDAT<=date$ and ([F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>=date$)
#&               and ([F:TRN]DOM(0) = [M]DOM or [F:TRN]DOM(1) = [M]DOM
#&                or  [F:TRN]DOM(2) = [M]DOM or [F:TRN]DOM(3) = [M]DOM
#&                or  [F:TRN]DOM(4) = [M]DOM or [F:TRN]DOM(5) = [M]DOM
#&                or  [F:TRN]DOM(6) = [M]DOM or [F:TRN]DOM(7) = [M]DOM
#&                or  [F:TRN]DOM(8) = [M]DOM or [F:TRN]DOM(9) = [M]DOM)
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  TIT(0)  = mess(103,10717,1) : # Choix formateur interne
  Default File [NEW]

#  TIT(0)  = mess(103,717,1) : # Choix formateur interne
#  Default File [NEW]
#DIRAS - 27/03/2017 - JIRA X3-29536 - END


#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  NBCOL = 0
  CODFIC = "EMPLOID"
  # Colonne Nom
  NBCOL += 1 : TIT(NBCOL)=mess(38,100,1) : COL(NBCOL)="[F:ID]NAM"
  # Colonne Prénom
  NBCOL += 1 : TIT(NBCOL)=mess(69,10701,1)  : COL(NBCOL)="[F:ID]SRN"
  # Colonne Société
  NBCOL += 1 : COL(NBCOL) = "CPY"
  Gosub TEXTE
  # COL(NBCOL)="[F:ID]CPY"
  COL(NBCOL)="[F:FCY]LEGCPY"
  # Colonne Site
  NBCOL += 1 : TIT(NBCOL)=mess(7,47,1)
  # COL(NBCOL)="[F:ID]FCY"
  COL(NBCOL)="[F:FCY]FCY"
  # Colonne Domaine
  NBCOL += 1 : TIT(NBCOL)=mess(104,10717,1) : COL(NBCOL)="[M]DOM"
  # Colonne Intitulé du domaine
  NBCOL += 1 : TIT(NBCOL)=mess(30,109,1) : COL(NBCOL)="'"+L_LIBELLE+"'"
  # Colonne Niveau
  NBCOL += 1 : TIT(NBCOL)=mess(95,10717,1)
  # COL(NBCOL) = "max(LEV)"
  COL(NBCOL) = "max(LEV(0),LEV(1),LEV(2),LEV(3),LEV(4),LEV(5),LEV(6),LEV(7),LEV(8),LEV(9))"
  # Colonne Contrat
  NBCOL += 1 : COL(NBCOL) = "CTRNUM"
  CODFIC = "TRAINER" : Gosub TEXTE
  # Colonne Date du contrat
  NBCOL += 1 : COL(NBCOL) = "CTRDAT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:CTR]CTRDAT"

#  NBCOL = 0
#  CODFIC = "EMPLOID"
#  # Colonne Nom
#  NBCOL += 1 : TIT(NBCOL)=mess(38,100,1) : COL(NBCOL)="[F:ID]NAM"
#  # Colonne Prénom
#  NBCOL += 1 : TIT(NBCOL)=mess(69,701,1)  : COL(NBCOL)="[F:ID]SRN"
#  # Colonne Société
#  NBCOL += 1 : COL(NBCOL) = "CPY"
#  Gosub TEXTE
#  # COL(NBCOL)="[F:ID]CPY"
#  COL(NBCOL)="[F:FCY]LEGCPY"
#  # Colonne Site
#  NBCOL += 1 : TIT(NBCOL)=mess(7,47,1)
#  # COL(NBCOL)="[F:ID]FCY"
#  COL(NBCOL)="[F:FCY]FCY"
#  # Colonne Domaine
#  NBCOL += 1 : TIT(NBCOL)=mess(104,717,1) : COL(NBCOL)="[M]DOM"
#  # Colonne Intitulé du domaine
#  NBCOL += 1 : TIT(NBCOL)=mess(30,109,1) : COL(NBCOL)="'"+L_LIBELLE+"'"
#  # Colonne Niveau
#  NBCOL += 1 : TIT(NBCOL)=mess(95,717,1)
#  # COL(NBCOL) = "max(LEV)"
#  COL(NBCOL) = "max(LEV(0),LEV(1),LEV(2),LEV(3),LEV(4),LEV(5),LEV(6),LEV(7),LEV(8),LEV(9))"
#  # Colonne Contrat
#  NBCOL += 1 : COL(NBCOL) = "CTRNUM"
#  CODFIC = "TRAINER" : Gosub TEXTE
#  # Colonne Date du contrat
#  NBCOL += 1 : COL(NBCOL) = "CTRDAT"
#  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:CTR]CTRDAT"
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

  # [L]ORDRE = "[F:ID]NAM;[F:ID]SRN;[F:ID]CPY;[F:ID]FCY;[F:TRN]CTRNUM"
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  [L]ORDRE = "[F:ID]NAM;[F:ID]SRN;[F:FCY]LEGCPY;[F:FCY]FCY;[F:HRTRN]CTRNUM"
#  [L]ORDRE = "[F:ID]NAM;[F:ID]SRN;[F:FCY]LEGCPY;[F:FCY]FCY;[F:TRN]CTRNUM"
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
  [L]EXPSTART = "[F:ID]NAM>='"+evalue([L]PARAM(1))+"' and [F:ID]SRN>='"+evalue([L]PARAM(2))+"'"

Return

################################################################################
# Action SELFORTHM : sélection formateur interne filtrée par thème
# Utilisée dans le Stage et la Session
################################################################################
$S_SELFORTHM
 Local Char CODFIC(GLONATB), L_LIBELLE

  If clalev([F:ID])=0  : Local File EMPLOID  [ID]  : Endif
  #LIPET - 2017-05-10 - X3-29536 - START
  #If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  #LIPET - 2017-05-10 - X3-29536 - END
  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
  # récupération de l'intitulé du Thème

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  Call LECTEXTRA (L_LIBELLE,"ATABDIV","LNGDES","10457",[M]THM) From ATEXTRA
  #Call LECTEXTRA (L_LIBELLE,"ATABDIV","LNGDES","457",[M]THM) From ATEXTRA
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  # Je ne veux que les formateurs actifs qui ne sont pas sortis de la société
  # et qui ont dans leur spécialité le thème
  Link [F:HRTRN] With [F:ID]ID0=[F:HRTRN]REFNUM,
&                   [F:HRCTR]CTR0=[F:HRTRN]REFNUM;[F:HRTRN]CTRNUM,
&                   [F:FCY]FCY0=[F:HRCTR]ETRFCY
&                As [NEW]
&             Where [F:HRTRN]ENAFLG=2
&               and [F:HRCTR]CTRDAT<=date$ and ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)
&               and ([F:HRTRN]THM(0) = [M]THM or [F:HRTRN]THM(1) = [M]THM
&                or  [F:HRTRN]THM(2) = [M]THM or [F:HRTRN]THM(3) = [M]THM
&                or  [F:HRTRN]THM(4) = [M]THM or [F:HRTRN]THM(5) = [M]THM
&                or  [F:HRTRN]THM(6) = [M]THM or [F:HRTRN]THM(7) = [M]THM
&                or  [F:HRTRN]THM(8) = [M]THM or [F:HRTRN]THM(9) = [M]THM)

## Je ne veux que les formateurs actifs qui ne sont pas sortis de la société
#  # et qui ont dans leur spécialité le thème
#  Link [F:TRN] With [F:ID]ID0=[F:TRN]REFNUM,
#&                   [F:CTR]CTR0=[F:TRN]REFNUM;[F:TRN]CTRNUM,
#&                   [F:FCY]FCY0=[F:CTR]ETRFCY
#&                As [NEW]
#&             Where [F:TRN]ENAFLG=2
#&               and [F:CTR]CTRDAT<=date$ and ([F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>=date$)
#&               and ([F:TRN]THM(0) = [M]THM or [F:TRN]THM(1) = [M]THM
#&                or  [F:TRN]THM(2) = [M]THM or [F:TRN]THM(3) = [M]THM
#&                or  [F:TRN]THM(4) = [M]THM or [F:TRN]THM(5) = [M]THM
#&                or  [F:TRN]THM(6) = [M]THM or [F:TRN]THM(7) = [M]THM
#&                or  [F:TRN]THM(8) = [M]THM or [F:TRN]THM(9) = [M]THM)
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  TIT(0)  = mess(103,10717,1) : # Choix formateur interne
  Default File [NEW]

#  TIT(0)  = mess(103,717,1) : # Choix formateur interne
#  Default File [NEW]
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  NBCOL = 0
  CODFIC = "EMPLOID"
  # Colonne Nom
  NBCOL += 1 : TIT(NBCOL)=mess(38,100,1) : COL(NBCOL)="[F:ID]NAM"
  # Colonne Prénom
  NBCOL += 1 : TIT(NBCOL)=mess(69,10701,1)  : COL(NBCOL)="[F:ID]SRN"
  # Colonne Société
  NBCOL += 1 : COL(NBCOL) = "CPY"
  Gosub TEXTE
  # COL(NBCOL)="[F:ID]CPY"
  COL(NBCOL)="[F:FCY]LEGCPY"
  # Colonne Site
  NBCOL += 1 : TIT(NBCOL)=mess(7,47,1)
  # COL(NBCOL)="[F:ID]FCY"
  COL(NBCOL)="[F:FCY]FCY"
  # Colonne Thème
  NBCOL += 1 : TIT(NBCOL)=mess(105,10717,1) : COL(NBCOL)="[M]THM"
  # Colonne Intitulé du thème
  NBCOL += 1 : TIT(NBCOL)=mess(30,109,1) : COL(NBCOL)="'"+L_LIBELLE+"'"
  # Colonne Niveau
  NBCOL += 1 : TIT(NBCOL)=mess(95,10717,1)
  # COL(NBCOL) = "max(LEV)"
  COL(NBCOL) = "max(LEV(0),LEV(1),LEV(2),LEV(3),LEV(4),LEV(5),LEV(6),LEV(7),LEV(8),LEV(9))"
  # Colonne Contrat
  NBCOL += 1 : COL(NBCOL) = "CTRNUM"
  CODFIC = "TRAINER" : Gosub TEXTE
  # Colonne Date du contrat
  NBCOL += 1 : COL(NBCOL) = "CTRDAT"
  #LIPET - 2017-05-10 - X3-29536 - START
  #CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:CTR]CTRDAT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]CTRDAT"
  #LIPET - 2017-05-10 - X3-29536 - END

  # [L]ORDRE = "[F:ID]NAM;[F:ID]SRN;[F:ID]CPY;[F:ID]FCY;[F:TRN]CTRNUM"
  [L]ORDRE = "[F:ID]NAM;[F:ID]SRN;[F:FCY]LEGCPY;[F:FCY]FCY;[F:HRTRN]CTRNUM"
  [L]EXPSTART = "[F:ID]NAM>='"+evalue([L]PARAM(1))+"' and [F:ID]SRN>='"+evalue([L]PARAM(2))+"'"

#  NBCOL = 0
#  CODFIC = "EMPLOID"
