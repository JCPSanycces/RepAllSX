######################################################################################
# Lors de la navigation, elle se fait par défaut sur la clé primaire (contrat/matricule),
# donc sur le contrat. On force ici le déplacement sur la clé matricule.
######################################################################################
$EXEACT
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  Case [L]BOUT
    When "0"
      # Je me place sur le premier enregistrement
      Filter [F:HRTRN] Order By Key TRN1
      Read [F:HRTRN] First
      Filter [F:HRTRN]
      [M:HRTRN1]REFNUM = [F:HRTRN]REFNUM
      [M:HRTRN1]CTRNUM = [F:HRTRN]CTRNUM
      Gosub GET_FCY_CPY
    When "9"
      # Je me place sur le dernier enregistrement
      Filter [F:HRTRN] Order By Key TRN1
      Read [F:HRTRN] Last
      Filter [F:HRTRN]
      [M:HRTRN1]REFNUM = [F:HRTRN]REFNUM
      [M:HRTRN1]CTRNUM = [F:HRTRN]CTRNUM
      Gosub GET_FCY_CPY
    When "<"
      # Je me place sur l'enregistrement précédent
      Filter [F:HRTRN] Where (REFNUM = [M:HRTRN1]REFNUM and CTRNUM < [M:HRTRN1]CTRNUM)
&                       or (REFNUM < [M:HRTRN1]REFNUM)
&      Order By Key TRN1
      Read [F:HRTRN] Last
      Filter [F:HRTRN]
      If fstat
        [V]GMESSAGE=mess(11,100,1) : # Début/fin de fichier
        [V]GERR    =1
        [L]OK      =0
        Return
      Endif
      [M:HRTRN1]REFNUM = [F:HRTRN]REFNUM
      [M:HRTRN1]CTRNUM = [F:HRTRN]CTRNUM
      Gosub GET_FCY_CPY
    When ">"
      # Je me place sur l'enregistrement suivant
      Filter [F:HRTRN] Where (REFNUM = [M:HRTRN1]REFNUM and CTRNUM > [M:HRTRN1]CTRNUM)
&                       or (REFNUM > [M:HRTRN1]REFNUM)
&      Order By Key HRTRN1
      Read [F:HRTRN] First
      Filter [F:HRTRN]
      If fstat
        [V]GMESSAGE=mess(11,100,1) : # Début/fin de fichier
        [V]GERR    =1
        [L]OK      =0
        Return
      Endif
      [M:HRTRN1]REFNUM = [F:HRTRN]REFNUM
      [M:HRTRN1]CTRNUM = [F:HRTRN]CTRNUM
      Gosub GET_FCY_CPY
    When Default
      Return
  Endcase

#  Case [L]BOUT
#    When "0"
