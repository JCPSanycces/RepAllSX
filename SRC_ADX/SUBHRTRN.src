$DEGRISE

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  # Quand on rendait la fiche inactive, après l'enregistrement, le contrat était dégrisé.
  # Je teste ici le flag multi-contrat pour savoir s'il faut griser le contrat.
  If func READ_EMP([M:HRTRN1]REFNUM) = 0 Then
    Call GRISE_CTRNUM([F:ID]FLGMULCTR)
    Call GRISE_ENAFLG([F:ID]ENAFLG)
  Else
    Call GRISE_CTRNUM(1)
  Endif

