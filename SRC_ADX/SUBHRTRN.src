$GET_FCY_CPY
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
# Recherche site du contrat
  Filter [F:HRCTR] Where REFNUM=[F:HRTRN]REFNUM & CTRNUM=[F:HRTRN]CTRNUM & CTRDAT<=date$ and (XITDAT=[0/0/0] | XITDAT>=date$) Order By CTRDAT Desc
  Read [F:HRCTR] First
  Filter [F:HRCTR]
  If !fstat Then
    [M:HRTRN1]FCY = [F:HRCTR]ETRFCY
    # Recherche société du contrat
    Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
    If !fstat Then
      [M:HRTRN1]CPY = [F:FCY]LEGCPY
    Endif
  Endif

#  # Recherche site du contrat
#  Filter [F:CTR] Where REFNUM=[F:TRN]REFNUM & CTRNUM=[F:TRN]CTRNUM & CTRDAT<=date$ and (XITDAT=[0/0/0] | XITDAT>=date$) Order By CTRDAT Desc
