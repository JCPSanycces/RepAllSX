#    Endif
#  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
Return
######################################################################################
#**
#* Sélection des niveaux correspondant à l'échelle de niveaux
#*!
$S_SELLEV
  Local Char TEXTE(30)(1..99,1..2)
  Local Integer  I, IND_LEV
  I=0

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
 # Titre de la liste
  TIT(0) = mess(18,100,1) # Sélection
  # Titre des colonnes
  TIT(1) = mess(95,10717,1) # Niveau
  TIT(2) = mess(96,10717,1) # Echelle de référence
  Read [F:HRSCA]SCA0 = PARAM(1)
  If !fstat Then
    For IND_LEV = 0 To dim([F:HRSCA]LEV)-1
      If [F:HRSCA]LEV(IND_LEV) <> "" Then
        I += 1
        TEX(I) = [F:HRSCA]LEV(IND_LEV) # champ qui va être alimenté suite à la sélection
        TEXTE(I,1) = [F:HRSCA]LEV(IND_LEV)
        TEXTE(I,2) = num$([F:HRSCA]LEVREF(IND_LEV))
      Else
        Break
      Endif
    Next IND_LEV
  Endif
  NBTEX=I

#  # Titre de la liste
#  TIT(0) = mess(18,100,1) # Sélection
#  # Titre des colonnes
#  TIT(1) = mess(95,717,1) # Niveau
#  TIT(2) = mess(96,717,1) # Echelle de référence
#  Read [F:SCA]SCA0 = PARAM(1)
#  If !fstat Then
#    For IND_LEV = 0 To dim([F:SCA]LEV)-1
#      If [F:SCA]LEV(IND_LEV) <> "" Then
#        I += 1
#        TEX(I) = [F:SCA]LEV(IND_LEV) # champ qui va être alimenté suite à la sélection
#        TEXTE(I,1) = [F:SCA]LEV(IND_LEV)
#        TEXTE(I,2) = num$([F:SCA]LEVREF(IND_LEV))
#      Else
#        Break
#      Endif
#    Next IND_LEV
#  Endif
#  NBTEX=I
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
Return

