######################################################################################
#**
#* Récupération des informations du salarié : site, société, civilité, pseudo, nom, prénom
#*
#* @param P_REFNUM : matricule qui est cherché
#*!
Subprog GET_TRAINER(P_REFNUM)
Value Char P_REFNUM
#LIPET - 2017-05-10 - X3-29536 - START
#Local Char CONTRAT(GLONCTR)
Local Char CONTRAT(GLONHRCTR)
#LIPET - 2017-05-10 - X3-29536 - END

#DIRAS - 27/03/2017 - JIRA X3-29536 - START

  If func READ_EMP(P_REFNUM) = 0 Then
    [M:HRTRN1]FCY = [F:ID]FCY
    [M:HRTRN1]CPY = [F:ID]CPY
    [M:HRTRN1]CIV = [F:ID]CIV
    If dim([M:HRTRN1]PSD) > 0 Then
      [M:HRTRN1]PSD = [F:ID]PSD
    Endif
    [M:HRTRN1]NAM = [F:ID]NAM
    [M:HRTRN1]SRN = [F:ID]SRN
    If [F:ID]FLGMULCTR<>2
      Call CHERCHE_CTR(P_REFNUM,date$,CONTRAT) From DIVPAYE
      [M:HRTRN1]CTRNUM = CONTRAT
      Call GET_LEG(CONTRAT)
      # Recherche site du contrat
      Filter [F:HRCTR] Where REFNUM=P_REFNUM & CTRNUM=CONTRAT & CTRDAT<=date$ and (XITDAT=[0/0/0] | XITDAT>=date$) Order By CTRDAT Desc
      Read [F:HRCTR] First
      Filter [F:HRCTR]
      If !fstat Then
        [M:HRTRN1]FCY = [F:HRCTR]ETRFCY
        # Recherche société du contrat
        Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
        If !fstat Then
          [M:HRTRN1]CPY = [F:FCY]LEGCPY
        Endif
      Endif
    Else
      If P_REFNUM <> [M:HRTRN1]REFNUM
&     and (P_REFNUM <> [F:HRTRN]REFNUM
&      or (P_REFNUM = [F:HRTRN]REFNUM) and [M:HRTRN1]CTRNUM <> [F:HRTRN]CTRNUM) Then
        Raz [M:HRTRN1]CTRNUM : Affzo [M:HRTRN1]CTRNUM
      Endif
    Endif
    Affzo [M:HRTRN1]REFNUM, FCY, CPY, 10
    Call GRISE_CTRNUM([F:ID]FLGMULCTR)
    Call GRISE_ENAFLG([F:ID]ENAFLG)
  Else
    Effzo 5, 10
    [M:HRTRN1]REFNUM = P_REFNUM
    Affzo [M:HRTRN1]REFNUM
    Call GRISE_CTRNUM(1)
  Endif

#  If func READ_EMP(P_REFNUM) = 0 Then
#    [M:TRN1]FCY = [F:ID]FCY
#    [M:TRN1]CPY = [F:ID]CPY
#    [M:TRN1]CIV = [F:ID]CIV
#    If dim([M:TRN1]PSD) > 0 Then
#      [M:TRN1]PSD = [F:ID]PSD
#    Endif
#    [M:TRN1]NAM = [F:ID]NAM
#    [M:TRN1]SRN = [F:ID]SRN
#    If [F:ID]FLGMULCTR<>2
#      Call CHERCHE_CTR(P_REFNUM,date$,CONTRAT) From DIVPAYE
#      [M:TRN1]CTRNUM = CONTRAT
#      # Recherche site du contrat
#      Filter [F:CTR] Where REFNUM=P_REFNUM & CTRNUM=CONTRAT & CTRDAT<=date$ and (XITDAT=[0/0/0] | XITDAT>=date$) Order By CTRDAT Desc
#      Read [F:CTR] First
#      Filter [F:CTR]
#      If !fstat Then
#        [M:TRN1]FCY = [F:CTR]ETRFCY
#        # Recherche société du contrat
#        Read [F:FCY]FCY0=[F:CTR]ETRFCY
#        If !fstat Then
#          [M:TRN1]CPY = [F:FCY]LEGCPY
#        Endif
#      Endif
#    Else
#      If P_REFNUM <> [M:TRN1]REFNUM
#&     and (P_REFNUM <> [F:TRN]REFNUM
#&      or (P_REFNUM = [F:TRN]REFNUM) and [M:TRN1]CTRNUM <> [F:TRN]CTRNUM) Then
#        Raz [M:TRN1]CTRNUM : Affzo [M:TRN1]CTRNUM
#      Endif
#    Endif
#    Affzo [M:TRN1]REFNUM, FCY, CPY, 10
#    Call GRISE_CTRNUM([F:ID]FLGMULCTR)
#    Call GRISE_ENAFLG([F:ID]ENAFLG)
#  Else
#    Effzo 5, 10
#    [M:TRN1]REFNUM = P_REFNUM
#    Affzo [M:TRN1]REFNUM
#    Call GRISE_CTRNUM(1)
#  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
