######################################################################################
#**
#* Lecture du contrat pour voir s'il y a une date de sortie et si elle est définitive
#*!
Funprog CONTRAT_EN_COURS(P_REFNUM, P_CTRNUM)
Value Char P_REFNUM, P_CTRNUM
  If P_CTRNUM = "" Then End 2 Endif

  Local Integer LFLG_CONTRAT_ENCOURS : LFLG_CONTRAT_ENCOURS = 1
#LIPET - 2017-05-10 - X3-29536 - START
  # Recherche des différents contrats de travail, pour voir s'il y en a un en cours
  # J'ai pris les mêmes critères que dans la fenêtre de sélection des contrats
#  Filter [F:CTR] Where REFNUM=P_REFNUM and CTRNUM=P_CTRNUM and CTRDAT<=date$
#&                  and (XITDAT = [0/0/0] or XITDAT >= date$)
#&             Order By CTRDAT Asc
#  If rowcount([F:CTR]) > 0 Then
#    LFLG_CONTRAT_ENCOURS = 2
#  Endif
#  Filter [F:CTR]
  Filter [F:HRCTR] Where REFNUM=P_REFNUM and CTRNUM=P_CTRNUM and CTRDAT<=date$
&                  and (XITDAT = [0/0/0] or XITDAT >= date$)
&             Order By CTRDAT Asc
  If rowcount([F:HRCTR]) > 0 Then
    LFLG_CONTRAT_ENCOURS = 2
  Endif
  Filter [F:HRCTR]
#LIPET - 2017-05-10 - X3-29536 - END
End LFLG_CONTRAT_ENCOURS

######################################################################################
#**
#* Lecture de la table d'état civil EMPLOID
#*
#* @param P_REFNUM : matricule qui est cherché
#*!
Funprog READ_EMP(P_REFNUM)
Value Char P_REFNUM
  Read [F:ID]ID0 = P_REFNUM
End fstat

######################################################################################
#**
#* Lecture de la table des formateurs internes
#*
#* @param P_REFNUM : matricule qui est cherché
#*!
Funprog READ_TRN(P_REFNUM)
Value Char P_REFNUM
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
Read [F:HRTRN]TRN1 = P_REFNUM
#Read [F:TRN]TRN1 = P_REFNUM
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
End fstat

#=====================================================================================
# ACTIONS SUR CHAMP
#=====================================================================================

######################################################################################
# CONTROLE du Matricule : ce doit être un formateur ou un employé
######################################################################################
Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
If func READ_TRN(VALEUR) > 0 Then
    If func READ_EMP(VALEUR) > 0 Then
      # Ce salarié n'existe pas
      GMESSAGE = mess(94,10717,1)
      mkstat=2
    Elsif [F:ID]ENAFLG = 1 Then
      # Ce salarié est inactif
      GMESSAGE = mess(100,10717,1)
      mkstat=2
    Endif
  Endif
#LIPET - 2017-11-02 - START
Call GET_TRAINER(VALEUR)
#LIPET - 2017-11-02 - END
#  If func READ_TRN(VALEUR) > 0 Then
#    If func READ_EMP(VALEUR) > 0 Then
#      # Ce salarié n'existe pas
#      GMESSAGE = mess(94,717,1)
#      mkstat=2
#    Elsif [F:ID]ENAFLG = 1 Then
#      # Ce salarié est inactif
#      GMESSAGE = mess(100,717,1)
#      mkstat=2
#    Endif
#  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
End

######################################################################################
# APRES_MODIF du Matricule : récupération / sélection du contrat
######################################################################################
Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()

#  If [M:TRN1]REFNUM <> VALEUR Then
#    Raz [M:TRN1]CTRNUM
#    Affzo [M:TRN1]CTRNUM
#  Endif
  Call GET_TRAINER(VALEUR)
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  If func CONTRAT_EN_COURS(VALEUR, [M:HRTRN1]CTRNUM) = 1 Then
    GMESSAGE = mess(101,10717,1)
#    If func CONTRAT_EN_COURS(VALEUR, [M:TRN1]CTRNUM) = 1 Then
#    GMESSAGE = mess(101,717,1)
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
    mkstat = 2 : End
  Endif

End

######################################################################################
# (Dé)Grisage du contrat
######################################################################################
Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  If VALEUR=2
   Actzo [M:HRTRN1]CTRNUM
  Else
   Diszo [M:HRTRN1]CTRNUM
  Endif
  Affzo [M:HRTRN1]CTRNUM

#  If VALEUR=2
#   Actzo [M:TRN1]CTRNUM
#  Else
#   Diszo [M:TRN1]CTRNUM
#  Endif
#  Affzo [M:TRN1]CTRNUM
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
End

######################################################################################
# (Dé)Grisage du flag actif
######################################################################################
Subprog GRISE_ENAFLG(P_ID_ENAFLG)
Value Integer P_ID_ENAFLG

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  If P_ID_ENAFLG = 1
& or func CONTRAT_EN_COURS([F:ID]REFNUM, [M:HRTRN1]CTRNUM) = 1 Then
    # Le salarié est inactif ou il n'a aucun contrat en cours
    Diszo [M:HRTRN1]ENAFLG
  Else
    Actzo [M:HRTRN1]ENAFLG
  Endif

#  If P_ID_ENAFLG = 1
#& or func CONTRAT_EN_COURS([F:ID]REFNUM, [M:TRN1]CTRNUM) = 1 Then
#    # Le salarié est inactif ou il n'a aucun contrat en cours
#    Diszo [M:TRN1]ENAFLG
#  Else
#    Actzo [M:TRN1]ENAFLG
#  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
End

######################################################################################
# AVANT_SAISIE du Contrat : affichage de la fenêtre de choix du contrat
######################################################################################
Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  If [M:HRTRN1]CTRNUM=""
   Call SELCTR([M:HRTRN1]REFNUM,date$,date$,VALEUR) From DIVPAYE
  Endif
  Local Integer MULTI_CONTRAT : MULTI_CONTRAT = 1
  # Accès au champ contrat dépend du flag multi-contrat du salarié
  If [M:HRTRN1]REFNUM <> [F:ID]REFNUM or [F:ID]REFNUM = "" Then
    If func READ_EMP([M:HRTRN1]REFNUM) = 0 Then
      MULTI_CONTRAT = [F:ID]FLGMULCTR
    Endif
  Else
    MULTI_CONTRAT = [F:ID]FLGMULCTR
  Endif

#  If [M:TRN1]CTRNUM=""
#   Call SELCTR([M:TRN1]REFNUM,date$,date$,VALEUR) From DIVPAYE
#  Endif
#  Local Integer MULTI_CONTRAT : MULTI_CONTRAT = 1
#  # Accès au champ contrat dépend du flag multi-contrat du salarié
#  If [M:TRN1]REFNUM <> [F:ID]REFNUM or [F:ID]REFNUM = "" Then
#    If func READ_EMP([M:TRN1]REFNUM) = 0 Then
#      MULTI_CONTRAT = [F:ID]FLGMULCTR
#    Endif
#  Else
#    MULTI_CONTRAT = [F:ID]FLGMULCTR
#  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
  Call GRISE_CTRNUM(MULTI_CONTRAT)
End

######################################################################################
# CONTROLE du Contrat : il est obligatoire
######################################################################################
Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  If [M:HRTRN1]REFNUM <> "" & VALEUR = ""
    # Zone obligatoire
    GMESSAGE = mess(10,123,1)
    mkstat = 2 : End
  Endif
  If func CONTRAT_EN_COURS([M:HRTRN1]REFNUM, VALEUR) = 1 Then
    GMESSAGE = mess(101,10717,1)
    mkstat = 2 : End
  Endif


#  If [M:TRN1]REFNUM <> "" & VALEUR = ""
#    # Zone obligatoire
#    GMESSAGE = mess(10,123,1)
#    mkstat = 2 : End
#  Endif
#  If func CONTRAT_EN_COURS([M:TRN1]REFNUM, VALEUR) = 1 Then
#    GMESSAGE = mess(101,717,1)
#    mkstat = 2 : End
#  Endif
#DIRAS - 27/03/2017 - JIRA X3-29536 - END

#DIRAS - 27/03/2017 - JIRA X3-29536 - START
  # Recherche site du contrat
  Filter [F:HRCTR] Where REFNUM=[M:HRTRN1]REFNUM & CTRNUM=VALEUR & CTRDAT<=date$ and (XITDAT=[0/0/0] | XITDAT>=date$) Order By CTRDAT Desc
  Read [F:HRCTR] First
  Filter [F:HRCTR]
  If !fstat Then
    [M:HRTRN1]FCY = [F:HRCTR]ETRFCY
    # Recherche société du contrat
    Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
    If !fstat Then
      [M:HRTRN1]CPY = [F:FCY]LEGCPY
    Endif
  Endif
  Affzo [M:HRTRN1]FCY,CPY

#  # Recherche site du contrat
#  Filter [F:CTR] Where REFNUM=[M:TRN1]REFNUM & CTRNUM=VALEUR & CTRDAT<=date$ and (XITDAT=[0/0/0] | XITDAT>=date$) Order By CTRDAT Desc
#  Read [F:CTR] First
#  Filter [F:CTR]
#  If !fstat Then
#    [M:TRN1]FCY = [F:CTR]ETRFCY
#    # Recherche société du contrat
#    Read [F:FCY]FCY0=[F:CTR]ETRFCY
#    If !fstat Then
#      [M:TRN1]CPY = [F:FCY]LEGCPY
#    Endif
#  Endif
#  Affzo [M:TRN1]FCY,CPY
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
#LIPET - 2017-05-10 - X3-29536 - START
Call GET_LEG(VALEUR)
#LIPET - 2017-05-10 - X3-29536 - END
End


######################################################################################
#* SYMEU V6.1 : Fiche 70028
#* APRES_MODIF du flag Actif :
#* Quand le formateur devient inactif, s'il est trouvé dans une session ou un stage,
#* on affiche un message d'avertissement
#*!
######################################################################################
Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR

If VALEUR = 1 Then
  Local Integer L_OK : L_OK = 1
  Gosub VERIF_STG_SES
  If L_OK < 1 Then
    # Ce formateur interne est renseigné dans un stage ou une session
#DIRAS - 27/03/2017 - JIRA X3-29536 - START
      Call MESSAGE(mess(190,10717,1)) From GESECRAN
      #Call MESSAGE(mess(190,717,1)) From GESECRAN
#DIRAS - 27/03/2017 - JIRA X3-29536 - END
  Endif
Endif
End


