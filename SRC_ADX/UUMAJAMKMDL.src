#<AdxTL>@(#)6.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour champ MDL dans le dico écran & fenêtre
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update MDL field on AMSK et AWINDOW files") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJMDL
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJMDL
End

#-------------------#
$MAJMDL

Local File =DOSSIER+".AMSK" [AMK]

# Mise à jour de la table AMSK+AWINDOW
Call ECR_TRACE(mess(81,125,1)-"AMSK+AWINDOW :"-time$,0) From GESECRAN
Trbegin [AMK]
 Update [AMK] Where MDL=0 With MDL=1
 If dim([F:AWI]MDL)>0
  Update [AWI] Where MDL=0 With MDL=1
 Endif
 If dim([F:AWI]FVT)>0
  Update [AWI] Where FVT=0 With FVT=1
 Endif
Commit

Close Local File [AMK]

Return
