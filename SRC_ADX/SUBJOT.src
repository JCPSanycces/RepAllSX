Subprog APRES_NBRFAM
Local Integer NBR_NBRFAM

  NBR_NBRFAM = [M:JOT4]NBRFAM
# En cas d'ajout ou d'insertion on a une ligne en plus
# Le status est à 1 qu'on soit en modif, insertion ou ajout d'1 ligne
If status<>65 & status<>83 & status<>68 : NBR_NBRFAM +=1 : Endif
Gosub INIT_CPC
#MIPEA - 2016-09-19 - X3PEOP-1920 - START
If func SUBJOT.IS_CAR
Affzo [JOT5]
Endif
#MIPEA - 2016-09-19 - X3PEOP-1920 - END
End

Subprog C_MIS(VALEUR)
Variable Char    VALEUR()
#LIPET - 2017-10-18 - X3-29326 - START
  #Call UNICITE(VALEUR,[M:JOT1]MIS(0..[M:JOT1]NBRMIS-1)) From OBJDIV
  If func AFNC.ACTIV("EVAEN")>0
    If VALEUR <> ""
      Call UNICITE(VALEUR,[M:JOT1]MIS(0..[M:JOT1]NBRMIS-1)) From OBJDIV
    Endif
  Else
    Call UNICITE(VALEUR,[M:JOT1]MIS(0..[M:JOT1]NBRMIS-1)) From OBJDIV
  Endif

  #Removed mandatory check from screen - but need to check in certain scenarios
  #On the first line there must be a value
  If func AFNC.ACTIV("EVAEN")>0
    If nolign = 1 and VALEUR = ""
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif
#LIPET - 2017-10-18 - X3-29326 - END
End

