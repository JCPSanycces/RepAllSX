 Filter [DIC] Where [DIC]TBL="EMPLOCTR"
 ## Action SELOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJW"
 PARMSK(1) = "DIC"
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 GACTION = SAVACT
 Filter [DIC]
Endif
Gosub AFF From GSAISIE
End
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran JOT2) 19/07/2010 14:11:13 (JML)
######################################################################################
Subprog B1_NBRDIC

Local Integer NB_LIG
Local Decimal L_LONG

# JML 17/08/10 CG She doesn't want CLLCVT, No 23/08/10 just prohibit it with LEV
Filter [DIC] Where [F:DIC]TBL="EMPLOCTR" & [F:DIC]POTFLG=2 : # & !find([F:DIC]FLD,"CLLCVT")
Raz NB_LIG
For [DIC]DIC3
# SEGAY - 11/03/11 - Bug 72320 dépassement capacité
 If [M]NBRDIC>=dim([M:JOT2]FLD)
     # Tableau plein
    Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
    Break
 Endif
 If !find([F:DIC]FLD,[M]FLD(0..[M]NBRDIC-1))
  [M]NBRDIC += 1
  nolign = [M]NBRDIC
  [M] = [F:DIC]
  Call TEXTE([F:DIC]DES,[M]TIT(nolign-1)) From OBJDIV
  Gosub CHARGE_DICO
  If GPAYE #* SEGAY 28/02/11 Bug 71973
  [M:JOT2]UNQ(nolign-1) = [M:JOT2]FLD(nolign-1)+"~"+[M:JOT2]CPY(nolign-1)+"~"+[M:JOT2]FCY(nolign-1)
&                        +"~"+[M:JOT2]CLLCVT(nolign-1)+"~"+[M:JOT2]POP(nolign-1)
  Else
  [M:JOT2]UNQ(nolign-1) = [M:JOT2]FLD(nolign-1)+"~"+[M:JOT2]CPY(nolign-1)+"~"+[M:JOT2]FCY(nolign-1)
&                        +"~"+[M:JOT2]POP(nolign-1)
  Endif
  NB_LIG += 1
 Endif : # If !find([F:DIC]FLD,[M]FLD(0..[M]NBRDIC-1))
Next : # [DIC]DIC3
Filter [DIC]
Affzo [JOT2]
If NB_LIG
 mkstat = 4
Endif
End
######################################################################################
$CHARGE_DICO

[M:JOT2]LEV(nolign-1) = 1 : # ML 508 Société
Read [ATZ]CODZONE="EMPLOCTR";[F:DIC]FLD
If !fstat
 Read [ATY]CODTYP=[F:ATZ]CODTYP
 If !fstat
  [M:JOT2]CODTYP(nolign-1) = [F:ATZ]CODTYP
  [M:JOT2]NOLIB(nolign-1)  = [F:ATZ]NOLIB
  L_LONG = [F:ATZ]LONG
  If !L_LONG
   L_LONG = [F:ATY]LNGTYP
  Endif
  [M:JOT2]LONG(nolign-1)   = L_LONG
  [M:JOT2]CODOBJ(nolign-1) = [F:ATY]OBJLIEN
 Else
  Raz [F:ATY]
 Endif : # If !fstat ATY
Else
 Raz [F:ATZ]
Endif : # If !fstat ATZ
Case [F:ATZ]CODTYP
 When "ADI" :
  Read [AMP]CODPAR=2;"EMPLOCTR";[F:DIC]FLD;[F:ATZ]CODTYP
  If !fstat
   # Certains paramètres ADI ont des " ou des '
   [F:AMP]VALPAR = ctrans([F:AMP]VALPAR,'"','')
   [F:AMP]VALPAR = ctrans([F:AMP]VALPAR,"'","")
   [M:JOT2]VALPAR(nolign-1) = [F:AMP]VALPAR
  Endif
 When "ORG","RUB","CUM","PRF"
  [M:JOT2]VALPAR(nolign-1) ="GCURLEG"
 Endcase
  #24/08/12 - PCA - DO NOT DEFAULT THE LEGLEV WITH LEGFIL
 [M:JOT2]LEGLEV(nolign-1) =""
Return
