Subprog AM_MISWEIFLG(VALEUR)
Variable Integer VALEUR
#LIPET - 2017-10-18 - X3-29326 - START
  If func AFNC.ACTIV("EVAEN")=0 : End : Endif
  If VALEUR = 2
    Chgfmt [M:JOT1]MISWEI     With "+Nz:3.2"
    [M:JOT1]MISEQ = 2
    Actzo [M:JOT1]MISEQ
  Else
    Chgfmt [M:JOT1]MISWEI     With "-Nz:3.2"         #: Raz [M:JOT1]MISWEI
    [M:JOT1]MISEQ = 2
    Diszo [M:JOT1]MISEQ
  Endif
  Affzo [M:JOT1]
#LIPET - 2017-10-18 - X3-29326 - END
End

Subprog AM_INDFLG(VALEUR)
Variable Integer VALEUR
#LIPET - 2017-10-18 - X3-29326 - START
  If func AFNC.ACTIV("EVAEN")=0 : End : Endif
  If VALEUR = 2
    Chgfmt [M:JOT1]IND      With "+K:10X"
    Chgfmt [M:JOT1]INDWEI   With "+Nz:3.2"
    [M:JOT1]INDWEIFLG = 2
    Actzo [M:JOT1]INDWEIFLG
    [M:JOT1]INDEQ = 2
    Actzo [M:JOT1]INDEQ
  Else
    Chgfmt [M:JOT1]IND      With "-K:10X"           : Raz [M:JOT1]IND
    Chgfmt [M:JOT1]INDWEI   With "-Nz:3.2"          : Raz [M:JOT1]INDWEI
    [M:JOT1]INDEQ = 1
    Diszo [M:JOT1]INDEQ
    [M:JOT1]INDWEIFLG = 1
    Diszo [M:JOT1]INDWEIFLG
  Endif
  Affzo [M:JOT1]
#LIPET - 2017-10-18 - X3-29326 - END
End

