#&            As [LID]
#&          Where [F:HRCTR]XITDAT=[0/0/0]
#&              & [F:ID]ENAFLG=2

If clalev([F:CPY])=0  : Local File COMPANY       [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY      [FCY]  : Endif
Link [HRCTR] With [ID]ID0=[F:HRCTR]REFNUM, [FCY]FCY0=[F:HRCTR]ETRFCY,[CPY]CPY0=[FCY]LEGCPY
&            As [LID]
&          Where [F:HRCTR]XITDAT=[0/0/0]
&              & [F:ID]ENAFLG=2
# SBA end


Local Integer NBR_NBRFAM
Local Integer I,J,K,L,N, ORIGINE, FAMORI
Local Integer L_IJ
# SBA add leg
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
# SBA add leg
Gosub RESTAURE_GLEGFIL From TOOLSHRLEG
# If(dim(SAV_GLEGFIL)>0)
#    GLEGFIL=SAV_GLEGFIL
#    Kill SAV_GLEGFIL
# Endif
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$ABANDON
# SBA add leg
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

###############################
$AVANTBOUT
GFLAG = "" : # Le fait de passer sur JOBGRP ou CPCFAM 'charge' GFLAG et du coup le bouton MAJ Héritage part en vrille...
Return
###############################
$SETBOUT
If instr(1,GUSRVID,"2")
 [L]CHMEN = "2"
Endif
[L]CHMEN+="3" : #MABOS-23/07/13-FQ90539-US1805-"Référentiel des emplois"
#JOJAC - 2016-03-23 - REQ114309 US86 - START
If GREP ="" : # 108810
  [L]CHMEN+="4"
Endif
#JOJAC - 2016-03-23 - REQ114309 US86 - END
Return

###############################
$LIENS
#* Test si code activité Carrière
#* SEGAY 28/02/11 Bug 71973
#*
#SBA leg
GCURLEG = [F:JOT]LEG : [M:JOT0]LEG=GCURLEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
#LIPET - X3-34428 - 2017-04-26 - START
#Call LECTEXTRA([M]DES,"JOBTYP","DES",[M]COD,"") From ATEXTRA
#Call LECTEXTRA([M]DESSHO,"JOBTYP","DESSHO",[M]COD,"") From ATEXTRA
Call LECTEXTRA([M:JOT0]DES,"JOBTYP","DES",[M]COD,"") From ATEXTRA
Call LECTEXTRA([M:JOT1]DESSHO,"JOBTYP","DESSHO",[M]COD,"") From ATEXTRA
#LIPET - X3-34428 - 2017-04-26 - END
#SBA end
Call DISPLAY_HIDE()From SUBJOTLEG

#LIPET - 2017-06-01 - X3-41956 - START
For I=0 To dim([F:JOT]MIS)-1
  If I<=dim([M:JOT1]MIS)-1 & [F:JOT]MIS(I)<>""
   [M:JOT1]MIS(I) = [F:JOT]MIS(I)
  Else
   Break
  Endif
Next
[M:JOT1]NBRMIS = I
#LIPET - 2017-06-01 - X3-41956 - END
If func IS_CAR
#LIPET - 2017-06-01 - X3-41956 - START
# # Charge tableau des missions
#  For I=0 To dim([F:JOT]MIS)-1
#   If I<=dim([M:JOT1]MIS)-1 & [F:JOT]MIS(I)<>""
#    [M:JOT1]MIS(I) = [F:JOT]MIS(I)
#   Else
#    Break
#   Endif
#  Next
#  [M:JOT1]NBRMIS = I
#LIPET - 2017-06-01 - X3-41956 - END

  # Charge tableau des familles de compétences
  For I=0 To dim([F:JOT]CPCFAM)-1
   # JML 13/07/10 CPCFAM is now on JOT4 (instead of JOT1)
   If I<=dim([M:JOT4]CPCFAM)-1 & [F:JOT]CPCFAM(I)<>""
    [M:JOT4]CPCFAM(I) = [F:JOT]CPCFAM(I)
   Else
    Break
   Endif
  Next
  [M:JOT4]NBRFAM = I
  NBR_NBRFAM=[M:JOT4]NBRFAM

  # Charge tableau des compétences
  For I=0 To dim([F:JOT]CPC)-1
   # JML 13/07/10 CPC is now on JOT5 (instead of JOT2)
   If I<=dim([M:JOT5]CPC)-1 & [F:JOT]CPC(I)<>""
    [M:JOT5]CPC(I)    = [F:JOT]CPC(I)
    [M:JOT5]NIV(I)    = [F:JOT]NIV(I)
    [M:JOT5]ORI(I)    = [F:JOT]ORI(I)
    [M:JOT5]WEI(I)    = [F:JOT]WEI(I)
    [M:JOT5]CODORI(I) = [F:JOT]CODORI(I)
    Call LECTURE("CPC",[M:JOT5]CPC(I),"") From CONTOBJ
    [M:JOT5]CODSCA(I) = [F:CPC]CODSCA
#JOJAC - 2016-03-23 - REQ114309 US86 - START
    #FRLAA - 2015-04-17 - REQUIREMENT 104631 US 3487 - START
    If func AFNC.ACTIV("FKZSD")>0 Then
      [M:JOT5]CRSFLG(I) = [F:CPC]CRSFLG
    Endif
    #FRLAA - 2015-04-17 - REQUIREMENT 104631 US 3487 - END
#JOJAC - 2016-03-23 - REQ114309 US86 - END
    # JML 04/08/10 Text of the scale
    If dim([M:JOT5]LEVDES)>0
     Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
     L_IJ = find([M:JOT5]NIV(I),[F:HRSCA]LEV)
     Read [HRSDD]SDD0=[F:CPC]CODSCA;L_IJ
     If !fstat
      [M:JOT5]LEVDES(I) = [F:HRSDD]LEVDES
     Endif
    Endif
    [M:JOT5]FLGKEY(I) = [F:CPC]FLGKEY
   Else
    Break
   Endif
  Next
  [M:JOT5]NBRLIG= I
  Sorta [M:JOT5]NBRLIG [M:JOT5]NBRLIG Order By [M:JOT5]ORI([S]indice),[M:JOT5]CPC([S]indice)
Endif #* END_Bug 71973
  # JML 15/07/10 Mini/Maxi
  Call AM_CCV([F:JOT]CCV) From SUBJOT

  # JML 16/07/10 Loading JOT6 LOT P01
  # SBA check leg
  Call LOAD_EMPLOYE("")


  # JML 20/07/10 Loading new table JOBTYPDEF LOT P01
  #76381
  #Raz [M:JOT2]
  Effzo [M:JOT2]5
  #[M:JOT2] = [F:JOT] #72635
  For [JOD]JOD0 Where [F:JOD]COD=[M:JOT0]COD
   nolign = [M:JOT2]NBRDIC+1
   If nolign>=dim([M:JOT2]FLD) : Break : Endif
   [M:JOT2] = [F:JOD]
   #83971
   Read [ATY]CODTYP=[F:JOD]CODTYP
   If !fstat
    [M:JOT2]CODOBJ(nolign-1) = [F:ATY]OBJLIEN
   Endif
   [M:JOT2]NBRDIC += 1
  Next : # [JOD]
#LIPET - 2017-10-19 - X3-29326 - START
  If func AFNC.ACTIV("EVAEN")>0
    Local Integer FIRSTMIS, X
    Filter [MJI] Where JOT = [M:JOT0]COD
    nolign = 0
    For [MJI]MJI0
      FIRSTMIS = 1
      nolign += 1
      [M:JOT1]MIS(nolign-1)         = [F:MJI]MIS
      [M:JOT1]WMIS(nolign-1)        = [F:MJI]MIS
      [M:JOT1]MISWEI(nolign-1)      = [F:MJI]MISWEI
      For X = 1 To dim([F:MJI]IND)
        If [F:MJI]IND(X-1) <> ""
          If FIRSTMIS = 1 : FIRSTMIS = 2 : Else nolign += 1  :Endif
          [M:JOT1]WMIS(nolign-1)    = [F:MJI]MIS
          [M:JOT1]IND(nolign-1)     = [F:MJI]IND(X-1)
          [M:JOT1]INDWEI(nolign-1)  = [F:MJI]INDWEI(X-1)
        Else
          Break
        Endif
      Next X
    Next
    Assign "[M:JOT1]NBRMIS" With nolign
    Filter [MJI]
    Affzo [M:JOT1]
  Endif
#LIPET - 2017-10-19 - X3-29326 - END
Return

#LIPET - 2017-10-19 - X3-29326 - START
$VERIF_MOD
$VERIF_CRE
  If func AFNC.ACTIV("EVAEN")>0
    Local Integer CELLCOUNT : CELLCOUNT = 0
    If [M:JOT1]INDFLG = 2
      CELLCOUNT = find("",[M:JOT1]IND(0..[M:JOT1]NBRMIS-1)(0..NOL-1),[M:JOT1]IND(0..[M:JOT1]NBRMIS-1)(NOL+1..dim([M:JOT1]IND(0..[M:JOT1]NBRMIS-1))-1))
    Endif
    If CELLCOUNT = 0
      If func AFNC.ACTIV("EVAEN")>0
        Local Integer STAT, K : STAT = 1
        Local Char ERRMESS(50), RETMSG(250)
        Local Char MISARR(GLONMIS)(0..)
        Local Decimal MISWEIARR(0..)
        Local Char WMISARR(GLONMIS)(0..)
        Local Decimal INDWEIARR(0..)
        Local Integer MISEQ,INDEQ,INDFLG
        If [M:JOT1]MISWEIFLG <> 2 : [M:JOT1]MISEQ = 2 : Endif
        If [M:JOT1]INDWEIFLG <> 2 : [M:JOT1]INDEQ = 2 : Endif
        MISEQ   = [M:JOT1]MISEQ
        INDFLG  = [M:JOT1]INDFLG
        INDEQ   = [M:JOT1]INDEQ



        #Storing grid values
        If [M:JOT1]NBRMIS >0
          For nolign = 1 To [M:JOT1]NBRMIS
            MISARR(K)      = [M:JOT1]MIS(nolign-1)
            MISWEIARR(K)   = [M:JOT1]MISWEI(nolign-1)
            WMISARR(K)     = [M:JOT1]WMIS(nolign-1)
            INDWEIARR(K)   = [M:JOT1]INDWEI(nolign-1)
            K+=1
          Next
         Call VALID_MISIND(STAT,MISEQ,MISARR,MISWEIARR,INDFLG,INDEQ,WMISARR,INDWEIARR,RETMSG) From EVAFNC
          If STAT = 0
            GMESSAGE = RETMSG
            OK=0
          Else
            #Fill the grid on the screen with calculated values
            K = 0
            For nolign = 1 To [M:JOT1]NBRMIS
              [M:JOT1]MISWEI(nolign-1) = MISWEIARR(K)
              [M:JOT1]INDWEI(nolign-1) = INDWEIARR(K)
              K+=1
            Next
            Affzo [M:JOT1]
          Endif
        Endif
      Endif
    Else
      GMESSAGE = mess(00001,10002,1)
      GOK=0
    Endif
  Endif
Return
#LIPET - 2017-10-19 - X3-29326 - END

#SBA fill JOT6 with the legislation
Subprog LOAD_EMPLOYE(LEGIS)
Value Char LEGIS
Raz [M:JOT6]
For [LID]CTR0 Where [F:HRCTR]JOBPOT=[M:JOT0]COD
If LEGIS="" or LEGIS=[F:CPY]LEG
 nolign = [M:JOT6]NBRLIG+1
 If nolign>=dim([M:JOT6]REFNUM) : Break : Endif
 [M:JOT6] = [F:HRCTR]
 # FQ81085 - MABON 05/07/12 - Find the good local menu for the title, depending on the site
 Local Char NUMLIB(10)
 Call PARAM([F:HRCTR]ETRFCY,"CIVIL",NUMLIB) From ADOVAL
 If [F:HRCTR]CIVCTR>0 Then [M:JOT6]CIVCTRA(nolign-1)=mess([F:HRCTR]CIVCTR,val(NUMLIB),1) : Endif
 # End MABONhttp://devx3vnext.sagefr.adinternal.com:8124/syracuse-main/html/main.html?url=%2Ftrans%2Fx3%2Ferp%2FGX3APP%2F%24sessions%3Ff%3DGESAMK%252F2%252F%252FM%252F#
 [M:JOT6] = [F:ID]
 [M:JOT6]NBRLIG += 1
 Endif
Next : # [LID]
Affzo[M:JOT6]
End
###############################
# SBA 25/07/12 selection object with leg
$SEL_TABLE
If GFONCTION<>"GESJOT"
  Gosub SAVE_GLEGFIL From TOOLSHRLEG
  GLEGFIL=GCURLEG
#  If(dim(GLEGFIL)>0 and dim(GCURLEG)>0)
#    If(dim(SAV_GLEGFIL)<0)
#      #if exist => pb before...
#      Global Char SAV_GLEGFIL
#      SAV_GLEGFIL=GLEGFIL
#    Endif
#    GLEGFIL=GCURLEG
#  Endif
  If find(GFONCTION,"GESECP","GESEVA") & dim(GCURLEG2)>0 & GCURLEG2 <> "" Then
     GLEGFIL=GCURLEG2
     If(dim(SAVS_GCURLEG)<0) Then Global Char SAVS_GCURLEG : Endif
     SAVS_GCURLEG=GCURLEG
     GCURLEG=GLEGFIL
  Endif
Else
  If(dim(GLEGFIL)>0 and dim(GCURLEG)>0)
    If(dim(SAVS_GCURLEG)<0) Then Global Char SAVS_GCURLEG : Endif
    SAVS_GCURLEG=GCURLEG
    GCURLEG=GLEGFIL
  Endif
Endif
#SBA end
  Case TABLE
    When "SELJOT","SELJOTH","SELJOTCRIT" : #MABOS-27/06/13-FQ90539-US1737
      Local Char    CRITERE_JOT(250) # SEGAY 25/10/12 US 930 81085

      If clalev ([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
      Filter [F:JOT]
      OBJET     = "JOT"
      START     = "[F:JOT]COD"
      EXPSTART  = "[F:JOT]COD>='"+VALEUR+"'"
#      If dim([M]LEG)>0 Then
         # deplacement dans toolshrleg
#      If dim([M]LEG)>0 & !find(GFONCTION,"GESECP","GESEVA") & !find(maskcou,"GENCSI")
#&       & !find(maskcou,"GENCEV")& !find(maskcou,"CEV0") Then
#81085-US1831
#      If func TOOLSHRLEG.ADDLEG_EXPSTART()
#      #fin deplacement
#        #MABOS-08/03/2013-FQ81085-US1332-generic rules in GENCEV
#        EXPSTART += '& [F:JOT]LEG="'+[M]LEG+'"'
#      Endif
#
      OPTIONS = "|"
      SUPP    = VALEUR
      #MABOS-08/03/2013-FQ81085-US1332-generic rules in GENCEV
#      If find(GFONCTION,"GESECP","GESEVA") Then
      If !func TOOLSHRLEG.ADDLEG_EXPSTART()
        ORDRE   = "[F:JOT]COD"
      Endif
      #Filter based on code legislation
      If TABLE="SELJOTH" # SEGAY 25/10/12 US 930 81085
        Call CRIT_LEG_HLEG ([L]VALEUR,"","[F:JOT]COD","","JOT","[F:JOT]LEG",GCURLEG,CRITERE_JOT) From TOOLSHRLEG

        #Filter based on code legislation
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CRITERE_JOT,"&") From GOBJSUB
      Else
        If GFONCTION="GESPOT"  # SEGAY 25/10/12 US 930 81085
           Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:JOT]LEG="'+PARAM(1)+'" | ([F:JOT]LEG="" & [F:JOT]LEG <> "'+PARAM(1)+'"))',"&") From GOBJSUB
        Else
          If PARAM(1)<>""
             Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:JOT]LEG="'+PARAM(1)+'" | [F:JOT]LEG="")',"&") From GOBJSUB
          Endif
        Endif
      Endif
      #MABOS-27/06/13-FQ90539-US1737
      If TABLE="SELJOTCRIT" Then
        If PARAM(1)= "" & PARAM(2)="1" :# leg vide uniquement - param(2) ALLFLG
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:JOT]LEG="'+PARAM(1)+'")',"&") From GOBJSUB
        Endif
        If PARAM(3)<>"" | PARAM(4)="1" Then   :# une métier précis ou un métier vide ( tous <> 2 = pas "tous")
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","JOBGRP = '"+PARAM(3)+"'","&") From GOBJSUB
        Endif
      Endif
      #end MABOS-27/06/13-FQ90539-US1737
    #LIPET - 2017-10-18 - X3-29326 - START
    When "SELINDJOT"
      OBJET = "MID"
      CRITERE = 'MIS=[M]WMIS(nolign-1)'
    #LIPET - 2017-10-18 - X3-29326 - END
Endcase
Return
