# SBA 25/07/12 selection object with leg

$FIN_TABLE
Gosub RESTAURE_GLEGFIL From TOOLSHRLEG
#  If(dim(SAV_GLEGFIL)>0)
#    GLEGFIL=SAV_GLEGFIL
#    Kill SAV_GLEGFIL
#  Endif
  If(dim(SAVS_GCURLEG)>0)
    GCURLEG=SAVS_GCURLEG
    Kill SAVS_GCURLEG
  Endif
Return

# MABON - 19/07/2012 - Reinit GCURLEG in case of creation
$RAZCRE
#JOJAC
 # GCURLEG = ""
#JOJAC
Return

###############################
# JML 20/07/10 Loading new table JOBTYPDEF LOT P01
$CRE_MOD
  Gosub ANNULE
  If GOK<1 : Return : Endif
  ###############################
  #SBA leg
  If GREP="D"
   ## In duplication mode we keep the translated text
   Call DUPTEXTRA("JOBTYP","DES",   CLECUR1,"","JOBTYP","DES",   [F:JOT]COD,"")  From ATEXTRA
   Call DUPTEXTRA("JOBTYP","DESSHO",CLECUR1,"","JOBTYP","DESSHO",[F:JOT]COD,"")  From ATEXTRA
  Endif
  Call MAJTEXTRA([M:JOT0]DES,   "JOBTYP","DES",   [F:JOT]COD,"") From ATEXTRA
  #LIPET - X3-34428 - 2017-04-26 - START
  #Call MAJTEXTRA([M:JOT0]DESSHO,"JOBTYP","DESSHO",[F:JOT]COD,"") From ATEXTRA
  Call MAJTEXTRA([M:JOT1]DESSHO,"JOBTYP","DESSHO",[F:JOT]COD,"") From ATEXTRA
  #LIPET - X3-34428 - 2017-04-26 - END
  #SBA fin

###############################
  For nolign=1 To [M:JOT2]NBRDIC
   Raz [F:JOD]
   [F:JOD] = [M:JOT0]
   [F:JOD] = [M:JOT2]
   Write [JOD]
   If fstat
    GOK = 0 : Call FSTA("JOD") From GLOCK : Break
   Endif
  Next nolign
  If GOK<1 : Return : Endif

#LIPET - 2017-10-19 - X3-29326 - START
  If func AFNC.ACTIV("EVAEN")>0
    Local Integer Y,Z,K
    Delete [F:MJI] Where [F:MJI]JOT=[M:JOT0]COD
    If fstat=1 | fstat>5
      GOK=0 : Call RSTA("MJI",[M:JOT0]COD) From GLOCK : Return
    Endif
    Delete [F:MJI] Where [F:MJI]JOT=""
    If fstat=1 | fstat>5
      GOK=0 : Call RSTA("MPI",[M:JOT0]COD) From GLOCK : Return
    Endif

    For nolign = 1 To [M:JOT1]NBRMIS

      If [M:JOT1]WMIS(nolign-1) = "" : Break: Endif
      If [M:JOT1]MIS(nolign-1) = [M:JOT1]WMIS(nolign-1)
        Raz [F:MJI]
        Y = nolign
        [F:MJI]JOT      = [M:JOT0]COD
        [F:MJI]MIS      = [M:JOT1]MIS(nolign-1)
        [F:MJI]MISWEI   = [M:JOT1]MISWEI(nolign-1)
        K = 0
        For Z = Y To [M:JOT1]NBRMIS
          If K > 0 and [M:JOT1]MIS(Z-1) = [M:JOT1]WMIS(Z-1) : nolign-=1 : Break : Endif
          [F:MJI]IND(K)     = [M:JOT1]IND(Z-1)
          [F:MJI]INDWEI(K)  = [M:JOT1]INDWEI(Z-1)
          K+=1
          nolign+=1
        Next
      Endif
      Write [F:MJI]
        If fstat
        GOK=0 : Call FSTA("MJI") From GLOCK : Break
      Endif
    Next
  Endif
#LIPET - 2017-10-19 - X3-29326 - END
Return

$ANNULE
#SBA leg
If(dim(SUPP)>0)
  Call SUPTEXTRA("JOBTYP","DES",   [L]CODE,"") From ATEXTRA
  Call SUPTEXTRA("JOBTYP","DESSHO",[L]CODE,"") From ATEXTRA
Endif
#SBA end
Delete [JOD] Where [F:JOD]COD=[M:JOT0]COD

If fstat=1 : GOK=-1 : Call RSTA("JOD",[M:JOT0]COD) From GLOCK : Return : Endif
Return
###############################
$INIT_CPC
Local Integer  NIVEAU, WNIVEAU
Local Char     L_CPC(GLONCPC)(0..)                    : # JML 30/07/10 LOT P02 To charge GRPCPCD [HRGCD]
Local Char     L_NIV(GLONNIV)(0..)                    : # JML 30/07/10 LOT P02 To charge GRPCPCD [HRGCD]
Local Char     L_LEVDES(GDIMFIC)(0..)                 : # JML 04/08/10 LOT P02 To charge GRPCPCD [HRGCD]
Local Shortint L_LEVREF(0..)                          : # JML 04/08/10 LOT P02 To charge GRPCPCD [HRGCD]
Local Char     L_CODSCA(GLONSCA)(0..)                 : # JML 30/07/10 LOT P02 To charge GRPCPCD [HRGCD]
Local Integer  L_NB_CPC
Local Integer  L_IJ
Local Integer  ORIGINE                                : # JML 04/08/10 Better when declared
Local Integer  L_I_CPC                                : # SEGAY - 24/11/10 - EXI 66105 LOT P01 indice courant du tableau de CPC


I = 0 : NIVEAU=0 : WNIVEAU=0
FAMORI=""
# SEGAY - 24/11/10 - EXI 66105 LOT P01
# Suppression lignes du tableau liste de compétence sauf les lignes
#Raz [M:JOT5]
#MIPEA - 2016-09-19 - X3PEOP-1920 - START
If func SUBJOT.IS_CAR
  For I=[M:JOT5]NBRLIG-1 To 0 Step -1
    # SBA add test checkleg_cpc
    # SEGAY 25/10/12 US 930 81085
  #  If [M:JOT5]ORI(I)<>len(mess(0,10937,1)) & (dim([M:JOT0]LEG)< 0 | !func TOOLSHRLEG.CHECKLEG_CPC([M:JOT5]CPC(I),[M:JOT0]LEG,0))  :  #manuelle
    If [M:JOT5]ORI(I)<>len(mess(0,10937,1))  :  #manuelle

      Dela I, 1 [M:JOT5]NBRLIG
      [M:JOT5]NBRLIG -= 1
    Endif
  Next

  If [M:JOT5]NBRLIG > 0
    L_I_CPC = [M:JOT5]NBRLIG
  Else
    L_I_CPC = 0
  Endif
Endif
#MIPEA - 2016-09-19 - X3PEOP-1920 - END
# Bug 71019 récupération des compétences dossier, famille, métier que si le métier est renseigné
#MIPEA - 2017-02-21- X3-11317- START
If func SUBJOT.IS_CAR
#MIPEA - 2017-02-21- X3-11317- END
  If [M:JOT4]JOBGRP <> ""
    # Niveau dossier
    Read [GCP]GCP0=1;"";"";""
    If !fstat # Bug 70929 rajout du fstat
      ORIGINE=1 : FAMORI=""
      Gosub RECUP_CPC
    Endif
  Endif # END_Bug 71019 récupération des compétences dossier, famille, métier que si le métier est renseigné

  # Niveau Famille
  # JML 13/07/10 UOMGRP is now on JOT4 (instead of JOT1)
  If [M:JOT4]UOMGRP<>""
   Read [GCP]GCP0=2;[M:JOT4]UOMGRP;"";""
   If !fstat # Bug 70929 rajout du fstat
     ORIGINE=2 : FAMORI=""
     Gosub RECUP_CPC
   Endif
  Endif

  # Niveau Métier
  # JML 13/07/10 JOBGRP is now on JOT4 (instead of JOT1)
  If [M:JOT4]JOBGRP<>""
   Read [GCP]GCP0=3;"";[M:JOT4]JOBGRP;""
   If !fstat # Bug 70929 rajout du fstat
     ORIGINE=3 : FAMORI=""
     Gosub RECUP_CPC
   Endif
  Endif
  # Niveau groupe de compétences
  For K=0 To NBR_NBRFAM-1
   If [M:JOT4]CPCFAM(K)<>""
    Read [GCP]GCP0=4;"";"";[M:JOT4]CPCFAM(K)
    If !fstat # Bug 70929 rajout du fstat
      ORIGINE=4 : FAMORI=[M:JOT4]CPCFAM(K)
      Gosub RECUP_CPC
    Endif
   Endif
  Next
#MIPEA - 2017-02-21- X3-11317- START
Endif
#MIPEA - 2017-02-21- X3-11317- END

################################################################
# JML 04/08/10 Is it really necessary ?
# Compétences du l'emploi type
# JML 13/07/10 CPC is now on JOT5 (instead of JOT2)
#For K=0 To dim([F:JOT]CPC)-1
# If [F:JOT]CPC(K)<>"" & [F:JOT]ORI(K)=6 :#manuelle
#  # JML 04/08/10 Text of the scale
#  Call LECTURE("CPC",[F:JOT]CPC(K),"") From CONTOBJ
#  Call LECTURE("SCA",[F:CPC]CODSCA,"") From CONTOBJ
#  L_IJ = find([F:JOT]NIV(K),[F:SCA]LEV)
#  Read [SDD]SDD0=[F:CPC]CODSCA;L_IJ
#  If fstat : Raz [F:SDD] : Endif
#  #
#  L=find( [F:JOT]CPC(K),[M:JOT5]CPC)
#  If !L
#   [M:JOT5]CPC(I)    = [F:JOT]CPC(K)
#   [M:JOT5]NIV(I)    = [F:JOT]NIV(K)
#   [M:JOT5]LEVDES(I) = [F:SDD]LEVDES
#   [M:JOT5]ORI(I)    = [F:JOT]ORI(K)
#   [M:JOT5]WEI(I)    = [F:JOT]WEI(K)
#   [M:JOT5]CODORI(I) = ""
#   I+=1
#  Else
#   # la saisie manuelle gagne toujours sur l'hérité !!!
#   [M:JOT5]NIV(L-1)    = [F:JOT]NIV(K)
#   [M:JOT5]LEVDES(L-1) = [F:SDD]LEVDES
#   [M:JOT5]ORI(L-1)    = [F:JOT]ORI(K)
#   [M:JOT5]WEI(L-1)    = [F:JOT]WEI(K)
#   [M:JOT5]CODORI(L-1) = ""
#  Endif
# Endif
#Next
# JML 04/08/10 Is it really necessary ?
################################################################
#MIPEA - 2016-09-19 - X3PEOP-1920 - START
If func SUBJOT.IS_CAR
  [M:JOT5]NBRLIG=L_I_CPC
  Sorta [M:JOT5]NBRLIG [M:JOT5]NBRLIG Order By ORI([S]indice),CPC([S]indice)
  Affzo [M:JOT5]
Endif
#MIPEA - 2016-09-19 - X3PEOP-1920 - END
Return

###############################
$RECUP_CPC
#MIPEA - 2016-09-19 - X3PEOP-1920 - START
If func SUBJOT.IS_CAR
# JML 30/07/10 LOT P02
Raz L_CPC, L_NIV, L_NB_CPC, L_LEVDES, L_LEVREF, L_CODSCA
For [HRGCD]GCD0 Where [F:HRGCD]LEVGRP=[F:GCP]LEVGRP & [F:HRGCD]UOMGRP=[F:GCP]UOMGRP
&                 & [F:HRGCD]JOBGRP=[F:GCP]JOBGRP & [F:HRGCD]CPCFAM=[F:GCP]CPCFAM
 #SBA test leg CPC
 # SEGAY 25/10/12 US 930 81085
 If(dim([M:JOT0]LEG)< 0 | func TOOLSHRLEG.CHECKLEG_CPC([F:HRGCD]CPC,[M:JOT0]LEG,0))
  L_CPC(L_NB_CPC) = [F:HRGCD]CPC
  L_NIV(L_NB_CPC) = [F:HRGCD]NIV
  # JML 04/08/10 Text of the scale
  Call LECTURE("CPC",[F:HRGCD]CPC,"") From CONTOBJ
  L_CODSCA(L_NB_CPC)  = [F:CPC]CODSCA
  Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
  L_IJ = find([F:HRGCD]NIV,[F:HRSCA]LEV)
  Read [HRSDD]SDD0=[F:CPC]CODSCA;L_IJ
  If !fstat
    L_LEVDES(L_NB_CPC) = [F:HRSDD]LEVDES
  Endif
  L_LEVREF(L_NB_CPC)  = [F:HRSCA]LEVREF
  L_NB_CPC += 1
 Endif
 # SBA fin
Next : # [HRGCD]GCD0
For J=0 To L_NB_CPC-1
 If L_CPC(J)<>""
  Call LECTURE("CPC",L_CPC(J),"") From CONTOBJ
  L = find(L_CPC(J),[M:JOT5]CPC)
  If !L
   # SEGAY - 24/11/10 - EXI 66105 LOT P01
   If L_I_CPC>=dim([M:JOT5]CPC)
    #Tableau des compétences plein
    Call ERREUR(mess(5,10720,1)-num$(dim([M:JOT5]CPC))) From GESECRAN
    Break
   Endif

   # JML 27/08/10 We need more information from CPC, a good idea for a transclass !
   nolign = L_I_CPC + 1
   [M:JOT5] = [F:CPC]
   [M:JOT5]CPC(L_I_CPC)     = L_CPC(J)
   [M:JOT5]NIV(L_I_CPC)     = L_NIV(J)
   [M:JOT5]CODSCA(L_I_CPC)  = L_CODSCA(J)
   If dim([M:JOT5]LEVDES)>0
    [M:JOT5]LEVDES(L_I_CPC)  = L_LEVDES(J)
   Endif
   [M:JOT5]ORI(L_I_CPC)     = ORIGINE
   [M:JOT5]CODORI(L_I_CPC)  = FAMORI
   [M:JOT5]WEI(L_I_CPC)     = 1
   L_I_CPC += 1
  Else
   Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
   # Niveau déjà défini dans l'écran
   N = find([M:JOT5]NIV(L-1),[F:HRSCA]LEV)
   If N
    WNIVEAU = [F:HRSCA]LEVREF(N-1)
   Else
    WNIVEAU = [F:HRSCA]LEVREF(0)
   Endif
   # Niveau défini dans le groupe de compétence
   N = find(L_NIV(J),[F:HRSCA]LEV)
   If N
    NIVEAU = [F:HRSCA]LEVREF (N-1)
   Else
    NIVEAU = [F:HRSCA]LEVREF (0)
   Endif
   #C'est le niveau le + élevé qui gagne
   # SEGAY - 24/11/10 - EXI 66105 LOT P01
   #Le niveau défini dans la compétence (niveau d’échelle),
   #   n’est pas pris en compte pour initialiser les compétences dans les emplois type et postes ;
   # (de la même manière qu’il n’est pas pris en compte dans les traitements de MàJ héritage).
   #Si on n'est pas sur une compétence manuelle et l'origine de la maj <> 4 ML 2400 Groupe de compétence
#   If WNIVEAU<NIVEAU
   If [M:JOT5]ORI(L-1) <> len(mess(0,10937,1)) & ORIGINE<>4 : # ML 2400 Groupe de compétence
    # JML 27/08/10 We need more information from CPC, a good idea for a transclass !
    nolign = L
    [M:JOT5] = [F:CPC]
    [M:JOT5]NIV(L-1)    = L_NIV(J)
    [M:JOT5]CODSCA(L-1) = L_CODSCA(J)
    If dim([M:JOT5]LEVDES)>0
     [M:JOT5]LEVDES(L-1) = L_LEVDES(J)
    Endif
    [M:JOT5]ORI(L-1)    = ORIGINE
    [M:JOT5]CODORI(L-1) = FAMORI
   Endif
  Endif
 Elsif L_CPC(J)=""
  Break
 Endif
Next J
Endif
#MIPEA - 2016-09-19 - X3PEOP-1920 - END
Return

# JOJAC - 2016-03-23 - REQ114309 US86 - END
# 108810
$TR_MAJ_MIS
Local Integer WMAXMIS,WJMIS,WPMIS,WPMISEND,WERASE,WNBITEM
If clalev([F:POT])=0  : Local File POSTE         [POT]  : Endif
If clalev([F:POT1])=0  : Local File POSTE        [POT1] : Endif
#LIPET - 2017-10-19 - X3-29326 - START
If func AFNC.ACTIV("EVAEN")>0
  If clalev([F:MJI2])=0 : Local File MISJOTIND      [MJI2]  : Endif
  If clalev([F:MPI])=0  : Local File MISPOTIND      [MPI]   : Endif
Endif
#LIPET - 2017-10-19 - X3-29326 - END
WMAXMIS=dim([F:POT]MIS)
GOK = 1

WERASE=0
If [M:DIA]RPLSUP=1 : WERASE=1 : Endif

#Mise à jour des missions dans les postes
TIT = mess(153,720,1)
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"*"),0) From GESECRAN

Call DEBTRANS From GLOCK
Trbegin [POT]
Gosub TRANSAC
If   GOK<0 : Goto ROLL_TR1
Elsif !GOK : Goto AB_TR1 : Return
Endif
Commit

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
If  WPMIS>0
 #Nombre de postes mis à jour :
 Call ECR_TRACE(mess(26,720,1)-":"-num$(WPMIS),0) From GESECRAN
Else
 #Aucun poste à traiter
 Call ECR_TRACE(mess(27,720,1),0) From GESECRAN
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
 # Affichage de la trace
 Call LEC_TRACE From LECFIC
Endif

Return
# 108810
$AB_TR1
Rollback
Call ERREUR(mess (17,107,1)) From GESECRAN :#Rollback suite à une erreur dans la transaction
Return
#######################################################
# 108810
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_MAJ_MIS : Endif
#######################################################
# 108810
$TRANSAC
#LIPET - 2017-10-18 - X3-29326 - START
  #In all cases the indicators will be updated
  If func AFNC.ACTIV("EVAEN")>0
    For [POT1]POT0 Where JOBPOT=[F:JOT]COD
      Readlock [F:POT]POT0=[F:POT1]COD
      If fstat=1
        GOK=-1 : GLOCK="$POSTE"-[F:POT1]COD : Break
      Elsif fstat=0
        [F:POT]MISWEIFLG   = [F:JOT]MISWEIFLG
        [F:POT]MISEQ       = [F:JOT]MISEQ
        [F:POT]INDFLG      = [F:JOT]INDFLG
        [F:POT]INDWEIFLG   = [F:JOT]INDWEIFLG
        [F:POT]INDEQ       = [F:JOT]INDEQ
        If dim([F:POT]UPDDAT)>0 : [F:POT]UPDDAT = date$     : Endif
        [F:POT]UPDUSR = GUSER
        If dim([F:POT]UPDTIM)>0 : [F:POT]UPDTIM = time      : Endif
      Endif
    Rewrite [POT]
    If fstat
      GOK=0 : Call FSTA("POT") From GLOCK : Break
      Return
    Endif
    # Mise à jour du poste
    Call ECR_TRACE(space$(5)+mess(28,720,1)-":"-[F:POT]COD - ":"- "Mission settings",0) From GESECRAN
    Next
    Unlock [POT]
  Endif
#LIPET - 2017-10-18 - X3-29326 - END
  For [POT1]POT0 Where JOBPOT=[F:JOT]COD
   WNBITEM=0
   If WERASE
      Readlock [F:POT]POT0=[F:POT1]COD
      If fstat=1
        GOK=-1 : GLOCK="$POSTE"-[F:POT1]COD : Break
      Elsif fstat=0
         Raz [F:POT]MIS
         For WJMIS=0 To dim([F:JOT]MIS)-1
           [F:POT]MIS(WJMIS) = [F:JOT]MIS(WJMIS)
           WNBITEM += 1
         Next WJMIS
      Endif
   Else
      For WJMIS=0 To dim([F:JOT]MIS)-1
       If [F:JOT]MIS(WJMIS)="" : Break : Endif
       WPMISEND=find("",[F:POT1]MIS(0..WMAXMIS-1))
       If WPMISEND
         If !find([F:JOT]MIS(WJMIS),[F:POT1]MIS(0..WMAXMIS-1))
            If !WNBITEM
              Readlock [F:POT]POT0=[F:POT1]COD
              If fstat=1
                GOK=-1 : GLOCK="$POSTE"-[F:POT1]COD : Break 2
              Endif
            Endif
            If fstat=0
              [F:POT]MIS(WPMISEND-1) = [F:JOT]MIS(WJMIS)
              [F:POT1]MIS(WPMISEND-1) = [F:JOT]MIS(WJMIS)
              WNBITEM += 1
            Endif
         Endif
       Else
         # Tableau des missions plein
         # Gosub FULL_MIS
         Break
       Endif
      Next WJMIS
    Endif
    If GOK & WNBITEM
       [F:POT]UPDDAT = date$
       [F:POT]UPDUSR = GUSER
       [F:POT]UPDTIM = time
       Rewrite [POT]
       If fstat
        GOK=0 : Call FSTA("POT") From GLOCK : Break 1
       Endif
       # Mise à jour du poste
       Call ECR_TRACE(space$(5)+mess(28,720,1)-":"-[F:POT]COD,0) From GESECRAN
       WPMIS += 1
    Endif
  Next
#LIPET - 2017-10-19 - X3-29326 - START
  #Updating the new mission table for positions (MISPOTIND)
  If func AFNC.ACTIV("EVAEN")>0
    Filter [POT1]
    For [POT1]POT0 Where JOBPOT=[F:JOT]COD
      Delete [F:MPI] Where POT = [F:POT1]COD
      If fstat=1 | fstat>5
        GOK=0 : Call RSTA("MPI",[F:JOT]COD) From GLOCK : Return
      Endif
      For [MJI] Where JOT=[F:JOT]COD
        Raz [F:MPI]
        [F:MPI]         = [F:MJI]
        [F:MPI]POT      = [F:POT1]COD
        For WJMIS=0 To dim([F:MJI]IND)-1
          [F:MPI]IND(WJMIS)     = [F:MJI]IND(WJMIS)
          [F:MPI]INDWEI(WJMIS)  = [F:MJI]INDWEI(WJMIS)
        Next WJMIS
        Write [F:MPI]
        If fstat<>0
          GOK = 0 : Call FSTA("MPI") From GLOCK : Break
          Return
        Endif
        Call ECR_TRACE(space$(5)+mess(28,10720,1)-":"-[F:POT1]COD -":" - "Mission Indicator",0) From GESECRAN
      Next
    Next
  Endif
#LIPET - 2017-10-19 - X3-29326 - END
Return

# 108810
$EXEC
Case GACTION
 When "MAJMIS"
  Gosub TR_MAJ_MIS
Endcase
Return
# JOJAC - 2016-03-23 - REQ114309 US86 - END
#LIPET - 2017-10-19 - X3-29326 - START
$APRES_MOD
$APRES_CRE
  Gosub CHANGE_STYLE
Return
#LIPET - 2017-10-19 - X3-29326 - END
#**
#* Test si code activité Carrière
#* SEGAY 28/02/11 Bug 71973
#*!
Funprog IS_CAR
Local Integer WOK
WOK = func AFNC.ACTIV("CAR")
End WOK


######################################################################################
## Etiquette écran JOT1
######################################################################################

######################################################################################
# SEGAY 25/10/12 US 930 81085
######################################################################################
Subprog C_JOBGRP(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
 If clalev([F:ADI])=0 : Local File ATABDIV       [ADI] : Endif
 ## Action CONTADI
 Call CONTADI(VALEUR,"10460","") From SUBADI
 If mkstat : GERR = 1  : End Endif
# If !mkstat
#  ## Action %CNTOBJ
#  Call CONTSEL("ADI","",VALEUR,"10461",mkstat) From CONTOBJ
 Read [F:ADI]CODE=10460;VALEUR
 If !fstat
  If dim([V]GCURLEG)>0 & [V]GCURLEG = "" & [F:ADI]LEG <> [V]GCURLEG
    GMESSAGE = mess(3,10937,1)-":"-VALEUR+chr$(10)+chr$(13)+mess(62,127,1)-":"-[F:ADI]LEG : # Réservé à la législation
    mkstat = 2
    GERR=1
    End
  Else
   Call CONTROLE("ADI","",VALEUR,"10460",mkstat) From CONTOBJ
   If mkstat : GERR = 1  : End Endif
  Endif
 Else
   If dim(GAUTOSEL)>0 & GAUTOSEL=2 & GWEBSERV<>1
     Local Char    CRITERE_JOT(250)
     Call CRIT_LEG_HLEG ([L]VALEUR,"10460","[F:ADI]CODE","NUMTAB","ADI","[F:ADI]LEG",GCURLEG,CRITERE_JOT) From TOOLSHRLEG

     Filter [F:ADI] Where  evalue(CRITERE_JOT)
     If rowcount([F:ADI]) > 1
# ## Action SELADILH
      Filter [F:ADI]
      If !GWEBSERV
        Local Char    PARMSK(250)(1..20) , SAVACT(20)
        SAVACT = GACTION : GACTION = "SELADILH"
        PARMSK(1) = "10460"
        PARMSK(2) = GCURLEG
        Call S_TAB_CHAR(VALEUR,PARMSK,"SELADILH","TOOLSHRLEG","") From GACTION
        GACTION = SAVACT
      Endif
      Gosub AFF From GSAISIE
     Endif
     If rowcount([F:ADI])=  1
       Read [F:ADI]CODE First
       If !fstat
         [L]VALEUR = num$([F:ADI]CODE)
       Endif
       Filter [F:ADI]
     Endif
     If !rowcount([F:ADI])
        Filter [F:ADI]
        Call CONTROLE("ADI","",VALEUR,"10460",mkstat) From CONTOBJ
        If mkstat : GERR = 1  : End Endif
     Endif
     Filter [F:ADI]
   Else
     Call CONTROLE("ADI","",VALEUR,"10460",mkstat) From CONTOBJ
     If mkstat : GERR = 1  : End Endif
   Endif
 Endif
Endif
End


