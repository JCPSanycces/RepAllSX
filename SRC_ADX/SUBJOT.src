#Init du niveau le plus faible par défaut en saisie
Subprog AS_NIV(VALEUR)
Variable Char    VALEUR()

Local Integer L_IJ

If dim([M:JOT5]LEVDES)>0
 [M:JOT5]LEVDES(nolign-1) = ""
Endif
If VALEUR=""
 Call BASNIVCPC([M:JOT5]CPC(nolign-1),VALEUR) From SUBCPC
 # JML 04/08/10 Text of the scale
 If dim([M:JOT5]LEVDES)>0
  Call LECTURE("CPC",[M:JOT5]CPC(nolign-1),"") From CONTOBJ
  Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
  L_IJ = find(VALEUR,[F:HRSCA]LEV)
  Read [HRSDD]SDD0=[F:CPC]CODSCA;L_IJ
  If !fstat
   [M:JOT5]LEVDES(nolign-1) = [F:HRSDD]LEVDES
  Endif
 Endif
 #
Endif
End

Subprog AM_NIV(VALEUR)
