Subprog AM_JOBGRP(VALEUR)
Variable Char    VALEUR()
Local Integer NBR_NBRFAM

# DBA 30/08/10
If clalev([F:ADI])=0 : Local File ATABDIV       [ADI] : Endif
  NBR_NBRFAM = [M:JOT4]NBRFAM
  [M:JOT4]JOBGRP = VALEUR
  If VALEUR<>""
   Read [F:ADI]CODE=10460;VALEUR
   If !fstat
     [M:JOT4]UOMGRP = [F:ADI]DEPCOD
   Endif
  Else
   Effzo[M:JOT4]UOMGRP
  Endif
#
Gosub INIT_CPC
#MIPEA - 2016-09-19 - X3PEOP-1920 - START
If func SUBJOT.IS_CAR
Affzo [JOT5]
Endif
#MIPEA - 2016-09-19 - X3PEOP-1920 - END

End

