# 108810
Subprog D_FLGINI(VALEUR)
Variable Char    VALEUR()
[M]RPLSUP=1
End
# JOJAC - 2016-03-23 - REQ114309 US86 - END

# SEGAY 25/10/12 US 930 81085
$CONTROLE_LEG_OK
# controle LEG
Local Char WLEGCOUR(GLONADI)
Local Char WORIFIELD(250)
Local Char WDESFIELD(250)
Local Integer WOK,POK
Local Integer WTYP
Local Char WFIELD(30)
Local Char ZFIELD(30)
Local Char WVALFIELD(30)

Local Char WECR(30)
Local Char WMES(250)
Local Integer NOL
If clalev([F:AMZ_])=0 : Local File AMSKZON [AMZ_] : Endif

WORIFIELD = "LEG"
WLEGCOUR=VALEUR
WOK = 1

If func SUBJOT.IS_CAR

WECR="JOT4"
ZFIELD="JOBGRP"
WFIELD=func TOOLSHRLEG.LIB_FIELD(WECR,ZFIELD)
WVALFIELD=[M:JOT4]JOBGRP

If WOK & WVALFIELD<> ""
    WTYP=3
    POK=0
    WLEGDEST=""
    Call GET_LEGADI("10460",WVALFIELD,POK,WLEGDEST,0)  From TOOLSHRLEG
    If POK
      Call LEGOK_H(WORIFIELD,WLEGCOUR,WVALFIELD,WLEGDEST,WTYP , WOK,WMES, 0)  From TOOLSHRLEG
      If !WOK
         zonsui =ZFIELD
         GMESSAGE = WMES:  mkstat = 2 :Return
      Endif
    Endif
Endif

If WOK
  WTYP=4
  NOL=0
  While (NOL<[M:JOT4]NBRFAM) &  mkstat<>2
      WVALFIELD=[M:JOT4]CPCFAM(NOL)
      If WVALFIELD<> ""
        POK=0
        WLEGDEST=""
        Call GET_LEGADI("10461",WVALFIELD,POK,WLEGDEST,0)  From TOOLSHRLEG
        If POK
          Call LEGOK_H(WORIFIELD,WLEGCOUR,WVALFIELD,WLEGDEST,WTYP , WOK,WMES, 0)  From TOOLSHRLEG
          If !WOK
             GMESSAGE = WMES:  mkstat = 2
          Endif
        Endif
      Endif
      NOL+=1
  Wend
Endif

If WOK
  WTYP=0
  NOL=0
  While (NOL<[M:JOT5]NBRLIG) &  mkstat<>2
      WVALFIELD=[M:JOT5]CPC(NOL)
      If WVALFIELD<> ""
        POK=0
        WLEGDEST=""
        Call GET_LEGCPC(WVALFIELD,POK,WLEGDEST,0)  From TOOLSHRLEG
        If POK
           Call LEGOK_H(WORIFIELD,WLEGCOUR,WVALFIELD,WLEGDEST,WTYP , WOK,WMES, 0)  From TOOLSHRLEG
          If !WOK
             GMESSAGE = WMES:  mkstat = 2
          Endif
        Endif
      Endif
      NOL+=1
  Wend
Endif
Endif # IS_CAR

# FQ81085 - 25/04/13 - Contrôle des législations de l'onglet Administratif
If WOK & WLEGCOUR<>""
  WTYP=0
  NOL=0
  While (NOL<[M:JOT2]NBRDIC) &  mkstat<>2
      WVALFIELD=num$([M:JOT2]LEV(NOL))
      If WVALFIELD="2" : # Niveau Législation
        POK=0
        WLEGDEST=""
        If [M:JOT2]LEGLEV(NOL)<>"" & [M:JOT2]LEGLEV(NOL)<>WLEGCOUR Then
          WOK=0
          GMESSAGE = mess(5,9009,1)+chr$(10)+chr$(13)+mess(62,127,1)-":"- [M:JOT2]LEGLEV(NOL)
          mkstat = 2
        Endif
      Endif
      NOL+=1
  Wend
Endif
# Fin FQ81085
Return


# END SEGAY 25/10/12 US 930 81085


######################################################################################
Funprog CHECKLEG_CPC(VALEUR,LEGREF)
Value Char VALEUR
Value Char LEGREF
Local Integer POK

  If (LEGREF<>"") Then
    If clalev([F:TCPC])=0    : Local File COMPETENCE  [TCPC]    : Endif
    Read [F:TCPC]CPC0=VALEUR
#    If !mkstat
    If !fstat
      If ([F:TCPC]LEG="" or [F:TCPC]LEG=LEGREF) Then
        POK=1
      Endif
    Endif
  Else
    POK=1
  Endif
End POK


