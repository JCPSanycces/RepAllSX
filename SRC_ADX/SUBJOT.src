Raz GPILOBJ
GFLAG = ""
Call OBJET("JOT",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "AVANTBOUT" : Gosub AVANTBOUT
 When "SETBOUT"   : Gosub SETBOUT
 When "RAZCRE"    : Gosub RAZCRE
 When "CREATION"  : Gosub CRE_MOD
 When "MODIF"     : Gosub CRE_MOD
 When "ANNULE"    : Gosub ANNULE
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "FIN_TABLE" : Gosub FIN_TABLE
#JOJAC - 2016-03-23 - REQ114309 US86 - START
 When "EXEC"      : Gosub EXEC : # 108810
 When "STYLE"     : Gosub STYLE
 When "APRIS_MODIF" : Gosub APRIS_MODIF
#JOJAC - 2016-03-23 - REQ114309 US86 - END
#LIPET - 2017-10-19 - X3-29326 - START
 When "VERIF_CRE"     : Gosub VERIF_CRE
 When "APRES_CRE"     : Gosub APRES_CRE
 When "APRES_MOD"     : Gosub APRES_MOD
#LIPET - 2017-10-19 - X3-29326 - END
  When Default
Endcase
#JOJAC - 2016-03-23 - REQ114309 US86 - START
#FRLAA - 2015-04-17 - REQUIREMENT 104631 US 3487 - START
If func AFNC.ACTIV("FKSQS")>0 & func DIVPAYE.EXISTE_KXX("SUBJOTKSA") Then
  Gosub ACTION From SUBJOTKSA
Endif
#FRLAA - 2015-04-17 - REQUIREMENT 104631 US 3487 - END
# JOJAC - 2016-03-23 - REQ114309 US86 - END
Return

$STYLE
  Call DISPLAY_HIDE()From SUBJOTLEG

#LIPET - 2017-10-19 - X3-29326 - START
  If func AFNC.ACTIV("EVAEN")=0 : Return : Endif
    If [M:JOT1]INDFLG = 2
      Chgfmt [M:JOT1]IND      With "+K:10X"
      Chgfmt [M:JOT1]INDWEI   With "+Nz:3.2"
      Actzo [M:JOT1]INDWEIFLG
      Actzo [M:JOT1]INDEQ
    Else
      Chgfmt [M:JOT1]IND      With "-K:10X"           : Raz [M:JOT1]IND
      Chgfmt [M:JOT1]INDWEI   With "-Nz:3.2"          : Raz [M:JOT1]INDWEI
      Diszo [M:JOT1]INDWEIFLG
      Diszo [M:JOT1]INDEQ
    Endif

    If [M:JOT1]MISWEIFLG = 2
      Chgfmt [M:JOT1]MISWEI     With "+Nz:3.2"
      Actzo [M:JOT1]MISEQ
    Else
      Chgfmt [M:JOT1]MISWEI     With "-Nz:3.2"         #: Raz [M:JOT1]MISWEI
      Diszo [M:JOT1]MISEQ
    Endif

    If [M:JOT1]INDWEIFLG= 2
      Chgfmt [M:JOT1]INDWEI     With "+Nz:3.2"
      Actzo [M:JOT1]INDEQ
    Else
      Chgfmt [M:JOT1]INDWEI     With "-Nz:3.2"         #: Raz [M:JOT1]INDWEI
      Diszo [M:JOT1]INDEQ
    Endif

  Gosub CHANGE_STYLE
  Affzo [M:JOT1]
#LIPET - 2017-10-19 - X3-29326 - END
Return

#LIPET - 2017-10-19 - X3-29326 - START
$CHANGE_STYLE
  If func AFNC.ACTIV("EVAEN")=0 : Return : Endif
  For nolign = 1 To [M:JOT1]NBRMIS
    If [M:JOT1]WMIS(nolign-1) = "" : Actzo [M:JOT1]MIS(nolign-1) :  Break: Endif
    If [M:JOT1]MIS(nolign-1) <> ""
      Chgstl [M:JOT1]MIS(nolign-1)    With "AMKACT"
      Actzo [M:JOT1]MIS(nolign-1)
      Actzo [M:JOT1]MISWEI(nolign-1)
      #Chgstl [M:JOT1]MISWEI(nolign-1) With "CONTRAT2"
    Else
      Chgstl [M:JOT1]MIS(nolign-1)    With ""
      Diszo [M:JOT1]MIS(nolign-1)
      Diszo [M:JOT1]MISWEI(nolign-1)
    Endif
  Next
Return
#LIPET - 2017-10-19 - X3-29326 - END
$APRIS_MODIF
Call DISPLAY_HIDE()From SUBJOTLEG
Return


###############################
$OUVRE
If clalev([F:GCP])=0    : Local File GRPCPC      [GCP]    : Endif
If clalev([F:HRSCA])=0  : Local File SCALE       [HRSCA]  : Endif
If clalev([F:CPC])=0    : Local File COMPETENCE  [CPC]    : Endif
If clalev([F:ID])=0     : Local File EMPLOID     [ID]     : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR    [HRCTR]  : Endif
If clalev([F:ATZ])=0    : Local File ATABZON     [ATZ]    : Endif
If clalev([F:ATY])=0    : Local File ATYPE       [ATY]    : Endif
If clalev([F:AMP])=0    : Local File AMSKPAR     [AMP]    : Endif
If clalev([F:HRGCD])=0  : Local File GRPCPCD     [HRGCD]  : Endif
If clalev([F:HRSDD])=0  : Local File SCALED      [HRSDD]  : Endif : # JML 04/08/10
If clalev([F:HRCCV])=0  : Local File CLASSCONV   [HRCCV]  : Endif
#LIPET - 2017-10-19 - X3-29326 - START
If func AFNC.ACTIV("EVAEN")>0
  If clalev([F:MJI])=0  : Local File MISJOTIND  [MJI] : Endif
Endif
#LIPET - 2017-10-19 - X3-29326 - END
# SBA 05/07/2012 add to have legislation
#old
