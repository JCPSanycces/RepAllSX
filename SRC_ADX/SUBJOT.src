## Etiquette ajoutée par le superviseur (écran JOT2) 20/07/2010 13:59:37 (JML)
######################################################################################
Subprog C_VALDEF(VALEUR)
Variable Char    VALEUR()

Local Integer  L_NOL
L_NOL = nolign - 1


Case [M:JOT2]CODTYP(L_NOL)
 When "ADI" :
  Call CONTSEL("ADI","!",VALEUR,[M:JOT2]VALPAR(L_NOL),mkstat) From CONTOBJ
  If mkstat : End : Endif

 When "HRCGD","HRCLV","HRCSP","HRMDP","HRMDT","HRNCT","HRXGD","HRCLC":
  Call CONTSEL(VALEUR,GCURLEG,"") From ="SUB"+[M:JOT2]CODTYP(L_NOL)
  If mkstat : End : Endif
 When "ORG"    :#Options 'I' for Type = Interim
  Call CONTSEL([M:JOT2]CODOBJ(L_NOL),"I",VALEUR,GCURLEG,mkstat) From CONTOBJ
  If mkstat : End : Endif
 When "RUB","CUM","PRF"    :#"VRA" later !
  Call CONTSEL([M:JOT2]CODOBJ(L_NOL),"",VALEUR,GCURLEG,mkstat) From CONTOBJ
  If mkstat : End : Endif
 When "VRA"
  Call CONTVRA(VALEUR,GCURLEG) From SUBVRA
  If mkstat : End : Endif
 When "EML"
  Call DROIT(VALEUR,"","","","") From DIVPAYE
  If !OK : mkstat=2 : End : Endif
 When "FCY"
  If clalev ([F:FCY])=0  : Local File FACILITY  [FCY] : Endif
  Call CONTROLE("FCY","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : End : Endif
  Call LECTURE("FCY",VALEUR,"") From CONTOBJ
  Call CONTCPYLEG([F:FCY]LEGCPY,GCURLEG) From TRTX3
  If mkstat : End : Endif
 When Default :
  If [M:JOT2]CODOBJ(L_NOL)<>"" & !find([M:JOT2]CODOBJ(L_NOL),"PLN")
   Call CONTSEL([M:JOT2]CODOBJ(L_NOL),"",VALEUR,"",mkstat) From CONTOBJ
   If mkstat : End : Endif
  Elsif [M:JOT2]CODTYP(L_NOL)<>"" & !find([M:JOT2]CODTYP(L_NOL),"PLN")
   Call CONTSEL([M:JOT2]CODTYP(L_NOL),"",VALEUR,"",mkstat) From CONTOBJ
   If mkstat : End : Endif
  Endif
 Endcase

If GPAYE
#PCA 13/08/12 - Added new LEGLEV field to unique checks
#[M:JOT2]UNQ(L_NOL) = [M:JOT2]FLD(L_NOL)+"~"+[M:JOT2]CPY(L_NOL)+"~"+[M:JOT2]FCY(L_NOL)+"~"+[M:JOT2]CLLCVT(L_NOL)+"~"+[M:JOT2]POP(L_NOL)
[M:JOT2]UNQ(L_NOL) = [M:JOT2]FLD(L_NOL)+"~"+[M:JOT2]CPY(L_NOL)+"~"+[M:JOT2]FCY(L_NOL)+"~"+[M:JOT2]CLLCVT(L_NOL)+"~"+[M:JOT2]POP(L_NOL)+"~"+[M:JOT2]LEGLEV(L_NOL)
Else
#PCA 13/08/12 - Added new LEGLEV field to unique checks
#[M:JOT2]UNQ(L_NOL) = [M:JOT2]FLD(L_NOL)+"~"+[M:JOT2]CPY(L_NOL)+"~"+[M:JOT2]FCY(L_NOL)+"~"+[M:JOT2]POP(L_NOL)
[M:JOT2]UNQ(L_NOL) = [M:JOT2]FLD(L_NOL)+"~"+[M:JOT2]CPY(L_NOL)+"~"+[M:JOT2]FCY(L_NOL)+"~"+[M:JOT2]POP(L_NOL)+"~"+[M:JOT2]LEGLEV(L_NOL)
Endif
Call UNICITE([M:JOT2]UNQ(L_NOL),[M:JOT2]UNQ(0..[M:JOT2]NBRDIC-1)) From OBJDIV
If mkstat : GMESSAGE = [M:JOT2]FLD(L_NOL) - GMESSAGE : End : Endif
End
