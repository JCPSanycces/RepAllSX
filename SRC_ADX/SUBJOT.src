Subprog AP_MIS(VALEUR)
Variable Char    VALEUR()
#LIPET - 2017-10-18 - X3-29326 - START
  Local Char PREVMIS : PREVMIS =[M:JOT1]WMIS(nolign-1)
  If func AFNC.ACTIV("EVAEN")=0 : End : Endif
  #Need to set WMIS even if there were no change
  If VALEUR = ""
    Actzo [M:JOT1]WMIS(nolign-1)
    [M:JOT1]WMIS(nolign-1)    = [M:JOT1]WMIS(nolign-2)
    Diszo [M:JOT1]MISWEI(nolign-1)
    Diszo [M:JOT1]MIS(nolign-1)
  Else
    Actzo [M:JOT1]MISWEI(nolign-1)
    [M:JOT1]WMIS(nolign-1) = VALEUR
  Endif
  Affzo [M:JOT1]MISWEI(nolign-1)
  For nolign = 1 To [M:JOT1]NBRMIS
    If [M:JOT1]WMIS(nolign-1) = PREVMIS
       [M:JOT1]WMIS(nolign-1) = VALEUR
    Endif
  Next
  Affzo [M:JOT1]WMIS(nolign-1)
#LIPET - 2017-10-18 - X3-29326 - END
End

Subprog AM_MIS(VALEUR)
Variable Char    VALEUR()
#LIPET - 2017-10-18 - X3-29326 - START
  If func AFNC.ACTIV("EVAEN")=0 : End : Endif
  If VALEUR = ""
    Actzo [M:JOT1]WMIS(nolign-1)
    [M:JOT1]WMIS(nolign-1)    = [M:JOT1]WMIS(nolign-2)
    Diszo [M:JOT1]MISWEI(nolign-1)
    Diszo [M:JOT1]MIS(nolign-1)
  Else
     Actzo [M:JOT1]MISWEI(nolign-1)
    [M:JOT1]WMIS(nolign-1) = VALEUR
  Endif
  Affzo [M:JOT1]MISWEI(nolign-1)
  For nolign = 1 To [M:JOT1]NBRMIS
    If [M:JOT1]WMIS(nolign-1) = VALEUR
      [M:JOT1]IND(nolign-1) = ""
    Endif
  Next
  Affzo [M:JOT1]IND(nolign-1)
#LIPET - 2017-10-18 - X3-29326 - END
End

Subprog C_MISWEI(VALEUR)
Variable Decimal VALEUR
#LIPET - 2017-10-18 - X3-29326 - START
  If func AFNC.ACTIV("EVAEN")=0 : End : Endif
  If VALEUR < 0
    mkstat = 1 : GMESSAGE = mess(00180,00141,1)
  Endif
  If [M:JOT1]MISWEIFLG = 2 and [M:JOT1]MIS(nolign-1) <> "" and [M:JOT1]MISEQ <> 2
    If VALEUR = 0
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif
#LIPET - 2017-10-18 - X3-29326 - END
End

Subprog C_IND(VALEUR)
Variable Char    VALEUR()
#LIPET - 2017-10-18 - X3-29326 - START
  Local Integer FOUND : FOUND = 0
  If clalev([F:MIS1])=0  : Local File MISIND     [MIS1] : Endif
    For [MIS1] Where MIS = [M:JOT1]WMIS(nolign-1)
      If [F:MIS1]COD = VALEUR Then
        FOUND = 1
      Endif
    Next
  If FOUND = 0 Then
    GMESSAGE = mess(00104,00199,1)
    mkstat=2 : End
  Endif
  If func AFNC.ACTIV("EVAEN")=0 : End : Endif
  #Test for duplication
  If VALEUR <> ""
    Call UNICITE(VALEUR,[M:JOT1]IND(0..[M:JOT1]NBRMIS-1)) From OBJDIV
  Endif

  If [M:JOT1]INDFLG = 2
    If VALEUR = ""
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif
#LIPET - 2017-10-18 - X3-29326 - END
End

Subprog C_INDWEI(VALEUR)
Variable Decimal VALEUR
#LIPET - 2017-10-18 - X3-29326 - START
  If func AFNC.ACTIV("EVAEN")=0 : End : Endif
  If VALEUR < 0
    mkstat = 1 : GMESSAGE = mess(00180,00141,1)
  Endif
  If [M:JOT1]INDFLG = 2 and [M:JOT1]INDWEIFLG = 2 and [M:JOT1]INDEQ <> 2
    If VALEUR = 0
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif
#LIPET - 2017-10-18 - X3-29326 - END
End


######################################################################################

