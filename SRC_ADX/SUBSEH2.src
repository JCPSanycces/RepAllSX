#<AdxTL>@(#)0.0.0.0 $Revision$

###########################################################
## Génération de la transaction de saisie d'hypothèse
###########################################################
Subprog GENECR(APPLI,MSK,COD,ENA,ACC,ACTV,DESI)
Value Char APPLI , MSK , COD , ACC , ACTV ,DESI
Value Integer ENA 
Local File =APPLI+".AWINDOW"    [AWI]
If clalev([F:AWP])=0  : Local File =APPLI+".AWINPAR"    [AWP]  : Endif
If clalev([F:AWT])=0  : Local File =APPLI+".AWINBOUT"   [AWT]  : Endif
If clalev([F:AWB])=0  : Local File =APPLI+".AWINBRO"    [AWB]  : Endif
If clalev([F:AWI2])=0 : Local File =APPLI+".AWINDOW"    [AWI2] : Endif
If clalev([F:AWP2])=0 : Local File =APPLI+".AWINPAR"    [AWP2] : Endif
If clalev([F:AWT2])=0 : Local File =APPLI+".AWINBOUT"   [AWT2] : Endif
If clalev([F:AWB2])=0 : Local File =APPLI+".AWINBRO"    [AWB2] : Endif

Local Integer OK
Local Char    WINREF(GLONFEN) , WINDES(GLONFEN)

WINREF  = "O"+MSK
WINDES  = "WF"+MSK+COD
MSK     = MSK+"0"

Call TR_DELWIN(WINDES,APPLI) From MSKDIV
If GOK=0 : End : Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=0 : End : Endif
## Validation fenêtre
Call VALID(WINDES,APPLI,0,OK) From VALWIN
If !OK : GOK = 0 : End : Endif
End

$TR1
GOK = 1
Trbegin [AWI]
# Création de la fenêtre de saisie
 Read [AWI2]AWI0 = WINREF
 [F:AWI] = [F:AWI2]
 [F:AWI]WIN       = WINDES
 [F:AWI]NOMMSK(0) = MSK  
 [F:AWI]ENAFLG    = ENA
 [F:AWI]MDL       = 1
 [F:AWI]TRN       = COD
 [F:AWI]ACS       = ACC
 [F:AWI]CODACT    = ACTV
 [F:AWI]LIBEL     = DESI
 Write [AWI]
 If fstat
  GOK = 0 : Call FSTA("AWI") From GLOCK : Goto AB_TR1
 Endif
 For [AWP2]AWP0 Where WIN=WINREF
  [F:AWP] = [F:AWP2]
  [F:AWP]WIN = WINDES
  Write [AWP]
  If fstat
   GOK = 0 : Call FSTA("AWP") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
 For [AWT2]AWT0 Where WIN=WINREF
  [F:AWT] = [F:AWT2]
  [F:AWT]WIN = WINDES
  Write [AWT]
  If fstat
   GOK = 0 : Call FSTA("AWT") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
 For [AWB2]AWB0 Where WIN=WINREF
  [F:AWB] = [F:AWB2]
  [F:AWB]WIN = WINDES
  Write [AWB]
  If fstat
   GOK = 0 : Call FSTA("AWB") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

#Contrôle des doublons de champs
Subprog CTL_DBL_FLD (REF,LIG)
Value Char REF
Value Integer LIG
Local Integer IND
GOK=1
For IND=0 To [M]NBDICO-1
 If IND<>LIG
  If [M]FLD(IND)=REF
   GMESSAGE = mess(19,176,1)-num$(IND+1) : # Zone déjà saisie 
   GOK=0 
   Break
  Endif
 Endif
Next
End

#Contrôle des doublons de variables
Subprog CTL_DBL_VRA (REF,LIG)
Value Char REF
Value Integer LIG
Local Integer IND
GOK=1
For IND=0 To [M]NBVRA-1
 If IND<>LIG
  If [M]VRA(IND)=REF
   GMESSAGE = mess(19,176,1)-num$(IND+1) : # Zone déjà saisie
   GOK=0 
   Break
  Endif
 Endif
Next
End

$MAJHYP
#M.à.j champs salarié et variables salarié dans les hypothèses saisies sur la transaction 
Local Char     TFLDEML(GLONDIC)(0..dim(GFLDMS)-1) : # Champs salariés MS
Local Char     TFLDVAL(80)(0..dim(GFLDMS)-1) 
Local Char     TVRAEML(GLONVRA)(0..dim(GVRAMS)-1) : # Variables salariés MS
Local Decimal  TVRAVAL(0..dim(GVRAMS)-1) 
Local Shortint TMOD , XIST
For [F:MH] Where [F:MH]TRN = [M]COD
 Raz TFLDEML , TFLDVAL , TVRAEML , TVRAVAL
 TFLDEML = [F:MH]FLDEML  
 TMOD = 0 
#Parcours du tableau des champs salarié  
 For LMS = 0 To (dim(GFLDMS)-1)
  TFLDEML(LMS) = [F:MH]FLDEML(LMS)
  TFLDVAL(LMS) = [F:MH]FLDVAL(LMS)
  If GFLDMS(LMS+1,0) <> TFLDEML(LMS) | GFLDMS(LMS+1,0) = ""   
   TMOD = 1 # pour ne faire les rewrites que si nécessaire
   XIST = find(GFLDMS(LMS+1,0),TFLDEML(0..dim(GFLDMS)-1))
   If XIST  : # le champs existait à un autre emplacement 
    [F:MH]FLDEML(LMS) = TFLDEML(XIST-1) 
    [F:MH]FLDVAL(LMS) = TFLDVAL(XIST-1)
   Else 
    XIST = find(GFLDMS(LMS+1,0),[F:MH]FLDEML(0..dim(GFLDMS)-1))
    If XIST  : # le champs existait à un autre emplacement
     [F:MH]FLDEML(LMS) = [F:MH]FLDEML(XIST-1) 
     [F:MH]FLDVAL(LMS) = [F:MH]FLDVAL(XIST-1)
    Else     : # c'est un nouveau champ dans la transation
     [F:MH]FLDEML(LMS) = GFLDMS(LMS+1,0)
     [F:MH]FLDVAL(LMS) = ""
    Endif
   Endif
  Else      : # le champs existait au même emplacement
   [F:MH]FLDEML(LMS) = TFLDEML(LMS) 
   [F:MH]FLDVAL(LMS) = TFLDVAL(LMS)
  Endif
 Next
 #parcours du tableau des variables salarié
 For LMS = 0 To (dim(GVRAMS)-1)
  TVRAEML(LMS) = [F:MH]VRAEML(LMS)
  TVRAVAL(LMS) = [F:MH]VRAVAL(LMS)
  If GVRAMS(LMS+1,0) <> TVRAEML(LMS) | GVRAMS(LMS+1,0) = ""
   TMOD = 1
   XIST = find(GVRAMS(LMS+1,0),TVRAEML(0..dim(GVRAMS)-1))
   If XIST  : # la variable existait à un autre emplacement 
    [F:MH]VRAEML(LMS) = TVRAEML(XIST-1) 
    [F:MH]VRAVAL(LMS) = TVRAVAL(XIST-1)
   Else 
    XIST = find(GVRAMS(LMS+1,0),[F:MH]VRAEML(0..dim(GVRAMS)-1))
    If XIST  : # la variable existait à un autre emplacement
     [F:MH]VRAEML(LMS) = [F:MH]VRAEML(XIST-1) 
     [F:MH]VRAVAL(LMS) = [F:MH]VRAVAL(XIST-1)
    Else     : # c'est une nouvelle variable dans la transation
     [F:MH]VRAEML(LMS) = GVRAMS(LMS+1,0)
     [F:MH]VRAVAL(LMS) = 0
    Endif
   Endif
  Else      : # la variable existait au même emplacement
   [F:MH]VRAEML(LMS) = TVRAEML(LMS) 
   [F:MH]VRAVAL(LMS) = TVRAVAL(LMS)
  Endif
 Next
 If TMOD : Rewrite [F:MH]: Endif
Next
Return
