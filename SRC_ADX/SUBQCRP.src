#<AdxTL>@(#)4.0.0.0 $Revision$
# TRAITEMENTS LIES AU PICKING DES DEMANDES ANALYSE                       #
#########################################################################

#########################################################################
# Actions de l'objet                                                    #
#########################################################################

#########################################################################
# Pour modifier la clé de classement
$HINT_KEY

Return

#########################################################################
$TIROIR
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI

Return

#########################################################################
$REMP_DERLU

# Pas de dernier lu
If GFONC1 <> GFONCTION
   adxmxl=0
Endif
Return

#########################################################################
$FILGAUCHE
Local Integer W_I, W_J
Local Char    W_STA(GLONSTA)

If !find(GFONC1,"GESQCR")
   If ILIS=0 adxmxl=0 Endif
Endif

If currbox<>GBOXSTO Return Endif

Raz FILGAUSUP(1)
Raz FILGAUSUP(2)

FILGAUSUP(0) = '[F:STO]STOFCY=[M:QCR1]STOFCY'
If [M:QCR1]ITMREFSEL <> ""
   FILGAUSUP(0) += '&[F:STO]ITMREF=[M:QCR1]ITMREFSEL'
Endif
If dim([M:QCR1]LOTSTR)>0
   FILGAUSUP(0) += '&[F:STO]LOT>=[M:QCR1]LOTSTR'
   If [M:QCR1]LOTEND<>""
      FILGAUSUP(0) += '&[F:STO]LOT<=[M:QCR1]LOTEND'
   Endif
Endif
If dim([M:QCR1]SLOSTR)>0
   FILGAUSUP(0) += '&[F:STO]SLO>=[M:QCR1]SLOSTR'
   If [M:QCR1]SLOEND<>""
      FILGAUSUP(0) += '&[F:STO]SLO<=[M:QCR1]SLOEND'
   Endif
Endif
If dim([M:QCR1]LOCSTR)>0
   FILGAUSUP(0) += '&[F:STO]LOC>=[M:QCR1]LOCSTR'
   If [M:QCR1]LOCEND<>""
      FILGAUSUP(0) += '&[F:STO]LOC<=[M:QCR1]LOCEND'
   Endif
Endif
If dim([M:QCR1]WRHSEL)>0
   If [M:QCR1]WRHSEL<>""
      FILGAUSUP(0) += '&[F:STO]WRH=[M:QCR1]WRHSEL'
   Endif
Endif
FILGAUSUP(1) = '&[F:STO]CUNLOKFLG<>2&[F:STO]QTYSTU>0&[F:STO]QLYCTLDEM=""'
   # Filtre statuts
If WCRITSTO4<>""
   FILGAUSUP(1) += '&('+WCRITSTO4+')'
Endif
If dim([M:QCR1]SERNUMSTR)>0
   FILGAUSUP(1) += '&[F:STO]SERNUM>=[M:QCR1]SERNUMSTR'
   If [M:QCR1]SERNUMEND<>""
      FILGAUSUP(1) += '&[F:STO]SERNUM<=[M:QCR1]SERNUMEND'
   Endif
Endif
If [M:QCR1]NBUOM>0
   FILGAUSUP(1) += '&find([F:STO]PCU,[M:QCR1]UOM)'
Endif
#                                                           # hcb X3-88857 deb
If dim([M:QCR1]LPNNUMDEB)>0
   FILGAUSUP(1) += '&[F:STO]LPNNUM>=[M:QCR1]LPNNUMDEB'
   If [M:QCR1]LPNNUMEND<>""
      FILGAUSUP(1) += '&[F:STO]LPNNUM<=[M:QCR1]LPNNUMEND'
   Endif
Endif

#                                                           # hcb X3-88857 fin

Return

#########################################################################
$AP_FILGAUCHE
Case currbox
 When GBOXSTO : WPICK=2 : Gosub RAFFRAICHI
 When Default
Endcase
Return

#########################################################################
$DEB_PICK

Return

#########################################################################
$PICKE
If GREP = "M"
   If dim(GCTRDATQCR) <= 0
      If [M:QCR1]IPTDAT < date$
         Global Integer GCTRDATQCR
         # Attention ! la date d imputation est antérieure à la date du jour
         Call MESSAGE(mess(162,184,1)) From GESECRAN
      Endif
   Endif
Endif

If dim(LSAVNOL)<=0
    Local Integer LSAVNOL
    LSAVNOL=-1
Endif

If REP=""
   If !CLECUR | !VERROU | !ACTMOD
      OK=0 : Return
   Endif
Endif

If currbox<>GBOXSTO
    Return
Endif

Read [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
If fstat
   Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
   OK=0 : Return
Endif
Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
If fstat
   Call RSTA ("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
   OK=0 : Return
Endif

# Si changement de stock et pas de filtre article saisi,
# il faut lire articles
If [M:QCR1]ITMREFSEL=""
   Call LECITM2([M:QCR1]STOFCY,[F:STO]ITMREF,[F:STO]WRH,LRET) From STKLIB
   If LRET<>0
      If GMESSAGE<>"" Call ERREUR(GMESSAGE) From GESECRAN Endif
      OK=0 : Return
   Endif
# sru
#   Call LECSRU([M:QCR1]STOFCY,[F:ITM]TCLCOD,34,"","",LRET) From STKLIB
#   If LRET<>0 mkstat=2 : End Endif
#   GQCRAUZSST = [F:SRU]AUZSST

Endif

Local Integer LRET
Local Integer LSEQ
Local Integer LNEW    # Indique s'il faut ajouter une ligne au document
Local Char    LSER(GLONSER)
Local Decimal LQTY , LQTYRES
Local Decimal LSTOCOU
If [F:STO]LOCCAT=2
   Raz LRET
   # Contrôle que la ligne de stock en attente de rangement est complète
   Call CTLPLFLOC([F:STO]ITMREF,"",LRET) From STKSOR
   If LRET<>0
      OK=0 : GERR=1
      GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
      GMESSAGE+="\"+mess(377,199,1)-": "
      Case LRET
       When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
       When 2 : GMESSAGE+=mess(453,197,1)
       When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
      Endcase
      Return
   Endif

   # La ligne de stock est elle dans une liste à ranger ?
   Filter [SGW] Where STOCOU=[F:STO]STOCOU
   Read [SGW]First
   If !fstat
      OK=0 : GERR=1
      GMESSAGE = mess(292,184,1)
      Filter [SGW]
      Return
   Endif
   Filter [SGW]

   GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(135,184,1)
   Return
Endif
Global Integer GALLSTO                                           # hcb 110327
Raz    GALLSTO                                                   # hcb 110327
If !clalev([F:STA]) : Local File STOALL [STA] : Endif
Look [F:STA]STA0(3)=[F:STO]STOFCY;[F:STO]ITMREF;[F:STO]STOCOU
[G:STA]currlen=0
If !fstat
#    If dim(GALLSTO)=0 : Global Integer GALLSTO : Endif           # hcb 110327
    GALLSTO = 1
Endif

If [F:STO]QTYSTU-[F:STO]CUMWIPQTY>0
    LSTOCOU = [F:STO]STOCOU
    Read [STO]STO0=[M:QCR1]STOFCY;LSTOCOU
    #                                                                 # hcb 110327 deb
    If [F:ITM]SERMGTCOD = 4 & [F:STO]CUMWIPQTY = 0 & [F:STO]CUMWIPQTA = 0 & GALLSTO = 0
       Call POSTABLE([M:QCR1]STOFCY, [F:STO]ITMREF, [F:STO]LOT, [F:STO]SLO, LRET) From SUBQCRB
       If LRET
          OK=0
          Return
       Endif
       Local Char    PABR
       Local Char    LSTA
       Local Integer PNOL
       Raz   LSTA
       PABR = "QCR1"
       NOL  = [M:QCR1]NBLIG
       NOL +=1
       If left$([F:STO]STA,1) <> "Q"
          Call STKINISTA(LSTA,"",[F:ITF]QUAFLG) From STKACT
          If LSTA = ""
             LSTA = "Q"
          Endif
       Else
          LSTA = [F:STO]STA
       Endif
       [M:QCR1]STADES   (NOL-1)      = LSTA
       [M:QCR1]QTYSTUDES(NOL-1)      = [F:STO]QTYSTU
       Gosub CTR_SERIES_GLOBALE From SUBSCSB
       If LSAVNOL<0
          LSAVNOL = nolign-1
       Endif
#                                                                 # hcb 110327 end

    Else
       Gosub ALI_DOC   From SUBQCRB
       LQTY                   = [M:QCR1]QTYSTUDES(NOL)
       Gosub CRERESSTO From SUBQCRB     # --> Modifie LQTY, calcule LQTYRES et LPOT
       [M:QCR1]WWIPQTY(NOL)   = [F:STO]CUMWIPQTY
       [M:QCR1]WWIPQTA(NOL)   = [F:STO]CUMWIPQTA
       If LSAVNOL<0
          LSAVNOL = nolign-1
       Endif
    Endif                                                         # hcb 110327
Else
    GMESSAGE=mess(57,184,1)
    OK = 0
Endif
Default Mask [QCR1]                                               # hcb 110327

Return

#########################################################################
$DEPICK
Local Integer DP_LRET
Case currbox
 When GBOXSTO :
      Look [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
      If fstat
         Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
         FOK=0 : Return
      Endif
      Call DEPICK([F:STO]STOFCY, [F:STO]STOCOU, "QCR1", DP_LRET) From SUBQCRB
      Affzo [M:QCR1]
      OK = !DP_LRET
 When Default
Endcase
Return
#########################################################################
$FIN_PICK

If REP=""
   If !VERROU
      GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
   Elsif !CLECUR | !ACTMOD | GCONSULT
      GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
   Endif
Endif

Local Integer LRET
Local Decimal LQTY
If dim(GQCRPIC)>0
   Kill GQCRPIC
   Affzo [M:QCR1]10
Endif

If dim(GALLSTO)>0
   If GALLSTO=1
      Call MESSAGE(mess(84,184,1)) From GESECRAN
   Endif
   Kill GALLSTO
Endif

Case currbox
     When GBOXSTO : Affzo [M:QCR1]1-99
     When Default
Endcase

If [M:QCR1]NBLIG>0 & dim(LSAVNOL)>0 & LSAVNOL>=0
    zonsui="NBLIG("+num$(LSAVNOL)+")"
    Kill LSAVNOL
Endif

Return

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

$REMPBOX
#-----------------------------------------------------------------------#
# Remplissage des boites de picking                                     #
#-----------------------------------------------------------------------#
ILIS=val(right$(currbox,8))

Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI
Return

#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement des listes de picking pour les lignes déjà saisies  #
#-----------------------------------------------------------------------#

For I=0 To [M:QCR1]NBLIG-1
    If [M:QCR1]QTYSTUDES(I) <> 0 & [M:QCR1]CREFLG(I) = 0
       Case currbox
       When GBOXSTO : Read [STO]STO0=[M:QCR1]STOFCY;[M:QCR1]WSTOCOU(I)
                      Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
       When Default
       Endcase
       If    WPICK = 1
             Gosub DEPICK From GOBJSUB
       Elsif WPICK = 2
             Gosub REPICK From GOBJSUB
       Endif
    Endif
Next I
Return

