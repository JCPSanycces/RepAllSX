#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque LPNIMP
$ACTION

Case ACTION
  When "DEBUT"    : Gosub DEBUT
  When "OK"       : Gosub OK
  #When "END"      : Gosub FIN
Endcase
Return

##########################################################################
$DEBUT
Local Integer OBLIG
Local Char WLPNNUM(GLONLPN)
Local File LPN [LPN]
Local File TABCONTAINER[TCTR]
# Récupération des paramètres
WLPNNUM    = PARAM(1)
Read [LPN]LPN0 =  WLPNNUM
Read [TCTR]TCTR0 = [F:LPN]TCTRNUM
[M:LPNI]LBEFMT = [F:TCTR]LBEFMT
Call DEFIMP([M:LPNI]LBEFMT,GUSER,"",[M:LPNI]PRT,OBLIG) From IMPRIME
Affzo [M:LPNI]
Return
##########################################################################
$OK
Local Char WLPNNUM (GLONLPN)
Local Integer WREQNUM
Local Char WREPORT (GLONARP)
Local Integer WDET, WRET, WLIG
Local File LABELPRN[LBP]

#remplissage de la table LABELPRN
WLPNNUM = [M:LPN]LPNNUM
WREQNUM = uniqid([LBP])
WLIG    = 1
WREPORT = [M:LPNI]LBEFMT
WRET    = 1
WDET    = 1

Call REMPLBP(WLPNNUM,WREQNUM,WLIG,WREPORT,WDET,WRET) From STKLPN
If WRET = 0
  mkstat = 2
  GMESSAGE = "Erreur dans le 'écriture de la table LABERPRN"
  Return
Endif
#remplissage des paramétres
Local Char TBPAR(15)(1..50),TBVAL(30)(1..50)
TBPAR(1) = "usr"
TBVAL(1) = GUSER
TBPAR(2) = "etat"
TBVAL(2) = [M:LPNI]LBEFMT
TBPAR(3) = "numedt"
TBVAL(3) = num$(WREQNUM)
TBPAR(4) = "impselections"
TBVAL(4) = "1"

Call ETAT([M:LPNI]LBEFMT,[M:LPNI]PRT,"",1,"",TBPAR,TBVAL) From AIMP3
#mise à jour du flag imprimé du LPN
Trbegin [LPN]
Read [LPN]LPN0=WLPNNUM
If fstat = 0
  [F:LPN]PRTFLG = 2
  Rewrite [LPN]
  If fstat = 0 Commit Else Rollback Endif
  Return
Else
  Rollback
Endif

Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNIMP) 25/05/2018 06:37:49 (MAE)
######################################################################################
Subprog AM_LBEFMT(VALEUR)
Variable Char    VALEUR()
End


