#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : GBO
# LE          : 31 Mai       2011 17:12:58
# Moulinette pour supprimer les sous-programmes inexistants dans le traitement TRTVENALL
# FQ72386
# FQ75621     : 08/08/11 Ajout suppression dans la table ASUBPROGD  
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIVEN13: Suppression des sous-pro inexistants dans TRTVENALL") From LECFIC
  Call EXE_UTIVEN13(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIVEN13(APPLI)
 Value Char APPLI
  If clalev([F:ASU]) : Close Local File [ASU] : Endif   
  If clalev([F:ASP]) : Close Local File [ASP] : Endif   : # Bug 75621
  Local File =APPLI+".ASUBPROG"  [ASU]
  Local File =APPLI+".ASUBPROGD" [ASP]                  : # Bug 75621
  Call ECR_TRACE("UTIVEN13: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIVEN13
  Call ECR_TRACE("UTIVEN13: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIVEN13

  Trbegin [F:ASU], [F:ASP] 

  Local Char LSUBPRG
  LSUBPRG="ALLNOM"     : Gosub REMOVE_SUBPROG
  LSUBPRG="DISALLNOM"  : Gosub REMOVE_SUBPROG
  LSUBPRG="IMPGLO"     : Gosub REMOVE_SUBPROG
  LSUBPRG="MAJALLCLI"  : Gosub REMOVE_SUBPROG
  LSUBPRG="MAJALLSEQ"  : Gosub REMOVE_SUBPROG
  LSUBPRG="MAJSTOALL"  : Gosub REMOVE_SUBPROG
  LSUBPRG="RECDISPOAL" : Gosub REMOVE_SUBPROG
  LSUBPRG="STODISALL"  : Gosub REMOVE_SUBPROG

  If !GOK Then
    Goto AB_UTIVEN13
  Else
    Commit
  Endif
Return

$AB_UTIVEN13
 Rollback
Return

$REMOVE_SUBPROG
  Delete [F:ASU] Where PRG="TRTVENALL" & SUBPRG=LSUBPRG
  If !fstat
   Call ECR_TRACE("   Subprog "+LSUBPRG+" removed from the subprog dictionnary ASUBPROG",0) From GESECRAN
  Else
   Call ECR_TRACE("   Error while removing "+LSUBPRG+" subprog in the subprog dictionnary ASUBPROG fstat="+num$(fstat),1) From GESECRAN    
   GOK=0 : Return
  Endif 
  # Bug 75621 
  Delete [F:ASP] Where PRG="TRTVENALL" & SUBPRG=LSUBPRG
  If !fstat
   Call ECR_TRACE("   Subprog "+LSUBPRG+" removed from the subprog dictionnary ASUBPROGD",0) From GESECRAN
  Else
   Call ECR_TRACE("   Error while removing "+LSUBPRG+" subprog in the subprog dictionnary ASUBPROGD fstat="+num$(fstat),1) From GESECRAN    
   GOK=0
  Endif 
  # Bug 75621 
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","ASUBPROG" ,"fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","ASUBPROGD","fde",APPLI),0) < 0 : End : Endif : # Bug 75621
  Call EXE_UTIVEN13(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","ASUBPROG" ,"fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","ASUBPROGD","fde",APPLI),0) < 0 : End : Endif : # Bug 75621
  Call EXE_UTIVEN13(APPLI)
End
