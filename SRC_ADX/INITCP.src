#JASMI - commented this line out - START
#MODIFICATION :
#JASMI - commented this line out - END
#       SEGAY - 14/03/12 - FQ74044-80569 - Erreur sur champ FILTRE
######################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","INITCP","INITCP",3,"") From GTRAITE
Infbox PARAM
End

####################################
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "EXEC"     : Gosub EXEC
 When "SORTIE"   : Gosub SORTIE
Endcase
Return

####################################
$INIT
Local Char    CRITERE(250)
Local Char    CRITERE1(250)
Local Char    TIT(50)
#LIPET - 12-05-2016 - X3-15388 - START
#Local Char    MATRI(GLONMAT)
Local Char    MATRI(GLONEML)
#Local Char    CTR(GLONCTR)
Local Char    CTR(GLONHRCTR)
#LIPET - 12-05-2016 - X3-15388 - END
Local Date    DATMAT
Local Integer OK , OKC, ANNEE
Local Decimal NBRJOU, MONTACQ, MONTPRI
Gosub OUVFIC


#JASMI - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#JASMI - END

#83905
Local Mask INITCP [DIA]
Raz [M:DIA]

TMP = 1
TRA = 1
Return

$SORTIE
#LIPET - 12-05-2016 - X3-15388 - START
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#LIPET - 12-05-2016 - X3-15388 - END
Return

####################################
$OUVFIC
#LIPET - 12-05-2016 - X3-15388 - START
#Gosub OUVRE From DEFTABLE
Gosub OUVRE From WPDEFTABLE
#LIPET - 12-05-2016 - X3-15388 - END

If clalev([F:PEO])=0  : Local File PERIOD    [PEO]  : Endif
If clalev([F:TIM])=0  : Local File TIMCOD    [TIM]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY  [FCY]  : Endif
If clalev([F:SIT])=0  : Local File SITEPAYE  [SIT]  : Endif
If clalev([F:ACC])=0  : Local File ACCES     [ACC]  : Endif
If clalev([F:SRV])=0  : Local File SERVICE   [SRV]  : Endif
If clalev([F:PRF])=0  : Local File PROFIL    [PRF]  : Endif
If clalev([F:VRA])=0  : Local File VARIA     [VRA]  : Endif
If clalev([F:HSP])=0  : Local File HISTOPAYE [HSP]  : Endif
If clalev([F:POA])=0  : Local File POPULA    [POA]  : Endif
If clalev([F:CNG])=0  : Local File CNGCPY    [CNG]  : Endif
If clalev([F:CNE])=0  : Local File CNGEMP    [CNE]  : Endif
If clalev([F:CNE2])=0 : Local File CNGEMP    [CNE2] : Endif
If clalev([F:VEP])=0  : Local File VALEMP    [VEP]  : Endif
Return

####################################

$EXEC
#LIPET - 12-05-2016 - X3-15388 - START
#TIT = mess(107,709,1) : # Initialisation des congés
TIT = mess(107,10709,1) : # Initialisation des congés
#LIPET - 12-05-2016 - X3-15388 - END

#ouverture de la trace et écriture de l'en-tête
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

CRITERE = "[F:ID]ENAFLG=2 & [F:ID]FLGTPS=2"
If [M:DIA]ALLCPY<>2  #société
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 CRITERE -= '& [F:VEP]FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:VEP]EMP>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:VEP]EMP<="'+[M:DIA]MATFIN+'"'
Endif

#filtre sur critere de la position professionnelle
CRITERE1 = "1=1"
If [M:DIA]ALLSRV<>2  #service
 CRITERE1 -= '& [F:VEP]SRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2  #profil
 CRITERE1 -= '& [F:VEP]PRF = "'+[M:DIA]PRF+'"'
Endif

If [M:DIA]FLGSTR=2
 CRITERE1 -= '& [F:VEP]PYRDAT = ['+format$(GFMD,[M:DIA]DATPYR)+']'
Else
 CRITERE1 -= '& [F:VEP]PYRDAT >= ['+format$(GFMD,[M:DIA]DATDEB)+'] & [F:VEP]PYRDAT <= [' +format$(GFMD,[M:DIA]DATFIN)+']'
Endif

#MIPEA - 2017-01-23- X3-LEG Addition Process Functions- START
If [M:DIA]POP<>""
 Link [VEP] With
&   [ID]ID0   = [F:VEP]EMP
& , [FCY]FCY0 = [F:VEP]FCY
& , [POA]POA0 = [M:DIA]POP;[F:VEP]EMP
&   As [LNK]
&   Where evalue(CRITERE1) & evalue(CRITERE) & [F:POA]REFNUM<>"" & [F:FCY]LEG=GCURLEG
Else
 Link [VEP] With
&   [ID]ID0   = [F:VEP]EMP
& , [FCY]FCY0 = [F:VEP]FCY
&   As [LNK]
&   Where evalue(CRITERE1) & evalue(CRITERE) & [F:FCY]LEG=GCURLEG
Endif
#If [M:DIA]POP<>""
# Link [VEP] With
#&   [ID]ID0   = [F:VEP]EMP
#& , [FCY]FCY0 = [F:VEP]FCY
#& , [POA]POA0 = [M:DIA]POP;[F:VEP]EMP
#&   As [LNK]
#&   Where evalue(CRITERE1) & evalue(CRITERE) & [F:POA]REFNUM<>""
#Else
# Link [VEP] With
#&   [ID]ID0   = [F:VEP]EMP
#& , [FCY]FCY0 = [F:VEP]FCY
#&   As [LNK]
#&   Where evalue(CRITERE1) & evalue(CRITERE)
#Endif
#MIPEA - 2017-01-23- X3-LEG Addition Process Functions- END

#RAZ préalable
# FQ74044 - MABON 13/02/12 - Ajout vérification du nouveau champ FILTRE
Local Integer RET
#LIPET - 12-05-2016 - X3-15388 - START
#Call LECTURE("TIM",[M:DIA]TIM,"") From CONTOBJ
Call LECTURE("HRTIM",[M:DIA]TIM,GCURLEG) From CONTOBJ
#LIPET - 12-05-2016 - X3-15388 - END
# Fin MABON
If [M]FLGRAZ=2
 For [LNK]
  If MATRI="" | MATRI<>[F:VEP]EMP | CTR<>[F:VEP]CTRNUM
   MATRI  = [F:VEP]EMP
   CTR    = [F:VEP]CTRNUM
   DATMAT = [F:VEP]PYRDAT
   #LIPET - 12-05-2016 - X3-15388 - START
#   Gosub LECEMP From DEFTABLE
   Gosub LECEMP From WPDEFTABLE
  #LIPET - 12-05-2016 - X3-15388 - END
   Gosub TRTCONT
   # FQ74044 - MABON 13/02/12 - Ajout vérification du nouveau champ FILTRE
   If OK & ([F:TIM]FILTRE<>"" | [F:TIM]POP<>"") Then
    Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,MATRI,CTR,RET) From DIVPAYE
    If RET>0 Then
       # FQ74044-80569 - SEGAY 14/03/12 - Erreur sur champ FILTRE
       Call ECR_TRACE(MATRI-[F:TIM]COD-":"-mess(320,199,1)-[F:TIM]COD,1) From GESECRAN
       OK=0
    Endif
   Endif
   # Fin MABON
  Endif
  If OK :  Gosub RAZCP : Endif
 Next
Endif

Raz MATRI
# Traitement de resynchronisation classique
For [LNK]
 If MATRI<>"" & MATRI<>[F:VEP]EMP & ([F:ID]FLGMULCTR<>2 | CTR<>[F:VEP]CTRNUM)
  Call ECR_TRACE(num$(ANNEE)-MATRI-[M:DIA]TIM-":"-num$(NBRJOU),0) From GESECRAN
 Endif
 If MATRI="" | MATRI<>[F:VEP]EMP | CTR<>[F:VEP]CTRNUM
  MATRI  = [F:VEP]EMP
  CTR    = [F:VEP]CTRNUM
  DATMAT = [F:VEP]PYRDAT
  #LIPET - 12-05-2016 - X3-15388 - START
#  Gosub LECEMP From DEFTABLE
   Gosub LECEMP From WPDEFTABLE
  #LIPET - 12-05-2016 - X3-15388 - END
  Gosub TRTCONT
  NBRJOU=0
  # FQ74044 - MABON 13/02/12 - Ajout vérification du nouveau champ FILTRE
  If OK & ([F:TIM]FILTRE<>""  | [F:TIM]POP<>"") Then
   Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,MATRI,CTR,RET) From DIVPAYE
   If RET>0 Then
       # FQ74044-80569 - SEGAY 14/03/12 - Erreur sur champ FILTRE
       Call ECR_TRACE(MATRI-[F:TIM]COD-":"-mess(320,199,1)-[F:TIM]COD,1) From GESECRAN
       OK=0
   Endif
  Endif
  # Fin MABON
 Endif
 If OK
  Gosub INITCP
 Endif
Next
Call ECR_TRACE(num$(ANNEE)-MATRI-[M:DIA]TIM-":"-num$(NBRJOU),0) From GESECRAN
Call FERME_TRACE From LECFIC
Return

####################################
$RAZCP
GOK = 1
Trbegin [CNE]

 Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=[M:DIA]TIM & STRPER<=[F:VEP]PYRDAT & ENDPER>=[F:VEP]PYRDAT
#JASMI - 2014-09-04 - START
#LIPET - 12-05-2016 - X3-15388 - START
# If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#LIPET - 12-05-2016 - X3-15388 - END
  Filter [F:CNE] Where REFNUM=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM & TIM=[M:DIA]TIM
&                           & EMPLEASTR<=[F:VEP]PYRDAT & EMPLEAEND>=[F:VEP]PYRDAT
  Read [F:CNE]CNE0 Last
  Filter [F:CNE]
  If !fstat
    Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=[M:DIA]TIM & YEA=[F:CNE]YEA
  Endif
 Endif
#JASMI - 2014-09-04 - END
 Read[F:CNG]CNG0 First
 Filter [F:CNG]
 If !fstat
  #If [F:ID]FLGMULCTR=2
  Readlock [F:CNE]CNE0=[F:CNG]YEA;[F:VEP]EMP;[F:VEP]CTRNUM;[F:CNG]TIM
  #Else
  # Readlock [F:CNE]CNE0=[F:CNG]YEA;[F:VEP]EMP;"";[F:CNG]TIM
  #Endif
  If !fstat
   [F:CNE]NBRDAY = 0
   Rewrite [CNE]
   If fstat
    GOK = 0 : Call FSTA("CNE") From GLOCK : Goto AB_TR1
   Endif
  Endif
 Endif
Commit
Return

####################################
$TRTCONT
OK = 0
Call CONTROLE([F:VEP]EMP,[F:VEP]PYRDAT,[F:VEP]CTRNUM,[M:DIA]CRI,OKC,1) From DIVPAYE
If !OKC : Return : Endif
OK = 1
Return

####################################
$INITCP
Call DEBTRANS From GLOCK
If [M]FLGSTR=2
 Gosub TR2
Else
 Gosub TR1
Endif
Return

#Acquisition classique
####################################
$TR1
GOK = 1

Trbegin [CNE]
Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=[M:DIA]TIM & STRPER<=[F:VEP]PYRDAT & ENDPER>=[F:VEP]PYRDAT
#JASMI - 2014-09-04 - START
#LIPET - 12-05-2016 - X3-15388 - START
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#LIPET - 12-05-2016 - X3-15388 - END
 Filter [F:CNE] Where REFNUM=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM & TIM=[M:DIA]TIM
&                          & EMPLEASTR<=[F:VEP]PYRDAT & EMPLEAEND>=[F:VEP]PYRDAT
 Read [F:CNE]CNE0 Last
 Filter [F:CNE]
 If !fstat
  Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=[M:DIA]TIM & YEA=[F:CNE]YEA
 Endif
Endif
#JASMI - 2014-09-04 - END
Read[F:CNG]CNG0 First
Filter [F:CNG]
If !fstat
 If [F:CNG]CUM<>""
  Read [HSP]HSP3 = [F:VEP]BUL;[F:CNG]CUM;6
  If !fstat
   #If [F:ID]FLGMULCTR=2
    Readlock [F:CNE]CNE0=[F:CNG]YEA;[F:VEP]EMP;[F:VEP]CTRNUM;[F:CNG]TIM
   #Else
   # Readlock [F:CNE]CNE0=[F:CNG]YEA;[F:VEP]EMP;"";[F:CNG]TIM
   #Endif
    If fstat=1
    GOK = -1 : GLOCK = "$CNGEMP"-num$([F:CNG]YEA)-[F:VEP]EMP-[F:VEP]CTRNUM-[F:CNG]TIM : Goto ROLL_TR1
   Elsif fstat
    Raz [F:CNE]
    [F:CNE]YEA    = [F:CNG]YEA
    [F:CNE]REFNUM = [F:VEP]EMP
    #If [F:ID]FLGMULCTR=2
    [F:CNE]CTRNUM = [F:VEP]CTRNUM
    #Endif
    [F:CNE]TIM    = [F:CNG]TIM
    [F:CNE]NBRDAY = [F:HSP]AMT
#JASMI - 2014-09-04 - START
#LIPET - 12-05-2016 - X3-15388 - START
#    If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#LIPET - 12-05-2016 - X3-15388 - END
    #JASMI - 2014-10-29 - 2999 - START
#      Call CALC_LVE_DATES_KSA([F:CNG]TIM,[F:FCY]LEGCPY,[F:CNG]YEA,[F:VEP]EMP,[F:VEP]CTRNUM,
#&                             [F:CNE]EMPLEASTR,[F:CNE]EMPLEAEND,[F:CNE]EMPCYCSTR,[F:CNE]EMPCYCEND) From SUBCNEKSA
      Local Integer NEWYEA : [L]NEWYEA = 0
      Call CALC_LVE_DATES_KSA([F:CNG]TIM,[F:FCY]LEGCPY,[F:CNE]YEA,[F:VEP]EMP,[F:VEP]CTRNUM,
&                             [F:CNE]EMPLEASTR,[F:CNE]EMPLEAEND,[F:CNE]EMPCYCSTR,[F:CNE]EMPCYCEND,
&                             [F:VEP]PYRDAT,[L]NEWYEA) From SUBCNEKSA
      If [L]NEWYEA <> 0 Then : [F:CNE]YEA = [L]NEWYEA : Endif
    #JASMI - 2014-10-29 - 2999 - END
    Endif
#JASMI - 2014-09-04 - END
    Gosub CHER_SLDNEG
    Write [CNE]
   Else
    [F:CNE]NBRDAY += [F:HSP]AMT
    Rewrite [CNE]
   Endif
   If fstat | !GOK
    GOK = 0 : Call FSTA("CNE") From GLOCK : Goto AB_TR1
   Endif
   NBRJOU = [F:CNE]NBRDAY
   ANNEE  = [F:CNG]YEA
  Endif
 Endif
Endif
Commit
Return

#Lors d'une création d'enreg dans [CNE], on reporte le solde négatif de l'année précédente.
#Ce solde négatif est basculé dans le nb de congés pris sur nouvelle fiche.
$CHER_SLDNEG
#If [F:ID]FLGMULCTR=2
 Filter [F:CNE2] Where YEA<[F:CNE]YEA & REFNUM=[F:CNE]REFNUM & CTRNUM=[F:CNE]CTRNUM & TIM=[F:CNE]TIM
#Else
# Filter [F:CNE2] Where YEA<[F:CNE]YEA & REFNUM=[F:CNE]REFNUM & CTRNUM="" & TIM=[F:CNE]TIM
#Endif
Read [F:CNE2]CNE0 Last
Filter [F:CNE2]
If ! fstat & [F:CNE2]NBRDAY-[F:CNE2]NBRPRI<0
  [F:CNE]NBRPRI +=abs([F:CNE2]NBRDAY- [F:CNE2]NBRPRI)
Endif
Return

####################################
$AB_TR1
Rollback
Return

####################################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#Démarrage en cours d'année
###################################
$TR2
GOK = 1
Trbegin [CNE]

Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=[M:DIA]TIM & STRPER<=[F:VEP]PYRDAT & ENDPER>=[F:VEP]PYRDAT
#JASMI - 2014-09-04 - START
#LIPET - 12-05-2016 - X3-15388 - START
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#LIPET - 12-05-2016 - X3-15388 - END
 Filter [F:CNE] Where REFNUM=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM & TIM=[M:DIA]TIM
&                          & EMPLEASTR<=[F:VEP]PYRDAT & EMPLEAEND>=[F:VEP]PYRDAT
 Read [F:CNE]CNE0 Last
 Filter [F:CNE]
 If !fstat
   Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=[M:DIA]TIM & YEA=[F:CNE]YEA
 Endif
Endif
#JASMI - 2014-09-04 - END
Read[F:CNG]CNG0 First
Filter [F:CNG]
If !fstat
 For K=0 To 1
  Read [HSP]HSP3 = [F:VEP]BUL;[F:CNG]CUMACQ(K);6
  If !fstat : MTTACQ=[F:HSP]AMT : Else : MTTACQ=0 : Endif
  Read [HSP]HSP3 = [F:VEP]BUL;[F:CNG]CUMPRI(K);6
  If !fstat : MTTPRI=[F:HSP]AMT : Else : MTTPRI=0 : Endif
  If MTTACQ<>0 | MTTPRI<>0
   If K=0 : ANNEE=[F:CNG]YEA : Else :  ANNEE=[F:CNG]YEA-1 : Endif
 #  If [F:ID]FLGMULCTR=2
    Readlock [F:CNE]CNE0 = ANNEE;[F:VEP]EMP;[F:VEP]CTRNUM;[F:CNG]TIM
 #  Else
 #   Readlock [F:CNE]CNE0 = ANNEE;[F:VEP]EMP;"";[F:CNG]TIM
 #  Endif
   If fstat=1
    GOK = -1 : Break
   Elsif fstat
    Raz [F:CNE]
    [F:CNE]YEA    = ANNEE
    [F:CNE]REFNUM = [F:VEP]EMP
    #If [F:ID]FLGMULCTR=2
     [F:CNE]CTRNUM = [F:VEP]CTRNUM
    #Endif
    [F:CNE]TIM    = [F:CNG]TIM
#JASMI - 2014-09-04 - START
#LIPET - 12-05-2016 - X3-15388 - START
#    If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
    If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#LIPET - 12-05-2016 - X3-15388 - END
    #JASMI - 2014-10-29 - 2999 - START
#      Call CALC_LVE_DATES_KSA([F:CNG]TIM,[F:FCY]LEGCPY,[F:CNG]YEA,[F:VEP]EMP,[F:VEP]CTRNUM,
#&                             [F:CNE]EMPLEASTR,[F:CNE]EMPLEAEND,[F:CNE]EMPCYCSTR,[F:CNE]EMPCYCEND) From SUBCNEKSA
      Local Integer NEWYEA : [L]NEWYEA = 0
      Call CALC_LVE_DATES_KSA([F:CNG]TIM,[F:FCY]LEGCPY,[F:CNE]YEA,[F:VEP]EMP,[F:VEP]CTRNUM,
&                             [F:CNE]EMPLEASTR,[F:CNE]EMPLEAEND,[F:CNE]EMPCYCSTR,[F:CNE]EMPCYCEND,
&                             [0/0/0],[L]NEWYEA) From SUBCNEKSA
    #JASMI - 2014-10-29 - 2999 - END
    Endif
#JASMI - 2014-09-04 - END
    [F:CNE]NBRDAY = MTTACQ
    [F:CNE]NBRPRI = MTTPRI
    Write [CNE]
   Else
    [F:CNE]NBRDAY = MTTACQ
    [F:CNE]NBRPRI = MTTPRI
    Rewrite [CNE]
   Endif
   If fstat | !GOK
    GOK = 0 : Break
   Endif
   NBRJOU=[F:CNE]NBRDAY
   If K=0
    Call ECR_TRACE(num$(ANNEE)-MATRI-[M:DIA]TIM-":"-num$(NBRJOU),0) From GESECRAN
   Endif
  Endif
 Next
 If GOK = -1 : GLOCK = "$CNGEMP"-num$(ANNEE)-[F:VEP]EMP-[F:CNG]TIM : Goto ROLL_TR2 : Endif
 If GOK = 0 : Call FSTA("CNE") From GLOCK : Goto AB_TR2 : Endif
Endif
Commit
Return

####################################
$AB_TR2
Rollback
Return

####################################
$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

################################################################################
## Etiquettes écran INITCP
################################################################################
Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From DIVPAYE
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From DIVPAYE
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
Call AS_CPY(VALEUR) From DIVPAYE
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From DIVPAYE
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From DIVPAYE
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR
Call AS_FCY(VALEUR) From DIVPAYE
End

Subprog C_ALLSRV(VALEUR)
Variable Integer VALEUR
Call C_ALLSRV(VALEUR) From DIVPAYE
End

Subprog AS_SRV(VALEUR)
Variable Char     VALEUR
Call AS_SRV(VALEUR) From DIVPAYE
End

Subprog C_ALLPRF(VALEUR)
Variable Integer VALEUR
Call C_ALLPRF(VALEUR) From DIVPAYE
End

Subprog AS_PRF(VALEUR)
Variable Char  VALEUR
Call AS_PRF(VALEUR) From DIVPAYE
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
End

Subprog C_MATFIN(VALEUR)
Variable Char    VALEUR()
Call C_MATFIN(VALEUR) From DIVPAYE
End

Subprog C_TIM(VALEUR)
Variable Char    VALEUR()
#LIPET - 12-05-2016 - X3-15388 - START
#Call LECTURE("TIM",VALEUR,"") From CONTOBJ
Call LECTURE("HRTIM",VALEUR,GCURLEG) From CONTOBJ
#LIPET - 12-05-2016 - X3-15388 - END
If [F:TIM]CATTIM<>3
#LIPET - 12-05-2016 - X3-15388 - START
# GMESSAGE = mess(105,709,1) : # Type d'événement incorrect
  GMESSAGE = mess(105,10709,1) : # Type d'événement incorrect
#LIPET - 12-05-2016 - X3-15388 - END
 mkstat = 2 : End
Endif
End

Subprog AM_FLGSTR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M]15 : Grizo [M]15
Else
 Actzo [M]15
 #LIPET - START
 Effzo [M:DIA]DATPYR
 #LIPET - END
Endif
End

Subprog AS_DATPYR(VALEUR)
Variable Date    VALEUR
If [M]FLGSTR=2
#JASMI - 2017-01-05 - X3-15388 - START
# VALEUR=eomonth(GMOIPAY)
  If VALEUR=[0/0/0]
    VALEUR=eomonth(GMOIPAY)
  Endif
#JASMI - 2017-01-05 - X3-15388 - END
Else

 mkstat=1 : End
Endif
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#LIPET - 12-05-2016 - X3-15388 - START
GCURLEG = VALEUR

If VALEUR=""
    [M]ALLPRF=2
    Diszo [M]ALLPRF
Else
    Actzo [M]ALLPRF
Endif
#LIPET - 12-05-2016 - X3-15388 - END
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
#LIPET - 12-05-2016 - X3-15388 - START
If clalev([F:CPY1])=0  : Local File COMPANY [CPY1] : Endif

If VALEUR <> ""
  Filter [CPY1] Where CPY=VALEUR
  Read [CPY1] First
  Filter [CPY1]
  If !fstat
   GCURLEG = [CPY1]LEG
  Endif
Endif
#LIPET - 12-05-2016 - X3-15388 - END
End

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
  GCURLEG = VALEUR
End


