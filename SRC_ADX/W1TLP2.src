#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TLP2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:48"
A_USER  = "DOC"
A_STAMP = "20181109230648"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "ITMFLDNBR"
  If [M]ITMFLDNBR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask TLP2 [TLP2]
Gosub HORODAT
Local Inpbox "TLP2" From GFONCTION At A_STAMP With A_WINDPREV Mask [TLP2] As [SIM_]
Grizo [TLP2]5
Grizo [TLP2]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [TLP2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=74 : Y1(1)=3 : Y2(1)=24
Return

$ON_SEAKEY
Onevent INIT_AREA Call D_SEAKEY(zc) From W1TLP2
Onevent BEFORE_INPUT Call AS_SEAKEY(zc) From W1TLP2
Onevent CONTROL Call C_SEAKEY(zc) From W1TLP2
Return

Subprog D_SEAKEY(VALEUR)
Variable Integer VALEUR
If varinit([M]SEAKEY,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SEAKEY(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_SEAKEY(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SEAKEY" : GZNUM = 255 : Endif
Gosub _AFF
End

$ON_ITMFLD
Onevent CONTROL Call C_ITMFLD(zc) From W1TLP2
Onevent BEFORE_INPUT Call AS_ITMFLD(zc) From W1TLP2
Return

Subprog AS_ITMFLD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_ITMFLD(zc) From W1TLP2
Gosub _AFF
End

Subprog C_ITMFLD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ITMFLD" : GZNUM = 14859 : Endif
If !mkstat
 ## Action STD
 Call C_ITMFLD(VALEUR) From SUBTLP
 If mkstat : GERR = 1 : GZONE = "ITMFLD" : GZNUM = 14859 : Endif
Endif
Gosub _AFF
End

Subprog S_ITMFLD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELTBL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELTBL"
 PARMSK(1) = "ITMMASTER"
 PARMSK(2) = [M:TLP0]CFGLIN
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELTBL","CFGLIB","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_INDFLD
Onevent BEFORE_INPUT Call AS_INDFLD(zc) From W1TLP2
Onevent CONTROL Call C_INDFLD(zc) From W1TLP2
Return

Subprog AS_INDFLD(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action CFGASIND
Call CFGASIND(13,[M]ITMFLD(nolign-1)) From CFGLIB
If mkstat=2
 [M]INDFLD(INDIC) = VALEUR
 Affzo INDFLD(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_INDFLD(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "INDFLD" : GZNUM = 773 : Endif
If !mkstat
 ## Action CFGCTRIND
 Call CFGCTRIND(VALEUR,13,[M]ITMFLD(nolign-1)) From CFGLIB
 If mkstat : GERR = 1 : GZONE = "INDFLD" : GZNUM = 773 : Endif
Endif
Gosub _AFF
End

$CHG_STY
Return


