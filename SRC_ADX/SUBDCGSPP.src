#CHSUL - 2018-02-05 - X3-75456 START
Funprog VALIDATE_SPP_DATES(START_DATE, END_DATE, ABSENCE_CODE)
  Value Date START_DATE, END_DATE
  Value Char ABSENCE_CODE
  Local Integer VALID, INVALID

  VALID = 1
  INVALID = 0

  If ABSENCE_CODE <> "SPP" Then: End VALID: Endif
  If START_DATE = [0/0/0] or END_DATE = [0/0/0] Then: End VALID: Endif
  # Includes the start as day one
  If START_DATE + 6 = END_DATE or START_DATE + 13 = END_DATE Then: End VALID: Endif

  GMESSAGE = mess(56,11800,1)

End INVALID
