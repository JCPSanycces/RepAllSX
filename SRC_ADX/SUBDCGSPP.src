#  Effzo [M:DCG1]SPPREA
#  Effzo [M:DCG1]SPPPRO
#  Effzo [M:DCG1]SPPQUADAT
#  Effzo [M:DCG1]SPPAWE
#
##ALHAR - 2017-09-21 X3-49262 START
#  #Effzo [M:DCG1]SXPSP1
##ALHAR - 2017-09-21 X3-49262 END
##ALHAR - 2017-11-15 X3-59938 START
#    [M:DCG1]SPPELI = 2
#    [M:DCG1]SPPPRO = 2
#    Affzo [M:DCG1]SPPELI
#    Affzo [M:DCG1]SPPPRO
##ALHAR - 2017-11-15 X3-59938 END

Endif
[M:DCG1]SPPRELPER = num$([M:DCG1]SPPRPSTR)+" - "+num$([M:DCG1]SPPRPEND) : Affzo [M:DCG1]SPPRELPER
Return
#MASHI - 2017-09-08 X3-54387 END

#MASHI - 2017-09-18 X3-49267 START
Subprog AM_TIM(VALEUR)
Variable Char    VALEUR()

  #SAVAN - 2018/02/27 - part of X3-78794 to block INSERT entries in DCG - start
  If clalev([DCG_BLK])=0 : Local File DEMCONGE [DCG_BLK] : Endif
  Filter [DCG_BLK] Where [DCG_BLK]STRDAT>[M:DCG1]STRDAT(nolign-1) and [DCG_BLK]TIM=VALEUR and [DCG_BLK]REFNUM = [M:DCG1]REFNUM and [DCG_BLK]CTRNUM = [M:DCG1]CTRNUM(nolign-1)
&  and ([F:DCG_BLK]STA=1 | [F:DCG_BLK]STA=2 | [F:DCG_BLK]STA=3 ) and [DCG_BLK]UID>0
  Read [DCG_BLK] First
  If rowcount([DCG_BLK])<>0
   #SAVAN message that there is another transaction before --> Block and end
   #GMESSAGE = mess(2,11828,1)
   Call ERREUR(mess(21,11828,1)) From GESECRAN
   [V]GOK=0
   mkstat = 2
   End
  Endif
  Filter [DCG_BLK]
  #SAVAN - 2018/02/27 - part of X3-78794 to block INSERT entries in DCG - end
  Gosub CHECKSAVESTATUS From SUBDCGSPP
  Gosub LOADSPP From SUBDCGSPP

  #[M:DCG1]AVEERN(nolign-1) = [M:DCG1]SPPAWE

  Affzo [M:DCG1]AVEERN(nolign-1)

End

$CHECKSAVESTATUS
Local Integer K

  For [L]K = 0 To [M:DCG1]NBLIG
    If [L]K <> nolign-1
      If [M:DCG1]UID([L]K) = 0 and [M:DCG1]SXPCAT([L]K) = 'SPP'
        #TODO
        Infbox "You have unsaved SPP transactions on the grid - please save grid before entering new SPP transactions"
        #mkstat = 2
      Endif
    Endif
  Next

Return
#MASHI - 2017-09-18 X3-49267 END

