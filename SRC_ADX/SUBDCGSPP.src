End

$SPP_RELEVANT_PERIOD
Local Date SUBRELPERSTR #: SUBRELPERSTR = QUADAT + 7 - 56
Local Date SUBRELPEREND #: SUBRELPEREND = QUADAT + 7 - 1
Local Char VPERCOD

If clalev([F:HRCTR9])=0 : Local File EMPLOCTR  [HRCTR9] : Endif
#If clalev([F:HRPEOH9])=0 : Local File HRPEOHEA  [HRPEOH9] : Endif
If clalev([F:HRPEOD9])=0 : Local File HRPEODET  [HRPEOD9] : Endif

#MASHI - 2017-09-08 X3-54202 START
#Filter [HRCTR9] Where CTRNUM = [M:DCG1]CTRNUM
Filter [HRCTR9] Where CTRNUM = [M:DCG1]CTRNUM(DCGUKINBLIG)
#MASHI - 2017-09-08 X3-54202 START
Read [HRCTR9] First
Filter [HRCTR9]
If !fstat
  [L]VPERCOD = [F:HRCTR9]PERCOD
Endif

#Filter [HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT <= QUADAT + 7
Filter [HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT <= [M:DCG1]SPPQUADAT + 7
Read [HRPEOD9] Last
Filter [HRPEOD9]
If !fstat
  [L]SUBRELPEREND = [F:HRPEOD9]PYRDAT
#MASHI - 2017-10-05 X3-58585 START
  [L]SUBRELPERSTR = ([F:HRPEOD9]PYRDAT - 56) + 1
#MASHI - 2017-10-05 X3-58585 END
Endif

[M:DCG1]SPPRPSTR = [L]SUBRELPERSTR : Affzo [M:DCG1]SPPRPSTR
[M:DCG1]SPPRPEND = [L]SUBRELPEREND : Affzo [M:DCG1]SPPRPEND
[M:DCG1]SPPRELPER = num$([L]SUBRELPERSTR)+" - "+num$([L]SUBRELPEREND) : Affzo [M:DCG1]SPPRELPER

#################
#MASHI - 2017-09-08 X3-54202 START
#Endif
#MASHI - 2017-09-08 X3-54202 END
Return


$SPP_LATEST_LEAVE_DATE
Local Integer SPP_DTLLD
Local Integer SPP_WKP_SR
Local Date SUBACTDOB
Local Date SUBEXPCON

  [L]SPP_DTLLD = int(func SUBDCGUKI.SETVARIABLE("SPP_DTLLD",[M:DCG1]STRDAT(DCGUKINBLIG)))
  [L]SPP_WKP_SR = int(func SUBDCGUKI.SETVARIABLE("SPP_WKP_SR",[M:DCG1]STRDAT(DCGUKINBLIG)))
  [L]SUBACTDOB = (VALEUR + [L]SPP_DTLLD) - [L]SPP_WKP_SR * 7
  [L]SUBEXPCON = ([M:DCG1]SPPEXPCON + [L]SPP_DTLLD) - [L]SPP_WKP_SR * 7

  If [L]SUBACTDOB >= [L]SUBEXPCON
    [M:DCG1]SPPLATDAT = [L]SUBACTDOB+1
  Else
    [M:DCG1]SPPLATDAT = [L]SUBEXPCON+1
  Endif

  Affzo [M:DCG1]SPPLATDAT

Return


Subprog SPPCAL(LVEDAT,RETDAT,AWE)
Value Date LVEDAT
Value Date RETDAT
Value Decimal AWE

Local Decimal TOTEARN
Local Decimal SUBEAR
Local Char FREQ, PERCODE
Local Integer SPP_WKP_SR
Local Integer SPP_SR_PER
Local Decimal SPP_SR_AMT
#Local Decimal SMP_MAWE
Local Decimal WEEKEARN
Local Date PERDAT
Local Integer LIGNUM
#MASHI - 2017-11-16 X3-59443 START
Local Integer SPP_DTLLD
#MASHI - 2017-11-16 X3-59443 END


 #MASHI - 2017-09-18 X3-49259 START
#If [M:DCG1]SPPDECREC < 2
##  Infbox mess(14,11828,1)
#  [M:DCG1]SPPELI = 1
#  [M:DCG1]SSPSTA(DCGUKINBLIG) = 1
#  [M:DCG1]SPPREA =  mess(14,11828,1)
#  Affzo [M:DCG1]SPPELI
#  Affzo [M:DCG1]SPPREA
#  Affzo [M:DCG1]SSPSTA(DCGUKINBLIG)
#   [M:DCG1]SPPREA = "N" : Affzo [M:DCG1]SPPREA, ZSPPREA

#MASHI - 2017-09-18 X3-49259 END
#Elsif [L]LVEDAT = [0/0/0]

#TODO - Change hardcoded msg
#   mkstat = 2 : GERR = 1 :  GMESSAGE = mess(11,11828,1)
#Infbox mess(11,11828,1)
#Else
  [L]SPP_WKP_SR = int(func SUBDCGUKI.SETVARIABLE("SPP_WKP_SR",[M:DCG1]STRDAT(DCGUKINBLIG)))
  [L]SPP_SR_PER = int(func SUBDCGUKI.SETVARIABLE("SPP_SR_PER",[M:DCG1]STRDAT(DCGUKINBLIG)))
#MASHI - 2017-09-08 X3-54202 START
#  Local Integer SPP_SR_AMT : SPP_SR_AMT = int(func SUBDCGUKI.SETVARIABLE("SPP_SR_AMT",[M:DCG1]STRDAT(DCGUKINBLIG)))
  [L]SPP_SR_AMT = func SUBDCGUKI.SETVARIABLE("SPP_SR_AMT",[M:DCG1]STRDAT(DCGUKINBLIG))
#  [L]SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(DCGUKINBLIG))
#MASHI - 2017-09-08 X3-54202 END
#MASHI - 2017-11-16 X3-59443 START
#   SPP_DTLLD = 56
    [L]SPP_DTLLD = int(func SUBDCGUKI.SETVARIABLE("SPP_DTLLD",[M:DCG1]STRDAT(DCGUKINBLIG)))
    If [L]RETDAT = [0/0/0]
      If [M:DCG1]SPPACTDOB <> [0/0/0]
        [L]RETDAT = [M:DCG1]SPPACTDOB + [L]SPP_DTLLD
      Else
        [L]RETDAT = [M:DCG1]SPPEXPCON + [L]SPP_DTLLD
      Endif
    Endif
#MASHI - 2017-11-16 X3-59443 END

  Call GETCTR([L]FREQ,[L]PERCODE,"") From SUBDCGSMP
#MASHI - 2017-09-08 X3-54387 START
#  SUBEAR = func GETAWE([M:DCG1]REFNUM,[M:DCG1][M:DCG1]SPPRPSTR,[M:DCG1]SPPRPEND)
  #SUBEAR = func SUBDCGUKI.AVERAGE_EARNING([M:DCG1]REFNUM,[M:DCG1]SPPRPSTR,[M:DCG1]SPPRPEND)
  #If   [M:DCG1]AVEERN(DCGUKINBLIG) = 0
    #[M:DCG1]AVEERN(DCGUKINBLIG) = SUBEAR
  #Endif
  #[M:DCG1]SPPAWE = [M:DCG1]AVEERN(DCGUKINBLIG) : Affzo [M:DCG1]SPPAWE
  #[M:DCG1]SPPAWE = SUBEAR : Affzo [M:DCG1]SPPAWE

#  If [L]AWE > [L]SMP_MAWE
#MASHI - 2017-09-08 X3-54387 END


##### in these for loops add these values to the payments grid
  If !clalev([F:HRPEOD]) : Local File HRPEODET [HRPEOD] : Endif
#MASHI - 2017-11-16 X3-59443 START
#   PERDAT = [M:DCG1]SPPLEADAT + 1
   [L]PERDAT = [L]LVEDAT
#MASHI - 2017-11-16 X3-59443 END
   [L]LIGNUM = 0

  For J = 1 To [L]SPP_WKP_SR
#MASHI - 2017-11-16 X3-59443 START
      If [L]RETDAT <> [0/0/0]
        If [L]PERDAT > [L]RETDAT : Break : Endif
      Endif
#MASHI - 2017-11-16 X3-59443 END
    [L]WEEKEARN = [L]SUBEAR / 100 * [L]SPP_SR_PER
#MASHI - 2017-09-08 X3-54202 START
#    Filter [HRPEOD] Where PERCOD = PERCODE and PERSTR >= PERDAT and PEREND <= PERDAT
    Filter [HRPEOD] Where PERCOD = [L]PERCODE and PERSTR <= [L]PERDAT and PEREND >= [L]PERDAT
#MASHI - 2017-09-08 X3-54202 END
    Read [HRPEOD] First
    Filter [HRPEOD]
    If !fstat
      #get the tax year and period i month here
#MASHI - 2017-09-08 X3-54202 START
      [M:DCG1]SPPWEKSTR(LIGNUM) = [L]PERDAT
      [M:DCG1]SPPTAXYEA(LIGNUM) = [HRPEOD]PERYEA
      [M:DCG1]SPPTAXPER(LIGNUM) = [HRPEOD]PERNUM
      [M:DCG1]SPPFREQUE(LIGNUM) = [L]FREQ
      [M:DCG1]SPPAMT(LIGNUM) = [L]SPP_SR_AMT
#      [M:DCG1]SPPTAXYEA(LIGNUM) = [HRPEOD]PERYEA
#      [M:DCG1]SPPTAXPER(LIGNUM) = [HRPEOD]PERMON
#      [M:DCG1]SPPFREQUE(LIGNUM) = [HRPEOD]FREQ
#      [M:DCG1]SPPAMT(LIGNUM) = WEEKEARN
#MASHI - 2017-09-08 X3-54202 END
       [M:DCG1]SPPPAI(LIGNUM) = "No"
    Endif
    [L]PERDAT = [L]PERDAT +7
    [L]LIGNUM += 1
  Next J
#ALHAR - 2017-11-16 X3-59443 START
  #AHAssign "[M:DCG1]NBSPPPAY" With LIGNUM
  #AHAffzo [M:DCG1]NBSPPPAY
  [M:DCG1]NBSPPPAY = [L]LIGNUM
  Affzo [M:DCG1]80
#ALHAR - 2017-11-16 X3-59443 END
#MASHI - 2017-09-08 X3-54202 START
#    [M:DCG1]SPPREA = '' : Affzo [M:DCG1]SPPREA
#    [M:DCG1]SPPELI = 2 : Affzo [M:DCG1]SPPELI
#    [M:DCG1]SSPSTA(DCGUKINBLIG) = 2: Affzo [M:DCG1]SSPSTA(DCGUKINBLIG)


##### in these for loops add these values to the payments grid
#Else
#set reason here
#    [M:DCG1]SPPREA = mess(8,11828,1) : Affzo [M:DCG1]SPPREA
#    [M:DCG1]SPPELI = 1 : Affzo [M:DCG1]SPPELI
#    [M:DCG1]SPPREA = "E" : Affzo [M:DCG1]SPPREA, ZSPPREA
#    [M:DCG1]SSPSTA(nolign-1) = 1: Affzo [M:DCG1]SSPSTA(nolign-1)
#    [M:DCG1]SSPSTAREA(nolign-1) = "E": Affzo [M:DCG1]SSPSTAREA(nolign-1)

#Endif
#MASHI - 2017-09-08 X3-54202 END

#Endif

  #JOJAC - 2017-10-16 - X3-15908 - START
  Grizo [M:DCG1]NBSPPPAY
  Grizo [M:DCG1]SPPWEKSTR
  Grizo [M:DCG1]SPPTAXYEA
  Grizo [M:DCG1]SPPTAXPER
  Grizo [M:DCG1]SPPFREQUE
  Grizo [M:DCG1]SPPAMT
  Grizo [M:DCG1]SPPPAI
  #JOJAC - 2017-10-16 - X3-15908 - END
End

#MASHI - 2017-09-08 X3-54202 START
Subprog AVANT_NBLIG
  Call SHOWHIDE(nolign-1) From SUBDCGUKI
#  Local Char DES
#  Call LECTEXTRA([L]DES,"ATABDIV","LNGDES","10408",[M:DCG1]SSPSTAREA(nolign-1)) From ATEXTRA : Affzo [M:DCG1]SSPEXC
#  [M:DCG1]SPPEXC      = [L]DES                            : Affzo [M:DCG1]SPPEXC
#  [M:DCG1]SPPELI      = [M:DCG1]SSPSTA(nolign-1)         : Affzo [M:DCG1]SPPELI

  #ALHAR - 08-02-2018 X3-76140 - start
  Gosub LOADSPP From SUBDCGSPP
  If [M:DCG1]SPPLEADAT <> [0/0/0] and [M:DCG1]SPPAWE <> 0.00
    Call SPPCAL ([M:DCG1]SPPLEADAT,[M:DCG1]SPPRETDAT,[M:DCG1]SPPAWE)
  Endif
  #ALHAR - 08-02-2018 X3-76140 - end

End
#MASHI - 2017-09-08 X3-54202 END

#MASHI - 2017-09-08 X3-54387 START

$LOADSPP
If !clalev([F:SPPLVE]) : Local File UKSPPLVE [SPPLVE] : Endif
#Infbox num$([M:DCG1]UID(nolign-1))
#Filter [SPPLVE] Where REFNUM = [M:DCG1]REFNUM and CTRNUM = [M:DCG1]CTRNUM(nolign-1) and UID = [M:DCG1]UID(nolign-1)
#Read [SPPLVE] First
Read [SPPLVE]SPPLVE1 = [M:DCG1]UID(nolign-1)
If !fstat
  [M:DCG1]SPPDECREC = [SPPLVE]SPPDECREC : Affzo [M:DCG1]SPPDECREC
  [M:DCG1]SPPEXC    = [SPPLVE]SPPEXC    : Affzo [M:DCG1]SPPEXC
  [M:DCG1]SPPEXPDOB = [SPPLVE]SPPEXPDOB : Affzo [M:DCG1]SPPEXPDOB
  [M:DCG1]SPPLEADAT = [SPPLVE]SPPLEADAT : Affzo [M:DCG1]SPPLEADAT
  [M:DCG1]SPPACTDOB = [SPPLVE]SPPACTDOB : Affzo [M:DCG1]SPPACTDOB
#  [M:DCG1]SPPEARDAT = [SPPLVE]SPPEARDAT : Affzo [M:DCG1]SPPEARDAT
  [M:DCG1]SPPRETDAT = [SPPLVE]SPPRETDAT : Affzo [M:DCG1]SPPRETDAT
  [M:DCG1]SPPQUADAT = [SPPLVE]SPPQUADAT : Affzo [M:DCG1]SPPQUADAT
  [M:DCG1]SPPEMPDAT = [SPPLVE]SPPEMPDAT : Affzo [M:DCG1]SPPEMPDAT
  [M:DCG1]SPPRPSTR  = [SPPLVE]SPPRPSTR  : Affzo [M:DCG1]SPPRPSTR
  [M:DCG1]SPPRPEND  = [SPPLVE]SPPRPEND  : Affzo [M:DCG1]SPPRPEND
  [M:DCG1]SPPEXPCON = [SPPLVE]SPPEXPCON : Affzo [M:DCG1]SPPEXPCON
#  [M:DCG1]SPPWEEPER = [SPPLVE]SPPWEEPER : Affzo [M:DCG1]SPPWEEPER
  [M:DCG1]SPPLATDAT = [SPPLVE]SPPLATDAT : Affzo [M:DCG1]SPPLATDAT
#  [M:DCG1]SPPLATRET = [SPPLVE]SPPLATRET : Affzo [M:DCG1]SPPLATRET
  [M:DCG1]SPPELI    = [SPPLVE]SPPELI    : Affzo [M:DCG1]SPPELI
  [M:DCG1]SPPREA    = [SPPLVE]SPPREA    : Affzo [M:DCG1]SPPREA
  [M:DCG1]SPPPRO    = [SPPLVE]SPPPRO    : Affzo [M:DCG1]SPPPRO
  [M:DCG1]SPPQUADAT = [SPPLVE]SPPQUADAT : Affzo [M:DCG1]SPPQUADAT
  [M:DCG1]SPPAWE    = [SPPLVE]SPPAWE    : Affzo [M:DCG1]SPPAWE

#ALHAR - 2017-09-21 X3-49262 START
  Effzo [M:DCG1]SXPSP1
#  If [M:DCG1]SPPREA = mess(16,11828,1)
#    [M:DCG1]SXPSP1    = mess(17,11828,1)    : Affzo [M:DCG1]SXPSP1
#  Endif
#ALHAR - 2017-09-21 X3-49262 END

Else
#ALHAR - 2017-11-30 X3-66781 START
#  Effzo [M:DCG1]SPPDECREC
#  Effzo [M:DCG1]SPPEXC
#  Effzo [M:DCG1]SPPEXPDOB
#  Effzo [M:DCG1]SPPLEADAT
#  Effzo [M:DCG1]SPPACTDOB
##  Effzo [M:DCG1]SPPEARDAT
#  Effzo [M:DCG1]SPPRETDAT
#  Effzo [M:DCG1]SPPQUADAT
#  Effzo [M:DCG1]SPPEMPDAT
#  Effzo [M:DCG1]SPPRPSTR
#  Effzo [M:DCG1]SPPRPEND
#  Effzo [M:DCG1]SPPEXPCON
##  Effzo [M:DCG1]SPPWEEPER
#  Effzo [M:DCG1]SPPLATDAT
##  Effzo [M:DCG1]SPPLATRET
