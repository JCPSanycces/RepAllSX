##    [SPPLVE]SPPEXPDOB = [M:DCG1]SPPEXPDOB
##    [SPPLVE]SPPLEADAT = [M:DCG1]SPPLEADAT
##    [SPPLVE]SPPACTDOB = [M:DCG1]SPPACTDOB
##    [SPPLVE]SPPRETDAT = [M:DCG1]SPPRETDAT
##    [SPPLVE]SPPQUADAT = [M:DCG1]SPPQUADAT
##    [SPPLVE]SPPEMPDAT = [M:DCG1]SPPEMPDAT
##    [SPPLVE]SPPEXPCON = [M:DCG1]SPPEXPCON
##    [SPPLVE]SPPLATDAT = [M:DCG1]SPPLATDAT
###MASHI - 2017-09-08 X3-54387 START
##    [SPPLVE]SPPAWE     = [M:DCG1]SPPAWE

  [M:DCG1]SPPDECREC = [SPPLVE]SPPDECREC : Affzo [M:DCG1]SPPDECREC
  [M:DCG1]SPPEXC    = [SPPLVE]SPPEXC    : Affzo [M:DCG1]SPPEXC
  [M:DCG1]SPPEXPDOB = [SPPLVE]SPPEXPDOB : Affzo [M:DCG1]SPPEXPDOB
  [M:DCG1]SPPLEADAT = [SPPLVE]SPPLEADAT : Affzo [M:DCG1]SPPLEADAT
  [M:DCG1]SPPACTDOB = [SPPLVE]SPPACTDOB : Affzo [M:DCG1]SPPACTDOB
  [M:DCG1]SPPRETDAT = [SPPLVE]SPPRETDAT : Affzo [M:DCG1]SPPRETDAT
  [M:DCG1]SPPQUADAT = [SPPLVE]SPPQUADAT : Affzo [M:DCG1]SPPQUADAT
  [M:DCG1]SPPEMPDAT = [SPPLVE]SPPEMPDAT : Affzo [M:DCG1]SPPEMPDAT
  [M:DCG1]SPPPRPSTR = [SPPLVE]SPPPRPSTR : Affzo [M:DCG1]SPPPRPSTR
  [M:DCG1]SPPPRPEND = [SPPLVE]SPPPRPEND : Affzo [M:DCG1]SPPPRPEND
  [M:DCG1]SPPEXPCON = [SPPLVE]SPPEXPCON : Affzo [M:DCG1]SPPEXPCON
  [M:DCG1]SPPLATDAT = [SPPLVE]SPPLATDAT : Affzo [M:DCG1]SPPLATDAT
  [M:DCG1]SPPELI    = [SPPLVE]SPPELI    : Affzo [M:DCG1]SPPELI
  [M:DCG1]SPPREA    = [SPPLVE]SPPREA    : Affzo [M:DCG1]SPPREA
  [M:DCG1]SPPPRO    = [SPPLVE]SPPPRO    : Affzo [M:DCG1]SPPPRO
#MASHI - 2017-09-08 X3-54387 START
  [M:DCG1]SPPAWE    = [SPPLVE]SPPAWE    : Affzo [M:DCG1]SPPAWE
#MASHI - 2017-09-08 X3-54387 END
Endif
Return

Funprog SPP_SPLIT(DCG_ID, SUB_TYPE)
Value Integer DCG_ID
Value Char SUB_TYPE
Local Decimal RESULT_STAT
Local Integer SUB_TYPE_INDEX

  RESULT_STAT=1 #initialize to correct
  If clalev([F:DCG_T])=0      : Local File DEMCONGE    [DCG_T] : Endif

  #get entry of absense record
  Read [F:DCG_T]DCG2 = DCG_ID
  If fstat
    [L]RESULT_STAT=0
    End [L]RESULT_STAT
  Endif

  #check if sub type exist on entry and get index
  [L]SUB_TYPE_INDEX=find(SUB_TYPE,[F:DCG_T]LVESUBTYP(0..(dim([F:DCG_T]LVESUBTYP)-1)))
  If [L]SUB_TYPE_INDEX=0
    End [L]RESULT_STAT
  Endif

  Local Integer A : A=0
    If [F:DCG_T]LVESUBBAL([L]SUB_TYPE_INDEX-1) <> 0
      #ALHAR - 27/11/2017 - X3-59938 - Start
      #If [M:DCG1]SPPPRO = 1
      If [M:DCG1]SPPPRO = 1 | [M:DCG1]SPPEXC <> ""
      #ALHAR - 27/11/2017 - X3-59938 - End

        [F:DCG_T]LVESUBRAT([L]SUB_TYPE_INDEX-1)=2
        Assign "[M:DCG1]LVESUBRAT" + num$([L]SUB_TYPE_INDEX-1) + "(" + num$(GPARENT_NOLIGN) + ")" With 2
      Else
        [F:DCG_T]LVESUBRAT([L]SUB_TYPE_INDEX-1)=1
        Assign "[M:DCG1]LVESUBRAT" + num$([L]SUB_TYPE_INDEX-1) + "(" + num$(GPARENT_NOLIGN) + ")" With 1
      Endif
    Endif

    Rewrite [F:DCG_T]
    If fstat
      [L]RESULT_STAT=0
      End [L]RESULT_STAT
    Endif

End RESULT_STAT
