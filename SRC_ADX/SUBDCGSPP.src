#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA SOURCE REMERGE
Subprog SHOWHIDESPP( ALT)
Value Char ALT
  Chgfmt [M:DCG1]SXPCAT          With ALT+"K:4X"
  Chgfmt [M:DCG1]SPPDECREC       With ALT+"LA:1"
  Chgfmt [M:DCG1]SPPEXC          With ALT+"K:1X"
  Chgfmt [M:DCG1]SPPEXPDOB       With ALT+"D:"+GFMDAT4
#  Chgfmt [M:DCG1]SSPLEADAT       With ALT+"D:"+GFMDAT4
  Chgfmt [M:DCG1]SPPACTDOB       With ALT+"D:"+GFMDAT4
  Chgfmt [M:DCG1]SPPRETDAT       With ALT+"D:"+GFMDAT4
  Chgfmt [M:DCG1]SPPQUADAT       With ALT+"D:"+GFMDAT4
  Chgfmt [M:DCG1]SPPEMPDAT       With ALT+"D:"+GFMDAT4
  Chgfmt [M:DCG1]SPPPRPSTR       With ALT+"D:"+GFMDAT4
  Chgfmt [M:DCG1]SPPPRPEND       With ALT+"D:"+GFMDAT4
  Chgfmt [M:DCG1]SPPEXPCON       With "-D:"+GFMDAT4
  Chgfmt [M:DCG1]SPPLATDAT       With ALT+"D:"+GFMDAT4
  Chgfmt [M:DCG1]SPPELI          With ALT+"LA:1"
  Chgfmt [M:DCG1]SPPREA          With ALT+"K:30X"
  Chgfmt [M:DCG1]SPPPRO          With ALT+"LA:1"
  Chgfmt [M:DCG1]SPPRELPER       With ALT+"K:30X"
  Chgfmt [M:DCG1]SPPRPSTR        With "-D:"+GFMDAT4
  Chgfmt [M:DCG1]SPPRPEND        With "-D:"+GFMDAT4
  Chgfmt [M:DCG1]SPPLEADAT       With ALT+"D:"+GFMDAT4

  Chgfmt [M:DCG1]SPPTAXYEA       With ALT+"D:"+GFMDAT4
  Chgfmt [M:DCG1]SPPTAXPER       With ALT+"N:4"
  Chgfmt [M:DCG1]SPPFREQUE       With ALT+"K:9X"
  Chgfmt [M:DCG1]SPPAMT          With ALT+"Nz:11.2"
#ALHAR - 2018-03-03 X3-77637 START
#  Chgfmt [M:DCG1]SPPPAI          With ALT+"K:3X"
  Chgfmt [M:DCG1]SPPPAI          With "-K:3X"
#ALHAR - 2018-03-03 X3-77637 END
  Chgfmt [M:DCG1]NBSPPPAY        With ALT+"N:4"
  Chgfmt [M:DCG1]SPPAWE          With ALT+"N:9.2"
#MASHI - 2017-09-08 X3-54387 START
  Chgfmt [M:DCG1]SPP          With ALT+"Nz:9.5"
#MASHI - 2017-09-08 X3-54387 END


#ALHAR - 2017-09-21 X3-49262 START
  Chgfmt [M:DCG1]SXPSP1          With ALT+"K:30X"
#ALHAR - 2017-09-21 X3-49262 END

#ALHAR - 2017-11-30 X3-66781 START
  If ALT = ""
    [M:DCG1]SPPELI = 2
    [M:DCG1]SPPPRO = 2
    Affzo [M:DCG1]SPPELI
    Affzo [M:DCG1]SPPPRO
  Endif
#ALHAR - 2017-09-21 X3-66781 END

End

Subprog C_SPPLEADAT(VALEUR)
Variable Date    VALEUR
#MASHI - 2017-11-16 X3-59443 START
Local Decimal SMP_MAWE

  #SMP_MAWE=113
  [L]SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(DCGUKINBLIG))
#MASHI - 2017-11-16 X3-59443 END

  If [M:DCG1]SPPACTDOB <> [0/0/0]
    If VALEUR < [M:DCG1]SPPACTDOB
      mkstat = 2 : GERR = 1 :  GMESSAGE = mess(9,11828,1)
    Endif
  Endif

  If [M:DCG1]SPPLATDAT <> [0/0/0]
#MASHI - 2017-11-16 X3-59443 START
#    If VALEUR > [M:DCG1]SPPLATDAT
    If VALEUR > [M:DCG1]SPPLATDAT
      If VALEUR <= [M:DCG1]SPPLATDAT + 7
       Infbox mess(18,11828,1)
      Else
       mkstat = 2 : GERR = 1 :  GMESSAGE = mess(10,11828,1)
      Endif
#MASHI - 2017-11-16 X3-59443 END
    Endif
  Endif
  #MASHI - 2017-11-16 X3-59443 START
  If [M:DCG1]SPPEMPDAT <> [0/0/0]
  Call SPP_ELIGIBILITY ([M:DCG1]SPPAWE, [M:DCG1]SPPEMPDAT, [M:DCG1]SPPDECREC  )
  Endif
#MASHI - 2017-11-16 X3-59443 END

#MASHI - 2017-11-16 X3-59443 START
  If VALEUR <> [0/0/0] and [M:DCG1]SPPAWE <> 0.00 and [M:DCG1]SPPAWE > [L]SMP_MAWE and mkstat <> 2

  Call SPPCAL(VALEUR,[M:DCG1]SPPRETDAT,[M:DCG1]SPPAWE)
  Endif
#MASHI - 2017-11-16 X3-59443 END

End

Subprog C_SPPRETDAT(VALEUR)
Variable Date    VALEUR
Local Integer SPP_WKP_SR
Local Integer SPP_DTLLD
#Local Date SPPLEADAT
Local Date SPPEXPCON
#MASHI - 2017-11-16 X3-59443 START
Local Decimal SMP_MAWE

  #SMP_MAWE=113
  [L]SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(DCGUKINBLIG))
#MASHI - 2017-11-16 X3-59443 END
If [M:DCG1]SPPLEADAT = [0/0/0]
#TODO - Change hardcoded msg
  mkstat = 2 : GERR = 1 :  GMESSAGE =  mess(11,11828,1)
Else
#MASHI - 2017-09-08 X3-54202 START
  If DCGUKINBLIG >= 0 and VALEUR <> [0/0/0]
  #MASHI - 2017-09-08 X3-54202 END
#    SPP_WKP_SR = 2
    [L]SPP_WKP_SR = int(func SUBDCGUKI.SETVARIABLE("SPP_WKP_SR",[M:DCG1]STRDAT(DCGUKINBLIG)))
#   SPP_DTLLD = 56
    [L]SPP_DTLLD = int(func SUBDCGUKI.SETVARIABLE("SPP_DTLLD",[M:DCG1]STRDAT(DCGUKINBLIG)))

#    [L]SPPLEADAT = [M:DCG1]SPPLEADAT
    If VALEUR > [M:DCG1]SPPLEADAT + ([L]SPP_WKP_SR*7) - 1
      mkstat = 2 : GERR = 1 :  GMESSAGE = mess(12,11828,1)
    Endif
#MASHI - 2017-11-16 X3-59443 START
#    If VALEUR > [M:DCG1]SPPACTDOB
    If VALEUR < [M:DCG1]SPPACTDOB
#MASHI - 2017-11-16 X3-59443 START
      mkstat = 2 : GERR = 1 :  GMESSAGE = mess(12,11828,1)
    Endif
#MASHI - 2017-11-16 X3-59443 START
    If [M:DCG1]SPPACTDOB <> [0/0/0]
      [L]SPPEXPCON = [M:DCG1]SPPACTDOB
    Else
      [L]SPPEXPCON = [M:DCG1]SPPEXPCON
    Endif
    If VALEUR > [L]SPPEXPCON + [L]SPP_DTLLD

      mkstat = 2 : GERR = 1 :  GMESSAGE = mess(12,11828,1)
    Endif
    If VALEUR <> [M:DCG1]SPPLEADAT + 6 and VALEUR <> [M:DCG1]SPPLEADAT + 13
      mkstat = 2 : GERR = 1 :  GMESSAGE = mess(12,11828,1)
    Endif
#MASHI - 2017-11-16 X3-59443 END
  Endif
#MASHI - 2017-09-08 X3-54202 START
Endif
#MASHI - 2017-09-08 X3-54202 END
#MASHI - 2017-11-16 X3-59443 START
  If [M:DCG1]SPPEMPDAT <> [0/0/0]
  Call SPP_ELIGIBILITY ([M:DCG1]SPPAWE, [M:DCG1]SPPEMPDAT, [M:DCG1]SPPDECREC  )
  Endif
#MASHI - 2017-11-16 X3-59443 END
#MASHI - 2017-11-16 X3-59443 START
  If [M:DCG1]SPPLEADAT <> [0/0/0] and [M:DCG1]SPPAWE <> 0.00 and [M:DCG1]SPPAWE > [L]SMP_MAWE and mkstat <> 2
  Call SPPCAL([M:DCG1]SPPLEADAT,VALEUR,[M:DCG1]SPPAWE)
  Endif
#MASHI - 2017-11-16 X3-59443 END

End

Subprog C_SPPEXPDOB(VALEUR)
Variable Date    VALEUR
Local Decimal SUBEAR
#MASHI - 2017-11-16 X3-59443 START
Local Decimal SMP_MAWE

  #SMP_MAWE=113
  [L]SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(DCGUKINBLIG))
#MASHI - 2017-11-16 X3-59443 END

#MASHI - 2017-09-08 X3-54202 START
If VALEUR <> [0/0/0] and DCGUKINBLIG >= 0
#MASHI - 2017-09-08 X3-54202 END
  Gosub SPP_QUALIFYING_WEEK
  Gosub LAST_EMPLOYMENT_START_DATE
  Gosub SPP_EXPECTED_WEEK
#  Gosub SPP_ELIGIBILITY
  Gosub SPP_RELEVANT_PERIOD

  #Average earnings
  [L]SUBEAR = func SUBDCGUKI.AVERAGE_EARNING([M:DCG1]REFNUM,[M:DCG1]SPPRPSTR,[M:DCG1]SPPRPEND)
  If [M:DCG1]SPPAWE = 0
    [M:DCG1]SPPAWE = [L]SUBEAR : Affzo [M:DCG1]SPPAWE
  Endif
#MASHI - 2017-11-16 X3-59443 START
  If [M:DCG1]SPPEMPDAT <> [0/0/0]
  Call SPP_ELIGIBILITY ([M:DCG1]SPPAWE, [M:DCG1]SPPEMPDAT, [M:DCG1]SPPDECREC  )
  Endif
#MASHI - 2017-11-16 X3-59443 END

  #JOJAC - 2017-10-31 - X3-59443 - START
#MASHI - 2017-11-16 X3-59443 START
#  Call C_SPPAWE([L]SUBEAR)

  If [M:DCG1]SPPLEADAT <> [0/0/0] and [M:DCG1]SPPAWE <> 0.00 and [M:DCG1]SPPAWE > [L]SMP_MAWE
  Call SPPCAL ([M:DCG1]SPPLEADAT,[M:DCG1]SPPRETDAT,[M:DCG1]SPPAWE)
  Endif
#MASHI - 2017-11-16 X3-59443 END
#JOJAC - 2017-10-31 - X3-59443 - END
Endif

End

Subprog C_SPPACTDOB(VALEUR)
Variable Date    VALEUR
#MASHI - 2017-09-08 X3-54202 START
If VALEUR <> [0/0/0] and DCGUKINBLIG >= 0
#If VALEUR <> [0/0/0]
#MASHI - 2017-09-08 X3-54202 END
  Gosub SPP_LATEST_LEAVE_DATE

Endif
End

Subprog C_SPPAWE(VALEUR)
Variable Decimal VALEUR
Local Decimal SMP_MAWE


  #SMP_MAWE=113
  [L]SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(DCGUKINBLIG))
#  If VALEUR < SMP_MAWE
#    [M:DCG1]SPPELI = 1 : Affzo [M:DCG1]SPPELI
##    [M:DCG1]SPPREA = mess(8,11828,1) : Affzo [M:DCG1]SPPREA
#    [M:DCG1]SPPREA = "E" : Affzo [M:DCG1]SPPREA, ZSPPREA
#  Else
#If GUSER = 'MASHI':Infbox num$(VALEUR) :Endif
#    [M:DCG1]SPPELI = 2 : Affzo [M:DCG1]SPPELI
#    Raz [M:DCG1]SPPREA : Affzo [M:DCG1]SPPREA
#  Endif
  If [M:DCG1]SPPEMPDAT <> [0/0/0]
  Call SPP_ELIGIBILITY (VALEUR, [M:DCG1]SPPEMPDAT, [M:DCG1]SPPDECREC  )
  Endif

#If GUSER = 'MASHI':Infbox num$(VALEUR) :Endif
#MASHI - 2017-11-16 X3-59443 START
  If [M:DCG1]SPPLEADAT <> [0/0/0] and VALEUR <> 0.00 and VALEUR > [L]SMP_MAWE
  Call SPPCAL ([M:DCG1]SPPLEADAT,[M:DCG1]SPPRETDAT,VALEUR)
  Endif
#MASHI - 2017-11-16 X3-59443 END

End

Subprog C_SPPDECREC(VALEUR)
Variable Integer VALEUR
Local Decimal SMP_MAWE


  #SMP_MAWE=113
  [L]SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(DCGUKINBLIG))

  If [M:DCG1]SPPEMPDAT <> [0/0/0]
  Call SPP_ELIGIBILITY ([M:DCG1]SPPAWE, [M:DCG1]SPPEMPDAT, VALEUR  )
  Endif

#If GUSER = 'MASHI':Infbox num$(VALEUR) :Endif
#MASHI - 2017-11-16 X3-59443 START
  If [M:DCG1]SPPLEADAT <> [0/0/0] and [M:DCG1]SPPAWE <> 0.00 and [M:DCG1]SPPAWE > [L]SMP_MAWE
  Call SPPCAL ([M:DCG1]SPPLEADAT,[M:DCG1]SPPRETDAT,[M:DCG1]SPPAWE)
  Endif
#MASHI - 2017-11-16 X3-59443 END

End


$SPP_QUALIFYING_WEEK
Local Integer SMP_DTQW
Local Date QUADAT
Local Integer DANAM

  [L]SMP_DTQW = int(func SUBDCGUKI.SETVARIABLE("SMP_DTQW",[M:DCG1]STRDAT(DCGUKINBLIG)))
  [L]QUADAT = VALEUR - [L]SMP_DTQW
  [L]DANAM = dayn([L]QUADAT)

  While [L]DANAM <> 7
    [L]QUADAT = [L]QUADAT -1
    [L]DANAM = dayn([L]QUADAT)
  Wend

  [M:DCG1]SPPQUADAT = [L]QUADAT : Affzo [M:DCG1]SPPQUADAT

Return

$LAST_EMPLOYMENT_START_DATE
Local Date SUBLASDAT
Local Integer SUBLASD
Local Integer SMP_DTLSD

  [L]SMP_DTLSD = int(func SUBDCGUKI.SETVARIABLE("SMP_DTLSD",[M:DCG1]STRDAT(DCGUKINBLIG)))
  #TODO - uncommetn
  #SMP_DTLSD = 182
  #SMP_DTLSD = SMP Days to Latest Start Date
  [L]SUBLASDAT = [L]QUADAT
  [L]SUBLASD = dayn([L]SUBLASDAT)

  While [L]SUBLASD <> 6
    [L]SUBLASDAT = [L]SUBLASDAT +1
    [L]SUBLASD = dayn([L]SUBLASDAT)
  Wend
  [L]SUBLASDAT = [L]SUBLASDAT - [L]SMP_DTLSD +1
  [L]SUBLASD = dayn([L]SUBLASDAT)

  While [L]SUBLASD <> 6
    [L]SUBLASDAT = [L]SUBLASDAT +1
    [L]SUBLASD = dayn([L]SUBLASDAT)
  Wend

  [M:DCG1]SPPEMPDAT = [L]SUBLASDAT : Affzo [M:DCG1]SPPEMPDAT

Return

$SPP_EXPECTED_WEEK
Local Integer SMP_DTLSD
Local Date LASDAT
Local Date SUBEXPCON
Local Integer EXPNAM

  [L]SMP_DTLSD = int(func SUBDCGUKI.SETVARIABLE("SMP_DTLSD",[M:DCG1]STRDAT(DCGUKINBLIG)))
  #Infbox num$(SMP_DTLSD)
  #Infbox num$([M:DCG1]SPPQUADAT)
  #LASDAT = QUADAT - SMP_DTLSD
  #LASDAT = [M:DCG1]SPPQUADAT - SMP_DTLSD
  [L]SUBEXPCON = VALEUR
  [L]EXPNAM = dayn([L]SUBEXPCON)

  #[M:DCG1]SPPEMPDAT = LASDAT : Affzo [M:DCG1]SPPEMPDAT




  If [M:DCG1]SPPPRO < 1
    [M:DCG1]SPPPRO = 2: Affzo [M:DCG1]SPPPRO
  Endif

  While [L]EXPNAM <> 7
    [L]SUBEXPCON = [L]SUBEXPCON -1
    [L]EXPNAM = dayn([L]SUBEXPCON)
  Wend

  [M:DCG1]SPPEXPCON = [L]SUBEXPCON : Affzo [M:DCG1]SPPEXPCON

Return

Subprog SPP_ELIGIBILITY (AVGEARN,LSTEMPSTR,DECREC)
Value Integer AVGEARN, DECREC
Value Date LSTEMPSTR

#31074
#31114
#ALHAR - 2017-09-18 X3-49262 START
Local Decimal SMP_MAWE


  #SMP_MAWE=113
  [L]SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(DCGUKINBLIG))
  If [L]AVGEARN < [L]SMP_MAWE
    [M:DCG1]SPPELI = 1 : Affzo [M:DCG1]SPPELI
#    [M:DCG1]SPPREA = mess(8,11828,1) : Affzo [M:DCG1]SPPREA
    [M:DCG1]SPPREA = "E" : Affzo [M:DCG1]SPPREA, ZSPPREA
  Else
#If GUSER = 'MASHI':Infbox num$(VALEUR) :Endif
    [M:DCG1]SPPELI = 2 : Affzo [M:DCG1]SPPELI
    Raz [M:DCG1]SPPREA : Affzo [M:DCG1]SPPREA, ZSPPREA
  Endif

  #JOJAC - 2017-11-01 - X3-61588 - START
  If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
  Filter [HRCTR] Where REFNUM = [M:DCG1]REFNUM and CTRNUM = [M:DCG1]CTRNUM
  Read [HRCTR] First
  Filter [HRCTR]
  If !fstat
    #If [HRCTR]CTRDAT < QUADAT-128
    #JOJAC - 2017-10-30 - X3-59159 - START
#ALHAR - 15-02-2018 X3-77357 - start
    #If [HRCTR]CTRDAT < [L]LSTEMPSTR
    If [HRCTR]CTRDAT <= [L]LSTEMPSTR
#ALHAR - 15-02-2018 X3-77357 - end
    #If [HRCTR]CTRDAT < [M:DCG1]SMPQUADAT-128
    #JOJAC - 2017-10-30 - X3-59159 - END
#      [M:DCG1]SPPELI = 2
      If [HRCTR]XITDAT <> [0/0/0]
        If [HRCTR]XITDAT < [M:DCG1]SPPQUADAT
          [M:DCG1]SPPELI = 1     : Affzo [M:DCG1]SPPELI
          #[M:DCG1]SMPREA = mess(4,11828,1)
          [M:DCG1]SPPREA = "M" : Affzo [M:DCG1]SPPREA, ZSPPREA
          Affzo [M:DCG1]SPPREA
        Endif
      Endif
    Else
      [M:DCG1]SPPELI = 1      : Affzo [M:DCG1]SPPELI
      #[M:DCG1]SSPSTA(DCGUKINBLIG) = 1
      #[M:DCG1]SMPREA = mess(1,11828,1)
      [M:DCG1]SPPREA = "M"    : Affzo [M:DCG1]SPPREA, ZSPPREA
    Endif
    Affzo [M:DCG1]60
  Endif

#MASHI - 2017-11-16 X3-59443 START
  If [L]DECREC < 2
    [M:DCG1]SPPREA = "O" : Affzo [M:DCG1]SPPREA, ZSPPREA
    [M:DCG1]SPPELI = 1  : Affzo [M:DCG1]SPPELI
  Endif
#MASHI - 2017-11-16 X3-59443 END


##  #### Calc Eligibility
##  If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
##  Filter [HRCTR] Where REFNUM = [M:DCG1]REFNUM and CTRNUM = [M:DCG1]CTRNUM
##  Read [HRCTR] First
##  Filter [HRCTR]
##  If !fstat
##    #JOJAC - START
##    #If [HRCTR]CTRDAT < QUADAT-(26*7)
##    #[M:DCG1]SPPQUADAT
##    If [HRCTR]CTRDAT < [M:DCG1]SPPQUADAT-(26*7)
##    #JOJAC - END
##      [M:DCG1]SPPELI = 2
##      #[M:DCG1]SSPSTA(DCGUKINBLIG) = 2
##    Else
##      [M:DCG1]SPPELI = 1
##      #[M:DCG1]SSPSTA(DCGUKINBLIG) = 1
##      [M:DCG1]SPPREA = mess(16,11828,1)
###ALHAR - 2017-09-21 X3-49262 START
## #     [M:DCG1]SXPSP1 = mess(17,11828,1)
###ALHAR - 2017-09-21 X3-49262 END
##    Endif
##    Affzo [M:DCG1]SPPELI
##    Affzo [M:DCG1]SPPREA
##    #Affzo [M:DCG1]SSPSTA(DCGUKINBLIG)
##
##  Endif
