#<AdxTL>@(#)1.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Initialisation à 2 de la rubrique [F:TCY]CTYUPP quand elle est à 0
# FGR 07/03/2012 : X3SUIVI79830
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("[F:TCY]CTYUPP initialization") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub UPDCTYUPP
End

#-------------------#
$UPDCTYUPP
#CHECK IGNORE_BEGIN

  # ------------------------------
  Local File =DOSSIER+".TABCOUNTRY" [TCY]
  # ------------------------------
  If dim([F:TCY]CTYUPP) >= 0 Then
    Trbegin [TCY]
    IOK = 1
    Update [TCY] Where CTYUPP <> 1 and CTYUPP <> 2 With CTYUPP = 2
    If fstat Then
      Call ERREUR("TABCOUNTRY  fstat=" - num$(fstat), 2) From DOSDIC
      Rollback
    Else
      Commit
    Endif
  Endif
  Close Local File [TCY]
  #CHECK IGNORE_END
Return

# Issue SAM121863 - 2017-04-06 by FGR : Missing subroutine
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If fstat  Raz [F:ADS] : Endif
#
Gosub UPDCTYUPP
End

