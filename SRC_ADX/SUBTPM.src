#<AdxTL>@(#)1.0.0.0 $Revision$
Call OBJET("TPM", GBIDC1, GBIDC2) From GOBJET
End

$ACTION

Case ACTION
 When "AFFMASK" : Gosub AFFMASK
 When "INIMOD"        : Gosub INICRE
 When "INICRE"        : Gosub INICRE
Endcase

Return

$AFFMASK
Affzo [M:TPM]1-99
Return

$INICRE
Call MAJTEXTRA([M:TPM]DESAXX,"TABPRTMOD","DESAXX",[M:TPM]TPMCOD,"") From ATEXTRA
Call MAJTEXTRA([M:TPM]SHOAXX,"TABPRTMOD","SHOAXX",[M:TPM]TPMCOD,"") From ATEXTRA
Return


