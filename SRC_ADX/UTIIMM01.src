#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# UTIIMM01   Suppression du code activité CAL               Module IMMO  #
#                                                                        #                     
##########################################################################
Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTIIMM01(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTIIMM01(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIIMM01 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
Local File =DOSSIER+".ACTIV"   [ACVF]
Local File ADOSACT [ADAF]
Local File =DOSSIER+".ADOCUMENT"   [ADOF]

Call DEBTRANS From GLOCK

Trbegin [ACVF], [ADAF], [ADOF]

Readlock [ACVF]CODACT ="CAL"
If !fstat
 Delete [ACVF] Curr
 If fstat=1
  # Erreur d'effacement
  GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"ACTIV : CAL",-1) From GESECRAN : Goto AB_UTIIMM01 
 Endif
Endif

Readlock [ADAF]ADA0 =DOSSIER;"CAL"
If !fstat
 Delete [ADAF] Curr
 If fstat=1
  # Erreur d'effacement
  GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"ADOSACT: CAL",-1) From GESECRAN : Goto AB_UTIIMM01 
 Endif
Endif

Update [ADOF] Where CODACT="CAL" With CODACT = "FAL"
If fstat
 # Erreur d'effacement
 GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"ADOCUMENT: CAL",-1) From GESECRAN : Goto AB_UTIIMM01 
Endif

Commit
Close Local File [ACVF], [ADAF], [ADOF]
Call ECR_TRACE("UTIIMM01 : record processed",0) From GESECRAN
End

$AB_UTIIMM01
Rollback
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
#If APPLI=GDOSX3: End : Endif
Call MAJ_UTIIMM01(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI=GDOSX3 :  End : Endif 
Call MAJ_UTIIMM01(APPLI)
End




