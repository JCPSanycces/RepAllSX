#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGPOR 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone PORCPYACT
mkstat = 0
zoncou = "PORCPYACT"
indice = 0
If varinit([M]PORCPYACT,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]PORCPYACT,"395","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]PORCPYACT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PORCPYACT" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]PORCPYACT,"395","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PORCPYACT" : GZNUM = 48831 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]PORCPYACT,"395",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "PORCPYACT" : GZNUM = 48831 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PORHQR
mkstat = 0
zoncou = "PORHQR"
indice = 0
IMPENT = [M]PORHQR
If varinit([M]PORHQR,indice)=0
 IMPENT = 1
Endif
If varmode([M]PORHQR,indice)=0
 Call INICOMBO(2274) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_PORHQR(IMPENT) From TRTCPYLEGPOR
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,2274,1))))
 Endif
 [M]PORHQR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PORHQR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PORHQR(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "PORHQR" : GZNUM = 47109 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]PORHQR = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone PORFINDPR
mkstat = 0
zoncou = "PORFINDPR"
indice = 0
If varmode([M]PORFINDPR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PORFINDPR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PORLRC
mkstat = 0
zoncou = "PORLRC"
indice = 0
If varmode([M]PORLRC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PORLRC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PORCTFACN
mkstat = 0
zoncou = "PORCTFACN"
indice = 0
If varmode([M]PORCTFACN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PORCTFACN" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PORDCLPER
mkstat = 0
zoncou = "PORDCLPER"
indice = 0
IMPENT = [M]PORDCLPER
If varinit([M]PORDCLPER,indice)=0
 IMPENT = 1
Endif
If varmode([M]PORDCLPER,indice)=0
 Call INICOMBO(2226) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_PORDCLPER(IMPENT) From TRTCPYLEGPOR
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,2226,1))))
 Endif
 [M]PORDCLPER(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PORDCLPER" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PORDCLPER(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "PORDCLPER" : GZNUM = 6322 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]PORDCLPER = IMPENT

## Zone PORRESFISCDA
mkstat = 0
zoncou = "PORRESFISCDA"
indice = 0
If varmode([M]PORRESFISCDA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PORRESFISCDA" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_PORRESFISCDA([M]PORRESFISCDA) From TRTCPYLEGPOR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PORRESFISCDA" : GZNUM = 52682 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone PORCPYACTTYP
mkstat = 0
zoncou = "PORCPYACTTYP"
indice = 0
IMPENT = [M]PORCPYACTTYP
If varinit([M]PORCPYACTTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]PORCPYACTTYP,indice)=0
 [M]PORCPYACTTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PORCPYACTTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PORCPYACTTYP(indice)
 Endif
Endif
[M]PORCPYACTTYP = IMPENT

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone PORSIMINVISS
mkstat = 0
zoncou = "PORSIMINVISS"
indice = 0
IMPENT = [M]PORSIMINVISS
If varinit([M]PORSIMINVISS,indice)=0
 IMPENT = 1
Endif
If varmode([M]PORSIMINVISS,indice)=0
 [M]PORSIMINVISS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PORSIMINVISS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PORSIMINVISS(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_PORSIMINVISS(IMPENT) From TRTCPYLEGPOR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PORSIMINVISS" : GZNUM = 52674 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]PORSIMINVISS = IMPENT

## Zone PORAMTSERINV
mkstat = 0
zoncou = "PORAMTSERINV"
indice = 0
If varmode([M]PORAMTSERINV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PORAMTSERINV" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PORAMTITMINV
mkstat = 0
zoncou = "PORAMTITMINV"
indice = 0
If varmode([M]PORAMTITMINV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PORAMTITMINV" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc tableau 5
####################################
IMPTBL = 1

## Zone NBCFE
mkstat = 0
zoncou = "NBCFE"
indice = 0
status = 1
zoncou = "NBCFE"
If varmode([M]NBCFE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBCFE" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBCFE
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBCFE = nolign
   status = 75
   Call SAI_NBCFE(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBCFE From TRTCPYLEGPOR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBCFE" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 5
####################################
Subprog SAI_NBCFE(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBCFE
mkstat = 0
zoncou = "NBCFE"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBCFE From TRTCPYLEGPOR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBCFE" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone COMMTYPE
mkstat = 0
zoncou = "COMMTYPE"
IMPENT = [M]COMMTYPE(indice)
If varinit([M]COMMTYPE,indice)=0
 IMPENT = 1
Endif
If varmode([M]COMMTYPE,indice)=0
 [M]COMMTYPE(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "COMMTYPE" : Gosub ACTION From =IMPTRT
  IMPENT = [M]COMMTYPE(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_COMMTYPE(IMPENT) From TRTCPYLEGPOR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "COMMTYPE" : GZNUM = 50107 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]COMMTYPE(indice) = IMPENT

## Zone ENDDAT
mkstat = 0
zoncou = "ENDDAT"
If varmode([M]ENDDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENDDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ENDDAT([M]ENDDAT(indice)) From TRTCPYLEGPOR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NBCFE
mkstat = 0
zoncou = "NBCFE"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CPYLEGPOR"
Return

