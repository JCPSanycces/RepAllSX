$DUPLICATE
Local Integer L
#Open the linked table to the main(this) class
Local File EMPCTRUKIRT [CTRUR1]

#Fill/Set the file instance to the parameter class
Raz [F:CTRUR1]
SetInstance [F:CTRUR1] With I_EMPCTRUKISTG_UPD

#Now we can fill the main(this) class from the table
SetInstance I_EMPCTRUKIINS With [F:CTRUR1]

L = fmet I_EMPCTRUKIINS.ADDLINE("UKADD",[V]CST_ALASTPOS)
SetInstance I_EMPCTRUKIINS.UKADD(L) With [F:CTRUR1]

#Write
[L]WRITESTATUS = fmet I_EMPCTRUKIINS.AINSERT()

LogicClose File        [CTRUR1]
Return

$UPDATE_FIELD
#Parameter (PCLASS - EMPCTRUKISTG)
Local Integer J,K,Z,Y,RETVAL
Local Char SYSPROP(GLONAVA)(1..)

[L]ARET_VALUE = [V]CST_AOK
RETVAL = func PIHRMFAIR_FUNCTIONS.SET_SYPROP(SYSPROP)

For K = 1 To I_EMPCTRUKISTG_UPD.ObjectNbs
  If find(I_EMPCTRUKISTG_UPD.ObjectVar(K),SYSPROP)=0
    If evalue("DIM(I_EMPCTRUKIINS."+I_EMPCTRUKISTG_UPD.ObjectVar(K)+")")>0
      Assign "I_EMPCTRUKIINS."+I_EMPCTRUKISTG_UPD.ObjectVar(K) With evalue("(I_EMPCTRUKISTG_UPD."+I_EMPCTRUKISTG_UPD.ObjectVar(K)+")")
    Endif
  Endif
Next K

#UKADD Collection
If I_EMPCTRUKIINS.UKADD <> null
For Z = 1 To maxtab(I_EMPCTRUKIINS.UKADD)
  If I_EMPCTRUKIINS.UKADD(Z).TYP = 1 #Home
    #Update
    For K = 1 To I_EMPCTRUKISTG_UPD.ObjectNbs
      If find(I_EMPCTRUKISTG_UPD.ObjectVar(K),SYSPROP)=0
        If evalue("DIM(I_EMPCTRUKIINS.UKADD("+num$(Z)+")."+I_EMPCTRUKISTG_UPD.ObjectVar(K)+")")>0
          Assign "I_EMPCTRUKIINS.UKADD("+num$(Z)+")."+I_EMPCTRUKISTG_UPD.ObjectVar(K) With evalue("(I_EMPCTRUKISTG_UPD."+I_EMPCTRUKISTG_UPD.ObjectVar(K)+")")
        Endif
      Endif
    Next K
  Endif
Next

Endif

#Write
[L]UPDSTATUS = fmet I_EMPCTRUKIINS.AUPDATE()


Return

