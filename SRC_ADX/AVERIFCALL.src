#<AdxTL>@(#)6.0.0.0 $Revision$

# #####################################################
#  Traitement de vÃĐrification syntaxique grossiÃĻre
#  recherche des incohÃĐrences dans les arguments de sous-programmes
#-----------------------------------------------------------------------------------------------------------#
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT,PARBOUT, "", "AVERIFSRC", "AVERIFSRC", 3, "") From GTRAITE
End

Subprog AVERIFCALL(CHEMINTRA, PATCH, SRCPATCH, NOMTRT, DOSSIER, PMODULE, OWNER, ECREXP, EXCLSUP,
&   PORT, MACHINE, CHEMINTRAW, NBERRTOT, NBWARTOT, PNUMERREUR, PACTION,
&   NBVARGLOB, NBVARGLOBDIC, NBVARGLOBSRC, PDEMANDEUR, PPASSE1FAITE, PBLISTETRT,
&   PTRIPARMODULE, PTYPE, PLIBVERIF)

Value Char CHEMINTRA    :  # Chemin oÃđ seront crÃĐÃĐs les fichiers de trace
Value Char PATCH        :  # Si patch, on ne vÃĐrifie que les traitement modifiÃĐs
Value Char SRCPATCH     :  # Si patch, chemin oÃđ sont les traitements patchÃĐs
Value Char NOMTRT       :  # Nom du source Ã  analyser (jokers autorisÃĐs)
Value Char DOSSIER      :  # Si non patch, dossier analysÃĐ

Value Integer PMODULE   :  # Si travail sur sources d'un module particulier
Value Integer OWNER     :  # Si on veut travailler sur les sources d'un owner particulier
Value Integer ECREXP    :  # ÃĐcrire les exceptions dans le compte-rendu
Value Integer EXCLSUP   :  # exclure le module superviseur
Value Integer PORT      :  # port du dossier
Value Char MACHINE      :  # machine du dossier
Value Char CHEMINTRAW
Variable Integer NBERRTOT, NBWARTOT
Value Integer PNUMERREUR : # pour ne travailler que sur une seule erreur
Value Integer PACTION    : # Call et/ou trts non utilisÃĐs (ds les call ou dicos)
                           # 0 Call   1 Trts non utilisÃĐs   3 pour VERIFTYPE 4 Call et VERIFTYPE
Variable Integer NBVARGLOB, NBVARGLOBDIC, NBVARGLOBSRC
Value Integer PDEMANDEUR : # niveau indus, dev, distri, spe...
Variable Integer PPASSE1FAITE, PBLISTETRT
Value Integer PTRIPARMODULE
Value Char PTYPE, PLIBVERIF




############PNUMERREUR = 73 # var non dÃĐclarÃĐe
############PNUMERREUR = 74 # var glob dÃĐclarÃĐe x fois avec un type <>




# A dimensionner pour tenir les tableaux en mÃĐmoire !
# On peut aller jusqu'Ã  32000 si nÃĐcessaire, mais si on n'analyse pas les traitements automatiques,
# on en est Ã  19800 sous-programmes et 16900 traitements environ... J'ai donc laissÃĐ de la marge
# Idem pour les zones du dico : on en est Ã  14300 aujourd'hui dans moins de 700 tables


Local Integer ARGUMENTS(1..GMAX_NBPAR), NBARG, NPPARENTH, ARRET, NBVARLOC, NBVARLOCCBO, NUMARGDECL
Local Char TNOMARG(20)(1..GMAX_NBPAR), WNOMARG(20)
Local Char TABARG(20)(1..GMAX_NBPAR), TABARGDECL(20)(1..GMAX_NBPAR)


Local Char NOMPROG(GMAX_LGSSPRO), NOMCALL(GMAX_LGSSPRO)
Local Integer IP,IQ,IR,IS,IT,IU,NBZO,NF,NSK,NANA,NLIG,NLIG_CALL,NBZA,IPOS, IR2, ID, ID2, IE, ITY, BOK
Local Integer TRTUTILISE(1..GMAX_TRT), POSUTIL, NLIGSAV, NSKLEC, NSK_SAV
Local Clbfile CHAINE(3), CHAINECPT(3), CHAINESAV(3), CHAININS(3), CHAINERES(3), CHAINEFUN(3), CHAININS2(3), CHAINELEC(3)
Local Char WFORMAT(10), TRTUTILDANS(20)(1..GMAX_TRT)
Local Char CHAINE1(255), TXTERR(200)

Local Integer NBWARNING, WERRTEXTE, BCHAINELEC, FST, NS2, NG2, IS2, IS3, DEPAS_VARGLOB, XXBOK


Local Libelle TYPCOUR
Local Char VARIA(20),ABV(20), DOSSIER2(100), WSTYPE(20)

Global Char ALPHA(27) : ALPHA="ABCDEFGHIJKLMNOPQRSTUVWXYZ_"
Global Char ALPHAN(37) : ALPHAN=ALPHA+"0123456789"
Global Char SPACEN(37) : SPACEN=space$(len(ALPHAN))

Local Char TVARLOC(20)(1..2000)

Local Char REPVAR(20)(1..100),REPTRT(GLONADC), SPENCOURS(20), WPROGVARGLOB(20)(1..GMAX_NBPAR)
Local Integer PTREP, NEX1, NEX2, NEX3
Local Char TABTYP(GLONATY)(1..GMAX_TYPE)
Local Shortint TYPVARLOC(1..2000)
Local Integer MAX_LENCALL
Local Shortint BSPECIF, SAUVEMODULE
Local Integer NBSP,LIMITE1,LIMITE2,NBPASSE, WMODULEOK
Local Integer WADRVAL(GMAX_NBPAR), TDTYPARG(GMAX_NBPAR), TDADRVAL(GMAX_NBPAR), WTYFC
Local Char ERRMES(200)(46)
Local Char EXCEPTTRT(30)(1..1000)
Local Char EXCEPTVAR(30)(1..1000)
Local Char TVGLOBEXCP(12)(1..10) : # Variables globales Ã  exclure des tests
Local Char NMTRT(GLONADC),NMFUNC(20)

Local Integer  TITAECRIRE, TITAECRIREW, NBTRAITES, NBERREUR, IQ2PTS, IPLUS, NBPARENTH, NBVGLOBEXCP
# TITAECRIRE boolÃĐen pour savoir si on a dÃĐjÃ  ÃĐcrit le nom du source
Local Char TDBG(30)(1..10)

#CBO 2009.04.14
Local Char WFILE(10), WABREV(5)
Local Integer WIGNWRSEQ, WIGNWRTRT, ILF, WECRERREUR, WBVARGLOB(GMAX_NBPAR), WBSUBPROG, WMIGRATE
Local Char TCODTYPATY(GLONATY)(1..GMAX_TYPE)
Local Integer TLGTYPATY(1..GMAX_TYPE)


Local Char WTITRE(150), WTITRE2(150), WTEXTE(250), PRECOP, OPERATEUR
Local Integer IB, MI1, MI2, MI3, NBTYPEATY

Local Integer INDERREUR, TERREUR(50), I
Local Char TPGMEXISTE(GMAX_LGSSPRO)(100), ZADXIFS, ZADXIRS, TEXCPGMSUP(GMAX_LGSSPRO)(100)
Local Integer NBPGMEXISTE, NBEXCPGMSUP

MAX_LENCALL=type(GTSOUSPRO)-10

ZADXIFS=adxifs
ZADXIRS=adxirs
adxifs=chr$(0)
adxirs=chr$(10)

LIMITE1=100000 : # Pas de limite=100000
LIMITE2=100000
WFORMAT = "KT:1024X"

Local Shortint WBWARNING
Local Integer NBGS

#

Global Integer WBECRIRELIGNESOURCE
WBECRIRELIGNESOURCE = 0



# CBO 2009.02.23 (type des fonctions)
Local Integer WIFTROUVE, WENDTROUVE, WBTABLEASP

Call TEMPON("VERIFCALL Initialisation du traitement...") From GESECRAN
SAUVEMODULE = -1

# tableau des exceptions pour le contrÃīle sur dbgaff
TDBG(1) = "DEBUGGER"
TDBG(2) = "SERVEUR"

#--------------------#
#Liste des exceptions
#--------------------#
If instr(1,DOSSIER,"X3")>0 Then
  Gosub LISTEX_X3
Elsif instr(1,DOSSIER,"PAY")>0 Then
  Gosub LISTEX_PAY
Endif

PNUMERREUR = mod(PNUMERREUR, 100)


#----------------
#Table des types
#----------------
If MACHINE = ""
    DOSSIER2 = DOSSIER
Else
    DOSSIER2 = MACHINE + ":" + num$(PORT) + "@" + DOSSIER
Endif

If clalev ([F:ATY])
    Close File [ATY]
Endif
If clalev ([F:ADC])
    Close File [ADC]
Endif
If clalev ([F:ASU])
    Close File [ASU]
Endif
If clalev ([F:AGB])
    Close File [AGB]
Endif
If clalev ([F:ATZ])
    Close File [ATZ]
Endif

If clalev ([F:ATB])
    Close File [ATB]
Endif

If clalev ([F:AMZ])
    Close File [AMZ]
Endif
If clalev ([F:AMK])
    Close File [AMK]
Endif
If clalev ([F:AMK1])
    Close File [AMK1]
Endif
If clalev ([F:AST])
    Close File [AST]
Endif
If clalev ([F:ASP])
    Close File [ASP]
Endif



Local File = DOSSIER2 + "."+"ATYPE"  [ATY]
Local File = DOSSIER2 + ".ADICTRT"   [ADC] : # table des traitements
Local File = DOSSIER2 + ".ASUBPROG"  [ASU]    : # pour le type des fonctions
Local File = DOSSIER2 + ".AGLOBVAR"  [AGB]
Local File = DOSSIER2 + ".ATABZON"   [ATZ]
Local File = DOSSIER2 + ".ATABLE"    [ATB]

Local File = DOSSIER2 + ".AMSKZON"   [AMZ]
Local File = DOSSIER2 + ".AMSK"      [AMK]
Local File = DOSSIER2 + ".AMSK"      [AMK1]
Local File = DOSSIER2 + ".APLSTD"    [AST]

WBTABLEASP = 0
If filinfo(filpath("FIL", "ASUBPROGD", "fde", DOSSIER2),0) >= 0
    Local File = DOSSIER2 + ".ASUBPROGD"  [ASP]
    WBTABLEASP = 1
Endif

    If PPASSE1FAITE = 0
        ID = 0
        For [ATY]
            ID += 1
            TABTYP(ID)=[ATY]CODTYP
        #    TYPTYP(ID)=2*([ATY]TYPTYP<=6)+1*([ATY]TYPTYP=7)+3*([ATY]TYPTYP=8) +4*([ATY]TYPTYP=9) + 5*([ATY]TYPTYP=10)

            If [ATY]TYPTYP <= 6
                GTTYPTYP(ID) = 2
            Elsif [ATY]TYPTYP = 7
                GTTYPTYP(ID) = 1
                TCODTYPATY(ID) = [F:ATY]CODTYP
                TLGTYPATY(ID)  = [F:ATY]LNGTYP
            Elsif [ATY]TYPTYP = 8
                GTTYPTYP(ID) = 3
            Elsif [ATY]TYPTYP = 9
                GTTYPTYP(ID) = 4
            Elsif [ATY]TYPTYP = 10
                GTTYPTYP(ID) = 5
            Endif
        Next
    Endif
    NBTYPEATY = ID

    # inutile de charger ces var pour la recherche des traitements non appelÃĐs
    If PACTION = 1
        Goto PASSEPREMIER
    Endif


#----------------
# variables globales de AGLOBVAR
#----------------

    If PPASSE1FAITE = 0
        Link [AGB] With [ATY]CODTYP = [AGB]CODTYP As [XGT]
        NBVARGLOBDIC=0
        For [XGT]
            NBVARGLOBDIC+=1
            GTVARGLOBDIC(NBVARGLOBDIC) = [F:AGB]CODVAR
            If [ATY]TYPTYP <= 6
                GTYPVARGLOBDIC(NBVARGLOBDIC) = 2
            Elsif [ATY]TYPTYP = 7
                GTYPVARGLOBDIC(NBVARGLOBDIC) = 1
            Elsif [ATY]TYPTYP = 8
                GTYPVARGLOBDIC(NBVARGLOBDIC) = 3
            Elsif [ATY]TYPTYP = 9
                GTYPVARGLOBDIC(NBVARGLOBDIC) = 4
            Elsif [ATY]TYPTYP = 10
                GTYPVARGLOBDIC(NBVARGLOBDIC) = 5
            Endif
            If [F:AGB]CODTYP = "A"
                GTLGVARGLOBDIC(NBVARGLOBDIC) = func AVERIFSRC.VALN([F:AGB]LNGTYP)
            Else
                GTLGVARGLOBDIC(NBVARGLOBDIC) = [F:ATY]LNGTYP
            Endif
        Next

#------------------------------#
# Table des variables fichiers
#------------------------------#

        NBFI=0
        NBZO=1
        For [ATZ]CODZONE(1)
          Read [ATB]CODFIC=[ATZ]CODFIC
          If [F:ATB]MODULE <> 11 and left$([F:ATB]CODFIC, 1) < "X" and [F:ATB]CODACT<>"MIG"
              NBFI+=1
              GTFICHIERS(NBFI)=[ATB]ABRFIC
              GTINDFIC(NBFI)=NBZO
              For [ATZ]CODZONE
                  Read [ATY]CODTYP=[ATZ]CODTYP
                  GTZONES(NBZO)=[ATZ]CODZONE
                  # CBO 20110107 FQ70501
                  ID = find([ATZ]CODTYP, TABTYP)
                  If ID
                      GTTYPZO(NBZO) = GTTYPTYP(ID)
                  Else
                      GTTYPZO(NBZO) = 0
                  Endif

                  NBZO+=1
                  If NBZO > GMAX_ZONEFIC
                        Break  2
                  Endif
              Next
          Endif
        Next
        GTINDFIC(NBFI+1)=NBZO
        GVALCBO(3) = NBZO
        GVALCBO(31) = NBFI


#----------------------------#
# Table des variables masques
#----------------------------#


        NBMA=0
        NBZM=1
        NBZMB=1

        Filter [AMZ] Where CODMSK < "VXACC"
        For [AMZ]CODE(1)
          Read [AMK]CODMSK=[AMZ]CODMSK
          NBZA=0
          For [AMK1]ABRMSK Where ABRMSK=[AMK]ABRMSK
              NBZA+=1
          Next
          If NBZA=1 : # Un seul masque possÃĻde cette abrÃĐviation, on a donc des chances
              NBMA+=1


              GTMASQUES(NBMA)=[AMK]ABRMSK
              GTINDMAS(NBMA)=NBZM
              For [AMZ]CODE

                # CBO 20110107 FQ70501
                ID = find([AMZ]CODTYP, TABTYP)
                If NBZM > GMAX_ZONEMSK

                    GTZONMSKB(NBZMB) = [AMZ]CODZON
                    If ID
                        GTTYPMZOB(NBZMB) = GTTYPTYP(ID)
                    Else
                        GTTYPMZOB(NBZMB) = 0
                    Endif

                    NBZM  += 1
                    NBZMB += 1

                    If NBZMB > GMAX_ZONEMSK
                        Wrseq "$$$$$ prÃĐvenir Indus : MAX_ZONMSK dÃĐpassÃĐ (2Â° tableau)" Using [FWR]
                        Break 2
                    Endif

                Else
                    GTZONMSK(NBZM) = [AMZ]CODZON
                    If ID
                        GTTYPMZO(NBZM) = GTTYPTYP(ID)
                    Else
                        GTTYPMZO(NBZMB) = 0
                    Endif

                    NBZM += 1
                Endif

              Next
           Endif
        Next
        GVALCBO(4) = NBZM
        GVALCBO(5) = NBZMB
        GVALCBO(32) = NBMA

        Filter [AMZ]
        GTINDMAS(NBMA+1)=NBMA

        #trts en exception uniquement si appelÃĐ par un traitement du module 1 (superviseur)
        TEXCPGMSUP(1) = "LOGDIV"
        TEXCPGMSUP(2) = "GENTRT"
        TEXCPGMSUP(3) = "GLOBGEO"
        TEXCPGMSUP(4) = "GLOBPAY"
        TEXCPGMSUP(5) = "GLOBLOAN"


        TEXCPGMSUP(6) = "PARVAL"
        TEXCPGMSUP(7) = "GENTRTWE"
        TEXCPGMSUP(8) = "GENTRTWF"
        NBEXCPGMSUP = 8

        #----------------
        # variables globales de AGLOBVAR dÃĐclarÃĐes dans WWGLOBLON.src
        #----------------

        Call TEMPON("VERIFCALL : variables globales de WWGLOBLON") From GESECRAN
        Call CHGSRCVARGLOB(DOSSIER2, "WWGLOBLON", GPREFIXE, NBVARGLOBSRC, PTYPE) From AVERIFSRC
    Endif

$PASSEPREMIER

    If PPASSE1FAITE = 0
   #     NOMTRT = "STRCONTACTCRM"
        If NOMTRT <> "STRCON_ACTCRM"
            If PBLISTETRT = 0
                Call LISTETRT(PDEMANDEUR, PORT, MACHINE, DOSSIER) From AVERIFSRC
                If PACTION = 0
                    PBLISTETRT = 1
                Endif
            Endif
        Else

            GTTRAITEMENTS(1) = NOMTRT
            GNBTRTADX = 1
#            GTTRAITEMENTS(2) = "STRBPDLVCUST"
#            GNBTRTADX = 2
#    GTTRAITEMENTS(3) = "FUNSTVA"
#    GNBTRTADX = 3
#    GTTRAITEMENTS(4) = "FIYEND"
#    GNBTRTADX = 4

            NOMTRT = ""
        Endif
    Endif

#-----------------------------------------------------------------------------#
# 1ÃĻre passe => Tableau des sous-programmes et tableau des variables globales
#-----------------------------------------------------------------------------#

    If PACTION = 0 or PACTION = 4
        Openo CHEMINTRA, -1
        Gosub ECRDEB

        # liste des exceptions :
        If ECREXP = 2
            Gosub ECRIREEXCPT
            Wrseq "-----------------------------------------------------------------------------------------------------"
        Endif
        Openo

        Openo CHEMINTRAW, -1
        Gosub ECRDEB
        Openo

        Openo CHEMINTRA, -1  Using [FER]
    Endif

    If PACTION <> 3
        Openo CHEMINTRAW, -1 Using [FWR]
    Endif

    WBWARNING = 0
    NBWARNING = 0
    Raz INDERREUR, TERREUR

    If PACTION <> 1
        Call TEMPON("VERIFCALL 1ÃĻre passe : ") From GESECRAN
        NBPASSE=1
        If PPASSE1FAITE = 0
            PPASSE1FAITE = 1

            For NF=1 To min(GNBTRTADX, LIMITE1)
                If NF > GMAX_TRT
                    Wrseq Using [FER]
                    Wrseq "Attention : nombre de traitements" - num$(GNBTRTADX) - "supÃĐrieur au max" - num$(GMAX_TRT)  Using [FER]
                    Break
                Endif

                If mod(NF,100)=0
                     Call TEMPON("V.CALL 1Â° : " + num$(NF) + "/" + num$(min(GNBTRTADX,LIMITE1)) - GTTRAITEMENTS(NF) + ".src" -
&                    "Err" - num$(NBERREUR)) From GESECRAN
                Endif

                Gosub RECHSUBP

            Next NF

            NS1 += 1
            NG1 += 1
            GVALCBO(1) = NS1
            GVALCBO(2) = NG1

            NF = min(GNBTRTADX, LIMITE1) + 1
            If NS1 <= GMAX_SOUSPRO
                GTPPTPRO(NF)=NS1
            Else
                NS1 = GMAX_SOUSPRO
            Endif
            GTPPTGOS(NF)=NG1 : # A voir
        Endif
    Endif


#-------------------------------------------------------------------------------------------#
# 2ÃĻme passe => Analyse des Call : nombre et type d'arguments, variables globales et locales
#-------------------------------------------------------------------------------------------#

    # erreur traitÃĐe en passe nÂ° 1 : inutile de passer en nÂ° 2
    If (PNUMERREUR > 0 and PNUMERREUR < 5) or PNUMERREUR = 15 or PNUMERREUR = 17  or
&       PNUMERREUR = 18  or PNUMERREUR = 19  or PNUMERREUR = 20
        Goto FINPASSE2
    Endif
    If PACTION = 3
        Goto FINPASSE2
    Endif

    NBPASSE=2


    If PNUMERREUR and PACTION <> 1
        If GBTWARNING(1, PNUMERREUR)
            Wrseq func AVERIFSRC.MESNUM(49, 144, num$(PNUMERREUR), "", "", "", "")  Using [FWR]
        Else
            Wrseq func AVERIFSRC.MESNUM(49, 144, num$(PNUMERREUR), "", "", "", "")  Using [FER]
        Endif
    Endif
    Raz TRTUTILISE, TRTUTILDANS, POSUTIL
    NBTRAITES = 0

    WBWARNING = 0
    Call TEMPON("V.CALL 2ÃĻme passe : ") From GESECRAN


    If NOMTRT <> "" and instr(1, NOMTRT, "*") = 0
        NF = func FINDTRT(NOMTRT, 1, GNBTRTADX)
        If NF
            Gosub ANALYSE
        Endif
    Else

        For NF=1 To min(GNBTRTADX, LIMITE2)
            If NF > GMAX_TRT
                Wrseq Using [FER]
                Wrseq Using [FER]
                Wrseq "Attention : nombre de traitements" - num$(GNBTRTADX) - "supÃĐrieur au max" - num$(GMAX_TRT)  Using [FER]
                Break
            Endif

            If PATCH = "" | filinfo(SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0) > 0
                If mod(NF,100) = 0
                    If PNUMERREUR or PTRIPARMODULE = 2
                        Call TEMPON("V.CALL 2Â° : " + num$(NF) + "/" + num$(GNBTRTADX) - GTTRAITEMENTS(NF) + ".src" -
&                                "module" - num$(PMODULE)) From GESECRAN
                    Else
                        Call TEMPON("V.CALL 2Â° : " + num$(NF) + "/" + num$(GNBTRTADX) - GTTRAITEMENTS(NF) + ".src" -
&                              "Err" - num$(NBERREUR)) From GESECRAN
                    Endif
                Endif

                Gosub ANALYSE
            Endif
        Next NF
    Endif

$FINPASSE2


#-------------------------------------------------------------------------------------------#
# 3ÃĻme passe => Si patch, analyse des Call depuis les trt non patchÃĐs vers les trt patchÃĐs
#-------------------------------------------------------------------------------------------#

    If PATCH <> ""
        NBPASSE = 3
        NBTRAITES = 0


        Wrseq Using [FER]
        Wrseq Using [FER]
        Wrseq "TroisiÃĻme passe" - time$ - "--------------------------------------------------------------------" Using [FER]
        Wrseq "Analyse des traitements non patchÃĐs par rapport aux traitements patchÃĐs" Using [FER]
        Wrseq Using [FER]

        Wrseq Using [FWR]
        Wrseq Using [FWR]
        Wrseq "TroisiÃĻme passe" - time$ - "--------------------------------------------------------------------" Using [FWR]
        Wrseq "Analyse des traitements non patchÃĐs par rapport aux traitements patchÃĐs" Using [FWR]
        Wrseq Using [FWR]


        Call TEMPON("V.CALL 3Â° : ") From GESECRAN

        For NF=1 To min(GNBTRTADX, LIMITE2)
            If NF > GMAX_TRT
                Wrseq Using [FER]
                Wrseq Using [FER]
                Wrseq "Attention : nombre de traitements" - num$(GNBTRTADX) - "supÃĐrieur au max" - num$(GMAX_TRT)  Using [FER]
                Break
            Endif

            If mod(NF,100)=0
                Call TEMPON("V.CALL 3Â° : "+num$(NF)+"/"+num$(min(GNBTRTADX, LIMITE1)) - GTTRAITEMENTS(NF) + ".src") From GESECRAN
            Endif
            If filinfo(SRCPATCH + "/" + GTTRAITEMENTS(NF)+".src",0) <= 0
                Gosub ANALYSE
            Endif
        Next NF

        Wrseq Using [FER]
        Wrseq Using [FER]
        Wrseq num$(NBERREUR) - "erreurs sur" - num$(NBTRAITES) - "sources contrÃīlÃĐs." Using [FER]
        Wrseq "Fin de 3Â° passe." - time$ Using [FER]
        Wrseq Using [FER]
        Wrseq Using [FER]
    Endif

    adxifs=ZADXIFS : adxirs=ZADXIRS

    If PACTION = 0 or PACTION = 4
        Wrseq Using [FER]
        Wrseq Using [FER]
        Wrseq func AVERIFSRC.MESNUM(45, 144, num$(NBERREUR), num$(NBTRAITES), "", "", "")  Using [FER]
        Wrseq Using [FER]




        Wrseq Using [FWR]
        Wrseq Using [FWR]
        Wrseq func AVERIFSRC.MESNUM(45, 144, num$(NBWARNING), num$(NBTRAITES), "", "", "")  Using [FWR]
        Wrseq Using [FWR]
    Endif


# ____________________________________________________________________________________________________________________


    NBERRTOT += NBERREUR
    NBWARTOT += NBWARNING

    If PACTION = 0 or PACTION = 4
        If PNUMERREUR
            If PNUMERREUR = 17 or PNUMERREUR = 18 or PNUMERREUR = 19
                IR = 17
                ILF = 19
            Else
                IR = PNUMERREUR
                ILF = PNUMERREUR
            Endif
        Else
            IR = 1
            ILF = GNBERREUR(GNUMMOUL)
        Endif
        Call RECAPMOUL(IR, ILF, TERREUR) From AVERIFSRC
    Endif

    Close File [ATY]
    Close File [ASU]
    Close File [AGB]
    Close File [ATZ]

    Close File [ATB]
    Close File [AMZ]
    Close File [AMK]
    Close File [AMK1]

    If clalev ([F:ASP])
        Close File[ASP]
    Endif


    # recherche des traitements non appelÃĐs
    If PACTION = 1
        Gosub INUTILISE
    Endif

    Close File [ADC]
    Close File [AST]

    If PACTION = 0 or PACTION = 4
        Wrseq Using [FER]
        Wrseq func AVERIFSRC.MESNUM(46, 144, PLIBVERIF, "", "", "", "") - time$  Using [FER]
        Wrseq Using [FER]

        Openo  Using [FER]

        Wrseq Using [FWR]
        Wrseq func AVERIFSRC.MESNUM(46, 144, PLIBVERIF, "", "", "", "") - time$  Using [FWR]
        Wrseq Using [FWR]

    Endif
    If PACTION <> 3
        Openo  Using [FWR]
    Endif

    Call TEMPOFF From GESECRAN

    GVALCBO(8) = NBVARGLOB + DEPAS_VARGLOB
    GVALCBO(9) = NBVARGLOBDIC
    GVALCBO(10) = NBVARGLOBSRC

    Goto FINCALL
#------------------------------------------------------------------------------------------------------------------------#

$ECRDEB
    Wrseq
    Wrseq
    Wrseq
    Wrseq "-------------------------###" - func AVERIFSRC.MESNUM(48, 144, PLIBVERIF, "", "", "", "") - ". ###---------------------------"
    Wrseq
    Wrseq
Return


#------------------------------------------------------------------#
# Recherche et analyse des Subprog dans un traitement (1ÃĻre passe)
# Constitution de la table des variables globales
#------------------------------------------------------------------#
$RECHSUBP

    NS1+=1
    NG1+=1
    If NS1 <= GMAX_SOUSPRO
        GTPPTPRO(NF)=NS1 : # Pointeur vers sous-programme courant
    Endif

    GTPPTGOS(NF)=NG1
    NS2=0
    NG2=0


    #--- Si source inexistant, ou commence X/Y/Z, ou dans les exceptions => fin ---#
    If filinfo(filpath("TRT", GTTRAITEMENTS(NF), "src", DOSSIER2), 0) < 0
        If PACTION <> 3
            Wrseq func AVERIFSRC.MESNUM(50, 144, GTTRAITEMENTS(NF), "", "", "", "") Using [FER]
        Endif
        Return
    Endif

    If find(GTTRAITEMENTS(NF),EXCEPTTRT(1..NEX1))
        Return
    Endif




    TITAECRIRE = 1
    TITAECRIREW = 1


    NBTRAITES += 1

    #--- On traite le source ---#

    If PATCH <> "" and filinfo(SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0) > 0
       Openi SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0
    Else
       Openi filpath("TRT", GTTRAITEMENTS(NF), "src", DOSSIER2), 0
    Endif

    Raz WFILE, WABREV, WIGNWRSEQ, WIGNWRTRT, ERRMES, WMIGRATE

    # Recherche du module
    Read [ADC]ADC0=GTTRAITEMENTS(NF)
    If fstat
        [F:ADC]MODULE = 0
    Endif

    # BoolÃĐen pour dire si on peut traiter l'erreur en fonction du module sÃĐlectionnÃĐ et celui du traitement...
    # si PTRIPARMODULE = 2, la phase 1 est globale : donc on doit sortir les erreurs qq le module
    WMODULEOK = 0
    If DOSSIER = "INDUSPRD"
        WMODULEOK = 1
    Else
        If (PMODULE = 0 and ((EXCLSUP = 2 and [F:ADC]MODULE <> 1) or EXCLSUP <> 2)) or
&           PMODULE = [F:ADC]MODULE or
&           PTRIPARMODULE = 2

            WMODULEOK = 1
        Endif
    Endif

    If PMODULE = 0
        If NOMTRT = "" or NOMTRT = "*"
        Elsif instr(1, NOMTRT, "*")
            If pat(GTTRAITEMENTS(NF), NOMTRT) = 0
                WMODULEOK = 0
            Endif
        Else
            If NOMTRT <> GTTRAITEMENTS(NF)
                WMODULEOK = 0
            Endif
        Endif
    Endif

    FST=0
    NLIG = -1
    NLIGSAV = -1
    CHAINELEC = ""
    BCHAINELEC = 0

    While FST=0
        Call LIREETFMT(CHAINE, CHAINELEC, BCHAINELEC, FST, NLIG, NSK, NSKLEC) From AVERIFSRC
        Call VIRECOMCHK (CHAINE, 0, 0, WFILE, WABREV, WIGNWRSEQ, WIGNWRTRT, WMIGRATE) From AVERIFSRC
        # CBO 20110124 FQ70150
        If WIGNWRTRT >= 20 and WIGNWRTRT < 30
            WIGNWRTRT -= 20
        Elsif WIGNWRTRT >= 30 and WIGNWRTRT < 40
            WIGNWRTRT -= 30
        Endif
        If WIGNWRTRT = 3 #or (WIGNWRTRT = 1 and GTTRAITEMENTS(NF) = "AVERIFSRC")
            GNBPROGUNUSED += 1
            GVALCBO(7) += 1
            GTPROGUNUSED(GNBPROGUNUSED) = GTTRAITEMENTS(NF)
            Return
        Endif

        CHAININS = CHAINE
        CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
        While CHAINE <> ""

            # mÃĐmo de la chaine intacte (complÃĻte avant traitement pour test sur DBGAFF)
            CHAINECPT = CHAINE

            If pat(CHAINE,"*Subprog*")
                #If GTTRAITEMENTS(NF)="SELOBJ" & pat(CHAINE,"*SELECT*") : dbgmode=1 : Dbgaff : Endif


                Gosub ANASUBP
            Elsif pat(CHAINE,"*Global*")
               Gosub ANAVARGLOB
            Elsif pat(CHAINE,"*Funprog*")
               Gosub ANAFUNP
            Elsif left$(CHAINE, 1)="$"
                Gosub ANAETIQ
            Elsif vireblc(CHAINE, 3) = vireblc(CHAINE, 4) and
&                 toupper(CHAINE) = CHAINE and CHAINE <> "" : # Si un seul mot majuscule
                Gosub ANAETIQ
            Endif

            CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
        Wend

    Wend

Return


# analyse de SUBPROG (charge)________________________________________________________________
$ANASUBP


    IP = instr(1, CHAINE, 'Subprog')
    CHAINE=right$(CHAINE, IP + len("Subprog") + 1)
    CHAINE1 = vireblc(CHAINE, 0)

    NOMCALL=""
    # CBO 2011.02.07
    NOMCALL = func CHALPHA(CHAINE1, IP)
    If NOMCALL <> ""
        NBSP += 1
        NS2  += 1
        If NS2 > 10
            NS1 += 1
            NS2  = 1
        Endif
        If NS1 > GMAX_SOUSPRO
            Return
        Endif
        GTSOUSPRO(NS2, NS1)=NOMCALL

        GTTYPARG(0,NS2,NS1)=0
        Raz TABARG, ARGUMENTS, NBARG, TNOMARG, WADRVAL
        IR=instr(1,CHAINE,"(")
        If IR
            CHAINE=right$(CHAINE,IR+1)
            CHAINE=vireblc(CHAINE,0)
            Repeat
                Gosub ANAVAR
            Until left$(CHAINE,1) = ")" or CHAINE = ""
        Endif

        WBSUBPROG = 1
        Gosub ANADECLAR

        If WERRTEXTE and WMODULEOK and WIGNWRTRT = 0 and PACTION <> 3
            ERRMES(1) =  func AVERIFSRC.MESNUM(67, 144, NOMCALL, "", "", "", "")
            Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                      CHAINECPT, NBERREUR, NBWARNING, NLIG, 15, TERREUR, SAUVEMODULE, PNUMERREUR,
&                      NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
        Endif
    Endif

Return

# analyse de $ÃĐtiquette (charge) ________________________________________________________________
$ANAETIQ


    If left$(CHAINE,1)="$"
        CHAINE = right$(CHAINE, 2)
    Endif

    NOMCALL = vireblc(CHAINE, 4)

    If NOMCALL <> ""
        NBGS += 1
        NG2  += 1
        If NG2 > 10
            NG1 += 1
            NG2 = 1
        Endif
        If NG1 <= GMAX_SOUSPRO
            GTGOS(NG2, NG1) = NOMCALL
        Elsif NG1 <= 2 * GMAX_SOUSPRO
            GTGOSB(NG2, NG1 - GMAX_SOUSPRO) = NOMCALL
        Elsif NG1 <= 3 * GMAX_SOUSPRO
            GTGOSC(NG2, NG1 - (2 * GMAX_SOUSPRO)) = NOMCALL
        Endif
    Endif
Return


# analyse de FUNPROG (charge) ________________________________________________________________
$ANAFUNP

    IP=instr(1,CHAINE,'Funprog')
    CHAINE = right$(CHAINE, IP + len("Funprog") + 1)
# opti    CHAINE1=vireblc(CHAINE,0)
    CHAINE1 = CHAINE
    NOMCALL=""

    NOMCALL = func CHALPHA(CHAINE1, IP)
    If NOMCALL = ""
        Return
    Endif

    NBSP+=1
    NS2+=1
    If NS2>10
        NS1+=1
        NS2=1
    Endif

    If NS1 > GMAX_SOUSPRO
        Return
    Endif
    GTSOUSPRO(NS2, NS1) = NOMCALL
    GTTYPFUNP(NS2, NS1) = 4 : # IndÃĐterminÃĐ, dans un premier temps
    GTTYPARG(0,NS2, NS1) = 0
    Raz TABARG, ARGUMENTS, NBARG, TNOMARG, WADRVAL
    IR=instr(1,CHAINE,"(")
    If IR
        CHAINE=right$(CHAINE,IR+1)
        CHAINE=vireblc(CHAINE,0)
      Repeat
          Gosub ANAVAR
      Until left$(CHAINE,1)=")" or CHAINE=""
    Endif

    WBSUBPROG = 0
    Gosub ANADECLAR

# On commence le tableau des variables locales (pour pouvoir identifier le type de la fonction)
    For NBVARLOCCBO=0 To NBARG-1
        TVARLOC(NBVARLOCCBO+1) = TABARG(NBVARLOCCBO+1)
        TYPVARLOC(NBVARLOCCBO+1) = GTTYPARG(NBVARLOCCBO+1,NS2,NS1)
    Next NBVARLOCCBO
    NBVARLOC = NBVARLOCCBO

    If WTYFC = -1
        # exclusion de superviseur pour ce cas...
        If WMODULEOK and WIGNWRTRT = 0 and PACTION <> 3 and PDEMANDEUR = 0
            ERRMES(1) = NOMCALL - ":" - mess(1001, 144, 1)
            Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                         CHAINECPT, NBERREUR, NBWARNING, NLIG, 1, TERREUR, SAUVEMODULE, PNUMERREUR,
&                         NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
        Endif
        WTYFC = 0
    Endif
    If WTYFC = -2

        If WMODULEOK and WIGNWRTRT = 0 and PACTION <> 3
            ERRMES(1) = NOMCALL - ":" - mess(1002, 144, 1)
            Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                          CHAINECPT, NBERREUR, NBWARNING, NLIG, 2, TERREUR, SAUVEMODULE, PNUMERREUR,
&                          NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)

        Endif
        WTYFC = 0
    Endif
    If WERRTEXTE and WMODULEOK and WIGNWRTRT = 0 and PACTION <> 3
        ERRMES(1) = NOMCALL - ":" - mess(1015, 144, 1)
        Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                      CHAINECPT, NBERREUR, NBWARNING, NLIG, 15, TERREUR, SAUVEMODULE, PNUMERREUR,
&                      NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
    Endif

    GTTYPFUNP(NS2,NS1) = WTYFC

    NBARG+=1 : # On va considÃĐrer la valeur de fin comme un argument "de plus"
    Gosub ANAEND

    If GTTYPFUNP(NS2,NS1) = 0
        GTTYPFUNP(NS2,NS1)=ARGUMENTS(NBARG)
    Else
        If ARGUMENTS(NBARG) and ARGUMENTS(NBARG) <> 4 and ARGUMENTS(NBARG) <> GTTYPFUNP(NS2,NS1)

            If WMODULEOK and WIGNWRTRT = 0  and PACTION <> 3
#CBO 20110509 FQ73715
                ERRMES(1) = func AVERIFSRC.MESNUM(68, 144, NOMCALL, func TYPEDATA(GTTYPFUNP(NS2,NS1)), "", "", "")
                ERRMES(2) = func AVERIFSRC.MESNUM(69, 144, func TYPEDATA(ARGUMENTS(NBARG)), "", "", "", "")
                Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                              CHAINECPT, NBERREUR, NBWARNING, NLIG, 3, TERREUR, SAUVEMODULE, PNUMERREUR,
&                              NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
            Endif
            # a priori, l'argument calculÃĐ est plus juste que celui du dico
            GTTYPFUNP(NS2,NS1) = ARGUMENTS(NBARG)
        Endif
    Endif


    If GTTYPFUNP(NS2,NS1) = 0
        GTTYPFUNP(NS2,NS1) = 4 : # IndÃĐterminÃĐ, dans un dernier temps
    Endif

Return


# ________________________
$ANAVAR

    If left$(CHAINE,1)<>")"
        NBARG+=1
    Endif : # Subprog TOTO() n'a pas d'argument !

    Repeat
        CHAINE=vireblc(CHAINE, 0)
        If left$(CHAINE,1)=")" : # On va sortir
        Elsif func DEBALPHA(CHAINE) : # On trouve une variable
#        Elsif instr(1, ALPHA, left$(CHAINE,1)) : # On trouve une variable
#            IS=len(CHAINE)-len(vireblc(ctrans(CHAINE,ALPHAN,SPACEN),0))

            If NBARG > GMAX_NBPAR
                If NBARG < GMAX_NBPAR + 10
                    Wrseq "9277" - GTTRAITEMENTS(NF) - "Ligne" - num$(NLIG) - "Trop d'arguments" - num$(NBARG) Using [FWR]
                    Wrseq "9277" - CHAINECPT Using [FWR]
                Endif
            Else
                TABARG(NBARG) = func CHALPHA(CHAINE, IS)
#                TABARG(NBARG)=vireblc(left$(CHAINE,IS),2)
                CHAINE=right$(CHAINE,IS+1)
            Endif
        Elsif left$(CHAINE,1)="(" : # On empile/dÃĐpile les parenthÃĻses
              NBPARENTH=1
              Repeat
                 CHAINE=right$(CHAINE,2)
                 NBPARENTH+=(left$(CHAINE,1)="(")-(left$(CHAINE,1)=")")
              Until NBPARENTH=0 or CHAINE=""
              CHAINE=right$(CHAINE,2)
        Elsif left$(CHAINE,1)="," : # Changement d'argument
              NBARG+=1
              CHAINE=right$(CHAINE,2)
        Else  CHAINE=right$(CHAINE,2)
        Endif
    Until left$(CHAINE,1)=")" or CHAINE=""
    GTTYPARG(0,NS2,NS1)=NBARG
Return


# ________________________
$ANADECLAR

#------------------------------------------------------#
# Analyse des dÃĐclarations et typage des variables
#------------------------------------------------------#

    Raz NUMARGDECL, TABARGDECL
    FST = 0
    While FST = 0

        Call LIREETFMT(CHAINE, CHAINELEC, BCHAINELEC, FST, NLIG, NSK, NSKLEC) From AVERIFSRC
        Call VIRECOMMEN(CHAINE) From AVERIFSRC

        NSK_SAV = NSK
        NLIG_CALL = NLIG - 1

        CHAININS2 = CHAINE
        CHAINE = func AVERIFSRC.DECOUPCH (CHAININS2, WIGNWRSEQ)


        While CHAINE <> "" and FST = 0

            WADRVAL(0) = 0
            IS = instr(1, CHAINE, "Value ")
            If IS = 0
                IS = instr(1, CHAINE, "Variable ")
                If IS = 0
                    IS = instr(1, CHAINE, "Const ")
                    If IS
                        IS += len("Const ")
                        WADRVAL(0) = 3
                    Endif
                Else
                    IS += len("Variable ")
                    WADRVAL(0) = 1
                Endif
            Else
                IS += len("Value ")
                WADRVAL(0) = 2
            Endif

            # on n'est pas sur une dÃĐclaration : on a donc fini...
            If IS = 0
                # recherche du type de la fonction et du nombre + type et mode  de passage des paramÃĻtres
                Call TYPEFONCTION (GTTRAITEMENTS(NF), NOMCALL, WTYFC, TDTYPARG, TDADRVAL,WBTABLEASP)

                If NBARG > GVALCBO(6)
                    GVALCBO(6) = NBARG
                Endif
                For IS=1 To NBARG
                    If GTTYPARG(IS,NS2,NS1)=0
                        GTTYPARG(IS,NS2,NS1)=4

                        If WMODULEOK and WIGNWRTRT = 0 and PACTION <> 3

                            If TABARGDECL(IS) <> "" and TABARGDECL(IS) <> TABARG(IS)
                            If WBSUBPROG
                                ERRMES(1) = func AVERIFSRC.MESNUM(70, 144, NOMCALL, num$(IS), TABARG(IS), TABARGDECL(IS), "")
                            Else
                                ERRMES(1) = func AVERIFSRC.MESNUM(71, 144, NOMCALL, num$(IS), TABARG(IS), TABARGDECL(IS), "")
                            Endif
                            Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE,
&                                TITAECRIREW, CHAINECPT, NBERREUR, NBWARNING, NLIG, 20, TERREUR, SAUVEMODULE,
&                                PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
                            Else
                            If WBSUBPROG
                                ERRMES(1) = func AVERIFSRC.MESNUM(72, 144, NOMCALL, num$(IS), TABARG(IS), "", "")
                            Else
                                ERRMES(1) = func AVERIFSRC.MESNUM(73, 144, NOMCALL, num$(IS), TABARG(IS), "", "")
                            Endif

                            Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE,
&                                TITAECRIREW, CHAINECPT, NBERREUR, NBWARNING, NLIG, 4, TERREUR, SAUVEMODULE,
&                                PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
                            Endif
                        Endif
                    Elsif WMODULEOK and WTYFC > 0 and GTTYPARG(IS, NS2, NS1) <> TDTYPARG(IS) and WIGNWRTRT = 0 and PACTION <> 3

                        If WBSUBPROG
                            ERRMES(1) = func AVERIFSRC.MESNUM(74, 144, NOMCALL, num$(IS), TABARG(IS), mess(GTTYPARG(IS, NS2, NS1), 33, 1), mess(TDTYPARG(IS), 33, 1))
                        Else
                            ERRMES(1) = func AVERIFSRC.MESNUM(75, 144, NOMCALL, num$(IS), TABARG(IS), mess(GTTYPARG(IS, NS2, NS1), 33, 1), mess(TDTYPARG(IS), 33, 1))
                        Endif
                        Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE,
&                            TITAECRIREW, CHAINECPT, NBERREUR, NBWARNING, NLIG, 17, TERREUR, SAUVEMODULE,
&                            PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
                    Elsif WMODULEOK and WTYFC > 0 and WADRVAL(IS) <> TDADRVAL(IS) and WIGNWRTRT = 0 and PACTION <> 3

                        If WBSUBPROG
                            ERRMES(1) = func AVERIFSRC.MESNUM(76, 144, NOMCALL, num$(IS), TABARG(IS), mess(WADRVAL(IS), 34, 1), mess(TDADRVAL(IS), 34, 1))
                        Else
                            ERRMES(1) = func AVERIFSRC.MESNUM(77, 144, NOMCALL, num$(IS), TABARG(IS), mess(WADRVAL(IS), 34, 1), mess(TDADRVAL(IS), 34, 1))
                        Endif
                        Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE,
&                            TITAECRIREW, CHAINECPT, NBERREUR, NBWARNING, NLIG, 18, TERREUR, SAUVEMODULE,
&                            PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)

                    Endif


                Next I
                If WTYFC > 0 and [F:ASU]NBRPAR <> NBARG and WMODULEOK and WIGNWRTRT = 0 and PACTION <> 3

                    ERRMES(1) = func AVERIFSRC.MESNUM(78, 144, NOMCALL, num$(NBARG), num$([F:ASU]NBRPAR), "", "")
                    Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE,
&                        TITAECRIREW, CHAINECPT, NBERREUR, NBWARNING, NLIG, 19, TERREUR, SAUVEMODULE,
&                        PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
                Endif

                NSK = NSK_SAV
                Seek First+NSK_SAV
                CHAINELEC = ""
                BCHAINELEC = 0
                NLIG = NLIG_CALL
                Return
            Endif

            CHAINE = vireblc(right$(CHAINE, IS), 0)

            # CBO STRUCT
            If IS
                IS = instr(1, CHAINE, "Struct ")
                If IS = 0
                    IS = instr(1, CHAINE, "STRUCT ")
                Endif
                If IS
                    CHAINE = right$(CHAINE, IS + 7)
                    IS = instr(1, CHAINE, "Using")
                    If IS = 0
                        IS = instr(1, CHAINE, "USING")
                    Endif

                    If IS
                        CHAINE = left$(CHAINE, IS - 2)
                    Endif
                Endif
            Endif
            # fin CBO STRUCT


            If    pat(CHAINE,"Libelle *")<>0 or pat(CHAINE,"Shortint *")<>0
&               or pat(CHAINE,"Integer *")<>0 or pat(CHAINE,"Decimal *")<>0
                TYPCOUR=2 : # NumÃĐrique
            Elsif pat(CHAINE,"Date *")<>0
                TYPCOUR=3 : # Date
            Elsif pat(CHAINE,"Char *")<>0
                TYPCOUR=1 : # Chaine
            Elsif pat(CHAINE,"Clbfile *")<>0
                TYPCOUR=5 : # Clob
            Elsif pat(CHAINE,"Blbfile *")<>0
                TYPCOUR=6 : # Blob
            Else
              TYPCOUR=4 : # IndÃĐterminÃĐ
            Endif

            If TYPCOUR <>4
                CHAINE = right$(CHAINE, instr(1, CHAINE," ") + 1)
            Endif

            Repeat
                CHAINE=vireblc(CHAINE, 0)
                If CHAINE<>"" & func DEBALPHA(CHAINE)
#                If CHAINE<>"" & instr(1,ALPHA,left$(CHAINE,1)) : # On trouve une variable
                    VARIA = func CHALPHA(CHAINE, IS)
#                    IS=len(CHAINE)-len(vireblc(ctrans(CHAINE,ALPHAN,SPACEN),0))
#                    VARIA=vireblc(left$(CHAINE,IS),2)
                    CHAINE=right$(CHAINE,IS+1)
                    NUMARGDECL += 1

                    IS = find(VARIA, TABARG(1..NBARG))
                    If IS
                        GTTYPARG(IS,NS2,NS1)=TYPCOUR
                        WADRVAL(IS) = WADRVAL(0)
                    Else
                        TABARGDECL(NUMARGDECL) = VARIA
                    Endif
                Elsif left$(CHAINE,1)="(" : # On empile/dÃĐpile les parenthÃĻses
                    NBPARENTH=1
                    CHAINE=right$(CHAINE,2)
                    Repeat
                        CHAINE=right$(CHAINE,min(instr(1,CHAINE+"(","("),instr(1,CHAINE+")",")")))
                        NBPARENTH+=(left$(CHAINE,1)="(")-(left$(CHAINE,1)=")")
                        CHAINE=right$(CHAINE,2)
                    Until NBPARENTH=0 or CHAINE=""
                Elsif left$(CHAINE,1)<>")" : # On va sortir sinon
                    CHAINE=right$(CHAINE,2)
                Endif
            Until left$(CHAINE,1)=")" or CHAINE=""



            CHAINE = func AVERIFSRC.DECOUPCH (CHAININS2, WIGNWRSEQ)
        Wend
    Wend
Return

#----------------------------------------------------------------#
# Recherche des End valeur et analyse au moins partielle
# Pour essayer d'affecter GTTYPFUNP(NS2,NS1) Ã  autre chose que 4
# Au passage, on analyse de faÃ§on succincte les variables locales
# Fonction dÃĐrivÃĐe de ANAVARLOC, qui sera fait dans la phase
# d'analyse globale
#----------------------------------------------------------------#
$ANAEND

    FST = 0
    NSK_SAV = NSK
    NLIG_CALL = NLIG

    While FST = 0

        Call LIREETFMT(CHAINE, CHAINELEC, BCHAINELEC, FST, NLIG, NSK, NSKLEC) From AVERIFSRC
        Call VIRECOMMEN(CHAINE) From AVERIFSRC

        CHAININS2 = CHAINE
        CHAINE = func AVERIFSRC.DECOUPCH (CHAININS2, WIGNWRSEQ)

        While CHAINE <> "" and FST = 0

            IS = instr(1, CHAINE, "End ")
            If IS : # On a trouvÃĐ un argument
                CHAINE = vireblc(right$(CHAINE, IS+3),0)
                Gosub ANAEXPR
                Seek First+NSK_SAV
                CHAINELEC = ""
                BCHAINELEC = 0
                NLIG = NLIG_CALL
                Return
            Endif

            If instr(1,CHAINE,"Funprog") : # Chou blanc, pas vu de End !
                ARGUMENTS(NBARG)=4 : # IndÃĐterminÃĐ
                Seek First+NSK_SAV
                CHAINELEC = ""
                BCHAINELEC = 0
                NLIG = NLIG_CALL
                Return
            Elsif instr(1,CHAINE,"Subprog") : # Chou blanc, pas vu de End !
                ARGUMENTS(NBARG)=4 : # IndÃĐterminÃĐ
                Seek First+NSK_SAV
                CHAINELEC = ""
                BCHAINELEC = 0
                NLIG = NLIG_CALL
                Return
            Endif

            If pat(CHAINE,"*Libelle *")
                CHAINE=vireblc(right$(CHAINE,instr(1,CHAINE,"Libelle")+8),0)
                TYPCOUR=2
                Gosub RECHVL
            Elsif pat(CHAINE,"*Shortint *")
                CHAINE=vireblc(right$(CHAINE,instr(1,CHAINE,"Shortint")+8),0)
                TYPCOUR=2
                Gosub RECHVL
            Elsif pat(CHAINE,"*Integer *")
                CHAINE=vireblc(right$(CHAINE,instr(1,CHAINE,"Integer")+7),0)
                TYPCOUR=2
                Gosub RECHVL
            Elsif pat(CHAINE,"*Decimal *")
                CHAINE=vireblc(right$(CHAINE,instr(1,CHAINE,"Decimal")+7),0)
                TYPCOUR=2
                Gosub RECHVL
            Elsif pat(CHAINE,"*Date *")
                CHAINE=vireblc(right$(CHAINE,instr(1,CHAINE,"Date")+4),0)
                TYPCOUR=3
                Gosub RECHVL
            Elsif pat(CHAINE,"*Char *")
                CHAINE=vireblc(right$(CHAINE,instr(1,CHAINE,"Char")+4),0)
                TYPCOUR=1
                Gosub RECHVL
            Elsif pat(CHAINE,"*Clbfile *")
                CHAINE=vireblc(right$(CHAINE,instr(1,CHAINE,"Clbfile")+7),0)
                TYPCOUR=5
                Gosub RECHVL
            Elsif pat(CHAINE,"*Blbfile *")
                CHAINE=vireblc(right$(CHAINE,instr(1,CHAINE,"Blbfile")+7),0)
                TYPCOUR=6
                Gosub RECHVL
            Endif

            CHAINE = func AVERIFSRC.DECOUPCH (CHAININS2, WIGNWRSEQ)
        Wend
    Wend

    Seek First+NSK_SAV
    CHAINELEC = ""
    BCHAINELEC = 0
    NLIG = NLIG_CALL

Return


$RECHVL : # DÃĐrivÃĐ de RECHVALOC, simplifiÃĐ pour obtenir les var dÃĐclarÃĐes ds la fct et pouvoir dÃĐfinir le type de la fct


#    While CHAINE<>"" & instr(1, ALPHA, left$(CHAINE,1)) : # On trouve une variable locale
    While CHAINE<>"" and func DEBALPHA(CHAINE) : # On trouve une variable locale
       # IS=len(CHAINE)-len(vireblc(ctrans(CHAINE,ALPHAN,SPACEN),0))
       # VARIA=vireblc(left$(CHAINE,IS),2)
        VARIA = func CHALPHA(CHAINE, IS)
        CHAINE=vireblc(right$(CHAINE,IS+1),0)
        IS=find(VARIA, TVARLOC(1..NBVARLOC))
        If IS=0
            NBVARLOC += 1
            TVARLOC(NBVARLOC) = VARIA
            TYPVARLOC(NBVARLOC) = TYPCOUR
        Endif

        While left$(CHAINE,1)="(" : # On empile/dÃĐpile les parenthÃĻses
            NBPARENTH=1
            CHAINE=right$(CHAINE,2)
            Repeat
                CHAINE=right$(CHAINE,min(instr(1,CHAINE+"(","("),instr(1,CHAINE+")",")")))
                NBPARENTH+=(left$(CHAINE,1)="(")-(left$(CHAINE,1)=")")
                CHAINE=right$(CHAINE,2)
            Until NBPARENTH=0 or CHAINE=""
            CHAINE=vireblc(CHAINE,0)
        Wend
        If left$(CHAINE,1)="," : # Une autre variable suit
            CHAINE=vireblc(right$(CHAINE,2),0)
        Endif
    Wend
Return


#___________________________________________________________________________________________________________________
#----------------------------------#
# Analyse (2ÃĻme passe) (3ÃĻme passe)
#----------------------------------#
$ANALYSE

    BOK = func AVERIFSRC.SRCAPASTRAITER (GTTRAITEMENTS(NF), NOMTRT, DOSSIER2, PMODULE, EXCLSUP, PATCH,
&                          SRCPATCH, OWNER, TXTERR, PDEMANDEUR)
    If PACTION <> 1
        If BOK or find(GTTRAITEMENTS(NF), EXCEPTTRT(1..NEX1))
            If NBPASSE = 2
                TRTUTILISE(NF) = 1
                TRTUTILDANS(NF) = "---Exception---"
            Endif
            Return
        Endif
    Endif
    TITAECRIRE = 1
    TITAECRIREW = 1
    NBTRAITES += 1

    # On traite le source

    If PATCH="" | NBPASSE=3
        If filinfo(filpath("TRT", GTTRAITEMENTS(NF), "src", DOSSIER2), 0) < 0
            Return
        Endif
        Openi filpath("TRT", GTTRAITEMENTS(NF), "src", DOSSIER2), 0
    Else
        Openi SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0
    Endif

    Raz WFILE, WABREV, WIGNWRSEQ, WIGNWRTRT, ERRMES, SPENCOURS, WMIGRATE
    Raz TPGMEXISTE, NBPGMEXISTE, TVARLOC

    FST=0
    NLIG = -1
    NBVARLOC=0
    NLIGSAV = -1
    CHAINELEC = ""
    BCHAINELEC = 0
    While FST=0
        Call LIREETFMT(CHAINE, CHAINELEC, BCHAINELEC, FST, NLIG, NSK, NSKLEC) From AVERIFSRC
        Call VIRECOMCHK (CHAINE, 1, 0, WFILE, WABREV, WIGNWRSEQ, WIGNWRTRT, WMIGRATE) From AVERIFSRC
        # CBO 20110124 FQ70150
        If WIGNWRTRT >= 20 and WIGNWRTRT < 30
            WIGNWRTRT -= 20
        Elsif WIGNWRTRT >= 30 and WIGNWRTRT < 40
            WIGNWRTRT -= 30
        Endif

        If WIGNWRTRT = 1 or WIGNWRTRT = 3
            Return
        Endif

        CHAININS = CHAINE
        CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
        While CHAINE <> ""

            # mÃĐmo de la chaine intacte (complÃĻte avant traitement pour test sur DBGAFF)
            CHAINECPT = CHAINE

            If pat(CHAINE,"*Call*") and pat(toupper(CHAINE),"*CALLIU*") = 0
                NANA+=1
                Gosub ANALICALL
            Elsif pat(CHAINE,"*func*") and pat(toupper(CHAINE),"*FUNCIU*") = 0
                NANA+=1
                Gosub ANALIFUN
            Elsif pat(CHAINE, "*Gosub*")
                SPENCOURS = ""
                NANA+=1
                Gosub ANALIGOS
            Elsif pat(CHAINE, "*Subprog*") and PACTION <> 1
                NBVARLOC=0
                Gosub SPENCOURS
            Elsif pat(CHAINE, "*Funprog*") and PACTION <> 1
                NBVARLOC=0
                Gosub SPENCOURS
            Elsif pat(CHAINE, "*Dbgaff*") and PACTION <> 1      #CHECK IGNORE_LINE
                Gosub ANADBGAFF
            # recherche call etiquette from pgm
            Elsif pat(CHAINE, "Goto*From*") and PACTION <> 1


                IP = instr(1, CHAINE, "From")
                NOMCALL = left$(CHAINE, IP - 1)
                NOMCALL = vireblc(right$(NOMCALL, 6), 4)
                NOMPROG = vireblc(right$(CHAINE, IP + 5), 4)

                If func AVERIFSRC.NVDEMANDEUR (PDEMANDEUR, NOMPROG) = 1 and pat(NOMPROG,"AUT*") = 0

                    If NOMPROG <> GTTRAITEMENTS(NF)
                        ERRMES(1) = "Goto" - NOMCALL - "From" - NOMPROG
                        ERRMES(2) = mess(1021, 144, 1)
                        WECRERREUR = 21
                        Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                            CHAINECPT, NBERREUR, NBWARNING, NLIG, WECRERREUR, TERREUR, SAUVEMODULE,
&                            PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
                    Endif
                Endif

            Else
                If left$(CHAINE1,1)="$"
                    SPENCOURS = ""
                Endif

                If PACTION <> 1
                    While  pat(CHAINE,"*Local*") or pat(CHAINE,"*Variable*") or pat(CHAINE,"*Const*") or pat(CHAINE,"*Value*")
                        If pat(CHAINE,"*Local*")
                            Gosub ANAVARLOC
                        Elsif pat(CHAINE,"*Value*")
                            IS = 1
                            Gosub ANAPARLOC
                        Elsif pat(CHAINE,"*Variable*")

                            IS = 2
                            Gosub ANAPARLOC
                        Elsif pat(CHAINE,"*Const*")
                            IS = 3
                            Gosub ANAPARLOC
                        Endif
                    Wend
                Endif
            Endif

            CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)

            # sauvegarde pour analyse du DBGAFF
            CHAINESAV = CHAINECPT

        Wend
    Wend
Return


# note le dernier sous-pro ou funprog trouvÃĐ
$SPENCOURS


    IP = instr(1, CHAINE, 'Subprog')
    If IP = 0
        IP = instr(1, CHAINE, 'Funprog')
    Endif

    If IP
        CHAINE = right$(CHAINE, IP + 8)

        IP = instr(1, CHAINE, '(')
        If IP
            CHAINE = left$(CHAINE, IP - 1)
        Endif

        SPENCOURS = vireblc(CHAINE, 4)
    Endif
Return


# recherche les DBGAFF en ÃĐvitant les tests GUSER
$ANADBGAFF

    # TDBG contient les programmes qui ne doivent pas ÃŠtre testÃĐs
    If find (GTTRAITEMENTS(NF), TDBG) = 0

        # en env indus : on ne doit plus avoir de DBGAFF (source propre pour le client...)
        If PDEMANDEUR = 0 or
&         (PDEMANDEUR and
&          pat(CHAINESAV, "*If GUSER*") = 0 and
&          pat(CHAINESAV, "*If (GUSER*") = 0 and
&          pat(CHAINESAV, "*Else*") = 0 and
&          pat(CHAINESAV, "*Elsif GUSER*") = 0 and
&          pat(CHAINE, "*If GUSER*") = 0 and
&          pat(CHAINE, "*If (GUSER*") = 0 and
&          pat(CHAINE, "*Else*") = 0 and
&          pat(CHAINE, "*Elsif GUSER*") = 0)

            ERRMES(1) = "contient un DBGAFF"
            Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                          CHAINECPT, NBERREUR, NBWARNING, NLIG, 5, TERREUR, SAUVEMODULE, PNUMERREUR,
&                          NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
        Endif
    Endif

Return



#----------------------------------------------------#
# Analyse d'une ligne contenant une instruction Call ______________________________________________________________
#----------------------------------------------------#
$ANALICALL
    Raz WBVARGLOB, WPROGVARGLOB
    Call PURGECH("Call", CHAINE, 0) From AVERIFSRC
    IP = instr(1, CHAINE, 'Call')

    CHAINE = right$(CHAINE, IP + 1 + len("Call"))
    IQ=instr(1,CHAINE, "From")
    If IQ = 0
        IQ=instr(1,CHAINE," FROM")
        If IQ
            IQ += 1
        Endif
    Endif

    If IQ
        CHAINE1 = vireblc(right$(CHAINE,IQ+len("From")),2)
        NOMPROG = func CHALPHA(CHAINE1, IS)
#        If instr(1, ALPHA, left$(CHAINE1, 1))
        If NOMPROG <> ""
#            IS=len(CHAINE1) - len(vireblc(ctrans(CHAINE1,ALPHAN,SPACEN),0))
#            NOMPROG=vireblc(vireblc(left$(CHAINE1,IS),2),3)

            If NOMPROG <> GTTRAITEMENTS(NF)
                POSUTIL = func FINDTRT(NOMPROG, 1, GNBTRTADX)
                If POSUTIL
                    TRTUTILISE(POSUTIL) = 1
                    If TRTUTILDANS(POSUTIL) = ""
                        TRTUTILDANS(POSUTIL) = GTTRAITEMENTS(NF)
                    Endif
                Endif
            Endif

        Elsif left$(CHAINE1,1) = "="
            Return : # On renonce Ã  l'analyse des Call ... From =
        Endif
# On renonce Ã  l'analyse sur des Call =... With ...
    Elsif instr(1, CHAINE, "With")<>0
        Return
    Else
        #Il n'y a pas de From
        NOMPROG=GTTRAITEMENTS(NF)
    Endif

    # inutile d'analyser le reste lors de cette option
    If PACTION = 1
        Return
    Endif

    If IQ
        CHAINE1=vireblc(left$(CHAINE, IQ - 1), 0)
    Else
        CHAINE1 = vireblc(CHAINE, 0)
    Endif
    NOMCALL=""
#    If instr(1,ALPHA,left$(CHAINE1,1))
#        IS=len(CHAINE1)-len(vireblc(ctrans(CHAINE1,ALPHAN,SPACEN),0))
#        NOMCALL=vireblc(vireblc(left$(CHAINE1,IS),2),3)
#    Endif
NOMCALL = func CHALPHA(CHAINE1, IS)
    If NOMCALL ="EXISTE_ADX"
        Gosub CHGPGMEXISTE
        Return
    Endif


    #--- Ici on a NOMCALL=SousPro et NOMPROG=Traitement du SousPro ---#
    # 3ÃĻ passe: si trt appelÃĐ n'existe pas dans le patch ou est diffÃĐrent du modÃĻle de trt Ã  analyser => exit
    If NBPASSE = 3 and (filinfo(SRCPATCH + "/" + NOMPROG + ".src", 0) <= 0 or pat(NOMPROG, NOMTRT) = 0)
        Return
    Endif
    # On vÃĐrifie si la Call Ã  analyser n'est pas dans les exceptions
    If NOMPROG <> GTTRAITEMENTS(NF)
        If find(GTTRAITEMENTS(NF) + '.' + NOMCALL + '.' + NOMPROG, EXCEPTTRT(1..NEX1))
            Return
        Endif

        # testÃĐ par EXISTE_ADX
        If find (NOMPROG, TPGMEXISTE(1..NBPGMEXISTE))
            Return
        Endif

        If [F:ADC]MODULE = 1 and find(NOMPROG, TEXCPGMSUP(1..NBEXCPGMSUP))
            Return
        Endif
    Endif

    IR=left$(vireblc(right$(CHAINE, len(NOMCALL) + 1), 2), 1) = "="
    If IR
        Return
    Endif

    Raz NBARG, ARGUMENTS, TABARG, TNOMARG
    IR=instr(1,CHAINE, "(")
    If IR
        CHAINE=right$(CHAINE, IR+1)
        Repeat

            Gosub ANARG
        Until left$(CHAINE,1)=")" or CHAINE=""
    Endif



    Raz ERRMES
    IT = 2
    WECRERREUR = 0
    If NOMPROG = GTTRAITEMENTS(NF)
        IP = NF
    Else
        IP = func FINDTRT(NOMPROG, 1, GNBTRTADX)
        If IP and GNBPROGUNUSED
            If find(NOMPROG, GTPROGUNUSED(1..GNBPROGUNUSED))
                IP = -1
            Endif
        Endif
    Endif



    ERRMES(1) = "Call" - NOMCALL - "From" - NOMPROG
    ERRMES(2) = ""
    If func AVERIFSRC.NVDEMANDEUR (PDEMANDEUR, NOMPROG) = 1 and pat(NOMPROG,"AUT*") = 0
        If IP = -1
            ERRMES(2) = func AVERIFSRC.MESNUM(79, 144, NOMPROG, "", "", "", "")
            WECRERREUR = 6
        Elsif IP = 0
            ERRMES(2) = func AVERIFSRC.MESNUM(80, 144, NOMPROG, "", "", "", "")
            WECRERREUR = 6
        Else
            IR=0
            For IQ=GTPPTPRO(IP) To GTPPTPRO(IP+1)-1
                If IQ = 0
                    Wrseq "7373 Traitement" - GTTRAITEMENTS(NF) - num$(NLIG) - "delta des PPTPRO" - num$(GTPPTPRO(IP)) - "et" - num$(GTPPTPRO(IP + 1) - 1) Using [FER]
                    Wrseq CHAINECPT Using [FER]
                    IR = 0
                    Break
                Endif
                IR = find(left$(NOMCALL, MAX_LENCALL), GTSOUSPRO(1..10,IQ))
                If IR
                    Break
                Endif
            Next IQ

            If IR=0
                ERRMES(2) = func AVERIFSRC.MESNUM(81, 144, NOMCALL, "", "", "", "")
                If find(NOMPROG,EXCEPTTRT(1..NEX1))
                    # S'il y a un mauvais appel de sous-pro vers un traitement dans les exceptions : avertissement
                    ERRMES(3)="Avertissement => " + NOMPROG + " fait partie des exceptions !"
                Else
                    WECRERREUR = 7

                    # recherche call etiquette from pgm
                    If func AVERIFSRC.NVDEMANDEUR (PDEMANDEUR, NOMPROG) = 1 and pat(NOMPROG,"AUT*") = 0
                        If IP
                            IR=0
                            For IQ=GTPPTGOS(IP) To GTPPTGOS(IP+1)-1
                                If IQ <= GMAX_SOUSPRO
                                    IR=find(left$(NOMCALL, MAX_LENCALL), GTGOS(1..10,IQ))
                                Elsif IQ <= 2 * GMAX_SOUSPRO
                                    IR=find(left$(NOMCALL, MAX_LENCALL), GTGOSB(1..10,IQ - GMAX_SOUSPRO))
                                Elsif IQ <= 3 * GMAX_SOUSPRO
                                    IR=find(left$(NOMCALL, MAX_LENCALL), GTGOSC(1..10,IQ - (2 * GMAX_SOUSPRO)))
                                Endif
                                If IR
                                    ERRMES(2) = mess(1022, 144, 1)
                                    WECRERREUR = 22
                                    Break
                                Endif
                            Next IQ

                        Endif
                    Endif
                Endif
            Else
                If NBARG <> GTTYPARG(0,IR,IQ)
                    ERRMES(2) = func AVERIFSRC.MESNUM(82, 144, num$(NBARG), num$(GTTYPARG(0,IR,IQ)), "", "", "")
                    WECRERREUR = 14
                Else
                    For IS=1 To NBARG
                        If GTTYPARG(IS,IR,IQ) <> ARGUMENTS(IS) & GTTYPARG(IS,IR,IQ) <> 4 & ARGUMENTS(IS) <> 4
                            # ne pas mettre en erreur les diffÃĐrences chaine/clob
                            If (GTTYPARG(IS,IR,IQ) <> 5 or ARGUMENTS(IS) <> 1) and (GTTYPARG(IS,IR,IQ) <> 1 or ARGUMENTS(IS) <> 5)

ERRMES(IT) = func AVERIFSRC.MESNUM(83, 144, num$(IS), TNOMARG(IS), func TYPEDATA(ARGUMENTS(IS)), func TYPEDATA(GTTYPARG(IS,IR,IQ)), "")
                                If WBVARGLOB(IS) = 2
                                    ERRMES(IT) -= "(var /" - WPROGVARGLOB(IS) + ")"
                                Endif
                                IT+=1
                                If TNOMARG(IS) = "VALEUR"
                                    WECRERREUR = 16
                                Else
                                    WECRERREUR = 13
                                Endif
                            Endif
                        Endif
                    Next IS
                Endif
            Endif
        Endif
    Endif

    If ERRMES(2) <> "" and WECRERREUR
        Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                      CHAINECPT, NBERREUR, NBWARNING, NLIG, WECRERREUR, TERREUR, SAUVEMODULE,
&                      PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)

    Endif
Return



$CHGPGMEXISTE
    # analyse de cette syntaxe
    # Call EXISTE_ADX("",APPLI,PROGOBJ,OKTRT) From ORDSYS

    # recherche du 3Â° paramÃĻtre
    IP = instr(1, CHAINE, ",")
    If IP = 0
        Return
    Endif
    IP = instr(IP + 1, CHAINE, ",")
    If IP = 0
        Return
    Endif
    CHAINE1 = right$(CHAINE, IP + 1)
    IP = instr(1, CHAINE1, ",")
    If IP > 1
        CHAINE1 = left$(CHAINE1, IP - 1)
    Else
        Return
    Endif

    # dÃĐduction de sa valeur si constante
    IP = instr(1, CHAINE1, "'")
    If IP
        CHAINE1 = right$(CHAINE1, IP + 1)
        IP = instr(1, CHAINE1, "'")
        CHAINE1 = left$(CHAINE1, IP - 1)
    Else
        IP = instr(1, CHAINE1, '"')
        If IP = 0
            Return
        Endif
        CHAINE1 = right$(CHAINE1, IP + 1)
        IP = instr(1, CHAINE1, '"')
        CHAINE1 = left$(CHAINE1, IP - 1)
    Endif

    # mÃĐmorisation de ce traitement ds la liste
    If find (CHAINE1, TPGMEXISTE(1..NBPGMEXISTE))
        Return
    Endif

    NBPGMEXISTE += 1
    TPGMEXISTE(NBPGMEXISTE) = CHAINE1
Return
#----------------------------------------------------#
# Analyse d'une ligne contenant une instruction Func
#----------------------------------------------------#

$ANALIFUN
    WENDTROUVE = 0
    # inutile d'analyser le type de la fonction
    If instr(1, CHAINE, "End func")   #CHECK IGNORE_LINE
        WENDTROUVE = 1
    Endif                             #CHECK IGNORE_LINE

    Raz WBVARGLOB, WPROGVARGLOB
    Call PURGECH("func", CHAINE, 0) From AVERIFSRC
    CHAINEFUN = CHAINE
    While CHAINEFUN <> ""

        CHAINE = CHAINEFUN
        IP = instr(1, CHAINE, 'func')   #CHECK IGNORE_LINE
        If IP = 0
            Return
        Endif


    #__________________________________________________________________________________________________

        WIFTROUVE = 0
        If pat(CHAINE, "*If*") or pat(CHAINE, "*Elsif*")
            WIFTROUVE = 1
        Endif


        # il faut sÃĐparer les sÃĐquences de code
        CHAINEFUN = ""
        ID = 1
        While ID

            IPLUS = 1

            ID = instr(1, CHAINE, 'and')
            If ID
                IPLUS = 3
            Endif
            ID2 = instr(1, CHAINE, 'or')

            # ÃĐviter de trouver un or dans un format$()
            While ID2 and instr(ID2 - 1, CHAINE, 'format')
                ID2 = instr(ID2 + 1, CHAINE, 'or')
            Wend
            If ID
                If ID2 and ID2 < ID
                    IPLUS = 2
                    ID = ID2
                Endif
            Elsif ID2
                ID = ID2
                IPLUS = 2
            Endif

            ID2 = instr(1, CHAINE, '&')
            If ID
                If ID2 and ID2 < ID
                    IPLUS = 1
                    ID = ID2
                Endif
            Elsif ID2
                ID = ID2
                IPLUS = 1
            Endif

            ID2 = instr(1, CHAINE, '|')
            If ID
                If ID2 and ID2 < ID
                    IPLUS = 1
                    ID = ID2
                Endif
            Elsif ID2
                ID = ID2
                IPLUS = 1
            Endif


            If ID
                If ID > IP
                    # mÃĐmorisation du reste de la chaine (pour rechercher un autre func xxx)
                    CHAINEFUN = right$(CHAINE, ID)
                    CHAINE = left$(CHAINE, ID - 1)
                    Break
                Else
                    # il ya du xxx And func toto yyyy
                    CHAINE = right$(CHAINE, ID + IPLUS)
                Endif
                CHAINE = vireblc(CHAINE, 0)
                IP = instr(1, CHAINE, 'func')   #CHECK IGNORE_LINE
            Endif

        Wend


        # CBO 2009.02.23 rechercher si la partie gauche de func est une variable

        CHAINERES = left$(CHAINE, IP - 1)

# CBO 20110117
# si fct sans parenthÃĻse
        ID = instr(1, CHAINERES, "Infbox")
        If ID
            CHAINERES = right$(CHAINERES, ID + 6)
        Else
            ID = instr(1, CHAINERES, "Affzo")
            If ID
                CHAINERES = right$(CHAINERES, ID + 5)
            Else
                ID = instr(1, CHAINERES, "Effzo")
                If ID
                    CHAINERES = right$(CHAINERES, ID + 5)
                Else
                    ID = instr(1, CHAINERES, "Diszo")
                    If ID
                        CHAINERES = right$(CHAINERES, ID + 5)
                    Else
                        ID = instr(1, CHAINERES, "Grizo")
                        If ID
                            CHAINERES = right$(CHAINERES, ID + 5)
                        Endif
                    Endif
                Endif
            Endif
        Endif


# CBO 20110117
        CHAINERES = vireblc(CHAINERES, 4)


        ID = instr(1, CHAINERES, '=')
        If ID = 0
            ID = instr(1, CHAINERES, '<')
        Endif
        If ID = 0
            ID = instr(1, CHAINERES, '>')
        Endif

        # si on trouve "(", cela veut sans doute dire que la fct traitÃĐe se trouve Ã  l'intÃĐrieur d'1 instruction
        # comme j = find(func toto(a,b,c)), on ne peut en dÃĐduire le type SAUF :
        # Ã  analyser ce qui se passe entre le = et (

        # on recherche quand mÃŠme si autant de ( que de ) entre le ÃĐgal et Func : dans ce cas la func n'est pas Ã  l'intÃĐrieur d'1 autre

        NBPARENTH = 0
        IP = ID
        If IP = 0
            IP = 1
        Endif
        While IP
            IP = instr(IP, CHAINERES, '(')
            If IP
                NBPARENTH += 1
                IP += 1
            Endif
        Wend
        IP = ID
        If IP = 0
            IP = 1
        Endif
        While IP
            IP=instr(IP, CHAINERES,')')
            If IP
                NBPARENTH -= 1
                IP += 1
            Endif
        Wend

        # on a une variable...
        If ID
            If NBPARENTH
                CHAINERES = ""
            Else
                CHAINERES = left$(CHAINERES, ID - 1)
                # CHAINERES doit ÃŠtre Ã  ce stade une variable (ou un champ)
            Endif
        Else
            # CBO 20110119 : on n'a pas de variable : plutÃīt num$(Func AFNC.NUMWEK()
            CHAINERES = ""
        Endif


        # remise IP Ã  la bonne valeur
        IP=instr(1,CHAINE, 'func')   #CHECK IGNORE_LINE


        # traitement de la partie droite de func
        CHAINE=right$(CHAINE,IP+len("func"))      #CHECK IGNORE_LINE
        CHAINE1=vireblc(CHAINE, 2)

    # CBO 2008.09.16 recherche .. pour ÃĐviter la recherche dans un tableau


        IQ=instr(1,CHAINE1,'.')
        If IQ
            IQ2PTS = instr(1,CHAINE1,'..')
            If IQ2PTS = IQ
                NOMPROG = GTTRAITEMENTS(NF)
            Else
                # si le . est aprÃĻs ( ce n'est pas un nomprog.fc (param)
                IQ2PTS = instr(1,CHAINE1,'(')
                If IQ2PTS > 0 and IQ2PTS < IQ
                    NOMPROG=GTTRAITEMENTS(NF)
                Else
                    NOMPROG=left$(CHAINE1,IQ-1)
                    CHAINE1=right$(CHAINE1,IQ+1)
                Endif

                # testÃĐ par EXISTE_ADX
                If find (NOMPROG, TPGMEXISTE(1..NBPGMEXISTE))
                    Return
                Endif

                If [F:ADC]MODULE = 1 and find(NOMPROG, TEXCPGMSUP(1..NBEXCPGMSUP))
                    Return
                Endif

            Endif
        Else
            NOMPROG=GTTRAITEMENTS(NF)
        Endif

        If NOMPROG <> GTTRAITEMENTS(NF)
            POSUTIL = func FINDTRT(NOMPROG, 1, GNBTRTADX)
            If POSUTIL
                TRTUTILISE(POSUTIL) = 1
                If TRTUTILDANS(POSUTIL) = ""
                    TRTUTILDANS(POSUTIL) = GTTRAITEMENTS(NF)
                Endif
            Endif
        Endif

        # inutile d'analyser le reste lors de cette option
        If PACTION = 1
            Return
        Endif


        NOMCALL=""


        IS=instr(1,CHAINE1,'(')

        # on tronque la chaine  Ã  la (
        ID = 0
        IQ = 0
        If IS = 0
            # on n'a pas de ( donc si on trouve un des opÃĐrateur suivant, il sera pris en compte
            IS = 9999
            IQ = 1
        Endif

        CHAINE1 = vireblc(CHAINE1, 3)
        # attention si la parenthÃĻse est aprÃĻs une , = > < ) ; * / ^ on va tronquer avant
        ID = instr(1,CHAINE1,',')
        If ID and ID < IS
            IS = ID
            IQ = 1
        Endif
        ID = instr(1,CHAINE1,'=')
        If ID and ID < IS
            IS = ID
            IQ = 1
        Endif
        ID = instr(1,CHAINE1,'>')
        If ID and ID < IS
            IS = ID
            IQ = 1
        Endif
        ID = instr(1,CHAINE1,'<')
        If ID and ID < IS
            IS = ID

        Endif
        ID = instr(1,CHAINE1,'+')
        If ID and ID < IS
            IS = ID
            IQ = 1
        Endif
        ID = instr(1,CHAINE1,'-')
        If ID and ID < IS
            IS = ID
            IQ = 1
        Endif
        ID = instr(1,CHAINE1,')')
        If ID and ID < IS
            IS = ID
            IQ = 1
        Endif
        ID = instr(1,CHAINE1,';')
        If ID and ID < IS
            IS = ID
            IQ = 1
        Endif
        ID = instr(1,CHAINE1,'*')
        If ID and ID < IS
            IS = ID
            IQ = 1
        Endif
        ID = instr(1,CHAINE1,'/')
        If ID and ID < IS
            IS = ID
            IQ = 1
        Endif
        ID = instr(1,CHAINE1,'^')
        If ID and ID < IS
            IS = ID
            IQ = 1
        Endif

        # pour dire qu'on n'a pas de paramÃĻtre Ã  la fonction malgrÃĐ la ( on a IQ = 1

        CHAINE1=left$(CHAINE1,IS-1)

        NOMCALL=vireblc(CHAINE1, 2)
        If NOMCALL=""
            Break
        Endif


        #--- Ici on a NOMCALL=SousPro et NOMPROG=Traitement du SousPro ---#
        # 3ÃĻ passe: si trt appelÃĐ pas dans patch ou ou diffÃĐrent du modÃĻle de trt Ã  analyser => exit
        If NBPASSE = 3 and (filinfo(SRCPATCH + "/" + NOMPROG + ".src", 0) <= 0 or pat(NOMPROG, NOMTRT) = 0)
            Break
        Endif

        # On vÃĐrifie si le Func Ã  analyser n'est pas dans les exceptions
        If find(GTTRAITEMENTS(NF)+'.'+NOMCALL+'.'+NOMPROG,EXCEPTTRT(1..NEX1))
            Break
        Endif

        Raz NBARG,ARGUMENTS,TABARG, TNOMARG

        # Iq = 1 veut dire qu'il n'y a pas de paramÃĻtre lors de cet appel Ã  la fonction
        If IQ = 0
            IR=instr(1,CHAINE,"(")
            If IR
                CHAINE=right$(CHAINE,IR+1)
                Repeat
                Gosub ANARG
                Until left$(CHAINE,1)=")" or CHAINE=""
            Endif
        Endif



        Raz ERRMES
        IT = 2
        WECRERREUR = 0
        If NOMPROG = GTTRAITEMENTS(NF)
            IP = NF
        Else
            IP = func FINDTRT(NOMPROG, 1, GNBTRTADX)
            If IP and GNBPROGUNUSED
                If find(NOMPROG, GTPROGUNUSED(1..GNBPROGUNUSED))
                    IP = -1
                Endif
            Endif
        Endif


        ERRMES(1) = "Func" - NOMPROG + "." + NOMCALL
        ERRMES(2) = ""
        If func AVERIFSRC.NVDEMANDEUR (PDEMANDEUR, NOMPROG) = 1 and pat(NOMPROG,"AUT*") = 0
            If IP = -1
                ERRMES(2) = func AVERIFSRC.MESNUM(79, 144, NOMPROG, "", "", "", "")
                WECRERREUR = 6
            Elsif IP=0
                ERRMES(2) = func AVERIFSRC.MESNUM(80, 144, NOMPROG, "", "", "", "")
                WECRERREUR = 6
            Else
                IR=0
                For IQ=GTPPTPRO(IP) To GTPPTPRO(IP+1)-1
                    IR=find(left$(NOMCALL,MAX_LENCALL),GTSOUSPRO(1..10,IQ))
                    If IR
                        Break
                    Endif
                Next IQ

                If IR=0

                    ERRMES(2) = func AVERIFSRC.MESNUM(80, 144, NOMCALL, "", "", "", "")
                    If find(NOMPROG,EXCEPTTRT(1..NEX1))
                        # S'il y a un mauvais appel de sous-pro vers un traitement dans les exceptions : avertissement
                        ERRMES(3)="Avertissement =>" - NOMPROG - "fait partie des exceptions !"
                    Else
                        WECRERREUR = 7
                    Endif
                Else
                    If NBARG<>GTTYPARG(0,IR,IQ)
                        ERRMES(2) = func AVERIFSRC.MESNUM(82, 144, num$(NBARG), num$(GTTYPARG(0,IR,IQ)), "", "", "")
                        WECRERREUR = 14
                    Else
                        For IS=1 To NBARG


                            If GTTYPARG(IS,IR,IQ) <> ARGUMENTS(IS) & GTTYPARG(IS,IR,IQ)<>4 & ARGUMENTS(IS)<>4
                                # ne pas mettre en erreur les diffÃĐrences chaine/clob

                                If (GTTYPARG(IS,IR,IQ) <> 5 or ARGUMENTS(IS) <> 1) and (GTTYPARG(IS,IR,IQ) <> 1 or ARGUMENTS(IS) <> 5)
 ERRMES(IT) = func AVERIFSRC.MESNUM(83, 144, num$(IS), TNOMARG(IS), func TYPEDATA(ARGUMENTS(IS)), func TYPEDATA(GTTYPARG(IS,IR,IQ)), "")
                                    If WBVARGLOB(IS) = 2
                                        ERRMES(IT) -= "(var. /" - WPROGVARGLOB(IS) + ")"
                                    Endif

                                    IT += 1

                                    If TNOMARG(IS) = "VALEUR"
                                        WECRERREUR = 16
                                    Else
                                        WECRERREUR = 13
                                    Endif
                                Endif
                            Endif
                        Next IS

                    Endif

                    #CBO 2009.02.23
                    # analyser le rÃĐsultat de la fonction
                    IS = GTTYPFUNP (IR, IQ)
                    # CBO 2009.02.23 rechercher si la partie droite (aprÃĻs la fonction) est un test
                    If WIFTROUVE
                        If NBPARENTH
                            CHAINE = ""
                        Else
                            CHAINERES = CHAINE

                            IP=instr(1, CHAINE,')')
                            If IP
                                CHAINERES= right$(CHAINE, IP + 1)
                            Endif

                            IP=instr(1,CHAINE,'=')
                            If IP
                                  CHAINERES= right$(CHAINE, IP + 1)
                                  CHAINE = CHAINERES
                            Endif

                            IP=instr(1,CHAINE,'>')
                            If IP
                                CHAINERES= right$(CHAINE, IP + 1)
                            Endif

                            IP=instr(1,CHAINE,'<')
                            If IP
                                CHAINERES= right$(CHAINE, IP + 1)
                            Endif


                            CHAINE = vireblc(CHAINERES, 4)
                        Endif
                    Else
                        CHAINE = CHAINERES
                    Endif

                    If CHAINE = "" or WENDTROUVE
                        TYPCOUR = 4
                    Else
                        CHAINE = vireblc(CHAINE, 0)
                        Gosub ANAELT
                    Endif

                    ID = GTTYPFUNP(IR, IQ)

                    IE = TYPCOUR
                    If ID <> IE and ID <> 4 and IE <> 4 and IE <> 0
                        ERRMES(IT) = func AVERIFSRC.MESNUM(85, 144, func TYPEDATA(IE), func TYPEDATA(ID), "", "", "")
                        WECRERREUR = 13

                        IT+=1
                    Endif
                Endif
            Endif
        Endif

        If ERRMES(2)<>"" and WECRERREUR
            Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                          CHAINECPT, NBERREUR, NBWARNING, NLIG, WECRERREUR, TERREUR, SAUVEMODULE,
&                          PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
        Endif

    Wend
# fin de $ANALIFUN
Return


#----------------------------------------------------#
# Analyse d'une ligne contenant une instruction Gosub
#----------------------------------------------------#
$ANALIGOS

    IP=instr(1, CHAINE, 'Gosub')


    CHAINE = right$(CHAINE, IP + len("Gosub"))
    IQ=instr(1, CHAINE, "From")
    If IQ
        CHAINE1 = vireblc(right$(CHAINE, IQ + len("From")),2)

        If instr(1, CHAINE1, "=")
            Return
        Endif
        CHAINE1 = vireblc(CHAINE1, 0)

        NOMPROG = func CHALPHA(CHAINE1, IS)
        If NOMPROG <> ""
#        If instr(1, ALPHA, left$(CHAINE1, 1))
#            IS=len(CHAINE1)-len(vireblc(ctrans(CHAINE1,ALPHAN,SPACEN),0))
#            NOMPROG=vireblc(vireblc(left$(CHAINE1,IS),2),3)

            # testÃĐ par EXISTE_ADX
            If find (NOMPROG, TPGMEXISTE(1..NBPGMEXISTE))
                Return
            Endif

            If [F:ADC]MODULE = 1 and find(NOMPROG, TEXCPGMSUP(1..NBEXCPGMSUP))
                Return
            Endif

        Elsif left$(CHAINE1,1) = "="
            Return : # On renonce Ã  l'analyse des Gosub ... From =
        Endif

        If NOMPROG <> GTTRAITEMENTS(NF)
            POSUTIL = func FINDTRT(NOMPROG, 1, GNBTRTADX)
            If POSUTIL
                TRTUTILISE(POSUTIL) = 1
                If TRTUTILDANS(POSUTIL) = ""
                    TRTUTILDANS(POSUTIL) = GTTRAITEMENTS(NF)
                Endif
            Endif
        Endif

    Else
        NOMPROG=GTTRAITEMENTS(NF)
    Endif

    # inutile d'analyser le reste lors de cette option
    If PACTION = 1
        Return
    Endif

    If IQ
        CHAINE1 = vireblc(left$(CHAINE,IQ - 1), 0)
    Else
        CHAINE1 = vireblc(CHAINE, 0)
    Endif


    If left$(CHAINE1, 1) = "$"
        CHAINE1 = right$(CHAINE1, 2)
    Endif
    NOMCALL = ""
#    If instr(1,ALPHA,left$(CHAINE1, 1))
#        IS=len(CHAINE1)-len(vireblc(ctrans(CHAINE1,ALPHAN,SPACEN),0))
#        NOMCALL = vireblc(vireblc(left$(CHAINE1,IS),2),3)
#    Endif
NOMCALL = func CHALPHA(CHAINE1, IS)


#--- Ici on a NOMCALL=Etiquette et NOMPROG=Traitement du Gosub ---#
# 3ÃĻ passe: si trt appelÃĐ pas dans patch ou ou diffÃĐrent du modÃĻle de trt Ã  analyser => exit
If NBPASSE=3 & (filinfo(SRCPATCH+"/"+NOMPROG+".src",0)<=0 | pat(NOMPROG,NOMTRT))
   Return
Endif

    WECRERREUR = 0
    # On vÃĐrifie si le trt du gosub Ã  analyser n'est pas dans les exceptions
    If find(GTTRAITEMENTS(NF) + '.' + NOMCALL + '.' + NOMPROG, EXCEPTTRT(1..NEX1))
        Return
    Endif

    Raz ERRMES : IT=3
    If NOMPROG = GTTRAITEMENTS(NF)
        IP = NF
    Else
        IP = func FINDTRT(NOMPROG, 1, GNBTRTADX)
        If IP and GNBPROGUNUSED
            If find(NOMPROG, GTPROGUNUSED(1..GNBPROGUNUSED))
                IP = -1
            Endif
        Endif
    Endif

    ERRMES(1) = "Gosub" - NOMCALL - "From" - NOMPROG
    ERRMES(2) = ""
    If func AVERIFSRC.NVDEMANDEUR (PDEMANDEUR, NOMPROG) = 1 and pat(NOMPROG,"AUT*") = 0
        If IP = -1
            ERRMES(2) = func AVERIFSRC.MESNUM(79, 144, NOMPROG, "", "", "", "")
            WECRERREUR = 6
        Elsif IP = 0
            ERRMES(2) = func AVERIFSRC.MESNUM(80, 144, NOMPROG, "", "", "", "")
            WECRERREUR = 6
        Else
            IR=0
            For IQ=GTPPTGOS(IP) To GTPPTGOS(IP+1)-1
                If IQ <= GMAX_SOUSPRO
                    IR=find(left$(NOMCALL, MAX_LENCALL), GTGOS(1..10, IQ))
                Elsif IQ <= 2 * GMAX_SOUSPRO
                    IR=find(left$(NOMCALL, MAX_LENCALL), GTGOSB(1..10, IQ - GMAX_SOUSPRO))
                Elsif IQ <= 3 * GMAX_SOUSPRO
                    IR=find(left$(NOMCALL, MAX_LENCALL), GTGOSC(1..10, IQ - (2 * GMAX_SOUSPRO)))
                Endif
                If IR
                    Break
                Endif
            Next IQ

            If IR=0
                # On recherche si on ne fait pas un Gosub sur un Subprog (ou Funprog)...
                For IQ=GTPPTPRO(IP) To GTPPTPRO(IP+1)-1
                    IR=find(left$(NOMCALL, MAX_LENCALL), GTSOUSPRO(1..10,IQ))
                    If IR
                        Break
                    Endif
                Next IQ

                If IR=0
                    WECRERREUR = 23
                    ERRMES(2) = mess(1023, 144, 1)
                Else
                    WECRERREUR = 8
                    ERRMES(2) = mess(1008, 144, 1)
                Endif
            Endif
        Endif
    Endif
    If ERRMES(2)<>""
        Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                      CHAINECPT, NBERREUR, NBWARNING, NLIG, WECRERREUR, TERREUR, SAUVEMODULE,
&                      PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
    Endif
Return


#__________________________________________
$ANARG : # Suppose que CHAINE soit non vide

    CHAINE = vireblc(CHAINE, 0)
    NBARG += left$(CHAINE, 1) <> ")" : # Pour ÃĐviter de voir un argument sur Call TOTO() From TITI

    Repeat
        CHAINE=vireblc(CHAINE,0)
        Case left$(CHAINE,1)
          When "(" : # On n'essaie pas de rentrer dans les parenthÃĻses
              ARGUMENTS(NBARG) += 4*(ARGUMENTS(NBARG)=0)
              Gosub SAUTEPAR
          When ")" : # On va sortir...
          When "," : # Changement d'argument
              ARGUMENTS(NBARG)+= 4*(ARGUMENTS(NBARG)=0)
              NBARG+=1
              CHAINE=right$(CHAINE,2)
          When Default
              Gosub ANAEXPR : # On essaie d'analyser l'expression

      #       On saute au prochain caractÃĻre intÃĐressant (virgule, simple ou double quote, parenthÃĻses)
              CHAINE=right$(CHAINE, instr(1, ctrans(CHAINE + chr$(1), "(), '" + '"', string$(6,1)), chr$(1)))
              If right$(CHAINE,1) = "("
                  Gosub SAUTEPAR
              Endif

              While CHAINE <> "" & instr(1, '"' + "'", right$(CHAINE,1))
                  CHAINE=right$(CHAINE,instr(2,CHAINE+left$(CHAINE,1),left$(CHAINE,1))+1)
                  CHAINE=right$(CHAINE,instr(1,ctrans(CHAINE+chr$(1),",'"+'"',string$(6,1)),chr$(1)))
                  If right$(CHAINE,1)="("
                      Gosub SAUTEPAR
                  Endif
              Wend
        Endcase
    Until left$(CHAINE,1)=")" or CHAINE=""
Return



#_________________________
# Analyse d'une variable : on suppose que ARGUMENTS(NBARG) est ÃĐgal Ã  0 Ã  ce stade
$ANAEXPR

    WNOMARG = ""
    TYPCOUR=0
    Gosub ANAELT : # analyse d'un ÃĐlÃĐment d'expression : renvoie TYPCOUR et OPERATEUR s'il y en a un derriÃĻre
    ARGUMENTS(NBARG) = TYPCOUR #CBO20110315

    If TYPCOUR = 4 #CBO20110315
        Gosub FINEXPR
        Return
    Endif

    While OPERATEUR <> ""
        If instr(1, "<>=&|*/^", OPERATEUR)
            ARGUMENTS(NBARG) = 2
            # CBO 20110315 vider la fin de cette expression
            #       On saute au prochain caractÃĻre intÃĐressant (virgule, parenthÃĻses)
            Gosub FINEXPR
            Return
        Endif
        PRECOP = OPERATEUR
#        ARGUMENTS(NBARG) = TYPCOUR #CBO20110315
        Gosub ANAELT

        WNOMARG = ""
        If ARGUMENTS(NBARG) = 3 & TYPCOUR = 3 & PRECOP = '-'
            ARGUMENTS(NBARG) = 2 : # Date - Date => numÃĐrique
#        Elsif ARGUMENTS(NBARG) = 2 & TYPCOUR=3 & OPERATEUR='+'
        Elsif ((ARGUMENTS(NBARG) = 2 & TYPCOUR = 3) or (ARGUMENTS(NBARG) = 3 & TYPCOUR = 2)) and (PRECOP = '+' or PRECOP = '-')
            ARGUMENTS(NBARG) = 3 : # NumÃĐrique + Date => Date

        Elsif ((ARGUMENTS(NBARG) = 1 and TYPCOUR = 3) or (ARGUMENTS(NBARG) = 3 and TYPCOUR = 1)) and (PRECOP = '+' or PRECOP = '-')
            ARGUMENTS(NBARG) = 1 : # chaÃŪne concatÃĐnÃĐe Ã  1 date : rÃĐsultat = chaÃŪne

        Elsif ((ARGUMENTS(NBARG) = 1 and TYPCOUR = 2) or (ARGUMENTS(NBARG) = 2 and TYPCOUR = 1)) and (PRECOP = '+' or PRECOP = '-')
            ARGUMENTS(NBARG) = 1 : # chaÃŪne concatÃĐnÃĐe Ã  1 num : rÃĐsultat = chaÃŪne

        Else    #CBO20110315
            ARGUMENTS(NBARG) = TYPCOUR #CBO20110315
        Endif
    Wend
    ARGUMENTS(NBARG)+=TYPCOUR*(ARGUMENTS(NBARG)=0)
    TNOMARG(NBARG) = WNOMARG
Return



#_______________________
# Analyse d'un ÃĐlÃĐment : suppose que CHAINE soit non vide et ne commence pas par un espace
$ANAELT

    If NBARG = 0
        NBARG = 1
    Endif
    WBVARGLOB(NBARG) = 0
    WPROGVARGLOB(NBARG) = ""


########### chaine de caractÃĻres
    If instr(1, "'" + '"', left$(CHAINE, 1))
        IS = instr(2, CHAINE, left$(CHAINE, 1))
        If IS
            WNOMARG = left$(CHAINE, IS - 1)
            WNOMARG = right$(WNOMARG, 2)
        Endif

        CHAINE=right$(CHAINE,instr(2,CHAINE+left$(CHAINE,1),left$(CHAINE,1))+1)
        TYPCOUR=1

########### nombre
    Elsif instr(1,"0123456789",left$(CHAINE,1))

        IS = instr(1, CHAINE, ",")
        If IS
            WNOMARG = left$(CHAINE, IS - 1)
        Else
            IS = instr(1, CHAINE, ")")
            If IS
                WNOMARG = left$(CHAINE, IS - 1)
            Endif
        Endif


        IS=len(CHAINE) - len(vireblc(ctrans(CHAINE,"-0123456789",space$(11)),0))
        CHAINE=right$(CHAINE,IS+1)
        TYPCOUR=2

########### nombre nÃĐgatif
    Elsif left$(CHAINE,1) = "-" and instr(1,"0123456789", mid$(CHAINE, 2, 1))

        IS = instr(1, CHAINE, ",")
        If IS
            WNOMARG = left$(CHAINE, IS - 1)
        Else
            IS = instr(1, CHAINE, ")")
            If IS
                WNOMARG = left$(CHAINE, IS - 1)
            Endif
        Endif


        IS=len(CHAINE) - len(vireblc(ctrans(CHAINE,"-0123456789",space$(11)),0))
        CHAINE=right$(CHAINE,IS+1)
        TYPCOUR=2

########### abrÃĐviation
    Elsif left$(CHAINE,1)="["

       CHAINE=right$(CHAINE,2)
       If find(left$(CHAINE,1),"0","1","2","3")
#### dates ???
            WNOMARG = func FNOMARG (CHAINE, instr(1, CHAINE + "]", "]") - 1)
            CHAINE = vireblc(right$(CHAINE, instr(1, CHAINE + "]", "]") + 1), 0)
            TYPCOUR=3
#### fichiers
       Elsif pat(CHAINE,"F:??]*") or pat(CHAINE,"F:???]*") or pat(CHAINE,"F:????]*") or pat(CHAINE,"F:?????]*")
            If pat(CHAINE,"F:??]*")
                ABV=mid$(CHAINE,3,2)
                CHAINE=vireblc(right$(CHAINE,6),0)
            Elsif pat(CHAINE,"F:???]*")
                ABV=mid$(CHAINE,3,3)
                CHAINE=vireblc(right$(CHAINE,7),0)
            Elsif pat(CHAINE,"F:????]*")
                ABV=mid$(CHAINE,3,4)
                CHAINE=vireblc(right$(CHAINE,8),0)
            Else
                ABV=mid$(CHAINE,3,5)
                CHAINE=vireblc(right$(CHAINE,9),0)
            Endif

            VARIA = func CHALPHA(CHAINE, IS)
#           IS=len(CHAINE)-len(vireblc(ctrans(CHAINE,ALPHAN,SPACEN),0))
#           VARIA=vireblc(left$(CHAINE,IS),2)
           WNOMARG = VARIA
           CHAINE=vireblc(right$(CHAINE,IS+1),0)
           IS=find(ABV, GTFICHIERS(1..NBFI))
           If IS
               ITY=find(VARIA,GTZONES(GTINDFIC(IS)..GTINDFIC(IS+1)-1))
           Else
               ITY=0
           Endif
           If ITY : # On a trouvÃĐ le type de la variable
               TYPCOUR=GTTYPZO(GTINDFIC(IS)+ITY-1)
           Else
                If VARIA = ""
                    TYPCOUR = 9
                Else
                    TYPCOUR=4
                Endif
           Endif
#### ÃĐcrans
       Elsif pat(CHAINE,"M:??]*") or pat(CHAINE,"M:???]*") or pat(CHAINE,"M:????]*") or pat(CHAINE,"M:?????]*")
           If pat(CHAINE,"M:??]*")
                ABV=mid$(CHAINE,3,2)
                CHAINE=vireblc(right$(CHAINE,6),0)
            Elsif pat(CHAINE,"M:???]*")
                ABV=mid$(CHAINE,3,3)
                CHAINE=vireblc(right$(CHAINE,7),0)
            Elsif pat(CHAINE,"M:????]*")
                ABV=mid$(CHAINE,3,4)
                CHAINE=vireblc(right$(CHAINE,8),0)
            Else
                ABV=mid$(CHAINE,3,5)
                CHAINE=vireblc(right$(CHAINE,9),0)
            Endif

            VARIA = func CHALPHA(CHAINE, IS)
#            IS=len(CHAINE) - len(vireblc(ctrans(CHAINE, ALPHAN, SPACEN), 0))
#            VARIA=vireblc(left$(CHAINE,IS),2)
            WNOMARG = VARIA
            CHAINE=right$(CHAINE,IS+1)

            IS=find(ABV, GTMASQUES(1..NBMA))
            If IS
                Gosub RECHTYPMSK
            Else
                ITY=0
            Endif

            If ITY = 0
                If VARIA = ""
                    TYPCOUR = 9
                Else
                    TYPCOUR=4
                Endif
            Endif


#### sans M: ou F:
       Elsif pat(CHAINE,"??]*") or pat(CHAINE,"???]*") or pat(CHAINE,"????]*") or pat(CHAINE,"?????]*")
           If pat(CHAINE,"??]*")
                ABV=left$(CHAINE, 2)
                CHAINE=vireblc(right$(CHAINE,4),0)
            Elsif pat(CHAINE,"???]*")
                ABV=left$(CHAINE, 3)
                CHAINE=vireblc(right$(CHAINE,5),0)
            Elsif pat(CHAINE,"????]*")
                ABV=left$(CHAINE, 4)
                CHAINE=vireblc(right$(CHAINE,6),0)
            Else
                ABV=left$(CHAINE, 5)
                CHAINE=vireblc(right$(CHAINE,7),0)
            Endif

            VARIA = func CHALPHA(CHAINE, IS)
#            IS=len(CHAINE)-len(vireblc(ctrans(CHAINE,ALPHAN,SPACEN),0))
#            VARIA=vireblc(left$(CHAINE,IS),2)
            WNOMARG = VARIA
            CHAINE=right$(CHAINE,IS+1)

            # recherche dans les tables
            IS=find(ABV,GTFICHIERS(1..NBFI))
            If IS
                ITY=find(VARIA,GTZONES(GTINDFIC(IS)..GTINDFIC(IS+1)-1))
            Else
                ITY=0
            Endif

            If ITY
                TYPCOUR=GTTYPZO(GTINDFIC(IS)+ITY-1)
            Else
                # recherche dans les masques
                IS=find(ABV, GTMASQUES(1..NBMA))
                If IS
                    Gosub RECHTYPMSK
                Else
                    ITY=0
               Endif

               If ITY = 0
                    If VARIA = ""
                        TYPCOUR = 9
                    Else
                        TYPCOUR=4
                   Endif
                Endif
            Endif
#### var locales
        Elsif pat(CHAINE,"L]*")
            CHAINE=vireblc(right$(CHAINE,3),0)

#            If CHAINE<>"" & instr(1,ALPHA,left$(CHAINE,1))
            If CHAINE<>"" & func DEBALPHA(CHAINE)
                VARIA = func CHALPHA(CHAINE, IS)
#                IS=len(CHAINE)-len(vireblc(ctrans(CHAINE,ALPHAN,SPACEN),0))
#                VARIA=vireblc(left$(CHAINE,IS),2)
                WNOMARG = VARIA
                CHAINE=vireblc(right$(CHAINE,IS+1),0)
                IS=find(VARIA, TVARLOC(1..NBVARLOC))
                If IS
                    TYPCOUR=TYPVARLOC(IS)
                Else
                    If VARIA = ""
                        TYPCOUR = 9
                    Else
                        TYPCOUR=4
                    Endif
                Endif
            Else : # Bizarre...
                ARGUMENTS(NBARG)=4
                TYPCOUR=0
                TYPCOUR=4 #CBO20110315
                OPERATEUR=""
                Return
            Endif
#### var globales
        Elsif pat(CHAINE,"V]?*")
            CHAINE=vireblc(right$(CHAINE,3),0)
            If CHAINE<>"" & instr(1,ALPHA,left$(CHAINE,1))
                VARIA = func CHALPHA(CHAINE, IS)
#                IS=len(CHAINE)-len(vireblc(ctrans(CHAINE,ALPHAN,SPACEN),0))
#                VARIA=vireblc(left$(CHAINE,IS),2)
                WNOMARG = VARIA
                CHAINE=vireblc(right$(CHAINE,IS+1),0)

                IS=find(VARIA,GTVARGLOB(1..NBVARGLOB))
                If IS
                    TYPCOUR=GTYPVARGLOB(IS)
                    WPROGVARGLOB(NBARG) = GPROGVARGLOB(IS)
                    WBVARGLOB(NBARG) = 2
                Else
                    # cbo 2008.09.12 rechercher dans la liste des var globales au produits
#                    If left$(VARIA, 1) = "G"
                        IS = find(VARIA, GTVARGLOBDIC(1..NBVARGLOBDIC))
                        If IS
                            TYPCOUR=GTYPVARGLOBDIC(IS)
                            WPROGVARGLOB(NBARG) = ""
                            WBVARGLOB(NBARG) = 1
                        Else
                            IS = find(VARIA, GTVARGLOBSRC(1..NBVARGLOBSRC))
                            If IS
                                # que de l'alpha
                                TYPCOUR = 1
                                WPROGVARGLOB(NBARG) = ""
                                WBVARGLOB(NBARG) = 1
                            Else
                                TYPCOUR=4 : # Variable globale inconnue : On trace
                                If NBPASSE > 1 : # Dans la premiÃĻre passe, on n'a pas encore tout vu
                                    ERRMES(1) = VARIA - ":" - mess(1009, 144, 1)
                                    Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE,
&                                        TITAECRIREW, CHAINECPT, NBERREUR, NBWARNING, NLIG, 9, TERREUR,
&                                        SAUVEMODULE, PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
                                Endif
                            Endif
                        Endif
#                    Else
#                         TYPCOUR=4 : # Variable globale inconnue : On trace
#                         If find(NBPASSE,2,3) : # Dans la premiÃĻre passe, on n'a pas encore tout vu
#                            ERRMES(1) = "Variable globale" + VARIA - "inexistante"
#                            Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE,
#&                                TITAECRIREW, CHAINECPT, NBERREUR, NBWARNING, NLIG, 9, TERREUR,
#&                                SAUVEMODULE, PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
#                        Endif
#                    Endif
                Endif
            Else : # Bizarre...
                ARGUMENTS(NBARG)=4
                TYPCOUR=0
                TYPCOUR=4 #CBO20110315
                OPERATEUR=""
                Return
            Endif
#### var ???
        Elsif pat(CHAINE,"S]?*")
            CHAINE=vireblc(right$(CHAINE,3),0)
            CHAINE1=toupper(CHAINE) : # Ces variables sont tokenisÃĐes

            If CHAINE1<>"" & func DEBALPHA(CHAINE1)
#            If CHAINE1<>"" & instr(1,ALPHA,left$(CHAINE1,1))
                VARIA = func CHALPHA(CHAINE1, IS)
                IS=len(CHAINE1)-len(vireblc(ctrans(CHAINE1,ALPHAN,SPACEN),0))
                VARIA=vireblc(left$(CHAINE1,IS),2)
                WNOMARG = VARIA
                CHAINE=vireblc(right$(CHAINE,IS+1),0) : # C'est bien CHAINE qu'on coupe et pas CHAINE1
                If find(VARIA,"NOLIGN","FSTAT","INDICE","MKSTAT")
                    TYPCOUR=2
                Else
                    If VARIA = ""
                        TYPCOUR = 9
                    Else
                        TYPCOUR=4
                    Endif

                Endif
            Else : # Bizarre...
                ARGUMENTS(NBARG)=4
                TYPCOUR=0
                TYPCOUR=4 #CBO20110315
                OPERATEUR=""
                Return
            Endif
#### inconnues
        Else : # Si c'est [M],[F], je ne sais pas comment trouver la bonne classe
        # en fait, on a [] donc il n'y a pas de raison pour passer ici
            ARGUMENTS(NBARG)=4
            TYPCOUR=0
            TYPCOUR=4 #CBO20110315
            OPERATEUR=""
            Return
        Endif
    # fin de Elsif left$(CHAINE,1)="["
    Else
########### autres cas : fcts, variables...
        CHAINE1 = vireblc(CHAINE, 4)
        If  pat(CHAINE1,"string$(*") or pat(CHAINE1,"space$(*") or pat(CHAINE1,"left$(*")
&       or pat(CHAINE1,"right$(*")  or pat(CHAINE1,"mess(*") or pat(CHAINE1,"num$(*")
&       or pat(CHAINE1,"format$(*") or pat(CHAINE1,"toupper(*") or pat(CHAINE1,"tolower(*")

            TYPCOUR=1
            Gosub SKIPAR
         Elsif pat(CHAINE1,"Infbox*") or pat(CHAINE1,"Affzo*") or pat(CHAINE1,"Effzo*")
&       or pat(CHAINE1,"Diszo*") or pat(CHAINE1,"Actzo*") or pat(CHAINE1,"Grizo*")

            TYPCOUR=1
            Gosub SKIPAR
        Elsif pat(CHAINE1,"val(*") or pat(CHAINE1,"fix(*") or pat(CHAINE1,"int(*")
&          or pat(CHAINE1,"month(") or pat(CHAINE1,"day(*") or pat(CHAINE1,"year(*")
            TYPCOUR=2
            Gosub SKIPAR
        Elsif pat (CHAINE1,"gdat$(*") or pat (CHAINE1,"addmonth(*")
&         or pat(CHAINE1,"eomonth(*")
            TYPCOUR=3
            Gosub SKIPAR
        Elsif pat(CHAINE1,"date$")
            TYPCOUR=3
            WNOMARG = func FNOMARG (CHAINE1, 5)
            CHAINE=right$(CHAINE,6)
        Elsif pat(CHAINE1,"nolign") or pat(CHAINE1,"indice") or pat(CHAINE1,"mkstat")
            TYPCOUR=2
            WNOMARG = func FNOMARG (CHAINE1, 6)
            CHAINE=right$(CHAINE,7)
        Elsif pat(CHAINE1,"fstat")
            TYPCOUR=2
            WNOMARG = func FNOMARG (CHAINE1, 5)
            CHAINE=right$(CHAINE,6)

        Elsif pat(CHAINE1,"func*")
            CHAINE = vireblc(right$(CHAINE, 5), 0)
            IS=len(CHAINE)-len(vireblc(ctrans(CHAINE, ALPHAN, SPACEN),0))

            If mid$(CHAINE,IS+1,1)="."
                NMTRT=vireblc(left$(CHAINE, IS),2)
                #cbo 2008.09.19      CHAINE=vireblc(right$(CHAINE, IS+1),0)
                CHAINE=vireblc(right$(CHAINE, IS+2),0)

            Else
                NMTRT=GTTRAITEMENTS(NF)
            Endif
            NMFUNC = func CHALPHA(CHAINE, IS)
#            IS = len(CHAINE)-len(vireblc(ctrans(CHAINE,ALPHAN,SPACEN),0))
#            NMFUNC=vireblc(left$(CHAINE,IS),2)
            WNOMARG = NMFUNC

            CHAINE = vireblc(right$(CHAINE,IS+1), 0)

            # Pour le moment, on n'analyse pas les arguments du subprog, on saute les parenthÃĻses...
            Gosub SKIPAR

            If NMTRT = GTTRAITEMENTS(NF)
                IS = NF
            Else
                IS = func FINDTRT(NMTRT, 1, GNBTRTADX)
            Endif

            If func AVERIFSRC.NVDEMANDEUR (PDEMANDEUR, NMTRT) = 1
                If IS=0 : # traitement inexistant
                    TYPCOUR=4
                    If NBPASSE > 1
                        ERRMES(1) = NMTRT - ":" - mess(1006, 144, 1)
                        Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                                      CHAINECPT, NBERREUR, NBWARNING, NLIG, 6, TERREUR, SAUVEMODULE,
&                                      PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
                    Endif

                Else
                    ITY=0

                    # cbo 2009.10.05 en premiÃĻre passe, le traitement IS n'est pas encore chargÃĐ (si IS > nÂ° courant = NF)
                    If NBPASSE = 1 and (GTPPTPRO(IS) = 0 or IS > NF)
                        TYPCOUR=4
                    Else
                        For IU=GTPPTPRO(IS) To max(GTPPTPRO(IS+1)-1,GTPPTPRO(IS))

                            ITY=find(left$(NMFUNC, MAX_LENCALL), GTSOUSPRO(1..10,IU))
                            If ITY
                                Break
                            Endif
                        Next IU
                        If ITY
                            TYPCOUR=GTTYPFUNP(ITY,IU)

                        Elsif NBPASSE = 2 : # Dans la premiÃĻre passe, on n'a pas encore tout vu
                            ERRMES(1) = func AVERIFSRC.MESNUM(87, 144, NMFUNC, NMTRT, "", "", "")
                            Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                                          CHAINECPT, NBERREUR, NBWARNING, NLIG, 7, TERREUR, SAUVEMODULE,
&                                          PNUMERREUR, NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)

                            TYPCOUR=4 : # A tracer, le Func n'existe pas
                        Endif
                    Endif
                Endif
            Endif
        # fin de Elsif pat(CHAINE1,"func*")
        Elsif func DEBALPHA(CHAINE) : # CÃ  commence par une lettre ou un underscore
#        Elsif instr(1,ALPHA,left$(CHAINE,1)) : # CÃ  commence par une lettre ou un underscore
#            IS=len(CHAINE)-len(vireblc(ctrans(CHAINE,ALPHAN,SPACEN),0))
#            VARIA=vireblc(left$(CHAINE,IS),2)
            VARIA = func CHALPHA(CHAINE, IS)
            WNOMARG = VARIA
            CHAINE=vireblc(right$(CHAINE,IS+1),0)

            # Recherche dans le tableau des variables locales (et paramÃĻtres si ds un sous-pro ou fonction)
            IS=find(VARIA, TVARLOC(1..NBVARLOC))
            If IS
                TYPCOUR=TYPVARLOC(IS)

                If SPENCOURS = "" and NBPASSE > 1

                    # vÃĐrification si elle n'est pas ÃĐgalement dÃĐclarÃĐe en global
                    IS=find(VARIA, GTVARGLOB(1..NBVARGLOB))
                    If IS
                        ERRMES(1) = func AVERIFSRC.MESNUM(88, 144, VARIA, GPROGVARGLOB(IS), "", "", "")
                        Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                             CHAINECPT, NBERREUR, NBWARNING, NLIG, 10, TERREUR, SAUVEMODULE, PNUMERREUR,
&                             NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)

                    Else
                        #ajout 2009.11.23
                        IS = find(VARIA, GTVARGLOBDIC(1..NBVARGLOBDIC))
                        If IS
                           ERRMES(1) = func AVERIFSRC.MESNUM(89, 144, VARIA, "", "", "", "")
                            Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                             CHAINECPT, NBERREUR, NBWARNING, NLIG, 10, TERREUR, SAUVEMODULE, PNUMERREUR,
&                             NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)

                        Endif
                    Endif

                Endif
            Else
                IS=find(VARIA, GTVARGLOB(1..NBVARGLOB))

                If IS
                    TYPCOUR=GTYPVARGLOB(IS)
                    WPROGVARGLOB(NBARG) = GPROGVARGLOB(IS)
                    WBVARGLOB(NBARG) = 2
                Else
                    #ajout 2009.11.23
                    IS = find(VARIA, GTVARGLOBDIC(1..NBVARGLOBDIC))
                    If IS
                        TYPCOUR=GTYPVARGLOBDIC(IS)
                        WPROGVARGLOB(NBARG) = ""
                        WBVARGLOB(NBARG) = 1
                    Else
                        TYPCOUR=4 : # Variable inconnue
If PNUMERREUR = 73
    Wrseq "ano" - num$(PNUMERREUR) - "trt :" - GTTRAITEMENTS(NF) - "var inconnue (nÂ° ligne/variable) :" - num$(NLIG) - VARIA - "--> :" - CHAINECPT Using [FWR]
Endif
                    Endif
                Endif
            Endif
        Else
            # On n'a pas trouvÃĐ : on force l'argument Ã  indÃĐterminÃĐ, l'analyse est inutile
            # on ne devrait jamais passer ici
            ARGUMENTS(NBARG)=4
            TYPCOUR=0
            TYPCOUR=4 #CBO20110315
            OPERATEUR=""
            Return
        Endif
    Endif

    # Si on a analysÃĐ un argument et qu'il en reste derriÃĻre, on tente de voir la suite
    If CHAINE <> "" & instr(1, "+-*/^&|<>=",left$(CHAINE,1))
        # CBO 20110314
#        If TYPCOUR = 1
#        OPERATEUR = ""
#        Else
        OPERATEUR = left$(CHAINE, 1)
        CHAINE = vireblc(right$(CHAINE, 2), 0)

        # CBO 20110314 FQ72325 (pas grave de perdre la fin de l'opÃĐrateur : mÃŠme, cela simplifie
        # les tests d'opÃĐrations entre types)
        If OPERATEUR = "<" and (left$(CHAINE, 1)= "=" or left$(CHAINE, 1) = ">")
            CHAINE = vireblc(right$(CHAINE, 2), 0)
        Elsif OPERATEUR = ">" and left$(CHAINE, 1)= "="
            CHAINE = vireblc(right$(CHAINE, 2), 0)
        Endif
#        Endif
    Else
        OPERATEUR = ""
    Endif
Return


# _____________
$SKIPAR : # On va Ã  la prochaine parenthÃĻse ouvrante (on sait qu'existe) et on cherche la suivante appariÃĐe

# SI IL N'y a pas de () ds la fct en paramÃĻtre : on a des pbs donc...
#    WNOMARG = func FNOMARG (CHAINE, instr(1, CHAINE, "(") - 1)
#    CHAINE = right$(CHAINE, instr(1, CHAINE, "("))

    IS = instr(1, CHAINE, "(")
    If IS
        # on garde la partie gauche
        WNOMARG = func FNOMARG (CHAINE, IS - 1)
        CHAINE = right$(CHAINE, instr(1, CHAINE, "("))
    Else
        NBPARENTH = 0
        Return
    Endif

$SAUTEPAR : # On saute jusqu'Ã  la derniÃĻre parenthÃĻse du groupe
    NBPARENTH = 1
    CHAINE=right$(CHAINE,2)
    Repeat
    # On saute Ã  la prochaine parenthÃĻse (ouvrante ou fermante) ou Ã  la prochaine quote (simple ou double)
        CHAINE = right$(CHAINE, min(instr(1, CHAINE + "(", "("), instr(1, CHAINE + ")", ")"),
&                                   instr(1, CHAINE + "'", "'"), instr(1, CHAINE + '"', '"')))

        If instr(1, "'" + '"', left$(CHAINE, 1))
    # On saute Ã  la double ou simple quote suivante (Ã  la fin s'il n'y en a pas)
            CHAINE = right$(CHAINE, instr(2, CHAINE + left$(CHAINE, 1), left$(CHAINE, 1))+1)
        Else
            NBPARENTH += (left$(CHAINE, 1) = "(") - (left$(CHAINE, 1) = ")")
            CHAINE = right$(CHAINE,2)
        Endif
    Until NBPARENTH=0 or CHAINE=""
Return

$FINEXPR
XXBOK = 1
    While XXBOK
        XXBOK = instr(1, ctrans(CHAINE, "(),", string$(3, 1)), chr$(1))
        If XXBOK
            CHAINE=right$(CHAINE, XXBOK)
            If left$(CHAINE, 1) = "("
                Gosub SAUTEPAR
            Elsif left$(CHAINE, 1) = "," or left$(CHAINE, 1) = ")"
                Break
            Endif
        Endif
    Wend
Return
# _____________
# Analyse des paramÃĻtres locaux dans un Call
$ANAPARLOC
    If IS = 1
        IS = instr(1, CHAINE, "Value ") + len("Value ")
    Elsif IS = 2
        IS = instr(1, CHAINE, "Variable ") + len("Variable ")

    Else
        IS = instr(1, CHAINE, "Const ") + len("Const ")
    Endif

    CHAINE = vireblc(right$(CHAINE, IS), 0)

    # CBO STRUCT
    IS = instr(1, CHAINE, "Struct")
    If IS
        CHAINE = right$(CHAINE, IS + 7)
        IS = instr(1, CHAINE, "Using")
        If IS
            CHAINE = left$(CHAINE, IS - 2)
        Endif
    Endif
    # fin CBO STRUCT

    Goto VARLOC1 : # On fait comme si c'ÃĐtait des variables locales


#___________________________________________
# Analyse des variables locales dans un Call
$ANAVARLOC

CHAINE = vireblc(right$(CHAINE, instr(1, CHAINE, "Local ") + 6), 0)

$VARLOC1
#opti : ttes les lg sont augmentÃĐes de 1 et le vireblc est enlevÃĐ
If  pat(CHAINE,"Libelle *")
#opti    CHAINE=vireblc(right$(CHAINE,8),0)
    CHAINE = right$(CHAINE, 9)
    TYPCOUR=2
    Gosub RECHVARLOC
Elsif pat(CHAINE,"Shortint *")
    CHAINE=right$(CHAINE, 10)
    TYPCOUR=2
    Gosub RECHVARLOC
Elsif pat(CHAINE,"Integer *")
    CHAINE=right$(CHAINE, 9)
    TYPCOUR=2
    Gosub RECHVARLOC
Elsif pat(CHAINE,"Decimal *")
    CHAINE=right$(CHAINE, 9)
    TYPCOUR=2
    Gosub RECHVARLOC
Elsif pat(CHAINE,"Date *")
    CHAINE=right$(CHAINE, 6)
    TYPCOUR=3
    Gosub RECHVARLOC
Elsif pat(CHAINE,"Char *")
    CHAINE=right$(CHAINE, 6)
    TYPCOUR=1
    Gosub RECHVARLOC
Elsif pat(CHAINE,"Clbfile *")
    CHAINE=right$(CHAINE, 9)
    TYPCOUR=5
    Gosub RECHVARLOC
Elsif pat(CHAINE,"Blbfile *")
    CHAINE=right$(CHAINE, 9)
    TYPCOUR=6
    Gosub RECHVARLOC
Endif : # Sinon, c'ÃĐtait un Local File ou une autre dÃĐclaration
Return



#___________________________________________
$RECHVARLOC

    While CHAINE <> "" & func DEBALPHA(CHAINE) : # On trouve une variable locale
#    While CHAINE <> "" & instr(1,ALPHA,left$(CHAINE,1)) : # On trouve une variable locale
        VARIA = func CHALPHA(CHAINE, IS)
#        IS = len(CHAINE) - len(vireblc(ctrans(CHAINE,ALPHAN,SPACEN),0))
#        VARIA = vireblc(left$(CHAINE,IS), 2)
        CHAINE = vireblc(right$(CHAINE,IS+1),0)

        IS=find(VARIA, TVARLOC(1..NBVARLOC))
        If IS
            If TYPCOUR<>TYPVARLOC(IS)
                #WARNING : la mÃŠme variable est dÃĐclarÃĐe avec des types diffÃĐrents
                TYPVARLOC(IS)=4 : # On considÃĻre que la variable est indÃĐterminÃĐe pour la suite
                If REPTRT <> GTTRAITEMENTS(NF)
                    PTREP=1
                    REPVAR(PTREP)=VARIA
                Elsif find(VARIA,REPVAR(1..PTREP))=0 : # On ne fait l'avertissement qu'une fois
                    PTREP+=1
                    If PTREP <= dim(REPVAR)
                        REPVAR(PTREP)=VARIA
                    Endif
                    If find(GTTRAITEMENTS(NF)+'.'+VARIA, EXCEPTVAR(1..NEX2))=0
                    # Si la variable de fait pas partie des exceptions => avertissement

                       ERRMES(1) = VARIA - "(" + func TYPEDATA(TYPCOUR) + ")" - mess(1011, 144, 1)
                       Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                                     CHAINECPT, NBERREUR, NBWARNING, NLIG, 11, TERREUR, SAUVEMODULE, PNUMERREUR,
&                                     NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
                    Endif
                Endif
                REPTRT=GTTRAITEMENTS(NF)
            Endif
        Else
            #CBO 20091124 contrÃīle si existe en global
            If NBPASSE > 1
                IS=find(VARIA, GTVARGLOB(1..NBVARGLOB))
            Endif
            If IS
                If TYPCOUR <> GTYPVARGLOB(IS)
                    ERRMES(1) = func AVERIFSRC.MESNUM(90, 144, func TYPEDATA(TYPCOUR), VARIA, GPROGVARGLOB(IS), "", "")
                    Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                                  CHAINECPT, NBERREUR, NBWARNING, NLIG, 11, TERREUR, SAUVEMODULE, PNUMERREUR,
&                                  NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
                Endif
            Else
                If NBPASSE > 1
                    IS = find(VARIA, GTVARGLOBDIC(1..NBVARGLOBDIC))
                Endif
                If IS
                    If TYPCOUR <> GTYPVARGLOBDIC(IS)
                        ERRMES(1) = func AVERIFSRC.MESNUM(91, 144, func TYPEDATA(TYPCOUR), VARIA, "", "", "")
                        Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                                      CHAINECPT, NBERREUR, NBWARNING, NLIG, 11, TERREUR, SAUVEMODULE, PNUMERREUR,
&                                      NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
                    Endif
                Endif
            Endif
            NBVARLOC+=1
            TVARLOC(NBVARLOC)=VARIA
            TYPVARLOC(NBVARLOC)=TYPCOUR

        Endif

        While left$(CHAINE,1)="(" : # On empile/dÃĐpile les parenthÃĻses
            NBPARENTH=1
            CHAINE=right$(CHAINE,2)
            Repeat
                CHAINE=right$(CHAINE,min(instr(1,CHAINE+"(","("),instr(1,CHAINE+")",")")))
                NBPARENTH+=(left$(CHAINE,1)="(")-(left$(CHAINE,1)=")")
                CHAINE=right$(CHAINE,2)
            Until NBPARENTH=0 or CHAINE=""
            CHAINE=vireblc(CHAINE,0)
        Wend
        If left$(CHAINE,1)="," : # Une autre variable suit
            CHAINE=vireblc(right$(CHAINE,2),0)
        Endif
        If left$(CHAINE,1)=":" : # Une autre instruction suit
            CHAINE=vireblc(right$(CHAINE,2),0)
            Break
        Endif
    Wend
Return



