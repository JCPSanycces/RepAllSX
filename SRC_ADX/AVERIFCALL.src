# Analyse des variables Globales dans un Call
#Copie presque conforme des sous-programmes prÃĐcÃĐdents (rÃĐpÃĐtÃĐs pour raisons de performance)

$ANAVARGLOB

CHAINE=vireblc(right$(CHAINE,instr(1,CHAINE+"Global ","Global ")+7),0)
If    pat(CHAINE,"Libelle *")
#opti on ajoute 1 et enlÃĻve vireblc    CHAINE=vireblc(right$(CHAINE,8),0)
    CHAINE=right$(CHAINE, 9)
    TYPCOUR=2
    Gosub RECHVARGLOB
Elsif pat(CHAINE,"Shortint *")
    CHAINE=right$(CHAINE, 10)
    TYPCOUR=2
    Gosub RECHVARGLOB
Elsif pat(CHAINE,"Integer *")
    CHAINE=right$(CHAINE, 9)
    TYPCOUR=2
    Gosub RECHVARGLOB
Elsif pat(CHAINE,"Decimal *")
    CHAINE=right$(CHAINE, 9)
    TYPCOUR=2
    Gosub RECHVARGLOB
Elsif pat(CHAINE,"Date *")
    CHAINE=right$(CHAINE, 6)
    TYPCOUR=3
    Gosub RECHVARGLOB
Elsif pat(CHAINE,"Char *")
    CHAINE=right$(CHAINE, 6)
    TYPCOUR=1
    Gosub RECHVARGLOB
Elsif pat(CHAINE,"Clbfile *")
    CHAINE=right$(CHAINE, 9)
    TYPCOUR=5
    Gosub RECHVARGLOB
Elsif pat(CHAINE,"Blbfile *")
    CHAINE=right$(CHAINE, 9)
    TYPCOUR=6
    Gosub RECHVARGLOB
Endif : # Sinon, c'ÃĐtait un Global File ou une autre dÃĐclaration
Return


$RECHVARGLOB

    While CHAINE<>"" & func DEBALPHA(CHAINE) : # On trouve une variable globale
#    While CHAINE<>"" & instr(1,ALPHA,left$(CHAINE,1)) : # On trouve une variable globale
        VARIA = func CHALPHA(CHAINE, IS)
#        IS = len(CHAINE) - len(vireblc(ctrans(CHAINE,ALPHAN,SPACEN),0))
#        VARIA=vireblc(left$(CHAINE,IS),2)
        CHAINE=vireblc(right$(CHAINE,IS+1),0)

        IS3 = 0
        If find(VARIA, TVGLOBEXCP(1..NBVGLOBEXCP)) = 0

            # recherche si dÃĐjÃ  ds 1 des 3 tableaux
            IS=find(VARIA, GTVARGLOB(1..NBVARGLOB))
            If IS
                IS3 = 1
            Else
                #ajout 2009.11.23
                IS = find(VARIA, GTVARGLOBDIC(1..NBVARGLOBDIC))
                If IS
                    IS3 = 2
                Else
                    IS = find(VARIA, GTVARGLOBSRC(1..NBVARGLOBSRC))
                    If IS
                        IS3 = 3
                    Else
                        If NBVARGLOB >= GMAX_VAR - 1
                            DEPAS_VARGLOB += 1
                        Else
                            NBVARGLOB += 1
                        Endif
                        GTVARGLOB(NBVARGLOB)    = VARIA
                        GTYPVARGLOB(NBVARGLOB)  = TYPCOUR
                        GPROGVARGLOB(NBVARGLOB) = GTTRAITEMENTS(NF)
                        GLIBTYPGLOB(NBVARGLOB) = ""
                        IS = NBVARGLOB

       #     If left$(GTVARGLOB(NBVARGLOB),1)<>"G" : # ELA le 5/10/2004 : Voir comment tracer Ã§a sans remettre en cause l'existant
       #         ERRMES(1)=GTTRAITEMENTS(NF)+"("+num$(NLIG)+") : Declaration de la variable globale "
       #         ERRMES(1)+=string$(TYPCOUR=1,"chaine")+string$(TYPCOUR=2,"numerique")+string$(TYPCOUR=3,"date")-VARIA
       #         ERRMES(2)="**** Avertissement : cette variable ne commence pas par G"
       #         Wrseq ERRMES(1)
       #         Wrseq ERRMES(2)
       #     Endif
                    Endif
                Endif
            Endif

            # dÃĐjÃ  dÃĐclarÃĐ avec un type diffÃĐrent
            If WMODULEOK and PACTION <> 3
                If IS3 = 1 and GTYPVARGLOB(IS) <> TYPCOUR
                    ERRMES(1)  = func AVERIFSRC.MESNUM(90, 144, func TYPEDATA(TYPCOUR), VARIA, GPROGVARGLOB(IS), func TYPEDATA(GTYPVARGLOB(IS)), "")
                   Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                       CHAINECPT, NBERREUR, NBWARNING, NLIG, 12, TERREUR, SAUVEMODULE, PNUMERREUR,
&                       NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)

                    # positionnement au type du pgm en cours
                    GTYPVARGLOB(IS) = TYPCOUR
                    GPROGVARGLOB(IS) = GTTRAITEMENTS(NF)
                Elsif IS3 = 2 and GTYPVARGLOBDIC(IS) <> TYPCOUR
                    ERRMES(1)  = func AVERIFSRC.MESNUM(91, 144, func TYPEDATA(TYPCOUR), VARIA, func TYPEDATA(GTYPVARGLOBDIC(IS)), "", "")
                    Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                        CHAINECPT, NBERREUR, NBWARNING, NLIG, 12, TERREUR, SAUVEMODULE, PNUMERREUR,
&                        NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
                Elsif (IS3 = 3 and TYPCOUR <> 1)
                    ERRMES(1)  = func AVERIFSRC.MESNUM(91, 144, func TYPEDATA(TYPCOUR), VARIA, func TYPEDATA(1), "", "")
                    Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
&                        CHAINECPT, NBERREUR, NBWARNING, NLIG, 12, TERREUR, SAUVEMODULE, PNUMERREUR,
&                        NLIGSAV, PATCH, WMIGRATE, PDEMANDEUR)
                Endif
            Endif
        Endif

#    If left$(VARIA, 1) <> "G"
#        ERRMES(1)  = "Variable" - VARIA - "ne commence pas par G"
#        Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE, TITAECRIREW,
#&            CHAINECPT, NBERREUR, NBWARNING, NLIG, 20, TERREUR, SAUVEMODULE, PNUMERREUR, NLIGSAV,
#&            PATCH, WMIGRATE, PDEMANDEUR)
#    Endif

        While left$(CHAINE,1)="(" : # On empile/dÃĐpile les parenthÃĻses
            NBPARENTH=1
            CHAINE=right$(CHAINE,2)

            If IS3 = 0 or IS3 = 1
                If GLIBTYPGLOB(IS) = ""
                    GLIBTYPGLOB(IS) = left$(CHAINE, min(instr(1,CHAINE+"(","("),instr(1,CHAINE+")",")")) - 1)

                    If left$(GLIBTYPGLOB(IS), len(GPREFIXE)) = GPREFIXE
                        GLIBTYPGLOB(IS) = right$(GLIBTYPGLOB(IS), len(GPREFIXE) + 1)
                    Endif
                Endif
            Endif

            Repeat
                CHAINE = right$(CHAINE, min(instr(1, CHAINE + "(", "("), instr(1, CHAINE + ")", ")")))
                NBPARENTH += (left$(CHAINE,1)="(")-(left$(CHAINE,1)=")")
                CHAINE=right$(CHAINE,2)
            Until NBPARENTH=0 or CHAINE=""
            CHAINE=vireblc(CHAINE,0)
        Wend

        # on recherche la longueur de la chaÃŪne
        If IS3 = 0 or IS3 = 1
            If TYPCOUR = 1
             # longueur par dÃĐfaut d'1 chaÃŪne
                If GLIBTYPGLOB(IS) = ""
                    GLIBTYPGLOB(IS) = GSANSLG
                Else
                    If func AVERIFSRC.VALN(GLIBTYPGLOB(IS)) = -1
                        If func AVERIFSRC.MTCLEFCOMPLEXE(GLIBTYPGLOB(IS)) = 0

                            WSTYPE = GLIBTYPGLOB(IS)
                            If left$(WSTYPE, len(GPREFIXE)) = GPREFIXE
                                WSTYPE = right$(WSTYPE, len(GPREFIXE) + 1)
                            Endif

                            # type de donnÃĐes
                            IS2 = find(WSTYPE, TCODTYPATY(1..NBTYPEATY)) = 0
                            If IS2
                                GTLGVARGLOB(IS) = TLGTYPATY(IS2)
                            Else
                                IS2 = find(WSTYPE, GTVARGLOBSRC(1..NBVARGLOBSRC))
                                If IS2
                                    GTLGVARGLOB(IS) = GTLGVARGLOBSRC(IS2)
                                Else
                                    # dÃĐfinition de longueur par une variable globale (de source)
                                    IS2 = find(WSTYPE, GTVARGLOB(1..NBVARGLOB))
                                    If IS2
                                        GTLGVARGLOB(IS) = GTLGVARGLOB(IS2)
                                    Else
                                        # dÃĐfinition de longueur par une variable globale (du dico)
                                        IS2 = find(WSTYPE, GTVARGLOBDIC(1..NBVARGLOBDIC))
                                        If IS2
                                            GTLGVARGLOB(IS) = GTLGVARGLOBDIC(IS2)
                                        Endif

                                    Endif
                                Endif
                            Endif
                        Else
                            # mot clef complexe : non traitable
                            If IS3 = 0
                                NBVARGLOB -= 1
                            Endif
                        Endif
                    Endif
                Endif
            Else
                #cas des num et dates
                IS2 = instr(1, VARIA, "(")
                If IS2
                    VARIA = left$(VARIA, IS2 - 1)
                Endif

                IS = find(VARIA, GTVARGLOB(1..NBVARGLOB))
                If IS3 = 0
                    If NBVARGLOB >= GMAX_VAR - 1
                        DEPAS_VARGLOB += 1
                    Else
                        NBVARGLOB += 1
                    Endif
                    GTVARGLOB(NBVARGLOB) = VARIA
                    GTYPVARGLOB(NBVARGLOB)  = TYPCOUR
                    GLIBTYPGLOB(NBVARGLOB) = "-" + num$(TYPCOUR)
                Elsif IS3 = 1
                    GLIBTYPGLOB(IS) = "-" + num$(TYPCOUR)
                Endif
            Endif
        Endif

        If left$(CHAINE,1)="," : # Une autre variable suit
            CHAINE=vireblc(right$(CHAINE,2),0)
        Endif
    Wend
Return


