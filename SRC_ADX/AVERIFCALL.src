# recherche le type d'une fonction + doc correspondante
# si aucun type (non trouvÃĐ ou version < 7), on fera un GOSUB ANAEND qui tentera de le dÃĐterminer


Subprog TYPEFONCTION (PPROG , PSUBPROG, RTYPE, TDTYPARG, TDADRVAL, PBTABLEASP)
Value Char PPROG
Value Char PSUBPROG

Variable Integer RTYPE #######, RERRTEXTE
Variable Integer TDTYPARG(), TDADRVAL()
Value Integer PBTABLEASP

Local Integer I

    Raz TDTYPARG, TDADRVAL
    If dim([F:ASU]TYPFCT) < 0
        RTYPE = 0
        End
    Endif

    Read [ASU]ASU0 = PPROG ; PSUBPROG
    If fstat
        RTYPE = -1
        End
    Endif

    RTYPE = [F:ASU]TYPFCT
    If RTYPE = 0
        RTYPE = -2
    Endif
    # CBO 2009.07.31
    # attention ASUBPROG fonctionne sur le menu 33 qui est diffÃĐrent de la codif de ce pgm !!!
    Call RECODIFM33(RTYPE)

    For I = 1 To [F:ASU]NBRPAR
        # V6.2 patch 11 dÃĐplacement des infos dans ASUBPROGD
        # TCH, Bug 102060, Table ASUBPROG no longer contains column TYPPAR
        If !PBTABLEASP
            TDTYPARG(I) = [F:ASU]TYPPAR(I-1)
            TDADRVAL(I) = [F:ASU]ADRVAL(I-1)
        Else
            Read [ASP]ASP0 = PPROG ; PSUBPROG ; (I-1)
            If fstat = 0
                TDTYPARG(I) = [F:ASP]TYPPAR
                TDADRVAL(I) = [F:ASP]ADRVAL
            Endif
        Endif
        # attention ASUBPROG fonctionne sur le menu 33 qui est diffÃĐrent de la codif de ce pgm !!!
        Call RECODIFM33(TDTYPARG(I))
    Next I

End

# attention ASUBPROG fonctionne sur le menu 33 qui est diffÃĐrent de la codif de ce pgm !!!
Subprog RECODIFM33(RTYPNUM)
Variable Integer RTYPNUM

    If RTYPNUM = 3
        RTYPNUM = 2
    Elsif RTYPNUM = 4
        RTYPNUM = 3
    Elsif RTYPNUM = 5
        RTYPNUM = 2
    Elsif RTYPNUM = 6
        RTYPNUM = 5
    Elsif RTYPNUM = 7
        RTYPNUM = 6
    Endif
End

Funprog TYPEDATA (PTYPENUM)
Value Integer PTYPENUM

Local Char TYPEALFA(20)

    Case PTYPENUM
    When 1 :
        TYPEALFA = "chaÃŪne"
    When 2 :
        TYPEALFA = "numerique"
    When 3 :
        TYPEALFA = "date"
    When 4 :
        TYPEALFA = "indeterminÃĐ"
    When 5 :
        TYPEALFA = "clob"
    When 6 :
        TYPEALFA = "blob"
    When 9 :
        TYPEALFA = "classe"
    When Default :
        TYPEALFA = num$(PTYPENUM)
    Endcase

End TYPEALFA

Funprog FNOMARG (PCHAINE, PPOS)
Value Clbfile PCHAINE
Value Integer PPOS

    If PPOS > 0 and PCHAINE <> ""
        End left$(PCHAINE, PPOS)
    Endif

End PCHAINE

#------------------------------------------------------------------------------------------------------------------------#

Subprog ECRERREUR(PMODULE, PTRAITEMENT, ERRMES, TITAECRIRE, TITAECRIREW, CHAINE,
&       NBERREUR, NBWARNING, NLIG, INDERREUR, TERREUR, SAUVEMODULE, PNUMERREUR, NLIGSAV, PATCH,
&       PMIGRATE, PDEMANDEUR)
Value Integer PMODULE
Variable Char PTRAITEMENT
Variable Char ERRMES()
Variable Integer TITAECRIRE, TITAECRIREW
Value Clbfile CHAINE
Variable Integer NBERREUR, NBWARNING
Variable Integer NLIG
Value Integer INDERREUR
Variable Integer TERREUR()
Variable Shortint SAUVEMODULE
Value Integer PNUMERREUR
Variable Integer NLIGSAV
Value Char PATCH
Value Integer PMIGRATE
Value Integer PDEMANDEUR

Local Integer IC


    If PNUMERREUR <> 0 and PNUMERREUR <> INDERREUR
        # sortir ÃĐgalement la 18 et 19 si la 17 est sÃĐlectionnÃĐe
        If (PNUMERREUR <> 17 and PNUMERREUR <> 18 and PNUMERREUR <> 19) or (INDERREUR <> 17 and INDERREUR <> 18 and INDERREUR <> 19)
            Raz ERRMES
            End
        Endif
    Endif

    # recherche des W : pas d'erreur sur les pgms superviseurs chargÃĐs
    If PDEMANDEUR = -5 and left$(PTRAITEMENT, 1) < "W"
        Raz ERRMES
        End
    Endif

    If GBTDESACTIVE(GNUMMOUL, INDERREUR) or (PMIGRATE and GTMIGRATE(GNUMMOUL, INDERREUR))
        Raz ERRMES
        End
    Endif

    Call ECRIRETITRE(TITAECRIRE, TITAECRIREW, INDERREUR, PMODULE, PTRAITEMENT, SAUVEMODULE,
&       NBERREUR, NBWARNING, NLIG, NLIGSAV) From AVERIFSRC

    TERREUR(INDERREUR) += 1
    GTRECAPERR(GNUMMOUL, [F:ADC]MODULE, INDERREUR) += 1

    If GBTWARNING(GNUMMOUL, INDERREUR)
        Wrseq "  *** (" + mess(57, 144, 1) - num$(NLIG) - mess(55, 144, 1) - num$(INDERREUR) + ")" - ERRMES(1) Using [FWR]
    Else
        Wrseq "  *** (" + mess(57, 144, 1) - num$(NLIG) - mess(56, 144, 1) - num$(INDERREUR) + ")" - ERRMES(1) Using [FER]
    Endif

    # Ecrire les autres lignes
    IC = 2
    While IC <=20
        If ERRMES(IC) <> ""
            If GBTWARNING(GNUMMOUL, INDERREUR)
                Wrseq "  ***" - ERRMES(IC) Using [FWR]
            Else
                Wrseq "  ***" - ERRMES(IC) Using [FER]
            Endif
        Endif
        IC += 1
    Wend

    If CHAINE <> "" and (PATCH <> "" or WBECRIRELIGNESOURCE)
        If GBTWARNING(GNUMMOUL, INDERREUR)
            Wrseq "  -->" - CHAINE Using [FWR]
        Else
            Wrseq "  -->" - CHAINE Using [FER]
        Endif
    Endif
    Raz ERRMES

End


# Dichotomie sur le tableau GTTRAITEMENTS
Funprog FINDTRT(PTRT, POSD, POSF)
Value Char PTRT
Value Integer POSD, POSF

Local Integer WPOS, WPOSOLD, WPOSD, WPOSF
#POSUTIL = find(NOMPROG, GTTRAITEMENTS(1..GNBTRTADX))

    WPOSD = POSD
    WPOSF = POSF


    If POSF and POSF < 10
        WPOS = find(PTRT, GTTRAITEMENTS(WPOSD..WPOSF))
        End WPOS
    Endif

    WPOSOLD = -1
    WPOS = int(WPOSD + (WPOSF - WPOSD)/2)

    While WPOS
        If PTRT = GTTRAITEMENTS(WPOS)
            Break
        Elsif WPOS < WPOSD or WPOS >= WPOSF
            WPOS = 0
            Break
        Elsif PTRT < GTTRAITEMENTS(WPOS)
            WPOSF = WPOS
            WPOS = int(WPOSD + (WPOSF - WPOSD)/2)
        Elsif PTRT > GTTRAITEMENTS(WPOS)
            WPOSD = WPOS
            WPOS = int(WPOSD + (WPOSF - WPOSD)/2)
        Endif
        If WPOSOLD = WPOS
            If WPOS = WPOSF - 1 and PTRT = GTTRAITEMENTS(WPOSF)
                WPOS = WPOSF
            Else
                WPOS = 0
            Endif
            Break
        Endif
        WPOSOLD = WPOS
    Wend
End WPOS

# POUR RETROUVER LE NOM D'1 sous-pro, fct ou variable
Funprog CHALPHA(PCHAINE, RLONGUEUR)
Variable Clbfile PCHAINE
Variable Integer RLONGUEUR

Local Char VARIA(50), WCAR(1)
Local Integer IQ, WNCAR
#        If instr(1, ALPHAN, left$(PCHAINE,1)) : # On trouve une variable locale
#
#
#        IS=len(PCHAINE)-len(vireblc(ctrans(PCHAINE, ALPHAN, SPACEN),0))
#        VARIA=vireblc(left$(PCHAINE,IS),2)
#        End VARIA
#        Endif
#        End ""
#
#    If left$(PCHAINE, 1) < "A" or left$(PCHAINE, 1) > "Z"
#        End ""
#    Endif



    # iq est la position du dÃĐbut du champ
    VARIA = ""
    IQ = 1
#    RLONGUEUR = 0
# CBO 2011.02.07
    While len(PCHAINE) >= IQ
        WCAR = toupper(mid$(PCHAINE, IQ, 1))
        WNCAR = ascii(WCAR)
        If (WNCAR >= 65 and WNCAR <= 90) or (WNCAR >= 48 and WNCAR <= 57) or WNCAR = 95
            VARIA += WCAR
            IQ + =1
        Else
            Break
        Endif
    Wend
    RLONGUEUR = IQ - 1
End VARIA

#End

Funprog DEBALPHA(PCHAINE)
Variable Clbfile PCHAINE

Local Integer WNCAR
    WNCAR = ascii(left$(PCHAINE, 1))
    If (WNCAR >= 65 and WNCAR <= 90)
        End 1
    Endif
End 0
