#<AdxTL>@(#)202.0.0.0 $Revision$
Subprog CREAPL

Onerrgo ERREUR
If GINFO
 Call AFF_VLC(mess(10,125,1),"") From GESECRAN
 # Mise à jour répertoires
Endif
Call ECR_TIME(mess(10,125,1)) From DOSSUB

Local Char    APPLI(GDIMFIC) , VOLUME(1)
Local Char    REPERT(GDIMFIC) , ORDSYS(250)
Local Char    MACHINE(GDIMFIC) , REP(GDIMFIC) , SREP(GDIMFIC), FICH(GDIMFIC)
Local Char    NOMFIC1(GDIMFIC) , NOMFIC2(GDIMFIC) , NOMFIC3(GDIMFIC)
Local Char    DIRSEP(1)
Local Integer I , K , LANCUR , ERREUR

MACHINE = adxmac(0)
APPLI  = [F:ADS]DOSSIER
VOLUME = [F:ADS]VOLUME

Case GOS(1)
 When "unix" : DIRSEP = "/"
 When "dos"  : DIRSEP = "\"
Endcase

# Répertoire de base

ERREUR = 0
Call CREREP(filpath("","","",APPLI,VOLUME,MACHINE),ERREUR)
If ERREUR : GERRDOS = 1 : End : Endif

# Sous-répertoires niveau -1

Gosub SET_DIRECT_SYS
Gosub SET_DIRECT_STO
For I=1 To NBDIR
 Call CREREP(filpath(TBDIR(I),"","",APPLI,VOLUME,MACHINE),ERREUR)
Next I

# Sous-répertoires liés a la langue

Call CREREPAPP(APPLI)

# Sous-répertoires pour la publication

Local Char APPLI1(GLONADS)
APPLI1 = APPLI
Gosub CREREP_PUB From INTRUTILC
If ERREUR : GERRDOS = 1 : End : Endif

# Fichiers .users et .passwd

For FICH = ".users",".passwd"
 NOMFIC1 = filpath("",FICH,"",APPLI,VOLUME,MACHINE)
 If filinfo(NOMFIC1,0)<0
  Call ECR_TRACE("|"+mess(12,125,1)-ctrans(NOMFIC1,"\","/"),0) From GESECRAN
  # Création du fichier
  Openo NOMFIC1 , 0
  Openo
  If filinfo(NOMFIC1,0)<0
   Call ECR_TRACE(mess(184,124,1)+"\|"+ctrans(NOMFIC1,"\","/")+"|",1) From GESECRAN
   ERREUR = 1 : Break
  Endif
 Endif
Next FICH
If ERREUR : GERRDOS = 1 : End : Endif

# Mise à jour du fichier APL.ini

Call MAJ_APLINI(APPLI)

# Création de la classe OBJECT

Call CRE_CLASS_OBJECT(APPLI)

# Création version de l'archive

If filinfo(filpath("","vers","atx",APPLI),0)<=0
 Call SYSTEME(MACHINE,'archive -n -f -d'-APPLI,"",ERREUR) From ORDSYS
Endif

End

#-------------------#
$SET_DIRECT_SYS
If dim(TBDIR)<=0
 Gosub DIM_DIRECT
Endif
NBDIR += 1 : TBDIR(NBDIR) = "TRT"
NBDIR += 1 : TBDIR(NBDIR) = "FIL"
NBDIR += 1 : TBDIR(NBDIR) = "ETM"
NBDIR += 1 : TBDIR(NBDIR) = "TXT"
NBDIR += 1 : TBDIR(NBDIR) = "REPORT"
NBDIR += 1 : TBDIR(NBDIR) = "PCD"
NBDIR += 1 : TBDIR(NBDIR) = "GRAPH"
NBDIR += 1 : TBDIR(NBDIR) = "LNK"
NBDIR += 1 : TBDIR(NBDIR) = "ECR"
NBDIR += 1 : TBDIR(NBDIR) = "RQT"
NBDIR += 1 : TBDIR(NBDIR) = "STC"
Return

#-------------------#
$SET_DIRECT_STO
If dim(TBDIR)<=0
 Gosub DIM_DIRECT
Endif
NBDIR += 1 : TBDIR(NBDIR) = "TRA"   : # Traces
NBDIR += 1 : TBDIR(NBDIR) = "tmp"   : # Fichiers temporaires
NBDIR += 1 : TBDIR(NBDIR) = "BQR"   : # Banque réception
NBDIR += 1 : TBDIR(NBDIR) = "BQE"   : # Banque émission
NBDIR += 1 : TBDIR(NBDIR) = "BQT"   : # Banque transmission
NBDIR += 1 : TBDIR(NBDIR) = "LIA"   : # Liasses fiscales
NBDIR += 1 : TBDIR(NBDIR) = "PIC"   : # Images
NBDIR += 1 : TBDIR(NBDIR) = "CASH"  : # Caisse
NBDIR += 1 : TBDIR(NBDIR) = "DEC"   : # Déclarations
NBDIR += 1 : TBDIR(NBDIR) = "PAT"   : # Patterns for ZPL report
NBDIR += 1 : TBDIR(NBDIR) = "PATCH" : # Fichiers de patch
NBDIR += 1 : TBDIR(NBDIR) = "ATT" : # Fichiers de pièces jointes
NBDIR += 1 : TBDIR(NBDIR) = "EDI" : # Fichiers EDI
Return

#-------------------#
$DIM_DIRECT
Local Char    TBDIR(10)(1..30)
Local Integer NBDIR
Raz TBDIR , NBDIR
Return

#-----------------------------------------------------#
# Création de la classe Object
#-----------------------------------------------------#

Subprog CRE_CLASS_OBJECT(APPLI)
Value Char APPLI
Local Char NOM(30) , NOMFIC(255) , ORDSYS(255) , REP(5) , REPERT(255)
Local Integer STAT
REP = "STC"
REPERT = filpath(REP,"","",APPLI)
If filinfo(REPERT,0)>0
 NOMFIC = filpath("STC","OBJECT","stc",APPLI)
 Openo NOMFIC,0
 adxifs = "" : adxirs = chr$(10)
 Wrseq "#<AdxTJ>@(#)%I%"
 Wrseq "# Mother class"
 Wrseq "%%"
 Openo
 ORDSYS = "valstc "+APPLI+" OBJECT"
 Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
Endif
End


#-----------------------------------------------------#
# Mise à jour du fichier APL.ini
#-----------------------------------------------------#

Subprog MAJ_APLINI(APPLI)
Value Char APPLI
Local Char    VOLUME(1) , MACHINE(GDIMFIC)
Local Char    NOMFIC1(GDIMFIC) , NOMFIC2(GDIMFIC) , NOMFIC3(GDIMFIC)
Local Integer OK , K , LIG , STAT , MODIF , CRE
Local Integer FLGAPL(1..10)
Local Char    LIGNE(250) , OLIGNE(250) , VALEUR(80) , VARIA(80)
Local Integer VADXMTO , VADXMSO , VMAXMEM , VADXMPR , VSADMEM , VMAXHEAP

#------------------------------------------------------------------------------------------------------------------------------#
VADXMTO  = 100     : # fichiers ouverts
VADXMSO  = 10      : # fichiers séquentiels
                     # mb 25.2.2 bug 12841 maxmem passe à 8192 en standard (proposé par la hot-line, voté par l'exécutif)
                     # mb 6.9.2  maxmem passe à 10240 en standard (proposé par solon)
                     # mb 10.7.3  maxmem passe à 12480 en standard (proposé par CC suite à pb sur PRODV140)
                     # mb 2.3.4 maxmem passe à 20480 bug 21459
                     # mb 11.1.7 maxmem passe 25600 bug 39205
                     # mb 21.10.8 maxmem passe 32800 bug 48297
                     # SAM 122730 maxmem => 65536 (64x1024)
VMAXMEM  = 65536   : # maximum of memory
                     # mb 6.9.2  adxmpr passe à 100 en standard (proposé par solon)
VADXMPR  = 100     : # Nb de programmes
VSADMEM  = 20480   : # Taille mémoire sadora
VMAXHEAP = 49152   : # SAM 122730 memory place for classes (48x1024)
#------------------------------------------------------------------------------------------------------------------------------#

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=APPLI
APPLI  = [F:ADS]DOSSIER
VOLUME = [F:ADS]VOLUME
MACHINE = adxmac(0)

# Fichier APL.ini
NOMFIC1 = filpath("","APL","ini",APPLI,VOLUME,MACHINE)
If filinfo(NOMFIC1,0)<0
 Call ECR_TRACE("|"+mess(12,125,1)-"APL.ini",0) From GESECRAN : # Création du fichier
 CRE = 1
 MODIF = 0
 NOMFIC2 = filpath("","APL","ini",GDOSX3)
Else
 CRE = 0
 MODIF = 0
 NOMFIC2 = NOMFIC1
Endif
NOMFIC3 = filpath("","APL","new",APPLI,VOLUME,MACHINE)
Openi NOMFIC2
Openo NOMFIC3 , 0
adxifs = ""
adxirs = chr$(10)
fstat = 0
LIG = 0
Raz FLGAPL
Repeat
 Rdseq LIGNE
 If !fstat
  OK = 1
  LIG += 1
  OLIGNE = LIGNE
  K = instr(1,LIGNE,"=")
  If K
   VARIA = vireblc(left$(LIGNE,K-1),2)
   VALEUR = vireblc(right$(LIGNE,K+1),2)
   Case VARIA
    When "adxmother(0)" : VALEUR = '"'+[F:ADS]DOSREF+'"'        : # Appli mère référence
    When "adxmother(1)" : VALEUR = '"'+GDOSX3+'"'               : # Appli mère superviseur
    When "adxmother(2)" : If VALEUR="IAP" : OK = 0 : Endif      : # Ex IAP
    When "adxtim"       : OK = 0                                : # Tables des imprimantes ??
    When "adxttf"       : OK = 0                                : # Tables des fichiers ??
    When "adxtlb"       : OK = 0                                : # Tables des libellés ??
    When "messname(0)"  : OK = 0                                : # On ne met plus messname
    When "adxmto"
     VALEUR = num$(max(VADXMTO,[F:ADS]SYSPAR(2)))               : # fichiers ouverts
     FLGAPL(1) = 1
    When "adxmso"
     VALEUR = num$(max(VADXMSO,[F:ADS]SYSPAR(3)))               : # fichiers séquentiels
     FLGAPL(2) = 1
    When "maxmem"
     VALEUR = num$(max(VMAXMEM,1024*[F:ADS]SYSPAR(0)))          : # Taille mémoire
     FLGAPL(3) = 1
    When "adxmpr"
     VALEUR = num$(max(VADXMPR,[F:ADS]SYSPAR(1)))               : # Nb de programmes
     FLGAPL(4) = 1
    When "sadmem"
     VALEUR = num$(max(VSADMEM,1024*[F:ADS]SYSPAR(4)))          : # Taille mémoire sadora
     FLGAPL(5) = 1
    When "maxheap"
     VALEUR = num$(max(VMAXHEAP,1024*[F:ADS]SYSPAR(5)))         : # Taille mémoire structure
     FLGAPL(6) = 1
   Endcase
   LIGNE = VARIA + " = " + VALEUR
  Elsif LIG=1
   If left$(LIGNE,15)<>"#<AdxTJ>@(#)%I%"
    LIGNE = "#<AdxTJ>@(#)%I%" + " " + [F:ADS]NOMDOS
   Endif
  Endif
  If OK
   If OLIGNE<>LIGNE : MODIF = 1 : Endif
   Wrseq LIGNE
  Else
   MODIF = 1
  Endif
 Endif
Until fstat
If !FLGAPL(1) : Wrseq "adxmto = " + num$(max(VADXMTO,[F:ADS]SYSPAR(2)))        : MODIF = 1 : Endif
If !FLGAPL(2) : Wrseq "adxmso = " + num$(max(VADXMSO,[F:ADS]SYSPAR(3)))        : MODIF = 1 : Endif
If !FLGAPL(3) : Wrseq "maxmem = " + num$(max(VMAXMEM,1024*[F:ADS]SYSPAR(0)))   : MODIF = 1 : Endif
If !FLGAPL(4) : Wrseq "adxmpr = " + num$(max(VADXMPR,[F:ADS]SYSPAR(1)))        : MODIF = 1 : Endif
If !FLGAPL(5) : Wrseq "sadmem = " + num$(max(VSADMEM,1024*[F:ADS]SYSPAR(4)))   : MODIF = 1 : Endif
If !FLGAPL(6) : Wrseq "maxheap = " + num$(max(VMAXHEAP,1024*[F:ADS]SYSPAR(5))) : MODIF = 1 : Endif
Openi
Openo
If CRE      : #  CCL bug 49267 on ne crée pas le APL.ini en création de dossier
 Call MOVE(NOMFIC3,NOMFIC1,STAT) From ORDSYS
Endif
If MODIF & !CRE
 Call MOVE(NOMFIC1,filpath("","APL","old",APPLI,VOLUME,MACHINE),STAT) From ORDSYS
 Call MOVE(NOMFIC3,NOMFIC1,STAT) From ORDSYS
Endif
Onerrgo
If MODIF & !CRE
 Call ECR_TRACE("|"+func AFNC.MES(mess(156,125,1),"APL.ini"),0) From GESECRAN : # Fichier # modifié
Endif
End

#----------------------------------------------------------------------#
# Création des répertoires langues sous l'arborescence du dossier
#----------------------------------------------------------------------#

Subprog CREREPAPP(APPLI)
Value Char APPLI
Local Integer LANCUR , ERREUR
Local Char    VOLUME(1) , MACHINE(GDIMFIC)
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=APPLI
VOLUME = [F:ADS]VOLUME
MACHINE = adxmac(0)
For LANCUR=0 To [F:ADS]NBRLAN-1
 Call CREREP(filpath("M"+[F:ADS]LAN(LANCUR),"","",APPLI,VOLUME,MACHINE),ERREUR)
 Call CREREP(filpath("REPORT",[F:ADS]LAN(LANCUR),"",APPLI,VOLUME,MACHINE),ERREUR)
Next LANCUR
Close Local File
End

#----------------------------------------------------------------------#
# Création d'un répertoire sous l'arborescence du dossier
#----------------------------------------------------------------------#

Subprog CREREP(CHEMIN,ERREUR)
Value Char CHEMIN
Variable Integer ERREUR
Local Integer STAT
Local Char    ORDSYS(250) , MACHINE(GDIMFIC) , REPERT(GDIMFIC) , COMMAND(250)
If filinfo(CHEMIN,0)<0
 If dim(GSILCREREP)<0 : # Pour ne pas avoir le message dans SUBADS en ajout de langue dossier
  Call ECR_TRACE(mess(11,125,1)+" |"+CHEMIN,0) From GESECRAN
 Endif
 If dim(GINFO)>0 & GINFO
  Call AFF_VLC(mess(10,125,1),CHEMIN) From GESECRAN : # Création du répertoire
 Endif
 Call MACHINE(CHEMIN,MACHINE,REPERT) From ORDSYS
 If MACHINE<>""
  ORDSYS = MACHINE+"@"
 Else
  ORDSYS = ""
 Endif
 ORDSYS += 'ae_mkdir'-'"'+REPERT+'"'
 System COMMAND=ORDSYS
 If filinfo(CHEMIN,0)<0
  Call ECR_TRACE(mess(184,124,1)+"\|"+CHEMIN,1) From GESECRAN
  ERREUR = 1
 Endif
Endif
End

$ERREUR
Call ECR_TRACE(mess(6,123,1)-num$(errn)-errmes$(errn)-errm-errp-mess(61,100,1)-num$(errl),1) From GESECRAN
# Erreur...ligne no...
Resume

