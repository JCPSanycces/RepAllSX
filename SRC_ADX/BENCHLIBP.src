#<AdxTL>@(#)1.0.0.0 $Revision$
# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
#---------------------------------------------------------------------------#
# Actions Achat pour les outils d'approvisionnement/planification:          #
# - SAICREPOX    Création nouvel ordre POP/POF                              #
# - SAIMODPOX    Modification ordre POF + PEC                               #
#---------------------------------------------------------------------------#
$ACTION
Case ACTION
    When "OUVRE":         Gosub INIT : # Issue X3-4769 - 2017-06-14 by ALSHE : check reply from WIP exists message, close if NO
                          Case GACTION
                              When "SAICREPOX" : Gosub OUVRE_CREPOX
                              When "SAIMODPOX" : Gosub OUVRE_MODPOX
                          Endcase
    When "TITRE":         If find(GACTION,"SAICREPOX","SAIMODPOX") : TIT = XTITLE : Endif
    When "DEBUT":         Case GACTION
                              When "SAICREPOX" : Gosub DEBUT_CREPOX
                              When "SAIMODPOX" : Gosub DEBUT_MODPOX
                          Endcase
    When "SETBOUT":       Case GACTION
                              When "SAICREPOX" : Gosub SETBOUT_CREPOX
                              When "SAIMODPOX" : Gosub SETBOUT_MODPOX
                          Endcase
    When "AVANT_BOUTON"   Case GACTION
                              When "SAICREPOX" : Gosub AVBOUT_CREPOX
                          Endcase
    When "BOUTON":        Case GACTION
                              When "SAICREPOX" : Gosub BOUTON_CREPOX
                              When "SAIMODPOX" : Gosub BOUTON_MODPOX
                          Endcase
    When "ENR":           Case GACTION
                              When "SAIMODPOX":  Gosub ENR_MODPOX
                          Endcase
    When "SUP":           Case GACTION
                              When "SAIMODPOX":  Gosub SUP_MODPOX
                          Endcase
    When "FIN":           Case GACTION
                              When "SAIMODPOX":  If val(PARAM(9)) = 2
                                                       Case GFONCTION
                                                           When "FUNGBENCH","FUNGBENCHA" :
                                                                              If clalev ([M:MGD])=0
                                                                                 [M:MGB]REACT = 2
                                                                                 GLRET = 2
                                                                                 Gosub ACHAT From FUNGBENCH
                                                                              Else
                                                                                 [M:MGD]REACT = 2
                                                                                 GDLRET = 2
                                                                                 Gosub ACHAT From FUNDBENCH
                                                                              Endif
                                                           When "FUNDBENCH","FUNDBENCHA" :
                                                                              If clalev ([M:MGB])=0
                                                                                 [M:MGD]REACT = 2
                                                                                 GDLRET = 2
                                                                                 Gosub ACHAT From FUNDBENCH
                                                                              Else
                                                                                 [M:MGB]REACT = 2
                                                                                 GLRET = 2
                                                                                 Gosub ACHAT From FUNGBENCH
                                                                              Endif
                                                           When "FUNMLINK","FUNMLINKA" :
                                                                              [M:MLB]REACT = 2
                                                                              Gosub ACHAT From FUNMLINK
                                                       Endcase
                                                       Raz GMESSAGE
                                                   Endif
                          Endcase
    When Default
Endcase
Return

#---------------------------------------------------------------------------#
# Action INIT                                                               #
# Issue X3-4769 - 2017-06-14 by ALSHE : display message if WIP exists       #
#---------------------------------------------------------------------------#
$INIT
  If dim(GVALIDWIP) >= 0 and GVALIDWIP = [V]CST_ANO Then
    FIN = 1
    Return
  Endif
Return

#---------------------------------------------------------------------------#
# Action SAICREPOX                                                          #
#---------------------------------------------------------------------------#
###########################################################################
# ouverture
$OUVRE_CREPOX
Local    Char       WFCY(GLONFCY)
Local    Char       WITM(GLONITM)
Local    Integer    WAPPHAB
Local    Char       WPLANNER(20)
Local    Integer    WINTHAB

Local    Integer    WRET
Local    Integer    OK
Local    Char       XTITLE(250)
Local    Date       TODAY : TODAY = date$
Local    Integer    INDINTER : INDINTER = 0
Local    Char       MESS1(250), MESS2(250)

# 14102 mm 04.06
Local    Char       WORIFCY(GLONFCY)
Local    Date       WORIDAT, WSTRDAT
Local    Decimal    WLTI             # Issue 81510 GA 04/2012 before: Integer
Local    Integer    STAT
Local    Integer    WWIPTYP
Local    Char       WWIPNUM(GLONVCR)
#
Local    Integer    WPJTLAUNCH : WPJTLAUNCH=0 # Issue 107498/108 - 2016-05-20 by ALSHE : flag for control possibility of launching PJT products/POx
Local    Char       WPJT(40)
Local    Decimal    WQTYSTU # Issue X3-4774 - 2016-10-11 by ALSHE : Initialisation of Parameters when comming from PJM
Local    Date       WEXTRCPDAT # Issue X3-4774 - 2016-10-11 by ALSHE : Initialisation of Parameters when comming from PJM
Local    Char       WDATC(20) # Issue X3-4774 - 2016-10-11 by ALSHE : Initialisation of Parameters when comming from PJM
Local    Char       WBTSNUM(5) # Issue X3-4774 - 2016-11-07 by ALSHE : Entry transaction for enterpirse planning
Local    Char       WORDCRE(4)

If clalev ([F:ORD1])<= 0 : Local File ORDERS     [ORD1]: Endif
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:ITF1])<= 0 : Local File ITMFACILIT [ITF1]: Endif    # 14102 mm 04.06
If clalev ([F:FCY]) <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:TUV]) <= 0 : Local File TABUNAVAIL [TUV] : Endif
If clalev ([F:POC]) <= 0 : Local File PORDERC    [POC] : Endif
If clalev ([F:BPS]) <= 0 : Local File BPSUPPLIER [BPS] : Endif
If clalev ([F:TCU]) <= 0 : Local File TABCUR     [TCU] : Endif
If clalev ([F:ITP]) <=0  : Local File ITMBPS     [ITP] : Endif
If clalev ([F:BPR]) <=0  : Local File BPARTNER   [BPR] : Endif

If clalev ([M:PMG]) <= 0 : Local Mask PURMGT     [PMG] : Endif
If clalev ([M:ORDK]) <= 0 : Local Mask ORDK      [ORDK] : Endif    # 14102 mm 04.06

WFCY     = PARAM(1)
WITM     = PARAM(2)
WAPPHAB  = val(PARAM(3))
# Issue X3-51935 - 2017-09-20 by ALSHE : allow to create POF in material task line depending on user parameter PJMORDCRE
If func AFNC.ACTIV("PJM") & find(GFONCTION,"GESPJM")
    Call PARAMUTIL("PJMORDCRE",WORDCRE,GUSER,WFCY) From SUBAUS
    If WORDCRE = "2"
        WAPPHAB = 6
    Endif
Endif
# End issue X3-51935
WPLANNER = PARAM(4)
WINTHAB  = val(PARAM(5))
WPJT     = PARAM(7)
# Issue X3-4774 - 2016-10-11 by ALSHE : Initialisation of Parameters when comming from PJM
If PARAM(8) <> "" : WQTYSTU = val(PARAM(8)) : Else : WQTYSTU = 0 : Endif
WDATC = PARAM(9)
If WDATC <> ""
    If instr(1,WDATC,"/")
        WEXTRCPDAT = "["+WDATC+"]"
    Else
        WEXTRCPDAT = WDATC
    Endif
Endif
# End issue X3-4774

Raz PARAM(6)

# GA pour les paramètres interface cpta 150
GFCY=WFCY
Gosub CHARG_PARAM

# Issue X3-4774 - 2016-11-07 by ALSHE : Read entry transaction from Parameter PJMPLNTRA
If find(GFONCTION,"GESPJM")
    If clalev ([F:BTS])=0  : Local File BENCHTRS [BTS] : Endif
    Call PARAMUTIL("PJMPLNTRA",WBTSNUM,GUSER,WFCY) From SUBAUS
    Read [BTS]BTS0=51;WBTSNUM
Endif
# End issue X3-4774



XTITLE = mess(460,198,1)

Return

###########################################################################
# chargement
$DEBUT_CREPOX
Gosub CHARGE_PBW3
Affzo [M:PBW3]1-99

# Issue 104943 - 2015-06-29 by BEEBE : Implementing Versioning
If dim([M:PBW3]ECCVALMAJ)>0
    Call ECCAFF([M:PBW3]ITMREF,"PBW3") From MFGECCLIB

    If func ECCLIB.NBRCPN([M:PBW3]ITMREF)
        # ECC preload of major and minor version
        Raz [M:PBW3]ECCVALMAJ, [M:PBW3]ECCVALMIN
        Call INIECCITM([M:PBW3]ITMREF, [M:PBW3]STOFCY, [M:PBW3]EXTRCPDAT, [M:PBW3]ECCVALMAJ,[M:PBW3]ECCVALMIN,4) From MFGECCLIB
        Affzo [M:PBW3]ECCVALMAJ
        Affzo [M:PBW3]ECCVALMIN
    Else
        Effzo [M:PBW3]ECCVALMAJ
        Effzo [M:PBW3]ECCVALMIN
    Endif
Endif
Return

###########################################################################
# état boutons
$SETBOUT_CREPOX
INDINTER = 0
If [M:PBW3]BPSNUM <> ""
    If [F:BPR]BPRNUM <> [M:PBW3]BPSNUM
        Read [BPR]BPR0=[M:PBW3]BPSNUM
        If fstat : Raz [F:BPR] : Endif
    Endif
    If [F:BPR]FCY <> ""
        If [F:FCY]FCY <> [F:BPR]FCY
            Read [FCY]FCY0=[F:BPR]FCY
            If fstat : Raz [F:FCY] : Endif
        Endif
    Endif
    If [F:BPR]FCY <> "" & [F:FCY]LEGCPY = GSOCIETE  : INDINTER = 1 : Endif
Endif
ETABOU(GSPE1)=0
ETABOU(GSPE2)=0
ETABOU(GSPE3)=0    # 14102 mm 04.06

# 14102 mm 04.06 : les POS et les TRS ne sont jamais liés à un contrat.
If  find(WAPPHAB, 1,3,5,7) & !find(2,[M:PBW3]SELIND(0..[M:PBW3]NBLIG-1))
    ETABOU(GSPE1) = 1
Endif
If  find(WINTHAB, 1,3,5,7) & !find(2,[M:PBW3]SELIND(0..[M:PBW3]NBLIG-1))
    ETABOU(GSPE1) = 1
Endif
#
If !INDINTER & find(WAPPHAB,2,3,6,7)                         : ETABOU(GSPE2) = 1 : Endif
If !INDINTER & find(WAPPHAB,4,5,6,7) & [M:PBW3]BPSNUM <> ""  : ETABOU(GSPE3) = 1 : Endif
If  INDINTER & find(WINTHAB,2,3,6,7)                         : ETABOU(GSPE2) = 1 : Endif
If  INDINTER & find(WINTHAB,4,5,6,7) & [M:PBW3]BPSNUM <> ""  : ETABOU(GSPE3) = 1 : Endif
ETABOU(GBFIN)=1

If [M:PBW3]ITMREF <> ""
    Case GPLNFLT
        When 2:    If [F:ITF]PLANNER <> [M:PBW3]PLANNER & [F:ITF]PLANNER <> ""
                       ETABOU(GSPE2) = 0
                   Endif
        When 3:    If [F:ITF]PLANNER <> [M:PBW3]PLANNER
                       ETABOU(GSPE2) = 0
                   Endif
    Endcase

    If GBUYFLT = 2 & [F:ITF]BUY <> [M:PBW3]PLANNER & [F:ITF]BUY <> ""             # 01.05 27441
        ETABOU(GSPE3) = 0
    Endif
Endif

Diszo [M:PBW3]STU

ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0
Return

########################################################################
$AVBOUT_CREPOX
Case BOUT
    When "1"       :     Gosub AVMAJ_CREPOS
Endcase
Return
########################################################################
$BOUTON_CREPOX

Case BOUT
    When "1"       :     # suggérer
                         Gosub MAJ_CREPOS    # 14102 mm 04.06
                         Return
    When "2"       :     # demander
                         Gosub MAJ_CREPOP
                         Return
    When "3"       :     # acheter
                         Gosub MAJ_CREPOF
                         Return
Endcase
FIN=0
Return

########################################################################
$AVMAJ_CREPOS

# on s'assure de l'existence du couple article/ site fournisseur
If [M:PBW3]BPSNUM<>""
    Read [BPR]BPR0= [M:PBW3]BPSNUM
    If fstat : Raz [F:BPR] : Endif
    If [F:BPR]BETFCY = 2
        Read [ITF]ITF0 = [M:PBW3]ITMREF;[F:BPR]FCY
        If fstat
            Call ERREUR (mess(261,193,1)-[F:BPR]FCY-mess(263,193,1)-"ITMFACILIT") From GESECRAN
            FOK = 0
        Endif
    Endif
Else
    # on s'assure de l'existence du couple article/ site de réapprovisionnement
    Read [ITF]ITF0=[M:PBW3]ITMREF;[M:PBW3]STOFCY
    If fstat : Raz [F:ITF] : Endif
    If [F:ITF]REOCOD = 4
        Read [ITF1]ITF0=[M:PBW3]ITMREF;[F:ITF]REOFCY
        If fstat
            Call ERREUR (mess(262,193,1)-[F:ITF]REOFCY-mess(263,193,1)-"ITMFACILIT") From GESECRAN
            FOK = 0
        Endif
    Endif
Endif

Return
########################################################################
$MAJ_CREPOS

# 01.05 28080
#----- Contrôle si article actif ? -----#
If [F:ITM]ITMSTA = 3
    OK = 2
    Call AVERTIR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",OK) From GESECRAN
    If OK = 1 : Return : Endif
Elsif [F:ITM]ITMSTA <> 1
    Call ERREUR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")") From GESECRAN
    GERR = 1
    Return
Endif

If [M:PBW3]QTYSTU <= 0 : Return : Endif : # GH 30/08/11 bug 75888

GOK = 1
Raz  [M:ORDK]

Trbegin ADOVAL
If [M:PBW3]BPSNUM<>""
    Read [BPR]BPR0= [M:PBW3]BPSNUM
    If fstat : Raz [F:BPR] : Endif
    If [F:BPR]BETFCY = 2 :
        [M:ORDK]WIPTYP     = 7
        [M:ORDK]ORIFCY = [F:BPR]FCY
    Else
        [M:ORDK]WIPTYP     = 2
    Endif
Else
    Read [ITF]ITF0=[M:PBW3]ITMREF;[M:PBW3]STOFCY
    If fstat : Raz [F:ITF] : Endif
    Case [F:ITF]REOCOD
        When 2: [M:ORDK]WIPTYP = 2    # POS
        When 4: [M:ORDK]WIPTYP = 7    # TRS
                [M:ORDK]ORIFCY =  [F:ITF]REOFCY
        When 5: Return     # sous-traitance : à compléter plus tard
        When Default : [M:ORDK]WIPTYP = 2    # POS
    Endcase
Endif

If  [M:ORDK]WIPTYP     = 2
    If [M:PBW3]ORIFCY <> "" & [M:PBW3]ORIFCY <> [M:PBW3]PSHFCY
        [M:ORDK]ORIFCY      = [M:PBW3]ORIFCY
    Else
        [M:ORDK]ORIFCY      = [M:PBW3]PSHFCY
    Endif
Endif

If  [M:ORDK]ORIFCY  = [M:PBW3]STOFCY    # sites identiques :  pas de génération d'ordre intersite !
    [M:ORDK]WIPTYP = 2
Endif
[M:ORDK]MAJCOD     = "C"
[M:ORDK]STOFCY     = [M:PBW3]STOFCY
[M:ORDK]ITMREF     = [M:PBW3]ITMREF
[M:ORDK]BPRNUM     = [M:PBW3]BPSNUM
[M:ORDK]PJT        = [M:PBW3]PJT
[M:ORDK]EXTQTY     = [M:PBW3]QTYSTU
[M:ORDK]ENDDAT     = [M:PBW3]EXTRCPDAT
WORIDAT            = [M:PBW3]EXTRCPDAT
WORIFCY            = [M:PBW3]STOFCY
# calcul date début
If [M:PBW3]ITMREF<>[F:ITF]ITMREF | [M:PBW3]STOFCY<>[F:ITF]STOFCY
    Read [ITF]ITF0=[M:PBW3]ITMREF;[M:PBW3]STOFCY
    If fstat : Raz [F:ITF] : Endif
Endif
WLTI    = [F:ITF]OFS

# Issue 80737 GA 03/2012 pour les Achats le délai est un délai calendaire
#Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, WSTRDAT) From MFGLIB
Local Integer  WCOR : WCOR=8  # Arrondi date
Local Integer  WCOD : WCOD=1  # 1=délai achat en jours calendaires, 2=délai fab en jours ouvrés
Local Shortint WUPD : WUPD=0  # flag recalcul enddat
Local Date     WCALDATD : Raz WCALDATD
Local Decimal  WCAP(31)
Call CALDAT("-",WCOR,WORIDAT,WCOD,WLTI,WCAP,WCALDATD,WSTRDAT) From CBNLIB
[M:ORDK]STRDAT    = WSTRDAT

Call NUMERO(GSUG,[M:PBW3]STOFCY,[M:ORDK]STRDAT,"", [M:ORDK]WIPNUM,STAT) From SUBANM
If STAT <> 0
    Call ERREUR("WIP"-mess(60,199,1)) From GESECRAN
    GOK = 0 : Goto VAL_CRE
Endif

# sauvegardé pour éventuel TPS
WWIPTYP         = [M:ORDK]WIPTYP
[M:PBW3]ORIFCY  = [M:ORDK]ORIFCY
WWIPNUM         = [M:ORDK]WIPNUM
#
[M:ORDK]WIPSTA     = 3
[M:ORDK]VCRNUM     = [M:ORDK]WIPNUM
[M:ORDK]VCRTYP     = 11
[M:ORDK]PIO        = 1
[M:ORDK]FMI        = 1
[M:ORDK]MRPMES     = 1

# Issue 104943 - 2015-06-29 by BEEBE : Implementing Versioning
If dim([M:PBW3]ECCVALMAJ)>0
    [M:ORDK]ECCVALMAJ=[M:PBW3]ECCVALMAJ
    [M:ORDK]ECCVALMIN=[M:PBW3]ECCVALMIN
Endif

Case [F:ITF]REOMGTCOD
    When 1,4,5 : [M:ORDK]ORI = 3    # stock
    When 3     : [M:ORDK]ORI = 5    # PDP
    When 2     : [M:ORDK]ORI = 6    # CBN
    When Default : [M:ORDK]ORI = 3    # stock
Endcase
Call WIP From TRTWIP
If GOK<>1 : Goto VAL_CRE : Endif

# si la commande est une TRS, on crée son pendant dans les ventes
If WWIPTYP = 7
    Raz [M:ORDK]
    [M:ORDK]MAJCOD     = "C"
    [M:ORDK]WIPTYP     = 8
    [M:ORDK]WIPNUM     = WWIPNUM
    [M:ORDK]STOFCY     = [M:PBW3]ORIFCY
    [M:ORDK]ORIFCY     = [M:PBW3]STOFCY
    [M:ORDK]ITMREF     = [M:PBW3]ITMREF
    [M:ORDK]BPRNUM     = [M:PBW3]BPSNUM
    [M:ORDK]PJT        = [M:PBW3]PJT
    [M:ORDK]EXTQTY     = [M:PBW3]QTYSTU
    [M:ORDK]STRDAT     = WSTRDAT
    [M:ORDK]ENDDAT     = WSTRDAT
    [M:ORDK]WIPSTA     = 3
    Case [F:ITF]REOMGTCOD
        When 1,4,5 : [M:ORDK]ORI = 3    # stock
        When 3     : [M:ORDK]ORI = 5    # PDP
        When 2     : [M:ORDK]ORI = 6    # CBN
        When Default : [M:ORDK]ORI = 3    # stock
    Endcase

    [M:ORDK]VCRNUM     = WWIPNUM
    [M:ORDK]VCRTYP     = 11
    [M:ORDK]PIO        = 1
    Call WIP From TRTWIP
    If GOK<>1 : Goto VAL_CRE : Endif
Endif

$VAL_CRE
If GOK = 1 : Commit
Else  : Goto AB_TRS : Endif

# trace
Call OUVRE_TRACE(mess(74,192,1)) From LECFIC
If  [M:ORDK]WIPTYP  = 2       # POS
    MESS1 = mess(1,392,1)- mess(260,193,1)- num$([M:ORDK]WIPNUM) -mess(224,197,1)
Else                          # TRS
    MESS1 = mess(269,197,1)-num$([M:ORDK]WIPNUM)-mess(233,197,1)
    MESS2 = mess(8,306,1)- mess(260,193,1)-num$([M:ORDK]WIPNUM)-mess(224,197,1)
Endif
Call ECR_TRACE(MESS1,0) From GESECRAN
If MESS2<>"" : Call ECR_TRACE(MESS2,0) From GESECRAN : Endif
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
FIN =1

Return

########################################################################
$MAJ_CREPOP
# 01.05 28080
#----- Contrôle si article actif ? -----#
If [F:ITM]ITMSTA = 3
    OK = 2
    Call AVERTIR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",OK) From GESECRAN
    If OK = 1 : Return : Endif
Elsif [F:ITM]ITMSTA <> 1
    Call ERREUR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")") From GESECRAN
    GERR = 1
    Return
Endif

Raz [M:PMG]
[M:PMG]MAJCOD         = "C"
[M:PMG]MAJTYP         = "P"
[M:PMG]RGRFLG         = 1
[M:PMG]MSGFLG         = 1
# 18138 MM 01.05
If [F:BTS]TRACE = 2
    [M:PMG]TRAFLG  = 2
Else
    [M:PMG]TRAFLG  = 1
Endif
If [M:PBW3]POCNUM <> ""
    # contrat
    [M:PMG]WRCPDAT        = [M:PBW3]WRCPDAT
    [M:PMG]USEPLC         = [M:PBW3]USEPLC
    [M:PMG]NBLIG          = 1
    [M:PMG]POCNUM(0)      = [M:PBW3]POCNUM
    [M:PMG]WIPTYP(0)      = 2
    [M:PMG]WIPSTA(0)      = 2
    [M:PMG]WIPNUM(0)      = ""
    [M:PMG]ITMREF(0)      = [M:PBW3]ITMREF
    [M:PMG]ORIFCY(0)      = [M:PBW3]PSHFCY
    [M:PMG]STOFCY(0)      = [M:PBW3]STOFCY
    [M:PMG]ENDDAT(0)      = [M:PBW3]EXTRCPDAT
    [M:PMG]STU(0)         = [M:PBW3]STU
    [M:PMG]EXTSTUQTY(0)   = [M:PBW3]QTYSTU
    [M:PMG]PUU(0)         = [M:PBW3]PUU
    [M:PMG]EXTPUUQTY(0)   = [M:PBW3]QTYPUU
 Else
    # hors contrat
    [M:PMG]REQUSR         = GUSER
    [M:PMG]PSHFCY         = [M:PBW3]PSHFCY
    [M:PMG]PRQDAT         = date$
    [M:PMG]NBLIG          = 1
    [M:PMG]WIPTYP(0)      = 2
    [M:PMG]WIPSTA(0)      = 2
    [M:PMG]WIPNUM(0)      = ""
    [M:PMG]ITMREF(0)      = [M:PBW3]ITMREF
    # interx
    If [M:PBW3]ORIFCY <> "" & [M:PBW3]ORIFCY <> [M:PBW3]PSHFCY
        [M:PMG]ORIFCY(0)      = [M:PBW3]ORIFCY
    Else
        [M:PMG]ORIFCY(0)      = [M:PBW3]PSHFCY
    Endif
    [M:PMG]STOFCY(0)      = [M:PBW3]STOFCY
    [M:PMG]PJT(0)         = [M:PBW3]PJT
    [M:PMG]BPRNUM(0)      = [M:PBW3]BPSNUM
    [M:PMG]ENDDAT(0)      = [M:PBW3]EXTRCPDAT
    [M:PMG]STU(0)         = [M:PBW3]STU
    [M:PMG]EXTSTUQTY(0)   = [M:PBW3]QTYSTU
    [M:PMG]PUU(0)         = [M:PBW3]PUU
    [M:PMG]EXTPUUQTY(0)   = [M:PBW3]QTYPUU
Endif

# Issue 104943 - 2015-06-29 by BEEBE : Implementing Versioning
If dim([M:PMG]ECCVALMAJ)>0
    [M:PMG]ECCVALMAJ(0)=[M:PBW3]ECCVALMAJ
    [M:PMG]ECCVALMIN(0)=[M:PBW3]ECCVALMIN
Endif

If [M:PMG]EXTPUUQTY(0) = 0 : Return : Endif
Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    PARAM(6) = num$(2)
    Raz [M:PBW3]
    If find(GFONCTION,"FUNGBENCH", "FUNDBENCH","FUNGBENCHA", "FUNDBENCHA","FUNMLINK")
        GVCR   = [M:PMG]VCRNUM(0)
        GLIN   = [M:PMG]VCRLIN(0)
        GSEQ   = [M:PMG]VCRSEQ(0)
    Endif
    FIN = 1
    Return
Else
    Return
Endif
Return

########################################################################
$MAJ_CREPOF
Local Integer WOK
If [F:ITM]PRQFLG = 2
    GMESSAGE = mess(164,194,1)
    GERR = 1
    Return
Endif

# 01.05 28080
#----- Contrôle si article actif ? -----#
If [F:ITM]ITMSTA = 3
    OK = 2
    Call AVERTIR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",OK) From GESECRAN
    If OK = 1 : Return : Endif
Elsif [F:ITM]ITMSTA <> 1
    Call ERREUR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")") From GESECRAN
    GERR = 1
    Return
Endif

Raz [M:PMG]
[M:PMG]MAJCOD         = "C"
[M:PMG]MAJTYP         = "F"
[M:PMG]RGRFLG         = 1
[M:PMG]MSGFLG         = 1
# 18138 MM 01.05
If [F:BTS]TRACE = 2
    [M:PMG]TRAFLG         = 2
Else
    [M:PMG]TRAFLG         = 1
Endif
If [M:PBW3]POCNUM <> ""
    # contrat
    [M:PMG]WRCPDAT        = [M:PBW3]WRCPDAT
    [M:PMG]USEPLC         = [M:PBW3]USEPLC
    [M:PMG]NBLIG          = 1
    [M:PMG]POCNUM(0)      = [M:PBW3]POCNUM
    [M:PMG]WIPTYP(0)      = 2
    [M:PMG]WIPSTA(0)      = 1
    [M:PMG]WIPNUM(0)      = ""
    [M:PMG]ITMREF(0)      = [M:PBW3]ITMREF
    [M:PMG]ORIFCY(0)      = [M:PBW3]PSHFCY
    [M:PMG]STOFCY(0)      = [M:PBW3]STOFCY
    [M:PMG]ENDDAT(0)      = [M:PBW3]EXTRCPDAT
    [M:PMG]STU(0)         = [M:PBW3]STU
    [M:PMG]EXTSTUQTY(0)   = [M:PBW3]QTYSTU
    [M:PMG]PUU(0)         = [M:PBW3]PUU
    [M:PMG]EXTPUUQTY(0)   = [M:PBW3]QTYPUU
Else
    #----- Contrôle article-fournisseur -----#
    If [F:ITP]ITMREF <> [M:PBW3]ITMREF | [F:ITP]BPSNUM <> [M:PBW3]BPSNUM
        Read [ITP]ITP0=[M:PBW3]ITMREF;[M:PBW3]BPSNUM
        If fstat : Raz [F:ITP] : Endif
    Else
        fstat = 0
    Endif
    # Issue 103282 GA 10/2014 when supplier-product not found
    If [F:ITP]ITMREF <> [M:PBW3]ITMREF | [F:ITP]BPSNUM <> [M:PBW3]BPSNUM
      # Issue 95343 GA 01/2014 article-fournisseur facultatif
      # Référencement inutile si fournisseur de type Divers
      If [F:BPS]BPSNUM<>[M:PBW3]BPSNUM
        Read [BPS] BPS0=[M:PBW3]BPSNUM : If fstat : Raz [F:BPS] : Endif
      Endif
      #----- Si fournisseur <> Divers -----#
      If [F:BPS]BPSTYP<>3
        #----- Si article non générique -----#
        If [F:ITM]GENFLG<>2
          If GITMBPS=1 GMESSAGE=[M:PBW3]ITMREF-mess(8,194,1) : GERR=1 : mkstat= 2 : Endif
          If GITMBPS=2 OK=2 : Call AVERTIR([M:PBW3]ITMREF-mess(8,194,1),OK) From GESECRAN
            If OK=1  : mkstat=2 : Raz GMESSAGE : Endif
          Endif
        Endif
      Endif
    Endif
    If [F:ITP]PURMINQTY>0
        Call PCAL_QTY ([F:ITP]PURMINQTY,[F:ITP]PUU,GBIDD1,[M:PBW3]PUU,
&                      [M:PBW3]ITMREF,[M:PBW3]BPSNUM,1,GBIDD2) From TRTACHQTE1
        #----- Test qté inférieure à qté minimum d'achat -----#
        #VPO 15/10/10 17730/59532 contrôle selon paramètre
        If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
        #If [M:PBW3]QTYPUU < GBIDD1
        If [M:PBW3]QTYPUU < GBIDD1 & GPOHMINQTY<3
            GMESSAGE =[M:PBW3]ITMREF-mess(14,194,1)                    # 47589 mm 06.08
            GMESSAGE-=num$(GBIDD1)-[M:PBW3]PUU
            If GPOHMINQTY=1
                GERR = 1
                Return
            Else : #GPOHMINQTY=2
              WOK=2
              Call AVERTIR (GMESSAGE, WOK)From GESECRAN
              If WOK=1
                  Raz GMESSAGE
                  GERR = 1
                  Return
              Endif
              Raz GMESSAGE
            Endif
        Endif
    Endif
    [M:PMG]REQUSR         = GUSER
    [M:PMG]PSHFCY         = [M:PBW3]PSHFCY
    [M:PMG]PRQDAT         = TODAY
    [M:PMG]TARGRP         = 1
    [M:PMG]USEPLC         = [M:PBW3]USEPLC
    [M:PMG]NBLIG          = 1
    [M:PMG]WIPTYP(0)      = 2
    [M:PMG]WIPSTA(0)      = 1
    [M:PMG]WIPNUM(0)      = ""
    [M:PMG]ITMREF(0)      = [M:PBW3]ITMREF
    # interx
    If [M:PBW3]ORIFCY <> "" & [M:PBW3]ORIFCY <> [M:PBW3]PSHFCY
        [M:PMG]ORIFCY(0)      = [M:PBW3]ORIFCY
    Else
        [M:PMG]ORIFCY(0)      = [M:PBW3]PSHFCY
    Endif
    [M:PMG]STOFCY(0)      = [M:PBW3]STOFCY
    [M:PMG]PJT(0)         = [M:PBW3]PJT
    [M:PMG]BPRNUM(0)      = [M:PBW3]BPSNUM
    [M:PMG]ENDDAT(0)      = [M:PBW3]EXTRCPDAT
    [M:PMG]STU(0)         = [M:PBW3]STU
    [M:PMG]EXTSTUQTY(0)   = [M:PBW3]QTYSTU
    [M:PMG]PUU(0)         = [M:PBW3]PUU
    [M:PMG]EXTPUUQTY(0)   = [M:PBW3]QTYPUU
Endif
# Issue 104943 - 2015-06-29 by BEEBE : Implementing Versioning
If dim([M:PMG]ECCVALMAJ)>0
    [M:PMG]ECCVALMAJ(0)=[M:PBW3]ECCVALMAJ
    [M:PMG]ECCVALMIN(0)=[M:PBW3]ECCVALMIN
Endif
If [M:PMG]EXTPUUQTY(0) = 0 | ([M:PMG]POCNUM(0) = "" & [M:PMG]BPRNUM(0) = "" )
    Return
Endif
Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    PARAM(6) = num$(2)
    Raz [M:PBW3]
    If find(GFONCTION,"FUNGBENCH", "FUNDBENCH","FUNGBENCHA", "FUNDBENCHA","FUNMLINK")
        GVCR   = [M:PMG]VCRNUM(0)
        GLIN   = [M:PMG]VCRLIN(0)
        GSEQ   = [M:PMG]VCRSEQ(0)
    Endif
    FIN = 1
    Return
Else
    Return
Endif
Return

#---------------------------------------------------------------------------#
# Action SAIMODPOX                                                          #
#---------------------------------------------------------------------------#
###########################################################################
# ouverture
$OUVRE_MODPOX
Local    Char       WFCY(GLONFCY)
Local    Integer    WTYP
Local    Integer    WSTA
Local    Char       WWIP(GLONVCR)
Local    Char       WITM(GLONITM)
Local    Integer    WAPPHAB
Local    Integer    WINTHAB
Local    Char       WPLANNER(20)

Local    Integer    WRET
Local    Integer    OK
Local    Char       MESS1(250), MESS2(250)
Local    Decimal    WCOEFF, WQTYPRV, C_QTY
Local    Char       WVCRNUM(GLONVCR)
Local    Date       TODAY : TODAY = date$
Local    Char       XTITLE(250)
Local    Integer    WMODE            # (1 = Modification WOx, 2 = PEC)
Local    Integer    INDINTER : INDINTER = 0
Local    Integer    WOFS             # 09.04 25242
Local    Char       WWIPNUM(GLONVCR)
Local    Char       WCLE(200)        # 14102 mm 04.06
Local    Char       WORIFCY(GLONFCY) # 14102 mm 04.06
Local    Date       WORIDAT, WSTRDAT # 14102 mm 04.06
Local    Decimal    WLTI             # Issue 81510 GA 04/2012 before: Integer # 14102 mm 04.06
Local    Integer    WWIPTYP          # 14102 mm 04.06
Local    Char       CRITERE(250)     # 36471 mm 06.06
Local    Decimal    WFRCQTY
Local    Integer    WPJTLAUNCH : WPJTLAUNCH=0 # Issue 107498/108 - 2016-05-20 by BEEBE : flag for control possibility of launching PJT products/POx

If clalev ([F:ORD1])<= 0 : Local File ORDERS        [ORD1]  : Endif
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER     [ITM]   : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT    [ITF]   : Endif
If clalev ([F:FCY]) <= 0 : Local File FACILITY      [FCY]   : Endif
If clalev ([F:TUV]) <= 0 : Local File TABUNAVAIL    [TUV]   : Endif
If clalev ([F:POC]) <= 0 : Local File PORDERC       [POC]   : Endif
If clalev ([F:BPS]) <= 0 : Local File BPSUPPLIER    [BPS]   : Endif
If clalev ([F:PSH]) <= 0 : Local File PREQUIS       [PSH]   : Endif
If clalev ([F:PSD]) <= 0 : Local File PREQUISD      [PSD]   : Endif
If clalev ([F:POH]) <= 0 : Local File PORDER        [POH]   : Endif
If clalev ([F:POQ]) <= 0 : Local File PORDERQ       [POQ]   : Endif
If clalev ([F:TCU]) <= 0 : Local File TABCUR        [TCU]   : Endif
If clalev ([F:ITP]) <= 0 : Local File ITMBPS        [ITP]   : Endif
If clalev ([F:BPR]) <= 0 : Local File BPARTNER      [BPR]   : Endif
If clalev ([F:PTO]) <= 0 : Local File PARMTO        [PTO]   : Endif
If clalev ([F:TCTR])<= 0 : Local File TABCONTAINER  [TCTR]  : Endif  # 106430.n

If clalev ([M:PMG]) <= 0 : Local Mask PURMGT     [PMG] : Endif
If clalev ([M:ORDK]) <= 0 : Local Mask ORDK      [ORDK] : Endif    # 14102 mm 04.06

WFCY    = PARAM(1)
WTYP    = val(PARAM(2))
WSTA    = val(PARAM(3))
WWIP    = PARAM(4)
WITM    = PARAM(5)
WAPPHAB = val(PARAM(6))
WINTHAB = val(PARAM(7))
WPLANNER = PARAM(8)
Raz PARAM(9)

# GA pour les paramètres interface cpta 150
GFCY=WFCY     : # Gosub CHARG_PARAM From SUBPOIA
Gosub CHARG_PARAM

# débranchement suivant type en-cours
# par défaut on est en WMODE = 1 donc pas de substitution de fenêtre (DMODPOX par défaut)
Case WTYP
    When 2,7:        # modification POx
                   Case WSTA
                       When 1:  # modification POF
                                WMODE = 1
                                XTITLE = mess(335,198,1)    # modifier
                       When 2:  # modification POP
                                WMODE = 2
                                # substitution fenêtre
                                BOITE     = "DMODPOP"
                                WMASQUE   = "PBENCHW1"
                                Gosub CHANGE_AWI From BENCHLIB
                                Case WAPPHAB
                                    When 2,3 :    XTITLE = mess(335,198,1)  # modifier
                                    When 6,7 :    XTITLE = mess(362,198,1)  # modifier/commander
                                Endcase
                       When 3:  # création POP/POF par prise en compte POS
                                WMODE = 3
                   Endcase
    # Issue 107498/101 - 2016-05-02 by ALSHE : Action menue
    When 1,3,4,5,6,8,13,14:  # création POX par prise en compte SOF/MWF/MSF/TPF/SCF/EOF ...
                   WMODE = 3
   #When 0:
   #     Infbox "SAIMODPOX: Erreur de fonctionnement ????"
Endcase
If WMODE = 3
    # substitution fenêtre
    BOITE     = "DDEM2POX"
    WMASQUE   = "PBENCHW4"
    Gosub CHANGE_AWI From BENCHLIB
    Case WAPPHAB
        When 1:   XTITLE = mess(335,198,1)  # modifier
        When 2,3: XTITLE = mess(337,198,1)  # demander
        When 4,5: XTITLE = mess(363,198,1)  # commander
        When 6,7: XTITLE = mess(364,198,1)  # demander/commander
    Endcase
    If XTITLE = ""
        Case WINTHAB
            When 1:   XTITLE = mess(335,198,1)  # modifier
            When 2,3: XTITLE = mess(337,198,1)  # demander
            When 4,5: XTITLE = mess(363,198,1)  # commander
            When 6,7: XTITLE = mess(364,198,1)  # demander/commander
        Endcase
    Endif
Endif
Return

###########################################################################
# chargement
$DEBUT_MODPOX
Case WMODE
    When 1:    Gosub DEBUT_MODPOF
    When 2:    Gosub DEBUT_MODPOP
    When 3:    Gosub DEBUT_DEM2POX
Endcase
Return

###########################################################################
# état boutons
$SETBOUT_MODPOX
Case WMODE
    When 1:    Gosub SETBOUT_MODPOF
    When 2:    Gosub SETBOUT_MODPOP
    When 3:    Gosub SETBOUT_DEM2POX
Endcase
Return

########################################################################
$BOUTON_MODPOX
Case WMODE
    When 1:    Gosub BOUTON_MODPOF
    When 2:    Gosub BOUTON_MODPOP
    When 3:    Gosub BOUTON_DEM2POX
Endcase
Return

########################################################################
$ENR_MODPOX
Case WMODE
    When 1:    Gosub ENR_MODPOF
    When 2:    Gosub ENR_MODPOP
    When 3:    Gosub ENR_DEM2POX    # 14102 MM 04.06
    When 4:    # pas d'action "enregistrer" en sous-traitance
Endcase

Return

########################################################################
$SUP_MODPOX
Case WMODE
    When 1:    Gosub SUP_MODPOF
    When 2:    Gosub SUP_MODPOP
    When 3:    Gosub SUP_DEM2POX
    When 4:    # pas d'action "supprimer" en sous-traitance
Endcase
Return

#-------------------------------------------------------------------------#
# >>>>> Fenêtre DMODPOF
#-------------------------------------------------------------------------#
###########################################################################
# chargement
$DEBUT_MODPOF
Gosub CHARGE_PBW5
Diszo [M:PBW5]5
Diszo [M:PBW5]STU
Diszo [M:PBW5]RCPQTYPUU
Diszo [M:PBW5]10
Affzo [M:PBW5]1-99

# Issue 104943 - 2015-07-03 by BEEBE : Implementing Versioning
If dim([M:PBW5]ECCVALMAJ)>0
    # Enable/Disable version fields
    Call ECCAFF([M:PBW5]ITMREF,"PBW5") From MFGECCLIB
Endif
Return

###########################################################################
# état boutons
$SETBOUT_MODPOF

INDINTER = 0

If [M:PBW5]BPSNUM <> ""
    If [F:BPR]BPRNUM <> [M:PBW5]BPSNUM
        Read [BPR]BPR0=[M:PBW5]BPSNUM
        If fstat : Raz [F:BPR] : Endif
    Endif
    If [F:BPR]FCY <> ""
        If [F:FCY]FCY <> [F:BPR]FCY
            Read [FCY]FCY0=[F:BPR]FCY
            If fstat : Raz [F:FCY] : Endif
        Endif
    Endif
    If [F:BPR]FCY <> "" & [F:FCY]LEGCPY = GSOCIETE  : INDINTER = 1 : Endif
Endif

ETABOU(GENRE) = 0
ETABOU(GSUPP) = 0
ETABOU(GSPE1) = 0
ETABOU(GSPE2) = 0

If !INDINTER & find(WAPPHAB,2,3,6,7) & ([M:PBW5]RCPFLG <= 1 & [M:PBW5]INVFLG <= 1) : ETABOU(GSUPP)= 1 : Endif
If  INDINTER & find(WINTHAB,2,3,6,7) & ([M:PBW5]RCPFLG <= 1 & [M:PBW5]INVFLG <= 1) : ETABOU(GSUPP)= 1 : Endif
If !INDINTER & find(WAPPHAB,2,3,6,7)                            : ETABOU(GENRE)= 1 : ETABOU(GSPE1)= 1 : Endif
If  INDINTER & find(WINTHAB,2,3,6,7)                            : ETABOU(GENRE)= 1 : ETABOU(GSPE1)= 1 : Endif

If [M:PBW5]LINAPPFLG < 4 : ETABOU(GSPE2)= 1 : Endif
# 20846 mm 11.05
If [M:PBW5]MRPMES > 1 & ETABOU(GENRE)= 1 : ETABOU(GSPE3) = 1 : Else : ETABOU(GSPE3) = 0 : Endif

ETABOU(GPREM) = 0
ETABOU(GDERN) = 0
ETABOU(GSUIV) = 0
ETABOU(GPREC) = 0

Return

########################################################################
$ENR_MODPOF
Local Integer WOK
If [M:PBW5]POCNUM = ""
    #----- Contrôle article-fournisseur -----#
    If [F:ITP]ITMREF <> [M:PBW5]ITMREF | [F:ITP]BPSNUM <> [M:PBW5]BPSNUM
        Read [ITP]ITP0=[M:PBW5]ITMREF;[M:PBW5]BPSNUM
        If fstat : Raz [F:ITP] : Endif
    Else
        fstat = 0
    Endif
    # Issue 103282 GA 10/2014 when supplier-product not found
    If [F:ITP]ITMREF <> [M:PBW5]ITMREF | [F:ITP]BPSNUM <> [M:PBW5]BPSNUM
      # Issue 95343 GA 01/2014 article-fournisseur facultatif
      # Référencement inutile si fournisseur de type Divers
      If [F:BPS]BPSNUM<>[M:PBW5]BPSNUM
        Read [BPS] BPS0=[M:PBW5]BPSNUM : If fstat : Raz [F:BPS] : Endif
      Endif
      #----- Si fournisseur <> Divers -----#
      If [F:BPS]BPSTYP<>3
        #----- Si article non générique -----#
        If [F:ITM]GENFLG<>2
          If GITMBPS=1 GMESSAGE=[M:PBW5]ITMREF-mess(8,194,1) : GERR=1 : mkstat= 2 : Endif
          If GITMBPS=2 OK=2 : Call AVERTIR([M:PBW5]ITMREF-mess(8,194,1),OK) From GESECRAN
            If OK=1  : mkstat=2 : Raz GMESSAGE : Endif
          Endif
        Endif
      Endif
    Endif
    If [F:ITP]PURMINQTY>0
        Call PCAL_QTY ([F:ITP]PURMINQTY,[F:ITP]PUU,GBIDD1,[M:PBW5]PUU,
&                      [M:PBW5]ITMREF,[M:PBW5]BPSNUM,1,GBIDD2) From TRTACHQTE1
        #----- Test qté inférieure à qté minimum d'achat -----#
        #VPO 15/10/10 17730/59532 contrôle selon paramètre
        If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
        #If [M:PBW5]QTYPUU < GBIDD1
        If [M:PBW5]QTYPUU < GBIDD1 & GPOHMINQTY<3
            GMESSAGE =[M:PBW5]ITMREF-mess(14,194,1)                    # 47589 mm 06.08
            GMESSAGE-=num$(GBIDD1)-[M:PBW5]PUU
            If GPOHMINQTY=1
                GERR = 1
                Return
            Else : #GPOHMINQTY=2
              WOK=2
              Call AVERTIR (GMESSAGE, WOK)From GESECRAN
              If WOK=1
                  Raz GMESSAGE
                  GERR = 1
                  Return
              Endif
              Raz GMESSAGE
            Endif
        Endif
    Endif
Endif
Raz [M:PMG]
[M:PMG]MAJCOD         = "M"
[M:PMG]MAJTYP         = "F"
[M:PMG]MSGFLG         = 1
# 18138 MM 01.05
If clalev ([F:BTS]) <> 0
    If [F:BTS]TRACE = 2
        [M:PMG]TRAFLG         = 2
    Else
        [M:PMG]TRAFLG         = 1
    Endif
Else
    [M:PMG]TRAFLG     = 2
Endif
[M:PMG]USEPLC         = [M:PBW5]USEPLC
[M:PMG]REVFLG         = 1
# sr 08.11 Demande 75557
[M:PMG]INITAR         = [M:PBW5]INITAR
# Issue X3-71652 - 2018-01-25 by SDEM : Begin
#----- Modification avec avenant ?
If GPURREV > 1 & [M:PBW5]LINAPPFLG > 1
    If [F:POH]RCPFLG > 1 | [F:POH]INVFLG > 1
      If GPURREV=2 Then
        OK = 2
        Call OUINON (mess(49,194,1),OK) From GESECRAN
        If OK = 2 : [M:PMG]REVFLG = 2 : Endif
        Goto SUITE_ENR_MODPOX
      Elsif GPURREV=3 Then
        OK = 2
        [M:PMG]REVFLG = 2
        Goto SUITE_ENR_MODPOX
      Endif
    Endif
    If [F:POH]PRNFLG = 2 & [F:POH]APPFLG > 2
      If GPURREV=2 Then
        OK = 2
        Call OUINON (mess(50,194,1),OK) From GESECRAN
        If OK = 2 : [M:PMG]REVFLG = 2 : Endif
        Goto SUITE_ENR_MODPOX
      Elsif GPURREV=3 Then
        OK = 2
        [M:PMG]REVFLG = 2
        Goto SUITE_ENR_MODPOX
      Endif
    Endif
    If [F:POH]APPFLG = 3
      If GPURREV=2
        OK = 2
        Call OUINON (mess(51,194,1),OK) From GESECRAN
        If OK = 2 : [M:PMG]REVFLG = 2 : Endif
        Goto SUITE_ENR_MODPOX
      Elsif GPURREV=3
        OK = 2
        [M:PMG]REVFLG = 2
        Goto SUITE_ENR_MODPOX
      Endif
    Endif
Endif
# Issue X3-71652 - 2018-01-25 by SDEM : end

$SUITE_ENR_MODPOX
If [M:PBW5]POCNUM <> ""
    [M:PMG]WRCPDAT        = [M:PBW5]WRCPDAT
Endif
[M:PMG]POCNUM         = [M:PBW5]POCNUM
[M:PMG]NBLIG          = 1
[M:PMG]STOFCY(0)      = [M:PBW5]STOFCY
[M:PMG]PJT(0)         = [M:PBW5]PJT
[M:PMG]BPRNUM(0)      = [M:PBW5]BPSNUM
[M:PMG]VCRNUM(0)      = [M:PBW5]VCRNUM
[M:PMG]VCRLIN(0)      = [M:PBW5]VCRLIN
[M:PMG]VCRSEQ(0)      = [M:PBW5]VCRSEQ
[M:PMG]ENDDAT(0)      = [M:PBW5]EXTRCPDAT
[M:PMG]STU(0)         = [M:PBW5]STU
[M:PMG]EXTSTUQTY(0)   = [M:PBW5]QTYSTU
[M:PMG]PUU(0)         = [M:PBW5]PUU
[M:PMG]EXTPUUQTY(0)   = [M:PBW5]QTYPUU

# Issue 104943 - 2015-06-29 by BEEBE : Implementing Versioning
If dim([M:PBW5]ECCVALMAJ)>0
    [M:PMG]ECCVALMAJ(0)=[M:PBW5]ECCVALMAJ
    [M:PMG]ECCVALMIN(0)=[M:PBW5]ECCVALMIN
Endif

If [M:PMG]EXTPUUQTY(0) = 0 : Return : Endif
Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    PARAM(9) = num$(2)
    Raz [M:PBW5]
    If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNGBENCHA", "FUNDBENCHA","FUNMLINK")
        GVCR   = [M:PMG]VCRNUM(0)
        GLIN   = [M:PMG]VCRLIN(0)
        GSEQ   = [M:PMG]VCRSEQ(0)
    Endif
    FIN = 1
    Return
Else
    Return
Endif
Return

########################################################################
$SUP_MODPOF
# v6 affectations
Call CHECK_FRCQTY([M:PBW5]STOFCY, [M:PBW5]ITMREF, 14, [M:PBW5]VCRNUM, [M:PBW5]VCRLIN, [M:PBW5]VCRSEQ, 2, WRET) From MTOLINKLIB
If WRET
    If [F:PTO]FRCPRO <> 2
        OK = 1
        Call OUINON(mess(227,190,1),OK) From GESECRAN
        If OK = 1 : OK = 0 : Return : Endif
    Endif
Endif

Raz [M:PMG]
[M:PMG]MAJCOD         = "A"
[M:PMG]MAJTYP         = "F"
[M:PMG]MSGFLG         = 0
# 18138 MM 01.05
If clalev ([F:BTS]) <> 0
    If [F:BTS]TRACE = 2
        [M:PMG]TRAFLG         = 2
    Else
        [M:PMG]TRAFLG         = 1
    Endif
Else
    [M:PMG]TRAFLG     = 2
Endif
[M:PMG]NBLIG          = 1
[M:PMG]POCNUM(0)      = [M:PBW5]POCNUM
[M:PMG]VCRNUM(0)      = [M:PBW5]VCRNUM
[M:PMG]VCRLIN(0)      = [M:PBW5]VCRLIN
[M:PMG]VCRSEQ(0)      = [M:PBW5]VCRSEQ
Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    PARAM(9) = num$(2)
    Raz [M:PBW5]
    FIN = 1
    Return
Else
    Return
Endif
Return

########################################################################
$BOUTON_MODPOF
Case BOUT
    When "1"       :     # solde
                         Gosub MAJ_SOLDEPOF
                         Return
    When "3"       :     # message
                         Gosub MAJ_MESPOF    # 20846 mm 11.05
                         Return
Endcase
FIN=0
Return

########################################################################
$MAJ_MESPOF
# 20846 mm 11.05
[M:PBW5]STU        = [M:PBW5]STU2
[M:PBW5]QTYSTU     = [M:PBW5]EXTQTY2
[M:PBW5]EXTRCPDAT  = [M:PBW5]ENDDAT2
# Conversion de la qté US en UA
Call PCAL_QTY([M:PBW5]QTYSTU,[M:PBW5]STU,[M:PBW5]QTYPUU,[M:PBW5]PUU,
&  [M:PBW5]ITMREF,[M:PBW5]BPSNUM,1,GBIDD1  ) From TRTACHQTE1
Affzo  [M:PBW5]
Return

########################################################################
$MAJ_SOLDEPOF
Raz [M:PMG]

# v6 affectations
Call CHECK_FRCQTY([M:PBW5]STOFCY, [M:PBW5]ITMREF, 14, [M:PBW5]VCRNUM, [M:PBW5]VCRLIN, [M:PBW5]VCRSEQ, 2, WRET) From MTOLINKLIB
If WRET
    If [F:PTO]FRCPRO <> 2
        OK = 1
        Call OUINON(mess(227,190,1),OK) From GESECRAN
        If OK = 1 : OK = 0 : Return : Endif
    Endif
Endif

If [M:PBW5]POCNUM = ""
    # la commande va être entièrement soldée, voulez-vous continuer ?
    OK = 1 : Call AVERTIR(mess(56,194,1),OK) From GESECRAN
    If OK = 1 : OK = 0 : Return : Endif
    OK = 1
    # aucune réception effectuée, voulez-vous solder la commande ?
    If [M:PBW5]RCPQTYPUU = 0
        OK = 1 : Call OUINON(mess(59,194,1),OK) From GESECRAN
        If OK = 1 : OK=0 : Return : Else : OK = 1 : Endif
    Endif
Endif
[M:PMG]MAJCOD         = "S"
[M:PMG]MAJTYP         = "F"
[M:PMG]MSGFLG         = 0
# 18138 MM 01.05
If clalev ([F:BTS]) <> 0
    If [F:BTS]TRACE = 2
        [M:PMG]TRAFLG         = 2
    Else
        [M:PMG]TRAFLG         = 1
    Endif
Else
    [M:PMG]TRAFLG     = 2
Endif

# 47227 mm 05.08
[M:PMG]REVFLG         = 1
# Issue X3-71652 - 2018-01-26 by SDEM : begin
#----- Modification avec avenant ?
If GPURREV > 1 & [M:PBW5]LINAPPFLG > 1
    If [F:POH]RCPFLG > 1 | [F:POH]INVFLG > 1
      If GPURREV=2 Then
        OK = 2
        Call OUINON (mess(49,194,1),OK) From GESECRAN
        If OK = 2 : [M:PMG]REVFLG = 2 : Endif
        Goto SUITE_MAJ_SOLDEPOF
      Elsif GPURREV=3
        OK = 2
        [M:PMG]REVFLG = 2
        Goto SUITE_MAJ_SOLDEPOF
      Endif
    Endif
    If [F:POH]PRNFLG = 2 & [F:POH]APPFLG > 2
      If GPURREV=2 Then
        OK = 2
        Call OUINON (mess(50,194,1),OK) From GESECRAN
        If OK = 2 : [M:PMG]REVFLG = 2 : Endif
        Goto SUITE_MAJ_SOLDEPOF
      Elsif GPURREV=3
        OK = 2
        [M:PMG]REVFLG = 2
        Goto SUITE_MAJ_SOLDEPOF
      Endif

    Endif
    If [F:POH]APPFLG = 3
      If GPURREV=2
        OK = 2
        Call OUINON (mess(51,194,1),OK) From GESECRAN
        If OK = 2 : [M:PMG]REVFLG = 2 : Endif
        Goto SUITE_ENR_MODPOX
      Elsif GPURREV=3
        OK = 2
        [M:PMG]REVFLG = 2
        Goto SUITE_ENR_MODPOX
      Endif
    Endif
Endif
# Issue X3-71652 - 2018-01-26 by SDEM : end
$SUITE_MAJ_SOLDEPOF
[M:PMG]NBLIG          = 1
[M:PMG]POCNUM         = [M:PBW5]POCNUM
[M:PMG]VCRNUM(0)      = [M:PBW5]VCRNUM
[M:PMG]VCRLIN(0)      = [M:PBW5]VCRLIN
[M:PMG]VCRSEQ(0)      = [M:PBW5]VCRSEQ
Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    PARAM(9) = num$(2)
    Raz [M:PBW5]
    FIN = 1
    Return
Else
    Return
Endif
Return

#-------------------------------------------------------------------------#
# >>>>> Fenêtre DMODPOP
#-------------------------------------------------------------------------#
###########################################################################
# chargement
$DEBUT_MODPOP

Gosub CHARGE_PBW1
If [M:PBW1]LINCLEFLG = 2 |
&  [M:PBW1]LINORDFLG = 2
    Diszo [M:PBW1]
Else
    Diszo [M:PBW1]5
    Diszo [M:PBW1]STU
    Diszo [M:PBW1]ORDQTYPUU
    If [F:BTS]UOMSAI = 1 :  Diszo [M:PBW1]UOM   Endif    # 29397 mm 12.06
    # FQ 59636 GA 11/2009 autoriser affermissement partiel: plusieurs commandes sur une POP
    #If [M:PBW1]ORDQTYPUU<>0 Diszo [M:PBW1]15-25 Endif    # 29397 mm 12.06
    If [M:PBW1]ORDQTYPUU Diszo [M:PBW1]UOM   Endif
Endif

Diszo [M:PBW1]10
Affzo [M:PBW1]1-99

# Issue 104943 - 2015-07-03 by BEEBE : Implementing Versioning
If dim([M:PBW1]ECCVALMAJ)>0
    # Enable/Disable version fields
    Call ECCAFF([M:PBW1]ITMREF,"PBW1") From MFGECCLIB
Endif
Return

###########################################################################
# état boutons
$SETBOUT_MODPOP
INDINTER = 0
If [M:PBW1]BPSNUM <> ""
    If [F:BPR]BPRNUM <> [M:PBW1]BPSNUM
        Read [BPR]BPR0=[M:PBW1]BPSNUM
        If fstat : Raz [F:BPR] : Endif
    Endif
    If [F:BPR]FCY <> ""
        If [F:FCY]FCY <> [F:BPR]FCY
            Read [FCY]FCY0=[F:BPR]FCY
            If fstat : Raz [F:FCY] : Endif
        Endif
    Endif
    If [F:BPR]FCY <> "" & [F:FCY]LEGCPY = GSOCIETE  : INDINTER = 1 : Endif
Endif

ETABOU(GENRE) = 0
ETABOU(GSUPP) = 0
ETABOU(GSPE1) = 0
ETABOU(GSPE2) = 0
ETABOU(GSPE3) = 0

# 29397 mm 12.06
# FQ 59636 GA 11/2009 autoriser affermissement partiel: plusieurs commandes sur une POP
#If [M:PBW1]ORDQTYPUU <> 0  : Return : Endif

If [M:PBW1]LINCLEFLG <> 2 &
&  [M:PBW1]LINORDFLG <> 2
    If !INDINTER & find(WAPPHAB,2,3,6,7) : ETABOU(GENRE) = 1 : ETABOU(GSUPP)= 1 : Endif
    If  INDINTER & find(WINTHAB,2,3,6,7) : ETABOU(GENRE) = 1 : ETABOU(GSUPP)= 1 : Endif
    # 20846 mm 11.05
    If [M:PBW1]MRPMES > 1 & ETABOU(GENRE) =1 : ETABOU(GSPE3) = 1 : Endif
    If !INDINTER & find(WAPPHAB,4,5,6,7) & [M:PBW1]LINAPPFLG >= 3  & [M:PBW1]BPSNUM <> "" : ETABOU(GSPE2) = 1 : Endif
    If  INDINTER & find(WINTHAB,4,5,6,7) & [M:PBW1]LINAPPFLG >= 3  & [M:PBW1]BPSNUM <> "" : ETABOU(GSPE2) = 1 : Endif
Endif

If [M:PBW1]LINCLEFLG = 2 |
&  [M:PBW1]LINORDFLG = 2 |
&  [M:PBW1]LINAPPFLG < 4
    ETABOU(GSPE1)= 1
Else
    ETABOU(GSPE1)= 0
Endif

If find([M:PBW1]LINAPPFLG,2,3)
    ETABOU(GENRE) = 0
    ETABOU(GSUPP) =0
    ETABOU(GSPE1) = 1
Endif

If find([M:PBW1]LINAPPFLG,2,3)
    If !INDINTER & !find(WAPPHAB,4,5,6,7) : Diszo [M:PBW1] : Endif
    If  INDINTER & !find(WINTHAB,4,5,6,7) : Diszo [M:PBW1] : Endif
Endif

# Issue 107498/108 - 2016-05-20 by BEEBE : button only active when launching possible
# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
If WPJTLAUNCH = 1 & func AFNC.ACTIV("PJM")
    GERR = 1
    GMESSAGE = [M:PBW1]PJT + " : " + mess(228,2260,1)
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
    ETABOU(GSPE3) = 0

Endif

ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0
ETABOU(GBFIN)=1

Return

########################################################################
$ENR_MODPOP

Raz [M:PMG]
[M:PMG]MAJCOD = "M"
[M:PMG]MAJTYP = "P"
[M:PMG]MSGFLG         = 1
# 18138 MM 01.05
If clalev ([F:BTS]) <> 0
    If [F:BTS]TRACE = 2
        [M:PMG]TRAFLG         = 2
    Else
        [M:PMG]TRAFLG         = 1
    Endif
Else
    [M:PMG]TRAFLG         = 2
Endif
If [M:PBW1]POCNUM <> ""
    # contrat
    [M:PMG]WRCPDAT        = [M:PBW1]WRCPDAT
    [M:PMG]USEPLC         = [M:PBW1]USEPLC
    [M:PMG]NBLIG          = 1
    [M:PMG]POCNUM(0)      = [M:PBW1]POCNUM
    If [M:PMG]MAJCOD <> "C"
        [M:PMG]WIPTYP(0)      = WTYP
        [M:PMG]WIPSTA(0)      = WSTA
        [M:PMG]WIPNUM(0)      = WWIP
        [M:PMG]VCRNUM(0)      = [M:PBW1]VCRNUM
        [M:PMG]VCRLIN(0)      = [M:PBW1]VCRLIN
        [M:PMG]VCRSEQ(0)      = [M:PBW1]VCRSEQ
    Else
        [M:PMG]WIPTYP(0)      = 2
        [M:PMG]WIPSTA(0)      = 2
        [M:PMG]WIPNUM(0)      = ""
    Endif
    [M:PMG]ITMREF(0)      = [M:PBW1]ITMREF
    [M:PMG]ORIFCY(0)      = [M:PBW1]PSHFCY
    [M:PMG]STOFCY(0)      = [M:PBW1]STOFCY
    [M:PMG]ENDDAT(0)      = [M:PBW1]EXTRCPDAT
    [M:PMG]STU(0)         = [M:PBW1]STU
    [M:PMG]EXTSTUQTY(0)   = [M:PBW1]QTYSTU
    [M:PMG]PUU(0)         = [M:PBW1]UOM        # 29397 mm 12.06 - UC saisissable
    [M:PMG]EXTPUUQTY(0)   = [M:PBW1]QTYUOM     # 29397 mm 12.06 - UC saisissable
Else
    [M:PMG]REQUSR         = GUSER
    [M:PMG]PSHFCY         = [M:PBW1]PSHFCY
    [M:PMG]USEPLC         = [M:PBW1]USEPLC
    [M:PMG]NBLIG          = 1
    If [M:PMG]MAJCOD <> "C"
        [M:PMG]WIPTYP(0)      = WTYP
        [M:PMG]WIPSTA(0)      = WSTA
        [M:PMG]WIPNUM(0)      = WWIP
        [M:PMG]VCRNUM(0)      = [M:PBW1]VCRNUM
        [M:PMG]VCRLIN(0)      = [M:PBW1]VCRLIN
        [M:PMG]VCRSEQ(0)      = [M:PBW1]VCRSEQ
    Else
        [M:PMG]WIPTYP(0)      = 2
        [M:PMG]WIPSTA(0)      = 2
        [M:PMG]WIPNUM(0)      = ""
    Endif
    [M:PMG]ITMREF(0)      = [M:PBW1]ITMREF
    # interx
    If [M:PBW1]APPFCY <> "" & [M:PBW1]APPFCY <> [M:PBW1]PSHFCY
        [M:PMG]ORIFCY(0)      = [M:PBW1]APPFCY
    Else
        [M:PMG]ORIFCY(0)      = [M:PBW1]PSHFCY
    Endif
    [M:PMG]STOFCY(0)      = [M:PBW1]STOFCY
    [M:PMG]PJT(0)         = [M:PBW1]PJT
    [M:PMG]BPRNUM(0)      = [M:PBW1]BPSNUM
    [M:PMG]ENDDAT(0)      = [M:PBW1]EXTRCPDAT
    [M:PMG]STU(0)         = [M:PBW1]STU
    [M:PMG]EXTSTUQTY(0)   = [M:PBW1]QTYSTU
    [M:PMG]PUU(0)         = [M:PBW1]UOM          # 29397 mm 12.06 - UC saisissable
    [M:PMG]EXTPUUQTY(0)   = [M:PBW1]QTYUOM       # 29397 mm 12.06 - UC saisissable
Endif
If [M:PMG]EXTPUUQTY(0) = 0 : Return : Endif

# Issue 104943 - 2015-07-13 by BEEBE : Implementing Versioning
If dim([M:PBW1]ECCVALMAJ)>0
    [M:PMG]ECCVALMAJ(0)=[M:PBW1]ECCVALMAJ
    [M:PMG]ECCVALMIN(0)=[M:PBW1]ECCVALMIN
Endif

Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    PARAM(9) = num$(2)
    Raz [M:PBW1]
    If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNGBENCHA", "FUNDBENCHA","FUNMLINK")
        GVCR   = [M:PMG]VCRNUM(0)
        GLIN   = [M:PMG]VCRLIN(0)
        GSEQ   = [M:PMG]VCRSEQ(0)
    Endif
    FIN = 1
    Return
Else
    Return
Endif

Return

########################################################################
$SUP_MODPOP
Raz [M:PMG]
[M:PMG]MAJCOD         = "A"
[M:PMG]MAJTYP         = "P"
[M:PMG]MSGFLG         = 0
# 18138 MM 01.05
If clalev ([F:BTS]) <> 0
    If [F:BTS]TRACE = 2
        [M:PMG]TRAFLG = 2
    Else
        [M:PMG]TRAFLG = 1
    Endif
Else
    [M:PMG]TRAFLG     = 2
Endif
[M:PMG]POCNUM         = [M:PBW1]POCNUM
[M:PMG]NBLIG          = 1
[M:PMG]WIPTYP(0)      = WTYP
[M:PMG]WIPSTA(0)      = WSTA
[M:PMG]WIPNUM(0)      = WWIP
[M:PMG]VCRNUM(0)      = [M:PBW1]VCRNUM
[M:PMG]VCRLIN(0)      = [M:PBW1]VCRLIN
[M:PMG]VCRSEQ(0)      = [M:PBW1]VCRSEQ
Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    PARAM(9) = num$(2)
    Raz [M:PBW1]
    FIN = 1
    Return
Else
    Return
Endif
Return

########################################################################
$BOUTON_MODPOP
Case BOUT
    When "2"       :     # commander
                         Gosub MAJ_POP2POF
                         Return
    When "3"       :     # message
                         Gosub MAJ_MESPOP    # 20846 mm 11.05
                         Return
Endcase
FIN=0
Return

########################################################################
$MAJ_POP2POF
Local Integer WOK
# 01.05 28080
#----- Contrôle si article actif ? -----#
If [F:ITM]ITMSTA = 3
    OK = 2
    Call AVERTIR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",OK) From GESECRAN
    If OK = 1 : Return : Endif
Elsif [F:ITM]ITMSTA <> 1
    Call ERREUR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")") From GESECRAN
    GERR = 1
    Return
Endif

If [M:PBW1]POCNUM = ""
    #----- Contrôle article-fournisseur -----#
    If [F:ITP]ITMREF <> [M:PBW1]ITMREF | [F:ITP]BPSNUM <> [M:PBW1]BPSNUM
        Read [ITP]ITP0=[M:PBW1]ITMREF;[M:PBW1]BPSNUM
        If fstat : Raz [F:ITP] : Endif
    Else
        fstat = 0
    Endif
    # Issue 103282 GA 10/2014 when supplier-product not found
    If [F:ITP]ITMREF <> [M:PBW1]ITMREF | [F:ITP]BPSNUM <> [M:PBW1]BPSNUM
      # Issue 95343 GA 01/2014 article-fournisseur facultatif
      # Référencement inutile si fournisseur de type Divers
      If [F:BPS]BPSNUM<>[M:PBW1]BPSNUM
        Read [BPS] BPS0=[M:PBW1]BPSNUM : If fstat : Raz [F:BPS] : Endif
      Endif
      #----- Si fournisseur <> Divers -----#
      If [F:BPS]BPSTYP<>3
        #----- Si article non générique -----#
        If [F:ITM]GENFLG<>2
          If GITMBPS=1 GMESSAGE=[M:PBW1]ITMREF-mess(8,194,1) : GERR=1 : mkstat= 2 : Endif
          If GITMBPS=2 OK=2 : Call AVERTIR([M:PBW1]ITMREF-mess(8,194,1),OK) From GESECRAN
            If OK=1  : mkstat=2 : Raz GMESSAGE : Endif
          Endif
        Endif
      Endif
    Endif
    If [F:ITP]PURMINQTY>0
        Call PCAL_QTY ([F:ITP]PURMINQTY,[F:ITP]PUU,GBIDD1,[M:PBW1]STU,
&                      [M:PBW1]ITMREF,[M:PBW1]BPSNUM,1,GBIDD2) From TRTACHQTE1
        #----- Test qté inférieure à qté minimum d'achat -----#
        #VPO 15/10/10 17730/59532 contrôle selon paramètre
        If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
        #If [M:PBW1]QTYSTU < GBIDD1
        If [M:PBW1]QTYSTU < GBIDD1 & GPOHMINQTY<3
            [M:PBW1]PUU = [F:ITP]PUU    # 29397 mm 12.06 - UA remplacé par UC
            GMESSAGE =[M:PBW1]ITMREF-mess(14,194,1)                    # 47589 mm 06.08
            GMESSAGE-=num$(GBIDD1)-[M:PBW1]PUU
            If GPOHMINQTY=1
                GERR = 1
                Return
            Else : #GPOHMINQTY=2
              WOK=2
              Call AVERTIR (GMESSAGE, WOK)From GESECRAN
              If WOK=1
                  Raz GMESSAGE
                  GERR = 1
                  Return
              Endif
              Raz GMESSAGE
            Endif
        Endif
    Endif
Endif
Raz [M:PMG]
[M:PMG]MAJCOD         = "C"
[M:PMG]MAJTYP         = "F"
[M:PMG]RGRFLG         = 1
[M:PMG]MSGFLG         = 1
# 18138 MM 01.05
If clalev ([F:BTS]) <> 0
    If [F:BTS]TRACE = 2
        [M:PMG]TRAFLG     = 2
    Else
        [M:PMG]TRAFLG     = 1
    Endif
Else
    [M:PMG]TRAFLG         = 2
Endif
If [M:PBW1]POCNUM <> ""
    # contrat
    [M:PMG]WRCPDAT        = [M:PBW1]WRCPDAT
    [M:PMG]USEPLC         = [M:PBW1]USEPLC
    [M:PMG]NBLIG          = 1
    [M:PMG]POCNUM(0)      = [M:PBW1]POCNUM
    [M:PMG]WIPTYP(0)      = WTYP
    [M:PMG]WIPSTA(0)      = WSTA
    [M:PMG]WIPNUM(0)      = WWIP
    [M:PMG]VCRNUM(0)      = [M:PBW1]VCRNUM
    [M:PMG]VCRLIN(0)      = [M:PBW1]VCRLIN
    [M:PMG]VCRSEQ(0)      = [M:PBW1]VCRSEQ
    [M:PMG]ITMREF(0)      = [M:PBW1]ITMREF
    [M:PMG]ORIFCY(0)      = [M:PBW1]PSHFCY
    [M:PMG]STOFCY(0)      = [M:PBW1]STOFCY
    [M:PMG]ENDDAT(0)      = [M:PBW1]EXTRCPDAT
    [M:PMG]STU(0)         = [M:PBW1]STU
    [M:PMG]EXTSTUQTY(0)   = [M:PBW1]QTYSTU
    [M:PMG]PUU(0)         = [M:PBW1]UOM        # 29397 mm 12.06
    [M:PMG]EXTPUUQTY(0)   = [M:PBW1]QTYUOM     # 29397 mm 12.06
Else
    [M:PMG]REQUSR         = GUSER
    [M:PMG]PSHFCY         = [M:PBW1]PSHFCY
    If [F:ITF]OFS <> 0
        [M:PMG]PRQDAT         = TODAY
    Else
        [M:PMG]PRQDAT         = TODAY
    Endif
    [M:PMG]TARGRP         = 1
    [M:PMG]USEPLC         = [M:PBW1]USEPLC
    [M:PMG]NBLIG          = 1
    [M:PMG]WIPTYP(0)      = WTYP
    [M:PMG]WIPSTA(0)      = WSTA
    [M:PMG]WIPNUM(0)      = WWIP
    [M:PMG]VCRNUM(0)      = [M:PBW1]VCRNUM
    [M:PMG]VCRLIN(0)      = [M:PBW1]VCRLIN
    [M:PMG]VCRSEQ(0)      = [M:PBW1]VCRSEQ
    [M:PMG]ITMREF(0)      = [M:PBW1]ITMREF
    # interx
    If [M:PBW1]APPFCY <> "" & [M:PBW1]APPFCY <> [M:PBW1]PSHFCY
        [M:PMG]ORIFCY(0)      = [M:PBW1]APPFCY
    Else
        [M:PMG]ORIFCY(0)      = [M:PBW1]PSHFCY
    Endif
    [M:PMG]STOFCY(0)      = [M:PBW1]STOFCY
    [M:PMG]PJT(0)         = [M:PBW1]PJT
    [M:PMG]BPRNUM(0)      = [M:PBW1]BPSNUM
    [M:PMG]ENDDAT(0)      = [M:PBW1]EXTRCPDAT
    [M:PMG]STU(0)         = [M:PBW1]STU
    [M:PMG]EXTSTUQTY(0)   = [M:PBW1]QTYSTU
    [M:PMG]PUU(0)         = [M:PBW1]UOM        # 29397 mm 12.06
    [M:PMG]EXTPUUQTY(0)   = [M:PBW1]QTYUOM     # 29397 mm 12.06
Endif
If [M:PMG]EXTPUUQTY(0) = 0 | ([M:PMG]POCNUM(0) = "" & [M:PMG]BPRNUM(0) = "" )
    Return
Endif
# 106430.sn - Purchase planning - carry container info over to Purchase order
[M:PMG]TCTRNUM    = [M:PBW1]TCTRNUM
[M:PMG]TCTRQTY    = [M:PBW1]TCTRQTY
[M:PMG]WEICAP     = [M:PBW1]WEICAP
[M:PMG]VOLCAP     = [M:PBW1]VOLCAP
[M:PMG]ORDMAXAMT  = [M:PBW1]ORDMAXAMT
# 106430.en
Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    PARAM(9) = num$(2)
    Raz [M:PBW1]
    If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNGBENCHA", "FUNDBENCHA","FUNMLINK")
        GVCR   = [M:PMG]VCRNUM(0)
        GLIN   = [M:PMG]VCRLIN(0)
        GSEQ   = [M:PMG]VCRSEQ(0)
    Endif
    FIN = 1
    Return
Else
    Return
Endif
Return

###########################################################################
$MAJ_MESPOP
# 20846 mm 11.05
[M:PBW1]STU        = [M:PBW1]STU2
[M:PBW1]QTYSTU     = [M:PBW1]EXTQTY2
[M:PBW1]EXTRCPDAT  = [M:PBW1]ENDDAT2
# Conversion de la qté US en UC - 29397 mm 12.06
Call PCAL_QTY([M:PBW1]QTYSTU,[M:PBW1]STU,[M:PBW1]QTYUOM,[M:PBW1]UOM,
&  [M:PBW1]ITMREF,[M:PBW1]BPSNUM,1,GBIDD1  ) From TRTACHQTE1
Affzo  [M:PBW1]
Return
###########################################################################
#-------------------------------------------------------------------------#
# >>>>> Fenêtre DDEM2POX
#-------------------------------------------------------------------------#
###########################################################################
# chargement
$DEBUT_DEM2POX
Gosub CHARGE_PBW4
Diszo [M:PBW4]5-10
Diszo [M:PBW4]STU
Affzo [M:PBW4]1-99

# Issue 104943 - 2015-06-29 by BEEBE : Implementing Versioning
If dim([M:PBW4]ECCVALMAJ)>0
    Call ECCAFF([M:PBW4]ITMREF,"PBW4") From MFGECCLIB
    Call CTRECCPRD("PBW4") From MFGECCLIB
Endif

Return

###########################################################################
# état boutons
$SETBOUT_DEM2POX
INDINTER = 0

ETABOU(GENRE) = 0    # 14102 MM 04.06
ETABOU(GSUPP) = 0
ETABOU(GSPE1) = 0
ETABOU(GSPE2) = 0

If [M:PBW4]BPSNUM <> ""
    If [F:BPR]BPRNUM <> [M:PBW4]BPSNUM
        Read [BPR]BPR0=[M:PBW4]BPSNUM
        If fstat : Raz [F:BPR] : Endif
    Endif
    If [F:BPR]FCY <> ""
        If [F:FCY]FCY <> [F:BPR]FCY
            Read [FCY]FCY0=[F:BPR]FCY
            If fstat : Raz [F:FCY] : Endif
        Endif
    Endif
    If [F:BPR]FCY <> "" & [F:FCY]LEGCPY = GSOCIETE  : INDINTER = 1 : Endif
Endif

# 08.04 24522 + 11.05 32926 + 14102 mm 04.06
If  find(WAPPHAB, 1,3,5,7) & (WTYP = 2 & WSTA = 3) & !find(2,[M:PBW4]SELIND(0..[M:PBW4]NBLIG-1))
    ETABOU(GENRE) = 1 : ETABOU(GSUPP) = 1
Endif
If  find(WINTHAB, 1,3,5,7) & (WTYP = 7 & WSTA = 3) & !find(2,[M:PBW4]SELIND(0..[M:PBW4]NBLIG-1))
    ETABOU(GENRE) = 1 : ETABOU(GSUPP) = 1
Endif
If !INDINTER & find([M:PBW4]APPHAB,2,3,6,7) & !find([M:PBW4]FMI,2,3)                         : ETABOU(GSPE1) = 1 : Endif
If !INDINTER & find([M:PBW4]APPHAB,4,5,6,7) & [M:PBW4]BPSNUM <> ""                           : ETABOU(GSPE2) = 1 : Endif
If  INDINTER & find([M:PBW4]INTHAB,2,3,6,7) & !find([M:PBW4]FMI,2,3)                         : ETABOU(GSPE1) = 1 : Endif
If  INDINTER & find([M:PBW4]INTHAB,4,5,6,7) & !find([M:PBW4]FMI,2,3) & [M:PBW4]BPSNUM <> ""  : ETABOU(GSPE2) = 1 : Endif

# Issue 107307 - 2015-12-18 by BEEBE : consider user authorisation for function GESPOH and GESPOI,
#                                      to disable "Order" button in PBW4
If [M:PBW4]VCRTYP=10 # Subcontracting Service
    Local Integer LOK
    Local Char LMESSAGE
    # Check access rights for GESPOH and GFONCION - even when read only => disable button GSPE2
    Call DROITSITEF("GESPOH",[M:PBW4]PSHFCY,LMESSAGE,LOK) From CPTSUB
    If !LOK | GUSRVID="" : ETABOU(GSPE2)=0 : Endif
    # Check access rights for GESPOIand GFONCION - even when read only => disable button GSPE2
    Call DROITSITEF("GESPOI",[M:PBW4]PSHFCY,LMESSAGE,LOK) From CPTSUB
    If !LOK | GUSRVID="" : ETABOU(GSPE2)=0 : Endif
Endif

ETABOU(GBFIN)=1
If [M:PBW4]ITMREF <> ""
    Case GPLNFLT
        When 2:    If [F:ITF]PLANNER <> [M:PBW4]PLANNER & [F:ITF]PLANNER <> ""
                       ETABOU(GSPE1) = 0
                   Endif
        When 3:    If [F:ITF]PLANNER <> [M:PBW4]PLANNER
                       ETABOU(GSPE1) = 0
                   Endif
    Endcase

    If GBUYFLT = 2 & [F:ITF]BUY <> [M:PBW4]PLANNER & [F:ITF]BUY <> ""                # 01.05 27441
        ETABOU(GSPE2) = 0
    Endif
Endif
# si sous-traitance, on ne peut pas faire de DA
If WTYP = 4  : ETABOU(GSPE1) = 0 : Endif

# Issue 107498/108 - 2016-05-20 by BEEBE : button only active when launching possible
# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
If WPJTLAUNCH = 1 & func AFNC.ACTIV("PJM")
    GERR = 1
    GMESSAGE = [M:PBW4]PJT + " : " + mess(228,2260,1)
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
Endif

ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0
Return


########################################################################
$BOUTON_DEM2POX
Case BOUT
    When "1"       :     # demander
                         Gosub MAJ_DEM2POP
                         Return
    When "2"       :     # commander
                         #If WTYP <> 4 : Gosub MAJ_DEM2POF : Else : Gosub MAJ_SCF2POF : Endif
                         Case WTYP
                            When 4 : Gosub MAJ_SCF2POF
                                     Return
                            When 13: If WSTA = 1 : Gosub MAJ_EOF2POF : Else : Gosub MAJ_DEM2POF : Endif  # 54539
                                     Return
                            When Default: Gosub MAJ_DEM2POF
                                          Return
                         Endcase
Endcase
FIN=0
Return

########################################################################
# modification POS/TRS - 14102 MM 04.06
$ENR_DEM2POX

GOK = 1
Raz [M:ORDK]

Trbegin [ORD]
# modification de la POS ou de la TRS
Read [ORD] ORD0=WTYP;WWIP;WITM
If fstat
    GOK = 0
    WCLE = num$(WTYP)-WWIP-WITM
    Call RSTA ("ORD", WCLE)From GLOCK
    Goto AB_TRS
Endif

[M:ORDK]MAJCOD     = "M"
[M:ORDK]           = [F:ORD]
If WTYP=2
    [M:ORDK]BPRNUM = [M:PBW4]BPSNUM
Endif
[M:ORDK]PJT        = [M:PBW4]PJT
[M:ORDK]EXTQTY     = [M:PBW4]QTYSTU
[M:ORDK]ENDDAT     = [M:PBW4]EXTRCPDAT
WORIDAT            = [M:PBW4]EXTRCPDAT
WORIFCY            = [M:PBW4]STOFCY
# calcul date début
Read [ITF]ITF0=[M:PBW4]ITMREF;[M:PBW4]STOFCY
If fstat : Raz [F:ITF] : Endif
WLTI    = [F:ITF]OFS

# Issue 80737 GA 03/2012 pour les Achats le délai est un délai calendaire
#Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, WSTRDAT) From MFGLIB
Local Integer  WCOR : WCOR=8  # Arrondi date
Local Integer  WCOD : WCOD=1  # 1=délai achat en jours calendaires, 2=délai fab en jours ouvrés
Local Shortint WUPD : WUPD=0  # flag recalcul enddat
Local Date     WCALDATD : Raz WCALDATD
Local Decimal  WCAP(31)
Call CALDAT("-",WCOR,WORIDAT,WCOD,WLTI,WCAP,WCALDATD,WSTRDAT) From CBNLIB
[M:ORDK]STRDAT    = WSTRDAT

# Issue 104943 - 2015-06-29 by BEEBE : Implementing Versioning
If dim([M:PBW4]ECCVALMAJ)>0
    [M:ORDK]ECCVALMAJ=[M:PBW4]ECCVALMAJ
    [M:ORDK]ECCVALMIN=[M:PBW4]ECCVALMIN
Endif

Call WIP From TRTWIP
If GOK<>1 : Goto VAL_TRS : Endif

# si la commande est une TRS, on modifie son pendant dans les ventes
If WTYP = 7
    WWIPTYP = 8
    Raz [M:ORDK]
    Read [ORD1]ORD0=WWIPTYP;WWIP;WITM
    If fstat
        GOK = 0
        WCLE =num$(WWIPTYP)-WWIP-WITM
        Call RSTA ("ORD", WCLE)From GLOCK
        Goto AB_TRS
    Endif

    [M:ORDK]MAJCOD     = "M"
    [M:ORDK]           = [F:ORD1]
    [M:ORDK]STRDAT     = [M:PBW4]EXTRCPDAT        # 118177 mm 11.16 - Taking into account modification of the date
    [M:ORDK]ENDDAT     = [M:PBW4]EXTRCPDAT        # 118177 mm 11.16 - Taking into account modification of the date
    [M:ORDK]EXTQTY     = [M:PBW4]QTYSTU
    [M:ORDK]PJT        = [M:PBW4]PJT
    Call WIP From TRTWIP
Endif

$VAL_TRS
If GOK = 1 : Commit
Else  : Goto AB_TRS : Endif

# trace
Call OUVRE_TRACE(mess(74,192,1)) From LECFIC
If WTYP = 2       # POS
    MESS1 = mess(1,392,1)- mess(260,193,1)-WWIP-mess(223,197,1)
Elsif WTYP = 7    # TRS
    MESS1 = mess(269,197,1)-WWIP-mess(232,197,1)
    MESS2 = mess(8,306,1)- mess(260,193,1)-WWIP-mess(223,197,1)
Endif
Call ECR_TRACE(MESS1,0) From GESECRAN
If MESS2<>"" : Call ECR_TRACE(MESS2,0) From GESECRAN : Endif
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

FIN = 1
PARAM(9) = num$(2)


Return

########################################################################
$AB_TRS
Rollback
Call ECR_TRACE(mess(17,107,1), 1)From GESECRAN
Return
########################################################################
# suppression POS
$SUP_DEM2POX

OK = 1
Call OUINON(mess(62,190,1),OK) From GESECRAN
If OK = 2
    Call OUVRE_TRACE(mess(53,123,1)) From LECFIC
    Case WTYP
        When 5:
           Raz [M:MFGK]
           [M:MFGK]CODMAJ = "A"
           [M:MFGK]CODTRS = 2
           [M:MFGK]MFGNUM = [M:PBW4]VCRNUM
           [M:MFGK]MFGFCY = [M:PBW4]STOFCY
           [M:MFGK]MFGSTA = [M:PBW4]WIPSTA
           [M:MFGK]ITMREF = [M:PBW4]ITMREF
           [M:MFGK]WIPTYP = WTYP
           Call MAJ_OF From MFGAUTLIB
        When 2:
           [M:MFGK]WIPTYP = WTYP
           Call SUPPRIME_POS(WTYP, WWIP, [M:PBW4]ITMREF)
           [M:MFGK]CODRET = 0
        When 7: # FQ 76783 GA 09/2011 cas des TRS supprimer d'abord la TPS
           [M:MFGK]WIPTYP = 8      # TPS
           Call SUPPRIME_POS(8, WWIP, [M:PBW4]ITMREF)
           [M:MFGK]CODRET = 0
           [M:MFGK]WIPTYP = WTYP   # TRS
           Call SUPPRIME_POS(WTYP, WWIP, [M:PBW4]ITMREF)
           [M:MFGK]CODRET = 0
        When 13:
            Raz [M:SCOK]
            [M:SCOK]CODMAJ = "A"
            [M:SCOK]SCONUM = [M:PBW4]VCRNUM
            [M:SCOK]STOFCY = [M:PBW4]STOFCY
            Call MAJ_SCO From SCOAUTLIB
        When Default :
            # FQ 76783 GA 09/2011
            Call ECR_TRACE(mess(28,125,1)-mess(126,853,1)-mess(WTYP,341,1)+mess(WSTA,342,1)-WWIP-[M:PBW4]ITMREF,1) From GESECRAN
    Endcase
    If [M:MFGK]CODRET = 0
        # 42410 mm 09.07
        If [M:MFGK]WIPTYP = 2         # POS
            MESS1 = mess(236,197,1)-[M:MFGK]MFGNUM-mess(234,197,1)
        Elsif [M:MFGK]WIPTYP = 7      # TRS
            MESS1 = mess(269,197,1)-[M:MFGK]MFGNUM-mess(175,197,1)- mess(713,197,1)
        Endif
        Call ECR_TRACE(MESS1,0) From GESECRAN
        PARAM(9) = num$(2)
        Raz [M:PBW4]
        If find(GFONCTION,"FUNGBENCH", "FUNDBENCH","FUNGBENCHA", "FUNDBENCHA","FUNMLINK")
            GVCR   = ""
            GLIN   = 0
            GSEQ   = 0
        Endif
        FIN = 1
    Endif
    Call FERME_TRACE From LECFIC
    # 18138 MM 01.05
    If  clalev ([F:BTS]) <> 0
        If [F:BTS]TRACE=2  : Call LEC_TRACE From LECFIC : Endif
    Else
         Call LEC_TRACE From LECFIC
    Endif
Endif
Return

########################################################################
# création POP par PEC
$MAJ_DEM2POP
# 01.05 28080
#----- Contrôle si article actif ? -----#
If [F:ITM]ITMSTA = 3
    OK = 2
    Call AVERTIR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",OK) From GESECRAN
    If OK = 1 : Return : Endif
Elsif [F:ITM]ITMSTA <> 1
    Call ERREUR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")") From GESECRAN
    GERR = 1
    Return
Endif
Raz [M:PMG]
[M:PMG]MAJCOD         = "C"
[M:PMG]MAJTYP         = "P"
[M:PMG]RGRFLG         = 1
[M:PMG]MSGFLG         = 1
# 18138 MM 01.05
If clalev ([F:BTS]) <> 0
    If [F:BTS]TRACE = 2
        [M:PMG]TRAFLG     = 2
    Else
        [M:PMG]TRAFLG     = 1
    Endif
Else
    [M:PMG]TRAFLG         = 2
Endif

If [M:PBW4]POCNUM <> ""
    # contrat
    [M:PMG]WRCPDAT        = [M:PBW4]WRCPDAT
    [M:PMG]USEPLC         = [M:PBW4]USEPLC
    [M:PMG]NBLIG          = 1
    [M:PMG]POCNUM(0)      = [M:PBW4]POCNUM
    If (WTYP = 2 & WSTA = 3) | (WTYP = 4 & WSTA = 1) | (WTYP = 7 & WSTA = 3)    # 08.04 24522
        [M:PMG]WIPTYP(0)      = WTYP
        [M:PMG]WIPSTA(0)      = WSTA
        [M:PMG]WIPNUM(0)      = WWIP
    Else
        [M:PMG]WIPTYP(0)      = 0
        [M:PMG]WIPSTA(0)      = 0
        [M:PMG]WIPNUM(0)      = ""
    Endif
    [M:PMG]ITMREF(0)      = [M:PBW4]ITMREF
    [M:PMG]STOFCY(0)      = [M:PBW4]STOFCY
    [M:PMG]ORIFCY(0)      = [M:PBW4]PSHFCY
    [M:PMG]ENDDAT(0)      = [M:PBW4]EXTRCPDAT
    [M:PMG]STU(0)         = [M:PBW4]STU
    [M:PMG]EXTSTUQTY(0)   = [M:PBW4]QTYSTU
    [M:PMG]PUU(0)         = [M:PBW4]PUU
    [M:PMG]EXTPUUQTY(0)   = [M:PBW4]QTYPUU
Else
    # hors contrat
    [M:PMG]REQUSR         = GUSER
    [M:PMG]PSHFCY         = [M:PBW4]PSHFCY
    [M:PMG]PRQDAT         = date$
    [M:PMG]NBLIG          = 1
    If (WTYP = 2 & WSTA = 3) | (WTYP = 4 & WSTA = 1)  | (WTYP = 7 & WSTA = 3)    # 08.04 24522
        [M:PMG]WIPTYP(0)      = WTYP
        [M:PMG]WIPSTA(0)      = WSTA
        [M:PMG]WIPNUM(0)      = WWIP
    Else
        [M:PMG]WIPTYP(0)      = 0
        [M:PMG]WIPSTA(0)      = 0
        [M:PMG]WIPNUM(0)      = ""
    Endif
    [M:PMG]ITMREF(0)      = [M:PBW4]ITMREF
    # interx
    If [M:PBW4]APPFCY <> "" & [M:PBW4]APPFCY <> [M:PBW4]PSHFCY
        [M:PMG]ORIFCY(0)      = [M:PBW4]APPFCY
    Else
        [M:PMG]ORIFCY(0)      = [M:PBW4]PSHFCY
    Endif
    [M:PMG]STOFCY(0)      = [M:PBW4]STOFCY
    [M:PMG]PJT(0)         = [M:PBW4]PJT
    [M:PMG]BPRNUM(0)      = [M:PBW4]BPSNUM
    [M:PMG]ENDDAT(0)      = [M:PBW4]EXTRCPDAT
    [M:PMG]STU(0)         = [M:PBW4]STU
    [M:PMG]EXTSTUQTY(0)   = [M:PBW4]QTYSTU
    [M:PMG]PUU(0)         = [M:PBW4]PUU
    [M:PMG]EXTPUUQTY(0)   = [M:PBW4]QTYPUU
Endif
[M:PMG]VCRTYP(0)          = [M:PBW4]VCRTYP
[M:PMG]VCRNUM(0)          = [M:PBW4]VCRNUM
[M:PMG]VCRLIN(0)          = [M:PBW4]VCRLIN
[M:PMG]VCRSEQ(0)          = [M:PBW4]VCRSEQ : # Ajout GA 03/10/2005
If [M:PMG]EXTPUUQTY(0) = 0 : Return : Endif
Gosub CHECK_WIP
If WRET
    GERR = 1
    FIN = 1
    PARAM(9) = num$(2)
    Return
Endif
# Issue 104943 - 2015-06-29 by BEEBE : Implementing Versioning
If dim([M:PMG]ECCVALMAJ)>0
    [M:PMG]ECCVALMAJ(0)=[M:PBW4]ECCVALMAJ
    [M:PMG]ECCVALMIN(0)=[M:PBW4]ECCVALMIN
Endif
Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    # If [M:PBW4]VCRTYP = 11 & WTYP = 5 & [M:PBW4]WIPSTA = 3 : # GH 13/03/13 bug 91838
    If [M:PBW4]VCRTYP = 11 & find(WTYP,5,13) & [M:PBW4]WIPSTA = 3
        If [M:PBW4]QTYSTU >= WQTYPRV
            Raz [M:MFGK]
            [M:MFGK]CODMAJ = "A"
            [M:MFGK]CODTRS = 2
            [M:MFGK]MFGNUM = [M:PBW4]VCRNUM
            [M:MFGK]MFGLIN = [M:PBW4]VCRLIN
            [M:MFGK]MFGFCY = [M:PBW4]STOFCY
            [M:MFGK]MFGSTA = 3
            [M:MFGK]ITMREF = [M:PBW4]ITMREF
            [M:MFGK]WIPTYP = WTYP
            [M:MFGK]WIPNUM = WWIPNUM
            Call MAJ_OF From MFGAUTLIB
        Else
            Raz [M:MFGK]
            [M:MFGK]CODMAJ = "D"
            [M:MFGK]CODTRS = 2
            [M:MFGK]MFGNUM = [M:PBW4]VCRNUM
            [M:MFGK]MFGFCY = [M:PBW4]STOFCY
            [M:MFGK]MFGSTA = 3
            [M:MFGK]ITMREF = [M:PBW4]ITMREF
            [M:MFGK]PRVQTY = WQTYPRV
            [M:MFGK]EXTQTY = WQTYPRV - [M:PBW4]QTYSTU
            [M:MFGK]WIPNUM = WWIPNUM
            [M:MFGK]WIPTYP = WTYP
            Call MAJ_OF From MFGAUTLIB
        Endif
    Endif

    PARAM(9) = num$(2)
    Raz [M:PBW4]
    If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNGBENCHA", "FUNDBENCHA","FUNMLINK")
        GVCR   = [M:PMG]VCRNUM(0)
        GLIN   = [M:PMG]VCRLIN(0)
        GSEQ   = [M:PMG]VCRSEQ(0)
        FIN = 1
        Return
    Else
        Return
    Endif
Endif
Return

########################################################################
# création POF par PEC
$MAJ_DEM2POF
Local Integer WOK
# 05.05 30151
If [F:ITM]PRQFLG = 2
    GMESSAGE = mess(164,194,1)
    GERR = 1
    Return
Endif
# 01.05 28080
#----- Contrôle si article actif ? -----#
If [F:ITM]ITMSTA = 3
    OK = 2
    Call AVERTIR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",OK) From GESECRAN
    If OK = 1 : Return : Endif
Elsif [F:ITM]ITMSTA <> 1
    Call ERREUR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")") From GESECRAN
    GERR = 1
    Return
Endif
If [M:PBW4]POCNUM = ""
    #----- Contrôle article-fournisseur -----#
    If [F:ITP]ITMREF <> [M:PBW4]ITMREF | [F:ITP]BPSNUM <> [M:PBW4]BPSNUM
        Read [ITP]ITP0=[M:PBW4]ITMREF;[M:PBW4]BPSNUM
        If fstat : Raz [F:ITP] : Endif
    Else
        fstat = 0
    Endif
    # Issue 103282 GA 10/2014 when supplier-product not found
    If [F:ITP]ITMREF <> [M:PBW4]ITMREF | [F:ITP]BPSNUM <> [M:PBW4]BPSNUM
      # Issue 95343 GA 01/2014 article-fournisseur facultatif
      # Référencement inutile si fournisseur de type Divers
      If [F:BPS]BPSNUM<>[M:PBW4]BPSNUM
        Read [BPS] BPS0=[M:PBW4]BPSNUM : If fstat : Raz [F:BPS] : Endif
      Endif
      #----- Si fournisseur <> Divers -----#
      If [F:BPS]BPSTYP<>3
        #----- Si article non générique -----#
        If [F:ITM]GENFLG<>2
          If GITMBPS=1 GMESSAGE=[M:PBW4]ITMREF-mess(8,194,1) : GERR=1 : mkstat= 2 : Endif
          If GITMBPS=2 OK=2 : Call AVERTIR([M:PBW4]ITMREF-mess(8,194,1),OK) From GESECRAN
            If OK=1  : mkstat=2 : Raz GMESSAGE : Endif
          Endif
        Endif
      Endif
    Endif
    If [F:ITP]PURMINQTY>0
        Call PCAL_QTY ([F:ITP]PURMINQTY,[F:ITP]PUU,GBIDD1,[M:PBW4]PUU,
&                      [M:PBW4]ITMREF,[M:PBW4]BPSNUM,1,GBIDD2) From TRTACHQTE1
        #----- Test qté inférieure à qté minimum d'achat -----#
        #VPO 15/10/10 17730/59532 contrôle selon paramètre
        If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
        #If [M:PBW4]QTYPUU < GBIDD1
        If [M:PBW4]QTYPUU < GBIDD1 & GPOHMINQTY<3
            GMESSAGE =[M:PBW4]ITMREF-mess(14,194,1)                    # 47589 mm 06.08
            GMESSAGE-=num$(GBIDD1)-[M:PBW4]PUU
            If GPOHMINQTY=1
                GERR = 1
                Return
            Else : #GPOHMINQTY=2
              WOK=2
              Call AVERTIR (GMESSAGE, WOK)From GESECRAN
              If WOK=1
                  Raz GMESSAGE
                  GERR = 1
                  Return
              Endif
              Raz GMESSAGE
            Endif
        Endif
    Endif
Endif
If [F:ITM]ITMSTA = 3
   OK = 2
   Call AVERTIR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",OK) From GESECRAN
   If OK = 1 : Return : Endif
Endif

Raz [M:PMG]
[M:PMG]MAJCOD         = "C"
[M:PMG]MAJTYP         = "F"
[M:PMG]RGRFLG         = 1
[M:PMG]MSGFLG         = 1
# 18138 MM 01.05
If clalev ([F:BTS]) <> 0
    If [F:BTS]TRACE = 2
        [M:PMG]TRAFLG     = 2
    Else
        [M:PMG]TRAFLG     = 1
    Endif
Else
    [M:PMG]TRAFLG         = 2
Endif
If [M:PBW4]POCNUM <> ""
    # contrat
    [M:PMG]WRCPDAT        = [M:PBW4]WRCPDAT
    [M:PMG]USEPLC         = [M:PBW4]USEPLC
    [M:PMG]NBLIG          = 1
    [M:PMG]POCNUM(0)      = [M:PBW4]POCNUM
    If (WTYP = 2 & WSTA = 3) | (WTYP = 4 & WSTA = 1)  | (WTYP = 7 & WSTA = 3)    # 08.04 24522
        [M:PMG]WIPTYP(0)      = WTYP
        [M:PMG]WIPSTA(0)      = WSTA
        [M:PMG]WIPNUM(0)      = WWIP
    Else
        [M:PMG]WIPTYP(0)      = 0
        [M:PMG]WIPSTA(0)      = 0
        [M:PMG]WIPNUM(0)      = ""
    Endif
   [M:PMG]ITMREF(0)      = [M:PBW4]ITMREF
   [M:PMG]STOFCY(0)      = [M:PBW4]STOFCY
   [M:PMG]ORIFCY(0)      = [M:PBW4]PSHFCY
   [M:PMG]ENDDAT(0)      = [M:PBW4]EXTRCPDAT
   [M:PMG]STU(0)         = [M:PBW4]STU
   [M:PMG]EXTSTUQTY(0)   = [M:PBW4]QTYSTU
   [M:PMG]PUU(0)         = [M:PBW4]PUU
   [M:PMG]EXTPUUQTY(0)   = [M:PBW4]QTYPUU
Else
   [M:PMG]REQUSR         = GUSER
   [M:PMG]PSHFCY         = [M:PBW4]PSHFCY
   [M:PMG]PRQDAT         = TODAY
   [M:PMG]TARGRP         = 1
   [M:PMG]USEPLC         = [M:PBW4]USEPLC
   [M:PMG]NBLIG          = 1
   If (WTYP = 2 & WSTA = 3) | (WTYP = 4 & WSTA = 1)  | (WTYP = 7 & WSTA = 3)    # 08.04 24522
       [M:PMG]WIPTYP(0)      = WTYP
       [M:PMG]WIPSTA(0)      = WSTA
       [M:PMG]WIPNUM(0)      = WWIP
   Else
       [M:PMG]WIPTYP(0)      = 0
       [M:PMG]WIPSTA(0)      = 0
       [M:PMG]WIPNUM(0)      = ""
   Endif
   [M:PMG]ITMREF(0)      = [M:PBW4]ITMREF
    # interx
    If [M:PBW4]APPFCY <> "" & [M:PBW4]APPFCY <> [M:PBW4]PSHFCY
        [M:PMG]ORIFCY(0)      = [M:PBW4]APPFCY
    Else
        [M:PMG]ORIFCY(0)      = [M:PBW4]PSHFCY
    Endif
   [M:PMG]STOFCY(0)      = [M:PBW4]STOFCY
   [M:PMG]PJT(0)         = [M:PBW4]PJT
   [M:PMG]BPRNUM(0)      = [M:PBW4]BPSNUM
   [M:PMG]ENDDAT(0)      = [M:PBW4]EXTRCPDAT
   [M:PMG]STU(0)         = [M:PBW4]STU
   [M:PMG]EXTSTUQTY(0)   = [M:PBW4]QTYSTU
   [M:PMG]PUU(0)         = [M:PBW4]PUU
   [M:PMG]EXTPUUQTY(0)   = [M:PBW4]QTYPUU
Endif
[M:PMG]VCRTYP(0)          = [M:PBW4]VCRTYP
[M:PMG]VCRNUM(0)          = [M:PBW4]VCRNUM
[M:PMG]VCRLIN(0)          = [M:PBW4]VCRLIN
[M:PMG]VCRSEQ(0)          = [M:PBW4]VCRSEQ : # Ajout GA 03/10/2005
# Issue 104943 - 2015-06-29 by BEEBE : Implementing Versioning
If dim([M:PMG]ECCVALMAJ)>0
    [M:PMG]ECCVALMAJ(0)=[M:PBW4]ECCVALMAJ
    [M:PMG]ECCVALMIN(0)=[M:PBW4]ECCVALMIN
Endif
If ([M:PBW4]FMI=2 |[M:PBW4]FMI=3)
    Read [SOQ]SOQ0= [M:PBW4]VCRNUM;[M:PBW4]VCRLIN;[M:PBW4]VCRSEQ
    If !fstat
        If [M:PBW4]QTYSTU < [F:SOQ]QTYSTU
            GMESSAGE = mess(255,194,1)
            GERR = 1
            Return
        Else
            If [F:SOQ]FMINUM=""
                [M:PMG]SOHNUM(0)     = [M:PBW4]VCRNUM
                [M:PMG]SOPLIN(0)     = [M:PBW4]VCRLIN
                [M:PMG]SOQSEQ(0)     = [M:PBW4]VCRSEQ
            Else
                GMESSAGE = mess(246,194,1)
                GERR = 1
                Return
            Endif
        Endif
    Endif
Endif
If [M:PMG]EXTPUUQTY(0) = 0 | ([M:PMG]POCNUM(0) = "" & [M:PMG]BPRNUM(0) = "" )
    Return
Endif
#
# 106430.sn - Purchase planning - carry container info over to Purchase order
[M:PMG]TCTRNUM    = [M:PBW4]TCTRNUM
[M:PMG]TCTRQTY    = [M:PBW4]TCTRQTY
[M:PMG]WEICAP     = [M:PBW4]WEICAP
[M:PMG]VOLCAP     = [M:PBW4]VOLCAP
[M:PMG]ORDMAXAMT  = [M:PBW4]ORDMAXAMT
# 106430.en
Gosub CHECK_WIP
If WRET
    GERR = 1
    FIN = 1
    PARAM(9) = num$(2)
    Return
Endif
Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    If [M:PBW4]VCRTYP = 11 & find(WTYP,5,13) & [M:PBW4]WIPSTA = 3
        If [M:PBW4]QTYSTU >= WQTYPRV
            Raz [M:MFGK]
            [M:MFGK]CODMAJ = "A"
            [M:MFGK]CODTRS = 2
            [M:MFGK]MFGNUM = [M:PBW4]VCRNUM
            [M:MFGK]MFGLIN = [M:PBW4]VCRLIN
            [M:MFGK]MFGFCY = [M:PBW4]STOFCY
            [M:MFGK]MFGSTA = 3
            [M:MFGK]ITMREF = [M:PBW4]ITMREF
            [M:MFGK]WIPTYP = WTYP
            [M:MFGK]WIPNUM = WWIPNUM
            Call MAJ_OF From MFGAUTLIB
        Else
            Raz [M:MFGK]
            [M:MFGK]CODMAJ = "D"
            [M:MFGK]CODTRS = 2
            [M:MFGK]MFGNUM = [M:PBW4]VCRNUM
            [M:MFGK]MFGFCY = [M:PBW4]STOFCY
            [M:MFGK]MFGSTA = 3
            [M:MFGK]ITMREF = [M:PBW4]ITMREF
            [M:MFGK]PRVQTY = WQTYPRV
            [M:MFGK]EXTQTY = WQTYPRV - [M:PBW4]QTYSTU
            [M:MFGK]WIPNUM = WWIPNUM
            [M:MFGK]WIPTYP = WTYP
            Call MAJ_OF From MFGAUTLIB
        Endif
    Endif

    PARAM(9) = num$(2)
    Raz [M:PBW4]
    If find(GFONCTION,"FUNGBENCH", "FUNDBENCH","FUNGBENCHA", "FUNDBENCHA","FUNMLINK")
        GVCR   = [M:PMG]VCRNUM(0)
        GLIN   = [M:PMG]VCRLIN(0)
        GSEQ   = [M:PMG]VCRSEQ(0)
    Endif
    FIN = 1
    Return
Else
    Return
Endif
Return

########################################################################
$MAJ_SCF2POF
Local Integer WOK
# 01.05 28080
#----- Contrôle si article actif ? -----#
If [F:ITM]ITMSTA = 3
    OK = 2
    Call AVERTIR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",OK) From GESECRAN
    If OK = 1 : Return : Endif
Elsif [F:ITM]ITMSTA <> 1
    Call ERREUR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")") From GESECRAN
    GERR = 1
    Return
Endif

# GH 06/09/11 bug 75768
If [M:PBW4]POCNUM = ""
    #----- Contrôle article-fournisseur -----#
    If [F:ITP]ITMREF <> [M:PBW4]ITMREF | [F:ITP]BPSNUM <> [M:PBW4]BPSNUM
        Read [ITP]ITP0=[M:PBW4]ITMREF;[M:PBW4]BPSNUM
    Else
        fstat = 0
    Endif
    # Issue 103282 GA 10/2014 when supplier-product not found
    If [F:ITP]ITMREF <> [M:PBW4]ITMREF | [F:ITP]BPSNUM <> [M:PBW4]BPSNUM
      # Issue 95343 GA 01/2014 article-fournisseur facultatif
      # Référencement inutile si fournisseur de type Divers
      If [F:BPS]BPSNUM<>[M:PBW4]BPSNUM
        Read [BPS] BPS0=[M:PBW4]BPSNUM : If fstat : Raz [F:BPS] : Endif
      Endif
      #----- Si fournisseur <> Divers -----#
      If [F:BPS]BPSTYP<>3
        #----- Si article non générique -----#
        If [F:ITM]GENFLG<>2
          If GITMBPS=1 GMESSAGE=[M:PBW4]ITMREF-mess(8,194,1) : GERR=1 : mkstat= 2 : Endif
          If GITMBPS=2 OK=2 : Call AVERTIR([M:PBW4]ITMREF-mess(8,194,1),OK) From GESECRAN
            If OK=1  : mkstat=2 : Raz GMESSAGE : Endif
          Endif
        Endif
      Endif
    Endif
    If [F:ITP]PURMINQTY>0
        Call PCAL_QTY ([F:ITP]PURMINQTY,[F:ITP]PUU,GBIDD1,[M:PBW4]PUU,
&                      [M:PBW4]ITMREF,[M:PBW4]BPSNUM,1,GBIDD2) From TRTACHQTE1
        #----- Test qté inférieure à qté minimum d'achat -----#
        If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
        If [M:PBW4]QTYPUU < GBIDD1 & GPOHMINQTY<3
            GMESSAGE =[M:PBW4]ITMREF-mess(14,194,1)
            GMESSAGE-=num$(GBIDD1)-[M:PBW4]PUU
            If GPOHMINQTY=1
                GERR = 1
                Return
            Else : #GPOHMINQTY=2
              WOK=2
              Call AVERTIR (GMESSAGE, WOK)From GESECRAN
              If WOK=1
                  Raz GMESSAGE
                  GERR = 1
                  Return
              Endif
              Raz GMESSAGE
            Endif
        Endif
    Endif
Endif
Raz [M:PMG]
[M:PMG]MAJCOD         = "C"
[M:PMG]MAJTYP         = "F"
[M:PMG]RGRFLG         = 1
[M:PMG]MSGFLG         = 1
# 18138 MM 01.05
If clalev ([F:BTS]) <> 0
    If [F:BTS]TRACE = 2
        [M:PMG]TRAFLG         = 2
    Else
        [M:PMG]TRAFLG         = 1
    Endif
Else
    [M:PMG]TRAFLG     = 2
Endif
[M:PMG]REQUSR         = GUSER
[M:PMG]PSHFCY         = [M:PBW4]PSHFCY
[M:PMG]PRQDAT         = TODAY
[M:PMG]TARGRP         = 1
[M:PMG]USEPLC         = [M:PBW4]USEPLC
[M:PMG]NBLIG          = 1
If WWIP=""  # FQ 77397 GA 12/2011 si [F:MFO]WIPNUM perdu/non reçu en paramètre
  For [ORDW] Where VCRTYP=[M:PBW4]VCRTYP & VCRNUM=[M:PBW4]VCRNUM
&               &  VCRLIN=[M:PBW4]VCRLIN & VCRSEQ=[M:PBW4]VCRSEQ
&               &  ITMREF=[M:PBW4]ITMREF & WIPTYP=[L]WTYP & WIPSTA=[L]WSTA
      WWIP=[F:ORDW]WIPNUM
      Break
  Next
Endif
[M:PMG]WIPTYP(0)      = WTYP
[M:PMG]WIPSTA(0)      = WSTA
[M:PMG]WIPNUM(0)      = WWIP
[M:PMG]ITMREF(0)      = [M:PBW4]ITMREF
[M:PMG]VCRTYP(0)      = [M:PBW4]VCRTYP : # Ajout GA 03/10/2005
[M:PMG]VCRNUM(0)      = [M:PBW4]VCRNUM : # Ajout GA 03/10/2005
[M:PMG]VCRLIN(0)      = [M:PBW4]VCRLIN : # Ajout GA 03/10/2005
[M:PMG]VCRSEQ(0)      = [M:PBW4]VCRSEQ : # Ajout GA 03/10/2005
# interx
If [M:PBW4]APPFCY <> "" & [M:PBW4]APPFCY <> [M:PBW4]PSHFCY
    [M:PMG]ORIFCY(0)      = [M:PBW4]APPFCY
Else
    [M:PMG]ORIFCY(0)      = [M:PBW4]PSHFCY
Endif
[M:PMG]STOFCY(0)      = [M:PBW4]STOFCY
[M:PMG]PJT(0)         = [M:PBW4]PJT
[M:PMG]BPRNUM(0)      = [M:PBW4]BPSNUM
[M:PMG]ENDDAT(0)      = [M:PBW4]EXTRCPDAT
[M:PMG]STU(0)         = [M:PBW4]STU
[M:PMG]EXTSTUQTY(0)   = [M:PBW4]QTYSTU
[M:PMG]PUU(0)         = [M:PBW4]PUU
[M:PMG]EXTPUUQTY(0)   = [M:PBW4]QTYPUU
If [M:PMG]EXTPUUQTY(0) = 0 | ([M:PMG]POCNUM(0) = "" & [M:PMG]BPRNUM(0) = "" )
    Return
Endif

# Issue 104943 - 2015-06-29 by BEEBE : Implementing Versioning
If dim([M:PMG]ECCVALMAJ)>0
    [M:PMG]ECCVALMAJ(0)=[M:PBW4]ECCVALMAJ
    [M:PMG]ECCVALMIN(0)=[M:PBW4]ECCVALMIN
Endif

# PE SCFZONSPE pour le traitement des zones spécifiques - 20167 11.03 MM
GPOINT= "SCFZONSPE" : Gosub ENTREE From EXEFNC
#
Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    If GCLCWOCAUT = 3 & [M:PBW4]VCRTYP=10  # FQ 75863 GA 08/2011 calcul prévisionnel
      # appel direct possible car la boite de dlg ne s'ouvre pas
      Local Char PARAM_CLC(250)(1..14) , VAL_CLC(250)
      PARAM_CLC(1)  = [M:PBW4]STOFCY
      PARAM_CLC(2)  = [M:PBW4]VCRNUM
      PARAM_CLC(4)  = "1"
      PARAM_CLC(5)  = "4"
      # positionner PARAM_CLC(9) à "1" SI ON NE VEUT PAS l'édition du calcul
      # positionner PARAM_CLC(13) à "2" si on veut la trace
      PARAM_CLC(9)  = "1"   # GH 09/04/2014 bug 99047 # PARAM_CLC(12) = "2"
      PARAM_CLC(13) = "0"   # Issue 89622 - 2013-06-05 by CCC
      PARAM_CLC(14) = "10"    # OF

      Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBMCC","",3,"") From GTRAITE
    Endif

    # PE EDITSCF pour pouvoir lancer l'édition de la commande
    # qui vient d'être générée - 20168 11.03 MM
    GPOINT= "EDITSCF" : Gosub ENTREE From EXEFNC
    #
    PARAM(9) = num$(2)
    Raz [M:PBW4]
    If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNGBENCHA", "FUNDBENCHA","FUNMLINK")
        GVCR   = [M:PMG]VCRNUM(0)
        GLIN   = [M:PMG]VCRLIN(0)
        GSEQ   = [M:PMG]VCRSEQ(0)
    Endif
    FIN = 1
Endif
Return

########################################################################
$MAJ_EOF2POF
#----- Contrôle si article actif ? -----#
If [F:ITM]ITMSTA = 3
    OK = 2
    Call AVERTIR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",OK) From GESECRAN
    If OK = 1 : Return : Endif
Elsif [F:ITM]ITMSTA <> 1
    Call ERREUR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")") From GESECRAN
    GERR = 1
    Return
Endif

Raz [M:PMG]
[M:PMG]MAJCOD         = "C"
[M:PMG]MAJTYP         = "F"
[M:PMG]RGRFLG         = 1
[M:PMG]MSGFLG         = 1
[M:PMG]TRAFLG         = 2
[M:PMG]REQUSR         = GUSER
[M:PMG]PSHFCY         = [M:PBW4]PSHFCY
[M:PMG]PRQDAT         = TODAY
[M:PMG]TARGRP         = 1
[M:PMG]USEPLC         = [M:PBW4]USEPLC
[M:PMG]NBLIG          = 1
[M:PMG]WIPTYP(0)      = WTYP
[M:PMG]WIPSTA(0)      = WSTA
[M:PMG]WIPNUM(0)      = WWIP
[M:PMG]ITMREF(0)      = [M:PBW4]ITMREF
[M:PMG]VCRTYP(0)      = [M:PBW4]VCRTYP : # Ajout GA 03/10/2005
[M:PMG]VCRNUM(0)      = [M:PBW4]VCRNUM : # Ajout GA 03/10/2005
[M:PMG]VCRLIN(0)      = [M:PBW4]VCRLIN : # Ajout GA 03/10/2005
[M:PMG]VCRSEQ(0)      = [M:PBW4]VCRSEQ : # Ajout GA 03/10/2005
# interx
If [M:PBW4]APPFCY <> "" & [M:PBW4]APPFCY <> [M:PBW4]PSHFCY
    [M:PMG]ORIFCY(0)      = [M:PBW4]APPFCY
Else
    [M:PMG]ORIFCY(0)      = [M:PBW4]PSHFCY
Endif
[M:PMG]STOFCY(0)      = [M:PBW4]STOFCY
[M:PMG]PJT(0)         = [M:PBW4]PJT
[M:PMG]BPRNUM(0)      = [M:PBW4]BPSNUM
[M:PMG]ENDDAT(0)      = [M:PBW4]EXTRCPDAT
[M:PMG]STU(0)         = [M:PBW4]STU
[M:PMG]EXTSTUQTY(0)   = [M:PBW4]QTYSTU
[M:PMG]PUU(0)         = [M:PBW4]PUU
[M:PMG]EXTPUUQTY(0)   = [M:PBW4]QTYPUU
If [M:PMG]EXTPUUQTY(0) = 0 | ([M:PMG]POCNUM(0) = "" & [M:PMG]BPRNUM(0) = "" )
    Return
Endif
# Issue 107513/US10 by GA 08/2015 versionning
If dim([M:PMG]ECCVALMAJ(0))>0
    [M:PMG]ECCVALMAJ(0)=[M:PBW4]ECCVALMAJ
    [M:PMG]ECCVALMIN(0)=[M:PBW4]ECCVALMIN
Endif

# PE EOFZONSPE pour le traitement des zones spécifiques
GPOINT= "EOFZONSPE" : Gosub ENTREE From EXEFNC
#
# nécessaire pour voir le fichier trace ?
Call OUVRE_TRACE(mess(381,194,1)) From LECFIC

# Issue 85528 10/2012 cas particulier changt site de commande
If [M:PBW4]VCRTYP=36
   Gosub OPEN_FILES_SCO From SCOLIB
   Call UPD_POHFCY([M:PBW4]VCRNUM,[M:PBW4]VCRLIN,[M:PBW4]PSHFCY,WRET) From SCOAUTLIB
   If WRET
      [M:PBW4]PSHFCY = [F:SCO]POHFCY : Affzo [M:PBW4]PSHFCY
      GERR=1 : Return
   Endif
   # Issue 107513/US10 by GA 08/2015 versionning
   If [M:PMG]PRQDAT<[F:SCO]ORDDAT
      If dim([M:PMG]ECCVALMAJ(0))>0 & [M:PMG]ECCVALMAJ(0)<>""
         Read [SCI]SCI0=[M:PBW4]VCRNUM;[M:PBW4]VCRLIN : If fstat Raz [F:SCI] Endif
         # date for POF can not be < date EOF if  version is not available
         Raz GMESSAGE
         Call BOMCTRECC([M:PBW4]ITMREF,[M:PBW4]ECCVALMAJ,[M:PBW4]ECCVALMIN,"",0,[F:SCI]BOMALT,3,[M:PMG]PRQDAT) From TRTBOM
         If GMESSAGE<>""    # Version is not valid at this date ?
            GERR=1 : Return
         Endif
      Endif
   Endif
Endif
# FQ 54554 cas particulier changt fournisseur
# maj préalable de l'EO pour recherche de l'adresse Client livré, des délais, etc ...
If [M:PBW4]BPSNUM<>[M:PBW4]BPRNUM
    Raz [M:SCOK]
    Call ECR_TRACE("MAJ_EOF2POF: change BPRNUM from"-[M:PBW4]BPRNUM-"to"-[M:PBW4]BPSNUM,0) From GESECRAN
    [M:SCOK]CODMAJ = "M"
    [M:SCOK]SCONUM = [M:PBW4]VCRNUM
    [M:SCOK]SCILIN = [M:PBW4]VCRLIN
    [M:SCOK]BPRNUM = [M:PBW4]BPSNUM  # FQ 54554 cas particulier changt fournisseur
    [M:SCOK]POHFCY = [M:PBW4]PSHFCY
    [M:SCOK]STOFCY = [M:PBW4]PSHFCY
    [M:SCOK]PRHFCY = [M:PBW4]STOFCY
    [M:SCOK]SCOSTA = WSTA
    [M:SCOK]ITMREF = [M:PBW4]ITMREF
    [M:SCOK]PUU    = [M:PBW4]PUU
    #[M:SCOK]QTYPUU = [M:PBW4]QTYPUU
    #[M:SCOK]EXTQTY = [M:PBW4]QTYSTU
    [M:SCOK]PRVQTY = 0
    [M:SCOK]STRDAT = TODAY
    [M:SCOK]ENDDAT = [M:PBW4]EXTRCPDAT
    #[M:SCOK]BOMALT = [M:PBW4]BOMALT
    [M:SCOK]PJT    = [M:PBW4]PJT
    #[M:SCOK]LOT    = [M:PBW4]LOT
    [M:SCOK]OBJDAT = [M:PBW4]EXTRCPDAT
    Call MAJ_SCO From SCOAUTLIB
    If [M:SCOK]CODRET = 0  & GOK=1
        Local Char WMESS(250)
        WMESS = mess(641,197,1)-"["-mess(WSTA,317,1)-"]"-[M:SCOK]SCONUM-mess(232,197,1)
        Call ECR_TRACE(WMESS,0) From GESECRAN
    Else
        Local Char WMESS(250)
        WMESS = num$([M:SCOK]CODRET)-mess(50,176,1)-":"-mess(641,197,1)-"["-mess(WSTA,317,1)-"]"-[M:SCOK]SCONUM
        Call ECR_TRACE(WMESS,1) From GESECRAN
        Return
    Endif
Endif

Call MGT_PURCHASE From TRTACHMGT1
#
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

If [M:PMG]ERRCOD = 0
    # PE EDITSCF pour pouvoir lancer l'édition de la commande
    GPOINT= "EDITEOF" : Gosub ENTREE From EXEFNC
    #
    PARAM(9) = num$(2)
    Raz [M:PBW4]
    FIN = 1
    Return
Else
    Return
Endif
Return


#########################################################################
#                                                                       #
#      Traitements divers liés aux plans de travail   Achats            #
#                                                                       #
#########################################################################
$CHARGE_PBW1

Raz [M:PBW1]    # MM 02.04
# traitement ordre existant
Read [ORD1]ORD0=WTYP;WWIP;WITM
If fstat : Return : Endif

[M:PBW1] = [F:ORD1]
[M:PBW1]PSHFCY = [F:ORD1]ORIFCY
[M:PBW1]POHFCY = [F:ORD1]ORIFCY
[M:PBW1]APPHAB  = WAPPHAB
[M:PBW1]INTHAB  = WINTHAB

If [M:PBW1]MRPMES <> 0
    [M:PBW1]XMRPMES = mess([M:PBW1]MRPMES,318,1)
Endif

# libellé MM 02.04
If [F:FCY]FCY<>[F:ORD1]ORIFCY
    Read [FCY]FCY0=[F:ORD1]ORIFCY
    If fstat : Raz [F:FCY] : Endif
Endif
If dim([M:PBW1]ZPSHFCY)>0  [M:PBW1]ZPSHFCY=[F:FCY]FCYNAM  Endif
If [F:FCY]FCY<>[F:ORD1]STOFCY
    Read [FCY]FCY0=[F:ORD1]STOFCY
    If fstat : Raz [F:FCY] : Endif
Endif
If dim([M:PBW1]ZSTOFCY)>0 [M:PBW1]ZSTOFCY=[F:FCY]FCYNAM  Endif

# test origine POP
Case [F:ORD1]ABBFIL
    When "PSD" : # lecture entête DA
                 Read [PSH]PSH0 = [F:ORD1]VCRNUM
                 If fstat : Return : Endif
                 [M:PBW1]REQUSR = [F:PSH]REQUSR
                 # lecture ligne DA
                 Read [PSD]PSD0 = [F:ORD1]VCRNUM;[F:ORD1]VCRLIN
                 If fstat : Return : Endif

                 [M:PBW1]BPSNUM = [F:PSD]BPSNUM
                 [M:PBW1]QTYUOM = [F:PSD]QTYPUU    # 29397 mm 12.06
                 [M:PBW1]QTYSTU = [F:PSD]QTYSTU
                 [M:PBW1]UOM    = [F:PSD]PUU       # 29397 mm 12.06
                 [M:PBW1]ORDQTYPUU = [F:PSD]ORDQTYPUU
                 [M:PBW1]STU    = [F:PSD]STU
                 [M:PBW1]EXTRCPDAT = [F:PSD]EXTRCPDAT
                 [M:PBW1]LINAPPFLG = [F:PSD]LINAPPFLG
                 If [M:PBW1]LINAPPFLG = 0 : [M:PBW1]LINAPPFLG = 4 : Endif
                 [M:PBW1]XLINAPPFLG = mess([M:PBW1]LINAPPFLG, 280,1)
                 [M:PBW1]POHTYP   = 1
                 [M:PBW1]CODOBJ   = "PSH"
                 [M:PBW1]PSHFCY   = [F:PSD]PSHFCY
                 # FQ 59636 GA 11/2009 correction non reportée en V6 # 10.05 32291
                 [M:PBW1]QTYUOM -= [F:PSD]ORDQTYPUU
                 [M:PBW1]QTYSTU -= [F:PSD]ORDQTYSTU
    When "POC" : # lecture entête DL
                 Read [POH]POH0 = [F:ORD1]VCRNUM
                 If fstat : Return : Endif
                 [M:PBW1]REQUSR = [F:POH]BUY
                 # lecture ligne DL
                 Read [POQ]POQ0 = [F:ORD1]VCRNUM;[F:ORD1]VCRLIN;[F:ORD1]VCRSEQ
                 If fstat : Return : Endif

                 [M:PBW1]POCNUM = [F:POH]POHNUM
                 [M:PBW1]BPSNUM = [F:POQ]BPSNUM
                 [M:PBW1]QTYUOM = [F:POQ]QTYPUU         # 29397 mm 12.06
                 [M:PBW1]QTYSTU = [F:POQ]QTYSTU
                 [M:PBW1]UOM    = [F:POQ]PUU            # 29397 mm 12.06
                 [M:PBW1]USEPLC = [F:POQ]USEPLC
                 [M:PBW1]ORDQTYPUU = 0
                 [M:PBW1]STU    = [F:POQ]STU
                 [M:PBW1]EXTRCPDAT = [F:POQ]EXTRCPDAT
                 [M:PBW1]LINAPPFLG = [F:POH]APPFLG
                 If [M:PBW1]LINAPPFLG = 0 : [M:PBW1]LINAPPFLG = 4 : Endif
                 [M:PBW1]XLINAPPFLG = mess([M:PBW1]LINAPPFLG, 280,1)
                 [M:PBW1]POHTYP = 3
                 [M:PBW1]CODOBJ   = "POD"
                 [M:PBW1]PSHFCY   = [F:POQ]POHFCY
Endcase

# libellé MM 02.04
If [F:BPR]BPRNUM <>[M:PBW1]REQUSR
    Read [BPR]BPR0 = [M:PBW1]REQUSR
    If fstat : Raz [F:BPR] : Endif
Endif
If dim([M:PBW1]ZREQUSR)>0 [M:PBW1]ZREQUSR=[F:BPR]BPRNAM  Endif

# lecture article
If [F:ITM]ITMREF <> [M:PBW1]ITMREF
    Read [ITM]ITM0=[M:PBW1]ITMREF
    If fstat : Return : Endif
Endif
#If dim([M:PBW1]ZITMREF)>0  [M:PBW1]ZITMREF=[F:ITM]ITMDES1  Endif    # Libellé MM 02.04
If dim([M:PBW1]ZITMREF)>0
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PBW1]ZITMREF, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
Endif    # Libellé MM 02.04

# lecture article/site
If [F:ITF]ITMREF <> [M:PBW1]ITMREF | [F:ITF]STOFCY <> [M:PBW1]STOFCY
# If [F:ITF]ITMREF <> [M:PBW1]ITMREF : # GH 10/04/2015 bug 104152
    Read [ITF]ITF0=[M:PBW1]ITMREF;[M:PBW1]STOFCY
    If fstat : Return : Endif
Endif
[M:PBW1]STOMGTCOD = [F:ITF]STOMGTCOD

# interX
# dans tous les cas, on propose la liste des contrats
# GH 27/06/2012 bug 83199
#Filter [POC] Where ITMREF = [M:PBW1]ITMREF & PRHFCY = [M:PBW1]STOFCY & ENDDAT >= TODAY
# GH 31/01/2014 bug 95640
CRITERE = "ITMREF = [M:PBW1]ITMREF & PRHFCY = [M:PBW1]STOFCY"
If [M:PBW1]EXTRCPDAT <> [0/0/0]
   CRITERE+= "& ENDDAT >= [M:PBW1]EXTRCPDAT & STRDAT <= [M:PBW1]EXTRCPDAT"
Else
   CRITERE+= "& ENDDAT >= TODAY & STRDAT <= TODAY"
Endif
nolign = 1
For [POC]POC2 Where evalue(CRITERE)
    If nolign > dim([M:PBW1]SELIND) : Break : Endif
    Read [POH]POH0 = [F:POC]POHNUM
    If fstat : Goto NCW1 : Endif
    If !find([F:POH]APPFLG,3,4,5): Goto NCW1 : Endif
    If [F:POH]CLEFLG = 2         : Goto NCW1 : Endif
    [M:PBW1]SELIND(nolign-1) = 1
    [M:PBW1]POHNUM(nolign-1) = [F:POC]POHNUM
    [M:PBW1]BPSNUM2(nolign-1)= [F:POC]BPSNUM
    [M:PBW1]STRDAT(nolign-1) = [F:POC]STRDAT
    [M:PBW1]ENDDAT(nolign-1) = [F:POC]ENDDAT
    [M:PBW1]PUU2(nolign-1)   = [F:POC]PUU
    [M:PBW1]USEPLC2(nolign-1)= [F:POC]USEPLC
    [M:PBW1]PURFCY(nolign-1) = [F:POC]POHFCY
    If [M:PBW1]POHNUM(nolign-1) = [M:PBW1]POCNUM : [M:PBW1]SELIND(nolign-1) = 2 : Endif
    nolign += 1
$NCW1
Next

#20846 mm 11.05
[M:PBW1]STU2    = [M:PBW1]STU
[M:PBW1]EXTQTY1 = [M:PBW1]QTYSTU
[M:PBW1]EXTQTY2 = [M:PBW1]QTYSTU
[M:PBW1]STRDAT1 = [F:ORD1]STRDAT
[M:PBW1]ENDDAT1 = [M:PBW1]EXTRCPDAT
[M:PBW1]ENDDAT2 = [M:PBW1]EXTRCPDAT
#

# 106430 - Purchase planning
# UOM AND Currency defaults
[M:PBW1]TCTRWEU   = GSALDSPWEU
[M:PBW1]TCTRVOU   = GSALDSPVOU
[M:PBW1]TOTCUR    = GLOCALDEV

#Weights
[M:PBW1]ITMWEI    = [F:ITM]ITMWEI
[M:PBW1]WEU       = [F:ITM]WEU
[M:PBW1]WEITOT    = [F:ITM]ITMWEI * [M:PBW1]QTYSTU
If [M:PBW1]WEU<>[M:PBW1]TCTRWEU
  Call CONVERT_QTY([M:PBW1]WEU,[M:PBW1]TCTRWEU,[M:PBW1]WEITOT)From TRTX3
Endif
If [M:PBW1]WEICAP > 0 : [M:PBW1]WEIAVL = [M:PBW1]WEICAP-[M:PBW1]WEITOT : Endif

#Volumes
[M:PBW1]ITMVOL    = [F:ITM]ITMVOU
[M:PBW1]VOU       = [F:ITM]VOU
[M:PBW1]VOLTOT    = [F:ITM]ITMVOU * [M:PBW1]QTYSTU
If [M:PBW1]VOU<>[M:PBW1]TCTRVOU
  Call CONVERT_QTY([M:PBW1]VOU,[M:PBW1]TCTRVOU,[M:PBW1]VOLTOT)From TRTX3
Endif
If [M:PBW1]VOLCAP > 0 : [M:PBW1]VOLAVL = [M:PBW1]VOLCAP-[M:PBW1]VOLTOT : Endif

#Costs
If GSYSCUR <> GLOCALDEV
  Local Integer STAT
  Call CONVERT (GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,[M:PBW1]EXTRCPDAT,[F:ITM]PURBASPRI,[M:PBW1]PURBASPRI,STAT) From TRTDEV
Else
  [M:PBW1]PURBASPRI = [F:ITM]PURBASPRI
Endif
[M:PBW1]TOTCOST     = [M:PBW1]PURBASPRI * [M:PBW1]QTYSTU
Diszo [M:PBW1]TCTRQTY

# Issue 104943 - 2015-07-03 by BEEBE : Implementing Versioning
If dim([M:PBW1]ECCVALMAJ)>0
    [M:PBW1]ECCVALMAJ=[F:ORD1]ECCVALMAJ
    [M:PBW1]ECCVALMIN=[F:ORD1]ECCVALMIN
Endif
# Issue 107498/108 - 2016-05-20 by BEEBE : validation product/site/PJT whether it may/can be launched
# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
If func AFNC.ACTIV("PJM")
    Call VALIDPJT([M:PBW1]ITMREF,[M:PBW1]STOFCY,[F:ITM]STDFLG,[M:PBW1]PJT,WPJTLAUNCH) From MFGLIB
Endif

[M:PBW1]NBLIG = nolign - 1

Return

#########################################################################
$CHARGE_PBW3
Raz [M:PBW3]
[M:PBW3]STOFCY  = WFCY
[M:PBW3]PSHFCY  = GFCYDEF(6)
[M:PBW3]ITMREF  = WITM
[M:PBW3]PLANNER = WPLANNER
[M:PBW3]APPHAB  = WAPPHAB
[M:PBW3]INTHAB  = WINTHAB
[M:PBW3]PJT     = WPJT  # Issue 107498/108 - 2016-06-20 by ALSHE : load Project number to mask
[M:PBW3]QTYSTU  = WQTYSTU # Issue X3-4774 - 2016-10-11 by ALSHE : load mask with data from PJM
[M:PBW3]EXTRCPDAT = WEXTRCPDAT  # Issue X3-4774 - 2016-10-11 by ALSHE : load mask with data from PJM
# Issue 107498/18 - 2016-08-04 by ALSHE : load PJT Number
# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
# Issue 118199 30/08/2016 by GH - crashed when it was called from workbench planning
#If func AFNC.ACTIV("PJM")
#    If [M:PBW3]PJT = "" : [M:PBW3]PJT = [M:MGB]PJTSTR :  Endif
#Endif
If [M:PBW3]PJT = "" & find(GFONCTION,"FUNGBENCH","FUNGBENCHA","GESPJM") & func AFNC.ACTIV("PJM") # Issue X3-3996 - 2016-09-26 by ALSHE : Initialisation of PJT number when comming from project
# management
   [M:PBW3]PJT = [M:MGB]PJTSTR
Endif

# lecture article
If [F:ITM]ITMREF <> [M:PBW3]ITMREF
    Read [ITM]ITM0=[M:PBW3]ITMREF
    If fstat : Return : Endif
Endif
# lecture article/site
If [F:ITF]ITMREF <> [M:PBW3]ITMREF | [F:ITF]STOFCY <> [M:PBW3]STOFCY
# If [F:ITF]ITMREF <> [M:PBW3]ITMREF : # GH 10/04/2015 bug 104152
    Read [ITF]ITF0=[M:PBW3]ITMREF;[M:PBW3]STOFCY
    If fstat : Return : Endif
Endif
[M:PBW3]STOMGTCOD = [F:ITF]STOMGTCOD
[M:PBW3]STU    = [F:ITM]STU
[M:PBW3]PUU    = [F:ITM]PUU
[M:PBW3]CAD = 1

# recherche fournisseur

# Epic: 55934 (STLIG) - supplier initialisation
If ([M:PBW3]BPSNUM = "" & [M:PBW3]ITMREF <> "")
  Local Integer ITMBPS
  Call DEFBPSNUM([M:PBW3]ITMREF,"",[M:PBW3]PSHFCY,"",1,[M:PBW3]BPSNUM,ITMBPS) From TRTACHDEF1
  If (ITMBPS > 0)
    Read [ITP]ITP0=[M:PBW3]ITMREF;[M:PBW3]BPSNUM
    If (fstat)
      Raz [F:ITP]
    Else
      [M:PBW3]PUU = [F:ITP]PUU
    Endif
  Endif
Endif

If [M:PBW3]PUU = "" : [M:PBW3]PUU = [F:ITM]PUU : Endif    # 05.01 llc

  # ------------------------------------------
  # Issue X3-90988 - 2018-08-21 by FGR : BEGIN was missing after X3-4774
  Local Decimal WQTYSTUCONV

  If [M:PBW3]PUU = [M:PBW3]STU Then
    [M:PBW3]QTYPUU = WQTYSTU
  Else
    WQTYSTUCONV = WQTYSTU
    Call CONVERT_QTY([M:PBW3]STU, [M:PBW3]PUU, WQTYSTUCONV) From TRTX3
    [M:PBW3]QTYPUU = WQTYSTUCONV
  Endif
  # Issue X3-90988 - 2018-08-21 by FGR : END
  # ------------------------------------------

# VPO 10/02/11 71437 PE PWB3ZONSPE pour le traitement des zones spécifiques
GPOINT= "PBW3ZONSPE" : Gosub ENTREE From EXEFNC
Return

#########################################################################
$CHARGE_PBW4
Local Decimal WCOEUOM, WCOEFF_CDE
Local Char    WLEGCPY(GLONFCY)        # 05.05 30222
If WWIP=""  # Issue 103007 GA 09/2014 when [F]WIPNUM is lost
  Case [L]WTYP
    When 4
      If dim([M:MFG0]MFGNUM)>0 & [M:MFG0]MFGNUM<>""
        For [ORD1] Where VCRTYP=10 & VCRNUM=[M:MFG0]MFGNUM
&                     &  ITMREF=[L]WITM & WIPTYP=[L]WTYP
          WWIP=[F:ORD1]WIPNUM
          Break
        Next
      Endif
    When 13
      If dim([M:SCO0]SCONUM)>0 & [M:SCO0]SCONUM<>""
        For [ORD1] Where VCRTYP=36 & VCRNUM=[M:SCO0]SCONUM
&                     &  ITMREF=[L]WITM & WIPTYP=[L]WTYP
          WWIP=[F:ORD1]WIPNUM
          Break
        Next
      Endif
  Endcase
Endif
# traitement ordre existant
# SCx: si commande depuis OMFG ordre de fabrication    WTYP=4
# EOx: si commande depuis OSCO ordre de sous-traitance WTYP=13
Read [ORD1]ORD0=WTYP;WWIP;WITM
If fstat : Return : Endif

# FQ 57543 GA 09/2009 idem CHARGE_PBW3 il faut Raz tout le masque
# Raz [M:PBW4]BPSNUM                # 05.05
Raz [M:PBW4]
[M:PBW4]APPHAB  = WAPPHAB
[M:PBW4]INTHAB  = WINTHAB
[M:PBW4]PLANNER = WPLANNER
[M:PBW4] = [F:ORD1]
Case [F:ORD1]WIPSTA
    When 1,2: [M:PBW4]XVCRTYP = mess(WTYP, 306, 1)
    When 3  : [M:PBW4]XVCRTYP = mess([F:ORD1]VCRTYP, 701, 1)
Endcase

#--------------------
# 11.05 33075 (si TRS traitement spécial)
If [F:FCY]FCY<>[F:ORD1]STOFCY
    Read [FCY]FCY0=[F:ORD1]STOFCY
    If fstat : Raz [F:FCY] : Endif
Endif
If dim([M:PBW4]ZSTOFCY)>0 [M:PBW4]ZSTOFCY=[F:FCY]FCYNAM  Endif

If [F:ORD1]WIPTYP = 7 & [F:ORD1]WIPSTA = 3 : # TRS
    [M:PBW4]PSHFCY  = [F:ORD1]STOFCY
Elsif [F:ORD1]WIPTYP = 8
    # GH 25/07/2016 bug 113721 -The purchase site should be the TP receipt site instead of the purchase site from which the TP was generated
    [M:PBW4]PSHFCY  = [F:ORD1]STOFCY
Else
    [M:PBW4]PSHFCY  = [F:ORD1]ORIFCY
    If [F:FCY]FCY<>[F:ORD1]ORIFCY
        Read [FCY]FCY0=[F:ORD1]ORIFCY
        If fstat : Raz [F:FCY] : Endif
    Endif
Endif

If GFCYDEF(6) <> ""
    WLEGCPY = [F:FCY]LEGCPY
    If [F:FCY]FCY <> [M:PBW4]PSHFCY
        Read [FCY]FCY0=[M:PBW4]PSHFCY
        If fstat : Raz [F:FCY] : Endif
    Endif
Else
    WLEGCPY = [F:FCY]LEGCPY
Endif

# si ORIFCY non site achat ou société différente on prend site d'achat par défaut sinon 1er site d'achat de la société
If [F:FCY]PURFLG <> 2 | [F:FCY]LEGCPY <> WLEGCPY
    If GFCYDEF(6) <> "" & [F:FCY]LEGCPY = WLEGCPY
        [M:PBW4]PSHFCY = GFCYDEF(6)
    Else
        WLEGCPY = [F:FCY]LEGCPY
        Filter [FCY] Where LEGCPY = WLEGCPY & PURFLG = 2
        Read [FCY] First
        If !fstat : [M:PBW4]PSHFCY = [F:FCY]FCY : Else : Raz [M:PBW4]PSHFCY : Endif    # 36152 mm 05.06
        Filter [FCY]
    Endif
Endif
If [F:FCY]PURFLG <> 2 : [M:PBW4]PSHFCY = GFCYDEF(6) : Endif

# Issue 81519 GA 04/2012
GFCY=[M:PBW4]PSHFCY
Gosub CHARG_PARAM

#------------------------

If [F:BPR]BPRNUM <>[F:ORD1]BPRNUM
    Read [BPR]BPR0 = [F:ORD1]BPRNUM
    If fstat : Raz [F:BPR] : Endif
Endif
If dim([M:PBW4]ZBPRNUM)>0 [M:PBW4]ZBPRNUM=[F:BPR]BPRNAM  Endif

# [M:PBW4]QTYSTU = [F:ORD1]RMNEXTQTY - [F:ORD1]MTOQTY - [F:ORD1]ALLQTY : # GH 05/09/2013 bug 92354
[M:PBW4]QTYSTU = [F:ORD1]RMNEXTQTY - [F:ORD1]ALLQTY
If [M:PBW4]QTYSTU < 0 : [M:PBW4]QTYSTU = 0 : Endif

WQTYPRV        = [F:ORD1]RMNEXTQTY : # GH 03/06/2014 bug 100026 # [F:ORD1]EXTQTY
WVCRNUM        = [F:ORD1]VCRNUM
WITMREF        = [M:PBW4]ITMREF
WWIPNUM        = [F:ORD1]WIPNUM                        # 03.06 35440

# lecture article
If [F:ITM]ITMREF <> WITMREF
    Read [ITM]ITM0=WITMREF
    If fstat : Return : Endif
Endif
#If dim([M:PBW4]ZITMREF)>0  [M:PBW4]ZITMREF=[F:ITM]ITMDES1  Endif    # Libellé MM 02.04
If dim([M:PBW4]ZITMREF)>0
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PBW4]ZITMREF, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
Endif    # Libellé MM 02.04

# lecture article/site
If [F:ITF]ITMREF <> WITMREF | [F:ITF]STOFCY <> [M:PBW4]STOFCY
#If [F:ITF]ITMREF <> WITMREF : # GH 10/04/2015 bug 104152
    Read [ITF]ITF0=WITMREF;[M:PBW4]STOFCY
    If fstat : Raz [F:ITF] : Endif        # 42792 mm 03.08
Endif

# Issue 104943 - 2015-07-03 by BEEBE : Implementing Versioning
If dim([M:PBW4]ECCVALMAJ)>0
    [M:PBW4]ECCVALMAJ=[F:ORD1]ECCVALMAJ
    [M:PBW4]ECCVALMIN=[F:ORD1]ECCVALMIN
Endif

# Issue 107498/108 - 2016-05-20 by BEEBE : validation product/site/PJT whether it may/can be launched
# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
If func AFNC.ACTIV("PJM")
    Call VALIDPJT([M:PBW4]ITMREF,[M:PBW4]STOFCY,[F:ITM]STDFLG,[M:PBW4]PJT,WPJTLAUNCH) From MFGLIB
Endif
# Issue 115348 - 2016-07-27 by YARAM : Used funprog LTI_GET_EXTRCPDAT to calculate WOFS & EXTRCPDAT
# So as to add price list lead time to the calculation.
[M:PBW4]EXTRCPDAT = func LTI_GET_EXTRCPDAT(WOFS, [F:ITM]OFS, [F:ITF]OFS, [F:ORD1]ENDDAT, WITMREF)

[M:PBW4]STOMGTCOD = [F:ITF]STOMGTCOD

[M:PBW4]PUU = [F:ITM]PUU
[M:PBW4]STU = [F:ITM]STU
WCOEUOM     = [F:ITM]PUUSTUCOE # Issue 80045 Suite FQ 74274 GA 02/2012

# Issue 89563 GA 05/2013 code simplifié cf + bas
#If WCOEUOM<>0  # Issue 80045 GA 02/2012
#   [M:PBW4]QTYPUU = [M:PBW4]QTYSTU / WCOEUOM
#   Call QTEARR([M:PBW4]QTYPUU,[M:PBW4]PUU) From TRTDIV
#Else
#   Call PCAL_QTY ([M:PBW4]QTYSTU, [M:PBW4]STU, [M:PBW4]QTYPUU, [M:PBW4]PUU,
#&                  WITMREF, [M:PBW4]BPSNUM, 1, WCOEUOM) From TRTACHQTE1
#Endif

# recherche fournisseur
# 11.05 33075 (si TRS, recherche fournisseur = ORIFCY)
If [F:ORD1]WIPTYP = 7 & [F:ORD1]WIPSTA = 3
    Filter [BPR] Where BETFCY = 2 & FCY = [F:ORD1]ORIFCY
&                Order By Key BPR2
    For [BPR]
        # lecture fournisseur
        Read [BPS] BPS0=[F:BPR]BPRNUM
        If fstat : Raz [F:BPS] : Endif
        [M:PBW4]BPSNUM = [F:BPR]BPRNUM
        Break
    Next
    Filter [BPR]
Else
    # Issue 89886 Suite GA 03/2014 à faire sur toutes les suggestions provenant d'une cde de vente
    #If [F:ORD1]WIPTYP = 2 & [F:ORD1]WIPSTA = 3          # 08.05 31804 + 01.06 34344
    If find([F:ORD1]WIPTYP,2,4,5,13) & [F:ORD1]WIPSTA = 3
        [M:PBW4]BPSNUM = [F:ORD1]BPRNUM
        If [M:PBW4]BPSNUM <>""
            # 35681 mm 01.07 - le tiers est-il un fournisseur ?
            Read [BPS] BPS0=[M:PBW4]BPSNUM
            If fstat : Raz [F:BPS],[M:PBW4]BPSNUM  : Endif
        Endif
        # Issue 89886 GA 10/2013 POS => POF, garder la réf de la SOF à l'origine de la suggestion
        If [F:ORD1]VCRTYPORI=2
           [M:PBW4]VCRTYP = [F:ORD1]VCRTYPORI
           [M:PBW4]VCRNUM = [F:ORD1]VCRNUMORI
           [M:PBW4]VCRLIN = [F:ORD1]VCRLINORI
           [M:PBW4]VCRSEQ = [F:ORD1]VCRSEQORI
        Endif
    Endif
    If find([F:ORD1]WIPTYP,4,13) & [F:ORD1]WIPSTA<>3 : [M:PBW4]BPSNUM = [F:ORD1]BPRNUM : Endif                # 02.05 28818 + 01.06 34344

    # Epic: 55934 (STLIG)
    If ([M:PBW4]BPSNUM <> "")
      Read [ITP]ITP0=WITMREF;[M:PBW4]BPSNUM
      If (fstat)
        Raz [F:ITP]
      Else
        [M:PBW4]PUU = [F:ITP]PUU
        WCOEUOM     = [F:ITP]PUUSTUCOE
      Endif
    Endif

    # Epic: 55934 (STLIG) - supplier initialisation
    If ([M:PBW4]BPSNUM = "")
      Local Integer ITMBPS
      Call DEFBPSNUM(WITMREF,"",[M:PBW4]PSHFCY,"",1,[M:PBW4]BPSNUM,ITMBPS) From TRTACHDEF1
      If (ITMBPS > 0)
        Read [ITP]ITP0=WITMREF;[M:PBW4]BPSNUM
        If (fstat)
          Raz [F:ITP]
        Else
          [M:PBW4]PUU = [F:ITP]PUU
          WCOEUOM     = [F:ITP]PUUSTUCOE
        Endif
      Endif
    Endif

Endif

# Issue 89563 GA 05/2013 code simplifié
If WCOEUOM<>0  # Issue 80045 GA 02/2012
  [M:PBW4]QTYPUU = [M:PBW4]QTYSTU / WCOEUOM
  Call QTEARR([M:PBW4]QTYPUU,[M:PBW4]PUU) From TRTDIV
Else
  Call PCAL_QTY ([M:PBW4]QTYSTU, [M:PBW4]STU, [M:PBW4]QTYPUU, [M:PBW4]PUU,
&                WITMREF, [M:PBW4]BPSNUM, 1, WCOEUOM) From TRTACHQTE1
Endif

If [M:PBW4]BPSNUM <> ""
    # Issue 81519 GA 04/2012 tarif en devise
    If [M:PBW4]BPSNUM=[F:BPS]BPSNUM & [F:BPS]CUR<>"" GCUR = [F:BPS]CUR Endif

    Case [F:ORD1]VCRTYP
      When 10 :
          If !clalev([F:MFO]) Local File MFGOPE  [MFO] Endif
          For [MFO]MFO0 Where MFGNUM = [F:ORD1]VCRNUM & WIPNUM = [F:ORD1]WIPNUM
              # Issue 89563 GA 05/2013 Raz 80831 If [M:PBW4]STU<>[F:MFO]OPEUOM
              # Issue 80831 GA 03/2012 avant [M:PBW4]STU=[F:MFO]OPEUOM, ne pas écraser si déjà ok
              If [M:PBW4]STU=[F:MFO]OPEUOM
                 [M:PBW4]QTYSTU = [F:ORD1]RMNEXTQTY                      # FQ 77512 avant * [F:MFO]OPESTUCOE
                 Call QTEARR([M:PBW4]QTYSTU,[M:PBW4]STU) From TRTDIV
              Endif
              # Issue 89563 GA 05/2013 Raz 80831 If [M:PBW4]STU<>[F:MFO]OPEUOM
              # Issue 80831 GA 03/2012 avant [M:PBW4]PUU=[F:MFO]SCOPUU, ne pas écraser si déjà ok
              If [M:PBW4]PUU=[F:MFO]SCOPUU & WCOEUOM<>0  # Issue 80045 GA 02/2012
                 [M:PBW4]QTYPUU = [F:ORD1]RMNEXTQTY / WCOEUOM
                 Call QTEARR([M:PBW4]QTYPUU,[M:PBW4]PUU) From TRTDIV
              Endif
              Break
          Next
      When 36 :
        # Issue 94215 & 88046 GA 12/2013 pas de changt de fournisseur, sauf si EOS
        # FQ 60084 GA 11/2009 si commande sous-traitance partielle déjà réalisée, pas de changt de fournisseur
        #If [F:ORD1]RMNEXTQTY <> [F:ORD1]EXTQTY   Grizo [M:PBW4]BPSNUM Endif
        If [F:ORD1]WIPSTA<>3 Grizo [M:PBW4]BPSNUM Endif
        If [F:ORD1]WIPTYP=4
            # FQ 77413 GA 11/2011 idem OF on garde SCOPUU indiquée sur l'EO
            If !clalev([F:SCS]) Local File SCOSRV  [SCS] Endif
            For [SCS]SCS0 Where SCONUM = [F:ORD1]VCRNUM & WIPNUM = [F:ORD1]WIPNUM
              # Issue 80831 GA 03/2012 avant [M:PBW4]PUU=[F:SCS]SCOPUU, ne pas écraser si déjà ok
                If [M:PBW4]PUU<>[F:SCS]SCOPUU & [F:SCS]OPESTRCOE<>0
                   [M:PBW4]QTYPUU = [F:ORD1]RMNEXTQTY * [F:SCS]OPESTRCOE
                   Call QTEARR([M:PBW4]QTYPUU,[M:PBW4]PUU) From TRTDIV
                Endif
              # Issue 80831 GA 03/2012 avant [M:PBW4]STU=[F:SCS]OPESTU, ne pas écraser si déjà ok
                If [M:PBW4]STU<>[F:SCS]OPESTU
                   [M:PBW4]QTYSTU = [F:ORD1]RMNEXTQTY
                   Call QTEARR([M:PBW4]QTYSTU,[M:PBW4]STU) From TRTDIV
                Endif
                Break
            Next
         Elsif [F:ORD1]WIPTYP=13
         Endif

    Endcase

Endif
Affzo [M:PBW4]PUU,STU,QTYSTU,QTYPUU

# 106430 - Purchase planning
# UOM AND Currency defaults
[M:PBW4]TCTRWEU   = GSALDSPWEU
[M:PBW4]TCTRVOU   = GSALDSPVOU
[M:PBW4]TOTCUR    = GLOCALDEV

#Weights
[M:PBW4]ITMWEI    = [F:ITM]ITMWEI
[M:PBW4]WEU       = [F:ITM]WEU
[M:PBW4]WEITOT    = [F:ITM]ITMWEI * [M:PBW4]QTYSTU
If [M:PBW4]WEU<>[M:PBW4]TCTRWEU
  Call CONVERT_QTY([M:PBW4]WEU,[M:PBW4]TCTRWEU,[M:PBW4]WEITOT)From TRTX3
Endif
If [M:PBW4]WEICAP > 0 : [M:PBW4]WEIAVL = [M:PBW4]WEICAP-[M:PBW4]WEITOT : Endif

#Volumes
[M:PBW4]ITMVOL    = [F:ITM]ITMVOU
[M:PBW4]VOU       = [F:ITM]VOU
[M:PBW4]VOLTOT    = [F:ITM]ITMVOU * [M:PBW4]QTYSTU
If [M:PBW4]VOU<>[M:PBW4]TCTRVOU
  Call CONVERT_QTY([M:PBW4]VOU,[M:PBW4]TCTRVOU,[M:PBW4]VOLTOT)From TRTX3
Endif
If [M:PBW4]VOLCAP > 0 : [M:PBW4]VOLAVL = [M:PBW4]VOLCAP-[M:PBW4]VOLTOT : Endif

#Costs
If GSYSCUR <> GLOCALDEV
  Local Integer STAT
  Call CONVERT (GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,[M:PBW4]EXTRCPDAT,[F:ITM]PURBASPRI,[M:PBW4]PURBASPRI,STAT) From TRTDEV
Else
  [M:PBW4]PURBASPRI = [F:ITM]PURBASPRI
Endif
[M:PBW4]TOTCOST     = [M:PBW4]PURBASPRI * [M:PBW4]QTYSTU
Diszo [M:PBW4]TCTRQTY

# Demande PE 36471 06.06 mm
# Permettre de filter les contrats selon d'autres critères que les critères std
# mettre GPE=0 pour court-circuiter l'action standard
GPE=1
Raz CRITERE
GPOINT ="FILTCONT"
Gosub ENTREE From EXEFNC
If GPE <>0
    # GH 27/06/2012 bug 83199
    # CRITERE = "ITMREF = [M:PBW4]ITMREF & PRHFCY = [M:PBW4]STOFCY & ENDDAT >= TODAY"
    # CRITERE = "ITMREF = [M:PBW4]ITMREF & PRHFCY = [M:PBW4]STOFCY & ENDDAT >= TODAY & STRDAT <= TODAY"
    # GH 31/01/2014 bug 95640
    CRITERE = "ITMREF = [M:PBW4]ITMREF & PRHFCY = [M:PBW4]STOFCY"
    If [M:PBW4]EXTRCPDAT <> [0/0/0]
      CRITERE+= "& ENDDAT >= [M:PBW4]EXTRCPDAT & STRDAT <= [M:PBW4]EXTRCPDAT"
    Else
      CRITERE+= "& ENDDAT >= TODAY & STRDAT <= TODAY"
    Endif
Elsif CRITERE=""
    CRITERE = "1=1"
Endif

# dans tous les cas, on propose la liste des contrats
nolign = 1
For [POC]POC2 Where evalue(CRITERE)
    If nolign > dim([M:PBW4]SELIND) : Break : Endif
    Read [POH]POH0 = [F:POC]POHNUM
    If fstat : Goto NCW4 : Endif
    If !find([F:POH]APPFLG,3,4,5): Goto NCW4 : Endif
    If [F:POH]CLEFLG = 2         : Goto NCW4 : Endif
    [M:PBW4]SELIND(nolign-1) = 1
    [M:PBW4]POHNUM(nolign-1) = [F:POC]POHNUM
    [M:PBW4]BPSNUM2(nolign-1)= [F:POC]BPSNUM
    [M:PBW4]STRDAT(nolign-1) = [F:POC]STRDAT
    [M:PBW4]ENDDAT(nolign-1) = [F:POC]ENDDAT
    [M:PBW4]PUU2(nolign-1)   = [F:POC]PUU
    [M:PBW4]USEPLC2(nolign-1)= [F:POC]USEPLC
    [M:PBW4]PURFCY(nolign-1) = [F:POC]POHFCY
    nolign += 1
$NCW4
Next
[M:PBW4]NBLIG = nolign - 1

Return

#########################################################################
$CHARGE_PBW5
# traitement ordre existant
Read [ORD1]ORD0=WTYP;WWIP;WITM
If fstat : Return : Endif

# FQ 57543 GA 09/2009 idem CHARGE_PBW3 il faut Raz tout le masque
Raz [M:PBW5]

[M:PBW5] = [F:ORD1]
[M:PBW5]POHFCY = [F:ORD1]ORIFCY

# 20846 mm 11.05
If [M:PBW5]MRPMES <> 0
    [M:PBW5]XMRPMES = mess([M:PBW5]MRPMES,318,1)
Endif
#

Read [FCY]FCY0 = [M:PBW5]POHFCY
If fstat : Raz [F:FCY] : Endif
[M:PBW5]FCYDES = [F:FCY]FCYNAM
# Libellé MM 02.04
Read [FCY]FCY0 = [M:PBW5]STOFCY
If fstat : Raz [F:FCY] : Endif
If dim([M:PBW5]ZSTOFCY)>0 [M:PBW5]ZSTOFCY=[F:FCY]FCYNAM  Endif
#

Read [POH]POH0 = [F:ORD1]VCRNUM
If fstat : Return : Endif

[M:PBW5]BUY     = [F:POH]BUY
[M:PBW5]POHFCY =  [F:POH]POHFCY
# lecture ligne DL
Read [POQ]POQ0 = [F:ORD1]VCRNUM;[F:ORD1]VCRLIN;[F:ORD1]VCRSEQ
If fstat : Return : Endif

[M:PBW5]BPSNUM = [F:POQ]BPSNUM
[M:PBW5]QTYPUU = [F:POQ]QTYPUU
[M:PBW5]QTYSTU = [F:POQ]QTYSTU
[M:PBW5]PUU    = [F:POQ]PUU
[M:PBW5]RCPQTYPUU = [F:POQ]RCPQTYPUU
[M:PBW5]STU    = [F:POQ]STU
# 20846 mm 11.05
[M:PBW5]EXTQTY1  = [F:POQ]QTYSTU
[M:PBW5]EXTQTY2  = [F:POQ]QTYSTU
[M:PBW5]STU2     = [F:POQ]STU
[M:PBW5]STRDAT1  = [F:POQ]ORDDAT
[M:PBW5]ENDDAT1  = [F:POQ]EXTRCPDAT
[M:PBW5]ENDDAT2  = [F:POQ]EXTRCPDAT
#
[M:PBW5]USEPLC = [F:POQ]USEPLC
[M:PBW5]EXTRCPDAT = [F:POQ]EXTRCPDAT
[M:PBW5]CAD = 1


Case [F:POH]POHTYP
    When 2:         [M:PBW5]LINAPPFLG = 4
                    [M:PBW5]XLINAPPFLG = mess([M:PBW5]LINAPPFLG, 280,1)
                    [M:PBW5]RCPFLG  = [F:POH]RCPFLG # Issue 75668 - 2011-08-19 by SR
                    [M:PBW5]XRCPFLG = ""
                    [M:PBW5]INVFLG  = [F:POH]INVFLG # Issue 75668 - 2011-08-19 by SR
                    [M:PBW5]XINVFLG = ""
                    [M:PBW5]POCNUM = [F:POH]POHNUM
                    [M:PBW5]POHTYP = 3
                    Diszo [M:PBW5]PJT
                    Grizo [M:PBW5]XLINAPPFLG
                    Grizo [M:PBW5]XRCPFLG
                    Grizo [M:PBW5]XINVFLG
    When Default:   [M:PBW5]LINAPPFLG = [F:POH]APPFLG
                    [M:PBW5]POHTYP = 2
                    If [M:PBW5]LINAPPFLG = 0 : [M:PBW5]LINAPPFLG = 4 : Endif
                    [M:PBW5]XLINAPPFLG = mess([M:PBW5]LINAPPFLG, 280,1)
                    [M:PBW5]RCPFLG  = [F:POH]RCPFLG
                    [M:PBW5]XRCPFLG = mess([M:PBW5]RCPFLG, 280,1)
                    [M:PBW5]INVFLG  = [F:POH]INVFLG
                    [M:PBW5]XINVFLG = mess([M:PBW5]INVFLG, 280,1)
Endcase


# lecture article
If [F:ITM]ITMREF <> [M:PBW5]ITMREF
    Read [ITM]ITM0=[M:PBW5]ITMREF
    If fstat : Return : Endif
Endif
# lecture article/site
If [F:ITF]ITMREF <> [M:PBW5]ITMREF | [F:ITF]STOFCY <> [M:PBW5]STOFCY
# If [F:ITF]ITMREF <> [M:PBW5]ITMREF : # GH 10/04/2015 bug 104152
    Read [ITF]ITF0=[M:PBW5]ITMREF;[M:PBW5]STOFCY
    If fstat : Return : Endif
Endif
[M:PBW5]STOMGTCOD = [F:ITF]STOMGTCOD

# Issue 104943 - 2015-07-03 by BEEBE : Implementing Versioning
If dim([M:PBW5]ECCVALMAJ)>0
    [M:PBW5]ECCVALMAJ=[F:POQ]ECCVALMAJ
    [M:PBW5]ECCVALMIN=[F:POQ]ECCVALMIN
Endif

Return


########################################################################
# vérif encours
$CHECK_WIP
If dim(WRET)<0 : Local Integer WRET : Endif          # Ctrl des sources
Call CHECK_WIP(WTYP, WITM, WWIP, WQTYPRV, C_QTY, WRET) From MFGLIB
If !WRET : Return : Endif

If [F:ITM]ITMREF  <> WITM
    Read [ITM]ITM0=WITM
    If fstat : Raz [F:ITM] : Endif
Endif
If find(WTYP,2,5)
    GMESSAGE  = mess(220,193,1)
Else
    GMESSAGE  = mess(222,193,1)
Endif
GMESSAGE -= "("+num$(C_QTY)-[F:ITM]STU+")"+"\"+mess(221,193,1)

Return

########################################################################
$CHARGE_WRCPDAT
Local    Shortint   WJOUR ,WMOIS ,WANNEE
Local    Char       WDATE(10)


# chargement zone wrcpdat
WANNEE = val(left$([M]EXTRCPDAT,4))
WMOIS  = val(mid$([M]EXTRCPDAT,5,2))
WJOUR  = val(right$([M]EXTRCPDAT,7))

If [M]CAD = 1           : # cadencement jour
     Gosub DAT8
     [M]WRCPDAT     = WDATE
     [M]STRRCPDAT   = [M]EXTRCPDAT
Elsif [M]CAD = 3        : # cadencement mois
      [M]STRRCPDAT  = aweek([M]WEE,[M]YEA)
      Local Char WWMOIS(2)
      If len(num$(WMOIS))= 1
          WWMOIS = "0"+num$(WMOIS)
      Else  WWMOIS = num$(WMOIS)
      Endif
      WDATE= format$("K:2#[-]4#",WWMOIS+num$(WANNEE))
      [M]WRCPDAT = WDATE
Else                    : # cadencement semaine
    [M]STRRCPDAT = aweek([M]WEE,[M]YEA)
    Local Char WSEM(2)
    If len(num$([M]WEE))= 1
          WSEM = "00"+num$([M]WEE)
    Elsif len(num$([M]WEE))= 2
          WSEM = "0"+num$([M]WEE)
    Else  WSEM = num$([M]WEE)
    Endif
    WDATE= format$("K:3#[-]4#",WSEM+num$([M]YEA))
    [M]WRCPDAT = WDATE
Endif

Return

########################################################################
$DAT8
Local Char WWJOUR(2) ,WWMOIS(2) ,WWANNEE(4)
If len(num$(WJOUR)) = 1
             WWJOUR= "0"+num$(WJOUR)
Else         WWJOUR = num$(WJOUR)
Endif
If len(num$(WMOIS)) = 1
       WWMOIS = "0"+num$(WMOIS)
Else   WWMOIS = num$(WMOIS)
Endif
WWANNEE = num$(WANNEE)
WDATE=format$("D:"+GFMDAT4,gdat$(val(WWJOUR),val(WWMOIS),val(WWANNEE)))
Return

#######################################################################
# Sous programme de sélection contrat
#######################################################################
Subprog SELCONT(LFCY, LITM, LVCR, LLIN, LDAT)
Value    Char     LFCY
Value    Char     LITM
Variable Char     LVCR
Variable Integer  LLIN
Value    Date     LDAT

Local Integer     REPONSE, I
Local Integer     WBOU(1..GNBBOU), WGOBJET

WOBJET=GOBJET : Call SAVBOUT From GESECRAN
GOBJET=0

If clalev ([F:POC]) <= 0 : Local File PORDERC    [POC] : Endif
If clalev ([F:POH]) <= 0 : Local File PORDER     [POH] : Endif

Local Mask SELCONT [SLCO]
Local Dlgbox Mask [SLCO]
& Button mess(64,123,1), mess(65,123,1)
& With left$(mess(64,123,1),1), left$(mess(65,123,1),1)
& Coded GSTAOK, GSTAFIN
& Titled mess(215,195,1) As [SLCO]
#
Boxact [SLCO]
#
If LDAT=[0/0/0] : LDAT=date$ : Endif                               : ## GH 11/01/13 bug 87167
#Filter [POC] Where ITMREF = LITM & PRHFCY = LFCY & ENDDAT >= LDAT : ## GH 27/06/12 bug 83199
Filter [POC] Where ITMREF = LITM & PRHFCY = LFCY & ENDDAT >= LDAT & STRDAT <= LDAT
nolign = 1
For [POC]POC2                                        # llc 05.02 14394 Performances
    If nolign > 9 : Break : Endif
    Read [POH]POH0 = [F:POC]POHNUM
    If fstat : Goto N_POC : Endif
    If !find([F:POH]APPFLG,3,4,5): Goto N_POC : Endif
    If [F:POH]CLEFLG = 2         : Goto N_POC : Endif
    [M:SLCO] = [F:POC]
    nolign += 1
N_POC
Next
Filter [POC]

[M:SLCO]NBLIG = nolign - 1

If [M:SLCO]NBLIG <> 0 : [M:SLCO]SELIND(0) = 2 : Endif

For I = 1 To GNBBOU
  WBOU(I) = 0
Next I
WBOU(GVALI) = 1
WBOU(GABAN) = 1
Call SETBOUT(WBOU) From GESECRAN

$SAISLCO
Affzo  [M:SLCO]
Boxinp [SLCO] Using REPONSE
Case REPONSE
   When GSTAOK,GSTARET : For I = 0 To [M:SLCO]NBLIG - 1
                             If [M:SLCO]SELIND(I) = 2 : Break : Endif
                         Next I
                         LVCR = [M:SLCO]POHNUM(I)
                         LLIN = [M:SLCO]POPLIN(I)
                         Goto FINSLCO
   When GSTAESC,GSTAFIN: Goto FINSLCO
   When Default :        Goto SAISLCO
Endcase
#
$FINSLCO
Boxclr [SLCO]
Close Local Mask [SLCO]
GOBJET=WGOBJET
Call RESTBOUT From GESECRAN

End

#######################################################################
# Sous programme de suppression POS
#######################################################################
Subprog SUPPRIME_POS(LWIPTYP, LWIPNUM, LITMREF)
Value Integer LWIPTYP
Value Char    LWIPNUM
Value Char    LITMREF

Call DEBTRANS From GLOCK
## GH 06/08/2014 bug 101679

$TR_SUPPOS
GOK=1
Trbegin ADOVAL
  Raz [M:ORDK]
  [M:ORDK]MAJCOD    = "A"
  [M:ORDK]WIPTYP    = LWIPTYP
  [M:ORDK]WIPNUM    = LWIPNUM
  [M:ORDK]ITMREF    = LITMREF
  Call WIP From TRTWIP
  If GOK<=0
     Rollback
     If GOK<0
        Call ROLL From GLOCK
        If !GROLL : Goto TR_SUPPOS : Endif
     Endif
     End
  Endif
Commit
End

########################################################################
Funprog ISINTERCPY(LFCY1, LFCY2)
Value    Char LFCY1
Value    Char LFCY2

Local Char    WSOC1(GLONCPY)
Local Integer LRET : LRET = 0

If clalev ([F:FCY]) <= 0 : Local File FACILITY   [FCY] : Endif
If [F:FCY]FCY <> LFCY1
    Read [FCY]FCY0=LFCY1
    If fstat : Raz [F:FCY] : Endif
Endif
WSOC1 = [F:FCY]LEGCPY

Read [FCY]FCY0=LFCY2
If fstat : Raz [F:FCY] : Endif

If [F:FCY]LEGCPY <> WSOC1  : LRET = 1 : Endif

End LRET

########################################################################
# Issue 81519 GA 04/2012 tarif en devise, achats de sous-traitance
########################################################################
$CHARG_PARAM
If GMODU(1) = 2  # Dossier avec module comptabilité
  Call GLOBVAR(GFCY)  From WWGLOBCPT
  #----- Chargement des globales référentiels, comptes et sections de la société -----#
  Call GETCPY(GFCY,"",9,"") From TRTX3CPT
Endif
If GMODU(6) = 2  # Dossier avec module Achats
  Call GLOBVAR(GFCY)    From WWGLOBACH
Endif
Raz GMESSAGE

Return

#**---------------------------------------------------------------------<br/>
#* Issue 115348 - 2016-07-27 by YARAM
#* LTI_GET_EXTRCPDAT : New funprog to calculate lead time(WOFS) and expected rcpt. date(EXTRCPDAT)
#* So as to add price list lead time to the calculation.
#**<br/>----------------------------------------------------------------<br/>
#* @param WOFS = local variable for OFS (lead time)
#* @param WITMOFS = product lead time
#* @param WITFOFS = product site lead time
#* @param WORDENDDAT = work order end date
#* @param WITMREF = product
#*
#* @Return value = Expected receive date
#**<br/>----------------------------------------------------------------
#*!
Funprog LTI_GET_EXTRCPDAT(WOFS, WITMOFS, WITFOFS, WORDENDDAT, WITMREF)
Variable Integer WOFS
Value Integer WITMOFS
Value Decimal WITFOFS
Value Date WORDENDDAT
Value Char WITMREF

Local Date WEXTRCPDAT : WEXTRCPDAT = WORDENDDAT

If !clalev([F:PPL1]) : Local File PPRICLIST  [PPL1] : Endif
Filter [PPL1] Where PLICRI2 = WITMREF Order By Key PPL0
Read [PPL1] First
If [F:PPL1]LTI <> 0
  WOFS = [F:PPL1]LTI
Else
  If WITFOFS <> 0 : WOFS = WITFOFS : Else : WOFS = WITMOFS : Endif
Endif
Filter [PPL1]

Case GEXTRCPDAT
    When 1:    If WORDENDDAT >= date$
                   WEXTRCPDAT = WORDENDDAT
               Else
                  WEXTRCPDAT = date$
               Endif
    When 2:    If WORDENDDAT >= date$ + WOFS
                   WEXTRCPDAT = WORDENDDAT
               Else
                   WEXTRCPDAT = date$ + WOFS
               Endif
    When Default: WEXTRCPDAT = date$
Endcase
End WEXTRCPDAT

