#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
# SQUOTL : Liste des devis de ventes détail                             #
# --------------------------------------------------------------------- #
# Chargement et gestion paramètres (filtre représentant et mémo)        #
#      Etat SQUOTL   : Liste des devis de ventes détail                 #
#########################################################################

$ACTION
Case ACTION
  When "OUVRE"   : Gosub OUVRE2
  When "INIPAR"  : Gosub INIPAR
  When "INIPAR2" : Gosub INIPAR
  When "CONT1"   : Gosub CONT1
  When "MEMO"    : Gosub MEMO
Endcase
Return

######################################################################

$OUVRE2
GBIDI2=find("REP",[M:RPT]PARTYP)
If GBIDI2
  If GAUSCRMF<>"" & GAUSCRMA=2 & (dim(GAUSCRMROL)<1 | (dim(GAUSCRMROL)>0 & GAUSCRMROL<>1))
    [M:RPT]VALEUR1(GBIDI2-1)=GAUSCRMF
    [M:RPT]VALINT1(GBIDI2-1)=GAUSCRMF
  Endif
  Affzo [RPT]VALEUR1(GBIDI2-1)
Endif
#--CPO 104383 Nouveau : "Type de devis"
If clalev([F:TSQ])=0 : Local File TABSQHTYP [TSQ] : Endif
GBIDI2 = find("TSQ",[M:RPT]PARTYP)
If GBIDI2
  Read [F:TSQ] Last
  If ! fstat : [M:RPT]VALEUR2(GBIDI2-1) = [F:TSQ]SQHTYP : Endif
Endif
#--/
Return

######################################################################

$INIPAR
If GAUSCRMF<>"" & GAUSCRMA=2 & [M:RPT]PARTYP(nolign-1)="REP"  mkstat=2 : Endif
Return

######################################################################

$CONT1
If [M]PARCOD(nolign-1)="rupturesite" Then
    If VALEUR ="Non" Then
        If [M]VALEUR1(nolign-1) <> VALEUR Then
            [M]NOLIB(nolign+1) = 2407
            [M]VALEUR1(nolign+1)=mess(1,2407,1)
            [M]VALINT1(nolign+1)="1"
        Endif
    Elsif VALEUR ="Oui" or VALEUR = "Oui avec saut de page" Then
        If [M]VALEUR1(nolign-1) <> VALEUR Then
            [M]NOLIB(nolign+1) = 2408
            [M]VALEUR1(nolign+1)=mess(1,2408,1)
            [M]VALINT1(nolign+1)="1"
        Endif
    Endif
    Affzo [M]VALEUR1(nolign+1)
Endif
Return

######################################################################

# Exécuté suite au rappel d'un mémo
$MEMO
Local Integer I
Local Char VAL1(250),VAL2(250)
For I=1 To dim([M:RPT]PARCOD)
    If [M:RPT]PARCOD(I)="" : Break : Endif
    If [M:RPT]PARCOD(I)="rupturesite" Then
        If [M:RPT]VALEUR1(I) = "Non"
            # on change le numéro du menu local
            [M:RPT]NOLIB(I+2) = 2407
            # on relit la variable ordre de tri
            Call  LECMEMO_COD([M:RPT]RPTCOD,"rpt",[M:MEM]CODE,"ordretri",VAL1,VAL2)  From AIMP4
            # on récupère la variable ordre de tri
            [M:RPT]VALEUR1(I+2) = VAL1
            # on refait le contrôle de la variable ordre de tri
            Call CONTROLE([M:RPT]VALEUR1(I+2),[M:RPT]PARTYP(I+2),[M:RPT]NOLIB(I+2),[M:RPT]LONG(I+2)
& ,[M:RPT]VALINT1(I+2)) From FMTVAR
            Break
        Endif
    Endif
Next
Return

######################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
End

######################################################################
