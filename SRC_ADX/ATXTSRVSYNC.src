#<AdxTL>@(#)0.0.0.0 $Revision$
#localhost:8124/syracuse-main/html/main.html?url=%2Ftrans%2Fx3%2Ferp%2FSOLDEV_FOLDEV%2F%24sessions%3Ff%3DAECLIEXE%252F2%252FAECLIEXE%252FM%252FATXTSRVSYNC
#localhost:8125/syracuse-main/html/main.html?url=%2Ftrans%2Fx3%2Ferp%2FSOLDEV_FOLDEV%2F%24sessions%3Ff%3DAECLIEXE%252F2%252FAECLIEXE%252FM%252FATXTSRVSYNC
Local Integer FIN: FIN=0
Gosub INIT
Gosub EXEC
Call LEC_TRACE From LECFIC
End

##########################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "CONT_BATCH"   : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TITRE"       : Gosub TIT
Endcase
Return

##########################
$INIT
Local Char    APPLI(GLONADS)
Local Mask ATXTSRVSYNC [DIA]

$INIT_DIA
If func AFNC.PARAMDOS(nomap,"ATXTSRV")<>"2"
  GMESSAGE = mess(74,100,1)
  GERR=1
  Return
Endif
Raz [M:DIA]
[M:DIA]DOSSIER=nomap
Affzo [M:DIA]DOSSIER
Return

##########################
$TIT
TIT = mess(329,123,1) : # Synchronisation des textes depuis le serveur de textes
Return

##########################
$CONTROLE
If [M:DIA]DOSSIER="" : FIN = 1 : Return : Endif

APPLI = [M:DIA]DOSSIER
If func AFNC.PARAMDOS(APPLI,"ATXTSRV")<>"2" | func DOSSUB.ISHISTFOLD(APPLI)
  Call ERREUR(mess(74,100,1)) From GESECRAN
  FIN = 1 : Return
Endif

If GLANGUE<>"FRA" & GLANGUE<>"ENG"
  Call ERREUR(func AFNC.MES2(mess(325,123,1), "FRA", "ENG")) From GESECRAN
  FIN = 1 : Return
Endif

Return

##########################
$EXEC

Gosub CONTROLE
If FIN=1 : Return  : Endif

If !GSERVEUR
 Call TEMPON(APPLI-mess(329,123,1)) From GESECRAN : # Synchronisation des textes depuis le serveur de textes
 Call OUVRE_TRACE(APPLI-mess(329,123,1)) From LECFIC
Endif


TRA = 1
Gosub SYNC_TEXTES
Gosub SYNC_APLSTDS

If !GSERVEUR
 Call TEMPOFF From GESECRAN
 Call FERME_TRACE From LECFIC
Endif
Return

##########################
$ERRSQL
ER = errn
ERM = errm
Resume


$SYNC_TEXTES
GOK=1
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
Local Integer ASTATUS,HASCHANGED
Local Integer TBNUM(1..)
Local Char TBLAN(250)(1..)
Local Char TBTEXT(250)(1..)
Local Char TBCOM(250)(1..)
Local Char TBLANORI(250)(1..)
Local Char  MESSAGE(250)
Local Char ETAG(250),TMPETAG(250),NEWETAG(250)
Local Integer COUNT,ICOUNT,NBCOUNT,MAJCOUNT

Call GETPAR(APPLI,"ATXTETAG",ETAG) From SUBADS
If ETAG=""
   If GPRODUIT=-1
    ETAG="2016-07-15T10:01:01.625Z"
   Elsif GPRODUIT=0
    ETAG="2016-09-27T00:00:00.000Z"
   Endif
Endif

Call ECR_TRACE(mess(329,123,1),0) From GESECRAN
Call ECR_TRACE(mess(3,23,1)-APPLI,0) From GESECRAN
Call ECR_TRACE(mess(72,104,1)-ETAG,0) From GESECRAN

#Gosub SYNC_TEXTES_0
Gosub SYNC_TEXTES_1

Call ECR_TRACE('',0) From GESECRAN

If GOK & NEWETAG<>""
Call MAJPAR(APPLI,"ATXTETAG",NEWETAG) From SUBADS
Call ECR_TRACE(mess(72,104,1)-NEWETAG,0) From GESECRAN
Endif

Return

###########################
$SYNC_TEXTES_1
Local Integer COUNTASK : COUNTASK=1000
Local Integer COUNTPOS : COUNTPOS=0
While GOK=1
 COUNT=COUNTPOS
 TMPETAG=ETAG
 ASTATUS = func ATXTSVC.GET_LASTMODIFIED(GPRODUIT, TMPETAG, 1000, COUNT, TBNUM, TBLAN, TBTEXT, TBCOM, TBLANORI, MESSAGE)
 If ASTATUS<>[V]CST_AOK | COUNT<0
   Call ERREUR(mess(7,21,1)-"("+num$(COUNT)+")"-MESSAGE) From GESECRAN
   FIN = 1 : Return
 Endif

 If COUNTPOS=0
  Call ECR_TRACE('',0) From GESECRAN
  Call ECR_TRACE_F("NUM","LAN","LANORI",mess(4,38,1)+"/"+mess(123,124,1),"",8,4,7,80,0,0) From GESECRAN
  Call ECR_TRACE_F("-------","---","------",string$(80,"-"),"",8,4,7,80,0,0) From GESECRAN
 Endif

 Trbegin [ATX]
 For ICOUNT=1 To COUNT
  HASCHANGED=0
  Gosub TR_ATEXTE
  If HASCHANGED
   Call ECR_TRACE_F(num$(TBNUM(ICOUNT)),TBLAN(ICOUNT),TBLANORI(ICOUNT),TBTEXT(ICOUNT),"",8,4,7,80,0,0) From GESECRAN
   If TBCOM(ICOUNT)<>""
     Call ECR_TRACE_F(" "," "," ",TBCOM(ICOUNT),"",8,4,7,80,0,0) From GESECRAN
   Endif
   If GOK=1 : MAJCOUNT+=1 : Endif
  Endif
  If GOK<>1 : Break : Endif
  NBCOUNT+=1
  If NEWETAG=""
   NEWETAG=TMPETAG
  Elsif gdatetime$(TMPETAG)>gdatetime$(NEWETAG)
   NEWETAG=TMPETAG
  Endif
 Next
 If GOK
  Commit
 Else
  Rollback
  Break
 Endif
 If COUNT<COUNTASK | COUNT>COUNTASK
  Break
 Endif
 COUNTPOS+=COUNT
Wend
Call ECR_TRACE('',0) From GESECRAN
Call ECR_TRACE(func AFNC.MES(mess(220,115,1),num$(NBCOUNT)),0) From GESECRAN
Call ECR_TRACE(mess(192,124,1)-":"-num$(MAJCOUNT),0) From GESECRAN
Return

###########################
$SYNC_TEXTES_0
TMPETAG=ETAG
ASTATUS = func ATXTSVC.GET_LASTMODIFIED(GPRODUIT, TMPETAG, 1000, COUNT, TBNUM, TBLAN, TBTEXT, TBCOM, TBLANORI, MESSAGE)
If ASTATUS<>[V]CST_AOK | COUNT<0
  Call ERREUR(mess(7,21,1)-"("+num$(COUNT)+")"-MESSAGE) From GESECRAN
  FIN = 1 : Return
Endif


Call ECR_TRACE('',0) From GESECRAN
Call ECR_TRACE_F("NUM","LAN","LANORI",mess(4,38,1)+"/"+mess(123,124,1),"",8,4,7,80,0,0) From GESECRAN
Call ECR_TRACE_F("-------","---","------",string$(80,"-"),"",8,4,7,80,0,0) From GESECRAN

Trbegin [ATX]
For ICOUNT=1 To COUNT
 HASCHANGED=0
 Gosub TR_ATEXTE
 If HASCHANGED
  Call ECR_TRACE_F(num$(TBNUM(ICOUNT)),TBLAN(ICOUNT),TBLANORI(ICOUNT),TBTEXT(ICOUNT),"",8,4,7,80,0,0) From GESECRAN
  If TBCOM(ICOUNT)<>""
    Call ECR_TRACE_F(" "," "," ",TBCOM(ICOUNT),"",8,4,7,80,0,0) From GESECRAN
  Endif
  If GOK=1 : MAJCOUNT+=1 : Endif
 Endif
 If GOK<>1 : Break : Endif
 NBCOUNT+=1
 NEWETAG=TMPETAG
Next
If GOK
Commit
Else
Rollback
Endif
Call ECR_TRACE('',0) From GESECRAN
Call ECR_TRACE(func AFNC.MES(mess(220,115,1),num$(NBCOUNT)),0) From GESECRAN
Call ECR_TRACE(mess(192,124,1)-":"-num$(MAJCOUNT),0) From GESECRAN
Return

###########################
$TR_ATEXTE
Readlock [ATX]NUMERO = TBLAN(ICOUNT);TBNUM(ICOUNT)
If fstat
 HASCHANGED=1
 Raz  [F:ATX]
 [F:ATX]NUMERO = TBNUM(ICOUNT)
 [F:ATX]LAN = TBLAN(ICOUNT)
 [F:ATX]LANORI = TBLANORI(ICOUNT)
 [F:ATX]TEXTE = TBTEXT(ICOUNT)
 [F:ATX]COMMENT = TBCOM(ICOUNT)
 Write [ATX]
 Call FLDCRE("ATX") From OBJDIV
 If fstat
  GOK=0 : Call FSTA("ATX") From GLOCK
 Endif
Elsif [F:ATX]LANORI <> TBLANORI(ICOUNT) | [F:ATX]TEXTE <> TBTEXT(ICOUNT) | [F:ATX]COMMENT <> TBCOM(ICOUNT)
 HASCHANGED=1
 [F:ATX]LANORI = TBLANORI(ICOUNT)
 [F:ATX]TEXTE = TBTEXT(ICOUNT)
 [F:ATX]COMMENT = TBCOM(ICOUNT)
 Call FLDUPD("ATX") From OBJDIV
 Rewrite [ATX]
 If fstat
  GOK=0 : Call FSTA("ATX") From GLOCK
 Endif
Endif

Return


$SYNC_APLSTDS
