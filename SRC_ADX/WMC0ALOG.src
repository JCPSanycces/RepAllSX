####################################################################
# Traitments
####################################################################
$_ADDTRT
this.AINF.TRT(1) = "ALOG_CSTD"
this.AINF.TYP(1) = 1
this.AINF.PTH(1) = ""
this.AINF.NBTRT = 1
Return

####################################################################
#Declaration of variables
####################################################################

$DECLARE_VAR
Local Char    ACTION(50) , CURPRO(250) , VALPRO(250) , CURQRY(50) , CURPTH(250)
Local Char    AMETHOD(50) ,AOPERATION(50),AEVENT(50),ARULE(50)
Local Integer ALLSTAT,AISMET,ASTATUS
Return

####################################################################
# Methods of the class
####################################################################
# Fmethod Début
$ABEGINLOG
Gosub DECLARE_VAR
[L]AISMET = [V]CST_AYES
[L]AMETHOD = "ABEGINLOG" : [L]ACTION = "ABEGINLOG" : [L]CURPRO = "" : Gosub ACTION_MET From ASYRSUB
Return

# Fmethod Ajout
$APUTLINE
Gosub DECLARE_VAR
[L]AISMET = [V]CST_AYES
[L]AMETHOD = "APUTLINE" : [L]ACTION = "APUTLINE" : [L]CURPRO = "" : Gosub ACTION_MET From ASYRSUB
Return

# Fmethod Fin
$AENDLOG
Gosub DECLARE_VAR
[L]AISMET = [V]CST_AYES
[L]AMETHOD = "AENDLOG" : [L]ACTION = "AENDLOG" : [L]CURPRO = "" : Gosub ACTION_MET From ASYRSUB
Return

# Fmethod Ajouter les erreurs
$APUTERRS
Gosub DECLARE_VAR
[L]AISMET = [V]CST_AYES
[L]AMETHOD = "APUTERRS" : [L]ACTION = "APUTERRS" : [L]CURPRO = "" : Gosub ACTION_MET From ASYRSUB
Return

# Fmethod Ajouter les erreurs d'instance
$APUTINSTERRS
Gosub DECLARE_VAR
[L]AISMET = [V]CST_AYES
[L]AMETHOD = "APUTINSTERRS" : [L]ACTION = "APUTINSTERRS" : [L]CURPRO = "" : Gosub ACTION_MET From ASYRSUB
Return

# Fmethod Flush des lignes dans le log
$AFLUSHLOG
Gosub DECLARE_VAR
[L]AISMET = [V]CST_AYES
[L]AMETHOD = "AFLUSHLOG" : [L]ACTION = "AFLUSHLOG" : [L]CURPRO = "" : Gosub ACTION_MET From ASYRSUB
Return

# Fmethod Obtenir le nom du log
$AGETNAME
Gosub DECLARE_VAR
[L]AISMET = [V]CST_AYES
[L]AMETHOD = "AGETNAME" : [L]ACTION = "AGETNAME" : [L]CURPRO = "" : Gosub ACTION_MET From ASYRSUB
Return

# Fmethod Affecter le nom du log
$ASETNAME
Gosub DECLARE_VAR
[L]AISMET = [V]CST_AYES
[L]AMETHOD = "ASETNAME" : [L]ACTION = "ASETNAME" : [L]CURPRO = "" : Gosub ACTION_MET From ASYRSUB
Return

# Fmethod Ouvrir un log existant
$APPENDLOG
Gosub DECLARE_VAR
[L]AISMET = [V]CST_AYES
[L]AMETHOD = "APPENDLOG" : [L]ACTION = "APPENDLOG" : [L]CURPRO = "" : Gosub ACTION_MET From ASYRSUB
Return


####################################################################
# AERRORS
####################################################################

$_AERROR
Gosub DECLARE_VAR From WMC0ALOG
Local Integer ALLSTAT
Call ALLERRORS(this,_CTX,_SUPP) From ASYRSUB
For AINDCLA=1 To maxtab(this.ALOGD)
 If this.ALOGD(AINDCLA)<>null
  [L]ASTATUS = fmet this.ALOGD(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
Return

####################################################################
# Delete all errors
####################################################################

$_ADELERRORS
Gosub DECLARE_VAR From WMC0ALOG
Local Integer ALLSTAT
[L]ASTATUS = fmet this.ADELETEERROR([L]_APARAM)
For AINDCLA=1 To maxtab(this.ALOGD)
 If this.ALOGD(AINDCLA)<>null
  [L]ASTATUS = fmet this.ALOGD(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
Return

####################################################################
# _ASEARCHINFOS
####################################################################

$_ASEARCHINFOS
Gosub DECLARE_VAR From WMC0ALOG
ASTATUS= func ASYRSUB.ASEARCHINFOS(this,[L]AINS_ORI,[L]ERR_TYPE,[L]PROPERTY,[L]ASTAT,[L]SELSTAT,[L]PATH)
If [L]ERR_TYPE=[V]CST_ACURRENT : Return : Endif
For AINDCLA=1 To maxtab(this.ALOGD)
 If this.ALOGD(AINDCLA)<>null
  [L]ASTATUS = fmet this.ALOGD(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'ALOGD('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
Return

####################################################################
# AGETERRORSFROM
####################################################################

$_AGETERRORSFROM
Gosub DECLARE_VAR From WMC0ALOG
If AINS_FROM<>null
 [L]ASTATUS = fmet AINS_FROM.ASEARCHINFOS( [V]CST_ALL, "", [V]CST_AFATAL, 0)
Endif
Call AGETERRORSFROM(AINS_FROM,this,ENVIRONNEMENT) From ASYRSUB
Return

####################################################################
# ADELLINE
####################################################################
$ADELLINE
Case _ACOLLECTION
 When "ALOGD"
  If this.ALOGD([L]ALINE)<>null : FreeInstance this.ALOGD([L]ALINE) : this.ALOGD([L]ALINE) = null :Endif
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# ADDLINE
####################################################################
$ADDLINE
Case _ACOLLECTION
 When "ALOGD"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"ALOGD","C_ALOGD",this)
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETDIM
####################################################################
$AGETDIM
Case _ACOLLECTION
 When "ALOGD"
  [L]_ALINE = 0
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETMIN
####################################################################
$AGETMIN
Case _ACOLLECTION
 When "ALOGD"
  [L]_ALINE = 1
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# _ADELINSTANCE
####################################################################
$_ADELINSTANCE
[L]ASTATUS = func ASYRSUBTAB._ADELINSTANCE(this)
Return

####################################################################
# ADDINSTANCE_BOUND
####################################################################
$ADDINSTANCE_BOUND
Return



