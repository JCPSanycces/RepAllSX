#<AdxTL>@(#)9.0.0.0 $Revision$
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
#    Interface avec portail (basé sur AEXPCONS/EXPCONS et EXPORT_XLS/GCONSULT)
#    Ce tratiement pourrait être intégré dans GCONSULT
#
#    $PTL_INI    Initialisation consultation
#    $PTL_INFOS  Obtention infos générales consultations
#    $PTL_FIN    Fermeture
#
#    Cette interface est appelée depuis SUBAPSCNS
#    Nota: SUBAPSCNS contient la boucle pour acquerir les données écran par écran
#    
#
#    Subprog     ACTRUN(INFOS)        Gestion du click utilisateur général et appelé SUBAPSOBJ
#
#
#
#    Version:  003    Evol VERFGTC() 
#                     Where de For [AMZ]CODZON
#                     SetMask
#                    
#    003
#     E63631 - Routine calcul format (heure , date)
#    002    
#     EVOL VERFGTC() 
#     Where de For [AMZ]CODZON
#     SetMask
#                    
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 


# # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # 
# Gestion initialisation consultation
# # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # 
#
# En entrée:
#    CNSCOD      Code consultation
#    CECRAN      Code de l'écran issu du paramétrage de la vue (code ECRAN)
#                Si non présent alors ""
#
# En sortie:
#    EXPMES     Message si erreur
#    EXPSTA     Flg erreur 0:Ok 1:Ko)
$PTL_INI
Local Char EXPMES(250)
Local Integer EXPSTA
Raz EXPSTA, EXPMES

If CNSCOD="" : # Consultation non définie
    EXPMES=mess(16,126,1) : EXPSTA=1
    Return
Endif

# Initilaisation
If !clalev([F:ACN]) : Local File ACONSULT [ACN] : Endif
If !clalev([F:AMK]) : Local File AMSK     [AMK] : Endif
If !clalev([F:AMZ]) : Local File AMSKZON  [AMZ] : Endif
If !clalev([F:AFC]) : Local File AFONCTION [AFC] : Endif
If !clalev([F:ACT]) : Local File ACTION   [ACT] : Endif
If !clalev([F:ATX]) : Local File ATEXTE   [ATX] : Endif

Read [ACN]ACN0 = CNSCOD
If fstat : # Consultation non définie
 EXPMES = CNSCOD-":"-mess(16,126,1) : EXPSTA=1
 Return
Endif


#Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
#  A-t-on le droit de naviguer vers cette action (empilage écran)
Call CNAVIG(2,"","","","",[F:ACN]WND1,"",EXPMES) From EXEFNC
If EXPMES<>""  : EXPSTA=1 : Return : Endif

# ?? Close Local File [ACN]

Gosub DECLARE From GCONSULT

SAVFONC    = GFONCTION
SAVOBJET   = GOBJET
SAVPROG    = GPROGRAMME
SAVTITCOL  = GORITITCOL
SAVNOL     = nolign
SAVBOITE   = GBOITE
GORITITCOL = 0
GFONCTION  = "CONS"+CNSCOD
PROGCNS    = "WWCNS"+CNSCOD
Gosub NOMFIC From =PROGCNS
If PROGSTD<>""
 Call EXISTE_ADX("","",PROGSTD,OKTRT) From ORDSYS
 If !OKTRT
  PROGSTD = ""
 Else
  PROG = PROGSTD
 Endif
Endif
If PROGSPE<>""
 Call EXISTE_ADX("","",PROGSPE,OKTRT) From ORDSYS
 If !OKTRT
  PSPE = 0 : PROGSPE = ""
 Else
  PSPE = 1
 Endif
Endif

GOBJET = 1
GPROGRAMME = "GCONSULT"

Call AUTORIS From EXEFNC
If GNBAUZ=0
 # Fonction non autorisée
 EXPMES =  GFONCTION-":"-mess(1,123,1) : EXPSTA= 1 :  Goto PTL_FIN
Endif
OK = 1 : ACTION = "AUTORIS" : Gosub ACTION From GCONSULT
If !OK : EXPSTA= 1  : Goto PTL_FIN : Endif

NBMASK = 2
For MA=2 To dim(NOMMSK)-1
 If NOMMSK(MA)=""
  NBMASK = MA-1 : Break
 Endif
Next MA

OK = 1
If CODMSKDEF<>""   # 002
 If CECRAN=""
  Call VERFGTC(CNSCOD,CODMSKDEF,CODMSKDEF, EXPMES, OK) From GCONSULT    
 Else
  Call VERFGTC(CNSCOD,CECRAN,CODMSKDEF, EXPMES, OK) From GCONSULT 
 Endif
 If !OK        # Ptl - remonte le message
    EXPSTA=1
    Goto PTL_FIN
 Endif
Endif

For MA=-1 To NBMASK
 If MA=1 & CODMSKDEF<>""
  If OK
   NOMMSK(1) = "WM"+CNSCOD+CODMSKDEF
  Else
   GMESSAGE = ""
  Endif
 Elsif MA=2 & CNSCOD="STA" & CODMSKDEF<>""
  If OK
   NOMMSK(2) = "WMSTB"+CODMSKDEF
  Else
   GMESSAGE = ""
  Endif
 Endif
 Gosub OUVRE_MSK From =PROGCNS
Next MA
MSKDEF = NOMMSK(1)

If CODMSKDEF<>"" & OK
 GBOITE = "WM"+CNSCOD+CODMSKDEF
Elsif CECRAN<>""
 GBOITE = "WM"+CNSCOD+CECRAN
Else
 GBOITE = BOITE
Endif
BOXDEF = GBOITE

If CABMSK="" or evalue("dim([M:"+CABMSK+"]MEMO)<=0")
 MEMO = ""
Endif

Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV

For MA=0 To NBMASK              # 002
 Gosub SETMASK From =PROGCNS
Next MA

For MA=-1 To NBMASK
 Gosub RAZMASK From =PROGCNS
Next MA

Raz CHARGMT   # Bug 9630 : Préchargement oui/non (CP:12/07/01)
Gosub OUVRE From =PROGCNS

Raz FILSIT, FILACC
If NOMFIC<>"" 
 Gosub SETCLE From =PROGCNS
 If NBCMP
  # Filtre sur sites autorisés
  If GUSRFCY(1)<>"\" & dim([L]ZSITE)>0 & [L]ZSITE<>"" & GNBAUZ<>GNBSITE
   FILSIT = '([F:'+ABFIC+']'+ZSITE+'="" or find([F:'+ABFIC+']'+ZSITE+',GUSRFCY(1..GNBAUZ))<>0)'
  Endif
  # Filtre sur codes d'accès
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  If GUSRACS<>2 & [L]ZACC<>""
   FILACC = '([F:'+ABFIC+']'+ZACC+'="" or [F:ACC]CONSUL=2)'
  Else
   FILACC = "1=1"
  Endif 
 Endif
Endif
If OBJDERLU<>""
 If GNBDERNIER>0 & !clalev([F:ALS]) : Local File ALSTRD [ALS] : Endif
 PROGOBJ = "WO"+OBJDERLU
Endif

ACTION = "OUVRE" : Gosub ACTION From GCONSULT
If OK<0 : EXPMES = GMESSAGE : EXPSTA = 1 : Goto PTL_FIN : Endif
EXPCONS=1 : Gosub CHANGE_MSK From GCONSULT         # Adaptation GConsult en mode export


Read [AFC] = GFONCTION
If !fstat & [F:AFC]ACTION <> ""
 Read [F:ACT]ACTION = [F:AFC]ACTION
 If !fstat & [F:ACT]PARAM1 <> ""
  CNSCOD =  [F:ACT]PARAM1
  Read [F:ACN]ACN0 = CNSCOD
 Endif
Endif
If CNSCOD="" : Goto PTL_FIN : Endif

Return



# # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # 
# Gestion informations globales à une consultation
# # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # 
#
# En entrée:
#
# En sortie:
#    C_CNSTITLE    Titre consultation
#    C_CNSMASKABR  Abr. mask support de l'échange des données (sous la forme [M:XXX] )
###    C_CNSMAXROW   Nombre de ligne maxi du tableau
#
#    C_CLSCOD      Liste des codes des colonnes à présenter (code du champs dans le mask ci-dessus)
#    C_CLSTITLE    Liste des libelles des colonnes
#    C_CLSTYP      Liste des types des colonnes - valeurs issues du menu local 30
#    C_CLSMNL      Liste des numéro menu local des colonnes ( le cas échant )
#    C_CLSLNG      Liste des format sous forme 12.4 des colonnes ( le cas échant )
#    C_CLSFMT      Liste des format exploitatable par format$
#    C_CLSNB       Nb de colonnes 
#
#    EXPMES     Message si erreur
#    EXPSTA     Flg erreur 0:Ok 1:Ko)
#
$PTL_INFOS
C_CLSNB     =0
C_CNSMASKABR="[M:"+ABMSK(1)+"]"
#
Call TEXTE([F:ACN]LIBEL, C_CNSTITLE) From OBJDIV
#
Read [F:AMK]CODMSK=NOMMSK(1)
If fstat
    EXPMES = mess(1, 105,1) : EXPSTA = 1 : Goto PTL_FIN
Endif

## Recherche bloc de NBLIG
ZNBLIG = -1
Read [AMZ]CODE =NOMMSK(1);"NBLIG"
If !fstat
 ZNBLIG = [AMZ]NUMBLOC
Endif
If ZNBLIG=-1
    EXPMES = mess(11,75,1) : EXPSTA = 1 : Goto PTL_FIN
Endif


## Place obligatoire pour avoir les titres si évalués
EXPCONS=1            # Adaptation GConsult en mode export
NBLU = 1 : ACTION = "LECTURE" : Gosub ACTION From GCONSULT      #Gosub PAG_PREM From GCONSULT#
For [AMZ]CODZON Where CODMSK=NOMMSK(1) & [AMZ]SAIAFF<=2  & [AMZ]NUMBLOC = ZNBLIG & [AMZ]CODZON<>"NBLIG"
    # Evol Colonne active mb 13.8.9
    K  = func AFNC.ACTIV([F:AMZ]CODACT) : # mb 13.8.9
    K *= evalue("dim([M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+")")>0 : # mb 13.8.9
    # Flg colonne visible (tient compte des cons. statistique (intitulé évalué --> vide --> pas affiché))
    K *=func GCONSULT.VERIF_STA([F:AMZ]CODZON,[L]CNSCOD)
    C_CLSFLGEXP(C_CLSNB)=K
    #   
    If C_CLSFLGEXP(C_CLSNB)
       C_CLSCOD(C_CLSNB)    =[F:AMZ]CODZON 
       C_CLSLNG(C_CLSNB)    =[F:AMZ]LONG
       C_CLSTITLE(C_CLSNB)  =func GCONSULT.INTIT_XLS([F:AMZ]INTIT,[F:AMZ]INTEVAL)
       Read [F:ATY]CODTYP=[F:AMZ]CODTYP
       If !fstat
           C_CLSTYP(C_CLSNB)    =[F:ATY]TYPTYP
           If [F:ATY]TYPTYP=1
              C_CLSMNL(C_CLSNB) =[F:AMZ]NOLIB
           Else       # E63631  (rq: type HS=alphanum donc 7)
             Call FMTECR(CODMSK,[AMZ]CODZON,[ATY]CODTYP,C_CLSFMT(C_CLSNB)) From SUBFMT    # E63631
           Endif
       Else 
           EXPMES = mess(7, 150,1) : EXPSTA = 1 : Goto PTL_FIN
       Endif
    Endif
    #
    C_CLSNB+=1
    If C_CLSNB=CC_NBMAXCOL : Break : Endif
Next
Return


# # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # 
# Gestion fin consultation
# # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # 
$PTL_FIN
ACTION = "FERME" : Gosub ACTION From GCONSULT
If BOX
 Gosub FERME_BOITE From =WINPROG
 BOX = 0
Endif
GOBJET     = SAVOBJET
GPROGRAMME = SAVPROG
GFONCTION  = SAVFONC
GBOITE     = SAVBOITE
Call AUTORIS From EXEFNC : # Restauration des autorisations
GORITITCOL = SAVTITCOL
#  Traiter le pb de CNavig()/EXEFNC
If dim(GNBMASKOUV)>0 
 GNBMASKOUV-=1  
 GNBMASKOUV=max(0,GNBMASKOUV)
Endif


Setmode
Return


# # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # # 
# Gestion du click utilisateur général (dans Gconsult)
#   Appelé par le portail et permet l'aiguillage
#
Subprog ACTRUN(INFOS)
Variable Char INFOS()     # Informations pour retrouver le contexte

Local Integer WI, WJ
Local Char CNSCOD 

# Recherche code consultation
WI=instr(1,INFOS,"~")
If WI
    CNSCOD=left$(INFOS,WI-1)
    #test
    #If CNSCOD="AUD"
    #    Call ACTRUNCNS(INFOS) From ZJJCNST
    #    End
    #Endif
    INFOS=right$(INFOS, WI+1)
    Call ACTRUN(INFOS) From ="WWCNS"+CNSCOD
Endif
End

