#<AdxTL>@(#)9.0.0.0 $Revision$
##############################################################################################
# Activité CRM pour le portail
#    Paramètre source de données:
#            DAYBEF:    Nb de jour avant la date du jour pour extraction
#            DAYAFT:    Nb de jour après la date du jour pour extraction
#
##############################################################################################
##############################################################################################
$T_EXECUTE     # Traitement (I1)
  Onerrgo         # Suppression gestion d'erreur du prgrm appelant 
  U_TRAMES = "--> Debut: " + "Exemple traitement" : Gosub U_TRAPUT From SUBAPSUTI     # Trace (I9)
  Gosub T_INIT    # Initialisation
  #-- XML
  U_SEQPUT = ' <Data>' : Gosub U_PUT From SUBAPSUTI # Ecriture balise Data  (I2)
  ### Gestion Action
  Case M_ACTION
    When TQ_ACTINIT, TQ_ACTREFRESH
      Gosub T_ACTINIT
      If U_ERR = UC_ERRG Then
        Goto ERRXMLCLOSE
      Endif    # (I3)
    When Default                                                        
      U_MESCODE = "TRTACTUNKNOWN"
      U_MESP1 = M_ACTION
      U_MESP2 = [F:APV]SRCCODTYP
      U_ERR = UC_ERRG     # (I3)
      Gosub U_MESPUT From SUBAPSUTI
      Goto ERRXMLCLOSE
  Endcase    
  $ERRXMLCLOSE    # fermeture XML listes
  #-- XML 
  U_SEQPUT = ' </Data>' : Gosub U_PUT From SUBAPSUTI
  # Trace
  U_TRAMES="--> Fin: " + "Serveur statistique du portail": Gosub U_TRAPUT From SUBAPSUTI 
Return

##############################################################################################
# ------------------------------------------------------------
#     G O S U B
# ------------------------------------------------------------
# Gestion de la demande INIT
$T_ACTINIT
  # Par. sources de données
  Gosub T_GETSRCPAR
  # Section lignes de données
  Gosub SEC_LINES
  If U_ERR = UC_ERRG Then
    Return
  Endif
  # Section titres
  Gosub SEC_TITLES
  If U_ERR = UC_ERRG Then
    Return
   Endif
  #LSE 07/12/2006
  Gosub SEC_CATEG
  If U_ERR = UC_ERRG Then
    Return
  Endif
Return

##############################################################################################
# gestion des messages 
#  info: Valoriser U_MES
#        Utiliser une section de message propre à vos traitements (pas la 137!)
$T_GETMESBYCODE        # (I3)
  Case U_MESCODE
    When "TRTACTUNKNOWN"    # "Source de données: " + U_MESP2 + " - Action inconnue: " + U_MESP1
      U_MES = mess(45,137,1) - U_MESP2 - "-" - mess(5,137,1) - U_MESP1
    When "TRTPARERR"        # Paramètre non trouvé ou incorrect: xx  YY
      U_MES = mess(59,137,1) - U_MESP1 - ":" - U_MESP2
    When "TRTPARMAX"        # Paramètre hors limite: xx - yy
      U_MES = mess(60,137,1) - U_MESP1 - ":" - U_MESP2 
    When "TRTPARDEF"        # Paramètre: xx Valeur par défaut: yy 
      U_MES = mess(41,137,1) - U_MESP1 - "-" - mess(61,137,1) - U_MESP2
  Endcase
Return

##############################################################################################
#   G O S U B
# Section titres
$SEC_TITLES
  U_SEQPUT = '<Titles>' : Gosub T_SEQPUT
  # Titre
  U_SEQPUT = ' <Title>' + mess(96,177,1) + '</Title>' : Gosub T_SEQPUT
  # Colonnes
  For TW_I = 1 To 11
    Case TW_I
      When 1
        Call TEXTE(96, U_HEXTOTXT) From OBJDIV      #Type d'action
      When 2
        Call TEXTE(24967, U_HEXTOTXT) From OBJDIV   #Chrono action
      When 3
        Call TEXTE(1805, U_HEXTOTXT) From OBJDIV    #Date début
      When 4
        Call TEXTE(14714, U_HEXTOTXT) From OBJDIV   #Heure début
      When 5
        Call TEXTE(1806, U_HEXTOTXT) From OBJDIV    #Date fin
      When 6
        Call TEXTE(15114, U_HEXTOTXT) From OBJDIV   #Heure fin
      When 7
        Call TEXTE(19569, U_HEXTOTXT) From OBJDIV   #Tiers
      When 8
        Call TEXTE(10981, U_HEXTOTXT) From OBJDIV   #Interlocuteur
      When 9
        Call TEXTE(707, U_HEXTOTXT) From OBJDIV     #Catégorie
      When 10
        Call TEXTE(1158, U_HEXTOTXT) From OBJDIV    #Objet
      When 11
        Call TEXTE(14437, U_HEXTOTXT) From OBJDIV   #Effectué
      When Default
        Call TEXTE(2808, U_HEXTOTXT) From OBJDIV    #Colonne
        U_HEXTOTXT += " "
        U_HEXTOTXT += num$(TW_I)
    Endcase
    Gosub U_TXTTOHEX From SUBAPSUTI
    U_SEQPUT = ' <ColTitle Num="' + num$(TW_I) + '" X3Type="7">' + U_TXTTOHEX + '</ColTitle>' : Gosub T_SEQPUT
  Next
  U_SEQPUT = '</Titles>' : Gosub T_SEQPUT
Return 

##############################################################################################
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#LSE 07/12/2006 V5 gestion des catégories
$SEC_CATEG
  U_SEQPUT = '<Categs>' : Gosub T_SEQPUT
  #
  # Catégories
  Call TEXTE(1195, U_HEXTOTXT) From OBJDIV      #Tâche
  Gosub U_TXTTOHEX From SUBAPSUTI
  # FGR 11/02/2010 : X3SUIVI62444
  #U_SEQPUT = ' <categ Color="0xFFCC55" Id="1">' + U_HEXTOTXT + '</categ>' : Gosub T_SEQPUT
  U_SEQPUT = ' <categ Color="0xFDE6D5" Id="1">' + U_HEXTOTXT + '</categ>' : Gosub T_SEQPUT
  #    
  Call TEXTE(13606, U_HEXTOTXT) From OBJDIV     #Appel
  Gosub U_TXTTOHEX From SUBAPSUTI
  #U_SEQPUT = ' <categ Color="0x772255" Id="2">' + U_HEXTOTXT + '</categ>' : Gosub T_SEQPUT
  # FGR 11/02/2010 : X3SUIVI62444
  #U_SEQPUT = ' <categ Color="0xFDE6D5" Id="2">' + U_HEXTOTXT + '</categ>' : Gosub T_SEQPUT
  U_SEQPUT = ' <categ Color="0xDEF3DD" Id="2">' + U_HEXTOTXT + '</categ>' : Gosub T_SEQPUT
  #    
  Call TEXTE(14423, U_HEXTOTXT) From OBJDIV     #Rendez-vous
  Gosub U_TXTTOHEX From SUBAPSUTI
  # FGR 11/02/2010 : X3SUIVI62444
  #U_SEQPUT = ' <categ Color="0x44CC55" Id="3">' + U_HEXTOTXT + '</categ>' : Gosub T_SEQPUT
  U_SEQPUT = ' <categ Color="0xF9FDD5" Id="3">' + U_HEXTOTXT + '</categ>' : Gosub T_SEQPUT
  #
  # FLORENT EVOL_MK (Début)
  Call TEXTE(14729, U_HEXTOTXT) From OBJDIV     #Campagne marketing
  Gosub U_TXTTOHEX From SUBAPSUTI
  U_SEQPUT = ' <categ Color="0xC5F7C1" Id="4">' + U_HEXTOTXT + '</categ>' : Gosub T_SEQPUT
  # FLORENT EVOL_MK (Fin)
  #
  # FGR 12/02/2010 : X3SUIVI62489 (début)
  Call TEXTE(14607, U_HEXTOTXT) From OBJDIV     #Interventions
  Gosub U_TXTTOHEX From SUBAPSUTI
  # Pour les interventions je mets cette couleur. Je ne peux pas mettre la même que dans
  # l'agenda (FUNHDKAGD) parce que je n'ai pas la main là bas et que c'est traité comme un RdV
  U_SEQPUT = ' <categ Color="0xD4CCA5" Id="5">' + U_HEXTOTXT + '</categ>' : Gosub T_SEQPUT
  # FGR 12/02/2010 : X3SUIVI62489 (fin)
  #
  U_SEQPUT = '</Categs>' : Gosub T_SEQPUT
Return 

##############################################################################################
Funprog RENDMEMO(DDEBUT, SHDEBUT, DFIN, SHFIN, STYPE, SCHRONO)
Value Date DDEBUT
Value Char SHDEBUT
Value Date DFIN
Value Char SHFIN
Value Char STYPE
Value Char SCHRONO

Local Char SARENDRE(50)

  # FGR 07/01/2010 : X3SUIVI59683
  Raz SARENDRE
  SARENDRE = SARENDRE + format$("D:YYYYMMDD", DDEBUT)
  SARENDRE = SARENDRE + SHDEBUT
  SARENDRE = SARENDRE + format$("D:YYYYMMDD", DFIN)
  SARENDRE = SARENDRE + SHFIN
  SARENDRE = SARENDRE + STYPE
  SARENDRE = SARENDRE + SCHRONO
End SARENDRE

##############################################################################################
Subprog DECOUPEMEMO(SMEMO, DDEBUT, SHDEBUT, DFIN, SHFIN, STYPE, SCHRONO)
Value Char SMEMO
Variable Date DDEBUT
Variable Char SHDEBUT
Variable Date DFIN
Variable Char SHFIN
Variable Char STYPE
Variable Char SCHRONO

Local Char SCHAINE(50)(6)
Local Integer JOUR
Local Integer MOIS
Local Integer ANNEE

  # FGR 07/01/2010 : X3SUIVI59683
  #000000000011111111112222222222333333333344444
  #123456789012345678901234567890123456789012345
  #---------------------------------------------
  #111111112222333333334444566666666666666666666
  #---------------------------------------------
  #200912310000200912312359499999999999999999999
  #---------------------------------------------
  SCHAINE(0) = left$(SMEMO,8)
  SCHAINE(1) = mid$(SMEMO,9,4)
  SCHAINE(2) = mid$(SMEMO,13,8)
  SCHAINE(3) = mid$(SMEMO,21,4)
  SCHAINE(4) = mid$(SMEMO,25,1)
  SCHAINE(5) = mid$(SMEMO,26,len(SMEMO))
  #
  ANNEE = val(left$(SCHAINE(0),4))
  MOIS = val(mid$(SCHAINE(0),5,2))
  JOUR = val(mid$(SCHAINE(0),7,2))
  DDEBUT = gdat$(JOUR, MOIS, ANNEE)
  SHDEBUT = SCHAINE(1)
  ANNEE = val(left$(SCHAINE(2),4))
  MOIS = val(mid$(SCHAINE(2),5,2))
  JOUR = val(mid$(SCHAINE(2),7,2))
  DFIN = gdat$(JOUR, MOIS, ANNEE)
  SHFIN = SCHAINE(3)
  STYPE = SCHAINE(4)
  SCHRONO = SCHAINE(5)
End

##############################################################################################
$ECRITEVT
Local Date DDEBUT
Local Char SHDEBUT(GLONHM)
Local Date DFIN
Local Char SHFIN(GLONHM)
Local Char STYPE(1)
Local Char SCHRONO(GLONVCR)
Local Integer NI

  # FGR 07/01/2010 : X3SUIVI59683
  If ILSTEVT > 0 Then
    Sorta ILSTEVT SZLSTEVT   # FGR 12/02/2010 : X3SUIVI62489 : pas (ILSTEVT-1)
    For NI = 0 To ILSTEVT-1
      Call DECOUPEMEMO(SZLSTEVT(NI), DDEBUT, SHDEBUT, DFIN, SHFIN, STYPE, SCHRONO)
      If STYPE = "1" Then
        # Tâche
        Read [TSK]TSK0=SCHRONO
        [F:TSK]TSKSTR = DDEBUT
        [F:TSK]TSKDAT = DFIN
        Gosub WRITETSK
      Elsif STYPE = "2" Then
        # Appel
        Read [CLL]CLL0=SCHRONO
        [F:CLL]CLLDAT = DDEBUT
        [F:CLL]CLLHOU = SHDEBUT
        Gosub WRITECLL
      Elsif STYPE = "3" Then
        # Rendez-vous
        Read [BAP]APP0=SCHRONO
        [F:BAP]APTDAT = DDEBUT
        [F:BAP]APTHOU = SHDEBUT
        [F:BAP]APTDATEND = DFIN
        [F:BAP]APTHOUEND = SHFIN
        Gosub WRITEBAP
      Elsif STYPE = "4" Then
        # Campagne marketing
        Read [CMG]CMG0=SCHRONO
        [F:CMG]DATSTR = DDEBUT
        [F:BAP]APTHOU = SHDEBUT
        [F:CMG]DATEND = DFIN
        [F:BAP]APTHOUEND = SHFIN
        Gosub WRITECMG
      Elsif STYPE = "5" Then
        # Intervention
        Read [ITN]ITN0=SCHRONO
        [F:ITN]DAT = DDEBUT
        [F:ITN]HOU = SHDEBUT
        [F:ITN]DATEND = DFIN
        [F:ITN]HOUEND = SHFIN
        Gosub WRITEITN
      Endif
    Next NI
  Endif
Return

##############################################################################################
# Section des données
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$SEC_LINES
  U_SEQPUT = ' <Lines>' : Gosub T_SEQPUT
  Gosub EXTRACTCMG    # FLORENT EVOL_MK
  If SZCRMREP <> "" Then
    Gosub EXTRACTBAP
    Gosub EXTRACTCLL
    Gosub EXTRACTTSK
  Endif
  If SZCRMUSR <> "" Then
    Gosub EXTRACTITN
  Endif
  Gosub ECRITEVT
  U_SEQPUT = '  </Lines>' : Gosub T_SEQPUT
Return

##############################################################################################
# Initialisations
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#    info: Pour ne pas interferer avec les autres programmes, les variables commencent par 'T'
$T_INIT
Local Char SZBUFFTOFILL(250)
Local Char SZLIBELLE(250)
Local Char SZCODE
Local Integer ICOLNUM
Local Integer IOVERDAY
Local Date DOVERDAT
Local Date DOVERDATEND
Local Char SZOVERHOUEND
Local Integer ITER2
Local Date DDATSTR
Local Date DDATEND
Local Integer IDONFLG
Local Char SZCRMREP
Local Char SZCRMUSR
Local Char SZROLE(250)
Local Char SZWHERE(250)(20)
Local Integer ILIGNEWHERE
Local Char SZLSTEVT(50)(1000)   # FGR 07/01/2010 : X3SUIVI59683
Local Integer ILSTEVT           # FGR 07/01/2010 : X3SUIVI59683

  # Table Interventions
  If !clalev([F:TSK]) : Local File TASK [TSK] : Endif
  If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
  If !clalev([F:BAP]) : Local File BAPPOINT [BAP] : Endif
  If !clalev([F:ITN]) : Local File INTERVEN [ITN] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:CMG]) : Local File CMARKETING [CMG] : Endif   # FLORENT EVOL_MK
  #
  SZCRMUSR = GUSER
  Call PARAMUTIL("AUSCRMF", SZCRMREP, SZCRMUSR, "") From SUBAUS
  IDONFLG = 2
  DDATSTR = date$
  DDATEND = date$ + 7
  Raz SZROLE 
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZLSTEVT   # FGR 07/01/2010 : X3SUIVI59683
  ILSTEVT = 0    # FGR 07/01/2010 : X3SUIVI59683
  # Actions    
  #    info: TQ pour T:prefixe traitement, Q:donnée issue de la Query string
Local Char TQ_ACTFIRST(10) : TQ_ACTINIT = 'INIT'                 # En 1er appel
Local Char TQ_ACTREFRESH(10) : TQ_ACTREFRESH = 'REFRESH'         # En 1er appel
  # Paramètres sources de données
  #    info: TC pour T:prefixe traitement, C: constante
Local Char TC_P1(6): TC_P1 = "DAYBEF"                            # code - Nb de jour avant
Local Integer T_P1NUM                                            # valeur 1er paramètre en format numérique
Local Char TC_P2(6) : TC_P2 = "DAYAFT"                           # code et valeur 2ième paramètre - Nb de jour après
Local Integer T_P2NUM                                            # valeur 2ième paramètre en format numérique
  # Travail
  #    info: TC pour T:prefixe traitement, W: travail
Local Integer TW_I
Local Char TW_STR1(100), TW_URL(100)
Return

##############################################################################################
# Ecriture XML 
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$T_SEQPUT
  Gosub U_PUT From SUBAPSUTI
Return

##############################################################################################
# Paramètres sources de données 
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$T_GETSRCPAR
  # Paramètre: P1  Nb jour avant
  U_PARCODE = TC_P1 : Gosub U_PARSRCREAD From SUBAPSUTI : If U_ERR = UC_ERRG : Return : Endif 
  If U_PAREXIST and U_PARVALTYP = 3 Then
    T_P1NUM = U_PARVALNUM
    If T_P1NUM > 400 Then
      T_P1NUM = 400
      U_MESCODE = "TRTPARMAX" : U_MESP1 = U_PARCODE - "(0-400)" : U_MESP2 = U_PARVAL : U_ERR = UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
      U_MESCODE = "TRTPARDEF" : U_MESP1 = U_PARCODE : U_MESP2 = "400" : U_ERR = UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
    Elsif T_P1NUM < 0 Then
      T_P1NUM = 0
      U_MESCODE = "TRTPARMAX" : U_MESP1 = U_PARCODE - "(0-400)" : U_MESP2 = U_PARVAL : U_ERR = UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
      U_MESCODE = "TRTPARDEF" : U_MESP1 = U_PARCODE : U_MESP2 = "0" : U_ERR = UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
    Endif
  Else
    U_MESCODE = "TRTPARERR" : U_MESP1 = U_PARCODE - "(0-400)" : U_MESP2 = U_PARVAL : U_ERR = UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
    U_MESCODE = "TRTPARDEF" : U_MESP1 = U_PARCODE : U_MESP2 = "2" : U_ERR = UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
    T_P1NUM = 2    # defaut
  Endif
  DDATSTR = date$ - T_P1NUM
  # Paramètre: P2  Nb jour après
  U_PARCODE = TC_P2 : Gosub U_PARSRCREAD From SUBAPSUTI : If U_ERR = UC_ERRG : Return : Endif 
  If U_PAREXIST and U_PARVALTYP = 3 Then
    T_P2NUM = U_PARVALNUM
    If T_P2NUM > 400 Then
      T_P2NUM = 400
      U_MESCODE = "TRTPARMAX" : U_MESP1 = U_PARCODE - "(0-400)" : U_MESP2 = U_PARVAL : U_ERR = UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
      U_MESCODE = "TRTPARDEF" : U_MESP1 = U_PARCODE : U_MESP2 = "400" : U_ERR = UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
    Elsif T_P2NUM < 0 Then
      T_P2NUM = 0
      U_MESCODE = "TRTPARMAX" : U_MESP1 = U_PARCODE - "(0-400)" : U_MESP2 = U_PARVAL : U_ERR = UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
      U_MESCODE = "TRTPARDEF" : U_MESP1 = U_PARCODE : U_MESP2 = "0" : U_ERR = UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
    Endif
  Else
    U_MESCODE = "TRTPARERR" : U_MESP1 = U_PARCODE - "(0-400)" : U_MESP2 = U_PARVAL : U_ERR = UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
    U_MESCODE = "TRTPARDEF" : U_MESP1 = U_PARCODE : U_MESP2 = "7" : U_ERR = UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
    T_P2NUM = 7    # defaut
  Endif
  DDATEND = date$ + T_P2NUM
Return

################################################################################
# Extraction des rendez-vous
################################################################################
$EXTRACTBAP
  #Extraction des rendez-vous
  #Sélection des rendez vous
  ILIGNEWHERE = 0
  Raz SZWHERE
  SZWHERE(ILIGNEWHERE) = "find(SZCRMREP,[F:BAP]APTREPNUM)<>0"
  ILIGNEWHERE += 1
  SZWHERE(ILIGNEWHERE) = " and (([F:BAP]APTDATX<>[00/00/00]) and ([F:BAP]APTDATX>=DDATSTR))"
  ILIGNEWHERE += 1
  SZWHERE(ILIGNEWHERE) = " and (([F:BAP]APTDATX<>[00/00/00]) and ([F:BAP]APTDATX<=DDATEND))"
  ILIGNEWHERE += 1
  # FGR 18/05/2009 : X3SUIVI48957 (debut)
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = " and" - SZROLE
    ILIGNEWHERE += 1
  Endif
  # FGR 18/05/2009 : X3SUIVI48957 (debut)
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "BAP") From CRMUTIL150
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [BAP] Where evalue(SZWHERE) Order By [F:BAP]APTDATX Asc; [F:BAP]APTHOU Asc
  Else
    Filter [BAP] Order By [F:BAP]APTDATX Asc; [F:BAP]APTHOU Asc
  Endif
  For [BAP] Hint Key APP4
    For ITER2 = 0 To dim([F:BAP]APTREPNUM)-1
      If [F:BAP]APTREPNUM(ITER2) <> "" Then
        If [F:BAP]APTREPNUM(ITER2) = SZCRMREP Then
          If [F:BAP]APTDAT = [00/00/00] Then
            #Gestion des rendez-vous en date floue
            [F:BAP]APTDAT = [F:BAP]APTDATX
            [F:BAP]APTDATEND = [F:BAP]APTDATX
            [F:BAP]APTHOU = "0000"
            [F:BAP]APTHOUEND = "0000"
            #Gosub WRITEBAP # FGR 07/01/2010 : X3SUIVI59683
            Gosub MEMOBAP   # FGR 07/01/2010 : X3SUIVI59683
          Else
            #Gestion des rendez-vous s'étalant sur plusieurs jours.
            IOVERDAY = 0
            DOVERDAT = [F:BAP]APTDAT
            If [F:BAP]APTDATEND = [00/00/00] Then
              DOVERDATEND = [F:BAP]APTDAT
            Else
              If [F:BAP]APTDATEND < [F:BAP]APTDAT Then
                DOVERDATEND = [F:BAP]APTDAT
              Else
                DOVERDATEND = [F:BAP]APTDATEND
              Endif
            Endif
            SZOVERHOUEND = [F:BAP]APTHOUEND
            While 1
              If DOVERDATEND = [F:BAP]APTDAT Then
                If IOVERDAY Then
                  [F:BAP]APTHOU = "0000"
                  [F:BAP]APTDATEND = [F:BAP]APTDAT
                  [F:BAP]APTHOUEND = SZOVERHOUEND
                Endif
                #Gosub WRITEBAP # FGR 07/01/2010 : X3SUIVI59683
                Gosub MEMOBAP   # FGR 07/01/2010 : X3SUIVI59683
                Break
              Else
                If IOVERDAY Then
                  [F:BAP]APTHOU = "0000"
                  [F:BAP]APTDATEND = [F:BAP]APTDAT
                  [F:BAP]APTHOUEND = "0000"
                Else
                  [F:BAP]APTDATEND = [F:BAP]APTDAT
                  [F:BAP]APTHOUEND = "0000"
                Endif
                #Gosub WRITEBAP  # FGR 07/01/2010 : X3SUIVI59683
                Gosub MEMOBAP    # FGR 07/01/2010 : X3SUIVI59683
              Endif
              [F:BAP]APTDAT = [F:BAP]APTDAT + 1
              IOVERDAY += 1
            Wend
          Endif
          Break
        Endif
      Endif
    Next
  Next
  Filter [BAP]
Return

###############################################################
# Mémorise BAP dans tableau pour trie tout evt confondus
###############################################################
$MEMOBAP
  # FGR 07/01/2010 : X3SUIVI59683
  If ILSTEVT < dim(SZLSTEVT) Then
    SZLSTEVT(ILSTEVT) = func RENDMEMO([F:BAP]APTDAT, [F:BAP]APTHOU, [F:BAP]APTDATEND, [F:BAP]APTHOUEND, "3", [F:BAP]APTNUM)
    ILSTEVT += 1
  Endif
Return

###############################################################
# Ecriture XML d'un rendez-vous
###############################################################
$WRITEBAP
  ICOLNUM = 1
  U_SEQPUT = '  <Line>' : Gosub T_SEQPUT
  # Type
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>3</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>3</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Chrono rdv
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7" ' 
  #   ajout du lien sur l'intervention        (I8)
  Call GETURLCLEPRIM("BAP", [F:BAP]APTNUM, M_MODE, TW_URL) From SUBAPSOBJ     # JPJ E25050 / 26760
  If TW_URL <> "" Then
    U_HEXTOTXT = TW_URL : Gosub U_TXTTOHEX From SUBAPSUTI
    U_SEQPUT += ' X3Link="' + U_TXTTOHEX + '" '
  Endif
  U_SEQPUT +=  ' >': Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:BAP]APTNUM + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + [F:BAP]APTNUM + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Date deb
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:BAP]APTDAT + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$(GFMD,[F:BAP]APTDAT) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Heure deb
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:BAP]APTHOU + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$("K:##[:]##",[F:BAP]APTHOU) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Date fin
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:BAP]APTDATEND + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$(GFMD,[F:BAP]APTDATEND) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Heure fin
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:BAP]APTHOUEND + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$("K:##[:]##",[F:BAP]APTHOUEND) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Client
  Read [BPR]BPR0=[F:BAP]APTCMP
  If fstat = 0 Then
    SZCODE = [F:BAP]APTCMP
    SZLIBELLE = [F:BPR]BPRNAM
  Else
    SZCODE = [F:BAP]APTCMP
    SZLIBELLE = ""
  Endif
  Call CRMAFFAGD(SZCODE, SZLIBELLE, SZBUFFTOFILL) From CRMUTIL150
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Interlocuteur
  If [F:BAP]APTCCNNUM(0) = "" Then
    SZCODE = ""
    SZLIBELLE = ""
  Else
    Read [AIN]AIN0=[F:BAP]APTCCNNUM(0)
    If fstat Then
      SZCODE = [F:BAP]APTCCNNUM(0)
      SZLIBELLE = ""
    Else
      SZCODE = [F:BAP]APTCCNNUM(0)
      Call BUILDFULNAM("AIN", SZLIBELLE) From CRMUTIL140
    Endif
  Endif
  Call CRMAFFAGD(SZCODE, SZLIBELLE, SZBUFFTOFILL) From CRMUTIL150
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Catégorie
  If [F:BAP]APTTYP = "" Then
    SZBUFFTOFILL = ""
  Else
    Call GET_LIB(433, [F:BAP]APTTYP, SZBUFFTOFILL) From CRM_UTIL
  Endif
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Objet du rdv
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = [F:BAP]APTOBJ
  If len(U_HEXTOTXT) > 200 Then
    U_HEXTOTXT = left$(U_HEXTOTXT,200) + "..."
  Endif        # JPJ
  Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Effectué
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = num$([F:BAP]APTDON) : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  If [F:BAP]APTDON = 0 Then
    U_SEQPUT = '     <X3Value>' + mess(1,1,1) + '</X3Value>' : Gosub T_SEQPUT
  Else
    U_SEQPUT = '     <X3Value>' + mess([F:BAP]APTDON,1,1) + '</X3Value>' : Gosub T_SEQPUT
  Endif
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # fin de ligne
  U_SEQPUT = '  </Line>' : Gosub T_SEQPUT
Return

################################################################################
# Extraction des interventions
################################################################################
$EXTRACTITN
  ILIGNEWHERE = 0
  Raz SZWHERE
  SZWHERE(ILIGNEWHERE) = "([F:ITN]REP=SZCRMUSR)"
  ILIGNEWHERE += 1
  SZWHERE(ILIGNEWHERE) = " and ([F:ITN]DATX<>[00/00/00] and [F:ITN]DATX>=DDATSTR)"
  ILIGNEWHERE += 1
  SZWHERE(ILIGNEWHERE) = " and ([F:ITN]DATX<>[00/00/00] and [F:ITN]DATX<=DDATEND)"
  ILIGNEWHERE += 1
  # FGR 18/05/2009 : X3SUIVI48957 (debut)
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = " and" - SZROLE 
    ILIGNEWHERE += 1
  Endif
  # FGR 18/05/2009 : X3SUIVI48957 (fin)
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "ITN") From CRMUTIL150
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [ITN] Where evalue(SZWHERE) Order By [F:ITN]DATX Asc; [F:ITN]HOU Asc
  Else
    Filter [ITN] Order By [F:ITN]DATX Asc; [F:ITN]HOU Asc
  Endif
  For [ITN] Hint Key ITN1
    If [F:ITN]DAT = [00/00/00] Then
      #Gestion en date floue
      [F:ITN]DAT = [F:ITN]DATX
      [F:ITN]DATEND = [F:ITN]DATX
      [F:ITN]HOU = "0000"
      [F:ITN]HOUEND = "0000"
      #Gosub WRITEITN  # FGR 07/01/2010 : X3SUIVI59683
      Gosub MEMOITN    # FGR 07/01/2010 : X3SUIVI59683
    Else
      #Gestion des interventions s'étalant sur plusieurs jours.
      IOVERDAY = 0
      DOVERDAT = [F:ITN]DAT
      If [F:ITN]DATEND = [00/00/00] Then
        DOVERDATEND = [F:ITN]DAT
      Else
        If [F:ITN]DATEND < [F:ITN]DAT Then
          DOVERDATEND = [F:ITN]DAT
        Else
          DOVERDATEND = [F:ITN]DATEND
        Endif
      Endif
      SZOVERHOUEND = [F:ITN]HOUEND
      While 1
        If DOVERDATEND = [F:ITN]DAT Then
          If IOVERDAY Then
            [F:ITN]HOU = "0000"
            [F:ITN]DATEND = [F:ITN]DAT
            [F:ITN]HOUEND = SZOVERHOUEND
          Endif
          #Gosub WRITEITN  # FGR 07/01/2010 : X3SUIVI59683
          Gosub MEMOITN    # FGR 07/01/2010 : X3SUIVI59683
          Break
        Else
          If IOVERDAY Then
            [F:ITN]HOU = "0000"
            [F:ITN]DATEND = [F:ITN]DAT
            [F:ITN]HOUEND = "0000"
          Else
            [F:ITN]DATEND = [F:ITN]DAT
            [F:ITN]HOUEND = "0000"
          Endif
          #Gosub WRITEITN  # FGR 07/01/2010 : X3SUIVI59683
          Gosub MEMOITN    # FGR 07/01/2010 : X3SUIVI59683
        Endif
        [F:ITN]DAT = [F:ITN]DAT + 1
        IOVERDAY += 1
      Wend
    Endif
  Next
  Filter [ITN]
Return

###############################################################
# Mémorise ITN dans tableau pour trie tout evt confondus
###############################################################
$MEMOITN
  # FGR 07/01/2010 : X3SUIVI59683
  If ILSTEVT < dim(SZLSTEVT) Then
    SZLSTEVT(ILSTEVT) = func RENDMEMO([F:ITN]DAT, [F:ITN]HOU, [F:ITN]DATEND, [F:ITN]HOUEND, "5", [F:ITN]NUM)
    ILSTEVT += 1
  Endif
Return

###############################################################
# Ecriture XML d'une intervention
###############################################################
$WRITEITN
  ICOLNUM = 1
  U_SEQPUT = '  <Line>' : Gosub T_SEQPUT
  # Type
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>5</X3IntVal>' : Gosub T_SEQPUT                     # FGR 12/02/2010 : X3SUIVI62489 : 5 pas 3
  U_SEQPUT = '     <X3Value>5</X3Value>' : Gosub T_SEQPUT                       # FGR 12/02/2010 : X3SUIVI62489 : 5 pas 3
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Chrono rdv
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7" ' 
  #   ajout du lien sur l'intervention        (I8)
  Call GETURLCLEPRIM("ITN", [F:ITN]NUM, M_MODE, TW_URL) From SUBAPSOBJ     # JPJ E2050 / 26760
  If TW_URL <> "" Then
    U_HEXTOTXT = TW_URL : Gosub U_TXTTOHEX From SUBAPSUTI
    U_SEQPUT += ' X3Link="' + U_TXTTOHEX + '" '
  Endif
  U_SEQPUT +=  ' >' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:ITN]NUM + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + [F:ITN]NUM + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Date deb
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:ITN]DAT + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$(GFMD,[F:ITN]DAT) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Heure deb
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:ITN]HOU + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$("K:##[:]##",[F:ITN]HOU) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Date fin
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:ITN]DATEND + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$(GFMD,[F:ITN]DATEND) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Heure fin
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:ITN]HOUEND + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$("K:##[:]##",[F:ITN]HOUEND) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Client
  Read [BPR]BPR0=[F:ITN]BPC
  If fstat = 0 Then
    SZCODE = [F:ITN]BPC
    SZLIBELLE = [F:BPR]BPRNAM
  Else
    SZCODE = [F:ITN]BPC
    SZLIBELLE = ""
  Endif
  Call CRMAFFAGD(SZCODE, SZLIBELLE, SZBUFFTOFILL) From CRMUTIL150
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Interlocuteur
  SZCODE = [F:ITN]CCN
  If [F:ITN]CCN = "" Then
    SZLIBELLE = ""
  Else
    Read [AIN]AIN0=[F:ITN]CCN
    If fstat Then
      SZLIBELLE = ""
    Else
      Call BUILDFULNAM("AIN", SZLIBELLE) From CRMUTIL140
    Endif
  Endif
  Call CRMAFFAGD(SZCODE, SZLIBELLE , SZBUFFTOFILL) From CRMUTIL150
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Catégorie
  If [F:ITN]TYP = "" Then
    SZBUFFTOFILL = ""
  Else
    Call GET_LIB(407, [F:ITN]TYP, SZBUFFTOFILL) From CRM_UTIL
  Endif
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Objet du rdv
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = [F:ITN]OBJ 
  If len(U_HEXTOTXT) > 200 Then
    U_HEXTOTXT = left$(U_HEXTOTXT,200) + "..."
  Endif    #jpj
  Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Effectué
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = num$([F:ITN]DON) : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  If [F:ITN]DON = 0 Then
    U_SEQPUT = '     <X3Value>' + mess(1,1,1) + '</X3Value>' : Gosub T_SEQPUT
  Else
    U_SEQPUT = '     <X3Value>' + mess([F:ITN]DON,1,1) + '</X3Value>' : Gosub T_SEQPUT
  Endif
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # fin de ligne
  U_SEQPUT = '  </Line>' : Gosub T_SEQPUT
Return

################################################################################
# Extraction des appels
################################################################################
$EXTRACTCLL
  #Sélection des appels
  ILIGNEWHERE = 0
  Raz SZWHERE
  SZWHERE(ILIGNEWHERE) = "[F:CLL]CLLREP=SZCRMUSR"
  ILIGNEWHERE += 1
  SZWHERE(ILIGNEWHERE) = " and (([F:CLL]CLLDATX <> [00/00/00]) and ([F:CLL]CLLDATX >= DDATSTR))"
  ILIGNEWHERE += 1
  SZWHERE(ILIGNEWHERE) = " and (([F:CLL]CLLDATX > [00/00/00]) and ([F:CLL]CLLDATX <= DDATEND))"
  ILIGNEWHERE += 1
  # FGR 18/05/2009 : X3SUIVI48957 (debut)
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = " and" - SZROLE 
    ILIGNEWHERE += 1
  Endif
  # FGR 18/05/2009 : X3SUIVI48957 (debut)
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "CLL") From CRMUTIL150
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [CLL] Where evalue(SZWHERE) Order By [F:CLL]CLLDATX Asc; [F:CLL]CLLHOU Asc
  Else
    Filter [CLL] Order By [F:CLL]CLLDATX Asc; [F:CLL]CLLHOU Asc
  Endif
  For [CLL] Hint Key CLL4
    If [F:CLL]CLLDAT = [00/00/00] Then
      #Gestion en date floue
      [F:CLL]CLLDAT = [F:CLL]CLLDATX
      [F:CLL]CLLHOU = "0000"
    Endif
    #Gosub WRITECLL  # FGR 07/01/2010 : X3SUIVI59683
    Gosub MEMOCLL    # FGR 07/01/2010 : X3SUIVI59683
  Next
  Filter [CLL]
Return

###############################################################
# Mémorise CLL dans tableau pour trie tout evt confondus
###############################################################
$MEMOCLL
  # FGR 07/01/2010 : X3SUIVI59683
  If ILSTEVT < dim(SZLSTEVT) Then
    SZLSTEVT(ILSTEVT) = func RENDMEMO([F:CLL]CLLDAT, [F:CLL]CLLHOU, [F:CLL]CLLDAT, [F:CLL]CLLHOU, "2", [F:CLL]CLLNUM)
    ILSTEVT += 1
  Endif
Return

###############################################################
# Ecriture XML d'un appel
###############################################################
$WRITECLL
  ICOLNUM = 1
  U_SEQPUT = '  <Line>' : Gosub T_SEQPUT
  # Type
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>2</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>2</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Chrono rdv
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7" ' 
  #   ajout du lien sur l'intervention        (I8)
  Call GETURLCLEPRIM("CLL", [F:CLL]CLLNUM, M_MODE, TW_URL) From SUBAPSOBJ     # JPJ E25050 / 26760
  If TW_URL <> "" Then
    U_HEXTOTXT = TW_URL : Gosub U_TXTTOHEX From SUBAPSUTI
    U_SEQPUT+=' X3Link="' + U_TXTTOHEX + '" '
  Endif
  U_SEQPUT +=  ' >' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:CLL]CLLNUM + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + [F:CLL]CLLNUM + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Date deb
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:CLL]CLLDAT + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$(GFMD,[F:CLL]CLLDAT) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Heure deb
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:CLL]CLLHOU + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$("K:##[:]##",[F:CLL]CLLHOU) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Date fin
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal></X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value></X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Heure fin
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal></X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value></X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Client
  SZCODE=[F:CLL]CLLCMP
  Read [BPR]BPR0=[F:CLL]CLLCMP
  If fstat = 0 Then
    SZLIBELLE = [F:BPR]BPRNAM
  Else
    SZLIBELLE = ""
  Endif
  Call CRMAFFAGD(SZCODE, SZLIBELLE, SZBUFFTOFILL) From CRMUTIL150
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Interlocuteur
  SZCODE=[F:CLL]CLLCCN
  If [F:CLL]CLLCCN = "" Then
    SZLIBELLE = ""
  Else
    Read [AIN]AIN0=[F:CLL]CLLCCN
    If fstat Then
      SZLIBELLE = ""
    Else
      Call BUILDFULNAM("AIN", SZLIBELLE) From CRMUTIL140
    Endif
  Endif
  Call CRMAFFAGD(SZCODE, SZLIBELLE, SZBUFFTOFILL) From CRMUTIL150
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Catégorie
  If [F:CLL]CLLCAT = "" Then
    SZBUFFTOFILL = ""
  Else
    Call GET_LIB(432, [F:CLL]CLLCAT, SZBUFFTOFILL) From CRM_UTIL
  Endif
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Objet du rdv
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = [F:CLL]CLLOBJ 
  If len(U_HEXTOTXT) > 200 Then
    U_HEXTOTXT = left$(U_HEXTOTXT,200) + "..."
  Endif        # jpj
  Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Effectué
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = num$([F:CLL]CLLDON) : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  If [F:CLL]CLLDON = 0 Then
    U_SEQPUT = '     <X3Value>' + mess(1,1,1) + '</X3Value>' : Gosub T_SEQPUT
  Else
    U_SEQPUT = '     <X3Value>' + mess([F:CLL]CLLDON,1,1) + '</X3Value>' : Gosub T_SEQPUT
  Endif
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # fin de ligne
  U_SEQPUT = '  </Line>' : Gosub T_SEQPUT
Return

################################################################################
# Extraction des tâches
################################################################################
$EXTRACTTSK
  #Sélection des taches
  ILIGNEWHERE = 0
  Raz SZWHERE
  SZWHERE(ILIGNEWHERE) = "[F:TSK]TSKREP=SZCRMREP"
  ILIGNEWHERE += 1
  SZWHERE(ILIGNEWHERE) = " and (([F:TSK]TSKDAT<> [00/00/00]) and ([F:TSK]TSKDAT>=DDATSTR))"
  ILIGNEWHERE += 1
  SZWHERE(ILIGNEWHERE) = " and (([F:TSK]TSKDAT> [00/00/00]) and ([F:TSK]TSKDAT<=DDATEND))"
  ILIGNEWHERE += 1
  # FGR 18/05/2009 : X3SUIVI48957 (debut)
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE 
    ILIGNEWHERE += 1
  Endif
  # FGR 18/05/2009 : X3SUIVI48957 (debut)
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "TSK") From CRMUTIL150
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [TSK] Where evalue(SZWHERE) Order By [F:TSK]TSKDAT Asc
  Else
    Filter [TSK] Order By [F:TSK]TSKDAT Asc
  Endif
  For [TSK] Hint Key TSK4
    #Gosub WRITETSK  # FGR 07/01/2010 : X3SUIVI59683
    Gosub MEMOTSK    # FGR 07/01/2010 : X3SUIVI59683
  Next
  Filter [TSK]
Return

###############################################################
# Mémorise TSK dans tableau pour trie tout evt confondus
###############################################################
$MEMOTSK
  # FGR 07/01/2010 : X3SUIVI59683
  If ILSTEVT < dim(SZLSTEVT) Then
    SZLSTEVT(ILSTEVT) = func RENDMEMO([F:TSK]TSKSTR, "0000", [F:TSK]TSKDAT, "0000", "1", [F:TSK]TSKNUM)
    ILSTEVT += 1
  Endif
Return

###############################################################
# Ecriture XML d'une tâche
###############################################################
$WRITETSK
  ICOLNUM = 1
  U_SEQPUT = '  <Line>' : Gosub T_SEQPUT
  # Type
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>1</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>1</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Chrono rdv
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7" ' 
  #   ajout du lien sur l'intervention        (I8)
  Call GETURLCLEPRIM("TSK", [F:TSK]TSKNUM, M_MODE, TW_URL) From SUBAPSOBJ     # JPJ E25050 / 26760
  If TW_URL <> "" Then
    U_HEXTOTXT = TW_URL : Gosub U_TXTTOHEX From SUBAPSUTI
    U_SEQPUT += ' X3Link="' + U_TXTTOHEX + '" '
  Endif
  U_SEQPUT +=  ' >' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:TSK]TSKNUM + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + [F:TSK]TSKNUM + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Date deb
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:TSK]TSKSTR + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$(GFMD,[F:TSK]TSKSTR) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Heure deb
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>0000</X3IntVal>' : Gosub T_SEQPUT                     # FGR 06/01/2010 : X3SUIVI59683 : mettre une heure non nulle
  U_SEQPUT = '     <X3Value>00:00</X3Value>' : Gosub T_SEQPUT                      # FGR 06/01/2010 : X3SUIVI59683 : mettre une heure non nulle
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Date fin
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:TSK]TSKDAT + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$(GFMD,[F:TSK]TSKDAT) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Heure fin
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>0000</X3IntVal>' : Gosub T_SEQPUT                     # FGR 06/01/2010 : X3SUIVI59683 : mettre une heure non nulle
  U_SEQPUT = '     <X3Value>00:00</X3Value>' : Gosub T_SEQPUT                      # FGR 06/01/2010 : X3SUIVI59683 : mettre une heure non nulle
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Client
  SZCODE=[F:TSK]TSKCMP
  Read [BPR]BPR0=[F:TSK]TSKCMP
  If fstat = 0 Then
    SZLIBELLE = [F:BPR]BPRNAM
  Else
    SZLIBELLE = ""
  Endif
  Call CRMAFFAGD(SZCODE, SZLIBELLE, SZBUFFTOFILL) From CRMUTIL150
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Interlocuteur
  SZCODE = [F:TSK]TSKCCN
  If [F:TSK]TSKCCN = ""
    SZLIBELLE = ""
  Else
    Read [AIN]AIN0=[F:TSK]TSKCCN
    If fstat Then
      SZLIBELLE = ""
    Else
      Call BUILDFULNAM("AIN", SZLIBELLE) From CRMUTIL140
    Endif
  Endif
  Call CRMAFFAGD(SZCODE, SZLIBELLE, SZBUFFTOFILL) From CRMUTIL150
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Catégorie
  If [F:TSK]TSKTYP = "" Then
    SZBUFFTOFILL = ""
  Else
    Call GET_LIB(431, [F:TSK]TSKTYP, SZBUFFTOFILL) From CRM_UTIL
  Endif
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Objet du rdv
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = [F:TSK]TSKDES : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Effectué
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = num$([F:TSK]TSKDON) : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  If [F:TSK]TSKDON = 0 Then
    U_SEQPUT = '     <X3Value>' + mess(1,1,1) + '</X3Value>' : Gosub T_SEQPUT
  Else
    U_SEQPUT = '     <X3Value>' + mess([F:TSK]TSKDON,1,1) + '</X3Value>' : Gosub T_SEQPUT
  Endif
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # fin de ligne
  U_SEQPUT = '  </Line>' : Gosub T_SEQPUT
Return

#######################
# FLORENT EVOL_MK Début
#######################
################################################################################
# Extraction des campagnes marketing
################################################################################
$EXTRACTCMG
  #Return
  #Extraction des campagnes marketing
  #Sélection des campagnes marketing
  ILIGNEWHERE = 0
  Raz SZWHERE
  SZWHERE(ILIGNEWHERE) = " ([F:CMG]DATEND>=DDATSTR and [F:CMG]DATSTR<=DDATEND)"
  ILIGNEWHERE += 1
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("FCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = " and" - SZROLE
    ILIGNEWHERE += 1
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "CMG") From CRMUTIL150
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [CMG] Where evalue(SZWHERE) Order By [F:CMG]DATSTR Asc
  Else
    Filter [CMG] Order By [F:CMG]DATSTR Asc
  Endif
  For [CMG] Hint Key CMG1
    #Gestion des rendez-vous s'étalant sur plusieurs jours.
    DOVERDAT = max([F:CMG]DATSTR, DDATSTR)
    DOVERDATEND = min([F:CMG]DATEND, DDATEND)
    [F:CMG]DATSTR = DOVERDAT
    [F:BAP]APTHOU = "0000"
    [F:BAP]APTHOUEND = "0100"
    While 1
      If DOVERDATEND = [F:CMG]DATSTR Then
        [F:CMG]DATEND = [F:CMG]DATSTR
        [F:BAP]APTHOU = "2358"
        [F:BAP]APTHOUEND = "2359"
        #Gosub WRITECMG  # FGR 07/01/2010 : X3SUIVI59683
        Gosub MEMOCMG    # FGR 07/01/2010 : X3SUIVI59683
        Break
      Else
        [F:CMG]DATEND = [F:CMG]DATSTR
        [F:BAP]APTHOU = "0000"
        [F:BAP]APTHOUEND = "0001"
        #Gosub WRITECMG  # FGR 07/01/2010 : X3SUIVI59683
        Gosub MEMOCMG    # FGR 07/01/2010 : X3SUIVI59683
      Endif
      [F:CMG]DATSTR = [F:CMG]DATSTR + 1
    Wend
  Next
  Filter [CMG]
Return

###############################################################
# Mémorise CMG dans tableau pour trie tout evt confondus
###############################################################
$MEMOCMG
  # FGR 07/01/2010 : X3SUIVI59683
  If ILSTEVT < dim(SZLSTEVT) Then
    SZLSTEVT(ILSTEVT) = func RENDMEMO([F:CMG]DATSTR, [F:BAP]APTHOU, [F:CMG]DATEND, [F:BAP]APTHOUEND, "4", [F:CMG]NUM)
    ILSTEVT += 1
  Endif
Return

###############################################################
# Ecriture XML d'une campagne marketing
###############################################################
$WRITECMG
  ICOLNUM = 1
  U_SEQPUT = '  <Line>' : Gosub T_SEQPUT
  # Type
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>4</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>4</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Chrono rdv
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7" ' 
  #   ajout du lien sur l'intervention        (I8)
  Call GETURLCLEPRIM("CMG", [F:CMG]NUM, M_MODE, TW_URL) From SUBAPSOBJ     # JPJ E25050 / 26760
  If TW_URL <> "" Then
    U_HEXTOTXT = TW_URL : Gosub U_TXTTOHEX From SUBAPSUTI
    U_SEQPUT += ' X3Link="' + U_TXTTOHEX + '" '
  Endif
  U_SEQPUT +=  ' >': Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:CMG]NUM + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + [F:CMG]NUM + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Date deb
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:CMG]DATSTR + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$(GFMD,[F:CMG]DATSTR) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Heure deb
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:BAP]APTHOU + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$("K:##[:]##",[F:BAP]APTHOU) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Date fin
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:CMG]DATEND + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$(GFMD,[F:CMG]DATEND) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Heure fin
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3IntVal>' + [F:BAP]APTHOUEND + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + format$("K:##[:]##",[F:BAP]APTHOUEND) + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Client
  SZCODE = ""
  SZLIBELLE = ""
  SZBUFFTOFILL = ""
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Interlocuteur
  SZCODE = ""
  SZLIBELLE = ""
  SZBUFFTOFILL = ""
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Catégorie
  SZBUFFTOFILL = ""
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = SZBUFFTOFILL : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Objet du rdv
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = [F:CMG]TTR
  If len(U_HEXTOTXT) > 200 Then
    U_HEXTOTXT = left$(U_HEXTOTXT,200) + "..."
  Endif        # JPJ
  Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  U_SEQPUT = '     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # Effectué
  U_SEQPUT = '    <Col Num="' + num$(ICOLNUM) + '" X3Type="7">' : Gosub T_SEQPUT
  U_HEXTOTXT = num$([F:CMG]CLO) : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
  U_SEQPUT = '     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
  If [F:CMG]CLO = 0 Then
    U_SEQPUT = '     <X3Value>' + mess(1,1,1) + '</X3Value>' : Gosub T_SEQPUT
  Else
    U_SEQPUT = '     <X3Value>' + mess([F:CMG]CLO,1,1) + '</X3Value>' : Gosub T_SEQPUT
  Endif
  U_SEQPUT = '    </Col>' : Gosub T_SEQPUT
  ICOLNUM += 1
  # fin de ligne
  U_SEQPUT = '  </Line>' : Gosub T_SEQPUT
Return
#######################
# FLORENT EVOL_MK Fin
#######################
