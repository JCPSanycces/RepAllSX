#<AdxTL>@(#)0.0.0.0 $Revision$

#**
#* _REQUIRE_ROW - requires at least one row in the collection
#*    Return found status
#*      [V]CST_AFALSE = collection is empty
#*      [V]CST_ATRUE = at least 1 row found
#*
#*
#* @param MY_COLLECTION - Collection to be examined (this.COLxxx)
#* @param MESSAGE - Message returned if collection is empty
#*!
Funprog _REQUIRE_ROW(MY_COLLECTION,MESSAGE)
Variable Instance MY_COLLECTION(1..) Using OBJECT
Variable Char MESSAGE

Local Integer FOUND
[L]FOUND=[V]CST_AFALSE
[L]MESSAGE = AVOID.ACHAR

  For ILINE=1 To maxtab(MY_COLLECTION)
    If MY_COLLECTION(ILINE)<>null
      If !find(MY_COLLECTION(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
        [L]FOUND=[V]CST_ATRUE
        Break
      Endif
    Endif
  Next
  If [L]FOUND=[V]CST_AFALSE
    # There must be at least one line
    [L]MESSAGE = mess(178,123,1)
  Endif
End [L]FOUND

#**
#* _UNIQUE_PROPERTY - Determine if property is unique in a collection
#*    Return status
#*      [V]CST_AOK = value is unique in collection
#*      [V]CST_AERROR = value is not unique
#*
#* @param MY_COLLECTION - Collection to be examined (this.COLxxx)
#* @param PRONAME - Property name to be compared to VALEUR
#* @param VALEUR - Value to be checked
#* @param MESSAGE - Message returned if property found
#*
#*!
Funprog _UNIQUE_PROPERTY(MY_COLLECTION,PRONAME,VALEUR,MESSAGE)
Variable Instance MY_COLLECTION(1..) Using OBJECT
Value Char PRONAME
Variable Char MESSAGE

Local Integer MY_STATUS, OCCURS, ILINE
[L]MY_STATUS = [V]CST_AOK
[L]OCCURS=0

# Check for any duplicates regardless of delete status
For ILINE=1 To maxtab(MY_COLLECTION)
  If MY_COLLECTION(ILINE)<>null
    If !find(MY_COLLECTION(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
      If evalue("MY_COLLECTION("+num$(ILINE)+")."+PRONAME)=VALEUR
        [L]OCCURS+=1
        If [L]OCCURS>1
          [L]MY_STATUS=[V]CST_AERROR
          MESSAGE = num$(VALEUR)-mess(33,137,1)
          Break
        Endif
      Endif
    Endif
  Endif
Next
End MY_STATUS
