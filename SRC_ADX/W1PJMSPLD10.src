#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMSPLD10 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:54"
A_USER  = "DOC"
A_STAMP = "20181109230554"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMSPLD10 [SPLD10]
Gosub HORODAT
Local Inpbox "PJMSPLD10" From GFONCTION At A_STAMP With A_WINDPREV Mask [SPLD10] As [SIM_]
Grizo [SPLD10]5
Grizo [SPLD10]10
Grizo [SPLD10]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [SPLD10]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=5
X1(1)=1 : X2(1)=112 : Y1(1)=6 : Y2(1)=11
X1(2)=1 : X2(2)=112 : Y1(2)=12 : Y2(2)=28
Return

$ON_OPPNUM
Return

$ON_ZOPPNUM
Onevent BEFORE_AREA Gosub AV_ZOPPNUM From W1PJMSPLD10
Return

$AV_ZOPPNUM
Call LECTEXTRA(zc,"PIMPL","PIMDESAXX",num$([M]OPPNUM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_PJTALL
Onevent INIT_AREA Call D_PJTALL(zc) From W1PJMSPLD10
Onevent BEFORE_INPUT Call AS_PJTALL(zc) From W1PJMSPLD10
Return

Subprog D_PJTALL(VALEUR)
Variable Integer VALEUR
If varinit([M]PJTALL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PJTALL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

