$AMM_INCBUD
Call AM_INCBUD(zc)
If !mkstat & GOBJET
 zoncou = "INCBUD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_INCBUD(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_INCBUD(VALEUR) From PJMAUTSPLD
If mkstat : GERR = 1 : GZONE = "INCBUD" : GZNUM = 1001834 : Endif
Gosub _AFF
End

