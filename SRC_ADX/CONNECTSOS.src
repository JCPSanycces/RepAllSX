#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBSCMDINT","SCMDINT",4,"SPESCMDINT") From GTRAITE
End


######################################################################
# CONNECTSOS : SCM Import des Prévisions de ventes                   #
######################################################################
$ACTION
Return

######################################################################
Subprog TRAITE(ID,OS,FICCSV,FICCLI,CONPIT,CONREF,SOSDLTFLG,SOSRAZFLG,REJ,FICREJ,REF,FICREF,ERRG,ERRNOFIC)
Value Char ID(),OS(),FICCSV(),FICCLI(),CONPIT(),CONREF()
Value Integer SOSDLTFLG
Value Integer SOSRAZFLG
Value Integer REJ
Value Char FICREJ()
Value Integer REF
Value Char FICREF()
Variable Integer ERRG,ERRNOFIC

Local Integer ERR : ERR=0
Local Integer NOLIG : NOLIG=0
Local Integer OUVFICREJ: OUVFICREJ=0
Local Integer OUVFICREF: OUVFICREF=0


Local Clbfile LIGCLOB(10)
Local Clbfile LIGENTETE(10)
Local Integer ERRFIC : ERRFIC=0

If clalev ([F:ORD])  = 0  : Local File   ORDERS [ORD]    : Endif

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
If ID="SCMA"
adxium = GASCII
Else
adxium = GUTF8
Endif
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub INITPIVOT From CONNECTFCT

Local Char WITM(GLONITM)
Local Char WFCY(GLONFCY)

GIMPORT=1
 GCONSOS_NBF+=1
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE("==========================",0) From GESECRAN
 If FICCLI<>""
  GCONSOS_FIC(GCONSOS_NBF)=FICCLI
  Call ECR_TRACE(mess(220,139,1)-"|"+FICCLI,0) From GESECRAN : # Traitement du fichier
 Else
  GCONSOS_FIC(GCONSOS_NBF)=FICCSV
  Call ECR_TRACE(mess(38,115,1)-"|"+FICCSV,0) From GESECRAN : # Lecture du fichier
 Endif

 Gosub OUVFIC
 Onerrgo FIN_ERRGO
 Gosub LIREFIC
 If ERRFIC 
    ERRG+=1 : ERRNOFIC+=1
    Call ECR_TRACE(mess(14,7710,1),1) From GESECRAN : # Lecture du fichier impossible
    Goto FIN
 Endif
 While !ERRFIC
     Gosub CHARGEPIVOT From CONNECTFCT
     If !ERR
         Gosub TRAITE_SOS
         Onerrgo FIN_ERRGO
     Endif
     If ERR & REJ
        ERRG+=1
        # on doit ecrire dans le fichier des rejets
        Gosub ECR_REJ
     Endif
     ERR=0
     Gosub LIREFIC
 Wend

$FIN
 Onerrgo
 Gosub FERMEFIC
 GIMPORT=0
 adxium = SAVADXIUM
 adxifs = SAVADXIFS
 adxirs = SAVADXIRS
End
############
$FIN_ERRGO
 ERRG+=1 : ERRNOFIC+=1
 Call ECR_TRACE(mess(17,7710,1),1) From GESECRAN : # Erreur sur traitement d'une ligne du fichier
 Goto FIN
############

######################################################################
#Ouverture du fichier CSV
$OUVFIC
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openi FICCSV,0 Using [FCSV]
 adxifs=""
 adxirs=IRS
 If ID="SCMA"
 adxium = GASCII
 Else
 adxium = GUTF8
 Endif
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FCSV]
 Iomode adxirs adxirs Using [FCSV]
 Iomode adxium adxium Using [FCSV]
 If WPIVHEATYP<>1
    Rdseq LIGCLOB Using [FCSV]
    If fstat=0
        LIGENTETE=LIGCLOB
        Call FILE_UTF8_BOM(LIGENTETE) From CONNECTFCT : # FQ 65094 GA 06/2010
    Endif
 Endif
Return

$LIREFIC
Rdseq LIGCLOB Using [FCSV]
If fstat<>0
    ERRFIC=1
Else
    If NOLIG=0  & WPIVHEATYP=1
       Call FILE_UTF8_BOM(LIGCLOB) From CONNECTFCT : # FQ 65094 GA 06/2010
    Endif
    GCONSOS_ENR+=1
    NOLIG+=1
Endif
Return

$FERMEFIC
 Openi Using [FCSV]
 Openo Using [FREJ]
 Openo Using [FREF]
Return

######################################################################
#Ouverture du fichier REJ
$OUVFICREJ
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openo FICREJ,0 Using [FREJ]
 adxifs=""
 adxirs=IRS
 If ID="SCMA"
 adxium = GASCII
 Else
 adxium = GUTF8
 Endif
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FREJ]
 Iomode adxirs adxirs Using [FREJ]
 Iomode adxium adxium Using [FREJ]
 OUVFICREJ=1
 If WPIVHEATYP<>1
    Wrseq LIGENTETE Using [FREJ]
 Endif
Return

$ECR_REJ
If !OUVFICREJ
    Gosub OUVFICREJ
Endif
Wrseq LIGCLOB Using [FREJ]
GCONSOS_REJ+=1
Return

######################################################################
#Ouverture du fichier REF
$OUVFICREF
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openo FICREF,0 Using [FREF]
 adxifs=""
 adxirs=IRS
 If ID="SCMA"
 adxium = GASCII
 Else
 adxium = GUTF8
 Endif
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FREF]
 Iomode adxirs adxirs Using [FREF]
 Iomode adxium adxium Using [FREF]
 OUVFICREF=1
 If WPIVHEATYP<>1
    Wrseq "WIPTYP;WIPNUM;ITMREF" Using [FREF]
 Endif
Return

$ECR_REF
If REF
    If !OUVFICREF
        Gosub OUVFICREF
    Endif
    Wrseq [F:ORD]WIPTYP+";"+[F:ORD]WIPNUM+";"+[F:ORD]ITMREF Using [FREF]
Endif
Return


######################################################################
$INIVARNB
Global Integer GCONSOS_NBF : GCONSOS_NBF = 0 : #nombre de fichier ITM
Global Char    GCONSOS_FIC(GDIMFIC)(1..1000) : Raz GCONSOS_FIC
Global Integer GCONSOS_ENR : GCONSOS_ENR = 0 : #enreg lus
Global Integer GCONSOS_NEW : GCONSOS_NEW = 0 : #enreg importés/nouveaux
Global Integer GCONSOS_MAJ : GCONSOS_MAJ = 0 : #enreg importés/maj
Global Integer GCONSOS_REJ : GCONSOS_REJ = 0 : #enreg rejetés
Return

$SUPVARNB
  # Désallocation des variables globales
  If dim(GCONSOS_NBF)>0 Then Kill GCONSOS_NBF Endif
  If dim(GCONSOS_FIC)>0 Then Kill GCONSOS_FIC Endif
  If dim(GCONSOS_ENR)>0 Then Kill GCONSOS_ENR Endif
  If dim(GCONSOS_NEW)>0 Then Kill GCONSOS_NEW Endif
  If dim(GCONSOS_MAJ)>0 Then Kill GCONSOS_MAJ Endif
  If dim(GCONSOS_REJ)>0 Then Kill GCONSOS_REJ Endif
Return
######################################################################
$OUVRE_IMP_SOS
Local   Char    WMESSAGE(250)
Local   Date    TODAY : TODAY = date$
Local   Integer VS

If clalev ([F:ITM])  <= 0  : Local File   ITMMASTER  [ITM] : Endif
If clalev ([F:ITF])  <= 0  : Local File   ITMFACILIT [ITF] : Endif
If clalev ([F:FCY])  <= 0  : Local File   FACILITY   [FCY] : Endif
If clalev ([F:ORD1])  = 0  : Local File   ORDERS [ORD1]    : Endif
Return
######################################################################

$TRAITE_SOS
Onerrgo FIN_ERRGO_SOS
Local Shortint IADIME : IADIME = 30    : # Taille pour le Setmode
Local Integer  INBAFF                  : # Pile/Indice
Local Integer  IAFFCOD(0..IADIME)      : # Code instruction
Local Char     IAFFMASK(GLONABR)(0..IADIME)  : # Abréviation écran
Local Char     IAFFCHP(50)(0..IADIME)        : # Zone écran
Local Integer  IAFFIND(0..IADIME)            : # Indice de la zone
Local Char     IAFFTXT(250)(0..IADIME) : # Texte
Local Integer  IAFFRANG(0..IADIME)     : # Rang
Local Integer  IAFFOPT1(0..IADIME)     : # Option1 Ex: Status, premier rang affzo 10-20
Local Integer  IAFFOPT2(0..IADIME)     : # Option2 Ex: Raccourci clavier, dernier rang affzo 10-20

Local Char    PROGOBJ(GLONADC) , PROGSUB(GLONADC) , PROGSPE(GLONADC) , PROGSPV(GLONADC)
Local Char    PROGIMP(GLONADC) , PROGIMS(GLONADC)
Local Char    OBJLIS(GLONAOB)(1..8)
Local Integer AMA(0..16) , RESTMSK(0..16)
Local Integer CRE, MODI, SUPPR, ISITE
Local Char    ERRMES(50)
Local Integer NRMASK , ILIS , RELIT
Local Integer PSPE, PSUB, PSPV, PSTD
Local Integer PIMP
Local Char    SYMBOLE(35)
Local Char    CLECUR1(GLONID1) , CLECUR2(GLONID2)(0..16), CLE2(GLONID2)(0..16)
Local Char    SCLE2(GLONID2) , COUZON(GLONAVA)
Local Integer TPCLE1 , TPCLE2(0..16)
Local Char    SAVCLE1(GLONID1) , SAVCLE2(GLONID2)
Local Char    FILTRE(240) , FILTSUP(240) , CRITTAB(250)
Local Char    CRITERE(250) , FILROLE(250) , FILSUITE(250)
Local Integer ICRITERE , IFILROLE , IFILSUITE
Local Char    ACTION(20) , CHAINE(20) , REP(1)
Local Char    MESSA(250)
Local Char    IDENT(50), ABREV(GLONAOB), SITCUR(15)
Local Integer MA, CL , CLECUR, AFFICHE, AUTENA, OPTENA, OPTDOC , OKTRT,OK
Local Integer TUNNEL, VERROU
Local Integer NBMEN , NBRMEN , ETAMEN(1..60)
Local Char    CHMEN(30) , BOUT(1)
Local Char GCLESOS(GLONITM+20)
Local Char GREPCON : # "C" ou "M"
Local Integer WGETREF

OK=1
Raz GCLESOS
If [F:PIT]TYP=43 : #SCM prévisions
GCLESOS=func CONNECTFCT.GETVAL("ORDERS","ITMREF",NBPIVZON,WPIVTABZON,WPIVVAL)+"/"+func CONNECTFCT.GETVAL("ORDERS","ENDDAT",NBPIVZON,WPIVTABZON,WPIVVAL)
Endif
If GCLESOS=""
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-mess(9,7710,1),1) From GESECRAN : # Ligne x Référence non renseignée
    Goto FIN_SOS_ERR
Endif

WOBJ="SOS"
GABREV="ORD"
ABREV="ORD"
ABFIC="ORD"

WINPROG="WGO"+WOBJ
# Issue 81372 - 2012-05-04 by SR
Call ISWINDOWOK (nomap,"OORD") From INTRUTILB
##  "WOSOS SUBSOS SPESOS SPVSOS"
Call SETPROG(WOBJ,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
Gosub DEFVAR From =WINPROG
Gosub OUVRE_MSK From GOBJET
For MA=0 To NBMASK
    Gosub RAZMASK From =WINPROG
Next MA
Gosub OUVRE From =PROGOBJ

Raz GFLAG
ACTION="DEFTRANS"
Gosub ACTION From =PROGSUB

Gosub OUVRE_IMP_SOS

ACTION="OUVRE"
Gosub ACTION From =PROGSUB

If !OK : Goto FIN_SOS_ERR : Endif

If evalue("clalev([F:"+ABFIC+"])")=0 : Gosub OUVFIC From =PROGOBJ : Endif
If !OK : Goto FIN_SOS_ERR : Endif

Default File [F:ORD]

Raz [F:ORD]
WGETREF=0
Gosub SETCLE : #pour vider les zones
If [F:PIT]TYP=43 : #SCMD Prévisions
    GREPCON = "C"
Else
    ### A VERIFIER LE JOUR OU ON AURA UN AUTRE CONNECTEUR
Endif

## AVEC SCMD Mouvements on est toujours en insertion
If GREPCON = "C"
 CLECUR = 0
 CHAINE = "C"
 ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : Goto FIN_SOS_ERR : Endif
 ###ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 OK=(instr(1,CHAINE,"C")<>0)
 If OK
   GREP = "C" : REP = "C"
   ACTION = "RAZCRE"      : Gosub ACTIONG From SUBIMPOBJ
   ###ACTION = "IMP_RAZCRE"  : Gosub ACTION From SUBIMPOBJ
 Endif
Else
 ### A VERIFIER LE JOUR OU ON AURA UN AUTRE CONNECTEUR
Endif

If !OK | GREP="" : Goto FIN_SOS_VERROU : Endif

#on affecte les valeurs du mask
# écriture SOS
[M:ORDK]WIPTYP     = 1
[M:ORDK]WIPSTA     = 3
[M:ORDK]VCRTYP     = 1
[M:ORDK]CPLQTY     = 0
[M:ORDK]ALLQTY     = 0
[M:ORDK]SHTQTY     = 0
[M:ORDK]FMI        = 1
[M:ORDK]MRPMES     = 1
[M:ORDK]ORI        = 3


nolign=1
MA=1
Gosub SETMASK From =WINPROG
For NOPIV=1 To NBPIVZON
    If pat(WPIVTABZON(NOPIV),"ORDERS/*")
        If evalue("dim([M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
           Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV),WPIVVAL(NOPIV),OK) From CONNECTFCT
        Endif
    Endif
Next
If !OK : Goto FIN_SOS_VERROU : Endif

#on affecte les valeurs particulières
If [M:ORDK]ORIFCY=""
   [M:ORDK]ORIFCY     = [M:ORDK]STOFCY
Endif
If [M:ORDK]STRDAT = [0/0/0]
   [M:ORDK]STRDAT     = [M:ORDK]ENDDAT
Endif


######################################################
# Contrôles
# zones obligatoires : Site, article, date fin et quantité prévue
If [M:ORDK]STOFCY = "" |
&  [M:ORDK]ITMREF = "" |
&  [M:ORDK]ENDDAT = [0/0/0] |
&  [M:ORDK]EXTQTY < 0
    GMESSAGE = mess(1,79,1)+" : STOFCY, ITMREF, ENDDAT, EXTQTY"
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESOS-GMESSAGE,1) From GESECRAN
    OK = 0
    If !OK : Goto FIN_SOS_VERROU : Endif
Endif

# controle site
Call LECTURE("FCY",[M:ORDK]STOFCY,"") From CONTOBJ
#VPO 19/04/10 64127 le site doit être un site de stockage
#If fstat | [F:FCY]MFGFLG <> 2 
If fstat | [F:FCY]WRHFLG <> 2 
    #GMESSAGE = mess(1,193,1)+" : "+[M:ORDK]STOFCY
    GMESSAGE = mess(358,184,1)+" : "+[M:ORDK]STOFCY
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESOS-GMESSAGE,1) From GESECRAN
    OK = 0 
    If !OK : Goto FIN_SOS_VERROU : Endif
Endif

# controle article
If [F:ITM]ITMREF <> [M:ORDK]ITMREF
    Read [ITM]ITM0 = [M:ORDK]ITMREF
    If fstat 
        GMESSAGE = mess(134,100,1)
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESOS-GMESSAGE,1) From GESECRAN
        OK = 0
        If !OK : Goto FIN_SOS_VERROU : Endif
    Endif
Endif
If [F:ITF]ITMREF <> [M:ORDK]ITMREF | [F:ITF]STOFCY <> [M:ORDK]STOFCY
    Read [ITF]ITF0 = [M:ORDK]ITMREF;[M:ORDK]STOFCY
    If fstat & [F:ITM]STOMGTCOD=2   # FQ 64723 GA 05/2010
       # "Article-site inexistant" au lieu de "Article non géré en stock pour le site"
       # GMESSAGE = mess(2,196,1)+" : "+[M:ORDK]STOFCY
        GMESSAGE = mess(139,197,1)+" : "+[M:ORDK]ITMREF+"/"+[M:ORDK]STOFCY
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESOS-GMESSAGE,1) From GESECRAN
        OK = 0
        If !OK : Goto FIN_SOS_VERROU : Endif
    Endif
Endif

Gosub VALID
If !OK : Goto FIN_SOS_VERROU : Endif
Gosub DEVERROU

$FIN_SOS
Return
$FIN_SOS_VERROU
Gosub DEVERROU
$FIN_SOS_ERR
Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
ERR=1
OK=0
Return

#####FIN onerrgo###########
$FIN_ERRGO_VERROU
Onerrgo
#on est en erreur sur la ligne
Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESOS,1) From GESECRAN : # erreur
If errn
    Call ECR_TRACE(errp+"("+num$(errl)+"):"-errmes$(errn),1) From GESECRAN
Endif
Gosub DEVERROU
$FIN_ERRGO_SOS
Onerrgo
Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
ERR=1
OK=0
Resume


$VERROU
OK = 1
ACTION = "VERROU"     : Gosub ACTIONG From SUBIMPOBJ
If !OK : Return : Endif
###ACTION = "IMP_VERROU" : Gosub ACTION From SUBIMPOBJ
###If !OK : Return : Endif
OK = 1
SYMBOLE = format$("K:3X",ABFIC)+GCLE
Lock =SYMBOLE With lockwait=0
If fstat
  Call ECR_TRACE(GCLESOS-mess(61,141,1),1) From GESECRAN : # Fiche en cours de modification
  Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
  OK = 0
Endif
Return

$DEVERROU
ACTION = "DEVERROU"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_DEVERROU" : Gosub ACTION From SUBIMPOBJ
SYMBOLE = format$("K:3X",ABFIC)+GCLE
If SYMBOLE <> ""
    Unlock =SYMBOLE
Endif
SYMBOLE = ""
Return

$SETCLE
CLECUR1 = [F:ORD]WIPNUM
GCLE = num$([F:ORD]WIPTYP)+"\"+[F:ORD]WIPNUM+"\"+[F:ORD]ITMREF
Return

$VALID
 Gosub DEFAUT From =PROGOBJ
 Raz mkstat
 OK = 1
 Gosub VALIDOBJ
 If !OK 
   # ici on sort de subprog VALID avec GMESSAGE=vide, si OK a été razé via $ACTIONG
   # qui a mis le message dans la trace puis l’a razé  
   If GMESSAGE="" : GMESSAGE=ACTION : Endif
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESOS-GMESSAGE,1) From GESECRAN : # erreur
   GMESSAGE=""
 Elsif GOK>=1
   If GREP="C"
        GCONSOS_NEW += 1 
        If WGETREF : Gosub ECR_REF : Endif
   Elsif GREP="M" 
        GCONSOS_MAJ += 1
   Endif
 Endif
 Raz GREP
Return

$VALIDOBJ
If GREP="C"
  [L]ACTION="VERIF_CRE"  : Gosub ACTION From GOBJSUB
 ##ACTION = "VERIF_CRE"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ###ACTION = "IMP_VERIF_CRE" : Gosub ACTION  From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 Gosub TR1
 If GOK<1
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESOS-mess(100,141,1),1) From GESECRAN : # Erreur création
 Else
  Gosub SETCLE : CLECUR = 1
  ##ACTION = "APRES_CRE"     : Gosub ACTIONG From SUBIMPOBJ
  [L]ACTION="APRES_CRE" : Gosub ACTION From GOBJSUB
  ###ACTION = "IMP_APRES_CRE" : Gosub ACTION From SUBIMPOBJ
  ###Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESOS,-1) From GESECRAN
  Call IDENT3(WOBJ,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  ###VPO 12/10/10 64861 : perf / on supp le workflow unitaire
  ##Call WORKFLOW(2,WOBJ,"C",IDENT) From AWRK
 Endif
Elsif GREP="M"
 ACTION = "VERIF_MOD"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ###ACTION = "IMP_VERIF_MOD" : Gosub ACTION From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 Gosub TR2
 If GOK<1
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESOS-mess(101,141,1),1) From GESECRAN : # Erreur modification
 Else
  Gosub SETCLE
  ACTION = "APRES_MOD"     : Gosub ACTIONG From SUBIMPOBJ
  ###ACTION = "IMP_APRES_MOD" : Gosub ACTION From SUBIMPOBJ
  ###Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESOS,-1) From GESECRAN
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  ###VPO 12/10/10 64861 : perf / on supp le workflow unitaire
  ##Call WORKFLOW(2,ABREV,"M",IDENT) From AWRK
 Endif
Endif
Return

$TR1
GOK = 1
Trbegin ADOVAL
###############
 If SOSRAZFLG=2
    # si 1er article, RAZ des SOS existantes ...
    If WITM = ""
        WITM = [M:ORDK]ITMREF
        WFCY = [M:ORDK]STOFCY
        Filter [ORD1]
        Delete [ORD1] Where [F:ORD1]WIPTYP = 1 & [F:ORD1]WIPSTA = 3
        If !GOK : Goto ROLL_TR1 : Endif
$FIN_RAZ
        WMESSAGE = mess(111,190,1)
        Call ECR_TRACE(WMESSAGE,0) From GESECRAN  
    Endif
 Endif
###############
 If SOSDLTFLG=2
    # si rupture sur article, purge des SOS existantes ...
    If WITM = "" | WITM <> [M:ORDK]ITMREF | WFCY <> [M:ORDK]STOFCY 
        WITM = [M:ORDK]ITMREF
        WFCY = [M:ORDK]STOFCY
        # GA 05/2010 optimisation: utiliser l'index ORD4
        Filter [ORD1] Where [F:ORD1]ITMREF = [M:ORDK]ITMREF &
&                           [F:ORD1]STOFCY = [M:ORDK]STOFCY & 
&                           [F:ORD1]WIPTYP = 1 &
&                           [F:ORD1]WIPSTA = 3
&                     Order By Key ORD4
        For [ORD1]
            If fstat : Goto FIN_PUR : Endif
            Readlock [ORD1] Curr
            If fstat : Goto ROLL_TR1 : Endif
            Delete [ORD1]
        Next
        Filter [ORD1]
        If !GOK : Goto ROLL_TR1 : Endif
$FIN_PUR
        WMESSAGE = mess(111,190,1)-[M:ORDK]ITMREF+"/"+[M:ORDK]STOFCY
        Call ECR_TRACE(WMESSAGE,0) From GESECRAN  
    Endif
 Endif
###############
 Gosub DEFAUT From =PROGOBJ
 Raz [F]
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Gosub INICRE From GOBJSUB
 ###Gosub INIEXP From SUBIMPOBJ
 ACTION = "INICRE"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ###ACTION = "IMP_INICRE" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Gosub MAJSOS
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ##fait dans MAJSOS
 ###Write
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK
  Goto AB_TR1
 Endif
 ACTION = "CREATION"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ###ACTION = "IMP_CREATION" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
ACTION = "AB_CREATION"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_AB_CREATION" : Gosub ACTION  From SUBIMPOBJ
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

######################################################
$MAJSOS
Call NUMERO(GWIP,[M:ORDK]STOFCY,TODAY,"",[M:ORDK]WIPNUM,VS) From SUBANM
If VS <> 0
    OK = 0
    Goto ROLL_TR1
Else
    [M:ORDK]MAJCOD     = "C"
    [M:ORDK]VCRNUM     = [M:ORDK]WIPNUM
    Call WIP From TRTWIP
    If !GOK : Goto ROLL_TR1 : Endif
# FQ 74427 TRTWIP utilise un autre buffer que [F:ORD] (table ouverte en local)
#    WMESSAGE = mess(59,123,1)-mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)-[F:ORD]STOFCY-[F:ORD]ITMREF-
#&                   [F:ORD]WIPNUM-format$(GFMDAT4,[F:ORD]ENDDAT)-num$([F:ORD]EXTQTY)-
    WMESSAGE = mess(59,123,1)-mess([M:ORDK]WIPTYP,341,1)+mess([M:ORDK]WIPSTA,342,1)-[M:ORDK]STOFCY-[M:ORDK]ITMREF-
&                   [M:ORDK]WIPNUM-format$(GFMDAT4,[M:ORDK]ENDDAT)-num$([M:ORDK]EXTQTY)-
&                   [F:ITM]STU
    Call ECR_TRACE(WMESSAGE,0) From GESECRAN
Endif
Return

$TR2
GOK=1
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Readlock =
 If fstat=1
  GOK=-1 : Call FSTA(ABFIC) From GLOCK : Goto ROLL_TR2
 Elsif fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "AVANT_MODFIC"    : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_AVANT_MODFIC" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Gosub INIMOD From GOBJSUB
 ###Gosub INIEXP From SUBIMPOBJ
 ACTION = "INIMOD"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_INIMOD" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Rewrite
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "MODIF"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_MODIF" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
ACTION = "AB_MODIF"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_AB_MODIF" : Gosub ACTION From SUBIMPOBJ
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif



