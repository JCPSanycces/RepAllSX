#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Modifications :
#  FQ85820 - 29/04/13 - prise en compte date d'effet + fiches de rûˋtroactivitûˋ
#  92876 - adaptation compta
######################################################################################

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "FIN_LISTE"   : Gosub FIN_LISTE
 When "CONTROLE"    : Gosub CONTROLE
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "TRN"         : FIN =1
 When "EXEC"        : If GSTATUT=GSTATRN : SAI = 1 : Endif
 When "SETBOUT"     : Gosub SETBOUT
 When "BOUTON"      : Gosub BOUTON
 When "MEN"         : Gosub MENU
 When "SUI"         : Gosub SUI
 When "PRE"         : Gosub PRE
 When "FIR"         : Gosub FIR
 When "LAS"         : Gosub LAS
 When "ENR"         : Gosub ENREGISTRE
 When "ABA"         : Gosub ABANDON
 When "END"         : Gosub FIN
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "TERMINE"     : Gosub KILLVARG
 When "SORTIE"      : Gosub SORTIE
 When Default
Endcase
Return

$KILLVARG
If dim(GEVT)>0   : Kill GEVT   : Endif
Return


#####################################################################################
# Remplissage de la liste des transactions de saisie
#####################################################################################

$INIT
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
If clalev([F:STH])=0 : Local File SCRTPSH [STH] : Endif
Return

$SORTIE
#LIPET - 10-01-2017 - X3-18688 - START
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#LIPET - 10-01-2017 - X3-18688 - END
Return

$SEL_LISTE
Local Integer OK
Raz GFLAG
# Paramû´tre utilisateur
If GDEFSCR<>""
 NBTEX = 1
 TEX(1) = GDEFSCR
 Return
Endif
Filter [STH] Where ENAFLG=2 and REGFLG<>2
For [STH]
 OK = 1
 # Code activitûˋ
 If [F:STH]CODACT<>""
  Read [ACV]CODACT=[F:STH]CODACT
  If fstat or [F:ACV]FLACT<>2
   OK = 0
  Endif
 Endif
 # Code d'accû´s
 If OK & [F:STH]CODACS<>"" & GUSRACS<>2
  Read [ACC]CODACC = GUSER;[F:STH]CODACS
  If fstat or [F:ACC]EXEC<>2
   OK = 0
  Endif
 Endif
 #92876_US2759
 # Nombre d'axe analytique <= 9
 #105526 test GACTION in place of GFONCTION
 If OK & GACTION="TPSJOU" & [F:STH]CODCDT<>""
  If !clalev([F:CDT]) : Local File CADIETPS [CDT] : Endif
  Read [CDT]CDT0=[F:STH]CODCDT
  If fstat or [F:CDT]NBRDIE>9
    OK = 0
  Endif
 Endif
#end 92876_US2759
 If OK
  NBTEX +=1
  TEXTE(NBTEX) = format$("Kb:"+num$(GLONSTH)+"X",[F:STH]COD)-':'-[F:STH]DES
  TEX(NBTEX)   = [F:STH]COD
 Endif
Next
Filter [STH]
#LIPET - 12-12-2016 - X3-12033 - START
#TIT = mess(148,709,1) : # Modû´le de saisie
TIT = mess(148,10709,1) : # Modû´le de saisie
#LIPET - 12-12-2016 - X3-12033 - END
If NBTEX=0 Then
  GMESSAGE=mess(4,126,1) : # Aucune transaction autorisûˋe
  GERR=1
Endif
Return

$FIN_LISTE
GFLAG = VALEUR
Return


# Pas de transaction saisie
$CONTROLE
If GSTATUT = 7 | GFLAG=""
 FIN = 1
 Return
Endif
Call LECTURE("STH",GFLAG,"") From CONTOBJ
If fstat
 If GFLAG<>""
  Raz GMESSAGE
  Call TITOBJ("STH","!",GMESSAGE) From CONTOBJ
  GMESSAGE -= ":"-GFLAG-mess(86,105,1) : # Paramûˋtrage û  revoir
 Endif
 GERR = 1 : FIN = 1
 Return
Endif
If GACTION="TPSJOU"
 If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
 BOITE = "WFJOU"+GFLAG
 Look [AWI]AWI0=BOITE
 If fstat
 #LIPET - 12-12-2016 - X3-12033 - START
  # Transaction non validûˋe
  #GMESSAGE = GFLAG-":"-mess(145,709,1)
  GMESSAGE = GFLAG-":"-mess(145,10709,1)
#LIPET - 12-12-2016 - X3-12033 - END
  GERR = 1 : FIN = 1
  Return
 Endif
Endif
Return

#####################################################################################
# Saisie des temps
#####################################################################################

$OUVRE
Local Mask TPSVENT [VTL] , VENTILE2 [VT2], TPSSTD [TPS], TPSJOUINV [TPSI]
GREPORT1 = "TPSMAT"
GREPORT2 = "TPSSAL"
Local Char    SAVFONC(GLONAFC)
SAVFONC = GFONCTION
Case GACTION
 When "TPSSTD" : GFONCTION = "TPSSTD"
 When "TPSJOU" : GFONCTION = "TPSJOU"
Endcase
Call AUTORIS From EXEFNC
Gosub OUVFIC
#LIPET - 10-01-2017 - X3-18688 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#LIPET - 10-01-2017 - X3-18688 - END
Return

$OUVFIC
If clalev([F:ATY])=0  : Local File ATYPE     [ATY]  : Endif
#LIPET - 12-12-2016 - X3-12033 - START
#If clalev([F:PEO])=0  : Local File PERIOD    [PEO]  : Endif
If clalev([F:HRPEOD])=0  : Local File HRPEODET   [HRPEOD]  : Endif
If clalev([F:HRPEOH])=0  : Local File HRPEOHEA    [HRPEOH]  : Endif
#LIPET - 12-12-2016 - X3-12033 - END
If clalev([F:HLY])=0    : Local File HLYDAY    [HLY]  : Endif
If clalev([F:TIP])=0    : Local File TIMEMP    [TIP]  : Endif
If clalev([F:TIP2])=0   : Local File TIMEMP    [TIP2] : Endif
If clalev([F:TIG])=0    : Local File TIMREGUL  [TIG]  : Endif
If clalev([F:TIA])=0    : Local File TIMANA    [TIA]  : Endif
If clalev([F:TIM])=0    : Local File TIMCOD    [TIM]  : Endif
If clalev([F:TIR])=0    : Local File TIMRECAP  [TIR]  : Endif
If clalev([F:ID])=0     : Local File EMPLOID   [ID]   : Endif
If clalev([F:AD])=0     : Local File EMPLOAD   [AD]   : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]  : Endif
If clalev([F:CTR1])=0   : Local File EMPLOCTR  [CTR1] : Endif
If clalev([F:FCY])=0    : Local File FACILITY  [FCY]  : Endif
If clalev([F:SIT])=0    : Local File SITEPAYE  [SIT]  : Endif
If clalev([F:CPY])=0    : Local File COMPANY   [CPY]  : Endif
If clalev([F:PLN])=0    : Local File PLANTYP   [PLN]  : Endif
If clalev([F:PLE])=0    : Local File PLANEMP   [PLE]  : Endif
If clalev([F:WTY])=0    : Local File TYPWEEK   [WTY]  : Endif
If clalev([F:ADW])=0    : Local File ADOVAL    [ADW]  : Endif
If clalev([F:ACV])=0    : Local File ACTIV     [ACV]  : Endif
If clalev([F:ACC])=0    : Local File ACCES     [ACC]  : Endif
If clalev([F:AUS])=0    : Local File AUTILIS   [AUS]  : Endif
If clalev([F:SRV])=0    : Local File SERVICE   [SRV]  : Endif
If clalev([F:NAT])=0    : Local File NATACTIV  [NAT]  : Endif
If clalev([F:ATZ])=0    : Local File ATABZON   [ATZ]  : Endif
If clalev([F:STH])=0    : Local File SCRTPSH   [STH]  : Endif
If clalev([F:STD])=0    : Local File SCRTPSD   [STD]  : Endif
If clalev([F:CNG])=0    : Local File CNGCPY    [CNG]  : Endif
If clalev([F:CNE])=0    : Local File CNGEMP    [CNE]  : Endif
If clalev([F:TIC])=0    : Local File TIMCNG    [TIC]  : Endif
If clalev([F:AMZ])=0    : Local File AMSKZON   [AMZ]  : Endif
If clalev([F:ECT])=0    : Local File EMPCTR    [ECT]  : Endif
If GPAYE
 If clalev([F:VEP])=0 : Local File VALEMP    [VEP]  : Endif
Endif
If clalev([F:CCE])=0  : Local File =GTABCPT+"CACCE" [CCE] : Endif
If clalev([F:DSP])=0  : Local File =GTABCPT+"CADSP" [DSP] : Endif
##**92876
If clalev([F:CDT])=0  : Local File CADIETPS    [CDT]  : Endif

Return


$DEBUT
Local Integer I, J, K, L, NOL, DEFILE
Local Char    SITE(GLONFCY), CHAMP(GLONAVA)
Local Char    FLDINV(GLONAVA)(0..30), FLDCTL(GLONAVA)(0..30), TITCTL(30)(0..30)
Local Char    SYMBOLE(50), ZONCOP(GLONAVA)
Local Integer SAVCONS, NBINV, NBCTL
Local Char    LESITE(GLONFCY) : #59323
Local Integer NBTRANS

Raz [TPSJ]
Gosub INIT_NUMPLG
SAVCONS  = GCONSULT
GCONSULT = 0
DEFILE = 1
# Paramû´tre de recopie de chaque donnûˋe modifiûˋe la plage 1 sur les autres plages
# Sauf plage horaire, temps de pause, nombre d'heures et nombre de jours
Call PARAMUTIL("COPPLG",[M:TPSI]COP,GUSER,"") From SUBAUS
Gosub OUVRE_IJSS From TPSSTD
Gosub INIPAR
Gosub INITRANSAC
#92876_US2759
#Affzo 10
Affzo
# 105106
Setmok [M] With 0
#LIPET - 10-01-2017 - X3-18688 - START
If [M:TPSJ]LEG<>""
  GCURLEG = [M:TPSJ]LEG
Endif
#LIPET - 10-01-2017 - X3-18688 - END

Return

$INIT_NUMPLG
If GNBHOR = 0 | GNBHOR=1
 [M]NUMPLG = "1/1"
 [M:TPSJ]SUIPLG = ""
 Grizo [TPSJ]SUIPLG
 [M:TPSI]NBHOR  = 1
Else
 [M]NUMPLG = "1/"+num$(GNBHOR)
 [M:TPSJ]SUIPLG = "29"
 Actzo [TPSJ]SUIPLG
 [M:TPSI]NBHOR  = GNBHOR
Endif
[M:TPSJ]PREPLG = ""
Grizo [TPSJ]PREPLG
Affzo [TPSJ]NUMPLG,SUIPLG,PREPLG,PREWEK,SUIWEK
Return

$INITRANSAC
NBTRANS=1
## Initialisation des libellûˋs des champs
I = 1
Read [STD]STD1=GFLAG;"STRTIM"
If !fstat & [F:STD]OPT<>3
 For J=1 To [M:TPSI]NBHOR
 #LIPET - 12-12-2016 - X3-12033 - START
  #Assign "[M]LIB"+num$(I) With mess(122,709,1) : # Plage horaire
  Assign "[M]LIB"+num$(I) With mess(122,10709,1) : # Plage horaire
 #LIPET - 12-12-2016 - X3-12033 - END
  I +=1
 Next
Endif

# Champs saisis ou affichûˋs
#92876_US2759 : optimisation du filtre et exclusion des CCE
#Filter [STD] Where COD=GFLAG & OPT<>3 & FLD<>"STRDAT" & FLD<>"ENDDAT" & FLD<>"STRTIM" & FLD<>"ENDTIM" & FLD<>"TYPPGN"
# FQ102773 -04/12/14 - Dorûˋnavant, c'est le champ NBRHOU qui est sur la mûˆme ligne que le champ NBRDAY, de faûÏon û  ce que le champ
# Nature d'ûˋvûˋnement soit tout seul sur sa ligne. En revanche, si le champ NBRDAY est invisible, on met le champ NBRHOU tout seul
# sur la ligne
#Filter [STD] Where COD=GFLAG & OPT<>3 & !find(FLD, "STRDAT","ENDDAT","STRTIM","ENDTIM","TYPPGN") & left$(FLD,3)<>'CCE'
#Filter [STD] Where COD=GFLAG & OPT<>3 & !find(FLD, "STRDAT","ENDDAT","STRTIM","ENDTIM","NBRHOU") & left$(FLD,3)<>'CCE'
If clalev([F:STD2])=0 : Local File SCRTPSD [STD2] : Endif
Filter [STD] Where COD=GFLAG & OPT<>3 & !find(FLD, "STRDAT","ENDDAT","STRTIM","ENDTIM") & left$(FLD,3)<>'CCE'
For [STD]STD0
 #If evalue("dim([M]LIB"+num$(I)+")")<=0 :#92876_US2759 : correction, si dim retourne 0, la variable existe.
 If evalue("dim([M]LIB"+num$(I)+")")<0
 #LIPET - 12-12-2016 - X3-12033 - START
  # Trop de zones dans la transaction. Nombre limitûˋ û  xx
  #Call ERREUR(mess(123,709,1)-num$(I-1)) From GESECRAN
  Call ERREUR(mess(123,10709,1)-num$(I-1)) From GESECRAN
  #LIPET - 12-12-2016 - X3-12033 - END
  GERR = 1 : FIN = 1 : NBTRANS=0
  Break
 Endif
 # FQ102773 -04/12/14 - Gestion du champ NBRHOU
 If [F:STD]FLD="NBRHOU" Then
  Read [F:STD2]STD1=GFLAG;"NBRDAY"
  # Si le champ NBRDAY est invisible, il faut metttre le champ NBRHOU tout seul sur sa ligne
  If [F:STD2]OPT=3 Then
    Assign "[M]LIB"+num$(I) With [F:STD]TIT
    I +=1
  Endif
 Elsif [F:STD]FLD="NBRDAY" Then
  Assign "[M]LIB"+num$(I) With [F:STD]TIT
  Read [F:STD2]STD1=GFLAG;"NBRHOU"
  # Si le champ NBRHOU est visible, il faut accoler les intitulûˋs Nb jours / Nb heures
  If [F:STD2]OPT<>3 Then
    Assign "[M]LIB"+num$(I) With [F:STD]TIT+"/"+[F:STD2]TIT
  Endif
  I +=1
 Else
  Assign "[M]LIB"+num$(I) With [F:STD]TIT
  I +=1
 Endif
Next
Filter [STD]

If !FIN Then
  ## Recherche des zones invisibles de la transaction
  ## Recherche des zones obligatoires de la transaction
  Raz NBCTL, NBINV
  #92876_US2759 : amûˋlioration du filtre et exclusion des CCE
  #Filter [STD] Where COD=GFLAG & FLD<>"STRDAT" & FLD<>"ENDDAT" & FLD<>"TIM"
  Filter [STD] Where COD=GFLAG & !find(FLD, "STRDAT","ENDDAT","TIM") & left$(FLD,3)<>'CCE'
  For [STD]
   If [F:STD]OPT=3
    FLDINV(NBINV) = [F:STD]FLD
    NBINV +=1
   Elsif [F:STD]OBG=2
    FLDCTL(NBCTL) = [F:STD]FLD
    TITCTL(NBCTL) = [F:STD]TIT
    NBCTL +=1
   Endif
  Next
  Filter [STD]

  Gosub OUVRE_CCE :#92876_US2759
Endif
Return

#92876_US2759
$OUVRE_CCE
Local Char TITDIE(80)

If dim([M]NBRDIE)>=0
 Read[F:STH]STH0=GFLAG
 If !fstat & [F:STH]CODCDT<>""
  Read [CDT]CDT0=[F:STH]CODCDT
  If !fstat
   [M]NBRDIE=[F:CDT]NBRDIE
   #105526 Par sûˋcuritûˋ, ne devrait pas arriver car la sûˋlection ûˋlimine dûˋjû  ces cas.
   If GACTION="TPSJOU" & [F:CDT]NBRDIE>9
   #LIPET - 12-12-2016 - X3-12033 - START
     #Cette transaction de saisie comporte un nombres d'axes analytique supûˋrieur û  9.
     #Call ERREUR(mess(206,709,1)) From GESECRAN
     Call ERREUR(mess(206,10709,1)) From GESECRAN
   #LIPET - 12-12-2016 - X3-12033 - END
     GERR = 1 : FIN = 1 : NBTRANS=0
     Return
   Endif
   #end 105526
   For J=0 To [M]NBRDIE-1
    If evalue("dim([M]LIB"+num$(I)+")")<0
    #LIPET - 12-12-2016 - X3-12033 - START
     # Trop de zones dans la transaction. Nombre limitûˋ û  xx
     #Call ERREUR(mess(123,709,1)-num$(I-1)) From GESECRAN
     Call ERREUR(mess(123,10709,1)-num$(I-1)) From GESECRAN
     #LIPET - 12-12-2016 - X3-12033 - END
     GERR = 1 : FIN = 1 : NBTRANS=0
     Break
    Endif
    [M]WDIE(J)=[F:CDT]DIE(J)
    # Affichûˋ ou saisie
    If [F:CDT]OPT(J)=2
     [M]FRMFLD(J)="KP:"
    Else
     [M]FRMFLD(J)="K:"
    Endif
    Call INICCEFMT([F:CDT]DIE(J)) From SETGLBDIE
    [M]FRMFLD(J)+=GCCEFMT
    Call LECTEXTRA([L]TITDIE,"GDIE","COLHEA",[F:CDT]DIE(J),"") From ATEXTRA
    Assign "[M]LIB"+num$(I) With [L]TITDIE
    I+=1
   Next
  Endif
 Endif
Endif
Return
#end 92876_US2759

$CHARGE
Local Integer I, J, K, L, NOL, NOPLAGE, INI, II , M, AXE :#92876_US2757
Local Integer LJNUIT, LTYP, ANNEE, SEMAINE, STAT
Local Date    DAT
Local Decimal LNBRDAY,LNBRHOU
Local Decimal JOUR(1..2) , HEURE(1..2)

STAT = 1
Gosub RAZ_MSK
For I=1 To 7
 If evalue("dim([M:TPSJ]TIM"+num$(I)+")")>0     : CHAMP="[M:TPSJ]TIM"+num$(I)        : Effzo =CHAMP : Endif
Next
Gosub TITBLOC
If STAT=0 : Return : Endif
Gosub CHARGE_TIMEMP
Affzo [TPSJ]15-45

Gosub AUTORIS From TPSSTD
If GCONSULT=0
 Gosub CHARGE_PLANNING
Affzo [TPSJ]15-45
Endif

Gosub REMP_TPSJ
J = val(left$([M]NUMPLG,1))
Gosub COLORE_PLAGE
Affzo [TPSJ]15-45
Return

$RAZ_MSK
Raz [M:VT2]
Raz [M:TPSI]
If GNBHOR=0
 [M:TPSI]NBHOR = 1
Else
 [M:TPSI]NBHOR = GNBHOR
Endif
Call PARAMUTIL("COPPLG",[M:TPSI]COP,GUSER,"") From SUBAUS
Return

$RAZ_MSK2
For I=1 To 7
 If evalue("dim([M:TPSJ]TIM"+num$(I)+")")>0     : CHAMP="[M:TPSJ]TIM"+num$(I)        : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]STRTIM"+num$(I)+"1)")>0 : CHAMP="[M:TPSJ]STRTIM"+num$(I)+"1" : Effzo =CHAMP : Endif
