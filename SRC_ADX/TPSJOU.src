 If evalue("dim([M:TPSJ]STRTIM"+num$(I)+"2)")>0 : CHAMP="[M:TPSJ]STRTIM"+num$(I)+"2" : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]ENDTIM"+num$(I)+"2)")>0 : CHAMP="[M:TPSJ]ENDTIM"+num$(I)+"2" : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]STRTIM"+num$(I)+"3)")>0 : CHAMP="[M:TPSJ]STRTIM"+num$(I)+"3" : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]ENDTIM"+num$(I)+"3)")>0 : CHAMP="[M:TPSJ]ENDTIM"+num$(I)+"3" : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]BRKTIM"+num$(I)+")")>0  : CHAMP="[M:TPSJ]BRKTIM"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]LEADAY"+num$(I)+")")>0  : CHAMP="[M:TPSJ]LEADAY"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]TYPPGN"+num$(I)+")")>0  : CHAMP="[M:TPSJ]TYPPGN"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]NATCOD"+num$(I)+")")>0  : CHAMP="[M:TPSJ]NATCOD"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]NBRDAY"+num$(I)+")")>0  : CHAMP="[M:TPSJ]NBRDAY"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]NBRHOU"+num$(I)+")")>0  : CHAMP="[M:TPSJ]NBRHOU"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]DAYNGT"+num$(I)+")")>0  : CHAMP="[M:TPSJ]DAYNGT"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]TYPDAY"+num$(I)+")")>0  : CHAMP="[M:TPSJ]TYPDAY"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]QTY1"+num$(I)+")")>0    : CHAMP="[M:TPSJ]QTY1"+num$(I)       : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]QTY2"+num$(I)+")")>0    : CHAMP="[M:TPSJ]QTY2"+num$(I)       : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]FLD1"+num$(I)+")")>0    : CHAMP="[M:TPSJ]FLD1"+num$(I)       : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]FLD2"+num$(I)+")")>0    : CHAMP="[M:TPSJ]FLD2"+num$(I)       : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]CPY"+num$(I)+")")>0     : CHAMP="[M:TPSJ]CPY"+num$(I)        : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]BPCNUM"+num$(I)+")")>0  : CHAMP="[M:TPSJ]BPCNUM"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]SOHNUM"+num$(I)+")")>0  : CHAMP="[M:TPSJ]SOHNUM"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]SOHLIG"+num$(I)+")")>0  : CHAMP="[M:TPSJ]SOHLIG"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]INVFLG"+num$(I)+")")>0  : CHAMP="[M:TPSJ]INVFLG"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]CMT"+num$(I)+")")>0     : CHAMP="[M:TPSJ]CMT"+num$(I)        : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]STAFLG"+num$(I)+")")>0  : CHAMP="[M:TPSJ]STAFLG"+num$(I)     : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]DSP"+num$(I)+")")>0     : CHAMP="[M:TPSJ]DSP"+num$(I)        : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]CCE1"+num$(I)+")")>0    : CHAMP="[M:TPSJ]CCE1"+num$(I)       : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]CCE2"+num$(I)+")")>0    : CHAMP="[M:TPSJ]CCE2"+num$(I)       : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]CCE3"+num$(I)+")")>0    : CHAMP="[M:TPSJ]CCE3"+num$(I)       : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]CCE4"+num$(I)+")")>0    : CHAMP="[M:TPSJ]CCE4"+num$(I)       : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]CCE5"+num$(I)+")")>0    : CHAMP="[M:TPSJ]CCE5"+num$(I)       : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]CCE6"+num$(I)+")")>0    : CHAMP="[M:TPSJ]CCE6"+num$(I)       : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]CCE7"+num$(I)+")")>0    : CHAMP="[M:TPSJ]CCE7"+num$(I)       : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]CCE8"+num$(I)+")")>0    : CHAMP="[M:TPSJ]CCE8"+num$(I)       : Effzo =CHAMP : Endif
 If evalue("dim([M:TPSJ]CCE9"+num$(I)+")")>0    : CHAMP="[M:TPSJ]CCE9"+num$(I)       : Effzo =CHAMP : Endif
Next
Return

$TITBLOC
LESITE = [M]FCY
#LIPET - 12-12-2016 - X3-12033 - START
#Call PERIO(LESITE,[M]REFNUM) From SUBPEO
#Filter [PEO] Where (FCY=LESITE | FCY="") & find([M]YEA,YEAWEK)<>0  & find([M]NUMWEK,NUMWEK)<>0 Order By FCY Desc
#STAT = 0
#For [PEO]
# I = find([M]NUMWEK,[F:PEO]NUMWEK)
# If [F:PEO]YEAWEK(I-1)=[M]YEA
#  STAT = 1 : Break
# Endif
#Next
#Filter [PEO]
#If STAT=0 : Return : Endif
#DAT = [F:PEO]PERSTR(0)
Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & find([M]YEA,YEAWEK)<>0  & find([M]NUMWEK,NUMWEK)<>0 Order By PERCOD
#Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & find([M]YEA,YEAWEK)<>0
STAT = 0
For [HRPEOD]
 I = find([M]NUMWEK,[F:HRPEOD]NUMWEK)
 If [F:HRPEOD]YEAWEK(I-1)=[M]YEA
  STAT = 1 : Break
 Endif
Next
Filter [HRPEOD]
If STAT=0 : Return : Endif
DAT = [F:HRPEOD]PERSTR(0)
#LIPET - 12-12-2016 - X3-12033 - END
I -=1
DAT = DAT+(I*7)
Chgtbk [TPSJ]15 With day$(DAT)-format$("D:DD[/]MM[/]YY",DAT)
Chgtbk [TPSJ]20 With day$(DAT+1)-format$("D:DD[/]MM[/]YY",DAT+1)
Chgtbk [TPSJ]25 With day$(DAT+2)-format$("D:DD[/]MM[/]YY",DAT+2)
Chgtbk [TPSJ]30 With day$(DAT+3)-format$("D:DD[/]MM[/]YY",DAT+3)
Chgtbk [TPSJ]35 With day$(DAT+4)-format$("D:DD[/]MM[/]YY",DAT+4)
Chgtbk [TPSJ]40 With day$(DAT+5)-format$("D:DD[/]MM[/]YY",DAT+5)
Chgtbk [TPSJ]45 With day$(DAT+6)-format$("D:DD[/]MM[/]YY",DAT+6)

[M]DAT(0) = DAT
[M]DAT(1) = DAT+1
[M]DAT(2) = DAT+2
[M]DAT(3) = DAT+3
[M]DAT(4) = DAT+4
[M]DAT(5) = DAT+5
[M]DAT(6) = DAT+6

#LIPET - 12-12-2016 - X3-12033 - START
#Call MAJ_PYRDAT([M]REFNUM,[M]CTRNUM,[F:PEO]FCY,[F:PEO]PYRDAT,[M]DAT,[M]PYRDAT,STAT)
Call MAJ_PYRDAT([M]REFNUM,[M]CTRNUM,[F:HRPEOH]FCY,[F:HRPEOD]PYRDAT,[M]DAT,[M]PYRDAT,STAT)
#LIPET - 12-12-2016 - X3-12033 - END
If STAT=0 : Return : Endif
Gosub PRESENCE
Return

Subprog MAJ_PYRDATOLD(MATRI,CTR,SIT,DATEPAYE,TABDAT,TABPYRDAT,STAT)
Value    Char    MATRI,SIT,CTR
Variable Date    DATEPAYE,TABDAT(0..), TABPYRDAT(0..)
Variable Integer STAT
Local    Char    MOIDEB(2), MOIFIN(2)
Local    Integer I

#LIPET - 12-12-2016 - X3-12033 - START
#If clalev([F:CTR])=0  : Local File EMPLOCTR [CTR]  : Endif
#If clalev([F:PEO1])=0 : Local File PERIOD   [PEO1] : Endif
#STAT = 1
#Filter [CTR] Where REFNUM=MATRI & CTRNUM=CTR & (CTRDAT<=DATEPAYE | (FLGRET=2 & RETDATEFF<=DATEPAYE))
#Read [CTR]CTR0 Last
#Filter [CTR]
#If !fstat & [F:CTR]MODTPS=2
# Call PARAM(SIT,"MTTPERDEB",MOIDEB) From ADOVAL
# Call PARAM(SIT,"MTTPERFIN",MOIFIN) From ADOVAL
# For I=0 To 6
#  If (num$(month(TABDAT(I)))=MOIFIN & (TABDAT(I)<[F:PEO]PERSTR(1) | TABDAT(I)>[F:PEO]PEREND(1))) |
#&    (num$(month(TABDAT(I)))=MOIDEB & (TABDAT(I)<[F:PEO]PERSTR(1) | TABDAT(I)>[F:PEO]PEREND(1)))
#   Filter [PEO1] Where PERSTR(1)<=TABDAT(I) & PEREND(1)>=TABDAT(I)
#   Read [PEO1]PEO1 First
#   Filter [PEO1]
#   If !fstat
#    TABPYRDAT(I) = [F:PEO1]PYRDAT
#   Else
If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR]  : Endif
If clalev([F:HRPEOD1])=0 : Local File HRPEODET   [HRPEOD1] : Endif
STAT = 1
Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & (CTRDAT<=DATEPAYE | (FLGRET=2 & RETDATEFF<=DATEPAYE))
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If !fstat & [F:HRCTR]MODTPS=2
 Call PARAM(SIT,"MTTPERDEB",MOIDEB) From ADOVAL
 Call PARAM(SIT,"MTTPERFIN",MOIFIN) From ADOVAL
 For I=0 To 6
  If (num$(month(TABDAT(I)))=MOIFIN & (TABDAT(I)<[F:HRPEOD]PERSTR(1) | TABDAT(I)>[F:HRPEOD]PEREND(1))) |
&    (num$(month(TABDAT(I)))=MOIDEB & (TABDAT(I)<[F:HRPEOD]PERSTR(1) | TABDAT(I)>[F:HRPEOD]PEREND(1)))
   Filter [HRPEOD1] Where PERSTR(1)<=TABDAT(I) & PEREND(1)>=TABDAT(I)
   Read [HRPEOD1]HRPEOD1 First
   Filter [HRPEOD1]
   If !fstat
    TABPYRDAT(I) = [F:HRPEOD1]PYRDAT
   Else
    # Pas de pûˋriode d'extraction des temps
    #Call ERREUR(num$(TABDAT(I))-mess(92,703,1)) From GESECRAN
    Call ERREUR(num$(TABDAT(I))-mess(92,10703,1)) From GESECRAN
    #LIPET - 12-12-2016 - X3-12033 - END
    STAT = 0 : Break
   Endif
  Else
   TABPYRDAT(I) = DATEPAYE
  Endif
 Next
 If STAT=0 : End : Endif
Else
 For I=0 To 6
  TABPYRDAT(I) = DATEPAYE
 Next
 If STAT=0 : End : Endif
Endif
End

#Calcul de la date de paie au jour le jour car on peut avoir des contrats successif sur la mûˆme pûˋriode
#(Idem $PRESENCE)
Subprog MAJ_PYRDAT(MATRI,CTR,SIT,DATEPAYE,TABDAT,TABPYRDAT,STAT)
Value    Char    MATRI,SIT,CTR
Variable Date    DATEPAYE,TABDAT(0..), TABPYRDAT(0..)
Variable Integer STAT
Local    Char    MOIDEB(2), MOIFIN(2)
Local    Integer I
#LIPET - 12-12-2016 - X3-12033 - START
#If clalev([F:CTR2])=0  : Local File EMPLOCTR [CTR2]  : Endif
#If clalev([F:PEO1])=0 : Local File PERIOD   [PEO1] : Endif
If clalev([F:HRCTR2])=0  : Local File EMPLOCTR [HRCTR2]  : Endif
If clalev([F:HRPEOD1])=0 : Local File HRPEODET  [HRPEOD1] : Endif
STAT = 1
Local Date DATDEBCTR
#For [CTR2]CTR0 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
For [HRCTR2]CTR0 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
# On doit prendre la date de rûˋtroactivitûˋ au lieu de la date du contrat, pour dûˋterminer la prûˋsence du salariûˋ
 [L]DATDEBCTR=[F:HRCTR2]CTRDAT
 If [F:HRCTR2]FLGRET=2 & [F:HRCTR2]RETDATEFF<>[0/0/0] Then
  [L]DATDEBCTR=[F:HRCTR2]RETDATEFF
 Endif
 If [F:HRCTR2]XITDAT=[0/0/0] & [L]DATDEBCTR<=TABDAT(6)
  For I=max(TABDAT(0),[L]DATDEBCTR)-TABDAT(0) To TABDAT(6)-TABDAT(0)
   If I>6 : Break : Endif
   Filter [HRPEOD1] Where PERSTR(0)<=TABDAT(I) & PEREND(0)>=TABDAT(I) & (PERCOD=[F:HRCTR2]PERCOD) Order By Key HRPEOD1 Desc
   Read [HRPEOD1]HRPEOD1 First
   Filter [HRPEOD1]
   If !fstat
    TABPYRDAT(I) = [F:HRPEOD1]PYRDAT
   Else
    # Pas de pûˋriode d'extraction des temps
    #Call ERREUR(num$(TABDAT(I))-mess(92,703,1)) From GESECRAN
    Call ERREUR(num$(TABDAT(I))-mess(92,10703,1)) From GESECRAN
    #LIPET - 14-02-2017 - X3-18688 - START
    #STAT = 0 : Break
    STAT = 0 : mkstat=2 :End
    #LIPET - 14-02-2017 - X3-18688 - END
   Endif
  Next I
#LIPET - 12-12-2016 - X3-12033 - END
#Elsif [F:CTR2]XITDAT>=TABDAT(0) & [L]DATDEBCTR<=TABDAT(6)
 Elsif [F:HRCTR2]XITDAT>=TABDAT(0) & [L]DATDEBCTR<=TABDAT(6)
 #For I=max(TABDAT(0),[L]DATDEBCTR)-TABDAT(0) To min(TABDAT(6),[F:CTR2]XITDAT)-TABDAT(0)
  For I=max(TABDAT(0),[L]DATDEBCTR)-TABDAT(0) To min(TABDAT(6),[F:HRCTR2]XITDAT)-TABDAT(0)
   If I>6 : Break : Endif
#   Filter [PEO1] Where PERSTR(0)<=TABDAT(I) & PEREND(0)>=TABDAT(I) & (FCY=[F:CTR2]ETRFCY | FCY="") Order By Key PEO1 Desc
#   Read [PEO1]PEO1 First
#   Filter [PEO1]
   Filter [HRPEOD1] Where PERSTR(0)<=TABDAT(I) & PEREND(0)>=TABDAT(I) & (PERCOD=[F:HRCTR2]PERCOD) Order By Key HRPEOD1 Desc
   Read [HRPEOD1]HRPEOD1 First
   Filter [HRPEOD1]
   If !fstat
    TABPYRDAT(I) = [F:HRPEOD1]PYRDAT
   Else
    # Pas de pûˋriode d'extraction des temps
    #Call ERREUR(num$(TABDAT(I))-mess(92,703,1)) From GESECRAN
    Call ERREUR(num$(TABDAT(I))-mess(92,10703,1)) From GESECRAN
    STAT = 0 : Break
   Endif
   Next I
  If STAT=0 : Break : Endif
 Endif
Next
End
#LIPET - 12-12-2016 - X3-12033 - END


$PRESENCE
Local Date DATDEBCTR
Raz [M]FCY, SRV
Raz [M]PRE
#LIPET - 12-12-2016 - X3-12033 - START
#For [CTR]CTR0 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
 For [HRCTR]CTR0 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
#On doit prendre la date de rûˋtroactivitûˋ au lieu de la date du contrat, pour dûˋterminer la prûˋsence du salariûˋ
# [L]DATDEBCTR=[F:CTR]CTRDAT
# If [F:CTR]FLGRET=2 & [F:CTR]RETDATEFF<>[0/0/0] Then
#  [L]DATDEBCTR=[F:CTR]RETDATEFF
 [L]DATDEBCTR=[F:HRCTR]CTRDAT
 If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then
  [L]DATDEBCTR=[F:HRCTR]RETDATEFF
 Endif
# If [F:CTR]XITDAT=[0/0/0] & [L]DATDEBCTR<=[M]DAT(6)
 If [F:HRCTR]XITDAT=[0/0/0] & [L]DATDEBCTR<=[M]DAT(6)
  For I=max([M]DAT(0),[L]DATDEBCTR)-[M]DAT(0)+1 To [M]DAT(6)-[M]DAT(0)+1
   [M]PRE(I) = 1
  Next I
# Elsif [F:CTR]XITDAT>=[M]DAT(0) & [L]DATDEBCTR<=[M]DAT(6)
#  For I=max([M]DAT(0),[L]DATDEBCTR)-[M]DAT(0)+1 To min([M]DAT(6),[F:CTR]XITDAT)-[M]DAT(0)+1
 Elsif [F:HRCTR]XITDAT>=[M]DAT(0) & [L]DATDEBCTR<=[M]DAT(6)
  For I=max([M]DAT(0),[L]DATDEBCTR)-[M]DAT(0)+1 To min([M]DAT(6),[F:HRCTR]XITDAT)-[M]DAT(0)+1
   [M]PRE(I) = 1
  Next I
 Endif
 If [L]DATDEBCTR<=[M]DAT(6)
#  [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]DAT(6),"ETRFCY","CTR")
#  [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]DAT(6),"ETRSRV","CTR")
  [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]DAT(6),"ETRFCY","HRCTR")
  [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]DAT(6),"ETRSRV","HRCTR")
 Endif
 #LIPET - 12-12-2016 - X3-12033 - END
Next
If [M]FCY<>""
 Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 Call LECTURE("SRV",[M]SRV,"") From CONTOBJ
 If dim(AFFDATA)<0 | AFFDATA>0 Then
  Affzo [M]FCY,SRV
 Endif
Endif
Return


$CHARGE_TIMEMP
## Chargement par rapport û  TIMEMP
Filter [TIP2] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & STRDAT<=[M]DAT(6) & ENDDAT>=[M]DAT(0)
# On parcourt par date
For [TIP2]TIP4(2)
 [L]DAT = max([M]DAT(0),[F:TIP2]STRDAT)
 #LIPET - 12-12-2016 - X3-12033 - START
 #Call LECTURE("TIM",[F:TIP2]TIM,"") From CONTOBJ
 Call LECTURE("HRTIM",[F:TIP2]TIM,GCURLEG) From CONTOBJ
 #LIPET - 12-12-2016 - X3-12033 - END
 For K=1 To min([M]DAT(6),[F:TIP2]ENDDAT)-max([M]DAT(0),[F:TIP2]STRDAT)+1
  I = find([L]DAT,[M]DAT(0..6))

  If I & [M]PRE(I)=1
   NOPLAGE = 0
   Filter [TIP] Where REFNUM=[F:TIP2]REFNUM & CTRNUM=[F:TIP2]CTRNUM & STRDAT=[F:TIP2]STRDAT
   # On parcourt par plage horaire sur la date
   For [TIP]TIP4
    NOPLAGE +=1
    If NOPLAGE > [M:TPSI]NBHOR
     Call ERREUR("Chargement partiel le"-num$([F:TIP]STRDAT)) From GESECRAN
     For II=1 To NOPLAGE-1
      Assign "[M:TPSI]KFLGVISU"+num$(II)+"("+num$(I-1)+")" With -1
     Next
     Break
    Endif
    If [F:TIP]STRDAT<>[F:TIP]ENDDAT
     Call VALORIS(DAT,DAT,[F:TIP2]REFNUM,[F:TIP2]TIM,LNBRDAY,LNBRHOU,[F:TIP2]FCY,[F:TIP2]CTRNUM) From SUBPLN
     If LNBRDAY=0 & LNBRHOU=0
      Raz [F:TIP]
     Else
      LJNUIT  = [F:TIP]DAYNGT
     Endif
    Else
     LNBRDAY = [F:TIP]NBRDAY
     LNBRHOU = [F:TIP]NBRHOU
     LJNUIT  = [F:TIP]DAYNGT
    Endif
    Gosub CHARGE_TPSI
    Gosub CHARGE_ANA
   Next
   Filter [TIP]
  Endif
  DAT +=1
 Next
Next
Filter [TIP2]
Return

$CHARGE_TPSI
[M:TPSI]INI(I-1) = 1
Assign "[M:TPSI]KLIG"+num$(NOPLAGE)+"("+num$(I-1)+")"     With [F:TIP]LIG
Assign "[M:TPSI]KTIM"+num$(NOPLAGE)+"("+num$(I-1)+")"     With [F:TIP]TIM
Assign "[M:TPSI]KCTRDAT"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:TIP]CTRDAT
#LIPET - 12-12-2016 - X3-12033 - START
#Read [F:CTR]CTR0=[M]REFNUM;[M]CTRNUM;[F:TIP]CTRDAT
#If !fstat Then
#  Assign "[M:TPSI]KSCTRDAT"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:CTR]XITDAT
#Endif
Read [F:HRCTR]CTR0=[M]REFNUM;[M]CTRNUM;[F:TIP]CTRDAT
If !fstat Then
  Assign "[M:TPSI]KSCTRDAT"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:HRCTR]XITDAT
Endif
#LIPET - 12-12-2016 - X3-12033 - END
Assign "[M:TPSI]KFCYT"+num$(NOPLAGE)+"("+num$(I-1)+")"    With [F:TIP]FCY
Assign "[M:TPSI]KSRVT"+num$(NOPLAGE)+"("+num$(I-1)+")"    With [F:TIP]SRV
Assign "[M:TPSI]KSTRTIM"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:TIP]STRTIM
Assign "[M:TPSI]KENDTIM"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:TIP]ENDTIM
Assign "[M:TPSI]KBRKTIM"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:TIP]BRKTIM
Assign "[M:TPSI]KTYPPGN"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:TIP]TYPPGN

If [F:TIP]STRDAT=[F:TIP]ENDDAT & [F:TIP]STRDAY=2 & [F:TIP]ENDDAY=1
 Assign "[M:TPSI]KLEADAY"+num$(NOPLAGE)+"("+num$(I-1)+")"  With 1 : # Matin
Elsif [F:TIP]STRDAT=[F:TIP]ENDDAT & [F:TIP]STRDAY=1 & [F:TIP]ENDDAY=2
 Assign "[M:TPSI]KLEADAY"+num$(NOPLAGE)+"("+num$(I-1)+")"  With 2 : # AM
Else
 Assign "[M:TPSI]KLEADAY"+num$(NOPLAGE)+"("+num$(I-1)+")"  With 3 : # Journûˋe
Endif

Assign "[M:TPSI]KNATCOD"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:TIP]NATCOD
Assign "[M:TPSI]KNBRDAY"+num$(NOPLAGE)+"("+num$(I-1)+")"  With LNBRDAY
Assign "[M:TPSI]KNBRHOU"+num$(NOPLAGE)+"("+num$(I-1)+")"  With LNBRHOU
Assign "[M:TPSI]KDAYNGT"+num$(NOPLAGE)+"("+num$(I-1)+")"  With LJNUIT
Assign "[M:TPSI]KTYPDAY"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:TIP]TYPDAY
Assign "[M:TPSI]KQTY1"+num$(NOPLAGE)+"("+num$(I-1)+")"    With [F:TIP]QTY1
Assign "[M:TPSI]KQTY2"+num$(NOPLAGE)+"("+num$(I-1)+")"    With [F:TIP]QTY2
Assign "[M:TPSI]KFLD1"+num$(NOPLAGE)+"("+num$(I-1)+")"    With [F:TIP]FLD1
Assign "[M:TPSI]KFLD2"+num$(NOPLAGE)+"("+num$(I-1)+")"    With [F:TIP]FLD2
Assign "[M:TPSI]KCPY"+num$(NOPLAGE)+"("+num$(I-1)+")"     With [F:TIP]CPY
Assign "[M:TPSI]KBPCNUM"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:TIP]BPCNUM
Assign "[M:TPSI]KSOHNUM"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:TIP]SOHNUM
Assign "[M:TPSI]KSOHLIG"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:TIP]SOHLIG
Assign "[M:TPSI]KINVFLG"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:TIP]INVFLG
Assign "[M:TPSI]KCMT"+num$(NOPLAGE)+"("+num$(I-1)+")"     With [F:TIP]CMT
Assign "[M:TPSI]KSTAFLG"+num$(NOPLAGE)+"("+num$(I-1)+")"  With [F:TIP]STAFLG
Assign "[M:TPSI]KDSP"+num$(NOPLAGE)+"("+num$(I-1)+")"     With [F:TIP]DSP
# Evû´nement saisi sur le mois de paye prûˋcûˋdent (exemple : Saisie calendaire des CP)
If [F:TIP]DATPYR<>[M:TPSJ]PYRDAT(I-1)
 Assign "[M:TPSI]KFLGVISU"+num$(NOPLAGE)+"("+num$(I-1)+")" With -1
Endif
# Ligne visûˋe
If GVISA=2 & [F:TIP]STAFLG<>"" & !instr(1,GUSRAUZ(1),"4")
 Assign "[M:TPSI]KFLGVISU"+num$(NOPLAGE)+"("+num$(I-1)+")" With -1
Endif
#LIPET - 12-12-2016 - X3-12033 - START
# Pûˋriode fermûˋe
#If [F:PEO]STA<>2 & !instr(1,GUSRAUZ(1),"5") & ([F:TIP]TIM<>GTPSW or !instr(1,GUSRAUZ(1),"6"))
If [F:HRPEOD]STA<>2 & !instr(1,GUSRAUZ(1),"5") & ([F:TIP]TIM<>GTPSW or !instr(1,GUSRAUZ(1),"6"))
#LIPET - 12-12-2016 - X3-12033 - END
 Assign "[M:TPSI]KFLGVISU"+num$(NOPLAGE)+"("+num$(I-1)+")" With -1
Endif
Return


$CHARGE_ANA
# FQ92876 - 25/09/14 - Ajout sauvegarde des nouveaux champs [M:TPSI]KDIExx
For L=1 To GOPTCANA
 Case L
  When 1 : Assign "[M:TPSI]KCCE1"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]CCE(0) : Assign "[M:TPSI]KDIE1"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]DIE(0)
  When 2 : Assign "[M:TPSI]KCCE2"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]CCE(1) : Assign "[M:TPSI]KDIE2"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]DIE(1)
  When 3 : Assign "[M:TPSI]KCCE3"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]CCE(2) : Assign "[M:TPSI]KDIE3"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]DIE(2)
  When 4 : Assign "[M:TPSI]KCCE4"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]CCE(3) : Assign "[M:TPSI]KDIE4"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]DIE(3)
  When 5 : Assign "[M:TPSI]KCCE5"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]CCE(4) : Assign "[M:TPSI]KDIE5"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]DIE(4)
  When 6 : Assign "[M:TPSI]KCCE6"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]CCE(5) : Assign "[M:TPSI]KDIE6"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]DIE(5)
  When 7 : Assign "[M:TPSI]KCCE7"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]CCE(6) : Assign "[M:TPSI]KDIE7"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]DIE(6)
  When 8 : Assign "[M:TPSI]KCCE8"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]CCE(7) : Assign "[M:TPSI]KDIE8"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]DIE(7)
  When 9 : Assign "[M:TPSI]KCCE9"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]CCE(8) : Assign "[M:TPSI]KDIE9"+num$(NOPLAGE)+"("+num$(I-1)+")"   With [F:TIP]DIE(8)
 Endcase
Next
If [F:TIP]ANAFLG=1
 K = [M:VT2]PTVENT+1
 NOL = (I-1)+7*(NOPLAGE-1)
 # PTV et PTF variable de dimension 21 (7 jours * 3 plages). Chaque indice correspond û  1 jour et 1 plage.
 [M:TPSI]PTV(NOL) = K
 For [TIA]TIA0 Where LIG=[F:TIP]LIG
  #92876_US2757
  For AXE=1 To [M]NBRDIE
   If AXE>GOPTCANA : Break : Endif
   L=find([M]WDIE(AXE-1),[F:TIA]DIE(0..dim([F:TIA]DIE)-1))
   If L
    Assign "[M:VT2]TBCCE"+num$(AXE)+"(K)" With [F:TIA]CCE(L-1)
    If [M:VT2]TBDIE(L-1)="" : [M:VT2]TBDIE(L-1)=[F:TIA]DIE(L-1) : Endif
   Endif
  Next
  [M:VT2]TBAMT(K) = [F:TIA]NBRHOU
  #end 92876_US2757
  K += 1
  [M:VT2]PTVENT += 1
 Next
 [M:TPSI]PTF(NOL) = K-1
 Assign "[M:TPSI]KDSP"+num$(NOPLAGE)+"("+num$(I-1)+")" With "$"
Endif
Return

$CHARGE_PLANNING
Local Date CTRDATT
Local Char CCE(GLONCCE)(1..), VCCE(GLONCCE) :#92876_US2759 autant les dûˋclarer lû  oû¿ on s'en sert.
# FQ92876 - 25/09/14 - Ajout de l'axe DIE
Local Char DIE(GLONDIE)(1..)
Local Char SAU_GSOCIETE(GLONCPY)
If clalev([F:CTRD])=0 : Local File EMPLOCTR [CTRD] : Endif
## Chargement par rapport au planning salariûˋ (PLANEMP) si TIMEMP vide
#ADNGO - 2016-01-26 - X3-12033 - START
#Read [TIM]TIM0=GTPSW

Read [TIM]TIM0=GCURLEG;GTPSW
#ADNGO - 2016-01-26 - X3-12033 - END
For K=0 To 6               : # Boucle sur les jours
 If [M:TPSI]KTIM1(K)="" & [M:TPSI]KTIM2(K)="" & [M:TPSI]KTIM3(K)="" & [M]PRE(K+1)=1
  For I=1 To [M:TPSI]NBHOR : # Boucle sur les plages horaires
   Case I
    When 1
     # FQ92876 - 25/09/14 - Ajout de l'axe DIE
#     Call JOUR([M]REFNUM,[M]DAT(K),LTYP,JOUR,HEURE,[M:TPSI]KDAYNGT1(K),[M]FCY,[M]CTRNUM,I
#&             ,[M:TPSI]KSTRTIM1(K),[M:TPSI]KENDTIM1(K),[M:TPSI]KBRKTIM1(K),[M:TPSI]KNATCOD1(K),CCE,INI) From SUBPLN
     Call JOUR_AXE([M]REFNUM,[M]DAT(K),LTYP,JOUR,HEURE,[M:TPSI]KDAYNGT1(K),[M]FCY,[M]CTRNUM,I
&             ,[M:TPSI]KSTRTIM1(K),[M:TPSI]KENDTIM1(K),[M:TPSI]KBRKTIM1(K),[M:TPSI]KNATCOD1(K),CCE,INI,DIE) From SUBPLN
     # DAYTYP=1=Ouvrable DAYTYP=2=Ouvrûˋ. JOUR(2)=0 si jour ouvrable et code W paramûˋtrûˋ en ouvrûˋ
     If ([F:TIM]DAYTYP=2 & JOUR(2)<>0) | ([F:TIM]DAYTYP=1 & JOUR(1)<>0)
      If GNBHOR=0
       Case [F:TIM]DAYTYP
        When 1 : Assign "[M:TPSI]KNBRHOU1("+num$(K)+")" With HEURE(1)
                 Assign "[M:TPSI]KNBRDAY1("+num$(K)+")" With JOUR(1)
        When 2 : Assign "[M:TPSI]KNBRHOU1("+num$(K)+")" With HEURE(2)
                 Assign "[M:TPSI]KNBRDAY1("+num$(K)+")" With JOUR(2)
       Endcase
      Else
       Call MAJHOU(1,K+1,[M:TPSI]KSTRTIM1(K),[M:TPSI]KENDTIM1(K),[M:TPSI]KBRKTIM1(K),
&                  "[M:TPSI]KNBRHOU1("+num$(K)+")","[M:TPSI]KNBRDAY1("+num$(K)+")",0,1) From TPSJOU2
      Endif
     Else
      Raz [M:TPSI]KSTRTIM1(K),[M:TPSI]KENDTIM1(K),[M:TPSI]KBRKTIM1(K)
     Endif

    When 2
     # FQ92876 - 25/09/14 - Ajout de l'axe DIE
#     Call JOUR([M]REFNUM,[M]DAT(K),LTYP,JOUR,HEURE,[M:TPSI]KDAYNGT2(K),[M]FCY,[M]CTRNUM,I
#&             ,[M:TPSI]KSTRTIM2(K),[M:TPSI]KENDTIM2(K),[M:TPSI]KBRKTIM2(K),[M:TPSI]KNATCOD2(K),CCE,INI) From SUBPLN
     Call JOUR_AXE([M]REFNUM,[M]DAT(K),LTYP,JOUR,HEURE,[M:TPSI]KDAYNGT2(K),[M]FCY,[M]CTRNUM,I
&             ,[M:TPSI]KSTRTIM2(K),[M:TPSI]KENDTIM2(K),[M:TPSI]KBRKTIM2(K),[M:TPSI]KNATCOD2(K),CCE,INI,DIE) From SUBPLN
     If ([F:TIM]DAYTYP=2 & JOUR(2)<>0) | ([F:TIM]DAYTYP=1 & JOUR(1)<>0)
      Call MAJHOU(2,K+1,[M:TPSI]KSTRTIM2(K),[M:TPSI]KENDTIM2(K),[M:TPSI]KBRKTIM2(K),
&                 "[M:TPSI]KNBRHOU2("+num$(K)+")","[M:TPSI]KNBRDAY2("+num$(K)+")",0,1) From TPSJOU2
     Else
      Raz [M:TPSI]KSTRTIM2(K),[M:TPSI]KENDTIM2(K),[M:TPSI]KBRKTIM2(K)
     Endif

    When 3
     # FQ92876 - 25/09/14 - Ajout de l'axe DIE
#     Call JOUR([M]REFNUM,[M]DAT(K),LTYP,JOUR,HEURE,[M:TPSI]KDAYNGT3(K),[M]FCY,[M]CTRNUM,I
#&             ,[M:TPSI]KSTRTIM3(K),[M:TPSI]KENDTIM3(K),[M:TPSI]KBRKTIM3(K),[M:TPSI]KNATCOD3(K),CCE,INI) From SUBPLN
     Call JOUR_AXE([M]REFNUM,[M]DAT(K),LTYP,JOUR,HEURE,[M:TPSI]KDAYNGT3(K),[M]FCY,[M]CTRNUM,I
&             ,[M:TPSI]KSTRTIM3(K),[M:TPSI]KENDTIM3(K),[M:TPSI]KBRKTIM3(K),[M:TPSI]KNATCOD3(K),CCE,INI,DIE) From SUBPLN
     If ([F:TIM]DAYTYP=2 & JOUR(2)<>0) | ([F:TIM]DAYTYP=1 & JOUR(1)<>0)
      Call MAJHOU(3,K+1,[M:TPSI]KSTRTIM3(K),[M:TPSI]KENDTIM3(K),[M:TPSI]KBRKTIM3(K),
&                 "[M:TPSI]KNBRHOU3("+num$(K)+")","[M:TPSI]KNBRDAY3("+num$(K)+")",0,1) From TPSJOU2
     Else
      Raz [M:TPSI]KSTRTIM3(K),[M:TPSI]KENDTIM3(K),[M:TPSI]KBRKTIM3(K)
     Endif
   Endcase

   If LTYP<>0 : [M:TPSI]INI(K) = 2 : Endif

   If LTYP=0
    # Employûˋ sans planning
    [M:TPSI]WIOPLN = 1 : Break 2
   Elsif LTYP<>3 & ([F:TIM]DAYTYP=2 & JOUR(2)<>0) | ([F:TIM]DAYTYP=1 & JOUR(1)<>0)
    # Jour non chûÇmûˋ et ouvrable (si W ouvrable) ou ouvrûˋ (si W ouvrûˋ)
    If GNBHOR=0 | ( evalue("[M:TPSI]KSTRTIM"+num$(I)+"("+num$(K)+")")<>"" &
&                   evalue("[M:TPSI]KENDTIM"+num$(I)+"("+num$(K)+")")<>"" )

     Assign "[M:TPSI]KTIM"+num$(I)+"(K)"    With GTPSW
     Assign "[M:TPSI]KLEADAY"+num$(I)+"(K)" With 3
     CTRDATT=func TPSSTD.CALC_CTRDATDEF([M:TPSJ]REFNUM,[M:TPSJ]CTRNUM,[M:TPSJ]DAT(K),[M:TPSJ]PYRDAT(K),[M:TPSJ]DAT(K),3)
     Read [F:CTRD]CTR0=[M:TPSJ]REFNUM;[M:TPSJ]CTRNUM;CTRDATT
     If !fstat Then
      Assign "[M:TPSI]KCTRDAT"+num$(I)+"(K)"  With [F:CTRD]CTRDAT
      Assign "[M:TPSI]KSCTRDAT"+num$(I)+"(K)" With [F:CTRD]XITDAT
      Assign "[M:TPSI]KFCYT"+num$(I)+"(K)"    With func SUBCTRRET.FIND_RETRO_FLD([M:TPSJ]REFNUM,[M:TPSJ]CTRNUM,[F:CTRD]CTRDAT,[M:TPSJ]PYRDAT(K),"ETRFCY","CTRD")
      Assign "[M:TPSI]KSRVT"+num$(I)+"(K)"    With func SUBCTRRET.FIND_RETRO_FLD([M:TPSJ]REFNUM,[M:TPSJ]CTRNUM,[F:CTRD]CTRDAT,[M:TPSJ]PYRDAT(K),"ETRSRV","CTRD")
     Endif

     If evalue("[M:TPSI]KNATCOD"+num$(I)+"(K)")<>""
      Call LECTURE("NAT",evalue("[M:TPSI]KNATCOD"+num$(I)+"(K)"),GCURLEG) From CONTOBJ
      If !fstat
       Assign "[M:TPSI]KTYPDAY"+num$(I)+"(K)" With [F:NAT]TYPDAY
       Assign "[M:TPSI]KQTY1"+num$(I)+"(K)" With [F:NAT]QTY1
       Assign "[M:TPSI]KQTY2"+num$(I)+"(K)" With [F:NAT]QTY2
       Assign "[M:TPSI]KFLD1"+num$(I)+"(K)" With [F:NAT]FLD1
       Assign "[M:TPSI]KFLD2"+num$(I)+"(K)" With [F:NAT]FLD2
      Endif
     Endif
     If INI
      # Affectation des sections analytiques en fonction du planning salariûˋ
      For J=1 To GOPTCANA
       If GFONCTION="TPSJOU" & J>9 : Break : Endif
       Assign "[M:TPSI]KCCE"+num$(J)+num$(I)+"(K)" With CCE(J)
       # FQ92876 - 25/09/14 - Ajout de l'axe DIE
       Assign "[M:TPSI]KDIE"+num$(J)+num$(I)+"(K)" With DIE(J)
      Next
     Else
      SAU_GSOCIETE=GSOCIETE
      GSOCIETE=func DIVPAYE.GETSOC(evalue("[M:TPSI]KFCYT"+num$(I)+"(K)"))
      If GSOCIETE="" Then GSOCIETE=SAU_GSOCIETE : Endif
      For J=1 To GOPTCANA
       If GFONCTION="TPSJOU" & J>9 : Break : Endif
       Raz VCCE
       #92876_US2759 : on optimise
       #Call LECTURE("NAT",evalue("[M:TPSI]KNATCOD"+num$(I)+"(K)"),"") From CONTOBJ
       #Call INICCE(evalue("[M:TPSI]KTIM"+num$(I)+"(K)"),J,VCCE) From TPSSTD
       Call INICCE(evalue("[M:TPSI]KNATCOD"+num$(I)+"(K)"),evalue("[M:TPSI]KTIM"+num$(I)+"(K)"),J,VCCE) From TPSDIV
       #end 92876_US2759
       Assign "[M:TPSI]KCCE"+num$(J)+num$(I)+"("+num$(K)+")" With VCCE
       # FQ92876 - 25/09/14 - Ajout sauvegarde des nouveaux champs [M:TPSI]KDIExx
       Assign "[M:TPSI]KDIE"+num$(J)+num$(I)+"("+num$(K)+")" With [F:TIM]DIE(J-1)
      Next
      GSOCIETE=SAU_GSOCIETE
     Endif
    Endif
   Endif
  Next
 Endif
Next
Return

$REMP_TPSI
Local Integer IJ,IK
Filter [AMZ] Where CODMSK="WMJOU"+GFLAG & NUMBLOC>=4 & NUMBLOC<=10
For [AMZ]CODZON
 If pat([F:AMZ]CODZON,"STRTIM##") | pat([F:AMZ]CODZON,"ENDTIM##")
  J     = val(right$([F:AMZ]CODZON,len([F:AMZ]CODZON)))
  K     = val(mid$([F:AMZ]CODZON,len([F:AMZ]CODZON)-1,1))
  CHAMP = left$([F:AMZ]CODZON,len([F:AMZ]CODZON)-2)+num$(J)
  If evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(K-1)+")")<>"" Then
#LIPET - 12-12-2016 - X3-12033 - START
#    Call LECTURE("TIM",evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(K-1)+")"),"") From CONTOBJ
#  Else
#    Call LECTURE("TIM",evalue("[M:TPSJ]TIM"+num$(K)),"") From CONTOBJ
    Call LECTURE("HRTIM",evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(K-1)+")"),GCURLEG) From CONTOBJ
  Else
    Call LECTURE("HRTIM",evalue("[M:TPSJ]TIM"+num$(K)),GCURLEG) From CONTOBJ
 #LIPET - 12-12-2016 - X3-12033 - END
  Endif
  If [F:TIM]PLGHOR = 2
    Assign "[M:TPSI]K"+CHAMP+"("+num$(K-1)+")" With evalue("[M:TPSJ]"+[F:AMZ]CODZON)
  Else
    Assign "[M:TPSI]K"+CHAMP+"("+num$(K-1)+")" With ""
  Endif
 # FQ92876 - 25/09/14 - Gestion spûˋcifique des champs CCE/DIE
 Elsif pat([F:AMZ]CODZON,"CCE##")
  IJ   = val(mid$([F:AMZ]CODZON,4,1))
  J     = val(left$([M]NUMPLG,1))
  IK   = val(mid$([F:AMZ]CODZON,5,1))
  Assign "[M:TPSI]KCCE"+num$(IJ)+num$(J)+"("+num$(K-1)+")" With evalue("[M:TPSJ]CCE"+num$(IJ)+num$(IK))
  Assign "[M:TPSI]KDIE"+num$(IJ)+num$(J)+"("+num$(K-1)+")" With evalue("[M:TPSJ]WDIE("+num$(IJ-1)+")")
 Else
  J     = val(left$([M:TPSJ]NUMPLG,1))
  K     = val(right$([F:AMZ]CODZON,len([F:AMZ]CODZON)))
  CHAMP = left$([F:AMZ]CODZON,len([F:AMZ]CODZON)-1)+num$(J)
  Assign "[M:TPSI]K"+CHAMP+"("+num$(K-1)+")" With evalue("[M:TPSJ]"+[F:AMZ]CODZON)
 Endif
Next
Filter [AMZ]
Return

$REMP_TPSJ
Local Integer L,IJ,FOUNDL,OK
Local Char FCY_REF(GLONFCY)
Actzo [M:TPSJ]15-45

Filter [AMZ] Where CODMSK="WMJOU"+GFLAG & NUMBLOC>=4 & NUMBLOC<=10
For [AMZ]CODZON

 If pat([F:AMZ]CODZON,"STRTIM##") | pat([F:AMZ]CODZON,"ENDTIM##")
  J     = val(right$([F:AMZ]CODZON,len([F:AMZ]CODZON)))
  K     = val(mid$([F:AMZ]CODZON,len([F:AMZ]CODZON)-1,1))
  CHAMP = left$([F:AMZ]CODZON,len([F:AMZ]CODZON)-2)+num$(J)
  #LIPET - 12-12-2016 - X3-12033 - START
  #Call LECTURE("TIM",evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(K-1)+")"),"") From CONTOBJ
  Call LECTURE("HRTIM",evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(K-1)+")"),GCURLEG) From CONTOBJ
  #LIPET - 12-12-2016 - X3-12033 - END
  If [F:TIM]PLGHOR = 2
    Assign "[M:TPSJ]"+[F:AMZ]CODZON With evalue("[M:TPSI]K"+CHAMP+"("+num$(K-1)+")")
  Else
    Assign "[M:TPSJ]"+[F:AMZ]CODZON With ""
  Endif
  If evalue("[M:TPSI]KFLGVISU"+num$(J)+"("+num$(K-1)+")")<>0 | GCONSULT  | [M]PRE(K)=0
   Diszo ="[M:TPSJ]"+[F:AMZ]CODZON
  Endif
 # FQ92876 - 25/09/14 - Gestion spûˋcifique des champs CCE/DIE
 Elsif pat([F:AMZ]CODZON,"CCE##")
  J     = val(left$([M]NUMPLG,1))
  K     = val(right$([F:AMZ]CODZON,len([F:AMZ]CODZON)))
  FOUNDL=0
  IJ    = val(mid$([F:AMZ]CODZON,4,1))
  If evalue("dim([M]FCYT"+num$(K)+")")>0 Then
    FCY_REF=evalue("[M]FCYT"+num$(K))
  Elsif evalue("dim([M]CPY"+num$(K)+")")>0 Then
    Filter [F:FCY] Where LEGCPY=evalue("[M]CPY"+num$(K))
    Read [F:FCY] First
    Filter [F:FCY]
    FCY_REF=[F:FCY]FCY
  Else
    If clalev([F:CTRD])=0 : Local File EMPLOCTR [CTRD] : Endif
    Filter [CTRD] Where REFNUM=[M:TPSJ]REFNUM & CTRNUM=[M:TPSJ]CTRNUM & (CTRDAT<=[M:TPSJ]DAT(K-1) | (FLGRET=2 & RETDATEFF<=[M:TPSJ]DAT(K-1)))
    Read [F:CTRD] Last
    FCY_REF=[F:CTRD]ETRFCY
  Endif
  If FCY_REF="" Then FCY_REF=[M]FCY : Endif
  OK=0
  Call CPY_AXE(IJ,FCY_REF,OK) From TPSDIV
  If OK Then
    For L=1 To 9
      If [M]WDIE(IJ-1)=evalue("[M:TPSI]KDIE"+num$(L)+num$(J)+"("+num$(K-1)+")") Then
        FOUNDL=1
        Break
      Endif
    Next
    If FOUNDL Then
      Assign "[M:TPSJ]"+[F:AMZ]CODZON With evalue("[M:TPSI]KCCE"+num$(L)+num$(J)+"("+num$(K-1)+")")
    Else
      Assign "[M:TPSJ]"+[F:AMZ]CODZON With ""
    Endif
  Endif
  If evalue("[M:TPSI]KFLGVISU"+num$(J)+"("+num$(K-1)+")")<>0 | GCONSULT | [M]PRE(K)=0
   Diszo ="[M:TPSJ]"+[F:AMZ]CODZON
  Endif
 Else
  J     = val(left$([M]NUMPLG,1))
  K     = val(right$([F:AMZ]CODZON,len([F:AMZ]CODZON)))
  CHAMP = left$([F:AMZ]CODZON,len([F:AMZ]CODZON)-1)+num$(J)
  Assign "[M:TPSJ]"+[F:AMZ]CODZON With evalue("[M:TPSI]K"+CHAMP+"("+num$(K-1)+")")
  If evalue("[M:TPSI]KFLGVISU"+num$(J)+"("+num$(K-1)+")")<>0 | GCONSULT | [M]PRE(K)=0
   Diszo ="[M:TPSJ]"+[F:AMZ]CODZON
  Endif
 Endif
Next
Filter [AMZ]
Return

$SETBOUT
CHMEN = ""
REPORT1 = GREPORT1
REPORT2 = ""
If GREP="M"
 CHBOU = "EA"
 STADEF = GSTAENR
Else
 CHBOU = "09ILT"
 If ([M:TPSI]INI(0)=2 & ([M:TPSI]KTIM1(0)<>"" | [M:TPSI]KTIM2(0)<>"" | [M:TPSI]KTIM3(0)<>""))
& | ([M:TPSI]INI(1)=2 & ([M:TPSI]KTIM1(1)<>"" | [M:TPSI]KTIM2(1)<>"" | [M:TPSI]KTIM3(1)<>""))
& | ([M:TPSI]INI(2)=2 & ([M:TPSI]KTIM1(2)<>"" | [M:TPSI]KTIM2(2)<>"" | [M:TPSI]KTIM3(2)<>""))
& | ([M:TPSI]INI(3)=2 & ([M:TPSI]KTIM1(3)<>"" | [M:TPSI]KTIM2(3)<>"" | [M:TPSI]KTIM3(3)<>""))
& | ([M:TPSI]INI(4)=2 & ([M:TPSI]KTIM1(4)<>"" | [M:TPSI]KTIM2(4)<>"" | [M:TPSI]KTIM3(4)<>""))
& | ([M:TPSI]INI(5)=2 & ([M:TPSI]KTIM1(5)<>"" | [M:TPSI]KTIM2(5)<>"" | [M:TPSI]KTIM3(5)<>""))
& | ([M:TPSI]INI(6)=2 & ([M:TPSI]KTIM1(6)<>"" | [M:TPSI]KTIM2(6)<>"" | [M:TPSI]KTIM3(6)<>""))
  CHBOU += "E"
  STADEF = GSTAENR
 Endif
 CHMEN ="D"
 If [M]REFNUM<>"" & [M]NUMWEK<>0 & [M]YEA<>0
  CHBOU += "<>"
  #LIPET - 2017-06-13 - X3-44692 - START
  #CHMEN += "567"
  CHMEN += "57"
  #LIPET - 2017-06-13 - X3-44692 - END
  #LIPET - 12-12-2016 - X3-12033 - START
  #If [F:PEO]STA=2 | instr(1,GUSRAUZ(1),"5") | instr(1,GUSRAUZ(1),"6")
  If [F:HRPEOD]STA=2 | instr(1,GUSRAUZ(1),"5") | instr(1,GUSRAUZ(1),"6")
  #LIPET - 12-12-2016 - X3-12033 - END
   If GPAYE
    Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=[M]PYRDAT & CTRNUM=[M]CTRNUM
    Read [VEP]VEP0 First
    Filter [VEP]
    If fstat | [F:VEP]PST<2
     CHMEN += "4"
    Endif
   Else
    CHMEN +="4"
   Endif
  Endif

  # GVISA : Globale du paramû´tre VISA. Menu local 1. Gestion des visas.
  If instr(1,GUSRAUZ(1),"2") & GVISA=2 & dim([M]STAFLG1)>0 & instr(1,CHBOU,"E")=0 : # Saisie visa
   CHMEN += "V"
  Endif
  If instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
   REPORT2 = GREPORT2
   Case DEFILE
    When 1
     CHMEN += "2"
    When 2
     CHMEN += "1"
    When 3
     CHMEN += "2"
   Endcase
  Endif
 Endif
Endif
#LIPET - 2017-06-13 - X3-44692 - START
If func DIVPAYE.IS_KFR_LEG(GCURLEG) Then
  [L]CHMEN += "A6"
  Gosub SET_BOUT_SPE From GSAISIE
Endif
#LIPET - 2017-06-13 - X3-44692 - END
If [M]REFNUM<>"" & [M]NUMWEK<>0 & [M]YEA<>0 # & instr(1,CHBOU,"E")=0
 # Recopie jour
 CHMEN +="C"
Endif

Gosub SET_BOUT_STD From GSAISIE
Gosub SET_BOUT_SPE From GSAISIE
Return


$BOUTON
Case BOUT
 When "V"
 #LIPET - 12-12-2016 - X3-12033 - START
  #OK = 2 : Call OUINON(mess(27,709,1),OK) From GESECRAN : # Confirmation du visa
  OK = 2 : Call OUINON(mess(27,10709,1),OK) From GESECRAN : # Confirmation du visa
 #LIPET - 12-12-2016 - X3-12033 - END
  If OK=2
   Call DEBTRANS From GLOCK
   Gosub TR2
   If GOK=1
    Gosub CHARGE
   Endif
  Endif
 When "C"
  If GSTATUT=GSTAOK
   Gosub CHARGE
  Endif
 When "D"
  Gosub CHARGE
Endcase
Return

# Visa
$TR2
GOK = 1
Trbegin [TIP]
  For I=0 To 6
   For J=1 To [M:TPSI]NBHOR
   K = evalue("[M:TPSI]KLIG"+num$(J)+"("+num$(I)+")")
    If K<>0 & evalue("[M:TPSI]KFLGVISU"+num$(J)+"("+num$(I)+")")<>0
    Update [TIP] Where LIG=K & REFNUM=[M]REFNUM With STAFLG=GUSER
    If fstat
     GOK = 0 : Call RSTA("TIP",[M]REFNUM) From GLOCK : Goto AB_TR2
    Endif
   Endif
  Next
 Next
Commit
Return

$AB_TR2
Rollback
Return

$PLG_SUIV
# On conserve les modifications qu'on a faites sur l'ûˋcran avant de passer û  la plage suivante
Gosub REMP_TPSI
J = val(left$([M]NUMPLG,1))
J +=1
[M]NUMPLG = num$(J)+right$([M]NUMPLG,2)
If J=GNBHOR | GNBHOR=0
 [M:TPSJ]SUIPLG = ""
 Grizo [TPSJ]SUIPLG
Else
 [M:TPSJ]SUIPLG = "29"
 Actzo [TPSJ]SUIPLG
Endif
If J=1
 [M:TPSJ]PREPLG = ""
 Grizo [TPSJ]PREPLG
Else
 [M:TPSJ]PREPLG = "30"
 Actzo [TPSJ]PREPLG
Endif
Affzo [TPSJ]NUMPLG,PREPLG,SUIPLG
Gosub REMP_TPSJ
Gosub COLORE_PLAGE
Affzo [TPSJ]15-45
Return


$COLORE_PLAGE
If dim([M:TPSJ]STRTIM11)>0
 K = [M:TPSI]NBHOR
 Repeat
 # Boucle sur les plages
  If K=J
   For L=1 To 7
   # Boucle sur les 7 jours
    If [M:TPSI]INI(L-1)=2
     Chgstl [TPSJ] ="STRTIM"+num$(L)+num$(K) With "INITPLGCUR"
     Chgstl [TPSJ] ="ENDTIM"+num$(L)+num$(K) With "INITPLGCUR"
    Else
     Chgstl [TPSJ] ="STRTIM"+num$(L)+num$(K) With "PLGCUR"
     Chgstl [TPSJ] ="ENDTIM"+num$(L)+num$(K) With "PLGCUR"
    Endif
    Gosub CHG_STY
   Next
  Else
   For L=1 To 7
    If [M:TPSI]INI(L-1)=2
     Chgstl [TPSJ] ="STRTIM"+num$(L)+num$(K) With "INITPLAGE"
     Chgstl [TPSJ] ="ENDTIM"+num$(L)+num$(K) With "INITPLAGE"
    Else
     Chgstl [TPSJ] ="STRTIM"+num$(L)+num$(K) With "PLAGE"
     Chgstl [TPSJ] ="ENDTIM"+num$(L)+num$(K) With "PLAGE"
    Endif
    Gosub CHG_STY
   Next
  Endif
  K-=1
 Until K=0
Endif
Return

$CHG_STY
Local Char STYLE (GLONSTY)
If [M:TPSI]INI(L-1)=2
 STYLE="INIT"
Else
 STYLE=""
Endif
If evalue("dim([M:TPSJ]TIM"+num$(L)+")")     >=0 : Chgstl [TPSJ]= "TIM"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]TYPPGN"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "TYPPGN"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]LEADAY"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "LEADAY"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]BRKTIM"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "BRKTIM"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]NATCOD"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "NATCOD"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]NBRDAY"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "NBRDAY"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]NBRHOU"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "NBRHOU"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]DAYNGT"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "DAYNGT"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]TYPDAY"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "TYPDAY"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]QTY1"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "QTY1"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]QTY2"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "QTY2"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]FLD1"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "FLD1"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]FLD2"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "FLD2"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]CPY"+num$(L)+")")     >=0 : Chgstl [TPSJ]= "CPY"+num$(L)    With STYLE : Endif
If evalue("dim([M:TPSJ]BPCNUM"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "BPCNUM"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]SOHNUM"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "SOHNUM"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]SOHLIG"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "SOHLIG"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]INVFLG"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "INVFLG"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]CMT"+num$(L)+")")     >=0 : Chgstl [TPSJ]= "CMT"+num$(L)    With STYLE : Endif
If evalue("dim([M:TPSJ]STAFLG"+num$(L)+")")  >=0 : Chgstl [TPSJ]= "STAFLG"+num$(L) With STYLE : Endif
If evalue("dim([M:TPSJ]DSP"+num$(L)+")")     >=0 : Chgstl [TPSJ]= "DSP"+num$(L)    With STYLE : Endif
If evalue("dim([M:TPSJ]CCE1"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "CCE1"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]CCE2"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "CCE2"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]CCE3"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "CCE3"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]CCE4"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "CCE4"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]CCE5"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "CCE5"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]CCE6"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "CCE6"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]CCE7"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "CCE7"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]CCE8"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "CCE8"+num$(L)   With STYLE : Endif
If evalue("dim([M:TPSJ]CCE9"+num$(L)+")")    >=0 : Chgstl [TPSJ]= "CCE9"+num$(L)   With STYLE : Endif
Return


$PLG_PREC
# On conserve les modifications qu'on a faites sur l'ûˋcran avant de passer û  la plage prûˋcûˋdente
Gosub REMP_TPSI
J = val(left$([M]NUMPLG,1))
J -=1
[M]NUMPLG = num$(J)+right$([M]NUMPLG,2)
If J=GNBHOR | GNBHOR=0
 [M:TPSJ]SUIPLG = ""
 Grizo [TPSJ]SUIPLG
Else
 [M:TPSJ]SUIPLG = "29"
 Actzo [TPSJ]SUIPLG
Endif
If J=1
 [M:TPSJ]PREPLG = ""
 Grizo [TPSJ]PREPLG
Else
 [M:TPSJ]PREPLG = "30"
 Actzo [TPSJ]PREPLG
Endif
Affzo [TPSJ]NUMPLG,PREPLG,SUIPLG
Gosub REMP_TPSJ
Gosub COLORE_PLAGE
Affzo [TPSJ]15-45
Return

$MENU
Case BOUT
 When "1"
  DEFILE = 1
 When "2"
  DEFILE = 2
 When "4" : # Gûˋnûˋration auto
  Call MAJ([M]REFNUM,[M]PYRDAT(0),[M]CTRNUM,0,[M]NUMWEK) From TRTREM
  Gosub CHARGE
Endcase
Return

$SUI
Case DEFILE
 When 1 : # Par matricule
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 > [M]REFNUM;[M]CTRNUM
 When 2 : # Par site/service
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 > [M]FCY;[M]SRV;[M]REFNUM;[M]CTRNUM
 When 3 : # Par semaine
  Local Integer I ,K ,L, STAT
  Raz fstat
#MIPEA - 2017-11-27- US X3-63170- START
  Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-27- US X3-63170- END
  Call DAT([M]DAT(0)+7,K,L) From SUBPLN :# Recherche de la semaine suivante
  LESITE = [M]FCY
  #LIPET - 12-12-2016 - X3-12033 - START
  #Call PERIO(LESITE,[M]REFNUM) From SUBPEO
#    Filter [PEO] Where (FCY=LESITE | FCY="") & find(K,YEAWEK)<>0  & (NUMWEK(0)>=L | NUMWEK(1)>=L | NUMWEK(2)>=L | NUMWEK(3)>=L | NUMWEK(4)>=L | NUMWEK(5)>=L) Order By FCY Desc;PYRDAT Asc #;NUMWEK Asc
#    For [PEO]
#    For I=0 To dim([F:PEO]NUMWEK)-1
#    If [F:PEO]YEAWEK(I)=K & [F:PEO]NUMWEK(I)>=L
#     STAT = 1 : Break 2
#    Endif
#   Next
#  Next
  Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
  Filter [HRPEOD] Where (PERCOD=[F:HRCTR]PERCOD) & find(K,YEAWEK)<>0  & (NUMWEK(0)>=L | NUMWEK(1)>=L | NUMWEK(2)>=L | NUMWEK(3)>=L | NUMWEK(4)>=L | NUMWEK(5)>=L) Order By PERCOD;PYRDAT
& Asc #;NUMWEK#
# Asc
    For [HRPEOD]
    For I=0 To dim([F:HRPEOD]NUMWEK)-1
    If [F:HRPEOD]YEAWEK(I)=K & [F:HRPEOD]NUMWEK(I)>=L
     STAT = 1 : Break 2
    Endif
   Next
  Next
  #Filter [PEO]
  Filter [HRPEOD]
  If STAT=1
#   [M]NUMWEK = [F:PEO]NUMWEK(I)
#   [M]YEA    = [F:PEO]YEAWEK(I)
   [M]NUMWEK = [F:HRPEOD]NUMWEK(I)
   [M]YEA    = [F:HRPEOD]YEAWEK(I)
   #LIPET - 12-12-2016 - X3-12033 - END
  Else
   GMESSAGE = mess(11,100,1) : # Dûˋbut/Fin de fichier
   GERR = 2 : Return
  Endif
  Local Integer I,J
  Local Char    CHAMP(15)
  For I=1 To 9
    For J=1 To 7
      If evalue("dim([M:TPSJ]CCE"+num$(I)+num$(J)+")")>0    : CHAMP="[M:TPSJ]CCE"+num$(I)+num$(J)       : Effzo =CHAMP : Endif
    Next
  Next
  Affzo [M]YEA
Endcase
Goto SUIVPREC
Return

$PRE
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 < [M]REFNUM;[M]CTRNUM
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 < [M]FCY;[M]SRV;[M]REFNUM;[M]CTRNUM
 When 3
  Local Integer I, K ,L, STAT
  Raz fstat
#MIPEA - 2017-11-27- US X3-63170- START
  Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-27- US X3-63170- END
  Call DAT([M]DAT(0)-7,K,L) From SUBPLN :# Recherche de la semaine prûˋcûˋdente
  LESITE = [M]FCY
  #LIPET - 12-12-2016 - X3-12033 - START
  #Call PERIO(LESITE,[M]REFNUM) From SUBPEO
  Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
  #Filter [PEO] Where (FCY=LESITE | FCY="") & find(K,YEAWEK)<>0  & (NUMWEK(0)<=L | NUMWEK(1)<=L | NUMWEK(2)<=L | NUMWEK(3)<=L | NUMWEK(4)<=L | NUMWEK(5)<=L) Order By FCY Desc;PYRDAT Desc #;NUMWEK Desc
  Filter [HRPEOD] Where (PERCOD=[F:HRCTR]PERCOD) & find(K,YEAWEK)<>0  & (NUMWEK(0)<=L | NUMWEK(1)<=L | NUMWEK(2)<=L | NUMWEK(3)<=L | NUMWEK(4)<=L | NUMWEK(5)<=L) Order By PERCOD;PYRDAT
& Desc #;NUMWEK#
# Desc
  #For [PEO]
  For [HRPEOD]
  #For I=dim([F:PEO]NUMWEK)-1 To 0 Step -1
  For I=dim([F:HRPEOD]NUMWEK)-1 To 0 Step -1
    #If [F:PEO]YEAWEK(I)=K & [F:PEO]NUMWEK(I)<=L
    If [F:HRPEOD]YEAWEK(I)=K & [F:HRPEOD]NUMWEK(I)<=L
     STAT = 1 : Break 2
    Endif
   Next
  Next
  #Filter [PEO]
  Filter [HRPEOD]
  If STAT=1
#   [M]NUMWEK = [F:PEO]NUMWEK(I)
#   [M]YEA    = [F:PEO]YEAWEK(I)
   [M]NUMWEK = [F:HRPEOD]NUMWEK(I)
   [M]YEA    = [F:HRPEOD]YEAWEK(I)
   #LIPET - 12-12-2016 - X3-12033 - END
  Else
   GMESSAGE = mess(11,100,1) : # Dûˋbut/Fin de fichier
   GERR = 2 : Return
  Endif
  Local Integer I,J
  Local Char    CHAMP(15)
  For I=1 To 9
    For J=1 To 7
      If evalue("dim([M:TPSJ]CCE"+num$(I)+num$(J)+")")>0    : CHAMP="[M:TPSJ]CCE"+num$(I)+num$(J)       : Effzo =CHAMP : Endif
    Next
  Next
  Affzo [M]YEA
Endcase
Goto SUIVPREC
Return

$FIR
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 First
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 First
Endcase
Goto SUIVPREC

$LAS
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 Last
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 Last
Endcase
Goto SUIVPREC

$SUIVPREC
If fstat<=2
 If DEFILE<3
  [M]REFNUM = [F:ID]REFNUM
  [M]CTRNUM = [F:ECT]CTRNUM
  [M]NAM    = [F:ID]NAM-[F:ID]SRN
  If [F:ID]FLGMULCTR<>2
   Diszo CTRNUM
  Else
   Actzo CTRNUM
  Endif
  Affzo REFNUM, CTRNUM, NAM
  Call AM_CTRNUM([M]CTRNUM) From TPSJOU0
 Else
  Call AM_NUMWEK([M]NUMWEK) From TPSJOU0
  Affzo [M]NUMWEK
 Endif
Endif
Gosub AUTORIS From TPSSTD
#LIPET - 10-01-2017 - X3-18688 - START
 Call C_CTRNUM([M]CTRNUM) From TPSJOU0
#LIPET - 10-01-2017 - X3-18688 - END
Return


$INIPAR
If PARAM(2)="" | PARAM(2)="[0/0/0]"
 VALPAR = func DIVPAYE.INIPARUSR("DATPAY","","")
Else
 VALPAR = PARAM(2)
Endif
If PARAM(1)=""  or !instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
 Call PARAMUTIL("REFNUM",[M]REFNUM,GUSER,"") From SUBAUS
Else
 [M]REFNUM = PARAM(1)
Endif
If PARAM(1)<>"" or !instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
 If [M]REFNUM=""
  FIN = 1
 Else
  Read [ID]ID0 = [M]REFNUM
  If [F:ID]ENAFLG<>2 or [F:ID]FLGTPS<>2
   FIN = 1
  Endif
 Endif
 If FIN
  GERR = 2
  #LIPET - 12-12-2016 - X3-12033 - START
  #GMESSAGE = mess(113,709,1) : # Saisie des temps inactive
  GMESSAGE = mess(113,10709,1) : # Saisie des temps inactive
  #LIPET - 12-12-2016 - X3-12033 - END
  Return
 Endif
 Diszo REFNUM
 DEFILE = 3
Endif

If [M]REFNUM<>""
 Read [ID]ID0 = [M]REFNUM
 Affzo REFNUM
 Call AM_REFNUM([M]REFNUM) From TPSJOU0
 If PARAM(3)<>""
  [M]CTRNUM = PARAM(3)
  Call AM_CTRNUM([M]CTRNUM) From TPSJOU0
 Endif
#MIPEA - 2017-11-27- US X3-63170- START
 Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-27- US X3-63170- END
 Call DAT(VALPAR,I,J) From SUBPLN
 [M]YEA = I : [M]NUMWEK= J : Raz I,J
#LIPET - 12-12-2016 - X3-12033 - START
# If [F:ID]FLGMULCTR<>2 | [M]CTRNUM<>""
#  LESITE = [M]FCY
#  Call PERIO(LESITE,[M]REFNUM) From SUBPEO
#  Filter [PEO] Where (FCY=LESITE | FCY="") & find([M]YEA,YEAWEK)<>0  & find([M]NUMWEK,NUMWEK)<>0 Order By FCY Desc
#  For [PEO]
#   I = find([M]NUMWEK,[F:PEO]NUMWEK)
#   If [F:PEO]YEAWEK(I-1)=[M]YEA
#    OK = 1 : Break
#   Endif
#  Next
#  Filter [PEO]
#
#  If OK=1
#   If GPAYE
#    Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=[F:PEO]PYRDAT & CTRNUM=[M]CTRNUM
#    Read [VEP]VEP0 First
#    Filter [VEP]
#   Endif
#   Call AM_NUMWEK([M]NUMWEK) From TPSJOU0
#   Affzo YEA,NUMWEK
#  Else
#   LESITE = [M]FCY
#   Call PERIO(LESITE,[M]REFNUM) From SUBPEO
#   Read [PEO]PEO0(1) = LESITE
#   If fstat<=2
#    Filter [PEO] Where FCY=LESITE & PYRDAT>=gdat$(VALPAR) & STA=2
#   Else
#    Filter [PEO] Where FCY="" & PYRDAT>=gdat$(VALPAR) & STA=2
#   Endif
#   Read [PEO]PEO0 First
#   Filter [PEO]
#   If fstat<=2
#    If GPAYE
#     Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=[F:PEO]PYRDAT & CTRNUM=[M]CTRNUM
#     Read [VEP]VEP0 First
#     Filter [VEP]
#    Endif
#    [M]YEA    = [F:PEO]YEAWEK(0)
#    [M]NUMWEK = [F:PEO]NUMWEK(0)
#    Call AM_NUMWEK([M]NUMWEK) From TPSJOU0
#   Endif
#  Endif
# Endif
# Affzo YEA,NUMWEK
 If [F:ID]FLGMULCTR<>2 | [M]CTRNUM<>""
  LESITE = [M]FCY
  Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
  Filter [HRPEOD] Where (PERCOD=[F:HRCTR]PERCOD) & find([M]YEA,YEAWEK)<>0  & find([M]NUMWEK,NUMWEK)<>0 Order By PERCOD
  For [HRPEOD]
   I = find([M]NUMWEK,[F:HRPEOD]NUMWEK)
   If [F:HRPEOD]YEAWEK(I-1)=[M]YEA
    OK = 1 : Break
   Endif
  Next
  Filter [HRPEOD]

  If OK=1
   If GPAYE
    Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=[F:HRPEOD]PYRDAT & CTRNUM=[M]CTRNUM
    Read [VEP]VEP0 First
    Filter [VEP]
   Endif
   Call AM_NUMWEK([M]NUMWEK) From TPSJOU0
   Affzo YEA,NUMWEK
  Else
   LESITE = [M]FCY
   Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
   Read [HRPEOD]HRPEOD0(1) = PERCOD
   If fstat<=2
    Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT>=gdat$(VALPAR) & STA=2
   Else
    Filter [HRPEOD] Where PYRDAT>=gdat$(VALPAR) & STA=2
   Endif
   Read [HRPEOD]HRPEOD0 First
   Filter [HRPEOD]
   If fstat<=2
    If GPAYE
     Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=[F:HRPEOD]PYRDAT & CTRNUM=[M]CTRNUM
     Read [VEP]VEP0 First
     Filter [VEP]
    Endif
    [M]YEA    = [F:HRPEOD]YEAWEK(0)
    [M]NUMWEK = [F:HRPEOD]NUMWEK(0)
    Call AM_NUMWEK([M]NUMWEK) From TPSJOU0
   Endif
  Endif
 Endif
 Affzo YEA,NUMWEK
 #LIPET - 12-12-2016 - X3-12033 - END
Endif
Return

$APRES_MODIF

If COUZON="PREWEK" or COUZON="SUIWEK"
 Gosub SETBOUT : Return
Endif

If COUZON<>"REFNUM" & COUZON<>"CTRNUM" & COUZON<>"YEA" & COUZON<>"NUMWEK" & GREP=""
 Gosub VERROU
 If OK
  GREP = "M" : REP = "M"
  Gosub GRISE
 Else
  GMESSAGE = mess(10,100,1) : # Modif en cours...
  GERR = 1
 Endif
Endif

If left$(COUZON,len(COUZON)-2)="STRTIM" |  left$(COUZON,len(COUZON)-2)="ENDTIM"
 Gosub AM_PLAGE From TPSJOU2
 If mkstat : GERR=1 : Endif
 Return
Endif

# Si paramû´tre COPPLG=2 ET plage courante=plage1 ET l'ûˋvû´nement de la plage1 est de type plage horaire
# Alors Recopie de la 1û´re plage sur les autres plages
ZONCOP = left$(COUZON,len(COUZON)-1)
If ([M:TPSI]COP="1" | [M:TPSI]COP="2") & val(left$([M]NUMPLG,1))=1 & [M:TPSI]NBHOR>1 & dim([M:TPSJ]STRTIM11)>0 & COUZON <> "REFNUM" &
& (ZONCOP="NATCOD" | ZONCOP="DAYNGT" | ZONCOP="TYPDAY" | ZONCOP="QTY1" | ZONCOP="QTY2" | ZONCOP="FLD1"
&| ZONCOP="FLD2" | ZONCOP="CPY" | ZONCOP="BPCNUM" | ZONCOP="SOHNUM" | ZONCOP="SOHLIG"| ZONCOP="INVFLG"
&| ZONCOP="CMT" | ZONCOP="STAFLG" | ZONCOP="DSP" | ZONCOP="CCE1" | ZONCOP="CCE2" | ZONCOP="CCE3"
&| ZONCOP="CCE4" | ZONCOP="CCE5" | ZONCOP="CCE6" | ZONCOP="CCE7" | ZONCOP="CCE8" | ZONCOP="CCE9")
 K = val(right$(COUZON,len(COUZON)))
 #LIPET - 12-12-2016 - X3-12033 - START
 #Call LECTURE("TIM",evalue("[M:TPSJ]TIM"+num$(K)),"") From CONTOBJ
 Call LECTURE("HRTIM",evalue("[M:TPSJ]TIM"+num$(K)),GCURLEG) From CONTOBJ
 #LIPET - 12-12-2016 - X3-12033 - END
 If [F:TIM]PLGHOR=2
  If dim([M:TPSJ]STRTIM12)>0 & evalue("[M:TPSJ]STRTIM"+num$(K)+num$(2))<>""
   Case evalue("type([M:TPSJ]"+ZONCOP+"1)")
    When 1,2,4,5,6,7,9 : Assign "[M:TPSI]K"+ZONCOP+num$(2)+"("+num$(K-1)+")" With val(CZ)
    When Default       : Assign "[M:TPSI]K"+ZONCOP+num$(2)+"("+num$(K-1)+")" With CZ
   Endcase
  Endif
  If dim([M:TPSJ]STRTIM13)>0 & evalue("[M:TPSJ]STRTIM"+num$(K)+num$(3))<>""
   Case evalue("type([M:TPSJ]"+ZONCOP+"1)")
    When 1,2,4,5,6,7,9 : Assign "[M:TPSI]K"+ZONCOP+num$(3)+"("+num$(K-1)+")" With val(CZ)
    When Default       : Assign "[M:TPSI]K"+ZONCOP+num$(3)+"("+num$(K-1)+")" With CZ
   Endcase
  Endif
 Endif
Endif
Return

$GRISE
Diszo NUMWEK,REFNUM,YEA,CTRNUM
Return

$DEGRISE
If PARAM(1)<>"" or !instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
 Actzo  NUMWEK,YEA
 If [F:ID]FLGMULCTR=2
  Actzo CTRNUM
 Endif
Else
 Actzo NUMWEK,REFNUM,YEA
 If [F:ID]FLGMULCTR=2
  Actzo CTRNUM
 Endif
Endif
Return


$VERROU
Local Date MCTRDAT
For II=0 To 6
 If !instr(1,SYMBOLE,[M]PYRDAT(II))
  If dim([M]CTRDAT)>0 Then
    MCTRDAT=[M]CTRDAT(II)
  Else
  #LIPET - 12-12-2016 - X3-12033 - START
#    For [F:CTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
#      If [M:TPSJ]DAT(II)>=[F:CTR]CTRDAT & ([F:CTR]XITDAT=[0/0/0] | [M:TPSJ]DAT(II)<=[F:CTR]XITDAT) Then
#        MCTRDAT = [F:CTR]CTRDAT
#        Break
#      Endif
#    Next
    For [F:HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
      If [M:TPSJ]DAT(II)>=[F:HRCTR]CTRDAT & ([F:HRCTR]XITDAT=[0/0/0] | [M:TPSJ]DAT(II)<=[F:HRCTR]XITDAT) Then
        MCTRDAT = [F:HRCTR]CTRDAT
        Break
      Endif
    Next
  #LIPET - 12-12-2016 - X3-12033 - START
  Endif
  #90728
  #SYMBOLE = "TPS"+format$("D:"+GFMDAT,[M]PYRDAT(II))+"\"+[M]REFNUM+"\"+[M]CTRNUM+format$("D:"+GFMDAT,MCTRDAT)
  SYMBOLE = "TPS"+format$("D:"+GFMDAT,[M]PYRDAT(II))+"\"+[M]CTRNUM+format$("D:"+GFMDAT,MCTRDAT)
  Lock =SYMBOLE
  If fstat :   OK = 0
  Else     :   OK = 1
  Endif
 Endif
Next
Return

$DEVERROU
If SYMBOLE<>""
 Unlock =SYMBOLE
 SYMBOLE = ""
Endif
Return

$FIN
If !NBTRANS | ACTION="END" Then
  Gosub DEVERROU
  GFONCTION = SAVFONC
  Raz GFLAG
  Call AUTORIS From EXEFNC
  GCONSULT = SAVCONS
Endif
Return

$ENREGISTRE
# Recopie de l'ûˋcran courant dans l'ûˋcran TPSI
Gosub REMP_TPSI
# ContrûÇle des zones obligatoires
Gosub VERFZON
If GERR=1 : Return : Endif
# Initialisation des zones inivisibles de la transaction de saisie
Gosub INIZONINV
Call DEBTRANS From GLOCK
Gosub TR1
GREP = "" : REP = ""
Gosub DEGRISE
Gosub DEVERROU
Gosub CHARGE
Return

## Vûˋrifie que les zones paramûˋtrûˋes comme obligatoires dans la transaction ont ûˋtûˋ saisies.

$VERFZON
If NBCTL=0 : Return : Endif
GERR = 0
For I=1 To 7
 For J=1 To [M:TPSI]NBHOR
  If evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(I-1)+")")<>""
  #LIPET - 12-12-2016 - X3-12033 - START
   #Call LECTURE("TIM", evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(I-1)+")"),"") From CONTOBJ
   Call LECTURE("HRTIM", evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(I-1)+")"),GCURLEG) From CONTOBJ
  #LIPET - 12-12-2016 - X3-12033 - END
   For L=0 To NBCTL-1
    Case FLDCTL(L)
     When "STRTIM" : If [F:TIM]PLGHOR=2 & (evalue("[M:TPSI]KSTRTIM"+num$(J)+"("+num$(I-1)+")")=""
&                     | evalue("[M:TPSI]KENDTIM"+num$(J)+"("+num$(I-1)+")")="")
                      GERR = 1
                     Endif
     When "NATCOD" : If [F:TIM]NATACT=2 & evalue("[M:TPSI]KNATCOD"+num$(J)+"("+num$(I-1)+")")=""
                      GERR = 1
                     Endif
     When "NBRDAY" : If [F:TIM]DAYDAC=2 & evalue("[M:TPSI]KNBRDAY"+num$(J)+"("+num$(I-1)+")")=0 : GERR = 1 : Endif
     When "NBRHOU" : If [F:TIM]HOUDAC=2 & evalue("[M:TPSI]KNBRHOU"+num$(J)+"("+num$(I-1)+")")=0 : GERR = 1 : Endif
     When "DAYNGT" : If evalue("[M:TPSI]KDAYNGT"+num$(J)+"("+num$(I-1)+")")=0 : GERR = 1 : Endif
     When "TYPDAY" : If evalue("[M:TPSI]KTYPDAY"+num$(J)+"("+num$(I-1)+")")=0 : GERR = 1 : Endif
     When "QTY1"   : If evalue("[M:TPSI]KQTY1"+num$(J)+"("+num$(I-1)+")")=0   : GERR = 1 : Endif
     When "QTY2"   : If evalue("[M:TPSI]KQTY2"+num$(J)+"("+num$(I-1)+")")=0   : GERR = 1 : Endif
     When "FLD1"   : If evalue("[M:TPSI]KFLD1"+num$(J)+"("+num$(I-1)+")")=""  : GERR = 1 : Endif
     When "FLD2"   : If evalue("[M:TPSI]KFLD2"+num$(J)+"("+num$(I-1)+")")=""  : GERR = 1 : Endif
     When "CPY"    : If [F:TIM]COD=GTPSW & evalue("[M:TPSI]KCPY"+num$(J)+"("+num$(I-1)+")")=""
                      GERR = 1
                     Endif
     When "BPCNUM" : If [F:TIM]COD=GTPSW & evalue("[M:TPSI]KBPCNUM"+num$(J)+"("+num$(I-1)+")")=""
                      GERR = 1
                     Endif
     When "SOHNUM" : If [F:TIM]COD=GTPSW & evalue("[M:TPSI]KSOHNUM"+num$(J)+"("+num$(I-1)+")")=""
                      GERR = 1
                     Endif
     When "SOHLIG" : If [F:TIM]COD=GTPSW & evalue("[M:TPSI]KSOHLIG"+num$(J)+"("+num$(I-1)+")")=0
                      GERR = 1
                     Endif
     When "INVFLG" : If evalue("[M:TPSI]KBPCNUM"+num$(J)+"("+num$(I-1)+")")<>""
&                     & evalue("[M:TPSI]KINVFLG"+num$(J)+"("+num$(I-1)+")")=0
                      GERR = 1
                     Endif
     When "CMT"    : If evalue("[M:TPSI]KCMT"+num$(J)+"("+num$(I-1)+")")="" : GERR = 1 : Endif
     When "STAFLG" : If GVISA=2 & evalue("[M:TPSI]KSTAFLG"+num$(J)+"("+num$(I-1)+")")="" : GERR = 1 : Endif
     When "DSP"    : If find(2,[F:TIM]CCEDAC(0..GOPTCANA-1)) & evalue("[M:TPSI]KDSP"+num$(J)+"("+num$(I-1)+")")=""
                      GERR = 1
                     Endif
#92876_US2759
#     When "CCE1"   : If [F:TIM]CCEDAC(0)=2 & evalue("[M:TPSI]KCCE1"+num$(J)+"("+num$(I-1)+")")=""
#                      GERR = 1
#                     Endif
#     When "CCE2"   : If [F:TIM]CCEDAC(1)=2 & evalue("[M:TPSI]KCCE2"+num$(J)+"("+num$(I-1)+")")=""
#                      GERR = 1
#                     Endif
#     When "CCE3"   : If [F:TIM]CCEDAC(2)=2 & evalue("[M:TPSI]KCCE3"+num$(J)+"("+num$(I-1)+")")=""
#                      GERR = 1
#                     Endif
#     When "CCE4"   : If [F:TIM]CCEDAC(3)=2 & evalue("[M:TPSI]KCCE4"+num$(J)+"("+num$(I-1)+")")=""
#                      GERR = 1
#                     Endif
#     When "CCE5"   : If [F:TIM]CCEDAC(4)=2 & evalue("[M:TPSI]KCCE5"+num$(J)+"("+num$(I-1)+")")=""
#                      GERR = 1
#                     Endif
#     When "CCE6"   : If [F:TIM]CCEDAC(5)=2 & evalue("[M:TPSI]KCCE6"+num$(J)+"("+num$(I-1)+")")=""
#                      GERR = 1
#                     Endif
#     When "CCE7"   : If [F:TIM]CCEDAC(6)=2 & evalue("[M:TPSI]KCCE7"+num$(J)+"("+num$(I-1)+")")=""
#                      GERR = 1
#                     Endif
#     When "CCE8"   : If [F:TIM]CCEDAC(7)=2 & evalue("[M:TPSI]KCCE8"+num$(J)+"("+num$(I-1)+")")=""
#                      GERR = 1
#                     Endif
#     When "CCE9"   : If [F:TIM]CCEDAC(8)=2 & evalue("[M:TPSI]KCCE9"+num$(J)+"("+num$(I-1)+")")=""
#                      GERR = 1
#                     Endif
#end 92876_US2759
    Endcase
    If GERR=1 : Break 3 : Endif
   Next
  Endif
 Next
Next
If GERR=1
#LIPET - 12-12-2016 - X3-12033 - START
 # xx/xx/xx plage horaire y intitulûˋ de la zone : Zone obligatoire
 #GMESSAGE = num$([M]DAT(I-1))-mess(122,709,1)-num$(J)-FLDCTL(L)-":"-mess(10,123,1)
 GMESSAGE = num$([M]DAT(I-1))-mess(122,10709,1)-num$(J)-FLDCTL(L)-":"-mess(10,123,1)
#LIPET - 12-12-2016 - X3-12033 - END
Endif
Return



## Initialise les zones invisibles de l'ûˋcran
## NBRDAY et NBRHOU sont toujours initialisûˋs si les plages horaires ont ûˋtûˋ saisies

$INIZONINV
Local Integer JNUIT,TDAY
Local Char    TIM(GLONTPS):#, ZONCCE(GLONCCE) #92876_US2759
Local Decimal JOUR, HEURE
Local Date    DATEJ
# Mise û  jour des champs dans TPSI
For I=0 To 6
 DATEJ = evalue("[M]DAT("+num$(I)+")")
 For J = 1 To [M:TPSI]NBHOR
  TIM = evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(I)+")")
  If TIM<>""
   Raz JNUIT, TDAY, JOUR, HEURE
   Raz [F:NAT]
   Call VALORIS(DATEJ,DATEJ,[M]REFNUM,TIM,JOUR,HEURE,[M]FCY,[M]CTRNUM) From SUBPLN
   If dim([M]NATCOD1)>0
    # Si la nature d'activitûˋ est saisissable
    #ADNGO - 2016-01-26 - X3-12033 - START
    #Read [NAT]NAT0=evalue("[M:TPSI]KNATCOD"+num$(J)+"("+num$(I)+")")
    Read [NAT]NAT0=GCURLEG;evalue("[M:TPSI]KNATCOD"+num$(J)+"("+num$(I)+")")
    #ADNGO - 2016-01-26 - X3-12033 - END
    JNUIT = [F:NAT]DAYNGT
    TDAY  = [F:NAT]TYPDAY
   Endif
   If JNUIT=0 : JNUIT = 1 : Endif
   If TDAY=0
    Case dayn(DATEJ)
     When 6,7     : TDAY = 2
     When Default : TDAY = 1
    Endcase
   Endif
   For L=0 To NBINV-1
    Case FLDINV(L)
     When "NBRDAY" : Assign "[M:TPSI]KNBRDAY"+num$(J)+"("+num$(I)+")" With JOUR
     When "NBRHOU" : Assign "[M:TPSI]KNBRHOU"+num$(J)+"("+num$(I)+")" With HEURE
     When "DAYNGT" : Assign "[M:TPSI]KDAYNGT"+num$(J)+"("+num$(I)+")" With JNUIT
     When "TYPDAY" : #41475 If [M:TPSI]INI(I)<>2 : # Pas de planning salariûˋ chargûˋ dans TPSI
                     Assign "[M:TPSI]KTYPDAY"+num$(J)+"("+num$(I)+")" With TDAY
     When "STAFLG" : If !instr(1,GUSRAUZ(1),"2") | GVISA<>2 : # Visa
                      Assign "[M:TPSI]KSTAFLG"+num$(J)+"("+num$(I)+")" With ""
                     Else
                      Assign "[M:TPSI]KSTAFLG"+num$(J)+"("+num$(I)+")" With GUSER
                     Endif
#92876_US2759
#     When "CCE1"   : #41475 If [M:TPSI]INI(I)<>2 : # Pas de planning salariûˋ chargûˋ dans TPSI
#                     If evalue("[M:TPSI]KCCE1"+num$(J)+"("+num$(I)+")")=""
#                      Call INICCE(TIM,1,ZONCCE) From TPSSTD
#                      Assign "[M:TPSI]KCCE1"+num$(J)+"("+num$(I)+")" With ZONCCE
#                     Endif
#     When "CCE2"   : #41475 If [M:TPSI]INI(I)<>2
#                     If evalue("[M:TPSI]KCCE2"+num$(J)+"("+num$(I)+")")=""
#                      Call INICCE(TIM,2,ZONCCE) From TPSSTD
#                      Assign "[M:TPSI]KCCE2"+num$(J)+"("+num$(I)+")" With ZONCCE
#                     Endif
#     When "CCE3"   : #41475 If [M:TPSI]INI(I)<>2
#                     If evalue("[M:TPSI]KCCE3"+num$(J)+"("+num$(I)+")")=""
#                      Call INICCE(TIM,3,ZONCCE) From TPSSTD
#                      Assign "[M:TPSI]KCCE3"+num$(J)+"("+num$(I)+")" With ZONCCE
#                     Endif
#     When "CCE4"   : #41475 If [M:TPSI]INI(I)<>2
#                     If evalue("[M:TPSI]KCCE4"+num$(J)+"("+num$(I)+")")=""
#                      Call INICCE(TIM,4,ZONCCE) From TPSSTD
#                      Assign "[M:TPSI]KCCE4"+num$(J)+"("+num$(I)+")" With ZONCCE
#                     Endif
#     When "CCE5"   : #41475 If [M:TPSI]INI(I)<>2
#                     If evalue("[M:TPSI]KCCE5"+num$(J)+"("+num$(I)+")")=""
#                      Call INICCE(TIM,5,ZONCCE) From TPSSTD
#                      Assign "[M:TPSI]KCCE5"+num$(J)+"("+num$(I)+")" With ZONCCE
#                     Endif
#     When "CCE6"   : #41475 If [M:TPSI]INI(I)<>2
#                     If evalue("[M:TPSI]KCCE6"+num$(J)+"("+num$(I)+")")=""
#                      Call INICCE(TIM,6,ZONCCE) From TPSSTD
#                      Assign "[M:TPSI]KCCE6"+num$(J)+"("+num$(I)+")" With ZONCCE
#                     Endif
#     When "CCE7"   : #41475 If [M:TPSI]INI(I)<>2
#                     If evalue("[M:TPSI]KCCE7"+num$(J)+"("+num$(I)+")")=""
#                      Call INICCE(TIM,7,ZONCCE) From TPSSTD
#                      Assign "[M:TPSI]KCCE7"+num$(J)+"("+num$(I)+")" With ZONCCE
#                     Endif
#     When "CCE8"   : #41475 If [M:TPSI]INI(I)<>2
#                     If evalue("[M:TPSI]KCCE8"+num$(J)+"("+num$(I)+")")=""
#                      Call INICCE(TIM,8,ZONCCE) From TPSSTD
#                      Assign "[M:TPSI]KCCE8"+num$(J)+"("+num$(I)+")" With ZONCCE
#                     Endif
#     When "CCE9"   : #41475 If [M:TPSI]INI(I)<>2
#                     If evalue("[M:TPSI]KCCE9"+num$(J)+"("+num$(I)+")")=""
#                      Call INICCE(TIM,9,ZONCCE) From TPSSTD
#                      Assign "[M:TPSI]KCCE9"+num$(J)+"("+num$(I)+")" With ZONCCE
#                     Endif
#end 92876_US2759
     When "QTY1"   : Assign "[M:TPSI]KQTY1"+num$(J)+"("+num$(I)+")" With [F:NAT]QTY1
     When "QTY2"   : Assign "[M:TPSI]KQTY2"+num$(J)+"("+num$(I)+")" With [F:NAT]QTY2
     When "FLD1"   : Assign "[M:TPSI]KFLD1"+num$(J)+"("+num$(I)+")" With [F:NAT]FLD1
     When "FLD2"   : Assign "[M:TPSI]KFLD2"+num$(J)+"("+num$(I)+")" With [F:NAT]FLD2
    Endcase
   Next
  Endif
 Next
Next
Return

$TR1
GOK = 1
Local Integer MAXWRK : MAXWRK = 10
Local Integer LIGWRK : LIGWRK = 20
Local Integer NBWRK , IWRK , JWRK , WRKMOD
Local Char    WRK(80)
Local Char    WRKCOD(GLONTPS)(1..MAXWRK)
Local Integer WRKLIG(1..MAXWRK)
Local Char    WRKTXT(120)(1..MAXWRK,1..LIGWRK)
Local Decimal HEURE(1..42), JOUR(1..42)
Local Integer JNUIT(1..42)
Local Date CTRDAT_VEP : # FQ91472 US2857/58 - SEGAY 02/09/14
Raz CTRDAT_VEP
NBWRK = 0
Trbegin [TIP]
 # Parcours des 6 jours de la semaine
 For I=0 To 6
 #LIPET - 12-12-2016 - X3-12033 - START
#  #On doit prendre la date de rûˋtroactivitûˋ au lieu de la date du contrat, pour dûˋterminer la prûˋsence du salariûˋ
#  Filter [CTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M:TPSJ]DAT(I) | (FLGRET=2 & RETDATEFF<=[M:TPSJ]DAT(I)))
#  # Fin MABON
#  Read[F:CTR]CTR1 Last
#  Filter [F:CTR]
#  If !fstat
#   #On cherche si on a une fiche de rûˋtroactivitûˋ relative aux champs ETRFCY et ETRSRV
#   [M:TPSJ]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M:TPSJ]DAT(I),"ETRFCY","CTR")
#   [M:TPSJ]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M:TPSJ]DAT(I),"ETRSRV","CTR")
#  Endif
  #On doit prendre la date de rûˋtroactivitûˋ au lieu de la date du contrat, pour dûˋterminer la prûˋsence du salariûˋ
  Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M:TPSJ]DAT(I) | (FLGRET=2 & RETDATEFF<=[M:TPSJ]DAT(I)))
  # Fin MABON
  Read[F:HRCTR]CTR1 Last
  Filter [F:HRCTR]
  If !fstat
   #On cherche si on a une fiche de rûˋtroactivitûˋ relative aux champs ETRFCY et ETRSRV
   [M:TPSJ]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M:TPSJ]DAT(I),"ETRFCY","HRCTR")
   [M:TPSJ]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M:TPSJ]DAT(I),"ETRSRV","HRCTR")
  Endif
 #LIPET - 12-12-2016 - X3-12033 - END
  # Parcours sur les plages horaires
  For J=1 To [M:TPSI]NBHOR
   NOL = evalue("[M:TPSI]KLIG"+num$(J)+"("+num$(I)+")")
   # Plage supprimûˋe
   If NOL<>0 & evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(I)+")")=""
    Read [TIP]TIP0 = NOL
    #LIPET - 12-12-2016 - X3-12033 - START
    #WRK = mess(74,709,1)     : # Suppression
    WRK = mess(74,10709,1)     : # Suppression
    #LIPET - 12-12-2016 - X3-12033 - END
    Gosub WORKFLOW From TPSSTD
    #LIPET - 12-12-2016 - X3-12033 - START
    # Maj cp pris avant suppression
    #Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
    Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
    #LIPET - 12-12-2016 - X3-12033 - END
    If [F:TIM]CATTIM=3
     Call SUPP_CPPRIS From TPSSTD1
     If GOK<1 : Break 2 : Endif
    Endif
    Delete [TIP] Where LIG=NOL
    If fstat=1
     GOK = -1 : GLOCK = "$TIMEMP"-num$(NOL) : Break 2
    Endif
    Delete [TIA] Where LIG=NOL
    If fstat=1
     GOK = -1 : GLOCK = "$TIMANA"-num$(NOL) : Break 2
    Endif
    #LIPET - 12-12-2016 - X3-12033 - START
    #Read[F:CTR]CTR0=[M]REFNUM;[M]CTRNUM;[F:TIP]CTRDAT
    Read[F:HRCTR]CTR0=[M]REFNUM;[M]CTRNUM;[F:TIP]CTRDAT
    #LIPET - 12-12-2016 - X3-12033 - END
    If !fstat & GOK & CTRDAT_VEP <> [F:TIP]CTRDAT : Gosub FLGVEP From TPSSTD : Endif : # FQ91472 US2857/58 - SEGAY 02/09/14
   # Plage crûˋee
   Elsif NOL=0 & evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(I)+")")<>""
&           & evalue("[M:TPSI]KFLGVISU"+num$(J)+"("+num$(I)+")")=0
    Gosub CRE_TIMEMP
    If GOK<1 : Break 2 : Endif
    Write [TIP]
    If fstat
     GOK = 0 : Call FSTA("TIP") From GLOCK : Break 2
    Endif
    #LIPET - 12-12-2016 - X3-12033 - START
    #WRK = mess(75,709,1)     : # Ajout
    WRK = mess(75,10709,1)     : # Ajout
    #LIPET - 12-12-2016 - X3-12033 - END
    Gosub WORKFLOW From TPSSTD
    If  GOK & CTRDAT_VEP <> [F:TIP]CTRDAT : Gosub FLGVEP From TPSSTD : Endif : # FQ91472 US2857/58 - SEGAY 02/09/14
   # Plage modifiûˋe
   Elsif NOL<>0 & evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(I)+")")<>""
&               & evalue("[M:TPSI]KFLGVISU"+num$(J)+"("+num$(I)+")")=0
    Read [TIP]TIP0 = NOL
    If !fstat
     ## Envoi d'un workflow
     WRKMOD = 0
     If  [F:TIP]STRDAT<>evalue("[M:TPSJ]DAT("+num$(I)+")")
&     or [F:TIP]ENDDAT<>evalue("[M:TPSJ]DAT("+num$(I)+")")
&     or [F:TIP]NBRDAY<>evalue("[M:TPSI]KNBRDAY"+num$(J)+"("+num$(I)+")")
&     or [F:TIP]CMT<>evalue("[M:TPSI]KCMT"+num$(J)+"("+num$(I)+")")
&     or (GVISA=2 & [F:TIP]STAFLG<>evalue("[M:TPSI]KSTAFLG"+num$(J)+"("+num$(I)+")"))
      WRKMOD = 1
      #LIPET - 12-12-2016 - X3-12033 - START
      #WRK = mess(76,709,1)   : # Modif (avant)
      WRK = mess(76,10709,1)   : # Modif (avant)
      #LIPET - 12-12-2016 - X3-12033 - END
      Gosub WORKFLOW From TPSSTD
     Endif
     #LIPET - 12-12-2016 - X3-12033 - START
     ## Mise û  jour des CP
     #Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
     Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
     #LIPET - 12-12-2016 - X3-12033 - END
     If [F:TIM]CATTIM=3
      Call SUPP_CPPRIS From TPSSTD1
      If GOK<1 : Break 2 : Endif
     Endif
     ## Suppression des lignes dans TIMEMP et TIMANA
     Delete [TIP] Where LIG=NOL
     If fstat=1
      GOK = -1 : GLOCK = "$TIMEMP"-num$(NOL) : Break 2
     Endif
     Delete [TIA] Where LIG=NOL
     If fstat=1
      GOK = -1 : GLOCK = "$TIMANA"-num$(NOL) : Break 2
     Endif
    Endif
    ## Crûˋation des lignes dans TIMEMP et TIMANA
    Gosub CRE_TIMEMP
    If GOK<1 : Break 2 : Endif
    Write [TIP]
    If fstat
     GOK = 0 : Call FSTA("TIP") From GLOCK : Break 2
    Endif
    If WRKMOD
     #LIPET - 12-12-2016 - X3-12033 - START
     #WRK = mess(77,709,1)   : # Modif (aprû´s)
     WRK = mess(77,10709,1)   : # Modif (aprû´s)
     #LIPET - 12-12-2016 - X3-12033 - END
     Gosub WORKFLOW From TPSSTD
    Endif
    If  GOK & CTRDAT_VEP <> [F:TIP]CTRDAT : Gosub FLGVEP From TPSSTD : Endif : # FQ91472 US2857/58 - SEGAY 02/09/14
   Endif
  Next
 Next
 If   GOK<1 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Gosub MEL From TPSSTD
#Gosub FLGVEP From TPSSTD
Return


$CRE_TIMEMP

Raz [F:TIP]
[F:TIP]LIG     = uniqid([TIP])
[F:TIP]REFNUM  = [M:TPSJ]REFNUM
[F:TIP]CTRNUM  = [M:TPSJ]CTRNUM
#Si [M]CTRDAT n'est pas affichûˋ ou pas renseignûˋ, il faut le calculer
[F:TIP]CTRDAT  = evalue("[M:TPSI]KCTRDAT"+num$(J)+"("+num$(I)+")")
If [F:TIP]CTRDAT=[0/0/0] Then
#LIPET - 12-12-2016 - X3-12033 - START
#  Filter [CTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
#  For [F:CTR]
#    If [M:TPSJ]DAT(I)>=[F:CTR]CTRDAT & ([F:CTR]XITDAT=[0/0/0] | [M:TPSJ]DAT(I)<=[F:CTR]XITDAT) Then
#      [F:TIP]CTRDAT = [F:CTR]CTRDAT
#      Break
#    Endif
#  Next
#  Filter [F:CTR]
  Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
  For [F:HRCTR]
    If [M:TPSJ]DAT(I)>=[F:HRCTR]CTRDAT & ([F:HRCTR]XITDAT=[0/0/0] | [M:TPSJ]DAT(I)<=[F:HRCTR]XITDAT) Then
      [F:TIP]CTRDAT = [F:HRCTR]CTRDAT
      Break
    Endif
  Next
  Filter [F:HRCTR]
#LIPET - 12-12-2016 - X3-12033 - END
Endif

[F:TIP]STRDAT  = [M:TPSJ]DAT(I)
[F:TIP]ENDDAT  = [M:TPSJ]DAT(I)
[F:TIP]DATPYR  = [M:TPSJ]PYRDAT(I)
[F:TIP]FCY     = [M:TPSJ]FCY
[F:TIP]SRV     = [M:TPSJ]SRV
[F:TIP]TIM     = evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(I)+")")
[F:TIP]STRTIM  = evalue("[M:TPSI]KSTRTIM"+num$(J)+"("+num$(I)+")")
[F:TIP]ENDTIM  = evalue("[M:TPSI]KENDTIM"+num$(J)+"("+num$(I)+")")
[F:TIP]BRKTIM  = evalue("[M:TPSI]KBRKTIM"+num$(J)+"("+num$(I)+")")
[F:TIP]TYPPGN  = evalue("[M:TPSI]KTYPPGN"+num$(J)+"("+num$(I)+")")
Case evalue("[M:TPSI]KLEADAY"+num$(J)+"("+num$(I)+")")
 When 1 : [F:TIP]STRDAY = 2 : [F:TIP]ENDDAY = 1 : # Matin
 When 2 : [F:TIP]STRDAY = 1 : [F:TIP]ENDDAY = 2 : # Apres-midi
 When 3 : [F:TIP]STRDAY = 1 : [F:TIP]ENDDAY = 1 : # Journûˋe
Endcase
[F:TIP]NATCOD  = evalue("[M:TPSI]KNATCOD"+num$(J)+"("+num$(I)+")")
[F:TIP]NBRDAY  = evalue("[M:TPSI]KNBRDAY"+num$(J)+"("+num$(I)+")")
[F:TIP]NBRHOU  = evalue("[M:TPSI]KNBRHOU"+num$(J)+"("+num$(I)+")")
[F:TIP]DAYNGT  = evalue("[M:TPSI]KDAYNGT"+num$(J)+"("+num$(I)+")")
[F:TIP]TYPDAY  = evalue("[M:TPSI]KTYPDAY"+num$(J)+"("+num$(I)+")")
[F:TIP]QTY1    = evalue("[M:TPSI]KQTY1"+num$(J)+"("+num$(I)+")")
[F:TIP]QTY2    = evalue("[M:TPSI]KQTY2"+num$(J)+"("+num$(I)+")")
[F:TIP]FLD1    = evalue("[M:TPSI]KFLD1"+num$(J)+"("+num$(I)+")")
[F:TIP]FLD2    = evalue("[M:TPSI]KFLD2"+num$(J)+"("+num$(I)+")")
[F:TIP]CPY     = evalue("[M:TPSI]KCPY"+num$(J)+"("+num$(I)+")")
[F:TIP]BPCNUM  = evalue("[M:TPSI]KBPCNUM"+num$(J)+"("+num$(I)+")")
[F:TIP]SOHNUM  = evalue("[M:TPSI]KSOHNUM"+num$(J)+"("+num$(I)+")")
[F:TIP]SOHLIG  = evalue("[M:TPSI]KSOHLIG"+num$(J)+"("+num$(I)+")")
[F:TIP]INVFLG  = evalue("[M:TPSI]KINVFLG"+num$(J)+"("+num$(I)+")")
[F:TIP]CMT     = evalue("[M:TPSI]KCMT"+num$(J)+"("+num$(I)+")")
[F:TIP]STAFLG  = evalue("[M:TPSI]KSTAFLG"+num$(J)+"("+num$(I)+")")
[F:TIP]DSP     = evalue("[M:TPSI]KDSP"+num$(J)+"("+num$(I)+")")

If dim([F:TIP]CREDAT)>0 : [F:TIP]CREDAT = date$ : Endif
If dim([F:TIP]CREUSR)>0 : [F:TIP]CREUSR = GUSER : Endif
If dim([F:TIP]CRETIM)>0 : [F:TIP]CRETIM = time  : Endif
#LIPET - 12-12-2016 - X3-12033 - START
#Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
#LIPET - 12-12-2016 - X3-12033 - END
If [F:TIM]CATTIM=3
 Call ADD_CPPRIS([F:TIP]NBRDAY) From TPSSTD1
 If GOK<1 : Return : Endif
Endif

Gosub ANA

Return


$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$ANA
If [F:TIP]DSP="$"
 [F:TIP]DSP = ""
 Raz [F:TIP]CCE
 [F:TIP]ANAFLG = 1
 NOL = I+7*(J-1)
 For K=[M:TPSI]PTV(NOL) To [M:TPSI]PTF(NOL)
  Raz [F:TIA]
  [F:TIA]LIG    = [F:TIP]LIG
  [F:TIA]LIGANA = K+1-[M:TPSI]PTV(NOL)
  #92876_US2757
  For L=1 To [M:TPSJ]NBRDIE
   If L>GOPTCANA : Break : Endif
   # Par contre on cherche le bon DIE pour sauver le bon CCE dans le bon champ
   M=find([M:TPSJ]WDIE(L-1),[F:TIA]DIE(0..dim([F:TIA]DIE)-1))
   If !M
    M=1
    While [F:TIA]DIE(M-1)<>"" & M<dim([F:TIA]DIE)
     M+=1
    Wend
    If [F:TIA]DIE(M-1)="": [F:TIA]DIE(M-1)=[M:TPSJ]WDIE(L-1) : Endif
   Endif
   If M
    [F:TIA]CCE(M-1) = evalue("[M:VT2]TBCCE"+num$(L)+"("+num$(K)+")")
   Endif
  Next L
  # end 92876_US2757
  [F:TIA]NBRHOU+= [M:VT2]TBAMT(K)
  Write [TIA]
  If fstat
   GOK = 0 : Call FSTA("TIA") From GLOCK : Break
  Endif
 Next
Else
 [F:TIP]ANAFLG = 0
 # FQ92876 - 25/09/14 - Ajout sauvegarde depuis les nouveaux champs [M:TPSI]KDIExx
 For L=1 To GOPTCANA
  Case L
   When 1 : [F:TIP]CCE(L-1) = evalue("[M:TPSI]KCCE1"+num$(J)+"("+num$(I)+")") : [F:TIP]DIE(L-1) = evalue("[M:TPSI]KDIE1"+num$(J)+"("+num$(I)+")")
   When 2 : [F:TIP]CCE(L-1) = evalue("[M:TPSI]KCCE2"+num$(J)+"("+num$(I)+")") : [F:TIP]DIE(L-1) = evalue("[M:TPSI]KDIE2"+num$(J)+"("+num$(I)+")")
   When 3 : [F:TIP]CCE(L-1) = evalue("[M:TPSI]KCCE3"+num$(J)+"("+num$(I)+")") : [F:TIP]DIE(L-1) = evalue("[M:TPSI]KDIE3"+num$(J)+"("+num$(I)+")")
   When 4 : [F:TIP]CCE(L-1) = evalue("[M:TPSI]KCCE4"+num$(J)+"("+num$(I)+")") : [F:TIP]DIE(L-1) = evalue("[M:TPSI]KDIE4"+num$(J)+"("+num$(I)+")")
   When 5 : [F:TIP]CCE(L-1) = evalue("[M:TPSI]KCCE5"+num$(J)+"("+num$(I)+")") : [F:TIP]DIE(L-1) = evalue("[M:TPSI]KDIE5"+num$(J)+"("+num$(I)+")")
   When 6 : [F:TIP]CCE(L-1) = evalue("[M:TPSI]KCCE6"+num$(J)+"("+num$(I)+")") : [F:TIP]DIE(L-1) = evalue("[M:TPSI]KDIE6"+num$(J)+"("+num$(I)+")")
   When 7 : [F:TIP]CCE(L-1) = evalue("[M:TPSI]KCCE7"+num$(J)+"("+num$(I)+")") : [F:TIP]DIE(L-1) = evalue("[M:TPSI]KDIE7"+num$(J)+"("+num$(I)+")")
   When 8 : [F:TIP]CCE(L-1) = evalue("[M:TPSI]KCCE8"+num$(J)+"("+num$(I)+")") : [F:TIP]DIE(L-1) = evalue("[M:TPSI]KDIE8"+num$(J)+"("+num$(I)+")")
   When 9 : [F:TIP]CCE(L-1) = evalue("[M:TPSI]KCCE9"+num$(J)+"("+num$(I)+")") : [F:TIP]DIE(L-1) = evalue("[M:TPSI]KDIE9"+num$(J)+"("+num$(I)+")")
  Endcase
 Next
Endif
Return

$ABANDON
Gosub INIT_NUMPLG
Gosub CHARGE
GREP = "" : REP = ""
Gosub DEGRISE
Gosub DEVERROU
Return

