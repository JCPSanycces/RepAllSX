#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","DOSMAJTXT","",2,"") From GTRAITE
End

#######################################################################
$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return

$INIT
Global Char GDOSX3(GLONADS)
Call PARAM("","SUPDOS",GDOSX3) From ADOVAL
If nomap=GDOSX3 or nomap=adxmother
 GMESSAGE = mess(112,125,1) : # Opération impossible sur ce dossier
 GERR     = 2
 FIN      = 1
Else
 TIT = mess(113,125,1)-nomap-adxmother : # Synchonisation des textes entre les dossiers
Endif
Return

$EXEC
Call MAJTXT(nomap,adxmother,GLANGUE)
Return

########################################################################
## DOSMAJTXT Mise à jour des textes en conformité avec le dossier mère
########################################################################
Subprog MAJTXT(DOSSIER,DOSMERE,LANGUE)
Value Char DOSSIER
Value Char DOSMERE
Value Char LANGUE

If DOSSIER=GDOSX3 or DOSSIER=DOSMERE
 End
Endif

Local Integer MAXFIL , MAXZON , MAXTEX

MAXFIL = 200
MAXZON = 50 : #121622 40->50 #110981 20->40
MAXTEX = 10000

Local Char    TABTEX(GLONATB)(1..MAXFIL)
Local Char    ZONTEX(GLONAVA)(1..MAXZON,1..MAXFIL)
Local Char    EXPRFILT(250)(1..10)
Local Integer DIMZONTEX(1..MAXZON,1..MAXFIL)
Local Integer NBZONTEX(1..MAXFIL)
Local Integer NBTABTEX , MODIFNUM , NBTEX
Local Integer I , J , K , L , M , N , P , Q , T
Local Integer ANCTEX(1..MAXTEX)
Local Integer NOUTEX(1..MAXTEX)

Local File =DOSSIER+".ATABZON" [ATZ]
Local File =DOSSIER+".ATEXTE"  [ATX]
Local File =DOSMERE+".ATEXTE"  [ATM]

# Y-a-t-il des textes spécifiques ?
#115210/6
#Filter [ATX]
#Read [ATX]DERNUM Last
#Filter [ATX]
#If [F:ATX]NUMERO<GMAXTXTSTD : End : Endif
Filter [ATX] Where NUMERO>=GMAXTXTSTD & NUMERO<GNEWTXTSTD
Read [ATX]DERNUM Last
Filter [ATX]
If fstat : End : Endif

#115210/6
Filter [ATM] Where NUMERO>=GMAXTXTSTD & NUMERO<GNEWTXTSTD
Read [ATM]DERNUM Last
Filter [ATM]
P = max([F:ATX]NUMERO,[F:ATM]NUMERO)

# Mise en conformité avec le dossier mère

If GINFO
 Call AFF_VLC(mess(44,125,1),mess(108,125,1)) From GESECRAN
Endif
Call ECR_TRACE(mess(108,125,1),0) From GESECRAN

# Lecture des zones de type ATX

For [ATZ]CODTYP(2) Where CODTYP="ATX"
 If filinfo(filpath("FIL",[F:ATZ]CODFIC,"fde",DOSSIER),0)>0
  NBTABTEX += 1
  TABTEX(NBTABTEX) = [F:ATZ]CODFIC
  For [ATZ]CODTYP
   NBZONTEX(NBTABTEX) += 1
   ZONTEX(NBZONTEX(NBTABTEX),NBTABTEX) = [F:ATZ]CODZONE
  Next ATZ
 Endif
Next ATZ

# Boucle sur les tables

For I=1 To NBTABTEX
 Gosub TRT_TABLE
Next I
End

$TRT_TABLE
Onerrgo ERR_TRT_TABLE
Local File =DOSSIER+"."+TABTEX(I) [XXX]
Raz EXPRFILT
L = 1
For J=1 To NBZONTEX(I)
 DIMZONTEX(J,I) = evalue("dim([F:XXX]"+ZONTEX(J,I)+")")
 For K=0 To DIMZONTEX(J,I)-1
  If len(EXPRFILT(L))>200 : L += 1 : Endif
  If EXPRFILT(1)<>"" : EXPRFILT(L) -= "|" : Endif
  #115210/6
  #EXPRFILT(L) -= ZONTEX(J,I)+"("+num$(K)+")"+">="+num$(GMAXTXTSTD)
  EXPRFILT(L) -= "("+ZONTEX(J,I)+"("+num$(K)+")"+">="+num$(GMAXTXTSTD)-"&"-ZONTEX(J,I)+"("+num$(K)+")"+"<"+num$(GNEWTXTSTD)+")"
 Next K
Next J
Filter [XXX] Where evalue(EXPRFILT(1..L))
Trbegin [XXX],[ATX],[ATM]
 For [XXX] With Nohint
  MODIFNUM = 0
  For J=1 To NBZONTEX(I)
   For K=0 To DIMZONTEX(J,I)-1
    Gosub TRT_CHAMP
   Next K
  Next J
  If MODIFNUM
   Rewrite [XXX]
   If fstat : Call ERREUR(TABTEX(I),2) From DOSDIC : Endif
  Endif
 Next XXX
Commit
Close Local File [XXX]
Onerrgo
Return

$ERR_TRT_TABLE
Call ECR_TRACE(DOSSIER+"."+TABTEX(I)-mess(6,123,1)-num$(errn)-mess(61,100,1)-num$(errl)-"("+errp+")\"+errmes$(errn)-errm,1) From GESECRAN
Resume

$TRT_CHAMP
L = evalue("[F:XXX]"+ZONTEX(J,I)+"("+num$(K)+")")
#115210/6
If L>GMAXTXTSTD & L<GNEWTXTSTD
 N = find(L,ANCTEX(1..NBTEX))
 If N=0 : # Numéro pas encore traité
  Read [ATX]NUMERO = LANGUE;L
  If fstat
   Read [ATX]DERNUM(1) = L : # Texte créé en étant connecté dans une autre langue
  Endif
  If fstat : Return : Endif : # Texte fantôme...
  T = 0
  For [ATM]TEXTE Where LAN=[F:ATX]LAN & TEXTE=[F:ATX]TEXTE & NUMERO=L
   T = 1 : Break
  Next ATM
  If T : Return : Endif : # Le texte existe dans le dossier avec le bon numéro
  Read [ATM]TEXTE = [F:ATX]LAN;[F:ATX]TEXTE
  If !fstat : # Le texte existe dans le dossier mère
   MODIFNUM = 1
   Assign "[F:XXX]"+ZONTEX(J,I)+"("+num$(K)+")" With [F:ATM]NUMERO
   NBTEX += 1
   ANCTEX(NBTEX) = L
   NOUTEX(NBTEX) = [F:ATM]NUMERO
   For [ATX]DERNUM Where NUMERO=L With Nohint
    Delete [ATX] Curr : # On supprime l'ancien pour éviter les doublons
   Next ATX
  Else
   Read [ATM]NUMERO = [F:ATX]LAN;L
   If fstat : # Numéro de texte inexistant dans le dossier mère, on le crée
    For [ATM]DERNUM Where NUMERO=L With Nohint
     Delete [ATM] Curr
    Next ATM
    For [ATX]DERNUM Where NUMERO=L With Nohint
     [F:ATM] = [F:ATX]
     Write [ATM]
     If fstat : Call ERREUR(DOSMERE+".ATEXTE"-num$(L),1) From DOSDIC : Endif
    Next ATX
    NBTEX += 1
    ANCTEX(NBTEX) = L
    NOUTEX(NBTEX) = L
   Elsif [F:ATM]TEXTE<>[F:ATX]TEXTE : # Numéro occupé par un autre texte
    P += 1
    # Issue 82117 - 2012-06-04 by VPO : on ne doit pas supprimer le texte dans ATM
#    For [ATM]DERNUM Where NUMERO=L With Nohint
#     Delete [ATM] Curr
#    Next ATM
    For [ATX]DERNUM Where NUMERO=L With Nohint
     [F:ATM] = [F:ATX]
     [F:ATM]NUMERO = P
     Write [ATM]
     If fstat : Call ERREUR(DOSMERE+".ATEXTE"-num$(P),1) From DOSDIC : Endif
    Next ATX
    For [ATM]DERNUM Where NUMERO=P With Nohint
     [F:ATX] = [F:ATM]
     Write [ATX]
     If fstat : Call ERREUR("ATEXTE"-num$(P),1) From DOSDIC : Endif
    Next ATM
    # Issue 82117 - 2012-06-04 by VPO : on supprime l'ancien texte dans ATX
    For [ATX]DERNUM Where NUMERO=L With Nohint
     Delete [ATX] Curr : # On supprime l'ancien pour éviter les doublons
    Next ATX
    # on recree l'ancien dans ATX
    For [ATM]DERNUM Where NUMERO=L With Nohint
     [F:ATX] = [F:ATM]
     Write [ATX]
     If fstat : Call ERREUR("ATEXTE"-num$(L),1) From DOSDIC : Endif
    Next ATM
    #
    MODIFNUM = 1
    Assign "[F:XXX]"+ZONTEX(J,I)+"("+num$(K)+")" With P
    NBTEX += 1
    ANCTEX(NBTEX) = L
    NOUTEX(NBTEX) = P
   Endif
  Endif
 Elsif ANCTEX(N)<>NOUTEX(N) : # Le numéro a déjà été réattribué
  MODIFNUM = 1
  Assign "[F:XXX]"+ZONTEX(J,I)+"("+num$(K)+")" With NOUTEX(N)
 Endif
Endif
Return

