#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion objet AM3
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AM3",GBIDC1,GBIDC2) From GOBJET
End


######################################################################################
## Etiquette ajoutée par le superviseur (Objet AM3) 16/09/2011 14:53:27 (CCORA)
######################################################################################
$ACTION
Case ACTION
 When "ANNULE"   : Gosub ANNULE
 When "CREATION" : Gosub CREATION
 When "NOUVEAU"  : Gosub NOUVEAU
 When "MODIF"    : Gosub MODIF
 When "SETBOUT"  : Gosub SETBOUT
 When "LIENS"    : Gosub LIENS
 When Default
Endcase
Return


######################################################################################

$SETBOUT
If GADONIX<>2 and [M]STANDARD=2
   Disable GSTAANU
Endif
Return

$LIENS
If [M]CODE<>"" and GADONIX<>2 and [M]STANDARD=2
  Diszo [M]
  Actzo [M]RANG
Else
  Actzo [M]
  If [M]RANGMOD<>3
    Raz [M]MODULE
    Diszo [M]MODULE
  Endif
Endif

Call TEXTE([M]INTIT,[M]AINTIT) From OBJDIV
Call TEXTE([M]DESCRIP,[M]ADESCRIP) From OBJDIV
Call TEXTE([M]DESCRIP1,[M]ADESCRIP1) From OBJDIV
Call TEXTE([M]DESCRIP2,[M]ADESCRIP2) From OBJDIV

Return

$NOUVEAU
Actzo [M]
If GADONIX=2
  [M]STANDARD=2
Else
  [M]STANDARD=1
Endif
Affzo [M]STANDARD
Return


$CREATION
#Call MAJTEXTRA([M]INTIT,"AMOULIN","INTIT",[M]CODE,"") From ATEXTRA
#Call MAJTEXTRA([M]DESCRIP,"AMOULIN","DESCRIP",[M]CODE,"") From ATEXTRA
#Call MAJTEXTRA([M]DESCRIP1,"AMOULIN","DESCRIP1",[M]CODE,"") From ATEXTRA
#Call MAJTEXTRA([M]DESCRIP2,"AMOULIN","DESCRIP2",[M]CODE,"") From ATEXTRA
Return



$MODIF
#Call MAJTEXTRA([M]INTIT,"AMOULIN","INTIT",[M]CODE,"") From ATEXTRA
#Call MAJTEXTRA([M]DESCRIP,"AMOULIN","DESCRIP",[M]CODE,"") From ATEXTRA
#Call MAJTEXTRA([M]DESCRIP1,"AMOULIN","DESCRIP1",[M]CODE,"") From ATEXTRA
#Call MAJTEXTRA([M]DESCRIP2,"AMOULIN","DESCRIP2",[M]CODE,"") From ATEXTRA
Return


$ANNULE
#Delete [AXX] Where CODFIC="AMOULIN" & IDENT1=[M]CODE
Return

#----------------------------------------------------------------------------#

$TRTCOP
If [M]DOSORG=nomap
 Local File AMOULIN  [AI01]
 Local File ATEXTE    [ATX1]
Else
 Local File =[M]DOSORG+".AMOULIN"  [AI01]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AMOULIN  [AI02]
 Local File ATEXTE    [ATX2]
Else
 Local File =[M]DOSDES+".AMOULIN"  [AI02]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
Endif
OK = 1
If GTRACE=""
 Read [AI02]AI01 = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [AI01], [ATX1], [AI02], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [AI02] , [ATX2]
 Delete [AI02] Where CODE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AMOULIN" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AI02","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AI01]AI01 Where CODE=TABLE
  [F:AI02] = [F:AI01]
  Call COPTEXTE([F:AI01]INTIT,[F:AI02]INTIT) From OBJDIV
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:AI01]DESCRIP,[F:AI02]DESCRIP) From OBJDIV
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:AI01]DESCRIP1,[F:AI02]DESCRIP1) From OBJDIV
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:AI01]DESCRIP2,[F:AI02]DESCRIP2) From OBJDIV
  If GOK<1 : Break : Endif
  Write [AI02]
  If fstat
   GOK=0 : Call FSTA("AI02") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

# Gestion du masque AMOULIN3
Subprog AM_MODULE(VALEUR)
Variable Integer VALEUR
[M]INDMOD=VALEUR
Affzo INDMOD
[M]INDICEM=[M]RANGMOD*100000+[M]PHASE*10000+[M]INDMOD*100+[M]RANG
Affzo INDICEM
End


Subprog AM_RANGMOD(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
  Raz [M]MODULE
  [M]INDMOD=1
Endif
Affzo INDMOD
[M]INDICEM=VALEUR*100000+[M]PHASE*10000+[M]INDMOD*100+[M]RANG
Affzo INDICEM
End




Subprog AM_PHASE(VALEUR)
Variable Decimal VALEUR
[M]INDICEM=[M]RANGMOD*100000+VALEUR*10000+[M]INDMOD*100+[M]RANG
Affzo INDICEM
End


Subprog D_RANG(VALEUR)
Variable Decimal VALEUR
Filter [AI0] Where RANGMOD=[M]RANGMOD and MODULE=[M]MODULE and PHASE=[M]PHASE
Local Integer MAXRANG
For [AI0]
  If [F:AI0]RANG>MAXRANG : MAXRANG=[F:AI0]RANG : Endif
Next
Filter [AI0]
VALEUR=MAXRANG+1
End


Subprog C_RANG(VALEUR)
Variable Decimal VALEUR
If clalev([F:AI0])=0 : Local File AMOULIN [AI0] : Endif
Filter [AI0] Where  RANGMOD=[M]RANGMOD and MODULE=[M]MODULE and PHASE=[M]PHASE
For [AI0]
  If [F:AI0]RANG=VALEUR and [F:AI0]CODE<>[M]CODE
# Indice déjà utilisé par la procédure
    GMESSAGE=mess(6,7902,1)-[F:AI0]CODE
    mkstat=2
    Break 1
  Endif
Next
Filter [AI0]
End


Subprog AM_RANG(VALEUR)
Variable Decimal VALEUR
[M]INDICEM=[M]RANGMOD*100000+[M]PHASE*10000+[M]INDMOD*100+VALEUR
Affzo INDICEM
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran AMOULIN3) 26/09/2011 12:51:22 (CCORA)
######################################################################################
Subprog AS_MODULE(VALEUR)
Variable Integer VALEUR
If [M]RANGMOD<>3 : mkstat=2 : Endif
If [M]RANGMOD=3
  GMENLOC(9)=1
Endif
End


Subprog S_RANG(VALEUR)
Variable Decimal VALEUR

Local Integer NBLIB,IND
Local Char TBLIB(70)(0..99)
Local Char TIT(50)

If clalev([F:AI0])=0 : Local File AMOULIN [AI0] : Endif
Filter [AI0] Where RANGMOD=[M]RANGMOD & MODULE=[M]MODULE & PHASE=[M]PHASE
For [AI0]
  NBLIB += 1
 # Call LECTEXTRA(TIT,"AMOULIN","INTIT",[F:AI0]CODE,"") From ATEXTRA
  Call TEXTE([F:AI0]INTIT,TIT) From OBJDIV
  TBLIB(NBLIB) =num$([F:AI0]RANG)-":"-[F:AI0]CODE-":"-TIT
Next
Call SAITEX(NBLIB,TBLIB,IND,mess(8,7902,1)) From GESECRAN
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran AMOULIN3) 07/10/2011 16:15:12 (CCORA)
######################################################################################
Subprog AP_RANGMOD(VALEUR)
Variable Integer VALEUR
If VALEUR<>3
  Raz [M]MODULE
  Diszo [M]MODULE
Else
  Actzo [M]MODULE
Endif
End


######################################################################################
