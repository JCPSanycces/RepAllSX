# FUNTBASWAS : W-A-S         VP/OL - Septembre 2009                   #
#*********************************************************************#
# Gestion du panier                                                   #
#*********************************************************************#


Local Char BASKETID(30)
Local Char ACT(10)
Local Integer LINNUM(100)
# Issue 121827 - 2017-03-09 by MAE
#Local Char ITMREF(20)(100)
Local Char ITMREF(GLONITM)(100)
Local Integer QTY(100)
Local Decimal PRICE(100)
Local Char CHECKED(100)
Local Integer NBITM
Local Decimal TOTPRICE
ACT="MOD"
BASKETID="TEST"
Call MAJ_BK(BASKETID,ACT,LINNUM,ITMREF,QTY,PRICE,CHECKED,NBITM,TOTPRICE)
##Infbox num$(NBITM)
End


Subprog MAJ_BK(BASKETID,ACT,LINNUM,ITMREF,QTY,PRICE,CHECKED,NBITM,TOTPRICE)
Variable Char BASKETID()
Variable Char ACT()
Variable Integer LINNUM(1..)
Variable Char ITMREF()(1..)
Variable Integer QTY(1..)
Variable Decimal PRICE(1..)
Variable Char CHECKED()(1..)
Variable Integer NBITM
Variable Decimal TOTPRICE

If !clalev([F:TBD]) Local File TBASKETD [TBD] Endif
Local Integer LINEID,I

Case ACT
 When "DEL" : Gosub DELLINES
 When "ADD" : Gosub ADDLINES
 When "MOD" : Gosub MODIFY
 When "RAZ" : Gosub DEL
 When "READ": Gosub READBASK
Endcase
End

$DELLINES
 Trbegin [TBD]
 For I=1 To 100
  If I=100 or  [L]ITMREF(I)=""
   Break
  Else
   If [L]CHECKED(I)="on"
    Delete [F:TBD] Where NUM=BASKETID & [F:TBD]ITMREF=[L]ITMREF(I)
    If fstat<>0
     Call ADDMESSERR("ERREUR EN SUPPRESSION") From AWEB
     Rollback
     End
    Endif
   Endif
  Endif
 Next
 Commit
 Gosub READBASK
Return

$ADDLINES
 Trbegin [TBD]
 For [TBD] Where NUM=BASKETID
  If LINEID<[F:TBD]BASKLIN
   LINEID=[F:TBD]BASKLIN : # On récupère le dernier numéro de ligne
  Endif
 Next
 #Call ADDMESSERR("ol5"-num$(dim(ITMREF))) From AWEB
 #Rollback : End
 For I=1 To 100
  If [L]ITMREF(I)=""
   Break
  Else
   If [L]QTY(I)>0
    Read [F:TBD]TBD1=BASKETID;[L]ITMREF(I)
    If fstat<>0
     LINEID+=500
     Raz [F:TBD]
     [F:TBD]NUM=BASKETID
     [F:TBD]BASKLIN=LINEID
     [F:TBD]ITMREF=[L]ITMREF(I)
     [F:TBD]QTY=[L]QTY(I)
     [F:TBD]PRICE=[L]PRICE(I)
     Write [F:TBD]
     If fstat<>0
      Call ADDMESSERR("ERREUR EN CREATION") From AWEB
      Rollback
      End
     Endif
    Else
     [F:TBD]QTY+=[L]QTY(I)
     Rewrite [F:TBD]
     If fstat<>0
      Call ADDMESSERR("ERREUR EN CREATION") From AWEB
      Rollback
      End
     Endif
    Endif
   Endif
  Endif
 Next
 Commit
 Gosub READBASK
Return

$MODIFY
 Trbegin [TBD]
  For I=1 To 100
   If [L]ITMREF(I)=""
    Break
   Else
    If [L]QTY(I)>0
     Read [F:TBD]TBD1=BASKETID;[L]ITMREF(I)
     If fstat=0
      [F:TBD]QTY=[L]QTY(I)
      Rewrite [F:TBD]
      If fstat<>0
       Call ADDMESSERR("ERREUR EN CREATION") From AWEB
       Rollback
       End
      Endif
     Endif
    Endif
   Endif
  Next
 Commit
 Gosub READBASK
Return

$DEL
 Trbegin [TBD]
  Delete [TBD] Where NUM=BASKETID
 Commit
Gosub READBASK
Return

$READBASK
 Local Integer I
 I=0 : NBITM=0 : TOTPRICE=0
 For [TBD] Where NUM=BASKETID
  I+=1
  LINNUM(I)=[F:TBD]BASKLIN
  [L]ITMREF(I)=[F:TBD]ITMREF
  [L]QTY(I)=[F:TBD]QTY
  [L]PRICE(I)=[F:TBD]PRICE
  TOTPRICE+=[F:TBD]QTY*[F:TBD]PRICE
  NBITM+=[F:TBD]QTY
 Next
Return

