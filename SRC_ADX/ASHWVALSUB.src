#<AdxTL>@(#)0.0.0.0 $Revision$
Gosub TEST From ASHWVAL
End

#-------------------------------------------------------#
Subprog SAVE_STC(DOSSIER,COD)
Value Char DOSSIER, COD
Local Integer STAT , K , OKTRT
Local Char    FICSAV(GDIMFIC)
Local Char    FICHIER(GDIMFIC)
Local Char    PREFIX(30)

Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

Local Char PREFOLD(6) : PREFOLD = "_old"

FICSAV  = filpath("STC",func SUBASW.PREFIX_REP+COD+PREFOLD,"stc",APPLI,"",MACHINE)
FICHIER = filpath("STC",func SUBASW.PREFIX_REP+COD,"stc",APPLI,"",MACHINE)
If filinfo(FICHIER,0)>=0
 Call _COPIE(FICHIER,FICSAV,STAT) From ASYRSYS
Endif

For K=0 To 20
 FICHIER = filpath("TRT",func APREFIXTRT.GET_PREFIX_REP+num$(K)+[L]COD,"src",APPLI,"",MACHINE)
 FICSAV  = filpath("TRT",func APREFIXTRT.GET_PREFIX_REP+num$(K)+[L]COD+PREFOLD,"src",APPLI,"",MACHINE)
 If filinfo(FICHIER,0)>=0
  Call _COPIE(FICHIER,FICSAV,STAT) From ASYRSYS
 Endif
Next K

For K=0 To 20
 FICHIER = filpath("TRT",func SUBASW.PREFIX_TRT+string$(K>0,num$(K))+[L]COD,"src",APPLI,"",MACHINE)
 FICSAV  = filpath("TRT",func SUBASW.PREFIX_TRT+string$(K>0,num$(K))+[L]COD+PREFOLD,"src",APPLI,"",MACHINE)
 If filinfo(FICHIER,0)>=0
  Call _COPIE(FICHIER,FICSAV,STAT) From ASYRSYS
 Endif
Next K

For PREFIX=func APREFIXTRT.GET_PREFIX_REP_CRUD,
&             func ACLAVALCRUD.GET_PREFIX_REP_READ,
&             func ACLAVALCRUD.GET_PREFIX_REP_UPD,
&             func ACLAVALCRUD.GET_PREFIX_REP_DEL,
&             func ACLAVALCRUD.GET_PREFIX_REP_CRE,
&             func SUBASW.PREFIX_QRYTRT,
&             func APREFIXTRT.GET_PREFIX_REP+"I",
&             func APREFIXTRT.GET_PREFIX_REP+"O",
&             func APREFIXTRT.GET_PREFIX_REP+"N",
&             func APREFIXTRT.GET_PREFIX_REP+"C",
&             func ASHWVALLEC.GETPREFIXTRTCTLSUP,
&             func APREFIXTRT.GET_PREFIX_RPT
 FICHIER = filpath("TRT",PREFIX+COD,"src",APPLI,"",MACHINE)
 FICSAV  = filpath("TRT",PREFIX+COD+PREFOLD,"src",APPLI,"",MACHINE)
 If filinfo(FICHIER,0)>=0
  Call _COPIE(FICHIER,FICSAV,STAT) From ASYRSYS
 Endif
Next

#Save WJSO treatments :
Call SAVE_WJSO(MACHINE,APPLI,COD) From ASHWJSO

End

#-------------------------------------------------------#
Subprog RESTORE_STC(DOSSIER,COD)
Value Char DOSSIER, COD
Local Integer STAT , K , OKTRT,TYPAGE
Local Char    FICSAV(GDIMFIC)
Local Char    FICHIER(GDIMFIC)
Local Char    PREFIX(30)

Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC),MES(250)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

Local Char PREFOLD(6) : PREFOLD = "_old"

FICSAV  = filpath("STC",func SUBASW.PREFIX_REP+COD+PREFOLD,"stc",APPLI,"",MACHINE)
FICHIER = filpath("STC",func SUBASW.PREFIX_REP+COD,"stc",APPLI,"",MACHINE)
If filinfo(FICSAV,0)>=0
 Call _COPIE(FICSAV,FICHIER,STAT) From ASYRSYS
 Call _EFFACE(FICSAV,STAT) From ASYRSYS
 #Call VALID_TECH("STC",COD,0,DOSSIER,0,TYPAGE,STAT,MES) From ACLAVALSUB
 Call VALID_TECH("STC",func SUBASW.PREFIX_REP+COD,0,DOSSIER,0,TYPAGE,STAT,MES) From ACLAVALSUB
Endif

For K=0 To 20
 FICHIER = filpath("TRT",func APREFIXTRT.GET_PREFIX_REP+num$(K)+[L]COD,"src",APPLI,"",MACHINE)
 FICSAV  = filpath("TRT",func APREFIXTRT.GET_PREFIX_REP+num$(K)+[L]COD+PREFOLD,"src",APPLI,"",MACHINE)
 If filinfo(FICSAV,0)>=0
  Call _COPIE(FICSAV,FICHIER,STAT) From ASYRSYS
  Call _EFFACE(FICSAV,STAT) From ASYRSYS
  Call VALID_TECH("TRT",func APREFIXTRT.GET_PREFIX_REP+num$(K)+[L]COD,0,DOSSIER,0,TYPAGE,STAT,MES) From ACLAVALSUB
 Endif
Next K

For K=0 To 20
 FICHIER = filpath("TRT",func SUBASW.PREFIX_TRT+string$(K>0,num$(K))+[L]COD,"src",APPLI,"",MACHINE)
 FICSAV  = filpath("TRT",func SUBASW.PREFIX_TRT+string$(K>0,num$(K))+[L]COD+PREFOLD,"src",APPLI,"",MACHINE)
 If filinfo(FICSAV,0)>=0
  Call _COPIE(FICSAV,FICHIER,STAT) From ASYRSYS
  Call _EFFACE(FICSAV,STAT) From ASYRSYS
  Call VALID_TECH("TRT",func SUBASW.PREFIX_TRT+string$(K>0,num$(K))+[L]COD,0,DOSSIER,0,TYPAGE,STAT,MES) From ACLAVALSUB
 Endif
Next K

For PREFIX=func APREFIXTRT.GET_PREFIX_REP_CRUD,
&             func ACLAVALCRUD.GET_PREFIX_REP_READ,
&             func ACLAVALCRUD.GET_PREFIX_REP_UPD,
&             func ACLAVALCRUD.GET_PREFIX_REP_DEL,
&             func ACLAVALCRUD.GET_PREFIX_REP_CRE,
&             func SUBASW.PREFIX_QRYTRT,
&             func APREFIXTRT.GET_PREFIX_REP+"I",
&             func APREFIXTRT.GET_PREFIX_REP+"O",
&             func APREFIXTRT.GET_PREFIX_REP+"N",
&             func APREFIXTRT.GET_PREFIX_REP+"C",
&             func ASHWVALLEC.GETPREFIXTRTCTLSUP,
&             func APREFIXTRT.GET_PREFIX_RPT
 FICHIER = filpath("TRT",PREFIX+COD,"src",APPLI,"",MACHINE)
 FICSAV  = filpath("TRT",PREFIX+COD+PREFOLD,"src",APPLI,"",MACHINE)
 If filinfo(FICSAV,0)>=0
  Call _COPIE(FICSAV,FICHIER,STAT) From ASYRSYS
  Call _EFFACE(FICSAV,STAT) From ASYRSYS
  #Call VALID("TRT",PREFIX+COD,APPLI,STAT) From VALMSKSUB
  Call VALID_TECH("TRT",PREFIX+COD,0,DOSSIER,0,TYPAGE,STAT,MES) From ACLAVALSUB
 Endif
Next

#Restore WJSO treatments :
Call SAVE_WJSO(MACHINE,APPLI,COD) From ASHWJSO
End


#----------------------------------------------#
#----------------------------------------------#

Subprog DELETE_STCOLD(DOSSIER,COD)
Value Char DOSSIER, COD
Local Integer STAT , K , OKTRT
Local Char    FICANU(GDIMFIC)
Local Char    FICHIER(GDIMFIC)
Local Char    PREFIX(30)

Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC),EXTSTC(6),EXTTRT(6)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

[L]EXTSTC = "_old"
[L]EXTTRT = "_old"

Gosub DELETESTC
End

#----------------------------------------------#
#----------------------------------------------#

Subprog DELETE_ALLSTC(DOSSIER,COD)
Value Char DOSSIER, COD
Local Integer STAT , K , OKTRT
Local Char    FICANU(GDIMFIC)
Local Char    FICHIER(GDIMFIC)
Local Char    PREFIX(30)

Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC),EXTSTC(6),EXTTRT(6)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

[L]EXTSTC = ""
[L]EXTTRT = ""

Gosub DELETESTC
End

Subprog DELETE_STC(DOSSIER,COD)
Value Char DOSSIER, COD
Local Integer STAT , K , OKTRT
Local Char    FICANU(GDIMFIC)
Local Char    FICHIER(GDIMFIC)
Local Char    PREFIX(30)

Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC),EXTSTC(6),EXTTRT(6)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

[L]EXTSTC = ""
[L]EXTTRT = ""
Gosub DELSTC

End

$DELETESTC
Local Char WCMDE(250)
WCMDE = adxmac(0)+'@lsadx -a '+nomap-' STC adx'
Local File (STC(30)) From System WCMDE As [STC_]
For [STC_] Where (STC="R_"+COD or (len(STC)>len("R_"+COD) & left$(STC,len("R_"+COD+"_"))="R_"+COD+"_")       )
 [L]COD =  right$([STC_]STC,3)
 Gosub DELSTC
Next TRT_
Close Local File [STC_]
Return

#----------------------------------------------#

$DELSTC
FICANU = filpath("STC",func SUBASW.PREFIX_REP+COD+[L]EXTSTC,"stc",APPLI,"",MACHINE)
If filinfo(FICANU,0)>=0
 Call _EFFACE(FICANU,STAT) From ASYRSYS
Endif
#Call _EFFACE_STC(MACHINE,APPLI,func SUBASW.PREFIX_REP+COD+[L]EXTSTC,STAT) From ASYRSYS
Call _INVALID_STC(MACHINE,APPLI,func SUBASW.PREFIX_REP+COD+[L]EXTSTC,STAT) From ASYRSYS

For K=0 To 20
 FICHIER = filpath("TRT",func APREFIXTRT.GET_PREFIX_REP+num$(K)+[L]COD+[L]EXTTRT,"src",APPLI,"",MACHINE)
 If filinfo(FICHIER,0)>=0
  Call _EFFACE(FICHIER,STAT) From ASYRSYS
 Endif
 Call EXISTE_ADX(MACHINE,APPLI,func APREFIXTRT.GET_PREFIX_REP+num$(K)+[L]COD+[L]EXTTRT,OKTRT) From ASYRSYS
 If OKTRT>0
  Call _EFFACE_ADX(MACHINE,APPLI,func APREFIXTRT.GET_PREFIX_REP+num$(K)+[L]COD+[L]EXTTRT,STAT) From ASYRSYS
 Endif
Next K

For K=0 To 20
 FICHIER = filpath("TRT",func SUBASW.PREFIX_TRT+string$(K>0,num$(K))+[L]COD+[L]EXTTRT,"src",APPLI,"",MACHINE)
 If filinfo(FICHIER,0)>=0
  Call _EFFACE(FICHIER,STAT) From ASYRSYS
 Endif
 Call EXISTE_ADX(MACHINE,APPLI,func SUBASW.PREFIX_TRT+string$(K>0,num$(K))+[L]COD+[L]EXTTRT,OKTRT) From ASYRSYS
 If OKTRT>0
  Call _EFFACE_ADX(MACHINE,APPLI,func SUBASW.PREFIX_TRT+string$(K>0,num$(K))+[L]COD+[L]EXTTRT,STAT) From ASYRSYS
 Endif
Next K

For PREFIX=func APREFIXTRT.GET_PREFIX_REP_CRUD,
&             func ACLAVALCRUD.GET_PREFIX_REP_READ,
&             func ACLAVALCRUD.GET_PREFIX_REP_UPD,
&             func ACLAVALCRUD.GET_PREFIX_REP_DEL,
&             func ACLAVALCRUD.GET_PREFIX_REP_CRE,
&             func SUBASW.PREFIX_QRYTRT,
&             func APREFIXTRT.GET_PREFIX_REP+"I",
&             func APREFIXTRT.GET_PREFIX_REP+"O",
&             func APREFIXTRT.GET_PREFIX_REP+"N",
&             func APREFIXTRT.GET_PREFIX_REP+"C",
&             func ASHWVALLEC.GETPREFIXTRTCTLSUP,
&             func APREFIXTRT.GET_PREFIX_RPT
 FICHIER = filpath("TRT",PREFIX+COD+[L]EXTTRT,"src",APPLI,"",MACHINE)
 If filinfo(FICHIER,0)>=0
  Call _EFFACE(FICHIER,STAT) From ASYRSYS
 Endif
 Call EXISTE_ADX(MACHINE,APPLI,PREFIX+COD+[L]EXTTRT,OKTRT) From ASYRSYS
 If OKTRT>0
  Call _EFFACE_ADX(MACHINE,APPLI,PREFIX+COD+[L]EXTTRT,STAT) From ASYRSYS
 Endif
Next

#Delete WJSO treatments :
Call DEL_WJSO(MACHINE,APPLI,COD) From ASHWJSO

Return

End

