#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTITRS25   UTI process                                    Module TRS   #
#            correction utility
#    TRS for module :  must be replaced (GPA ACH STO ...)
#    25  number of sequence : must be replaced (01 02 ...)
##########################################################################

If clalev([F:ADS])=0
    Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
        Raz [F:ADS]
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTITRS25(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTITRS25(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR
Call ECR_TRACE("UTITRS25 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ADI])  =0  Local File =DOSSIER+".ATABDIV"   [ADI] : Endif


WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [ADI]

WCOMPTEUR = 0
Filter [ADI] Where NUMTAB=330
For [ADI]
 Case [F:ADI]CODE
  When "FNA","FNAL" : [F:ADI]N1 = 1
  When "FRS","FRST" : [F:ADI]N1 = 2
  When "OOF","OOFF" : [F:ADI]N1 = 3
  When "RCU","RCUR" : [F:ADI]N1 = 4
 Endcase
 Rewrite [F:ADI]
 If !fstat WCOMPTEUR += 1 Endif
Next
Filter [ADI]
Call ECR_TRACE("UTITRS25 : ATABDIV-330 (N1) "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN


Commit

Close Local File [ADI]

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTITRS25 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
#If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
Call MAJ_UTITRS25(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UTITRS25(APPLI)
End

