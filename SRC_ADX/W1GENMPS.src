#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENMPS 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:26"
A_USER  = "DOC"
A_STAMP = "20181109230426"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask GENMPS [GENMPS]
Gosub HORODAT
Local Inpbox "GENMPS" From GFONCTION At A_STAMP With A_WINDPREV Mask [GENMPS] As [SIM_]
Grizo [GENMPS]5
Grizo [GENMPS]10
Grizo [GENMPS]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [GENMPS]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=25 : X2(0)=88 : Y1(0)=7 : Y2(0)=8
X1(1)=25 : X2(1)=88 : Y1(1)=9 : Y2(1)=20
X1(2)=25 : X2(2)=88 : Y1(2)=21 : Y2(2)=22
Return

$ON_PROSEL
Onevent AFTER_CHANGE Gosub AMM_PROSEL From W1GENMPS
Onevent INIT_AREA Call D_PROSEL(zc) From W1GENMPS
Onevent BEFORE_INPUT Call AS_PROSEL(zc) From W1GENMPS
Return

Subprog D_PROSEL(VALEUR)
Variable Integer VALEUR
If varinit([M]PROSEL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PROSEL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_PROSEL
Call AM_PROSEL(zc)
If !mkstat & GOBJET
 zoncou = "PROSEL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PROSEL(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_PROSEL(VALEUR) From TRTMPS
If mkstat : GERR = 1 : GZONE = "PROSEL" : GZNUM = 6028 : Endif
Gosub _AFF
End

