Subprog AS_PRF(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(8750,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action BSPRF
Call AS_PRF(VALEUR) From DIVPAYE
If mkstat=2
 [M]PRF(INDIC) = VALEUR
 Affzo PRF(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_PRF(zc) From W1GENMPS
Onkey   2 Titled GBOUTS Call S_PRF(zc) From W1GENMPS
Onkey 144 Titled GBOUTP Call P_PRF(zc) From W1GENMPS
Onkey 146 Titled GBOUTA Call SA_PRF(zc) From W1GENMPS
Gosub _AFF
End

Subprog C_PRF(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PRF" : GZNUM = 8750 : Endif
If !mkstat
 ## Action CONTPRF
 Call CONTPRF(VALEUR) From SUBPRF
 If mkstat : GERR = 1 : GZONE = "PRF" : GZNUM = 8750 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PRF" : GZNUM = 8750 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_PRF
Call AM_PRF(zc)
If !mkstat & GOBJET
 zoncou = "PRF" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PRF(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZPRF)")>indice
 [M]PRF(indice) = VALEUR
 Affzo ZPRF(indice)
Endif
Gosub _AFF
End

Subprog S_PRF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPRF
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPRF"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPRF","SUBPRF","SPEPRF") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PRF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPRF
 Call TUNPRF(VALEUR) From SUBPRF
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_PRF(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "PRF"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PRF(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("PRF",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZPRF
Onevent BEFORE_AREA Gosub AV_ZPRF From W1GENMPS
Return

$AV_ZPRF
Call LECTEXTRA(zc,"PROFIL","PRFDES",num$(GCURLEG),num$([M]PRF(indice))) From ATEXTRA
Gosub _AFF
Return

