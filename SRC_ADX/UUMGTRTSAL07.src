    [F:SRD]SRHCAT=[F:SRH]SRHCAT
Return

# -------------------------------------------------- #
# Création des enregistrements de la table CPTANALIN #
# -------------------------------------------------- #
$UPD_CAL_SRD

#Look [CAL] CAL0="SRD";0;[F:SRD]SRHNUM;[F:SRD]SRDLIN;0;"";1
#If fstat
    Raz [F:CAL]
    [F:CAL]ABRFIC="SRD"
    [F:CAL]VCRNUM=[F:SRD]SRHNUM
    [F:CAL]VCRLIN=[F:SRD]SRDLIN
    [F:CAL]ANALIG=1
    For J=1 To max(GNBCOA,2)
        [F:CAL]LED(J-1)=GLEDSOC(J)
        [F:CAL]COA(J-1)=GCOA(J)
    Next J
    Gosub EVAL_CAL

    # Issue 106947 - 20150811 by LD : Migration of historic folder
#    If NEWMOTEUR
#        Gosub CAL_STK : # pour stocker ref
#        WriteB [F:CAL]
#    Else
#        Write [F:CAL]
#    Endif
#    If fstat
#      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#      Gosub CAL_ERRTRA : # pour afficher les ref
#      GOK=0 : Return
#    Endif
    Gosub CAL_STK : # pour stocker ref
    WriteB [F:CAL]
    If fstat
      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
      Gosub CAL_ERRTRA : # pour afficher les ref
      GOK=0 : Return
    Endif
    # Issue 106947 - 20150811 by LD
#Endif

Return

$EVAL_CAL

  For J=1 To max(GNBDIE,GOPTCANA)
      [F:CAL]DIE(J-1)=GDIE(J)
      Case J
          When 1 : [F:CAL]CCE(J-1)=[F:SRDM]CCE1
          When 2 : [F:CAL]CCE(J-1)=[F:SRDM]CCE2
          When 3 : [F:CAL]CCE(J-1)=[F:SRDM]CCE3
          When 4 : [F:CAL]CCE(J-1)=[F:SRDM]CCE4
          When 5 : [F:CAL]CCE(J-1)=[F:SRDM]CCE5
          When 6 : [F:CAL]CCE(J-1)=[F:SRDM]CCE6
          When 7 : [F:CAL]CCE(J-1)=[F:SRDM]CCE7
          When 8 : [F:CAL]CCE(J-1)=[F:SRDM]CCE8
          When 9 : [F:CAL]CCE(J-1)=[F:SRDM]CCE9
          When Default
      Endcase

#       If evalue("dim([F:SRDM]CCE"+num$(J)+")")>0
#           [F:CAL]CCE(J-1)=evalue("[F:SRDM]CCE"+num$(J))
#       Endif

  Next J
Return

########################################################################
# Nouveaux Champs entête à alimenter à partir de la V6
########################################################################
$SUITE_AMAJ60_SRH

Return

########################################################################
$RECUP_BPR

    If GACTDEB=2 & [F:SRH]BPIEECNUM=""
        # --- Alimentation n° d'identification CEE
        If [F:BPR]BPRNUM<>[F:SRH]BPCINV & [F:SRH]BPCINV<>""
           Read [F:BPR]BPR0 = [F:SRH]BPCINV : If fstat Raz [BPR] Endif
        Endif
        [F:SRH]BPIEECNUM=[F:BPR]EECNUM
    Endif

Return

########################################################################
$RECUP_BPD

      If [F:SRH]EECICT="" | (GACTDEB=2 & ([F:SRH]EECLOC=0 | [F:SRH]EECTRN=0))
          # --- Alimentation incoterm, lieu de transport CEE et mode de transport CEE
          If [F:BPD]BPCNUM<>[F:SRH]BPCORD | [F:BPD]BPAADD<>[F:SRH]BPAADD
             Read [F:BPD]BPD0 = [F:SRH]BPCORD;[F:SRH]BPAADD : If fstat Raz [BPD] Endif
          Endif
          If [F:SRH]EECICT="" [F:SRH]EECICT=[F:BPD]EECICT Endif
          If GACTDEB=2
             If [F:SRH]EECLOC=0 [F:SRH]EECLOC=[F:BPD]EECLOC Endif
             If [F:SRH]EECTRN=0 & [F:BPD]MDL<>""
                If [F:TMD]MDL<>[F:BPD]MDL
                   Read [TMD]TMD0=[F:BPD]MDL
                   If fstat Raz [TMD] : Endif
                Endif
                [F:SRH]EECTRN=[F:TMD]EECTRN
             Endif
          Endif
      Endif

Return
########################################################################
########################################################################
#----- Suppression des incohérences entre tables avant migration -----#
########################################################################
$TRT_SQL

 #-----  Déclaration des variables -----#

 Call DEBTRANS From GLOCK
 Gosub SET_FIRST From TRTFIRST

 Trbegin [SRDM]
 GOK = 1

 Gosub TRT_SQL1

 If GOK<1
  Rollback
 Else
  Commit
 Endif

Gosub UNSET_FIRST From TRTFIRST

Return

########################################################################
# Mise à jour STOFCY SRETURND à partir de STOFCY SRETURN
########################################################################
$TRT_SQL1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL

REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMSRDM+" SET STOFCY_0="
REQSQL(1)="(SELECT SRH.STOFCY_0 FROM"-DOSSIER+"."+WNAMSRHM+" SRH Where SRH.SRHNUM_0="+WNAMSRDM+".SRHNUM_0)"
REQSQL(2)=" WHERE "+WNAMSRDM+".STOFCY_0<>(SELECT SRH.STOFCY_0 From"-DOSSIER+"."+WNAMSRHM+" SRH Where SRH.SRHNUM_0="+WNAMSRDM+".SRHNUM_0) "
Execsql From num$(GTYPDBA*2+1) Sql REQSQL

Onerrgo
Return
###################################################################################################
$ERR_SQL
 GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 GOK=0
Resume
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGTRTSAL07(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTSAL07(APPLI)
End

