#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "SEL_TABLE" : Gosub SELSIH
  Endcase
Return


#########################################################################################################################################################
$SELSIH

## The selection option for the invoice number are filtered to allow only the following:
## (1) Invoice category (INVTYP) must be 'Invoice', all other types (i.e. credit memo) are not allowed
## (2) Invoice number cannot have any reference or link (RCRNUM) to another recurring invoice record
## (3) Invoice site (FCY) must match the recurring invoice site
## (4) Business partner must be of type (BPSTYP) 'Normal'


CRITERE = "[F:SIH1]STA <> 2 & [F:SIH1]INVTYP = 1 & [F:SIH1]RCRNUM = ''"
CRITERE -= "& [F:SIH1]FCY = '" + PARAM(1) + "'"

If !clalev([F:SIH1])   Local File SINVOICE   [SIH1]  : Endif
If !clalev([F:BPC])    Local File BPCUSTOMER [BPC]  : Endif

Link [SIH1] With [BPC]BPC0 = [SIH1]BPR As [SIHX] Where [BPC]BPCTYP = 1
Default File [SIHX]
START = "[F:SIH1]NUM"
OBJET=""
TIT(0) = mess(207,198,1)
NBCOL  = 0
NBCOL+=1 : COL(NBCOL) = "[SIH1]NUM"
Call TEXTFIC("SINVOICE","NUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[SIH1]FCY"
Call TEXTFIC("SINVOICE","FCY",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[SIH1]BPR"
Call TEXTFIC("SINVOICE","BPR",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[SIH1]ACCDAT"
Call TEXTFIC("SINVOICE","ACCDAT",1,TIT(NBCOL)) From OBJDIV

DEFPAG=1

Return

