#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################################
#    ACTION MODELISATION                                                #
#                                                                       #
# GACTION  : VISUROUG    : Action visualisation gamme  graphique        #
#                                                                       #
# Paramètres
#     WFCY  = Site de production
#     WROO  = Gamme
#     WALT  = Alternative
#     WDAT  = Date
#     WQTY  = quantite
# GACTION  : VISUJALG    : Action visualisation jalmonnement OF graph.  #
#                                                                       #
# Paramètres                                                            #
#     WVCR  = OF                                                        #
#########################################################################
$ACTION
Case ACTION
    When "OUVRE"          :
        Case GACTION
            When "VISUROUG" :  Gosub OUVRE_ROUG
            When "VISUJALG" :  Gosub OUVRE_JALG
        Endcase
    When "DEBUT"          :
        Case GACTION
            When "VISUROUG" :  Gosub DEBUT_ROUG
            When "VISUJALG" :  Gosub DEBUT_JALG
        Endcase
    When "OK"
        Case GACTION
            When "VISUROUG" :  Gosub OUVRE_ROUG
                               Gosub DEBUT_ROUG
            When "VISUJALG" :  Gosub OUVRE_JALG
                               Gosub DEBUT_JALG
        Endcase
    When Default
Endcase
Return

########################################################################
$OUVRE_ROUG
If clalev([F:ROH]) = 0 : Local File ROUTING    [ROH] : Endif
If clalev([F:ROO]) = 0 : Local File ROUOPE     [ROO] : Endif

Goto OUVRE

########################################################################
$OUVRE_JALG
If clalev([F:MFG]) = 0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFO]) = 0 : Local File MFGOPE     [MFO] : Endif
If clalev([F:SCH]) = 0 : Local File SCHEDULING [SCH] : Endif

Goto OUVRE

########################################################################
# Issue 75830 GH 21/12/2018 - Performance enhancement
$OUVRE
If clalev([F:MWS]) = 0 : Local File WORKSTATIO  [MWS] : Endif
If clalev([F:TWD]) = 0 : Local File TABWEEDIA   [TWD] : Endif
If clalev([F:DIH]) = 0 : Local File DIAHOU      [DIH] : Endif
If clalev([F:CPV]) = 0 : Local File CAPVAR      [CPV] : Endif

Local Mask ROUG [ROUG]
Local Mask JALK [JALK]
Return

########################################################################
$DEBUT_ROUG
Local Char    WFCY(GLONFCY) : WFCY = PARAM(1)
Local Char    WROO(GLONITM) : WROO = PARAM(2)
Local Integer WALT(3)       : WALT = val(PARAM(3))
Local Date    WDAT : WDAT = PARAM(4)
Local Decimal WQTY : WQTY = val(PARAM(5))
FIN = 0

If GFCY = "" : Call FIND_GFCYDEF(8) From TRTX3 : Endif # FQ 54218
If WFCY = "" : WFCY = GFCY : Endif

#La gamme est-elle valide ?
Read [ROH]ROH0=WROO;WALT;WFCY        : # Beryl Site en fin de clé primaire
If fstat | [F:ROH]CFMFLG <> 2
    FIN = 1
Endif

Gosub CHARG_GRAPHE
# si rien dans le tableau ou que des lignes avec 0 dans la durée
#If [M:ROUG]NBLIGC = 0 | (sum([M:ROUG]LTI(0..[M:ROUG]NBLIGC-1)) = 0)
If [M:ROUG]NBLIGC = 0 | (sum([M:ROUG]DUR(0..[M:ROUG]NBLIGC-1)) = 0)
    FIN = 1
Endif

Affzo [M:ROUG]1-99
Return

########################################################################
$DEBUT_JALG
Local Char    WVCR(GLONVCR)  : WVCR =  PARAM(1)
Local Char    WROO(GLONITM)
Local Integer WALT(3)
Local Char    WFCY(GLONFCY)
FIN = 0
Gosub CHARG_GRAPHE
# si rien dans le tableau ou que des lignes avec 0 dans la durée
If [M:ROUG]NBLIGC = 0 | (sum([M:ROUG]LTI(0..[M:ROUG]NBLIGC-1)) = 0)
    FIN = 1
Else
    If GACTION = "VISUJALG" : Grizo [M:ROUG]WQTYREF : Endif
    Affzo [M:ROUG]1-99
Endif
Return

############################################################
$CHARG_GRAPHE
Local Integer WROW, WRET
Local Integer I,J, K, WD, WH,WCALC
Local Char    WINTSTRDAT(20),WINTENDDAT(20) # stockage date+heure YYYYMMDDHHMI
Local Date    WSTRDAT, WCURRDATE,WENDDAT
Local Decimal WSTRHOUR, WENDHOUR, WSTRFRD, WENDFRD, WCLCWORDUR, WHOURI, WLTIAFF
Local Char    WSTRHHMI(4),WENDHHMI(4), HH(2), MM(2)
Local Char    WSTARTC(1) , WWST(GLONWST)
Local Char    WROODES(GLONDES) : Raz WROODES      # FQ 60990 GA 02/2010
Local Integer HOUR
Local Integer MINUTE
Local Integer ND
Local Integer WTYPTPS                      # Issue 108897 - 07/2015 by GA

Case GACTION
     When "VISUROUG" :  Gosub CHARG_ROU
     When "VISUJALG" :  Gosub CHARG_JAL
Endcase
If WROW = 0
  Return
Endif
Raz I,J, K

For I = 0 To WROW-1
  Case GACTION
         When "VISUROUG" :    Filter [ROO] Where ITMREF=[M:JALK]ROUNUM & ROUALT=[M:JALK]ROUALT
&                             & OPENUM = [M:JALK]OPENUM(I)
&                         & (VALENDDAT = [0/0/0] | (VALENDDAT >= [L]WSTRDAT & VALENDDAT <> [0/0/0]))
&                         & (VALSTRDAT = [0/0/0] | (VALSTRDAT <= [L]WSTRDAT & VALSTRDAT <> [0/0/0]))
                              Read [F:ROO]ROO0 First
                              If fstat : Raz [F:ROO] : Endif
                              WROODES = [F:ROO]ROODES                        # FQ 60990 GA 02/2010
                              Filter [F:ROO]
                              Read [F:MWS]WST0 = [F:ROO]WST;[F:ROO]FCY
                              If fstat : Raz [F:MWS] : Endif
         When "VISUJALG" :    Read[MFO]MFO0 = [M:JALK]MFGNUM;[M:JALK]OPENUM(I);[M:JALK]OPESPLNUM(I)
                              If fstat : Raz [F:MFO] : Endif
                              WROODES = [F:MFO]ROODES                        # FQ 60990 GA 02/2010
                              Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
                              If fstat : Raz [F:MWS] : Endif

  Endcase
  WWST = [F:MWS]WST
  # lecture schéma hebdo
  If [F:TWD]TWD <> [F:MWS]TWD
     Read [TWD]TWD0=[F:MWS]TWD
     If fstat : Raz [F:TWD] : Endif
  Endif
#
  WCURRDATE = [M:JALK]OPESTRDAT(I)
  [M:ROUG]OPENUM(J) = [M:JALK]OPENUM(I)
  # FQ 60990 GA 02/2010 ajout WROODES
  [M:ROUG]ROODES(J) = mess(209,197,1) - num$([M:ROUG]OPENUM(J))-WROODES
  J+=1

# FQ 55735 selon GBE 06/2009 remplacement des appels FRAC2DUR
  Raz [L]WSTRHOUR,[L]WENDHOUR
  If [M:JALK]CLCPRPDUR(I) <> 0
      [M:ROUG]OPENUM(J)  = [M:JALK]OPENUM(I)
      # date+heure de début
      [L]WSTRDAT = [M:JALK]OPESTRDAT(I)
      [L]WSTRFRD = [M:JALK]OPESTRFRD(I)
      [L]WENDDAT = [M:JALK]INFCAPSTR(I) # FQ 79141 GA 01/2012
      [L]WENDFRD = [M:JALK]INFCAPSTF(I) # FQ 79141 GA 01/2012
      [L]WTYPTPS = 1                      # Issue 108897 - 07/2015 by GA

      Gosub DISPLAY_DATES
      If WRET                             # Issue 106567 GA 02/2015
        If dim([M:ROUG]DUR)>0             # Issue 106567 GA 02/2015
           [M:ROUG]DUR(J) = [M:JALK]CLCPRPDUR(I)
        Endif
        [M:ROUG]LTI(J)    = WLTIAFF         # FQ 55735 avant [M:JALK]CLCPRPDUR(I)
        [M:ROUG]LTIAFF(J) = WLTIAFF         # FQ 55735 avant [M:JALK]CLCPRPDUR(I)
        [M:ROUG]TYPTPS(J) = 1
        J+=1
      Endif
  Endif
  If [M:JALK]CLCWORDUR(I) <> 0
      [M:ROUG]OPENUM(J)  = [M:JALK]OPENUM(I)
      # date+heure de début
      [L]WSTRDAT = [M:JALK]INFCAPSTR(I)
      [L]WSTRFRD = [M:JALK]INFCAPSTF(I)
      # date+heure de fin                 # FQ 55735 GA 07/2009 ajouté
      [L]WENDDAT = [M:JALK]INFCAPEND(I)
      [L]WENDFRD = [M:JALK]INFCAPENF(I)
      [L]WTYPTPS = 2                      # Issue 108897 - 07/2015 by GA

      Gosub DISPLAY_DATES
      If WRET                             # Issue 106567 GA 02/2015
        If dim([M:ROUG]DUR)>0             # Issue 106567 GA 02/2015
           [M:ROUG]DUR(J) = [M:JALK]CLCWORDUR(I)
        Endif
        [M:ROUG]LTI(J)    = WLTIAFF         # FQ 55735 avant [M:JALK]CLCWORDUR(I)
        [M:ROUG]LTIAFF(J) = WLTIAFF         # FQ 55735 avant WCLCWORDUR
        [M:ROUG]TYPTPS(J) = 2
        J+=1
    Endif
  Endif
  If [M:JALK]CLCAFTDUR(I) <> 0
      [M:ROUG]OPENUM(J)  = [M:JALK]OPENUM(I)
      # date+heure de début
      [L]WSTRDAT = [M:JALK]INFCAPEND(I)
      [L]WSTRFRD = [M:JALK]INFCAPENF(I)

      # FQ 79141 GA 01/2012 utiliser les résultats du jalonnement au lieu de recalculer
      [L]WENDDAT = [M:JALK]OPEENDDAT(I)   # FQ 79141 GA 01/2012
      [L]WENDFRD = [M:JALK]OPEENDFRD(I)   # FQ 79141 GA 01/2012
      [L]WTYPTPS = 3                      # Issue 108897 - 07/2015 by GA

      Gosub DISPLAY_DATES
      If WRET                             # Issue 106567 GA 02/2015
        If dim([M:ROUG]DUR)>0             # Issue 106567 GA 02/2015
           [M:ROUG]DUR(J) = [M:JALK]CLCAFTDUR(I)
        Endif
        [M:ROUG]LTI(J)    = WLTIAFF         # FQ 55735 avant [M:JALK]CLCAFTDUR(I)
        [M:ROUG]LTIAFF(J) = WLTIAFF         # FQ 55735 avant [M:JALK]CLCAFTDUR(I)
        [M:ROUG]TYPTPS(J) = 3
        J+=1
    Endif
  Endif
Next I

If J >= 1
    [M:ROUG]NBLIGC = J
Endif
Return

# ----------------------------------------------------
# FQ 79141 GA 01/2012 évite lignes de code redondantes
# ----------------------------------------------------
$DISPLAY_DATES
  # Issue 106567 GA 02/2015
  If [L]WSTRDAT=[0/0/0] | [L]WENDDAT=[0/0/0]  WRET=0 : Return
  Else                                        WRET=1 : Endif
  # Issue 108897 - 07/2015 by GA
  If [M:JALK]SCDMOD & [L]WTYPTPS=3 & [L]WENDFRD=1 & [L]WSTRFRD=[L]WENDFRD & [L]WSTRDAT=[L]WENDDAT
    [L]WSTRHOUR= [L]WENDHOUR  # time = previous end hour
    [L]WENDHOUR= 2359         # time = 23:59
  # X3-56795 - STWIL - Post-op time so use 24 hour calendar
  Elsif [L]WTYPTPS=3 & [M:JALK]SCDFLG = 4
    Local Integer LHOUR
    Local Decimal LTIME
    Local Decimal LMRMD
    Local Integer LMIN

    [L]WSTRHOUR= [L]WENDHOUR  # time = previous end hour
    [L]WSTRHHMI= format$("N0:4",[L]WSTRHOUR)
    [L]WSTRHOUR = val([L]WSTRHHMI)
    # Need to work out if we have some minutes
    [L]LTIME = [L]WENDFRD * 24
    [L]LHOUR = int([L]LTIME)
    [L]LMRMD = [L]LTIME - [L]LHOUR
    If [L]LMRMD > 0
        [L]LMIN = int([L]LMRMD * 60)
    Endif
    #[L]WENDHOUR= arr (arr ([L]WENDFRD * 24, 0.0001) * 100, 1)         # time = Duration * 24 hours
    [L]WENDHHMI= format$("N0:2",[L]LHOUR) + format$("N0:2",[L]LMIN)
    [L]WENDHOUR= val([L]WENDHHMI)
  Else
  # Start date
    Call OPETIME(WFCY, WWST, [L]WSTRDAT, [L]WSTRFRD, [L]WSTRHHMI) From JALLIBB
    [L]WSTRHOUR = val([L]WSTRHHMI)
  # End date
    Call OPETIME(WFCY, WWST, [L]WENDDAT, [L]WENDFRD, [L]WENDHHMI) From JALLIBB
    [L]WENDHOUR= val([L]WENDHHMI)
  Endif
  Call CONVDATI([L]WSTRDAT,[L]WSTRHOUR,WINTSTRDAT) From INTRUTILA
  Call CONVDATI([L]WENDDAT,[L]WENDHOUR,WINTENDDAT) From INTRUTILA
  If dim([M:ROUG]WSTRDAT)>0 [M:ROUG]WSTRDAT(J)= [L]WSTRDAT    Endif
  If dim([M:ROUG]WSTRFRD)>0 [M:ROUG]WSTRFRD(J)= [L]WSTRFRD    Endif
  If dim([M:ROUG]WENDDAT)>0 [M:ROUG]WENDDAT(J)= [L]WENDDAT    Endif
  If dim([M:ROUG]WENDFRD)>0 [M:ROUG]WENDFRD(J)= [L]WENDFRD    Endif
  If dim([M:ROUG]INTDAT)>0  [M:ROUG]INTDAT(J) = [L]WINTSTRDAT Endif
  If dim([M:ROUG]SENDDAT)>0 [M:ROUG]SENDDAT(J)= [L]WINTENDDAT Endif

# Elapsed time
  [L]WCALC          = 1 : Raz WLTIAFF
  Call DIFFINTDAT([L]WCALC,[L]WSTRDAT,[L]WSTRHHMI,[L]WENDDAT,[L]WENDHHMI,WLTIAFF)
Return

############################################################
$CHARG_ROU
Raz [M:JALK]
[M:JALK]CODORI     = 0
[M:JALK]CODMAJ     = 2
[M:JALK]CODTRS     = 0
[M:JALK]MFGFCY     = WFCY
[M:JALK]ROUNUM     = WROO
[M:JALK]ROUALT     = WALT
[M:JALK]REOMINQTY  = WQTY
[M:JALK]TRTDAT     = WDAT
[M:JALK]STRDAT     = WDAT
[M:JALK]JAVFLG     = 2
[M:JALK]SCDMOD     = 2

Call JALONNE From JALLIB

# Calcul nombre d'opérations
WROW = 0
While [M:JALK]OPENUM(WROW) <> 0
  WROW += 1
Wend
If WROW = 0
  Return
Endif
#
# Préparation du Gantt
#
Raz [M:ROUG]
[M:ROUG]WFCYG    = WFCY
[M:ROUG]WGAMME   = WROO + "/" + num$(WALT)
[M:ROUG]WGAMMEG  = WROO
[M:ROUG]WROUALTG = WALT
[M:ROUG]WQTYREF  = WQTY
#
Return

############################################################
$CHARG_JAL
Read [F:MFG]MFG0 = WVCR
If fstat
   Raz [F:MFG] : Return
Else
   WFCY = [F:MFG]MFGFCY
   WROO = [F:MFG]ROUNUM
   WALT = [F:MFG]ROUALT
   WQTY = [F:MFG]EXTQTY
Endif

Raz [M:JALK]

# 09.07 42901
[M:JALK]MFGFCY = [F:MFG]MFGFCY
[M:JALK]MFGNUM = [F:MFG]MFGNUM
[M:JALK]SCDMOD = [F:MFG]SCDMOD # Issue 108897 - 07/2015 by GA
# X3-56795 - STWIL - Need to know the scheduling status
[M:JALK]SCDFLG = [M:MFOS]SCDFLG

I = 0
For [SCH]SCH0 Where MFGNUM=WVCR
    If [F:SCH]OPESTRDAT = [0/0/0] : Goto NEXT_SCH : Endif
    [M:JALK]OPENUM(I)    = [F:SCH]OPENUM
    [M:JALK]OPESPLNUM(I) = [F:SCH]OPESPLNUM
    [M:JALK]OPESTRDAT(I) = [F:SCH]OPESTRDAT
    [M:JALK]OPEENDDAT(I) = [F:SCH]OPEENDDAT
    Case [M:MFOS]SCDFLG
        When 1,2,3: [M:JALK]INFCAPSTR(I) = [F:SCH]INFCAPSTR
                    [M:JALK]INFCAPSTF(I) = [F:SCH]INFCAPSTF
                    [M:JALK]INFCAPEND(I) = [F:SCH]INFCAPEND
                    [M:JALK]INFCAPENF(I) = [F:SCH]INFCAPENF
                    [M:JALK]OPESTRFRD(I) = [F:SCH]OPESTRFRD
                    [M:JALK]OPEENDFRD(I) = [F:SCH]OPEENDFRD
                    [M:JALK]CLCPRPDUR(I) = [F:SCH]CLCPRPDUR
                    [M:JALK]CLCWORDUR(I) = [F:SCH]CLCWORDUR
                    If [F:SCH]CLCPSTDUR > [F:SCH]CLCWAIDUR
                       [M:JALK]CLCAFTDUR(I) = [F:SCH]CLCPSTDUR
                    Else
                       [M:JALK]CLCAFTDUR(I) = [F:SCH]CLCWAIDUR
                    Endif
        When 4:     [M:JALK]INFCAPSTR(I) = [F:SCH]FITCAPSTR
                    [M:JALK]INFCAPSTF(I) = [F:SCH]FITCAPSTF
                    [M:JALK]INFCAPEND(I) = [F:SCH]FITCAPEND
                    [M:JALK]INFCAPENF(I) = [F:SCH]FITCAPENF
                    [M:JALK]OPESTRFRD(I) = [F:SCH]OPEFITSTF
                    [M:JALK]OPEENDFRD(I) = [F:SCH]FITOPEENF
                    [M:JALK]CLCPRPDUR(I) = [F:SCH]FITPRPDUR
                    [M:JALK]CLCWORDUR(I) = [F:SCH]FITWORDUR
                    [M:JALK]CLCAFTDUR(I) = [F:SCH]FITPSTDUR
                    # X3-56794 - STWILL - Set the preparation and post-op dates correctly
                    [M:JALK]OPESTRDAT(I) = [F:SCH]OPEFITSTD
                    [M:JALK]OPEENDDAT(I) = [F:SCH]FITOPEEND
    Endcase
    I += 1
$NEXT_SCH
Next
# Calcul nombre d'opérations
Local Integer WROW
WROW = 0
While [M:JALK]OPENUM(WROW) <> 0
  WROW += 1
Wend
If WROW = 0
    Return
Endif
#
# Préparation du Gantt
#
Raz [M:ROUG]
[M:ROUG]WFCYG   = WFCY  # GA 07/2009 idem CHARG_ROU
[M:ROUG]WGAMMEG = WROO  # GA 07/2009 idem CHARG_ROU
[M:ROUG]WROUALTG= WALT  # GA 07/2009 idem CHARG_ROU
[M:ROUG]WGAMME = WVCR + "/"+ WROO + "/" +num$(WALT)
[M:ROUG]WQTYREF = WQTY
#
Return


#########################################################################
# Calcul différence dates
#
Subprog DIFFINTDAT(LCALC,LDAT1,LHHMI1,LDAT2,LHHMI2,LDIFF)
#
Value    Integer  LCALC        # 1=Résultat en jours, ...
Value    Date     LDAT1
Value    Char     LHHMI1       # heure en format HHMI
Value    Date     LDAT2
Value    Char     LHHMI2       # heure en format HHMI
Variable Decimal  LDIFF        #
#
Local    Integer  WNDAY1,WNDAY2,WMI1,WMI2,WCALC
Local    Decimal  WHH1,WHH2,WDIFF
#
LDIFF = 0
If LDAT1=[0/0/0] | LDAT2=[0/0/0] End Endif
#
Case LCALC
  When 1              # Intervalle en jours (récursif)
    WCALC=2
    Call DIFFINTDAT(WCALC,LDAT1,LHHMI1,LDAT2,LHHMI2,WDIFF)
    LDIFF = WDIFF / 24
  When 2              # Intervalle en heures
    WMI1  = val(right$(LHHMI1,3))+60*val(left$(LHHMI1,2))
    WMI2  = val(right$(LHHMI2,3))+60*val(left$(LHHMI2,2))
    LDIFF = (LDAT2 - LDAT1) * 24 + (WMI2 - WMI1)/60
  When Default
    LDIFF = 0
Endcase


End
#

