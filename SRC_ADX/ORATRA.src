#<AdxTL>@(#)7.0.0.0 $Revision:   1.3  $
Call ORATRA
End

###################################################################################################
Subprog ORATRA
If dim(GORATRA)<0 : End : Endif
If GORATRA="" : Call ACTIVE : End : Endif
Call ARRET
End


###################################################################################################
Subprog ACTIVE
Local Char PARAM(30)(1..4) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ORATRA","ORATRA",3,"SPEORATRA") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "INIT_DIA" : Gosub INIT_DIA
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When "SORTIE"   : Gosub SORTIE
Endcase
Return

$INIT
If GACTION<>"ORATRA1"
    # Test que la trace n'est pas déjà en route
    If GORATRA<>""
        Call ERREUR(mess(107,115,1)) From GESECRAN : # Trace déjà en cours de constitution
        FIN=1
        Return
    Endif

    # Vérifier que la base de données est bien oracle (optionnel)
# Issue 83278 - 2012-07-03 by VPO : pb sur recherche type de base
#    Local Integer BASE_DONNEES
#    Call TEST_BDD(BASE_DONNEES)
#    If BASE_DONNEES<>2
    If GTYPDBA<>1
        Call ERREUR(mess(108,115,1)) From GESECRAN : # La base de données n'est pas oracle
        FIN=1
        Return
    Endif

    #JPGA 17/08/2010 BUG-64041 : Pour lancer une trace, il faut être DBA. sinon mettre le GUID à +s sur le DUMPDIR. Affichage DUMPDIR sur ecran
    Local Char REP_DUMPDIR(GDIMFIC)
    Call RECH_REP(REP_DUMPDIR, FIN)
Endif
Return

$INIT_DIA
If GACTION<>"ORATRA1"
    Local Mask ORATRA1 [ORA2]
    Gosub INIT_MORA2
####
    [M:ORA0]AGGREG = 2
    [M:ORA0]TXTAGGREG = mess(50 ,153,1)
    [M:ORA0]WAITS = 2
    [M:ORA0]TXTWAITS  = mess(51 ,153,1)
    [M:ORA0]SYS = 1
    [M:ORA0]TXTSYS  = mess(52 ,153,1)
    [M:ORA0]REPERT = REP_DUMPDIR
Else
    If [M:ORA0]TRI<>6
       Raz [M:ORA2]
       Gosub INIT_MORA2
       If [M:ORA0]TRI= 2
            [M:ORA2]PRSELA=2
            [M:ORA2]EXEELA=2
            [M:ORA2]FCHELA=2
       Elsif [M:ORA0]TRI= 3
            [M:ORA2]PRSQRY=2
            [M:ORA2]EXEQRY=2
            [M:ORA2]FCHQRY=2
            [M:ORA2]PRSCPU=2
            [M:ORA2]EXECPU=2
            [M:ORA2]FCHCPU=2
       Elsif [M:ORA0]TRI= 4
            [M:ORA2]PRSCPU=2
            [M:ORA2]EXECPU=2
            [M:ORA2]FCHCPU=2
       Elsif [M:ORA0]TRI= 5
            [M:ORA2]PRSDSK=2
            [M:ORA2]EXEDSK=2
            [M:ORA2]FCHDSK=2
       Endif
    Endif
    [M:ORA1]=[M:ORA2]
Endif
Return

$INIT_MORA2
    [M:ORA2]TXTPRSCNT = mess(1 ,153,1)
    [M:ORA2]TXTPRSCPU = mess(2 ,153,1)
    [M:ORA2]TXTPRSELA = mess(3 ,153,1)
    [M:ORA2]TXTPRSDSK = mess(4 ,153,1)
    [M:ORA2]TXTPRSQRY = mess(5 ,153,1)
    [M:ORA2]TXTPRSCU  = mess(6 ,153,1)
    [M:ORA2]TXTPRSMIS = mess(7 ,153,1)
    [M:ORA2]TXTEXECNT = mess(8 ,153,1)
    [M:ORA2]TXTEXECPU = mess(9 ,153,1)
    [M:ORA2]TXTEXEELA = mess(10,153,1)
    [M:ORA2]TXTEXEDSK = mess(11,153,1)
    [M:ORA2]TXTEXEQRY = mess(12,153,1)
    [M:ORA2]TXTEXECU  = mess(13,153,1)
    [M:ORA2]TXTEXEROW = mess(14,153,1)
    [M:ORA2]TXTEXEMIS = mess(15,153,1)
    [M:ORA2]TXTFCHCNT = mess(16,153,1)
    [M:ORA2]TXTFCHCPU = mess(17,153,1)
    [M:ORA2]TXTFCHELA = mess(18,153,1)
    [M:ORA2]TXTFCHDSK = mess(19,153,1)
    [M:ORA2]TXTFCHQRY = mess(20,153,1)
    [M:ORA2]TXTFCHCU  = mess(21,153,1)
    [M:ORA2]TXTFCHROW = mess(22,153,1)
Return


$CONTROLE
Local Integer NB_OPT
Raz NB_OPT
If GACTION<>"ORATRA1"
    If [M:ORA0]TRI=6
        If [M:ORA2]PRSCNT =2 : NB_OPT += 1 : Endif
        If [M:ORA2]PRSCPU =2 : NB_OPT += 1 : Endif
        If [M:ORA2]PRSELA =2 : NB_OPT += 1 : Endif
        If [M:ORA2]PRSDSK =2 : NB_OPT += 1 : Endif
        If [M:ORA2]PRSQRY =2 : NB_OPT += 1 : Endif
        If [M:ORA2]PRSCU  =2 : NB_OPT += 1 : Endif
        If [M:ORA2]PRSMIS =2 : NB_OPT += 1 : Endif
        If [M:ORA2]EXECNT =2 : NB_OPT += 1 : Endif
        If [M:ORA2]EXECPU =2 : NB_OPT += 1 : Endif
        If [M:ORA2]EXEELA =2 : NB_OPT += 1 : Endif
        If [M:ORA2]EXEDSK =2 : NB_OPT += 1 : Endif
        If [M:ORA2]EXEQRY =2 : NB_OPT += 1 : Endif
        If [M:ORA2]EXECU  =2 : NB_OPT += 1 : Endif
        If [M:ORA2]EXEROW =2 : NB_OPT += 1 : Endif
        If [M:ORA2]EXEMIS =2 : NB_OPT += 1 : Endif
        If [M:ORA2]FCHCNT =2 : NB_OPT += 1 : Endif
        If [M:ORA2]FCHELA =2 : NB_OPT += 1 : Endif
        If [M:ORA2]FCHDSK =2 : NB_OPT += 1 : Endif
        If [M:ORA2]FCHQRY =2 : NB_OPT += 1 : Endif
        If [M:ORA2]FCHCU  =2 : NB_OPT += 1 : Endif
        If [M:ORA2]FCHROW =2 : NB_OPT += 1 : Endif
        If NB_OPT = 0
           GERR = 1
           GMESSAGE = mess(190,115,1)
           SAI=1
           Return
        Endif
    Endif
    If [M:ORA0]PRES=2 and [M:ORA0]NBPRES=0
        GERR = 1
        GMESSAGE = mess(191,115,1)
        SAI=1
    Endif
Else
    If [M:ORA1]PRSCNT =2 : NB_OPT += 1 : Endif
    If [M:ORA1]PRSCPU =2 : NB_OPT += 1 : Endif
    If [M:ORA1]PRSELA =2 : NB_OPT += 1 : Endif
    If [M:ORA1]PRSDSK =2 : NB_OPT += 1 : Endif
    If [M:ORA1]PRSQRY =2 : NB_OPT += 1 : Endif
    If [M:ORA1]PRSCU  =2 : NB_OPT += 1 : Endif
    If [M:ORA1]PRSMIS =2 : NB_OPT += 1 : Endif
    If [M:ORA1]EXECNT =2 : NB_OPT += 1 : Endif
    If [M:ORA1]EXECPU =2 : NB_OPT += 1 : Endif
    If [M:ORA1]EXEELA =2 : NB_OPT += 1 : Endif
    If [M:ORA1]EXEDSK =2 : NB_OPT += 1 : Endif
    If [M:ORA1]EXEQRY =2 : NB_OPT += 1 : Endif
    If [M:ORA1]EXECU  =2 : NB_OPT += 1 : Endif
    If [M:ORA1]EXEROW =2 : NB_OPT += 1 : Endif
    If [M:ORA1]EXEMIS =2 : NB_OPT += 1 : Endif
    If [M:ORA1]FCHCNT =2 : NB_OPT += 1 : Endif
    If [M:ORA1]FCHCPU =2 : NB_OPT += 1 : Endif
    If [M:ORA1]FCHELA =2 : NB_OPT += 1 : Endif
    If [M:ORA1]FCHDSK =2 : NB_OPT += 1 : Endif
    If [M:ORA1]FCHQRY =2 : NB_OPT += 1 : Endif
    If [M:ORA1]FCHCU  =2 : NB_OPT += 1 : Endif
    If [M:ORA1]FCHROW =2 : NB_OPT += 1 : Endif
    If NB_OPT = 0
       GERR = 1
       GMESSAGE = mess(190,115,1)
       SAI=1
    Endif
Endif
Return

$EXEC
If GACTION<>"ORATRA1"
    Call EXEC_ACTIVE(FIN)
Else
    [M:ORA2]=[M:ORA1]
    [M:ORA0]TRI=6
    Affzo [M:ORA0]TRI
Endif
Return

$SORTIE
If GACTION<>"ORATRA1"
    If clalev([M:ORA2])>0 : Close Local Mask [ORA2] : Endif
Endif
Return

###################################################################################################
Subprog EXEC_ACTIVE (ERR)
Variable Integer ERR

Local Char MESSINIT(100)

# Rechercher le nom du fichier de trace
Call RECH_FIC(GORATRA, ERR)
If ERR
    Call ERREUR(mess(110,115,1)) From GESECRAN : # Trace non lancée
    End
Endif

# Traiter les options de trace
Call TRAIT_OPT(ERR)
If ERR
    Call ERREUR(mess(110,115,1)) From GESECRAN : # Trace non lancée
    End
Endif

MESSINIT = mess(109,115,1) : # Trace activée

# on ne peut pas supprimer le fichier de trace
# sinon il ne se recree pas
#Call SUPTRA

# Passage en mode trace
#dbgstr(128)="alter session set sql_trace=true timed_statistics=true"

# mb 8.3.6 Goodbye sbgstr, morning execsql
Local File ADOSSIER [AAA_]
Read [AAA_]DOSSIER=nomap
Gosub SET_DBA
Execsql From DBA Sql "alter session set sql_trace=true timed_statistics=true"
Close Local File [AAA_]

If dim(GSTAOR1)>0
 Disable GSTAOR1 : # Menu Activation trace
 Enable  GSTAOR2 : # Menu désactivation
Endif

# Tout est OK
Call MESSAGE(MESSINIT) From GESECRAN
End

$SET_DBA
Local Char DBA(1)
Case [F:AAA_]TYPDBA
 When 1 : DBA = "3"
 When 2 : DBA = "5"
 When 3 : DBA = "2"
 When 4 : DBA = "4"
Endcase
Return


###################################################################################################
Subprog SUPTRA
Local Char    MACBID(GDIMFIC),FICTRA(GDIMFIC),MACTRA(GDIMFIC)
Local Char    COMMANDE(250)

# Test que la trace est bien en route
If GORATRA=""
 End
Endif

If GORATRAMAC<>""
    MACTRA=GORATRAMAC+"@"
    MACBID=GORATRAMAC
Else
    MACTRA=adxmac(-1)+"@"
    MACBID=adxmac(0)
Endif

FICTRA=MACTRA+GORATRA
If filinfo(FICTRA,0)<=0
    # dans le cas de NT, il faut chercher avec GORATRA = GFICDEC_ORA
    If dim(GFICDEC_ORA) > 0
       FICTRA=MACTRA+GFICDEC_ORA
       If filinfo(FICTRA,0)<=0
          End
       Endif
       System COMMANDE = MACBID+'@ae_rm'-'"'+GFICDEC_ORA+'"'
    Endif
    End
Endif
System COMMANDE = MACBID+'@ae_rm'-'"'+GORATRA+'"'
End

###################################################################################################
Subprog ARRET
Local Char PARAMORA(20)(1..5)
Local Char TKPROF(255)
Local Char ORAHOME(GDIMFIC)
Local Integer STAT
Local Char OS(20)(1..2)
Local Char    CMDFIC(GDIMFIC), FICCMD(GDIMFIC),MACBID(GDIMFIC),FICTRA(GDIMFIC)
Local Char    COMMANDE(250)
Local Char    SAVIFS(5) , SAVIRS(5) , IRS(2),LIGNE(150)
Local Integer SAVIUM


#dbgstr(128)="alter session set sql_trace=false"

# mb 8.3.6 Goodbye sbgstr, morning execsql
Local File ADOSSIER [AAA_]
Read [AAA_]DOSSIER=nomap
Gosub SET_DBA
Execsql From DBA Sql "alter session set sql_trace=false"
Close Local File [AAA_]

# Test que la trace est bien en route
If GORATRA=""
 Call ERREUR(mess(110,115,1)) From GESECRAN : # Trace non lancée
 End
Endif

# test que la trace est présente sinon on regarde avec GFICDEC_ORA
# cg le 15/01/2003
If GORATRAMAC<>""
    FICTRA=GORATRAMAC+"@"
Else
    FICTRA=adxmac(-1)+"@"
Endif
FICTRA+=GORATRA
If filinfo(FICTRA,0)<=0
   # dans le cas de NT, il faut chercher avec GORATRA = GFICDEC_ORA
    If dim(GFICDEC_ORA) > 0
       GORATRA = GFICDEC_ORA
       Kill GFICDEC_ORA
    Endif
Endif

# On récupère le mot de passe oracle
Call PASSE(nomap,PARAMORA(1),PARAMORA(2),PARAMORA(3),PARAMORA(4),PARAMORA(5)) From ORAPASSE

# On ouvre (et on réserve) un fichier de trace (le fichier trace est fermé dans le Call SYSTEME)
Call OUVRE_TRACE(mess(113,115,1)) From LECFIC : # Trace Oracle

#VPO 30/12/05 prise en compte base sur machine distante
Call GET_OS(GORATRAMAC ,OS) From ORDSYS
Call GETENV(GORATRAMAC,"ORACLE_HOME",ORAHOME ) From ORDSYS
SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = " " : adxirs = chr$(10) : adxium = GASCII
If OS(1)="unix"
FICCMD = filpath("",GORATRA,"sh","","",GORATRAMAC)
Else
FICCMD = filpath("",GORATRA,"cmd","","",GORATRAMAC)
Endif
Call MACHINE(FICCMD ,MACBID,CMDFIC) From ORDSYS
System COMMANDE = MACBID+'@ae_rm'-'"'+CMDFIC+'"'
Openo FICCMD , 0

If OS(1)="unix"
     Wrseq ORAHOME+"/bin/tkprof",GORATRA,GORATRA+"tra","explain="+PARAMORA(2)+"/"+PARAMORA(3),GORATRAOPT
Else
        #---------------------------------------
        # On determine si Oracle 8 ou Oracle 8.1 ou Oracle 9
        #   CH le 22/04/2005
        #---------------------------------------
        Local Char WVERSORA(30)
        Local Char WTKPROF(8)
        Local Integer STAT : STAT=0

        Call VERS_ORA(WVERSORA,STAT)
        If STAT <> 0 : Goto SUITE_ARRET : Endif
        If WVERSORA="8.0"
         If WTKPROF=""   : WTKPROF  = "tkprof80"  : Endif
        Else
         If WTKPROF=""   : WTKPROF  = "tkprof"  : Endif
        Endif
    Wrseq ORAHOME+"\bin\"+WTKPROF,GORATRA,GORATRA+"tra","EXPLAIN="+PARAMORA(2)+"/"+PARAMORA(3),GORATRAOPT

Endif

Openo
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM

If OS(1)="unix"
    TKPROF= "."-CMDFIC
Else
    TKPROF= CMDFIC
Endif
System COMMANDE = MACBID+'@'+TKPROF

System COMMANDE = MACBID+'@ae_rm'-'"'+CMDFIC+'"'

#############################################################
## Lecture de la trace du tkprof pour alimenter fichier GTRACE
#############################################################
$READ_TRA
If OS="unix"
    IRS = chr$(10)
Else
    IRS = chr$(13)+chr$(10)
Endif

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = IRS : adxium = GASCII
If GORATRAMAC<>""
    FICTRA=GORATRAMAC+"@"
Else
    FICTRA=adxmac(-1)+"@"
Endif
FICTRA+=GORATRA
FICTRA+="tra"
If filinfo(FICTRA,0)>0
   Openi FICTRA
   Rdseq LIGNE
   While fstat=0
      Call ECR_TRACE("|"+LIGNE,0) From GESECRAN
      Rdseq LIGNE
   Wend
   Openi
   System COMMANDE = MACBID+'@ae_rm'-'"'+GORATRA+"tra"+'"'
Endif
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM

$SUITE_ARRET
If dim(GSTAOR1)>0
 Disable GSTAOR2
 Enable  GSTAOR1
Endif

Call LEC_TRACE From LECFIC

GORATRA = ""
If dim(GFICDEC_ORA) > 0
    Kill GFICDEC_ORA
Endif
End

###################################################################################################
# Algorithme de traitements des options de traces ORACLE
# on affecte GORATRAOPT
###################################################################################################
Subprog TRAIT_OPT(ERR)
Variable Integer ERR

GORATRAOPT = ""
If [M:ORA0]TRI <> 1
    GORATRAOPT += "SORT="
Endif
If [M:ORA0]TRI= 2
    GORATRAOPT += "PRSELA,EXEELA,FCHELA"
Elsif [M:ORA0]TRI= 3
    GORATRAOPT += "PRSQRY,EXEQRY,FCHQRY,PRSCPU,EXECPU,FCHCPU"
Elsif [M:ORA0]TRI= 4
    GORATRAOPT += "PRSCPU,EXECPU,FCHCPU"
Elsif [M:ORA0]TRI= 5
    GORATRAOPT += "PRSDSK,EXEDSK,FCHDSK"
Elsif [M:ORA0]TRI= 6
    If [M:ORA2]PRSCNT = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "PRSCNT" : Endif
    If [M:ORA2]PRSCPU = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "PRSCPU" : Endif
    If [M:ORA2]PRSELA = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "PRSELA" : Endif
    If [M:ORA2]PRSDSK = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "PRSDSK" : Endif
    If [M:ORA2]PRSQRY = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "PRSQRY" : Endif
    If [M:ORA2]PRSCU  = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "PRSCU"  : Endif
    If [M:ORA2]PRSMIS = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "PRSMIS" : Endif
    If [M:ORA2]EXECNT = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "EXECNT" : Endif
    If [M:ORA2]EXECPU = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "EXECPU" : Endif
    If [M:ORA2]EXEELA = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "EXEELA" : Endif
    If [M:ORA2]EXEDSK = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "EXEDSK" : Endif
    If [M:ORA2]EXEQRY = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "EXEQRY" : Endif
    If [M:ORA2]EXECU  = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "EXECU"  : Endif
    If [M:ORA2]EXEROW = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "EXEROW" : Endif
    If [M:ORA2]EXEMIS = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "EXEMIS" : Endif
    If [M:ORA2]FCHCNT = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "FCHCNT" : Endif
    If [M:ORA2]FCHCPU = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "FCHCPU" : Endif
    If [M:ORA2]FCHELA = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "FCHELA" : Endif
    If [M:ORA2]FCHDSK = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "FCHDSK" : Endif
    If [M:ORA2]FCHQRY = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "FCHQRY" : Endif
    If [M:ORA2]FCHCU  = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "FCHCU"  : Endif
    If [M:ORA2]FCHROW = 2 : If len(GORATRAOPT)>6 : GORATRAOPT +="," : Endif : GORATRAOPT += "FCHROW" : Endif
Endif

## Nombre d'ordres présentés
If [M:ORA0]PRES = 2
    GORATRAOPT -= "PRINT="+num$([M:ORA0]NBPRES)
Endif

If [M:ORA0]AGGREG = 2
    GORATRAOPT -= "AGGREGATE=yes"
Else
    GORATRAOPT -= "AGGREGATE=no"
Endif

If [M:ORA0]WAITS = 2
    GORATRAOPT -= "WAITS=yes"
Else
    GORATRAOPT -= "WAITS=no"
Endif

If [M:ORA0]SYS = 2
    GORATRAOPT -= "SYS=yes"
Else
    GORATRAOPT -= "SYS=no"
Endif
End

###################################################################################################
# Algorithme de recherche du repertoire des traces ORACLE
# verification que l'on peut y acceder
# on affecte GORATRAMAC
###################################################################################################
Subprog RECH_REP(REP_DUMPDIR,ERR)
Variable Integer ERR
Variable Char    REP_DUMPDIR

Local Char OS(20)(1..2), CODPROC(30)
Local Char REPDUMP(GDIMFIC)
Local Integer MODE_REP
Local Char WVERSORA(30)
Local Char WDIR(200)
WDIR=func AFNC.PARAMDOS(GDOSX3,"ORATRAPATH")

Call VERS_ORA(WVERSORA,ERR)
If ERR <> 0 : End : Endif

#VPO 30/12/05 prise en compte base sur machine distante
GORATRAMAC = ""
Onerrgo ERR_SQL

For (Char DDIR(200),Char MACBASE(200)) From '3' Sql
&    "Select VALUE, MACHINE from v$session,v$parameter"
&   +" Where SID=1 and name='user_dump_dest'"
&   As [BZZ]
    If WDIR<>""
     [BZZ]MACBASE=""
     [BZZ]DDIR=WDIR
    Endif
    GORATRAMAC  = [BZZ]MACBASE
    REP_DUMPDIR = [BZZ]DDIR

    # on regarde si on est sur le bon serveur, on compare avec adxmac(-1)
    If toupper(GORATRAMAC)=toupper(adxmac(-1))
       # c'est la meme machine, on annule
       GORATRAMAC = ""
    Endif
    If [BZZ]MACBASE<>""
     REPDUMP=[BZZ]MACBASE+"@"+[BZZ]DDIR
    Else
     REPDUMP=[BZZ]DDIR
    Endif
    MODE_REP = filinfo(REPDUMP,0)
    If MODE_REP < 0
       Call ERREUR(mess(188,115,1)-"("+num$(MODE_REP)+")") From GESECRAN
       #Erreur lors de l'accès au serveur de la base de données
       ERR=1
       Break
    Endif
    #cf doc de filinfo
    PFIF = 1 : PCAR = 2 : PDIR = 4 : PBLO = 6 : PFI1 = 0 : PFI2 = 8
    If int(mod(MODE_REP/(2 ^ 12), 16))<> PDIR
       Call ERREUR(mess(189,115,1)) From GESECRAN
       #Erreur d'accès au répertoire des traces de la base de données
       ERR=1
       Break
    Endif
Next
If ERR=1 : End : Endif
If REP_DUMPDIR=""
   For (Char DDIR(200),Char MACBASE(200)) From '3' Sql
&    "Select pa.VALUE, s.MACHINE from v$session s, v$parameter pa"
&   -"Where s.AUDSID=userenv('SESSIONID') and pa.name='user_dump_dest'"
&   As [BZZ]
    If WDIR<>""
     [BZZ]MACBASE=""
     [BZZ]DDIR=WDIR
    Endif
    REP_DUMPDIR = [BZZ]DDIR
   Next
Endif
Onerrgo
End

###################################################################################################
# Algorithme de recherche du fichier de trace
# Attention : le numéro de process est formatté sur 5 caractères paddés avec des zéros !!!
# on affecte GORATRA (et GFICDEC_ORA sur windows)
###################################################################################################
Subprog RECH_FIC(FICORA, ERR)
Variable Char    FICORA
Variable Integer ERR

Local Char OS(20)(1..2), CODPROC(30)
Local Char WVERSORA(30)
Local Char WDIR(200)
WDIR=func AFNC.PARAMDOS(GDOSX3,"ORATRAPATH")
# VPO 22/11/05 33156: ajout test version oracle pour construction nom de fichier
Call VERS_ORA(WVERSORA,ERR)
If ERR <> 0 : End : Endif

Call GET_OS(GORATRAMAC ,OS) From ORDSYS

Onerrgo ERR_SQL


For (Char DDIR(200),Char CPROC(20),Char BPROC(20),Char SSERV(20),Char PPROG(200)) From '3' Sql
&    "Select pa.VALUE,s.PROCESS,p.SPID,s.SERVER,p.program from v$session s,V$process p,v$parameter pa"
&   -"Where s.AUDSID=userenv('SESSIONID') and s.paddr=p.addr and pa.name='user_dump_dest'"
&   As [BZZ]
  If WDIR<>""
   [BZZ]DDIR=WDIR
  Endif
  If len([BZZ]BPROC)<=5 : # Des numéros de process > 5c, ça existe ...
   CODPROC = format$("N0:5",[BZZ]BPROC)
  Else
   CODPROC = [BZZ]BPROC
  Endif
  If OS(1)="unix"
    # VPO 22/11/05 33156 si oracle 9 nom de fichier = SID+_ora+proc+.trc
    # VPO 30/12/05 prise en compte oracle 10
    #VPO 10/07/09 56459 oracle 11
    # If WVERSORA="9" or WVERSORA="10"
    Global Char GFICDEC_ORA (255)

    If val(WVERSORA)>=9
        # VPO 24/01/07 prise en compte server SHARED
        If [BZZ]SSERV='SHARED'
            [BZZ]PPROG=vireblc([BZZ]PPROG,2)
            ORAABREV=right$([BZZ]PPROG,instr(1,[BZZ]PPROG,"(")+1)
            ORAABREV=left$(ORAABREV,instr(1,ORAABREV,")")-1)
            If ORAABREV=""
                ORAABREV="_ora_"
            Else
                ORAABREV="_"+tolower(ORAABREV)+"_"
            Endif
        Else
            ORAABREV="_ora_"
        Endif
        # La règle est la même pour HP-UX et AIX, mais j'ai laissé le test
        If OS(2)="AIX"
            FICORA=[BZZ]DDIR+"/"+tolower(getenv$("ORACLE_SID"))+ORAABREV+CODPROC+".trc"
        Else
            FICORA=[BZZ]DDIR+"/"+tolower(getenv$("ORACLE_SID"))+ORAABREV+[BZZ]BPROC+".trc"
        Endif
        If OS(2)="AIX"
            GFICDEC_ORA=[BZZ]DDIR+"/"+toupper(getenv$("ORACLE_SID"))+ORAABREV+CODPROC+".trc"
        Else
            GFICDEC_ORA=[BZZ]DDIR+"/"+toupper(getenv$("ORACLE_SID"))+ORAABREV+[BZZ]BPROC+".trc"
        Endif
    Else
        # La règle est la même pour HP-UX et AIX, mais j'ai laissé le test
        If OS(2)="AIX"
            FICORA=[BZZ]DDIR+"/ora_"+CODPROC+"_"+tolower(getenv$("ORACLE_SID"))+".trc"
        Else
            FICORA=[BZZ]DDIR+"/ora_"+[BZZ]BPROC+"_"+tolower(getenv$("ORACLE_SID"))+".trc"
        Endif
        If OS(2)="AIX"
            GFICDEC_ORA=[BZZ]DDIR+"/ora_"+CODPROC+"_"+toupper(getenv$("ORACLE_SID"))+".trc"
        Else
            GFICDEC_ORA=[BZZ]DDIR+"/ora_"+[BZZ]BPROC+"_"+toupper(getenv$("ORACLE_SID"))+".trc"
        Endif
    Endif
  Else
    #   CG le 15/01/2003
    #--- certains systemes renvoie de l'hexa et d'autres du décimal
    #--- je n'ai pas moyen de savoir dans quel cas .
    #--- donc on va d'abord traiter l'HEXA et ensuite le décimal
    #   CH le 21/04/2005
    #--- test de la version d'oracle
    #--- Vérifier le fonctionnement avec Linux
    Local Char CODPROCDEC (30)
    #Local Char WVERSORA
    Global Char GFICDEC_ORA (255)

    # VPO 22/11/05 33156: test deplacé au dessus
    #Call VERS_ORA(WVERSORA,ERR)
    #If ERR <> 0 : End : Endif

    # VPO 30/12/05 prise en compte oracle 10
    #VPO 10/07/09 56459 oracle 11
    # If WVERSORA="9" or WVERSORA="10"
    If val(WVERSORA)>=9
     CODPROCDEC = [BZZ]BPROC
    Else
     CODPROCDEC = CODPROC
    Endif
    #
    Local Char WCHAR
    If CODPROC = "00000"
        WCHAR = [BZZ]BPROC
    Else
        WCHAR = CODPROC
    Endif
    Call CONVER_HEXA(WCHAR)
    CODPROC = WCHAR
    # ficora en hexa
    # VPO 30/12/05 prise en compte oracle 10
    #VPO 10/07/09 56459 oracle 11
    # If WVERSORA="9" or WVERSORA="10"
    If val(WVERSORA)>=9
     FICORA=[BZZ]DDIR+"\"+toupper(getenv$("ORACLE_SID"))+"_ORA_"+CODPROC+".TRC"
    Else
     FICORA=[BZZ]DDIR+"\ORA"+CODPROC+".TRC"
    Endif
    # ficora en decimal
    # VPO 30/12/05 prise en compte oracle 10
    #VPO 10/07/09 56459 oracle 11
    # If WVERSORA="9" or WVERSORA="10"
    If val(WVERSORA)>=9
     GFICDEC_ORA =[BZZ]DDIR+"\"+toupper(getenv$("ORACLE_SID"))+"_ORA_"+CODPROCDEC+".TRC"
    Else
     GFICDEC_ORA =[BZZ]DDIR+"\ORA"+CODPROCDEC+".TRC"
    Endif
  Endif
  Break
Next
Onerrgo
End

$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
If errn=75
    GMESSAGE += "\"+mess(111,115,1)-mess(112,115,1)
    # Les vues oracles v$session, v$process, v$parameter ne sont pas accessibles à user_ADONIX
Endif
Call ERREUR(GMESSAGE) From GESECRAN
End

