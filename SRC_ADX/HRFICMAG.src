  Filter [F:BPAD] Where [F:BPAD]BPATYP=3 & [F:BPAD]BPANUM=[F:HRFRM]FCYFRM  & [F:BPAD]BPAADDFLG=2
#  Filter [F:BPAD] Where [F:BPAD]BPATYP=3 & [F:BPAD]BPANUM=[F:FRM]FCYFRM  & [F:BPAD]BPAADDFLG=2
