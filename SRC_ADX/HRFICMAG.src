# Used to replace the forbidden characters by empty
Funprog REPLCAR(STRCAR)
Value Char STRCAR
Local Char MODEL(250), STRCAR1(250)
MODEL='!"#$%&*;<>=@[]\_^`{}|~§µ°£¤'
STRCAR1 = ctrans(STRCAR,MODEL,"")
STRCAR1 = ctrans(STRCAR1)
End STRCAR1

