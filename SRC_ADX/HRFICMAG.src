[V]GPOINT ="UPDCURBAN" : Gosub ENTREE From EXEFNC :#95388

#87897: FORMAT Variable
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
If [F:HRTFB]FMT=2
#If [F:TFB]FMT=2
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
 Gosub ENREGVAR
 Return
Else
#
#Pour gestion des retours chariot
Local Integer S_ORDNUM, CARRET
S_ORDNUM=-1 : CARRET=1
#
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
For [HRTFB]TFB0(4) Where COD=CODE & BAN=BANCUR & RECTYP=TYP
 CONDOK=1
 If [F:HRTFB]FORCND<>""
   CONDOK = evalue([F:HRTFB]FORCND)
 Endif
 If CONDOK
  If TYP=2 : NUMREC+=1 : Endif
  For [HRTFB]TFB0

   #Ajout retour chariot à la fin de la ligne
   If [F:HRTFB]COD='VIRSEPA' and S_ORDNUM<>[F:HRTFB]ORDNUM Then
     If S_ORDNUM>=0 Then
       CARRET=2
       RESULT = chr$(10)
       Wrseq RESULT Using [FIC] :#93917
     Endif
     S_ORDNUM=[F:HRTFB]ORDNUM
   Endif
   #

   RESULT = ""
   If [F:HRTFB]FRM<>""
    Onerrgo ERREUR
    ER = 0
    Case [F:HRTFB]FLDTYP
     When 3,4,5,6,7 : # Dates pour l'avoir sous forme AAAAMMJJ
      RESULT = evalue([F:HRTFB]FRM)
      If RESULT="000000" : RESULT="00000000" : Endif
     When Default
      RESULT = num$(evalue([F:HRTFB]FRM))
    Endcase
    Onerrgo
   Endif
   # FQ87356 - MABON 18/01/13 - Si montant avec moins de chiffres après la virgule que le nombre de décimales requis, le montant
   # tracé dans le fichier n'est pas formaté avec les '0' pour les décimales manquantes
   If [F:HRTFB]FRM="[F:STL]AMT" Then
    Call LECTURE("TCU",[F:HRFRM]CUR,"") From CONTOBJ
    DECA = [F:TCU]DECNBR
    If int(val(RESULT))<>val(RESULT) Then : # Si nombre avec décimales
      NBDEC=len(right$(num$(val(RESULT)-int(val(RESULT))),3)) : # Nombre de décimales après la virgule
    Else
      If instr(1,RESULT,".")<=0 Then RESULT += "." : Endif
      NBDEC=0
    Endif
    While NBDEC<DECA
      RESULT += "0"
      NBDEC  += 1
    Wend
   Endif
   # Fin MABON
   LONG = [F:HRTFB]LNG
   Case [F:HRTFB]FLDTYP
    When 1 : # Chaîne cadrée à gauche
     RESULT = toupper(ctrans(left$(RESULT+space$(LONG),LONG)))
    When 2 : # Numérique cadré à gauche
     RESULT = right$(string$(LONG,"0")+RESULT,len(RESULT)+1)
    When 3 : # Date JJMMAA
     RESULT = mid$(RESULT,7,2)+mid$(RESULT,5,2)+mid$(RESULT,3,2)
    When 4 : # Date AAMMJJ
     RESULT = right$(RESULT,3)
    When 5 : # Année
     Case LONG
      When 1 : RESULT = mid$(RESULT,4,1)
      When 2 : RESULT = mid$(RESULT,3,2)
      When 4 : RESULT = mid$(RESULT,1,4)
     Endcase
    When 6 : # Mois
     RESULT = mid$(RESULT,5,2)
    When 7 : # Jour
     RESULT = mid$(RESULT,7,2)
    When 8 : # Séquence spéciale (binaire)
    When 9 : # Montant centimes
     RESULT = num$(arr(DECIM*val(RESULT),1))
     RESULT = right$(string$(LONG,"0")+RESULT,len(RESULT)+1)
   Endcase
   RESULT = left$(RESULT+space$(LONG),LONG)
   [V]GPOINT ="UPDRESVIR" : Gosub ENTREE From EXEFNC :#95911
   Wrseq RESULT; Using [FIC] :#93917
  Next
 Endif   # CONDOK
Next
#For [TFB]TFB0(4) Where COD=CODE & BAN=BANCUR & RECTYP=TYP
# CONDOK=1
# If [F:TFB]FORCND<>""
#   CONDOK = evalue([F:TFB]FORCND)
# Endif
# If CONDOK
#  If TYP=2 : NUMREC+=1 : Endif
