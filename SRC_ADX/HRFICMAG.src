 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
Else
 Actzo CPY,ALLFCY
 If [M]ALLFCY=2
  Effzo FCY : Grizo FCY
 Else
  Actzo FCY
 Endif
Endif
If [M]ALLBAN=2
 Effzo BAN : Grizo BAN
Else
 Actzo BAN
Endif

End

