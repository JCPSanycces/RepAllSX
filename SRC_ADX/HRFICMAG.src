#MIPEA - JIRA X3-11520 - 07/03/2017 - END
 DECIM = 10^[F:TCU]DECNBR
 AMTCUR = [F:STL]AMT
 TOTCUR += AMTCUR
 TOTVIR =  arr(DECIM*TOTCUR,1) :#104342
 Read [TCY]TCY0 = [F:CPY]CRY : If fstat : Raz [F:TCY] : Endif
 Filter [RIB] Where REFNUM=[F:STL]REFNUM and MODSTL='SCT' :# 94008 - A quoi ça sert ?
 Read [F:RIB] First
 If rowcount([F:RIB])=0 Then
  Raz [RIB]
 Else
  Read [F:RIB] First
 Endif
 #Lecture table pour enregistrement
 Read [ID]ID0=[F:STL]REFNUM
 If fstat : Raz [F:ID] : Endif

 #94425
