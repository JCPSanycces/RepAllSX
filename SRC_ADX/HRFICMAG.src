 #MIPEA - JIRA X3-11520 - 07/03/2017 - END
 Read [F:BPAD] First
 Filter [F:BPAD]
 #

  TYP = 2 : Gosub ENREG
  Filter [F:RIB]
Next

# Fin
Call LECTURE("TCU",DEVBAN,"") From CONTOBJ
DECIM = 10^[F:TCU]DECNBR
NUMREC += 1
TYP = 3
Gosub ENREG

