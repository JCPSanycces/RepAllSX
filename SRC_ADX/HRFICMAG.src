#<AdxTL>@(#)0.0.0.0 $Revision$
Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION

#DIRAS - JIRA X3-11520 - 09/02/2017 - START
#If GFONCTION<>"FICMAG"
# GFONCTION="FICMAG" : Call AUTORIS From EXEFNC
#Endif
#GACTION = "FICMAG"
#Call TRAITE_CHAR(VALBOUT,PARBOUT,"","FICMAG","DFICMAG",3,"") From GTRAITE
#If OFONCTION<>GFONCTION
# GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
#Endif

If GFONCTION<>"HRFICMAG"
 GFONCTION="HRFICMAG" : Call AUTORIS From EXEFNC
Endif
GACTION = "HRFICMAG"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","HRFICMAG","DHRFICMAG",3,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
#DIRAS - JIRA X3-11520 - 09/02/2017 - END
End

###################################################################################
## Action FICMAG1 : Virement magnétique pour le bordereau en cours
## Action FICMAG  : Virement magnétique pour une borne de bordereaux


$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "INIT_DIA"  : Gosub INIT_DIA
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
 When "TERMINE"   : Gosub TERMINE
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "SORTIE"    : Gosub SORTIE
Endcase
Return


$INIT

#DIRAS - JIRA X3-11520 - 09/02/2017 - START
Case GACTION
 When "HRFICMAG1"
 #When "FICMAG1"
 #DIRAS - JIRA X3-11520 - 09/02/2017 - End
  Onerrgo ERREUR From CONTROLE
  If clalev([F:BAN])=0 : Local File BANK      [BAN] : Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
  If clalev([F:HRFRM])=0 : Local File HRFRMPAY    [HRFRM] : Endif
  If clalev([F:HRTFB])=0 : Local File HRTABFILBAN [HRTFB] : Endif
#  If clalev([F:FRM])=0 : Local File FRMPAY    [FRM] : Endif
#  If clalev([F:TFB])=0 : Local File TABFILBAN [TFB] : Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
  If clalev([F:ADI])=0 : Local File ATABDIV   [ADI] : Endif
  If clalev([F:STL])=0 : Local File STLPAY    [STL] : Endif :#95036
  Onerrgo
  If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

  Local Char    DIR_FICBAN(GDIMFIC)
  Local Char    MACHIN(GDIMFIC)      :#78250         : # Machine
  Local Char    IRS(2)                               : # Séparateur
  Local Char    OS(20), CODE(10)
  Local Char    L_NOM(20), NOM(20)                   : # Nom fichier à générer
  Local Integer L_NUM                                : # No extension fichier à générer
  Local Char    L_EXT(5), EXT(5)                     : # Extension fichier à générer
  Local Integer I, J

  Call SETPARAM(DIR_FICBAN,MACHIN,IRS,OS,I) From PARFICBAN
  If I
   If OS="unix"
    DIR_FICBAN += "/"+GDIRBQE
   Else
    DIR_FICBAN += "\"+GDIRBQE
   Endif
   If MACHIN<>""
    DIR_FICBAN = MACHIN+"@"+DIR_FICBAN
   Endif
  Else
   DIR_FICBAN = filpath(GDIRBQE,"","",0)
   Call MACHINE(DIR_FICBAN,MACHIN,DIR_FICBAN) From ORDSYS
   Call GET_OS(MACHIN,OS) From ORDSYS
  Endif

  #87897 & #98590
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
  Read [HRFRM]FRM0 = PARAM(1)
#  Read [FRM]FRM0 = PARAM(1)
#MIPEA - JIRA X3-11520 - 07/03/2017 - END

  #MAPAD - BANK SIMULATION
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
   If PARAM(2) = "R"
      If fstat | [F:HRFRM]STA<>3 : FIN=1 : Return : Endif
   Else
      If fstat | [F:HRFRM]STA=3  : FIN=1 : Return : Endif
   Endif
#   If PARAM(2) = "R"
#      If fstat | [F:FRM]STA<>3 : FIN=1 : Return : Endif
#   Else
#      If fstat | [F:FRM]STA=3 : FIN=1 : Return : Endif
#   Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
  #MAPAD - BANK SIMULATION

  #If fstat | [F:FRM]STA<>3 : FIN=1 : Return : Endif

#MIPEA - JIRA X3-11520 - 07/03/2017 - START
  If [F:HRFRM]TFBFIL<>""
   I = instr(1,[F:HRFRM]TFBFIL,".")
   Call LECTURE("BAN",[F:HRFRM]BAN,"") From CONTOBJ
   L_EXT = [F:BAN]FILEXT
   If L_EXT="" : L_EXT = left$([F:BAN]BAN,3) : Endif
   #J = len([F:FRM]BAN)
   J = len(L_EXT)
   If I
    If I<7
     L_NUM=val(mid$([F:HRFRM]TFBFIL,I-3,3))
    Else
     L_NUM=val(mid$([F:HRFRM]TFBFIL,I-J-3,3))
    Endif
   Endif
  Endif
#  If [F:FRM]TFBFIL<>""
#   I = instr(1,[F:FRM]TFBFIL,".")
#   Call LECTURE("BAN",[F:FRM]BAN,"") From CONTOBJ
#   L_EXT = [F:BAN]FILEXT
#   If L_EXT="" : L_EXT = left$([F:BAN]BAN,3) : Endif
#   #J = len([F:FRM]BAN)
#   J = len(L_EXT)
#   If I
#    If I<7
#     L_NUM=val(mid$([F:FRM]TFBFIL,I-3,3))
#    Else
#     L_NUM=val(mid$([F:FRM]TFBFIL,I-J-3,3))
#    Endif
#   Endif
#  Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END

#MIPEA - JIRA X3-11520 - 07/03/2017 - START
  Call LECTURE("ADI",[F:HRFRM]MODPAY,"10387") From CONTOBJ
#  Call LECTURE("ADI",[F:FRM]MODPAY,"387") From CONTOBJ
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
  If [F:ADI]A2="" : FIN=1 : Return : Endif : # Ce n'est pas un virement
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
  Read [HRTFB]TFB0(3) = toupper([F:ADI]A2);[F:HRFRM]BAN;1 :#94008
#  Read [TFB]TFB0(3) = toupper([F:ADI]A2);[F:FRM]BAN;1 :#94008
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
  If fstat
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
   Read [HRTFB]TFB0(3) = toupper([F:ADI]A2);"";1 :#94008
   If fstat : Raz [F:HRTFB] : Endif
#   Read [TFB]TFB0(3) = toupper([F:ADI]A2);"";1 :#94008
#   If fstat : Raz [F:TFB] : Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
  Endif

#98590
#  Call LECTURE("BAN",[F:FRM]BAN,"") From CONTOBJ
#  L_EXT = [F:BAN]FILEXT
#  If L_EXT="" : L_EXT = left$([F:BAN]BAN,3) : Endif

  If L_NUM=0
   L_NUM = [C]NUMFIL+1
  Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
  L_NOM = [F:HRTFB]FILREF
  If L_NOM="" : L_NOM = left$([F:HRTFB]COD,2) : Endif
#  L_NOM = [F:TFB]FILREF
#  If L_NOM="" : L_NOM = left$([F:TFB]COD,2) : Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
  L_NOM += format$("N0:3#",L_NUM)

  Raz [L]NOM, [L]EXT
  # Point d'entrée personnalisation nom du fichier
  GPOINT = "NOMFIC" : Gosub ENTREE From EXEFNC
  If [L]NOM<>"" : L_NOM=[L]NOM : Endif
  If [L]EXT<>"" : L_EXT=[L]EXT : Endif

  If clalev([M:DIA])>0 :  DIR_FICBAN=[M:DIA]FILNAM :  Endif

#87897
#  If L_NOM<>""
#   If OS="unix"
#    DIR_FICBAN += "/"+L_NOM+"."+L_EXT
#   Else
#    DIR_FICBAN += "\"+L_NOM+"."+L_EXT
#   Endif
#  Endif


Raz CODE
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
If [F:HRFRM]MODPAY="SCT"
  CODE=toupper(func AFNC.PARAM("FMTBAN", [F:HRFRM]FCYFRM)) :#94008
Endif
If CODE=""
  Call LECTURE("ADI", [F:HRFRM]MODPAY, "10387") From CONTOBJ
  CODE=toupper([F:ADI]A2) :#94008
Endif
#If [F:FRM]MODPAY="SCT"
#  CODE=toupper(func AFNC.PARAM("FMTBAN", [F:FRM]FCYFRM)) :#94008
#Endif
#If CODE=""
#  Call LECTURE("ADI", [F:FRM]MODPAY, "387") From CONTOBJ
#  CODE=toupper([F:ADI]A2) :#94008
#Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END

#MIPEA - JIRA X3-11520 - 07/03/2017 - START
If CODE="":STA=2: Goto FINFIC: Endif # Ce n'est pas un virement
Read [HRTFB]TFB0(1) = CODE
  If L_NOM<>""
   If OS="unix"
     DIR_FICBAN += "/"
   Else
     DIR_FICBAN += "\"
   Endif
   If [F:HRTFB]FMT=2
     If [F:HRTFB]FILEXT<>""
      DIR_FICBAN += L_NOM+L_EXT+"."+[F:HRTFB]FILEXT
     Endif
   Else
    DIR_FICBAN += L_NOM+"."+L_EXT
   Endif
  Endif
#If CODE="":STA=2: Goto FINFIC: Endif # Ce n'est pas un virement
#Read [TFB]TFB0(1) = CODE
#  If L_NOM<>""
#   If OS="unix"
#     DIR_FICBAN += "/"
#   Else
#     DIR_FICBAN += "\"
#   Endif
#   If [F:TFB]FMT=2
#     If [F:TFB]FILEXT<>""
#      DIR_FICBAN += L_NOM+L_EXT+"."+[F:TFB]FILEXT
#     Endif
#   Else
#    DIR_FICBAN += L_NOM+"."+L_EXT
#   Endif
#  Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
 #

  # Confirmation ?
  GMESSAGE = ""
  OK = 2
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
  If [F:HRFRM]TFBFIL<>""      : GMESSAGE -= [F:HRFRM]TFBFIL : Endif
  If [F:HRFRM]TFBDAT<>[0/0/0] : GMESSAGE -= format$(GFMDAT,[F:HRFRM]TFBDAT) : Endif
#  If [F:FRM]TFBFIL<>""      : GMESSAGE -= [F:FRM]TFBFIL : Endif
#  If [F:FRM]TFBDAT<>[0/0/0] : GMESSAGE -= format$(GFMDAT,[F:FRM]TFBDAT) : Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
  If GMESSAGE<>"" : OK = 1 : GMESSAGE = " :"+GMESSAGE : Endif
  If OK=1
   TIT=mess(69,121,1)+GMESSAGE+"\"+mess(68,141,1)-"|"+DIR_FICBAN+"|\"+mess(36,100,1)
   # Fichier déjà émis xxx Génération du fichier zzzz Confirmation ?
  Elsif OK=2
   TIT=mess(68,141,1)-"|"+DIR_FICBAN+"|\"+mess(36,100,1)
   # Génération du fichier zzzz Confirmation ?
  Endif

#DIRAS - JIRA X3-11520 - 09/02/2017 - START
#When "FICMAG"
 When "HRFICMAG"
#DIRAS - JIRA X3-11520 - 09/02/2017 - END
  Onerrgo CHUT From CONTROLE
  If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
  If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
  If !clalev([F:HRFRM])  : Local File HRFRMPAY     [HRFRM]  : Endif
#  If !clalev([F:FRM])  : Local File FRMPAY     [FRM]  : Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
  If !clalev([F:BAN])  : Local File BANK       [BAN]  : Endif
  If !clalev([F:ADI])  : Local File ATABDIV    [ADI]  : Endif
  If !clalev([F:STL])  : Local File STLPAY     [STL]  : Endif :#95036
  Onerrgo
  If GERREUR : GERREUR=0 : Endif

Endcase

#DIRAS - JIRA X3-11520 - 09/02/2017 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#DIRAS - JIRA X3-11520 - 09/02/2017 - END

Return

#Choix poste client
$INIT_DIA
#DIRAS - JIRA X3-11520 - 09/02/2017 - START
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
Case GACTION
 When "HRFICMAG1"
 #When "FICMAG1"
#DIRAS - JIRA X3-11520 - 09/02/2017 - END
  Read [HRFRM]FRM0 = PARAM(1)
  If !fstat & clalev([M:DIA])>0 Then
    [M:DIA]ALLCPY=1 : [M:DIA]CPY=[F:HRFRM]CPY
    [M:DIA]ALLFCY=1 : [M:DIA]FCY=[F:HRFRM]FCYFRM
    [M:DIA]ALLBAN=1 : [M:DIA]BAN=[F:HRFRM]BAN
    [M:DIA]VCRSTR=[F:HRFRM]NUMFRM : [M:DIA]VCREND=[F:HRFRM]NUMFRM
  Endif
Endcase
#Case GACTION
# When "HRFICMAG1"
# #When "FICMAG1"
##DIRAS - JIRA X3-11520 - 09/02/2017 - END
#  Read [FRM]FRM0 = PARAM(1)
#  If !fstat & clalev([M:DIA])>0 Then
#    [M:DIA]ALLCPY=1 : [M:DIA]CPY=[F:FRM]CPY
#    [M:DIA]ALLFCY=1 : [M:DIA]FCY=[F:FRM]FCYFRM
#    [M:DIA]ALLBAN=1 : [M:DIA]BAN=[F:FRM]BAN
#    [M:DIA]VCRSTR=[F:FRM]NUMFRM : [M:DIA]VCREND=[F:FRM]NUMFRM
#  Endif
#Endcase
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
Return


$CONTROLE
#DIRAS - JIRA X3-11520 - 09/02/2017 - START
Case GACTION
 When "HRFICMAG"
 #When "FICMAG"
#DIRAS - JIRA X3-11520 - 09/02/2017 - END
  If GSERVEUR : [M:DIA]TRCFLG=2 : Endif
  TMP=1 : TIT="V"
Endcase
Return


$EXEC
Local Integer STA
Local Char    MESSA(250)

#DIRAS - JIRA X3-11520 - 09/02/2017 - START
Case GACTION
 When "HRFICMAG"
 #When "FICMAG"
#DIRAS - JIRA X3-11520 - 09/02/2017 - END
  Local Integer OK, NBREM
  Local Char    CRITERE(250), CRITERE_SUP(250)  :#112775
  If !GSERVEUR & [M:DIA]TRCFLG=2
   Call TITAWI(BCRIT,CRITERE) From OBJDIV
   Call OUVRE_TRACE(CRITERE) From LECFIC
  Endif

  CRITERE = "STA=3"
  If [M:DIA]VCRFLG<>2
   CRITERE -= " & TFBFIL=''"
  Endif
  If [M:DIA]ALLCPY<>2
   CRITERE -= '& CPY="'+[M:DIA]CPY+'"'
  Endif
  If [M:DIA]ALLFCY<>2
   CRITERE -= '& FCYFRM="'+[M:DIA]FCY+'"'
  Endif
  If [M:DIA]ALLBAN<>2
   CRITERE -= '& BAN="'+[M:DIA]BAN+'"'
  Endif
  If [M:DIA]VCRSTR=[M:DIA]VCREND & [M:DIA]VCRSTR<>""
   CRITERE -= '& NUMFRM="'+[M:DIA]VCRSTR+'"'
  Else
   If [M:DIA]VCRSTR<>""
    CRITERE -= '& NUMFRM>="'+[M:DIA]VCRSTR+'"'
   Endif
   If [M:DIA]VCREND<>""
    CRITERE -= '& NUMFRM<="'+[M:DIA]VCREND+'"'
   Endif
  Endif

  OK = 0
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
  Filter [ADI] Where NUMTAB=10387 & A2<>""
#  Filter [ADI] Where NUMTAB=387 & A2<>""
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
  For [ADI]
   If OK=0
    CRITERE -= '& (MODPAY="'+[F:ADI]CODE+'"'
    OK = 1
   Else
    CRITERE -= '| MODPAY="'+[F:ADI]CODE+'"'
   Endif
  Next
  Filter [ADI]
  If OK : CRITERE -=')' : Endif

  CRITERE_SUP="1=1" :#112775

  GPOINT = "CRIFICMAG" : Gosub ENTREE From EXEFNC :#112775
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
  Filter [HRFRM] Where evalue([L]CRITERE) & evalue ([L]CRITERE_SUP) :#112775
  Gosub PARCOURS
  Filter [HRFRM]
#  Filter [FRM] Where evalue([L]CRITERE) & evalue ([L]CRITERE_SUP) :#112775
#  Gosub PARCOURS
#  Filter [FRM]
#MIPEA - JIRA X3-11520 - 07/03/2017 - END

  If !GSERVEUR & [M:DIA]TRCFLG=2
   Call FERME_TRACE From LECFIC
   TRA=1
  Endif

#DIRAS - JIRA X3-11520 - 09/02/2017 - START
 When "HRFICMAG1"
 #When "FICMAG1"
#DIRAS - JIRA X3-11520 - 09/02/2017 - END
  Call FICHIER(PARAM(1),STA,MESSA)
  If !STA
   # Fichier banque
   GERR=2 : GMESSAGE=mess(101,117,1)-MESSA
  Else
   GERR=1 : GMESSAGE=MESSA
  Endif
Endcase
Return


$TERMINE
#DIRAS - JIRA X3-11520 - 09/02/2017 - START
Case GACTION
 When "HRFICMAG"
 #When "FICMAG"
#DIRAS - JIRA X3-11520 - 09/02/2017 - END
  If GSERVEUR : Return : Endif
  If !NBREM
   GERR=2 : GMESSAGE=mess(129,117,1)             : # Aucun bordereau traité
  Elsif [M:DIA]TRCFLG<>2
   GERR=2 : GMESSAGE=num$(NBREM)-mess(130,117,1) : # NBREM bordereau(x) traité(s)
  Endif
Endcase
Return


$PARCOURS
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
For [HRFRM]FRM0
#For [FRM]FRM0
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
 NBREM += 1
 STA=0
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
 Call FICHIER([F:HRFRM]NUMFRM,STA,MESSA)
# Call FICHIER([F:FRM]NUMFRM,STA,MESSA)
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
 If [M:DIA]TRCFLG=2
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
  If STA=0
   Call ECR_TRACE(mess(126,117,1)-[F:HRFRM]NUMFRM-":"-mess(101,117,1)-MESSA,0) From GESECRAN
   # Bordereau de remise...Fichier banque
  #89865
  Elsif STA=7
   Call ECR_TRACE(mess(126,117,1)-[F:HRFRM]NUMFRM-":"-mess(101,117,1),0) From GESECRAN
   Call ECR_TRACE(MESSA,-1) From GESECRAN #Copie non réalisée
  #
  #95036
  Elsif STA=8 | STA=9
   Call ECR_TRACE(MESSA,1) From GESECRAN
   Call ECR_TRACE(mess(249,117,1),1) From GESECRAN #Fichier non généré
  #
  Else
   Call ECR_TRACE(mess(100,117,1)-[F:HRFRM]NUMFRM-":"-MESSA,1) From GESECRAN
  Endif
#  If STA=0
#   Call ECR_TRACE(mess(126,117,1)-[F:FRM]NUMFRM-":"-mess(101,117,1)-MESSA,0) From GESECRAN
#   # Bordereau de remise...Fichier banque
#  #89865
#  Elsif STA=7
#   Call ECR_TRACE(mess(126,117,1)-[F:FRM]NUMFRM-":"-mess(101,117,1),0) From GESECRAN
#   Call ECR_TRACE(MESSA,-1) From GESECRAN #Copie non réalisée
#  #
#  #95036
#  Elsif STA=8 | STA=9
#   Call ECR_TRACE(MESSA,1) From GESECRAN
#   Call ECR_TRACE(mess(249,117,1),1) From GESECRAN #Fichier non généré
#  #
#  Else
#   Call ECR_TRACE(mess(100,117,1)-[F:FRM]NUMFRM-":"-MESSA,1) From GESECRAN
#  Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
 Endif
Next
Return

#DIRAS - JIRA X3-11520 - 09/02/2017 - START
$SORTIE

If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
#DIRAS - JIRA X3-11520 - 09/02/2017 - END

###############################################################################
#  Génération d'un fichier                                                    #
###############################################################################
Subprog FICHIER(NUMERO,STA,MESSA)
Value    Char    NUMERO
Variable Integer STA
Variable Char    MESSA()



Local Integer TYP , NUM , STAT, I, J
Local Integer SAVIUM    :#87249
Local Char    CODE(10) , BANQUE(5) , BANCUR(5) , DEVBAN(3), SITE(10)
Local Char    FICHIER(250) , NOM(20) , EXT(5)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Char    RESULT(250) , SYMBOLE(40)
Local Char    FLEURO(1)
Local Decimal AMTCUR, TOTCUR, TOTVIR :#104342
Local Integer NUMREC , DECIM
Local Date    DATJ
Local Char    NOMTIRE(50)
#87897
Local Integer NBPYH                # Number of payment include in one file SEPA
Local Integer CONDOK
Local Integer NBLIG
Local Char    MSGID(35)
Local Integer OKTCA
Local Integer NBLIG2
Local Char    CODLAN(GLONLAN)
#
## JML 26/04/00 Laisser la possibilité d'aller sur le client
Local Char    DIR_FICBAN(GDIMFIC)
Local Char    MACHIN(GDIMFIC)      :#78250         : # Machine
Local Char    IRS(2)                               : # Séparateur
Local Char    OS(20)
Local Integer OK
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
Local File HRFRMPAY [HRFRM], STLPAY[STL]
#Local File FRMPAY [FRM], STLPAY[STL]
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
If clalev([F:HRTFB]) =0 : Local File HRTABFILBAN [HRTFB] : Endif
#If clalev([F:TFB]) =0 : Local File TABFILBAN [TFB] : Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
If clalev([F:BAN]) =0 : Local File BANK      [BAN] : Endif
