  Raz AMTCUR
  Raz TOTCUR
  For [STL] Where NUMFRM=NUMERO
    NBPYH +=1
    AMTCUR = [F:STL]AMT
    TOTCUR += AMTCUR
  Next
Endif
#

Gosub ENREG

# Ligne
Raz TOTCUR
Raz AMTCUR : #87897
For [STL] Where NUMFRM=NUMERO
 NOMTIRE = [F:STL]BNF
 If NOMTIRE=""
  Call LECTURE("EML",[F:STL]REFNUM,"") From CONTOBJ
  NOMTIRE = [F:ID]NAM-[F:ID]SRN
 Endif
