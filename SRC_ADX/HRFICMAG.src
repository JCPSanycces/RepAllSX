#   #Ajout retour chariot à la fin de la ligne
#   If [F:TFB]COD='VIRSEPA' and S_ORDNUM<>[F:TFB]ORDNUM Then
#     If S_ORDNUM>=0 Then
#       CARRET=2
#       RESULT = chr$(10)
#       Wrseq RESULT Using [FIC] :#93917
#     Endif
#     S_ORDNUM=[F:TFB]ORDNUM
#   Endif
#   #
#
#   RESULT = ""
#   If [F:TFB]FRM<>""
