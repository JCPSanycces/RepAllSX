Subprog SET_NOMFIC(NOMFIL,TYPEXP)
Variable Char NOMFIL
Value Integer TYPEXP
Local Char    FICSRV(GDIMFIC) , URL(GDIMFIC), FICHIER
Local Char    REPERT(GDIMFIC) , MACHINE(GDIMFIC)
Local Char    DIR_FICBAN(GDIMFIC)
Local Char    MACHIN(GDIMFIC)      :#78250         : # Machine
Local Char    IRS(2)                               : # Séparateur
Local Integer I
Local Char    OS(20)
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
If clalev([F:HRTFB])=0 : Local File HRTABFILBAN [HRTFB] : Endif
#If clalev([F:TFB])=0 : Local File TABFILBAN [TFB] : Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
If TYPEXP<>2
 Raz NOMFIL
 Call SET_NAMCLI(NOMFIL) From ORDSYS
Else
 Call SETPARAM(DIR_FICBAN,MACHIN,IRS,OS,I) From PARFICBAN
 If I Then
  If OS="unix"
    DIR_FICBAN += "/"+GDIRBQE
  Else
    DIR_FICBAN += "\"+GDIRBQE
  Endif
  If MACHIN<>""
   DIR_FICBAN = MACHIN+"@"+DIR_FICBAN
  Endif
 Else
  DIR_FICBAN = filpath(GDIRBQE,"","",0)
  Call MACHINE(DIR_FICBAN,MACHIN,DIR_FICBAN) From ORDSYS
  Call GET_OS(MACHIN,OS) From ORDSYS
 Endif
 NOMFIL=DIR_FICBAN
Endif
End

# MABON - FQ65412 - 18/08/10 - Fonction utilisée dans le fichier bancaire
# VIRSEPA de n° d'ordre 1
Funprog PROLOT(SCTPROLOT)
Value Integer SCTPROLOT
Local Char    RTN

  RTN = ""
  If SCTPROLOT=2 Then
    RTN="1"
  Else
    RTN="0"
  Endif
End RTN



