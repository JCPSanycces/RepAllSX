adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM    :#87249
GPOINT = "FIN" : Gosub ENTREE From EXEFNC

Call DEBTRANS From GLOCK
Gosub TR2
If GOK<1 : STA = 5 : Endif

If clalev([M:DIA]) & [M:DIA]TYPEXP<>2
  Local Integer STAT
  Local Char    FICBAN(250)
  #87897
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
  If [F:HRTFB]FILEXT<>""
    FICBAN=[M]FILNAM+"\"+NOM+L_EXT+"."+[F:HRTFB]FILEXT
  Else
    FICBAN=[M]FILNAM+"\"+NOM+"."+L_EXT
  Endif
#  If [F:TFB]FILEXT<>""
#    FICBAN=[M]FILNAM+"\"+NOM+L_EXT+"."+[F:TFB]FILEXT
#  Else
#    FICBAN=[M]FILNAM+"\"+NOM+"."+L_EXT
#  Endif
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
  #

  Call COPCLI(DIR_FICBAN,FICBAN,STAT) From ORDSYS
  If STAT
    #89865
    #Call ERREUR(mess(12,139,1)-DIR_FICBAN-"->"-FICBAN) From GESECRAN
    STA=7
    Goto FINFIC
  Endif
  Call EFFACE(DIR_FICBAN,STAT) From ORDSYS
  DIR_FICBAN=FICBAN
Endif

$FINFIC
#94008
# Read[F:ADI]CODE=387;[F:FRM]MODPAY
# If !fstat
#   If [F:ADI]CODE<>'SCT' & [F:ADI]A2="VIRSEPAXML"
#      Call ECR_TRACE(mess(28,704,1),1) From GESECRAN
#   Endif
# Endif

Case STA
 When 0  : MESSA = "|"+DIR_FICBAN+"|"
 When 1  : MESSA = mess(102,117,1)                   : # Remise inexistante
 When 2  : MESSA = mess(103,117,1)                   : # Pas de remise à faire
 When 3  : MESSA = mess(104,117,1)-"NUMFIL"          : # Erreur sur compteur
 When 4  : MESSA = "|"+DIR_FICBAN-"|:"-mess(9,141,1) : # Répertoire inexistant
 When 5  : MESSA = mess(35,110,1)                    : # Erreur transactionnelle
 When 6  : MESSA = mess(10,100,1)                    : # Modification en cours sur un autre poste
 When 7  : MESSA = mess(12,139,1)                    : # 89865 - Copie non réalisée
 When 8  : MESSA = mess(248,117,1)                   : # 95036 - BIC société non renseigné et virement vers pays étranger
 When 9  : MESSA = mess(250,117,1)                   : # 95036 - Code BIC obligatoire
Endcase
If SYMBOLE<>""
 Unlock =SYMBOLE
Endif
End

#########################################################################
$TR1
GOK = 1
Trbegin [BAN]
 Lock NUMFIL
 If fstat
  GOK = -1 : GLOCK = "%NUMFIL" : Goto ROLL_TR1
 Endif
 [C]NUMFIL += 1
 If fstat=0 & [C]NUMFIL>=1000
  [C]NUMFIL = 1
 Endif
 If fstat=1
  GOK = -1 : GLOCK = "@NUMFIL" : Goto ROLL_TR1
 Elsif fstat
  GOK = 0 : Call RSTA("@NUMFIL","") From GLOCK : Goto AB_TR1
 Endif
 NUM = [C]NUMFIL
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

#################################################################################
$TR2
GOK = 1
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
Trbegin [HRFRM]
  Readlock [HRFRM]FRM0 =[L]NUMERO
 If fstat=1
  GOK=-1 : GLOCK="$HRFRMPAY"-"1"-[F:HRFRM]NUMFRM : Goto ROLL_TR2
 Endif
 #87897
 If [F:HRTFB]FILEXT<>""
  [F:HRFRM]TFBFIL = NOM+L_EXT+"."+[F:HRTFB]FILEXT
 Else
  [F:HRFRM]TFBFIL=[L]NOM+"."+L_EXT
 Endif
 #
 [F:HRFRM]TFBDAT=[L]DATJ
 Rewrite [HRFRM]
 If fstat
  GOK = 0 : Call FSTA("HRFRM") From GLOCK : Goto AB_TR2
 Endif
Commit
