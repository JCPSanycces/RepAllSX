########################################################################
$SEL_TABLE
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
OBJET="HRFRM"
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
SUPP="1"
CRITERE="STA=3"
If [M]FCY<>"" : CRITERE -= "& FCYFRM='"+[M]FCY+"'" : Endif
If [M]CPY<>"" : CRITERE -= "& CPY='"+[M]CPY+"'" : Endif
If [M]BAN<>"" : CRITERE -= "& BAN='"+[M]BAN+"'" : Endif
If [M]VCRFLG=1 : CRITERE -= "& TFBFIL=''" : Endif
If [M]VCRFLG=2 : CRITERE -= "& TFBFIL<>''" : Endif
OK = 0
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
Filter [ADI] Where NUMTAB=10387 & A2<>""
#Filter [ADI] Where NUMTAB=387 & A2<>""
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
For [ADI]
 If OK=0
  CRITERE -= '& (MODPAY="'+[F:ADI]CODE+'"'
  OK = 1
 Else
  CRITERE -= '| MODPAY="'+[F:ADI]CODE+'"'
 Endif
Next
Filter [ADI]
If OK : CRITERE -=')' : Endif
Return

#######################################################################
#87897
$ENREGVAR
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
For [HRTFB]TFB0(3) Where COD=CODE & BAN=BANCUR & RECTYP=TYP
 NBLIG+=1 : CONDOK=1
 If [F:HRTFB]FORCND<>""
  CONDOK = evalue([F:HRTFB]FORCND)
 Endif
#For [TFB]TFB0(3) Where COD=CODE & BAN=BANCUR & RECTYP=TYP
# NBLIG+=1 : CONDOK=1
# If [F:TFB]FORCND<>""
#  CONDOK = evalue([F:TFB]FORCND)
# Endif
 #MIPEA - JIRA X3-11520 - 07/03/2017 - START

 If CONDOK
  # Gestion du compteur nécessaire au paramétrage (to fill in MSGID)
  If TYP=1 #& [F:FRM]MODPAY="SCT"
   COUNTSEPA = ""
   Call LECTCA(2,OKTCA) From SUBTCA
   If OKTCA
    COUNTSEPA = [F:TCA]CODNUM(9) :#93966
   Endif
   If COUNTSEPA = "" : COUNTSEPA="SEPA" : Endif
   #
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
   Call LECTURE("HRFRM", NUMERO,"") From CONTOBJ
   SITE=[F:HRFRM]FCYFRM
#   Call LECTURE("FRM", NUMERO,"") From CONTOBJ
#   SITE=[F:FRM]FCYFRM
#MIPEA - JIRA X3-11520 - 07/03/2017 - END
   #
   Call NUMERO(COUNTSEPA,SITE,date$,"",[L]MSGID,STAT) From SUBANM
   If STAT
   # Problème lors de la récupération du compteur
    Gosub MESSAGE From SUBANM
    GMESSAGE = mess(60,199,1)-"("+COUNTSEPA+") : "+MESSA
    STA=14
    Break
   Endif
  Endif

   NBLIG2 = 0 # Line number in the TFB file
#MIPEA - JIRA X3-11520 - 07/03/2017 - START
   For [HRTFB]TFB0
    RESULT = ""
    NBLIG2 +=1
    # Formule
    # Take back the formule according to its type
    If [F:HRTFB]FRM<>""
     Onerrgo ERREUR
     ER = 0
     Case [F:HRTFB]FLDTYP
      When 3,4,5,6,7 : # Dates pour l'avoir sous forme AAAAMMJJ
       RESULT = evalue([F:HRTFB]FRM)
       If RESULT="000000" : RESULT="00000000" : Endif
      When Default
       RESULT = num$(evalue([F:HRTFB]FRM))
     Endcase
     Onerrgo
    Endif

    # Ajustement à la longueur variable
    LONG = [F:HRTFB]LNG
    Case [F:HRTFB]FLDTYP
      When 1 : # Chaîne cadrée à gauche
      RESULT= func REPLCAR(RESULT)
      RESULT = func AFNC.TRANS(left$(RESULT,LONG),CODLAN)
      When 2 : # Numérique (rien à faire pour le cadrage)
      When 3 : # Date JJMMAA
       RESULT = mid$(RESULT,7,2)+mid$(RESULT,5,2)+mid$(RESULT,3,2)
      When 4 : # Date AAMMJJ
       RESULT = right$(RESULT,3)
      When 5 : # Année
       Case LONG
        When 1 : RESULT = mid$(RESULT,4,1)
        When 2 : RESULT = mid$(RESULT,3,2)
        When 4 : RESULT = mid$(RESULT,1,4)
       Endcase
      When 6 : # Mois
       RESULT = mid$(RESULT,5,2)
      When 7 : # Jour
       RESULT = mid$(RESULT,7,2)
      When 8 : # Séquence spéciale (binaire)
      When 9 : # Montant centimes
       RESULT = num$(arr(DECIM*val(RESULT),1))
    Endcase

    #110759
    [V]GPE=0
    [V]GPOINT ="UPDRESULT" : Gosub ENTREE From EXEFNC :#95727
    If ![V]GPE
     # If the result of formule is empty and the field is mandatory in the TFB file corresponding on, then advice
     # the user in the file trace.
     If ([F:HRTFB]CND="" & ([F:HRTFB]FRM="" or RESULT<>"")) or [F:HRTFB]CND<>"" & evalue([F:HRTFB]CND)
      #121090
      #Wrseq [F:TFB]STRSEP + RESULT + [F:TFB]ENDSEP + chr$(10) Using [FIC] :#93917
      Wrseq [F:HRTFB]STRSEP + RESULT + [F:HRTFB]ENDSEP Using [FIC] :#93917
      #On ne veut pas ajouter systématiquement de retour à la ligne
      If [F:HRTFB]COD='VIRSEPAXML' & ([F:HRTFB]STRSEP="" | right$([F:HRTFB]STRSEP,len([F:HRTFB]STRSEP))=">" )
        Wrseq chr$(10) Using [FIC]
      Endif
      ##
     Elsif [F:HRTFB]FRM<>"" & RESULT="" & [F:HRTFB]OBY = 2
      If TYP=2  # Détail
       Call ECR_TRACE(mess(27,117,1)-[F:STL]NUMFRM-":",0) From GESECRAN
      Endif
      Call ECR_TRACE(mess(155,117,1)-[F:HRTFB]COD-mess(10,123,1)-mess(TYP,656,1)-mess(61,100,1)-num$(NBLIG2)-":"-[F:HRTFB]FRM,1) From GESECRAN
      #121090
      #Wrseq [F:TFB]STRSEP + RESULT + [F:TFB]ENDSEP + chr$(10) Using [FIC] :#93917
      Wrseq [F:HRTFB]STRSEP + RESULT + [F:HRTFB]ENDSEP Using [FIC] :#93917
      #On ne veut pas ajouter systématiquement de retour à la ligne
      If [F:HRTFB]COD='VIRSEPAXML' & ([F:HRTFB]STRSEP="" | right$([F:HRTFB]STRSEP,len([F:HRTFB]STRSEP))<>">" )
        Wrseq chr$(10) Using [FIC]
      Endif
      ##
     Endif
    Endif
   Next # For TFB0
 Endif # CONDOK
Next # For TFB0(3)
#   For [TFB]TFB0
#    RESULT = ""
#    NBLIG2 +=1
#    # Formule
#    # Take back the formule according to its type
#    If [F:TFB]FRM<>""
