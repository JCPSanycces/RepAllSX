Call OUVRE_TRACE("") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#####################################################################
#####################################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","AYTINT","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS(DOSSIER,"AYT") : End : Endif

Local Integer WX_RET
Call DIRXTUPD("", DOSSIER,  WX_RET) From AYTGESFILE
If WX_RET=1
 Call DIRXTUNIX("", DOSSIER, WX_RET) From AYTGESFILE
Endif

End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","AYTINT","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS(DOSSIER,"AYT") : End : Endif

Local Integer WX_RET
Call DIRXTUPD("", DOSSIER,  WX_RET) From AYTGESFILE
If WX_RET=1
 Call DIRXTUNIX("", DOSSIER, WX_RET) From AYTGESFILE
Endif

End

