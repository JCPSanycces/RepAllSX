#<AdxTL>@(#)4.0.0.0 $Revision$
########################################################################
# SUBADLVW : Prise en compte des élements pour livrable 
# ACTION ADLVW
# -------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par appel 
#         dasn SUBADLV en click droit sur tableau des objets
# de plus l ecran ADLVWB sert à stocker les records pris en compte uniquement
# c'est pour pouvoir jouer avec les critères  et la case à cocher WALLENA (Tous - selction- non selection)
# il est invisible et c'est à partir de cet ecran qu on charge aussi ADLV6 et ADLV6B
########################################################################

$ACTION
#---------------------------------------------------------------------#
# Actions sur de la fenêtre (GTRAITE)                          #
#---------------------------------------------------------------------#
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub AJOUT_RAZ
 When "AP_CHOIX"    : Gosub FIN_CONTROLE
 When "TERMINE"     : Gosub FERME
Endcase
Return

#######################################################################
#             Actions sur la saisie de fenêtre 
#######################################################################
$OUVRE
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
#----- variables globales -----#
Global Shortint GSAVNOLIGN : GSAVNOLIGN=nolign
Global Char GAWMTYP(1)
#-----
Return

#######################################################################
$DEBUT
#--------------------------------------------------------------#
# debut affichage fenetre                                      #
#--------------------------------------------------------------#
Raz [M:ADLVW]
[M:ADLVW]WFORMULETAB = '1=1'

#------------------------------------
# paramètre passé via action adlvw
# type 1 = nouveau modèle, 2 = ajout cle sur le modèle en cours
#------------------------------------
GAWMTYP =GBIDC1
If GAWMTYP = "2"
    [M:ADLVW]MODELE    = [M:ADLV6]TABAWM1 (GSAVNOLIGN-1)
    [M:ADLVW]TABREF    = [M:ADLV6]TABCOD1 (GSAVNOLIGN-1)
    [M:ADLVW]NULRECFLG = [M:ADLV6]NULRECFLG1 (GSAVNOLIGN-1)
    [M:ADLVW]TABADINUM = [M:ADLV6]TABADINUM1 (GSAVNOLIGN-1)
    # lecture modele
    Read [F:AWM]AWM0 = [M:ADLVW]MODELE
    If fstat <> 0
        #"prob modele n existe plus"
        GMESSAGE = mess (7,140,1)
        FIN = 1
    Elsif [F:AWM]TABREF <> [M:ADLVW]TABREF
        #"prob modele n est plus conforme"
        GMESSAGE = mess (1,7999,1)
        FIN = 1
    Else
        If [M:ADLVW]TABADINUM <> 0
            [M:ADLVW]WFORMULETAB = 'NUMTAB='+num$([M:ADLVW]TABADINUM)
        Endif
        # init des prise en compte, raz du tableau des prises en compte
        Gosub INIT_ADLVWB
        # affichage des lignes de toute la table (selectionnes ou ps)
        [M:ADLVW]WALLENA = 1
        Gosub AFF_ELEMENT
        # mise a jour flag enaflg en fct de l ecran d ou on vient
        # c'est pour init du flag enaflg.
        Gosub LOAD_ADLVW
        # chargement tableau prise en compte en fct de adlvw
        Gosub LOAD_ADLVWB
        #
        Grizo [M:ADLVW]MODELE
        Grizo [M:ADLVW]TABADINUM
        Affzo [M:ADLVW]
    Endif
Elsif GAWMTYP  <> "1"
    #'fct impossible'
    GMESSAGE = mess(127,100,1)
    FIN = 1
Endif
Return


#######################################################################
$FERME
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
nolign=GSAVNOLIGN
#-----------#
# Globales   #
#-----------#
If dim(GSAVNOLIGN)>0
    Kill GSAVNOLIGN
Endif
If dim(GAWMTYP)>0
    Kill GAWMTYP
Endif
Return

#######################################################################
$FIN_CONTROLE
If REPONSE = GSTARET
    #------------------------------------------#
    # choix bouton fin -
    #------------------------------------------#
    Local Integer WOK
    WOK = 0
    Call OUINON (mess (13,7999,1), WOK) From GESECRAN
    If WOK <> 2
        REPONSE = 0
        FIN = 0
    Endif
Endif
Return

#######################################################################
$AJOUT_RAZ
#------------------------------------------#
# choix bouton ok
#------------------------------------------#

# on calcule le nombre de ligne à ajouter

Local Integer WNBRLIG
Local Integer WIND, J

Local Integer WNBRSUP
Local Integer WDEBLIGSUP
WNBRLIG = 0
WNBRSUP = 0
WDEBLIGSUP = 0

# attention on peut avoir aucune donnée à prendre en compte sur toute la table
# on ecrira donc une ligne avec juste le code table et vide dans la clé 
# de même faire attention si table est vide a l origine et qu on fait ok.. ne rien prendre
If [M:ADLVW]TABREF <> "" and [M:ADLVW]NULRECFLG = 2
            WNBRLIG =1
Elsif [M:ADLVW]TABREF <> ""
    # on utilise le tableau adlvwb pour recuperer les lignes prises en compte en fct de diff critères.
    # attention ce tableau est peut être vide  
    # si on ne saisie jamais de critère ou si pas cocher affichage uniquement les à oui
    If [M:ADLVWB]NBRENA= 0
        For WIND = 0 To [M:ADLVW]NBR-1
            If [M:ADLVW]ENAFLG (WIND) = 2
                WNBRLIG +=1
            Endif
        Next WIND 
    Else
        # voir le cas ou si dans tableau adlvw on a aussi des prise en compte pour le dernier filtre!!!!!
        # il faut faire attention si dans dernier tableau un element a ete deselectionné
        For WIND = 0  To [M:ADLVW]NBR-1
           Local Integer WWIND
           WWIND = find ([M:ADLVW]ELEMENT(WIND),[M:ADLVWB]ELEMENT1(0..[M:ADLVWB]NBRENA-1)) 
           If WWIND <> 0
                If [M:ADLVW]ENAFLG (WIND) <> 2
                    # il faut virer cette ligne 
                    # WWIND est le numero de ligne on fait - 1 dessus pour indice ligne du tableau
                        WWIND-=1
                        If dim([M:ADLVWB]ELEMENT1)=[M:ADLVWB]NBRENA
                              Dela WWIND,1 [M:ADLVWB]NBRENA
                        Else
                              Dela WWIND,1,[M:ADLVWB]NBRENA-1 [M:ADLVWB]NBRENA
                        Endif
                        [M:ADLVWB]NBRENA-=1
                Endif
           Endif
        Next WIND
        # voir par contre si on a des lignes en plus....
        For WIND = 0 To [M:ADLVW]NBR-1
            If [M:ADLVW]ENAFLG (WIND) = 2
                   Local Integer WWIND
                   WWIND = find ([M:ADLVW]ELEMENT(WIND),[M:ADLVWB]ELEMENT1(0..[M:ADLVWB]NBRENA-1)) 
                   If WWIND = 0
                        WWIND=[M:ADLVWB]NBRENA
                        # la on en a en plus mais pas dans adlvwb
                        # il faut ajouter cette ligne 
                        If dim([M:ADLVWB]ELEMENT1)=[M:ADLVWB]NBRENA+1
                              Insa WWIND,1 [M:ADLVWB]NBRENA    : # Pas de borne sinon plantage
                        Else
                              Insa WWIND,1,[M:ADLVWB]NBRENA [M:ADLVWB]NBRENA
                        Endif
                        WWIND = [M:ADLVWB]NBRENA
                        [M:ADLVWB]NBRENA+=1
                        [M:ADLVWB]ELEMENT1 (WWIND)   = [M:ADLVW]ELEMENT (WIND)
                        [M:ADLVWB]ELTLEG1 (WWIND)    = [M:ADLVW]ELTLEG (WIND)
                        [M:ADLVWB]ELTDES1 (WWIND)    = [M:ADLVW]ELTDES (WIND)
                   Endif
            Endif
        Next WIND 
        # nbr de ligne a ajouter
        WNBRLIG =[M:ADLVWB]NBRENA
    Endif
Elsif [M:ADLVW]TABREF = ""
    # ici la table n existe plus ou pas encore
    # on ne peut rien faire donc.
    WNBRLIG = 0
Endif

#----------------------------------------------#
# Contrôle de la suppression                   #
# il faut virer les lignes dans ecran ADLV6 se rapportant à tabcod
# et ensuite faire insertion ou pas d insert si rien en prise en compte
#----------------------------------------------#
nolign=GSAVNOLIGN
If GAWMTYP = "2"
    Local Char WTABREF
    Local Integer WTABADINUM
    WTABREF    = [M:ADLVW]TABREF
    WTABADINUM = [M:ADLVW]TABADINUM
    Local Char WSUPLIG(1)
    # il faut virer la ligne dans adlv 
    # donc on positionne y dans la variable car sous prog commun avec subadlv
    WSUPLIG = "Y"
    Gosub SUP_LIGTAB From SUBADLV
Endif

# ici nbrlig peut etre à zero
# soit parce qu on n a rien pris
# soit parce qu on a tout mis à non pour prise en compte
If WNBRLIG=0
    If GAWMTYP  <> "2"
        # on sort tout simplement sans rien faire
        Gosub RAZ_NBRKEY From SUBADLV
        Goto FIN_AJOUTBIS
    Else
        Goto FIN_AJOUT
    Endif
Endif
#----------------------------------------------#
# Contrôle de l'insertion   en fin de tableau  #
#----------------------------------------------#
nolign=[M:ADLV6B]NBROBJ

status=73
If dim ([M:ADLV6B]TABCOD)<[M:ADLV6B]NBROBJ+WNBRLIG
  GMESSAGE=mess(122,199,1) : GERR=1 : FIN=1 : Return
Endif
#----- Insertion en fin de tableau -----#
If dim([M:ADLV6B]TABCOD)=[M:ADLV6B]NBROBJ+WNBRLIG
  Insa nolign,WNBRLIG [M:ADLV6B]NBROBJ    : # Pas de borne sinon plantage
Else
  Insa nolign,WNBRLIG,[M:ADLV6B]NBROBJ+WNBRLIG-1 [M:ADLV6B]NBROBJ
Endif
[M:ADLV6B]NBROBJ+=WNBRLIG

#----- Chargement des lignes -----#
WIND = nolign
If [M:ADLVW]NULRECFLG = 2
       # une seule ligne
       [M:ADLV6B]TABAWM(WIND)    = [M:ADLVW]MODELE
       [M:ADLV6B]TABCOD(WIND)    = [M:ADLVW]TABREF
       [M:ADLV6B]NULRECFLG(WIND) = [M:ADLVW]NULRECFLG
       [M:ADLV6B]TABADINUM(WIND) = [M:ADLVW]TABADINUM
       If [M:ADLVW]TABREF = "ATABDIV"
                  [M:ADLV6B]TABKEY(WIND)    = num$([M:ADLVW]TABADINUM)+"~"
       Else
                  [M:ADLV6B]TABKEY(WIND)    = ""
       Endif
       [M:ADLV6B]TABLEG(WIND)    = ""
       [M:ADLV6B]TABKEYDES(WIND) = ""
       [M:ADLV6B]TABKEYNAM(WIND) = ""
       [M:ADLV6B]TABKEYFMT(WIND) = ""
Else
    If [M:ADLVWB]NBRENA <> 0
        For J = 0 To [M:ADLVW]NBR-1
              [M:ADLV6B]TABAWM(WIND)    = [M:ADLVW]MODELE
              [M:ADLV6B]TABCOD(WIND)    = [M:ADLVW]TABREF
              [M:ADLV6B]NULRECFLG(WIND) = [M:ADLVW]NULRECFLG
              [M:ADLV6B]TABADINUM(WIND) = [M:ADLVW]TABADINUM
              [M:ADLV6B]TABKEYNAM(WIND) = [M:ADLVW]ELTKEYNAM
              [M:ADLV6B]TABKEYFMT(WIND) = [M:ADLVW]ELTKEYFMT
              [M:ADLV6B]TABKEY(WIND)    = [M:ADLVWB]ELEMENT1 (J)
              [M:ADLV6B]TABLEG(WIND)    = [M:ADLVWB]ELTLEG1  (J)
              [M:ADLV6B]TABKEYDES(WIND) = [M:ADLVWB]ELTDES1  (J)
              WIND+=1
        Next J
    Else
        For J = 0 To [M:ADLVW]NBR-1
            If [M:ADLVW]TABREF <> ""
               If [M:ADLVW]ENAFLG (J)  = 2
                  [M:ADLV6B]TABAWM(WIND)    = [M:ADLVW]MODELE
                  [M:ADLV6B]TABCOD(WIND)    = [M:ADLVW]TABREF
                  [M:ADLV6B]NULRECFLG(WIND) = [M:ADLVW]NULRECFLG
                  [M:ADLV6B]TABADINUM(WIND) = [M:ADLVW]TABADINUM
                  [M:ADLV6B]TABKEYNAM(WIND) = [M:ADLVW]ELTKEYNAM
                  [M:ADLV6B]TABKEYFMT(WIND) = [M:ADLVW]ELTKEYFMT
                  [M:ADLV6B]TABKEY(WIND)    = [M:ADLVW]ELEMENT (J)
                  [M:ADLV6B]TABLEG(WIND)    = [M:ADLVW]ELTLEG  (J)
                  [M:ADLV6B]TABKEYDES(WIND) = [M:ADLVW]ELTDES  (J)
                  WIND+=1
                Endif
            Endif
        Next J
    Endif
Endif
# insertion dans adlv6
nolign=[M:ADLV6]NBRTAB

status=73
If dim ([M:ADLV6]TABCOD1)<[M:ADLV6]NBRTAB+1
  GMESSAGE=mess(122,199,1) : GERR=1 : FIN=1 : Return
Endif
#----- Insertion en fin de tableau -----#
If dim([M:ADLV6]TABCOD1)=[M:ADLV6]NBRTAB+1
  Insa nolign,1 [M:ADLV6]NBRTAB    : # Pas de borne sinon plantage
Else
  Insa nolign,1,[M:ADLV6]NBRTAB [M:ADLV6]NBRTAB
Endif
[M:ADLV6]NBRTAB+=1
#----- Chargement des lignes -----#
WIND = nolign
If [M:ADLVW]TABREF <> ""
   [M:ADLV6]TABAWM1(WIND)    = [M:ADLVW]MODELE
   [M:ADLV6]TABCOD1(WIND)    = [M:ADLVW]TABREF
   [M:ADLV6]NULRECFLG1(WIND) = [M:ADLVW]NULRECFLG
   [M:ADLV6]TABADINUM1(WIND) = [M:ADLVW]TABADINUM
   [M:ADLV6]TABKEYNAM1(WIND) = [M:ADLVW]ELTKEYNAM
   [M:ADLV6]TABKEYFMT1(WIND) = [M:ADLVW]ELTKEYFMT
   # ligne correcte puisque qu on est en selection
   [M:ADLV6]FLGKO     (WIND) = 1
   WIND+=1
Endif

$FIN_AJOUT
# raz de l autre tableau
# dans tous les cas
Gosub RAZ_NBRKEY From SUBADLV
#
nolign=GSAVNOLIGN
status=0
Affzo [M:ADLV6]5
Affzo [M:ADLV6]15
# pour degriser bouton enreg
mkstat=4 

$FIN_AJOUTBIS
nolign=GSAVNOLIGN
FIN=1
Return

#######################################################################
#                     Etiquettes divers
#######################################################################
$SETNOL
Local Shortint NOL 
NOL=nolign-1
Return


$AFF_ELEMENT
# ----------------------------------------#
# affichage des cles de fichier à filtrer
# affichage des lignes de toute la table
# ----------------------------------------#
Local Integer WIND
Local Integer WNBR_ELE_MAX
Local Char WNAMEFILE (250)
Local Char WFLDLEG (250)

Local Char WELTKEY   (250)
Local Char WELTKEYFMT(250)
Local Char WELTFIELD (250)

Local Char WTEXTE (250)
Local Char WMESSAGE (250)

WMESSAGE = ""
WNAMEFILE =  [F:AWM]TABREF
Gosub LOAD_FLDLEG

# si tabfor et poscod   on fera un cas particulier 
# voir avec le filtre sur selection avancée attention a celles à oui a les conserver sauf si nouveau modele.

Read [F:ATB]CODFIC = [F:AWM]TABREF
If fstat = 0
    # OUVERTURE de la table en question
    If filinfo(filpath("FIL",WNAMEFILE,"fde"),0)>=0
        Local File =WNAMEFILE [WWW]
        #
        Call SET_IDENT_KEY (WNAMEFILE,WELTKEY,WELTKEYFMT,WELTFIELD)
        If WELTKEY = ""
             # ici on a un prob il faut interdire la saisie
             # modele non conforme , table sans cle principale
             # on n autorise que le bouton fin...... pas d autre choix
             WMESSAGE = mess (1,7999,1)
             Call MESSAGE(WMESSAGE) From GESECRAN
             WMESSAGE = ""
        Else
            # chargement du tableau de prise en compte
            [M:ADLVW]TABREF      = WNAMEFILE
            [M:ADLVW]ELTKEYNAM   = WELTKEY
            [M:ADLVW]ELTKEYFMT   = WELTKEYFMT

            [M:ADLVW]NBR = 0
            If [M:ADLVW]WFORMULE <> ""
                Filter [F:WWW] Where evalue ([M:ADLVW]WFORMULE) and evalue ([M:ADLVW]WFORMULETAB)
            Else
                Filter [F:WWW] Where evalue ([M:ADLVW]WFORMULETAB)
            Endif
            # calcul nombre d element
            WNBR_ELE_MAX = rowcount ([F:WWW])
            If WNBR_ELE_MAX > GMAXELEMENT
                WNBR_ELE_MAX = GMAXELEMENT
                # cas qui ne devrait pas arriver
                Infbox 'attention trop element dans table, affichage incomplet'
            Endif
            For [F:WWW]
                # test champs leg
                If WFLDLEG <> ""
                 # on verifie que champ est present dans la table 
                 If evalue("dim([F:WWW]"+WFLDLEG+")") >= 0
                        If num$(evalue("[F:WWW]"+WFLDLEG)) = ""
                               # cas de la leg vide on prend tout
                               If [M:ADLVW]WALLENA = 3
                                        Gosub LOAD_ELT_NON
                               Else
                                        Gosub LOAD_ELT
   
                               Endif
                         Else
                               # cas des kits on prend tout pas de leg
                               If GFONCTION = "GESADLK"
                                   If [M:ADLVW]WALLENA = 3
                                        Gosub LOAD_ELT_NON
                                   Else
                                        Gosub LOAD_ELT
   
                                   Endif
                               Else
                                   If find(num$(evalue("[F:WWW]"+WFLDLEG)),[M:ADLV4]DOSLEG(0..[M:ADLV4]NBRLEG-1) )
                                          If [M:ADLVW]WALLENA = 3
                                                Gosub LOAD_ELT_NON
                                          Else
                                                Gosub LOAD_ELT
                                          Endif

                                   Endif
                               Endif
                        Endif
                 Else
                    # champs n existe pas ou plus
                    # "prob sur modele et leg"
                    WMESSAGE = mess (2,7999,1)
                    Call MESSAGE(WMESSAGE) From GESECRAN
                    WMESSAGE = ""
                    Break
                 Endif
                Else
                    If [M:ADLVW]WALLENA = 3
                       Gosub LOAD_ELT_NON
                     Else
                       Gosub LOAD_ELT
                     Endif
               Endif
               If WIND >= WNBR_ELE_MAX
                    Break
                Endif
            Next
            Filter [F:WWW] 
        Endif
    Else
        # ici le fichier n existe plus ou pas encore
        # on n autorise que le bouton fin...... pas d autre choix
        # mess ---Le fichier utilisé n'existe plus ou n'a pas encore été créé dans votre dossier.
        WMESSAGE = mess (14,7999,1)
        Call MESSAGE(WMESSAGE) From GESECRAN
        WMESSAGE = ""
    Endif
Else
    # ici le fichier n existe plus ou pas encore
    # on n autorise que le bouton fin...... pas d autre choix
    # mess ---Le fichier utilisé n'existe plus ou n'a pas encore été créé dans votre dossier.
    WMESSAGE = mess (14,7999,1)
    Call MESSAGE(WMESSAGE) From GESECRAN
    WMESSAGE = ""
Endif
Return

#######################################################################
$INIT_ADLVW
WIND = [M:ADLVW]NBR
If WIND <> 0
    If dim([M:ADLVW]ELEMENTW)=[M:ADLVW]NBR
              Dela 0,WIND [M:ADLVW]NBR
    Else
              Dela 0,WIND,[M:ADLVW]NBR-1 [M:ADLVW]NBR
    Endif
Endif
[M:ADLVW]NBR = 0
Return

#######################################################################
$LOAD_ADLVW
Local Integer WIND
Local Integer WWIND

# attention la clé peut exister sur une autre table et donc il faut d abord
# trouver la ligne de la table et ensutie rechercher l element a partir de cette ligne
# sur  tabref cela suffit car unique sur avec le modele - unciite du coup table-modele
Local Integer WINDICE
WINDICE = find ([M:ADLVW]TABREF,[M:ADLV6B]TABCOD(0..[M:ADLV6B]NBROBJ-1)) 
If WINDICE <> 0
    WINDICE -=1
    For WIND = 0 To [M:ADLVW]NBR-1
        # la première fois c'est tout
        # mais plus apres si on coche decoche affichage tous les pris en compte
        Local Integer WWIND
        WWIND = find ([M:ADLVW]ELEMENT(WIND),[M:ADLV6B]TABKEY(WINDICE..[M:ADLV6B]NBROBJ-1)) 
        If WWIND <> 0
              WWIND +=WINDICE
              If [M:ADLV6B]TABCOD (WWIND-1) =  [M:ADLVW]TABREF
                    # attention ici car si leg renseignée il faut verifier que leg existe encore 
                    # pour le livrable et si pas le cas on ne selectioonne pas  d'office
                    # car c'est faux
                    If [M:ADLV6B]TABLEG (WWIND-1) =  [M:ADLVW]ELTLEG (WIND)
                        [M:ADLVW]ENAFLG (WIND) = 2
                    Endif
              Endif
        Endif
    Next J
Endif
Return

#######################################################################
$INIT_ADLVWB
# init des prise en compte, raz du tableau des prises en compte

Raz [M:ADLVWB]
[M:ADLVWB]NBRENA = 0
Return

#######################################################################
$LOAD_ADLVWB
Local Integer WIND
Local Integer J
WIND = [M:ADLVWB]NBRENA
# chargement tabelau prise en compte en fct de adlvw
#
# attention si la ligne existe deux fois.. 
# ne pas la mettre deux fois.....
For J = 0 To [M:ADLVW]NBR-1
    If [M:ADLVW]TABREF <> ""
      If [M:ADLVW]NULRECFLG = 2
            # on vire toutes les lignes 
           Gosub INIT_ADLVWB
       Elsif [M:ADLVW]ENAFLG (J)  = 2
           # on verifie avant qu elle n est pas deja là.
           Local Integer WWIND
           WWIND = find ([M:ADLVW]ELEMENT(J),[M:ADLVWB]ELEMENT1(0..[M:ADLVWB]NBRENA-1)) 
           If WWIND = 0
              # ajout en fin de tableau
              [M:ADLVWB]ELEMENT1  (WIND) = [M:ADLVW]ELEMENT (J)
              [M:ADLVWB]ELTLEG1   (WIND) = [M:ADLVW]ELTLEG  (J)
              [M:ADLVWB]ELTDES1   (WIND) = [M:ADLVW]ELTDES  (J)
              WIND+=1
              [M:ADLVWB]NBRENA = WIND
           Endif
       Else
           # on verifie avant qu elle n est pas deja là.
           # et on la vire dans cas ou a remis non
           Local Integer WWIND
           WWIND = find ([M:ADLVW]ELEMENT(J),[M:ADLVWB]ELEMENT1(0..[M:ADLVWB]NBRENA-1)) 
           If WWIND <> 0
                 # on vire la ligne
                 # WWIND est le numero de ligne on fait - 1 dessus pour indice ligne du tableau
                 WWIND-=1
                 If dim([M:ADLVWB]ELEMENT1)=[M:ADLVWB]NBRENA
                        Dela WWIND,1 [M:ADLVWB]NBRENA
                 Else
                        Dela WWIND,1,[M:ADLVWB]NBRENA-1 [M:ADLVWB]NBRENA
                 Endif
                 WIND -=1
                [M:ADLVWB]NBRENA = WIND
           Endif
       Endif
    Endif
Next J
Return


#######################################################################
$LOAD_ELT
# ---------------------------------------#
# champs cle 
# ---------------------------------------#
Gosub INIT_ELTDES
#
# on regarde si on a deja stocker des elements dans adlvwb dans cas de pose critère
If [M:ADLVWB]NBRENA <>0
           Local Integer WWIND
           WWIND = find ([M:ADLVW]ELEMENT(WIND),[M:ADLVWB]ELEMENT1(0..[M:ADLVWB]NBRENA-1)) 
           If WWIND <> 0
                    [M:ADLVW]ENAFLG (WIND) = 2
           Endif
Endif
[M:ADLVW]NBR +=1
WIND +=1
Return

#######################################################################
$LOAD_ELT_NON
# on regarde si on a deja stocker des elements dans adlvwb 
# et si c'est le cas , on ne prend
Local Char WELEMENT(250)
WELEMENT    = evalue(WELTFIELD)

If [M:ADLVWB]NBRENA <>0
    Local Integer WWIND
    WWIND = find (WELEMENT,[M:ADLVWB]ELEMENT1(0..[M:ADLVWB]NBRENA-1)) 
    If WWIND = 0
        # ---------------------------------------#
        # champs cle 
        # ---------------------------------------#
        Gosub INIT_ELTDES
        #
        [M:ADLVW]NBR +=1
        WIND +=1
    Endif
Else
    # ---------------------------------------#
    # champs cle 
    # ---------------------------------------#
    Gosub INIT_ELTDES
    #
    [M:ADLVW]NBR +=1
    WIND +=1
Endif


Return
#######################################################################
$LOAD_FLDLEG
# -------------------------- #
# on reformate le champs leg
# -------------------------- #
Local Integer I
WFLDLEG   =  [F:AWM]FLDLEG
If [F:AWM]FLDLEG<>""
     WFLDLEG = [F:AWM]FLDLEG
     I = instr(1,WFLDLEG,"]")
     If I : WFLDLEG = right$(WFLDLEG,I+1) : Endif
Endif
Return

#######################################################################
$INIT_ELTDES
[M:ADLVW]ELEMENT(WIND)     = evalue(WELTFIELD)
If [F:ATB]INTIT <> ""
     # on verifie que champ est present dans la table cas des atextra
     If evalue("dim([F:WWW]"+[F:ATB]INTIT+")") >= 0
         [M:ADLVW]ELTDES (WIND) = num$(evalue("[F:WWW]"+[F:ATB]INTIT))
     Else
         # cas des types AXX etc...
          Call SET_IDENT_ATEXTRA (WNAMEFILE,[F:ATB]INTIT,WTEXTE)
         [M:ADLVW]ELTDES (WIND) = WTEXTE
     Endif
Endif
[M:ADLVW]ENAFLG (WIND) = 1

If WFLDLEG <> ""
   # on verifie que champ est present dans la table 
   If evalue("dim([F:WWW]"+WFLDLEG+")") >= 0
               If GFONCTION = "GESADLK"
                     # cas des kits on prend tout
                     [M:ADLVW]ELTLEG (WIND) = num$(evalue("[F:WWW]"+WFLDLEG))
               Else
                  If find(num$(evalue("[F:WWW]"+WFLDLEG)),[M:ADLV4]DOSLEG(0..[M:ADLV4]NBRLEG-1) )
                     [M:ADLVW]ELTLEG (WIND) = num$(evalue("[F:WWW]"+WFLDLEG))
                  Else
                     If num$(evalue("[F:WWW]"+WFLDLEG)) = ""
                        # cas de la leg vide on prend tout
                         [M:ADLVW]ELTLEG (WIND) = num$(evalue("[F:WWW]"+WFLDLEG))
                     Endif
                  Endif
               Endif
    Endif
Endif

Return

#######################################################################
$LOAD_WALLENA
Local Integer WIND
Local Integer J
WIND = [M:ADLVW]NBR
For J = 0 To [M:ADLVWB]NBRENA-1
     [M:ADLVW]ELEMENT  (WIND) = [M:ADLVWB]ELEMENT1 (J)
     [M:ADLVW]ELTLEG   (WIND) = [M:ADLVWB]ELTLEG1  (J)
     [M:ADLVW]ELTDES   (WIND) = [M:ADLVWB]ELTDES1  (J)
     [M:ADLVW]ENAFLG(WIND) = 2
      WIND+=1
Next J
[M:ADLVW]NBR = WIND
Return

#######################################################################
$ERREXP
ER = errn
GMESSAGE = mess(37,124,1)+"\"+errmes$(ER)+"\"+errm
ER=1
# Expression incorrecte
Resume

#######################################################################
#                         Sous programmes 
#######################################################################
Subprog SET_IDENT_ATEXTRA (RNAMEFILE,RINTIT,RTEXTE)
Value    Char RNAMEFILE
Value    Char RINTIT
Variable Char RTEXTE


Local Char    WLAN
Local Char    WVAL(250)(1..4),WPAR(GLONAVA)
Local Integer WP_IND


# lecture amkspar pour recup paramètrage des champs cle sur atextra
# table amkspar avec type = 2 contient le paramétrage de la cle atextra defini sur une table
Raz WVAL 
WP_IND = 0
Raz RTEXTE

Read [AMP_]CODPAR(3)=2;RNAMEFILE;RINTIT
If !fstat
    For WPAR="TABLE1","ZONE","CLECUR1","CLECUR2"
          WP_IND += 1
          Read [AMP_]CODPAR=2;RNAMEFILE;RINTIT;WPAR
          If !fstat & [F:AMP_]VALPAR<>""
               WVAL(WP_IND) = [F:AMP_]VALPAR
          Else
               WVAL(WP_IND) = '""'
          Endif
    Next WPAR
Endif

If WP_IND <> 0
    If WVAL(3) <> '""' and WVAL (4) <> '""'
        Read [AXX_]AXX0 = num$(evalue(WVAL(1)));num$(evalue(WVAL(2)));GLANGUE;num$(evalue("[F:WWW]"+WVAL(3)));num$(evalue("[F:WWW]"+WVAL(4)))
    Elsif WVAL(3) <> '""'
        Read [AXX_]AXX0 = num$(evalue(WVAL(1)));num$(evalue(WVAL(2)));GLANGUE;num$(evalue("[F:WWW]"+WVAL(3)));""
    Else
        Read [AXX_]AXX0 = num$(evalue(WVAL(1)));num$(evalue(WVAL(2)));GLANGUE;"";""
    Endif
    If fstat = 0
        RTEXTE = [F:AXX_]TEXTE
    Else
        # lecture en FRA si glangue  = eng et vis versa
        # pour autre langue en eng si inexistant dans langue de connexion
        If GLANGUE  = "FRA"
            WLAN = "ENG"
        Elsif GLANGUE  = "ENG"
            WLAN = "FRA"
        Else
            WLAN = "ENG"
        Endif
        If WVAL(3) <> '""' and WVAL (4) <> '""'
            Read [AXX_]AXX0 = num$(evalue(WVAL(1)));num$(evalue(WVAL(2)));WLAN;num$(evalue("[F:WWW]"+WVAL(3)));num$(evalue("[F:WWW]"+WVAL(4)))
        Elsif WVAL(3) <> '""'
            Read [AXX_]AXX0 = num$(evalue(WVAL(1)));num$(evalue(WVAL(2)));WLAN;num$(evalue("[F:WWW]"+WVAL(3)));""
        Else
            Read [AXX_]AXX0 = num$(evalue(WVAL(1)));num$(evalue(WVAL(2)));GLANGUE;"";""
        Endif
        If fstat = 0
            RTEXTE = [F:AXX_]TEXTE
        Endif
    Endif
Endif

End

######################################################################################
Subprog SET_IDENT_KEY (RNAMEFILE,RELTKEY,RELTKEYFMT,RELTFIELD)
Value    Char RNAMEFILE
Variable Char RELTKEY
Variable Char RELTKEYFMT
Variable Char RELTFIELD


Local Char    WVAL(250)(1..4)
Local Char    ZIDENT (250), ZA (250)
Local Integer Z1,Z2 
# recherche des clés du fichiers premiere en sans homonymes
Filter [ATI_] Where HOMONYM= 1 and CODFIC = RNAMEFILE
# on prend la premiere cle sans homonyme
Read [ATI_] First
If fstat = 0
   RELTKEYFMT  = [F:ATI_]DESCRIPT
   ZIDENT      = [F:ATI_]DESCRIPT
   RELTKEY     = [F:ATI_]CODIND
   #
   WVAL(3) = ""
   WVAL(4) = ""
   While ZIDENT<>""
     Z1 = instr(1,ZIDENT,"+")
     Z2 = instr(1,ZIDENT,"-")
     If    Z1 & Z2  : Z1 = min(Z1,Z2)
     Elsif Z2 & !Z1 : Z1 = Z2
     Endif
     If Z1
          ZA = left$(ZIDENT,Z1-1) : ZIDENT = right$(ZIDENT,Z1+1)
     Else
          ZA = ZIDENT : ZIDENT = ""
     Endif
     Read [ATZ_]CODZONE = RNAMEFILE;ZA
     Read [ATY_]CODTYP  = [F:ATZ_]CODTYP
     If [F:ATY_]TYPTYP=7
          ZA = "[F:WWW]"+ZA
     Else
          ZA = "num$([F:WWW]"+ZA+")"
     Endif
     If RELTFIELD = ""
         RELTFIELD = ZA
     Else
         RELTFIELD += '+"~"+'+ZA
     Endif
   Wend
Else
   # il faut interdire la saisie , la table n a pas de cle sans homonyme
   RELTKEYFMT = ""
   RELTKEY = ""
   RELTFIELD = ""
Endif
Filter [ATI_]

End

