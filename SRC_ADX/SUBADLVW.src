Subprog AS_MODELE(VALEUR)
Variable Char    VALEUR()
If GAWMTYP <> "1"
       mkstat = 2
Endif
End

Subprog IB_MODELE
End

Subprog B1_MODELE(VALEUR)
Variable Char    VALEUR()
# fev 2013
# je n arrive pas a mettre le tunnel en auto
# le choix etait bien fait dans l ecran mais 
# dans le trt w1adlvw il ne génere pas l'action associé
# on fait donc à la main pas cool mais bon
Call OBJET("AWM",VALEUR,"") From GOBJET
Gosub AFF From GSAISIE
End


Subprog C_MODELE(VALEUR)
Variable Char    VALEUR()
# on autorise que le modele de la ligne sur adlv6
# ou un nouveau pas encore enreg dans adlv6
# en fct de GAWMTYP = 1 = new modele 2 : ajout de cle
Local Integer WRETOUR
WRETOUR = 0

If GAWMTYP <> "1"
   If VALEUR <> [M:ADLV6]TABAWM1(GSAVNOLIGN-1)
       #pas autorisé, vous ne pouvez changer de modèle'
       GMESSAGE =mess (3,7999,1)
       mkstat = 2
       End
   Endif
Else
    WRETOUR = 0
    # lecture du modele seul
    Call READ_MODELE (VALEUR,"",WRETOUR) From SUBADLV
    If WRETOUR = 0
        # verification table
        # lecture table 
        Read [F:ATB]CODFIC = [F:AWM]TABREF
        If fstat = 0
            If [F:ATB]TYPDLV <> 4 and [F:ATB]TYPDLV  <> 5
                #"interdit, pas table de paramètrage"
                GMESSAGE =mess (4,7999,1)
                mkstat = 2
            Elsif [F:ATB]TYPFIC = 3 or [F:ATB]TYPFIC = 5
                #"interdit, fichier non applicatif"
                GMESSAGE =mess (5,7999,1)
                mkstat = 2
            Elsif pat ([F:AWM]TABREF, "*ADELIV*")
                # "interdit sur adelver" poscod ou tabfor
                GMESSAGE =mess (6,7999,1)
                mkstat = 2
            Elsif pat ([F:AWM]TABREF, "*POSCOD*")
                # "interdit sur adelver" poscod ou tabfor
                GMESSAGE =mess (6,7999,1)
                mkstat = 2
            #Elsif pat ([F:AWM]TABREF, "*TABFOR*")
                # "interdit sur adelver" poscod ou tabfor
            #    GMESSAGE =mess (6,7999,1)
            #    mkstat = 2
            Elsif pat ([F:AWM]TABREF, "*ADOVAL*")
                # "interdit sur adelver* poscod ou tabfor et adoval 
                GMESSAGE =mess (6,7999,1)
                mkstat = 2
            Elsif pat ([F:AWM]TABREF, "*ADOPAR*")
                # "interdit sur adelver* poscod ou tabfor et adoval 
                GMESSAGE =mess (6,7999,1)
                mkstat = 2
            Elsif !pat ([F:AWM]TABREF, "*ATABDIV*")
                If find (VALEUR,[M:ADLV6]TABAWM1(0..[M:ADLV6]NBRTAB-1))
                   #Infbox 'pas autorisé, vous ne pouvez ajouter ce modèle'
                    GMESSAGE =mess (7,7999,1)
                   mkstat = 2
                Else
                    # il faut aussi controler que le couple modele - table est unique
                    If find ([F:AWM]TABREF,[M:ADLV6]TABCOD1(0..[M:ADLV6]NBRTAB-1))
                       #Infbox 'pas autorisé, vous ne pouvez ajouter ce modèle'
                        GMESSAGE =mess (7,7999,1)
                        mkstat = 2
                    Endif
                Endif
            Elsif pat ([F:AWM]TABREF, "*ATABDIV*")
                # ici table diverse
                # on controle que si on a deja une table diverse on garde bien le même modele
                # pas le droit de mettre un autre modele sur table diverse
                If find ([F:AWM]TABREF,[M:ADLV6]TABCOD1(0..[M:ADLV6]NBRTAB-1))
                    If !find (VALEUR,[M:ADLV6]TABAWM1(0..[M:ADLV6]NBRTAB-1))
                       #Infbox 'pas autorisé, vous ne pouvez ajouter ce modèle'
                        GMESSAGE =mess (7,7999,1)
                        mkstat = 2
                    Endif
                Endif
            Endif
        Else
            mkstat = 2
        Endif
    Else
        mkstat = 2
    Endif
Endif

End

Subprog AM_MODELE(VALEUR)
Variable Char    VALEUR()
# affichage des lignes 
[M:ADLVW]NULRECFLG = 1
[M:ADLVW]WFORMULE = ""
[M:ADLVW]WFORMULETAB = '1=1'
[M:ADLVW]TABADINUM = 0
[M:ADLVW]WALLENA = 1
# init des prise en compte, raz du tableau des prises en compte
Gosub INIT_ADLVWB
If !pat ([F:AWM]TABREF, "*ATABDIV*")
    Grizo [M:ADLVW]TABADINUM
    # affichage des lignes de toute la table
    Gosub AFF_ELEMENT
    Affzo [M:ADLVW]
Else
    Actzo [M:ADLVW]TABADINUM
    #
    Affzo [M:ADLVW]WFORMULE
    Affzo [M:ADLVW]NULRECFLG
    Affzo [M:ADLVW]TABADINUM
    Affzo [M:ADLVW]WALLENA
Endif
End

Subprog AS_TABADINUM(VALEUR)
Variable Decimal VALEUR
If GAWMTYP <> "1"
       mkstat = 2
Endif
End

Subprog C_TABADINUM(VALEUR)
Variable Decimal VALEUR
If GAWMTYP <> "1"
   If VALEUR <> [M:ADLV6]TABADINUM1(GSAVNOLIGN-1)
      #Infbox 'pas autorisé, vous ne pouvez changer le modèle'
       GMESSAGE =mess (3,7999,1)
       mkstat = 2
       End
   Endif
Else
   If VALEUR  =0
           mkstat = 2
   Elsif find (VALEUR,[M:ADLV6]TABADINUM1(0..[M:ADLV6]NBRTAB-1))
           #'pas autorisé, vous ne pouvez ajouter cette table diverse'
           GMESSAGE =mess (8,7999,1)
           mkstat = 2
    Endif
Endif
End


Subprog AM_TABADINUM(VALEUR)
Variable Decimal VALEUR
# affichage des lignes 
If pat ([F:AWM]TABREF, "*ATABDIV*")
    [M:ADLVW]NULRECFLG = 1
    [M:ADLVW]WALLENA = 1
    [M:ADLVW]WFORMULE = ""
    [M:ADLVW]WFORMULETAB = 'NUMTAB='+num$(VALEUR)
    # init des prise en compte, raz du tableau des prises en compte
    Gosub INIT_ADLVWB
    # affichage des lignes de toute la table
    Gosub AFF_ELEMENT
    Affzo [M:ADLVW]
Else
    [M:ADLVW]WFORMULETAB = '1=1'
Endif
End

Subprog AM_NULRECFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    # on met tout à non pour prise en comtpe
    For I=0 To [M:ADLVW]NBR-1
     [M:ADLVW]ENAFLG(I) = 1
    Next I
    Affzo [M:ADLVW]20
    [M:ADLVW]WALLENA = 1
    Grizo [M:ADLVW]WALLENA
    Affzo [M:ADLVW]WALLENA
Else
    Actzo [M:ADLVW]WALLENA
    Affzo [M:ADLVW]WALLENA
Endif
End


Subprog AS_NBR
If [M:ADLVW]NULRECFLG = 2
    # pas de saisie si on ne prend en compte aucun record
    mkstat = 2
Endif
End

Subprog B2_NBR
Local Integer I
For I=nolign  To [M:ADLVW]NBR
 [M:ADLVW]ENAFLG(I-1) = 2
Next I
Affzo [M:ADLVW]20
End

Subprog B3_NBR
Local Integer I
For I=nolign To [M:ADLVW]NBR
 [M:ADLVW]ENAFLG(I-1) = 1
Next I
Affzo [M:ADLVW]20
End

Subprog B4_NBR
# tunnel sur element si possible
# au plus simple pour instant sans verif de combien de partie de cle..
Gosub SETNOL
If  [M:ADLVW]ELEMENT(NOL) <>  ""
    Read [F:ATB]CODFIC = [M:ADLVW]TABREF
    If fstat = 0
        If [F:ATB]ABRFIC = "ADI"
            Call OBJET([F:ATB]ABRFIC,[M:ADLVW]ELEMENT(NOL),num$([M:ADLVW]TABADINUM)) From GOBJET
        Else
            # verif existence de objet sinon rien
            Local Char WFENETRE (30)
            Call CONT_FEN ([F:ATB]ABRFIC,WFENETRE) From GOBJET
            If WFENETRE <> ""
                Call OBJET([F:ATB]ABRFIC,[M:ADLVW]ELEMENT(NOL),"") From GOBJET
            Else
                #"Pas de tunnel dispo dans ce contexte"
                GMESSAGE =  mess (53,7999,1)
            Endif
        Endif
    Endif
Endif

End



Subprog AS_WFORMULE(VALEUR)
Variable Char    VALEUR()
If [M:ADLVW]MODELE = ""
    mkstat = 2
Endif
If [M:ADLVW]TABREF = ""
    mkstat = 2
Endif
If [M:ADLVW]NULRECFLG = 2
    mkstat = 2
Endif
# Filtre sur la table
Raz [M]TEXCON
Raz [M]VARSUP
[M]FILTAB = [M:ADLVW]TABREF
If pat( VALEUR,"*[F:*")
   # il faut remplacer le code fichier WWWW par du blanc
   # pour ne pas planter dans assistant formule
   VALEUR = func AFNC.TRANSF(VALEUR,"[F:WWW]","") 
Endif

End

Subprog C_WFORMULE(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
    Local Integer I , K , ER
    Local Char    CHAINE(80)
    Local File =[M]TABREF : # Pour l'avoir par défaut
    Default [F] , [V] , [L] , [S]
    Onerrgo ERREXP
    ER = 0
    K = evalue([L]VALEUR)
    Onerrgo
    Close Local File
    If ER
          mkstat = 2 
    Else
        If pat( VALEUR,"*[F:*")
            # il faut remplacer le code abrev fichier par WWWW
            WABR = func AFNC.PARTS(VALEUR,"[F:","]") 
            # il faut remplacer le code abrev fichier par WWWW
            VALEUR = func AFNC.TRANSF(VALEUR,WABR,"F:WWW") 
            # et ensuite par du blanc
            VALEUR = func AFNC.TRANSF(VALEUR,"[F:WWW]","") 
        Endif
    Endif
Endif
End



Subprog AM_WFORMULE(VALEUR)
Variable Char    VALEUR()
# on filtre les elements de WW en fct de ce critère.
# attention si on a deja des elements avec oui .. on garde ceux là dans la boite en plus
# affichage des lignes 
[M:ADLVW]NULRECFLG = 1
If [M:ADLVW]WALLENA = 2
    [M:ADLVW]WALLENA = 1
    Affzo [M:ADLVW]WALLENA
Endif
# chargement tableau prise en compte en fct de adlvw
# et on stocke avant les lignes prises en compte pour ne pas les perdre.
# et ensuite on vire les lignes du tableau adlvw 
Gosub LOAD_ADLVWB
#
# init tableau affichage
Gosub INIT_ADLVW
#
[M]WFORMULE = VALEUR
# affichage des lignes de toute la table
Gosub AFF_ELEMENT
Affzo [M:ADLVW]20
End



Subprog AS_WALLENA(VALEUR)
Variable Integer VALEUR
If [M:ADLVW]NULRECFLG = 2
    mkstat = 2
Endif
End

Subprog C_WALLENA(VALEUR)
Variable Integer VALEUR
End

Subprog AM_WALLENA(VALEUR)
Variable Integer VALEUR

If pat ([F:AWM]TABREF, "*ATABDIV*")
        [M:ADLVW]WFORMULETAB = 'NUMTAB='+num$([M:ADLVW]TABADINUM)
Else
        [M:ADLVW]WFORMULETAB = '1=1'
        Grizo [M:ADLVW]TABADINUM
Endif
# chargement tableau prise en compte en fct de adlvw
# et on stocke avant les lignes prises en compte pour ne pas les perdre.
Gosub LOAD_ADLVWB

# case à cocher pour afficher tous les prises en compte
If VALEUR = 2 
    [M:ADLVW]WFORMULE = ""
    # selectionnés 'sans critere , on le force a blanc)
    #
    # init tableau affichage
    # on vire toutes les lignes
    Gosub INIT_ADLVW
    # on charge le tableau avec uniquement ceux à enaflg = oui
    Gosub LOAD_WALLENA
    Affzo [M:ADLVW]20
Elsif VALEUR = 3 
    # Non selectionnes en fct critere
    # init tableau affichage
    # on vire toutes les lignes
    Gosub INIT_ADLVW
    # on charge le tableau avec uniquement ceux à enaflg = non
    [M:ADLVW]WALLENA = 3
    Gosub AFF_ELEMENT
    Affzo [M:ADLVW]20
Else
    [M:ADLVW]NBR = 0
    # Tous en fct du critere
    # affichage des lignes de toute la table 'selectionnée ou pas'
    [M:ADLVW]WALLENA = 1
    Gosub AFF_ELEMENT
    Affzo [M:ADLVW]
Endif

End


