#######################################################################
# SUBPCO1 : Saisie des critères pour filtre du picking      SB oct 99 #
#         de préchargement des lignes de réception à partir des cdes  #
#           Modifié                                         HN sep 03 #
# ------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p de     #
#        saisie des critères "POQCRIT" et ne sert qu'à gérer le       #
#        masque écran "PCRITORD [PCO1]".                              #
#######################################################################


$ACTION
Case ACTION
  When "AS_WBPSNUM"
    Local Char WOPTION(2)
    If [M:PCO1]WBETFCY=2  [L]WOPTION="AE"  Else  [L]WOPTION="AF" : Endif
Endcase
Return


Subprog AM_WBETFCY(VALEUR)
#---------------------------------#
# Après modif du code inter-sites #
#---------------------------------#
Variable Integer VALEUR
If [M:PCO1]WBPSNUM<>""
  If [F:BPR]BPRNUM<>[M:PCO1]WBPSNUM
    Read [BPR] BPR0=[M:PCO1]WBPSNUM : If fstat  Raz [F:BPR] : Endif
  Endif
Else
  Raz [F:BPR]
Endif
If VALEUR=1
  Actzo WPOHNUM, WITMREFBPS, WITMDESBPS, WVCRNUMORI
Else
  If [F:BPR]FCY=""  Effzo [PCO1]WBPSNUM, WBPSNAM : Endif
  #Effzo WPOHNUM, WITMREFBPS, WITMDESBPS, WVCRNUMORI
  #Grizo WPOHNUM, WITMREFBPS, WITMDESBPS, WVCRNUMORI
Endif
End


Subprog IB_WBPSNUM
#-----------------------------#
# Avant saisie du fournisseur #
#-----------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
GBOUT1=mess(73,198,1) : # Fournisseur
End


Subprog AM_WBPSNUM(VALEUR)
#----------------------------#
# Après modif du fournisseur #
#----------------------------#
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
If VALEUR<>""
  If [F:BPR]BPRNUM<>VALEUR
    Read [BPR] BPR0=VALEUR : If fstat Raz [F:BPR] : End : Endif
  Endif
  If [F:BPR]BPRNUM<>""
    If [F:BPR]BETFCY=2 & [M:PTH0]BETFCY=2
      [M:PCO1]WBETFCY=2
      [M:PTH0]SALFCY = [F:BPR]FCY
    Elsif [F:BPR]BETFCY<>2
      [M:PCO1]WBETFCY=1
      Raz [M:PTH0]SALFCY
    Endif
    Affzo [PCO1]WBETFCY
    If [M:PCO1]WBETFCY=1
      Actzo WPOHNUM, WITMREFBPS, WITMDESBPS, WVCRNUMORI
    Else
      Effzo WPOHNUM, WITMREFBPS, WITMDESBPS, WVCRNUMORI
      Grizo WPOHNUM, WITMREFBPS, WITMDESBPS, WVCRNUMORI
    Endif
  Endif
  #----- affichage nom du fournisseur -----#
  If [F:BPS]BPSNUM<>[M:PCO1]WBPSNUM
    Read [BPS] BPS0= VALEUR : If fstat Raz [F:BPS] : Endif
  Endif
  [M:PCO1]WBPSNAM=[F:BPS]BPSNAM
Else
  Raz [M:PCO1]WBPSNAM
Endif
Affzo [PCO1]WBPSNAM
End


#------------------------------------------------#
#------------------------------------------------#
Subprog IB_WITMREF
GBOUT1=mess(22,198,1) : # Articles
End


#------------------------------------------------#
#------------------------------------------------#
Subprog AM_WITMREF(VALEUR)
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
If VALEUR <> ""
   Read [ITM] ITM0=VALEUR
   If fstat
     If instr(1,VALEUR,'*')|instr(1,VALEUR,'?')|instr(1,VALEUR,'#')|instr(1,VALEUR,'?')
     #- optimisation pour le temps de réponse -#
       Filter [ITM] Where pat(ITMREF,VALEUR)
       Read [ITM] ITM0 First : If fstat  Raz [F:ITM] : Endif
       Filter [ITM]
       If !fstat
         #--- par "sécurité", on enlève l'article fournisseur ---#
         Effzo [PCO1]WITMREFBPS, WITMDESBPS
       Else
         mkstat=2
       Endif
     Else
       Raz [F:ITM] : mkstat=2
     Endif
   Else
     #--- on enlève l'article fournisseur ---#
     Effzo [PCO1]WITMREFBPS, WITMDESBPS
   Endif
   #[M:PCO1]WITMDES = [F:ITM]ITMDES1
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PCO1]WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
   Affzo [PCO1]WITMDES
   # Issue X3-86269 - 2018-06-18 by SR : Load Supplier informations if not already done (if WBPSNUM loaded by SELITMBPS action)
   If [M:PCO1]WBPSNUM <> "" & [M:PCO1]WBPSNAM = ""
      Read [BPS] BPS0=[M:PCO1]WBPSNUM : If fstat  Raz [F:BPS] : Endif
      [M:PCO1]WBPSNAM   =[F:BPS]BPSNAM
      Affzo [PCO1]WBPSNUM, WBPSNAM
   Endif
   # End issue X3-86269
Else
   Effzo [PCO1]WITMDES
Endif
End

#------------------------------------------------#
#------------------------------------------------#
Subprog AM_WITMREFBPS(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
    #--- cas où on efface la valeur ---#
    Effzo [PCO1]WITMDESBPS
Else
    #--- il faut contrôler si la valeur saisie (ou choisie) est correcte ---#
    If [M:PCO1]WBPSNUM <> ""
      Read [ITP] ITP2 = [M:PCO1]WBPSNUM ; VALEUR
    Else
      #--- il faut au moins le fournisseur ---#
     GERR = 1 : GMESSAGE =mess(57,194,1)
     #Call ERREUR (mess(57,194,1)) From GESECRAN
      mkstat=2 : End
    Endif
    #-- à ce stade, fournisseur est connu dans [M:PCO1]WBPSNUM --#
    If !fstat
      Read [BPS] BPS0=[M:PCO1]WBPSNUM : If fstat  Raz [F:BPS] : Endif
      Read [ITM] ITM0=[F:ITP]ITMREF   : If fstat  Raz [F:ITM] : Endif
      [M:PCO1]WBPSNAM   =[F:BPS]BPSNAM
      [M:PCO1]WITMREF   =[F:ITP]ITMREF
      #[M:PCO1]WITMDES   =[F:ITM]ITMDES1
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PCO1]WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
      [M:PCO1]WITMDESBPS=[F:ITP]ITMDESBPS
      Affzo [PCO1]WBPSNUM, WBPSNAM, WITMREF, WITMDES, WITMDESBPS
    Else
    #--- l'article fournisseur n'existe pas, vérification si saisie d'un 'pat' ---#
    #--- attention : un 'pat' n'est valable que si fournisseur connu dans PTH1 ---#
      If instr(1,VALEUR,'*')|instr(1,VALEUR,'?')|instr(1,VALEUR,'#')|instr(1,VALEUR,'?')
      #- optimisation pour le temps de réponse -#
        Filter [ITP] Where pat(BPSNUM,[M:PCO1]WBPSNUM) & pat(ITMREFBPS,VALEUR)
        Read [ITP] ITP2 First
        Filter [ITP]
        If fstat
          mkstat=2
        Else     : #il existe au moins un article-fournisseur correspondant au 'pat'
          Effzo [PCO1]WITMDESBPS, WITMREF, WITMDES
        Endif
      Else
        mkstat=2
      Endif
    Endif
Endif
End


#------------------------------------------------#
#------------------------------------------------#
Subprog IB_WPOHNUM
GBOUT1 = mess(48,198,1)
End


#------------------------------------------------#
#------------------------------------------------#
Subprog AM_WPOHNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Read [POH]POH0=VALEUR
  If fstat
    If instr(1,VALEUR,'*')|instr(1,VALEUR,'?')|instr(1,VALEUR,'#')|instr(1,VALEUR,'?')
    #- optimisation pour le temps de réponse -#
       Filter [POH] Where pat(POHNUM,VALEUR)
       Read [POH] POH0 First
       Filter [POH]
       If fstat : mkstat=2 : Endif
    Else
       mkstat=2
    Endif
  Endif
Endif
End


#-----------------------------------------------------#
# Initialisation boutons sur no ordre fabric/sous-tr. #
# --------------------------------------------------- #
# Sélections sur ordres fabrication et sous-traitance #
#   GBOUT1 = Action SELMFG1 avec titre bouton         #
#   GBOUT2 = Action SELSCO2 avec titre bouton         #
# Tunnels    sur ordres fabrication et sous-traitance #
#   GBOUT3 = Action GOBJET1 sans titre bouton         #
#   GBOUT4 = Action GOBJET2 sans titre bouton         #
#-----------------------------------------------------#
Subprog IB_WVCRNUMORI
If GMODU(8)=2 : # Module GP actif
  GBOUT3=mess(156,197,1) : # Tunnel sur Ordre de fabrication
Else
  Raz GBOUT1, GBOUT3
Endif
GBOUT4=mess(36,701,1)    : # Tunnel sur ordre de sous-traitance
End


#---------------------------------#
# Après modif du no ordre fab/sst #
#---------------------------------#
Subprog AM_WVCRNUMORI(VALEUR)
Variable Char    VALEUR()
Local Integer TROUVE : TROUVE=0
If VALEUR<>""
  If GMODU(8)=2
    Read [MFG] MFG0=VALEUR
    If fstat
      If instr(1,VALEUR,'*')|instr(1,VALEUR,'?')|instr(1,VALEUR,'#')|instr(1,VALEUR,'?')
      #----- Optimisation pour le temps de réponse -----#
        Filter [MFG] Where pat(MFGNUM,VALEUR)
        Read [MFG] MFG0 First
        Filter [MFG]
        If fstat TROUVE=0 Else TROUVE=1 : Endif
      Else
        mkstat=2
      Endif
    Else
      # Issue X3-101765 - 2018-08-02 by MUARN : c'est un OF
      TROUVE =1
    Endif
  Endif
  If TROUVE=0
    Raz mkstat
    If !clalev([F:SCO])  Local File SCOHEAD [SCO] : Endif
    Read [SCO] SCO0=VALEUR
    If fstat
      If instr(1,VALEUR,'*')|instr(1,VALEUR,'?')|instr(1,VALEUR,'#')|instr(1,VALEUR,'?')
      #----- Optimisation pour le temps de réponse -----#
        Filter [SCO] Where pat(SCONUM,VALEUR)
        Read [SCO] SCO First
        Filter [SCO]
        If fstat  mkstat=2 : Endif
      Else
        mkstat=2
      Endif
    Endif
  Endif
Endif
End
# Issue 110325 - 2016-08-29 by SR : US 120
######################################################################################
Subprog IB_WSHIPNUM
GBOUT1 = mess(500,198,1)
End

Subprog AM_WSHIPNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Read [SHH]SHH0=VALEUR
  If fstat
    If instr(1,VALEUR,'*')|instr(1,VALEUR,'?')|instr(1,VALEUR,'#')|instr(1,VALEUR,'?')
    #- optimisation pour le temps de réponse -#
       Filter [SHH] Where pat(SHIPNUM,VALEUR) & (LEGCPY = GSOCIETE | LEGCPY = "")
       Read [SHH] SHH0 First
       Filter [SHH]
       If fstat : mkstat=2 : Endif
    Else
       mkstat=2
    Endif
  Else
   If [F:SHH]LEGCPY <> GSOCIETE & [F:SHH]LEGCPY <> ""
     mkstat = 2
   Else
     Filter [F:SHD] Where SHIPNUM = VALEUR &  LEGCPY = GSOCIETE & CLEFLG <> 2
     Look [F:SHD]SHD0 First
     Filter [F:SHD]
     If fstat :  mkstat=2 : Endif
   Endif
   If mkstat = 2 : Call ERREUR(mess(36,7750,1)) From GESECRAN : Endif
 Endif
Endif
End

Subprog IB_WBPTNUM
GBOUT1=mess(488,198,1) : # Transporteurs
End

Subprog AM_WBPTNUM(VALEUR)
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
If VALEUR<>""
  If !instr(1,VALEUR,'*') &
&    !instr(1,VALEUR,'?') &
&    !instr(1,VALEUR,'#')
    If VALEUR<>[F:BPT]BPTNUM
      Read [BPT] BPT0=VALEUR : If fstat  Raz [F:BPT] : mkstat=1 : Endif
    Endif
    If [F:BPT]BPTNUM<>""  [M:PCO1]WBPTNAM=[F:BPT]BPTNAM : Endif
  Else
    Filter [BPT] Where pat(BPTNUM,VALEUR)
    Read [BPT] BPT0 First
    Filter [BPT]
    If fstat  Raz [F:BPT] : mkstat=2 : Endif
    If [F:BPT]BPTNUM<>""  Raz [M:PCO1]WBPTNAM : Endif
  Endif
Else
  Raz [M:PCO1]WBPTNAM
Endif
Case mkstat
  When 1 : Call ERREUR(VALEUR-mess(540,199,1)) From GESECRAN : End
  When 2 : Call ERREUR(VALEUR-mess(314,194,1)) From GESECRAN : End
Endcase
Affzo [PCO1]WBPTNAM
End
# End issue 110325-120

