#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# UTITC35   Table PIVOTS                                       Module TC #
#           Mettre HEATYP a 1 pour pivot SCMDSOS                         #
##########################################################################
# VPO 08/10/10 68047
##########################################################################

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Call OUVRE_TRACE("Correction pivot SCMDSOS") From LECFIC

For [ADS]
  Call TEMPON("O") From GESECRAN
  Call MAJ_UTITC35([F:ADS]DOSSIER)
  Call TEMPOFF     From GESECRAN
Next

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

Subprog MAJ_UTITC35(PDOSSIER)
Value Char PDOSSIER

Local Integer COMPTEUR
Local Integer STAT
Local Char APPLI : APPLI = PDOSSIER

If filinfo(filpath("FIL","PIVOTS","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table
Call ECR_TRACE("UTITC35: Process Start on : "+PDOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:PIT])  <>0   Close File [PIT] : Endif
If clalev([F:PIT])  =0  Local File =PDOSSIER+".PIVOTS"   [PIT] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [PIT]
For [PIT] Where STDFLG=2 & ID="SCMDSOS" & HEATYP<>1
   Readlock [PIT] Curr
   If !fstat
      # --- alimentation des champs et réécriture enreg
      [F:PIT]HEATYP = 1
      Rewrite [F:PIT]
      If !fstat COMPTEUR += 1 Endif
   Endif
Next
Commit

Close Local File [PIT]

Call ECR_TRACE("UTITC35: "+num$(COMPTEUR)+" records processed",0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-08-07 by MAE :
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
If filinfo(filpath("FIL","PIVOTS","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table
If func DOSVUE.ISVIEW(APPLI,"PIVOTS") : End : Endif
Call MAJ_UTITC35(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If filinfo(filpath("FIL","PIVOTS","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table
# Issue 108760 - 2015-08-07 by MAE :
If func DOSVUE.ISVIEW(APPLI,"PIVOTS") : End : Endif
Call MAJ_UTITC35(APPLI)
End

