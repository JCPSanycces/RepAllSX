#<AdxTL>@(#)0.0.0.0 $Revision$ Object management NCSP
# Issue X3-69118 - 2018-01-18 by JUSYN : Create scripts for GESNCSP
# Issue X3-74449 - 2018-02-01 by BAKHA : When Plan status in 'Implement', Allow Planner to add lines,
#                                        delete lines at 'Pending' status and amend lines which are not at 'Complete' status
# Issue X3-72907 - 2018-02-15 by BAKHA : Add left list for my non-conformances to plan
# Issue X3-74466 - 2018-02-22 by JUSYN : Line text entry for actions
# Issue X3-94378 - 2018-06-06 by JUSYN : DB structure changes to seperate NCS: CCMPLANH to PLANHDR; CCMPLAND to PLANDET
#                                        CRSTATUS to NCSSTA
# Issue X3-85682 - 2018-08-07 by BAKHA : Add action type to plan lines
# Issue X3-105283 - 2018-08-29 by BAKHA : Local menu changed to misc table for transaction type

$ACTION
Case ACTION
  When "OUVRE"        : Gosub OUVRE           From SUBNCSPA
  When "SETBOUT"      : Gosub SETBOUT         From SUBNCSPA
  When "EXEBOUT"      : Gosub EXEBOUT         From SUBNCSPA
  When "LIENS"        : Gosub LIENS           From SUBNCSPA
  When "APRES_MOD"    : Gosub APRES_MOD       From SUBNCSPA
  When "AV_ANNULE"    : Gosub AV_ANNULE       From SUBNCSPA
  When "ANNULE"       : Gosub ANNULE          From SUBNCSPA
  When "ABANDON"      : Gosub ABANDON         From SUBNCSPA
  When "FILTRE"       : Gosub FILTRE          From SUBNCSPA
  When "FILGAUCHE"    : Gosub FILGAUCHE       From SUBNCSPA          # Issue X3-72907
  When "CLE_GAUCHE"   : Gosub CLE_GAUCHE      From SUBNCSPA          # Issue X3-72457 - 2018-02-19 by ALSHE : add sort to left list with view
  When "GAUCHE"       : Gosub GAUCHE          From SUBNCSPA          # Issue X3-72457 - 2018-02-19 by ALSHE : assign selected value from left list with a view to the main class
  When "MODIF"        : Gosub MODIF           From SUBNCSPA
  When "FERME"        : Gosub FERME           From SUBNCSPA
  When Default
Endcase
Return

######################################################################################
## Section automatically added (screen NCSP1) 01/19/2018 12:40:13 (JUSYN)
######################################################################################
Subprog C_NBLIG
Local Integer INDEX
Local Integer NI
Local Integer WRET # Issue X3-74466 - 2018-02-21 by JUSYN : Return code for deletion action line text

# if not QA manager, do not allow insert line or delete line
If ([M:NCSP0]NCSPLANNER <> GUSER)
    If (status = 82 or status = 73 or status = 65)
        GERR = 1
        If (status = 65)
            GMESSAGE = mess(184,193,1)   # Deletion not allowed
        Endif
        mkstat = 2
        End
    Endif
# Issue X3-74449 - allow Planner to delete lines at 'Pending' status
Elsif (status = 65)
    If ([M:NCSP1]IMPLEMENT = 2 and [M:NCSP1]LINESTATUS(nolign-1) > 1) or (find([M:NCSP0]NCSSTA,6,7))  # Issue X3-74466 - 2018-02-22 by JUSYN : No delection when completed/closed
        GERR = 1
        GMESSAGE = mess(184,193,1)   # Deletion not allowed
        mkstat = 2
        End
    Endif
# Issue X3-74449 - do not allow lines to be added if plan status is complete
Elsif ((status = 82 or status = 73) and  [M:NCSP0]PLANSTATUS =3)
  mkstat = 2
  End
Endif

If status = 82 or status = 73 Then
    # Insert line
    If [M:NCSP1]TRANTYPE(nolign-1) = "" Then # Issue X3-105283
        INDEX = fmet WPLANHDR.ADDLINE("PLANDET", [V]CST_ALASTPOS)
        If INDEX <> [V]CST_ANOTDEFINED Then
            WPLANHDR.PLANDET(INDEX).PLANID = [M:NCSP0]PLANID
            Call SHOW_GLOBAL_ACTIONS(INDEX) From SUBNCSPA
        Else
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WPLANHDR)
            GERR = 4
            mkstat = 2
            GOK = 1
            End
        Endif
        Affzo [M:NCSP1]10
    Endif
Elsif status = 65 Then
    # Issue X3-74466 - 2018-02-21 by JUSYN : Delete action line text
    If [M:NCSP1]LINTEX(nolign-1) = "" & left$(WPLANHDR.PLANDET([M:NCSP1]LINENO(nolign-1)).LINTEX,3)="NCP"
        Call SUP_CLOB(WPLANHDR.PLANDET([M:NCSP1]LINENO(nolign-1)).LINTEX,WRET) From TRTX3TEX
    Endif
    # End issue X3-74466
    # Delete a line
    IRET = fmet WPLANHDR.ADELLINE("PLANDET", WPLANHDR.PLANDET([M:NCSP1]LINENO(nolign-1)).AORDER)
    If IRET = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WPLANHDR)
        GOK = 0
        GERR = 1
        mkstat = 2
    Endif
Endif

End
######################################################################################
Subprog AP_NBLIG

# Field activate/deactivate
If (GUSER = [M:NCSP0]NCSPLANNER and [M:NCSP1]LINESTATUS(nolign-1) < 2)
    Actzo [M:NCSP1]TRANTYPE(nolign-1)
    Actzo [M:NCSP1]ACTIONER(nolign-1)
    Actzo [M:NCSP1]ACTIONID(nolign-1)
    Actzo [M:NCSP1]ACTTYP(nolign-1)    # Issue X3-85682
    Actzo [M:NCSP1]COMPLETEDATE(nolign-1)
# Issue X3-74449 - if Planner and line status not 'Complete', allow Actioner and Complete By to be amended
Elsif (GUSER = [M:NCSP0]NCSPLANNER and [M:NCSP1]LINESTATUS(nolign-1) < 3)
    Actzo [M:NCSP1]ACTIONER(nolign-1)
    Actzo [M:NCSP1]COMPLETEDATE(nolign-1)
    Grizo [M:NCSP1]TRANTYPE(nolign-1)
    Grizo [M:NCSP1]ACTIONID(nolign-1)
    Grizo [M:NCSP1]ACTTYP(nolign-1)     # Issue X3-85682
Else
    Grizo [M:NCSP1]TRANTYPE(nolign-1)
    Grizo [M:NCSP1]ACTIONER(nolign-1)
    Grizo [M:NCSP1]ACTIONID(nolign-1)
    Grizo [M:NCSP1]ACTTYP(nolign-1)     # Issue X3-85682
    Grizo [M:NCSP1]COMPLETEDATE(nolign-1)
Endif

# LINESTATUS activate/deactivate
# Only active when NCS status is Implement, Planning Complete is Yes, and actioner
If ([M:NCSP0]NCSSTA = 5 and [M:NCSP0]PLANSTATUS = 2 and GUSER = [M:NCSP1]ACTIONER(nolign-1))
    Actzo [M:NCSP1]LINESTATUS(nolign-1)
Else
    Grizo [M:NCSP1]LINESTATUS(nolign-1)
Endif

# COMMENT activate/deactivate
# Issue X3-74449- if Planner and line status not 'Complete', allow comment to be amended
If (GUSER = [M:NCSP0]NCSPLANNER and [M:NCSP1]LINESTATUS(nolign-1) < 3)
    Actzo [M:NCSP1]COMMENT(nolign-1)
Elsif ([M:NCSP0]PLANSTATUS = 2 and GUSER = [M:NCSP1]ACTIONER(nolign-1) and [M:NCSP0]NCSSTA = 5)
    Actzo [M:NCSP1]COMMENT(nolign-1)
Else
    Grizo [M:NCSP1]COMMENT(nolign-1)
Endif

End
######################################################################################
Subprog AM_TRANTYPE(VALEUR)
Variable Char VALEUR() # Issue X3-105283

WPLANHDR.PLANDET([M:NCSP1]LINENO(nolign-1)).TRANTYPE = VALEUR
Call GET_ERRORS(WPLANHDR) From SUBNCSPA
If GERR = 1 Then
    WPLANHDR.PLANDET([M:NCSP1]LINENO(nolign-1)).TRANTYPE = WPLANHDR.PLANDET([M:NCSP1]LINENO(nolign-1)).snapshot.TRANTYPE
    GERR = 1
    mkstat = 2
    End
Else
    Call SHOW_GLOBAL_ACTIONS([M:NCSP1]LINENO(nolign-1)) From SUBNCSPA
Endif

Affzo [M:NCSP1]1-99

End
