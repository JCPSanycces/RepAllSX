######################################################################################

# Issue X3-74466 - 2018-02-22 by JUSYN : treatment line entry or line display
######################################################################################
## Section automatically added (screen NCSP1) 02/22/2018 08:29:02 (JUSYN)
######################################################################################
Subprog IB_NBLIG

GBOUT1 = ""
GBOUT2 = ""

If (find([M:NCSP1]LINESTATUS(nolign-1),1,2) and !find([M:NCSP0]NCSSTA,6,7) and GUSER = [M:NCSP0]NCSPLANNER)
    GBOUT1 = mess(31,3702,1)    # Line text entry
Elsif ([M:NCSP1]LINTEX(nolign-1) <> "")
    GBOUT2 = mess(32,3702,1)    # Line text display
Endif

End
######################################################################################
# End issue X3-74466

# Issue X3-97070 - 2018-06-19 by JUSYN : check for valid entity-action combination
######################################################################################
Funprog CHECK_TYPE_ACTION_COMBI()
Local Integer WRET

WRET = 0
If [M:NCSP1]TRANTYPE(nolign-1) = "" or [M:NCSP1]ACTIONID(nolign-1) = "" Then # Issue X3-105283
    End WRET
Endif

Read[F:PLAACT]PLAACT0=[M:NCSP1]ACTIONID(nolign-1)
If fstat
    WRET = 1
Else
    If [M:NCSP1]TRANTYPE(nolign-1) = [F:PLAACT]TRANTYPE & [M:NCSP1]ACTIONID(nolign-1) = [F:PLAACT]ACTIONID
        WRET = 0   # Okay
    Else
        WRET = 1   # Combination not valid
    Endif
Endif

End WRET
# End issue X3-97070
######################################################################################

