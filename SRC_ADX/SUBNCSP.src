######################################################################################
Subprog AM_LINESTATUS(VALEUR)
Variable Integer VALEUR

WPLANHDR.PLANDET([M:NCSP1]LINENO(nolign-1)).LINESTATUS = VALEUR
Call GET_ERRORS(WPLANHDR) From SUBNCSPA
If GERR = 1 Then
    WPLANHDR.PLANDET([M:NCSP1]LINENO(nolign-1)).LINESTATUS = WPLANHDR.PLANDET([M:NCSP1]LINENO(nolign-1)).snapshot.LINESTATUS
    GERR = 1
    mkstat = 2
    End
Else
    Call SHOW_GLOBAL_ACTIONS([M:NCSP1]LINENO(nolign-1)) From SUBNCSPA
Endif

# If line Status is Pending then reset Start and End dates,
# If line Status is In progress then set Start date to today's date and reset End date,
# If line Status is Completed then set Start date to today's date (if not set) and End date to today's date ...
If ([M:NCSP1]LINESTATUS = 1)
    [M:NCSP1]STARTDATE = [0/0/0]
    [M:NCSP1]ENDDATE = [0/0/0]
Elsif ([M:NCSP1]LINESTATUS = 2)
    [M:NCSP1]STARTDATE = date$
    [M:NCSP1]ENDDATE = [0/0/0]
Else
    If ([M:NCSP1]STARTDATE = [0/0/0])
      [M:NCSP1]STARTDATE = date$
    Endif
    [M:NCSP1]ENDDATE = date$
Endif

Affzo [M:NCSP1]1-99

End
