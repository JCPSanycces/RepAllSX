End
# Issue X3-97070 - 2018-06-19 by JUSYN : check for valid entity-action combination
######################################################################################

Subprog C_ACTIONID(VALEUR)
Variable Char    VALEUR()
Local Integer WRET

WRET = 0
[M:NCSP1]ACTIONID(nolign-1) = VALEUR
WRET = func CHECK_TYPE_ACTION_COMBI()

If WRET
    mkstat = 2
    GMESSAGE = func AFNC.MES2(mess(567,194,1),[M:NCSP1]TRANTYPE(nolign-1),[M:NCSP1]ACTIONID(nolign-1))  # THE $1$/$2$ COMBINATION IS not CORRECT.
Endif

End
# End issue X3-97070

