#<AdxTL>@(#)8.0.0.0 $Revision$
#Local Char PARAM(50)(1..3) , VALEUR(50)
#Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
#End

$ACTION
Case ACTION
  When "FIN": Gosub FERME
Endcase
Return

$OUVRE
  If clalev([F:FGR])=0   : Local File FACGROUP   [FGR]  : Endif
  If clalev([F:FCY])=0   : Local File FACILITY   [FCY]  : Endif
  If clalev([F:CPY])=0   : Local File COMPANY    [CPY]  : Endif
  If clalev([F:GAC])=0   : Local File GACCOUNT   [GAC]  : Endif
  If clalev([F:TCU])=0   : Local File TABCUR     [TCU]  : Endif
  If clalev([F:GCM])=0   : Local File GACM       [GCM]  : Endif
  If clalev([F:LED])=0   : Local File GLED       [LED]  : Endif
  If clalev([F:BAL])=0   : Local File BALANCE    [BAL]  : Endif
  If clalev([F:PER])=0   : Local File PERIOD     [PER]  : Endif
  If clalev([F:DAE])=0   : Local File GACCENTRYD [DAE]  : Endif
  If clalev([F:HAE])=0   : Local File GACCENTRY  [HAE]  : Endif
  If clalev([F:BPL])=0   : Local File BANKPOSD   [BPL]  : Endif
  If clalev([F:BAN])=0   : Local File BANK       [BAN]  : Endif
  If clalev([F:BGR])=0   : Local File BGRBAN     [BGR]  : Endif
  If clalev([F:CFODD])=0 : Local File CFODUDDATE [CFODD]: Endif
Return

$FERME
Kill GNBAN, GNSITE, GTBAN, GSIT

Return

##########################################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

  Local Char  PARAM(30), SOC(GLONCPY), SITE(GLONFCY), BANKGR(GLONBGR), BANK(GLONBAN), DEV(GLONCUR), DEVCUR(GLONCUR), CFOCRIT(13), ETAT(15), SCOLDES(20)(0..15)
  Local Date SOLDAT, FINDAT, PERDAT(16)  #(1..)
  Local Integer LEVG, DLEV, PERLEV, CHGTYP, NBPER, IMP, OK
  If clalev([F:CPY])=0   : Local File COMPANY    [CPY]  : Endif

  Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT) From ETAT
  Call GETPARAM("soc",NBPAR,PARAMETRE,PARAM) From ETAT: SOC=PARAM
    Read [CPY]CPY0=PARAM: If !fstat: DEV=[F:CPY]ACCCUR: Endif
  Call GETPARAM("site",NBPAR,PARAMETRE,SITE) From ETAT
  Call GETPARAM("grpban",NBPAR,PARAMETRE,BANKGR) From ETAT
  Call GETPARAM("ban",NBPAR,PARAMETRE,BANK) From ETAT
  If BANKGR="" and BANK=""
    Call AVERTIR(mess(45,120,1)+mess(10,123,1),OK) From GESECRAN
  Endif
  Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM) From ETAT:  SOLDAT=gdat$(val(right$(PARAM,7)),val(mid$(PARAM,5,2)),val(left$(PARAM,4)))
  Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM) From ETAT:  FINDAT=gdat$(val(right$(PARAM,7)),val(mid$(PARAM,5,2)),val(left$(PARAM,4)))
  Call GETPARAM("grplev",NBPAR,PARAMETRE,PARAM) From ETAT:  LEVG=val(PARAM)
  Call GETPARAM("detlev",NBPAR,PARAMETRE,PARAM) From ETAT:  DLEV=val(PARAM)
  Call GETPARAM("period",NBPAR,PARAMETRE,PARAM) From ETAT:  PERLEV=val(PARAM)
  Call GETPARAM("cur",NBPAR,PARAMETRE,PARAM) From ETAT   :
    If DEV=""   : DEV   =PARAM : Endif
    If DEVCUR="": DEVCUR=PARAM : Endif
  Call GETPARAM("typrat",NBPAR,PARAMETRE,PARAM) From ETAT:  CHGTYP=val(PARAM)
  Call GETPARAM("typgac",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT ="1" :  Else:  CFOCRIT ="0" : Endif           #accounting
  Call GETPARAM("typdud",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT +="1" :  Else:  CFOCRIT+="0" : Endif          #due date
  Call GETPARAM("cfopq",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT +="1" :  Else:  CFOCRIT +="0" : Endif          #RFQs
  Call GETPARAM("cfopc",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT +="1" :  Else:  CFOCRIT +="0" : Endif          #purchasing contract
  Call GETPARAM("cfopo",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT +="1" :  Else:  CFOCRIT +="0" : Endif          #purchase orders
  Call GETPARAM("cforn",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT +="1" :  Else:  CFOCRIT +="0" : Endif          #receipts
  Call GETPARAM("cfosq",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT +="1" :  Else:  CFOCRIT +="0" : Endif          #quotes
  Call GETPARAM("cfoso",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT +="1" :  Else:  CFOCRIT +="0" : Endif          #sales orders
  Call GETPARAM("cfosc",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT +="1" :  Else:  CFOCRIT +="0" : Endif          #sales contract
  Call GETPARAM("cfocm",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT +="1" :  Else:  CFOCRIT +="0" : Endif          #CRM contract
  Call GETPARAM("cfodn",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT +="1" :  Else:  CFOCRIT +="0" : Endif          #deliveries
  Call GETPARAM("cfolea",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT +="1" :  Else:  CFOCRIT +="0" : Endif          #leasing
  Call GETPARAM("cfome",NBPAR,PARAMETRE,PARAM) From ETAT
  If val(PARAM)=1:   CFOCRIT +="1" :  Else:  CFOCRIT +="0" : Endif          #manual forecast

  IMP=1

  If !clalev([M:BTR1]): Local Mask CONSBTR1 [BTR1]: Endif
  If [M:BTR1]NBLIG=0
    Call WRITE_TMP (SOC,SITE,BANKGR,BANK,SOLDAT,FINDAT,LEVG,DLEV,PERLEV,DEV,DEVCUR,CHGTYP,CFOCRIT,IMP)
  Endif

End

##########################################################################################################
Subprog WRITE_TMP (SOC,SITE,BANKGR,BANK,SOLDAT,FINDAT,LEVG,DLEV,PERLEV,DEV,DEVCUR,CHGTYP,CFOCRIT,IMP)
Value Char SOC
Value Char SITE
Value Char BANKGR
Value Char BANK
Value Date SOLDAT
Value Date FINDAT
Value Integer LEVG
Value Integer DLEV
Value Integer PERLEV
Value Char DEV
Value Char DEVCUR
Value Integer CHGTYP
Value Char CFOCRIT
Value Integer IMP

Gosub OUVRE
Gosub GRPCPY

#Write detail table
Gosub TR0
Gosub TR1

Gosub TRT

End

$GRPCPY
Local Char COLLEC(4), COMPTE(GLONGAC), TIERS(GLONGAC), FILBAN(GLONBAN)(1..)
Local Integer I, F, OK, GRP, COURS, SENS,FILSTA
Local Decimal  SOLDE, RESULACC(1..), RESULDUD(1..), TOTACC, TOTDUD
Global Char GTBAN(GLONBAN)(1..), GSIT(GLONFCY)(1..)
Global Shortint GNBAN, GNSITE

Raz RESULACC, RESULDUD, TOTACC, TOTDUD
GNSITE = 0

Call LECTURE("CPY",SOC,"") From CONTOBJ
  GRP=([F:CPY]CPYLEGFLG=1)

  If SITE=""
    For [FGR]FGR0 Where CPY = SOC
      Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
      If [F:FCY]FINFLG=2
        GNSITE+=1
        GSIT(GNSITE) = [F:FGR]FCY
      Endif
    Next
  Else GNSITE=1: GSIT(1)=SITE
  Endif

  If BANKGR<>""
    GNBAN=0
    Read[BGR]BGR0= BANKGR
    For I=0 To dim([F:BGR]BAN)-1
      If [F:BGR]BAN(I)<>""
        GNBAN+=1
        GTBAN(GNBAN) = [F:BGR]BAN(I)
      Endif
    Next
  Else
    GNBAN=1: GTBAN(GNBAN)=BANK
  Endif

    For I=1 To GNBAN
      If IMP=0: Call OTHERCRIT(GTBAN(I),FILSTA,1) From CNSBTRSTD: Else FILSTA=0: Endif
      If FILSTA=1: Raz GTBAN(I): Endif
    Next

Return

$TR0
  # Delete of the working table before leave the inquiry
  Trbegin [BPL]
    Delete [BPL] Where CNSUSR=GUSER
    If fstat=1: GOK=-1: Endif
    If   GOK<0 : Goto ROLL_TR1
    Elsif !GOK : Goto AB_TR1
    Endif
  Commit

Return

$TR1
  Local Char WSOC(GLONCPY)(1..),WSIT(GLONFCY)(1..),WBANKGR(GLONBGR)(1..),WBANK(GLONBAN)(1..), WTYPFRT(25)(1..), CRITDUD(250)
  Local Char CPYSOC(GLONCPY), CRITDUD1(250), SCOLDES(20)(0..15), WCUR(GLONCUR)
  Local Date WDUDDAT(1..), PERDAT(15)(1..)
  Local Integer I, J, K, D, L, OKK, STAT, NBPER, WPER(16)(1..)
  Local Decimal WAMTCUR1(1..), WAMTCUR2(1..), WAMTCUR3(1..), WAMTCUR4(1..), WAMTCUR5(1..)
  Local Decimal WAMTCUR6(1..), WAMTCUR7(1..), WAMTCUR8(1..), WAMTCUR9(1..), WAMTCUR10(1..)
  Local Decimal WAMTCUR11(1..), WAMTCUR12(1..), WAMTCUR13(1..), WAMTCUR14(1..), WAMTCUR15(1..)
  Local Decimal WTOTACC, WDEVAMT

  If PERLEV=3: NBPER=12 :Else: NBPER=14:  Endif

  Gosub CAL_PERIOD
  Onerrgo ERR_CRITERE

  If left$(CFOCRIT,1)="1"   # calculating initial account balance first column
    For I=1 To GNBAN
      OKK=0
      If GTBAN(I)<>""
        Read [BAN]BAN0=GTBAN(I)
        If !fstat:
          COMPTE=[F:BAN]BANACC: TIERS=[F:BAN]BANBPR: CPYSOC=[F:BAN]CPY: If [F:BAN]CUR<>"": WCUR=[F:BAN]CUR : Endif
          If GRP=0 and [F:BAN]CPY<>CPYSOC: OKK=1: Endif
          If OKK=0
           For J=1 To GNSITE
            Raz SOLDE, SENS
            Read [FCY]FCY0=GSIT(J)
            If CPYSOC=[F:FCY]LEGCPY : SITE=GSIT(J)
              Call SOLDEBAL(WCUR,CPYSOC,SITE,COMPTE,TIERS,SENS,SOLDAT,SOLDE,IMP)
              WTOTACC=SOLDE: GSIT(J)=SITE
              If DEVCUR<>WCUR
               Call CONVERT(WCUR,DEVCUR,DEV,CHGTYP,SOLDAT,SOLDE,WTOTACC,STAT) From TRTDEV
              Endif
              If SENS=2: WTOTACC*=-1: Endif
              WSOC(J)    =  CPYSOC
              WSIT(J)    =  GSIT(J)
              WBANKGR(J)  =  BANKGR
              If LEVG=3:  WBANK(J)   =  GTBAN(I) Else:  WBANK(J)="" : Endif
              WTYPFRT(J) =  "*BA"    #Bank balance
              WDUDDAT(J) =  SOLDAT-1
              WAMTCUR1(J)=  WTOTACC
              K=J
              Gosub WRITE_REC
            Endif
          Next
         Endif
        Endif
      Endif
    Next
  Endif

  CPYSOC=SOC
  If mid$(CFOCRIT,2,1)="1"
    For I=1 To GNBAN
      OKK=0
      Read [BAN]BAN0=GTBAN(I)
      If GRP=1: CPYSOC=[F:BAN]CPY
      Else: If [F:BAN]CPY<>CPYSOC: OKK=1: Endif
      Endif
      If OKK=0
         For J=1 To GNSITE
          Read [FCY]FCY0=GSIT(J)
          If [F:FCY]LEGCPY=CPYSOC
            Raz OKK, CRITDUD
            CRITDUD ="CPY='"+CPYSOC+"' & FCY='"+GSIT(J)+"' & CFOBAN='"+GTBAN(I)+"' & CFODAT<["+format$(GFMD,SOLDAT)+"] & AMTCUR<>PAYCUR"
            CRITDUD-="& (TYP>'*CM99')"
            Filter [CFODD] Where evalue(CRITDUD)  Order By TYP;CFODAT Asc
            For [CFODD]
              If IMP=0: Call OTHERCRIT([F:CFODD]NUM,FILSTA,3) From CNSBTRSTD: Else FILSTA=0: Endif
               If FILSTA=0
                If OKK=0: OKK=1: Endif
                WDEVAMT=([F:CFODD]AMTCUR-[F:CFODD]PAYCUR)*[F:CFODD]SNS
                If WDEVAMT<>0
                  If [F:CFODD]CUR<>DEVCUR
                    Call CONVERT([F:CFODD]CUR,DEVCUR,DEV,CHGTYP,[F:CFODD]CFODAT,[F:CFODD]AMTCUR,WDEVAMT,STAT) From TRTDEV
                    WDEVAMT=WDEVAMT*[F:CFODD]SNS   # SAM 116076
                  Endif
                  WTYPFRT(J)="*BB"
                  WDUDDAT(J)=SOLDAT-1
                  Gosub ADD_PERIOD
                  If DLEV>1:  K=D: Gosub WRITE_REC: Endif
                Endif
              Endif
            Next
            Filter [CFODD]
            If DLEV=1 and OKK=1: K=J: Gosub WRITE_REC: Endif
          Endif
        Next
      Endif
    Next
  Endif

  CPYSOC=SOC
  For I=1 To GNBAN
    OKK=0
    Read [BAN]BAN0=GTBAN(I)
    If GRP=1: CPYSOC=[F:BAN]CPY
    Else: If [F:BAN]CPY<>CPYSOC: OKK=1: Endif
    Endif
    If OKK=0
      For J=1 To GNSITE
       Read [FCY]FCY0=GSIT(J)
       If [F:FCY]LEGCPY=CPYSOC
        Raz OKK, CRITDUD, CRITDUD1
        CRITDUD ="CPY='"+CPYSOC+"'& FCY='"+GSIT(J)+"' & CFOBAN='"+GTBAN(I)+"' & CFODAT>=["+format$(GFMD,SOLDAT)+"]"
        CRITDUD -="& CFODAT<=["+format$(GFMD,FINDAT)+"] & AMTCUR<>PAYCUR"
        CRITDUD1="1=1"
        If instr(2,CFOCRIT,"1")<>0
          CRITDUD1= "("
          If mid$(CFOCRIT,2,1)="1" : CRITDUD1 += "TYP>'*CM99'"          : Endif                #Due date
          If mid$(CFOCRIT,3,1)="1"
            If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM01'":  Else CRITDUD1 -= "TYP='*CM01'":  Endif
          Endif                                                                                #RFQ´s
          If mid$(CFOCRIT,4,1)="1"
            If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM02'":  Else CRITDUD1 -= "TYP='*CM02'":  Endif
          Endif                                                                                 #Purchasing contract
          If mid$(CFOCRIT,5,1)="1"
            If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM03'":  Else CRITDUD1 -= "TYP='*CM03'":  Endif
          Endif                                                                                 #Purchase orders
          If mid$(CFOCRIT,6,1)="1"
            If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM04'":  Else CRITDUD1 -= "TYP='*CM04'":  Endif
          Endif                                                                                 #Receipts
          If mid$(CFOCRIT,7,1)="1"
            If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM05'":  Else CRITDUD1 -= "TYP='*CM05'":  Endif
          Endif                                                                                 #Quotes
          If mid$(CFOCRIT,8,1)="1"
            If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM06'":  Else CRITDUD1 -= "TYP='*CM06'":  Endif
          Endif                                                                                 #Sales orders
          If mid$(CFOCRIT,9,1)="1"
            If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM07'":  Else CRITDUD1 -= "TYP='*CM07'":  Endif
          Endif                                                                                 #Sales contract
          If mid$(CFOCRIT,10,1)="1"
            If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM08'":  Else CRITDUD1 -= "TYP='*CM08'":  Endif
          Endif                                                                                 #CRM contract
          If mid$(CFOCRIT,11,1)="1"
            If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM09'":  Else CRITDUD1 -= "TYP='*CM09'":  Endif
          Endif                                                                                 #Deliveries
          If mid$(CFOCRIT,12,1)="1"
            If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM10'":  Else CRITDUD1 -= "TYP='*CM10'":  Endif
          Endif                                                                                 #Leasing
          CRITDUD1 +=')'
          If mid$(CFOCRIT,13,1)="1":
            If len(CRITDUD1)>1: CRITDUD1 -= "or (TYP>'*CM10' & TYP<'*CM99')": Else CRITDUD1 -= "(TYP>'*CM10' & TYP<'*CM99')": Endif
          Endif                                                                                  #Manual forecast
        Endif

        If CRITDUD1="1=1": Break: Endif
        If left$(CRITDUD1,2)="()": CRITDUD1=mid$(CRITDUD1,7,len(CRITDUD1)): Endif

        Filter [CFODD] Where evalue(CRITDUD) & evalue(CRITDUD1) Order By TYP;CFODAT Asc

        For [CFODD]
          If IMP=0: Call OTHERCRIT([F:CFODD]NUM,FILSTA,3) From CNSBTRSTD: Else FILSTA=0: Endif
          If FILSTA=0
            If OKK=0: OKK=1: Endif
              WDEVAMT=([F:CFODD]AMTCUR-[F:CFODD]PAYCUR)*[F:CFODD]SNS
              If WDEVAMT<>0
                If [F:CFODD]CUR<>DEVCUR
                  Call CONVERT([F:CFODD]CUR,DEVCUR,DEV,CHGTYP,[F:CFODD]CFODAT,[F:CFODD]AMTCUR,WDEVAMT,STAT) From TRTDEV
                  WDEVAMT=WDEVAMT*[F:CFODD]SNS    # SAM 116076
                Endif
                Gosub ADD_PERIOD
                If DLEV>1:  K=D: Gosub WRITE_REC: Endif
            Endif
          Endif
        Next
        Filter [CFODD]
        If DLEV=1 and OKK=1 : K=J: WTYPFRT(K)="*BT": Gosub WRITE_REC: Endif
      Endif
     Next
    Endif
  Next

  Return

$TRT
  #udpate balance initial and Total balance
#  Local Char WENDSOC(GLONCPY)(100),WENDFCY(GLONFCY)(100),WENDGRPBAN(5)(100),WENDBAN(GLONBAN)(100) # SAM 118717
  Local Char WENDSOC(GLONCPY)(100),WENDFCY(GLONFCY)(100),WENDGRPBAN(GLONBGR)(100),WENDBAN(GLONBAN)(100) # SAM 118717
  Local Decimal WAMTENDBAL(100),WAMTENDBAL1(100),WAMTENDBAL2(100),WAMTENDBAL3(100),WAMTENDBAL4(100),WAMTENDBAL5(100)
  Local Decimal WAMTENDBAL6(100),WAMTENDBAL7(100),WAMTENDBAL8(100),WAMTENDBAL9(100),WAMTENDBAL10(100),WAMTENDBAL11(100)
  Local Decimal WAMTENDBAL12(100),WAMTENDBAL13(100), WAMTENDBAL14(100)
  Local Shortint WREG
  If clalev([XBPL])=0: Local File BANKPOSD [XBPL]: Endif

  Trbegin [BPL]
  Filter [BPL] Where TYPFRT="*BA" and CNSUSR=GUSER  Order By BAN  #(X3-45708) CONSBTR - Bank group

  For [BPL]
    For J=0 To NBPER
#      If [M:BTR0]LEVELA=3 and [M:BTR0]LEVELD=2 and [F:BPL]GRPBAN<>""  #(X3-45708) CONSBTR - Bank group
      If [M:BTR0]LEVELA=3   # Ini X3-61522
        If [M:BTR0]FCY<>""
          Filter [XBPL] Where CNSUSR=GUSER & CPY=[F:BPL]CPY & FCY=[F:BPL]FCY & GRPBAN=[F:BPL]GRPBAN  & BAN=[F:BPL]BAN
        Else
          Filter [XBPL] Where CNSUSR=GUSER & CPY=[F:BPL]CPY  & GRPBAN=[F:BPL]GRPBAN  & BAN=[F:BPL]BAN
        Endif               # End X3-61522
      Else
        Filter [XBPL] Where CNSUSR=GUSER & CPY=[F:BPL]CPY & FCY=[F:BPL]FCY & GRPBAN=[F:BPL]GRPBAN # & BAN=[F:BPL]BAN  # SAM 117462
      Endif
      WENDSOC(WREG)   =[F:BPL]CPY
      WENDFCY(WREG)   =[F:BPL]FCY
      WENDGRPBAN(WREG)=[F:BPL]GRPBAN
      WENDBAN(WREG)   =[F:BPL]BAN
      Case J:
        When 0 :
          For [XBPL]
            [F:BPL]AMTCUR(1) += [F:XBPL]AMTCUR(0)
          Next
          WAMTENDBAL(WREG)=[F:BPL]AMTCUR(1)
        When 1 :
          [F:BPL]AMTCUR(2) += [F:BPL]AMTCUR(1)
          For [XBPL]
            [F:BPL]AMTCUR(2) += [F:XBPL]AMTCUR(1)
          Next
          WAMTENDBAL1(WREG)=[F:BPL]AMTCUR(2)
        When 2 :
          [F:BPL]AMTCUR(3) += [F:BPL]AMTCUR(2)
          For [XBPL]
            [F:BPL]AMTCUR(3) += [F:XBPL]AMTCUR(2)
          Next
          WAMTENDBAL2(WREG)=[F:BPL]AMTCUR(3)
        When 3 :
          [F:BPL]AMTCUR(4) += [F:BPL]AMTCUR(3)
          For [XBPL]
            [F:BPL]AMTCUR(4) += [F:XBPL]AMTCUR(3)
          Next
          WAMTENDBAL3(WREG)=[F:BPL]AMTCUR(4)
        When 4 :
          [F:BPL]AMTCUR(5) += [F:BPL]AMTCUR(4)
          For [XBPL]
            [F:BPL]AMTCUR(5) += [F:XBPL]AMTCUR(4)
          Next
          WAMTENDBAL4(WREG)=[F:BPL]AMTCUR(5)
        When 5 :
          [F:BPL]AMTCUR(6) += [F:BPL]AMTCUR(5)
          For [XBPL]
            [F:BPL]AMTCUR(6) += [F:XBPL]AMTCUR(5)
          Next
          WAMTENDBAL5(WREG)=[F:BPL]AMTCUR(6)
        When 6 :
          [F:BPL]AMTCUR(7) += [F:BPL]AMTCUR(6)
          For [XBPL]
            [F:BPL]AMTCUR(7) += [F:XBPL]AMTCUR(6)
          Next
          WAMTENDBAL6(WREG)=[F:BPL]AMTCUR(7)
        When 7 :
          [F:BPL]AMTCUR(8) += [F:BPL]AMTCUR(7)
          For [XBPL]
            [F:BPL]AMTCUR(8) += [F:XBPL]AMTCUR(7)
          Next
          WAMTENDBAL7(WREG)=[F:BPL]AMTCUR(8)
        When 8 :
          [F:BPL]AMTCUR(9) += [F:BPL]AMTCUR(8)
          For [XBPL]
            [F:BPL]AMTCUR(9) += [F:XBPL]AMTCUR(8)
          Next
          WAMTENDBAL8(WREG)=[F:BPL]AMTCUR(9)
        When 9 :
          [F:BPL]AMTCUR(10) += [F:BPL]AMTCUR(9)
          For [XBPL]
            [F:BPL]AMTCUR(10) += [F:XBPL]AMTCUR(9)
          Next
          WAMTENDBAL9(WREG)=[F:BPL]AMTCUR(10)
        When 10 :
          [F:BPL]AMTCUR(11) += [F:BPL]AMTCUR(10)
          For [XBPL]
            [F:BPL]AMTCUR(11) += [F:XBPL]AMTCUR(10)
          Next
          WAMTENDBAL10(WREG)=[F:BPL]AMTCUR(11)
        When 11 :
          [F:BPL]AMTCUR(12) += [F:BPL]AMTCUR(11)
          For [XBPL]
            [F:BPL]AMTCUR(12) += [F:XBPL]AMTCUR(11)
          Next
          WAMTENDBAL11(WREG)=[F:BPL]AMTCUR(12)
        When 12 :
          If NBPER>12
            [F:BPL]AMTCUR(13) += [F:BPL]AMTCUR(12)
            For [XBPL]
              [F:BPL]AMTCUR(13) += [F:XBPL]AMTCUR(12)
            Next
            WAMTENDBAL12(WREG)=[F:BPL]AMTCUR(13)
          Else
            WAMTENDBAL12(WREG) += [F:BPL]AMTCUR(12)
            For [XBPL]
              WAMTENDBAL12(WREG) += [F:XBPL]AMTCUR(12)
            Next
          Endif
        When 13 :
          If NBPER>12
            [F:BPL]AMTCUR(14) += [F:BPL]AMTCUR(13)
            For [XBPL]
              [F:BPL]AMTCUR(14) += [F:XBPL]AMTCUR(13)
            Next
            WAMTENDBAL13(WREG)=[F:BPL]AMTCUR(14)
          Endif
      Endcase
    Next
    WREG+=1
    Rewrite [BPL]
    If fstat>0
      GOK=0 : Call FSTA("BPL") From GLOCK : Break
    Endif
  Next
  Filter [BPL]
  Commit
  Close Local File [XBPL]

  If clalev([XBPL])=0: Local File BANKPOSD [XBPL]: Endif
  Trbegin [XBPL]

  For I=0 To WREG-1
    Raz [F:XBPL]
    [F:XBPL]CNSUSR     = GUSER
    [F:XBPL]CPY        = WENDSOC(I)
    [F:XBPL]FCY        = WENDFCY(I)
    [F:XBPL]GRPBAN     = WENDGRPBAN(I)
    [F:XBPL]BAN        = WENDBAN(I)
    [F:XBPL]TYPFRT     = "*DA"
    [F:XBPL]DUDDAT     = SOLDAT
    [F:XBPL]AMTCUR(0)  = WAMTENDBAL(I)
    [F:XBPL]AMTCUR(1)  = WAMTENDBAL1(I)
    [F:XBPL]AMTCUR(2)  = WAMTENDBAL2(I)
    [F:XBPL]AMTCUR(3)  = WAMTENDBAL3(I)
    [F:XBPL]AMTCUR(4)  = WAMTENDBAL4(I)
    [F:XBPL]AMTCUR(5)  = WAMTENDBAL5(I)
    [F:XBPL]AMTCUR(6)  = WAMTENDBAL6(I)
    [F:XBPL]AMTCUR(7)  = WAMTENDBAL7(I)
    [F:XBPL]AMTCUR(8)  = WAMTENDBAL8(I)
    [F:XBPL]AMTCUR(9)  = WAMTENDBAL9(I)
    [F:XBPL]AMTCUR(10) = WAMTENDBAL10(I)
    [F:XBPL]AMTCUR(11) = WAMTENDBAL11(I)
    [F:XBPL]AMTCUR(12) = WAMTENDBAL12(I)
    [F:XBPL]AMTCUR(13) = WAMTENDBAL13(I)
    [F:XBPL]AMTCUR(14) = WAMTENDBAL13(I)
    Case LEVG
      When 1: [F:XBPL]INDLNK=WENDSOC(I)+[F:XBPL]TYPFRT+WENDGRPBAN(I)+WENDBAN(I)+WENDFCY(I)+FINDAT
      When 2: [F:XBPL]INDLNK=WENDGRPBAN(I)+[F:XBPL]TYPFRT+WENDSOC(I)+WENDFCY(I)+WENDBAN(I)+FINDAT
      When 3: [F:XBPL]INDLNK=WENDBAN(I)+[F:XBPL]TYPFRT+WENDSOC(I)+WENDFCY(I)+WENDGRPBAN(I)+FINDAT
      When 4: [F:XBPL]INDLNK=WENDFCY(I)+[F:XBPL]TYPFRT+WENDSOC(I)+WENDGRPBAN(I)+WENDBAN(I)+FINDAT
    Endcase
    Write [XBPL]
    If fstat>0
      GOK=0 : Call FSTA("XBPL") From GLOCK : Break
    Endif
  Next

  Commit
  Close Local File [XBPL]
Return

$CAL_PERIOD
Local Integer J, OKK
Local Date DATEWEEK
Raz OKK,J
DATWEEK= SOLDAT
SCOLDES(0)=mess(7,2,1)  # Previous
PERDAT(0)=SOLDAT-1

 Case PERLEV
    When 1:  For H=1 To NBPER
               SCOLDES(H)=  day$(SOLDAT+H)-num$(day(SOLDAT+H))
               PERDAT(H)=SOLDAT+(H-1)
               If PERDAT(H)>=FINDAT: PERDAT(H)=FINDAT: Break: Endif
              Next
    When 2:  For H=1 To NBPER
               If week(SOLDAT)+H-1>week(gdat$(31,12,year(SOLDAT))):
                 If OKK=1
                   J+=1
                 Else
                   OKK=1: DATWEEK=gdat$(01,01,year(SOLDAT)+1): J=1
                 Endif
               Else J=H
               Endif
               SCOLDES(H)  =mess(4,47,1)-num$(week(DATWEEK)+J-1)+"-"+num$(year(DATWEEK))   # Week
               If H=1: PERDAT(H)=SOLDAT+(7-dayn(SOLDAT))
               Else: PERDAT(H)=PERDAT(H-1)+7
               Endif
               If PERDAT(H)>=FINDAT: PERDAT(H)=FINDAT: Break: Endif
             Next

    When 3:  For H=1 To NBPER
                # Mouth
               If H=1: PERDAT(H)=eomonth(SOLDAT): SCOLDES(H)=  month$(val(mid$((SOLDAT),5,2))+H-1)+"-"+num$(year(SOLDAT))
               Else:  PERDAT(H)= eomonth(addmonth(PERDAT(H-1),1))
                      SCOLDES(H)=  month$(val(mid$((SOLDAT),5,2))+H-1)+"-"+num$(year(addmonth(PERDAT(H-1),1)))
               Endif
               If PERDAT(H)>=FINDAT: PERDAT(H)=FINDAT: Break: Endif
             Next
  Endcase
Return

$WRITE_REC
  Local Integer OK
  Raz [BPL]
  OK=0
  Trbegin [BPL]
    Case LEVG
      When 1 :
        If WTYPFRT(K)="*BA":
          Filter [BPL] Where CNSUSR=GUSER & CPY=WSOC(K) & FCY=WSIT(K) & GRPBAN=WBANKGR(K) & BAN=WBANK(K) & TYPFRT=WTYPFRT(K)
        Else
          Filter [BPL] Where CNSUSR=GUSER & CPY=WSOC(K) & GRPBAN=WBANKGR(K) & BAN=WBANK(K) & TYPFRT=WTYPFRT(K)
        Endif
      When 2 :
        If WTYPFRT(K)="*BA":
          Filter [BPL] Where CNSUSR=GUSER & CPY=WSOC(K) & FCY=WSIT(K) & GRPBAN=WBANKGR(K) & BAN=WBANK(K) & TYPFRT=WTYPFRT(K)
        Else
          Filter [BPL] Where CNSUSR=GUSER & GRPBAN=WBANKGR(K) & TYPFRT=WTYPFRT(K)
        Endif
      When 3 :
        If WTYPFRT(K)="*BA":
           Filter [BPL] Where CNSUSR=GUSER & CPY=WSOC(K) & GRPBAN=WBANKGR(K) & BAN=WBANK(K) & TYPFRT=WTYPFRT(K)
        Else
          Filter [BPL] Where CNSUSR=GUSER & GRPBAN=WBANKGR(K) & BAN=WBANK(K) & TYPFRT=WTYPFRT(K)
        Endif
      When 4 : Filter [BPL] Where CNSUSR=GUSER & CPY=WSOC(K) & FCY=WSIT(K) & GRPBAN=WBANKGR(K) & BAN=WBANK(K) & TYPFRT=WTYPFRT(K)
    Endcase

    Read First

    If !fstat : OK=1: Endif
    [F:BPL]CNSUSR     = GUSER
    [F:BPL]CPY        = WSOC(K)
    [F:BPL]CPY        = WSOC(K)
    [F:BPL]FCY        = WSIT(K)
    [F:BPL]GRPBAN     = WBANKGR(K)
    [F:BPL]BAN        = WBANK(K)
    [F:BPL]TYPFRT     = WTYPFRT(K)
    If OK=0
      [F:BPL]DUDDAT     = WDUDDAT(K)
    Endif
    [F:BPL]AMTCUR(0)  += WAMTCUR1(K)
    [F:BPL]AMTCUR(1)  += WAMTCUR2(K)
    [F:BPL]AMTCUR(2)  += WAMTCUR3(K)
    [F:BPL]AMTCUR(3)  += WAMTCUR4(K)
    [F:BPL]AMTCUR(4)  += WAMTCUR5(K)
    [F:BPL]AMTCUR(5)  += WAMTCUR6(K)
    [F:BPL]AMTCUR(6)  += WAMTCUR7(K)
    [F:BPL]AMTCUR(7)  += WAMTCUR8(K)
    [F:BPL]AMTCUR(8)  += WAMTCUR9(K)
    [F:BPL]AMTCUR(9)  += WAMTCUR10(K)
    [F:BPL]AMTCUR(10) += WAMTCUR11(K)
    [F:BPL]AMTCUR(11) += WAMTCUR12(K)
    [F:BPL]AMTCUR(12) += WAMTCUR13(K)
    [F:BPL]PER(0)      = SCOLDES(0)
    [F:BPL]PER(1)      = SCOLDES(1)
    [F:BPL]PER(2)      = SCOLDES(2)
    [F:BPL]PER(3)      = SCOLDES(3)
    [F:BPL]PER(4)      = SCOLDES(4)
    [F:BPL]PER(5)      = SCOLDES(5)
    [F:BPL]PER(6)      = SCOLDES(6)
    [F:BPL]PER(7)      = SCOLDES(7)
    [F:BPL]PER(8)      = SCOLDES(8)
    [F:BPL]PER(9)      = SCOLDES(9)
    [F:BPL]PER(10)     = SCOLDES(10)
    [F:BPL]PER(11)     = SCOLDES(11)
    [F:BPL]PER(12)     = SCOLDES(12)
    If NBPER>12
      [F:BPL]AMTCUR(13) += WAMTCUR14(K)
      [F:BPL]PER(13)      = SCOLDES(13)
      [F:BPL]AMTCUR(14) += WAMTCUR15(K)
      [F:BPL]PER(14)      = SCOLDES(14)
    Endif

    Case LEVG
      When 1: [F:BPL]INDLNK=WSOC(K)+WTYPFRT(K)+WBANKGR(K)+WBANK(K)+WSIT(K)+WDUDDAT(K)
      When 2: [F:BPL]INDLNK=WBANKGR(K)+WTYPFRT(K)+WSOC(K)+WSIT(K)+WBANK(K)+WDUDDAT(K)
      When 3: [F:BPL]INDLNK=WBANK(K)+WTYPFRT(K)+WSOC(K)+WSIT(K)+WBANKGR(K)+WDUDDAT(K)
      When 4: [F:BPL]INDLNK=WSIT(K)+WTYPFRT(K)+WSOC(K)+WBANKGR(K)+WBANK(K)+WDUDDAT(K)
    Endcase
    If OK=1: Rewrite [BPL]: Else : Write [BPL] : Endif
    If fstat>0
      GOK=0 : Call FSTA("BPL") From GLOCK : Return
    Endif

    Filter [BPL]
  Commit

  Raz WSOC(), WSIT(), WBANKGR(), WBANK(), WTYPFRT(), WDUDDAT(), WAMTCUR1(), WAMTCUR2(), WAMTCUR3(), WAMTCUR4(), WAMTCUR5()
  Raz WAMTCUR6(), WAMTCUR7(), WAMTCUR8(), WAMTCUR9(), WAMTCUR10(), WAMTCUR11(), WAMTCUR12(), WAMTCUR13(), WAMTCUR14()
  Raz WAMTCUR15()

Return

$ADD_PERIOD
  D=J
  If DLEV=3 and WTYPFRT(D)<>"*BB": D=1 : Endif
  WSOC(D)     = [F:CFODD]CPY
  WSIT(D)     = [F:CFODD]FCY
  WBANKGR(D)   = BANKGR
  WBANK(D)    = [F:CFODD]CFOBAN
#  If IMP=1 and DLEV<>3 and WTYPFRT(D)="*BB" and LEVG<>3: Raz WBANK(D): Endif

  If DLEV<3
    If  [F:CFODD]TYP>="*CM01" & [F:CFODD]TYP<="*CM99"
      WTYPFRT(D)  = [F:CFODD]TYP
    Else
      If WTYPFRT(D)<>"*BB":  WTYPFRT(D)  = "*CM0" :Endif    #Due date amount into periods
    Endif
  Else
    If WTYPFRT(D)<>"*BB": WTYPFRT(D) = "*BT"+[F:CFODD]NUM: Endif #jcc
    If WTYPFRT(D)="*BB" : WDUDDAT(D) = SOLDAT
        If LEVG<>3: : WBANK(D)="" :Endif
    Endif
  Endif
  If WDUDDAT(D)=[00/00/00]
    WDUDDAT(D)  = [F:CFODD]CFODAT
  Endif


  If DLEV<>3 and LEVG<>3 : WBANK(D)="": Endif

  If [F:CFODD]CFODAT<=PERDAT(0):  WAMTCUR1(D)  +=  WDEVAMT:
  Endif
  If [F:CFODD]CFODAT<=PERDAT(1)  & [F:CFODD]CFODAT>PERDAT(0):  WAMTCUR2(D)  +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(2)  & [F:CFODD]CFODAT>PERDAT(1) : WAMTCUR3(D)  +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(3)  & [F:CFODD]CFODAT>PERDAT(2) : WAMTCUR4(D)  +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(4)  & [F:CFODD]CFODAT>PERDAT(3) : WAMTCUR5(D)  +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(5)  & [F:CFODD]CFODAT>PERDAT(4) : WAMTCUR6(D)  +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(6)  & [F:CFODD]CFODAT>PERDAT(5) : WAMTCUR7(D)  +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(7)  & [F:CFODD]CFODAT>PERDAT(6) : WAMTCUR8(D)  +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(8)  & [F:CFODD]CFODAT>PERDAT(7) : WAMTCUR9(D)  +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(9)  & [F:CFODD]CFODAT>PERDAT(8) : WAMTCUR10(D) +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(10) & [F:CFODD]CFODAT>PERDAT(9) : WAMTCUR11(D) +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(11) & [F:CFODD]CFODAT>PERDAT(10): WAMTCUR12(D) +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(12) & [F:CFODD]CFODAT>PERDAT(11): WAMTCUR13(D) +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(13) & [F:CFODD]CFODAT>PERDAT(12): WAMTCUR14(D) +=  WDEVAMT
  Endif
  If [F:CFODD]CFODAT<=PERDAT(14) & [F:CFODD]CFODAT>PERDAT(13): WAMTCUR15(D) +=  WDEVAMT
  Endif

Return

$ERR_CRITERE
Resume

############################################################
#X3-67843 Subprog SOLDEBAL(DEV,CPYSOC,SITE,CPT,BPR,SENS,DATSOL,MTBAL,IMP)
#X3-67843 Value    Char DEV(),CPYSOC(),SITE(),CPT(),BPR()
Subprog SOLDEBAL(DEV,CPYSOC,SITE,CPT,BANBPR,SENS,DATSOL,MTBAL,IMP)
Value    Char DEV(),CPYSOC(),SITE(),CPT(),BANBPR()
Variable Integer SENS()
Value    Date    DATSOL
Variable Decimal MTBAL
Variable Integer IMP

Local Decimal EXERCICE, PERIODE, PDEB, PFIN, PMAX, EDEB, EFIN, MTDES
Local Date    DATECT
Local Integer FLECT, STAT, FILSTA

If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif

Local Char COALED(GLONCOA), CURLED(GLONCUR)
Call GETSOC(CPYSOC) From DEVSUB
Call LECLED(CPYSOC,GTYPGEN,COALED,CURLED) From CPTDIV

MTBAL=0
Call GETPERSOC(CPYSOC,GTYPGEN,DATSOL,EFIN,PERIODE) From CPTSUB
If DATSOL = [F:PER]PEREND
 PFIN = PERIODE : FLECT = 0
Else
 PFIN = PERIODE-1 : FLECT = 1 : DATECT = [F:PER]PERSTR
Endif
Filter [FIY] Where CPY=CPYSOC & LEDTYP=GTYPGEN & FIYSTA=2
Read [FIY]FIY0 First
Filter [FIY]
EDEB = [F:FIY]FIYNUM
If EFIN<EDEB : EDEB = EFIN : Endif
PMAX = dim([F:BAL]DEB)-1
For EXERCICE=EDEB To EFIN
 Gosub CUMSOLDAT
Next
If FLECT
 Call LECTURE("GAC",CPT,COALED) From CONTOBJ
 If [F:GAC]CUR<>""
 #X3-67843 Filter [DAE] Where ACC=CPT & BPR=BPR & ACCDAT>=DATECT & ACCDAT<=DATSOL & CPY=CPYSOC & CUR=[F:GAC]CUR & LEDTYP=GTYPGEN
  Filter [DAE] Where ACC=CPT & BPR=BANBPR & ACCDAT>=DATECT & ACCDAT<=DATSOL & CPY=CPYSOC & CUR=[F:GAC]CUR & LEDTYP=GTYPGEN
  For [DAE]DAE3
   If IMP=0: Call OTHERCRIT([F:BAL]BPR,FILSTA,2) From CNSBTRSTD: Else FILSTA=0: Endif
   If FILSTA=0
    If (SITE="" | SITE=[F:DAE]FCYLIN)
     Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
     If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
      MTBAL += [F:DAE]SNS*[F:DAE]AMTCUR
     Endif
    Endif
   Endif
  Next
 Else
 #X3-67843 Filter [DAE] Where ACC=CPT & BPR=BPR & ACCDAT>=DATECT & ACCDAT<=DATSOL & CPY=CPYSOC & LEDTYP=GTYPGEN
  Filter [DAE] Where ACC=CPT & BPR=BANBPR & ACCDAT>=DATECT & ACCDAT<=DATSOL & CPY=CPYSOC & LEDTYP=GTYPGEN
  For [DAE]DAE3
   If IMP=0: Call OTHERCRIT([F:BAL]BPR,FILSTA,2) From CNSBTRSTD:  Else FILSTA=0: Endif
   If FILSTA=0
    If (SITE="" | SITE=[F:DAE]FCYLIN)
     Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
     If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
      Case DEV
       When [L]CURLED  : MTBAL += [F:DAE]SNS*[F:DAE]AMTLED
       When [F:DAE]CUR : MTBAL += [F:DAE]SNS*[F:DAE]AMTCUR
       When Default  :
        Call CONVERT([L]CURLED,DEV,[L]CURLED,1,[F:HAE]ACCDAT,[F:DAE]AMTLED,MTDES,STAT) From TRTDEV
        If !STAT
         MTBAL += [F:DAE]SNS*MTDES
        Endif
      Endcase
     Endif
    Endif
   Endif
  Next
 Endif
Endif
If MTBAL>=0
 SENS = 1
Else
 MTBAL = -MTBAL
 SENS = 2
Endif
End

$CUMSOLDAT
 #X3-67843 Filter [BAL] Where LEDTYP=GTYPGEN & CPY=CPYSOC & FCY=SITE & FIY=EXERCICE & ACC=CPT & BPR=[L]BPR
Filter [BAL] Where LEDTYP=GTYPGEN & CPY=CPYSOC & FCY=SITE & FIY=EXERCICE & ACC=CPT & BPR=[L]BANBPR
For [BAL]BAL0
 If IMP=0: Call OTHERCRIT([F:CFODD]NUM,FILSTA,2) From CNSBTRSTD:  Else FILSTA=0: Endif
 If FILSTA=0
   If EDEB=EFIN
     If PFIN>0
       Case DEV
         When [F:BAL]CUR    : MTBAL += sum([F:BAL]DEB(0..PFIN))-sum([F:BAL]CDT(0..PFIN))
         When [F:BAL]CURLED : MTBAL += sum([F:BAL]DEBLED(0..PFIN))-sum([F:BAL]CDTLED(0..PFIN))
       Endcase
     Endif
   Elsif EXERCICE=EDEB
     Case DEV
       When [F:BAL]CUR    : MTBAL += sum([F:BAL]DEB(0..PMAX))-sum([F:BAL]CDT(0..PMAX))
       When [F:BAL]CURLED : MTBAL += sum([F:BAL]DEBLED(0..PMAX))-sum([F:BAL]CDTLED(0..PMAX))
     Endcase
   Elsif EXERCICE=EFIN
     Case DEV
       When [F:BAL]CUR    : MTBAL += sum([F:BAL]DEB(1..PFIN))-sum([F:BAL]CDT(1..PFIN))
       When [F:BAL]CURLED : MTBAL += sum([F:BAL]DEBLED(1..PFIN))-sum([F:BAL]CDTLED(1..PFIN))
     Endcase
   Else
     Case DEV
       When [F:BAL]CUR    : MTBAL += sum([F:BAL]DEB(1..PMAX))-sum([F:BAL]CDT(1..PMAX))
       When [F:BAL]CURLED : MTBAL += sum([F:BAL]DEBLED(1..PMAX))-sum([F:BAL]CDTLED(1..PMAX))
     Endcase
   Endif
  Endif
Next

Filter [BAL]
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR0 : Endif

