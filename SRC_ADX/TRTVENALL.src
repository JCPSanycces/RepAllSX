#<AdxTL>@(#)7.0.0.0 $Revision$
##################################################################################################
#                                                                                                #
#    TRAITEMENTS LIES aux ALLOCATIONS dans les VENTES                                            #
#                                                                                                #
##################################################################################################
#                                   V140                                                         #
#                                                                                                #
# Subprog GENALLORD(LSOQ, LSOP, LTRTLIG, LIMPCLI, LGENSHT, LALLPAR, LALLSTU, LSHTSTU, LRET)      #
#    Allocation d'une ligne de commande                                                          #
#                                                                                                #
# Subprog GENALLBPC(LITM, LFCY, LALLDAT, LNUM, LLIN, LSEQ, LTRTLIG, LALLSTU, LRET)               #
#    Génération d'une réservation client                                                         #
#                                                                                                #
# Subprog GENALLKIT(LSOHNUM, LSOPLIN, LSOQSEQ, LTRTLIG, LIMPCLI, LGENSHT, LALLPAR, LRAZCTM       #
#    Allocation d'un kit d'une commande (avec maj de la commande)                                #
#                                                                                                #
# Subprog MAJALLORD(LSOHNUM, LSOPLIN, LSOQSEQ, LALLTYP, LRAZCTM, LALLSTU, LSHTSTU, LRET)         #
#    Maj de la commande suite à l'allocation                                                     #
#                                                                                                #
# Subprog RECITMSHT (LFCY, LITM, LSHT)                                                           #
#    Recherche des ruptures d'un article                                                         #
#                                                                                                #
# Subprog DIVALLORD(LVCRNUM, LVCRLIN, LVCRSEQ, LTRTALL, LIMPCLI, LGENSHT, LALLPAR, LABREV, LNOL) #
#    Allocation/Déallocation d'une ligne de commande                                             #
#               Actions associées : DIVAUTALL                                                    #
#                                   DISDESALL                                                    #
#                                                                                                #
# Subprog STODISKIT (WTRSTYP,WTRSCOD,WQTYCPE,WQTYSTUCPE,WRET)                                    #
#    Calcul du stock disponible des composants d'un kit                                          #
#                                                                                                #
# Subprog MAJALLBPC(LDAT,LTYP,LNUM,LLIN,LSEQ,LPRE,LRET)                                          #
#    Modification d'une allocation client                                                        #
#                                                                                                #
# Subprog MAJORDBPC(LTYP,LNUM,LITM,LFCY,LQTA,LRET)                                               #
#    Suite à consommation des réservations clients maj de l'encours correspondant                #
#                                                                                                #
# Subprog RECSHTKIT (LSOHNUM, LSOPLIN, LSOQSEQ, LSHTQTYSTU, LRET)                                #
#    Recherche de la qté rupture d'un kit non géré stock (en fct des qtés ruptures composants)   #
#                                                                                                #
##################################################################################################
# Issue 116484 - 20160526 by LD : PERF FUNAUTPREP - optimisation done for MADMAN
# Issue 120079 - 20161227 by LD : Automatic desallocation created orders record for non stock

###########################################################################
#                                                                         #
#                     TRAITEMENTS V140                                    #
#                                                                         #
###########################################################################
#-------------------------------------------------------------------------#
# GENALLORD : Sous-programme d'allocation d'une ligne de commande         #
#             Génération des allocations dans le fichier STOALL           #
#                        par appel des composants d'allocations de STKALL #
#-------------------------------------------------------------------------#
# Prérequis : L'écran paramêtre ALLPAR doit être ouvert                   #
#-------------------------------------------------------------------------#
# Entrée  LSOQ       : Classe fichier SOQ  : Par défaut [F:SOQ]           #
#         LSOP       : Classe fichier SOP  : Par défaut [F:SOP]           #
#         LTRTLIG    : Type de traitement                                 #
#                            "C" : Création d'une allocation              #
#                            "M" : Modification                           #
#                            "D" : Diminution                             #
#                            "A" : Annulation                             #
#         LIMPCLI    : Imputation des allocations client (1=Non,2=Oui)    #
#         LGENSHT    : Génération des ruptures (1=Non,2=Oui)              #
#         LALLPAR    : Allocations partielles  (0=Autorisée,1=Interdite)  #
#         LALLSTU    : Quantité à allouer                                 #
# Sortie  LALLSTU    : Quantité réellement allouée                        #
#         LSHTSTU    : Quantité rejettée                                  #
#         LRET       : Code retour                                        #
#                             0 : OK                                      #
#                             1 : Erreur                                  #
#                             2 : Alloc totale impossible                 #
#-------------------------------------------------------------------------#
Subprog GENALLORD(LSOQ, LSOP, LTRTLIG, LIMPCLI, LGENSHT, LALLPAR, LALLSTU, LSHTSTU, LRET)
Value    Char    LSOQ
Value    Char    LSOP
Value    Char    LTRTLIG
Value    Libelle LIMPCLI
Value    Libelle LGENSHT
Value    Libelle LALLPAR
Variable Decimal LALLSTU
Variable Decimal LSHTSTU
Variable Integer LRET

If LSOQ = "" LSOQ="[F:SOQ]" : Endif
If LSOP = "" LSOP="[F:SOP]" : Endif

Local Char    WITM(GLONITM)  :       WITM    = evalue (LSOQ+"ITMREF")
Local Char    WFCY(GLONFCY)  :       WFCY    = evalue (LSOQ+"STOFCY")
Local Char    WVCRRER(GLONBPC+GLONBPD)
Local Integer WTYP           :       WTYP    = 2
Local Char    WNUM           :       WNUM    = evalue (LSOQ+"SOHNUM")
Local Decimal WLIN           :       WLIN    = evalue (LSOQ+"SOPLIN")
Local Decimal WSEQ           :       WSEQ    = evalue (LSOQ+"SOQSEQ")
Local Libelle WALLTYP        :       WALLTYP = evalue (LSOQ+"ALLTYP")
Local Integer WRUPTYP
Local Decimal WALLSTU, WSHTSTU, WALLQTY, WSHTQTY, WSHTQTYSUP, WQTY
Local Decimal WQTYSTU, WQTYARR, WQTA, WQTR, WQT1, WQT2
Local Char    WMAJ :       WMAJ = "C"
Local Integer WOPT, WRUP, WTRT
#--- TS 106217
Local Char    WECCVALMAJ(GLONECS)   # FGR 29/04/2015 : X3SUIVI105605 : ajout de la longueur

If LGENSHT=2 WRUP=1 Else WRUP=0 Endif
WTRT=LALLPAR
# Le buffer [F:ITM] doit être en ligne dans GENSTOALL
If clalev([F:ITM]) = 0 Local File ITMMASTER Endif
If [F:ITM]ITMREF <> WITM Read [ITM] ITM0=WITM
                         If fstat Raz [F:ITM] : Endif
                         Endif
# --> Récupération du paramêtre stock : MARGE alerte péremption jours
#Local Char     WPARAM(10)                        # hcb v6per
#Call PARAM(WFCY,"MARPER",WPARAM) From ADOVAL     # hcb v6per
#GSMARPER = val(WPARAM)                           # hcb v6per

# Alimentation de la classe ecran ALLPAR
Raz [M:ALP]
If evalue(LSOQ+"SOHCAT")=2
   [M:ALP]TRSTYP = 17
Else
   [M:ALP]TRSTYP = 4
Endif
[M:ALP]VCRTYP    = WTYP
[M:ALP]VCRNUM    = WNUM
[M:ALP]VCRLIN    = WLIN
[M:ALP]VCRSEQ    = WSEQ
[M:ALP]STOFCY    = evalue(LSOQ+"STOFCY")
[M:ALP]ITMREF    = evalue(LSOQ+"ITMREF")
# FGR 14/04/2015 : X3SUIVI105605 (début)
If dim([M:ALP]ECCVALMAJ) >= 0 Then
  [M:ALP]ECCVALMAJ = evalue(LSOQ+"ECCVALMAJ")
Endif
# FGR 14/04/2015 : X3SUIVI105605 (fin)
[M:ALP]PCU       = evalue(LSOP+"SAU")
[M:ALP]PCUSTUCOE = evalue(LSOP+"SAUSTUCOE")
[M:ALP]TYPQTY    = 2
# 88827 : La date besoin doit tjs être alimentée avec la date d'expédition pour respecter l'ordre chronologique des ddes d'allocation
#[M:ALP]BESDAT    = max(date$,evalue(LSOQ+"SHIDAT"))
[M:ALP]BESDAT    = evalue(LSOQ+"SHIDAT")
# 88827
[M:ALP]DLVDAT    = max(date$,evalue(LSOQ+"EXTDLVDAT"))
[M:ALP]PECRER    = LIMPCLI
If LIMPCLI=2
    WVCRRER = format$("K:"+num$(GLONBPC)+"X", evalue(LSOQ+"BPCORD"))+format$("K:"+num$(GLONBPD)+"X", evalue(LSOQ+"BPAADD"))
    WVCRRER = vireblc(WVCRRER, 1)
    [M:ALP]VCRRER = WVCRRER
Endif
[M:ALP]PECPLFLOC = 2    : # Prise en cpte empl quai : Oui
[M:ALP]PECCUNLOK = 2    : # Prise en cpte stock en cours inventaire : Oui
[M:ALP]PECQLYCTL = 2    : # Prise en cpte stock en demande d'analyse: Oui
[M:ALP]LOT       = evalue(LSOQ+"LOT")
[M:ALP]LOC       = evalue(LSOQ+"LOC")
[M:ALP]STA       = evalue(LSOQ+"STA")
If [M:ALP]ALLDAT=[0/0/0]
   [M:ALP]ALLDAT=[31/12/2999]
Endif
WSHTQTY    = LSHTSTU
WALLQTY    = LALLSTU
#DLUBPC
[M:ALP]BPRNUM=[F:SOH]BPCORD
Raz [M:ALP]WRH
Case LTRTLIG
     When "C" : # ------ Création     -----------
        #---------------------------------------------
        # TS : réajustement qté en unité vente entière
        #---------------------------------------------
        WQTYSTU = WALLQTY
        Gosub REAJUSTE_QTY
        WALLQTY = WQTYSTU
        # Algorithme d'allocation
        [M:ALP]QTY = WALLQTY
        Call GENSTOALL(WMAJ, WALLTYP, WRUP, WTRT, LRET) From STKALL
        If LRET <> 0 End : Endif

        # Réajustement qté allouée en unité vente entière
        If [M:ALP]ALLQTY<>0
           WQTYSTU = [M:ALP]ALLQTY
           Gosub REAJUSTE_QTY
           # Si qté réajustée, diminution des allocations en conséquence
           If WQTYSTU < [M:ALP]ALLQTY
              WQTA = [M:ALP]ALLQTY-WQTYSTU
              Call DIMALL([M:ALP]VCRTYP,[M:ALP]VCRNUM,[M:ALP]VCRLIN,[M:ALP]VCRSEQ,
&                         [M:ALP]ITMREF,1,WQTA,WQT1,WQT2,LRET) From STKALL
              If LRET<>0 End Endif
              # Quantité allouée
              [M:ALP]ALLQTY = WQTYSTU
           Endif
        Endif
        # Réajustement qté rupture en unité vente entière
        If [M:ALP]ALLQTYSHT<>0
           WQTYSTU = [M:ALP]ALLQTYSHT
           Gosub REAJUSTE_QTY
           # Si qté réajustée, diminution des ruptures en conséquence
           If WQTYSTU < [M:ALP]ALLQTYSHT
              WQTR = [M:ALP]ALLQTYSHT-WQTYSTU
              Call DIMALL([M:ALP]VCRTYP,[M:ALP]VCRNUM,[M:ALP]VCRLIN,[M:ALP]VCRSEQ,
&                         [M:ALP]ITMREF,2,WQTR,WQT1,WQT2,LRET) From STKALL
              If LRET<>0 End Endif
              # Quantité rupture
              [M:ALP]ALLQTYSHT = WQTYSTU
           Endif
        Endif
        # Si génération rupture et qté diminuée
        If WRUP=1 & WQTA+WQTR<>0
           # Si qté diminuée des allocations est un multiple de la qté en UC
           WQTYSTU = WQTA+WQTR
           Gosub REAJUSTE_QTY
           If WQTYSTU<>0
              If WALLTYP=1
                 WRUPTYP=5
              Else
                 WRUPTYP=4
              Endif
              #--- TS 106217
              #--- Si version exclusive et renseignée
              If [M:ALP]ECCVALMAJ<>"" & [F:SRU]ORDVER=2 & WRUPTYP=4
                 WECCVALMAJ = [M:ALP]ECCVALMAJ
              Else
                 WECCVALMAJ = ""
              Endif
              #---
              #--- TS 106217 ajout paramètre LECC (avant dernier)
              # Création d'une allocation de rupture pour cette qté
              Call CREALL(WRUPTYP,[M:ALP]STOFCY,[M:ALP]ITMREF,0,[M:ALP]ALLDAT,
&                         0,WQTYSTU,[M:ALP]VCRTYP,[M:ALP]VCRNUM,[M:ALP]VCRLIN,
&                         [M:ALP]VCRSEQ,"",[M:ALP]BESDAT,[M:ALP]LOT,"","",
&                         [M:ALP]LOC,"",[M:ALP]WRH,0,0,"","","","",1,
&                         WECCVALMAJ,LRET) From STKALL
              If LRET=0
                 # Alimentation quantité rupture
                 [M:ALP]ALLQTYSHT += WQTYSTU
              Endif
           Endif
        Endif
        # Si consommation des réservations clients : Maj de l'encours correspondant
        If [M:ALP]PECRERQTY<>0
            Call MAJORDBPC(1,[M:ALP]VCRRER,[M:ALP]ITMREF,[M:ALP]STOFCY,[M:ALP]PECRERQTY,LRET)
            If LRET<>0 End Endif
        Endif
#       Quantité qui a été allouée
        WALLSTU = [M:ALP]ALLQTY
#       Quantité rupture
        WSHTSTU = [M:ALP]ALLQTYSHT
     When "M" : # ------ Modification -----------
# ----- Suppression de l'allocation existante sur les manquants
        If  WSHTQTY <> 0
            # 84767 : Suppression des manquants ssi ils ne sont pas sur une liste à ranger
            #WOPT = 2    : # suppression manquants seulss
            WOPT = 12    : # suppression manquants seulss si pas de liste à ranger
            # 84767
            WQTY = 0 : WSHTQTYSUP = 0
            Call DELALL(WTYP, WNUM, WLIN, WSEQ, WITM, WOPT, WQTY, WSHTQTYSUP, LRET) From STKALL
            If LRET <> 0 End : Endif
#           On enlève de la quantité rupture les manquants reellement supprimés
            WSHTQTY -= WSHTQTYSUP
        Endif

# ----- Allocation de la nouvelle qté + les manquants supprimés
        WALLQTY = WALLQTY + WSHTQTYSUP
        If WALLQTY<>0 : # 84767
          #---------------------------------------------
          # TS : réajustement qté en unité vente entière
          #---------------------------------------------
          WQTYSTU = WALLQTY
          Gosub REAJUSTE_QTY
          WALLQTY = WQTYSTU

          [M:ALP]QTY = WALLQTY
          Call GENSTOALL(WMAJ, WALLTYP, WRUP, WTRT, LRET) From STKALL
          If LRET <> 0 End : Endif

          # Réajustement qté allouée en unité vente entière
          If [M:ALP]ALLQTY<>0
             WQTYSTU = [M:ALP]ALLQTY
             Gosub REAJUSTE_QTY
             # Si qté réajustée, diminution des allocations en conséquence
             If WQTYSTU < [M:ALP]ALLQTY
                WQTA = [M:ALP]ALLQTY-WQTYSTU
                Call DIMALL([M:ALP]VCRTYP,[M:ALP]VCRNUM,[M:ALP]VCRLIN,[M:ALP]VCRSEQ,
&                           [M:ALP]ITMREF,1,WQTA,WQT1,WQT2,LRET) From STKALL
                If LRET<>0 End Endif
                # Quantité allouée
                [M:ALP]ALLQTY = WQTYSTU
             Endif
          Endif
          # Réajustement qté rupture en unité vente entière
          If [M:ALP]ALLQTYSHT<>0
             WQTYSTU = [M:ALP]ALLQTYSHT
             Gosub REAJUSTE_QTY
             # Si qté réajustée, diminution des ruptures en conséquence
             If WQTYSTU < [M:ALP]ALLQTYSHT
                WQTR = [M:ALP]ALLQTYSHT-WQTYSTU
                Call DIMALL([M:ALP]VCRTYP,[M:ALP]VCRNUM,[M:ALP]VCRLIN,[M:ALP]VCRSEQ,
&                           [M:ALP]ITMREF,2,WQTR,WQT1,WQT2,LRET) From STKALL
                If LRET<>0 End Endif
                # Quantité rupture
                [M:ALP]ALLQTYSHT = WQTYSTU
             Endif
          Endif
          # Si génération rupture et qté diminuée
          If WRUP=1 & WQTA+WQTR<>0
             # Si qté diminuée des allocations est un multiple de la qté en UC
             WQTYSTU = WQTA+WQTR
             Gosub REAJUSTE_QTY
             If WQTYSTU<>0
                If WALLTYP=1
                   WRUPTYP=5
                Else
                   WRUPTYP=4
                Endif
                #--- TS 106217
                #--- Si version exclusive et renseignée
                If [M:ALP]ECCVALMAJ<>"" & [F:SRU]ORDVER=2 & WRUPTYP=4
                   WECCVALMAJ = [M:ALP]ECCVALMAJ
                Else
                   WECCVALMAJ = ""
                Endif
                #---
                #--- TS 106217 ajout paramètre LECC (avant dernier)
                # Création d'une allocation de rupture pour cette qté
                Call CREALL(WRUPTYP,[M:ALP]STOFCY,[M:ALP]ITMREF,0,[M:ALP]ALLDAT,
&                           0,WQTYSTU,[M:ALP]VCRTYP,[M:ALP]VCRNUM,[M:ALP]VCRLIN,
&                           [M:ALP]VCRSEQ,"",[M:ALP]BESDAT,[M:ALP]LOT,"","",
&                           [M:ALP]LOC,"",[M:ALP]WRH,0,0,"","","","",1,
&                           WECCVALMAJ,LRET) From STKALL
                If LRET=0
                   # Alimentation quantité rupture
                   [M:ALP]ALLQTYSHT += WQTYSTU
                Endif
             Endif
          Endif
          # Si consommation des réservations clients : Maj de l'encours correspondant
          If [M:ALP]PECRERQTY<>0
              Call MAJORDBPC(1,[M:ALP]VCRRER,[M:ALP]ITMREF,[M:ALP]STOFCY,[M:ALP]PECRERQTY,LRET)
              If LRET<>0 End Endif
          Endif
#         Quantité qui a été allouée
          WALLSTU = [M:ALP]ALLQTY
#         On ajoute à la quantité déjà en rupture la nouvelle quantité rupture générée
          WSHTQTY += [M:ALP]ALLQTYSHT
          WSHTSTU = WSHTQTY
        # 84767
        Else
          WALLSTU = WALLQTY
          WSHTSTU = WSHTQTY
        Endif
        # 84767
     When "A" : # ------ Annulation   -----------
        WOPT = 0    :     # suppression allocations + manquants
        WALLQTY = 0 : WSHTQTYSUP = 0 : WOPT = 0
        # --- Point d'entree annulation d'une allocation
        GPOINT="DELALLORD" : Gosub ENTREE From EXEFNC   :#CHECK IGNORE_LINE
        If LRET = 1 End : Endif
        Call DELALL(WTYP, WNUM, WLIN, WSEQ, WITM, WOPT, WALLQTY, WSHTQTYSUP, LRET) From STKALL
        If LRET <> 0 End : Endif
#       Quantité allouée qui a été supprimée
        WALLSTU=WALLQTY
        WSHTSTU=WSHTQTYSUP
     When "D" : # ------ Diminution -----------
        WQTY=WALLQTY+WSHTQTY
        If WQTY <> 0
            WOPT=0                              : # 0 : diminution manquant puis allocation
            If WALLQTY <> 0
                If WSHTQTY = 0 WOPT=1 Endif     : # 1 : diminution allocations seules
            Elsif WSHTQTY <> 0
                WOPT = 2                        : # 2 : diminution manquant seuls
            Endif
            Call DIMALL(WTYP, WNUM, WLIN, WSEQ, WITM, WOPT, WQTY, WALLQTY, WSHTQTY, LRET) From STKALL
            If LRET <> 0 End : Endif
#           Quantité allouée qui a été diminuée
            WALLSTU = WALLQTY
            WSHTSTU = WSHTQTY
        Endif
     When Default
        End
Endcase

# 93846
# --- Entry point to intercept qty really allocated
Local Decimal WSVGALLSTU : WSVGALLSTU=WALLSTU : # Qty are saved to avoid overwritten in the PE
Local Decimal WSVGSHTSTU : WSVGSHTSTU=WSHTSTU
GPOINT="AFTGENALLORD" : Gosub ENTREE From EXEFNC
WALLSTU=WSVGALLSTU                            : # Qty are restitued
WSHTSTU=WSVGSHTSTU
# 93846

LALLSTU = WALLSTU
LSHTSTU = WSHTSTU

If LRET <> 0 LALLSTU =0  Endif
End

#-------------------------------------------------------------------------#
# GENALLBPC : Sous-programme de génération d'une réservation client       #
#             Génération des allocations dans le fichier STOALL           #
#                        par appel des composants d'allocations de STKALL #
#-------------------------------------------------------------------------#
# Prérequis : L'écran paramêtre ALLPAR doit être ouvert                   #
#-------------------------------------------------------------------------#
# Entrée  LITM       : Référence article                                  #
#         LFCY       : Site de stock                                      #
#         LALLDAT    : Date fin de réservation                            #
#         LNUM       : Numero de pièce        (n°client + code adresse)   #
#         LLIN       : Numero ligne pièce                                 #
#         LSEQ       : Numéro sequence pièce  (0)                         #
#         LTRTLIG    : Type de traitement                                 #
#                            "C" : Création d'une allocation              #
#                            "M" : Modification                           #
#                            "D" : Diminution                             #
#                            "A" : Annulation                             #
#         LALLSTU    : Quantité à allouer                                 #
# Sortie  LALLSTU    : Quantité réellement allouée                        #
#         LRET       : Code retour                                        #
#-------------------------------------------------------------------------#
Subprog GENALLBPC(LITM, LFCY, LALLDAT, LNUM, LLIN, LSEQ, LTRTLIG, LALLSTU, LRET)
Value    Char    LITM
Value    Char    LFCY
Value    Date    LALLDAT
Value    Char    LNUM
Value    Integer LLIN
Value    Integer LSEQ
Value    Char    LTRTLIG
Variable Decimal LALLSTU
Variable Integer LRET

Local Integer WTYP           :       WTYP    = 1
Local Libelle WALLTYP        :       WALLTYP = 1
Local Decimal WALLSTU, WALLQTY, WQTY, WSHT
Local Char    WMAJ           :       WMAJ    = "C"
Local Integer WOPT           :       WOPT    = 1
Local Integer WRUP           :       WRUP    = 0
Local Integer WTRT           :       WTRT    = 0

# Le buffer [F:ITM] doit être en ligne dans GENSTOALL
If LITM<>"" & [F:ITM]ITMREF<>LITM    Read [ITM] ITM0=LITM
                                     If fstat Raz [F:ITM] : Endif
                                     Endif
# --> Récupération du paramêtre stock : MARGE alerte péremption jours
#Local Char     WPARAM(10)                       # hcb v6per
#Call PARAM(LFCY,"MARPER",WPARAM) From ADOVAL    # hcb v6per
#GSMARPER = val(WPARAM)                          # hcb v6per

# Alimentation de la classe ecran ALLPAR
Raz [M:ALP]
[M:ALP]TRSTYP    = 0
[M:ALP]VCRTYP    = WTYP
[M:ALP]VCRNUM    = LNUM
[M:ALP]VCRLIN    = LLIN
[M:ALP]VCRSEQ    = LSEQ
[M:ALP]STOFCY    = LFCY
[M:ALP]ITMREF    = LITM
[M:ALP]PCU       = [F:ITM]STU
[M:ALP]PCUSTUCOE = 1
[M:ALP]TYPQTY    = 2
[M:ALP]BESDAT    = date$
[M:ALP]ALLDAT    = LALLDAT
[M:ALP]PECRER    = 1
[M:ALP]PECINTLOC = 2    : # Prise en cpte empl internes    : Oui
[M:ALP]PECPLFLOC = 2    : # Prise en cpte empl quai        : Oui
[M:ALP]PECSCOLOC = 1    : # Prise en cpte empl s-traitants : Non
[M:ALP]PECCUNLOK = 2    : # Prise en cpte stock en cours inventaire : Oui
[M:ALP]PECQLYCTL = 2    : # Prise en cpte stock en demande d'analyse: Oui
Raz [M:ALP]WRH
#DLUBPC
[M:ALP]BPRNUM=[M]BPCORD

WALLQTY    = LALLSTU
Case LTRTLIG
     When "C" : # ------ Création     -----------
        [M:ALP]QTY = WALLQTY
        WRUP = 0
        Call GENSTOALL(WMAJ, WALLTYP, WRUP, WTRT, LRET) From STKALL
        If LRET <> 0 End : Endif
#       Quantité qui a été allouée
        WALLSTU = [M:ALP]ALLQTY
     When "M" : # ------ Modification -----------
# ----- Suppression de l'allocation existante
        WOPT = 1
        WQTY = 0 : WSHT = 0
        Call DELALL(WTYP, LNUM, LLIN, LSEQ, LITM, WOPT, WQTY, WSHT, LRET) From STKALL
        If LRET <> 0 End : Endif
# ----- Allocation de ancienne qté + nouvelle qté (pour n'avoir qu'un seul enr.)
        WALLQTY += WQTY
        [M:ALP]QTY = WALLQTY
        WRUP = 0
        Call GENSTOALL(WMAJ, WALLTYP, WRUP, WTRT, LRET) From STKALL
        If LRET <> 0 End : Endif
#       Quantité qui a été allouée
        WALLSTU = [M:ALP]ALLQTY
     When "A" : # ------ Annulation   -----------
        WOPT = 1
        WQTY = 0 : WSHT = 0 : WOPT = 0
        Call DELALL(WTYP, LNUM, LLIN, LSEQ, LITM, WOPT, WQTY, WSHT, LRET) From STKALL
        If LRET <> 0 End : Endif
#       Quantité qui a été supprimée
        WALLSTU=WQTY
     When "D" : # ------ Diminution -----------
        WQTY=WALLQTY
        If WQTY <> 0
            WOPT=1
            Call DIMALL(WTYP, LNUM, LLIN, LSEQ, LITM, WOPT, WQTY, WALLQTY, WSHT, LRET) From STKALL
            If LRET <> 0 End : Endif
#           Quantité allouée qui a été diminuée
            WALLSTU = WALLQTY
        Endif
     When Default
        End
Endcase
LALLSTU = WALLSTU

If LRET <> 0 LALLSTU =0  Endif
End

###########################################################################
#-------------------------------------------------------------------------#
# GENALLKIT : Sous-programme d'allocation d'une nomenclature d'une        #
#                            commande de vente                            #
#             - Génération des allocations dans le fichier STOALL         #
#                        par appel des composants d'allocations de STKALL #
#             - Maj des zones d'allocations dans la commande              #
#-------------------------------------------------------------------------#
#     Utilisé par FUNMANALL: Allocation manuelle des cdes                 #
#                 FUNDESALL: Désallocation des cdes                       #
#                 SUBSOH   : Gestion des cdes : Bt alloc. manuelles       #
#                 CNSSHTSTD: Consultation ruptures : Bt alloc. manuelles  #
#-------------------------------------------------------------------------#
# Prérequis : L'écran paramêtre ALLPAR doit être ouvert                   #
#-------------------------------------------------------------------------#
#-------------------------------------------------------------------------#
# Entrée  LSOHNUM    : Numéro de la commande                              #
#         LSOPLIN    : Numéro de ligne du composé                         #
#         LSOQSEQ    : Numéro de séquence du composé                      #
#         LTRTLIG    : Code traitement ("C", "M", "D", "A")               #
#         LIMPCLI    : Imputation des allocations clients (1=non,2=oui)   #
#         LGENSHT    : Génération des ruptures (toujours à 2=oui)         #
#         LALLPAR    : Allocations partielles  (toujours à 0=Autorisée)   #
#         LRAZCTM    : Raz n°contremarque pour désallocation (1=non,2=oui)#
#         LTRACE     : Ecriture dans la trace (0=non,1=oui)               #
#         LALLSTU    : Quantité à traiter                                 #
# Sortie  WRET       : Code retour                                        #
#-------------------------------------------------------------------------#
# ATTENTION : IL FAUT AVOIR L'ENTETE COMMANDE EN LIGNE                    #
#                           POUR TESTER LA CATEGORIE                      #
#-------------------------------------------------------------------------#
Subprog GENALLKIT (LSOHNUM, LSOPLIN, LSOQSEQ, LTRTLIG, LIMPCLI, LGENSHT, LALLPAR, LRAZCTM, LTRACE, LALLSTU, LRET)
Value    Char    LSOHNUM
Value    Integer LSOPLIN, LSOQSEQ
Value    Char    LTRTLIG
Value    Libelle LIMPCLI
Value    Libelle LGENSHT
Value    Libelle LALLPAR
Value    Libelle LRAZCTM
Value    Integer LTRACE
Value    Decimal LALLSTU
Variable Integer LRET

LRET = 0

Local    Decimal WCPESTU, WRAPPORT, WALLQTYSTU, WCPETALLSTU
Local    Decimal WSHTCPSSTU, WSHTCPS
Local    Decimal WALLCPSSTU, WALLCPS, WCPLQTY, WCPSTALLSTU
Local    Char    WMESS(80), WMESS1(80), WMESS2(80), WMESS3
Local    Char    WTRTORD
Local    Integer WALLSTA

If clalev ([F:SOQ1]) = 0 Local File SORDERQ [SOQ1] : Endif
If clalev ([F:SOP1]) = 0 Local File SORDERP [SOP1] : Endif

If clalev ([M:ALP])  = 0 Local Mask ALLPAR [ALP] : Endif

# --> Lecture du composé
Read [SOQ1]SOQ0 = LSOHNUM; LSOPLIN; LSOQSEQ
If fstat LRET=fstat :Call RSTA("SOQ", LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)) From GLOCK:End:Endif
Read [SOP1]SOP0 = LSOHNUM; LSOPLIN; LSOQSEQ
If fstat LRET=fstat :Call RSTA("SOP", LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)) From GLOCK:End:Endif
WCPESTU = [F:SOQ1]QTYSTU
WCPETALLSTU=[F:SOQ1]ALLQTYSTU+[F:SOQ1]ODLQTYSTU+[F:SOQ1]OPRQTYSTU+[F:SOQ1]PREQTYSTU
If [F:SOP1]SOHCAT = 3
    WCPETALLSTU+=[F:SOQ1]INVQTYSTU
Else
    WCPETALLSTU+=[F:SOQ1]DLVQTYSTU
Endif

# --> Lecture des composants
Filter [SOP1] Where SOHNUM = LSOHNUM & SOPLIN > LSOPLIN
For [SOP1]SOP0
# --- Sortie de la boucle qd on est plus sur un composant
    If !(find([F:SOP1]LINTYP, 3,4,5,11,12,13)) : Break :Endif
    Read [SOQ1]SOQ0 = [F:SOP1]SOHNUM; [F:SOP1]SOPLIN; [F:SOP1]SOPSEQ
    If fstat
       LRET=fstat
       Call RSTA("SOQ", [F:SOP1]SOHNUM-num$([F:SOP1]SOPLIN)-num$([F:SOP1]SOPSEQ)) From GLOCK
       Break
    Endif
#    --> Trt articles gérés ou non en stock
#    --> Trt articles avec contremarque receptionnée ssi en annulation (Désallocation)
#    --> Trt articles avec ordre de production       ssi en annulation (Désallocation)
    If [F:SOQ1]FMI <= 2 | ([F:SOQ1]FMI > 2 & LTRTLIG = "A")
#       Calcul de la qté à traiter du composant
        WRAPPORT = [F:SOQ1]QTYSTU / WCPESTU
#       Quantité totale à traiter sur le composant
        WALLQTYSTU=WRAPPORT * LALLSTU
        # Traitement qté allouée :
        # Cas d'une commande d'une nomenclature de sous-traitance avec un service forfaitaire
        # Si allocation partielle, le service forfaitaire est également alloué partiellement
        # Sur la dernière allocation, il faut vérifier que le service est complètement alloué (pb d'arrondi)
        If [F:SOP1]LINTYP=13
            # Si tout est alloué sur le composé, tout doit être alloué sur le service
            # (Total alloué = Total alloué-Ancienne allocation+nouvelle allocation)
            If WCPETALLSTU=WCPESTU
                WCPSTALLSTU=[F:SOQ1]ODLQTYSTU+[F:SOQ1]OPRQTYSTU+[F:SOQ1]PREQTYSTU
                If [F:SOP1]SOHCAT = 3
                    WCPSTALLSTU+=[F:SOQ1]INVQTYSTU
                Else
                    WCPSTALLSTU+=[F:SOQ1]DLVQTYSTU
                Endif
                If WCPSTALLSTU+WALLQTYSTU<>[F:SOQ1]QTYSTU
                    WALLQTYSTU=[F:SOQ1]QTYSTU-WCPSTALLSTU
                Endif
            Endif
        Endif
        WALLCPSSTU=0:WSHTCPSSTU=0
        Case LTRTLIG
            When "C" :
                WALLCPSSTU=WALLQTYSTU
            When "M" :
# Bug 25853
#                WALLCPSSTU=WALLQTYSTU
                WALLCPSSTU=WALLQTYSTU-[F:SOQ1]ALLQTYSTU-[F:SOQ1]SHTQTYSTU

                WSHTCPSSTU=[F:SOQ1]SHTQTYSTU
            When "A" :
                WALLCPSSTU=[F:SOQ1]ALLQTYSTU
                WSHTCPSSTU=[F:SOQ1]SHTQTYSTU
            When "D"
#               On diminue en priorité la quantité rupture
                If [F:SOQ1]SHTQTYSTU <> 0
                    If WALLQTYSTU < [F:SOQ1]SHTQTYSTU
#                       On décrémente la quantité rupture
                        WSHTCPSSTU = WALLQTYSTU
                    Else
#                       On annule la quantité rupture et on décrémente la quantité allouée
                        WSHTCPSSTU = [F:SOQ1]SHTQTYSTU
                        WALLQTYSTU -= WSHTCPSSTU
                        WALLCPSSTU = WALLQTYSTU
                    Endif
                Else
#                   On traite ensuite la quantité allouée
                    If WALLQTYSTU < [F:SOQ1]ALLQTYSTU
#                       On décrémente la quantité allouée
                        WALLCPSSTU = WALLQTYSTU
                    Else
#                       On annule la quantité allouée
                        LTRTLIG = "A"
                        WALLCPSSTU = [F:SOQ1]ALLQTYSTU
                    Endif
                Endif
             When Default
        Endcase
#       ---> Allocation
        If WALLCPSSTU + WSHTCPSSTU <> 0
            WMESS=mess([F:SOP1]LINTYP,423,1)-[F:SOQ1]ITMREF-[F:SOP1]ITMDES1
            If LTRACE Call ECR_TRACE("  "+WMESS,0) From GESECRAN : Endif
            If [F:SOQ1]STOMGTCOD <> 1
                # Article géré en stock : Génération de l'allocation
                # (Les quantité allouées et ruptures sont toujours positives)
                Call GENALLORD("[F:SOQ1]","[F:SOP1]",LTRTLIG, LIMPCLI, LGENSHT, LALLPAR, WALLCPSSTU, WSHTCPSSTU, LRET) From TRTVENALL
                If LRET <> 0 Break Endif
            Else
                # Article non géré en stock
                If LTRACE Call ECR_TRACE("     "+mess(283,197,1),0) From GESECRAN : Endif
            Endif
#           Conversion des quantités allouée et en rupture en UV pour la trace
            WALLCPS=WALLCPSSTU*(1/[F:SOP1]SAUSTUCOE)
            Call QTEARR(WALLCPS, [F:SOP1]SAU) From TRTDIV
            WSHTCPS=WSHTCPSSTU*(1/[F:SOP1]SAUSTUCOE)
            Call QTEARR(WSHTCPS, [F:SOP1]SAU) From TRTDIV
#           Recalcul des nouvelles Qtés allouées et ruptures
#           Création et modification  : Qté allouée en +
#                                       Nouvelle Qté rupture
#           Annulation  et diminution : Qté allouée en -
#                                       Qté rupture en -
            If find(LTRTLIG, "C","M")
                [F:SOQ1]ALLQTYSTU += WALLCPSSTU
                [F:SOQ1]SHTQTYSTU = WSHTCPSSTU
            Else
                [F:SOQ1]ALLQTYSTU -= WALLCPSSTU
                [F:SOQ1]SHTQTYSTU -= WSHTCPSSTU
                WALLCPS *=-1
                WSHTCPS *=-1
            Endif
#           Mise à jour de la commande
            Call MAJALLORD([F:SOQ1]SOHNUM, [F:SOQ1]SOPLIN, [F:SOQ1]SOQSEQ, [F:SOQ1]ALLTYP, LRAZCTM, [F:SOQ1]ALLQTYSTU, [F:SOQ1]SHTQTYSTU, LRET) From TRTVENALL
            If LRET <> 0 : Break : Endif
#
            Read [SOQ1] Curr
            If fstat
                LRET=fstat
                Call RSTA("SOQ", [F:SOP1]SOHNUM-num$([F:SOP1]SOPLIN)-num$([F:SOP1]SOPSEQ)) From GLOCK
                Break
            Endif
            If [F:SOQ1]STOMGTCOD<>1
                WMESS1 = mess(106,197,1)+":"+format$("N:15F", WALLCPS)-[F:SOP1]SAU
                WMESS2 = mess(107,197,1)+":"+format$("N:15F", WSHTCPS)-[F:SOP1]SAU
                If LTRACE Call ECR_TRACE("     "+mess(479,197,1)-WMESS1-WMESS2,0) From GESECRAN : Endif
            Endif
            If [F:SOH]SOHCAT = 3 WCPLQTY = [F:SOQ1]INVQTYSTU Else WCPLQTY = [F:SOQ1]DLVQTYSTU : Endif
            WALLSTA=1
#            If ([F:SOQ1]ALLQTYSTU+[F:SOQ1]ODLQTYSTU+WCPLQTY)>=[F:SOQ1]QTYSTU & [F:SOQ1]SHTQTYSTU=0
            If ([F:SOQ1]ALLQTYSTU+[F:SOQ1]OPRQTYSTU+[F:SOQ1]PREQTYSTU+[F:SOQ1]ODLQTYSTU+WCPLQTY)>=[F:SOQ1]QTYSTU & [F:SOQ1]SHTQTYSTU=0
                WALLSTA = 3
            Elsif [F:SOQ1]ALLQTYSTU <> 0
                WALLSTA = 2
            Endif
            If LTRTLIG <> "A"
                WMESS1 = mess(480,197,1)-format$("N:15F", [F:SOQ1]QTY)-[F:SOP1]SAU
                WMESS2 = mess(481,197,1)-format$("N:15F", [F:SOQ1]ALLQTY)
                WMESS3 = mess(66,191,1)-":"-format$("N:15F", [F:SOQ1]SHTQTY)
                If LTRACE Call ECR_TRACE("     "+mess(18,197,1)-mess(WALLSTA,416,1)-"=>"-WMESS1-WMESS2-WMESS3,0) From GESECRAN : Endif
            Endif
        Endif
    Endif
Next
Filter [SOP1]
End

#-------------------------------------------------------------------------#
# Maj des zones d'allocations dans une commande                           #
#-------------------------------------------------------------------------#
# Entrée  LSOHNUM   : N° de la commande                                   #
#         LSOPLIN   : N° ligne                                            #
#         LSOQSEQ   : N° séquence                                         #
#         LALLTYP   : Type d'allocation                                   #
#         LRAZCTM   : Raz n°contremarque pour désallocation (1=non,2=oui) #
#         LALLQTY   : Qté allouée                                         #
#         LSHTQTY   : Qté rupture                                         #
# Sortie  LRET      : 0 Ok ; 1 Pb                                         #
#-------------------------------------------------------------------------#
Subprog MAJALLORD(LSOHNUM, LSOPLIN, LSOQSEQ, LALLTYP, LRAZCTM, LALLSTU, LSHTSTU, LRET)
Value    Char    LSOHNUM
Value    Integer LSOPLIN
Value    Integer LSOQSEQ
Value    Integer LALLTYP
Value    Libelle LRAZCTM
Value    Decimal LALLSTU
Value    Decimal LSHTSTU
Variable Integer LRET    : LRET=0

Local    Integer WALLLINNBR, WALLSTA
Local    Decimal WALL, WSHT, WCPLQTY
Local    Char    WTRTORD

If clalev ([F:SOH]) = 0 Local File SORDER  [SOH] : Endif
If clalev ([F:SOQ]) = 0 Local File SORDERQ [SOQ] : Endif
If clalev ([F:SOP]) = 0 Local File SORDERP [SOP] : Endif
If GMODU(6)=2 & clalev([F:POQ])=0 : Local File PORDERQ [POQ] : Endif

# --- Déclaration classe ecran pour les encours
If clalev ([M:ORDK])= 0 Local Mask ORDK    [ORDK] : Endif

If [F:SOH]SOHNUM<>LSOHNUM                    : # Issue 116484
    Read [SOH]SOH0=LSOHNUM
    If fstat LRET=1 : Call RSTA("SOH", [F:SOH]SOHNUM) From GLOCK : End : Endif
Endif                                        : # Issue 116484

#--- Issue 119042 ajout du lockwait
Readlock [SOQ]SOQ0 = LSOHNUM;LSOPLIN;LSOQSEQ With lockwait=3
If fstat LRET=1 : Call RSTA("SOQ", LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)) From GLOCK : End : Endif
Read [SOP]SOP0 = [F:SOQ]SOHNUM; [F:SOQ]SOPLIN; [F:SOQ]SOQSEQ
If fstat & [F:SOH]SOHCAT <> 4
    LRET=1 : Call RSTA("SOP", LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)) From GLOCK : End
Elsif fstat
    If clalev ([F:SOC]) = 0 Local File SORDERC [SOC] : Endif
    If [F:SOC]SOHNUM <> [F:SOQ]SOHNUM | [F:SOC]SOPLIN <> [F:SOQ]SOPLIN
        Raz [F:SOP]
        Read [SOC]SOC0 = [F:SOQ]SOHNUM; [F:SOQ]SOPLIN
        If fstat LRET=1 : Call RSTA("SOC", LSOHNUM-num$(LSOPLIN)) From GLOCK : End : Endif
    Endif
    [F:SOP] = [F:SOC]
Endif
If [F:SOH]SOHCAT = 3
    WCPLQTY = [F:SOQ]INVQTYSTU
Else
    WCPLQTY = [F:SOQ]DLVQTYSTU
Endif
# --- Calcul ancien statut allocation de la ligne
# Calcul de la qté réalisée : Livré ou facturé selon le type de commande
If [F:SOQ]ALLQTYSTU + [F:SOQ]OPRQTYSTU +[F:SOQ]PREQTYSTU + [F:SOQ]ODLQTYSTU + WCPLQTY >= [F:SOQ]QTYSTU
&       &  [F:SOQ]SHTQTYSTU = 0 & ([F:SOQ]STOMGTCOD <> 1  | find([F:SOP]LINTYP,2,10))
# --- La ligne etait allouée
    WALLSTA = 2
Else
# --- La ligne n'etait pas allouée
    WALLSTA = 1
Endif

WALL=LALLSTU*(1/[F:SOP]SAUSTUCOE)
Call QTEARR(WALL, [F:SOP]SAU) From TRTDIV
WSHT=LSHTSTU*(1/[F:SOP]SAUSTUCOE)
Call QTEARR(WSHT, [F:SOP]SAU) From TRTDIV
[F:SOQ]ALLQTY     = WALL
[F:SOQ]ALLQTYSTU  = LALLSTU
[F:SOQ]SHTQTY     = WSHT
[F:SOQ]SHTQTYSTU  = LSHTSTU
[F:SOQ]ALLTYP     = LALLTYP

# --- raz du n°contremarque (En désallocation)
If LRAZCTM = 2 & ([F:SOQ]FMI = 3 | [F:SOQ]FMI = 5)
    Raz [F:SOQ]FMINUM, [F:SOQ]FMILIN, [F:SOQ]FMISEQ
Endif

Rewrite [F:SOQ]
If fstat LRET=1 : Call FSTA("SOQ") From GLOCK : Endif

# Issue 120079
# Maj de l'encours uniquement pour les articles gérés en stock
# (Kits et composants non gérés en stock : Juste alimentation de la qté allouée ds la cde)
# --> Mise à jour de l'encours
#WTRTORD = "M" : Gosub APPELWIP From TRTVENMAJ
#If GOK < 1 LRET=1 : End : Endif
#
## V6 Affectations
#Gosub MAJ_MTO_SOQ From SALMTOLIB
If [F:SOQ]STOMGTCOD <> 1
    # --> Mise à jour de l'encours
    WTRTORD = "M" : Gosub APPELWIP From TRTVENMAJ
    If GOK < 1 LRET=1 : End : Endif

    # V6 Affectations
    Gosub MAJ_MTO_SOQ From SALMTOLIB
Endif
# End Issue 120079

WALLLINNBR+=1
# Bug 53787 : Pour un kit non géré, la ligne ne change pas d'état (la ligne n'est pas à allouer)
# La ligne est passée du statut non alloué au statut alloué
If [F:SOQ]ALLQTYSTU + [F:SOQ]OPRQTYSTU +[F:SOQ]PREQTYSTU + [F:SOQ]ODLQTYSTU + WCPLQTY >= [F:SOQ]QTYSTU
&       &  [F:SOQ]SHTQTYSTU = 0 & [F:SOQ]STOMGTCOD <> 1
&       &  WALLSTA = 1
    WALLLINNBR *=-1
# La ligne est passée du statut alloué au statut non alloué
Elsif ([F:SOQ]ALLQTYSTU + [F:SOQ]OPRQTYSTU + [F:SOQ]PREQTYSTU + [F:SOQ]ODLQTYSTU + WCPLQTY < [F:SOQ]QTYSTU
&       | [F:SOQ]SHTQTYSTU <> 0) & [F:SOQ]STOMGTCOD <> 1
&       &  WALLSTA = 2
    WALLLINNBR *=1
Else
# La ligne n'a pas changé d'état
    WALLLINNBR=0
Endif

If [F:SOH]SOHCAT <> 4
#   -----------------------------------------------------------------------#
#   Mise à jour de l'entête commande                                      #
#   -----------------------------------------------------------------------#
#     --> Il faut bloquer la commande
    #--- Issue 119042 ajout du lockwait
    Readlock [SOH]SOH0=[F:SOH]SOHNUM With lockwait=3
    If fstat LRET=1 : Call RSTA("SOH", [F:SOH]SOHNUM) From GLOCK : End : Endif
    # --> Décrémentation du nbre lignes à allouer
    [F:SOH]ALLLINNBR += WALLLINNBR
    # --> Mise à jour de l'état allocation
    If [F:SOH]ALLLINNBR = 0
        # Aucune ligne à allouer
        # ==> La cde est totalement allouée ou non allouée (aucune ligne gérée en stock)
        [F:SOH]ALLSTA=3
        If [F:SOH]LINNBR>1 Gosub CALC_ALLSTA Endif
    Elsif [F:SOQ]ALLQTYSTU <> 0
        [F:SOH]ALLSTA=2
    Elsif [F:SOH]ALLLINNBR >= [F:SOH]LINNBR
        [F:SOH]ALLSTA = 1 : # Ttes les lignes sont à allouer
    Else
        # Nbre de lignes à allouer < Nbre de lignes de la cde
        # ==> Le cde est partiellement allouée ou non allouée (aucune ligne gérée en stock)
        [F:SOH]ALLSTA = 2
        Gosub CALC_ALLSTA
    Endif
#   ---------------------------------------------------------------------#
#    Point d'entree mise à jour de la commande                           #
#   ---------------------------------------------------------------------#
    GPOINT="MAJCDEALL" : Gosub ENTREE From EXEFNC
    If GOK < 1 LRET=1 : End : Endif
    # --> Reecriture de la commande
    Rewrite [SOH]
    If fstat LRET=1 : Call FSTA("SOH") From GLOCK : Endif
Else
#   ---------------------------------------------------------------------#
#   Utilisation du PE MAJCDEALL pour les commandes ouvertes              #
#   ---------------------------------------------------------------------#
#    Point d'entree mise à jour de la commande                           #
#   ---------------------------------------------------------------------#
    GPOINT="MAJCDEALL" : Gosub ENTREE From EXEFNC
    If GOK < 1 LRET=1 : End : Endif
Endif

End


#-------------------------------------------------------------------------#
# Calcul de l'état d'allocation                                           #
#-------------------------------------------------------------------------#
$CALC_ALLSTA

# Issue 116484
#If clalev ([F:SOQ1]) = 0 Local File SORDERQ [SOQ1] : Endif
#
#Columns [SOQ1] (SOHNUM, SOPLIN, SOQSEQ, ALLQTYSTU, SHTQTYSTU)
#Filter [SOQ1] Where SOHNUM=[F:SOH]SOHNUM & sum(ALLQTYSTU, SHTQTYSTU)<>0
#Look [SOQ1]SOQ0 First
#If fstat [F:SOH]ALLSTA=1 : Endif : # Aucune ligne n'a des allocations : Commande non allouée
#Filter [SOQ1]
#Columns [SOQ1]

Local File SORDERQ [SOQW] Where sum(ALLQTYSTU, SHTQTYSTU)<>0

Look [F:SOQW]SOQ0=[F:SOH]SOHNUM
If fstat [F:SOH]ALLSTA=1 : Endif : # Aucune ligne n'a des allocations : Commande non allouée
# End issue 116484

Return

#-------------------------------------------------------------------------#
# Recherche des ruptures d'un article                                     #
#-------------------------------------------------------------------------#
# Entrée  LFCY       : Site                                               #
#         LITM       : Référence article                                  #
# Sortie  LSHT       : Total des ruptures                                 #
#-------------------------------------------------------------------------#
Subprog RECITMSHT (LFCY, LITM, LSHT)
Value    Char    LFCY
Value    Char    LITM
Variable Decimal LSHT

If clalev([F:ITV]) = 0 Local File ITMMVT [ITV] Endif

If [F:ITV]ITMREF<>LITM | [F:ITV]STOFCY<>LFCY
    Read [ITV]ITV0=LITM;LFCY
    If fstat Raz [F:ITV] : Endif
Endif
LSHT = [F:ITV]DETSHT+[F:ITV]GLOSHT

End

#-------------------------------------------------------------------------#
# Allocation/Déallocation d'une ligne de commande                         #
#            génération de l'allocation et maj de la commande             #
#-------------------------------------------------------------------------#
# Entrée  LVCRNUM   : N° de commande                                      #
#         LVCRLIN   : N° ligne                                            #
#         LVCRSEQ   : N° séquence                                         #
#         LTRTALL   : Code traitement : (1=Allocation, 2=Désallocation)   #
#         LIMPCLI   : Imputation des allocations client (1=Non,2=Oui)     #
#         LGENSHT   : Génération des ruptures (1=Non,2=Oui)               #
#         LALLPAR   : Allocations partielles  (1=non,2=Oui)               #
#         LABREV    : Abréviation du masque à réafficher                  #
#         LNOL      : Indice de la ligne à réafficher                     #
#-------------------------------------------------------------------------#
Subprog DIVALLORD(LVCRNUM, LVCRLIN, LVCRSEQ, LTRTALL, LIMPCLI, LGENSHT, LALLPAR, LABREV, LNOL)
Value Char    LVCRNUM
Value Integer LVCRLIN
Value Integer LVCRSEQ
Value Integer LTRTALL
Value Libelle LIMPCLI
Value Libelle LGENSHT
Value Libelle LALLPAR
Value Char    LABREV
Value Integer LNOL

If clalev ([F:SOH]) = 0 Local File SORDER  [SOH] : Endif
If clalev ([F:SOQ]) = 0 Local File SORDERQ [SOQ] : Endif
If clalev ([F:SOP]) = 0 Local File SORDERP [SOP] : Endif
If clalev ([F:SOC]) = 0 Local File SORDERC [SOC] : Endif

Local Integer WRET
Local Decimal WALLSTU, WSHTSTU, WTALLSTU, WALLCPS, WALL, WSHT
Local Char    WMESS(80), WMESS1(80), WMESS2(80), SYMBOLE(50), WTRTLIG, SYMBOLESOC(50)

Local Decimal WALLKIT
#--------------------------------------------------#
# Verrouillage de la commande                      #
#--------------------------------------------------#
#VPO 18/05/09 54861 pb lock cde ouverte
SYMBOLESOC=""

SYMBOLE = "SOH"+LVCRNUM
Lock = SYMBOLE
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=LVCRNUM-":"-mess(10,100,1) : End
Endif
Gosub TRT_DIVALL
#--------------------------------------------------#
# Suppression du verrou sur la commande            #
#--------------------------------------------------#
#VPO 18/05/09 54861 pb lock cde ouverte
If SYMBOLESOC<>""
    Unlock=SYMBOLESOC
Endif

Unlock=SYMBOLE
End


$TRT_DIVALL
Call DEBTRANS From GLOCK
GOK=1
Trbegin [SOH],[SOQ],[SOP]

    Read [SOH]SOH0 = LVCRNUM
    If fstat=1
        GOK=-1 : GLOCK="$SORDER"-LVCRNUM: Goto ROLL_DIVALL
    Elsif fstat
        GOK=0  : Call RSTA ("SOH",LVCRNUM) From GLOCK : Goto AB_DIVALL
    Endif
    #VPO 18/05/09 54861 pb lock cde ouverte
    If [F:SOH]SOHCAT = 4
        # Lock fichier commande ouverte
        SYMBOLESOC = "SOC"+num$(LVCRLIN)+"\"+LVCRNUM
        Lock = SYMBOLESOC
        If fstat
            GMESSAGE=LVCRNUM-":"-mess(10,100,1)
            GOK=0 : Goto AB2_DIVALL
        Endif
    Endif
    Read [SOQ]SOQ0 = LVCRNUM; LVCRLIN; LVCRSEQ
    If fstat=1
        GOK=-1 : GLOCK="$SORDERQ"-LVCRNUM-num$(LVCRLIN)-num$(LVCRSEQ) : Goto ROLL_DIVALL
    Elsif fstat
        GOK=0  : Call RSTA ("SOQ",LVCRNUM-num$(LVCRLIN)-num$(LVCRSEQ)) From GLOCK : Goto AB_DIVALL
    Endif
    Read [SOP]SOP0 = LVCRNUM; LVCRLIN; LVCRSEQ
    If fstat=1
        GOK=-1 : GLOCK="$SORDERP"-LVCRNUM-num$(LVCRLIN)-num$(LVCRSEQ) : Goto ROLL_DIVALL
    Elsif fstat & [F:SOH]SOHCAT <> 4
        GOK=0  : Call RSTA ("SOP",LVCRNUM-num$(LVCRLIN)-num$(LVCRSEQ)) From GLOCK : Goto AB_DIVALL
    Elsif fstat
        Raz [F:SOP]
        Read [SOC]SOC0 = [F:SOQ]SOHNUM; [F:SOQ]SOPLIN
        If fstat=1
            GOK=-1 : GLOCK="$SORDERC"-LVCRNUM-num$(LVCRLIN) : Goto ROLL_DIVALL
        Elsif fstat
            GOK=0  : Call RSTA ("SOC",LVCRNUM-num$(LVCRLIN)) From GLOCK : Goto AB_DIVALL
        Endif
        #VPO 19/05/09 55287 manque info sur SOP
        [F:SOP]=[F:SOC]
    Endif
#   ------------------------------   #
#   Calcul des quantités à traiter   #
#   ------------------------------   #
    Case LTRTALL
        When 1 :    #    Allocation
            WTALLSTU = [F:SOQ]ALLQTYSTU+[F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU+[F:SOQ]ODLQTYSTU
            If [F:SOH]SOHCAT = 3
                WTALLSTU += [F:SOQ]INVQTYSTU
            Else
                WTALLSTU += [F:SOQ]DLVQTYSTU
            Endif
            WALLSTU = [F:SOQ]QTYSTU - WTALLSTU - [F:SOQ]SHTQTYSTU
            WALLCPS = WALLSTU
            WSHTSTU = [F:SOQ]SHTQTYSTU
            If [F:SOQ]ALLQTYSTU = 0 & [F:SOQ]SHTQTYSTU = 0 WTRTLIG = "C"
            Else WTRTLIG = "M" :Endif
        When 2 :    #    Désallocation
            WALLSTU = [F:SOQ]ALLQTYSTU
            WALLCPS = 0
            WSHTSTU = [F:SOQ]SHTQTYSTU
            WTRTLIG = "A"
        When Default
    Endcase
#   ------------------------------------------   #
#   Positionnement des paramètres d'allocation   #
#   ------------------------------------------   #
#   Allocation partielle toujours autorisée
#   Sauf si non cochée ds l'écran et livraison.ligne/cde complète et ce n'est pas un kit
#   (Un kit/sous-traité et ses composants ne peuvent être alloués partiellement sinon déphasage possible)
    If LALLPAR=1 & find([F:SOH]DME,2,3) & !find([F:SOP]LINTYP,2,3,4,5,10,11,12,13) LALLPAR=1
    Else LALLPAR=0 : Endif
#   Génération des ruptures
#   Si cochée à l'écran ou kit
#   On génère toujours les ruptures sur un kit/sous-traité et ses composants (sinon déphasage possible)
    If find([F:SOP]LINTYP,2,3,4,5,10,11,12,13) LGENSHT=2 Endif
#   Articles gérés en stock               : Désallocation et maj de la cde
#   (Les quantité allouées et ruptures sont toujours positives)
#   Kits et composants non gérés en stock : Juste maj de la qté allouée ds la cde
    If [F:SOQ]STOMGTCOD <> 1
#       ----------------------------------   #
#       Allocation de la ligne de commande   #
#       ----------------------------------   #
        Call GENALLORD("","",WTRTLIG, LIMPCLI, LGENSHT, LALLPAR, WALLSTU, WSHTSTU, WRET) From TRTVENALL
        If WRET=2 & GOK=1
            GMESSAGE=mess(103,197,1)-":"-mess(105,197,1)-":"-mess(367,199,1)
            Call MESSAGE(GMESSAGE) From GESECRAN : GOK=0 : Goto AB_DIVALL
        Elsif WRET <> 0
            GMESSAGE=mess(96,197,1) : Call MESSAGE(GMESSAGE) From GESECRAN
            GOK=0 : Goto AB_DIVALL
        Endif
    Endif
#   -----------------------------------   #
#   Mise à jour de la ligne de commande   #
#   -----------------------------------   #
    WALL=WALLSTU*(1/[F:SOP]SAUSTUCOE)
    Call QTEARR(WALL, [F:SOP]SAU) From TRTDIV
    WSHT=WSHTSTU*(1/[F:SOP]SAUSTUCOE)
    Call QTEARR(WSHT, [F:SOP]SAU) From TRTDIV
    Case LTRTALL
        When 1 :    #    Allocation
            WALLSTU= [F:SOQ]ALLQTYSTU + WALLSTU
        When 2 :    #    Désallocation
            WALL*=-1
            WSHT*=-1
            WALLSTU=[F:SOQ]ALLQTYSTU-WALLSTU
            WSHTSTU=[F:SOQ]SHTQTYSTU-WSHTSTU
    Endcase
    Call MAJALLORD([F:SOQ]SOHNUM, [F:SOQ]SOPLIN, [F:SOQ]SOQSEQ, [F:SOQ]ALLTYP, 1, WALLSTU, WSHTSTU, WRET) From TRTVENALL
    If WRET <> 0 : GOK = 0 : Goto AB_DIVALL : Endif
#   Ecriture dans la trace
#    WALL=([F:SOQ]ALLQTYSTU*(1/[F:SOP]SAUSTUCOE))*-1
#    Call QTEARR(WALL, [F:SOP]SAU) From TRTDIV
#    WSHT=([F:SOQ]SHTQTYSTU*(1/[F:SOP]SAUSTUCOE))*-1
#    Call QTEARR(WSHT, [F:SOP]SAU) From TRTDIV

    If [F:SOQ]STOMGTCOD<>1
        GERR=2
        WMESS1 = mess(106,197,1)+":"+format$("N:15F", WALL)-[F:SOP]SAU
        WMESS2 = mess(107,197,1)+":"+format$("N:15F", WSHT)-[F:SOP]SAU
        GMESSAGE=mess(479,197,1)-WMESS1-WMESS2
#        Call MESSAGE(GMESSAGE) From GESECRAN
    Endif

#   Si Composé de kit/sous-traité, il faut traiter les composants
    If find([F:SOP]LINTYP,2,10)

#        Call GENALLKIT ([F:SOQ]SOHNUM, [F:SOQ]SOPLIN, [F:SOQ]SOQSEQ, WTRTLIG, LIMPCLI, LGENSHT, LALLPAR, 1, 0, WALLSTU, WRET) From TRTVENALL


# Bug 25853
        WALLKIT=WALLSTU+WSHTSTU
        Call GENALLKIT ([F:SOQ]SOHNUM, [F:SOQ]SOPLIN, [F:SOQ]SOQSEQ, WTRTLIG, LIMPCLI, LGENSHT, LALLPAR, 1, 0, WALLKIT, WRET) From TRTVENALL

        If WRET <> 0
#           Call ECR_TRACE(WMESS,0) From GESECRAN
            GMESSAGE=mess(194,197,1)
            Goto AB_DIVALL
        Endif
    Endif
Commit
Gosub AFF_ABREV
Return

$ROLL_DIVALL
Rollback : Call ROLL From GLOCK
If GROLL
    GMESSAGE=mess(17,107,1)
Else Goto TRT_DIVALL
Endif
Return
$AB_DIVALL
Rollback
GMESSAGE=mess(17,107,1)
Return
$AB2_DIVALL
Rollback
Return


#    Réaffichage des masques après
$AFF_ABREV

Case LABREV
    When "SAL2"
       Gosub MAJ_MSK_SAL2 From FUNMANALL
    When Default
Endcase

Return

###########################################################################
#-------------------------------------------------------------------------#
# STODISKIT : Calcul du stock disponible des composants d'un kit          #
#             pour détermination de la quantité livrable                  #
#-------------------------------------------------------------------------#
# Entrée  WTRSTYP       : Type de transaction                             #
#         WTRSCOD       : Code mouvement                                  #
#         WQTYCPE       : Quantité à livrer                               #
#         WQTYSTUCPE    : Quantité à livrer (US)                          #
# Sortie  WQTYCPE       : Quantité que l'on peut livrer                   #
#         WQTYSTUCPE    : Quantité que l'on peut livrer (US)              #
#         WRET          : Code retour                                     #
#-------------------------------------------------------------------------#
Subprog STODISKIT (WTRSTYP,WTRSCOD,WQTYCPE,WQTYSTUCPE,WRET)
Value    Libelle WTRSTYP
Value    Char    WTRSCOD
Variable Decimal WQTYCPE
Variable Decimal WQTYSTUCPE
Variable Integer WRET

Raz WRET

Local    Decimal RAPPORT, WQTY, QTYCPE, WQTYSTUCPS, WQTYCPS
Local    Decimal QDISSTUCPE, QDISCPE, QDISSTUCPS, QDISCPS
Local    Decimal WQTYCPE, WCOEFCPE, WCOEFCPS
Local    Integer WSTA, WA, WQ, WR

If WQTYSTUCPE=0 End Endif
If clalev ([F:SOQ1]) = 0 Local File SORDERQ [SOQ1]:Endif
If clalev ([F:SOP1]) = 0 Local File SORDERP [SOP1]:Endif

QTYCPE   = [F:SOQ]QTY
WCOEFCPE = [F:SOP1]SAUSTUCOE
WQTYCPE  = WQTYSTUCPE*(1/WCOEFCPE)
Call QTEARR(WQTYCPE, [F:SOP1]SAU) From TRTDIV

# ---> Recherche stock disponible des composants
Filter [SOP1] Where SOHNUM = WSOHNUM & SOPLIN > WSOPLIN
For [SOP1]
    # --- Sortie de la boucle qd on est plus sur un composant
    If !(find([F:SOP1]LINTYP, 3,4,5,11,12,13)) Break Endif
    Read [SOQ1]SOQ0 = [F:SOP1]SOHNUM; [F:SOP1]SOPLIN; [F:SOP1]SOPSEQ
    If fstat
       Call RSTA("SOQ", [F:SOP1]SOHNUM-num$([F:SOP1]SOPLIN)-num$([F:SOP1]SOPSEQ)) From GLOCK
       Raz QDISSTUCPE : WRET=fstat : Break
    Endif
    If [F:SOQ1]STOMGTCOD <> 1 & [F:SOQ1]FMI <= 1
       # --- Calcul de la qté à allouer du composant en UV et en US
       RAPPORT = [F:SOQ1]QTY / QTYCPE
       WQTYCPS = RAPPORT * WQTYCPE
       WCOEFCPS= [F:SOP1]SAUSTUCOE
       WQTYSTUCPS=WQTYCPS*WCOEFCPS
       Call QTEARR(WQTYSTUCPS, [F:SOP1]STU) From TRTDIV

       # Lecture des articles
       Call LECITM([F:SOQ1]STOFCY,[F:SOQ1]ITMREF,"",0,"",WRET) From STKLIB
       If WRET<>0 Break Endif
       # Lecture de la règle de gestion à utiliser
       Call LECSRU([F:SOQ1]STOFCY,[F:ITM]TCLCOD,WTRSTYP,WTRSCOD,"",WRET) From STKLIB
       If WRET<>0 Break Endif
       # Statuts autorisés par la règle de gestion
       If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
       If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
       If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
       WSTA = WA+2*WQ+4*WR
       # Calcul stock disponible
       Call STODISTOT("",1,WSTA,"",QDISSTUCPS) From STKLIB

       QDISCPS =QDISSTUCPS*(1/WCOEFCPS)
       Call QTEARR(QDISCPS, [F:SOP1]SAU) From TRTDIV
       # --- Il faut que la qté reste un multiple du rapport cpé/cps
       QDISCPS = QDISCPS - mod(QDISCPS, RAPPORT)
       # --- Recherche si la qté à allouer est dispo
       If QDISCPS <= 0 QDISSTUCPE=0 : Break : Endif
       If QDISCPS < WQTYCPS
          # --- Calcul qte à allouer composé par rapport au dispo. composant
          WQTY = QDISCPS / RAPPORT
          If WQTY = 0 QDISSTUCPE=0 : Break : Endif
          If WQTY < QDISCPE
             QDISCPE = WQTY
             QDISSTUCPE=QDISCPE*WCOEFCPE
          Endif
       Endif
    Endif
Next
Filter [SOP1]
If WRET=0 & QDISSTUCPE=0
   GMESSAGE = [F:SOQ1]ITMREF-mess(35,197,1)-mess(409,197,1)
Endif
# Alimentation de la quantité à livrer
WQTYSTUCPE = QDISSTUCPE

End

#--------------------------------------------------------------------------#
# MAJALLBPC : Modification d'une allocation client                         #
#--------------------------------------------------------------------------#
# Entrée  LDAT = date limite allocation globale                            #
#         LTYP = type de pièce                                             #
#         LNUM = numero de pièce                                           #
#         LLIN = numero ligne pièce                                        #
#         LSEQ = Numéro sequence pièce                                     #
#         LPRE = Numéro préparation                                        #
# Sortie  LRET = code retour                                               #
#--------------------------------------------------------------------------#
Subprog MAJALLBPC(LDAT,LTYP,LNUM,LLIN,LSEQ,LPRE,LRET)
Value    Date    LDAT
Value    Integer LTYP
Value    Char    LNUM
Value    Decimal LLIN
Value    Decimal LSEQ
Value    Char    LPRE
Variable Integer LRET
#
LRET = 0

#--------------------------------------------------------#
# Modification de l'allocation                           #
#--------------------------------------------------------#
If clalev([F:STA]) = 0 Local File STOALL [STA] : Endif

Filter [STA] Where VCRTYP = LTYP &
&                  VCRNUM = LNUM &
&                  VCRLIN = LLIN &
&                  VCRSEQ = LSEQ Order By Key STA1
For [STA]
    Readlock
    If fstat <> 0  LRET =fstat : Break : Endif
    [F:STA]ALLDAT     = LDAT
    [F:STA]VCRTYP     = LTYP
    [F:STA]VCRNUM     = LNUM
    [F:STA]VCRLIN     = LLIN
    [F:STA]VCRSEQ     = LSEQ
    [F:STA]PRENUM     = LPRE
    [F:STA]UPDDAT     = date$
    [F:STA]UPDUSR     = GUSER
    Rewrite [STA]
    If fstat LRET= fstat : Call FSTA("STA") From GLOCK : Break : Endif
Next
Filter [STA]
End


########################################################################
$REAJUSTE_QTY
#---------------------------------------------
# TS : réajustement qté en unité vente entière
#---------------------------------------------

GPOINT = "NO_REAJUST" : Gosub ENTREE From EXEFNC
If GOK=0 : GOK=1 :  Return : Endif

If [M:ALP]PCU<>[F:ITM]STU
   Call CTRQTYPCU([M:ALP]PCU,[M:ALP]PCUSTUCOE,WQTYSTU,WQTYARR) From STKLIB
   If WQTYARR<>WQTYSTU
      Call QTEARR(WQTYARR,[F:ITM]STU) From TRTDIV : # 96288 : Pb qté US calculée non arrondie
      WQTYSTU = WQTYARR
      WQTY    = WQTYSTU/[M:ALP]PCUSTUCOE
      Call QTEARR(WQTY,[M:ALP]PCU) From TRTDIV    : # 96288 : Pb qté US calculée non arrondie
   Endif
Endif
Return
#---------------------------------------------

#####################################################################################
# MAJORDBPC : Suite à Consommation des réservations clients                         #
#             Maj de l'encours correspondant (diminution de la qté ou suppression)  #
#####################################################################################
# Paramètres E : LTYP = Type de pièce (1=client)
#                LNUM = Numéro pièce (no client+code adresse / 10x+3x)
#                LITM = Article
#                LFCY = Site
#                LQTA = Quantité UA à traiter
#            S : LRET = Code retour (0=OK / 1=Erreur)
#
########################################################################
Subprog MAJORDBPC(LTYP,LNUM,LITM,LFCY,LQTA,LRET)
Value    Integer LTYP
Value    Char    LNUM
Value    Char    LITM
Value    Char    LFCY
Value    Decimal LQTA
Variable Integer LRET

#Local Char     WTRTORD, WVCRRER, WWIPNUM, WITMREF, WSTOFCY, WORIFCY # FGR 13/04/2015 : X3SUIVI105605
Local Date     WALLDAT
Local Decimal  WLIN, LQTY, WQTY

LRET=0
If clalev([F:ORD]) = 0 Local File ORDERS     [ORD] : Endif
# --------------------------------------
# FGR 13/04/2015 : X3SUIVI105605 (début)
Local Char     WTRTORD(1)
Local Char     WVCRRER(type(LNUM)-10)
Local Char     WWIPNUM(type([F:ORD]WIPNUM)-10)
Local Char     WITMREF(type([F:ORD]ITMREF)-10)
Local Char     WSTOFCY(type([F:ORD]STOFCY)-10)
Local Char     WORIFCY(type([F:ORD]ORIFCY)-10)
If func AFNC.ACTIV("ECC") Then
  Local Char   WECCVALMAJ(type([F:ORD]ECCVALMAJ)-10)
  Local Char   WECCVALMIN(type([F:ORD]ECCVALMIN)-10)
Endif
# FGR 13/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------

WVCRRER=LNUM
WQTY=LQTA
Gosub MAJ_ORDERS_BPC
If LRET <> 0 End Endif
If WQTY > 0
    WVCRRER=vireblc(left$(LNUM,10), 1)
    Gosub MAJ_ORDERS_BPC
Endif

LQTA=WQTY
End

$MAJ_ORDERS_BPC
# On recherche les en-cours qui correspondent
Filter [ORD] Where STOFCY=LFCY & VCRTYP=LTYP & VCRNUM=WVCRRER & VCRSEQ=0 & ITMREF=LITM
For [ORD]ORD3
    WWIPNUM=[F:ORD]WIPNUM
    WITMREF=[F:ORD]ITMREF
    # --------------------------------------
    # FGR 13/04/2015 : X3SUIVI105605 (début)
    If dim(WECCVALMAJ) >= 0 Then
      WECCVALMAJ = [F:ORD]ECCVALMAJ
    Endif
    If dim(WECCVALMIN) >= 0 Then
      WECCVALMIN = [F:ORD]ECCVALMIN
    Endif
    # FGR 13/04/2015 : X3SUIVI105605 (fin)
    # --------------------------------------
    WSTOFCY=[F:ORD]STOFCY
    WORIFCY=[F:ORD]ORIFCY
    WALLDAT=[F:ORD]ENDDAT

    LNUM   =[F:ORD]VCRNUM
    WLIN   =[F:ORD]VCRLIN

    If [F:ORD]EXTQTY > WQTY
        LQTY=[F:ORD]EXTQTY-WQTY
        WTRTORD="M" : Gosub APPELWIP_BPCALL From TRTVENMAJ
        If GOK=0 LRET=1 : Break : Endif
        If GOK=-1
            If GTRACE <> ""
                Call ECR_TRACE(GLOCK-":"-mess(60,100,1),1) From GESECRAN
            Else
                Call ERREUR(GLOCK-":"-mess(60,100,1)) From GESECRAN
            Endif
            LRET=-1 : Break
        Endif
        WQTY=0
      Else
        LQTY=[F:ORD]EXTQTY
        WTRTORD="A" : Gosub APPELWIP_BPCALL From TRTVENMAJ
        If GOK=0 LRET=1 : Break : Endif
        If GOK=-1
            If GTRACE <> ""
                Call ECR_TRACE(GLOCK-":"-mess(60,100,1),1) From GESECRAN
            Else
                Call ERREUR(GLOCK-":"-mess(60,100,1)) From GESECRAN
            Endif
            LRET=-1 : Break
        Endif
        WQTY-=[F:ORD]EXTQTY
    Endif
    If WQTY=0 Break Endif
Next
Filter [ORD]
Return


###########################################################################
#-------------------------------------------------------------------------#
# RECSHTKIT : Sous-programme de recherche de la qté rupture d'un kit      #
#                            non géré stock                               #
#             Recherche des qtés rupture sur tous les composants          #
#                 avec calcul de la qté rupture maximum ramenée au niveau #
#                 du kit                                                  #
#-------------------------------------------------------------------------#
#             Utilisé par FUNMANALL: Allocation par article des cdes      #
#-------------------------------------------------------------------------#
# Entrée  LSOHNUM    : Numéro de la commande                              #
#         LSOPLIN    : Numéro de ligne du composé                         #
#         LSOQSEQ    : Numéro de séquence du composé                      #
#         LSHTQTYSTU : Quantité rupture calculée                          #
# Sortie  LRET       : Code retour                                        #
#-------------------------------------------------------------------------#
Subprog RECSHTKIT (LSOHNUM, LSOPLIN, LSOQSEQ, LSHTQTYSTU, LRET)
Value    Char    LSOHNUM
Value    Integer LSOPLIN, LSOQSEQ
Variable Decimal LSHTQTYSTU
Variable Integer LRET

Local    Decimal WCPESTU, WRAPPORT

LRET=0 : LSHTQTYSTU=0

If clalev ([F:SOQ1]) = 0 Local File SORDERQ [SOQ1]:Endif
If clalev ([F:SOP1]) = 0 Local File SORDERP [SOP1]:Endif

# --> Lecture du composé
Read [SOQ1]SOQ0 = LSOHNUM; LSOPLIN; LSOQSEQ
If fstat LRET=fstat :Call RSTA("SOQ", LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)) From GLOCK:End:Endif
Read [SOP1]SOP0 = LSOHNUM; LSOPLIN; LSOQSEQ
If fstat LRET=fstat :Call RSTA("SOP", LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)) From GLOCK:End:Endif
WCPESTU = [F:SOQ1]QTYSTU

# --> Lecture des composants
Filter [SOP1] Where SOHNUM = LSOHNUM & SOPLIN > LSOPLIN
For [SOP1]SOP0
# --- Sortie de la boucle qd on est plus sur un composant
    If !(find([F:SOP1]LINTYP, 3,4,5,11,12,13)) : Break :Endif
    Read [SOQ1]SOQ0 = [F:SOP1]SOHNUM; [F:SOP1]SOPLIN; [F:SOP1]SOPSEQ
    If fstat
       LRET=fstat
       Call RSTA("SOQ", [F:SOP1]SOHNUM-num$([F:SOP1]SOPLIN)-num$([F:SOP1]SOPSEQ)) From GLOCK
       Break
    Endif
    # Si composant de kit en rupture, calcul de la qté rupture ramenée au niveau kit
    If [F:SOQ1]SHTQTYSTU>0
        WRAPPORT=WCPESTU / [F:SOQ1]QTYSTU
        LSHTQTYSTU=max(arr([F:SOQ1]SHTQTYSTU*WRAPPORT,0.000001), LSHTQTYSTU)
    Endif
Next
End

