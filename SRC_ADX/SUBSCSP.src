#<AdxTL>@(#)0.0.0.0 $Revision$ $Revision$
# TRAITEMENTS LIES AU PICKING DES CHANGEMENT STOCK                      #
#########################################################################

#########################################################################
# Actions de l'objet                                                    #
#########################################################################

#########################################################################
# Pour modifier la clé de classement
$HINT_KEY

Return

#########################################################################
$TIROIR
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI

Return

#########################################################################
$REMP_DERLU

# Pas de dernier lu
If !find (GFONC1,"GESSCS","GESSIS","GESSST","GESSIH","GESSTR") & GFONC1 <> GFONCTION
   adxmxl=0
Endif

Return

#########################################################################
$FILGAUCHE
Local Integer W_I, W_J
Local Char    W_STA(GLONSTA)


If !find(GFONC1,"GESSCS","GESSIS","GESSST","GESSTR")
   If ILIS=0 adxmxl=0 Endif
Endif

#--- Bug 63633
# Le dépôt a été initialisé (WRHINIT) alors qu'on travaille
# sur des emplacements sous-traitants, donc sans dépôt
If GFONC1="GESSTR"
   If dim([M:SCS1]WRHSEL)>0 [M:SCS1]WRHSEL="" Endif
   If dim([M:SCS1]WRHSTR)>0 [M:SCS1]WRHSTR="" Endif
   If dim([M:SCS1]WRHEND)>0 [M:SCS1]WRHEND="" Endif
Endif
#---
#                                                                              # hcb X3-67989 deb
Case currbox
 When GBOXSTO  : Gosub FILGAUCHE_STO
 When Default  : Return
Endcase

Return

$FILGAUCHE_STO

#If currbox<>GBOXSTO Return Endif
#                                                                              # hcb X3-67989 fin

Raz FILGAUSUP(1)
Raz FILGAUSUP(2)
Raz FILGAUSUP(3)

# Si transfert inter-site inter-société facturé
If [M:SCS1]BETCPY=2 & [M:SCS1]SIHNUM<>""
   # Rien dans la liste de picking
   FILGAUSUP(0) = '[F:STO]ITMREF=""&[F:STO]STOFCY=""'
Else
   FILGAUSUP(0) = "1=1"                                  # hcb x3-67989
   # Filtre article, site
   If dim([M:SCS1]LOCSEL)>0 & [M:SCS1]LOCSEL<>""
      If [M:SCS1]ITMREFSEL<>""
         #--- TS 106217
         If dim([M:SCS1]ECSSEL)>0 & [M:SCS1]ECSSEL<>""
            FILGAUSUP(0) = '[F:STO]ITMREF=[M:SCS1]ITMREFSEL&[F:STO]STOFCY=[M:SCS1]STOFCY'
            FILGAUSUP(0)+= '&[F:STO]ECCVALMAJ=[M:SCS1]ECSSEL&[F:STO]LOC=[M:SCS1]LOCSEL'
         Else
            FILGAUSUP(0) = '[F:STO]ITMREF=[M:SCS1]ITMREFSEL&[F:STO]STOFCY=[M:SCS1]STOFCY&[F:STO]LOC=[M:SCS1]LOCSEL'
         Endif
         #FILGAUSUP(0) = '[F:STO]ITMREF=[M:SCS1]ITMREFSEL&[F:STO]STOFCY=[M:SCS1]STOFCY&[F:STO]LOC=[M:SCS1]LOCSEL'
         #---
      Else
         FILGAUSUP(0) = '[F:STO]STOFCY=[M:SCS1]STOFCY&[F:STO]LOC=[M:SCS1]LOCSEL'
      Endif
   Elsif dim([M:SCS1]WRHSEL)>0 & [M:SCS1]WRHSEL<>""
      If [M:SCS1]ITMREFSEL<>""
         #--- TS 106217
         If dim([M:SCS1]ECSSEL)>0 & [M:SCS1]ECSSEL<>""
            FILGAUSUP(0) = '[F:STO]ITMREF=[M:SCS1]ITMREFSEL&[F:STO]STOFCY=[M:SCS1]STOFCY'
            FILGAUSUP(0)+= '&[F:STO]ECCVALMAJ=[M:SCS1]ECSSEL&[F:STO]WRH=[M:SCS1]WRHSEL'
         Else
            FILGAUSUP(0) = '[F:STO]ITMREF=[M:SCS1]ITMREFSEL&[F:STO]STOFCY=[M:SCS1]STOFCY&[F:STO]WRH=[M:SCS1]WRHSEL'
         Endif
         #FILGAUSUP(0) = '[F:STO]ITMREF=[M:SCS1]ITMREFSEL&[F:STO]STOFCY=[M:SCS1]STOFCY&[F:STO]WRH=[M:SCS1]WRHSEL'
         #---
      Else
         #--- Bug 65411 suite
         #FILGAUSUP(0) = '[F:STO]STOFCY=[M:SCS1]STOFCY&[F:STO]WRH=[M:SCS1]WRHSEL'
         # Rien dans la liste de picking
         If FILGAUSUP(0) = ""                                                  # hcb x3-67989    deb
            FILGAUSUP(0) = '[F:STO]ITMREF=""&[F:STO]STOFCY=""'
         Endif                                                                 # hcb x3-67989    fin
         #---
      Endif
   Else
      If [M:SCS1]ITMREFSEL<>""                                                 # hcb x3-67989
         FILGAUSUP(0) = '[F:STO]ITMREF=[M:SCS1]ITMREFSEL&[F:STO]STOFCY=[M:SCS1]STOFCY'
      Else
         FILGAUSUP(0) = '[F:STO]ITMREF=""&[F:STO]STOFCY=""'
      Endif                                                                    # hcb x3-67989
      #--- TS 106217
      If dim([M:SCS1]ECSSEL)>0 & [M:SCS1]ECSSEL<>""
         FILGAUSUP(0)+= '&[F:STO]ECCVALMAJ=[M:SCS1]ECSSEL'
      Endif
      #---
   Endif
#                                                                              # hcb x3-67989 deb
   If [F:SRT]CHGEMPCOD=2 & [F:SRT]CHGSTACOD <> 2 & [F:SRT]CHGPCUCOD <> 2 & !find([M:SCS1]BETFCYCOD,2,4)
      FILGAUSUP(0) += '&[F:STO]LPNNUM=""'
   Endif
  If dim([M:SCS1]LPNSTR)>0
      FILGAUSUP(0) += '&[F:STO]LPNNUM>=[M:SCS1]LPNSTR'
      If [M:SCS1]LPNEND<>""
         FILGAUSUP(0) += '&[F:STO]LPNNUM<=[M:SCS1]LPNEND'
      Endif
   Endif
#                                                                              # hcb x3-67989 fin
   If dim([M:SCS1]LOTSTR)>0
      FILGAUSUP(0) += '&[F:STO]LOT>=[M:SCS1]LOTSTR'
      If [M:SCS1]LOTEND<>""
         FILGAUSUP(0) += '&[F:STO]LOT<=[M:SCS1]LOTEND'
      Endif
   Endif
   If dim([M:SCS1]SLOSTR)>0
      FILGAUSUP(0) += '&[F:STO]SLO>=[M:SCS1]SLOSTR'
      If [M:SCS1]SLOEND<>""
         FILGAUSUP(0) += '&[F:STO]SLO<=[M:SCS1]SLOEND'
      Endif
   Endif

   If dim([M:SCS1]WRHSEL)>0 & [M:SCS1]WRHSEL=""
      If dim([M:SCS1]WRHSTR)>0
         FILGAUSUP(0) += '&[F:STO]WRH>=[M:SCS1]WRHSTR'
         If [M:SCS1]WRHEND<>""
            FILGAUSUP(0) += '&[F:STO]WRH<=[M:SCS1]WRHEND'
         Endif
      Endif
   Endif

   If dim([M:SCS1]LOCSEL)<0 | (dim([M:SCS1]LOCSEL)>0 & [M:SCS1]LOCSEL="")
      If dim([M:SCS1]LOCSTR)>0
         FILGAUSUP(0) += '&[F:STO]LOC>=[M:SCS1]LOCSTR'
         If [M:SCS1]LOCEND<>""
            FILGAUSUP(0) += '&[F:STO]LOC<=[M:SCS1]LOCEND'
         Endif
      Endif
   Endif

   FILGAUSUP(1) += '&[F:STO]CUNLOKFLG<>2&[F:STO]QTYSTU>0'
   # Si transfert inter-sites ou tiers
   If [M:SCS1]BETFCYCOD>1
      # Filtre péremption
      If [M:SCS1]SHLLOT <> 3 & WCRITSTO3<>""     # hcb V6per nouvelle gestion
         FILGAUSUP(1) += '&'+WCRITSTO3
      Endif
   Endif
   # Filtre statuts
   If WCRITSTO4<>""
      FILGAUSUP(1) += '&('+WCRITSTO4+')'
   Endif
   If dim([M:SCS1]SERNUMSTR)>0
      FILGAUSUP(1) += '&[F:STO]SERNUM>=[M:SCS1]SERNUMSTR'
      If [M:SCS1]SERNUMEND<>""
         FILGAUSUP(1) += '&[F:STO]SERNUM<=[M:SCS1]SERNUMEND'
      Endif
   Endif
   If [M:SCS1]NBUOM>0
      FILGAUSUP(1) += '&find([F:STO]PCU,[M:SCS1]UOM)'
   Endif

#                                                                              # x3-67989 deb
   If dim([M:SCS1]LPNSEL)>0
      If [M:SCS1]LPNSEL=""
         If dim([M:SCS1]LPNSTR)>0
            FILGAUSUP(1) += '&[F:STO]LPNNUM>=[M:SCS1]LPNSTR'
            If [M:SCS1]LPNEND<>""
               FILGAUSUP(1) += '&[F:STO]LPNNUM<=[M:SCS1]LPNEND'
            Endif
         Endif
      Endif
   Endif
#                                                                              # x3-67989 fin

   If [M:SCS1]BETFCYCOD=1 & [F:SRT]CHGEMPCOD=2
      If [M:SCS1]ALLSTO=2 & [M:SCS1]NOTALLSTO<>2
         FILGAUSUP(3) += '&[F:STO]CUMALLQTY<>0'
      Elsif [M:SCS1]NOTALLSTO=2 & [M:SCS1]ALLSTO<>2
         FILGAUSUP(3) += '&[F:STO]QTYSTU-[F:STO]CUMALLQTY>0'
      Elsif [M:SCS1]NOTALLSTO<>2 & [M:SCS1]ALLSTO<>2
         FILGAUSUP(3) += '&[F:STO]QTYSTU=0&[F:STO]CUMALLQTY=0'
      Endif
   Endif

   #--- PE Pour autoriser des chgts d'emp depuis des emplacements clients
   #--- If [M:SCS1]BETFCYCOD=1 FILGAUSUP(3)+="&[F:STO]LOCCAT<=3" : GPE=1 Endif
   GPE=0
   GPOINT="MOD_FILLOC2"
   Gosub ENTREE From EXEFNC
   If GPE=0
      # Si retour sous-traitant, sélection sur catégorie/emplacement sous-traitant
      If [M:SCS1]BETFCYCOD=5
         If [M:SCS1]SCOLOC<>""
            FILGAUSUP(3) += '&[F:STO]LOC=[M:SCS1]SCOLOC'
         Else
            FILGAUSUP(3) += '&[F:STO]LOCCAT=4'
         Endif
      # Sinon si sélection sur emplacement interne (et quai)
      Else
         FILGAUSUP(3) += '&[F:STO]LOCCAT<=2'
      Endif
   Endif

Endif

Return


#########################################################################
$AP_FILGAUCHE
Case currbox
 When GBOXSTO    : WPICK=2 : Gosub RAFFRAICHI
 When Default
Endcase
Return

#########################################################################
$DEB_PICK
Return

#########################################################################
$PICKE
Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS, WTOTACTDIS, WDISPO, WQTYSTU
Local Integer LTYPLOC, LSTA
#--- Issue 89625
Local Char    LOWNER
#--- Issue 96990
Local Integer I
#                                                                              # hcb X3-67989 deb
Local Integer LRET
Local Integer LSEQ
Local Integer LNEW    # Indique s'il faut ajouter une ligne au document
Local Char    LSER(GLONSER)
Local Decimal LQTY
Local Decimal LSTOCOU
#                                                                              # hcb X3-67989 fin
#hcb 33564 deb
If GREP = "M"
   If dim(GCTRDATSCS) <= 0
      If [M:SCS1]IPTDAT < date$
         Global Integer GCTRDATSCS
         # Attention ! la date d imputation est antérieure à la date du jour
         Call MESSAGE(mess(162,184,1)) From GESECRAN
      Endif
   Endif
Endif
# hcb 33564 fin
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif             # hcb 50197
If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM                    # hcb 50197
   Read [SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
Endif


If dim(LSAVNOL)<=0
    Local Integer LSAVNOL
    LSAVNOL=-1
Endif

If REP=""
   If !CLECUR | !VERROU | !ACTMOD
      OK=0 : Return
   Endif
Endif


#                                                                              # hcb X3-67989 deb
Case currbox
 When GBOXSTO  : Gosub PICKE_STO
 When Default  : Return
Endcase
Return
################################################################################
#  Picking lignes de stock
################################################################################
$PICKE_STO
#If currbox<>GBOXSTO
#    Return
#Endif
#                                                                              # hcb X3-67989 fin
Read [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
If fstat
   Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
   OK=0 : Return
Endif

$CONTROLE_STO                                                                  # hcb x3-67989

Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO                     # ALI_DOC
If fstat
   Call RSTA ("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
   OK=0 : Return
Endif

#--- TS 106217
# Si trf inter-sites, client ou sous-traitant
If find([M:SCS1]BETFCYCOD,2,3,4)
  # Contrôle version par rapport à la règle de gestion
  If [F:STO]ECCVALMAJ<>""
    Call CTLECCVALMAJ([F:STO]ITMREF,"",[F:STO]ECCVALMAJ,[M:SCS1]IPTDAT,"SRU1",LRET) From STKSOR
    If LRET<>0
      OK=0 : GERR=1 : Return
    Endif
  Endif
Endif
#---

#--- Bug 65411
# Si dépôt destination entête renseigné et dépôt destination ligne non saisissable
# Contrôle existence article dépôt
If dim([M:SCS1]WRHDESH)>0 & [M:SCS1]WRHDESH<>"" & varmode([M:SCS1]WRHDES)<>0
   Read [ITW]ITW0=[F:STO]ITMREF;[M:SCS1]WRHDESH
   If fstat
      Call ERREUR(mess(978,196,1)-[M:SCS1]WRHDESH) From GESECRAN
      OK=0: Return
   Endif
Endif
#                                                                              # hcb X3-67989 deb
 If [F:STO]LPNNUM<>"" & [F:SRT]CHGEMPCOD=2 & [F:SRT]CHGSTACOD <> 2 & [F:SRT]CHGPCUCOD <> 2 & !find([M:SCS1]BETFCYCOD,2,4)
    Call ERREUR(mess(534,184,1)) From GESECRAN   # Stock associé à un contenant. Changement d'emplacement partiel interdit !
    OK=0
    GERR=1
    Return
Endif
#                                                                              # hcb X3-67989 FIN

#---
# Si changement de stock et pas de filtre article saisi,
# il faut lire articles et règle de gestion
#If [M:SCS1]BETFCYCOD=1 & [M:SCS1]ITMREFSEL=""                                # hcb 116105
If [F:STO]ITMREF <> [F:ITM]ITMREF                                             # hcb 116105
   Call LECITM2([M:SCS1]STOFCY,[F:STO]ITMREF,[F:STO]WRH,LRET) From STKLIB
   If LRET<>0
      If GMESSAGE<>"" Call ERREUR(GMESSAGE) From GESECRAN Endif
      OK=0 : Return
   Endif
   [F:ITFD] = [F:ITF]   # hcb 108849

   Call LECSRU([M:SCS1]STOFCY,[F:ITM]TCLCOD,26,[M:SCS1]TRSCOD,"",LRET) From STKLIB
   If LRET<>0
      OK=0 : Return
   Endif
   GSCSAUZSST = [F:SRU]AUZSST
Endif
#                                                                              # hcb X3-67989 deb
#Local Integer LRET
#Local Integer LSEQ
#Local Integer LNEW    # Indique s'il faut ajouter une ligne au document
#Local Char    LSER(GLONSER)
#Local Decimal LQTY
#Local Decimal LSTOCOU
#                                                                              # hcb X3-67989 fin

If [F:STO]LOCCAT=2
   Raz LRET
   # Contrôle que la ligne de stock en attente de rangement est complète
   Call CTLPLFLOC([F:STO]ITMREF,"",LRET) From STKSOR
   If LRET<>0
      OK=0 : GERR=1
      GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
      GMESSAGE+="\"+mess(377,199,1)-": "
      Case LRET
       When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
       When 2 : GMESSAGE+=mess(453,197,1)
       When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
      Endcase
      Return
   Endif
   #--- Bug 68529
   If GWIPSTOLCK=2
      # La ligne de stock est elle dans une liste à ranger ?
      Filter [SGW] Where STOCOU=[F:STO]STOCOU
      Read [SGW]First
      If !fstat
         OK=0 : GERR=1
         GMESSAGE = mess(292,184,1)
         Filter [SGW]
         Return
      Endif
      Filter [SGW]
   #--- Bug 68529
   Endif
   # Si mouvement interne et changement d'emplacement non autorisé
   # Changement de statut et défractionnement interdit si stock non rangé
   If [M:SCS1]BETFCYCOD=1 & ([F:SRT]CHGEMPCOD<>2 | [F:STO]LPNNUM <> "")   # hcb X3-67989
      OK=0 : GERR=1
      GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(135,184,1)
      Return
   Endif
Endif
Raz WQTYSTU
# Ligne de stock avec demande d'analyse
If [F:STO]QLYCTLDEM<>""
   # Si transfert inter-site ou transfert sous-traitant
   If [M:SCS1]BETFCYCOD<>1
      GMESSAGE=mess(134,184,1)
      OK=0 : GERR=1 : Return
   # Si changement de statut
   Elsif [F:SRT]CHGPCUCOD<>2 & ([F:SRT]CHGEMPCOD<>2 | [F:ITFD]LOCMGTCOD<>2)
      GMESSAGE=mess(80,184,1)  # changment de statut impossible sur une ligne en CQ
      OK=0 : GERR=1 : Return
#---
   # Sinon recherche de la ligne de demande d'analyse pour vérifier
   # que celle-ci n'a pas déjà été partiellement contrôlée
   Else
#                                                          # hcb X3-75321 deb : mise en commentaire X3-46616
# verification que des reponses n existent pas
#      Filter [QLA] Where QLYCTLDEM    = [F:STO]QLYCTLDEM         &
#&                        TRKTYP       = 28
#&     Order By Key QLA0
#            Look [QLA]QLA0 First
#      Filter [QLA]
#      If !fstat
#        #Modification du message suite demande NACI du 24/10/2017
#         #GMESSAGE=mess(502,184,1)
#         GMESSAGE=mess(68,187,1)
#         OK=0
#         GERR=1
#         Return
#      Endif
#                                                          # hcb X3-75321 fin : mise en commentaire X3-46616

      For [QLD]QLD1 Where ITMREF=[F:STO]ITMREF & STOFCY=[F:STO]STOFCY
&                       & VCRTYP=28 & VCRNUM=[F:STO]QLYCTLDEM
         If [F:QLD]LOT      =[F:STO]LOT
&         & [F:QLD]SLO      =[F:STO]SLO
&         & [F:QLD]SERNUM   =[F:STO]SERNUM
&         & [F:QLD]STA      =[F:STO]STA
&         & [F:QLD]LOC      =[F:STO]LOC
&         & [F:QLD]PCU      =[F:STO]PCU
&         & [F:QLD]PCUSTUCOE=[F:STO]PCUSTUCOE
&         & [F:QLD]PALNUM   =[F:STO]PALNUM
&         & [F:QLD]CTRNUM   =[F:STO]CTRNUM
&         & [F:QLD]OWNER    =[F:STO]OWNER
&         & [F:QLD]STOFLD1  =[F:STO]STOFLD1
&         & [F:QLD]STOFLD2  =[F:STO]STOFLD2
            #--- Bug 57358
            #If [F:QLD]QTYSTU=[F:STO]QTYSTU
            #   OK=1 : Break
            #Else
            #   Break
            #Endif
            WQTYSTU += [F:QLD]QTYSTU
            #---
         Endif
      Next
      #--- Bug 57358
      #If OK=0
      If WQTYSTU<>[F:STO]QTYSTU
      #---
         GMESSAGE=mess(163,184,1)+"\"+mess(164,184,1)   # vous devez terminer le CQ pour acceder à ce stock
         OK=0                                              # hcb 65927
         GERR=1 : Return
      Endif
#---
   Endif
Endif

# Si transfert inter-sites ou tiers et non administrateur stock,
# contrôle ligne pickée par rapport à la règle de gestion
If [M:SCS1]BETFCYCOD>1 & GSTOADMIN<>2

   WPICKSTO=string$(evalue(WCRITPIC),"OK")
   If WPICKSTO<>"OK"
      OK=0 : GERR=1
      GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
      If [F:ITM]LOTMGTCOD>1
         GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
      Endif
      If [F:ITM]LOTMGTCOD=4
         GMESSAGE-=mess(456,197,1)-":"-[F:STO]SLO
      Endif
      If [F:ITM]SERMGTCOD=3
         GMESSAGE-=mess(453,197,1)-":"-[F:STO]SERNUM
      Endif
      If [F:ITF]LOCMGTCOD=2
         GMESSAGE-=mess(44,197,1)-":"-[F:STO]LOC
      Endif
      GMESSAGE+="\"+mess(366,199,1)
      Return
   Endif
Endif

#--- Issue 89625
LOWNER=""
GPOINT="TRF_OWNER" : Gosub ENTREE From EXEFNC
#---

# Si transfert inter-sites ou tiers contrôle du stock disponible
If [M:SCS1]BETFCYCOD>1
   #--- Lecture cumuls article
   If [F:ITV]STOFCY<>[M:SCS1]STOFCY | [F:ITV]ITMREF<>[F:STO]ITMREF   # hcb 87802
      Read [ITV]ITV0=[F:STO]ITMREF;[M:SCS1]STOFCY                    # hcb 87802
      If fstat Raz [F:ITV] Endif
   Endif
   #--- Calcul du stock disponible sur l'article
   # Si retour sous-traitant, stock dispo article sur emplacement sous-traitant
   If [M:SCS1]BETFCYCOD=5
      LTYPLOC = -4
   Else
      LTYPLOC = 1
      If [F:STO]LOCCAT=3 LTYPLOC+=2 Endif
      If [F:STO]LOCCAT=4 LTYPLOC+=4 Endif
   Endif
   LSTA    = 0
   # Statuts autorisés par les règles de gestion d'E/S
   If find([F:SRU]AUZSTA,1,3,5,7) LSTA+=1  Endif
   If find([F:SRU]AUZSTA,2,3,6,7) LSTA+=2  Endif
   If find([F:SRU]AUZSTA,4,5,6,7) LSTA+=4  Endif
   #--- Issue 89625
   #Call STODISTOT("[F:ITV]",LTYPLOC,LSTA,"",WTOTACTDIS) From STKLIB
   Call STODISTOT("[F:ITV]",LTYPLOC,LSTA,LOWNER,WTOTACTDIS) From STKLIB
   #---

   #--- Issue 94494
   #--- Issue 96990
   #WTOTACTDIS-=sum([M:SCS1]QTYSTUDES)
   WTOTACTDIS-=sigma(I=0,[M:SCS1]NBLIG-1,[M:SCS1]QTYSTUDES(I)*([M:SCS1]CREFLG(I)=0)*([F:STO]ITMREF=[M:SCS1]ITMREF(I)))
   #---

   # Contrôle du disponible pour sortie sur la ligne de stock
   Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB

   # Disponible = min(dispo ligne stock, dispo article)
   WDISPO = min(WSTUACTDIS,WTOTACTDIS)

   # Pas de stock disponible
   If WDISPO<=0
      OK=0 : GERR=1               : #--- Bug 63633 (remplacement FOK par OK)
      If WTOTACTDIS <= 0
         GMESSAGE = mess(80,197,1)-[M:SCS1]ITMREF(nolign-1)-": "
      Else
         GMESSAGE = mess(644,197,1)-": "
      Endif
      GMESSAGE += mess(367,199,1)
      #--- Bug 68529
      If GWIPSTOLCK=2 & [F:STO]LOCCAT=2
         # La qté en attente de rangement est peut être dans une liste à ranger
         GMESSAGE += "\"+mess(150,184,1)
      Endif
      #---
      Return

   Endif
Endif

If !clalev([F:STA]) : Local File STOALL [STA] : Endif
Look [F:STA]STA0(3)=[F:STO]STOFCY;[F:STO]ITMREF;[F:STO]STOCOU
[G:STA]currlen=0
If !fstat
    If dim(GALLSTO)=0 : Global Integer GALLSTO : Endif
    GALLSTO = 1
Endif

#--- Dem 83376
# S'il y a des allocations sur la ligne de stock
# et que l'on fait un changement de stock interne
If dim(GALLSTO)>0 & GALLSTO=1
  If [M:SCS1]BETFCYCOD=1
    # La ligne de stock est-elle en cours de pesée
    Call ALL_WEIGHING([F:STO]STOFCY,[F:STO]ITMREF,[F:STO]STOCOU,LRET) From STKALL
    If LRET<>0
      GMESSAGE=mess(402,184,1)
      Raz GALLSTO
      Return
    Endif
  Endif

Endif
#---

# Si fonctionnement en mode VT
If GVTMOD
   Gosub ALI_DOC From ENVADC
   Return
Endif
If [F:STO]QTYSTU-[F:STO]CUMWIPQTY-([F:STO]CUMALLQTY*([F:SRT]BETFCYCOD=2))>0
#                                                           # hcb  121800 / X3-108627 deb
    If [F:STO]SERNUM<>"" & nolign>0
        If  [F:STO]ITMREF <> [M:SCS1]ITMREF(nolign-1)
&         | [F:STO]STA    <> [M:SCS1]STA(nolign-1)
&         | dim([M:SCS1]LOT)>0       & [F:STO]LOT    <> [M:SCS1]LOT(nolign-1)
&         | dim([M:SCS1]SLO)>0       & [F:STO]SLO    <> [M:SCS1]SLO(nolign-1)
&         | dim([M:SCS1]LOC)>0       & [F:STO]LOC    <> [M:SCS1]LOC(nolign-1)
&         | dim([M:SCS1]PCU)>0       & [F:STO]PCU    <> [M:SCS1]PCU(nolign-1)
&         | dim([M:SCS1]PALNUM)>0    & [F:STO]PALNUM <> [M:SCS1]PALNUM(nolign-1)
&         | dim([M:SCS1]CTRNUM)>0    & [F:STO]CTRNUM <> [M:SCS1]CTRNUM(nolign-1)
&         | dim([M:SCS1]OWNER)>0     & [F:STO]OWNER  <> [M:SCS1]OWNER(nolign-1)
&         | dim([M:SCS1]QLYCTLDEM)>0 & [F:STO]QLYCTLDEM <> [M:SCS1]QLYCTLDEM(nolign-1)
&         | dim([M:SCS1]STOFLD1)>0   & [F:STO]STOFLD1<> [M:SCS1]STOFLD1(nolign-1)
&         | dim([M:SCS1]STOFLD2)>0   & [F:STO]STOFLD2<> [M:SCS1]STOFLD2(nolign-1)
&         | dim([M:SCS1]LPNNUM)>0    & [F:STO]LPNNUM <> [M:SCS1]LPNNUM (nolign-1)
&         | [M:SCS1]CREFLG(nolign-1) > 0##
            LNEW = 1
        Else
            If !(  [M:SCS1]PCUDES(nolign-1)="$"
&                | [M:SCS1]STADES(nolign-1)="$"
&                | dim([M:SCS1]LOCDES)>0 & [M:SCS1]LOCDES(nolign-1)="$" )
                Call PLUS_UN([M:SCS1]SERNUMF(nolign-1),LSER,LRET) From STKLIB
                If !LRET
                    LNEW= ([F:STO]SERNUM<>LSER)
                Else
                    LNEW = 1
                Endif
            Else
                LNEW = 1
            Endif
        Endif
    Else
     LNEW = 1
    Endif
#                                                                                 # hcb 121800 fin
    If LNEW
        If dim(GSCSPIC)>0
            #---- FillCHGW utilise [F:STO] => il faut sauvegarder la position courante
            LSTOCOU = [F:STO]STOCOU

            Call FILLCHGW("SCS1", nolign-1, 1, [M:SCS1]WSTOSEQ(nolign-1), [M:SCS1]STOFCY, LRET, LQTY) From SUBSCSB
            Read [STO]STO0=[M:SCS1]STOFCY;LSTOCOU
        Endif
        Call STKWSTOSEQ ("SCS1", [M:SCS1]NBLIG, [M:SCS1]NBLIG, 2, LSEQ, LRET) From STKECR
        Gosub ALI_DOC From SUBSCSB
    Else
        [M:SCS1]QTYPCU(nolign-1) += 1
        Call MAJQTY(1,[M:SCS1]QTYPCU(nolign-1),LRET) From SUBSCSB
        If dim(GSCSPIC)<=0
            # Nécessaire dans le cas où on effectue 2 picking et non pas un seul picking multiple
            # Issue 120553 - 2017-01-17 by CCC : No need to reset price
            #Call DELSTOCHGW( "SCS1", [M:SCS1]STOFCY, nolign-1, nolign-1, 1, LRET ) From SUBSCSB
            Call DELSTOCHGW2( "SCS1", [M:SCS1]STOFCY, nolign-1, nolign-1, 1, 0, LRET ) From SUBSCSB
            Global Integer GSCSPIC
        Endif
    Endif
    If LSAVNOL<0
        LSAVNOL = nolign-1
    Endif
Else
    GMESSAGE=mess(57,184,1)
    OK = 0
Endif

Return

#########################################################################
$DEPICK
Local Integer WRET
Case currbox
 When GBOXSTO :
        Look [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
        If fstat
            Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
            FOK=0 : Return
        Endif
        Call DEPICK([F:STO]STOFCY, [F:STO]STOCOU, "SCS1", WRET) From SUBSCSB
        Affzo [M:SCS1]
        OK = !WRET
 When Default
Endcase
Return
#########################################################################
$FIN_PICK
If REP=""
   If !VERROU
      GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return             # modification en cours sur un autre poste
   Elsif !CLECUR | !ACTMOD | GCONSULT
      GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return             # modification impossible
   Endif
Endif

Local Integer LRET
Local Decimal LQTY
    If dim(GSCSPIC)>0
        Kill GSCSPIC
        Call FILLCHGW("SCS1", nolign-1, 1, [M:SCS1]WSTOSEQ(nolign-1), [M:SCS1]STOFCY, LRET, LQTY) From SUBSCSB
        Affzo [M:SCS1]10
    Endif

If dim(GALLSTO)>0
    If GALLSTO=1
        Call MESSAGE(mess(84,184,1)) From GESECRAN        # attention de la quantité est deja allouée
    Endif
    Kill GALLSTO
Endif

Case currbox
 When GBOXSTO : Affzo [M:SCS1]1-99
 When Default
Endcase

If ([F:SRT]BETFCYCOD=4 | [F:SRT]BETFCYCOD=5)
    If [M:SCS1]NBLIG>0
        Diszo [M:SCS1]SCOLOC
    Else
        Actzo [M:SCS1]SCOLOC
    Endif
    Affzo [M:SCS1]SCOLOC
Endif

If [M:SCS1]NBLIG>0 & dim(LSAVNOL)>0 & LSAVNOL>=0
    zonsui="NBLIG("+num$(LSAVNOL)+")"
    Kill LSAVNOL
Endif

Return

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

$REMPBOX

#-----------------------------------------------------------------------#
# Remplissage des boites de picking                                     #
#-----------------------------------------------------------------------#
ILIS=val(right$(currbox,8))

Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI


Return

#########################################################################
$RAFFRAICHI

#-----------------------------------------------------------------------#
# Raffraichissement des listes de picking pour les lignes déjà saisies  #
#-----------------------------------------------------------------------#
   For I=0 To [M:SGW]NBLIG-1
      If [M:SGW]WSTOSEQ(I) <> 0
         Case currbox
          When GBOXSTO :
                         Read [STO]STO0=[M:SCS1]STOFCY;[M:SGW]WSTOCOU(I)
                         If fstat
                            Raz [F:STO]
                         Endif
                         Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
                         If fstat
                            Raz [F:STL]
                         Endif

          When Default
         Endcase
         If    WPICK=1 Gosub DEPICK From GOBJSUB
         Elsif WPICK=2 Gosub REPICK From GOBJSUB
         Endif
      Endif
   Next I
Return
#                                                           # hcb X3-108627 deb
$CLE_GAUCHE
Local Integer LRET
Local Decimal LQTY
If dim(GSCSPIC)>0
   Kill GSCSPIC
   Call FILLCHGW("SCS1", nolign-1, 1, [M:SCS1]WSTOSEQ(nolign-1), [M:SCS1]STOFCY, LRET, LQTY) From SUBSCSB
Endif
Return
#                                                           # hcb X3-108627 fin

