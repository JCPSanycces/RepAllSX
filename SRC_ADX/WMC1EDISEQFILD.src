If this.MANDATORY<0 or this.MANDATORY>len(mess(0,2018,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"2018 ->"-num$(this.MANDATORY)-mess(99,123,1)):  Return : # Local menu "2018 -> Invalid option
Endif
Return

