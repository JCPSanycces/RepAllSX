#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# UTISTO05   Moulinette pour initialiser REGFLG des mouvements           #
#            de changement de valeur dans STOJOU (Bug 32243)             #
# ---------------------------------------------------------------------- #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTISTO05(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTISTO05(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

If [F:ADS]MODULE(6)<>2    # Ne concerne que le module stock
    End
Endif

Call ECR_TRACE("UTISTO05: Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:STJ])  =0  Local File =DOSSIER+".STOJOU"   [STJ] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [STJ]
Update [STJ] Where VCRTYP=30 & REGFLG=0
&            With REGFLG=1
Commit
If fstat
    Call ECR_TRACE("UTISTO05 : Update --> fstat="+num$(fstat),1) From GESECRAN
Else
    Call ECR_TRACE("UTISTO05 : "+num$(adxuprec)+" records processed",0) From GESECRAN
Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call MAJ_UTISTO05(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
Call MAJ_UTISTO05(APPLI)
End





