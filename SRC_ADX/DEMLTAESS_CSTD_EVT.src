#<AdxTL>@(#)0.0.0.0 $Revision$
# Class DEMLTAESS
#FRLAA 2018-02-22 X3-79298 - START

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"  : Gosub AREAD_AFTER
    Endcase
Endcase
Return

$AREAD_AFTER
If func AFNC.ACTIV("GLM")>0
  Gosub UPDATE_BALANCES
Endif
Return

#FRLAA 2018-02-22 X3-74480 - START
$UPDATE_BALANCES
#Get all the contracts for the employee and set the balances
#This routine is being used by various methods from DEMCONGE, DEMCONGEESS and DEMLTA

Gosub UPDATE_BALANCE_VARIABLES

Read [DCG]DCG3 = this.REFNUM;this.UID
If fstat = [V]CST_AOK
  #Populate technical fields - used as parameters for the balance function
  #Also used to show the user the information used
  #At this stage we do not always have CTRDAT in context - from GESDCG
  Filter [HRCTR2] Where REFNUM=[F:DCG]REFNUM & CTRNUM=[F:DCG]CTRNUM & (CTRDAT<=[F:DCG]ENDDAT | (FLGRET=2 & RETDATEFF<=[F:DCG]ENDDAT))
&  & (XITDAT=[0/0/0] | XITDAT>=[F:DCG]STRDAT) Order By CTRDAT Desc

  Read [F:HRCTR2] First
  Filter [F:HRCTR2]
  If fstat = [V]CST_AOK
    this.TCH_BALCTR     = [F:HRCTR2]CTRNUM
    this.TCH_BALEML     = [F:HRCTR2]REFNUM
    this.TCH_BALDTR     = [F:HRCTR2]CTRDAT
    this.TCH_BALLEG     = func DIVPAYE_SOA.GET_LEG_CTR([F:HRCTR2]REFNUM, [F:HRCTR2]CTRNUM, [F:HRCTR2]CTRDAT, 1)
    this.TCH_BALTIM     = [F:DCG]TIM
    this.TCH_BALDAT     = [F:DCG]ENDDAT
    this.TCH_BALACT     = 2 #Active only
    #Set additional paramater values
    PLVEFILTER          = [F:DCG]ENDDAT
    PGCURLEG            = this.TCH_BALLEG
    LVEACTONLY          = this.TCH_BALACT
    CURR_NATURE_EVENT   = this.TCH_BALTIM
    Gosub ADD_BALANCE_CLASS_UPDATE
  Endif
Endif
Return

$ADD_BALANCE_CLASS_UPDATE

If PGCURLEG = AVOID.ACHAR
  PGCURLEG = func DIVPAYE_SOA.GET_LEG_CTR([F:HRCTR2]REFNUM, [F:HRCTR2]CTRNUM, [F:HRCTR2]CTRDAT, 1)
Endif

#Add line in the CTRLTAESS  and CTRLTAESSDAT Class
If COLLECTIONNAME = "CTRLTAESS"
  VCTRLTAESS_INDEX = fmet this.ADDLINE("CTRLTAESS",[V]CST_ALASTPOS)
  If VCTRLTAESS_INDEX <> [V]CST_ANOTDEFINED
    #Fill the instance
    If func SUBHRLTA.GET_SOA_BALANCES_FUNC([F:HRCTR2]CTRNUM, [F:HRCTR2]REFNUM, [F:HRCTR2]CTRDAT, this.CTRLTAESS(VCTRLTAESS_INDEX),PLVEFILTER,PGCURLEG,LVEACTONLY,CURR_NATURE_EVENT)= 0
    Endif
  Endif
Endif
Return

$UPDATE_BALANCE_VARIABLES
Local Char PCURRENT_CTR(GLONHRCTR)
Local Char PGCURLEG(GLONADI)
Local Integer L, K , M, N
Local Integer VCTRLTAESS_INDEX
Local Integer CONSLTAESS_INDEX
Local Integer LVEACCDET_INDEX
Local Date LVEFILTER
Local Integer LVEACTONLY
Local Char CURR_NATURE_EVENT(GLONTPS)

PLVEFILTER = datesyst
Local Char COLLECTIONNAME(GLONACLA)
Local File DEMCONGE [DCG]
Local File EMPLOCTR [HRCTR2]
Local Date DCG_START, DCG_END
COLLECTIONNAME = "CTRLTAESS"

Return

$SET_DCG_DATES_DEM
DCG_START   = this.STRDAT
DCG_END     = this.ENDDAT
Return

$SET_DCG_DATES_DCG
DCG_START   = [F:DCG]STRDAT
DCG_END     = [F:DCG]ENDDAT
Return
#FRLAA 2018-02-22 X3-79298 - END

