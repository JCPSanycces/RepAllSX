Subprog AVANT_TBL
#FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - START
[M]MODIF(nolign-1) = 1
#91472 : Consolidation des bulletins
Local Integer OK
OK = 2
If (nolign)>[M]TBL : End : Endif
Case [M]FLG(nolign-1)
When 0
 #Paie(s) existante(s), postérieure(s) au
 Call OUINON(mess(10,10701,1)-num$([M]DAT(nolign-1)),OK) From GESECRAN
When 2
 #Bulletin déjà calculé pour cette période, voulez vous poursuivre ?
 Call OUINON(mess(15,10703,1),OK) From GESECRAN
Endcase
If OK<>2 : mkstat = 2 :End : Endif

#[M]MODIF(nolign-1) = 1
End
#FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - END

