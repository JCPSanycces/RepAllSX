########################################
## Ecran TRTAUG
########################################
Subprog C_TYPAUG(VALEUR)
Variable Integer VALEUR
If VALEUR=3
 Grizo TYPAMT, ARD
Else
 Actzo TYPAMT
Endif
End

Subprog AS_TYPAMT(VALEUR)
Variable Integer VALEUR
If [M]TYPAUG=3 : mkstat = 2 : End : Endif
End

Subprog C_TYPAMT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Grizo ARD
Else
 Actzo ARD
Endif
End

Subprog C_ARD(VALEUR)
Variable Decimal VALEUR
Local Char    DECIM(10)
Local Decimal MINI
If VALEUR<=0 : mkstat = 2 : End : Endif
Call PARAM("","NBRDEC",DECIM) From ADOVAL
MINI = 10^(-val(DECIM))
If VALEUR<MINI : VALEUR = MINI : Endif
End

########################################
## Augmentation
########################################
$OUVRE_AUG
Local Mask TRTAUGMENT [AUG]
Local Integer NUMLIG , NUMCOL
Local Integer I , J , K
Local Integer NUMLIG , NUMCOL , NOL
Local Decimal OLDVAL , NEWVAL
Local Char    VARIA(GLONVRA) , RUBRI(GLONRUB)
Raz [M:AUG]
NUMLIG = val(PARAM(1))
NUMCOL = val(PARAM(2))
If clalev([F:BCB])=0 : Local File BCLOB    [BCB] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
Case NUMCOL
 When 1 : VARIA = [M:SVV]VAR1
 When 2 : VARIA = [M:SVV]VAR2
 When 3 : VARIA = [M:SVV]VAR3
 When 4 : VARIA = [M:SVV]VAR4
 When 5 : VARIA = [M:SVV]VAR5
 When 6 : VARIA = [M:SVV]VAR6
 When 7 : VARIA = [M:SVV]VAR7
 When 8 : VARIA = [M:SVV]VAR8
 When 9  : VARIA = [M:SVV]VAR9
 When 10 : VARIA = [M:SVV]VAR10
 When 11 : VARIA = [M:SVV]VAR11
 When 12 : VARIA = [M:SVV]VAR12
 When 13 : VARIA = [M:SVV]VAR13
 When 14 : VARIA = [M:SVV]VAR14
 When 15 : VARIA = [M:SVV]VAR15
Endcase

RUBRI = ""
For I=0 To dim([F:RUB]TEXVRI)-1
 Filter [RUB] Where LEG=GCURLEG and TEXVRI(I)=VARIA
 Read [RUB] First
 Filter [RUB]
 If !fstat
  RUBRI = [F:RUB]COD : Break
 Endif
Next I
[M:AUG]RUBRI = RUBRI
Return

$DEBUT_AUG
If [M:AUG]RUBRI=""
 Grizo [AUG]TEXTE,RAZTXT
Else
 Actzo [AUG]TEXTE,RAZTXT
Endif
Return

$EXEC_AUG
For NOL=NUMLIG-1 To [M:SVV]TBL-1
 Case NUMCOL
  When 1 : OLDVAL = [M:SVV]VRI1(NOL) : VARIA = [M:SVV]VAR1
  When 2 : OLDVAL = [M:SVV]VRI2(NOL) : VARIA = [M:SVV]VAR2
  When 3 : OLDVAL = [M:SVV]VRI3(NOL) : VARIA = [M:SVV]VAR3
  When 4 : OLDVAL = [M:SVV]VRI4(NOL) : VARIA = [M:SVV]VAR4
  When 5 : OLDVAL = [M:SVV]VRI5(NOL) : VARIA = [M:SVV]VAR5
  When 6 : OLDVAL = [M:SVV]VRI6(NOL) : VARIA = [M:SVV]VAR6
  When 7 : OLDVAL = [M:SVV]VRI7(NOL) : VARIA = [M:SVV]VAR7
  When 8 : OLDVAL = [M:SVV]VRI8(NOL) : VARIA = [M:SVV]VAR8
  When 9  : OLDVAL = [M:SVV]VRI9(NOL)  : VARIA = [M:SVV]VAR9
  When 10 : OLDVAL = [M:SVV]VRI10(NOL) : VARIA = [M:SVV]VAR10
  When 11 : OLDVAL = [M:SVV]VRI11(NOL) : VARIA = [M:SVV]VAR11
  When 12 : OLDVAL = [M:SVV]VRI12(NOL) : VARIA = [M:SVV]VAR12
  When 13 : OLDVAL = [M:SVV]VRI13(NOL) : VARIA = [M:SVV]VAR13
  When 14 : OLDVAL = [M:SVV]VRI14(NOL) : VARIA = [M:SVV]VAR14
  When 15 : OLDVAL = [M:SVV]VRI15(NOL) : VARIA = [M:SVV]VAR15
 Endcase
 Case [M:AUG]TYPAUG
  When 1 : # Augmentation
   Case [M:AUG]TYPAMT
    When 1 : NEWVAL = arr(OLDVAL*(1+[M:AUG]AMT/100),[M:AUG]ARD)
    When 2 : NEWVAL = OLDVAL+[M:AUG]AMT
   Endcase
  When 2 : # Diminution
   Case [M:AUG]TYPAMT
    When 1 : NEWVAL = arr(OLDVAL*(1-[M:AUG]AMT/100),[M:AUG]ARD)
    When 2 : NEWVAL = OLDVAL-[M:AUG]AMT
   Endcase
  When 3 : # Affectation
   NEWVAL = [M:AUG]AMT
 Endcase
 Case NUMCOL
  When 1 : [M:SVV]VRI1(NOL) = NEWVAL
  When 2 : [M:SVV]VRI2(NOL) = NEWVAL
  When 3 : [M:SVV]VRI3(NOL) = NEWVAL
  When 4 : [M:SVV]VRI4(NOL) = NEWVAL
  When 5 : [M:SVV]VRI5(NOL) = NEWVAL
  When 6 : [M:SVV]VRI6(NOL) = NEWVAL
  When 7 : [M:SVV]VRI7(NOL) = NEWVAL
  When 8 : [M:SVV]VRI8(NOL) = NEWVAL
  When 9  : [M:SVV]VRI9(NOL)  = NEWVAL
  When 10 : [M:SVV]VRI10(NOL) = NEWVAL
  When 11 : [M:SVV]VRI11(NOL) = NEWVAL
  When 12 : [M:SVV]VRI12(NOL) = NEWVAL
  When 13 : [M:SVV]VRI13(NOL) = NEWVAL
  When 14 : [M:SVV]VRI14(NOL) = NEWVAL
  When 15 : [M:SVV]VRI15(NOL) = NEWVAL
 Endcase
 [M:SVV]MODIF(NOL) = 1
Next NOL

Case NUMCOL
 When 1 : VALEUR = [M:SVV]VRI1(NUMLIG-1)
 When 2 : VALEUR = [M:SVV]VRI2(NUMLIG-1)
 When 3 : VALEUR = [M:SVV]VRI3(NUMLIG-1)
 When 4 : VALEUR = [M:SVV]VRI4(NUMLIG-1)
 When 5 : VALEUR = [M:SVV]VRI5(NUMLIG-1)
 When 6 : VALEUR = [M:SVV]VRI6(NUMLIG-1)
 When 7 : VALEUR = [M:SVV]VRI7(NUMLIG-1)
 When 8 : VALEUR = [M:SVV]VRI8(NUMLIG-1)
 When 9  : VALEUR = [M:SVV]VRI9(NUMLIG-1)
 When 10 : VALEUR = [M:SVV]VRI10(NUMLIG-1)
 When 11 : VALEUR = [M:SVV]VRI11(NUMLIG-1)
 When 12 : VALEUR = [M:SVV]VRI12(NUMLIG-1)
 When 13 : VALEUR = [M:SVV]VRI13(NUMLIG-1)
 When 14 : VALEUR = [M:SVV]VRI14(NUMLIG-1)
 When 15 : VALEUR = [M:SVV]VRI15(NUMLIG-1)
Endcase

If RUBRI<>"" & len([M:AUG]TEXTE)<>0
 Call DEBTRANS From GLOCK
 Gosub TR2
Endif
Return

$TR2
GOK = 1
Trbegin [BCB]
 For NOL=NUMLIG-1 To [M:SVV]TBL-1
  #Création des commentaires
  For [RUB]RUB0 Where LEG=GCURLEG & (TEXVRI(0)=VARIA or TEXVRI(1)=VARIA)
   Read [F:BCB]BCB0="VARTXT";VARIA;[M:SVV]BUL(NOL);"";[F:RUB]COD
   If fstat
    Raz [F:BCB]
    [F:BCB]CODBLB = "VARTXT"
    [F:BCB]IDENT1 = VARIA
    [F:BCB]IDENT2 = [M:SVV]BUL(NOL)
    [F:BCB]IDENT3 = ""
    [F:BCB]IDENT4 = [F:RUB]COD
    [F:BCB]CLOB   = [M:AUG]TEXTE
    If dim([F:BCB]CREUSR)>0 : [F:BCB]CREUSR = GUSER : Endif
    If dim([F:BCB]CREDAT)>0 : [F:BCB]CREDAT = date$ : Endif
    If dim([F:BCB]CRETIM)>0 : [F:BCB]CRETIM = time  : Endif
    Write [BCB]
   Else
    If [M:AUG]RAZTXT=2
     Raz [F:BCB]CLOB
     [F:BCB]CLOB = [M:AUG]TEXTE
    Else
     [F:BCB]CLOB += [M:AUG]TEXTE
    Endif
    If dim([F:BCB]UPDUSR)>0 : [F:BCB]UPDUSR = GUSER : Endif
    If dim([F:BCB]UPDDAT)>0 : [F:BCB]UPDDAT = date$ : Endif
    If dim([F:BCB]UPDTIM)>0 : [F:BCB]UPDTIM = time  : Endif
    Rewrite [BCB]
   Endif
   If fstat
    GOK = 0 : Call FSTA("BCB") From GLOCK : Break
   Endif
  Next
 Next NOL
 If GOK<1 : Goto AB_TR2 : Endif
Commit
Return

$AB_TR2
Rollback
Return

