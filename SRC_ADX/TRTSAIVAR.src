#<AdxTL>@(#)2.0.0.0 $Revision$
####################################################################################################################
# HCM V8 :
# To manage the filter by GCURLEG on the main process    : Already done by DBA
# To manage the filter on new concept of population      : Not yet
###################################################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
GACTION = "TRTSAIVAR"
Call TRAITE_CHAR(VALEUR,PARAM,"TRTSAIVAL","TRTSAIVAR","TRTSAIVAR",4,"") From GTRAITE
End

#########################################
## Traitement des actions : SAIVAR
## Saisie des valeurs par variables
#########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE   : # Trt principal + augmentation
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVFIC

 When "DEBUT"       : Gosub DEBUT    : # Chacune des fenêtres
 When "SORTIE"      : Gosub SORTIE
 When "OK"          : Gosub BOUTON_OK
 When "END"         : Gosub BOUTON_FIN
 When "BOUTON"      : Gosub BOUTON
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

######################################################
$OUVRE
Local Mask TRTSAIVAL [SVV]
Local Mask TRTSAIVAR [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","sai") From GMEMO
Call AFF_MEMO From DIVPAYE
Case GACTION
 When "TRTSAIVAR"  : Gosub OUVRE_VAL
 When "TRTAUGMENT" : Gosub OUVRE_AUG
Endcase

Return

######################################################
$OUVRE_VAL
Gosub OUVFIC
Local Integer I, J, K , OK
Local Char    CRITERE(250)  # pour les matricules
Local Char    CRITERE1(250) # pour les profils et les services
Local Char    CRITERE2(250) # pour les dates
Local Char    CRITERE3(250) # pour les variables
Local Char    MESSA(50)
Local Char    VALPAR(30)
Local Char    SYMBOLE(80)
Local Decimal NEWVAL
Local Integer PLEIN
Local Char    CODVAR(GLONVRA) , FORMA(10)
Local Char    MATRI(GLONEML)
Local Date    DATMAT
#LIPET - 2017-06-15 - START
Local Mask TRTSAIVAL [SVV]
Local Mask TRTSAIVAR [DIA]
Raz [M:DIA]
#LIPET - 2017-06-15 - END

#FRLAA - 2016-04-26 - REQUIREMENT 114309 US 120 - START
#GCURLEG must automatically be set here to FRA
#GCURLEG=PARAM(2) #FRA
#FRLAA - 2016-04-26 - REQUIREMENT 114309 US 120 - END
If dim(GCURLEG)>0 :  Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif

#Raz [M:DIA]
[M:DIA]DATDEB = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
[M:DIA]DATFIN = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))

#FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - START
Call LECMEMO("STD","[M:DIA]","sai") From GMEMO
Effzo [M:DIA]INI
#FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - END

#Raz [M:DIA]INI
Return

# A faire peu importe GACTION ??? A vérifier...
######################################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

######################################################
## Ouverture des tables
######################################################
$OUVFIC
If clalev([F:SVR])=0 : Local File SCRVRA     [SVR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:SRV])=0 : Local File SERVICE    [SRV] : Endif
If clalev([F:PRF])=0 : Local File PROFIL     [PRF] : Endif
If clalev([F:VRA])=0 : Local File VARIA      [VRA] : Endif
If clalev([F:VEP])=0 : Local File VALEMP     [VEP] : Endif
If clalev([F:VLA])=0 : Local File VALEUR     [VLA] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA] : Endif
If clalev([F:ECT])=0 : Local File EMPCTR     [ECT] : Endif
If clalev([F:VEP2])=0 : Local File VALEMP     [VEP2] : Endif    : ##**82073
Gosub OUVRE From WPDEFTABLE
Return

######################################################
## Selection des variables qui ne concernent que le salarié
## ACTION SELVAR  obsolète !
######################################################
$SEL_TABLE
Case TABLE
 When "SELVAR"
  # On filtre sur le type, ici "Salarié"
  OBJET = "VRA"
  CRITERE = "FLGEMP=2"
Endcase
Return

#######################################################
## Initialisation des en-têtes de colonnes
#######################################################
$DEBUT
Local Char DES (GLONAX3)
#MABOS-01/10/13:# MABOS suite à Erreur
#Enlevé ici car fait plus bas
#Affzo [DIA] : Setmok [DIA] With 0
#Call AFF_MEMO From DIVPAYE :#81085:#MABOS suite à Erreur
#End MABOS
Case BOITE
 When "TRTSAIVAR"
  Affzo [DIA]
  Setmok [DIA] With 0
#LIPET - 2017-06-15 - START
#  If PARAM(1)<>"" & PARAM(2)<>""
#   GCURLEG=PARAM(2)
#   If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
#   Read [SVR]SVR0 = PARAM(1);PARAM(2)
  If PARAM(1)<>"" & GCURLEG<>""
   Read [SVR]SVR0 = GCURLEG;PARAM(1)
#LIPET - 2017-06-15 - END
   Call LECTEXTRA([L]DES,"SCRVRA","DES",[F:SVR]COD,GCURLEG) From ATEXTRA
   Titled [DIA] [L]DES
   [M:DIA]SVR = PARAM(1)
   [M:DIA]ZSVR = [L]DES
   If dim ([M:DIA]LEG)>=0
    [M:DIA]LEG = PARAM(2)
    Call LECTEXTRA([M:DIA]ZLEG,"ATABDIV","LNGDES","909",PARAM(2)) From ATEXTRA
    Affzo [DIA]LEG,ZLEG
    Grizo [DIA]LEG
   Endif
   Affzo [DIA]SVR,ZSVR
   Grizo [DIA]SVR
  Else
   Call AFF_MEMO From DIVPAYE
  Endif
 When "TRTSAIVAL"
  Raz [M:SVV]
  Read [F:SVR]SVR0=GCURLEG;[M:DIA]SVR
  For I=1 To [F:SVR]NBRVAR
   Read [VRA]VRA0 = GCURLEG;[F:SVR]VARCOD(I-1)
   Read [ADI]CODE = 10337;[F:VRA]PAGEMP
   FORMA = "N3:9."+num$([F:ADI]N1)+"#"
   Case I
    When 1 : [M:SVV]VAR1 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI1 With FORMA
    When 2 : [M:SVV]VAR2 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI2 With FORMA
    When 3 : [M:SVV]VAR3 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI3 With FORMA
    When 4 : [M:SVV]VAR4 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI4 With FORMA
    When 5 : [M:SVV]VAR5 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI5 With FORMA
    When 6 : [M:SVV]VAR6 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI6 With FORMA
    When 7 : [M:SVV]VAR7 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI7 With FORMA
    When 8 : [M:SVV]VAR8 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI8 With FORMA
    When 9  : [M:SVV]VAR9  = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI9 With FORMA
    When 10 : [M:SVV]VAR10 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI10 With FORMA
    When 11 : [M:SVV]VAR11 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI11 With FORMA
    When 12 : [M:SVV]VAR12 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI12 With FORMA
    When 13 : [M:SVV]VAR13 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI13 With FORMA
    When 14 : [M:SVV]VAR14 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI14 With FORMA
    When 15 : [M:SVV]VAR15 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI15 With FORMA
   Endcase
   [M:SVV]LIBVAR(I-1)=[F:SVR]VARDES(I-1)
  Next I
  For I=[F:SVR]NBRVAR+1 To 15
   Case I
    When 1 : Chgfmt [M:SVV]VRI1 With "-N:9.2#"
    When 2 : Chgfmt [M:SVV]VRI2 With "-N:9.2#"
    When 3 : Chgfmt [M:SVV]VRI3 With "-N:9.2#"
    When 4 : Chgfmt [M:SVV]VRI4 With "-N:9.2#"
    When 5 : Chgfmt [M:SVV]VRI5 With "-N:9.2#"
    When 6 : Chgfmt [M:SVV]VRI6 With "-N:9.2#"
    When 7 : Chgfmt [M:SVV]VRI7 With "-N:9.2#"
    When 8 : Chgfmt [M:SVV]VRI8 With "-N:9.2#"
    When 9  : Chgfmt [M:SVV]VRI9 With "-N:9.2#"
    When 10 : Chgfmt [M:SVV]VRI10 With "-N:9.2#"
    When 11 : Chgfmt [M:SVV]VRI11 With "-N:9.2#"
    When 12 : Chgfmt [M:SVV]VRI12 With "-N:9.2#"
    When 13 : Chgfmt [M:SVV]VRI13 With "-N:9.2#"
    When 14 : Chgfmt [M:SVV]VRI14 With "-N:9.2#"
    When 15 : Chgfmt [M:SVV]VRI15 With "-N:9.2#"
   Endcase
  Next I
  Gosub FILTRE
  Affzo [SVV]
 When "TRTAUG"
  Gosub DEBUT_AUG
Endcase
Return

#######################################################
## Contrôle des paramètres
#######################################################
$CONTROLE
Case GACTION
 When "TRTSAIVAR" : Gosub CONTROLE1
Endcase
Return

$CONTROLE1
If GSTATUT=GSTAOK
 TMP = 1
Else
 FIN = 1
Endif
#Affectations indispensables pour avoir GCURLEG renseigné dans la 2ième fenêtre
#Sinon on le perd...
If dim([M:DIA]LEG)>0 : GCURLEG=[M:DIA]LEG : Endif
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If GLEGFIL<>"" & GCURLEG="" : GCURLEG = GLEGFIL : Endif
Return

#######################################################
## Boutons OK et FIN
#######################################################
$BOUTON_OK
Case BOITE
 When "TRTSAIVAL"
  FIN = 1
  # Mise à jour des valeurs par variables
  Call TEMPON("V") From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR1
  Gosub DEVERROU
  Call TEMPOFF From GESECRAN
Endcase
Return

$BOUTON_FIN
Case BOITE
 When "TRTSAIVAR"
  FIN = 1
 When "TRTSAIVAL"
  Gosub DEVERROU
  FIN = 1
Endcase
Return

#81085
$BOUTON
Case BOITE
When "TRTSAIVAR"
 Case BOUT
  When "R" :
   # Button "Rappel MEMO"
    Call AFF_MEMO From DIVPAYE
  Endcase
Endcase
Return

#######################################################
## Remplissage du tableau
#######################################################
$FILTRE
# Mise en place du filtre sur la table des salariés
#ADNGO - 2017-07-13 - X3-33802 - START
#CRITERE = "[F:ID]ENAFLG=2 & [F:ID]FLGPAY=2 & [F:CPY]LEG='"+GCURLEG+"'"
CRITERE = "[F:ID]ENAFLG=2 & [F:ID]FLGPAY=2 & [F:FCY]LEG='"+GCURLEG+"'"
#ADNGO - 2017-07-13 - X3-33802 - END
If [M:DIA]ALLCPY<>2  #société
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= '[F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif

#FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - START
##91472 - Consolidation des bulletins
###***Now we have to work on VALEMP file, not on EMPLOCTR file***
If [M:DIA]ALLFCY<>2  #site
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= '[F:VEP]FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= '[F:VEP]EMP>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= '[F:VEP]EMP<="'+[M:DIA]MATFIN+'"'
Endif
CRITERE1 = "1=1"
If [M:DIA]ALLSRV<>2  #service
 CRITERE1 -= '& [F:VEP]SRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2  #profil
 CRITERE1 -= '& [F:VEP]PRF = "'+[M:DIA]PRF+'"'
Endif



#If [M:DIA]ALLFCY<>2  #site
# If CRITERE<>"" : CRITERE -= "&" : Endif
# CRITERE -= '[F:HRCTR]ETRFCY = "'+[M:DIA]FCY+'"'
#Endif
#If [M:DIA]MATDEB<>"" #borne début matricule
# If CRITERE<>"" : CRITERE -= "&" : Endif
# CRITERE -= '[F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
#Endif
#If [M:DIA]MATFIN<>"" #borne fin du matricule
# If CRITERE<>"" : CRITERE -= "&" : Endif
# CRITERE -= '[F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
#Endif
#
## Filtre sur critere de la position professionnelle
#CRITERE1 = "1=1"
#If [M:DIA]ALLSRV<>2  #service
# CRITERE1 -= '& [F:HRCTR]ETRSRV = "'+[M:DIA]SRV+'"'
#Endif
#If [M:DIA]ALLPRF<>2  #profil
# CRITERE1 -= '& [F:HRCTR]PROPRF = "'+[M:DIA]PRF+'"'
#Endif


#FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - END


#FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - START
If [M:DIA]POP<>""
 Link [VEP] With
&      [ID]ID0=[F:VEP]EMP,
&      [FCY]FCY0=[F:VEP]FCY,
&      [HRPOA]POA0 = [M:DIA]POP;[F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
&  As  [LNK]
&  Where evalue(CRITERE1) & evalue(CRITERE) & [F:HRPOA]REFNUM<>"" & PYRDAT>=[M:DIA]DATDEB & (PYRDAT<=[M:DIA]DATFIN | [M:DIA]DATFIN=[0/0/0]) & [F:FCY]LEG=GCURLEG
Else
 Link [VEP] With
&      [ID]ID0=[F:VEP]EMP,
&      [FCY]FCY0=[F:VEP]FCY
&  As  [LNK]
&  Where evalue(CRITERE1) & evalue(CRITERE) & PYRDAT>=[M:DIA]DATDEB & (PYRDAT<=[M:DIA]DATFIN | [M:DIA]DATFIN=[0/0/0]) #& [F:FCY]LEG=GCURLEG #ADNGO - 2017-07-13 - X3-33802
Endif
#If [M:DIA]POP<>""
##86255
## Link [HRCTR] With
##&      [ID]ID0=[F:HRCTR]REFNUM,
##&      [FCY]FCY0=[F:HRCTR]ETRFCY,
##&      [HRPOA]POA0 = [M:DIA]POP;[F:HRCTR]REFNUM
##&  As  [LNK]
##&  Where evalue(CRITERE1) & evalue(CRITERE) & [F:HRPOA]REFNUM<>"" & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=[M:DIA]DATDEB)
# Link [HRCTR] With
#&      [ID]ID0=[F:HRCTR]REFNUM,
#&      [FCY]FCY0=[F:HRCTR]ETRFCY,
#&      [CPY]CPY0=[F:FCY]LEGCPY,
#&      [HRPOA]POA0 = [M:DIA]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
#&  As  [LNK]
#&  Where evalue(CRITERE1) & evalue(CRITERE) & [F:HRPOA]REFNUM<>"" & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=[M:DIA]DATDEB)
#Else
# Link [HRCTR] With
#&      [ID]ID0=[F:HRCTR]REFNUM,
#&      [FCY]FCY0=[F:HRCTR]ETRFCY,
#&      [CPY]CPY0=[F:FCY]LEGCPY
#&  As  [LNK]
#&  Where evalue(CRITERE1) & evalue(CRITERE) & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=[M:DIA]DATDEB)
#Endif
#FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - END
Effzo [SVV]10
I = -1
PLEIN = 0
For [LNK]
 OK = 1
 #FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - START
 Call CONTROLE([F:VEP]EMP,[F:VEP]CTRDAT,[F:VEP]CTRNUM,[M:DIA]CRI,OK,1) From DIVPAYE
 #FRLAA - 2016-04-11 - REQUIREMENT 104631 US 3487 - START
 #Call CONTROLE([F:ID]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:DIA]CRI,OK,1) From DIVPAYE
 #FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - END
 If OK
 #LIPET - 2017-06-15 - START
#  For [VEP] Where EMP=[F:ID]REFNUM & PYRDAT>=[M:DIA]DATDEB & (PYRDAT<=[M:DIA]DATFIN | [M:DIA]DATFIN=[0/0/0])
#&                & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT  ##**82073 Add filter on CTRDAT
  #LIPET - 2017-06-15 - END
  If [M:DIA]PAYCAL<>2 & [F:VEP]STA>1
    OK = 0
   Endif
# pas comptabilisée ni extourne
   If [F:VEP]PST>1 or [F:VEP]RVS=2
&  or [F:VEP]FLGLOCK=2 : # Verrouillé US 2022 65062
    OK = 0
   Endif
   If OK
    ##**82073
    Call VEPSYMBOLE (SYMBOLE, "VEP") From DIVPAYE
    Lock =SYMBOLE
    If fstat : OK = 0 : Endif
   Endif
   If OK
    If I>=dim([M:SVV]MAT)-1
     PLEIN = 1 : Break
    Endif
    I += 1
    [M:SVV]MAT(I) = [F:ID]REFNUM
    [M:SVV]DES(I) = [F:ID]NAM-[F:ID]SRN
    [M:SVV]CTR(I) = [F:VEP]CTRNUM
    [M:SVV]CTRDAT(I) = [F:VEP]CTRDAT
    [M:SVV]DAT(I) = [F:VEP]PYRDAT
    [M:SVV]BUL(I) = [F:VEP]BUL
    [M:SVV]FLG(I) = 1
    ##**82073
    If [F:VEP]STA=1
     [M:SVV]FLG(I) = 1   :#Ligne modifiable
    Else
     [M:SVV]FLG(I) = 2   :#Ligne modifiable mais bulletin déjà calculé
    Endif
    #FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - START
    Filter [VEP2] Where EMP=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM & STRCTRDAT<=[F:VEP]CTRDAT & CTRDAT>=[F:VEP]CTRDAT
    #Filter [VEP2] Where EMP=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM & CTRDAT=[F:VEP]CTRDAT
    #FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - END
    Read [VEP2]VEP0 Last
    Filter [VEP2]
    If fstat<=2 & [F:VEP2]BUL<>[F:VEP]BUL
     [M:SVV]FLG(I) = 0           :#Ligne non modifiable
    Endif
    #
    #FRLAA - 2016-04-11 - REQUIREMENT 114309 US 120 - START
    #For [VLA]VLA0 Where TYP=4 & LEG="" & CPY="" & FCY="" & EMP=[F:ID]REFNUM & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL
    For [VLA]VLA0 Where TYP=4 & CPY="" & FCY="" & EMP=[F:ID]REFNUM & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL
&    & find(VARCOD,[F:SVR]VARCOD(0..[F:SVR]NBRVAR-1))
     Case [F:VLA]VARCOD
      When [M:SVV]VAR1 : [M:SVV]VRI1(I) = [F:VLA]VARVAL
      When [M:SVV]VAR2 : [M:SVV]VRI2(I) = [F:VLA]VARVAL
      When [M:SVV]VAR3 : [M:SVV]VRI3(I) = [F:VLA]VARVAL
      When [M:SVV]VAR4 : [M:SVV]VRI4(I) = [F:VLA]VARVAL
      When [M:SVV]VAR5 : [M:SVV]VRI5(I) = [F:VLA]VARVAL
      When [M:SVV]VAR6 : [M:SVV]VRI6(I) = [F:VLA]VARVAL
      When [M:SVV]VAR7 : [M:SVV]VRI7(I) = [F:VLA]VARVAL
      When [M:SVV]VAR8 : [M:SVV]VRI8(I) = [F:VLA]VARVAL
      When [M:SVV]VAR9  : [M:SVV]VRI9(I) = [F:VLA]VARVAL
      When [M:SVV]VAR10 : [M:SVV]VRI10(I) = [F:VLA]VARVAL
      When [M:SVV]VAR11 : [M:SVV]VRI11(I) = [F:VLA]VARVAL
      When [M:SVV]VAR12 : [M:SVV]VRI12(I) = [F:VLA]VARVAL
      When [M:SVV]VAR13 : [M:SVV]VRI13(I) = [F:VLA]VARVAL
      When [M:SVV]VAR14 : [M:SVV]VRI14(I) = [F:VLA]VARVAL
      When [M:SVV]VAR15 : [M:SVV]VRI15(I) = [F:VLA]VARVAL
     Endcase
    Next
   Endif
#  Next
 Endif
Next
[M:SVV]TBL = I+1
[M:SVV]TRI = 0
Affzo [SVV]
If PLEIN
 Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
Endif
Return

#######################################################
## Transaction de mise à jour des variables
#######################################################

$EXEC
Case GACTION
 When "TRTAUGMENT" : If GSTATUT=GSTAOK : Gosub EXEC_AUG : Endif
Endcase
Return

$TR1
GOK=1
Trbegin [VLA]
 For I=0  To [M:SVV]TBL-1
  If [M:SVV]MODIF(I)=1
   For J = 0 To [F:SVR]NBRVAR-1
    CODVAR = evalue("[M:SVV]VAR"+num$(J+1))
    NEWVAL = evalue("[M:SVV]VRI"+num$(J+1)+"("+num$(I)+")")
    #LIPET - 2017-06-15 - START
    #Readlock [VLA]VLA0 = 4;"";"";"";[M:SVV]MAT(I);[M:SVV]DAT(I);CODVAR;[M:SVV]BUL(I)
    Readlock [VLA]VLA0 = 4;"";"";"";[M:SVV]MAT(I);[M:SVV]DAT(I);CODVAR;[M:SVV]BUL(I)
    #LIPET - 2017-06-15 - END
    If fstat=1
     GOK = -1 : GLOCK = "$VALEUR" : Break 2
    Elsif fstat
     fstat = 0
     If NEWVAL<>0
      Raz [F:VLA]
      [F:VLA] = [M:SVV]
      [F:VLA]BUL    = [M:SVV]BUL(I)
      [F:VLA]EMP    = [M:SVV]MAT(I)
      [F:VLA]VARCOD = CODVAR
      [F:VLA]VARVAL = NEWVAL
      [F:VLA]DAT    = [M:SVV]DAT(I)
      [F:VLA]TYP    = 4
      Write [VLA]
     Endif
    Else
     If [F:VLA]VARVAL<>NEWVAL
      [F:VLA]VARVAL = NEWVAL
      Rewrite [VLA]
     Endif
    Endif
    If fstat
     GOK = 0 : Call FSTA("VLA") From GLOCK : Break 2
    Endif
   Next J
  Endif
 Next I
 If GOK<0      : Goto ROL_TR1
 Elsif GOK=0   : Goto AB_TR1
 Endif
Commit
Return

$DEVERROU
Call DELOCK("VEP") From GLOCK
Return

$AB_TR1
Rollback
Return

$ROL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

