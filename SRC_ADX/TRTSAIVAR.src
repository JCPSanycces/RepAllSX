Subprog B1_TBL
If [M]TRI=0
 Sorta [M]TBL [M]TBL Order By [M]DES(indice)
 [M]TRI = 1
Else
 Sorta [M]TBL [M]TBL Order By [M]MAT(indice)
 [M]TRI = 0
Endif
Affzo
End

