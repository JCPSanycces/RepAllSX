#<AdxTL>@(#)3.0.0.0 $Revision$
##################################################################################################
#  traduction ATEXTE : mise a jour des différents produits pour la V8
#  utilise par INDUS
##################################################################################################
End

#--------------------------------------------#
# mise a jour table du superviseur
#--------------------------------------------#
$MAJSUPER_180
Local Integer WTAB_NUM (1..100)
Local Integer WTAB_INDICE

Local Integer W_INDICE


#---------------------------------
# en premier 
# il faut ici mettre à jour le produit en v7 X3 X3INDv7
# et ensuite on regarde pour la v180
# ----------------------------------------


If GPRODUIT = 0
    #---------------------------------------------
    # mise a jour X3IND170
    # lecture dans le fichier XYZ code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
    # mise a jour de atexte de la version 170 pour x3 code XYZ X3IND170


    Raz WTAB_NUM
    W_INDICE  =0

    Filter [XYZ] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
    WTAB_INDICE = 0
    For [XYZ]
        WTAB_INDICE +=1
        WTAB_NUM (WTAB_INDICE)= [F:XYZ]NUMERO
    Next
    Filter [XYZ]
    If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur X3IND170
        #Return
    Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XYZ]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
           If [F:XYZ]COMMENT = WTEXTE_COMMENT
                Gosub X3IND170_TEXTE From ATRADTEX
           Endif
        Endif
    Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XYZ]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYZ]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub X3IND170_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
    Endif

    #---------------------------------------------
    # mise a jour PAIEIND170
    #  à faire Gosub PAIEIND170_TEXTE
    #  ne porte pas le même numéro 
    #  on le fait ici car dans le trt ASUPERV170 c'est fait aussi
    #  mais uniquement dans le cas d'un texte supervisuer
    # il faut aussi le faire sur un texte paye uniquement
    #---------------------------------------------
    Raz WTAB_NUM
    W_INDICE  =0

    Filter [XYP] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
    WTAB_INDICE = 0
    For [XYP]
        WTAB_INDICE +=1
        WTAB_NUM (WTAB_INDICE)= [F:XYP]NUMERO
    Next
    Filter [XYP]
    If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur paiev7
        #Return
    Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XYP]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
           If [F:XYP]COMMENT = WTEXTE_COMMENT
                Gosub PAYIND170_TEXTE From ATRADTEX
           Endif
        Endif
    Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XYP]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYP]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub PAYIND170_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
    Endif

Endif

If GPRODUIT = 1
    #---------------------------------------------
    # mise a jour GEOIND170
    # lecture dans le fichier Xxxxx code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
    # mise a jour de atexte de la version 170 pour code XxxxX GEOIND170
Endif

If GPRODUIT = 2
    #---------------------------------------------
    # mise a jour PAYIND170
    # lecture dans le fichier XyP code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
    Raz WTAB_NUM
    W_INDICE  =0

    Filter [XYP] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
    WTAB_INDICE = 0
    For [XYP]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XYP]NUMERO
    Next
    Filter [XYP]
    If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur paye on sort
            Return
    Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XYP]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XYP]COMMENT = WTEXTE_COMMENT
                    Gosub PAYIND170_TEXTE From ATRADTEX
               Endif
            Endif
    Else
            # +sieurs textes correspondant on regarde le commentaire
            # pour faire le choix 
            For W_INDICE = 1 To WTAB_INDICE
                Read [XYP]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYP]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub PAYIND170_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
    Endif

Endif

If GPRODUIT = 3
    # n'existe plus en V6
    # abelx3 est dans X3......... depuis la v6
Endif





#--------------------------------------------#
# mise a jour ATEXTE de SUPERV180
# lecture dans le fichier XYSV8 code langue FRA
# recherche du texte correspond 
# dans superv180 ne porte pas le même numéro obligatoirement
# attention test aussi de la zone commentaire en FRA 
#--------------------------------------------#

Raz WTAB_NUM
W_INDICE  =0

Filter [XYSV8] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
WTAB_INDICE = 0
For [XYSV8]
    WTAB_INDICE +=1
    WTAB_NUM (WTAB_INDICE)= [F:XYSV8]NUMERO
Next
Filter [XYSV8]


If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur superv180 on sort
        # on ne cherche meme pas a mettre a jour abelx3 ou x3 ou geode
        Return
Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XYSV8]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
             If [F:XYSV8]COMMENT = WTEXTE_COMMENT
                    Gosub SUPERV180_TEXTE From ATRADTEX
                Endif
        Endif
Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XYSV8]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYSV8]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub SUPERV180_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
Endif


#--------------------------------------------#
# on fait idem si on est sur x3
# mise a jour ATEXTE de geode et de la paye
#--------------------------------------------#

If GPRODUIT = 0
    #---------------------------------------------
    # mise a jour ABELX V8 : jamais plus 
     If GFOLDER_V180(4) <> ""
     Endif
    #---------------------------------------------
    # mise a jour geode v8 
    If GFOLDER_V180(2) <> ""
        # lecture dans le fichier XYXV8 code langue FRA
        # recherche du texte correspond 
        # dans geode ne porte pas le même numéro obligatoirement
        # attention test aussi de la zone commentaire en FRA 
        Raz WTAB_NUM
        W_INDICE  =0

        Filter [XYXV8] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
        WTAB_INDICE = 0
        For [XYXV8]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XYXV8]NUMERO
        Next
        Filter [XYXV8]
        If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur geode on sort
            Return
        Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XYXV8]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XYXV8]COMMENT = WTEXTE_COMMENT
                    Gosub GEOIND180_TEXTE From ATRADTEX
               Endif
            Endif
        Else
            # +sieurs textes correspondant on regarde le commentaire
            # pour faire le choix 
            For W_INDICE = 1 To WTAB_INDICE
                Read [XYXV8]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYXV8]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub GEOIND180_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
        Endif
    Endif
    #---------------------------------------------
    # mise a jour paye v8 
    If GFOLDER_V180(3) <> ""
        # lecture dans le fichier XYPv8 code langue FRA
        # recherche du texte correspond 
        # dans geode ne porte pas le même numéro obligatoirement
        # attention test aussi de la zone commentaire en FRA 
        Raz WTAB_NUM
        W_INDICE  =0

        Filter [XYPV8] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
        WTAB_INDICE = 0
        For [XYPV8]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XYPV8]NUMERO
        Next
        Filter [XYPV8]
        If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur paye on sort
            Return
        Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XYPV8]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XYPV8]COMMENT = WTEXTE_COMMENT
                    Gosub PAYIND180_TEXTE From ATRADTEX
               Endif
            Endif
        Else
            # +sieurs textes correspondant on regarde le commentaire
            # pour faire le choix 
            For W_INDICE = 1 To WTAB_INDICE
                Read [XYPV8]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYPV8]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub PAYIND180_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
        Endif

    Endif
Endif

#--------------------------------------------#
# on fait idem si on est sur geodev8
# mise a jour ATEXTE de X3 et la paye
# a faire plus tard
#--------------------------------------------#

If GPRODUIT = 1
Endif

#--------------------------------------------#
# on fait idem si on est sur payev8
# mise a jour ATEXTE de X3  et de geode
#--------------------------------------------#
If GPRODUIT = 2

    #---------------------------------------------
