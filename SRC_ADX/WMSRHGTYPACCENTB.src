$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 5152: RES='Type de pièces'
   When 436: RES='Type de pièce'
   When 71: RES='Code d'+"'"+'accès'
   When 26213: RES='Législation'
  Endcase
 When "ENG":
  Case _ID
   When 5152: RES='Document types'
   When 436: RES='Entry type'
   When 71: RES='Access code'
   When 26213: RES='Legislation'
  Endcase
 When "ITA":
  Case _ID
   When 5152: RES='Tipo movimento'
   When 436: RES='Tipo movimento'
   When 71: RES='Codice accesso'
   When 26213: RES='Legislazione'
  Endcase
 When "POR":
  Case _ID
   When 5152: RES='Tipos de doc.'
   When 436: RES='Tipo de docum.'
   When 71: RES='Código acesso'
   When 26213: RES='Legislação'
  Endcase
 When "SPA":
  Case _ID
   When 5152: RES='Tipo de asientos'
   When 436: RES='Tipo asiento'
   When 71: RES='Cód. de acceso'
   When 26213: RES='Legislación'
  Endcase
 When "BRI":
  Case _ID
   When 5152: RES='Document Types'
   When 436: RES='Document Type'
   When 71: RES='Access code'
   When 26213: RES='Legislation'
  Endcase
 When "GER":
  Case _ID
   When 5152: RES='Belegtypen'
   When 436: RES='Belegtyp'
   When 71: RES='Zugriffscode'
   When 26213: RES='Rechtsordnung'
  Endcase
 When "POL":
  Case _ID
   When 5152: RES='Typy dokumentów księgowań'
   When 436: RES='Typ dokumentu KG'
   When 71: RES='Kod dostępu'
   When 26213: RES='Legislacja'
  Endcase
 When "CHI":
  Case _ID
   When 5152: RES='凭证类型'
   When 436: RES='凭证类型'
   When 71: RES='访问代码'
   When 26213: RES='准则'
  Endcase
 When "ARB":
  Case _ID
   When 5152: RES='أنواع الوثيقة    نص خاطئ - لا يمكن استخدامه'
   When 436: RES='نوع الإدخال'
   When 71: RES='رمز الدخول'
   When 26213: RES='تشريعات'
  Endcase
Endcase
Return
#---------------------------------------------------------------------------------------------------#
$_GET_RES_MENU
