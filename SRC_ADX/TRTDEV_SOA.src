#<AdxTL>@(#)0.0.0.0 $Revision$
Local Integer STAT
Local Decimal MTDES1,MTDES2
#Call COURSITE("TL","PAR",1,date$,MTDES,STAT)
Call CONVERT3("TL","JPY","EUR",1,date$,10000,MTDES1,0,STAT) From CPTSUB
Call COURMNT("TL","JPY","EUR",1,date$,1,10000,MTDES2,0,STAT)
Infbox num$(MTDES1),num$(MTDES2)
End

######################################################################################
## Conversion d'un montant unique
## Subprog CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
##
## Conversion avec toute la précision
## Subprog CONVERT2(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
##
## Conversion avec un arrondi donné (en nombre de décimales)
## Subprog CONVERT3(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT)
##
## Conversion d'un tableau à somme constante
## Subprog CONVERT_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
##
## Conversion d'un tableau avec un arrondi forcé
## Subprog CONVERT3_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT)
##
## Récupération du cours entre une devise origine et la devise société
## Subprog COURSITE(DEVORG,SITE,TYPCOURS,DATCOURS,COURS,STAT)
##
## Conversion avec un arrondi donné (en nombre de décimales) et cours éventuellement fourni
## Subprog COURMNT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,COURS,STAT)
######################################################################################
Subprog CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = 0
Local Integer ARROND : ARROND = 1 : # Arrondi
Goto CONVERSION
#---------------
Subprog CONVERT2(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = 0
Local Integer ARROND : ARROND = 0 : # Pas d'arrondi
Goto CONVERSION
#---------------
Subprog CONVERT3(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Integer ARODEC           : # Arrondi
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = 0
Local Integer ARROND : ARROND = 2 : # Arrondi forcé à ARODES
Local Decimal ADODES
If int(ARODEC)>0 : ARODES = 10^(-ARODEC) : Else : ARROND = 1 : Endif
Goto CONVERSION
#---------------
Subprog CONVERT_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG(0..)       : # Montant origine
Variable Decimal MTDES(0..)       : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = dim(MTORG)-1
Local Integer ARROND : ARROND = 1
Goto CONVERSION
#---------------
Subprog CONVERT2_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG(0..)       : # Montant origine
Variable Decimal MTDES(0..)       : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = dim(MTORG)-1
Local Integer ARROND : ARROND = 0
Goto CONVERSION
#---------------
Subprog CONVERT3_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Integer ARODEC           : # Arrondi
Value    Decimal MTORG(0..)       : # Montant origine
Variable Decimal MTDES(0..)       : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = dim(MTORG)-1
Local Integer ARROND : ARROND = 2 : # Arrondi forcé à ARODES
Local Decimal ADODES
If int(ARODEC)>0 : ARODES = 10^(-ARODEC) : Else : ARROND = 1 : Endif
Goto CONVERSION
######################################################################################
# get global values for the following:
# - SOA_GAROEURO - see WWAGLOBVAR
#Global Decimal  GAROEURO            : # Euro conversion rounding
#Call PARAM("","EURORND",PARAM) From ADOVAL
#SOA_GAROEURO = val(PARAM)
#
# - SOA_GEURO
#Global Char     SOA_GEURO(30)           : # Euro code
#Call PARAM("","EURO",PARAM) From ADOVAL
#SOA_GEURO = PARAM
#
# - SOA_GDECRCU
#Global Decimal  SOA_GDECRCU             : # No. decimals currency rate
#Call PARAM("","DECRCU",PARAM) From ADOVAL
#SOA_GDECRCU = val(PARAM)
#
# - SOA_GHIDATE - see WWAGLOBDEF
#Global Date     SOA_GHIDATE             : # Plus grande date valable sur 2 chiffres
#SOA_GHIDATE = gdat$(31,12,adxdcs+99)
#
# - SOA_GEURODEV - see WWAGLOBSUP
#Global Decimal  SOA_GEURODEV            : # Code devise EURO
#
#**
#* This Funprog is used to get parameter value defined at
#* Folder/Legislation/Company/Site level.
#*
#* Note that:
#* - The "Definition Level" of the parameter to search could be at any level.
#* - But the search level TYPCOD can only be Folder/Legislation/Company/Site,
#*   for search of value at User level, please use Funprog GET_PARAM_SUER.
#* - An heritage logic is implemented in this Funprog, which means:
#*   - If no value found for the given site, looking for the value defined
#*     for this site's company.
#*   - If no value found for the given company, looking for the value defined
#*     for this company's Legislation.
#*   - If no value found for the given legislation, looking for the value defined
#*     at Folder level.
#*
#* @param APPLI   Folder
#* @param TYPCOD  1-Folder;  2-Company;  3-Site;  5-Legislation; 0-not specified
#* @param TYPVAL  value corresponds to the TYPCOD
#* @param PARAM   Parameter code
#* @return PARAMVAL  value of parameter
#*!
#Funprog GET_PARAM(APPLI, TYPCOD, TYPVAL, PARAM)
#Value Char APPLI
#Value Integer TYPCOD
#Value Char TYPVAL, PARAM
 #Local Integer RES_FOUND
 #Local Char PARAMVAL
 #Call GET_PARAM_SUB(APPLI, TYPCOD, TYPVAL, PARAM, RES_FOUND, PARAMVAL)
#End PARAMVAL
######################################################################################
$CONVERSION

Local Decimal COURS , COURDIV , COURMUL , COURDIV1 , COURMUL1 , ARD
Local Char    DEV1(GLONCUR) , DEV2(GLONCUR) , DEVCUR(GLONCUR)
Local Decimal MTEURO , AROEURO , EURT1 , EURT2 , SOMME
Local Integer EUR1 , EUR2 , I , FLEURO

# Convert Global variables to Local variables
Local Decimal  SOA_GAROEURO            : # Euro conversion rounding
Local Char     SOA_GEURO(30)           : # Euro code
Local Decimal  SOA_GDECRCU             : # No. decimals currency rate
Local Date     SOA_GHIDATE             : # Plus grande date valable sur 2 chiffres
Local Decimal  SOA_GEURODEV            : # Code devise EURO

Call GAROEURO(SOA_GAROEURO) From ESSGLOB_SOA
Call GEURO(SOA_GEURO)       From ESSGLOB_SOA
Call GDECRCU(SOA_GDECRCU)   From ESSGLOB_SOA
Call GHIDATE(SOA_GHIDATE)   From ESSGLOB_SOA
Call GEURODEV(SOA_GEURODEV) From ESSGLOB_SOA

If dim(SOA_GAROEURO)>0
 AROEURO = 10^(-SOA_GAROEURO)   : # Arrondi pour les calculs en euro
Else
 AROEURO = 0.001            : # Valeur par défaut minimale
Endif
FLEURO  = 1       : # Passage par l'euro ou non

STAT = 0
If DATCOURS=[0/0/0] : DATCOURS = SOA_GHIDATE : Endif
If TYPCOURS=0       : TYPCOURS = 1           : Endif

If clalev([F:TCU])=0
 Local File TABCUR    [TCU]
Else
 DEVCUR = [F:TCU]CUR
Endif

# Cas trivial
If DEVORG=DEVDES
 If [F:TCU]CUR<>DEVDES
     Read [TCU]TCU0=DEVDES : If fstat  Raz [F:TCU] : Endif
 Endif
 For I=0 To NBMONT
  MTDES(I) = MTORG(I)
  Case ARROND
   When 1 : MTDES(I)=arr(MTDES(I),[F:TCU]CURRND)
   When 2 : MTDES(I)=arr(MTDES(I),ARODES)
  Endcase
 Next I
 Goto FIN
Endif

Local Char SOA_GTABCPT(80) : Call GTABCPT(SOA_GTABCPT) From ESSGLOB_SOA

If clalev([F:TCH])=0
  Local File =SOA_GTABCPT+"TABCHANGE" [TCH]
Endif

If DEVORG=SOA_GEURO
 If [F:TCU]CUR<>DEVDES
     Read [TCU]TCU0=DEVDES
     If fstat : STAT = 3 : Goto FIN : Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
# Euro vers devise "in"
  SOMME = 0
  Case ARROND
   When 1       : ARD = [F:TCU]CURRND
   When 2       : ARD = ARODES
   When Default : ARD = 0
  Endcase
  For I=0 To NBMONT
   MTDES(I) = arr((MTORG(I)+SOMME)*[F:TCU]EURRAT,ARD)
&             -arr(SOMME*[F:TCU]EURRAT,ARD)
   SOMME += MTORG(I)
  Next I
 Else
# Euro vers devise "out"
  DEV1 = SOA_GEURO : DEV2 = DEVDES : Gosub COURS
  If STAT=0
   SOMME = 0
   Case ARROND
    When 1       : ARD = [F:TCU]CURRND
    When 2       : ARD = ARODES
    When Default : ARD = 0
   Endcase
   For I=0 To NBMONT
## <PP 31/05/2010>
#    MTDES(I) = arr((MTORG(I)+SOMME)*COURMUL/COURDIV,ARD)
#&             -arr(SOMME*COURMUL/COURDIV,ARD)
    MTDES(I) = arr((MTORG(I)+SOMME)*arr(COURMUL/COURDIV,10^-SOA_GDECRCU),ARD)
&             -arr(SOMME*arr(COURMUL/COURDIV,10^-SOA_GDECRCU),ARD)
    SOMME += MTORG(I)
   Next I
  Endif
 Endif
Elsif DEVDES=SOA_GEURO
 # Issue 74775 - 2011-07-07 by VPO : Pour perf, on passe par une 2eme classe F
 # ssi la classe [F:TCU0] existe pour ne pas avoir d'effet de bord en migration
  If clalev([F:TCU0])=0
     If [F:TCU]CUR<>DEVORG
         Read  [TCU] TCU0=DEVORG
         If fstat : STAT = 2 : Goto FIN : Endif
     Endif

     If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
    # Devise "in" vers Euro
      SOMME = 0
      Case ARROND
       When 1       : ARD = SOA_GEURODEV
       When 2       : ARD = ARODES
       When Default : ARD = 0
      Endcase
      For I=0 To NBMONT
       MTDES(I) = arr((MTORG(I)+SOMME)/[F:TCU]EURRAT,ARD)
&                -arr(SOMME/[F:TCU]EURRAT,ARD)
       SOMME += MTORG(I)
      Next I
     Else
    # Devise "out" vers Euro
      DEV1 = SOA_GEURO : DEV2 = DEVORG : Gosub COURS
      If STAT=0
       SOMME = 0
       Case ARROND
        When 1       : ARD = SOA_GEURODEV
        When 2       : ARD = ARODES
        When Default : ARD = 0
       Endcase
       For I=0 To NBMONT
    ## <PP 31/05/2010>
    #    MTDES(I) = arr((MTORG(I)+SOMME)*COURDIV/COURMUL,ARD)
    #&             -arr(SOMME*COURDIV/COURMUL,ARD)
        MTDES(I) = arr((MTORG(I)+SOMME)*arr(COURDIV/COURMUL,10^-SOA_GDECRCU),ARD)
&                -arr(SOMME*arr(COURDIV/COURMUL,10^-SOA_GDECRCU),ARD)
        SOMME += MTORG(I)
       Next I
      Endif
     Endif
  Else
     If [F:TCU0]CUR<>DEVORG
      If [F:TCU]CUR=DEVORG
         [F:TCU0]=[F:TCU]
      Else
         Read  [TCU0] TCU0=DEVORG
         If fstat : STAT = 2 : Goto FIN : Endif
      Endif
     Endif

     If [F:TCU0]EURFLG=2 & ([F:TCU0]EURDAT=[0/0/0] | [F:TCU0]EURDAT<=DATCOURS)
    # Devise "in" vers Euro
      SOMME = 0
      Case ARROND
       When 1       : ARD = SOA_GEURODEV
       When 2       : ARD = ARODES
       When Default : ARD = 0
      Endcase
      For I=0 To NBMONT
       MTDES(I) = arr((MTORG(I)+SOMME)/[F:TCU0]EURRAT,ARD)
&                -arr(SOMME/[F:TCU0]EURRAT,ARD)
       SOMME += MTORG(I)
      Next I
     Else
    # Devise "out" vers Euro
      DEV1 = SOA_GEURO : DEV2 = DEVORG : Gosub COURS
      If STAT=0
       SOMME = 0
       Case ARROND
        When 1       : ARD = SOA_GEURODEV
        When 2       : ARD = ARODES
        When Default : ARD = 0
       Endcase
       For I=0 To NBMONT
    ## <PP 31/05/2010>
    #    MTDES(I) = arr((MTORG(I)+SOMME)*COURDIV/COURMUL,ARD)
    #&             -arr(SOMME*COURDIV/COURMUL,ARD)
        MTDES(I) = arr((MTORG(I)+SOMME)*arr(COURDIV/COURMUL,10^-SOA_GDECRCU),ARD)
&                -arr(SOMME*arr(COURDIV/COURMUL,10^-SOA_GDECRCU),ARD)
        SOMME += MTORG(I)
       Next I
      Endif
     Endif
  Endif
Else
 # Issue 74775 - 2011-07-07 by VPO : Pour perf, on passe par une 2eme classe F
 # ssi la classe [F:TCU0] existe pour ne pas avoir d'effet de bord en migration
 If clalev([F:TCU0])=0
   If [F:TCU]CUR<>DEVORG
       Read  [TCU] TCU0=DEVORG
       If fstat : STAT = 2 : Goto FIN : Endif
   Endif

   If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
    EUR1 = [F:TCU]EURFLG
   Else EUR1 = 1
   Endif
   EURT1 = [F:TCU]EURRAT
 Else
   If [F:TCU0]CUR<>DEVORG
    If [F:TCU]CUR=DEVORG
       [F:TCU0]=[F:TCU]
    Else
       Read  [TCU0] TCU0=DEVORG
       If fstat : STAT = 2 : Goto FIN : Endif
    Endif
   Endif

   If [F:TCU0]EURFLG=2 & ([F:TCU0]EURDAT=[0/0/0] | [F:TCU0]EURDAT<=DATCOURS)
    EUR1 = [F:TCU0]EURFLG
   Else EUR1 = 1
   Endif
   EURT1 = [F:TCU0]EURRAT
 Endif

 If [F:TCU]CUR<>DEVDES
     Read [TCU]TCU0=DEVDES
     If fstat : STAT = 3 : Goto FIN : Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  EUR2 = [F:TCU]EURFLG
 Else EUR2 = 1
 Endif
 EURT2 = [F:TCU]EURRAT
 If EUR1=2 & EUR2=2
# Devise "in" vers devise "in"
  SOMME = 0
  For I=0 To NBMONT
   Case ARROND
    When 1       : ARD = AROEURO
    When 2       : ARD = ARODES
    When Default : ARD = 0
   Endcase
   MTEURO = arr((MTORG(I)+SOMME)/EURT1,ARD)
   MTSOMM = arr(SOMME/EURT1,ARD)
   Case ARROND
    When 1       : ARD = [F:TCU]CURRND
    When 2       : ARD = ARODES
    When Default : ARD = 0
   Endcase
   MTDES(I)  = arr(MTEURO*EURT2,ARD)
&             -arr(MTSOMM*EURT2,ARD)
   SOMME += MTORG(I)
  Next I
 Elsif EUR1=2
# Devise "in" vers devise "out"
  DEV1 = SOA_GEURO : DEV2 = DEVDES : Gosub COURS
  If STAT=0
   SOMME = 0
   For I=0 To NBMONT
    Case ARROND
     When 1       : ARD = AROEURO
     When 2       : ARD = ARODES
     When Default : ARD = 0
    Endcase
    MTEURO = arr((MTORG(I)+SOMME)/EURT1,ARD)
    MTSOMM = arr(SOMME/EURT1,ARD)
    Case ARROND
     When 1       : ARD = [F:TCU]CURRND
     When 2       : ARD = ARODES
     When Default : ARD = 0
    Endcase
## <PP 31/05/2010>
#    MTDES(I) = arr(MTEURO*COURMUL/COURDIV,ARD)
#&             -arr(MTSOMM*COURMUL/COURDIV,ARD)
    MTDES(I) = arr(MTEURO*arr(COURMUL/COURDIV,10^-SOA_GDECRCU),ARD)
&             -arr(MTSOMM*arr(COURMUL/COURDIV,10^-SOA_GDECRCU),ARD)
    SOMME += MTORG(I)
   Next I
  Endif
 Elsif EUR2=2
# Devise "out" vers devise "in"
  DEV1 = SOA_GEURO : DEV2 = DEVORG : Gosub COURS
  If STAT=0
   SOMME = 0
   For I=0 To NBMONT
    Case ARROND
     When 1       : ARD = AROEURO
     When 2       : ARD = ARODES
     When Default : ARD = 0
    Endcase
    ## <PP 31/05/2010>
    #MTEURO = arr((MTORG(I)+SOMME)*COURDIV/COURMUL,ARD)
    #MTSOMM = arr(SOMME*COURDIV/COURMUL,ARD)
    MTEURO = arr((MTORG(I)+SOMME)*arr(COURDIV/COURMUL,10^-SOA_GDECRCU),ARD)
    MTSOMM = arr(SOMME*arr(COURDIV/COURMUL,10^-SOA_GDECRCU),ARD)
    Case ARROND
     When 1       : ARD = [F:TCU]CURRND
     When 2       : ARD = ARODES
     When Default : ARD = 0
    Endcase
    MTDES(I)  = arr(MTEURO*EURT2,ARD)
&              -arr(MTSOMM*EURT2,ARD)
    SOMME += MTORG(I)
   Next I
  Endif
 Else
# Devise "out" vers devise "out"
  DEV1 = DEVDES : DEV2 = DEVORG : Gosub COURS
  If STAT=0
#  Y'a un cours direct
   SOMME = 0
   For I=0 To NBMONT
    Case ARROND
     When 1       : ARD = [F:TCU]CURRND
     When 2       : ARD = ARODES
     When Default : ARD = 0
    Endcase
## <PP 31/05/2010>
#    MTDES(I) = arr((MTORG(I)+SOMME)*COURDIV/COURMUL,ARD)
#&             -arr(SOMME*COURDIV/COURMUL,ARD)
    MTDES(I) = arr((MTORG(I)+SOMME)*arr(COURDIV/COURMUL,10^-SOA_GDECRCU),ARD)
&             -arr(SOMME*arr(COURDIV/COURMUL,10^-SOA_GDECRCU),ARD)
    SOMME += MTORG(I)
   Next I
  Else
#  Sinon, on passe par le cours "société" (pour l'étranger)
#  ou par l'euro pour l'europe
   STAT = 0
   If FLEURO
    DEV1 = SOA_GEURO : DEV2 = DEVORG : Gosub COURS
    If STAT=0
     COURMUL1 = COURMUL
     COURDIV1 = COURDIV
     DEV1 = SOA_GEURO : DEV2 = DEVDES : Gosub COURS
     If STAT=0
      SOMME = 0
      For I=0 To NBMONT
       Case ARROND
        When 1       : ARD = AROEURO
        When 2       : ARD = ARODES
        When Default : ARD = 0
       Endcase
       ## <PP 31/05/2010>
       #MTEURO = arr((MTORG(I)+SOMME)*COURDIV1/COURMUL1,ARD)
       #MTSOMM = arr(SOMME*COURDIV1/COURMUL1,ARD)
       MTEURO = arr((MTORG(I)+SOMME)*arr(COURDIV1/COURMUL1,10^-SOA_GDECRCU),ARD)
       MTSOMM = arr(SOMME*arr(COURDIV1/COURMUL1,10^-SOA_GDECRCU),ARD)
       Case ARROND
        When 1       : ARD = [F:TCU]CURRND
        When 2       : ARD = ARODES
        When Default : ARD = 0
       Endcase
       ## <PP 31/05/2010>
       #MTDES(I) = arr(MTEURO*COURMUL/COURDIV,ARD)
#&                -arr(MTSOMM*COURMUL/COURDIV,ARD)
       MTDES(I) = arr(MTEURO*arr(COURMUL/COURDIV,10^-SOA_GDECRCU),ARD)
&                -arr(MTSOMM*arr(COURMUL/COURDIV,10^-SOA_GDECRCU),ARD)
       SOMME += MTORG(I)
      Next I
     Endif
    Endif
   Else
    DEV1 = DEVSOC : DEV2 = DEVORG : Gosub COURS
    If STAT=0
     COURMUL1 = COURMUL
     COURDIV1 = COURDIV
     DEV1 = DEVSOC : DEV2 = DEVDES : Gosub COURS
     If STAT=0
      SOMME = 0
      For I=0 To NBMONT
       Case ARROND
        When 1       : ARD = AROEURO
        When 2       : ARD = ARODES
        When Default : ARD = 0
       Endcase
       ## <PP 31/05/2010>
       #MTEURO = arr((MTORG(I)+SOMME)*COURDIV1/COURMUL1,ARD)
       #MTSOMM = arr(SOMME*COURDIV1/COURMUL1,ARD)
       MTEURO = arr((MTORG(I)+SOMME)*arr(COURDIV1/COURMUL1,10^-SOA_GDECRCU),ARD)
       MTSOMM = arr(SOMME*arr(COURDIV1/COURMUL1,10^-SOA_GDECRCU),ARD)
       Case ARROND
        When 1       : ARD = [F:TCU]CURRND
        When 2       : ARD = ARODES
        When Default : ARD = 0
       Endcase
       ## <PP 31/05/2010>
#       MTDES(I) = arr(MTEURO*COURMUL/COURDIV,ARD)
#&                -arr(MTSOMM*COURMUL/COURDIV,ARD)
       MTDES(I) = arr(MTEURO*arr(COURMUL/COURDIV,10^-SOA_GDECRCU),ARD)
&                -arr(MTSOMM*arr(COURMUL/COURDIV,10^-SOA_GDECRCU),ARD)
       SOMME += MTORG(I)
      Next I
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
######################################################################################
$FIN
If DEVCUR<>""
 If [F:TCU]CUR<>DEVCUR
    Read [TCU]TCU0=DEVCUR: If fstat  Raz [F:TCU] : Endif
 Endif
Endif
End
######################################################################################
$COURS
Filter [TCH] Where CHGTYP=TYPCOURS & CURDEN=DEV1 & CUR=DEV2
&                & CHGSTRDAT<=DATCOURS
Read [TCH]TCH0 Last
If fstat<=2
 # Version 150, il y a 2 cours...
 COURMUL = [F:TCH]REVCOURS
 COURDIV = [F:TCH]CHGDIV
 ## <PP 31/05/2010>
 #COURS   = COURDIV/COURMUL
 COURS = arr(COURDIV/COURMUL,10^-SOA_GDECRCU)
 STAT    = 0
Else
 STAT = 1
Endif
GPOINT = "RECHTCH" : Gosub ENTREE From EXEFNC
Return
#################################################################################
# Not being called yet ????

Subprog COURSITE(DEVORG,SITE,TYPCOURS,DATCOURS,COURS,STAT)
Value    Char    DEVORG        : # Devise origine
Value    Char    SITE          : # Site
Value    Libelle TYPCOURS      : # Type de cours
Value    Date    DATCOURS      : # Date du cours
Variable Decimal COURS         : # Cours
Variable Integer STAT          : # Status de retour (OK=0)

Local Char    DEVDES(GLONCUR), DEV1(GLONCUR), DEV2(GLONCUR), DEVCUR(GLONCUR)
Local Decimal COURDIV , COURMUL
Local Decimal EURT1, EURT2, COURS1
Local Integer EUR1, EUR2, FLEURO

If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif

COURS=1
If SITE="" : SITE=GFCYDEF : Endif
If [F:FCY]FCY<>SITE
 Read [FCY]FCY0=SITE
 If fstat : STAT=1 : End Endif
Endif
If [F:CPY]CPY<>[F:FCY]LEGCPY
 Read [CPY]CPY0=[F:FCY]LEGCPY
 If fstat : STAT=1 : End Endif
Endif
Call SETCUR(1,[F:CPY]CPY,DEVDES) From CPTDIV

FLEURO=1
STAT=0
If DATCOURS=[0/0/0] : DATCOURS=SOA_GHIDATE : Endif
If TYPCOURS=0 : TYPCOURS=1 : Endif

If DEVORG=DEVDES
 COURS=1 : End
Endif

If clalev([F:TCU])=0 : Local File TABCUR    [TCU] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE [TCH] : Endif

If DEVORG=SOA_GEURO
 If [F:TCU]CUR<>DEVDES
     Read [TCU]TCU0=DEVDES
     If fstat STAT=3 : End Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  # Euro vers devise "in"
  If [F:TCU]EURRAT=0
   COURS=1 : STAT=1
  Else
   COURS=[F:TCU]EURRAT
  Endif
 Else
  # Euro vers devise "out"
  DEV1=DEVDES : DEV2=SOA_GEURO : Gosub COURS
 Endif
Elsif DEVDES=SOA_GEURO
 If [F:TCU]CUR<>DEVORG
     Read [TCU]TCU0=DEVORG
     If fstat STAT=2 : End Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  # Devise "in" vers Euro
  If [F:TCU]EURRAT=0
   COURS=1 : STAT=1
  Else
   COURS=1/[F:TCU]EURRAT
  Endif
 Else
  # Devise "out" vers Euro
  DEV1=SOA_GEURO : DEV2=DEVORG : Gosub COURS
 Endif
Else
 If [F:TCU]CUR<>DEVORG
     Read [TCU]TCU0=DEVORG
     If fstat STAT=2 : End Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  EUR1=[F:TCU]EURFLG
 Else
  EUR1=1
 Endif
 EURT1=[F:TCU]EURRAT
 If [F:TCU]CUR<>DEVDES
     Read [TCU]TCU0=DEVDES
     If fstat STAT=3 : End Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  EUR2=[F:TCU]EURFLG
 Else
  EUR2=1
 Endif
 EURT2=[F:TCU]EURRAT
 If EUR1=2 & EUR2=2
  # Devise "in" vers devise "in"
  If EURT1=0 | EURT2=0
   COURS=1 : STAT=1
  Else
   COURS=EURT2/EURT1
  Endif
 Elsif EUR1=2
  # Devise "in" vers devise "out"
  DEV1=DEVDES : DEV2=SOA_GEURO : Gosub COURS
  If EURT1=0
   COURS=1 : STAT=1
  Else
   COURS=COURS/EURT1
  Endif
 Elsif EUR2=2
  # Devise "out" vers devise "in"
  DEV1=SOA_GEURO : DEV2=DEVORG : Gosub COURS
  If EURT2=0
   COURS=1 : STAT=1
  Else
   COURS=COURS*EURT2
  Endif
 Else
  # Devise "out" vers devise "out"
  DEV1=DEVDES : DEV2=DEVORG : Gosub COURS
  If STAT<>0
   # Y'a pas de cours direct, on passe l'euro pour l'europe
   STAT=0
   If FLEURO
    DEV1=SOA_GEURO : DEV2=DEVORG : Gosub COURS
    If STAT=0
     COURS1=COURS
     DEV1=DEVDES : DEV2=SOA_GEURO : Gosub COURS
     If STAT=0
      COURS=COURS1*COURS
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
End
#####################################################################
# Not being called yet -????
#
Subprog COURMNT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,COURS,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise de destination
Value    Char    DEVSOC           : # Devise de référentiel général principal
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Integer ARODEC           : # Arrondi
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Value    Decimal COURS            : # Cours devise -> destination eventuelt donné
Variable Integer STAT             : # Status de retour (0 = OK)

Local  Decimal AMTINT             : # Montant intermédiaire
Local  Integer ORGFLG, DESFLG     : # Flags monnaies origine et destination
Local  Decimal ARRONDI
Local  Integer I

# Recherche de l'arrondi
If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
If [F:TCU]CUR<>DEVDES
   Read [TCU]TCU0=DEVDES : If fstat  Raz [F:TCU] : Endif
Endif
#-- Si ARODEC > 1 : Arrondi forcé avec le nombre de décimales
#-- Si ARODEC = 0 : Aucun Arrondi
#-- Sinon l'arrondi est récupéré sous le paramètrage de la devise
If int(ARODEC)>1
 ARRONDI = 10^(-ARODEC)
Elsif ARODEC=0
 ARRONDI = 0
Else
 ARRONDI = [F:TCU]CURRND
Endif

STAT=0
If DEVORG="" | DEVDES=""
 # Devise inexistante
 Call ECR_TRACE(mess(151,105,1),1) From GESECRAN : STAT=1
 End
Endif
ORGFLG=1 : DESFLG=1
#----- Partie modifiée par MBT pour un fonctionnement avec un contexte sans globale -----#
# Issue 74775 - 2011-07-07 by VPO : Pour perf, on passe par une 2eme classe F
# ssi la classe [F:TCU0] existe pour ne pas avoir d'effet de bord en migration
If clalev([F:TCU0])=0
  If [F:TCU]CUR<>DEVORG
       Read  [TCU] TCU0=DEVORG : If fstat  Raz [F:TCU] : Endif
  Endif
  If [F:TCU]CUR<>"" & [F:TCU]EURFLG=2  ORGFLG=2 : Endif
Else
  If [F:TCU0]CUR<>DEVORG
    If [F:TCU]CUR=DEVORG
       [F:TCU0]=[F:TCU]
    Else
       Read  [TCU0] TCU0=DEVORG : If fstat  Raz [F:TCU0] : Endif
    Endif
  Endif
  If [F:TCU0]CUR<>"" & [F:TCU0]EURFLG=2  ORGFLG=2 : Endif
Endif

If [F:TCU]CUR<>DEVDES
  Read  [TCU] TCU0=DEVDES : If fstat  Raz [F:TCU] : Endif
Endif
If [F:TCU]CUR<>"" & [F:TCU]EURFLG=2  DESFLG=2 : Endif
#-----
#I = find(DEVORG, GDEVISE(1..GNBDEV))
#If GDEVDAT(I) <= DATCOURS : ORGFLG = 2 : Endif   : # Si devise 'Out', GDEVDAT=31/12/9999
#I = find(DEVDES, GDEVISE(1..GNBDEV))
#If GDEVDAT(I) <= DATCOURS : DESFLG = 2 : Endif
#-----

If COURS<>0
 If ORGFLG=1
  #-------- 'Out' --> 'Out'
  If DESFLG=1
   MTDES = arr(MTORG*COURS, ARRONDI)
  Else
   #-------- 'Out' --> 'In'
   If DEVDES = SOA_GEURO
    MTDES = arr(MTORG*COURS, ARRONDI)
   Else      : # Si on a un cours, c'est celui de l'Euro
    AMTINT = arr(MTORG*COURS, 10^(-SOA_GAROEURO))
    Case ARODEC
     When 0  : Call CONVERT2(SOA_GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,AMTINT,MTDES,STAT) From TRTDEV
     When 1  : Call CONVERT(SOA_GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,AMTINT,MTDES,STAT) From TRTDEV
     When Default : Call CONVERT3(SOA_GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,AMTINT,MTDES,STAT) From TRTDEV
    Endcase
   Endif
  Endif
 Else
  If DESFLG=1
   #-------- 'In' --> 'Out'
   If DEVORG=SOA_GEURO
    MTDES = arr(MTORG*COURS, ARRONDI)
   Else
    Case ARODEC
     When 0  : Call CONVERT2(DEVORG,SOA_GEURO,DEVSOC,TYPCOURS,DATCOURS,MTORG,AMTINT,STAT) From TRTDEV
     When 1  : Call CONVERT(DEVORG,SOA_GEURO,DEVSOC,TYPCOURS,DATCOURS,MTORG,AMTINT,STAT) From TRTDEV
     When Default : Call CONVERT3(DEVORG,SOA_GEURO,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,AMTINT,STAT) From TRTDEV
    Endcase
    MTDES = arr(AMTINT*COURS, ARRONDI)
   Endif
  Else
  #-------- 'In' --> 'In'  : # si cours renseigné, on n'en tient pas compte
   Case ARODEC
    When 0  : Call CONVERT2(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
    When 1  : Call CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
    When Default : Call CONVERT3(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT) From TRTDEV
   Endcase
  Endif
 Endif
Else
 Case ARODEC
  When 0  : Call CONVERT2(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
  When 1  : Call CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
  When Default : Call CONVERT3(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT) From TRTDEV
 Endcase
Endif
End
#################################################################################
## Contrôle de saisie devise, euro et date de fin
#################################################################################
Subprog CONTDEV(DEVISE,DAT)
Value Char DEVISE
Value Date DAT
Local Integer OK

Local Char SOA_GUSER(GLONAUS)  : # Code utilisateur # User code
Call GUSER(SOA_GUSER) From ESSGLOB_SOA

Local File TABCUR  [TCU]
Local File AUTILIS [AUS]
If [F:TCU]CUR<>DEVISE
    Read [TCU]TCU0=DEVISE
    If fstat <> [V]CST_AOK : End : Endif
Endif
If [F:AUS]USR<>SOA_GUSER
    Read [AUS]CODUSR=SOA_GUSER
    If fstat <> [V]CST_AOK : End : Endif
Endif
# Date de validité
If [F:TCU]CURENDDAT<>[0/0/0] & DAT>=[F:TCU]CURENDDAT
 #mkstat = 2 : GMESSAGE = DEVISE-":"-mess(96,107,1)-format$("D:"+GFMDAT4,[F:TCU]CURENDDAT)
 ASTATUS=fmet this.ASETERROR([L]CURPRO,DEVISE-":"-mess(96,107,1)-format$("D:"+GFMDAT4,[F:TCU]CURENDDAT),[V]CST_AERROR)
 End
 # Devise non valide à cette date
Endif
# Contrôle utilisateur
Local Char SOA_GEURO(30) : Call GEURO(SOA_GEURO) From ESSGLOB_SOA
If DEVISE = SOA_GEURO : End : Endif : # Perf CP 08/07
Local Char LEURDAT(10), LEURDAC(3)
Local Date DEURDAT
Call PARAMUTIL("SAIDEVISE",LEURDAC,"","") From SUBAUS_SOA
Call PARAMUTIL("DATDEBCTR",LEURDAT,"","") From SUBAUS_SOA
If LEURDAT<>""
 DEURDAT = LEURDAT
 If DEURDAT<>[0/0/0] & datesyst>DEURDAT
  If [F:TCU]EURFLG=2 & DEVISE<>SOA_GEURO
   If val(LEURDAC)<>2
    #mkstat = 2 : GMESSAGE = mess(94,107,1) : # Saisie en devise in interdite   ???
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(94,107,1),[V]CST_AERROR)
    End
   Elsif (GPROGRAMME="GOBJSUB"
&       & find(GABREV,"GAS","GAF","BIC","BIS","PAY","CMM","LOT","PIH","FAS","BUP","FRM","PAB",
&                     "SQH","SOH","SOR","SDH","SIH","PPD","PSH","POI","POH","POC"))
&       | find(left$(GFONCTION,6),"SUBHLN","BUDDET","BUDNAT","BUDSEC","PAYPRO")
#???? how do we do this in SOA
    OK = 2 : Call AVERTIR(mess(95,107,1),OK) From GESECRAN  :# Attention saisie en devise in   ???
    If OK<>2 : mkstat = 2 : End : Endif
   Endif
  Endif
 Endif
Endif
End
######################################################################################

