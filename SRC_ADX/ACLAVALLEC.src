Subprog INI_ACLAVARDEF(CODCLA,DOSSIER,ACLA,AERR)
Value Char CODCLA
Value Char DOSSIER
Variable  Instance  ACLA  Using OBJECT
Variable  Instance  AERR Using C_AERROR
ACLA.ACLAV = NewInstance  C_ACLAVARDEF AllocGroup ACLA
ACLA.ACLAV.MAGIC     = mess(77,133,1) : # Superviseur Adonix
ACLA.ACLAV.TITETA    = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
ACLA.ACLAV.IDENTSTC  = "## ACLA-CLASSE ##"
ACLA.ACLAV.IDENTWML  = "## CRUD-CLASSE ##"
ACLA.ACLAV.VARIND    = "AINDICE"
ACLA.ACLAV.VARIST    = "AINDCLA"
ACLA.ACLAV.VAROLD    = "_AOLDVAL"
ACLA.ACLAV.VARPRO    = "CURPRO"
ACLA.ACLAV.VARPTH    = "CURPTH"
ACLA.ACLAV.VARVAL    = "VALPRO"
ACLA.ACLAV.VARQRY    = "CURQRY"
ACLA.ACLAV.VARCTL    = "ASTATUS"
ACLA.ACLAV.VARCTLALL = "ALLSTAT"
ACLA.ACLAV.TRTACT    = "ASYRSUB"
ACLA.ACLAV.TRTSYR    = "ASYRSUB"
ACLA.ACLAV.VARSTR    = "CURSTR"
ACLA.ACLAV.VARMES    = "MESERR"
ACLA.ACLAV.VARNUM    = "NUMERR"
ACLA.ACLAV.STRERR    = "AERROR"
ACLA.ACLAV.VARNXT    = "BREAKERR"
ACLA.ACLAV.VARLIG    = "AORDER"
ACLA.ACLAV.VARFAT    = "APARENT"
ACLA.ACLAV.AREPLNK   = "AREPLNK"
ACLA.ACLAV.DOSSIER   = [L]DOSSIER
Gosub MET_RESERVE From SUBACLA         : # Nom des méthodes d'init et contrôle
For I=1 To dim([L]TBMET)
 ACLA.ACLAV.TBMET(I) = [L]TBMET(I)
Next
Gosub SET_VARRET                             : # Nom des variables retour fonction méthode (suivant le type)
ACLA.ACLAV.VARRET(1) = "ARET_VALUE"                   : ACLA.ACLAV.LENRET(1)=""
ACLA.ACLAV.VARRET(2) = ACLA.ACLAV.VARRET(1)       : ACLA.ACLAV.LENRET(2)="(250)"
ACLA.ACLAV.VARRET(3) = ACLA.ACLAV.VARRET(1)       : ACLA.ACLAV.LENRET(3)=""
ACLA.ACLAV.VARRET(4) = ACLA.ACLAV.VARRET(1)       : ACLA.ACLAV.LENRET(4)=""
ACLA.ACLAV.VARRET(5) = ACLA.ACLAV.VARRET(1)       : ACLA.ACLAV.LENRET(5)=""
ACLA.ACLAV.VARRET(6) = ACLA.ACLAV.VARRET(1)       : ACLA.ACLAV.LENRET(6)=""
ACLA.ACLAV.NOMSTC    = func SUBACLA.PREFIX_CLA+[L]CODCLA

ACLA.ACLAV.TRTCRUD         = func APREFIXTRT.GET_PREFIX_CLA_CRUD+[L]CODCLA
ACLA.ACLAV.TRTCRUDREAD   = func ACLAVALCRUD.GET_PREFIX_CLA_READ+[L]CODCLA
ACLA.ACLAV.TRTCRUDUPD    = func ACLAVALCRUD.GET_PREFIX_CLA_UPD+[L]CODCLA
ACLA.ACLAV.TRTCRUDDEL    = func ACLAVALCRUD.GET_PREFIX_CLA_DEL+[L]CODCLA
ACLA.ACLAV.TRTCRUDCRE    = func ACLAVALCRUD.GET_PREFIX_CLA_CRE+[L]CODCLA
End

