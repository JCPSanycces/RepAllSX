#<AdxTL>@(#)1.0.0.0 $Revision$
Gosub TEST From ACLAVAL
End

#---------------------------------------------------------------------------------------------------#
## Class load
#---------------------------------------------------------------------------------------------------#
Subprog LOAD_CLASSE(TEST,DOSSIER,CODCLA,TYPGEN,NAMCOL,ACLA,AERR)
Value Integer TEST
Value Char DOSSIER , CODCLA
Value Integer TYPGEN
Value Char NAMCOL
Variable  Instance  ACLA  Using C_ACLA
Variable  Instance  AERR(1..) Using C_AERROR
Gosub OPEN_FILE
Gosub DEFVAR
Gosub LOAD
Gosub CLOSE_FILE
End

#---------------------------------------------------------------------------------------------------#
## Class load
#---------------------------------------------------------------------------------------------------#
Subprog LOAD_CLASSE_COL(TEST,DOSSIER,CODCLA,ACLA,AERR)
Value Integer TEST
Value Char DOSSIER , CODCLA
Variable  Instance  ACLA  Using C_ACLA
Variable  Instance  AERR(1..) Using C_AERROR
Local File =DOSSIER+".ACLASSE"    [ACLA]
Gosub DEFVAR
Read [ACLA]ACLA0 = [L]CODCLA
If fstat
 Close Local File [ACLA]
Else
 If [F:ACLA]FLGACTX=2
  Close Local File [ACLA]
  Call LOAD_CLASSE(TEST,DOSSIER,CODCLA,0,"",ACLA,AERR)
 Else
  Close Local File [ACLA]
  Call LOAD_CLASSE(TEST,DOSSIER,CODCLA,1,"",ACLA,AERR)
  For I=1 To ACLA.NBRGRP
   If ACLA.CRECLAGRP(I)=2
    ACLA.ACLACOL(I)  = NewInstance C_ACLA AllocGroup ACLA
    Call INI_ACLAVARDEF(CODCLA+"_"+ACLA.CODGRP(I),DOSSIER,ACLA.ACLACOL(I) ,AERR)
    Call LOAD_CLASSE(TEST,DOSSIER,CODCLA+"_"+ACLA.CODGRP(I),2,ACLA.CODGRP(I),ACLA.ACLACOL(I),AERR)
   Endif
  Next
 Endif
Endif
End

#---------------------------------------------------------------------------------------------------#
## Class reading in memory
#---------------------------------------------------------------------------------------------------#
# TYPGEN
# 0 --> normal
# 1 --> classe principale, on mets les pointeurs vers les classes collections
# 2 --> On créer les classe collections

$LOAD
If TEST : Call ECR_TRACE("####################################################",0) From GESECRAN : Endif
If TEST : Call ECR_TRACE("- Load class :"-[L]CODCLA,0) From GESECRAN : Endif
If TEST : Call ECR_TRACE("####################################################",0) From GESECRAN : Endif

Call CHARGE_ACLA([L]CODCLA,[L]TYPGEN,ACLA,AERR)   : # Classe
If maxtab(AERR)>0  : Return : Endif

# By default TEST = 0 : TEST = 1  for a trace
ACLA.TEST = [L]TEST

Call CHARGE_ACLAF([L]CODCLA,[L]TYPGEN,[L]NAMCOL,ACLA,AERR)  : # Properties
If maxtab(AERR)>0  : Return : Endif

If TYPGEN =2 : Return Endif

Gosub CHARGE_ACLAO  : # Operations
If maxtab(AERR)>0  : Return : Endif

Gosub CHARGE_ACLAM  : # Methodes
If maxtab(AERR)>0  : Return : Endif

Gosub CHARGE_ACLAT  : # Standard methods
If maxtab(AERR)>0  : Return : Endif

Gosub CHARGE_ACLAK  : # Tables (CRUD)
If maxtab(AERR)>0  : Return : Endif

Call CHARGE_ACLE([L]CODCLA,ACLA,AERR)
If maxtab(AERR)>0  : Return : Endif

Call CHARGE_GRP([L]CODCLA,ACLA,AERR)
If maxtab(AERR)>0  : Return : Endif

Return


