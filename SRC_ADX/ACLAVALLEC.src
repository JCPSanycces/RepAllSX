#---------------------------------------------------------------------------------------------------#
## Load CHARGE_GRP : repere le nom de la classe et du pointeur
#---------------------------------------------------------------------------------------------------#
Subprog CHARGE_GRP(ACLASSE,ACLA,AERR)
Value Char ACLASSE
Variable  Instance  ACLA  Using OBJECT
Variable  Instance  AERR Using C_AERROR

Local Integer G,I,J

For G=1 To ACLA.NBRGRP
 For I=1 To maxtab(ACLA.ACLAF)
  If ACLA.ACLAF(I).LNKCLA<>"" & ACLA.ACLAF(I).FLDGRP=ACLA.CODGRP(G)
   ACLA.PROUID(G) = ACLA.ACLAF(I).FLDCLA
   ACLA.TYPUID(G) = 2
   ACLA.CLAUID(G) = ACLA.ACLAF(I).LNKCLA
  Endif
 Next
Next
End

#---------------------------------------------------------------------------------------------------#
## GETNAMCLA : Retourne le nom de la classe
#---------------------------------------------------------------------------------------------------#

Funprog GETNAMCLA(TYPGEN,ACLASSE)
Value Integer TYPGEN
Value Char ACLASSE
Local Char NAMCLA(100)
NAMCLA = ACLASSE
If TYPGEN=2 & instr(1,NAMCLA,"_")>0
 NAMCLA = left$(NAMCLA,instr(1,NAMCLA,"_")-1)
Endif
End NAMCLA

#---------------------------------------------------------------------------------------------------#
## CHARGE_ACLA : Chargement de la classe ACLASSE
#---------------------------------------------------------------------------------------------------#
Subprog CHARGE_ACLA(ACLASSE,TYPGEN,ACLA,AERR)
Value Char ACLASSE
Value Integer TYPGEN
Variable  Instance  ACLA  Using C_ACLA
Variable  Instance  AERR Using C_AERROR

Local Integer J,K,N

Read [F:ACLA]ACLA0 = func GETNAMCLA(TYPGEN,[L]ACLASSE)
If !fstat

 SetInstance ACLA With [F:ACLA]

 ACLA.CODCLA = [L]ACLASSE
 ACLA.CODECLA = ACLA.CODCLA
 If instr(1,[L]ACLASSE,"_")>0
  ACLA.CODESUBCLA = right$( [L]ACLASSE,instr(1, [L]ACLASSE,"_")+1)
 Endif
 ACLA.INTITCLA = func ASYRFNC.TEXTE(ACLA.INTCLA)

 Sorta [F:ACLA]NBRTRT [F:ACLA]RANTRT,[F:ACLA]TYPTRT,[F:ACLA]CODTRT,[F:ACLA]ACTTRT Order By [F:ACLA]RANTRT(indice)
 Raz ACLA.NBRTRT
 For I=0 To [F:ACLA]NBRTRT-1
  If [F:ACLA]ACTTRT(I)<>""
    Read [ACV]CODACT = [F:ACLA]ACTTRT(I)
  Endif
  If (!fstat & [F:ACV]FLACT=2) or [F:ACLA]ACTTRT(I)=""
   ACLA.NBRTRT +=1
   ACLA.ACLATRT((ACLA.NBRTRT)) = NewInstance C_ACLATRT AllocGroup ACLA
   ACLA.ACLATRT((ACLA.NBRTRT)).RANTRT = [F:ACLA]RANTRT(I)
   ACLA.ACLATRT((ACLA.NBRTRT)).TYPTRT = [F:ACLA]TYPTRT(I)
   ACLA.ACLATRT((ACLA.NBRTRT)).CODTRT= [F:ACLA]CODTRT(I)
   ACLA.ACLATRT((ACLA.NBRTRT)).ACTTRT = [F:ACLA]ACTTRT(I)
  Endif
 Next

 If TYPGEN = 2
  Raz ACLA.NBRGRP,ACLA.CODGRP,ACLA.MINGRP,ACLA.MAXGRP,ACLA.INTGRP,ACLA.INTITGRP
  End
 Endif

 # Option
 Raz ACLA.NBROPT
 For [ACLAO] Where CODCLA=[F:ACLA]CODCLA
  ACLA.NBROPT += 1
  ACLA.ACLAOPT(ACLA.NBROPT ) = NewInstance C_ACLAOPTION AllocGroup ACLA
  ACLA.ACLAOPT(ACLA.NBROPT ).OPTCOD = [F:ACLAO]OPTCOD
  ACLA.ACLAOPT(ACLA.NBROPT ).OPTCND = [F:ACLAO]OPTCND
  ACLA.ACLAOPT(ACLA.NBROPT ).OPTERR = [F:ACLAO]OPTERR
  ACLA.ACLAOPT(ACLA.NBROPT ).OPTLIB = [F:ACLAO]OPTLIB
  ACLA.ACLAOPT(ACLA.NBROPT ).OPTACT = [F:ACLAO]OPTACT
 Next

 # Group
 Local Integer NB_FLDCLA_COL,K
 Raz ACLA.NBRGRP,ACLA.CODGRP,ACLA.MINGRP,ACLA.MAXGRP,ACLA.INTGRP,ACLA.INTITGRP,ACLA.NBRPROGRP
 For [ACLAC] Where CODCLA=[F:ACLA]CODCLA
  Raz NB_FLDCLA_COL,K
  # Check si des proprité valides dans la collection
  For [ACLAF4]ACLAF0 Where CODCLA=[F:ACLA]CODCLA & FLDGRP=[F:ACLAC]CODCOL
   K= 1
   If [F:ACLAF4]ACTFLD<>""
    Read [ACV]CODACT = [F:ACLAF4]ACTFLD
    If fstat or [F:ACV]FLACT<>2
     K = -1
    Endif
   Endif
   If K>0 : NB_FLDCLA_COL += 1 : Endif
  Next
  Read [ACV]CODACT = [F:ACLAC]ACTCOL
  If (([F:ACLAC]ACTCOL="") or (!fstat & [F:ACV]FLACT=2) or (!fstat & [F:ACV]TYP=2)) and NB_FLDCLA_COL>0
   ACLA.NBRGRP +=1
   ACLA.CODGRP(ACLA.NBRGRP)   = [F:ACLAC]CODCOL
   ACLA.MINGRP(ACLA.NBRGRP)   = [F:ACLAC]MINCOL
   ACLA.PROGRP(ACLA.NBRGRP)   = [F:ACLAC]PROCOL
   ACLA.INTGRP(ACLA.NBRGRP)   = [F:ACLAC]INTCOL
   ACLA.INTITGRP(ACLA.NBRGRP) = func ASYRFNC.TEXTE(ACLA.INTGRP(ACLA.NBRGRP))
   ACLA.ACTGRP(ACLA.NBRGRP)   =  [F:ACLAC]ACTCOL
   If ACLA.MINGRP(ACLA.NBRGRP)<>3
    ACLA.FLGTRIGRP(ACLA.NBRGRP)   = [F:ACLAC]FLGTRICOL
    ACLA.FLGAPDGRP(ACLA.NBRGRP)   = [F:ACLAC]FLGAPDCOL
    ACLA.FLGINSGRP(ACLA.NBRGRP)   = [F:ACLAC]FLGINSCOL
    ACLA.FLGSUPGRP(ACLA.NBRGRP)   = [F:ACLAC]FLGSUPCOL
   Else
    ACLA.FLGTRIGRP(ACLA.NBRGRP)   =  [V]CST_ANO
    ACLA.FLGAPDGRP(ACLA.NBRGRP)   = [V]CST_ANO
    ACLA.FLGINSGRP(ACLA.NBRGRP)   =  [V]CST_ANO
    ACLA.FLGSUPGRP(ACLA.NBRGRP)   =  [V]CST_ANO
   Endif
   If ACLA.ACTGRP(ACLA.NBRGRP)<>""
    If [F:ACV]DIMFIL>0 & [F:ACV]DIME>0 & [F:ACV]DIMMAX>0
     ACLA.MAXGRP(ACLA.NBRGRP) = min(max([F:ACV]DIMFIL,[F:ACV]DIME),[F:ACV]DIMMAX)
    Elsif ([F:ACV]DIMFIL<>0 | [F:ACV]DIME<>0)
     ACLA.MAXGRP(ACLA.NBRGRP) = max([F:ACV]DIMFIL,[F:ACV]DIME)
    Else
     ACLA.MAXGRP(ACLA.NBRGRP)   = -1
    Endif
   Else
    ACLA.MAXGRP(ACLA.NBRGRP)   = [F:ACLAC]MAXCOL
   Endif
   ACLA.CRECLAGRP(ACLA.NBRGRP) = func CRECLAGRPCOL(ACLA.CODCLA,ACLA.CODGRP(ACLA.NBRGRP))
   For [ACLAF4]ACLAF0 Where CODCLA=ACLA.CODCLA & FLDGRP=ACLA.CODGRP(ACLA.NBRGRP)
    K=1
    If [F:ACLAF4]ACTFLD<>""
     Read [ACV]CODACT = [F:ACLAF4]ACTFLD
     If fstat or [F:ACV]FLACT<>2 : K = -1 : Endif
    Endif
    If K>=0
     If [F:ACLAF4]LNKCLA<>""
      For [ACLAF3]ACLAF0 Where CODCLA=[F:ACLAF4]LNKCLA & FLDGRP=""
       K=1
       If [F:ACLAF3]ACTFLD<>""
       Read [ACV]CODACT = [F:ACLAF3]ACTFLD
        If fstat or [F:ACV]FLACT<>2 : K = -1 : Endif
       Endif
       If K>=0
        ACLA.NBRPROGRP(ACLA.NBRGRP) += 1
       Endif
      Next
     Else
      ACLA.NBRPROGRP(ACLA.NBRGRP) += 1
     Endif
    Endif
   Next
  Endif
 Next

# Raz ACLA.NBRGRP
# For [ACLAC] Where CODCLA=[F:ACLA]CODCLA
#  Read [ACV]CODACT = [F:ACLAC]ACTCOL
#  If ([F:ACLAC]ACTCOL="") or (!fstat & [F:ACV]FLACT=2) or (!fstat & [F:ACV]TYP=2)
#   ACLA.NBRGRP +=1
#   ACLA.GRP(ACLA.NBRGRP) = NewInstance C_ACLAGROUP ALLOCGROUP ACLA
#   ACLA.GRP(ACLA.NBRGRP).CODGRP  = [F:ACLAC]CODCOL
#   ACLA.GRP(ACLA.NBRGRP).MINGRP  = [F:ACLAC]MINCOL
#   ACLA.GRP(ACLA.NBRGRP).INTGRP  = [F:ACLAC]INTCOL
#   ACLA.GRP(ACLA.NBRGRP).INTITGRP= func ASYRFNC.TEXTE(ACLA.GRP(ACLA.NBRGRP).INTGRP)
#   ACLA.GRP(ACLA.NBRGRP).ACTGRP  =  [F:ACLAC]ACTCOL
#   If ACLA.GRP(ACLA.NBRGRP).ACTGRP(ACLA.NBRGRP)<>""
#    Read [ACV]CODACT = ACLA.ACTGRP(ACLA.NBRGRP)
#    If !fstat and ([F:ACV]TYP=2) & [F:ACV]DIME<>0
#     ACLA.GRP(ACLA.NBRGRP).MAXGRP = [F:ACV]DIME
#    Else
#     ACLA.GRP(ACLA.NBRGRP).MAXGRP  = -1
#    Endif
#   Else
#    ACLA.GRP(ACLA.NBRGRP).MAXGRP  = [F:ACLAC]MAXCOL
#   Endif
#  Endif
# Next
Endif

End

##############################################################
## Dimension d'une propriete                                                                         ##
##############################################################
Subprog REPTAB(CODACT,REPET)
Value    Char    CODACT
Variable Integer REPET
If CODACT<>""
 Read [ACV]CODACT = CODACT
 If !fstat
  If [F:ACV]DIMFIL>0 & [F:ACV]DIME>0 & [F:ACV]DIMMAX>0
   REPET = min(max([F:ACV]DIMFIL,[F:ACV]DIME),[F:ACV]DIMMAX)
  Elsif ([F:ACV]DIMFIL<>0 | [F:ACV]DIME<>0)
   REPET = max([F:ACV]DIMFIL,[F:ACV]DIME)
  Endif
  If [F:ACV]FLACT<>2
   REPET = -max(REPET,1) : End
  Endif
 Else
  Call ECR_TRACE(CODACT-":"-mess(22,150,1),1) From GESECRAN : # Code activité inexistant
 Endif
Endif
REPET = max(REPET,1)
End REPET

#---------------------------------------------------------------------------------------------------#
## Load Field
#---------------------------------------------------------------------------------------------------#
Subprog CHARGE_ACLAF(ACLASSE,TYPGEN,NAMCOL,ACLA,AERR)
Value Char ACLASSE
Value Integer TYPGEN
Value Char NAMCOL
Variable  Instance  ACLA  Using C_ACLA
Variable  Instance  AERR Using C_AERROR

Local Integer   ACLAF_NBR,ACLAF_NBP,RULPAR_NBR,I,K
Local Char CRITERIA(250)

If TYPGEN=0 or TYPGEN = 1
 CRITERIA = "1=1"
Else
 CRITERIA = 'FLDGRP="'+NAMCOL+'" & LNKCLA= ""'
Endif

If ACLA.TEST : Call ECR_TRACE("- Load properties of class :"-ACLA.CODCLA,0) From GESECRAN : Endif

For [ACLAF]ACLAF2 Where CODCLA=func GETNAMCLA(TYPGEN,[L]ACLASSE) & evalue(CRITERIA)
 K=1
 If [F:ACLAF]FLDGRP<>""
  I = find([F:ACLAF]FLDGRP,ACLA.CODGRP(1..20))
  If I>0
   K  = ACLA.MAXGRP(I)
  Endif
 Endif
 If [F:ACLAF]ACTFLD<>""
  Read [ACV]CODACT = [F:ACLAF]ACTFLD
  If fstat or [F:ACV]FLACT<>2
   K = -1
  Endif
 Endif
 If K<>-1 & [F:ACLAF]FLDGRP<>""
  If [L]TYPGEN=1
   J = find(ACLA.CODCLA+"_"+[F:ACLAF]FLDGRP,ACLA.ACLAF(1..ACLAF_NBR).LNKCLA )
   If J
       # Issue X3-47119 - 2018-10-08 by CCC : The collection is searchable if at least one of its field is searchable
       ACLA.ACLAF(J).FLDSEARCH=max(ACLA.ACLAF(J).FLDSEARCH,[F:ACLAF]FLDSEARCH)
       K=-1
   Endif
  Endif
 Endif
 If K>=0
  ACLAF_NBR += 1
  ACLA.ACLAF(ACLAF_NBR) = NewInstance C_ACLAFLD AllocGroup ACLA
  SetInstance ACLA.ACLAF(ACLAF_NBR) With [F:ACLAF]
  If ACLA.ACLAF(ACLAF_NBR).FLDGRP<>""
   If [L]TYPGEN=1 & I>0 & ACLA.CRECLAGRP(I) =2
    ACLA.ACLAF(ACLAF_NBR).FLDCLA = ACLA.ACLAF(ACLAF_NBR).FLDGRP
    ACLA.ACLAF(ACLAF_NBR).LNKCLA = ACLA.CODCLA+"_"+ACLA.ACLAF(ACLAF_NBR).FLDGRP
    ACLA.ACLAF(ACLAF_NBR).CODTYP = ""
    ACLA.ACLAF(ACLAF_NBR).LONG = 0
    ACLA.ACLAF(ACLAF_NBR).NOLIB = 0
   Elsif [L]TYPGEN=2
    ACLA.ACLAF(ACLAF_NBR).FLDGRP = ""
   Endif
  Elsif [L]TYPGEN=2
   ACLA.ACLAF(ACLAF_NBR).FLDGRP = ""
  Endif
  If ACLA.FLGBUFFER<>2
   Case ACLA.TYPCLA
    When 4
     ACLA.ACLAF(ACLAF_NBR).FLGACCGET = 1
    When 3
     ACLA.ACLAF(ACLAF_NBR).FLGACCSET = 1
    When 1,2,5
      ACLA.ACLAF(ACLAF_NBR).FLGACCSET = 2
      ACLA.ACLAF(ACLAF_NBR).FLGACCCTL = 2
      ACLA.ACLAF(ACLAF_NBR).FLGACCINI = 2
   Endcase
  Endif
  If ACLA.ACLAF(ACLAF_NBR).LNKCLA<>""
   Read [ACLA]ACLA0 = ACLA.ACLAF(ACLAF_NBR).LNKCLA
   If !fstat
    ACLA.ACLAF(ACLAF_NBR).LNKCLATYP = [F:ACLA]TYPCLA
   Endif
  Endif
  ACLA.ACLAF(ACLAF_NBR).ACLA = ACLA
  ACLA.ACLAF(ACLAF_NBR).INTITFLD = func ASYRFNC.TEXTE([F:ACLAF]INTFLD)
  Call CHARGE_FLD(AERR,ACLA.ACLAF(ACLAF_NBR),ACLA.ACLAF(ACLAF_NBR).CODTYP,K,func GETNAMCLA(TYPGEN,[L]ACLASSE),ACLA.ACLAF(ACLAF_NBR).NOLIB,ACLA.ACLAF(ACLAF_NBR).LONG,ACLA.TEST)
  Call CHARGE_PARFLD(AERR,ACLA.ACLAF(ACLAF_NBR))
  Call CHARGE_RULES(AERR,ACLA.ACLAF(ACLAF_NBR),ACLA.TYPCLA)
  If find(ACLA.ACLAF(ACLAF_NBR).CODTYP,"AX1","AX2","AXX","AX3","ATX")>0 : ACLA.ACLAF(ACLAF_NBR).FLGACCGET = 2 : Endif
  If ACLA.ACLAF(ACLAF_NBR).ATY<>null & find(ACLA.ACLAF(ACLAF_NBR).ATY.TYPTYP,9,10)>0 : ACLA.ACLAF(ACLAF_NBR).FLGACCGET = 2 : Endif

  If ACLA.TEST & 0 :
   Call ECR_TRACE(" --- "
&    -ACLA.ACLAF(ACLAF_NBR).FLDCLA
&    +space$(max(0,20-len(ACLA.ACLAF(ACLAF_NBR).FLDCLA)))+ACLA.ACLAF(ACLAF_NBR).CODTYP
&    +space$(max(0,12-len(ACLA.ACLAF(ACLAF_NBR).CODTYP)))+ACLA.ACLAF(ACLAF_NBR).LNKCLA
&    +space$(max(0,12-len(ACLA.ACLAF(ACLAF_NBR).FLDGRP)))+ACLA.ACLAF(ACLAF_NBR).FLDGRP
&    +space$(max(0,20-len(ACLA.ACLAF(ACLAF_NBR).LNKCLA)))+ACLA.ACLAF(ACLAF_NBR).INTITFLD
&    ,0) From GESECRAN
  Endif
 Endif
Next ACLAF
End


#---------------------------------------------------------------------------------------------------#
## Load operations
#---------------------------------------------------------------------------------------------------#
$CHARGE_ACLAO
If ACLA.TEST : Call ECR_TRACE("- Load operations :",0) From GESECRAN : Endif
Raz ACLAO_NBR
For [F:ACLAM]ACLAM1 Where CODCLA=[L]CODCLA & [F:ACLAM]FLGOPE=2
 If func AFNC.ACTIV([F:ACLAM]ACTMET)
  ACLAO_NBR += 1
  ACLA.ACLAO(ACLAO_NBR) = NewInstance C_ACLAMET AllocGroup ACLA
  SetInstance ACLA.ACLAO(ACLAO_NBR) With  [F:ACLAM]
  ACLA.ACLAO(ACLAO_NBR).INTITMET = func ASYRFNC.TEXTE([F:ACLAM]INTMET)
  If ACLA.TEST : Call ECR_TRACE(" --- Operation :"-ACLA.ACLAO(ACLAO_NBR).CODMET+space$(max(0,20-len(ACLA.ACLAO(ACLAO_NBR).CODMET)))+ACLA.ACLAO(ACLAO_NBR).INTITMET,0) From GESECRAN : Endif
  Raz ACLAO_NBP
  For [ACLPD]ACLPD1  Where CODCLA=[L]CODCLA & CODE=[F:ACLAM]CODMET & TYPKEY=2
   ACLAO_NBP += 1
   ACLA.ACLAO(ACLAO_NBR).ACLMP(ACLAO_NBP) = NewInstance C_ACLAPARDEF AllocGroup ACLA
   SetInstance ACLA.ACLAO(ACLAO_NBR).ACLMP(ACLAO_NBP) With  [F:ACLPD]
  Next
  For [ACLPD]ACLPD1  Where CODCLA=[L]CODCLA & CODE=[F:ACLAM]CODMET & TYPKEY=1
   ACLAO_NBP += 1
   ACLA.ACLAO(ACLAO_NBR).ACLMP(ACLAO_NBP) = NewInstance C_ACLAPARDEF AllocGroup ACLA
   SetInstance ACLA.ACLAO(ACLAO_NBR).ACLMP(ACLAO_NBP) With  [F:ACLPD]
  Next
 Endif
Next
Return

#---------------------------------------------------------------------------------------------------#
## Load Methods
#---------------------------------------------------------------------------------------------------#
$CHARGE_ACLAM
If ACLA.TEST : Call ECR_TRACE("- Load methods :",0) From GESECRAN : Endif
Raz ACLAM_NBR
For [F:ACLAM]ACLAM1 Where CODCLA=[L]CODCLA  & [F:ACLAM]FLGOPE<>2
 If func AFNC.ACTIV([F:ACLAM]ACTMET)
  ACLAM_NBR += 1
  ACLA.ACLAM(ACLAM_NBR) = NewInstance C_ACLAMET AllocGroup ACLA
  SetInstance ACLA.ACLAM(ACLAM_NBR) With  [F:ACLAM]
  ACLA.ACLAM(ACLAM_NBR).INTITMET = func ASYRFNC.TEXTE([F:ACLAM]INTMET)
  If ACLA.TEST : Call ECR_TRACE(" --- Method :"-ACLA.ACLAM(ACLAM_NBR).CODMET+space$(max(0,20-len(ACLA.ACLAM(ACLAM_NBR).CODMET)))+ACLA.ACLAM(ACLAM_NBR).INTITMET,0) From GESECRAN : Endif
  Raz ACLAM_NBP
  For [ACLPD]ACLPD1  Where CODCLA=[L]CODCLA & CODE=[F:ACLAM]CODMET
   ACLAM_NBP += 1
   ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP) = NewInstance  C_ACLAPARDEF AllocGroup ACLA
   SetInstance ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP) With  [ACLPD]
  Next
 Endif
Next
Return

#---------------------------------------------------------------------------------------------------#
## Load standart methods
#---------------------------------------------------------------------------------------------------#
$CHARGE_ACLAT
If ACLA.TEST : Call ECR_TRACE("- Load standart methods :",0) From GESECRAN : Endif
Raz ACLAT_NBR
For [F:ACLAT]ACLAT1 Where CODCLA=[L]CODCLA & ENAMETSTD=2
 If func AFNC.ACTIV([F:ACLAT]ACTMETSTD)
  ACLAT_NBR += 1
  ACLA.ACLAT(ACLAT_NBR) = NewInstance C_ACLAMETSTD AllocGroup ACLA
  SetInstance ACLA.ACLAT(ACLAT_NBR) With  [F:ACLAT]
  If ACLA.TEST : Call ECR_TRACE(" --- Method :"-ACLA.ACLAT(ACLAT_NBR).CODMETSTD,0) From GESECRAN : Endif : #
  ACLA.ACLAT(ACLAT_NBR).ACLA = ACLA
  Case ACLA.ACLAT(ACLAT_NBR).CODMETSTD
   When "C"
    ACLA.ACLAT(ACLAT_NBR).NAMMETSTD = [V]CST_APRGAINSERT
   When "R" :
    ACLA.ACLAT(ACLAT_NBR).NAMMETSTD = [V]CST_APRGAREAD
   When "U" :
    ACLA.ACLAT(ACLAT_NBR).NAMMETSTD = [V]CST_APRGAUPDATE
   When "D" :
    ACLA.ACLAT(ACLAT_NBR).NAMMETSTD = [V]CST_APRGADELETE
 Endcase
 Endif
Next
Return

#---------------------------------------------------------------------------------------------------#
## Load mapping
#---------------------------------------------------------------------------------------------------#
$CHARGE_ACLAK  : # Tables
If !find(ACLA.TYPCLA,2,5) : Return : Endif

If ACLA.TYPCLA=5
 Raz ACLAK_NBR
 ACLAK_NBR += 1
 ACLA.ACLAK(ACLAK_NBR) = NewInstance C_ACLALNK AllocGroup ACLA
 ACLA.ACLAK(ACLAK_NBR).ACLA = ACLA
 ACLA.ACLAK(ACLAK_NBR).CLALNK  = ACLA.CODCLA
 ACLA.ACLAK(ACLAK_NBR).ACLALNK = NewInstance C_ACLA AllocGroup ACLA
 Call CHARGE_ACLAF(ACLA.ACLAK(ACLAK_NBR).CLALNK,0,"",ACLA.ACLAK(ACLAK_NBR).ACLALNK,AERR)  : # Champs
 Call DEF_PTRLNK(ACLA.ACLAK(ACLAK_NBR), ACLA.CODCLA)
 Return
Endif

If ACLA.TEST  : Call ECR_TRACE("- Load class persistent :",0) From GESECRAN : Endif

Raz ACLAK_NBR

# main table
ACLAK_NBR += 1
ACLA.ACLAK(ACLAK_NBR) = NewInstance C_ACLALNK AllocGroup ACLA
ACLA.ACLAK(ACLAK_NBR).ACLA = ACLA
ACLA.ACLAK(ACLAK_NBR).CLALNK  = ACLA.CODCLA

If ACLA.TEST : Call ECR_TRACE(" --- Load table :"-ACLA.TABREF,0) From GESECRAN : Endif
ACLA.ACLAK(ACLAK_NBR).ACLALNK = NewInstance C_ACLA AllocGroup ACLA
Call CHARGE_ACLA(ACLA.ACLAK(ACLAK_NBR).CLALNK,0,ACLA.ACLAK(ACLAK_NBR).ACLALNK,AERR)   : # Classe
Call CHARGE_ACLAF(ACLA.ACLAK(ACLAK_NBR).CLALNK,0,"",ACLA.ACLAK(ACLAK_NBR).ACLALNK,AERR)  : # Champs
ACLA.ACLAK(ACLAK_NBR).TABLNK  = ACLA.TABREF
ACLA.ACLAK(ACLAK_NBR).CLELNK  = ACLA.INDREF
ACLA.ACLAK(ACLAK_NBR).FLGR = ACLA.FLGRREF
ACLA.ACLAK(ACLAK_NBR).FLGC = ACLA.FLGCREF
ACLA.ACLAK(ACLAK_NBR).FLGU = ACLA.FLGUREF
ACLA.ACLAK(ACLAK_NBR).FLGD = ACLA.FLGDREF
ACLA.ACLAK(ACLAK_NBR).FLGV = 1
Call DEF_PTRLNK(ACLA.ACLAK(ACLAK_NBR), ACLA.CODCLA)
Read [F:ATB]CODFIC  = ACLA.ACLAK(ACLAK_NBR).TABLNK
If fstat : Return : Endif
ACLA.ACLAK(ACLAK_NBR).ABRLNK  = [F:ATB]ABRFIC
ACLA.ACLAK(ACLAK_NBR).TYPTAB  = [F:ATB]TYPFIC
Read [ATI]CODIND = ACLA.ACLAK(ACLAK_NBR).TABLNK;ACLA.ACLAK(ACLAK_NBR).CLELNK
If !fstat & [F:ATI]HOMONYM<2
 ACLA.ACLAK(ACLAK_NBR).EXPLNK = [F:ATI]DESCRIPT
Else
 Return
Endif
Call  EXPR_INDEX_TRI(ACLA.ACLAK(ACLAK_NBR),[L]DOSSIER) : # Expression fields / index fields
For I=1 To ACLA.ACLAK(1).NBRIND
 J=find(ACLA.ACLAK(1).INDEX(I),ACLA.ACLAF(1..maxtab(ACLA.ACLAF)).FLDCLA)
 If J
  ACLA.ACLAK(1).CODTYPIND(I) = ACLA.ACLAF(J).CODTYP
  ACLA.ACLAK(1).TYPIND(I)  = ACLA.ACLAF(J).ATY.TYPTYP
  ACLA.ACLAK(1).LNGIND(I) = ACLA.ACLAF(J).LON
 Endif
Next

# Linked tables
For [F:ACLAK]ACLAK1 Where CODCLA=[L]CODCLA
 If [F:ACLAK]ACVLNK<>""
  Read [ACV]CODACT = [F:ACLAK]ACVLNK
 Endif
 Raz TABCLA,TABPTR,NBCLA,ISACTX
 Call DECODE_PRO([F:ACLAK]REFLNK,0,"PTR",[L]DOSSIER,"","",ACLA.CODCLA,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
 If NBCLA>=1 & ([F:ACLAK]ACVLNK="" or(!fstat & [F:ACV]FLACT=2))
  If ACLA.TEST : Call ECR_TRACE(" --- PTR :"-[F:ACLAK]REFLNK-"--"-TABCLA(NBCLA)-"--"-TABPTR(NBCLA)-"--"-num$(NBCLA)-OBJ,0) From GESECRAN : Endif
  ACLAK_NBR += 1
  ACLA.ACLAK(ACLAK_NBR) = NewInstance C_ACLALNK AllocGroup ACLA
  SetInstance ACLA.ACLAK(ACLAK_NBR) With  [F:ACLAK]
  ACLA.ACLAK(ACLAK_NBR).ACLA = ACLA
  If ACLA.ACLAK(ACLAK_NBR).CLALNK<>""
   ACLA.ACLAK(ACLAK_NBR).ACLALNK = NewInstance C_ACLA AllocGroup ACLA
   Call CHARGE_ACLA(ACLA.ACLAK(ACLAK_NBR).CLALNK,0,ACLA.ACLAK(ACLAK_NBR).ACLALNK,AERR)   : # Classe
   Call CHARGE_ACLAF(ACLA.ACLAK(ACLAK_NBR).CLALNK,0,"",ACLA.ACLAK(ACLAK_NBR).ACLALNK,AERR)  : # Champs
   Call CHARGE_ACLE(ACLA.ACLAK(ACLAK_NBR).CLALNK,ACLA.ACLAK(ACLAK_NBR).ACLALNK,AERR) : # Clés
   If NBCLA=1
    Read [ACLAF]ACLAF0 = ACLA.CODCLA;TABPTR(NBCLA)
   Else
    Read [ACLAF]ACLAF0 = TABCLA(NBCLA-1);TABPTR(NBCLA)
   Endif
   If !fstat
    If [ACLAF]FLDGRP=""
     ACLA.ACLAK(ACLAK_NBR).DIMCLALNK = 2
    Else
     ACLA.ACLAK(ACLAK_NBR).DIMCLALNK = 1
    Endif
   Endif
  Endif
  If ACLA.ACLAK(ACLAK_NBR).ABRLNK=""
   Read [F:ATB]CODFIC = ACLA.ACLAK(ACLAK_NBR).TABLNK
   ACLA.ACLAK(ACLAK_NBR).ABRLNK = [F:ATB]ABRFIC
  Endif
  If ACLA.ACLAK(ACLAK_NBR).ABRORI=""
   Read [F:ATB]CODFIC = ACLA.ACLAK(ACLAK_NBR).TABORI
   ACLA.ACLAK(ACLAK_NBR).ABRORI = [F:ATB]ABRFIC
  Endif
  If ACLA.TEST
   Call ECR_TRACE(" --- Load table :"-ACLA.ACLAK(ACLAK_NBR).TABORI-mess(ACLA.ACLAK(ACLAK_NBR).TYPLNK,2916,1)-ACLA.ACLAK(ACLAK_NBR).TABLNK+"   ("+ACLA.ACLAK(ACLAK_NBR).EXPLNK+")",0) From GESECRAN
  Endif
  Call DEF_PTRLNK(ACLA.ACLAK(ACLAK_NBR), ACLA.CODCLA)
  If ACLA.ACLAK(ACLAK_NBR).CLESORT="" : ACLA.ACLAK(ACLAK_NBR).CLESORT = ACLA.ACLAK(ACLAK_NBR).CLELNK : Endif


  Call  EXPR_INDEX_TRI(ACLA.ACLAK(ACLAK_NBR),[L]DOSSIER) : # champs expression /  champs index
  For I=1 To ACLA.ACLAK(ACLAK_NBR).NBRIND
   J=find(ACLA.ACLAK(ACLAK_NBR).INDEX(I),ACLA.ACLAK(ACLAK_NBR).ACLALNK.ACLAF(1..maxtab(ACLA.ACLAK(ACLAK_NBR).ACLALNK.ACLAF)).FLDCLA)
   If J
    ACLA.ACLAK(ACLAK_NBR).CODTYPIND(I) = ACLA.ACLAK(ACLAK_NBR).ACLALNK.ACLAF(J).CODTYP
    ACLA.ACLAK(ACLAK_NBR).TYPIND(I)    =  ACLA.ACLAK(ACLAK_NBR).ACLALNK.ACLAF(J).ATY.TYPTYP
    ACLA.ACLAK(ACLAK_NBR).LNGIND(I) = ACLA.ACLAK(ACLAK_NBR).ACLALNK.ACLAF(J).LON
   Endif
  Next
  For I=1 To ACLA.ACLAK(ACLAK_NBR).NBRSORT
   J=find(ACLA.ACLAK(ACLAK_NBR).FLDSORT(I),ACLA.ACLAK(ACLAK_NBR).ACLALNK.ACLAF(1..maxtab(ACLA.ACLAK(ACLAK_NBR).ACLALNK.ACLAF)).FLDCLA)
   If J
    ACLA.ACLAK(ACLAK_NBR).CODTYPSORT(I) = ACLA.ACLAK(ACLAK_NBR).ACLALNK.ACLAF(J).CODTYP
    ACLA.ACLAK(ACLAK_NBR).TYPSORT(I)    = ACLA.ACLAK(ACLAK_NBR).ACLALNK.ACLAF(J).ATY.TYPTYP
    ACLA.ACLAK(ACLAK_NBR).LNGSORT(I) = ACLA.ACLAK(ACLAK_NBR).ACLALNK.ACLAF(J).LON
   Endif
  Next
  For I=1 To 16
   If ACLA.ACLAK(ACLAK_NBR).INDEX(I)<>""
    Read [F:ACLAKP]ACLAKP0 = ACLA.CODCLA;ACLA.ACLAK(ACLAK_NBR).REFLNK;ACLA.ACLAK(ACLAK_NBR).INDEX(I)
    If !fstat
     ACLA.ACLAK(ACLAK_NBR).PROMAP(I) = [F:ACLAKP]PROMAP
     ACLA.ACLAK(ACLAK_NBR).VALDEFMAP(I) = [F:ACLAKP]VALDEFMAP
    Endif
   Endif
  Next
 Endif
Next

Gosub DEF_PTRFOR

If dim(ACLA.ACLAV.TRTMAP)>0
 For I=2 To maxtab(ACLA.ACLAK)
  For J=1 To 16
   If ACLA.ACLAK(I).PROMAP(J) <>""
    ACLA.ACLAV.TRTMAP  = func ACLAVALLEC.GETPREFIXTRTMAP+ACLA.CODECLA
    Break
   Endif
  Next
 Next
 If ACLA.ACLAV.TRTMAP =""
  For I=1 To ACLA.NBRTRT
   If ACLA.ACLATRT(I).CODTRT=func ACLAVALLEC.GETPREFIXTRTMAP+ACLA.CODECLA
    ACLA.ACLATRT(I).CODTRT =""
   Endif
  Next
 Endif
Endif

Return

$DEF_PTRFOR
For K=1 To maxtab(ACLA.ACLAK)
 For I=1 To maxtab(ACLA.ACLAK)
  If ACLA.ACLAK(K).STRCURFAT=ACLA.ACLAK(I).STRCUR
   For J=1 To maxtab(ACLA.ACLAK(I).ACLALNK.ACLAF)
    If ACLA.ACLAK(I).ACLALNK.ACLAF(J).LNKCLA=ACLA.ACLAK(K).CLALNK & ACLA.ACLAK(I).ACLALNK.ACLAF(J).FLDCLA=ACLA.ACLAK(K).PTRLNK
     If ACLA.ACLAK(I).ACLALNK.ACLAF(J).FLDGRP<>"" & ACLA.ACLAK(I).ACLALNK.ACLAF(J).LNKCLA<>""
      ACLA.ACLAK(K).STRMAXFOR     = "maxtab("+ACLA.ACLAK(K).STRMAXFOR+")"
      ACLA.ACLAK(K).STRCURDIM      = 0
     Else
      ACLA.ACLAK(K).STRMAXFOR     = "dim("+ACLA.ACLAK(K).STRMAXFOR+")"
      ACLA.ACLAK(K).STRCURDIM     = ACLA.MAXGRP(find(ACLA.ACLAK(I).ACLALNK.ACLAF(J).FLDGRP,ACLA.ACLAK(I).ACLALNK.CODGRP(1..20)))
     Endif
     Break
    Endif
   Next
  Endif
 Next
Next
Return

#-------------------------------------------------------------------------------#
# Initialisation de tous les pointeurs de liens : parent,...
#-------------------------------------------------------------------------------#
Subprog DEF_PTRLNK(ACLAK,STRCUR)
Variable Instance ACLAK Using  C_ACLALNK
Value Char STRCUR

Local Char    CHAINE(250),TABPTR(GLONAVB)(1..20)
Local Integer WNIV,I,NBPTR

CHAINE = ACLAK.REFLNK

I=instr(1,CHAINE,".")
While I>0
 NBPTR += 1
 TABPTR(NBPTR) = left$(CHAINE,I-1)
 CHAINE = right$(CHAINE,I+1)
 I=instr(1,CHAINE,".")
Wend
If CHAINE=""
 ACLAK.STRCUR      = [L]STRCUR
 ACLAK.STRCURFAT = ""
 ACLAK.STRFAT      = ""
Else
 NBPTR += 1
 TABPTR(NBPTR) = CHAINE
 ACLAK.PTRLNK = CHAINE


 ACLAK.STRCUR      = [L]STRCUR
 ACLAK.STRCURFAT = ACLAK.STRCUR
 ACLAK.STRFAT      = ACLAK.STRCUR
 ACLAK.STRMAXFOR = ACLAK.STRCUR
 For I=1 To NBPTR
  J = I+1
  ACLAK.STRCUR      += "."+TABPTR(I)+"(A_N"+num$(J)+")"
  ACLAK.STRMAXFOR += "."+TABPTR(I)
  ACLAK.STRFAT      += "."+TABPTR(I)
  If I<=NBPTR-1
   #ACLAK.STRFAT      += "."+TABPTR(I)+'("+num$(A_N'+num$(J)+')+")'
   ACLAK.STRMAXFOR +="(A_N"+num$(J)+")"
   ACLAK.STRCURFAT += "."+TABPTR(I)+"(A_N"+num$(J)+")"
   ACLAK.STRFAT      += "(A_N"+num$(J)+")"
  Endif
 Next
Endif

End

#-------------------------------------------------------------------------------#
# Subroutine dehulling index and expression of links
#-------------------------------------------------------------------------------#
Subprog EXPR_INDEX_TRI(ACLALNK,DOSSIER)
Variable  Instance  ACLALNK Using C_ACLALNK
Value Char DOSSIER

Local Integer NBCLE,I
Local Char    CLE(GLONAVB)(1..),CHAINE(250)

If filinfo(filpath("FIL","AVIEWIND","fde",DOSSIER),0)<0
 If DOSSIER="" | DOSSIER=nomap
  Local File ATABIND [ATI]
 Else
  Local File =DOSSIER+".ATABIND" [ATI]
 Endif
Else
 If DOSSIER="" | DOSSIER=nomap
  Local File AVIEWIND [ATI]
 Else
  Local File =DOSSIER+".AVIEWIND" [ATI]
 Endif
Endif

Read [F:ATI]CODIND = ACLALNK.TABLNK;ACLALNK.CLELNK
If !fstat
 Call SETCLE([L]NBCLE,[L]CLE,[F:ATI]DESCRIPT) From LNKSUB
 For I=1 To [L]NBCLE
  ACLALNK.NBRIND+=1
  ACLALNK.INDEX(ACLALNK.NBRIND) = [L]CLE(I)
 Next
Endif

Read [F:ATI]CODIND = ACLALNK.TABLNK;ACLALNK.CLESORT
If !fstat
 Call SETCLE([L]NBCLE,[L]CLE,[F:ATI]DESCRIPT) From LNKSUB
 For I=1 To [L]NBCLE
  ACLALNK.NBRSORT+=1
  ACLALNK.FLDSORT(ACLALNK.NBRSORT) = [L]CLE(I)
 Next
Endif

If ACLALNK.EXPLNK="" : End : Endif

CHAINE = ACLALNK.EXPLNK
I = instr(0,CHAINE,";")
While I
 ACLALNK.NBREXP += 1
 ACLALNK.EXPR(ACLALNK.NBREXP) = func ACLASUBCRUD.RECHCHP(left$(CHAINE,I-1),ACLALNK.TABORI,ACLALNK.ABRORI,[L]DOSSIER)
 CHAINE       = right$(CHAINE,I+1)
 I = instr(0,CHAINE,";")
Wend
ACLALNK.NBREXP += 1
ACLALNK.EXPR(ACLALNK.NBREXP) = func ACLASUBCRUD.RECHCHP(CHAINE,ACLALNK.TABORI,ACLALNK.ABRORI,[L]DOSSIER)

Close Local File [ATI]
End

#-------------------------------------------------------------------------------#
# load field and parameters
#-------------------------------------------------------------------------------#
Subprog CHARGE_FLD(AERR,ACLAF,CODTYP,DIME,CODCLA,NOLIB,LONG,TEST)
Variable  Instance  AERR Using C_AERROR
Variable  Instance  ACLAF  Using C_ACLAFLD
Value Char CODTYP
Value Integer DIME
Value Char CODCLA
Value Integer NOLIB
Value Decimal LONG
Value Integer TEST

Local Integer NBR_RUL
Local Integer NBR_RULPAR
Local Integer NBR_NBA,NBR_NBP,NBCLE
ACLAF.DIME = [L]DIME

If [L]CODTYP<>""
 If [F:ATY]CODTYP<>[L]CODTYP
   Read [ATY]CODTYP=[L]CODTYP
   If fstat : Raz [F:ATY] : Endif
 Endif
 If [F:ATY]CODTYP=""
  AERR = NewInstance C_AERROR AllocGroup null
  AERR.STA = [V]CST_AERROR
  AERR.MES = "("+[L]CODCLA+"~"+ACLAF.FLDCLA+") : "+[L]CODTYP-":"-mess(82,133,1)
  AERR.NUM = 9101
  If [L]TEST>0 : Call ECR_TRACE(AERR.MES,1) From GESECRAN  : Endif
  End
 Else
  ACLAF.ATY = NewInstance C_ACLATYPE AllocGroup ACLAF
  SetInstance ACLAF.ATY With [F:ATY]
  If find([F:ATY]TYPTYP,7) & [F:ATY]LNGTYP<>0
   ACLAF.LON = [F:ATY]LNGTYP
  Else
   If find([F:ATY]TYPTYP,9,10) >0
    ACLAF.LON = 1 : # blob et clob
   Else
    ACLAF.LON =  [L]LONG
   Endif
  Endif
  #LONG sera utilisé pour calculer précision et scale
  If ACLAF.LONG=0 & [F:ATY]LNGTYP<>0
    ACLAF.LONG=[F:ATY]LNGTYP
  Endif
  #
  If [F:ATYP]COD<>[F:ATY]TYPPROSYR
   Read [ATYP]ATYP0 = [F:ATY]TYPPROSYR
   If fstat : Raz [F:ATYP] : Endif
  Endif
  If [F:ATYP]COD<>""
   ACLAF.ATY.PROTYP = [F:ATYP]PROTYP
   ACLAF.ATY.PROSTDFLG  = [F:ATYP]STDFLG
   ACLAF.ATY.PROPREFLG  = [F:ATYP]PREFLG
   ACLAF.ATY.PROLISFLG  = [F:ATYP]LISFLG
   If find([F:ATY]TYPTYP,9,10) & [F:ATYP]LISFLG<>2
    NBR_NBA = maxtab(ACLAF.ATYPPAR)
    NBR_NBA += 1
    ACLAF.ATYPPAR(NBR_NBA) = NewInstance C_ACLAPARFLD AllocGroup ACLAF
    ACLAF.ATYPPAR(NBR_NBA).CODPAR = [F:ATY]TYPPROSYR
    ACLAF.ATYPPAR(NBR_NBA).VALEUR=[F:ATYP]PROTYP
   Endif
  Endif
  If [F:ATY]TYPTYP=1
   If [F:ATY]NOLIB<>0
    ACLAF.MENU = [F:ATY]NOLIB
   Else
    ACLAF.MENU = [L]NOLIB
   Endif
  Endif
  If ACLAF.ATY.CODCLA<>"" : # cas TABLAN & ACLAF.ATY.CODCLA<>[L]CODCLA
   Read [ACLA]ACLA0 = ACLAF.ATY.CODCLA
   If !fstat & [F:ACLA]TYPCLA=2
    Read [ATB]CODFIC = [F:ACLA]TABREF
    If !fstat
     Read [ATI]CODIND = [F:ACLA]TABREF;[F:ACLA]INDREF
     If !fstat
      ACLAF.ATY.FICLIEN =  [F:ACLA]TABREF : # todo crée une propriété pour cel
      ACLAF.ATY.INDLIEN = [F:ACLA]INDREF
      ACLAF.ATY.ABRLIEN = [F:ATB]ABRFIC
      Call SETCLE(NBCLE ,ACLAF.ATY.CHPLIEN,[F:ATI]DESCRIPT) From LNKSUB
      For I=1 To maxtab(ACLAF.ATY.CHPLIEN)
       Read [ATZ]CODZONE = [F:ATB]CODFIC;ACLAF.ATY.CHPLIEN(I)
       If !fstat
        ACLAF.ATY.CODTYPLIEN(I) = [F:ATZ]CODTYP
        ACLAF.ATY.TYPINTLIEN(I) =  [F:ATY]TYPTYP
       Endif
      Next
      If dim([F:ATB]INTITC)>0 & [F:ATB]INTITC<>""
       ACLAF.ACHPSHO = NewInstance C_ACLALNKCHP AllocGroup ACLAF
       Call CHARGE_ALNKCHP(AERR,ACLAF,ACLAF.ACHPSHO,[F:ACLA]TABREF,[F:ATB]INTITC)
      Endif
      If dim([F:ATB]INTIT)>0 & [F:ATB]INTIT<>""
        ACLAF.ACHPLNG = NewInstance C_ACLALNKCHP AllocGroup ACLAF
       Call CHARGE_ALNKCHP(AERR,ACLAF,ACLAF.ACHPLNG,[F:ACLA]TABREF,[F:ATB]INTIT)
      Endif
      If dim([F:ATB]SYMBOL)>0 & [F:ATB]SYMBOL<>""
        ACLAF.ACHPSYM = NewInstance C_ACLALNKCHP AllocGroup ACLAF
       Call CHARGE_ALNKCHP(AERR,ACLAF,ACLAF.ACHPSYM,[F:ACLA]TABREF,[F:ATB]SYMBOL)
      Endif
      #91088/5
      If dim([F:ATB]COLFMT)>0 & [F:ATB]COLFMT<>""
        ACLAF.ACHPCOLFMT = NewInstance C_ACLALNKCHP AllocGroup ACLAF
       Call CHARGE_ALNKCHP(AERR,ACLAF,ACLAF.ACHPCOLFMT,[F:ACLA]TABREF,[F:ATB]COLFMT)
      Endif
      If dim([F:ATB]COLLNG)>0 & [F:ATB]COLLNG<>""
        ACLAF.ACHPCOLLNG = NewInstance C_ACLALNKCHP AllocGroup ACLAF
       Call CHARGE_ALNKCHP(AERR,ACLAF,ACLAF.ACHPCOLLNG,[F:ACLA]TABREF,[F:ATB]COLLNG)
      Endif
      If dim([F:ATB]COLDEC)>0 & [F:ATB]COLDEC<>""
        ACLAF.ACHPCOLDEC = NewInstance C_ACLALNKCHP AllocGroup ACLAF
       Call CHARGE_ALNKCHP(AERR,ACLAF,ACLAF.ACHPCOLDEC,[F:ACLA]TABREF,[F:ATB]COLDEC)
      Endif
      #
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
#LONG sera utilisé pour calculer précision et scale
If ACLAF.LONG=0 & [L]LONG<>0
  ACLAF.LONG=[L]LONG
Endif
End

Subprog CHARGE_RULES(AERR,ACLAF,TYPCLA)
Variable Instance AERR Using C_AERROR
Variable  Instance  ACLAF  Using C_ACLAFLD
Value Integer TYPCLA

If ACLAF.ATY=null : End : Endif

Local Integer NBCLE,I,ACTRLREF
Local Char    CLE(GLONAVB)(1..),CHAINE(250)
Local Integer NBR_RUL,NBR_RULPAR,I,J
Local Char    WVALEUR(250)

If ACLAF.ACLA<>null and ACLAF.ACLA.CODCLA=ACLAF.ATY.CODCLA and find(ACLAF.ACLA.TYPCLA,2,5)>0
 If ACLAF.ACLA.TYPCLA=2 : # persistant
  Read [F:ATI]CODIND = ACLAF.ACLA.TABREF;ACLAF.ACLA.INDREF
  CHAINE = [F:ATI]DESCRIPT
 Elsif ACLAF.ACLA.TYPCLA=5 : # Interface
  CHAINE = vireblc(ACLAF.ACLA.KEYINT,4)
 Endif
 Call SETCLE([L]NBCLE,[L]CLE,CHAINE) From LNKSUB
 If NBCLE>0 and find(ACLAF.FLDCLA,CLE)>0 : [L]ACTRLREF=0 : Else : [L]ACTRLREF=1 : Endif
Else
 [L]ACTRLREF = 1
Endif

For [F:ATYR]ATYR0 Where CODTYP=ACLAF.ATY.CODTYP
 If [F:ATYR]ACTRUL<>""
  Read [ACV]CODACT =  [F:ATYR]ACTRUL
 Endif
 If ((!fstat & [F:ACV]FLACT=2) or  [F:ATYR]ACTRUL="" ) &  [F:ATYR]ENARUL=2
  If ([F:ATYR]PRGRUL=[V]CST_ANAMCTLREF & [L]ACTRLREF=1) or [F:ATYR]PRGRUL<>[V]CST_ANAMCTLREF
   NBR_RUL += 1
   ACLAF.ATY.ARUL(NBR_RUL) = NewInstance C_ACLATYPRUL AllocGroup ACLAF
   SetInstance ACLAF.ATY.ARUL(NBR_RUL)  With [F:ATYR]
   Raz NBR_RULPAR
   For [ATYRP]ATYRP1 Where  CODTYP= ACLAF.ATY.CODTYP & TYPRUL= ACLAF.ATY.ARUL(NBR_RUL).TYPRUL & TRTRUL=ACLAF.ATY.ARUL(NBR_RUL).TRTRUL & PRGRUL=ACLAF.ATY.ARUL(NBR_RUL).PRGRUL
    NBR_RULPAR +=1
    ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR) = NewInstance C_ACLATYPRULP AllocGroup ACLAF
    SetInstance ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR) With [F:ATYRP]
    Case [L]TYPCLA
     When -1       : Read [ASWP]ASWP0 =   ACLAF.CODCLA;1;1;ACLAF.FLDCLA;"";1;[F:ATYRP]PARCOD : [L]WVALEUR=[F:ASWP]VALEUR
     When Default : Read [ACLFP]ACLFP0 = ACLAF.CODCLA;1;1;ACLAF.FLDCLA;[F:ATYRP]PARCOD  : [L]WVALEUR=[F:ACLFP]VALEUR
    Endcase
    If !fstat
     # cas particulier AFILTEE
     If [F:ATYRP]PARCOD="AFILTER" & [L]WVALEUR="" :  [L]WVALEUR='""' : Endif
     ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).PARVAL = [L]WVALEUR
     ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).VALEUR = [L]WVALEUR
     If instr(1,[L]WVALEUR,"=")>0
      I = instr(1,[L]WVALEUR,"(")
      J = instr(1,[L]WVALEUR,")")
      If I & J
       ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).VALEUR = mid$([L]WVALEUR,I+1,J-I-1)
      Endif
     Endif
    Else
     ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).PARVAL = '""'
     ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).VALEUR = '""'
     Case [F:ATYRP]PARCOD
      When "AINSTANCE"
       ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).PARVAL = 'this'
       ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).VALEUR = 'this'
      When "APRONAME"
       ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).PARVAL = '"'+ACLAF.FLDCLA+'"'
       ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).VALEUR = '"'+ACLAF.FLDCLA+'"'
      When "AVALCNT"
       ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).PARVAL = "[L]_CNT"
       ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).VALEUR = "[L]_CNT"
      When "AEXIST"
       ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).PARVAL = "[L]_EXIT"
       ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).VALEUR = "[L]_EXI"
      When "AVALUE"
       ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).PARVAL = "this."+ACLAF.FLDCLA
       ACLAF.ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).VALEUR = "this."+ACLAF.FLDCLA
     Endcase
    Endif
   Next
  Endif
 Endif
Next
End

#-------------------------------------------------------------------------------#
# load parameters of field
#-------------------------------------------------------------------------------#
Subprog CHARGE_PARFLD(AERR,ACLAF)
Variable  Instance  AERR Using C_AERROR
Variable  Instance  ACLAF  Using C_ACLAFLD
Local Integer NBR_NBP,NBR_NBK,NBR_NBA
NBR_NBP = maxtab(ACLAF.ATBPAR)
NBR_NBK = maxtab(ACLAF.ATBKEY)
NBR_NBA = maxtab(ACLAF.ATYPPAR)
For [ACLFP]ACLFP1 Where CODCLA=ACLAF.CODCLA & FLDCLA=ACLAF.FLDCLA
 If [F:ACLFP]TYPPAR = 1 & [F:ACLFP]TYPKEY = 2
  NBR_NBK += 1
  ACLAF.ATBKEY(NBR_NBK) = NewInstance C_ACLAPARFLD AllocGroup ACLAF
  SetInstance ACLAF.ATBKEY(NBR_NBK) With  [F:ACLFP]
  ACLAF.ATBKEY(NBR_NBK).ACLAF = ACLAF
 Elsif [F:ACLFP]TYPPAR = 1
  NBR_NBP += 1
  ACLAF.ATBPAR(NBR_NBP) = NewInstance C_ACLAPARFLD AllocGroup ACLAF
  SetInstance ACLAF.ATBPAR(NBR_NBP) With  [F:ACLFP]
  ACLAF.ATBPAR(NBR_NBP).ACLAF = ACLAF
 Elsif [F:ACLFP]TYPPAR = 2
  Read [ATYP]ATYP0=[F:ACLFP]VALEUR
  If !fstat
   NBR_NBA += 1
   ACLAF.ATYPPAR(NBR_NBA) = NewInstance C_ACLAPARFLD AllocGroup ACLAF
   SetInstance ACLAF.ATYPPAR(NBR_NBA) With  [F:ACLFP]
   ACLAF.ATYPPAR(NBR_NBA).ACLAF = ACLAF
   ACLAF.ATYPPAR(NBR_NBA).CODPAR = ACLAF.ATYPPAR(NBR_NBA).VALEUR
   ACLAF.ATYPPAR(NBR_NBA).VALEUR=[F:ATYP]PROTYP
  Endif
 Endif
Next
End

#-------------------------------------------------------------------------------#
# parameters of links
#-------------------------------------------------------------------------------#
Subprog CHARGE_ALNKCHP(AERR,ACLAF,ALNKCHP,TABLE,CHAMP)
Variable  Instance  AERR Using C_AERROR
Variable  Instance  ACLAF Using C_ACLAFLD
Variable  Instance  ALNKCHP Using C_ACLALNKCHP
Value Char TABLE
Value Char CHAMP
Read [ATZ]CODZONE = TABLE;CHAMP
If !fstat
 ALNKCHP.CODTYP = [F:ATZ]CODTYP
 Case [F:ATZ]CODTYP
  When "ATX" :  ALNKCHP.CHPATX = [F:ATZ]CODZONE
  When "AXX","AX1","AX2","AX3"
   For PAR="TABLE1","ZONE","CLECUR1","CLECUR2"
    Read [AMP]CODPAR=2;[F:ATB]CODFIC;[F:ATZ]CODZONE;PAR
    If !fstat
     If !instr(1,[F:AMP]VALPAR,"[F")
      Case PAR
       When "TABLE1"  : ALNKCHP.CHPTAB  = [F:AMP]VALPAR
       When "ZONE"    : ALNKCHP.CHPZON  = [F:AMP]VALPAR
       When "CLECUR1" : ALNKCHP.CHPCUR1 = [F:AMP]VALPAR
       When "CLECUR2" : ALNKCHP.CHPCUR2 = [F:AMP]VALPAR
      Endcase
     Else
      AERR = NewInstance C_AERROR AllocGroup null
      AERR.STA = [V]CST_AERROR
      AERR.MES = "("+ACLAF.CODCLA+"~"+ACLAF.FLDCLA+") , "+mess(67,103,1)-" : "-[F:AMP]VALPAR
      AERR.NUM = 9101
     Endif
    Endif
   Next PAR
  When Default :  ALNKCHP.CHPCHAR = [F:ATZ]CODZONE
 Endcase
Endif
End

#-------------------------------------------------------------------------------#
# Chargement des clés de la classe persitante ou interface
#-------------------------------------------------------------------------------#
Subprog CHARGE_ACLE(ACLASSE,ACLA,AERR)
Value Char ACLASSE
Variable  Instance  ACLA  Using C_ACLA
Variable  Instance  AERR Using C_AERROR

Local Integer NBCLE,I
Local Char    CLE(GLONAVB)(1..),CHAINE(250)

If find(ACLA.TYPCLA,2,5)>0
 If ACLA.TYPCLA=2 : # persistant
  Read [F:ATI]CODIND = ACLA.TABREF;ACLA.INDREF
  CHAINE = [F:ATI]DESCRIPT
 Elsif ACLA.TYPCLA=5 : # Interface
  CHAINE = vireblc(ACLA.KEYINT,4)
 Endif
 Call SETCLE([L]NBCLE,[L]CLE,CHAINE) From LNKSUB
 For I=1 To [L]NBCLE
  ACLA.NBCLEREF += 1
  ACLA.ACLAI((ACLA.NBCLEREF)) = NewInstance C_ACLAINDREF AllocGroup ACLA
  ACLA.ACLAI((ACLA.NBCLEREF)).CLEREF = [L]CLE(I)
 Next
Endif
For I=1 To ACLA.NBCLEREF
 J = find(ACLA.ACLAI(I).CLEREF,ACLA.ACLAF(1..maxtab(ACLA.ACLAF)).FLDCLA)
 If J and ACLA.ACLAF(J).ATY<>null : # 118558
  ACLA.ACLAI(I).CLEINTREF =  ACLA.ACLAF(J).ATY.TYPTYP
 Endif
Next
End

#-------------------------------------------------------------------------------#
# parameters of links
#-------------------------------------------------------------------------------#
Funprog CRECLAGRPCOL(CODCLA,CODGRP)
Value Char CODCLA
Value Char CODGRP
Local Integer J,K,N,CRECLAGRP
J =0 : K=0 : N=0
Read [ACLA]ACLA0 = [L]CODCLA
If fstat : End -1 : Endif
For [ACLAF4]ACLAF0 Where CODCLA=[L]CODCLA & FLDGRP=[L]CODGRP
 N+=1
 If [ACLAF4]LNKCLA<>""
  J+=1
 Else
  K +=1
 Endif
Next
[L]CRECLAGRP = 1
If N
 [L]CRECLAGRP  = 2
Endif
If J & !K
 [L]CRECLAGRP  = 1
Endif
End [L]CRECLAGRP

#---------------------------------------------------------------------------------------------------#
#---------------------------------------------------------------------------------------------------#

Subprog CREATE_1_1(DOSSIER,WCODCLA,WCODREP,TBCLA,TBPRO,TBPTR,TBCOL,STA)
Value Char DOSSIER
Value Char    WCODCLA
Value Char    WCODREP
Variable Char TBCLA()(1..)
Variable Char TBPRO()(1..)
Variable Char TBPTR()(1..)
Variable Char TBCOL()(1..)
Variable Integer STA

Local Integer OK ,I,TYPAGE,CPT

Local Char WTBCLA(GLONACLA)(1..)
Local Char WTBPRO(GLONAVA)(1..)
Local Char WTBCOL(GLONAVA)(1..)
Local Char WTBPTR(250)(1..)

If DOSSIER=nomap
 Local File ACLASSE [ACLA]
 Local File ASHW    [ASW]
 Local File ACLAFLD [ACLAF]
 Local File ACTIV   [ACV]
 Local File ACLACOL [ACLAC]
Else
 Local File =DOSSIER+".ACLASSE" [ACLA]
 Local File =DOSSIER+".ASHW"    [ASW]
 Local File =DOSSIER+".ACLAFLD" [ACLAF]
 Local File =DOSSIER+".ACTIV"   [ACV]
 Local File =DOSSIER+".ACLACOL" [ACLAC]
Endif


If WCODREP<>""
 Read [ASW]ASW0 = [L]WCODREP
 If fstat : End : Endif

 Read [ACLA]ACLA0=[F:ASW]CODCLA
 If fstat : End : Endif

 TBCLA(1) = [F:ASW]CODCLA
 TBPTR(1) = ""
 TBPRO(1) = [F:ASW]ABRCLA
 TBCOL(1) = ""
 CPT += 1
Else
 Read [ACLA]ACLA0=WCODCLA
 If fstat : End : Endif
Endif


For [ACLAF]ACLAF0 Where CODCLA=[F:ACLA]CODCLA & [F:ACLAF]LNKCLA<>""
 OK =0
 If [F:ACLAF]FLDGRP=""
  OK =1
 Else
  Read [F:ACLAC]ACLAC0 = [F:ACLAF]CODCLA;[F:ACLAF]FLDGRP
  If !fstat & [F:ACLAC]MAXCOL=1 & [F:ACLAC]MINCOL=2
   OK=1
  Endif
 Endif
 If  func AFNC.ACTIV([F:ACLAF]ACTFLD)>0 & OK>0
  Raz WTBCLA
  WTBCLA(1) = [F:ACLA]CODCLA
  WTBPTR(1) = ""
  If WCODREP<>""
   WTBPRO(1) = [F:ASW]ABRCLA
  Else
   WTBPRO(1) = ""
  Endif
  WTBCOL(1) = [F:ACLAF]FLDGRP
  #Call CHARGE_TBCLA11(nomap,[F:ACLAF]LNKCLA,WTBPRO(1),[F:ACLAF]FLDCLA,[F:ACLAF]FLDGRP,WTBCLA,WTBPTR,WTBPRO,WTBCOL,CPT,STA)
  #119343
  Call CHARGE_TBCLA11([L]DOSSIER,[F:ACLAF]LNKCLA,WTBPRO(1),[F:ACLAF]FLDCLA,[F:ACLAF]FLDGRP,WTBCLA,WTBPTR,WTBPRO,WTBCOL,CPT,STA)
  If STA<0 : Break  : Endif
  For I=2 To maxtab([L]WTBCLA)
   TBCLA(maxtab(TBCLA)+1) = WTBCLA(I)
   TBPTR(maxtab(TBCLA)) = WTBPTR(I)
   TBPRO(maxtab(TBCLA)) = WTBPRO(I)
   TBCOL(maxtab(TBCLA)) = WTBCOL(I)
  Next
 Endif
Next

Close Local File
End


#--------------------------------#
Subprog CHARGE_TBCLA11(APPLI,WCLA,WPTR,WPRO,WCOL,TBCLA,TBPTR,TBPRO,TBCOL,CPT,STA)
Value Char APPLI
Value Char WCLA
Value Char WPTR
Value Char WPRO
Value Char WCOL
Variable Char TBCLA()(1..)
Variable Char TBPTR()(1..)
Variable Char TBPRO()(1..)
Variable Char TBCOL()(1..)
Variable Integer CPT
Variable Integer STA

Local Integer OK

If CPT>20 or STA<0
 STA = -1
 End
Endif

If APPLI=nomap
 Local File ACLAFLD [ACLAF9]
 Local File ACTIV   [ACV]
 Local File ACLACOL [ACLAC]
Else
 Local File =APPLI+".ACLAFLD" [ACLAF9]
 Local File =APPLI+".ACTIV"   [ACV]
 Local File =APPLI+".ACLACOL" [ACLAC]
Endif

TBCLA(maxtab(TBCLA)+1) = WCLA
TBPTR(maxtab(TBCLA)) = WPTR
TBPRO(maxtab(TBCLA)) = WPRO
TBCOL(maxtab(TBCLA)) = WCOL
CPT += 1

For [ACLAF9]ACLAF0 Where [F:ACLAF9]CODCLA=WCLA & [F:ACLAF9]LNKCLA<>""
 OK =0
 If  [F:ACLAF9]FLDGRP=""
  OK =1
 Else
  Read [F:ACLAC]ACLAC0 = [F:ACLAF9]CODCLA;[F:ACLAF9]FLDGRP
  If !fstat & [F:ACLAC]MAXCOL=1 & [F:ACLAC]MINCOL=2
   OK =1
  Endif
 Endif
 If func AFNC.ACTIV([F:ACLAF9]ACTFLD)>0 & OK>0
  #Call CHARGE_TBCLA11(nomap,[F:ACLAF9]LNKCLA,string$(WPTR<>"",WPTR+".")+WPRO,[F:ACLAF9]FLDCLA,[F:ACLAF9]FLDGRP,TBCLA,TBPTR,TBPRO,TBCOL,CPT,STA)
  #119343
  Call CHARGE_TBCLA11(APPLI,[F:ACLAF9]LNKCLA,string$(WPTR<>"",WPTR+".")+WPRO,[F:ACLAF9]FLDCLA,[F:ACLAF9]FLDGRP,TBCLA,TBPTR,TBPRO,TBCOL,CPT,STA)
 Endif
Next


Close Local File
End

