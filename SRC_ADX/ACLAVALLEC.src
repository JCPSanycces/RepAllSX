$OPEN_FILE
# Tables for classes
Local File =DOSSIER+".ACLASSE"    [ACLA]
Local File =DOSSIER+".ACLASSE"    [ACLA2]
Local File =DOSSIER+".ACLAFLD"    [ACLAF]
Local File =DOSSIER+".ACLAFLD"    [ACLAF2]
Local File =DOSSIER+".ACLAFLD"    [ACLAF3]
Local File =DOSSIER+".ACLAFLD"    [ACLAF4]
Local File =DOSSIER+".ACLAMET"    [ACLAM]
Local File =DOSSIER+".ACLAPARFLD" [ACLFP]
Local File =DOSSIER+".ACLAPARDEF" [ACLPD]
Local File =DOSSIER+".ACLAMETSTD" [ACLAT]
Local File =DOSSIER+".ACLALNK"    [ACLAK]
Local File =DOSSIER+".ACLALNK"    [ACLAK2]
Local File =DOSSIER+".ACLAOPT"    [ACLAO]
Local File =DOSSIER+".ACLACOL"    [ACLAC]
Local File =DOSSIER+".ACLAMAP"    [ACLAKP]

# Other tables
Local File =DOSSIER+".ATYPE"      [ATY]
Local File =DOSSIER+".ATYPEPRO"  [ATYP]
Local File =DOSSIER+".ATYPERPAR"  [ATYRP]
Local File =DOSSIER+".ATYPELNK"  [ATYL]
Local File =DOSSIER+".ATYPELPAR"  [ATYLP]
Local File =DOSSIER+".ATYPERUL"   [ATYR]
Local File =DOSSIER+".AFONCTION"   [AFC]
Local File =DOSSIER+".AOBJET"     [AOB]
Local File =DOSSIER+".ACTPAR"     [ATR]
Local File =DOSSIER+".ACTIV"      [ACV]
Local File =DOSSIER+".ATEXTE"     [ATX]
Local File =DOSSIER+".ACTION"     [ACT]
Local File =DOSSIER+".ASUBPROG"   [ASU]
Local File =DOSSIER+".ASUBPROGD"  [ASP]
Local File =DOSSIER+".AMSKPAR"    [AMP]
Local File =DOSSIER+".ACONTEXT" [ACTX]
Local File =DOSSIER+".ACONTEXT" [ACTX2]
Local File =DOSSIER+".ATABLE"      [ATB1]

If filinfo(filpath("FIL","AVIEWTAB","fde",DOSSIER),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde",DOSSIER),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",DOSSIER),0)<0
 Local File =DOSSIER+".ATABLE" [ATB]
 Local File =DOSSIER+".ATABZON" [ATZ]
 Local File =DOSSIER+".ATABIND" [ATI]
Else
 Local File =DOSSIER+".AVIEWTAB" [ATB]
 Local File =DOSSIER+".AVIEWFLD" [ATZ]
 Local File =DOSSIER+".AVIEWIND" [ATI]
Endif



Return

$CLOSE_FILE
Close Local File
Return


