#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################
# UUMGTRTCPT04                                      Module  Accounting   #
#                    Migration Process                                   #
#                                                                        #
#     Flow for Accounting journal batch                                  #
#            GENTLOT/GENTLOTH/GENTLOTD/GENTLOTA                          #
#                                                                        #
##########################################################################
#                                                                        #
#  Optimized Index for Migration                                         #
#                                                                        #
#   GENTLOT  : CPY;LOT                                                   #
#                                                                        #
#  Index to keep for Migration                                           #
#                                                                        #
#   GENTLOT  : LOT                                                       #
#   GENTLOTH : LOT;ORNVCR                                                #
#   GENTLOTD : LOT;ORNVCR;LIG                                            #
#   GENTLOTA : LOT;ORNVCR;LIG;ANALIG                                     #
#                                                                        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTCPT04") From LECFIC
  Endif

  #Call RAZ_UUMGTRTCPT04(DOSSIER)
  Call MAJ_UUMGTRTCPT04(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

########################################################################
Subprog RAZ_UUMGTRTCPT04(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(1)<>2 : End : Endif


#----- File naming...  -----#
Local Char WNAMLOTM,WNAMLOHM,WNAMLODM,WNAMLOAM
Call MIGTABNAME (DOSSIER,"GENTLOT",WNAMLOTM,ERR) From TRTMIG  : If ERR : End : Endif
Call MIGTABNAME (DOSSIER,"GENTLOTH",WNAMLOHM,ERR) From TRTMIG : If ERR : End : Endif
Call MIGTABNAME (DOSSIER,"GENTLOTD",WNAMLODM,ERR) From TRTMIG : If ERR : End : Endif
Call MIGTABNAME (DOSSIER,"GENTLOTA",WNAMLOAM,ERR) From TRTMIG : If ERR : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMLOTM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL",WNAMLOHM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL",WNAMLODM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL",WNAMLOAM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif

#----- Deleting of records...  -----#
Call MIGTABRAZ (DOSSIER,"GENTLOT",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"GENTLOTH",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"GENTLOTD",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"GENTLOTA",ERR) From TRTMIG

Call MIGRAZKEY (DOSSIER,"UUMGTRTCPT04",ERR) From TRTMIG

End

########################################################################
Subprog MAJ_UUMGTRTCPT04(DOSSIER)
Value Char DOSSIER
Local Integer ERR

If [F:ADS]MODULE(1)<>2
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT04",3,ERR) From TRTMIG : End
Endif

#----- File naming...  -----#
Local Char WNAMLOTM,WNAMLOHM,WNAMLODM,WNAMLOAM
Call MIGTABNAME (DOSSIER,"GENTLOT",WNAMLOTM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT04",7,ERR) From TRTMIG : End : Endif
Call MIGTABNAME (DOSSIER,"GENTLOTH",WNAMLOHM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT04",7,ERR) From TRTMIG : End : Endif
Call MIGTABNAME (DOSSIER,"GENTLOTD",WNAMLODM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT04",7,ERR) From TRTMIG : End : Endif
Call MIGTABNAME (DOSSIER,"GENTLOTA",WNAMLOAM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT04",7,ERR) From TRTMIG : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMLOTM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT04",3,ERR) From TRTMIG : End
Endif
If filinfo(filpath("FIL",WNAMLOHM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT04",3,ERR) From TRTMIG : End
Endif
If filinfo(filpath("FIL",WNAMLODM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT04",3,ERR) From TRTMIG : End
Endif
If filinfo(filpath("FIL",WNAMLOAM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT04",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT04",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT04",7,ERR) From TRTMIG : End : Endif

Call ECR_TIME("UUMGTRTCPT04  journal batch Process : Update GENTLOT/GENTLOTH/GENTLOTD/GENTLOTA") From DOSSUB
Call ECR_TRACE("UUMGTRTCPT04 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Files Updating where we will insert -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"GENTLOT",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"GENTLOTH",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"GENTLOTD",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"GENTLOTA",ERR) From TRTMIG

#--------------- Opening of files  -----#
# X3 Files
If clalev([F:LOT]) = 0 :  Local File =DOSSIER+".GENTLOT"    [LOT]   : Endif     # Accounting Journal batche
If clalev([F:LOH]) = 0 :  Local File =DOSSIER+".GENTLOTH"   [LOH]   : Endif     # Head of accounting joutnal batche
If clalev([F:LOD]) = 0 :  Local File =DOSSIER+".GENTLOTD"   [LOD]   : Endif     # General accounting line batch
If clalev([F:LOA]) = 0 :  Local File =DOSSIER+".GENTLOTA"   [LOA]   : Endif     # Analytical accounting line batch

# X3 Renamed Files
If clalev([F:LOTM]) = 0 :  Local File =DOSSIER+"."+WNAMLOTM   [LOTM]   : Endif     # Accounting Journal batche
If clalev([F:LOHM]) = 0 :  Local File =DOSSIER+"."+WNAMLOHM   [LOHM]   : Endif     # Head of accounting joutnal batche
If clalev([F:LODM]) = 0 :  Local File =DOSSIER+"."+WNAMLODM   [LODM]   : Endif     # General accounting line batch
If clalev([F:LOAM]) = 0 :  Local File =DOSSIER+"."+WNAMLOAM   [LOAM]   : Endif     # Analytical accounting line batch

If clalev([F:ADW])  = 0 : Local File =DOSSIER+".ADOVAL"      [ADW]    : Endif
Local Char ZONE1(30), ZONE2(30)
Raz ZONE1, ZONE2
Read [ADW]ADW0 = "";"";"SCHSAISIE"
If !fstat
 ZONE1 = [F:ADW]VALEUR
Endif
Read [ADW]ADW0 = "";"";"SCHSTDC"
If !fstat
 ZONE2 = [F:ADW]VALEUR
Endif


# X3 Commun File
Gosub OPEN_FILE From UUMGTRTCPT00

#-----  Declaration of Variables
Gosub DECLARE From UUMGTRTCPT00

# Variables to manage Flush instruction
Local Char WTAB_LOT (100) (adxwrb)
Local Char WTAB_LOH (100) (adxwrb)
Local Char WTAB_LOD (100) (adxwrb)
Local Char WTAB_LOA (100) (adxwrb)
Local Shortint WCPT_LOT,WCPT_LOH,WCPT_LOD,WCPT_LOA

# Variables to Handle Loops Ruptures
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

#-----  Keys's reading  -----#
# Table's AMIGKEY reading to initialize ACLEx/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTCPT04",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

#-----  Link LOT/LOD
Link [LODM] With [LOTM]LOT0~=[F:LODM]LOT
&   As [LNK]
&   Order By Key CLE = [F:LOTM]CPY;[F:LOTM]LOT


# EP to add a criteria in the "where"
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTCPT04" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CPT04
Raz NB

If STOP = 1
 STOP = 2
 CRITERE = "[F:LOTM]CPY='"+TABMIGKEY(1)+"' & [F:LOTM]LOT>'"+TABMIGKEY(2)+"'"
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:LOTM]CPY>'"+TABMIGKEY(1)+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [LOT],[LOH],[LOD],[LOA]
GOK = 1

For [LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

  # By company - Initialization of Variables linked to the Account Core Model
 [L]COMPANY = [F:LOTM]CPY
 Gosub INI_CPY From UUMGTRTCPT00
 If !GOK : Break : Endif

 For [LNK]CLE(2)

  NBLUS+=1

  # EP to delete line
  If FILTRELIN
   FLUX="UUMGTRTCPT04" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
   If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  # To Update GENTLOT table - Journal batch
  Gosub MAJ30_LOT
  If GOK<1 : Break 2 : Endif

  # To Update GENTLOTH table - Header of journal batch
  Gosub MAJ30_LOH
  If GOK<1 : Break 2 : Endif

  For [LNK]CLE

   # To Update GENTLOTD table - General accounting line batch
   Gosub MAJ30_LOD
   If !GOK : Break 3 : Endif

  Next

  # To Update GENTLOTA table - Analytical accounting line batch
  Gosub MAJ30_LOA
  If !GOK : Break 2 : Endif

  NB+=1
  If NB>GMAXUPDTRS
   TABMIGKEY(1) = [F:LOTM]CPY
   TABMIGKEY(2) = [F:LOTM]LOT
   STOP=1
   Break 2
  Endif
 $SUITE_BOUCLE
 Next
Next

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT04",7,ERR) From TRTMIG
Else
 Flush [F:LOT]
 If fstat
  Call ECR_TRACE("File GENTLOT, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub LOT_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:LOH]
 If fstat
  Call ECR_TRACE("File GENTLOTH, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub LOH_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:LOD]
 If fstat
  Call ECR_TRACE("File GENTLOTD, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub LOD_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:LOA]
 If fstat
  Call ECR_TRACE("File GENTLOTA, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub LOA_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 # To Save values of key ACLEx/STOP in AMIGKEY table
 If STOP
  TABMIGKEY(3)=num$(STOP)
 Else
  Raz TABMIGKEY
 Endif
 Call MIGSTKKEY (DOSSIER,"UUMGTRTCPT04",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
 If ERR
  GOK=-1 : Goto FIN_BOUCLE
 Endif
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTCPT04",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_CPT04
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [LOT], [LOH], [LOD], [LOA]
Close Local File [LOTM], [LOHM], [LODM], [LOAM]
Close Local File [GCM], [LED], [CPY]

#----- To Re-Update files where we will insert
Call MIGTABEND (DOSSIER,"GENTLOT",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"GENTLOTH",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"GENTLOTD",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"GENTLOTA",ERR) From TRTMIG

$FIN
Call MIGTRTEND (DOSSIER,"UUMGTRTCPT04") From TRTMIG
Call ECR_TIME("UUMGTRTCPT04 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

$MAJ30_LOT
#--- Transclass
#Raz [LOT]  # expensive... must RAZ new V6 fields
[LOT] = [LOTM]

#--- New fields's assignation
[F:LOT]DACDIAGAS = ZONE1
If [F:LOT]DACDIAGAS=""
 [F:LOT]DACDIAGAS = ZONE2
Endif

Gosub WRI_LOT
Return


$MAJ30_LOH
#--- Reading of the Heads Lines
For [LOHM] Where LOT=[F:LODM]LOT

 #--- Transclass
 #Raz [LOH]  # expensive... must RAZ new V6 fields
 [LOH] = [LOHM]

 #--- New fields's assignation
 For IREF=1 To dim([F:GCM]LED)
  If [F:GCM]LED(IREF-1)<>""
   [F:LOH]CURMGT(IREF-1) = [F:GCM]CUR(IREF-1)
   [F:LOH]RATDIV(IREF-1) = 1
   If IREF<3
    [F:LOH]RATMLT(IREF-1) = [F:LOHM]RATCUR
   Else
    [F:LOH]RATMLT(IREF-1) = [F:LOHM]RATRPT
   Endif
   #[F:LOH]NBRCUR += 1  ??
  Else # useful to delete intruction RAZ
   [F:LOH]CURMGT(IREF-1) = ""
   [F:LOH]RATDIV(IREF-1) = 0
   [F:LOH]RATMLT(IREF-1) = 0
  Endif
 Next

 [F:LOH]TYPRAT = 1

 Gosub WRI_LOH
Next
Return


$MAJ30_LOD
#--- Transclass
#Raz [LOD]  # expensive... must RAZ new V6 fields
[F:LOD] = [F:LODM]

#--- New fields's assignation
# Renamed fields
[F:LOD]LIN    = [F:LODM]LIG

# Indice 0 - Main general ledger
[F:LOD]LEDTYP(0)  = [L]TYPGEN
[F:LOD]COA(0)     = [L]COAGEN
[F:LOD]SAC(0)     = [F:LODM]SAC
[F:LOD]ACC(0)     = [F:LODM]ACC

# Indice 1 -  IAS or Analytic
If TYPANA>0 & COAANA<>"" & [F:LODM]CNA<>"" & [L]TYPGEN<>[L]TYPANA
 If COAIAS<>""
  [F:LOD]LEDTYP(2)  = [L]TYPANA
  [F:LOD]COA(2)     = [L]COAANA
  [F:LOD]ACC(2)     = [F:LODM]CNA
 Else
  [F:LOD]LEDTYP([L]TYPANA-1)  = [L]TYPANA
  [F:LOD]COA([L]TYPANA-1)     = [L]COAANA
  [F:LOD]ACC([L]TYPANA-1)     = [F:LODM]CNA
 Endif
Else  # useful to delete intruction RAZ
 [F:LOD]LEDTYP(1)  = 0
 [F:LOD]COA(1)     = ""
 [F:LOD]ACC(1)     = ""

 [F:LOD]LEDTYP(2)  = 0
 [F:LOD]COA(2)     = ""
 [F:LOD]ACC(2)     = ""
Endif

Gosub WRI_LOD
Return

$MAJ30_LOA
#--- Reading of the Analytics Lines
For [LOAM]LOA0 Where LOT=[F:LODM]LOT & ORNVCR=[F:LODM]ORNVCR #& LIG=[F:LODM]LIG

 #--- Transclass
 #Raz [LOA]  # expensive... must RAZ new V6 fields
 [F:LOA] = [F:LOAM]

 #--- New fields's assignation
 # Renamed fields
 [F:LOA]LIN    = [F:LOAM]LIG
 [F:LOA]ANALIN = [F:LOAM]ANALIG

 # Indice 0 - Main general ledger
 [F:LOA]AMTCUR(0)  = [F:LOAM]AMTCUR
 [F:LOA]QTY(0)     = 0

 # Indice 1 -  IAS or Analytic
 If TYPANA>0 & COAANA<>"" & [F:LODM]CNA<>"" & [L]TYPGEN<>[L]TYPANA
  If COAIAS<>""
   [F:LOA]AMTCUR(2)  = [F:LOAM]AMTCUR
   [F:LOA]QTY(2)     = [F:LOAM]QTY
  Else
   [F:LOA]AMTCUR([L]TYPANA-1)  = [F:LOAM]AMTCUR
   [F:LOA]QTY([L]TYPANA-1)     = [F:LOAM]QTY
  Endif
 Else  # useful to delete intruction RAZ
  [F:LOA]AMTCUR(1)  = 0
  [F:LOA]QTY(1)     = 0
  [F:LOA]AMTCUR(2)  = 0
  [F:LOA]QTY(2)     = 0
 Endif


 For AXE=1 To dim([F:LOA]DIE)
  If COAIAS<>""
   If [L]AXEI(AXE)<>""
    [F:LOA]DIE(AXE-1) = [L]AXEI(AXE)
    [F:LOA]CCE(AXE-1) = ""
   Elsif [L]AXEA(AXE-2)<>""
    [F:LOA]DIE(AXE-3) = [L]AXEA(AXE-2)
    [F:LOA]CCE(AXE-3) = [F:LOAM]CCE(AXE-3)
   Else  # useful to delete intruction RAZ
    [F:LOA]DIE(AXE-1) = ""
    [F:LOA]CCE(AXE-1) = ""
   Endif
  Else
   If [L]AXEA(AXE)<>""
    [F:LOA]DIE(AXE-1) = [L]AXEA(AXE)
    [F:LOA]CCE(AXE-1) = [F:LOAM]CCE(AXE-1)
   Elsif [L]AXEI(AXE)<>""
    [F:LOA]DIE(AXE-1) = [L]AXEI(AXE)
    [F:LOA]CCE(AXE-1) = ""
   Else  # useful to delete intruction RAZ
    [F:LOA]DIE(AXE-1) = ""
    [F:LOA]CCE(AXE-1) = ""
   Endif
  Endif
 Next

 Gosub WRI_LOA
 If GOK<1 : Break : Endif
Next
Return

# Write Instruction
$WRI_LOT
# To Save reference
Gosub LOT_STK
WriteB [F:LOT]
If fstat
 Call ECR_TRACE("File GENTLOT, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub LOT_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_LOH
# To Save reference
Gosub LOH_STK
WriteB [F:LOH]
If fstat
 Call ECR_TRACE("File GENTLOTH, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub LOH_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_LOD
# To Save reference
Gosub LOD_STK
WriteB [F:LOD]
If fstat
 Call ECR_TRACE("File GENTLOTD, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub LOD_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_LOA
# To Save reference
Gosub LOA_STK
WriteB [F:LOA]
If fstat
 Call ECR_TRACE("File GENTLOTA, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub LOA_ERRTRA
 GOK=0 : Return
Endif
Return

################################################
$LOT_STK
Call STK (WTAB_LOT,WCPT_LOT,[F:LOT]LOT) From TRTMIG
Return
$LOH_STK
Call STK (WTAB_LOH,WCPT_LOH,[F:LOH]LOT-'/'-num$([F:LOH]ORNVCR))  From TRTMIG
Return
$LOD_STK
Call STK (WTAB_LOD,WCPT_LOD,[F:LOD]LOT-'/'-num$([F:LOD]ORNVCR)-'/'-num$([F:LOD]LIN)) From TRTMIG
Return
$LOA_STK
Call STK (WTAB_LOA,WCPT_LOA,[F:LOA]LOT-'/'-num$([F:LOA]ORNVCR)-'/'-num$([F:LOA]LIN)-'/'-num$([F:LOA]ANALIN)) From TRTMIG
Return
##############################################################################################

$LOT_ERRTRA
Call ERRTRA (WTAB_LOT,WCPT_LOT,"File GENTLOT(LOT)=") From TRTMIG
Return
$LOH_ERRTRA
Call ERRTRA (WTAB_LOH,WCPT_LOH,"File GENTLOTH(LOT/ORNVCR)=") From TRTMIG
Return
$LOD_ERRTRA
Call ERRTRA (WTAB_LOD,WCPT_LOD,"File GENTLOTD(LOT/ORNVCR/LIN)=") From TRTMIG
Return
$LOA_ERRTRA
Call ERRTRA (WTAB_LOA,WCPT_LOA,"File GENTLOTA(LOT/ORNVCR/LIN/ANALIN)=") From TRTMIG
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTCPT04(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGTRTCPT04(APPLI)
End

