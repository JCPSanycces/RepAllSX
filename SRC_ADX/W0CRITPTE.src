 If mkstat : End : Endif
Endif

## Zone PTEUOM
mkstat = 0
zoncou = "PTEUOM"
indice = 0
If varmode([M]PTEUOM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PTEUOM" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TUN","!B",[M]PTEUOM,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PTEUOM" : GZNUM = 2915 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PJTDEBC
mkstat = 0
zoncou = "PJTDEBC"
indice = 0
WCHAR = [M]PJTDEBC
If varmode([M]PJTDEBC,indice)=0
 SAVACT = GACTION : GACTION = "PJTBEFZON"
 Call PJT_BEFORE_ZONE([M]PJTDEBC,"CPTE","PJTDEBC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,"","","","","") From TRTPJT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PJTDEBC : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PJTDEBC" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "PJTCTL"
  Call PJT_CONTROL([M]PJTDEBC,"CPTE","PJTDEBC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,"","","","","") From TRTPJT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PJTDEBC" : GZNUM = 54671 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]PJTDEBC
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]PJTDEBC = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PJTDEBC" : GZNUM = 54671 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]PJTDEBC or IMPMOD
     SAVACT = GACTION : GACTION = "PJTAFTMOD"
     Call PJT_AFTER_MODIFY([M]PJTDEBC,"CPTE","PJTDEBC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,"","","","","") From TRTPJT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "PJTDEBC" : GZNUM = 54671 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "STD"
      Call AM_PJTDEBC([M]PJTDEBC) From CNSPTESTD
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "PJTDEBC" : GZNUM = 54671 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone PJTFINC
mkstat = 0
zoncou = "PJTFINC"
indice = 0
WCHAR = [M]PJTFINC
If varmode([M]PJTFINC,indice)=0
 SAVACT = GACTION : GACTION = "PJTBEFZON"
 Call PJT_BEFORE_ZONE([M]PJTFINC,"CPTE","PJTFINC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,"","","","","") From TRTPJT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PJTFINC : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PJTFINC" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "PJTCTL"
  Call PJT_CONTROL([M]PJTFINC,"CPTE","PJTFINC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,"","","","","") From TRTPJT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PJTFINC" : GZNUM = 54672 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]PJTFINC
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]PJTFINC = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PJTFINC" : GZNUM = 54672 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CTLALPV"
    Call CTLALPV([M]PJTFINC,[M:CPTE]PJTDEBC) From CONTDIV
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PJTFINC" : GZNUM = 54672 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_PJTFINC([M]PJTFINC) From CNSPTESTD
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "PJTFINC" : GZNUM = 54672 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]PJTFINC or IMPMOD
       SAVACT = GACTION : GACTION = "PJTAFTMOD"
       Call PJT_AFTER_MODIFY([M]PJTFINC,"CPTE","PJTFINC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,"","","","","") From TRTPJT
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "PJTFINC" : GZNUM = 54672 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone PJTDSPALL
mkstat = 0
zoncou = "PJTDSPALL"
indice = 0
IMPENT = [M]PJTDSPALL
If varinit([M]PJTDSPALL,indice)=0
 IMPENT = 1
Endif
If varmode([M]PJTDSPALL,indice)=0
 [M]PJTDSPALL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PJTDSPALL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PJTDSPALL(indice)
 Endif
Endif
[M]PJTDSPALL = IMPENT

## Zone PTEDATDEB
mkstat = 0
zoncou = "PTEDATDEB"
indice = 0
If varmode([M]PTEDATDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PTEDATDEB" : Gosub ACTION From =IMPTRT
 Endif
 If [M]PTEDATDEB=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PTEDATDEB" : GZNUM = 1805 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PTEDATFIN
mkstat = 0
zoncou = "PTEDATFIN"
indice = 0
If varmode([M]PTEDATFIN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PTEDATFIN" : Gosub ACTION From =IMPTRT
 Endif
 If [M]PTEDATFIN=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PTEDATFIN" : GZNUM = 1806 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "DATDEBFIN"
  Call DATDEBFIN([M]PTEDATFIN,[M:CPTE]PTEDATDEB) From EXEFNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PTEDATFIN" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone OPENUM
mkstat = 0
zoncou = "OPENUM"
indice = 0
If varmode([M]OPENUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPENUM" : Gosub ACTION From =IMPTRT
 Endif
 If [M]OPENUM<0
