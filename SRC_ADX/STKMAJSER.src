#<AdxTL>@(#)9.0.0.0 $Revision$
########################################################################
# Traitement STKMAJSER - Librairie des composants de màj stock    V140 #
#                        Contrôle et mise à jour des no séries         #
########################################################################
# Etiquettes appelées par Gosub depuis les STKMAJ-E-S-C         TS 2004
#
# CTL_SERIE         Contrôles si numéros série et
#                   affectation du 1er no si nécessaire
# MAJ_SERIE         Mise à jour des numéros de série
#
#-----------------------------------------------------------------------
# Autres étiquettes appelées par Gosub depuis ce traitement :
#
# CTL_SERIE_ENTREE  Contrôles si nos de série en entrée
# CTL_SERIE_SORTIE  Contrôles si nos de série en sortie
# CTL_SERIE_CHGEMP  Contrôles si nos de série en changement d'emplacement
# MAJ_SERIE_ENTREE  Mise à jour no série en entrée de stock
# MAJ_SERIE_SORTIE  Mise à jour no série en sortie de stock
# MAJ_SERIE_CHGEMP  Mise à jour série en changement d'emplacement
#
########################################################################

#--------------------------------------------------------------------------#
# Contrôles si numéros de série et affectation du 1er numéro si nécessaire #
# ------------------------------------------------------------------------ #
# [L]WCODFONC: Code fonction (1=Entrée, 2=Sortie, 3=Changement emplacement)#
# [L]WFLUX   : Flux (1=Entrée, 2=Sortie)                                   #
# [L]WCTLSER : Indicateur des contrôles à effectuer                        #
#              1 = Le numéro de série doit être renseigné                  #
#              2 = Vérification du compteur et récup 1er no de série       #
#              3 = Contrôle correspondance qté et no série renseigné       #
#--------------------------------------------------------------------------#
$CTL_SERIE
Raz [L]WCRESER, [L]WNBRSER, [L]WCTLSER
#----- Gestion des nos série, la quantité doit être un nombre entier -----#
If [F:ITM]SERMGTCOD>1
  If mod([M:STW]QTYSTU(I),1)
    [M:STW]ERRCOD=18 : Gosub TRT_ERR From STKMAJ : Return
  Endif
  #-----
  [L]WSERNUM =[M:STW]SERNUM(I)
  [L]WSERNUMF=[M:STW]SERNUMF(I)
Endif
#----- Pas de gestion de no série, la champ doit être vide -----#
If [F:ITM]SERMGTCOD<2 & [M:STW]SERNUM(I)<>""
  [M:STW]ERRCOD=32 : Gosub TRT_ERR From STKMAJ : Return
Endif

# Propriétaire du stock [L]WOWNFLG
# - 0 = Le site lui-même (fonctionnement std)
# - 1 = Un autre site    (ne rien faire)
# - 2 = Un tiers externe (gestion similaire au fonctionnement std)

If [M:STW]OWNER(I)=[L]WFCY | [M:STW]OWNER(I)=""
  [L]WOWNFLG = 0
Else
  If !clalev([F:FCY1]) : Local File FACILITY [FCY1] : Endif
  Read [FCY1]FCY0=[M:STW]OWNER(I)
  If fstat
    [L]WOWNFLG = 1
  Else
    [L]WOWNFLG = 2
  Endif
Endif

#----- Pas de gestion de no série, le contrôle est fini ! -----#
If [F:ITM]SERMGTCOD<2  Return : Endif
#----- Chargement [L]WCTLSER suivant la fonction -----#
Case [L]WCODFONC
  When 1 : Gosub CTL_SERIE_ENTREE
  When 2 : Gosub CTL_SERIE_SORTIE
  When 3 : Gosub CTL_SERIE_CHGEMP
Endcase
#----- Traitement de contrôles en fonction du code chargé -----#
Case [L]WCTLSER
  When 1
    #----- Le numéro de série doit être renseigné -----#
    If [M:STW]SERNUM(I)=""
      [M:STW]ERRCOD=17 : [L]WZON="SERNUM" : Gosub TRT_ERR From STKMAJ : Return
    Endif
  When 2
    #----- Affectation du 1er no de série -----#
    If [F:ITM]SERCOU=""  [L]WSERCOU=GSTKCPT(12)  Else  [L]WSERCOU=[F:ITM]SERCOU : Endif
    Call NUMERO([L]WSERCOU,[L]WFCY,[M:STW]IPTDAT,[F:ITM]ITMREF,
&               [M:STW]SERNUM(I),[L]WRET) From SUBANM
    If GOK<0
      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
    Elsif GOK<1 | [L]WRET<>0
      [M:STW]ERRCOD=50 : [L]WCTEUR=[L]WSERCOU : Gosub TRT_ERR From STKMAJ : Return
    Endif

    #--- Issue X3-66323
    If [L]WCODFONC=1
      Read [STS]STS0=[F:ITM]ITMREF;[M:STW]SERNUM(I)
      If !fstat
        [M:STW]ERRCOD=47 : [L]WSERNUMF=[M:STW]SERNUM(I) : Gosub TRT_ERR From STKMAJ : Return
      Endif
    Endif
    #---

    [L]WCRESER=1
    [L]WNBRSER=[M:STW]QTYSTU(I)
  When 3
    If [M:STW]MAJCOD(I)<>"A" & [L]WSERNUMF<>""
      #----- Contrôle correspondance qté et no série renseignés -----#
      [L]WNBRSER=val(ctrans([L]WSERNUMF,sigma(J=1,47,chr$(J))+sigma(J=58,255,chr$(J)),""))
&               -val(ctrans([L]WSERNUM,sigma(J=1,47,chr$(J))+sigma(J=58,255,chr$(J)),""))+1
      If [L]WNBRSER<>abs([M:STW]QTYSTU(I))
        [M:STW]ERRCOD=31 : Gosub TRT_ERR From STKMAJ : Return
      Endif
    Else
      [L]WNBRSER=abs([M:STW]QTYSTU(I))
    Endif
    #--- Issue 110327
    ##----- Si flux de sortie et Numéro de série renseigné, la qté doit être 1 -----#
    #If [L]WCODFONC<>3 & [L]WFLUX=2 & [L]SENS=+1 & [F:ITM]SERMGTCOD>2 & abs([M:STW]QTYSTU(I))<>1
    #----- Si flux de sortie et numéro de série géré en E/S, la qté doit être 1
    If [L]WCODFONC<>3 & [L]WFLUX=2 & [L]SENS=+1 & [F:ITM]SERMGTCOD=3 & abs([M:STW]QTYSTU(I))<>1
    #---
      [M:STW]ERRCOD=35 : Gosub TRT_ERR From STKMAJ : Return
    Endif
Endcase
Return

#-------------------------------------#
# Contrôles si nos de série en entrée #
#-------------------------------------#
$CTL_SERIE_ENTREE
If [F:ITM]SERMGTCOD>1
  #----- Numéro de série non renseigné -----#
  If [M:STW]SERNUM(I)=""
    #----- Gestion des no série en entrée et emplacement différent de quai -----#
    #--- Issue X3-53322
    #If [F:ITM]SERMGTCOD>2 & [M:STW]LOCCAT(I)<>2
    If [F:ITM]SERMGTCOD>2 & ([M:STW]LOCCAT(I)<>2 | [M:STW]LPNNUM(I)<>"")
    #---
      #----- Si annulation ou entrée négative ou inter-site -----#
      If [L]SIGN=-1 | [L]SENS=-1 | (find([M:STW]TRSTYP,3,16) & [M:STW]TRFFCY<>"") | [M:STW]TRSTYP=14
        [L]WCTLSER=1 : # No série devrait être renseigné
      #----- Entrée classique -----#
      Else
        [L]WCTLSER=2 : # Récupération 1er no série
      Endif
    Endif
  #----- Numéro de série renseigné -----#
  Else
    [L]WCTLSER=3     : # Contrôle correspondance qté et no série début-fin
  Endif
Endif
Return

#-------------------------------------#
# Contrôles si nos de série en sortie #
#-------------------------------------#
$CTL_SERIE_SORTIE

# No série en sortie et (stock appartenant à un autre site ou intra-société) --> pas d'affectation
If [F:ITM]SERMGTCOD=2 & ([L]WOWNFLG=1 |
&                        [M:STW]TRFFCY<>"" & [M:STW]TRFFCY<>[M:STW]STOFCY & [M:STW]BETCPY<>2)
   Return
Endif

# hcb # 96916 deb
#CHECK IGNORE_BEGIN
Raz GPE
GPOINT = "CTRSERSOR"
Gosub  ENTREE From EXEFNC
If GPE = 1
   Return
Endif
#CHECK IGNORE_END
# hcb # 96916 deb

# Si inventaire ne pas affecter les numéros série, si géré en sortie
If [M:STW]TRSTYP=13 & [F:ITM]SERMGTCOD<=2 & [M:STW]SERNUM(I)=""
   Return
Endif
If [F:ITM]SERMGTCOD>1
  #----- Numéro de série non renseigné -----#
  If [M:STW]SERNUM(I)=""
    #----- Si annulation, sortie négative ou no série géré en entrée-sortie -----#
    If [M:STW]MAJCOD(I)="A" | [L]SENS=-1 | [F:ITM]SERMGTCOD>2
      #--- Issue 110327
      If [M:STW]LOCCAT(I)<>2
        [L]WCTLSER=1   : # No série devrait être renseigné
      Endif
      #[L]WCTLSER=1   : # No série devrait être renseigné
      #--- End issue 110327
    #----- Sortie classique -----#
    Else
      [L]WCTLSER=2   : # Récupération 1er no série
    Endif
  #----- Numéro de série renseigné -----#
  Else
    [L]WCTLSER=3     : # Contrôle correspondance qté et no série début-fin
  Endif
Endif
#-----
Look [STS] STS0=[M:STW]ITMREFLIG(I);[M:STW]SERNUM(I)
If fstat  [L]WCRESER=1 : Endif
Return

#-------------------------------------------------------#
# Contrôles si nos de série en changement d'emplacement #
#-------------------------------------------------------#
$CTL_SERIE_CHGEMP
#----- Changement emplacement entrée, traité comme une entrée -----#
If [L]WFLUX=1
  Gosub CTL_SERIE_ENTREE
#----- Changement emplacement sortie -----#
Else
  #----- Si no série géré en sortie uniquement -----#
  #----- Si changement de site et inter-société -----#
  #----- ou emplacement externe (tiers ou sous-traitant) -----#
  If [F:ITM]SERMGTCOD=2 &
&   (([M:STW]STOFCY<>[M:STW]TRFFCY & [M:STW]BETCPY=2) |
&   ([M:STW]LOCCAT(I)<3 & [M:STW]LOCDESCAT(I)>2))
    #----- Numéro de série non renseigné -----#
    If [M:STW]SERNUM(I)=""
      #----- Si annulation ou sortie négative -----#
      If [M:STW]MAJCOD(I)="A" | [L]SENS=-1
        [L]WCTLSER=1   : # No série devrait être renseigné
      #----- Changement emplacement sortie classique -----#
      Else
        [L]WCTLSER=2   : # Récupération 1er no série
      Endif
    #----- Numéro de série renseigné -----#
    Else
      [L]WCTLSER=3     : # Contrôle correspondance qté et no série début-fin
    Endif
  Else
    [L]WCTLSER=3     : # Contrôle correspondance qté et no série début-fin
  Endif
Endif
#-----
#--- Issue 110327
# Dans le cas du plan de rangement,
# si le premier no série n'existe pas, alors ils sont tous à créer
#--- End issue 110327
Look [STS] STS0=[M:STW]ITMREFLIG(I);[M:STW]SERNUM(I)
If fstat  [L]WCRESER=1 : Endif
Return


#----------------------------------#
# Mise à jour des numéros de série #
#----------------------------------#
$MAJ_SERIE
#--- Issue X3-53322 Remplacement des WSERNUM par WSERNUMT
#--- dans tout les composants appelés depuis MAJ_SERIE
Local Char      WSERNUMT(GLONSER)
# Si modification lot, pas de maj des no série
#--- Issue 110327
#If [M:STW]VCRTYP=35 Return Endif
If [M:STW]VCRTYP=35 & [F:ITM]SERMGTCOD<>4 Return Endif
#---
[L]WFIC="STOSER"
[L]WCLE=[M:STW]ITMREFLIG(I)-[M:STW]SERNUM(I)
Case WCODFONC
  When 1 : Gosub MAJ_SERIE_ENTREE
  When 2 : Gosub MAJ_SERIE_SORTIE
  When 3 : Gosub MAJ_SERIE_CHGEMP
Endcase
#--- Maj CRM ---#
If GMODU(12)=2
#   Gosub
Endif

Return

#-----------------------------------------#
# Mise à jour no série en entrée de stock #
#-----------------------------------------#
$MAJ_SERIE_ENTREE
#-----------------------------------#
# Stock appartenant à un autre site #
#-----------------------------------#
If [L]WOWNFLG=1 : Return : Endif

#--- Issue 110327
If [F:ITM]SERMGTCOD=4
  If [M:STW]VCRTYP=35
    For J=1 To abs([M:STW]QTYSTU(I))
      If J=1
        WSERNUMT=[M:STW]SERNUM(I)
      Else
        Call PLUS_UN(WSERNUMT,WSERNUMT,[L]WRET) From STKLIB
        If [L]WRET<>0  [M:STW]ERRCOD=33 : Gosub TRT_ERR From STKMAJ : Break : Endif
      Endif
      Gosub UPD_SERIE_ENTREE
      If [M:STW]ERRCOD<>0 : Break : Endif
    Next J
  Else
    For J=1 To abs([M:STW]QTYSTU(I))
      If J=1
        WSERNUMT=[M:STW]SERNUM(I)
      Else
        Call PLUS_UN(WSERNUMT,WSERNUMT,[L]WRET) From STKLIB
        If [L]WRET<>0  [M:STW]ERRCOD=33 : Gosub TRT_ERR From STKMAJ : Break : Endif
      Endif
      Gosub MAJ_SERIE_ENTREE_UNITAIRE
      If [M:STW]ERRCOD<>0 : Break : Endif
    Next J
  Endif
Else
  WSERNUMT=[M:STW]SERNUM(I)
  Gosub MAJ_SERIE_ENTREE_UNITAIRE
Endif

Return
#--- End issue 110327

#--- Issue 110327
$MAJ_SERIE_ENTREE_UNITAIRE
# Remplacement de tous les [M:STW]SERNUM(I) par WSERNUMT
# dans toute l'étiquette $MAJ_SERIE_ENTREE_UNITAIRE
# et ajout de la ligne suivante
[L]WCLE=[M:STW]ITMREFLIG(I)-WSERNUMT
#------------------------------------------#
# Réception inter-sites avec pièce origine #
#------------------------------------------#
If (find([M:STW]TRSTYP,3,16) & [M:STW]TRFFCY<>"" & [M:STW]VCRNUMORI<>"")  # hcb 105723
  #----- Lecture du numéro de série -----#
  Readlock [STS] STS0=[M:STW]ITMREFLIG(I);WSERNUMT
  If fstat=1
    GLOCK="$STOSER"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
  Elsif fstat
    Call RSTA("STS",[L]WCLE) From GLOCK
    [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
  Endif
  #----- Réception -----#
  If [M:STW]QTYSTU(I)*[L]SIGN>0
    [F:STS]STOFCY   =[L]WFCY
    [F:STS]RCPFCY   =[L]WFCY
    [F:STS]RCPDAT   =[M:STW]IPTDAT
    [F:STS]RCPVCRTYP=[M:STW]VCRTYP
    [F:STS]RCPVCRNUM=[M:STW]VCRNUM
    [F:STS]RCPVCRLIN=[M:STW]VCRLIN

    If [F:ITM]SERMGTCOD=4
      [F:STS]STOCOU = [M:STW]STOCOU(I)
    Endif

    Raz [F:STS]ISSDAT
    Raz [F:STS]SDHTYP, [F:STS]SDHNUM, [F:STS]SDDLIN
  #----- Annulation réception -----#
  Else
    [F:STS]STOFCY=[M:STW]TRFFCY
    [F:STS]SDHTYP=[M:STW]VCRTYPORI
    [F:STS]SDHNUM=[M:STW]VCRNUMORI
    [F:STS]SDDLIN=[M:STW]VCRLINORI
    [F:STS]ISSDAT=[M:STW]IPTDAT

    Raz [F:STS]RCPFCY, [F:STS]RCPDAT
    Raz [F:STS]RCPVCRTYP, [F:STS]RCPVCRNUM, [F:STS]RCPVCRLIN
  Endif
  # Si no série sorti alors Raz STOCOU
  If [F:STS]ISSDAT<>[0/0/0] & [F:STS]SDHNUM<>""
    Raz [F:STS]STOCOU
  Endif
  #------ Réécriture du numéro de série -----#
  Call REWSTS From STKLIB
  If fstat
    Call FSTA("STS") From GLOCK
    [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
  Endif
  If [M:STW]TRAFLG>2
    [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
  Endif
#----------------#
# Autres entrées #
#----------------#
Else
  #---------------------------------------------------------#
  # Création entrée classique ou Annulation entrée négative #
  #---------------------------------------------------------#
  If [M:STW]QTYSTU(I)*[L]SIGN>0
    #----- Lecture du numéro de série -----#
    Readlock [STS] STS0=[M:STW]ITMREFLIG(I);WSERNUMT
    If fstat=1
      GLOCK="$STOSER"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
    #----- Création du numéro de série -----#
    Elsif fstat
      Raz [F:STS]
      nolign=I+1 : [F:STS]=[M:STW]
      Raz [F:STS]BPAADD
      [F:STS]SERNUM   =WSERNUMT
      [F:STS]ITMREF   =[M:STW]ITMREFLIG(I)
      [F:STS]RCPDAT   =[M:STW]IPTDAT
      [F:STS]RCPFCY   =[L]WFCY
      [F:STS]RCPVCRTYP=[M:STW]VCRTYP
      [F:STS]RCPVCRNUM=[M:STW]VCRNUM
      [F:STS]RCPVCRLIN=[M:STW]VCRLIN
      If [F:ITM]SERMGTCOD<>4 : Raz [F:STS]STOCOU : Endif
      Call ECRSTS From STKLIB
      If fstat
        Call FSTA("STS") From GLOCK
        [M:STW]ERRCOD=70 : [L]WFIC="STOSER" : Gosub TRT_ERR From STKMAJ : Return
      Endif
      If [M:STW]TRAFLG>2
        [L]WMESSAGE=mess(233,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
      Endif
    #----- Cas du changement des caractéristiques stock par la modif lot -----#
    #----- Sortie (div) puis entrée (div) -----#
    Else
      Raz [F:STS]BPCNUM, [F:STS]BPAADD, [F:STS]ISSDAT, [F:STS]GUAENDDAT
      Raz [F:STS]SDHTYP, [F:STS]SDHNUM, [F:STS]SDDLIN
      [F:STS]STOFCY=[L]WFCY
      # Si le no série était sortie, il faut lui remettre le chrono stock
      If [F:ITM]SERMGTCOD=4 & [F:STS]STOCOU=0
        [F:STS]STOCOU = [M:STW]STOCOU(I)
      Endif
      #------ Réécriture du numéro de série -----#
      Call REWSTS From STKLIB
      If fstat
        Call FSTA("STS") From GLOCK
        [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
      Endif
      If [M:STW]TRAFLG>2
        [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
      Endif
    Endif
  #--------------------------------------#
  # Création entrée négative inter-sites #
  #--------------------------------------#
  Elsif [L]SENS=-1 & [M:STW]TRFFCY<>""
    #----- Lecture du numéro de série -----#
    Readlock [STS] STS0=[M:STW]ITMREFLIG(I);WSERNUMT
    If fstat=1
      GLOCK="$STOSER"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
    Elsif fstat
      Call RSTA("STS",[L]WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
    Endif
    [F:STS]SDHTYP=[M:STW]VCRTYP
    [F:STS]SDHNUM=[M:STW]VCRNUM
    [F:STS]SDDLIN=[M:STW]VCRLIN
    [F:STS]ISSDAT=[M:STW]IPTDAT
    # Si no série sorti alors Raz STOCOU
    If [F:STS]ISSDAT<>[0/0/0] & [F:STS]SDHNUM<>""
      Raz [F:STS]STOCOU
    Endif
    #------ Réécriture du numéro de série -----#
    Call REWSTS From STKLIB
    If fstat
      Call FSTA("STS") From GLOCK
      [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
    Endif
    If [M:STW]TRAFLG>2
      [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
    Endif
  #--------------------------------------------------------------------------#
  # Annulation d'entrée diverse pas à l'origine de la création du no série   #
  #--------------------------------------------------------------------------#
  Elsif [M:STW]VCRTYP=19
    Readlock [STS] STS0=[M:STW]ITMREFLIG(I);WSERNUMT
    If fstat=1
      GLOCK="$STOSER"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
    Elsif fstat
      Call RSTA("STS",[L]WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
    Endif
    # C'est cette entrée diverse qui l'a créé --> on le supprime
    If [F:STS]VCRTYP=[M:STW]VCRTYP & [F:STS]VCRNUM=[M:STW]VCRNUM
      Delete [STS] Curr
      If fstat
        Call RSTA("STS",[L]WCLE) From GLOCK
        [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
      Endif
      If [M:STW]TRAFLG>2
        [L]WMESSAGE=mess(175,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
      Endif
    # Il a été créé par une autre entrée
    # On ne sait pas traiter ce qui suit si série géré en E/S global
    #Else
    Elsif [F:ITM]SERMGTCOD<>4
      # On recherche si le mvt précédent était une sortie diverse
      Filter [STJ1] Where STOFCY   = [M:STW]STOFCY
&                       & UPDCOD   = 2
&                       & ITMREF   = [M:STW]ITMREFLIG(I)
&                       & IPTDAT  <= [M:STW]IPTDAT
&                       & SERNUM   = [M:STW]SERNUM(I)
&                       & VCRTYP  <> 19
&                       & QTYSTU  <  0
&                   Order By Key STJ0
      Read [STJ1] First
      # Il n'y en avait pas ou c'était une sortie diverse  --> on le supprime
      If fstat | [F:STJ1]VCRTYP<>20
        Delete [STS] Curr
        If fstat
          Filter [STJ1]
          Call RSTA("STS",[L]WCLE) From GLOCK
          [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
        Endif
        If [M:STW]TRAFLG>2
          [L]WMESSAGE=mess(175,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
        Endif
      # Sinon on le réécrit avec les références de la pièce de sortie
      Else
        [F:STS]SDHTYP=[F:STJ1]VCRTYP
        [F:STS]SDHNUM=[F:STJ1]VCRNUM
        [F:STS]SDDLIN=[F:STJ1]VCRLIN
        [F:STS]ISSDAT=[F:STJ1]IPTDAT
        # Si no série sorti alors Raz STOCOU
        If [F:STS]ISSDAT<>[0/0/0] & [F:STS]SDHNUM<>""
          Raz [F:STS]STOCOU
        Endif
        #------ Réécriture du numéro de série -----#
        Call REWSTS From STKLIB
        If fstat
          Filter [STJ1]
          Call FSTA("STS") From GLOCK
          [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
        Endif
        If [M:STW]TRAFLG>2
          [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
        Endif
      Endif
      Filter [STJ1]
    Endif
  #-------------------------------------------------#
  # Annulation d'entrée ou Création entrée négative #
  #-------------------------------------------------#
  Else
    #----- Suppression numéro de série -----#
    Delete [STS] Where ITMREF=[M:STW]ITMREFLIG(I) & SERNUM=WSERNUMT
    If fstat=1
      GLOCK="$STOSER"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
    Elsif fstat
      Call RSTA("STS",[L]WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
    Endif
    If [M:STW]TRAFLG>2
      [L]WMESSAGE=mess(175,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
    Endif
  Endif
Endif
Return
#--- End issue 110327

#-----------------------------------------#
# Mise à jour no série en sortie de stock #
#-----------------------------------------#
$MAJ_SERIE_SORTIE

#-----------------------------------#
# Stock appartenant à un autre site #
#-----------------------------------#
If [L]WOWNFLG=1 : Return : Endif

#----- Livraison client, calcul de la date de fin de garantie -----#
Raz [L]DAT
If [M:STW]TRSTYP=4 & [M:STW]MAJCOD(I)<>"A"
  If !clalev([F:ITS])  Local File ITMSALES [ITS] : Endif
  If [F:ITS]ITMREF<>[M:STW]ITMREFLIG(I)
    Read [ITS] ITS0=[M:STW]ITMREFLIG(I) : If fstat Raz [F:ITS] : Endif
  Endif
  If [F:ITS]GUAMON<>0  [L]DAT=addmonth([M:STW]IPTDAT,[F:ITS]GUAMON) : Endif
Endif
#-----
If [L]WCRESER=0
  #----- Lecture du numéro de série -----#
  Readlock [STS] STS0=[M:STW]ITMREFLIG(I);[M:STW]SERNUM(I)
  If fstat=1
    GLOCK="$STOSER"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
  Elsif fstat
    Call RSTA("STS",[L]WCLE) From GLOCK
    [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
  Endif
Else
  #----- Création du numéro de série -----#
  Raz [F:STS]
  nolign=I+1 : [F:STS]=[M:STW]
  Raz [F:STS]BPAADD
  [F:STS]STOFCY   =[L]WFCY
  [F:STS]ITMREF   =[M:STW]ITMREFLIG(I)
Endif

#-----------------------#
# Livraison inter-sites #
#-----------------------#
If ([M:STW]TRSTYP=4 & [M:STW]TRFFCY<>"")
  #----- Création livraison -----#
  If [M:STW]QTYSTU(I)*[L]SIGN<0
    [F:STS]BPCNUM   =[M:STW]BPRNUM
    [F:STS]BPAADD   =[M:STW]BPAADD
    [F:STS]SDHTYP   =[M:STW]VCRTYP
    [F:STS]SDHNUM   =[M:STW]VCRNUM
    [F:STS]SDDLIN   =[M:STW]VCRLIN
    [F:STS]ISSDAT   =[M:STW]IPTDAT
    [F:STS]GUAENDDAT=[L]DAT
  Else
    #----- Annulation livraison -----#
    Raz [F:STS]BPCNUM, [F:STS]BPAADD, [F:STS]ISSDAT, [F:STS]GUAENDDAT
    Raz [F:STS]SDHTYP, [F:STS]SDHNUM, [F:STS]SDDLIN
    #--- Issue 110327
    If [F:ITM]SERMGTCOD=4 [F:STS]STOCOU=[M:STW]STOCOU(I) Endif
    #---
  Endif
#----------------#
# Autres sorties #
#----------------#
Else
  #---------------------------------------------------------#
  # Création sortie classique ou Annulation sortie négative #
  #---------------------------------------------------------#
  If [M:STW]QTYSTU(I)*[L]SIGN<0
    [F:STS]BPCNUM=[M:STW]BPRNUM
    [F:STS]BPAADD=[M:STW]BPAADD
    #--- Issue 110327
    #If [L]SENS=+1 | [M:STW]VCRNUMORI=""
    If [L]SENS=+1 & [M:STW]VCRTYP <> 35      # hcb 110327
    #--- End issue 110327
      [F:STS]SDHTYP=[M:STW]VCRTYP
      [F:STS]SDHNUM=[M:STW]VCRNUM
      [F:STS]SDDLIN=[M:STW]VCRLIN
      #--- 87708
      [F:STS]ISSDAT=[M:STW]IPTDAT
    #--- Issue 110327
    #  #-- X3Suivi 82757 : Retour client
    #  If [F:STS]SDHTYP=13 : Gosub ANNUL_RETOUR : Endif : #- Une sortie sur un retour client correspond à une annulation de retour -#
    Elsif [M:STW]VCRNUMORI<>""
    #--- End issue 110327

       [F:STS]SDHTYP=[M:STW]VCRTYPORI
       [F:STS]SDHNUM=[M:STW]VCRNUMORI
       [F:STS]SDDLIN=[M:STW]VCRLINORI
       #--- 87708
       [F:STS]ISSDAT=[M:STW]IPTDAT
    #--- Issue 11327
    Else
      If  [M:STW]VCRTYP <> 35      # hcb 110327
          [F:STS]SDHTYP=[M:STW]VCRTYP
          [F:STS]SDHNUM=[M:STW]VCRNUM
          [F:STS]SDDLIN=[M:STW]VCRLIN
          [F:STS]ISSDAT=[M:STW]IPTDAT
      Endif                        # hcb 110327
      If [F:STS]SDHTYP=13 : Gosub ANNUL_RETOUR : Endif
    #--- End issue 110327
    Endif
    #--- 87708
    #[F:STS]ISSDAT   =[M:STW]IPTDAT
    [F:STS]GUAENDDAT=[L]DAT
  #---------------------------------------------------------#
  # Annulation sortie classique ou Création sortie négative #
  #---------------------------------------------------------#
  Else
    #----- Annulation de sortie ou sortie négative -----#
    Raz [F:STS]BPCNUM, [F:STS]BPAADD, [F:STS]ISSDAT, [F:STS]GUAENDDAT
    Raz [F:STS]SDHTYP, [F:STS]SDHNUM, [F:STS]SDDLIN
    #--- Issue 110327
    If [F:ITM]SERMGTCOD=4 [F:STS]STOCOU=[M:STW]STOCOU(I) Endif
    #---
    #----- Si sortie négative, alimentation pièce entrée -----#
    If [L]SENS=-1
      [F:STS]STOFCY   =[L]WFCY
      [F:STS]RCPFCY   =[L]WFCY
      [F:STS]RCPDAT   =[M:STW]IPTDAT
      [F:STS]RCPVCRTYP=[M:STW]VCRTYP
      [F:STS]RCPVCRNUM=[M:STW]VCRNUM
      [F:STS]RCPVCRLIN=[M:STW]VCRLIN
    Endif
  Endif
Endif
#----- Modification ou création du numéro de sortie -----#
If [L]WCRESER=0
  #----- Si annulation sortie et no série créé lors de la sortie -----#
  #--- Bug 87708
  #If [M:STW]MAJCOD(I)="A" & [L]SENS=1 &
  If [M:STW]MAJCOD(I)="A" &
&    [F:STS]VCRTYP=[M:STW]VCRTYP & [F:STS]VCRNUM=[M:STW]VCRNUM &
&    [F:STS]VCRLIN=[M:STW]VCRLIN
    Delete [STS] Where ITMREF=[M:STW]ITMREFLIG(I) & SERNUM=[M:STW]SERNUM(I)
    [L]WMESSAGE=mess(234,197,1)
  Else
    #--- Issue 110327
    # Si no série sorti alors Raz STOCOU
    If [F:STS]ISSDAT<>[0/0/0] & [F:STS]SDHNUM<>""
      Raz [F:STS]STOCOU
    Endif
    #---
    Call REWSTS From STKLIB : [L]WMESSAGE=mess(232,197,1)
  Endif
Else
  #--- Issue 110327
  # Si no série sorti alors Raz STOCOU
  If [F:STS]ISSDAT<>[0/0/0] & [F:STS]SDHNUM<>""
    Raz [F:STS]STOCOU
  Endif
  #---
  Call ECRSTS From STKLIB : [L]WMESSAGE=mess(233,197,1)
Endif
If fstat
  Call FSTA("STS") From GLOCK
  [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
Endif
If [M:STW]TRAFLG>2  Gosub TRACE_DETAILLEE From STKMAJSUP : Endif
Return

#---------------------------------------------------------#
# X3Suivi 82757 : Gestion de l'annulation de retour       #
#---------------------------------------------------------#
$ANNUL_RETOUR
#--- Issue 110327
If [F:STS]VCRTYP=[M:STW]VCRTYP & [F:STS]VCRNUM=[M:STW]VCRNUM & [F:STS]VCRLIN=[M:STW]VCRLIN
  Delete [STS] Where ITMREF=[M:STW]ITMREFLIG(I) & SERNUM=[M:STW]SERNUM(I)
  [L]WMESSAGE=mess(234,197,1)
  Return
Endif
# Ne peut être fait si série en E/S globale
If [F:ITM]SERMGTCOD=4 : Return : Endif
#--- End issue 110327

#-- On recherche le mvt précédent (la derniere livraison) precedent le retour --#
Filter [STJ1] Where STOFCY   = [M:STW]STOFCY
&                 & UPDCOD   = 2
&                 & ITMREF   = [M:STW]ITMREFLIG(I)
&                 & IPTDAT  <= [M:STW]IPTDAT
&                 & SERNUM   = [M:STW]SERNUM(I)
&                 & VCRTYP   = 4
&             Order By Key STJ0
Read [STJ1] First
If !fstat
  [F:STS]SDHTYP=[F:STJ1]VCRTYP
  [F:STS]SDHNUM=[F:STJ1]VCRNUM
  [F:STS]SDDLIN=[F:STJ1]VCRLIN
#--- Issue 110327
##--- Bug 87708
#Else
#   Raz [F:STS]SDHTYP, [F:STS]SDHNUM, [F:STS]SDDLIN, [F:STS]ISSDAT
##---
#--- End issue 110327
Endif
Filter [STJ1]
Return

#-----------------------------------------------#
# Mise à jour série en changement d'emplacement #
#-----------------------------------------------#
$MAJ_SERIE_CHGEMP
If [L]WFLUX=1 : # Entrée
  If [M:STW]MAJCOD(I)="C"
    #----- Cas du plan de rangement (no série créé lors du rangement) -----#
    If [L]WCRESER=1

      #--- Issue 110327
      If [F:ITM]SERMGTCOD=4
        For J=1 To abs([M:STW]QTYSTU(I))
          If J=1
            WSERNUMT=[M:STW]SERNUM(I)
          Else
            Call PLUS_UN(WSERNUMT,WSERNUMT,[L]WRET) From STKLIB
            If [L]WRET<>0  [M:STW]ERRCOD=33 : Gosub TRT_ERR From STKMAJ : Break : Endif
          Endif
          Gosub CRE_SERIE_ENTREE
          If [M:STW]ERRCOD<>0 : Break : Endif
        Next J
      Else
        WSERNUMT=[M:STW]SERNUM(I)
        Gosub CRE_SERIE_ENTREE
      Endif
      ##----- Création du numéro de série -----#
      #Raz [F:STS]
      #nolign=I+1 : [F:STS]=[M:STW]
      #Raz [F:STS]BPAADD
      #[F:STS]STOFCY=[L]WFCY
      #[F:STS]ITMREF=[M:STW]ITMREFLIG(I)
      #[F:STS]RCPDAT=[M:STW]IPTDAT
      #[F:STS]RCPFCY=[L]WFCY
      #If [M:STW]VCRNUMORI=""
      #  # Pièce changement emplacement, pas terrible, mais on a pas mieux
      #  [F:STS]RCPVCRTYP=[M:STW]VCRTYP
      #  [F:STS]RCPVCRNUM=[M:STW]VCRNUM
      #  [F:STS]RCPVCRLIN=[M:STW]VCRLIN
      #Else
      #  # Pièce entrée origine (celle qui a alimenté l'emplacement quai)
      #  [F:STS]RCPVCRTYP=[M:STW]VCRTYPORI
      #  [F:STS]RCPVCRNUM=[M:STW]VCRNUMORI
      #  [F:STS]RCPVCRLIN=[M:STW]VCRLINORI
      #  [F:STS]VCRTYP=[M:STW]VCRTYPORI
      #  [F:STS]VCRNUM=[M:STW]VCRNUMORI
      #  [F:STS]VCRLIN=[M:STW]VCRLINORI
      #Endif
      #Call ECRSTS From STKLIB
      #If fstat
      #  Call FSTA("STS") From GLOCK
      #  [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
      #Endif
      #If [M:STW]TRAFLG>2
      #  [L]WMESSAGE=mess(233,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
      #Endif
      #--- End issue 110327

    Else

      #--- Issue 110327
      If [F:ITM]SERMGTCOD=4
        For J=1 To abs([M:STW]QTYSTU(I))
          If J=1
            WSERNUMT=[M:STW]SERNUM(I)
          Else
            Call PLUS_UN(WSERNUMT,WSERNUMT,[L]WRET) From STKLIB
            If [L]WRET<>0  [M:STW]ERRCOD=33 : Gosub TRT_ERR From STKMAJ : Break : Endif
          Endif
          Gosub UPD_SERIE_ENTREE
          If [M:STW]ERRCOD<>0 : Break : Endif
        Next J
      Else
        WSERNUMT=[M:STW]SERNUM(I)
        Gosub UPD_SERIE_ENTREE
      Endif
      #Read [STS] STS0=[M:STW]ITMREFLIG(I);[M:STW]SERNUM(I)
      #If !fstat
      #  #----- Transfert inter-site ou retour de prêt -----#
      #  #MAE, bg 101636, ou si plan de rangement
      #  If [F:STS]STOFCY<>[L]WFCY |([M:STW]LOCCAT(I)<3 & [M:STW]LOCDESCAT(I)>2)|[M:STW]TRSTYP=22
      #    #----- Lecture du numéro de série -----#
      #    Readlock [STS] STS0=[M:STW]ITMREFLIG(I);[M:STW]SERNUM(I)
      #    If fstat=1
      #      GLOCK="$STOSER"-[L]WCLE
      #      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
      #    Elsif fstat
      #      Call RSTA("STS",[L]WCLE) From GLOCK
      #      [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
      #    Endif
      #    #----- Si transfert inter-site, maj pièce de réception
      #    #MAE, bg 101636, ou si plan de rangement
      #    If [F:STS]STOFCY<>[L]WFCY |[M:STW]TRSTYP=22
      #      [F:STS]RCPDAT   =[M:STW]IPTDAT
      #      [F:STS]RCPFCY   =[L]WFCY
      #      [F:STS]RCPVCRTYP=[M:STW]VCRTYP
      #      [F:STS]RCPVCRNUM=[M:STW]VCRNUM
      #      [F:STS]RCPVCRLIN=[M:STW]VCRLIN
      #    Endif
      #    [F:STS]STOFCY=[L]WFCY
      #    Raz [F:STS]BPCNUM, [F:STS]BPAADD, [F:STS]ISSDAT, [F:STS]GUAENDDAT
      #    Raz [F:STS]SDHTYP, [F:STS]SDHNUM, [F:STS]SDDLIN
      #    #----- Réécriture du numéros de série -----#
      #    Call REWSTS From STKLIB
      #    If fstat
      #      Call FSTA("STS") From GLOCK
      #      [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
      #    Endif
      #    If [M:STW]TRAFLG>2
      #      [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
      #    Endif
      #  Endif
      #Endif
      #--- End issue 110327

    Endif
  #----- Annulation changement d'emplacement -----#
  Else

    #--- Issue 110327
    If [F:ITM]SERMGTCOD=4
      For J=1 To abs([M:STW]QTYSTU(I))
        If J=1
          WSERNUMT=[M:STW]SERNUM(I)
        Else
          Call PLUS_UN(WSERNUMT,WSERNUMT,[L]WRET) From STKLIB
          If [L]WRET<>0  [M:STW]ERRCOD=33 : Gosub TRT_ERR From STKMAJ : Break : Endif
        Endif
        Gosub UPD2_SERIE_ENTREE
        If [M:STW]ERRCOD<>0 : Break : Endif
      Next J
    Else
      WSERNUMT=[M:STW]SERNUM(I)
      Gosub UPD2_SERIE_ENTREE
    Endif
    #Read [STS] STS0=[M:STW]ITMREFLIG(I);[M:STW]SERNUM(I)
    #If !fstat
    #  #----- Annulation transfert inter-site ou retour de prêt -----#
    #  If [F:STS]STOFCY<>[M:STW]STOFCY |([M:STW]LOCCAT(I)<3 & [M:STW]LOCDESCAT(I)>2)
    #    #----- Lecture du numéro de série -----#
    #    Readlock [STS] STS0=[M:STW]ITMREFLIG(I);[M:STW]SERNUM(I)
    #    If fstat=1
    #      GLOCK="$STOSER"-[L]WCLE
    #      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
    #    Elsif fstat
    #      Call RSTA("STS",[L]WCLE) From GLOCK
    #      [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
    #    Endif
    #    #----- Si transfert inter-site, maj pièce de réception avec pièce d'entrée -----#
    #    If [F:STS]STOFCY<>[M:STW]STOFCY
    #      [F:STS]RCPDAT   =[F:STS]CREDAT
    #      [F:STS]RCPFCY   =[M:STW]STOFCY
    #      [F:STS]RCPVCRTYP=[F:STS]VCRTYP
    #      [F:STS]RCPVCRNUM=[F:STS]VCRNUM
    #      [F:STS]RCPVCRLIN=[F:STS]VCRLIN
    #    #----- Autres cas (retour de prêt) -----#
    #    Else
    #      [F:STS]SDHTYP=[M:STW]VCRTYPORI
    #      [F:STS]SDHNUM=[M:STW]VCRNUMORI
    #      [F:STS]SDDLIN=[M:STW]VCRLINORI
    #    Endif
    #    [F:STS]STOFCY=[M:STW]STOFCY
    #    #----- Réécriture du numéros de série -----#
    #    Call REWSTS From STKLIB
    #    If fstat
    #      Call FSTA("STS") From GLOCK
    #      [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
    #    Endif
    #    If [M:STW]TRAFLG>2
    #      [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
    #    Endif
    #  Endif
    #Endif
    #--- End issue 110327

  Endif
Else          : # Sortie
  If [M:STW]MAJCOD(I)="C"
    #----- Numéro série à créer
    If [L]WCRESER=1

      #--- Issue 110327
      WSERNUMT=[M:STW]SERNUM(I)
      Gosub CRE_SERIE_SORTIE
      #Raz [F:STS]
      #nolign=I+1 : [F:STS]=[M:STW]
      #[F:STS]STOFCY=[L]WFCY
      #[F:STS]ITMREF=[M:STW]ITMREFLIG(I)
      ##----- Si livraison de prêt, alimentation pièce de sortie -----#
      #If [M:STW]LOCDESCAT(I)=3
      #  [F:STS]SDHTYP=[M:STW]VCRTYP
      #  [F:STS]SDHNUM=[M:STW]VCRNUM
      #  [F:STS]SDDLIN=[M:STW]VCRLIN
      #  [F:STS]BPCNUM=[M:STW]BPRNUM
      #  [F:STS]BPAADD=[M:STW]BPAADD
      #Endif
      #Call ECRSTS From STKLIB
      #If fstat
      #  Call FSTA("STS") From GLOCK
      #  [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
      #Endif
      #If [M:STW]TRAFLG>2
      #  [L]WMESSAGE=mess(233,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
      #Endif
      #--- End issue 110327

    #----- Si livraison de prêt, alimentation pièce de sortie -----#
    Elsif [M:STW]LOCDESCAT(I)=3

      #--- Issue 110327
      WSERNUMT=[M:STW]SERNUM(I)
      Gosub UPD_SERIE_SORTIE
      ##----- Lecture du numéro de série -----#
      #Update [STS] Where ITMREF=[M:STW]ITMREFLIG(I)
#&                      & SERNUM=[M:STW]SERNUM(I)
#&                  With  SDHTYP=[M:STW]VCRTYP,
#&                        SDHNUM=[M:STW]VCRNUM,
#&                        SDDLIN=[M:STW]VCRLIN,
#&                        BPCNUM=[M:STW]BPRNUM,
#&                        BPAADD=[M:STW]BPAADD,
#&                        UPDUSR=GUSER,
#&                        UPDDAT=date$
      #If fstat=1
      #  GLOCK="$STOSER"-[L]WCLE
      #  [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
      #Elsif fstat
      #  Call RSTA("STS",[L]WCLE) From GLOCK
      #  [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
      #Endif
      #If [M:STW]TRAFLG>2
      #  [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
      #Endif
      #--- End issue 110327

    Endif
  #----- Annulation livraison prêt ou sous-traitance -----#
  Elsif [M:STW]LOCCAT(I)<3 & [M:STW]LOCDESCAT(I)>2

    #--- Issue 110327
    WSERNUMT=[M:STW]SERNUM(I)
    Gosub UPD2_SERIE_SORTIE
    ##----- Lecture du numéro de série -----#
    #Readlock [STS] STS0=[M:STW]ITMREFLIG(I);[M:STW]SERNUM(I)
    #If fstat=1
    #  GLOCK="$STOSER"-[L]WCLE
    #  [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
    #Elsif fstat
    #  Call RSTA("STS",[L]WCLE) From GLOCK
    #  [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
    #Endif
    ##----- Si no série créé lors de la sortie, suppression de celui-ci -----#
    #If [F:STS]VCRTYP=[M:STW]VCRTYP & [F:STS]VCRNUM=[M:STW]VCRNUM &
#&      [F:STS]VCRLIN=[M:STW]VCRLIN
    #  Delete [STS] Where ITMREF=[M:STW]ITMREFLIG(I) & SERNUM=[M:STW]SERNUM(I)
    #  [L]WMESSAGE=mess(234,197,1)
    ##----- Sinon, raz pièce sortie -----#
    #Else
    #  [F:STS]STOFCY=[L]WFCY
    #  Raz [F:STS]SDHTYP, [F:STS]SDHNUM, [F:STS]SDDLIN
    #  Raz [F:STS]BPCNUM, [F:STS]BPAADD
    #  #----- Réécriture du numéros de série -----#
    #  Call REWSTS From STKLIB
    #  [L]WMESSAGE=mess(232,197,1)
    #Endif
    #If fstat
    #  Call FSTA("STS") From GLOCK
    #  [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
    #Endif
    #If [M:STW]TRAFLG>2 : Gosub TRACE_DETAILLEE From STKMAJSUP : Endif
    #--- End issue 110327

  #--- Issue 110327
  #----- Annulation transfert inter-sites, retour prêt ou sous-traitance -----#
  Elsif [F:STS]STOFCY<>[M:STW]TRFFCY | ([M:STW]LOCCAT(I)>2 & [M:STW]LOCDESCAT(I)<3)
    If [F:ITM]SERMGTCOD=4
      WSERNUMT=[M:STW]SERNUM(I)
      Gosub UPD3_SERIE_SORTIE
    Endif
  #--- End issue 110327

  Endif
Endif
Return

##############################################################################
#--- Issue 110327
$CRE_SERIE_SORTIE
[L]WCLE=[M:STW]ITMREFLIG(I)-WSERNUMT
Raz [F:STS]
nolign=I+1 : [F:STS]=[M:STW]
[F:STS]STOFCY=[L]WFCY
[F:STS]ITMREF=[M:STW]ITMREFLIG(I)
#----- Si livraison de prêt, alimentation pièce de sortie -----#
If [M:STW]LOCDESCAT(I)=3

  [F:STS]SDHTYP=[M:STW]VCRTYP
  [F:STS]SDHNUM=[M:STW]VCRNUM
  [F:STS]SDDLIN=[M:STW]VCRLIN
  [F:STS]BPCNUM=[M:STW]BPRNUM
  [F:STS]BPAADD=[M:STW]BPAADD
Endif
[F:STS]SERNUM=WSERNUMT
If [F:ITM]SERMGTCOD<>4 : Raz [F:STS]STOCOU : Endif
Call ECRSTS From STKLIB
If fstat
  Call FSTA("STS") From GLOCK
  [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
Endif
If [M:STW]TRAFLG>2
  [L]WMESSAGE=mess(233,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
Endif
Return
#--- End issue 110327

##############################################################################
#--- Issue 110327
$UPD_SERIE_SORTIE
[L]WCLE=[M:STW]ITMREFLIG(I)-WSERNUMT
#----- Lecture du numéro de série -----#
Update [STS] Where ITMREF=[M:STW]ITMREFLIG(I)
&                & SERNUM=WSERNUMT
&            With  SDHTYP=[M:STW]VCRTYP,
&                  SDHNUM=[M:STW]VCRNUM,
&                  SDDLIN=[M:STW]VCRLIN,
&                  BPCNUM=[M:STW]BPRNUM,
&                  BPAADD=[M:STW]BPAADD,
&                  UPDUSR=GUSER,
&                  UPDDAT=date$
If fstat=1
  GLOCK="$STOSER"-[L]WCLE
  [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
Elsif fstat
  Call RSTA("STS",[L]WCLE) From GLOCK
 [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
Endif
If [M:STW]TRAFLG>2
  [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
Endif
Return
#--- End issue 110327

##############################################################################
#--- Issue 110327
$UPD2_SERIE_SORTIE
[L]WCLE=[M:STW]ITMREFLIG(I)-WSERNUMT
#----- Lecture du numéro de série -----#
Readlock [STS] STS0=[M:STW]ITMREFLIG(I);WSERNUMT
If fstat=1
  GLOCK="$STOSER"-[L]WCLE
  [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
Elsif fstat
  Call RSTA("STS",[L]WCLE) From GLOCK
  [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
Endif
#----- Si no série créé lors de la sortie, suppression de celui-ci -----#
If [F:STS]VCRTYP=[M:STW]VCRTYP & [F:STS]VCRNUM=[M:STW]VCRNUM &
&  [F:STS]VCRLIN=[M:STW]VCRLIN
  Delete [STS] Where ITMREF=[M:STW]ITMREFLIG(I) & SERNUM=WSERNUMT
  [L]WMESSAGE=mess(234,197,1)
#----- Sinon, raz pièce sortie -----#
Else
  [F:STS]STOFCY=[L]WFCY
  Raz [F:STS]SDHTYP, [F:STS]SDHNUM, [F:STS]SDDLIN
  Raz [F:STS]BPCNUM, [F:STS]BPAADD

  If [F:ITM]SERMGTCOD=4 [F:STS]STOCOU=[M:STW]STOCOU(I) Endif

  #----- Réécriture du numéros de série -----#
  Call REWSTS From STKLIB
  [L]WMESSAGE=mess(232,197,1)
Endif
If fstat
  Call FSTA("STS") From GLOCK
  [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
Endif
If [M:STW]TRAFLG>2 : Gosub TRACE_DETAILLEE From STKMAJSUP : Endif
Return
#--- End issue 110327

##############################################################################
#--- Issue 110327
$UPD3_SERIE_SORTIE
[L]WCLE=[M:STW]ITMREFLIG(I)-WSERNUMT
#----- Lecture du numéro de série -----#
Readlock [STS] STS0=[M:STW]ITMREFLIG(I);WSERNUMT
If fstat=1
  GLOCK="$STOSER"-[L]WCLE
  [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
Elsif fstat
  Call RSTA("STS",[L]WCLE) From GLOCK
  [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
Endif

[F:STS]STOCOU=[M:STW]STOCOU(I)
#----- Réécriture du numéros de série -----#
Call REWSTS From STKLIB
If fstat
  Call FSTA("STS") From GLOCK
  [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
Endif
If [M:STW]TRAFLG>2 : Gosub TRACE_DETAILLEE From STKMAJSUP : Endif
Return
#--- End issue 110327

##############################################################################
#--- Issue 110327
$CRE_SERIE_ENTREE
[L]WCLE=[M:STW]ITMREFLIG(I)-WSERNUMT
Raz [F:STS]
nolign=I+1 : [F:STS]=[M:STW]
Raz [F:STS]BPAADD
[F:STS]STOFCY=[L]WFCY
[F:STS]ITMREF=[M:STW]ITMREFLIG(I)
[F:STS]RCPDAT=[M:STW]IPTDAT
[F:STS]RCPFCY=[L]WFCY
If [M:STW]VCRNUMORI=""
  # Pièce changement emplacement, pas terrible, mais on a pas mieux
  [F:STS]RCPVCRTYP=[M:STW]VCRTYP
  [F:STS]RCPVCRNUM=[M:STW]VCRNUM
  [F:STS]RCPVCRLIN=[M:STW]VCRLIN
Else
  # Pièce entrée origine (celle qui a alimenté l'emplacement quai)
  [F:STS]RCPVCRTYP=[M:STW]VCRTYPORI
  [F:STS]RCPVCRNUM=[M:STW]VCRNUMORI
  [F:STS]RCPVCRLIN=[M:STW]VCRLINORI
  [F:STS]VCRTYP=[M:STW]VCRTYPORI
  [F:STS]VCRNUM=[M:STW]VCRNUMORI
  [F:STS]VCRLIN=[M:STW]VCRLINORI
Endif
[F:STS]SERNUM=WSERNUMT
If [F:ITM]SERMGTCOD<>4 : Raz [F:STS]STOCOU : Endif
Call ECRSTS From STKLIB
If fstat
  Call FSTA("STS") From GLOCK
  [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
Endif
If [M:STW]TRAFLG>2
  [L]WMESSAGE=mess(233,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
Endif
Return
#--- End issue 110327

##############################################################################
#--- Issue 110327
$UPD_SERIE_ENTREE
[L]WCLE=[M:STW]ITMREFLIG(I)-WSERNUMT
#----- Lecture du numéro de série -----#
Read [STS] STS0=[M:STW]ITMREFLIG(I);WSERNUMT
If !fstat
  #----- Transfert inter-site ou retour de prêt -----#
  #MAE, bg 101636, ou si plan de rangement
  If [F:ITM]SERMGTCOD=4 | [F:STS]STOFCY<>[L]WFCY |([M:STW]LOCCAT(I)<3 & [M:STW]LOCDESCAT(I)>2)|[M:STW]TRSTYP=22
    #----- Lecture du numéro de série -----#
    Readlock [STS] STS0=[M:STW]ITMREFLIG(I);WSERNUMT
    If fstat=1
      GLOCK="$STOSER"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
    Elsif fstat
      Call RSTA("STS",[L]WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
    Endif
    If [F:STS]STOFCY<>[L]WFCY |([M:STW]LOCCAT(I)<3 & [M:STW]LOCDESCAT(I)>2)|[M:STW]TRSTYP=22
      #----- Si transfert inter-site, maj pièce de réception
      #MAE, bg 101636, ou si plan de rangement
      If [F:STS]STOFCY<>[L]WFCY |[M:STW]TRSTYP=22
        [F:STS]RCPDAT   =[M:STW]IPTDAT
        [F:STS]RCPFCY   =[L]WFCY
        [F:STS]RCPVCRTYP=[M:STW]VCRTYP
        [F:STS]RCPVCRNUM=[M:STW]VCRNUM
        [F:STS]RCPVCRLIN=[M:STW]VCRLIN
      Endif
      [F:STS]STOFCY=[L]WFCY
      Raz [F:STS]BPCNUM, [F:STS]BPAADD, [F:STS]ISSDAT, [F:STS]GUAENDDAT
      Raz [F:STS]SDHTYP, [F:STS]SDHNUM, [F:STS]SDDLIN
    Endif

    If [F:ITM]SERMGTCOD=4 [F:STS]STOCOU=[M:STW]STOCOU(I) Endif

    #----- Réécriture du numéros de série -----#
    Call REWSTS From STKLIB
    If fstat
      Call FSTA("STS") From GLOCK
      [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
    Endif
    If [M:STW]TRAFLG>2
      [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
    Endif
  Endif
Endif
Return
#--- End issue 110327

##############################################################################
#--- Issue 110327
$UPD2_SERIE_ENTREE
[L]WCLE=[M:STW]ITMREFLIG(I)-WSERNUMT
#----- Lecture du numéro de série -----#
Read [STS] STS0=[M:STW]ITMREFLIG(I);WSERNUMT
If !fstat
  #----- Annulation transfert inter-site ou retour de prêt -----#
  If [F:ITM]SERMGTCOD=4 | [F:STS]STOFCY<>[M:STW]STOFCY |([M:STW]LOCCAT(I)<3 & [M:STW]LOCDESCAT(I)>2)
    #----- Lecture du numéro de série -----#
    Readlock [STS] STS0=[M:STW]ITMREFLIG(I);WSERNUMT
    If fstat=1
      GLOCK="$STOSER"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
    Elsif fstat
      Call RSTA("STS",[L]WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
    Endif
    #----- Si transfert inter-site, maj pièce de réception avec pièce d'entrée -----#
    If [F:STS]STOFCY<>[M:STW]STOFCY
      [F:STS]RCPDAT   =[F:STS]CREDAT
      [F:STS]RCPFCY   =[M:STW]STOFCY
      [F:STS]RCPVCRTYP=[F:STS]VCRTYP
      [F:STS]RCPVCRNUM=[F:STS]VCRNUM
      [F:STS]RCPVCRLIN=[F:STS]VCRLIN
    #----- Si retour de prêt
    #Elsif [M:STW]LOCCAT(I)<3 & [M:STW]LOCDESCAT(I)>2
    Elsif [M:STW]LOCCAT(I)<3 & [M:STW]LOCDESCAT(I)=3
      [F:STS]SDHTYP=[M:STW]VCRTYPORI
      [F:STS]SDHNUM=[M:STW]VCRNUMORI
      [F:STS]SDDLIN=[M:STW]VCRLINORI
    Endif
    [F:STS]STOFCY=[M:STW]STOFCY
    #----- Réécriture du numéros de série -----#
    # Si no série sorti alors Raz STOCOU
    If [F:STS]ISSDAT<>[0/0/0] & [F:STS]SDHNUM<>""
      Raz [F:STS]STOCOU
    Endif
    Call REWSTS From STKLIB
    If fstat
      Call FSTA("STS") From GLOCK
      [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
    Endif
    If [M:STW]TRAFLG>2
      [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
    Endif
  Endif
Endif
Return
#--- End issue 110327

