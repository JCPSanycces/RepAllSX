#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion objet TFO
Raz GPILOBJ , GNBMASKOUV
Call OBJET("TFO",GBIDC1,GBIDC2) From GOBJET
End

############################################################
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBTFOB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "AV_IMPRIME"  : Gosub AV_IMPRIME
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FERME"       : Gosub FERME
 When "RAZCRE"      : Gosub CHARGE_LEG
 When "RAZDUP"      : Gosub CHARGE_LEG
Endcase
If PSUBB
 Gosub ACTION From SUBTFOB
Endif
Return

$OUVRE
Local File ATABTAB [ADV]
Return

$APRES_MODIF
Return

$LIENS
Gosub CHARGE_LEG
Return

$CHARGE_LEG
Local Integer I , J , OKLEG , LNGTAB , MAXLEG
Local Char    OACTION(20) , FMTDES(20) , FMTFOR(20)
Read [ADV]CODE=909
LNGTAB = max(3,[F:ADV]LNG)
OKLEG = 0
If dim([L]ACTION)>0
 OACTION = ACTION
Else
 Local Char ACTION(20)
Endif
ACTION = "CHARGE_LEG" : Gosub ACTION
ACTION = OACTION
If GNBLEG<=1 or !OKLEG or !(func AFNC.ACTIV("LEG"))
 MAXLEG = 0
Else
 MAXLEG = GNBLEG
Endif
FMTDES = "KP:"+num$(GLONDES)+"X"
#113536
#FMTFOR = "K:70>180X"
FMTFOR = "K:70>250X"
If MAXLEG=0
 [M]FORFOR1 = [F:TFO]FORFOR(0)
 [M]LEG1 = ""
 [M]ZLEG1 = ""
 Chgfmt [M]LEG1 With "-K:X"
 Chgfmt [M]ZLEG1 With "-K:X"
Else
 For I=1 To MAXLEG
  Chgfmt [M]LEG1 With "KP:"+num$(LNGTAB)+"X" : Chgfmt [M]ZLEG1 With FMTDES
  If evalue("dim([M]FORFOR"+num$(I)+")")>0
   Case I
    When 2  : Chgfmt [M]LEG2 With "KP:"+num$(LNGTAB)+"X"  : Chgfmt [M]FORFOR2 With FMTFOR  : Chgfmt [M]ZLEG2 With FMTDES
    When 3  : Chgfmt [M]LEG3 With "KP:"+num$(LNGTAB)+"X"  : Chgfmt [M]FORFOR3 With FMTFOR  : Chgfmt [M]ZLEG3 With FMTDES
    When 4  : Chgfmt [M]LEG4 With "KP:"+num$(LNGTAB)+"X"  : Chgfmt [M]FORFOR4 With FMTFOR  : Chgfmt [M]ZLEG4 With FMTDES
    When 5  : Chgfmt [M]LEG5 With "KP:"+num$(LNGTAB)+"X"  : Chgfmt [M]FORFOR5 With FMTFOR  : Chgfmt [M]ZLEG5 With FMTDES
    When 6  : Chgfmt [M]LEG6 With "KP:"+num$(LNGTAB)+"X"  : Chgfmt [M]FORFOR6 With FMTFOR  : Chgfmt [M]ZLEG6 With FMTDES
    When 7  : Chgfmt [M]LEG7 With "KP:"+num$(LNGTAB)+"X"  : Chgfmt [M]FORFOR7 With FMTFOR  : Chgfmt [M]ZLEG7 With FMTDES
    When 8  : Chgfmt [M]LEG8 With "KP:"+num$(LNGTAB)+"X"  : Chgfmt [M]FORFOR8 With FMTFOR  : Chgfmt [M]ZLEG8 With FMTDES
    When 9  : Chgfmt [M]LEG9 With "KP:"+num$(LNGTAB)+"X"  : Chgfmt [M]FORFOR9 With FMTFOR  : Chgfmt [M]ZLEG9 With FMTDES
    When 10 : Chgfmt [M]LEG10 With "KP:"+num$(LNGTAB)+"X" : Chgfmt [M]FORFOR10 With FMTFOR : Chgfmt [M]ZLEG10 With FMTDES
    When 11 : Chgfmt [M]LEG11 With "KP:"+num$(LNGTAB)+"X" : Chgfmt [M]FORFOR11 With FMTFOR : Chgfmt [M]ZLEG12 With FMTDES
    When 12 : Chgfmt [M]LEG12 With "KP:"+num$(LNGTAB)+"X" : Chgfmt [M]FORFOR12 With FMTFOR : Chgfmt [M]ZLEG12 With FMTDES
    When 13 : Chgfmt [M]LEG13 With "KP:"+num$(LNGTAB)+"X" : Chgfmt [M]FORFOR13 With FMTFOR : Chgfmt [M]ZLEG13 With FMTDES
    When 14 : Chgfmt [M]LEG14 With "KP:"+num$(LNGTAB)+"X" : Chgfmt [M]FORFOR14 With FMTFOR : Chgfmt [M]ZLEG14 With FMTDES
    When 15 : Chgfmt [M]LEG15 With "KP:"+num$(LNGTAB)+"X" : Chgfmt [M]FORFOR15 With FMTFOR : Chgfmt [M]ZLEG15 With FMTDES
    When 16 : Chgfmt [M]LEG16 With "KP:"+num$(LNGTAB)+"X" : Chgfmt [M]FORFOR16 With FMTFOR : Chgfmt [M]ZLEG16 With FMTDES
    When 17 : Chgfmt [M]LEG17 With "KP:"+num$(LNGTAB)+"X" : Chgfmt [M]FORFOR17 With FMTFOR : Chgfmt [M]ZLEG17 With FMTDES
    When 18 : Chgfmt [M]LEG18 With "KP:"+num$(LNGTAB)+"X" : Chgfmt [M]FORFOR18 With FMTFOR : Chgfmt [M]ZLEG18 With FMTDES
    When 19 : Chgfmt [M]LEG19 With "KP:"+num$(LNGTAB)+"X" : Chgfmt [M]FORFOR19 With FMTFOR : Chgfmt [M]ZLEG19 With FMTDES
    When 20 : Chgfmt [M]LEG20 With "KP:"+num$(LNGTAB)+"X" : Chgfmt [M]FORFOR20 With FMTFOR : Chgfmt [M]ZLEG20 With FMTDES
   Endcase
   Assign "[M]LEG"+num$(I) With GDOSLEG(I)
   J = find(GDOSLEG(I),[F:TFO]LEG)
   If J
    Assign "[M]FORFOR"+num$(I) With [F:TFO]FORFOR(J-1)
   Elsif I=1 & [F:TFO]LEG(0)=""
    [M]FORFOR1 = [F:TFO]FORFOR(0)
   Endif
  Endif
 Next I
Endif
For I=MAXLEG+1 To dim(GDOSLEG)
 If evalue("dim([M]FORFOR"+num$(I)+")")>0
  Case I
   When 2  : Chgfmt [M]LEG2 With "-K:X"  : Chgfmt [M]FORFOR2 With "-K:X"  : Chgfmt [M]ZLEG2 With "-K:X"
   When 3  : Chgfmt [M]LEG3 With "-K:X"  : Chgfmt [M]FORFOR3 With "-K:X"  : Chgfmt [M]ZLEG3 With "-K:X"
   When 4  : Chgfmt [M]LEG4 With "-K:X"  : Chgfmt [M]FORFOR4 With "-K:X"  : Chgfmt [M]ZLEG4 With "-K:X"
   When 5  : Chgfmt [M]LEG5 With "-K:X"  : Chgfmt [M]FORFOR5 With "-K:X"  : Chgfmt [M]ZLEG5 With "-K:X"
   When 6  : Chgfmt [M]LEG6 With "-K:X"  : Chgfmt [M]FORFOR6 With "-K:X"  : Chgfmt [M]ZLEG6 With "-K:X"
   When 7  : Chgfmt [M]LEG7 With "-K:X"  : Chgfmt [M]FORFOR7 With "-K:X"  : Chgfmt [M]ZLEG7 With "-K:X"
   When 8  : Chgfmt [M]LEG8 With "-K:X"  : Chgfmt [M]FORFOR8 With "-K:X"  : Chgfmt [M]ZLEG8 With "-K:X"
   When 9  : Chgfmt [M]LEG9 With "-K:X"  : Chgfmt [M]FORFOR9 With "-K:X"  : Chgfmt [M]ZLEG9 With "-K:X"
   When 10 : Chgfmt [M]LEG10 With "-K:X" : Chgfmt [M]FORFOR10 With "-K:X" : Chgfmt [M]ZLEG10 With "-K:X"
   When 11 : Chgfmt [M]LEG11 With "-K:X" : Chgfmt [M]FORFOR11 With "-K:X" : Chgfmt [M]ZLEG11 With "-K:X"
   When 12 : Chgfmt [M]LEG12 With "-K:X" : Chgfmt [M]FORFOR12 With "-K:X" : Chgfmt [M]ZLEG12 With "-K:X"
   When 13 : Chgfmt [M]LEG13 With "-K:X" : Chgfmt [M]FORFOR13 With "-K:X" : Chgfmt [M]ZLEG13 With "-K:X"
   When 14 : Chgfmt [M]LEG14 With "-K:X" : Chgfmt [M]FORFOR14 With "-K:X" : Chgfmt [M]ZLEG14 With "-K:X"
   When 15 : Chgfmt [M]LEG15 With "-K:X" : Chgfmt [M]FORFOR15 With "-K:X" : Chgfmt [M]ZLEG15 With "-K:X"
   When 16 : Chgfmt [M]LEG16 With "-K:X" : Chgfmt [M]FORFOR16 With "-K:X" : Chgfmt [M]ZLEG16 With "-K:X"
   When 17 : Chgfmt [M]LEG17 With "-K:X" : Chgfmt [M]FORFOR17 With "-K:X" : Chgfmt [M]ZLEG17 With "-K:X"
   When 18 : Chgfmt [M]LEG18 With "-K:X" : Chgfmt [M]FORFOR18 With "-K:X" : Chgfmt [M]ZLEG18 With "-K:X"
   When 19 : Chgfmt [M]LEG19 With "-K:X" : Chgfmt [M]FORFOR19 With "-K:X" : Chgfmt [M]ZLEG19 With "-K:X"
   When 20 : Chgfmt [M]LEG20 With "-K:X" : Chgfmt [M]FORFOR20 With "-K:X" : Chgfmt [M]ZLEG20 With "-K:X"
  Endcase
 Endif
Next I
Return

$INICRE
$INIMOD
[F]FORNUM = num$([F]FORTYP)
If GNBLEG=1 & dim([M]FORFOR1)>0
 [F]LEG    = GDOSLEG(1)
 [F]FORFOR = [M]FORFOR1
Else
 For I=1 To GNBLEG
  If evalue("dim([M]FORFOR"+num$(I)+")")>0 & I<=dim([F]FORFOR)
   [F]LEG(I-1) = evalue("[M]LEG"+num$(I))
   [F]FORFOR(I-1) = evalue("[M]FORFOR"+num$(I))
  Endif
 Next I
Endif
I = 3500 : # Pour ne pas dépasser la taille d'enregistrement maxi sous SQL (8000 octets)
If sigma(0,dim([F:TFO]FORFOR)-1,len([F:TFO]FORFOR(indcum)))>I
 Call ERREUR(func AFNC.MES1(mess(80,143,1),num$(I))) From GESECRAN : # Longueur des formules trop long (> $1$)
 GOK = 0 : Return
Endif
Return

$MODIF
Gosub CREATION
Return

$CREATION
Call MAJTEXTRA([M]DES,"TABFOR","DES",num$([M]FORTYP),[M]FORCOD) From ATEXTRA
If GOK<1 : Return : Endif
Call MAJTEXTRA([M]DESSHO,"TABFOR","DESSHO",num$([M]FORTYP),[M]FORCOD) From ATEXTRA
If GOK<1 : Return : Endif
Return

$ANNULE
Delete [AXX] Where CODFIC="TABFOR" & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]SUPP-[L]CODE) From GLOCK : Return
Endif
Return

$AV_IMPRIME
Call PRTSCR("TFO1","","",0,0) From ATRTX3
OK = 0
Return

$FERME
Call IMPSCR From ATRTX3
Return

############################################################
Subprog VALTFO_CHAR(LTYP,LCOD,VALEUR)
Value    Integer LTYP
Value    Char    LCOD
Variable Char    VALEUR
Goto VALTFO

############################################################
Subprog VALTFO_NUM(LTYP,LCOD,VALEUR)
Value    Integer LTYP
Value    Char    LCOD
Variable Decimal VALEUR
Goto VALTFO

############################################################
Subprog VALTFO_DAT(LTYP,LCOD,VALEUR)
Value    Integer LTYP
Value    Char    LCOD
Variable Date VALEUR
Goto VALTFO

############################################################
Subprog VALTFO_LIB(LTYP,LCOD,VALEUR)
Value    Integer LTYP
Value    Char    LCOD
Variable Integer VALEUR
Goto VALTFO

$VALTFO
Local Char FORMULE(255)
If LTYP<>0 & LCOD<>""
 FORMULE = func LECTFO(LTYP,LCOD)
 Onerrgo ERR
 VALEUR = evalue(FORMULE)
 Onerrgo
Endif
End

$ERR
# Erreur en évaluation de la formule
Call ERREUR(mess(65,106,1)+" : "+LCOD+"\"+format$("KTv2:255X",FORMULE)+"\"+errmes$(errn)-errm) From GESECRAN
Resume

############################################################
Funprog FC(FORMULE)
Value Char FORMULE
Local Char ACTION(20) , RESULTAT(250)
ACTION = "FC" : Gosub ACTION
End RESULTAT

########################################################################
# Lecture d'une formule (Table TABFOR)                                 #
#          GCURLEG doit contenir le code législation                   #
#----------------------------------------------------------------------#
# Entrée : LTYP = Type formule                                         #
#          LCOD = Code formule                                         #
########################################################################

Funprog LECTFO(LTYP,LCOD)
Value    Integer LTYP
Value    Char    LCOD
Local Integer J
Local Char RESULTAT(250)
If LTYP=21
 If filinfo(filpath("FIL","TABFORLEG","fde",nomap),0)>0
  Gosub FORMULE_LEG
 Else
  Gosub FORMULE
 Endif
Else
 Gosub FORMULE
Endif
End RESULTAT

$FORMULE
If clalev([F:TFO])=0 : Local File TABFOR [TFO] : Endif
Read [TFO]TFO0=LTYP;LCOD
If fstat
 RESULTAT = ''
Elsif dim(GCURLEG)>0 & GCURLEG<>""
 J = find(GCURLEG,[F:TFO]LEG)
 If J
  RESULTAT = [F:TFO]FORFOR(J-1)
 Elsif sum([F:TFO]LEG)=""
  RESULTAT = [F:TFO]FORFOR
 Else
  RESULTAT = ''
 Endif
Else
 RESULTAT = [F:TFO]FORFOR
Endif
Return

$FORMULE_LEG
If clalev([F:TFOLEG])=0 : Local File TABFORLEG [TFOLEG] : Endif
If dim(GCURLEG)>0 & GCURLEG<>""
 Read [TFOLEG]TFOLEG0=LCOD;GCURLEG
 If !fstat
  RESULTAT = [F:TFOLEG]FORFOR
  Return
 Endif
Endif
Read [TFOLEG]TFOLEG0=LCOD;GDOSLEG(1)
If !fstat
 RESULTAT = [F:TFOLEG]FORFOR
Else
 RESULTAT = ''
Endif
Return

######################################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File TABFOR   [TFO1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".TABFOR"   [TFO1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File TABFOR   [TFO2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".TABFOR"   [TFO2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Local Char DOSDESLEG(GLONADI)(1..dim(GDOSLEG)) , DOSORGLEG(GLONADI)(1..dim(GDOSLEG))
Local Integer I , J , K , L , NBDESLEG , NBORGLEG , OK
Call SETLEG([M]DOSDES,DOSDESLEG,NBDESLEG) From DOSCONT
Call SETLEG([M]DOSORG,DOSORGLEG,NBORGLEG) From DOSCONT
OK = 1
If GTRACE=""
 Read [TFO2]TFO0 = val(TABLE);TABLE2
 If !fstat
  # Fiche déjà existante
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [TFO1] , [TFO2] , [AXX1] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [TFO2]
 Read [TFO1]TFO0 = val(TABLE);TABLE2
 If !fstat
  Readlock [TFO2]TFO0 = val(TABLE);TABLE2
  If fstat=1
   GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABFOR" : Goto ROLL_TR_COP
  Elsif fstat
   [F:TFO2]FORTYP = [F:TFO1]FORTYP
   [F:TFO2]FORCOD = [F:TFO1]FORCOD
   Gosub COP
   If dim([F:TFO2]CREUSR)>0 : [F:TFO2]CREUSR = GUSER : Endif
   If dim([F:TFO2]CREDAT)>0 : [F:TFO2]CREDAT = date$ : Endif
   If dim([F:TFO2]CRETIM)>0 : [F:TFO2]CRETIM = time  : Endif
   Write [TFO2]
   If fstat
    GOK=0 : Call FSTA("TFO2") From GLOCK : Goto AB_TR_COP
   Endif
  Else
   Gosub COP
   If dim([F:TFO2]UPDUSR)>0 : [F:TFO2]UPDUSR = GUSER : Endif
   If dim([F:TFO2]UPDDAT)>0 : [F:TFO2]UPDDAT = date$ : Endif
   If dim([F:TFO2]UPDTIM)>0 : [F:TFO2]UPDTIM = time  : Endif
   Rewrite [TFO2]
   If fstat
    GOK=0 : Call FSTA("TFO2") From GLOCK : Goto AB_TR_COP
   Endif
  Endif
 Endif
Commit
Return

$COP
For I=1 To NBORGLEG
 If find(DOSORGLEG(I),DOSDESLEG(1..NBDESLEG))
  J = find(DOSORGLEG(I),[F:TFO1]LEG)
  If J
   K = find(DOSORGLEG(I),[F:TFO2]LEG)
   If K
    [F:TFO2]FORFOR(K-1) = [F:TFO1]FORFOR(J-1)
   Else
    For K=1 To dim([F:TFO2]LEG)
     If [F:TFO2]LEG(K-1)=""
      [F:TFO2]LEG(K-1)    = [F:TFO1]LEG(J-1)
      [F:TFO2]FORFOR(K-1) = [F:TFO1]FORFOR(J-1)
      Break
     Endif
    Next K
   Endif
  Else
   [F:TFO2]FORFOR(0) = [F:TFO1]FORFOR(0)
  Endif
 Endif
Next I
[F:TFO2]FORNUM = [F:TFO1]FORNUM
Call COPTEXTRA("TABFOR","DES",num$(TABLE),TABLE2) From ATEXTRA
Call COPTEXTRA("TABFOR","DESSHO",num$(TABLE),TABLE2) From ATEXTRA
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

