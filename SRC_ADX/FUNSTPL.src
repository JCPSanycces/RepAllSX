#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du masque STOCKPUL
############################################################
# Purge des lots nuls
############################################################
$ACTION
Case ACTION
  When "EXEC"         : Gosub EXEC_PURLOT
  When "TERMINE"      : Gosub TERMINE_PURLOT
  When "INIT_DIA"     : Gosub INIT_DIA_PURLOT
  When "OK"           : Gosub OK_PURLOT
  When "END"          : Gosub END_PURLOT
Endcase 
Return

#############################################################
$EXEC_PURLOT
If [M:DIA]PURLOTDAT <> [0/0/0]
  Gosub PUR_LOT
Endif
Return
#############################################################
$TERMINE_PURLOT
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
Return
#############################################################
$INIT_DIA_PURLOT
Raz [M:DIA]
Local Char WPAR(05)
Call PARAM(VALEUR,"MARPURLOT",WPAR) From ADOVAL
If val(WPAR) = 0
  WPAR = "12"
Endif
[M:DIA]DATREFMAX =addmonth(date$,val(WPAR)*-1)
[M:DIA]PURLOTDAT = [M:DIA]DATREFMAX
[M:DIA]SIM    = 2   # hcb 040105 26446

Return
#############################################################
$OK_PURLOT
FIN  = 1
Return
#############################################################
$END_PURLOT
Raz [M:DIA]
FIN = 1
Return
#############################################################
$PUR_LOT
Local Integer NBSTO
Local Char    WMSG(240)

If [M:DIA]SIM=1
     Call TEMPON (mess(398,197,1)) From GESECRAN
     If !GSERVEUR
        Call OUVRE_TRACE(mess(398,197,1)) From LECFIC  
     Endif
Else Call TEMPON (mess(885,196,1)) From GESECRAN
     If !GSERVEUR
        Call OUVRE_TRACE(mess(885,196,1)-":"-mess(398,197,1)) From LECFIC
     Endif  
Endif

Local File STOLOT    [STL]
Local File STOLOTFCY [SLF]
Local File STOCK     [STO]
Local File STOLOTFCY [SLF2]   # hcb 88068

#
$PUR_LOT1
Filter [SLF] Where AAACUMQTY = 0 & QQQCUMQTY = 0 & RRRCUMQTY = 0
For [SLF]
  If [F:SLF]LASRCPDAT < [M]PURLOTDAT &
&    [F:SLF]LASISSDAT < [M]PURLOTDAT
    Trbegin [SLF]
    Readlock [SLF] Curr
    Case fstat 
      When 1 :
        WMSG = mess(20,100,1)+" : "+[F:SLF]ITMREF-[F:SLF]LOT-[F:SLF]SLO-[F:SLF]STOFCY
        Call ECR_TRACE(WMSG,1) From GESECRAN
        Rollback
      When 0 :
        Filter [STO] Where ITMREF = [F:SLF]ITMREF &
&                          STOFCY = [F:SLF]STOFCY &
&                          LOT    = [F:SLF]LOT    &
&                          SLO    = [F:SLF]SLO    

        NBSTO=rowcount([STO]) 
        Filter [STO]
        If NBSTO=0
           If [M:DIA]SIM=1   
              Delete [SLF]
              If fstat 
                 Call FSTA("SLF") From GLOCK
                 Rollback
                 Break
              Else
                Filter [SLF2] Where ITMREF = [F:SLF]ITMREF &
&                                   LOT    = [F:SLF]LOT    &
&                                   SLO    = [F:SLF]SLO    
                If rowcount([SLF2])=0
                    Readlock [STL]STL0=[F:SLF]ITMREF;[F:SLF]LOT;[F:SLF]SLO
                    Delete [STL] Curr
                Endif
                Filter [SLF2]
              Endif
           Endif
           WMSG = [F:SLF]ITMREF+"/"+[F:SLF]LOT+"/"+[F:SLF]SLO+" "+mess(33,196,1)  
           Call ECR_TRACE(WMSG,0) From GESECRAN
        Else 
           WMSG = [F:SLF]ITMREF+"/"+[F:SLF]LOT+"/"+[F:SLF]SLO+" "+mess(103,184,1)  
           Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        Commit
      When Default :
        Call FSTA("SLF") From GLOCK
        Rollback
        Break
    Endcase
  Endif
Next  
#
WMSG = mess(107,184,1)+" ("+format$("D:",[M]PURLOTDAT)+")"
Call ECR_TRACE(WMSG,0) From GESECRAN
Filter [SLF]

Close Local File [SLF]
Close Local File [STO]
Call TEMPOFF     From GESECRAN
Return

############################################################
# Actions écran STOCKPUM
############################################################
Subprog C_PURLOTDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [M:DIA]DATREFMAX
  mkstat = 2
  GMESSAGE = mess(30,187,1)-num$([M:DIA]DATREFMAX)
Endif
End
