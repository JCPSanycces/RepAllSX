#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque POT6 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone JOBGRP
mkstat = 0
zoncou = "JOBGRP"
indice = 0
If varinit([M]JOBGRP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]JOBGRP,"10460","") From SUBADI
 GACTION = SAVACT
Endif

## Zone UOMGRP
mkstat = 0
zoncou = "UOMGRP"
indice = 0
If varinit([M]UOMGRP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]UOMGRP,"10459","") From SUBADI
 GACTION = SAVACT
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRFAM
mkstat = 0
zoncou = "NBRFAM"
indice = 0
status = 1
zoncou = "NBRFAM"
If varmode([M]NBRFAM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRFAM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRFAM
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRFAM = nolign
   status = 75
   Call SAI_NBRFAM(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRFAM(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRFAM
mkstat = 0
zoncou = "NBRFAM"

## Zone CPCFAM
mkstat = 0
zoncou = "CPCFAM"
If varinit([M]CPCFAM,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]CPCFAM(indice),"10461","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]CPCFAM,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CPCFAM" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]CPCFAM(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CPCFAM" : GZNUM = 45514 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]CPCFAM(indice),"10461","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CPCFAM" : GZNUM = 45514 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CPCFAM([M]CPCFAM(indice)) From SUBPOT
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CPCFAM" : GZNUM = 45514 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CONTOBJN"
     Local Char    VALEUR(250)
     VALEUR = [M]CPCFAM(indice)
     Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
     [M]CPCFAM(indice) = VALEUR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CPCFAM" : GZNUM = 45514 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone NBRFAM
mkstat = 0
zoncou = "NBRFAM"
status = 71
SAVACT = GACTION : GACTION = "STD"
Call APRES_NBRFAM From SUBPOT
GACTION = SAVACT

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "POT6"
Return

