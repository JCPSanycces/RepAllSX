########################################
Subprog AS_GRPSETTIM(VALEUR)
Variable Decimal VALEUR
If [M:ROT2]TIMUOMCOD=1
   [M:ROT3]TIMUOM7=mess(30,197,1)
Else
   [M:ROT3]TIMUOM7=mess(32,197,1)
Endif
If !GIMPORT : Affzo [ROT3]TIMUOM7 : Endif
End

