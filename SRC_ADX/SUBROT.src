Subprog AM_OPEUOM(VALEUR)
Variable Char     VALEUR
If GREP<>"C"
   Call MESSAGE (mess(23,193,1)) From GESECRAN
   If [M:ROT2]ROOTIMCOD=1
      zonsui="OPETIM"
   Elsif [M:ROT2]ROOTIMCOD=2
      zonsui="CAD"
   Endif
Endif
End

