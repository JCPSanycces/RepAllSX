#<AdxTL>@(#)12.0.0.0 $Revision$
## Programme de gestion des opérations standard                  #
##################################################################
## écrit en décembre 1997 par Adeline Lenoir                     #
## revu et adapté en juillet 98 par LLC                          #
## revu en Janvier 99 par SR pour gestion du texte               #
##################################################################
$ACTION
Case ACTION
 When "STATUT"       : Gosub STATUT
 When "SETBOUT"      : Gosub SETBOUT
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "LIENS"        : Gosub LIENS
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INICRE
 When "APRES_CRE"    : Gosub APRES_CRE
 When "ABANDON"      : Gosub SUPPRESS_TEX
 When "AB_CREATION"  : Gosub SUPPRESS_TEX
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "CREATION"     : Gosub CREATION  # FGR 22/09/2009 : X3SUIVI57981
 When "MODIF"        : Gosub MODIF     # FGR 22/09/2009 : X3SUIVI57981
 When "ANNULE"       : Gosub ANNULE
 When "FERME"        : Gosub FERME
 When "BB1_WST"      : Gosub BB1_WST
 When "BB1_LABWST"   : Gosub BB1_WST
 When "BB1_SCOWST"   : Gosub BB1_WST
Endcase
Return
###
###########################################################################################
$STATUT
#-------------------------------------------------#
# gestion des textes                              #
#-------------------------------------------------#
Local Integer WRETOUR
Local Char    WNUMTEX(12)

If mkstat=4 & GREP=""
   #MAE, bg 50938
   #GREP="M" : REP="M"
   #Gosub SETBOUT From GOBJSUB
   Gosub ENTRE_MODIF From GOBJSUB
Endif
#------------------------#
# affichage icone texte  #
#------------------------#
If GREP = "" & [M:ROT0]OPETEXNUM <> ""
     Call SET_IMAGE (4) From GESECRAN
Else
    Call RESET_IMAGE (4) From GESECRAN
Endif
Return

#################################################################
$SETBOUT
#---------------------------------------------------------------------------------#
# Activation / Désactivation menus "Texte entête" dans la ToolBar                 #
#---------------------------------------------------------------------------------#
If GREP="C" | GREP="D" | [M:ROT0]STDOPENUM<> 0
   CHMEN += "F"   # v 140
Endif
Return

###############################################################
$RAZCRE
Call RAZ_CLOB From ACLOB

Raz [M:ROT0]OPETEXNUM
If !GIMPORT : Call RESET_IMAGE (4) From GESECRAN : Endif
Return

###############################################################
$RAZDUP
Local Integer WRET,I
Call RAZ_CLOB From ACLOB
Call DUP_CLOB("ROT",[M:ROT0]OPETEXNUM,WRET) From TRTX3TEX
If WRET<1 Raz [M:ROT0]OPETEXNUM : Endif
Return

###############################################################
$LIENS
Call RAZ_CLOB From ACLOB

If [M:ROT1]SCOWST <> ""
   Read [MWS]WST0=[M:ROT1]SCOWST;[M:ROT0]FCY
   If ! fstat
      [M:ROT1]SCOWCR=[F:MWS]WCR
#      [M:ROT1]SCOWSTDES=[F:MWS]WSTDES
      #LECTURE du libellé traduisible
      Call LECTEXTRA([M:ROT1]SCOWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
      [M:ROT1]SCOWSTTYP = [F:MWS]WSTTYP
      [M:ROT1]XSCOWSTTYP = format$("K:2X",mess([M:ROT1]SCOWSTTYP, 313,1))
   Endif
Endif
If [M:ROT2]WST <> ""
   Read [MWS]WST0=[M:ROT2]WST;[M:ROT0]FCY
   If ! fstat
      [M:ROT2]WCR=[F:MWS]WCR
#      [M:ROT2]WSTDES=[F:MWS]WSTDES
      #LECTURE du libellé traduisible
      Call LECTEXTRA([M:ROT2]WSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
      [M:ROT2]WSTTYP=[F:MWS]WSTTYP
      [M:ROT2]XWSTTYP = format$("K:2X", mess([M:ROT2]WSTTYP,313,1))
   Endif
Endif

# llc 06.01 9548
Case [M:ROT2]WSTTYP
    When 1,2:    If [M:ROT1]SCOWST <> "" : [M:ROT1]SCOCOD = 3 : Endif
    When 3:      [M:ROT1]SCOCOD = 2
                 [M:ROT1]SCOWST = [M:ROT2]WST
                 [M:ROT2]LABWST = ""
Endcase


If [M:ROT2]LABWST <> ""
   Read [MWS]WST0=[M:ROT2]LABWST;[M:ROT0]FCY
   If ! fstat
      [M:ROT2]LABWCR=[F:MWS]WCR
#      [M:ROT2]LABWSTDES=[F:MWS]WSTDES
      #LECTURE du libellé traduisible
      Call LECTEXTRA([M:ROT2]LABWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
      [M:ROT2]LABWSTTYP=[F:MWS]WSTTYP
      [M:ROT2]XLABWSTTYP = format$("K:2X",mess([M:ROT2]LABWSTTYP, 313,1))
   Endif
Endif
If [M:ROT2]ROOTIMCOD <> 0
   If [M:ROT2]ROOTIMCOD = 2
      [M:ROT2]OPETIM = 0
      [M:ROT2]TIMUOM2 = ""
   Else
      [M:ROT2]CAD = 0
      [M:ROT2]X = ""
      [M:ROT2]TIMUOM3 = ""
   Endif
   If [M:ROT2]ROOTIMCOD <>1
      [M:ROT2]TIMCOD=0
      [M:ROT2]BASQTY=0
   Endif
Endif
If [M:ROT2]TIMUOMCOD=1
   [M:ROT2]TIMUOM1 = mess(30,197,1)
Else
   [M:ROT2]TIMUOM1 = mess(32,197,1)
Endif
If [M:ROT2]TIMUOMCOD=1
   [M:ROT2]TIMUOM2 = mess(30,197,1)
Else
   [M:ROT2]TIMUOM2 = mess(32,197,1)
Endif
If [M:ROT2]CAD = 0
   [M:ROT2]X = ""
Else
   [M:ROT2]X = "/"
Endif
If [M:ROT2]CAD = 0
   [M:ROT2]TIMUOM3 = ""
Else
   If [M:ROT2]TIMUOMCOD=1
      [M:ROT2]TIMUOM3 = mess(30,197,1)
   Else
      [M:ROT2]TIMUOM3 = mess(32,197,1)
   Endif
Endif
[M:ROT2]TIMUOM4 = mess(30,197,1)
[M:ROT2]TIMUOM5 = mess(30,197,1)
[M:ROT2]TIMUOM6 = mess(30,197,1)

#
#------------------------#
# Affichage icone texte  #
#------------------------#
If [M:ROT0]OPETEXNUM <> ""
    Call SET_IMAGE (4) From GESECRAN
Else
    Call RESET_IMAGE (4) From GESECRAN
Endif
Return

###########################################################
$INICRE
#texte

If [M:ROT0]OPETEXNUM<>""
      Call CRE_CLOB([M:ROT0]OPETEXNUM,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      [F:ROT]OPETEXNUM = [M:ROT0]OPETEXNUM
Endif

Return

################################################################
$APRES_CRE
#  #----- Affichage icone texte -----#
   If [M:ROT0]OPETEXNUM<>""
      Call SET_IMAGE(4)   From GESECRAN
   Else
      Call RESET_IMAGE(4) From GESECRAN
   Endif
Return

################################################################
$SUPPRESS_TEX
Local Integer WRET, I
If GREP = "D"
      Call SUP_CLOB([M:ROT0]OPETEXNUM,WRET) From TRTX3TEX
Endif
Call RAZ_CLOB From ACLOB
Return

################################################################
$ANNULE
Local Integer WRET
#------------------------------------#
# supression du texte associé        #
#------------------------------------#
# on ne vire jamais les textes sur les données de base pour l'instant
#Call SUP_CLOB([M:ROT0]OPETEXNUM,WRET) From TRTX3TEX

  # FGR 22/09/2009 : X3SUIVI57981
  #--- maj de la table des libéllés traduisibles
  Call SUPTEXTRA("ROUOPESTD","STDOPEDESAXX",num$([M:ROT0]STDOPENUM),[M:ROT0]FCY) From ATEXTRA
Return

#############################################################
$CREATION
  # FGR 22/09/2009 : X3SUIVI57981
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:ROT0]STDOPEDESAXX,"ROUOPESTD","STDOPEDESAXX",num$([M:ROT0]STDOPENUM),[M:ROT0]FCY) From ATEXTRA
Return

#############################################################
$MODIF
  # FGR 22/09/2009 : X3SUIVI57981
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:ROT0]STDOPEDESAXX,"ROUOPESTD","STDOPEDESAXX",num$([M:ROT0]STDOPENUM),[M:ROT0]FCY) From ATEXTRA
Return

#################################################################
$FERME
#----- Effacement icone texte -----#
Call RESET_IMAGE(4) From GESECRAN
Return

#################################################################
$VERIF_MOD
# controle article sous-traitance obligatoire si sous-traitance conjoncturelle
# ou structurelle
If [M:ROT1]SCOCOD <> 1 & [M:ROT1]SCOITMREF = ""
   Call ERREUR(mess(7,193,1)) From GESECRAN
   zonsui="SCOITMREF"
   OK=0
Endif
If [M:ROT1]SCOCOD <> 1 & [M:ROT1]SCOWST = ""
   Call ERREUR(mess(39,193,1)) From GESECRAN
   zonsui="SCOWST"
   OK=0
Endif
Return


####################################################################
$AVANT_MODFIC
#------------------------------------------#
# Traitement avant modification            #
#------------------------------------------#
Local Integer WRET

# on a viré le texte
# on ne vire jamais les textes sur les données de base pour l'instant
If [M:ROT0]OPETEXNUM="" & [F:ROT]OPETEXNUM <> ""
#   Call SUP_CLOB([F:ROT]OPETEXNUM,WRET) From TRTX3TEX
Endif
Return

####################################################################

$BB1_WST
If [F:MWS]WST<>"" : VALEUR=[F:MWS]WST : Endif
Return

###################################################
# étiquettes écran
###################################################
# zones saisissables selon le code sous-traitance #
Subprog AM_SCOCOD(VALEUR)
Variable Integer  VALEUR

If VALEUR = 1
    [M:ROT1]SCOITMREF = ""
    [M:ROT1]SCOWST = ""
    [M:ROT1]SCOWCR = ""
    [M:ROT1]SCOWSTTYP = 0
    [M:ROT1]XSCOWSTTYP = ""
    [M:ROT1]SCOWSTDES = ""
    If !GIMPORT
       Affzo [ROT1]SCOITMREF
       Affzo [M:ROT1]SCOWST
       Affzo [M:ROT1]SCOWCR
       Affzo [M:ROT1]XSCOWSTTYP
       Affzo [M:ROT1]SCOWSTDES
    Endif
Endif
End

########################################
Subprog AM_WST(VALEUR)
Variable Char    VALEUR()
Local File WORKSTATIO [MWS]
If VALEUR <> ""
   Read [MWS]WST0 = VALEUR;[M:ROT0]FCY
   If !fstat
      [M:ROT2]WCR = [F:MWS]WCR
      [M:ROT2]WSTTYP = [F:MWS]WSTTYP
      [M:ROT2]XWSTTYP = format$("K:2X",mess([M:ROT2]WSTTYP, 313,1))
#      [M:ROT2]WSTDES = [F:MWS]WSTDES
      #LECTURE du libellé traduisible
      Call LECTEXTRA([M:ROT2]WSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
      [M:ROT2]WSTNBR = [F:MWS]WSTNBR
      Case GWSTEFFINH
          When 1:        # ben rien
          When Default:  [M:ROT2]EFF = [F:MWS]EFF
      Endcase
      [M:ROT2]SHR = [F:MWS]SHR
      If !GIMPORT
          Affzo [M:ROT2]WCR
          Affzo [M:ROT2]XWSTTYP
          Affzo [M:ROT2]WSTDES
          Affzo [M:ROT2]EFF
          Affzo [M:ROT2]SHR
          Affzo [M:ROT2]WSTNBR
      Endif
      If [F:MWS]WSTTYP = 3
         [M:ROT1]SCOCOD=2
         [M:ROT1]SCOWST=VALEUR
         If GREP = "C" | GREP = "D"
            [M:ROT1]SCOCOD=2
            [M:ROT1]SCOWST=VALEUR
         Endif
         [M:ROT2]LABWCR=""
         [M:ROT2]LABWST=""
         [M:ROT2]LABWSTTYP=0
         [M:ROT2]XLABWSTTYP = ""
         [M:ROT2]LABWSTDES=""
         [M:ROT2]SETLABCOE=0
         [M:ROT2]OPELABCOE=0
         [M:ROT2]WSTNBR=0
         If !GIMPORT
             Affzo [ROT2]LABWCR
             Affzo [M:ROT2]XLABWSTTYP
             Affzo [M:ROT2]LABWST
             Affzo [M:ROT2]LABWSTDES
             Affzo [ROT2]SETLABCOE
             Affzo [M:ROT2]OPELABCOE
             Affzo [M:ROT2]WSTNBR
         Endif
      Endif
      If [F:MWS]WSTTYP <> 3 & [M:ROT1]SCOCOD = 2
         [M:ROT1]SCOCOD = 3
         If GREP = "C" | GREP = "D"
            [M:ROT1]SCOCOD = 3
         Endif
      Endif
    Endif
Else
    [M:ROT2]WCR = ""
    [M:ROT2]WSTTYP = 0
    [M:ROT2]XWSTTYP =""
    [M:ROT2]WSTDES = ""
    [M:ROT2]EFF = 100
    [M:ROT2]SHR = 0
    If !GIMPORT
        Affzo [M:ROT2]WCR
        Affzo [M:ROT2]XWSTTYP
        Affzo [M:ROT2]WSTDES
        Affzo [M:ROT2]EFF
        Affzo [M:ROT2]SHR
    Endif
Endif
If [M:ROT1]SCOCOD = 1 : Grizo [M:ROT1]25 : Else : Actzo [M:ROT1]25 : Endif
End

########################################
Subprog AM_LABWST(VALEUR)
Variable Char    VALEUR()
Local File WORKSTATIO [MWS]
If VALEUR <> ""
   Read [MWS]WST0 = VALEUR;[M:ROT0]FCY
   If ! fstat
      [M:ROT2]LABWCR = [F:MWS]WCR
      [M:ROT2]LABWSTTYP = [F:MWS]WSTTYP
      [M:ROT2]XLABWSTTYP = format$("K:2X",mess([M:ROT2]LABWSTTYP, 313,1))
#      [M:ROT2]LABWSTDES = [F:MWS]WSTDES
      #LECTURE du libellé traduisible
      Call LECTEXTRA([M:ROT2]LABWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
      [M:ROT2]LABNBR    = [F:MWS]WSTNBR
      If !GIMPORT
          Affzo [M:ROT2]LABWCR
          Affzo [M:ROT2]XLABWSTTYP
          Affzo [M:ROT2]LABWSTDES
          Affzo [M:ROT2]LABNBR
      Endif
    Endif
Else
    [M:ROT2]SETLABCOE=0
    [M:ROT2]OPELABCOE=0
    [M:ROT2]LABWCR = ""
    [M:ROT2]LABWSTTYP = 0
    [M:ROT2]XLABWSTTYP = ""
    [M:ROT2]LABWSTDES = ""
    [M:ROT2]LABNBR = 0
    If !GIMPORT
        Affzo [M:ROT2]SETLABCOE
        Affzo [M:ROT2]OPELABCOE
        Affzo [M:ROT2]LABWCR
        Affzo [M:ROT2]XLABWSTTYP
        Affzo [M:ROT2]LABWSTDES
        Affzo [M:ROT2]LABNBR
    Endif
Endif
End

########################################
Subprog AM_SCOWST(VALEUR)
Variable Char    VALEUR()
Local File WORKSTATIO [MWS]
If VALEUR <> ""
# alimentation des zones liées au poste de sous-traitance
   Read [MWS]WST0 = VALEUR;[M:ROT0]FCY
   If ! fstat
      [M:ROT1]SCOWCR = [F:MWS]WCR
      [M:ROT1]SCOWSTTYP = [F:MWS]WSTTYP
      [M:ROT1]XSCOWSTTYP = format$("K:2X",mess([M:ROT1]SCOWSTTYP, 313,1))
#      [M:ROT1]SCOWSTDES = [F:MWS]WSTDES
      #LECTURE du libellé traduisible
      Call LECTEXTRA([M:ROT1]SCOWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
      If !GIMPORT
          Affzo [M:ROT1]SCOWCR
          Affzo [M:ROT1]XSCOWSTTYP
          Affzo [M:ROT1]SCOWSTDES
      Endif
    Endif
Else
    [M:ROT1]SCOWCR = ""
    [M:ROT1]SCOWSTTYP = 0
    [M:ROT1]XSCOWSTTYP=""
    [M:ROT1]SCOWSTDES = ""
    If !GIMPORT
        Affzo [M:ROT1]SCOWCR
        Affzo [M:ROT1]XSCOWSTTYP
        Affzo [M:ROT1]SCOWSTDES
    Endif
Endif
End

###################################
Subprog C_WST(VALEUR)
Variable Char     VALEUR
Local File WORKSTATIO [MWS]
If VALEUR <> ""
   Look [MWS]WST0=VALEUR;[M:ROT0]FCY
   If fstat
      GMESSAGE = VALEUR+"\"+mess(133,193,1) : mkstat=2
   Endif
Endif
End

#####################################
Subprog C_LABWST(VALEUR)
Variable Char     VALEUR
Local File WORKSTATIO [MWS]
If VALEUR <> ""
   If VALEUR=[M:ROT2]WST : GMESSAGE=mess(26,193,1) : mkstat=2 : Endif
   Read [MWS]WST0=VALEUR;[M:ROT0]FCY
   If fstat
      GMESSAGE=VALEUR+"\"+mess(133,193,1) : mkstat=2
   Else
      If [F:MWS]WSTTYP <> 2
         GMESSAGE=VALEUR - mess(4,193,1)
         mkstat = 2
         End
      Endif
   Endif
Endif
End

##########################################
Subprog AM_ROOTIMCOD(VALEUR)
Variable Integer  VALEUR
[M:ROT2]ROOTIMCOD = VALEUR :# pour que les AV_ fonctionnent bien (04/02/00 TB)
If VALEUR = 2
   [M:ROT2]OPETIM = 0
   [M:ROT2]TIMUOM2 = ""
   If !GIMPORT
       Affzo [ROT2]OPETIM
       Affzo [ROT2]TIMUOM2
   Endif
Else
   [M:ROT2]CAD = 0
   [M:ROT2]X = ""
   [M:ROT2]TIMUOM3 = ""
   If !GIMPORT
       Affzo [ROT2]CAD
       Affzo [ROT2]X
       Affzo [ROT2]TIMUOM3
   Endif
Endif
If VALEUR<>1
    [M:ROT2]TIMCOD=0
    [M:ROT2]BASQTY=0
    If !GIMPORT
        Affzo [ROT2]TIMCOD
        Affzo [ROT2]BASQTY
    Endif
Else
    [M:ROT2]TIMCOD=1
    [M:ROT2]BASQTY=1
    If !GIMPORT
        Affzo [ROT2]TIMCOD
        Affzo [ROT2]BASQTY
    Endif
Endif
End

############################################
Subprog C_SCOWST(VALEUR)
Variable Char     VALEUR
Local File WORKSTATIO [MWS]
If VALEUR <> ""
   Read [MWS]WST0=VALEUR;[M:ROT0]FCY
   If fstat
      GMESSAGE=VALEUR+"\"+mess(133,193,1) : mkstat=2
   Else
      If [F:MWS]WSTTYP <> 3
         GMESSAGE=VALEUR - mess(3,193,1)
         mkstat = 2
         End
      Endif
   Endif
Endif
End

