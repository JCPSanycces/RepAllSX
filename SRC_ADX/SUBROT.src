Subprog AP_CAD(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0
   [M:ROT2]X="/"
   If [M:ROT2]TIMUOMCOD=1
      [M:ROT2]TIMUOM3=mess(30,197,1)
   Else
      [M:ROT2]TIMUOM3=mess(32,197,1)
   Endif
Else
   [M:ROT2]X=""
