        Affzo [ROT2]LABWCR
        Affzo [ROT2]XLABWSTTYP
        Affzo [ROT2]LABWSTDES
    Endif
Endif
End

#####################################################"
Subprog AM_TIMUOMCOD(VALEUR)
Variable Integer  VALEUR
Local Integer OK
# Issue 101397 - 2014-11-10 by JUSYN : Automatically conversion of setup and run time in routings
# If GREP<>"C" & GREP<>"D" : Call MESSAGE(mess(23,193,1)) From GESECRAN : Endif
If GREP<>"C" & GREP<>"D"
    Call OUINON(mess(302,193,1),OK) From GESECRAN
    If OK = 2
        Call CHANGETIMVALUE(VALEUR)
        If VALEUR = 1
            # Setup and Run time have been converted from minutes to hours
            Call MESSAGE(mess(300,193,1)) From GESECRAN
        Else
            # Setup and Run time have been converted from hours to minutes
            Call MESSAGE(mess(301,193,1)) From GESECRAN
        Endif
    Else
        If VALEUR<>0 : Call MESSAGE(mess(23,193,1)) From GESECRAN : Endif
    Endif
Endif

If VALEUR=1
   [M:ROT2]TIMUOM1=mess(30,197,1)
   [M:ROT2]TIMUOM2=mess(30,197,1)
   If [M:ROT2]CAD<>0 : [M:ROT2]TIMUOM3=mess(30,197,1) : Endif
   If dim([M:ROT3]TIMUOM7) > 0 : [M:ROT3]TIMUOM7=mess(30,197,1) : Endif
Else
   [M:ROT2]TIMUOM1=mess(32,197,1)
   [M:ROT2]TIMUOM2=mess(32,197,1)
   If [M:ROT2]CAD<>0 : [M:ROT2]TIMUOM3=mess(32,197,1) : Endif
   If dim([M:ROT3]TIMUOM7) > 0 : [M:ROT3]TIMUOM7=mess(32,197,1) : Endif
Endif
[M:ROT2]TIMUOMCOD = VALEUR :# pour que les AV_ fonctionnent bien (04/02/00 TB)
If !GIMPORT
    Affzo [ROT2]TIMUOM1
    Affzo [ROT2]TIMUOM2
    Affzo [ROT2]TIMUOM3
Endif
End

#####################################################"
Subprog AM_TIMCOD(VALEUR)
Variable Integer  VALEUR
If GREP<>"C" & GREP<>"D" : Call MESSAGE(mess(23,193,1)) From GESECRAN : Endif
Case VALEUR
 When 4 : [M:ROT2]BASQTY=0 :    If !GIMPORT : Affzo [ROT2]BASQTY : Endif
 When 1 : [M:ROT2]BASQTY=1 :    If !GIMPORT : Affzo [ROT2]BASQTY : Endif
 When 2 : [M:ROT2]BASQTY=100 :  If !GIMPORT : Affzo [ROT2]BASQTY : Endif
 When 3 : [M:ROT2]BASQTY=1000 : If !GIMPORT : Affzo [ROT2]BASQTY : Endif
Endcase
End

