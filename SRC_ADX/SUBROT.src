########################################
Subprog AM_BPRNUM(VALEUR)
Variable Char    VALEUR()
GBPCNUM= VALEUR
[M:ROT1]BPAADD=""
End
# Ticket 101397 Automatically conversion of setup and run time in routings
######################################################################################
## Recalculate setup and run time from hours to minutes and vice versa
######################################################################################
Subprog CHANGETIMVALUE(UNIT)
Variable Integer UNIT
# UNIT = 1 = hours (minutes before, divide by 60)
# UNIT = 2 = minutes (hours before, multiply with 60)

# hours
If UNIT = 1
  # Run time
  If [M:ROT2]OPETIM <> 0
    [M:ROT2]OPETIM = [M:ROT2]OPETIM / 60
  Endif
  # Setup time
  If [M:ROT2]SETTIM <> 0
    [M:ROT2]SETTIM = [M:ROT2]SETTIM / 60
  Endif
Endif

# minutes
If UNIT = 2
  # Run time
  If [M:ROT2]OPETIM <> 0
    [M:ROT2]OPETIM = [M:ROT2]OPETIM * 60
  Endif
  # Setup time
  If [M:ROT2]SETTIM <> 0
    [M:ROT2]SETTIM = [M:ROT2]SETTIM * 60
  Endif
Endif

If UNIT = 1
   [M:ROT2]TIMUOM1 = mess(30,197,1)
Else
   [M:ROT2]TIMUOM1 = mess(32,197,1)
Endif

If UNIT = 1
   [M:ROT2]TIMUOM2 = mess(30,197,1)
Else
   [M:ROT2]TIMUOM2 = mess(32,197,1)
Endif

Affzo [ROT2]OPETIM
Affzo [ROT2]SETTIM
Affzo [ROT2]TIMUOM1
Affzo [ROT2]TIMUOM2

End
