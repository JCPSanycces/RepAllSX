########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Local File WORKSTATIO [MWS]
If VALEUR <> ""
   If [M:ROT1]SCOWST <> ""
      Read [MWS]WST0=[M:ROT1]SCOWST;VALEUR
      If ! fstat
         [M:ROT1]SCOWCR=[F:MWS]WCR
#         [M:ROT1]SCOWSTDES=[F:MWS]WSTDES
         #LECTURE du libellé traduisible
         Call LECTEXTRA([M:ROT1]SCOWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
         [M:ROT1]SCOWSTTYP = [F:MWS]WSTTYP
         [M:ROT1]XSCOWSTTYP = format$("K:2X",mess([M:ROT1]SCOWSTTYP, 313,1))
      Endif
   Endif
   If [M:ROT2]WST <> ""
      Read [MWS]WST0=[M:ROT2]WST;VALEUR
      If ! fstat
         [M:ROT2]WCR=[F:MWS]WCR
#         [M:ROT2]WSTDES=[F:MWS]WSTDES
         #LECTURE du libellé traduisible
         Call LECTEXTRA([M:ROT2]WSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
         [M:ROT2]WSTTYP=[F:MWS]WSTTYP
         [M:ROT2]XWSTTYP = format$("K:2X", mess([M:ROT2]WSTTYP,313,1))
         If !GIMPORT
             Affzo [ROT2]WCR
             Affzo [ROT2]XWSTTYP
             Affzo [ROT2]WSTDES
         Endif
      Endif
   Endif
   If [M:ROT2]LABWST <> ""
      Read [MWS]WST0=[M:ROT2]LABWST;VALEUR
      If ! fstat
         [M:ROT2]LABWCR=[F:MWS]WCR
#         [M:ROT2]LABWSTDES=[F:MWS]WSTDES
         #LECTURE du libellé traduisible
         Call LECTEXTRA([M:ROT2]LABWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
         [M:ROT2]LABWSTTYP=[F:MWS]WSTTYP
         [M:ROT2]XLABWSTTYP = format$("K:2X",mess([M:ROT2]LABWSTTYP, 313,1))
         If !GIMPORT
             Affzo [ROT2]LABWCR
             Affzo [ROT2]XLABWSTTYP
             Affzo [ROT2]LABWSTDES
         Endif
      Endif
   Endif
Endif
End

