#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA - 2017-02-18- X3-12098- START
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ODPAYANU","DODPAYANU",3,"") From GTRAITE
End

################################################################################
$ACTION
Case ACTION
 When "INIT"       : Gosub OUVRE
 When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"   : TRA = 1
 When "EXEC"       : Gosub EXEC
 When "SEL_TABLE"  : Gosub SEL_TABLE
Endcase
Return

$OUVRE
Local Integer OKOD, DIMVAR, I
Local Char    CRITERE(250)
Local Char    SYMBOLE(80) :#Attention car en réalité SYMBOLE limite superv à 50 caract !(Cf. table APLLCK)

If clalev([F:VEP])=0  : Local File VALEMP [VEP]  : Endif
If clalev([F:ODE])=0  : Local File ODPAYE [ODE]  : Endif
If clalev([F:ODP])=0  : Local File ODPAY  [ODP]  : Endif
If clalev([F:ODP1])=0  : Local File ODPAY  [ODP1]  : Endif
If clalev([F:ODA])=0  : Local File ODPAYA [ODA]  : Endif
Return

$INIT_DIA
Raz [M:DIA]
Return

$EXEC
If GSERVEUR
 [M:DIA]TRCFLG = 2
Endif
If !GSERVEUR & [M:DIA]TRCFLG=2
#MIPEA - 2017-02-18- X3-12098- START
 Call OUVRE_TRACE(mess(73,10703,1)) From LECFIC : # Annulation Od de paye
# Call OUVRE_TRACE(mess(73,703,1)) From LECFIC : # Annulation Od de paye
#MIPEA - 2017-02-18- X3-12098- END
Endif
If [M:DIA]TRCFLG=2
#MIPEA - 2017-02-18- X3-12098- START
 Call ECR_TRACE(mess(73,10703,1),0) From GESECRAN
# Call ECR_TRACE(mess(73,703,1),0) From GESECRAN
#MIPEA - 2017-02-18- X3-12098- END
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

CRITERE = "[F:ODP]PST=1"      : #Non validée

If [M:DIA]ODPNUMDEB<>""       : #Numéro OD
 CRITERE -= '& [F:ODP]ODPNUM >= "'+[M:DIA]ODPNUMDEB+'"'
Endif
If [M:DIA]ODPNUMFIN<>""       : #Numéro OD
 CRITERE -= '& [F:ODP]ODPNUM <= "'+[M:DIA]ODPNUMFIN+'"'
Endif
If [M:DIA]MATDEB<>""          : #Matricule
 CRITERE -= '& [F:ODP]EMP >= "'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>""          : #Matricule
 CRITERE -= '& [F:ODP]EMP <= "'+[M:DIA]MATFIN+'"'
Endif
If [M:DIA]DATDEB<>[0/0/0]     : #Date paye
 CRITERE -= '& [F:ODP]PYRDAT >= [M:DIA]DATDEB '
Endif
If [M:DIA]DATFIN<>[0/0/0]     : #Date paye
 CRITERE -= '& [F:ODP]PYRDAT <= [M:DIA]DATFIN '
Endif

OKOD = 0

#MIPEA - 2017-02-18- X3-12098- START
Call TEMPON(mess(73,10703,1)) From GESECRAN : # Annulation Od de paye
#Call TEMPON(mess(73,703,1)) From GESECRAN : # Annulation Od de paye
#MIPEA - 2017-02-18- X3-12098- END

Filter [ODP] Where evalue(CRITERE)

For [ODP]ODP1(2)
 DIMVAR +=1
Next

If DIMVAR=0
 Local Char SVGSYM(50)
Else
 Local Char SVGSYM(50)(1..DIMVAR)
Endif

I = 0 : OK = 1
For [ODP]ODP1(2)
 ##**82073
 #SYMBOLE = "VEP"+format$("D:"+GFMDAT4,[F:ODP]PYRDAT)+"\"+[F:ODP]EMP+"\"+[F:ODP]CTRNUM
 Call VEPSYMBOLE (SYMBOLE, "ODP") From DIVPAYE
 Lock =SYMBOLE
 If fstat
  # Opération en cours sur autre poste
  Call ECR_TRACE(mess(30,100,1)-[F:ODP]EMP-num$([F:ODP]PYRDAT),1) From GESECRAN
  OK = 0 : Break
 Endif
 I +=1
 SVGSYM(I) = SYMBOLE
Next

If OK=1
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif

For I=1 To DIMVAR
 SYMBOLE = SVGSYM(I)
 Unlock =SYMBOLE
Next
Filter [ODP]

$FIN
Call TEMPOFF From GESECRAN
If OKOD=0
#MIPEA - 2017-02-18- X3-12098- START
 Call ECR_TRACE(mess(74,10703,1),0) From GESECRAN : # Pas d'OD à annuler
# Call ECR_TRACE(mess(74,703,1),0) From GESECRAN : # Pas d'OD à annuler
#MIPEA - 2017-02-18- X3-12098- END
Endif
If !GSERVEUR & [M:DIA]TRCFLG=2
 Call FERME_TRACE From LECFIC
Endif
Return

$TR1
Trbegin [ODE],[ODP],[ODA],[VEP]
 For [ODP]ODP2(1) With Stability
  # Mise à jour flag PST (Non comptabilisé) dans VALEMP
  Readlock [VEP]VEP5=[F:ODP]BUL
  If fstat=1
   GOK = -1 : GLOCK = "$VALEMP"-[F:ODP]BUL-[F:ODP]EMP-num$([F:ODP]PYRDAT) : Break
  Elsif fstat
   GOK = 0 : Call RSTA("VEP",[F:ODP]BUL-[F:ODP]EMP) From GLOCK : Break
  Endif
  [F:VEP]PST = 1
  Rewrite [VEP]
  If fstat
   GOK = 0 : Call FSTA("VEP") From GLOCK : Break
  Endif
  OKOD = 1
#MIPEA - 2017-02-18- X3-12098- START
  Call ECR_TRACE([F:ODP]ODPNUM+" : "+mess(80,10703,1)+space$(1)+format$("K:15X",[F:ODP]EMP)+space$(1)+mess(104,10703,1)+space$(1)+[F:ODP]BUL+space$(1)+mess(94,100,1)+space$(1)+num$([F:ODP]PYRDAT),0)
& From
& GESECRAN
#  Call ECR_TRACE([F:ODP]ODPNUM+" : "+mess(80,703,1)+space$(1)+format$("K:15X",[F:ODP]EMP)+space$(1)+mess(104,703,1)+space$(1)+[F:ODP]BUL+space$(1)+mess(94,100,1)+space$(1)+num$([F:ODP]PYRDAT),0) From
#& GESECRAN
#MIPEA - 2017-02-18- X3-12098- END
 Next

 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 For [ODP]ODP0
  # Suppression ODPAYA Analytique
  Delete [ODA] Where ODPNUM=[F:ODP]ODPNUM & ODPLIG=[F:ODP]ODPLIG
  If fstat=1
   GOK = -1 : GLOCK = "ODPAYA"-[F:ODA]ODPNUM : Break
  Endif

  # Suppression ODPAY Détail des lignes
  Delete [ODP1] Where ODPNUM=[F:ODP]ODPNUM & ODPLIG=[F:ODP]ODPLIG
  If fstat=1
   GOK = -1 : GLOCK = "ODPAY"-[F:ODP]ODPNUM : Break
  Endif

  Look[ODP1]ODP0(1)=[F:ODP]ODPNUM
  If fstat : # Plus d'enregistrement ODPNUM dans ODPAY
   Delete [ODE] Where ODPNUM=[F:ODP]ODPNUM
   If fstat=1
    GOK = -1 : GLOCK = "ODPAYE"-[F:ODP]ODPNUM : Break
   Endif
  Endif
 Next

 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$SEL_TABLE
Case TABLE
 When "SELODP"    : Gosub SELODP : # Sélection OD
 When "SELEMP"    : Gosub SELEMP : # Sélection matricule
Endcase
Return

$SELODP
OBJET      = "ODP"
CRITERE(1) = "ODPLIG=1 & PST=1"
OPTIONS    = "|"
Return

$SELEMP
OBJET   = "EML"
CRITERE = "ENAFLG=2"
Return


########################################
Subprog C_ODPNUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ODPNUMDEB
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2
Endif
End

Subprog C_MATFIN(VALEUR)
Variable Char    VALEUR()
Call C_MATFIN(VALEUR) From DIVPAYE
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:DIA]DATDEB
#MIPEA - 2017-02-18- X3-12098- START
 GMESSAGE = mess(25,10702,1) : # Période incorrecte
# GMESSAGE = mess(25,702,1) : # Période incorrecte
#MIPEA - 2017-02-18- X3-12098- END
 mkstat = 2 : End
Endif
End
#MIPEA - 2017-02-18- X3-12098- END

