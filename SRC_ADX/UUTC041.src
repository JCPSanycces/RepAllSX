#<AdxTL>@(#)2.0.0.0 $Revision$
# MAF 05/31/2012 : 81683
# UUTC041  Table TABDEPAGIO Initialization of DEPTYP
#          Table PFOOTINV   Initialization of DEPFLG
#          Table SFOOTINV   Initialization of DEPFLG

Call MAJ_UUTC041(nomap)
End

########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
Call MAJ_UUTC041(APPLI)
End

########################################################################
Subprog MAJ_UUTC041(DOSSIER)
Value Char DOSSIER

If DOSSIER=GDOSX3 : End : Endif
#------------------------------------------------------
Call ECR_TRACE("--------------------------------------",0) From GESECRAN
Call ECR_TIME("DOSSIER : "+DOSSIER) From DOSSUB
Call ECR_TIME("Table TABDEPAGIO Initialization of DEPTYP") From DOSSUB
Call ECR_TIME("Table PFOOTINV,SFOOTINV Initialization of DEPFLG") From DOSSUB
#------------------------------------------------------
Call MAJ_UTITC41(DOSSIER) From UTITC41
Call ECR_TIME("FIN => Table TABDEPAGIO Initialization of DEPTYP") From DOSSUB
Call ECR_TIME("FIN => Table PFOOTINV,SFOOTINV Initialization of DEPFLG") From DOSSUB
#------------------------------------------------------
End
