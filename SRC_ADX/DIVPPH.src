End

Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    Grizo ALLCPY
    Actzo ALLFCY
    If dim([M]CPY) > 0
        Actzo CPY
    Endif
    If dim([M]CRICPY) > 0
        Actzo CRICPY
    Endif
    mkstat = 1
    End
Endif
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If [L]VALEUR = 2
    [M]ALLFCY=2 : Affzo ALLFCY : Diszo ALLFCY
    If dim([M]CPY) > 0
        Effzo CPY,FCY : Diszo CPY,FCY
    Endif
    If dim([M]CRICPY) > 0
        Effzo CRICPY, CRIFCY : Diszo CRICPY, CRIFCY
    Endif
Else
    Actzo ALLFCY
    If dim([M]CPY) > 0
        Actzo [M]CPY
    Endif
    If dim([M]CRICPY) > 0
        Actzo [M]CRICPY
    Endif
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]ALLCPY=2 : mkstat = 1 : End : Endif
End

Subprog AS_CRICPY(VALEUR)
Variable Char     VALEUR
If [M]ALLCPY=2 : mkstat = 1 : End : Endif
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR

  If [M]ALLCPY=2 : VALEUR = 2 : End : Endif
  If dim([M]CPY)>=0
   Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
  Endif
  If dim([M]CRICPY)>=0
   Call INIALLFCY(VALEUR,[M]CRICPY) From CPTTRT
  Endif
  If VALEUR=2
      If dim([M]FCY) > 0
          Effzo FCY : Grizo [M]FCY
      Endif
      If dim([M]CRIFCY) > 0
          Effzo [M]CRIFCY : Grizo [M]CRIFCY
      Endif
  Else
      If dim([M]FCY) > 0
          Actzo [M]FCY
      Endif
      If dim([M]CRIFCY) > 0
          Actzo [M]CRIFCY
      Endif
  Endif

End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR

  If VALEUR=2
      If dim([M]FCY) > 0
          Effzo FCY : Diszo FCY
      Endif
      If dim([M]CRIFCY) > 0
          Effzo CRIFCY : Diszo CRIFCY
      Endif
  Else
      If dim([M]FCY) > 0
          Actzo FCY
      Endif
      If dim([M]CRIFCY) > 0
          Actzo CRIFCY
      Endif
  Endif

End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR
If [M]ALLFCY=2 : mkstat = 1 : End : Endif
End

Subprog AS_CRIFCY(VALEUR)
Variable Char    VALEUR
If [M]ALLFCY=2 : mkstat = 1 : End : Endif
End

$SEL_FCY
[L]OBJET="FCY"
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",[L]PARAM(1),"") From CONTOBJ
If fstat : Return : Endif
If [F:CPY]CPYLEGFLG=2
 [L]CRITERE(1)="LEGCPY='"+[L]PARAM(1)+"'"
 If [V]GUSRFCY(1)<>"\"
  [L]CRITERE(1)-="& find(FCY,[V]GUSRFCY(1..[V]GNBAUZ))"
 Endif
Else
 If !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif
 If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
 If [V]GUSRFCY(1)="\"
  Link [FGR] With [FCY]FCY0=FCY As [LNK] Where CPY=[L]PARAM(1)
 Else
  Link [FGR] With [FCY]FCY0=FCY
&              As [LNK]
&           Where CPY=[L]PARAM(1) & find(FCY,[V]GUSRFCY(1..[V]GNBAUZ))
 Endif
 Local Libelle CHXLNK
Endif
Return

Subprog AS_ALLSRV(VALEUR)
Variable Integer  VALEUR
Grizo ALLSRV
Actzo ALLSRV
If dim([M]SRV) > 0
    Actzo SRV
Endif
If dim([M]CRISRV) > 0
    Actzo CRISRV
Endif
End

Subprog C_ALLSRV(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    If dim([M]SRV) > 0
        Effzo SRV : Diszo SRV
    Endif
    If dim([M]CRISRV) > 0
        Effzo CRISRV : Diszo CRISRV
    Endif
Else
    If dim([M]SRV) > 0
        Actzo SRV
    Endif
    If dim([M]CRISRV) > 0
        Actzo CRISRV
    Endif
Endif
End

Subprog AS_SRV(VALEUR)
Variable Char     VALEUR
If [M]ALLSRV = 2 : mkstat = 1 : End : Endif
If VALEUR="" : VALEUR = GSRVDEF : Endif
End

Subprog AS_CRISRV(VALEUR)
Variable Char     VALEUR
If [M]ALLSRV = 2 : mkstat = 1 : End : Endif
If VALEUR="" : VALEUR = GSRVDEF : Endif
End

Subprog AS_ALLPRF(VALEUR)
Variable Integer  VALEUR
Grizo ALLPRF
Actzo ALLPRF
If dim([M]PRF) > 0
    Actzo PRF
Endif
If dim([M]CRIPRF) > 0
    Actzo CRIPRF
Endif
End

Subprog C_ALLPRF(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    If dim([M]PRF) > 0
        Effzo PRF : Diszo PRF
    Endif
    If dim([M]CRIPRF) > 0
        Effzo CRIPRF : Diszo CRIPRF
    Endif
Else
    If dim([M]PRF) > 0
        Actzo PRF
    Endif
    If dim([M]CRIPRF) > 0
        Actzo CRIPRF
    Endif
Endif
End

Subprog AS_PRF(VALEUR)
Variable Char  VALEUR
If [M]ALLPRF = 2 : mkstat = 1 : End : Endif
If VALEUR="" : VALEUR = GPRFDEF : Endif
End

Subprog AS_CRIPRF(VALEUR)
Variable Char  VALEUR
If [M]ALLPRF = 2 : mkstat = 1 : End : Endif
If VALEUR="" : VALEUR = GPRFDEF : Endif
End

Subprog GET_PARCPT(MODULE, POSITION, CODNUM, MANCOU)
Value Integer MODULE, POSITION
Variable Char CODNUM()
Variable Integer MANCOU
Local Integer STAT


#Local File TABCOUAFF [WTCA]
#
#Raz [L]CODNUM, [L]MANCOU
#Read [F:WTCA]TCA0 = [L]MODULE                  : # Lecture des affectations du module (15=Admin des RH)
#If fstat = 0
#    [L]CODNUM = [F:WTCA]CODNUM([L]POSITION)    : # Récupération du compteur (HRPPH=7)
#    [L]MANCOU = [F:WTCA]MANCOU([L]POSITION)    : # Compteur manuel (on le récupére par principe,
#                                                 # non géré car bloqué à non en dur dans la paye )
#
#    [L]MANCOU = 2    # On autorise de force les compteurs manuels
#Endif
#
#Close Local File [WTCA]

Raz [L]CODNUM, [L]MANCOU

Call LECTCA([L]MODULE,STAT) From SUBTCA
If STAT
  [L]WCODNUM= [F:TCA]CODNUM([L]POSITION)
  [L]MANCOU = 2    # On autorise de force les compteurs manuels
Endif

End

Funprog IS_AUTHVAR(VRACOD, LEG)
Value Char VRACOD()
Value Char LEG()

If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
If clalev([F:VRA]) = 0 : Local File VARIA [VRA] : Endif

Local Integer AUTHVAR
[L]AUTHVAR = 1

If [V]GUSRACS <> 2
    Read [F:VRA]VRA0 = [L]LEG;[L]VRACOD
    If fstat = 0 & [F:VRA]CODACC<>""
        Read [ACC]CODACC = [V]GUSER ; [F:VRA]CODACC
        If fstat <> 0 or ( fstat = 0 & [F:ACC]MODIF <> 2 )
            [L]AUTHVAR = 0
        Endif
    Endif
Endif

End [L]AUTHVAR

