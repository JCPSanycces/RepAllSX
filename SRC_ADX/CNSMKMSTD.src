#<AdxTL>@(#)11.0.0.0 $Revision$ Consultation MKM
##################################################
#                                                #
#    Consultation des consommations              #
#                                       06/01    #
##################################################

########################################################
#
# Parametres de consultation via PARAM()
#
#
#1 = site
#
#2 = date suivi
#
#3 = article
#
#4 = n° de suivi
#
#5 = n° O.F.
#
#6 = Article lancé
#
#7 = Nomenclature
#
#8 = ALTERNATIVE de Nomenclature
#
#9 = OPERATION
#
#10 = Affaire
#
#11 = Commande
#
#12 = TRI
#
#    1- N° de suivi
#    2- Date suivi
#    3- N° OF
#    4- Article
#
##########################################################


Local Char PARAM(20)(1..12)
PARAM(1) ="GAL"
PARAM(2) =""
PARAM(3) =""
PARAM(4) =""
PARAM(5) =""
PARAM(6) =""
PARAM(7) =""
PARAM(8) =""
PARAM(9) =""
PARAM(10)=""
PARAM(11)=""
PARAM(12)=""
Call GCONSULT("MKM", "",PARAM) From GCONSULT
End


##################################################
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "LECTURE"  : Gosub LECTURE
 When "DEB_CRIT" : Gosub DEB_CRIT
 When Default
Endcase
Return

##################################################
$OUVRE

Integer I
Local Char CRITERE(255)
Local Char CRITERE1(255)
Local Char CRITERE2(255)
Local Char CRITERE3(255)
Local Char CRITERE4(255)
Local Char DEBNUM(GLONVCR)    , FINNUM(GLONVCR)
Local Char DEBMFGNUM(GLONVCR) , FINMFGNUM(GLONVCR)
Local Char DEBITM(GLONITM)    , FINITM(GLONITM)
Local Date DEBDAT, FINDAT
Local Integer WSRT


If clalev ([F:FCY]) <= 0 : Local File FACILITY [FCY] : Endif

Gosub DEFCRIT

If !find ([M:CMKM]TRI,1,2,3,4) : [M:CMKM]TRI=1 : Endif

# Mail TS du 18/03/08
NAVIG="CONSMKM"
Return

##################################################
$DEFCRIT

#chargement par defaut : en fonction du site et de la date du jour


For I= 1 To dim(PARAM)
    Case I
        When 1 :     #site
            If  PARAM(I)<> ""
                Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                If !fstat & [F:FCY]MFGFLG = 2 : [M:MKM1]MFGFCY = PARAM(I) : Endif
            Endif
        When 2 :     #article
            If  PARAM(I)<> ""
                Read [ITM]ITM0 =  PARAM(I)
                If ! fstat
                    [M:MKM1]ITMREFDEB = PARAM(I)
                    [M:MKM1]ITMREFFIN = PARAM(I)
                Endif
            Endif
        When 3 :      #date suivi
            If  PARAM(I)<> ""
                If instr(1, PARAM(I),"/")
                   [M:MKM1]MFGDATDEB = "["+PARAM(I)+"]"
                   [M:MKM1]MFGDATFIN = "["+PARAM(I)+"]"
                Else
                   [M:MKM1]MFGDATDEB= PARAM(I)
                   [M:MKM1]MFGDATFIN= PARAM(I)
                Endif
            Endif
            If [M:MKM1]MFGDATDEB = [0/0/0]
                [M:MKM1]MFGDATDEB = date$ :  [M:MKM1]MFGDATFIN = date$
            Endif

       When 4 :     # n° de suivi
            If  PARAM(I)<>  ""
                   [M:MKM1]MFGTNUMDEB = PARAM(I)
                   [M:MKM1]MFGTNUMFIN = PARAM(I)
            Endif
       When 5 :     # n° O.F.
             If  PARAM(I)<> ""
               [M:MKM1]MFGNUMDEB = PARAM(I)
               [M:MKM1]MFGNUMFIN = PARAM(I)
            Endif
       When 6 :    # Article lancé
            If  PARAM(I)<> ""
               [M:CMKM]RELITMDEB = PARAM(I)
               [M:CMKM]RELITMFIN = PARAM(I)
            Endif
       When 7 :    # Nomenclature
            If  PARAM(I)<> ""
               [M:CMKM]BOMNUMDEB = PARAM(I)
               [M:CMKM]BOMNUMFIN = PARAM(I)
            Endif
       When 8 :    # ALTERNATIVE de Nomenclature
            If  PARAM(I)<> ""
               [M:CMKM]BOMALTDEB = val(PARAM(I))
               [M:CMKM]BOMALTFIN = val(PARAM(I))
            Endif
            If PARAM(I) = "" : [M:CMKM]BOMALTDEB = 0: [M:CMKM]BOMALTFIN = 0 : Endif
       When 9 :     # OPERATION
            If  PARAM(I)<> ""
               [M:CMKM]OPENUMDEB = val(PARAM(I))
               [M:CMKM]OPENUMFIN = val(PARAM(I))
            Endif
            If PARAM(I)= "" : [M:CMKM]OPENUMDEB = 0 : [M:CMKM]OPENUMFIN = 0 : Endif
       When 10 : # Affaire
            If  PARAM(I)<> ""
                 [M:CMKM]PJTDEB = PARAM(I)
                 [M:CMKM]PJTFIN= PARAM(I)
                 # Issue X3-25731 - 2017-02-24 by FGR : BEGIN
                 If find(GNAVIG(GPILNAV-0),"GESPJM") Then   # Note FGR : '-0' is not an error. This is true in this case.
                   [M:CMKM]PJTDSPALL = [V]CST_AYES
                 Endif
                 # Issue X3-25731 - 2017-02-24 by FGR : END
            Endif
       When 11 : # Commande
            If  PARAM(I)<> ""
                 [M:CMKM]VCRORIDEB = PARAM(I)
                 #[M:CMKM]VRCORIFIN = PARAM(I)  # FGR 14/01/2010 : X3SUIVI60986
                 [M:CMKM]VCRORIFIN = PARAM(I)   # FGR 14/01/2010 : X3SUIVI60986
            Endif
       When 12: # Tri
            If PARAM(I)<> ""
                WSRT = val(PARAM(I))
                If WSRT<0 | WSRT > 4 : WSRT = 1 : Endif
                [M:CMKM]TRI = WSRT
            Endif
       When Default : Break

    Endcase
Next I


# Copie de l'ecran d'entête / ecran de criteres
Gosub CRITENT From =PROGCNS
Return
##################################################
$DEB_CRIT
#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
           Diszo [M:CMKM]ITMREFDEB
           Diszo [M:CMKM]ITMREFFIN
    Endif
    # Issue X3-25731 - 2017-02-24 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CMKM]PJTDEB
      Diszo [M:CMKM]PJTFIN
    Endif
    # Issue X3-25731 - 2017-02-24 by FGR : END
Endif

Return
##################################################
$LECTURE

#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:MKM1]ITMREFDEB
        Diszo [M:MKM1]ITMREFFIN
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:MKM1]ITMREFDEB
        Diszo [M:MKM1]ITMREFFIN
        Diszo [M:MKM1]MFGFCY
    Endif
Endif

# Si le tri n'est pas passé en paramètre, pas de chargement automatique
If [M:MKM1]MFGFCY ="" : NBLU= 0 : Return : Endif
If PARAM(11)="" : PARAM(11)="1" : Endif

#-- Changement d'écran paramétrable
Gosub CHANGE_MSK From GCONSULT
If CHGPAG <0 : NOL = MAXLIG : Endif

#-- Positionnement des filtres
Gosub LOAD_FILTER
# sr 10.04 demande 26046
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif


#########################################################
#                                                       #
#    CHGPAG = 1  : Recherche                            #
#    ------ = 2  : Suite                                #
#    ------ = 3  : F5 (Rafraichissement page courante)  #
#                                                       #
#    CHGPAG = -1 : Dernier                              #
#    ------ = -2 : Retour (page precedente)             #
#                                                       #
#########################################################



#-- Application du filtre et positionnement des boutons
If CHGPAG >0
    SUITE = 1
    If CHGPAG = 1 : RETOUR =1    #recherche
    Elsif CHGPAG = 2 : RETOUR = 2   # suite
    Endif
    Case [M:CMKM]TRI
      When 1 : # Tri par n° de suivi
        Link [MKM] With [F:MTK]MTK0 = [F:MKM]MFGTRKNUM, [F:MFI]MFI0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue (CRITERE4)
&       Order By Key CLE=[F:MKM]MFGTRKNUM
      When 2 : # Tri par date suivi
        Link [MKM] With [F:MTK]MTK0 = [F:MKM]MFGTRKNUM, [F:MFI]MFI0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue (CRITERE4)
&       Order By Key CLE=[F:MTK]MFGTRKDAT
      When 3 : # Tri par n° OF
        Link [MKM] With [F:MTK]MTK0 = [F:MKM]MFGTRKNUM, [F:MFI]MFI0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue (CRITERE4)
&       Order By Key CLE= [F:MKM]MFGNUM
      When 4 : # Tri par article
        Link [MKM] With [F:MTK]MTK0 = [F:MKM]MFGTRKNUM, [F:MFI]MFI0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue (CRITERE4)
&       Order By Key CLE= [F:MKM]ITMREF
    Endcase
Else
    RETOUR = 1
    If CHGPAG = -1 : SUITE =1    #dernier
    Elsif CHGPAG =-2 : SUITE = 2 #retour
    Endif

    Case [M:CMKM]TRI
      When 1 : # Tri par n° de suivi
        Link [MKM] With [F:MTK]MTK0 = [F:MKM]MFGTRKNUM,  [F:MFI]MFI0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)& evalue (CRITERE4)
&       Order By Key CLE=[F:MKM]MFGTRKNUM Desc
     When 2 : # Tri par date suivi
        Link [MKM] With [F:MTK]MTK0 = [F:MKM]MFGTRKNUM,  [F:MFI]MFI0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)& evalue (CRITERE4)
&       Order By Key CLE= [F:MTK]MFGTRKDAT Desc
     When 3 : # Tri par n° OF
        Link [MKM] With [F:MTK]MTK0 = [F:MKM]MFGTRKNUM,  [F:MFI]MFI0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)& evalue (CRITERE4)
&       Order By Key CLE= [F:MKM]MFGNUM Desc
     When 4 : # Tri par article
        Link [MKM] With [F:MTK]MTK0 = [F:MKM]MFGTRKNUM,  [F:MFI]MFI0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)& evalue (CRITERE4)
&       Order By Key CLE= [F:MKM]ITMREF Desc
    Endcase
Endif

#-- RAZ du masque
       If CHGPAG<>2 | CHGPAG<>-2 : Raz [M:MKM2] : Endif

#--  Lecture

For[LIE]

  If NBLU = 1
    If CHGPAG=2 | CHGPAG=-2 : Raz [M:MKM2] : Endif
    NBLU = 2
  Endif

  If CHGPAG >0
      If NOL>=MAXLIG-1 : SUITE = 2 : Break : Endif
      NOL +=1
      If NOL = 0
        DEBNUM = [F:MKM]MFGTRKNUM
        DEBDAT = [F:MTK]MFGTRKDAT
        DEBMFGNUM = [F:MKM]MFGNUM
        DEBITM = [F:MKM]ITMREF
      Endif
        FINNUM = [F:MKM]MFGTRKNUM
        FINDAT = [F:MTK]MFGTRKDAT
        FINMFGNUM = [F:MKM]MFGNUM
        FINITM = [F:MKM]ITMREF
  Else
     If NOL <=0 : RETOUR = 2 : Break : Endif
     NOL -=1
     If NOL = MAXLIG -1
        FINNUM = [F:MKM]MFGTRKNUM
        FINDAT = [F:MTK]MFGTRKDAT
        FINMFGNUM = [F:MKM]MFGNUM
        FINITM = [F:MKM]ITMREF
     Endif
        DEBNUM = [F:MKM]MFGTRKNUM
        DEBDAT = [F:MTK]MFGTRKDAT
        DEBMFGNUM = [F:MKM]MFGNUM
        DEBITM = [F:MKM]ITMREF
  Endif


 nolign = NOL +1
 [M:MKM2]MFGTRKNUM(nolign-1)  = [F:MKM]MFGTRKNUM
 [M:MKM2]MATTRKLIN(nolign-1)  = [F:MKM]MATTRKLIN
 [M:MKM2]MFGLIN(nolign-1)     = [F:MKM]MFGLIN
 [M:MKM2]ITMREF(nolign-1)     = [F:MKM]ITMREF
 [M:MKM2]MATTYP(nolign-1)     = [F:MKM]MATTYP
 [M:MKM2]STU(nolign-1)        = [F:MKM]STU
 [M:MKM2]USEQTY(nolign-1)     = [F:MKM]USEQTY
 [M:MKM2]IPTDAT(nolign-1)     = [F:MKM]IPTDAT
 [M:MKM2]TYPQTY(nolign-1)     = [F:MKM]TYPQTY
 If [M:MKM2]TYPQTY(nolign-1) = 0 : [M:MKM2]TYPQTY(nolign-1) = 2 : Endif
 [M:MKM2]MFMITMREF(nolign-1)  = [F:MKM]MFMITMREF
 [M:MKM2]BOMSEQ(nolign-1)     = [F:MKM]BOMSEQ
 [M:MKM2]LOTPREF(nolign-1)    = [F:MKM]LOTPREF
     If  [M:MKM2]LOTPREF(nolign-1)='*' :  [M:MKM2]LOTPREF(nolign-1)  = ' ': Endif
 [M:MKM2]LOCPREF(nolign-1)    = [F:MKM]LOCPREF
     If  [M:MKM2]LOCPREF(nolign-1)='*' :  [M:MKM2]LOCPREF(nolign-1)  = ' ': Endif
 [M:MKM2]STAPREF(nolign-1)    = [F:MKM]STAPREF
 [M:MKM2]MFGNUM(nolign-1)     = [F:MKM]MFGNUM

 If dim([F:MKM]ECCVALMAJ)>0 & dim([M:MKM2]ECCVALMAJ)>0  # Issue 107513 GA 04/2015
   [M:MKM2]ECCVALMAJ(nolign-1)  = [F:MKM]ECCVALMAJ
   [M:MKM2]ECCVALMIN(nolign-1)  = [F:MKM]ECCVALMIN
 Endif

Case MATTYP(nolign-1)
    When 1             # si type matiere = O.F.
     [M:MKM2]PJT(nolign-1)        = [F:MFI]PJT
     [M:MKM2]VCRNUMORI(nolign-1)  = [F:MFI]VCRNUMORI
     [M:MKM2]BOMNUM(nolign-1)  = [F:MFI]ITMREF
     [M:MKM2]BOMALT(nolign-1)     = [F:MFI]BOMALT
    When Default :     # si type matiere = NOMENCLATURE ou rien
     [M:MKM2]BOMNUM(nolign-1)     = [F:MKM]BOMNUM
     [M:MKM2]BOMALT(nolign-1)     = [F:MKM]BOMALT
 Endcase

 [M:MKM2]OPENUM(nolign-1)     = [F:MKM]OPENUM
 [M:MKM2]CPLWST(nolign-1)     = [F:MKM]CPLWST
 [M:MKM2]MFGTRKDAT(nolign-1)  = [F:MTK]MFGTRKDAT
 [M:MKM2]RELITM(nolign-1)     = [F:MFI]ITMREF
 # Issue 92219 GA 10/2013
 # PE permettant de faire apparaitre dans la consultation des champs spécifiques de tables (idem CNSMKOSTD)
 GPOINT = "MKMMAJ" : Gosub ENTREE From EXEFNC

Next


Return



##################################################
$LOAD_FILTER

Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3
Raz CRITERE4

#site
If [M:MKM1]MFGFCY <> ""
    CRITERE = "[F:MKM]MFGFCY=[M:MKM1]MFGFCY"
Gosub LOAD_CRITERE
Endif


#date suivie
If [M:MKM1]MFGDATDEB <> [0/0/0]
 CRITERE = "[F:MTK]MFGTRKDAT>=[M:MKM1]MFGDATDEB"
Gosub LOAD_CRITERE
Endif

If [M:MKM1]MFGDATFIN<>[0/0/0]
 CRITERE = "[F:MTK]MFGTRKDAT<=[M:MKM1]MFGDATFIN"
Gosub LOAD_CRITERE
Endif


#article
If [M:MKM1]ITMREFDEB <> ""
     CRITERE = "[F:MKM]ITMREF >=[M:MKM1]ITMREFDEB "
Gosub LOAD_CRITERE
Endif

If [M:MKM1]ITMREFFIN <> ""
     CRITERE = "[F:MKM]ITMREF <= [M:MKM1]ITMREFFIN "
Gosub LOAD_CRITERE
Endif


#N° de suivie
If [M:MKM1]MFGTNUMDEB <> ""
 CRITERE = "[F:MKM]MFGTRKNUM>=[M:MKM1]MFGTNUMDEB"
 Gosub LOAD_CRITERE
Endif

If [M:MKM1]MFGTNUMFIN<>""
 CRITERE = "[F:MKM]MFGTRKNUM<=[M:MKM1]MFGTNUMFIN"
 Gosub LOAD_CRITERE
Endif


# N° O.F.
If [M:MKM1]MFGNUMDEB<> ""
 CRITERE = "[F:MKM]MFGNUM>=[M:MKM1]MFGNUMDEB"
 Gosub LOAD_CRITERE
Endif

If [M:MKM1]MFGNUMFIN<> ""
 CRITERE = "[F:MKM]MFGNUM<=[M:MKM1]MFGNUMFIN"
Gosub LOAD_CRITERE
Endif


# Article lancé
If [M:CMKM]RELITMDEB<>""
 CRITERE = "[F:MFI]ITMREF >= [M:CMKM]RELITMDEB"
 Gosub LOAD_CRITERE
Endif

If [M:CMKM]RELITMFIN<>""
 CRITERE = "[F:MFI]ITMREF<= [M:CMKM]RELITMFIN"
 Gosub LOAD_CRITERE
Endif


# Nomenclature
If [M:CMKM]BOMNUMDEB<> ""
 CRITERE = "[F:MKM]BOMNUM>=[M:CMKM]BOMNUMDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKM]BOMNUMFIN<> ""
 CRITERE = "[F:MKM]BOMNUM<=[M:CMKM]BOMNUMFIN"
Gosub LOAD_CRITERE
Endif

# ALTERNATIVE de Nomenclature
If [M:CMKM]BOMALTDEB<> 0
 CRITERE = "[F:MKM]BOMALT>=[M:CMKM]BOMALTDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKM]BOMALTFIN<> 0
 CRITERE = "[F:MKM]BOMALT<=[M:CMKM]BOMALTFIN"
Gosub LOAD_CRITERE
Endif

#Operation
If [M:CMKM]OPENUMDEB<> 0
 CRITERE = "[F:MKM]OPENUM>=[M:CMKM]OPENUMDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKM]OPENUMFIN<> 0
 CRITERE = "[F:MKM]OPENUM<=[M:CMKM]OPENUMFIN"
Gosub LOAD_CRITERE
Endif

# Issue X3-25731 - 2017-02-24 by FGR : BEGIN
#Affaire
#If [M:CMKM]PJTDEB<> ""
# CRITERE = "[F:MFI]PJT>=[M:CMKM]PJTDEB"
#Gosub LOAD_CRITERE
#Endif
#
#If [M:CMKM]PJTFIN<> ""
# CRITERE = "[F:MFI]PJT<=[M:CMKM]PJTFIN"
#Gosub LOAD_CRITERE
#Endif
If dim([M:CMKM]PJTDSPALL) >= 0 and [M:CMKM]PJTDSPALL = [V]CST_AYES and [M:CMKM]PJTDEB <> "" Then
  Local Char SPJT(GLONPIM)
  Local Char SBUDGET(GLONTAC)
  Local Char STASK(GLONPBU)
  Local Integer IRET

  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CMKM]PJTDEB, SPJT, SBUDGET, STASK)
  CRITERE = "pat([F:MFI]PJT,'" + SPJT + "*')<>0"
  Gosub LOAD_CRITERE
Else
  If [M:CMKM]PJTDEB<> ""
   CRITERE = "[F:MFI]PJT>=[M:CMKM]PJTDEB"
  Gosub LOAD_CRITERE
  Endif

  If [M:CMKM]PJTFIN<> ""
   CRITERE = "[F:MFI]PJT<=[M:CMKM]PJTFIN"
  Gosub LOAD_CRITERE
  Endif
Endif
# Issue X3-25731 - 2017-02-24 by FGR : END

# Commande
If [M:CMKM]VCRORIDEB<> ""
 CRITERE = "[F:MFI]VCRNUMORI>=[M:CMKM]VCRORIDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKM]VCRORIFIN<> ""
 CRITERE = "[F:MFI]VCRNUMORI<=[M:CMKM]VCRORIFIN"
Gosub LOAD_CRITERE
Endif

# Type matière
If [M:CMKM]MATTYPDEB<> 0
 CRITERE ="[F:MKM]MATTYP>= [M:CMKM]MATTYPDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKM]MATTYPFIN<> 0
 CRITERE ="[F:MKM]MATTYP<= [M:CMKM]MATTYPFIN"
Gosub LOAD_CRITERE
Endif


Case CHGPAG
    When 3 : # rafraichissement
      Case [M:CMKM]TRI
         When 1 : # Tri par N° de suivi
              CRITERE ="[F:MKM]MFGTRKNUM >= DEBNUM"
              Gosub LOAD_CRITERE
         When 2 : # Tri par date suivi
              CRITERE = "[F:MTK]MFGTRKDAT >= DEBDAT"
              Gosub LOAD_CRITERE
         When 3 : # Tri par N° OF
              CRITERE = "[F:MKM]MFGNUM >= DEBMFGNUM"
              Gosub LOAD_CRITERE
         When 4 : # Tri par article
              CRITERE = "[F:MKM]ITMREF >= DEBITM"
              Gosub LOAD_CRITERE
     Endcase

    When 2 : #suite
      Case [M:CMKM]TRI
         When 1 : # Tri par N° de suivi
              CRITERE ="[F:MKM]MFGTRKNUM > FINNUM"
              Gosub LOAD_CRITERE
         When 2 : # Tri par date suivi
              CRITERE = "[F:MTK]MFGTRKDAT > FINDAT"
              Gosub LOAD_CRITERE
         When 3 : # Tri par N° OF
              CRITERE = "[F:MKM]MFGNUM > FINMFGNUM"
              Gosub LOAD_CRITERE
        When 4 :  # Tri par article
              CRITERE = "[F:MKM]ITMREF > FINITM"
              Gosub LOAD_CRITERE
      Endcase

    When -2 : #retour
      Case [M:CMKM]TRI
        When 1 : # Tri par N° de suivi
              CRITERE ="[F:MKM]MFGTRKNUM < DEBNUM"
              Gosub LOAD_CRITERE
        When 2 : # Tri par date suivi
              CRITERE ="[F:MTK]MFGTRKDAT < DEBDAT"
              Gosub LOAD_CRITERE
        When 3 : # Tri par N° OF
              CRITERE = "[F:MKM]MFGNUM < DEBMFGNUM"
              Gosub LOAD_CRITERE
        When 4 :  # Tri par article
              CRITERE = "[F:MKM]ITMREF < DEBITM"
              Gosub LOAD_CRITERE
      Endcase
Endcase

If CRITERE1 = "" : CRITERE1 ="1=1" : Endif
If CRITERE2 = "" : CRITERE2 ="1=1" : Endif
If CRITERE3 = "" : CRITERE3 ="1=1" : Endif
If CRITERE4 = "" : CRITERE4 ="1=1" : Endif

Return

####################################################
$LOAD_CRITERE
If len(CRITERE)+len(CRITERE1)+1 <255
    If len(CRITERE1) <>0 : CRITERE1 += "&" : Endif
    CRITERE1 += CRITERE
Elsif len(CRITERE)+len(CRITERE2)+1 <255
    If len(CRITERE2) <>0 : CRITERE2 += "&" : Endif
    CRITERE2 += CRITERE
Elsif len(CRITERE)+len(CRITERE3)+1 <255
    If len(CRITERE3) <>0 : CRITERE3 += "&" : Endif
    CRITERE3 += CRITERE
Else
    If len(CRITERE4) <>0 : CRITERE4 += "&" : Endif
    CRITERE4 += CRITERE
Endif

Return

