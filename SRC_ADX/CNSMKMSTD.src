########################################
Subprog IB_NBLIG
Local Integer L : L = nolign-1
#MAE/CCC : doc Ergonomie Beryl de GL
#Raz GBOUT1,GBOUT2, GBOUT3, GBOUT4
Raz GBOUT1,GBOUT2


GBOUT2 = mess(311,198,1)
If L>= 0
 If [M:MKM2]MFGNUM(L)<> ""    # on ne fait un tunnel que lorsqu'il s'agit d'un OF
    GBOUT1 = mess(166,198,1)
 Endif
 Read [MTK]MTK0 = [M:MKM2]MFGTRKNUM(L)
Endif
If [F:MTK]OPETRKFLG = 2
 If  clalev ([M:MKO1]) > 0 : GBOUT3 ="" : Endif
#MAE/CCC : doc Ergonomie Beryl de GL
 #Elsif clalev([M:MKO1])<=0 : GBOUT3= mess(436,198,1) : Endif
Endif

If [F:MTK]ITMTRKFLG = 2
 If  clalev ([M:MKI1]) > 0 : GBOUT4 ="" : Endif
#MAE/CCC : doc Ergonomie Beryl de GL
#Elsif clalev([M:MKI1])<=0 : GBOUT4= mess(435,198,1) : Endif
Endif

End

