########################################
Subprog C_NBRPOP
# Il est interdit de supprimer des populations mises à jour automatiquement'
# voir C_NBRPSN pour suppression une ou groupe
#If status=65 &  [M:CTR6]MAJTYP(nolign-1)=1 Then
# GMESSAGE = mess(1126,196,1)
# mkstat = 2 : End
#Endif
# suppression d'une ligne ou d'un groupe de lignes
# une ligne n'arrivera pas car pas possible par
Local Integer NOL
If (status=65 | status=83) Then
 If status=65
   If [M:CTR6]MAJTYP(nolign-1)=1 Then
     # Ligne x : Suppression impossible \ au - une population mise à jour automatiquement
     GMESSAGE = mess(1126,196,1)-":"-[M:CTR6]POP(nolign-1)
     mkstat = 2 : End
   Endif
 Else
   For NOL=nolign-1 To nolign1-1
    If [M:CTR6]MAJTYP(NOL)=1 Then
     # Ligne x : Suppression impossible \ au - une population mise à jour automatiquement
     GMESSAGE = mess(1126,196,1)-":"-[M:CTR6]POP(NOL)
     mkstat = 2 : End
    Endif
   Next
 Endif
Endif
If find(status,65,68,83,73,82,75)
 [M:CTR6]POPMOD = 1
Endif
End

