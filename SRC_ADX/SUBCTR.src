Subprog C_NBRPSN
If status=65 & [M]BUL(nolign-1)<>""
 # Suppression  impossible \ Une paie existe sur la prestation
 #JOJAC - 2016-06-02 - REQ114309 US215 - START
 #GMESSAGE = mess(32,701,1)
 GMESSAGE = mess(32,10701,1)
 #JOJAC - 2016-06-02 - REQ114309 US215 - END
 mkstat = 2 : End
Endif
If status=83
 For NOL=nolign-1 To nolign1-1
  If [M]BUL(NOL)<>""
   # Ligne x : Suppression  impossible \ Une paie existe sur la prestation
   #JOJAC - 2016-06-02 - REQ114309 US215 - START
   #GMESSAGE = mess(45,9009,1)-num$(NOL+1)-":"-mess(32,701,1)
   GMESSAGE = mess(45,9009,1)-num$(NOL+1)-":"-mess(32,10701,1)
   #JOJAC - 2016-06-02 - REQ114309 US215 - END
   mkstat = 2 : End
  Endif
 Next
Endif
End

