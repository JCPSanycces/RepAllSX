Subprog AM_WRKCODPOS(VALEUR)
Variable Char    VALEUR()
If clalev([F:POS])=0 : Local File POSCOD [POS] : Endif
Read [POS]POS0(3) = [M]WRKCRY;VALEUR;[M]WRKCTY
If fstat<=2
 [M]WRKCODSEE = [F:POS]POSCTYCOD
 Affzo WRKCODSEE
Endif
End

Subprog AM_WRKCTY(VALEUR)
Variable Char    VALEUR()
If clalev([F:POS])=0 : Local File POSCOD [POS] : Endif
If VALEUR<>""
 VALEUR=toupper(VALEUR)
 Read [POS]POS1 = [M]WRKCRY;VALEUR;[M]WRKCODPOS
 If fstat<=2
  [M]WRKCODSEE = [F:POS]POSCTYCOD
  Affzo WRKCODSEE
 Endif
Endif
End

