Subprog C_XITDAT(VALEUR)
Variable Date    VALEUR
If [M:CTR0]FLGVAR<>2
  Call CONTROLE_SORTIE([M]CTRDAT,VALEUR,[M]REFNUM,[M]CTRNUM)
 If mkstat : End : Endif
