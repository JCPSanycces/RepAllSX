Subprog C_TWDPAY(VALEUR)
Variable Integer VALEUR
Call GRISE_INFOS_ENVERS(VALEUR) From SUBCTR2
If VALEUR=2
 If [M]OBJRUB=""
  Call PARAM([M]ETRFCY,"PAERUB",[M]OBJRUB) From ADOVAL
  Affzo OBJRUB
 Endif
 If [M]OBJVAR=""
  Call PARAM([M]ETRFCY,"PAEVAL",[M]OBJVAR) From ADOVAL
  Affzo OBJVAR
 Endif
 If [M]INCVAR=""
  Call PARAM([M]ETRFCY,"PAEVAR",[M]INCVAR) From ADOVAL
  Affzo INCVAR
 Endif
Endif
End

