Subprog C_NBRPER(VALEUR)
Variable Decimal  VALEUR
End

########################################################
$SET_REFDAT
Local Date REFDAT
If [M]FLGRET<>2
 REFDAT=[M]CTRDAT
Else
 REFDAT=[M]RETDATEFF
Endif
Return

Subprog AM_NBRPER(VALEUR)
Variable Decimal VALEUR
Gosub SET_REFDAT
If VALEUR
 Case [M]PERCON
  When 1 : [M]ENDCON = [L]REFDAT+VALEUR-1              : # Jour
  When 2 : [M]ENDCON = [L]REFDAT+(VALEUR*7)-1          : # Semaine
  When 3 : [M]ENDCON = addmonth([L]REFDAT,VALEUR)-1    : # Mois
  When 4 : [M]ENDCON = addmonth([L]REFDAT,VALEUR*12)-1 : # Année
 Endcase
Else
 [M]ENDCON=[L]REFDAT
Endif
Affzo [M]ENDCON
End

Subprog C_PERCON(VALEUR)
Variable Integer  VALEUR
End

Subprog AM_PERCON(VALEUR)
Variable Integer VALEUR
Gosub SET_REFDAT
If [M]NBRPER
 Case VALEUR
  When 1 : [M]ENDCON = [L]REFDAT+[M]NBRPER-1              : #Jour
  When 2 : [M]ENDCON = [L]REFDAT+([M]NBRPER*7)-1          : #Semaine
  When 3 : [M]ENDCON = addmonth([L]REFDAT,[M]NBRPER)-1    : #Mois
  When 4 : [M]ENDCON = addmonth([L]REFDAT,[M]NBRPER*12)-1 : #Année
 Endcase
Else
 [M]ENDCON=[L]REFDAT
Endif
Affzo [M]ENDCON
End

Subprog C_ENDCON(VALEUR)
Variable Date     VALEUR
Gosub SET_REFDAT
If VALEUR<>[0/0/0] & VALEUR<[L]REFDAT
 #Une date de fin de contrat doit être supérieure à la date de début du contrat.
#JOJAC - 2016-06-02 - REQ114309 US215 - START
 #GMESSAGE=mess(137,702,1)
 GMESSAGE=mess(137,10702,1)
#JOJAC - 2016-06-02 - REQ114309 US215 - END
 mkstat=2 : End
Endif
If VALEUR=[0/0/0] & ([M]CDDGRD="REM" | [M]CDDGRD="RPL")
 GMESSAGE=mess(10,123,1) :# Zone Obligatoire
 mkstat=2 : End
Endif

If func ISKMIEA() and func DIVPAYE.EXISTE_KXX("SUBCTRMID")
    Call C_ENDCON(VALEUR) From SUBCTRMID
Endif

End

Subprog C_MATREMP(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]REFNUM
 # Un salarié en CDD de remplacement ne peut se remplacer lui-même
#JOJAC - 2016-06-02 - REQ114309 US215 - START
 #GMESSAGE = mess(25,701,1)
 GMESSAGE = mess(25,10701,1)
#JOJAC - 2016-06-02 - REQ114309 US215 - END
 mkstat = 2 : End
Endif
End

Subprog C_ENDTRY(VALEUR)
Variable Date     VALEUR
If VALEUR<>[0/0/0]
 Gosub SET_REFDAT
 If VALEUR<[L]REFDAT
  #Une date de fin de période d'essai doit être supérieure à la date de début du contrat.
#JOJAC - 2016-06-02 - REQ114309 US215 - START
  #GMESSAGE=mess(138,702,1)
  GMESSAGE=mess(138,10702,1)
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  mkstat=2 : End
 Endif
 If [M]ENDCON<>[0/0/0] & VALEUR>[M]ENDCON
  #Une date de fin de période d'essai doit être inférieure à la date de fin du contrat.
#JOJAC - 2016-06-02 - REQ114309 US215 - START
  #GMESSAGE=mess(139,702,1)
  GMESSAGE=mess(139,10702,1)
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  mkstat=2 : End
 Endif

  Call C_ENDTRY(VALEUR) From SUBCTR2

Endif
End

Subprog C_NEWTRY(VALEUR)
Variable Integer  VALEUR
Call GRISE_ESSAI2(VALEUR) From SUBCTR2
If VALEUR=2 & [M]ENDTRY=[0/0/0]
 # Une date de fin de période d'essai doit être saisie avant de renouveler la période d'essai
#JOJAC - 2016-06-02 - REQ114309 US215 - START
 #GMESSAGE = mess(113,702,1)
 GMESSAGE = mess(113,10702,1)
#JOJAC - 2016-06-02 - REQ114309 US215 - END
 mkstat = 2 : End
Endif
End

Subprog AM_NEWTRY(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]ENDTRY2
Endif
End

Subprog C_ENDTRY2(VALEUR)
Variable Date     VALEUR
If VALEUR<=[M]ENDTRY
 # La 2ème période d'essai doit se terminer après la période d'essai initiale
#JOJAC - 2016-06-02 - REQ114309 US215 - START
 #GMESSAGE = mess(112,702,1)
 GMESSAGE = mess(112,10702,1)
#JOJAC - 2016-06-02 - REQ114309 US215 - END
 mkstat = 2 : End
Endif

  Call C_ENDTRY2(VALEUR) From SUBCTR2

End

