#######################################################################################
# Modifications :
#     #Selection salarié dans fonction contrat si GREP<>"C"
#                                  Selection contrat par salarié
#                                  Test entrée au contrôle du motif CTRGRD
#                                  Repositionnement sur ACCCOD si code comptable est vide
#                                  ET SI LA Case INFOS COMPTABLES AU CONTRAT EST COCHÉE
#     #Synchronisation des populations
#     #Initialisation de TIP.CTRDAT selon règle métier
#     #[F:ID]REFNUM lost after tunnel on JOB Type , standard job
#     FQ92876-US2582 - Accounting Interface
#     SEGAY - 09/04/14 - FQ96877 FQ96876 : Update populations of inactive contract (old)
######################################################################################

########################################################


$ACTION
If dim([L]CSUBB)<=0
 Local Integer CSUBB
 Call EXISTE_ADX("","","SUBCTR2",CSUBB) From ORDSYS
Endif

Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "OUVRE_BOITE": Gosub OUVRE_BOITE
 When "LIENS"      : Gosub LIENS
 When "STYLE"      : Gosub STYLE
 When "GRISE"      : Gosub GRISE From SUBCTR2
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "RAZCRE"     : Gosub RAZCRE
 When "RAZDUP"     : Gosub RAZDUP
 When "CREATION"   : Gosub CREATION
 When "APRES_CRE"  : Gosub APRES_CRE
 When "APRES_MOD"  : Gosub APRES_MOD
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When "AV_VERF_ANU": Gosub AV_VERF_ANU
 When "SETBOUT"    : Gosub SETBOUT
 When "FILTRE"     : Gosub FILTRE
 When "FILGAUCHE"  : Gosub FILGAUCHE
 When "FIN"        : Gosub FIN
 #JOJAC - START
# When "AVANT_CHOI" : Read [ID]ID0=[F:HRCTR]REFNUM # Recharger [ID] apres Fillbox de REMPLIT
 When "AVANT_CHOI" : Gosub AVANT_CHOI
 #JOJAC - END
 When "AVANTBOUT"  : Gosub AVANTBOUT
 When "STATUT"     : Gosub STATUT
 When "FERME"      : Gosub FERME
 #JOJAC - 2016-06-02 - REQ114309 US215 - START
 When "ABANDON"    : Gosub ABANDON
 When "APRES_CHOI" : Gosub APRES_CHOI
 #JOJAC - 2016-06-02 - REQ114309 US215 - END
 When Default
Endcase


If [L]CSUBB
 Gosub ACTION From SUBCTR2
Endif

#JASMI - 2016-06-01 - REQ 114309 - START
#BRBAN - 2014/04/16 - Fields for KPO
# Issue 110164 - 2016-01-15 by BRBAN
#If func AFNC.ACTIV("KPOAO")>0 & func DIVPAYE.EXISTE_KXX("SUBCTRKPO") Then
#    Gosub ACTION From SUBCTRKPO
#Endif
#If func AFNC.ACTIV("KFR") & func DIVPAYE.EXISTE_KXX("SUBCTRKFR") Then
#    Gosub ACTION From SUBCTRKFR
#Endif
If ACTION="OUVRE"
  If func AFNC.ACTIV("KPOAO")>0 & func DIVPAYE.EXISTE_KXX("SUBCTRKPO") Then
      Gosub ACTION From SUBCTRKPO
  Endif
  If func AFNC.ACTIV("KFR") & func DIVPAYE.EXISTE_KXX("SUBCTRKFR") Then
      Gosub ACTION From SUBCTRKFR
  Endif
Else
  If (func DIVPAYE.IS_KPO_LEG(GCURLEG)|func DIVPAYE.IS_KAO_LEG(GCURLEG)) & func DIVPAYE.EXISTE_KXX("SUBCTRKPO") Then
      Gosub ACTION From SUBCTRKPO
  Endif
  If func DIVPAYE.IS_KFR_LEG(GCURLEG) & func DIVPAYE.EXISTE_KXX("SUBCTRKFR") Then
      Gosub ACTION From SUBCTRKFR
  Endif
Endif
#JASMI - 2016-06-01 - REQ 114309 - end

Return

