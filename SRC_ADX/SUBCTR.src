 If fstat
 #JOJAC - 2016-06-02 - REQ114309 US215 - START
  #GMESSAGE = mess(44,703,1) : # Ce compte individuel n'est pas un tiers comptable
  GMESSAGE = mess(44,10703,1) : # Ce compte individuel n'est pas un tiers comptable
 #JOJAC - 2016-06-02 - REQ114309 US215 - END
  mkstat   = 2
 Endif
Endif
End

