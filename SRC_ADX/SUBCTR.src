Subprog C_PSNENDDAT(VALEUR)
Variable Date    VALEUR
Gosub PSNDAT
If mkstat=2 : End : Endif

If VALEUR>eomonth(PSNSTRDAT(nolign-1))
 #JOJAC - 2016-06-02 - REQ114309 US215 - START
 #GMESSAGE=mess(170,701,1)
 GMESSAGE=mess(170,10701,1)
 #JOJAC - 2016-06-02 - REQ114309 US215 - END
 mkstat=2
 End
Endif
#
End

########################################################
$PSNDAT
Local Date DATREF
If GFONCTION="GESCTR"
 DATREF=[M]CTRDAT

 If [M:CTR0]FLGRET=2 : DATREF=[M]RETDATEFF : Endif
 If VALEUR<DATREF | (VALEUR>[M:CTR8]XITDAT & [M:CTR8]XITDAT<>[0/0/0])
  # Date de la prestation en dehors de la période du contrat
  If [M:CTR8]XITDAT<>[0/0/0]
   #JOJAC - 2016-06-02 - REQ114309 US215 - START
   #GMESSAGE = mess(37,701,1)-":"-mess(94,100,1)-format$("D:"+GFMDAT,[L]DATREF)-mess(95,100,1)-format$("D:"+GFMDAT,[M]XITDAT)
   GMESSAGE = mess(37,10701,1)-":"-mess(94,100,1)-format$("D:"+GFMDAT,[L]DATREF)-mess(95,100,1)-format$("D:"+GFMDAT,[M]XITDAT)
   #JOJAC - 2016-06-02 - REQ114309 US215 - END
  Else
   #JOJAC - 2016-06-02 - REQ114309 US215 - START
   #GMESSAGE = mess(37,701,1)-":"-format$("D:"+GFMDAT,[L]DATREF)
   GMESSAGE = mess(37,10701,1)-":"-format$("D:"+GFMDAT,[L]DATREF)
   #JOJAC - 2016-06-02 - REQ114309 US215 - END
  Endif
  mkstat = 2 : Return
 Endif
Else
 If VALEUR<[M]CTRDAT
  # Date de la prestation en dehors de la période du contrat
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
  #GMESSAGE = mess(37,701,1)-":"-format$("D:"+GFMDAT,[M]CTRDAT)
  GMESSAGE = mess(37,10701,1)-":"-format$("D:"+GFMDAT,[M]CTRDAT)
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
  mkstat = 2 : Return
 Endif
Endif
Return

