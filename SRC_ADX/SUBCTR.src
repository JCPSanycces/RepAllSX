Subprog C_PSNJOB(VALEUR)
Variable Char    VALEUR()
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
#Check if Misc Table 362 is correct and if this needs to be replaced with 10362
Read[F:ADI]CODE=362;[M]CATCSP
If !fstat & [F:ADI]A1="389b"
 If VALEUR<>""
 #JOJAC - 2016-06-02 - REQ114309 US215 - START
  #If GDOSLEG="FRA" Then
  If func DIVPAYE.IS_KFR_LEG(GCURLEG) Then
    #Read[F:ADI]CODE=604;VALEUR
    Read[F:ADI]CODE=10604;VALEUR
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
    If fstat | ([F:ADI]A1<>"T389" & [F:ADI]A1<>"C389")
     #Valeur incorrecte
     #JOJAC - 2016-06-02 - REQ114309 US215 - START
      #GMESSAGE=mess(1,702,1)
      GMESSAGE=mess(1,10702,1)
     #JOJAC - 2016-06-02 - REQ114309 US215 - END
      mkstat=2 : End
    Endif
  Endif
 Else
  #zone obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog C_EVECTRDAT(VALEUR)
Variable Date    VALEUR
#JOJAC - 2016-07-19 - REQ114309 - START
#If VALEUR<[M:CTR0]CTRDAT | ([M:CTR8]XITDAT<>[0/0/0] & VALEUR>[M:CTR8]XITDAT)
 ##Valeur incorrecte
 ##JOJAC - 2016-06-02 - REQ114309 US215 - START
  ##GMESSAGE=mess(1,702,1)
  #GMESSAGE=mess(1,10702,1)

  If VALEUR<[M:CTR0]CTRDAT
    GMESSAGE=mess(247,10702,1)
    mkstat=2 : End
  Endif
  If ([M:CTR8]XITDAT<>[0/0/0] & VALEUR>[M:CTR8]XITDAT)
    GMESSAGE=mess(248,10702,1)
    mkstat=2 : End
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  Endif
End

Subprog AM_XITFNL(VALEUR)
Variable Integer VALEUR

# BRBAN - Portuguese legal requirements 11/09/14
#JOJAC - 2016-06-02 - REQ114309 US215 - START (GX3APP)
#If func AFNC.ACTIV("KPO")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KSA")=0) & VALEUR=2
If GCURLEG = 'POR' & VALEUR=2
  Local Integer OKPRF : [L]OKPRF = 1
  #Do you want to update the employee contract profile?
  #JOJAC - 2016-06-03 - REQ114309 US215 - START
  #Call OUINON(mess(22,11553,1),[L]OKPRF) From GESECRAN
  Call OUINON(mess(22,11663,1),[L]OKPRF) From GESECRAN
  #JOJAC - 2016-06-03 - REQ114309 US215 - END
  If [L]OKPRF=2
    [M:CTR1]PROPRF = func AFNC.PARAMDOS(nomap,"PRFXITFNL")
    Call AM_PROPRF([M:CTR1]PROPRF) From SUBCTR
    Affzo [M:CTR1]PROPRF
  Endif
Endif


If VALEUR<>2
 [M]FLGALCCHO = 1 : Grizo FLGALCCHO : Affzo FLGALCCHO
Else
 Actzo FLGALCCHO
Endif
#JASMI - 2016-06-01 - REQ 114309 - START
#If func ISKZAKAQ() & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
If func DIVPAYE.IS_AFRICA_LEG(GCURLEG)|func DIVPAYE.IS_KZA(GCURLEG) Then
#JASMI - 2016-06-01 - REQ 114309 - END
  If func DIVPAYE.EXISTE_KXX("SUBCTRKSA") Then
    Call AM_XITFNL(VALEUR) From SUBCTRKSA
  Endif
Endif

If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
   Gosub FNLXITDAT From SUBCTR2
Endif

End

Subprog C_NBRDAYCTR(VALEUR)
