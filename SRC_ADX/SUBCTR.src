    If GPAYE : Call UPD_FLGCREBUL([M]FLGCREBUL, 1) From SUBCTR2 : Endif
    #If func AFNC.ACTIV("FPAY")
    If func AFNC.ACTIV("FPAY") & func DIVPAYE.IS_KFR_LEG(GCURLEG)
  #JASMI - 2016-06-02 - REQ 114309 - END
