Subprog B1_MNL(NOLIB)
Value    Integer NOLIB
Local    Char    PARMSK(250)(1..20) , SAVACT(20)
Local    Integer RETOUR

  SAVACT = GACTION : GACTION = "SAIAPLSTD"
  [L]RETOUR = [L]NOLIB
  Call SAISIE_LIB(RETOUR, [L]PARMSK, "FAPLSTD", "APLSTD", "XWFAPLSTD") From GSAISIE
  GACTION = SAVACT
End

