Subprog AM_CTRDAT(VALEUR)
Variable Date    VALEUR

#JOJAC - 2016-07-20 - REQ114309 - START
#If  func ISKZAKAQ() Then
If func DIVPAYE.IS_KZA(GCURLEG) | func DIVPAYE.IS_AFRICA_LEG(GCURLEG) Then
#JOJAC - 2016-07-20 - REQ114309 - END
  If func DIVPAYE.EXISTE_KXX("SUBCTRKSA") Then
    Call AM_CTRDAT(VALEUR) From SUBCTRKSA
  Endif
Endif
##Manage the box 'Break payslip' (1 = Assign & Display)
[M]CTRDAT=VALEUR
If GPAYE : Call UPD_FLGCREBUL([M]FLGCREBUL, 1) From SUBCTR2 : Endif
If GCURLEG = 'BRI' and func DIVPAYE.EXISTE_KXX("SUBCTRUKI") Then
  Call DEFAULTTAXYEASTR()From SUBCTRUKI
Endif
End

