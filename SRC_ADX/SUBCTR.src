########################################################
$RAZCRE
  #JOJAC - START
  #If GINTMT=1 & [F:ID]FLGINT<>2
  If GINTMT=1 & [F:ID]FLGINT<>2 #& func DIVPAYE.IS_KFR_LEG(GCURLEG)
  #JOJAC - END
   Grizo [CTR3]
   Affzo [CTR3]
  Endif
  Call GRISE_CALPAY([F:ID]FLGINT) From SUBCTR2
  Call GRISE_FLGPAY([F:ID]FLGPAY) From SUBCTR2
  Call INI_GRDEXUDSN([F:ID]FLGPAY) From SUBCTR2 :#105476 - US3421
  [M:CTR0]FLGVAR=1
  Gosub RAZRETRO
  [M:CTR4]WRKFLGADD=2
  Call GRISE_WRKADD([M:CTR4]WRKFLGADD)
  If [F:ID]FLGMULCTR=2 : [M:CTR2]SEVCTR = 2 : Endif
  Gosub CHARGE_BULDEM

  For nolign=1 To len(mess(0,50,1))
   [M:CTR6]RESPO(nolign-1)=nolign
  Next
  [M:CTR6]NBRCHEF=nolign
  Affzo [M:CTR6]
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
  #If func AFNC.ACTIV("KFR") > 0
  If GCURLEG = 'FRA'
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
    Call GRISE_PEN("FLGEXCPEN") From SUBCTRKFR
  Endif
Return

########################################################
$RAZDUP
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
  #JOJAC - START
  #If GINTMT=1
  If GINTMT=1 & func DIVPAYE.IS_KFR_LEG(GCURLEG)
  #JOJAC - END
    If [F:ID]FLGINT<>2
      Grizo [CTR3]
    Else
      Effzo [M:CTR3]AEMNUM
      Effzo [M:CTR3]NBRPSN, PSNSTRDAT, PSNENDDAT, BUL :#94459
      Effzo [M:CTR3]30
    Endif
  Endif

  If dim([M:CTR1]FLGDUE)>0 Then
    Effzo [M:CTR1]FLGDUE
  Endif
  [M:CTR0]FLGVAR=1
  Gosub RAZRETRO
  Call INI_GRDEXUDSN([F:ID]FLGPAY) From SUBCTR2
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
Return

