If GINTMT &  [F:ID]FLGINT=2 & func DIVPAYE.IS_KFR_LEG(GCURLEG) : [V]GMENLOC(1) = 1 : Endif
#JOJAC - 2016-06-08 - REQ114309 US215 - END
End

