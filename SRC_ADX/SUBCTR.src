#JOJAC - 2016-06-02 - REQ114309 US215 - START
#Read[F:ADI]CODE=359;[M]XITGRD
#JOJAC - 2016-06-02 - REQ114309 US215 - END
Local Integer JADI
Local Char CODA1 (10)
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#JADI=instr (1,[F:ADI]A1,"|")
#If JADI
# CODA1=seg$([F:ADI]A1,1,JADI-1)
#Else
# CODA1=[F:ADI]A1
#Endif
#If fstat | (GDOSLEG="FRA" & (val(CODA1)<>12 & val(CODA1)<>26))
Call SIMPLEREAD([M]XITGRD,GCURLEG,GERRHRM) From SUBHRXGD
If !GERRHRM
  JADI=instr (1,[F:HRXGD]CODN4H,"|")
  If JADI
