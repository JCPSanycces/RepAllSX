#ADNGO - 2017-05-22 - START
##JOJAC - 2016-06-02 - REQ114309 US215 - START
###** Awaiting Time Management
Subprog AM_XITDAT(VALEUR)
Variable Date    VALEUR
#If VALEUR<>[0/0/0] & GREP<>"C" & GREP<>"D" & ([M]XITDAT =[0/0/0] | VALEUR < [M]XITDAT )
# WXITDAT=VALEUR
# Gosub CONTROLE_TIP2
# If mkstat : End : Endif
# If GPAYE
#  Gosub CONTROLE_PRVPAIE
#  If mkstat : End : Endif
# Endif
#Endif
#GRETTIP=1
#If VALEUR=[0/0/0] & [M]XITFNL<>1
# [M]XITFNL = 1
# [M]FLGALCCHO = 1 : Grizo FLGALCCHO
#Endif
#[M:CTR0]XITDAT=VALEUR : Affzo [M:CTR0]XITDAT :#94459
#
#If func ISKZAKAQ() Then
#  If func DIVPAYE.EXISTE_KXX("SUBCTRKSA") Then
#    Call AM_XITDAT(VALEUR) From SUBCTRKSA
#  Endif
#Endif
#
#If dim([M:CTRB]FLGEXCPEN) > 0 & [M:CTRB]FLGEXCPEN<>2
# If [M:CTR1]POT<>""
#  [M:CTR8]XITDAT=VALEUR
#  Gosub CHARGE_CPN From SUBCTRKFR
# Endif
#Endif
If VALEUR<>[0/0/0] & GREP<>"C" & GREP<>"D" & ([M]XITDAT =[0/0/0] | VALEUR < [M]XITDAT )
 WXITDAT=VALEUR
 Gosub CONTROLE_TIP2
 If mkstat : End : Endif
 If GPAYE
  Gosub CONTROLE_PRVPAIE
  If mkstat : End : Endif
 Endif
Endif
GRETTIP=1
If VALEUR=[0/0/0] & [M]XITFNL<>1
 [M]XITFNL = 1
 [M]FLGALCCHO = 1 : Grizo FLGALCCHO
Endif
[M:CTR0]XITDAT=VALEUR : Affzo [M:CTR0]XITDAT :#94459
#ADNGO - 2017-05-30 - JIRA X3-12050 - START
#If func ISKZAKAQ() Then
If func DIVPAYE.IS_AFRICA_LEG(GCURLEG) | func DIVPAYE.IS_KZA(GCURLEG)
#ADNGO - 2017-05-30 - JIRA X3-12050 - END
  If func DIVPAYE.EXISTE_KXX("SUBCTRKSA") Then
    Call AM_XITDAT(VALEUR) From SUBCTRKSA
  Endif
Endif

If dim([M:CTRB]FLGEXCPEN) > 0 & [M:CTRB]FLGEXCPEN<>2
 If [M:CTR1]POT<>""
  [M:CTR8]XITDAT=VALEUR
  Gosub CHARGE_CPN From SUBCTRKFR
 Endif
Endif
End
