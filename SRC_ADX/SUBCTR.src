Call SIMPLEREAD(VALEUR,GCURLEG,GERRHRM) From SUBHRXGD
#Read[F:ADI]CODE=359;VALEUR
#faute lourde
#If fstat | (GDOSLEG="FRA" & ([F:ADI]A1="012|88" |[F:ADI]A1="902|96"))
If GERRHRM | [F:HRXGD]CODN4H="012|88" |[F:HRXGD]CODN4H="902|96"
#JOJAC - 2016-06-02 - REQ114309 US215 - END
 Grizo FLGALCCHO
Else
 Actzo FLGALCCHO
Endif

Gosub STYLE

