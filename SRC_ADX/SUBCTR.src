## Controle existante de frais sur la période
########################################################
Subprog CONTROLE_FRAIS(CRITERE,MATRI)
Variable Char CRITERE
Variable Char MATRI()
#DIRAS - 31-05-2017 - JIRA X3-11253 - START
If !clalev([F:HREXS]) : Local File HREXPENSES [HREXS] : Endif
mkstat=0
Filter [HREXS] Where REFNUM=[L]MATRI & evalue(CRITERE)
Read [HREXS]HREXS1 First
Filter [HREXS]

#If !clalev([F:EXS]) : Local File EXPENSES [EXS] : Endif
#mkstat=0
#Filter [EXS] Where REFNUM=[L]MATRI & evalue(CRITERE)
#Read [EXS]EXS1 First
#Filter [EXS]
#DIRAS - 31-05-2017 - JIRA X3-11253 - END
If !fstat : mkstat=1 : Endif
End

## Controle avantages en nature
########################################################
Subprog CONTROLE_AVNNAT(VALEUR)
Variable Char    VALEUR()
#JASMI - 2016-06-01 - REQ 114309 - START
#If !func AFNC.ACTIV("FPAY") : End : Endif
If !(func AFNC.ACTIV("HRPAY")&func DIVPAYE.IS_KFR_LEG(GCURLEG)) : End : Endif
#JASMI - 2016-06-01 - REQ 114309 - END
Local Integer I, J, COMPTEUR, LONG
# Ne peut contenir que N(nourriture), L(logement), V(voiture), A(autres).
If VALEUR<>""
 LONG=len (VALEUR)
 For I=1 To LONG
  COMPTEUR=0
  DOUBLON=mid$(VALEUR,I,1)
  If !find(DOUBLON,"N","L","V","A")
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
     #GMESSAGE = DOUBLON-mess(1,702,1)-": (NLVA)" : # Valeur incorrecte
     GMESSAGE = DOUBLON-mess(1,10702,1)-": (NLVA)" : # Valeur incorrecte
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
     mkstat = 1 : End
  Endif
  For J=1 To LONG
   If DOUBLON = mid$(VALEUR,J,1)
    COMPTEUR=COMPTEUR+1
    If COMPTEUR>1
    #JOJAC - 2016-06-02 - REQ114309 US215 - START
     #GMESSAGE = DOUBLON-mess(5,702,1) : # Valeur doublée
     GMESSAGE = DOUBLON-mess(5,10702,1) : # Valeur doublée
     #JOJAC - 2016-06-02 - REQ114309 US215 - END
     mkstat = 1 : End
    Endif
   Endif
  Next J
 Next I
Endif
End

## Controle frais professionnels
########################################################
Subprog CONTROLE_EXSPFL(VALEUR)
Variable Char    VALEUR()
#JASMI - 2016-06-01 - REQ 114309 - START
#If !func AFNC.ACTIV("FPAY") : End : Endif
If !(func AFNC.ACTIV("HRPAY")&func DIVPAYE.IS_KFR_LEG(GCURLEG)) : End : Endif
#JASMI - 2016-06-01 - REQ 114309 - END
Local Integer I, J, COMPTEUR, LONG
# Ne peut contenir que F,R,P,D
If VALEUR<>""
 LONG=len (VALEUR)
 For I=1 To LONG
  COMPTEUR=0
  DOUBLON=mid$(VALEUR,I,1)
  If !find(DOUBLON,"F","R","P","D")
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
     #GMESSAGE = DOUBLON-mess(1,702,1)-": (FRPD)" : # Valeur incorrecte
     GMESSAGE = DOUBLON-mess(1,10702,1)-": (FRPD)" : # Valeur incorrecte
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
     mkstat = 1 : End
  Endif
  For J=1 To LONG
   If DOUBLON = mid$(VALEUR,J,1)
    COMPTEUR=COMPTEUR+1
    If COMPTEUR>1
    #JOJAC - 2016-06-02 - REQ114309 US215 - START
     #GMESSAGE = DOUBLON-mess(5,702,1) : # Valeur doublée
     GMESSAGE = DOUBLON-mess(5,10702,1) : # Valeur doublée
     #JOJAC - 2016-06-02 - REQ114309 US215 - END
     mkstat = 1 : End
    Endif
   Endif
  Next J
 Next I
Endif
End

#JOJAC - 2016-06-02 - REQ114309 US215 - START
# US1807 90853 24/07/13
## Controle date de sortie / Leg # contrat et salarié
#################################################################
#**
#* Control date of end  / Leg # contract and employee
#*
#* @param PXITDAT : date of end
#* @param PFCY    : code facility
#*!
Subprog CONTROLE_XITDAT_LEG(PXITDAT,PFCY)
Value Date       PXITDAT()
Value Char       PFCY()
Local Integer    OK
Local Char       LEGI(GLONADI), LEGC(GLONADI)
Local Char       WCRIT(250)
Local Char       LISTLEG(GLONADI)(1..10)
Local Integer    WNBLEG
Local Integer    WNBCRT
Local Char       WMESSAGE(250)

If [L]PXITDAT <> [0/0/0]
  Read [F:ID]ID0=[M]REFNUM
  If !fstat & [F:ID]FCYORI<>"" Then
   Call LECTURE("FCY",[F:ID]FCYORI,"")  From CONTOBJ : [L]LEGI = [F:FCY]LEG : # LEGI=leg of the employee
   Call LECTURE("FCY",[L]PFCY,"")       From CONTOBJ : [L]LEGC = [F:FCY]LEG : # LEGC=leg of the current contract
   If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
   Filter [ILEG] Where REFNUM=[M]REFNUM & (CTRNUM<>[M]CTRNUM | (CTRNUM=[M]CTRNUM & CTRDAT<>[M]CTRDAT)) & XITDAT=[0/0/0]
   [L]WNBCRT=rowcount([ILEG])
   If [L]WNBCRT > 0
     Call LIST_LEG_EML([M]REFNUM,[L]LEGI,2,[L]LISTLEG,[L]WNBLEG,[L]WCRIT) From TOOLSHRLEG
     Filter [ILEG]
     If !find([L]LEGI,[L]LISTLEG(1..[L]WNBLEG))
        [L]WMESSAGE=func AFNC.MES1(mess(168,10701,1),[L]LEGI) # Aucun contrat actif n'a la législation $1$ du site principal du salarié : il serait souhaitable de modifier ce site
        GERR=2
        GMESSAGE=[L]WMESSAGE
     Endif
   Endif
  Endif
Endif
End
#JOJAC - 2016-06-02 - REQ114309 US215 - END

# SETMSK_CTR9 : Défini l'état saisissable ou non du masque CTR9 - Infos compta / contrat
########################################################
Subprog SETMSK_CTR9(FCY)
Value Char FCY()

Local Integer FLGCTRCPT
Local Char VOIDCHAR(250)

Raz [L]FLGCTRCPT, [L]VOIDCHAR

Call PARAM([L]FCY, "CTRCPT", [L]VOIDCHAR) From ADOVAL
[L]FLGCTRCPT = max(val(vireblc([L]VOIDCHAR, 4)), 1)

#JASMI - 2016-05-28 - REQ 114309 - START
##JOJAC - 2016-06-02 - REQ114309 US215 - START
###** V7 : Waiting Update Accounting **#
#[L]FLGCTRCPT =1
###**#
##JOJAC - 2016-06-02 - REQ114309 US215 - END
#JASMI - 2016-05-28 - REQ 114309 - END

# Parameter Value is able to modify screen field
Case [L]FLGCTRCPT
  When 1 : # [M:CTR9]FLGCTRCPT must be unavailable
    [M:CTR9]FLGCTRCPT = 1 : Grizo [M:CTR9]

  When Default :
    If find([V]GREP,"C") :# --- Creating
      Case [L]FLGCTRCPT
        When 2
            [M:CTR9]FLGCTRCPT = 1
#JASMI - 2016-05-28 - REQ 114309 - START
#            #JOJAC - 2016-06-02 - REQ114309 US215 - START
#            Grizo [M:CTR9]            : # On grise tout
#            Actzo [M:CTR9]FLGCTRCPT   : # On rend l'accès
#            Affzo [M:CTR9]FLGCTRCPT
#            #JOJAC - 2016-06-02 - REQ114309 US215 - END
#JASMI - 2016-05-28 - REQ 114309 - END
        When 3
#JASMI - 2016-05-28 - REQ 114309 - START
#        #JOJAC - 2016-06-02 - REQ114309 US215 - START
#        [M:CTR9]FLGCTRCPT = 1
#        If find([V]GREP,"C","D")
#        #JOJAC - 2016-06-02 - REQ114309 US215 - END
#JASMI - 2016-05-28 - REQ 114309 - END
            [M:CTR9]FLGCTRCPT = 2
#JASMI - 2016-05-28 - REQ 114309 - START
#        #JOJAC - 2016-06-02 - REQ114309 US215 - START
#        Endif
#JASMI - 2016-05-28 - REQ 114309 - END
      Endcase
    Endif

    If [M:CTR9]FLGCTRCPT = 1
        Grizo [M:CTR9]            : # On grise tout
#JASMI - 2016-05-28 - REQ 114309 - START
#        #JOJAC - 2016-06-02 - REQ114309 US215 - START
#        Actzo [M:CTR9]FLGCTRCPT   : # On rend l'accès à la zone
#        #JOJAC - 2016-06-02 - REQ114309 US215 - END
#JASMI - 2016-05-28 - REQ 114309 - END
    Else
        Actzo [M:CTR9]            : # On active tout
    Endif
    Actzo [M:CTR9]FLGCTRCPT
Endcase
Affzo [M:CTR9]FLGCTRCPT

End

## VALDEF_CTR9_CPT : Charge les valeurs par défaut du bloc compta du masque CTR9 en fonction du salarié
#########################################################
Subprog VALDEF_CTR9_CPT(REFNUM)
Value Char REFNUM()
#JASMI - 2016-05-28 - REQ 114309 - START
#JOJAC - 2016-06-02 - REQ114309 US215 - START
##** V7 : Waiting Update Accounting **#
Local Char WZONE(20)
#
Read [F:CPT]CPT0 = [L]REFNUM
If fstat = 0
    # Cas particulier des imports : on ne veut pas que des valeurs imposées
    # par l'import soit écrasées
    If not [V]GIMPORT
        [M:CTR9]BPR = [F:CPT]BPR
        [M:CTR9]ACCCOD = [F:CPT]ACCCOD
        [M:CTR9]DSP = [F:CPT]DSP
        Call LECTEXTRA([M:CTR9]DSPDES, "CADSP","DESTRA",[F:CPT]DSP,"") From ATEXTRA
    Else

    Endif
    Look [F:CAC]CAC0 = 14 ; [M:CTR9]ACCCOD
    If fstat <> 0
        Raz [M:CTR9]ACCCOD
        # Pour conserver un comportement identique à la saisie
#JASMI - 2016-05-30 - REQ 114309 - START
#        Call INITACCCOD([M:CTR9]ACCCOD,14) From TRTINTCPT
        Call INITACCCOD([M:CTR9]ACCCOD,35) From TRTX3
#JASMI - 2016-05-30 - REQ 114309 - END
    Endif
Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - END
#JASMI - 2016-05-28 - REQ 114309 - END
End

Subprog VALDEF_CTR9_ANA(WCHARGE,WCPY)
Value Integer WCHARGE  :# 0 : default values, 1 : value from EMPLOCTRCPT
Value Char WCPY()

Local Integer J
Local Integer NBPLAN, NBAXE
Local Integer REFTYP(1..10)
Local Integer OBLIG(1..max(GOPTCANA,20))
Global Char   GPLAN(GLONCOA)(1..10)
Local Char    ACMCUR(GLONGCM)

If dim([M]DIE)<=0 : End : Endif
  nolign = 1
  Raz [M]DIE, CCE, INICCE


    Call SETGCM(WCPY,ACMCUR) From CPTDIV : # code du modèle de la société
    # liste des axes de tous les référentiels du modèle (nb référentiels limités à len de
    Call SETPLAN2(ACMCUR,NBPLAN,GPLAN,REFTYP,NBAXE,[M:CTR9]DIE,OBLIG) From CPTDIV
    [M]NBAXECPR = min(NBAXE,dim([M:CTR9]DIE))
    For I=0 To [M:CTR9]NBAXECPR-1
     If [L]WCHARGE=1 & [M:CTR9]DIE(I)<>"" & find([M:CTR9]DIE(I),[F:CPR]DIE(0..dim([F:CPR]DIE)-1))
      For J=0 To dim([F:CPR]DIE)-1
       If [M:CTR9]DIE(I) = [F:CPR]DIE(J)
         If [M:CTR9]DSP="" Then
          [M:CTR9]CCE(I) = [F:CPR]CCE(J)
          [M:CTR9]INICCE(I)=[F:CPR]INICCE(J)
         Endif
        Break
       Endif
      Next J
     Else
       If [M:CTR9]DSP = ""
        If [M:CTR9]DIE(I) <> ""
         [M:CTR9]INICCE(I)=3
        Endif

       Endif
     Endif
    Next I

End

