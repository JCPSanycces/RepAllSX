If !clalev([F:WAD]) : Local File EMPLOAD [WAD] : Endif
If ACTION="ANNULE"
  Delete [ESB] Where [F:ESB]REFNUM=[M:CTR0]REFNUM & [F:ESB]CTRNUM=[M:CTR0]CTRNUM &  [F:ESB]CTRDAT=[M:CTR0]CTRDAT
  If fstat=1
   GOK = -1 : GLOCK = "$EMPSBD"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-[M:CTR0]CTRDAT-num$(1)-num$([F:ESB]RANG)
   Return
  Endif
  Return
Endif
Filter [F:ESB] Where [F:ESB]REFNUM=[M:CTR0]REFNUM & [F:ESB]CTRNUM=""
If rowcount([F:ESB])>0 Then
   Filter [F:ESB]
   Delete [F:ESB] Where [F:ESB]REFNUM=[M:CTR0]REFNUM & [F:ESB]CTRNUM=""
   If fstat=1
     GOK = -1 : GLOCK = "$EMPSBD"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-[M:CTR0]CTRDAT-num$([F:ESB]NIVEAU)-num$([F:ESB]RANG)
     Return
   Endif
   Read [F:WAD] AD0=[M:CTR0]REFNUM
   If !fstat
    For L_K=0 To len(mess(0,50,1))
      If [F:WAD]CHEF(L_K)<> ""
         Raz [F:ESB]
         [F:ESB]CHEF=[F:WAD]CHEF(L_K)
         [F:ESB]NIVEAU=2
         [F:ESB]RANG=L_K+1
         Gosub WRITE_ESB
         If !GOK : Break : Endif
      Endif
    Next L_K
   Endif
Endif
Filter [F:ESB]

Delete [ESB] Where [F:ESB]REFNUM=[M:CTR0]REFNUM & [F:ESB]CTRNUM=[M:CTR0]CTRNUM &  [F:ESB]CTRDAT=[M:CTR0]CTRDAT  & [F:ESB]NIVEAU=1
If fstat=1
 GOK = -1 : GLOCK = "$EMPSBD"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-[M:CTR0]CTRDAT-num$(1)-num$([F:ESB]RANG)
 Return
Endif
For L_K=0 To len(mess(0,50,1))
  If [M:CTR6]CHEFCTR(L_K)<> ""
     Raz [F:ESB]
     [F:ESB]CHEF=[M:CTR6]CHEFCTR(L_K)
     [F:ESB]NIVEAU=1
     [F:ESB]RANG=L_K+1
     Gosub WRITE_ESB
     If !GOK : Break : Endif
  Endif
Next L_K
Delete [ESB] Where [F:ESB]REFNUM=[M:CTR0]REFNUM & [F:ESB]CTRNUM=[M:CTR0]CTRNUM &  [F:ESB]CTRDAT=[M:CTR0]CTRDAT  & [F:ESB]NIVEAU=3
If fstat=1
 GOK = -1 : GLOCK = "$EMPSBD"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-[M:CTR0]CTRDAT-num$(3)-num$([F:ESB]RANG)
 Return
Endif
Read [F:SRV] SRV0=[M:CTR1]ETRSRV
If !fstat
  For L_K=0 To len(mess(0,50,1))
    If [F:SRV]CHEF(L_K)<> ""
       Raz [F:ESB]
       [F:ESB]CHEF=[F:SRV]CHEF(L_K)
       [F:ESB]SRV=[F:SRV]COD
       [F:ESB]NIVEAU=3
       [F:ESB]RANG=L_K+1
       Gosub WRITE_ESB
       If !GOK : Break : Endif
    Endif
  Next L_K
Endif

Delete [ESB] Where [F:ESB]REFNUM=[M:CTR0]REFNUM & [F:ESB]CTRNUM=[M:CTR0]CTRNUM &  [F:ESB]CTRDAT=[M:CTR0]CTRDAT  & [F:ESB]NIVEAU=4
If fstat=1
 GOK = -1 : GLOCK = "$EMPSBD"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-[M:CTR0]CTRDAT-num$(4)-num$([F:ESB]RANG)
 Return
Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#Read [F:SIT]SIT0=[M:CTR0]ETRFCY
#JOJAC - 2016-08-02 - REQ114309 - START
Read [F:FCY]FCY0=[M:CTR0]ETRFCY
#Read [F:HRSIT]HRSIT0=[M:CTR0]ETRFCY
#JOJAC - 2016-08-02 - REQ114309 - END
#JOJAC - 2016-06-02 - REQ114309 US215 - END
If !fstat
  For L_K=0 To len(mess(0,50,1))
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
    #If [F:SIT]CHEF(L_K)<> ""
    #JOJAC - 2016-08-02 - REQ114309 - START
    If [F:FCY]CHEF(L_K)<> ""
    #If [F:HRSIT]CHEF(L_K)<> ""
    #JOJAC - 2016-08-02 - REQ114309 - END
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
       Raz [F:ESB]
       #JOJAC - 2016-06-02 - REQ114309 US215 - START
       #[F:ESB]CHEF=[F:SIT]CHEF(L_K)
       #[F:ESB]FCY=[F:SIT]FCY
       #JOJAC - 2016-08-02 - REQ114309 - START
       [F:ESB]CHEF=[F:FCY]CHEF(L_K)
       [F:ESB]FCY=[F:FCY]FCY
       #[F:ESB]CHEF=[F:HRSIT]CHEF(L_K)
       #[F:ESB]FCY=[F:HRSIT]FCY
       #JOJAC - 2016-08-02 - REQ114309 - END
       #JOJAC - 2016-06-02 - REQ114309 US215 - END
       [F:ESB]NIVEAU=4
       [F:ESB]RANG=L_K+1
       Gosub WRITE_ESB
       If !GOK : Break : Endif
    Endif
  Next L_K
Endif
Return

########################################################
$WRITE_ESB
[F:ESB]CTRNUM=[M:CTR0]CTRNUM
[F:ESB]REFNUM=[M:CTR0]REFNUM
[F:ESB]CTRDAT=[M:CTR0]CTRDAT
If dim([F:ESB]CREDAT)>0 : [F:ESB]CREDAT = date$     : Endif
If dim([F:ESB]CRETIM)>0 : [F:ESB]CRETIM = time      : Endif
If dim([F:ESB]CREUSR)>0 : [F:ESB]CREUSR = GUSER     : Endif
Write [F:ESB]
If fstat
 GOK = 0 : Call FSTA("ESB") From GLOCK : Return
Endif
Return

############################################
$MAJ_EMPLOELC
If [M]MAIFCY<2 : Return : Endif

If [M:CTR0]FLGVAR=2 : Return : Endif

Look [ELC]ELC0=[F:HRCTR]REFNUM;[F:HRCTR]ETRFCY
If !fstat : Return : Endif

Link [ELC] With [FCY]FCY0=RPEFCY
&            As [LNK]
&         Where REFNUM=[F:HRCTR]REFNUM & [FCY]LEGCPY=func DIVPAYE.GETSOC([F:HRCTR]ETRFCY)
Read [LNK] First
If !fstat
 Readlock [ELC] Curr
 If fstat
  [V]GOK  =-1
  [V]GLOCK="$EMPLOELC"-[F:ELC]REFNUM-[F:ELC]RPEFCY
  Return
 Endif

 [F:ELC]RPEFCY=[F:HRCTR]ETRFCY
 [F:ELC]UPDUSR=[V]GUSER
 [F:ELC]UPDDAT=date$
 [F:ELC]UPDTIM=time

 Rewrite [ELC] Curr
 If fstat
  [V]GOK=0
  Call FSTA("ELC") From GLOCK
  Return
 Endif

Else
 Raz [F:ELC]
 [F:ELC]REFNUM=[F:HRCTR]REFNUM
 [F:ELC]RPEFCY=[F:HRCTR]ETRFCY
 [F:ELC]CREUSR=[V]GUSER
 [F:ELC]CREDAT=date$
 [F:ELC]CRETIM=time
 Write [ELC]
 If fstat
  [V]GOK=0
  Call FSTA("ELC") From GLOCK
  Return
 Endif
Endif
Return

#JASMI - 2016-05-30 - REQ 114309 - START
##** V7 : Waiting Update Accounting **#
############################################

########################################################
$MAJ_EMPLOCTRCPT
#JOJAC - 2016-06-02 - REQ114309 US215 - START
Delete [F:CPR] Where [F:CPR]REFNUM = [M:CTR0]REFNUM
&                & [F:CPR]CTRNUM = [M:CTR0]CTRNUM
&                & [F:CPR]CTRDAT = [M:CTR0]CTRDAT
If fstat <> 0
    [V]GOK = 0
    Call FSTA("CPR") From GLOCK
    Return
Endif
If [M:CTR9]FLGCTRCPT = 2 & GREP <> "A"
    Raz [F:CPR]
    [F:CPR] = [M:CTR0]
    [F:CPR] = [M:CTR9]
    Write [F:CPR]
    If fstat <> 0
        [V]GOK = 0
        Call FSTA("CPR") From GLOCK
        Return
    Endif
Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - END
#JASMI - 2016-05-30 - REQ 114309 - END
Return

########################################################
$MAJ_EMPLOPOT
If [M:CTR0]FLGVAR=2 : Return : Endif

Delete [EPO] Where [F:EPO]REFNUM=[M:CTR0]REFNUM
&                & [F:EPO]CTRNUM=[M:CTR0]CTRNUM
&                & [F:EPO]DATPOT=[M:CTR0]CTRDAT
&                & [F:EPO]ORIGINE=1
If fstat=1
 GOK = -1 : GLOCK = "$EMPLOPOT"-[M:CTR0]REFNUM+"\"+[M:CTR0]CTRNUM+"\"+[M:CTR0]CTRDAT+"\1" : Return
Endif
If [M:CTR1]SUICAR = 2 & GREP <> "A"
  Raz [F:EPO]
  [F:EPO] = [M:CTR1]
  [F:EPO] = [M:CTR0]
  [F:EPO]DATPOT  = [M:CTR0]CTRDAT
  [F:EPO]ORIGINE = 1 : # ML 399 Automatique
  Write [EPO]
  If fstat
   GOK = 0 : Call FSTA("EPO") From GLOCK : Return
  Endif
Endif
Return

########################################################
$MAJ_POPUL
If ACTION="AP_ANNULE" : Return : Endif
#MIPEA - 2017-02-16- X3-11258- START
Local Char    MATRI(GLONEML), CTR(GLONHRCTR)
#Local Char    MATRI(GLONMAT), CTR(GLONCTR)
#MIPEA - 2017-02-16- X3-11258- END
Local Date    DATMAT,DATDIA
DATDIA=date$
Local Integer I, AUTO
Local Integer OKENR
Filter [CTR1]  Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM

If rowcount([CTR1])>=1
 Gosub DEFPOP From SUBPOP

 MATRI  = [M:CTR0]REFNUM
 DATMAT = [M:CTR0]CTRDAT
 CTR    = [M:CTR0]CTRNUM
#JASMI - 2016-09-23 - START
# Gosub LECEMP From DEFTABLE
 Gosub LECEMP From WPDEFTABLE
#JASMI - 2016-09-23 - END
 I = 0
 #En création comme en modif de fiche contrat : Ajout du salarié dans les populations lui correspondant si il n'y est pas déjà
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#For [POP] Where CRI<>"" & DATMAT<=DATDIA :# 96877 on ne prend pas les contrats qui ne sont pas encore actifs
#  If evalue([F:POP]CRI)=1 & !find([F:POP]COD,L_POPUL(0..L_NB_POPUL-1))
For [HRPOP] Where CRI<>"" & DATMAT<=DATDIA :# 96877 on ne prend pas les contrats qui ne sont pas encore actifs
  If evalue([F:HRPOP]CRI)=1 & !find([F:HRPOP]COD,L_POPUL(0..L_NB_POPUL-1))
#JOJAC - 2016-06-02 - REQ114309 US215 - START
   #Read [F:POA]POA0=[F:POP]COD;MATRI
   Read [F:HRPOA]POA0=[F:HRPOP]COD;MATRI
#JOJAC - 2016-06-02 - REQ114309 US215 - END
   If fstat Then
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#     [F:POA]COD    = [F:POP]COD
#     [F:POA]TYP    = 0
#     [F:POA]REFNUM = MATRI
#     [F:POA]MAJTYP = 1 : # Automatique
#     If dim([F:POA]CREUSR)>0 : [F:POA]CREUSR = GUSER : Endif
#     If dim([F:POA]CREDAT)>0 : [F:POA]CREDAT = date$ : Endif
#     If dim([F:POA]CRETIM)>0 : [F:POA]CRETIM = time  : Endif
#     Write [POA]
     [F:HRPOA]COD    = [F:HRPOP]COD
     [F:HRPOA]TYP    = 0
     [F:HRPOA]REFNUM = MATRI
     [F:HRPOA]MAJTYP = 1 : # Automatique
     If dim([F:HRPOA]CREUSR)>0 : [F:HRPOA]CREUSR = GUSER : Endif
     If dim([F:HRPOA]CREDAT)>0 : [F:HRPOA]CREDAT = date$ : Endif
     If dim([F:HRPOA]CRETIM)>0 : [F:HRPOA]CRETIM = time  : Endif
     Write [HRPOA]
#JOJAC - 2016-06-02 - REQ114309 US215 - END
     If fstat
      GOK = 0 : Call FSTA("POA") From GLOCK : Break
     Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - START
     #CODPOP = [F:POP]COD
     CODPOP = [F:HRPOP]COD
#JOJAC - 2016-06-02 - REQ114309 US215 - END
     nolign=0 : AUTO=1
     Gosub AJOUTLIS From SUBEML
   Endif
  Endif
 Next
 #En modif de fiche contrat : Suppr du salarié dans les populations ne lui correspondant plus (si automatique)
 If ACTION="APRES_MOD" | ACTION="APRES_CRE" : # 96877 aprés création aussi
  For I=0 To L_NB_POPUL-1
#JOJAC - 2016-06-02 - REQ114309 US215 - START
   #Read[F:POP]POP0=L_POPUL(I)
   #If !fstat & [F:POP]CRI<>"" & evalue([F:POP]CRI)<>1
   Read[F:HRPOP]POP0=L_POPUL(I)
   If !fstat & [F:HRPOP]CRI<>"" & evalue([F:HRPOP]CRI)<>1
#JOJAC - 2016-06-02 - REQ114309 US215 - END

     If clalev([F:CTR2])=0 : Local File EMPLOCTR [CTR2] : Endif
     OKENR=1
     For [CTR2]CTR0 Where REFNUM=MATRI & CTRDAT<=DATDIA
       CTR = [F:CTR2]CTRNUM
       DATMAT=[F:CTR2]CTRDAT
#JASMI - 2016-09-23 - START
#       Gosub LECEMP From DEFTABLE
       Gosub LECEMP From WPDEFTABLE
#JASMI - 2016-09-23 - END
#JOJAC - 2016-06-02 - REQ114309 US215 - START
       #If evalue([F:POP]CRI)=1 Then OKENR=2 : Break : Endif
       If evalue([F:HRPOP]CRI)=1 Then OKENR=2 : Break : Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - END
     Next
     If  OKENR=1
#JOJAC - 2016-06-02 - REQ114309 US215 - START
      #Readlock[F:POA]POA0=[F:POP]COD;MATRI
      #If !fstat & [F:POA]MAJTYP = 1
      # Delete [F:POA]
      Readlock[F:HRPOA]POA0=[F:HRPOP]COD;MATRI
      If !fstat & [F:HRPOA]MAJTYP = 1
       Delete [F:HRPOA]
#JOJAC - 2016-06-02 - REQ114309 US215 - END
       If fstat=1
#JOJAC - 2016-06-02 - REQ114309 US215 - START
        #GOK = -1 : GLOCK = "$POPULA"-[F:POA]COD-[F:POA]REFNUM : Break
        GOK = -1 : GLOCK = "$POPULA"-[F:HRPOA]COD-[F:HRPOA]REFNUM : Break
#JOJAC - 2016-06-02 - REQ114309 US215 - END
       Endif
      Endif
     Endif
   Endif
  Next

#JASMI - 2016-05-23 - START
#  Read [CTR]CTR0=MATRI;CTR;DATMAT
  Read [HRCTR]CTR0=MATRI;CTR;DATMAT
#JASMI - 2016-05-23 - END

 Endif
Endif
Filter [CTR1]
Return

########################################################
$MAJ_TRAINER
If [M:CTR0]FLGVAR=2 : Return : Endif

If func AFNC.ACTIV("FRT")>0 Then
 Local Integer LFLG_CONTRAT_ENCOURS : LFLG_CONTRAT_ENCOURS = 1

 Filter [F:CTR3] Where REFNUM=[M:CTR0]REFNUM and CTRDAT<=date$
&                     and (XITDAT = [0/0/0] or XITDAT >= date$)
&                Order By CTRDAT Asc
    If rowcount([F:CTR3]) > 0 Then
      LFLG_CONTRAT_ENCOURS = 2
    Endif
    Filter [F:CTR3]
    If LFLG_CONTRAT_ENCOURS = 1 Then
      Filter [F:TRN] Where REFNUM=[M:CTR0]REFNUM and ENAFLG=2
      For [TRN]TRN1
        [F:TRN]ENAFLG=1
        Rewrite [TRN] Curr
        If fstat
         GOK = 0 : Call FSTA("TRN") From GLOCK : Break
        Endif
      Next
      Filter [TRN]
    Endif
  Endif
Return

########################################################
$MAJ_EMPLOSAL
If [M:CTR5]NBRSAL
 For nolign = 1 To [M:CTR5]NBRSAL
  If [M:CTR5]FLGMOD(nolign-1)
   Readlock [F:SAL]SAL0 = [M:CTR0]REFNUM;[M:CTR0]CTRNUM;nolign
   If !fstat
    [F:SAL] = [M:CTR5]
    [F:SAL]UPDDAT = date$
    [F:SAL]UPDTIM = time
    [F:SAL]UPDUSR = GUSER
    Rewrite [F:SAL]
    If fstat=1
     GOK = -1 : GLOCK = "$EMPLOSAL"-[F:SAL]REFNUM-[F:SAL]CTRNUM : Break
    Elsif fstat
     GOK = 0 : Call FSTA("SAL") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
Endif
Return

########################################################
$APRES_CRE
Call DEBTRANS From GLOCK
Gosub APRES
If [V]GOK<1 : Return : Endif
#JASMI - START
#Call CHARGE_POPUL([F:HRCTR]REFNUM,L_POPUL,L_NB_POPUL) From SUBCTR2
Local Integer L_MAJTYP(0..)
Call CHARGE_POPUL([F:HRCTR]REFNUM,L_POPUL,L_NB_POPUL,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,L_MAJTYP) From SUBCTR2
#JASMI - END
Gosub MAJ_POPUL
If [V]GOK<1 : Return : Endif
#SAVAN - 2018/05/08 - X3-86553 - start
#SAVAN  X3-56779 2017/10/12
#Gosub LINKING_ACCRUALS From SUBACCRUAL
#SAVAN
If func AFNC.ACTIV("GLM")
#MIPEA - 2018-05-10-  X3-86564- START
  Gosub LINK_ACCRUALS From SUBCTR2
#  Call LINKING_ACCRUALS_PROG("","","",[HRCTR]CTRNUM,[HRCTR]CTRDAT,4) From SUBACCRUAL
#MIPEA - 2018-05-10-  X3-86564- END
Endif
#SAVAN - 2018/05/08 - X3-86553 - start
Return

########################################################
$APRES_MOD
$AP_ANNULE
Call DEBTRANS From GLOCK
Gosub APRES
If [V]GOK<1 : Return : Endif
Gosub MAJ_POPUL
If [V]GOK<1 : Return : Endif
Return

########################################################
$APRES
GOK = 1
#ADNGO - 2016-05-22 - START
#JOJAC - 2016-06-02 - REQ114309 US215 - START
##** Awaiting time management
#Trbegin [ECT],[CTR1]
Trbegin [ECT],[CTR1],[TIP]
#JOJAC - 2016-06-02 - REQ114309 US215 - END
#ADNGO - 2016-05-22 - END
## Mise à jour de la table EMPCTR et de la zone NUMLIG de EMPLOCTR
Filter [CTR1]  Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM
Read [CTR1]CTR0 Last
If fstat
 Raz [F:CTR1]
Endif
Readlock [ECT]ECT0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM
If fstat=1
 GOK=-1 : GLOCK="$EMPCTR"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM
Elsif fstat
 [F:ECT]REFNUM = [M:CTR0]REFNUM
 [F:ECT]CTRNUM = [M:CTR0]CTRNUM
 [F:ECT]NBRCTR = rowcount([CTR1])
 [F:ECT]FCY    = [F:CTR1]ETRFCY
 [F:ECT]SRV    = [F:CTR1]ETRSRV
 [F:ECT]PRF    = [F:CTR1]PROPRF
 [F:ECT]CREUSR = [V]GUSER
 [F:ECT]CREDAT = date$
 [F:ECT]CRETIM = time
 Write [ECT]
 If fstat
  GOK=0 : Call FSTA("ECT") From GLOCK
 Endif
Else
 [F:ECT]NBRCTR = rowcount([CTR1])
 If [F:CTR1]FLGVAR<>2
  [F:ECT]FCY    = [F:CTR1]ETRFCY
  [F:ECT]SRV    = [F:CTR1]ETRSRV
  [F:ECT]PRF    = [F:CTR1]PROPRF
 Endif
 [F:ECT]UPDUSR = [V]GUSER
 [F:ECT]UPDDAT = date$
 [F:ECT]UPDTIM = time
 If [F:ECT]NBRCTR>0
  Rewrite [ECT]
  If fstat
   GOK=0 : Call FSTA("ECT") From GLOCK
  Endif
 Else
  Delete [ECT]ECT0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM
  If fstat=1 | fstat>5
   GOK=0 : Call RSTA("ECT",[M:CTR0]REFNUM-[M:CTR0]CTRNUM) From GLOCK
  Endif
 Endif
Endif
If GOK=1
 I = 0
 For [CTR1]CTR0
  I +=1
  [F:CTR1]NUMLIG = I
  #First contract = Check the box 'Break payslip' is mandatory except for casual workers
  If I=1 & GPAYE
  #JOJAC - 2016-06-08 - REQ114309 US215 - START
   #If GINTMT & [F:ID]FLGINT=2
   If GINTMT & [F:ID]FLGINT=2 & func DIVPAYE.IS_KFR_LEG(GCURLEG)
   #JOJAC - 2016-06-08 - REQ114309 US215 - START
    [F:CTR1]FLGCREBUL=1
   Else
    [F:CTR1]FLGCREBUL=2
   Endif
  Endif
  Rewrite [CTR1]Curr
  If fstat
#MIPEA - 2017-02-16- X3-11258- START
   GOK=0 : Call FSTA("HRCTR") From GLOCK : Break
#   GOK=0 : Call FSTA("CTR") From GLOCK : Break
#MIPEA - 2017-02-16- X3-11258- END
  Endif
 Next
Endif
Filter [CTR1]
If GOK<0   : Goto ROLL_APRES
Elsif !GOK : Goto AB_APRES
Endif
# Si MAJ_EMPLOID fait dans ANNULE, l'enreg n'est pas encore annulé et rowid renvoie 1
If ACTION="AP_ANNULE"
 Gosub MAJ_EMPLOID
 If GOK<0   : Goto ROLL_APRES
 Elsif !GOK : Goto AB_APRES
 Endif
Endif
If GPAYE & ACTION<>"APRES_MOD"
 # MAJ du CTRDAT de la saisie des valeurs prev non encore passées en paie
 # En effet si déjà passée en paie cela signifie qu'il existe des payes donc on aura planté avant.
 Gosub MAJ_VALPREV
 If GOK<0   : Goto ROLL_APRES
 Elsif !GOK : Goto AB_APRES
 Endif
Endif
#ADNGO - 2017-05-22 - START
##** V7 : Waiting Time Mangement **#
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#If GRETTIP
#   Local Char W_TIP_REFNUM(GLONMAT)
#   Local Char W_TIP_CTRNUM(GLONCTR)
#   Local Char WACTION
#   Local Date W_TIP_CTRDAT
#   Local Date W_TIP_XITDAT
#   Local Char W_TIP_ETRFCY(GLONFCY)
#   Local Char W_TIP_ETRSRV(GLONSRV)


#   W_TIP_REFNUM=[M]REFNUM
#   W_TIP_CTRNUM=[M]CTRNUM
#   W_TIP_CTRDAT=[M]CTRDAT
#   W_TIP_XITDAT=[M]XITDAT
#   W_TIP_ETRFCY=[M]ETRFCY
#   W_TIP_ETRSRV=[M:CTR1]ETRSRV


#   WACTION=ACTION
#   If [M:CTR0]FLGVAR<>2 & GTPS
#     Gosub MAJ_TIMEMP2
#     GRETTIP=0
#     If GOK<0   : Goto ROLL_APRES
#     Elsif !GOK : Goto AB_APRES
#     Endif
#   Endif
#   GRETTIP=0
#Endif

If GRETTIP
   Local Char W_TIP_REFNUM(GLONEML)
   Local Char W_TIP_CTRNUM(GLONHRCTR)
   Local Char WACTION
   Local Date W_TIP_CTRDAT
   Local Date W_TIP_XITDAT
   Local Char W_TIP_ETRFCY(GLONFCY)
   Local Char W_TIP_ETRSRV(GLONSRV)


   W_TIP_REFNUM=[M]REFNUM
   W_TIP_CTRNUM=[M]CTRNUM
   W_TIP_CTRDAT=[M]CTRDAT
   W_TIP_XITDAT=[M]XITDAT
   W_TIP_ETRFCY=[M]ETRFCY
   W_TIP_ETRSRV=[M:CTR1]ETRSRV


   WACTION=ACTION
   If [M:CTR0]FLGVAR<>2 & GTPS
     Gosub MAJ_TIMEMP2
     GRETTIP=0
     If GOK<0   : Goto ROLL_APRES
     Elsif !GOK : Goto AB_APRES
     Endif
   Endif
   GRETTIP=0
Endif
#ADNGO - 2017-05-22 - END
Commit
Return

########################################################
$ROLL_APRES
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto APRES : Endif

########################################################
$AB_APRES
Rollback
Return

########################################################
$MAJ_VALPREV
GOK=1

Filter [F:VPR] Where EMP=[F:CTR1]REFNUM & CTRNUM=[F:CTR1]CTRNUM & DAT>=[F:CTR1]CTRDAT & CTRDAT<>[F:CTR1]CTRDAT
Look [F:VPR]VPR0 First
Filter [F:VPR]
If fstat : Return : Endif

#Création entête des valeurs prev si inexistante
Look [F:VPH]VPH0=[F:CTR1]REFNUM;[F:CTR1]CTRNUM;[F:CTR1]CTRDAT
If fstat=5
 Raz [F:VPH]
 [F:VPH]EMP=[F:CTR1]REFNUM
 [F:VPH]CTRNUM=[F:CTR1]CTRNUM
 [F:VPH]CTRDAT=[F:CTR1]CTRDAT
 [F:VPH]SRV=[F:CTR1]ETRSRV
 [F:VPH]FCY=[F:CTR1]ETRFCY
 Call LECTURE("EML",[F:CTR1]REFNUM,"") From CONTOBJ
 [F:VPH]CODACS = [F:ID]CODACS
 If dim([F:VPH]CREDAT)>0 : [F:VPH]CREDAT = date$ : Endif
 If dim([F:VPH]CREUSR)>0 : [F:VPH]CREUSR = GUSER : Endif
 If dim([F:VPH]CRETIM)>0 : [F:VPH]CRETIM = time  : Endif
 Write [VPH]
 If fstat
   GOK = 0 : Call FSTA("VPH") From GLOCK : Return
 Endif
Endif

#MAJ lignes des valeurs prev
Update [VPR] Where EMP=[F:CTR1]REFNUM & CTRNUM=[F:CTR1]CTRNUM & DAT>=[F:CTR1]CTRDAT
&                & CTRDAT<>[F:CTR1]CTRDAT With CTRDAT=[F:CTR1]CTRDAT
If fstat
 GOK = 0 : Call FSTA("VPR") From GLOCK : Return
Endif
#MAJ commentaires sur lignes des valeurs prev
Update [PCB] Where IDENT1=[F:CTR1]REFNUM & IDENT3=[F:CTR1]CTRNUM & IDENT2>=format$("D:4Y2M2D",[F:CTR1]CTRDAT)
&                & IDENT4<>[F:CTR1]CTRDAT With IDENT4=[F:CTR1]CTRDAT
If fstat
 GOK = 0 : Call FSTA("PCB") From GLOCK : Return
Endif
Return

