# Filter [F:CNE]
#Next
#Filter [F:CNG]
Gosub SUPPR_CNE From SUBCTR2
#JASMI - 2016-02-15 - Issue 114547 - END
Return

########################################################
$INICRE
If [F:ID]FLGINT<>2
 Local Integer WOK
 WOK=1
 Call CONTROLE_ENT_CTRGRD([M:CTR0]CTRGRD,1,WOK)
 If !WOK : GERR=1 : GOK=0 : Endif
Endif
If [M:CTR0]CTRNUM=""
 Read [TCA]TCA0 = 9
#MIPEA - 2016-10-18 - X3PEOP-753 - START
 COMPTEUR = [F:TCA]CODNUM(4)
 #COMPTEUR = [F:TCA]CODNUM(2)
#MIPEA - 2016-10-18 - X3PEOP-753 - END
 If COMPTEUR=""
#JASMI - 2016-05-31 - REQ 114309 - START
#  GMESSAGE = mess(39,701,1) : # Compteur contrat non défini
  GMESSAGE = mess(39,10701,1) : # Compteur contrat non défini
#JASMI - 2016-05-31 - REQ 114309 - END
  GOK = 0 : Return
 Endif
 Call NUMERO(COMPTEUR,[M:CTR0]ETRFCY,[M:CTR0]CTRDAT,[M:CTR0]NATCON,[M:CTR0]CTRNUM,STAT) From SUBANM
 #JOJAC - 2016-06-02 - REQ114309 US215 - START
  W_SIT=[M:CTR0]ETRFCY
  W_DATCPT=[M:CTR0]CTRDAT
  W_CRITCOMP=[M:CTR0]NATCON
#MIPEA - 2016-10-19 - X3PEOP-753 - START
  TYP_CPT=2 # to indicate in TOOLSHRTCA that it is a contract type
#MIPEA - 2016-10-19 - X3PEOP-753 - END
  Gosub GET_COUNTER_SAL From TOOLSHRTCA
  If !GOK : Return : Endif
  [M:CTR0]CTRNUM=W_VALUECPT
 #JOJAC - 2016-06-02 - REQ114309 US215 - END
 If STAT
#JASMI - 2016-05-31 - REQ 114309 - START
#  GMESSAGE = mess(4,702,1)-COMPTEUR : # "Erreur sur compteur"
  GMESSAGE = mess(4,10702,1)-COMPTEUR : # "Erreur sur compteur"
#JASMI - 2016-05-31 - REQ 114309 - END
  GOK = 0 : Return
 Endif
 [F:HRCTR]CTRNUM = [M:CTR0]CTRNUM
 Affzo [CTR0]CTRNUM
Endif

If [M]REFNUM<>[F:ID]REFNUM
 Read [ID]ID0=[M]REFNUM
 If fstat : Return : Endif
Endif
If [F:ID]FLGINT<>2
 [F:HRCTR]CALPAY = 1                   : # Par contrat
 [F:HRCTR]STACTR = 2                   : # Validé
#JOJAC - 2016-06-08 - REQ114309 US215 - START
#Elsif [F:ID]FLGINT=2 & GINTMT=1 & [M:CTR3]STACTR=2
Elsif [F:ID]FLGINT=2 & GINTMT=1 & [M:CTR3]STACTR=2 & func DIVPAYE.IS_KFR_LEG(GCURLEG)
#JOJAC - 2016-06-08 - REQ114309 US215 - START
 [F:HRCTR]XITDAT = max([M:CTR3]PSNENDDAT)
 [F:HRCTR]XITGRD = "FDC"

 [M:CTR0]XITDAT=[F:HRCTR]XITDAT : Affzo [M:CTR0]XITDAT
 [M:CTR8]XITDAT=[F:HRCTR]XITDAT : [M:CTR8]XITGRD=[F:HRCTR]XITGRD : Affzo [M:CTR8]5

Endif
If [F:HRCTR]FLGVAR=0 : [F:HRCTR]FLGVAR=1 : Endif
Gosub SAUVE_EVT From SUBCTR2
#LIPET - 2017-06-27 - X3-32840 - START
Gosub CRE_HRLST From SUBCTR2
#LIPET - 2017-06-27 - X3-32840 - END
# V01X08 - Délégation maladie disparaît (public seulement), on force la valeur trois si vide
#          pour éviter un effet de bord malencontreux.
If dim([M]DEGMAL) > 0 & [M]DEGMAL = 0
 [M]DEGMAL = 3
Endif

If GPAYE
 Gosub SAVE_RETROCTR From SUBCTRRET
 #If the field doesn't exist in screens or if it's null (security)
 #-----> We have to assign it in the file
 Local Char ZONE(10) : ZONE = "FLGCREBUL"
 Gosub SET_ZONE
 If !MA  or [M]FLGCREBUL=0
   Local Integer TEMPO
   #Manage the box 'Break payslip' (2 = Assign only)
   [L]TEMPO=[F:HRCTR]FLGCREBUL
   Call UPD_FLGCREBUL(TEMPO, 2) From SUBCTR2
   [F:HRCTR]FLGCREBUL=[L]TEMPO
 Endif
Endif
Return

########################################################
$INIMOD
If [F:ID]FLGINT<>2 & [M:CTR0]FLGVAR<>2
 Local Integer WOK
 WOK=1
 Call CONTROLE_ENT_CTRGRD([M:CTR0]CTRGRD,1,WOK) #bug 91300 Suite 85360
 If !WOK : GERR=1 : GOK=0 : Endif
Endif

If [M:CTR0]FLGRET<>2
#JOJAC - 2016-06-08 - REQ114309 US215 START
 #If GINTMT=1 & [F:ID]FLGINT=2 & [M:CTR3]STACTR=2
 If GINTMT=1 & [F:ID]FLGINT=2 & [M:CTR3]STACTR=2 & func DIVPAYE.IS_KFR_LEG(GCURLEG)
 #JOJAC - 2016-06-08 - REQ114309 US215 END
#JASMI - 2016-05-23 - START
#  If max([M:CTR3]PSNENDDAT)<[F:CTR]CTRDAT
  If max([M:CTR3]PSNENDDAT)<[F:HRCTR]CTRDAT
#JASMI - 2016-05-23 - end
   # La date du contrat est postérieure aux dates des prestations
#JASMI - 2016-05-31 - REQ 114309 - START
#   GOK=0 : GMESSAGE = mess(56,701,1)
   GOK=0 : GMESSAGE = mess(56,10701,1)
#JASMI - 2016-05-31 - REQ 114309 - END
  Else
#JASMI - 2016-05-23 - START
#   [F:CTR]XITDAT = max([M:CTR3]PSNENDDAT)
#   [F:CTR]XITGRD = "FDC"
   [F:HRCTR]XITDAT = max([M:CTR3]PSNENDDAT)
   [F:HRCTR]XITGRD = "FDC"
#JASMI - 2016-05-23 - END
  Endif
 Endif
Endif
#JASMI - 2016-05-23 - START
#If [F:CTR]FLGVAR=0 : [F:CTR]FLGVAR=1 : Endif
If [F:HRCTR]FLGVAR=0 : [F:HRCTR]FLGVAR=1 : Endif
#JASMI - 2016-05-23 - END
Gosub SAUVE_EVT From SUBCTR2
#LIPET - 2017-06-27 - X3-32840 - START
Gosub CRE_HRLST From SUBCTR2
#LIPET - 2017-06-27 - X3-32840 - END
## V01X08 - Délégation maladie disparaît (public seulement), on force la valeur trois si vide
##          pour éviter un effet de bord malencontreux.
If dim([M]DEGMAL) > 0 & [M]DEGMAL = 0
    [M]DEGMAL = 3
Endif

If GPAYE
 Gosub SAVE_RETROCTR From SUBCTRRET
Endif
Return

