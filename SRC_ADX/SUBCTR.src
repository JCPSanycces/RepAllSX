Subprog MULCTR(VREFNUM,VCTRNUM,ISOK)
Variable Char VREFNUM,VCTRNUM
Variable Integer ISOK : ISOK=2
Call MULCTR(VREFNUM,VCTRNUM,ISOK) From SUBCTR2
End


Subprog C_CTRNUM(VALEUR)
Variable Char     VALEUR
Local Integer OK
If clalev([F:CTR2])=0 : Local File EMPLOCTR [CTR2] : Endif
If clalev([F:ID])=0   : Local File EMPLOID  [ID]   : Endif
If VALEUR<>""
 Filter [CTR2] Where REFNUM<>[M]REFNUM & CTRNUM=VALEUR
 Read[CTR2]CTR0 First
 Filter [CTR2]
 If !fstat
  # Ce contrat est rattaché au salarié
#JOJAC - 2016-06-02 - REQ114309 US215 - START
  #GMESSAGE = mess(61,701,1)-[F:CTR2]REFNUM
  GMESSAGE = mess(61,10701,1)-[F:CTR2]REFNUM
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  mkstat = 2 : End
 Endif
Else
 Filter [CTR2] Where REFNUM=[M]REFNUM
 Read[CTR2]CTR0 First
 Filter [CTR2]
 If !fstat
   OK = 2
#JOJAC - 2016-06-02 - REQ114309 US215 - START
   #Call AVERTIR(mess(51,701,1),OK) From GESECRAN
   Call AVERTIR(mess(51,10701,1),OK) From GESECRAN
#JOJAC - 2016-06-02 - REQ114309 US215 - END
   If OK=1 : mkstat = 2 : End : Endif
 Endif
Endif
If !(GPILNAV>1 & find(GNAVIG(GPILNAV-1), "GESEML")) & !GIMPORT
  If VALEUR <> "" & (VALEUR <> [M]CTRNUM | [F:HRCTR]CTRDAT <> [M]CTRDAT)
   If GREP<> "C" & [M]CTRDAT <> [0/0/0]
     [M:CTR0]=[F:HRCTR]
     Affzo [M:CTR0]
    Else
      If GREP= "C" & [M:CTR0]ETRFCY<>[F:HRCTR]ETRFCY
        Local Char     PETRFCY
        PETRFCY=[F:HRCTR]ETRFCY
        Call AM_ETRFCY(PETRFCY)
        If mkstat =2 : End : Endif
        [M:CTR0]ETRFCY=[F:HRCTR]ETRFCY
#JOJAC - 2016-06-02 - REQ114309 US215 - START
        #Affzo [M:CTR0]ETRFCY,ZETRFCY
        Affzo [M:CTR0]ETRFCY,ZETRFCY,CPY,LEG
#JOJAC - 2016-06-02 - REQ114309 US215 - START
      Endif
   Endif
  Endif
Endif

If [M]CTRNUM<>VALEUR
 [M]CTRNUM=VALEUR
 #Manage the box 'Break payslip' (1 = Assign & Display)
 If GPAYE : Call UPD_FLGCREBUL([M]FLGCREBUL, 1) From SUBCTR2 : Endif
Endif
End

Subprog AS_CTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR=date$
Endif
End

Subprog C_CTRGRD(VALEUR)
Variable Char    VALEUR()
Call C_CTRGRD(VALEUR) From SUBCTR2

End

Subprog AM_NATCON(VALEUR)
Variable Char    VALEUR()
Local Char ZONE(10)
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#Call GRISE_GRDCDD (VALEUR)
#Read[F:ADI]CODE=354;VALEUR
Call SIMPLEREAD(VALEUR,GCURLEG,GERRHRM) From SUBHRNCT
If !GERRHRM
 Call GRISE_GRDCDD ([F:HRNCT]CODN4H)
#If fstat=0
# If VALEUR="COD"
#  ZONE = "CDDGRD"
#  Gosub SET_ZONE
#  If MA
#   [M]CDDGRD=VALEUR
#   Affzo CDDGRD
#  Endif
# Endif
# CODA1=[F:ADI]A1
CODA1=[F:HRNCT]CODN4H
# If GDOSLEG="FRA" & CODA1="03" : # CTT alors type d'emploi est intérimaire.
If CODA1="03" : # CTT alors type d'emploi est intérimaire.
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  ZONE = "TYPJOB"
  Gosub SET_ZONE
  If MA
   [M]TYPJOB = 3
   Call C_TYPJOB([M]TYPJOB)
   Affzo TYPJOB
  Endif
 Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - START
Else
 GMESSAGE=mess(4,10707,1)-"HRNATCON [HRNCT]"
#JOJAC - 2016-06-02 - REQ114309 US215 - END
Endif

 If func ISKZAKAQ() Then
  [M:CTR1]TYPJOB = func DIVPAYE.SET312(VALEUR)
  Affzo [M:CTR1]TYPJOB
Endif

End

Subprog AM_ETRFCY(VALEUR)
Variable Char    VALEUR()
Local Char    CRITCTRL (250), SOC(GLONCPY), VOIDCHAR(250)
#JOJAC - 2016-06-02 - REQ114309 US215 - START
Local Char       TMPLEG (20)
#JOJAC - 2016-06-02 - REQ114309 US215 - END
Local Integer OK

#JOJAC - 2017-02-15 - START
Raz [M:CTR1]PERCOD : Affzo [M:CTR1]PERCOD
#JOJAC - 2017-02-15 - END

If GREP<>"C" & GREP<>"D" & [F:ID]FLGINT<>2
  Gosub CONTROLE :#Paies présentes sur la période
  If mkstat : End : Endif
#ADNGO - 2016-05-22 - START
#JOJAC - 2016-06-02 - REQ114309 US215 - START
##** V7 : Waiting Time Mangement **#
#   Gosub CONTROLE_TIP : # Temps présents sur la période
#   If mkstat : End : Endif
##**
#JOJAC - 2016-06-02 - REQ114309 US215 - END
   Gosub CONTROLE_TIP : # Temps présents sur la période
   If mkstat : End : Endif
#ADNGO - 2016-05-22 - END
  Endif

#JOJAC - 2016-06-02 - REQ114309 US215 - START
# Multi_leg & multi_société
If VALEUR<>""
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 GSOCIETE=[F:CPY]CPY : [M:CTR0]CPY=GSOCIETE
 #19/04/12 - DKA - Compare site legislation to see if legislation has changed
 TMPLEG = GCURLEG
 If dim([F:CPY]LEG)>0
   GCURLEG =[F:CPY]LEG : [M:CTR0]LEG=GCURLEG
 Endif
 If TMPLEG <> GCURLEG
   #18/04/12 - DKA - Clear fields on site change to avoid error reading table with no corresponding legislation
   Effzo [M:CTR0]NATCON
   Effzo [M:CTR0]ZNATCON
   Effzo [M:CTR0]CTRGRD
   Effzo [M:CTR0]ZCTRGRD

   # Display\Hide fields based on legislation
#JASMI - 2016-06-06 - REQ 114309 - START
####JOJAC - 2016-06-02 - REQ114309 US215 - START
###   Call DISPLAY_HIDE() From SUBCTRLEG
###   #Call HIDE_ACTIVITYFIELDS From WOCTRHIDE
###   #Call SHOW_LEGACTCALLS From WOCTRSHOW
####JOJAC - 2016-06-02 - REQ114309 US215 - END
#JASMI - 2016-06-06 - REQ 114309 - END
# Refresh AGNMIDWRK based on legislation - move to SUBCTRLEG?
   Call GRISE_AGENCE([M]TYPJOB)
 Endif

#JASMI - 2017-12-14 - X3-57401 - START
  If GCURLEG='GHA'
    If [M:CTR5]TAXSTAAFR<18
      [M:CTR5]TAXSTAAFR=18
    Endif
  Endif
#JASMI - 2017-12-14 - X3-57401 - END

#PEVAN - 2018-02-01 - X3-75292 - START
  If GCURLEG='KEN'
    If [M:CTR5]TAXSTAAFR<3
      [M:CTR5]TAXSTAAFR=6 #Default to Resident
    Endif
  Endif
#PEVAN - 2018-02-01 - X3-75292 - END

#PEVAN - 2018-06-20 - X3-97490 - START
  If GCURLEG='LSO'
    If [M:CTR5]TAXSTAAFR<3
      [M:CTR5]TAXSTAAFR=6 #Default to Resident
    Endif
  Endif
#PEVAN - 2018-06-20 - X3-97490 - END

Affzo [M:CTR5]

 Local Char    LEGI, LEGC
 Local Integer PNOLIB,OKPAR
 Call VERIF_AML_EML(VALEUR,0,1,"CIVIL",PNOLIB,LEGI,LEGC,OKPAR) From SUBCTR2
 [M:CTR4]NOLIB=PNOLIB
 Actzo [M:CTR4]CIVCTRA
 #JOJAC - 2017-03-01 - START
 If LEGI<>LEGC
    Infbox mess(193,10701,1)
 Endif
 #JOJAC - 2017-03-01 - END
 If OKPAR Then
  If [M:CTR4]CIVCTR=0 & LEGI=LEGC Then [M:CTR4]CIVCTR = [F:ID]CIV : Endif
  If [M:CTR4]CIVCTR>0 Then [M:CTR4]CIVCTRA=mess([M:CTR4]CIVCTR,[M:CTR4]NOLIB,1) : Endif
  Affzo [M:CTR4]CIVCTRA
  #JOJAC - 2016-07-25 - REQ114309 - START
  #If LEGI=LEGC Then
  # Grizo [M:CTR4]CIVCTRA
  #Endif
  #JOJAC - 2016-07-25 - REQ114309 - END
 Else
  mkstat=2 : End
 Endif
 Read [F:ID]ID0=[M]REFNUM
 If !fstat & [F:ID]FCYORI<>"" & [F:ID]FCYORI<>VALEUR Then
   Call LECTURE("FCY",[F:ID]FCYORI,"")  From CONTOBJ : LEGI = [F:FCY]LEG : # LEGI=leg of the employee
   Call LECTURE("FCY",VALEUR,"")        From CONTOBJ : LEGC = [F:FCY]LEG : # LEGC=leg of the current contract
   If LEGI<>LEGC Then
      Call AVERTIR(mess(129,10701,1),OK) From GESECRAN : # La législation de ce site est différente de celle du site principal du salarié
      If OK=2 Then  GERR=2 : GMESSAGE=(mess(189,10701,1))  :  mkstat = 1 : Endif
      If OK=1 Then
      mkstat = 2 : End
   Else
      [M:CTR4]CIVCTR  = 0
      [M:CTR4]CIVCTRA = ""
      Affzo [M:CTR4]CIVCTRA
      Actzo [M:CTR4]CIVCTRA
     Endif
   Endif
 Endif
Else
 [M:CTR0]CPY=GSOCIETE
 If dim([M:CTR0]LEG)>0
   [M:CTR0]LEG=GCURLEG
 Endif
Endif

#JOJAC - 2016-06-02 - REQ114309 US215 - END

##** V7 : Waiting Time Mangement **#
#JOJAC - 2016-06-02 - REQ114309 US215 - START
  #JOJAC - 2017-01-23 - START
  GRETTIP=1
  #JOJAC - 2017-01-23 - END
##**
#JOJAC - 2016-06-02 - REQ114309 US215 - END
#ADNGO - 2017-05-22 - START
 # If GREP<>"C" & GREP<>"D" & [F:ID]FLGINT<>2
 #  Gosub CONTROLE :#Paies présentes sur la période
 #  If mkstat : End : Endif
   If GREP<>"C" & GREP<>"D" & [F:ID]FLGINT<>2
    Gosub CONTROLE :#Paies présentes sur la période
    If mkstat : End : Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - START
##** V7 : Waiting Time Mangement **#
#   Gosub CONTROLE_TIP : # Temps présents sur la période
#   If mkstat : End : Endif
##**
#JOJAC - 2016-06-02 - REQ114309 US215 - END
   Gosub CONTROLE_TIP : # Temps présents sur la période
   If mkstat : End : Endif
  Endif
#ADNGO - 2017-05-22 - END
#JASMI - 2016-06-02 - REQ 114309 - START
#  If func ISKSA()
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
    Call AM_ETRFCY(VALEUR,OK) From SUBCTRKSA
    If OK = 1 : mkstat = 2 : End : Endif
  Endif

# Avertissement si l'on crée une entrée sur un site appartenant à une société différente d'une entrée
# déjà existante.
If (GREP="C" | GREP="D")
 SOC =""
 If clalev([F:CTR1])=0 : Local File EMPLOCTR[CTR1] : Endif
 Filter [CTR1] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT<[M]CTRDAT
 Read [CTR1]CTR1 Last
 Filter [CTR1]
 If !fstat
  Call LECTURE("FCY",[F:CTR1]ETRFCY,"") From CONTOBJ
  SOC = [F:FCY]LEGCPY
# Endif
# --- The new VALUE ------
  Call LECTURE("FCY",VALEUR,"") From CONTOBJ
   If [F:FCY]LEGCPY<>SOC : #& SOC <>""
     # Changement société/Les cumuls niveau salarié sont repris dans la nouvelle société sauf si la zone Raz Cumul cochée
     OK = 2
#JASMI - 2016-05-30 - REQ 114309 - START
#     Call AVERTIR (mess(15,701,1),OK) From GESECRAN
     Call AVERTIR (mess(15,10701,1),OK) From GESECRAN
#JASMI - 2016-05-30 - REQ 114309 - END
     If OK=1 : mkstat = 2 : End : Endif
   Endif
 Endif
Endif

#JOJAC - 2016-06-02 - REQ114309 US215 - START
 # Display\Hide fields based on legislation
#JASMI - 2016-06-06 - REQ 114309 - START
### #JOJAC - 2016-06-02 - REQ114309 US215 - START
### Call DISPLAY_HIDE() From SUBCTRLEG
### #Call HIDE_ACTIVITYFIELDS From WOCTRHIDE
### #Call SHOW_LEGACTCALLS From WOCTRSHOW
### #JOJAC - 2016-06-02 - REQ114309 US215 - END
#JASMI - 2016-06-06 - REQ 114309 - END
 # Refresh AGNMIDWRK based on legislation - move to SUBCTRLEG?
 Call GRISE_AGENCE([M]TYPJOB)

#JASMI - 2016-05-30 - REQ 114309 - START
##** V7 : Waiting Update Accounting **#
## Activation désactivation de l'écran CTR9 - Infos comptables contrat
# # en fonction d'une valeur paramètre définissable au site.
#
# If dim([M:CTR9]FLGCTRCPT) > 0
#    Call SETMSK_CTR9([L]VALEUR) From SUBCTR
#    If [M:CTR9]FLGCTRCPT = 2
#        # Récupération des valeurs par défaut depuis la fiche salarié
#        # pour l'impact sur les valeurs / défaut liées à l'emploi
#        Call VALDEF_CTR9([M:CTR0]REFNUM) From SUBCTR
#        Call AS_NBAXECPR
#        Affzo [M:CTR9]
#    Endif
# Endif
##**
#JOJAC - 2016-06-02 - REQ114309 US215 - END
#JASMI - 2016-05-30 - REQ 114309 - END

#JOJAC - 2016-07-07 - START
 If TMPLEG <> "" & TMPLEG <> GCURLEG
   [M:CTR4]SITFAM  = 0
   [M:CTR4]SITFAMA = ""
 Endif
 Local Integer WSITFAM
 WSITFAM=[M:CTR4]SITFAM
 #JOJAC - 2016-07-07 - REQ114309 - START
 #Call VERIF_AML_EML(PFCY,WSITFAM,1,"SITFAM",PNOLIB,LEGI,LEGC,OKPAR) From SUBEML2
 Call VERIF_AML_EML(VALEUR,WSITFAM,1,"SITFAM",PNOLIB,LEGI,LEGC,OKPAR) From SUBCTR2
 #JOJAC - 2016-07-07 - REQ114309 - END
 [M:CTR4]NOLIBM=PNOLIB
 If OKPAR
   [M:CTR4]SITFAM  = WSITFAM
   If(WSITFAM<>0)
     [M:CTR4]SITFAMA = mess(WSITFAM,[M:CTR4]NOLIBM,1)
   Else
     [M:CTR4]SITFAMA=""
   Endif
 Else
  [M:CTR4]SITFAMA=""
 Endif
 [M:CTR4]NOLIBM=PNOLIB
 Affzo [M:CTR4]NOLIBM

 # Fin FQ81085
#JOJAC - 2016-07-07 - END

Gosub RET_EXTOURNE
If mkstat : End : Endif

#JASMI - 2016-05-30 - REQ 114309 - START
#JOJAC - 2016-06-02 - REQ114309 US215 - START
## Compare the country of the main site of the employee, and the country of the
## site of the contract, to determine if the fields can be seizable or not
#[M:CTR0]ETRFCY=VALEUR
#Call SEIZE_NUMSSC([M:CTR0]ETRFCY)
## US 2216 88174 BULDEM
#JOJAC - 2016-06-02 - REQ114309 US215 - END
#JASMI - 2016-05-30 - REQ 114309 - END

# To do after all the controls,
# to display fields linked to the new FCY VALEUR
Gosub REFRESH_BULDEM

Gosub REFRESH_CPR

#GSOCIETE=[F:FCY]LEGCPY
#[M:CTR0]CPY=[F:FCY]LEGCPY
#JASMI - 2016-06-06 - REQ 114309 - START
If TMPLEG <> GCURLEG
  Gosub STYLE
#JASMI - 2018-01-11 - X3-70568 - START
Else
  If GREP="C"
    Gosub STYLE
  Endif
#JASMI - 2018-01-11 - X3-70568 - END
Endif
#JASMI - 2016-06-06 - REQ 114309 - END
Filter [F:CTR1]
If GCURLEG = 'BRI' and func DIVPAYE.EXISTE_KXX("SUBCTRUKI") Then
  Call DEFAULTTAXYEASTR()From SUBCTRUKI
Endif
End

######################
$RET_EXTOURNE
If dim([M:CTRA]FLGRET) > 0 & [M:CTRA]FLGRET = 2 & [M:CTRA]RETTYP = 1
  Local Integer OK_MODIF
  #Avenant au contrat avec retroactivité, le type de retroactivité 'Extourne' est plus approprié à cette modification.
  #Confirmez-vous la modification ?
#JOJAC - 2016-06-02 - REQ114309 US215 - START
  #Call AVERTIR(mess(97,701,1)+"\"+mess(180,133,1)-"?", [L]OK_MODIF) From GESECRAN
  Call AVERTIR(mess(97,10701,1)+"\"+mess(180,133,1)-"?", [L]OK_MODIF) From GESECRAN
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  If [L]OK_MODIF = 1 : mkstat = 2 : Return : Endif
Endif
Return

