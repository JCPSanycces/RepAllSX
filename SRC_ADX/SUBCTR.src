Subprog AM_WRKADD3(VALEUR)
Variable Char    VALEUR()
If clalev([F:POS])=0 : Local File POSCOD [POS] : Endif
If VALEUR<>""
 VALEUR=toupper(VALEUR)
 Read [POS]POS1(2) = [M]WRKCRY;VALEUR
 If fstat<=2
  [M]WRKCODSEE = [F:POS]POSCTYCOD
  Affzo WRKCODSEE
 Endif
Endif
End

Subprog AS_WRKCODSEE(VALEUR)
Variable Char    VALEUR()
If clalev([F:POS])=0 : Local File POSCOD [POS] : Endif
If VALEUR="" & [M]WRKCRY<>"" & [M]WRKCODPOS<>"" & [M]WRKCTY<>""
 Read [POS]POS1 = [M]WRKCRY;[M]WRKCTY;[M]WRKCODPOS
 If !fstat
  VALEUR = [F:POS]POSCTYCOD
 Endif
