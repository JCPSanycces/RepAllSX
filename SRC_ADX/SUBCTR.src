VALEUR = ([M]PSNENDDAT(nolign-1)-[M]PSNSTRDAT(nolign-1))+1
End

Subprog AS_NBRTIM(VALEUR)
Variable Decimal  VALEUR
Local Decimal VALHMDEB, VALHMFIN
If [M]PSNSTRTIM(nolign-1)<>"" & [M]PSNENDTIM(nolign-1)<>""
#JOJAC - 2016-06-02 - REQ114309 US215 - START
 #Call CONVERTHM([M]PSNSTRTIM(nolign-1),VALHMDEB) From SUBSTY
 #Call CONVERTHM([M]PSNENDTIM(nolign-1),VALHMFIN) From SUBSTY
 Call CONVERTHM([M]PSNSTRTIM(nolign-1),VALHMDEB) From DIVPAYE
 Call CONVERTHM([M]PSNENDTIM(nolign-1),VALHMFIN) From DIVPAYE
#JOJAC - 2016-06-02 - REQ114309 US215 - END
 If VALHMFIN>=VALHMDEB
  VALEUR = VALHMFIN-VALHMDEB
 Else
  VALEUR = 24-VALHMDEB + VALHMFIN
 Endif
 VALEUR = VALEUR*([M]PSNENDDAT(nolign-1)-[M]PSNSTRDAT(nolign-1)+1)
 mkstat=2
Endif
End

