########################################################
$MAJ_PSNBUL
If clalev([F:PSN2])=0 : Local File PRESTATION [PSN2] : Endif
For [PSN2]PSN0 Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & CTRDAT=[M:CTRA]RETCTRDATORI & toupper(BUL)=toupper(mess(1,303,1))
  Raz [F:PSN2]BUL
  Rewrite [F:PSN2]
  If fstat
   GOK = 0 : Call FSTA("PSN2") From GLOCK : Break
  Endif
Next
If !GOK : Return : Endif
Return

########################################################
$AV_VERF_ANU
#LIMAS - 2017-09-20- US X3-55115- START
#Variable Integer MKSTR
Local Integer MKSTR : MKSTR=0
Call CHK_CTR([M:CTR0]REFNUM,[M:CTR0]CTRNUM,MKSTR) From SUBCTR2
mkstat=MKSTR
 If mkstat
   Raz mkstat
    GMESSAGE = mess(256,10702,1)
    GOK=0 : Return
  Endif
#LIMAS - 2017-09-20- US X3-55115- END
CRITCTRL = "CTRNUM='"+[M]CTRNUM+"'"
CRITCTRL-="& CTRDAT=["+num$([M]CTRDAT)+"]"
Call CONTROLE_PAYE([M]REFNUM, CRITCTRL)
If mkstat
 #Suppression impossible : Paies présentes sur la période
 Raz mkstat
#JOJAC - 2016-06-02 - REQ114309 US215 - START
 #GMESSAGE = mess(9,701,1)
 GMESSAGE = mess(9,10701,1)
#JOJAC - 2016-06-02 - REQ114309 US215 - END
 OKANU=0 : Return
Endif
##**82073
#ADNGO - 2017-05-22 - START
##** V7 : Waiting Time Mangement **#
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#Gosub CONTROLE_TIP3
#If mkstat
#  #Suppression impossible : Temps saisis sur la période
# Raz mkstat
# OKANU=0 : Return
#Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - END
Gosub CONTROLE_TIP3
If mkstat
 #Suppression impossible : Temps saisis sur la période
 Raz mkstat
 OKANU=0 : Return
Endif
#ADNGO - 2017-05-22 - END
#Test en suppression de contrat si contrat sur fiche de rétroactivité
#Pour une obscure raison les variables déclarées dans $OUVRE ne sont plus la !
#d'où déclaration PRESENCE_REC ici ...
Local Integer PRESENCE_REC

# Pas de suppression si le contrat apparaît sur une fiche de rétroactivité
# non validée : en effet si la fiche a été validée, il existe des payes
# donc on aura planté avant. Le seul cas qui nous intéresse est d'empêcher
# de supprimer un avenant s'il apparaît sur une fiche "à traiter".
If GPAYE
 Filter [F:RES] Where [F:RES]REFNUM = [M:CTR0]REFNUM
&                   & [F:RES]CTRNUM = [M:CTR0]CTRNUM
&                   & [F:RES]CTRDAT = [M:CTR0]CTRDAT
 For [F:RES]
  [L]PRESENCE_REC = 1    : # Est ce qu'on a un enregistrement dans REC
  For [F:REC]REC0(3) Where [F:REC]RETNUM = [F:RES]RETNUM
&                        & [F:REC]RECREFNUM = [F:RES]REFNUM & [F:REC]RECCTRNUM = [F:RES]CTRNUM
   [L]PRESENCE_REC = 2    : # Oui, on a un enregistrement
   # Présence d'enregistrement sans numéro de bulletin dessus => pas traité ( calculé ).
   If [F:REC]RECBUL = ""
    [L]OKANU = 0        : # Pas de suppression
    Break 2
   Endif
  Next
  # Notre contrat apparaît dans [RES] mais pas dans [REC] : il n'a pas été calculé ou validé si extourne
  If [L]PRESENCE_REC = 1
   [L]OKANU = 0
   Break
  Endif
 Next
 Filter [F:RES]
 If [L]OKANU = 0
  # Suppression : Avenant présent sur une fiche de rétroactivité
#JOJAC - 2016-06-02 - REQ114309 US215 - START
  #Call ERREUR(mess(112, 701, 1)) From GESECRAN
  Call ERREUR(mess(112, 10701, 1)) From GESECRAN
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  [L]OKANU = 0
  Return
 Endif

 #Pas de suppression si le contrat apparaît sur une fiche de régularisation
 Filter [RGL] Where ENAFLG=2 & find([M:CTR0]REFNUM+"~"+[M:CTR0]CTRNUM+"~"+format$("D:YYYYMMDD",[M:CTR0]CTRDAT), [F:RGL]CTRCRI)
 Look [RGL]RGL0 First
 Filter [RGL]
 If !fstat
  # Suppression : Avenant présent sur une fiche de régularisation
#JOJAC - 2016-06-02 - REQ114309 US215 - START
  #Call ERREUR(mess(144, 701, 1)) From GESECRAN
  Call ERREUR(mess(144, 10701, 1)) From GESECRAN
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  [L]OKANU = 0:   Return
 Endif

 #Pas de suppression si le contrat apparaît sur une fiche d'exception de calcul
 Filter [ECH] Where find([M:CTR0]REFNUM+"~"+[M:CTR0]CTRNUM+"~"+format$("D:YYYYMMDD",[M:CTR0]CTRDAT), [F:ECH]CTRCRI)
 Look [ECH]ECH0 First
 Filter [ECH]
 If !fstat
  # Suppression : Avenant présent sur une fiche d'exception de calcul
#JOJAC - 2016-06-02 - REQ114309 US215 - START
  #Call ERREUR(mess(145, 701, 1)) From GESECRAN
  Call ERREUR(mess(145, 10701, 1)) From GESECRAN
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  [L]OKANU = 0 : Return
 Endif

 Filter [F:VPR] Where EMP=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & CTRDAT=[M:CTR0]CTRDAT
 Look [VPR]VPR0 First
 Filter [VPR]
 If !fstat
  # Suppression : Avenant présent en saisie de valeurs prévisionnelles
#JOJAC - 2016-06-02 - REQ114309 US215 - START
  #Call ERREUR(mess(148, 701, 1)) From GESECRAN
  Call ERREUR(mess(148, 10701, 1)) From GESECRAN
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  [L]OKANU = 0 : Return
 Endif

 Filter [F:PPD] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & CTRDAT=[M:CTR0]CTRDAT
 Look [F:PPD]PPD0 First
 Filter [F:PPD]
 If !fstat
  # Suppression : Avenant présent sur un bordereau de prépa-paie
#JOJAC - 2016-06-02 - REQ114309 US215 - START
  #Call ERREUR(mess(149, 701, 1)) From GESECRAN
  Call ERREUR(mess(149, 10701, 1)) From GESECRAN
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  [L]OKANU = 0 : Return
 Endif
Endif

# Suppression bloquante si le contrat existe dans un autre fichier et que c'est la dernière fiche du contrat
Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM
If rowcount([CTR1])=1
 Filter [CTR1]
#JOJAC - 2016-06-02 - REQ114309 US215 - START
##** V7 : Waiting Time Mangement **#
# For [A_TZ] Where CODTYP="CTR" & CODFIC<>"EMPCTR" & CODFIC<>"PRESTATION"
#&               & CODFIC<>"SOLDPAY" & CODFIC<>"CNGEMP"
##**
#JOJAC - 2016-06-02 - REQ114309 US215 - END
 For [A_TZ] Where CODTYP="CTR" & CODFIC<>"EMPCTR" & CODFIC<>"PRESTATION"
&               & CODFIC<>"SOLDPAY" & CODFIC<>"CNGEMP"
&               & CODFIC<>"EMPLOCTR" & CODFIC<>"EMPLOCUM" & CODFIC<>"EMPLOPOT"
&               & CODFIC<>"EMPLOSAL" & CODFIC<>"EMPLOCTRCPT" & CODFIC<>"EMPSBD"
&               & CODFIC<>"EMPLOCTRSA" & CODFIC<>"EMPLOCTRPOR"
&               & CODFIC<>"EMPLOCTRFRA" & CODFIC<>"EMPLOCTRPEN"
&               & CODFIC<>"EMPLOCTRAFR" & CODFIC<>"EMPLOCTRMID"
&               & CODFIC<>"EMPLOTAXREC" & CODFIC<>"HRAFRCLASS"
&               & left$(CODFIC,3)<>"TMP"
#JASMI - 2016-04-06 - ISSUE 115628 - START - Added EMPLOTAXREC & HRAFRCLASS
  FICHIER = [F:A_TZ]CODFIC
  Read [A_TB]CODFIC = FICHIER
  Call AFF_VLC(mess(56,123,1),FICHIER) From GESECRAN : # Table
  K = 0
  If [F:A_TB]TYPFIC=3 & nomap=APPLI & filinfo(filpath("FIL",FICHIER,"fde"),0)>0 : # Table système
   K = 1
  Elsif filinfo(filpath("FIL",FICHIER,"fde",APPLI),0)>0
   K = 1
  Endif
  If K & APPLI=GDOSH
   Call VUE_OK(FICHIER,APPLI,"FIL",K) From DOSVUE
   K = !K
  Endif
  If K
   If nomap=APPLI
    Local File =FICHIER [LIE_]
   Else
    Local File =APPLI+"."+FICHIER [LIE_]
   Endif
   SUBCRIT = [F:A_TZ]CODZONE+'="'+[M]CTRNUM+'"'

   If FICHIER="EVAEMP" :
      SUBCRIT-='& EVAVAL<10'
   Endif

   Filter [LIE_] Where evalue(SUBCRIT)
   For [LIE_]
    OKANU = 0
   Next
   Filter [LIE_]

   If OKANU=0
    REFERR(1) = mess(46,150,1) : # Annulation
    REFERR(1) -= mess(198,133,1)-FICANU : # dans - Table sur laquelle on fait la suppression
    Call TEXTE([F:A_TB]INTITFIC,CHAINE) From OBJDIV
    REFERR(1) -= "("+CHAINE+")" : # Intitulé de la table associée à l'objet sur lequel on fait la suppression
    Read [A_TI]NUMLIG(2) = FICHIER;1
    CHAINE = [F:A_TI]DESCRIPT
    Raz I, CLE, CLE1, CLE2
    While CHAINE<>""
     I1 = instr(1,CHAINE,"+")
     I2 = instr(1,CHAINE,"-")
     If I2
      If I1 : I1 = min(I1,I2) : Else : I1 = I2 : Endif
     Endif
     If I1
      WCLE = left$(CHAINE,I1-1)
      CHAINE = right$(CHAINE,I1+1)
     Else
      WCLE = CHAINE
      CHAINE = ""
     Endif
     If CLE<>"" : CLE += "~" : Endif
     CLE += num$(evalue("[F:LIE_]"+WCLE))
     I += 1
     Case I
      When 1
       CLE1 = num$(evalue("[F:LIE_]"+WCLE))
      When Default
       If I>2 : CLE2 += "~" : Endif
       CLE2 += num$(evalue("[F:LIE_]"+WCLE))
     Endcase
    Wend
    REFERR(2) = mess(101,126,1)-CLE : # La fiche est utilisée par
    REFERR(2) -= mess(198,133,1) : # dans
    If APPLI<>nomap(0) : REFERR(2) -= APPLI+"."+FICHIER
    Else               : REFERR(2) -= FICHIER
    Endif
    Read [A_TB]CODFIC = FICHIER
    Call TEXTE([F:A_TB]INTITFIC,CHAINE) From OBJDIV
    If vireblc(CHAINE,4)<>"" : CHAINE = "("+CHAINE+")" : Endif
    REFERR(2) -= CHAINE : # Intitulé de la table associé à l'objet dont le type de données est concerné
    REFERR(3) = mess(176,115,1) : # Il faut d'abord supprimer ce lien

    If !GSERVEUR & !GIMPORT
     Call ERRTITT(REFERR(2)+"\"+REFERR(3),REFERR(1)) From GESECRAN
    Else
     GMESSAGE = REFERR(1)+"\"+REFERR(2)
     If !GIMPORT
      GMESSAGE+="\"+REFERR(3)
     Endif
    Endif
    Close Local File [LIE_]
    Break
   Endif
   Close Local File [LIE_]
  Endif
 Next
Else
 Filter [CTR1]
Endif

Return

########################################################
$SETBOUT
[L]CHMEN=""
If GREP="" & VERROU
#JASMI - 2017-08-10 - X3-48900 - START
# ZONE = "FLGCRECTR" : Gosub SET_ZONE
# If MA & ([M]FLGCRECTR=2 | [M]FLGCRELET=2 | [M]FLGCREAVN=2)
 ZONE = "FLGCRE1" : Gosub SET_ZONE
 If MA & [M]FLGCRE1=2
#JASMI - 2017-08-10 - X3-48900 - END
  [L]CHMEN+="1"
#JOJAC - 2016-06-02 - REQ114309 US215 - START
     # Ajout 8 Documents administratifs
  [L]CHMEN+="8"
#JOJAC - 2016-06-02 - REQ114309 US215 - END
 Endif
 ZONE = "FLGVAR" : Gosub SET_ZONE
 # Possibilité de créer un avenant VAR uniquement sur le dernier contrat du chrono, si date de sortie
 If MA & [M]XITDAT<>[0/0/0] & GLASTCTR
  [L]CHMEN+="6"
 Endif

 If MA &  [M]FLGVAR<>2 & GLASTCTR & ([F:ID]FLGINT<>2 | ([F:ID]FLGINT=2 & [F:HRCTR]FLGRET<>2))
  [L]CHMEN+="5"
 Endif
  CHMEN+="23"
Else
 # Bouton caisses

 Gosub DES_BUTEVA
Endif

#Objet à 3 éléments de clé : ajout du btn suppression
If CLECUR  CHAINE+="A"  Endif
Call VIREBOUT (CHAINE,"H") From GOBJET    :#91500

If IS_FNCA
  Call PARAM([M:CTR0]ETRFCY,"EVASUI",DISP_EVA)From ADOVAL
  If (DISP_EVA<>"2")
    Gosub DES_BUTEVA
  Endif
Endif
Return

$DES_BUTEVA
  If IS_FNCA
    Call VIREBOUT (CHAINE,"7") From GOBJET
  Endif
Return

########################################################
$FILTRE
FILTSUP   = "[F:ID]FLGNEWSAL<>2"
Call FILTREROLE("EML",FILTSUP) From SUBEML
Call FILTREROLE("CTR",FILTSUP) From SUBEML
If GUSRACS<>2
 FILTSUP -= "& find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV))"
 FILTSUP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
Endif
If GPILNAV>1
 If find(GNAVIG(GPILNAV-1),"GESEML") & GREP<>"C" & GREP<>"D" & dim(TUNCLE)>0
  FILTSUP -= "& CTRNUM='"+TUNCLE+"'"
 Endif
#ADNGO - 2017-05-22 - START
 #JOJAC - 2016-06-02 - REQ114309 US215 - START
 ##** V7 : Waiting Time Mangement **#
# If find(GNAVIG(GPILNAV-1), "TPSSTD")
#  FILTSUP -= "& [F:ID]REFNUM=[M:TPS]REFNUM"
# Endif
# If find(GNAVIG(GPILNAV-1), "GESCNE")
#  FILTSUP -= "& [F:ID]REFNUM=[M:CNE1]REFNUM"
# Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - END
 If find(GNAVIG(GPILNAV-1), "TPSSTD")
  FILTSUP -= "& [F:ID]REFNUM=[M:TPS]REFNUM"
 Endif
 If find(GNAVIG(GPILNAV-1), "GESCNE")
  FILTSUP -= "& [F:ID]REFNUM=[M:CNE1]REFNUM"
 Endif
#ADNGO - 2017-05-22 - END
Endif
Return

########################################################
$FILGAUCHE
FILGAUSUP = "[F:ID]FLGNEWSAL<>2"
Call FILTREROLE("EML",FILGAUSUP) From SUBEML
Call FILTREROLE("CTR",FILGAUSUP) From SUBEML
If GUSRACS<>2
 FILGAUSUP -= "& find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV))"
 FILGAUSUP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
Endif
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 FILGAUSUP -= '& find([F:HRCTR]ETRFCY,GUSRFCY(1..GNBAUZ))'
Endif

#JOJAC - 2016-06-02 - REQ114309 US215 - START
FILGAUCHE = "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) | [F:FCY]LEG='' | GLEGFIL='')"
If FILGAUSUP <> '' FILGAUSUP -= '&' Endif
FILGAUSUP -= "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) | [F:FCY]LEG='' | GLEGFIL='')"
#ADNGO - 2017-05-22 - START
##** V7 : Waiting Time Mangement **#
#If GPILNAV>1
# If find(GNAVIG(GPILNAV-1), "TPSSTD")
#  FILGAUSUP -= "& [F:ID]REFNUM=[M:TPS]REFNUM"
# Endif
# If find(GNAVIG(GPILNAV-1), "GESCNE")
#  FILGAUSUP -= "& [F:ID]REFNUM=[M:CNE1]REFNUM"
# Endif
#Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - END
If GPILNAV>1
 If find(GNAVIG(GPILNAV-1), "TPSSTD")
  FILGAUSUP -= "& [F:ID]REFNUM=[M:TPS]REFNUM"
 Endif
 If find(GNAVIG(GPILNAV-1), "GESCNE")
  FILGAUSUP -= "& [F:ID]REFNUM=[M:CNE1]REFNUM"
 Endif
Endif
#ADNGO - 2017-05-22 - END
Return

########################################################
$FIN
# Pour raffraichir l'écran MAT6 quand tunnel à partir des salariés
If GPILNAV>1 & find(GNAVIG(GPILNAV-1), "GESEML")
 mkstat=4
Endif
Kill GRETTIP, GLASTCTR
#JOJAC - 2016-06-02 - REQ114309 US215 - START
If dim([V]WGOLDCTRNUM)>0 : Kill WGOLDCTRNUM : Endif
If dim([V]WGOLDCTRDAT)>0 : Kill WGOLDCTRDAT : Endif
If dim([V]WGDIFLEG)>0 : Kill WGDIFLEG : Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - END
Return

#JOJAC - 2016-06-02 - REQ114309 US215 - START
$AVANT_CHOI
Read [ID]ID0=[F:HRCTR]REFNUM # Recharger [ID] apres Fillbox de REMPLIT
#JOJAC - 2016-06-07 - REQ114309 US215 - START
#SAV_GLEGFIL = GLEGFIL
#GLEGFIL = ''
#JOJAC - 2016-06-07 - REQ114309 US215 - END
Return
#JOJAC - 2016-06-02 - REQ114309 US215 - END


########################################################
$AVANTBOUT
Case [L]BOUT
 When "2"
  # Bulletins salariés
  GBIDC1 = [M:CTR0]CTRNUM
#JOJAC - 2016-06-02 - REQ114309 US215 - START
    When "8"
    Local Integer TYPDOC
    Local Char CRITERE(250)
    CRITERE = "REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT=[M]CTRDAT"
    Call LECTXC(CRITERE) From CTRDOC
    Gosub LIENS
#JOJAC - 2016-06-02 - REQ114309 US215 - END
Endcase
Return

########################################################
$STATUT
Case [L]BOUT
 When "2"
  # Bulletins salariés
  Raz [V]GBIDC1
 When "3"
  # Changement de date
  # Comme changement de clé on fait un DEVERRROU pour que le RELIT vérouille le nvx code
  If VERROU : Gosub DEVERROU From GOBJET : Endif
  [L]CLECUR2(1) = format$(GFMD,[M:CTR0]CTRDAT)
  Gosub RELIT From GOBJSUB
 When "5","6"
  If VERROU : Gosub DEVERROU From GOBJET : Endif
  #New date de contrat pour avenant retro ou VAR
  If GBIDC2<>"" :
   [L]CLECUR2(1) = format$(GFMD,GBIDC2)
  Endif
  # Avenant VAR avec potentiellement un new chrono
  If BOUT="6" & GBIDC1<>"" : CLECUR1=GBIDC1 : Endif
  Gosub RELIT From GOBJSUB
  If BOUT='5'& GBIDC1<>"" & GBIDC2<>""
    Gosub LOAD_RETTAB  From SUBCTRRET : Gosub SAVE_RETROCTR  From SUBCTRRET
  Endif
  Raz [V]GBIDC1 :  Raz [V]GBIDC2
 Endcase
Return

