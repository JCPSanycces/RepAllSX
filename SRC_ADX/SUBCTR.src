Subprog AM_ETRSRV(VALEUR)
Variable Char    VALEUR()
Local Integer L_OK
#ADNGO - 2017-05-22 - START
#JOJAC - 2016-06-02 - REQ114309 US215 - START
##** V7 : Waiting Time Mangement **#
#GRETTIP=1
##**
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  GRETTIP=1
#ADNGO - 2017-05-22 - END
If GREP<>"C" & GREP<>"D" & [F:ID]FLGINT<>2
 Gosub CONTROLE
 If mkstat
  #Il existe des bulletins calculés pour ce contrat, voulez vous vraiment changer le service ?
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
#JASMI - 2016-05-31 - REQ 114309 - START
#  Call AVERTIR(mess(146, 701, 1),L_OK) From GESECRAN
  Call AVERTIR(mess(146, 10701, 1),L_OK) From GESECRAN
#JASMI - 2016-05-31 - REQ 114309 - END
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
  If L_OK<>2 : End : Endif
  mkstat = 0
 Endif
Endif
End

Subprog C_TYPJOB(VALEUR)
Variable Integer VALEUR
Call GRISE_TAUX_TP(VALEUR,[M]DNACODMOD) From SUBCTR2
If VALEUR<>[M]TYPJOB
 Call AM_RATMIDWRK([M]RATMIDWRK)
Endif
Call GRISE_AGENCE(VALEUR) From SUBCTR2
End

## Sélection poste
Subprog B1_JOB(VALEUR)
Variable Char    VALEUR()
Local Char  PARMSK(250)(1..20) , SAVACT(20), SAVVALEUR(30)
Local Char  ZONE(10)
If !clalev([POT]) : Local File POSTE     [POT] : Endif
SAVACT = GACTION : GACTION = "SELOBJSTD"
SAVVALEUR = VALEUR
PARMSK(1) = "POT"
PARMSK(2) = ""
PARMSK(3) = ""
PARMSK(4) = "([F:POT]DATENDVLY=[0/0/0] | [F:POT]DATENDVLY>=[M]CTRDAT)"
PARMSK(5) = "([M]XITDAT=[0/0/0] | [F:POT]DATSTRVLY<=[M]XITDAT)"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJCRIT","SELOBJ","") From GACTION
GACTION = SAVACT
Read [POT]POT0=VALEUR
If !fstat
#JOJAC - 2016-06-02 - REQ114309 US215 - START
 Call LECTEXTRA(VALEUR,"POSTE","DES",VALEUR,"") From ATEXTRA
#JOJAC - 2016-06-02 - REQ114309 US215 - END
Else
 VALEUR = SAVVALEUR
Endif
End

## Sélection emploi-type
Subprog B2_JOB(VALEUR)
Variable Char    VALEUR()
Local Char    PARMSK(250)(1..20) , SAVACT(20), SAVVALEUR(30)
Local Char  ZONE(10)
If !clalev([F:JOT]) : Local File JOBTYP    [JOT] : Endif

SAVACT = GACTION : GACTION = "SELOBJSTD"
SAVVALEUR = VALEUR
PARMSK(1) = "JOT"
PARMSK(2) = ""
PARMSK(3) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJSTD","SELOBJ","") From GACTION
GACTION = SAVACT
Read [JOT]JOT0=VALEUR

If !fstat
#JOJAC - 2016-06-02 - REQ114309 US215 - START
 Call LECTEXTRA(VALEUR,"JOBTYP","DES",VALEUR,"") From ATEXTRA
#JOJAC - 2016-06-02 - REQ114309 US215 - END
# VALEUR = [JOT]DES
Else
 VALEUR = SAVVALEUR
Endif
End

Subprog AS_RATMIDWRK(VALEUR)
Variable Decimal VALEUR
Local Decimal WEKPAR, MONPAR
If !VALEUR & [M]TYPJOB=14 : VALEUR=100 : Endif :# Forfait jour (N4DS)
End

Subprog AM_RATMIDWRK(VALEUR)
Variable Decimal VALEUR
Local Decimal WEKPAR, MONPAR
Gosub LIRE_SITE
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#WEKPAR=val(func AFNC.PARAM("HOUWEKLEG",[F:SIT]FCY))
#JOJAC - 2016-08-02 - REQ114309 - START
WEKPAR=val(func AFNC.PARAM("HOUWEKLEG",[F:FCY]FCY))
#WEKPAR=val(func AFNC.PARAM("HOUWEKLEG",[F:HRSIT]FCY))
#JOJAC - 2016-08-02 - REQ114309 - START
#JOJAC - 2016-06-02 - REQ114309 US215 - END
If VALEUR>0 & VALEUR<100
 [M]HRSWEK=fix(VALEUR*WEKPAR)/100
Else
 [M]HRSWEK=WEKPAR
Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#MONPAR=val(func AFNC.PARAM("HOUMONLEG",[F:SIT]FCY))
#JOJAC - 2016-08-02 - REQ114309 - START
MONPAR=val(func AFNC.PARAM("HOUMONLEG",[F:FCY]FCY))
#MONPAR=val(func AFNC.PARAM("HOUMONLEG",[F:HRSIT]FCY))
#JOJAC - 2016-08-02 - REQ114309 - END
#JOJAC - 2016-06-02 - REQ114309 US215 - START
If VALEUR>0 & VALEUR<100
 [M]HRSMTH=fix(VALEUR*MONPAR)/100
Else
 [M]HRSMTH=MONPAR
Endif
Affzo [M]HRSWEK,HRSMTH
#109334
#JASMI - 2016-06-01 - REQ 114309 - START
#If func AFNC.ACTIV("FPAY")
If func AFNC.ACTIV("HRPAY") & func DIVPAYE.IS_KFR_LEG(GCURLEG)
#JASMI - 2016-06-01 - REQ 114309 - END
 [M]RATMIDWRK=VALEUR
 Gosub INI_COTMIDWRK From SUBCTR2
 Call GRISE_COTMIDWRK(VALEUR) From SUBCTR2
Endif
End

