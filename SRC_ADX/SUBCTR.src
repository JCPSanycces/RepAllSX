# Function to combine the checks for BRI legislation
# Returns 1 if Current legislation is BRI and program SUBCTRUKI exists, otherwise 0
Funprog BRI_LEG()
Local Integer LOK
LOK = 0
If GCURLEG='BRI'
  LOK = func DIVPAYE.EXISTE_KXX("SUBCTRUKI")
Endif
End LOK
