$VERIF_CRE
#ADNGO - 2017-05-23 - JIRA X3-12050 - START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
    Gosub VERIF_CRE From SUBCTR2
  Endif
#ADNGO - 2017-05-23 - JIRA X3-12050 - END

$VERIF_MOD
#JOJAC - 2016-06-08 - REQ114309 US215 - START
#If GINTMT=1 & [F:ID]FLGINT=2 & [M:CTR3]STACTR=2
If GINTMT=1 & func DIVPAYE.IS_KFR_LEG(GCURLEG) & [F:ID]FLGINT=2 & [M:CTR3]STACTR=2
#JOJAC - 2016-06-08 - REQ114309 US215 - START
 If [M:CTR3]NBRPSN=0
  # Un contrat validé d'un intermittent doit contenir au moins une prestation
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
  #GMESSAGE = mess(38,701,1)
  GMESSAGE = mess(38,10701,1)
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
  OK = 0 : Return
 Endif
Endif
#JOJAC - 2016-06-08 - REQ114309 US215 - START
#If GINTMT=1 & [F:ID]FLGINT=2 & [M:CTR0]CTRNUM<>""
If GINTMT=1 & [F:ID]FLGINT=2 & [M:CTR0]CTRNUM<>"" & func DIVPAYE.IS_KFR_LEG(GCURLEG)
#JOJAC - 2016-06-08 - REQ114309 US215 - END
 ## Add filter about FLGRET
 Filter [CTR1] Where CTRNUM=[M:CTR0]CTRNUM & (REFNUM<>[M:CTR0]REFNUM | CTRDAT<>[M:CTR0]CTRDAT) & FLGRET=[M:CTR0]FLGRET
 Read [CTR1]CTR0 First
 Filter [CTR1]
 If !fstat
  # Chaque contrat d'un intermittent doit avoir un numéro de dossier unique
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
  #GMESSAGE = mess(70,701,1)
  GMESSAGE = mess(70,10701,1)
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
  OK = 0 : Return
 Endif
Endif

Gosub CONTROLE_STATUT
If OK=0 : Return : Endif

Gosub CONTROLE_PREAVIS
If OK=0 : Return : Endif

#JASMI - 2016-05-30 - REQ 114309 - START
#JOJAC - 2016-06-02 - REQ114309 US215 - START
##** V7 : Waiting Update Accounting **#
If dim([M:CTR9]FLGCTRCPT) > 0 & [M:CTR9]FLGCTRCPT = 2
  If [M:CTR9]ACCCOD = ""
    # mess(179,105,1) : Code comptable non défini
    GMESSAGE = mess(179, 105, 1)
    [L]OK = 0
    zonsui = "[M:CTR9]ACCCOD"
    Return
  Endif
  If [M:CTR9]DSP <> ""
#    # If DSP non authorized for the site, RAZ DSP
    Call CTRL_DSP([M:CTR9]DSP,[M:CTR0]ETRFCY,[M:CTR0]CTRDAT) From TRTHRCPT
    If mkstat
       [L]OK = 0
       zonsui = "[M:CTR9]DSP"
       Return
   Endif
 Endif
Endif

If dim([M:CTR9]CCE) > 0 & [M:CTR9]FLGCTRCPT = 2
Local Integer I, WMKSTAT
    For I=0 To dim([M:CTR9]CCE)-1
      If [M:CTR9]CCE(I)<>""
        ## Action CNTCCE
        WMKSTAT=mkstat
        Call SECTION([M:CTR9]CCE(I),2,[M:CTR0]ETRFCY,[0/0/0],[M]DIE(I)) From SUPCPT
        If mkstat
          GMESSAGE=mess(17,103,1)-GMESSAGE
          [L]OK = 0
          zonsui = "[M:CTR9]CEE"
          Break
        Endif
      Endif
    Next
    Return
Endif
#JASMI - 2016-05-30 - REQ 114309 - END

#If GREP<>"M"
# Filter [F:CTR1] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM
# Read [F:CTR1]CTR1 Last
# Filter [F:CTR1]
# If !fstat & [F:CTR1]XITFNL=2
#  VOK=1
#  #Voulez-vous réinitialiser les fiches congés de ce salarié pour ce contrat ?
##JASMI - 2016-05-30 - REQ 114309 - START
##  Call OUINON (mess(82,701,1), VOK) From GESECRAN
#  Call OUINON (mess(82,10701,1), VOK) From GESECRAN
##JASMI - 2016-05-30 - REQ 114309 - END
#  If VOK=2
#   Gosub SUPPR_CNE
#   If !GOK
#    #"Opération impossible : pb d'ecriture sur la table CNGEMP"
#    GMESSAGE = mess(157,123,1)-":"-mess(13,100,1)-"CNGEMP"
#    Return
#   Endif
#  Endif
# Endif
# Gosub CONTROLE_TIP3
# If mkstat : Return : Endif
# GRETTIP=1
#Endif

If  (dim([V]WGOLDCTRNUM)>0 & dim([V]WGOLDCTRDAT)> 0)
   Raz [V]WGOLDCTRNUM
   Raz [V]WGOLDCTRDAT
   If GREP="D"
      If [F:HRCTR]REFNUM=[M:CTR0]REFNUM & [F:HRCTR]CTRNUM<>[M:CTR0]CTRNUM
         [V]WGOLDCTRNUM=[F:HRCTR]CTRNUM
         [V]WGOLDCTRDAT=[F:HRCTR]CTRDAT
      Endif
   Endif
Endif
If  dim([V]WGDIFLEG)>0
  Raz [V]WGDIFLEG
  If GREP<>"C"
     If [F:HRCTR]ETRFCY<>[M:CTR0]ETRFCY
        Call LECTURE("FCY",[F:HRCTR]ETRFCY,"")  From CONTOBJ : WLEGOLD = [F:FCY]LEG
        Call LECTURE("FCY",[M:CTR0]ETRFCY,"")   From CONTOBJ : WLEGNEW = [F:FCY]LEG
        If WLEGOLD<>WLEGNEW Then
          [V]WGDIFLEG=1
        Endif
     Endif
  Endif
Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - END

Call CALL_INIML1

If dim([M:CTRB]NBRPEN)>0 & dim([M:CTRB]FLGEXCPEN)> 0 & [M:CTRB]FLGEXCPEN=2 & [M:CTRB]NBRPEN>0
 Local Integer FLGPEN
 FLGPEN=0
 For I=0 To dim([M:CTRB]PEN)-1
  If [M]CTRDAT>[M:CTRB]ENDDATPEN(I) & [M:CTRB]ENDDATPEN(I)<>[0/0/0]
   FLGPEN+=1
   Break
  Endif
  If [M]XITDAT<>[0/0/0] & [M]XITDAT<[M:CTRB]STRDATPEN(I)
   FLGPEN+=1
   Break
  Endif
 Next
 If FLGPEN
#JASMI - 2016-05-31 - REQ 114309 - START
#  Call AVERTIR (mess(21,724,1), [L]VOK) From GESECRAN :#Veuillez contrôler la cohérence des dates des facteurs de pénibilité
  Call AVERTIR (mess(21,10724,1), [L]VOK) From GESECRAN :#Veuillez contrôler la cohérence des dates des facteurs de pénibilité
#JASMI - 2016-05-31 - REQ 114309 - END
  If [L]VOK = 1
   OK=0 : Return
  Endif
 Endif
Endif


