######################################################################################
## Before Entry - make sure date field hidden when tabbed into, if not FRA legislation

######################################################################################
Subprog AS_STRCAE(VALEUR)
Variable Date    VALEUR
Case GCURLEG
When "FRA", ""
 Chgfmt [M:CTR1]STRCAE    With  "DzZ2:"+GFMDAT4 #CEA signature
When Default
 Chgfmt [M:CTR1]STRCAE    With "-DzZ2:"+GFMDAT4 #CEA signature
Endcase
End

######################################################################################
## Control - 02/05/12 - DKA - Field is mandatory if French legislation


######################################################################################
Subprog C_RSKWRK(VALEUR)
Variable Char    VALEUR()
  Case GCURLEG
   When "FRA", ""
     If VALEUR=""
       #Mandatory field
       GMESSAGE=mess(10,123,1)
       mkstat=2 : End
     Endif
  Endcase
End


Subprog AM_CIVCTRA(VALEUR)
Variable Char    VALEUR()
Local Char NUMLIB(10), LEGI, LEGC
Local Integer CTRCOUNT : CTRCOUNT = 0

[M:CTR4]CIVCTR=val([M]VALINT)

#JOJAC - 2016-07-20 - REQ114309 - START
  #If VALEUR <> [M:CTR4]CIVCTRA
    If clalev([HRCTR2]) = 0 : Local File EMPLOCTR [HRCTR2] : Endif
    Trbegin [HRCTR2]
   # For [F:HRCTR2] Where LEG = [M:CTR0]LEG & REFNUM = [M:CTR0]REFNUM & CTRNUM <> [M:CTR0]CTRNUM & (XITDAT = [00/00/00] | XITDAT >= date$)
    For [F:HRCTR2] Where  REFNUM = [M:CTR0]REFNUM & CTRNUM <> [M:CTR0]CTRNUM & (XITDAT = [00/00/00] | XITDAT >= date$)
      If fstat >= 1
        Rollback
        Break
      Else
        Call LECTURE("FCY",[F:HRCTR2]ETRFCY,"") From CONTOBJ : LEGC = [F:FCY]LEG
        If LEGC = [M:CTR0]LEG
          [HRCTR2]CIVCTR = val([M]VALINT)
          Rewrite [HRCTR2]
        Else
          [L]CTRCOUNT+=1
        Endif
      Endif
    Next
    Commit
    If [L]CTRCOUNT > 0
#MIPEA - 2017-02-28- X3-11258- START
      #GERR = 2  : GMESSAGE = mess(193,10701,1)
#      GERR = 2  : GMESSAGE = mess(191,10701,1)
#MIPEA - 2017-02-28- X3-11258- END
      Filter [F:HRCTR2]
    Endif
#JOJAC - 2016-07-20 - REQ114309 - END
#MIPEA - 2016-10-21 - X3PEOP-907 - START
    If clalev([F:ID2])= 0 : Local File EMPLOID [ID2] : Endif
    Filter [F:ID2]
    Trbegin [ID2]
    Read [F:ID2]ID0 = [M:CTR0]REFNUM
    If clalev([F:FCY2])=0 : Local File FACILITY [FCY2] : Endif
    Read [FCY2]FCY0 = [F:ID2]FCYORI
    If !fstat
      If [F:FCY2]LEG = [M:CTR0]LEG
        [F:ID2]CIV = val([M]VALINT)
        Rewrite [ID2]
        If fstat
          Rollback
        Else
          Commit
        Endif
      Else
        Rollback
      Endif
    Endif
#MIPEA - 2016-10-21 - X3PEOP-907 - START
End
Subprog C_ETRFCY(VALEUR)
Variable Char    VALEUR()
Local    Char    NUMLIB(10), LEGC, LEGF
Local    Integer OK

Filter [CTR1] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT<[M]CTRDAT
Read [CTR1]CTR1 Last
Filter [CTR1]
If !fstat Then
 Call LECTURE("FCY",[F:CTR1]ETRFCY,"") From CONTOBJ : LEGF = [F:FCY]LEG : # Leg of another existing contract with the same contract chrono
 Call LECTURE("FCY",VALEUR,"")         From CONTOBJ : LEGC = [F:FCY]LEG : # Leg of the current contract
 If LEGC<>LEGF Then
  GMESSAGE=mess(128,10701,1) : # Dans un même chrono contrat, les périodes d'activité doivent être dans la même législation
  If LEGF<>"" Then GMESSAGE-="("+LEGF+")" : Endif
  mkstat=2 : End
 Endif
Endif
End
#JOJAC - 2016-06-02 - REQ114309 US215 - END

#JOJAC - 2016-06-02 - REQ114309 US215 - START
######################################################################################
## Etiquette ajoutée par le superviseur (écran CTR1) 24/07/2012 14:32:45 (MLLF)
######################################################################################
Subprog S_JOB(VALEUR)
Variable Char    VALEUR()
Local Char  PARMSK(250)(1..20) , SAVACT(20), SAVVALEUR(30)
Local Char  ZONE(10)
If !clalev([F:POT])   : Local File POSTE     [POT]   : Endif
If !clalev([F:HRCCV]) : Local File CLASSCONV [HRCCV] : Endif
SAVACT = GACTION : GACTION = "SELOBJSTD"
SAVVALEUR = VALEUR
# SBA ajout car on ne connait pas la provenance
VALEUR=""
PARMSK(1) = "POT"
PARMSK(2) = ""
PARMSK(3) = ""
PARMSK(4) = "([F:POT]DATENDVLY=[0/0/0] | [F:POT]DATENDVLY>=[M]CTRDAT)"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJCRIT","SELOBJ","") From GACTION
GACTION = SAVACT
Read [POT]POT0=VALEUR
If !fstat
# VALEUR = [F:POT]DES
 Local Char DES
 Call LECTEXTRA(DES,"POSTE","DES",VALEUR,"") From ATEXTRA
 VALEUR=DES
 If [F:POT]CCV<>""
  Read [HRCCV]CCV0=[F:POT]CCV;GCURLEG
  If !fstat
   For ZONE = "GRA","COE","IND","CATCSP"
    Gosub SET_ZONE
    If MA
     Case ZONE
      When "GRA"    : [M]GRA    = [F:HRCCV]GRA    : Affzo [M]GRA
      When "COE"    : [M]COE    = [F:HRCCV]COE    : Affzo [M]COE
      When "IND"    : [M]IND    = [F:HRCCV]IND    : Affzo [M]IND
      When "CATCSP" : [M]CATCSP = [F:HRCCV]CATCSP : Affzo [M]CATCSP
     Endcase
    Endif
   Next
  Endif
   Endif
Else
 VALEUR = SAVVALEUR
Endif
End

