###############################################################################
Subprog LEC_TVT(ACTX, TVTCOD, LEG)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char TVTCOD
Value Char LEG

  fstat = [V]CST_AOK
  If [F:TVT]VAT <> TVTCOD or [F:TVT]LEG <> LEG Then
    LEG = func GET_MONO_LEG(ACTX, LEG)
    Read [TVT]TVT0=TVTCOD;LEG
    If fstat Then
      Read [TVT]TVT0=TVTCOD;""
    Endif
  Endif
End

###############################################################################
Subprog LEC_SFI(ACTX, SFI)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Integer SFI

  fstat = [V]CST_AOK
  If [F:SFI]SFINUM <> SFI Then
    Read [SFI]SFI0=SFI
  Endif
End

###############################################################################
Subprog LEC_TDA(ACTX, COD, LEG)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char COD
Value Char LEG

  fstat = [V]CST_AOK
  If [F:TDA]DEP <> COD or [F:TDA]LEG <> LEG Then
    LEG = func GET_MONO_LEG(ACTX, LEG)
    Read [TDA]TDA0=COD;LEG
    If fstat Then
      Read [TDA]TDA0=COD;""
    Endif
  Endif
End

