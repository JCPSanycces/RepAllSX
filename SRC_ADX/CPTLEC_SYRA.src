###############################################################################
Funprog GET_MONO_LEG(ACTX, LEG)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char LEG

Local Integer SARENDRE(GLONADI)

  If fmet ACTX.AGETNBLEG() = 1 Then
    SARENDRE = ACTX.APARAM.LIST_LEG(fmet ACTX.AGETNBLEG())
  Else
    SARENDRE = LEG
  Endif
End SARENDRE

###############################################################################
Subprog LEC_CCE_ON_ABREV(ACTX, SABREV, SKEY1, SKEY2)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SABREV
Value Char SKEY1
Value Char SKEY2

  fstat = [V]CST_AOK
  Case SABREV
    When "GCM"
      Call LEC_GCM(ACTX, MODELE)
    When "ITM"
      Call LEC_ITM(ACTX, SKEY1)
    When "BPC"
      Call LEC_BPC(ACTX, SKEY1)
    When "BPS"
      Call LEC_BPS(ACTX, SKEY1)
    When "REP"
      Call LEC_REP(ACTX, SKEY1)
    When "AUS"
      Call LEC_AUS(ACTX, SKEY1)
    When "CPY"
      Call LEC_CPY(ACTX, SKEY1)
    When "FCY"
      Call LEC_FCY(ACTX, SKEY1)
    When "TCU"
      Call LEC_TCU(ACTX, SKEY1)
    When "TVT"
      Call LEC_TVT(ACTX, SKEY1, SKEY2)
    When "SFI"
      Call LEC_SFI(ACTX, SKEY1)
    When "TDA"
      Call LEC_TDA(ACTX, SKEY1, SKEY2)
    When "BAN"
      Call LEC_BAN(ACTX, SKEY1)
    When "GAC"
      Call LEC_GAC(ACTX, SKEY1, SKEY2)
    When "FAS"
      Call LEC_FAS(ACTX, SKEY1)
    When "PFI"
      Call LEC_PFI(ACTX, SKEY1)
    When "BPR"
      Call LEC_BPR(ACTX, SKEY1)
    When "MWC"
      Call LEC_MWC(ACTX, SKEY1, SKEY2)
    When "ONA"
      Call LEC_ONA(ACTX, SKEY1)
    When "FCS"
      Call LEC_FCS(ACTX, SKEY1)
    When "OPPPJM"
      Call LEC_OPPPJM(ACTX, SKEY1)
    When "PJCC"
      Call LEC_PJCC(ACTX, SKEY1)
    When Default
      fstat = 5
  Endcase
End

###############################################################################
Subprog LEC_GCM(ACTX, MODELE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char MODELE

  fstat = [V]CST_AOK
  If [F:GCM]GCM <> MODELE Then
    Read [GCM]GCM0 = MODELE
  Endif
End

