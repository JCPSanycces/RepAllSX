#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------- EVENTS
$AINIT
  this.INVMONTHEND = 1 #--"Non"
Return
#---------------------------------------------------------------
$AREAD_AFTER
  Gosub GET_INVDAYMON_FROM_FILE
Return
#-----------------------
$ACONTROL
  #--This class it is supposed to be used as collection of TABINVCNDLINH, due to the key structure
  #--To prevent using the subclass TABINVCNDLIN stand alone
  If this.HASRIGHTHEAD<>[V]CST_AYES
    [L]ASTATUS = fmet this.ASETERROR("",func AFNC.MES1(mess(460,192,1),"TABINVCND"),[V]CST_AERROR)
  Endif
  #--
  If    this.INVCNDTYP=2
    Gosub ACONTROL_INVCNDTYP_EQ_2
  Elsif this.INVCNDTYP=3
    Gosub ACONTROL_INVCNDTYP_EQ_3
  Else
    #--Others
  Endif
  #--Common controls
  #--..
Return
#-----------------------
$ACONTROL_INVCNDTYP_EQ_2

  #--Only for "Fixed percent" invoice scheduling type
  Gosub CONTROL_INVDAYMON1   From TABINVCNDLIN_PROPERTIES
  Gosub CONTROL_INVDAYMON2   From TABINVCNDLIN_PROPERTIES
  Gosub CONTROL_INVDAYMON3   From TABINVCNDLIN_PROPERTIES
  Gosub CONTROL_INVDAYMON4   From TABINVCNDLIN_PROPERTIES
  Gosub CONTROL_INVDAYMON5   From TABINVCNDLIN_PROPERTIES
  Gosub CONTROL_INVDAYMON6   From TABINVCNDLIN_PROPERTIES
  #--
  Gosub CONTROL_MINAMTNOTCUR From TABINVCNDLIN_PROPERTIES
  Gosub CONTROL_INVPERCENT   From TABINVCNDLIN_PROPERTIES

Return
#-----------------------
$ACONTROL_INVCNDTYP_EQ_3
  #--Controls when "Periodicity" invoice scheduling type
  #--NO ENTRY HERE !

  [L]ASTATUS = fmet this.ASETERROR("" ,func AFNC.MES1(mess(445,192,1),"'"+mess(3,2420,1)+"'"),[V]CST_AERROR)

Return
#-----------------------
$AINSERT_BEFORE
  #--Copying the header common properties to each line
  Gosub SET_INVDAYMON_TO_FILE
Return
#-----------------------
$AUPDATE_BEFORE
#  #--Copying the header common properties to each line
  Gosub SET_INVDAYMON_TO_FILE
Return
#-----------------------
$GET_INVDAYMON_FROM_FILE
  this.INVDAYMON1 = [F:INVCNDD]INVDAYMON(0)
  this.INVDAYMON2 = [F:INVCNDD]INVDAYMON(1)
  this.INVDAYMON3 = [F:INVCNDD]INVDAYMON(2)
  this.INVDAYMON4 = [F:INVCNDD]INVDAYMON(3)
  this.INVDAYMON5 = [F:INVCNDD]INVDAYMON(4)
  this.INVDAYMON6 = [F:INVCNDD]INVDAYMON(5)
Return
#-----------------------
$SET_INVDAYMON_TO_FILE
  [F:INVCNDD]INVDAYMON(0) = this.INVDAYMON1
  [F:INVCNDD]INVDAYMON(1) = this.INVDAYMON2
  [F:INVCNDD]INVDAYMON(2) = this.INVDAYMON3
  [F:INVCNDD]INVDAYMON(3) = this.INVDAYMON4
  [F:INVCNDD]INVDAYMON(4) = this.INVDAYMON5
  [F:INVCNDD]INVDAYMON(5) = this.INVDAYMON6
Return
#-----------------------
$ADELETE_CONTROL_BEFORE
  #--This class it is supposed to be used as collection of TABINVCNDLINH, due to the key structure
  #--To prevent using the subclass TABINVCNDLIN stand alone
  If this.HASRIGHTHEAD<>[V]CST_AYES
    [L]ASTATUS = fmet this.ASETERROR("",func AFNC.MES1(mess(460,192,1),"TABINVCND"),[V]CST_AERROR)
  Endif
  #--
Return
#-----------------------

