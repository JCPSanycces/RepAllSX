#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMTSKCAT
###################################################################################################
$ENAFLG
  Case [L]ARULE
    When "INIT"      : Gosub ENAFLG_INIT
  Endcase
Return

$ENAFLG_INIT
  this.ENAFLG = [V]CST_ANO
Return

###################################################################################################
$TASTYP
  Case [L]ARULE
    When "INIT"      : Gosub TASTYP_INIT
    When "CONTROL"   : Gosub TASTYP_CONTROL
    When "PROPAGATE" : Gosub TASTYP_PROPAGATE
  Endcase
Return

$TASTYP_INIT
  this.TASTYP = 2   # per PRD must default to 2=Labor
Return

$TASTYP_CONTROL
  # Issue X3-5064/118941 - 2016-10-07 by FGR : BEGIN
  If this.ASTALIN = [V]CST_AUPD Then
    If this.TASTYP <> this.snapshot.TASTYP Then
      If func PJMTSK_CSTD_PROGS.IS_TCACOD_USED(this.ACTX, this.TCACOD) = [V]CST_AYES Then
        [L]ASTATUS = fmet this.ASETERROR("TASTYP", mess(430,2260,1), [V]CST_AERROR)
      Endif
    Endif
  Endif
  # Issue X3-5064/118941 - 2016-10-07 by FGR : END
Return

$TASTYP_PROPAGATE
  If this.TASTYP = 1 or this.TASTYP = 4 Then
    this.TCAMOD = 4
  Elsif this.TASTYP = 2 or this.TASTYP = 3 Then
    this.TCAMOD = 1
  Endif
Return

###################################################################################################
$TCAMOD
  Case [L]ARULE
    When "INIT"      : Gosub TCAMOD_INIT
    When "CONTROL"   : Gosub TCAMOD_CONTROL
  Endcase
Return

$TCAMOD_INIT
  this.TCAMOD = 1
Return

$TCAMOD_CONTROL
  # Issue X3-5032/118942 - 2016-10-07 by FGR : BEGIN Option 3 not available
  If this.TCAMOD = 3 Then
    [L]ASTATUS = fmet this.ASETERROR("TCAMOD", mess(357,199,1), [V]CST_AERROR)
  Endif
  # Issue X3-5032/118942 - 2016-10-07 by FGR : END
Return

###################################################################################################
$PCCCOD
  Case [L]ARULE
    When "CONTROL"   : Gosub PCCCOD_CONTROL
  Endcase
Return

$PCCCOD_CONTROL
  If (this.ASTALIN = [V]CST_ANEW) or (this.ASTALIN = [V]CST_AUPD and this.PCCCOD <> this.snapshot.PCCCOD) Then
    If this.PCCCOD <> AVOID.ACHAR Then
      # check for new item
      If func PJMCOSTCTR_CSTD_PROGS.IS_PCCCOD_ENABLE(this.ACTX, this.PCCCOD) = [V]CST_ANO Then
        [L]ASTATUS = fmet this.ASETERROR("PCCCOD", this.PCCCOD - mess(273,2260,1), [V]CST_AERROR)
      Endif
    Endif
  Endif
Return

