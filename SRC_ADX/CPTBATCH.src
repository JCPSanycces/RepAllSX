#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char ACCTSKREC
Call CRT_KEY_ABA_ACC_TASK(ACCTSKREC) From SUBBTC
Infbox ACCTSKREC
End

Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"CPTBATCH","CPTBATCH","") From GSAISIE
End
#
# Issue X3-115384 - 2018-11-05 by CBO : Error when histo folder
# Issue X3-113885 - 2018-10-23 by CBO : manage n folders
# Issue X3-111845 - 2018-10-05 by CBO : manage n folders
# Issue X3-111553 - 2018-10-04 by CBO : new field [F:BTC]CODABT which replaces [F:BTC]COD for [F:ABA]CODABT
# Issue X3-59028 - 2018-01-09 by CBO : Changes of accounting task for mindo
# Issue X3-102376 - 2018-07-31 by MWA : Import large number of Supplier BP invoices failed on 2018 R4 cloud site
#*X3-84159   MWA  Experiencing invoice posting error involving automatic creation setup in dimension type
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
###################################################
## Démarrage en batch (Trt ACCBATCH)
###################################################
Subprog CPTBATCH
Gosub OUVRE
Gosub TR4
End

###################################################
## Surveillance tâche comptabilité CPTBATCH (start and stop)
###################################################

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub LIRE
 When "SETBOUT"  : Gosub SETBOUT
 When "BOUTON"   : Gosub EXEBOUT
 When "RAF"      : Gosub LIRE

 When "INIT"     : Gosub TRACE
Endcase

Return

$OUVRE

Local Integer NBTEX , TSK_STA_IS_STOPPED
Local Char    CHAINE(30) , REP(1) , TEX(20)(20)
Local Char    CATT(1) , CRUN(1) , CSTO(1) , CTRA(1)
Local Char    TACHE(10), ACCBATCH(10)
Local Char    ORDSYS (250) , FICBAT(250)
Local Char    TBFIL(250)(1..99) , TBLET(250)(1..99) , TBBAL(250)(1..99)
Local Integer NBFIL , NBFIT , NBBAL
Local Integer QURSTA : # Query Progress Status
Local Date WDATE
Local Char WTIME(20)
Gosub SET_FILTRE
ACCBATCH = "ACCBATCH1" : # Tache "unique"  ne doit pas être lancée directement

If clalev([F:BTC])=0 : Local File =GTABCPT+"BATCH"     [BTC] : Endif
If clalev([F:HAT])=0 : Local File =GTABCPT+"GACCTMP"   [HAT] : Endif
If clalev([F:MTB])=0 : Local File =GTABCPT+"MTCBATCH"  [MTB] : Endif
If clalev([F:ABP])=0 : Local File ABATPAR   [ABP] : Endif
If clalev([F:ABR])=0 : Local File ABATRQT   [ABR] : Endif
If clalev([F:ABL])=0 : Local File ABATRQTL  [ABL] : Endif
If clalev([F:ABL])=0 : Local File ABATRQTL  [ABL] : Endif
If clalev([F:ABT])=0 : Local File ABATTAC   [ABT] : Endif
#If clalev([F:ABA])=0 : Local File ABATABT   [ABA] : Endif # Issue X3-59028
Local File ABATABT   [ABA] # Issue X3-59028

Return

$SET_FILTRE

Local Char    FILTRE(50)

  Call PARAM("", "MULBATCH", FILTRE) From ADOVAL
  If val(FILTRE) = 2
    FILTRE = 'COD <> "ACCENTRY"'
  Else
    FILTRE = 'COD = "ACCENTRY"'
  Endif

Return

# Issue X3-59028

$LIRE

  Call TEMPON("L") From GESECRAN
  Filter [BTC] Where evalue(FILTRE)
  [M]NBLIG = 0
  NBFIL = 0
  NBFIT = 0
  NBBAL = 0

  For [BTC]
    [M]COD([M]NBLIG) = [F:BTC]COD
    [M]CODABT([M]NBLIG) = [F:BTC]CODABT # Issue X3-111553

    Filter [ABR] Where CODABT = [F:BTC]CODABT
    Read [ABR]NUMREQ Last
    Filter [ABR]
    If fstat = 0
      [M]RQT([M]NBLIG) = [F:ABR]NUMREQ
    Else
      [M]RQT([M]NBLIG) = 0
    Endif

    Gosub FILTER_BTC
    Gosub GET_INFOS_BTC

    Call QUERY_STA([F:BTC]CODABT, [L]QURSTA, [L]TSK_STA_IS_STOPPED, [M]RQT([M]NBLIG), [L]WDATE, [L]WTIME) # Issue X3-111553

    # Recurring task management
    Read [ABA]CODABT = [F:BTC]CODABT # Issue X3-111553
    If fstat or [F:ABA]ENAFLG  <> [V]CST_AYES
      [M]STA([M]NBLIG) = 1 # state of task : stopped
      [M]RQT([M]NBLIG) = 0
    Else
      [M]STA([M]NBLIG) = 2 # state of task : running
    Endif

    If [M]RQT([M]NBLIG) = 0
      [M]FLAG([M]NBLIG) = 1
    Else
      [M]FLAG([M]NBLIG) = [L]QURSTA
    Endif
    If [M]STA([M]NBLIG) = 1 or [L]WTIME = ""
      [M]NEXTEXE([M]NBLIG) = ""
    Else
      [M]NEXTEXE([M]NBLIG) = format$("D:" + GFMDAT4, [L]WDATE) - "-" - left$([L]WTIME, 2) + ":" + right$([L]WTIME, 3)
    Endif

    [M]NBLIG += 1
  Next BTC

  Call TEMPOFF From GESECRAN
  Affzo
  If evalue("dim("+clanam([M])+"NBRBAL)") > 0
    If dim(GUPDBAL) < 1 or GUPDBAL <> 2
      Chgfmt [M]NBRBAL With "-K:20B"
    Endif
  Endif
  Diszo

Return

$FILTER_BTC

  # Prepare a condition :
  # Different of every line which has a selection
  # it's for a line which has NO selection : so, no enreg of the other lines must be treated
  # remark : this line must be the last one

  If [F:BTC]CRI <> ""
    If [F:BTC]ACC = 2
      NBFIL += 1
      If NBFIL > 1
        TBFIL(NBFIL) = "& "
      Else
        TBFIL(NBFIL) = ""
      Endif
      TBFIL(NBFIL) -= "!("+[F:BTC]CRI+")"
    Endif

    If [F:BTC]MTC = 2
      NBFIT += 1
      If NBFIT > 1
        TBLET(NBFIT) = "& "
      Else
        TBLET(NBFIT) = ""
      Endif
      TBLET(NBFIT) -= "!("+[F:BTC]CRI+")"
    Endif

    If [F:BTC]BAL = 2
      NBBAL += 1
      If NBBAL > 1
        TBBAL(NBBAL) = "& "
      Else
        TBBAL(NBBAL) = ""
      Endif
      TBBAL(NBBAL) -= "!("+[F:BTC]CRI+")"
    Endif
  Endif

Return

$GET_INFOS_BTC

  If [F:BTC]ACC = 2
    If [F:BTC]CRI <> ""
      Filter [HAT] Where evalue([F:BTC]CRI) and FLG < 100
    Elsif NBFIL>0
      Filter [HAT] Where evalue(TBFIL(1..NBFIL)) and FLG < 100
    Endif
    [M]NBRPCE([M]NBLIG) = rowcount([HAT])
    Filter [HAT]
  Endif

  If [F:BTC]MTC = 2
    If [F:BTC]CRI <> ""
      Filter [MTB] Where evalue([F:BTC]CRI)
    Elsif NBFIT > 0
      Filter [MTB] Where evalue(TBLET(1..NBFIT))
    Endif
    [M]NBRMTC([M]NBLIG) = 0
    For [MTB]MTB0(1)
      [M]NBRMTC([M]NBLIG) += 1
    Next
    Filter [MTB]

  Endif

  If [F:BTC]BAL = 2
    If [F:BTC]CRI <> ""
      Filter [HAT] Where evalue([F:BTC]CRI) and FLG >= 100
    Elsif NBBAL>0
      Filter [HAT] Where evalue(TBBAL(1..NBBAL)) and FLG >= 100
    Endif
    [M]NBRBAL([M]NBLIG) = rowcount([HAT])
    Filter [HAT]
  Endif

Return

$SETBOUT

  If instr(1, CHBOU, "=") = 0
    CHBOU += "="
  Endif

Return

$EXEBOUT

  Case BOUT
    When "N"
      OK = [V]CST_AYES
      Call OUINON(mess(158,105,1), OK) From GESECRAN # Démarrer les tâches comptables
      If OK = [V]CST_AYES
        Gosub DEMARRER
      Endif
    When "O"
      OK = [V]CST_AYES
      Call OUINON(mess(157,105,1), OK) From GESECRAN # Arrêter les tâches comptables
      If OK = [V]CST_AYES
        Gosub STOPPE
      Endif
    When "A"
      Gosub LIRE
    When "T"
      Local Char WCOD(30)
      Call OBJET("BTC", WCOD, "") From GOBJET # call Accounting task setup
  Endcase

Return

$DEMARRER

  Call TEMPON("O") From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR4

#  Sleep 4
  Gosub LIRE
  Call TEMPOFF From GESECRAN
  If K = 0
    Call MESSAGE(mess(159,105,1)) From GESECRAN : # Toutes les tâches sont actives
  Endif

Return

$TR4

  If dim(FILTRE)  <= 0
    Gosub OUVRE
  Endif
  GOK = 1

  Trbegin [BTC]
  K = 0
  For [BTC] Where evalue(FILTRE)

    Local Decimal RQT
    Call QUERY_STA([F:BTC]CODABT, QURSTA, TSK_STA_IS_STOPPED, RQT, WDATE, WTIME) # Issue X3-111553

    If TSK_STA_IS_STOPPED = 0
      GOK = 0
    Else

      # update (and create if not exists) Recurring task management : Task in progress
      Read [ABA]CODABT = [F:BTC]CODABT # Issue X3-111553
      If fstat
        Call CRT_ACC_REC_TASK([F:BTC]CODABT, [F:BTC]COD, nomap, [V]CST_ANO) From SUBBTC # Issue X3-113885
        If GMESSAGE <> ""
          GOK = 0
          Break
        Endif
        Rewrite [BTC] # X3-115384

        Read [ABA]CODABT = [F:BTC]CODABT # Issue X3-111553
        If fstat
          GMESSAGE = "[ABA] not created =" - [F:BTC]COD
          GOK = 0
          Break
        Endif
      Endif

      # need to be updated before RELANCE
      [F:ABA]ENAFLG = [V]CST_AYES
      [F:ABA]DREL = [V]CST_AYES
      Rewrite [ABA]
      K += 1  # counter of started tasks

    Endif
  Next

  Filter [BTC]
  If GOK
    Commit
  Else
    Rollback
  Endif

Return

$STOPPE

  Call TEMPON("O") From GESECRAN
  Openo filpath("TRA", TACHE, "tra", 0), -1
  Wrseq GUSER - ":" - mess(32,114,1)
  Openo

  Trbegin [BTC]
  Gosub STOP_ACCTSK

  Delete [F:ABR]  Where TACHE = "ACCBATCH1" and FLAG = 1
  Update [F:ABR]  Where TACHE = "ACCBATCH1" and FLAG = 2
&                 With  FRQFIN = ""
  Commit
#  Sleep 4
  Call TEMPOFF From GESECRAN
  Gosub LIRE

Return

$STOP_ACCTSK
# used also by AX3MONO trt from Supervisor

  For [BTC] # On arrête tout pour le cas où on a changé le paramètre MULBATCH

    # Recurring task management
    Read [ABA]CODABT = [F:BTC]CODABT  # Issue X3-111553
    If fstat = 0
      If [F:ABA]ENAFLG = [V]CST_AYES
        If dim(FLBAT) < 0
          Local Integer FLBAT
        Endif
        FLBAT = 1
      Endif

      [F:ABA]ENAFLG = [V]CST_ANO
      Rewrite [ABA]

    Endif
  Next

Return

$TRACE

  GTRACE = [M]COD(nolign-1)
  TRA    = 1

Return

#**
#* Indicate if accounting task is stopped
#*
#* @param RTSK_STA_IS_STOPPED boolean value
#*!
Subprog PRESENCE(RTSK_STA_IS_STOPPED)
Variable Integer RTSK_STA_IS_STOPPED

Local Integer I
Local Integer QRYSTA : # Query Progress Status
Local Decimal RQT
Local Date WDATE
Local Char WTIME(20)

  If clalev([F:BTC2])=0 : Local File =GTABCPT+"BATCH" [BTC2] : Endif

  RTSK_STA_IS_STOPPED = 0
  Gosub SET_FILTRE
  For [BTC2] Where evalue(FILTRE)

    Call QUERY_STA([F:BTC2]CODABT, QRYSTA, RTSK_STA_IS_STOPPED, RQT, WDATE, WTIME)  # Issue X3-111553
    If RTSK_STA_IS_STOPPED
      Break
    Endif
  Next

End



#**
#* Query Status
#*
#* @param PQRY_COD            Query code
#* @param QURSTA              Query Progress Status
#* @param RTSK_STA_IS_STOPPED Boolean Status of task (0:OK=Request in Progress  1:NOK)
#* @param RNUM_RQT            Request Id
#* @param RDATE               Next date exe
#* @param RTIME               Next time exe
#*!
Subprog QUERY_STA(PQRY_COD, RQRY_STA, RTSK_STA_IS_STOPPED, RNUM_RQT, RDATE, RTIME)
Value    Char    PQRY_COD()
Variable Integer RQRY_STA
Variable Integer RTSK_STA_IS_STOPPED
Variable Decimal RNUM_RQT
Variable Date RDATE
Variable Char RTIME()

  If clalev([F:ABR])=0 : Local File ABATRQT   [ABR] : Endif
#  If clalev([F:ABA22])>0
#  Close File [ABA22]
#  Endif
#  If clalev([F:ABA])=0 : Local File ABATABT   [ABA] : Endif
Local File ABATABT   [ABA]

  RQRY_STA = 0
  RTSK_STA_IS_STOPPED = 1
  RNUM_RQT = 0
  RDATE = [0/0/0]
  RTIME = ""

  Read [ABA]CODABT = PQRY_COD
  If fstat = 0
    If [F:ABA]ENAFLG = [V]CST_AYES
      RTSK_STA_IS_STOPPED = 0
    Endif
  Endif

  Filter [ABR] Where CODABT = PQRY_COD
  Read [ABR] Last
  If fstat = 0
    RQRY_STA = [F:ABR]FLAG
    If [F:ABR]FLAG < 3 : # In Pending, In Progress
      RDATE = [F:ABR]DAT
      RTIME = [F:ABR]HEURE
      RNUM_RQT  = [F:ABR]NUMREQ
    Endif
  Endif
  Filter [ABR]

End
# End issue X3-59028
# End of starting batch task --------------------------------------------------------------------------------------------
# Sart of validatong entry journal --------------------------------------------------------------------------------------------



###################################################
## Subprog CONTROLE(STAT,MESSA)
## Subprog VALPIECE(STAT,MESSA)
## Subprog DELPCE(TYPPCE,PIECE)
###################################################
Subprog CONTROLE(STAT,MESSA)
Variable Integer STAT
Variable Char    MESSA

Local Integer NOL, AXE, PT, NOLDEB
Local Char    DIE(GLONDIE)
Local Char    SECTION(GLONCCE), CENTRAL(GLONGAC), CRECCE(2), CHAINE(10), CODLED(GLONLED), DEVLED(GLONCUR)
Local Char    REF(30)
Local Char    COLLEC(GLONSAC), COMPTE(GLONGAC)
Local Char    TCOMPTE(GLONGAC)(1..len(mess(0,2644,1)))
Local Char    PLGEN(GLONCOA), PLANA(GLONCOA)
Local Char    CPTGEN(GLONGAC), CPTANA(GLONGAC)
Local Char    SPROG(15)
Local Decimal MTTH, MTRR, ECART, AROQTE
Local Integer IEC, USRPAZ
Local Integer CHGDEV
Local Integer LEDTYP, SUIVI, VU
Local Integer IND, AXI
Local Decimal COURS
Local Integer FLGPER  # Flag des pièces d'à-nouveau (permet d'inhiber les contrôles analytiques)
Local Char    PCEMTE(GLONGAU)  # Code de la pièce d'écart de change extournée  (standard : MTE)
Local Integer FLGPRCSL
Local Char    MAINBPR(GLONBPR)
Local Tinyint INIMAINBPR
Local Tinyint LEDFLGCSL
Local Tinyint FLGCSL
Local Integer ASTATUS
Local Integer INILEDCSL
Local Integer FLGCSL1

If clalev([F:CPY])=0  : Local File COMPANY                 [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY                [FCY]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR                  [TCU]  : Endif
If clalev([F:AUS])=0  : Local File AUTILIS                 [AUS]  : Endif
If clalev([F:TUN])=0  : Local File TABUNIT                 [TUN]  : Endif
If clalev([F:COA])=0  : Local File =GTABCPT+"GCOA"         [COA]  : Endif
If clalev([F:LED])=0  : Local File =GTABCPT+"GLED"         [LED]  : Endif
If clalev([F:DIE])=0  : Local File =GTABCPT+"GDIE"         [DIE]  : Endif
If clalev([F:CCE])=0  : Local File =GTABCPT+"CACCE"        [CCE]  : Endif
If clalev([F:DSP])=0  : Local File =GTABCPT+"CADSP"        [DSP]  : Endif
If clalev([F:AUZ])=0  : Local File =GTABCPT+"CAAUZ"        [AUZ]  : Endif
If clalev([F:TCK])=0  : Local File =GTABCPT+"TABACCLIK"    [TCK]  : Endif
If clalev([F:TCH])=0  : Local File =GTABCPT+"TABCHANGE"    [TCH]  : Endif
If clalev([F:GAC])=0  : Local File =GTABCPT+"GACCOUNT"     [GAC]  : Endif
If clalev([F:GAC1])=0 : Local File =GTABCPT+"GACCOUNT"     [GAC1] : Endif
If clalev([F:CLS])=0  : Local File =GTABCPT+"GACCCLS"      [CLS]  : Endif
If clalev([F:GAC2])=0 : Local File =GTABCPT+"GACCOUNT"     [GAC2] : Endif
If clalev([F:CCE2])=0 : Local File =GTABCPT+"CACCE"        [CCE2] : Endif
If clalev([F:HAE2])=0 : Local File =GTABCPT+"GACCTMP"      [HAE2] : Endif

If GCOMPTA<>3
 If clalev([F:GTE])=0  : Local File =GTABCPT+"GTYPACCENT"   [GTE]  : Endif
 If clalev([F:FIY])=0  : Local File =GTABCPT+"FISCALYEAR"   [FIY]  : Endif
 If clalev([F:PER])=0  : Local File =GTABCPT+"PERIOD"       [PER]  : Endif
 If clalev([F:BPR])=0  : Local File =GTABCPT+"BPARTNER"     [BPR]  : Endif
 If clalev([F:JOU])=0  : Local File =GTABCPT+"GJOURNAL"     [JOU]  : Endif
 If clalev([F:JCO])=0  : Local File =GTABCPT+"GJOUCOA"      [JCO]  : Endif
 If clalev([F:JST])=0  : Local File =GTABCPT+"GAJOUSTA"     [JST]  : Endif
 If clalev([F:GDE])=0  : Local File =GTABCPT+"GDIAENTRY"    [GDE]  : Endif
 If clalev([F:GDD])=0  : Local File =GTABCPT+"GDIAENTRYD"   [GDD]  : Endif
 If clalev([F:HAE1])=0 : Local File =GTABCPT+"GACCENTRY"    [HAE1] : Endif
Endif

Raz STAT, MESSA

## Ouverture masque GACCENTFMT [HAEF]. Dans ce masque sont stockées diverses informations exploitées
## dans les étiquettes de contrôles des champs de saisies pièces (SUBGA0, SUBGA1)
If clalev([M:HAEF]) = 0 : Local Mask GACCENTFMT  [HAEF]  : Endif
If clalev([M:HAEW]) = 0 : Local Mask GACCENTW    [HAEW]  : Endif

Default Mask [HAE0]
Default Mask [HAE1]
Default Mask [HAE2]

If GCOMPTA<>3  :# Compta
 Call LEC_GDE([M]DACDIA) From CPTLEC
 # Schéma inexistant
 If fstat : MESSA = "GDE"-[M]DACDIA : GMESSAGE=mess(34,106,1) : STAT = 99 : Goto FIN_CONT : Endif
 # Schéma de compte incorrect
 If [F:GDE]TYPENT=3 : MESSA = "GDE"-[M]DACDIA : GMESSAGE=mess(130,104,1) : STAT = 99 : Goto FIN_CONT : Endif
Endif

Call LEC_CPY([M]CPY) From CPTLEC
Call LEC_TCU([M]CUR) From CPTLEC

CHGDEV = 0
If [M]ORIMOD=3 & [F:TCU]CURENDDAT<>[0/0/0] & [M]ACCDAT>=[F:TCU]CURENDDAT
 CHGDEV    = 1
Endif

Gosub CONTZONE
If STAT : Goto FIN_CONT : Endif

#JASMI - 2017-04-24 - Req. 122336 - START
#Gosub CONTZONE_KRU From SUBGASD
If func TRTHRCPT.IS_X3PEOPLE_EXT_ACC() #if X3 People and External Accounting
  Gosub CONTZONE_KRU From SUBHRGASD
Else
  Gosub CONTZONE_KRU From SUBGASD
Endif
#JASMI - 2017-04-24 - Req. 122336 - END

If STAT : Goto FIN_CONT : Endif

#JASMI - 2017-04-24 - Req. 122336 - START
#Gosub MAJMSK2 From SUBGASB : # Pour remplir le masque GACCENTW
If func TRTHRCPT.IS_X3PEOPLE_EXT_ACC() #if X3 People and External Accounting
 Gosub MAJMSK2 From SUBHRGASB : # Pour remplir le masque GACCENTW
Else
 Gosub MAJMSK2 From SUBGASB : # Pour remplir le masque GACCENTW
Endif
#JASMI - 2017-04-24 - Req. 122336 - END

If STAT : Goto FIN_CONT : Endif

#JASMI - 2017-04-24 - Req. 122336 - START
#Gosub CONTVAL From SUBGA1
If func TRTHRCPT.IS_X3PEOPLE_EXT_ACC() #if X3 People and External Accounting
 Gosub CONTVAL From SUBHRGA1
Else
 Gosub CONTVAL From SUBGA1
Endif
#JASMI - 2017-04-24 - Req. 122336 - END

If STAT : Goto FIN_CONT : Endif

$FIN_CONT
If STAT
 Call TRACE_PIECE(0)
Endif

End


$CONTZONE

# Site
Call LEC_FCY([M]FCY) From CPTLEC
If [F:FCY]FINFLG<>2
 [M]FCY = [F:FCY]FINRSPFCY : # Site financier
Endif
Call CONTROLE("FCY","C",[M]FCY,"",mkstat) From CONTOBJ
If mkstat : MESSA = "FCY"-[M]FCY : STAT = 99 : Return : Endif
Call CONTFCY([M]FCY) From CPTSUB : # Vérif droits
If mkstat : MESSA = "FCY"-[M]FCY : STAT = 99 : Return : Endif
Call GETSOC([M]FCY) From DEVSUB

Local Char PARAM(10)
#--- Paramètre de création de lignes à zéro
If dim(GSIVNULL)>0
 Call PARAML([M]FCY,"SIVNULL",PARAM) From ADOVAL
 GSIVNULL=val(PARAM)
Endif

#--- Est-ce la pièce MTC extournée ?
PCEMTE=""
If left$([M]REFINT,3)="MTC"
 Call PARAM([M]FCY,"GAUMTE",PCEMTE) From ADOVAL
 If PCEMTE="" : PCEMTE = "MTE" : Endif
 If [M]AUTACE=PCEMTE : [M:HAEF]TYPENT=2 : Endif
Endif

# Société
If [M]CPY="" : [M]CPY = [F:FCY]LEGCPY : Endif
Call CONTROLE("CPY","",[M]CPY,"",mkstat) From CONTOBJ
If mkstat : MESSA = "CPY"-[M]CPY : STAT = 99 : Return : Endif
Call LEC_GCM([F:CPY]ACM) From CPTLEC

# Type de pièce
Raz FLGPER
If dim([F:GTE]TYP)>0
 Call CONTGTE([M]TYP,[F:CPY]LEG,"") From SUBGTE
 If mkstat : MESSA = "GTE"-[M]TYP : STAT = 99 : Return : Endif
 Call CONTEXE([F:GTE]ACS) From CPTSUB
 If mkstat : MESSA = "GTE"-[M]TYP : STAT = 99 : Return : Endif
 If [F:GTE]PER=2 : FLGPER=1 : Endif
Endif

# Date comptable
If [M]ACCDAT=[0/0/0] : [M]ACCDAT = datesyst : Endif
If GCOMPTA<>3
 Local Date VALEUR
 VALEUR = [M]ACCDAT : Gosub SETEXE From SUBGA0
 Call C_ACCDAT([M]ACCDAT) From SUBGA0
 If mkstat
  MESSA = "ACCDAT"-format$("D:"+GFMDAT,[M]ACCDAT)
  STAT = 99 : Return
 Endif
Endif
If [M:HAE1]ENTDAT < [M]ACCDAT
 [M:HAE1]ENTDAT = [M]ACCDAT
Endif

# Numéro de pièce
If [M]NUM<>""
 If GCOMPTA<>3  :# Compta
  Look [HAE1]HAE0 = [M]TYP;[M]NUM
  If !fstat : MESSA = [M]TYP-[M]NUM : STAT = 21 : Return : Endif
 Endif
 Look [HAE2]HAT0 = [M]TYP;[M]NUM
 If !fstat : MESSA = [M]TYP-[M]NUM : STAT = 22 : Return : Endif
Endif

# Journal
If GCOMPTA<>3  :# Compta
 If [M]JOU="" : [M]JOU = [F:GTE]DEFJOU : Endif
 If [M]JOU="" :  MESSA = "JOU"-mess(7,175,1) : STAT = 97 : Gosub ERR_HAE : Return : Endif
 Call CONTJOU([M]JOU,[F:CPY]LEG,"") From SUBJOU
 If mkstat : MESSA = "JOU"-[M]JOU : STAT = 99 : Return : Endif
 Call C_JOU([M]JOU) From SUBGA0
 If mkstat : MESSA = "JOU"-[M]JOU : STAT = 99 : Return : Endif
Endif

# Catégorie, état
If dim([F:GTE]TYP)>0
 Local Decimal VALEUR
 mkstat= 0 : Gosub CONTTET From SUBGA1
 If mkstat : MESSA = "" : STAT = 99 : Return : Endif
Endif

# Dates
If [M]ENTDAT=[0/0/0]
 [M]ENTDAT = [M]ACCDAT
Endif
If [M]DUDDAT=[0/0/0]
 [M]DUDDAT = [M]ACCDAT
Endif
If [M]VALDAT=[0/0/0]
 [M]VALDAT = [M]DUDDAT
Endif
If [M]RATDAT=[0/0/0]
 [M]RATDAT = [M]ACCDAT
Endif

# Devise
If [M]CUR=""
 Call LECLED([M]CPY,GTYPGEN,CODLED,[M]CUR) From CPTDIV
Endif
Call CONTROLE("TCU","",[M]CUR,"",mkstat) From CONTOBJ
If mkstat : MESSA = "TCU"-[M]CUR : STAT = 99 : Return : Endif
If !CHGDEV
 Call CONTDEV([M]CUR,[M]ACCDAT) From TRTDEV
 If mkstat : MESSA = GMESSAGE : STAT = 97 : Return : Endif
Endif

# Position des 3 devises par rapport à l'Euro
Call SETFLGDEV([M]CUR,[M]CPY,[M]RATDAT) From CPTDIV
If dim([F:GTE]TYPRAT)>0 & [M]TYPRAT=0 : [M]TYPRAT = [F:GTE]TYPRAT : Endif

#103096
## Initialisation masque de référence [HAEF] (les contrôles sur champs exploitent ce masque de référence)
If GFONCTION ="CPTEXT"
 Call INIMSKFMT([M]FCY,[M]DACDIA,[M]TYP,[M]ACCDAT,STAT) From SUBGASA
 # To avoid the message "Pas de cours de devise"
 For I=0 To len(mess(0,2644,1))-1
  [M:HAEF]RATDIVC(I) = [M:HAE1]RATDIV(I)
  [M:HAEF]RATMLTC(I) = [M:HAE1]RATMLT(I)
 Next
Else

#JASMI - 2017-04-24 - Req. 122336 - START
# Call INIMSKFMT3([M]FCY,[M:HAEF]TYPENT,[M]DACDIA,[M]TYP,[M]ACCDAT,STAT) From SUBGASA
 If func TRTHRCPT.IS_X3PEOPLE_EXT_ACC() #if X3 People and External Accounting
  Call INIMSKFMT3([M]FCY,[M:HAEF]TYPENT,[M]DACDIA,[M]TYP,[M]ACCDAT,STAT) From SUBHRGASA
 Else
  Call INIMSKFMT3([M]FCY,[M:HAEF]TYPENT,[M]DACDIA,[M]TYP,[M]ACCDAT,STAT) From SUBGASA
 Endif
#JASMI - 2017-04-24 - Req. 122336 - END

Endif

# Initialisation des RATDIV, RATMLT
For J=1 To len(mess(0,2644,1))
 [M]LED(J-1)    = [M:HAEF]LEDC(J-1)
 [M]CURLED(J-1) = [M:HAEF]CURC(J-1)
 Gosub INIT_COURS_LED From TRTPCE
 If STAT : Break : Endif
 [M:HAEF]RATDIVC(J-1) = [M:HAE1]RATDIV(J-1)
 [M:HAEF]RATMLTC(J-1) = [M:HAE1]RATMLT(J-1)
Next
If STAT
 MESSA=mess(16,114,1)-[M]CUR-"->"-[M]CURLED(J-1)-"("+format$("D:"+GFMDAT,[M]RATDAT)+")" : STAT=99 : Return
Endif

# Zones diverses
If [M]RVS<1 | [M]RVS>2
 [M]RVS = 1    : # Extourne = non
Endif
If dim([M]FLGDAS)>0
 If [M]FLGDAS<1 | [M]FLGDAS>2
  [M]FLGDAS = 1 : # Das2 = non
 Endif
Endif
If dim([F:GTE]FUP)>0 & ([M]FLGFUP<1 | [M]FLGFUP>2)
 If [F:GTE]FUP=2
  [M]FLGFUP = 2 : # Relance = d'après le type de pièce
 Else
  [M]FLGFUP = 1
 Endif
Endif

[L]USRPAZ = len(mess(0,510,1))   : # Par défaut, niveau max
Call PARAML([M]FCY,"FLGPAZ",CHAINE) From ADOVAL
If val(CHAINE)=2
 Local Char LLEVPAZ(3)
 Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
 [L]USRPAZ = val(LLEVPAZ)    : # Niveau du user si géré
Endif

If [M]FLGPAZ<1 | [M]FLGPAZ>len(mess(0,510,1))
 [M]FLGPAZ = [L]USRPAZ    : # Bon à payer
Endif

If [M]ORIMOD<1 or [M]ORIMOD>len(mess(0,14,1))
 [M]ORIMOD = 2 : # Compta
Endif

If !GIMPORT & [M]FLGGEN<>3
 # Pas de propagation automatique.
 #  La propagation est déjà effectuée :
 #    - via le paramétrage des pièces automatiques
 #    - via les traitements amonts comme le Solde d'abonnement. (FLGGEN=3)
 [M]FLGGEN = 2
Else
 # Propagation automatique des référentiels via les règles de saisie de pièces comptables.
 [M]FLGGEN = 1
Endif

NOLDEB=0

$CONTLIG
OKERR = 0
If dim(GSIVNULL)>0 & GSIVNULL=2
 #Issue 74113 – 2018-01-31 by MADOR - Adjustments driven from the FIFRC automatic journal
 If (sum([M]CDT)=0 & sum([M]DEB)=0 & left$([M]REFINT,3)<>"MTC" &
&    [M]REFINT<>"CNVEC" & left$([M]REFINT,4)<>"FIFO" & [M]FLGREP<>2)
 #Issue end
  ERRNULL=1
  For I=1 To len(mess(0,2644,1))
   If sigma(0,[M]NBLIG-1,evalue("abs([M]AMT"+num$(I)+"("+num$(indcum)+"))"))=0
    ERRNULL = 1
   Else
    ERRNULL = 0 : Break
   Endif
  Next
  If ERRNULL
   # Lignes nulles interdites
   MESSA = [M]FCY : GMESSAGE=mess(91,106,1)
   STAT=99 : Return
  Endif
 Endif
Endif

Raz MAINBPR, INIMAINBPR
FLGPRCSL = func AFNC.ACTIV("PRCSL")
FLGCSL1 = func AFNC.ACTIV("CSL1")

For NOL=NOLDEB To [M]NBLIG-1

 Default Mask [HAE0]
 Default Mask [HAE1]
 Default Mask [HAE2]

 nolign = NOL+1

 # Site
 If [M]FCYLIN(NOL)="" : [M]FCYLIN(NOL) = [M]FCY : Endif
 If [M]FCYLIN(NOL)<>[M]FCY
  Call LEC_FCY([M]FCYLIN(NOL)) From CPTLEC
  If [F:FCY]FINFLG<>2
   [M]FCYLIN(NOL) = [F:FCY]FINRSPFCY : # Site financier
  Endif
  Call CONTROLE("FCY","C",[M]FCYLIN(NOL),"",mkstat) From CONTOBJ
  If mkstat : MESSA = "FCYLIN"-[M]FCYLIN(NOL) : STAT = 99 : Break : Endif
  Call C_FCYLIN([M]FCYLIN(NOL)) From SUBGA0
  If mkstat : MESSA = "FCYLIN"-[M]FCYLIN(NOL) : STAT = 99 : Break : Endif
 Endif

 Raz COLLEC, COMPTE, TCOMPTE, PLGEN, PLANA, CPTGEN, CPTANA

#JASMI - 2017-04-24 - Req. 122336 - START
# Call INISTR From SUBGASA
 If func TRTHRCPT.IS_X3PEOPLE_EXT_ACC() #if X3 People and External Accounting
  Call INISTR From SUBHRGASA
 Else
  Call INISTR From SUBGASA
 Endif
#JASMI - 2017-04-24 - Req. 122336 - END

 INILEDCSL = 0

 Local Integer II
 For I=1 To [M:HAEF]NBRLED
  REF    = mess([M:HAEF]LEDTYP(I-1),2644,1)
  ## Ticket number 117771 : when we reverse a variance journal through the automatic journal MTE, we have an only one ledger
  ## by line. It means that only the field [M]ACC1 is loaded, with accounts which can concern different ledgers.
  ## In that case, the loop done on the ledger types and the initialiaztion of the local variable TCOMPRE from the ledger I
  ## was incorrect
  If [M]AUTACE = "" | [M]AUTACE<>PCEMTE | ([M]AUTACE=PCEMTE & [M]LEDTYP(NOL)=[M:HAEF]LEDTYP(I-1))
   If [M]AUTACE<>PCEMTE | PCEMTE = "" : II = I : Else : II = 1 : Endif
   COLLEC = evalue("[M]SAC"+num$(II)+"("+num$(NOL)+")")
   COMPTE = evalue("[M]ACC"+num$(II)+"("+num$(NOL)+")")
   TCOMPTE(II) = evalue("[M]ACC"+num$(II)+"("+num$(NOL)+")")
   # Collectif
   If COLLEC<>""
    SPROG = "C_SAC"+num$(II)

#JASMI - 2017-04-24 - Req. 122336 - START
#    Call =SPROG With COLLEC From SUBGA0
    If func TRTHRCPT.IS_X3PEOPLE_EXT_ACC() #if X3 People and External Accounting
     Call =SPROG With COLLEC From SUBHRGA0
    Else
     Call =SPROG With COLLEC From SUBGA0
    Endif
#JASMI - 2017-04-24 - Req. 122336 - END

    If mkstat : MESSA = "SAC"-REF-COLLEC : STAT = 99 : Break 2 : Endif
   Endif
   # Compte
   If COMPTE<>""
    SPROG ="C_ACC"+num$(II)

#JASMI - 2017-04-24 - Req. 122336 - START
#    Call =SPROG With COMPTE From SUBGA0
    If func TRTHRCPT.IS_X3PEOPLE_EXT_ACC() #if X3 People and External Accounting
     Call =SPROG With COMPTE From SUBHRGA0
    Else
     Call =SPROG With COMPTE From SUBGA0
    Endif
#JASMI - 2017-04-24 - Req. 122336 - END

    If mkstat : MESSA = "ACC"-REF-COMPTE : STAT = 99 : Break 2 : Endif
    If COLLEC="" & evalue("[M]SAC"+num$(II)+"("+num$(NOL)+")")<>"" : COLLEC=evalue("[M]SAC"+num$(II)+"("+num$(NOL)+")") : Endif
   Endif
   # Tiers

#JASMI - 2017-04-24 - Req. 122336 - START
#   If COLLEC<>"" | GIMPORT
#    If [M]BPR(NOL)<>""
#     Call LEC_BPR([M]BPR(NOL)) From CPTLEC
#     If fstat :  MESSA = "BPR"-[M]BPR(NOL) : STAT = 44 : Break 2 : Endif
#     Call C_BPR([M]BPR(NOL)) From SUBGA0
#     If mkstat : MESSA = "BPR"-[M]BPR(NOL) : STAT = 99 : Break 2 : Endif
#    Elsif COLLEC<>""
#     MESSA = "ACC"-REF-COMPTE : STAT = 44 : Break 2
#    Endif
#   Endif
  If !func TRTHRCPT.IS_X3PEOPLE_EXT_ACC() #if Not X3 People and Not External Accounting
   If COLLEC<>"" | GIMPORT
    If [M]BPR(NOL)<>""
     Call LEC_BPR([M]BPR(NOL)) From CPTLEC
     If fstat :  MESSA = "BPR"-[M]BPR(NOL) : STAT = 44 : Break 2 : Endif
     Call C_BPR([M]BPR(NOL)) From SUBGA0
     If mkstat : MESSA = "BPR"-[M]BPR(NOL) : STAT = 99 : Break 2 : Endif
    Elsif COLLEC<>""
     MESSA = "ACC"-REF-COMPTE : STAT = 44 : Break 2
    Endif
   Endif
  Endif
#JASMI - 2017-04-24 - Req. 122336 - END

   # Search the partner code of the account of first consolidated ledger in the mask
   If FLGPRCSL & COLLEC<>"" & TCOMPTE(II)<>"" & INIMAINBPR=0 & INILEDCSL=0
    ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX, [M:HAEF]LED(I-1), LEDFLGCSL, MESSA)
    If ASTATUS<>[V]CST_AERROR & LEDFLGCSL=2
     INILEDCSL = 1
     Call LEC_GAC(TCOMPTE(II),[M:HAEF]COA(I-1)) From CPTLEC
     # Partner management<> not entered
     If [F:GAC]CSLFLGBPR<>1
      If [M]CSLBPR(NOL)<>""
       MAINBPR =[M]CSLBPR(NOL)
      Elsif [M]BPR(NOL)<>""
       Call LEC_BPR([M]BPR(NOL)) From CPTLEC
       MAINBPR = [F:BPR]CSLBPR
      Endif
      If MAINBPR=""
       Call PARAML([M]CPY,"CSLBPRDEF",MAINBPR) From ADOVAL
      Endif
      INIMAINBPR = 1
      [M:HAEF]INICSLBPR = [V]CST_AYES
      [M:HAEF]MAINCSLBPR = MAINBPR
     Endif
    Endif
   Endif
   If PCEMTE<>"" & [M]AUTACE=PCEMTE & [M]LEDTYP(NOL)=[M:HAEF]LEDTYP(I-1) : Break : Endif
  Endif
 Next

 # Ajout de la condition car à ce stade, si X3 est en génération de pièce automatique,
 #     le contrôle s'effectue en mode "Colonne" (quelque le mode de la transaction de saisie)
 # Par contre, indépendamment de la génération de pièce, le CONTROLE de CPTBATCH est appelé dans divers traitements comptable.
 #     le contrôle s'effectue donc par rapport au type de la transaction de saisie.

 If ([M]AUTACE<>"" & [M]AUTACE<>PCEMTE) | [M:HAEF]TYPENT=1
  Call RECH_ACC(1,[M]CPY,[M:HAEF]LEDTYP,[M:HAEF]NBRLED,[M:HAEF]COA,TCOMPTE,PLGEN,CPTGEN) From CPTDIV
  Call RECH_ACC(2,[M]CPY,[M:HAEF]LEDTYP,[M:HAEF]NBRLED,[M:HAEF]COA,TCOMPTE,PLANA,CPTANA) From CPTDIV
 Else
  Call LEC_COA([M]COA1(NOL)) From CPTLEC
  If !fstat & [F:COA]ANATRK=2
   PLANA  = [M]COA1(NOL)
   CPTANA = [M]ACC1(NOL)
  Endif
 Endif


 # Taxe
 If ([M]AUTACE<>"" & [M]AUTACE<>PCEMTE) | [M:HAEF]TYPENT=1 | GIMPORT #DdM53331
  If [M]TAX(NOL)=""
   ## Contrôle que le code taxe ne soit pas obligatoire sur un des référentiels
   For I=1 To [M:HAEF]NBRLED
    If [M:HAEF]COA(I-1)<>""
     Call LEC_COA([M:HAEF]COA(I-1)) From CPTLEC
     # Est-il Gestion des taxes ?
     If !fstat & [F:COA]TAXMGT = 2
      Call LEC_GAC(TCOMPTE(I),[M:HAEF]COA(I-1)) From CPTLEC
#JASMI - 2017-04-24 - Req. 122336 - START
#      If [F:GAC]FLGVAT<>1
      If [F:GAC]FLGVAT<>1 & (!func TRTHRCPT.IS_X3PEOPLE_EXT_ACC()) #if Not X3 People and Not External Accounting
#JASMI - 2017-04-24 - Req. 122336 - END
       # Paramètre EXETAX (Tronc commun)
       If dim(GEXETAX)>0 : [M]TAX(NOL) = GEXETAX : Endif
       # Code taxe renseigné au niveau du compte général
       If [F:GAC]VAT(0)<>"" : [M]TAX(NOL) = [F:GAC]VAT(0) : Endif
       If [M]TAX(NOL)=""
        # Code taxe obligatoire
        MESSA = "ACC"-TCOMPTE(I)-"("+[M:HAEF]COA(I-1)+")"-":"-mess(126,104,1) : STAT = 97 : Break 2
       Else
        Break : # on break parce que le code taxe vient d'être initialisé
       Endif
      Endif
     Endif
    Endif
   Next
  Endif
 Endif
 If find("TVT",GABRCPT(1..GNBTABCPT)) & [M]TAX(NOL)<>""
  #--CPO 71937 TVT Report
  #Call CONTROLE("TVT","",[M]TAX(NOL),"",mkstat) From CONTOBJ
  Call CONTTVT([M]TAX(NOL),GCURLEG,"","","","","") From SUBTVT #Gbn-71937
  If mkstat : MESSA = "TAX"-[M]TAX(NOL) : STAT = 99 : Break : Endif
 Endif

 # Arrondi des montants
 Call LEC_TCU([M]CUR) From CPTLEC
 [M]DEB(NOL) = arr([M]DEB(NOL),[F:TCU]CURRND)
 [M]CDT(NOL) = arr([M]CDT(NOL),[F:TCU]CURRND)

 # Consolidation : Gestion du Flux
 If ([M]AUTACE<>"" & [M]AUTACE<>PCEMTE) | [M:HAEF]TYPENT=1

  # Flow management for consolidation
  If FLGPRCSL & dim([M]CSLFLO(NOL))>0 & [M]CSLFLO(NOL)=""
   FLGCSL = 0
   # Loop on the non automatic ledgers in the order of the local menu 2644
   For I=1 To [M:HAEF]NBRLED
    # Initialize the flow code with the first consolidated ledger that have a non empty account
    # Initialisation du code flux avec le premier référentiel consolidé qui mouvemente un compte
    If [M:HAEF]COA(I-1)<>"" & TCOMPTE(I)<>""
     Call LEC_GAC(TCOMPTE(I),[M:HAEF]COA(I-1)) From CPTLEC
     If [M]CDT(NOL)<>0
      [L]ASTATUS = func FINCSLLIB.GET_CSLFLO(GACTX,[M]CPY,[M:HAEF]LED(I-1),[M]JOU,[M:HAEF]COA(I-1),TCOMPTE(I),-1,FLGCSL,[M]CSLFLO(NOL),MESSA)
     Else
      [L]ASTATUS = func FINCSLLIB.GET_CSLFLO(GACTX,[M]CPY,[M:HAEF]LED(I-1),[M]JOU,[M:HAEF]COA(I-1),TCOMPTE(I),1,FLGCSL,[M]CSLFLO(NOL),MESSA)
     Endif
     # Is it a consolidated ledger ?
     [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,[M:HAEF]LED(I-1),FLGCSL,MESSA)
     If FLGCSL=2 : Break  : Endif
    Endif
   Next
  Elsif dim([M]CSLFLO(NOL))>0 & [M]CSLFLO(NOL)=""
   J = -1
   ## Initialisation du code flux... et contrôle que le code flux ne soit pas obligatoire sur un des référentiels.
   For I=1 To [M:HAEF]NBRLED
    If [M:HAEF]COA(I-1)<>""
     Call LEC_GAC(TCOMPTE(I),[M:HAEF]COA(I-1)) From CPTLEC
     # Est-il Gestion de flux ?
     If !fstat & dim([F:GAC]CSLFLGFLW)>0 & [F:GAC]CSLFLGFLW>1
      If [M]DEB(NOL)<>0
       [M]CSLFLO(NOL) = [F:GAC]FLODEB
      Else
       [M]CSLFLO(NOL) = [F:GAC]FLOCDT
      Endif
      If [M]CSLFLO(NOL)<>"" : Break : Endif
      If [F:GAC]CSLFLGFLW=3 : J = I : Endif
     Endif
    Endif
   Next
   If [M]CSLFLO(NOL)="" & J>-1
    # Code flux obligatoire
    MESSA = "ACC"-TCOMPTE(J)-"("+[M:HAEF]COA(J-1)+")"-":"-mess(137,104,1) : STAT = 97 : Break
   Endif
  Endif

  ## After the initialization, if the consolidation code is empty, check that it is not mandatory
  ## for the accounts of the other consolidated ledgers
  If FLGPRCSL & dim([M]CSLFLO(NOL))>0 & [M]CSLFLO(NOL)=""
   For I=1 To [M:HAEF]NBRLED
    FLGCSL = 0
    [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,[M:HAEF]LED(I-1),FLGCSL,MESSA)
    If FLGCSL=2 & [M:HAEF]COA(I-1)<>"" & TCOMPTE(I)<>""
     Call LEC_GAC(TCOMPTE(I),[M:HAEF]COA(I-1)) From CPTLEC
     If [F:GAC]CSLFLGFLW=3
      MESSA =  func AFNC.MES2(mess(127,106,1),[F:GAC]COA,[F:GAC]ACC)
      STAT = 97 : Break 2
     Endif
    Endif
   Next
  Endif

  # Partner management for consolidation
  If FLGPRCSL
   If dim([M]CSLBPR(NOL))>0 & [M]CSLBPR(NOL)=""
    FLGCSL = 0
    # Loop on the non automatic ledgers in the order of the local menu 2644
    For I=1 To [M:HAEF]NBRLED
     # Initialize the partner code with the first consolidated ledger that have a non empty account
     If [M:HAEF]COA(I-1)<>"" & TCOMPTE(I)<>""
      # Is it a consolidated ledger ?
      [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,[M:HAEF]LED(I-1),FLGCSL,MESSA)
      If FLGCSL=2
       [L]ASTATUS = func FINCSLLIB.GET_CSLBPR(GACTX,MAINBPR,[M]CPY,[M:HAEF]LED(I-1),[M:HAE2]BPR(NOL), [M:HAEF]COA(I-1),TCOMPTE(I),FLGCSL,[M:HAE2]CSLBPR(NOL),MESSA)
       Break
      Endif
     Endif
    Next
   Endif
   ## After the initialization, if the consolidation code is empty, check that it is not mandatory
   ## for the accounts of the other consolidated ledgers
   If dim([M]CSLBPR(NOL))>0 & [M]CSLBPR(NOL)=""
    For I=1 To [M:HAEF]NBRLED
     FLGCSL = 0
     [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,[M:HAEF]LED(I-1),FLGCSL,MESSA)
     If FLGCSL=2 & [M:HAEF]COA(I-1)<>"" & TCOMPTE(I)<>""
      Call LEC_GAC(TCOMPTE(I),[M:HAEF]COA(I-1)) From CPTLEC
      If [F:GAC]CSLFLGBPR=3
       MESSA =  func AFNC.MES2(mess(128,106,1),[F:GAC]COA,[F:GAC]ACC)
       STAT = 97 : Break 2
      Endif
     Endif
    Next
   Endif
  Endif

 Endif

 # For import templates GAS/GAS1/GAS2/GASDUD, checking of the validity of the fields CSLFLO and CSLBPR
 If GIMPORT
  If FLGCSL1 & dim([M]CSLFLO(NOL))>0 & [M]CSLFLO(NOL)<> ""
   Call LEC_ADI("324",[M]CSLFLO(NOL)) From CPTLEC
   If fstat # Nonexistent flow
    MESSA =   "CSLFLO"-[M]CSLFLO(NOL)-": "-mess(202,104,1)
    STAT = 97 : Break
   Endif
  Endif
  If FLGPRCSL & dim([M]CSLBPR(NOL))>0 & [M]CSLBPR(NOL)<>""
   If !clalev([F:AMZ_I]) : Local File AMSKZON [AMZ_I] : Endif
   If [F:AMZ_I]CODMSK<>"GACCENTR1" & [F:AMZ_I]CODZON<>"CSLBPR"
    Read [AMZ_I]CODE="GACCENTR1";"CSLBPR"
   Endif
   Call CONTROLE("BPR",[F:AMZ_I]OPTOBJ,[M]CSLBPR(NOL),"",mkstat) From CONTOBJ
   If mkstat
    MESSA = "CSLBPR"-[M]CSLBPR(NOL)-": "-GMESSAGE
    STAT = 97 : Break
   Endif
  Endif
 Endif

 # Unité, Quantité
 If CPTANA<>""
  Call LEC_GAC(CPTANA,PLANA) From CPTLEC
  If !fstat & dim([F:GAC]UOM)>0
   [M]UOM(NOL) = [F:GAC]UOM
   If [F:GAC]UOM<>""
    Call LEC_TUN([F:GAC]UOM) From CPTLEC
    AROQTE = 10^(-[F:TUN]UOMDEC)
    [M]QTY(NOL) = arr([M]QTY(NOL),AROQTE)
   Else
    [M]QTY(NOL) = 0
   Endif
  Else
   [M]QTY(NOL) = 0
  Endif

 # Sections ana
  If [M]DSP(NOL)<>"" & [M]DSP(NOL)<>"$"
   Call C_DSP([M]DSP(NOL)) From SUBGA0
   If mkstat : MESSA = "DSP"-[M]DSP(NOL) : STAT = 99 : Break : Endif
  Elsif [M]PTV(NOL)=0
   For AXE=1 To [M:HAEF]NBRAXI
    ## Recherche des types référentiels qui gèrent cet axe.
    ## - Si tous les comptes des types référentiels qui gèrent cet axe n'ont pas l'axe de renseigné dans
    ## la fiche compte, alors ça veut dire que l'axe n'est pas saisissable
    [L]DIE = [M:HAEF]DIE(AXE-1) : SUIVI = 0
    For LEDTYP=1 To [M:HAEF]NBRLED
     If [M]AUTACE<>"" | [M:HAEF]TYPENT=1 | LEDTYP=[M]LEDTYP(NOL)
      Call INDLED([M:HAEF]LED(LEDTYP-1),[L]DIE,IND,AXI) From CPTDIV
      If IND & AXI
       If ([M]AUTACE<>"" & [M]AUTACE<>PCEMTE) | [M:HAEF]TYPENT=1
        COMPTE = evalue("[M]ACC"+num$(LEDTYP)+"("+num$(NOL)+")")
       Else
        COMPTE = evalue("[M]ACC1("+num$(NOL)+")")
       Endif
       Call LEC_GAC(COMPTE,[M:HAEF]COA(LEDTYP-1)) From CPTLEC
       If !fstat & find([L]DIE,[F:GAC]DIE(0..dim([F:GAC]DIE)-1))
        Local Integer B_CRESEC : B_CRESEC = 0 : # X3-84159
        SUIVI = 1
        SECTION = evalue("[M]CCE"+num$(AXE)+"("+num$(NOL)+")")
        VU = find([L]DIE,[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
        If SECTION="" & VU & [F:CPY]OBYDIE(VU-1)=2 & !FLGPER
         MESSA = COMPTE-"("+[M:HAEF]LED(LEDTYP-1)+")"-":"-mess(46,106,1)-[L]DIE : STAT = 97 : Break 3
        Endif
        If SECTION<>""
         Call LEC_CCE(SECTION,[L]DIE) From CPTLEC
         If fstat
          Call LEC_DIE([L]DIE) From CPTLEC
          If [F:DIE]CREAUT=2
           Call CRESEC([L]DIE,SECTION,"") From CPTAUTO
           B_CRESEC = 1 : # X3-84159
           mkstat = 0
          Else
           ## Section inexistante
           MESSA = COMPTE-"("+[M:HAEF]LED(LEDTYP-1)+")"-":"-SECTION-mess(35,106,1) : STAT = 97 : Break 3
          Endif
         Endif
        Endif
        If [M]FLGREP<>2
         Call CONTCCE(SECTION,[M:HAEF]LED(LEDTYP-1),[L]DIE,[M]FCYLIN(NOL),[M]ACCDAT,COMPTE,[M:HAEF]DIE,"[M]CCE#",NOL) From CPTCNT
         # Issue X3-84159 If mkstat : MESSA = COMPTE-[L]DIE-"("+[M:HAEF]LED(LEDTYP-1)+")"-":"-SECTION-GMESSAGE : STAT = 97 : Break 3 : Endif
         If mkstat Then
          If (B_CRESEC and instr(1,GMESSAGE,mess(7,103,1)) <> 0) Then
           mkstat = 0
          Else
           MESSA = COMPTE-[L]DIE-"("+[M:HAEF]LED(LEDTYP-1)+")"-":"-SECTION-GMESSAGE : STAT = 97 : Break 3
          Endif
         Endif
         # End issue X3-84159
        Endif
       Endif
      Endif
     Endif
    Next LEDTYP
    If !SUIVI
     Assign "[M]CCE"+num$(AXE)+"("+num$(NOL)+")" With ""
    Endif
   Next AXE
  Else
   ## Toute une partie à revoir (non comprise) : voir $PARTIE_A_REVOIR
   # Sections du masque ventile
   #  Default Mask [VTL] (MB)
   For IEC=[M]PTV(NOL) To [M]PTF(NOL)
    [M:VT2]TBAMT(IEC) = arr([M:VT2]TBAMT(IEC),[F:TCU]CURRND)
    If [M]UOM(NOL)=""
     [M:VT2]TBQTY(IEC) = 0
    Else
     [M:VT2]TBQTY(IEC) = arr([M:VT2]TBQTY(IEC),AROQTE)
    Endif
   Next IEC
   MTTH = [M]DEB(NOL)+[M]CDT(NOL)
   MTRR = sum([M:VT2]TBAMT([M]PTV(NOL)..[M]PTF(NOL)))
   If MTTH<>MTRR
    If abs(MTTH-MTRR)<5*[F:TCU]CURRND*([M]PTF(NOL)-[M]PTV(NOL)) : # Pour pas boucler
     ECART = MTTH-MTRR
     IEC = [M]PTV(NOL)
     While ECART<>0
      If ECART>0
       [M:VT2]TBAMT(IEC) += [F:TCU]CURRND
       ECART             -= [F:TCU]CURRND
      Else
       [M:VT2]TBAMT(IEC) -= [F:TCU]CURRND
       ECART             += [F:TCU]CURRND
      Endif
      IEC += 1
      If IEC>[M]PTF(NOL) : IEC = [M]PTV(NOL) : Endif
     Wend
    Else
     MESSA = num$(NOL+1) : STAT = 25 : Break
    Endif
   Endif
   MTTH = [M]QTY(NOL)
   MTRR = sum([M:VT2]TBQTY([M]PTV(NOL)..[M]PTF(NOL)))
   If MTTH<>MTRR & (!GIMPORT or MTRR<>0)
    If abs(MTTH-MTRR)<5*AROQTE*([M]PTF(NOL)-[M]PTV(NOL)) : # Pour pas boucler
     ECART = MTTH-MTRR
     IEC = [M]PTV(NOL)
     While ECART<>0
      If ECART>0
       [M:VT2]TBQTY(IEC) += AROQTE
       ECART             -= AROQTE
      Else
       [M:VT2]TBQTY(IEC) -= AROQTE
       ECART             += AROQTE
      Endif
      IEC += 1
      If IEC>[M]PTF(NOL) : IEC = [M]PTV(NOL) : Endif
     Wend
    Else
     MESSA = num$(NOL+1) : STAT = 26 : Break
    Endif
   Endif

   ## 1 ère passe pour supprimer les lignes analytiques à 0 (mais uniquement dans le cas où le montant
   ## de la pièce est différent de zéro : en effet, autant on supprime les lignes nulles lorsque le montant
   ## de la pièce est différent de zéro (fait dans trt SUBGA1), autant on autorise la
   ## génération des lignes nulles si le montant de la pièce est <>0 (paramètre SIVNULL).
   ## Dans ce dernier cas, on veut conserver l'imputation analytique nulle (qui est correcte puisque la ligne
   ## d'écriture elle-même est nulle)
   If !GIMPORT & sum([M]DEB(0..[M]NBLIG-1))<>0  # Exclu l'import => F58541
    Local Integer PTVD, NBANU
    Local Integer PT_V, PT_F
    Local Decimal TB_AMT([M]PTV(NOL)..[M]PTF(NOL))
    PT_V = [M]PTV(NOL)
    PT_F = [M]PTF(NOL)
    For PT=PT_V To PT_F
     TB_AMT(PT) = [M:VT2]TBAMT(PT)
    Next
    Raz NBANU
    For PT=PT_V To PT_F
     ## Dans le cas d'un montant pièce<>0, les lignes à 0 vont être supprimées (dans trt SUBGA1)
     ## On supprime alors aussi les lignes ana à 0 (au cas où il y aurait eu regroupement)
     If TB_AMT(PT) = 0
      PTVD = PT-NBANU
      Call ANUVENTIL([M]PTV,[M]PTF,[M]NBLIG,PTVD,1) From VENTILE
      [M]PTF(NOL) -= 1
      NBANU +=1
      # Demande 51618 : si au final toutes les lignes de la répartition sont à 0 => la ventilation est donc supprimé. cf FINREP de CPTAUTO
      If [M]PTF(NOL)=[M]PTV(NOL)
       VENT = [M]PTV(NOL)
       For AXE=1 To [M:HAEF]NBRAXI
        Assign "[M]CCE"+num$(AXE)+"("+num$(NOL)+")" With evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$(VENT)+")")
       Next AXE
       ## <PP> Bug 52771 : on RAZ la répartition mais pas les PTV et PTF.
       #[M]PTV(NOL) = 0 : [M]PTF(NOL) = 0 : [M]DSP(NOL) = ""
       [M]DSP(NOL) = ""
      Endif
     Endif
    Next
    # S'il y a plusieurs lignes à zéro, cela signifie que la ventilation analytique est <>... et qu'il faut la garder
    If [M]PTF(NOL)<[M]PTV(NOL) # Suppression de toutes les lignes
     [M]PTV(NOL) = 0 : [M]PTF(NOL) = 0 : [M]DSP(NOL) = ""
    Endif

   Endif
  If GUSER="ADMIN" Infbox "entro" Endif
   For PT=[M]PTV(NOL) To [M]PTF(NOL)
    If PT=0 : Break : Endif
    nolign = PT
    For AXE=1 To [M:HAEF]NBRAXI
     [L]DIE = [M:HAEF]DIE(AXE-1) : SUIVI = 0
     For LEDTYP=1 To [M:HAEF]NBRLED
      Call INDLED([M:HAEF]LED(LEDTYP-1),[L]DIE,IND,AXI) From CPTDIV
      If IND & AXI
       If ([M]AUTACE<>"" & [M]AUTACE<>PCEMTE) | [M:HAEF]TYPENT=1
        COMPTE = evalue("[M]ACC"+num$(LEDTYP)+"("+num$(NOL)+")")
       Else
        COMPTE = evalue("[M]ACC1("+num$(NOL)+")")
       Endif
       Call LEC_GAC(COMPTE,[M:HAEF]COA(LEDTYP-1)) From CPTLEC
       If !fstat & find([L]DIE,[F:GAC]DIE(0..dim([F:GAC]DIE)-1))
        Local Integer B_CRESEC : B_CRESEC = 0 : # X3-84159
        SUIVI = 1
        SECTION = evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$(PT)+")")
        VU = find([L]DIE,[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
        If SECTION="" & VU & [F:CPY]OBYDIE(VU-1)=2 & !FLGPER
         MESSA = COMPTE-"("+[M:HAEF]LED(LEDTYP-1)+")"-":"-mess(46,106,1)-[L]DIE : STAT = 97 : Break 4
        Endif
        If SECTION<>""
         Call LEC_CCE(SECTION,[L]DIE) From CPTLEC
         If fstat
          Call LEC_DIE([L]DIE) From CPTLEC
          If [F:DIE]CREAUT=2
           Call CRESEC([L]DIE,SECTION,"") From CPTAUTO
           B_CRESEC = 1 : # X3-84159
           mkstat = 0
          Else
           ## Section inexistante
           MESSA = COMPTE-"("+[M:HAEF]LED(LEDTYP-1)+")"-":"-SECTION-mess(35,106,1) : STAT = 97 : Break 4
          Endif
         Endif
        Endif
        If [M]FLGREP<>2
         Call CONTCCE(SECTION,[M:HAEF]LED(LEDTYP-1),[L]DIE,[M]FCYLIN(NOL),[M]ACCDAT,COMPTE,[M:HAEF]DIE,"[M:VT2]TBCCE#",PT) From CPTCNT
         # Issue X3-84159 If mkstat : MESSA = COMPTE-[L]DIE-"("+[M:HAEF]LED(LEDTYP-1)+")"-":"-SECTION-GMESSAGE : STAT = 97 : Break 4 : Endif
         If mkstat Then
          If (B_CRESEC and instr(1,GMESSAGE,mess(7,103,1)) <> 0) Then
           mkstat = 0
          Else
           MESSA = COMPTE-[L]DIE-"("+[M:HAEF]LED(LEDTYP-1)+")"-":"-SECTION-GMESSAGE : STAT = 97 : Break 4
          Endif
         Endif
         # End issue X3-84159
        Endif
       Endif
      Endif
     Next LEDTYP
    Next AXE
   Next PT
  Endif

 Else : # Pas de compte analytique (CPTANA = "")
  [M]PTV(NOL) = 0 : [M]PTF(NOL) = 0
  [M]UOM(NOL) = "" : [M]QTY(NOL) = 0
  [M]DSP(NOL) = ""
  For AXE=1 To [M:HAEF]NBRAXI
   Assign "[M]CCE"+num$(AXE)+"("+num$(NOL)+")" With ""
  Next AXE
 Endif
Next NOL
If STAT
 If [M]AUTACE<>"" & [M]LIGPCEAUTO(NOL)<>0
  MESSA -= "("+[M]AUTACE-mess(1,114,1)-num$([M]LIGPCEAUTO(NOL))+")" : # Ligne...
 Else
  MESSA -= "("+mess(1,114,1)-num$(NOL+1)+")" : # Ligne...
 Endif
Endif

Return

$ERR_HAE

If STAT
 If [M]AUTACE<>""
  MESSA -= "("+[M]AUTACE+")"
 Endif
Endif

Return

########################################################
## Validation dans les fichiers temporaires
Subprog VALPIECE(STAT,MESSA)
Variable Integer STAT
Variable Char    MESSA()
Local Integer DIRECT : DIRECT = 0

Goto VALPCE
########################################################
##*X3-39795  validation with imposed values
Subprog VALPIECE2(STAT,MESSA,ZONE,VALEUR)
Variable Integer STAT
Variable Char    MESSA()
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)
Local Integer DIRECT : DIRECT = 0
Goto VALPCE
########################################################
## Validation dans les fichiers réels
Subprog VALPIECER(STAT,MESSA)
Variable Integer STAT
Variable Char    MESSA()
Local Integer DIRECT : DIRECT = 1

Goto VALPCE
########################################################
##*X3-39795  validation with imposed values
Subprog VALPIECER2(STAT,MESSA,ZONE,VALEUR)
Variable Integer STAT
Variable Char    MESSA()
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)
Local Integer DIRECT : DIRECT = 1
Goto VALPCE
########################################################
$VALPCE

If clalev([M:HAEW])=0 : STAT = 1 : End : Endif
If clalev([M:HAE0])=0 : STAT = 1 : End : Endif
If clalev([M:HAE1])=0 : STAT = 1 : End : Endif
If clalev([M:HAE2])=0 : STAT = 1 : End : Endif
If clalev([M:VTL]) =0 : STAT = 1 : End : Endif
If clalev([M:VT2]) =0 : STAT = 1 : End : Endif

Local Integer MAXLIG , MAXVTL
MAXLIG = dim([M:HAE2]SAC1)

MAXVTL = dim([M:VTL]AMT)
Local Decimal DEBLOC(MAXLIG) , CDTLOC(MAXLIG)
Local Decimal DEBRPT(MAXLIG) , CDTRPT(MAXLIG)
Local Decimal TMPLOC(MAXVTL) , TMPRPT(MAXVTL)
Local Decimal AROLOC , ARORPT
Local Integer FLECHE , ECHNUM
Local Decimal ECHCUR , ECHLED
Local Integer I , J , K, NOL
Local Integer BAL
Local Integer IND, AXE
Local Char    PIECE(GLONVCR)
Local Integer SPEGAS, SPVGAS(0..)
Local Char    ACTION(GLONADC), TEMP_ACTION(GLONADC)
Local Char    CODSPEGAS(GLONADC), CODSPVGAS(GLONADC)(0..)
Local Decimal EXERCICE , PERIODE
Local Integer FLCHRNUM

CODSPEGAS ="SPEGAS"
Call EXISTE_ADX("","","SPEGAS",SPEGAS) From ORDSYS
CODSPVGAS ="SPVGAS"
Call EXISTE_ADX("","","SPVGAS",SPVGAS) From ORDSYS

If DIRECT
 If  GCOMPTA<>3 :# Si compta
  If clalev([F:HAE])=0 : Local File =GTABCPT+"GACCENTRY"    [HAE] : Endif
  If clalev([F:DAE])=0 : Local File =GTABCPT+"GACCENTRYD"   [DAE] : Endif
  If clalev([F:DAA])=0 : Local File =GTABCPT+"GACCENTRYA"   [DAA] : Endif
  If clalev([F:BAL])=0 : Local File =GTABCPT+"BALANCE"      [BAL] : Endif
  If clalev([F:BLA])=0 : Local File =GTABCPT+"BALANA"       [BLA] : Endif
 Endif
Else
 If clalev([F:HAE])=0 : Local File =GTABCPT+"GACCTMP"    [HAE] : Endif
 If clalev([F:DAE])=0 : Local File =GTABCPT+"GACCTMPD"   [DAE] : Endif
 If clalev([F:DAA])=0 : Local File =GTABCPT+"GACCTMPA"   [DAA] : Endif
Endif

If clalev([F:TCU])=0 : Local File TABCUR                [TCU] : Endif
If clalev([F:CPY])=0 : Local File COMPANY               [CPY] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT               [TUN] : Endif
If clalev([F:ANM])=0 : Local File =GTABCPT+"ACODNUM"    [ANM] : Endif
If clalev([F:AVN])=0 : Local File =GTABCPT+"AVALNUM"    [AVN] : Endif
If clalev([F:DSP])=0 : Local File =GTABCPT+"CADSP"      [DSP] : Endif
#ISSUE X3-57794 by MRDAB
If clalev([F:APE])=0 : Local File AENTREE               [APE] : Endif
#ISSUE END

If GCOMPTA<>3
 If clalev([F:GTE])=0 : Local File =GTABCPT+"GTYPACCENT" [GTE] : Endif
 If clalev([F:DUD])=0 : Local File =GTABCPT+"GACCDUDATE" [DUD] : Endif
 If clalev([F:TAM])=0 : Local File =GTABCPT+"TABPAM"     [TAM] : Endif
 Local File =GTABCPT+"GACCENTRY" [HAE2]
Endif

CODSPEGAS ="SPEGAS"
Call EXISTE_ADX("","","SPEGAS",SPEGAS) From ORDSYS
#ISSUE X3-57794 by MRDAB
Gosub COLLECT_GAS_SPVS
#ISSUE END

GPOINT = "OPNATB" : Gosub ENTREE From EXEFNC

# Contrôles & conversion
Gosub TR1
If GOK>0   MESSA = PIECE   : Endif
If GOK<0 & !STAT : STAT=20 : Endif

End

$TR1

Raz [F:HAE]
PIECE = [M]NUM
If PIECE=""
 If dim([F:GTE]TYP)<0
  Call NUMERO([M]TYP,[M]FCY,[M]ACCDAT,[M]JOU,PIECE,STAT) From SUBANM
  If GOK<0
   Return
  Elsif STAT
   # Problème lors de la récupération du compteur
   Gosub MESSAGE From SUBANM
   MESSA = mess(60,199,1)-"("+[M]TYP+") : "+MESSA
   GOK=0 : Return
  Endif
 Else
  Call GETSOC([M]FCY) From DEVSUB
  Call LEC_GTE_LEG(GCURLEG,[M]TYP) From CPTLEC
  If fstat | [F:GTE]COU="" : # GH 23/09/99 bug 3270
   # Aucune séquence de numérotation définie pour le type de pièce TYP
   GOK=0 : MESSA=mess(103,106,1)-[M]TYP : STAT=99 : Return
  Endif
  # Issue 102662
  #If dim([F:GTE]PREACC)>0 & [F:GTE]PREACC=2 & func AFNC.PARAM("ITAPRO",[M]CPY)="2"
  If dim([F:GTE]PREACC)>0 & [F:GTE]PREACC=2 & func AFNC.ACTIV("KIT") & func AFNC.PARAM("ITAPRO",[M]CPY)="2"
   # Localisation Italie : exercice provisoire
   Call NUMERO([F:GTE]COU,[M]FCY,[M:HAE1]ENTDAT,[M]JOU,PIECE,STAT) From SUBANM
  Else
   Call NUMERO([F:GTE]COU,[M]FCY,[M]ACCDAT,[M]JOU,PIECE,STAT) From SUBANM
  Endif
  If STAT
   # Problème lors de la récupération du compteur
   Gosub MESSAGE From SUBANM
   MESSA = mess(60,199,1)-"("+[F:GTE]COU+") : "+MESSA
   GOK=0 : Return
  Elsif GOK<1 : Return
  Endif
  If GCOMPTA<>3  :# Compta
   Look [HAE2]HAE0 = [M]TYP;PIECE
   If fstat=0
    MESSA = [M]TYP-PIECE
    STAT = 21 : Gosub MESSAGE From CPTAUTO
    GOK = 0 : Return
   Endif
  Endif
 Endif
Endif

# Issue 102662
If dim([F:HAE]BOLLATO)>0 and func AFNC.ACTIV("KIT") and func AFNC.PARAM("ITABOL",[M]CPY)="2"
#If dim([F:HAE]BOLLATO)>0 & func AFNC.PARAM("ITABOL",[M]CPY)="2"
 If !clalev([F:JOU]) : Local File GJOURNAL [JOU]  : K=1 : Else K=0 : Endif
 OK=1
 Gosub INIT_BOLLATO From SUBGAS
 If K : Close Local File [JOU] : Endif
Endif

[M:HAE0]NUM = PIECE
[F:HAE] = [M:HAE0]
[F:HAE] = [M:HAE1]
[F:HAE]NUM = PIECE

 #*X3-39795   Assignment of imposed values
 For I=1 To dim(ZONE)
 If ZONE(I)<>""
  Case evalue("type([F:HAE]"+ZONE(I)+")")
   When 1,2,4,5,6,7,8,9
    Assign "[F:HAE]"+ZONE(I) With val(VALEUR(I))
   When 3
    Assign "[F:HAE]"+ZONE(I) With gdat$(VALEUR(I))
   When Default
    Assign "[F:HAE]"+ZONE(I) With VALEUR(I)
  Endcase
 Endif
Next I
#*X3-39795  END

# Initialization of final number
#JASMI - 2017-04-24 - Req. 122336 - START
#Gosub INI_FNLPSTNUM From SUBGAS
If !func TRTHRCPT.IS_X3PEOPLE_EXT_ACC() #if Not X3 People and Not External Accounting
 Gosub INI_FNLPSTNUM From SUBGAS
Endif
#JASMI - 2017-04-24 - Req. 122336 - END
If GOK<1 : MESSA = GMESSAGE : Return : Endif

If dim([F:HAE]CREDAT)>0 : [F:HAE]CREDAT = date$ : Endif
If dim([F:HAE]CREUSR)>0 : [F:HAE]CREUSR = GUSER : Endif
If dim([F:HAE]EXPNUM)>0
 [F:HAE]EXPNUM = [C]EXPORT
Endif

If SPEGAS
 ACTION = "INICRE" : Gosub ACTION From =CODSPEGAS
Endif


#ISSUE X3-57794 by MRDAB
[L]TEMP_ACTION = ACTION
ACTION = "INICRE"
Gosub CALL_SPVS_ACTION
ACTION = [L]TEMP_ACTION
If GOK <= 0 : Return : Endif
#ISSUE END

FLCHRNUM = 1
GPOINT = "PIECE" : Gosub ENTREE From EXEFNC

If !DIRECT & dim([F:HAE]NUMPCE)>0
 [F:HAE]NUMPCE = uniqid([HAE])
Endif
Write [HAE]
If fstat
 GOK=0 : Call FSTA("HAE") From GLOCK : Return
Endif
If DIRECT
 BAL = 1
 FLECHE = 1
 FLCHRNUM = 1
Else
 BAL = 0
 FLECHE = 0
Endif
#JASMI - 2017-04-24 - Req. 122336 - START
#Gosub CREPCE From SUBGAS
If func TRTHRCPT.IS_X3PEOPLE_EXT_ACC() #if X3 People and External Accounting
 Gosub CREPCE From SUBHRGAS
Else
 Gosub CREPCE From SUBGAS
Endif
#JASMI - 2017-04-24 - Req. 122336 - END
If   GOK<0 : Return : Endif
GTYPPCE = [F:HAE]TYP
GNUMPCE = [F:HAE]NUM
If SPEGAS
 ACTION = "CREATION" : Gosub ACTION From =CODSPEGAS
Endif
If SPVGAS
 ACTION = "CREATION" : Gosub ACTION From =CODSPVGAS
Endif

Return

##########################################################
Subprog DELPCE(TYPPCE,PIECE)
Value Char TYPPCE
Value Char PIECE

Local Char SYMBOLE(30)
##DBA le 20/01/03 : Historisation des échéances supprimées
Local Char CRITSUPPR (250)
##

Local Char LSTTYPLED(10) : # Liste des types référentiels flagués 'Double Entry Method'

If clalev([F:BAL])=0 : Local File =GTABCPT+"BALANCE"    [BAL] : Endif
If clalev([F:BLA])=0 : Local File =GTABCPT+"BALANA"     [BLA] : Endif
If clalev([F:BLQ])=0 : Local File =GTABCPT+"BLAQTY"     [BLQ] : Endif
If clalev([F:LED])=0 : Local File =GTABCPT+"GLED"       [LED] : Endif

Local File =GTABCPT+"GACCENTRYD" [DAE]
Local File =GTABCPT+"GACCENTRYA" [DAA]
Local File =GTABCPT+"GACCDUDATE" [DUD]
If !adxtrans
 Local File =GTABCPT+"GACCENTRY" [HAE]
Endif

# FQ104266
If GMODU(14) = 2 and GPRODUIT = 0
 If clalev([F:LCA])=0 : Local File =GTABCPT+"LNKCPTABX3"      [LCA] : Endif
 If clalev([F:LCD])=0 : Local File =GTABCPT+"LNKCPTABD"       [LCD] : Endif
Endif

SYMBOLE = "HAE"+PIECE+"\"+TYPPCE
Lock =SYMBOLE
If fstat=1
 If adxtrans & GTRACE="" : GOK=1 : Call ERREURT(TYPPCE-PIECE-mess(12,110,1),GOK) From GESECRAN
 Else                    : Call ECR_TRACE(TYPPCE-PIECE-mess(12,110,1),1) From GESECRAN
 Endif
 GOK=0 : End
Endif
If adxtrans
 # Read [HAE]HAE0 = TYPPCE;PIECE doit avoir été fait avant le Call DELPCE
 Gosub DELHAE
Else
 Call DEBTRANS From GLOCK
 Gosub TR3
Endif
Unlock =SYMBOLE

End

$TR3

GOK = 1
Trbegin [HAE] , [DAE] , [DAA] , [DUD]
 Read [HAE]HAE0 = TYPPCE;PIECE
 If func AFNC.ACTIV("KRU")
  Call LEDTYPDEM([F:HAE]CPY,LSTTYPLED) From CPTDIV
 Else
  LSTTYPLED = ""
 Endif
 Gosub DELHAE
 If   GOK<0 : Goto ROLL_TR3
 Elsif !GOK : Goto AB_TR3
 Endif
Commit

Return

$DELHAE

If GSOCIETE=""
 GSOCIETE = [F:HAE]CPY
Endif
For [DAE] Where TYP=TYPPCE & NUM=PIECE
 Call VALSTA("GAS",-1) From SUBPS2
 If GOK<1 : Break : Endif
 If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
  Call LEC_LED([F:DAE]LED) From CPTLEC
  If [F:LED]GEN=2
   Call BALANCE(-1) From CPTBAL
   If GOK<1 : Break : Endif
  Endif
  If [F:LED]ANA=2
   For [DAA]DAA0 Where TYP=TYPPCE & NUM=PIECE & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
    Call BALANA(-1) From CPTBAL
    If GOK<1 : Break 2 : Endif
    ## Mise à jour Balance Russe si on est sur le référentiel Russe et sur une ligne éclatée
    If instr(1,LSTTYPLED,num$([F:DAE]LEDTYP)) & [F:DAE]ACCNUMDOE = 0
     Call BALDEM(-1) From CPTBAL
     If GOK<1 : Break 2 : Endif
    Endif
   Next
  Endif
 Endif
Next
If GOK<0 : Return : Endif
Delete [HAE] Where TYP=TYPPCE & NUM=PIECE
If fstat=1
 GOK = -1 : GLOCK = "$GACCENTRY"-TYPPCE-PIECE : Return
Endif
Delete [DAE] Where TYP=TYPPCE & NUM=PIECE
If fstat=1
 GOK = -1 : GLOCK = "$GACCENTRYD"-TYPPCE-PIECE : Return
Endif
Delete [DAA] Where TYP=TYPPCE & NUM=PIECE
If fstat=1
 GOK = -1 : GLOCK = "$GACCENTRYA"-TYPPCE-PIECE : Return
Endif
If GCOMPTA<>3
 ##DBA le 20/01/03 : Historisation des échéances supprimées
 CRITSUPPR="TYP='"+TYPPCE+"' & NUM='"+PIECE+"'"
 Call HISTOSUPPR (CRITSUPPR) From MODECHE
 ##
Endif
Delete [DUD] Where TYP=TYPPCE & NUM=PIECE
If fstat=1
 GOK = -1 : GLOCK = "$GACCDUDATE"-TYPPCE-PIECE : Return
Endif

GPOINT = "DELVCR" : Gosub ENTREE From EXEFNC

# FQ104266
If GMODU(14) = 2 and GPRODUIT = 0
 Delete [LCA] Where TYP=TYPPCE & NUM=PIECE
 If fstat=1
  GOK = -1 : GLOCK = "$LNKCPTABX3"-TYPPCE-PIECE : Return
 Endif
 Delete [LCD] Where TYP=TYPPCE & NUM=PIECE
 If fstat=1
  GOK = -1 : GLOCK = "$LNKCPTABD"-TYPPCE-PIECE : Return
 Endif
Endif

Return

$AB_TR3
Rollback
Return

$ROLL_TR3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR3 : Endif

Return

#ISSUE X3-57794 by MRDAB
####################################################################
# Collect all GAS object type entry points from APE
####################################################################
$COLLECT_GAS_SPVS

# 1st record with index = 0 is hardcoded for backward compatibility
I = 1
CODSPVGAS(0) = "SPVGAS"
Call EXISTE_ADX("", "", "SPVGAS", SPVGAS(0)) From ORDSYS

# TYP - object, OBJ - GAS, TRTSPE - do not include first hardcoded script again, the order will not work for the first hardcoded record
Filter [F:APE] Where [F:APE]TYP = 2 and [F:APE]OBJ = "GAS" and [F:APE]TRTSPE <> "SPVGAS" Order By [F:APE]RNG Asc; [F:APE]TRTSPE Asc
For [F:APE]
  If [F:APE]CODACT = "" or func AFNC.ACTIV([F:APE]CODACT)
    CODSPVGAS(I) = [F:APE]TRTSPE
    Call EXISTE_ADX("", "", CODSPVGAS(I), SPVGAS(I)) From ORDSYS
    I += 1
  Endif
Next

Filter [F:APE]

Return

####################################################################
# Calls Action from all GAS object related entry points from APE
####################################################################
$CALL_SPVS_ACTION

For I = 0 To maxtab(SPVGAS(I))
  If SPVGAS(I)
    Gosub ACTION From =CODSPVGAS(I)
  Endif
  If GOK <= 0 : Break : Endif
Next

Return
#ISSUE END

###########################
Subprog TRACE_PIECE(MTRACE)
###########################
Value Libelle MTRACE : # =1, inclure dans la trace courante, =0, autre trace
Local Integer I, J, K, EXISTE , SAVIUM
Local Integer OSEEK, OLTRACE, OERRTRACE
Local Integer TYPREF
Local Char    SAVIRS(10), SAVIFS(10), TEXTE(200), SUITE(5), FICTRA(GDIMFIC), OTRACE(GLONTRA)
Local Char    ZONE(20)
Local Char    VIDE(len(mess(23,147,1)))

VIDE = "<"+mess(23,147,1)+">"

If GTRACE="" : MTRACE=0 : Endif
If !MTRACE
 SAVIFS=adxifs
 SAVIRS=adxirs
 SAVIUM=adxium
 If GTRACE<>""
  OTRACE=GTRACE
  OLTRACE=GLTRACE
  OERRTRACE=GERRTRACE
  OSEEK=adxseek(1)
  Openo
 Endif
 GTRACE="VALPIECE"
 FICTRA=filpath("TRA",GTRACE,"tra",0)
 Lock FICTRA With lockwait=-1
 If filinfo(FICTRA,0)>=0 : EXISTE = 1 : Else : EXISTE = 0 : Endif
 Openo FICTRA , -1
 adxifs=""
 adxirs=chr$(10)
 If !EXISTE
  TEXTE="#<AdxV"+GADOVERS+">@(#)%I% "+format$("D:"+GFMDAT,datesyst)-"("+GUSER+") VALPIECE"
  Wrseq TEXTE
  GLTRACE=len(TEXTE)+1
 Endif
 GERRTRACE=0
Else
 FICTRA = filpath("TRA",GTRACE,"tra",0)
 Openo FICTRA,-1
Endif

Wrseq format$("D:"+GFMDAT,datesyst)-time$-"("+GUSER+")"-GFONCTION
Wrseq "TYP=";[M]TYP;" - ";
Wrseq "FCY=";[M]FCY;" - ";
Wrseq "JOU=";[M]JOU;" - ";
Wrseq "CUR=";[M]CUR;" - ";
Wrseq "ACCDAT=";format$("D:"+GFMDAT,[M]ACCDAT);" - ";
Wrseq "DESVCR=";[M]DESVCR
Wrseq

Wrseq format$("K:5X","FCY");" ";
For TYPREF=1 To [M:HAEF]NBRLED
 ZONE = "SAC"+num$(TYPREF)
 Wrseq format$("K:5X",ZONE);" ";
 ZONE = "ACC"+num$(TYPREF)
 Wrseq format$("K:15X",ZONE);" ";
Next
Wrseq format$("K:15X","BPR");" ";
Wrseq format$("K>:10X","DEB");" ";
Wrseq format$("K>:10X","CDT");" ";
For TYPREF=1 To len(mess(0,2644,1))
 ZONE = "AMTFRC"+num$(TYPREF)
 Wrseq format$("K>:10X",ZONE);" ";
Next
Wrseq format$("K:5X","TAX");" ";
Wrseq "DES"

For K=0 To [M]NBLIG-1
 SUITE=""
 Wrseq format$("K:5X",[M]FCYLIN(K));" ";
 For TYPREF=1 To [M:HAEF]NBRLED
  Wrseq format$("K:5X",evalue("[M]SAC"+num$(TYPREF)+"("+num$(K)+")"));" ";
  Wrseq format$("K:15X",evalue("[M]ACC"+num$(TYPREF)+"("+num$(K)+")"));" ";
 Next
 Wrseq format$("K:15X",[M]BPR(K));" ";
 Wrseq format$("N3z:6.2#",[M]DEB(K));" ";
 Wrseq format$("N3z:6.2#",[M]CDT(K));" ";
 For TYPREF=1 To len(mess(0,2644,1))
  Wrseq format$("N3z:6.2#",evalue("[M]AMTFRC"+num$(TYPREF)+"("+num$(K)+")"));" ";
 Next
 Wrseq format$("K:5X",[M]TAX(K));" ";
 Wrseq [M]DES(K)
 If [M]DSP(K)<>"" | [M]QTY(K)<>0 | ([M]PTV(K)<>0 & [M]PTF(K)>=[M]PTV(K))
  SUITE="... "
  If [M]DSP(K)<>"" : Wrseq SUITE+"DSP = ";[M]DSP(K) : Endif
  If [M]QTY(K)<>0  : Wrseq SUITE+"QTY = ";num$([M]QTY(K)) : Endif
  If [M]PTV(K)<>0
   For I=[M]PTV(K) To [M]PTF(K)
    Wrseq SUITE;
    For J=1 To [M:HAEF]NBRAXI
     Call INICCEFMT([M]DIE(J-1)) From SETGLBDIE
     If evalue("[M:VT2]TBCCE"+num$(J)+"("+num$(I)+")")<>""
      Wrseq format$("K:"+GCCEFMT,evalue("[M:VT2]TBCCE"+num$(J)+"("+num$(I)+")"));" ";
     Endif
    Next J
    If [M]QTY(K)<>0
     Wrseq "Q="+format$("N:5F",[M:VT2]TBQTY(I));" ";
    Endif
    Wrseq "M="+num$([M:VT2]TBAMT(I))
   Next I
  Endif
 Endif
Next K
Wrseq string$(75,"-")
If !MTRACE
 Openo
 adxifs=SAVIFS
 adxirs=SAVIRS
 adxium=SAVIUM
 Unlock FICTRA
 GTRACE=OTRACE
 GERRTRACE=OERRTRACE
 GLTRACE=OLTRACE
 If GTRACE<>""
  FICTRA=filpath("TRA",GTRACE,"tra",0)
  Openo FICTRA , -1 : #OSEEK
 Endif
Else
 Openo
 FICTRA = filpath("TRA",GTRACE,"tra",0)
 Openo FICTRA , -1
Endif

End

# Issue X3-59028
Subprog B3_NBLIG

  # Recurring task management
  Call OBJET("ABA", [M]CODABT(nolign - 1), "") From GOBJET # Issue X3-111553

End
# End Issue X3-59028
