#<AdxTL>@(#)0.0.0.0 $Revision$
#-------------------#
$INIT_OS
Gosub _INIT_ACTX
Return

#-------------------#
$INIT_OS2
Gosub _INIT_ACTX
Return

#-------------------#
$INIT_IRS
Gosub _INIT_ACTX
Return

#-------------------#
$INIT_TMPDIR
Gosub _INIT_ACTX
Return

#---------------------------------------------------------------------#
$_INIT_ACTX
Gosub _INIT
#Fin
For I = 0 To 3
  this.OS(I+1)=WOS(I)
  this.OS2(I+1)=WOS2(I)
  this.TMPDIR(I+1)=WTMPDIR(I)
  this.IRS(I+1)=WIRS(I)
Next I

Local Integer RES
RES = fmet this.ASETATTRIBUTE("OS","STA","1")
RES = fmet this.ASETATTRIBUTE("IRS","STA","1")
RES = fmet this.ASETATTRIBUTE("TMPDIR","STA","1")
RES = fmet this.ASETATTRIBUTE("OS2","STA","1")
Return

#---------------------------------------------------------------------#
$_INIT
Local Char    MAC(GDIMFIC)(1..3)
Local Integer I , J , K , STAT
Onerrgo ERRINIT

Local Char     WOS(10)(0..3)       : # Type de machine (dos/unix)
Local Char     WOS2(10)(0..3)      : # Sous-type (AIX/ULTRIX)
Local Char     WTMPDIR(250)(0..3)  : # Répertoires temporaires
Local Char     WIRS(2)(0..3)       : # Séparateur ligne

I = 0
Gosub _SET_MAC
For I=1 To 3
 K = -1
 If adxmac(I-1)=""
  K = 0
 Else
  For J=1 To I-1
   If adxmac(I-1) = adxmac(J-1)
    K = J : Break
   Endif
  Next J
 Endif
 If K<0
  Gosub _SET_MAC
 Else
  WOS(I)     = WOS(K)
  WOS2(I)    = WOS2(K)
  WTMPDIR(I) = WTMPDIR(K)
 Endif
Next I

For I = 0 To 3
 Case WOS(I)
  When "unix"  : WIRS(I) = chr$(10)
  When "dos"   : WIRS(I) = chr$(13) + chr$(10)
  When Default : WIRS(I) = chr$(10)
 Endcase
Next I
Return


#----------------------------------------------#
$_SET_MAC
If I=0
 System MAC = "@ae_os"
Else
 System MAC = adxmac(I-1)+"@ae_os"
Endif
WOS(I)     = MAC(1)
WOS2(I)    = MAC(2)
WTMPDIR(I) = MAC(3)
If vireblc(WTMPDIR(I),2)=""
# Case WOS(I)
#  When "unix"
#   WTMPDIR(I) = "/tmp"
#  When "dos"
#   WTMPDIR(I) = "C:\TEMP"
# Endcase
 If I=0
  WTMPDIR(I) = filpath("!tmp","","","","","")
  WTMPDIR(I) = right$(WTMPDIR(I),instr(0,WTMPDIR(I),"@")+1)
 Else
  WTMPDIR(I) = filpath("!tmp","","","","",adxmac(I-1))
  WTMPDIR(I) = right$(WTMPDIR(I),instr(0,WTMPDIR(I),"@")+1)
 Endif
Endif
Return

#----------------------------------------------#
$ERRINIT
Resume

#---------------------------------------------------------------------------#
# Return "17r.218" or etna... or empty
#---------------------------------------------------------------------------#
Funprog _AVERSRUN(MACHINE)
#---------------------------------------------------------------------------#
Value    Char    MACHINE() : # Où sera exécuté l'ordre système
Goto RUNVER

#---------------------------------------------------------------------------#
Funprog VERSRUN(ACTX,MACHINE)
#---------------------------------------------------------------------------#
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    MACHINE() : # Où sera exécuté l'ordre système

$RUNVER
Local Char WCHTMP(250)
Local Integer RES
If MACHINE="" | MACHINE=adxmac(-1) | MACHINE=adxmac(0)
 WCHTMP=ver$(0)
Else
If dim(ACTX)>0
 Call SYSTEME2(ACTX,MACHINE,"adonix -v","",RES,WCHTMP)
Else
 Call _ASYSTEME2(MACHINE,"adonix -v","",RES,WCHTMP)
Endif
Endif
If pat(WCHTMP,"Version*")>0
 WCHTMP=func AFNC.PARTSEP(WCHTMP,2," ")
Endif
End WCHTMP

#---------------------------------------------------------------------------#
Subprog _ASYSTEME2(MACHINE,ORDRE,OPT,STAT,RESULT)
#---------------------------------------------------------------------------#
Value    Char    MACHINE() : # Où sera exécuté l'ordre système
Value    Char    ORDRE()   : # ORDRE(0) = ordre à exécuter ou nom d'un fichier de commande si option "f"
                           : # ORDRE(1) = fichier de trace éventuel
Value    Char    OPT()     : # Options !fs&b (conversationnel/fichier/silence/backround/backround dos)
Variable Integer STAT      : # = fstat1
Variable Char    RESULT()()

Local Integer RES
RES = 1
Goto SYST

#---------------------------------------------------------------------------#
Subprog SYSTEME2(ACTX,MACHINE,ORDRE,OPT,STAT,RESULT)
#---------------------------------------------------------------------------#
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    MACHINE() : # Où sera exécuté l'ordre système
Value    Char    ORDRE()   : # ORDRE(0) = ordre à exécuter ou nom d'un fichier de commande si option "f"
                           : # ORDRE(1) = fichier de trace éventuel
Value    Char    OPT()     : # Options !fs&b (conversationnel/fichier/silence/backround/backround dos)
Variable Integer STAT      : # = fstat1
Variable Char    RESULT()()

Local Integer RES
RES = 1
Goto SYST

#---------------------------------------------------------------------------#
Subprog _ASYSTEME(MACHINE,ORDRE,OPT,STAT)
#---------------------------------------------------------------------------#
Value    Char    MACHINE() : # Où sera exécuté l'ordre système
Value    Char    ORDRE()   : # ORDRE(0) = ordre à exécuter ou nom d'un fichier de commande si option "f"
                           : # ORDRE(1) = fichier de trace éventuel
Value    Char    OPT()     : # Options !fs&b (conversationnel/fichier/silence/backround/backround dos)
Variable Integer STAT      : # = 0

Local Integer RES
Local Char RESULT(1)
RES = 0
Goto SYST

#---------------------------------------------------------------------------#
Subprog SYSTEME(ACTX,MACHINE,ORDRE,OPT,STAT)
#---------------------------------------------------------------------------#
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    MACHINE() : # Où sera exécuté l'ordre système
Value    Char    ORDRE()   : # ORDRE(0) = ordre à exécuter ou nom d'un fichier de commande si option "f"
                           : # ORDRE(1) = fichier de trace éventuel
Value    Char    OPT()     : # Options !fs&b (conversationnel/fichier/silence/backround/backround dos)
Variable Integer STAT      : # = 0

Local Integer RES
Local Char RESULT(1)
RES = 0


$SYST
Local Integer CMD                         : # 1=fichier (option "f"), 0=commande
Local Integer BACK                        : # 1=background (option"&"), 0=non
Local Integer CONV                        : # 1=conversationnel ("!" ou "!!"), 0=non
Local Integer REDIR                       : # 0=>/dev/null, 1=non, 2=fichier
Local Integer ZERO                        : # 1=raz fichier (option "z"), 0=non
Local Integer SILENCE                     : # 1=silencieux (options "s")
Local Char    OS_ORD(GDIMFIC)(1..3)       : # O.S. machine de l'ordre à exécuter (os/type machine/rep.temp)
Local Char    OS_CMD(10)                  : # O.S. machine du fichier de commande (dos/unix)
Local Char    OS_TRA(10)                  : # O.S. machine du fichier trace intermédiaire (dos/unix)
Local Char    IRS_ORD(5)                  : # Séparateur ligne machine ordre
Local Char    IRS_CMD(5)                  : # Séparateur ligne machine fic commande
Local Char    IRS_TRA(5)                  : # Séparateur ligne machine trace
Local Char    IRS_LEC(5)                  : # Séparateur ligne de la trace généré par l'ordre système
Local Char    SCRIPT(GDIMFIC)             : # Chemin système ordre à exécuter
Local Char    TRACE(GDIMFIC)              : # Chemin système fichier trace
Local Char    FICHIER(GDIMFIC)            : # Chemin système fichier de commande
Local Char    SORTIE(GDIMFIC)             : # Sortie standard & erreurs à l'exécution
Local Char    FICCMD(30)
Local Char    EXT(3)(1..2)
Local Char    CHEMIN(GDIMFIC)(1..2)
Local Clbfile COMMANDE(1)
Local Clbfile BIN(1)
Local Clbfile ARG(1)
Local Char    WCMDE(250)
Local Char    MAC(GDIMFIC)(0..2)          : #
Local Char    SAVIFS(5)
Local Char    SAVIRS(5)
Local Integer STAT2 , SAVIUM,ASTATUS,SAVACTXREADONLY

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
If instr(1,OPT,"!")
 MACHINE = ""
Endif

##  O.S. de la machine sur laquelle doit s'exécuter l'ordre ?
If dim(ACTX)>0
 SAVACTXREADONLY = ACTX.isReadonly
 Call GET_OS(ACTX,MACHINE,OS_ORD)
Else
 Gosub _INIT
 Call _AGET_OS(WOS,WOS2,WTMPDIR,MACHINE,OS_ORD)
Endif

# Le répertoire temporaire doit exister
STAT = 1
If OS_ORD(3)<>""
 FICHIER = filpath(OS_ORD(3),"","","","",MACHINE)
 If MACHINE<>"#" & filinfo(FICHIER,0)<0
  # Répertoire temporaire pour les ordres systèmes inexistant
  #Call ECR_TRACE("|"+FICHIER-":"-mess(138,133,1),1) From GESECRAN
  If dim(ACTX)>0
   ACTX.isReadonly = 0
   ASTATUS = fmet ACTX.ASETERROR("","|"+FICHIER-":"-mess(138,133,1),[V]CST_AERROR)
   ACTX.isReadonly = SAVACTXREADONLY
  Endif
  STAT = 0 : End
 Endif
Endif
If STAT & OS_ORD(3)=""
 # Machine inaccessible
 #Call ECR_TRACE(MACHINE-":"-mess(199,100,1),1) From GESECRAN
 If dim(ACTX)>0
 ACTX.isReadonly = 0
 ASTATUS = fmet ACTX.ASETERROR("",MACHINE-":"-mess(199,100,1),[V]CST_AERROR)
 ACTX.isReadonly = SAVACTXREADONLY
 Endif
 STAT = 0 : End
Endif

##  Exécution conversationelle ?

If instr(1,OPT,"!")
 CONV = 1
Else
 CONV = 0
Endif

##  Fichier de commande ?

If instr(1,OPT,"f")
 CMD = 1
Else
 CMD = 0
Endif

##  Exécution silencieuse ?

If instr(1,OPT,"s")
 SILENCE = 1
Else
 SILENCE = 0
Endif

##  Exécution en arrière plan ?

If instr(1,OPT,"&")
 BACK = 1 : SILENCE = 1
Else
 BACK = 0
Endif

adxium = GASCII

If BACK
 If OS_ORD(1)="unix"
  Local Clbfile ORDRE_CLB(2)
  ORDRE_CLB = "{ trap 'exit 2' 2 ; trap '' 1 ;"-ORDRE-" & } ; echo $!"
  If dim(GTEST)>0 & GTEST
   adxifs = ""
   If dim(ACTX)>0
    adxirs = ACTX.ASOL.IRS(1+1)
    Openo filpath("",ACTX.ASOL.TMPDIR(1+1)+"/sh"+num$(adxpid),"tra") Using [AOUT]
   Else
    adxirs = WIRS(1)
    Openo filpath("",WTMPDIR(1)+"/sh"+num$(adxpid),"tra") Using [AOUT]
   Endif
   Wrseq ORDRE_CLB Using [AOUT]
   Openo Using [AOUT]
   adxifs = ""
   adxirs = chr$(10)
  Endif
  System RESULT = ORDRE_CLB
  End
 Else
  # Exécution en arrière plan impossible sous
  #Call ERREUR(mess(137,133,1)-OS_ORD(1)) From GESECRAN
  If dim(ACTX)>0
   ACTX.isReadonly = 0
   ASTATUS = fmet ACTX.ASETERROR("",mess(137,133,1)-OS_ORD(1),[V]CST_AERROR)
   ACTX.isReadonly = SAVACTXREADONLY
  Endif
  STAT = 0 : End
 Endif
Endif

##  Exécution redirigé vers un fichier de trace ?

If dim(ORDRE)>1 & ORDRE(1)<>""
 REDIR = 2 : SILENCE = 1
Elsif !CONV & !RES
 REDIR = 0
Else
 REDIR = 1
Endif

##  Remise à zéro préalable du fichier de trace ?

If REDIR=2 & instr(1,OPT,"z")
 ZERO = 1
Else
 ZERO = 0
Endif

########################################################
##  Nomenclatures des fichiers propres à chaque O.S.  ##
########################################################

Local Char    WFICCMD(10)
Local Integer WERR
Onerrgo ERREUR
Local File AESPION [AES]
WFICCMD = format$("N0:5#",mod(uniqid([AES]),99999))
Close Local File [AES]
Onerrgo
If WERR
 WFICCMD = format$("N0:5#",time)
Endif


##  1-) Le script intermédiaire

If dim(GTEST)>0 & GTEST
 ##  JP
 ##  En mode "debug", si la machine est rapide, on souhaite tout
 ##  de même distinguer les différents fichiers cmd,
 ##  on temporise donc pour n'en perdre aucun !!
 Sleep 1
 FICCMD = "cmd"+num$(adxuid(1))+"_"+WFICCMD
Elsif dim(GSERVEUR)>0 & GSERVEUR
 FICCMD = "cmd"+num$(adxuid(2))+"_"+WFICCMD
Elsif dim(ACTX)>0 & ACTX.ASOL.SERVEUR<>0
 FICCMD = "cmd"+num$(adxuid(2))+"_"+WFICCMD
Else
 FICCMD = "cmd"+num$(adxuid(1))+"_"+WFICCMD
Endif
Case OS_ORD(1)
 When "unix"
  EXT(1) = "sh"  : EXT(2) = "tra" : IRS_ORD = chr$(10)
 When "dos"
  EXT(1) = "BAT" : EXT(2) = "TRA" : IRS_ORD = chr$(13)+chr$(10)
Endcase

CHEMIN(1) = filpath(OS_ORD(3),FICCMD,EXT(1),"","",MACHINE)

Call MACHINE(CHEMIN(1),MAC(1),SCRIPT)
If OS_ORD(1)="dos" & !find(left$(SCRIPT,1),'"',"'")
 SCRIPT = '"'+SCRIPT+'"'
Endif


##  2-) Le fichier de commandes

If CMD
 Call MACHINE(ORDRE(0),MAC(0),FICHIER)
 If dim(ACTX)>0 & MAC(0) <> MACHINE
  Call GET_OS(ACTX,MAC(0),OS_CMD)
 Elsif MAC(0) <> MACHINE
  Call _AGET_OS(WOS,WOS2,WTMPDIR,MAC(0),OS_CMD)
 Else
  OS_CMD = OS_ORD(1)
 Endif
 # JP - Le fichier de commandes généré par des programmes
 # indifférents de l'O.S., a pour délimiteur de ligne LF (chr$(10))
 # Ce fichier est passé en entrée , il n'est pas
 # directement exécuté par l'interpréteur de commandes.
 Case OS_CMD
  When "unix"
   IRS_CMD = chr$(10)
  When "dos"
   IRS_CMD = chr$(10)
 Endcase
Endif

###########################################################################################################
##  mb 13.3.3
##  En cas de redirection, la trace de l'ordre système est écrit en ascii dans une trace intermédiaire
##  A la fin de l'ordre système, on recopie cette trace en UTF8 dans le bon fichier trace
###########################################################################################################

If REDIR=2
 CHEMIN(2) = filpath(OS_ORD(3),FICCMD,EXT(2),"","",MACHINE)
 ##  On vire la machine pour ne pas avoir d'emmerdes
 Call MACHINE(CHEMIN(2),MAC(2),TRACE)
 If dim(ACTX)>0 & MAC(2) <> MACHINE
  Call GET_OS(ACTX,MAC(2),OS_TRA)
 Elsif MAC(2) <> MACHINE
  Call _AGET_OS(WOS,WOS2,WTMPDIR,MAC(2),OS_TRA)
 Else
  OS_TRA = OS_ORD(1)
 Endif
 IRS_LEC = chr$(10)
 If dim(ACTX)>0
  Call GET_OS(ACTX,MACHINE,OS_TRA)
 Else
  Call _AGET_OS(WOS,WOS2,WTMPDIR,MACHINE,OS_TRA)
 Endif
 Case OS_TRA
  When "unix"
   IRS_TRA = chr$(10)
  When "dos"
   IRS_TRA = chr$(13)+chr$(10)
   If !find(left$(TRACE,1),'"',"'")
    TRACE = '"'+TRACE+'"'
   Endif
 Endcase
 Openo CHEMIN(2), 0 Using [AOUT]
 Openo Using [AOUT]
Endif

############################################
##  Confection d'un script intermédiaire  ##
##  pour l'exécution de l'ordre           ##
############################################

adxifs = ""
Openo CHEMIN(1), 0 Using [AOUT]
adxirs = IRS_ORD
Case OS_ORD(1)
 When "unix"
  Wrseq "trap 'exit 2' 2" Using [AOUT]
 When "dos"
  Wrseq "@ECHO OFF" Using [AOUT]
  Wrseq "BREAK OFF" Using [AOUT]
  Wrseq "chcp 1252 > nul" Using [AOUT] : # CCL 113224
  Case OS_ORD(2)
   When "w95", "dos"
    #If !CONV & !RES : Wrseq "CTTY NUL:" Using [AOUT] : Endif
  Endcase
Endcase

If !CMD
 COMMANDE = ORDRE(0) : Gosub LIGNE
Else
 Openi ORDRE(0) Using [AINP]
 adxirs = IRS_CMD : Rdseq COMMANDE Using [AINP]
 While fstat=0
  Gosub LIGNE
  adxirs = IRS_CMD : Rdseq COMMANDE Using [AINP]
 Wend
 Openi Using [AINP]
Endif

adxirs = IRS_ORD
Case OS_ORD(1)
 When "unix"
  If !CONV
   WCMDE = "."-SCRIPT-"2>/dev/null"
  Else
   WCMDE = "."-SCRIPT
  Endif
 When "dos"
  Case OS_ORD(2)
   When "w95", "dos"
    WCMDE = SCRIPT
    #If !CONV & !RES : Wrseq "CTTY CON:" Using [AOUT] : Endif
   When "NT"
    If !CONV
     WCMDE = SCRIPT-"2>NUL:"
    Else
     WCMDE = SCRIPT
    Endif
  Endcase
  Wrseq "BREAK ON" Using [AOUT]
Endcase
Openo Using [AOUT]

If REDIR=2 & ZERO
 Openo ORDRE(1), 0 Using [AOUT]
 Openo Using [AOUT]
Endif

#########################################
##  Sortie standard & sortie d'erreur  ##
##  à l'exécution                      ##
#########################################

Raz SORTIE

Case REDIR
 When 0
  Case OS_ORD(1)
   When "unix"
    SORTIE = ">/dev/null 2>&1"
   When "dos"
    Case OS_ORD(2)
     When "NT"
      SORTIE = ">NUL: 2>&1"
    Endcase
  Endcase
 When 2
  Case OS_ORD(1)
   When "unix"
    SORTIE = ">>"-TRACE-"2>&1"
   When "dos"
    Case OS_ORD(2)
     When "NT"
      SORTIE = ">>"-TRACE-"2>&1"
    Endcase
  Endcase
Endcase

#####################################
##  Enfin, on exécute l'ordre ...  ##
#####################################

If instr(1,OPT,"!!") : # Reparamétrage + sauvegarde
 System "!!"+MACHINE+"@"+WCMDE+SORTIE
Elsif instr(1,OPT,"!") : # Reparamétrage seulement
 System "!"+MACHINE+"@"+WCMDE+SORTIE
Elsif RES
 System RESULT = MACHINE+"@"+WCMDE+SORTIE
Elsif instr(1,OPT,"b") : # Pour les ordres backround sous dos (exemple serveur batch)
 System MACHINE+"@"+WCMDE+SORTIE
Else
 System COMMANDE = MACHINE+"@"+WCMDE+SORTIE
Endif

If !RES
 STAT = 0 : # stat1 rend n'importe quoi
Else
 STAT = stat1 : # Dans ce cas là, c'est bon
Endif

###################################
##  On fait le ménage en virant  ##
##  le script intermédiaire      ##
###################################

If !(dim(GTEST)>0 & GTEST)
 System COMMANDE = MACHINE+'@ae_rm'-SCRIPT
Endif

############################################
##  On réinjecte la trace de l'exécution  ##
##  dans le bon fichier de trace          ##
############################################

Local Integer WERR , ESSAI
ESSAI = 0

$REDIR
WERR = 0
ESSAI += 1
Onerrgo ERREUR
If REDIR=2
 adxifs = ""
 adxirs = IRS_LEC
 If ESSAI=2 : adxium = GASCII : Else : adxium = GUTF8 : Endif
 Openi CHEMIN(2), 0 Using [AINP]
 Openo ORDRE(1) Using [AOUT]
 Rdseq COMMANDE Using [AINP]
 If WERR & ESSAI=1 : Goto REDIR : Endif
 While fstat=0
  adxirs = IRS_TRA
  If ESSAI=2 : adxium = GUTF8 : Endif
  Wrseq COMMANDE Using [AOUT]
  adxirs = IRS_LEC
  If ESSAI=2 : adxium = GASCII : Endif
  Rdseq COMMANDE Using [AINP]
  If WERR & ESSAI=1 : Break : Endif
 Wend
 If WERR & ESSAI=1 : Goto REDIR : Endif
 If COMMANDE<>""
  adxirs = IRS_TRA
  If ESSAI=2 : adxium = GUTF8 : Endif
  Wrseq COMMANDE Using [AOUT]
 Endif
 Openo Using [AOUT]
 Openi Using [AINP]
 If !(dim(GTEST)>0 & GTEST)
  System COMMANDE = MACHINE+'@ae_rm'-TRACE
 Endif
Endif
Onerrgo

adxirs = SAVIRS
adxifs = SAVIFS
adxium = SAVIUM
End

#-------------------------#
$LIGNE
adxirs = IRS_ORD
If COMMANDE = ""
 Wrseq Using [AOUT]
Else
 Case REDIR
  When 0, 1
   Case OS_ORD(1)
    When "unix"
     Wrseq COMMANDE Using [AOUT]
    When "dos"
     Wrseq "CALL"-COMMANDE Using [AOUT]
   Endcase
  When 2
   Case OS_ORD(1)
    When "unix"
     Wrseq COMMANDE Using [AOUT]
    When "dos"
     Case OS_ORD(2)
      When "w95", "dos"
       BIN = vireblc(COMMANDE,3)
       ARG = right$(vireblc(COMMANDE,0),len(BIN)+1)
       If left$(BIN,3) = "ae_"
        Wrseq "CALL"-BIN - "-t" - TRACE - ARG Using [AOUT]
       Else
        Wrseq "CALL"-COMMANDE-">>"-TRACE Using [AOUT]
       Endif
      When "NT"
       Wrseq "CALL"-COMMANDE Using [AOUT]
     Endcase
   Endcase
 Endcase
Endif
Return

$ERREUR
WERR = errn
Resume

#---------------------------------------------------------------------------#
Subprog MACHINE(CHEMIN,MACHINE,FICHIER)
#---------------------------------------------------------------------------#
Value    Char CHEMIN()
Variable Char MACHINE()
Variable Char FICHIER()

Local Integer I

I=instr(1,CHEMIN,"@")

If I=0
 MACHINE = adxmac(0)
 FICHIER = CHEMIN
Else
 MACHINE = left$(CHEMIN,I-1)
 FICHIER = right$(CHEMIN,I+1)
Endif
End

#---------------------------------------------------------------------------#
Subprog _AGET_OS(WOS,WOS2,WTMPDIR,MACHINE,OS)
#---------------------------------------------------------------------------#
Value    Char WOS()()
Value    Char WOS2()()
Value    Char WTMPDIR()()
Value    Char MACHINE()
Variable Char OS()(1..)     : # 1: OS (dos/unix)
                            : # 2: Sous type OS (AIX/ULTRIX/..)
                            : # 3: Répertoire temporaire ($TMPDIR)

Goto OS_GET

#---------------------------------------------------------------------------#
Subprog GET_OS(ACTX,MACHINE,OS)
#---------------------------------------------------------------------------#
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char MACHINE()
Variable Char OS()(1..)     : # 1: OS (dos/unix)
                            : # 2: Sous type OS (AIX/ULTRIX/..)
                            : # 3: Répertoire temporaire ($TMPDIR)

$OS_GET

Local Integer I , ER
Local Char CHAINE(250) , PARAM(30) , REPDOS(GDIMFIC)

Raz OS , ER

# Histoire d'accepter les deux syntaxes (machine ou machine@)
If right$(MACHINE,len(MACHINE))="@"
 MACHINE = left$(MACHINE,len(MACHINE)-1)
Endif

## Machine où tourne adonix
If MACHINE=""
 If dim(ACTX)>0
  OS(1) = ACTX.ASOL.OS(1+0)
  If dim(OS)>1
   OS(2) = ACTX.ASOL.OS2(1+0)
   If dim(OS)>2
    OS(3) = ACTX.ASOL.TMPDIR(1+0)
   Endif
  Endif
 Else
  OS(1) = WOS(0)
  If dim(OS)>1
   OS(2) = WOS2(0)
   If dim(OS)>2
    OS(3) = WTMPDIR(0)
   Endif
  Endif
 Endif

## Machine locale (PC)
Elsif MACHINE="!" or MACHINE="#"
 REPDOS = "C:\TEMP"
 If GRELCLI>="15c.007"
  OS(1) = "dos"
  If dim(OS)>1
   OS(2) = "w95"
   If dim(OS)>2
    If !GBROWS
     Onerrgo ERRMAC
     For PARAM="X3TempDir","X3UserTempDir","X3UserDir"
      Call PARCLI(PARAM+";",CHAINE) From GLOBVAR
      If CHAINE<>""
       OS(3) = CHAINE : Break
      Endif
     Next PARAM
     Onerrgo
    Endif
    If ER or OS(3)=""
     OS(3) = REPDOS
    Endif
   Endif
  Endif
 Else
  Onerrgo ERRMAC
  System OS = "#@ae_os"
  Onerrgo
  OS(1) = "dos"
  If dim(OS)>1
   OS(2) = "w95"
   If dim(OS)>2
    If ER
     OS(3) = REPDOS
    Elsif OS(3)="" or filinfo(filpath(OS(3),"","","","","#"),0)<0
     Call PARCLI("ClientRootDir",CHAINE) From GLOBVAR
     If filinfo(filpath(CHAINE+"Temp","","","","","#"),0)>0
      OS(3) = filpath(CHAINE+"Temp","","") : # Répertoire d'installation du client X3
     Else
      OS(3) = REPDOS
     Endif
    Endif
   Endif
  Endif
 Endif

## Autres machines
Else
 I = find(MACHINE,adxmac(0),adxmac(1),adxmac(2))
 If I
  If dim(ACTX)>0
   OS(1) = ACTX.ASOL.OS(1+I)
   If dim(OS)>1
    OS(2) = ACTX.ASOL.OS2(1+I)
    If dim(OS)>2
     OS(3) = ACTX.ASOL.TMPDIR(1+I)
    Endif
   Endif
  Else
   OS(1) = WOS(I)
   If dim(OS)>1
    OS(2) = WOS2(I)
    If dim(OS)>2
     OS(3) = WTMPDIR(I)
    Endif
   Endif
  Endif
 Else
  ER = 0
  Onerrgo ERRMAC
  System OS = MACHINE+"@ae_os"
  Onerrgo
  If ER
   Raz OS
  Elsif dim(OS)>2 & OS(3)=""
#   Case OS(1)
#    When "unix"
#     OS(3) = "/tmp"
#    When "dos"
#     OS(3) = "C:\TEMP"
#   Endcase
   OS(3) = filpath("!tmp","","","","",MACHINE)
   OS(3) = right$(OS(3),instr(0,OS(3),"@")+1)
  Endif
 Endif
Endif
End

#----------------#
$ERRMAC
ER=1
Resume


#---------------------------------------------------------------------------#
Subprog _EFFACE(FICHIER,STAT)
#---------------------------------------------------------------------------#
Value Char       FICHIER()
Variable Integer STAT

Local Char MAC1(GDIMFIC), FIC1(GDIMFIC)

Call MACHINE(FICHIER,MAC1,FIC1)

# Optimisations du delete en version >=16r214     CC - 14/06/2011

If MAC1<>"#"  & instr(1,FIC1,"*")<=0
 STAT = Delfile(FICHIER)
Else
 Call _ASYSTEME(MAC1,'ae_rm'-'"'+FIC1+'"',"",STAT) From ASYRSYS
Endif
End

#############################################
# Invalidation de l'adx d'une structure
#############################################
Subprog _INVALID_STC(MAC,DOS,TRT,STAT)
Value Char MAC , DOS , TRT
Variable Integer STAT
Local Char  REP(3) , CODTRT(GLONADC) , OPT(1)
REP = "STC"
OPT = "o"
#CODTRT = "_"+TRT
CODTRT = TRT
Goto INVALID_TRT

#---------------------------------------------------------------------------#
# Effacement de l'adx d'une structure
#---------------------------------------------------------------------------#
Subprog _EFFACE_STC(MAC,DOS,TRT,STAT)
Value Char MAC , DOS , TRT
Variable Integer STAT
Local Char  REP(3) , CODTRT(GLONADC) , OPT(1)
REP = "STC"
OPT = "o"
#CODTRT = "_"+TRT
CODTRT = TRT
Goto EFFACE_TRT

#---------------------------------------------------------------------------#
# Effacement de l'adx d'un traitement
#---------------------------------------------------------------------------#
Subprog _EFFACE_ADX(MAC,DOS,TRT,STAT)
Value Char MAC , DOS , TRT
Variable Integer STAT
Local Char  REP(3) , CODTRT(GLONADC) , OPT(1)
REP = "TRT"
OPT = "t"
CODTRT = TRT

$EFFACE_TRT
Local Char    WCMDE(250) , FIC(GDIMFIC)
If TRT="" : STAT = 1 : End : Endif
If DOS=""
 WCMDE = 'archive -d'-nomap-'-'+OPT-'-e'-'"'+CODTRT+'"'
Else
 WCMDE = 'archive -d'-DOS-'-'+OPT-'-e'-'"'+CODTRT+'"'
Endif
If MAC=""
 Call _ASYSTEME(adxmac(0),WCMDE,"",STAT)
Else
 Call _ASYSTEME(MAC,WCMDE,"",STAT)
Endif
$INVALID_TRT
If DOS=nomap or DOS="": # temporaire et pourri
# adxmpr = adxmpr
#90822
#STAT = pushScript(MAC,DOS,CODTRT)
STAT = pullScript(MAC,DOS,CODTRT)
Endif
If DOS="" & MAC=""
 FIC = filpath(REP,TRT,"adx",nomap)
Elsif MAC=""
 FIC = filpath(REP,TRT,"adx",DOS)
Else
 FIC = filpath(REP,TRT,"adx",DOS,"",MAC)
Endif
Call _EFFACE(FIC,STAT)
End

#---------------------------------------------------------------------------#
# Existence de l'adx d'une structure
#---------------------------------------------------------------------------#
Subprog EXISTE_STC(MAC,DOS,TRT,OK)
Value Char MAC , DOS , TRT
Variable Integer OK
If TRT=""
 OK = 0
Else
 OK = objectExist(MAC,DOS,TRT)
Endif
End

#---------------------------------------------------------------------------#
# Existence de l'adx d'un traitement
#---------------------------------------------------------------------------#
Subprog EXISTE_ADX(MAC,DOS,TRT,OK)
Value Char MAC , DOS , TRT
Variable Integer OK
Local Shortint K
If TRT=""
 OK = 0
Else
 OK = filexist(MAC,DOS,TRT)
Endif
End

#---------------------------------------------------------------------------#
# Existence de l'adx d'un traitement
#---------------------------------------------------------------------------#
Funprog CHECK_SCRIPT(_ACTX,_SCRIPT)
Variable Instance _ACTX Using OBJECT
Value Char _SCRIPT

Local Integer ERROR : ERROR=[V]CST_AOK
If len(_SCRIPT) & ! filexist("","",_SCRIPT)
 ERROR = func ASYRSUB._ASETSTATUS(_ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(4,149,1),_SCRIPT))
Endif
End ERROR

#---------------------------------------------------------------------------#
Subprog _COPIE(FICHIER1,FICHIER2,STAT)
#---------------------------------------------------------------------------#
Value Char       FICHIER1()
Value Char       FICHIER2()
Variable Integer STAT
Gosub TRT_COPY
End

#--------------#
$TRT_COPY
Local Char MAC1(GDIMFIC), MAC2(GDIMFIC)
Local Char FIC1(GDIMFIC), FIC2(GDIMFIC)
Local Char COMMANDE(30) , FICASK(GDIMFIC) , MESSAGE(250)
Local Char RETOUR(250) , REP2(250) , NAM(250)
Local Integer I , OK , ASTATUS

If FICHIER1="" | FICHIER2=""
 STAT = 1
 MESSAGE = mess(48,149,1) : # Le nom du fichier n'est pas défini
 Return
Endif

Call IDENTIQUE(FICHIER1,FICHIER2,STAT)
If STAT
 MESSAGE = mess(125,141,1) : # Les noms des fichiers doivent être différents
 Return
Endif

Call MACHINE(FICHIER1,MAC1,FIC1)
Call MACHINE(FICHIER2,MAC2,FIC2)

If MAC1<>"#" & MAC2<>"#"
 If MAC1=MAC2
  If filinfo(FICHIER1,0)<0
   STAT = 1
   MESSAGE = mess(101,100,1)-FIC1 : # Fichier inexistant
  Else
   #101513 : delete file before copy
   If filinfo(FICHIER2,0)>=0
    Call _EFFACE(FICHIER2,STAT) : STAT=0
   Endif
   Call _ASYSTEME(MAC1,'ae_cp'-'"'+FIC1+'" "'+FIC2+'"','',STAT)
   #101513 : check file copy
   If STAT | filinfo(FICHIER2,0)<0 : STAT = 2
    MESSAGE = mess(33,143,1)-":"-mess(159,141,1)-FIC2 : # Erreur pendant la copie du fichier
   Endif
  Endif
 Else
  STAT = 0 : Gosub COPIEFIC
 Endif
Endif
Return

#---------------------------------------------------------------------------#
Subprog IDENTIQUE(FICHIER1,FICHIER2,STAT)
#---------------------------------------------------------------------------#
Value    Char FICHIER1()
Value    Char FICHIER2()
Variable Integer STAT
Local Char MAC1(GDIMFIC), MAC2(GDIMFIC)
Local Char FIC1(GDIMFIC), FIC2(GDIMFIC)

Call MACHINE(FICHIER1,MAC1,FIC1)
Call MACHINE(FICHIER2,MAC2,FIC2)

##  WIN JP / PP
##  Pour l'instant test sur le numéro d'inode
##  pour savoir si deux chemins pointent
##  sur un seul et même fichier existant

If MAC1="#" or MAC2="#" : STAT = 0 : End : Endif

Local Integer INODE1, INODE2
INODE1 = filinfo(FICHIER1,1)
INODE2 = filinfo(FICHIER2,1)

#109519
#If INODE1>0 & INODE2>0 & INODE1=INODE2
If MAC1=MAC2 & INODE1>0 & INODE2>0 & INODE1=INODE2
 STAT = 1
Else
 STAT = 0
Endif
End

#---------------------------------------------------------------------------#
# Copie hors web
#---------------------------------------------------------------------------#
$COPIEFIC
Local Integer NB , COMPTE,WERR
NB = 5000
Local Libelle BUFFER(1..NB)

COMPTE = filinfo(FICHIER1,7)
If dim(VIDE)>0
 If COMPTE<0
  STAT = 1
  MESSAGE = mess(101,100,1) : # Fichier inexistant
  Return
 Endif
Else
 If COMPTE<=0
  STAT = 1
  MESSAGE = mess(101,100,1) : # Fichier inexistant
  Return
 Endif
Endif

Onerrgo ERREUR
Openi FICHIER1 Using [AINP]
Openo FICHIER2 , 0 Using [AOUT]
Onerrgo
If WERR
 STAT = 2
 MESSAGE = mess(12,100,1) : # Erreur d'accès sur le fichier
 Return
Endif

Getseq NB , BUFFER Using [AINP]
While fstat=0
 COMPTE -= NB
 Putseq NB , BUFFER Using [AOUT]
 Getseq NB , BUFFER Using [AINP]
Wend

If COMPTE>0 or dim(VIDE)>0
 Putseq COMPTE , BUFFER Using [AOUT]
Endif

Openi Using [AINP]
Openo Using [AOUT]
Return

#---------------------------------------------------------------------------#
Subprog _MOVE(FICHIER1,FICHIER2,STAT)
#---------------------------------------------------------------------------#
Value Char       FICHIER1()
Value Char       FICHIER2()
Variable Integer STAT
Gosub TRT_MOVE
End

#-----------------#
$TRT_MOVE
Local Char MESSAGE(250)

Call IDENTIQUE(FICHIER1,FICHIER2,STAT)
If STAT
 MESSAGE = mess(125,141,1) : # Les noms des fichiers doivent être différents
 Return
Endif

Local Char MAC1(GDIMFIC), MAC2(GDIMFIC)
Local Char FIC1(GDIMFIC), FIC2(GDIMFIC)

Call MACHINE(FICHIER1,MAC1,FIC1)
Call MACHINE(FICHIER2,MAC2,FIC2)

If (MAC1="#" or MAC2="#") and (GSERVEUR or (GBROWS & !GADXLOC))
 STAT = 2
 MESSAGE = mess(199,100,1) : # Machine inaccessible
Else
 If MAC1=MAC2
  #101513 : check file before copy
  If filinfo(FICHIER1,0)<0 : STAT = 1
   MESSAGE=mess(159,141,1)-FIC1
   End
  Endif
  #101513 : delete file before copy
  If filinfo(FICHIER2,0)>=0
   Call _EFFACE(FICHIER2,STAT) : STAT=0
  Endif
  Call _ASYSTEME(MAC1,'ae_mv'-'"'+FIC1+'" "'+FIC2+'"',"",STAT) From ASYRSYS
  #101513 : check file after copy
  If STAT | filinfo(FICHIER2,0)<0 : STAT = 2
   MESSAGE=mess(33,143,1)-":"-mess(159,141,1)-FIC2 : # Erreur pendant la copie du fichier
  Endif
 Else
  STAT = 0
  Gosub COPIEFIC
  If !STAT
   Call _EFFACE(FICHIER1,STAT)
   If STAT
    MESSAGE = func AFNC.MES1(mess(50,149,1),FICHIER1) : # Le fichier $1$ n'a pas pu être supprimé
   Endif
  Endif
 Endif
Endif
Return

#---------------------------------------------------------------------------#
Subprog EXIST(FILE_NAME,EXIST)
#---------------------------------------------------------------------------#
Value    Char    FILE_NAME
Variable Integer EXIST

Local Char    MAC1(GDIMFIC) , FIC1(GDIMFIC)
Local Integer ER , INFO

Call MACHINE(FILE_NAME,MAC1,FIC1)

If MAC1="#"
 EXIST = 0 : End
Endif

INFO = filinfo(FILE_NAME,0)

If INFO<0
 EXIST = 0 : # This file not exist
Elsif find(int(mod(INFO/2^12,16)),0,8)=0
 EXIST = 2 : # This is a folder
Else
 EXIST = 1 : # This is a file (not a folder)
Endif
End

#---------------------------------------------------------------------------#
Funprog MOVEFILE(FILE_OLD,FILE_NEW,MESSAGE)
#---------------------------------------------------------------------------#
Value Char       FILE_OLD()
Value Char       FILE_NEW()
Variable Char    MESSAGE
Local Integer STAT , ARETURN
Local Char    FICHIER1(250) , FICHIER2(250)
FICHIER1 = func _GETFULLPATH(FILE_OLD)
FICHIER2 = func _GETFULLPATH(FILE_NEW)
Gosub TRT_MOVE
ARETURN = (STAT=0)
End ARETURN

#---------------------------------------------------------------------------#
Funprog COPYFILE(FILE_ORI,FILE_DEST,MESSAGE)
#---------------------------------------------------------------------------#
Value Char       FILE_ORI()
Value Char       FILE_DEST()
Variable Char    MESSAGE
Local Integer STAT , ARETURN
Local Char    FICHIER1(250) , FICHIER2(250)
FICHIER1 = func _GETFULLPATH(FILE_ORI)
FICHIER2 = func _GETFULLPATH(FILE_DEST)
Gosub TRT_COPY
ARETURN = (STAT=0)
End ARETURN

#---------------------------------------------------------------------------#
Funprog DELETEFILE(FILE_DEL,MESSAGE)
#---------------------------------------------------------------------------#
Value Char       FILE_DEL()
Variable Char    MESSAGE
Local Integer STAT , ARETURN
Local Char    FICHIER(250)
FICHIER = func _GETFULLPATH(FILE_DEL)
If FICHIER=""
 STAT = 1
 MESSAGE = mess(48,149,1) : # Le nom du fichier n'est pas défini
Else
 Call _EFFACE(FICHIER,STAT)
 If STAT
  MESSAGE = func AFNC.MES1(mess(50,149,1),FILE_DEL) : # Le fichier $1$ n'a pas pu être supprimé
 Endif
Endif
ARETURN = (STAT=0)
End ARETURN

#---------------------------------------------------------------------------#
Funprog _GETFULLPATH(FILEWITHSPACE)
#---------------------------------------------------------------------------#
Value Char FILEWITHSPACE
Local Char SPACESTORAGE(30) , DIRECTORY(250) , FILEPATH(255) , FULLNAME(255)
Local Char APPLI(50) , MACHINE(255) , REP(1)
Local Integer I , J
I = instr(1,FILEWITHSPACE,"[")
J = instr(I,FILEWITHSPACE,"]")
If I & J
 SPACESTORAGE = seg$(FILEWITHSPACE,I+1,J-1)
 FULLNAME = right$(FILEWITHSPACE,J+1)
 Local File AVOLUME [AVL]
 Read [AVL]CODE=SPACESTORAGE
 If !fstat
  [L]FILEPATH  = filpath([F:AVL]ROOT,"","","")
  If find(right$([L]FILEPATH,len([L]FILEPATH)),"/","\")
   [L]FILEPATH = left$([L]FILEPATH,len([L]FILEPATH)-1)
  Endif
  If instr(1,[L]FILEPATH,"\")
   REP = "\"
  Else
   REP = "/"
  Endif
  If find(right$([L]FULLNAME,len([L]FULLNAME)),"/","\")
   [L]FULLNAME = left$([L]FULLNAME,len([L]FULLNAME)-1)
  Endif
  If find(left$([L]FULLNAME,1),"/","\")
   [L]FULLNAME = right$([L]FULLNAME,2)
  Endif
  [L]FILEPATH = [L]FILEPATH+REP+[L]FULLNAME
  If REP="\"
   [L]FILEPATH = ctrans([L]FILEPATH,"/",REP)
  Else
   [L]FILEPATH = ctrans([L]FILEPATH,"\",REP)
  Endif
 Endif
Else
 FILEPATH = FILEWITHSPACE
Endif
End FILEPATH

#**
#* Create a directory if it doesn't exist
#*
#* @param PATH = Path of the new directory. For example : filpath("directory_name","","",APPLI)
#*!
Funprog CREATE_DIRECTORY(PATH)
Value Char PATH

Local Char    ORDSYS(250) , MACHINE(GDIMFIC) , REPERT(GDIMFIC) , COMMAND(250)

If filinfo(PATH,0)<0
    Call MACHINE(PATH,MACHINE,REPERT) From ASYRSYS
    If MACHINE<>""
     ORDSYS = MACHINE+"@"
    Else
     ORDSYS = ""
    Endif
    ORDSYS += 'ae_mkdir'-'"'+REPERT+'"'
    System COMMAND=ORDSYS
    If filinfo(PATH,0)<0
        End [V]CST_AERROR
    Endif
Endif

End [V]CST_AOK

#**
#* Remove a directory
#*
#* @param PATH = Path of the directory to remove. For example : filpath("directory_name","","",APPLI)
#*!
Funprog REMOVE_DIRECTORY(PATH)
Value Char PATH

Local Char    ORDSYS(250) , MACHINE(GDIMFIC) , REPERT(GDIMFIC) , COMMAND(250)

If filinfo(PATH,0)>0
    Call MACHINE(PATH,MACHINE,REPERT) From ASYRSYS
    If MACHINE<>""
     ORDSYS = MACHINE+"@"
    Else
     ORDSYS = ""
    Endif
    ORDSYS += 'ae_rmdir'-'"'+REPERT+'"'
    System COMMAND=ORDSYS
    If filinfo(PATH,0)>0
        End [V]CST_AERROR
    Endif
Endif

End [V]CST_AOK

