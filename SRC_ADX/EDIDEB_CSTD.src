#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe EDIDEB


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"            : Gosub AREAD_AFTER
        When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER
        When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER
        When "ADELETE_CONTROL_AFTER"  : Gosub ADELETE_CONTROL_AFTER
      Endcase
  Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "CPY"
      Case [L]ARULE
        When 'PROPAGATE'  : Gosub CPY_PROPAGATE
      Endcase
    When "DEBYEAR"
      Case [L]ARULE
        When "INIT"       : Gosub DEBYEAR_INIT
        When 'CONTROL'    : Gosub DEBYEAR_CONTROL
      Endcase
    When "DEBMONTH"
      Case [L]ARULE
        When "INIT"       : Gosub DEBMONTH_INIT
      Endcase
  Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_LOAD_CPY_INFO"  : Gosub MET_LOAD_CPY_INFO
  Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
Endcase
Return

##############################################################################

$CPY_PROPAGATE
  Local Integer WOK
  WOK = fmet this.MET_LOAD_CPY_INFO()
  ASTATUS = WOK
Return

##############################################################################

$DEBYEAR_INIT
  this.DEBYEAR = val(format$("D:4Y",date$))
Return

$DEBYEAR_CONTROL
  If this.DEBYEAR < 2018
    #err
  Endif
Return

##############################################################################

$DEBMONTH_INIT
  this.DEBMONTH = month(date$)
Return

##############################################################################

$AREAD_AFTER
Return

##############################################################################

$AUPDATE_CONTROL_AFTER
  this.DEBDATTIM = datetime$
Return

##############################################################################

$AINSERT_CONTROL_AFTER
  Local Integer WOK
  this.DEBDATTIM = datetime$

  Local Char WERR(250)
  Local Integer I, WNBLIG
  For I = 1 To maxtab(this.EDEBD)
    If this.EDEBD(I)<>null and this.EDEBD(I).ASTALIN <> [V]CST_ADEL and this.EDEBD(I).ASTALIN <> [V]CST_ANEWDEL
      WNBLIG = WNBLIG + 1
    Endif
  Next
  If WNBLIG = 0
#    WERR = "Création impossible, aucun échange à déclarer"
    WERR = mess(218,2006,1)
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
    ARET_VALUE = [V]CST_AERROR
  Else
    ARET_VALUE = [V]CST_AOK
  Endif
  ASTATUS = ARET_VALUE
Return

##############################################################################

$ADELETE_CONTROL_AFTER
  Local Char WERR(250)
  Local Char WDOCID(250)
  WDOCID = this.CPY+"!"+num$(this.DEBYEAR)+"!"+num$(this.DEBMONTH)
  If func CNSEDKSTD.GET_EDI_CATACT(WDOCID, 6) <> 0
#    WERR = "Suppression impossible, document déjà généré"
    WERR = mess(219,2006,1)
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
    ARET_VALUE = [V]CST_AERROR
  Else
    ARET_VALUE = [V]CST_AOK
  Endif
  ASTATUS = ARET_VALUE
Return

##############################################################################

$MET_LOAD_CPY_INFO
  Local Integer WOK : WOK = [V]CST_AOK
  Local Integer WI  : WI  = 0


  If this.CPY <> ""
    #Query
    Local File COMPANY [CPY]
    Read [CPY]CPY0 = this.CPY
    If fstat = [V]CST_AOK
      this.CRN      = [CPY]CRN
      this.CRY      = [CPY]CRY
      this.EECNUM   = [CPY]EECNUM
      this.MAIFCY   = [CPY]MAIFCY
      Local File FACILITY [FCY]
      If this.MAIFCY <> ""
        Read [FCY]FCY0 = this.MAIFCY
        If fstat = [V]CST_AOK
          this.CRT = [FCY]CRN
        Endif
      Endif
      Call DELETELINES(this,"PARTY") From EDILIBA
      WI = fmet this.ADDLINE("PARTY",[V]CST_ALASTPOS)
      this.PARTY(WI).PARTYTYP = "PSI"
      this.PARTY(WI).PARTYROL = "PSI" #"sender"
      this.PARTY(WI).PARTYID  = left$([CPY]EECNUM,4) + [FCY]CRN
      this.PARTY(WI).PARTYNAM = [CPY]CPYNAM
      LogicClose File [FCY]

      Local File EDICPYPAR [ECP]
      Local File EDIPARTNERD [EPRD]
      Link [EPRD] With [ECP]ECP0 = [CPY]CPY;[EPRD]PARCOD As [WOO]
&     Where [EPRD]CATACT = 1
&     and [EPRD]CATOPE = 2
&     and [EPRD]CATTYP = 6
      For [WOO]
        Read [ECP]ECP0 = [CPY]CPY;[WOO]PARCOD
        If fstat = [V]CST_AOK
          this.ENVID = [ECP]EXCEDICOD
        Else
          #
        Endif
        Break
      Next
      LogicClose File [EPRD]
      LogicClose File [ECP]

    Else
      WOK = [V]CST_AERROR
    Endif
    LogicClose File [CPY]
  Else
    WOK = [V]CST_AERROR
  Endif
  ARET_VALUE = WOK
Return

