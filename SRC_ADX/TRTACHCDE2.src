#<AdxTL>@(#)1.0.0.0 $Revision$
###########################################################################
# TRTACHCDE2          Traitements liés aux commandes         Module ACHAT #
# ----------------------------------------------------------------------- #
# Gosub                                                    MBT 17/03/2008 #
#   - GENERE_POH  : Génération des commandes d'achat à partir de [M:POI1] #
###########################################################################


$ACTION
If GPOH_WERR  mkstat=1 : Return : Endif : # Si déjà une erreur , c'est fini !
Case ACTION
  When "IMP_ZONE"  : Gosub MSK_ENTETE
  When "IMP_TAB"   : Gosub MSK_DETAIL
Endcase
Return


################################################################################
# GENERE_POH : S/P de génération des commandes d'achat                         #
# ---------------------------------------------------------------------------- #
#   WTRT    : Nom du traitement à exécuter pour le chargement des champs       #
#   WTRA    : Fichier trace (0-1=Non, 2=Oui, 3=Détaillée, 4=Hyper Détaillée)   #
#   WERR    : Code retour (0=Ok,  1-99=Erreur avec GMESSAGE)                   #
################################################################################
$GENERE_POH
#----- Variables locales -----#
Local  Char     WTRT(GLONADC)        : WTRT="TRTACHCDE2"
Local  Integer  WTRA                 : WTRA=2 : # Trace simple !
Local  Integer  WERR                 : WERR=0
Local  Char     SAV_GGRPFCY(GLONFCY) : SAV_GGRPFCY=GGRPFCY
Local  Char     SAV_GABREV(5)        : SAV_GABREV =GABREV
Local  Char     SAV_GPTRNUM(GLONTRS) : SAV_GPTRNUM=GPTRNUM
Local  Integer  SAV_GIMPORT          : SAV_GIMPORT=GIMPORT
Local  Char     SAV_GCLE(50)         : SAV_GCLE   =GCLE
Local  Integer  SAV_NOLIGN           : SAV_NOLIGN =nolign
Local  Integer  SAV_NBLIG
Local  Integer  OK                   : OK=1
Local  Integer  I
Local  Integer  NOL1, NOL2
Local  Char     WZON(GLONAVA)
Local  Char     ACTION(30)
Local  Char     WPGM(GLONADC)
Local  Char     WMESSAGE(100)
Local  Libelle  WADXLOG
#-----
Global Integer  GPOH_WTRA      : GPOH_WTRA=WTRA
Global Integer  GPOH_WERR      : GPOH_WERR=WERR
# Issue 120855 - 2017-01-13 by SR : dissocier import réel de import simulé
Global Integer  GIMPSIM        : GIMPSIM = 2
# Issue X3-111565 - 2018-10-09 by SR :
Global  Char    GPOI_VCRNUM
Global  Integer GPOI_VCRLIN
Global  Integer GPOI_VCRSEQ
Global  Integer GPOI_VCRTYP
#-----
If !adxlog  WADXLOG=0  Else  WADXLOG=1 : Endif
If WADXLOG=0
  Call DEBTRANS From GLOCK
Endif
#----- Ouverture masques écrans si nécessaire -----#
If !clalev([M:POH0])  Local Mask "POH0"       [POH0] : Endif
If !clalev([M:POH1])  Local Mask "POH1"       [POH1] : Endif
If !clalev([M:POH2])  Local Mask "POH2"       [POH2] : Endif
If !clalev([M:POH3])  Local Mask "POH3"       [POH3] : Endif
#-----
Raz [M:POH0], [M:POH1], [M:POH2], [M:POH3]
#----- Définition des variables de l'objet -----#
Raz GPTRNUM, GCLE, GGRPFCY
GIMPORT=1
Local Char ABREV(5)
ABREV ="POH"
GABREV="POH"
ACTION="DEFVAR" : WPGM="GOBJET"  : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub DEFVAR  From GOBJET
WINPROG="WGOPOH"
# Issue X3-83983 - 2018-05-07 by MUARN : section par défaut, on peut avoir besoin des autres masque POHX
Gosub DEFVAR From WGOPOH
# sr 02.12 Demande 80297
# Issue 81372 - 2012-05-04 by SR
Call ISWINDOWOK (nomap,"OPOH") From INTRUTILB
ACTION="OUVRE"  : WPGM="WOPOH"   : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub OUVRE   From WOPOH
OK=1
ACTION="OUVRE"  : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
If !OK  WERR=1 : Goto FIN_GENERE_POH : Endif
#-----
Raz WORDFCY, WCUR, WBPSNUM, WLINBUY, WSEVLIN, GFCY, WBPCADD, WSOHNUM, WFMI
Raz WSOHCAT, WPRHFCY, WSTOFCY, WSALFCY, WGRPDEB
# Issue 71069 - 2013-08-23 by SR : PJT
Raz WPJT
#-----
For NOL1=0 To [M:POI1]NBLIG-1
  If [M:POI1]SOHNUM(NOL1)<>""
    Read [SOQ] SOQ0=[M:POI1]SOHNUM(NOL1);[M:POI1]SOPLIN(NOL1);[M:POI1]SOQSEQ(NOL1)
    If fstat  Raz [F:SOQ] : Endif
    WFMI2=[F:SOQ]FMI : WBPCADD2=[F:SOQ]BPCORD+[F:SOQ]BPAADD
  Else
    WFMI2=0 : WBPCADD2=""
  Endif
   #-----
  If [M:POI1]SALFCY(NOL1)<>""
    If [M:POI1]SALFCY(NOL1)<>WSALFCY
      Call PARAM([M:POI1]SALFCY(NOL1),"LINBPD",GBIDC3) From ADOVAL
      GLINBPD=val(GBIDC3)
    Endif
  Else
    GLINBPD=2
  Endif
  # Issue 71069 - 2016-06-14 by SR : US 65  éventuellement Paramètre perdu par RAZCRE de DEB_GENPOH
  GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC([M:POI1]POHFCY)
  #-----
  # Issue 71069 - 2013-08-23 by SR : PJT
  nolign=NOL1+1 : # Pour critère rupture spcécial
  # Issue 114588 - 2016-02-16 by MUARN : NBLIG+2>MAXLIGNE au lieu NBLIG-2>MAXLIGNE
  If [M:POI1]ORDFCY(NOL1)   <>WORDFCY                                                    |
&    [M:POI1]CUR   (NOL1)   <>WCUR                                                       |
&    [M:POI1]BPSNUM(NOL1)   <>WBPSNUM                                                    |
&   ([M:POI1]LINBUY(NOL1)   <>WLINBUY  & GBUYFLT=2)                                      |
&   ([M:POI1]SOHNUM(NOL1)   <>WSOHNUM  & WSOHFLG=0)                                      |
&    [M:POI1]SOHCAT(NOL1)   <>WSOHCAT                                                    |
&   ([M:POI1]PJT(NOL1)      <>WPJT     & GPJTSNGDOC=G_OUI)                               |
&  (([M:POI1]PRHFCY(NOL1)   <>WPRHFCY) & ([M:POI1]DME(NOL1)=3 | GLINBPD<>2 | WRCPFLG=0)) |
&   ([M:POI1]LINSTOFCY(NOL1)<>WSTOFCY  &  [M:POI1]DME(NOL1)=3)                           |
&   (WSEVLIN=1 & [M:POI1]LINTYP(NOL1)<3) | [M:POH2]NBLIG+2>MAXLIGNE                      |
&   (WFMI2=2 & WBPCADD2<>WBPCADD & WFMIFLG=0)                                            |
&   (WFMI2<>WFMI & WFMIFLG=0) | evalue(WNAMCRITSPE)<>WVALCRITSPE
    If WORDFCY=""
      Gosub DEB_GENPOH
    Else
      Gosub TRT_GENPOH
      If SYMBOLE2<>""  Unlock=SYMBOLE2 : Endif
      If (GOK<1 | WERR>0) & CHOIX=4 : Break : Endif
      Gosub DEB_GENPOH
    Endif
  Endif
  #----- Vérification du code acheteur -----#
  If GBUYFLT=2 & [M:POI1]LINBUY(NOL1)=""
    If WTRA>1
      WMSG=GFCY+"/"+[M:POI1]ITMREF(NOL1)-mess(166,197,1)
      Call ECR_TRACE (WMSG,1) : # Code acheteur non renseigné
    Endif
    Goto SUITPOI1
  Endif
  #----- Contrôle sur commande de vente si contremarque -----#
  If [M:POI1]SOHNUM(NOL1)<>""
    #----- Relecture ligne commande de vente si nécessaire car peut être écrasée -----#
    If [F:SOQ]SOHNUM<>[M:POI1]SOHNUM(NOL1) |
&      [F:SOQ]SOPLIN<>[M:POI1]SOPLIN(NOL1) |
&      [F:SOQ]SOQSEQ<>[M:POI1]SOQSEQ(NOL1)
      Read [SOQ] SOQ0=[M:POI1]SOHNUM(NOL1);[M:POI1]SOPLIN(NOL1);[M:POI1]SOQSEQ(NOL1)
      If fstat  Raz [F:SOQ] : Endif
    Endif
    #----- Si entête commande vente bloquée logiquement --> Abandon -----#
    If SYMBOLE2<>""  Unlock=SYMBOLE2 : Endif
    SYMBOLE2="SOH"+[M:POI1]SOHNUM(NOL1)
    Lock=SYMBOLE2
    If fstat
      If WTRA>1
        WMSG =[M:POI1]SOHNUM(NOL1)+"/"+num$([M:POI1]SOPLIN(NOL1))+"/"
        WMSG+=num$([M:POI1]SOQSEQ(NOL1))-mess(67,197,1)-mess(10,100,1)
        Call ECR_TRACE (WMSG,1) : # Modif en cours sur un autre poste
      Endif
      Goto SUITPOI1
    Endif
    #----- Si contremarque déjà générée --> Abandon -----#
    If [F:SOQ]FMINUM<>""
      If WTRA>1
        WMSG =[M:POI1]SOHNUM(NOL1)+"/"+num$([M:POI1]SOPLIN(NOL1))+"/"
        WMSG+=num$([M:POI1]SOQSEQ(NOL1))-mess(67,197,1)-mess(73,197,1)
        Call ECR_TRACE (WMSG,1) : # Ligne absente ou déja transférée
      Endif
      Goto SUITPOI1
    Endif
  Endif
  #----------------------------------------------------------#
  # Point d'entrée GENCDESEL pour accepter la ligne courante #
  # -------------------------------------------------------- #
  # La variable OK permet d'accepter ou de refuser la ligne  #
  #     0 = la ligne est refusée, on passe à la suivante     #
  #     1 = la ligne de commande est acceptée                #
  #----------------------------------------------------------#
  nolign=NOL1+1 : # Pour compatibilité avec versions précédentes !
  OK=1
  Gosub POINT_GENCDESEL From TRTACHCDE1
  If OK=1
    [M:POH2]POHLIN([M:POH2]NBLIG)=NOL1
    [M:POH2]NBLIG+=1
  Else
    #VPO 25/03/11 72592 reinit OK sinon  provoque arret groupe de tache
    OK=1
  Endif
$SUITPOI1
Next NOL1
Gosub TRT_GENPOH
If SYMBOLE2<>""  Unlock=SYMBOLE2 : Endif
#-----
$FIN_GENERE_POH
# FQ 73645 Plan de travail: Fin de la transaction ?
If clalev([M:PMG]) : Gosub FINTRS_POH : Endif : # C'est terminé si l'on vient des plans de travail
ACTION="FERME"  : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
GIMPORT=0
#-----
Kill GPOH_WTRA, GPOH_WERR
# Issue 120855 - 2017-01-13 by SR : dissocier import réel de import simulé
Kill GIMPSIM
# Issue X3-111565- 2018-10-09 by SR : clé ligne commande de vente
Kill GPOI_VCRNUM,GPOI_VCRLIN,GPOI_VCRSEQ,GPOI_VCRTYP
GGRPFCY=SAV_GGRPFCY
GABREV =SAV_GABREV
GPTRNUM=SAV_GPTRNUM
GIMPORT=SAV_GIMPORT
GCLE   =SAV_GCLE
nolign =SAV_NOLIGN
Return


#---------------------------#
# Ecriture du fichier trace #
#---------------------------#
Subprog ECR_TRACE (WMSG,TRAIT)
Value Char    WMSG
Value Integer TRAIT
If GTRACE<>""
  Call ECR_TRACE(WMSG,TRAIT) From GESECRAN
  If GPURTRACE=1  GPURTRACE=2 : Endif
Endif
End


#-----------------#
# Trace détaillée #
#-----------------#
$TRACE_DETAILLEE
If WPGM=""
  If ACTION="Write [POH]"
    WMESSAGE=ACTION
  Else
    WMESSAGE="---"-mess(5,126,1)-ACTION
  Endif
Else
  WMESSAGE=mess(27,115,1)-ACTION+space$(20-len(ACTION))+"From "-WPGM
Endif
Call ECR_TRACE(WMESSAGE,0)
Return


#--------------------------------------------------------------#
# Traitement à effectuer avant le chargement des champs écrans #
#--------------------------------------------------------------#
$DEB_GENPOH
# FQ 73645 Plan de travail: Début de la transaction ?
If clalev([M:PMG]) : Gosub DEBTRS_POH : Endif
#-----
WORDFCY=[M:POI1]ORDFCY   (NOL1)
WCUR   =[M:POI1]CUR      (NOL1)
WBPSNUM=[M:POI1]BPSNUM   (NOL1)
WLINBUY=[M:POI1]LINBUY   (NOL1)
WSOHNUM=[M:POI1]SOHNUM   (NOL1)
WSOHCAT=[M:POI1]SOHCAT   (NOL1)
WPRHFCY=[M:POI1]PRHFCY   (NOL1)
WSTOFCY=[M:POI1]LINSTOFCY(NOL1)
WSALFCY=[M:POI1]SALFCY   (NOL1)
# Issue 71069 - 2013-08-23 by SR : PJT
WPJT   =[M:POI1]PJT      (NOL1)
WBPCADD=WBPCADD2
WFMI   =WFMI2
nolign=NOL1+1 : WVALCRITSPE=evalue(WNAMCRITSPE)
#-----
[M:POI1]WORDFCY=WORDFCY
[M:POI1]WCUR   =WCUR
[M:POI1]WBPSNUM=WBPSNUM
# Issue 71069 - 2013-08-23 by SR : PJT
#If [M:POI1]PJTH = "" & GPJTSNGDOC = G_OUI
If GPJTSNGDOC = G_OUI
  [M:POI1]PJTH=WPJT
Endif
#----- Ne pas toucher le GOK si l'on vient des retours -----#
If CHOIX<>4  GOK=1 : Endif
#-----
Raz WERR, GPOH_WERR
Raz  [M:POH0], [M:POH1], [M:POH2], [M:POH3]
GREP="C" : OK=1
ACTION="RAZCRE" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB : If !OK  WERR=1 : Return : Endif
#----- Chargement indicateur commande multi-lignes ? -----#
If [F:BPS]BPSNUM<>WBPSNUM
  Read [BPS] BPS0=WBPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
WSEVLIN=[F:BPS]SEVLIN
#----- Récupération du code acheteur ligne -----#
If OPERATEUR="" & CHOIX<>4
  [M:POI1]BUY=[M:POI1]LINBUY(NOL1)
Endif
#----- Chargement des écrans POH0 et POH1 -----#
nolign=NOL1+1
If WSOHNUM<>""
  If [F:SOH]SOHNUM<>WSOHNUM
    Read [SOH] SOH0=WSOHNUM : If fstat  Raz [F:SOH] : Endif
  Endif
  [M:POH0]=[F:SOH]
  [M:POH1]=[F:SOH]
  Raz [M:POH0]REVNUM, [M:POH0]BETFCY, [M:POH0]BETCPY, [M:POH0]SALFCY
  Raz [M:POH1]STOFCY
Endif
#-----
[M:POH0]=[M:POI1]
# X3-26914 by RBA 20-04-2017
#[M:POH1]=[M:POI1]
Transmask [M:POI1] To [M:POH1]
#/ X3-26914 by RBA 20-04-2017
# Issue X3-68900 - 2018-03-15 by MUARN : trace inutile
#Call ECR_TRACE("[M:POH1]PJTH=" - [M:POH1]PJTH,0)

#-----
If [M:POH0]BETFCY=2
  If [M:POH0]ORIFCY=""  [M:POH0]ORIFCY=[M:POH0]POHFCY              : Endif
  If [M:POH1]STOFCY=""  [M:POH1]STOFCY=[M:POI1]LINSTOFCY(nolign-1) : Endif
Endif
Return


#-----------------------------------#
# Génération d'une commande d'achat #
#-----------------------------------#
$TRT_GENPOH
SAV_NBLIG=[M:POH2]NBLIG
[M:POH2]NBLIG=0
#----- Chargement masques écrans -----#
ACTION="IMP_ZONE(SAIMSK)" : WPGM="W0POH0" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Default Mask [POH0] : Call SAIMSK("POH","IMP_ZONE",WTRT) From W0POH0
If mkstat | GPOH_WERR  WERR=1 : Return : Endif
[M:POH0]SALFCY=WSALFCY
# Issue 111471 - 2016-01-22 by MUARN : init STOFCY si non fait en intersite
If (SAV_NBLIG = 1 & [M:POH1]STOFCY="" & [M:POH0]BETFCY=2 ) : [M:POH1]STOFCY=WSTOFCY : Endif

ACTION="IMP_ZONE(SAIMSK)" : WPGM="W0POH1" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Default Mask [POH1] : Call SAIMSK("POH","IMP_ZONE",WTRT) From W0POH1
If mkstat | GPOH_WERR  WERR=1 : Return : Endif
#----- Avertissement : L'article n'est pas référencé chez le fournisseurs -----#
If GITMBPS=2  & WTRA<3
  GITMBPS=3 : # Pour ne pas imprimer le message d'information dans la trace !
Endif
# Issue X3-55891 - 2018-10-03 by MUARN : exploitation table article/fournisseur/site et nouveau paramètre GITMBPSFCY
If GITMBPSFCY=2  & WTRA<3
  GITMBPSFCY=3 : # Pour ne pas imprimer le message d'information dans la trace !
Endif
#-----
[M:POH2]NBLIG=SAV_NBLIG
ACTION="IMP_TAB(SAIMSK)"  : WPGM="W0POH2" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Default Mask [POH2] : Call SAIMSK("POH","IMP_TAB" ,WTRT) From W0POH2
If mkstat | GPOH_WERR  WERR=1 : Return : Endif
ACTION="IMP_ZONE(SAIMSK)" : WPGM="W0POH3" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Default Mask [POH3] : Call SAIMSK("POH","IMP_ZONE",WTRT) From W0POH3
If mkstat | GPOH_WERR  WERR=1 : Return : Endif

#sr 08.11 Demande 74804 Pas de modèle/plan de l'acheteur ou contremarque : on prend le nbre de copies de la destination
If [F:BPS]BPSNUM=[M:POH0]BPSNUM & [F:BPS]TPMCOD="" & (GFONCTION="GESPOI" | GFONCTION = "FUNPOHW")
  If (dim([M:POI1]PRTCOD)>0 & [M:POI1]PRTCOD<>"") : [M:POH0]COPNBR=[M:POI1]PRTCOP : Endif
Endif
#----- Point d'entrée pour gestion champs ou écrans supplémentaires spécifiques -----#
GPOINT="ALIMSKPOH" : Gosub ENTREE From EXEFNC
If mkstat | GPOH_WERR  WERR=1 : Return : Endif
#----- Génération de la commande d'achat proprement dite -----#
OK=1
ACTION="VERIF_CRE" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
If !OK
  If GMESSAGE<>""
    If WTRA>1
      GMESSAGE=GMESSAGE-mess(98,197,1)-mess(202,197,1)
      Call ECR_TRACE(GMESSAGE,1)
    Endif
    Raz GMESSAGE, GERR
  Endif
  WERR=1 : Return
Endif
#-----
$TR_GENPOH
GOK=1
If WADXLOG=0
  If WTRA>2
    ACTION="Trbegin [POH], [POQ], [POP]" : WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Trbegin [POH], [POQ], [POP]
Endif
#-----
Raz [F:POH], [F:POQ], [F:POP]
nolign=1
[F:POH]=[M:POH0]
[F:POH]=[M:POH1]
[F:POH]=[M:POH2]
[F:POH]=[M:POH3]
If dim([F:POH]CREDAT)>0  [F:POH]CREDAT=date$     : Endif
If dim([F:POH]CRETIM)>0  [F:POH]CRETIM=time      : Endif
If dim([F:POH]CREUSR)>0  [F:POH]CREUSR=GUSER     : Endif
If dim([F:POH]EXPNUM)>0  [F:POH]EXPNUM=[C]EXPORT : Endif
# Issue 94341 - 2013-11-14 by SR
If [F:POH]SOHCAT = 0 : [F:POH]SOHCAT = 1 : Endif
Default File [POH]
ACTION="INICRE"   : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
If GOK<0  Goto ROLL_GENPOH  Elsif !GOK  Goto AB_GENPOH : Endif
#---------------------------------------------------------------------#
# Point d'entrée GENPURORD pour alimentation de zones spécifiques     #
# ------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# CTMFLAG : Indicateur commande de contremarque (2=Oui)               #
# FICHIER : Nom de la table qui va être écrite                        #
# ABRFIC  : Abréviation de la table qui va être écrite                #
# La  classe  [F:POH] est modifiable avant le Write                   #
#---------------------------------------------------------------------#
If WSOHNUM<>""  CTMFLAG=2 Else CTMFLAG=1 : Endif
Raz NUMSOH, LINSOH, SEQSOH
FICHIER="PORDER"
ABRFIC ="POH"
SAVXZSNOL=nolign
Gosub POINT_GENPURORD From TRTACHCDE1
nolign=SAVXZSNOL
If GOK<0  Goto ROLL_GENPOH  Elsif !GOK  Goto AB_GENPOH : Endif
#-----
If WTRA>2
  ACTION="Write [POH]" : WPGM="" : Gosub TRACE_DETAILLEE
Endif
#-----
Write [POH]
If fstat  GOK=0 : Call FSTA("POH")  From GLOCK : Goto AB_GENPOH : Endif
ACTION="CREATION" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
If GOK<0  Goto ROLL_GENPOH  Elsif !GOK  Goto AB_GENPOH : Endif
#----- Ecriture AREPORTM et màj indicateur d'impression sur entête commande -----#
If [M:POI1]PRTFLG=2 & [M:POI1]PRTCOD<>""
  If [M:POH0]DOCNAM<>""
    WARP_RPTCOD(0)=[M:POH0]DOCNAM
  Else
    WARP_RPTCOD(0)=[M:POI1]DOCNAM
  Endif
  WARP_NBRCPY=[F:POH]COPNBR
  Call ALIM_ETAT(1,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA
Endif
#----- Mise à jour du suivi workflow signature -----#
If GOK=1
  Call WRKGLOB(170,[F:POH]POHNUM,"PORDER","") From GOBJACT
  Call WORKPLUS(2,"POH","C",[F:POH]POHNUM,"",0,1,0,WGRPDEB) From AWRK
  If GOK<0  Goto ROLL_GENPOH  Elsif !GOK  Goto AB_GENPOH : Endif
Endif
#-----
If WADXLOG=0
  If WTRA>2
    ACTION="Commit" : WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Commit
Endif
#----- Relecture fournisseur si nécessaire -----#
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
  Read [BPS] BPS0=[F:POH]BPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
#----- Si fournisseur divers, vérifiez l'adresse SVP ! -----#
If [F:BPS]BPSTYP=3
  If WTRA>1
    WMSG=[F:POH]POHNUM-[F:POH]BPSNUM-mess(177,194,1)
    Call ECR_TRACE(WMSG,0)
  Endif
Endif
#----- Contrôle périodes indisponibilités fournisseur (Warning) -----#
Call CTL_PER ([F:POH]ORDDAT,[F:BPS]UVYCOD) From CONTX3
If mkstat
  If WTRA>1
    WMSG=mess(73,198,1)-[F:POH]BPSNUM+"\"+GMESSAGE
    WMSG=mess(1,503,1)-format$("D:"+GFMDAT,[F:POH]ORDDAT)-WMSG
    Call ECR_TRACE(WMSG,0)
  Endif
  Raz mkstat, GMESSAGE, WMSG
Endif
#----- Trace : Commande xxxxxxxxxx créée Fournisseur yyyyyy zzzzzzzzzzzzz -----#
If WTRA>1
  WMSG =mess(98,197,1)-[F:POH]POHNUM-mess(224,197,1)
  WMSG-=mess(73,198,1)-[F:POH]BPSNUM-[F:BPS]BPSNAM
  Call ECR_TRACE(WMSG,0)
Endif
#-----
ACTION="APRES_CRE" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
#----- Envoi des messages groupe workflow signature -----#
If WGRPDEB<>""  Call ENVOI_GROUPE(WGRPDEB) From AWRK : WGRPDEB="" : Endif
Return
#-----
$ROLL_GENPOH
If WADXLOG=0
  If WTRA>2
    ACTION="Rollback" : WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Rollback
  Call ROLL From GLOCK
  If !GROLL  Goto TR_GENPOH : Endif
Endif
Goto ERR_GENPOH
#-----
$AB_GENPOH
If WADXLOG=0
  If WTRA>2
    ACTION="Rollback" : WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Rollback
Endif
#-----
$ERR_GENPOH
#----- Relecture fournisseur si nécessaire -----#
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
  Read [BPS] BPS0=[F:POH]BPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
#----- Trace -----#
If CHOIX<>4
  #----- Commande xxxxxxxxxx non générée ! Fournisseur yyyyyy zzzzzzzzzzzzz -----#
  WMSG =mess(98,197,1)-[F:POH]POHNUM-mess(202,197,1)
  WMSG-=mess(73,198,1)-[F:POH]BPSNUM-[F:BPS]BPSNAM
Else
  #----- Ligne xxxxxxxxxx/999999,9999/999999,99 Non transformée -----#
  WMSG =mess(18,197,1)-[M:POH2]ITMREF([M:POH2]NBLIG-1)+"/"+num$([M:POH2]GROPRI([M:POH2]NBLIG-1))
  WMSG+="/"+num$([M:POH2]QTYUOM([M:POH2]NBLIG-1))-mess(67,197,1)
Endif
If WTRA>1  Call ECR_TRACE(WMSG,0) : Endif
#-----
ACTION="AB_CREATION" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
#----- Suppression des message groupe workflow signature -----#
If WGRPDEB<>""  Call VIRE_GROUPE(WGRPDEB)  From AWRK : WGRPDEB="" : Endif
#-----
WERR=1
Return

# FQ 73645 GA 05/2011
# Plan de travail: Ouverture d'une transaction
$DEBTRS_POH
If adxlog Gosub FINTRS_POH Endif
If [M:PMG]RGRFLG=4 & WADXLOG=0 # Transaction globale pour toute la commande
  #Call DEBTRANS From GLOCK
  WADXLOG=1
  If [M:PMG]TRAFLG>2
   Call ECR_TRACE("Trbegin [POH], [POQ], [POP]",0) From GESECRAN
  Endif
  Trbegin [POH], [POQ], [POP]
Endif
Return
# FQ 73645 GA 05/2011
# Plan de travail: Fermeture de la transaction
# si une erreur détectée, Rollback de toute la commande
$FINTRS_POH
If [M:PMG]RGRFLG=4  # Transaction globale pour toute la commande
  WADXLOG=0
  If GOK=1
      If [M:PMG]TRAFLG>2
         Call ECR_TRACE("Commit",0) From GESECRAN
      Endif
      Commit
  Else
      If [M:PMG]TRAFLG>2
         Call ECR_TRACE("Rollback",0) From GESECRAN
      Endif
      Rollback
  Endif
Endif
Return

#---------------------------------------------------------------#
# Chargement des champs écrans POH0, POH1, POH3 entête commande #
#---------------------------------------------------------------#
$MSK_ENTETE
If GPOH_WTRA>3
  If IMPZON="CCE" | IMPZON="INVDTAAMT"
    Call ECR_TRACE("     ."-mess(36,124,1)-IMPZON+"("+num$(nolign-1)+")",0)
  Else
    Call ECR_TRACE("     ."-mess(36,124,1)-IMPZON,0)
  Endif
Endif
# Issue 71069 - 2013-08-23 by SR : PJT
Case IMPZON
  When "POHFCY"    : #----- Ecran POH0 -----#
    [M:POH0]POHFCY=[M:POI1]WORDFCY
    IMPMOD=1 : # Pour forcer l'après modif
  When "POHNUM"
  When "ORDDAT"
    [M:POH0]ORDDAT=[M:POI1]ORDDAT
  When "BPSNUM"
    [M:POH0]BPSNUM=[M:POI1]WBPSNUM
    IMPMOD=1 : # Pour forcer l'après modif
  When "BPSINV"    : #----- Ecran POH1 -----#
  When "BPAINV"
  When "BPRPAY"
  When "BPAPAY"
  When "BPSSHI"
  When "BPOADD"
  When "ORDREF"
    [M:POH1]ORDREF=[M:POI1]ORDREF
  When "PTE"
  When "BUY"
    If [M:POI1]BUY<>""
      [M:POH1]BUY=[M:POI1]BUY
    Endif
  When "CUR"
    [M:POH1]CUR=[M:POI1]WCUR
  When "CHGTYP"
    If [M:POH1]CHGTYP=0
      [M:POH1]CHGTYP=1
    Endif
  When "BPTNUM"
  When "MDL"
  When "DAYLTI"
  When "VACBPR"
  When "EXTRCPDAT1"
  When "INVFCY"
    If [M:POH1]INVFCY=""  [M:POH1]INVFCY=GFINRSP : Endif
  When "STOFCY"
  When "NBAXE"
  When "CCE"
    If [M:POI1]CCE(indice)<>""
      [M:POH1]CCE(indice)=[M:POI1]CCE(indice)
    Endif
  When "PJTH"
      [M:POH1]PJTH=[M:POI1]PJTH
  When "NBFAC"     : #----- Ecran POH3 -----#
  When "INVDTA"
  When "INVDTAAMT"
  When "INVDTAVAT"
  When "ACC1","ACC2","ACC3","ACC4","ACC5","ACC6","ACC7","ACC8","ACC9","ACC10"
  When "DSP"
  When "PFICCE1", "PFICCE2", "PFICCE3", "PFICCE4", "PFICCE5", "PFICCE6", "PFICCE7",
&      "PFICCE8", "PFICCE9", "PFICCE10","PFICCE11","PFICCE12","PFICCE13","PFICCE14",
&      "PFICCE15","PFICCE16","PFICCE17","PFICCE18","PFICCE19","PFICCE20"
  When "OCNDAT"
  When "OCNNUM"
  When "OCNREM"
Endcase
Return


#-----------------------------------------------------#
# Chargement des champs écran POH2 lignes de commande #
#-----------------------------------------------------#
$MSK_DETAIL
NOL=nolign-1 : # La variable NOL est définie par W0POH2
If GPOH_WTRA>3
  If IMPZON="NBLIG"
    Call ECR_TRACE("     ."-mess(36,124,1)-IMPZON,0)
  Else
    Call ECR_TRACE("     ."-mess(36,124,1)-IMPZON+"("+num$(NOL)+")",0)
  Endif
Endif
Case IMPZON
  When "NBLIG"
  When "ITMREF"
    [M:POH2]ITMREF    (NOL)=[M:POI1]ITMREF    ([M:POH2]POHLIN(NOL))
    # Issue 94186 - 2013-11-07 by MUARN : landed cost et sous traitance
    [M:POH2]LINTYP    (NOL)=[M:POI1]LINTYP    ([M:POH2]POHLIN(NOL))
    # Issue X3-68900 - 2018-03-16 by MUARN : modification dates sur EO
    [M:POH2]UPDSCO    (NOL)=[M:POI1]UPDSCO    ([M:POH2]POHLIN(NOL))
    # Issue X3-111565 - 2018-10-09 by SR : Stockage de la clé afin de se repostionner dessus en $D_CCEX de SUBPOH
    Raz GPOI_VCRNUM,GPOI_VCRLIN,GPOI_VCRSEQ,GPOI_VCRTYP
    If [M:POI1]SOHNUM([M:POH2]POHLIN(NOL)) <> ""
      GPOI_VCRNUM = [M:POI1]SOHNUM([M:POH2]POHLIN(NOL))
      GPOI_VCRLIN = [M:POI1]SOPLIN([M:POH2]POHLIN(NOL))
      GPOI_VCRSEQ = [M:POI1]SOQSEQ([M:POH2]POHLIN(NOL))
      GPOI_VCRTYP = 2
    Elsif [M:POI1]VCRTYPORI([M:POH2]POHLIN(NOL)) = 10
      GPOI_VCRNUM = [M:POI1]VCRNUMORI([M:POH2]POHLIN(NOL))
      GPOI_VCRLIN = [M:POI1]VCRLINORI([M:POH2]POHLIN(NOL))
      GPOI_VCRSEQ = [M:POI1]VCRSEQORI([M:POH2]POHLIN(NOL))
      GPOI_VCRTYP = 10
    Endif
    # End issue X3-111565
    IMPMOD=1
  When "ITMDES"
    [M:POH2]ITMDES    (NOL)=[M:POI1]ITMDES    ([M:POH2]POHLIN(NOL))
  When "ITMDES1"
    [M:POH2]ITMDES1   (NOL)=[M:POI1]ITMDES1   ([M:POH2]POHLIN(NOL))
  When "ITMKND"
    [M:POH2]ITMKND    (NOL)=[M:POI1]ITMKND    ([M:POH2]POHLIN(NOL))  # Issue 112754 - 2016-11-04 by SR : Services
  When "ECCVALMAJ"
    [M:POH2]ECCVALMAJ (NOL)=[M:POI1]ECCVALMAJ ([M:POH2]POHLIN(NOL)) # Issue 71276 - 2015-03-02 by SR : Versions
  When "ECCVALMIN"
    [M:POH2]ECCVALMIN (NOL)=[M:POI1]ECCVALMIN ([M:POH2]POHLIN(NOL))  # Issue 71276 - 2015-03-02 by SR : Versions
  When "PRHFCY"
    [M:POH2]PRHFCY    (NOL)=[M:POI1]PRHFCY    ([M:POH2]POHLIN(NOL))
  When "FCYADD"
    [M:POH2]FCYADD    (NOL)=[M:POI1]FCYADD    ([M:POH2]POHLIN(NOL))
  When "USEPLC"
    [M:POH2]USEPLC    (NOL)=[M:POI1]USEPLC    ([M:POH2]POHLIN(NOL))
  When "LINSTOFCY"
    [M:POH2]LINSTOFCY (NOL)=[M:POI1]LINSTOFCY ([M:POH2]POHLIN(NOL))
  When "SCOADD"
    If [M:POI1]SCOADD([M:POH2]POHLIN(NOL))<>""
      [M:POH2]SCOADD  (NOL)=[M:POI1]SCOADD    ([M:POH2]POHLIN(NOL))
    Endif
  When "UOM"
    [M:POH2]UOM       (NOL)=[M:POI1]UOM       ([M:POH2]POHLIN(NOL))
    [M:POH2]UOMFLG    (NOL)=[M:POI1]UOMFLG    ([M:POH2]POHLIN(NOL))
    [M:POH2]COEFLG    (NOL)=[M:POI1]COEFLG    ([M:POH2]POHLIN(NOL))
  When "QTYUOM"
    [M:POH2]QTYUOM    (NOL)=[M:POI1]QTYUOM    ([M:POH2]POHLIN(NOL))
    [M:POH2]RETQTYSTU (NOL)=[M:POI1]RETQTYSTU ([M:POH2]POHLIN(NOL))
  When "UOMPUUCOE"
    [M:POH2]UOMPUUCOE (NOL)=[M:POI1]UOMPUUCOE ([M:POH2]POHLIN(NOL))
    [M:POH2]PUU       (NOL)=[M:POI1]PUU       ([M:POH2]POHLIN(NOL))
    [M:POH2]QTYPUU    (NOL)=[M:POI1]QTYPUU    ([M:POH2]POHLIN(NOL))
    [M:POH2]STU       (NOL)=[M:POI1]STU       ([M:POH2]POHLIN(NOL))
  When "QTYSTU"
    [M:POH2]QTYSTU    (NOL)=[M:POI1]QTYSTU    ([M:POH2]POHLIN(NOL))
  When "PJT"
    [M:POH2]PJT       (NOL)=[M:POI1]PJT       ([M:POH2]POHLIN(NOL))
  When "EXTRCPDAT"
    [M:POH2]EXTRCPDAT (NOL)=[M:POI1]EXTRCPDAT ([M:POH2]POHLIN(NOL))
    [M:POH2]RETRCPDAT (NOL)=[M:POI1]RETRCPDAT ([M:POH2]POHLIN(NOL))
  When "GROPRI"
    [M:POH2]GROPRI    (NOL)=[M:POI1]GROPRI    ([M:POH2]POHLIN(NOL))
    [M:POH2]PRIREN    (NOL)=[M:POI1]PRIREN    ([M:POH2]POHLIN(NOL))
    [M:POH2]LINTYP    (NOL)=[M:POI1]LINTYP    ([M:POH2]POHLIN(NOL))
  When "DISCRGVAL1", "DISCRGVAL2", "DISCRGVAL3", "DISCRGVAL4", "DISCRGVAL5",
&      "DISCRGVAL6", "DISCRGVAL7", "DISCRGVAL8", "DISCRGVAL9"
    GBIDC3=right$(IMPZON,10)
    Assign "[M:POH2]DISCRGVAL"+GBIDC3+"(NOL)" With
&          evalue("[M:POI1]DISCRGVAL"+GBIDC3+"([M:POH2]POHLIN(NOL))")
    Assign "[M:POH2]DISCRGREN"+GBIDC3+"(NOL)" With
&          evalue("[M:POI1]DISCRGREN"+GBIDC3+"([M:POH2]POHLIN(NOL))")
  When "LINACC1", "LINACC2", "LINACC3", "LINACC4", "LINACC5",
&      "LINACC6", "LINACC7", "LINACC8", "LINACC9", "LINACC10"
    GBIDC3=right$(IMPZON,7)
    # Issue 94643 - 2013-11-25 by SR : Si DA ou plan de l'acheteur, on récupère toujours
    If evalue("[M:POI1]LINACC"+GBIDC3+"([M:POH2]POHLIN(NOL))")<>"" | find(GFONCTION,"GESPSH","GESPOI")
      Assign "[M:POH2]LINACC"+GBIDC3+"(NOL)" With
&            evalue("[M:POI1]LINACC"+GBIDC3+"([M:POH2]POHLIN(NOL))")
    Endif
  When "LINPURTYP"
    If [M:POI1]LINPURTYP([M:POH2]POHLIN(NOL))<>0
      [M:POH2]LINPURTYP(NOL)=[M:POI1]LINPURTYP([M:POH2]POHLIN(NOL))
    Endif
  When "CCE1",  "CCE2",  "CCE3",  "CCE4",  "CCE5",  "CCE6",  "CCE7",  "CCE8",  "CCE9",  "CCE10",
&      "CCE11", "CCE12", "CCE13", "CCE14", "CCE15", "CCE16", "CCE17", "CCE18", "CCE19", "CCE20"
    GBIDC3=right$(IMPZON,4)
    If evalue("[M:POI1]CCE"+GBIDC3+"([M:POH2]POHLIN(NOL))")<>""
      Assign "[M:POH2]CCE"+GBIDC3+"(NOL)" With
&            evalue("[M:POI1]CCE"+GBIDC3+"([M:POH2]POHLIN(NOL))")
    Endif
  When "QUAFLG"
    [M:POH2]QUAFLG    (NOL)=[M:POI1]QUAFLG    ([M:POH2]POHLIN(NOL))
  When "EECINCRAT"
    [M:POH2]EECINCRAT (NOL)=[M:POI1]EECINCRAT ([M:POH2]POHLIN(NOL))
  When "ORICRY"
    [M:POH2]ORICRY    (NOL)=[M:POI1]ORICRY    ([M:POH2]POHLIN(NOL))
    #----- Dernier champ saisissable pour ligne nomenclature composé (produit fini) -----#
    If [M:POI1]LINTYP([M:POH2]POHLIN(NOL))=2  Gosub FIN_CHARGE_LIGNE : Endif
    #-----
  When "VAT1"
    [M:POH2]VAT1      (NOL)=[M:POI1]VAT1      ([M:POH2]POHLIN(NOL))
  When "VAT2"
    [M:POH2]VAT2      (NOL)=[M:POI1]VAT2      ([M:POH2]POHLIN(NOL))
  When "VAT3"
    [M:POH2]VAT3      (NOL)=[M:POI1]VAT3      ([M:POH2]POHLIN(NOL))
    #----- Dernier champ saisissable non soumis à code activité -----#
    Gosub FIN_CHARGE_LIGNE
    #-----
  When "TAXRCP"
    [M:POH2]TAXRCP    (NOL)=[M:POI1]TAXRCP    ([M:POH2]POHLIN(NOL))
  When "TAXISS"
    [M:POH2]TAXISS    (NOL)=[M:POI1]TAXISS    ([M:POH2]POHLIN(NOL))
  When "TAXOTH1"
    [M:POH2]TAXOTH1   (NOL)=[M:POI1]TAXOTH1   ([M:POH2]POHLIN(NOL))
  When "TAXOTH2"
    [M:POH2]TAXOTH2   (NOL)=[M:POI1]TAXOTH2   ([M:POH2]POHLIN(NOL))
  When "TCTRNUM"
    [M:POH2]TCTRNUM        =[M:POI1]TCTRNUM   # 106430.n - Import puchase planning data
  When "TCTRQTY"
    [M:POH2]TCTRQTY        =[M:POI1]TCTRQTY   # 106430.n - Import puchase planning data
  When "WEICAP"
    [M:POH2]WEICAP         =[M:POI1]WEICAP       # 106430.n - Import puchase planning data
  When "VOLCAP"
    [M:POH2]VOLCAP         =[M:POI1]VOLCAP       # 106430.n - Import puchase planning data
  When "ORDMAXAMT"
    [M:POH2]ORDMAXAMT      =[M:POI1]ORDMAXAMT # 106430.n - Import puchase planning data
Endcase
Return

#-------------------------------------------------#
# Fin de chargement de la ligne et écriture trace #
#-------------------------------------------------#
$FIN_CHARGE_LIGNE
If dim(WMSG)<1  Local Char WMSG (100) : Endif
#-----
If dim([M:POH2]TSICOD1)>0  [M:POH2]TSICOD1(NOL)=[M:POI1]TSICOD1([M:POH2]POHLIN(NOL)) : Endif
If dim([M:POH2]TSICOD2)>0  [M:POH2]TSICOD2(NOL)=[M:POI1]TSICOD2([M:POH2]POHLIN(NOL)) : Endif
If dim([M:POH2]TSICOD3)>0  [M:POH2]TSICOD3(NOL)=[M:POI1]TSICOD3([M:POH2]POHLIN(NOL)) : Endif
If dim([M:POH2]TSICOD4)>0  [M:POH2]TSICOD4(NOL)=[M:POI1]TSICOD4([M:POH2]POHLIN(NOL)) : Endif
If dim([M:POH2]TSICOD5)>0  [M:POH2]TSICOD5(NOL)=[M:POI1]TSICOD5([M:POH2]POHLIN(NOL)) : Endif
#----- Gestion des textes sur ligne de cde -----#
If GPURTEXPSH=2
  Call RECHERCHE_DA_TEX([M:POI1]PRONUM,"POI",[M:POI1]POILIN([M:POH2]POHLIN(NOL)),GBIDC3) From TRTACHCDE1
Else
  Raz GBIDC3
Endif
If GBIDC3<>""
  Call DUP_CLOB("POQ",GBIDC3,GBIDI1) From TRTX3TEX
  If GBIDI1<1  Raz GBIDC3 : Endif
Endif
If GBIDC3<>""
  [M:POH2]LINTEX(NOL)=GBIDC3
Endif
#----- Code acheteur -----#
If [M:POI1]LINBUY([M:POH2]POHLIN(NOL))<>""
  [M:POH2]LINBUY (NOL)=[M:POI1]LINBUY   ([M:POH2]POHLIN(NOL))
Endif
#-----
[M:POH2]SOHNUM   (NOL)=[M:POI1]SOHNUM   ([M:POH2]POHLIN(NOL))
[M:POH2]SOPLIN   (NOL)=[M:POI1]SOPLIN   ([M:POH2]POHLIN(NOL))
[M:POH2]SOQSEQ   (NOL)=[M:POI1]SOQSEQ   ([M:POH2]POHLIN(NOL))
[M:POH2]LINTYP   (NOL)=[M:POI1]LINTYP   ([M:POH2]POHLIN(NOL))
[M:POH2]PURMINQTY(NOL)=[M:POI1]PURMINQTY([M:POH2]POHLIN(NOL))
[M:POH2]ITMREFORI(NOL)=[M:POI1]ITMREFORI([M:POH2]POHLIN(NOL))
[M:POH2]VCRTYPORI(NOL)=[M:POI1]VCRTYPORI([M:POH2]POHLIN(NOL))
[M:POH2]VCRNUMORI(NOL)=[M:POI1]VCRNUMORI([M:POH2]POHLIN(NOL))
[M:POH2]VCRLINORI(NOL)=[M:POI1]VCRLINORI([M:POH2]POHLIN(NOL))
[M:POH2]VCRSEQORI(NOL)=[M:POI1]VCRSEQORI([M:POH2]POHLIN(NOL))
[M:POH2]OFS      (NOL)=[M:POI1]OFS      ([M:POH2]POHLIN(NOL))
[M:POH2]LIKQTYCOE(NOL)=[M:POI1]LIKQTYCOE([M:POH2]POHLIN(NOL))
[M:POH2]PREQTYPUU(NOL)=[M:POH2]QTYPUU(NOL)
# Issue 115775 - 2016-04-22 by MUARN : Motif tarif, perdu par PAMDISCRG
[M:POH2]PRIREN(NOL)=[M:POI1]PRIREN([M:POH2]POHLIN(NOL))
#----- Chargement origine de la demande -----#
If [M:POH2]SOHNUM(NOL)<>""
  Read [SOQ] SOQ0=[M:POH2]SOHNUM(NOL);[M:POH2]SOPLIN(NOL);[M:POH2]SOQSEQ(NOL)
  [M:POH2]ORI(NOL)=[F:SOQ]FMI
Else
  [M:POH2]ORI(NOL)=1
Endif
#----- Message d'avertissement si ligne avec prix nul -----#
If [M:POH2]GROPRI(NOL)=0 & [M:POH2]NETPRI(NOL)=0 & [M:POH2]LINTYP(NOL)<>2 &
&        ([M:POH0]BETFCY<>2 | [M:POH0]BETCPY=2)
  GBIDC3=mess(62,194,1)
Else
  GBIDC3=""
Endif
#----- Message d'avertissement si date réception prévue inférieure à date du jour -----#
If [M:POH2]EXTRCPDAT(NOL)<date$
  If GPOH_WTRA>1
    WMSG=format$("DD2",[M:POH2]EXTRCPDAT(NOL))-mess(203,197,1)
    Call ECR_TRACE(WMSG,0)
  Endif
Endif
#----- Ligne sous-traitance -----#
If find([M:POH2]VCRTYPORI(NOL),10,36)
  If [M:POH2]VCRTYPORI(NOL)=10
    WMSG=mess(156,197,1) : # Ordre de fabrication
  Else
    WMSG=mess(641,197,1) : # Ordre de sous-traitance
  Endif
  If GPOH_WTRA>1
    WMSG-=[M:POH2]VCRNUMORI(NOL)+"/"+num$([M:POH2]VCRLINORI(NOL))
    WMSG+="/"+num$([M:POH2]VCRSEQORI(NOL))-mess([M:POH2]LINTYP(NOL),570,1)
    Call ECR_TRACE(WMSG,0)
  Endif
Endif
#----- Ligne classique -----#
If [M:POI1]SOHNUM(NOL)=""
  WMSG =mess(160,195,1)-num$((NOL+1)*1000)
  WMSG-=mess(73,198,1)-[M:POH0]BPSNUM-mess(14,195,1)-[M:POH2]ITMREF(NOL)-GBIDC3
#----- Ligne contremarque -----#
Else
  WMSG =mess(57,198,1)-"<--"-mess(72,197,1)-[M:POH2]SOHNUM(NOL)
  WMSG+="/"+num$([M:POI1]SOPLIN([M:POH2]POHLIN(NOL)))
  WMSG+="/"+[M:POH2]ITMREF(NOL)-GBIDC3
Endif
# Issue 59217 - 2012-02-02 by MUARN : si prix nul ligne en rouge
#If GPOH_WTRA>1  Call ECR_TRACE(WMSG,0) : Endif
If GPOH_WTRA>1
  If GBIDC3<>"" & (GFONCTION="GESSOH" | GFONCTION="FUNPOHW") & GPURCTLPRI0<>2
    Call ECR_TRACE(WMSG,1)
  Else
    Call ECR_TRACE(WMSG,0)
  Endif
Endif
# Issue 84130 - 2013-01-10 by MUARN : landed cost
[M:POH2]WSTCUPD(NOL) = 2
#-----
Return

