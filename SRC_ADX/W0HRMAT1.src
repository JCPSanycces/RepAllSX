  Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "POSCNTOBL"
   PARAM(1) = [M]CRY
   PARAM(2) = "0"
   Local Char    VALEUR(250)
   VALEUR = [M]CODPOS
   Call S_AFF_CHAR(VALEUR,PARAM,"POSCNTOBL","SUBPOS","") From GACTION
   [M]CODPOS = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CODPOS" : GZNUM = 210 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]CODPOS or IMPMOD
     SAVACT = GACTION : GACTION = "CPCONT"
     PARAM(1) = [M]CRY
     PARAM(2) = [M]CTY
     PARAM(3) = ""
     Local Char    VALEUR(250)
     VALEUR = [M]CODPOS
     Call S_AFF_CHAR(VALEUR,PARAM,"CPCONT","SUBPOS","") From GACTION
     [M]CODPOS = VALEUR
     [M]CTY = PARAM(2)
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CODPOS" : GZNUM = 210 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "STD"
      Call AM_CODPOS([M]CODPOS) From SUBEML2
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "CODPOS" : GZNUM = 210 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

