mkstat = 0
zoncou = "CODACS"
indice = 0
If varmode([M]CODACS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACS" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACS","!",[M]CODACS,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACS" : GZNUM = 729 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTACC"
  Call CONTACC([M]CODACS) From SUBACS
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODACS" : GZNUM = 729 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

## Zone NBCNT
mkstat = 0
zoncou = "NBCNT"
indice = 0
status = 1
zoncou = "NBCNT"
If varmode([M]NBCNT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBCNT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBCNT
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBCNT = nolign
   status = 75
   Call SAI_NBCNT(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 4
####################################
Subprog SAI_NBCNT(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBCNT
mkstat = 0
zoncou = "NBCNT"

## Zone NAMCNT
mkstat = 0
zoncou = "NAMCNT"
If varmode([M]NAMCNT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NAMCNT" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]NAMCNT(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NAMCNT" : GZNUM = 55 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone SRNCNT
mkstat = 0
zoncou = "SRNCNT"
If varmode([M]SRNCNT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SRNCNT" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]SRNCNT(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SRNCNT" : GZNUM = 1825 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone CNTTYP
mkstat = 0
zoncou = "CNTTYP"
IMPENT = [M]CNTTYP(indice)
If varinit([M]CNTTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]CNTTYP,indice)=0
 [M]CNTTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CNTTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CNTTYP(indice)
 Endif
Endif
[M]CNTTYP(indice) = IMPENT

## Zone CRYCNT
mkstat = 0
zoncou = "CRYCNT"
If varinit([M]CRYCNT,indice)=0
 [M]CRYCNT(indice) = GPAYS
Endif
If varmode([M]CRYCNT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRYCNT" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CRYCNT(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CRYCNT" : GZNUM = 263 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("TCY","",[M]CRYCNT(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CRYCNT" : GZNUM = 263 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone TELCNT
mkstat = 0
zoncou = "TELCNT"
WCHAR = [M]TELCNT(indice)
SAVACT = GACTION : GACTION = "FMTTELPAY"
Call FMTTELPAY([M]CRYCNT(nolign-1)) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]TELCNT(indice) : Endif
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call AV_TELCNT([M]TELCNT(indice)) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]TELCNT(indice) : Endif
 If !mkstat
  If varmode([M]TELCNT,indice)=0
   If !mkstat
    IMPMOD = 0 : IMPZON = "TELCNT" : Gosub ACTION From =IMPTRT
   Endif
   SAVACT = GACTION : GACTION = "ACNTTEL"
   Call CONTTEL([M]TELCNT(indice),[M]CRYCNT(nolign-1)) From CONTNUM
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TELCNT" : GZNUM = 289 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]TELCNT(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "ACNTTELMOD"
     Call CONTTELMOD([M]TELCNT(indice),[M]CRYCNT(nolign-1)) From CONTNUM
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "TELCNT" : GZNUM = 289 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone MOBCNT
mkstat = 0
zoncou = "MOBCNT"
WCHAR = [M]MOBCNT(indice)
SAVACT = GACTION : GACTION = "FMTTELPAY"
Call FMTTELPAY([M]CRYCNT(nolign-1)) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]MOBCNT(indice) : Endif
If !mkstat
 If varmode([M]MOBCNT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "MOBCNT" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "ACNTTEL"
  Call CONTTEL([M]MOBCNT(indice),[M]CRYCNT(nolign-1)) From CONTNUM
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "MOBCNT" : GZNUM = 9564 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]MOBCNT(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "ACNTTELMOD"
    Call CONTTELMOD([M]MOBCNT(indice),[M]CRYCNT(nolign-1)) From CONTNUM
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "MOBCNT" : GZNUM = 9564 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone EMLCNT
mkstat = 0
zoncou = "EMLCNT"
If varmode([M]EMLCNT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EMLCNT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NBCNT
mkstat = 0
zoncou = "NBCNT"

End

