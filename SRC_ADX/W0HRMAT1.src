#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CRY
mkstat = 0
zoncou = "CRY"
indice = 0
WCHAR = [M]CRY
If varinit([M]CRY,indice)=0
 [M]CRY = GPAYS
Endif
If varmode([M]CRY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRY" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CRY,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("TCY","",[M]CRY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "INIPAYS"
   Call INIPAYS([M]CRY,[M]CRYNAM) From TRTDIV
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CRY([M]CRY) From SUBEML2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]CRY or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_CRY([M]CRY) From SUBEML2
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

