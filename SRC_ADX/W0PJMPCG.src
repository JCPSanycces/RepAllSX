#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMPCG 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBPCG
mkstat = 0
zoncou = "NBPCG"
indice = 0
status = 1
zoncou = "NBPCG"
If varmode([M]NBPCG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBPCG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBPCG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBPCG = nolign
   status = 75
   Call SAI_NBPCG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBPCG From SUBPJCC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBPCG" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBPCG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBPCG
mkstat = 0
zoncou = "NBPCG"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBPCG From SUBPJCC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBPCG" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PCGTYP
mkstat = 0
zoncou = "PCGTYP"
IMPENT = [M]PCGTYP(indice)
WNUM = IMPENT
If varinit([M]PCGTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]PCGTYP,indice)=0
 [M]PCGTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PCGTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PCGTYP(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PCGTYP(IMPENT) From SUBPJCC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PCGTYP" : GZNUM = 1001819 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]PCGTYP(indice) = IMPENT

## Zone PCGGRPMAT
mkstat = 0
zoncou = "PCGGRPMAT"
IMPENT = [M]PCGGRPMAT(indice)
WNUM = IMPENT
If varinit([M]PCGGRPMAT,indice)=0
 IMPENT = 1
Endif
If varmode([M]PCGGRPMAT,indice)=0
 [M]PCGGRPMAT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PCGGRPMAT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PCGGRPMAT(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PCGGRPMAT(IMPENT) From SUBPJCC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PCGGRPMAT" : GZNUM = 11249 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]PCGGRPMAT(indice) = IMPENT

## Zone PCGGRPLAB
mkstat = 0
zoncou = "PCGGRPLAB"
IMPENT = [M]PCGGRPLAB(indice)
WNUM = IMPENT
If varinit([M]PCGGRPLAB,indice)=0
 IMPENT = 1
Endif
If varmode([M]PCGGRPLAB,indice)=0
 [M]PCGGRPLAB(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PCGGRPLAB" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PCGGRPLAB(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PCGGRPLAB(IMPENT) From SUBPJCC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PCGGRPLAB" : GZNUM = 8757 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]PCGGRPLAB(indice) = IMPENT

## Zone PCGGRPMAC
mkstat = 0
zoncou = "PCGGRPMAC"
IMPENT = [M]PCGGRPMAC(indice)
WNUM = IMPENT
If varinit([M]PCGGRPMAC,indice)=0
 IMPENT = 1
Endif
If varmode([M]PCGGRPMAC,indice)=0
 [M]PCGGRPMAC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PCGGRPMAC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PCGGRPMAC(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PCGGRPMAC(IMPENT) From SUBPJCC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PCGGRPMAC" : GZNUM = 1071 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]PCGGRPMAC(indice) = IMPENT

## Zone NBPCG
mkstat = 0
zoncou = "NBPCG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMPCG"
Return

