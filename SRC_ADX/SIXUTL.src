#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################################
#  SIXUTI : pour traitements de bascule Integrale --> X3                             #
######################################################################################
#                                                                                    #
# Subprog SIXUTI                                                                     #
#     Création des utilisateurs                                                      #
#                                                                                    #
#                                                                                    #
# ---------------------------------------------------------------------------------- #
# PRE-REQUIS :                                                                       #
# ---------------------------------------------------------------------------------- #
#                                                                                    #
#                                                                                    #
#                                                                                    #
#####################################################################################

End

# Supp...
If !clalev([F:AUS])  : Local File AUTILIS [AUS]  : Endif   # Utilisateur X3
If !clalev([F:XUTI]) : Local File XIUTI   [XUTI] : Endif   # Utilisateur Intégrale

Trbegin [AUS], [XUTI]
Delete [AUS] Where CREUSR="CP"
Update [XUTI] Where 1=1 With FLGREP=1
Commit 
# Fin Supp
End
Gosub SI_CONTEXT From SIXFONCTION

Global Integer X_NB
Call OUVRE_BOITE("XIUTI",nbrecord([XUTI])) From GESECRAN
Raz X_NB
Call EXEC
Call FERME_BOITE From GESECRAN
Kill X_NB

End
#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE
If GTRACE = ""
 Call OUVRE_TRACE("SIXUTI : Process translation file from INTEGRALE to X3") From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#----  Migration des utilisateurs : AUTILIS  ------#
Call ECR_TIME("SIXUTI : "+SI_MES(96)+" AUTILIS") From DOSSUB
Call SI_UTI
If GOK<>1 : Goto FIN_UTI : Endif

$FIN_UTI
Onerrgo 
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
Resume

#########################################################################
# Création des utilisateurs
#########################################################################
Subprog SI_UTI

Local Integer STOP, NB
Local Char LTMP(50)

If !clalev([F:AUS])  : Local File =SI_DOSSIER+".AUTILIS"  [AUS]  : Endif   # Utilisateurs X3
If !clalev([F:XUTI]) : Local File =SI_DOSSIER+".XIUTI"    [XUTI] : Endif   # Utilisateurs Intégrale

SI_SUBPRG = "SIXUTI"
SI_TABLE  = "XIUTI"
Gosub SI_CRITSUP From SIXFONCTION

$LOOP_UTI
Raz NB

If STOP=1
 CRITERE = "CODUTI>LREPRISE"
 STOP=0
Else
 CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Trbegin [AUS], [XUTI]

# Traitement des utilisateurs
For [XUTI] Where FLGREP<>2
&             & evalue(CRITERE)
&             & evalue(SI_CRITERE)
 
 GOK = 1
 Call AFFBOITE(num$([F:XUTI]CODUTI)) From SUBSIM

 # creation utilisateurs (AUTILIS)
 Gosub CRE_UTI
 If GOK<=0 : Break :  Endif

 Readlock [XUTI] Curr
 [F:XUTI]FLGREP = 2
 Rewrite [XUTI]

 # NB alimenté dans CRE_UTI
 If NB>1000
  LREPRISE = [F:XUTI]CODUTI
  STOP     = 1
  Break
 Endif
Next

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
 If STOP
  Goto LOOP_UTI
 Endif
Else
 Rollback
Endif
End

##################################################################
$CRE_UTI
Raz [F:AUS]

# recuperation et controle code compte
If !func SIXFONCTION.SI_CTL("AUS",[F:XUTI]X3CLE,"XIUTI ("+num$([F:XUTI]CODUTI)+")")
 GOK=0 : Return
Else
 [F:AUS]USR = [F:XUTI]X3CLE
Endif

[F:AUS]NOMUSR  = [F:XUTI]NOMUTI
[F:AUS]LOGIN   = [F:AUS]USR
[F:AUS]PRFMEN  = GMENDEP
[F:AUS]PRFFCT  = GPROFIL
[F:AUS]PASSE   = "BAABAA"


[F:AUS]ENAFLG     = 2 
[F:AUS]USRCONNECT = 2

# Dates et utilisateurs
#-------------------------------------------------
[F:AUS]CREDAT   = date$
[F:AUS]CREUSR   = GUSER              
[F:AUS]UPDDAT   = date$   
[F:AUS]UPDUSR   = GUSER   


SI_TABLE = "AUTILIS"
Gosub SI_BEFWRI From SIXFONCTION

Write [AUS]
If fstat
 # Utilisateur... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(37,133,1)-[F:AUS]USR-"("+num$([F:XUTI]CODUTI)+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Else
 NB+=1
Endif
Return


