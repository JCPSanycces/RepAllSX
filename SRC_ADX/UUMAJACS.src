#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour table intitulé traduisibles sur table des codes d'accès
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update translated field ACCCOD file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub DESACC
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub DESACC
End

#-------------------#
$DESACC

Local Integer I , VALMOD(20)

If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
Endif

Local File =DOSSIER+".ACCCOD"    [ACS]
Local File =DOSSIER+".ATEXTRA"   [AXX]

If dim([F:ACS]INTACC)<0
 Close Local File [ACS],[AXX]
 Return
Endif

# Mise à jour de la table ACCCOD
Call ECR_TRACE(mess(81,125,1)-"ACCCOD:"-time$,0) From GESECRAN
Trbegin [ACS]
 For [ACS]ACS0
  If [F:ACS]INTACC<>""
   Call MAJTEXTRA([F:ACS]INTACC,"ACCCOD","DESACC",[F:ACS]CODACC,"") From ATEXTRA
   [F:ACS]INTACC = ""
   Rewrite [ACS]
   If fstat
    Call ERREUR("ACCCOD"-[F:ACS]CODACC,2) From DOSDIC
   Endif
  Endif
 Next
Commit

Close Local File [ACS],[AXX]

# Validation des écrans avec type de données ACS

Call VALID_TRT(DOSSIER,0,"ACS","","","","","","","Z","","","","","","","","","","","","",VALMOD) From VALDICO

# Onglet Sélection

Call MAJ_SEL(DOSSIER,"ACS") From PATCHAOB

# Validation de l'objet ACS

Call VALID_TRT(DOSSIER,0,"","","","","","","","","ACS","ACS","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(DOSSIER,"ACS") From SUBAOB

Return
