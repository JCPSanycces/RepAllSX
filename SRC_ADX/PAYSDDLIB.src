End
##########################################################
##  SDD management                                     ##
##########################################################
###############################################################################
## SDD management                                                            ##
## This sub programm allows to update HISTOMDT                               ##
## This sub programm allows to update MANDATE =>  Status                     ##
###############################################################################
Subprog UPDMDTPYH(CPY,UMR,DAT,NUM,SEQ,AMT,FRM,CAS)
Value   Char     CPY
Value   Char     UMR
Value   Date     DAT
Value   Char     NUM
Value   Char     SEQ
Value   Decimal  AMT
Value   Char     FRM
Value   Char     CAS    # A = Annulation, I = Impayé

If clalev([F:MDT])   = 0 : Local File MANDATE   [MDT]   : Endif
If clalev([F:HMDT])  = 0 : Local File HISTOMDT  [HMDT]  : Endif
If clalev([F:ADI])   = 0 : Local File ATABDIV   [ADI]   : Endif

Local Integer COUNT_HMDT
Local Char    SEQACTUAL, SEQCODE
[L]SEQACTUAL = right$([L]SEQ,3)
Call LEC_ADI_330B(SEQACTUAL,SEQCODE) From PAYSDDLIB

# Lock MANDATE
#
Readlock [MDT]MDT0 = [L]CPY;[L]UMR
If fstat=1
 GOK = -1 : GLOCK = "$MANDATE"-[L]CPY-[L]UMR : End
Elsif fstat
 End
Endif


# Update HISTOMDT
If CAS="A"

  Delete [HMDT] Where CPY=[L]CPY & UMR=[L]UMR & PAYNUM=[L]NUM
  If fstat : GOK = 0 : Call FSTA("HMDT") From GLOCK : End : Endif

Else

 Readlock [HMDT]HMDT0 = [L]CPY;[L]UMR;[L]DAT;[L]NUM
 If fstat = 1 : GOK = -1 : GLOCK = "$HISTOMDT"-[L]CPY-[L]UMR-[L]DAT-[L]NUM : End : Endif
 If fstat = 4 | fstat = 5
   Raz [F:HMDT]
   [F:HMDT]CPY       = [L]CPY
   [F:HMDT]UMRNUM    = [L]UMR
   [F:HMDT]PAYDAT    = [L]DAT
   [F:HMDT]PAYNUM    = [L]NUM

   Gosub INIOTHFLD
   Call FLDCRE("HMDT") From OBJDIV
   Write [HMDT]
   If fstat : GOK = 0 : Call FSTA("HMDT") From GLOCK : End : Endif

 Elsif fstat = 0
   Gosub INIOTHFLD

   Call FLDUPD("HMDT") From OBJDIV
   Rewrite [HMDT]
   If fstat : GOK = 0 : Call FSTA("HMDT") From GLOCK : End : Endif
 Endif
Endif

# Update MANDATE
Gosub UPDMDTSTA

End

$INIOTHFLD
[F:HMDT]CUR       = GEURO
[F:HMDT]SEQTYP    = [L]SEQCODE
[F:HMDT]AMT       = [L]AMT
[F:HMDT]FRMNUM    = [L]FRM
If [L]CAS="I" : [F:HMDT]DPT=3 : Endif
Return

$UPDMDTSTA
If [L]CAS="A"
 [F:MDT]TOTSDDPAY -= [L]AMT
 [F:MDT]NBRSDDPAY -= 1
 Call LEC_ADI("330",[L]SEQCODE) From CPTLEC
 If [F:ADI]N1=1 or [F:ADI]N1=3
  [F:MDT]STA = 2
 Elsif [F:ADI]N1=2
  If func AMDPAY_SMNDA([L]CPY,[L]UMR,[L]NUM)
   If [F:MDT]PAYNBR=0
    [F:MDT]STA = 2
   Else
    If clalev([F:HMDT2])  = 0 : Local File HISTOMDT  [HMDT2]  : Endif
    Filter [HMDT2] Where CPY=[L]CPY & UMRNUM=[L]UMR
    [L]COUNT_HMDT= rowcount([HMDT2])
    Filter [HMDT2]
    If [L]COUNT_HMDT<=[F:MDT]PAYNBR
     [F:MDT]STA = 2
    Endif
   Endif
  Endif
 Endif
 #
 Call FLDUPD("MDT") From OBJDIV
 Rewrite [MDT]
 If fstat : GOK = 0 : Call FSTA("MDT") From GLOCK : Return : Endif
Else
 [F:MDT]TOTSDDPAY += [L]AMT
 [F:MDT]NBRSDDPAY += 1
 Call LEC_ADI("330",[L]SEQCODE) From CPTLEC
 If [F:ADI]N1=1 or [F:ADI]N1=3
  [F:MDT]STA = 5
  [F:MDT]ENDDAT = [L]DAT
 Else
  If [F:ADI]N1=4 [F:MDT]ENDDAT = addmonth([L]DAT,36) : Endif

  Local Char SEQFINAL
  Call LEC_ADI_330(1,SEQFINAL) From PAYSDDLIB

  If clalev([F:HMDT2])  = 0 : Local File HISTOMDT  [HMDT2]  : Endif
  Link [HMDT2] With [ADI] CODE = 330;[F:HMDT]SEQTYP
& As [LNK]
& Where [F:HMDT2]CPY=[L]CPY &  [F:HMDT2]UMRNUM=[L]UMR & [F:ADI]A1=[L]SEQFINAL


  If rowcount([LNK])
   [F:MDT]STA = 5
   [F:MDT]ENDDAT = [L]DAT
  Else
   Call LEC_ADI("330",[L]SEQCODE) From CPTLEC
   If [F:ADI]N1=2  # FRST=First
    If [F:MDT]PAYNBR>0 & func AMDPAY_SMNDA([L]CPY,[L]UMR,[L]NUM)
     If clalev([F:HMDT3])  = 0 : Local File HISTOMDT  [HMDT3]  : Endif
     Filter [HMDT3] Where CPY=[L]CPY & UMRNUM=[L]UMR
     [L]COUNT_HMDT= rowcount([HMDT3])
     Filter [HMDT3]
     If [L]COUNT_HMDT>=[F:MDT]PAYNBR
      [F:MDT]STA = 5
      [F:MDT]ENDDAT = [L]DAT
     Endif
    Endif
   Endif
  Endif
 Endif
 Call FLDUPD("MDT") From OBJDIV
 Rewrite [MDT]
 If fstat : GOK = 0 : Call FSTA("MDT") From GLOCK : Return : Endif
Endif
Return

Funprog AMDPAY_SMNDA(CPY,UMRNUM,PYHNUM)
Value Char PYHNUM
Value Char UMRNUM
Value Char CPY

Local Integer AMD_IBACOD
Local Integer AMD_BICCOD
Local Integer RES

If GREP="C" or GREP="D" : PYHNUM="" : Endif

If clalev([F:HAM])=0 : Local File HISTOAMD [HAM] : Endif
Filter [HAM] Where [F:HAM]CPY=[L]CPY & [F:HAM]UMRNUM=[L]UMRNUM & FLDCOD="BICCOD" & PAYNUM=PYHNUM
Read  [HAM] First
Filter [HAM]
If !fstat Then
 AMD_BICCOD = 1
Else
 AMD_BICCOD = 0
Endif

Filter [HAM] Where [F:HAM]CPY=[L]CPY & [F:HAM]UMRNUM=[L]UMRNUM & FLDCOD="IBACOD" & PAYNUM=PYHNUM
Read  [HAM] First
Filter [HAM]
If !fstat Then
 AMD_IBACOD = 1
Else
 AMD_IBACOD = 0
Endif

If AMD_BICCOD = 1 &  AMD_IBACOD = 1
 RES = 1
Else
 RES = 0
Endif

End RES



###############################################################################
## SDD management                                                            ##
## This sub programm allows to initialize the sequence                       ##
###############################################################################
Subprog CALSEQTYP(CPY,UMR,SEQ)
Value    Char     CPY
Value    Char     UMR
Variable Char     SEQ

If clalev([F:MDT])   = 0 : Local File MANDATE   [MDT]   : Endif
If clalev([F:HMDT])  = 0 : Local File HISTOMDT  [HMDT]  : Endif
If clalev([F:ADI])   = 0 : Local File ATABDIV   [ADI]   : Endif

Local Integer COUNT_HMDT


If [F:MDT]UMRNUM<>[L]UMR | [F:MDT]CPY<>[L]CPY
 Read [MDT]MDT0 = [L]CPY;[L]UMR
Endif

# Initialization SEQ - "OOFF" - Table MANDATE : Field PAYTYP   1 Recurring 2 Single
If [F:MDT]PAYTYP=2
 Call LEC_ADI_330(3,SEQ) From PAYSDDLIB
Else
 # Initialization SEQ - "FRST"/"RCUR"  or "FRST"/"FNAL"
 Filter [HMDT] Where CPY=[L]CPY & UMRNUM=[L]UMR
 [L]COUNT_HMDT= rowcount([HMDT])
 Filter [HMDT]

 If [L]COUNT_HMDT=0
  If [F:MDT]WIOFIRSEQ=2
   Call LEC_ADI_330(4,SEQ) From PAYSDDLIB
  Else
   Call LEC_ADI_330(2,SEQ) From PAYSDDLIB
  Endif
 Else
  If [F:MDT]FNLFLG=2 & [L]COUNT_HMDT+1>=[F:MDT]PAYNBR
   Call LEC_ADI_330(1,SEQ) From PAYSDDLIB
  Else
   Call LEC_ADI_330(4,SEQ) From PAYSDDLIB
  Endif
 Endif

 If func AMDPAY_SMNDA([L]CPY,[L]UMR,"")
  Call LEC_ADI_330(2,SEQ) From PAYSDDLIB
 Endif
Endif

[L]SEQ = num$([F:MDT]TYP)+"/"+[L]SEQ
End

Subprog LEC_ADI_330(NUM,CODE)
Value    Integer NUM
Variable Char    CODE
Raz [L]CODE
Filter [ADI] Where NUMTAB = 330 & N1=[L]NUM
Read [ADI]CODE First
If !fstat
 [L]CODE = [F:ADI]A1
Endif
Filter [ADI]
End

Subprog LEC_ADI_330B(SEQ,CODE)
Value    Char   SEQ
Variable Char   CODE
Raz [L]CODE
Filter [ADI] Where NUMTAB = 330 & A1=[L]SEQ
Read [ADI]CODE First
If !fstat
 [L]CODE = [F:ADI]CODE
Endif
Filter [ADI]
End

###############################################################################
## SDD management                                                            ##
## This sub programm allows to control the sequence                          ##
###############################################################################
Subprog CTLSEQ(CPY,UMR,SEQ,DAT,OK)
Value    Char     CPY
Value    Char     UMR
Value    Char     SEQ
Value    Date     DAT
Variable Integer  OK

If clalev([F:MDT])   = 0 : Local File MANDATE   [MDT]   : Endif
If clalev([F:HMDT])  = 0 : Local File HISTOMDT  [HMDT]  : Endif
If clalev([F:ADI])   = 0 : Local File ATABDIV   [ADI]   : Endif

Local Char SEQFIRST, SEQFINAL, SEQACTUAL, SEQCODE

Call LEC_ADI_330(2,SEQFIRST) From PAYSDDLIB
Call LEC_ADI_330(1,SEQFINAL) From PAYSDDLIB
SEQACTUAL = right$([L]SEQ,3)

If [F:MDT]UMRNUM<>[L]UMR | [F:MDT]CPY<>[L]CPY
 Read [MDT]MDT0 = [L]CPY;[L]UMR
Endif
If [L]DAT<[F:MDT]SIGDAT
 GMESSAGE=mess(289,117,1)-format$("D:"+GFMDAT,[F:MDT]SIGDAT) : mkstat = 2 : End
Endif
##

Link [HMDT] With [ADI] CODE = 330;[F:HMDT]SEQTYP
& As [LNK]
& Where [F:HMDT]CPY=[L]CPY &  [F:HMDT]UMRNUM=[L]UMR
& Order By Key CLE= [F:HMDT]CPY;[F:HMDT]UMRNUM;[F:HMDT]PAYDAT;[F:HMDT]PAYNUM

Raz OK, GMESSAGE
If [L]SEQ=""  # SEQ is empty when creating.
 Call CALSEQTYP([L]CPY,[L]UMR,[L]SEQ) From PAYSDDLIB
 SEQACTUAL = right$([L]SEQ,3)
 If [L]SEQACTUAL=[L]SEQFINAL
  Read [LNK]CLE Last
  If !fstat & [F:HMDT]PAYDAT>[L]DAT
   GMESSAGE=mess(281,117,1)-[F:HMDT]PAYNUM-format$("D:"+GFMDAT,[F:HMDT]PAYDAT) : OK=1 : Goto E_END
  Endif
 Else
  Read [LNK]CLE First
  If !fstat & [F:HMDT]PAYDAT>[L]DAT
   GMESSAGE=mess(280,117,1)-[F:HMDT]PAYNUM-format$("D:"+GFMDAT,[F:HMDT]PAYDAT) : OK=1 : Goto E_END
  Endif
 Endif
Else
 For [LNK]
  If [L]SEQACTUAL=[L]SEQFIRST
   If [F:HMDT]PAYDAT<[L]DAT & [F:ADI]A1<>[L]SEQFIRST
    GMESSAGE=mess(282,117,1)-[F:HMDT]PAYNUM-format$("D:"+GFMDAT,[F:HMDT]PAYDAT) : OK=1 : Break
   Endif
  Elsif [L]SEQACTUAL=[L]SEQFINAL & [F:ADI]A1<>[L]SEQFINAL
   If [F:HMDT]PAYDAT>[L]DAT
    GMESSAGE=mess(281,117,1)-[F:HMDT]PAYNUM-format$("D:"+GFMDAT,[F:HMDT]PAYDAT) : OK=1 : Break
   Endif
  Else
   If [F:ADI]A1=[L]SEQFIRST
    If [F:HMDT]PAYDAT>[L]DAT
     GMESSAGE=mess(280,117,1)-[F:HMDT]PAYNUM-format$("D:"+GFMDAT,[F:HMDT]PAYDAT) : OK=1 : Break
    Endif
   Elsif [F:ADI]A1=[L]SEQFINAL
    If [F:HMDT]PAYDAT<[L]DAT
     GMESSAGE=mess(295,117,1)-[F:HMDT]PAYNUM-format$("D:"+GFMDAT,[F:HMDT]PAYDAT) : OK=1 : Break
    Endif
   Endif
  Endif
 Next
Endif

$E_END
Filter [HMDT]
End


###############################################################################
## SDD management                                                            ##
## Initialization of "Adress" field                                          ##
###############################################################################
Subprog INIT_ADD(UMR,ADD)
Value    Char    UMR()
Variable Char    ADD()

If clalev([F:MDT])=0    : Local File MANDATE [MDT] : Endif
Raz [L]ADD

If [F:MDT]UMRNUM<>[L]UMR | [F:MDT]CPY<>GSOCIETE
 Read [MDT]MDT0 = GSOCIETE;[L]UMR
Endif

[L]ADD=[F:MDT]BPCADD
End

###############################################################################
## SDD management                                                            ##
## This sub programm updates the receipt entry number in the HISTOAMD table  ##
###############################################################################
Funprog UPDHAMNUM(SOC,RUM,NUMSEA,NUMVAL)
Value Char SOC : # Creditor identifier (=Company)
Value Char RUM : # Mandate
Value Char NUMSEA : #receipt entry number to search
Value Char NUMVAL : #receipt entry number to update
If !clalev([F:HAM]) : Local File HISTOAMD [HAM] : Endif
Local Integer OK
OK = 1
Filter [HAM] Where CPY=[L]SOC & UMRNUM=[L]RUM & PAYNUM=[L]NUMSEA
For [HAM]
 [F:HAM]PAYNUM=[L]NUMVAL
 Rewrite [F:HAM]
 If fstat=1
  OK = 1
 Elsif fstat
  OK = 0
 Endif
Next
Filter [HAM]
End OK

######################################################################################
# Funprog used to generate the File bank SDD in FICMAG script
######################################################################################
# If SCTPROLOT = 1 then return false else return true
Funprog PROLOTCHAR(SCTPROLOT)
Value Integer SCTPROLOT
Local Char    RTN
 RTN = ""
 # Becareful always in lowercase
 If SCTPROLOT=G_OUI Then
  RTN="true"
 Else
  RTN="false"
 Endif
End RTN

#To know if the payment is amended or not
Funprog AMDPAY(CPY,UMRNUM,PYHNUM)
Value Char PYHNUM
Value Char UMRNUM
Value Char CPY
Local Char RES
RES = ""
If clalev([F:HAM])=0 : Local File HISTOAMD [HAM] : Endif
Filter [HAM] Where CPY=[L]CPY & UMRNUM=[L]UMRNUM & PAYNUM=PYHNUM
Read  [HAM] First
Filter [HAM]
# Becareful always in lowercase
If !fstat Then
 RES="true"
Else
 RES="false"
Endif
End RES

#Not managed in X3 : oldreference of the mandat
Funprog OLDMDT
Local Char RES
 # Not managed in X3 but in case we have the func ready.
 RES = ""
End RES

#Find the old value of the company name
Funprog OLDCPY(CPY,UMRNUM,PYHNUM)
Value Char PYHNUM
Value Char UMRNUM
Value Char CPY
Local Char RES
Local Char FLDCOD
RES = ""
FLDCOD ="CPYNAM"
If clalev([F:HAM])=0 : Local File HISTOAMD [HAM] : Endif
Read [HAM]HAM0 = CPY; UMRNUM ; FLDCOD ; PYHNUM
If !fstat Then
 RES=[F:HAM]OLDVAL
Endif
End RES

#Find the old value of the SEPA creditor ID
Funprog OLDSCI(CPY,UMRNUM,PYHNUM)
Value Char PYHNUM
Value Char UMRNUM
Value Char CPY
Local Char RES
Local Char FLDCOD
RES = ""
FLDCOD ="SCINUM"
If clalev([F:HAM])=0 : Local File HISTOAMD [HAM] : Endif
Read [HAM]HAM0 = CPY; UMRNUM ; FLDCOD ; PYHNUM
If !fstat Then
 RES=[F:HAM]OLDVAL
Endif
End RES

#Find the old value of BIC code
Funprog OLDBIC(CPY,UMRNUM,PYHNUM)
Value Char PYHNUM
Value Char UMRNUM
Value Char CPY
Local Char    RES
Local Char FLDCOD
RES = ""
FLDCOD ="BICCOD"
If clalev([F:HAM])=0 : Local File HISTOAMD [HAM] : Endif
Read [HAM]HAM0 = CPY; UMRNUM ; FLDCOD ; PYHNUM
If !fstat Then
 RES="SMNDA"
Endif
End RES

#Find the old value IBAN code
Funprog OLDIBAN(CPY,UMRNUM,PYHNUM)
Value Char PYHNUM
Value Char UMRNUM
Value Char CPY
Local Char    RES
Local Char FLDCOD
RES = ""
FLDCOD ="IBACOD"
If clalev([F:HAM])=0 : Local File HISTOAMD [HAM] : Endif
Read [HAM]HAM0 = CPY; UMRNUM ; FLDCOD ; PYHNUM
If !fstat Then
 RES=[F:HAM]OLDVAL
Endif
End RES


#Find the old value of the company name if an amendment was created after the creation of the payment
# The amendment can be linked to a payment or not
Funprog CPYNAM(CPY,UMRNUM,PYHNUM)
Value Char CPY
Value Char UMRNUM
Value Char PYHNUM
Local Char RES
Local Char FLDCOD
FLDCOD ="CPYNAM"
Gosub FINDCPYVAL
End RES


#Find the old value of the SCI company name if an amendment was created after the creation of the payment
# The amendment can be linked to a payment or not
Funprog SCINUM(CPY,UMRNUM,PYHNUM)
Value Char CPY
Value Char UMRNUM
Value Char PYHNUM
Local Char RES
Local Char FLDCOD
FLDCOD ="SCINUM"
Gosub FINDCPYVAL
End RES

$FINDCPYVAL
Raz RES
If clalev([F:HAM])=0  : Local File HISTOAMD [HAM]  : Endif
If clalev([F:PYH1])=0 : Local File PAYMENTH [PYH1] : Endif
# The receipt entry includes an amendment
Read [HAM]HAM0 = CPY; UMRNUM ; FLDCOD ; PYHNUM
If !fstat
 RES = [F:HAM]NEWVAL
 Return
Endif
# The receipt entry doesn't include an amendment
Read [HAM]HAM0 = [L]CPY; [L]UMRNUM ; [L]FLDCOD ; ""
If !fstat
 RES = [F:HAM]OLDVAL
Else
 Link [HAM] With [PYH1]PYH0~=[F:HAM]PAYNUM As [LNK]
&  Where [F:HAM]CPY=[L]CPY & [F:HAM]UMRNUM=[L]UMRNUM & [F:HAM]FLDCOD=[L]FLDCOD & [F:PYH1]STA<8 & [F:PYH1]TFBFIL="" & [F:PYH1]NUM<>[L]PYHNUM
& Order By OPEDAT
  Read [LNK] First
  If !fstat
   RES = [F:HAM]OLDVAL
  Else
   Call LEC_CPY(CPY) From CPTLEC
   RES = evalue("[F:CPY]"+[L]FLDCOD)
  Endif
Endif
Return

Funprog BIC(CPY,UMRNUM,PYHNUM)
Value Char CPY
Value Char UMRNUM
Value Char PYHNUM
Local Char RES(50)
Local Char FLDCOD(GLONAVA)
FLDCOD ="BICCOD"
Gosub FINDBANVAL
End RES
End

Funprog IBAN(CPY,UMRNUM,PYHNUM)
Value Char CPY
Value Char UMRNUM
Value Char PYHNUM
Local Char RES(50)
Local Char FLDCOD(GLONAVA)
FLDCOD ="IBACOD"
Gosub FINDBANVAL
End RES

$FINDBANVAL
Raz RES
If clalev([F:HAM])=0  : Local File HISTOAMD [HAM]  : Endif
If clalev([F:PYH1])=0 : Local File PAYMENTH [PYH1] : Endif
# The receipt entry includes an amendment
Read [HAM]HAM0 = CPY; UMRNUM ; FLDCOD ; PYHNUM
If !fstat
 RES = [F:HAM]NEWVAL
 Return
Endif
# The receipt entry doesn't include an amendment
Read [F:PYH1]PYH0=[L]PYHNUM
If !fstat
 Case FLDCOD
  When "BICCOD" : RES = [F:PYH1]BICCOD
  When "IBACOD" : RES = func FICMAG.IBAN([F:PYH1]BIDCRY,[F:PYH1]BID)
 Endcase
Endif
Return
