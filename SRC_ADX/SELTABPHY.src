#<AdxTL>@(#)2.0.0.0 $Revision$
################################################################################
#    SELECTION DANS TABLE CONCERNANT LA GESTION DES ELEMENTS PHYSIQUES
#    MWA
#-------------------------------------------------------------------------------
#
#-------------------------------------------------------------------------------
#    ****  SELECTION DANS TABLE  *****
#
#    SELPHYFCY      LISTE DES SITES APPARTENANT A LA SOCIETE
#    SELPHYBUI      LISTE DES BATIMENTS
#
#
#-------------------------------------------------------------------------------

#  Appel direct d'une sélection sur table
  Local Char VALEUR(10),PARAM(10)(1..2)
  PARAM(1) = "Z02"
  PARAM(2) = "01"
  Call S_TAB_CHAR(VALEUR,PARAM,"SELCMPFAS","SELTABFAS","") From GACTION
  End


################################################################################
$ACTION
  If clalev([F:FCY]) =0                          : Local File FACILITY      [FCY] : Endif

  Case ACTION
    When  "SEL_TABLE"      : Gosub SEL_TABLE
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$SEL_TABLE

  Case TABLE
    When "SELPHYFCY"    : Gosub SET_PHYFCY
    When "SELPHYBUI"    : Gosub SET_PHYBUI
    When "SELPHYLCT"    : Gosub SET_PHYLCT
  Endcase
Return



#-------------------------------------------------------------------------------
$SET_PHYFCY

 # ******  Liste des sites de la société   *************

  Local Char LCPY(GLONCPY)

  LCPY = PARAM(1) : # Société

  DEFPAG = 1

 # ******  Description de la table
  Local Char CODFIC(20)  : CODFIC = "FACILITY" : # Séléction sur table

  If clalev([F:FCY])=0 : Local File = "FACILITY" [FCY]:   Endif
  Default File [FCY]

  # ******  Description de la table
  # ...................
  # Critères de sélection
  If(LCPY <> "") Then
    CRITERE =  "LEGCPY='"+LCPY+"'"
  Else
    CRITERE = "1=1"
  Endif
  ORDRE   = "FCY"                          : # Clause order by
  TIT(0)  = mess(7,GML_MSGPHY,1)           : # Liste des sites de la société
  SIZLIG  = 80                             : # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL  = 240                            : # Défaut 240 (60 col en quart de colonne)
  NBCOL   = 0
  NBCOL  += 1 : COL(NBCOL) = "FCY"         : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "FCYNAM"      : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  START   = "FCY"                          : # Colonne à récupérer suite au choix

Return

#-------------------------------------------------------------------------------
$SET_PHYBUI

 # ******  Liste des bâtiments *************

  DEFPAG = 1

 # ******  Description de la table
  Local Char CODFIC(20)  : CODFIC = "PHYBUI" : # Séléction sur table

  If clalev([F:BUI])=0 : Local File = "PHYBUI" [BUI]:   Endif
  Default File [BUI]

  # ******  Description de la table
  # ...................
  # Critères de sélection
  CRITERE = "1=1"
  ORDRE   = "BUICOD"                       : # Clause order by
  TIT(0)  = mess(182,GML_MSGPHY,1)           : # Liste des bâtiments
  SIZLIG  = 80                             : # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL  = 240                            : # Défaut 240 (60 col en quart de colonne)
  NBCOL   = 0
  NBCOL  += 1 : COL(NBCOL) = "BUICOD"      : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "BUIDES"      : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  START   = "BUICOD"                          : # Colonne à récupérer suite au choix

Return


#-------------------------------------------------------------------------------
$SET_PHYLCT

 # ******  Liste des localisations   *************

  Local Char LCPY(GLONCPY)
  Local Char LFCY(GLONFCY)
  Local Char LCOD(GLONLCT)

  LCPY = PARAM(1) : # Société
  LFCY = PARAM(2) : # Site
  LCOD = PARAM(3) : # Localisation

  DEFPAG = 1

 # ******  Description de la table
  #Local Char CLS
  Local Char CODFIC(20)  : CODFIC = "PHYLCT" : # Séléction sur table

  If clalev([F:LCT])=0 : Local File = "PHYLCT" [LCT]:   Endif
  Default File [LCT]

  # ******  Description de la table
  # ...................
  # Critères de sélection
  If(LCPY <> "" and LFCY <> "") Then
    CRITERE = "CPY='"+LCPY+"' and FCY='"+LFCY+"'"
  Elsif(LCPY <> "") Then
    CRITERE =  "CPY='"+LCPY+"'"
  Elsif(LFCY <> "") Then
    CRITERE =  "FCY='"+LFCY+"'"
  Else
    CRITERE = "1=1"
  Endif

  If (LCOD <> "") Then
    CRITERE +=  " and LCTCOD <> '"+LCOD+"'"
  Endif

  ORDRE   = "LCTCOD"                          : # Clause order by
  TIT(0)  = mess(181,GML_MSGPHY,1)         : # Liste des localisations de la société
  SIZLIG  = 80                             : # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL  = 240                            : # Défaut 240 (60 col en quart de colonne)
  NBCOL   = 0
  NBCOL  += 1 : COL(NBCOL) = "LCTCOD"      : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "LCTDES"      : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV

  # Colonne à récupérer suite au choix
  START   = "LCTCOD"

Return

