#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ADOCVAL","ADOCVAL",3,"") From GTRAITE
End

###############################################################
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "EXEC"       : Gosub EXEC
Endcase
Return

###################################################################
$INIT
Local Mask ADOCVAL [ADOV]
Raz [M:ADOV]
[M:ADOV]ALLLAN  = 1
[M:ADOV]ALLTYP  = 1
[M:ADOV]ALLCOD  = 1
[M:ADOV]LAN     = PARAM(1)
[M:ADOV]TYP     = PARAM(2)
[M:ADOV]COD     = PARAM(3)
[M:ADOV]VALID   = 1
[M:ADOV]DAT     = [0/0/0]
If [M:ADOV]LAN="" : [M:ADOV]LAN = GLANGUE : Endif

# JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call INIT_ALLCREGRP("[M:ADOV]ALLCREGRP") From AGENLIBA
Return

$EXEC
Local File ADOCUMENT [ADO]
Local Char CRITERE(250) , CLEADO(30)(0..3)
Call DEBTRANS From GLOCK
CRITERE = ""
If [M:ADOV]ALLLAN=1
 CRITERE += 'LAN="'+[M:ADOV]LAN+'"'
Endif
If [M:ADOV]ALLTYP=1
 If CRITERE<>"" : CRITERE += "&" : Endif
 CRITERE += 'TYP="'+[M:ADOV]TYP+'"'
Endif
If [M:ADOV]ALLCOD=1
 If CRITERE<>"" : CRITERE += "&" : Endif
 CRITERE += 'COD="'+[M:ADOV]COD+'"'
Endif
Gosub TR1
Return

$TR1
Trbegin [ADO]
 Filter [ADO] Where evalue(CRITERE)
 For [ADO]ADO0(3)
   #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
    If ! func AGENLIBA.TEST_GROUPE_OK("ADO", [ADO]LAN, [ADO]TYP, [ADO]COD, "[M]ALLCREGRP")
      If [M:ADOV]ALLLAN=1 & [M:ADOV]ALLTYP=1 & [M:ADOV]ALLCOD=1  # Pour une documentation seule donnée : On peut afficher un message à l'acran
        Call MESSAGE_GROUPE("ADO", [ADO]LAN, [ADO]TYP, [ADO]COD) From AGENLIBA
      Endif
   Else
     For [ADO]ADO0
       Case [M:ADOV]VALID
         When 1 : [F:ADO]VLDFLG = 1
         When 2 : [F:ADO]VLDFLG = 2 : [F:ADO]VLDDAT = [M:ADOV]DAT
       Endcase
       Rewrite [ADO]
       If fstat
         GOK = 0 : Call FSTA("ADO") From GLOCK : Break 2
       Endif
       If GADONIX=2
         Local Char INDEX(30)(2)
         INDEX(0) = [F:ADO]LAN
         INDEX(1) = [F:ADO]COD
         Call TRACE_COR("ADO",[F:ADO]TYP,INDEX,"M") From GOBJET
       Endif
     Next ADO
     Call MAJ_ENVINDUS_DOC ([F:ADO]LAN,[F:ADO]TYP,[F:ADO]COD,2) From AGENREM : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
   Endif
 Next ADO(3)
 Filter [ADO]
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

######################################################################################
Subprog C_ALLLAN(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]LAN = "" : Affzo LAN : Grizo LAN
Else
 Actzo LAN
Endif
End

Subprog AS_LAN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = GLANGUE
Endif
End

Subprog C_ALLTYP(VALEUR)
Variable Integer  VALEUR
If VALEUR=2
 [M]TYP = "" : Affzo TYP : Grizo TYP
Else
 Actzo TYP
Endif
End

Subprog C_ALLCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]COD = "" : Affzo COD : Grizo COD
Else
 Actzo COD
Endif
End

Subprog C_VALID(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When 1 : [M]DAT = [0/0/0] : Affzo DAT : Grizo DAT
 When 2 : Actzo DAT
Endcase
End

Subprog AS_DAT(VALEUR)
Variable Date    VALEUR
If [M]VALID=2 & VALEUR=[0/0/0]
 VALEUR = date$
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ADOCVAL) 25/10/2012 10:36:14 (JPGA)
######################################################################################
Subprog AV_ALLCREGRP(VALEUR)
Variable Integer VALEUR
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  #Le modèle "Traitement Standard-Boite de dialogue" ne permet pas chgfmt en INIT_DIA : on le fait donc en Avant-zone de champ
  Call AFFMASK_GROUPE("[M]ALLCREGRP") From AGENLIBA
End
######################################################################################

