#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
# UUMGPOSSAL06   Moulinette de Postmigration des livraisons      Module Ventes #
################################################################################
Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSSAL06") From LECFIC
  Endif

  #Call RAZ_UUMGPOSSAL06(DOSSIER)
  Call MAJ_UUMGPOSSAL06(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


###################################################################################
Subprog MAJ_UUMGPOSSAL06(DOSSIER)
Value Char DOSSIER

# Issue 106947 - 20150811 by LD : Migration of historic folder
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
# Issue 106947 - 20150811 by LD

Local Integer ERR
##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Récupération du n° de version
Local Char CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL06",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

# Issue 106947 - 20150811 by LD : Migration of historic folder
Gosub MIG_OUVRE From TRTMIG
# Issue 106947 - 20150811 by LD

# La moulinette de postmigration concerne l'alimentation du flag RTNSTA
# Elle doit se faire uniquement lors du passage en V8 AKIRA
# A voir : Contrôle à déplacer lors de l'ajout de nvelles initialisations
If VERSION>=GMIGX3VER80
    Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL06",3,ERR) From TRTMIG : #3=Terminée
    End
Endif

#----- Présence des fichiers  -----#
If filinfo(filpath("FIL","SDELIVERY",  "fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL","SDELIVERYD", "fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL06",2,ERR) From TRTMIG : #2=En cours

###################

Call ECR_TIME("UUMGPOSSAL06 Sales Delivery Process : Update SDELIVERY") From DOSSUB
Call ECR_TRACE("UUMGPOSSAL06 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:SDH])  = 0 : Local File =DOSSIER+".SDELIVERY"    [SDH]  : Endif
If clalev([F:SDD])  = 0 : Local File =DOSSIER+".SDELIVERYD"   [SDD]  : Endif

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

# Déclaration des variables communes de travail
Local Integer I, J

# Déclaration des variables locales de travail

Gosub OUVRE_SAL From UUMGTRTSAL00
If GOK<>1
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL06",7,ERR) From TRTMIG : #7=Erreur
  Goto FIN
Endif

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGPOSSAL06",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGPOSSAL06" : FILTRELIN=0  : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_SAL01
Raz NB
If STOP=1
 STOP = 0
 CRITERE = "[F:SDH]LND<>2 & [F:SDH]SCO<>2 & [F:SDH]SDHNUM>TABMIGKEY(1)"
Else
 CRITERE = "[F:SDH]LND<>2 & [F:SDH]SCO<>2 & 1=1"
Endif

Trbegin [SDH],[SDD]
GOK = 1

For [SDH]SDH0 Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
    FLUX="UUMGPOSSAL06" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
    If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  Raz [F:SDH]RTNLINNBR  : # Nombre de lignes totalement retournées
  [F:SDH]RTNSTA=1       : # Statut retour
  ############################
  #-- Boucle sur les lignes
  ############################
  For [SDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM

      # -- Il y a une qté retour sur la ligne : La livraison est partiellement retournée
      If [F:SDD]RTNQTYSTU<>0
         [F:SDH]RTNSTA=2
      Endif

      # -- la ligne est totalement retournée  : Incrémentation du nbre de lignes retournées
      If [F:SDD]RTNQTYSTU >= [F:SDD]QTYSTU
         [F:SDH]RTNLINNBR += 1
      Endif
  Next
  If GOK<1 : Break : Endif

  # Si toutes les lignes sont retournées, la livraison est totalement retournée
  If [F:SDH]RTNLINNBR >= [F:SDH]LINNBR : [F:SDH]RTNSTA = 3 Endif

  Rewrite [F:SDH]
  If fstat
    Call ECR_TRACE("File SDELIVERY(SDHNUM)"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:SDH]SDHNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL06",7,ERR) From TRTMIG : #7=Erreur
Else
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
      TABMIGKEY(2)=num$(STOP)
  Else
      Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGPOSSAL06",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGPOSSAL06",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_SAL01
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

$FIN
Close Local File [SDD], [SDH]

Call ECR_TIME("UUMGPOSSAL06 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB

$FIN_FIN
Call MIGTRTEND (DOSSIER,"UUMGPOSSAL06") From TRTMIG
End

##########################################################################
Subprog RAZ_UUMGPOSSAL06(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : # N= no module
  End
Endif

Call MIGRAZKEY (DOSSIER,"UUMGPOSSAL06",ERR) From TRTMIG
Call MIGRAZKEY (DOSSIER,"UUMGPOSSAL06/VALORISATION",ERR) From TRTMIG

End
##############################################################################################
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGPOSSAL06(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGPOSSAL06(APPLI)
End

