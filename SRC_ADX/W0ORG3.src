#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ORG3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone KEYORG
mkstat = 0
zoncou = "KEYORG"
indice = 0
IMPENT = [M]KEYORG
WNUM = IMPENT
If varinit([M]KEYORG,indice)=0
 IMPENT = 1
Endif
If varmode([M]KEYORG,indice)=0
 [M]KEYORG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "KEYORG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]KEYORG(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "KEYORG" : GZNUM = 680 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_KEYORG(IMPENT) From SUBORG
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "KEYORG" : GZNUM = 680 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>IMPENT or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_KEYORG(IMPENT) From SUBORG
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "KEYORG" : GZNUM = 680 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif
[M]KEYORG = IMPENT

## Zone LIBKEYORG
mkstat = 0
zoncou = "LIBKEYORG"
indice = 0
If varmode([M]LIBKEYORG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LIBKEYORG" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]LIBKEYORG,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "LIBKEYORG" : GZNUM = 11117 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone TYPIRC
mkstat = 0
zoncou = "TYPIRC"
indice = 0
IMPENT = [M]TYPIRC
WNUM = IMPENT
If varinit([M]TYPIRC,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPIRC,indice)=0
 [M]TYPIRC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPIRC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPIRC(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_TYPIRC(IMPENT) From SUBORG
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "TYPIRC" : GZNUM = 680 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_TYPIRC(IMPENT) From SUBORG
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TYPIRC" : GZNUM = 680 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]TYPIRC = IMPENT

## Zone FLGORGCMP
mkstat = 0
zoncou = "FLGORGCMP"
indice = 0
IMPENT = [M]FLGORGCMP
If varinit([M]FLGORGCMP,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGORGCMP,indice)=0
 [M]FLGORGCMP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGORGCMP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGORGCMP(indice)
 Endif
Endif
[M]FLGORGCMP = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone CODSSC
mkstat = 0
zoncou = "CODSSC"
indice = 0
If varmode([M]CODSSC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODSSC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TYPFRM0
mkstat = 0
zoncou = "TYPFRM0"
indice = 0
If varinit([M]TYPFRM0,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]TYPFRM0,"10374","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]TYPFRM0,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "TYPFRM0" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]TYPFRM0,"10374","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TYPFRM0" : GZNUM = 7469 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]TYPFRM0,"10374",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "TYPFRM0" : GZNUM = 7469 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone DUECOD
mkstat = 0
zoncou = "DUECOD"
indice = 0
If varinit([M]DUECOD,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]DUECOD,"10561","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DUECOD,indice)=0
  SAVACT = GACTION : GACTION = "STD"
  Call AS_DUECOD([M]DUECOD) From SUBORG
  GACTION = SAVACT
  If mkstat=1 : Raz [M]DUECOD : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "DUECOD" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]DUECOD,"10561","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DUECOD" : GZNUM = 46889 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","!",[M]DUECOD,"10561",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "DUECOD" : GZNUM = 46889 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone TYPASS
mkstat = 0
zoncou = "TYPASS"
indice = 0
IMPENT = [M]TYPASS
If varinit([M]TYPASS,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPASS,indice)=0
 [M]TYPASS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPASS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPASS(indice)
 Endif
Endif
[M]TYPASS = IMPENT

## Zone NUMASS
mkstat = 0
zoncou = "NUMASS"
indice = 0
If varmode([M]NUMASS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NUMASS" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TYPFRM1
mkstat = 0
zoncou = "TYPFRM1"
indice = 0
If varinit([M]TYPFRM1,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]TYPFRM1,"10375","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]TYPFRM1,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "TYPFRM1" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]TYPFRM1,"10375","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TYPFRM1" : GZNUM = 7469 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]TYPFRM1,"10375",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "TYPFRM1" : GZNUM = 7469 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone NUMDCS
mkstat = 0
zoncou = "NUMDCS"
indice = 0
If varinit([M]NUMDCS,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]NUMDCS,"10340","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]NUMDCS,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "NUMDCS" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]NUMDCS,"10340","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NUMDCS" : GZNUM = 46228 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]NUMDCS,"10340",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "NUMDCS" : GZNUM = 46228 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone TYPFRM2
mkstat = 0
zoncou = "TYPFRM2"
indice = 0
If varinit([M]TYPFRM2,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]TYPFRM2,"10376","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]TYPFRM2,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "TYPFRM2" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]TYPFRM2,"10376","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TYPFRM2" : GZNUM = 7469 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]TYPFRM2,"10376",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "TYPFRM2" : GZNUM = 7469 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 6
####################################
IMPTBL = 1

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"
indice = 0
status = 1
zoncou = "NBRLIG"
If varmode([M]NBRLIG,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBRLIG From SUBORG
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBRLIG : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRLIG = nolign
   status = 75
   Call SAI_NBRLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 6
####################################
Subprog SAI_NBRLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"

## Zone GRPORG
mkstat = 0
zoncou = "GRPORG"
If varmode([M]GRPORG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRPORG" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]GRPORG(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "GRPORG" : GZNUM = 35085 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]GRPORG(indice)
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]GRPORG(indice) = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GRPORG" : GZNUM = 35085 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTORG"
   Call CONTORG([M]GRPORG(indice)) From SUBORG
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "GRPORG" : GZNUM = 35085 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_GRPORG([M]GRPORG(indice)) From SUBORG
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "GRPORG" : GZNUM = 35085 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ORG3"
Return

