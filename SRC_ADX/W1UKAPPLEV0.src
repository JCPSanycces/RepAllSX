#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque UKAPPLEV0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:58"
A_USER  = "DOC"
A_STAMP = "20181109230658"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask UKAPPLEV0 [UAPPLEV0]
Gosub HORODAT
Local Inpbox "UKAPPLEV0" From GFONCTION At A_STAMP With A_WINDPREV Mask [UAPPLEV0] As [SIM_]
Grizo [UAPPLEV0]5
Grizo [UAPPLEV0]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [UAPPLEV0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=74 : Y1(1)=3 : Y2(1)=4
Return

$ON_CPY
Onevent CONTROL Call C_CPY(zc) From W1UKAPPLEV0
Onevent BEFORE_INPUT Call AS_CPY(zc) From W1UKAPPLEV0
Return

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3529,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CPY(zc) From W1UKAPPLEV0
Onkey   2 Titled GBOUTS Call S_CPY(zc) From W1UKAPPLEV0
Onkey 144 Titled GBOUTP Call P_CPY(zc) From W1UKAPPLEV0
Onkey 146 Titled GBOUTA Call SA_CPY(zc) From W1UKAPPLEV0
Gosub _AFF
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
## Action ACONTCPY
Call CONTSOC(VALEUR) From SUBAGF
If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 33782 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CPY","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 33782 : Endif
Endif
Gosub _AFF
End

Subprog S_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "CPY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CPY(VALEUR)
Variable Char    VALEUR()
Call OBJET("CPY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CPY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CPY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_PAYTHR
Onevent INIT_AREA Call D_PAYTHR(zc) From W1UKAPPLEV0
Return

Subprog D_PAYTHR(VALEUR)
Variable Integer VALEUR
If varinit([M]PAYTHR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CURCPY
Onevent CONTROL Call C_CURCPY(zc) From W1UKAPPLEV0
Onevent INIT_AREA Call D_CURCPY(zc) From W1UKAPPLEV0
Onevent BEFORE_INPUT Call AS_CURCPY(zc) From W1UKAPPLEV0
Return

Subprog D_CURCPY(VALEUR)
Variable Integer VALEUR
If varinit([M]CURCPY,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CURCPY(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_CURCPY(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_CURCPY(VALEUR) From SUBUAPPLEV0
If mkstat : GERR = 1 : GZONE = "CURCPY" : GZNUM = 28056 : Endif
Gosub _AFF
End

$ON_ALLCPY
Onevent INIT_AREA Call D_ALLCPY(zc) From W1UKAPPLEV0
Return

Subprog D_ALLCPY(VALEUR)
Variable Integer VALEUR
If varinit([M]ALLCPY,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_RECALC
Onevent INIT_AREA Call D_RECALC(zc) From W1UKAPPLEV0
Return

Subprog D_RECALC(VALEUR)
Variable Integer VALEUR
If varinit([M]RECALC,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


