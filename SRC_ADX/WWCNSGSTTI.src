#<AdxTL>@(#)%I%
# Supervisor
# Inquiry GSTTI

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:08"
A_USER  = "ADMIN"
A_STAMP = "20181109081108"
Return

$DEFAUT
Return

$OUVFIC
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(57283,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSGSTTAXINVSTD"
PROGSPE    = "CNSGSTTAXINVSPE"
CBOITE     = "DCNSGSTTAXI"
BOITE      = "FCNSGSTTAXI"
NOMMSK(0)  = "GSTTAXINV0"
ABMSK(0)   = "GSTTI0"
NOMMSK(1)  = "GSTTAXINV1"
ABMSK(1)   = "GSTTI1"
CMEMO      = "MDTCLS~sel"
CNOMMSK    = "GSTCRITAXINV"
CABMSK     = "GSTCTI"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = ""
NBCMP = 0
CLECMP = "" : CLEMSK = ""
Return

$OUVRE
If clalev([F:DLVBD])=0 : Local File DCLVATBOXDBD [DLVBD] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [GSTCTI]
 When  0 : Local Mask =NOMMSK(0) [GSTTI0]
 When  1 : Local Mask =NOMMSK(1) [GSTTI1]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [GSTCTI]
 When  0 : Grizo [GSTTI0]
 When  1 : Grizo [GSTTI1]
Endcase
Return

$GRISE_CLE
Return

$GRISE_CRIT
If dim([M:GSTCTI]CPY)>0
 Grizo [GSTCTI]CPY
Endif
If dim([M:GSTCTI]STRDAT)>0
 Grizo [GSTCTI]STRDAT
Endif
If dim([M:GSTCTI]ENDDAT)>0
 Grizo [GSTCTI]ENDDAT
Endif
If dim([M:GSTCTI]FCY)>0
 Grizo [GSTCTI]FCY
Endif
If dim([M:GSTCTI]BPR)>0
 Grizo [GSTCTI]BPR
Endif
If dim([M:GSTCTI]VATCOD)>0
 Grizo [GSTCTI]VATCOD
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:GSTCTI])>0 : Close Local Mask [GSTCTI] : Endif
 When  0 : If clalev([M:GSTTI0])>0 : Close Local Mask [GSTTI0] : Endif
 When  1 : If clalev([M:GSTTI1])>0 : Close Local Mask [GSTTI1] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [GSTCTI]
 When  0 : Default Mask [GSTTI0]
 When  1 : Default Mask [GSTTI1]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:GSTCTI]
 When  0 : Raz [M:GSTTI0]
 When  1 : Raz [M:GSTTI1]
Endcase
Return

$CRITENT
If dim([M:GSTCTI]CPY)>0 & dim([M:GSTTI0]CPY)>0
 [M:GSTCTI]CPY = [M:GSTTI0]CPY
Endif
If dim([M:GSTCTI]STRDAT)>0 & dim([M:GSTTI0]STRDAT)>0
 [M:GSTCTI]STRDAT = [M:GSTTI0]STRDAT
Endif
If dim([M:GSTCTI]ENDDAT)>0 & dim([M:GSTTI0]ENDDAT)>0
 [M:GSTCTI]ENDDAT = [M:GSTTI0]ENDDAT
Endif
If dim([M:GSTCTI]FCY)>0 & dim([M:GSTTI0]FCY)>0
 [M:GSTCTI]FCY = [M:GSTTI0]FCY
Endif
If dim([M:GSTCTI]BPR)>0 & dim([M:GSTTI0]BPR)>0
 [M:GSTCTI]BPR = [M:GSTTI0]BPR
Endif
If dim([M:GSTCTI]VATCOD)>0 & dim([M:GSTTI0]VATCOD)>0
 [M:GSTCTI]VATCOD = [M:GSTTI0]VATCOD
Endif
Return

$ENTCRIT
If dim([M:GSTCTI]CPY)>0 & dim([M:GSTTI0]CPY)>0
[M:GSTTI0]CPY = [M:GSTCTI]CPY
Endif
If dim([M:GSTCTI]STRDAT)>0 & dim([M:GSTTI0]STRDAT)>0
[M:GSTTI0]STRDAT = [M:GSTCTI]STRDAT
Endif
If dim([M:GSTCTI]ENDDAT)>0 & dim([M:GSTTI0]ENDDAT)>0
[M:GSTTI0]ENDDAT = [M:GSTCTI]ENDDAT
Endif
If dim([M:GSTCTI]FCY)>0 & dim([M:GSTTI0]FCY)>0
[M:GSTTI0]FCY = [M:GSTCTI]FCY
Endif
If dim([M:GSTCTI]BPR)>0 & dim([M:GSTTI0]BPR)>0
[M:GSTTI0]BPR = [M:GSTCTI]BPR
Endif
If dim([M:GSTCTI]VATCOD)>0 & dim([M:GSTTI0]VATCOD)>0
[M:GSTTI0]VATCOD = [M:GSTCTI]VATCOD
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..6) , CRITAFF2(10)(1..6)
CRITAFF(1) = "CPY" : CRITAFF2(1) = "CPY"
CRITAFF(2) = "STRDAT" : CRITAFF2(2) = "STRDAT"
CRITAFF(3) = "ENDDAT" : CRITAFF2(3) = "ENDDAT"
CRITAFF(4) = "FCY" : CRITAFF2(4) = "FCY"
CRITAFF(5) = "BPR" : CRITAFF2(5) = "BPR"
CRITAFF(6) = "VATCOD" : CRITAFF2(6) = "VATCOD"
NBCA = 6
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1GSTTAXINV1"
NBBOUT = 0
If GBOUT1<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT1
 VALBOUT(NBBOUT) = "GSTTI"
 VALBOUT(NBBOUT) += "~B1"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
If GBOUT2<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT2
 VALBOUT(NBBOUT) = "GSTTI"
 VALBOUT(NBBOUT) += "~B2"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
 When "B1"
  Onerrgo RIEN
  Onerrgo
  Call B1_NBLIG From ="W1GSTTAXINV1"
 When "B2"
  Onerrgo RIEN
  Onerrgo
  Call B2_NBLIG From ="W1GSTTAXINV1"
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


