#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UUACHV62     Utilitaire de migration du module achats     Module ACHAT #
#              d'une version 6.1 vers  une version 6.2                   #
##########################################################################


Call MAJ_UUACHV62
End


Subprog MAJ_UUACHV62
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UUACHV62 - Migration achats Béryl 6.1 vers 6.2") From SAIDOS
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UUACHV62 : Utilitaire de migration achats 6.1 vers 6.2") From LECFIC
  Call EXE_UUACHV62(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UUACHV62(DOSSIER)
Value Char    DOSSIER
#----- Test dossier mère et module achat -----#
If DOSSIER=GDOSX3  End : Endif
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2  End : Endif
#-----
Call ECR_TIME("UUACHV62 : Start folder's process"-DOSSIER) From DOSSUB
Call ECR_TRACE("---------- Update purchasing module release 6.1 to 6.2 ----------",0) From GESECRAN
#----- Chargement globale GMAXUPDTRS -----#
If dim([V]GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =DOSSIER+".ADOVAL" [ADW] 
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]
#-----
If filinfo(filpath("FIL","TABVAT","fde",DOSSIER),0)<0  Goto FIN_UUACHV62 : Endif
If filinfo(filpath("FIL","ACTIV" ,"fde",DOSSIER),0)<0  Goto FIN_UUACHV62 : Endif
#----- Variable locales communes -----#
Local Integer  COMPTEUR, STOP
Local Char     CRITERE(120), WVAT(GLONVAT), WNUMERO(20), WNUMPRE(20), WMESSAGE(100)
Local Integer  WNBR, WNBRCOR, I, WLIGNE
Local Libelle  X : X=3+4*func AFNC.ACTIV("PTX")
Local Decimal  WCLCAMT1, WCLCAMT2, WCLCAMT(1..7)
Local Libelle  WCLCFLG1, WCLCFLG2, WCLCFLG(1..7)
Local Libelle  WTRACE : WTRACE=2 : # 1 = Trace normale, 2 = Trace détaillée
#----- Ouverture tables communes -----#
Local File =DOSSIER+".TABVAT"     [TVT]
Local File =DOSSIER+".ACTIV"      [ACV]
#----- Début du traitement -----#
Gosub TRT_PSH : # Traitement des demandes d'achat
Call ECR_TRACE("-----",0) From GESECRAN
Gosub TRT_POH : # Traitement des commandes d'achat
Call ECR_TRACE("-----",0) From GESECRAN
Gosub TRT_PTH : # Traitement des réceptions
Call ECR_TRACE("-----",0) From GESECRAN
Gosub TRT_PNH : # Traitement des retours fournisseurs
Call ECR_TRACE("-----",0) From GESECRAN
Gosub TRT_PIH : # Traitement des factures d'achat
#----- Fin du traitement -----#
Close Local File [TVT], [ACV]
#-----
$FIN_UUACHV62
Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Call ECR_TIME("UUACHV62 : End folder's process"-DOSSIER) From DOSSUB
End


#----------------------------------------------------------------#
#   Alimentation des nouveaux champs dans les demandes d'achat   #
# -------------------------------------------------------------- #
# Table PREQUISD - Lignes demande d'achat                        #
#   CLCAMT1-7    Base 1-7 calcul taxe                            #
#----------------------------------------------------------------#
$TRT_PSH
#----- Test existence des fichiers -----#
If filinfo(filpath("FIL","PREQUISD","fde",DOSSIER),0)<0  Return : Endif
#-----
Call ECR_TIME("UUACHV62 : Purchase Request Process : Update PREQUISD") From DOSSUB
#----- Ouverture des fichiers -----#
Local File =DOSSIER+".PREQUISD"   [PSD]
#----- Variables locales -----#
Local Char     CLE1(GLONPSH), WPSHNUM(GLONPSH)
Local Integer  CLE2,          WPSDLIN
#-----
Raz CLE1, CLE2, STOP, WNBR, WNBRCOR, WNUMPRE
$BOUCLE_PSD
If  STOP=1
  CRITERE='PSHNUM="'+CLE1+'" & PSDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='PSHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [PSD]
  For [PSD] PSD0 Where evalue(CRITERE)
    WNUMERO=[F:PSD]PSHNUM
    WLIGNE =[F:PSD]PSDLIN
    WPSHNUM=[F:PSD]PSHNUM
    WPSDLIN=[F:PSD]PSDLIN
    If ([F:PSD]CLCAMT1<>0 | [F:PSD]CLCAMT2<>0)
&     & [F:PSD]CLCAMT3=0
&     & [F:PSD]CLCAMT4=0
&     & [F:PSD]CLCAMT5=0
&     & [F:PSD]CLCAMT6=0
&     & [F:PSD]CLCAMT7=0
      Readlock [PSD] Curr
      If fstat
        Call ECR_TRACE("File PREQUISD"-WPSHNUM-num$(WPSDLIN)+", Error ="-num$(fstat),1) From GESECRAN
      Else
        WCLCAMT1=[F:PSD]CLCAMT1 : WCLCFLG1=0
        WCLCAMT2=[F:PSD]CLCAMT2 : WCLCFLG2=0
        Raz WCLCAMT, WCLCFLG
        For I=2 To X
          Case I
            When 2 : WVAT=[F:PSD]VAT(I-1) : Gosub TRT_BASE
            When 3 : WVAT=[F:PSD]VAT(I-1) : Gosub TRT_BASE
            When 4 : WVAT=[F:PSD]TAXRCP   : Gosub TRT_BASE
            When 5 : WVAT=[F:PSD]TAXISS   : Gosub TRT_BASE
            When 6 : WVAT=[F:PSD]TAXOTH1  : Gosub TRT_BASE
            When 7 : WVAT=[F:PSD]TAXOTH2  : Gosub TRT_BASE
          Endcase
        Next I
        If WCLCFLG1 | WCLCFLG2
          If WCLCFLG1  Raz [F:PSD]CLCAMT1 : Endif
          If WCLCFLG2  Raz [F:PSD]CLCAMT2 : Endif
          For I=2 To X
            If WCLCFLG(I)=1
              Assign "[F:PSD]CLCAMT"+num$(I) With WCLCAMT(I)
            Endif
          Next I
          COMPTEUR+=1 : WNBRCOR+=1
          Rewrite [PSD]
          If fstat
            Call ECR_TRACE("File PREQUISD"-WPSHNUM-num$(WPSDLIN)+", Error ="-num$(fstat),1) From GESECRAN
          Endif
        Else
          COMPTEUR+=1
        Endif
      Endif
    Endif
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PSD]PSHNUM : CLE2=[F:PSD]PSDLIN : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PSD : Endif
Close Local File [PSD]
Call ECR_TIME("UUACHV62 : Purchase Request Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
Return


#---------------------------------------------------------------#
#   Alimentation des nouveaux champs dans les commandes d'achat #
# ------------------------------------------------------------- #
# Table PORDERQ - Lignes quantités commandes d'achat            #
#   CLCAMT1-7    Base 1-7 calcul taxe                           #
# Table UPORDERQ - Historique lignes commandes d'achat          #
#   CLCAMT1-7    Base 1-7 calcul taxe                           #
#---------------------------------------------------------------#
$TRT_POH
If filinfo(filpath("FIL","PORDERQ" ,"fde",DOSSIER),0)<0  Return : Endif
If filinfo(filpath("FIL","PORDERP" ,"fde",DOSSIER),0)<0  Return : Endif
#-----
Call ECR_TIME("UUACHV62 : Purchase Order Process : Update PORDERQ") From DOSSUB
#-----
Local File =DOSSIER+".PORDERQ"    [POQ]
Local File =DOSSIER+".PORDERP"    [POP]
#----- Variables locales -----#
Local Char     CLE1(GLONPOH), WPOHNUM(GLONPOH)
Local Integer  CLE2, CLE3,    WPOPLIN, WPOQSEQ
#-----
Raz CLE1, CLE2, CLE3, STOP, WNBR, WNBRCOR, WNUMPRE
$BOUCLE_POQ
If  STOP=1
  CRITERE='POHNUM="'+CLE1+'" & POPLIN='+num$(CLE2)+' & POQSEQ>'+num$(CLE3)
  STOP=2
Elsif STOP=2
  CRITERE='POHNUM="'+CLE1+'" & POPLIN>'+num$(CLE2)
  STOP=3
Elsif STOP=3
  CRITERE='POHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [POQ]
  For [POQ] POQ0 Where evalue(CRITERE)
    WNUMERO=[F:POQ]POHNUM
    WLIGNE =[F:POQ]POPLIN
    WPOHNUM=[F:POQ]POHNUM
    WPOPLIN=[F:POQ]POPLIN
    WPOQSEQ=[F:POQ]POQSEQ
    If ([F:POQ]CLCAMT1<>0 | [F:POQ]CLCAMT2<>0)
&     & [F:POQ]CLCAMT3=0
&     & [F:POQ]CLCAMT4=0
&     & [F:POQ]CLCAMT5=0
&     & [F:POQ]CLCAMT6=0
&     & [F:POQ]CLCAMT7=0
      Readlock [POQ] Curr
      If fstat
        Call ECR_TRACE("File PORDERQ"-WPOHNUM-num$(WPOPLIN)+", Error ="-num$(fstat),1) From GESECRAN
      Else
        #----- Lecture ligne commande prix -----#
        If [F:POQ]POHTYP=1
          Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1 : If fstat  Raz [F:POP] : Endif
        Else
          Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPDAT>=[F:POQ]DEMRCPDAT
          Read [POP] POP1 First : If fstat  Raz [F:POP] : Endif
          Filter [POP]
        Endif
        #-----
        WCLCAMT1=[F:POQ]CLCAMT1 : WCLCFLG1=0
        WCLCAMT2=[F:POQ]CLCAMT2 : WCLCFLG2=0
        Raz WCLCAMT, WCLCFLG
        For I=2 To X
          Case I
            When 2 : WVAT=[F:POP]VAT(I-1) : Gosub TRT_BASE
            When 3 : WVAT=[F:POP]VAT(I-1) : Gosub TRT_BASE
            When 4 : WVAT=[F:POP]TAXRCP   : Gosub TRT_BASE
            When 5 : WVAT=[F:POP]TAXISS   : Gosub TRT_BASE
            When 6 : WVAT=[F:POP]TAXOTH1  : Gosub TRT_BASE
            When 7 : WVAT=[F:POP]TAXOTH2  : Gosub TRT_BASE
          Endcase
        Next I
        If WCLCFLG1 | WCLCFLG2
          If WCLCFLG1  Raz [F:POQ]CLCAMT1 : Endif
          If WCLCFLG2  Raz [F:POQ]CLCAMT2 : Endif
          For I=2 To X
            If WCLCFLG(I)=1
              Assign "[F:POQ]CLCAMT"+num$(I) With WCLCAMT(I)
            Endif
          Next I
          COMPTEUR+=1 : WNBRCOR+=1
          Rewrite [POQ]
          If fstat
            Call ECR_TRACE("File PORDERQ"-WPOHNUM-num$(WPOPLIN)+", Error ="-num$(fstat),1) From GESECRAN
          Endif
        Else
          COMPTEUR+=1
        Endif
      Endif
    Endif
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:POQ]POHNUM : CLE2=[F:POQ]POPLIN : CLE3=[F:POQ]POQSEQ : STOP=1 : Break
    Endif
  Next
Commit
If STOP Goto BOUCLE_POQ : Endif
Close Local File [POQ], [POP]
Call ECR_TIME("UUACHV62 : Purchase Order Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
#-----
Call ECR_TRACE("-----",0) From GESECRAN
#-----
If filinfo(filpath("FIL","UPORDERQ" ,"fde",DOSSIER),0)<0  Return : Endif
If filinfo(filpath("FIL","UPORDERP" ,"fde",DOSSIER),0)<0  Return : Endif
#-----
Call ECR_TIME("UUACHV62 : History Purchase Order Process : Update UPORDERQ") From DOSSUB
#-----
Local File =DOSSIER+".UPORDERQ"   [UOQ]
Local File =DOSSIER+".UPORDERP"   [UOP]
Local File =DOSSIER+".PORDERP"    [POP]
#----- Variables locales -----#
Local Integer  CLE4,    WLINREVNUM
#-----
Raz CLE1, CLE2, CLE3, CLE4, STOP, WNBR, WNBRCOR, WNUMPRE
$BOUCLE_UOQ
If  STOP=1
  CRITERE='POHNUM="'+CLE1+'" & REVNUM='+num$(CLE2)+' & POPLIN='+num$(CLE3)+' & POQSEQ>'+num$(CLE4)
  STOP=2
Elsif STOP=2
  CRITERE='POHNUM="'+CLE1+'" & REVNUM='+num$(CLE2)+' & POPLIN>'+num$(CLE3)
  STOP=3
Elsif STOP=3
  CRITERE='POHNUM="'+CLE1+'" & REVNUM>'+num$(CLE2)
  STOP=4
Elsif STOP=4
  CRITERE='POHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [UOQ]
  For [UOQ] POQ0 Where evalue(CRITERE)
    WNUMERO   =[F:UOQ]POHNUM
    WLIGNE    =[F:UOQ]POPLIN
    WPOHNUM   =[F:UOQ]POHNUM
    WLINREVNUM=[F:UOQ]LINREVNUM
    WPOPLIN   =[F:UOQ]POPLIN
    WPOQSEQ   =[F:UOQ]POQSEQ
    If ([F:UOQ]CLCAMT1<>0 | [F:UOQ]CLCAMT2<>0)
&     & [F:UOQ]CLCAMT3=0
&     & [F:UOQ]CLCAMT4=0
&     & [F:UOQ]CLCAMT5=0
&     & [F:UOQ]CLCAMT6=0
&     & [F:UOQ]CLCAMT7=0
      Readlock [UOQ] Curr
      If fstat
        Call ECR_TRACE("File UPORDERQ"-WPOHNUM-num$(WLINREVNUM)+", Error ="-num$(fstat),1) From GESECRAN
      Else
        #----- Lecture ligne commande prix -----#
        If [F:UOQ]POHTYP=1
          Read [UOP] POP0=[F:UOQ]POHNUM;[F:UOQ]POPLIN;1
          If fstat
            Read [POP] POP0=[F:UOQ]POHNUM;[F:UOQ]POPLIN;1 : If fstat  Raz [F:POP] : Endif
          Else
            [F:POP]=[F:UOP]
          Endif
        Else
          Filter [UOP] Where POHNUM=[F:UOQ]POHNUM & POPLIN=[F:UOQ]POPLIN & POPDAT>=[F:UOQ]DEMRCPDAT
          Read [UOP] POP1 First
          Filter [UOP]
          If fstat
            Filter [POP] Where POHNUM=[F:UOQ]POHNUM & POPLIN=[F:UOQ]POPLIN & POPDAT>=[F:UOQ]DEMRCPDAT
            Read [POP] POP1 First
            Filter [POP]
          Else
            [F:POP]=[F:UOP]
          Endif
        Endif
        #-----
        WCLCAMT1=[F:UOQ]CLCAMT1 : WCLCFLG1=0
        WCLCAMT2=[F:UOQ]CLCAMT2 : WCLCFLG2=0
        Raz WCLCAMT, WCLCFLG
        For I=2 To X
          Case I
            When 2 : WVAT=[F:POP]VAT(I-1) : Gosub TRT_BASE
            When 3 : WVAT=[F:POP]VAT(I-1) : Gosub TRT_BASE
            When 4 : WVAT=[F:POP]TAXRCP   : Gosub TRT_BASE
            When 5 : WVAT=[F:POP]TAXISS   : Gosub TRT_BASE
            When 6 : WVAT=[F:POP]TAXOTH1  : Gosub TRT_BASE
            When 7 : WVAT=[F:POP]TAXOTH2  : Gosub TRT_BASE
          Endcase
        Next I
        If WCLCFLG1 | WCLCFLG2
          If WCLCFLG1  Raz [F:UOQ]CLCAMT1 : Endif
          If WCLCFLG2  Raz [F:UOQ]CLCAMT2 : Endif
          For I=2 To X
            If WCLCFLG(I)=1
              Assign "[F:UOQ]CLCAMT"+num$(I) With WCLCAMT(I)
            Endif
          Next I
          COMPTEUR+=1 : WNBRCOR+=1
          Rewrite [UOQ]
          If fstat
            Call ECR_TRACE("File UPORDERQ"-WPOHNUM-num$(WLINREVNUM)+", Error ="-num$(fstat),1) From GESECRAN
          Endif
        Else
          COMPTEUR+=1
        Endif
      Endif
    Endif
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:UOQ]POHNUM : CLE2=[F:UOQ]LINREVNUM : CLE3=[F:UOQ]POPLIN : CLE4=[F:UOQ]POQSEQ : STOP=1 : Break
    Endif
  Next
Commit
If STOP Goto BOUCLE_UOQ : Endif
Close Local File [UOQ], [UOP], [POP]
Call ECR_TIME("UUACHV62 : History Purchase Order Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
Return

#-----------------------------------------------------------#
#   Alimentation des nouveaux champs dans les réceptions    #
# --------------------------------------------------------- #
# Table PRECEIPTD - Lignes de réception                     #
#   CLCAMT1-7    Base 1-7 calcul taxe                       #
#-----------------------------------------------------------#
$TRT_PTH
#----- Test existence des fichiers -----#
If filinfo(filpath("FIL","PRECEIPTD","fde",DOSSIER),0)<0  Return : Endif
#-----
Call ECR_TIME("UUACHV62 : Purchase Receipt Process : Update PRECEIPTD") From DOSSUB
#----- Ouverture des fichiers -----#
Local File =DOSSIER+".PRECEIPTD"   [PTD]
#----- Variables locales -----#
Local Char     CLE1(GLONPTH), WPTHNUM(GLONPTH)
Local Integer  CLE2,          WPTDLIN
#-----
Raz CLE1, CLE2, STOP, WNBR, WNBRCOR, WNUMPRE
$BOUCLE_PTD
If  STOP=1
  CRITERE='PTHNUM="'+CLE1+'" & PTDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='PTHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [PTD]
  For [PTD] PTD0 Where evalue(CRITERE)
    WNUMERO=[F:PTD]PTHNUM
    WLIGNE =[F:PTD]PTDLIN
    WPTHNUM=[F:PTD]PTHNUM
    WPTDLIN=[F:PTD]PTDLIN
    If ([F:PTD]CLCAMT1<>0 | [F:PTD]CLCAMT2<>0)
&     & [F:PTD]CLCAMT3=0
&     & [F:PTD]CLCAMT4=0
&     & [F:PTD]CLCAMT5=0
&     & [F:PTD]CLCAMT6=0
&     & [F:PTD]CLCAMT7=0
      Readlock [PTD] Curr
      If fstat
        Call ECR_TRACE("File PRECEIPTD"-WPTHNUM-num$(WPTDLIN)+", Error ="-num$(fstat),1) From GESECRAN
      Else
        WCLCAMT1=[F:PTD]CLCAMT1 : WCLCFLG1=0
        WCLCAMT2=[F:PTD]CLCAMT2 : WCLCFLG2=0
        Raz WCLCAMT, WCLCFLG
        For I=2 To X
          Case I
            When 2 : WVAT=[F:PTD]VAT(I-1) : Gosub TRT_BASE
            When 3 : WVAT=[F:PTD]VAT(I-1) : Gosub TRT_BASE
            When 4 : WVAT=[F:PTD]TAXRCP   : Gosub TRT_BASE
            When 5 : WVAT=[F:PTD]TAXISS   : Gosub TRT_BASE
            When 6 : WVAT=[F:PTD]TAXOTH1  : Gosub TRT_BASE
            When 7 : WVAT=[F:PTD]TAXOTH2  : Gosub TRT_BASE
          Endcase
        Next I
        If WCLCFLG1 | WCLCFLG2
          If WCLCFLG1  Raz [F:PTD]CLCAMT1 : Endif
          If WCLCFLG2  Raz [F:PTD]CLCAMT2 : Endif
          For I=2 To X
            If WCLCFLG(I)=1
              Assign "[F:PTD]CLCAMT"+num$(I) With WCLCAMT(I)
            Endif
          Next I
          COMPTEUR+=1 : WNBRCOR+=1
          Rewrite [PTD]
          If fstat
            Call ECR_TRACE("File PRECEIPTD"-WPTHNUM-num$(WPTDLIN)+", Error ="-num$(fstat),1) From GESECRAN
          Endif
        Else
          COMPTEUR+=1
        Endif
      Endif
    Endif
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PTD]PTHNUM : CLE2=[F:PTD]PTDLIN : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PTD : Endif
Close Local File [PTD]
Call ECR_TIME("UUACHV62 : Purchase Receipt Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
Return


#----------------------------------------------------------------#
# Alimentation des nouveaux champs dans les retours fournisseurs #
# -------------------------------------------------------------- #
# Table PRETURND - Lignes de retour fournisseur                  #
#   CLCAMT1-7    Base 1-7 calcul taxe                            #
#----------------------------------------------------------------#
$TRT_PNH
#----- Test existence des fichiers -----#
If filinfo(filpath("FIL","PRETURND","fde",DOSSIER),0)<0  Return : Endif
#-----
Call ECR_TIME("UUACHV62 : Purchase Return Process : Update PRETURND") From DOSSUB
#----- Ouverture des fichiers -----#
Local File =DOSSIER+".PRETURND"   [PND]
#----- Variables locales -----#
Local Char     CLE1(GLONPNH), WPNHNUM(GLONPNH)
Local Integer  CLE2,          WPNDLIN
#-----
Raz CLE1, CLE2, STOP, WNBR, WNBRCOR, WNUMPRE
$BOUCLE_PND
If  STOP=1
  CRITERE='PNHNUM="'+CLE1+'" & PNDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='PNHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [PND]
  For [PND] PND0 Where evalue(CRITERE)
    WNUMERO=[F:PND]PNHNUM
    WLIGNE =[F:PND]PNDLIN
    WPNHNUM=[F:PND]PNHNUM
    WPNDLIN=[F:PND]PNDLIN
    If ([F:PND]CLCAMT1<>0 | [F:PND]CLCAMT2<>0)
&     & [F:PND]CLCAMT3=0
&     & [F:PND]CLCAMT4=0
&     & [F:PND]CLCAMT5=0
&     & [F:PND]CLCAMT6=0
&     & [F:PND]CLCAMT7=0
      Readlock [PND] Curr
      If fstat
        Call ECR_TRACE("File PRETURND"-WPNHNUM-num$(WPNDLIN)+", Error ="-num$(fstat),1) From GESECRAN
      Else
        WCLCAMT1=[F:PND]CLCAMT1 : WCLCFLG1=0
        WCLCAMT2=[F:PND]CLCAMT2 : WCLCFLG2=0
        Raz WCLCAMT, WCLCFLG
        For I=2 To X
          Case I
            When 2 : WVAT=[F:PND]VAT(I-1) : Gosub TRT_BASE
            When 3 : WVAT=[F:PND]VAT(I-1) : Gosub TRT_BASE
            When 4 : WVAT=[F:PND]TAXRCP   : Gosub TRT_BASE
            When 5 : WVAT=[F:PND]TAXISS   : Gosub TRT_BASE
            When 6 : WVAT=[F:PND]TAXOTH1  : Gosub TRT_BASE
            When 7 : WVAT=[F:PND]TAXOTH2  : Gosub TRT_BASE
          Endcase
        Next I
        If WCLCFLG1 | WCLCFLG2
          If WCLCFLG1  Raz [F:PND]CLCAMT1 : Endif
          If WCLCFLG2  Raz [F:PND]CLCAMT2 : Endif
          For I=2 To X
            If WCLCFLG(I)=1
              Assign "[F:PND]CLCAMT"+num$(I) With WCLCAMT(I)
            Endif
          Next I
          COMPTEUR+=1 : WNBRCOR+=1
          Rewrite [PND]
          If fstat
            Call ECR_TRACE("File PRETURND"-WPNHNUM-num$(WPNDLIN)+", Error ="-num$(fstat),1) From GESECRAN
          Endif
        Else
          COMPTEUR+=1
        Endif
      Endif
    Endif
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PND]PNHNUM : CLE2=[F:PND]PNDLIN : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PND : Endif
Close Local File [PND]
Call ECR_TIME("UUACHV62 : Purchase Return Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
Return


#----------------------------------------------------------------#
#   Alimentation des nouveaux champs dans les factures d'achat   #
# -------------------------------------------------------------- #
# Table PINVOICED - Lignes factures d'achat                      #
#   CLCAMT1-7    Base 1-7 calcul taxe                            #
#----------------------------------------------------------------#
$TRT_PIH
#----- Test existence des fichiers -----#
If filinfo(filpath("FIL","PINVOICED","fde",DOSSIER),0)<0  Return : Endif
#-----
Call ECR_TIME("UUACHV62 : Purchase Invoice Process : Update PINVOICED") From DOSSUB
#----- Ouverture des fichiers -----#
Local File =DOSSIER+".PINVOICED"   [PID]
#----- Variables locales -----#
Local Char     CLE1(GLONPIH), WNUM(GLONPIH)
Local Integer  CLE2,          WPIDLIN
#-----
Raz CLE1, CLE2, STOP, WNBR, WNBRCOR, WNUMPRE
$BOUCLE_PID
If  STOP=1
  CRITERE='NUM="'+CLE1+'" & PIDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='NUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [PID]
  For [PID] PID0 Where evalue(CRITERE)
    WNUMERO=[F:PID]NUM
    WLIGNE =[F:PID]PIDLIN
    WNUM   =[F:PID]NUM
    WPIDLIN=[F:PID]PIDLIN
    If ([F:PID]CLCAMT1<>0 | [F:PID]CLCAMT2<>0)
&     & [F:PID]CLCAMT3=0
&     & [F:PID]CLCAMT4=0
&     & [F:PID]CLCAMT5=0
&     & [F:PID]CLCAMT6=0
&     & [F:PID]CLCAMT7=0
      Readlock [PID] Curr
      If fstat
        Call ECR_TRACE("File PINVOICED"-WNUM-num$(WPIDLIN)+", Error ="-num$(fstat),1) From GESECRAN
      Else
        WCLCAMT1=[F:PID]CLCAMT1 : WCLCFLG1=0
        WCLCAMT2=[F:PID]CLCAMT2 : WCLCFLG2=0
        Raz WCLCAMT, WCLCFLG
        For I=2 To X
          Case I
            When 2 : WVAT=[F:PID]VAT(I-1) : Gosub TRT_BASE
            When 3 : WVAT=[F:PID]VAT(I-1) : Gosub TRT_BASE
            When 4 : WVAT=[F:PID]TAXRCP   : Gosub TRT_BASE
            When 5 : WVAT=[F:PID]TAXISS   : Gosub TRT_BASE
            When 6 : WVAT=[F:PID]TAXOTH1  : Gosub TRT_BASE
            When 7 : WVAT=[F:PID]TAXOTH2  : Gosub TRT_BASE
          Endcase
        Next I
        If WCLCFLG1 | WCLCFLG2
          If WCLCFLG1  Raz [F:PID]CLCAMT1 : Endif
          If WCLCFLG2  Raz [F:PID]CLCAMT2 : Endif
          For I=2 To X
            If WCLCFLG(I)=1
              Assign "[F:PID]CLCAMT"+num$(I) With WCLCAMT(I)
            Endif
          Next I
          COMPTEUR+=1 : WNBRCOR+=1
          Rewrite [PID]
          If fstat
            Call ECR_TRACE("File PINVOICED"-WNUM-num$(WPIDLIN)+", Error ="-num$(fstat),1) From GESECRAN
          Endif
        Else
          COMPTEUR+=1
        Endif
      Endif
    Endif
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PID]NUM : CLE2=[F:PID]PIDLIN : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PID : Endif
Close Local File [PID]
Call ECR_TIME("UUACHV62 : Purchase Invoice Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
Return


##################################
# Traitement des bases spéciales #
##################################
$TRT_BASE
If [F:TVT]VAT<>WVAT
  Read [TVT] TVT0=WVAT : If fstat  Raz [F:TVT] : Endif
Endif
If [F:TVT]VATBAS=2 & WCLCAMT1<>0
  WCLCFLG1=1 : WCLCAMT(I)=WCLCAMT1 : WCLCFLG(I)=1
  If WTRACE=2
    If WNUMERO<>WNUMPRE
      WMESSAGE =WNUMERO+space$(max(GLONVCR-len(WNUMERO),0))+space$(max(6-len(num$(WLIGNE)),0))+num$(WLIGNE)
    Else
      WMESSAGE =space$(GLONVCR)+space$(max(6-len(num$(WLIGNE)),0))+num$(WLIGNE)
    Endif
    WMESSAGE+=" :"+space$(13-len(format$("N:9.2",WCLCAMT1)))+format$("N:9.2",WCLCAMT1)
    WMESSAGE+="  CLCAMT1 --> CLCAMT"+num$(I)
    Call ECR_TRACE(WMESSAGE,0) From GESECRAN
    WNUMPRE=WNUMERO
  Endif
Endif
If [F:TVT]VATBAS=3 & WCLCAMT2<>0
  WCLCFLG2=1 : WCLCAMT(I)=WCLCAMT2 : WCLCFLG(I)=1
  If WTRACE=2
    If WNUMERO<>WNUMPRE
      WMESSAGE =WNUMERO+space$(max(GLONVCR-len(WNUMERO),0))+space$(max(6-len(num$(WLIGNE)),0))+num$(WLIGNE)
    Else
      WMESSAGE =space$(GLONVCR)+space$(max(6-len(num$(WLIGNE)),0))+num$(WLIGNE)
    Endif
    WMESSAGE+=" :"+space$(13-len(format$("N:9.2",WCLCAMT2)))+format$("N:9.2",WCLCAMT2)
    WMESSAGE+="  CLCAMT2 --> CLCAMT"+num$(I)
    Call ECR_TRACE(WMESSAGE,0) From GESECRAN
    WNUMPRE=WNUMERO
  Endif
Endif
Return


####################
# Appel par un EXE #
####################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call EXE_UUACHV62(DOSSIER)
Endif
#-----
End


#########################################################
# Pour exécution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call EXE_UUACHV62(DOSSIER)
Endif
#-----
End
