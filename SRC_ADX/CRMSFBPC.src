#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################################
# Subprogram for Salesforce to create and maintain customers in X3
####################################################################################################

Subprog SAVECUSTOMER(CUSTOMERNUMBER,
&                    CUSTOMERNAME,
&                    CUSTOMERPHONE,
&                    CUSTOMERFAX,
&                    CUSTOMERWEBSITE,
&                    CUSTOMERCOUNTRYCODE,
&                    CUSTOMERBILLINGADDRESSNUMBER,
&                    CUSTOMERBILLINGADDRESS,
&                    CUSTOMERBILLINGCITY,
&                    CUSTOMERBILLINGPROVINCECODE,
&                    CUSTOMERBILLINGPOSTALCODE,
&                    CUSTOMERBILLINGCOUNTRYCODE,
&                    CUSTOMERSHIPPINGADDRESSNUMBER,
&                    CUSTOMERSHIPPINGADDRESS,
&                    CUSTOMERSHIPPINGCITY,
&                    CUSTOMERSHIPPINGPROVINCECODE,
&                    CUSTOMERSHIPPINGPOSTALCODE,
&                    CUSTOMERSHIPPINGCOUNTRYCODE,
&                    CONTACTNUMBER,
&                    CONTACTFIRSTNAME,
&                    CONTACTLASTNAME,
&                    CONTACTPHONE,
&                    CONTACTFAX,
&                    CONTACTEMAIL,
&                    CONTACTMAILINGADDRESSNUMBER,
&                    CONTACTMAILINGADDRESS,
&                    CONTACTMAILINGCITY,
&                    CONTACTMAILINGPROVINCECODE,
&                    CONTACTMAILINGPOSTALCODE,
&                    CONTACTMAILINGCOUNTRYCODE,
&                    RESPONSESTATUS,
&                    RESPONSEMESSAGES,
&                    LBLCUSTOMERNUMBER,
&                    LBLCUSTOMERNAME,
&                    LBLCUSTOMERPHONE,
&                    LBLCUSTOMERFAX,
&                    LBLCUSTOMERWEBSITE,
&                    LBLCUSTOMERCOUNTRYCODE,
&                    LBLCUSTOMERBILLINGADDRESSNUM,
&                    LBLCUSTOMERBILLINGADDRESS,
&                    LBLCUSTOMERBILLINGCITY,
&                    LBLCUSTOMERBILLINGPROVINCECODE,
&                    LBLCUSTOMERBILLINGPOSTALCODE,
&                    LBLCUSTOMERBILLINGCOUNTRYCODE,
&                    LBLCUSTOMERSHIPPINGADDRESSNUM,
&                    LBLCUSTOMERSHIPPINGADDRESS,
&                    LBLCUSTOMERSHIPPINGCITY,
&                    LBLCUSTOMERSHIPPINGPROVINCECOD,
&                    LBLCUSTOMERSHIPPINGPOSTALCODE,
&                    LBLCUSTOMERSHIPPINGCOUNTRYCODE,
&                    LBLCONTACTNUMBER,
&                    LBLCONTACTFIRSTNAME,
&                    LBLCONTACTLASTNAME,
&                    LBLCONTACTPHONE,
&                    LBLCONTACTFAX,
&                    LBLCONTACTEMAIL,
&                    LBLCONTACTMAILINGADDRESSNUMBER,
&                    LBLCONTACTMAILINGADDRESS,
&                    LBLCONTACTMAILINGCITY,
&                    LBLCONTACTMAILINGPROVINCECODE,
&                    LBLCONTACTMAILINGPOSTALCODE,
&                    LBLCONTACTMAILINGCOUNTRYCODE)

  Variable Char CUSTOMERNUMBER
  Variable Char CUSTOMERNAME
  Variable Char CUSTOMERPHONE
  Variable Char CUSTOMERFAX
  Variable Char CUSTOMERWEBSITE
  Variable Char CUSTOMERCOUNTRYCODE

  Variable Char CUSTOMERBILLINGADDRESSNUMBER
  Variable Char CUSTOMERBILLINGADDRESS
  Variable Char CUSTOMERBILLINGCITY
  Variable Char CUSTOMERBILLINGPROVINCECODE
  Variable Char CUSTOMERBILLINGPOSTALCODE
  Variable Char CUSTOMERBILLINGCOUNTRYCODE

  Variable Char CUSTOMERSHIPPINGADDRESSNUMBER
  Variable Char CUSTOMERSHIPPINGADDRESS
  Variable Char CUSTOMERSHIPPINGCITY
  Variable Char CUSTOMERSHIPPINGPROVINCECODE
  Variable Char CUSTOMERSHIPPINGPOSTALCODE
  Variable Char CUSTOMERSHIPPINGCOUNTRYCODE

  Variable Char CONTACTNUMBER()(1..)
  Variable Char CONTACTFIRSTNAME()(1..)
  Variable Char CONTACTLASTNAME()(1..)
  Variable Char CONTACTPHONE()(1..)
  Variable Char CONTACTFAX()(1..)
  Variable Char CONTACTEMAIL()(1..)

  Variable Char CONTACTMAILINGADDRESSNUMBER()(1..)
  Variable Char CONTACTMAILINGADDRESS()(1..)
  Variable Char CONTACTMAILINGCITY()(1..)
  Variable Char CONTACTMAILINGPROVINCECODE()(1..)
  Variable Char CONTACTMAILINGPOSTALCODE()(1..)
  Variable Char CONTACTMAILINGCOUNTRYCODE()(1..)

  Variable Integer RESPONSESTATUS
  Variable Char    RESPONSEMESSAGES()(1..)

  Variable Char LBLCUSTOMERNUMBER
  Variable Char LBLCUSTOMERNAME
  Variable Char LBLCUSTOMERPHONE
  Variable Char LBLCUSTOMERFAX
  Variable Char LBLCUSTOMERWEBSITE
  Variable Char LBLCUSTOMERCOUNTRYCODE

  Variable Char LBLCUSTOMERBILLINGADDRESSNUM
  Variable Char LBLCUSTOMERBILLINGADDRESS
  Variable Char LBLCUSTOMERBILLINGCITY
  Variable Char LBLCUSTOMERBILLINGPROVINCECODE
  Variable Char LBLCUSTOMERBILLINGPOSTALCODE
  Variable Char LBLCUSTOMERBILLINGCOUNTRYCODE

  Variable Char LBLCUSTOMERSHIPPINGADDRESSNUM
  Variable Char LBLCUSTOMERSHIPPINGADDRESS
  Variable Char LBLCUSTOMERSHIPPINGCITY
  Variable Char LBLCUSTOMERSHIPPINGPROVINCECOD
  Variable Char LBLCUSTOMERSHIPPINGPOSTALCODE
  Variable Char LBLCUSTOMERSHIPPINGCOUNTRYCODE

  Variable Char LBLCONTACTNUMBER
  Variable Char LBLCONTACTFIRSTNAME
  Variable Char LBLCONTACTLASTNAME
  Variable Char LBLCONTACTPHONE
  Variable Char LBLCONTACTFAX
  Variable Char LBLCONTACTEMAIL

  Variable Char LBLCONTACTMAILINGADDRESSNUMBER
  Variable Char LBLCONTACTMAILINGADDRESS
  Variable Char LBLCONTACTMAILINGCITY
  Variable Char LBLCONTACTMAILINGPROVINCECODE
  Variable Char LBLCONTACTMAILINGPOSTALCODE
  Variable Char LBLCONTACTMAILINGCOUNTRYCODE

  # Environment
  Local Char    WEBSERVICELANGUAGE(GLONLAN) : WEBSERVICELANGUAGE = GLANGUE
  Local Char    ERRMSG(255)

  # Customer
  Local Char    CUSTOMERCATEGORY(GLONBCG)
  Local Char    CUSTOMERBILLINGADDRESS1(GLONADL)
  Local Char    CUSTOMERBILLINGADDRESS2(GLONADL)
  Local Char    CUSTOMERBILLINGADDRESS3(GLONADL)
  Local Char    CUSTOMERSHIPPINGADDRESS1(GLONADL)
  Local Char    CUSTOMERSHIPPINGADDRESS2(GLONADL)
  Local Char    CUSTOMERSHIPPINGADDRESS3(GLONADL)
  Local Char    CONTACTMAILINGADDRESS1(GLONADL)(dim(CONTACTMAILINGADDRESS))
  Local Char    CONTACTMAILINGADDRESS2(GLONADL)(dim(CONTACTMAILINGADDRESS))
  Local Char    CONTACTMAILINGADDRESS3(GLONADL)(dim(CONTACTMAILINGADDRESS))

  # Used across gosubs
  Local Char    FUNCTION(30) : FUNCTION = "soapSave"
  Local Clbfile ARGUMENTS
  Local Clbfile RESBODY

  # Logging across gosubs
  Local Instance MYLOG Using C_ALOG
  MYLOG=NewInstance C_ALOG AllocGroup null
  OK=fmet MYLOG.ABEGINLOG("CRMSFBPCS"-mess(3,7845,1))
  OK=fmet MYLOG.APUTLINE("Saving customer"-CUSTOMERNAME-"from Salesforce",OK)   # TODO translation
  OK=fmet MYLOG.AFLUSHLOG

  Gosub DATARECEIVED

  Gosub BUILDXMLSAVE
  If ERRMSG <> ""
     RESPONSEMESSAGES(1) = ERRMSG
  Else
    Gosub CALLBUNDLE From CRMSF
    If ERRMSG <> ""
      RESPONSEMESSAGES(1) = ERRMSG
    Else
      RESPONSESTATUS = func CRMSF.GETRESPONSESTATUS(RESBODY)
      If RESPONSESTATUS=0
        Gosub LOADRESPONSES From CRMSF
      Else
        Gosub PROCESSRETURNEDXML
        If ERRMSG <> ""
          RESPONSESTATUS = 0
          RESPONSEMESSAGES(1) = ERRMSG
        Else
           OK=fmet MYLOG.APUTLINE("Saved customer"-CUSTOMERNAME-"from Salesforce as"-CUSTOMERNUMBER,OK) : OK = fmet MYLOG.AFLUSHLOG    # TODO translation
       Endif
      Endif
    Endif
  Endif

  # End logging
  OK = fmet MYLOG.AENDLOG
  FreeGroup MYLOG

End

####################################################################################################

$BUILDXMLSAVE

  Local Integer LOOP
  Local Integer ERR
  Local Clbfile COUNTRYXML
  Local Integer ADDRESSLINES
  Local Clbfile ADDRESSESXML
  Local Char    ADDRESSCODE(GLONADR)
  Local Integer SHIPTOADDRESSLINES
  Local Clbfile SHIPTOXML
  Local Integer CONTACTLINES
  Local Clbfile CONTACTSXML
  Local Char    CONTACTNUM(GLONCNT)


  # Get default Customer category from SFCRMCAT parameter
  Call PARAM("", "SFCRMCAT", CUSTOMERCATEGORY) From ADOVAL
  If CUSTOMERCATEGORY = ""
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000103", mess(74,9005,1), "", "SFCRMCAT")
    Return
  Endif

  # Get country code from category.
  If clalev([F:BCG]) = 0 : Local File BPCCATEG [BCG] : Endif
  Read [F:BCG]BCG0=CUSTOMERCATEGORY
  If !fstat
    CUSTOMERCOUNTRYCODE = [F:BCG]CRY
  Else
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000102", mess(23,100,1), CUSTOMERCATEGORY, func CRMSF.GETLABEL("BPC0", "BCGCOD"))
    Return
  Endif

  # Get values based on country
  COUNTRYXML = func GETCOUNTRYXML(CUSTOMERCOUNTRYCODE, ERRMSG)
  If ERRMSG <> "" : Return : Endif

  # Get next customer number from SFBPC sequence
  Call NUMERO("SFBPC", "", date$, "", CUSTOMERNUMBER, ERR) From SUBANM
  If ERR
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000104", mess(83,134,1), "", "SFBPC")
    Return
  Endif
  CUSTOMERNUMBER = "SF-" + CUSTOMERCOUNTRYCODE + "-" + right$(CUSTOMERNUMBER, len("SF-" + CUSTOMERCOUNTRYCODE + "-")+1)

  # Build customer addresses
  ADDRESSLINES = 1
  If CUSTOMERBILLINGADDRESS > ""
    Call PARSEADDRESS(CUSTOMERBILLINGADDRESS, CUSTOMERBILLINGADDRESS1, CUSTOMERBILLINGADDRESS2, CUSTOMERBILLINGADDRESS3) From CRMSF
    ADDRESSESXML += func BUILDADDRESSXML("BILL", ADDRESSLINES, CUSTOMERBILLINGADDRESS1, CUSTOMERBILLINGADDRESS2, CUSTOMERBILLINGADDRESS3,
&                                      CUSTOMERBILLINGCITY, CUSTOMERBILLINGPROVINCECODE, CUSTOMERBILLINGPOSTALCODE, CUSTOMERBILLINGCOUNTRYCODE,
&                                      CUSTOMERPHONE, CUSTOMERFAX, CUSTOMERWEBSITE)
  Else
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000105", mess(6,136,1), "", func AFNC.TEXTE(100437))
    Return
  Endif

  # If there is no shipping address then use billing information
  ADDRESSLINES = 2
  If CUSTOMERSHIPPINGADDRESS > ""
    Call PARSEADDRESS(CUSTOMERSHIPPINGADDRESS, CUSTOMERSHIPPINGADDRESS1, CUSTOMERSHIPPINGADDRESS2, CUSTOMERSHIPPINGADDRESS3) From CRMSF
    ADDRESSESXML += func BUILDADDRESSXML("SHIP", ADDRESSLINES, CUSTOMERSHIPPINGADDRESS1, CUSTOMERSHIPPINGADDRESS2, CUSTOMERSHIPPINGADDRESS3,
&                                      CUSTOMERSHIPPINGCITY, CUSTOMERSHIPPINGPROVINCECODE, CUSTOMERSHIPPINGPOSTALCODE, CUSTOMERSHIPPINGCOUNTRYCODE, "", "", "")
  Else
    ADDRESSESXML += func BUILDADDRESSXML("SHIP", ADDRESSLINES, CUSTOMERBILLINGADDRESS1, CUSTOMERBILLINGADDRESS2, CUSTOMERBILLINGADDRESS3,
&                                      CUSTOMERBILLINGCITY, CUSTOMERBILLINGPROVINCECODE, CUSTOMERBILLINGPOSTALCODE, CUSTOMERBILLINGCOUNTRYCODE,
&                                      CUSTOMERPHONE, CUSTOMERFAX, CUSTOMERWEBSITE)
  Endif

  # Build contacts and their addresses
  For LOOP = 1 To dim(CONTACTLASTNAME)
    If CONTACTLASTNAME(LOOP) > ""
      ADDRESSCODE = ""
      Call NUMERO("SFCCN", "", date$, "", CONTACTNUM, ERR) From SUBANM
      If ERR
        ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000104", mess(83,134,1), "", "SFCCN")
        Break
      Endif

      # Build XML for contact addresses
      If CONTACTMAILINGCITY(LOOP) > ""
        ADDRESSCODE   = "CNT" + format$("N0:2",num$(LOOP))
        ADDRESSLINES += 1
        Call PARSEADDRESS(CONTACTMAILINGADDRESS(LOOP), CONTACTMAILINGADDRESS1(LOOP), CONTACTMAILINGADDRESS2(LOOP), CONTACTMAILINGADDRESS3(LOOP)) From CRMSF
        ADDRESSESXML += func BUILDADDRESSXML(ADDRESSCODE, ADDRESSLINES, CONTACTMAILINGADDRESS1(LOOP), CONTACTMAILINGADDRESS2(LOOP), CONTACTMAILINGADDRESS3(LOOP), CONTACTMAILINGCITY(LOOP),
&                                       CONTACTMAILINGPROVINCECODE(LOOP), CONTACTMAILINGPOSTALCODE(LOOP), CONTACTMAILINGCOUNTRYCODE(LOOP), "", "", "")
      Endif

      CONTACTLINES += 1
      CONTACTSXML += func GETCONTACTXML(CONTACTNUM, CONTACTLINES, CONTACTFIRSTNAME(LOOP), CONTACTLASTNAME(LOOP), CONTACTPHONE(LOOP), CONTACTFAX(LOOP), CONTACTEMAIL(LOOP), ADDRESSCODE)
    Endif
  Next LOOP
  If ERRMSG <> "" : Return : Endif

  # Build Ship-to XML
  SHIPTOADDRESSLINES = 1
  SHIPTOXML = func GETSHIPTOXML(CUSTOMERCATEGORY, "SHIP", SHIPTOADDRESSLINES, ERRMSG)
  If ERRMSG <> "" : Return : Endif


  # Build call to BPC web service
  ARGUMENTS = '"'
  Append ARGUMENTS, WEBSERVICELANGUAGE   # <codeLang> from ws call to this subprogram
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'SFCRMPOOL'  # TODO can this come from call?  <poolAlias>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'CRMSFBPC'  # <publicName>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, '<PARAM>'   # <requestXml>
  Append ARGUMENTS,   '<GRP ID=\"BPC0_1\">'
  Append ARGUMENTS,     '<FLD NAME=\"BCGCOD\" type=\"Char\">' + CUSTOMERCATEGORY + '</FLD>'
  Append ARGUMENTS,     '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"BPCSTA\" type=\"Integer\">2</FLD>'   # Active flag
  Append ARGUMENTS,     '<FLD NAME=\"BPCNUM\" type=\"Char\">' + CUSTOMERNUMBER + '</FLD>'
  Append ARGUMENTS,   '</GRP>'
  Append ARGUMENTS,   '<GRP ID=\"BPRC_1\">'
  Append ARGUMENTS,     COUNTRYXML
  Append ARGUMENTS,     '<LST NAME=\"BPRNAM\" SIZE=\"1\" type=\"Char\">'    #
  Append ARGUMENTS,       '<ITM>' + func CRMSF.ESCAPECHARS(CUSTOMERNAME, "IN") + '</ITM>'                 # Limiting customer name to 1 field for now
  Append ARGUMENTS,     '</LST>'                                            #
  Append ARGUMENTS,   '</GRP>'
  Append ARGUMENTS,   '<GRP ID=\"BPC3_1\">'
  Append ARGUMENTS,     '<FLD NAME=\"BPAINV\" TYPE=\"Char\">BILL</FLD>'
  Append ARGUMENTS,     '<FLD NAME=\"BPAPYR\" TYPE=\"Char\">BILL</FLD>'
  Append ARGUMENTS,   '</GRP>'
  Append ARGUMENTS,   '<TAB DIM=\"' + num$(func AFNC.ACTIV("BPA")) + '\" ID=\"BPAC_1\" SIZE=\"' + num$(ADDRESSLINES) + '\">'
  Append ARGUMENTS,     ADDRESSESXML
  Append ARGUMENTS,   '</TAB>'
  Append ARGUMENTS,   '<TAB DIM=\"' + num$(func AFNC.ACTIV("BPA")) + '\" ID=\"BPC4_1\" SIZE=\"1\">'
  Append ARGUMENTS,     SHIPTOXML
  Append ARGUMENTS,   '</TAB>'
  If CONTACTLINES
    Append ARGUMENTS,   '<TAB DIM=\"' + num$(func AFNC.ACTIV("NBCNT")) + '\" ID=\"CNTC_1\" SIZE=\"' + num$(CONTACTLINES) + '\">'
    Append ARGUMENTS, CONTACTSXML
    Append ARGUMENTS,   '</TAB>'
  Endif
  Append ARGUMENTS, '</PARAM>'
  Append ARGUMENTS, '"'

#-------------------------------------------------------------------------------------------------#
# Unremark below lines to log contents of ARGUMENTS
#  Local Char     CLOBNAME(30)
#  Local Clbfile  CLOBDATA
#  CLOBNAME = "ARGUMENTS" : CLOBDATA = ARGUMENTS : Gosub LOGCLOB From CRMSF
#-------------------------------------------------------------------------------------------------#

Return

####################################################################################################

$PROCESSRETURNEDXML

  OK = fmet MYLOG.APUTLINE(mess(RESPONSESTATUS,189,1), OK) : OK = fmet MYLOG.AFLUSHLOG

  # Populate return variables
  Gosub LOADRETURNVALUES
  If ERRMSG = ""
    # Get field labels
    Gosub LOADLABELS
  Endif

Return

####################################################################################################

Funprog GETCOUNTRYXML(CUSTOMERCOUNTRYCODE, ERRMSG)

  Value Char CUSTOMERCOUNTRYCODE()
  Variable Char ERRMSG()

  Local Clbfile COUNTRY

  Append COUNTRY, '<FLD NAME=\"CRY\" type=\"Char\">' + CUSTOMERCOUNTRYCODE + '</FLD>'

  If clalev([F:TCY]) = 0 : Local File TABCOUNTRY [TCY] : Endif
  Read [F:TCY]TCY0=CUSTOMERCOUNTRYCODE
  If !fstat
    Append COUNTRY, '<FLD NAME=\"LAN\" type=\"Char\">' + [F:TCY]LAN + '</FLD>'
    Append COUNTRY, '<FLD NAME=\"CUR\" type=\"Char\">' + [F:TCY]CUR + '</FLD>'
  Else
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000102", mess(23,100,1), CUSTOMERCOUNTRYCODE, func CRMSF.GETLABEL("BPABPC", "BPACRY"))
  Endif

End COUNTRY

####################################################################################################

Funprog BUILDADDRESSXML(ADDRESSCODE, LINENUMBER, ADDRESS1, ADDRESS2, ADDRESS3, CITY, PROVINCECODE, POSTALCODE, COUNTRYCODE, PHONE1, PHONE2, WEB)

  Value Char    ADDRESSCODE
  Value Integer LINENUMBER
  Value Char    ADDRESS1
  Value Char    ADDRESS2
  Value Char    ADDRESS3
  Value Char    CITY
  Value Char    PROVINCECODE
  Value Char    POSTALCODE
  Value Char    COUNTRYCODE
  Value Char    PHONE1
  Value Char    PHONE2
  Value Char    WEB

  Local Clbfile ADDRESS

  Append ADDRESS, '<LIN NUM=\"' + num$(LINENUMBER) + '\">'
  Append ADDRESS,   '<FLD NAME=\"CODADR\" TYPE=\"Char\">' + ADDRESSCODE + '</FLD>'
  Append ADDRESS,   '<FLD NAME=\"BPACRY\" TYPE=\"Char\">' + COUNTRYCODE + '</FLD>'
  Append ADDRESS,   '<FLD NAME=\"ADDLIG1\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(ADDRESS1, "IN") + '</FLD>'
  Append ADDRESS,   '<FLD NAME=\"ADDLIG2\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(ADDRESS2, "IN") + '</FLD>'
  Append ADDRESS,   '<FLD NAME=\"ADDLIG3\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(ADDRESS3, "IN") + '</FLD>'
  Append ADDRESS,   '<FLD NAME=\"POSCOD\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(POSTALCODE, "IN") + '</FLD>'
  Append ADDRESS,   '<FLD NAME=\"CTY\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CITY, "IN") + '</FLD>'
  Append ADDRESS,   '<FLD NAME=\"SAT\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(PROVINCECODE, "IN") + '</FLD>'
  Append ADDRESS,   '<FLD NAME=\"TEL1\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(PHONE1, "IN") + '</FLD>'
  Append ADDRESS,   '<FLD NAME=\"TEL2\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(PHONE2, "IN") + '</FLD>'
  Append ADDRESS,   '<FLD NAME=\"FCYWEB\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(WEB, "IN") + '</FLD>'
  If LINENUMBER=1
    Append ADDRESS, '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"BPAADDFLG\" type=\"Integer\">2</FLD>'
  Else
    Append ADDRESS, '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"BPAADDFLG\" type=\"Integer\">1</FLD>'
  Endif
  Append ADDRESS, '</LIN>'

End ADDRESS

####################################################################################################

Funprog GETCONTACTXML(CONTACTNUMBER, LINENUMBER, CONTACTFIRSTNAME, CONTACTLASTNAME, CONTACTPHONE, CONTACTFAX, CONTACTEMAIL, CONTACTADDRESSCODE)

  Value Char    CONTACTNUMBER
  Value Integer LINENUMBER
  Value Char    CONTACTFIRSTNAME
  Value Char    CONTACTLASTNAME
  Value Char    CONTACTPHONE
  Value Char    CONTACTFAX
  Value Char    CONTACTEMAIL
  Value Char    CONTACTADDRESSCODE

  Local Clbfile CONTACT

  Append CONTACT, '<LIN NUM=\"' + num$(LINENUMBER) + '\">'
  Append CONTACT,   '<FLD NAME=\"CCNCRM\" type=\"Char\">' + CONTACTNUMBER + '</FLD>'
  Append CONTACT,   '<FLD NAME=\"CNTFNA\" type=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTFIRSTNAME, "IN") + '</FLD>'
  Append CONTACT,   '<FLD NAME=\"CNTLNA\" type=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTLASTNAME,  "IN") + '</FLD>'   # See SPEBPC for logic that allows this
  Append CONTACT,   '<FLD NAME=\"CNTTEL\" type=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTPHONE,     "IN") + '</FLD>'
  Append CONTACT,   '<FLD NAME=\"CNTFAX\" type=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTFAX,       "IN") + '</FLD>'
  Append CONTACT,   '<FLD NAME=\"CNTWEB\" type=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTEMAIL,     "IN") + '</FLD>'
  Append CONTACT,   '<FLD NAME=\"CNTADD\" type=\"Char\">' + CONTACTADDRESSCODE + '</FLD>'
  Append CONTACT,   '<FLD MENULAB=\"Other\" MENULOCAL=\"233\" NAME=\"CNTFNC\" TYPE=\"Integer\">11</FLD>'    # Function = Other
  Append CONTACT, '</LIN>'

End CONTACT

####################################################################################################

Funprog GETSHIPTOXML(CUSTOMERCATEGORY, ADDRESSCODE, LINENUMBER, ERRMSG)

  Value    Char    CUSTOMERCATEGORY
  Value    Char    ADDRESSCODE
  Variable Integer LINENUMBER
  Variable Char    ERRMSG

  Local Clbfile SHIPTO

  If clalev([F:BCG]) = 0 : Local File BPCCATEG [BCG] : Endif
  Read [F:BCG]BCG0=CUSTOMERCATEGORY
  If fstat = 0
    Append SHIPTO, '<LIN NUM=\"' + num$(LINENUMBER) + '\">'
    Append SHIPTO,     '<FLD NAME=\"BPAADD\" TYPE=\"Char\">' + ADDRESSCODE + '</FLD>'
    Append SHIPTO,     '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"NPRFLG\" type=\"Integer\">' + num$([F:BCG]NPRFLG) + '</FLD>'
    Append SHIPTO,     '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"NDEFLG\" type=\"Integer\">' + num$([F:BCG]NDEFLG) + '</FLD>'
    Append SHIPTO,     '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"UVYDAY1\" type=\"Integer\">' + num$([F:BCG]UVYDAY1) + '</FLD>'
    Append SHIPTO,     '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"UVYDAY2\" type=\"Integer\">' + num$([F:BCG]UVYDAY2) + '</FLD>'
    Append SHIPTO,     '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"UVYDAY3\" type=\"Integer\">' + num$([F:BCG]UVYDAY3) + '</FLD>'
    Append SHIPTO,     '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"UVYDAY4\" type=\"Integer\">' + num$([F:BCG]UVYDAY4) + '</FLD>'
    Append SHIPTO,     '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"UVYDAY5\" type=\"Integer\">' + num$([F:BCG]UVYDAY5) + '</FLD>'
    Append SHIPTO,     '<FLD MENULAB=\"No\" MENULOCAL=\"1\" NAME=\"UVYDAY6\" type=\"Integer\">' + num$([F:BCG]UVYDAY6) + '</FLD>'
    Append SHIPTO,     '<FLD MENULAB=\"No\" MENULOCAL=\"1\" NAME=\"UVYDAY7\" type=\"Integer\">' + num$([F:BCG]UVYDAY7) + '</FLD>'
    Append SHIPTO,     '<FLD NAME=\"EECINCRAT\" type=\"Decimal\">' + num$([F:BCG]EECINCRAT) + '</FLD>'
    Append SHIPTO,     '<FLD MENULAB=\"Outside EU\" MENULOCAL=\"236\" NAME=\"EECLOC\" type=\"Integer\">' + num$([F:BCG]EECLOC) + '</FLD>'
    Append SHIPTO,     '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"BPDADDFLG\" type=\"Integer\">2</FLD>'
    Append SHIPTO,     '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"ENAFLG\" type=\"Integer\">2</FLD>'
    Append SHIPTO,   '</LIN>'
  Else
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000102", mess(23,100,1), CUSTOMERCATEGORY, func CRMSF.GETLABEL("BPC0", "BCGCOD"))
  Endif

End SHIPTO

####################################################################################################

Funprog GETSHIPTOADDRESSESXML(CUSTOMERNUMBER, LINENUMBER)

  Value    Char    CUSTOMERNUMBER
  Variable Integer LINENUMBER

  Local Clbfile SHIPTO

  If clalev([F:BPD]) = 0 : Local File BPDLVCUST [BPD] : Endif
  Filter [BPD] Where [F:BPD]BPCNUM = CUSTOMERNUMBER

  For [BPD]
    LINENUMBER += 1
    Append SHIPTO, '<LIN NUM=\"' + num$(LINENUMBER) + '\">'
    Append SHIPTO,   '<FLD NAME=\"BPAADD\" TYPE=\"Char\">' + [F:BPD]BPAADD + '</FLD>'
    Append SHIPTO, '</LIN>'
  Next

End SHIPTO

####################################################################################################

$ CLEARRETURNVALUES

  # Don't use RAZ here because it will initialize all the dims of the variables
  # which causes a lot of extra fields in the returned XML

  CUSTOMERNUMBER                 = ""
  CUSTOMERNAME                   = ""
  CUSTOMERPHONE                  = ""
  CUSTOMERFAX                    = ""
  CUSTOMERWEBSITE                = ""
  CUSTOMERCOUNTRYCODE            = ""

  CUSTOMERBILLINGADDRESSNUMBER   = ""
  CUSTOMERBILLINGADDRESS         = ""
  CUSTOMERBILLINGCITY            = ""
  CUSTOMERBILLINGPROVINCECODE    = ""
  CUSTOMERBILLINGPOSTALCODE      = ""
  CUSTOMERBILLINGCOUNTRYCODE     = ""

  CUSTOMERSHIPPINGADDRESSNUMBER  = ""
  CUSTOMERSHIPPINGADDRESS        = ""
  CUSTOMERSHIPPINGCITY           = ""
  CUSTOMERSHIPPINGPROVINCECODE   = ""
  CUSTOMERSHIPPINGPOSTALCODE     = ""
  CUSTOMERSHIPPINGCOUNTRYCODE    = ""

  CONTACTNUMBER                  = ""
  CONTACTFIRSTNAME               = ""
  CONTACTLASTNAME                = ""
  CONTACTPHONE                   = ""
  CONTACTFAX                     = ""
  CONTACTEMAIL                   = ""

  CONTACTMAILINGADDRESSNUMBER    = ""
  CONTACTMAILINGADDRESS          = ""
  CONTACTMAILINGCITY             = ""
  CONTACTMAILINGPROVINCECODE     = ""
  CONTACTMAILINGPOSTALCODE       = ""
  CONTACTMAILINGCOUNTRYCODE      = ""

  LBLCUSTOMERNUMBER              = ""
  LBLCUSTOMERNAME                = ""
  LBLCUSTOMERPHONE               = ""
  LBLCUSTOMERFAX                 = ""
  LBLCUSTOMERWEBSITE             = ""
  LBLCUSTOMERCOUNTRYCODE         = ""

  LBLCUSTOMERBILLINGADDRESSNUM   = ""
  LBLCUSTOMERBILLINGADDRESS      = ""
  LBLCUSTOMERBILLINGCITY         = ""
  LBLCUSTOMERBILLINGPROVINCECODE = ""
  LBLCUSTOMERBILLINGPOSTALCODE   = ""
  LBLCUSTOMERBILLINGCOUNTRYCODE  = ""

  LBLCUSTOMERSHIPPINGADDRESSNUM  = ""
  LBLCUSTOMERSHIPPINGADDRESS     = ""
  LBLCUSTOMERSHIPPINGCITY        = ""
  LBLCUSTOMERSHIPPINGPROVINCECOD = ""
  LBLCUSTOMERSHIPPINGPOSTALCODE  = ""
  LBLCUSTOMERSHIPPINGCOUNTRYCODE = ""

  LBLCONTACTNUMBER               = ""
  LBLCONTACTFIRSTNAME            = ""
  LBLCONTACTLASTNAME             = ""
  LBLCONTACTPHONE                = ""
  LBLCONTACTFAX                  = ""
  LBLCONTACTEMAIL                = ""

  LBLCONTACTMAILINGADDRESSNUMBER = ""
  LBLCONTACTMAILINGADDRESS       = ""
  LBLCONTACTMAILINGCITY          = ""
  LBLCONTACTMAILINGPROVINCECODE  = ""
  LBLCONTACTMAILINGPOSTALCODE    = ""
  LBLCONTACTMAILINGCOUNTRYCODE   = ""

Return

####################################################################################################

$LOADRETURNVALUES

  Local Clbfile CUSTOMERNAMELIST
  Local Integer LOOP
  Local Integer LOOP2
  Local Char    CODADR(GLONADR)
  Local Char    ADDRESSCODE(GLONADR)
  Local Integer CONTACTLINES
  Local Tinyint ISDEFAULT
  Local Char    CUSTOMERBILLINGCUSTOMERNUMBER(GLONBPC)
  Local Char    PROVINCENAME(35)
  Local Char    COUNTRYNAME(40)
  Local Char    PHONE(0)
  Local Char    FAX(0)
  Local Char    WEBSITE(0)

  # Customer details
  CUSTOMERNUMBER      = func CRMSF.GETXMLVALUE(RESBODY, "BPC0_1", 0, "BPCNUM")
  CUSTOMERNAMELIST    = func CRMSF.GETXMLVALUE(RESBODY, "BPRC_1", 0, "BPRNAM")
  CUSTOMERNAME        = func CRMSF.GETLISTVALUE(CUSTOMERNAMELIST, 1)
  CUSTOMERCOUNTRYCODE = func CRMSF.GETXMLVALUE(RESBODY, "BPRC_1", 0, "CRY")

  # Customer addresses
  CUSTOMERBILLINGCUSTOMERNUMBER = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_1", 0, "BPCINV")
  CUSTOMERBILLINGADDRESSNUMBER  = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_1", 0, "BPAINV")
  Call GETADDRESS(CUSTOMERBILLINGCUSTOMERNUMBER, CUSTOMERBILLINGADDRESSNUMBER, CUSTOMERBILLINGADDRESS1, CUSTOMERBILLINGADDRESS2, CUSTOMERBILLINGADDRESS3,
&                 CUSTOMERBILLINGCITY, CUSTOMERBILLINGPROVINCECODE, PROVINCENAME, CUSTOMERBILLINGPOSTALCODE, CUSTOMERBILLINGCOUNTRYCODE, COUNTRYNAME,
&                 CUSTOMERPHONE, CUSTOMERFAX, CUSTOMERWEBSITE, ERRMSG)
  Call COMBINEADDRESSES(CUSTOMERBILLINGADDRESS1, CUSTOMERBILLINGADDRESS2, CUSTOMERBILLINGADDRESS3, CUSTOMERBILLINGADDRESS) From CRMSF

  For LOOP = 1 To int(val(func CRMSF.GETXMLVALUE(RESBODY, "BPC4_1", 0, "SIZE")))
    ISDEFAULT = int(val(func CRMSF.GETXMLVALUE(RESBODY, "BPC4_1", LOOP, "BPDADDFLG")))
    If ISDEFAULT = 2 :
      CUSTOMERSHIPPINGADDRESSNUMBER = func CRMSF.GETXMLVALUE(RESBODY, "BPC4_1", LOOP, "BPAADD")
      Break
    Endif
  Next
  If CUSTOMERSHIPPINGADDRESSNUMBER > ""
    Call GETADDRESS(CUSTOMERNUMBER, CUSTOMERSHIPPINGADDRESSNUMBER, CUSTOMERSHIPPINGADDRESS1, CUSTOMERSHIPPINGADDRESS2, CUSTOMERSHIPPINGADDRESS3,
&                 CUSTOMERSHIPPINGCITY, CUSTOMERSHIPPINGPROVINCECODE, PROVINCENAME, CUSTOMERSHIPPINGPOSTALCODE, CUSTOMERSHIPPINGCOUNTRYCODE, COUNTRYNAME,
&                 PHONE, FAX, WEBSITE, ERRMSG)
    Call COMBINEADDRESSES(CUSTOMERSHIPPINGADDRESS1, CUSTOMERSHIPPINGADDRESS2, CUSTOMERSHIPPINGADDRESS3, CUSTOMERSHIPPINGADDRESS) From CRMSF
  Endif

  # Contacts
  CONTACTLINES = int(val(func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", 0, "SIZE")))
  If CONTACTLINES
    For LOOP = 1 To CONTACTLINES
      CONTACTNUMBER(LOOP)    = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CCNCRM")
      CONTACTFIRSTNAME(LOOP) = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTFNA")
      CONTACTLASTNAME(LOOP)  = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTLNA")
      CONTACTPHONE(LOOP)     = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTTEL")
      CONTACTFAX(LOOP)       = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTFAX")
      CONTACTEMAIL(LOOP)     = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTWEB")

      # Contact addresses
      ADDRESSCODE = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTADD")
      If ADDRESSCODE <> ""
        For LOOP2 = 1 To int(val(func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", 0, "SIZE")))
          CODADR = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP2, "CODADR")
          If CODADR=ADDRESSCODE
            CONTACTMAILINGADDRESSNUMBER(LOOP) = CODADR
            CONTACTMAILINGADDRESS1(LOOP)      = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP2, "ADDLIG1")
            CONTACTMAILINGADDRESS2(LOOP)      = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP2, "ADDLIG2")
            CONTACTMAILINGADDRESS3(LOOP)      = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP2, "ADDLIG3")
            Call COMBINEADDRESSES(CONTACTMAILINGADDRESS1(LOOP), CONTACTMAILINGADDRESS2(LOOP), CONTACTMAILINGADDRESS3(LOOP), CONTACTMAILINGADDRESS(LOOP)) From CRMSF
            CONTACTMAILINGCITY(LOOP)          = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP2, "CTY")
            CONTACTMAILINGPROVINCECODE(LOOP)  = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP2, "SAT")
            CONTACTMAILINGPOSTALCODE(LOOP)    = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP2, "POSCOD")
            CONTACTMAILINGCOUNTRYCODE(LOOP)   = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP2, "BPACRY")
          Endif
        Next LOOP2
      Endif
    Next LOOP
  Endif

  OK=fmet MYLOG.APUTLINE("Customer return values loaded",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

  # Decode any XML escaped characters in the returned values
  If CUSTOMERNAME    <> "" : CUSTOMERNAME    = func CRMSF.ESCAPECHARS(CUSTOMERNAME,    "OUT") : Endif
  If CUSTOMERPHONE   <> "" : CUSTOMERPHONE   = func CRMSF.ESCAPECHARS(CUSTOMERPHONE,   "OUT") : Endif
  If CUSTOMERFAX     <> "" : CUSTOMERFAX     = func CRMSF.ESCAPECHARS(CUSTOMERFAX,     "OUT") : Endif
  If CUSTOMERWEBSITE <> "" : CUSTOMERWEBSITE = func CRMSF.ESCAPECHARS(CUSTOMERWEBSITE, "OUT") : Endif

  If CUSTOMERBILLINGADDRESS      <> "" : CUSTOMERBILLINGADDRESS      = func CRMSF.ESCAPECHARS(CUSTOMERBILLINGADDRESS,      "OUT") : Endif
  If CUSTOMERBILLINGCITY         <> "" : CUSTOMERBILLINGCITY         = func CRMSF.ESCAPECHARS(CUSTOMERBILLINGCITY,         "OUT") : Endif
  If CUSTOMERBILLINGPROVINCECODE <> "" : CUSTOMERBILLINGPROVINCECODE = func CRMSF.ESCAPECHARS(CUSTOMERBILLINGPROVINCECODE, "OUT") : Endif
  If CUSTOMERBILLINGPOSTALCODE   <> "" : CUSTOMERBILLINGPOSTALCODE   = func CRMSF.ESCAPECHARS(CUSTOMERBILLINGPOSTALCODE,   "OUT") : Endif

  If CUSTOMERSHIPPINGADDRESS      <> "" : CUSTOMERSHIPPINGADDRESS      = func CRMSF.ESCAPECHARS(CUSTOMERSHIPPINGADDRESS,      "OUT") : Endif
  If CUSTOMERSHIPPINGCITY         <> "" : CUSTOMERSHIPPINGCITY         = func CRMSF.ESCAPECHARS(CUSTOMERSHIPPINGCITY,         "OUT") : Endif
  If CUSTOMERSHIPPINGPROVINCECODE <> "" : CUSTOMERSHIPPINGPROVINCECODE = func CRMSF.ESCAPECHARS(CUSTOMERSHIPPINGPROVINCECODE, "OUT") : Endif
  If CUSTOMERSHIPPINGPOSTALCODE   <> "" : CUSTOMERSHIPPINGPOSTALCODE   = func CRMSF.ESCAPECHARS(CUSTOMERSHIPPINGPOSTALCODE,   "OUT") : Endif

  If CONTACTLINES
    For LOOP = 1 To CONTACTLINES
      If CONTACTFIRSTNAME(LOOP) <> "" : CONTACTFIRSTNAME(LOOP) = func CRMSF.ESCAPECHARS(CONTACTFIRSTNAME(LOOP), "OUT") : Endif
      If CONTACTLASTNAME(LOOP)  <> "" : CONTACTLASTNAME(LOOP)  = func CRMSF.ESCAPECHARS(CONTACTLASTNAME(LOOP),  "OUT") : Endif
      If CONTACTPHONE(LOOP)     <> "" : CONTACTPHONE(LOOP)     = func CRMSF.ESCAPECHARS(CONTACTPHONE(LOOP),     "OUT") : Endif
      If CONTACTFAX(LOOP)       <> "" : CONTACTFAX(LOOP)       = func CRMSF.ESCAPECHARS(CONTACTFAX(LOOP),       "OUT") : Endif
      If CONTACTEMAIL(LOOP)     <> "" : CONTACTEMAIL(LOOP)     = func CRMSF.ESCAPECHARS(CONTACTEMAIL(LOOP),     "OUT") : Endif

      If CONTACTMAILINGADDRESS(LOOP)      <> "" : CONTACTMAILINGADDRESS(LOOP)      = func CRMSF.ESCAPECHARS(CONTACTMAILINGADDRESS(LOOP),      "OUT") : Endif
      If CONTACTMAILINGCITY(LOOP)         <> "" : CONTACTMAILINGCITY(LOOP)         = func CRMSF.ESCAPECHARS(CONTACTMAILINGCITY(LOOP),         "OUT") : Endif
      If CONTACTMAILINGPROVINCECODE(LOOP) <> "" : CONTACTMAILINGPROVINCECODE(LOOP) = func CRMSF.ESCAPECHARS(CONTACTMAILINGPROVINCECODE(LOOP), "OUT") : Endif
      If CONTACTMAILINGPOSTALCODE(LOOP)   <> "" : CONTACTMAILINGPOSTALCODE(LOOP)   = func CRMSF.ESCAPECHARS(CONTACTMAILINGPOSTALCODE(LOOP),   "OUT") : Endif
    Next LOOP
  Endif

  OK=fmet MYLOG.APUTLINE("Character conversion completed for customer",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

Return

####################################################################################################

$LOADLABELS

  LBLCUSTOMERNUMBER      = func CRMSF.GETLABEL("BPC0", "BPCNUM")
  LBLCUSTOMERNAME        = func CRMSF.GETLABEL("BPRBPC", "BPRNAM")
  LBLCUSTOMERPHONE       = func CRMSF.GETLABEL("BPRBPC", "TEL1"  )
  LBLCUSTOMERFAX         = func CRMSF.GETLABEL("BPRBPC", "TEL2"  )
  LBLCUSTOMERWEBSITE     = func CRMSF.GETLABEL("BPRBPC", "FCYWEB")
  LBLCUSTOMERCOUNTRYCODE = func CRMSF.GETLABEL("BPRBPC", "CRY"   )

  LBLCUSTOMERBILLINGADDRESSNUM   = func CRMSF.GETLABEL("BPABPC", "CODADR")
  LBLCUSTOMERBILLINGADDRESS      = func CRMSF.GETLABEL("BPABPC", "ADDLIG")
  LBLCUSTOMERBILLINGCITY         = func CRMSF.GETLABEL("BPABPC", "CTY"   )
  LBLCUSTOMERBILLINGPROVINCECODE = func CRMSF.GETPROVINCELABEL(CUSTOMERBILLINGCOUNTRYCODE, WEBSERVICELANGUAGE)
  LBLCUSTOMERBILLINGPOSTALCODE   = func CRMSF.GETLABEL("BPABPC", "POSCOD")
  LBLCUSTOMERBILLINGCOUNTRYCODE  = func CRMSF.GETLABEL("BPABPC", "BPACRY")

  LBLCUSTOMERSHIPPINGADDRESSNUM  = LBLCUSTOMERBILLINGADDRESSNUM
  LBLCUSTOMERSHIPPINGADDRESS     = LBLCUSTOMERBILLINGADDRESS
  LBLCUSTOMERSHIPPINGCITY        = LBLCUSTOMERBILLINGCITY
  LBLCUSTOMERSHIPPINGPROVINCECOD = func CRMSF.GETPROVINCELABEL(CUSTOMERSHIPPINGCOUNTRYCODE, WEBSERVICELANGUAGE)
  LBLCUSTOMERSHIPPINGPOSTALCODE  = LBLCUSTOMERBILLINGPOSTALCODE
  LBLCUSTOMERSHIPPINGCOUNTRYCODE = LBLCUSTOMERBILLINGCOUNTRYCODE

  LBLCONTACTNUMBER    = func CRMSF.GETLABEL("CNTBPC", "CCNCRM" )
  LBLCONTACTFIRSTNAME = func CRMSF.GETLABEL("CNTBPC", "CNTFNA" )
  LBLCONTACTLASTNAME  = func CRMSF.GETLABEL("CNTBPC", "CNTLNA" )
  LBLCONTACTPHONE     = func CRMSF.GETLABEL("CNTBPC", "CNTTEL" )
  LBLCONTACTFAX       = func CRMSF.GETLABEL("CNTBPC", "CNTFAX" )
  LBLCONTACTEMAIL     = func CRMSF.GETLABEL("CNTBPC", "CNTWEB" )

  LBLCONTACTMAILINGADDRESSNUMBER = func CRMSF.GETLABEL("CNTBPC", "CNTADD" )
  LBLCONTACTMAILINGADDRESS       = LBLCUSTOMERBILLINGADDRESS
  LBLCONTACTMAILINGCITY          = LBLCUSTOMERBILLINGCITY
  LBLCONTACTMAILINGPROVINCECODE  = func CRMSF.GETPROVINCELABEL(CONTACTMAILINGCOUNTRYCODE, WEBSERVICELANGUAGE)
  LBLCONTACTMAILINGPOSTALCODE    = LBLCUSTOMERBILLINGPOSTALCODE
  LBLCONTACTMAILINGCOUNTRYCODE   = LBLCUSTOMERBILLINGCOUNTRYCODE

  OK=fmet MYLOG.APUTLINE("Labels loaded",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

Return

####################################################################################################

####################################################################################################
# Subprogram for Salesforce to read a customer with contacts in X3
####################################################################################################

Subprog READCUSTOMER(CUSTOMERNUMBER,
&                    CUSTOMERNAME,
&                    CUSTOMERPHONE,
&                    CUSTOMERFAX,
&                    CUSTOMERWEBSITE,
&                    CUSTOMERCOUNTRYCODE,
&                    CUSTOMERBILLINGADDRESSNUMBER,
&                    CUSTOMERBILLINGADDRESS,
&                    CUSTOMERBILLINGCITY,
&                    CUSTOMERBILLINGPROVINCECODE,
&                    CUSTOMERBILLINGPOSTALCODE,
&                    CUSTOMERBILLINGCOUNTRYCODE,
&                    CUSTOMERSHIPPINGADDRESSNUMBER,
&                    CUSTOMERSHIPPINGADDRESS,
&                    CUSTOMERSHIPPINGCITY,
&                    CUSTOMERSHIPPINGPROVINCECODE,
&                    CUSTOMERSHIPPINGPOSTALCODE,
&                    CUSTOMERSHIPPINGCOUNTRYCODE,
&                    CONTACTNUMBER,
&                    CONTACTFIRSTNAME,
&                    CONTACTLASTNAME,
&                    CONTACTPHONE,
&                    CONTACTFAX,
&                    CONTACTEMAIL,
&                    CONTACTMAILINGADDRESSNUMBER,
&                    CONTACTMAILINGADDRESS,
&                    CONTACTMAILINGCITY,
&                    CONTACTMAILINGPROVINCECODE,
&                    CONTACTMAILINGPOSTALCODE,
&                    CONTACTMAILINGCOUNTRYCODE,
&                    RESPONSESTATUS,
&                    RESPONSEMESSAGES,
&                    LBLCUSTOMERNUMBER,
&                    LBLCUSTOMERNAME,
&                    LBLCUSTOMERPHONE,
&                    LBLCUSTOMERFAX,
&                    LBLCUSTOMERWEBSITE,
&                    LBLCUSTOMERCOUNTRYCODE,
&                    LBLCUSTOMERBILLINGADDRESSNUM,
&                    LBLCUSTOMERBILLINGADDRESS,
&                    LBLCUSTOMERBILLINGCITY,
&                    LBLCUSTOMERBILLINGPROVINCECODE,
&                    LBLCUSTOMERBILLINGPOSTALCODE,
&                    LBLCUSTOMERBILLINGCOUNTRYCODE,
&                    LBLCUSTOMERSHIPPINGADDRESSNUM,
&                    LBLCUSTOMERSHIPPINGADDRESS,
&                    LBLCUSTOMERSHIPPINGCITY,
&                    LBLCUSTOMERSHIPPINGPROVINCECOD,
&                    LBLCUSTOMERSHIPPINGPOSTALCODE,
&                    LBLCUSTOMERSHIPPINGCOUNTRYCODE,
&                    LBLCONTACTNUMBER,
&                    LBLCONTACTFIRSTNAME,
&                    LBLCONTACTLASTNAME,
&                    LBLCONTACTPHONE,
&                    LBLCONTACTFAX,
&                    LBLCONTACTEMAIL,
&                    LBLCONTACTMAILINGADDRESSNUMBER,
&                    LBLCONTACTMAILINGADDRESS,
&                    LBLCONTACTMAILINGCITY,
&                    LBLCONTACTMAILINGPROVINCECODE,
&                    LBLCONTACTMAILINGPOSTALCODE,
&                    LBLCONTACTMAILINGCOUNTRYCODE)

  Variable Char CUSTOMERNUMBER
  Variable Char CUSTOMERNAME
  Variable Char CUSTOMERPHONE
  Variable Char CUSTOMERFAX
  Variable Char CUSTOMERWEBSITE
  Variable Char CUSTOMERCOUNTRYCODE

  Variable Char CUSTOMERBILLINGADDRESSNUMBER
  Variable Char CUSTOMERBILLINGADDRESS
  Variable Char CUSTOMERBILLINGCITY
  Variable Char CUSTOMERBILLINGPROVINCECODE
  Variable Char CUSTOMERBILLINGPOSTALCODE
  Variable Char CUSTOMERBILLINGCOUNTRYCODE

  Variable Char CUSTOMERSHIPPINGADDRESSNUMBER
  Variable Char CUSTOMERSHIPPINGADDRESS
  Variable Char CUSTOMERSHIPPINGCITY
  Variable Char CUSTOMERSHIPPINGPROVINCECODE
  Variable Char CUSTOMERSHIPPINGPOSTALCODE
  Variable Char CUSTOMERSHIPPINGCOUNTRYCODE

  Variable Char CONTACTNUMBER()(1..)
  Variable Char CONTACTFIRSTNAME()(1..)
  Variable Char CONTACTLASTNAME()(1..)
  Variable Char CONTACTPHONE()(1..)
  Variable Char CONTACTFAX()(1..)
  Variable Char CONTACTEMAIL()(1..)

  Variable Char CONTACTMAILINGADDRESSNUMBER()(1..)
  Variable Char CONTACTMAILINGADDRESS()(1..)
  Variable Char CONTACTMAILINGCITY()(1..)
  Variable Char CONTACTMAILINGPROVINCECODE()(1..)
  Variable Char CONTACTMAILINGPOSTALCODE()(1..)
  Variable Char CONTACTMAILINGCOUNTRYCODE()(1..)

  Variable Integer RESPONSESTATUS
  Variable Char    RESPONSEMESSAGES()(1..)

  Variable Char LBLCUSTOMERNUMBER
  Variable Char LBLCUSTOMERNAME
  Variable Char LBLCUSTOMERPHONE
  Variable Char LBLCUSTOMERFAX
  Variable Char LBLCUSTOMERWEBSITE
  Variable Char LBLCUSTOMERCOUNTRYCODE

  Variable Char LBLCUSTOMERBILLINGADDRESSNUM
  Variable Char LBLCUSTOMERBILLINGADDRESS
  Variable Char LBLCUSTOMERBILLINGCITY
  Variable Char LBLCUSTOMERBILLINGPROVINCECODE
  Variable Char LBLCUSTOMERBILLINGPOSTALCODE
  Variable Char LBLCUSTOMERBILLINGCOUNTRYCODE

  Variable Char LBLCUSTOMERSHIPPINGADDRESSNUM
  Variable Char LBLCUSTOMERSHIPPINGADDRESS
  Variable Char LBLCUSTOMERSHIPPINGCITY
  Variable Char LBLCUSTOMERSHIPPINGPROVINCECOD
  Variable Char LBLCUSTOMERSHIPPINGPOSTALCODE
  Variable Char LBLCUSTOMERSHIPPINGCOUNTRYCODE

  Variable Char LBLCONTACTNUMBER
  Variable Char LBLCONTACTFIRSTNAME
  Variable Char LBLCONTACTLASTNAME
  Variable Char LBLCONTACTPHONE
  Variable Char LBLCONTACTFAX
  Variable Char LBLCONTACTEMAIL

  Variable Char LBLCONTACTMAILINGADDRESSNUMBER
  Variable Char LBLCONTACTMAILINGADDRESS
  Variable Char LBLCONTACTMAILINGCITY
  Variable Char LBLCONTACTMAILINGPROVINCECODE
  Variable Char LBLCONTACTMAILINGPOSTALCODE
  Variable Char LBLCONTACTMAILINGCOUNTRYCODE

  # Environment
  Local Char    WEBSERVICELANGUAGE(GLONLAN) : WEBSERVICELANGUAGE = GLANGUE
  Local Char    ERRMSG(255)

  # Addresses
  Local Char    CUSTOMERBILLINGADDRESS1(GLONADL)
  Local Char    CUSTOMERBILLINGADDRESS2(GLONADL)
  Local Char    CUSTOMERBILLINGADDRESS3(GLONADL)
  Local Char    CUSTOMERSHIPPINGADDRESS1(GLONADL)
  Local Char    CUSTOMERSHIPPINGADDRESS2(GLONADL)
  Local Char    CUSTOMERSHIPPINGADDRESS3(GLONADL)
  Local Char    CONTACTMAILINGADDRESS1(GLONADL)(dim(CONTACTMAILINGADDRESS))
  Local Char    CONTACTMAILINGADDRESS2(GLONADL)(dim(CONTACTMAILINGADDRESS))
  Local Char    CONTACTMAILINGADDRESS3(GLONADL)(dim(CONTACTMAILINGADDRESS))

  # Used across gosubs
  Local Char    FUNCTION(30) : FUNCTION = "soapRead"
  Local Clbfile ARGUMENTS
  Local Clbfile RESBODY

  # Logging across gosubs
  Local Instance MYLOG Using C_ALOG
  MYLOG=NewInstance C_ALOG AllocGroup null
  OK=fmet MYLOG.ABEGINLOG("CRMSFBPCR"-mess(3,7845,1))
  OK=fmet MYLOG.APUTLINE("Reading customer"-CUSTOMERNUMBER,OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

  # Build call to BPC web service
  ARGUMENTS = '"'
  Append ARGUMENTS, WEBSERVICELANGUAGE    # <codeLang> from ws call to this subprogram
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'SFCRMPOOL'            # TODO can this come from call?  <poolAlias>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'CRMSFBPC'            # <publicName>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'BPCNUM'              # <objectKeys.key>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, CUSTOMERNUMBER        # <objectKeys.value>
  Append ARGUMENTS, '"'

#-------------------------------------------------------------------------------------------------#
# Unremark below line to log contents of ARGUMENTS
#  OK = fmet MYLOG.APUTLINE("ARGUMENTS ="-ARGUMENTS, OK) : OK = fmet MYLOG.AFLUSHLOG
#-------------------------------------------------------------------------------------------------#

If ERRMSG <> ""
     RESPONSEMESSAGES(1) = ERRMSG
  Else
    Gosub CALLBUNDLE From CRMSF
    If ERRMSG <> ""
      RESPONSEMESSAGES(1) = ERRMSG
    Else
      RESPONSESTATUS = func CRMSF.GETRESPONSESTATUS(RESBODY)
      If RESPONSESTATUS=0
        Gosub LOADRESPONSES From CRMSF
      Else
        Gosub PROCESSRETURNEDXML
        If ERRMSG=""
          OK=fmet MYLOG.APUTLINE("Read customer"-CUSTOMERNUMBER-CUSTOMERNAME,OK)    # TODO translation
        Else
          RESPONSEMESSAGES(1) = ERRMSG
          OK=fmet MYLOG.APUTLINE(RESPONSEMESSAGES(1),OK)
       Endif
      Endif
    Endif
  Endif

  # End logging
  OK = fmet MYLOG.AENDLOG
  FreeGroup MYLOG

End

####################################################################################################

####################################################################################################
# Subprogram for Salesforce to modify a customer with contacts in X3
####################################################################################################

Subprog MODIFYCUSTOMER(CUSTOMERNUMBER,
&                      CUSTOMERNAME,
&                      CUSTOMERPHONE,
&                      CUSTOMERFAX,
&                      CUSTOMERWEBSITE,
&                      CUSTOMERCOUNTRYCODE,
&                      CUSTOMERBILLINGADDRESSNUMBER,
&                      CUSTOMERBILLINGADDRESS,
&                      CUSTOMERBILLINGCITY,
&                      CUSTOMERBILLINGPROVINCECODE,
&                      CUSTOMERBILLINGPOSTALCODE,
&                      CUSTOMERBILLINGCOUNTRYCODE,
&                      CUSTOMERSHIPPINGADDRESSNUMBER,
&                      CUSTOMERSHIPPINGADDRESS,
&                      CUSTOMERSHIPPINGCITY,
&                      CUSTOMERSHIPPINGPROVINCECODE,
&                      CUSTOMERSHIPPINGPOSTALCODE,
&                      CUSTOMERSHIPPINGCOUNTRYCODE,
&                      CONTACTNUMBER,
&                      CONTACTFIRSTNAME,
&                      CONTACTLASTNAME,
&                      CONTACTPHONE,
&                      CONTACTFAX,
&                      CONTACTEMAIL,
&                      CONTACTMAILINGADDRESSNUMBER,
&                      CONTACTMAILINGADDRESS,
&                      CONTACTMAILINGCITY,
&                      CONTACTMAILINGPROVINCECODE,
&                      CONTACTMAILINGPOSTALCODE,
&                      CONTACTMAILINGCOUNTRYCODE,
&                      RESPONSESTATUS,
&                      RESPONSEMESSAGES,
&                      LBLCUSTOMERNUMBER,
&                      LBLCUSTOMERNAME,
&                      LBLCUSTOMERPHONE,
&                      LBLCUSTOMERFAX,
&                      LBLCUSTOMERWEBSITE,
&                      LBLCUSTOMERCOUNTRYCODE,
&                      LBLCUSTOMERBILLINGADDRESSNUM,
&                      LBLCUSTOMERBILLINGADDRESS,
&                      LBLCUSTOMERBILLINGCITY,
&                      LBLCUSTOMERBILLINGPROVINCECODE,
&                      LBLCUSTOMERBILLINGPOSTALCODE,
&                      LBLCUSTOMERBILLINGCOUNTRYCODE,
&                      LBLCUSTOMERSHIPPINGADDRESSNUM,
&                      LBLCUSTOMERSHIPPINGADDRESS,
&                      LBLCUSTOMERSHIPPINGCITY,
&                      LBLCUSTOMERSHIPPINGPROVINCECOD,
&                      LBLCUSTOMERSHIPPINGPOSTALCODE,
&                      LBLCUSTOMERSHIPPINGCOUNTRYCODE,
&                      LBLCONTACTNUMBER,
&                      LBLCONTACTFIRSTNAME,
&                      LBLCONTACTLASTNAME,
&                      LBLCONTACTPHONE,
&                      LBLCONTACTFAX,
&                      LBLCONTACTEMAIL,
&                      LBLCONTACTMAILINGADDRESSNUMBER,
&                      LBLCONTACTMAILINGADDRESS,
&                      LBLCONTACTMAILINGCITY,
&                      LBLCONTACTMAILINGPROVINCECODE,
&                      LBLCONTACTMAILINGPOSTALCODE,
&                      LBLCONTACTMAILINGCOUNTRYCODE)

  Variable Char CUSTOMERNUMBER
  Variable Char CUSTOMERNAME
  Variable Char CUSTOMERPHONE
  Variable Char CUSTOMERFAX
  Variable Char CUSTOMERWEBSITE
  Variable Char CUSTOMERCOUNTRYCODE

  Variable Char CUSTOMERBILLINGADDRESSNUMBER
  Variable Char CUSTOMERBILLINGADDRESS
  Variable Char CUSTOMERBILLINGCITY
  Variable Char CUSTOMERBILLINGPROVINCECODE
  Variable Char CUSTOMERBILLINGPOSTALCODE
  Variable Char CUSTOMERBILLINGCOUNTRYCODE

  Variable Char CUSTOMERSHIPPINGADDRESSNUMBER
  Variable Char CUSTOMERSHIPPINGADDRESS
  Variable Char CUSTOMERSHIPPINGCITY
  Variable Char CUSTOMERSHIPPINGPROVINCECODE
  Variable Char CUSTOMERSHIPPINGPOSTALCODE
  Variable Char CUSTOMERSHIPPINGCOUNTRYCODE

  Variable Char CONTACTNUMBER()(1..)
  Variable Char CONTACTFIRSTNAME()(1..)
  Variable Char CONTACTLASTNAME()(1..)
  Variable Char CONTACTPHONE()(1..)
  Variable Char CONTACTFAX()(1..)
  Variable Char CONTACTEMAIL()(1..)

  Variable Char CONTACTMAILINGADDRESSNUMBER()(1..)
  Variable Char CONTACTMAILINGADDRESS()(1..)
  Variable Char CONTACTMAILINGCITY()(1..)
  Variable Char CONTACTMAILINGPROVINCECODE()(1..)
  Variable Char CONTACTMAILINGPOSTALCODE()(1..)
  Variable Char CONTACTMAILINGCOUNTRYCODE()(1..)

  Variable Integer RESPONSESTATUS
  Variable Char    RESPONSEMESSAGES()(1..)

  Variable Char LBLCUSTOMERNUMBER
  Variable Char LBLCUSTOMERNAME
  Variable Char LBLCUSTOMERPHONE
  Variable Char LBLCUSTOMERFAX
  Variable Char LBLCUSTOMERWEBSITE
  Variable Char LBLCUSTOMERCOUNTRYCODE

  Variable Char LBLCUSTOMERBILLINGADDRESSNUM
  Variable Char LBLCUSTOMERBILLINGADDRESS
  Variable Char LBLCUSTOMERBILLINGCITY
  Variable Char LBLCUSTOMERBILLINGPROVINCECODE
  Variable Char LBLCUSTOMERBILLINGPOSTALCODE
  Variable Char LBLCUSTOMERBILLINGCOUNTRYCODE

  Variable Char LBLCUSTOMERSHIPPINGADDRESSNUM
  Variable Char LBLCUSTOMERSHIPPINGADDRESS
  Variable Char LBLCUSTOMERSHIPPINGCITY
  Variable Char LBLCUSTOMERSHIPPINGPROVINCECOD
  Variable Char LBLCUSTOMERSHIPPINGPOSTALCODE
  Variable Char LBLCUSTOMERSHIPPINGCOUNTRYCODE

  Variable Char LBLCONTACTNUMBER
  Variable Char LBLCONTACTFIRSTNAME
  Variable Char LBLCONTACTLASTNAME
  Variable Char LBLCONTACTPHONE
  Variable Char LBLCONTACTFAX
  Variable Char LBLCONTACTEMAIL

  Variable Char LBLCONTACTMAILINGADDRESSNUMBER
  Variable Char LBLCONTACTMAILINGADDRESS
  Variable Char LBLCONTACTMAILINGCITY
  Variable Char LBLCONTACTMAILINGPROVINCECODE
  Variable Char LBLCONTACTMAILINGPOSTALCODE
  Variable Char LBLCONTACTMAILINGCOUNTRYCODE

 # Environment
  Local Char    WEBSERVICELANGUAGE(GLONLAN) : WEBSERVICELANGUAGE = GLANGUE
  Local Char    ERRMSG(255)

  # Customer
  Local Char    CUSTOMERCATEGORY(GLONBCG)
  Local Char    CUSTOMERBILLINGADDRESS1(GLONADL)
  Local Char    CUSTOMERBILLINGADDRESS2(GLONADL)
  Local Char    CUSTOMERBILLINGADDRESS3(GLONADL)
  Local Char    CUSTOMERSHIPPINGADDRESS1(GLONADL)
  Local Char    CUSTOMERSHIPPINGADDRESS2(GLONADL)
  Local Char    CUSTOMERSHIPPINGADDRESS3(GLONADL)
  Local Char    CONTACTMAILINGADDRESS1(GLONADL)(dim(CONTACTMAILINGADDRESS))
  Local Char    CONTACTMAILINGADDRESS2(GLONADL)(dim(CONTACTMAILINGADDRESS))
  Local Char    CONTACTMAILINGADDRESS3(GLONADL)(dim(CONTACTMAILINGADDRESS))

  # Used across gosubs
  Local Char    FUNCTION(30) : FUNCTION = "soapModify"
  Local Clbfile ARGUMENTS
  Local Clbfile RESBODY

 # Logging across gosubs
  Local Instance MYLOG Using C_ALOG
  MYLOG=NewInstance C_ALOG AllocGroup null
  OK=fmet MYLOG.ABEGINLOG("CRMSFBPCM"-mess(3,7845,1))
  OK=fmet MYLOG.APUTLINE("Modiying customer"-CUSTOMERNAME-"from Salesforce",OK)   # TODO translation
  OK=fmet MYLOG.AFLUSHLOG

  Gosub DATARECEIVED

  Gosub BUILDXMLMODIFY
  If ERRMSG <> ""
     RESPONSEMESSAGES(1) = ERRMSG
  Else
    Gosub CALLBUNDLE From CRMSF
    If ERRMSG <> ""
      RESPONSEMESSAGES(1) = ERRMSG
    Else
      RESPONSESTATUS = func CRMSF.GETRESPONSESTATUS(RESBODY)
      If RESPONSESTATUS=0
        Gosub LOADRESPONSES From CRMSF
      Else
        Gosub PROCESSRETURNEDXML
        If ERRMSG <> ""
          RESPONSESTATUS = 0
          RESPONSEMESSAGES(1) = ERRMSG
        Else
          OK=fmet MYLOG.APUTLINE("Modified customer"-CUSTOMERNUMBER-CUSTOMERNAME,OK) : OK = fmet MYLOG.AFLUSHLOG    # TODO translation
        Endif
      Endif
    Endif
  Endif

  # End logging
  OK = fmet MYLOG.AENDLOG
  FreeGroup MYLOG

End

####################################################################################################

$ BUILDXMLMODIFY

  Local Clbfile COUNTRYXML
  Local Integer ADDRESSLINES
  Local Clbfile ADDRESSESXML
  Local Clbfile SHIPTOXML
  Local Integer SHIPTOADDRESSLINES
  Local Clbfile SHIPTOADDRESSESXML
  Local Tinyint SHIPEXISTS
  Local Integer LOOP

  # Get category from existing record
  If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC] : Endif
  Read [F:BPC]BPC0=CUSTOMERNUMBER
  If !fstat
    CUSTOMERCATEGORY = [F:BPC]BCGCOD
  Else
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000102", mess(23,100,1), CUSTOMERNUMBER, func CRMSF.GETLABEL("BPC0", "BPCNUM"))
    Return
  Endif

  # Get country from existing record
  If clalev([F:BPR]) = 0 : Local File BPARTNER [BPR] : Endif
  Read [F:BPR]BPR0=CUSTOMERNUMBER
  CUSTOMERCOUNTRYCODE = [F:BPR]CRY

  # Get values based on country
  COUNTRYXML = func GETCOUNTRYXML(CUSTOMERCOUNTRYCODE, ERRMSG)
  If ERRMSG <> "" : Return : Endif

  # Customer addresses
  If clalev([F:BPA]) = 0 : Local File BPADDRESS [BPA] : Endif
  Filter [BPA] Where [F:BPA]BPANUM=CUSTOMERNUMBER

  # Get current address numbers
  CUSTOMERBILLINGADDRESSNUMBER  = [F:BPC]BPAINV
  CUSTOMERSHIPPINGADDRESSNUMBER = [F:BPC]BPDADD

  # Compare address numbers to determine if a new one is needed
  If [F:BPC]BPCINV = [F:BPC]BPCPYR and CUSTOMERBILLINGADDRESSNUMBER = CUSTOMERSHIPPINGADDRESSNUMBER
    # Create new shipping address number (next available SHIP#) and use it for the shipping address
    For LOOP = 49 To 90
      Read [F:BPA]BPA0 = 1;CUSTOMERNUMBER;"SHIP"+chr$(LOOP)
      If fstat
        CUSTOMERSHIPPINGADDRESSNUMBER = "SHIP"+chr$(LOOP)
        Break
      Endif
      If LOOP = 57 : LOOP = 65 : Endif
    Next
    If LOOP=90 &  CUSTOMERSHIPPINGADDRESSNUMBER<>"SHIPZ"
      ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000109", mess(187,143,1), "SHIP*", func CRMSF.GETLABEL("BPC4", "BPDADD"))
    Endif
  Endif

  # Get list of all address codes and build XML. If an incomplete list is submitted for a modify then unlisted codes are removed from the customer.
  For [BPA]
    ADDRESSLINES += 1
    If [F:BPA]BPAADD = CUSTOMERBILLINGADDRESSNUMBER
      Call PARSEADDRESS(CUSTOMERBILLINGADDRESS, CUSTOMERBILLINGADDRESS1, CUSTOMERBILLINGADDRESS2, CUSTOMERBILLINGADDRESS3) From CRMSF
      ADDRESSESXML += func BUILDADDRESSXML(CUSTOMERBILLINGADDRESSNUMBER, ADDRESSLINES, CUSTOMERBILLINGADDRESS1, CUSTOMERBILLINGADDRESS2, CUSTOMERBILLINGADDRESS3,
&                                        CUSTOMERBILLINGCITY, CUSTOMERBILLINGPROVINCECODE, CUSTOMERBILLINGPOSTALCODE, CUSTOMERBILLINGCOUNTRYCODE,
&                                        CUSTOMERPHONE, CUSTOMERFAX, CUSTOMERWEBSITE)
    Elsif [F:BPA]BPAADD = CUSTOMERSHIPPINGADDRESSNUMBER
      Call PARSEADDRESS(CUSTOMERSHIPPINGADDRESS, CUSTOMERSHIPPINGADDRESS1, CUSTOMERSHIPPINGADDRESS2, CUSTOMERSHIPPINGADDRESS3) From CRMSF
      ADDRESSESXML += func BUILDADDRESSXML(CUSTOMERSHIPPINGADDRESSNUMBER, ADDRESSLINES, CUSTOMERSHIPPINGADDRESS1, CUSTOMERSHIPPINGADDRESS2, CUSTOMERSHIPPINGADDRESS3,
&                                        CUSTOMERSHIPPINGCITY, CUSTOMERSHIPPINGPROVINCECODE, CUSTOMERSHIPPINGPOSTALCODE, CUSTOMERSHIPPINGCOUNTRYCODE, "", "", "")
      If ERRMSG <> "" : Return : Endif
      SHIPEXISTS = 1
    Else
      ADDRESSESXML += func BUILDADDRESSXML([F:BPA]BPAADD, ADDRESSLINES, "", "", "", "", "", "", "", "", "", "")
    Endif

  Next

  # Get list of all Ship-to address codes. If an incomplete list is submitted for a modify then unlisted codes are removed from the customer.
  SHIPTOADDRESSESXML = func GETSHIPTOADDRESSESXML(CUSTOMERNUMBER, SHIPTOADDRESSLINES)

  # Add shipping address if new
  If !SHIPEXISTS and CUSTOMERSHIPPINGADDRESS > ""
    ADDRESSLINES += 1
    Call PARSEADDRESS(CUSTOMERSHIPPINGADDRESS, CUSTOMERSHIPPINGADDRESS1, CUSTOMERSHIPPINGADDRESS2, CUSTOMERSHIPPINGADDRESS3) From CRMSF
    ADDRESSESXML += func BUILDADDRESSXML(CUSTOMERSHIPPINGADDRESSNUMBER, ADDRESSLINES, CUSTOMERSHIPPINGADDRESS1, CUSTOMERSHIPPINGADDRESS2, CUSTOMERSHIPPINGADDRESS3,
&                                      CUSTOMERSHIPPINGCITY, CUSTOMERSHIPPINGPROVINCECODE, CUSTOMERSHIPPINGPOSTALCODE, CUSTOMERSHIPPINGCOUNTRYCODE, "", "", "")
    SHIPTOADDRESSLINES += 1
    SHIPTOXML = func GETSHIPTOXML(CUSTOMERCATEGORY, CUSTOMERSHIPPINGADDRESSNUMBER, SHIPTOADDRESSLINES, ERRMSG)
    If ERRMSG <> "" : Return : Endif
  Endif


  # Build call to BPC web service
  ARGUMENTS = '"'
  Append ARGUMENTS, WEBSERVICELANGUAGE   # <codeLang> from ws call to this subprogram
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'SFCRMPOOL'        # TODO can this come from call?  <poolAlias>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'CRMSFBPC'        # <publicName>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'BPCNUM'          # <objectKeys.key>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, CUSTOMERNUMBER    # <objectKeys.value>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, '<PARAM>'   # <requestXml>
  Append ARGUMENTS,   '<GRP ID=\"BPC0_1\">'
  Append ARGUMENTS,     '<FLD NAME=\"BCGCOD\" type=\"Char\">' + CUSTOMERCATEGORY + '</FLD>'
  Append ARGUMENTS,     '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"BPCSTA\" type=\"Integer\">2</FLD>'   # Active flag
  Append ARGUMENTS,     '<FLD NAME=\"BPCNUM\" type=\"Char\">' + CUSTOMERNUMBER + '</FLD>'
  Append ARGUMENTS,   '</GRP>'
  Append ARGUMENTS,   '<GRP ID=\"BPRC_1\">'
  Append ARGUMENTS,     COUNTRYXML
  Append ARGUMENTS,     '<LST NAME=\"BPRNAM\" SIZE=\"1\" type=\"Char\">'                                  #
  Append ARGUMENTS,       '<ITM>' + func CRMSF.ESCAPECHARS(CUSTOMERNAME, "IN") + '</ITM>'                 # Limiting customer name to 1 field for now
  Append ARGUMENTS,     '</LST>'                                                                          #
  Append ARGUMENTS,   '</GRP>'
  Append ARGUMENTS,   '<GRP ID=\"BPC3_1\">'
  Append ARGUMENTS,     '<FLD NAME=\"BPAINV\" TYPE=\"Char\">' + CUSTOMERBILLINGADDRESSNUMBER + '</FLD>'
  Append ARGUMENTS,   '</GRP>'
  Append ARGUMENTS,   '<TAB DIM=\"' + num$(func AFNC.ACTIV("BPA")) + '\" ID=\"BPAC_1\" SIZE=\"' + num$(ADDRESSLINES) + '\">'
  Append ARGUMENTS,     ADDRESSESXML
  Append ARGUMENTS,   '</TAB>'
  Append ARGUMENTS,   '<TAB DIM=\"' + num$(func AFNC.ACTIV("BPA")) + '\" ID=\"BPC4_1\" SIZE=\"' + num$(SHIPTOADDRESSLINES) + '\">'
  Append ARGUMENTS,     SHIPTOADDRESSESXML
  Append ARGUMENTS,     SHIPTOXML
  Append ARGUMENTS,   '</TAB>'
  Append ARGUMENTS, '</PARAM>'
  Append ARGUMENTS, '"'

#-------------------------------------------------------------------------------------------------#
# Unremark below line to log contents of ARGUMENTS
#  Local Char     CLOBNAME(30)
#  Local Clbfile  CLOBDATA
#  CLOBNAME = "ARGUMENTS" : CLOBDATA = ARGUMENTS : Gosub LOGCLOB From CRMSF
#-------------------------------------------------------------------------------------------------#

Return

####################################################################################################

####################################################################################################
# Subprogram for Salesforce to get additional customer information and sales order data
####################################################################################################

Subprog CUSTOMERDETAILS(CUSTOMERNUMBER,
&                       CUSTOMERNAME,
&                       SITETAXIDNO,
&                       SICCODE,
&                       CATEGORY,
&                       DESCATEGORY,
&                       COUNTRY,
&                       DESCOUNTRY,
&                       LANGUAGE,
&                       DESLANGUAGE,
&                       CURRENCY,
&                       DESCURRENCY,
&                       CREDITCONTROL,
&                       CREDITLEVELTOTAL,
&                       AUTHORIZEDCREDIT,
&                       BILLTOCUSTOMER,
&                       DESBILLTOCUSTOMER,
&                       BILLTOADDRESS,
&                       BILLTOADDRESSCITY,
&                       BILLTOADDRESSPROVINCE,
&                       BILLTOADDRESSPOSTALCODE,
&                       BILLTOADDRESSCOUNTRY,
&                       GROUPCUSTOMER,
&                       DESGROUPCUSTOMER,
&                       RISKCUSTOMER,
&                       DESRISKCUSTOMER,
&                       PAYBYCUSTOMER,
&                       DESPAYBYCUSTOMER,
&                       PAYBYADDRESS,
&                       PAYBYADDRESSCITY,
&                       PAYBYADDRESSPROVINCE,
&                       PAYBYADDRESSPOSTALCODE,
&                       PAYBYADDRESSCOUNTRY,
&                       ACCOUNTINGCODE,
&                       DESACCOUNTINGCODE,
&                       TAXRULE,
&                       DESTAXRULE,
&                       PAYMENTTERM,
&                       DESPAYMENTTERM,
&                       ORDERNUMBER,
&                       ORDERDATE,
&                       ORDERTYPE,
&                       SALESSITE,
&                       ORDERREFERENCE,
&                       SOLDTO,
&                       ORDERSTATE,
&                       RESPONSESTATUS,
&                       RESPONSEMESSAGES,
&                       LBLCUSTOMERNUMBER,
&                       LBLCUSTOMERNAME,
&                       LBLSITETAXIDNO,
&                       LBLSICCODE,
&                       LBLCATEGORY,
&                       LBLCOUNTRY,
&                       LBLLANGUAGE,
&                       LBLCURRENCY,
&                       LBLCREDITCONTROL,
&                       LBLCREDITLEVELTOTAL,
&                       LBLAUTHORIZEDCREDIT,
&                       LBLBILLTOCUSTOMER,
&                       LBLBILLTOADDRESS,
&                       LBLGROUPCUSTOMER,
&                       LBLRISKCUSTOMER,
&                       LBLPAYBYCUSTOMER,
&                       LBLPAYBYADDRESS,
&                       LBLACCOUNTINGCODE,
&                       LBLTAXRULE,
&                       LBLPAYMENTTERM,
&                       LBLORDERNUMBER,
&                       LBLORDERDATE,
&                       LBLORDERTYPE,
&                       LBLSALESSITE,
&                       LBLORDERREFERENCE,
&                       LBLSOLDTO,
&                       LBLORDERSTATE)

  Variable Char CUSTOMERNUMBER
  Variable Char CUSTOMERNAME
  Variable Char SITETAXIDNO
  Variable Char SICCODE
  Variable Char CATEGORY
  Variable Char DESCATEGORY
  Variable Char COUNTRY
  Variable Char DESCOUNTRY
  Variable Char LANGUAGE
  Variable Char DESLANGUAGE
  Variable Char CURRENCY
  Variable Char DESCURRENCY
  Variable Char CREDITCONTROL
  Variable Char CREDITLEVELTOTAL
  Variable Char AUTHORIZEDCREDIT
  Variable Char BILLTOCUSTOMER
  Variable Char DESBILLTOCUSTOMER
  Variable Char BILLTOADDRESS
  Variable Char BILLTOADDRESSCITY
  Variable Char BILLTOADDRESSPROVINCE
  Variable Char BILLTOADDRESSPOSTALCODE
  Variable Char BILLTOADDRESSCOUNTRY
  Variable Char GROUPCUSTOMER
  Variable Char DESGROUPCUSTOMER
  Variable Char RISKCUSTOMER
  Variable Char DESRISKCUSTOMER
  Variable Char PAYBYCUSTOMER
  Variable Char PAYBYADDRESS
  Variable Char PAYBYADDRESSCITY
  Variable Char PAYBYADDRESSPROVINCE
  Variable Char PAYBYADDRESSPOSTALCODE
  Variable Char PAYBYADDRESSCOUNTRY
  Variable Char DESPAYBYCUSTOMER
  Variable Char ACCOUNTINGCODE
  Variable Char DESACCOUNTINGCODE
  Variable Char TAXRULE
  Variable Char DESTAXRULE
  Variable Char PAYMENTTERM
  Variable Char DESPAYMENTTERM
  Variable Char ORDERNUMBER()(0..)
  Variable Char ORDERDATE()(0..)
  Variable Char ORDERTYPE()(0..)
  Variable Char SALESSITE()(0..)
  Variable Char ORDERREFERENCE()(0..)
  Variable Char SOLDTO()(0..)
  Variable Char ORDERSTATE()(0..)

  Variable Integer RESPONSESTATUS
  Variable Char    RESPONSEMESSAGES()(1..)

  Variable Char LBLCUSTOMERNUMBER
  Variable Char LBLCUSTOMERNAME
  Variable Char LBLSITETAXIDNO
  Variable Char LBLSICCODE
  Variable Char LBLCATEGORY
  Variable Char LBLCOUNTRY
  Variable Char LBLLANGUAGE
  Variable Char LBLCURRENCY
  Variable Char LBLCREDITCONTROL
  Variable Char LBLCREDITLEVELTOTAL
  Variable Char LBLAUTHORIZEDCREDIT
  Variable Char LBLBILLTOCUSTOMER
  Variable Char LBLBILLTOADDRESS
  Variable Char LBLGROUPCUSTOMER
  Variable Char LBLRISKCUSTOMER
  Variable Char LBLPAYBYCUSTOMER
  Variable Char LBLPAYBYADDRESS
  Variable Char LBLACCOUNTINGCODE
  Variable Char LBLTAXRULE
  Variable Char LBLPAYMENTTERM
  Variable Char LBLORDERNUMBER
  Variable Char LBLORDERDATE
  Variable Char LBLORDERTYPE
  Variable Char LBLSALESSITE
  Variable Char LBLORDERREFERENCE
  Variable Char LBLSOLDTO
  Variable Char LBLORDERSTATE

  # Environment
  Local Char    WEBSERVICELANGUAGE(GLONLAN) : WEBSERVICELANGUAGE = GLANGUE
  Local Char    ERRMSG(255)

  # Addresses
  Local Char    BILLTOADDRESS1(GLONADL)
  Local Char    BILLTOADDRESS2(GLONADL)
  Local Char    BILLTOADDRESS3(GLONADL)
  Local Char    PAYBYADDRESS1(GLONADL)
  Local Char    PAYBYADDRESS2(GLONADL)
  Local Char    PAYBYADDRESS3(GLONADL)

  # Used across gosubs
  Local Char    FUNCTION(30) : FUNCTION = "soapRead"
  Local Clbfile ARGUMENTS
  Local Clbfile RESBODY

  # Logging across gosubs
  Local Instance MYLOG Using C_ALOG
  MYLOG=NewInstance C_ALOG AllocGroup null
  OK=fmet MYLOG.ABEGINLOG("CRMSFBPCR"-mess(3,7845,1))
  OK=fmet MYLOG.APUTLINE("Reading customer details for"-CUSTOMERNUMBER-CUSTOMERNAME,OK)   # TODO translation
  OK=fmet MYLOG.AFLUSHLOG

  # Build call to BPC web service
  ARGUMENTS = '"'
  Append ARGUMENTS, WEBSERVICELANGUAGE    # <codeLang> from ws call to this subprogram
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'SFCRMPOOL'            # TODO can this come from call?  <poolAlias>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'CRMSFBPC'            # <publicName>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'BPCNUM'              # <objectKeys.key>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, CUSTOMERNUMBER        # <objectKeys.value>
  Append ARGUMENTS, '"'

#-------------------------------------------------------------------------------------------------#
# Unremark below line to log contents of ARGUMENTS
#  OK = fmet MYLOG.APUTLINE("ARGUMENTS ="-ARGUMENTS, OK) : OK = fmet MYLOG.AFLUSHLOG
#-------------------------------------------------------------------------------------------------#

If ERRMSG <> ""
     RESPONSEMESSAGES(1) = ERRMSG
  Else
    Gosub CALLBUNDLE From CRMSF
    If ERRMSG <> ""
      RESPONSEMESSAGES(1) = ERRMSG
    Else
      RESPONSESTATUS = func CRMSF.GETRESPONSESTATUS(RESBODY)
      If RESPONSESTATUS=0
        Gosub LOADRESPONSES From CRMSF
      Else
        Gosub PROCESSDETAILRETURNEDXML
        If ERRMSG <> ""
          RESPONSEMESSAGES(1) = ERRMSG
        Else
          OK=fmet MYLOG.APUTLINE("Read customer details for"-CUSTOMERNUMBER-CUSTOMERNAME,OK) : OK = fmet MYLOG.AFLUSHLOG    # TODO translation
       Endif
      Endif
    Endif
  Endif

  # End logging
  OK = fmet MYLOG.AENDLOG
  FreeGroup MYLOG

End

####################################################################################################

$PROCESSDETAILRETURNEDXML

  OK = fmet MYLOG.APUTLINE(mess(RESPONSESTATUS,189,1), OK) : OK = fmet MYLOG.AFLUSHLOG

  # Populate return variables
  Gosub LOADDETAILRETURNVALUES
  If ERRMSG = ""
    Gosub LOADSORETURNVALUES
    If ERRMSG = ""
      # Get field labels
      Gosub LOADDETAILLABELS
    Endif
  Endif

Return

####################################################################################################

$LOADDETAILRETURNVALUES

  Local Char CURRENCYFORMAT(30)
  Local Char BILLTOADDRESSNUMBER(GLONADR)
  Local Char BILLTOCOUNTRYCODE(GLONCRY)
  Local Char BILLTOPROVINCECODE(GLONSAT)
  Local Char PAYBYADDRESSNUMBER(GLONADR)
  Local Char PAYBYCOUNTRYCODE(GLONCRY)
  Local Char PAYBYPROVINCECODE(GLONSAT)
  Local Char PHONE(0)
  Local Char FAX(0)
  Local Char WEBSITE(0)

  CUSTOMERNUMBER   = func CRMSF.GETXMLVALUE(RESBODY, "BPC0_1", 0, "BPCNUM")

  CUSTOMERNAMELIST = func CRMSF.GETXMLVALUE(RESBODY, "BPRC_1", 0, "BPRNAM")
  CUSTOMERNAME     = func CRMSF.GETLISTVALUE(CUSTOMERNAMELIST, 1)

  COUNTRY          = func CRMSF.GETXMLVALUE(RESBODY, "BPRC_1", 0, "CRY")
  DESCOUNTRY       = func CRMSF.GETXMLVALUE(RESBODY, "BPRC_1", 0, "ZCRY")

  If clalev([F:TCY]) = 0 : Local File TABCOUNTRY [TCY] : Endif
  Read [F:TCY]TCY0=COUNTRY

  SITETAXIDNO = func CRMSF.GETXMLVALUE(RESBODY, "BPRC_1", 0, "CRN")
  If SITETAXIDNO <> "" & [F:TCY]CRTFMT <> ""
    SITETAXIDNO = vireblc(format$("K:"+[F:TCY]CRTFMT, SITETAXIDNO), 2)
  Endif

  SICCODE = func CRMSF.GETXMLVALUE(RESBODY, "BPC0_1", 0, "NAF")
  If SICCODE <> "" & [F:TCY]NAFFMT <> ""
    SICCODE = vireblc(format$("K:"+[F:TCY]NAFFMT, SICCODE), 2)
  Endif

  CATEGORY       = func CRMSF.GETXMLVALUE(RESBODY, "BPC0_1", 0, "BCGCOD")
  DESCATEGORY    = func CRMSF.GETXMLVALUE(RESBODY, "BPC0_1", 0, "ZBCGCOD")
  LANGUAGE       = func CRMSF.GETXMLVALUE(RESBODY, "BPRC_1", 0, "LAN")
  DESLANGUAGE    = func CRMSF.GETXMLVALUE(RESBODY, "BPRC_1", 0, "ZLAN")
  CURRENCY       = func CRMSF.GETXMLVALUE(RESBODY, "BPRC_1", 0, "CUR")
  DESCURRENCY    = func CRMSF.GETXMLVALUE(RESBODY, "BPRC_1", 0, "ZCUR")

  CREDITCONTROL  = func CRMSF.GETXMLVALUE(RESBODY, "BPC2_2", 0, "OSTCTL")
  CREDITCONTROL  = mess(val(CREDITCONTROL),234,1)

  If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
  Read [ATY]CODTYP = "MD1"
  CURRENCYFORMAT = "N" + [F:ATY]OPTION + ":" + num$([F:ATY]LNGTYP)

  CREDITLEVELTOTAL = vireblc(format$(CURRENCYFORMAT, func CRMSF.GETXMLVALUE(RESBODY, "BPC2_2", 0, "XOST")), 2)
  AUTHORIZEDCREDIT = vireblc(format$(CURRENCYFORMAT, func CRMSF.GETXMLVALUE(RESBODY, "BPC2_2", 0, "WOSTAUZ")), 2)

  BILLTOCUSTOMER      = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_1", 0, "BPCINV")
  BILLTOADDRESSNUMBER = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_1", 0, "BPAINV")
  GROUPCUSTOMER       = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_1", 0, "BPCGRU")
  RISKCUSTOMER        = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_1", 0, "BPCRSK")
  PAYBYCUSTOMER       = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_1", 0, "BPCPYR")
  PAYBYADDRESSNUMBER  = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_1", 0, "BPAPYR")
  ACCOUNTINGCODE      = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_1", 0, "ACCCOD")
  DESACCOUNTINGCODE   = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_1", 0, "ZACCCOD")
  TAXRULE             = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_2", 0, "VACBPR")
  DESTAXRULE          = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_2", 0, "ZVACBPR")
  PAYMENTTERM         = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_3", 0, "PTE")
  DESPAYMENTTERM      = func CRMSF.GETXMLVALUE(RESBODY, "BPC3_3", 0, "ZPTE")

  If BILLTOCUSTOMER = CUSTOMERNUMBER
    DESBILLTOCUSTOMER = CUSTOMERNAME
  Else
    DESBILLTOCUSTOMER = func GETCUSTOMERNAME(BILLTOCUSTOMER)
  Endif

  If GROUPCUSTOMER = CUSTOMERNUMBER
    DESGROUPCUSTOMER = CUSTOMERNAME
  Else
    DESGROUPCUSTOMER = func GETCUSTOMERNAME(GROUPCUSTOMER)
  Endif

  If RISKCUSTOMER = CUSTOMERNUMBER
    DESRISKCUSTOMER = CUSTOMERNAME
  Else
    DESRISKCUSTOMER = func GETCUSTOMERNAME(RISKCUSTOMER)
  Endif

  If PAYBYCUSTOMER = CUSTOMERNUMBER
    DESPAYBYCUSTOMER = CUSTOMERNAME
  Else
    DESPAYBYCUSTOMER = func GETCUSTOMERNAME(PAYBYCUSTOMER)
  Endif

  Call GETADDRESS(BILLTOCUSTOMER, BILLTOADDRESSNUMBER, BILLTOADDRESS1, BILLTOADDRESS2, BILLTOADDRESS3, BILLTOADDRESSCITY,
&                 BILLTOPROVINCECODE, BILLTOADDRESSPROVINCE, BILLTOADDRESSPOSTALCODE, BILLTOCOUNTRYCODE, BILLTOADDRESSCOUNTRY, PHONE, FAX, WEBSITE, ERRMSG)
  If ERRMSG <> "" : Return : Endif
  Call COMBINEADDRESSES(BILLTOADDRESS1, BILLTOADDRESS2, BILLTOADDRESS3, BILLTOADDRESS) From CRMSF

  Call GETADDRESS(PAYBYCUSTOMER, PAYBYADDRESSNUMBER, PAYBYADDRESS1, PAYBYADDRESS2, PAYBYADDRESS3, PAYBYADDRESSCITY,
&                 PAYBYPROVINCECODE, PAYBYADDRESSPROVINCE, PAYBYADDRESSPOSTALCODE, PAYBYCOUNTRYCODE, PAYBYADDRESSCOUNTRY, PHONE, FAX, WEBSITE, ERRMSG)
  If ERRMSG <> "" : Return : Endif
  Call COMBINEADDRESSES(PAYBYADDRESS1, PAYBYADDRESS2, PAYBYADDRESS3, PAYBYADDRESS) From CRMSF

  OK=fmet MYLOG.APUTLINE("Customer detail return values loaded",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

  # Decode any XML escaped characters in the returned values
  If CUSTOMERNAME            <> "" : CUSTOMERNAME            = func CRMSF.ESCAPECHARS(CUSTOMERNAME           , "OUT") : Endif
  If SITETAXIDNO             <> "" : SITETAXIDNO             = func CRMSF.ESCAPECHARS(SITETAXIDNO            , "OUT") : Endif
  If SICCODE                 <> "" : SICCODE                 = func CRMSF.ESCAPECHARS(SICCODE                , "OUT") : Endif
  If DESCATEGORY             <> "" : DESCATEGORY             = func CRMSF.ESCAPECHARS(DESCATEGORY            , "OUT") : Endif
  If DESCOUNTRY              <> "" : DESCOUNTRY              = func CRMSF.ESCAPECHARS(DESCOUNTRY             , "OUT") : Endif
  If DESLANGUAGE             <> "" : DESLANGUAGE             = func CRMSF.ESCAPECHARS(DESLANGUAGE            , "OUT") : Endif
  If DESCURRENCY             <> "" : DESCURRENCY             = func CRMSF.ESCAPECHARS(DESCURRENCY            , "OUT") : Endif
  If DESBILLTOCUSTOMER       <> "" : DESBILLTOCUSTOMER       = func CRMSF.ESCAPECHARS(DESBILLTOCUSTOMER      , "OUT") : Endif
  If BILLTOADDRESS           <> "" : BILLTOADDRESS           = func CRMSF.ESCAPECHARS(BILLTOADDRESS          , "OUT") : Endif
  If BILLTOADDRESSCITY       <> "" : BILLTOADDRESSCITY       = func CRMSF.ESCAPECHARS(BILLTOADDRESSCITY      , "OUT") : Endif
  If BILLTOADDRESSPROVINCE   <> "" : BILLTOADDRESSPROVINCE   = func CRMSF.ESCAPECHARS(BILLTOADDRESSPROVINCE  , "OUT") : Endif
  If BILLTOADDRESSPOSTALCODE <> "" : BILLTOADDRESSPOSTALCODE = func CRMSF.ESCAPECHARS(BILLTOADDRESSPOSTALCODE, "OUT") : Endif
  If DESGROUPCUSTOMER        <> "" : DESGROUPCUSTOMER        = func CRMSF.ESCAPECHARS(DESGROUPCUSTOMER       , "OUT") : Endif
  If DESRISKCUSTOMER         <> "" : DESRISKCUSTOMER         = func CRMSF.ESCAPECHARS(DESRISKCUSTOMER        , "OUT") : Endif
  If PAYBYADDRESS            <> "" : PAYBYADDRESS            = func CRMSF.ESCAPECHARS(PAYBYADDRESS           , "OUT") : Endif
  If PAYBYADDRESSCITY        <> "" : PAYBYADDRESSCITY        = func CRMSF.ESCAPECHARS(PAYBYADDRESSCITY       , "OUT") : Endif
  If PAYBYADDRESSPROVINCE    <> "" : PAYBYADDRESSPROVINCE    = func CRMSF.ESCAPECHARS(PAYBYADDRESSPROVINCE   , "OUT") : Endif
  If PAYBYADDRESSPOSTALCODE  <> "" : PAYBYADDRESSPOSTALCODE  = func CRMSF.ESCAPECHARS(PAYBYADDRESSPOSTALCODE , "OUT") : Endif
  If DESPAYBYCUSTOMER        <> "" : DESPAYBYCUSTOMER        = func CRMSF.ESCAPECHARS(DESPAYBYCUSTOMER       , "OUT") : Endif
  If DESACCOUNTINGCODE       <> "" : DESACCOUNTINGCODE       = func CRMSF.ESCAPECHARS(DESACCOUNTINGCODE      , "OUT") : Endif
  If DESTAXRULE              <> "" : DESTAXRULE              = func CRMSF.ESCAPECHARS(DESTAXRULE             , "OUT") : Endif
  If DESPAYMENTTERM          <> "" : DESPAYMENTTERM          = func CRMSF.ESCAPECHARS(DESPAYMENTTERM         , "OUT") : Endif

  OK=fmet MYLOG.APUTLINE("Character conversion completed for customer details",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

Return

####################################################################################################

Subprog GETADDRESS(CUSTOMERNUMBER, ADDRESSNUMBER, ADDRESS1, ADDRESS2, ADDRESS3, CITY, PROVINCECODE, PROVINCENAME, POSTALCODE, COUNTRYCODE, COUNTRYNAME, PHONE, FAX, WEBSITE, ERRMSG)

  Value Char    CUSTOMERNUMBER
  Value Char    ADDRESSNUMBER
  Variable Char ADDRESS1
  Variable Char ADDRESS2
  Variable Char ADDRESS3
  Variable Char CITY
  Variable Char PROVINCECODE
  Variable Char PROVINCENAME
  Variable Char POSTALCODE
  Variable Char COUNTRYCODE
  Variable Char COUNTRYNAME
  Variable Char PHONE
  Variable Char FAX
  Variable Char WEBSITE
  Variable Char ERRMSG

  If clalev([F:BPA]) = 0 : Local File BPADDRESS [BPA] : Endif
  Read [F:BPA]BPA0=1;CUSTOMERNUMBER;ADDRESSNUMBER
  If ! fstat
    ADDRESS1     = [F:BPA]BPAADDLIG(0)
    ADDRESS2     = [F:BPA]BPAADDLIG(1)
    ADDRESS3     = [F:BPA]BPAADDLIG(2)
    CITY         = [F:BPA]CTY
    PROVINCECODE = [F:BPA]SAT
    POSTALCODE   = [F:BPA]POSCOD
    COUNTRYCODE  = [F:BPA]CRY
    PHONE        = [F:BPA]TEL(0)
    FAX          = [F:BPA]TEL(1)
    WEBSITE      = [F:BPA]FCYWEB
  Else
#    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000102", mess(23,100,1), ADDRESSNUMBER, func CRMSF.GETLABEL("BPABPC", "CODADR"))
  Endif

  # Formats from country
  If clalev([F:TCY]) = 0 : Local File TABCOUNTRY [TCY] : Endif
  Read [F:TCY]TCY0=COUNTRYCODE

  # Country
  Call LECTEXTRA(COUNTRYNAME, "TABCOUNTRY", "CRYDES", COUNTRYCODE, "") From ATEXTRA

  # Address lines
  If [F:TCY]ADRCODFMT <> ""
    If ADDRESS1 <> "" : ADDRESS1 = format$("Kv2:"+[F:TCY]ADRCODFMT, ADDRESS1) : Endif
    If ADDRESS2 <> "" : ADDRESS2 = format$("Kv2:"+[F:TCY]ADRCODFMT, ADDRESS2) : Endif
    If ADDRESS3 <> "" : ADDRESS3 = format$("Kv2:"+[F:TCY]ADRCODFMT, ADDRESS3) : Endif
  Endif

  # Postal code
  If POSTALCODE <> "" &  [F:TCY]POSCODFMT <> ""
    POSTALCODE = format$("Kv2:"+[F:TCY]POSCODFMT, POSTALCODE)
  Endif

  # City
  If CITY <> "" & [F:TCY]CTYCODFMT<> ""
    CITY = format$("Kv2:"+[F:TCY]CTYCODFMT, CITY)
  Endif

  # Subdivision
  Call LECTEXTRA(PROVINCENAME, "TABSUBDIV", "INTIT", COUNTRYCODE+"~"+num$([F:TCY]ETAT), PROVINCECODE) From ATEXTRA
  If PROVINCENAME <> "" & [F:TCY]ETATFMT <> ""
    Call FMTSATPAY(COUNTRYCODE, "") From TRTDIV
    PROVINCENAME = format$("Kv2:"+GFMT, PROVINCENAME)
  Endif

  # Telephones
  If PHONE <> "" &  [F:TCY]TELFMT <> ""
    PHONE = format$("Kv2:"+[F:TCY]TELFMT, PHONE)
  Endif

  If FAX <> "" &  [F:TCY]TELFMT <> ""
    FAX = format$("Kv2:"+[F:TCY]TELFMT, FAX)
  Endif

End

####################################################################################################

Funprog GETCUSTOMERNAME(CUSTOMERNUMBER)

  Value Char CUSTOMERNUMBER

  Local Char CUSTOMERNAME(35)

  If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC] : Endif
  Read [F:BPC]BPC0=CUSTOMERNUMBER
  If !fstat
    CUSTOMERNAME = [F:BPC]BPCNAM
  Endif

End CUSTOMERNAME

####################################################################################################

$LOADDETAILLABELS

  LBLCUSTOMERNUMBER   = func CRMSF.GETLABEL("BPC0",   "BPCNUM"   )
  LBLCUSTOMERNAME     = func CRMSF.GETLABEL("BPRBPC", "BPRNAM"   )
  LBLCOUNTRY          = func CRMSF.GETLABEL("BPRBPC", "CRY"      )
  LBLSITETAXIDNO      = func CRMSF.GETLABEL("BPRBPC", "CRN"      )
  LBLSICCODE          = func CRMSF.GETLABEL("BPRBPC", "NAF"      )
  LBLCATEGORY         = func CRMSF.GETLABEL("BPC0",   "BCGCOD"   )
  LBLLANGUAGE         = func CRMSF.GETLABEL("BPRBPC", "LAN"      )
  LBLCURRENCY         = func CRMSF.GETLABEL("BPRBPC", "CUR"      )
  LBLCREDITCONTROL    = func CRMSF.GETLABEL("BPC2",   "OSTCTL"   )
  LBLCREDITLEVELTOTAL = func CRMSF.GETLABEL("BPC2",   "XOST"     )
  LBLAUTHORIZEDCREDIT = func CRMSF.GETLABEL("BPC2",   "WOSTAUZ"  )
  LBLBILLTOCUSTOMER   = func CRMSF.GETLABEL("BPC3",   "BPCINV"   )
  LBLBILLTOADDRESS    = func CRMSF.GETLABEL("BPC3",   "BPAINV"   )
  LBLGROUPCUSTOMER    = func CRMSF.GETLABEL("BPC3",   "BPCGRU"   )
  LBLRISKCUSTOMER     = func CRMSF.GETLABEL("BPC3",   "BPCRSK"   )
  LBLPAYBYCUSTOMER    = func CRMSF.GETLABEL("BPC3",   "BPCPYR"   )
  LBLPAYBYADDRESS     = func CRMSF.GETLABEL("BPC3",   "BPAPYR"   )
  LBLACCOUNTINGCODE   = func CRMSF.GETLABEL("BPC3",   "ACCCOD"   )
  LBLTAXRULE          = func CRMSF.GETLABEL("BPC3",   "VACBPR"   )
  LBLPAYMENTTERM      = func CRMSF.GETLABEL("BPC3",   "PTE"      )
  LBLORDERNUMBER      = func CRMSF.GETLABEL("SOH0",   "SOHNUM"   )
  LBLORDERDATE        = func CRMSF.GETLABEL("SOH0",   "ORDDAT"   )
  LBLORDERTYPE        = func CRMSF.GETLABEL("SOH0",   "SOHTYP"   )
  LBLSALESSITE        = func CRMSF.GETLABEL("SOH0",   "SALFCY"   )
  LBLORDERREFERENCE   = func CRMSF.GETLABEL("SOH0",   "CUSORDREF")
  LBLSOLDTO           = func CRMSF.GETLABEL("SOH0",   "BPCORD"   )
  LBLORDERSTATE       = func CRMSF.GETLABEL("SOH1",   "ORDSTA"   )

  OK=fmet MYLOG.APUTLINE("Labels loaded",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

Return

####################################################################################################

$LOADSORETURNVALUES

  Local Integer LOOP
  Local Char DATEFORMAT(20)

  If clalev([F:SOH]) = 0 : Local File SORDER [SOH] : Endif

  Filter [SOH] Where BPCORD = CUSTOMERNUMBER Order By ORDDAT Desc
  Read [SOH] First
  If !fstat
    For LOOP=0 To dim(ORDERNUMBER)-1
      ORDERNUMBER(LOOP)    = [F:SOH]SOHNUM
      DATEFORMAT           = func CRMSF.GETDATEFORMAT(WEBSERVICELANGUAGE)
      ORDERDATE(LOOP)      = format$("DZ:"+DATEFORMAT, [F:SOH]ORDDAT)
      Call LECTEXTRA(ORDERTYPE(LOOP), "TABSOHTYP", "DESAXX", [F:SOH]SOHTYP, "") From ATEXTRA
      SALESSITE(LOOP)      = [F:SOH]SALFCY
      ORDERREFERENCE(LOOP) = [F:SOH]CUSORDREF
      SOLDTO(LOOP)         = [F:SOH]BPCORD
      ORDERSTATE(LOOP)     = mess([F:SOH]ORDSTA,415,1)
      Read [SOH] Next
      If fstat : Break : Endif
    Next LOOP
  Endif

  OK=fmet MYLOG.APUTLINE("Sales order return values loaded",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

  # Decode any XML escaped characters in the returned values
  For LOOP = 0 To dim(ORDERNUMBER)-1
    If ORDERREFERENCE(LOOP) <> "" : ORDERREFERENCE(LOOP) = func CRMSF.ESCAPECHARS(ORDERREFERENCE(LOOP), "OUT") : Endif
  Next LOOP

  OK=fmet MYLOG.APUTLINE("Character conversion completed for sales orders",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

Return

####################################################################################################

$ DATARECEIVED

  OK=fmet MYLOG.APUTLINE("\Begin data dump\",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

  OK=fmet MYLOG.APUTLINE("CUSTOMERNUMBER ="-CUSTOMERNUMBER,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERNAME ="-CUSTOMERNAME,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERPHONE ="-CUSTOMERPHONE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERFAX ="-CUSTOMERFAX,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERWEBSITE ="-CUSTOMERWEBSITE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERCOUNTRYCODE ="-CUSTOMERCOUNTRYCODE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("",OK) : OK=fmet MYLOG.AFLUSHLOG

  OK=fmet MYLOG.APUTLINE("CUSTOMERBILLINGADDRESSNUMBER ="-CUSTOMERBILLINGADDRESSNUMBER,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERBILLINGADDRESS ="-CUSTOMERBILLINGADDRESS,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERBILLINGCITY ="-CUSTOMERBILLINGCITY,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERBILLINGPROVINCECODE ="-CUSTOMERBILLINGPROVINCECODE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERBILLINGPOSTALCODE ="-CUSTOMERBILLINGPOSTALCODE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERBILLINGCOUNTRYCODE ="-CUSTOMERBILLINGCOUNTRYCODE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("",OK) : OK=fmet MYLOG.AFLUSHLOG

  OK=fmet MYLOG.APUTLINE("CUSTOMERSHIPPINGADDRESSNUMBER ="-CUSTOMERSHIPPINGADDRESSNUMBER,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERSHIPPINGADDRESS ="-CUSTOMERSHIPPINGADDRESS,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERSHIPPINGCITY ="-CUSTOMERSHIPPINGCITY,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERSHIPPINGPROVINCECODE ="-CUSTOMERSHIPPINGPROVINCECODE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERSHIPPINGPOSTALCODE ="-CUSTOMERSHIPPINGPOSTALCODE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERSHIPPINGCOUNTRYCODE ="-CUSTOMERSHIPPINGCOUNTRYCODE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("",OK) : OK=fmet MYLOG.AFLUSHLOG

  For I = 1 To dim(CONTACTNUMBER)
    OK=fmet MYLOG.APUTLINE("CONTACT"-num$(I),OK) : OK=fmet MYLOG.AFLUSHLOG
    If CONTACTLASTNAME(I) > ""
      OK=fmet MYLOG.APUTLINE("    CONTACTNUMBER ="-CONTACTNUMBER(I),OK) : OK=fmet MYLOG.AFLUSHLOG
      OK=fmet MYLOG.APUTLINE("    CONTACTFIRSTNAME ="-CONTACTFIRSTNAME(I),OK) : OK=fmet MYLOG.AFLUSHLOG
      OK=fmet MYLOG.APUTLINE("    CONTACTLASTNAME ="-CONTACTLASTNAME(I),OK) : OK=fmet MYLOG.AFLUSHLOG
      OK=fmet MYLOG.APUTLINE("    CONTACTPHONE ="-CONTACTPHONE(I),OK) : OK=fmet MYLOG.AFLUSHLOG
      OK=fmet MYLOG.APUTLINE("    CONTACTFAX ="-CONTACTFAX(I),OK) : OK=fmet MYLOG.AFLUSHLOG
      OK=fmet MYLOG.APUTLINE("    CONTACTEMAIL ="-CONTACTEMAIL(I),OK) : OK=fmet MYLOG.AFLUSHLOG

      OK=fmet MYLOG.APUTLINE("    CONTACTMAILINGADDRESSNUMBER ="-CONTACTMAILINGADDRESSNUMBER(I),OK) : OK=fmet MYLOG.AFLUSHLOG
      OK=fmet MYLOG.APUTLINE("    CONTACTMAILINGADDRESS ="-CONTACTMAILINGADDRESS(I),OK) : OK=fmet MYLOG.AFLUSHLOG
      OK=fmet MYLOG.APUTLINE("    CONTACTMAILINGCITY ="-CONTACTMAILINGCITY(I),OK) : OK=fmet MYLOG.AFLUSHLOG
      OK=fmet MYLOG.APUTLINE("    CONTACTMAILINGPROVINCECODE ="-CONTACTMAILINGPROVINCECODE(I),OK) : OK=fmet MYLOG.AFLUSHLOG
      OK=fmet MYLOG.APUTLINE("    CONTACTMAILINGPOSTALCODE ="-CONTACTMAILINGPOSTALCODE(I),OK) : OK=fmet MYLOG.AFLUSHLOG
      OK=fmet MYLOG.APUTLINE("    CONTACTMAILINGCOUNTRYCODE ="-CONTACTMAILINGCOUNTRYCODE(I),OK) : OK=fmet MYLOG.AFLUSHLOG
      OK=fmet MYLOG.APUTLINE("",OK) : OK=fmet MYLOG.AFLUSHLOG
    Endif
  Next

  OK=fmet MYLOG.APUTLINE("\End data dump\",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

Return

####################################################################################################

