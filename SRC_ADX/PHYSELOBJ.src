################################################################################
$ACTION
  Gosub ACTION From ASELOBJ : # Pour faire tout ce qui va bien en standard

  Case ACTION
    When "OUVRE" :
      Global Integer GLPHYSELOBJ : GLPHYSELOBJ=G_OUI
      Gosub OUVRE
    When "OK" :
      GLDAPCRIT = PARAM(2)
      GLDAPSTAR = val(PARAM(3))
      Gosub DEBUT From SUBFASPY
      If [M:FSP]NBPHYS=0 Then
        FIN=0
        GMESSAGE=mess(112,7775,1)
        GERR=1
      Else
        Call AS_NBPHYS From W1FASPHYS
        Affzo [M:FSP]10
      Endif
    When "FIN" :
      If [M:FSP]NBPHYS=0 Then
        GLDAPCRIT = ""
        GLDAPSTAR = val(PARAM(3))
        Gosub DEBUT From SUBFASPY
        Call AS_NBPHYS From W1FASPHYS
        Affzo [M:FSP]10
      Endif
      If dim(GLPHYSELOBJ)>0 Then Kill GLPHYSELOBJ Endif

    When Default
  Endcase
Return

# Ajout de critﾃｨres supplﾃｩmentaires par dﾃｩfaut, si le fournisseur et/ou
# le numﾃｩro de commande sont renseignﾃｩs dans le bien en cours
$OUVRE
Local Integer NUM_ASL, WINDICE
Local Char FLD_NAME(20) : # FQ98089
Local Char LPARAM(20)   : # FQ98089

  If !clalev([M:ASL]) Then
    Return
  Endif

  If [M:FAS2]BPR <> "" or [M:FAS2]ORDREF<>"" Then

    If [M:FAS2]BPR <> "" Then
      NUM_ASL = 0

      WINDICE = func FIND_FLD("BPR")
      If WINDICE>0 Then
        # BPR est dﾃｩjﾃ dans les filtres
        NUM_ASL=WINDICE
      Else
        # On recherche la premiﾃｨre ligne vide
           If [M:ASL]FLD1="" Then
          NUM_ASL=1
        Elsif [M:ASL]FLD2="" Then
          NUM_ASL=2
        Elsif [M:ASL]FLD3="" Then
          NUM_ASL=3
        Elsif [M:ASL]FLD4="" Then
          NUM_ASL=4
        Elsif [M:ASL]FLD5="" Then
          NUM_ASL=5
        Endif
      Endif

      # Si NUM_ASL est ﾃ zﾃｩro ici, c'est que BPR n'est pas dans la liste et que les 5 critﾃｨres sont utilisﾃｩs
      If NUM_ASL>0 Then
        Assign ("[M:ASL]FLD"+num$(NUM_ASL)) With "BPR"
        FLD_NAME = "AM_FLD"+num$(NUM_ASL)           : # FQ98089
        LPARAM = evalue("[M:ASL]FLD"+num$(NUM_ASL)) : # FQ98089
        Call =FLD_NAME With LPARAM From ASELOBJ     : # FQ98089
        Assign ("[M:ASL]OPE"+num$(NUM_ASL)) With 2
        Assign ("[M:ASL]VAL"+num$(NUM_ASL)) With [M:FAS2]BPR
        If NUM_ASL>1 Then
          Assign ("[M:ASL]ANDOR"+num$(NUM_ASL)) With 1
        Endif
      Endif
    Endif

    If [M:FAS2]ORDREF<> "" Then
      NUM_ASL = 0

      WINDICE = func FIND_FLD("ORDBUY")
      If WINDICE>0 Then
        # ORDBUY est dﾃｩjﾃ dans les filtres
        NUM_ASL=WINDICE
      Else
        # On recherche la premiﾃｨre ligne vide
           If [M:ASL]FLD1="" Then
          NUM_ASL=1
        Elsif [M:ASL]FLD2="" Then
          NUM_ASL=2
        Elsif [M:ASL]FLD3="" Then
          NUM_ASL=3
        Elsif [M:ASL]FLD4="" Then
          NUM_ASL=4
        Elsif [M:ASL]FLD5="" Then
          NUM_ASL=5
        Endif
      Endif

      # Si NUM_ASL est ﾃ zﾃｩro ici, c'est que ORDBUY n'est pas dans la liste et que les 5 critﾃｨres sont utilisﾃｩs
      If NUM_ASL>0 Then
        Assign ("[M:ASL]FLD"+num$(NUM_ASL)) With "ORDBUY"
        FLD_NAME = "AM_FLD"+num$(NUM_ASL)           : # FQ98089
        LPARAM = evalue("[M:ASL]FLD"+num$(NUM_ASL)) : # FQ98089
        Call =FLD_NAME With LPARAM From ASELOBJ     : # FQ98089
        Assign ("[M:ASL]OPE"+num$(NUM_ASL)) With 2
        Assign ("[M:ASL]VAL"+num$(NUM_ASL)) With [M:FAS2]ORDREF
        If NUM_ASL>1 Then
          Assign ("[M:ASL]ANDOR"+num$(NUM_ASL)) With 1
        Endif
      Endif
    Endif
  Endif

  If [M:FAS2]BPR="" Then
    Call REMONTE_CRIT(func FIND_FLD("BPR"))
  Endif

  If [M:FAS2]ORDREF="" Then
    Call REMONTE_CRIT(func FIND_FLD("ORDBUY"))
  Endif
Return

Funprog FIND_FLD(CHAMP)
Value Char    CHAMP
Local Integer I, WINDICE

  WINDICE = 0
  For I=1 To 5
    If evalue("[M:ASL]FLD"+num$(I))=CHAMP Then
      WINDICE = I
      Break
    Endif
  Next
End WINDICE

Subprog REMONTE_CRIT(WINDICE)
Value Integer WINDICE

# DEBUT FQ98089
  If WINDICE>0 Then
    Local Integer I

    I = WINDICE
    While I < 5
      Assign ("[M:ASL]FLD"+num$(I))   With evalue("[M:ASL]FLD"+num$(I+1))
      Assign ("[M:ASL]DES"+num$(I))   With evalue("[M:ASL]DES"+num$(I+1))
      Assign ("[M:ASL]OPE"+num$(I))   With evalue("[M:ASL]OPE"+num$(I+1))
      Assign ("[M:ASL]VAL"+num$(I))   With evalue("[M:ASL]VAL"+num$(I+1))
      If I > 1
        Assign ("[M:ASL]ANDOR"+num$(I)) With evalue("[M:ASL]ANDOR"+num$(I+1))
      Endif

      I += 1
    Wend
    Assign ("[M:ASL]FLD"+num$(I))   With ""
    Assign ("[M:ASL]DES"+num$(I))   With ""
    Assign ("[M:ASL]OPE"+num$(I))   With 0
    Assign ("[M:ASL]VAL"+num$(I))   With ""
    Assign ("[M:ASL]ANDOR"+num$(I)) With 0
  Endif

#  If WINDICE>0 Then
#    If evalue("[M:ASL]FLD"+num$(WINDICE+1))<>"" Then
#      For I=WINDICE+1 To 5
#        Assign ("[M:ASL]FLD"+num$(I-1))   With evalue("[M:ASL]FLD"+num$(I))
#        Assign ("[M:ASL]OPE"+num$(I-1))   With evalue("[M:ASL]OPE"+num$(I))
#        Assign ("[M:ASL]VAL"+num$(I-1))   With evalue("[M:ASL]VAL"+num$(I))
#        Assign ("[M:ASL]ANDOR"+num$(I-1)) With evalue("[M:ASL]ANDOR"+num$(I))
#      Next
#      Assign ("[M:ASL]FLD5") With ""
#      Assign ("[M:ASL]VAL5") With ""
#    Else
#      Assign ("[M:ASL]FLD"+num$(WINDICE)) With ""
#      Assign ("[M:ASL]VAL"+num$(WINDICE)) With ""
#    Endif
#  Endif
# FIN FQ98089
End

