Subprog AM_SDHNUMDEB(VALEUR)
Variable Char    VALEUR()
 If VALEUR <> "" : [M]SDHNUMFIN= VALEUR : Endif
End

########################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
 Affzo ZCPY
 Raz [M]STOFCY, ZSTOFCY
 Affzo STOFCY,ZSTOFCY
 If VALEUR<>"" : GSOCIETE=VALEUR : Endif
End

########################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
 If VALEUR<>""
   Affzo CPY, ZCPY
 Endif
End

#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
 If APPLI="X3" End Endif
 If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
 Read [ADS]DOSSIER=APPLI
 If !fstat & [F:ADS]MODULE(4)<>2 End Endif
 Call VALGTC(APPLI,"CSG") From SUBGTC
End

######################################################################################
Subprog AM_DRNDEB(VALEUR)
Variable Integer VALEUR
 If VALEUR <> 0 : [M]DRNDEB= VALEUR : Endif
End

######################################################################################
## TRILIGNE : Chargement en tableau des No livraison/Commande trié sur No chrono    ##
######################################################################################
$TRILIGNE

 Local Integer J
 Local Integer K

 Raz [M:CSG2]WSDHNUM
 K = 0

 For J=0 To [M:CSG2]NBLIG-1
  If [M:CSG2]FLGKO(J) = 2 Then
      [M:CSG2]WSDHNUM (K) = [M:CSG2]SDHNUM(J)
      [M:CSG2]WCSGNUM (K) = [M:CSG2]CSGNUM(J)
      K +=1
  Endif
 Next J

 [M:CSG2]NBLIGTAB = K

 Sorta [M:CSG2]NBLIGTAB [M:CSG2]NBLIGTAB Order By [M:CSG2]WCSGNUM(indice), [M:CSG2]DLVDAT(indice) , [M:CSG2]ETD(indice)

Return

##########################################################################################################
## Sous-Prog : alime SCHRONO à partir de ligne tableau traitée (Appelé par TRTITI (Gestion itineraire) ###
##########################################################################################################
Subprog GET_CHRONO_ITI(ILIGNE, SCHRONO)
Variable Integer ILIGNE
Variable Char SCHRONO

Local Integer NI
Local Integer NBEGIN
Local Integer NFOUND

  If [M:CSG2]NBLIG = 0 Then
    ILIGNE = -1
    Raz SCHRONO
  Else
    If ILIGNE = -1 : Gosub TRILIGNE : Endif : #--- Tri des lignes suivant chrono
    NBEGIN = ILIGNE + 1
    If NBEGIN > [M:CSG2]NBLIGTAB-1 Then
      ILIGNE = -1
      Raz SCHRONO
    Else
      NFOUND = 0
      For NI = NBEGIN To [M:CSG2]NBLIGTAB-1
          ILIGNE = NI
          SCHRONO = [M:CSG2]WSDHNUM(ILIGNE)
          NFOUND = 1
          Break
      Next NI
      If NFOUND = 0 Then
        ILIGNE = -1
        Raz SCHRONO
      Endif
    Endif
  Endif
End

######################################################################################
## AM_FLGKO (Flag d'exlusion de la ligne)
######################################################################################
Subprog AM_FLGKO(VALEUR)
Variable Integer VALEUR
 If VALEUR = 1   : # Diminution des totaux --#

  #-- Poids --#
  WLIV_UNITE_DEST    = [M:CSG2]TOTWEU
  WLIV_UNITE_ORI     = [M:CSG2]WEU    (nolign-1)

  WLIV_VALEUR        = [M:CSG2]NETWEI (nolign-1)
  Gosub TRANSF_UNITE
  [M:CSG2]TOTNETWEI -= WLIV_VALEUR

  WLIV_VALEUR        = [M:CSG2]GROWEI (nolign-1)
  Gosub TRANSF_UNITE
  [M:CSG2]TOTGROWEI  -= WLIV_VALEUR

  #-- Volume --#
  WLIV_UNITE_DEST    = [M:CSG2]TOTVOU
  WLIV_UNITE_ORI     = [M:CSG2]VOU    (nolign-1)
  WLIV_VALEUR        = [M:CSG2]VOL    (nolign-1)
  Gosub TRANSF_UNITE
  [M:CSG2]TOTVOL    -= WLIV_VALEUR

  [M:CSG2]TOTPACNBR -= [M:CSG2]PACNBR (nolign-1)
 Else            : # Augmentation des totaux --#
  #-- Poids --#
  WLIV_UNITE_DEST    = [M:CSG2]TOTWEU
  WLIV_UNITE_ORI     = [M:CSG2]WEU    (nolign-1)

  WLIV_VALEUR        = [M:CSG2]NETWEI (nolign-1)
  Gosub TRANSF_UNITE
  [M:CSG2]TOTNETWEI += WLIV_VALEUR

  WLIV_UNITE_ORI     = [M:CSG2]WEU    (nolign-1)
  WLIV_VALEUR        = [M:CSG2]GROWEI (nolign-1)
  Gosub TRANSF_UNITE
  [M:CSG2]TOTGROWEI  += WLIV_VALEUR

  #-- Volume --#
  WLIV_UNITE_DEST    = [M:CSG2]TOTVOU
  WLIV_UNITE_ORI     = [M:CSG2]VOU    (nolign-1)
  WLIV_VALEUR        = [M:CSG2]VOL    (nolign-1)
  Gosub TRANSF_UNITE
  [M:CSG2]TOTVOL    += WLIV_VALEUR

  [M:CSG2]TOTPACNBR += [M:CSG2]PACNBR (nolign-1)
 Endif

Affzo  [M:CSG2]TOTNETWEI
Affzo  [M:CSG2]TOTGROWEI
Affzo  [M:CSG2]TOTVOL
Affzo  [M:CSG2]TOTPACNBR

End

######################################################################################
Subprog AM_FLGTYP(VALEUR)
Variable Integer VALEUR


If maskcou = 'CRITCSG'
 Raz    [M:CCSG]SDHNUMDEB
 Raz    [M:CCSG]SDHNUMFIN
 Raz    [M:CCSG]MDL
 Affzo  [M:CCSG]SDHNUMDEB
 Affzo  [M:CCSG]SDHNUMFIN
 Affzo  [M:CCSG]MDL

 [M:CCSG]FLGTYP=VALEUR

 If [M:CCSG]FLGTYP= 2      : # Livraison
  Chgtzn [M:CCSG]SDHNUMDEB With mess(3,443,1) : # Livraison
  Chgtzn [M:CCSG]SDHNUMFIN With mess(257,191,1) : # 105537-v7.2 UI Text Review
  Chgfmt [M:CCSG]DLVPIO    With "-N:4"
 Else                       : # Commande
  Chgtzn [M:CCSG]SDHNUMDEB With mess(2,443,1) : # Commande
  Chgtzn [M:CCSG]SDHNUMFIN With mess(258,191,1) : # 105537-v7.2 UI Text Review
  Chgfmt [M:CCSG]DLVPIO    With "N:4"
 Endif
 Affzo [M:CCSG]
Else
 [M:CSG1]FLGTYP=VALEUR
 Raz    [M:CSG1]SDHNUMDEB
 Raz    [M:CSG1]SDHNUMFIN
 Raz    [M:CSG1]MDL
 Affzo  [M:CSG1]SDHNUMDEB
 Affzo  [M:CSG1]SDHNUMFIN
 Affzo  [M:CSG1]MDL

 Gosub OUVRE_FILE

 Gosub MAJAFFICHAGE

 Local Integer WNB1
 WNB1 = [M:CSG2]NBLIG
 If WNB1 > 0
  Dela 0,WNB1 [M:CSG2]NBLIG
  [M:CSG2]NBLIG = 0
  [M:CSG2]TOTPACNBR = 0
  [M:CSG2]TOTNETWEI = 0
  [M:CSG2]TOTGROWEI = 0
  [M:CSG2]TOTVOL    = 0

  Affzo  [M:CSG2]
 Endif
Endif

If [M:CSG1]FLGTYP = 2
 [M:CSG1]WOBJET   = 'SDH'
 [M:CSG1]WTYPFOR = 52
Else
 [M:CSG1]WOBJET   = 'SOH'
 [M:CSG1]WTYPFOR = 52
Endif

End

######################################################################################
#-- Après_zone FLGTYP
Subprog AP_FLGTYP(VALEUR)
Variable Integer VALEUR
 [M:CSG1]FLGTYP=VALEUR
End

######################################################################################
Subprog IB_SDHNUMDEB
 Gosub SELFCY
End

######################################################################################
Subprog IB_SDHNUMFIN
 Gosub SELFCY
End


########################################################################
# ACT_INCSSL  bouton TOUT INCLURE
########################################################################
Subprog ACT_INCSSL
Local Integer  NOL
Local Shortint WAFF
Raz WAFF
Raz NOL
#message opération en cours ...
Call TEMPON("O") From GESECRAN

For NOL = 0 To [M:CSG2]NBLIG-1
    If [M:CSG2]FLGKO(NOL) <> 2
       #-- Poids --#
       WLIV_UNITE_DEST    = [M:CSG2]TOTWEU
       WLIV_UNITE_ORI     = [M:CSG2]WEU    (NOL)
       WLIV_VALEUR        = [M:CSG2]NETWEI (NOL)
       Gosub TRANSF_UNITE
       [M:CSG2]TOTNETWEI += WLIV_VALEUR
       WLIV_UNITE_ORI     = [M:CSG2]WEU    (NOL)
       WLIV_VALEUR        = [M:CSG2]GROWEI (NOL)
       Gosub TRANSF_UNITE
       [M:CSG2]TOTGROWEI  += WLIV_VALEUR
       #-- Volume --#
       WLIV_UNITE_DEST    = [M:CSG2]TOTVOU
       WLIV_UNITE_ORI     = [M:CSG2]VOU    (NOL)
       WLIV_VALEUR        = [M:CSG2]VOL    (NOL)
       Gosub TRANSF_UNITE
       [M:CSG2]TOTVOL    += WLIV_VALEUR
       [M:CSG2]TOTPACNBR += [M:CSG2]PACNBR (NOL)
       WAFF = 1
       [M:CSG2]FLGKO             (NOL) = 2
       GREP = "M"
    Endif
Next
#suppression message opération en cours ...
Call TEMPOFF   From GESECRAN

If WAFF = 1
   Affzo [M:CSG2]
Endif
End


##################################################
Subprog ACT_EXCSSL
Local Integer  NOL
Local Shortint WAFF
Raz WAFF
Raz NOL
#message opération en cours ...
Call TEMPON("O") From GESECRAN

For NOL = 0 To [M:CSG2]NBLIG-1
    If [M:CSG2]FLGKO(NOL) = 2
       #-- Poids --#
       WLIV_UNITE_DEST    = [M:CSG2]TOTWEU
       WLIV_UNITE_ORI     = [M:CSG2]WEU    (NOL)
       WLIV_VALEUR        = [M:CSG2]NETWEI (NOL)
       Gosub TRANSF_UNITE
       [M:CSG2]TOTNETWEI -= WLIV_VALEUR
       WLIV_VALEUR        = [M:CSG2]GROWEI (NOL)
       Gosub TRANSF_UNITE
       [M:CSG2]TOTGROWEI  -= WLIV_VALEUR
       #-- Volume --#
       WLIV_UNITE_DEST    = [M:CSG2]TOTVOU
       WLIV_UNITE_ORI     = [M:CSG2]VOU    (NOL)
       WLIV_VALEUR        = [M:CSG2]VOL    (NOL)
       Gosub TRANSF_UNITE
       [M:CSG2]TOTVOL    -= WLIV_VALEUR
       [M:CSG2]TOTPACNBR -= [M:CSG2]PACNBR (NOL)
       WAFF = 1
       [M:CSG2]FLGKO               (NOL) = 1
       GREP = "M"
    Endif
Next
#suppression message opération en cours ...
Call TEMPOFF   From GESECRAN

If WAFF = 1
   Affzo [M:CSG2]
Endif

End
