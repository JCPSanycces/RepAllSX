#<AdxTL>@(#)10.0.0.0 $Revision$
########################################################################
# CNSCSGSTD : Visualisation des tournées (ecran de Consultation)        #
#             Avec appel GOOGLE MAP (visu lieu et/ou trajet)            #
# Ecran Entete                  : CONSCSG1                              #
# Ecran Tableau                 : CONSCSG2                              #
# Ecran Criteres supplementaire : CRITCSG                               #
#########################################################################

$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AB3_NBLIG"  : [M:CSG2]WACT1 = "1"  : # Click droit sur le tableau : Affichage photo du lieu
  When "AB4_NBLIG"  : [M:CSG2]WACT1 = "2"  : # Click droit sur le tableau : Affichage trajet direct
When Default
Endcase
Return

############################################################
$AUTORIS
Return

############################################################
$SETBOUT
 If [M:CSG2]NBLIG>0 CHMEN += "BCDE" Endif
Return

#############################################################
$EXEBOUT
 Case BOUT
    When "B", "C", "D", "E" : #        OK=1 : CHANGE=1 : # Pour déclencher un réaffichage de la consultation
 Endcase
Return

############################################################
## $OUVRE   ################################################
############################################################
$OUVRE
Local Char    WFIL(255),WFIL1(250),WFIL2(250)
Local Char    DEBNUM, FINNUM
Local Date    DEBDAT, FINDAT
Local Char    WACT1
Local Decimal WPACNBRTHE
Local Char    WFILFOR(250)
Global   Char    GCOLDES


If !clalev([M:CSG1])  : Local Mask CONSCSG1  [CSG1]  : Endif
If !clalev([M:CSG2])  : Local Mask CONSCSG2  [CSG2]  : Endif
If !clalev([M:CCSG])  : Local Mask CRITCSG   [CCSG]  : Endif
If clalev([F:AST])=0  : Local File APLSTD    [AST]   : Endif : # Messages
If clalev([F:BPA])=0  : Local File BPADDRESS [BPA]   : Endif : # Adresses

NAVIG="CONSCSG"
Gosub DEFCRIT

#-- Alimentation de la tournée fin avec la + grande valeur de tournée --#
[M:CSG1]DRNFIN = 1
Filter [AST] Where LANCHP =409 & LAN=GLANGUE Order By [F:AST]LANNUM Desc
For [AST]
 [M:CSG1]DRNFIN =[F:AST]LANNUM
 Affzo [M:CSG1]DRNFIN
 Break
Next
Filter [AST]

If dim([M:SDH0]SDHNUM)>0                   : #-- On vient des livraisons
  [M:CSG1]FLGTYP = 2
  [M:CSG1]SHIDATDEB = [M:SDH1]SHIDAT   : # Date Expé
  [M:CSG1]SHIDATFIN = [M:SDH1]SHIDAT   : # Date Expé
  [M:CSG1]MDL       = [M:SDH2]MDL      : # Mode de transport
  [M:CSG1]DRNDEB    = [M:SDH2]DRN      : # Tournée
  [M:CSG1]DRNFIN    = [M:SDH2]DRN      : # Tournée
  [M:CSG1]BPTNUMDEB = [M:SDH2]BPTNUM   : # Transporteur
  [M:CSG1]BPTNUMFIN = [M:SDH2]BPTNUM   : # Transporteur
Elsif dim([M:SOH0]SOHNUM)>0                : #-- On vient des commandes
  [M:CSG1]FLGTYP = 1
  [M:CSG1]SHIDATDEB = [M:SOH2]SHIDAT   : # Date Expé
  [M:CSG1]SHIDATFIN = [M:SOH2]SHIDAT   : # Date Expé
  [M:CSG1]MDL       = [M:SOH2]MDL      : # Mode de transport
  [M:CSG1]DRNDEB    = [M:SOH2]DRN      : # Tournée
  [M:CSG1]DRNFIN    = [M:SOH2]DRN      : # Tournée
  [M:CSG1]BPTNUMDEB = [M:SOH2]BPTNUM   : # Transporteur
  [M:CSG1]BPTNUMFIN = [M:SOH2]BPTNUM   : # Transporteur

Else                                       : #-- On vient du menu des consultations
 If GBIDC1="1"                             : #                des livraisons
  [M:CSG1]FLGTYP = 2
 Else                                      : #                des commandes
   [M:CSG1]FLGTYP = 1
 Endif
Endif
Affzo [M:CSG1]FLGTYP

Gosub MAJAFFICHAGE


Return

############################################################
## $OUVRE_FILE #############################################
############################################################
$OUVRE_FILE
 #-- Ouverture des fichiers suivant demande sur les commandes ou les livraisons --#
 If !clalev([F:SDH]) : Local File SDELIVERY [SDH] : Endif
 If !clalev([F:SOH]) : Local File SORDER    [SOH] : Endif

 If clalev([F:SXH]) : Close File [F:SXH] : Endif
 If [M:CSG1]FLGTYP = 2
  If !clalev([F:SXH]) : Local File SDELIVERY [SXH] : Endif
 Else
  If !clalev([F:SXH]) : Local File SORDER    [SXH] : Endif
  If !clalev([F:SOQ]) : Local File SORDERQ   [SOQ] : Endif
 Endif
If !clalev([F:TFO])   : Local File TABFOR    [TFO] : Endif

 If [M:CSG1]FLGTYP = 2
  [M:CSG1]WOBJET   = 'SDH'
  [M:CSG1]WTYPFOR = 52
 Else
  [M:CSG1]WOBJET   = 'SOH'
  [M:CSG1]WTYPFOR = 52
 Endif
Return

############################################################
## $MAJAFFICHAGE ###########################################
############################################################
$MAJAFFICHAGE

 If [M:CSG1]FLGTYP= 2      : #----- Livraison
  Chgtzn [M:CSG1]SDHNUMDEB With mess(3,443,1) : # Livraison
  Chgtzn [M:CSG1]SDHNUMFIN With mess(257,191,1) : # Livraison fin    # hcb 97619
  Chgfmt [M:CSG1]DLVPIO    With "-N:4"

  #Titcol [M:CSG2]SDHNUM   mess(3,443,1) : # Livraison
  GCOLDES =  mess(3,443,1)
  Chgfmt [M:CSG2]CSGNUM    With "N:4"
  Chgfmt [M:CSG2]NETWEI    With "N:11.2"
  Chgfmt [M:CSG2]ETD       With "K:5X"
  Chgfmt [M:CSG2]ETA       With "K:5X"
  Chgfmt [M:CSG2]LICPLATE  With "K:10X"
  Chgfmt [M:CSG2]TOTNETWEI With "N:11.2"
  Chgfmt [M:CSG2]DLVPIO    With "-N:4"
  Diszo  [M:CSG2]TOTNETWEI
  Diszo  [M:CSG2]ETD
  Diszo  [M:CSG2]ETA
  Diszo  [M:CSG2]LICPLATE
 Else                : #------ Commande
  Chgtzn [M:CSG1]SDHNUMDEB With mess(2,443,1) : # Commande
  Chgtzn [M:CSG1]SDHNUMFIN With mess(258,191,1) : # Commande fin   # hcb 97619

  Chgfmt [M:CSG1]DLVPIO    With "N:4"

  #Titcol [M:CSG2]SDHNUM    mess(2,443,1) : # Commande
  GCOLDES =  mess(2,443,1)

  Chgfmt [M:CSG2]DLVPIO    With "N:4"
  Chgfmt [M:CSG2]CSGNUM    With "-N:4"
  Chgfmt [M:CSG2]NETWEI    With "-N:11.2"
  Chgfmt [M:CSG2]ETD       With "-K:5X"
  Chgfmt [M:CSG2]ETA       With "-K:5X"
  Chgfmt [M:CSG2]LICPLATE  With "-K:10X"
  Chgfmt [M:CSG2]TOTNETWEI With "-N:11.2"
 Endif

 Affzo [M:CSG2]
 Diszo [M:CSG2]NETWEI

Return

############################################################
## $DEFCRIT ################################################
############################################################
# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT

If [M:CSG1]STOFCY<>"" & GUSRFCY(1)<>"\" & !find([M:CSG1]STOFCY,GUSRFCY(1..GNBAUZ))
 [M:CSG1]STOFCY=""
Endif

For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [F:FCY]FCY0 = PARAM(I)
                                     If fstat
                                       Raz [F:FCY], PARAM(I)
                                     Endif
        Endif
        If GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ))
           [M:CSG1]STOFCY = PARAM(I)
           If [M:CSG1]STOFCY <> ""
             Call GETDEV([M:CSG1]STOFCY) From DEVSUB
             [M:CSG1]CPY  = GSOCIETE
           Endif
        Endif
      Endif
  Endcase
Next I

If !find([M:CCSG]TRI,1,2)     : [M:CCSG]TRI     = 1 : Endif

# -- copie de l'écran critères (CCSG) vers le masque 1 (CSG1)
Gosub CRITENT From =PROGCNS

Return

############################################################
## $CTRL_BORNE : Controle des bornes   #####################
############################################################
$CTRL_BORNE

Local Integer WB_OK
Local Char    WTEXTE
WB_OK=2

#--------------------------- Ctrl sur No de livraison ou No de commande --#
If [M:CSG1]SDHNUMDEB <> "" &  [M:CSG1]SDHNUMFIN <> ""                  & [M:CSG1]SDHNUMDEB > [M:CSG1]SDHNUMFIN
 WB_OK = 1
 If [M:CSG1]FLGTYP= 2      : #----- Livraison
  WTEXTE  = mess(3,443,1) : # Livraison
 Else                : #------ Commande
  WTEXTE  = mess(2,443,1) : # Commande
 Endif
 Return
Endif

#--------------------------- Ctrl sur tournée --#
If [M:CSG1]DRNDEB <> 0 & [M:CSG1]DRNFIN <> 0                           & [M:CSG1]DRNDEB    > [M:CSG1]DRNFIN
 WB_OK = 1
 WTEXTE  = mess(243,191,1) : # Tournée
 Return
Endif

#--------------------------- Ctrl sur date livraison --#
If [M:CSG1]DLVDATDEB <> [00/00/00] & [M:CSG1]DLVDATFIN <> [00/00/00]   & [M:CSG1]DLVDATDEB > [M:CSG1]DLVDATFIN
 WB_OK = 1
 WTEXTE  = mess(2,407,1) : # Date livraison
 Return
Endif

#--------------------------- Ctrl sur date expé  --#
If [M:CSG1]SHIDATDEB <> [00/00/00] &  [M:CSG1]SHIDATFIN <> [00/00/00]  & [M:CSG1]SHIDATDEB > [M:CSG1]SHIDATFIN
 WB_OK = 1
 WTEXTE  = mess(184,197,1) : # Date expé
 Return
Endif

#--------------------------- Ctrl sur transporteur  --#
If [M:CSG1]BPTNUMDEB <> "" & [M:CSG1]BPTNUMFIN <> ""                   & [M:CSG1]BPTNUMDEB > [M:CSG1]BPTNUMFIN
 WB_OK = 1
 WTEXTE  = mess(244,191,1) : # Transporteur
 Return
Endif

Return

############################################################
## $LECTURE : Chargement du tableau    #####################
############################################################
$LECTURE
Gosub CTRL_BORNE
If WB_OK = 1
    Call MESSAGE (WTEXTE - ':' - mess(252,123,1)) From GESECRAN : # bornes fin < début
    Return
Endif

Local   Decimal  WMNTORG(0..5), WMNTDES(0..5), WLIV_VALEUR
Local   Integer  SPSTAT
Local   Char     WLIV_UNITE_ORI, WLIV_UNITE_DEST, WCHAMP1, WCHAMP2
Gosub OUVRE_FILE
Gosub MAJAFFICHAGE

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCSG]TRI
      When 1 : # Tri par numéro
        If [M:CSG1]FLGTYP = 2
           Filter [SXH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILFOR) Order By Key SDH0
        Else
           Filter [SXH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILFOR) Order By Key SOH0
        Endif
      When 2 : # Tri par date de livraison
        If [M:CSG1]FLGTYP = 2
           Filter [SXH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILFOR) Order By Key CLE =[F:SXH]DLVDAT;[F:SXH]ETD
        Else
           Filter [SXH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILFOR) Order By Key CLE =[F:SXH]DEMDLVDAT
        Endif
     Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCSG]TRI
      When 1 : # tri par numéro
        If [M:CSG1]FLGTYP = 2
           Filter [SXH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILFOR) Order By Key SDH0 Desc
        Else
           Filter [SXH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILFOR) Order By Key SOH0 Desc
        Endif
      When 2 : # tri par date
        If [M:CSG1]FLGTYP = 2
           Filter [SXH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILFOR) Order By Key SDH2 Desc
        Else
           Filter [SXH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILFOR) Order By Key SOH2 Desc
        Endif
    Endcase
Endif

#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CSG2] : Endif

#--------------------------------------------------------------------#
#------------------------------ lecture -----------------------------#
#--------------------------------------------------------------------#
$BOUCLE
For [SXH] With Nohint

  # Filtre sur la société
  If [M:CSG1]CPY <> ""
      If [F:FCY]FCY <> [F:SXH]STOFCY Read [F:FCY]FCY0 = [F:SXH]STOFCY
                                     If fstat  Raz [F:FCY] : Endif
                                     Endif
      If [F:FCY]LEGCPY <> [M:CSG1]CPY : Goto SUIV : Endif
  Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CSG2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
      Gosub ALIM1
     Endif
     Gosub ALIM2
 Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
      Gosub ALIM2
     Endif
     Gosub ALIM1
  Endif

  If [M:CSG1]FLGTYP = 2
    WCHAMP1 = 'SDHNUM' :     WCHAMP2 = 'DLVDAT'
  Else
    WCHAMP1 = 'SOHNUM' :     WCHAMP2 = 'DEMDLVDAT'
  Endif

  Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCSG]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SXH]" + WCHAMP1   + ">=DEBNUM"
       When 2 : # tri par date
           WFIL += "&[F:SXH]" + WCHAMP2   + ">=DEBDAT"
     Endcase
   When 2 : # suite
     Case [M:CCSG]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SXH]" + WCHAMP1    + ">FINNUM"
       When 2 : # tri par date
           WFIL += "&[F:SXH]" + WCHAMP2    + ">=FINDAT & [F:SXH]" +  WCHAMP1 + ">FINNUM"
     Endcase
   When -2 : # retour
     Case [M:CCSG]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SXH]" + WCHAMP1    + "<DEBNUM"
       When 2 : # tri par date
           WFIL += "&[F:SXH]" + WCHAMP2    + "<DEBDAT"

     Endcase
  Endcase

  nolign   = NOL+1
  [M:CSG2] = [F:SXH]

 # [M:CSG2]TOTWEU = 'KG'   # hcb 97305
 # [M:CSG2]TOTVOU = 'M3'   # hcb 97305

  [M:CSG2]CSGNUM     (nolign-1)     = nolign

  If [F:SXH]BPDPOSCOD = ''
   Read [BPA]BPA0=1;[F:SXH]BPCORD;[F:SXH]BPAADD
   If !fstat
   [M:CSG2]BPDADDLIG0 (nolign-1)     = [F:BPA]BPAADDLIG(0)
   [M:CSG2]BPDPOSCOD  (nolign-1)     = [F:BPA]POSCOD
   [M:CSG2]BPDCTY     (nolign-1)     = [F:BPA]CTY
   [M:CSG2]BPDCRY     (nolign-1)     = [F:BPA]CRY
   Endif
  Else
   [M:CSG2]BPDADDLIG0 (nolign-1)     = [F:SXH]BPDADDLIG(0)
   [M:CSG2]BPDPOSCOD  (nolign-1)     = [F:SXH]BPDPOSCOD
   [M:CSG2]BPDCTY     (nolign-1)     = [F:SXH]BPDCTY
   [M:CSG2]BPDCRY     (nolign-1)     = [F:SXH]BPDCRY
  Endif

  [M:CSG2]BPCORD     (nolign-1)     = [F:SXH]BPCORD
  [M:CSG2]SHIDAT     (nolign-1)     = [F:SXH]SHIDAT
  [M:CSG2]PJT        (nolign-1)     = [F:SXH]PJT
  [M:CSG2]DRN        (nolign-1)     = [F:SXH]DRN
  [M:CSG2]BPTNUM     (nolign-1)     = [F:SXH]BPTNUM
  [M:CSG2]FLGKO      (nolign-1)     = 2


  If [M:CSG1]FLGTYP = 2
   [M:CSG2]SDHNUM     (nolign-1)     = [F:SXH]SDHNUM
   [M:CSG2]PACNBR     (nolign-1)     = [F:SXH]PACNBR
   [M:CSG2]WEU        (nolign-1)     = [F:SXH]WEU
   [M:CSG2]VOU        (nolign-1)     = [F:SXH]VOU
#                                               # hcb 97305  deb
   If [M:CSG2]TOTWEU = "" & [F:SXH]WEU <> ""
      [M:CSG2]TOTWEU =      [F:SXH]WEU
   Endif
   If [M:CSG2]TOTVOU = "" & [F:SXH]VOU <> ""
      [M:CSG2]TOTVOU =      [F:SXH]VOU
   Endif
#                                               # hcb 97305  fin

   [M:CSG2]NETWEI     (nolign-1)     = [F:SXH]NETWEI
   [M:CSG2]GROWEI     (nolign-1)     = [F:SXH]GROWEI
   [M:CSG2]VOL        (nolign-1)     = [F:SXH]VOL
   [M:CSG2]ETD        (nolign-1)     = [F:SXH]ETD
   If [F:SXH]ETD<>''
    [M:CSG2]ETD(nolign-1)= left$([F:SXH]ETD, 2) + ":" + mid$([F:SXH]ETD, 3, 2)
   Endif
   If [F:SXH]ETA<>''
    [M:CSG2]ETA(nolign-1)= left$([F:SXH]ETA, 2) + ":" + mid$([F:SXH]ETA, 3, 2)
   Endif
   [M:CSG2]LICPLATE   (nolign-1)     = [F:SXH]LICPLATE

   #-- Cumul des totaux --#

   [M:CSG2]TOTPACNBR       += [F:SXH]PACNBR

   #-- Poids --#
   WLIV_UNITE_DEST    = [M:CSG2]TOTWEU
   WLIV_UNITE_ORI     = [F:SXH]WEU

   WLIV_VALEUR        = [F:SXH]NETWEI
   Gosub TRANSF_UNITE
   [M:CSG2]TOTNETWEI += WLIV_VALEUR

   WLIV_VALEUR        = [F:SXH]GROWEI
   Gosub TRANSF_UNITE
   [M:CSG2]TOTGROWEI += WLIV_VALEUR

   #-- Volume   --#
   WLIV_UNITE_DEST    = [M:CSG2]TOTVOU
   WLIV_UNITE_ORI     = [F:SXH]VOU
   WLIV_VALEUR        = [F:SXH]VOL
   Gosub TRANSF_UNITE
   [M:CSG2]TOTVOL    += WLIV_VALEUR

  Else
   [M:CSG2]SDHNUM     (nolign-1)     = [F:SXH]SOHNUM
   [M:CSG2]WEU        (nolign-1)     = [F:SXH]DSPWEU
   [M:CSG2]VOU        (nolign-1)     = [F:SXH]DSPVOU
   [M:CSG2]GROWEI     (nolign-1)     = [F:SXH]DSPTOTWEI
   [M:CSG2]VOL        (nolign-1)     = [F:SXH]DSPTOTVOL
   [M:CSG2]DLVDAT     (nolign-1)     = [F:SXH]DEMDLVDAT

#                                               # hcb 97305  deb
   If [M:CSG2]TOTWEU = "" & [F:SXH]DSPWEU <> ""
      [M:CSG2]TOTWEU =      [F:SXH]DSPWEU
   Endif
   If [M:CSG2]TOTVOU = "" & [F:SXH]DSPVOU <> ""
      [M:CSG2]TOTVOU =      [F:SXH]DSPVOU
   Endif
#                                               # hcb 97305  fin



   #-- Recherche poids théorique --#
   Gosub RECH_POIDS_THEORIQUE

   #-- Cumul des totaux --#

   #-- Poids --#
   WLIV_UNITE_DEST    = [M:CSG2]TOTWEU
   WLIV_UNITE_ORI     = [F:SXH]DSPWEU

   WLIV_VALEUR        = [F:SXH]DSPTOTWEI
   Gosub TRANSF_UNITE
   [M:CSG2]TOTGROWEI += WLIV_VALEUR

   #-- Volume   --#
   WLIV_UNITE_DEST    = [M:CSG2]TOTVOU
   WLIV_UNITE_ORI     = [F:SXH]DSPVOU
   WLIV_VALEUR        = [F:SXH]DSPTOTVOL
   Gosub TRANSF_UNITE
   [M:CSG2]TOTVOL    += WLIV_VALEUR

  Endif

  Raz WMNTORG

  $SUIV
Next
Filter [SXH]

Return


############################################################
# $RECH_POIDS_THEORIQUE                                    #
############################################################
$RECH_POIDS_THEORIQUE
Local Decimal WPACNBRTHE                               # hcb 97628 deb
Local Integer WPACNBRTHEI
WPACNBRTHE  = 0
WPACNBRTHEI = 0
Filter [SOQ] Where [F:SOQ]SOHNUM = [F:SXH]SOHNUM
For [SOQ]
 If [SOQ]PCK     <> ""  & [SOQ]PCKCAP <> 0
      WPACNBRTHE += [SOQ]QTYSTU/[SOQ]PCKCAP :
 Endif
Next

Filter [SOQ]

WPACNBRTHEI  = WPACNBRTHE
If  WPACNBRTHEI <> WPACNBRTHE
    WPACNBRTHEI +=1
Endif
[M:CSG2]PACNBR     (nolign-1)     = WPACNBRTHEI
[M:CSG2]TOTPACNBR   += [M:CSG2]PACNBR     (nolign-1)  # hcb 97628 fin
Return

############################################################
# $ALIM1                                                   #
############################################################
$ALIM1
 If [M:CSG1]FLGTYP = 2
         DEBNUM = [F:SXH]SDHNUM
         DEBDAT = [F:SXH]DLVDAT
 Else
         DEBNUM = [F:SXH]SOHNUM
         DEBDAT = [F:SXH]DEMDLVDAT
 Endif
Return

############################################################
# $ALIM2                                                   #
############################################################
$ALIM2
 If [M:CSG1]FLGTYP = 2
       FINNUM = [F:SXH]SDHNUM
       FINDAT = [F:SXH]DLVDAT
 Else
       FINNUM = [F:SXH]SOHNUM
       FINDAT = [F:SXH]DEMDLVDAT
 Endif
Return


############################################################
# $TRANSF_UNITE : Transformation unité                     #
############################################################
$TRANSF_UNITE
  If WLIV_UNITE_ORI<>"" & WLIV_UNITE_DEST <>"" & WLIV_UNITE_ORI<>WLIV_UNITE_DEST
        Call SCONV_TCO(WLIV_UNITE_ORI,WLIV_UNITE_DEST ,WLIV_VALEUR) From TRTVENQTE
  Endif
Return

############################################################
# $LOAD_FILTER : Préparation du filtre                     #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"

##------------------------------------##
##-- Filtre sur ecran entête ---------##
##------------------------------------##
If [M:CSG1]STOFCY <> ""
    WFIL += "&[F:SXH]STOFCY=[M:CSG1]STOFCY"
Endif
#    Autorisation site
If GUSRFCY(1)<>"\"& [M:CSG1]STOFCY <> "" & GNBAUZ<>GNBSITE
    WFIL += "& find([F:SXH]STOFCY,GUSRFCY(1..GNBAUZ))"
Endif

#--------------------------- Filtre sur Mode de livraison --#
If [M:CSG1]MDL <> ""
   WFIL += "&[F:SXH]MDL=[M:CSG1]MDL"
Endif

#--------------------------- Filtre sur No de livraison ou No de commande --#
If [M:CSG1]SDHNUMDEB <> ""
 If [M:CSG1]FLGTYP = 2
   WFIL += "&[F:SXH]SDHNUM>=[M:CSG1]SDHNUMDEB"
 Else
   WFIL += "&[F:SXH]SOHNUM>=[M:CSG1]SDHNUMDEB"
 Endif
Endif

If [M:CSG1]SDHNUMFIN <> ""
 If [M:CSG1]FLGTYP = 2
   WFIL += "&[F:SXH]SDHNUM <=[M:CSG1]SDHNUMFIN"
 Else
   WFIL += "&[F:SXH]SOHNUM <=[M:CSG1]SDHNUMFIN"
 Endif
Endif

#--------------------------- Filtre sur No de tournée --#
If [M:CSG1]DRNDEB <> 0
   WFIL += "&[F:SXH]DRN >=[M:CSG1]DRNDEB"
Endif

If [M:CSG1]DRNFIN <> 0
   WFIL += "&[F:SXH]DRN <=[M:CSG1]DRNFIN"
Endif

#--------------------------- Filtre sur date de livraison --#
If [M:CSG1]DLVDATDEB <> [00/00/00]
 If [M:CSG1]FLGTYP = 2
   WFIL += "&[F:SXH]DLVDAT>=[M:CSG1]DLVDATDEB"
 Else
   WFIL += "&[F:SXH]DEMDLVDAT>=[M:CSG1]DLVDATDEB"
 Endif
Endif

If [M:CSG1]DLVDATFIN <> [00/00/00]
 If [M:CSG1]FLGTYP = 2
   WFIL += "&[F:SXH]DLVDAT<=[M:CSG1]DLVDATFIN"
 Else
   WFIL += "&[F:SXH]DEMDLVDAT<=[M:CSG1]DLVDATFIN"
 Endif
Endif

#--------------------------- Filtre sur date d'expédition --#
If [M:CSG1]SHIDATDEB <> [00/00/00]
 If [M:CSG1]FLGTYP = 2
   WFIL1 += "&[F:SXH]SHIDAT>=[M:CSG1]SHIDATDEB"
 Else
   WFIL1 += "&[F:SXH]SHIDAT>=[M:CSG1]SHIDATDEB"
 Endif
Endif

If [M:CSG1]SHIDATFIN <> [00/00/00]
 If [M:CSG1]FLGTYP = 2
   WFIL1 += "&[F:SXH]SHIDAT<=[M:CSG1]SHIDATFIN"
 Else
   WFIL1 += "&[F:SXH]SHIDAT<=[M:CSG1]SHIDATFIN"
 Endif
Endif

#--------------------------- Filtre sur le transporteur --#

If [M:CSG1]BPTNUMDEB <> ""
   WFIL1 += "&[F:SXH]BPTNUM >=[M:CSG1]BPTNUMDEB"
Endif

If [M:CSG1]BPTNUMFIN <> ""
   WFIL1 += "&[F:SXH]BPTNUM <=[M:CSG1]BPTNUMFIN"
Endif

#--------------------------- Filtre sur priorité livraison (dans les commandes uniquement) --#

If [M:CSG1]FLGTYP = 1 & [M:CSG1]DLVPIO > 0
   WFIL1 += "&[F:SXH]DLVPIO = [M:CSG1]DLVPIO"
Endif

#---------------------------- Prise en compte UNIQUEMENT des livraisons non validées --#+
If [M:CSG1]FLGTYP = 2
   #WFIL += "&[F:SXH]CFMFLG=1"
Endif

##------------------------------------##
## Filtre sur ecran complémentaire  --##
##------------------------------------##

#-- Filtre sur No de livraison ou No de commande --#
#If [M:CCSG]SDHNUMDEB <> ""
# If [M:CCSG]FLGTYP = 2
#   WFIL += "&[F:SXH]SDHNUM>=[M:CCSG]SDHNUMDEB"
# Else
#   WFIL += "&[F:SXH]SOHNUM>=[M:CCSG]SDHNUMDEB"
# Endif
#Endif
#If [M:CCSG]SDHNUMFIN <> ""
# If [M:CCSG]FLGTYP = 2
#   WFIL += "&[F:SXH]SDHNUM<=[M:CCSG]SDHNUMFIN"
# Else
#   WFIL += "&[F:SXH]SOHNUM<=[M:CCSG]SDHNUMFIN"
# Endif
#Endif


##------------------------------------##
## Filtre formule
##------------------------------------##
Raz WFILFOR
If [M:CCSG]SELFOR <> ""
  Read [TFO]TFO0=[M:CSG1]WTYPFOR;[M:CCSG]SELFOR
  If fstat = 0
      WFILFOR = [F:TFO]FORFOR
  Endif
Endif
If WFILFOR= ""
  WFILFOR = "1=1"
Endif
#

##------------------------------------##
##-- Gestion du TRI               --####
##------------------------------------##

If [M:CSG1]FLGTYP = 2
   WCHAMP1 = 'SDHNUM' :     WCHAMP2 = 'DLVDAT'
Else
   WCHAMP1 = 'SOHNUM' :     WCHAMP2 = 'DEMDLVDAT'
Endif

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCSG]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SXH]"  + WCHAMP1 + ">=DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:SXH]" + WCHAMP2  + ">DEBDAT | ([F:SXH]" +  WCHAMP2 + "=DEBDAT  & [F:SXH]" + WCHAMP1 + ">=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCSG]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SXH]" + WCHAMP1 + ">FINNUM"

       When 2 : # tri par date
           WFIL += "&([F:SXH]" + WCHAMP2 + ">FINDAT | ([F:SXH]" +  WCHAMP2 + "=FINDAT  & [F:SXH]" + WCHAMP1 + ">FINNUM))"
     Endcase
   When -2 : # retour
     Case [M:CCSG]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SXH]" + WCHAMP1  + "<DEBNUM"

       When 2 : # tri par date
           WFIL += "& ([F:SXH]" +  WCHAMP2 + "<DEBDAT | ([F:SXH]"  +  WCHAMP2 + "=DEBDAT & [F:SXH]" +   WCHAMP1 + "<DEBNUM))"
     Endcase
Endcase

Return

############################################################################
# $DEB_CRIT :   #
############################################################################
$DEB_CRIT
 If [M:CCSG]FLGTYP= 2      : # Livraison
  Chgtzn [M:CCSG]SDHNUMDEB With mess(3,443,1) : # Livraison
  Chgtzn [M:CCSG]SDHNUMFIN With mess(257,191,1) : # 105537-v7.2 UI Text Review
  Chgfmt [M:CCSG]DLVPIO    With "-N:4"
 Else                       : # Commande
  Chgtzn [M:CCSG]SDHNUMDEB With mess(2,443,1) : # Commande
  Chgtzn [M:CCSG]SDHNUMFIN With mess(258,191,1) : # 105537-v7.2 UI Text Review
  Chgfmt [M:CCSG]DLVPIO    With "N:4"
 Endif
 Affzo [M:CCSG]
Return

############################################################################
# $FIN_CRIT : Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT

Return


############################################################################
# $FIN_CRIT : Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################

$SELFCY
 If [M:CSG1]FLGTYP= 2      : #----- Livraison
  GBIDC1="[F:SDH]STOFCY=[M:CSG1]STOFCY "
 Else                      : #----- Commande
  GBIDC1="[F:SOH]STOFCY=[M:CSG1]STOFCY "
 Endif
Return


