############################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]STOFCY = ""
  GSOCIETE="" : GLOCALDEV=""
Endif
End


############################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()

 If VALEUR <> ""
 # -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat=2 : End
    Endif
   #-----------------------------------#
   # Alimentation site fin.(GFINRSP)   #
   #              soc. (GSOCIETE)      #
   #              dev.soc. (GLOCALDEV) #
   #-----------------------------------#
   Call GETDEV(VALEUR) From DEVSUB
   [M]CPY = GSOCIETE
   Affzo [M]CPY, ZCPY
 Elsif [M]CPY = ""
   GSOCIETE="" : GLOCALDEV=""
 Else
   Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
 Endif
End

########################################
Subprog IB_NBLIG
 If [M:CSG1]FLGTYP = 2
  GBOUT1 = mess(54, 198,1)-[M]SDHNUM(nolign-1)
  [M:CSG1]WOBJET   = 'SDH'
  [M:CSG1]WTYPFOR = 52
 Else
  GBOUT1 = mess(48, 198,1)-[M]SDHNUM(nolign-1)
  [M:CSG1]WOBJET   = 'SOH'
  [M:CSG1]WTYPFOR = 52
 Endif
End

