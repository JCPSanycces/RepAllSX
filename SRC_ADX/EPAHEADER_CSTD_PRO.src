#<AdxTL>@(#)0.0.0.0 $Revision$ 

#FRLAA - 2016-12-06 - REQUIREMENT X3-11647 US X3-12771 - START
$PROPERTIES
Case [L]CURPRO
  When "EPADETAILS.ADMVAL"       Gosub EPADETAILS_ADMVAL
  When "EPADETAILS.ADMCST"       Gosub EPADETAILS_ADMCST
Endcase
Return

$EPADETAILS_ADMVAL
Case [L]ARULE
  When "CONTROL"
  When "PROPAGATE"
    Gosub EPADETAILS_ADMVAL_PROPAGATE
Endcase
Return

$EPADETAILS_ADMCST
Case [L]ARULE
  When "CONTROL"
  When "PROPAGATE"
    Gosub EPADETAILS_ADMCST_PROPAGATE
Endcase
Return

$EPADETAILS_ADMVAL_PROPAGATE
Gosub UPDATE_ADMTOT
Return

$EPADETAILS_ADMCST_PROPAGATE
Gosub UPDATE_ADMTOT
Return

$UPDATE_ADMTOT
#Store VCPY and VFCY
Local Char VCPY(GLONCPY), VFCY(GLONFCY)
Local Integer TYPVAL

If this.ADMCST = 2
  TYPVAL = 7
Elsif this.ADMCST = 3
 TYPVAL = 5
Else
  TYPVAL = 0
Endif

Call FCY_CPY(this.APARENT.REFNUM,this.APARENT.CTRNUM,this.APARENT.CTRDAT,VCPY,VFCY)
this.WADMVAL = func EPAFUNCTIONS.GET_RATE(TYPVAL,eomonth(GMOIPAY),this.LEG,VCPY,VFCY) + this.ADMVAL
Return

Subprog FCY_CPY(VREFNUM,VCTRNUM,VCTRDAT,PVCPY,PVFCY)
Value Char VREFNUM,VCTRNUM
Variable Char PVCPY,PVFCY
Value Date VCTRDAT

#Store VCPY and VFCY
Local File EMPLOCTR [CTR]
Local File FACILITY [FCY]
Filter [CTR] Where REFNUM = VREFNUM and CTRNUM = VCTRNUM and CTRDAT = VCTRDAT Order By CTRDAT
Read [CTR] Last
If !fstat
  PVFCY = [F:CTR]ETRFCY
  If PVFCY <> ""
    Read [FCY]FCY0 = PVFCY
    If !fstat
      PVCPY = [F:FCY]LEGCPY
    Endif
  Endif
Endif
LogicClose File [CTR]
LogicClose File [FCY]
End

#FRLAA - 2016-12-06 - REQUIREMENT X3-11647 US X3-12771 - END



