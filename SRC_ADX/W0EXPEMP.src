#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque EXPEMP 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone EXC
mkstat = 0
zoncou = "EXC"
indice = 0
IMPENT = [M]EXC
If varinit([M]EXC,indice)=0
 IMPENT = 1
Endif
If varmode([M]EXC,indice)=0
 [M]EXC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EXC(indice)
 Endif
Endif
[M]EXC = IMPENT

## Zone ADR
mkstat = 0
zoncou = "ADR"
indice = 0
IMPENT = [M]ADR
If varinit([M]ADR,indice)=0
 IMPENT = 1
Endif
If varmode([M]ADR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_ADR(IMPENT) From TRTEMP1
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]ADR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ADR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ADR(indice)
 Endif
Endif
[M]ADR = IMPENT

## Zone FLGCTR
mkstat = 0
zoncou = "FLGCTR"
indice = 0
IMPENT = [M]FLGCTR
If varinit([M]FLGCTR,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGCTR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_FLGCTR(IMPENT) From TRTEMP1
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]FLGCTR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGCTR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGCTR(indice)
 Endif
Endif
[M]FLGCTR = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "EXPEMP"
Return

