#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe BUDINQH

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
       When "AREAD" : Gosub AREAD
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

##########################################################################################################
$AREAD
Gosub DECLARE
Call LEC_FCY(this.SIT) From CPTLEC
COMPANY = [F:FCY]LEGCPY

# Search the ledgers ticked "budget"
[L]ASTATUS = func FINACM_SYRA.GET_LSTLEDTYP(this.ACTX,COMPANY,4,NBRLED,WTBUDLEDTYP,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Raz NBRLED

# To decrypt the LLEDTYP and LACC parameters
For I=1 To len(mess(0,2644,1))
 J = instr(1,this.LLEDTYP,";")
 K = instr(1,this.LACC,";")
 If J & K
  VLEDTYP = val(left$(this.LLEDTYP,J-1))
  If VLEDTYP<>0 & find(VLEDTYP,WTBUDLEDTYP)
   NBRLED +=1
   TBUDLEDTYP(NBRLED) = VLEDTYP
   TBUDACC(NBRLED)    = left$(this.LACC,K-1)
  Endif
 Endif
 this.LLEDTYP = right$(this.LLEDTYP,J+1)
 this.LACC    = right$(this.LACC,K+1)
Next

# Search the accounting and analytical structure for the ledgers stored in TBUDLED
[L]ASTATUS = func FINACM_SYRA.GET_FINREDSTC(this.ACTX,COMPANY,1,NBRLED,TBUDLEDTYP,TBUDLEDCOD,TBUDLEDCUR,TBUDCOA,COAFMT,
&             COACOLHEA,NBRDIE,TDIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# To decrypt the LDIE and LCCE parameters
Raz NBRDIE

For I=1 To DIMANA
 J = instr(1,this.LDIE,";")
 K = instr(1,this.LCCE,";")
 If J & K
  VDIE = left$(this.LDIE,J-1)
  If VDIE<>"" & find(VDIE,TDIE)
   NBRDIE +=1
   TBUDDIE(NBRDIE) = VDIE
   TBUDCCE(NBRDIE) = left$(this.LCCE,K-1)
  Endif
 Endif
 this.LDIE = right$(this.LDIE,J+1)
 this.LCCE = right$(this.LCCE,K+1)
Next

If NBRLED=0
 [L]ASTATUS = fmet this.ASETERROR("",mess(112,106,1),[V]CST_AERROR) : Return
Endif

# Return the budgets to inquire
Call GET_BUP(this.ACTX,this.SIT,BUD,BUDVER,NBRBUD) From FINBUD_SYRA

NBRRUN=0
For I=1 To NBRBUD
 For J=1 To NBRLED
  For [BUD] Where BUD=[L]BUD(I) & VER=[L]BUDVER(I)& LEDTYP=[L]TBUDLEDTYP(J)
   NBRRUN = fmet this.ADDLINE("C_BUDINQ",[V]CST_ALASTPOS)
   this.C_BUDINQ(NBRRUN).BUP = BUD(I)
   this.C_BUDINQ(NBRRUN).VER = BUDVER(I)
   this.C_BUDINQ(NBRRUN).LEDTYP = TBUDLEDTYP(J)
   Break
  Next
 Next
Next
If NBRRUN=0
 [L]ASTATUS = fmet this.ASETERROR("",mess(265,108,1),[V]CST_AERROR) :  Return
Endif

# Load the budgets data
For IBUD=1 To maxtab(this.C_BUDINQ)
 Gosub LOAD_DATA
Next
Return


###################################################################################################
# Load the data in the representation
###################################################################################################
$LOAD_DATA

ILED = find(this.C_BUDINQ(IBUD).LEDTYP ,TBUDLEDTYP)
COA  = TBUDCOA(ILED)
ACC  = TBUDACC(ILED)

Call LEC_LED(TBUDLEDCOD(ILED)) From CPTLEC

Call LEC_BUP(this.C_BUDINQ(IBUD).BUP) From CPTLEC

# Get the rate

If [F:BUP]CUR<>TBUDLEDCUR(ILED)
 TYPCUR = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,this.SIT,"BUDTYPCUR")
 If TYPCUR=0 : TYPCUR = 1 : Endif
 [L]ASTATUS = func CDACUR_SYRA.GET_CURRAT(this.ACTX,[F:BUP]CUR,TBUDLEDCUR(ILED),TYPCUR,this.DAT,RATE)
 If [L]ASTATUS = [V]CST_AERROR
  [L]ASTATUS = fmet this.ASETERROR("",[F:BUP]BUD-mess(16,114,1)-TBUDLEDCUR(ILED),[V]CST_AERROR)
  Return
 Endif
Endif

# Get the fiscal year and the period
Gosub GET_PEREXE

If [F:BUP]LEV=1
 BUDFCY = ""
Else
 BUDFCY = this.SIT
Endif

# Get the accounts and the dimensions if the budget has a pyramid
Gosub INI_ACC
Gosub INI_CCE

# Loading is different if it is an operating budget
If [F:BUP]GDDFLG=2
 Gosub BUD_BUO
Else
 Gosub BUD_ANA
Endif

Return

###################################################################################################
$DECLARE
If adxtyp=33 | !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If adxtyp=33 | !clalev([F:LED]) : Local File GLED       [LED] : Endif
If adxtyp=33 | !clalev([F:BUD]) : Local File BUD        [BUD] : Endif
If adxtyp=33 | !clalev([F:BUP]) : Local File BUDPAR     [BUP] : Endif
If adxtyp=33 | !clalev([F:CRY]) : Local File GCCEGRUPYM [CRY] : Endif
If adxtyp=33 | !clalev([F:GRY]) : Local File GACCGRUPYM [GRY] : Endif
If adxtyp=33 | !clalev([F:CYK]) : Local File GCCEPYMLIK [CYK] : Endif
If adxtyp=33 | !clalev([F:GYK]) : Local File GACCPYMLIK [GYK] : Endif
If adxtyp=33 | !clalev([F:ACV]) : Local File ACTIV      [ACV] : Endif
If adxtyp=33 | !clalev([F:PER]) : Local File PERIOD     [PER] : Endif
If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT   [GAC] : Endif
If adxtyp=33 | !clalev([F:COA]) : Local File GCOA       [COA] : Endif
If adxtyp=33 | !clalev([F:CLS]) : Local File GACCCLS    [CLS] : Endif
If adxtyp=33 | !clalev([F:BLA]) : Local File BALANA     [BLA] : Endif
If adxtyp=33 | !clalev([F:BLM]) : Local File BLACMM     [BLM] : Endif
If adxtyp=33 | !clalev([F:BLQ]) : Local File BLAQTY     [BLQ] : Endif

# Parameters : DAT, SITE, ACC, LEDTYP, CCE, DIE
Local Integer ASTATUS
Local Char    ERRMES(250)
Local Char    COMPANY(GLONCPY)                     : # Company of the site parameter
Local Integer DIMLED : DIMLED = len(mess(0,2644,1))
Local Integer DIMANA, FLG
Call LEC_ACV("ANA",FLG) From CPTLEC
If !FLG
 DIMANA = 1
Else
 DIMANA = max(1,[F:ACV]DIME)
Endif


Local Tinyint WTBUDLEDTYP(1..DIMLED)         : # List of the ledger types ticked 'budget' of the company
# Variables only used to call FINACM_SYRA.GET_FINREDSTC
Local Char    COAFMT(15)(1..DIMLED)          : # Charts of accounts Formats
Local Char    COACOLHEA(GLONAX1)(1..DIMLED)  : # Charts of accounts Column Header
Local Char    DIEFMT(15)(1..DIMANA)          : # Dimension Type Formats
Local Char    DIECOLHEA(GLONAX1)(1..DIMANA)  : # Dimension Types Column Header
Local Integer DIEOBYFLG(1..DIMANA)           : # Obligatory Flags (Y/N)

# Variables used to decrypt the LLEDTYP LACC LDIE and LCCE parameters
Local Integer NBRDIE                         : # Number of dimensions
Local Tinyint VLEDTYP                        : # Ledger type read in the list LLEDTYP
Local Char    VDIE(GLONDIE)                  : # Dimension type read in the list LDIE
Local Char    TDIE(GLONDIE)(1..DIMANA)       : # List of the dimensions types of the budget ledger
Local Char    TBUDDIE(GLONDIE)(1..DIMANA)    : # List of dimension types
Local Char    TBUDCCE(GLONCCE)(1..DIMANA)    : # List of dimensions
Local Integer NBRLED                         : # Number of ledgers ticked budget
Local Tinyint TBUDLEDTYP(1..DIMLED)          : # List of ledgers ticked budget
Local Char    TBUDACC(GLONGAC)(1..DIMLED)    : # List of accounts of the ledgers ticked budget
Local Char    TBUDLEDCOD(GLONLED)(1..DIMLED) : # List of ledger codes matching the ledgers in TBUDLEDTYP
Local Char    TBUDLEDCUR(GLONCUR)(1..DIMLED) : # List of ledger currencies matching the ledgers in TBUDLEDTYP
Local Char    TBUDCOA(GLONCOA)(1..DIMLED)    : # List of chart of account matching the ledgers in TBUDLEDTYP

# Variables used to store the budget to control
Local Integer NBRBUD                         : # Number of budgets to control
Local Char    BUD(GLONBUP)(1..10)            : # Budgets to control.It refers to parameters BUPx
Local Char    BUDVER(GLONBUV)(1..10)         : # Versions of the budgets to control
Local Integer NBRRUN                         : # Number of budget/version/ledtyp to display
Local Char    ACC(GLONGAC)                   : # Current Account managed by the budget
Local Char    COA(GLONCOA)                   : # Current Chart of account of ACC
Local Integer I, J, K, I1, I2, I3, I4
Local Integer I5, I6, I7, I8, I9, I10
Local Integer TYPCUR                         : # Rate type of a currency
Local Decimal RATE                           : # Currency rate
Local Integer FIYSTR, FIYEND                 : # First and last fiscal year
Local Integer PERSTR, PEREND                 : # First and last period of a budget
Local Integer PER1,PER2                      : # First and last period of a FIY to take into account the amounts in the balance
Local Date    TMPSTRDAT                      : # Date de début d'une période
Local Char    BUDFCY(GLONFCY)                : # Empty if the definition level of the budget is company
Local Char    GRUREF(max(GLONCYR,GLONGRY))   : # Group of dimensions or accounts linked to the dimension/account

# Variables used to initialize the accounts and dimensions
Local Integer NBACC                          : # Number of accounts that belong to the pyramid
Local Char    BUDACC(GLONGAC)                : # Group of accounts if the budget is defined with an account pyramid
Local Char    TACC(GLONGAC)(1..300)          : # List of accounts that belong to the pyramid
Local Integer NBCCE(1..9)                    : # Number of dimensions that belong to the pyramid for the 1st,2nd .. dimension type
Local Char    BUDCCE(GLONCCE)(1..9)          : # Dimension or group of dimensions for 1st,2nd... dimension in order of BUD
Local Char    LEDBUDCCE(GLONCCE)(1..9)       : # Dimension or group of dimensions for 1st,2nd... dimension in order of LED
Local Char    TCCE1(GLONCCE)(1..300)         : # List of dimensions that belong to the pyramid for the 1st dimension type
Local Char    TCCE2(GLONCCE)(1..300)         : # List of dimensions that belong to the pyramid for the 2nd dimension type
Local Char    TCCE3(GLONCCE)(1..300)         : # List of dimensions that belong to the pyramid for the 3rd dimension type
Local Char    TCCE4(GLONCCE)(1..300)         : # List of dimensions that belong to the pyramid for the 4th dimension type
Local Char    TCCE5(GLONCCE)(1..300)         : # List of dimensions that belong to the pyramid for the 5th dimension type
Local Char    TCCE6(GLONCCE)(1..300)         : # List of dimensions that belong to the pyramid for the 6th dimension type
Local Char    TCCE7(GLONCCE)(1..300)         : # List of dimensions that belong to the pyramid for the 7th dimension type
Local Char    TCCE8(GLONCCE)(1..300)         : # List of dimensions that belong to the pyramid for the 8th dimension type
Local Char    TCCE9(GLONCCE)(1..300)         : # List of dimensions that belong to the pyramid for the 9th dimension type
Local Integer ICCE(1..9)                     : # Index of the dimension type in the ledger to populate CCE1,2 ....
Local Integer INDCCE

Local Char    CRITBLA(250)                   : # Criteria in the balance when the budget has no pyramid
Local Char    CRITBLAPYM1(250)               : # Criteria number 1 in the balance when the budget has a pyramid
Local Char    CRITBLAPYM2(250)               : # Criteria number 2 in the balance when the budget has a pyramid
Local Char    CRITBLAPYM3(250)               : # Criteria number 3 in the balance when the budget has a pyramid
Local Char    CRITBLAPYM4(250)               : # Criteria number 4 in the balance when the budget has a pyramid
Local Integer FLGBUDCMM                      : # Value of the BUDCMM parameter (take into account CMM in the balance ?)
Local Integer FLGBUDCMMPRP                   : # Value of the BUDCMMPRP parameter (take into account CMMPRP in the balance ?)
Local Integer SIGN                           : # Analytical sense of the account
Return

###################################################################################################
# Period and fiscal year of the date depending on the control type of the budget
###################################################################################################
$GET_PEREXE
Case [F:BUP]BUDCTL
 When 2,3 : # Annual control type, Period control type
  [L]ASTATUS = func FINPER_SYRA.GET_PER(this.ACTX, COMPANY, this.C_BUDINQ(IBUD).LEDTYP, this.DAT, FIYSTR, PERSTR, ERRMES)
  FIYEND = FIYSTR

 When 4   : # Sliding control typ
  [L]ASTATUS = func FINPER_SYRA.GET_PER(this.ACTX,COMPANY,this.C_BUDINQ(IBUD).LEDTYP,[F:BUP]VLYSTR,FIYSTR,PERSTR,ERRMES)
  If FIYSTR=0 | PERSTR=0
   For [PER]PER0 Where CPY=COMPANY & LEDTYP=this.C_BUDINQ(IBUD).LEDTYP & PERSTR>=[F:BUP]VLYSTR & PEREND>=[F:BUP]VLYSTR
    FIYSTR = [F:PER]FIYNUM
    PERSTR = [F:PER]PERNUM
    Break
   Next
  Endif
  If [F:BUP]VLYEND<>[0/0/0]
   [L]ASTATUS = func FINPER_SYRA.GET_PER(this.ACTX,COMPANY,this.C_BUDINQ(IBUD).LEDTYP,[F:BUP]VLYEND,FIYEND,PEREND,ERRMES)
   If FIYEND=0 | PEREND=0
    For [PER]PER0 Where CPY=COMPANY & LEDTYP=this.C_BUDINQ(IBUD).LEDTYP & PERSTR<=[F:BUP]VLYEND & PEREND<=[F:BUP]VLYEND
     FIYEND = [F:PER]FIYNUM
     PEREND = [F:PER]PERNUM
    Next
   Endif
   If FIYEND=0
    For [PER]PER0 Where CPY=COMPANY & LEDTYP=this.C_BUDINQ(IBUD).LEDTYP &  PERSTA=2
     FIYEND = [F:PER]FIYNUM
     PEREND = [F:PER]PERNUM
    Next
    [L]ASTATUS = func FINPER_SYRA.GET_FIYDATES(this.ACTX, COMPANY, this.C_BUDINQ(IBUD).LEDTYP, FIYEND, TMPSTRDAT, [F:BUP]VLYEND, ERRMES)
   Endif
  Else
   For [PER]PER0 Where LEDTYP=this.C_BUDINQ(IBUD).LEDTYP & CPY=COMPANY & PERSTA=2
    FIYEND = [F:PER]FIYNUM
    PEREND = [F:PER]PERNUM
   Next
  Endif

 When 5   : # Accumulated control type
  [L]ASTATUS = func FINPER_SYRA.GET_PER(this.ACTX, COMPANY, this.C_BUDINQ(IBUD).LEDTYP, [F:BUP]VLYSTR, FIYSTR, PERSTR, ERRMES)
  If FIYSTR=0 | PERSTR=0
   For [PER]PER0 Where LEDTYP=this.C_BUDINQ(IBUD).LEDTYP & CPY=COMPANY & PERSTR>=[F:BUP]VLYSTR & PEREND>=[F:BUP]VLYSTR
    FIYSTR = [F:PER]FIYNUM
    PERSTR = [F:PER]PERNUM
    Break
   Next
  Endif
  [L]ASTATUS = func FINPER_SYRA.GET_PER(this.ACTX, COMPANY, this.C_BUDINQ(IBUD).LEDTYP, this.DAT, FIYEND, PEREND, ERRMES)
Endcase

If FIYSTR=0 & PERSTR=0
 For [PER]PER0 Where CPY=COMPANY & LEDTYP=this.C_BUDINQ(IBUD).LEDTYP
  If [F:PER]PERSTR>[F:BUP]VLYSTR
   FIYSTR = [F:PER]FIYNUM
   PERSTR = [F:PER]PERNUM
  Endif
  Break
 Next
Endif
Return

###################################################################################################
# Initialize the accounts
###################################################################################################
$INI_ACC
Raz BUDACC

If [F:BUP]PYMACC<>""
 Raz [F:GRY]
 For [GRY]GRY0 Where PYM=[F:BUP]PYMACC & pat([L]ACC,ACC)
  Break
 Next
 If [F:GRY]PYM=[F:BUP]PYMACC
  GRUREF = [F:GRY]GRU : NBACC = 0
  For [GRY]GRY0 Where PYM=[F:BUP]PYMACC & GRU=GRUREF
   If NBACC+1>=dim(TACC)
    [L]ASTATUS = fmet this.ASETERROR("",mess(26,100,1),[V]CST_AERROR)
    Break
   Endif
   NBACC += 1
   TACC(NBACC) = [F:GRY]ACC : # This array is populated for the balance reading
  Next
  If [F:BUP]PYMACCLEV=[F:GRY]LEV
   BUDACC = GRUREF
  Else
   Raz [F:GYK]
   Filter [GYK] Where PYM=[F:BUP]PYMACC & LEV=[F:BUP]PYMACCLEV & pat([L]ACC,ACC)
   For [GYK]GYK0
    Break
   Next
   If [F:GYK]PYM=[F:BUP]PYMACC
    BUDACC = [F:GYK]GRU
    NBACC = 0 : Raz TACC
    For [GYK]GYK0 Where PYM=[F:BUP]PYMACC & LEV=[F:BUP]PYMACCLEV & GRU=BUDACC
     If NBACC+1>=dim(TACC)
      [L]ASTATUS = fmet this.ASETERROR("",mess(26,100,1),[V]CST_AERROR)
      Break
     Endif
     NBACC += 1
     TACC(NBACC) = [F:GYK]ACC
    Next
   Else
    Raz [F:GYK]
    Filter [GYK] Where PYM=[F:BUP]PYMACC & LEV=[F:BUP]PYMACCLEV
    For [GYK]GYK0
     Break
    Next
    If [F:GYK]PYM=[F:BUP]PYMACC
     BUDACC = [F:GYK]GRU
     NBACC = 0 : Raz TACC
     For [GYK]GYK0 Where PYM=[F:BUP]PYMACC & LEV=[F:BUP]PYMACCLEV & GRU=BUDACC
      If NBACC+1>=dim(TACC)
       [L]ASTATUS = fmet this.ASETERROR("",mess(26,100,1),[V]CST_AERROR)
       Break
      Endif
      NBACC += 1
      TACC(NBACC) = [F:GYK]ACC
     Next
    Endif
   Endif
   Filter [GYK]
  Endif
 Endif
 [L]ACC = BUDACC
Else
 NBACC   = 1
 TACC(1) = [L]ACC
Endif
Return

###################################################################################################
# Initialize the dimensions
###################################################################################################
$INI_CCE
For I=1 To dim(NBCCE)
 NBCCE(I) = 1
Next
Raz LEDBUDCCE
Raz BUDCCE
For I=1 To [F:BUP]DIENBR

 # The budget has no pyramid for this dimension type
 If [F:BUP]DIE(I-1)<>"" & [F:BUP]PYMCCE(I-1)=""
  J      = find([F:BUP]DIE(I-1),TBUDDIE)
  INDCCE = find([F:BUP]DIE(I-1),[F:LED]DIE)
  If J & INDCCE
   LEDBUDCCE(INDCCE) = TBUDCCE(J)
   BUDCCE(I)         = TBUDCCE(J)
  Endif

 # The budget has a pyramid for this dimension type
 Elsif [F:BUP]DIE(I-1)<>"" & [F:BUP]PYMCCE(I-1)<>""
  J      = find([F:BUP]DIE(I-1),TBUDDIE)
  INDCCE = find([F:BUP]DIE(I-1),[F:LED]DIE)
  If J & INDCCE
   LEDBUDCCE(INDCCE) = TBUDCCE(J)
   BUDCCE(I)         = TBUDCCE(J)
   NBCCE(INDCCE)     = 1
   Case INDCCE
    When 1 : TCCE1(1) = LEDBUDCCE(INDCCE)
    When 2 : TCCE2(1) = LEDBUDCCE(INDCCE)
    When 3 : TCCE3(1) = LEDBUDCCE(INDCCE)
    When 4 : TCCE4(1) = LEDBUDCCE(INDCCE)
    When 5 : TCCE5(1) = LEDBUDCCE(INDCCE)
    When 6 : TCCE6(1) = LEDBUDCCE(INDCCE)
    When 7 : TCCE7(1) = LEDBUDCCE(INDCCE)
    When 8 : TCCE8(1) = LEDBUDCCE(INDCCE)
    When 9 : TCCE9(1) = LEDBUDCCE(INDCCE)
   Endcase

   Raz [F:CRY]
   For [CRY]CRY0 Where PYM=[F:BUP]PYMCCE(I-1) & pat(LEDBUDCCE(INDCCE),CCE)<>0
    Break
   Next

   If [F:CRY]PYM=[F:BUP]PYMCCE(I-1)
    GRUREF = [F:CRY]GRU
    NBCCE(INDCCE) = 0
    For [CRY]CRY0 Where PYM=[F:BUP]PYMCCE(I-1) & GRU=GRUREF
     If NBCCE(INDCCE)+1>=dim(TCCE1)
      [L]ASTATUS = fmet this.ASETERROR("",mess(26,100,1),[V]CST_AERROR)
      Break
      Endif
     NBCCE(INDCCE) += 1
     Case INDCCE
      When 1 : TCCE1(NBCCE(INDCCE)) = [F:CRY]CCE
      When 2 : TCCE2(NBCCE(INDCCE)) = [F:CRY]CCE
      When 3 : TCCE3(NBCCE(INDCCE)) = [F:CRY]CCE
      When 4 : TCCE4(NBCCE(INDCCE)) = [F:CRY]CCE
      When 5 : TCCE5(NBCCE(INDCCE)) = [F:CRY]CCE
      When 6 : TCCE6(NBCCE(INDCCE)) = [F:CRY]CCE
      When 7 : TCCE7(NBCCE(INDCCE)) = [F:CRY]CCE
      When 8 : TCCE8(NBCCE(INDCCE)) = [F:CRY]CCE
      When 9 : TCCE9(NBCCE(INDCCE)) = [F:CRY]CCE
     Endcase
    Next

    If [F:BUP]PYMCCELEV(I-1)=[F:CRY]LEV
     LEDBUDCCE(INDCCE) = GRUREF
    Else
     If LEDBUDCCE(INDCCE)<>""
      Read [CYK]CYK0 = [F:BUP]PYMCCE(I-1);[F:BUP]PYMCCELEV(I-1);LEDBUDCCE(INDCCE)
      If !fstat
       LEDBUDCCE(INDCCE) = [F:CYK]GRU
       NBCCE(INDCCE)  = 0
       Gosub RAZ_TCCE
       For [CYK]CYK0 Where PYM=[F:BUP]PYMCCE(I-1) & LEV=[F:BUP]PYMCCELEV(I-1) & GRU=LEDBUDCCE(INDCCE)
        If NBCCE(INDCCE)+1>=dim(TCCE1)
         [L]ASTATUS = fmet this.ASETERROR("",mess(26,100,1),[V]CST_AERROR)
         Break
        Endif
        NBCCE(INDCCE) += 1
        Gosub UPD_TCCE
       Next
      Endif
     Else
      Raz [F:CYK]
      For [CYK]CYK0 Where PYM=[F:BUP]PYMCCE(I-1) & LEV=[F:BUP]PYMCCELEV(I-1)
       Break
      Next
      If [F:CYK]PYM=[F:BUP]PYMCCE(I-1)
       LEDBUDCCE(INDCCE) = [F:CYK]GRU
       NBCCE(INDCCE)  = 0
       Gosub RAZ_TCCE
       For [CYK]CYK0 Where PYM=[F:BUP]PYMCCE(I-1) & LEV=[F:BUP]PYMCCELEV(I-1) & GRU=LEDBUDCCE(INDCCE)
        If NBCCE(INDCCE)+1>=dim(TCCE1)
         [L]ASTATUS = fmet this.ASETERROR("",mess(26,100,1),[V]CST_AERROR)
         Break
        Endif
        NBCCE(INDCCE) += 1
        Gosub UPD_TCCE
       Next
      Endif
      Filter [CYK]
     Endif
    Endif
   Endif
  Endif
 Else
  Raz NBCCE(INDCCE)
 Endif

Next
Return

$RAZ_TCCE
## Reset TCCEindcce taking into account all the dimensions of the new group included in LEDBUDCCE(INDCCE)
## and linked to the same level defined in the budget code
Case INDCCE
 When 1 : Raz TCCE1
 When 2 : Raz TCCE2
 When 3 : Raz TCCE3
 When 4 : Raz TCCE4
 When 5 : Raz TCCE5
 When 6 : Raz TCCE6
 When 7 : Raz TCCE7
 When 8 : Raz TCCE8
 When 9 : Raz TCCE9
Endcase
Return

$UPD_TCCE
Case INDCCE
 When 1 : TCCE1(NBCCE(INDCCE)) = [F:CYK]CCE
 When 2 : TCCE2(NBCCE(INDCCE)) = [F:CYK]CCE
 When 3 : TCCE3(NBCCE(INDCCE)) = [F:CYK]CCE
 When 4 : TCCE4(NBCCE(INDCCE)) = [F:CYK]CCE
 When 5 : TCCE5(NBCCE(INDCCE)) = [F:CYK]CCE
 When 6 : TCCE6(NBCCE(INDCCE)) = [F:CYK]CCE
 When 7 : TCCE7(NBCCE(INDCCE)) = [F:CYK]CCE
 When 8 : TCCE8(NBCCE(INDCCE)) = [F:CYK]CCE
 When 9 : TCCE9(NBCCE(INDCCE)) = [F:CYK]CCE
Endcase
Return

###################################################################################################
# Load the data in the representation for an operating budget
###################################################################################################
$BUD_BUO

If adxtyp=33 | !clalev([F:CMD])  : Local File GCOMMITD  [CMD] : Endif
If adxtyp=33 | !clalev([F:ENV])  : Local File ENVELOPPE [ENV] : Endif
If adxtyp=33 | !clalev([F:BUT])  : Local File BUDTYP    [BUT] : Endif
If adxtyp=33 | !clalev([F:DIE])  : Local File GDIE      [DIE] : Endif
Local Integer ENVFIY

[L]ASTATUS = func FINPER_SYRA.GET_PER(this.ACTX, COMPANY, this.C_BUDINQ(IBUD).LEDTYP, this.DAT, FIYSTR, PERSTR, ERRMES)

For I=1 To [F:LED]DIENBR
 Read [DIE]DIE0 = [F:LED]DIE(I-1)
 If !fstat & [F:DIE]ENV=2
  Break
 Endif
Next
Call LEC_ENV(LEDBUDCCE(I)) From CPTLEC
Call LEC_BUT([F:ENV]BUDTYP) From CPTLEC

# Check the consistency between the given date and the date of the envelop
If [F:BUT]YEAFLG=1 : # Yearly budget envelop
 [L]ASTATUS = func FINPER_SYRA.GET_FIY(this.ACTX, COMPANY, this.C_BUDINQ(IBUD).LEDTYP, [F:ENV]REASTR, ENVFIY, ERRMES)
 If FIYSTR<ENVFIY
  FIYSTR = ENVFIY
 Endif
Else               : # Multi annual envelop - if a carry forward is done for the commitment, get the right date
 Raz [F:CMD]
 Filter [CMD] Where NUM=this.CMMNUM & GRDPCE=6 Order By Key CMD0 Desc
 For [CMD]CMD0
  Break
 Next
 Filter [CMD]
 If [F:CMD]NUM=this.CMMNUM
  [L]ASTATUS = func FINPER_SYRA.GET_FIY(this.ACTX, COMPANY, this.C_BUDINQ(IBUD).LEDTYP, [F:CMD]ACCDAT, ENVFIY, ERRMES)
  If FIYSTR<ENVFIY
   FIYSTR = ENVFIY
  Endif
 Endif
Endif

[L]ASTATUS = func FINPER_SYRA.GET_FIYDATES(this.ACTX, COMPANY, this.C_BUDINQ(IBUD).LEDTYP, FIYSTR,
&                                          this.C_BUDINQ(IBUD).STRDAT, this.C_BUDINQ(IBUD).ENDDAT, ERRMES)

Read [BUD]BUD0=this.C_BUDINQ(IBUD).LEDTYP;this.C_BUDINQ(IBUD).BUP;COMPANY;BUDFCY;FIYSTR;this.C_BUDINQ(IBUD).VER;
&              ACC;LEDBUDCCE(1);LEDBUDCCE(2);LEDBUDCCE(3);LEDBUDCCE(4);LEDBUDCCE(5);LEDBUDCCE(6);LEDBUDCCE(7);
&              LEDBUDCCE(8);LEDBUDCCE(9)

If !fstat
 this.C_BUDINQ(IBUD).AMTREA    = [F:BUD]AMTREA
 this.C_BUDINQ(IBUD).AMTCMM    = [F:BUD]AMTCMM
 this.C_BUDINQ(IBUD).AMTPRECMM = [F:BUD]AMTCMMPRP
 this.C_BUDINQ(IBUD).AMTTOT    = [F:BUD]AMTREA+[F:BUD]AMTCMM+[F:BUD]AMTCMMPRP
 this.C_BUDINQ(IBUD).AMTBUD    = [F:BUD]AMT
 this.C_BUDINQ(IBUD).CUR       = [F:BUD]CUR
 this.C_BUDINQ(IBUD).DES = ACC-BUDCCE(1)-BUDCCE(2)-BUDCCE(3)-BUDCCE(4)-BUDCCE(5)-BUDCCE(6)-BUDCCE(7)-BUDCCE(8)-BUDCCE(9)
 this.C_BUDINQ(IBUD).BUDCTL    = [F:BUP]BUDCTL
 Raz this.C_BUDINQ(IBUD).UOM
Endif

If adxtyp=33 : Close Local File [CMD] : Endif
If adxtyp=33 : Close Local File [ENV] : Endif
If adxtyp=33 : Close Local File [BUT] : Endif
Return

###################################################################################################
# Load the data in the representation for a classic budget
###################################################################################################
$BUD_ANA

# Calculate the budget amount to display
For I=FIYSTR To FIYEND
 Read [BUD]BUD0=this.C_BUDINQ(IBUD).LEDTYP;this.C_BUDINQ(IBUD).BUP;COMPANY;BUDFCY;I;this.C_BUDINQ(IBUD).VER;
&               ACC;LEDBUDCCE(1);LEDBUDCCE(2);LEDBUDCCE(3);LEDBUDCCE(4);LEDBUDCCE(5);LEDBUDCCE(6);
&               LEDBUDCCE(7);LEDBUDCCE(8);LEDBUDCCE(9)
 If !fstat
  Case [F:BUP]BUDCTL
   When 2   : # Annual control type
    this.C_BUDINQ(IBUD).AMTBUD = sum([F:BUD]AMT)
    this.C_BUDINQ(IBUD).QTYBUD = sum([F:BUD]QTY)
   When 3   : # Period control type
    this.C_BUDINQ(IBUD).AMTBUD = [F:BUD]AMT(PERSTR-1)
    this.C_BUDINQ(IBUD).QTYBUD = [F:BUD]QTY(PERSTR-1)
   When 4,5 : # Sliding control type, Accumulated control type
    If I=FIYSTR & I=FIYEND
     this.C_BUDINQ(IBUD).AMTBUD += sum([F:BUD]AMT(PERSTR-1..PEREND-1))
     this.C_BUDINQ(IBUD).QTYBUD += sum([F:BUD]QTY(PERSTR-1..PEREND-1))
    Elsif I=FIYSTR
     this.C_BUDINQ(IBUD).AMTBUD += sum([F:BUD]AMT(PERSTR-1..dim([F:BUD]AMT)-1))
     this.C_BUDINQ(IBUD).QTYBUD += sum([F:BUD]QTY(PERSTR-1..dim([F:BUD]QTY)-1))
    Elsif I=FIYEND
     this.C_BUDINQ(IBUD).AMTBUD += sum([F:BUD]AMT(0..PEREND-1))
     this.C_BUDINQ(IBUD).QTYBUD += sum([F:BUD]QTY(0..PEREND-1))
    Else
     this.C_BUDINQ(IBUD).AMTBUD += sum([F:BUD]AMT(0..dim([F:BUD]AMT)-1))
     this.C_BUDINQ(IBUD).QTYBUD += sum([F:BUD]QTY(0..dim([F:BUD]QTY)-1))
    Endif
  Endcase
 Endif
Next

If [F:BUP]CUR<>TBUDLEDCUR(ILED)
 Call LEC_TCU(TBUDLEDCUR(ILED)) From CPTLEC
 this.C_BUDINQ(IBUD).AMTBUD = arr(this.C_BUDINQ(IBUD).AMTBUD*RATE,[F:TCU]CURRND)
Endif

this.C_BUDINQ(IBUD).CUR = TBUDLEDCUR(ILED)

# Read the right index of the dimension type to populate the right dimension
Call LEC_LED(TBUDLEDCOD(ILED)) From CPTLEC
For I=1 To 9
 ICCE(I) = find([F:BUP]DIE(I-1),[F:LED]DIE)
Next

# Calculate the balance amounts to display
If [F:BUP]PYMACC="" & [F:BUP]PYMCCE(0)="" & [F:BUP]PYMCCE(1)="" & [F:BUP]PYMCCE(2)="" & [F:BUP]PYMCCE(3)=""
&& [F:BUP]PYMCCE(4)="" & [F:BUP]PYMCCE(5)="" & [F:BUP]PYMCCE(6)="" & [F:BUP]PYMCCE(7)="" & [F:BUP]PYMCCE(8)=""
 Gosub CAL_BAL_NOPYM
Else
 Gosub CAL_BAL_WITHPYM
Endif

this.C_BUDINQ(IBUD).AMTTOT = this.C_BUDINQ(IBUD).AMTREA
this.C_BUDINQ(IBUD).QTYTOT = this.C_BUDINQ(IBUD).QTYREA

FLGBUDCMM    = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,this.SIT,"BUDCMM")
FLGBUDCMMPRP = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,this.SIT,"BUDCMMPRP")

If FLGBUDCMM=[V]CST_AYES
 this.C_BUDINQ(IBUD).AMTTOT += this.C_BUDINQ(IBUD).AMTCMM
 this.C_BUDINQ(IBUD).QTYTOT += this.C_BUDINQ(IBUD).QTYCMM
Endif

If FLGBUDCMMPRP=[V]CST_AYES
 this.C_BUDINQ(IBUD).AMTTOT += this.C_BUDINQ(IBUD).AMTPRECMM
 this.C_BUDINQ(IBUD).QTYTOT += this.C_BUDINQ(IBUD).QTYPRECMM
Endif
this.C_BUDINQ(IBUD).DES = ACC-BUDCCE(1)-BUDCCE(2)-BUDCCE(3)-BUDCCE(4)-BUDCCE(5)-BUDCCE(6)-BUDCCE(7)-BUDCCE(8)-BUDCCE(9)
this.C_BUDINQ(IBUD).UOM    = [F:GAC]UOM
this.C_BUDINQ(IBUD).BUDCTL = [F:BUP]BUDCTL

Case [F:BUP]BUDCTL
 When 2   : # Annual control type
 [L]ASTATUS = func FINPER_SYRA.GET_FIYDATES(this.ACTX, COMPANY, this.C_BUDINQ(IBUD).LEDTYP, FIYSTR,
&                                           this.C_BUDINQ(IBUD).STRDAT, this.C_BUDINQ(IBUD).ENDDAT, ERRMES)
 When 3   : # Period control type
  [L]ASTATUS = func FINPER_SYRA.GET_PERDATES(this.ACTX, COMPANY, this.C_BUDINQ(IBUD).LEDTYP, FIYSTR,
&                                            PERSTR, this.C_BUDINQ(IBUD).STRDAT, this.C_BUDINQ(IBUD).ENDDAT, ERRMES)
 When 4   : # Sliding control typ
  this.C_BUDINQ(IBUD).STRDAT = [F:BUP]VLYSTR
  If [F:BUP]VLYEND<>[0/0/0]
   this.C_BUDINQ(IBUD).ENDDAT = [F:BUP]VLYEND
  Else
   [L]ASTATUS = func FINPER_SYRA.GET_PERDATES(this.ACTX, COMPANY, this.C_BUDINQ(IBUD).LEDTYP, FIYEND,
&                                             PEREND, TMPSTRDAT, this.C_BUDINQ(IBUD).ENDDAT, ERRMES)
  Endif
 When 5   : # Accumulated control type
  this.C_BUDINQ(IBUD).STRDAT = [F:BUP]VLYSTR
  [L]ASTATUS = func FINPER_SYRA.GET_PERDATES(this.ACTX, COMPANY, this.C_BUDINQ(IBUD).LEDTYP, FIYEND,
&                                            PEREND, TMPSTRDAT, this.C_BUDINQ(IBUD).ENDDAT, ERRMES)
Endcase

Return

###################################################################################################
# Scan the balances to calculate the amounts to display when the budget is not linked to a pyramid
###################################################################################################
$CAL_BAL_NOPYM
# Criteria
CRITBLA  = "LEDTYP="+num$(this.C_BUDINQ(IBUD).LEDTYP)+" & CPY='"+COMPANY+"' & FCY='"+BUDFCY+"' & BPR=''"
&       -"& COA='"+COA+"' & ACC='"+ACC+"'"

For I=1 To 9
 If ICCE(I)<>0 : CRITBLA += " & CCE"+num$(ICCE(I))+"='"+LEDBUDCCE(ICCE(I))+"'" : Endif
Next

# Analytical sense of the account
Call LEC_GAC(ACC,COA) From CPTLEC
Call LEC_COA(COA) From CPTLEC
Call LEC_CLS([F:COA]LEGCLS,[F:GAC]CLSCOD) From CPTLEC
If [F:CLS]SNSANA=2 : SIGN = -1 : Else : SIGN = 1 : Endif

 For I=FIYSTR To FIYEND
 # Analytical balance BALANA [BLA]
  Filter [BLA] Where evalue(CRITBLA) & FIY=I
  For [BLA]BLA0
   Case [F:BUP]BUDCTL
    When 2   : # Annual control type
     this.C_BUDINQ(IBUD).AMTREA += SIGN*(sum([F:BLA]DEBLED)-sum([F:BLA]CDTLED)-[F:BLA]DEBLED(0)+[F:BLA]CDTLED(0))
    When 3   : # Period control type
     this.C_BUDINQ(IBUD).AMTREA += SIGN*([F:BLA]DEBLED(PERSTR)-[F:BLA]CDTLED(PERSTR))
    When 4,5 : # Sliding control type, Accumulated control type
     If I=FIYSTR & I=FIYEND
      PER1 = PERSTR
      PER2 = PEREND
     Elsif I=FIYSTR
      PER1 = PERSTR
      PER2 = dim([F:BLA]DEB)-1
     Elsif I=FIYEND
      PER1 = 1
      PER2 = PEREND
     Else
      PER1 = 1
      PER2 = dim([F:BLA]DEB)-1
     Endif
     this.C_BUDINQ(IBUD).AMTREA += SIGN*(sum([F:BLA]DEBLED(PER1..PER2))-sum([F:BLA]CDTLED(PER1..PER2)))
    Endcase
  Next
  Filter [BLA]

# Analytical balance for quantities BLAQTY [BLQ]
  Filter [BLQ] Where evalue(CRITBLA) & FIY=I
  For [BLQ]BLQ0
   Case [F:BUP]BUDCTL
    When 2   : # Annual control type
     this.C_BUDINQ(IBUD).QTYREA    += SIGN*(sum([F:BLQ]QTY)-[F:BLQ]QTY(0))
     this.C_BUDINQ(IBUD).QTYCMM    += SIGN*(sum([F:BLQ]QTYCMM)-[F:BLQ]QTYCMM(0))
     this.C_BUDINQ(IBUD).QTYPRECMM += SIGN*(sum([F:BLQ]QTYPRP)-[F:BLQ]QTYPRP(0))
    When 3   : # Period control type
     this.C_BUDINQ(IBUD).QTYREA    += SIGN*[F:BLQ]QTY(PERSTR)
     this.C_BUDINQ(IBUD).QTYCMM    += SIGN*[F:BLQ]QTYCMM(PERSTR)
     this.C_BUDINQ(IBUD).QTYPRECMM += SIGN*[F:BLQ]QTYPRP(PERSTR)
    When 4,5 : # Sliding control type, Accumulated control type
     If I=FIYSTR & I=FIYEND
      PER1 = PERSTR
      PER2 = PEREND
     Elsif I=FIYSTR
      PER1 = PERSTR
      PER2 = dim([F:BLQ]QTY)-1
     Elsif I=FIYEND
      PER1 = 1
      PER2 = PEREND
     Else
      PER1 = 1
      PER2 = dim([F:BLQ]QTY)-1
     Endif
     this.C_BUDINQ(IBUD).QTYREA   += SIGN*sum([F:BLQ]QTY(PER1..PER2))
     this.C_BUDINQ(IBUD).QTYCMM   += SIGN*sum([F:BLQ]QTYCMM(PER1..PER2))
     this.C_BUDINQ(IBUD).QTPRECMM += SIGN*sum([F:BLQ]QTYPRP(PER1..PER2))
   Endcase
  Next
  Filter [BLQ]

# Analytical balance for commitment BLACMM [BLM]
  Filter [BLM] Where evalue(CRITBLA) & FIY=I
  For [BLM]BLM0
   Case [F:BUP]BUDCTL
    When 2   : # Annual control type
     this.C_BUDINQ(IBUD).AMTCMM    += SIGN*(sum([F:BLM]CMMLED)-[F:BLM]CMMLED(0))
     this.C_BUDINQ(IBUD).AMTPRECMM += SIGN*(sum([F:BLM]CMMPRPLED)-[F:BLM]CMMPRPLED(0))
    When 3   : # Period control type
     this.C_BUDINQ(IBUD).AMTCMM    += SIGN*[F:BLM]CMMLED(PERSTR)
     this.C_BUDINQ(IBUD).AMTPRECMM += SIGN*[F:BLM]CMMPRPLED(PERSTR)
    When 4,5 : # Sliding control type, Accumulated control type
     If I=FIYSTR & I=FIYEND
      PER1 = PERSTR
      PER2 = PEREND
     Elsif I=FIYSTR
      PER1 = PERSTR
      PER2 = dim([F:BLM]CMM)-1
     Elsif I=FIYEND
      PER1 = 1
      PER2 = PEREND
     Else
      PER1 = 1
      PER2 = dim([F:BLM]CMM)-1
     Endif
     this.C_BUDINQ(IBUD).AMTCMM    += SIGN*sum([F:BLM]CMMLED(PER1..PER2))
     this.C_BUDINQ(IBUD).AMTPRECMM += SIGN*sum([F:BLM]CMMPRPLED(PER1..PER2))
   Endcase
  Next
  Filter [BLM]
 Next
Return

###################################################################################################
# Scan the balances to calculate the amounts to display when the budget is linked to a pyramid
###################################################################################################
$CAL_BAL_WITHPYM
# Criteria
CRITBLAPYM1 = "LEDTYP="+num$(this.C_BUDINQ(IBUD).LEDTYP)+" & CPY='"+COMPANY+"' & FCY='"+BUDFCY+"'"
&           -"& COA='"+COA+"' & BPR=''"-"& FIY>="+num$(FIYSTR)-"& FIY<="+num$(FIYEND)
If [F:BUP]PYMACC=""
 CRITBLAPYM1 -= "& ACC='"+[L]ACC+"'"
Endif

CRITBLAPYM2 = '1=1'
CRITBLAPYM3 = '1=1'
CRITBLAPYM4 = '1=1'
For I=1 To 9
 If ICCE(I)<>0
   If [F:BUP]PYMCCE(I-1)<>""
     Case ICCE(I)
      When 1 : CRITBLAPYM2 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE1,TCCE1(I2))<>0)'
      When 2 : CRITBLAPYM2 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE2,TCCE2(I3))<>0)'
      When 3 : CRITBLAPYM2 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE3,TCCE3(I4))<>0)'
      When 4 : CRITBLAPYM2 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE4,TCCE4(I5))<>0)'
      When 5 : CRITBLAPYM3 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE5,TCCE5(I6))<>0)'
      When 6 : CRITBLAPYM3 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE6,TCCE6(I7))<>0)'
      When 7 : CRITBLAPYM3 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE7,TCCE7(I8))<>0)'
      When 8 : CRITBLAPYM3 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE8,TCCE8(I9))<>0)'
      When 9 : CRITBLAPYM4 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE9,TCCE9(I10))<>0)'
     Endcase
   Else
    Case ICCE(I)
     When 1       : CRITBLAPYM2 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE1,LEDBUDCCE(1))<>0)'
     When 2,3,4   : CRITBLAPYM2 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE'+num$(ICCE(I))+',LEDBUDCCE('+num$(ICCE(I))+'))<>0)'
     When 5,6,7,8 : CRITBLAPYM3 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE'+num$(ICCE(I))+',LEDBUDCCE('+num$(ICCE(I))+'))<>0)'
     When 9       : CRITBLAPYM4 -='& ([F:BUP]DIE('+num$(I-1)+')="" | pat(CCE'+num$(ICCE(I))+',LEDBUDCCE('+num$(ICCE(I))+'))<>0)'
    Endcase
   Endif
 Endif
Next

# Calculation
For I1=1 To NBACC
 # Search the analytical sense of the account
 Gosub SEARCH_SIGN
 For I2=1 To NBCCE(1)
  For I3=1 To NBCCE(2)
   For I4=1 To NBCCE(3)
    For I5=1 To NBCCE(4)
     For I6=1 To NBCCE(5)
      For I7=1 To NBCCE(6)
       For I8=1 To NBCCE(7)
        For I9=1 To NBCCE(8)
         For I10=1 To NBCCE(9)
# ANALYTICAL BALANCE BALANA [BLA]
          For [BLA]BLA0 Where evalue(CRITBLAPYM1) & pat(ACC,TACC(I1))<>0 & evalue(CRITBLAPYM2) & evalue(CRITBLAPYM3)
&&                      evalue(CRITBLAPYM4)
           Case [F:BUP]BUDCTL
            When 2   : # Annual control type
             this.C_BUDINQ(IBUD).AMTREA += SIGN*(sum([F:BLA]DEBLED)-sum([F:BLA]CDTLED)-[F:BLA]DEBLED(0)+[F:BLA]CDTLED(0))
            When 3   : # Period control type
             this.C_BUDINQ(IBUD).AMTREA += SIGN*(sum([F:BLA]DEBLED(PERSTR)-[F:BLA]CDTLED(PERSTR)))
            When 4,5 : # Sliding control type, Accumulated control type
             If [F:BLA]FIY=FIYSTR & [F:BLA]FIY=FIYEND
              PER1 = PERSTR
              PER2 = PEREND
             Elsif [F:BLA]FIY=FIYSTR
              PER1 = PERSTR
              PER2 = dim([F:BLA]CDT)-1
             Elsif [F:BLA]FIY=FIYEND
              PER1 = 1
              PER2 = PEREND
             Else
              PER1 = 1
              PER2 = dim([F:BLA]CDT)-1
             Endif
             this.C_BUDINQ(IBUD).AMTREA += SIGN*(sum([F:BLA]DEBLED(PER1..PER2))-sum([F:BLA]CDTLED(PER1..PER2)))
           Endcase
          Next

# Analytical balance for commitment BLACMM [BLM]
          For [BLM]BLM0 Where evalue(CRITBLAPYM1) & pat(ACC,TACC(I1))<>0 & evalue(CRITBLAPYM2) & evalue(CRITBLAPYM3)
&&                      evalue(CRITBLAPYM4)
           Case [F:BUP]BUDCTL
            When 2   : # Annual control type
             this.C_BUDINQ(IBUD).AMTCMM    += SIGN*(sum([F:BLM]CMMLED)-[F:BLM]CMMLED(0))
             this.C_BUDINQ(IBUD).AMTPRECMM += SIGN*(sum([F:BLM]CMMPRPLED)-[F:BLM]CMMPRPLED(0))
            When 3   : # Period control type
             this.C_BUDINQ(IBUD).AMTCMM    += SIGN*[F:BLM]CMMLED(PERSTR)
             this.C_BUDINQ(IBUD).AMTPRECMM += SIGN*[F:BLM]CMMPRPLED(PERSTR)
            When 4,5 : # Sliding control type, Accumulated control type
             If [F:BLM]FIY=FIYSTR & [F:BLM]FIY=FIYSTR
              PER1 = PERSTR
              PER2 = PERSTR
             Elsif [F:BLM]FIY=FIYSTR
              PER1 = PERSTR
              PER2 = dim([F:BLM]CMM)-1
             Elsif [F:BLM]FIY=FIYEND
              PER1 = 1
              PER2 = PEREND
             Else
              PER1 = 1
              PER2 = dim([F:BLM]CMM)-1
             Endif
             this.C_BUDINQ(IBUD).AMTCMM    += SIGN*sum([F:BLM]CMMLED(PER1..PER2))
             this.C_BUDINQ(IBUD).AMTPRECMM += SIGN*sum([F:BLM]CMMPRPLED(PER1..PER2))
           Endcase
          Next
# Analytical balance for quantities BLAQTY [BLQ]
          For [BLQ]BLQ0 Where evalue(CRITBLAPYM1) & pat(ACC,TACC(I1))<>0 & evalue(CRITBLAPYM2) & evalue(CRITBLAPYM3)
&&                      evalue(CRITBLAPYM4)
           Case [F:BUP]BUDCTL
            When 2 : # Annual control type
             this.C_BUDINQ(IBUD).QTYREA    += SIGN*(sum([F:BLQ]QTY)-[F:BLQ]QTY(0))
             this.C_BUDINQ(IBUD).QTYCMM    += SIGN*(sum([F:BLQ]QTYCMM)-[F:BLQ]QTYCMM(0))
             this.C_BUDINQ(IBUD).QTYPRECMM += SIGN*(sum([F:BLQ]QTYPRP)-[F:BLQ]QTYPRP(0))
            When 3   : # Period control type
             this.C_BUDINQ(IBUD).QTYREA    += SIGN*sum([F:BLQ]QTY(PERSTR))
             this.C_BUDINQ(IBUD).QTYCMM    += SIGN*sum([F:BLQ]QTYCMM(PERSTR))
             this.C_BUDINQ(IBUD).QTYPRECMM += SIGN*sum([F:BLQ]QTYPRP(PERSTR))
            When 4,5 : # Sliding control type, Accumulated control type
             If [F:BLQ]FIY=FIYSTR & [F:BLQ]FIY=FIYEND
              PER1 = PERSTR
              PER2 = PEREND
             Elsif [F:BLQ]FIY=FIYSTR
              PER1 = PERSTR
              PER2 = dim([F:BLQ]QTY)-1
             Elsif [F:BLQ]FIY=FIYEND
              PER1 = 1
              PER2 = PEREND
             Else
              PER1 = 1
              PER2 = dim([F:BLQ]QTY)-1
             Endif
             this.C_BUDINQ(IBUD).QTYREA    += SIGN*sum([F:BLQ]QTY(PER1..PER2))
             this.C_BUDINQ(IBUD).QTYCMM    += SIGN*sum([F:BLQ]QTYCMM(PER1..PER2))
             this.C_BUDINQ(IBUD).QTYPRECMM += SIGN*sum([F:BLQ]QTYPRP(PER1..PER2))
           Endcase
          Next
         Next
        Next
       Next
      Next
     Next
    Next
   Next
  Next
 Next
Next
Return

$SEARCH_SIGN
If [F:BUP]PYMACC=""
 Call LEC_GAC(TACC(I1),COA) From CPTLEC
 Call LEC_COA([F:GAC]COA) From CPTLEC
 Call LEC_CLS([F:COA]LEGCLS,[F:GAC]CLSCOD) From CPTLEC
 If [F:CLS]SNSANA=2 : SIGN = -1 : Else : SIGN = 1 : Endif
Else
 Raz [F:GRY]
 For [GRY] Where PYM=[F:BUP]PYMACC and pat(TACC(I1),ACC)<>0
  Break
 Next
 If [F:GRY]COA<>""
  Call LEC_COA([F:GRY]COA) From CPTLEC
  Call LEC_CLS([F:COA]LEGCLS,[F:GRY]CLSCOD) From CPTLEC
  If [F:CLS]SNSANA=2 : SIGN = -1 : Else : SIGN = 1 : Endif
 Else
  SIGN = -1
 Endif
Endif
Return

