#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CNE1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:12"
A_USER  = "DOC"
A_STAMP = "20181109230312"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CNE1 [CNE1]
Gosub HORODAT
Local Inpbox "CNE1" From GFONCTION At A_STAMP With A_WINDPREV Mask [CNE1] As [SIM_]
Grizo [CNE1]10
Grizo [CNE1]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CNE1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=131 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=131 : Y1(1)=3 : Y2(1)=28
Return

$ON_YEA
Onevent CONTROL Call C_YEA(zc) From W1CNE1
Return

Subprog C_YEA(VALEUR)
Variable Decimal VALEUR
## Action STD
Call C_YEA(VALEUR) From SUBCNE
If mkstat : GERR = 1 : GZONE = "YEA" : GZNUM = 1879 : Endif
Gosub _AFF
End

$ON_REFNUM
Onevent CONTROL Call C_REFNUM(zc) From W1CNE1
Onevent AFTER_CHANGE Gosub AMM_REFNUM From W1CNE1
Onevent BEFORE_INPUT Call AS_REFNUM(zc) From W1CNE1
Return

Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44843,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_REFNUM(zc) From W1CNE1
Onkey   2 Titled GBOUTS Call S_REFNUM(zc) From W1CNE1
Onkey 144 Titled GBOUTP Call P_REFNUM(zc) From W1CNE1
Onkey 146 Titled GBOUTA Call SA_REFNUM(zc) From W1CNE1
Gosub _AFF
End

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTEMP
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTEMP"
  PARMSK(1) = ""
  PARMSK(2) = ""
  PARMSK(3) = ""
  PARMSK(4) = ""
  PARMSK(5) = "2"
  PARMSK(6) = GCURLEG
  Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Endif
Endif
If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","","") From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("EML","T",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_REFNUM
Call AM_REFNUM(zc)
If !mkstat & GOBJET
 zoncou = "REFNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_REFNUM(VALEUR) From SUBCNE
If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZREFNUM)")>indice
 [M]REFNUM(indice) = VALEUR
 Affzo ZREFNUM(indice)
Endif
Gosub _AFF
End

Subprog S_REFNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMP"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = "2"
 PARMSK(6) = GCURLEG
 PARMSK(7) = ""
 PARMSK(8) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELEMP","SELMAT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_REFNUM(VALEUR)
Variable Char    VALEUR()
Call OBJET("EML",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EML"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EML",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZREFNUM
Onevent BEFORE_AREA Gosub AV_ZREFNUM From W1CNE1
Return

$AV_ZREFNUM
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Call LECTURE("EML",num$([M]REFNUM(indice)),"") From CONTOBJ
zc = [F:ID]NAM
Gosub _AFF
Return

$ON_CTRNUM
Onevent CONTROL Call C_CTRNUM(zc) From W1CNE1
Onevent BEFORE_INPUT Call AS_CTRNUM(zc) From W1CNE1
Return

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CTRNUM(zc) From W1CNE1
Onkey 144 Titled GBOUTP Call P_CTRNUM(zc) From W1CNE1
Onkey 146 Titled GBOUTA Call SA_CTRNUM(zc) From W1CNE1
Gosub _AFF
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
If !mkstat
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
 If !GWEBSERV
  If !mkstat
   ## Action CONTCTR
   Call CONTCTR(VALEUR,[M]REFNUM) From DIVPAYE
   If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
  Endif
 Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CTR","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
 If !mkstat
  ## Action STD
  Call C_CTRNUM(VALEUR) From SUBCNE
  If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_CTRNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCTREMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCTREMP"
 PARMSK(1) = [M]REFNUM
 PARMSK(2) = [0/0/0]
 Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CTR"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CTR",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1CNE1
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"","") From SUBADI
Endif
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1CNE1
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1CNE1
Return

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBLIG From SUBCNE
Gosub _AFF
End

$ON_TIM
Onevent CONTROL Call C_TIM(zc) From W1CNE1
Onevent AFTER_CHANGE Gosub AMM_TIM From W1CNE1
Onevent BEFORE_INPUT Call AS_TIM(zc) From W1CNE1
Return

Subprog AS_TIM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(47937,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_TIM(zc) From W1CNE1
Onkey   2 Titled GBOUTS Call S_TIM(zc) From W1CNE1
Onkey 144 Titled GBOUTP Call P_TIM(zc) From W1CNE1
Onkey 146 Titled GBOUTA Call SA_TIM(zc) From W1CNE1
Gosub _AFF
End

Subprog C_TIM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTHRTIM
 Call CONTHRTIM(VALEUR) From SUBHRTIM
 If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
  If !mkstat
   ## Action STD
   Call C_TIM(VALEUR) From SUBCNE
   If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_TIM
Call AM_TIM(zc)
If !mkstat & GOBJET
 zoncou = "TIM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TIM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_TIM(VALEUR) From SUBCNE
If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZTIM)")>indice
 [M]TIM(indice) = VALEUR
 Affzo ZTIM(indice)
Endif
Gosub _AFF
End

Subprog S_TIM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRTIM
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRTIM"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRTIM","SUBHRTIM","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_TIM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRTIM
 Call TUNHRTIM(VALEUR) From SUBHRTIM
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_TIM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRTIM"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TIM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("HRTIM",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZTIM
Onevent BEFORE_AREA Gosub AV_ZTIM From W1CNE1
Return

$AV_ZTIM
Call LECTEXTRA(zc,"TIMCOD","DES",num$(GCURLEG),num$([M]TIM(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_NBRDAY
Onevent AFTER_CHANGE Gosub AMM_NBRDAY From W1CNE1
Onevent CONTROL Call C_NBRDAY(zc) From W1CNE1
Return

Subprog C_NBRDAY(VALEUR)
Variable Decimal VALEUR
Gosub _AFF
End

$AMM_NBRDAY
Call AM_NBRDAY(zc)
If !mkstat & GOBJET
 zoncou = "NBRDAY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NBRDAY(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_NBRDAY(VALEUR) From SUBCNE
If mkstat : GERR = 1 : GZONE = "NBRDAY" : GZNUM = 47292 : Endif
Gosub _AFF
End

$ON_NBRPRI
Onevent BEFORE_INPUT Call AS_NBRPRI(zc) From W1CNE1
Onevent AFTER_CHANGE Gosub AMM_NBRPRI From W1CNE1
Return

Subprog AS_NBRPRI(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBRPRI(VALEUR) From SUBCNE
If mkstat=2
 [M]NBRPRI(INDIC) = VALEUR
 Affzo NBRPRI(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$AMM_NBRPRI
Call AM_NBRPRI(zc)
If !mkstat & GOBJET
 zoncou = "NBRPRI" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NBRPRI(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_NBRPRI(VALEUR) From SUBCNE
If mkstat : GERR = 1 : GZONE = "NBRPRI" : GZNUM = 35162 : Endif
Gosub _AFF
End

$CHG_STY
Return


