#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# EMHRMAJ90_ACTION UTI process                                  PAY Module
#                  Migration To U12 - Vnext version
#
# ==>  Update Field Actions and Parameters on custom fields
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Payroll Module
  If [F:ADS]MODULE(14)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update Field Actions and Parameters on custom fields") From LECFIC

  Call MAJ_EMHRMAJ90_ACTION(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif

Close Local File
End

Subprog MAJ_EMHRMAJ90_ACTION(LDOSSIER)
Value Char LDOSSIER
Local Char DOSLEGMIG(5)

#  Onerrgo CYCLECHECKERROR

  Call ECR_TRACE("EMHRMAJ90_ACTION: Update Field Actions and Parameters on custom fields",0) From GESECRAN
  Call ECR_TRACE("EMHRMAJ90_ACTION: Start of process on : "+LDOSSIER,0) From GESECRAN

  Gosub PROCESS_ACTION_U9_RECORDS

  Call ECR_TRACE("EMHRMAJ90_ACTION : End of process on : "+LDOSSIER,0) From GESECRAN

End

$CYCLECHECKERROR
  Call ECR_TRACE("Error in EMHRMAJ90_ACTION: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN
  UPD_OK = 1
Resume

$PROCESS_ACTION_U9_RECORDS

  Local Char LDOSSIER(250) : LDOSSIER=nomap
  If clalev([F:HRAMA]) = 0 : Local File =LDOSSIER+".AMSKACT" [HRAMA] : Endif
  If clalev([F:HRAMP]) = 0 : Local File =LDOSSIER+".AMSKPAR" [HRAMP] : Endif
  If clalev([F:HRAMZ]) = 0 : Local File =LDOSSIER+".AMSKZON" [HRAMZ] : Endif
  If clalev([F:HRATR]) = 0 : Local File =LDOSSIER+".ACTPAR"  [HRATR] : Endif
  If clalev([F:AMA12]) = 0 : Local File ="PAIE.AMSKACT" [AMA12] : Endif
  If clalev([F:AMP12]) = 0 : Local File ="PAIE.AMSKPAR" [AMP12] : Endif
  If clalev([F:ATR12]) = 0 : Local File ="PAIE.ACTPAR"  [ATR12] : Endif
  Local Integer DELETED_ROWS

  For [F:HRAMZ] Where ([F:HRAMZ]CODACT<>"" & (left$([F:HRAMZ]CODACT,1)="Y" | left$([F:HRAMZ]CODACT,1)="X"))
    Delete [F:HRAMA] Where [F:HRAMA]CODAFF=[F:HRAMZ]CODMSK & [F:HRAMA]CODZON=[F:HRAMZ]CODZON & !find([F:HRAMA]ACTION,"SPE","SPV")
    DELETED_ROWS = adxdlrec
    Call ECR_TRACE("DELETED for screen:"-[F:HRAMZ]CODMSK-", and field:"-[F:HRAMZ]CODZON-", rows:"-num$(DELETED_ROWS),0) From GESECRAN
    For [F:AMA12] Where [F:AMA12]CODAFF=[F:HRAMZ]CODMSK & [F:AMA12]CODZON=[F:HRAMZ]CODZON & !find([F:AMA12]ACTION,"SPE","SPV")
      Raz [F:HRAMA]
      [F:HRAMA] = [F:AMA12]
      Write [F:HRAMA]
      If !fstat
        Call ECR_TRACE("Successfully written ACTION Type:"-[F:HRAMA]ACTION-"for screen:"-[F:HRAMA]CODAFF-", and field:"-[F:HRAMA]CODZON,0) From GESECRAN
        For [F:AMP12] Where [F:AMP12]CODAFF=[F:HRAMA]CODAFF & [F:AMP12]CODZON=[F:HRAMA]CODZON
          Read [F:HRAMP]CODPAR=[F:AMP12]TYPAFF;[F:AMP12]CODAFF;[F:AMP12]CODZON;[F:AMP12]CODPAR
          If fstat
            Raz [F:HRAMP]
            [F:HRAMP] = [F:AMP12]
            Write [F:HRAMP]
            If !fstat
              Call ECR_TRACE("Successfully written AMSKPAR for screen:"-[F:HRAMP]CODAFF-", and field:"-[F:HRAMP]CODZON-", param:"-[F:HRAMP]CODPAR-", VALPAR:"-[F:HRAMP]VALPAR,0) From GESECRAN
            Else
              Call ECR_TRACE("Could not write to AMSKPAR for screen:"-[F:HRAMP]CODAFF-", and field:"-[F:HRAMP]CODZON-", param:"-[F:HRAMP]CODPAR-", VALPAR:"-[F:HRAMP]VALPAR,0) From GESECRAN
            Endif
          Else
            [F:HRAMP]VALPAR = [F:AMP12]VALPAR
            Rewrite [F:HRAMP]
            If !fstat
              Call ECR_TRACE("Successfully rewrote AMSKPAR for screen:"-[F:HRAMP]CODAFF-", and field:"-[F:HRAMP]CODZON-", param:"-[F:HRAMP]CODPAR-", VALPAR:"-[F:HRAMP]VALPAR,0) From GESECRAN
            Else
              Call ECR_TRACE("Could not rewrite to AMSKPAR for screen:"-[F:HRAMP]CODAFF-", and field:"-[F:HRAMP]CODZON-", param:"-[F:HRAMP]CODPAR-", VALPAR:"-[F:HRAMP]VALPAR,0) From GESECRAN
            Endif
          Endif
#          For [F:ATR12] Where [F:ATR12]ACTION=[F:AMA12]ACTION & [F:ATR12]CODPAR=[F:AMP12]CODPAR
#            Raz [F:HRATR]
#            [F:HRATR] = [F:ATR12]
#            Write [F:HRATR]
#            If !fstat
#              Call ECR_TRACE("Successfully written ACTPAR for ACTION:"-[F:HRATR]ACTION-", and CODPAR:"-[F:HRATR]CODPAR,0) From GESECRAN
#            Else
#              Call ECR_TRACE("Could not write to ACTPAR for ACTION:"-[F:HRATR]ACTION-", and CODPAR:"-[F:HRATR]CODPAR,0) From GESECRAN
#            Endif
#          Next
        Next
      Else
        Call ECR_TRACE("Could not write ACTION Type:"-[F:HRAMA]ACTION-"for screen:"-[F:HRAMA]CODAFF-", and field:"-[F:HRAMA]CODZON,0) From GESECRAN
      Endif
    Next
  Next

  Close File [F:HRAMA], [F:HRAMP], [F:HRAMZ], [F:AMA12]
Return


########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 : End : Endif
  If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
  If [F:ADS]MODULE(14)<>2 : End : Endif
  Call MAJ_EMHRMAJ90_ACTION(APPLI)

End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3: End : Endif
  If [F:ADS]MODULE(14)<>2 : End : Endif
  Call MAJ_EMHRMAJ90_ACTION(APPLI)

End

