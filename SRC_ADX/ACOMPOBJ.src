    Endif
    If left$([M:ACMP]ACLADEB,1)<>"W" & left$([M:ACMP]ACLAFIN,1)<>"W"
     CRITERE += "& left$(CODCLA,1)<>'W'"
    Endif
    For [F:ACLA1] Where evalue(CRITERE)
        If [M:ACMP]COPMOD(max([F:ACLA1]MODULE-1,0)) = 2
            FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
            Gosub FILTRE_ACLA From ACOMPOBJ3    #X3PLAT-940 - Filter on activity code
            If !OK Goto NEXT_ACLA: Endif        #X3PLAT-940 - Filter on activity code
            NB_ACLA+=1                          #X3PLAT-940 - Filter on activity code
        Endif
    $NEXT_ACLA                                  #X3PLAT-940 - Filter on activity code
    Next
#X3PLAT-940 - Filter on activity code
#   Close Local File [ACLA1]
    Gosub CLOSE_ACLA
#X3PLAT-940 - Filter on activity code
