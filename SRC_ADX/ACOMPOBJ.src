Local Char        ZON(GLONAVA)(2,1..250), INTZON(30)(2,1..250), TYP(15)(2,1..250)
Gosub OPEN_ACT
Gosub COMP_ACT From ACOMPOBJ3    #X3PLAT-940 - move to ACOMPOBJ3 (ACOMPOBJ2) script to large)
Gosub CLOSE_ACT
End

#####################################
