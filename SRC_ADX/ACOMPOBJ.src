Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
GMODIF = 0
End

Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
Gosub GRISE_AMK
Gosub GRISE_AWI
Gosub GRISE_AOB
Gosub GRISE_AOC
Gosub GRISE_AFC
Gosub GRISE_ACT
Gosub GRISE_ATY
Gosub GRISE_ATB
Gosub GRISE_ARP
Gosub GRISE_ADI
Gosub GRISE_AST
Gosub GRISE_ACN
Gosub GRISE_ADC
Gosub GRISE_FORMAT
Gosub GRISE_AOE
Gosub GRISE_AEV
Gosub GRISE_ACLA
Gosub GRISE_ASW
Gosub GRISE_ACV         # RBU
Setmok [M] With 0
If !GMODIF : mkstat = 2 : Endif
GMODIF = 1
End

Subprog AS_DOSDES(VALEUR)
Variable Char     VALEUR
If GDOSPATH="" : End : Endif
Call C_DOSSIER(GDOSPATH) From DOSCONT
If mkstat
 mkstat = 0
Else
 VALEUR = GDOSPATH
Endif
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call DOSORGDES([M]DOSORG,VALEUR) From DOSCONT
If mkstat : End : Endif
GDOSPATH = VALEUR
End

Subprog C_AMKFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If VALEUR<[M:ACMP]AMKDEB
    GMESSAGE =mess(83,123,1)           # valeur incorrecte
    mkstat=2
Endif
End

