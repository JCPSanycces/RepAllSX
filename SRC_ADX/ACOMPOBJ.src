#X3PLAT-940 - Filter on activity code
    CRITERE = "1=1"
    If [M:ACMP]ACLADEB="" & [M:ACMP]ACLAFIN="ZZZZZZZZZZ"
     If GADONIX=2
      CRITERE += "& CODCLA<'X'"
