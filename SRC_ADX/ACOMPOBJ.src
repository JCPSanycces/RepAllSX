 Local File =[M]DOSORG+".ACTIV"     [ACV1]
Endif
If [M]DOSDES=nomap
 Local File ACTIV     [ACV2]
Else
 Local File =[M]DOSDES+".ACTIV"     [ACV2]
Endif
Return

#############################
$CLOSE_ACV
Close Local File [ACV1], [ACV2]
Return
#X3PLAT-941 - add activity code comparison - RBU


#########################################################
Subprog COMPDOS(FORMAT)
Value Integer FORMAT
If clalev([F:ADS])=0 : End : Endif
Local Mask ACOMPOBJ [ACMP]
Raz [M:ACMP]
[M:ACMP]DOSORG = nomap
[M:ACMP]DOSDES = [F:ADS]DOSSIER
[M:ACMP]LANGUE = GLANGUE
[M:ACMP]FICHIER = 2
[M:ACMP]FORMAT = FORMAT
[M:ACMP]DETAIL = 2
[M:ACMP]AMK = 2
[M:ACMP]AWI = 2
[M:ACMP]AOB = 2
[M:ACMP]AOC = 2
[M:ACMP]AFC = 2
[M:ACMP]ACT = 2
[M:ACMP]ATY = 2
[M:ACMP]ATB = 2
[M:ACMP]ADI = 2
[M:ACMP]AST = 2
[M:ACMP]ARP = 2
[M:ACMP]ACN = 2
[M:ACMP]ACLA = 2
[M:ACMP]ASW = 2
[M:ACMP]ADC = 2
Gosub INIT_MOD
Gosub INIT_AV
If GINFO
 Call AFF_VLC(mess(81,126,1)-[M:ACMP]DOSORG-"=>"-[M:ACMP]DOSDES,"") From GESECRAN : # Différence
Endif
Gosub TRT_COMPTE
Call COMPARAISON(NB_AMK,NB_AWI,NB_AOB,NB_AOC,NB_AFC,NB_ACT,NB_ATY,NB_ATB,NB_ADI,NB_AST,NB_ARP,NB_ACN,NB_ADC,NB_AOE,NB_AEV,NB_ACLA,NB_ASW,NB_ACV)
Close Local Mask [ACMP]
End

####################################################################
Subprog COMPARAISON_SOLO(ABREV,VAL_OBJ,TRACE,DET,DOSORG,DOSDES,STAT)
####################################################################
Value Char    ABREV,VAL_OBJ
Value Integer TRACE
Value Integer DET
Value Char    DOSORG,DOSDES
Variable Integer STAT
Local Integer I,NB,PATCH,EXCEL
Local Char    CRITERE(250),OGTRACE(GDIMFIC)
Local File    ADOSSIER [ADS]
Local Mask    ACOMPOBJ [ACMP]
Raz [M:ACMP]
[M:ACMP]DOSORG = DOSORG
[M:ACMP]DOSDES = DOSDES
Case ABREV
 When "AMK"       :  [M:ACMP]AMK = 2 : [M:ACMP]AMKDEB = VAL_OBJ      : [M:ACMP]AMKFIN = VAL_OBJ
 When "AWI"       :  [M:ACMP]AWI = 2 : [M:ACMP]AWIDEB = VAL_OBJ      : [M:ACMP]AWIFIN = VAL_OBJ
 When "AOB"       :  [M:ACMP]AOB = 2 : [M:ACMP]AOBDEB = VAL_OBJ      : [M:ACMP]AOBFIN = VAL_OBJ
 When "AOC"       :  [M:ACMP]AOC = 2 : [M:ACMP]AOCDEB = VAL_OBJ      : [M:ACMP]AOCFIN = VAL_OBJ
 When "AFC"       :  [M:ACMP]AFC = 2 : [M:ACMP]AFCDEB = VAL_OBJ      : [M:ACMP]AFCFIN = VAL_OBJ
 When "ACT"       :  [M:ACMP]ACT = 2 : [M:ACMP]ACTDEB = VAL_OBJ      : [M:ACMP]ACTFIN = VAL_OBJ
 When "ATY"       :  [M:ACMP]ATY = 2 : [M:ACMP]ATYDEB = VAL_OBJ      : [M:ACMP]ATYFIN = VAL_OBJ
 When "ATB"       :  [M:ACMP]ATB = 2 : [M:ACMP]ATBDEB = VAL_OBJ      : [M:ACMP]ATBFIN = VAL_OBJ
 When "ADI"       :  [M:ACMP]ADI = 2 : [M:ACMP]ADIDEB = val(VAL_OBJ) : [M:ACMP]ADIFIN = val(VAL_OBJ)
 When "AST","AML" :  [M:ACMP]AST = 2 : [M:ACMP]ASTDEB = val(VAL_OBJ) : [M:ACMP]ASTFIN = val(VAL_OBJ)
                     [M:ACMP]LANGUE = GLANGUE
 When "ARP"       :  [M:ACMP]ARP = 2 : [M:ACMP]ARPDEB = VAL_OBJ      : [M:ACMP]ARPFIN = VAL_OBJ
 When "ACN"       :  [M:ACMP]ACN = 2 : [M:ACMP]ACNDEB = VAL_OBJ      : [M:ACMP]ACNFIN = VAL_OBJ
                     [M:ACMP]LANGUE = GLANGUE
 When "TRT"       :  [M:ACMP]ADC = 2 : [M:ACMP]ADCDEB = VAL_OBJ      : [M:ACMP]ADCFIN = VAL_OBJ
 When "AOE"       :  [M:ACMP]AOE = 2 : [M:ACMP]AOEDEB = VAL_OBJ      : [M:ACMP]AOEFIN = VAL_OBJ
 When "AEV"       :  [M:ACMP]AEV = 2 : [M:ACMP]AEVDEB = VAL_OBJ      : [M:ACMP]AEVFIN = VAL_OBJ
 When "ACLA"       :  [M:ACMP]ACLA = 2 : [M:ACMP]ACLADEB = VAL_OBJ      : [M:ACMP]ACLAFIN = VAL_OBJ
 When "ASW"       :  [M:ACMP]ASW = 2 : [M:ACMP]ASWDEB = VAL_OBJ      : [M:ACMP]ASWFIN = VAL_OBJ
 When "ACV"       :  [M:ACMP]ACV = 2 : [M:ACMP]ACVDEB = VAL_OBJ      : [M:ACMP]ACVFIN = VAL_OBJ   #RBU
Endcase
[M:ACMP]NBMOD = len(mess(0,14,1))
For I = 0 To [M:ACMP]NBMOD-1
 [M:ACMP]COPMOD(I) = 2
Next I
If [L]DET
 [M:ACMP]DETAIL = 2
 [M:ACMP]TECHNI = 2
Else
 [M:ACMP]DETAIL = 1
 [M:ACMP]TECHNI = 1
Endif
Raz PATCH , EXCEL
Gosub OUVFIC

If TRACE>0
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE(mess(81,126,1)-[M:ACMP]DOSORG-"=>"-[M:ACMP]DOSDES) From LECFIC   # Différence
Elsif TRACE=-1
 OGTRACE = GTRACE
 GTRACE = ""
Endif

NB = 1
Case ABREV
 When "AMK"       :  Call TRT_ECRAN(NB,STAT,PATCH,EXCEL)               # Ecran
 When "AWI"       :  Call TRT_FENETRE(NB,STAT,PATCH,EXCEL)             # Fenêtre
 When "AOB"       :  Call TRT_OBJET(NB,STAT,PATCH,EXCEL)               # Objet
 When "AOC"       :  Call TRT_PERSOBJ(NB,STAT,PATCH,EXCEL)             # Personnalisation d'objet
 When "AFC"       :  Call TRT_FONCTION(NB,STAT,PATCH,EXCEL)            # Fonction
 When "ACT"       :  Call TRT_ACTION(NB,STAT,PATCH,EXCEL)              # Action
 When "ATY"       :  Call TRT_TYPE(NB,STAT,PATCH,EXCEL)                # Type
 When "ATB"       :  Call TRT_TABLE(NB,STAT,PATCH,EXCEL)               # Table
 When "ADI"       :  Call TRT_TABDIV(NB,STAT,PATCH,EXCEL)              # Table diverse
 When "AST","AML" :  Call TRT_MESSAGE(NB,STAT,PATCH,EXCEL)             # Message
 When "ARP"       :  Call TRT_REPORT(NB,STAT,PATCH,EXCEL)              # Etat
 When "ACN"       :  Call TRT_CONSULT(NB,STAT,PATCH,EXCEL)             # Consultation
 When "TRT"       :  Call TRT_TRAIT(NB,STAT,PATCH,EXCEL,TRACE)         # Traitement
 When "AOE"       :  Call TRT_MODELE(NB,STAT,PATCH,EXCEL)              # Modele
 When "AEV"       :  Call TRT_TABIMP(NB,STAT,PATCH,EXCEL)              # Modele
 When "ACLA"       :  Call TRT_CLASSE(NB,STAT,PATCH,EXCEL)              # Classes
 When "ASW"       :  Call TRT_REPRESENTATION(NB,STAT,PATCH,EXCEL)              # Représentation
 When "ACV"       :  Call TRT_ACTIV(NB,STAT,PATCH,EXCEL)              # Actovoty code = RBU
 When Default     :  Call ECR_TRACE(mess(61,139,1),1) From GESECRAN    # Objet non géré
Endcase

If TRACE>0
 Call FERME_TRACE From LECFIC
 Call TEMPOFF From GESECRAN
 Call SUPP_TRACE From LECFIC
Elsif TRACE=-1
 GTRACE = OGTRACE
Endif
End

#############################
$TRT_COMPTE
#############################
If !GINFO
 Call TEMPON("O") From GESECRAN
Endif

Local Integer  INTERM, NB_AMK, NB_AWI, NB_AOB, NB_AOC, NB_AFC, NB_ACT, NB_ATY, NB_ATB, NB_ADI, NB_AST
Local Integer  NB_ARP, NB_ACN , NB_ADC , NB_AOE , NB_AEV , NB_ACLA, NB_ASW,NB_ACV   #120382 - X3PLAT-940 - Filter on activity code
Local Char     MSG(250) , CRITERE(250)
Local Clbfile  CLOB(1)
Local Integer  I , OK
Local Integer  FILTRE_STEP                      #X3PLAT-940 - Filter on activity code
## Calcul du nombre d'écrans à comparer
Raz NB_AMK
If [M]AMK = 2
#X3PLAT-940 - Filter on activity code
#    If [M]DOSORG=nomap
#        Local File AMSK    [AMK1]
#    Else
#        Local File =[M]DOSORG+".AMSK"    [AMK1]
#    Endif
    Gosub OPEN_AMK
#X3PLAT-940 - Filter on activity code
    CRITERE = "1=1"
    If [M:ACMP]AMKDEB="" & [M:ACMP]AMKFIN="ZZZZZZZZZZ"
     If GADONIX=2
      CRITERE += "& CODMSK<'X'"
     Endif
    Else
     CRITERE += "& CODMSK>=[M:ACMP]AMKDEB & CODMSK<=[M:ACMP]AMKFIN"
    Endif
    If left$([M:ACMP]AMKDEB,1)<>"W" & left$([M:ACMP]AMKFIN,1)<>"W"
     CRITERE += "& left$(CODMSK,1)<>'W'"
    Endif
    For [F:AMK1]CODMSK Where evalue(CRITERE)
        If [M:ACMP]COPMOD(max([F:AMK1]MODULE-1,0)) = 2
            FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
            Gosub FILTRE_AMK From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
            If !OK Goto NEXT_AMK: Endif         #X3PLAT-940 - Filter on activity code
            NB_AMK +=1
        Endif
    $NEXT_AMK                                   #X3PLAT-940 - Filter on activity code
    Next
#X3PLAT-940 - Filter on activity code
#   Close Local File [AMK1]
    Gosub CLOSE_AMK
#X3PLAT-940 - Filter on activity code
Endif

Local Integer  I , OK

## Calcul du nombre de classe
Raz NB_ACLA
If [M]ACLA = 2
#X3PLAT-940 - Filter on activity code
#    If [M]DOSORG=nomap
#        Local File ACLASSE    [ACLA1]
#    Else
#        Local File =[M]DOSORG+".ACLASSE"    [ACLA1]
#    Endif
