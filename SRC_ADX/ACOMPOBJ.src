## déclaration pour la table ATABZON (mémorisation des champs à comparer)
Local Integer       DIMZON(1,1..250),NBRZON
Local Char          ZON(GLONAVA)(1,1..250), INTZON(30)(1,1..250), TYP(15)(1,1..250)
Gosub OPEN_ADI
Gosub COMP_ADI From ACOMPOBJ2
Gosub CLOSE_ADI
End

########################################
Subprog TRT_MESSAGE(NB_AST,DIF,PATCH,EXCEL)
Value Integer  NB_AST
Variable Integer  DIF
Value Integer     PATCH,EXCEL
Local Integer  I,J,K,OBJ,NBFIC,TOUT,OK_C
Local Char     AOBJ,COD,CRITERE(200),MESSA(250)
Local Char INTERM1(250), INTERM2(250)
## déclaration pour la table ATABZON (mémorisation des champs à comparer)
Local Integer     DIMZON(4,1..250),NBRZON(4)
Local Char        ZON(GLONAVA)(4,1..250), INTZON(30)(4,1..250), TYP(15)(4,1..250)
Gosub OPEN_AST
If [M:ACMP]LANGUE<>""
    Gosub COMP_AST From ACOMPOBJ2
Else
    Gosub COMP_AST_TOT From ACOMPOBJ2
Endif
Gosub CLOSE_AST
End

