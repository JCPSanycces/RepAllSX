#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(30)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACOMPOBJ","ACOMPOBJ",3,"XYACOMPOBJ") From GTRAITE
End
GBIDC1 = "SUPERV"
GBIDC2 = "MONO"
Call OUVRE_TRACE("") From LECFIC
Call COMPARAISON_SOLO("AEV","AHI",-1,0,GBIDC1,GBIDC2,GBIDI1)
Call ECR_TRACE(num$(GBIDI1),0) From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


#########################################################################################################################
## Programme DIFFERENCE D'OBJETS
##
## Subprog COMPARAISON_SOLO(ABREV,NOM_OBJ,TRACE,DET,DOSORG,DOSORG,STAT)   Comparaison d'un seul et unique objet
##
## Subprog COMPDOS(FORMAT)                                                Appelé depuis la validatioon de dossier
##
#########################################################################################################################

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

#########################################################
$INIT
Local File     ADOSSIER [ADS]
Return

#########################################################
$INIT_DIA
Raz [M:ACMP]
Gosub INIT_MOD
Return

########################################################
$INIT_MOD
Local Integer I
[M:ACMP]NBMOD = len(mess(0,14,1))
For I=1 To len(mess(0,14,1))
 If left$(mess(I,14,1),1)="#"
  [M:ACMP]NBMOD = I-1
  Break
 Endif
 [M:ACMP]COPMOD(I-1) = 2
Next I

Return

#########################################################
$CONTROLE
Gosub INIT_AV
## Calcul du nombre de comparaison à faire.
Gosub TRT_COMPTE
If (NB_AMK>10) or (NB_AOB>10) or (NB_AOC>10) or (NB_AST>10) or (NB_ATB>10) or (NB_AWI>10) or (NB_ADI>10)
&              or (NB_AFC>10) or (NB_ACT>10) or (NB_ATY>10) or (NB_ARP>10) or (NB_ACN>10) or NB_ADC>10
&              or (NB_AOE>10) or (NB_AEV>10) or (NB_ACLA>10) or (NB_ASW>10) or (NB_ACV)>0
&              or [M:ACMP]CODACT<>""                      #X3PLAT-940 - Filter on activity code
 If GSERVEUR
  Call ECR_TRACE(MSG,0) From GESECRAN
 Else
  Append CLOB , chr$(13)+chr$(13)+mess(205,100,1) : # Voulez vous continuer ?
  Call MESCTL(CLOB,OK) From GESECRAN
  #Call AVERTIR (MSG+"\\"+mess(205,100,1),OK) From GESECRAN :  # Voulez vous continuer ?
  If OK<>2
   SAI = 1
   Gosub INIT_AP
   Return
  Endif
 Endif
Endif
TMP = 1
Return

#######################################################
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(mess(81,126,1)-[M:ACMP]DOSORG-"=>"-[M:ACMP]DOSDES) From LECFIC   # Différence
Endif

# X3PLAT-940 - filter by activity code
If [M:ACMP]CODACT<>""
  Call ECR_TRACE(mess(42,142,1)-[M:ACMP]CODACT,0) From GESECRAN
Endif
# X3PLAT-940 - filter by activity code

TRA = 1
Call COMPARAISON(NB_AMK,NB_AWI,NB_AOB,NB_AOC,NB_AFC,NB_ACT,NB_ATY,NB_ATB,NB_ADI,NB_AST,NB_ARP,NB_ACN,NB_ADC,NB_AOE,NB_AEV,NB_ACLA,NB_ASW,NB_ACV)
Gosub INIT_AP
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

#############################################################
# L'écran ACOMPOBJ doit être renseigné
#############################################################
Subprog COMPARAISON(NB_AMK,NB_AWI,NB_AOB,NB_AOC,NB_AFC,NB_ACT,NB_ATY,NB_ATB,NB_ADI,NB_AST,NB_ARP,NB_ACN,NB_ADC,NB_AOE,NB_AEV,NB_ACLA,NB_ASW,NB_ACV) #RBU
Value Integer  NB_AMK,NB_AWI,NB_AOB,NB_AOC,NB_AFC,NB_ACT,NB_ATY,NB_ATB,NB_ADI,NB_AST,NB_ARP,NB_ACN,NB_ADC,NB_AOE,NB_AEV,NB_ACLA,NB_ASW,NB_ACV #RBU

Local Integer  DIF , PATCH , EXCEL
Local Char     OGFICPATH(GDIMFIC) , OGFILPATH(GDIMFIC)

Raz PATCH , DIF
If dim([M]FICHIER)<=0
 EXCEL = 0
Elsif [M]FICHIER=2
 If dim([M]FORMAT)<=0
  EXCEL = 1
 Else
  EXCEL = max(1,[M]FORMAT)
 Endif
Else
 EXCEL = 0
Endif

#PATCH = 1

If EXCEL
 OGFICPATH = GFICPATH
 Raz GFICPATH , GNBIMP
Endif
If PATCH
 OGFILPATH = GFILPATH
 Raz GFILPATH
Endif

Gosub INIT_AV
Gosub OUVFIC
Call MACHINE([M:ACMP]DOSDES,GBIDC1,GDOSSIER) From ORDSYS
If [M]AMK=2
    Call TRT_ECRAN(NB_AMK,DIF,PATCH,EXCEL)      # Ecran
Endif
If [M]AWI=2
    Call TRT_FENETRE(NB_AWI,DIF,PATCH,EXCEL)    # Fenetre
Endif
If [M]AOB=2
    Call TRT_OBJET(NB_AOB,DIF,PATCH,EXCEL)      # Objet
Endif
If [M]AOC=2
    Call TRT_PERSOBJ(NB_AOC,DIF,PATCH,EXCEL)    # Perso
Endif
If [M]AFC=2
    Call TRT_FONCTION(NB_AFC,DIF,PATCH,EXCEL)   # Fonction
Endif
If [M]ACT=2
    Call TRT_ACTION(NB_ACT,DIF,PATCH,EXCEL)     # Action
Endif
If [M]ATY=2
    Call TRT_TYPE(NB_ATY,DIF,PATCH,EXCEL)       # Type de données
Endif
If [M]ATB=2
    Call TRT_TABLE(NB_ATB,DIF,PATCH,EXCEL)      # Table
Endif
If [M]ADI=2
    Call TRT_TABDIV(NB_ADI,DIF,PATCH,EXCEL)     # Table diverse
Endif
If [M]AST=2
    Call TRT_MESSAGE(NB_AST,DIF,PATCH,EXCEL)    # Message
Endif
If [M]ARP=2
    Call TRT_REPORT(NB_ARP,DIF,PATCH,EXCEL)     # Etats
Endif
If [M]ACN=2
    Call TRT_CONSULT(NB_ACN,DIF,PATCH,EXCEL)    # Consultations
Endif
If [M]ADC=2
    Call TRT_TRAIT(NB_ADC,DIF,PATCH,EXCEL,1)    # Traitements
Endif
If [M]AOE=2
    Call TRT_MODELE(NB_AOE,DIF,PATCH,EXCEL)    # Modele d'import/export
Endif
If [M]AEV=2
    Call TRT_TABIMP(NB_AEV,DIF,PATCH,EXCEL)    # Modele tableau/import
Endif
If [M]ACLA=2
 Call TRT_CLASSE(NB_ACLA,DIF,PATCH,EXCEL) : # Classes
Endif
If [M]ASW=2
 Call TRT_REPRESENTATION(NB_ASW,DIF,PATCH,EXCEL) : # Classes
Endif
#RBU
If [M]ACV=2
 Call TRT_ACTIV(NB_ACV,DIF,PATCH,EXCEL) : # Activity codes
Endif
#RBU

If PATCH
 Call PATCH("","","") From ACOMPOBJ2
 If !GSERVEUR : GFILPATH = OGFILPATH : Endif
Endif
If EXCEL
 If !GSERVEUR : GFICPATH = OGFICPATH : Endif
Endif
End

#########################################################
$TERMINE
If !GSERVEUR
    SAI=1  ## Permet de revenir sur l'écran (à partir de l'action AVANT_PAR)
Endif
Return

#########################################################
$OUVFIC
# Ouverture du fichier ATABZON sur les deux dossiers (bug 8339 - 13/03/01)
# Comparaison possible entre deux versions (120 & 130)
#  qui n'ont pas la même structure au niveau des tables de référence.
If clalev([F:OATZ])<>0 : Close Local File [OATZ] : Endif
If clalev([F:DATZ])<>0 : Close Local File [DATZ] : Endif
If clalev([F:OATX])<>0 : Close Local File [OATX] : Endif
If clalev([F:DATX])<>0 : Close Local File [DATX] : Endif
If clalev([F:OAXT])<>0 : Close Local File [OAXT] : Endif
If clalev([F:DAXT])<>0 : Close Local File [DAXT] : Endif
If clalev([F:OACV])<>0 : Close Local File [OACV] : Endif
If clalev([F:DACV])<>0 : Close Local File [DACV] : Endif
Local File =[M:ACMP]DOSORG+".ATABZON"   [OATZ]
Local File =[M:ACMP]DOSDES+".ATABZON"   [DATZ]
Local File =[M:ACMP]DOSORG+".ATEXTE"    [OATX]
Local File =[M:ACMP]DOSDES+".ATEXTE"    [DATX]
Local File =[M:ACMP]DOSORG+".ATEXTRA"   [OAXT]
Local File =[M:ACMP]DOSDES+".ATEXTRA"   [DAXT]
Local File =[M:ACMP]DOSORG+".ACTIV"     [OACV]  #X3PLAT-941 - add activity code comparison - RBU
Local File =[M:ACMP]DOSDES+".ACTIV"     [DACV]  #X3PLAT-941 - add activity code comparison - RBU
Return

#########################################################
$INIT_AV
## Initialisation pour éxécution de la comparaison
If [M:ACMP]AMKFIN  = "" : [M:ACMP]AMKFIN = "ZZZZZZZZZZ"   : Endif
If [M:ACMP]AWIFIN  = "" : [M:ACMP]AWIFIN = "ZZZZZZZZZZ"   : Endif
If [M:ACMP]AOBFIN  = "" : [M:ACMP]AOBFIN = "ZZZ"          : Endif
If [M:ACMP]AOCFIN  = "" : [M:ACMP]AOCFIN = "ZZZ"          : Endif
If [M:ACMP]AFCFIN  = "" : [M:ACMP]AFCFIN = "ZZZZZZZZZZ"   : Endif
If [M:ACMP]ACTFIN  = "" : [M:ACMP]ACTFIN = "ZZZZZZZZZZ"   : Endif
If [M:ACMP]ATYFIN  = "" : [M:ACMP]ATYFIN = "ZZZ"          : Endif
If [M:ACMP]ATBFIN  = "" : [M:ACMP]ATBFIN = "ZZZZZZZZZZ"   : Endif
If [M:ACMP]ASTFIN  = 0  : [M:ACMP]ASTFIN = 9999           : Endif
If [M:ACMP]ADIFIN  = 0  : [M:ACMP]ADIFIN = 9999           : Endif
If [M:ACMP]ARPFIN  = "" : [M:ACMP]ARPFIN = "ZZZZZZZZZZ"   : Endif
If [M:ACMP]ACNFIN  = "" : [M:ACMP]ACNFIN = "ZZZ"          : Endif
If [M:ACMP]ADCFIN  = "" : [M:ACMP]ADCFIN = "ZZZZZZZZZZZZ" : Endif
If [M:ACMP]AOEFIN  = "" : [M:ACMP]AOEFIN = "ZZZZZZZZZZ"   : Endif
If [M:ACMP]AEVFIN  = "" : [M:ACMP]AEVFIN = "ZZZZZZZZZZ"   : Endif
If [M:ACMP]ACLAFIN = "" : [M:ACMP]ACLAFIN= "ZZZZZZZZZZZZZZZZZZZZ" : Endif #X3PLAT-940 - correction
If [M:ACMP]ASWFIN  = "" : [M:ACMP]ASWFIN = "ZZZZZZZZZZZZZZZZZZZZ" : Endif #X3PLAT-940 - correction
If [M:ACMP]ACVFIN  = "" : [M:ACMP]ACVFIN = "ZZZZZ"        : Endif #X3PLAT-941 - add activity code comparison - RBU
Return

#########################################################
$INIT_AP
## Ré-initialisation pour éviter d'effacer la dernière sélection
If [M:ACMP]AMKFIN  = "ZZZZZZZZZZ"   : Raz [M:ACMP]AMKFIN  : Endif
If [M:ACMP]AWIFIN  = "ZZZZZZZZZZ"   : Raz [M:ACMP]AWIFIN  : Endif
If [M:ACMP]AOBFIN  = "ZZZ"          : Raz [M:ACMP]AOBFIN  : Endif
If [M:ACMP]AOCFIN  = "ZZZ"          : Raz [M:ACMP]AOCFIN  : Endif
If [M:ACMP]AFCFIN  = "ZZZZZZZZZZ"   : Raz [M:ACMP]AFCFIN  : Endif
If [M:ACMP]ACTFIN  = "ZZZZZZZZZZ"   : Raz [M:ACMP]ACTFIN  : Endif
If [M:ACMP]ATYFIN  = "ZZZ"          : Raz [M:ACMP]ATYFIN  : Endif
If [M:ACMP]ATBFIN  = "ZZZZZZZZZZ"   : Raz [M:ACMP]ATBFIN  : Endif
If [M:ACMP]ASTFIN  = 9999           : Raz [M:ACMP]ASTFIN  : Endif
If [M:ACMP]ADIFIN  = 9999           : Raz [M:ACMP]ADIFIN  : Endif
If [M:ACMP]ARPFIN  = "ZZZZZZZZZZ"   : Raz [M:ACMP]ARPFIN  : Endif
If [M:ACMP]ACNFIN  = "ZZZ"          : Raz [M:ACMP]ACNFIN  : Endif
If [M:ACMP]ADCFIN  = "ZZZZZZZZZZZZ" : Raz [M:ACMP]ADCFIN  : Endif
If [M:ACMP]AOEFIN  = "ZZZZZZZZZZ"   : Raz [M:ACMP]AOEFIN  : Endif
If [M:ACMP]AEVFIN  = "ZZZZZZZZZZ"   : Raz [M:ACMP]AEVFIN  : Endif
If [M:ACMP]ACLAFIN = "ZZZZZZZZZZZZZZZZZZZZ" : Raz [M:ACMP]ACLAFIN : Endif #X3PLAT-940 - correction
If [M:ACMP]ASWFIN  = "ZZZZZZZZZZZZZZZZZZZZ" : Raz [M:ACMP]ASWFIN  : Endif #X3PLAT-940 - correction
If [M:ACMP]ACVFIN  = "ZZZZZ"        : Raz [M:ACMP]ACVFIN  : Endif  #X3PLAT-941 - add activity code comparison - RBU
Return

############################################################################
# Contrôle sur la comparaison possible entre deux versions (bug 8339 - 13/03/01)
# Condition sur les tables des OBJETS
# La comparaison n'est possible que si les deux versions sont en 140
#############################################################################
$CTRL_VRS
Local Char ODOS,OMAC,OAPPLI,NOM,EXT
Local Char DDOS,DMAC,DAPPLI,NOM,EXT

ODOS=[M]DOSORG
If instr(1,ODOS,"@")>0
    Call MACHINE(ODOS,OMAC,OAPPLI) From ORDSYS
    OAPPLI = toupper(OAPPLI)
Else
    OMAC = ""
    OAPPLI   = toupper(ODOS)
Endif

DDOS=[M]DOSDES
If instr(1,DDOS,"@")>0
    Call MACHINE(DDOS,DMAC,DAPPLI) From ORDSYS
    DAPPLI = toupper(DAPPLI)
Else
    DMAC = ""
    DAPPLI   = toupper(DDOS)
Endif

If filinfo(filpath("FIL","AWINBRO","fde",OAPPLI,"",OMAC),7)<=0 and
&  filinfo(filpath("FIL","AWINBRO","fde",DAPPLI,"",DMAC),7)<=0
    VERSION=0
Endif
Return

###########################################
Subprog TRT_ECRAN(NB_AMK,DIF,PATCH,EXCEL)
Value Integer     NB_AMK
Variable Integer  DIF
Value Integer     PATCH,EXCEL
Local Integer     I,J,K,OBJ,NBFIC,TOUT,OK_C
Local Char        AOBJ,COD,LIBEL(250),CRITERE(200),MESSA(250),MESSTECH
## variables utilisées pour afficher les chaines formatées "KT"
Local Char INTERM1(250), INTERM2(250)
## déclaration pour la table ATABZON (mémorisation des champs à comparer)
Local Integer     DIMZON(4,1..500),NBRZON(4)
Local Schar       ZON(GLONAVA)(4,1..500), TYP(15)(4,1..500)
Local Char        INTZON(30)(4,1..500)
Gosub OPEN_AMK
Gosub COMP_AMK From ACOMPOBJ2
Gosub CLOSE_AMK
End

#########################################
Subprog TRT_FENETRE(NB_AWI,DIF,PATCH,EXCEL)
Value Integer     NB_AWI
Variable Integer  DIF
Value Integer     PATCH,EXCEL
Local Integer       I,J,K,OBJ,NBFIC,TOUT,OK_C
Local Char          AOBJ,COD,CRITERE(200), MESSA(250),MESSTECH
## variables utilisées pour afficher les chaines formatées "KT"
Local Char INTERM1(250), INTERM2(250)
## déclaration pour la table ATABZON (mémorisation des champs à comparer)
Local Integer       DIMZON(4,1..250),NBRZON(4)
Local Char          ZON(GLONAVA)(4,1..250), INTZON(30)(4,1..250), TYP(15)(4,1..250)
Gosub OPEN_WIN
Gosub COMP_WIN From ACOMPOBJ2
Gosub CLOSE_WIN
End

#####################################
Subprog TRT_OBJET(NB_AOB,DIF,PATCH,EXCEL)
Value Integer     NB_AOB
Variable Integer  DIF
Value Integer     PATCH,EXCEL
Local Integer     I,J,K,OBJ,NBFIC,TOUT,OK_C
Local Char        AOBJ,COD,CRITERE(200), MESSA(250), MESSTECH
## variables utilisées pour afficher les chaines formatées "KT"
Local Char INTERM1(250), INTERM2(250)
## déclaration pour la table ATABZON (mémorisation des champs à comparer)
Local Integer     DIMZON(3,1..250),NBRZON(3)
Local Char        ZON(GLONAVA)(3,1..250), INTZON(30)(3,1..250), TYP(15)(3,1..250)

Local Integer  VERSION
VERSION = 1
Gosub CTRL_VRS
If VERSION
 Gosub OPEN_OBJ
 Gosub COMP_OBJ From ACOMPOBJ2
 Gosub CLOSE_OBJ
Endif
End

########################################
