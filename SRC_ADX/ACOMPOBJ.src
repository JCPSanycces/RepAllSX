Subprog AS_NBMOD
GBOUT2 = mess(202,124,1) : # Oui à tout le reste
GBOUT3 = mess(203,124,1) : # Non à tout le reste
End

Subprog B2_NBMOD
Local Integer I
For I=nolign To [M]NBMOD
 [M]COPMOD(I-1) = 2
Next I
Affzo 25
End

Subprog B3_NBMOD
Local Integer I
For I=nolign To [M]NBMOD
 [M]COPMOD(I-1) = 1
Next I
Affzo 25
End

Subprog AM_AMK(VALEUR)
Variable Integer VALEUR
[M]AMK = VALEUR
Effzo AMKDEB , AMKFIN
Gosub GRISE_AMK
End

$GRISE_AMK
