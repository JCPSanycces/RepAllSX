If [M]ADI = 2
#X3PLAT-940 - Filter on activity code
#    If [M]DOSORG=nomap
#        Local File ATABDIV [ADI1], ATABTAB [ADV1]
#    Else
#        Local File =[M]DOSORG+".ATABDIV" [ADI1], =[M]DOSORG+".ATABTAB" [ADV1]
#    Endif
    Gosub OPEN_ADI
#X3PLAT-940 - Filter on activity code
    Raz INTERM
    CRITERE = "1=1"
    If [M:ACMP]ADIDEB=0 & [M:ACMP]ADIFIN=9999
    Else
     CRITERE += "& NUMTAB>=[M:ACMP]adideb & NUMTAB<=[M:ACMP]adifin"
    Endif
    For [F:ADI1] Where evalue(CRITERE)
        Read [ADV1]CODE = [F:ADI1]NUMTAB
        If [M:ACMP]COPMOD(max([F:ADV1]MODULE-1,0)) = 2 & INTERM <> [F:ADI1]NUMTAB
            INTERM=[F:ADI1]NUMTAB
            FILTRE_STEP = 1                    #X3PLAT-940 - Filter on activity code
            Gosub FILTRE_ADI From ACOMPOBJ3    #X3PLAT-940 - Filter on activity code
            If !OK Goto NEXT_ADI: Endif        #X3PLAT-940 - Filter on activity code
            NB_ADI +=1
        Endif
    $NEXT_ADI                                  #X3PLAT-940 - Filter on activity code
    Next
#X3PLAT-940 - Filter on activity code
#   Close Local File [ADI1],[ADV1]
    Gosub CLOSE_ADI
#X3PLAT-940 - Filter on activity code
Endif

## Calcul du nombre de messages à comparer
Raz NB_AST
If [M]AST = 2
#X3PLAT-940 - Filter on activity code
#    If [M]DOSORG=nomap
#        Local File APLSTD [AST1], AMENLOC [AML1]
#    Else
#        Local File =[M]DOSORG+".APLSTD" [AST1], =[M]DOSORG+".AMENLOC" [AML1]
#    Endif
    Gosub OPEN_AST
#X3PLAT-940 - Filter on activity code
    CRITERE = "1=1"
    If [M:ACMP]ASTDEB<>0 or [M:ACMP]ASTFIN<>9999
     CRITERE += "& LANCHP>=[M:ACMP]ASTDEB & LANCHP<=[M:ACMP]ASTFIN"
    Endif
    CRITERE += "& LAN=[M:ACMP]LANGUE"
    For [F:AST1]CLE(1) Where evalue(CRITERE)
        Read [AML1]MENLOC = [F:AST1]LANCHP
        If !fstat & [F:AML1]MODULE<>0 & [M:ACMP]COPMOD(max([F:AML1]MODULE-1,0)) = 2
            FILTRE_STEP = 1                    #X3PLAT-940 - Filter on activity code
            Gosub FILTRE_AST From ACOMPOBJ3    #X3PLAT-940 - Filter on activity code
            If !OK Goto NEXT_AST: Endif        #X3PLAT-940 - Filter on activity code
            For [AST1]CLE
                 NB_AST +=1
            Next
        Endif
    $NEXT_AST                                  #X3PLAT-940 - Filter on activity code
    Next
#X3PLAT-940 - Filter on activity code
#   Close Local File [AST1],[AML1]
    Gosub CLOSE_AST
#X3PLAT-940 - Filter on activity code
Endif

## Calcul du nombre d'états à comparer
Raz NB_ARP
If [M]ARP = 2
#X3PLAT-940 - Filter on activity code
#    If [M]DOSORG=nomap
#        Local File AREPORT    [ARP1]
#    Else
#        Local File =[M]DOSORG+".AREPORT"    [ARP1]
#    Endif
    Gosub OPEN_ARP
#X3PLAT-940 - Filter on activity code
    CRITERE = "1=1"
    If [M:ACMP]ARPDEB="" & [M:ACMP]ARPFIN="ZZZZZZZZZZ"
     If GADONIX=2
      CRITERE += "& RPTCOD<'X'"
     Endif
    Else
     CRITERE += "& RPTCOD>=[M:ACMP]ARPDEB & RPTCOD<=[M:ACMP]ARPFIN"
    Endif
    If [M:ACMP]LANGUE<>""
     CRITERE += "& LAN=[M:ACMP]LANGUE"
    Endif
    For [F:ARP1] Where evalue(CRITERE)
      If [M:ACMP]COPMOD(max([F:ARP1]MODULE-1,0)) = 2
            FILTRE_STEP = 1                    #X3PLAT-940 - Filter on activity code
            Gosub FILTRE_ARP From ACOMPOBJ3    #X3PLAT-940 - Filter on activity code
            If !OK Goto NEXT_ARP: Endif        #X3PLAT-940 - Filter on activity code
        NB_ARP +=1
      Endif
    $NEXT_ARP                                 #X3PLAT-940 - Filter on activity code
    Next
    Filter [F:ARP1]
#X3PLAT-940 - Filter on activity code
#   Close Local File [ARP1]
    Gosub CLOSE_ARP
#X3PLAT-940 - Filter on activity code
Endif

## Calcul du nombre de consultations à comparer
Raz NB_ACN
If [M]ACN = 2
#X3PLAT-940 - Filter on activity code
#    If [M]DOSORG=nomap
#        Local File ACONSULT    [ACN1]
#    Else
#        Local File =[M]DOSORG+".ACONSULT"    [ACN1]
#    Endif
    Gosub OPEN_ACN
#X3PLAT-940 - Filter on activity code
    CRITERE = "1=1"
    If [M:ACMP]ACNDEB="" & [M:ACMP]ACNFIN="ZZZ"
     If GADONIX=2
      CRITERE += "& COD<'X'"
     Endif
    Else
     CRITERE += "& COD>=[M:ACMP]ACNDEB & COD<=[M:ACMP]ACNFIN"
    Endif
    For [F:ACN1] Where evalue(CRITERE)
      If [M:ACMP]COPMOD(max([F:ACN1]MODULE-1,0)) = 2
            FILTRE_STEP = 1                    #X3PLAT-940 - Filter on activity code
            Gosub FILTRE_ACN From ACOMPOBJ3    #X3PLAT-940 - Filter on activity code
            If !OK Goto NEXT_ACN: Endif        #X3PLAT-940 - Filter on activity code
         NB_ACN +=1
      Endif
    $NEXT_ACN                                  #X3PLAT-940 - Filter on activity code
    Next
#X3PLAT-940 - Filter on activity code
#   Close Local File [ACN1]
    Gosub CLOSE_ACN
#X3PLAT-940 - Filter on activity code
Endif

## Calcul du nombre de traitements à comparer
Raz NB_ADC
If [M]ADC = 2
#X3PLAT-940 - Filter on activity code
# If filinfo(filpath("FIL","ADICTRT","fde",[M]DOSORG),0)>0
#& & filinfo(filpath("FIL","ADICTRT","fde",[M]DOSDES),0)>0
#  If [M]DOSORG=nomap
#   Local File ADICTRT [ADC1]
#  Else
#   Local File =[M]DOSORG+".ADICTRT" [ADC1]
#  Endif
# Endif
    Gosub OPEN_ADC
#X3PLAT-940 - Filter on activity code
 Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
 Local Char    ORDRE(200)
 Local Integer I , OK , CMPDIC
 CRITERE = "1=1"
 If [M:ACMP]ADCDEB="" & [M:ACMP]ADCFIN="ZZZZZZZZZZZZ"
  If GADONIX=2
   CRITERE += "& [F:TRT_]TRAIT<'X' & !find(left$([F:TRT_]TRAIT,4),'SUBX','SUBY','SUBZ')"
  Endif
 Else
  CRITERE += "& [F:TRT_]TRAIT>=[M:ACMP]ADCDEB & [F:TRT_]TRAIT<=[M:ACMP]ADCFIN"
 Endif
 If left$([M:ACMP]ADCDEB,1)<>"W" & left$([M:ACMP]ADCFIN,1)<>"W"
  CRITERE += '& left$([F:TRT_]TRAIT,1)<>"W"'
 Endif
 CMPDIC = ((sum([M:ACMP]COPMOD(0..[M:ACMP]NBMOD-1))<>[M:ACMP]NBMOD*2) & clalev([F:ADC1])>0)
 Call MACHINE([M]DOSORG,MACHINE,APPLI) From ORDSYS
 ORDRE = MACHINE+'@lsadx -a '+APPLI-' TRT src'
 Local File (TRAIT(GLONADC)) From System ORDRE As [TRT_]
 For [TRT_]
  If [F:TRT_]TRAIT<>"" & evalue(CRITERE)
   OK = 1
   If CMPDIC
    Read [ADC1]ADC0 = [F:TRT_]TRAIT
    If fstat | [M:ACMP]COPMOD(max([F:ADC1]MODULE-1,0))<>2
      FILTRE_STEP = 1                    #X3PLAT-940 - Filter on activity code
      Gosub FILTRE_ADC From ACOMPOBJ3    #X3PLAT-940 - Filter on activity code
      If !OK Goto NEXT_ADC: Endif        #X3PLAT-940 - Filter on activity code
     OK = 0
    Endif
   Endif
   If OK
    NB_ADC += 1
   Endif
  Endif
 $NEXT_ADC                                  #X3PLAT-940 - Filter on activity code
 Next TRT_
 Close Local File [TRT_]
#X3PLAT-940 - Filter on activity code
#   Close Local File [ADC1]
    Gosub CLOSE_ADC
#X3PLAT-940 - Filter on activity code
Endif

## Calcul du nombre de models d'import/export et de tableaux d'import
Raz NB_AOE
If [M]AOE = 2
#X3PLAT-940 - Filter on activity code
#    If [M]DOSORG=nomap
#        Local File AOBJEXT    [AOE1]
#    Else
#        Local File =[M]DOSORG+".AOBJEXT"    [AOE1]
#    Endif
    Gosub OPEN_AOE
#X3PLAT-940 - Filter on activity code
    CRITERE = "1=1"
    If [M:ACMP]AOEDEB="" & [M:ACMP]AOEFIN="ZZZZZZZZZZ"
     If GADONIX=2
      CRITERE += "& EXT<'X'"
     Endif
    Else
     CRITERE += "& EXT>=[M:ACMP]AOEDEB & EXT<=[M:ACMP]AOEFIN"
    Endif
    For [F:AOE1] Where evalue(CRITERE)
      If [M:ACMP]COPMOD(max([F:AOE1]MODULE-1,0)) = 2
         FILTRE_STEP = 1                    #X3PLAT-940 - Filter on activity code
         Gosub FILTRE_AOE From ACOMPOBJ3    #X3PLAT-940 - Filter on activity code
         If !OK Goto NEXT_AOE: Endif        #X3PLAT-940 - Filter on activity code
         NB_AOE +=1
      Endif
    $NEXT_AOE                                  #X3PLAT-940 - Filter on activity code
    Next
#X3PLAT-940 - Filter on activity code
#   Close Local File [AOE1]
    Gosub CLOSE_AOE
#X3PLAT-940 - Filter on activity code
Endif

## Calcul du nombre des tableaux d'import
Raz NB_AEV
If [M]AEV = 2
    If [M]DOSORG=nomap
        Local File AEXPV3  [AEV1]
    Else
        Local File =[M]DOSORG+".AEXPV3"     [AEV1]
    Endif
    CRITERE = "1=1"
    If [M:ACMP]AEVDEB="" & [M:ACMP]AEVFIN="ZZZZZZZZZZ"
     If GADONIX=2
      CRITERE += "& CODE<'X'"
     Endif
    Else
     CRITERE += "& CODE>=[M:ACMP]AEVDEB & CODE<=[M:ACMP]AEVFIN"
    Endif
    For [F:AEV1] Where evalue(CRITERE)
      NB_AEV +=1
    Next
    Close Local File [AEV1]
Endif

#RBU
## Calcul du nombre des activity codes
Raz NB_ACV
If [M]ACV = 2
#X3PLAT-940 - Filter on activity code
#    If [M]DOSORG=nomap
#        Local File ACTIV    [ACV1]
#    Else
#        Local File =[M]DOSORG+".ACTIV"    [ACV1]
#    Endif
    Gosub OPEN_ACV
#X3PLAT-940 - Filter on activity code
    CRITERE = "1=1"
    If [M:ACMP]ACVDEB="" & [M:ACMP]ACVFIN="ZZZZZ"
     If GADONIX=2
      CRITERE += "& CODACT<'X'"
     Endif
    Else
     CRITERE += "& CODACT>=[M:ACMP]ACVDEB & CODACT<=[M:ACMP]ACVFIN"
    Endif
    For [F:ACV1] Where evalue(CRITERE)
      FILTRE_STEP = 1                    #X3PLAT-940 - Filter on activity code
      Gosub FILTRE_ACV From ACOMPOBJ3    #X3PLAT-940 - Filter on activity code
      If !OK Goto NEXT_ACV: Endif        #X3PLAT-940 - Filter on activity code
      NB_ACV +=1
    $NEXT_ACV                                  #X3PLAT-940 - Filter on activity code
    Next
#X3PLAT-940 - Filter on activity code
#   Close Local File [ACV1]
    Gosub CLOSE_ACV
#X3PLAT-940 - Filter on activity code
Endif
#RBU

If !GINFO
 Call TEMPOFF From GESECRAN
Endif

Raz MSG , CLOB
If [M:ACMP]CODACT=""                                                         # X3PLAT-940 - Filter on activity code
  If NB_AMK<>0 : Call ADDMES(CLOB,MSG,num$(NB_AMK)-mess(17,125,1))  : Endif : # Ecrans
  If NB_AWI<>0 : Call ADDMES(CLOB,MSG,num$(NB_AWI)-mess(11,42,1))   : Endif : # Fenêtres
  If NB_AOB<>0 : Call ADDMES(CLOB,MSG,num$(NB_AOB)-mess(18,125,1))  : Endif : # Objets
  If NB_AOC<>0 : Call ADDMES(CLOB,MSG,num$(NB_AOC)-mess(83,126,1))  : Endif : # Personnalisation objets
  If NB_AFC<>0 : Call ADDMES(CLOB,MSG,num$(NB_AFC)-mess(21,125,1))  : Endif : # Fonctions
  If NB_ACT<>0 : Call ADDMES(CLOB,MSG,num$(NB_ACT)-mess(20,125,1))  : Endif : # Actions
  If NB_ATY<>0 : Call ADDMES(CLOB,MSG,num$(NB_ATY)-mess(19,125,1))  : Endif : # Types de données
  If NB_ATB<>0 : Call ADDMES(CLOB,MSG,num$(NB_ATB)-mess(16,125,1))  : Endif : # Tables
  If NB_ADI<>0 : Call ADDMES(CLOB,MSG,num$(NB_ADI)-mess(2,26,1))    : Endif : # Tables diverses
  If NB_AST<>0 : Call ADDMES(CLOB,MSG,num$(NB_AST)-mess(201,124,1)) : Endif : # Messages
  If NB_ARP<>0 : Call ADDMES(CLOB,MSG,num$(NB_ARP)-mess(1,92,1))    : Endif : # Etats
  If NB_ACN<>0 : Call ADDMES(CLOB,MSG,num$(NB_ACN)-mess(12,42,1))   : Endif : # Consultations
  If NB_ADC<>0 : Call ADDMES(CLOB,MSG,num$(NB_ADC)-mess(43,115,1))  : Endif : # Traitements
  If NB_AOE<>0 : Call ADDMES(CLOB,MSG,num$(NB_AOE)-mess(214,142,1)) : Endif : # Modèle d'import/export
  If NB_ACLA<>0 :Call ADDMES(CLOB,MSG,num$(NB_ACLA)-mess(254,125,1)) : Endif : # Activity codes #X3PLAT-940 correction
  If NB_ASW<>0 : Call ADDMES(CLOB,MSG,num$(NB_ASW)-mess(255,125,1))  : Endif : # Activity codes #X3PLAT-940 correction
  If NB_ACV<>0 : Call ADDMES(CLOB,MSG,num$(NB_ACV)-mess(24,125,1))  : Endif : # Activity codes #X3PLAT-941
Else
# X3PLAT-940 - filter by activity code
  Call ADDMES(CLOB, MSG, mess(42,142,1)-[M:ACMP]CODACT) # Add activity code to message
  If [M:ACMP]AMK=2 : Call ADDMES(CLOB,MSG,num$(NB_AMK)-mess(17,125,1))  : Endif : # Ecrans
  If [M:ACMP]AWI=2 : Call ADDMES(CLOB,MSG,num$(NB_AWI)-mess(11,42,1))   : Endif : # Fenêtres
  If [M:ACMP]AOB=2 : Call ADDMES(CLOB,MSG,num$(NB_AOB)-mess(18,125,1))  : Endif : # Objets
  If [M:ACMP]AOC=2 : Call ADDMES(CLOB,MSG,num$(NB_AOC)-mess(83,126,1))  : Endif : # Personnalisation objets
  If [M:ACMP]AFC=2 : Call ADDMES(CLOB,MSG,num$(NB_AFC)-mess(21,125,1))  : Endif : # Fonctions
  If [M:ACMP]ACT=2 : Call ADDMES(CLOB,MSG,num$(NB_ACT)-mess(20,125,1))  : Endif : # Actions
  If [M:ACMP]ATY=2 : Call ADDMES(CLOB,MSG,num$(NB_ATY)-mess(19,125,1))  : Endif : # Types de données
  If [M:ACMP]ATB=2 : Call ADDMES(CLOB,MSG,num$(NB_ATB)-mess(16,125,1))  : Endif : # Tables
  If [M:ACMP]ADI=2 : Call ADDMES(CLOB,MSG,num$(NB_ADI)-mess(2,26,1))    : Endif : # Tables diverses
  If [M:ACMP]AST=2 : Call ADDMES(CLOB,MSG,num$(NB_AST)-mess(201,124,1)) : Endif : # Messages
  If [M:ACMP]ARP=2 : Call ADDMES(CLOB,MSG,num$(NB_ARP)-mess(1,92,1))    : Endif : # Etats
  If [M:ACMP]ACN=2 : Call ADDMES(CLOB,MSG,num$(NB_ACN)-mess(12,42,1))   : Endif : # Consultations
  If [M:ACMP]ADC=2 : Call ADDMES(CLOB,MSG,num$(NB_ADC)-mess(43,115,1))  : Endif : # Traitements
  If [M:ACMP]AOE=2 : Call ADDMES(CLOB,MSG,num$(NB_AOE)-mess(214,142,1)) : Endif : # Modèle d'import/export
  If [M:ACMP]ACLA=2 :Call ADDMES(CLOB,MSG,num$(NB_ACLA)-mess(254,125,1)) :Endif : # Classes
  If [M:ACMP]ASW=2 : Call ADDMES(CLOB,MSG,num$(NB_ASW)-mess(255,125,1))  :Endif : # Representations
  If [M:ACMP]ACV=2 : Call ADDMES(CLOB,MSG,num$(NB_ACV)-mess(24,125,1))  : Endif : # Activity codes
Endif
Return

#####################################
Subprog ADDMES(CLOB,MSG,NEW)
Variable Clbfile CLOB
Variable Char MSG
Value Char NEW
If len(MSG)=0
 MSG += NEW
Elsif len(MSG)+len(NEW)+1<200
 MSG += "\"+NEW
Endif
If len(CLOB)=0
 Append CLOB , NEW
Else
 Append CLOB , chr$(13)+NEW
Endif
End

