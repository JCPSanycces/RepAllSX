# CBO 2013.07.12 FQ91070 ajout ﾃｩclatement d'un bien
# CBO 2012.02.23 FQ80109
# CBO 20120227 FQ80394
#

Call OBJET("FXM",GBIDC1,GBIDC2) From GOBJET
End


######################################################################################
## Etiquette ajoutﾃｩe par le superviseur (Objet FXM) 04/08/2011 14:41:24 (CBO)
######################################################################################
$ACTION

Case ACTION
    When "OUVRE"
        Gosub OUVRE
    When "CREATION"
        Gosub CREATION
    When "LIENS"
        Gosub LIENS
    When "ANNULE"
        Gosub ANNULE
    When "MODIF"
        Gosub MODIF
    When "APRES_MODIF"
        Gosub APRES_MODIF
    When "APRES_MODIF"
        Gosub LIENS
    When "AVANT_CHOIX"
        Affzo [M:FXM1]
    When "INICRE"
        Gosub INICRE
    When "INICRE_LIG"
        Gosub INICRE
    When "INIMOD_LIG"
        Gosub INICRE
    When "INICRE_MOD"
        Gosub INICRE_MOD
        Gosub ANNULE

    When "DEFLIG"
        Gosub DEFLIG
    When "INICRE_LIG"
        Gosub INI_LIG

    When "INIMOD_LIG"
        Gosub INI_LIG

    When "OUVRE_BOITE"
        Gosub OUVRE_BOITE
    When "FILGAUCHE"
        Gosub FILGAUCHE
    When "SETBOUT"       : Gosub SETBOUT
    When "EXEBOUT"       : Gosub EXEBOUT

    When "VERROU"           : Gosub VERROU
    When "DEVERROU"         : Gosub DEVERROU


    When Default
Endcase
Return

######################################################################################

$OUVRE
Local Integer WMAXIDMVT, WTYPDIMEAL, WNDIME
Local Char WABRMSK(30), WSSUFFIXE(20), WSCODESUFF(20), WMSK(30)
Local Decimal WTYPTYP
Local Char SVTRACE(GLONTRA)
# FQ91070
Global Integer G_HASELT

    Gosub GLOBFXM

    # recherche de la clef la plus rﾃｩcente
    Read [FXM]FXM0 Last
    If fstat
        WMAXIDMVT = 0
    Else
        WMAXIDMVT = [F:FXM]IDMVT
    Endif


    If !clalev([F:ATY])
        Local File ATYPE [ATY]
    Endif
    If !clalev([F:ATX])
        Local File ATEXTE [ATX]
    Endif

    If !clalev([F:AWI])
        Local File AWINDOW [AWI]
    Endif
        If !clalev([F:AMK])
        Local File AMSK [AMK]
    Endif
    If !clalev([F:AMZ])
        Local File AMSKZON [AMZ]
    Endif

    If !clalev([F:LOF])
        Local File LAYOUTFAS  [LOF]
    Endif
    If !clalev([F:FAS])
        Local File FXDASSETS  [FAS]
    Endif
   # CBO 20120227 FQ80394
    If GPHY = G_OUI
        If !clalev([F:PHY])
            Local File PHYELT  [PHY]
        Endif
    Endif

    # CBO 2012.01.22 FQ69691B
    If !clalev([F:CNX])
        Local File CONTEXT  [CNX]
    Endif

    If !clalev([F:AMP]) #FQ91070
        Local File AMSKPAR [AMP]
    Endif

    Read [AMZ]CODE = "FXDMVT1"; "DIME"
    If [F:AMZ]CODTYP = "A"
        WTYPDIMEAL = 1
    Else
        WTYPDIMEAL = 0
    Endif

Return

######################################################################################
$VERROU

    If func GLOBIENS.IS_SYMBOLE_LOCKED ("FXM", [M:FXM0]CPY, num$([M:FXM0]IDMVT)) = 0
        # Test si la sociﾃｩtﾃｩ est verrouillﾃｩe sur cette table pour en empﾃｪcher la modification
        OK = 0
        Return
    Endif

    # sinon on gﾃｨre ﾃ la main le verrou identifiant+sociﾃｩtﾃｩ pour permettre le contrﾃｴle
    # de tester si le lockage de la table pour la sociﾃｩtﾃｩ est possible
    If func GLOBIENS.LOCK_SYMBOLE_CPY ("FXM", [M:FXM0]CPY, num$([M:FXM0]IDMVT), 0) = 0
      # on teste rien, normalement ﾃｧa marche puisqu'on a pu locker l'enregistrement
      # et que la sociﾃｩtﾃｩ n'est pas lockﾃｩe
    Endif
Return

$DEVERROU

    Call UNLOCK_SYMBOLE_CPY ("FXM", [M:FXM0]CPY, num$([M:FXM0]IDMVT)) From GLOBIENS
Return


$DEFLIG
    Default Mask [FXM1]
    Default File [FXD]
#    CRIT = 'IDMVT = "' + '[M:FXM0]IDMVT' + '"'
    CRIT  = 'OBJMVT = "' + '[M:FXM0]OBJMVT' + '" and'
    CRIT += 'TYPMVT = "' + '[M:FXM0]TYPMVT' + '" and'
    CRIT = 'REF1MVT = "' + '[M:FXM0]REF1MVT' + '" and'
    CRIT = 'SEQMVT = "' + '[M:FXM0]SEQMVT' + '" '

    FICLIG = "FXDMVTD"
    ABLIG  = "FXD"
    ZONLIG = "REF1MVT"
Return


######################################################################################


$LIENS

    # FQ91070
    If dim(G_HASELT) < 0
        Global Integer G_HASELT
    Endif
    G_HASELT = G_NON
    If GPHY = G_OUI and [M:FXM0]OBJMVT = GFXM_IMMOS and [M:FXM0]TYPMVT = GFXM_SPLIT
        If clalev([F:PHY]) = 0
            Local File PHYELT  [PHY]
        Endif
        Look [PHY] PHY5(1)=[M:FXM0]REF1MVT
        If !fstat
            G_HASELT = G_OUI
        Endif
        If clalev([F:PHY])
            Close Local File [PHY]
        Endif
#        If G_HASELT = G_OUI and WCODMSK = "FASSPL1"
#            WCODMSK = "FASSPL1B"
#        Endif
    Endif

    nolign = 1
    For [FXD] Where IDMVT = [M:FXM0]IDMVT

        [M:FXM1]CODTYP(nolign-1) = func LIRTYPMSK([M:FXM0]OBJMVT, [M:FXM0]TYPMVT,
&         [F:FXD]CODZONE, [F:FXD]DPRPLN, [M:FXM1]DIMEMAX(nolign-1), WTYPTYP,
&         [M:FXM1]DESI(nolign-1), WABRMSK, WMSK)

        If [F:FXD]DPRPLN > 0
            # CBO 2012.01.22 FQ69691B : ajout de la fct
            If func IS_PLANOK([F:FXM]CPY, [F:FXD]DPRPLN) > 0
                [M:FXM1]DESI(nolign-1) = [M:FXM1]DESI(nolign-1) - "(" + mess([F:FXD]DPRPLN, GML_NPLAN, 1) + ")"
            Else
                [M:FXM1]DESI(nolign-1) = [M:FXM1]DESI(nolign-1) - ":" + func AFNC.MES5(mess(23, GML_IMPFXD, 1), num$([F:FXD]DPRPLN), "", "", "", "")
            Endif
        Endif
        If WTYPDIMEAL
            I = func TRTDIME(WTYPDIMEAL, [F:FXD]DIME, [F:FXD]CODZONE, [M:FXM1]DIMEMAX(nolign-1), WNDIME, WSSUFFIXE, WSCODESUFF)
        Else
            I = func TRTDIME(WTYPDIMEAL, num$([F:FXD]DIME), [F:FXD]CODZONE, [M:FXM1]DIMEMAX(nolign-1), WNDIME, WSSUFFIXE, WSCODESUFF)
        Endif
        If WSSUFFIXE <> ""
            [M:FXM1]DESI(nolign-1) -= WSSUFFIXE
        Endif

        [M:FXM1]                  = [F:FXD]
        [M:FXM1]IDMVT(nolign-1)   = [M:FXM0]IDMVT
        [M:FXM1]TYPNUM(nolign-1)  = WTYPTYP

        [M:FXM1]CREFLG(nolign-1) = nolign

        nolign += 1
    Next
    [M:FXM1]ABSZONE = nolign-1
    Affzo [M:FXM1]ABSZONE

    # Il faut faire le remplissage et le grisage du tableau en deux fois sinon ﾃｧa ne marche pas bien
    For nolign = 1 To [M:FXM1]ABSZONE
        Diszo [M:FXM1]CODZONE(nolign-1)
        Diszo [M:FXM1]DIME(nolign-1)
        Diszo [M:FXM1]DPRPLN(nolign-1)

        If [M:FXM0]STATMVT = GFXM_ARCHIVE
            Diszo [M:FXM1]VALZONE(nolign-1)
        Else
            Actzo [M:FXM1]VALZONE(nolign-1)
        Endif
    Next

    If [M:FXM0]STATMVT = GFXM_ARCHIVE
        Disable 65 # suppression ligne
        Disable 73 # insertion ligne
    Else
        Enable 65 # suppression ligne
        Enable 73 # insertion ligne
    Endif

Return


$INI_LIG

    If [M:FXM0]IDMVT = 0
        WMAXIDMVT += 1
        [M:FXM0]IDMVT = WMAXIDMVT
    Endif

    [M:FXM1]IDMVT = [M:FXM0]IDMVT
    [FXD]IDMVT = [M:FXM0]IDMVT
    [FXM]IDMVT = [M:FXM0]IDMVT
    Affzo [M:FXM1]IDMVT

Return

$INICRE
    If [M:FXM0]IDMVT = 0
        WMAXIDMVT += 1
        [M:FXM0]IDMVT = WMAXIDMVT
        Affzo [M:FXM0]IDMVT
    Endif

    [M:FXM1]IDMVT = [M:FXM0]IDMVT
    [FXD]IDMVT = [M:FXM0]IDMVT
    [FXM]IDMVT = [M:FXM0]IDMVT
    Affzo [M:FXM1]IDMVT

    Gosub SOC_SITE

Return
#
$CREATION

  #  Par dﾃｩfaut : "Modification rﾃｩussie"
    GMODOK = G_OUI

    For nolign = 1 To [M:FXM1]ABSZONE
        If [M:FXM1]CODZONE(nolign - 1) <> ""
            Raz  [F:FXD]
            [F:FXD]       = [M:FXM1]
            [M:FXM1]IDMVT(nolign-1) = [M:FXM0]IDMVT
            [FXD]IDMVT = [M:FXM0]IDMVT
            Write [F:FXD]
            If ( fstat ) Then
                GOK = 0
                Break
            Endif
        Endif
    Next
    If !GOK
        Return
    Endif
Return
#
$INICRE_MOD
Return

$APRES_MODIF
Return

$MODIF

  #  Par dﾃｩfaut : "Modification rﾃｩussie"
    GMODOK = G_OUI

    Delete [FXD] Where IDMVT = [M:FXM0]IDMVT
    Gosub CREATION
Return

$ANNULE
    Delete [FXD] Where IDMVT = [M:FXM0]IDMVT
Return

$SOC_SITE

    If [M:FXM0]CPY = "" or [M:FXM0]FCY = ""

        [M:FXM0]CPY = ""
        [M:FXM0]FCY = ""
        If [F:FXM]OBJMVT = GFXM_DEPENSE
            Read [F:LOF]LOF0(1) = [F:FXM]REF1MVT
            If fstat = 0
                [M:FXM0]CPY = [F:LOF]CPY
                [M:FXM0]FCY = [F:LOF]FCY
            Endif

        Elsif [F:FXM]OBJMVT = GFXM_IMMOS
            Read [F:FAS]FAS0 = [F:FXM]REF1MVT
            If fstat = 0
                [M:FXM0]CPY = [F:FAS]CPY
                [M:FXM0]FCY = [F:FAS]FCY
            Endif
        Elsif [F:FXM]OBJMVT = GFXM_PHY
            Read [F:PHY]PHY0 = [F:FXM]REF1MVT
            If fstat = 0
                [M:FXM0]CPY = [F:PHY]CPY
                [M:FXM0]FCY = [F:PHY]FCY
            Endif
        Endif
    Endif
    [F:FXM]CPY = [M:FXM0]CPY
    [F:FXM]FCY = [M:FXM0]FCY
Return



$GLOBFXM

# dﾃｩfinition de globales propres ﾃ la gestion de l'import des mouvements
Global Integer GFXM_DEPENSE, GFXM_IMMOS, GFXM_PHY
Global Integer GFXM_SORTIE, GFXM_TRANSFERT, GFXM_IMPUT, GFXM_METHODE, GFXM_MODIF
Global Integer GFXM_SPLIT # FQ91070
Global Integer GFXM_ATRAITER, GFXM_ENIMPORT, GFXM_ARCHIVE, GFXM_REJET
Global Char GFMTDAT(30), GFMTDEC(30), GFMTDATTXT(30)
Global Integer GREPART_VIA_QTY # FQ91070 ﾃｩclatement : rﾃｩpart des montants par rapport ﾃ la qtﾃｩ
Global Integer GNBFAS_FXD # FQ91070 ﾃｩclatement : nombre prﾃｩcisﾃｩ (doit primer sur la qtﾃｩ si ecl par qtﾃｩ)
Global Char GCODE_REPART(10)  # FQ91070 ﾃｩclatement : action de rﾃｩpartir (pseudo champ)

Local Char WCH(30)

    GCODE_REPART = "REPART" # FQ91070
    GFXM_DEPENSE   = 1
    GFXM_IMMOS     = 2
    GFXM_PHY       = 6

    GFXM_SORTIE    = 1
    GFXM_TRANSFERT = 2
    GFXM_IMPUT     = 3
    GFXM_METHODE   = 4
    GFXM_MODIF     = 5
    GFXM_SPLIT     = 6 # FQ91070

    GFXM_ATRAITER  = 1
    GFXM_ENIMPORT  = 2
    GFXM_ARCHIVE   = 3
    GFXM_REJET     = 4

    # format de date et de sﾃｩparateur decimal
    Call PARAM("", "FMTFXMDAT", WCH) From ADOVAL
    If WCH = ""
        GFMTDAT = "4"
    Elsif WCH = "JJMMAA"
        GFMTDAT = "1"
    Elsif WCH = "JJMMAAAA"
        GFMTDAT = "2"
    Elsif WCH = "AAMMJJ"
        GFMTDAT = "3"
    Elsif WCH = "AAAAMMJJ"
        GFMTDAT = "4"
    Endif
    GFMTDATTXT = WCH

    WCH = ""
    Call PARAM("", "FMTFXMDEC", WCH) From ADOVAL
    If WCH = ""
        GFMTDEC = "."
    Else
        GFMTDEC = left$(WCH, 1)
    Endif

Return


$SETBOUT
    If [F:FXM]TRACE = ""
        Call VIREBOUT(CHAINE,"B") From GOBJET
    Endif
    #FQ91070 bouton ﾃｩxﾃｩcuter
#    If [F:FXM]STATMVT = 3 # = archivﾃｩ
# FQ100398/13
    If [F:FXM]STATMVT = 3 or [F:FXM]OBJMVT = GFXM_PHY
        Call VIREBOUT(CHAINE,"c") From GOBJET
    Endif

Return

$EXEBOUT
  #-------------
    Case BOUT
    When "B"  : # trace
        SVTRACE = GTRACE
        GTRACE = [F:FXM]TRACE
        Call LEC_TRACE From LECFIC
        GTRACE = SVTRACE
    Endcase
  #-------------
Return

$OUVRE_BOITE
    Local Char TIROIR(10)(10)

    TIROIR(1) = "GAU_CHE" + num$(find("FX2", OBJLIS(1..10)))
    TIROIR(2) = "GAU_CHE" + num$(find("FX3", OBJLIS(1..10)))
    TIROIR(3) = "GAU_CHE" + num$(find("FX4", OBJLIS(1..10)))
    TIROIR(4) = "GAU_CHE" + num$(find("FX5", OBJLIS(1..10)))
    TIROIR(5) = "GAU_CHE" + num$(find("FX6", OBJLIS(1..10)))
    TIROIR(6) = "GAU_CHE" + num$(find("FX7", OBJLIS(1..10)))
Return

$FILGAUCHE

    Case currbox
        When TIROIR(1)
            FILGAUSUP = "TYPMVT = 1 and (STATMVT = GFXM_ATRAITER or STATMVT = GFXM_REJET)"
        When TIROIR(2)
            FILGAUSUP = "TYPMVT = 2 and (STATMVT = GFXM_ATRAITER or STATMVT = GFXM_REJET)"
        When TIROIR(3)
            FILGAUSUP = "TYPMVT = 3 and (STATMVT = GFXM_ATRAITER or STATMVT = GFXM_REJET)"
        When TIROIR(4)
            FILGAUSUP = "TYPMVT = 5 and (STATMVT = GFXM_ATRAITER or STATMVT = GFXM_REJET)"
        When TIROIR(5)
            FILGAUSUP = "STATMVT = GFXM_REJET"
        When TIROIR(6)
            FILGAUSUP = "TYPMVT = 6 and (STATMVT = GFXM_ATRAITER or STATMVT = GFXM_REJET)"
    Endcase
Return


#** Infos pour utiliser le modﾃｨle d'action mﾃｩtier du mouvement traitﾃｩ
#*
#*
#* @param POBJMVT       Objet
#* @param PTYPMVT       Type de mouvement
#* @param RCODWIN       fenﾃｪtre de la fct ou du trt
#* @param RTRTMAM       action mﾃｩtier demandﾃｩe
#* @param RTRTALIMMSK   trt oﾃｹ a lieu le ALIM_MASK
#* @param RABVMSKMAM    abrﾃｩviation du maque de l'action mﾃｩtier
#* @param RTRTGENERE    traitement gﾃｩnﾃｩrﾃｩ de l'action = W0 + action + P
#*!
Subprog REFFXM(POBJMVT, PTYPMVT, RCODWIN, RTRTMAM, RTRTALIMMSK, RABVMSKMAM, RTRTGENERE)

Value Integer POBJMVT, PTYPMVT
Variable Char RCODWIN
Variable Char RTRTMAM
Variable Char RTRTALIMMSK
Variable Char RABVMSKMAM
Variable Char RTRTGENERE

    RCODWIN = ""
    RTRTMAM = ""
    RTRTALIMMSK = ""
    RABVMSKMAM = ""
    RTRTGENERE = ""

    If POBJMVT = GFXM_DEPENSE
        If PTYPMVT = GFXM_MODIF
            RCODWIN = "OLOF"
        Endif

    Elsif POBJMVT = GFXM_IMMOS
        If PTYPMVT = GFXM_SORTIE
            RCODWIN = "FASISSM"
            RTRTMAM = "FASISS"
            RTRTALIMMSK = "FXDINT"
            RABVMSKMAM = "[M:FASS]"
        Elsif PTYPMVT = GFXM_TRANSFERT
            RCODWIN = "FASTRFM"
            RTRTMAM = "FASTRF"
            RTRTALIMMSK = "FXDINT"
            RABVMSKMAM = "[M:FASM]"
        Elsif PTYPMVT = GFXM_IMPUT
            RCODWIN = "FASTRFCU"
            RTRTMAM = "FASTRFC"
            RTRTALIMMSK = "FXDINT"
            RABVMSKMAM = "[M:FASC]"
        Elsif PTYPMVT = GFXM_METHODE
#            RCODWIN = "FASTRFCU"
#            RTRTMAM = "FASTRFC"
#            RTRTALIMMSK = "FXDINT"
#            RABVMSKMAM = "[M:FASC]"
        Elsif PTYPMVT = GFXM_MODIF
             RCODWIN = "OFAS"
        Elsif PTYPMVT = GFXM_SPLIT # FQ91070

            # fenﾃｪtre d'ﾃｩclatement si pas d'ﾃｩlﾃｩment physique reliﾃｩ :
             RCODWIN = "FASSPL"

            # fenﾃｪtre d'ﾃｩclatement si au moins un ﾃｩlﾃｩment physique reliﾃｩ :

            # G_HASELT et HASELT : trﾃｨs proches mais plus sur de tester sur les 2

            If dim(G_HASELT) >= 0     # variable globale de l'intﾃｩgration des mouvements
                If G_HASELT = G_OUI
                    RCODWIN = "FASSPE"
                Endif
            Endif
#            If dim(HASELT) >= 0       # variable locale de TRTFASSPL
#                If HASELT = G_OUI
#                    RCODWIN = "FASSPE"
#                Endif
#            Endif
        Endif

    Elsif POBJMVT = GFXM_PHY

        If PTYPMVT = GFXM_SORTIE
            RCODWIN = "PHYISSM"
            RTRTMAM = "PHYISS"            # n'existe pas !!!
            RTRTALIMMSK = "FXDINT"
            RABVMSKMAM = "[M:PHYS]"
        Elsif PTYPMVT = GFXM_TRANSFERT
            RCODWIN = "PHYTRFM"
            RTRTMAM = "PHYTRF"            # n'existe pas !!!
            RTRTALIMMSK = "FXDINT"
        Elsif PTYPMVT = GFXM_MODIF
            RCODWIN = "OPHY"
        Endif
    Endif

    If RTRTMAM <> ""
        RTRTGENERE = "W0" + RTRTMAM + "P"
    Endif
End


#** Lecture d'un champ d'une action mﾃｩtier
#* retourne le type de donnﾃｩes : [F:AMZ]CODTYP
#*
#* @param POBJMVT     Objet
#* @param PTYPMVT     Type de mouvement
#* @param PCODZONE    champ ﾃｩcran
#* @param PDPRPLN     plan traitﾃｩ (si utile)
#* @param RDIMEMAX    dim maxi du champ : permet de contrﾃｴler les indices ﾃｩventuels
#* @param RTYPTYP     type de donnﾃｩes du champ [F:AMZ]CODTYP ou si trouvﾃｩ : [F:ATY]TYPTYP (type interne)
#* @param RDESI       dﾃｩsignation du champ (code si dﾃｩsi vide)
#* @param RABVMSK     abrﾃｩviation du masque du champ
#* @param RMSK        masque du champ # FQ91070
#*!
Funprog LIRTYPMSK(POBJMVT, PTYPMVT, PCODZONE, PDPRPLN, RDIMEMAX, RTYPTYP,
& RDESI, RABVMSK, RMSK)

Value Integer POBJMVT, PTYPMVT
Value Char PCODZONE
Value Integer PDPRPLN
Variable Decimal RDIMEMAX, RTYPTYP
Variable Char RDESI()
Variable Char RABVMSK(), RMSK()

Local Char WCODWIN(30), WCODMSK(30), WTRTMAM(30), WTRTALIMMSK(30), WABVMSKMAM(30), WTRTGENERE(30)
Local Integer I, WBTROUVE

    RDIMEMAX = 1
    RTYPTYP  = 0
    RDESI = ""
    RABVMSK = ""
    RMSK = ""

    Call REFFXM(POBJMVT, PTYPMVT, WCODWIN, WTRTMAM, WTRTALIMMSK, WABVMSKMAM, WTRTGENERE)

    Read [AWI]AWI0 = WCODWIN
    If fstat
        End ""
    Endif

    # FQ91070
    If POBJMVT = GFXM_IMMOS and PTYPMVT = GFXM_SPLIT and PCODZONE = GCODE_REPART
        RTYPTYP = 1 # menu Local 1
        RDESI = "-->" - PCODZONE
        RABVMSK = ""

        End "M"
    Endif

    WBTROUVE = 0
    I = -1
    While I < [F:AWI]NBMSK

        WCODMSK = ""
        If I = -1
            WCODMSK = [F:AWI]MSKENT
        Else
            WCODMSK = [F:AWI]NOMMSK(I)
            # FQ91070
            If dim(G_HASELT) < 0
                Global Integer G_HASELT
                G_HASELT = G_NON
            Endif
            If G_HASELT = G_OUI and WCODMSK = "FASSPL1"
                WCODMSK = "FASSPL1B"
            Endif
        Endif

        If WCODMSK <> ""
            Read [AMZ]CODE = WCODMSK; PCODZONE

            If fstat = 0
                Read [AMK]CODMSK = WCODMSK
                RABVMSK = [F:AMK]ABRMSK
                RMSK    = WCODMSK #FQ91070

                WBTROUVE = 1
                RDIMEMAX = [F:AMZ]DIME
                # FQ91070 : on force le nombre de lignes pour les tableaux (code activitﾃｩ de dimensionnement...)
                If RDIMEMAX = 0
                    If [F:AMK]TYPBLOC([F:AMZ]NUMBLOC - 1) = 1
                        RDIMEMAX = 999
                    Endif
                Endif
#                If PDIME >= RDIMEMAX
#                    RDIMEMAX = -RDIMEMAX
#                    End ""
#                Endif
                Read [ATY]CODTYP = [F:AMZ]CODTYP
                If fstat
#                    RTYPTYP = [F:AMZ]CODTYP #FQ91070
                    RTYPTYP = 0
                Else
                    RTYPTYP = [F:ATY]TYPTYP
                Endif

                If left$(PCODZONE,  6) = "USRFLD"
                    Call LECTEXTRA(RDESI, "FREFLD", PCODZONE, num$(POBJMVT), GABZLCPY) From ATEXTRA
                    If RDESI <> ""
                        WBTROUVE = 2
                    Endif
                Else
                    Read [ATX]NUMERO = GLANGUE ; [F:AMZ]INTIT
                    If fstat = 0
                        RDESI = [F:ATX]TEXTE
                        WBTROUVE = 2
                    Endif
                Endif
                Break
            Endif
        Endif
        I += 1
    Wend

    If WBTROUVE = 0
        End ""
    Endif
    If RDESI = ""
        RDESI = PCODZONE
    Endif

End [F:AMZ]CODTYP


#** construction d'une date en fonction de la date passﾃｩe en alpha
#*  et du format de l'interface
#*
#* @param PVALEURALPHA  date passﾃｩe en alpha
#* @param RERREUR       erreur ﾃｩventuelle
#*!
Funprog CSTRDATE(PVALEURALPHA, RERREUR)
Value Char PVALEURALPHA
Variable Integer RERREUR

Local Date WDT
Local Integer WJJ, WMM, WAA

    WDT = [0/0/0]
    RERREUR = 0
    If PVALEURALPHA = ""
        End WDT
    Endif

    If GFMTDAT = "1" or GFMTDAT = "3"
        If len(PVALEURALPHA) <> 6
            RERREUR = 1
            End WDT
        Endif
    Elsif GFMTDAT = "2" or GFMTDAT = "4"
        If len(PVALEURALPHA) <> 8
            RERREUR = 1
            End WDT
        Endif
    Elsif GFMTDAT = "5"
        If len(PVALEURALPHA) <> 10
            RERREUR = 1
            End WDT
        Endif
    Endif

    # JJMMAA
    If GFMTDAT = "1"
        WJJ = val(left$(PVALEURALPHA, 2))
        WMM = val(mid$(PVALEURALPHA, 3, 2))
        WAA = 2000 + val(mid$(PVALEURALPHA, 5, 2) )
    # JJMMAAAA
    Elsif GFMTDAT = "2"
        WJJ = val(left$(PVALEURALPHA, 2))
        WMM = val(mid$(PVALEURALPHA, 3, 2))
        WAA = val(mid$(PVALEURALPHA, 5, 4) )
    # AAMMJJ
    Elsif GFMTDAT = "3"
        WJJ = val(mid$(PVALEURALPHA, 5, 2))
        WMM = val(mid$(PVALEURALPHA, 3, 2))
        WAA = 2000 + val(left$(PVALEURALPHA, 2))
    # AAAAMMJJ
    Elsif GFMTDAT = "4"
        WJJ = val(mid$(PVALEURALPHA, 7, 2))
        WMM = val(mid$(PVALEURALPHA, 5, 2))
        WAA = val(left$(PVALEURALPHA, 4))
    # AAAA-MM-JJ
    Elsif GFMTDAT = "5"
        WJJ = val(mid$(PVALEURALPHA, 9, 2))
        WMM = val(mid$(PVALEURALPHA, 6, 2))
        WAA = val(left$(PVALEURALPHA, 4))
    Endif

    # contrﾃｴle primaire
    If func GLOFUNC.ISDATEOK(WJJ, WMM, WAA) = 0
        RERREUR = 2
        End WDT
    Endif

    WDT = gdat$(WJJ, WMM, WAA)
End WDT


#** construction d'un montant en fonction de celui passﾃｩ en alpha
#*  et du format de l'interface
#*
#* @param PVALEURALPHA    montant alpha
#* @param PTYPTYP         type : <= 3 pas de +-,. >= 4 il peut y en avoir
#* @param RERREUR         erreur ﾃｩventuelle
#*!
Funprog CSTRMTDEC(PVALEURALPHA, PTYPTYP, RERREUR)
Value Char PVALEURALPHA
Value Decimal PTYPTYP
Variable Integer RERREUR

Local Decimal WMT
Local Integer I

    WMT = 0
    RERREUR = 0

    PVALEURALPHA = vireblc(PVALEURALPHA, 4)
    If PVALEURALPHA = ""
        End WMT
    Endif
    Call QUENUM(PVALEURALPHA, PTYPTYP, RERREUR)
    If RERREUR
        End WMT
    Endif

    If GFMTDEC = "."
        WMT = val(PVALEURALPHA)
        End WMT
    Endif

    I = instr(1, PVALEURALPHA, GFMTDEC)
    If I = 0
        WMT = val(PVALEURALPHA)
        End WMT
    Endif

    WMT = val(left$(PVALEURALPHA, I - 1))
    WMT += val("0." + right$(PVALEURALPHA, I + 1))

End WMT


#** Analyse de la syntaxe d'un montant
#*
#*
#* @param PVALEURALPHA  montant alpha
#* @param PTYPTYP       type : <= 3 pas de +-,. >= 4 il peut y en avoir
#* @param RERREUR       erreur ﾃｩventuelle
#*!
Subprog QUENUM(PVALEURALPHA, PTYPTYP, RERREUR)
Value Char PVALEURALPHA
Value Decimal PTYPTYP
Variable Integer RERREUR

Local Integer I, J, CPTRDEC, CPTRSGN

    CPTRDEC = 0
    CPTRSGN = 0
    J = len(PVALEURALPHA)
    For I = 1 To J
        If mid$(PVALEURALPHA, I, 1) <> GFMTDEC and
&          mid$(PVALEURALPHA, I, 1) <> "-" and
&          mid$(PVALEURALPHA, I, 1) <> "+" and
&          (mid$(PVALEURALPHA, I, 1) < "0" or
&          (mid$(PVALEURALPHA, I, 1) > "9"))
            RERREUR = 2
            Break
        Endif
        If mid$(PVALEURALPHA, I, 1) = GFMTDEC
            CPTRDEC += 1
        Endif
        If mid$(PVALEURALPHA, I, 1) = "-" or
&          mid$(PVALEURALPHA, I, 1) = "+"
            CPTRSGN += 1
        Endif

    Next I
    If PTYPTYP < 4
        If CPTRDEC or CPTRSGN
            RERREUR = 4
        Endif
    Else
        If CPTRDEC > 1 or CPTRSGN > 1
            RERREUR = 3
        Endif
    Endif
End

# ----------------------------------------------------------------------------
#**
#* Cette fonction permet de contrﾃｴler que le champ passﾃｩ en paramﾃｨtre se trouve
#* bien dans la table diverse qui liste les champs modifiables de l'objet mﾃｩtier traitﾃｩ
#*
#* Retourne 0 si le champ ne peut pas ﾃｪtre modifiﾃｩ par Import,
#*          1 si le champ peut ﾃｪtre modifiﾃｩ par Import
#* Retourne le numﾃｩro de la table diverse ﾃ complﾃｩter ﾃｩventuellement
#*
#* @param POBJ    : Objet mﾃｩtier
#* @param PCHAMP  : Nom du Champ traitﾃｩ
#*
#* @param RTAB    : Numﾃｩro de la table diverse correspondant ﾃ l'objet mﾃｩtier
#*!
Funprog IS_MVT_AUTORISE (POBJ, PCHAMP, RTAB)
Value Integer    POBJ
Value Char       PCHAMP
Variable Integer RTAB

    Local Integer WNUMTAB, WCOD

    WCOD = 0

    Case  POBJ
    When 1
        WNUMTAB = GTD_MVT_LOF
    When 2
        WNUMTAB = GTD_MVT_FAS
    When 6
        WNUMTAB = GTD_MVT_PHY
    Endcase

    # Tables diverses
    If clalev([F:ADI])  = 0
        Local File ATABDIV [ADI]
    Endif
    Read [ADI]CODE= WNUMTAB;PCHAMP
    If fstat
        WCOD = 0
        RTAB = WNUMTAB
    Else
        WCOD = 1
    Endif
End WCOD


# ----------------------------------------------------------------------------
#**
#* Cette fonction permet de contrﾃｴler la valeur du champ de type USRFLDAn
#* dans la table diverse associﾃｩe ﾃ la Zone Libre
#*
#* Retourne 0 si le champ ne se trouve pas dans la table diverse associﾃｩe ﾃ la zone libre,
#*          1 si le champ se trouve dans la table diverse associﾃｩe ﾃ la zone libre
#* Retourne le numﾃｩro de la table diverse ﾃ complﾃｩter ﾃｩventuellement
#*
#* @param PCPY    : Sociﾃｩtﾃｩ
#* @param POBJ    : Objet mﾃｩtier
#* @param PCHAMP  : Nom du Champ traitﾃｩ
#* @param PVAL    : Valeur du Champ traitﾃｩ
#*
#* @param RTAB    : Numﾃｩro de la table diverse correspondant ﾃ l'objet mﾃｩtier
#*!
Funprog IS_ZLIB_OK(PCPY, POBJ, PCHAMP, PVAL, RTAB)
Value Char       PCPY
Value Integer    POBJ
Value Char       PCHAMP
Value Char       PVAL
Variable Integer RTAB

    Local Integer J, LNUMTAB, WCOD

    If clalev([F:FRF]) = 0
        Local File FREFLD [FRF]
    Endif    # table des zones libres
    If clalev([F:ADI])  = 0
        Local File ATABDIV [ADI]
    Endif    # Tables diverses

    WCOD = 1
    RTAB = 0

    If left$(PCHAMP,7) = "USRFLDA"
        J= val(right$(PCHAMP, 8))
        If J=0
            J=10
        Endif
        Read [FRF]FRF0 = POBJ;PCPY
        If (fstat = 5)
            Read [FRF]FRF0 = POBJ;""
        Endif
        If [F:FRF]ALPREF(J-1) > 0
            LNUMTAB = [F:FRF]ALPREF(J-1)
            Read [ADI]CODE= LNUMTAB;PVAL
            If fstat
                WCOD = 0
                RTAB = LNUMTAB
            Else
                WCOD = 1
            Endif
        Else
            WCOD = 0
            RTAB = LNUMTAB
        Endif
    Endif

End WCOD


# FQ91070 ajout de PDIMEMAX pour gﾃｩrer l'affichage d'1 tableau en indice 0
#** Gestion de la zone DIME (num en V5 et alpha ensuite)
#*
#*
#* @param PBTYPALPHA  gestion alpha de la dimension (alpha pour version >= V6 et numﾃｩrique avant)
#* @param PSDIME      dimension
#*                      rien ou 0 : champ non dimensionnﾃｩ
#*                      numﾃｩrique : champ dimensionnﾃｩ (ex : axe analytique en V5)
#*                      alpha     : champ dimensionnﾃｩ oﾃｹ il faut trouver l'ﾃｩquivalence du rang (ex : axe analytique en V6 et +)
#* @param PSCODZONE   champ
#* @param PDIMEMAX    dimension maxi du champ
#* @param RNDIME      dimension retournﾃｩe (aprﾃｨs ﾃｩventuelle transcodification)
#* @param RSSUFFIXE   suffixe construit, ex : (3)
#* @param RSCODESUFF  code + suffixe, ex : CCED(3)
#*!
Funprog TRTDIME(PBTYPALPHA, PSDIME, PSCODZONE, PDIMEMAX, RNDIME, RSSUFFIXE, RSCODESUFF)
Value Integer PBTYPALPHA
Value Char PSDIME(), PSCODZONE()
Value Decimal PDIMEMAX
Variable Integer RNDIME
Variable Char RSSUFFIXE(), RSCODESUFF()

    Local Integer WBNUM

    RNDIME = 0
    RSSUFFIXE = ""
    RSCODESUFF = PSCODZONE

    WBNUM = 0
    If PBTYPALPHA
        If PSDIME = ""
            If PDIMEMAX <= 1 # FQ91070
                End 1
            Else
                PSDIME = "0"
            Endif
        # FQ98900
        Elsif PSDIME = "0" and PDIMEMAX <= 1
            End 1
        Endif

        If len(PSDIME) = 1
            If PSDIME >= "0" and PSDIME <= "9"
                RNDIME = val(PSDIME)
                WBNUM = 1
            Endif
        Elsif len(PSDIME) = 2
            If left$(PSDIME, 1) >= "0" and left$(PSDIME , 1) <= "9" and
&              mid$(PSDIME, 2, 1) >= "0" and mid$(PSDIME, 2 , 1) <= "9"
                RNDIME = val(PSDIME)
                WBNUM = 1
            Endif
        Elsif len(PSDIME) = 3
            If left$(PSDIME, 1) >= "0" and left$(PSDIME , 1)<= "9" and
&              mid$(PSDIME, 2, 1) >= "0" and mid$(PSDIME, 2 , 1) <= "9" and
&              mid$(PSDIME, 3, 1) >= "0" and mid$(PSDIME, 3 , 1) <= "9"
                RNDIME = val(PSDIME)
                WBNUM = 1
            Endif
        Endif

        If WBNUM
            If RNDIME > 0
                RSSUFFIXE = "(" + num$(RNDIME) + ")"
                RSCODESUFF += RSSUFFIXE
            Else # FQ91070
                RSSUFFIXE = "(0)"
                RSCODESUFF += RSSUFFIXE
            Endif
            End 1
        Endif

        RSSUFFIXE = "(" + PSDIME + ")"
        RSCODESUFF += RSSUFFIXE
        End 0
    Else
        If val(PSDIME) > 0
            RSSUFFIXE = "(" + PSDIME + ")"
            RSCODESUFF += RSSUFFIXE
            # CBO 2012.02.23 FQ80109
            RNDIME = val(PSDIME)
            End 1
        Endif
    Endif
End 0


# CBO 2012.01.22 FQ69691B

#** Vﾃｩrif si le nﾂｰ de plan passﾃｩ existe bien pour la sociﾃｩtﾃｩ
#*  retourne -1 si pb, 0 si non trouvﾃｩ ou le nﾂｰ de plan si OK
#*
#* @param PCPY      sociﾃｩtﾃｩ
#* @param PNUMPLAN  nﾂｰ du plan
#*!
Funprog IS_PLANOK(PCPY, PNUMPLAN)
Value Char PCPY()
Value Integer PNUMPLAN

Local Integer I, J

    If PCPY = "" or PNUMPLAN <= 0
        End -1
    Endif

    I = 0
    For [CNX] Where CPY = PCPY

        For J = 0 To ([F:CNX]NBPLC - 1)
            If [F:CNX]PLNCAA(J) = PNUMPLAN
                I = PNUMPLAN
                Break(2)
            Endif
        Next J
    Next
End I


