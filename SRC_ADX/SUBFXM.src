Subprog B2_VALZONE(VALEUR)
Variable Char    VALEUR()

Local Char WT(50)(2), WLIB(30)
    # format de date et de sﾃｩparateur decimal
    Call PARAM("", "FMTFXMDAT", WT(0)) From ADOVAL
    Call PARAM("", "FMTFXMDEC", WT(1)) From ADOVAL

    WT(0) = mess(42, GML_IMPFXD, 1) - "=" - WT(0)
    WT(1) = mess(43, GML_IMPFXD, 1) - "=" - WT(1)

    Infbox WT(0..1)
End

# FQ91070
#** Dﾃｩcodif de la valeur si le champ correspond ﾃ un menu
#*
#*
#* @param VALEUR
#*!
Subprog B3_VALZONE(VALEUR)
Variable Char    VALEUR()

Local Char WLIB(80), WCODTYP(10), WABRMSK(10), WMSK(30), WDESI(50)
Local Decimal WTYPTYP
Local Date WDT
Local Integer WERR


    If [M:FXM0]OBJMVT = GFXM_IMMOS and [M:FXM0]TYPMVT = GFXM_SPLIT and [M:FXM1]CODZONE(nolign-1) = GCODE_REPART
        [F:AMZ]NOLIB = 1
    Else
        WCODTYP= func LIRTYPMSK([M:FXM0]OBJMVT, [M:FXM0]TYPMVT,
&         [M:FXM1]CODZONE(nolign-1), [M:FXM1]DPRPLN(nolign-1), [M:FXM1]DIMEMAX(nolign-1), WTYPTYP,
&         [M:FXM1]DESI(nolign-1), WABRMSK, WMSK)
    Endif

    If [F:AMZ]NOLIB
        WLIB = VALEUR - "=" - mess(val(VALEUR), [F:AMZ]NOLIB, 1)
        Infbox WLIB Titled mess(15, 7, 1) - num$([F:AMZ]NOLIB)
    Elsif [M:FXM1]TYPNUM(nolign-1) = 8
        WDT = func SUBFXM.CSTRDATE(VALEUR, WERR)
        If WERR = 0
            Infbox format$("D:" + GFMDAT4, WDT)
        Endif
    Elsif WCODTYP = "ADI"
        Read [AMP]CODPAR = 1; WMSK; [M:FXM1]CODZONE(nolign-1); "ADI"
        If fstat = 0
            Call LECTEXTRA(WDESI, "ATABDIV", "LNGDES", [F:AMP]VALPAR, [M:FXM1]VALZONE(nolign-1)) From ATEXTRA

            WLIB = VALEUR - "=" - WDESI
            Infbox WLIB Titled "ATABDIV =" - [F:AMP]VALPAR
        Endif
    Else
        If [F:ATY]OBJLIEN <> ""
            Call OBJET([F:ATY]OBJLIEN, VALEUR, "") From GOBJET
        Endif
    Endif

End

Subprog CL_CHXOBJ(VALEUR)
Variable Char    VALEUR()

Local Char XX(30)

    If [M:FXM0]CPY = "" or [M:FXM0]REF1MVT = "" # ie l'objet n'existe pas ou non sﾃｩlectionnﾃｩ
        End
    Endif

    If [M:FXM0]OBJMVT = GFXM_IMMOS
        Call OBJET("FAS", [M:FXM0]REF1MVT, "") From GOBJET
    Elsif [M:FXM0]OBJMVT = GFXM_PHY
        Call OBJET("PHY", [M:FXM0]REF1MVT, "") From GOBJET
    Elsif [M:FXM0]OBJMVT = GFXM_DEPENSE
        Call OBJET("LOF", XX, [M:FXM0]REF1MVT + "@" + [M:FXM0]REF2MVT) From GOBJET
    Endif
End


