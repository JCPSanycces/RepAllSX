Subprog C_VALZONE(VALEUR)
Variable Char VALEUR

Local Integer WERR

# FQ91070 si [M:FXM1]TYPNUM non affectﾃｩ on va le chercher
Local Integer WDPRPLN
Local Decimal WTYPTYP
Local Char WABRMSK(30), WMSK(30)
    If [M:FXM1]TYPNUM(nolign-1) < 1
        [M:FXM1]CREFLG(nolign-1) = nolign
        [M:FXM1]CODTYP(nolign-1) = func LIRTYPMSK([M:FXM0]OBJMVT, [M:FXM0]TYPMVT, [M:FXM1]CODZONE(nolign-1),
&         WDPRPLN, [M:FXM1]DIMEMAX(nolign-1), WTYPTYP,
&         [M:FXM1]DESI(nolign-1), WABRMSK, WMSK)

        [M:FXM1]TYPNUM(nolign-1) = WTYPTYP
    Endif

    If [M:FXM1]TYPNUM(nolign-1) < 7
        WMT = func SUBFXM.CSTRMTDEC(VALEUR, [M:FXM1]TYPNUM(nolign-1), WERR)
        If WERR
#            GMESSAGE = "Format numﾃｩrique invalide"
            GMESSAGE = func AFNC.MES5(mess(2, GML_IMPFXD, 1), [M:FXM1]CODZONE(nolign-1), VALEUR, "", "", "")

            mkstat = 2
        Endif
    Elsif [M:FXM1]TYPNUM(nolign-1) = 8
        WDT = func SUBFXM.CSTRDATE(VALEUR, WERR)
        If WERR
#            GMESSAGE = "Format de date invalide"
            GMESSAGE = func AFNC.MES5(mess(3, GML_IMPFXD, 1), [M:FXM1]CODZONE(nolign-1), VALEUR, "", "", "")

            mkstat = 2
        Endif
    Endif
End
