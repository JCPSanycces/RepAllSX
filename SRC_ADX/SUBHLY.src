#<AdxTL>@(#)0.0.0.0 $Revision$
Call OBJET("HLY",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When "LIENS"     : Gosub LIENS
 When "RAZCRE"    : Gosub RAZCRE
 When "RAZDUP"    : Gosub RAZDUP
 When "SETBOUT"   : Gosub SETBOUT
Endcase

Return

#ADNGO - X3PEOP-1237 - 2016-10-18 - START
$OUVRE
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Return
#ADNGO - X3PEOP-1237 - 2016-10-18 - END

#ADNGO - X3PEOP-1237 - 2016-10-18 - START
$SETBOUT
CHAINE += "A"
Return
#ADNGO - X3PEOP-1237 - 2016-10-18 - END

$INICRE
$INIMOD
For I=0 To [F:HLY]NBRDAY-1
 [F:HLY]HLYDAY(I) = gdat$(day([F:HLY]HLYDAY(I)),month([F:HLY]HLYDAY(I)),[F:HLY]YEA)
Next I
Sorta [F:HLY]NBRDAY [F:HLY]HLYDAY Order By [F:HLY]HLYDAY(indice)
Return

#JOJAC - 2016-10-31 - START
$RAZCRE
GCURLEG=""
Return
#JOJAC - 2016-10-31 - END

$RAZDUP
Effzo NBRDAY,HLYDAY,DAY1
Return

$LIENS

#ADNGO - X3PEOP-1237 - 2016-10-18 - START
#JASMI - 2016-11-01 - START
#If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#JASMI - 2016-11-01 - END
If dim([M:HLY1]LEG)>0 & [M:HLY1]LEG <> "" : GCURLEG=[M:HLY1]LEG : Endif
#ADNGO - X3PEOP-1237 - 2016-10-18 - END

For I=0 To [F:HLY]NBRDAY-1
 [M]DAY1(I) = day$([F:HLY]HLYDAY(I))
Next I

#JASMI - 2016-11-04 - START
  If [M:HLY1]FCY <> ""
    Grizo [M:HLY1]CPY
    Grizo [M:HLY1]LEG
  Else
    Actzo [M:HLY1]CPY
    Actzo [M:HLY1]LEG
  Endif
#JASMI - 2016-11-04 - END

Return

#ADNGO - X3PEOP-1237 - 2016-10-18 - START
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
#ADNGO - X3PEOP-1237 - 2016-10-18 - END

Subprog AS_HLYDAY(VALEUR)
Variable Date     VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(1,1,[M]YEA)
Endif
End

Subprog C_HLYDAY(VALEUR)
Variable Date    VALEUR
Call UNICITE(VALEUR,[M]HLYDAY(0..[M]NBRDAY-1)) From OBJDIV
End

Subprog AM_HLYDAY(VALEUR)
Variable Date    VALEUR
[M]DAY1(nolign-1) = day$(gdat$(day(VALEUR),month(VALEUR),[M]YEA))
End

Subprog C_YEA(VALEUR)
Variable Decimal VALEUR
If VALEUR<1600 : mkstat = 1 : End : Endif
End

Subprog AS_NBRDAY
If [M]NBRDAY=0 & [M]YEA<>0
 Local Integer I , NBFER
 Call FERIES([M]YEA,NBFER,[M]HLYDAY)
 [M]NBRDAY = NBFER
 For I=0 To [M]NBRDAY-1
  [M]DAY1(I) = day$([M]HLYDAY(I))
 Next I
 Affzo HLYDAY,DAY1
Endif
End

####################################################
## Calcul des jours fériés d'une année
####################################################
Subprog FERIES(ANNEE,NBFER,TBFER)
Value    Integer ANNEE
Variable Integer NBFER
Variable Date    TBFER(1..)

Local Integer I
Local Date    PAQUES , FERIE

NBFER = 0

## Jours fixes

NBFER += 1 : TBFER(NBFER) = gdat$(01,01,ANNEE)
NBFER += 1 : TBFER(NBFER) = gdat$(01,05,ANNEE)
#JASMI - 2016-10-18 - START
#NBFER += 1 : TBFER(NBFER) = gdat$(08,05,ANNEE)
#NBFER += 1 : TBFER(NBFER) = gdat$(14,07,ANNEE)
#NBFER += 1 : TBFER(NBFER) = gdat$(15,08,ANNEE)
#NBFER += 1 : TBFER(NBFER) = gdat$(01,11,ANNEE)
#NBFER += 1 : TBFER(NBFER) = gdat$(11,11,ANNEE)
#JASMI - 2016-10-18 - END
NBFER += 1 : TBFER(NBFER) = gdat$(25,12,ANNEE)
#JASMI - 2016-10-18 - START
NBFER += 1 : TBFER(NBFER) = gdat$(26,12,ANNEE)
#JASMI - 2016-10-18 - END

## Jours dépendant de paques

Call PAQUES(ANNEE,PAQUES)

#JASMI - 2016-10-20 - START
#FERIE = PAQUES+1  : Gosub ADDFER : # Lundi de paques
#FERIE = PAQUES+39 : Gosub ADDFER : # Ascension
#FERIE = PAQUES+50 : Gosub ADDFER : # Lundi de pentecôte
If find(GCURLEG,"ZAF","BRI","FRA","ZMB") > 0
  FERIE = PAQUES+1  : Gosub ADDFER : # Lundi de paques
Endif
If find(GCURLEG,"FRA") > 0
  FERIE = PAQUES+39 : Gosub ADDFER : # Ascension
  FERIE = PAQUES+50 : Gosub ADDFER : # Lundi de pentecôte
Endif
#JASMI - 2016-10-20 - END

Sorta NBFER TBFER

End

$ADDFER
If !find(FERIE,TBFER(1..NBFER))
 NBFER += 1 : TBFER(NBFER) = FERIE
Endif
Return

####################################################
## Calcul de la date de paques (Toutes dates)
####################################################
Subprog PAQUES(ANNEE,PAQUES)
Value    Integer ANNEE
Variable Date    PAQUES

Local Integer G,C,H,I,J,L,MM,JJ

G = mod(ANNEE,19)
C = int(ANNEE/100)
H = mod(C-int(C/4)-int((8*C+13)/25)+19*G+15,30)
I = H-int(H/28)*(1-int(H/28)*int(29/(H+1))*int((21-G)/11))
J = mod(ANNEE+int(ANNEE/4)+I+2-C+int(C/4),7)
L = I-J
MM = 3+int((L+40)/44)
JJ = L+28-31*int(MM/4)
PAQUES = gdat$(JJ,MM,ANNEE)
End

######################################################################################
## Section automatically added (screen HLY1) 10/18/2016 09:34:27 (ANSA)
######################################################################################
Subprog IB_FCY
End
#ADNGO - X3PEOP-1237 - 2016-10-18 - START
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  If clalev([F:FCY])=0 : Local File FACILITY [FCY]  : Endif
  Read [FCY]FCY0 = VALEUR
  If !fstat
    GCURLEG = [F:FCY]LEG
    [M:HLY1]CPY=[F:FCY]LEGCPY   : Affzo [M:HLY1]CPY
    [M:HLY1]LEG=GCURLEG  : Affzo [M:HLY1]LEG
  Endif

  If VALEUR <> ""
    Grizo [M:HLY1]CPY
    Grizo [M:HLY1]LEG
  Else
    Actzo [M:HLY1]CPY
    Actzo [M:HLY1]LEG
  Endif

End
#ADNGO - X3PEOP-1237 - 2016-10-18 - END

######################################################################################

#ADNGO - X3PEOP-1237 - 2016-10-18 - START
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  GCURLEG=VALEUR
End
#ADNGO - X3PEOP-1237 - 2016-10-18 - END

