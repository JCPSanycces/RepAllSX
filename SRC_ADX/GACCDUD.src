#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(30)(1..10) , VALEUR(10)
PARAM(1) = "324904"
PARAM(2) = "298408.66"
PARAM(3) = "1"
Call SAISIE_CHAR(VALEUR,PARAM,"DDUD","GACCDUD","") From GSAISIE
End


######################################################
## Saisie des échéances d'une facture               ##
######################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub VALID
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FIN"         : Gosub FIN
 When Default
Endcase
Return

$OUVRE
Local    Integer NUMERO, LIGPCE
Local    Decimal TOTAL
Local    Integer FLMOD
Local    Integer LIGECH , STAT , TYPTIERS , OK , MODIF

Local    Integer TYPDUD
Local    Char    XPARAM(10)

NUMERO = val(PARAM(1))
TOTAL  = val(PARAM(2))
FLMOD  = val(PARAM(3))

Local Integer OCONSULT, I
Local Char    OBOUT(50)(1..12)
OCONSULT = GCONSULT
For I=1 To dim(OBOUT)
 OBOUT(I) = evalue("GBOUT"+num$(I))
Next I

If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS    [AUS] : Endif
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev([F:PYD])=0 : Local File PAYMENTD   [PYD] : Endif
If clalev([F:TAM])=0 : Local File TABPAM     [TAM] : Endif

Read [DAE]DAE2 = NUMERO
If fstat : FIN = 1 : Return : Endif
Read [DUD]DUD1(1) = NUMERO
If fstat
 Read [DUD]DUD0(2) = [F:DAE]TYP;[F:DAE]NUM
 If !fstat
  NUMERO = [F:DUD]ACCNUM
  Read [DAE]DAE2 = NUMERO
  If fstat : FIN = 1 : Return : Endif
 Else
  FIN = 1 : Return
 Endif
Endif
LIGPCE = [F:DAE]LIN
Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
If fstat : FIN = 1 : Return : Endif
Call LECTURE("CPY",[F:HAE]CPY,"") From CONTOBJ
Call GETSOC([F:HAE]FCY) From DEVSUB
If dim(GSDDMGT)>0
 Call PARAM(GSOCIETE,"SDDMGT",XPARAM) From ADOVAL
 GSDDMGT=val(XPARAM)
Endif
Return

$DEBUT
Raz [M]
[M]AMTTOT = TOTAL
[M]DUDCUR  = [F:HAE]CUR
[M]DUDCUR2 = [F:HAE]CUR
nolign = 0
For [DUD]DUD1 Where ACCNUM=NUMERO
 nolign += 1
 [M] = [F:DUD]
 [M]PAYTOT += [F:DUD]PAYCUR+[F:DUD]TMPCUR
# Lecture des reglements
 Filter [PYD] Where DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
&             Order By Key CLE=DUDNUM;DUDLIG
 Read [F:PYD]CLE First
 If fstat = 0
  [M]REG(nolign-1) = [F:PYD]NUM
 Endif
 Filter [PYD]
 If [M]TYPDUD=0 : [M]TYPDUD =[F:DUD]TYPDUD  : Endif
Next
[M]NBECH = nolign
Sorta [M]NBECH [M]NBECH Order By [M]DUDDAT(indice)
Affzo
If dim(GSDDMGT)>0 & GSDDMGT<>2
 Chgfmt [M]UMRNUM With "-K:"+num$(type([M]UMRNUM)-10)
Endif
If FLMOD
 Actzo
Else
 Grizo
Endif
MODIF = 0
Return

$SETBOUT
Raz ETABOU
If MODIF
 ETABOU(GENRE) = 1
Endif
ETABOU(GBFIN) = 1
Return

$APRES_MODIF
If FLMOD
 MODIF = 1
Endif
Return

$VALID
If sum([M]AMTCUR(0..[M]NBECH-1))<>[M]AMTTOT
 GERR = 1 : GMESSAGE = mess(24,119,1) : Return
#  Total des échéances incorrect
Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1 : MODIF = 0 : Endif
Return

# Validation
$TR1
GOK = 1
Trbegin [DUD]
 Gosub VALECH
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$VALECH
# Effacement des échéances qui ne sont plus dans le tableau
# ou qui ont un montant = 0
For [DUD]DUD1 Where ACCNUM=NUMERO
 LIGECH = find([F:DUD]DUDLIG,[M]DUDLIG(0..[M]NBECH-1))
 If !LIGECH | [M]AMTCUR(LIGECH-1)=0
  Call HISTOECH("DUD",2,[F:HAE]ACCDAT)From MODECHE
  Delete [DUD]
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE"-num$(NUMERO) : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif

# Recalcul des montants société et reporting
Local Char DEVLED(GLONCUR)
Local Char CODLED(GLONLED)
Local Decimal AROLED, COURS

#--- Position des 3 devises par rapport à l'Euro
Call SETFLGDEV([F:HAE]CUR,[F:CPY]CPY,[F:HAE]RATDAT) From CPTDIV

Call GETSOC([F:HAE]FCY) From DEVSUB
Call LECLED([F:CPY]CPY,GTYPGEN,CODLED,DEVLED) From CPTDIV
If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
Call LECTURE("TCU",DEVLED,"") From CONTOBJ
AROLED = [F:TCU]CURRND

COURS  = [F:HAE]RATMLT/[F:HAE]RATDIV

If [M]NBECH>0
 Call CONVERT_DEV([F:HAE]CUR,[L]DEVLED,[L]DEVLED,NBECH,[M]AMTCUR(0..[M]NBECH-1),[M]AMTLOC,
&  COURS,[F:HAE]TYPRAT,[F:HAE]RATDAT,AROLED) From CPTSUB
Endif

# Mise à jour des échéances modifiées
LIGECH = 0
For nolign=1 To [M]NBECH
 If [M]DUDLIG(nolign-1)<>0 & [M]AMTCUR(nolign-1)<>0
  Readlock [DUD]DUD1 = NUMERO;[M]DUDLIG(nolign-1)
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE"-num$(NUMERO) : Break
  Elsif fstat
   GOK=0 : Call RSTA("DUD",num$(NUMERO)) From GLOCK : Break
  Endif
  [F:DUD]    = [M]
  [F:DUD]LIG = LIGPCE
  [L]TYPDUD =[F:DUD]TYPDUD
  Call SLDECH("DUD")From MODECHE
  Local Decimal EXERCICE, PERIODE
  Call GETPERSOC([F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
  [F:DUD]FIY = EXERCICE
  [F:DUD]PER = PERIODE
  If dim([M]UMRNUM)>0 & GSDDMGT=2 & [M]TYPDUD=2 & [M]BPRTYP=1 & [F:DUD]UMRNUM=""
   Call LEC_TAM(GSOCIETE,[F:DUD]PAM) From CPTLEC
   If !fstat & [F:TAM]SDDFLG=2
    Gosub TIT From WOTAM : GMESSAGE  = TIT-":"-[F:DUD]PAM
    GMESSAGE += "\"+mess(270,117,1)
    GERR=1 : GOK = 0 : Break
   Endif
  Endif
  Rewrite [DUD]
  If fstat
   GOK=0 : Call FSTA("DUD") From GLOCK : Break
  Endif
  Call HISTOECH("DUD",1,[F:HAE]ACCDAT)From MODECHE
  LIGECH = max(LIGECH,[F:DUD]DUDLIG)
 Endif
Next nolign
If GOK<1 : Return : Endif

If [L]TYPDUD=0 : [L]TYPDUD=4 : Endif

# Création des nouvelles échéances
For nolign=1 To [M]NBECH
 If [M]DUDLIG(nolign-1)=0 & [M]AMTCUR(nolign-1)<>0
  Raz [F:DUD]
  [F:DUD]       = [F:HAE]
  [F:DUD]       = [F:DAE]
  [F:DUD]FCY    = [F:DAE]FCYLIN
  [F:DUD]BPRPAY = [F:DUD]BPR
  [F:DUD]DUDSTA = 2
  [F:DUD]PAMTYP = 1
  [F:DUD]       = [M]
  [F:DUD]LIG    = LIGPCE
  [F:DUD]DUDLIG = LIGECH+1
  If dim([F:DUD]CREDAT)>0 : [F:DUD]CREDAT = datesyst : Endif
  If dim([F:DUD]CREUSR)>0 : [F:DUD]CREUSR = GUSER : Endif
  LIGECH += 1
  If [F:DAE]MTC>="A" & [F:DAE]MTC<="ZZZZZ"
   [F:DUD]PAYCUR = [F:DUD]AMTCUR
   [F:DUD]PAYLOC = [F:DUD]AMTLOC
  Endif
  [F:DUD]TYPDUD=[L]TYPDUD
  If dim([M]UMRNUM)>0 & GSDDMGT=2 & [M]TYPDUD=2 & [M]BPRTYP=1 & [F:DUD]UMRNUM=""
   Call LEC_TAM(GSOCIETE,[F:DUD]PAM) From CPTLEC
   If !fstat & [F:TAM]SDDFLG=2
    Gosub TIT From WOTAM : GMESSAGE  = TIT-":"-[F:DUD]PAM
    GMESSAGE += "\"+mess(270,117,1)
    GERR=1 : GOK = 0 : Break
   Endif
  Endif
  Call KEYDUD("DUD") From MODECHE
  Call SLDECH("DUD")From MODECHE
  Write [DUD]
  If fstat
   GOK=0 : Call FSTA("DUD") From GLOCK : Break
  Endif
  Call HISTOECH("DUD",1,[F:HAE]ACCDAT)From MODECHE
 Endif
Next nolign
Affzo [M]AMTLOC
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$FIN
GCONSULT = OCONSULT
For I=1 To dim(OBOUT)
 Assign "GBOUT"+num$(I) With OBOUT(I)
Next I
Return


#######################################################
## Etiquettes de contrôle
#######################################################

Subprog C_NBECH
Case status
 When 65
  Gosub SETNOL
  Gosub TST_ANU
 When 68,83
  Local Integer NOL
  For NOL=nolign-1 To nolign1-1
   Gosub TST_ANU
   If mkstat : Break : Endif
  Next NOL
Endcase
End

$TST_ANU
If [M]PAYCUR(NOL)<>0 | [M]TMPCUR(NOL)<>0
 GMESSAGE = mess(25,119,1) : mkstat = 2
# Echéance réglée, annulation impossible
Elsif [M]SOINUM(NOL)<>""
 GMESSAGE = mess(30,119,1) : mkstat = 2
# Echéance su relevé, annulation impossible
Endif
Return

Subprog C_BPRTYP(VALEUR)
Variable Integer VALEUR
Call LECTURE("BPR",[M]BPRPAY,"") From CONTOBJ
If VALEUR=1 & [F:BPR]BPCFLG<>2
 GMESSAGE = [M]BPRPAY-":"-mess(2,119,1) : # Ce tiers n'est pas un client
 mkstat = 2 : End
Elsif VALEUR=2 & [F:BPR]BPSFLG<>2
 GMESSAGE = [M]BPRPAY-":"-mess(3,119,1) : # Ce tiers n'est pas un fournisseur
 mkstat = 2 : End
Elsif VALEUR=3 & [F:BPR]BPTFLG<>2
 GMESSAGE = [M]BPRPAY-":"-mess(71,119,1) : # Ce tiers n'est pas un transporteur
 mkstat = 2 : End
Elsif VALEUR=4 & [F:BPR]FCTFLG<>2
 GMESSAGE = [M]BPRPAY-":"-mess(72,119,1) : # Ce tiers n'est pas un factor
 mkstat = 2 : End
Elsif VALEUR=5 & [F:BPR]REPFLG<>2
 GMESSAGE = [M]BPRPAY-":"-mess(73,119,1) : # Ce tiers n'est pas un représentant
 mkstat = 2 : End
Elsif VALEUR=6 & [F:BPR]BPRACC<>2
 mkstat = 2 : End
Endif
If dim([M]UMRNUM)>0 & VALEUR<>[M]BPRTYP & GSDDMGT=2 & [M]TYPDUD=2
 If VALEUR<>1
  For I=0 To [M]NBECH-1
   [M]UMRNUM(I)=""
  Next
 Elsif [M]BPRTYP<>1
  Local Char NEWUMR(GLONMDT)
  Call INIT_UMRNUM(GSOCIETE,[M]BPRPAY,2,2,[L]NEWUMR) From INVSDDLIB
  For I=0 To [M]NBECH-1
   Call LEC_TAM(GCURLEG,[M]PAM(I)) From CPTLEC
   If [F:TAM]SDDFLG=2
    [M]UMRNUM(I)=[L]NEWUMR
   Endif
  Next
 Endif
 Affzo [M]UMRNUM
Endif
End

Subprog AS_DUDDAT(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
If ([M]AMTCUR(NOL)<>0 & abs([M]AMTCUR(NOL))<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL)))
&  or [M]SOINUM(NOL)<>""
 mkstat = 2 : End
Endif
End

# Initialisation du code adresse , aprés la modification de la date
#(cad une nouvelle ligne ds le tableau des échéances)
# - si on rajoute une 1ère ligne , la nouvelle ligne devient la ligne 1 le code adresse est : si tiers client alors BPAPYR (de fiche client),
# si tiers fournisseur BPAPAY (de fiche fournisseur), sinon l'adresse par défaut du Tiers;
#- si on rajoute une ligne 2 ou 3 ou ... : proposer le code adresse règlement de la 1ière ligne d'échéance.
Subprog AM_DUDDAT(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
If NOL=0
 If [M]BPRTYP=1
  Call LECTURE("BPC",[M]BPRPAY,"") From CONTOBJ
  [M]BPAPAY(0) = [F:BPC]BPAPYR
 Elsif [M]BPRTYP=2
  Call LECTURE("BPS",[M]BPRPAY,"") From CONTOBJ
  [M]BPAPAY(0) = [F:BPS]BPAPAY
 Else
   Call LECTURE("BPR",[M]BPRPAY,"") From CONTOBJ
   [M]BPAPAY(0) = [F:BPR]BPAADD
 Endif
Else
 [M]BPAPAY(NOL) = [M]BPAPAY(0)
Endif
Affzo [M]BPAPAY(NOL)
End

Subprog AS_PAM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If ([M]AMTCUR(NOL)<>0 & abs([M]AMTCUR(NOL))<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL)))
&  or [M]SOINUM(NOL)<>""
 mkstat = 2 : End
Endif
If dim([M]UMRNUM)>0 & GSDDMGT=2 & [M]BPRTYP=1 & [M]TYPDUD=2
 If [M]AMTCUR(NOL)<>0 & abs([M]PAYCUR(NOL))+abs([M]TMPCUR(NOL))<>0
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_PAM(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
Local Integer OK
If VALEUR<>[M]PAM(NOL)
 If ([M]SOINUM(NOL)<>"" | [M]SOI(NOL)=2)
  Call LEC_TAM(GCURLEG, VALEUR) From CPTLEC
  If [F:TAM]SOI=""  :# Pas de code relevé
   If [M]SOINUM(NOL)="" :# Relevé "A faire"
    # Mode de règlement non concerné par les relevés
    OK = 1 : Call AVERTIR(mess(38,117,1),OK) From GESECRAN
    If [L]OK=1 : mkstat = 2 : End : Else : [M]SOI(NOL) = 1 : Affzo [M]SOI(NOL) : Endif
   Else
    # Mode de règlement non concerné par les relevés
    GMESSAGE = mess(38,117,1)
    mkstat = 2 : End
   Endif
  Endif
 Endif
 If dim([M]UMRNUM)>0
  Call LEC_TAM(GCURLEG,VALEUR) From CPTLEC
  If [F:TAM]SDDFLG<>2 : Raz [M]UMRNUM(NOL) : Endif
 Endif
Endif
End

Subprog B2_AMTCUR(VALEUR)
Variable Decimal VALEUR
VALEUR = [M]AMTTOT-sum([M]AMTCUR(0..nolign-2))-sum([M]AMTCUR(nolign..[M]NBECH-1))
End

Subprog AS_AMTCUR(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If (VALEUR<>0 & abs(VALEUR)<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL)))
&  or [M]SOINUM(NOL)<>""
 mkstat = 2 : End
Endif
GBOUT2 = mess(26,119,1) : # Solde
End

Subprog C_AMTCUR(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If [M]AMTCUR(NOL)<>0 & sgn(VALEUR)<>sgn([M]AMTCUR(NOL)) : mkstat=1 : End : Endif
If abs(VALEUR)<abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL))
 GMESSAGE = mess(27,119,1) : mkstat = 2
# Montant inférieur au règlement
Endif
End

Subprog D_DEP(VALEUR)
Variable Char    VALEUR()
# Initialisation des escomptes et agios
If [M]BPRTYP=1
 Call INIT_ESCOMPTE([M]BPRPAY,GSOCIETE,"C",VALEUR) From CPTSUB
Elsif [M]BPRTYP=2
 Call INIT_ESCOMPTE([M]BPRPAY,GSOCIETE,"F",VALEUR) From CPTSUB
Endif
End

Subprog AS_FLGFUP(VALEUR)
Variable Integer VALEUR
If [M]BPRTYP<>1
 mkstat = 1
Else
 Gosub SETNOL
 If [M]AMTCUR(NOL)<>0 & abs([M]AMTCUR(NOL))<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL))
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_LEVFUP(VALEUR)
Variable Decimal VALEUR
If [M]BPRTYP<>1
 mkstat = 1
Else
 Gosub SETNOL
 If [M]AMTCUR(NOL)<>0 & abs([M]AMTCUR(NOL))<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL))
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_FLGPAZ(VALEUR)
Variable Integer VALEUR
Local Char CHAINE(10)
If [M]BPRTYP=1 : mkstat = 2 : End : Endif
Call PARAM([F:DAE]FCYLIN,"FLGPAZ",CHAINE) From ADOVAL
If val(CHAINE)<>2
 VALEUR = len(mess(0,510,1))
 mkstat = 2 : End
Endif
Gosub SETNOL
If ([M]AMTCUR(NOL)<>0 & abs([M]AMTCUR(NOL))<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL)))
 mkstat=2 : End
Endif
If GMODU(3)=2  :# Tiers
 Call LECTURE("AUS",GUSER,"") From CONTOBJ
 Local Char LLEVPAZ(3)
 Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
 If VALEUR>val(LLEVPAZ)
  mkstat=2 : End
 Endif
Endif
End

Subprog D_FLGPAZ(VALEUR)
Variable Integer VALEUR
Call LECTURE("BPS",[M]BPRPAY,"") From CONTOBJ
# X3-71518 Don't consider Payment hold flag of the supplier
#If dim([F:BPS]PAYLOKFLG)>0 & [F:BPS]PAYLOKFLG=2
# VALEUR = 1
#Else
Call LECTURE("AUS",GUSER,"") From CONTOBJ
Local Char LLEVPAZ(3)
Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
If nolign>1
 VALEUR = min(val(LLEVPAZ),[M]FLGPAZ(nolign-2))
Else
 VALEUR = val(LLEVPAZ)
Endif
#Endif
End

Subprog C_FLGPAZ(VALEUR)
Variable Integer VALEUR
If GMODU(3)=2  :# Tiers
 Call LECTURE("AUS",GUSER,"") From CONTOBJ
 Local Char LLEVPAZ(3)
 Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
 If VALEUR>val(LLEVPAZ)
  GMESSAGE = mess(29,119,1) : mkstat = 2 : End
  # Niveau de bon à payer non autorisé
 Endif
Endif
End

Subprog D_PAM(VALEUR)
Variable Char    VALEUR()
If nolign>1
 VALEUR = [M]PAM(nolign-2)
Endif
End

Subprog AS_SOI(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]SOINUM(NOL)<>"" : mkstat = 2 : End : Endif
Call LEC_TAM(GCURLEG, [M]PAM(NOL)) From CPTLEC
If [F:TAM]SOI=""  :# Mode de règlement non concerné par les relevés
 mkstat=2 : End
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog D_SOI(VALEUR)
Variable Integer VALEUR
If nolign>1
 VALEUR = [M]SOI(nolign-2)
Endif
End

Subprog D_FLGFUP(VALEUR)
Variable Integer VALEUR
If nolign>1
 VALEUR = [M]FLGFUP(nolign-2)
Endif
End

Subprog AM_BPRPAY(VALEUR)
Variable Char    VALEUR()
If clalev([F:TPT])=0: Local File TABPAYTERM [TPT] : Endif
Local Integer I
Local Char CNDPAY(15)
Local Integer FLGSDD : FLGSDD=0
If dim([M]UMRNUM)>0
 Local Char NEWUMR(GLONMDT)
 [L]FLGSDD=1
 If GSDDMGT=2 & [M]BPRTYP=1 & [M]TYPDUD=2
  [L]FLGSDD=2
  Call INIT_UMRNUM(GSOCIETE,VALEUR,2,2,[L]NEWUMR) From INVSDDLIB
 Endif
Endif

# Initialisation du code condition de paiement
Call LECTURE("BPR",VALEUR,"") From CONTOBJ
If [F:BPR]BPCFLG=2
 Call LECTURE("BPC",[F:BPR]BPRNUM,"") From CONTOBJ
 Call INIPTE([F:BPC]BPCPYR,"","C",CNDPAY) From TRTX3
Elsif [F:BPR]BPSFLG=2
 Call LECTURE("BPS",[F:BPR]BPRNUM,"") From CONTOBJ
 Call INIPTE ([F:BPS]BPRPAY,"","F",CNDPAY) From TRTX3
Endif
If CNDPAY<>""
 Call CONTTPT(CNDPAY,GCURLEG,"","",[F:HAE]FCY,"",[F:HAE]CPY) From SUBTPT
 If mkstat : End : Endif
 For I=0 To [M]NBECH-1
  [M]PAM(I) = [F:TPT]PAM
  If [L]FLGSDD=1
   Raz [M]UMRNUM(I) :   Affzo [M]UMRNUM(I)
  Elsif FLGSDD=2
   Call LEC_TAM(GCURLEG,[M]PAM(I)) From CPTLEC
   If !fstat & [F:TAM]SDDFLG=2
    [M]UMRNUM(I) = [L]NEWUMR
   Else
    [M]UMRNUM(I) = ""
   Endif
   Affzo [M]UMRNUM(I)
  Endif
 Next I
 Affzo [M]PAM
Endif

# Initialisation du code adresse
If [M]BPRTYP=1
 Call LECTURE("BPC",VALEUR,"") From CONTOBJ
 [M]BPAPAY(0) = [F:BPC]BPAPYR
Elsif [M]BPRTYP=2
 Call LECTURE("BPS",VALEUR,"") From CONTOBJ
 [M]BPAPAY(0) = [F:BPS]BPAPAY
Else
 Call LECTURE("BPR",VALEUR,"") From CONTOBJ
 [M]BPAPAY(0) = [F:BPR]BPAADD
Endif
Affzo [M]BPAPAY(0)
For I=1 To [M]NBECH -1
 [M]BPAPAY(I) = [M]BPAPAY(0)
 Affzo [M]BPAPAY(I)
Next
End

Subprog C_BPAPAY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<>[M]BPAPAY
  Read [BPA]BPA0 = 1;[M:DIA]BPRPAY;VALEUR
 If fstat
  # Adresse inexistante
  GMESSAGE = mess(10,119,1)
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_DEP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Call CNTDEPTYP(0,[M:DIA]ACCNUM,"",VALEUR) From CPTCNT
If mkstat : End : Endif
End

######################################################################################
Subprog AS_BPRPAY(VALEUR)
Variable Char    VALEUR()
If dim([M]UMRNUM)>0 & GSDDMGT=2 & [M]BPRTYP=1 & [M]TYPDUD=2 & [M]PAYTOT<>0
 mkstat=2 : End
Endif
End

######################################################################################
Subprog AS_BPRTYP(VALEUR)
Variable Integer VALEUR
If dim([M]UMRNUM)>0 & GSDDMGT=2 & VALEUR=1 & [M]TYPDUD=2 & [M]PAYTOT<>0
 mkstat=2 : End
Endif
End

######################################################################################
Subprog AS_UMRNUM(VALEUR)
Variable Char    VALEUR()
If GSDDMGT<>2 | [M]BPRTYP<>1 | [M]TYPDUD<>2 : mkstat=2 : End : Endif

Gosub SETNOL
If [M]AMTCUR(NOL)<>0 & abs([M]PAYCUR(NOL))+abs([M]TMPCUR(NOL))<>0 : mkstat=2 : End : Endif

Call LEC_TAM(GCURLEG,[M]PAM(NOL)) From CPTLEC
If fstat | [F:TAM]SDDFLG<>2 : mkstat=1 : End : Endif

If VALEUR="" : Call INIT_UMRNUM(GSOCIETE,[M]BPRPAY,2,2,VALEUR) From INVSDDLIB : Endif
End

Subprog C_UMRNUM(VALEUR)
Variable Char    VALEUR()
If GSDDMGT<>2 | [M]BPRTYP<>1 | [M]TYPDUD<>2 : End : Endif

Call CTL_UMRNUM2(VALEUR,GSOCIETE,[M]BPRPAY,[M]PAM(nolign-1)) From INVSDDLIB
If mkstat : End : Endif
End

