#<AdxTL>@(#)0.0.0.0 $Revision$
# Sous-pro pour zones du masque STKACC : Interface comptable des stocks  SUBSAC
# Prog modifié pour la v 140
########################################
Subprog C_PRODAT(VALEUR)
Variable Date    VALEUR

#- Go see if we need to display the "Processing already carried out for this date" message
   Call CHECK_PRIOR ([M:DIA]FINFCY, VALEUR)         #X3-59814.n

#X3-59814.so - below replaced with above call
#  # Issue 101389 - 2017-02-09 by ERMIL : Filter on this site or global
#  Filter [SAC] Where FINFCY=[M:DIA]FINFCY | FINFCY=""
#  Read [SAC]SAC0(1)=VALEUR
#  Filter [SAC] # 101389.n
#  If !fstat
#     #"Traitement déjà effectué à cette date"
#     GMESSAGE = mess(165,196,1)
#     GERR = 2
#  Endif
#X3-59814.eo - end of commented out block

  # "La date sera forcée au jour de traitement effectif si le dernier traitement s'est bien terminé."
  If [M:DIA]ABT = 1 & VALEUR <> [0/0/0]
    GMESSAGE = mess(199,196,1) : GERR = 2 : VALEUR = [0/0/0] : End
  Endif

  If VALEUR < [M:DIA]LASPRODAT & VALEUR <> [0/0/0]  # 12/06/01
    # "Cette date est antérieure au dernier traitement"
    GMESSAGE = mess(166,196,1)
    GERR = 2    # 101389.n - no longer a hard error, just a warning
    #mkstat = 2 # 101389.o
  Endif

  If VALEUR > date$
    mkstat=2
    GMESSAGE = mess(177,196,1) :#"doit être antérieure ou égale à la date du jour"
  Endif
End

########################################
Subprog C_FINFCY(VALEUR)
Variable Char    VALEUR()
Local Decimal NO_EXE,NO_PER
Local Char    SOC, LACCIFA
Local Integer LTYPLED, LRET
Local Date    LPRODAT
If GBATCH
    End
Endif

Call PARAM(VALEUR,"ACCIFA",LACCIFA) From ADOVAL
GACCIFA = val(LACCIFA)
If GACCIFA = 1
#  "Le paramètre général Interface comptable est à Non !"
   GMESSAGE = mess(173,196,1)+"\"+mess(205,100,1) : GERR = 3
   End
Endif

If [M]PRODAT = [0/0/0]
    LPRODAT = date$
Else
    LPRODAT = [M]PRODAT
Endif

#- Go see if we need to display the "Processing already carried out for this date" message
Call CHECK_PRIOR(VALEUR, [M:DIA]PRODAT)         #X3-59814.n

# si renseigné, contrôler que les périodes comprises
# entre dernier trt et PRODAT sont ouvertes, sinon msg bloquant (13064) 20/03/02
# Attention ce contrôle ne se base pas sur les IPTDAT !
# Si on traite tous les sites msg non bloquant car des sociétés ne sont peut-être
# pas concernées.
If VALEUR <> ""
    Call GETSOC(VALEUR) From DEVSUB
    For LTYPLED=GTYPGEN, GTYPANA
        For [PER]PER0 Where CPY=GSOCIETE & LEDTYP=LTYPLED
&                         & [F:PER]PERSTR <= LPRODAT & [F:PER]PEREND >= [M]LASPRODAT
          Gosub CTR_PER
          If mkstat : Break 2 : Endif
        Next
    Next
Else
    For LTYPLED=GTYPGEN, GTYPANA
        Filter [PER] Where LEDTYP=LTYPLED
&                        & [F:PER]PERSTR <= LPRODAT
&                        & [F:PER]PEREND >= [M]LASPRODAT
        For [PER]PER0(1)
          Call GETSOC([F:PER]CPY) From DEVSUB
          For [PER]PER0
              If [F:PER]PERSTR <= LPRODAT & [F:PER]PEREND >= [M]LASPRODAT
                  Gosub CTR_PER
                  If mkstat : Break 3 : Endif
              Endif
          Next
        Next
        Filter [PER]
    Next
Endif
End


#X3-59814.sn - added below block to check if we need to show the "Processing already carried out for this date" message
Subprog CHECK_PRIOR (SITE,PROCDATE)
   Value Char SITE
   Value Date PROCDATE

   If dim([M:DIA]WERRMSG)>0
      Filter [SAC] Where FINFCY=SITE | FINFCY=""
      Read [SAC]SAC0(1)=PROCDATE
      Filter [SAC]
      If !fstat
         [M:DIA]WERRMSG="* "-mess(165,196,1)
      Else
         Raz [M:DIA]WERRMSG
      Endif

      Affzo [M:DIA]WERRMSG
   Endif
End
#X3-59814.en - end of added block

########################################
Subprog AM_FINFCY(VALEUR)
Variable Char    VALEUR()

  # Issue 101389 - 2017-02-09 by ERMIL : Update last run date for the site selected
  Filter [SAC] Where FINFCY=VALEUR or FINFCY=""
  Read [SAC]SAC0 Last
  Filter [SAC]
  If !fstat
    [M:DIA]LASPRODAT=[F:SAC]PRODAT
  Endif

End

$CTR_PER
    Call CONTPER([F:PER]PERSTR,LTYPLED,VALEUR) From CPTSUB
    If mkstat
        GMESSAGE += "\"+mess(166,105,1)-num$(LTYPLED)
&                  +"\"+mess(2,45,1)-":"-[F:PER]CPY
&                  +"\"+mess(10,47,1)-":"-num$([F:PER]FIYNUM)
&                  +"\"+mess(11,47,1)-":"-num$([F:PER]PERNUM)
        Call AVERTIR(GMESSAGE,LRET) From GESECRAN
        Raz GMESSAGE
        If LRET=2
            Raz mkstat
        Endif
    Endif
Return

