#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# SUBPOHC : Gestion des commandes (valorisations)          MBT 27/12/07 #
# --------------------------------------------------------------------- #
# Traitements complémentaires de l'objet "POH"                          #
# Les traitements sur champ "Call"     se trouvent dans le SUBPOH       #
# Les actions "Gosub" de l'objet "POH" se trouvent dans le SUBPOHA      #
# Les traitements complémentaires -1-  se trouvent dans le SUBPOHB      #
# --------------------------------------------------------------------- #
#   Subprog MAJ_CUMULS_LIG(NOL,SENS)                                    #
#     S/P de mise à jour des cumuls, bases et montants éléments à       #
#         partir des valeurs de la ligne de commande                    #
#   Subprog MAJ_BASTAX_LIG(NOL,SENS)                                    #
#     S/P de mise à jour des cumuls bases et montants de taxe à partir  #
#         des valeurs de la ligne de commande                           #
#   Subprog REAJUST_BASTAXLIN1 (NOL,MT)                                 #
#     S/P de réajustement de la base de TVA si modif d'un montant       #
#         de taxe parafiscale ou spéciale soumise à TVA                 #
#   Subprog REAJUST_CLCAMT (NOL,MT,CLCAMTFLG)                           #
#     S/P de réajustement des bases spéciales 1 et 2 si TVA incluse     #
#         dans ces bases (Canada)                                       #
#   Subprog MAJ_TAXE (NOL)                                              #
#     S/P de mise à jour des montants de taxe au prorata des bases sur  #
#         les éléments de facturation et sur les lignes de commande     #
#   Subprog MAJ_ELEMENT (NOL,AFF,SENS)                                  #
#     S/P de mise à jour des bases et calcul des taxes et répartition   #
#         si besoin des montants sur les lignes au prorata des qtés     #
#         ou montants                                                   #
#   Subprog MAJ_REPART_LIG (NOL)                                        #
#     S/P de répartition des montants sur les lignes au prorata des     #
#         quantités ou montants, calcul des taxes                       #
#   Subprog INIT_COMPTES_INVDTA (NOL)                                   #
#     S/P d'initialisation des comptes d'un élément de facturation      #
#   Gosub PREP_INIT_PFICCE                                              #
#     S/P de préparation des sections d'un élément de facturation       #
#   Gosub CALCUL_MT_ELEMENT                                             #
#     S/P de calcul des éléments suivant ordre de calcul                #
#   Subprog MAJ_CPR_LIG                                                 #
#     S/P de calcul prix unitaire de revient                            #
#   subprog CTRL_BUDLIN                                                 #
#     S/P de contrôle dépassement budget à la ligne de commande         #
#########################################################################

#########################################################################
# MAJ_CUMULS_LIG : S/P de mise à jour des cumuls           MBT 27/12/07 #
#         à partir des valeurs de la ligne de commande :                #
#    - Total Mts HT des lignes de commande                              #
#    - Total Qtés des lignes de commande                                #
#    - Màj des montants éléments venant du tarif                        #
# --------------------------------------------------------------------- #
# Subprog MAJ_CUMULS_LIG(NOL,SENS)                                      #
#   NOL    : indice de la ligne de réception (nolign-1)                 #
#   SENS   : Sens de la mise à jour (+1=Cumul, -1=Soustraction)         #
#       (+2=Cumul sans màj éléments, -2=Soustraction sans màj éléments) #
#########################################################################
Subprog MAJ_CUMULS_LIG(NOL,SENS)
Value   Shortint NOL
Value   Integer  SENS
#---- Test si ligne existe bien (Avant ligne d'une nouvelle ligne) ----#
If [M:POH2]ITMREF(NOL)=""  End : Endif
#----- Variables locales -----#
Local   Shortint I, J
Local   Integer  STAT
Local   Decimal  MT, MT2, WRND
Local   Decimal  WMNTMAX, WQTEMAX, WQTYSTU, WQTYSTUMAX
Local   Shortint SAV_LINFLG
Local   Libelle  WFLAG
#----- SENS = +2 ou -2, pas de màj des éléments -----#
WFLAG=0
If SENS=-2  SENS=-1 : WFLAG=1 : Endif
If SENS=+2  SENS=+1 : WFLAG=1 : Endif
#----- Chargement arrondi devise commande -----#
If [F:TCU]CUR<>[M:POH1]CUR
  Read [TCU] TCU0=[M:POH1]CUR
  If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
Else
  WRND=[F:TCU]CURRND
Endif
#----- Mise à jour total HT lignes et total qtés lignes -----#
SAV_LINFLG=[M:POH2]LINFLG(NOL)
If SENS=1
  #----- Cumuls HT si ce n'est pas le composé (produit fini) -----#
  If [M:POH2]LINTYP(NOL)<>2
    [M:POH3]TOTLINAMT+=[M:POH2]LINAMT(NOL)
    [M:POH3]TOTLINATI+=[M:POH2]LINATI(NOL)
  Endif
  #----- Cumuls qtés si ce n'est pas un composant service -----#
  If [M:POH2]LINTYP(NOL)<>3
    [M:POH3]TOTLINQTY+=[M:POH2]QTYPUU(NOL)
    #----- Cumuls poids, volume si ce n'est pas service, matière fournie -----#
    If [M:POH2]LINTYP(NOL)<3
      [M:POH3]TOTLINWEU+=[M:POH2]QTYWEU(NOL)
      [M:POH3]TOTLINVOU+=[M:POH2]QTYVOU(NOL)
    Endif
  Endif
  #-----
  Gosub TRT_CUMULS_LIG : # Màj des éléments venant des commandes et du tarif
Else
  #----- Cumuls HT si ce n'est pas le composé (produit fini) -----#
  If [M:POH2]LINTYP(NOL)<>2
    [M:POH3]TOTLINAMT-=[M:POH2]LINAMT(NOL)
    [M:POH3]TOTLINATI-=[M:POH2]LINATI(NOL)
  Endif
  #----- Cumuls qtés si ce n'est pas un composant service -----#
  If [M:POH2]LINTYP(NOL)<>3
    [M:POH3]TOTLINQTY-=[M:POH2]QTYPUU(NOL)
    #----- Cumuls poids, volume si ce n'est pas service, matière fournie -----#
    If [M:POH2]LINTYP(NOL)<3
      [M:POH3]TOTLINWEU-=[M:POH2]QTYWEU(NOL)
      [M:POH3]TOTLINVOU-=[M:POH2]QTYVOU(NOL)
    Endif
  Endif
  #-----
  [M:POH2]LINFLG(NOL)=9
  Gosub TRT_CUMULS_LIG : # Màj des éléments venant du tarif
Endif
[M:POH2]LINFLG(NOL)=SAV_LINFLG
Call UPDATE_VOLWEI # 106430.n
End
#-----------------------------------------#
# Traitement des éléments venant du tarif #
#-----------------------------------------#
$TRT_CUMULS_LIG
#----- Mise à jour montants éléments venant du tarif -----#
For I=1 To 9
  If evalue("dim([M:POH2]DISCRGVAL"+num$(I)+"(NOL))")>0
    If GNPRNOTFLG(I-1)=1 & GINVDTALIN(I-1)<>0
      J=find(GINVDTALIN(I-1),[M:POH3]INVDTA(0..[M:POH3]NBFAC-1))
      If J<>0
        #----- C'est un montant -----#
        If GDISCRGTYP(I-1)=1
          If GCLCRUL(I-1)=1 : # Par unité
            MT=arr(evalue("[M:POH2]DISCRGVAL"+num$(I)+"(NOL)")*[M:POH2]QTYUOM(NOL),WRND)
          Else              : # Par ligne
            MT=evalue("[M:POH2]DISCRGVAL"+num$(I)+"(NOL)")
          Endif
        #----- C'est un pourcentage -----#
        Else
          MT=arr([M:POH2]LINAMT(NOL)*evalue("[M:POH2]DISCRGVAL"+num$(I)+"(NOL)")/100,WRND)
        Endif
        #----- Inversion du montant si minoration -----#
        If GINCDCR(I-1)=2  MT=-MT : Endif
        #-----
        #If !WFLAG  Call MAJ_ELEMENT(J-1,0,-2) From SUBPOHC : Endif
        Call MAJ_ELEMENT(J-1,0,-2) From SUBPOHC
        If SENS=1
          [M:POH3]INVLINAMT(J-1)+=MT
        Else
          [M:POH3]INVLINAMT(J-1)-=MT
        Endif
        #If !WFLAG  Call MAJ_ELEMENT(J-1,0,+2) From SUBPOHC : Endif
        Call MAJ_ELEMENT(J-1,0,+2) From SUBPOHC
      Endif
    Endif
  Endif
Next I
Return

#--------------------------------------------------------#
# Contrôles supplémentaires sur fournisseurs inter-sites #
#--------------------------------------------------------#
# Issue 84130 - 2012-12-14 by SR : CTRL_BPSINTERSITE déplacée dans SUBPOHC
$CTRL_BPSINTERSITE
#-----
If [F:BPR]BPRNUM<>[M:POH0]BPSNUM
  Read [BPR] BPR0=[M:POH0]BPSNUM : If fstat  Raz [F:BPR] : Endif
Endif
#----- Fournisseur inexistant ! ------#
If [F:BPR]BPRNUM=""
  Raz [F:BPR] : GMESSAGE=mess(541,199,1) : GERR=1 : mkstat=1 : Return
Endif
#----- Le tiers doit être inter-site -----#
If [F:BPR]FCY=""
  GMESSAGE=mess(408,199,1) : GERR=1 : mkstat=1 : Return
Endif
#----- Lecture du site lié au fournisseur commande -----#
If [F:FCY]FCY<>[F:BPR]FCY
  Read [FCY] FCY0=[F:BPR]FCY : If fstat  Raz [F:FCY] : Endif
Endif
#----- Si financier --> fournisseur facturant et payé = fournisseur commande -----#
If [F:FCY]FINFLG=2
  If VALEUR<>[M:POH0]BPSNUM
    GMESSAGE=mess(463,199,1)-"\"-mess(461,199,1) : GERR=1 : mkstat=1 : Return
  Endif
#----- Si autre --> fournisseur facturant et payé liés au site financier -----#
Else
  If [F:BPR2]BPRNUM<>VALEUR
    Read [BPR2] BPR0=VALEUR : If fstat  Raz [F:BPR2] : Endif
  Endif
  If [F:BPR2]FCY<>[F:FCY]FINRSPFCY
    GMESSAGE=mess(463,199,1)-"\"-mess(461,199,1) : GERR=1 : mkstat=1 : Return
  Endif
Endif
# 26113  : Inter-site : Price recalculation (LD:06/07/15)
##-- X3Suivi 26113: Transfert du Prix en Intersite/Intersoc  --#
##----- Vérification que la structure tarif soit identique entre le fournisseur et la société -----#
#If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
#If [F:CPY]CPY<>GSOCIETE
#    Read [CPY] CPY0=GSOCIETE : If fstat : Raz [F:CPY] : Endif
#Endif
#If [F:BPS]PLISTC<>[F:CPY]PLISTC
# GMESSAGE = func AFNC.MES2 (mess(575,199, 1),[F:BPR]BPRNUM - '('+ [F:BPS]PLISTC + ')', GSOCIETE - '('+ [F:CPY]PLISTC + ')')
# mkstat=2 : Return
#Endif
# 26113  : Inter-site : Price recalculation (LD:06/07/15)
#-----
Return

#########################################################################
# MAJ_BASTAX_LIG : S/P de mise à jour des bases et         MBT 27/12/07 #
#                     montants de taxe à partir des                     #
#                     valeurs de la ligne de commande                   #
# --------------------------------------------------------------------- #
# Subprog MAJ_BASTAX_LIG(NOL,SENS)                                      #
#   NOL    : indice de la ligne de réception (nolign-1)                 #
#   SENS   : Sens de la mise à jour (+1=Cumul, -1=Soustraction)         #
#########################################################################
Subprog MAJ_BASTAX_LIG(NOL,SENS)
Value   Shortint NOL
Value   Integer  SENS
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#----- Test si ligne existe bien (Avant ligne d'une nouvelle ligne) -----#
If [M:POH2]ITMREF(NOL)=""  End : Endif
#----- Si c'est le composé (produit fini), pas de chiffrage -----#
If [M:POH2]LINTYP(NOL)=2   End : Endif
#----- Variables locales -----#
Local   Shortint I, J, K, I2, J2, K2
Local   Integer  STAT
Local   Decimal  MT, WBASE, WDISBASE, WAMTTAX, WDEDTAX, MT2
Local   Char     WTAX(GLONVAT)
#----- Mise à jour des bases et des montants de taxe -----#
For I=1 To 3+4*(func AFNC.ACTIV("PTX") & dim([M:POH2]TAXRCP)>0)
  Raz WDISBASE
  Case I
    When 1 : WTAX   =[M:POH2]VAT1(NOL)       : WBASE  =[M:POH2]BASTAXLIN1(NOL)
             WAMTTAX=[M:POH2]AMTTAXLIN1(NOL) : WDEDTAX=[M:POH2]DEDTAXLIN1(NOL)
             If dim([M:POH2]DISBASLIN1)>0
               WDISBASE=[M:POH2]DISBASLIN1(NOL)
             Endif
    When 2 : WTAX   =[M:POH2]VAT2(NOL)       : WBASE  =[M:POH2]LINAMT(NOL)
             WAMTTAX=[M:POH2]AMTTAXLIN2(NOL) : WDEDTAX=[M:POH2]DEDTAXLIN2(NOL)
    When 3 : WTAX   =[M:POH2]VAT3(NOL)       : WBASE  =[M:POH2]LINAMT(NOL)
             WAMTTAX=[M:POH2]AMTTAXLIN3(NOL) : WDEDTAX=[M:POH2]DEDTAXLIN3(NOL)
    When 4 : WTAX   =[M:POH2]TAXRCP(NOL)     : WBASE  =[M:POH2]LINAMT(NOL)
             WAMTTAX=[M:POH2]AMTTAXRCP(NOL)  : WDEDTAX=[M:POH2]DEDTAXRCP(NOL)
    When 5 : WTAX   =[M:POH2]TAXISS(NOL)     : WBASE  =[M:POH2]LINAMT(NOL)
             WAMTTAX=[M:POH2]AMTTAXISS(NOL)  : WDEDTAX=[M:POH2]DEDTAXISS(NOL)
    When 6 : WTAX   =[M:POH2]TAXOTH1(NOL)    : WBASE  =[M:POH2]LINAMT(NOL)
             WAMTTAX=[M:POH2]AMTTAXOTH1(NOL) : WDEDTAX=[M:POH2]DEDTAXOTH1(NOL)
    When 7 : WTAX   =[M:POH2]TAXOTH2(NOL)    : WBASE  =[M:POH2]LINAMT(NOL)
             WAMTTAX=[M:POH2]AMTTAXOTH2(NOL) : WDEDTAX=[M:POH2]DEDTAXOTH2(NOL)
  Endcase
  If WTAX<>""
 	#--CPO 71937 TVT et  multi-lég
    #If [F:TVT]VAT<>WTAX
    #--/CPO
      # Issue 71937 - 2012-03-27 by SR : comment
      Call LEC_TVT_LEG(GCURLEG,WTAX,WRET) From TRTLECLEG
      If WRET : Raz [F:TVT] : Endif
#			 Read [TVT] TVT0=WTAX : If fstat Raz [F:TVT] : Endif
    #Endif
    If I>1 & [F:TVT]VATBAS>1
      WBASE=evalue("[M:POH2]CLCAMT"+num$(I)+"(NOL)") : # Bases spéciales 2-7
    Endif
    #----- Recherche si taxe déja existante -----#
    J=find(WTAX,[M:POH3]TAX(0..[M:POH3]NBTAX-1))
    If J<>0 & [M:POH3]PURTYP(J-1)<>[M:POH2]LINPURTYP(NOL)
      K=find(WTAX,[M:POH3]TAX(J..[M:POH3]NBTAX-1))
      If K<>0
        J+=K
        If [M:POH3]PURTYP(J-1)<>[M:POH2]LINPURTYP(NOL)
          K=find(WTAX,[M:POH3]TAX(J..[M:POH3]NBTAX-1))
          If K<>0 J+=K Else J=0 : Endif
        Endif
      Else
        J=0
      Endif
    Endif
    #----- Nouvelle taxe -----#
    If J=0
      #----- Le nombre maximum de taxe est dépassé ! ------#
      If [M:POH3]NBTAX>=dim([M:POH3]TAX)
        Call ERREUR (WTAX-mess(300,194,1)) From GESECRAN
        Goto MAJ_SUIT1
      Endif
      #-----
      J=[M:POH3]NBTAX
      [M:POH3]NBTAX+=1
      [M:POH3]TAX(J)=WTAX
      Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:POH3]LIBTAX(J)) From TRTX3TEX
      [M:POH3]PURTYP(J)=[M:POH2]LINPURTYP(NOL)
      [M:POH3]VATTYP(J)=[F:TVT]VATTYP
    Else
      J-=1
    Endif
    #----- Mise à jour de la base et des montants de taxe -----#
    If SENS=1
      If dim([M:POH3]DISBAS)>0  [M:POH3]DISBAS(J)+=WDISBASE : Endif
      [M:POH3]BASTAX(J)+=WBASE
      [M:POH3]AMTTAX(J)+=WAMTTAX
      [M:POH3]DEDTAX(J)+=WDEDTAX
    Else
      If dim([M:POH3]DISBAS)>0  [M:POH3]DISBAS(J)-=WDISBASE : Endif
      [M:POH3]BASTAX(J)-=WBASE
      [M:POH3]AMTTAX(J)-=WAMTTAX
      [M:POH3]DEDTAX(J)-=WDEDTAX
      #----- Suppression ligne taxe si aucun montant -----#
      If [M:POH3]BASTAX(J)=0 & [M:POH3]AMTTAX(J)=0 & [M:POH3]DEDTAX(J)=0
        If !GIMPORT
          Dela J,1,[M:POH3]NBTAX-1 [M:POH3]NBTAX : [M:POH3]NBTAX-=1
        Endif
      Endif
    Endif
  Endif
$MAJ_SUIT1
Next I
End


########################################################################
# REAJUST_BASTAXLIN1 : S/P de réajustement de la base     MBT 27/12/07 #
#            de TVA si modif d'un montant de taxe parafiscale          #
#            ou spéciale soumise à TVA                                 #
# -------------------------------------------------------------------- #
# Subprog REAJUST_BASTAXLIN1 (NOL,MT)                                  #
#   NOL    : Indice de la ligne de commande concernée                  #
#   MT     : Montant de l'écart pour mise à jour                       #
########################################################################
Subprog REAJUST_BASTAXLIN1 (NOL,MT)
Value   Shortint   NOL
Value   Decimal    MT
#----- Variables locales -----#
Local   Shortint   I, J
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#----- Mise à jour base taxe de la ligne de commande -----#
[M:POH2]BASTAXLIN1(NOL)+=MT
#----- Recherche si taxe déja existante -----#
I=find([M:POH2]VAT1(NOL),[M:POH3]TAX(0..[M:POH3]NBTAX-1))
If I<>0 & [M:POH3]PURTYP(I-1)<>[M:POH2]LINPURTYP(NOL)
   J=find([M:POH2]VAT1(NOL),[M:POH3]TAX(I..[M:POH3]NBTAX-1))
  #If J<>0 I+=J Else I=0 : Endif
   If J<>0
     I+=J
     If [M:POH3]PURTYP(I-1)<>[M:POH2]LINPURTYP(NOL)
       J=find([M:POH2]VAT1(NOL),[M:POH3]TAX(I..[M:POH3]NBTAX-1))
       If J<>0 I+=J Else I=0 : Endif
     Endif
   Else
     I=0
   Endif
Endif
#----- Nouvelle taxe -----#
If I=0
  #----- Le nombre maximum de taxe est dépassé ! ------#
  If [M:POH3]NBTAX>=dim([M:POH3]TAX)
    Call ERREUR ([M:POH2]VAT1(NOL)-mess(300,194,1)) From GESECRAN
    End
  Endif
  #-----
  I=[M:POH3]NBTAX
  [M:POH3]NBTAX+=1
  [M:POH3]TAX(I)=[M:POH2]VAT1(NOL)
  # Issue 71937 - 2012-03-27 by SR : comment
  Call LEC_TVT_LEG(GCURLEG,[M:POH2]VAT1(NOL),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT] TVT0=[M:POH2]VAT1(NOL) : If fstat Raz [F:TVT] : Endif
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:POH3]LIBTAX(I)) From TRTX3TEX
  [M:POH3]PURTYP(I)=[M:POH2]LINPURTYP(NOL)
  #If [F:TVT]VAT<>[M:POH2]VAT1(NOL)
  #  Read [TVT] TVT0=[M:POH2]VAT1(NOL) : If fstat  Raz [F:TVT] : Endif
  #Endif
  [M:POH3]VATTYP(I)=[F:TVT]VATTYP
Else
  I-=1
Endif
#----- Mise à jour de la base taxe du tableau des taxes -----#
[M:POH3]BASTAX(I)+=MT : GPOH_INDBASTAX(I)=1
End


########################################################################
# REAJUST_CLCAMT : S/P de réajustement des bases          MBT 27/12/07 #
#            spéciales si modif du montant de taxe principale          #
#            et base spéciale incluant la taxe (Canada)                #
# -------------------------------------------------------------------- #
# Subprog REAJUST_CLCAMT (NOL,MT)                                      #
#   NOL       : Indice de la ligne de commande concernée               #
#   MT        : Montant de l'écart pour mise à jour                    #
#   CLCAMTFLG : Indicateur màj base                                    #
#               1=Base 1                                               #
#               2=Base 2   3=Bases 1+2                                 #
#               4=Base 3   5=Bases 1+3   6=Bases 2+3   7=Bases 1+2+3   #
#               8=Base 4   9=Bases 1+8  10=Bases 2+8  11=Bases 1+2+8   #
#               ... etc                                                #
########################################################################
Subprog REAJUST_CLCAMT (NOL,MT,CLCAMTFLG)
Value   Shortint   NOL
Value   Decimal    MT
Value   Shortint   CLCAMTFLG
#----- Variables locales -----#
Local   Shortint   I, J, L
Local   Char       VATSPE(GLONVAT)
# Issue 71937 - 2012-03-27 by SR
Local   Integer   WRET
#-----
For L=3+4*(func AFNC.ACTIV("PTX") & dim([M:POH2]TAXRCP)>0) To 2 Step -1
  If CLCAMTFLG>=2^L-1
    Case L
      When 2 : VATSPE=[M:POH2]VAT2(NOL)
      When 3 : VATSPE=[M:POH2]VAT3(NOL)
      When 4 : VATSPE=[M:POH2]TAXRCP(NOL)
      When 5 : VATSPE=[M:POH2]TAXISS(NOL)
      When 6 : VATSPE=[M:POH2]TAXOTH1(NOL)
      When 7 : VATSPE=[M:POH2]TAXOTH2(NOL)
    Endcase
    Gosub MAJ_BASTAX_CLCAMT
    CLCAMTFLG-=2^L-1
  Endif
Next L
End
#-----------------------------------------------------#
# Mise à jour de la base de taxe du tableau des taxes #
#-----------------------------------------------------#
$MAJ_BASTAX_CLCAMT
#--CPO 71937 TVT et multi-lég
#If [F:TVT]VAT<>VATSPE
#--/CPO
  # Issue 71937 - 2012-03-27 by SR : comment
  Call LEC_TVT_LEG(GCURLEG,VATSPE,WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
#  Read [TVT] TVT0=VATSPE : If fstat  Raz [F:TVT] : Endif
#Endif
#----- Si pas montant 1 ou 2 alors pas de mise à jour -----#
If [F:TVT]VATBAS<2  Return : Endif
#----- Mise à jour bases spéciales 2-7 de la ligne -----#
Case L
  When 2 : [M:POH2]CLCAMT2(NOL)+=MT
  When 3 : [M:POH2]CLCAMT3(NOL)+=MT
  When 4 : [M:POH2]CLCAMT4(NOL)+=MT
  When 5 : [M:POH2]CLCAMT5(NOL)+=MT
  When 6 : [M:POH2]CLCAMT6(NOL)+=MT
  When 7 : [M:POH2]CLCAMT7(NOL)+=MT
Endcase
#----- Recherche si taxe déja existante -----#
I=find(VATSPE,[M:POH3]TAX(0..[M:POH3]NBTAX-1))
If I<>0 & [M:POH3]PURTYP(I-1)<>[M:POH2]LINPURTYP(NOL)
  J=find(VATSPE,[M:POH3]TAX(I..[M:POH3]NBTAX-1))
  If J<>0
    I+=J
    If [M:POH3]PURTYP(I-1)<>[M:POH2]LINPURTYP(NOL)
      J=find(VATSPE,[M:POH3]TAX(I..[M:POH3]NBTAX-1))
      If J<>0  I+=J Else I=0 : Endif
    Endif
  Else
    I=0
  Endif
Endif
#----- Nouvelle taxe -----#
If I=0
  #----- Le nombre maximum de taxe est dépassé ! ------#
  If [M:POH3]NBTAX>=dim([M:POH3]TAX)
    Call ERREUR (VATSPE-mess(300,194,1)) From GESECRAN : End
  Endif
  #-----
  I=[M:POH3]NBTAX
  [M:POH3]NBTAX+=1
  [M:POH3]TAX(I)=VATSPE
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:POH3]LIBTAX(I)) From TRTX3TEX
  [M:POH3]PURTYP(I)=[M:POH2]LINPURTYP(NOL)
  [M:POH3]VATTYP(I)=[F:TVT]VATTYP
Else
  I-=1
Endif
#----- Mise à jour de la base taxe du tableau des taxes -----#
[M:POH3]BASTAX(I)+=MT
Return


####################################################################
# Recalcul de la taxe globalement à partir de la base taxe cumulée #
# ---------------------------------------------------------------- #
#      GPOH_INDTAX  = Numéro de la ligne de taxe à traiter         #
#                I  = Indice de la ligne de taxe à traiter         #
# [M:POH3]TAX   (I) = Code taxe à traiter                          #
# [M:POH3]BASTAX(I) = Base taxe cumulée à traiter                  #
####################################################################
$CAL_TAXE_GLOB
If GPOH_INDTAX=0 | GPOH_INDTAX>[M:POH3]NBTAX  Return : Endif
If dim(I)<0  Local Integer I : Endif
If dim(J)<0  Local Integer J : Endif
I=GPOH_INDTAX-1
Local Integer  TYPREG,  STAT, NUMLIG_DISVAT
Local Decimal  MONTANT, MONTDED, SEUIL
Local Char     TAXE(GLONVAT)
#----- Si taxe classique, recherche présence remise sur taxe (settlement discount) -----#
If [M:POH3]VATTYP(I)=1
  If dim([M:POH3]DISVATFLG)>0
    J=0
    NUMLIG_DISVAT=find(2,[M:POH3]DISVATFLG(J..[M:POH3]NBFAC-1))
    If NUMLIG_DISVAT
      If [M:POH3]INVDTAAMT(NUMLIG_DISVAT-1)=0
        J=NUMLIG_DISVAT
        NUMLIG_DISVAT=find(2,[M:POH3]DISVATFLG(J..[M:POH3]NBFAC-1))
        If NUMLIG_DISVAT & [M:POH3]INVDTAAMT(NUMLIG_DISVAT-1)=0
          Raz NUMLIG_DISVAT
        Endif
      Endif
    Endif
  Endif
  If NUMLIG_DISVAT | (dim([M:POH3]DISBAS)>0 & [M:POH3]DISBAS(I)<>0)
    Gosub SETTLEMENT_DISCOUNT
  Endif
Endif
#-----
TAXE=[M:POH3]TAX(I)
Call CALTAXE(GSOCIETE,[M:POH0]ORDDAT,[M:POH1]VACBPR,GCUR,1,TAXE,1,
&         [M:POH3]BASTAX(I),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
If func AFNC.ACTIV("PTX") & dim([F:TRA]AMTTSD)>0 & [F:TRA]AMTTSD<>0
  Call CONVERT(GCURSHR,[M:POH1]CUR,GLOCALDEV,[M:POH1]CHGTYP,
&               [M:POH0]ORDDAT,[F:TRA]AMTTSD,SEUIL,STAT) From TRTDEV
  If MONTANT<SEUIL  Raz MONTANT, MONTDED : Endif
Endif
If MONTANT<>[M:POH3]AMTTAX(I)
  [M:POH3]AMTTAX(I)=MONTANT
  [M:POH3]DEDTAX(I)=MONTDED
  [M:POH3]TOTTAXAMT=sum([M:POH3]AMTTAX)
  #----- Réajustement mts taxe sur éléments et lignes facture -----#
  Raz GPOH_INDBASTAX
  Call MAJ_TAXE(I) From SUBPOHC
  #----- Si les bases ont été réajustées, il faut recalculer la taxe -----#
  If sum(GPOH_INDBASTAX)>0
    For I=0 To [M:POH3]NBTAX-1
      If GPOH_INDBASTAX(I)=1
        #----- Si taxe classique, recherche présence remise sur taxe (settlement discount) -----#
        If [M:POH3]VATTYP(I)=1
          If dim([M:POH3]DISVATFLG)>0
            J=0
            NUMLIG_DISVAT=find(2,[M:POH3]DISVATFLG(J..[M:POH3]NBFAC-1))
            If NUMLIG_DISVAT
              If [M:POH3]INVDTAAMT(NUMLIG_DISVAT-1)=0
                J=NUMLIG_DISVAT
                NUMLIG_DISVAT=find(2,[M:POH3]DISVATFLG(J..[M:POH3]NBFAC-1))
                If NUMLIG_DISVAT & [M:POH3]INVDTAAMT(NUMLIG_DISVAT-1)=0
                  Raz NUMLIG_DISVAT
                Endif
              Endif
            Endif
          Endif
          If NUMLIG_DISVAT | (dim([M:POH3]DISBAS)>0 & [M:POH3]DISBAS(I)<>0)
            Gosub SETTLEMENT_DISCOUNT
          Endif
        Endif
        #-----
        TAXE=[M:POH3]TAX(I)
        Call CALTAXE(GSOCIETE,[M:POH0]ORDDAT,[M:POH1]VACBPR,GCUR,1,TAXE,1,
&                 [M:POH3]BASTAX(I),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
        If func AFNC.ACTIV("PTX") & dim([F:TRA]AMTTSD)>0 & [F:TRA]AMTTSD<>0
          Call CONVERT(GCURSHR,[M:POH1]CUR,GLOCALDEV,[M:POH1]CHGTYP,
&                       [M:POH0]ORDDAT,[F:TRA]AMTTSD,SEUIL,STAT) From TRTDEV
          If MONTANT<SEUIL  Raz MONTANT, MONTDED : Endif
        Endif
        If MONTANT<>[M:POH3]AMTTAX(I)
          [M:POH3]AMTTAX(I)=MONTANT
          [M:POH3]DEDTAX(I)=MONTDED
          [M:POH3]TOTTAXAMT=sum([M:POH3]AMTTAX)
          #----- Réajustement mts taxe sur éléments et lignes facture -----#
          Call MAJ_TAXE(I) From SUBPOHC
        Endif
      Endif
    Next I
  Endif
  #-----
Endif
Return


###################################################################
# Traitement de la remise sur taxe (code activité KUK             #
#                                   et paramètre GBRDSC)          #
# --------------------------------------------------------------- #
#                   I  = Indice de la ligne de taxe à traiter     #
#    [M:POH3]TAX   (I) = Code taxe                                #
#    [M:POH3]BASTAX(I) = Base taxe net (remise déduite            #
#    [M:POH3]DISBAS(I) = Montant de la remise base (en négatif)   #
#        NUMLIG_DISVAT = Numéro ligne élément settlement discount #
#                   K  = Indice de la plus grosse base TVA        #
#             WBASFLG  = 0  Base sur ligne commande               #
#                        1  Base sur ligne élément de facturation #
#             WDIFBAS  = Calcul du delta bases Mises mis à jour   #
#             WMAXBAS  = Montant de la plus grosse bases TVA      #
#          WMT_DISVAT  = Montant de la remise sur taxe            #
#          WTX_DISVAT  = Pourcentage de la remise sur taxe        #
###################################################################
$SETTLEMENT_DISCOUNT
If dim(K)<0  Local Integer K : Endif
Local Libelle WBASFLG
Local Decimal WDIFBAS, WMAXBAS
Local Decimal WMT_DISVAT, WTX_DISVAT
Local Integer WSIGN
#-----
If NUMLIG_DISVAT
  WSIGN=1-2*([M:POH3]DEBCDT(NUMLIG_DISVAT-1)-1)
  WTX_DISVAT=[M:POH3]INVDTAAMT(NUMLIG_DISVAT-1)
Else
  WSIGN=0
  WTX_DISVAT=0
Endif
#-----
WMT_DISVAT=arr(([M:POH3]BASTAX(I)-[M:POH3]DISBAS(I))*WTX_DISVAT/100,GPOH_RND)*WSIGN
[M:POH3]BASTAX(I)=[M:POH3]BASTAX(I)-[M:POH3]DISBAS(I)+WMT_DISVAT
[M:POH3]DISBAS(I)=WMT_DISVAT
#-----
Raz WMAXBAS, WBASFLG, K
WDIFBAS=WMT_DISVAT
#----- Boucle sur les lignes de commande -----#
For J=0 To [M:POH2]NBLIG-1
  If [M:POH2]VAT1(J)=[M:POH3]TAX(I)
    WMT_DISVAT=arr(([M:POH2]BASTAXLIN1(J)-[M:POH2]DISBASLIN1(J))*WTX_DISVAT/100,GPOH_RND)*WSIGN
    [M:POH2]BASTAXLIN1(J)=[M:POH2]BASTAXLIN1(J)-[M:POH2]DISBASLIN1(J)+WMT_DISVAT
    [M:POH2]DISBASLIN1(J)=WMT_DISVAT
    [M:POH2]UPDFLG(J)=1
    If abs([M:POH2]BASTAXLIN1(J))>WMAXBAS
      WMAXBAS=abs([M:POH2]BASTAXLIN1(J)) : K=J : WBASFLG=0
    Endif
    WDIFBAS-=WMT_DISVAT
  Endif
Next J
#----- Boucle sur les éléments de facturation -----#
For J=0 To [M:POH3]NBFAC-1
  If [M:POH3]INVDTAVAT(J)=[M:POH3]TAX(I) & sum([M:POH3]INVORDAMT(J),[M:POH3]INVLINAMT(J))<>0
    WMT_DISVAT=arr(([M:POH3]INVORDAMT(J)+[M:POH3]INVLINAMT(J))*WTX_DISVAT/100,GPOH_RND)*WSIGN
    [M:POH3]DTADISBAS(J)=WMT_DISVAT
    If abs([M:POH3]INVORDAMT(J)+[M:POH3]INVLINAMT(J)+WMT_DISVAT)>WMAXBAS
      WMAXBAS=abs([M:POH3]INVORDAMT(J)+[M:POH3]INVLINAMT(J)+WMT_DISVAT) : K=J : WBASFLG=1
    Endif
    WDIFBAS-=WMT_DISVAT
  Endif
Next J
#----- Imputation de l'écart éventuel sur la base la plus importante -----#
If WDIFBAS<>0
  Case WBASFLG
    When 1       : [M:POH3]DTADISBAS (K)+=WDIFBAS
    When Default : [M:POH2]DISBASLIN1(K)+=WDIFBAS
                   [M:POH2]BASTAXLIN1(K)+=WDIFBAS
  Endcase
Endif
#-----
Return


########################################################################
# MAJ_TAXE : S/P de mise à jour des montants de taxe au prorata        #
#                des bases sur les éléments de facturation et          #
#                          sur les lignes de commande                  #
# -------------------------------------------------------------------- #
# Subprog MAJ_TAXE (NOL)                                               #
#    NOL  : Numéro de ligne de la taxe (nolign-1)                      #
########################################################################
Subprog MAJ_TAXE (NOL)
Value Shortint NOL
Local Shortint I, J, K, L, CLCAMTFLG
Local Decimal  CUMTAX, CUMDED, DIFTAX, DIFDED, MAXBAS, DIFBAS1, MT
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
If [M:POH3]BASTAX(NOL)=0  End : Endif : # Si le diviseur est zéro on ne fait rien !
#----- Màj des montants de taxe sur les éléments de facturation -----#
For I=0 To [M:POH3]NBFAC-1
  If [M:POH3]INVDTAVAT(I)=[M:POH3]TAX(NOL) & [M:POH3]PURTYP(NOL)=1
    MT=[M:POH3]INVORDAMT(I)+[M:POH3]INVLINAMT(I)
    [M:POH3]DTAAMTTAX(I)=arr([M:POH3]AMTTAX(NOL)*MT/[M:POH3]BASTAX(NOL),GPOH_RND)
    CUMTAX+=[M:POH3]DTAAMTTAX(I)
    [M:POH3]DTADEDTAX(I)=arr([M:POH3]DEDTAX(NOL)*MT/[M:POH3]BASTAX(NOL),GPOH_RND)
    CUMDED+=[M:POH3]DTADEDTAX(I)
    If abs(MT)>MAXBAS MAXBAS=abs(MT) : J=1 : K=I : Endif
  Endif
Next I
#----- Màj des montants de taxe sur les lignes de facture -----#
For I=0 To [M:POH2]NBLIG-1
  If [M:POH2]LINPURTYP(I)=[M:POH3]PURTYP(NOL)
    If [M:POH2]VAT1(I)=[M:POH3]TAX(NOL)
      #----- Positionnement indicateur de réajustement des bases spéciales 2 à 7 -----#
      Raz CLCAMTFLG
      For L=2 To 3+4*(func AFNC.ACTIV("PTX") & dim([M:POH2]CLCAMT4)>0)
        GBIDD2=evalue("[M:POH2]CLCAMT"+num$(L)+"(I)")
        If GBIDD2<>0 & (GBIDD2=[M:POH2]LINAMT(I)+[M:POH2]AMTTAXLIN1(I) |
&                       GBIDD2=[M:POH2]AMTTAXLIN1(I))
          CLCAMTFLG+=2^L-1
        Endif
      Next L
      If CLCAMTFLG>0  DIFBAS1=-[M:POH2]AMTTAXLIN1(I) : Endif
      #-----
      [M:POH2]AMTTAXLIN1(I)=arr([M:POH3]AMTTAX(NOL)*[M:POH2]BASTAXLIN1(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
      CUMTAX+=[M:POH2]AMTTAXLIN1(I)
      #----- Réajustement bases spéciales 1 et 2 si TVA incluse dans ces bases (Canada) -----#
      If CLCAMTFLG>0
        DIFBAS1+=[M:POH2]AMTTAXLIN1(I)
        Call REAJUST_CLCAMT(I,DIFBAS1,CLCAMTFLG) From SUBPOHC
      Endif
      #-----
      [M:POH2]DEDTAXLIN1(I)=arr([M:POH3]DEDTAX(NOL)*[M:POH2]BASTAXLIN1(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
      [M:POH2]UPDFLG(I)=1
      CUMDED+=[M:POH2]DEDTAXLIN1(I)
      If abs([M:POH2]BASTAXLIN1(I))>MAXBAS MAXBAS=abs([M:POH2]BASTAXLIN1(I)) : J=2 : K=I : Endif
    Elsif [M:POH2]VAT2(I)=[M:POH3]TAX(NOL)
      #----- Réajustement base taxe 1 (TVA) si taxe parafiscale soumise -----#
      # Issue 71937 - 2012-03-27 by SR : comment
      Call LEC_TVT_LEG(GCURLEG,[M:POH2]VAT2(I),WRET) From TRTLECLEG
      If WRET : Raz [F:TVT] : Endif
			#Read [TVT] TVT0=[M:POH2]VAT2(I) : If fstat Raz [F:TVT] : Endif
      If [F:TVT]VATCHA=2 DIFBAS1=-[M:POH2]AMTTAXLIN2(I) : Endif
      #-----
      [M:POH2]AMTTAXLIN2(I)=arr([M:POH3]AMTTAX(NOL)*[M:POH2]LINAMT(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
      CUMTAX+=[M:POH2]AMTTAXLIN2(I)
      #----- Réajustement base taxe 1 (TVA) si taxe parafiscale soumise -----#
      If [F:TVT]VATCHA=2
        DIFBAS1+=[M:POH2]AMTTAXLIN2(I)
        Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPOHC
      Endif
      #-----
      [M:POH2]DEDTAXLIN2(I)=arr([M:POH3]DEDTAX(NOL)*[M:POH2]LINAMT(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
      CUMDED+=[M:POH2]DEDTAXLIN2(I)
      If abs([M:POH2]LINAMT(I))>MAXBAS MAXBAS=abs([M:POH2]LINAMT(I)) : J=3 : K=I : Endif
    Elsif [M:POH2]VAT3(I)=[M:POH3]TAX(NOL)
      #----- Réajustement base taxe 1 (TVA) si taxe spéciale soumise -----#
      # Issue 71937 - 2012-03-27 by SR : comment
      Call LEC_TVT_LEG(GCURLEG,[M:POH2]VAT3(I),WRET) From TRTLECLEG
      If WRET : Raz [F:TVT] : Endif
      #Read [TVT] TVT0=[M:POH2]VAT3(I) : If fstat Raz [F:TVT] : Endif
      If [F:TVT]VATCHA=2 DIFBAS1=-[M:POH2]AMTTAXLIN3(I) : Endif
      #-----
      [M:POH2]AMTTAXLIN3(I)=arr([M:POH3]AMTTAX(NOL)*[M:POH2]LINAMT(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
      CUMTAX+=[M:POH2]AMTTAXLIN3(I)
      #----- Réajustement base taxe 1 (TVA) si taxe spéciale soumise -----#
      If [F:TVT]VATCHA=2
        DIFBAS1+=[M:POH2]AMTTAXLIN3(I)
        Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPOHC
      Endif
      #-----
      [M:POH2]DEDTAXLIN3(I)=arr([M:POH3]DEDTAX(NOL)*[M:POH2]LINAMT(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
      [M:POH2]UPDFLG(I)=1
      CUMDED+=[M:POH2]DEDTAXLIN3(I)
      If abs([M:POH2]LINAMT(I))>MAXBAS MAXBAS=abs([M:POH2]LINAMT(I)) : J=4 : K=I : Endif
    Elsif func AFNC.ACTIV("PTX") & dim([M:POH2]TAXRCP)>0
      If [M:POH2]TAXRCP(I)=[M:POH3]TAX(NOL)
        #----- Réajustement base taxe 1 (TVA) si taxe entrée soumise -----#
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,[M:POH2]TAXRCP(I),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:POH2]TAXRCP(I) : If fstat Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 DIFBAS1=-[M:POH2]AMTTAXRCP(I) : Endif
        #-----
        [M:POH2]AMTTAXRCP(I)=arr([M:POH3]AMTTAX(NOL)*[M:POH2]LINAMT(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
        CUMTAX+=[M:POH2]AMTTAXRCP(I)
        #----- Réajustement base taxe 1 (TVA) si taxe entrée soumise -----#
        If [F:TVT]VATCHA=2
          DIFBAS1+=[M:POH2]AMTTAXRCP(I)
          Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPOHC
        Endif
        #-----
        [M:POH2]DEDTAXRCP(I)=arr([M:POH3]DEDTAX(NOL)*[M:POH2]LINAMT(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
        [M:POH2]UPDFLG(I)=1
        CUMDED+=[M:POH2]DEDTAXRCP(I)
        If abs([M:POH2]LINAMT(I))>MAXBAS MAXBAS=abs([M:POH2]LINAMT(I)) : J=5 : K=I : Endif
      Elsif [M:POH2]TAXISS(I)=[M:POH3]TAX(NOL)
        #----- Réajustement base taxe 1 (TVA) si taxe sortie soumise -----#
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,[M:POH2]TAXISS(I),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:POH2]TAXISS(I) : If fstat Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 DIFBAS1=-[M:POH2]AMTTAXISS(I) : Endif
        #-----
        [M:POH2]AMTTAXISS(I)=arr([M:POH3]AMTTAX(NOL)*[M:POH2]LINAMT(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
        CUMTAX+=[M:POH2]AMTTAXISS(I)
        #----- Réajustement base taxe 1 (TVA) si taxe entrée soumise -----#
        If [F:TVT]VATCHA=2
          DIFBAS1+=[M:POH2]AMTTAXISS(I)
          Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPOHC
        Endif
        #-----
        [M:POH2]DEDTAXISS(I)=arr([M:POH3]DEDTAX(NOL)*[M:POH2]LINAMT(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
        [M:POH2]UPDFLG(I)=1
        CUMDED+=[M:POH2]DEDTAXISS(I)
        If abs([M:POH2]LINAMT(I))>MAXBAS MAXBAS=abs([M:POH2]LINAMT(I)) : J=6 : K=I : Endif
      Elsif [M:POH2]TAXOTH1(I)=[M:POH3]TAX(NOL)
        #----- Réajustement base taxe 1 (TVA) si autre taxe 1 soumise -----#
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,[M:POH2]TAXOTH1(I),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:POH2]TAXOTH1(I) : If fstat Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 DIFBAS1=-[M:POH2]AMTTAXOTH1(I) : Endif
        #-----
        [M:POH2]AMTTAXOTH1(I)=arr([M:POH3]AMTTAX(NOL)*[M:POH2]LINAMT(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
        CUMTAX+=[M:POH2]AMTTAXOTH1(I)
        #----- Réajustement base taxe 1 (TVA) si autre taxe 1 soumise -----#
        If [F:TVT]VATCHA=2
          DIFBAS1+=[M:POH2]AMTTAXOTH1(I)
          Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPOHC
        Endif
        #-----
        [M:POH2]DEDTAXOTH1(I)=arr([M:POH3]DEDTAX(NOL)*[M:POH2]LINAMT(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
        CUMDED+=[M:POH2]DEDTAXOTH1(I)
        If abs([M:POH2]LINAMT(I))>MAXBAS MAXBAS=abs([M:POH2]LINAMT(I)) : J=7 : K=I : Endif
      Elsif [M:POH2]TAXOTH2(I)=[M:POH3]TAX(NOL)
        #----- Réajustement base taxe 1 (TVA) si autre taxe 2 soumise -----#
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,[M:POH2]TAXOTH2(I),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:POH2]TAXOTH2(I) : If fstat Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 DIFBAS1=-[M:POH2]AMTTAXOTH2(I) : Endif
        #-----
        [M:POH2]AMTTAXOTH2(I)=arr([M:POH3]AMTTAX(NOL)*[M:POH2]LINAMT(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
        CUMTAX+=[M:POH2]AMTTAXOTH2(I)
        #----- Réajustement base taxe 1 (TVA) si autre taxe 1 soumise -----#
        If [F:TVT]VATCHA=2
          DIFBAS1+=[M:POH2]AMTTAXOTH2(I)
          Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPOHC
        Endif
        #-----
        [M:POH2]DEDTAXOTH2(I)=arr([M:POH3]DEDTAX(NOL)*[M:POH2]LINAMT(I)/[M:POH3]BASTAX(NOL),GPOH_RND)
        CUMDED+=[M:POH2]DEDTAXOTH2(I)
        If abs([M:POH2]LINAMT(I))>MAXBAS MAXBAS=abs([M:POH2]LINAMT(I)) : J=8 : K=I : Endif
      Endif
    Endif
    #----- Mise à jour du TTC ligne si facture non CEE -----#
    If [M:POH1]VACTYP<>4
      [M:POH2]LINATIAMT(I)=[M:POH2]LINAMT(I)+[M:POH2]AMTTAXLIN1(I)
&                           +[M:POH2]AMTTAXLIN2(I)+[M:POH2]AMTTAXLIN3(I)
      If func AFNC.ACTIV("PTX") & dim([M:POH2]TAXRCP)>0
        [M:POH2]LINATIAMT(I)+=[M:POH2]AMTTAXRCP(I)
        [M:POH2]LINATIAMT(I)+=[M:POH2]AMTTAXISS(I)
        [M:POH2]LINATIAMT(I)+=[M:POH2]AMTTAXOTH1(I)
        [M:POH2]LINATIAMT(I)+=[M:POH2]AMTTAXOTH2(I)
      Endif
    Endif
  Endif
Next I
#----- Imputation des écarts éventuels sur les montants les plus gros -----#
DIFTAX=[M:POH3]AMTTAX(NOL)-CUMTAX
DIFDED=[M:POH3]DEDTAX(NOL)-CUMDED
If DIFTAX<>0 | DIFDED<>0
  Case J
    When 1 : [M:POH3]DTAAMTTAX (K)+=DIFTAX : [M:POH3]DTADEDTAX (K)+=DIFDED
    When 2 : Raz CLCAMTFLG
             #----- Positionnement indicateur de réajustement des bases spéciales 2 à 7 -----#
             For L=2 To 3+4*(func AFNC.ACTIV("PTX") & dim([M:POH2]CLCAMT4)>0)
               GBIDD2=evalue("[M:POH2]CLCAMT"+num$(L)+"(I)")
               If GBIDD2<>0 & (GBIDD2=[M:POH2]LINAMT(I)+[M:POH2]AMTTAXLIN1(I) |
&                              GBIDD2=[M:POH2]AMTTAXLIN1(I))
                 CLCAMTFLG+=2^L-1
               Endif
             Next L
             #-----
             [M:POH2]AMTTAXLIN1(K)+=DIFTAX : [M:POH2]DEDTAXLIN1(K)+=DIFDED
             If CLCAMTFLG>0  Call REAJUST_CLCAMT(K,DIFTAX,CLCAMTFLG) From SUBPOHC : Endif
    When 3 : [M:POH2]AMTTAXLIN2(K)+=DIFTAX : [M:POH2]DEDTAXLIN2(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR : comment
             Call LEC_TVT_LEG(GCURLEG,[M:POH2]VAT2(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:POH2]VAT2(K) : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPOHC : Endif
    When 4 : [M:POH2]AMTTAXLIN3(K)+=DIFTAX : [M:POH2]DEDTAXLIN3(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR : comment
             Call LEC_TVT_LEG(GCURLEG,[M:POH2]VAT3(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:POH2]VAT3(K) : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPOHC : Endif
    When 5 : [M:POH2]AMTTAXRCP(K)+=DIFTAX  : [M:POH2]DEDTAXRCP(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR : comment
             Call LEC_TVT_LEG(GCURLEG,[M:POH2]TAXRCP(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:POH2]TAXRCP(K)  : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPOHC : Endif
    When 6 : [M:POH2]AMTTAXISS(K)+=DIFTAX  : [M:POH2]DEDTAXISS(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR : comment
             Call LEC_TVT_LEG(GCURLEG,[M:POH2]TAXISS(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:POH2]TAXISS(K)  : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPOHC : Endif
    When 7 : [M:POH2]AMTTAXOTH1(K)+=DIFTAX : [M:POH2]DEDTAXOTH1(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR : comment
             Call LEC_TVT_LEG(GCURLEG,[M:POH2]TAXOTH1(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:POH2]TAXOTH1(K) : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPOHC : Endif
    When 8 : [M:POH2]AMTTAXOTH2(K)+=DIFTAX : [M:POH2]DEDTAXOTH2(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR : comment
             Call LEC_TVT_LEG(GCURLEG,[M:POH2]TAXOTH2(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:POH2]TAXOTH2(K) : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPOHC : Endif
  Endcase
Endif
End


########################################################################
# MAJ_ELEMENT : S/P de mise à jour des bases et calcul des taxes       #
#                   et répartition si besoin des montants sur          #
#                   les lignes au prorata des qtés ou montant          #
# -------------------------------------------------------------------- #
# Subprog MAJ_ELEMENT (NOL,AFF,SENS)                                   #
#    NOL  : Numéro de ligne de l'élément de facturation (nolign-1)     #
#    AFF  : Indicateur d'affichage (0=Non, 1-2=Oui)                    #
#    SENS : Sens de la mise à jour (+1=Cumul, -1=Soustraction)         #
########################################################################
Subprog MAJ_ELEMENT (NOL,AFF,SENS)
Value Shortint NOL
Value Integer  AFF
Value Integer  SENS
#-----
Local Libelle  WFLAG
Local Shortint I, J, K, L, M
Local Integer  TYPREG,  STAT
Local Decimal  MONTANT, MONTDED, MTLIG, CUMLIG, CUMLINQTY, CUMLINWEU, CUMLINVOU
Local Decimal  CUMLINMT # Issue 121453 - 2017-02-09 by MUARN : répartition montant en SST
Local Decimal  CUMORIMT, CUMORIQTE, CUMQTYPUU, WMT
Local Char     TAXE(GLONVAT)
Local Integer  MAXLIG : MAXLIG=max([M:POH2]NBLIG,find("",[M:POH2]ITMREF)-1)
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#-----
Raz GPOH_INDTAX
#----- SENS = +2 ou -2, pas de répartition tarif -----#
WFLAG=0
If SENS=-2  SENS=-1 : WFLAG=1 : Endif
If SENS=+2  SENS=+1 : WFLAG=1 : Endif
#---- Si élément fait partie de la ligne tarif et taxe produit ----#
If [M:POH3]INVLINFLG(NOL)=6 & [M:POH3]INVDTAVAT(NOL)=""
  Goto AFF_TAXES
Endif
#----- Si l'élément est une remise sur taxe (settlement discount) -----#
If dim([M:POH3]DISVATFLG)>0 & [M:POH3]DISVATFLG(NOL)=2
  Goto AFF_TAXES
Endif
#------ Si montant de l'élément égal à zéro ni calcul, ni màj ------#
WMT=[M:POH3]INVORDAMT(NOL)+[M:POH3]INVLINAMT(NOL)
If WMT=0 & find([M:POH3]INVLINFLG(NOL),1,6)  Goto AFF_TAXES : Endif
#----- Calcul suivant le type de répartition -----#
Case [M:POH3]INVLINFLG(NOL)
  When 1  : Gosub CAL_TAXE_PIED : # Pas de répartition sur les lignes
  When 2  : Gosub CAL_PRORATA   : # Prorata des quantités
  When 3  : Gosub CAL_PRORATA   : # Prorata des montants
  When 4  : Gosub CAL_PRORATA   : # Prorata des poids
  When 5  : Gosub CAL_PRORATA   : # Prorata des volumes
  When 6  : Gosub CAL_TAXE_PIED : # Provient des lignes (tarif)
Endcase
#----- Affichage du tableau des taxes -----#
$AFF_TAXES
If AFF>0 & !GIMPORT  Affzo [POH3]10,15 : Endif
End
#------------------------------------------------------------#
# Répartition sur les lignes au prorata des qtés ou montants #
#------------------------------------------------------------#
$CAL_PRORATA
#----- Taxe à taux fixe -----#
If [M:POH3]INVDTAVAT(NOL)<>"" & WMT<>0  Gosub CAL_TAXE_PIED : Endif
#----- Recherche si élément nouveau et màj soustraction alors c'est fini -----#
#If !find([M:POH3]INVDTA(NOL),[M:POH2]INVDTALIN2(0..8)) & SENS=-1  Return : Endif
#---- C'est un élément nouveau : Stockage du no d'élément et du code taxe ----#
If !find([M:POH3]INVDTA(NOL),[M:POH2]INVDTALIN2(0..8))
   I=find(0,[M:POH2]INVDTALIN2(0..8))
   If I<>0
     [M:POH2]INVDTALIN2(I-1)=[M:POH3]INVDTA(NOL)
     [M:POH2]INVDTAVAT2(I-1)=[M:POH3]INVDTAVAT(NOL)
   Else
     Return : # Une 10ème répartition est impossible !
   Endif
Endif
If [M:POH3]INVORDAMT(NOL)=0  Return : Endif
#----- Répartition sur les lignes -----#
J=find([M:POH3]INVDTA(NOL),[M:POH2]INVDTALIN2(0..8))
Raz CUMLIG, CUMLINQTY, CUMLINWEU, CUMLINVOU, CUMLINMT # Issue 121453 - 2017-02-09 by MUARN : répartition montant en SST CUMLINMT
If MAXLIG>0
  For I=0 To MAXLIG-1
    If [M:POH2]LINTYP(I)<2
&   | ([M:POH2]LINTYP(I)=2 & [M:POH3]INVLINFLG(NOL)<>3)
&   | ([M:POH2]LINTYP(I)=3 & [M:POH3]INVLINFLG(NOL)=3)
&   | ([M:POH2]LINTYP(I)=4 & [M:POH3]INVLINFLG(NOL)<4)
      #----- Le prorata du produit fini s'affecte au service -----#
      If [M:POH2]LINTYP(I)=2
        M=I+1
      #----- Le prorata des autres s'affecte sur eux-mêmes -----#
      Else
        M=I
      Endif
      #-----
      If SENS=1
        If [M:POH2]LINFLG(I)<>9
          # Issue X3-91854 - 2018-05-29 by MUARN : répartition poids/volume
          # Issue 121453 - 2017-02-08 by MUARN : tenir compte du type de répartition
          #If I<MAXLIG-1 & CUMLINQTY+[M:POH2]QTYPUU(I)<[M:POH3]TOTLINQTY
          If ( I<MAXLIG-1 & [M:POH3]INVLINFLG(NOL)=2 & (CUMLINQTY+[M:POH2]QTYPUU(I)<[M:POH3]TOTLINQTY) ) |
&            ( I<MAXLIG-1 & [M:POH3]INVLINFLG(NOL)=3 & (CUMLINMT +[M:POH2]LINAMT(I)<[M:POH3]TOTLINAMT ) ) |
&            ( I<MAXLIG-1 & [M:POH3]INVLINFLG(NOL)=4 & (CUMLINWEU +[M:POH2]QTYWEU(I)<[M:POH3]TOTLINWEU ) ) |
&            ( I<MAXLIG-1 & [M:POH3]INVLINFLG(NOL)=5 & (CUMLINVOU +[M:POH2]QTYVOU(I)<[M:POH3]TOTLINVOU ) )
            Raz MTLIG
            Case [M:POH3]INVLINFLG(NOL)
              When 2 : #----- Prorata par quantités -----#
                If [M:POH3]TOTLINQTY<>0 & [M:POH2]LINTYP(I)<>3
                  MTLIG=[M:POH3]INVORDAMT(NOL)*[M:POH2]QTYPUU(I)/[M:POH3]TOTLINQTY
                Endif
              When 3 : #----- Prorata par montants -----#
                If [M:POH3]TOTLINAMT<>0 & [M:POH2]LINTYP(I)<>2
                  MTLIG=[M:POH3]INVORDAMT(NOL)*[M:POH2]LINAMT(I)/[M:POH3]TOTLINAMT
                Endif
              When 4 : #----- Prorata par poids -----#
                If [M:POH3]TOTLINWEU<>0 & [M:POH2]LINTYP(I)<3
                  MTLIG=[M:POH3]INVORDAMT(NOL)*[M:POH2]QTYWEU(I)/[M:POH3]TOTLINWEU
                Endif
              When 5 : #----- Prorata par volume -----#
                If [M:POH3]TOTLINVOU<>0 & [M:POH2]LINTYP(I)<3
                  MTLIG=[M:POH3]INVORDAMT(NOL)*[M:POH2]QTYVOU(I)/[M:POH3]TOTLINVOU
                Endif
            Endcase
            MTLIG=arr(MTLIG,GPOH_RND)
          Else
            MTLIG=[M:POH3]INVORDAMT(NOL)-CUMLIG
          Endif
          Assign "[M:POH2]DISCRGAMT"+num$(J)+"(M)" With MTLIG
          CUMLIG+=MTLIG
          CUMLINQTY+=[M:POH2]QTYPUU(I)
          CUMLINWEU+=[M:POH2]QTYWEU(I)
          CUMLINVOU+=[M:POH2]QTYVOU(I)
          CUMLINMT+=[M:POH2]LINAMT(I) # Issue 121453 - 2017-02-08 by MUARN : tenir compte du type de répartition
        Else
          MTLIG=0
          Assign "[M:POH2]DISCRGAMT"+num$(J)+"(M)" With MTLIG
        Endif
      Else
        MTLIG=evalue("[M:POH2]DISCRGAMT"+num$(J)+"(M)")
        Assign "[M:POH2]DISCRGAMT"+num$(J)+"(M)" With 0
      Endif
      If [M:POH2]INVDTAVAT2(J-1)="" & [M:POH2]VAT1(M)<>"" Gosub CAL_TAXE_LIGNE : Endif
      # Issue 120672 - 2017-02-02 by MUARN : SST M au lieu de I
      #[M:POH2]UPDFLG(I)=1
      [M:POH2]UPDFLG(M)=1
    Endif
  Next I
Endif
If SENS=-1  [M:POH2]INVDTALIN2(J-1)=0 : [M:POH2]INVDTAVAT2(J-1)="" : Endif
Return
#-----------------------------------------------------------#
# Màj bases taxables et calcul des taxes en pied de facture #
#-----------------------------------------------------------#
$CAL_TAXE_PIED
#----- Recherche si taxe déja existante -----#
I=find([M:POH3]INVDTAVAT(NOL),[M:POH3]TAX(0..[M:POH3]NBTAX-1))
If I<>0 & [M:POH3]PURTYP(I-1)<>1
  J=find([M:POH3]INVDTAVAT(NOL),[M:POH3]TAX(I..[M:POH3]NBTAX-1))
  If J<>0
    I+=J
    If [M:POH3]PURTYP(I-1)<>1
      J=find([M:POH3]INVDTAVAT(NOL),[M:POH3]TAX(I..[M:POH3]NBTAX-1))
      If J<>0 I+=J Else I=0 : Endif
    Endif
  Else
    I=0
  Endif
Endif
#----- Nouvelle taxe -----#
If I=0
  #----- Le nombre maximum de taxe est dépassé ! ------#
  If [M:POH3]NBTAX>=dim([M:POH3]TAX)
    Call ERREUR ([M:POH3]INVDTAVAT(NOL)-mess(300,194,1)) From GESECRAN
    GPOH_INDTAX=I+1
    Return
  Endif
  #-----
  I=[M:POH3]NBTAX
  [M:POH3]NBTAX+=1
  [M:POH3]TAX(I)=[M:POH3]INVDTAVAT(NOL)
  # Issue 71937 - 2012-03-27 by SR : comment
  Call LEC_TVT_LEG(GCURLEG,[M:POH3]INVDTAVAT(NOL),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT] TVT0=[M:POH3]INVDTAVAT(NOL) : If fstat Raz [F:TVT] : Endif
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:POH3]LIBTAX(I)) From TRTX3TEX
  [M:POH3]PURTYP(I)=1
  [M:POH3]VATTYP(I)=[F:TVT]VATTYP
Else
  I-=1
Endif
#----- Mise à jour base taxable et montants de taxe-----#
If SENS=-1
  [M:POH3]BASTAX(I)-=WMT
  If dim([M:POH3]DTADISBAS)>0
    [M:POH3]BASTAX(I)-=[M:POH3]DTADISBAS(NOL)
    [M:POH3]DISBAS(I)-=[M:POH3]DTADISBAS(NOL)
  Endif
  [M:POH3]AMTTAX(I)-=[M:POH3]DTAAMTTAX(NOL)
  [M:POH3]DEDTAX(I)-=[M:POH3]DTADEDTAX(NOL)
  #----- Suppression ligne taxe si aucun montant et affichage -----#
  If [M:POH3]BASTAX(I)=0 & [M:POH3]AMTTAX(I)=0 & [M:POH3]DEDTAX(I)=0 : # & AFF>0
    If !GIMPORT
      Dela I,1,[M:POH3]NBTAX-1 [M:POH3]NBTAX : [M:POH3]NBTAX-=1
    Endif
  Endif
Else
  [M:POH3]BASTAX(I)+=WMT
  If dim([M:POH3]DTADISBAS)>0
    Raz [M:POH3]DTADISBAS(NOL)
  Endif
  #----- Calcul du montant de taxe avec sa partie déductible -----#
  #If [M:POH3]DTAAMTTAX(NOL)=0 & [M:POH3]DTADEDTAX(NOL)=0
    TAXE=[M:POH3]INVDTAVAT(NOL)
    Call CALTAXE(GSOCIETE,[M:POH0]ORDDAT,[M:POH1]VACBPR,GCUR,1,TAXE,1,
&                WMT,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
    [M:POH3]DTAAMTTAX(NOL)=MONTANT
    [M:POH3]DTADEDTAX(NOL)=MONTDED
  #Endif
  [M:POH3]AMTTAX(I)+=[M:POH3]DTAAMTTAX(NOL)
  [M:POH3]DEDTAX(I)+=[M:POH3]DTADEDTAX(NOL)
Endif
GPOH_INDTAX=I+1
Return
#---------------------------------------------------------------#
# Màj bases taxables et calcul des taxes à la ligne de commande #
#---------------------------------------------------------------#
$CAL_TAXE_LIGNE
#----- Recherche si taxe déja existante -----#
K=find([M:POH2]VAT1(M),[M:POH3]TAX(0..[M:POH3]NBTAX-1))
If K<>0 & [M:POH3]PURTYP(K-1)<>[M:POH2]LINPURTYP(M)
   L=find([M:POH2]VAT1(M),[M:POH3]TAX(K..[M:POH3]NBTAX-1))
   If L<>0
     K+=L
     If [M:POH3]PURTYP(K-1)<>[M:POH2]LINPURTYP(M)
       L=find([M:POH2]VAT1(M),[M:POH3]TAX(K..[M:POH3]NBTAX-1))
       If L<>0 K+=L Else K=0 : Endif
     Endif
   Else
     K=0
   Endif
Endif
#----- Nouvelle taxe -----#
If K=0
  #----- Le nombre maximum de taxe est dépassé ! ------#
  If [M:POH3]NBTAX>=dim([M:POH3]TAX)
    Call ERREUR ([M:POH2]VAT1(M)-mess(300,194,1)) From GESECRAN
    GPOH_INDTAX=K+1
    Return
  Endif
  #-----
  K=[M:POH3]NBTAX
  [M:POH3]NBTAX+=1
  [M:POH3]TAX(K)=[M:POH2]VAT1(M)
  # Issue 71937 - 2012-03-27 by SR : comment
  Call LEC_TVT_LEG(GCURLEG,[M:POH2]VAT1(M),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT] TVT0=[M:POH2]VAT1(M) : If fstat Raz [F:TVT] : Endif
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:POH3]LIBTAX(K)) From TRTX3TEX
  [M:POH3]PURTYP(K)=[M:POH2]LINPURTYP(M)
  [M:POH3]VATTYP(K)=[F:TVT]VATTYP
Else
  K-=1
Endif
#----- Calcul du montant de taxe avec sa partie déductible -----#
TAXE=[M:POH2]VAT1(M)
Call CALTAXE(GSOCIETE,[M:POH0]ORDDAT,[M:POH1]VACBPR,GCUR,1,TAXE,1,
&            MTLIG,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#----- Mise à jour base taxable et montants de taxe-----#
If SENS=-1
  [M:POH2]BASTAXLIN1(M)-=MTLIG
  [M:POH2]AMTTAXLIN1(M)-=MONTANT
  [M:POH2]DEDTAXLIN1(M)-=MONTDED
  If [M:POH1]VACTYP<>4  [M:POH2]LINATIAMT(M) -=MONTANT : Endif
  [M:POH3]BASTAX(K)-=MTLIG
  [M:POH3]AMTTAX(K)-=MONTANT
  [M:POH3]DEDTAX(K)-=MONTDED
  #----- Suppression ligne taxe si aucun montant -----#
  If [M:POH3]BASTAX(K)=0 & [M:POH3]AMTTAX(K)=0 & [M:POH3]DEDTAX(K)=0
    If !GIMPORT
      Dela K,1,[M:POH3]NBTAX-1 [M:POH3]NBTAX : [M:POH3]NBTAX-=1
    Endif
  Endif
Else
  [M:POH2]BASTAXLIN1(M)+=MTLIG
  [M:POH2]AMTTAXLIN1(M)+=MONTANT
  [M:POH2]DEDTAXLIN1(M)+=MONTDED
  If [M:POH1]VACTYP<>4  [M:POH2]LINATIAMT(M) +=MONTANT : Endif
  # Issue 70985 - 2012-05-09 by MUARN : landedcost (taxe avec taux produit)
  If [M:POH3]INVDTAVAT(NOL) <>"" | [M:POH3]BASTAX(K)<>0
  # fin Issue 70985 - 2012-05-09 by MUARN : landedcost (taxe avec taux produit)
    [M:POH3]BASTAX(K)+=MTLIG
    [M:POH3]AMTTAX(K)+=MONTANT
    [M:POH3]DEDTAX(K)+=MONTDED
  Endif
Endif
GPOH_INDTAX=K+1
Return

#########################################################################
# MAJ_REPART_LIG : S/P de répartition des éléments de facturation sur   #
#         les lignes de commande au prorata des qantités ou montants,   #
#         calcul taxes                                                  #
# --------------------------------------------------------------------- #
# Subprog MAJ_REPART_LIG                                                #
#########################################################################
Subprog MAJ_REPART_LIG
#----- Variables locales -----#
Local Shortint I, J, K
Local Decimal  MTLIG, CUMLIG

# Issue 70985 - 2012-06-19 by MUARN : landedcost
Local Integer SAV_NOLIGN
SAV_NOLIGN=nolign
#-----
For I=0 To [M:POH3]NBFAC-1
  Call MAJ_ELEMENT (I,0,-2) From SUBPOHC
  # Issue 70985 - 2012-04-24 by MUARN : landed cost ajout calcul sir pourcentage
  #----- Calcul du montant de l'élément si pourcentage sur base -----#
  If [M:POH3]AMTCOD(I)=1 & (dim([M:POH3]DISVATFLG)<1 | [M:POH3]DISVATFLG(I)<>2)
    nolign=I+1 : Call AM_INVDTAAMT([M:POH3]INVDTAAMT(I)) From SUBPOH
  Endif
  Call MAJ_ELEMENT (I,0,+2) From SUBPOHC
Next I
nolign=SAV_NOLIGN # Issue 70985 - 2012-06-19 by MUARN : landedcost
#-----
# Issue 70985 - 2012-02-21 by MUARN : landed cost
For I=0 To [M:POH2]NBLIG-1
  If [M:POH2]ITMREF(I) <> ""
    Call MAJ_CPR_LIG(I) From SUBPOHC
  Endif
Next I
End

########################################################################
# CONVERT_MONTANT : S/P de conversion des éléments de facturation      #
#                   et des montants HT, TVA                            #
#                   après un changement de devise commande             #
#                   type de cours commande                             #
# -------------------------------------------------------------------- #
# Subprog CONVERT_MONTANT (DEV,TYP)                                    #
#    DEV  : Nouveau code devise                                        #
#    TYP  : Nouveau type de cours                                      #
########################################################################
Subprog CONVERT_MONTANT(DEV,TYP)
Value Char    DEV
Value Integer TYP
Local Integer  I, STAT
If [M:POH3]NBFAC>0
  For I=0 To [M:POH3]NBFAC-1
    Call MAJ_ELEMENT (I,0,-1) From SUBPOHC
    If [M:POH3]AMTCOD(I)=2
      [M:POH3]FORMAT(I)="NZ:"+[F:TCU]CURFMT1
      Call CONVERT([M:POH1]CUR,DEV,GLOCALDEV,TYP,[M:POH0]ORDDAT,
&                  [M:POH3]INVDTAAMT(I),GBIDD2,STAT) From TRTDEV
      If STAT  Raz GBIDD2 : Endif
      [M:POH3]INVDTAAMT(I)=GBIDD2
      [M:POH3]AMTCODLIB(I)=DEV
    Endif
    Call CONVERT([M:POH1]CUR,DEV,GLOCALDEV,TYP,[M:POH0]ORDDAT,
&                [M:POH3]INVORDAMT(I),GBIDD2,STAT) From TRTDEV
    If STAT  Raz GBIDD2 : Endif
    [M:POH3]INVORDAMT(I)=GBIDD2
    Call CONVERT([M:POH1]CUR,DEV,GLOCALDEV,TYP,[M:POH0]ORDDAT,
&                [M:POH3]INVLINAMT(I),GBIDD2,STAT) From TRTDEV
    If STAT  Raz GBIDD2 : Endif
    [M:POH3]INVLINAMT(I)=GBIDD2
    Call CONVERT([M:POH1]CUR,DEV,GLOCALDEV,TYP,[M:POH0]ORDDAT,
&                [M:POH3]INVCPLAMT(I),GBIDD2,STAT) From TRTDEV
    If STAT  Raz GBIDD2 : Endif
    [M:POH3]INVCPLAMT(I)=GBIDD2
    Call MAJ_ELEMENT (I,0,+1) From SUBPOHC
  Next I
Endif
End


########################################################################
# INIT_COMPTES_INVDTA : S/P d'initialisation              MBT 27/12/07 #
#                des comptes d'un élément de facturation               #
# -------------------------------------------------------------------- #
# Subprog INIT_COMPTES_INVDTA (NOL)                                    #
#   NOL    : Indice de la ligne de l'élément à traiter (nolign-1)      #
########################################################################
Subprog INIT_COMPTES_INVDTA (NOL)
Value    Shortint NOL
#-----
Local    Shortint I
#----- Chargement de comptes avec "" pour désactiver l'action d'init -----#
For I=1 To 10
  If evalue("dim([M:POH3]ACC"+num$(I)+")")>0
    Assign "[M:POH3]ACC"+num$(I)+"(NOL)" With ""
  Endif
Next I
#----- Si ligne vide, pas la peine d'initialiser ! -----#
If [M:POH3]INVDTA(NOL)=0  End : Endif
#-----
Local    Libelle  WCDTFLG
Local    Char     ID1(20)(1..1), ID2(20)(1..3), CODPIECE(GLONGAU)
Local    Shortint J, LIG, SAVNOLIGN : SAVNOLIGN=nolign
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#-----
If [M:POH3]DEBCDT(NOL)=2 & [M:POH3]INVDTAAMT(NOL)=0
  [M:POH3]INVDTAAMT(NOL)=-1 : WCDTFLG=1
Else
  Raz WCDTFLG
Endif
#-----
Local File PORDER [TB0], PVCRFOOT [TB1], CPTANALIN [TB2]
nolign=NOL+1
#----- Chargement pseudo fichier entête PORDER [TB0] -----#
[F:TB0]=[M:POH0] : [F:TB0]=[M:POH1] : [F:TB0]=[M:POH2] : [F:TB0]=[M:POH3]
For I=0 To dim([F:TB0]INVDTALIN1)-1 : [F:TB0]INVDTALIN1(I)=GINVDTALIN(I) : Next I
#----- Chargement pseudo fichier ligne éléments facturation PVCRFOOT [TB1] -----#
[F:TB1]=[M:POH0] : [F:TB1]=[M:POH1] : [F:TB1]=[M:POH2] : [F:TB1]=[M:POH3]
[F:TB1]VCRNUM=[M:POH0]POHNUM
[F:TB1]VCRTYP=3
[F:TB1]IND   =NOL+1
#----- Pour forcer la condition de la pièce auto et charger le compte et la nature -----#
If [F:TB1]INVLINFLG=2 | [F:TB1]INVLINFLG=3 | [F:TB1]INVLINFLG=4 | [F:TB1]INVLINFLG=5
  [F:TB1]INVLINFLG=0
Endif
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="PVF"
[F:TB2]VCRTYP=3
[F:TB2]VCRNUM=[M:POH0]POHNUM
[F:TB2]VCRSEQ=NOL+1
[F:TB2]ANALIG=1
For I=1 To max(GNBCOA,2)
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=GCOA(I)
    [F:TB2]ACC(J-1)=evalue("[M:POH3]ACC"+num$(I)+"(NOL)")
  Endif
Next I
For I=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(I-1)=GDIE(I)
  If evalue("dim([M:POH3]PFICCE"+num$(I)+")")>0
    [F:TB2]CCE(I-1)=evalue("[M:POH3]PFICCE"+num$(I)+"(NOL)")
  Endif
Next I
#----- Chargement des identifiants (pas indispensable) -----#
ID1(1)=[M:POH0]POHNUM : # Num pas chargé en création si cteur auto !!
ID2(1)=[M:POH0]POHNUM
ID2(2)="3"
ID2(3)=num$(NOL+1)
If [M:POH0]POHNUM="" Raz ID1,ID2 : Endif
#-----
CODPIECE="POPV"
#----- Lecture de la pièce automatique -----#
If clalev([F:GAU])<=0 Local File GAUTACE   [GAU] : Endif
Read [GAU] GAU0=CODPIECE : If fstat Raz [F:GAU] : CODPIECE="PORD" : Endif
#----- Recherche du numéro de ligne de la pièce auto -----#
If clalev([F:GAD])<=0 Local File GAUTACED  [GAD] : Endif
Filter [GAD] Where COD=CODPIECE & LINNUM>0
For [GAD]
  If instr(1,vireblc([F:GAD]ACCKEY(0),4),"INVDTA")
    LIG=[F:GAD]LINNUM : Break
  Endif
Next
Filter [GAD]
If LIG=0
  Look [GAD] GAD0=CODPIECE;9
  If !fstat  LIG=9  Else  LIG=120 : Endif
Endif
#----- Recherche des comptes à l'aide de la pièce auto -----#
Call COMPTE(CODPIECE,LIG,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From CPTCOD
If STA
  Raz TPLAN, TCOMPTE, GMESSAGE
Else
  If [F:GAD]COD<>CODPIECE | [F:GAD]LINNUM<>LIG
    Read [GAD] GAD0=CODPIECE;LIG : If fstat  Raz [F:GAD] : Endif
  Endif
  For I=1 To 10
    If TPLAN(I)<>""
     #J=find(TPLAN(I),GCOA(1..GNBCOA))
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        Assign "[M:POH3]ACC"+num$(J)+"(NOL)" With TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
Close Local File [TB0], [TB1], [TB2]
If WCDTFLG=1  [M:POH3]INVDTAAMT(NOL)=0 : Endif
nolign=SAVNOLIGN
#-----
End


###############################################################################
# Préparation des sections analytiques d'une ligne d'élément de facturation   #
# --------------------------------------------------------------------------- #
# Si la clé de répartion est renseignée                                       #
#    il faut "mettre à blanc" toutes les sections                             #
# Si l'axe est suivi en analytique et que la section correspondante est vide  #
#    il faut forcer l'initialisation grâce au Raz                             #
# Si l'axe n'est pas suivi en analytique                                      #
#    il faut "mettre  à blanc" la section correspondante                      #
# --------------------------------------------------------------------------- #
# nolign contient le numéro de la ligne en cours                              #
# NOL contient l'indice de la ligne en cours                                  #
# [M:POH3]ACC1-10(NOL) contient les comptes                                   #
# GBIDI2 : 0 = Pas d'affichage des sections analytiques                       #
#          1 = Affichage des sections analytiques                             #
###############################################################################
$PREP_INIT_PFICCE
#-----
If dim(I)<1    Local Integer I             : Endif
If dim(WCCE)<1 Local Char    WCCE(GLONCCE) : Endif
#----- Si clé de répartition renseignée, pas de sections analytiques -----#
If !varinit([M:POH3]DSP,NOL)  [M:POH3]DSP(NOL)=[F:GAC]DSP : Endif
If [M:POH3]DSP(NOL)<>""
  For I=1 To GNBDIE
    If evalue("dim([M:POH3]PFICCE"+num$(I)+")")>0
      Assign"[M:POH3]PFICCE"+num$(I)+"(NOL)" With ""
    Endif
  Next I
#----- Pas de section si pas de suivi analytique sur l'axe concerné -----#
Else
  For I=1 To GNBDIE
    WCCE=evalue("[M:POH3]PFICCE"+num$(I)+"(NOL)")
    Raz mkstat
    Call SAIS_CCE(WCCE,I,"[M:POH3]ACC","[M:POH3]DSP") From TRTX3CPT
    If mkstat
      Assign "[M:POH3]PFICCE"+num$(I)+"(NOL)" With ""
      Raz mkstat
    Elsif evalue("[M:POH3]PFICCE"+num$(I)+"(NOL)")=""
      #----- Raz pour forcer l'initialisation -----#
      Case I
        When  1 : Raz [M:POH3]PFICCE1 (NOL)
        When  2 : Raz [M:POH3]PFICCE2 (NOL)
        When  3 : Raz [M:POH3]PFICCE3 (NOL)
        When  4 : Raz [M:POH3]PFICCE4 (NOL)
        When  5 : Raz [M:POH3]PFICCE5 (NOL)
        When  6 : Raz [M:POH3]PFICCE6 (NOL)
        When  7 : Raz [M:POH3]PFICCE7 (NOL)
        When  8 : Raz [M:POH3]PFICCE8 (NOL)
        When  9 : Raz [M:POH3]PFICCE9 (NOL)
        When 10 : Raz [M:POH3]PFICCE10(NOL)
        When 11 : Raz [M:POH3]PFICCE11(NOL)
        When 12 : Raz [M:POH3]PFICCE12(NOL)
        When 13 : Raz [M:POH3]PFICCE13(NOL)
        When 14 : Raz [M:POH3]PFICCE14(NOL)
        When 15 : Raz [M:POH3]PFICCE15(NOL)
        When 16 : Raz [M:POH3]PFICCE16(NOL)
        When 17 : Raz [M:POH3]PFICCE17(NOL)
        When 18 : Raz [M:POH3]PFICCE18(NOL)
        When 19 : Raz [M:POH3]PFICCE19(NOL)
        When 20 : Raz [M:POH3]PFICCE20(NOL)
      Endcase
    Endif
  Next I
Endif
#----- Affichage des sections analytiques -----#
If GBIDI2=1
  Affzo [POH3]DSP(NOL)
  Gosub AFFICH_PFICCE From SUBPOHC
Endif
Return


$AFFICH_PFICCE
#-----------------------------------------------------------------#
# Affichage des sections analytiques ligne élément de facturation #
#-----------------------------------------------------------------#
If dim(I)<1  Local Integer I : Endif
For I=1 To GNBDIE
  Case I
    When  1 : Affzo [POH3]PFICCE1 (NOL)
    When  2 : Affzo [POH3]PFICCE2 (NOL)
    When  3 : Affzo [POH3]PFICCE3 (NOL)
    When  4 : Affzo [POH3]PFICCE4 (NOL)
    When  5 : Affzo [POH3]PFICCE5 (NOL)
    When  6 : Affzo [POH3]PFICCE6 (NOL)
    When  7 : Affzo [POH3]PFICCE7 (NOL)
    When  8 : Affzo [POH3]PFICCE8 (NOL)
    When  9 : Affzo [POH3]PFICCE9 (NOL)
    When 10 : Affzo [POH3]PFICCE10(NOL)
    When 11 : Affzo [POH3]PFICCE11(NOL)
    When 12 : Affzo [POH3]PFICCE12(NOL)
    When 13 : Affzo [POH3]PFICCE13(NOL)
    When 14 : Affzo [POH3]PFICCE14(NOL)
    When 15 : Affzo [POH3]PFICCE16(NOL)
    When 16 : Affzo [POH3]PFICCE17(NOL)
    When 17 : Affzo [POH3]PFICCE17(NOL)
    When 18 : Affzo [POH3]PFICCE18(NOL)
    When 19 : Affzo [POH3]PFICCE19(NOL)
    When 20 : Affzo [POH3]PFICCE20(NOL)
  Endcase
Next I
Return


##################################################################################
# Calcul des montants éléments en % sur HT/TTC ou action suivant ordre de calcul #
##################################################################################
$CALCUL_MT_ELEMENT
#-----
If dim(I)<1          Local Integer I         : Endif
If dim(J)<1          Local Integer J         : Endif
If dim(SAVNOLIGN)<1  Local Integer SAVNOLIGN : Endif
#-----
SAVNOLIGN=nolign
#----- Chargement et tri du tableau de l'ordre de calcul -----#
For I=0 To [M:POH3]NBFAC-1
  [M:POH3]TABCLCORD(I)=[M:POH3]CLCORD(I)
  [M:POH3]TABINDPFI(I)=I
Next I
[M:POH3]NBPFI=[M:POH3]NBFAC
Sorta [M:POH3]NBPFI [M:POH3]NBPFI Order By [M:POH3]TABCLCORD(indice),
&                                          [M:POH3]TABINDPFI(indice)
#-----
For I=0 To [M:POH3]NBPFI-1
  J=[M:POH3]TABINDPFI(I)
  Call MAJ_ELEMENT(J,0,-1) From SUBPOHC
  #----- Calcul du montant de l'élément si pourcentage sur base -----#
  If [M:POH3]AMTCOD(J)=1 & (dim([M:POH3]DISVATFLG)<1 | [M:POH3]DISVATFLG(J)<>2)
    nolign=I+1 : Call AM_INVDTAAMT([M:POH3]INVDTAAMT(J)) From SUBPOH
  Endif
  #-----
  Call MAJ_ELEMENT(J,0,+1) From SUBPOHC
Next I
#-----
If GPIHCALTAX=2 | (dim([M:POH3]DISVATFLG)>1 & find(2,[M:POH3]DISVATFLG(0..[M:POH3]NBFAC-1)))
  For GPOH_INDTAX=1 To [M:POH3]NBTAX
    Gosub CAL_TAXE_GLOB From SUBPOHC
  Next GPOH_INDTAX
Endif
#-----
nolign=SAVNOLIGN
Return

# Issue 70985 - 2012-02-21 by MUARN : landed cost
############################################################################
# MAJ_CPR_LIG : S/P de calcul prix unitaire de revient    MUARN 21/02/2012 #
# ------------------------------------------------------------------------ #
# Subprog MAJ_CPR_LIG(NOL)                                                 #
#   NOL    : indice de la ligne de réception (nolign-1)                    #
############################################################################
Subprog MAJ_CPR_LIG (NOL)
Value   Shortint NOL
Local Decimal WCPRAMT, WUOMSTUCOE
#----- Si composant, pas de calcul prix de revient -----#
If [M:POH2]LINTYP(NOL)>2
  Raz [M:POH2]CPR(NOL) : End
Endif
#-----
Local   Decimal  WPRIPUR
Local   Decimal  WBASE, WMT, WNEWCPR, WRND, WTAXE
Local   Integer  STAT, I, J, WCPRFLG
#----- Chargement arrondi devise facture -----#
If [F:TCU]CUR<>[M:POH1]CUR
  Read [TCU] TCU0=[M:POH1]CUR
  If !fstat WRND=[F:TCU]CURRND Else WRND=0.01 : Endif
Else
  WRND=[F:TCU]CURRND
Endif
#-----
If [M:POH2]LINTYP(NOL)=2
  J=NOL+1
  While [M:POH2]LINTYP(J)>2 & J<[M:POH2]NBLIG
    If [M:POH2]QTYUOM(J)<>0
      WBASE+=[M:POH2]NETPRI(J)*[M:POH2]QTYUOM(J)  : # Mt ligne avec précision maxi
    Else
      WBASE+=[M:POH2]LINAMT(J)                    : # Mt ligne arrondi suivant devise
    Endif
    J+=1
  Wend
Else
  If [M:POH2]QTYUOM(NOL)<>0
    WBASE=[M:POH2]NETPRI(NOL)*[M:POH2]QTYUOM(NOL) : # Mt ligne avec précision maxi
  Else
    WBASE=[M:POH2]LINAMT(NOL)                     : # Mt ligne arrondi suivant devise
  Endif
Endif
#----- Eléments provenant du tarif -----#
For I=1 To 9
  If GINVDTALIN(I-1)<>0 & GNPRNOTFLG(I-1)=1
    Read [PFI] PFI0=GINVDTALIN(I-1) : If fstat Raz [F:PFI] : Endif
    If [F:PFI]NPRVLT=2
      If [M:POH2]LINTYP(NOL)=2
        J=NOL+1 : Raz WMT
        While [M:POH2]LINTYP(J)>2 & J<[M:POH2]NBLIG
          #----- C'est un montant -----#
          If GDISCRGTYP(I-1)=1
            If GCLCRUL(I-1)=1 : # Par unité
              WMT+=evalue("[M:POH2]DISCRGVAL"+num$(I)+"(J)")*[M:POH2]QTYUOM(J)
            Else              : # Par ligne
              WMT+=evalue("[M:PoH2]DISCRGVAL"+num$(I)+"(J)")
            Endif
          #----- C'est un pourcentage -----#
          Else
            WMT+=arr([M:POH2]LINAMT(J)*evalue("[M:POH2]DISCRGVAL"+num$(I)+"(J)")/100,WRND)
          Endif
          J+=1
        Wend
      Else
        #----- C'est un montant -----#
        If GDISCRGTYP(I-1)=1
          If GCLCRUL(I-1)=1 : # Par unité
            WMT=evalue("[M:POH2]DISCRGVAL"+num$(I)+"(NOL)")*[M:POH2]QTYUOM(NOL)
          Else              : # Par ligne
            WMT=evalue("[M:POH2]DISCRGVAL"+num$(I)+"(NOL)")
          Endif
        #----- C'est un pourcentage -----#
        Else
          WMT=arr([M:POH2]LINAMT(NOL)*evalue("[M:POH2]DISCRGVAL"+num$(I)+"(NOL)")/100,WRND)
        Endif
      Endif
      If GINCDCR(I-1)=2  WBASE-=WMT  Else WBASE+=WMT : Endif
    Endif
  Endif
Next I

# Issue 105027 - 2015-02-10 by MUARN : élément de facturation en inter site
If ([M:POH0]BETFCY=2 & [M:POH0]BETCPY=1 & GBETFCYCST = 2) | [M:POH0]BETFCY=1 | [M:POH0]BETCPY =2
  #----- Eléments provenant du pied de commande -----#
  For I=1 To 9
    If [M:POH2]INVDTALIN2(I-1)<>0
      Read [PFI] PFI0=[M:POH2]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        If [M:POH2]LINTYP(NOL)=2
          J=NOL+1
          While [M:POH2]LINTYP(J)>2 & J<[M:POH2]NBLIG
            WBASE+=evalue("[M:POH2]DISCRGAMT"+num$(I)+"(J)")
            J+=1
          Wend
        Endif
        WBASE+=evalue("[M:POH2]DISCRGAMT"+num$(I)+"(NOL)")
      Endif
    Endif
  Next I
Endif

#----- Conversion si nécessaire du montant en devise société -----#
If [M:POH1]CUR<>GLOCALDEV
  WMT=WBASE
  Call CONVERT2([M:POH1]CUR, GLOCALDEV, GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&                    WMT,WBASE,STAT) From TRTDEV
  WBASE=arr(WBASE,10^-GDECPRI)
Endif
#----- Calcul prix unitaire d'achat en devise société et par unité de stock -----#
Call CALCUL_PRIPUR(NOL,WPRIPUR) From SUBPOHC

# Issue 93835 - 2013-10-24 by MUARN : utilisation GBIDD1 ne pas écraser QTYSTU
Call PCAL_QTY([M:POH2]QTYPUU(NOL),[M:POH2]PUU(NOL),GBIDD1,[M:POH2]STU(NOL),
&             [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,WUOMSTUCOE) From TRTACHQTE1
WCPRAMT = arr([M:POH2]CPRAMT(NOL)/WUOMSTUCOE,10^-GDECPRI)

WCPRFLG=1

#----- Calcul du prix unitaire de revient théorique en US -----#
If [M:POH2]QTYSTU(NOL)<>0
  [M:POH2]CPRPRI(NOL)=arr(WBASE/[M:POH2]QTYSTU(NOL),10^-GDECPRI)
Else
  [M:POH2]CPRPRI(NOL)=WBASE
Endif

#----- Calcul prix de revient (prix ordre) si pas de facture et non modifié -----#
If [M:POH2]INVQTYSTU(NOL)=0 & WCPRFLG=1
  If [M:POH2]CPRCOE(NOL) = 0 [M:POH2]CPRCOE(NOL) = 1 : Affzo[POH2]CPRCOE(NOL) : Endif
  # Issue 105027 - 2014-12-31 by MUARN : cas particulier inter-site
  If [M:POH0]BETFCY = 2 & [M:POH0]BETCPY=1
    # part coeff + cout + élément facturation
    [M:POH2]CPR(NOL) = (WPRIPUR*[M:POH2]CPRCOE(NOL) - WPRIPUR) + WCPRAMT + ([M:POH2]CPRPRI(NOL)-WPRIPUR)
  Else
    # Issue 84130 - 2012-12-14 by MAE : landed cost
    [M:POH2]CPR(NOL)=[M:POH2]CPRPRI(NOL)-WPRIPUR+(WPRIPUR*[M:POH2]CPRCOE(NOL))+WCPRAMT
  Endif

  # Issue 105027 - 2014-12-31 by MUARN : ne pas faire en inter-site
  If GNODVATSTO = 2 &[M:POH0]BETFCY = 1
    #----- Taxes non déductible -----#
    WTAXE+=[M:POH2]AMTTAXLIN1(NOL)-[M:POH2]DEDTAXLIN1(NOL)
    WTAXE+=[M:POH2]AMTTAXLIN2(NOL)-[M:POH2]DEDTAXLIN2(NOL)
    WTAXE+=[M:POH2]AMTTAXLIN3(NOL)-[M:POH2]DEDTAXLIN3(NOL)
    If dim([M:POH2]AMTTAXRCP(NOL)) >0
      WTAXE+=[M:POH2]AMTTAXRCP(NOL) -[M:POH2]DEDTAXRCP(NOL)
      WTAXE+=[M:POH2]AMTTAXISS(NOL) -[M:POH2]DEDTAXISS(NOL)
      WTAXE+=[M:POH2]AMTTAXOTH1(NOL)-[M:POH2]DEDTAXOTH1(NOL)
      WTAXE+=[M:POH2]AMTTAXOTH2(NOL)-[M:POH2]DEDTAXOTH2(NOL)
    Endif
    If [M:POH1]CUR<>GLOCALDEV
    WMT=WTAXE
    Call CONVERT2([M:POH1]CUR, GLOCALDEV, GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&                    WMT,WTAXE,STAT) From TRTDEV
    WBASE=arr(WBASE,10^-GDECPRI)
    Endif
    If [M:POH2]QTYSTU(NOL)<>0
      [M:POH2]CPR(NOL) += (WTAXE/[M:POH2]QTYSTU(NOL))
    Endif
  Endif
  # Issue 100325 - 2014-11-04 by MUARN : ne faire l'arrondi qu'à la fin
  #[M:POH2]CPR(NOL)=arr([M:POH2]CPR(NOL),10^-GDECPRI)
  [M:POH2]LINAMTCPR(NOL)=[M:POH2]CPR(NOL)*[M:POH2]QTYSTU(NOL)
  # si structure de cout et/ou Factures complémentaires
  If [M:POH2]STCNUM(NOL) <> ""
     # Issue 84130 - 2012-12-17 by SR : Si structure de cout
     If [M:POH2]STCNUM(NOL) <> ""
       [M:POH2]LINAMTCPR(NOL) += [M:POH2]FCSCPR(NOL)
     Endif
     [M:POH2]CPR(NOL)        = [M:POH2]LINAMTCPR(NOL) / [M:POH2]QTYSTU(NOL)
     [M:POH2]CPR(NOL)        = arr([M:POH2]CPR(NOL),10^-GDECPRI)
  Endif
  # Issue 100325 - 2014-11-04 by MUARN : ne faire l'arrondi qu'à la fin
  [M:POH2]CPR(NOL)=arr([M:POH2]CPR(NOL),10^-GDECPRI)

  [M:POH2]LINAMTCPR(NOL)= arr([M:POH2]LINAMTCPR(NOL),10^-GDECPRI)

Endif
[M:POH2]UPDFLG(NOL)=1

# Issue 84129 - 2012-10-03 by MUARN : calcul cout achat et cout achat unitaire
Call MAJ_CSTPUR_LIG("POH2",NOL,[M:POH0]ORDDAT,[M:POH1]CUR, [M:POH1]CHGTYP) From STCCLC
End

# Issue 70985 - 2012-02-21 by MUARN : landed cost
###########################################################################
# CALCUL_PRIPUR : S/P de calcul prix unitaire d'achat    MUARN 21/02/2012 #
# ----------------------------------------------------------------------- #
# Subprog CALCUL_PRIPUR(NOL)                                              #
#   NOL    : indice de la ligne de commande (nolign-1)                    #
###########################################################################
Subprog CALCUL_PRIPUR(NOL,WPRIPUR)
Value    Integer NOL
Variable Decimal WPRIPUR
#-----
Local    Char    WUOM(GLONUOM)
Local    Char    WCUR(GLONCUR)
Local    Integer WSTAT
Local    Decimal WCOEFF
Local    Char    WNUM(GLONPIH)
Local    Decimal WQTE
Local    Integer WLINTYP
Local    Integer J
#-----
Raz WPRIPUR

#----- Récupération prix d'achat sur commande -----#
If [M:POH2]LINTYP(NOL)=2
  J=NOL+1
  While [M:POH2]LINTYP(J)>2 & J<[M:POH2]NBLIG
    If [M:POH2]QTYUOM(J)<>0
      WPRIPUR+=[M:POH2]NETPRI(J)*[M:POH2]QTYUOM(J)
    Else
      WPRIPUR+=[M:POH2]LINAMT(J)
    Endif
    J+=1
  Wend
  If [M:POH2]QTYUOM(NOL)<>0
    WPRIPUR/=[M:POH2]QTYUOM(NOL)
  Endif
Else
  WPRIPUR=[M:POH2]NETPRI(NOL)
Endif
WUOM  =[M:POH2]UOM(NOL)
WCUR  =[M:POH1]CUR
WCOEFF = [M:POH2]QTYSTU(NOL) / [M:POH2]QTYUOM(NOL)

#----- Conversion si nécessaire du montant en devise société -----#
If WCUR<>GLOCALDEV
  Call CONVERT2(WCUR,GLOCALDEV, GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&                    WPRIPUR,WPRIPUR,WSTAT) From TRTDEV
  WPRIPUR=arr(WPRIPUR,10^-GDECPRI)
Endif
#----- Le prix unitaire d'achat doit être par unité de stock -----#
If WUOM<>[M:POH2]STU(NOL)
  If WCOEFF=0  WCOEFF=1 : Endif
  WPRIPUR=arr(WPRIPUR/WCOEFF,10^-GDECPRI)
Else
  WPRIPUR=arr(WPRIPUR,10^-GDECPRI)
Endif
End

#----------------------------------------------------#
# Contrôle dépassement budget à la ligne de commande #
# -------------------------------------------------- #
# NOL = Indice de la ligne à contrôler               #
#                                                    #
# GMESSAGE et GERR sont chargés si dépassement       #
#----------------------------------------------------#
# Issue 84130 - 2012-11-16 by MUARN : landed cost - déplacé de SUBPOHA à SUBPOHC, trop de lignes
Subprog CTRL_BUDLIN(NOL)
Value Integer NOL
#-----
Local Char     WCPTANA(GLONGAC)
Local Char     MESSA(250)
Local Integer  I, OK, OKDA
Local Decimal  WQTYUO, WLINAMT, WQTYDA, WAMTDA
Local Char     TBCCE (GLONCCE)(1..max(GNBDIE,GOPTCANA))
Local Char     TBDIE2(GLONDIE)(1..max(GNBDIE,GOPTCANA))
Local Char     TBCCE2(GLONCCE)(1..max(GNBDIE,GOPTCANA))
#-----
Raz GMESSAGE, GERR
#----- Recherche compte de la nature analytique -----#
Call RECH_ACC(2,"[M:POH2]LINACC",NOL,WCPTANA) From TRTX3CPT
If WCPTANA=""  End : Endif
#-----
If GPURCMMDAT=1
  [M:POH2]DATBUD(NOL)=[M:POH0]ORDDAT
Else
  [M:POH2]DATBUD(NOL)=[M:POH2]EXTRCPDAT(NOL)
Endif
#-----
For I=1 To GNBDIE : TBCCE(I)=evalue("[M:POH2]CCE"+num$(I)+"(NOL)") : Next I
#----- Filtrage des codes et sections analytiques sur référentiel analytique -----#
Call SETCCEAXE(GSOCIETE,GTYPANA,GDIE,TBCCE,TBDIE2,TBCCE2) From CPTDIV
#----- Conversion quantité UA puis US (Si pas de coef) en unité d'oeuvre -----#
Call PCAL_QTY([M:POH2]QTYPUU(NOL),[M:POH2]PUU(NOL),WQTYUO,[F:GAC]UOM,
&             [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GBIDD1) From TRTACHQTE1
If [F:TCO]UOM1=""
  Call PCAL_QTY([M:POH2]QTYSTU(NOL),[M:POH2]STU(NOL),WQTYUO,[F:GAC]UOM,
&               [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GBIDD1) From TRTACHQTE1
Endif
#----- Si prise en compte de DA, il faut enlever le mt du pré-engagement -----#
OKDA=1
Raz WQTYDA, WAMTDA
For [PWO] PWO0 Where PRONUM=adxuid(1)
&                  & CODFNC="POH"
&                  & LINNUM=[M:POH2]POHLIN(NOL)
  If [F:PWO]WIPTYP<>2 | [F:PWO]WIPSTA<>2  OKDA=0 : Break : Endif
  If [F:PWO]PSDLIN=0
    Read [ORD] ORD0=[F:PWO]WIPTYP;[F:PWO]WIPNUM;[F:PWO]ITMREF
    If fstat  Raz [F:ORD] : Endif
    If [F:ORD]ABBFIL="PSD"
      Readlock [PSD] PSD0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
      If fstat  Raz [F:PSD] : Endif
    Else
      Raz [F:PSD]
    Endif
  Else
    Readlock [PSD] PSD0=[F:PWO]WIPNUM;[F:PWO]PSDLIN
    If fstat  Raz [F:PSD] : Endif
  Endif
  If [F:PSD]PSHNUM<>""
    If [M:POH2]QTYSTU(NOL)<>0
      WQTYDA+=WQTYUO*[F:PWO]QTYSTU/[M:POH2]QTYSTU(NOL)
      GBIDD1 =[F:PSD]NETPRI*[F:PSD]QTYPUU*[F:PWO]QTYSTU/[M:POH2]QTYSTU(NOL)
      If [F:PSD]CUR<>GCUR
        Call CONVERT([F:PSD]CUR,GCUR,GLOCALDEV,[F:PSD]CHGTYP,[F:PSD]EXTRCPDAT,
&                    GBIDD1,GBIDD2,GBIDI2) From TRTDEV
        WAMTDA+=GBIDD2
      Else
        Call ARRDEV(GBIDD1,GCUR) From TRTDIV
        WAMTDA+=GBIDD1
      Endif
    Endif
  Endif
Next
#-----
WLINAMT=[M:POH2]LINAMT(NOL)
If OKDA=1
  WQTYUO -=WQTYDA
  WLINAMT-=WAMTDA
Endif
#-----
Call BUDGET([M:POH2]DATBUD(NOL),GFINRSP,GTYPANA,GCUR,WCPTANA,
&           GDIE,TBCCE,WLINAMT,WQTYUO,0,OK,MESSA) From CPTBUD
#--------------------------------------------------------#
# OK =-1 Une erreur a empêché le contrôle de s'effectuer #
# OK = 0 Le budget est dépassé                           #
# OK = 1 Tout va bien                                    #
#--------------------------------------------------------#
If OK=1  End : Endif
MESSA+="\"+mess(18,197,1)-num$(NOL+1)
[M:POH2]FBUFLG(NOL)=2
GMESSAGE=MESSA
If GCNTBUD=2  GERR=1  Else  GERR=2 : Endif
End

#                                                                                  # hcb 71276 deb
$C_ITMREF_ECC
If VALEUR <> [M]ITMREF (nolign-1)
   If dim([M]ECCVALMAJ) > 0
      Raz [M]ECCVALMAJ(nolign-1)
      Raz [M]ECCVALMIN(nolign-1)
   Endif
Endif
Return
$AM_ITMREF_ECC
If dim([M]ECCVALMAJ) > 0
   If [F:ITM]ECCFLG < 2 | [F:ITM]ECCSTO < 2
      Grizo  [M]ECCVALMAJ(NOL)
      Grizo  [M]ECCVALMIN(NOL)
   Endif
   If [F:ITM]ECCSTO<3
      Grizo  [M]ECCVALMIN(NOL)
   Endif
Endif
Return
#                                                                                  # hcb 71276 fin


# 106430.sn - Purchase planning
######################################################################################
Subprog UPDATE_CONTAINER (TCTRNUM,TCTRQTY)
Value Char    TCTRNUM
Value Integer TCTRQTY

#Display updates only, don't run on import.
If GIMPORT : End : Endif

If !clalev([F:TCTR]) : Local File TABCONTAINER [TCTR] : Endif
Read [TCTR]TCTR0 = [L]TCTRNUM
If fstat : Raz [F:TCTR] : Endif

If [L]TCTRNUM = ""
  Raz [M:POH2]TCTRQTY : Diszo [M:POH2]TCTRQTY
  Actzo [M:POH2]WEICAP, VOLCAP
Else
  Actzo [M:POH2]TCTRQTY

  #Set the weight and volume capacity for the container
  If [L]TCTRQTY <= 0 : [L]TCTRQTY=1 : Endif
  [M:POH2]WEICAP = [F:TCTR]MAXWEI  * [L]TCTRQTY
  [M:POH2]VOLCAP = [F:TCTR]TCTRVOL * [L]TCTRQTY

  Diszo [M:POH2]WEICAP, VOLCAP
Endif

#Set the UOM for both weight and volume
If [F:TCTR]WEU=""
  [M:POH2]TCTRWEU = GSALDSPWEU
Else
  [M:POH2]TCTRWEU = [F:TCTR]WEU
Endif

If [F:TCTR]VOU=""
  [M:POH2]TCTRVOU = GSALDSPVOU
Else
  [M:POH2]TCTRVOU = [F:TCTR]VOU
Endif

Affzo [POH2]20

Call UPDATE_VOLWEI

End

######################################################################################
Subprog UPDATE_VOLWEI
Local Decimal TOTWEI, TOTVOL

#Display updates only, don't run on import.
If GIMPORT : End : Endif

# Get the total and convert to container UOMs
TOTWEI = [M:POH3]TOTLINWEU
TOTVOL = [M:POH3]TOTLINVOU
Call CONVERT_QTY([M:POH3]DSPWEU,[M:POH2]TCTRWEU,TOTWEI)From TRTX3
Call CONVERT_QTY([M:POH3]DSPVOU,[M:POH2]TCTRVOU,TOTVOL)From TRTX3

# Set the totals and the remaining available
[M:POH2]WEITOT = [L]TOTWEI
[M:POH2]VOLTOT = [L]TOTVOL
Raz [M:POH2]WEIAVL, VOLAVL
If [M:POH2]WEICAP > 0 : [M:POH2]WEIAVL = [M:POH2]WEICAP - [L]TOTWEI : Endif
If [M:POH2]VOLCAP > 0 : [M:POH2]VOLAVL = [M:POH2]VOLCAP - [L]TOTVOL : Endif

Affzo [M:POH2]25, 30

End

######################################################################################
# 106430.en - Purchase planning

