#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################################################
# DOSMAJ60 : Mises à jour à effectuer lors du passage à la version 9 (Release 60)
# Moulinette avant la version 9 (AMBASSADOR)
##################################################################################


#-------------------------------------#
#         Avant mise à jour           #
#-------------------------------------#

#######################################
Subprog AMAJ
Local Integer VERSION

Onerrgo ERREUR

VERSION = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ60 - AMAJ - VERSION = "-num$(VERSION),-1) From GESECRAN

#----- Superviseur en premier
Call ECR_TRACE("************** AMAJ SUPMAJ60 ***************",-1) From GESECRAN
Call MAJDIC From SUPMAJ60
# Issue 109577
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=1 & func DOSVUE.ISVIEW([F:ADS]DOSSIER,"BPCINVLIG")=0
&                                           & func DOSVUE.ISVIEW([F:ADS]DOSSIER,"BPCINVLIGA")=1
 Call CRE_HISTAB([F:ADS]DOSREF,[F:ADS]DOSSIER,[F:ADS]TYPDBA, "BPCINVLIGA") From CREHISTO
Endif

Call AMAJ   From SUPMAJ60      : # Moulinettes Superviseur

#GVALIDE(2) = 1 : # Ecrans
#GVALIDE(3) = 1 : # Objets
#GVALIDE(4) = 1 : # Fenêtres et TRT générés superviseur
#GVALIDE(5) = 1 : # Consultations


#----- Puis Tronc commun

#109831.sn
Call ECR_TRACE("************** ATRCMAJ60 TRCMAJ60 ***************",-1) From GESECRAN
Call ATRCMAJ60   From TRCMAJ60
#109831.en

#----- Ensuite les autres modules

If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
 Call ECR_TRACE("************** ATRCMAJ CPTMAJ60 ***************",-1) From GESECRAN
 Call ATRCMAJ From CPTMAJ60 : # Moulinettes Compta - Commun
 If [F:ADS]MODULE(1)=2
  Call ECR_TRACE("************** AMAJ CPTMAJ60 ***************",-1) From GESECRAN
  Call AMAJ  From CPTMAJ60 : # Moulinettes Compta
  GVALTRANS(2)=2
 Endif
Endif

If [F:ADS]MODULE(2)=2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
 Call ECR_TRACE("************** AMAJ TRSMAJ60 ***************",-1) From GESECRAN
 Call AMAJ From TRSMAJ60 : # Moulinettes Tiers
 GVALTRANS(3)=2
Endif

Call ECR_TRACE("************** AMAJ FASMAJ60 ***************",-1) From GESECRAN
If [F:ADS]MODULE(13)=2
  Call AMAJ From FASMAJ60 : # Moulinettes Immobilisations
  GVALTRANS(14)=2
Endif

# FGR 01/07/2015 : X3SUIVI105605 (début)
If [F:ADS]MODULE(4)=2
  Call ECR_TRACE("************** AVENMAJ60 VENMAJ60 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    Call AVENMAJ60 From VENMAJ60 : # Moulinettes Ventes
    GVALTRANS(5)=2               : # TRT générés Ventes (transactions, tarifs)
  Else
    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif
# FGR 01/07/2015 : X3SUIVI105605 (fin)

Onerrgo
End



#-------------------------------------#
#          Après mise à jour          #
#-------------------------------------#

#######################################
Subprog MAJ
Local Integer VERSION

Onerrgo ERREUR

VERSION = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ60 - MAJ - VERSION = "-num$(VERSION),-1) From GESECRAN

#----- Superviseur en premier

Call ECR_TRACE("************** MAJ SUPMAJ60 ***************",-1) From GESECRAN
Call MAJ      From SUPMAJ60     : # Moulinettes Superviseur

#----- Puis Tronc commun

Call ECR_TRACE("************** MAJ TRCMAJ60 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  Call TRCMAJ60 From TRCMAJ60     : # Moulinettes Tronc commun
Else
  Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

#----- Ensuite les autres modules


If [F:ADS]MODULE(1)=2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
  Call ECR_TRACE("************** MAJ CPTMAJ60 ***************",-1) From GESECRAN
  Call MAJ  From CPTMAJ60  : # Moulinettes Compta
Endif

If [F:ADS]MODULE(2)=2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
  Call ECR_TRACE("************** MAJ TRSMAJ60 ***************",-1) From GESECRAN
  Call MAJ  From TRSMAJ60  : # Moulinettes Tiers
Endif

# FGR 01/07/2015 : X3SUIVI105605 (début)
If [F:ADS]MODULE(11) = 2
  Call ECR_TRACE("************** MAJ CRMMAJ60 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER) = 0 Then
    Call HDKMAJ60  From CRMMAJ60  : # Moulinettes HDK (support client)
  Else
    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif
# FGR 01/07/2015 : X3SUIVI105605 (fin)

Call ECR_TRACE("************** AMAJ FASMAJ60 ***************",-1) From GESECRAN
If [F:ADS]MODULE(13)=2
  Call MAJ From FASMAJ60 : # Moulinettes Immobilisations
Endif

############################################
# MODUL Manufacturing
############################################
# Issue 107012 - 2015-09-17 by BEEBE : Initialize ROUOPENUM = 0 for unexpected tracked OPs
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA47
Endif

Onerrgo
End

###################################################################################
###################################################################################
###################################################################################

$ERREUR
GERRDOS = errn
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Resume

