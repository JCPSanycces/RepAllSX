#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
$ACTION
  Case ACTION
    When Default
  Endcase
Return

##########################################################################################################
# Screens fields
##########################################################################################################
# PSO2
##########################################################################################################
Subprog AS_NBLIG2
  If [M:PSO2]ITMREF(nolign-1) = AVOID.ACHAR Then
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

  If VALEUR <> [M:PSO2]QTY(nolign-1) Then
    [M:PSO0]CHGFLG = [V]CST_AYES
  Endif
  [M:PSO2]UPDLIG(nolign-1) = [V]CST_AYES         # Issue X3-49776 - 2018-06-25 by FGR
End

##########################################################################################################
Subprog AM_BASPRI(VALEUR)
Variable Decimal VALEUR

  If VALEUR <> [M:PSO2]BASPRI(nolign-1) Then
    [M:PSO0]CHGFLG = [V]CST_AYES
  Endif
  [M:PSO2]UPDLIG(nolign-1) = [V]CST_AYES         # Issue X3-49776 - 2018-06-25 by FGR
End

##########################################################################################################
Subprog C_PRODGRPLVL(VALEUR)
Variable Integer VALEUR

  Case VALEUR
    When 3
      If [M:PSO2]PBUCOD(nolign-1) = AVOID.ACHAR Then
        GMESSAGE = mess(380,2260,1)
        GERR = 1
        GOK = 0
        End
      Endif
    When 4
      If [M:PSO2]TASCOD(nolign-1) = AVOID.ACHAR Then
        GMESSAGE = mess(381,2260,1)
        GERR = 1
        GOK = 0
        End
      Endif
  Endcase
End

##########################################################################################################
Subprog AM_PRODGRPLVL(VALEUR)
Variable Integer VALEUR

  If VALEUR <> [M:PSO2]PRODGRPLVL(nolign-1) Then
    [M:PSO0]CHGFLG = [V]CST_AYES
  Endif
  [M:PSO2]UPDLIG(nolign-1) = [V]CST_AYES         # Issue X3-49776 - 2018-06-25 by FGR
End

