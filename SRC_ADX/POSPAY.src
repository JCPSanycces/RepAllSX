#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-65076 - 2017-12-01 by FHA : Void checks should be included if "payment date range" keyed in
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)

OFONCTION=GFONCTION
If GFONCTION<>"GESPPY"
  GFONCTION="GESPPY" : Call AUTORIS From EXEFNC
Endif

GACTION = "POSPAY"

Call TRAITE_CHAR(VALBOUT,PARBOUT,"","POSPAY","DPOSPAY",3,"") From GTRAITE
If OFONCTION<>GFONCTION
  GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif

End

#_______________________________________________________________________________

$ACTION
Case ACTION
  When "INIT_DIA"  : Gosub INIT_DIA
  When "TIT_DIA"   : Gosub TIT_DIA
  When "CONTROLE"  : Gosub CONTROLE
  When "EXEC"      : Gosub EXEC
  When "SEL_TABLE" : Gosub SEL_TABLE
  When "BOUT_TABLE": Gosub BOUT_TABLE
Endcase

Return

#_______________________________________________________________________________

$INIT_DIA
If clalev([F:BAN])=0  : Local File BANK      [BAN]  : Endif
If clalev([F:BPA])=0  : Local File BPADDRESS [BPA]  : Endif
If clalev([F:CHN])=0  : Local File CHQNUM    [CHN]  : Endif
If clalev([F:CHN1])=0 : Local File CHQNUM    [CHN1] : Endif
If clalev([F:CPY])=0  : Local File COMPANY   [CPY]  : Endif
If clalev([F:PYH])=0  : Local File PAYMENTH  [PYH]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR    [TCU]  : Endif
If clalev([F:TFB])=0  : Local File TABFILBAN [TFB]  : Endif

Link [CHN] With [PYH]PYH0=[F:CHN]PAYNUM,
&               [BAN]BAN0=[F:CHN]BAN,
&               [CPY]CPY0=[F:BAN]CPY,
&               [TCU]TCU0=[F:PYH]CUR
&          As [LNK]
&          Order By Key CHN0

If GERREUR : GERREUR=0 : FIN=1 : Endif

Affzo [DIA]
Call DEBUT(GUSER) From CPTTRT
Setmok [DIA] With 0

Return

#_______________________________________________________________________________

$TIT_DIA
Local Char NOMFIL(GDIMFIC)
If !GBATCH
 [M:DIA]TYPFIL=2
 If [M:DIA]VOLFIL=""
  Call PARAMUTIL("REPBANKDEF",NOMFIL,GUSER,"") From SUBAUS
  If NOMFIL<>"" & left$(NOMFIL,1)="["
   [M:DIA]VOLFIL = NOMFIL
  Else
   [M:DIA]VOLFIL = "["+GDIRBQE+"]"
  Endif
 Endif
Endif
Affzo [M:DIA]VOLFIL
Call AM_TYPFIL([M:DIA]TYPFIL) From SUBFRM

# 100380.sn
If dim([M:DIA]LEG)>0
  zonsui = "LEG"
Else
  zonsui = "ALLCPY"
Endif
# 100380.en

Return

#_______________________________________________________________________________

$CONTROLE
If GSERVEUR : [M:DIA]TRCFLG=2 : Endif
# Display wait message
TMP=1 : TIT="O" : # Operation in progress...

Return

#_______________________________________________________________________________

$EXEC
Local Integer STA
Local Char    MESSA(100)
Local Char    CRITERE(250)
Local Char    LABEL(50), LABELTO(10), LBLALLFEM(10), LBLALLMAS(10)

If !GSERVEUR & [M:DIA]TRCFLG=2
    Call TEXTE(51100,LABEL) From OBJDIV : # Positive Pay file generation
    Call OUVRE_TRACE(LABEL) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("POSPAY","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

Gosub BUILD_POSPAY_CRITERIA

# Filter link records to "in the bank" payments or voided checks
# within the selection criteria
Filter [LNK] Where evalue(CRITERIA) & find([F:CHN]STA,2,3,4)

Call POSITIVEPAY(STA, MESSA) From POSPAY

If STA
  GERR = 1 : GMESSAGE = MESSA
Endif

If !GSERVEUR & [M:DIA]TRCFLG=2
  If GERR=1 : Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Endif
  Call FERME_TRACE From LECFIC
  TRA = 1 : # display trace
  FIN = 1
Endif

Return

#_______________________________________________________________________________

$SEL_TABLE
Default File [LNK]

Case COUZON

  When "POSPAYSEQ"
    # The LNK table is used for this lookup in order to include the company
    # associated with the bank for each CHQNUM record.
    NBCOL   = 5

    Call TEXTFIC("CHQNUM","POSPAYSEQ",1,TIT(1)) From OBJDIV
    TIT(0)  = mess(12,123,1)-TIT(1)
    COL(1)  = "[F:CHN]POSPAYSEQ"

    COL(2)  = "[F:CHN]CHQNUM"
    Call TEXTFIC("CHQNUM","CHQNUM",1,TIT(2)) From OBJDIV

    COL(3)  = "[F:CHN]POSPAYCREDAT"
    Call TEXTFIC("CHQNUM","POSPAYCREDAT",1,TIT(3)) From OBJDIV

    COL(4)  = "[F:CHN]BAN"
    Call TEXTFIC("CHQNUM","BAN",1,TIT(4)) From OBJDIV

    COL(5)  = "[F:BAN]CPY"
    Call TEXTFIC("BANK","CPY",1,TIT(5)) From OBJDIV

    ORDRE   = "POSPAYSEQ Desc;CHQNUM Desc"
    START   = "[F:CHN]POSPAYSEQ"
    CRITERE = 'POSPAYSEQ<>""'

  When "CHQDEB","CHQFIN"
    # The LNK table is used for this lookup in order to limit the results to records
    # for the current bank, which can be based on the selected company or legislation.
    NBCOL  = 4

    Call TEXTFIC("CHQNUM","CHQNUM",1,TIT(1)) From OBJDIV
    TIT(0)  = mess(12,123,1)-TIT(1)
    COL(1) = "[F:CHN]CHQNUM"

    COL(2) = "[F:CHN]PRNDAT"
    Call TEXTFIC("CHQNUM","PRNDAT",1,TIT(2)) From OBJDIV

    COL(3) = "[F:CHN]BAN"
    Call TEXTFIC("CHQNUM","BAN",1,TIT(3)) From OBJDIV

    COL(4) = "mess([F:CHN]STA,2658,1)"
    Call TEXTFIC("CHQNUM","STA",1,TIT(4)) From OBJDIV

    ORDRE   = "CHQNUM"
    START   = "[F:CHN]CHQNUM"
    STARTEXP = [M:DIA]CHQDEB
    CRITERE = func ADD_BANK_CRITERIA('POSPAYSEQ=""')

  When "BAN"
    OBJET   = "BAN"
    CRITERE = "[F:BAN]CPY=[M:DIA]CPY"

Endcase

Return

#_______________________________________________________________________________

$BOUT_TABLE:

# Enable paging of manually defined lookups (declared in GACTION)
DEFPAG = 1

Return

#_______________________________________________________________________________

Subprog C_GENTYP(VALEUR)
Variable Integer VALEUR

If VALEUR=1
  Effzo POSPAYSEQ : Grizo POSPAYSEQ
  Actzo ALLCPY : Call C_ALLCPY([M:DIA]ALLCPY)
  Actzo ALLCHQ : Call C_ALLCHQ([M:DIA]ALLCHQ)
  Actzo ALLPAY : Call C_ALLPAY([M:DIA]ALLPAY)
Else
  Actzo POSPAYSEQ
  [M:DIA]ALLCPY = 2 : Affzo ALLCPY : Grizo ALLCPY : Call C_ALLCPY([M:DIA]ALLCPY) From POSPAY
  Call AM_CPY([M:DIA]CPY) From W1POSPAY : # To clear description
  If dim([M:DIA]LEG)>0    # 100380.n
    Effzo LEG : Grizo LEG : Call AM_LEG([M:DIA]LEG) From W1POSPAY
  Endif                   # 100380.n
  [M:DIA]ALLBAN = 2 : Affzo ALLBAN : Grizo ALLBAN : Call C_ALLBAN([M:DIA]ALLBAN) From POSPAY
  Call AM_BAN([M:DIA]BAN) From W1POSPAY
  [M:DIA]ALLCHQ = 2 : Affzo ALLCHQ : Grizo ALLCHQ : Call C_ALLCHQ([M:DIA]ALLCHQ) From POSPAY
  [M:DIA]ALLPAY = 2 : Affzo ALLPAY : Grizo ALLPAY : Call C_ALLPAY([M:DIA]ALLPAY) From POSPAY
Endif

End

#_______________________________________________________________________________

Subprog C_POSPAYSEQ(VALEUR)
Variable Char VALEUR()
Local Integer FOUND

If VALEUR<>""
  For [F:CHN] Where [F:CHN]POSPAYSEQ=VALEUR
    FOUND = 1
  Next
  If !FOUND
    GMESSAGE = VALEUR+":"-mess(23,100,1)
    mkstat   = 2
  Endif
Endif

End

#_______________________________________________________________________________

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR

If VALEUR=2
  Effzo CPY,BAN
  [M:DIA]ALLBAN = 2 : Affzo ALLBAN
  Grizo CPY,BAN,ALLBAN
  GSOCIETE=""
  If dim([M:DIA]LEG)>0 : Actzo LEG : Endif
Else
  Actzo CPY,ALLBAN
  If dim([M:DIA]LEG)>0
    Effzo LEG : Grizo LEG : Call AM_LEG([M:DIA]LEG) From W1POSPAY
  Endif
Endif

End

#_______________________________________________________________________________

Subprog AS_CPY(VALEUR)
Variable Char VALEUR()

If [M:DIA]ALLCPY = 2 : mkstat = 1 : Endif

End

#_______________________________________________________________________________

Subprog C_CPY(VALEUR)
Variable Char VALEUR()

Call C_CPY(VALEUR) From CPTTRT

End

#_______________________________________________________________________________

Subprog AM_CPY(VALEUR)
Variable Char VALEUR()
Call AM_CPY (VALEUR) From CPTTRT
End

#_______________________________________________________________________________

Subprog C_ALLBAN(VALEUR)
Variable Integer VALEUR

If VALEUR=2
  Effzo BAN
  Grizo BAN
Else
  Actzo BAN
Endif

End

#_______________________________________________________________________________

Subprog C_BAN(VALEUR)
Variable Char VALEUR()

# Verify bank belongs to selected company
If CPY<>"" and [F:BAN]CPY<>[M:DIA]CPY
  GMESSAGE = mess(12,117,1)
  mkstat   = 2
Endif

End

#_______________________________________________________________________________

Subprog C_ALLCHQ(VALEUR)
Variable Integer VALEUR

If VALEUR=2
  Effzo CHQDEB,CHQFIN
  Grizo CHQDEB,CHQFIN
Else
  Actzo CHQDEB,CHQFIN
Endif

End

#_______________________________________________________________________________

Subprog AS_CHQFIN(VALEUR)
Variable Char VALEUR()

If VALEUR="" | val(VALEUR)<val([M:DIA]CHQDEB)
  VALEUR=[M:DIA]CHQDEB
Endif

End

#_______________________________________________________________________________

Subprog C_CHQFIN(VALUER)
Variable Char VALUER()

If VALUER<>"" & val(VALUER)<val([M:DIA]CHQDEB)
 GMESSAGE = mess(44,199,1)
 mkstat = 2
Endif

End

#_______________________________________________________________________________

Subprog C_ALLPAY(VALEUR)
Variable Integer VALEUR

If VALEUR=2
  Effzo PAYDEB,PAYFIN
  Grizo PAYDEB,PAYFIN
Else
  Actzo PAYDEB,PAYFIN
Endif

End

#_______________________________________________________________________________

Subprog C_PAYFIN(VALEUR)
Variable Date VALEUR

If VALEUR<>[0/0/0] & VALEUR<PAYDEB
 GMESSAGE = mess(44,199,1)
 mkstat = 2
Endif

End

#_______________________________________________________________________________

Subprog D_TYPFIL(VALEUR)
Variable Integer VALEUR

Call D_TYPFIL(VALEUR) From SUBFRM

End

#_______________________________________________________________________________

Subprog AS_TYPFIL(VALEUR)
Variable Integer VALEUR

If GBATCH : Grizo [M:DIA]TYPFIL : Endif

End

#_______________________________________________________________________________

Subprog C_TYPFIL(VALEUR)
Variable Integer VALEUR
Local Char NOMFIL(GDIMFIC)

If VALEUR=1 # client
  If GBATCH : GMESSAGE = mess(163,141,1) : mkstat = 2 : End
  Else Raz [M:DIA]VOLFIL : Grizo [M:DIA]VOLFIL : Affzo [M:DIA]VOLFIL
  Endif
Endif

End

#_______________________________________________________________________________

Subprog AM_TYPFIL(VALEUR)
Variable Integer VALEUR

Call AM_TYPFIL(VALEUR) From SUBFRM

End

#_______________________________________________________________________________

Subprog AV_FILDIRLOC(VALEUR)
Variable Char VALEUR()

Call AV_FILDIRLOC(VALEUR) From SUBFRM

End

#_______________________________________________________________________________

$BUILD_POSPAY_CRITERIA
# Sequence number
CRITERIA = '[F:CHN]POSPAYSEQ="' + [M:DIA]POSPAYSEQ + '"'

If [M:DIA]POSPAYSEQ=""
  # Add bank criteria
  CRITERIA = func ADD_BANK_CRITERIA(CRITERIA)

  # Add check criteria
  CRITERIA = func ADD_CHECK_CRITERIA(CRITERIA)

  # Payment date range
  # Issue X3-65076 : Void checks should be included if "payment date range" keyed in
  If PAYDEB<>[0/0/0] or PAYFIN<>[0/0/0] # Issue X3-65076
    CRITERIA -="&(([F:CHN]STA<>3"       # Issue X3-65076
    If PAYDEB<>[0/0/0] & PAYDEB=PAYFIN
      CRITERIA -= '& [F:CHN]PRNDAT=['+format$(GFMD,[M:DIA]PAYDEB)+"]"
    Else
      If PAYDEB<>[0/0/0]
        CRITERIA -= '& [F:CHN]PRNDAT>=['+format$(GFMD,[M:DIA]PAYDEB)+"]"
      Endif
      If PAYFIN<>[0/0/0]
        CRITERIA -= '& [F:CHN]PRNDAT<=['+format$(GFMD,[M:DIA]PAYFIN)+"]"
      Endif
    Endif
    CRITERIA -=")|[F:CHN]STA=3)"  # Issue X3-65076
  Endif                           # Issue X3-65076
Endif

Return

#_______________________________________________________________________________

Funprog ADD_BANK_CRITERIA(CRITERIA)
Value Char CRITERIA
Local Char BANKCRITERIA(50)

# Company criteria
If [M:DIA]CPY=""
  If dim([M:DIA]LEG)>0    # 100380.n
    # All banks for all companies for one legislation
    BANKCRITERIA += '[F:CPY]LEG="' + [M:DIA]LEG + '"'
  Endif                   # 100380.n
Else
  # Bank criteria
  If [M:DIA]BAN=""
    # All banks for one company
    BANKCRITERIA += '[F:BAN]CPY="'+[M:DIA]CPY+'"'
  Else
    # One bank
    BANKCRITERIA += '[F:CHN]BAN="'+[M:DIA]BAN+'"'
  Endif
Endif

If BANKCRITERIA <> ""     # 100380.n
  CRITERIA += string$(CRITERIA<>""," & ") + BANKCRITERIA
Endif                     # 100380.n

End CRITERIA

#_______________________________________________________________________________

Funprog ADD_CHECK_CRITERIA(CRITERIA)
Value Char CRITERIA
Local Char CHECKCRITERIA(100)

# Check range
If [M:DIA]CHQDEB<>"" & [M:DIA]CHQDEB=[M:DIA]CHQFIN
  CHECKCRITERIA += '[F:CHN]CHQNUM="'+[M:DIA]CHQDEB+'"'
  CRITERIA += string$(CRITERIA<>""," & ") + CHECKCRITERIA
Else
  If [M:DIA]CHQDEB<>""
    If instr(1,"0123456789",left$([M:DIA]CHQDEB,1))
      CHECKCRITERIA += 'val([F:CHN]CHQNUM)>=val("'+[M:DIA]CHQDEB+'")'
    Else
      CHECKCRITERIA += '[F:CHN]CHQNUM>="'+[M:DIA]CHQDEB+'"'
    Endif
    CRITERIA += string$(CRITERIA<>""," & ") + CHECKCRITERIA
  Endif
  Raz CHECKCRITERIA
  If [M:DIA]CHQFIN<>""
     If instr(1,"0123456789",left$([M:DIA]CHQFIN,1))
      CHECKCRITERIA += 'val([F:CHN]CHQNUM)<=val("'+[M:DIA]CHQFIN+'")'
    Else
      CHECKCRITERIA += '[F:CHN]CHQNUM<="'+[M:DIA]CHQFIN+'"'
    Endif
    CRITERIA += string$(CRITERIA<>""," & ") + CHECKCRITERIA
  Endif
Endif

End CRITERIA

#_______________________________________________________________________________

#####################################
## Generation of Positive Pay file ##
#####################################

Subprog POSITIVEPAY(STA,MESSA)

# Parameters
Variable Integer STA      : # Status, to be returned
Variable Char    MESSA()  : # Message, to be returned

# Variables for main logic
Local Char    SYMBOLE(40)     : # Symbol used to lock process
Local Char    CRITERIA(250)   : # Filter criteria based on UI selection
Local Char    SEQNUM(14)      : # Positive Pay sequence number
Local Integer STAT            : # Status returned from calls
Local Integer TYP             : # File definition record type: 1=HEADER; 2=LINE; 3=TRAILER
Local Integer DECIM           : # Number of decimal places        (also used in ENREG)
Local Char    BANQUE(GLONBAN) : # Bank code                       (also used in ENREG)  (listed in the implementation help text for the GESTFB function)
Local Integer NUMREC          : # Number of records               (also used in ENREG)  (listed in the implementation help text for the GESTFB function)
Local Integer NUMCHK          : # Number of checks                                      (listed in the implementation help text for the GESTFB function)
Local Decimal AMTCUR          : # Line amount in transaction currency                   (listed in the implementation help text for the GESTFB function)
Local Decimal AMTVIR          : # Line amount in transaction currency with no decimal   (listed in the implementation help text for the GESTFB function)
Local Decimal TOTCUR          : # Total amount in transaction currency                  (listed in the implementation help text for the GESTFB function)
Local Decimal TOTVIR          : # Total amount in transaction currency with no decimal  (listed in the implementation help text for the GESTFB function)
Local Char    LABEL(80)       : # Label for writing to the log

# Variables for bank file
Local Char    DIR_FICBAN(GDIMFIC) : # File directory
Local Char    MACHIN(GDIMFIC)     : # Machine
Local Char    IRS(2)              : # Record separator
Local Char    OS(20)              : # Operating system
Local Integer OK                  : # Status flag
Local Char    EXT(3)              : # Bank file extension
Local Char    FICHIER(GDIMFIC)    : # Positive Pay file name, fully qualified
Local Char    SAVIFS(5)           : # For preserving field separator
Local Char    SAVIRS(5)           : # For preserving record separator
Local Integer SAVIUM              : # For preserving file format
Local Date    DATJ                : # Reference date

# Variables required For FICMAG.ENREG routine that writes records to the Positive Pay file
Local Char    VLEG(GLONADI)   : # Company legislation
Local Char    CODE            : # Bank file definition
Local Char    CODLAN(GLONLAN) : # Langauage from bank country
Local Char    BANCUR(GLONBAN) : # Current bank
Local Char    LEGCUR(GLONADI) : # Current legislation
Local Integer NBLIG           : # Number of detail lines
Local Integer TYPFIC          : # Electronic file type: 1=ETEBAC; 2=EDI; 3=SEPA

# Variables for copying bank file to client
Local Char FICDON(GDIMFIC)  : # File name on server
Local Char URL(GDIMFIC)     : # URL to file on server

# User-friendly variables for use in bank file definitions (GESTFB).
# These variables are listed in the implementation help text for the GESTFB function.
Local Char    ACCNUM(GLONBID) : # Bank ID number  [BAN]BIDNUM
Local Char    CHECK(15)       : # Check number    [CHN]CHQNUM
Local Date    CHKDAT          : # Check date      [CHN]PRNDAT
Local Date    VOIDAT          : # Void date       [CHN]CLODAT
Local Char    PAYNAM(GLONNAM) : # Payee name      [PYH]BPANAM
Local Integer ISVOID          : # Flag to indicate if the check's status is "void"


# Check for in use
SYMBOLE = "POSPAY"
Lock =SYMBOLE
If fstat=1 : STA = 6 : Goto END_POSPAY : Endif


# Process records
For [LNK]CHN0(1) : # Bank

  Raz STA

  ##### Set up and write header
  If GTRACE<>""
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE(mess(12,2230,1)+":"-[F:BAN]BAN-[F:BAN]DES,0) From GESECRAN
  Endif

  # Get bank file definition
  CODE = [F:BAN]POSPAYFIL
  If CODE=""
    STA = 11
    Gosub POSPAY_MESSAGES
    Call ECR_TRACE(MESSA,1) From GESECRAN
    Goto NEXT_BANK
  Endif
  If GTRACE<>"" : Call ECR_TRACE(mess(101,117,1)+":"-[F:BAN]POSPAYFIL,0) From GESECRAN : Endif

  # Check for bank ID number
  If [F:BAN]BIDNUM=""
    STA = 8
    Gosub POSPAY_MESSAGES
    Call ECR_TRACE(MESSA,1) From GESECRAN
    Goto NEXT_BANK
  Endif
  ACCNUM = [F:BAN]BIDNUM

  # Get next Positive Pay sequence number
  If [M:DIA]POSPAYSEQ=""
    Call NUMERO("POSPY","",date$,"",SEQNUM,STAT) From SUBANM
    If STAT
      STA = 1
      Break
      Goto END_POSPAY
    Endif
  Else
    SEQNUM = [M:DIA]POSPAYSEQ
  Endif

  # Set variables for ENREG routine
  BANQUE = [F:BAN]BAN
  CODLAN = ""
  VLEG   = [F:CPY]LEG

  # Get company address
  Read [F:BPA]BPA0 = 2;[F:CPY]CPY;[F:CPY]BPAADD
  If fstat
   Read [F:BPA]BPA0(2) = 2;[F:CPY]CPY
   If fstat : Raz [F:BPA] : Endif
  Endif

  Raz TOTCUR, TOTVIR
  Raz NUMREC, NUMCHK

  Gosub BUILD_FILE_NAME
  If STA
    Gosub POSPAY_MESSAGES
    Call ECR_TRACE(MESSA,1) From GESECRAN
    Goto NEXT_BANK
  Endif

  # If file exists then clear it
  If filinfo(FICHIER,0)>=0
    Call EFFACE(FICHIER,STAT) From ORDSYS
  Endif

  # Open file
  FICDON = FICHIER

  If [M:DIA]TYPFIL=1
    Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
  Endif

  Openo FICDON,0 Using [FIC]
  SAVIFS = adxifs
  SAVIRS = adxirs
  SAVIUM = adxium
  adxifs = ""
  adxirs = ""
  adxium = GASCII
  [L]DATJ = datesyst


  # If there is a header definition record then write the header
  Read [F:TFB]TFB0(3)=CODE;[F:BAN]BAN;1
  If fstat
    Read [F:TFB]TFB0(3)=CODE;"";1
  Endif
  If fstat=0
    NUMREC = 1
    TYP = 1 : Gosub ENREG From FICMAG : # Write header
    RESULT = chr$(13)+chr$(10)
    Wrseq RESULT Using [FIC]
  Endif


  # Begin transaction
  Call DEBTRANS From GLOCK
  Trbegin [CHN1]

  For [LNK]CHN0 : # Check

    # Get payment currency and number of decimal places
    DECIM = 10^[F:TCU]DECNBR

    # Assign user-friendly variables
    CHECK  = [F:CHN]CHQNUM
    CHKDAT = [F:CHN]PRNDAT
    VOIDAT = [F:CHN]CLODAT
    PAYNAM = [F:PYH]BPANAM
    ISVOID = ([F:CHN]STA=3)


    ##### Write line
    AMTCUR = [F:PYH]AMTCUR
    AMTVIR = arr(DECIM*AMTCUR,1)

    TOTCUR += AMTCUR
    TOTVIR += AMTVIR
    NUMCHK += 1

    TYP = 2 : Gosub ENREG From FICMAG : # Write line

    # Add CR LF to end of record and write to file
    RESULT = chr$(13)+chr$(10)
    Wrseq RESULT Using [FIC]


    # Update CHQNUM with Positive Pay data
    Read [F:CHN1]CHN0=[F:CHN]BAN;[F:CHN]CHQNUM
    [F:CHN1]POSPAYSEQ    = SEQNUM
    [F:CHN1]POSPAYCREDAT = [L]DATJ
    Rewrite [F:CHN1]

    If fstat
      GOK = 0
      If fstat=1
          GLOCK = "$CHQNUM"-"1"-[F:CHN1]BAN : Break
      Else
          Call RSTA("CHN","1"-[F:CHN1]BAN) From GLOCK : Break
      Endif
      Break
    Endif

  Next : # [LNK]CHN0 / check

  # If update failed then rollback and go to next bank.
  If GOK=0
    Rollback
    STA = 5
    Gosub POSPAY_MESSAGES
    Call ECR_TRACE(MESSA,1) From GESECRAN
  Else
    Commit

    ##### Write trailer and clean up
    If NUMCHK>0
      NUMREC += 1
      TYP = 3 : Gosub ENREG From FICMAG : # Write trailer
      RESULT = chr$(13)+chr$(10)
      Wrseq RESULT Using [FIC]
    Endif

    If NUMREC>0
      Openo Using [FIC]

      # Copy export file from server to client
      If [M:DIA]TYPFIL=1
        Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
        If STAT=1
          # Fichier non copié sur le poste client | File not copied to the client workstation
          STA = -1 : Call ECR_TRACE(mess(164,141,1),1) From GESECRAN
        Elsif STAT>1
          # Fichier inexistant | Table does not exist
          STA = -1  : Call ECR_TRACE(mess(101,100,1)-"("+num$(STAT)+")",1) From GESECRAN
        Endif
      Endif

      # Write file name to log
      If GTRACE<>""
        Call TEXTE(27481,LABEL) From OBJDIV : # Number of checks
        Call ECR_TRACE(LABEL+":"-num$(NUMCHK),0) From GESECRAN
        If [M:DIA]TYPFIL=1: Call SETNAM(FICHIER,FICDON) From ORDSYS : Endif
        Call ECR_TRACE(mess(104,121,1)+": |"+FICDON+"|",0) From GESECRAN
      Endif

    Endif
  Endif

$NEXT_BANK
Next : # [LNK]CHN0(1) / bank

If NUMCHK=0
  STA = 2
Else
  Raz STA
Endif


$END_POSPAY
Gosub POSPAY_MESSAGES

adxifs   = SAVIFS
adxirs   = SAVIRS
adxium   = SAVIUM

If SYMBOLE<>""
 Unlock =SYMBOLE
Endif

End

#_______________________________________________________________________________

$POSPAY_MESSAGES
MESSA = [F:BAN]BAN

Case STA
  When 1  : MESSA  = "POSPY"-mess(60,199,1)                      : # POSPY Problem in recovering the sequence number
  When 2  : MESSA  = mess(330,107,1)                             : # No checks selected
  When 3  : MESSA -= mess(104,117,1)-"NUMFIL"                    : # Error on Sequence Number NUMFIL
  When 4  : MESSA  = "|"+DIR_FICBAN+"|:"-mess(9,141,1)           : # Directory Non-existent
  When 5  : MESSA  = mess(35,110,1)                              : # Transaction error
  When 6  : MESSA  = mess(10,100,1)                              : # Change In Progress on another workstation
  When 8  : MESSA  = [F:BAN]BAN-mess(27,199,1)                   : # Non-existent Bank Account Number
  When 11 : MESSA -= mess(133,121,1)                             : # No bank file format predefined
  When 15 : MESSA  = func AFNC.MES1(mess(262,117,1), [F:BAN]BAN) : # The "File EXTENSION" code for bank '$1$' must be entered
Endcase

Return

#_______________________________________________________________________________

$BUILD_FILE_NAME
Repeat

  # Get the file path from the screen or get the default path - DIR_FICBAN
  If clalev([M:DIA])>0
   If [M:DIA]VOLFIL<>"" and right$([M:DIA]VOLFIL, len([M:DIA]VOLFIL))<>"/" : [M:DIA]VOLFIL+="/" : Endif
   If [M:DIA]FILDIRLOC<>"" and find(right$([M:DIA]FILDIRLOC, len([M:DIA]FILDIRLOC)), "/", "\")=0
    Call GET_OS(adxmac(-1), OS) From ORDSYS
    If OS="unix"
     [M:DIA]FILDIRLOC += "/"
    Else
     [M:DIA]FILDIRLOC += "\"
    Endif
   Endif
   DIR_FICBAN = [M:DIA]FILDIRLOC
   VOLPATH = [M:DIA]VOLFIL
  Else
   DIR_FICBAN = "["+GDIRBQE+"]/"
   VOLPATH    = "["+GDIRBQE+"]/"
   Gosub ENUM_VOLFIL_TYPE From ASYRSTO
   If func ASYRSTO.CTL_VOLFIL(2,DIR_FICBAN,DIR_FICBAN,E_TYPE_FOLDER,GMESSAGE)>0
    STA = 4
    Gosub POSPAY_MESSAGES
    Call ECR_TRACE(MESSA,1) From GESECRAN
   Endif
  Endif

  # Get file extension from Bank record - EXT
  EXT = [F:BAN]FILEXT
  If EXT=""
   If len([F:BAN]BAN)>3
    STA=15 : Break
   Else
    EXT = [F:BAN]BAN
   Endif
  Endif

  # Complete file name
  FICHIER = DIR_FICBAN
  If [F:TFB]FILEXO<>""
   FICHIER += SEQNUM + EXT + "." + [F:TFB]FILEXO
  Else
   FICHIER += SEQNUM + "." + EXT
  Endif

Until 1

Return

#_______________________________________________________________________________

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPFIL,VALEUR,[M]FILDIRLOC,E_TYPE_FOLDER,GMESSAGE)
End

#_______________________________________________________________________________

