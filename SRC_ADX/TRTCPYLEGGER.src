#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################################
#
#   Legal German data for table COMPANY
#
#   Window AWI      =>  CPYLEGGER
#   Mask/Screen AMK =>  CPYLEGGER [CLGER]
#
#   AUTHORS :    PP/DNE
#   DATE    :    2012-??-??
#   UPDATES :    2012-05-10 DNE - ...
#                2012-0x-xx XXX - YYYYY
#
#########################################################################################

#** #####################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #####################################################################################

$ACTION
    Case ACTION
        When "OUVRE"         : Gosub OUVRE          # Before opening the window?
        When "DEBUT"         : Gosub DEBUT          # Window/Screen initialization?
        When "APRES_MODIF"   : Gosub APRES_MODIF    # ?
        When "AVANT_ENR"     : Gosub AVANT_ENR      # Before SAVE?
        When "ENR"           : Gosub ENR            # After SAVE?
        When "ABA"           : Gosub ABA            # ... CANCEL?
        When "FIN"           : Gosub FIN            # After END pressed but before window disappeared?
    Endcase
Return


#** #####################################################################################
#*
#* Sub chunk:  OUVRE
#*
#* Purpose:    Handler before opening a window.
#*             - Opens some needed tables and the CPYLEGGER mask.
#*             - Creates some local variables/array to save/restore date to/from
#*               CPYLEGGER mask.
#*
#* Parameters (as variables in the main chunk, transfered from action DATALEG):
#*
#* @param PARAM(1)          local char(...)   Legislation code
#* @param PARAM(2)          local char(...)   Country code
#*
#*! #####################################################################################

$OUVRE
    #----- FRA: Paramètres de l'action DATALEG -----#
    #----- ENG: Parameters from action DATALEG -----#
    Local Char LEG(GLONADI)
    Local Char COD(max(GLONCPY,GLONVAT,5))
    [L]LEG = PARAM(1)
    [L]COD = PARAM(2)

    #----- FRA: Tables utilisée -----#
    #----- ENG: Used tables     -----#
    If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
    If !clalev([F:ALK]) : Local File APLLCK [ALK] : Endif

    #----- FRA: Masque local    -----#
    #----- ENG: Local mask used -----#
    Local Mask CPYLEGGER [CLGER]

    #----- FRA: Variables locales pour sauvegarde du masque -----#
    #----- ENG: Local variables (with same name as in table COUNTRY) to save the mask content. -----#
    Local Char 		STAFED(GLONADI)
    Local Char 		GERPTP(20)
    Local Integer	GERDEFVAT(0..8)
    Local Char 		GEREECNUM(20)(0..8)
    Local Char 		GERTAXCEN(GLONBPR)(0..8)
    Local Char 		GERTAXIDT(20)(0..8)
Return


#** #####################################################################################
#*
#* Sub chunk:  DEBUT
#*
#* Purpose:    Handler ...
#*             ...
#*
#*! #####################################################################################

$DEBUT
    Raz [M]NBLIG

    #--- FRA: Alimentation des champs de l'écran ---#
    #--- ENG: Initialize mask fields             ---#
    Read [CPY]CPY0 = [L]COD
    If !fstat
        [M:CLGER] = [F:CPY]
        For I=0 To dim([F:CPY]GERDEFVAL)-1
            If [M]GEREECNUM(I)<>"" | [M]GERTAXCEN(I)<>"" | [M]GERTAXIDT(I)<>""
                [M]NBLIG += 1
            Endif
        Next
    Endif

    #--- FRA: Sauvegarde des valeurs initiales du masque ---#
    #--- ENG: Save the mask fields in the local variables (introduced in $OUVRE). ---#
    [L]=[M:CLGER]
    Affzo [M:CLGER]
    Setmok [M:CLGER] With 0
Return


#** #####################################################################################
#*
#* Sub chunk:  AVANT_ENR
#*
#* Purpose:    Handler ...
#*             ...
#*
#*! #####################################################################################

$AVANT_ENR
    Local Integer VALDEF : VALDEF=0

    For I=0 To [M]NBLIG-1
        If [M]GERDEFVAL(I)=2
            VALDEF=1 : Break
        Endif
    Next
    If !VALDEF
        # FRA: Une case au moins doit être cochée dans ce bloc!
        # ENG: At least one line shold be checked!
        GMESSAGE=mess(359,199,1)
        FOK=0
        GERR=1
    Endif
Return


#** #####################################################################################
#*
#* Sub chunk:  ENR
#*
#* Purpose:    Handler ...
#*             ...
#*
#*! #####################################################################################

$ENR
    Trbegin [CPY]
    Readlock [CPY]CPY0 = [L]COD
    If !fstat
        [F:CPY]=[M:CLGER]
        Rewrite [CPY]
        If fstat
            GOK = 0 : Call FSTA("CPY") From GLOCK : Return
        Endif
    Endif
    Commit
    [L]=[M:CLGER] : REP=""
Return


#** #####################################################################################
#*
#* Sub chunk:  ABA
#*
#* Purpose:    Cancellation handler.
#*             ...
#*
#*! #####################################################################################

$ABA
    [M:CLGER]=[L] : REP=""
    Gosub ENR
    Affzo [M:CLGER]
Return


#** #####################################################################################
#*
#* Sub chunk:  APRES_MODIF
#*
#* Purpose:    After modification handler.
#*             ...
#*
#*! #####################################################################################

$APRES_MODIF
    Read [ALK]LCKCLE="CPY"+[L]COD;0
    If !fstat & [F:ALK]LCKPID<>adxuid(2)
        GMESSAGE=mess(10,100,1)
        GERR=1
        [M:CLGER]=[L]
        Affzo [M:CLGER] :# FIN=1
    Else
        REP = "M"
        Local Char SYMB(20)
        SYMB="CPY"+[L]COD
        Lock SYMB With lockwait=0
    Endif
Return


#** #####################################################################################
#*
#* Sub chunk:  FIN
#*
#* Purpose:    Handler ...
#*             ...
#*
#*! #####################################################################################

$FIN
    # Remove the lock on SYMB (if SYMB exists).
    If dim(SYMB)>0
        Unlock SYMB
    Endif
Return




# ############################################################################################# #
# ##########                                                                                    #
# ########## Screen/Window handling                                                             #
# ##########                                                                                    #
# ##########                                                                                    #
# ##########                                                                                    #
# ############################################################################################# #

#** #####################################################################################
#*
#* Procedure:  C_NBLIG
#*
#* Purpose:    Handler ...
#*             ...
#*
#*! #####################################################################################

Subprog C_NBLIG
    If status=65  # Line cancellation.
        If [M]GEREECNUM(nolign-1)=[F:CPY]EECNUM
            #EECNUM de la fiche société : Suppression impossible
            #mess(00034,00127,1) : No de TVA intracommunautaire
            #mess(00005,00117,1) : de la société
            GMESSAGE=mess(54,123,1)+"\"+"("+mess(34,127,1)-mess(5,117,1)+")"
            mkstat=2
        Endif
    Endif
End


#** #####################################################################################
#*
#* Procedure:  AS_GERDEFVAL
#*
#* Purpose:    Handler ...
#*             ...
#*
#* Parameters:
#* @param VALEUR    Integer       ...
#*
#*! #####################################################################################

Subprog AS_GERDEFVAL(VALEUR)
Variable Integer VALEUR

    If [M]GEREECNUM(nolign-1)=""
        mkstat=1
        zonsui=[M]GEREECNUM(nolign-1)
    Endif
End


#** #####################################################################################
#*
#* Procedure:  AM_GERDEFVAL
#*
#* Purpose:    Handler ...
#*             ...
#*
#* Parameters:
#* @param VALEUR    Integer       ...
#*
#*! #####################################################################################

Subprog AM_GERDEFVAL(VALEUR)
Variable Integer VALEUR

    If VALEUR=2
        For I=0 To [M]NBLIG-1
            If I<>(nolign-1)
                [M]GERDEFVAL(I)=1 # NO/NON
            Endif
        Next
        [M]GERDEFVAL(nolign-1)=2  # YES/OUI
        Affzo[M]
    Endif
End


#** #####################################################################################
#*
#* Procedure:  C_GEREECNUM
#*
#* Purpose:    Handler ...
#*             ...
#*
#* Parameters:
#* @param VALEUR    Value Char ()   ...
#*
#*! #####################################################################################

Subprog C_GEREECNUM(VALEUR)
Variable Char VALEUR()

    If VALEUR=""
        #mess(10,123,1) : Zone obligatoire
        GMESSAGE=mess(10,123,1)
        mkstat=2
    Else
        Call UNICITE(VALEUR,[M]GEREECNUM) From OBJDIV
    Endif
End
