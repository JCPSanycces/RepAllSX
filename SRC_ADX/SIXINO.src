#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#  SIXINO : pour traitements de bascule Integrale --> X3                 #
#########################################################################
#                                                                       #
# Subprog EXEC                                                          #
#     Création des familles statistiques article, client, fournisseur   #
#########################################################################

Gosub SI_CONTEXT From SIXFONCTION
Local File SIPARX3  [SPX]
Local File SIPARVAC [SPV]
Read [SPX] First

SI_SIMU=2
Call EXEC From SIXITM

End

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE

If GTRACE = ""
    Call OUVRE_TRACE("SIXINO : "+SI_MES(1)) From LECFIC
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#---- Création enregistrement ITMMASTER ------#
Call TEXTE(2148,GBIDC1) From OBJDIV
Call ECR_TIME("SIXINO : "+GBIDC1) From DOSSUB
Call SIXINO

If GOK<>1 : Goto FIN_INO : Endif


$FIN_INO
Onerrgo
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


$TRT_ERR
    Call ECR_TRACE( errp-"ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GOK=0
Resume


#########################################################################
# Création des familles statistiques articles
#########################################################################
Subprog SIXINO

Local Integer LRET, STOP, COMPTEUR
Local Char LCRIT(250)

If !clalev([F:INO]) : Local File =SI_DOSSIER+".ITMCUSNOM"  [INO] : Endif

If !clalev([F:XNPC]): Local File =SI_DOSSIER+".XINMCPTCEE" [XNPC]: Endif

SI_SUBPRG = "SIXINO"

SI_TABLE = "XINMCPTCEE"
Gosub SI_CRITSUP From SIXFONCTION

$LOOP_XNPC
Trbegin [XNPC]
If STOP=1
    LCRIT="NMCPDT>LNMCPDT"
    STOP = 0
Else
    LCRIT="1=1"
Endif

For [XNPC] Where FLGREP<>2
&              & evalue(SI_CRITERE)
&              & evalue(LCRIT)

    Call AFFBOITE([XNPC]NMCPDT) From SUBSIM

    Raz [F:INO]
    [F:INO]ITMNOM    = [F:XNPC]NMCPDT
    [F:INO]ITMCUSDES = [F:XNPC]DGN
    Call MAJTEXTRA([F:INO]ITMCUSDES,"ITMCUSNOM","DESAXX",[F:INO]ITMNOM,"") From ATEXTRA
    [F:INO]ITMCUSSHO = [F:INO]ITMCUSDES
    [F:INO]CREDAT = date$
    [F:INO]CREUSR = GUSER
    Write [INO]
    If SI_SIMU<>2
        [F:XNPC]FLGREP=2
        Rewrite [XNPC]
    Endif
    COMPTEUR+=1
    If COMPTEUR>GMAXUPDTRS/2
        Raz COMPTEUR
        LNMCPDT = [F:XNPC]NMCPDT
        STOP = 1
        Break
    Endif
Next
If SI_SIMU=2
    Rollback
Else
    Commit
Endif
If STOP
    Goto LOOP_XNPC
Endif

End
