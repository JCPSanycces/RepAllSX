#<AdxTL>@(#)0.0.0.0 $Revision$Class Process launch
# Supervisor
## CRUD-CLASSE ## EDIRUN
# 2018-10-17 07:54:24 923


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(EDIRUN,ASTATUS)
Variable Instance EDIRUN Using C_EDIRUN
Variable Integer ASTATUS

If EDIRUN = null : End : Endif

Gosub _AVARIABLES From WMC00EDIRUN

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_EDIRUN

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(EDIRUN,ASTATUS)
Variable Instance EDIRUN Using C_EDIRUN
Variable Integer ASTATUS

If EDIRUN = null : End : Endif

Gosub AVARIABLES From WMC00EDIRUN
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
EDIRUN.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_EDIRUN
Else
 Gosub AUPDATE_EDIRUN
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = EDIRUN.freeSnapshot
EDIRUN.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EDIRUN._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EDIRUN._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EDIRUN._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If EDIRUN.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDIRUN.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(EDIRUN.ASTALIN)<>""
 [L]A_ASTALIN = EDIRUN.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
For A_N2=1 To maxtab(EDIRUN.EDRD) : # EDIRUND -- 2
 If EDIRUN.EDRD(A_N2) <> null
& and EDIRUN.EDRD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIRUN.EDRD(A_N2).ASTALIN<>[V]CST_ANEW & EDIRUN.ASTALIN=[V]CST_ADEL
   EDIRUN.EDRD(A_N2).ASTALIN = [V]CST_ADEL
  Endif
  If EDIRUN.EDRD(A_N2).ASTALIN=[V]CST_ANEW & find(EDIRUN.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
   EDIRUN.EDRD(A_N2).ASTALIN = [V]CST_ANEWDEL
  Endif
  If [V]CST_ASTALIN(EDIRUN.EDRD(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIRUN.EDRD(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER
For A_N2=1 To maxtab(EDIRUN.EDRD) : # EDIRUND -- 2
 If EDIRUN.EDRD(A_N2) <> null
& and EDIRUN.EDRD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If [V]CST_ASTALIN(EDIRUN.EDRD(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIRUN.EDRD(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

If [V]CST_ASTALIN(EDIRUN.ASTALIN)<>""
 [L]A_ASTALIN = EDIRUN.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_EDIRUN
Trbegin [F:EDR]
 Gosub AUPDATE_EDIRUN
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_EDIRUN
[L]A_ASTALIN = EDIRUN.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EDIRUN._MAJSQL_EDIRUN(EDIRUN))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [L]A_TYPMAJ=[V]CST_ADEL,[V]CST_AUPD,[V]CST_ANEW
 #-----------------------#
 For A_N2=1 To maxtab(EDIRUN.EDRD)
  If EDIRUN.EDRD(A_N2) <> null and
& (EDIRUN.EDRD(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDIRUN.EDRD(A_N2).ASTALIN=[V]CST_ALL)
   If EDIRUN.EDRD(A_N2).ASTALIN=[L]A_TYPMAJ
    If [V]CST_ASTALIN(EDIRUN.EDRD(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDIRUN.EDRD(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
    [L]ASTATUS = func WMC00EDIRUN._MAJSQL_EDIRUND(EDIRUN.EDRD(A_N2))
    If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    If [V]CST_ASTALIN(EDIRUN.EDRD(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDIRUN.EDRD(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
   Endif
  Endif
  If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
 Next A_N2
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 #-----------------------#
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]A_ASTALIN = EDIRUN.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If EDIRUN.snapshotEnabled=1
 [L]A_RETIK = EDIRUN.revertUpdTick
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIRUN.EDRD)
 If EDIRUN.EDRD(A_N2) <> null
  If EDIRUN.EDRD(A_N2).ASTALIN=[V]CST_ANEWDEL
   EDIRUN.EDRD(A_N2).ASTALIN = [V]CST_ANEW
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2

[L]ASTATUS = max(fmet EDIRUN.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(EDIRUN.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EDIRUN.ASTALIN = [V]CST_ALL
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIRUN.EDRD)
 If EDIRUN.EDRD(A_N2) <> null
  If EDIRUN.EDRD(A_N2).ASTALIN=[V]CST_ADEL or EDIRUN.EDRD(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIRUN.EDRD(A_N2)
   EDIRUN.EDRD(A_N2) = null
  Elsif EDIRUN.EDRD(A_N2).ASTALIN <> [V]CST_ALL
   EDIRUN.EDRD(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Return



