#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# SUBPDQ2 : Affichage de la situation d'une ligne cde       MBT 18/12/98 #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p           #
# d'affichage "SITUATION_LIG_CDE" et ne sert qu'à gérer le masque        #
# écran "PDSYPOQ [PDQ2]".                                                #
##########################################################################
# Issue 110982 - 2016-03-22 by SR :
$ACTION
Case ACTION
  When "AB1_NBRCP"   : Gosub LOAD_GCONSULT
  When "BB1_NBRCP"   : Gosub REST_GCONSULT
  When "AB1_NBSHD"   : Gosub LOAD_GCONSULT
  When "BB1_NBSHD"   : Gosub REST_GCONSULT
  When "AB1_NBFAC"   : Gosub LOAD_GCONSULT
  When "BB1_NBFAC"   : Gosub REST_GCONSULT
Endcase
Return

$LOAD_GCONSULT
Local Integer SAVGCONSULT
SAVGCONSULT = GCONSULT
GCONSULT = 1
Return

$REST_GCONSULT
GCONSULT = SAVGCONSULT
Return
# End issue 110982
Subprog IB_NBRCP
#--------------------------------------------#
# Avant zone : Activation bouton "Réception" #
#--------------------------------------------#
Raz GBOUT1
If [M:PDQ2]PTHNUM(nolign-1)<>"" & GFONC1<>"GESPTH"
  GBOUT1=mess(117,198,1)-[M:PDQ2]PTHNUM(nolign-1)
Endif
End

Subprog IB_NBFAC
#------------------------------------------#
# Avant zone : Activation bouton "Facture" #
#------------------------------------------#
Raz GBOUT1
If [M:PDQ2]NUM(nolign-1)<>"" & GFONC1<>"GESPIH"
  GBOUT1=mess(55,198,1)-[M:PDQ2]NUM(nolign-1)
Endif
End


# Issue 106506 - 2015-05-07 by SR : Landed Cost
Subprog IB_NBSHD
Raz GBOUT1
If [M:PDQ2]SHIPNUM(nolign-1)<>"" & GFONC1<>"GESSHH"
  GBOUT1=mess(500,198,1)-[M:PDQ2]SHIPNUM(nolign-1)
Endif
End



######################################################################################

