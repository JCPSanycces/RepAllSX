#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UUMGTRTCPT03                                      Module  Accounting   #
#                    Migration Process                                   #
#                                                                        #
#      Flow for Commitments                                              #
#                  GCOMMIT/GCOMMITD                                      #
#                                                                        #
##########################################################################
#                                                                        #
#  Optimized Index for Migration                                         #
#                                                                        #
#   GCOMMIT : CPY;NUM                                                    #
#   GCOMMITD : CPY;NUM;LINNUM                                            #
#                                                                        #
#  Index to keep for Migration                                           #
#                                                                        #
#   GCOMMIT : NUM                                                        #
#   GCOMMITD : NUM;LINNUM                                                #
#                                                                        #
#                                                                        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTCPT03") From LECFIC
  Endif

  #Call RAZ_UUMGTRTCPT03(DOSSIER)
  Call MAJ_UUMGTRTCPT03(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

########################################################################
Subprog RAZ_UUMGTRTCPT03(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(1)<>2 : End : Endif

#----- File naming...  -----#
Local Char WNAMCMMM,WNAMCMDM
Call MIGTABNAME (DOSSIER,"GCOMMIT",WNAMCMMM,ERR) From TRTMIG  : If ERR : End : Endif
Call MIGTABNAME (DOSSIER,"GCOMMITD",WNAMCMDM,ERR) From TRTMIG : If ERR : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMCMMM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL",WNAMCMDM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif

#----- Deleting of records...  -----#
Call MIGTABRAZ (DOSSIER,"GCOMMIT",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"GCOMMITD",ERR) From TRTMIG
Call MIGRAZKEY (DOSSIER,"UUMGTRTCPT03",ERR) From TRTMIG

End

########################################################################
Subprog MAJ_UUMGTRTCPT03(DOSSIER)
Value Char DOSSIER
Local Integer ERR

If [F:ADS]MODULE(1)<>2
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT03",3,ERR) From TRTMIG : End
Endif

#----- File naming...  -----#
Local Char WNAMCMMM,WNAMCMDM
Call MIGTABNAME (DOSSIER,"GCOMMIT",WNAMCMMM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT03",7,ERR) From TRTMIG : End : Endif
Call MIGTABNAME (DOSSIER,"GCOMMITD",WNAMCMDM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT03",7,ERR) From TRTMIG : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMCMMM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT03",3,ERR) From TRTMIG : End
Endif
If filinfo(filpath("FIL",WNAMCMDM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT03",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT03",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT03",7,ERR) From TRTMIG : End : Endif


Call ECR_TIME("UUMGTRTCPT03 Commitments Process : Updates GCOMMIT/GCOMMITD") From DOSSUB
Call ECR_TRACE("UUMGTRTCPT03 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Files Updating where we will insert -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"GCOMMIT",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"GCOMMITD",ERR) From TRTMIG

#--------------- Opening of files  -----#
# X3 Files
If clalev([F:CMM]) = 0 : Local File =DOSSIER+".GCOMMIT"    [CMM]  : Endif
If clalev([F:CMD]) = 0 : Local File =DOSSIER+".GCOMMITD"   [CMD]  : Endif

# X3 Renamed File
If clalev([F:CMMM]) = 0 : Local File =DOSSIER+"."+WNAMCMMM  [CMMM] : Endif
If clalev([F:CMDM]) = 0 : Local File =DOSSIER+"."+WNAMCMDM  [CMDM] : Endif

# X3 Commun File
Gosub OPEN_FILE From UUMGTRTCPT00

#-----  Declaration of Variables
Gosub DECLARE From UUMGTRTCPT00

# Variables to manage Flush instruction
Local Char WTAB_CMM(30)(adxwrb), WTAB_CMD(30)(adxwrb)
Local Shortint WCPT_CMM,WCPT_CMD

Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

#-----  Keys's reading  -----#
# Table's AMIGKEY reading to initialize ACLEx/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTCPT03",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

#-----  Link of Head Table & Line Table
#-----  We don't have the line number in the key !
Link [CMDM] With [CMMM]CMM0~=[F:CMDM]NUM
&   As [LNK]
&   Order By Key CLE = [F:CMMM]CPY;[F:CMMM]NUM

# EP to add a criteria in the "where"
FLUX="UUMGTRTCPT03" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CPT03
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = '[F:CMMM]CPY="'+TABMIGKEY(1)+'" & [F:CMMM]NUM>"'+TABMIGKEY(2)+'"'
Elsif STOP=2
 STOP = 0
 CRITERE = '[F:CMMM]CPY>"'+TABMIGKEY(1)+'"'
Else
 CRITERE = '1=1'
Endif

Trbegin [CMM],[CMD]
GOK = 1

For [LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

 # By company - Initialization of Variables linked to the Account Core Model
 [L]COMPANY = [F:CMMM]CPY
 Gosub INI_CPY From UUMGTRTCPT00
 If !GOK : Break : Endif

 For [LNK]CLE(2)

  NBLUS+=1

  # EP to delete line
  If FILTRELIN
   FLUX="UUMGTRTCPT03" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
   If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  # To Update GCOMMIT table - Header of Commitments
  Gosub MAJ30_CMM
  If GOK<1 : Break 2 : Endif

  For [LNK]CLE
   # To Update GCOMMITD table - Lines of Commitments
   Gosub MAJ30_CMD
   If !GOK : Break 3 : Endif
  Next

  NB+=1
  If NB>GMAXUPDTRS
   TABMIGKEY(1) = [F:CMMM]CPY
   TABMIGKEY(2) = [F:CMMM]NUM
   STOP=1
   Break 2
  Endif

 $SUITE_BOUCLE
 Next
Next

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT03",7,ERR) From TRTMIG
Else
 Flush [F:CMM]
 If fstat
  Call ECR_TRACE("File GCOMMIT, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub CMM_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:CMD]
 If fstat
  Call ECR_TRACE("File GCOMMITD, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub CMD_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 # To Save values of key ACLEx/STOP in AMIGKEY table
 If STOP
  TABMIGKEY(3)=num$(STOP)
 Else
  Raz TABMIGKEY
 Endif
 Call MIGSTKKEY (DOSSIER,"UUMGTRTCPT03",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
 If ERR
  GOK=-1 : Goto FIN_BOUCLE
 Endif
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTCPT03",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_CPT03
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [CMM], [CMD]
Close Local File [CMMM], [CMDM]

#----- To Re-Update files where we will insert
Call MIGTABEND (DOSSIER,"GCOMMIT",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"GCOMMITD",ERR) From TRTMIG

$FIN
Call MIGTRTEND (DOSSIER,"UUMGTRTCPT03") From TRTMIG
Call ECR_TIME("UUMGTRTCPT03 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

$MAJ30_CMM
#--- Transclass
Raz [CMM]
[CMM] = [CMMM]

# Si [L]TYPANA=0 - Erreur sous UUMGTRTCPT00
# Raz [F:CMM]LED,RATMLT,RATDIV  #???

[F:CMM]LED([L]TYPANA-1)    = [L]LEDANA
[F:CMM]CURLED([L]TYPANA-1) = [F:GCM]CUR([L]TYPANA-1)
[F:CMM]RATMLT([L]TYPANA-1) = [F:CMMM]RATCUR
[F:CMM]RATDIV([L]TYPANA-1) = 1

# Renamed field
[F:CMM]REFINT = [F:CMMM]REFORD

# Différence sens V5(+1,-1)->V6(1,2)
If [F:CMMM]SNS<>1
 [F:CMM]SNS = 2
Endif

Gosub WRI_CMM
Return

$MAJ30_CMD
#--- Transclass
Raz [CMD]
[CMD] = [CMDM]

# Renamed field
[F:CMD]LIN = [F:CMDM]LINNUM

# News fields  (UOM, not init => UPOS)
[F:CMD]FIY = [F:CMMM]FIY
[F:CMD]PER = [F:CMMM]PER

[F:CMD]BPRACC = [F:CMMM]BPR

[F:CMD]CUR = [F:CMMM]CUR
[F:CMD]CURLED([L]TYPANA-1) = [F:GCM]CUR([L]TYPANA-1)

# Record on Chart of Account of Analytical Ledger
[F:CMD]LED([L]TYPANA-1)    = [L]LEDANA
[F:CMD]LEDTYP([L]TYPANA-1) = [L]TYPANA
[F:CMD]COA([L]TYPANA-1)    = [L]COAANA
[F:CMD]ACC([L]TYPANA-1)    = [F:CMDM]CNA

#For AXE=1 To min([L]NBRAXE,dim([F:CMD]DIE))
# [F:CMD]DIE(AXE-1) = [L]AXEA(AXE)
# [F:CMD]CCE(AXE-1) = evalue("[F:CMDM]CCE"+num$(AXE))
#Next

For AXE=1 To min([L]NBRAXE,dim([F:CMD]DIE))
 [F:CMD]DIE(AXE-1) = [L]AXEA(AXE)
 Case AXE
  When 1 : [F:CMD]CCE(AXE-1) =[F:CMDM]CCE1
  When 2 : [F:CMD]CCE(AXE-1) =[F:CMDM]CCE2
  When 3 : [F:CMD]CCE(AXE-1) =[F:CMDM]CCE3
  When 4 : [F:CMD]CCE(AXE-1) =[F:CMDM]CCE4
  When 5 : [F:CMD]CCE(AXE-1) =[F:CMDM]CCE5
  When 6 : [F:CMD]CCE(AXE-1) =[F:CMDM]CCE6
  When 7 : [F:CMD]CCE(AXE-1) =[F:CMDM]CCE7
  When 8 : [F:CMD]CCE(AXE-1) =[F:CMDM]CCE8
  When 9 : [F:CMD]CCE(AXE-1) =[F:CMDM]CCE9
  When Default
 Endcase
Next

[F:CMD]AMTLED([L]TYPANA-1) = [F:CMDM]AMTLOC

Gosub WRI_CMD
Return


# Write Instruction
$WRI_CMM
# To Save reference
Gosub CMM_STK
WriteB [F:CMM]
If fstat
 Call ECR_TRACE("File GCOMMIT, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub CMM_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_CMD
# To Save reference
Gosub CMD_STK
WriteB [F:CMD]
If fstat
 Call ECR_TRACE("File GCOMMITD, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub CMD_ERRTRA
 GOK=0 : Return
Endif
Return

################################################
$CMM_STK
Call STK (WTAB_CMM,WCPT_CMM,[F:CMM]NUM) From TRTMIG
Return
$CMD_STK
Call STK (WTAB_CMD,WCPT_CMD,[F:CMD]NUM-'/'-num$([F:CMD]LIN)) From TRTMIG
Return

#################################################
$CMM_ERRTRA
Call ERRTRA (WTAB_CMM,WCPT_CMM,"File GCOMMIT(NUM)=") From TRTMIG
Return
$CMD_ERRTRA
Call ERRTRA (WTAB_CMD,WCPT_CMD,"File GCOMMITD(NUM/LINNUM)=") From TRTMIG
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTCPT03(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGTRTCPT03(APPLI)
End
########################################################################

