#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################################################# 
#                   DECLARATIONS ECHANGES DE BIENS                                          #
#   A partir des RETOURS ACHAT                                                              #
#-------------------------------------------------------------------------------------------#  
#                                                                  cg octobre 98            #
############################################################################################# 
 
$ACTION
Case ACTION
        When "EXPORT" : Gosub EXPORT
        When Default
Endcase
Return


$EXPORT
#-------------------------------------------------#
# GIMP (1) --->     departement  de destination effective à l intro  #
# GIMP (2) --->     Numéro TVA client             # 
# GIMP (3) --->     Pays origine                  #
# GIMP (4) --->     Pays provenance               #
# GIMP (5) --->     Nature transactionA           #
# GIMP (6) --->     Nature transactionB           #
# GIMP (7) --->     Valeur fiscale en dev recp    #
# GIMP (8) --->     Valeur stat  dev recp         #
#-------------------------------------------------#

If [F:PND]QTYPUU = 0   : OK = 0 : Return : Endif

#----------------------------#
# voir si on active la ligne #
#----------------------------#
#If [F:PND]LINEECFLG = 2  : OK = 0 : Return : Endif

#------------------------------------------------#
# si ok = 0 pas d'enreg dans le fichier d'export #
#------------------------------------------------#
If clalev ([F:BPR]) = 0 : Local File BPARTNER   [BPR] : Endif
If clalev ([F:BPS]) = 0 : Local File BPSUPPLIER [BPS] : Endif
If clalev ([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:BPA]) = 0 : Local File BPADDRESS  [BPA] : Endif

If clalev ([F:PNH]) = 0 : Local File PRETURN    [PNH] : Endif
If clalev ([F:TCY]) = 0 : Local File TABCOUNTRY [TCY] : Endif
If clalev ([F:PIH]) = 0 : Local File PINVOICE   [PIH] : Endif
If clalev ([F:PID]) = 0 : Local File PINVOICED  [PID] : Endif


Local Integer STAT
Local Decimal WMONTANT, WQUANTITY



Read [PNH]PNH0 = [F:PND]PNHNUM
If fstat  : Raz  [F:PNH] : Endif

#--- il faut que le retour soit validé
If [F:PNH]CFMFLG <> 2 : OK = 0 : Return : Endif


#------------------#
# lecture du tiers #
#------------------#
Read [BPR]BPR0 = [F:PNH]BPSNUM
If fstat  : Raz  [F:BPR] : Endif

GIMP(2) = [F:BPR]EECNUM

#-------------------------#
# lecture du fournisseur  #
#-------------------------#
Read [BPS]BPS0 = [F:PNH]BPSNUM
If fstat  : Raz  [F:BPS] : Endif


#---------------------------------------------#
# lecture de l adresse du site fournisseur    #
# recuperation  du departement                #
#---------------------------------------------#
If [F:PNH]POSCOD = ""    
    Read [BPA]BPA0= 1;[F:PNH]BPSNUM ;[F:PNH]BPAADD 
    If fstat : Raz [F:BPA]  : Endif
    GIMP(1) = left$([F:BPA]POSCOD,2)
Else
    GIMP(1) = left$([F:PNH]POSCOD,2)
Endif    

#--------------------------------------------#
# lecture table des pays recup code EEC pays #
#--------------------------------------------#
Read [TCY]TCY0 = [F:PND]ORICRY
If fstat  : Raz  [F:TCY] : Endif
GIMP (3) = [F:TCY]EECCOD

Read [TCY]TCY0 = [F:BPR]CRY
If fstat  : Raz  [F:TCY] : Endif
#----------------------------------------------------------------#
# si pays non CEE ou même pays que pays pays d'origine pas de DEB#
# si ok = 0 pas d'enreg dans le fichier d'export                 #
#----------------------------------------------------------------#
If [F:TCY]EECFLG <> 2  | [F:TCY]EECCOD = GIMP(3) : OK = 0 : Return : Endif

GIMP (4) = [F:TCY]EECCOD

GIMP (5) = mid$([F:PNH]EECNAT,2,1)
GIMP (6) = right$([F:PNH]EECNAT,3)

#-------------------------------------------------------------#
# lecture des factures sur la ligne pour recupérer le montant #
# attention la qté retour n est pas forcement facturée        #
# entierement                                                 #
#-------------------------------------------------------------#

Filter [PID] Where TYPORI = 3 and NUMORI = [F:PND]PNHNUM and LINORI = [F:PND]PNDLIN 
&            and SEQORI = 0   Order By Key PID1
WMONTANT = 0
WQUANTITY = [F:PND]QTYPUU
For [PID] 
    Read [PIH]PIH0 = [F:PID]NUM
    If fstat = 0
        GBIDD2     = [F:PID]AMTNOTLIN
        WQUANTITY -= [F:PID]QTYPUU
        #--- conversion du montant facture dans la devise du fournisseur
        If [F:PIH]CUR <> [F:BPR]CUR
            Call CONVERT2([F:PIH]CUR,[F:BPR]CUR,GCUR,[F:BPS]CHGTYP,GHIDATE,GBIDD2,GBIDD2,STAT) From TRTDEV
            Call ARRDEV (GBIDD2,[F:BPR]CUR) From TRTDIV
        Endif
        WMONTANT += GBIDD2
    Endif
Next
Filter [PID]

If WQUANTITY > 0
        #------------------------------------------#
        # ajout du restant dans le prix NETPRIPUU  #
        #------------------------------------------#
        GBIDD2 = WQUANTITY * [F:PND]NETPRIPUU
        #--- conversion du montant dans la devise du fournisseur 
        If [F:BPR]CUR <> [F:PND]NETCUR
            Call CONVERT2([F:PND]NETCUR,[F:BPR]CUR,GCUR,[F:BPS]CHGTYP,GHIDATE,GBIDD2,GBIDD2,STAT) From TRTDEV
            Call ARRDEV (GBIDD2,[F:BPR]CUR) From TRTDIV
        Endif
        WMONTANT += GBIDD2
Endif

GIMP (7) = num$(WMONTANT)
If [F:PND]EECINCRAT <> 0
        GIMP (8) = num$(WMONTANT *(1+[F:PND]EECINCRAT/100))
Else    GIMP (8) = num$(WMONTANT)
Endif


GBIDC1 = [F:PND]PNHNUM
GBIDI2 = [F:PND]PNDLIN

Update [PND] Where PNHNUM = GBIDC1 and PNDLIN = GBIDI2 With LINEECFLG = 2

Return
