#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# UTIVEN80    Utilitaire de migration des transactions de saisie       Module VENTE  #
#             module ventes                                                          #
#              Initialisation des nouveaux champs suite                              #
#                au développement de l'exigence 105605                               #
#              Init. nouveau champs ECCCOD, ECCSCR, ECCCODMIN, ECCSCRMIN de SALTRS   #
# X3SUIVI105605                                                                      #
######################################################################################
  Call MAJ_UTIVEN80
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTIVEN80
Local Char DOSSIER(30)

  DOSSIER=nomap
  Call SAIDOS(DOSSIER,"UTIVEN80 - New sales transactions fields initialisation") From SAIDOS
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIVEN80 : New sales transactions fields initialisation") From LECFIC
    Call EXE_UTIVEN80(DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#-------------------------------------------------------------------------------#
Subprog EXE_UTIVEN80(DOSSIER)
Value Char    DOSSIER

  Call ECR_TIME("UTIVEN80 : Start folder's process"-DOSSIER) From DOSSUB
  #----- Chargement globale GMAXUPDTRS -----#
  If dim([V]GMAXUPDTRS) < 1 Then
    Global Integer GMAXUPDTRS
  Endif
  Local File =DOSSIER+".ADOVAL" [ADW]
  Read [ADW] ADW0="";"";"MAXUPDTRS"
  If fstat Then
    Raz [F:ADW]
  Endif
  If val([F:ADW]VALEUR) > 0 Then
    GMAXUPDTRS = val([F:ADW]VALEUR)
  Else
    GMAXUPDTRS = 1000
  Endif
  Close Local File [ADW]
  #----- Début mise à jour SALTRS -----#
  Gosub TRT_SLT
  #----- Fin mise à jour SALTRS   -----#
$FIN_UTIVEN80
  Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
  Call ECR_TIME("UTIVEN80 : End folder's process"-DOSSIER) From DOSSUB
End

#-------------------------------------------------------------------------------#
#   Initialisation des nouveaux champs dans les transactions vente              #
# ----------------------------------------------------------------------------- #
# Table SALTRS - Transactions vente                                             #
#-------------------------------------------------------------------------------#
$TRT_SLT
Local Shortint INDIC

  If filinfo(filpath("FIL","SALTRS","fde",DOSSIER),0) <= 0 Then
    Return
  Endif
  #-------------------------------------------------------------------------------#
  # Initialisation transactions ventes pour les nouvelles zones                   #
  #-------------------------------------------------------------------------------#
  Call ECR_TIME("UTIVEN80 Sales Transactions Process : Update SALTRS") From DOSSUB
  Local File =DOSSIER+".SALTRS"    [SLT]
  #
  Call ECR_TIME("UTIVEN80 Sales Transactions Process : --- Step 1 ") From DOSSUB
  Gosub TXNSQH
  #
  Call ECR_TIME("UTIVEN80 Sales Transactions Process : --- Step 2 ") From DOSSUB
  Gosub TXNSOH
  #
  Call ECR_TIME("UTIVEN80 Sales Transactions Process : --- Step 3 ") From DOSSUB
  Gosub TXNSOR
  #
  Call ECR_TIME("UTIVEN80 Sales Transactions Process : --- Step 4 ") From DOSSUB
  Gosub TXNSDH
  #
  Call ECR_TIME("UTIVEN80 Sales Transactions Process : --- Step 5 ") From DOSSUB
  Gosub TXNSIH
  #
  Close Local File [SLT]
Return

#-------------------------------------------------------------------------------#
# Transaction pour les devis                                                    #
#-------------------------------------------------------------------------------#
$TXNSQH
  Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP = 1
    Raz INDIC
    If dim([F:SLT]ECCCOD) > 0 Then
      If !find([F:SLT]ECCCOD,1,2,3) Then
        # Version majeure (invisible)
        INDIC = 1
        [F:SLT]ECCCOD = 3
        [F:SLT]ECCSCR = 1
      Endif
    Endif
    If dim([F:SLT]ECCCODMIN) > 0 Then
      If !find([F:SLT]ECCCODMIN,1,2,3) Then
        # Version mineure (invisible)
        INDIC = 1
        [F:SLT]ECCCODMIN = 3
        [F:SLT]ECCSCRMIN = 1
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [SLT]
      If fstat Then
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
  Commit
Return

