##############################################################
## Comparaison des valeurs
##############################################################
$VALEUR
Local File =[M]DOSORG+".VALEUR" [VLA1]
Local File =[M]DOSORG+".VARIA"  [VRA1]
Local File =[M]DOSDES+".VALEUR" [VLA2]
Local File =[M]DOSDES+".VARIA"  [VRA2]
Call ECR_TRACE(SEP,0) From GESECRAN
Call ECR_TRACE(mess(165,10703,1),0) From GESECRAN : # Comparaison des valeurs dossier
Call ECR_TRACE(SEP,0) From GESECRAN
ABR1  = "VLA1"
ABR2  = "VLA2"
TABLE = "VALEUR"
TYPOBJ = "VLA" : Gosub LECTAB
DIFF  = 0
TEXTE = ""
Filter [VRA1] Where FLGFDR=2 & LEG=GCURLEG
Filter [VRA2] Where FLGFDR=2 & LEG=GCURLEG
NMAX = rowcount([VRA1])+rowcount([VRA2])/2
Filter [VRA1]
Filter [VRA2]
OPCENT = 0
N = 0
For [VRA1]VRA0 Where FLGFDR=2 & LEG = GCURLEG
 N += 1
 PCENT = fix(100*N/NMAX)
 If PCENT<>OPCENT
  OPCENT = PCENT
  [M]CVLA = PCENT
  Affzo CVLA : Envzo
 Endif
 FLD = 0
#JASMI - 2016-10-20 - X3PEOP-740 - START
# TEXTET = [F:VRA1]COD-[F:VRA1]DES
 Call LECTEXTRA(THIS_DES,"VARIA","DES",GCURLEG,[F:VRA1]COD) From ATEXTRA
 TEXTET = [F:VRA1]COD-THIS_DES
#JASMI - 2016-10-20 - X3PEOP-740 - END
 Filter [VLA1] Where TYP=1 & LEG=GCURLEG & CPY="" & FCY="" & EMP="" & VARCOD=[F:VRA1]COD
& Order By Key CLE = TYP;CPY;FCY;EMP;VARCOD;DAT
 Read [VLA1]CLE Last
 If fstat<=2
  Filter [VLA2] Where TYP=1 & LEG=GCURLEG & CPY="" & FCY="" & EMP="" & VARCOD=[F:VRA1]COD
&  Order By Key CLE = TYP;CPY;FCY;EMP;VARCOD;DAT
  Read [VLA2]CLE Last
  If fstat<=2
   If [F:VLA1]DAT<>[F:VLA2]DAT or [F:VLA1]VARVAL<>[F:VLA2]VARVAL
    VALEUR1 = format$("D:"+GFMDAT4,[F:VLA1]DAT)-":"-num$([F:VLA1]VARVAL)
    VALEUR2 = format$("D:"+GFMDAT4,[F:VLA2]DAT)-":"-num$([F:VLA2]VARVAL)
    Gosub DIFFERENCE
   Endif
  Else
   VALEUR1 = format$("D:"+GFMDAT4,[F:VLA1]DAT)-":"-num$([F:VLA1]VARVAL)
   VALEUR2 = mess(166,10703,1) : # Valeur non définie
   Gosub DIFFERENCE
  Endif
 Endif
Next
For [VRA2]VRA0 Where FLGFDR=2 & LEG=GCURLEG
 N += 0.5
 PCENT = fix(100*N/NMAX)
 If PCENT<>OPCENT
  OPCENT = PCENT
  [M]CVLA = PCENT
  Affzo CVLA : Envzo
 Endif
 FLD = 0
#JASMI - 2016-10-20 - X3PEOP-740 - START
# TEXTET = [F:VRA2]COD-[F:VRA2]DES
 Call LECTEXTRA(THIS_DES,"VARIA","DES",GCURLEG,[F:VRA2]COD) From ATEXTRA
 TEXTET = [F:VRA2]COD-THIS_DES
#JASMI - 2016-10-20 - X3PEOP-740 - END
 Filter [VLA2] Where TYP=1 & LEG=GCURLEG & CPY="" & FCY="" & EMP="" & VARCOD=[F:VRA2]COD
& Order By Key CLE = TYP;CPY;FCY;EMP;VARCOD;DAT
 Read [VLA2]CLE Last
 If fstat<=2
  Filter [VLA1] Where TYP=1 & LEG=GCURLEG & CPY="" & FCY="" & EMP="" & VARCOD=[F:VRA2]COD
&  Order By Key CLE = TYP;CPY;FCY;EMP;VARCOD;DAT
  Read [VLA1]CLE Last
  If fstat>2
   VALEUR1 = mess(166,10703,1) : # Valeur non définie
   VALEUR2 = format$("D:"+GFMDAT4,[F:VLA2]DAT)-":"-num$([F:VLA2]VARVAL)
   Gosub DIFFERENCE
  Endif
 Endif
Next
[M]CVLA = 100 : Affzo CVLA : Envzo
Close Local File [VLA1] , [VRA1]
Close Local File [VLA2] , [VRA2]
Gosub FINCOMP
Return

##############################################################
## Comparaison des paramètres
##############################################################
$PARAM
Local File =[M]DOSORG+".ADOPAR" [ADP1]
Local File =[M]DOSORG+".ADOVAL" [ADW1]
Local File =[M]DOSDES+".ADOPAR" [ADP2]
Local File =[M]DOSDES+".ADOVAL" [ADW2]
Call ECR_TRACE(SEP,0) From GESECRAN
Call ECR_TRACE(mess(167,10703,1),0) From GESECRAN : # Comparaison des paramètres
Call ECR_TRACE(SEP,0) From GESECRAN
ABR1  = "ADP1"
ABR2  = "ADP2"
TABLE = "ADOPAR"
TYPOBJ = "ADP" : Gosub LECTAB
DIFF  = 0
TEXTE = ""
Filter [ADP1] Where CHAPITRE="PLA"
Filter [ADP2] Where CHAPITRE="PLA"
NMAX = rowcount([ADP1])+rowcount([ADP2])/2
Filter [ADP1]
Filter [ADP2]
OPCENT = 0
N = 0
For [ADP1]ADP0 Where CHAPITRE="PLA"
 N += 1
 PCENT = fix(100*N/NMAX)
 If PCENT<>OPCENT
  OPCENT = PCENT
  [M]CADP = PCENT
  Affzo CADP : Envzo
 Endif
 FLD = 0
 Call TEXTE([F:ADP1]NAM,TEXTET) From OBJDIV
 TEXTET = [F:ADP1]PARAM-TEXTET
 Read [ADW1]ADW0 = "";"";[F:ADP1]PARAM
 If !fstat
  Read [ADW2]ADW0 = "";"";[F:ADP1]PARAM
  If !fstat & [F:ADW1]VALEUR<>[F:ADW2]VALEUR
   VALEUR1 = [F:ADW1]VALEUR
   VALEUR2 = [F:ADW2]VALEUR
   Gosub DIFFERENCE
  Else
   VALEUR1 = [F:ADW1]VALEUR
   VALEUR2 = mess(166,10703,1) : # Valeur non définie
   Gosub DIFFERENCE
  Endif
 Endif
Next
For [ADP2]ADP0 Where CHAPITRE="PLA"
 N += 0.5
 PCENT = fix(100*N/NMAX)
 If PCENT<>OPCENT
  OPCENT = PCENT
  [M]CADP = PCENT
  Affzo CADP : Envzo
 Endif
 FLD = 0
 Call TEXTE([F:ADP2]NAM,TEXTET) From OBJDIV
 TEXTET = [F:ADP2]PARAM-TEXTET
 Read [ADW2]ADW0 = "";"";[F:ADP2]PARAM
 If !fstat
  Read [ADW1]ADW0 = "";"";[F:ADP2]PARAM
  If fstat
   VALEUR1 = mess(166,10703,1) : # Valeur non définie
   VALEUR2 = [F:ADW2]VALEUR
   Gosub DIFFERENCE
  Endif
 Endif
Next
[M]CADP = 100 : Affzo CADP : Envzo
Close Local File [ADP1] , [ADW1]
Close Local File [ADP2] , [ADW2]
Gosub FINCOMP
Return

##############################################################
## Comparaison des charges
##############################################################
$CHARGES
Local File =[M]DOSORG+".DECCHARGE" [DCH1]
Local File =[M]DOSDES+".DECCHARGE" [DCH2]
Call ECR_TRACE(SEP,0) From GESECRAN
Call ECR_TRACE(mess(168,10703,1),0) From GESECRAN : # Comparaison des charges
Call ECR_TRACE(SEP,0) From GESECRAN
ABR1  = "DCH1"
ABR2  = "DCH2"
TABLE = "DECCHARGE"
TYPOBJ = "DCH" : Gosub LECTAB
DIFF = 0
NMAX = nbrecord([DCH1])+nbrecord([DCH2])/2
OPCENT = 0
N = 0
For [DCH1]DCH0
 N += 1
 PCENT = fix(100*N/NMAX)
 If PCENT<>OPCENT
  OPCENT = PCENT
  [M]CDCH = PCENT
  Affzo CDCH : Envzo
 Endif
 FLD = 0
 Call LECTEXTRA([L]VTITLE,"DECCHARGE","DESDCC",[F:DCH1]LEG,[F:DCH1]CODDCC) From ATEXTRA
 TEXTET = [F:DCH1]CODDCC-[L]VTITLE
 Read [DCH2]DCH0 = [F:DCH1]CODDCC
 If fstat
  TEXTE   = ""
  VALEUR1 = "OK"
  VALEUR2 = mess(169,10703,1) : # Déclaration de charge inexistante
  Gosub DIFFERENCE
 Else
  Gosub COMPTAB
 Endif
Next
For [DCH2]DCH0
 N += 0.5
 PCENT = fix(100*N/NMAX)
 If PCENT<>OPCENT
  OPCENT = PCENT
  [M]CDCH = PCENT
  Affzo CDCH : Envzo
 Endif
 FLD = 0
 Call LECTEXTRA([L]VTITLE,"DECCHARGE","DESDCC",[F:DCH2]LEG,[F:DCH2]CODDCC) From ATEXTRA
 TEXTET = [F:DCH2]CODDCC-[L]VTITLE
 Read [DCH1]DCH0 = [F:DCH2]CODDCC
 If fstat
  TEXTE   = ""
  VALEUR1 = mess(169,10703,1) : # Déclaration de charge inexistante
  VALEUR2 = "OK"
  Gosub DIFFERENCE
 Endif
Next
[M]CDCH = 100 : Affzo CDCH : Envzo
Close Local File [DCH1]
Close Local File [DCH2]
Gosub FINCOMP
Return

##############################################################
## Sous-prog
##############################################################
$LECTAB
NBZ = 0
For [ATZ]CODZONE Where CODFIC=TABLE
 NBZ += 1
 ZONE(NBZ) = [F:ATZ]CODZONE
 Call TEXTE([F:ATZ]NOCOURT,LIBZ(NBZ)) From OBJDIV
Next
NBC = 0
NBC += 1 : NOCOMP(NBC) = "CREUSR"
NBC += 1 : NOCOMP(NBC) = "CREDAT"
NBC += 1 : NOCOMP(NBC) = "CRETIM"
NBC += 1 : NOCOMP(NBC) = "UPDUSR"
NBC += 1 : NOCOMP(NBC) = "UPDDAT"
NBC += 1 : NOCOMP(NBC) = "UPDTIM"
NBC += 1 : NOCOMP(NBC) = "EXPNUM"
NBC += 1 : NOCOMP(NBC) = "AUUID"
NBC += 1 : NOCOMP(NBC) = "CREDATTIM"
NBC += 1 : NOCOMP(NBC) = "UPDDATTIM"
Case TABLE
 When "CUMUL"
  NBC += 1 : NOCOMP(NBC) = "CUMROW"
 When "EXOPAY"
  NBC += 1 : NOCOMP(NBC) = "NUMLIG"
Endcase
If [M:DIA]PAR<>2
 Gosub CHAMP_SPE From PATCHS
 For I=1 To NBSPE
  If !find(CHPSPE(I),NOCOMP(1..NBC))
   NBC += 1
   NOCOMP(NBC) = CHPSPE(I)
  Endif
 Next I
Endif
Return

$COMPTAB
For I=1 To evalue("clanbs([F:"+ABR1+"],1)")
 VARIA = evalue("clavar([F:"+ABR1+"],"+num$(I)+")")
 If !find(VARIA,NOCOMP(1..NBC))
  TYP   = evalue("type([F:"+ABR1+"]"+VARIA+")")
  # DBA le 14/09/05 : Gestion d'un changement de type entre deux versions...
  TYP2  = evalue("type([F:"+ABR2+"]"+VARIA+")")
  #
  DIM1  = evalue("dim([F:"+ABR1+"]"+VARIA+")")
  DIM2  = evalue("dim([F:"+ABR2+"]"+VARIA+")")
  DIME  = min(DIM1,DIM2)
  For J=0 To DIME-1
   Case TYP
    When 1,2,4,5,6,7,8,9
     VALEUR1 = num$(evalue("[F:"+ABR1+"]"+VARIA+"("+num$(J)+")"))
    When 3
     VALEUR1 = format$("D:"+GFMDAT4,evalue("[F:"+ABR1+"]"+VARIA+"("+num$(J)+")"))
    When Default
     VALEUR1 = evalue("[F:"+ABR1+"]"+VARIA+"("+num$(J)+")")
   Endcase
   Case TYP2
    When 1,2,4,5,6,7,8,9
     VALEUR2 = num$(evalue("[F:"+ABR2+"]"+VARIA+"("+num$(J)+")"))
    When 3
     VALEUR2 = format$("D:"+GFMDAT4,evalue("[F:"+ABR2+"]"+VARIA+"("+num$(J)+")"))
    When Default
     VALEUR2 = evalue("[F:"+ABR2+"]"+VARIA+"("+num$(J)+")")
   Endcase
   If VALEUR1<>VALEUR2
    TEXTE = VARIA
    If DIME>1 : TEXTE += "("+num$(J)+")" : Endif
    K = find(VARIA,ZONE(1..NBZ))
    If K
     TEXTE -= LIBZ(K)
    Endif
    Gosub DIFFERENCE
   Endif
  Next J
 Endif
Next I
Return

$DIFFERENCE
If FLD=0
 Call ECR_TRACE(PFIX3-TEXTET,0) From GESECRAN
 FLD = 1
Endif
If TEXTE<>""
 Call ECR_TRACE(PFIX0-TEXTE ,0) From GESECRAN
Endif
Call ECR_TRACE(PFIX1-VALEUR1,0) From GESECRAN
Call ECR_TRACE(PFIX2-VALEUR2,0) From GESECRAN
DIFF += 1
Return

$FINCOMP
Call ECR_TRACE(SEP,0) From GESECRAN
If DIFF
 Call ECR_TRACE(num$(DIFF)-mess(170,10703,1),0) From GESECRAN : # différence(s)
Else
 Call ECR_TRACE(mess(171,10703,1),0) From GESECRAN : # Pas de différence
Endif
Call ECR_TRACE(SEP,0) From GESECRAN
Return

######################################################################################
## Ecran CMPPLAN
######################################################################################
Subprog C_DOSORG(VALEUR)
Variable Char    VALEUR()
If filinfo(filpath("FIL","RUBRIQUE","fde",VALEUR),0)<0
 GMESSAGE = VALEUR-":"-mess(172,10703,1) : # Pas de paye sur ce dossier
 mkstat = 2 : End
Endif
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]DOSORG
 mkstat = 2 : End
Endif
If filinfo(filpath("FIL","RUBRIQUE","fde",VALEUR),0)<0
 GMESSAGE = VALEUR-":"-mess(172,10703,1) : # Pas de paye sur ce dossier
 mkstat = 2 : End
Endif
End

