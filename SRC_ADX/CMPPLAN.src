#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################
## Comparaison de plans de paie
###################################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CMPPLAN","CMPPLAN",3,"") From GTRAITE
End
###################################################################

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "INIT_DIA" : Gosub INIT_DIA
 When "EXEC"     : Gosub EXEC
Endcase
Return

$INIT
#TMP = 1
Return

$INIT_DIA
Raz [M:DIA]
[M:DIA]DOSORG = nomap
Return

################################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$EXEC
Local Char    SEP(80) , PFIX0(10) , PFIX1(10) , PFIX2(10) , PFIX3(10)
Local Integer I , J , K
Local Integer DIM1 , DIM2 , DIME , TYP , TYP2,  DIFF , STA1 , STA2 , FLD
Local Char    VALEUR1(250) , VALEUR2(250) , TEXTE(250) , TEXTET(250) , VARIA(GLONADC)
Local Integer NBZ , NBC
Local Char    ZONE(GLONADC)(1..250) , LIBZ(80)(1..250) , NOCOMP(GLONADC)(1..50)
Local Char    TABLE(GLONATB) , ABR1(5) , ABR2(5) , TYPOBJ(5)
Local Integer NBPRF
Local Char    PROFIL(GLONPRF)(1..100) , LIBPRF(GLONDES)(1..100)
Local Decimal N , NMAX , PCENT , OPCENT
Local Char VTITLE(GLONAX3)
PFIX0 = "***"
PFIX1 = "   >>"
PFIX2 = "   <<"
PFIX3 = "==="
SEP   = string$(80,"#")
If clalev([F:ATZ])=0 : Local File ATABZON  [ATZ] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If !GSERVEUR
 Call OUVRE_TRACE(mess(157,10703,1)) From LECFIC : # Comparaison plans de paie
Endif
Call ECR_TRACE(SEP,0) From GESECRAN
Call ECR_TRACE(mess(157,10703,1),0) From GESECRAN : # Comparaison plans de paie
Read [ADS]DOSSIER = [M]DOSORG
Call ECR_TRACE(PFIX1-[M]DOSORG-[F:ADS]NOMDOS,0) From GESECRAN
Read [ADS]DOSSIER = [M]DOSDES
Call ECR_TRACE(PFIX2-[M]DOSDES-[F:ADS]NOMDOS,0) From GESECRAN
Call ECR_TRACE(SEP,0) From GESECRAN
Gosub OUVRE_BOITE From WGCMPPLAN
Affzo [DIA]

#Multilegislation changes
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG=[M]LEG

If [M]RUB=2 : Gosub RUBRIQUE : Endif
If [M]VRA=2 : Gosub VARIA    : Endif
If [M]CUM=2 : Gosub CUMUL    : Endif
If [M]EXO=2 : Gosub EXO      : Endif
If [M]VLA=2 : Gosub VALEUR   : Endif
If [M]ADP=2 : Gosub PARAM    : Endif
If [M]DCH=2 : Gosub CHARGES  : Endif
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Gosub FERME_BOITE From WGCMPPLAN
TRA = 1
Return

##############################################################
## Comparaison des rubriques
##############################################################
$RUBRIQUE
Local File =[M]DOSORG+".RUBRIQUE" [RUB1]
Local File =[M]DOSORG+".CALRUB"   [CRB1]
Local File =[M]DOSORG+".PROFIL"   [PRF1]
Local File =[M]DOSDES+".RUBRIQUE" [RUB2]
Local File =[M]DOSDES+".CALRUB"   [CRB2]
Local File =[M]DOSDES+".PROFIL"   [PRF2]
Call ECR_TRACE(SEP,0) From GESECRAN
Call ECR_TRACE(mess(158,10703,1),0) From GESECRAN : # Comparaison des rubriques
Call ECR_TRACE(SEP,0) From GESECRAN
ABR1  = "RUB1"
ABR2  = "RUB2"
TABLE = "RUBRIQUE"
TYPOBJ = "RUB" : Gosub LECTAB
NBPRF = 0
For [PRF1]PRF0 Where LEG=GCURLEG
 Read [PRF2]PRF0 = [F:PRF1]LEG;[F:PRF1]PRFCOD
 If !fstat
  NBPRF += 1
  PROFIL(NBPRF) = [F:PRF1]PRFCOD
  Call LECTEXTRA(LIBPRF(NBPRF),"PROFIL","PRFDES",[F:PRF1]LEG,[F:PRF1]PRFCOD) From ATEXTRA
 Endif
Next
DIFF   = 0
NMAX   = nbrecord([RUB1])+nbrecord([RUB2])/2
OPCENT = 0
N      = 0
For [RUB1]RUB1 Where LEG=GCURLEG
 N += 1
 PCENT = fix(100*N/NMAX)
 If PCENT<>OPCENT
  OPCENT = PCENT
  [M]CRUB = PCENT
  Affzo CRUB : Envzo
 Endif
 FLD = 0
 Call LECTEXTRA([L]VTITLE,"RUBRIQUE","DES",[F:RUB1]LEG,[F:RUB1]COD) From ATEXTRA
 TEXTET = [F:RUB1]COD-"("+num$([F:RUB1]ROW)+")"-[L]VTITLE
 Read [RUB2]RUB0 = [F:RUB1]LEG;[F:RUB1]COD
 If fstat
  TEXTE   = ""
  VALEUR1 = "OK"
  VALEUR2 = mess(11,10702,1) : # Rubrique inexistante
  Gosub DIFFERENCE
 Else
  Gosub COMPTAB
  For I=1 To NBPRF
   Read [CRB1]CRB0 = [F:RUB1]COD;PROFIL(I);GCURLEG
   STA1 = fstat
   Read [CRB2]CRB0 = [F:RUB2]COD;PROFIL(I);GCURLEG
   STA2 = fstat
   TEXTE = "Profil"-PROFIL(I)-LIBPRF(I)
   If STA1=0 & STA2<>0
    VALEUR1 = mess(159,10703,1) : # Calculée pour le profil
    VALEUR2 = mess(160,10703,1) : # Non calculée pour le profil
    Gosub DIFFERENCE
   Elsif STA1<>0 & STA2=0
    VALEUR1 = mess(160,10703,1) : # Non calculée pour le profil
    VALEUR2 = mess(159,10703,1) : # Calculée pour le profil
    Gosub DIFFERENCE
   Endif
  Next I
 Endif
Next
For [RUB2]RUB1 Where LEG=GCURLEG
 N += 0.5
 PCENT = fix(100*N/NMAX)
 If PCENT<>OPCENT
  OPCENT = PCENT
  [M]CRUB = PCENT
  Affzo CRUB
 Endif
 FLD = 0
 Call LECTEXTRA([L]VTITLE,"RUBRIQUE","DES",[F:RUB2]LEG,[F:RUB2]COD) From ATEXTRA
 TEXTET = [F:RUB2]COD-"("+num$([F:RUB2]ROW)+")"-[L]VTITLE
 Read [RUB1]RUB0 = [F:RUB2]LEG;[F:RUB2]COD
 If fstat
  TEXTE   = ""
  VALEUR1 = mess(11,10702,1) : # Rubrique inexistante
  VALEUR2 = "OK"
  Gosub DIFFERENCE
 Endif
Next
[M]CRUB = 100 : Affzo CRUB : Envzo
Close Local File [RUB1] , [CRB1] , [PRF1]
Close Local File [RUB2] , [CRB2] , [PRF2]
Gosub FINCOMP
Return

##############################################################
## Comparaison des variables
##############################################################
$VARIA
Local File =[M]DOSORG+".VARIA" [VRA1]
Local File =[M]DOSDES+".VARIA" [VRA2]
Call ECR_TRACE(SEP,0) From GESECRAN
Call ECR_TRACE(mess(161,10703,1),0) From GESECRAN : # Comparaison des variables
Call ECR_TRACE(SEP,0) From GESECRAN
ABR1  = "VRA1"
ABR2  = "VRA2"
TABLE = "VARIA"
TYPOBJ = "VRA" : Gosub LECTAB
DIFF   = 0
NMAX   = nbrecord([VRA1])+nbrecord([VRA2])/2
OPCENT = 0
N      = 0
For [VRA1]VRA0 Where LEG=GCURLEG
 N += 1
 PCENT = fix(100*N/NMAX)
 If PCENT<>OPCENT
  OPCENT = PCENT
  [M]CVRA = PCENT
  Affzo CVRA : Envzo
 Endif
 FLD = 0
#JASMI - 2016-10-20 - X3PEOP-740 - START
# TEXTET = [F:VRA1]COD-[F:VRA1]DES
Local Char THIS_DES
 Call LECTEXTRA(THIS_DES,"VARIA","DES",GCURLEG,[F:VRA1]COD) From ATEXTRA
 TEXTET = [F:VRA1]COD-THIS_DES
#JASMI - 2016-10-20 - X3PEOP-740 - END
 Read [VRA2]VRA0 = GCURLEG;[F:VRA1]COD
 If fstat
  TEXTE   = ""
  VALEUR1 = "OK"
  VALEUR2 = mess(13,10702,1) : # Variable inexistante
  Gosub DIFFERENCE
 Else
  Gosub COMPTAB
 Endif
Next
For [VRA2]VRA0 Where LEG = GCURLEG
 N += 0.5
 PCENT = fix(100*N/NMAX)
 If PCENT<>OPCENT
  OPCENT = PCENT
  [M]CVRA = PCENT
  Affzo CVRA : Envzo
 Endif
 FLD = 0
#JASMI - 2016-10-20 - X3PEOP-740 - START
# TEXTET = [F:VRA2]COD-[F:VRA2]DES
 Call LECTEXTRA(THIS_DES,"VARIA","DES",GCURLEG,[F:VRA2]COD) From ATEXTRA
 TEXTET = [F:VRA2]COD-THIS_DES
#JASMI - 2016-10-20 - X3PEOP-740 - END
 Read [VRA1]VRA0 = GCURLEG;[F:VRA2]COD
 If fstat
  TEXTE   = ""
  VALEUR1 = mess(13,10702,1) : # Variable inexistante
  VALEUR2 = "OK"
  Gosub DIFFERENCE
 Endif
Next
[M]CVRA = 100 : Affzo CVRA : Envzo
Close Local File [VRA1]
Close Local File [VRA2]
Gosub FINCOMP
Return

