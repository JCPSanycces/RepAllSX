#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("CLS",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case GACTION
 When "SELCLA"
  Case ACTION
   When "SEL_TABLE" : Gosub SEL_TABLE
  Endcase
 When Default
  Case ACTION
   When "OUVRE"     : Gosub OUVRE
   When "VERIF_MOD" : Gosub VERIF_MOD
   When "CREATION"  : Gosub CREATION
   When "MODIF"     : Gosub MODIF
   When "LIENS"     : Gosub LIENS
   When "AP_CHANGE" : Gosub AP_CHANGE
   When "ANNULE"    : Gosub ANNULE
   When "INICRE"    : Gosub INICRE
   When "INIMOD"    : Gosub INIMOD
   When "FILTRE"    : Gosub FILTRE
  Endcase
Endcase
Return

$OUVRE
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:COA])=0 : Local File GCOA     [COA] : Endif
Return

$FILTRE
Return

$INICRE
$INIMOD
If dim([F:CLS]CLSNAM)>0
 [F:CLS]CLSNAM = [M:CLS1]DESTRA(nolign-1)
Endif
Return

$VERIF_MOD
Local Integer NBANU
Local Char    TBANU(GLONCLA)(1..dim([M]CLSCOD)),BIDDES(50)
For [CLS] Where LEG=CLECUR1
 If !find([F:CLS]CLSCOD,[M]CLSCOD(0..[M]NBCAT-1))
  NBANU += 1
  TBANU(NBANU) = [F:CLS]CLSCOD
 Endif
Next
If NBANU
 Call TEMPON("O") From GESECRAN
 Link [GAC] With [COA]COA0=[F:GAC]COA As [LGAC]
 For [LGAC] Where [F:COA]LEGCLS=CLECUR1
  I = find([F:GAC]CLSCOD,TBANU(1..NBANU))
  If I
   Call LECTEXTRA(BIDDES,"GACCCLS","DESTRA",[F:COA]LEGCLS,TBANU(I)) From ATEXTRA
   GMESSAGE = TBANU(I)-BIDDES+"\"+mess(54,123,1)-"("+[F:GAC]COA-[F:GAC]ACC+")"
   OK = 0 : Break
  Endif
 Next
 Call TEMPOFF From GESECRAN
Endif
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$AP_CHANGE
Call CHGTEXTRA("GACCCLS","DESTRA",[M:CLS1]LEG,[M:CLS1]CLSCOD(nolign-1),[M:CLS1]LEG,NCODE) From ATEXTRA
Return


$LIENS
Call LECTEXTRA([M:CLS1]DESTRA(nolign-1),"GACCCLS","DESTRA",[M:CLS1]LEG,[M:CLS1]CLSCOD(nolign-1)) From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("GACCCLS","DESTRA",[M:CLS1]LEG,[M:CLS1]CLSCOD(nolign-1)) From ATEXTRA
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GACCCLS","DESTRA",CLECUR1,CLECUR2,"GACCCLS","DESTRA",[M:CLS1]LEG,[M:CLS1]CLSCOD(nolign-1))  From ATEXTRA
Endif
Call MAJTEXTRA([M:CLS1]DESTRA(nolign-1),"GACCCLS","DESTRA",[M:CLS1]LEG,[M:CLS1]CLSCOD(nolign-1)) From ATEXTRA
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran CLS1) 23/07/2008 12:28:35 (BY)
######################################################################################
Subprog C_CLSCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]CLSCOD) From OBJDIV
End


Subprog AS_ERA(VALEUR)
Variable Integer VALEUR
If [M]TYP(nolign-1) = 2
 VALEUR = 1
 mkstat = 2 : End
Endif
End

######################################################################################
## Actions SELCLA et CONTCLA
######################################################################################
$SEL_TABLE
Local File GACCCLS [CLS] , ATEXTRA [AXX]
Link [CLS] With [AXX]AXX0="GACCCLS";"DESTRA";GLANGUE;[F:CLS]LEG;[F:CLS]CLSCOD As [LCLS]
Default File [LCLS]
CRITERE = 'LEG="'+PARAM(1)+'"'
NBCOL = 2
COL(1) = "[CLS]CLSCOD"
COL(2) = "[AXX]TEXTE"
TIT    = mess(193,105,1): # Classification
TIT(1) = mess(5,159,1)  : # Numéro
TIT(2) = mess(30,109,1) : # Intitulé
Return

##################################################
Subprog CONTCLA(VALEUR,LEG,DESIG)
Variable Char    VALEUR()
Value    Char    LEG
Variable Char    DESIG()
Local Char BIDDES(50)
If clalev([F:CLS])=0 : Local File GACCCLS [CLS] : Endif
Read [CLS]CLS0 = LEG;VALEUR
If fstat
 # Classe de comptes inexistante
 GMESSAGE = mess(199,105,1)
 mkstat = 2 : End
Else
 Call LECTEXTRA(BIDDES,"GACCCLS","DESTRA",[F:CLS]LEG,VALEUR) From ATEXTRA
 DESIG = BIDDES
Endif
End


##################################################
Subprog TUNCLS(AZC,LEG)
Variable Char    AZC()
Value    Char    LEG
Call OBJET_CHAR(LEG,"CLS",AZC) From GOBJET
End


