#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################
# FUNUTICMM : Resynchronisation engagements fournisseurs    MBT 03/05/02 #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais une fonction                     #
#  - Resynchronisation des pré-engagements par ligne de demande d'achat  #
#  - Resynchronisation des engagements par ligne de commande d'achat     #
# ---------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                 #
#   - TRTUTICMM : Fonction de resynchronisation des engagements          #
##########################################################################

$ACTION
#------------------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)               #
# TRTUTICMM  : Fonction de resynchronisation des engagements #
#------------------------------------------------------------#
Case ACTION
 When "OUVRE_BATCH" : Gosub INIT
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Affzo [DIA]1-99 : Gosub GRISAGE
 When "SETBOUT"     : If GHISTO
                        Diszo [DIA]1-99
                        Call VIREBOUT(CHBOU,"O")   From GOBJET
                        Call VIREBOUT(CHMEN,"MRE") From GOBJET
                      Endif
 When "BOUTON"      : Gosub BOUTON
 When "OK"          : GOK=1
 When "END"         : GOK=0
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return


#################################################
# Initialisations avant exécution du traitement #
#################################################
$INIT
If GSERVEUR
  Onerrgo ERRBATCH : # En batch, il vaut mieux mettre onerrgo
Endif
Gosub OUVRE        : # Ouverture fichiers et déclaration variables locales
Local Mask PUTICMM [DIA]
Raz [M:DIA]
[M:DIA]XFCYFLG=2
[M:DIA]XCMMPRP=2
[M:DIA]XCMM   =2
[M:DIA]XGENTYP=1
[M:DIA]TRACE  =2
Call LECMEMO("STD","[M:DIA]","pm7") From GMEMO
TIT=mess(445,197,1) : # Titre de la boite de dialogue et message de temporisation
TMP=1               : # Affichage d'un message de temporisation
Return


###############################
# Après exécution d'un bouton #
###############################
$BOUTON
Case BOUT
  When "R" : Gosub GRISAGE
Endcase
Return


##########################################
# Contrôle avant exécution du traitement #
##########################################
$CONTROLE
If GOK<1  FIN=1 : Endif
Return


###########################
# Exécution du traitement #
###########################
$EXEC
If !GSERVEUR
  #----- Ouverture fichier trace et écriture des sélections -----#
  If [M:DIA]TRACE=2
    Call OUVRE_TRACE(mess(445,197,1))   From LECFIC
    Call ECR_TRACE(" ",0)               From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0)   From GESECRAN
    Call PRTSCR("PUTICMM","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0)   From GESECRAN
    Call ECR_TRACE(" ",0)               From GESECRAN
  Endif
Endif
If [M:DIA]TRACE=2 & [M:DIA]XGENTYP=2
  Call ECR_TRACE("******"-mess(2,555,1)-"******",0) From GESECRAN
Endif
If [M:DIA]XCMMPRP=2  Gosub TRT_PSH : Endif : # Traitement DA (Pré-engagements)
If [M:DIA]XCMM=2     Gosub TRT_POH : Endif : # Traitement commandes (Engagements)
If [M:DIA]TRACE=2 & [M:DIA]XGENTYP=2
  Call ECR_TRACE(" ",0)                        From GESECRAN
  Call ECR_TRACE("******"-mess(2,555,1)-"******",0) From GESECRAN
Endif
Return


#---------------------------------#
# Traitement des demandes d'achat #
#---------------------------------#
$TRT_PSH
If [M:DIA]TRACE=2
  Call ECR_TRACE(" ",0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(mess(446,197,1),0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif
#----- Ouverture des fichiers -----#
If clalev([F:PSH]) =0  Local File PREQUIS    [PSH] : Endif
If clalev([F:PSD]) =0  Local File PREQUISD   [PSD] : Endif
If clalev([F:CAL]) =0  Local File CPTANALIN  [CAL] : Endif
If clalev([F:TB0]) >0  Close Local File [TB0]      : Endif
If clalev([F:TB0]) =0  Local File PREQUISD   [TB0] : Endif
If clalev([F:TB2]) =0  Local File CPTANALIN  [TB2] : Endif
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz NBENR, NBCOR, GSOCIETE
#-----
CRITERE="CMMPRPNUM<>''"
If [M:DIA]XFCYFLG<>2  CRITERE+=" & PSHFCY=[M:DIA]FCY" : Endif
If [M:DIA]XCPYFLG<>2  CRITERE+=" & CPY=[M:DIA]CPY"    : Endif

For [PSD] PSD0 Where evalue(CRITERE)
  NBENR+=1
  # Issue 79938 - 2012-02-24 by SR : si changement de site récupération du site financier
  If GSOCIETE<>[F:PSD]CPY | GCURFCY <> [F:PSD]PSHFCY
    # Issue 95891 - 2014-01-24 by SR
    WSOCIETE = GSOCIETE
    # Issue 93478 - 2013-10-14 by MUARN : demande d'achat non signée, création pré engagement à la création DA
    If GCURFCY <> [F:PSD]PSHFCY
      Call PARAM([F:PSD]PSHFCY,"PSHCMMLEV",PARAM2) From ADOVAL
      GPSHCMMLEV = val(PARAM2)
    Endif
    Call GETDEV([F:PSD]PSHFCY) From DEVSUB : If GFINRSP="" GFINRSP=[F:PSD]PSHFCY : Endif
    # Issue 95891 - 2014-01-24 by SR
    #If GSOCIETE<>[F:PSD]CPY
    If WSOCIETE <> GSOCIETE
      Call LECLED(GSOCIETE,GTYPGEN,WLEDGEN,WDEVLED) From CPTDIV
      Call LECLED(GSOCIETE,GTYPANA,WLEDANA,WDEVLED) From CPTDIV
      #----- Liste des types de référentiel de la société -----#
      Raz TBTYPLED, WI : Call LSTLEDTYP(GSOCIETE,0,TBTYPLED,WI) From CPTDIV
    Endif
  Endif
  If [F:TCU]CUR<>[F:PSD]CUR
    Read [TCU] TCU0=[F:PSD]CUR
    If fstat  Raz [F:TCU] : [F:TCU]CURRND=2 : Endif
  Endif
  WDECCUR=[F:TCU]CURRND
  If [F:PSD]LINCLEFLG=2 | ([F:PSD]LINAPPFLG<2 & GPSHCMMLEV<>3) # Issue 93478 - 2013-10-14 by MUARN : GPSHCMMLEV pris en compte
    Raz WQTEPUU, WQTESTU, WMONTANT
  Else
    WQTEPUU=[F:PSD]QTYPUU-[F:PSD]ORDQTYPUU : If WQTEPUU<0 Raz WQTEPUU : Endif
    WQTESTU=[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU : If WQTESTU<0 Raz WQTESTU : Endif
    #----- Pré-engagement HT + taxes non déductibles -----#
    If [F:PSD]CMMPRPTAX=2
      WMONTANT=[F:PSD]LINAMT
      # Issue 120629 - 2016-12-29 by MUARN : Si CEE HT=TCC et toujours ajouté taxe non déductible
      If [F:PSD]VACTYP <>4
        If [F:PSD]LINATIAMT>[F:PSD]LINAMT
          WMONTANT+=([F:PSD]AMTTAXLIN1-[F:PSD]DEDTAXLIN1)
          WMONTANT+=([F:PSD]AMTTAXLIN2-[F:PSD]DEDTAXLIN2)
          WMONTANT+=([F:PSD]AMTTAXLIN3-[F:PSD]DEDTAXLIN3)
          WMONTANT+=([F:PSD]AMTTAXRCP -[F:PSD]DEDTAXRCP )
          WMONTANT+=([F:PSD]AMTTAXISS -[F:PSD]DEDTAXISS )
          WMONTANT+=([F:PSD]AMTTAXOTH1-[F:PSD]DEDTAXOTH1)
          WMONTANT+=([F:PSD]AMTTAXOTH2-[F:PSD]DEDTAXOTH2)
        Endif
      Else
          WMONTANT+=([F:PSD]AMTTAXLIN1-[F:PSD]DEDTAXLIN1)
          WMONTANT+=([F:PSD]AMTTAXLIN2-[F:PSD]DEDTAXLIN2)
          WMONTANT+=([F:PSD]AMTTAXLIN3-[F:PSD]DEDTAXLIN3)
          WMONTANT+=([F:PSD]AMTTAXRCP -[F:PSD]DEDTAXRCP )
          WMONTANT+=([F:PSD]AMTTAXISS -[F:PSD]DEDTAXISS )
          WMONTANT+=([F:PSD]AMTTAXOTH1-[F:PSD]DEDTAXOTH1)
          WMONTANT+=([F:PSD]AMTTAXOTH2-[F:PSD]DEDTAXOTH2)
      Endif
      If [F:PSD]QTYPUU=0 [F:PSD]QTYPUU=1 : Endif
      WMONTANT=WMONTANT*WQTEPUU/[F:PSD]QTYPUU
    #----- Pré-engagement TTC -----#
    Elsif [F:PSD]CMMPRPTAX=3
      If [F:PSD]QTYPUU=0 [F:PSD]QTYPUU=1 : Endif
      WMONTANT=[F:PSD]LINATIAMT*WQTEPUU/[F:PSD]QTYPUU
    #----- Pré-engagement HT -----#
    Else
      WMONTANT=[F:PSD]NETPRI*WQTEPUU
    Endif
    #-----
    Call ARRDEV (WMONTANT,[F:PSD]CUR) From TRTDIV
  Endif
  #----- Récupération des comptes et sections analytiques -----#
  Read [CAL] CAL0="PSD";0;[F:PSD]PSHNUM;[F:PSD]PSDLIN;0;"";1
  If fstat  Raz [F:CAL] : Endif
  #----- Référentiels, codes plans et comptes -----#
  For WI=1 To 10
    TPLAN  (WI)=[F:CAL]COA(WI-1)
    TCOMPTE(WI)=[F:CAL]ACC(WI-1)
    TBLED  (WI)=[F:CAL]LED(WI-1)
  Next WI
  #----- Recherche compte général -----#
  Raz WCOMPTE
  I=find(WLEDGEN,[F:CAL]LED(0..9))
  If I
    WCOMPTE=[F:CAL]ACC(I-1)
  Endif
  #----- Recherche compte analytique -----#
  Raz WCPTANA
  I=find(WLEDANA,[F:CAL]LED(0..9))
  If I
    WCPTANA=[F:CAL]ACC(I-1)
    WCOA   =[F:CAL]COA(I-1)
  Endif
  #-----
  [F:TB0]=[F:PSD]
  [F:TB2]=[F:CAL]
  ID1(1)=[F:PSD]PSHNUM : ID1(2)=num$([F:PSD]PSDLIN)
  #----- Recherche des comptes si nécessaire -----#
  If WCOMPTE="" & WCPTANA=""
    Call SETREF(GSOCIETE,WI,TBLED) From CPTDIV
    Call COMPTE ("PQUIS",1,ID1,ID2,TPLAN2,TCOMPTE2,STA,WMSG) From CPTCOD
    If STA
      Raz TPLAN, TCOMPTE, GMESSAGE
    Else
      For WI=1 To 10
        If TPLAN2(WI)<>""
          WJ=find([F:GAD]LEDTYP(WI-1),TBTYPLED(1..10))
          If WJ
            TPLAN  (WJ)=TPLAN2  (WI)
            TCOMPTE(WJ)=TCOMPTE2(WI)
          Endif
        Endif
      Next WI
    Endif
    #----- Récupération compte général -----#
    Call LECPLAN(GSOCIETE,GTYPGEN,WCOA) From CPTDIV
    I=find(WCOA,TPLAN(1..10))
    If I  WCOMPTE=TCOMPTE(I) : Endif
    If [F:GAC]COA<>WCOA | [F:GAC]ACC<>WCOMPTE
      Read [GAC] GAC0=WCOA;WCOMPTE : If fstat  Raz [F:GAC] : Endif
    Endif
    If [F:GAC]VATIPT=5
      [F:PSD]LINPURTYP=3
    Elsif [F:GAC]VATIPT=4
      [F:PSD]LINPURTYP=2
    Else
      [F:PSD]LINPURTYP=1
    Endif
    #----- Récupération compte analytique -----#
    Call LECPLAN(GSOCIETE,GTYPANA,WCOA) From CPTDIV
    I=find(WCOA,TPLAN(1..10))
    If I  WCPTANA=TCOMPTE(I) : Endif
  Endif
  If STA<>0 | WCOMPTE="" | WCPTANA=""
    If [M:DIA]TRACE=2 & STA<>0
      WMSG=[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)-"/"-mess(36,194,1)
      Call ECR_TRACE(WMSG,1) From GESECRAN
    Endif
    Raz STA : Goto SUITE_PSD
  Endif
  #----- Récupération unité d'oeuvre -----#
  If [F:GAC]COA<>WCOA | [F:GAC]ACC<>WCPTANA
    Read [GAC] GAC0=WCOA;WCPTANA : If fstat  Raz [F:GAC] : [F:GAC]UOM=[F:PSD]STU : Endif
  Endif
  #----- Conversion quantité UA puis US (Si pas de coef) en unité d'oeuvre -----#
  Call PCAL_QTY(WQTEPUU,[F:PSD]PUU,WQTEUOM,[F:GAC]UOM,
&               [F:PSD]ITMREF,[F:PSD]BPSNUM,1,GBIDD1) From TRTACHQTE1
  If [F:TCO]UOM1=""
    Call PCAL_QTY(WQTESTU,[F:PSD]STU,WQTEUOM,[F:GAC]UOM,
&               [F:PSD]ITMREF,[F:PSD]BPSNUM,1,GBIDD1) From TRTACHQTE1
  Endif
  #----- Coefficient de convertion introuvable ! -----#
  If [F:TCO]UOM1="" & [M:DIA]TRACE=2
    WMSG="/"-[F:PSD]STU-"->"-[F:GAC]UOM-mess(473,199,1)
    If WMSG<>WMSG3
      WMSG3=WMSG
      WMSG =[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)-WMSG
      Call ECR_TRACE (WMSG,0) From GESECRAN
    Endif
  Endif
  #----- Recherche pré-engagements existants pour en déduire le taux de conversion -----#
  Raz WTOTCUR, WTOTLED, WTOTQTY, WBUDQTYFLG
  For [CMD] CMD0 Where NUM=[F:PSD]CMMPRPNUM
    WAMTCUR=arr([F:CMD]AMTCUR,WDECCUR)
    If [F:CMD]AMTCUR<>WAMTCUR
      WNUM=[F:CMD]NUM : WLINNUM=[F:CMD]LIN
      If [M:DIA]XGENTYP<>2
        Trbegin [CMD]
        Update [CMD] Where NUM=WNUM & LIN=WLINNUM
&                    With AMTCUR=WAMTCUR
        If !fstat
          Commit
          If [M:DIA]TRACE=2
            WMSG =[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)
            WMSG-="/"-mess(448,197,1)-num$([F:CMD]AMTCUR)
            WMSG-="-->"-num$(WAMTCUR)+"  "+mess(450,197,1)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
        Else
          Rollback
          If [M:DIA]TRACE=2
            WMSG =mess(1,631,1)-WNUM-num$(WLINNUM)
            WMSG-=mess(137,188,1)+"="+num$(fstat)-mess(450,197,1)
            Call ECR_TRACE(WMSG,1) From GESECRAN
          Endif
        Endif
      Elsif [M:DIA]TRACE=2
        WMSG =[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)
        WMSG-="/"-mess(448,197,1)-num$([F:CMD]AMTCUR)
        WMSG-="-->"-num$(WAMTCUR)+"  "+mess(450,197,1)
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:CMD]AMTCUR=WAMTCUR
    Endif
    WTOTCUR+=[F:CMD]AMTCUR
    WTOTLED+=[F:CMD]AMTLED
    WTOTQTY+=[F:CMD]QTY
    If [F:CMD]QTY<>0  WBUDQTYFLG=1 : Endif
  Next
  #----- Test si contrôle budgétaire en quantité -----#
  If !WBUDQTYFLG  Raz WQTEUOM : Endif
  #----- Calcul écart en devise commande -----#
  # VPO 15/04/11 73289 appel PE MAJDELTA sur resynchro
  WTYPMAJ=10 : Gosub POINT_MAJDELTA
  If WTOTCUR<>WMONTANT : # | (WTOTQTY<>WQTEUOM & [F:GAC]FLGUOM=2)
    WDELTACUR=WMONTANT-WTOTCUR
    WDELTAQTY=WQTEUOM-WTOTQTY
    If WDELTACUR<0 | (WDELTACUR=0 & WDELTAQTY<0)
      WSIGN=-1
      WDELTACUR=-WDELTACUR
      WDELTAQTY=-WDELTAQTY
    Else
      WSIGN=1
    Endif
    #----- Calcul écarts en devise référentiel analytique -----#
    Raz WDELTALED
    If WTOTCUR<>0
      #----- Conversion des écarts avec anciens cumuls pré-engagements -----#
      If WTOTCUR<>WDELTACUR
        WDELTALED=WDELTACUR*(WTOTLED/WTOTCUR) : Call ARRDEV(WDELTALED,WDEVLED) From TRTDIV
      Else
        WDELTALED=WTOTLED
      Endif
    Else
      #----- Conversion écarts avec taux de devise -----#
      If WDEVLED<>[F:PSD]CUR
        Call CONVERT([F:PSD]CUR,WDEVLED,GLOCALDEV,[F:PSD]CHGTYP,[F:PSD]EXTRCPDAT,
&                    WDELTACUR,WDELTALED,STA) From TRTDEV
      Else
        WDELTALED=WDELTACUR
      Endif
    Endif
    #----- Chargement codes axes et sections analytiques -----#
    For I=1 To GOPTCANA
      TBDIE(I)=[F:CAL]DIE(I-1)
      TBCCE(I)=[F:CAL]CCE(I-1)
    Next I
    #----- Filtrage des codes et sections analytiques sur référentiel analytique -----#
    #             On ne filtre plus à partir de la version Béryl 6.1 !                #
    #---------------------------------------------------------------------------------#
    #Call SETCCEAXE(GSOCIETE,GTYPANA,TBDIE,TBCCE,TBDIE2,TBCCE2) From CPTDIV
    #----- Correction des pré-engagements -----#
    STA=1
    If [M:DIA]XGENTYP<>2
      Trbegin [CMM],[CMD]
#      Call MAJENGOLD([F:PSD]EXTRCPDAT,GFINRSP,[F:PSD]CUR,WDELTACUR,WDEVLED,WDELTALED,
#&             WDELTAQTY,WCPTANA,[F:PSD]BPSNUM,TBDIE2,TBCCE2,1,WSIGN,1,0,[F:PSD]CMMPRPNUM,
#&             [F:PSD]PSHNUM,STA,WMSG2,"PQUIS",ID1,"","",3,[F:PSD]CHGTYP) From CPTENG
      #----- Nouvel appel Béryl 6.1 -----#
      WDOCUMENT(1)=[F:PSD]PSHNUM
      WDOCUMENT(2)=num$([F:PSD]PSDLIN)
      WDOCUMENT(3)=""
      #----- Chargement des motifs -----#
      WMOTIF(1)=8 : # Resynchronisation
      WMOTIF(2)=1 : # Demande d'achat
      # --- Resynchronisation pré-engagement
      # VPO 14/03/11 72229 appel PE MAJENG sur resynchro
      WTYPMAJ=10 : Gosub POINT_MAJENG From TRTACHCDE1
      #-----
      Call MAJENG([F:PSD]EXTRCPDAT,GFINRSP,[F:PSD]CUR,WDELTACUR,WRATDIV,WRATMLT,
&             WDELTAQTY,TCOMPTE,TBLED,[F:PSD]BPSNUM,TBDIE,TBCCE,1,WSIGN,1,0,[F:PSD]CMMPRPNUM,
&             WDOCUMENT,WMOTIF,STA,WMSG2,"PQUIS",ID1,"","",3,[F:PSD]CHGTYP) From CPTENG
      #---------------------------------------------------------#
      # STA =-1 Une erreur a empêché le contrôle de s'effectuer #
      # STA = 0 Le budget est dépassé (GOK = 0)                 #
      # STA = 1 Tout va bien                                    #
      #---------------------------------------------------------#
      If GOK=1 Commit Else Rollback : GOK=1 : Endif
    Endif
    If STA<>1
      If [M:DIA]TRACE=2
        If WMSG2=""
          If STA=-1 WMSG2=mess(93,197,1) Else WMSG2=mess(5,108,1) : Endif
        Endif
        WMSG =[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)
        If WTOTCUR<>WMONTANT
          WMSG-="/"-mess(448,197,1)-num$(WTOTCUR)-"-->"-num$(WMONTANT)
        Endif
        If WTOTQTY<>WQTEUOM
          WMSG-="/"-mess(449,197,1)-num$(WTOTQTY)-"-->"-num$(WQTEUOM)
        Endif
        WMSG-=WMSG2
        Call ECR_TRACE(WMSG,1) From GESECRAN
      Endif
    Else
      If [M:DIA]TRACE=2
        WMSG =[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)
        If WTOTCUR<>WMONTANT
          WMSG-="/"-mess(448,197,1)-num$(WTOTCUR)-"-->"-num$(WMONTANT)
        Endif
        If WTOTQTY<>WQTEUOM
          WMSG-="/"-mess(449,197,1)-num$(WTOTQTY)-"-->"-num$(WQTEUOM)
        Endif
        Call ECR_TRACE(WMSG,1) From GESECRAN
      Endif
      NBCOR+=1
    Endif
  Endif
  #-----
$SUITE_PSD
Next
#----- Fin du traitement -----#
If [M:DIA]TRACE=2
  WMSG =mess(451,197,1)-num$(NBENR)-mess(452,197,1)-num$(NBCOR)
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
Close Local File [PSH]
Close Local File [PSD]
Close Local File [TB0]
Close Local File [TB2]
Return


#----------------------------------#
# Traitement des commandes d'achat #
#----------------------------------#
$TRT_POH
If [M:DIA]TRACE=2
  Call ECR_TRACE(" ",0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(mess(447,197,1),0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif
#----- Ouverture des fichiers -----#
If clalev([F:POH]) =0  Local File PORDER     [POH]  : Endif
If clalev([F:POQ]) =0  Local File PORDERQ    [POQ]  : Endif
If clalev([F:POQ0])=0  Local File PORDERQ    [POQ0] : Endif
If clalev([F:POQ1])=0  Local File PORDERQ    [POQ1] : Endif
If clalev([F:POQ2])=0  Local File PORDERQ    [POQ2] : Endif
If clalev([F:POP]) =0  Local File PORDERP    [POP]  : Endif
If clalev([F:CAL]) =0  Local File CPTANALIN  [CAL]  : Endif
If clalev([F:PTD]) =0  Local File PRECEIPTD  [PTD]  : Endif
If clalev([F:PIH]) =0  Local File PINVOICE   [PIH]  : Endif
If clalev([F:PID]) =0  Local File PINVOICED  [PID]  : Endif
If clalev([F:PIH2])=0  Local File PINVOICE   [PIH2] : Endif
If clalev([F:PID2])=0  Local File PINVOICED  [PID2] : Endif
If clalev([F:TB0]) =0  Local File PORDER     [TB0]  : Endif
If clalev([F:TB1]) >0  Close Local File [TB1]       : Endif
If clalev([F:TB1]) =0  Local File PORDERQ    [TB1]  : Endif
If clalev([F:TB2]) =0  Local File CPTANALIN  [TB2]  : Endif
Link [PID]  With [PIH]  PIH0=[F:PID]NUM  As [PIX]
Link [PID2] With [PIH2] PIH0=[F:PID2]NUM As [PIX2]
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz NBENR, NBCOR, GFCY, GSOCIETE
Raz WCMMNUM, WCMMNUM2, WTAB_CMMNUM, WTAB_NBLIG
#-----
CRITERE="CMMNUM<>''"
If [M:DIA]XFCYFLG<>2  CRITERE+=" & POHFCY=[M:DIA]FCY" : Endif
If [M:DIA]XCPYFLG<>2  CRITERE+=" & CPY=[M:DIA]CPY"    : Endif

# Issue 99391 - 2014-04-29 by MUARN : facture/avoir non validée
Local Integer WQTYFAC
Local Integer WAVO_DESOLDE, WAVO_DESOLDE_BKP

Filter [POQ] Where evalue(CRITERE) Order By Key POQ9=CPY;CMMNUM;POHNUM;POPLIN;POQSEQ
For [POQ] POQ9
  NBENR+=1
  Raz [F:PID] # Issue 99391 - 2014-04-25 by MUARN : facture partielle mais déclarée non partielle
  Raz WQTYFAC # Issue 99391 - 2014-04-29 by MUARN : facture/avoir non validé
  WAVO_DESOLDE = 1 # Issue 99391 - 2014-06-11 by MUARN : avoir qui réengage le solde non validé
  #----- Si 1ère fois -----#
  If WCMMNUM=""
    Raz [F:POQ0]
    Gosub COMPTES  : If !OK Goto SUITE_POQ : Endif
  Endif
  #----- Lecture entête de la commande -----#
  If [F:POH]POHNUM<>[F:POQ]POHNUM
    Read [POH] POH0=[F:POQ]POHNUM
    If fstat
      Raz [F:POH]
      If [M:DIA]TRACE=2
        WMSG=[F:POQ]POHNUM-"/"-mess(359,197,1)
        Call ECR_TRACE(WMSG,1) From GESECRAN
      Endif
      Raz OK : Goto SUITE_POQ
    Endif
  Endif
  #----- Lecture ligne prix -----#
  If [F:POH]POHTYP=1
    Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
    If fstat Raz [F:POP] : Endif
  Else
    Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN &
&                      POPDAT>=[F:POQ]DEMRCPDAT
    Read [POP] POP1 First
    If fstat : Raz [F:POP] : Endif
    Filter [POP]
  Endif
  #VPO 14/03/11 72229 deplacement MAJ_ENGAG après lecture POP
  #----- Si rupture sur numéro d'engagement -----#
  If GSOCIETE<>[F:POQ]CPY | WCMMNUM<>[F:POQ]CMMNUM
    [F:POQ0]=[F:POQ]
    [F:POQ]=[F:POQ1]
    Gosub MAJ_ENGAGEMENT : If !OK Goto SUITE_POQ : Endif
  Endif
  #----- Chargement société et paramètres -----#
  If GFCY<>[F:POQ]POHFCY
    GFCY=[F:POQ]POHFCY
    Call PARAM(GFCY,"PURCMMDAT",PARAM2) From ADOVAL
    GPURCMMDAT=val(PARAM2)
  Endif
  If GPURCMMDAT=1 DATBUD=[F:POQ]ORDDAT Else DATBUD=[F:POQ]EXTRCPDAT : Endif
  #----- Récupération des comptes et sections analytiques -----#
  Read [CAL] CAL0="POP";0;[F:POP]POHNUM;[F:POP]POPLIN;[F:POP]POPSEQ;"";1
  If fstat  Raz [F:CAL] : Endif
  #----- Référentiels, codes plans et comptes -----#
  For WI=1 To 10
    TPLAN  (WI)=[F:CAL]COA(WI-1)
    TCOMPTE(WI)=[F:CAL]ACC(WI-1)
    TBLED  (WI)=[F:CAL]LED(WI-1)
  Next WI
  #----- Calcul des quantités et du montant toujours engagés -----#
  WQTEPUU=[F:POQ]QTYPUU
  WQTESTU=[F:POQ]QTYSTU
  #----- Engagement HT + taxes non déductibles -----#
  If [F:POQ]CMMTAX=2
    WMONTANT=[F:POQ]LINAMT
    # Issue 120629 - 2016-12-29 by MUARN : Si CEE HT=TCC et toujours ajouté taxe non déductible
    If [F:POH]VACTYP <>4
      If [F:POQ]LINATIAMT>[F:POQ]LINAMT
        WMONTANT+=([F:POQ]AMTTAXLIN1-[F:POQ]DEDTAXLIN1)
        WMONTANT+=([F:POQ]AMTTAXLIN2-[F:POQ]DEDTAXLIN2)
        WMONTANT+=([F:POQ]AMTTAXLIN3-[F:POQ]DEDTAXLIN3)
        WMONTANT+=([F:POQ]AMTTAXRCP -[F:POQ]DEDTAXRCP )
        WMONTANT+=([F:POQ]AMTTAXISS -[F:POQ]DEDTAXISS )
        WMONTANT+=([F:POQ]AMTTAXOTH1-[F:POQ]DEDTAXOTH1)
        WMONTANT+=([F:POQ]AMTTAXOTH2-[F:POQ]DEDTAXOTH2)
      Endif
    Else
      WMONTANT+=([F:POQ]AMTTAXLIN1-[F:POQ]DEDTAXLIN1)
      WMONTANT+=([F:POQ]AMTTAXLIN2-[F:POQ]DEDTAXLIN2)
      WMONTANT+=([F:POQ]AMTTAXLIN3-[F:POQ]DEDTAXLIN3)
      WMONTANT+=([F:POQ]AMTTAXRCP -[F:POQ]DEDTAXRCP )
      WMONTANT+=([F:POQ]AMTTAXISS -[F:POQ]DEDTAXISS )
      WMONTANT+=([F:POQ]AMTTAXOTH1-[F:POQ]DEDTAXOTH1)
      WMONTANT+=([F:POQ]AMTTAXOTH2-[F:POQ]DEDTAXOTH2)
    Endif
    If [F:POQ]QTYPUU=0 [F:POQ]QTYPUU=1 : Endif
    WMONTANT=WMONTANT*WQTEPUU/[F:POQ]QTYPUU
  #----- Engagement TTC -----#
  Elsif [F:POQ]CMMTAX=3
    If [F:POQ]QTYPUU=0 [F:POQ]QTYPUU=1 : Endif
    WMONTANT=[F:POQ]LINATIAMT*WQTEPUU/[F:POQ]QTYPUU
  #----- Engagement HT -----#
  Else
    WMONTANT=WQTEPUU*[F:POP]NETPRI/[F:POQ]UOMPUUCOE
  Endif
  #-----
  Call ARRDEV (WMONTANT,[F:POH]CUR) From TRTDIV
  #-----
  If [F:POQ]INVQTYPUU<>0 | [F:POQ]INVQTYSTU<>0 | [F:POQ]LININVNBR>0
    Raz GBIDD1, GBIDD2, GBIDI1
    #----- Recherche réception puis facture -----#
    For [PTD] PTD2 Where POHNUM=[F:POQ]POHNUM
&                      & POPLIN=[F:POQ]POPLIN
&                      & POQSEQ=[F:POQ]POQSEQ
      For [PIX] Where [F:PID]TYPORI=2
&                   & [F:PID]NUMORI=[F:PTD]PTHNUM
&                   & [F:PID]LINORI=[F:PTD]PTDLIN
&                   & [F:PIH]STA=3
        If WTAB_NBLIG<200 & [F:PID]CMMNUM<>"" & [F:PID]CMMNUM<>WCMMNUM
          WTAB_CMMNUM(WTAB_NBLIG)=[F:PID]CMMNUM
          WTAB_NBLIG+=1
        Endif
        # Issue 99391 - 2014-06-10 by MUARN : avoir qui désolde
        If [F:PIH]INVTYP = 2 & [F:PID]QTYBUDLIN > [F:PID]QTYPUU & WQTEPUU <> GBIDD1
          GBIDD1+=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
          GBIDD2+=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
        Else
          GBIDD1+=[F:PID]QTYBUDLIN*(3-(2*[F:PIH]INVTYP))
          GBIDD2+=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
        Endif
        If GBIDD1=0 & GBIDD2>0  GBIDI1=1 : Endif
        For [PIX2] Where [F:PID2]TYPORI=4
&                      & [F:PID2]NUMORI=[F:PID]NUM
&                      & [F:PID2]LINORI=[F:PID]PIDLIN
&                      & [F:PIH2]STA=3
          If WTAB_NBLIG<200 & [F:PID2]CMMNUM<>"" & [F:PID2]CMMNUM<>WCMMNUM
            WTAB_CMMNUM(WTAB_NBLIG)=[F:PID2]CMMNUM
            WTAB_NBLIG+=1
          Endif
          # Issue 99391 - 2014-06-10 by MUARN : avoir qui désolde
          If [F:PIH2]INVTYP = 2 & [F:PID2]QTYBUDLIN > [F:PID2]QTYPUU & WQTEPUU <> GBIDD1
            GBIDD1+=[F:PID2]QTYPUU*(3-(2*[F:PIH2]INVTYP))
            GBIDD2+=[F:PID2]QTYPUU*(3-(2*[F:PIH2]INVTYP))
          Else
            GBIDD1+=[F:PID2]QTYBUDLIN*(3-(2*[F:PIH2]INVTYP))
            GBIDD2+=[F:PID2]QTYPUU*(3-(2*[F:PIH2]INVTYP))
          Endif
          If GBIDD1=0 & GBIDD2>0  GBIDI1=1 : Endif
        Next
        # Issue 99391 - 2014-04-29 by MUARN : recherche d'avoir non validée sur facture/réception
        For [PIX2] Where [F:PID2]TYPORI=4
&                      & [F:PID2]NUMORI=[F:PID]NUM
&                      & [F:PID2]LINORI=[F:PID]PIDLIN
&                      & [F:PIH2]STA<>3
            WQTYFAC=[F:PID2]QTYPUU*(3-(2*[F:PIH2]INVTYP))
            # avoir qui réengage le solde non validé
            If [F:PID2]QTYBUDLIN > [F:PID2] QTYPUU : WAVO_DESOLDE = 2 : Endif
        Next
      Next
      # Issue 99391 - 2014-04-29 by MUARN : recherche de facture non validée sur réception
      For [PIX2] Where [F:PID2]TYPORI=2
&                   & [F:PID2]NUMORI=[F:PTD]PTHNUM
&                   & [F:PID2]LINORI=[F:PTD]PTDLIN
&                   & [F:PIH2]STA<>3
          WQTYFAC=[F:PID2]QTYPUU*(3-(2*[F:PIH2]INVTYP))
          # avoir qui réengage le solde non validé
          If [F:PID2]QTYBUDLIN > [F:PID2] QTYPUU : WAVO_DESOLDE = 2 : Endif
      Next
    Next
    #----- Recherche facture -----#
    For [PIX] Where [F:PID]TYPORI=1
&                 & [F:PID]NUMORI=[F:POQ]POHNUM
&                 & [F:PID]LINORI=[F:POQ]POPLIN
&                 & [F:PID]SEQORI=[F:POQ]POQSEQ
&                 & [F:PIH]STA=3
      If WTAB_NBLIG<200 & [F:PID]CMMNUM<>"" & [F:PID]CMMNUM<>WCMMNUM
        WTAB_CMMNUM(WTAB_NBLIG)=[F:PID]CMMNUM
        WTAB_NBLIG+=1
      Endif
      # Issue 99391 - 2014-06-10 by MUARN : avoir qui désolde
      If [F:PIH]INVTYP = 2 & [F:PID]QTYBUDLIN > [F:PID]QTYPUU & WQTEPUU <> GBIDD1
        GBIDD1+=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
        GBIDD2+=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
      Else
        GBIDD1+=[F:PID]QTYBUDLIN*(3-(2*[F:PIH]INVTYP))
        GBIDD2+=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
      Endif
      If GBIDD1=0 & GBIDD2>0  GBIDI1=1 : Endif
      For [PIX2] Where [F:PID2]TYPORI=4
&                    & [F:PID2]NUMORI=[F:PID]NUM
&                    & [F:PID2]LINORI=[F:PID]PIDLIN
&                    & [F:PIH2]STA=3
        If WTAB_NBLIG<200 & [F:PID2]CMMNUM<>"" & [F:PID2]CMMNUM<>WCMMNUM
          WTAB_CMMNUM(WTAB_NBLIG)=[F:PID2]CMMNUM
          WTAB_NBLIG+=1
        Endif
        # Issue 99391 - 2014-06-10 by MUARN : avoir qui désolde
        If [F:PIH2]INVTYP = 2 & [F:PID2]QTYBUDLIN > [F:PID2]QTYPUU & WQTEPUU <> GBIDD1
          GBIDD1+=[F:PID2]QTYPUU*(3-(2*[F:PIH2]INVTYP))
          GBIDD2+=[F:PID2]QTYPUU*(3-(2*[F:PIH2]INVTYP))
        Else
          GBIDD1+=[F:PID2]QTYBUDLIN*(3-(2*[F:PIH2]INVTYP))
          GBIDD2+=[F:PID2]QTYPUU*(3-(2*[F:PIH2]INVTYP))
        Endif
        If GBIDD1=0 & GBIDD2>0  GBIDI1=1 : Endif
      Next
      # Issue 99391 - 2014-04-29 by MUARN : recherche d'avoir non validée sur facture/commande
      For [PIX2] Where [F:PID2]TYPORI=4
&                    & [F:PID2]NUMORI=[F:PID]NUM
&                    & [F:PID2]LINORI=[F:PID]PIDLIN
&                    & [F:PIH2]STA<>3
          WQTYFAC=[F:PID2]QTYPUU*(3-(2*[F:PIH2]INVTYP))
          # avoir qui réengage le solde non validé
          If [F:PID2]QTYBUDLIN > [F:PID2] QTYPUU : WAVO_DESOLDE = 2 : Endif
      Next
    Next
    # Issue 99391 - 2014-04-29 by MUARN : recherche de facture non validée sur commande
    For [PIX2] Where [F:PID2]TYPORI=1
&                 & [F:PID2]NUMORI=[F:POQ]POHNUM
&                 & [F:PID2]LINORI=[F:POQ]POPLIN
&                 & [F:PIH2]STA<>3
      WQTYFAC=[F:PID2]QTYPUU*(3-(2*[F:PIH2]INVTYP))
      # avoir qui réengage le solde non validé
      If [F:PID2]QTYBUDLIN > [F:PID2] QTYPUU : WAVO_DESOLDE = 2 : Endif
    Next
    # Issue 99391 - 2014-04-17 by MUARN : A ne faire que pour les articles gérés en stock
    If !clalev([F:ITM])   Local File ITMMASTER   [ITM] : Endif
    If [F:ITM]ITMREF<>[F:POQ]ITMREF
      Read [ITM] ITM0=[F:POQ]ITMREF : If fstat Raz [F:ITM] : Endif
    Endif
    If [F:POQ]LINCLEFLG=2 & [F:POQ]RCPCLEFLG<>2 & GBIDD1<=GBIDD2 &
&      [F:POQ]QTYPUU>[F:POQ]RCPQTYPUU & [F:ITM]RCPFLG=2
      GBIDD1+=([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU)
      If GBIDD1>WQTEPUU  GBIDI1=1 : Endif
    Endif
    If GBIDI1 Raz WQTEPUU Else WQTEPUU-=GBIDD1 : Endif
    # Issue 99391 - 2014-04-29 by MUARN : prise en compte de facture/avoir non validé
    # à réétudier à ne pas faire dans tous les cas...
    # ajout WQTYFAC = 0 et WQTEPUU <0
    #WQTEPUU+=WQTYFAC
    # Issue 91930 - 2013-08-21 by MUARN : Facture partielle, mais déclarée non partielle
    # Issue 94966 - 2013-12-04 by MUARN : que si la commande est soldée
    # Issue 94966 - 2013-12-16 by MUARN : que si la commande est soldée et facturée
    #If ([F:PID]PRTFLG = 1 & WQTEPUU>0) : Raz WQTEPUU : Endif
    #If ([F:PID]PRTFLG = 1 & WQTEPUU>0 & [F:POQ]LINCLEFLG=2) : Raz WQTEPUU : Endif
    #If ([F:PID]PRTFLG = 1 & WQTEPUU>0 & [F:POQ]LINCLEFLG=2 & [F:POQ]LININVFLG=2) : Raz WQTEPUU : Endif
    #If WQTYFAC>0 WQTEPUU-=WQTYFAC Endif #MUARN 27/05 NON...
    If ([F:PID]PRTFLG = 1 & WQTEPUU>0 & [F:POQ]LINCLEFLG=2 & [F:POQ]LININVFLG=2 & WQTYFAC = 0 ) | WQTEPUU < 0
      Raz WQTEPUU
    Endif
    # Issue 99391 - 2014-06-02 by MUARN : prise en compte de solde de commande
    If ([F:POQ]LINCLEFLG=2 & [F:POQ]RCPCLEFLG=1 & WQTYFAC=0) | ([F:POQ]LINCLEFLG=2 & [F:POQ]LININVFLG=2 & WQTYFAC<>0 & [F:POQ]RCPCLEFLG=2)
      Raz WQTEPUU
    Endif

    Call PCAL_QTY(WQTEPUU,[F:POQ]PUU,WQTESTU,[F:POQ]STU,
&                [F:POQ]ITMREF,[F:POH]BPSNUM,1,GBIDD2) From TRTACHQTE1
    #----- Engagement HT + taxes non déductibles -----#
    If [F:POQ]CMMTAX=2
      WMONTANT=[F:POQ]LINAMT
      # Issue 120629 - 2016-12-29 by MUARN : Si CEE HT=TCC et toujours ajouté taxe non déductible
      If [F:POH]VACTYP <>4
        If [F:POQ]LINATIAMT>[F:POQ]LINAMT
          WMONTANT+=([F:POQ]AMTTAXLIN1-[F:POQ]DEDTAXLIN1)
          WMONTANT+=([F:POQ]AMTTAXLIN2-[F:POQ]DEDTAXLIN2)
          WMONTANT+=([F:POQ]AMTTAXLIN3-[F:POQ]DEDTAXLIN3)
          WMONTANT+=([F:POQ]AMTTAXRCP -[F:POQ]DEDTAXRCP )
          WMONTANT+=([F:POQ]AMTTAXISS -[F:POQ]DEDTAXISS )
          WMONTANT+=([F:POQ]AMTTAXOTH1-[F:POQ]DEDTAXOTH1)
          WMONTANT+=([F:POQ]AMTTAXOTH2-[F:POQ]DEDTAXOTH2)
        Endif
      Else
        WMONTANT+=([F:POQ]AMTTAXLIN1-[F:POQ]DEDTAXLIN1)
        WMONTANT+=([F:POQ]AMTTAXLIN2-[F:POQ]DEDTAXLIN2)
        WMONTANT+=([F:POQ]AMTTAXLIN3-[F:POQ]DEDTAXLIN3)
        WMONTANT+=([F:POQ]AMTTAXRCP -[F:POQ]DEDTAXRCP )
        WMONTANT+=([F:POQ]AMTTAXISS -[F:POQ]DEDTAXISS )
        WMONTANT+=([F:POQ]AMTTAXOTH1-[F:POQ]DEDTAXOTH1)
        WMONTANT+=([F:POQ]AMTTAXOTH2-[F:POQ]DEDTAXOTH2)
      Endif
      If [F:POQ]QTYPUU=0 [F:POQ]QTYPUU=1 : Endif
      WMONTANT=WMONTANT*WQTEPUU/[F:POQ]QTYPUU
    #----- Engagement TTC -----#
    Elsif [F:POQ]CMMTAX=3
      If [F:POQ]QTYPUU=0 [F:POQ]QTYPUU=1 : Endif
      WMONTANT=[F:POQ]LINATIAMT*WQTEPUU/[F:POQ]QTYPUU
    #----- Engagement HT -----#
    Else
      WMONTANT=WQTEPUU*[F:POP]NETPRI/[F:POQ]UOMPUUCOE
    Endif
    #-----
    Call ARRDEV (WMONTANT,[F:POH]CUR) From TRTDIV
  Elsif [F:POQ]LINCLEFLG=2 & [F:POQ]RCPCLEFLG<>2 & [F:POQ]RCPQTYPUU<>0
    # Issue X3-81868 - 2018-04-12 by MUARN : ne pas faire, sinon non prise en compte de la sur-réception
    #If [F:POQ]QTYPUU>=[F:POQ]RCPQTYPUU # 90219 muarn
      Raz WQTEPUU, WQTESTU, WMONTANT
    #Endif
  Elsif [F:POQ]LINCLEFLG=2 & [F:POQ]RCPCLEFLG<>2 & [F:POQ]RCPQTYPUU=0
    Raz WQTEPUU, WQTESTU, WMONTANT
  Endif
  #----- Cumul des différentes lignes d'un même engagement (DL splittées)
  If [F:POQ]PUU=WPUU
    WCUMQTEPUU+=WQTEPUU
  Else
    Call PCAL_QTY(WQTEPUU,[F:POQ]PUU,GBIDD1,WPUU,
&                 [F:POQ]ITMREF,[F:POH]BPSNUM,1,GBIDD2) From TRTACHQTE1
    WCUMQTEPUU+=GBIDD1
  Endif
  WCUMQTESTU+=WQTESTU
  If [F:POH]CUR=WCUR
    WCUMMONTANT+=WMONTANT
  Else
    Call CONVERT([F:POH]CUR,WCUR,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                        WMONTANT,GBIDD1,STA) From TRTDEV
    WCUMMONTANT+=GBIDD1
  Endif
  #-----
  WAVO_DESOLDE_BKP = WAVO_DESOLDE # Issue 99391 - 2014-06-11 by MUARN : avoir qui réengage le solde non validé
$SUITE_POQ
Next
Filter [POQ]
If WCMMNUM<>""
  [F:POQ0]=[F:POQ]
  [F:POQ]=[F:POQ1]
  Gosub MAJ_ENGAGEMENT
Endif
#----- Fin du traitement -----#
If [M:DIA]TRACE=2
  WMSG =mess(451,197,1)-num$(NBENR)-mess(452,197,1)-num$(NBCOR)
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
Close Local File [PER]
Close Local File [CMM]
Close Local File [CMD]
Close Local File [CMM2]
Close Local File [CMD2]
Close Local File [GAC]
Close Local File [CAL]
Close Local File [TCO]
Close Local File [POH]
Close Local File [POQ]
Close Local File [POQ0]
Close Local File [POQ1]
Close Local File [POQ2]
Close Local File [POP]
Close Local File [PTD]
Close Local File [PIX]
Close Local File [PIH]
Close Local File [PID]
Close Local File [PIX2]
Close Local File [PIH2]
Close Local File [PID2]
Close Local File [TB0]
Close Local File [TB1]
Close Local File [TB2]
Return

#-----------------------------#
# Mise à jour de l'engagement #
#-----------------------------#
$MAJ_ENGAGEMENT
WCMMNUM2=WCMMNUM
#----- Conversion quantité UA puis US (Si pas de coef) en unité d'oeuvre -----#
Call PCAL_QTY(WCUMQTEPUU,WPUU,WQTEUOM,[F:GAC]UOM,
&             WITMREF,WBPSNUM,1,GBIDD1) From TRTACHQTE1
If [F:TCO]UOM1=""
  Call PCAL_QTY(WCUMQTESTU,WSTU,WQTEUOM,[F:GAC]UOM,
&             WITMREF,WBPSNUM,1,GBIDD1) From TRTACHQTE1
Endif
#----- Coefficient de convertion introuvable ! -----#
If [F:TCO]UOM1="" & [M:DIA]TRACE=2
  WMSG="/"-WSTU-"->"-[F:GAC]UOM-mess(473,199,1)
  If WMSG<>WMSG3
    WMSG3=WMSG
    WMSG =WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ)-WMSG
    Call ECR_TRACE (WMSG,0) From GESECRAN
  Endif
Endif
#----- Recherche engagements existants pour en déduire le taux de conversion -----#
Raz WTOTCUR, WTOTLED, WTOTQTY, WBUDQTYFLG
For [CMD] CMD0 Where NUM=WCMMNUM
  WAMTCUR=arr([F:CMD]AMTCUR,WDECCUR)
  If [F:CMD]AMTCUR<>WAMTCUR
    WNUM=[F:CMD]NUM : WLINNUM=[F:CMD]LIN
    If [M:DIA]XGENTYP<>2
      Trbegin [CMD]
      Update [CMD] Where NUM=WNUM & LIN=WLINNUM
&                  With AMTCUR=WAMTCUR
      If !fstat
        Commit
        If [M:DIA]TRACE=2
          WMSG =WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ)
          WMSG-="/"-mess(448,197,1)-num$([F:CMD]AMTCUR)
          WMSG-="-->"-num$(WAMTCUR)-mess(450,197,1)
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
      Else
        Rollback
        If [M:DIA]TRACE=2
          WMSG =mess(2,631,1)-WNUM-num$(WLINNUM)
          WMSG-=mess(137,188,1)+"="+num$(fstat)-mess(450,197,1)
          Call ECR_TRACE(WMSG,1) From GESECRAN
        Endif
      Endif
    Elsif [M:DIA]TRACE=2
      WMSG =WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ)
      WMSG-="/"-mess(448,197,1)-num$([F:CMD]AMTCUR)
      WMSG-="-->"-num$(WAMTCUR)-mess(450,197,1)
      Call ECR_TRACE(WMSG,0) From GESECRAN
    Endif
    [F:CMD]AMTCUR=WAMTCUR
  Endif
  WTOTCUR+=[F:CMD]AMTCUR
  WTOTLED+=[F:CMD]AMTLED
  WTOTQTY+=[F:CMD]QTY
  If [F:CMD]QTY<>0  WBUDQTYFLG=1 : Endif
Next
#----- Recherche si désengagement facture a été fait sur un nouvel engagement -----#
If WTAB_NBLIG>0
  # Issue 82582 - 2013-10-17 by SR : construire le find selon le nombre d'enregistrements dans la liste
  If WTAB_NBLIG <= 60
     WFLTCMD = "find(NUM,WTAB_CMMNUM(0..WTAB_NBLIG-1))<>0"
  Else
     WFLTCMD = "find(NUM,WTAB_CMMNUM(0..WTAB_NBLIG-1))"
  Endif
#  For [CMD2] CMD0 Where find(NUM,WTAB_CMMNUM(0..WTAB_NBLIG-1))<>0
   For [CMD2] CMD0 Where evalue(WFLTCMD)
    WTOTCUR+=[F:CMD2]AMTCUR
    WTOTLED+=[F:CMD2]AMTLED
    WTOTQTY+=[F:CMD2]QTY
  Next
Endif
#----- Test si contrôle budgétaire en quantité -----#
If !WBUDQTYFLG  Raz WQTEUOM : Endif
#----- Calcul écart en devise commande -----#
# VPO 15/04/11 73289 appel PE MAJDELTA sur resynchro
WTYPMAJ=11 : Gosub POINT_MAJDELTA

# Issue 99391 - 2014-06-11 by MUARN : avoir qui réengage le solde non validé
If WAVO_DESOLDE_BKP = 2 & WTOTCUR = 0 & WTOTCUR <> WCUMMONTANT
  Raz WCUMMONTANT
Endif

If WTOTCUR<>WCUMMONTANT : # | (WTOTQTY<>WQTEUOM & [F:GAC]FLGUOM=2)
  WDELTACUR=WCUMMONTANT-WTOTCUR
  WDELTAQTY=WQTEUOM-WTOTQTY
  If WDELTACUR<0 | (WDELTACUR=0 & WDELTAQTY<0)
    WSIGN=-1
    WDELTACUR=-WDELTACUR
    WDELTAQTY=-WDELTAQTY
  Else
    WSIGN=1
  Endif
  #----- Calcul écarts en devise référentiel analytique -----#
  Raz WDELTALED
  If WTOTCUR<>0
    #----- Conversion des écarts avec anciens cumuls engagements -----#
    If WTOTCUR<>WDELTACUR
      WDELTALED=WDELTACUR*(WTOTLED/WTOTCUR) : Call ARRDEV(WDELTALED,WDEVLED) From TRTDIV
    Else
      WDELTALED=WTOTLED
    Endif
  Else
    #----- Conversion écarts avec taux de devise -----#
    If WDEVLED<>WCUR
      Call CONVERT(WCUR,WDEVLED,GLOCALDEV,WCHGTYP,WORDDAT,
&                  WDELTACUR,WDELTALED,STA) From TRTDEV
    Else
      WDELTALED=WDELTACUR
    Endif
  Endif
  #----- Chargement codes axes et sections analytiques -----#
  For I=1 To GOPTCANA
    TBDIE(I)=[F:CAL]DIE(I-1)
    TBCCE(I)=[F:CAL]CCE(I-1)
  Next I
  #----- Filtrage des codes et sections analytiques sur référentiel analytique -----#
  #             On ne filtre plus à partir de la version Béryl 6.1 !                #
  #---------------------------------------------------------------------------------#
  #Call SETCCEAXE(GSOCIETE,GTYPANA,TBDIE,TBCCE,TBDIE2,TBCCE2) From CPTDIV
  #----- Correction des engagements -----#
  STA=1
  If [M:DIA]XGENTYP<>2
    Trbegin [CMM],[CMD]
    If WPOHTYP=2  TYPORG=2 Else  TYPORG=1 : Endif
#    Call MAJENGOLD(DATBUD,GFINRSP,WCUR,WDELTACUR,WDEVLED,WDELTALED,
#&          WDELTAQTY,WCPTANA,WBPSNUM,TBDIE2,TBCCE2,1,WSIGN,2,0,WCMMNUM,
#&          WPOHNUM,STA,WMSG2,"PORD",ID2,"","",TYPORG,WCHGTYP) From CPTENG
    #----- Nouvel appel Béryl 6.1 -----#
    WDOCUMENT(1)=WPOHNUM
    WDOCUMENT(2)=num$(WPOPLIN)
    # Issue 90891 - 2013-07-04 by MUARN : ajout N° seq DL
    #WDOCUMENT(3)=num$(WPOQSEQ)
    WDOCUMENT(3)=num$(WPOPSEQ)
    WDOCUMENT(4)=num$(WPOQSEQ)

    #----- Chargement des motifs -----#
    WMOTIF(1)=8 : # Resynchronisation
    WMOTIF(2)=2 : # Commande
    # --- Resynchronisation engagement
    # VPO 14/03/11 72229 appel PE MAJENG sur resynchro
    WTYPMAJ=11 : Gosub POINT_MAJENG From TRTACHCDE1
    #-----
    Call MAJENG(DATBUD,GFINRSP,WCUR,WDELTACUR,WRATDIV,WRATMLT,
&          WDELTAQTY,TCOMPTE,TBLED,WBPSNUM,TBDIE,TBCCE,1,WSIGN,2,0,WCMMNUM,
&          WDOCUMENT,WMOTIF,STA,WMSG2,"PORD",ID2,"","",TYPORG,WCHGTYP) From CPTENG
    #---------------------------------------------------------#
    # STA =-1 Une erreur a empêché le contrôle de s'effectuer #
    # STA = 0 Le budget est dépassé (GOK = 0)                 #
    # STA = 1 Tout va bien                                    #
    #---------------------------------------------------------#
    If GOK=1
      If WCMMNUM<>WCMMNUM2
        Update [POQ2] Where POHNUM=WPOHNUM & POPLIN=WPOPLIN & POQSEQ=WPOQSEQ
&                     With  CMMNUM=WCMMNUM
        If fstat
          If [M:DIA]TRACE=2
            Call ECR_TRACE(mess(13,100,1)-"PORDERQ"-WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ),1) From GESECRAN
          Endif
          Rollback
        Else
          If [M:DIA]TRACE=2
            Call ECR_TRACE(mess(32,172,1)-WCMMNUM2-mess(81,75,1)-WCMMNUM-mess(233,197,1),1) From GESECRAN
          Endif
          Commit
        Endif
        WCMMNUM=WCMMNUM2
      Else
        Commit
      Endif
    Else
      Rollback : GOK=1
    Endif
  Endif
  If STA<>1
    If [M:DIA]TRACE=2
      If WMSG2=""
        If STA=-1 WMSG2=mess(93,197,1) Else WMSG2=mess(5,108,1) : Endif
      Endif
      WMSG =WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ)
      If WTOTCUR<>WCUMMONTANT
        WMSG-="/"-mess(448,197,1)-num$(WTOTCUR)-"-->"-num$(WCUMMONTANT)
      Endif
      If WTOTQTY<>WQTEUOM
        WMSG-="/"-mess(449,197,1)-num$(WTOTQTY)-"-->"-num$(WQTEUOM)
      Endif
      WMSG-=WMSG2
      Call ECR_TRACE(WMSG,1) From GESECRAN
    Endif
  Else
    If [M:DIA]TRACE=2
      WMSG =WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ)
      If WTOTCUR<>WCUMMONTANT
        WMSG-="/"-mess(448,197,1)-num$(WTOTCUR)-"-->"-num$(WCUMMONTANT)
      Endif
      If WTOTQTY<>WQTEUOM
        WMSG-="/"-mess(449,197,1)-num$(WTOTQTY)-"-->"-num$(WQTEUOM)
      Endif
      Call ECR_TRACE(WMSG,1) From GESECRAN
    Endif
    NBCOR+=1
  Endif
Endif
Gosub COMPTES
Return
#----------------------------------------#
# Récupération comptes et unité d'oeuvre #
#----------------------------------------#
$COMPTES
Raz WCMMNUM, WCUMQTEPUU, WCUMQTESTU, WCUMMONTANT
Raz WTAB_CMMNUM, WTAB_NBLIG
OK=1
If [F:POQ0]POHNUM<>""
    [F:POQ]=[F:POQ0]
Endif
#----- Lecture entête de la commande -----#
If [F:POH]POHNUM<>[F:POQ]POHNUM
  Read [POH] POH0=[F:POQ]POHNUM
  If fstat
    Raz [F:POH]
    If [M:DIA]TRACE=2
      WMSG=[F:POQ]POHNUM-"/"-mess(359,197,1)
      Call ECR_TRACE(WMSG,1) From GESECRAN
    Endif
    Raz OK : Return
  Endif
Endif
#----- Lecture ligne prix -----#
If [F:POH]POHTYP=1
  Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
  If fstat Raz [F:POP] : Endif
Else
  Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN &
&                    POPDAT>=[F:POQ]DEMRCPDAT
  Read [POP] POP1 First
  If fstat : Raz [F:POP] : Endif
  Filter [POP]
Endif
#----- Chargement société et paramètres -----#
# Issue 79938 - 2012-02-24 by SR : si changement de site, récupération du site financier
If GSOCIETE<>[F:POQ]CPY | GCURFCY <> [F:POQ]POHFCY
  # Issue 95891 - 2014-01-24 by SR
  WSOCIETE = GSOCIETE
  Call GETDEV([F:POQ]POHFCY) From DEVSUB : If GFINRSP="" GFINRSP=[F:POQ]POHFCY : Endif
  # Issue 95891 - 2014-01-24 by SR
  #If GSOCIETE<>[F:POQ]CPY
  If WSOCIETE <> GSOCIETE
    Call LECLED(GSOCIETE,GTYPGEN,WLEDGEN,WDEVLED) From CPTDIV
    Call LECLED(GSOCIETE,GTYPANA,WLEDANA,WDEVLED) From CPTDIV
    #----- Liste des types de référentiel de la société -----#
    Raz TBTYPLED, WI : Call LSTLEDTYP(GSOCIETE,0,TBTYPLED,WI) From CPTDIV
  Endif
Endif
#----- Récupération des comptes et sections analytiques -----#
Read [CAL] CAL0="POP";0;[F:POP]POHNUM;[F:POP]POPLIN;[F:POP]POPSEQ;"";1
If fstat  Raz [F:CAL] : Endif
#----- Référentiels, codes plans et comptes -----#
For WI=1 To 10
  TPLAN  (WI)=[F:CAL]COA(WI-1)
  TCOMPTE(WI)=[F:CAL]ACC(WI-1)
  TBLED  (WI)=[F:CAL]LED(WI-1)
Next WI
#-----
[F:TB0]=[F:POH]
[F:TB1]=[F:POQ]
[F:TB2]=[F:CAL]
ID1(1)=[F:POQ]POHNUM
ID2(1)=[F:POQ]POHNUM : ID2(2)=num$([F:POQ]POPLIN) : ID2(3)=num$([F:POQ]POQSEQ)
#----- Recherche compte général -----#
Raz WCOMPTE
I=find(WLEDGEN,[F:CAL]LED(0..9))
If I
  WCOMPTE=[F:CAL]ACC(I-1)
Endif
#----- Recherche compte analytique -----#
Raz WCPTANA
I=find(WLEDANA,[F:CAL]LED(0..9))
If I
  WCPTANA=[F:CAL]ACC(I-1)
  WCOA   =[F:CAL]COA(I-1)
Endif
#-----
Raz STA
#----- Recherche des comptes si nécessaire -----#
If WCOMPTE="" & WCPTANA=""
  Call SETREF(GSOCIETE,WI,TBLED) From CPTDIV
  Call COMPTE ("PORD",1,ID1,ID2,TPLAN2,TCOMPTE2,STA,WMSG) From CPTCOD
  If STA
    Raz TPLAN, TCOMPTE, GMESSAGE
  Else
    For WI=1 To 10
      If TPLAN2(WI)<>""
        WJ=find([F:GAD]LEDTYP(WI-1),TBTYPLED(1..10))
        If WJ
          TPLAN  (WJ)=TPLAN2  (WI)
          TCOMPTE(WJ)=TCOMPTE2(WI)
        Endif
      Endif
    Next WI
  Endif
  #----- Récupération compte général -----#
  Call LECPLAN(GSOCIETE,GTYPGEN,WCOA) From CPTDIV
  I=find(WCOA,TPLAN(1..10))
  If I  WCOMPTE=TCOMPTE(I) : Endif
  If [F:GAC]COA<>WCOA | [F:GAC]ACC<>WCOMPTE
    Read [GAC] GAC0=WCOA;WCOMPTE : If fstat  Raz [F:GAC] : Endif
  Endif
  If [F:GAC]VATIPT=5
    [F:POQ]LINPURTYP=3
  Elsif [F:GAC]VATIPT=4
    [F:POQ]LINPURTYP=2
  Else
    [F:POQ]LINPURTYP=1
  Endif
  #----- Récupération compte analytique -----#
  Call LECPLAN(GSOCIETE,GTYPANA,WCOA) From CPTDIV
  I=find(WCOA,TPLAN(1..10))
  If I  WCPTANA=TCOMPTE(I) : Endif
Endif
If STA<>0 | WCOMPTE="" | WCPTANA=""
  If [M:DIA]TRACE=2 & STA<>0
    WMSG=[F:POQ]POHNUM-num$([F:POQ]POPLIN)-"/"-mess(36,194,1)
    Call ECR_TRACE(WMSG,1) From GESECRAN
  Endif
  Raz STA, OK : Return
Endif
#----- Récupération unité d'oeuvre -----#
If [F:GAC]COA<>WCOA | [F:GAC]ACC<>WCPTANA
  Read [GAC] GAC0=WCOA;WCPTANA : If fstat  Raz [F:GAC] : [F:GAC]UOM=[F:POQ]STU : Endif
Endif
#-----
[F:POQ1]=[F:POQ]
WCMMNUM=[F:POQ]CMMNUM
WPOHTYP=[F:POQ]POHTYP
WPOHNUM=[F:POQ]POHNUM
WBPSNUM=[F:POH]BPSNUM
WORDDAT=[F:POH]ORDDAT
WCHGTYP=[F:POH]CHGTYP
WPOPLIN=[F:POQ]POPLIN
WPOQSEQ=[F:POQ]POQSEQ
WPOPSEQ=[F:POP]POPSEQ # Issue 90891 - 2013-07-04 by MUARN : ajout N° seq DL
WITMREF=[F:POQ]ITMREF
WPUU=[F:POQ]PUU
WSTU=[F:POQ]STU
WCUR=[F:POH]CUR
If [F:TCU]CUR<>[F:POH]CUR
  Read [TCU] TCU0=[F:POH]CUR
  If fstat  Raz [F:TCU] : [F:TCU]CURRND=2 : Endif
Endif
WDECCUR=[F:TCU]CURRND
Return


#-----------------------------------------------------#
# Déblocage logique entête d'engagement si nécessaire #
#-----------------------------------------------------#
$DEBLOCAGE_CMM
If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Return


#####################################
# Fin après exécution du traitement #
#####################################
$TERMINE
TRA=0
If !GSERVEUR
  #----- Fermeture et affichage de la trace -----#
  If [M:DIA]TRACE=2
    Call FERME_TRACE From LECFIC : TRA=1
  Endif
Endif
Return


#######################################################
# Traitement du grisage et dégrisage des champs écran #
#######################################################
$GRISAGE
If [M:DIA]XCPYFLG=2 Diszo [DIA]CPY, XFCYFLG Else Actzo [DIA]CPY, XFCYFLG : Endif
If [M:DIA]XFCYFLG=2 Diszo [DIA]FCY          Else Actzo [DIA]FCY          : Endif
Return


#----------------------------------------------------------#
# Variables locales + ouverture des fichiers et de l'écran #
#----------------------------------------------------------#
$OUVRE
#----- Variables locales -----#
Local Char     WMSG(90),         WMSG2(90),         WMSG3(90)
Local Char     WCMMNUM(GLONVCR), WPUU   (GLONUOM),  WSTU(GLONUOM),  WCUR(GLONCUR)
Local Char     WCMMNUM2(GLONVCR)
Local Char     WPOHNUM(GLONPOH), WBPSNUM(GLONBPS),  WNUM(GLONVCR)
Local Char     CRITERE(100),     WITMREF(GLONITM)
Local Char     WCOMPTE(GLONGAC)
Local Char     WCPTANA(GLONGAC)
Local Decimal  WRATDIV(1..10), WRATMLT(1..10)
Local Integer  TBTYPLED(1..10)
Local Char     TPLAN  (GLONCOA)(1..10), TPLAN2  (GLONCOA)(1..10)
Local Char     TCOMPTE(GLONGAC)(1..10), TCOMPTE2(GLONGAC)(1..10)
Local Char     TBLED  (GLONLED)(1..10)
Local Char     TBDIE  (GLONDIE)(1..GOPTCANA)
Local Char     TBCCE  (GLONCCE)(1..GOPTCANA)
#Local Char     TBDIE2 (GLONDIE)(1..GOPTCANA)
#Local Char     TBCCE2 (GLONCCE)(1..GOPTCANA)
Local Char     WLEDGEN(GLONLED)
Local Char     WLEDANA(GLONLED)
Local Char     WDEVLED(GLONCUR)
Local Char     WCOA   (GLONCOA)
Local Char     PARAM2(10),       SYMBOL2(30)
Local Char     ID1(20)(1..3),    ID2(20)(1..3)
Local Char     TIT (50) : TIT=mess(445,197,1)
Local Date     WORDDAT, DATBUD
Local Decimal  WQTEPUU, WQTESTU, WQTEUOM, WMONTANT, WTOTQTY, WTOTLED, WTOTCUR
Local Decimal  WCUMQTEPUU, WCUMQTESTU, WCUMMONTANT, WAMTCUR, WDECCUR
Local Decimal  WDELTACUR, WDELTALED, WDELTAQTY
Local Decimal  EXERCICE, PERIODE
Local Shortint COMPTEUR, STOP, I
Local Integer  WPOPLIN, WPOQSEQ, WCHGTYP, WLINNUM, WPOHTYP
Local Integer  WPOPSEQ # Issue 90891 - 2013-07-04 by MUARN : ajout N° seq DL
Local Integer  NBENR, NBCOR, STA, OK, WSIGN, TYPORG, WI, WJ
Local Libelle  WBUDQTYFLG
Local Char     WDOCUMENT(max(GLONPOH,GLONPSH))(1..4) # Issue 90891 - 2013-07-04 by MUARN : ajout n° seq DL
Local Libelle  WMOTIF(1..2)
Local Char     WTAB_CMMNUM(GLONVCR)(200)
Local Integer  WTAB_NBLIG
Local Char     WDOSSIER(30) : WDOSSIER=nomap
# Issue 82582 - 2013-10-17 by SR :
Local Char     WFLTCMD(80)
# Issue 95891 - 2014-01-24 by SR
Local Char     WSOCIETE(GLONCPY)
#----- Ouverture des fichiers -----#
If clalev([F:CPY]) =0  Local File COMPANY    [CPY] : Endif
If clalev([F:FCY]) =0  Local File FACILITY   [FCY] : Endif
If clalev([F:PER]) =0  Local File PERIOD     [PER] : Endif
If clalev([F:CMM]) =0  Local File GCOMMIT    [CMM] : Endif
If clalev([F:CMD]) =0  Local File GCOMMITD   [CMD] : Endif
If clalev([F:CMM2])=0  Local File GCOMMIT   [CMM2] : Endif
If clalev([F:CMD2])=0  Local File GCOMMITD  [CMD2] : Endif
If clalev([F:GAC]) =0  Local File GACCOUNT   [GAC] : Endif
If clalev([F:TCO]) =0  Local File TABCOEFF   [TCO] : Endif
If clalev([F:TCU]) =0  Local File TABCUR     [TCU] : Endif
If clalev([F:CAL]) =0  Local File CPTANALIN  [CAL] : Endif
If clalev([F:GAD]) =0  Local File GAUTACED   [GAD] : Endif
Return


################################################################################
#             Actions sur champ pour gestion de l'écran PUTICMM                #
################################################################################

Subprog AV_XCPYFLG(VALEUR)
#--------------------------------------#
# Avant saisie du flag toutes sociétés #
# ------------------------------------ #
# Complément de l'initialisation des   #
# champs faite dans INIT_DIA et        #
# grisage des champs                   #
#--------------------------------------#
Variable Integer VALEUR
If varinit([M]XCPYFLG) End : Endif : # Pour n'exécuter qu'une seule fois
#----- Traitement des champs société -----#
[M]XCPYFLG=2 : VALEUR=2
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  VALEUR=1 : [M]XCPYFLG=2 : Grizo XCPYFLG
  Call INICPY([M]CPY) From CPTSUB
  Affzo CPY : If dim([M]ZCPY)>0  Affzo ZCPY : Endif
  If GNBAUZ=1 Diszo CPY : Endif
Else
  Diszo CPY
Endif
#----- Traitement des champs site -----#
If VALEUR=2
  Grizo XFCYFLG : Diszo FCY, FCYNAM
Else
  Call INIALLFCY([M]XFCYFLG,[M]CPY) From FUNUTICMM
  If mkstat
    Grizo XFCYFLG : Raz mkstat
    Call INIFCY([M]FCY,[M]CPY) From CPTSUB
    Read [F:FCY]FCY0 = [M]FCY
    If fstat : Raz [F:FCY] : Endif
    [M:DIA]FCYNAM = [F:FCY]FCYNAM
    [M]FCYNAM=[F:FCY]FCYNAM : Affzo FCY, FCYNAM
    If GNBAUZ=1 Diszo FCY, FCYNAM : Endif
  Else
    Diszo FCY, FCYNAM
  Endif
Endif
End


Subprog AM_XCPYFLG(VALEUR)
#-------------------------------------#
# Après modif du flag toutes sociétés #
#-------------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo CPY
  Call INICPY([M]CPY) From CPTSUB
  Affzo CPY : If dim([M]ZCPY)>0  Affzo ZCPY : Endif
  If GNBAUZ=1 Diszo CPY : Endif
  Call INIALLFCY([M]XFCYFLG,[M]CPY) From FUNUTICMM
  If mkstat
    Grizo XFCYFLG : Actzo FCY, FCYNAM : Raz mkstat
    Call INIFCY([M]FCY,[M]CPY) From CPTSUB
    [M]FCYNAM=[F:FCY]FCYNAM : Affzo FCY, FCYNAM
    If GNBAUZ=1 Diszo FCY, FCYNAM : Endif
  Else
    Actzo XFCYFLG
    If [M]XFCYFLG=1
      Call INIFCY([M]FCY,[M]CPY) From CPTSUB
      [M]FCYNAM=[F:FCY]FCYNAM : Affzo FCY, FCYNAM
    Endif
  Endif
Else
  [M]XFCYFLG=2 : Affzo XFCYFLG : Grizo XFCYFLG
  Effzo CPY, FCY, FCYNAM
  If dim([M]ZCPY)>0  Effzo ZCPY : Endif
  Diszo CPY, FCY, FCYNAM
Endif
End


Subprog C_CPY(VALEUR)
#------------------------------------------------------------------#
# Contrôle société : Obligatoire si flag toutes sociétés non coché #
#------------------------------------------------------------------#
Variable Char    VALEUR()
If [M]XCPYFLG<>2 & VALEUR="" mkstat=1 : End : Endif
End


Subprog AM_CPY(VALEUR)
#----------------------------------#
# Après modification de la société #
#----------------------------------#
Variable Char    VALEUR()
Call INIALLFCY([M]XFCYFLG,VALEUR) From FUNUTICMM
If mkstat
  Grizo XFCYFLG : Actzo FCY, FCYNAM : Raz mkstat
  Call INIFCY([M]FCY,VALEUR) From CPTSUB
  Affzo FCY, FCYNAM
  If GNBAUZ=1 Diszo FCY, FCYNAM : Endif
Else
  Actzo XFCYFLG
  If [M]XFCYFLG=1
    Call INIFCY([M]FCY,VALEUR) From CPTSUB
    [M]FCYNAM=[F:FCY]FCYNAM : Affzo FCY, FCYNAM
  Endif
Endif
End


Subprog AM_XFCYFLG(VALEUR)
#--------------------------------#
# Après modif du flag tous sites #
#--------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo FCY, FCYNAM
  Call INIFCY([M]FCY,[M]CPY) From CPTSUB
  If [F:FCY]FCY<>[M]FCY
    Read [FCY] FCY0=[M]FCY : If fstat  Raz [F:FCY] : Endif
  Endif
  [M]FCYNAM=[F:FCY]FCYNAM
  Affzo FCY, FCYNAM
  If GNBAUZ=1 Diszo FCY, FCYNAM : Endif
Else
  Effzo FCY, FCYNAM
  Diszo FCY, FCYNAM
Endif
End


Subprog C_FCY(VALEUR)
#-----------------------------------------------------#
# Contrôle site : Obligatoire si tous sites non coché #
#-----------------------------------------------------#
Variable Char    VALEUR()
If [M]XFCYFLG<>2 & VALEUR="" mkstat=1 : End : Endif
End


Subprog AM_FCY(VALEUR)
#---------------------#
# Après modif du site #
#---------------------#
Variable Char    VALEUR()
[M]FCYNAM=[F:FCY]FCYNAM : Affzo FCYNAM
End


#############################################
# Contrôle si tous les sites sont autorisés #
#############################################
Subprog INIALLFCY(VALEUR,SOC)
Variable Integer  VALEUR
Value    Char     SOC
Local    Integer  I, OK
If GUSRFCY(1)="\" : End : Endif
If GNBAUZ=GNBSITE : End : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If [L]SOC<>""
 OK = 1
 Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
 If [F:CPY]CPYLEGFLG=2  : # Société juridique
  For I=1 To GNBSITE
   If [L]SOC=GSOCSITE(I) & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
    OK = 0 : Break
   Endif
  Next I
 Else
  For [FGR]FGR0 Where CPY=[L]SOC
   If !find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
    OK = 0 : Break
   Endif
  Next
 Endif
Endif
If !OK
 VALEUR=1 : mkstat=2 : End : # Tous les sites de la société ne sont pas accessibles
Endif
End


###################
# Erreur en Batch #
###################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

#######################################################
# Appel du point d'entrée MAJDELTA depuis:            #
#     - le traitement FUNUTICMM (Resynchro)           #
#        WTYPMAJ = 10 Resynchronisation pré-engagement#
#        WTYPMAJ = 11 Resynchronisation engagement    #
#######################################################
$POINT_MAJDELTA
GPOINT="MAJDELTA" : Gosub ENTREE From EXEFNC
Return

