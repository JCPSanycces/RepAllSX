#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTICPT68   UTI process                                    Module CPT   #
#            correction utility
#    XXX for module :  must be replaced (GPA ACH STO ...)
#    NN  number of sequence : must be replaced (01 02 ...)
##########################################################################

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
 Read [ADS]DOSSIER=WDOSSIER
 If fstat <> 0 : Raz [F:ADS] : Endif
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("Correction") From LECFIC
 Call MAJ_UTICPT68(WDOSSIER)
 Call TEMPOFF From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
 Close Local File
Endif
End

##########################################################################
Subprog MAJ_UTICPT68(APPLI)
Value Char APPLI

Local Integer COUNT, VALMOD(20)

If APPLI=GDOSX3 : End : Endif

#----- Ouverture des tables -----#
If clalev([F:ADS])=0 : Local File =APPLI+".ADOSSIER" [ADS] : Endif
If clalev([F:AOL])=0 : Local File =APPLI+".AOBJLST"  [AOL] : Endif
Read [ADS]DOSSIER=APPLI
If fstat : Raz [F:ADS] : End : Endif
If [F:ADS]MODULE(1)<>2 : End : Endif

Call ECR_TRACE("UTICPT68 : Start of process on : "+APPLI,0) From GESECRAN

COUNT = 0
For I=0 To dim(VALMOD)-1
 VALMOD(I) = 2
Next I

Call DEBTRANS From GLOCK

Read [AOL]AOL0="GAC"
mkstat = 0
Call C_APPLI([F:ADS]DOSSIER) From VALDICO
If mkstat
 Call ECR_TRACE(GMESSAGE, -1) From GESECRAN
Else
 If clalev([F:AOL2])=0 : Local File =[F:ADS]DOSSIER+".AOBJLST"  [AOL2] : Endif
 Call ECR_TRACE("*** Update folder"-[F:ADS]DOSSIER, 0) From GESECRAN
 Trbegin [AOL2]
 Readlock [AOL2]AOL0=[AOL]ABREV
 If fstat = 0
  [F:AOL2] = [F:AOL]
  Rewrite [F:AOL2]
  If !fstat
   COUNT += 1
   Call VALID_TRT([F:ADS]DOSSIER,0,"","","","","","","","","GAC","GAC","","","","","","","","","","",VALMOD) From VALDICO
   Call VALFEN([F:ADS]DOSSIER,"GAC") From SUBAOB
  Endif
 Endif
 Commit
 Close Local File [AOL2]
Endif

Call ECR_TRACE("UTICPT68 : "+num$(COUNT)+" record(s) processed",0) From GESECRAN
End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT68 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
Call MAJ_UTICPT68(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char APPLI
Call MAJ_UTICPT68(APPLI)
End
