Subprog AS_CODPOS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(750,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CODPOS(zc) From W1DLA1
Onkey   2 Titled GBOUTS Call S_CODPOS(zc) From W1DLA1
Gosub _AFF
End

Subprog C_CODPOS(VALEUR)
Variable Char    VALEUR()
## Action POSCNTOBL
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "POSCNTOBL"
PARMSK(1) = [M]CRY
PARMSK(2) = "0"
Call S_AFF_CHAR(VALEUR,PARMSK,"POSCNTOBL","SUBPOS","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "CODPOS" : GZNUM = 16059 : Endif
Gosub _AFF
End

$AMM_CODPOS
Call AM_CODPOS(zc)
If !mkstat & GOBJET
 zoncou = "CODPOS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CODPOS(VALEUR)
Variable Char    VALEUR()
## Action CPCONT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CPCONT"
PARMSK(1) = [M]CRY
PARMSK(2) = [M]CTY
PARMSK(3) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"CPCONT","SUBPOS","") From GACTION
[M]CTY = PARMSK(2)
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "CODPOS" : GZNUM = 16059 : Endif
If !mkstat
 ## Action SELCTY2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCTY2"
 PARMSK(1) = [M]CRY
 PARMSK(2) = [M]CTY
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCTY2","SUBPOS","") From GACTION
 [M]CTY = PARMSK(2)
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CODPOS" : GZNUM = 16059 : Endif
Endif
Gosub _AFF
End

Subprog S_CODPOS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOS"
 PARMSK(1) = [M]CRY
 PARMSK(2) = [M]CTY
 PARMSK(3) = ""
 PARMSK(4) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOS","SUBPOS","") From GACTION
 [M]CTY = PARMSK(2)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CODPOS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATUNPOS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATUNPOS"
 PARMSK(1) = [M]CRY
 PARMSK(2) = [M]CTY
 PARMSK(3) = ""
 PARMSK(4) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"ATUNPOS","SUBPOS","") From GACTION
 [M]CTY = PARMSK(2)
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CTY
Onevent BEFORE_AREA Gosub AV_CTY From W1DLA1
Onevent BEFORE_INPUT Call AS_CTY(zc) From W1DLA1
Onevent CONTROL Call C_CTY(zc) From W1DLA1
Onevent AFTER_CHANGE Gosub AMM_CTY From W1DLA1
Return

Subprog IB_CTY(VALEUR)
Variable Char    VALEUR()
## Action ABOUTPLAN
Call BOUTPLAN From AVISUPLAN
Gosub _AFF
End

$AV_CTY
## Action FMTCTYPAY
Call FMTCTYPAY([M]CRY) From TRTDIV
If GFMT<>""
 Chgfmt [M]CTY(indice) With "K:"+GFMT
Else
 Chgfmt [M]CTY(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog AS_CTY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(36871,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_CTY(VALEUR)
## Action VILINI
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "VILINI"
Call S_AFF_CHAR(VALEUR,PARMSK,"INIVIL","SUBPOS","") From GACTION
GACTION = SAVACT
If mkstat=2
 [M]CTY(INDIC) = VALEUR
 Affzo CTY(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CTY(zc) From W1DLA1
Onkey   2 Titled GBOUTS Call S_CTY(zc) From W1DLA1
Gosub _AFF
End

Subprog C_CTY(VALEUR)
Variable Char    VALEUR()
## Action VILCNTOBL
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "VILCNTOBL"
PARMSK(1) = [M]CRY
PARMSK(2) = "0"
Call S_AFF_CHAR(VALEUR,PARMSK,"VILCNTOBL","SUBPOS","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "CTY" : GZNUM = 0 : Endif
Gosub _AFF
End

$AMM_CTY
Call AM_CTY(zc)
If !mkstat & GOBJET
 zoncou = "CTY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CTY(VALEUR)
Variable Char    VALEUR()
## Action VILCONT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "VILCONT"
PARMSK(1) = [M]CRY
PARMSK(2) = [M]CODPOS
PARMSK(3) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"VILCONT","SUBPOS","") From GACTION
[M]CODPOS = PARMSK(2)
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "CTY" : GZNUM = 0 : Endif
If !mkstat
 ## Action SELPOS2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOS2"
 PARMSK(1) = [M]CRY
 PARMSK(2) = [M]CODPOS
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOS2","SUBPOS","") From GACTION
 [M]CODPOS = PARMSK(2)
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CTY" : GZNUM = 0 : Endif
 If !mkstat
  ## Action AFFPOSCOD
  If !mkstat & !GIMPORT : Affzo [M]CODPOS : Endif
  If mkstat : GERR = 1 : GZONE = "CTY" : GZNUM = 0 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_CTY(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCTY
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCTY"
 PARMSK(1) = [M]CRY
 PARMSK(2) = [M]CODPOS
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCTY","SUBPOS","") From GACTION
 [M]CODPOS = PARMSK(2)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CTY(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AVISUPLAN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AVISUPLAN"
 PARMSK(1) = ""
 PARMSK(2) = [M]CRY
 PARMSK(3) = [M]CODPOS
 Call SAISIE_CHAR(VALEUR,PARMSK,"AVISUPLAN","AVISUPLAN","") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

