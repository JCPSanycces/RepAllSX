#<AdxTL>@(#)0.0.0.0 $Revision$Class Process launch
# Supervisor
## ACLA-CLASSE ## EDIRUN
# 2018-10-17 07:54:24 487

#-------------------------------------------------------#
$METHODS
$EVENTS
Case [L]AEVENT
 When "ADDLINE_AFTER"
  Case [L]CURPTH
   When "EDRD"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("NUM","$namProParent","NUM")
    this.NUM = this.APARENT.NUM
   When Default
  Endcase
 When Default
Endcase
Return

#-------------------------------------------------------#
$PROPERTIES
Local Integer ALINE
Case [L]CURPRO
 When "NUM" : Gosub PRO_NUM
Endcase
Return

#-------------------------------------------------------#
$PRO_NUM
Case [L]ARULE
 When "PROPAGATE"
  For ALINE=1 to maxtab(this.EDRD)
   If this.EDRD([L]ALINE)<>null
    this.EDRD([L]ALINE).NUM = this.NUM
   Endif
  Next
Endcase
Return



