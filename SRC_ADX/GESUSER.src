#<AdxTL>@(#)10.0.0.0 $Revision$

##############################################################
## Si appel par TRT GESUSER => Réinit variables             ##
##############################################################
Call INIGLOBVAR
End
##############################################################
##  Gestion des utilisateurs                                ##
##############################################################
## Subprog CONNECT
## Subprog DECONNECT
## Subprog CRYPT(PASSE)
##########################################
## Connexion                            ##
##########################################
Subprog CONNECT
If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
If clalev([F:AME])=0 : Local File AMETUTI   [AME] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL    [ADW] : Endif
If clalev([F:ADU])=0 : Local File ADOVALAUS [ADU] : Endif
If clalev([F:APF])=0 : Local File APROFIL   [APF] : Endif
#If adxusr="mbeinat" : GUSRNOMME = 10000 : Endif
If GUSRNOMME
 If clalev([F:AUO])=0 : Local File AUSRSOL [AUO] : Endif
Endif
Local Char    MOTPASSE(250) , PASSVIDE(250) , PARAM(250) , CHAINE(250)
Local Integer I , J , K , E , OK , MONO , VIDE , MAXCON , MAXSES , NBSES , TYPSES
Local Date    DATEXP
Local Integer NBLIG , OKCONNECT
Local Char    LIGNE(80)(1..1000)
Local Char    AAUSER(250) , APASSWD(250) , USRCLI(30)
Local Char    LCHGDAT(3)
Local Char    CTX(250) , VARIANTE(30) , EVENT(10) , OPER(10) , CLE(250) , RETOUR(1)
Local Char    CLE1(30) , CLEX(30)(1..16) , OBJET(30)
Local Integer NBCLE, AERR , SSOTYP
Local Char    AKEY(255) , MESSAG(120) , SSOCON(30) , SSOPAS(2)
#Local Char    AUTBAT(2) : #107748
Local Char    ERRCLAN(10)
Local Integer ERRAUD , ERADX
Local Char    P_ARAM(200) , NEWPASSE(24) , WEBSITE(100)
Local Char    FICHIER(GDIMFIC)
Local Integer NBOCT
Local Char    TIT(80) , TITSUF(80), TITABR(80)
Local Char    PCLI(80) , PMAI(50) , PUSR(50) , PPRO(50)
Local Integer TYPCON , USRADM
Local Integer STAT

TYPCON = 1 : # Connection standard
USRADM = 0

# Connexion avec des variables d'environnement (ça doit plus exister)

If getenv$("USER_ENTREP")<>""
 GUSER = toupper(getenv$("USER_ENTREP"))
 Read [AUS]CODUSR = GUSER
 If fstat=0
  If    date$<GDATDEB : datesyst = GDATDEB
  Elsif date$>GDATFIN : datesyst = GDATFIN
  Else                : datesyst = date$
  Endif
  MOTPASSE = getenv$("PASSE_ENTREP")
  Call CTLPAS(MOTPASSE,OK)
  If !OK
   GMENDEP = ""
#  GMESSAGE = mess(103,124,1)-GUSER : # Code utilisateur
#  GMESSAGE += "\"+mess(25,100,1) : # Mot de passe incorrect
#  CC   14/05/2012   -   Audit sécurité
   GMESSAGE=mess(233,100,1) : # Code utilisateur ou mot de passe incorrect
   ERRAUD = 1 : Gosub ERR_AUDIT
   GERR = 1 : # Pour le Workflow
   Goto FIN
  Else
   Goto CONNECT1
  Endif
 Endif
Endif

# Vérif de la langue de connexion : si connexion banalisée on choisit une langue "acceptable"
AAUSER = toupper(adxusr)
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
#Read [ADS]DOSSIER=nomap
STAT=func DOSSUB.FILL_ADS(nomap)

If STAT=1 & dim(GFUSION)>0 & GFUSION = 1
 #Fusion client :
 Local Char ISOLAN(10)

 ISOLAN = isomess

 GLANGUE = func ADS_TOOL.SEARCH_LANX3(nomap,isomess)

 #107661
 If GLANGUE<>"" & find(GLANGUE,[F:ADS]LAN(0..[F:ADS]NBRLAN-1))=0
  GLANGUE = func ADS_TOOL.SEARCH_LANRPL(nomap,GLANGUE)
  ISOLAN = func ADS_TOOL.SEARCH_ISOLAN(nomap,GLANGUE)
 Endif

 If find(GLANGUE,[F:ADS]LAN(0..[F:ADS]NBRLAN-1))=0
  # Warning -1: no lang found for the given isomess, apply the default LAN of the folder
  GLANGUE = func ADS_TOOL.GET_LANDEF(nomap)
  ISOLAN = func ADS_TOOL.SEARCH_ISOLAN(nomap,GLANGUE)
 Endif
 messname(0) = GLANGUE
 adxrob(0)   = "ECR"
 adxrob(1)   = "M"+GLANGUE
 #set cdLang in session setting returned to the client:
 Callui RETOUR="" With "UIAction="+ chr$(1)+ "SessionSettings", "cdLang="     + chr$(1)+ GLANGUE
 Callui RETOUR="" With "UIAction="+ chr$(1)+ "SessionSettings", "ADXLangIso=" + chr$(1)+ ISOLAN

Elsif STAT=1 & !find(messname(0),[F:ADS]LAN(0..[F:ADS]NBRLAN-1))
  If GBROWS=0 or AAUSER<>"ASK_"
    Call PARAM("","LANGUAGE",GLANGUE) From ADOVAL : # Langue principale du dossier
    adxrob(0)   = "ECR"
    adxrob(1)   = "M"+GLANGUE
    ERRCLAN     = messname(0)
    messname(0) = GLANGUE
    adxmbm      = adxmbm
    GMESSAGE    = ERRCLAN-":"-mess(138,124,1) : # Code langue incorrect
    Call ERREND(GMESSAGE) From GESECRAN
    ERRAUD  = 10 : Gosub ERR_AUDIT
    GERR    = 2
    GMENDEP = "" : Goto REBOOT
  Else
# On prend la langue par défaut du dossier en connexion banalisée si GLANGUE incorrect
# en mode demande User (si GLANGUE est une langue du dossier sinon on prend la 1ere)
    Call PARAM("","LANGUAGE",GLANGUE) From ADOVAL : # Langue principale du dossier
    If find(GLANGUE,[F:ADS]LAN(0..[F:ADS]NBRLAN-1))
      messname(0) = GLANGUE
    Else
      messname(0) = [F:ADS]LAN(0)
      GLANGUE     = [F:ADS]LAN(0)
    Endif
    adxrob(0) = "ECR"
    adxrob(1) = "M"+messname(0)
    adxmbm    = adxmbm
## Pour le format$(D:MMM)
    P_ARAM = mess(1,9001,1)+sigma(I=2,12,";"+mess(I,9001,1))
    Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","SetMonthList="+chr$(1)+P_ARAM
    Call TITFENP(TITABR,TIT,TITSUF) From GLOBVAR
    Titled [] nomap-TIT-TITSUF
    If !GSERVEUR
     Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","ADXWtitle="+chr$(1)+nomap-TIT-TITSUF
    Endif
    GUSER = AAUSER
    Gosub CHGUSRW
    GUSER = "ADMIN"
  Endif
Elsif filinfo(filpath("M"+messname(0),"","",nomap),0)<0
  Call PARAM("","LANGUAGE",GLANGUE) From ADOVAL : # Langue principale du dossier
  adxrob(0)   = "ECR"
  adxrob(1)   = "M"+GLANGUE
  ERRCLAN     = messname(0)
  messname(0) = GLANGUE
  adxmbm      = adxmbm
  GMESSAGE = ERRCLAN-":"-mess(138,124,1) : # Code langue incorrect
  Call ERREND(GMESSAGE) From GESECRAN
  ERRAUD  = 10 : Gosub ERR_AUDIT
  GERR    = 2
  GMENDEP = "" : Goto REBOOT
Else
  GLANGUE   = messname(0)
  adxrob(0) = "ECR"
  adxrob(1) = "M"+GLANGUE
Endif

# Vérification licence VT
# Supression serial_adonix
If GVTMOD
 APASSWD = password
# If func GLOBSUP.FICSERIAL(GPRODUIT,"",FICHIER)<>0
#  NBOCT = filinfo(FICHIER,7)
# Else
# NBOCT = 0
# Endif
# If NBOCT<>494 & 1=0 : # mb 14.9.6 Il vaut mieux activer ce contrôle après avoir modifié les licences
#  GMESSAGE = mess(182,139,1) : # Cette licence n'accepte pas ce type de connexion
#  Call ERREND(GMESSAGE) From GESECRAN
#  GERR = 2
#  GMENDEP = "" : Goto REBOOT
# Endif
Endif

# Connexion mode web via SDATAemail (adresse email)
Local Integer POSSDATA
POSSDATA=instr(1,adxctx,'Sdata-email="')
If POSSDATA<>0

# On vérifie si le user d'intégration et le password d'intégration sont OK
  GMESSAGE=""
  adxusr = tolower(AAUSER)
  Read [AUS]LOGIN = toupper(AAUSER)
  If fstat<>0
    GMESSAGE=mess(233,100,1) : # Code utilisateur ou mot de passe incorrect
    Call ERREND(GMESSAGE) From GESECRAN
    ERRAUD = 4 : Gosub ERR_AUDIT
    GERR = 6 : # Pour le Workflow
    GMENDEP = "" : Goto REBOOT
  Endif
  If [F:AUS]ENAFLG<>2
    GMESSAGE=mess(233,100,1) : # Code utilisateur ou mot de passe incorrect
# Bug 88704 - Modif pour Sdata controle pour session bridge   CC : 18/03/2013
  Elsif ([F:AUS]USRCONNECT<>2 and mod(adxtyp,8)<>4) or ([F:AUS]USRCONXTD<>2 and (mod(adxtyp,8)=4 or mod(adxtyp,8)=7))
    GMESSAGE = AAUSER-":"-mess(279,123,1) :  # Code utilisateur non autorisé pour ce type de connexion
  Endif
  If GMESSAGE<>""
    Call ERREND(GMESSAGE) From GESECRAN
    ERRAUD = 1 : Gosub ERR_AUDIT
    GERR = 3 : # Pour le Workflow
    GMENDEP = "" : Goto REBOOT
  Endif

#  Vérifie mot de passe

  APASSWD=password
  If toupper(left$(APASSWD,6))="CRYX3:"
    MOTPASSE = right$(APASSWD,7)
    If len(MOTPASSE)=24 : # Nouveau cryptage
      Call VARPSE(MOTPASSE)
      Call CTLPAS(MOTPASSE,OK)
    Else
      OK = ([F:AUS]PASSE=MOTPASSE) : # mb 27.8.2 Ancien cryptage
    Endif
  Elsif toupper(left$(APASSWD,6))="CRYPT:"
    MOTPASSE = right$(APASSWD,7)
    NEWPASSE = ""
    Call DECRYPTO(MOTPASSE,NEWPASSE)
    Call CTLPAS(NEWPASSE,OK)
  Else
    MOTPASSE = left$(APASSWD,10)
    Call CTLPAS(MOTPASSE,OK)
  Endif
  If !OK
    GMESSAGE=mess(233,100,1) : # Code utilisateur ou mot de passe incorrect
    Call ERREND(GMESSAGE) From GESECRAN
    ERRAUD = 4 : Gosub ERR_AUDIT
    GERR = 6 : # Pour le Workflow
    GMENDEP = "" : Goto REBOOT
  Endif

# On recherche un user associé à l'e-mail passé
# Si trouvé OK
# Si pas trouvé si ASDAUSFAC=2 on garde le user d'intégration
# Si ASDAUSFAC<>2 on sort en erreur

  Local Char MAILSDATA(200),W_PARSD(250)
  Call PARAM("","ASDAUSFAC",W_PARSD) From ADOVAL

#   ctx=    Sdata-email="claude.cora@sage.com"  si pas d'email on ne met rien dans ctx
  Local Integer POSSDATA1
#Infbox(num$(W_PARSD)-adxctx)
  POSSDATA=instr(1,adxctx,'Sdata-email')
  POSSDATA1=instr(POSSDATA+13,adxctx,'"')
  If POSSDATA1>POSSDATA
    MAILSDATA=toupper(mid$(adxctx,POSSDATA+13,POSSDATA1-POSSDATA-13))
  Endif
  If POSSDATA1<POSSDATA or MAILSDATA=""
    If W_PARSD<>"2"
      GMESSAGE = mess(99,130,1) : # Aucun utilisateur correspond à cette adresse
      Call ERREND(GMESSAGE) From GESECRAN
      GERR = 2 : GMENDEP = "" : Goto REBOOT
    Else
      Goto FINCONSDATA
    Endif
  Endif
#Infbox('mail'-MAILSDATA)
  K=0
  For [AUS] Where toupper(ADDEML)=MAILSDATA
    K += 1
    Break 1
  Next AUS
  If !K and W_PARSD<>"2"
    GMESSAGE = mess(99,130,1) : # Aucun utilisateur correspond à cette adresse
    Call ERREND(GMESSAGE) From GESECRAN
    GERR = 2 : GMENDEP = "" : Goto REBOOT
  Elsif K>1     : # Non utilisé pour l'instant
    GMESSAGE = func AFNC.MES2(mess(98,130,1),num$(K),MAILSDATA) : # Il y a $1$ utilisateurs qui utilisent l'adresse $2$
    Call ERREND(GMESSAGE) From GESECRAN
    GERR = 2 : GMENDEP = "" : Goto REBOOT
  Else
    If [F:AUS]ENAFLG<>2 or [F:AUS]USRCONNECT<>2
      # Code utilisateur non autorisé pour ce type de connexion
      GMESSAGE = mess(279,123,1)
      Call ERREND(GMESSAGE) From GESECRAN
      GERR = 2 : GMENDEP = "" : Goto REBOOT
    Endif
    Read [AUS]LOGIN = [F:AUS]LOGIN
    adxusr = tolower([F:AUS]LOGIN)
  Endif
$FINCONSDATA
  password = ""
  GUSER = [F:AUS]USR
  AAUSER=[F:AUS]LOGIN
  GLOGIN = tolower([F:AUS]LOGIN)
  Local Integer SDATAEMAIL
Endif

# Connexion de type SSO old (OPAC)

If AAUSER="SSO_"
 Onerrgo ERRSSO
 AKEY = password
 If left$(password,6)="CRYPT:"
  Call DECRYPTO(password,AKEY)
 Endif
 If left$(password,6)="CRYX3:"
  K = instr(1,adxctx,"sso=")
  I = instr(K+1,adxctx,";")
  AKEY = mid$(adxctx,K+4,I-K-4)
 Endif
 GPE = 0
#CHECK UNUSED_BEGIN
 GPOINT = "SSOCONNECT" : Gosub ENTREE From EXEFNC
#CHECK UNUSED_END
 If GPE=0
  Call SSOPAC(AKEY,AAUSER,APASSWD,AERR) From ASSOCODE
 Endif
 Onerrgo
 If AERR=2
#  GMESSAGE = mess(24,100,1) : # Code utilisateur incorrect
#  CC   14/05/2012   -   Audit sécurité
   GMESSAGE=mess(233,100,1) : # Code utilisateur ou mot de passe incorrect
  Call ERREND(GMESSAGE) From GESECRAN
  GERR = 2 : GMENDEP = "" : Goto REBOOT
 Endif
 password = APASSWD
Endif

# Connexion de type NTLM over http en Web

CHAINE = "~NTLM~"
If toupper(left$(AAUSER,len(CHAINE)))=CHAINE & GBROWS
 Onerrgo ERRSSO
 If dim(GSSODOM)<1
  # Utilisé pour rechercher le paramétrage LDAP correspondant au domaine (trt ASSOCODE)
  Global Char GSSODOM(250)
 Endif
 Local Char    NTLMU(250) , NTLM_DOMAIN(200), NTLM_COMPUT(200)
 Local Char    RETNTLM(250)(1..3)
 Local Integer LL1 , LL2 , LL3
 Callui RETNTLM="" With "UIAction="+chr$(1)+"SessionSettings","NtlmUser="+chr$(1)+ NTLMU
 # RETNTLM doit être sous la forme ~userreseau~domaine~hostname
 LL1 = instr(1,RETNTLM(2),"~")
 If LL1
  LL2 = instr(LL1+1,RETNTLM(2),"~")
  If LL2
   AAUSER = seg$(RETNTLM(2),LL1+1,LL2-1)
   LL3 = instr(LL2+1,RETNTLM(2),"~")
   If LL3
    GSSODOM = seg$(RETNTLM(2),LL2+1,LL3-1)
    NTLM_COMPUT = right$(RETNTLM(2),LL3+1)
   Endif
  Endif
 Endif
 #LL1 = instr(1,RETNTLM(2),"~")
 #LL2 = instr(LL1+1,RETNTLM(2),"~")
 #If LL2>LL1 and LL2<>0
 # AAUSER = mid$(RETNTLM(2),LL1+1,LL2-LL1-1)
 #Endif
 #LL1 = instr(LL2+1,RETNTLM(2),"~")
 #If LL1>LL2 and LL2<>0
 # GSSODOM = mid$(RETNTLM(2),LL2+1,LL1-LL2-1)
 #Endif
 #LL2 = instr(LL1+1,RETNTLM(2),"~")
 #If LL2>LL1 and LL2<>0
 # NTLM_COMPUT = mid$(RETNTLM(2),LL1+1,LL2-LL1-1)
 #Endif
 Onerrgo
 APASSWD = ""
 password = APASSWD
 TYPCON = 2 : # Ntlm
 SSOCON = ""
 Call PARAM("","SSOCONNECT",SSOCON) From ADOVAL
 Read [AUS]LOGIN = toupper(AAUSER)
 If fstat=0 and dim([F:AUS]WITHOUTLDAP)>0 and [F:AUS]WITHOUTLDAP=2     :# 90850 CC  01/07/2013
  USRADM = 1 : # Pas de contrôle LDAP pour certains utilisateurs (type connexion consultants)
 Endif
 If SSOCON<>"2" or USRADM=1     :#  Si la connexion à LDAP n'est pas activée on passe par la boite de connexion
  Global Integer CONFUSER : CONFUSER=1
  Global Char ASK_USER(30) : ASK_USER=AAUSER
  TYPCON=0
 Endif
Endif

# Connexion mode web via SSO sage (adresse email)

CHAINE = "~SSOSage~"
If left$(AAUSER,len(CHAINE))=CHAINE
 AAUSER = right$(AAUSER,len(CHAINE)+1)
 K = instr(1,AAUSER,"~")
 If K
  AAUSER = left$(AAUSER,K-1)
 Endif
 K = 0
 For [AUS] Where toupper(ADDEML)=toupper(AAUSER)
  K += 1
  CHAINE = [F:AUS]LOGIN
 Next AUS
 If !K
  GMESSAGE = AAUSER-":"-mess(99,130,1) : # Aucun utilisateur correspond à cette adresse
  Call ERREND(GMESSAGE) From GESECRAN
  GERR = 2 : GMENDEP = "" : Goto REBOOT
 Elsif K>1
  GMESSAGE = func AFNC.MES2(mess(98,130,1),num$(K),AAUSER) : # Il y a $1$ utilisateurs qui utilisent l'adresse $2$
  Call ERREND(GMESSAGE) From GESECRAN
  GERR = 2 : GMENDEP = "" : Goto REBOOT
 Else
  AAUSER = CHAINE
  adxusr = tolower(AAUSER)
  Read [AUS]LOGIN = toupper(AAUSER)
  APASSWD = [F:AUS]NEWPAS
  If APASSWD<>""
   Call VARPSE(APASSWD) From GESUSER
  Endif
  password = APASSWD
  TYPCON = 3 : # SSO sage
 Endif
Endif

# Si connection avec user banalisé on propose la boite de connexion

If dim(ASK_PASS)>0 : Kill ASK_PASS : Endif
If dim(ASK_LANG)>0 : Kill ASK_LANG : Endif
If dim(ASK_DATE)>0 : Kill ASK_DATE : Endif
If AAUSER="ASK_"
 Global Integer CONFUSER
Endif

#------------------------------------#
$CONFUSER:
If dim(CONFUSER)>0
  Raz GMESSAGE
#   CC 08/01/2007      ---  On informe le client d'arrêter le splash
      Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","Splash="+chr$(1)+ "off"
#

 Callui PARAM="" With "UIAction="+chr$(1)+"Sethangup"
&                   , "UITimehangup1="+chr$(1)+"120"
&                   , "UITimehangup2="+chr$(1)+"30"

  Call AUSER From AUSER
  AAUSER  = toupper(ASK_USER)
  APASSWD = ASK_PASS
  password = APASSWD
  If dim(ASK_TYPPAG)=1
    If ASK_TYPPAG=2
      Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","pagetype="+chr$(1)+ "HTML"
    Endif
    Kill ASK_TYPPAG
  Endif
Endif

#  Changement de langue par l'écran de connexion banalisé

If dim(ASK_LANG)>0
  If GLANGUE<>ASK_LANG
    GLANGUE = ASK_LANG
    adxrob(0) = "ECR"
    adxrob(1) = "M"+GLANGUE
    messname(0)=GLANGUE
    adxmbm=adxmbm
## Pour le format$(D:MMM)
    P_ARAM = mess(1,9001,1)+sigma(I=2,12,";"+mess(I,9001,1))
    Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","SetMonthList="+chr$(1)+P_ARAM
    Call TITFENP(TITABR,TIT,TITSUF) From GLOBVAR
    Titled [] nomap-TIT-TITSUF
    If !GSERVEUR
     Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","ADXWtitle="+chr$(1)+nomap-TIT-TITSUF
    Endif
  Endif
  Kill ASK_LANG
Endif

#  Connexion de type SSO new. (Vinci)
#  On teste l'existence et la valeur du paramètre ASSOCON Si 2 on est en SSO
SSOCON = ""
Call PARAM("","SSOCONNECT",SSOCON) From ADOVAL
If dim(GSSODOM)>0 : SSOCON="2" : Endif

K = (SSOCON>="2" & (GBROWS=0 or (GBROWS=1 and TYPCON=2))) : # Interactif C/S ou Connexion NTLM
GPOINT = "SETSSOCONNECT" : Gosub ENTREE From EXEFNC : # Non documenté
If K
 # USRADM = 0
 If dim([F:AUS]LOGIN)>0
  Read [AUS]LOGIN = toupper(AAUSER)
  If !fstat & [F:AUS]USR=GSUPER
   USRADM = 1 : # Pas de contrôle LDAP pour l'utilisateur ADMIN
  Elsif fstat=0 and dim([F:AUS]WITHOUTLDAP)>0 and [F:AUS]WITHOUTLDAP=2    :# 90850 CC  01/07/2013
   USRADM = 1 : # Pas de contrôle LDAP pour certains utilisateurs (type connexion consultants)
  Endif
 Endif
 If !USRADM
  Onerrgo ERRSSO
  If !GBROWS
   APASSWD = password
  Endif
  If left$(password,6)="CRYPT:"
   Call DECRYPTO(password,APASSWD)
  Endif
  Raz AERR , MESSAG , GPE
  GPOINT = "SSOCONNECT" : Gosub ENTREE From EXEFNC
  If GPE=0
   Call SSO(AAUSER,APASSWD,MESSAG,TYPCON,SSOTYP,AERR) From ASSOCODE
  Endif
  Onerrgo
  If AERR
   If MESSAG=""
    MESSAG = mess(231,100,1) : # Connexion refusée (contrôle annuaire)
    If MESSAG="" : MESSAG = "LDAP" : Endif
   Endif
   Call ERREND(MESSAG) From GESECRAN
   GERR = 2 : GMENDEP = "" : Goto REBOOT
  Endif
 Endif
Endif

# Récup du code utilisateur

Raz GMESSAGE
If dim([F:AUS]LOGIN)>0
 Read [AUS]LOGIN = toupper(AAUSER)
#Infbox("APRESSSO:"+AAUSER+":"+num$(fstat)+":")

 If !fstat
  GUSER = [F:AUS]USR
  GLOGIN = tolower([F:AUS]LOGIN)
  If adxusr<>GLOGIN
   adxusr = GLOGIN
   Gosub CHGUSRW
  Endif
 Elsif mod(adxtyp,8)=2 and GBROWS=1    #  CC 23/03/2005 Bug 29261
  GUSER = AAUSER
  Read [AUS]CODUSR = GUSER
  If fstat
  # GMESSAGE = GUSER-mess(141,100,1) : # Code utilisateur inexistant
   #  CC   14/05/2012   -   Audit sécurité
   GMESSAGE=mess(233,100,1) : # Code utilisateur ou mot de passe incorrect
  Else
   GLOGIN = tolower([F:AUS]LOGIN)
   If adxusr<>GLOGIN
    adxusr = GLOGIN
    Gosub CHGUSRW
   Endif
  Endif
 Else
#  GMESSAGE = AAUSER-":"-mess(134,139,1) : # Login inexistant
#  CC   14/05/2012   -   Audit sécurité
   GMESSAGE=mess(233,100,1) : # Code utilisateur ou mot de passe incorrect
 Endif
Else
 GUSER = AAUSER
 GLOGIN = tolower(GUSER)
 Read [AUS]CODUSR = GUSER
 If fstat
#  GMESSAGE = GUSER-mess(141,100,1) : # Code utilisateur inexistant
#  CC   14/05/2012   -   Audit sécurité
   GMESSAGE=mess(233,100,1) : # Code utilisateur ou mot de passe incorrect
 Endif
Endif

# Utilisateur actif et autorisé à se connecter

If GMESSAGE=""
 If [F:AUS]ENAFLG<>2
#   GMESSAGE = AAUSER-":"-mess(24,100,1) : # Code utilisateur incorrect
   #  CC   14/05/2012   -   Audit sécurité
   GMESSAGE=mess(233,100,1) : # Code utilisateur ou mot de passe incorrect
# Bug 88704 - Modif pour Sdata controle pour session bridge   CC : 18/03/2013
 Elsif ([F:AUS]USRCONNECT<>2 and mod(adxtyp,8)<>4) or ([F:AUS]USRCONXTD<>2 and (mod(adxtyp,8)=4 or mod(adxtyp,8)=7))
   GMESSAGE = AAUSER-":"-mess(279,123,1) :  # Code utilisateur non autorisé pour ce type de connexion
 Endif
Endif

If GMESSAGE<>""
 If dim(CONFUSER)>0 and CONFUSER<2
   CONFUSER+=1
   Call ERREUR(GMESSAGE) From GESECRAN
   ERRAUD = 1 : Gosub ERR_AUDIT
   GERR = 3 : # Pour le Workflow
   Goto CONFUSER
 Else
   Call ERREND(GMESSAGE) From GESECRAN
   ERRAUD = 1 : Gosub ERR_AUDIT
   GERR = 3 : # Pour le Workflow
   GMENDEP = "" : Goto REBOOT
 Endif
Endif

# Utilisateurs nommés

If GUSRNOMME & mod(adxtyp,8)=1

 OK = 0

 # Retour workflow

 If (adxctx<>"" & adxtyp=1) or (adxtyp=9 and instr(1,adxctx,"wkf=")<>0)
# Il faut remplacer par un test sur les connections en session primaire. La les Web services sont comptés  ***** A FAIRE
# Call USER_NBCON(tolower(GLOGIN),1,NBSES) From PSADX
  Call USER_CONNECT(tolower(GLOGIN),nomap,NBSES) From PSADX
  If NBSES>0 : # Déjà connecté en session primaire
   MAXSES=0
   #Call NOMBRA(5,MAXSES) From GLOCK : # Nb possible de sessions secondaires
   Call USER_NBCON("",2,NBSES) From PSADX : # Nb de sessions secondaires ouvertes
   If NBSES>=MAXSES : # On ouvre une session primaire
    OK = 1
   Else : # On transforme la session en session scondaire
    Onerrgo ERADX
    Case adxtyp
     When 1 : Assign "adxses" With 2  : OK = 1 : # C/S
     When 9 : Assign "adxses" With 10 : OK = 1 : # Web
    Endcase
    Onerrgo
    If ERADX : OK = 0 : Endif
   Endif
  Endif
 Endif

 # Synchro Outlook

 If adxtyp=17 : # Connexion client .Net
# Il faut remplacer par un test sur les connections en session primaire. La les Web services sont comptés  ***** A FAIRE
# Call USER_NBCON(tolower(GLOGIN),1,NBSES) From PSADX
  Call USER_CONNECT(tolower(GLOGIN),nomap,NBSES) From PSADX
  If NBSES>0 : # Déjà connecté en session primaire
   MAXSES=0
   #Call NOMBRA(5,MAXSES) From GLOCK : # Nb possible de sessions secondaires
   Call USER_NBCON("",2,NBSES) From PSADX : # Nb de sessions secondaires ouvertes
   If NBSES>=MAXSES : # On ouvre une session primaire
    OK = 1
   Else : # On transforme la session en session scondaire
    Onerrgo ERADX
    Assign "adxses" With 18  : OK = 1
    Onerrgo
    If ERADX : OK = 0 : Endif
   Endif
  Endif
 Endif

 If nbrecord([AUO])=0
  Call RECAUO From ARECAUO
 Endif
 If !OK
  MESSAG = ""
  Call CONNECT_NOMME(MESSAG,GUSER)
  If MESSAG<>""
   Call ERREND(MESSAG) From GESECRAN
   GERR = 3 : GMENDEP = "" : Goto REBOOT
  Endif
 Endif
Endif

# Inscription licence

GIDENT = format$("K:5X",GUSER)+num$(adxuid(1))

# Nb maximum de sessions par utilisateur

MAXSES = 0
TYPSES = mod(adxtyp,8)
#109897
If GUSER<>GSUPER & adxtyp<>34
 Read [ADU]ADU0 = GUSER;"MAXSES"+num$(TYPSES)
 If !fstat
  MAXSES = val([F:ADU]VALEUR)
 Else
  Read [ADW]ADW0 = "";"";"MAXSES"+num$(TYPSES)
  If !fstat
   MAXSES = val([F:ADW]VALEUR)
  Endif
 Endif
Endif
If MAXSES<>0
 #118292
 Local Integer NBSESSUSR25:NBSESSUSR25 = 0
 If TYPSES=1
 Call NBCON_APPNOWEB_USER(GLOGIN,nomap,TYPSES,NBSES) From PSADX
 #Call NBCON_APP_USER_ADXTYP(GLOGIN,nomap,25,NBSESSUSR25) From PSADX
 Else
 Call NBCON_APP_USER(GLOGIN,nomap,TYPSES,NBSES) From PSADX
 Endif
 If NBSES>MAXSES | NBSESSUSR25>MAXSES
  GMESSAGE = mess(116,133,1)+"\("+num$(max(0,MAXSES)) : # Nb maximum de sessions dépassé
  GMESSAGE -= mess(117,133,1)-mess(TYPSES,924,1)+")" : # Session(s)
  Call ERREND(GMESSAGE) From GESECRAN
  ERRAUD = 2 : Gosub ERR_AUDIT
  GERR = 4 : # Pour le Workflow
  GMENDEP = "" : Goto FIN
 Endif
Endif

# 99855 Connection using fat client should not be possible unless sophia_gaillard file exists
# in the folder directory or product code is different from 1 (X3).
# 99970  Add managment of GESW32 script : : # & (filinfo(filpath("","sophia_gaillard",""),0)>0)=0
If find(adxtyp,1,9)>0 & GPRODUIT=0 & !GSERVEUR  & (dim(GFUSION)>0 & GFUSION = 0)
 OK =0
 If !OK & adxmac(0)="" & (
& toupper(adxmac(-1))=toupper("ayvqsuiviprd")
& or toupper(adxmac(-1))=toupper("ayvqsuiviprd.sagefr.adinternal.com")
&) : # & or adxmother="SYDEV"
  OK =1
 Endif
 If !OK
  Onerrgo RIEN
  OK = func GESW32.ISVALID
  Onerrgo
 Endif
 If !OK
  # La connexion à cette application au moyen du client Safe X3 V1 est interdite
  GMESSAGE = mess(233,124,1)
  Call ERREND(GMESSAGE) From GESECRAN
  ERRAUD = 2 : Gosub ERR_AUDIT
  GERR = 4 : # Pour le Workflow
  GMENDEP = "" : Goto FIN
 Endif
Endif

# Bidouilles pour connexion en développement
OKCONNECT = 1
Gosub BIDOUILLES
If !OKCONNECT
 GMENDEP = "" : Goto REBOOT
Endif

# Avertissement pour la vérification du passage de la moulinette x3 130/140 texte -> clob

Call PARAM("","BLOB140",PARAM) From ADOVAL
If PARAM=""
 Call PARAM("","TEXCLOB140",PARAM) From ADOVAL
Endif
If PARAM<>""
 Call MESSAGE(mess(181,115,1)) From GESECRAN
 # Vous devez exécuter les procédures de transformations des textes en clob avant d'utiliser l'application
Endif

# Nb maximum d'essais pour le password

Call PARAM("","NBRCON",PARAM) From ADOVAL
MAXCON = val(PARAM)
If MAXCON<>0 & [F:AUS]NBRCON>=MAXCON
 GMESSAGE = mess(103,124,1)-GUSER : # Code utilisateur
 GMESSAGE += "\"+mess(153,124,1) : # Connexion impossible
 GMESSAGE += "\"+mess(113,133,1)-"("+num$(MAXCON)+")" : # Nombre d'essais dépassés ()
 Call ERREND(GMESSAGE) From GESECRAN
 ERRAUD = 3 : Gosub ERR_AUDIT
 GERR = 5 : # Pour le Workflow
 GMENDEP = "" : Goto REBOOT
Endif

# Contrôle du mot de passe

APASSWD = password

#  Pour ouverture session secondaire en Web avec le bon code langue
If GBROWS=1 and mod(adxtyp,8)=2
 Callui RETOUR="" With "UIAction="+ chr$(1)+ "SessionSettings", "lang="     + chr$(1)+ GLANGUE
Endif

# Check of the web server versio and WWEBVERSION<>"232"
Local Integer WWEBVERSION,K
If adxtyp=12
 Onerrgo ERRWEB
 Local Char WWWEBVERSION(50)
 Getui WWWEBVERSION="" With "WebVersion"
 K = instr(1,WWWEBVERSION,"=")
 If K
  WWWEBVERSION= right$(WWWEBVERSION,K+2)
  If len(WWWEBVERSION)>=3
   WWWEBVERSION = left$(WWWEBVERSION,3)
   WWEBVERSION = val(WWWEBVERSION)
  Endif
 Endif
 Onerrgo
Endif

# On ne contrôle pas le mot de passe dans les cas suivants :
# * session secondaire (find(adxtyp,2,10)
# * connection de type SSO sécurisé (SSOTYP<>2)
# * client fusion (GFUSION=1)
# * dim(SDATAEMAIL)<0 (??)
# If !find(adxtyp,2,10) and SSOTYP<>2 and dim(SDATAEMAIL)<0
# 109396 ne pas controler adxtyp=30 eclispse en http
# 109419  ne pas controler adxtyp=20 web services V9
If !find(adxtyp,2,10,20,30) and SSOTYP<>2 and (dim(GFUSION)<=0 or GFUSION<>1) and dim(SDATAEMAIL)<0 and WWEBVERSION<232
 If toupper(left$(APASSWD,6))="CRYX3:"
  MOTPASSE = right$(APASSWD,7)
  If len(MOTPASSE)=24 : # Nouveau cryptage
   Call VARPSE(MOTPASSE)
   Call CTLPAS(MOTPASSE,OK)
  Else
   OK = ([F:AUS]PASSE=MOTPASSE) : # mb 27.8.2 Ancien cryptage
  Endif
 Elsif toupper(left$(APASSWD,6))="CRYPT:"
  MOTPASSE = right$(APASSWD,7)
  NEWPASSE = ""
  Call DECRYPTO(MOTPASSE,NEWPASSE)
  Call CTLPAS(NEWPASSE,OK)
 Else
  MOTPASSE = left$(APASSWD,10)
  Call CTLPAS(MOTPASSE,OK)
 Endif
 If !OK
  Call CTLPAS(PASSVIDE,VIDE)
  If MOTPASSE=PASSVIDE
   GMESSAGE = mess(100,100,1) : # Vous devez saisir un mot de passe
  Elsif MAXCON<>0 & GUSER<>GSUPER
   Call UPD_NBCON_AUS
   Read [AUS]CODUSR = GUSER
 #  GMESSAGE = mess(25,100,1) : # Mot de passe incorrect
   #  CC   14/05/2012   -   Audit sécurité
   GMESSAGE=mess(233,100,1) : # Code utilisateur ou mot de passe incorrect
   GMESSAGE -= "("+mess(114,133,1)-num$([F:AUS]NBRCON)+"/"+num$(MAXCON)+")" : # essai x/y
   If [F:AUS]NBRCON>=MAXCON
    GMESSAGE += "\"+mess(153,124,1) : # Connection impossible
   Endif
  Else
#   GMESSAGE = mess(25,100,1) : # Mot de passe incorrect
   #  CC   14/05/2012   -   Audit sécurité
   GMESSAGE=mess(233,100,1) : # Code utilisateur ou mot de passe incorrect
  Endif
  If GMESSAGE=""     : #  CC 14/05/2012
   GMESSAGE = mess(103,124,1)-GUSER+"\"+GMESSAGE : # Code utilisateur
  Endif
  GPOINT = "UCONNECT" : Gosub ENTREE From EXEFNC : # mb 20.4.10 demande 63385

  If dim(CONFUSER)>0 and CONFUSER<2
    CONFUSER+=1
    Call ERREUR(GMESSAGE) From GESECRAN
    ERRAUD = 4 : Gosub ERR_AUDIT
    GERR = 6 : # Pour le Workflow
    Goto CONFUSER
  Else
    Call ERREND(GMESSAGE) From GESECRAN
    ERRAUD = 4 : Gosub ERR_AUDIT
    GERR = 6 : # Pour le Workflow
    GMENDEP = "" : Goto REBOOT
  Endif
 Endif
Endif

Onerrgo RIEN
password = "" : # Pour ne pas le voir en calculette!!
Onerrgo

## If user tries to login with a provisionnel password, ask for a change
If !GBROWS and dim([F:AUS]FLGPASPRV)>=1 and [F:AUS]FLGPASPRV = 2
 Call ERREUR(mess(106,130,1)) From GESECRAN : # Vous devez modifier votre mot de passe provisoire
 Call PASSE From PASSE
 If GSTATUT<>GSTAOK
  ERRAUD = 12 : Gosub ERR_AUDIT
  GERR = 13  : # Pour le Workflow
  GMENDEP = "" : Goto FIN
 Endif
Endif

