## Autorisation de changement de date à la connexion

If dim(CONFUSER)>0 : Kill CONFUSER : Endif

If dim(ASK_DATE)=1
  datesyst=ASK_DATE
  Kill ASK_DATE
Endif
Call PARAMUTIL("CHGDAT",LCHGDAT,GUSER,"") From SUBAUS
If val(LCHGDAT)<>2
 If datesyst<>date$
  Call MESSAGE(mess(56,139,1)-":"-format$("D:"+GFMDAT4,date$)) From GESECRAN
  # La date d'entrée ne peut pas être modifiée
 Endif
 datesyst = date$
Endif
If datesyst<GDATDEB
 datesyst = GDATDEB
Elsif datesyst>GDATFIN
 # Attention, la date de connexion logique n'est pas égale à la date demandée à la connexion
 # Le paramètre ENDDAT n'autorise pas les connexions à une date logique supérieure au
 Call MESSAGE(mess(202,133,1)+"\"+mess(203,133,1)-format$("D:"+GFMDAT,GDATFIN)) From GESECRAN
 datesyst = GDATFIN
Endif

Gosub CONNECT_SYRACUSE

