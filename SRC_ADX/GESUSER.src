#--------------------------------------------------------------------#

$CONNECT1
If GUSER=GSUPER | [F:AUS]PRFMEN=GSUPER
 GMENDEP = GSUPER
Else
 E=0
 If [F:AUS]PRFMEN=""
  Read [AME]AME0 = [F:AUS]CODMET
  Read [APF]CODPRF = 0;[F:AME]PRFMEN
  GMENDEP = [F:AME]PRFMEN
 Else
  Read [APF]CODPRF = 0;[F:AUS]PRFMEN
  GMENDEP = [F:AUS]PRFMEN
 Endif
 If fstat | [F:APF]MENDEP=""
  GMESSAGE = mess(10,130,1) : # Pas de menu de départ, connexion impossible
  Call ERREND(GMESSAGE) From GESECRAN
  ERRAUD = 5 : Gosub ERR_AUDIT
  GERR = 7 : # Pour le Workflow
  GMENDEP = "" : Goto FIN
 Endif
Endif

# Variables globales de l'utilisateur

GOK = 1
Call INIGLOBVAR
If GOK<1
 ERRAUD = 11 : Gosub ERR_AUDIT
 GERR = 8 : # Pour le Workflow
 GMENDEP = "" : Goto FIN
Endif

If func APRODUCT.AGETRELEASESUP()>="15v.002"
 Call NEW_MENU
Else
 Call MENU_DEBUG
Endif

# Vérif nb d'utilisateurs pour le profil

Gosub VERF_USER
If !OK
 ERRAUD = 6 : Gosub ERR_AUDIT
 GERR = 9 : # Pour le Workflow
 GMENDEP = "" : Goto FIN
Endif

#107271
#Verif si dossier histo doit être revalidé
Local Char WCHAMAJDOSREF(50),WCHDOSREF(50)
WCHDOSREF=func DOSSUB.PARENTHISTFOLD(nomap)
If WCHDOSREF<>""
 Call GETPARHIS(nomap,"AMAJDOSREF",WCHAMAJDOSREF) From SUBADS
 If val(WCHAMAJDOSREF)<>0
  #Attention: le dossier de référence $1$ a été modifié
  #La validation de dossier doit être lancée sur le dossier $1$
  Call MESSAGE(func AFNC.MES1(mess(289,125,1),WCHDOSREF)+chr$(10)+func AFNC.MES1(mess(290,125,1),nomap)) From GESECRAN
 Endif
Endif

# Vérif si le dossier n'est pas en mono, en revalidation ou en sauvegarde

#107271
Local Char WCHMONO(50)
#Read [ADW]ADW0 = "";"";"MONO"
#MONO = val([F:ADW]VALEUR)
If func DOSSUB.ISHISTFOLD(nomap)
 Call GETPARHIS(nomap,"MONO",WCHMONO) From SUBADS
Else
 Call GETPAR(nomap,"MONO",WCHMONO) From SUBADS
Endif
MONO=val(WCHMONO)
If MONO<>0
 # nbruser=1 C'est moi qui suis en train de rentrer !!
 # Mais il peut y avoir qqn qui travaille sur le dossier
 # par le menu "Autres fonctions" (Superviseur)
 #107807 use CHECK_MONO instead of nbruser
 #If GPROFIL=GSUPER & nbruser=1 & MONO=1
 If MONO=1 & GPROFIL=GSUPER & func ACONTEXT_CMET.CHECK_MONO(nomap,GLOGIN)=1
  Call MESSAGE(mess(151,124,1)) From GESECRAN : # Vous êtes en mode mono-utilisateur
  # MONO>1 Une opération a été lancée sur le dossier
  # (A partir du dossier OU du menu "Autres fonctions")
  # 1-) Soit, elle est en cours...
  # 2-) Soit, elle s'est mal terminée !!
  #     (un déverrouillage dossier s'impose alors)
 Elsif GHYPER=0 | MONO>1
  # Connection impossible
  Case MONO
   When 2       : GMESSAGE = mess(146,124,1) : # Modification du dossier en cours
   When 3       : GMESSAGE = mess(147,124,1) : # Sauvegarde du dossier en cours
   When 4       : GMESSAGE = mess(148,124,1) : # Resynchronisation en cours
   When 5       : GMESSAGE = mess(149,124,1) : # Remise à zéro en cours
   When Default : GMESSAGE = mess(153,100,1) : # Le dossier est en mode mono
  Endcase
  GMESSAGE += "\"+mess(153,124,1) : # Connexion impossible
  Call ERREND(GMESSAGE) From GESECRAN
  ERRAUD = 7 : Gosub ERR_AUDIT
  GERR = 10 : # Pour le Workflow
  GMENDEP = "" : Goto FIN
 Endif
Endif

If nomap<>adxmother(1) & filinfo(filpath(adxrob(1),GMENDEP,"mnu"),0)<0
 GMESSAGE = GMENDEP-':'-mess(154,124,1) : # Menu inexistant
 Call ERREND(GMESSAGE) From GESECRAN
 ERRAUD = 8 : Gosub ERR_AUDIT
 GERR = 11 : # Pour le Workflow
 GMENDEP = ""
Endif
If GMENDEP="" : Goto FIN : Endif

GPOINT = "SCONNECT" : Gosub ENTREE From EXEFNC : # mb 8.4.4 Demande no 22055
If GMENDEP=""
 ERRAUD = 9 : Gosub ERR_AUDIT
 Goto FIN
Endif

