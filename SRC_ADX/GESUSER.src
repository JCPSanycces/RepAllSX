##########################################
## Lock d'un symbole lié au profil      ##
##########################################
Subprog LCK_PROFIL(OK,NBUSR)
Variable Integer OK
Variable Integer NBUSR
Local Integer I
GLCKPRF = 0
Local File ADOVAL [ADW]
Read [ADW]ADW0 = "";"";"USR"+num$(GTYPPRF)
If fstat or val([F:ADW]VALEUR)=0
 OK = 1 : End
Endif
NBUSR = val([F:ADW]VALEUR)
OK = 0
Gosub LCK
End

$NEWLCK
Local Char    CODPRF(30)
Local File APLLCK [ALK]
# mb 14.9.10 Pour éviter les tentatives de lock infructueuses
# mb 13.10.10 Ne fonctionne pas parce qu'il y a des cas où les unlock ne sont pas fait
For I=1 To NBUSR
 CODPRF = "PROFIL"+num$(GTYPPRF)+format$("N0:4#",I)
 Read [ALK]LCKCLE(1)=CODPRF
 If fstat
  Lock =CODPRF
  If !fstat : OK = 1 : GLCKPRF = I : Break : Endif
 Endif
Next I
Close Local File
Return

$LCK
For I=1 To NBUSR
 Lock ="PROFIL"+num$(GTYPPRF)+format$("N0:4#",I)
 If !fstat : OK = 1 : GLCKPRF = I : Break : Endif
Next I
Return

Subprog UNLOCK_PROFIL
If dim([V]GLCKPRF)>0 & GLCKPRF>0
 Unlock ="PROFIL"+num$(GTYPPRF)+format$("N0:4#",GLCKPRF)
Endif
End

##########################################
## Connexion silencieuse                ##
##########################################
Subprog CONNECTSIL
Onerrgo ERRCON
Local File AUTILIS [AUS], ADOVAL [ADW], AMETUTI [AME]
Local Integer MONO
Local Char MESSA(250)

GUSER = toupper(getenv$("USER_ENTREP"))
If GUSER=""
 GUSER = "ADMIN"
Endif
Read [AUS]CODUSR = GUSER
If fstat<>0
 Call ECR_TRACE("CONNECTSIL"-mess(23,100,1)-GUSER,1) From GESECRAN : # Fiche inexistante
 GPROCED="" : Goto FIN_CONNECTSIL
Elsif [F:AUS]ENAFLG<>2 | [F:AUS]USRCONNECT<>2
 # Code utilisateur non autorisé pour ce type de connexion
 Call ECR_TRACE("CONNECTSIL:"-GUSER-mess(279,123,1),1) From GESECRAN
 GPROCED="" : Goto FIN_CONNECTSIL
Endif

GLANGUE   = messname(0)
adxrob(0) = "ECR"
adxrob(1) = "M"+GLANGUE

GLOGIN  = tolower([F:AUS]LOGIN)
If [F:AUS]PRFMEN=""
 Read [AME]AME0 = [F:AUS]CODMET
 GMENDEP = [F:AME]PRFMEN
Else
 GMENDEP = [F:AUS]PRFMEN
Endif
GOK = 1
Call INIGLOBVAR
If GOK<1 : GPROCED = "" : Goto FIN_CONNECTSIL : Endif

# init date
datesyst = date$
If    datesyst > GDATFIN : datesyst = GDATFIN
Elsif datesyst < GDATDEB : datesyst = GDATDEB
Endif

Gosub CONNECT_SYRACUSE

If !GSERVEUR
 Call MENU_DEBUG
Endif
Gosub VERF_USER
If !OK : GPROCED = "" : Goto FIN_CONNECTSIL : Endif

Call AUDIT_CONNECT(0)


#107271
Local Char WCHMONO(50)
#Read [ADW]ADW0 = "";"";"MONO"
#MONO = val([F:ADW]VALEUR)
If func DOSSUB.ISHISTFOLD(nomap)
 Call GETPARHIS(nomap,"MONO",WCHMONO) From SUBADS
Else
 Call GETPAR(nomap,"MONO",WCHMONO) From SUBADS
Endif
MONO=val(WCHMONO)
If MONO<>0
 If GHYPER=0 | MONO>1
  Case MONO
   When 2       : MESSA = mess(146,124,1) : # Modification du dossier en cours
   When 3       : MESSA = mess(147,124,1) : # Sauvegarde du dossier en cours
   When Default : MESSA = mess(153,100,1) : # Le dossier est en mode mono
  Endcase
  Call ECR_TRACE(MESSA+"\"+mess(153,124,1),1) From GESECRAN : # Connexion impossible
  GPROCED=""
 Endif
Endif

$FIN_CONNECTSIL
Onerrgo
End

$ERRCON
Call ECR_TRACE(errmes$(errn)-errm-num$(errl),1) From GESECRAN
Resume

#----------------#
$TRACE
If find(adxusr,"mbeinat","MBEINAT")
 GTRACE = filpath("TRA","SYRA_" + adxusr, "tra", 0)
 Openo GTRACE,-1
 Wrseq "CONNECT_SYRACUSE"
 Wrseq "adxtyp="+num$(adxtyp)
 Wrseq "adxpno(1)="+adxpno(1)
 Wrseq "adxpno(2)="+adxpno(2)
 Wrseq "adxpno(3)="+adxpno(3)
 Wrseq "adxusr ='"+adxusr+"'"
 Wrseq "ISOMESS='"+isomess+"'"
 Wrseq "adxmac(-2) ='"+adxmac(-2)+"'"
 Wrseq "adxdcs="+num$(adxdcs)
 Openo
Endif
Return

#--------------------------------------------------------#
$CONNECT_SYRACUSE

Onerrgo ERRSYR

# Pour les constantes
Call DEFVAR From ASYRCONST
#
Gosub DECLARE_AVOID From ASYRCONST

# Pour les contextes func ADS_TOOL.SEARCH_ISOLAN(nomap,GLANGUE)
Local Integer ERRCOD
Call CONTEXT_NEW From ASYRMAIN
If adxusr <> ""
 [L]ERRCOD = fmet GACTX.ACTX_INIT_LAN(nomap,GLANGUE,adxusr)
Else
 [L]ERRCOD = fmet GACTX.ACTX_INIT_LAN(nomap,GLANGUE,GLOGIN)
Endif
If GSERVEUR & ERRCOD>0
 Call ECR_TRACE("GACTX initialisation ERRCOD : "+num$(ERRCOD),0) From GESECRAN
Endif
#97567
If ERRCOD<>0
 Onerrgo
 Return
Endif
Gosub GESUSER_CHARGE_LIC From ASYRLIC

# Pour syracuse end
Onerrgo

#87108
If fmet GACTX.AGETLICLIC(func ASYRLIC.GET_CHPRODUCTSTDCODE)<>[V]CST_ATRUE
 Call ERREND(mess(22,139,1)) From GESECRAN : # Licence incorrecte
 ERRAUD = 2 : Gosub ERR_AUDIT
 GERR = 4 : # Pour le Workflow
 GMENDEP = "" : Goto FIN
Endif

If adxtyp<>17 and adxtyp<>14 & fmet GACTX.AGETLIC_EXPIRED(func ASYRLIC.GET_CHPRODUCTSTDCODE)=[V]CST_ATRUE
  Call MESSAGE(mess(327,139,1)) From GESECRAN : #Licence expirée
Endif

#99976/1
TYPSES=mod(adxtyp,8)
#109419
#If find(TYPSES,4,5) & adxtyp<>20: #Web-services or Terminal
#111233
If find(TYPSES,4,5)<>0 & find(adxtyp,12,20)=0: #Web-services or Terminal
 Local Char VALMAX(30)
 MAXSES=0
 If TYPSES=4 : #Web-services
  If fmet GACTX.AGETLICPAR("MAXWEBSERVICES",VALMAX)=[V]CST_ATRUE
   MAXSES=val(VALMAX)
  Endif
 Elsif TYPSES=5 : #Terminal
  If fmet GACTX.AGETLICPAR("MAXTERMINALRF",VALMAX)=[V]CST_ATRUE
   MAXSES=val(VALMAX)
  Endif
 Endif
 NBSES=0
 Call USER_NBCON_APP(nomap,TYPSES,NBSES) From PSADX
 #112347 If NBSES>MAXSES
 If NBSES>MAXSES & !(adxtyp=5 & GPRODUIT=2)
   GMESSAGE = mess(116,133,1)+"\("+num$(max(0,MAXSES)) : # Nb maximum de sessions dépassé
   GMESSAGE -= mess(117,133,1)-mess(TYPSES,924,1)+")" : # Session(s)
   Call ERREND(GMESSAGE) From GESECRAN
   ERRAUD = 2 : Gosub ERR_AUDIT
   GERR = 4 : # Pour le Workflow
   GMENDEP = "" : Goto FIN
 Endif
Endif

If baseUrl<>"" and func AFNC.PARAM("AWRKSYRA","")=""
 If func DOSSUB.ISHISTFOLD(nomap)=0
 Call MAJPAR("AWRKSYRA",baseUrl)
 Endif
Endif

Return

#----------#
$ERRSYR
Call ECR_TRACE(errmes$(errn)-"-"-errm-"*"-num$(errl),1) From GESECRAN
Resume

#-----------------------------------------#
Subprog MAJPAR(PARAM,VALEUR)
Value Char PARAM,VALEUR
Local File ADOVAL [ADW_]
If !adxlog
 Trbegin [ADW_]
  Gosub MAJ_PAR
 Commit
Else
 Gosub MAJ_PAR
Endif
Close Local File [ADW_]
End

#-------------#
$MAJ_PAR
Read [ADW_]ADW0 = "";"";PARAM
If fstat
 Raz [F:ADW_]
 [F:ADW_]PARAM  = PARAM
 [F:ADW_]VALEUR = VALEUR
 Write [ADW_]
Else
 [F:ADW_]VALEUR = VALEUR
 Rewrite [ADW_]
Endif
Return

#------------------------#
$CHGUSRW
    Local Char    XPROF(50),XUSER(50),TIMESP(14)
    Local Integer OKENV
    XUSER=GUSER   : If XUSER="" : XUSER="ASK_" : Endif
    If [F:AUS]USR=XUSER : # Bug 38429  - CC 14/11/2006
      If [F:AUS]PRFMEN=""
        Read [AME]AME0 = [F:AUS]CODMET
        XPROF=[F:AME]PRFMEN
      Else
        XPROF=[F:AUS]PRFMEN
      Endif
    Else
      Read [AUS]CODUSR = toupper(XUSER)
      If fstat=0
        If [F:AUS]PRFMEN=""
         Read [AME]AME0 = [F:AUS]CODMET
         XPROF=[F:AME]PRFMEN
        Else
         XPROF=[F:AUS]PRFMEN
        Endif
      Else
        XPROF="ASK_"
      Endif
    Endif
#    If GBROWS=0 : XUSER=[F:AUS]LOGIN : Endif   :  #  Bug 49099   - CC  09/10/2008
    XUSER=[F:AUS]LOGIN :  # BUG 50867  16/01/2009
    If adxtyp=13 : # Terminaux VT
      Call GETIMSP(XPROF,GLANGUE,TIMESP) From INTRUTILA
      Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","ChangeUserContext="+chr$(1)
&               +XUSER+";"+GLANGUE+";"+XPROF+"^"+TIMESP
&               +";"+format$("D:YYYY",datesyst)+format$("D:MM",datesyst)+format$("D:DD",datesyst)
      Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","ProfileTitle="+chr$(1)+ GVTPROF
    Else
      Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","ChangeUserContext="+chr$(1)
&               +XUSER+";"+GLANGUE+";"+XPROF
&               +";"+format$("D:YYYY",datesyst)+format$("D:MM",datesyst)+format$("D:DD",datesyst)

      Call SETBO(GUSER) From INTRUTILA
      Call INITYPPORT(OKENV) From INTRUTILA
      If OKENV
       Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","ADXTypportal="+chr$(1)+num$(OKENV)
      Endif
      Gosub CHTHEME
    Endif

Return

$CHTHEME
# Local Char CODT
# Call PARAMUTIL("THEMEUT",CODT,GUSER,"") From SUBAUS
# If CODT=GTHEME or CODT="" or (CODT="STD" and GTHEME=GTHEMESTD) or (CODT=GTHEMESTD and GTHEME="STD") : Return : Endif
# If CODT="STD" : CODT=GTHEMESTD : Endif
 Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","ADXTheme="+chr$(1)+GTHEME  : # au lieu de + CODT
 Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","ADXPortalTheme="+chr$(1)+GTHEME  : # au lieu de +CODT
 #GTHEME=CODT
Return

Subprog DECRYPTO(PASSEP,DECRYPT)
Value Char PASSEP
Variable Char DECRYPT

Local Char PRIVKEY(30)       : PRIVKEY="x3 vient du froid"
Local Char KDIVISER(30)  : KDIVISER="zxWyZxzvwYzxZXxxZWWyWxYXz"
Local Char KENTRE(30)    : KENTRE="cf2tln3yuVkDr7oPaQ8bsSd4x"
Local Char KINTERNE(30)  : KINTERNE="cromanwqxfzpgedkvstjhyilu"
Local Char RESPASSE(30),ATR(1)

Local Char PASSE(100) : PASSE=PASSEP
If left$(PASSE,6)="CRYPT:" : PASSE=right$(PASSE,7) : Endif
Local Integer LPASSE : LPASSE=len(PASSE)

Local Integer LKEY   : LKEY=len(PRIVKEY)
Local Integer I,J,K,ICAR,IDIV

DECRYPT=""
K=1
For I=1 To LPASSE Step 2
  ICAR=ascii(mid$(PASSE,I,1))
  IDIV=(ascii(mid$(KDIVISER,K,1))-ICAR)*LKEY
  ATR=mid$(PASSE,I+1,1)
  J=1
  While ATR<>mid$(KINTERNE,J,1)
    If J>LKEY : Goto ERRKEY  : Endif
    J+=1
  Wend
  IDIV+=J-1
  RESPASSE+=chr$(IDIV)
  If mod(J,2)=1
 #   If mid$(PASSE,I+2,1)<>mid$(KENTRE,I,1)
       I+=1
  Endif
  K+=1
Next I

DECRYPT=RESPASSE
$ERRKEY
End

