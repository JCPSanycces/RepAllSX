# Connexion
#--------------------------------------------------------------------#

Gosub MAJ_UTILIS
If GOK<1 : GMENDEP = "" : Goto FIN : Endif

Call ESPION("",1,"CONNECT","") From ESPION
Raz GMESSAGE , GERR

#--------------------------------------------------------------------#
# Mot de passe obligatoire ou périmé
#--------------------------------------------------------------------#

$VERF_PASSE
If !find(adxtyp,7,12,26) and !(dim(GFUSION)>0 and GFUSION) : # Bridge/Web-service and Convergence

 # Mot de passe obligatoire ?

 PASSVIDE = ""
 VIDE = 0
 Call CTLPAS(PASSVIDE,VIDE)
 If VIDE
  Read [ADW]ADW0 = "";"";"PASSWD"
  If !fstat & val([F:ADW]VALEUR)=2
   If GBROWS<>2
    While VIDE
     Call ERREUR(mess(100,100,1)) From GESECRAN : # Vous devez saisir un mot de passe
     # in case user has not defined yet a pw but pw is mandatory,
     # display the pw update window:
     Call PASSE From PASSE
     If GSTATUT<>GSTAOK : Break : Endif : # Utilisateur locké
     Read [AUS]CODUSR Curr
     Call CTLPAS(PASSVIDE,VIDE)
     Goto VERF_PASSE : # On ne passe pas si on a fermé la boîte!!
    Wend
    If GSTATUT<>GSTAOK
     ERRAUD = 12 : Gosub ERR_AUDIT
     GERR = 13  : # Pour le Workflow
     GMENDEP = "" : Goto FIN
    Endif
   Else  : #   Pour ne pas boucler en connection Web service
    Call ERREND(mess(100,100,1)) From GESECRAN : # Vous devez saisir un mot de passe
    ERRAUD = 12 : Gosub ERR_AUDIT
    GERR = 13  : # Pour le Workflow
    GMENDEP = "" : Goto REBOOT
   Endif
  Endif
 Endif

 # Mot de passe périmé ?

 If dim([F:AUS]PASSDAT)>0
  If func ARECAUO.USRSAG([F:AUS]USR)
   If [F:AUS]PASSDAT+7<date$
    Call ERREND(mess(214,100,1)) From GESECRAN : # Mot de passe périmé
    ERRAUD = 4 : Gosub ERR_AUDIT
    GERR = 6 : # Pour le Workflow
    GMENDEP = "" : Goto REBOOT
   Endif
  Else
   GPE = 0
   GPOINT = "CHGPASS" : Gosub ENTREE From EXEFNC : # mb 30.9.13 demande 92865
   If !GPE
    Read [ADW]ADW0 = "";"";"CHGPASS"
    If !fstat & val([F:ADW]VALEUR)>0
     If [F:AUS]PASSDAT+val([F:ADW]VALEUR)<date$
      Call CTLPAS(PASSVIDE,VIDE)
      If !VIDE
       If GBROWS<>2
        Call CHGPASSE From PASSE
        If GSTATUT=GSTAEND : # mb 23.9.13 changement de comportement demandé pour sortir de la boucle infernale
         Call ERREND(mess(214,100,1)) From GESECRAN : # Mot de passe périmé
         ERRAUD = 4 : Gosub ERR_AUDIT
         GERR = 6 : # Pour le Workflow
         GMENDEP = "" : Goto REBOOT
        Else
         Read [AUS]CODUSR Curr
         Goto VERF_PASSE : # On ne passe pas si on a fermé la boîte!!
        Endif
       Else : #   Pour ne pas boucler en connection Web service
        Call ERREND(mess(214,100,1)) From GESECRAN : # Mot de passe périmé
        ERRAUD = 4 : Gosub ERR_AUDIT
        GERR = 6 : # Pour le Workflow
        GMENDEP = "" : Goto REBOOT
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif

Endif

# Pour le psadx

Call SET_CURFCT("",1,GLOGIN) From PSADX

# Démarrage du serveur
#107748
#Call PARAMUTIL("DEMSRV",AUTBAT,"","") From SUBAUS
#If val(AUTBAT)=2
# Call ACTAUTO From SERVEUR
#Endif

# Audit du login

If dim([V]GAUDIT)>0 & GAUDIT=2
 Gosub OK_AUDIT
Endif

# Menus utilisateur

Call MENADD From EXEFNC

# Date expiration licence
#87108
#Call NOMBRA(2,I) From GLOCK
#DATEXP = [0/0/0]+I
#If DATEXP-date$<30 and DATEXP<>[0/0/0]
# Call ECR_TRACE(mess(98,133,1)-format$("D:"+GFMDAT4,DATEXP),0) From GESECRAN
# # Attention cette licence expire le
#Endif

# Statistiques utilisateurs
#87108
#Call NOMBRA(12,I) From GLOCK
#If mod(I,32)>=16 or GUSRNOMME>0 : # Case à cocher "STAT" dans les licences
# Call MAJSTA(GUSER,1,num$(adxtyp),"") From AUSRSTA
#Endif

If toupper(adxusr)="ASK_" or GBROWS or adxctx<>""
 Gosub CHGUSRW
Else
 Call SETBO(GUSER) From INTRUTILA
#  Changement de thème
 Gosub CHTHEME
Endif

#     CC 16/04/2007      ---  Définition du site Web de référence
Call CREWEBSIT(WEBSITE) From INTRUTILA
If !GSERVEUR and GWEBSERV=0
 Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","ADXWebsite="+chr$(1)+WEBSITE
Endif
#     CC 08/01/2007      ---  On informe le client qu'on est connecté
  Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","Userconnect="+chr$(1)+ "true"
#

# Lien vers un contexte ?

If (adxctx<>"" & (!GBROWS or GFUSION=1)) or (instr(1,adxctx,"wkf=") & !instr(1,adxctx,"wkf=;") & !instr(1,adxctx,"wkf=sso") & GBROWS)

 # en web, adxctx a une autre structure

 Call CONNECT_FONCTION(adxctx,RETOUR)

If find(adxusr,"lse") & 1=0
  Call STOP(GACTX,filpath("!tmp",adxusr,"tra","","",""),1,GBIDC1) From ASYRTIMING
  Infbox  "Stop : " + time$
 Infbox GBIDC1
Endif

 If RETOUR="3"
  Goto FIN
 Elsif RETOUR<>"2"
  Call FIN From FIN : # mb 18.9.2 bug 15787
  GMENDEP = ""
 Endif

Endif

GERR = 0

Call WORKFLOW(1,"CON","",GUSER) From AWRK : # Evènement connection
If GBROWS=2
  Global Date GWSTSESSD
  Global Integer GWSTSESST
  Global Char GWSTSESSU(30)
  GWSTSESSD=date$
  GWSTSESST=time
  GWSTSESSU=GUSER
Endif
End

$EVAL
Resume

$ERADX
ERADX = errn
Resume

#---------------------------------------------------------------------------#
# Bidouilles pour contrôler la connexion sur nos dossiers de développement
#---------------------------------------------------------------------------#

$BIDOUILLES
If GSOPHIA
 #If (dim(GFUSION)>0 & GFUSION = 0) & !GSERVEUR & adxtyp<>17 and adxtyp<>14
 If (dim(GFUSION)>0 & GFUSION = 0) & !GSERVEUR & find(adxtyp,1,9)>0
  OK=2
  GMESSAGE="You are connected to a V7 or V8 X3 folder with the V6 ‘fat client’."
  GMESSAGE+="\Please be aware that for Quality purposes,"
  GMESSAGE+=" the current directive is to use the V7 client whenever possible"
  Case nomap
   When "GX3APP","X3DEVV7","X3DEV"
    GMESSAGE+=", through the following URL:"
    GMESSAGE+="\- http://sosyrgx3app:8124"
   When "QAPRMV7ALL"
    GMESSAGE+=", through the following URL:"
    GMESSAGE+="\- http://aysyrqav7:8124"
   When "SEED","X3REFV7"
    GMESSAGE+=", through the following URL:"
    GMESSAGE+="\- http://aysyrindv7:8124"
   When "SUPERV"
    GMESSAGE+=", through the following URL:"
    GMESSAGE+="\- http://sosyrsuperv:8124"
  Endcase
  Call AVERTIR(GMESSAGE,OK) From GESECRAN
  If OK<>2 : OKCONNECT = 0 : Return : Endif
  Raz GMESSAGE
# Call AVERTIR("You are connected to a V7 or V8 X3 folder with the V6 ‘fat client’\Please be aware that for Quality purposes,"
#&                  +"the current directive is to use the V7 client whenever possible.\"
#&                  +string$(find(nomap(0),"GX3APP","X3DEVV7","QAPRMV7ALL","SEED","X3REFV7","SUPERV")<>0,"On this folder use :")
#&                  +string$(nomap="GX3APP","              http://sosyrgx3app:8124")
#&                  +string$(nomap="X3DEVV7","              http://sosyrgx3app:8124")
#&                  +string$(nomap="QAPRMV7ALL","              http://aysyrqav7:8124")
#&                  +string$(nomap="SEED","-              http://aysyrindv7:8124")
#&                  +string$(nomap="X3REFV7","             http://aysyrindv7:8124")
#&                  +string$(nomap="SUPERV","              http://sosyrsuperv:8124")
#&                  ,OK) From GESECRAN
 Endif
  #VVVVV
  If (GPRODUIT=-1 & nomap="REPOSUPERV")  & find(GUSER,"VPO","CCL","ERB")=0
   #User not authorized to log in using this type of session
   Call ERREND(GUSER-mess(49,130,1)) From GESECRAN
   OKCONNECT = 0 : Return
  Endif
 If GUSER="ADMIN"
  #VVVVV
  If (!GSERVEUR & GPRODUIT=-1 & nomap="SUPERV")
   #User not authorized to log in using this type of session
   Call ERREND("ADMIN"-mess(49,130,1)) From GESECRAN
   OKCONNECT = 0 : Return
  Endif

#  If (GPRODUIT=-1 or nomap="GX3APP") & !find(adxusr,"mbeinat","erbou","dom")
#   Call ERREND("You do not have permission to connect to this folder as ADMIN") From GESECRAN
#   OKCONNECT = 0 : Return
#  Else
   OK = 1
   #VVVVV
   If nomap<>"FOLDEV" & adxtyp<>17 and adxtyp<>14    : #  Pour ne pas gêner la connection Eclipse - CC : 28/01/2009 bug 52021
    Call AVERTIR("Are you sure to connect as ADMIN\on this development folder ?",OK) From GESECRAN
    If OK<>2 : OKCONNECT = 0 : Return : Endif
   Endif
# Endif
 Endif
 If GPRODUIT=-1 or nomap="GX3APP"
  If adxcus="adonix"
   Call ERREND("User account : adonix\You must log in with a custom user account") From GESECRAN
   OKCONNECT = 0 : Return
  Endif
 Endif
 Call EXISTE_ADX("","","XGESUSER",OK) From ORDSYS
 If OK
  OK = 1
  Gosub ACTION From XGESUSER
  If !OK
   OKCONNECT = 0 : Return
  Endif
 Endif
Endif
If dim(GMIGCLOUD)>0
 OK=1
 Call AVERTIR("This folder is in a migration phase in the Amazon cloud."+
&  " Any modification done will be lost. Do you still want to connect ?",OK) From GESECRAN
 If OK<>2 : OKCONNECT = 0 : Return : Endif
Endif
Return

#--------------------------------#
Subprog UPD_NBCON_AUS
If clalev([F:AUS])=0 : End : Endif
Local Integer VUE , ERADX
VUE = 0
If GHISTO
 Call VUE_OK("AUTILIS",nomap,"FIL",VUE) From DOSVUE
Endif
If VUE
 Onerrgo ERADX
 Local File ADOSSIER [A__ADS]
 For [A__ADS]
  If [F:A__ADS]DOSHIS=nomap
   Local File =[F:A__ADS]DOSHIS+".AUTILIS" [A__AUS]
   Look [A__AUS]CODUSR=GUSER
   If !fstat
    Trbegin [A__AUS]
     Update [A__AUS] Where USR=GUSER With NBRCON += 1
    Commit
   Endif
   Break
  Endif
 Next A__ADS
 Close Local File
 Onerrgo
Else
 Trbegin [AUS]
  Update [AUS] Where USR=GUSER With NBRCON += 1
 Commit
Endif
End

#---------------------------------------#
Subprog CONNECT_FONCTION(CTX,RETOUR)
Value    Char CTX
Variable Char RETOUR
adxmpr = adxmpr
adxmbm = adxmbm

# 116473
Close File
Close Mask

Onerrgo RIEN
If dim([V]I)>0 : Kill [V]I : Endif
If dim([V]J)>0 : Kill [V]J : Endif
If dim([V]K)>0 : Kill [V]K : Endif
Raz GTRACE
Raz GEDIDIF
Raz GPILSEL , GPILSELDOC
Raz GCONSULT, GORITITCOL
Raz GTUNCPT
Raz GOBJET , GPROGRAMME
Raz GERREUR , GTRANS , GPICK
Raz GPILBOITE
Raz GWINDOW , GWINCRIT , GTYPPROG , GPROG , GBOITE , GABREV
Raz GAFF , GNBAFF , GERR
Raz GPILLNK
Raz GPILOBJ
Raz GFONC1
Raz GBATCH
Raz GPILNAV
Raz GCURFCY , GGRPFCY , GCURLEG
Onerrgo

If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
If clalev([F:AMU])=0 : Local File AMENUSER  [AMU] : Endif

Local Integer I , J , K
Local Char    CLE(250) , VARIANTE(30) , CHAINE(250)
Local Char    OPER(30) , EVENT(30) , OBJET(30)
Local Char    CLE(250) , CLE1(30) , CLEX(30)(1..10)
Local Integer NBCLE

Local Clbfile CNX_DATA
:#SAVE RETOUR in CNX_DATA
CNX_DATA=RETOUR

#If 2=1 and instr(1,adxctx,"info=overflow")>0  : # Test pour CRM : overflow dans adxctx, suite demandée via CAllUI
#  Infbox("Avant CallUI")
#  Local Char VALCLI,VALCLI1(250)(1..2)
#  Callui VALCLI1="" With "UIAction="+chr$(1)+"SessionSettings", "InfoOverflow="+chr$(1)+ VALCLI
#  Infbox(num$(len(VALCLI1(2)))-mid$(VALCLI1(2),20,30))
#Endif
If GBROWS<>0 and GFUSION<>1
 K = instr(1,adxctx,"wkf=")
 I = instr(K+1,adxctx,"Sdata-email")
 If I=0
  I = instr(K+1,adxctx,";")
 Endif
 CTX = mid$(adxctx,K+4,I-K-4)
Endif
If GPRODUIT=1 & 1=0 : # mb 19.3.15 bug 106807 A remettre en place à l'issue de l'US
 # CTX est de la forme GFCY~GDEP/fonction~variante/retour/événement/opération/clé1~clé2
 K = instr(1,CTX,"/")
 If K
  CLE = left$(CTX,K-1)
  CTX = right$(CTX,K+1)
  K = instr(1,CLE,"~")
  If K
   GFCY = left$(CLE,K-1)
   GDEP = right$(CLE,K+1)
  Endif
 Endif
 Call AFF_ENV From MENU
Endif

# CTX est de la forme fonction~variante/retour/événement/opération/clé1~clé2
K = instr(1,CTX,"/")
If K
 VARIANTE = left$(CTX,K-1)
 CTX      = right$(CTX,K+1)
Else
 VARIANTE = CTX
 CTX      = ""
Endif
K = instr(1,VARIANTE,"~")
If K
 GFONCTION = left$(VARIANTE,K-1)
 VARIANTE  = right$(VARIANTE,K+1)
Else
 GFONCTION = VARIANTE
 VARIANTE  = ""
Endif
Read [AFC]CODINT = GFONCTION
If fstat
 RETOUR = "3"
 # Code utilisateur/Fonction inexistante
 GERR = 15 : GMESSAGE = mess(103,124,1)-GUSER+"\"+GFONCTION-mess(162,123,1)
 If GFUSION=1 : Call ERREUR(GMESSAGE) From GESECRAN : Endif
 GMENDEP = "" : End
Endif
GFONCTION1 = GFONCTION
Read [AMU]MENFCT = GPROFIL;GFONCTION
K = instr(1,CTX,"/")
If K
 If find(left$(CTX,K-1),"0","1","2")
  RETOUR = left$(CTX,K-1)
  CTX    = right$(CTX,K+1)
 Endif
Else
 RETOUR = CTX
 CTX    = ""
Endif

# mb 29.1.9 Si l'utilisateur est déjà connecté on désactive le retour
If GUSRNOMME
 Lock ="AUO"-GUSER
 If fstat=1
  RETOUR = "1"
 Endif
Endif

K = instr(1,CTX,"/")
If K
 EVENT = left$(CTX,K-1)
 CTX   = right$(CTX,K+1)
Else
 EVENT = CTX
 CTX   = ""
Endif
K = instr(1,CTX,"/")
If K
 OPER  = left$(CTX,K-1)
 CTX   = right$(CTX,K+1)
Else
 OPER  = CTX
 CTX   = ""
Endif
CLE = CTX

Call LOAD_APP_CNX_DATA(CNX_DATA) From ASYRCHGENV :#X3-37831

If [F:AFC]ACTION="GOBJET"
 OBJET = evalue([F:AFC]VALPAR(0))
Elsif [F:AFC]TRAIT="GOBJET"
 K = find("GBIDC1",[F:AFC]VARIA)
 If K
  OBJET = evalue([F:AFC]VALEUR(K-1))
 Else
  OBJET = evalue([F:AFC]VALPAR(0))
 Endif
Endif
If RETOUR<>"2" : # CC 30/10/2007 : Désactivation du menu Fichier/Exécuter si retour de workflow avec sortie
 Disable GSTAFNC
Endif
If OBJET<>""
 actihgup(0) = "TIMOUT"
 actihgup(1) = "FIN"
 Call EXEFNCCNV(GFONCTION,VARIANTE,OPER,CLE) From EXEFNC
Else
 actihgup(0) = "TIMOUT"
 actihgup(1) = "FIN"
 GTRAITE = [F:AFC]TRAIT
 GBIDC1  = CLE
 GBIDC2  = EVENT
 GBIDC3  = CTX
 # Init des variables fonctions
 For I=0 To [F:AFC]NBVAR-1
  If [F:AFC]VALEUR(I)<>"#"
   Onerrgo EVAL
   Assign [F:AFC]VARIA(I) With evalue([F:AFC]VALEUR(I))
   Onerrgo
  Else
   Assign [F:AFC]VARIA(I) With [F:AMU]CODMEN
  Endif
 Next I
 #VPO gestion appel fonction convergence avec paramètres depuis syracuse (/params~p1~v1~p2~v2~p3~v3....)
 K=instr(1,CTX,'/params~')
 If K=0
   Call EXEFNC(GFONCTION,VARIANTE) From EXEFNC
 Else
   #on decoupe les param
   CTX         = right$(CTX,K+8)
   Local Integer NBAPAR,NOAPAR
   Local Char    ACODPAR(20)(0..20)
   Local Char    AVALPAR(250)(0..20)
   NBAPAR = 0
   NOAPAR = 0
   While CTX<>""
    K = instr(1,CTX,"~")
    If K
     If NBAPAR
      AVALPAR(NOAPAR) = left$(CTX,K-1)
     Else
      ACODPAR(NOAPAR) = left$(CTX,K-1)
     Endif
     CTX         = right$(CTX,K+1)
    Else
     AVALPAR(NOAPAR) = CTX
     CTX         = ""
    Endif
    If NBAPAR : NBAPAR=0 : NOAPAR+=1 : Else : NBAPAR+=1 : Endif
   Wend
   Call EXEFNCP(GFONCTION,VARIANTE,ACODPAR,AVALPAR) From EXEFNC
 Endif
Endif
If RETOUR<>"2"
 End
Endif


GFONCTION = ""
Call SET_CURFCT("",1,GLOGIN) From PSADX
End

#-----------------------------------#
$FIN
Call WORKFLOW(1,"CON","",GUSER) From AWRK : # Evènement connection
If GBROWS
 Call ERREND(" ") From GESECRAN
 If GMESSAGE=mess(233,100,1)
  Local Integer IU : IU=1+rnd(3)
  Sleep IU
 Endif
 Reb
Endif : # Eh oui, il faut ça pour fermer la session en WEB
End

#----------------------------------#
$REBOOT
# Il vaut mieux éviter le "Reb" avec une session secondaire (sauf WEB)
If mod(adxtyp,8)=2 : Goto FIN : Endif
Call WORKFLOW(1,"CON","",GUSER) From AWRK : # Evènement connection
If GMESSAGE=mess(233,100,1)
  Local Integer IU : IU=1+rnd(3)
  Sleep IU
Endif
Reb
End

$RIEN
Resume

$ERRSSO
AERR=2
Resume


$ERRWEB
Call ERREND(WWEBVERSION) From GESECRAN
WWEBVERSION=0
Resume

#-------------------------------------------------------------------#
# Test de connexion en utilisateur nommé
#-------------------------------------------------------------------#

Subprog CONNECT_NOMME(MESSAG,USER)
Variable Char MESSAG
Value Char USER
Local Char    PCLI(80) , PMAI(50) , PUSR(50) , PPRO(50)
Local Integer OK
If clalev([F:AUO])=0 : Local File AUSRSOL [AUO] : Endif
If !func ARECAUO.USRSAG(USER) & !func ARECAUO.APPDEM(nomap(0)) & !func ARECAUO.APPRAC(nomap(0))
 If nbrecord([AUO])>GUSRNOMME
  If nbrecord([AUO])>int(GUSRNOMME*1.2)
   MESSAG = mess(45,130,1) : # Trop d'utilisateurs nommés
   End
  Else
   # Votre licence est limité à $1$ utilisateurs nommés et il y a $2$ utilisateurs connectés
   Call MESSAGE(func AFNC.MES2(mess(74,130,1),num$(GUSRNOMME),num$(nbrecord([AUO])))) From GESECRAN
  Endif
 Endif
 Read [AUO]AUO0 = USER
 If fstat
  MESSAG = USER-":"-mess(47,130,1) : # Utilisateur non autorisé à se connecter
  End
 Endif
 Lock ="AUO"-USER
 If fstat=1 & !(instr(1,adxctx,"wkf=") & !instr(1,adxctx,"wkf=;") & !instr(1,adxctx,"wkf=sso") & GBROWS)
  Call PROCESS_LOCK_SYMB("","AUO"-USER,PPRO) From PSADX
  Call USER_QUI(PPRO,"",PCLI,PUSR,PMAI) From PSADX
  OK = 0
  GPE = 0
  #CHECK UNUSED_BEGIN
  GPOINT = "DISCONNECT" : Gosub ENTREE From EXEFNC
  #CHECK UNUSED_END
  If func DEJA_CONNECTE(PCLI) or GPE or GBROWS=1
   # Une session tourne déjà pour cet utilisateur, voulez-vous l'arrêter ?
   Call AVERTIR(mess(82,130,1),OK) From GESECRAN
   If OK<>2
    OK = 0
   Else
    Call KILL_ALLPROC(PPRO) From PSADX
    Lock ="AUO"-USER
    If !fstat
     OK = 1
    Else
     OK = 0
    Endif
   Endif
  Endif
  If !OK
   MESSAG = USER-":"-mess(46,130,1) : # Utilisateur déjà connecté
   If GBROWS<>0 : MESSAG="CN01:"-MESSAG : Endif
   End
  Endif
 Endif
Endif
End

#-----------------------------------------#
Funprog DEJA_CONNECTE(PCLI)
Value Char PCLI : # Nom du pc retourné par psadx (qui peut être différent de adxmac(-2): nom de domaine en plus, adresse ip)
Local Integer OK , I , J , K
Local Char    CHAINE(250) , MYPC(250)
OK = 0
MYPC = adxmac(-2)
If PCLI=MYPC
 OK = 1
Else
 CHAINE = PCLI
 K = 1
 While CHAINE<>""
  I = instr(1,CHAINE,".")
  If I
   J = val(left$(CHAINE,I-1))
   CHAINE = right$(CHAINE,I+1)
  Else
   J = val(CHAINE)
   CHAINE = ""
  Endif
  If J=0 : K = 0 : Break : Endif
 Wend
 If !K : # Ce n'est pas une adresse ip
  If MYPC<>"" & left$(toupper(PCLI),len(MYPC))=toupper(MYPC)
   OK = 1
  Endif
 Endif
Endif
End OK

############################################
## Mise à jour table AUTILIS
############################################

$MAJ_UTILIS
If GHISTO : Return : Endif
Call DEBTRANS From GLOCK
Gosub TR_CONNECT
Return

$TR_CONNECT
GOK = 1
Trbegin [AUS]
 Readlock [AUS]CODUSR = GUSER
 If fstat=1
  GOK=-1 : GLOCK="$UTILIS"-GUSER
  Goto ROLL_CONNECT
 Elsif fstat
  GOK=0 : Call RSTA("AUS",GUSER) From GLOCK
  Goto AB_CONNECT
 Endif
 If GUSER=GSUPER & ([F:AUS]DATCONN<>date$ or GESPION=3)
  GBIDC1 = mess(168,123,1) : # Connection
  GBIDC1 -= adxmac(-2)
  If dim(adxcus)>0
   GBIDC1 -= "("+adxcus+")"
  Endif
  Call TRACE(nomap(0),"","",GBIDC1,"") From ESPION
 Endif
 [F:AUS]DATCONN = date$
 [F:AUS]TIMCONN = time$
 [F:AUS]NBRCON  = 0
 Rewrite [AUS]
 If fstat
  GOK=0 : Call RSTA("AUS",GUSER) From GLOCK
  Goto AB_CONNECT
 Endif
Commit
Return

$AB_CONNECT
Rollback
ERRAUD = 11 : Gosub ERR_AUDIT
GERR = 12 : # Pour le Workflow
GMENDEP = ""
Return

$ROLL_CONNECT
Rollback
Call ROLL From GLOCK
If GROLL
 GERR = 12 : GMENDEP = ""
Else
 Goto TR_CONNECT
Endif
Return

#########################################
## Audit des connexions
#########################################

$OK_AUDIT
ERRAUD = 0

$ERR_AUDIT
#  0 : Connexion OK
#  1 : Utilisateur incorrect
#  2 : Nb de sessions dépassé
#  3 : Nb d'essais dépassé
#  4 : Mot de passe incorrect  ou mot de passe vide en Web service
#  5 : Pas de menu de départ
#  6 : Nb utilisateur/profil dépassé
#  7 : Dossier en mode mono
#  8 : Menu inexistant
#  9 : Refus par point d'entrée
# 10 : Langue incorrecte
# 11 : Erreur dans transaction de connexion
# 12 : Refus de saisie ou chgt mot de passe

Call AUDIT_CONNECT(ERRAUD)
Return

############################################
Subprog AUDIT_CONNECT(ERRAUD)
Value Integer ERRAUD

Local Integer TT , HH , MM , SS, STAT
Local Char    USRBDD(30) , USRSYS(30) , USRCLI(30)
Local Char    SID(20) , SADR(50) , SDOS(50) , SLOGIN(30) , SUSR(30)

#109897
#If dim(GAUDIT)<=0 or GAUDIT<>2 or GHISTO
If dim(GAUDIT)<=0 or GAUDIT<>2 or (dim(GHISTO)>0 & GHISTO)
 End
Endif
If clalev([F:ALO])=0 : Local File ALOGIN   [ALO] : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL   [ADW] : Endif
If [F:ADS]DOSSIER<>nomap
 #Read [ADS]DOSSIER = nomap
 STAT=func DOSSUB.FILL_ADS(nomap)
Endif
Gosub USER_BDD
Gosub USER_SYS
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_AUD
Else
 Gosub MAJ_AUD
Endif
End

$TR_AUD
GOK = 1
Trbegin [ALO]
 Gosub MAJ_AUD
 If GOK=0 : Goto AB_AUD : Endif
Commit
Return

$MAJ_AUD
#
# Les autres sessions de même identifiant ne sont plus actives
#
Update [ALO] Where BDDID=USRBDD and FLG<>1 With FLG=1
If fstat
 GOK = 0 : Call FSTA("ALO") From GLOCK : Return
Endif
Update [ALO] Where ADOID=num$(adxuid(1)) and FLG<>1 With FLG=1
If fstat
 GOK = 0 : Call FSTA("ALO") From GLOCK : Return
Endif
#
# Création enreg dans ALOGIN
#
Raz [F:ALO]
[F:ALO]SEQ    = uniqid([ALO])
[F:ALO]ADOID  = num$(adxuid(1))
[F:ALO]BDDID  = USRBDD
[F:ALO]ADOLOG = adxusr
[F:ALO]ADOUSR = GUSER
[F:ALO]SYSUSR = USRSYS
[F:ALO]ADRCLI = USRCLI
[F:ALO]ADOTYP = mod(adxtyp,8)
[F:ALO]DATCNX = date$
TT = time
HH = int(TT/3600)
MM = int((TT-3600*HH)/60)
SS = TT-3600*HH-60*MM
[F:ALO]HOUCNX = format$("N0:2#",HH)+format$("N0:2#",MM)+format$("N0:2#",SS)
If ERRAUD
 [F:ALO]STA    = ERRAUD
 [F:ALO]MSG    = GMESSAGE
 [F:ALO]DATDCX = [F:ALO]DATCNX
 [F:ALO]HOUDCX = [F:ALO]HOUCNX
 [F:ALO]FLG = 1 : # mb 10.6.13 bug 89549
Else
 [F:ALO]STA    = 0
 [F:ALO]MSG    = ""
 [F:ALO]FLG = 2
Endif
Write [ALO]
If fstat
 GOK = 0 : Call FSTA("ALO") From GLOCK
Endif
Return

$REMP_AUD
Return

$AB_AUD
Rollback
Return

$USER_BDD
Case [F:ADS]TYPDBA
 When 1 : Gosub USER_ORA
 When 2 : Gosub USER_SQL
Endcase
Return

$USER_ORA
For (Integer ORASES) From '3' Sql
&   "Select userenv('SESSIONID') from dual"
&    As [ORA_]
 USRBDD = num$([ORA_]ORASES)
 Break
Next
Return

$USER_SQL
Execsql From '5'
& Sql "Update ADOVAL set VALEUR_0=convert(varchar,@@spid) where PARAM_0='TMPID' and CMP_0=' ' and FCY_0=' '"
Read [ADW]ADW0 = "";"";"TMPID"
USRBDD = [F:ADW]VALEUR
Return

$USER_SYS
If dim([S]adxcus)>0
 USRSYS = adxcus
 If instr(1,USRSYS,"\")
  USRSYS = right$(USRSYS,instr(1,USRSYS,"\")+1)
 Endif
 USRCLI = adxmac(-2)
Else
 If func ASESSIONS.ISMNGSESSIONS
  Call USER_SYS(USRSYS,USRCLI) From ASESSIONS
 Else
  Local File (SID,SADR,SDOS,SLOGIN,SUSR)
&          From System adxmac(0)+"@psadx -u"-GLOGIN-"-b"-nomap-"-n"  As [SYS_]
&          Where [SYS_]SID=num$(adxuid(1))
  For [SYS_]
   USRSYS = [F:SYS_]SLOGIN
   USRCLI = [F:SYS_]SADR
   Break
  Next
  Close Local File [SYS_]
 Endif
Endif
Return

##########################################
## Déconnexion                          ##
##########################################
Subprog DECONNECT
Local Integer TT , HH , MM , SS , ERR

# Opération de sécurité
If nbruser=1
 # JML 28/5/96 à la demande de dom on trace le dernier
 Call ESPION("",1,"DECONNECT",mess(22,130,1)) From ESPION : # Dernier utilisateur
Else
 Call ESPION("",1,"DECONNECT","") From ESPION
 Call RAZ_CURFCT(num$(adxuid(1))) From PSADX
Endif
Call UNLOCK_PROFIL
Call AUDIT_DECONNECT
End

############################################
Subprog AUDIT_DECONNECT
If dim(GAUDIT)<=0 or GAUDIT<>2 or GHISTO
 End
Endif
Local Integer ERR , TT , HH , MM , SS
Onerrgo ERRFIC
If clalev([F:ALO])=0 : Local File ALOGIN [ALO] : Endif
If !ERR
 If !adxlog
  Call DEBTRANS From GLOCK
  Gosub TR_DEC
 Else
  Gosub MAJ_DEC
 Endif
Endif
Onerrgo
End

$TR_DEC
GOK = 1
Trbegin [ALO]
 Gosub MAJ_DEC
Commit
Return

$MAJ_DEC
Filter [ALO] Where ADOID=num$(adxuid(1)) and FLG=2
Readlock [ALO]ALO2 First
Filter [ALO]
If fstat<=2
 [F:ALO]DATDCX = date$
 TT = time
 HH = int(TT/3600)
 MM = int((TT-3600*HH)/60)
 SS = TT-3600*HH-60*MM
 [F:ALO]HOUDCX = format$("N0:2#",HH)+format$("N0:2#",MM)+format$("N0:2#",SS)
 [F:ALO]FLG    = 1
 Rewrite [ALO]
Endif
Return

$ERRFIC
ERR = errn
Resume

###############################################################
# Renvoie utilisateur et passwd BI d'un utilisateur X3
###############################################################

Subprog VARPSEBO(USRX3,USRBI,PWD,MESSA,MODE,OK)
Value Char USRX3
Variable Char USRBI,PWD
Variable Char MESSA
Variable Integer MODE,OK
Local Integer ERR
If dim(GLONAIU)<=0 or filinfo(filpath("FIL","ABIPRFUSR","fde"),0)<0 : End : Endif
Local Char PRFBI(GLONAIU)
Onerrgo ERRFIC
If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
If clalev([F:AME])=0 : Local File AMETUTI   [AME] : Endif
If clalev([F:AIU])=0 : Local File ABIPRFUSR [AIU] : Endif
Onerrgo
If ERR : End : Endif
Raz OK , MESSA
If dim([F:AUS]USRBI)<=0 : End : Endif
If USRX3<>""
 Read [AUS]CODUSR=toupper(USRX3)
 If !fstat
  If USRX3=GSUPER & [F:AUS]USRBI="" : # Utilisateur ADMIN
   [L]PRFBI = "ADMIN"
  Else
   If [F:AUS]USRBI=""
    Read [AME]AME0 = [F:AUS]CODMET
    [L]PRFBI = [F:AME]USRBI
   Else
    [L]PRFBI = [F:AUS]USRBI
   Endif
  Endif
  Read [AIU]AIU0=[L]PRFBI
  If fstat
   MESSA = mess(77,148,1) : # Profil utilisateur BI inexistant
   End
  Else
   If [F:AIU]USR = "Administrator"
    Call RECHPROP("busobj.login.adminpwd",[L]PWD,OK) From INTRUTILA
    If OK=0
     OK =1
    Else
     OK=0 : MESSA = mess(77,148,1)  : # Profil utilisateur BI inexistant
     End
    Endif
    [L]USRBI = [F:AIU]USR
    Call DECRYPTO([L]PWD,[L]PWD) From GESUSER
   Else
    [L]USRBI = [F:AIU]USR
    [L]PWD = [F:AIU]PWD
    If dim([F:AIU]MODE)>0
     [L]MODE = max(1,[F:AIU]MODE)
    Endif
    If len([L]PWD)=24 : Call VARPSE([L]PWD) From GESUSER : Endif
   Endif
  Endif
  OK = 1
 Else
  MESSA = USRX3-mess(141,100,1) : # Code utilisateur inexistant
 Endif
 End
Elsif [L]USRBI<>""
 For [AIU]AIU0 Where [F]USR=[L]USRBI
  OK = 1 : Break
 Next AUS
 If !OK
  MESSA = [L]USRBI-mess(141,100,1)-"(BI)" : # Code utilisateur inexistant
 Else
  If [F:AIU]USR = "Administrator"
   Call RECHPROP("busobj.login.adminpwd",[L]PWD,OK) From INTRUTILA
   If OK=0
    OK =1
   Else
    OK=0 : MESSA = mess(77,148,1)  : # Profil utilisateur BI inexistant
    End
   Endif
   Call DECRYPTO([L]PWD,[L]PWD) From GESUSER
  Else
   [L]PWD = [F:AIU]PWD
   If dim([F:AIU]MODE)>0
    [L]MODE = max(1,[F:AIU]MODE)
   Endif
   If len([L]PWD)=24 : Call VARPSE([L]PWD) From GESUSER : Endif
  Endif
 Endif
 End
Endif
End

##########################################
## Cryptage du mot de passe             ##
##########################################
Subprog CRYPT(PASSE)
Variable Char PASSE()
Local Char P(20)
Local Integer I
Local Decimal NB , NB1 , NB2 , NB3 , NB4
NB1=937 : NB2=941
NB3=991 : NB4=997
P=PASSE
PASSE=""
NB=1
For I=1 To len(P) Step 2
 NB=mod(NB+NB1*ascii(mid$(P,I,1)),NB2)
Next I
PASSE += chr$(65+mod(NB,26))
PASSE += chr$(65+mod(int(NB/26),26))
PASSE += chr$(65+mod(int(NB/97),26))
NB=1
For I=2 To len(P) Step 2
 NB=mod(NB+NB3*ascii(mid$(P,I,1)),NB4)
Next I
PASSE += chr$(65+mod(NB,26))
PASSE += chr$(65+mod(int(NB/26),26))
PASSE += chr$(65+mod(int(NB/97),26))
End

##################################################
## Nouveau cryptage du mot de passe             ##
##################################################
Subprog CRYPTNEW(PASSE)
Variable Char    PASSE()
Local Integer ER , I , I1
Local Libelle CRI(1..12)
Raz CRI
For I=1 To min(len(PASSE),12)
 CRI(I) = ascii(mid$(PASSE,I,1))
Next I
# Utilisation du Crypton
Call CRI(CRI) From VISULIC
# Conversion ascii
PASSE = ""
For I=1 To 12
 I1 = int(CRI(I)/16) : Gosub PASSE1
 I1 = mod(CRI(I),16) : Gosub PASSE1
Next I
End

$PASSE1
If I1>=10
 PASSE += chr$(65+I1-10)
Else
 PASSE += chr$(48+I1)
Endif
Return

#################################################
Subprog CTLPAS(PASSE,OK)
Value    Char    PASSE
Variable Integer OK
Local Integer ER
Onerrgo ERPAS
OK = 1
If dim([F:AUS]NEWPAS)>0 & [F:AUS]NEWPAS<>"" : # nouveau cryptage
 Call CRYPTNEW(PASSE)
 If [F:AUS]NEWPAS<>PASSE
  OK = 0
 Endif
Else : # ancien cryptage
 Call CRYPT(PASSE)
 If [F:AUS]PASSE<>PASSE
  OK = 0
 Endif
Endif
Onerrgo
If ER : OK = 0 : Endif
End

$ERPAS
ER = errn
Resume

####################################################
Subprog VARPSE(PASSE)
Variable Char PASSE()
Local Libelle CRI(1..12)
Local Integer I, I1, I2
Local Char    C1(1), C2(1)
For I=1 To 12
 C1 = mid$(PASSE,2*I-1,1)
 If C1>="A"
  I1 = ascii(C1)-65+10
 Else
  I1 = ascii(C1)-48
 Endif
 C2 = mid$(PASSE,2*I,1)
 If C2>="A"
  I2 = ascii(C2)-65+10
 Else
  I2 = ascii(C2)-48
 Endif
 CRI(I) = 16*I1+I2
Next I
Call CRI(CRI) From VISULIC
PASSE = ""
For I=1 To 12
 If CRI(I)=0
  Break
 Else
  PASSE += chr$(CRI(I))
 Endif
Next I
End

#################################################
##     Init variables globales utilisateur     ##
#################################################
Subprog INIGLOBVAR
Local Integer I , J , OKTRT
Local Char    PARAM(40) , TIT(250) , TITSUF(80), TITABR(80) , TITUSR(250)
Local Char    TIMESP(14) , STYDEF(20) , TEXTE(250)
Local Integer TIME1 , TIME2

If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
If clalev([F:AUB])=0 : Local File AUSRBPR   [AUB] : Endif
If clalev([F:ACV])=0 : Local File ACTIV     [ACV] : Endif
If clalev([F:AFT])=0 : Local File AFCTFCT   [AFT] : Endif
If clalev([F:APF])=0 : Local File APROFIL   [APF] : Endif
If clalev([F:AME])=0 : Local File AMETUTI   [AME] : Endif

#109897
If find(adxtyp,34,35)>0
 GLOGIN=GACTX.LOGIN
 GUSER=GACTX.USER
Endif

Read [AUS]CODUSR = GUSER
If [F:AUS]PRFMEN=""
 Read [AME]AME0 = [F:AUS]CODMET
 Read [APF]CODPRF = 0;[F:AME]PRFMEN
Else
 Read [APF]CODPRF = 0;[F:AUS]PRFMEN
Endif
GNOMUSER = [F:AUS]NOMUSR
If [F:AUS]PRFFCT=""
 Read [AME]AME0 = [F:AUS]CODMET
 GPROFIL  = [F:AME]PRFFCT
Else
 GPROFIL  = [F:AUS]PRFFCT
Endif

#109897
If find(adxtyp,34,35)>0
 If [F:AUS]PRFMEN=""
  Read [AME]AME0 = [F:AUS]CODMET
  If !fstat
   GMENDEP = [F:AME]PRFMEN
  Endif
 Else
  GMENDEP = [F:AUS]PRFMEN
 Endif
Endif

GIDENT   = format$("K:5X",GUSER)+num$(adxuid(1))
GUSRACS  = [F:AUS]ALLACS
GTYPPRF  = [F:APF]TYPPRF
Read [AFT]AFT0 = GPROFIL
If GPROFIL=GSUPER
 GDIFIMP = 2
 GFILTETAT="*"
Else
 GDIFIMP = [F:AFT]DIFIMP
 If dim([F:AFT]FILTRE)>0
  GFILTETAT = [F:AFT]FILTRE
 Else
  GFILTETAT = "*"
 Endif
Endif

## Déconnexion
If !GSERVEUR     : #  CC  09/09/2011  Bug 72538
 Case mod(adxtyp,8)
  When 2 : # Sessions secondaires client/serveur
   #109897
   If adxtyp<>34
    Call PARAMUTIL("TIMEHGUP3",PARAM,"","") From SUBAUS
   Else
    Call PARAMUTIL("TIMEHGUP1",PARAM,"","") From SUBAUS
   Endif
  When Default
   Call PARAMUTIL("TIMEHGUP1",PARAM,"","") From SUBAUS
 Endcase
 TIME1 = val(PARAM)
 If TIME1>=0
  Call PARAMUTIL("TIMEHGUP2",PARAM,"","") From SUBAUS
  TIME2 = val(PARAM)
 Endif
Endif

# Styles de présentation
If !GSERVEUR and GWEBSERV=0
 Call PARAMUTIL("STYLE",STYDEF,"","") From SUBAUS
 If adxtyp=13 : # Terminaux VT
  If STYDEF=""
   Call GETIMSTY("STX_DEFAULT",TIMESP) From INTRUTILA
  Else
   Call GETIMSTY("STX_"+STYDEF,TIMESP) From INTRUTILA
  Endif
 Endif
Endif

# Sites par défaut par modules
For I=1 To len(mess(0,14,1))
 GFCYDEF(I) = [F:AFT]FCYDEF(I-1)
Next I

# Nb lignes affichées tableaux
Call PARAMUTIL("ADXLIG",PARAM,"","") From SUBAUS
[S]adxlig = val(PARAM)
# On garde la valeur en C/S. On la met à 0 en Web  :  CC 14 /01/2013   Bug 87092
If GBROWS<>0
# [S]adxlig = 9999 : # mb 23.3.9 en attendant la sortie du nouveau moteur où il faudra figer adxlig à 0
 [S]adxlig = 0
Endif
# Confirmation suppression
Call PARAMUTIL("CONFSUP",PARAM,"","") From SUBAUS
GCONF(1) = val(PARAM)

# Confirmation duplication
Call PARAMUTIL("CONFDUP",PARAM,"","") From SUBAUS
GCONF(2) = val(PARAM)

# Confirmation abandon
Call PARAMUTIL("CONFABD",PARAM,"","") From SUBAUS
GCONF(3) = val(PARAM)

# Groupe de liaison
Call PARAMUTIL("GRPLIAISON",PARAM,"","") From SUBAUS
GLIAISON(0) = PARAM

# Liaisons autos
Call PARAMUTIL("LIAISAUTO",PARAM,"","") From SUBAUS
GLIAISON(1) = PARAM

# Autres variables globales utilisateur
#{X3-37831: Be carefull not to erase global variables set by ASYRCHGENV:
If dim(GDEP) >= 0 : Local Char     SAVDEP(GLONDEP)   : SAVDEP = GDEP : Endif : # Déposant courant
If dim(GFCY) >= 0 : Local Char     SAVFCY(GLONFCY)    : SAVFCY = GFCY : Endif : # site courant
#X3-37831}
Call DEFVAR From WWAGLOBUSR
#{X3-37831
If dim(GDEP) >= 0  and dim(SAVDEP) >= 0 : GDEP  = SAVDEP: Endif : # Déposant courant
If dim(GFCY) >= 0  and dim(SAVFCY) >= 0 : GFCY  = SAVFCY: Endif : # site courant
#X3-37831}

# Default legislation
If !func AFNC.ACTIV("LEG") : # mono
 If GLEGFIL=""
  GLEGFIL = GDOSLEG
 Endif
Endif

# Debugger
If GDEBUG=2
 dbgmode = 1
 Enable GSTADBG
 Enable GSTADBR
Else
 dbgmode = 0
 Disable GSTADBG
 Disable GSTADBR
Endif

# Paramètres liés au produit
Case GPRODUIT
 When -1   : Call PARAM("","SUPDOS",PARAM) From ADOVAL
           : If nomap=PARAM
           :  Call EXISTE_ADX("","","GLOBGEO",OKTRT) From ORDSYS
           :  If OKTRT
           :   Call VARUSR From GLOBGEO
           :  Endif
           : Endif
 When 0    : Call VARUSR From GLOBX3
 When 1    : Call VARUSR From GLOBGEO
 When 2    : Call VARUSR From GLOBPAY
 When 3    : Call VARUSR From GLOBIMM
 When 4    : Call VARUSR From GLOBLOAN
Endcase

GNBROLUSR = 0
For [AUB]AUB0 Where USR=GUSER
 GNBROLUSR += 1
 GROLUSR(GNBROLUSR) = [F:AUB]ROL
 GROLCLE(GNBROLUSR) = [F:AUB]BPR
 If GNBROLUSR>=dim(GROLUSR) : Break : Endif
Next
Sorta GNBROLUSR GROLUSR,GROLCLE

# Taille mémoire
If dim([F:APF]MEM)>0 & [F:APF]MEM>0
 maxmem = (maxmem/1024) + [F:APF]MEM : # Bizarrerie de la variable maxmem
Endif

# Barre de titre
If !GSERVEUR & adxtyp<>34:#109897
 Call TITFENP(TITABR,TIT,TITSUF) From GLOBVAR
 TIT = nomap-TIT-TITSUF
 If [F:AUS]TIT<>""
  Onerrgo RIEN
  TITUSR = evalue([F:AUS]TIT)
  Onerrgo
  If TITUSR<>""
   TIT = TITUSR
  Endif
 Endif
 Titled [] TIT
Endif

GPOINT = "INIVAR" : Gosub ENTREE From EXEFNC : # mb 19.12.01 Demande no 10729

If !GSERVEUR & !GWEBSERV & adxtyp<>34 :#109897

 # Avertissement légal si le fichier existe
 Call AVLEGAL(TEXTE) From INTRUTILA

 Gosub ENVOI_CLIENT

Endif

End

#----------------------------------------------#
$ENVOI_CLIENT

# Déconnexion
If TIME1>0 or GBROWS=1
 Callui PARAM="" With "UIAction="+chr$(1)+"Sethangup"
&                   , "UITimehangup1="+chr$(1)+num$(TIME1)
&                   , "UITimehangup2="+chr$(1)+num$(TIME2)
Endif

# Styles de présentation
If adxtyp=13 : # Terminaux VT
 If STYDEF=""   : Callui PARAM="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_DEFAULT^"+TIMESP
 Else           : Callui PARAM="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_"+STYDEF+"^"+TIMESP
 Endif
Elsif STYDEF="" : Callui PARAM="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_DEFAULT"
Else            : Callui PARAM="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_"+STYDEF
Endif

# Développement Crystal Report
If GDEVCRY=2
 Callui PARAM="" With "UIAction="+chr$(1)+"SessionSettings","UIAllowDevRpt="+chr$(1)+num$(GDEVCRY-1)
Endif

# Barre de titre
Callui PARAM="" With "UIAction="+chr$(1)+"SessionSettings","ADXWtitle="+chr$(1)+TIT

# Avertissement légal
If adxtyp=13 : # Terminaux VT
 Callui PARAM="" With "UIAction="+chr$(1)+"SessionSettings","ProfileTitle="+chr$(1)+GVTPROF
Elsif TEXTE<>""
 Callui PARAM="" With "UIAction="+chr$(1)+"SessionSettings","AboutWarningFile="+chr$(1)+TEXTE
Endif

Return

