#<AdxTL>@(#)8.0.0.0 $Revision$
#--------------------------------------------------------------------#
# Sous-programmes Appelés par GOBJACT,GSAISIE ...
#                 et les moulinettes de MAJ
#--------------------------------------------------------------------#
# il faut appeler SET_FIRST puis UNSET_FIRST
#--------------------------------------------------------------------#

#------------------------------------------------------------------#
#------------------------------------------------------------------#
$SET_FIRST
If GTYPDBA=1
    If dim([L]OPTMIZ)<0 : Local Char OPTMIZ(100) : Endif
    Call SET_MODEFIRST([L]OPTMIZ)
Endif
Return

#------------------------------------------------------------------#
$UNSET_FIRST
If GTYPDBA=1
    If dim([L]OPTMIZ)>0 & [L]OPTMIZ<>"" : Call SET_MODE([L]OPTMIZ) : [L]OPTMIZ="" : Endif
Endif
Return

#------------------------------------------------------------------#
# Suivent les sous-pro internes
#------------------------------------------------------------------#
#------------------------------------------------------------------#
Subprog SET_MODE(OPTMIZ)
Value Char OPTMIZ
If GTYPDBA=1
    Execsql From '3' Sql "alter session set optimizer_mode="+OPTMIZ
Endif
End

#------------------------------------------------------------------#

Subprog SET_MODEFIRST(OPTMIZ)
Variable Char OPTMIZ
If GTYPDBA=1
    If OPTMIZ=""
        For (Char AVAL(50)) From '3' Sql "SELECT v.value From V$PARAMETER v WHERE name='optimizer_mode'" As [AM__]
         OPTMIZ = [F:AM__]AVAL
         Break
        Next AM__
        #VPO 04/12/07 on positionne mode selon GORAOPTNB
        If dim(GORAOPTNB)<0
        Call SET_MODE("FIRST_ROWS")
        Else
        Call SET_MODE("FIRST_ROWS"+string$( GORAOPTNB>0,"_"+num$(GORAOPTNB)))
        Endif
    Endif
Endif
End

#------------------------------------------------------------------#


