#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENEMPTMP 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone BPAG
mkstat = 0
zoncou = "BPAG"
indice = 0
status = 1
zoncou = "BPAG"
If varmode([M]BPAG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPAG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]BPAG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]BPAG = nolign
   status = 75
   Call SAI_BPAG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_BPAG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone BPAG
mkstat = 0
zoncou = "BPAG"

## Zone EXPR
mkstat = 0
zoncou = "EXPR"
If varmode([M]EXPR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXPR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PRDFRM
mkstat = 0
zoncou = "PRDFRM"
If varmode([M]PRDFRM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRDFRM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PRDUTL
mkstat = 0
zoncou = "PRDUTL"
If varmode([M]PRDUTL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRDUTL" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DATPAY
mkstat = 0
zoncou = "DATPAY"
If varmode([M]DATPAY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATPAY" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TOTTYP
mkstat = 0
zoncou = "TOTTYP"
IMPENT = [M]TOTTYP(indice)
If varinit([M]TOTTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]TOTTYP,indice)=0
 Call INICOMBO(10344) From COMBOS
 [M]TOTTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TOTTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TOTTYP(indice)
 Endif
 If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
  mkstat = 1 : GMESSAGE = mess(99,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TOTTYP" : GZNUM = 680 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]TOTTYP(indice) = IMPENT

## Zone TOTTYPCOD
mkstat = 0
zoncou = "TOTTYPCOD"
If varmode([M]TOTTYPCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TOTTYPCOD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TOTTYPELM
mkstat = 0
zoncou = "TOTTYPELM"
IMPENT = [M]TOTTYPELM(indice)
If varinit([M]TOTTYPELM,indice)=0
 IMPENT = 1
Endif
If varmode([M]TOTTYPELM,indice)=0
 Call INICOMBO(10355) From COMBOS
 [M]TOTTYPELM(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TOTTYPELM" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TOTTYPELM(indice)
 Endif
 If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
  mkstat = 1 : GMESSAGE = mess(99,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TOTTYPELM" : GZNUM = 3603 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]TOTTYPELM(indice) = IMPENT

## Zone TPS1
mkstat = 0
zoncou = "TPS1"
If varmode([M]TPS1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TPS1" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TIMVAR
mkstat = 0
zoncou = "TIMVAR"
If varmode([M]TIMVAR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TIMVAR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FRMIND
mkstat = 0
zoncou = "FRMIND"
If varmode([M]FRMIND,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FRMIND" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FLGFRM
mkstat = 0
zoncou = "FLGFRM"
IMPENT = [M]FLGFRM(indice)
If varinit([M]FLGFRM,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGFRM,indice)=0
 [M]FLGFRM(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGFRM" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGFRM(indice)
 Endif
Endif
[M]FLGFRM(indice) = IMPENT

## Zone BPAG
mkstat = 0
zoncou = "BPAG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "GENEMPTMP"
Return

