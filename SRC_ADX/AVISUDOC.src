#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = "E:\TEMP\Clients.csv"
Call SAISIE_CHAR(VALEUR,PARAM,"AVISUDOC","AVISUDOC","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT" : Gosub DEBUT
Endcase
Return

$DEBUT
[M]DOCUMENT = PARAM(1)
If GBROWS & pat(left$([M]DOCUMENT,3),"!:\") & GOS(1)="dos"
 Local Char SERVEUR(250)
 If adxmac(0)<>""
  SERVEUR = "\\"+adxmac(0)
 Else
  SERVEUR = "\\"+adxmac(-1)
 Endif
 [M]DOCUMENT = SERVEUR+right$([M]DOCUMENT,3)
Endif
Affzo
Return

Subprog AV_DOCUMENT(VALEUR)
Variable Char    VALEUR()
Diszo DOCUMENT
End
