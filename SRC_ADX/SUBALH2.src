#<AdxTL>@(#)5.0.0.0 $Revision$
Close Mask
Local Char PARAM(10)(1..3) , VALEUR(250)
PARAM(1) = "ZZMB"
PARAM(2) = "0"
PARAM(3) = "0"
Call TRAITE_CHAR(VALEUR,PARAM,"ALISTE","SUBALH2","ALISTE",6,"SPEALH") From GTRAITE
End

#---------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "AVANT_PAR"   : Gosub AVANT_PAR
 When "CONTROLE"    : Gosub CONTROLE
 When "TERMINE"     : Gosub TERMINE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "VERF_TABLE"  : Gosub VERF_TABLE

 When Default
  Case [F:ALH]TYP
   When 1 : Gosub ACT
   When 2 : Gosub ACTION From VISUSQL
   When 3 : Gosub ACT
  Endcase
Endcase
Return

#---------------------#
$ACT
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "TITRE"        : Gosub TIT
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "BOUTON"       : Gosub BOUTON
 When "SUI"          : Gosub SUIV
 When "PRE"          : Gosub PREC
 When "FIR"          : Gosub PREMIER
 When "LAS"          : Gosub DERNIER
 When "RAF"          : Gosub RAFFRAICHIR
 When "EDI"          : Gosub LISTE
 When "LIS"          : Gosub IMPRIME
 When "FIN"          : Gosub FIN
 When "END"          : GOK = 1 : FIN = 1
 When "ENV"          : Gosub CHGENV
 When "SORTIE"       : Gosub SORTIE
Endcase
Return

#-------------------------------------------------------------------------#
## GTRAITE
#-------------------------------------------------------------------------#

#---------------------#
$ALISTER
#CHECK UNUSED_BEGIN
If dim([F:ALH]TYPENV)>0 & GPRODUIT<>-1 & dim([F:ALR]DEP)<0
 If clalev([F:ALR])  : Close Local File [ALR] : Endif
 Local File ALISTENV [ALR]
Elsif !clalev([F:ALR])
 Local File ALISTER  [ALR]
Endif
#CHECK UNUSED_END
Return

#---------------------#

$INIT
If clalev([F:ALH])=0 : Local File ALISTEH [ALH] : Endif
If clalev([F:ALD])=0 : Local File ALISTED [ALD] : Endif
Gosub ALISTER
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:AOB])=0 : Local File AOBJET  [AOB] : Endif
If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
If clalev([F:ARP])=0 : Local File AREPORT [ARP] : Endif
If clalev([F:AXX2])=0 : Local File ATEXTRA [AXX2] : Endif

Local Char SYMBOLE(GLONASYM), LISTE(GLONALH)
Local Char SAVFONC(GLONAFC), SAV_PARAM(15)(1..3), SAV_DIV0(30)
Local Integer EXEC , OKTRT

If dim([V]GCHGENV)>0
 Local Integer SAV_GCHGENV
 [L]SAV_GCHGENV  = [V]GCHGENV
Endif
[L]SAVFONC = GFONCTION
[L]SAV_PARAM(1) = [L]PARAM(1)
[L]SAV_PARAM(2) = [L]PARAM(2)
[L]SAV_PARAM(3) = [L]PARAM(3)
[L]SAV_DIV0     = GDIV(0)
Return

#---------------------#
$AVANT_PAR
PARAM(1) = SAV_PARAM(1)
PARAM(2) = SAV_PARAM(2)
PARAM(3) = SAV_PARAM(3)
If dim([V]GCHGENV)>0
 [V]GCHGENV=[L]SAV_GCHGENV
Endif
Return

#---------------------#
$CONTROLE
If PARAM(1)=""
 FIN = 1
Else
 LISTE = PARAM(1)
 EXEC  = val(PARAM(3))
 Gosub CONTROLES
 If GERR
  If !val(PARAM(2)) : FIN=1 : Else : Close Local Mask : SAI=1 : Endif
 Else
  BOITE = MASQUE
 Endif
Endif
Return

#---------------------#
$CONTROLES
OK = 1
Read [ALH]ALH0 = LISTE
If fstat
 GERR = 1 : GMESSAGE = LISTE-":"-mess(23,100,1) : # Fiche inexistante
 OK = 0 : Return
Elsif [F:ALH]ACS<>"" & GUSRACS<>2 & [F:ALH]ALLUSR<>2
 If clalev([F:ACC])=0  : Local File ACCES    [ACC]  : Endif
 Read [ACC]CODACC = GUSER;[F:ALH]ACS
 If fstat or [F:ACC]CONSUL<>2
  GERR = 1 : GMESSAGE = LISTE-":"-mess(8,123,1) : # Accès impossible à cette fiche
  OK = 0 : Return
 Endif
Endif
If [F:ALH]FCTLNK<>"" & [F:ALH]ALLUSR<>2
 GFONCTION = [F:ALH]FCTLNK
 Call AUTORIS From EXEFNC
 If GNBAUZ=0
  GERR = 1 : GMESSAGE = mess(1,123,1) : # Fonction non autorisée
  OK = 0 : Return
 Endif
 GFONCTION = [L]SAVFONC
Elsif EXEC & EXEC<>9 & [F:ALH]ALLUSR=2
 # Requête partagée \ Exécution impossible
 GMESSAGE = [F:ALH]COD-":"-mess(14,127,1)+"\"+mess(160,115,1)+"\(EXEFLG)"
 GERR=1 : OK = 0 : Return
Else
 GFONCTION = SAVFONC
 Call AUTORIS From EXEFNC
Endif

Gosub SETPRG From SUBALH
Gosub SETMSK From SUBALH
WPROG   = PREFPRG+LISTE
MASQUE  = PREFMSK+LISTE

Call EXISTE_ADX("","",WPROG,OKTRT) From ORDSYS
If !OKTRT
 GERR = 1 : GMESSAGE = WPROG-":"-mess(90,123,1) : # Traitement inexistant
 OK = 0 : Return
Endif
If filinfo(filpath(adxrob(0),MASQUE,"msk"),0)<0
 GERR = 1 : GMESSAGE = MASQUE-":"-mess(72,123,1) : # Ecran inexistant
 OK = 0 : Return
Endif

GERREUR=0
Onerrgo CHUT From CONTROLE
Local Mask =MASQUE [LST]
Onerrgo
If GERREUR
 GERR = 1 : GMESSAGE = mess(157,123,1) : # Opération impossible
 FIN = 1 : OK=0 : Return
Endif

If dim([L]AFF)>0 & [L]AFF : # calcul via exécution de requête
 SYMBOLE = "ALH"-LISTE-GDIV(0)
 If GPRODUIT=1 & find([F:ALH]TYP,1,3) : UTIL0 = [M:LST]USR0 : Endif
 Return
Endif

GDIV(0)=GUSER : SYMBOLE = "ALH"-LISTE-GUSER
Lock =SYMBOLE With lockwait=0
If fstat & GPRODUIT=1 & find([F:ALH]TYP,1,3) & !(dim([L]AFF)>0 & ![L]AFF) : ## GEODE
 Gosub SET_IDENT
 GDIV(0)=IDENT : SYMBOLE = "ALH"-LISTE-IDENT
 Lock =SYMBOLE With lockwait=0
Endif
If fstat
 GERR = 1 : GMESSAGE = mess(30,100,1) : # Opération en cours
 OK=0 : Return
Endif

If [F:ALH]ALLUSR=2 : # En cours de calcul? Oui => affichage/calcul interdit
 Call QUILOCKE("ALH9"-LISTE-"",GERR,GCLE) From SUBALH9
 If GERR
  Gosub DEVERROU
  GERR = 1 : GMESSAGE = mess(10,100,1)-string$(GCLE<>"","("+GCLE+")") : # Modif en cours
  OK = 0 : Return
 Endif
Endif
Return

#---------------------#
$DEVERROU
If SYMBOLE<>""
 Unlock =SYMBOLE
 SYMBOLE=""
Endif
Return

#---------------------#
$TERMINE
GDIV(0) = [L]SAV_DIV0
Gosub DEVERROU
If GOK=2 : # Code
 FIN = 0
 SAI = 1
Endif
If clalev([M:LST])>0 : Close Local Mask [LST] : Endif
#18/05/2015 : SAM 108239
If dim([M:ALT1]CLBFL) > 0 and dim([M:ALT5]CLOB) > 0
 Sorta [M:ALT5]NBLIG [M:ALT5]NBLIG Order By [M:ALT5]NIV(indice) :#SAM 116798
 Call CREFLUX([M:ALT5]CLOB) From SUBALT
 [M:ALT1]CLBFL = [M:ALT5]CLOB
 Affzo [M:ALT1]CLBFL
Endif
Return

#---------------------#
$SORTIE
Inftxt " " At 2
GFONCTION = SAVFONC
Call AUTORIS From EXEFNC
If clalev([M:LST])>0 : Close Local Mask [LST] : Endif
Return

#-------------------------------------------------------------------------#
## GACTION
#-------------------------------------------------------------------------#

$SEL_TABLE
Case TABLE
 When "ALISTE","ALISTE2"
  If !val(PARAM(2))  : # pas de chg de liste
   OK=0 : Return
  Else
   Local Integer NBLIS, GRPOBJ, CRELIS
   Link [ALH] With [ACC]CODACC = GUSER;ACS As [ALHX]
   CRITERE = "[F:ALH]ENAFLG=2"
   Case val(PARAM(2))
    When 1 : # Liste par groupe
     If [L]PARAM(1)="*"
      CRITERE += " & [F:ALH]GRP<>''"
     Elsif [L]PARAM(1)<>""
      CRITERE += " & [F:ALH]GRP='"+[L]PARAM(1)+"'"
     Endif
    When 2 : # Liste tout groupe
     If [L]PARAM(1)<>""
      CRITERE += " & [F:ALH]COD='"+[L]PARAM(1)+"'"
     Endif
   Endcase
   CRITERE += " & ([F:ALH]ALLUSR=2"
   CRITERE += " | GUSRACS=2 | [F:ALH]ACS='' | [F:ACC]CONSUL=2 | [F:ACC]MODIF=2 | [F:ACC]EXEC=2)"
   For [ALHX]ALH0 Where evalue(CRITERE)
    If [L]NBLIS=0 : [L]PARAM(1) = [F:ALH]COD : Endif
    [L]NBLIS += 1
    If [L]NBLIS>=2 : Break : Endif
   Next ALHX
   Case [L]NBLIS
    When 0
     OK=0 : # pas de choose
     If !find([L]PARAM(1),"","*") & GPRODUIT=1 & GFONCTION="GES"+[L]PARAM(1) : ## GEODE
      Read [ALH]ALH0=[L]PARAM(1)
      If fstat>2
       [L]CRELIS = 2
       Call OUINON(mess(23,310,1),[L]CRELIS) From GESECRAN : #  Liste inexistante, création
       If [L]CRELIS=2
        Call CRELIS(nomap,[L]PARAM(1),0,[L]CRELIS) From SUBALH1
        If [L]CRELIS
         Read [ALH]ALH0 = [L]PARAM(1)
         PARAM(2)="0" : PARAM(3)="9" : Return
        Endif
       Endif
      Else
       Call MESSAGE(mess(22,310,1)) From GESECRAN : # Liste inexistante
      Endif
     Endif
    When 1
     OK = 0 : PARAM(2)="0" : Return
    When Default
     VALEUR = ""
     OBJET = "ALH"
     Call GET_DERLU(VALEUR,OBJET,"ENAFLG=2") From GOBJACT
     OPTIONS = "#"
   Endcase
  Endif
  PARAM(1)=""
Endcase
Return

#--------------------------------#
$VERF_TABLE
Case TABLE
 When "ALISTE", "ALISTE2"
  PARAM(1) = [F:ALH]COD
  Local File ALISTEH [AX__]
  Read [AX__]ALH0=[F:ALH]COD
  If !fstat & find([F:AX__]TYP,1,3)
   Call SET_DERLU("ALH",[F:ALH]COD+'~') From GOBJACT
  Endif
  Close Local File [AX__]
Endcase
Return

#-------------------------------------------------------------------------#
## GSAISIE
#-------------------------------------------------------------------------#

$OUVRE
Local Integer MAXCOL , NIVCUM
MAXCOL = 100
NIVCUM = 16
Local Integer EXEC , CHGTLIS
Local Integer I , J , K , ER , NOL , NBCRIT
Local Char    LISTE(GLONALH) , WPROG(GLONADC) , MASQUE(GLONAMK) , TIMED(4)
Local Char    AOBSIT(10), AOBACC(10), AOBFIC(10), LNKFIC(5)
Local Date    DATED
Local Integer NIVEAU , NBGRP , NBLIG , NBCOL , NBNIV , TIM , TEMPO , MAXTIM , MAXLIG , TRI(1..NIVCUM)
Local Integer NB , PAGE , DEBLIG , FINLIG , MAXPAG , PLEIN , TYP
Local Integer CUM(1..MAXCOL) , GRP(1..MAXCOL) , TBTYP(1..MAXCOL) , COLGRP , SNSGRP
Local Integer NBB(1..NIVCUM) , ONB(1..NIVCUM)
Local Integer ICRIT
Local Char    SAV_CHAR(50)
Local Decimal SAV_DECI
Local Date    SAV_DATE
Local Integer FLPOS
Local Integer DEBUG
Local Integer TBNIV(1..MAXCOL)
Local Char    UTIL(15), UTIL0(15)
Local Char    TITLIS(80)
Local Char    SAV_REPORT1(GLONARP), SAV_REPORT2(GLONARP)
Local Char    SAV_PARAM(250)(4..6)
If  GPRODUIT=1 : ## GEODE
 If dim([F:ALH]TYPENV)>0
  Local Char SAV_FCY(GLONFCY), SAV_DEP(GLONDEP)
 Endif
 Local Char SAV_FCY6(GLONFCY), SAV_DEP6(GLONDEP)
 Local Integer SAV_ENV6
Endif

SAV_REPORT1 = GREPORT1 : GREPORT1=""
SAV_REPORT2 = GREPORT2 : GREPORT2=""

LISTE       = PARAM(1)
CHGTLIS     = val(PARAM(2))
EXEC        = val(PARAM(3))
If dim([L]PARAM)>3
 If GPRODUIT=1 : ## GEODE
  I=instr(1,PARAM(6),","): # FCY~DEP,2
  J=instr(1,PARAM(6),"~")
  If J
   SAV_FCY6 = [V]GFCY
   SAV_DEP6 = [V]GDEP
   SAV_ENV6 = 1
   GFCY=left$(PARAM(6),J-1)
   If !I : GDEP=right$(PARAM(6),J+1)   : PARAM(6)=""
   Else  : GDEP=seg$(PARAM(6),J+1,I-1)
   Endif
  Endif
  If I
   PARAM(6)=right$(PARAM(6),I+1)
  Endif
 Endif
 SAV_PARAM(4)=PARAM(4)
 SAV_PARAM(5)=PARAM(5)
 SAV_PARAM(6)=PARAM(6)
 If PARAM(7)<>""  : TITLIS = PARAM(7)
 Else
  If PARAM(4)<>"" : TITLIS = PARAM(4) : Endif
  If PARAM(5)<>"" : TITLIS = TITLIS-string$(TITLIS<>"","&")-PARAM(5) : Endif
 Endif
Endif

Gosub SETPRG From SUBALH
Gosub SETMSK From SUBALH
WPROG   = PREFPRG+LISTE
MASQUE  = PREFMSK+LISTE
NBCRIT = 0
K = 0
For [ALD] Where COD=LISTE
 K += 1
 TBNIV(K) = [F:ALD]NIV
 If find([F:ALD]STREND,2,3)
  NBCRIT += 1
 Endif
Next
REPORT1 = "ALISTE"
REPORT2 = "ALISTE"
If dim([F:ALH]TYPENV)>0 & GPRODUIT=1
&  & (instr(1,adxpno(3),"EXEFNC") | instr(1,adxpno(3),"GESUSER")) : ## GEODE
 If dim([L]PARAM)<6 | !find([L]PARAM(6),"1","2","0")
  K = [F:ALH]TYPENV
 Else
  K = val([L]PARAM(6))
 Endif
 Case K
  When 1       : GCHGENV=1
  When 2       : GCHGENV=2
  When Default : GCHGENV=0
 Endcase
 CHGENV=GCHGENV
Endif
Return

#--------------------------------#
$SET_ENV
If dim([F:ALH]TYPENV)<0 : Return : Endif
If GPRODUIT=1 : ## GEODE
 Local Char    LFCY(GLONFCY), LDEP(GLONDEP)
 Call LECTURE("ALH",LISTE,"") From CONTOBJ
 If dim([L]PARAM)<6 | !find([L]PARAM(6),"1","2","0")
  Case [F:ALH]TYPENV
   When 1 : LFCY=GFCY
   When 2 : LFCY=GFCY : LDEP=GDEP
  Endcase
 Else
  Case [L]PARAM(6)
   When "1" : LFCY=GFCY
   When "2" : LFCY=GFCY : LDEP=GDEP
  Endcase
 Endif
Endif
Return

#--------------------------------#
$CHGENV
FOK=0
Gosub SET_ENV
If dim([F:ALH]TYPENV)>0 & [F:ALH]TYPENV
 Gosub DEBUT
Endif
Return

#--------------------------------#
$TIT
Call LECTEXTRA(TIT,"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA
If TITLIS="" & GPRODUIT=1 & CHGENV : ## GEODE
 Call TITENV(CHGENV,TIT) From LOGDIV
Elsif vireblc(TITLIS,2)<>""
 TIT = TIT-"-"-TITLIS
Endif
Return

#--------------------------------#
$SET_IDENT
Local Char IDENT(15)
IDENT=format$("K:"+num$(GLONAUS)+"X",GUSER)+num$(adxuid(2))
Return

#--------------------------------#
$DEBUT
Raz [M:LST]
#If GFUSION : Chgfmt [M:LST]PAGP With "-K:1X" : Endif # 115490
Gosub DEFVAR From =WPROG
Gosub SET_ENV
UTIL0 = GDIV(0)
If UTIL0=GUSER & [F:ALH]ALLUSR<>2 & GPRODUIT=1 : ## GEODE
 Gosub SET_IDENT
 Read [ALR]ALR0(4) = LISTE;LFCY;LDEP;IDENT
 If fstat<2 : UTIL=IDENT : UTIL0=IDENT : Endif
Endif
If GPRODUIT=1 : [M:LST]USR0 = UTIL0 : Endif : # GH 27/04/05 bug 29996
If EXEC
 If EXEC=9 : EXEC=0 : Endif : ## CRELIS
 Call SUBALH9(LISTE,0,SAV_PARAM(4),SAV_PARAM(5),SAV_PARAM(6))
 If GOK=1 : Gosub SET_UTIL From SUBALH9 : Else UTIL="" : Endif
Elsif [F:ALH]ALLUSR=3
 UTIL=""
Else
 If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
  If [F:ALH]ALLUSR=2
   Read [ALR]ALR0(3) = LISTE;LFCY;LDEP
  Else
   Read [ALR]ALR0(4) = LISTE;LFCY;LDEP;UTIL0
  Endif
 Elsif [F:ALH]ALLUSR=2
  Read [ALR]ALR0(1) = LISTE
 Else
  Read [ALR]ALR0(2) = LISTE;UTIL0
 Endif
 If !fstat
  UTIL = [F:ALR]USR
 Else
  UTIL = ""
  If UTIL0<>GUSER & [F:ALH]ALLUSR<>2 : ## GEODE
   Call TEMPON("O") From GESECRAN
   ## copie [ALR]USR = GUSER -> IDENT
   GOK=1
   Trbegin [ALR]
    For [ALR] Where COD=LISTE & USR=GUSER & FCY=LFCY & DEP=LDEP
     [F:ALR]USR=UTIL0
     Write [ALR]
     If fstat
      GOK = 0 : Call FSTA("ALR") From GLOCK : Break
     Else
      GOK = 2
     Endif
    Next
   If GOK : Commit   : If GOK=2 : GOK=1 : UTIL=UTIL0 : Endif
   Else   : Rollback
   Endif
   Call TEMPOFF From GESECRAN
  Endif
 Endif
Endif

If UTIL<>""
 For NIVEAU=1 To NBGRP+1
  If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
   Read [ALR]ALR0 = LISTE;LFCY;LDEP;UTIL;NIVEAU;0;0
  Else
   Read [ALR]ALR0 = LISTE;UTIL;NIVEAU;0;0
  Endif
  NBB(NIVEAU) = [F:ALR]NUM
 Next NIVEAU
Else
 Raz NBB
Endif
NBNIV  = NBGRP+1 : # max(TBNIV(1..K))
If GPRODUIT=1 : NIVEAU=1 : ## GEODE
Else          : NIVEAU = NBGRP+1
Endif
Gosub LECTURE
If GPRODUIT=1 & CHGENV=0 & SAV_ENV6 : ## GEODE
 Call AFF_ENV From MENU
Endif
Return

#--------------------------------#
$FIN
GREPORT1 = SAV_REPORT1
GREPORT2 = SAV_REPORT2
If GPRODUIT=1 & SAV_ENV6 : ## GEODE
 GFCY=SAV_FCY6
 GDEP=SAV_DEP6
 Call AFF_ENV From MENU
Endif
Return

#--------------------------------#
$AVANT_BOUTON
Case BOUT
 When "X" : # Export
  If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
   SAV_FCY = GFCY : GFCY = LFCY
   SAV_DEP = GDEP : GDEP = LDEP
  Endif
Endcase
Return

#--------------------------------#
$BOUTON
Case BOUT
 When "R" : # Critères
  If GOK=1
   Read [ALH]ALH0 = LISTE
   Gosub SET_UTIL From SUBALH9
   Gosub LECTURE
  Endif
 When "P" : # Niveau +
  NIVEAU = min(NIVEAU+1,NBNIV) : # min(NIVEAU+1,NBGRP+1)
  Gosub SAUVE_POS
  Gosub LECTURE
  Gosub REST_POS
 When "M" : # Niveau -
  NIVEAU = max(NIVEAU-1,1)
  Gosub SAUVE_POS
  Gosub LECTURE
  Gosub REST_POS
 When "C" : # Code
  GOK = 2
  FIN = 1
 When "H" : # Recherche
  Gosub RECHERCHE
Endcase
If find(BOUT,"X","G") & dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 GFCY = SAV_FCY : GDEP = SAV_DEP
Endif
Return

#--------------------------------#
$SAUVE_POS
If nolign>0 & evalue("dim([M:LST]C"+format$("N0:2#",COLGRP)+")")>nolign
 Case evalue("type([M:LST]C"+format$("N0:##",COLGRP)+")")
  When 1,2,4,5,6,7,8,9
   SAV_DECI = evalue("[M:LST]C"+format$("N0:2#",COLGRP)+"("+num$(nolign-1)+")")
  When 3
   SAV_DATE = evalue("[M:LST]C"+format$("N0:2#",COLGRP)+"("+num$(nolign-1)+")")
  When Default
   SAV_CHAR = evalue("[M:LST]C"+format$("N0:2#",COLGRP)+"("+num$(nolign-1)+")")
 Endcase
Endif
FLPOS = 1
Return

#--------------------------------#
$REST_POS
For nolign=1 To [M:LST]NBLIG
 Case evalue("type([M:LST]C"+format$("N0:##",COLGRP)+")")
  When 1,2,4,5,6,7,8,9
   If SAV_DECI=evalue("[M:LST]C"+format$("N0:##",COLGRP)+"(nolign-1)") : Break : Endif
  When 3
   If SAV_DATE=evalue("[M:LST]C"+format$("N0:##",COLGRP)+"(nolign-1)") : Break : Endif
  When Default
   If SAV_CHAR=evalue("[M:LST]C"+format$("N0:##",COLGRP)+"(nolign-1)") : Break : Endif
 Endcase
Next nolign
zonsui = "NBLIG("+num$(nolign-1)+")"
FLPOS = 0
Return

#--------------------------------#
$SETBOUT
If !CHGTLIS         : Call VIREBOUT(CHMEN,"C") From GOBJET : Endif
If !NBCRIT          : Call VIREBOUT(CHMEN,"R") From GOBJET : Endif
If !NBGRP           : Call VIREBOUT(CHMEN,"PM") From GOBJET
Else
 If NBNIV>0
  If NIVEAU>=NBNIV  : Call VIREBOUT(CHMEN,"P") From GOBJET : Endif
  If NIVEAU<=1      : Call VIREBOUT(CHMEN,"M") From GOBJET : Endif
 Endif
Endif
If ![M]NBLIG  : Call VIREBOUT(CHMEN,"X") From GOBJET : Endif
CHBOU += "IL"
If ![M]NBLIG        : Call VIREBOUT(CHBOU,"IL") From GOBJET : Endif
If PAGE<=1          : Call VIREBOUT(CHBOU,"0<") From GOBJET : Endif
If PAGE>=MAXPAG     : Call VIREBOUT(CHBOU,"9>") From GOBJET : Endif
CHBOU += "=" : # Rafraîchir
If [F:ALH]ACS<>""
 Read [ACC]CODACC = GUSER ; [F:ALH]ACS
 If fstat or [F:ACC]EXEC<>2
  Call VIREBOUT(CHMEN,"RH") From GOBJET
  Call VIREBOUT(CHBOU,"=") From GOBJET
 Endif
Endif
Return

#--------------------------------#
$RAFFRAICHIR
Read [ALH]ALH0 = LISTE

#--------------------------------#
$RECHERCHE
Call SUBALH9(LISTE,0,SAV_PARAM(4),SAV_PARAM(5),SAV_PARAM(6))
If !GOK : Return : Endif
Gosub SET_UTIL From SUBALH9

#--------------------------------#
#--------------------------------#
$LECTURE
Gosub ENT
MAXPAG = int((NB-1)/[L]NBLIG)+1
PAGE = 1
Effzo [M:LST]20 : # Tableau
NOL = -1
Gosub AFF2
Return

$ER
ER = errn
Resume

#-----------------------------#
$ENT
If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 Read [ALR]ALR0 = LISTE;LFCY;LDEP;UTIL;NIVEAU;0;0
Else
 Read [ALR]ALR0 = LISTE;UTIL;NIVEAU;0;0
Endif
If !fstat
 NB    = [F:ALR]NUM
 TEMPO = val([F:ALR]VLR)
 [M:LST]DAT  = [F:ALR]CREDAT
 If dim([F:ALR]CRETIM)>0 : [M:LST]TIM  = [F:ALR]CRETIM : Endif
 [M:LST]USR  = [F:ALR]USR
Else
 Raz [M:LST]DAT, [M:LST]TIM, [M:LST]USR, TEMPO, NB
Endif
Return

#--------------------------------#
$AFF
Raz [M:LST]
NOL = -1
Gosub ENT
Gosub AFF2
Return

#--------------------------------#
$AFF2
DEBLIG = (PAGE-1)*[L]NBLIG+1
FINLIG = PAGE*[L]NBLIG
If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 Filter [ALR] Where COD=LISTE & USR=UTIL & NIV=NIVEAU & LIG>=DEBLIG & LIG<=FINLIG
&                 & FCY=LFCY & DEP=LDEP
Else
 Filter [ALR] Where COD=LISTE & USR=UTIL & NIV=NIVEAU & LIG>=DEBLIG & LIG<=FINLIG
Endif
For [ALR]ALR0
 NOL = [F:ALR]LIG-DEBLIG
 Case [F:ALR]COL
  When -1 : If dim([M:LST]FCY)>1 : [M:LST]FCY(NOL) = [F:ALR]VLR : Endif
  When -2 : If dim([M:LST]DEP)>1 : [M:LST]DEP(NOL) = [F:ALR]VLR : Endif
  When Default
   If dim([M:LST]FCY)>1 & [M:LST]FCY(NOL) = "" : [M:LST]FCY(NOL) = GFCY : Endif
   If dim([M:LST]DEP)>1 & [M:LST]DEP(NOL) = "" : [M:LST]DEP(NOL) = GDEP : Endif
   ER = 0
   Onerrgo ER
   Case [F:ALR]TYP
    When 7       : Assign "[M:LST]C"+format$("N0:##",[F:ALR]COL)+"("+num$(NOL)+")" With [F:ALR]VLR
    When 8       : Assign "[M:LST]C"+format$("N0:##",[F:ALR]COL)+"("+num$(NOL)+")" With [F:ALR]DAT
    When Default : Assign "[M:LST]C"+format$("N0:##",[F:ALR]COL)+"("+num$(NOL)+")" With [F:ALR]NUM
   Endcase
   Onerrgo
 Endcase
Next
Filter [ALR]
[M:LST]COD    = LISTE
Call LECTURE("ALH",LISTE,"") From CONTOBJ : # GH 14/10/01 les links razent [F:ALH]
Call LECTEXTRA([M:LST]DES,"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA
[M:LST]NBLIG  = NOL+1
[M:LST]LIG    = NB
[M:LST]PAG    = PAGE
[M:LST]PAGMAX = MAXPAG
[M:LST]PAGP   = num$(PAGE)+"/"+num$(PAGMAX)
[M:LST]NIV    = NIVEAU
[M:LST]NIVMAX = NBNIV : # NBGRP+1
[M:LST]NIVP   = num$(NIVEAU)+"/"+num$(NBGRP+1)
[M:LST]TEMPO  = TEMPO
If FLPOS & PAGE<MAXPAG
 Case evalue("type([M:LST]C"+format$("N0:2#",COLGRP)+")")
  When 1,2,4,5,6,7,8,9
   Case SNSGRP
    When 2
     If SAV_DECI>evalue("[M:LST]C"+format$("N0:##",COLGRP)+"("+num$([M:LST]NBLIG-1)+")")
      PAGE += 1 : Goto AFF2
     Endif
    When Default
     If SAV_DECI<evalue("[M:LST]C"+format$("N0:##",COLGRP)+"("+num$([M:LST]NBLIG-1)+")")
      PAGE += 1 : Goto AFF2
     Endif
   Endcase
  When 3
   Case SNSGRP
    When 2
     If SAV_DATE>evalue("[M:LST]C"+format$("N0:##",COLGRP)+"("+num$([M:LST]NBLIG-1)+")")
      PAGE += 1 : Goto AFF2
     Endif
    When Default
     If SAV_DATE<evalue("[M:LST]C"+format$("N0:##",COLGRP)+"("+num$([M:LST]NBLIG-1)+")")
      PAGE += 1 : Goto AFF2
     Endif
   Endcase
  When Default
   Case SNSGRP
    When 2
     If SAV_CHAR>evalue("[M:LST]C"+format$("N0:##",COLGRP)+"("+num$([M:LST]NBLIG-1)+")")
      PAGE += 1 : Goto AFF2
     Endif
    When Default
     If SAV_CHAR<evalue("[M:LST]C"+format$("N0:##",COLGRP)+"("+num$([M:LST]NBLIG-1)+")")
      PAGE += 1 : Goto AFF2
     Endif
   Endcase
 Endcase
Endif

Affzo [LST]

#If [M:LST]LIG=0
# Inftxt mess(151,126,1) At 2 : # Enter criteria or press F5 to refresh
#Else
# Inftxt " " At 2
#Endif
# X3-98606 27.07.2018
Return

#--------------------------------#
$SUIV
PAGE = min(PAGE+1,MAXPAG)
Gosub AFF
Return

$PREC
PAGE = max(PAGE-1,1)
Gosub AFF
Return

$DERNIER
PAGE = MAXPAG
Gosub AFF
Return

$PREMIER
PAGE = 1
Gosub AFF
Return

#--------------------------------#
$LISTE
Call HCOPY("WN"+[M:LST]COD,"LST",[M:LST]DES)
Return

#--------------------------------#
$IMPRIME
Local Char    ETAT(16),ETATDES(16)
Local Char    TBPAR(10)(1..60),TBVAL(30)(1..60),FONT(40)(1..16)
Local Char    DIRBIN(GDIMFIC),DIRRPT(GDIMFIC),MACHINE(GDIMFIC)
Local Integer NBPAR,TAILLETIT(1..16),TAILLEMAX(1..16),UNDERLINE(1..16),BOLD(1..16),ITALICS(1..16)

If clalev([F:AST])=0 : Local File APLSTD [AST] : Endif

If dim([F:ALH]RPT)>0 & [F:ALH]RPT<>""
 ETAT    = [F:ALH]RPT
 ETATDES = ETAT
Else
 ETAT = "ALISTE"
Endif

If ETAT="ALISTE"
 If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
  ETATDES = "ALISTENV"
 Else
  ETATDES = "ALISTE"
 Endif
Endif

NBPAR = 0
NBPAR += 1 : TBPAR(NBPAR)="liste"  : TBVAL(NBPAR) = LISTE
NBPAR += 1 : TBPAR(NBPAR)="user"   : TBVAL(NBPAR) = UTIL
NBPAR += 1 : TBPAR(NBPAR)="titre"
Call LECTEXTRA(TBVAL(NBPAR),"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA
If TITLIS<>"" : TBVAL(NBPAR) -= "-"-TITLIS : Endif
NBPAR += 1 : TBPAR(NBPAR)="niveau" : TBVAL(NBPAR) = num$(NIVEAU)

K = 0
I = 0
For [ALD]ALD0 Where COD=LISTE & STREND<=2
 I += 1
 If NIVEAU=NBGRP+1 or CUM(I)<>0 or (GRP(I)<>0 & GRP(I)<=NIVEAU) or TBNIV(I)<=NIVEAU
  NBPAR += 1 : K += 1
  TBPAR(NBPAR) = "titre"+num$(K)
  #Call LECTEXTRA(TBVAL(NBPAR),"ALISTED","INTITLIG",[F:ALD]COD,num$([F:ALD]LIG)) From ATEXTRA # 118987 - columnn titles incorrect
  Call LECTEXTRA(TBVAL(NBPAR),"ALISTED","INTITLIG",[F:ALD]COD,num$([F:ALD]NUMTEX)) From ATEXTRA  # 118987 - columnn titles incorrect
  TAILLETIT(K) = len(TBVAL(NBPAR))
  NBPAR +=1
  TBPAR(NBPAR) = "col"+num$(K)   : TBVAL(NBPAR) = num$(I)
  NBPAR += 1
  TBPAR(NBPAR) = "cum"+num$(K)
  If CUM(I)<>0
   TBVAL(NBPAR) = "2"
  Else
   TBVAL(NBPAR) = "1"
  Endif
  If K>=16 : Break : Endif
 Endif
Next
For I=K+1 To 16
 NBPAR += 1
 TBPAR(NBPAR) = "titre"+num$(I) : TBVAL(NBPAR) = ""
 NBPAR += 1
 TBPAR(NBPAR) = "col"+num$(I)   : TBVAL(NBPAR) = "0"
 NBPAR += 1
 TBPAR(NBPAR) = "cum"+num$(I)
 TBVAL(NBPAR) = "1"
Next I
NBPAR += 1
TBPAR(NBPAR) = "grp"
If NIVEAU>1
 TBVAL(NBPAR) = num$(GRP(1))
Else
 TBVAL(NBPAR) = "0"
Endif

If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 NBPAR += 1 : TBPAR(NBPAR)="ldep"  : TBVAL(NBPAR) = LDEP
 NBPAR += 1 : TBPAR(NBPAR)="lfcy"  : TBVAL(NBPAR) = LFCY
Endif

Call ETAT(ETATDES,GFONCTION,TBPAR,TBVAL) From ETAT
Return

###############################
Subprog HCOPY(NOMMSK,ABMSK,TIT)
Value Char NOMMSK
Value Char ABMSK
Value Char TIT
###############################
Call PRTSCR(NOMMSK,ABMSK,TIT,0,0) From ATRTX3
Call IMPSCR From ATRTX3
End

#############################################
Subprog SUBALH9(LISTE,BCRIT,CRIT1,CRIT2,OPT)
Value Char    LISTE(), CRIT1(), CRIT2(), OPT()
Value Integer BCRIT
Local Char PARAM(250)(1..7) , VALEUR(10)
PARAM(1) = LISTE
PARAM(2) = "0"
PARAM(3) = "1"
PARAM(4) = CRIT1
PARAM(5) = CRIT2
PARAM(6) = OPT
If !BCRIT
 Call TRAITE_CHAR(VALEUR,PARAM,"","SUBALH9","",4,"SPEALH") From GTRAITE
Else
 Call TRAITE_CHAR(VALEUR,PARAM,"","SUBALH9","ALH9",4,"SPEALH") From GTRAITE
Endif
End

