[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_DISCRGREN1
Gosub DECLARE_VAR From WMC0SQUOTED
[L]CURPRO = "DISCRGREN1"
$_LNKPRO_DISCRGREN1
