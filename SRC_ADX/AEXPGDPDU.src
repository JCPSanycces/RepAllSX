#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(30)(1..10) , VALEUR(10)
PARAM = "ENT"
Call TRAITE_CHAR(VALEUR,PARAM,"","AEXPGDPDU","",2,"") From GTRAITE
End

#-------------------------------------------#
$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "AVANT_PAR" : Gosub AVANT_PAR
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
 When "TERMINE"   : Gosub TERMINE
Endcase
Return

#-------------------------------------------#
# Export GDPDU
#-------------------------------------------#

$INIT
If clalev([F:AEN])=0 : Local File AENCHAINE [AEN] : Endif
If clalev([F:AOE])=0 : Local File AOBJEXT   [AOE] : Endif
If clalev([F:AOD])=0 : Local File AOBJEXTD  [AOD] : Endif
If clalev([F:AOR])=0 : Local File AOBJEXTR  [AOR] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ATI])=0 : Local File ATABIND   [ATI] : Endif
If clalev([F:AOB])=0 : Local File AOBJET    [AOB] : Endif
If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV     [ACV] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA   [AXX] : Endif
Return

#-------------------------------------------#
$AVANT_PAR
TIT = mess(51,107,1)-"GDPDU" : # Génération
Return

#-------------------------------------------#
$TERMINE
Call OUVRE_TRACE(mess(104,121,1)-":\|"+FICHIER) From LECFIC : # Fichier généré
Openi FICHIER,0 Using [HTI_]
Iomode adxifs "" Using [HTI_]
Iomode adxirs chr$(10) Using [HTI_]
Iomode adxium GUTF8 Using [HTI_]
Rdseq CHAINE Using [HTI_]
While !fstat
 Call ECR_TRACE(CHAINE,0) From GESECRAN
 Rdseq CHAINE Using [HTI_]
Wend 
Openi Using [HTI_]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Return

#-------------------------------------------#
$CONTROLE
Local Char    ENCHAINE(10) , CHAINE(250) , FICDTD(GDIMFIC)
Local Char    CLE(GLONAVA)(1..16) , NOMFIC(GLONATB)
Local Integer I , J , K , NBCLE
Local Char    FLD(30) , ZONE(50) , INTIT(50)
Local Char    TYP(GLONATY)
Local Integer LNG , MNL , NBTAB , DIME
Local Char    TAB(30)(1..50)
ENCHAINE = PARAM
Read [AEN]CODE(0)=ENCHAINE
If fstat
 GMESSAGE = ENCHAINE-":"-mess(169,141,1)-ENCHAINE : # Enchainement inexistant
 FIN = 1 : Return
Else
 Read [AOE]AOE0=[F:AEN]MODELE
 If fstat or [F:AOE]TYPFIL<>7
  GMESSAGE = ENCHAINE-":"-mess(170,141,1)-ENCHAINE : # Enchainement incorrect
  FIN = 1 : Return
 Endif
Endif
Return

#-------------------------------------------#
$EXEC
FICDTD = "gdpdu-01-08-2002"
FICHIER = filpath("tmp",FICDTD,"dtd")
If filinfo(FICHIER,0)<=0
 Openo FICHIER,0 Using [AXML]
 Wrseq "" Using [AXML]
 Openo Using [AXML]
Endif
FICHIER = filpath("tmp",ENCHAINE,"xml")
Openo FICHIER,0 Using [AXML]
Iomode adxifs "" Using [AXML]
Iomode adxirs chr$(10) Using [AXML]
Iomode adxium GUTF8 Using [AXML]
Wrseq '<?xml version="1.0" encoding="'+tolower(mess(2,945,1))+'" ?>' Using [AXML]
Wrseq '<!DOCTYPE DataSet SYSTEM "'+FICDTD+'.dtd">' Using [AXML]
Wrseq '<!---             X   X  XXX                                   -->' Using [AXML]
Wrseq '<!---              X X     X                                   -->' Using [AXML]
Wrseq '<!---               X     X                                    -->' Using [AXML]
Wrseq '<!---              X X     X                                   -->' Using [AXML]
Wrseq '<!---             X   X  XXX                                   -->' Using [AXML]
Wrseq '<DataSet>' Using [AXML]
Wrseq '    <Version>1.1</Version>' Using [AXML]
Wrseq '    <DataSupplier>' Using [AXML]
Wrseq '        <Name>'+func CARSPEXML([L]ENCHAINE)+'</Name>' Using [AXML]
Wrseq '        <Location></Location>' Using [AXML]
Wrseq '        <Comment>'+func TEXTRA("AENCHAINE","DES",[L]ENCHAINE,"")+'</Comment>' Using [AXML]
Wrseq '    </DataSupplier>' Using [AXML]
Wrseq '    <Media>' Using [AXML]
Wrseq '        <Name></Name>' Using [AXML]
For [AEN]CODE Where CODE=[L]ENCHAINE
 Read [AOE]AOE0=[F:AEN]MODELE
 If !fstat
  Gosub MODELE
 Endif
Next AEN
Wrseq '    </Media>' Using [AXML]
Wrseq '</DataSet>' Using [AXML]
Openo Using [AXML]
Return

#-------------------------------------------#
$MODELE
Wrseq '        <Table>' Using [AXML]
Wrseq '            <URL>'+func FICHIER([F:AEN]CHEMIN)+'</URL>' Using [AXML]
Wrseq '            <Name>'+func CARSPEXML([F:AEN]MODELE)+'</Name>' Using [AXML]
Wrseq '            <Description>'+func TEXTRA("AOBJEXT","INTIT",[F:AEN]MODELE,"")+'</Description>' Using [AXML]
Wrseq '            <Validity>' Using [AXML]
Wrseq '                <Range>' Using [AXML]
Wrseq '                    <From>'+func DATDEB([F:AEN]MODELE)+'</From>' Using [AXML]
Wrseq '                    <To>'+func DATFIN([F:AEN]MODELE)+'</To>' Using [AXML]
Wrseq '                </Range>' Using [AXML]
Wrseq '            </Validity>' Using [AXML]
Wrseq '            <DecimalSymbol>'+[F:AOE]SEPDEC+'</DecimalSymbol>' Using [AXML]
Wrseq '            <DigitGroupingSymbol>'+''+'</DigitGroupingSymbol>' Using [AXML]
Wrseq '            <Range><From>'+'2'+'</From></Range>' Using [AXML]
Wrseq '            <VariableLength>' Using [AXML]
Wrseq '                <!-- <TextEncapsulator/> -->' Using [AXML]
Gosub SETCLE
For K=1 To NBCLE
 Read [ATZ]CODZONE=NOMFIC;CLE(K)
 If !fstat and func ACTIV([F:ATZ]CODACT) 
  ZONE  = CLE(K)
  INTIT = func TEXTE([F:ATZ]NOCOURT)
  LNG   = [F:ATZ]LONG
  MNL   = [F:ATZ]NOLIB
  TYP   = [F:ATZ]CODTYP
  Gosub SETTYP
  Wrseq '                <VariablePrimaryKey>' Using [AXML]
  Gosub ZONE
  Wrseq '                </VariablePrimaryKey>' Using [AXML]
 Endif
Next K
For [AOD]AOD0 Where EXT=[F:AOE]EXT
 Raz TYP , LNG , MNL , INTIT
 If find(left$([F:AOD]FLD,1),"/","*","=","'",'"',"")
  TYP = "A"
  LNG = 10
  ZONE = [F:AOD]TYP+"__"+num$([F:AOD]NUMLIG)
  INTIT = func TEXTRA("ATABLE","INTFLD",[F:AOD]EXT,[F:AOD]FIL+[F:AOD]FLD)
 Else
  K = instr(1,[F:AOD]FLD,"(")
  If K
   DIME = val(right$([F:AOD]FLD,K+1))
   FLD  = left$([F:AOD]FLD,K-1)
   ZONE = FLD+"_"+num$(DIME)
  Else
   FLD  = [F:AOD]FLD
   ZONE = [F:AOD]FLD
  Endif
  Read [ATZ]CODZONE=[F:AOD]FIL;[L]FLD
  If !fstat and func ACTIV([F:ATZ]CODACT) 
   INTIT = func TEXTE([F:ATZ]NOCOURT)
   LNG   = [F:ATZ]LONG
   MNL   = [F:ATZ]NOLIB
   TYP   = [F:ATZ]CODTYP
  Else
   INTIT = ""
   TYP   = "A"
   LNG   = 10 
  Endif
 Endif
 Gosub SETTYP
 Wrseq '                <VariableColumn>' Using [AXML]
 Gosub ZONE  
 Wrseq '                </VariableColumn>' Using [AXML]
Next AOD
Wrseq '            </VariableLength>' Using [AXML]
Wrseq '        </Table>' Using [AXML]
Return

#-------------------------------------------#
$SETTYP
Read [ATY]CODTYP=TYP
If !fstat
 If [F:ATY]LNGTYP>0
  LNG = [F:ATY]LNGTYP
 Endif
 If [F:ATY]TYPTYP=1
  Case [F:AOE]OPTMNL
   When 0       : LNG = 3
   When 1       : LNG = 1
   When Default : LNG = [F:AOE]OPTMNL
  Endcase
  If [F:ATY]NOLIB<>0
   MNL = [F:ATY]NOLIB
  Endif
 Endif
Else
 TYP = "A"
 LNG = 10
Endif
Read [ATY]CODTYP=TYP
Return

#-------------------------------------------#
Funprog ACTIV(CODACT)
Value Char CODACT
If CODACT<>""
 Read [ACV]CODACT=[F:ATZ]CODACT
 If fstat or [F:ACV]FLACT<>2
  End 0
 Endif
Endif
End 1

#-------------------------------------------#
$ZONE
Wrseq '                    <Name>'+[L]FLD+'</Name>' Using [AXML]
Wrseq '                    <Description>'+INTIT+'</Description>' Using [AXML]
Case [F:ATY]TYPTYP
 When 1 : # Menu local
  Wrseq '                    <AlphaNumeric/>' Using [AXML]
  Wrseq '                    <MaxLength>'+num$(LNG)+'</MaxLength>' Using [AXML]
  If [F:AOD]NUMTAB=0
   For I=1 To len(mess(0,MNL,1))
    Wrseq '                    <Map>' Using [AXML]
    Wrseq '                        <From>'+func CODMNL(I,MNL,[F:AOE]OPTMNL)+'</From>' Using [AXML]
    Wrseq '                        <To>'+func CARSPEXML(mess(I,MNL,1))+'</To>' Using [AXML]
    Wrseq '                    </Map>' Using [AXML]
   Next I
  Endif
 When 2,3,4 : # Numérique
  Wrseq '                    <Numeric>' Using [AXML]
  Wrseq '                    <Accuracy>'+'0'+'</Accuracy>' Using [AXML]
  Wrseq '                    </Numeric>' Using [AXML]
 When 5,6 : # Numérique (décimal
  Wrseq '                    <Numeric>' Using [AXML]
  Wrseq '                    <Accuracy>'+'2'+'</Accuracy>' Using [AXML]
  Wrseq '                    </Numeric>' Using [AXML]
 When 8 : # Date
  Wrseq '                    <Date>' Using [AXML]
  Wrseq '                    <Format>'+func FMTDAT([F:AOE]OPTDAT)+'</Format>' Using [AXML]
  Wrseq '                    </Date>' Using [AXML]
 When Default : # Char/Blob/Clob
  Wrseq '                    <AlphaNumeric/>' Using [AXML]
  Wrseq '                    <MaxLength>'+num$(LNG)+'</MaxLength>' Using [AXML]
Endcase
If [F:AOD]NUMTAB<>0
 Raz NBTAB, TAB
 For [AOR]AOR0 Where NUMTAB=[F:AOD]NUMTAB
  If !find([F:AOR]CODEXT,TAB)
   NBTAB += 1
   TAB(NBTAB) = [F:AOR]CODEXT
   Wrseq '                    <Map>' Using [AXML]
   Wrseq '                        <From>'+[F:AOR]CODEXT+'</From>' Using [AXML]
   Wrseq '                        <To>'; Using [AXML]
   Wrseq func TEXTRA("AOBJEXTR","CODINTIT",num$([F:AOR]NUMTAB),[F:AOR]CODLOC+"~"+[F:AOR]CODEXT)+'</To>' Using [AXML]
   Wrseq '                    </Map>' Using [AXML]
  Endif
 Next I
Endif
Return

#-------------------------------------------#
$SETCLE
CHAINE = ""
If [F:AOE]FLGFIL=""
 Read [AOB]ABREV=[F:AOE]OBJ
 If !fstat & [F:AOB]NOMFIC<>""
  Read [ATI]NUMLIG(2)=[F:AOB]NOMFIC
  If !fstat
   NOMFIC = [F:AOB]NOMFIC
   CHAINE = [F:ATI]DESCRIPT
  Endif
 Endif
Elsif [F:AOE]FLGKEY<>""
 NOMFIC = [F:AOE]FLGFIL
 Read [ATI]CODIND=[F:AOE]FLGKEY
 If !fstat
  CHAINE = [F:ATI]DESCRIPT
 Endif
Endif
Raz CLE, NBCLE
While CHAINE<>""
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 NBCLE += 1
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

#-------------------------------------------#
Funprog CODMNL(I,MNL,OPT)
Value Integer I,MNL,OPT
Local Char TEXTE(250)
Case OPT
 When 0       : TEXTE = num$(I)
 When 1       : TEXTE = mid$(mess(0,MNL,1),I,1)
 When Default : TEXTE = left$(mess(I,MNL,1),OPT)
Endcase
Call MODVAL(TEXTE) From INTRUTILA : # Transformation des caractères <>"& pour le script XML
End TEXTE

#-------------------------------------------#
Funprog FMTDAT(OPT)
Value Integer OPT
Local Char DAT(20)
Case OPT
 When 1 : End "JJMMAA"
 When 2 : End "JJMMAAAA"
 When 3 : End "AAMMJJ"
 When 4 : End "AAAAMMJJ"
Endcase
End

#-------------------------------------------#
Funprog FICHIER(CHEMIN)
Value Char CHEMIN
Local Char CHAINE(250)
Local Integer I
CHAINE = CHEMIN
I = max(instr(1,CHAINE,"/"),instr(1,CHAINE,"\"))
While I
 CHAINE = right$(CHAINE,I+1)
 I = max(instr(1,CHAINE,"/"),instr(1,CHAINE,"\"))
Wend
Call MODVAL(CHAINE) From INTRUTILA : # Transformation des caractères <>"& pour le script XML
End CHAINE

#-------------------------------------------#
Funprog DATDEB(MODELE)
Value Char MODELE
Local Char DAT(20) , CHAINE(250)
Local Integer K
For [AOD]AOD0 Where EXT=MODELE
 If [F:AOD]SEL=2 & ([F:AOD]STRVAL<>"" or [F:AOD]ENDVAL<>"") & !find(left$([F:AOD]FLD,1),"/","*","=","'",'"',"")
  CHAINE = [F:AOD]FLD
  K = instr(1,CHAINE,"(")
  If K
   CHAINE  = left$(CHAINE,K-1)
  Endif
  Read [ATZ]CODZONE=[F:AOD]FIL;CHAINE
  If !fstat
   Read [ATY]CODTYP=[F:ATZ]CODTYP
   If [F:ATY]TYPTYP=8
    If [F:AOD]STRVAL=""
     DAT = "00.00.0000"
    Else
     Onerrgo RIEN
     DAT = format$("D:DD[.]MM[.]YYYY",gdat$([F:AOD]STRVAL))
     Onerrgo
    Endif
    Break
   Endif
  Endif
 Endif
Next AOD
End DAT

$RIEN
Resume

#-------------------------------------------#
Funprog DATFIN(MODELE)
Value Char MODELE
Local Char DAT(20) , CHAINE(250)
Local Integer K
For [AOD]AOD0 Where EXT=MODELE
 If [F:AOD]SEL=2 & ([F:AOD]STRVAL<>"" or [F:AOD]ENDVAL<>"") & !find(left$([F:AOD]FLD,1),"/","*","=","'",'"',"")
  CHAINE = [F:AOD]FLD
  K = instr(1,CHAINE,"(")
  If K
   CHAINE  = left$(CHAINE,K-1)
  Endif
  Read [ATZ]CODZONE=[F:AOD]FIL;CHAINE
  If !fstat
   Read [ATY]CODTYP=[F:ATZ]CODTYP
   If [F:ATY]TYPTYP=8
    If [F:AOD]ENDVAL=""
     DAT = "31.12.2999"
    Else
     Onerrgo RIEN
     DAT = format$("D:DD[.]MM[.]YYYY",gdat$([F:AOD]ENDVAL))
     Onerrgo
    Endif
    Break
   Endif
  Endif
 Endif
Next AOD
End DAT

#-------------------------------------------#
Funprog TEXTE(NUMERO)
Value Integer NUMERO
Local Char TEXTE(250)
Call TEXTE(NUMERO,TEXTE) From OBJDIV
Call MODVAL(TEXTE) From INTRUTILA : # Transformation des caractères <>"& pour le script XML
End TEXTE

#-------------------------------------------#
Funprog TEXTRA(TABLE,CHAMP,CLE1,CLE2)
Value Char TABLE
Value Char CHAMP
Value Char CLE1
Value Char CLE2
Local Char TEXTE(250)
Call LECTEXTRA(TEXTE,TABLE,CHAMP,CLE1,CLE2) From ATEXTRA
Call MODVAL(TEXTE) From INTRUTILA : # Transformation des caractères <>"& pour le script XML
End TEXTE

#--------------------------------#
Funprog CARSPEXML(CHAINE)
Value Char CHAINE
Local Char CHAINE2(255)
CHAINE2 = CHAINE
Call MODVAL(CHAINE2) From INTRUTILA : # Transformation des caractères <>"& pour le script XML
End CHAINE2

