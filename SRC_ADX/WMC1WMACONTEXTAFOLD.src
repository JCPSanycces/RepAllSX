# 2 : ALANGDEF Default language ( Field LAN 3)
####################################################################

$GET_ALANGDEF
Gosub DECLARE_VAR From WMC0WMACONTEXTAFOLD
[L]CURPRO = "ALANGDEF"
[L]ARULE = "GET" : [L]ACTION = "GET" : Gosub ACTION From ASYRSUB
Return


