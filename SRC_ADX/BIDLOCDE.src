#** #####################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #####################################################################################

$ACTION
    Case ACTION
        When "OUVRE"    : Gosub OUVRE                 # Basic initialization.
        When "AV_CHOIX" : Gosub AV_CHOIX              # Initialize the fields by reading the parent screen.
        When "OK"       : VALEUR = "OK" : Gosub OK    # Write back the entered information.
    Endcase
Return



#** #####################################################################################
#*
#* Sub chunk:  OUVRE
#*
#* Purpose:    Handler before opening a window.
#*             Opens some needed tables and initializes some variables for further use.
#*
#*! #####################################################################################

$OUVRE
    # Set parameters.
    Local Char PARENTSCREEN(GLONAMK) : PARENTSCREEN   = PARAM(1)    # Parent screen
    Local Char PARENTSCRABR(GLONABR) : PARENTSCRABR   = PARAM(2)    # Abbreviation of the parent screen.
    Local Char COUNTRY(GLONCRY)      : COUNTRY        = PARAM(3)    # Country
    Local Char WINDOW(GLONFEN)       : WINDOW         = PARAM(4)    # Name of this window
    Local Char SCREEN(GLONAMK)       : SCREEN         = PARAM(5)    # Name of this screen
    Local Char TABINDEX(30)          : TABINDEX       = PARAM(6)    # Index of the current line in the parent screen
    Local Integer LENBANCOD          : [L]LENBANCOD   = 8           # Size of bank sort code
    Local Integer LENBANACC          : [L]LENBANACC   = 10          # Size of bank account number

    # Open needed tables.
    If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
    If clalev([F:ABN])=0 : Local File ABANK [ABN] : Endif
Return



#** #####################################################################################
#*
#* Sub chunk:  AV_CHOIX
#*
#* Purpose:    Handler before entering the window
#*             Reads data from the parent screen and prefills the local BID screen.
#*
#*! #####################################################################################

$AV_CHOIX
    Local Char BIDNUM(GLONBID)
    Local Char IBACOD(34)
    Local Char BANCOD([L]LENBANCOD)
    Local Char BANACC([L]LENBANACC)

    # Clear all fields.
    #
    # Note: We do this because the second start of a local BID window will otherwise
    #       have old content.
    #
    Effzo

    # Initiliaze hiden field sizes
    [M]LENBANCOD = [L]LENBANCOD
    [M]LENBANACC = [L]LENBANACC

    # Case distinction between BAN1 screen (GESBAN function) and the BIDxxx screens for
    # there are different field names and sometimes indexed fields (table view):
    If PARENTSCREEN = "BAN1"
        # GESBAN function:
        BIDNUM       = evalue( "[M:" + PARENTSCRABR + "]BIDNUM" )
        [M]PAB1      = evalue( "[M:" + PARENTSCRABR + "]PAB1" )
        [M]IBACOD    = evalue( "[M:" + PARENTSCRABR + "]IBACOD" )
        [M]BICCOD    = evalue( "[M:" + PARENTSCRABR + "]BICCOD" )
        Grizo BIDCUR
    Else
        # BIDxxx screens (GESBPR, GESBPC, ... function):
        BIDNUM       = evalue( "[M:" + PARENTSCRABR + "]BIDNUM("    + TABINDEX + ")" )
        [M]BIDBPAADD = evalue( "[M:" + PARENTSCRABR + "]BIDBPAADD(" + TABINDEX + ")" )
        [M]PAB1      = evalue( "[M:" + PARENTSCRABR + "]PAB1("      + TABINDEX + ")" )
        [M]BICCOD    = evalue( "[M:" + PARENTSCRABR + "]BICCOD("    + TABINDEX + ")" )
        [M]BIDCUR    = evalue( "[M:" + PARENTSCRABR + "]BIDCUR("    + TABINDEX + ")" )
    Endif

    # Common initialization.
    [M]BIDCRY = COUNTRY
    BANCOD = left$( BIDNUM, [M]LENBANCOD )
    BANACC = left$( right$( BIDNUM, [M]LENBANCOD + 1 ), [M]LENBANACC  )
    If BIDNUM <> ""
        If BANCOD <> "" #and func ISNUMERIC( BANCOD, [M]LENBANCOD )
            [M]BANCOD = BANCOD
        Endif
        If BANACC <> "" #and func ISNUMERIC( BANACC, [M]LENBANACC )
            [M]BANACC = BANACC
        Endif
        If BANCOD <> "" and BANACC <> ""
            [M]IBACOD = func BUILDIBAN( COUNTRY, BANCOD, BANACC )
        Endif
    Endif
    Affzo 1-99
    Grizo BIDBPAADD, BIDCRY
    zonsui = "BANACC"
Return



#** #####################################################################################
#*
#* Sub chunk:  OK
#*
#* Purpose:    Handler for the OK button. Insert the data in the parent screen.
#*
#*! #####################################################################################

$OK
    # Case distinction between BAN1 screen (GESBAN function) and the BIDxxx screens for
    # there are differend field names and sometimes indexed fields (table view):
    If PARENTSCREEN = "BAN1"
        # GESBAN function:
        Assign "[M:" + PARENTSCRABR + "]PAB1"   With [M]PAB1
        Assign "[M:" + PARENTSCRABR + "]BIDNUM" With [M]BANCOD + [M]BANACC
        Assign "[M:" + PARENTSCRABR + "]BICCOD" With [M]BICCOD
        Assign "[M:" + PARENTSCRABR + "]IBACOD" With func BUILDIBAN( [M]BIDCRY, [M]BANCOD, [M]BANACC )
    Else
        # BIDxxx screens (GESBPR, GESBPC, ... function):
        Assign "[M:" + PARENTSCRABR + "]BIDBPAADD(" + TABINDEX + ")" With [M]BIDBPAADD
        Assign "[M:" + PARENTSCRABR + "]PAB1("      + TABINDEX + ")" With [M]PAB1
        Assign "[M:" + PARENTSCRABR + "]BIDNUM("    + TABINDEX + ")" With [M]BANCOD + [M]BANACC
        Assign "[M:" + PARENTSCRABR + "]BICCOD("    + TABINDEX + ")" With [M]BICCOD
        Assign "[M:" + PARENTSCRABR + "]IBAN("      + TABINDEX + ")" With left$( func BUILDIBAN( [M]BIDCRY, [M]BANCOD, [M]BANACC ), 4 )
        Assign "[M:" + PARENTSCRABR + "]BIDCUR("    + TABINDEX + ")" With [M]BIDCUR
    Endif
Return



#** #####################################################################################
#*
#* Function:  BUILDIBAN
#*
#* Purpose:   Compute a valid IBAN from given country code, bank sort code and bank
#*            account number.
#*
#* Parameters:
#* @param CRY             Value Char ()   Country code
#* @param BANCOD          Value Char ()   Bank sort code
#* @param BANACC          Value Char ()   Bank account number
#*
#*! #####################################################################################

Funprog BUILDIBAN( CRY, BANCOD, BANACC )
Value Char CRY()
Value Char BANCOD()
Value Char BANACC()

    # Some nice little (pre)checks:
    If CRY = "" or BANCOD = "" or BANACC = ""
        End ""
    Endif

    Local Char IBAN(4)        # Return variable for IBAN prefix (e. g. "DE91")

    # Calculate the IBAN prefix (check sum) for the give BID.
    Call IBAN( CRY, BANCOD + BANACC, IBAN ) From TRTBPA

    # Return the whole IBAN (IBACOD)
End IBAN + BANCOD + BANACC



#** #####################################################################################
#*
#* Function:  ISNUMERIC
#*
#* Purpose:   Check if NUMBER consists only of numerical characters ( "0", "1", ... "9" )
#*            and prepends zeroes until NUMBER has the given SIZE. ISNUMERIC returns
#*            TRUE (1) for success and FALSE (0) for failure.
#*
#* Parameters:
#* @param NUMBER          Variable Char() The number to check
#* @param SIZE            Value integer   The size upto which NUMBER should filled with
#*                                        prepending zeroes
#*
#*! #####################################################################################

Funprog ISNUMERIC( NUMBER, SIZE )
Variable Char NUMBER()
Value Integer SIZE

    Local Integer LENGTH : LENGTH = len( NUMBER )
    Local Integer I

    # Check if NUMBER consists only of numerical characters.
    For I = 1 To LENGTH
        If ( mid$( NUMBER, I, 1) < "0" ) or ( mid$( NUMBER, I, 1) > "9" )

            # Nonnumerical character found. End with FALSE (failure).
            End 0
        Endif
    Next

    # Prepend leading zeroes.
    For I = LENGTH + 1 To SIZE
        NUMBER = "0" + NUMBER
    Next

    # End with TRUE (success).
End 1



# ############################################################################################# #
# ##########                                                                                    #
# ########## Screen/Window handling                                                             #
# ##########                                                                                    #
# ##########                                                                                    #
# ##########                                                                                    #
# ############################################################################################# #


# ############################################################################################# #
# ##########                                                                                    #
# ########## Event: After changing the bank account number                                      #
# ########## Does:  - Checks that the bank account number is numeric                            #
# ##########        - Fills the bank account number with leading zeroes.                        #
# ##########        - Recalculates the IBAN.                                                    #
# ##########                                                                                    #
# ############################################################################################# #

Subprog C_BANACC(VALEUR)
Variable Char VALEUR()

    # Check if the bank account number is all numeric (and fill it up by prepending zeroes).
    If !func ISNUMERIC( VALEUR, [M]LENBANACC )
        # If not raise an error message.
        GMESSAGE = mess(344,107,1) # Message: "The bank account number must be numeric only."
        mkstat = 2
        End
    Endif
End

Subprog AM_BANACC( VALEUR )
Variable Char VALEUR()

    # Create the according IBAN.
    [M]IBACOD= func BUILDIBAN( [M]BIDCRY, [M]BANCOD, VALEUR ) : Affzo IBACOD
End



# ############################################################################################# #
# ##########                                                                                    #
# ########## Event: After changing the bank sort code                                           #
# ########## Does:  - Checks that the bank sort code is numeric                                 #
# ##########        - Fills the bank sort code with leading zeroes.                             #
# ##########        - Checks if the bank sort code is valid (if bank control is activated)      #
# ##########        - Fills in bank and IBAN.                                                   #
# ##########                                                                                    #
# ############################################################################################# #

Subprog C_BANCOD( VALEUR )
Variable Char VALEUR()

    # Check if the bank sort code is all numeric (and fill it up by prepending zeroes).
    If !func ISNUMERIC( VALEUR, [M]LENBANCOD )

        # If not raise an error message.
        GMESSAGE = mess(343,107,1) # Message: "The bank sort code must be numeric only."
        mkstat = 2
        End
    Endif

    Call LEC_TCY( [M]BIDCRY ) From CPTLEC
    Call LEC_ABN( [M]BIDCRY, VALEUR ) From CPTLEC
    If fstat and ( [F:TCY]BIDCTL - 1 )
        # Bank doesn't exist.
        #
        # Note: This is the same message X3 shows in BIDxxx screens if there is no
        #       corresponding bank sort code in the  ABANK table. That's why we reuse
        #       it here even if it is a little bit cryptic.
        #
        GMESSAGE = mess(173,133,1)
        mkstat = 2
        End 0 # FALSE: Signal error.
    Endif
End

Subprog AM_BANCOD( VALEUR )
Variable Char VALEUR()

    # Get bank name and BIC code from table ABANK.
    Call LEC_ABN( [M]BIDCRY, VALEUR ) From CPTLEC
    If !fstat
        [M]PAB1   = [F:ABN]PAB  : Affzo PAB1
        [M]BICCOD = [F:ABN]BIC  : Affzo BICCOD
    Endif

    # Create the according IBAN.
    [M]IBACOD= func BUILDIBAN( [M]BIDCRY, VALEUR, [M]BANACC ) : Affzo IBACOD
End



# ############################################################################################# #
# ##########                                                                                    #
# ########## Event: After changing the IBAN                                                     #
# ########## Does:  Checks the validity of the IBAN and restores bank sort code and bank        #
# ##########        account number.                                                             #
# ##########                                                                                    #
# ############################################################################################# #

Subprog C_IBACOD( VALEUR )
Variable Char VALEUR()

    # If the IBAN is empty there is nothing to do.
    If VALEUR = ""
        End
    Endif

    # Make sure the ISO code part is in upper case.
    VALEUR= toupper( VALEUR )

    # Check the beginning of the IBAN against the country.
    #
    # Note: We can be sure that the record exists for it is validated in the parent window.
    #       So we don't have to check fstat.
    Call LEC_TCY( [M]BIDCRY ) From CPTLEC

    If left$( VALEUR, 2 ) <> [F:TCY]ISO
        GMESSAGE = func AFNC.MES1( mess(341,107,1), [M]BIDCRY ) # Message: "This local BID dialog is restricted to IBANs of country $1$"
        mkstat = 2
        End
    Endif

    # Create BIDNUM, bank sort code, bank acount number and the according reference IBAN.
    Local Char BIDNUM(GLONBID)      : BIDNUM = right$( VALEUR, 5 )                                        # BIDNUM
    Local Char BANCOD([M]LENBANCOD) : BANCOD = left$( BIDNUM, [M]LENBANCOD )                              # Bank sort code
    Local Char BANACC([M]LENBANACC) : BANACC = left$( right$( BIDNUM, [M]LENBANCOD + 1 ), [M]LENBANACC )  # Bank account number
    Local Char IBACOD(34)           : IBACOD = func BUILDIBAN( [M]BIDCRY, BANCOD, BANACC )                # Reference IBAN

    # Check if the entered IBAN coincides with the reference IBAN.
    If VALEUR <> IBACOD
        # If not raise an error message.
        GMESSAGE= mess(342,107,1) # Message: "The IBAN is not valid. Please enter a valid IBAN."
        mkstat = 2
        End
    Endif
End

Subprog AM_IBACOD( VALEUR )
Variable Char VALEUR()

    # Create BIDNUM, bank sort code, bank acount number and the according reference IBAN.
    Local Char BIDNUM(GLONBID)      : BIDNUM = right$( VALEUR, 5 )                                        # BIDNUM
    Local Char BANCOD([M]LENBANCOD) : BANCOD = left$( BIDNUM, [M]LENBANCOD )                              # Bank sort code
    Local Char BANACC([M]LENBANACC) : BANACC = left$( right$( BIDNUM, [M]LENBANCOD + 1 ), [M]LENBANACC )  # Bank account number

    # Restore bank sort code, bank account number, bank name, and BIC.
    [M]BANACC = BANACC : Affzo BANACC
    [M]BANCOD = BANCOD : Affzo BANCOD
    Call LEC_ABN( [M]BIDCRY, BANCOD ) From CPTLEC
    If !fstat
        [M]PAB1   = [F:ABN]PAB  : Affzo PAB1
        [M]BICCOD = [F:ABN]BIC  : Affzo BICCOD
    Endif
End

