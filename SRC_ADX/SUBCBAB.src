#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des transactions agenda action commercial     Module CRM   octobre 2006
#
##########################################################################################################
# LOADDATA : traitement lors du chargement des données
# ONGLETS_INIT :  Traitement de gestion des onglets en initialisation
# ONGLETS_ENREG : Traitement de gestion des onglets en enregistrement
# ONGLETS_READ : Traitement de gestion des onglets lors de la lecture
# ONGLETS :  Traitement de gestion des onglets
# COLFIX_INIT :  Traitement de gestion des colonnes fixes en initialisation
# COLFIX_ENREG : Traitement de gestion des colonnes fixes lors de l'enregistrement
# COLFIX_READ : Traitement de gestion des colonnes fixes lors de la lecture
# COLFIX : Traitement de gestion des colonnes fixes
# CHAMPS_INIT : Traitement de gestion des champs en initialisation
# CHAMPS_ENREG : Traitement de gestion des champs lors de l'enregistrement
# CHAMPS_READ : Traitement de gestion des champs lors de la lecture
# CHAMPS : Traitement de gestion des champs
# TAB_NBLIGSRE : Traitement de gestion des colonnes du tableau de l'écran CRMAGD1 demande de service
# TAB_NBLIGITN : Traitement de gestion des colonnes du tableau de l'écran CRMAGD2 intervention
# TAB_NBLIGINF Traitement de gestion des colonnes du tableau de l'écran CRMAGD3 information
# AFF_FENETRE : Affichage de la fenetre
# REORGANISE : Traitement de réorganisation (tri) de tous les tableaux de la fenetre
# REORG_NBLIGAGD : Tri du tableau de l'écran CRMAGD1 agenda
# REORG_NBLIGCLL : Tri du tableau de l'écran CRMAGD2 Appel
# REORG_NBLIGTSK : Tri du tableau de l'écran CRMAGD3 tache
# REORG_NBLIGOPP : Tri du tableau de l'écran CRMAGD4 affaire
# REORG_NBLIGINF : Tri du tableau de l'écran CRMAGD6 information
# VALINITIAL_INIT : Traitement de gestion valeurs initiales  en initialisation
# VALINITIAL_ENREG : Traitement de gestion valeurs initiales lors de l'enregistrement
# VALINITIAL_READ : Traitement de gestion valeurs initiales lors de la lecture
# VALINITIAL : Traitement de gestion valeurs initiales
########################################################################################################
##########################################################################################################
#traitement lors du chargement des données
$LOADDATA
Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZLIBELLE (50)

  Read [CTV]CTV0=[F:CTR]CTRTYP;[F:CTR]CTRNUM
  If fstat <> 0 Then
    Raz [F:CTV]
  Endif
  Gosub ONGLETS_READ From SUBCBAB
  Gosub COLFIX_READ  From SUBCBAB
  Gosub CHAMPS_READ From SUBCBAB
  Gosub VALINITIAL_READ From SUBCBAB
  If [M:CBA7]ONGLETACT <> "" Then
    Call GETLIB_ONGLET("FCRMAGD", [M:CBA7]ONGLETACT, SZLIBELLE, SZMESSAGE, IBRETOUR) From CRMTRSUTI
    If IBRETOUR = 0 Then
      SZLIBELLE = ""
    Endif
  Else
    SZLIBELLE = ""
  Endif
  [M:CBA7]LIBONGLET = SZLIBELLE
  Gosub REORGANISE From SUBCBAB
  Gosub PE_CRMTRS From SUBCRMTRS
  Affzo [M:CBA7]LIBONGLET
  Gosub AFF_FENETRE From SUBCBAB
Return

##########################################################################################################
# Traitement de gestion des onglets en initialisation
$ONGLETS_INIT
Local Char SZTYP_ACTION

  SZTYP_ACTION = "INIT"
  Gosub ONGLETS
Return

##########################################################################################################
# Traitement de gestion des onglets en enregistrement
$ONGLETS_ENREG
Local Char SZTYP_ACTION

  SZTYP_ACTION = "ENREG"
  Gosub ONGLETS
Return

##########################################################################################################
# Traitement de gestion des onglets lors de la lecture
$ONGLETS_READ
Local Char SZTYP_ACTION

  SZTYP_ACTION = "READ"
  Gosub ONGLETS
Return

##########################################################################################################
# Traitement de gestion des onglets
$ONGLETS
Local Integer INBONGLET
Local Integer ITROUVE
Local Char SZREFERENCE
Local Integer ITROUVE

  INBONGLET = 0
  ITROUVE = 0
  Raz SZREFERENCE
  #If SZTYP_ACTION = "INIT" Then
  If SZTYP_ACTION = "INIT" or SZTYP_ACTION = "ENREG" Then
    # FGR 13/10/2009 : X3SUIVI57386 faut le réinitialiser avant parce que sinon on modif les valeurs qui y sont ne sont pas ecrasées
    Raz [F:CTR]ONGINVISI
    INBONGLET = 0
  Endif
  #
  #CBA1 représente écran CRMAGD1 agenda
  SZREFERENCE = "CRMAGD1"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA1]AGDVISI = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    Raz [F:CTR]ONGINVISI # FGR 15/01/2009 : faut le réinitialiser avant parce que sinon on modif les valeurs qui y sont ne sont pas ecrasées
    If [M:CBA1]AGDVISI = 1 Then
      [F:CTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET = INBONGLET + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE= find(SZREFERENCE, [F:CTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CBA1]AGDVISI = 2
    Else
      [M:CBA1]AGDVISI = 1
    Endif
  Endif
  #CBA2 représente écran CRMAGD2 Appel
  SZREFERENCE = "CRMAGD2"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA2]CLLVISI = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA2]CLLVISI = 1 Then
      [F:CTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET = INBONGLET + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE= find(SZREFERENCE, [F:CTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CBA2]CLLVISI = 2
    Else
      [M:CBA2]CLLVISI = 1
    Endif
  Endif
  #CBA3 représente écran CRMAGD3 Tache
  SZREFERENCE = "CRMAGD3"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA3]TSKVISI = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA3]TSKVISI = 1 Then
      [F:CTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET = INBONGLET + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:CTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CBA3]TSKVISI = 2
    Else
      [M:CBA3]TSKVISI = 1
    Endif
  Endif
  #CBA4 représente écran CRMAGD4 Affaire
  SZREFERENCE = "CRMAGD4"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA4]OPPVISI = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA4]OPPVISI = 1 Then
      [F:CTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET = INBONGLET + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:CTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CBA4]OPPVISI = 2
    Else
      [M:CBA4]OPPVISI = 1
    Endif
  Endif
  #CBA6 représente écran CRMAGD6 Information
  SZREFERENCE = "CRMAGD6"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA6]INFVISI = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA6]INFVISI = 1 Then
      [F:CTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET = INBONGLET + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:CTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CBA6]INFVISI = 2
    Else
      [M:CBA6]INFVISI = 1
    Endif
  Endif
  #CBA8 représente écran CRMAGD7 Rendez-vous
  SZREFERENCE = "CRMAGD7"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA8]APPVISI = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA8]APPVISI = 1 Then
      [F:CTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET = INBONGLET + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:CTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CBA8]APPVISI = 2
    Else
      [M:CBA8]APPVISI = 1
    Endif
  Endif
  #CBA9 représente écran CRMAGD8 Campagnes marketing
  SZREFERENCE = "CRMAGD8"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA9]CMGVISI = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA9]CMGVISI = 1 Then
      [F:CTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET = INBONGLET + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:CTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CBA9]CMGVISI = 2
    Else
      [M:CBA9]CMGVISI = 1
    Endif
  Endif
Return

