    If ITROUVE = 0 Then
      [M:CBA6]INFOPP = 1
    Else
      If val([F:CTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CBA6]INFOPP = IAFFICHE
    Endif
  Endif

  #[CRMAGD6]INFCON
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CBA6]INFCON = 2
  Endif
  If SZTYP_ACTION = "ENREG" Then
    If [M:CBA6]INFCON = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:CTV]FIENAM(INBFIENAM) = "[CRMAGD6]INFCON"
    [F:CTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Endif
  If SZTYP_ACTION = "READ" Then
    ITROUVE = find("[CRMAGD6]INFCON", [F:CTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CBA6]INFCON = 1
    Else
      If val([F:CTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CBA6]INFCON = IAFFICHE
    Endif
  Endif

  #Gestion du bloc [CRMAGD6]5
  #---------------------#
  If SZTYP_ACTION = "ENREG" Then
    If [M:CBA6]INFBAP<>2 and [M:CBA6]INFCLL<>2 and [M:CBA6]INFTSK<>2 and [M:CBA6]INFOPP<>2 and [M:CBA6]INFCON<>2 Then
      [F:CTR]BLOCINVI(INBBLOCINVI) = "[CRMAGD6]5"
      INBBLOCINVI = INBBLOCINVI + 1
    Endif
  Endif

  # Chargement du tableau
  #---------------------#
  If 0=1 Then
  ILIGNE = -1
  Filter [AMZ] Where CODMSK="CRMAGD6" and NUMBLOC=2 and SAIAFF=2 and CODTYP<>"ABS" Order By NUMLIG
  For [AMZ] Hint Key CODZON
    SZCHAMP = "["+[F:AMZ]CODMSK+"]"+[F:AMZ]CODZON
    ILIGNE += 1
    #
    Call TEXTE([F:AMZ]INTIT, SZTEXTE) From OBJDIV
    IVISIBLE = 2
    IMODE = 1
    IPOSITION = ILIGNE + 1
    Gosub TAB_NBLIGINF
  Next
  Filter [AMZ]
  Endif
  If 1=1 Then
    # NOTE FGR : je le conserve pour le moment. mais c'est remplacé par "Chargement du tableau" ci-dessus
  #[CRMAGD6]INFTYPE
  #---------------------#
  SZCHAMP="[CRMAGD6]INFTYPE"
  ILIGNE=0
  #Type
  Call TEXTE(680, SZTEXTE) From OBJDIV
  IVISIBLE=2
  IMODE=1
  IPOSITION=ILIGNE+1
  Gosub TAB_NBLIGINF

  #[CRMAGD6]INFKEY
  #---------------------#
  SZCHAMP="[CRMAGD6]INFKEY"
  ILIGNE=1
  #Clé
  Call TEXTE(2943, SZTEXTE) From OBJDIV
  IVISIBLE=2
  IMODE=1
  IPOSITION=ILIGNE+1
  Gosub TAB_NBLIGINF

  #[CRMAGD6]INFINFO
  #---------------------#
  SZCHAMP="[CRMAGD6]INFINFO"
  ILIGNE=2
  #Message
  Call TEXTE(15545, SZTEXTE) From OBJDIV
  IVISIBLE=2
  IMODE=1
  IPOSITION=ILIGNE+1
  Gosub TAB_NBLIGINF

  #[CRMAGD6]INFDELAY
  #---------------------#
  SZCHAMP="[CRMAGD6]INFDELAY"
  ILIGNE=3
  #Delai
  Call TEXTE(14490, SZTEXTE) From OBJDIV
  IVISIBLE=2
  IMODE=1
  IPOSITION=ILIGNE+1
  Gosub TAB_NBLIGINF

  #[CRMAGD6]INFREPNAM
  #---------------------#
  SZCHAMP="[CRMAGD6]INFREPNAM"
  ILIGNE=4
  #Représentant
  Call TEXTE(2929, SZTEXTE) From OBJDIV
  IVISIBLE=2
  IMODE=1
  IPOSITION=ILIGNE+1
  Gosub TAB_NBLIGINF
  Endif

  #CBA8 représente écran CRMAGD7 Rendez-vous
  # FLORENT ICI
  #[CRMAGD7]
  #---------------------------------------------------#
  #[CRMAGD7]SEAAPTTYP
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CBA8]SEAAPPCAT = 2
  Endif
  If SZTYP_ACTION = "ENREG" Then
    If [M:CBA8]SEAAPPCAT = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:CTV]FIENAM(INBFIENAM) = "[CRMAGD7]SEAAPTTYP"
    [F:CTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Endif
  If SZTYP_ACTION = "READ" Then
    ITROUVE = find("[CRMAGD7]SEAAPTTYP", [F:CTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CBA8]SEAAPPCAT = 1
    Else
      If val([F:CTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CBA8]SEAAPPCAT = IAFFICHE
    Endif
  Endif

  #[CRMAGD7]SEABCS
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CBA8]SEAAPPDEL = 2
  Endif
  If SZTYP_ACTION = "ENREG" Then
    If [M:CBA8]SEAAPPDEL = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:CTV]FIENAM(INBFIENAM) = "[CRMAGD7]SEABCS"
    [F:CTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Endif
  If SZTYP_ACTION = "READ" Then
    ITROUVE = find("[CRMAGD7]SEABCS", [F:CTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CBA8]SEAAPPDEL = 1
    Else
      If val([F:CTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CBA8]SEAAPPDEL = IAFFICHE
    Endif
  Endif

  #Gestion du bloc [CRMAGD7]5
  #---------------------#
  If SZTYP_ACTION = "ENREG" Then
    If [M:CBA8]SEAAPPCAT<>2 and [M:CBA8]SEAAPPDEL<>2 Then
      [F:CTR]BLOCINVI(INBBLOCINVI)="[CRMAGD7]5"
      INBBLOCINVI = INBBLOCINVI + 1
    Endif
  Endif

  # Chargement du tableau
  #---------------------#
  ILIGNE = -1
  Filter [AMZ] Where CODMSK="CRMAGD7" and NUMBLOC=2 and SAIAFF=2 and CODTYP<>"ABS" Order By NUMLIG
  For [AMZ] Hint Key CODZON
    SZCHAMP = "["+[F:AMZ]CODMSK+"]"+[F:AMZ]CODZON
    ILIGNE += 1
    #
    Call TEXTE([F:AMZ]INTIT, SZTEXTE) From OBJDIV
    IVISIBLE = 2
    IMODE = 1
    IPOSITION = ILIGNE + 1
    Gosub TAB_NBLIGAPP
  Next
  Filter [AMZ]
Return

