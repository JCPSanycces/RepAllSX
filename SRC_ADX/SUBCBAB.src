##########################################################################################################
# Traitement de gestion des colonnes fixes
$COLFIX
Local Integer ITROUVE
Local Integer INBTABLEAU
Local Char SZREFERENCE

  Raz SZREFERENCE
  If SZTYP_ACTION="ENREG"
    Raz [F:CTR]COLFIXNAM
    Raz [F:CTR]COLFIXVAL
    INBTABLEAU = 0
  Endif
  #CBA1/0
  #CBA1 représente écran CRMAGD1
  SZREFERENCE="[CRMAGD1]NBLIGAGD"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA1]AGDCOLFIX = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    Raz [F:CTR]COLFIXNAM # FGR 15/01/2009 cf. plus haut
    Raz [F:CTR]COLFIXVAL # FGR 15/01/2009 cf. plus haut
    If [M:CBA1]AGDCOLFIX <> 0 Then
      [F:CTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:CTR]COLFIXVAL(INBTABLEAU) = [M:CBA1]AGDCOLFIX
      INBTABLEAU = INBTABLEAU + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE= find(SZREFERENCE, [F:CTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CBA1]AGDCOLFIX = 0
    Else
      [M:CBA1]AGDCOLFIX = [F:CTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  #CBA2
  #CBA2 représente écran CRMAGD2
  SZREFERENCE = "[CRMAGD2]NBLIGCLL"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA2]CLLCOLFIX = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA2]CLLCOLFIX <> 0 Then
      [F:CTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:CTR]COLFIXVAL(INBTABLEAU) = [M:CBA2]CLLCOLFIX
      INBTABLEAU = INBTABLEAU + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:CTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CBA2]CLLCOLFIX = 0
    Else
      [M:CBA2]CLLCOLFIX = [F:CTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  #CBA3 représente écran CRMAGD3 Tache
  SZREFERENCE = "[CRMAGD3]NBLIGTSK"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA3]TSKCOLFIX = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA3]TSKCOLFIX <> 0 Then
      [F:CTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:CTR]COLFIXVAL(INBTABLEAU) = [M:CBA3]TSKCOLFIX
      INBTABLEAU = INBTABLEAU + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:CTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CBA3]TSKCOLFIX = 0
    Else
      [M:CBA3]TSKCOLFIX = [F:CTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  #CBA4 représente écran CRMAGD4 Affaire
  SZREFERENCE = "[CRMAGD4]NBLIGOPP"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA4]OPPCOLFIX = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA4]OPPCOLFIX <> 0 Then
      [F:CTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:CTR]COLFIXVAL(INBTABLEAU) = [M:CBA4]OPPCOLFIX
      INBTABLEAU = INBTABLEAU + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:CTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CBA4]OPPCOLFIX = 0
    Else
      [M:CBA4]OPPCOLFIX = [F:CTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  #CBA6 représente écran CRMAGD6 information
  SZREFERENCE = "[CRMAGD6]NBLIGINF"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA6]INFCOLFIX = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA6]INFCOLFIX <> 0 Then
      [F:CTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:CTR]COLFIXVAL(INBTABLEAU) = [M:CBA6]INFCOLFIX
      INBTABLEAU = INBTABLEAU + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:CTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CBA6]INFCOLFIX = 0
    Else
      [M:CBA6]INFCOLFIX = [F:CTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  #CBA8 représente écran CRMAGD7 Rendez-vous
  SZREFERENCE = "[CRMAGD7]NBLIGAPP"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA8]APPCOLFIX = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA8]APPCOLFIX <> 0 Then
      [F:CTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:CTR]COLFIXVAL(INBTABLEAU) = [M:CBA8]APPCOLFIX
      INBTABLEAU = INBTABLEAU + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:CTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CBA8]APPCOLFIX = 0
    Else
      [M:CBA8]APPCOLFIX = [F:CTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  #CBA9 représente écran CRMAGD8 Rendez-vous
  SZREFERENCE = "[CRMAGD8]NBLIGCMG"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA9]CMGCOLFIX = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA9]CMGCOLFIX <> 0 Then
      [F:CTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:CTR]COLFIXVAL(INBTABLEAU) = [M:CBA9]CMGCOLFIX
      INBTABLEAU = INBTABLEAU + 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:CTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CBA9]CMGCOLFIX = 0
    Else
      [M:CBA9]CMGCOLFIX = [F:CTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
Return

##########################################################################################################
# Traitement de gestion des champs en initialisation
$CHAMPS_INIT
Local Char SZTYP_ACTION

  SZTYP_ACTION = "INIT"
  Gosub CHAMPS
Return

##########################################################################################################
# Traitement de gestion des champs lors de l'enregistrement
$CHAMPS_ENREG
Local Char SZTYP_ACTION

  SZTYP_ACTION = "ENREG"
  Gosub CHAMPS
Return

##########################################################################################################
# Traitement de gestion des champs lors de la lecture
$CHAMPS_READ
Local Char SZTYP_ACTION

  SZTYP_ACTION = "READ"
  Gosub CHAMPS
Return

##########################################################################################################
# Traitement de gestion des champs
$CHAMPS
Local Integer INBFIENAM
Local Integer INBBLOCINVI
Local Char SZTEXTE(100)
Local Char SZCHAMPS(50)
Local Integer ITROUVE
Local Integer IVISIBLE
Local Integer IPOSITION
Local Integer IMODE
Local Integer ISAISIE
Local Integer IAFFICHE

  INBFIENAM = 0
  INBBLOCINVI = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:CTV]FIENAM
    Raz [F:CTV]FIEVAL
    Raz [F:CTR]BLOCINVI
    Gosub REORGANISE
  Endif
  #[CRMAGD0]
  #---------------------------------------------------#
  #[CRMAGD0]REP
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CBA7]REP = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:CTV]FIENAM(INBFIENAM) = "[CRMAGD0]REP"
    [F:CTV]FIEVAL(INBFIENAM) = num$([M:CBA7]REP)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[CRMAGD0]REP", [F:CTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CBA7]REP = 1
    Else
      [M:CBA7]REP = val([F:CTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[CRMAGD0]DATMIN
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CBA7]DATMIN = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:CTV]FIENAM(INBFIENAM) = "[CRMAGD0]DATMIN"
    [F:CTV]FIEVAL(INBFIENAM) = num$([M:CBA7]DATMIN)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[CRMAGD0]DATMIN", [F:CTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CBA7]DATMIN = 1
    Else
      [M:CBA7]DATMIN = val([F:CTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[CRMAGD0]DATMAX
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CBA7]DATMAX = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:CTV]FIENAM(INBFIENAM) = "[CRMAGD0]DATMAX"
    [F:CTV]FIEVAL(INBFIENAM) = num$([M:CBA7]DATMAX)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE= find("[CRMAGD0]DATMAX", [F:CTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CBA7]DATMAX = 1
    Else
      [M:CBA7]DATMAX = val([F:CTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[CRMAGD1]
  #---------------------------------------------------#
  #[CRMAGD1]AGDBAP
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CBA1]AGDBAP = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA1]AGDBAP = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:CTV]FIENAM(INBFIENAM) = "[CRMAGD1]AGDBAP"
    [F:CTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[CRMAGD1]AGDBAP",[F:CTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CBA1]AGDBAP = 1
    Else
      If val([F:CTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CBA1]AGDBAP = IAFFICHE
    Endif
  Endif
  #[CRMAGD1]AGDTSK
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CBA1]AGDTSK = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA1]AGDTSK = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:CTV]FIENAM(INBFIENAM) = "[CRMAGD1]AGDTSK"
    [F:CTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[CRMAGD1]AGDTSK", [F:CTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CBA1]AGDTSK = 1
    Else
      If val([F:CTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CBA1]AGDTSK = IAFFICHE
    Endif
  Endif
  #[CRMAGD1]AGDCLL
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CBA1]AGDCLL = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA1]AGDCLL = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:CTV]FIENAM(INBFIENAM) = "[CRMAGD1]AGDCLL"
    [F:CTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[CRMAGD1]AGDCLL", [F:CTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CBA1]AGDCLL = 1
    Else
      If val([F:CTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CBA1]AGDCLL = IAFFICHE
    Endif
  Endif
  #Gestion du bloc [CRMAGD1]5
  #---------------------#
  If SZTYP_ACTION = "ENREG" Then
    If [M:CBA1]AGDBAP <> 2 and [M:CBA1]AGDTSK <> 2 and [M:CBA1]AGDCLL <> 2 Then
      [F:CTR]BLOCINVI(INBBLOCINVI) = "[CRMAGD1]5"
      INBBLOCINVI = INBBLOCINVI + 1
    Endif
  Endif
  # Chargement du tableau
  #---------------------#
  ILIGNE = -1
  Filter [AMZ] Where CODMSK="CRMAGD1" and NUMBLOC=2 and SAIAFF=2 and CODTYP<>"ABS" Order By NUMLIG
  For [AMZ] Hint Key CODZON
    SZCHAMP = "["+[F:AMZ]CODMSK+"]"+[F:AMZ]CODZON
    ILIGNE += 1
    #
    Call TEXTE([F:AMZ]INTIT, SZTEXTE) From OBJDIV
