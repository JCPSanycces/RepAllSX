##########################################################################################################
# Traitement de gestion valeurs initiales  en initialisation
$VALINITIAL_INIT
Local Char SZTYP_ACTION

  SZTYP_ACTION = "INIT"
  Gosub VALINITIAL
Return

##########################################################################################################
# Traitement de gestion valeurs initiales lors de l'enregistrement
$VALINITIAL_ENREG
Local Char SZTYP_ACTION

  SZTYP_ACTION = "ENREG"
  Gosub VALINITIAL
Return

##########################################################################################################
# Traitement de gestion valeurs initiales lors de la lecture
$VALINITIAL_READ
Local Char SZTYP_ACTION

  SZTYP_ACTION = "READ"
  Gosub VALINITIAL
Return

##########################################################################################################
# Traitement de gestion valeurs initiales
$VALINITIAL
#Enregistrement des valeurs par defaut
Local Integer IINDICE
Local Integer IINDICETROUVE

  IINDICE = 0
  IINDICETROUVE = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:CTV]ININAM
    Raz [F:CTV]INIVAL
  Endif
  #---------------------------------------------------------------------------------------------------
  #Onglet CRM1
  #AGDBAP inclure Rendez-vous
  SZNAME = "N\[M:CRM1]AGDBAP"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA1]VALAGDBAP = 2
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      #If [F:CTV]INIVAL(IINDICETROUVE-1) = "2" Then              # FGR 09/07/2010 : X3SUIVI65946
        [M:CBA1]VALAGDBAP = val([F:CTV]INIVAL(IINDICETROUVE-1))  # FGR 09/07/2010 : X3SUIVI65946  2
      #Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    #If [M:CBA1]VALAGDBAP = 2 Then                               # FGR 09/07/2010 : X3SUIVI65946
      [F:CTV]ININAM(IINDICE) = SZNAME
      [F:CTV]INIVAL(IINDICE) = num$([M:CBA1]VALAGDBAP)           # FGR 09/07/2010 : X3SUIVI65946  "2"
      IINDICE += 1
    #Endif
  Endif
  #AGDTSK inclure tache
  SZNAME = "N\[M:CRM1]AGDTSK"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA1]VALAGDTSK = 2
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      #If [F:CTV]INIVAL(IINDICETROUVE-1) = "2" Then              # FGR 09/07/2010 : X3SUIVI65946
        [M:CBA1]VALAGDTSK = val([F:CTV]INIVAL(IINDICETROUVE-1))  # FGR 09/07/2010 : X3SUIVI65946  2
      #Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    #If [M:CBA1]VALAGDTSK = 2 Then                               # FGR 09/07/2010 : X3SUIVI65946
      [F:CTV]ININAM(IINDICE) = SZNAME
      [F:CTV]INIVAL(IINDICE) = num$([M:CBA1]VALAGDTSK)           # FGR 09/07/2010 : X3SUIVI65946  "2"
      IINDICE += 1
    #Endif
  Endif
  #AGDCLL inclure appel
  SZNAME = "N\[M:CRM1]AGDCLL"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA1]VALAGDCLL = 2
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      #If [F:CTV]INIVAL(IINDICETROUVE-1) = "2" Then              # FGR 09/07/2010 : X3SUIVI65946
        [M:CBA1]VALAGDCLL = val([F:CTV]INIVAL(IINDICETROUVE-1))  # FGR 09/07/2010 : X3SUIVI65946  2
      #Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    #If [M:CBA1]VALAGDCLL = 2 Then                               # FGR 09/07/2010 : X3SUIVI65946
      [F:CTV]ININAM(IINDICE) = SZNAME
      [F:CTV]INIVAL(IINDICE) = num$([M:CBA1]VALAGDCLL)           # FGR 09/07/2010 : X3SUIVI65946  "2"
      IINDICE += 1
    #Endif
  Endif
  #---------------------------------------------------------------------------------------------------
  #Onglet CRM7
  #SEABCS Inclure les appels en retard
  SZNAME = "N\[M:CRM7]SEABCS"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA8]VALAPPDEL = 1
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      #If [F:CTV]INIVAL(IINDICETROUVE-1) = "2" Then              # FGR 09/07/2010 : X3SUIVI65946
        [M:CBA8]VALAPPDEL = val([F:CTV]INIVAL(IINDICETROUVE-1))  # FGR 09/07/2010 : X3SUIVI65946  2
      #Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    #If [M:CBA8]VALCLLDEL = 2 Then                               # FGR 09/07/2010 : X3SUIVI65946
      [F:CTV]ININAM(IINDICE) = SZNAME
      [F:CTV]INIVAL(IINDICE) = num$([M:CBA8]VALAPPDEL)           # FGR 09/07/2010 : X3SUIVI65946  "2"
      IINDICE += 1
    #Endif
  Endif
  #---------------------------------------------------------------------------------------------------
  #Onglet CRM2
  #SEACLLDEL Inclure les appels en retard
  SZNAME = "N\[M:CRM2]SEACLLDEL"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA2]VALCLLDEL = 1
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      #If [F:CTV]INIVAL(IINDICETROUVE-1) = "2" Then              # FGR 09/07/2010 : X3SUIVI65946
        [M:CBA2]VALCLLDEL = val([F:CTV]INIVAL(IINDICETROUVE-1))  # FGR 09/07/2010 : X3SUIVI65946  2
      #Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    #If [M:CBA2]VALCLLDEL = 2 Then                               # FGR 09/07/2010 : X3SUIVI65946
      [F:CTV]ININAM(IINDICE) = SZNAME
      [F:CTV]INIVAL(IINDICE) = num$([M:CBA2]VALCLLDEL)           # FGR 09/07/2010 : X3SUIVI65946  "2"
      IINDICE += 1
    #Endif
  Endif
  #SEACLLNDT Inclure les appels non planifiés
  SZNAME = "N\[M:CRM2]SEACLLNDT"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA2]VALCLLNDT = 1
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      #If [F:CTV]INIVAL(IINDICETROUVE-1) = "2" Then              # FGR 09/07/2010 : X3SUIVI65946
        [M:CBA2]VALCLLNDT = val([F:CTV]INIVAL(IINDICETROUVE-1))  # FGR 09/07/2010 : X3SUIVI65946  2
      #Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    #If [M:CBA2]VALCLLNDT = 2 Then                               # FGR 09/07/2010 : X3SUIVI65946
      [F:CTV]ININAM(IINDICE) = SZNAME
      [F:CTV]INIVAL(IINDICE) = num$([M:CBA2]VALCLLNDT)           # FGR 09/07/2010 : X3SUIVI65946  "2"
      IINDICE += 1
    #Endif
  Endif
  #VALCLLCMG Combo pour filtre Appel lié à une campagne
  SZNAME = "N\[M:CRM2]SEACLLCMG"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA2]VALCLLCMG = 1
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      [M:CBA2]VALCLLCMG = val([F:CTV]INIVAL(IINDICETROUVE-1))
    Else
      [M:CBA2]VALCLLCMG = 1
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:CTV]ININAM(IINDICE) = SZNAME
    [F:CTV]INIVAL(IINDICE) = num$([M:CBA2]VALCLLCMG)
    IINDICE += 1
  Endif
  #---------------------------------------------------------------------------------------------------
  #Onglet CRM3
  #SEATSKRTD Tenir compte des délais cochée
  SZNAME = "N\[M:CRM3]SEATSKRTD "
  If SZTYP_ACTION = "INIT" Then
    [M:CBA3]VALTSKRTD = 1
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      #If [F:CTV]INIVAL(IINDICETROUVE-1) = "2" Then              # FGR 09/07/2010 : X3SUIVI65946
        [M:CBA3]VALTSKRTD = val([F:CTV]INIVAL(IINDICETROUVE-1))  # FGR 09/07/2010 : X3SUIVI65946  2
      #Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    #If [M:CBA3]VALTSKRTD = 2 Then                               # FGR 09/07/2010 : X3SUIVI65946
      [F:CTV]ININAM(IINDICE) = SZNAME
      [F:CTV]INIVAL(IINDICE) = num$([M:CBA3]VALTSKRTD)           # FGR 09/07/2010 : X3SUIVI65946  "2"
      IINDICE += 1
    #Endif
  Endif
  #SEATSKNDT Inclure les tâches non planifiées
  SZNAME = "N\[M:CRM3]SEATSKNDT"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA3]VALTSKNDT = 1
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      #If [F:CTV]INIVAL(IINDICETROUVE-1) = "2" Then              # FGR 09/07/2010 : X3SUIVI65946
        [M:CBA3]VALTSKNDT = val([F:CTV]INIVAL(IINDICETROUVE-1))  # FGR 09/07/2010 : X3SUIVI65946  2
      #Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    #If [M:CBA3]VALTSKNDT = 2 Then                               # FGR 09/07/2010 : X3SUIVI65946
      [F:CTV]ININAM(IINDICE) = SZNAME
      [F:CTV]INIVAL(IINDICE) = num$([M:CBA3]VALTSKNDT)           # FGR 09/07/2010 : X3SUIVI65946  "2"
      IINDICE += 1
    #Endif
  Endif
  #SEATSKDEL Inclure les tâches en retard
  SZNAME = "N\[M:CRM3]SEATSKDEL"
  If SZTYP_ACTION = "INIT" Then
    [M:CBA3]VALTSKDEL = 1
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      #If [F:CTV]INIVAL(IINDICETROUVE-1) = "2" Then              # FGR 09/07/2010 : X3SUIVI65946
        [M:CBA3]VALTSKDEL = val([F:CTV]INIVAL(IINDICETROUVE-1))  # FGR 09/07/2010 : X3SUIVI65946  2
      #Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    #If [M:CBA3]VALTSKDEL = 2 Then                               # FGR 09/07/2010 : X3SUIVI65946
      [F:CTV]ININAM(IINDICE) = SZNAME
      [F:CTV]INIVAL(IINDICE) = num$([M:CBA3]VALTSKDEL)           # FGR 09/07/2010 : X3SUIVI65946  "2"
      IINDICE += 1
    #Endif
  Endif
  #---------------------------------------------------------------------------------------------------
  #Onglet CRM4
  #NOOPPCDA Date de conclusion absente
  SZNAME = "N\[M:CRM4]NOOPPCDA"                                  # FGR 09/07/2010 : X3SUIVI65946
  If SZTYP_ACTION = "INIT" Then
    [M:CBA4]VALNODA = 1
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      #If [F:CTV]INIVAL(IINDICETROUVE-1) = "2" Then              # FGR 09/07/2010 : X3SUIVI65946
        [M:CBA4]VALNODA = val([F:CTV]INIVAL(IINDICETROUVE-1))    # FGR 09/07/2010 : X3SUIVI65946  2
      #Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    #If [M:CBA4]VALNODA = 2 Then                                 # FGR 09/07/2010 : X3SUIVI65946
      [F:CTV]ININAM(IINDICE) = SZNAME
      [F:CTV]INIVAL(IINDICE) = num$([M:CBA4]VALNODA)             # FGR 09/07/2010 : X3SUIVI65946  "2"
      IINDICE += 1
    #Endif
  Endif
  #---------------------------------------------------------------------------------------------------
  #Onglet CRM8
  #DELAY Inclure les retards
  SZNAME = "N\[M:CRM8]DELAY"                                     # FGR 09/07/2010 : X3SUIVI65946
  If SZTYP_ACTION = "INIT" Then
    [M:CBA9]VALCMGDEL = 1
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      #If [F:CTV]INIVAL(IINDICETROUVE-1) = "2" Then              # FGR 09/07/2010 : X3SUIVI65946
        [M:CBA9]VALCMGDEL = val([F:CTV]INIVAL(IINDICETROUVE-1))  # FGR 09/07/2010 : X3SUIVI65946  2
      #Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    #If [M:CBA9]VALCMGDEL = 2 Then                               # FGR 09/07/2010 : X3SUIVI65946
      [F:CTV]ININAM(IINDICE) = SZNAME
      [F:CTV]INIVAL(IINDICE) = num$([M:CBA9]VALCMGDEL)           # FGR 09/07/2010 : X3SUIVI65946  "2"
      IINDICE += 1
    #Endif
  Endif
  #EVRCLL Afficher les appels toutes campagnes confondues
  SZNAME = "N\[M:CRM8]EVRCLL"                                    # FGR 09/07/2010 : X3SUIVI65946
  If SZTYP_ACTION = "INIT" Then
    [M:CBA9]VALCMGALL = 1
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:CTV]ININAM)
    If IINDICETROUVE > 0 Then
      #If [F:CTV]INIVAL(IINDICETROUVE-1) = "2" Then              # FGR 09/07/2010 : X3SUIVI65946
        [M:CBA9]VALCMGALL = val([F:CTV]INIVAL(IINDICETROUVE-1))  # FGR 09/07/2010 : X3SUIVI65946  2
      #Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    #If [M:CBA9]VALCMGALL = 2 Then                               # FGR 09/07/2010 : X3SUIVI65946
      [F:CTV]ININAM(IINDICE) = SZNAME
      [F:CTV]INIVAL(IINDICE) = num$([M:CBA9]VALCMGALL)           # FGR 09/07/2010 : X3SUIVI65946  "2"
      IINDICE += 1
    #Endif
  Endif
  #---------------------------------------------------------------------------------------------------
  #Onglet CRM6
  #INFBAP onglet information rendez vous
  SZNAME = "N\[M:CRM6]INFBAP"
