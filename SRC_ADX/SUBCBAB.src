##########################################################################################################
# Affichage de la fenetre
$AFF_FENETRE
  Affzo [M:CBA0]1-99
  Affzo [M:CBA7]1-99
  Affzo [M:CBA1]1-99
  Affzo [M:CBA2]1-99
  Affzo [M:CBA3]1-99
  Affzo [M:CBA4]1-99
  Affzo [M:CBA6]1-99
  Affzo [M:CBA9]1-99
  Affzo [M:CBA8]1-99
Return

##########################################################################################################
#Traitement de réorganisation (tri) de tous les tableaux de la fenetre
$REORGANISE
  Gosub REORG_NBLIGAGD
  Gosub REORG_NBLIGCLL
  Gosub REORG_NBLIGTSK
  Gosub REORG_NBLIGOPP
  Gosub REORG_NBLIGINF
  Gosub REORG_NBLIGAPP
  Gosub REORG_NBLIGCMG
Return

##########################################################################################################
# Tri du tableau de l'écran CRMAGD1 agenda
$REORG_NBLIGAGD
  # FGR 13/10/2008 : X3SUIVI49651
  If dim(APPLI) >= 0 Then
    Local Mask =APPLI+".CBA1" [CBW1]
  Else
    Local Mask CBA1 [CBW1]
  Endif
  # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
  #[M:CBW1] = [M:CBA1]
  Raz [M:CBW1] : Transmask [M:CBA1] To [M:CBW1]
  # Issue X3-35454 - 2017-05-03 by FGR : END
  Sorta [M:CBW1]NBAGD [M:CBW1]NBAGD Order By [M:CBW1]AGDFIEPOS(indice) , [M:CBW1]AGDFIECOD(indice)
  # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
  #[M:CBA1] = [M:CBW1]
  Raz [M:CBA1] : Transmask [M:CBW1] To [M:CBA1]
  # Issue X3-35454 - 2017-05-03 by FGR : END
  #Affzo [M:CBA1]1-99
Return

