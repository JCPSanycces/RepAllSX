  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CBA8]SEAAPPDEL = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA8]SEAAPPDEL = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:CTV]FIENAM(INBFIENAM) = "[CRMAGD7]SEABCS"
    [F:CTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[CRMAGD7]SEABCS", [F:CTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CBA8]SEAAPPDEL = 1
    Else
      If val([F:CTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CBA8]SEAAPPDEL = IAFFICHE
    Endif
  Endif
  #Gestion du bloc [CRMAGD7]5
  #---------------------#
  If SZTYP_ACTION = "ENREG" Then
    If [M:CBA8]SEAAPPCAT<>2 and [M:CBA8]SEAAPPDEL<>2 Then
      [F:CTR]BLOCINVI(INBBLOCINVI)="[CRMAGD7]5"
      INBBLOCINVI = INBBLOCINVI + 1
    Endif
  Endif
  # Chargement du tableau
  #---------------------#
  ILIGNE = -1
  Filter [AMZ] Where CODMSK="CRMAGD7" and NUMBLOC=2 and SAIAFF=2 and CODTYP<>"ABS" Order By NUMLIG
  For [AMZ] Hint Key CODZON
    SZCHAMP = "["+[F:AMZ]CODMSK+"]"+[F:AMZ]CODZON
    ILIGNE += 1
    #
    Call TEXTE([F:AMZ]INTIT, SZTEXTE) From OBJDIV
    IVISIBLE = 2
    IMODE = 1
    IPOSITION = ILIGNE + 1
    Gosub TAB_NBLIGAPP
  Next
  Filter [AMZ]
  #---------------------------
  #CBA9 représente écran CRMAGD8 Rendez-vous
  #[CRMAGD8]
  #---------------------------------------------------#
  #[CRMAGD8]DELAY
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CBA9]SEACMGDEL = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA9]SEACMGDEL = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:CTV]FIENAM(INBFIENAM) = "[CRMAGD8]DELAY"
    [F:CTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[CRMAGD8]DELAY", [F:CTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CBA9]SEACMGDEL = 1
    Else
      If val([F:CTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CBA9]SEACMGDEL = IAFFICHE
    Endif
  Endif
  #[CRMAGD8]EVRCLL
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CBA9]SEACMGALL = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CBA9]SEACMGALL = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:CTV]FIENAM(INBFIENAM) = "[CRMAGD8]EVRCLL"
    [F:CTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[CRMAGD8]EVRCLL", [F:CTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CBA9]SEACMGALL = 1
    Else
      If val([F:CTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CBA9]SEACMGALL = IAFFICHE
    Endif
  Endif
  #Gestion du bloc [CRMAGD8]10
  #---------------------#
  If SZTYP_ACTION = "ENREG" Then
    If [M:CBA9]SEACMGDEL <> 2 and [M:CBA9]SEACMGALL <> 2 Then
      [F:CTR]BLOCINVI(INBBLOCINVI)="[CRMAGD8]10"
      INBBLOCINVI = INBBLOCINVI + 1
    Endif
  Endif
  # Chargement du tableau
  #---------------------#
  ILIGNE = -1
  Filter [AMZ] Where CODMSK="CRMAGD8" and NUMBLOC=1 and SAIAFF=2 and CODTYP<>"ABS" Order By NUMLIG
  For [AMZ] Hint Key CODZON
    SZCHAMP = "["+[F:AMZ]CODMSK+"]"+[F:AMZ]CODZON
    ILIGNE += 1
    #
    Call TEXTE([F:AMZ]INTIT, SZTEXTE) From OBJDIV
    IVISIBLE = 2
    IMODE = 1
    IPOSITION = ILIGNE + 1
    Gosub TAB_NBLIGCMG
  Next
  Filter [AMZ]
Return

##########################################################################################################
# Traitement de gestion des colonnes du tableau de l'écran CRMAGD1 Agenda
$TAB_NBLIGAGD
Local Integer ILIGNETROUVE

  If SZTYP_ACTION = "INIT" Then
    [M:CBA1]AGDFIECOD(ILIGNE) = SZCHAMP
    [M:CBA1]AGDFIENAM(ILIGNE) = SZTEXTE
    [M:CBA1]AGDFIEAFF(ILIGNE) = IVISIBLE
    [M:CBA1]AGDFIEPOS(ILIGNE) = IPOSITION
    [M:CBA1]AGDFIEMOD(ILIGNE) = IMODE
  Elsif SZTYP_ACTION = "ENREG" Then
    ILIGNETROUVE = find(SZCHAMP, [M:CBA1]AGDFIECOD)
    If ILIGNETROUVE <> 0 Then
      IVISIBLE = [M:CBA1]AGDFIEAFF(ILIGNETROUVE-1)
      If IVISIBLE = 2 Then
        ISAISIE = 1
      Else
        ISAISIE = 3
      Endif
      IPOSITION = [M:CBA1]AGDFIEPOS(ILIGNETROUVE-1) + 1
      IMODE = [M:CBA1]AGDFIEMOD(ILIGNETROUVE-1)
      [F:CTV]FIENAM(INBFIENAM) = SZCHAMP
      [F:CTV]FIEVAL(INBFIENAM) = num$(ISAISIE) + "/" + num$(IMODE) + "/" + num$(IPOSITION)
      INBFIENAM += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZCHAMP, [F:CTV]FIENAM)
    If ITROUVE = 0 Then
      ISAISIE = 1
      # FGR 22/10/2010 : X3SUIVI68490 : 1000 c'est trop grand
      #IPOSITION = 1000 + IPOSITION
      IPOSITION = 50 + IPOSITION
      IMODE = 1
    Else
      ISAISIE = val(left$([F:CTV]FIEVAL(ITROUVE-1),1))
      IPOSITION = val(right$([F:CTV]FIEVAL(ITROUVE-1),5))-1
      If IPOSITION >= 1000 Then
        IPOSITION = IPOSITION - 1000 + 50  # FGR 22/10/2010 : X3SUIVI68490 : 1000 c'est trop grand
      Endif
      IMODE = val(mid$([F:CTV]FIEVAL(ITROUVE-1),3,1))
    Endif
    [M:CBA1]AGDFIECOD(ILIGNE) = SZCHAMP
    [M:CBA1]AGDFIENAM(ILIGNE) = SZTEXTE
    If ISAISIE = 1 Then
      [M:CBA1]AGDFIEAFF(ILIGNE) = 2
    Else
      [M:CBA1]AGDFIEAFF(ILIGNE) = 1
    Endif
    [M:CBA1]AGDFIEPOS(ILIGNE) = IPOSITION
    [M:CBA1]AGDFIEMOD(ILIGNE) = IMODE
  Endif
  [M:CBA1]NBAGD = ILIGNE + 1
Return

