######################################################################################
Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
    Call DISPLAY_HIDE() From SUBHRCCVLEG
End

#**
#* FQ81085 - MABON 22/06/12 - Object HRCCV control
#*!
Subprog CONTHRCCV(COD,LEG)
Value    Char    COD
Value    Char    LEG()
  #SBA
  If COD="" : End : Endif
  #SBA fin
If func AFNC.ACTIV("LEG")=0
    LEG = GDOSLEG
  Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
    LEG = GCURLEG
  Endif
  If LEG="" Then
    LEG=GLEGFIL
  Endif

  If [L]LEG<>"" Then
    Read [F:HRCCV]CCV0=[L]COD;[L]LEG
  Else
    Read [F:HRCCV]CCV0(1)=COD
    If !fstat
      LEG = [F:HRCCV]LEG
    Endif
  Endif
  # Never mind, a LEG is mandatory, so we take the first one if necessary
  If LEG="" Then
    Read [F:HRCCV] First
    If !fstat
      LEG = [F:HRCCV]LEG
    Endif
  Endif
  Call CONTROLE("HRCCV","",LEG,COD,mkstat) From CONTOBJ
End

#**
#* FQ81085 - MABON 22/06/12 - Object HRCCV selection
#*!
$SEL_TABLE
#SBA 05/07/2012 add for sélection in other function
If GFONCTION<>"GESHRCCV"
  Gosub SAVE_GLEGFIL From TOOLSHRLEG
  GLEGFIL=GCURLEG
Else
  # FQ81491 - US1752 SBA 27062013
  Gosub SAVE_GCURLEG From TOOLSHRLEG
  GCURLEG=GLEGFIL
Endif
#SBA end
  Case TABLE
    When "SELHRCCV"
      If clalev ([F:HRCCV])=0 : Local File CLASSCONV [HRCCV] : Endif
      Filter [F:HRCCV]
      OBJET     = "HRCCV"
      START     = "[F:HRCCV]COD"
      EXPSTART  = "[F:HRCCV]COD>='"+VALEUR+"'"
      If dim([M]LEG)>0 Then
         EXPSTART += '& [F:HRCCV]LEG="'+[M]LEG+'"'
     Endif
      OPTIONS = "|"
      SUPP    = VALEUR
      #Filter based on code legislation
      If PARAM(1)<>""
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRCCV]LEG="'+PARAM(1)+'" | [F:HRCCV]LEG="")',"&") From GOBJSUB
      Endif
  Endcase
Return

#**
#* FQ81085 - MABON 22/06/12 - Object HRCCV selection
#*!
$FIN_TABLE
Local Char MLEG, MDES
Case TABLE
    When "SELHRCCV" :
      If [F:HRCCV]COD<>"" Then
        If dim([M]LEG)>0 & clalev([M:HRCCV0])>0 Then
          [M]LEG=[F:HRCCV]LEG
        Endif
        MLEG=[F:HRCCV]LEG
        # We don't use ATEXTRA.LECTEXTRA because there is ACTIONB which initializes LEG if this is blank
  #      Call LECTEXTRA([M]DESCLA(nolign-1),"CLACTR","DESCLA",[F:HRCLC]CODCLA,[M]LEG(nolign-1)) From ATEXTRA
        If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
        Read [AXX]AXX0 = "CLASSCONV";"DES";GLANGUE;[F:HRCCV]COD;MLEG
        If !fstat
          MDES = [F:AXX]TEXTE
        Else
          Read [AXX]AXX0 = "CLASSCONV";"DES";GLANDEF;[F:HRCCV]COD;MLEG
          If !fstat
            MDES = [F:AXX]TEXTE
          Else
            MDES = ""
          Endif
        Endif
        If dim([M]DES)>0 Then
          If clalev([M:HRCCV0])>0 Then [M]DES=MDES : Endif
          If clalev([M:JOT3])>0   Then [M]DES=MDES : Endif
        Endif
      Endif
  Endcase
  #SBA 05/07/2012 add for sélection in other function
    # FQ81491 - US1752 SBA 27062013
  If GFONCTION<>"GESHRCCV"
    Gosub RESTAURE_GLEGFIL From TOOLSHRLEG
  Else
    Gosub RESTAURE_GCURLEG From TOOLSHRLEG
Endif
#  If(dim(SAV_GLEGFIL)>0)
#    GLEGFIL=SAV_GLEGFIL
#    Kill SAV_GLEGFIL
#  Endif
  #SBA end
Return

#**
#* FQ81085 - MABON 22/06/12 - Tunnel towards object HRCCV
#*
#* @param COD
#* @param LEG
#* @param SOC
#*!
Subprog TUNHRCCV(COD,LEG)
Variable Char    COD()
Value    Char    LEG
#Local    Char    VCOD(GLONCCV), MLEG
Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONCCV)
 TOKILL = 1
Endif
Raz [F:HRCCV]

  If clalev([F:HRCCV])=0 : Local File CLASSCONV [HRCCV] : Endif
  # To update the HRCCV code after the tunnel order
  VCOD = COD

  If GNBLEG = 1
    LEG = GDOSLEG
  Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
    LEG = GCURLEG
  Elsif LEG=""              : # If LEG="" then firstly we search a HRCCV record with LEG="" secondly a HRCCV record with LEG<>""
    Read [HRCCV]CCV0 = VCOD;LEG
    If fstat
      Read [HRCCV]CCV0(1)=VCOD
      If !fstat
        LEG = [F:HRCCV]LEG
      Endif
    Endif
  Endif

  #MABOS-10/12/12-FQ 81085-US1025
 If VCOD="" # & GLECOBJ=2 : # GLECOBJ=2 - Chargement dernier lus
    #If no code is specified, it's better to select one of the curent legislation
    Filter [HRCCV] Where LEG=[L]LEG
    Read [F:HRCCV] First
    Filter [HRCCV]
    If !fstat : VCOD=[F:HRCCV]COD : Endif
  Elsif VCOD<>"" Then
#  If VCOD<>"" Then :
    Read [HRCCV]CCV0 = VCOD;LEG
  Endif
  If fstat : LEG = "" : Endif


  Call OBJET("HRCCV",LEG,VCOD) From GOBJET
  #COD = [F:HRCCV]COD
  COD =   VCOD
  If TOKILL : Kill VCOD : Endif
# end  #MABOS-10/12/12-FQ 81085-US1025
#  If dim([M]LEG)>0 Then
    If dim([M]DES)>0 Then
      # We don't use ATEXTRA.LECTEXTRA because there is ACTIONB which initializes LEG if this is blank
#      Call LECTEXTRA([M]DESCLA(nolign-1),"CLACTR","DESCLA",COD,[M]LEG(nolign-1)) From ATEXTRA
      If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
#      [M]LEG=[F:HRCCV]LEG # MABOS-10/12/12-FQ 81085-US1025- comment because - if there are several CCV with same code and different legs,
                           # if you select one with different leg than JOT or POT, it changes [M:JOT0]LEG (or [M:JOB0] and we don't want that.
      #Read [AXX]AXX0 = "CLASSCONV";"DES";GLANGUE;COD;[F:HRCCV]LEG
      Read [AXX]AXX0 = "CLASSCONV";"DES";GLANGUE;COD;[L]LEG
      If fstat=0
        [M]DES = [F:AXX]TEXTE
      Else
#        Read [AXX]AXX0 = "CLASSCONV";"DES";GLANDEF;COD;[F:HRCCV]LEG : #MABOS-10/12/12-FQ 81085-US1025
         Read [AXX]AXX0 = "CLASSCONV";"DES";GLANDEF;COD;[L]LEG      :#  #MABOS-10/12/12-FQ 81085-US1025
        If fstat=0
          [M]DES = [F:AXX]TEXTE
        Else
          [M]DES = ""
        Endif
      Endif
#      Affzo [M]DES(nolign-1) :  #MABOS-10/12/12-FQ 81085-US1025
      Affzo [M]DES          :#  #MABOS-10/12/12-FQ 81085-US1025
    Endif
#  Endif
End

