$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "FERME"     : Gosub FERME
 When "ABANDON"   : Gosub ABANDON
 When "LIENS"     : Gosub LIENS
 When "RAZCRE"    : Gosub RAZCRE
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "ANNULE"    : Gosub ANNULE
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "FIN_TABLE" : Gosub FIN_TABLE
 When Default
Endcase
#JOJAC - 2016-06-29 - REQ 114309 US 7 - START
#FRLAA - 2015-04-14 - Requirement 104631 US 3487 - START
If func AFNC.ACTIV("FKZQS")>0
  If func DIVPAYE.EXISTE_KXX("SUBHRCCVKSA") Then
    Gosub ACTION From SUBHRCCVKSA
  Endif
Endif
#FRLAA - 2015-04-14 - Requirement 104631 US 3487 - END
#JOJAC - 2016-06-29 - REQ 114309 US 7 - START
Return


Return


######################################################################################

$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#GCURLEG = GDOSLEG #AJC- need to check what to use to set GCURLEG??
Return

$FERME
Gosub RESTAURE_GLEGFIL From TOOLSHRLEG
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONCCV) : Endif
VCOD = CLE2
Return

$ABANDON
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$LIENS
GCURLEG = [F:HRCCV]LEG : [M:HRCCV0]LEG=GCURLEG

# FQ81085 - MABON 22/06/12 - DES and DESSHO become translatable texts
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Call LECTEXTRA([M]DES,"CLASSCONV","DES",[M]COD,GCURLEG) From ATEXTRA
Call LECTEXTRA([M]DESSHO,"CLASSCONV","DESSHO",[M]COD,GCURLEG) From ATEXTRA
# End MABON

Call DISPLAY_HIDE() From SUBHRCCVLEG
Return

#**
#* FQ81085 - MABON 22/06/12 - DES & DESSHO become translatable texts
#*!
$MODIF
$CREATION
If GREP="D"
 ## In duplication mode we keep the translated text
 Call DUPTEXTRA("CLASSCONV","DES",   CLECUR1,"","CLASSCONV","DES",   [F:HRCCV]COD,GCURLEG)  From ATEXTRA
 Call DUPTEXTRA("CLASSCONV","DESSHO",CLECUR1,"","CLASSCONV","DESSHO",[F:HRCCV]COD,GCURLEG)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,   "CLASSCONV","DES",   [F:HRCCV]COD,GCURLEG) From ATEXTRA
Call MAJTEXTRA([M]DESSHO,"CLASSCONV","DESSHO",[F:HRCCV]COD,GCURLEG) From ATEXTRA
Return

#**
#* FQ81085 - MABON 22/06/12 - To delete translated texts (data type AX3)
#*!
$ANNULE
Call SUPTEXTRA("CLASSCONV","DES",   SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("CLASSCONV","DESSHO",SUPP,[L]CODE) From ATEXTRA
Return

$RAZCRE
  GCURLEG = GLEGFIL
  Call DISPLAY_HIDE() From SUBHRCCVLEG
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran HRCCV0) 30/05/2006 16:25:15 (DBA)
######################################################################################
Subprog AS_SALMAX(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 & [M]SALMIN<>0 : VALEUR=[M]SALMIN : Endif
End

Subprog C_SALMAX(VALEUR)
Variable Decimal VALEUR
If VALEUR<[M]SALMIN
 #Valeur inférieure à
 GMESSAGE=mess(200,126,1)-num$([M]SALMIN)
 mkstat=2 : End
Endif
End


