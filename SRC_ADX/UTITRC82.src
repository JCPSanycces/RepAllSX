#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################################
# UTITRC82                                                                                           #
#                                                                                                    #
# Common data module migration update tool for V11.0.2 (V11 Patch 2)                                 #
# This script is launched when the patch 2 is applied on a V11 version                               #
#                                                                                                    #
# For a migration to a highest version than V11, if the source folder level is lower                 #
# than 11.0.2, the script TRCMAJ82 is executed with DOSMAJ82                                         #
#                                                                                                    #
# 107888 : Scheduled invoices : X3-21402 (LD:18/01/17)                                               #
# Update of SFOOTINV table                                                                           #
# New transfer rules (feature 107888/107890)                                                         #
# Initialized fields :                                                                               #
# --RULE : Normal orders to Invoices (for service type items)                                        #
#   ORIVCR(7) : entry 10 "Normal order"         of local menu 476 - 'Type de document ventes'        #
#   DESVCR(7) : entry  4 "Invoice"              of local menu 476 - 'Type de document ventes'        #
#   BRDRUL(7) : same as the value of each invoicing element's existing rule Normal order to Delivery #
#   GRUFLG(7) : same as the value of each invoicing element's existing rule Normal order to Delivery #
#   GRURUL(7) : same as the value of each invoicing element's existing rule Normal order to Delivery #
######################################################################################################
  Call MAJ_UTITRC82
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTITRC82
Local Char DOSSIER(30)

  DOSSIER=nomap
  Call SAIDOSHIS(DOSSIER,"UTITRC82 - Upgrade process to V11 patch 2 for common data module") From SAIDOSHIS
  If DOSSIER <> "" Then
    If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
    If func DOSSUB.FILL_ADS(DOSSIER)=0 : End : Endif
    If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
        Call TEMPON("O") From GESECRAN
        Call OUVRE_TRACE("UTITRC82 - Upgrade process to V11 patch 2 for common data module") From LECFIC
        Call EXE_UTITRC82(DOSSIER)
        Call TEMPOFF From GESECRAN
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
  Endif
End

#-------------------------------------------------------------------------------#
Subprog EXE_UTITRC82(DOSSIER)
Value Char    DOSSIER

  Call ECR_TIME("UTITRC82 : Start folder's process"-DOSSIER) From DOSSUB

#  #----- Chargement globale GMAXUPDTRS -----#
#  If dim([V]GMAXUPDTRS) < 1 Then
#    Global Integer GMAXUPDTRS
#  Endif
#  Local File =DOSSIER+".ADOVAL" [ADW]
#  Read [ADW] ADW0="";"";"MAXUPDTRS"
#  If fstat Then
#    Raz [F:ADW]
#  Endif
#  If val([F:ADW]VALEUR) > 0 Then
#    GMAXUPDTRS = val([F:ADW]VALEUR)
#  Else
#    GMAXUPDTRS = 1000
#  Endif
#  Close Local File [ADW]

  # 107888 : Scheduled invoices : X3-21402 (LD:18/01/17)
  #----- Start Update SFOOTINV -----#
  Gosub TRT_SFI
  #----- End Update SFOOTINV -----  #
  # 107888 : Scheduled invoices : X3-21402 (LD:18/01/17)

$FIN_UTITRC82
  Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
  Call ECR_TIME("UTITRC82 : End folder's process"-DOSSIER) From DOSSUB
End

# 107888 : Scheduled invoices : X3-21402 (LD:18/01/17)
$TRT_SFI

If GTRACE=""
 Call OUVRE_TRACE("UTITRC82 - Upgrade process to V11 patch 2 for common data module") From LECFIC
 Local Integer LTRACE
Endif

If filinfo(filpath("FIL","SFOOTINV","fde",DOSSIER),0) <= 0 Return Endif

Local File =DOSSIER+".SFOOTINV"    [SFI]

GOK=1
Trbegin [SFI]
For [SFI]
  #------------------------------------------
  #--same values as Normal order to Delivery
  [SFI]ORIVCR(7)=10
  [SFI]DESVCR(7)=4
  If    [SFI]BRDRUL(2)=2 #--1st Invoice instead of 1st Delivery
    [SFI]BRDRUL(7)=3
  Elsif [SFI]BRDRUL(2)=6 #--All Invoices instead of All Deliveries
    [SFI]BRDRUL(7)=7
  Else
    [SFI]BRDRUL(7)=[SFI]BRDRUL(2)
  Endif
  [SFI]GRUFLG(7)=[SFI]GRUFLG(2)
  [SFI]GRURUL(7)=[SFI]GRURUL(2)
  #------------------------------------------
  Rewrite [SFI]
  If fstat
   GOK=0
   Call ECR_TRACE("UTITRC82/TRT_SFI => Error update SFOOTINV="+num$(fstat),1) From GESECRAN
  Else
   Call ECR_TRACE("UTITRC82/TRT_SFI => Update SFINUM="-num$([F:SFI]SFINUM),0) From GESECRAN
  Endif
Next

If GOK<1
 Rollback
Else
 #Rollback
 Commit
Endif

If dim(LTRACE)>0
 Call LEC_TRACE From LECFIC
Endif

Close Local File [SFI]

Return
#################################################################################
# 107888 : Scheduled invoices : X3-21402 (LD:18/01/17)


#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSSUB.ISHISTFOLD(APPLI)=0
      Call EXE_UTITRC82(APPLI)
  Endif
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSSUB.ISHISTFOLD(APPLI)=0
      Call EXE_UTITRC82(APPLI)
  Endif
End

