#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UUMGTRTGPA01   Migration des en-cours de production        Module GPA  #
##########################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(DOSSIER,"") From SAIDOS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTGPA01") From LECFIC
  Endif

#  Call RAZ_UUMGTRTGPA01(DOSSIER)
  Call MAJ_UUMGTRTGPA01(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

Subprog MAJ_UUMGTRTGPA01(DOSSIER)
Value Char DOSSIER

Local Integer ERR

If [F:ADS]MODULE(7)<>2 : : # 7=GPAO
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

Local Char WNAMMWHM,WNAMMWIM,WNAMMFCM
Call MIGTABNAME (DOSSIER,"MFGWIP",WNAMMWHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"WIPCOST",WNAMMWIM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"MFGCOST",WNAMMFCM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMMWHM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMMWIM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMMFCM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA01",2,ERR) From TRTMIG : #2=En cours

Call ECR_TIME("UUMGTRTGPA01 tables MWH Process : Update MWH") From DOSSUB
Call ECR_TRACE("UUMGTRTGPA01 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"MFGWIP",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"WIPCOST",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:MWH])  = 0 : Local File =DOSSIER+".MFGWIP"    [MWH]  : Endif   # Fichier X3 "Vide"
If clalev([F:MWI])  = 0 : Local File =DOSSIER+".WIPCOST"    [MWI]  : Endif   # Fichier X3 "Vide"

If clalev([F:MWHM]) = 0 : Local File =DOSSIER+"."+WNAMMWHM   [MWHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:MWIM]) = 0 : Local File =DOSSIER+"."+WNAMMWIM   [MWIM] : Endif   # Fichier X3 renommé Avant Migration
# Abréviation sans "M" pour utilisation d'un sous-pro dans UTIGPA37
If clalev([F:MFC]) = 0 : Local File =DOSSIER+"."+WNAMMFCM   [MFC] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz STOP, CRITERE, NBCOMMIT, NBLUS

# Déclaration des variables communes de travail
Local Integer I, J
Local Char WMFGFCY(20)

# pour les WriteB des tables détails
Local Char WTAB_MWH (100) (adxwrb)
Local Char WTAB_MWI (100) (adxwrb)
Local Shortint WCPT_MWH,WCPT_MWI


#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTGPA01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

#-----  Lien des tables entête & lignes -----#
Link [MWIM] With [MWHM]MWH0~=[F:MWIM]MFGNUM
&    As [LNK]
&    Order By Key CLE = [F:MWIM]MFGFCY;[F:MWIM]MFGNUM;[F:MWIM]WIPSEQ

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTGPA01" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Gosub INIT_TBO From UUMGTRTSTO00

$LOOP_GPA01
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:MWHM]MFGFCY=TABMIGKEY(1) & [F:MWHM]MFGNUM>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:MWHM]MFGFCY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [MWH],[MWI]
GOK = 1

For [LNK]CLE(2) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTGPA01" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  Raz [F:MWH]       # Issue 91893 - 2013-08-20 by CCC
  [F:MWH] = [F:MWHM]

  #Appel proc de migration sur entete
  Gosub MAJ30_MWH
  If GOK<1 : Break : Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  For [LNK]CLE
    Raz [F:MWI]     # Issue 91893 - 2013-08-20 by CCC
    #rupture par ligne de facture
    [F:MWI] = [F:MWIM]

    #Appel proc de migration sur detail
    Gosub MAJ30_MWI
    If GOK<1 : Break : Endif

    Gosub MWI_STK : # pour stocker ref
    WriteB [MWI]
    If fstat
        Call ECR_TRACE("File WIPCOST, Error ="-num$(fstat),1) From GESECRAN
        Gosub MWI_ERRTRA : # pour afficher les ref
        GOK=0 : Break
    Endif
  Next

  If GOK<1 : Break : Endif

  # --- alimentation des champs et écriture enreg
   # --- alimentation des champs et écriture enreg
  Gosub MWH_STK : # pour stocker ref
  WriteB [F:MWH]
  If fstat
      Call ECR_TRACE("File MFGWIP, Error ="-num$(fstat),1) From GESECRAN
      Gosub MWH_ERRTRA : # pour afficher les ref
      GOK=0 : Break
  Endif

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:MWHM]MFGFCY
    TABMIGKEY(2) = [F:MWHM]MFGNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA01",7,ERR) From TRTMIG : #7=Erreur
Else
    Flush [F:MWH]
    If fstat
        Call ECR_TRACE("File MFGWIP, Error ="-num$(fstat),1) From GESECRAN
        Gosub MWH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:MWI]
    If fstat
        Call ECR_TRACE("File WIPCOST, Error ="-num$(fstat),1) From GESECRAN
        Gosub MWI_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
    If STOP
      TABMIGKEY(3)=num$(STOP)
    Else
      Raz TABMIGKEY
    Endif
    Call MIGSTKKEY (DOSSIER,"UUMGTRTGPA01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
    If ERR
     GOK=-1 : Goto FIN_BOUCLE
    Endif
    Commit
    NBCOMMIT += NB
    Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTGPA01",STOP,ERR) From TRTMIG
    If STOP
      Goto LOOP_GPA01
    Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [MWH], [MWI]
Close Local File [MWHM], [MWIM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"MFGWIP",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"WIPCOST",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTGPA01") From TRTMIG
Call ECR_TIME("UUMGTRTGPA01 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed") From DOSSUB
End

################################################
$MAJ30_MWH
    [F:MWH]VCRNUM=[F:MWHM]MFGNUM
    If [F:MWH]TRKTYP=1
        [F:MWH]VCRTYP=10
    Else
        [F:MWH]VCRTYP=37
    Endif
    If [F:MWH]BOMALT>0
        [F:MWH]BOMALTTYP = WBOMALTTYP([F:MWHM]BOMALT)
    Else
        [F:MWH]BOMALTTYP = 0
    Endif
Return

################################################
$MAJ30_MWI
    [F:MWI]VCRNUM=[F:MWIM]MFGNUM
    [F:MWI]VCRLIN=[F:MWIM]MFGLIN
    [F:MWI]VCRTYP=[F:MWH]VCRTYP
    # Issue 82776 - 2012-08-08 by CCC : migration des sections analytiques
    #----- Alimentation champs pour le multi-référenciels comptabilité -----#
    If [F:MWI]MFGFCY<>WMFGFCY
       Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:MWI]MFGFCY) From TRTX3CPT
       WMFGFCY = [F:MWI]MFGFCY
    Endif
    [F:MWI]CCE(0) = [F:MWIM]CCE1
    [F:MWI]CCE(1) = [F:MWIM]CCE2
    [F:MWI]CCE(2) = [F:MWIM]CCE3
    [F:MWI]CCE(3) = [F:MWIM]CCE4
    [F:MWI]CCE(4) = [F:MWIM]CCE5
    [F:MWI]CCE(5) = [F:MWIM]CCE6
    [F:MWI]CCE(6) = [F:MWIM]CCE7
    [F:MWI]CCE(7) = [F:MWIM]CCE8
    [F:MWI]CCE(8) = [F:MWIM]CCE9
    For I=1 To max(GNBDIE,GOPTCANA)
       [F:MWI]DIE(I-1)=GDIE(I)
    Next I
    # Issue 84658 - 2012-11-15 by CCC
    Gosub ALIM_MWICST From UTIGPA37

    # Issue 91947 - 2013-08-21 by CCC : initialize new cost detail fields
    If find([F:MWI]TXNTYP,1,14) & [F:MWI]OVENAT=""
        [F:MWI]SCOCST = [F:MWI]CSTELM(11)
        [F:MWI]OVEMATCST = [F:MWI]CSTELM(12)
        [F:MWI]OVELABCST = [F:MWI]CSTELM(13)
        [F:MWI]OVEMACCST = [F:MWI]CSTELM(14)
        [F:MWI]OVESCOCST = [F:MWI]CSTELM(15)
    Endif
Return

################################################
$MWH_STK
Call STK (WTAB_MWH,WCPT_MWH,num$([F:MWH]VCRTYP)-'/'-[F:MWH]VCRNUM) From TRTMIG
Return
$MWI_STK
Call STK (WTAB_MWI,WCPT_MWI,num$([F:MWI]VCRTYP)-'/'-[F:MWI]VCRNUM-'/'-num$([F:MWI]WIPSEQ)) From TRTMIG
Return
##############################################################################################
$MWH_ERRTRA
Call ERRTRA (WTAB_MWH,WCPT_MWH,"File MFGWIP(MFGNUM)=") From TRTMIG
Return
$MWI_ERRTRA
Call ERRTRA (WTAB_MWI,WCPT_MWI,"File WIPCOST(MFGNUM/WIPSEQ)=") From TRTMIG
Return

##########################################################################
Subprog RAZ_UUMGTRTGPA01(DOSSIER)
Value Char DOSSIER

Local Integer ERR
Local Char WNAMMWHM,WNAMMWIM,WNAMMFCM
Call MIGTABNAME (DOSSIER,"MFGWIP",WNAMMWHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"WIPCOST",WNAMMWIM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"MFGCOST",WNAMMFCM,ERR) From TRTMIG

If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMMWHM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL",WNAMMWIM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL",WNAMMFCM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif

Call MIGTABRAZ (DOSSIER,"MFGWIP",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"WIPCOST",ERR) From TRTMIG

Call MIGRAZKEY (DOSSIER,"UUMGTRTGPA01",ERR) From TRTMIG

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call MAJ_UUMGTRTGPA01(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif

Call MAJ_UUMGTRTGPA01(APPLI)
End

