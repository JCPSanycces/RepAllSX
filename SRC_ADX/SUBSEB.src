#<AdxTL>@(#)0.0.0.0 $Revision$
# SUBSEB - Sage Exchange BP Customer Accounts - credit cards

$ACTION

Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "FILTRE"      : Gosub FILTRE
  When "RAZCRE"      : Gosub RAZCRE
  When "RAZDUP"      : Gosub RAZDUP
  When "SETBOUT"     : Gosub SETBOUT
  When "STATUT"      : Gosub STATUT
  When "VERF_ANU"    : Gosub VERF_ANU
  When "LIENS"       : Gosub LIENS
  When "INICRE"      : Gosub INICRE
  When "VERIF_MOD"   : Gosub VERIF_MOD
  When "ANNULE"      : Gosub ANNULE
  When "VERIF_CRE"   : Gosub VERIF_CRE
  When Default
Endcase

Return
######################################################################################
$OUVRE

# [F:SER] SEPRC - Sage Exchange Processing Setup - opened in object
If !clalev([F:SEP])  : Local File SEPAR       [SEP]  : Endif  # Sage Exchange Parameters
If !clalev([F:SEB2]) : Local File SEBPC       [SEB2] : Endif  # Sage Exchange Customer Accounts
If !clalev([F:SEU])  : Local File SEAUTH      [SEU]  : Endif  # Credit Card Authorization table

If !clalev([F:BPA])  : Local File BPADDRESS   [BPA]  : Endif  # BP Address
If !clalev([F:CNT])  : Local File CONTACT     [CNT]  : Endif  # Contact
If !clalev([F:BPC2]) : Local File BPCUSTOMER  [BPC2] : Endif  # BP Customer

Return

######################################################################################
$FILTRE
FILTRE = "ONETIME<2"
Return

######################################################################################
$SETBOUT
If GREP<>"C" and GREP <>"D"
  Diszo [M:SEB1]PRCCOD
Endif

Return

######################################################################################
$STATUT

Local Integer ERR
Local Char    ERRMSG(100)

If BOUT="R"   #Recover
  Call VAULT_QUERY([M:SEB1]BPCNUM,[M:SEB1]ACCNCKNAM,[M:SEB1]PRCCOD,num$([F:SEB]AUUID)+num$([F:SEB]VLTREQ),0,ERR,ERRMSG) From SEPPLIB
  If ERR
    Call ERREUR(ERRMSG) From GESECRAN
  Else
    [M:SEB1] = [F:SEB]
    Affzo [M:SEB1]
  Endif
Endif

Return
######################################################################################
$RAZCRE

If [M:SEB1]BPCNUM<>""
    Gosub GET_BILL_ADDRESS
    Gosub GET_EMAIL_ADDRESS
Else
    [M:SEB1]USEBILLADR = 1
Endif

Affzo [M:SEB1]
Actzo [M:SEB1]PRCCOD

# 109253 - show corect name fields based on payment processor
Call FMTNAM([F:SER]PAYPRC)
[M:SEB1]PAYPRC = [F:SER]PAYPRC
Affzo [M:SEB1]PAYPRC

Return
######################################################################################
$RAZDUP

Raz [M:SEB1]PYMTYP, CRDTYP, ACCL4D, EXPDAT, VLTID, VLTGUID, VLTREQ
Affzo [M:SEB1]
Actzo [M:SEB1]PRCCOD

Return
######################################################################################
$GET_BILL_ADDRESS

Read [F:BPC2]BPC0=[M:SEB1]BPCNUM
If fstat : Return : Endif

Filter [BPA] Where BPAADDFLG>1 & BPANUM=[M:SEB1]BPCNUM
Read [BPA] First
Filter [BPA]
If fstat
  [M:SEB1]USEBILLADR=1
  Actzo [M:SEB1]CRY, ADDLIG, SAT, POSCOD, CTY
  Return
Endif

[M:SEB1]USEBILLADR   = 2
[M:SEB1]ADDLIG(0)    = [F:BPA]BPAADDLIG(0)
[M:SEB1]ADDLIG(1)    = [F:BPA]BPAADDLIG(1)
[M:SEB1]CTY          = [F:BPA]CTY
[M:SEB1]SAT          = [F:BPA]SAT
[M:SEB1]POSCOD       = [F:BPA]POSCOD
[M:SEB1]CRY          = [F:BPA]CRY

Diszo [M:SEB1]CRY, ADDLIG, SAT, POSCOD, CTY

Return
######################################################################################
$GET_EMAIL_ADDRESS

If [F:BPC2]BPCNUM <> [M:SEB1]BPCNUM
  Read [F:BPC2]BPC0=[M:SEB1]BPCNUM
  If fstat : Return : Endif
Endif

# Get email address from Default Contact
Read [F:CNT]CNT0=1;[M:SEB1]BPCNUM;[F:BPC2]CNTNAM
If fstat = 0
  [M:SEB1]EMAIL = [F:CNT]WEB
Else
  Raz [M:SEB1]EMAIL
Endif

Return
######################################################################################
$INICRE

Gosub CRE_UPD_DETAILS

If GERR : GOK=0 : Return : Endif

Return
######################################################################################
$VERIF_MOD
# Sidestep "Obsolete record" error
If dim([L]ANOUPDTICK)>0
  [L]ANOUPDTICK=[M]ANOUPDTICK
  [M]ANOUPDTICK = 0
Endif
Return
######################################################################################
$LIENS

If [M:SEB1]PRCCOD<>""
  Read [F:SER]SER0=[M:SEB1]PRCCOD
  If fstat = 0
    [M:SEB1]CPY = [F:SER]CPY
  Endif
Endif

Call FMTNAM([F:SER]PAYPRC)		# 109253.n

[M:SEB1]PAYPRC = [F:SER]PAYPRC
Affzo [M:SEB1]PAYPRC

Call SET_FLGS([M:SEB1]FLACT,[M:SEB1]CPY)

If [M:SEB1]USEBILLADR=2 : Gosub GET_BILL_ADDRESS  : Endif



Return
######################################################################################
$VERF_ANU

# See if account has been used, if so, don't allow the delete
Filter [SEU] Where BPCNUM=[M:SEB1]BPCNUM & ACCNCKNAM=[M:SEB1]ACCNCKNAM
Read [SEU] Last
Filter [SEU]
If !fstat
  GMESSAGE = mess(32,2092,1)  # At least one transaction against account.  Cannot delete account.
  GERR=1 : OK = 0
Endif

Return
######################################################################################
$ANNULE
# Delete the card from the vault

# If Sage Pay and expired, it will be deleted already.  No need to delete now.
If [F:SER]PRCCOD<>[M:SEB1]PRCCOD : Read [F:SER]SER0=[M:SEB1]PRCCOD : Endif
If [M:SEB1]EXPDAT<date$ & [F:SER]PAYPRC=2 : Return : Endif

Local Char RESP
Call VAULT_DEL([M:SEB1]PRCCOD,GERR,GMESSAGE) From SEPPLIB  # 109253 - changed call from SEPPXML to SEPPLIB
If GERR : Raz GOK : Endif
Return
######################################################################################
$VERIF_CRE
# verify processing code is populated
If [M:SEB1]PRCCOD=""
  GMESSAGE = mess(10,123,1)
  zonsui = "PRCCOD"
  GERR=1 : OK=0 : Return
Endif
Return
######################################################################################
#
# Screen Field actions
#
######################################################################################
Subprog C_FLDEF(VALEUR)
Variable Integer VALEUR

If VALEUR = 2

  Filter [F:SEB2] Where BPCNUM=[M:SEB1]BPCNUM and ACCNCKNAM<>[M:SEB1]ACCNCKNAM and PRCCOD=[M:SEB1]PRCCOD and FLDEF=2
  Read [F:SEB2] First
  Filter [F:SEB2]
  If fstat = 0
    GMESSAGE = mess(27,2092,1) : mkstat = 2 : End  # Processing code already has a default account.
  Endif

Endif

End
######################################################################################
Subprog AM_FLACT(VALEUR)
Variable Integer VALEUR

If VALEUR = 1
  If [M:SEB1]FLDEF=2       # if they make inactive, then it cannot be the default
    [M:SEB1]FLDEF=1
    Affzo [M:SEB1]FLDEF
  Endif
  Diszo [M:SEB1]FLDEF
  Diszo [M:SEB1]CRY, ADDLIG, SAT, POSCOD, CTY, USEBILLADR, EMAIL, ACCNAM
Else
  If [M:SEB1]USEBILLADR<>2 : Actzo [M:SEB1]CRY, ADDLIG, SAT, POSCOD, CTY : Endif
  Actzo [M:SEB1]USEBILLADR, EMAIL, ACCNAM
  If [M:SEB1]PRCCOD <> ""
    Call AM_PRCCOD([M:SEB1]PRCCOD)  # to set the default flag
  Else
    Actzo [M:SEB1]FLDEF
  Endif
Endif

End
######################################################################################
Subprog AM_ACCNCKNAM(VALEUR)
Variable Char    VALEUR()

If [M:SEB1]PRCCOD <> ""

  Filter [F:SEB2] Where BPCNUM=[M:SEB1]BPCNUM and ACCNCKNAM<>VALEUR and PRCCOD=[M:SEB1]PRCCOD and FLDEF=2

  Read [F:SEB2] First
  If fstat = 0
    [M:SEB1]FLDEF = 1
  Else
    [M:SEB1]FLDEF = 2
  Endif

  Filter [F:SEB2]
  Affzo [M:SEB1]FLDEF

Endif

End
######################################################################################
Subprog AP_PRCCOD(VALEUR)
Variable Char    VALEUR()

  If VALEUR = ""
    Raz [M:SEB1]CPY
    Affzo [M:SEB1]CPY
  Elsif [F:SER]PRCCOD <> VALEUR or [M:SEB1]CPY <> [F:SER]CPY
    Read [F:SER]SER0=VALEUR
    If !fstat
      [M:SEB1]CPY = [F:SER]CPY
      Affzo [M:SEB1]CPY
    Endif
  Endif

End
######################################################################################
Subprog AM_PRCCOD(VALEUR)
Variable Char    VALEUR()

If [F:SER]PRCCOD <> VALEUR
  Read [F:SER]SER0=VALEUR
Endif

# Special case where some deactivated a processing code after it was used, therefore cannot be default
If [F:SER]FLACT <> 2 : [M:SEB1]FLDEF=1 : Affzo [M:SEB1]FLDEF : Diszo [M:SEB1]FLDEF : End : Endif

Filter [F:SEB2] Where BPCNUM=[M:SEB1]BPCNUM and ACCNCKNAM<>[M:SEB1]ACCNCKNAM and PRCCOD=VALEUR and FLDEF=2

Read [F:SEB2] First
If fstat = 0
  [M:SEB1]FLDEF = 1
  Diszo [M:SEB1]FLDEF
Else
  [M:SEB1]FLDEF = 2
  Actzo [M:SEB1]FLDEF
Endif

Filter [F:SEB2]
Affzo [M:SEB1]FLDEF

# 109253 - show corect name fields based on payment processor
Call FMTNAM([F:SER]PAYPRC)

[M:SEB1]PAYPRC = [F:SER]PAYPRC
Affzo [M:SEB1]PAYPRC

End
######################################################################################
Subprog CL_ACCDET(VALEUR)
Variable Char    VALEUR()

If GREP = ""
  Gosub CRE_UPD_DETAILS
Else
  GMESSAGE = mess(13,2092,1)  # Save before going to details
Endif

End
######################################################################################
$CRE_UPD_DETAILS

#
# Update Account table indicating a submission (VLTREQ) was "likely" sent to Sage exchange
# Also pass a new transaction/vault id based on AUUID and VLTREQ that will be associated with the VLTGUID in Sage Exchange
#

If GREP="C" or GREP="D"     # Create or Duplicate
  [F:SEB]VLTREQ=1
  # Create the Details (account number, expiration, etc.)
  Call VAULT_CRE([M:SEB1]BPCNUM,[M:SEB1]ACCNCKNAM,[M:SEB1]PRCCOD,num$(uuid$)+num$([F:SEB]VLTREQ),GERR,GMESSAGE) From SEPPLIB
  If [F:SEB]VLTGUID="" and find(GERR,0,99)
    GERR=1
    GMESSAGE=mess(28,2092,1)  # Error creating credit card
  Endif

Else
  Read [F:SEB]SEB0=[M:SEB1]BPCNUM;[M:SEB1]ACCNCKNAM
  If fstat
    Call RSTA("SEB","") From GLOCK
    GMESSAGE = mess(81,75,1) - [M:SEB1]BPCNUM-[M:SEB1]ACCNCKNAM
    GERR = 1 : Return
  Endif

  # Update the Details (account number, expiration, etc.)
  Call VAULT_CRE([M:SEB1]BPCNUM,[M:SEB1]ACCNCKNAM,[M:SEB1]PRCCOD,num$([F:SEB]AUUID)+num$([F:SEB]VLTREQ+1),GERR,GMESSAGE) From SEPPLIB
  If !GERR
    Trbegin [SEB]
    [F:SEB]VLTREQ += 1
    Rewrite [F:SEB]
    If fstat
      Call FSTA("SEB") From GLOCK
      Rollback
      GERR=1
      Return
    Else
      Commit
    Endif
  Elsif [F:SEB]VLTGUID="" and find(GERR,0,99)
    GERR=1
    GMESSAGE=mess(28,2092,1)  # Error creating credit card
  Endif
Endif

If GERR : Return : Endif

[M:SEB1] = [F:SEB]
Affzo [M:SEB1]
[M]ANOUPDTICK=1

Return
######################################################################################
Subprog AV_PYMTYP(VALEUR)
Variable Char    VALEUR()
VALEUR = func AFNC.TEXTRA("ATABDIV","LNGDES","398",[M:SEB1]CRDTYP)
End
######################################################################################
Subprog AM_USEBILLADR(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
  Gosub GET_BILL_ADDRESS
  Affzo [M:SEB1]
Else
  Actzo [M:SEB1]CRY, ADDLIG, SAT, POSCOD, CTY
Endif

End
######################################################################################
Subprog D_PRCCOD(VALEUR)
Variable Char    VALEUR()
Local Integer III

III = 0
For [F:SER] Where FLACT=2
  III += 1
  If III >= 2
    Raz VALEUR
    Break
  Endif
  VALEUR = [F:SER]PRCCOD
Next

End

######################################################################################
Subprog SET_FLGS(FLACT,CPY)
Value Integer FLACT   # Active flag
Value Char    CPY

Local Integer FLDEF : FLDEF = [M:SEB1]FLDEF

Actzo [M:SEB1]FLACT   # Enable Active
If GREP="C" & [M:SEB1]FLACT=[L]FLACT  # Auto activate on creation
  FLACT = 2
Endif
If FLACT<>2           # Record not active, disable Default
  Diszo [M:SEB1]FLDEF
  Diszo [M:SEB1]CRY, ADDLIG, SAT, POSCOD, CTY, USEBILLADR, EMAIL, ACCNAM, FSTNAM, LSTNAM
  FLDEF = 1
Else
  Actzo [M:SEB1]USEBILLADR, EMAIL
  # Active and processing code and company entered
  If FLACT=2 & [M:SEB1]PRCCOD<>"" & CPY<>""
    # Look to see if default is already set on another processing code for this company
    Filter [F:SEB2] Where BPCNUM=[M:SEB1]BPCNUM and ACCNCKNAM<>[M:SEB1]ACCNCKNAM and PRCCOD=[M:SEB1]PRCCOD and FLDEF=2
    Read [F:SEB2] First
    Filter [F:SEB2]
    If fstat=4
      Actzo [M:SEB1]FLDEF
      If GREP="C"     # Auto default on creation if no other default for company
        FLDEF = 2
      Endif
    Else              # Default already exists for this company
      Diszo [M:SEB1]FLDEF
      If GREP="C" or GREP="D"    # Default on creation if no other default for company
        FLDEF = 1
      Endif
    Endif
    Filter [F:SEB2]
  Else                # Record not active, or processing code and company not entereed
    Diszo [M:SEB1]FLDEF
    FLDEF = 1
  Endif
Endif

[M:SEB1]FLACT  = [L]FLACT
[M:SEB1]FLDEF  = [L]FLDEF

Affzo [M:SEB1]FLACT,FLDEF

If [M:SEB1]USEBILLADR=2
  Diszo [M:SEB1]CRY, ADDLIG, SAT, POSCOD, CTY
Else
  Actzo [M:SEB1]CRY, ADDLIG, SAT, POSCOD, CTY
Endif

End

######################################################################################
Subprog FMTNAM(PROCESSOR)
Value Integer PROCESSOR

# 109253 - If Sage Exchange - show Merchant, else show Vendor
If PROCESSOR=1
  #Disable First and Last name
  Effzo [M:SEB1]FSTNAM
  Effzo [M:SEB1]LSTNAM
  Grizo [M:SEB1]FSTNAM
  Grizo [M:SEB1]LSTNAM

  #Enable Account name
  Actzo [M:SEB1]ACCNAM

  #Show updates
  Chgfmt [M:SEB1]ACCDET     With "+K"

  # 111621.n - Show email
  Chgfmt [M:SEB1]EMAIL      With "+K"
Else
  #Enable First and Last name
  Actzo [M:SEB1]FSTNAM
  Actzo [M:SEB1]LSTNAM

  #Disable Account name
  Effzo [M:SEB1]ACCNAM
  Diszo [M:SEB1]ACCNAM

  #Hide updates
  Chgfmt [M:SEB1]ACCDET     With "-K"

  # 111621.n - Hide email
  Chgfmt [M:SEB1]EMAIL      With "-K"
Endif

End

######################################################################################
Subprog C_FSTNAM(VALEUR)
Variable Char    VALEUR()
  # 111621.n - Verify name format
  If !func SEPPLIB.VALID_NAME(VALEUR)
    GMESSAGE = mess(112,123,1) : mkstat = 2 : End
  Endif
End

######################################################################################
Subprog C_LSTNAM(VALEUR)
Variable Char    VALEUR()
  # 111621.n - Verify name format
  If !func SEPPLIB.VALID_NAME(VALEUR)
    GMESSAGE = mess(112,123,1) : mkstat = 2 : End
  Endif
End


######################################################################################

