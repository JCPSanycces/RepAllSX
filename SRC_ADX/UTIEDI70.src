#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################
# X3-46906 EDI migration tool (JUCON 29/06/17)  #
# Tool to adapt EDI categories from PU9 to PU10 #
#################################################

  Call MAJ_UTIEDI01(nomap)
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 : End : Endif

  If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

  # Check Common Data Module
  If [F:ADS]MODULE(8)<>2 : End : Endif

  Call MAJ_UTIEDI01(APPLI)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI=GDOSX3: End : Endif
  # Check Common Data Module
  If [F:ADS]MODULE(8)<>2 : End : Endif

  Call MAJ_UTIEDI01(APPLI)

End

########################################################################
Subprog AMAJ
  Call AMAJ_UTIEDI01([F:ADS]DOSSIER)
End

#######################################################################
Subprog AMAJ_UTIEDI01(APPLI)
Value Char APPLI

  If APPLI=GDOSX3: End : Endif

  If APPLI=GDOSH: End : Endif

  # Controling EDIX3 activity code

  Local Integer WOK : WOK=func AFNC.ACTIVDOS(DOSSIER,"EDIX3")

  If WOK=0: End: Endif  # EDIX3 activity code not active

  If clalev([F:ETC])  = 0 : Local File =APPLI + ".EDITMPDOC" [ETC]  : Endif

  Call ECR_TRACE("UTIEDI70_AMAJ : Start of process on : "+APPLI,0) From GESECRAN

  Gosub DEL_REC_ETC

  Call ECR_TRACE("UTIEDI70_AMAJ : EDITMPDOC."-mess(52,123,1),0) From GESECRAN
  Call ECR_TRACE("UTIEDI70_AMAJ : End of process on : "+APPLI,0) From GESECRAN

End

########################################################################
Subprog MAJ_UTIEDI01(DOSSIER)
Value Char DOSSIER

  If DOSSIER=GDOSH: End : Endif

  # Controling EDIX3 activity code

  Local Integer WOK : WOK=func AFNC.ACTIVDOS(DOSSIER,"EDIX3")

  If WOK=0: End: Endif  # EDIX3 activity code not active

  Local Char TIT(70)
  Local Integer NBTRAIT

  TIT="EDI:"-mess(81,125,1)-tolower(mess(655,197,1)) # Tittle of this tool

  If GSERVEUR : Onerrgo ERRBATCH : Endif

  #------------------------------------------------------
  # Opening the trace for the process
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN
  Call ECR_TIME("DOSSIER : "+DOSSIER) From DOSSUB
  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN

  #------------------------------------------------------
  # Opening the tables to use
  If clalev([F:ECA])  = 0 : Local File =DOSSIER + ".EDICAT"    [ECA]  : Endif
  If clalev([F:ECAK]) = 0 : Local File =DOSSIER + ".EDICATK"   [ECAK] : Endif
  If clalev([F:EMSA]) = 0 : Local File =DOSSIER + ".EDIMSGA"   [EMSA] : Endif
  If clalev([F:ETC])  = 0 : Local File =DOSSIER + ".EDITMPDOC" [ETC]  : Endif
  If clalev([F:ECAL]) = 0 : Local File =DOSSIER + ".EDICATL"   [ECAL] : Endif


  #Procesing the category table
  # 1. Categories issue type
  For [ECA]
    If [ECA]CATACT=1
      Gosub MAJ_CATISS
    Endif
  Next

  # 2. Categories receipt type
  Gosub MAJ_CATRCP

  Call ECR_TRACE(mess(93,143,1)+":"-num$(NBTRAIT),0) From GESECRAN
  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN
  Call ECR_TIME(mess(18,2,1)-"=>"-"EDI:"-mess(81,125,1)-tolower(mess(655,197,1))) From DOSSUB  #End tool


  # 3. Updating dossier in category
  Gosub UPD_DOSSIER


  # 4. Deleting records in working table
  Gosub DEL_REC_ETC

  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN
  Call ECR_TIME(mess(18,2,1)-"=>"-"EDI: EDITMPDOC."-mess(52,123,1)) From DOSSUB  #End tool

End

######################################################################################
$MAJ_CATISS   # Issue sense: finding CPY records to delete
  Trbegin [ECAK]
    Read [ECAK]ECAK2=[ECA]CATCOD;"FCY"
    If fstat=[V]CST_AOK
      Read [ECAK]ECAK2=[ECA]CATCOD;"CPY"
      If fstat=[V]CST_AOK
        Delete [ECAK] Curr
        NBTRAIT+=1
      Endif
    Else
      Call ECR_TRACE("EDI"-tolower(mess(655,197,1))-[ECA]CATCOD +". FCY"- tolower(mess(23,100,1)),0) From GESECRAN #EDI category without FCY record
    Endif
  Commit

Return

######################################################################################
$MAJ_CATRCP  # Receipt sense: finding CPY records to delete
  Local Char WMSGCOD (20)(0..), WMSGREL (5)(0..)
  Local Integer NBREC, I

  Trbegin [EMSA]
    Filter [EMSA] Where CODE="FCY"
    For [EMSA]
      WMSGCOD(NBREC)=[EMSA]MSGCOD
      WMSGREL(NBREC)=[EMSA]MSGREL
      NBREC+=1
    Next
    Filter [EMSA]

    For I=0 To NBREC-1
      Read [EMSA]EMSA2=WMSGCOD(I);WMSGREL(I);"CPY"
      If fstat=[V]CST_AOK
        Delete [EMSA] Curr
        NBTRAIT+=1
      Endif
    Next
  Commit

Return

######################################################################################
$UPD_DOSSIER
  Trbegin [ECAL]
    For [ECAL]
      [F:ECAL]DOSSIER=DOSSIER
      Rewrite
    Next
  Commit
Return

######################################################################################
$DEL_REC_ETC
  Trbegin [ETC]
    For [ETC]
      Delete [ETC] Curr
    Next
  Commit
Return

######################################################################################
$ERRBATCH
   Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
######################################################################################

