# ############################################################################################# #


# < DEBUG> #################################################################################### #
Local Char PARAM(10)(1..2), VALEUR(10) : Call TRAITE_CHAR(VALEUR, PARAM, "", "DMWBAT","DMWBAT", 4, "SPEDMWBAT" ) From GTRAITE : End
# </DEBUG> #################################################################################### #


#** #####################################################################################
#* Sub chunk:  ACTION
#* Purpose:    Standard action dispatcher.
#* Parameters (as variables in the main chunk):
#* @param ACTION      Name of the event (action).
#*! #####################################################################################

$ACTION
If GSERVEUR
    # Batch server mode
    Case ACTION
        When "INIT"        : Gosub BATCH_INIT
        When "EXEC"        : Gosub BATCH_EXEC
    Endcase
Else
    # Interactive mode
    Case ACTION
        When "OUVRE"       : Gosub OUVRE
        When "DEBUT"       : Gosub DEBUT
        When "OK"          : If !GBATCH : Gosub OK : Endif # Do not execute while batch parameterization.
    Endcase
Endif
Return




#** #####################################################################################
#* Sub chunk:  OUVRE
#* Purpose:    Handles OURVE event from supervisor. Introduces process's static variables
#*             and opens additional tables.
#*! #####################################################################################

$OUVRE
    Local Char MESSA(250)                     # Contains messages to log.
    Local Integer STA, DUMMY
    If GFONCTION = "" : GFONCTION = "DMWBAT" : Endif
Return



#** #####################################################################################
#* Sub chunk:  DEBUT
#* Purpose:    Handler for the DEBUT event. Initializes field states (enabling and
#*             disabling).
#*! #####################################################################################

$DEBUT
# Initialize the fields's grayed/disabled states.

# Update screen.
#Affzo [M]1-99
Return



#** #####################################################################################
#* Sub chunk:  OK
#* Purpose:    Handler for the OK button. Does all the data calculation
#* NOTE:       OK is called from the BATCH_EXEC handler in batch mode, too.
#*! #####################################################################################

$OK
# Open a log file and export the screen fields to the log file.
Gosub OPEN_LOG

# If in interactive mode open a "Wait..." box.
If !GSERVEUR
    Call TEMPON("V") From GESECRAN
Endif

STA = 0
# Check if there are already data for the given period and scheme. If yes, delete them.
If func DMWLIB.DMW_EXIST([M:DMWBAT]SCMCOD,[M:DMWBAT]STRDAT,[M:DMWBAT]ENDDAT)
    If [M:DMWBAT]OVRWRIEXI = 2              # Overwrite?
        Call DMW_DELETE([M:DMWBAT]SCMCOD,[M:DMWBAT]STRDAT,[M:DMWBAT]ENDDAT,STA,MESSA) From DMWLIB
    Else
        STA = 1
        MESSA = func AFNC.MES1(mess(10,7707,1),[M:DMWBAT]SCMCOD)
    Endif
Endif
If !STA             # everything OK -> calculate data
    Call DMW_CALCULATE([M:DMWBAT]SCMCOD,[M:DMWBAT]STRDAT,[M:DMWBAT]ENDDAT,STA,MESSA) From DMWLIB
Endif

If !STA
    MESSA = func AFNC.MES1(mess(3,7707,1),[M:DMWBAT]SCMCOD)
    Gosub LOGINFO
Else
    Gosub LOGERR
Endif

# If in interactive close the previously opened "Wait..." box.
If !GSERVEUR
    Call TEMPOFF From GESECRAN
Endif

# Close the log file.
Gosub CLOSE_LOG
Return



#** #####################################################################################
#* Sub chunk:  BATCH_INIT
#* Purpose:    Handler for the INIT event in batch mode. Initializes DMWBAT mask.
#*! #####################################################################################

$BATCH_INIT
    # Open the dialog window's screen:
    # Note: We do this because we need the mask accessible in batch tasks.
    #
    If clalev([M:DMWBAT])=0 : Local Mask DMWBAT [DMWBAT] : Endif
Return



#** #####################################################################################
#* Sub chunk:  BATCH_EXEC
#* Purpose:    Handler for the EXEC event in batch mode. Starts the validation process.
#*! #####################################################################################

$BATCH_EXEC
    # Initialize
    Gosub OUVRE
    Gosub DEBUT

    # Start waste disposal calculation.
    Gosub OK
Return



# ############################################################################################# #
# ##########                                                                                    #
# ########## Tool kit (small helpers)                                                           #
# ##########                                                                                    #
# ############################################################################################# #

$OPEN_LOG
    # Open X3 log file (on dialog usage).
    If !GSERVEUR
        Call OUVRE_TRACE( GFONCTION ) From LECFIC
        Call TRACE_MASQUE( GFONCTION, GFONCTION, nomap ) From GTRAITE
    Endif
Return

$CLOSE_LOG
    # Close X3 log/trace file and show it on screen (on dialog usage).
    If !GSERVEUR
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
Return

$LOGERR
    Call ECR_TRACE( MESSA, 1 ) From GESECRAN
Return

$LOGINFO
    Call ECR_TRACE( MESSA, 0 ) From GESECRAN
Return


# ############################################################################################# #
# ##########                                                                                    #
# ########## Screen/Window handling                                                             #
# ##########                                                                                    #
# ############################################################################################# #

Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR
VALEUR = gdat$(1,month(date$),year(date$))
End

Subprog D_ENDDAT(VALEUR)
Variable Date    VALEUR
VALEUR = eomonth([M]STRDAT)
End


######################################################################################

