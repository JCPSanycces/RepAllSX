#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PSO4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:09"
A_USER  = "DOC"
A_STAMP = "20181109230609"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG4"
  If [M]NBLIG4=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PSO4 [PSO4]
Gosub HORODAT
Local Inpbox "PSO4" From GFONCTION At A_STAMP With A_WINDPREV Mask [PSO4] As [SIM_]
Grizo [PSO4]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PSO4]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=21
Return

$ON_NBLIG4
Onevent BEFORE_INPUT Call AS_NBLIG4 From W1PSO4
Return

Subprog IB_NBLIG4
Local Decimal BASPAG
## Action STD
Call IB_NBLIG4 From SUBPSO
Gosub _AFF
End

Subprog AS_NBLIG4
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6346,GBOUT1) From OBJDIV
Call IB_NBLIG4
Onkey 129 Titled GBOUT1 Call B1_NBLIG4 From W1PSO4
Gosub _AFF
End

Subprog B1_NBLIG4
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC"
 Call OBJET_CHAR([M:PSO4]QHDOCNUM(nolign-1),"SQH","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_QHDOCNUM
Return

$ON_QVLYDAT
Onevent BEFORE_AREA Gosub AV_QVLYDAT From W1PSO4
Return

$AV_QVLYDAT
Chgfmt [M]QVLYDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_QDOCDAT
Onevent BEFORE_AREA Gosub AV_QDOCDAT From W1PSO4
Return

$AV_QDOCDAT
Chgfmt [M]QDOCDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_QCUR
Return

$ON_PFMTOT
Onevent BEFORE_AREA Gosub AV_PFMTOT From W1PSO4
Return

$AV_PFMTOT
## Action INIDEV
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PSO4]QCUR(nolign-1),GDEVISE(1..GNBDEV)),1))
Gosub _AFF
Return

$ON_QUONOT
Onevent BEFORE_AREA Gosub AV_QUONOT From W1PSO4
Return

$AV_QUONOT
## Action INIDEV
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PSO4]QCUR(nolign-1),GDEVISE(1..GNBDEV)),1))
Gosub _AFF
Return

$ON_QUOATI
Onevent BEFORE_AREA Gosub AV_QUOATI From W1PSO4
Return

$AV_QUOATI
## Action INIDEV
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PSO4]QCUR(nolign-1),GDEVISE(1..GNBDEV)),1))
Gosub _AFF
Return

$ON_QUOINVNOT
Onevent BEFORE_AREA Gosub AV_QUOINVNOT From W1PSO4
Return

$AV_QUOINVNOT
## Action INIDEV
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PSO4]QCUR(nolign-1),GDEVISE(1..GNBDEV)),1))
Chgfmt [M]QUOINVNOT(indice) With "NPz3:"+GDEVFMT
Gosub _AFF
Return

$ON_QUOINVATI
Onevent BEFORE_AREA Gosub AV_QUOINVATI From W1PSO4
Return

$AV_QUOINVATI
## Action INIDEV
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PSO4]QCUR(nolign-1),GDEVISE(1..GNBDEV)),1))
Chgfmt [M]QUOINVATI(indice) With "NPz3:"+GDEVFMT
Gosub _AFF
Return

$CHG_STY
Return


