######################################################################################
## Etiquette ajoutée par le superviseur (écran SNU4) 25/02/2016 08:45:13 (HCB)
######################################################################################
Subprog IB_NBLIG
Gosub SET_NOL From STKINV
# No série à inventorier
GBOUT1 = mess(650,199,1)
# l article ne gère pas les séries "globale"  pas de saisie des numéros de séries
If [M:SNU4]SERSEQ(NOL) = 0
    GBOUT1 = ""
Endif
# si pas d'écart pas de saisie des numéros de séries
If [M:SNU4]QTYSTU (NOL) = [M:SNU4]QTYSTUNEW (NOL)
    GBOUT1 = ""
Endif
# si pas comptée ou abandonnée pas de saisie des numéros de séries
If [M:SNU4]CUNLISSTA (NOL) = 1 | [M:SNU4]CUNLISSTA (NOL) = 3
    GBOUT1 = ""
Endif

End

Subprog B1_NBLIG
#Ouverture fenêtre de saisie série globale par clic droit
Global Shortint GSNLSTAIMG3   # hcb 74380
GSNLSTAIMG3 = 2
GOUVSNLS = 2

End

######################################################################################

