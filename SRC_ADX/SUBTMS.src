#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
  When "ANNULE"      : Gosub ANNULE
  When "CREATION"    : Gosub CREATION
  When "MODIF"       : Gosub MODIF
  When "CHANGE"      : Gosub CHANGE
  When Default
Endcase

Return
#############################################################
$ANNULE
  #Delete [AXX] Where CODFIC="TABMSG" & IDENT1=[L]CODE
  #If fstat=1 | fstat>5
  # GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
  #Endif
  # FGR 17/09/2009 : X3SUIVI57908
  #--- maj de la table des libéllés traduisibles
  Call SUPTEXTRA("TABMSG","MSGDESAXX",[L]CODE,"") From ATEXTRA
  Call SUPTEXTRA("TABMSG","MSGSHOAXX",[L]CODE,"") From ATEXTRA
Return
#############################################################
$CREATION
Local Integer WKNOL

  # FGR 17/09/2009 : X3SUIVI57908
  For WKNOL=0 To [M]NBMSG-1
    Call MAJTEXTRA([M]MSGDESAXX(WKNOL),"TABMSG","MSGDESAXX",num$([M]MSGNUM(WKNOL)),"") From ATEXTRA
    Call MAJTEXTRA([M]MSGSHOAXX(WKNOL),"TABMSG","MSGSHOAXX",num$([M]MSGNUM(WKNOL)),"") From ATEXTRA
  Next WKNOL
Return

#############################################################
$MODIF
Local Integer WKNOL

  # FGR 17/09/2009 : X3SUIVI57908
  For WKNOL=0 To [M]NBMSG-1
    Call MAJTEXTRA([M]MSGDESAXX(WKNOL),"TABMSG","MSGDESAXX",num$([M]MSGNUM(WKNOL)),"") From ATEXTRA
    Call MAJTEXTRA([M]MSGSHOAXX(WKNOL),"TABMSG","MSGSHOAXX",num$([M]MSGNUM(WKNOL)),"") From ATEXTRA
  Next WKNOL
Return

#############################################################
$CHANGE
  # FGR 17/09/2009 : X3SUIVI57908
  Call CHANGE_AXX("TABMSG", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
Return

########################################
Subprog AS_MSGNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : mkstat = 2 : Endif
End

########################################
Subprog C_MSGNUM(VALEUR)
Variable Decimal VALEUR
Call UNICITE(VALEUR, [M:TMS1]MSGNUM(0..NBMSG-1)) From OBJDIV
End

