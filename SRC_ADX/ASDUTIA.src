Subprog AJA_SET_AUDSEQ(ACTION, ASDTECCOM)
Value Char ACTION                            # C,U, D, R
#Variable Struct ASDTECCOM Using ASDTECCOM
#
#If ASDTECCOM.SYNFLG and find(ACTION,"C","U","D")                 # Mode synchro et maj
#    Local Decimal   A_SEQ               # Numero sequence
#    If clalev([AJA])=0 :  Local File AJSAUDIT[AJA] : Endif
#    Read [AJA]AJA0 Last
#    If fstat
#      A_SEQ=0
#    Else
#      A_SEQ=[AJA]SEQ
#    Endif
#    Close Local File [AJA]
