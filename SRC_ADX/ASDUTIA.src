#<AdxTL>@(#)4.0.0.0 $Revision$
######################################################################################
## SData - Version 0029_S
#    Utilitaires SData
#
#      Funprog AFNC.ACTIVDOS("sodaix02:17000@SUPERV", "ASD")          # Code activité actif dans dossier
#
#
#      Subprog-Funprog
#          JAVA_DEBUG                            # Activation debuger java
#          GETTIMSTAMP                           # Timestamp à partir d'une date et heure
#          STCGENXSD                             # Génération xsd
#          VALSTCXSD(DOSORG, STCCOD, OK)         # Appel simplifie génération xsd
#          DUMP_CLB2TRACE(AMSG, ACLB)            # Dump clob dans la trace
#          DUMP_CLB2FILE(AMSG,ACLB,ANAME,AVISU)  # Dump clob dans un fichier (répertoire tmp de X3_PUB)
#          SETGUSRSD(CTX)                        # Gestion GUSRSD dans le cadre de SData-CRM
#
#          ASDAUDPUR                             # Fonction critere purge table d'audit (utilsé par trt EPURASD)
#
#
#      Subprog-Funprog - table AJSAUDIT
#          AJA_SET_AUDSEQ(ACTION, ASDTECCOM)     # Maj ASDTECCOM - Dernier numero table d'audit (appelé par trt applicatif CRUD)
#          AJA_LST                               # Liste pour mise à jour de la table de synchro (utilise parametre ASDTRTAPP)
#          AJA_GET_LASTSEQ                       # Dernier numèro de séquence de la table d'audit SData
#
#      Etiquette
#          $ASD_AUDIT_ANA                        Exemple pour l'applicatif: Etiquette appelée par AJA_LST
#
#      Subprog-Funprog - consultation AJE
#          ASD_AJEINF( A_RESNAM, A_ERPKEY, A_DES, A_HASTUN)     EXEMPLE - Informations pour affichage -
#          ASD_AJETUN( A_RESNAM, A_ERPKEY)                      EXEMPLE - Gestion tunel -
#
#  Remarque sur la gestion des erreurs
#    Bridge = session primaire ou tech donc GWEBSERV = 0
######################################################################################

### Lct interne
Local Char DBGHST(50)
Local Integer DBGPRT
#DBGHST="172.28.9.11" # @ip du pc
#DBGHST = "ecjullienc.sagefr.adinternal.com"   # dns
DBGPRT=1789
Call JAVA_DEBUG(DBGHST, DBGPRT, 0)
#Dbgaff
#structure
#
#Gosub TST_STCGENXSD_UN  : End   # _UN _N _CRM
#Gosub TST_STCGENXSD_VAL : End

# timestamp
#Gosub TST_TIMSTP

# Gestion GUSRSD
#Call SETGUSRSD("jean1@sage.com") :  Infbox GUSRSD : End

#Audit
#Gosub TST_AUDITPUR

# Code activité
#Local Char WSTR(200)
#WSTR=" Code activité ASD:" -num$(func AFNC.ACTIVDOS("sodaix02:17000@SUPERV", "ASD")) -" Code activité AAA:" -num$(func AFNC.ACTIVDOS("sodaix02:17000@SUPERV", "AAA"))
#Infbox WSTR

# Table d'audit
#Gosub TST_AJALAST : End
#Gosub TST_AJA_LST : End

# Table Audit
Gosub TST_AJA_GET_LASTSEQ
End

######################################################################################
## Xtend - Utilitaires
######################################################################################
#  Appel simplifié pour trt ASTRVAL
######################################################################################
Subprog VALSTCXSD(DOSORG, STCCOD, OK)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char STCCOD        #     Code structure
Variable Integer OK      #     1 Ok; 0: Ko
Local Char OPTION(10)(1..2)
Local Char TIMSTP(14) : Call ENVVAR(TIMSTP) From INTRUTILA
Call STCGENXSD(DOSORG, STCCOD, TIMSTP, OPTION,OK)
End

######################################################################################
#    <STCGENXSD>  Debut section xsd
#      Basé sur générateur WS AGENXSD
#
#  Remarque:
#    Ce trt est appelé en validation d'une structre, de la validation de dossier
#    et de la validation du dico (ValDico)
#    En conséquence, il se fait toujours sur la machine hote et le fichier xsd
#    est à écrire dans X3_PUB de cette machine.
#    Cela induit que le parametre DOSORG est toujours un nom de dossier.
######################################################################################
Subprog STCGENXSD(DOSORG, STCCOD, TIMSTP, OPTION,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char STCCOD        #     Code structure
Value Char TIMSTP        #     Référence time stamp 20061012093014
Value Char OPTION()(1..) #     Option
                         #       'TRACE'= Trace
                         #       'TRACELEC'= Force fermeture et lecture
Variable Integer RET     #     1 Ok; 0: Ko ;    2: avertissement
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer WI, WNBREC
Local Integer TRAFLG,TRAFLGOPEN,TRAFLGLEC
TRAFLG      = find("TRACE",OPTION)          # Demande de trace
TRAFLGOPEN=0                                # Ouverture par ss-prg de la trace
TRAFLGLEC   = find("TRACELEC",OPTION)       # Forcer la fermeture de la trace (test)

#Gestion fichier
Local Char DIRSEP, NOMFIC(200),VALL1(200),NAMFILE
Local Char PROP(100),VALP(100),VALLM(100),ACOD1
Local Integer RES,TCODAGE

#Travail
Local Char TAGNAM(100),TAGXML(100),TAGERPTYP(50),TAGMINMAX(50)      # Tag Name - Tag attribut type (cas structure)
Local Integer RESTRICTOP, LGDATA                       # flg attribut restriction
Local Char TYPEDATA (20)                               # type de données
Local Integer STC_INCNB                # Nb de structures incluses
Local Char STC_INCCOD(GLONASE)(1..40)  # Liste stc incluses
Local Decimal LL
Local Char WSTR1(250), WSTR2(250), WSTR3(250)
Local Integer WI, WJ, SAVNOL

RET=1

WSTR1=mess(23,143,1)-STCCOD

If TRAFLG & GTRACE="" : TRAFLGOPEN=1 : Call OUVRE_TRACE(WSTR1) From LECFIC : Endif
If GTRACE<>"": TRAFLG=1 : Endif
If TRAFLG  : Call ECR_TRACE(WSTR1,0) From GESECRAN : Endif

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS
If TRAFLG  : Call ECR_TRACE(mess(3,23,1)-MACORG-DOSNAMORG,0) From GESECRAN : Endif
If MACORG<>""
    If TRAFLG  : Call ECR_TRACE(mess(37,143,1)-MACORG,1) From GESECRAN : Endif
    RET=0 : Goto STC_FINALLY
Endif

Gosub STC_OPENBASE
Gosub STC_STCREAD                 # Read structures
If RET=0 : Goto STC_FINALLY : Endif
Gosub STC_STCINC                  # Recherche des structures incluses

Gosub STC_OPENFILE
If RET=0 : Goto STC_FINALLY : Endif

Gosub STC_SHEMA                   # Ecriture entete fichier xsd
Gosub STC_STC_HEAD                # L'element structure
## Gosub STC_STC_STC                 # Structures - AP ComplexType non std
Gosub STC_STC_ST                  # SimpleType

$STC_FINALLY
Gosub STC_CLOSE
End


# L'element structure
# - - - - - - - - - - - - - - - - - - - - - - -
$STC_STC_HEAD
If [F:ASE]TAGXML=""
    WSTR1='<xs:element name="'+STCCOD+'">'
Else
    WSTR1='<xs:element name="'+STCCOD+'" serp:tagxml="'+[F:ASE]TAGXML+'">'
Endif
Wrseq WSTR1 Using [XSD_]
# voir annotation

# Ajout des elements (liste des champs)
Wrseq '  <xs:complexType>' Using [XSD_]
Wrseq '    <xs:sequence>' Using [XSD_]
For WI=0 To [M:A2_]NBRFLD-1
  If func AFNC.ACTIVDOS(DOSORG,[M:A2_]ACTFLD(WI))
      Gosub GETTAGINF
      ## If [M:A2_]DIME(WI)=1 : WSTR1=TAGNAM : Else : WSTR1=TAGNAM+'-L' : Endif
      ## If TAGXML=""         : WSTR2=""     : Else : WSTR2=' serp:tagxml="'+TAGXML+'"' : Endif

      # Tag name - Cas tableau
      If [M:A2_]DIME(WI)=1     : WSTR1=TAGNAM : Else : WSTR1=STCCOD+'_'+TAGNAM : Endif
      # Attribut tagxml
      If TAGXML=""             : WSTR2=""     : Else : WSTR2=' serp:tagxml="'+TAGXML+'"' : Endif
      # Attribut type
      If [M:A2_]STRSTR(WI)=""  : WSTR3=' type="'+TAGNAM+'"' : Else : WSTR3=' type='+TAGERPTYP : Endif
      Wrseq '      <xs:element name="'+WSTR1+'"'+WSTR3+TAGMINMAX+WSTR2+'/>' Using [XSD_]
  Endif
Next

Wrseq '    </xs:sequence>' Using [XSD_]
Wrseq '  </xs:complexType>' Using [XSD_]
Wrseq '</xs:element>' Using [XSD_]
Return

# SimpleType - Tous les champs de la structure
# sauf ceux liés à une structure
# - - - - - - - - - - - - - - - - - - - - - - -
$STC_STC_ST
For WI=0 To [M:A2_]NBRFLD-1
  If [M:A2_]STRSTR(WI)="" and func AFNC.ACTIVDOS(DOSORG,[M:A2_]ACTFLD(WI))
      Gosub GETTAGINF
      VALL1='<xs:simpleType name="'+TAGNAM+'">'
      Wrseq VALL1 Using [XSD_]

      Wrseq '  <xs:annotation>' Using [XSD_]
      If [M:A2_]NOLIB(WI)<>0         # Menu local
        Wrseq '    <xs:documentation>Local Menu '+num$([M:A2_]NOLIB(WI))+'</xs:documentation>' Using [XSD_]
      Endif
      If [M:A2_]INTFLD(WI)<>0        # intitule
        For indice=1 To GI_NBLAN
          Read [ATX]NUMERO = GI_LLAN(indice);[M:A2_]INTFLD(WI)
          If fstat=0
            VALLM = [F:ATX]TEXTE
            Gosub MVALC From INTRUTILA
            Wrseq '    <xs:documentation xml:lang="'+tolower(TLANISO(indice))+'">'+VALLM+'</xs:documentation>' Using [XSD_]
          Endif
        Next indice
      Endif
      Wrseq '  </xs:annotation>' Using [XSD_]

      If [M:A2_]NOLIB(WI)<1
          Read [ATY]CODTYP = [M:A2_]CODTYP(WI)

          Case [F:ATY]TYPTYP  # mnl30
              When 2 : TYPEDATA="xs:short"
              When 3 : TYPEDATA="xs:int"
              When 4 : TYPEDATA="xs:decimal"
              When 5 : TYPEDATA="xs:float"
              When 6 : TYPEDATA="xs:double"
              When 7 : TYPEDATA="xs:string"
              When 8 : TYPEDATA="xs:date"
              When 9 : TYPEDATA="xs:base64Binary"  :  # A défaut de mieux
              When 10 : TYPEDATA="xs:string"  :       # A défaut de mieux
              When Default : TYPEDATA="xs:string"
          Endcase
          Gosub ISRESTRICOP

          If [M:A2_]LONG(WI)<>0
              LGDATA=[M:A2_]LONG(WI)
          Else
              LGDATA=[ATY]LNGTYP
          Endif
          If LGDATA<>0
            If [F:ATY]TYPTYP=9
              LL=1024*2^LGDATA-4
              Wrseq '      <xs:maxLength value="'+num$(LL)+'"/>' Using [XSD_]
            Elsif [F:ATY]TYPTYP=10
              LL=512*2^LGDATA-2
              Wrseq '      <xs:maxLength value="'+num$(LL)+'"/>' Using [XSD_]
            Elsif [F:ATY]TYPTYP=7
              Wrseq '      <xs:maxLength value="'+num$(LGDATA)+'"/>' Using [XSD_]
            Endif
          Endif

    #     If [M:AWE2]AUTMIN(I-1)=2
    #       Gosub ISRESTRICOP
    #       If [M:AWE2]MININCLU(I-1)=2
    #         Wrseq '<xs:minInclusive value="'+num$([M:AWE2]VALMIN(I-1))+'"/>' Using [XSD_]
    #       Else
    #         Wrseq '<xs:minExclusive value="'+num$([M:AWE2]VALMIN(I-1))+'"/>' Using [XSD_]
    #       Endif
    #     Endif
    #     If [M:AWE2]AUTMAX(I-1)=2
    #      Gosub ISRESTRICOP
    #       If [M:AWE2]MAXINCLU(I-1)=2
    #         Wrseq '<xs:maxInclusive value="'+num$([M:AWE2]VALMAX(I-1))+'"/>' Using [XSD_]
    #       Else
    #         Wrseq '<xs:maxExclusive value="'+num$([M:AWE2]VALMAX(I-1))+'"/>' Using [XSD_]
    #       Endif
    #     Endif
    #     If [M:AWE2]FRACTIONDIG(I-1)<>0
    #        Gosub ISRESTRICOP
    #         Wrseq '<xs:fractionDigits value="'+num$([M:AWE2]FRACTIONDIG(I-1))+'"/>' Using [XSD_]
    #     Endif
    #     If [M:AWE2]TOTALDIGIT(I-1)<>0
    #       Gosub ISRESTRICOP
    #        Wrseq '<xs:totalDigits value="'+num$([M:AWE2]TOTALDIGIT(I-1))+'"/>' Using [XSD_]
    #     Endif
    #     If [M:AWE2]PATTERN(I-1)<>""
    #       Gosub ISRESTRICOP
    #        Wrseq '<xs:pattern value="'+num$([M:AWE2]PATTERN(I-1))+'"/>' Using [XSD_]
    #     Endif

        If RESTRICTOP=1 : Wrseq '    </xs:restriction>' Using [XSD_] : RESTRICTOP=0 : Endif

      Else
        Wrseq '    <xs:restriction base="xs:string">' Using [XSD_]
        Local Integer JK
        For indice=1 To GI_NBLAN
          Read [AST]LAN=GI_LLAN(indice);123;275
          If fstat=0
            VALLM = [F:AST]LANMES
            Gosub MVALC From INTRUTILA
          Else
            VALLM="Not initialized"
          Endif
          Wrseq '      <xs:enumeration value="'+format$("N0:##",0)+':'+GI_LLAN(indice)+':'+VALLM+'"/>' Using [XSD_]
          For JK=1 To func APLSTD.LENMEN(DOSORG,[M:A2_]NOLIB(WI))
            Read [AST]LAN=GI_LLAN(indice);[M:A2_]NOLIB(WI);JK
            If fstat=0
              VALLM = [F:AST]LANMES
              Gosub MVALC From INTRUTILA
                Wrseq '      <xs:enumeration value="'+format$("N0:##",JK)+':'+GI_LLAN(indice)+':'+VALLM+'"/>' Using [XSD_]
            Endif
          Next JK
        Next indice
          Wrseq '    </xs:restriction>' Using [XSD_] : RESTRICTOP=0
      Endif

      Wrseq '</xs:simpleType>' Using [XSD_]
  Endif     # If [M:A2_]STRSTR(WI)="" and func AFNC.ACTIVDOS(DOSORG,[M:A2_]ACTFLD(WI))
Next I
Return

# Utilitaires
#  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -
# Restriction
$ISRESTRICOP
 If RESTRICTOP=0
   RESTRICTOP=1
   Wrseq '    <xs:restriction base="'+TYPEDATA+'">' Using [XSD_]
 Endif
Return

# Input WI - Output TAGNAM, TAGERPTYP, TAGMINMAX
$GETTAGINF
  # Name
    TAGNAM=[M:A2_]FLDSTR(WI)
  # TagXml
    If [M:A2_]TAGXMLFLD(WI)<>""
        TAGXML=[M:A2_]TAGXMLFLD(WI)
    Else
        TAGXML=""
    Endif
  # Attribut Type cas structure
    If [M:A2_]STRSTR(WI)=""
        TAGERPTYP=""
    Else
        WJ=find([M:A2_]STRSTR(WI),STC_INCCOD)
        TAGERPTYP='"serp'+num$(WJ)+':'+[M:A2_]STRSTR(WI)+'"'
    Endif
  # Attributs min-maxOccurs
    TAGMINMAX=' minOccurs="'+num$([M:A2_]OBLIG(WI)=2)+'"'   # Gestion Obligatoire
    If [M:A2_]DIME(WI)<>0
        TAGMINMAX+=' maxOccurs="'+num$([M:A2_]DIME(WI))+'"'       # Maxi
    Else
        TAGMINMAX+=' maxOccurs="30000"'                           # Maxi tableau dynamique
    Endif
Return



# Les structures
# - - - - - - - - - - - - - - - - - - - - - - -
##$STC_STC_STC
##For WI=0 To [M:A2_]NBRFLD-1
##  If [M:A2_]STRSTR(WI)<>""
##      Gosub GETTAGINF
##      VALL1='<xs:complexType name="'+TAGNAM+'"'+TAGERPTYP+' />'
##      Wrseq VALL1 Using [XSD_]
##  Endif
##Next
##Return

# Read structures
# - - - - - - - - - - - - - - - - - - - - - -
$STC_STCREAD
Read [ASE]ASE0=STCCOD
If fstat
    If TRAFLG  :  Call ECR_TRACE(mess(4,140,1)-STCCOD,1) From GESECRAN : Endif
    RET=0
Else
    # Chrgt ecran
    Local Mask ASE2 [A2_]
    SAVNOL=nolign
    nolign=0
    For [ASF]ASF0 Where CODSTR=STCCOD
     [M:A2_]TAGXMLFLD(nolign) = [F:ASF]TAGXML
     nolign += 1
     [M:A2_] = [F:ASF]
    Next
    [M:A2_]NBRFLD = nolign
    nolign=SAVNOL
    If TRAFLG  : Call ECR_TRACE("Number of fields"-num$([M:A2_]NBRFLD),0) From GESECRAN : Endif
Endif
Return


# Recherche des structures incluses
# - - - - - - - - - - - - - - - - - - - - - -
$STC_STCINC
STC_INCNB=0
For WI=0 To [M:A2_]NBRFLD-1
    If [M:A2_]STRSTR(WI)<>"" and !find([M:A2_]STRSTR(WI),STC_INCCOD)
        STC_INCNB+=1 : STC_INCCOD(STC_INCNB)=[M:A2_]STRSTR(WI)
    Endif
Next
If TRAFLG  : Call ECR_TRACE("Number of included structures:"-num$(STC_INCNB),0) From GESECRAN : Endif
Return


# Ecriture entete fichier xsd
# - - - - - - - - - - - - - - - - - - - - - -
$STC_SHEMA
Wrseq '<?xml version="1.0" encoding="'+ACOD1+'" ?>' Using [XSD_]
VALL1='<xs:schema targetNamespace="http://schemas.sage.com/serp/stc/'+STCCOD+'"'
VALL1+=' xmlns:xs="http://www.w3.org/2001/XMLSchema"'
Wrseq VALL1 Using [XSD_]
For WI=1 To STC_INCNB
    VALL1=' xmlns:serp'+num$(WI)+'="http://schemas.sage.com/serp/stc/'+STC_INCCOD(WI)+'"'
    Wrseq VALL1 Using [XSD_]
Next
VALL1=' xmlns:serp="http://schemas.sage.com/serp/technical"'
Wrseq VALL1 Using [XSD_]
VALL1=' xmlns="http://schemas.sage.com/serp/'+STCCOD+'">'
Wrseq VALL1 Using [XSD_]
For WI=1 To STC_INCNB
     VALL1='<xs:import schemaLocation="'+STC_INCCOD(WI)+'_STC" mamespace="http://schemas.sage.com/serp/stc/'+STC_INCCOD(WI)+'" />'
    Wrseq VALL1 Using [XSD_]
Next
Wrseq '<xs:annotation>' Using [XSD_]
Wrseq ' <xs:documentation>Infos</xs:documentation>' Using [XSD_]
Wrseq ' <xs:documentation>'+TIMSTP+'</xs:documentation>' Using [XSD_]
Wrseq '</xs:annotation>' Using [XSD_]
Return

# Ouverture fichier base
# - - - - - - - - - - - - - - - - - - - - - -
$STC_OPENBASE
If DOSORG=nomap
 If clalev([F:ASE])=0  : Local File ASTR     [ASE]  : Endif
 If clalev([F:ASF])=0  : Local File ASTRFLD  [ASF]  : Endif
 If clalev([F:ATY])=0  : Local File ATYPE    [ATY]  : Endif
 If clalev([F:ATX])=0  : Local File ATEXTE   [ATX]  : Endif
 If clalev([F:AST])=0  : Local File APLSTD   [AST]  : Endif
 If clalev([F:AXX])=0  : Local File ATEXTRA  [AXX]  : Endif
 If clalev([F:TLA])=0  : Local File TABLAN   [TLA]  : Endif
Else
 If clalev([F:ASE])=0  :  Local File =[L]DOSORG+".ASTR"      [ASE]  : Endif
 If clalev([F:ASF])=0  :  Local File =[L]DOSORG+".ASTRFLD"   [ASF]  : Endif
 If clalev([F:ATY])=0  :  Local File =[L]DOSORG+".ATYPE"     [ATY]  : Endif
 If clalev([F:ATX])=0  :  Local File =[L]DOSORG+".ATEXTE"    [ATX]  : Endif
 If clalev([F:AST])=0  :  Local File =[L]DOSORG+".APLSTD"    [AST]  : Endif
 If clalev([F:AXX])=0  :  Local File =[L]DOSORG+".ATEXTRA"   [AXX]  : Endif
 If clalev([F:TLA])=0  :  Local File =[L]DOSORG+".TABLAN"    [TLA]  : Endif
Endif

Default File "[ASE],[ASF]"

# Création de la table iso des codes langues
Call GLOBWEB(DOSNAMORG) From INTRUTILA     #
Local Integer IISO,JK
Local Char NAMCH(50)
Local Char TLANISO(10)(1..GI_NBLAN)
For IISO=1 To GI_NBLAN
  Read [TLA]TLA0=GI_LLAN(IISO)
  If fstat=0 and [F:TLA]LANISO<>"" and instr(1,[F:TLA]LANISO,"_")<>0
    TLANISO(IISO)=left$([F:TLA]LANISO,instr(1,[F:TLA]LANISO,"_")-1)
  Else
    TLANISO(IISO)=GI_LLAN(IISO)
  Endif
Next IISO
Return

# Ouverture fichier sequentiel
# - - - - - - - - - - - - - - - - - - - - - -
$STC_OPENFILE
# Ouverture du fichier résultat
Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

NAMFILE=STCCOD+"_STC"                # Temporaire, voir dossier spécifique avec code XSDSTC
# exemple fichier;
#  acces disque: Fichier généré /produits/v160/SOLSUPV6/dossiers/X3_PUB/SUPERV/GEN/ALL/WEBS/ZSDADD_STC.xsd
#  acces http:   http://sodaix02/Adonix_SOLSUPV6/SUPERV/GEN/ALL/WEBS/ZSDADD_STC.xsd
Call NAMEFIC(DOSNAMORG,"XSD","",NAMFILE,NOMFIC) From INTRUTILA                        # Actuellement WEBS/xxx_STC.xsd
#
If TRAFLG : Call ECR_TRACE(mess(104,121,1)-NOMFIC,0) From GESECRAN : Endif

Onerrgo STC_OPERR
Openo NOMFIC,0 Using [XSD_]
Onerrgo
If RET=0
    If TRAFLG : Call ECR_TRACE(mess(12,100,1)-NOMFIC,1) From GESECRAN : Endif
    NOMFIC ="" # flg pour close
    Return
Endif
Iomode adxifs ""  Using [XSD_]
Iomode adxirs chr$(10)  Using [XSD_]
#  Le codage est passé pour les XSD export sinon par défaut c'est de l'utf-8
#  TCODAGE donne dans ce cas la valeur : 1 ascii  GASCII : 2 utf8 GUTF8 : 3 ucs2 GUCS2
ACOD1="utf-8" : TCODAGE=GUTF8
If dim(ACODAGE)>0 and ACODAGE>=1 and ACODAGE<=3
    Case ACODAGE
    When 1 : TCODAGE=GASCII : ACOD1=ENCODING
    When 3 : TCODAGE=GUCS2 : ACOD1=mess(ACODAGE,945,1)
  Endcase
Endif

Iomode adxium TCODAGE  Using [XSD_]
Return

$STC_OPERR
RET=0
Resume

# Fermeture
# - - - - - - - - - - - - - - - - - - - - - -
$STC_CLOSE
If NOMFIC <> ""
    Wrseq '</xs:schema>' Using [XSD_]
    Openo Using [XSD_]
Endif
Close Local File
Close Local Mask

If TRAFLG
    If RET=0 : Call ECR_TRACE(mess(39,7900,1),1) From GESECRAN: Endif
    Call ECR_TRACE(mess(4,125,1)-"-"-mess(23,143,1)-STCCOD,0) From GESECRAN
Endif
If TRAFLGOPEN or TRAFLGLEC
    Call FERME_TRACE From LECFIC
    If TRAFLGLEC : Call LEC_TRACE From LECFIC : Endif
Endif
Return

