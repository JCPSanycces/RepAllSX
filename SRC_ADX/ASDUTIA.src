#Endif
End


# - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - #
#  Dernier numèro de séquence de la table d'audit SData
#  Utilisé par le bridge (mise à jour table synchro)
# - - - - - - - - - - - - - - - - - - - - - -
Subprog AJA_GET_LASTSEQ(DBGHST, DBGPRT, DBGOPN, A_ERRLEV, A_ERRID, A_ERRMES, A_SEQLST)
Value    Char      DBGHST              # Debug: host
Value    Integer   DBGPRT              # Debug: port
Value    Shortint  DBGOPN              # Debug: dbgaff
Variable Integer   A_ERRLEV            # Message: niveau erreur  1:info 2:Warning 3:Transient 4:error
Variable Char      A_ERRID             # Message: identifiant
Variable Char      A_ERRMES            # Message

Variable Decimal   A_SEQLST            # Numero sequence fin

If clalev([AJA])=0 :  Local File AJSAUDIT[AJA] : Endif
Read [AJA]AJA0 Last
If fstat
  A_SEQLST=0
Else
  A_SEQLST=[AJA]SEQ
Endif
Close Local File [AJA]
End


# - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - #
#  Liste pour mise à jour de la table de synchro
#  Utilisé par le bridge
# - - - - - - - - - - - - - - - - - - - - - -
Subprog AJA_LST(DBGHST, DBGPRT, DBGOPN, A_ERRLEV, A_ERRID, A_ERRMES, A_SEQSTR, A_SEQEND, A_NLMAX, A_RESNAM, A_KEYERP, A_TIMSTP, A_EVT, A_FLGNXTSEQEND )
Value    Char      DBGHST              # Debug: host
Value    Integer   DBGPRT              # Debug: port
Value    Shortint  DBGOPN              # Debug: dbgaff
Variable Integer   A_ERRLEV            # Message: niveau erreur  1:info 2:Warning 3:Transient 4:error
Variable Char      A_ERRID             # Message: identifiant
Variable Char      A_ERRMES            # Message

Value    Decimal   A_SEQSTR            # Numero sequence debut
Value    Decimal   A_SEQEND            # Numero sequence fin

Value    Integer   A_NLMAX             #  Nb maxi de ligne retournées
Variable Char      A_RESNAM()(1..)     #  Nom de la ressource (RessourceKind)
Variable Char      A_KEYERP()(1..)     #  Clé ERP
Variable Char      A_TIMSTP()(1..)     #  TimeStamp
Variable Char      A_EVT()(1..)        #  I, U, D

Variable Decimal   A_FLGNXTSEQEND      #  !=0 si tableau plein = numero sequence fin pour rappel


Call JAVA_DEBUG(DBGHST, DBGPRT, DBGOPN)

Local Char    WC_MSGPRF : WC_MSGPRF="AJA_LST_"   # Prefixe pour identifiant erreur
Local Integer WNL, WOKTRT
Local Char W_TRTNAM(GLONADC)
Call PARAM("","ASDTRTAPP",W_TRTNAM) From ADOVAL
Call EXISTE_ADX("","",W_TRTNAM,WOKTRT) From ORDSYS
If !WOKTRT
  A_ERRLEV=4 : A_ERRID=WC_MSGPRF+"143_55" : A_ERRMES=num$(errn)-mess(55,143,1)-mess(90,123,1)-W_TRTNAM-"("-mess(143,105,1)-"SUP / ASDTRTANA"-")"
  End
Endif

If clalev([AJA])=0 :  Local File AJSAUDIT[AJA] : Endif

If dim(GSDATATRA) > 0 and GSDATATRA > 1 Then                                                  # FGR 12/08/2011
  Call OUVRE_TRACE("********** ASDUTIA" - num$(date$) - time$ - "**********") From STRSDATATEC    # FGR 12/08/2011
  Call ECR_TRACE("A_SEQSTR=" + num$(A_SEQSTR) - "A_SEQEND=" - num$(A_SEQEND), 0) From STRSDATATEC # FGR 12/08/2011
Endif                                                                                             # FGR 12/08/2011

Filter [AJA] Where SEQ <= A_SEQEND and SEQ >= A_SEQSTR Order By Key AJA0 Desc

Raz A_ERRLEV, A_ERRID, A_ERRMES, A_FLGNXTSEQEND   # A_RESNAM, A_KEYERP, A_TIMSTP, A_EVT, demande de AP
For [AJA]
    Gosub ASD_AUDIT_ANA From =W_TRTNAM
    If A_ERRLEV or A_FLGNXTSEQEND : Break : Endif
Next
Filter [AJA]
Close Local File [AJA]

If dim(GSDATATRA) > 0 and GSDATATRA > 1 Then                                                  # FGR 12/08/2011
  Call FERME_TRACE From STRSDATATEC                                                               # FGR 12/08/2011
Endif                                                                                             # FGR 12/08/2011
End


# - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - #
#  Etiquette $ASD_AUDIT_ANA: Analyse de la table d'audit - EXEMPLE
#
#   Transforme une ligne de la table d'audit en une ressource SData
#   Nota:
#    - Son écriture relève de l'applicatif
#    - L'audit ne concerne que les ressources déclarées synchronisées
#    dans le contrat (IsSyncSource="true")
#    - Normalement, un record de la table d'Audit permet de cibler une ressource,
#    mais si nécessaire cela pourrait se traduire par plusieurs ressources.
#    A priori ce besoin à disparu car les ressources filles ne sont plus déclarées synchronisables.
#
# - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - #
$ASD_AUDIT_ANA
# Entrée:
#              [F:AJA]            Record Audit
#  Integer     A_NLMAX            Indice maxi des tableaux de sortie
#
# Sortie:
#  Integer     WNL                Indice courant tableau
#  Char        A_RESNAM()(1..)    Nom de la ressource (RessourceKind)
#  Char        A_KEYERP()(1..)    Clé ERP    P1~P2
#  Char        A_TIMSTP()(1..)    TimeStamp
#  Char        A_EVT()(1..)       C, U, D
#  Erreur
#   Char       A_ERRID            Identifiant
#   Char       A_ERRMES           Libellé

# Sequence commune si un record audit = 1 record ressource
    WNL+=1 : If WNL > A_NLMAX : A_FLGNXTSEQEND = SEQ : Return : Endif
    A_EVT(WNL)   =[AJA]EVT
    If val([AJA]TIMSTP)+10000 <= val([AJA]TIMSTPTRI)    # Suppression ou timestamp non géré sur la table auditée (10000: marge de 10 sec.)
        A_TIMSTP(WNL) = [AJA]TIMSTPTRI
    Else
        A_TIMSTP(WNL) = [AJA]TIMSTP
    Endif
#

# Nom et clé
Case [AJA]TBL
When "ZJJ1"
    A_RESNAM(WNL)="ZJJRESSOURCEKIND"
    A_KEYERP(WNL)=[AJA]ID
When Default
    A_ERRLEV=4 : A_ERRID=WC_MSGPRF+"143_54" : A_ERRMES=mess(54,143,1)-[AJA]TBL-mess(8,47,1)-num$([AJA]SEQ)   # Analyse Audit SData - Code table non géré:
Endcase
Return


# - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - #
#  Pour consultation AJE
# - - - - - - - - - - - - - - - - - - - - - -
#    Informations pour affichage - EXEMPLE
Subprog ASD_AJEINF( A_RESNAM, A_ERPKEY, A_DES, A_HASTUN)
Value Char         A_RESNAM        # Nom de la ressource
Value Char         A_ERPKEY        # Clé Erp de la ressource
Variable Char      A_DES           # Description de la ressource
Variable Decimal   A_HASTUN        # 1: gestion d'un tunel
# En fonction du type de ressource
Case A_RESNAM
    When "TRADING"
        # En fonction de la clé ERP
       Case A_ERPKEY
        When "P1~P2"
            A_DES    ="Customer DIS001"
            A_HASTUN =1
       Endcase
Endcase
End

# - - - - - - - - - - - - - - - - - - - - - -
#    Gestion tunel - EXEMPLE
Subprog ASD_AJETUN( A_RESNAM, A_ERPKEY)
Value Char         A_RESNAM        # Nom de la ressource
Value Char         A_ERPKEY        # Clé Erp de la ressource
Local Char WDES(100)
# En fonction du type de ressource
Case A_RESNAM
    When "TRADING"
        # En fonction de la clé ERP
       Case A_ERPKEY
        When "P1~P2"
            Infbox "Tunnel vers P1~P2"
       Endcase
Endcase
End

######################################################################################
#    <UTILITAIRES>  Debut section utilitaires
######################################################################################
#  Timestamp à partir d'une date et heure
# - - - - - - - - - - - - - - - - - - - - - -
Funprog GETTIMSTAMP(DATEX, HEURX)
Value Date DATEX
Value Integer HEURX
Local Char TIMSTP(15)
Local Shortint HH, MM, SS, TMP
Local Integer TIMF
HH=HEURX/3600
TMP=mod(HEURX,3600)
MM=TMP/60
SS=mod(TMP,60)
TIMF=HH*10000+MM*100+SS
End format$("D:YYYYMMDD",DATEX)+format$("N0:######",TIMF)

# Activation debugger java
# - - - - - - - - - - - - - - - - - - - - - -
Subprog JAVA_DEBUG(DBGHST, DBGPRT, DBGOPN)
Value Char DBGHST
Value Integer DBGPRT
Value Integer DBGOPN

# - -
#DBGHST = "ecjullienc.sagefr.adinternal.com"   # dns
#DBGHST = "172.28.9.46"   # dns
#DBGPRT=1789
#DBGOPN=1
# - -

If DBGHST="" : End : Endif

If dim([V]GIAADXCTX)<0 : Global Char GIAADXCTX(250) : Endif
[V]GIAADXCTX = "X3_CS:NA1:"               : # entête "X3_CS:session client X3" + "NA1:session primaire"
Call SET_DEBUG_ON(1)  From DEBUGGERJ       : # 0=debugger socket "off"

Call SET_HOST(DBGHST) From DEBUGGERJ                  # dns
Call SET_PORT(num$(DBGPRT)) From DEBUGGERJ            # Port
# Call SET_PARAM("debug.trace","on") From DEBUGGERJ     # trace
                                                      #   filpath("TRA","X3DEBUG_"+ctrans(adxusr,".\/|*@","______"),"tra",0)
                                                      #   Ex: "/produits/v160/SOLSUPV6/dossiers/SUPERV/TRA/X3DEBUG_JPJ.tra"

#CHECK IGNORE_BEGIN
#If DBGOPN : Dbgaff : Endif
#CHECK IGNORE_END
End


# Dump clob dans la trace
# - - - - - - - - - - - - - - - - - - - - - -
Subprog DUMP_CLB2TRACE(AMSG, ACLB)
Value Char AMSG                # Message
Value Clbfile ACLB             # Clob
Local Char DP_CHAR(100)(0..)
Local Integer NB, WI : NB = len(ACLB)/100+1
If GTRACE="" : End : Endif
Setlob DP_CHAR With ACLB
Call ECR_TRACE("Start Dump"-AMSG,0) From GESECRAN
Repeat
 Call ECR_TRACE("   L"+num$(WI)+":"-DP_CHAR(WI),0) From GESECRAN : WI+=1
Until WI=100 or vireblc(DP_CHAR(WI),2)=""
Call ECR_TRACE("End Dump"-AMSG,0) From GESECRAN
End

# Dump clob dans un fichier (répertoire tmp de X3_PUB)
# - - - - - - - - - - - - - - - - - - - - - -
Subprog DUMP_CLB2FILE(AMSG, ACLB, ANAME, AVISU)
Value Char AMSG                # Message
Value Clbfile ACLB             # Clob
Value Char ANAME               # Nom fichier
Value Integer AVISU            # Lct browser pour visu
If vireblc(ANAME,2)="" : End : Endif

Local Char NOMFIC(200)
Call NAMEFIC(nomap,"TMP","", ANAME+".xml",NOMFIC) From INTRUTILA
Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

#Infbox NOMFIC
Openo NOMFIC,0 Using [CLB_]
Iomode adxifs ""  Using [CLB_]
Iomode adxirs chr$(10)  Using [CLB_]
Iomode adxium GUTF8 Using [CLB_]
Wrseq ACLB Using [CLB_]
Openo Using [CLB_]
If GTRACE<>"" : Call ECR_TRACE(AMSG-"Dump clob in file:"-NOMFIC ,0) From GESECRAN : Endif
If AVISU
    Local Char URL(200),RETOUR(200)
    URL=GVIRTDIR+"/"+nomap+"/TMP/"+ANAME+".xml"
    URL=ctrans(URL,"\","/")

    Callui RETOUR="" With   "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL ,
&                           "UIAdxPubSubFile="+ chr$(1) + "1"
Endif

End


# Gestion GUSRSD dans le cadre de SData-CRM
# - - - - - - - - - - - - - - - - - - - - - -
Subprog SETGUSRSD(CTX)
Value    Char    CTX
If dim(GUSRSD)>=0 : Kill GUSRSD : Endif
If (vireblc(CTX,2)="" or instr(0,CTX,"@")=0)
    End
Endif

If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
Local Char WEML(GLONMAI)
Local Integer WI, WEMLHASUSR
WEMLHASUSR=0

WEML = CTX
WI=instr(0,CTX,";")
If WI : WEML = right$(CTX,WI+1) : Endif

For [AUS] Where [F:AUS]ADDEML=WEML
    WEMLHASUSR=1
    Break
Next

If WEMLHASUSR                     # - User associé à l'email
    If [F:AUS]USR<>GUSER          # -- Utilisateurs différents (GUSER est positionné par le bridge CHGLOGINSD/CHGUSR
        Global Char GUSRSD(GLONAUS)
        GUSRSD = [F:AUS]USR
    Endif
Endif
End

