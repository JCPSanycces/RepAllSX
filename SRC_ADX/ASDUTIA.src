#  Fonction critere purge table d'audit  AJSAUDIT-AJA (utilsé par trt EPURASD)
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
Funprog ASDAUDPUR()
   Local Decimal   A_SEQ
   Local Integer   A_ERRLEV            # Message: niveau erreur
   Local Char      A_ERRID             # Message: identifiant
   Local Char      A_ERRMES            # Message
   Local Char      A_FILTRE(20)
   Call AJS_AUDINF("", 0, 0, A_ERRLEV, A_ERRID, A_ERRMES, "R", A_SEQ) From AJSSYNCA
   If A_ERRLEV <> 0             #  =4 and A_ERRID="115_154"  # Pas d'enreg.
        A_FILTRE = "[F1]SEQ < 0"
   Else
        A_FILTRE = "[F1]SEQ < " + num$(A_SEQ)   # La classe fichier est présente lors de l'appel
   Endif
End A_FILTRE


