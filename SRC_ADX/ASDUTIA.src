# - - - - - - - - - - - - - - - - - -  Génération 1 xsd via VALSTCXSD (appel simplifié)
$TST_AJA_LST
Call OUVRE_TRACE("TST_AJA_LST - Analyse Audit") From LECFIC
Local Char DBGHST(50)
Local Integer DBGPRT
DBGHST = "ecjullienc.sagefr.adinternal.com"   # dns
DBGPRT=1789

Local Integer   A_ERRLEV        # Message: niveau erreur
Local Char      A_ERRID(20)     # Message: identifiant
Local Char      A_ERRMES(200)   # Message

Local Decimal   A_SEQSTR            # Numero sequence debut
Local Decimal   A_SEQEND            # Numero sequence fin
Local Decimal   A_FLGNXTSEQEND      #  !=0 si tableau plein
A_SEQSTR = 2800
A_SEQEND = 2900

# Par ligne
Local Integer   A_NLMAX: A_NLMAX=100
Local Char      A_RESNAM(50)(1..A_NLMAX)         #  Nom de la ressource (RessourceKind)
Local Char      A_KEYERP(150)(1..A_NLMAX)        #  Clé ERP
Local Char      A_TIMSTP(15)(1..A_NLMAX)    #  TimeStamp
Local Char      A_EVT(1)(1..A_NLMAX)             #  I, U, D

Call AJA_LST(DBGHST, DBGPRT, 0, A_ERRLEV, A_ERRID, A_ERRMES, A_SEQSTR, A_SEQEND, A_NLMAX, A_RESNAM, A_KEYERP, A_TIMSTP, A_EVT, A_FLGNXTSEQEND )

If A_ERRLEV
 Call ECR_TRACE("Erreur"-A_ERRMES-"("-A_ERRID-")",1) From GESECRAN
Else
 Call ECR_TRACE(" Numero sequence fin suivant"-num$(A_FLGNXTSEQEND),0) From GESECRAN
 For WI=1 To A_NLMAX
    If A_RESNAM(WI)="" : Break : Endif
    Call ECR_TRACE(" Type ressource / Evt / Clé / Timestamp" -A_RESNAM(WI) -"/" -A_EVT(WI)-"/"-A_KEYERP(WI)-"/"-A_TIMSTP(WI),0) From GESECRAN
 Next
Endif

Call ECR_TRACE("Fin TST_AJA_LST",0) From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


# - - - - - - - - - - - - - - - - - -
$TST_AUDITPUR
Infbox  func ASDAUDPUR
Return


# - - - - - - - - - - - - - - - - - -
$TST_AJA_GET_LASTSEQ
Local Char DBGHST(50)
Local Integer DBGPRT

Local Integer   A_ERRLEV              # Message: niveau erreur
Local Char      A_ERRID(20)           # Message: identifiant
Local Char      A_ERRMES(200)         # Message
Local Decimal    A_VAL
Call AJA_GET_LASTSEQ(DBGHST, DBGPRT, 0, A_ERRLEV, A_ERRID, A_ERRMES,  A_VAL) From ASDUTIA
Infbox num$(A_VAL)
Return
