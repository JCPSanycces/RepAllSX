#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENHREXT2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone PARNBR
mkstat = 0
zoncou = "PARNBR"
indice = 0
status = 1
zoncou = "PARNBR"
If varmode([M]PARNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARNBR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]PARNBR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]PARNBR = nolign
   status = 75
   Call SAI_PARNBR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_PARNBR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone PARNBR
mkstat = 0
zoncou = "PARNBR"

## Zone PARDTALVL
mkstat = 0
zoncou = "PARDTALVL"
IMPENT = [M]PARDTALVL(indice)
If varinit([M]PARDTALVL,indice)=0
 IMPENT = 1
Endif
[M]PARDTALVL(indice) = IMPENT

## Zone PARMDT
mkstat = 0
zoncou = "PARMDT"
IMPENT = [M]PARMDT(indice)
If varinit([M]PARMDT,indice)=0
 IMPENT = 1
Endif
[M]PARMDT(indice) = IMPENT

## Zone PARVALTYP
mkstat = 0
zoncou = "PARVALTYP"
IMPENT = [M]PARVALTYP(indice)
If varinit([M]PARVALTYP,indice)=0
 IMPENT = 1
Endif
[M]PARVALTYP(indice) = IMPENT

## Zone PARVALDEB
mkstat = 0
zoncou = "PARVALDEB"
If varmode([M]PARVALDEB,indice)=0
 SAVACT = GACTION : GACTION = "AFMTSAI"
 Call ASAISIE([M]PARVALDEB(indice),[M:HREXE2]PARTYP(nolign-1)) From FMTVAR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PARVALDEB(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARVALDEB" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "AFMTCONT"
  Call CONTROLE([M]PARVALDEB(indice),[M:HREXE2]PARTYP(nolign-1),[M:HREXE2]PARNBRLIB(nolign-1),[M:HREXE2]PARLNG(nolign-1),[M:HREXE2]VALINT1(nolign-1)) From FMTVAR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PARVALDEB" : GZNUM = 7928 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTACL"
   Call CONTACL([M:HREXE2]VALINT1(nolign-1),[M:HREXE2]PARTYP(nolign-1),"","") From SUBACL
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PARVALDEB" : GZNUM = 7928 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_PARVALDEB([M]PARVALDEB(indice)) From TRTGENHREX
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PARVALDEB" : GZNUM = 7928 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone PARVALFIN
mkstat = 0
zoncou = "PARVALFIN"
If varmode([M]PARVALFIN,indice)=0
 SAVACT = GACTION : GACTION = "AFMTSAI"
 Call ASAISIE([M]PARVALFIN(indice),[M:HREXE2]PARTYP(nolign-1)) From FMTVAR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PARVALFIN(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARVALFIN" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "AFMTCONT"
  Call CONTROLE([M]PARVALFIN(indice),[M:HREXE2]PARTYP(nolign-1),[M:HREXE2]PARNBRLIB(nolign-1),[M:HREXE2]PARLNG(nolign-1),[M:HREXE2]VALINT2(nolign-1)) From FMTVAR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PARVALFIN" : GZNUM = 7929 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTACL"
   Call CONTACL([M:HREXE2]VALINT2(nolign-1),[M:HREXE2]PARTYP(nolign-1),"","") From SUBACL
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PARVALFIN" : GZNUM = 7929 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_PARVALFIN([M]PARVALFIN(indice)) From TRTGENHREX
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PARVALFIN" : GZNUM = 7929 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone PARNBR
mkstat = 0
zoncou = "PARNBR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "GENHREXT2"
Return

