#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################
# Valuation report calls that are point in time version
# specific.
#############################################################

#############################################################
# Point in Time main entry point
#############################################################
$PIT_VALUATION_REPORT
Local Decimal   LEXE, LPER
Local Integer   LCSTTYP, ISSMET, LRET, LVLT, LSUMMARY
Local Integer   LCOUNTER, LDETCNT, LSTOCOU, LSTANDARD
Local Date      STRDAT, ENDDAT, VLTBEG
Local Datetime  STRDATTIM, VLTBEGTIM, VLTENDTIM
Local Char      LTCM(GLONTCM), DATTEMP(10), VLTCHG(1)
Local Char      CRITERIA (255), CRITERIA2(255)
Local Char      LPITVALFLG(15)

# Variables used to handle intersite for detail valuation
Local Char    TXFR_DET_MAJ(GLONICVVAL)(1..), TXFR_DET_MIN(GLONICVVAL)(1..)
Local Char    TXFR_DET_LOT(GLONLOT)(1..), TXFR_DET_SLO(GLONSLO)(1..)
Local Integer TXFR_DET_VCR(1..), TXFR_DET_LIN(1..), TXFR_DET_TYP(1..)
Local Char    TXFR_DET_NUM(GLONVCR)(1..)
Local Decimal TXFR_DET_QTY(1..), TXFR_DET_AMT(1..)
Local Integer TXFR_RECORD

  # Are we looking at the primary or secondary issue method?
  Case [M:SVAL]CSTCOD
    When 9
      ISSMET = 1
      LPITVALFLG = 'PITVALFLG=2'
    When 13
      ISSMET = 2
      LPITVALFLG = 'PITVALFLG2=2'
    When Default : Return
  Endcase

  # We have an ITF record for what we are processing
  # We have passed all filters and know we want to get PIT related stuff
  # And we know we are in summary mode
  If [M:SVAL]DETFLG = 1
    LSUMMARY = 1
    [M:SVAL]NPRNAM    = "STOCK12PG"
  Else
    LSUMMARY = 0
    [M:SVAL]NPRNAM    = "STOCK12PD"
  Endif

  [L]STRDAT = [M:SVAL]STRDAT
  [L]ENDDAT = [M:SVAL]REFDAT

  # Find the period start date for the Start date of the report
  Call GETSOC([F:ITF]STOFCY) From DEVSUB

  # Check for method change during report span.
  Raz [L]VLTCHG
  [L]VLTCHG = func STKPITLIB.VAL_METH_CHK([F:ITF]VLTCODDAT, [L]STRDAT, [L]ENDDAT)
  # If we have a value change, loop through the valuation methods that were during report span
  # each method represented should get an entry from report start or date of change
  # to ref date or end of it being used as valuation
  If [L]VLTCHG <> ""
    For LVLT = dim([F:ITF]VLTCODDAT)-1 To 0 Step -1

      If [F:ITF]VLTCODDAT(LVLT)<>gdatetime$("0000-00-00T00:00:00Z")
        [L]STRDATTIM = gdatetime$(format$("DZ:YYYY[-]MM[-]DD",[M]STRDAT)+"T00:00:00Z")
        If [F:ITF]VLTCODDAT(LVLT) > [L]STRDATTIM
          If [L]ENDDAT<>[M]REFDAT
            # Update start date to end date
            [L]STRDAT = [L]ENDDAT+1
          Endif
          [L]DATTEMP = num$([F:ITF]VLTCODDAT(LVLT))
          [L]ENDDAT  = gdat$(val(mid$([L]DATTEMP,9,2)),val(mid$([L]DATTEMP,6,2)),val(left$([L]DATTEMP,4)))

          # Get the date that this valuation method started
          Raz [L]VLTBEG, [L]VLTBEGTIM, [L]VLTENDTIM
          If LVLT<>dim([F:ITF]VLTCODDAT)-1 & [F:ITF]VLTCODDAT(LVLT+1)<>gdatetime$("0000-00-00T00:00:00Z")
            [L]DATTEMP = num$([F:ITF]VLTCODDAT(LVLT+1))
            [L]VLTBEG  = gdat$(val(mid$([L]DATTEMP,9,2)),val(mid$([L]DATTEMP,6,2)),val(left$([L]DATTEMP,4)))
            [L]VLTBEGTIM = [F:ITF]VLTCODDAT(LVLT+1)
          Endif
          [L]VLTENDTIM = [F:ITF]VLTCODDAT(LVLT)
          LCOUNTER = LVLT+1
          If LSUMMARY
            Gosub LOAD_SUMMARY_DATA
          Else
            Gosub LOAD_DETAIL_DATA
          Endif
        Endif
      Endif
    Next
    [L]STRDAT = [L]ENDDAT
    [L]ENDDAT = [M]REFDAT
  Endif
  # Get the date that this valuation method started
  Raz [L]VLTBEG, [L]VLTBEGTIM, [L]VLTENDTIM
  If [L]VLTCHG <> ""
    [L]VLTBEGTIM = [F:ITF]VLTCODDAT(0)
  Elsif [F:ITF]VLTCODDAT(0)<>gdatetime$("0000-00-00T00:00:00Z")
    [L]DATTEMP = num$([F:ITF]VLTCODDAT(0))
    [L]VLTBEG  = gdat$(val(mid$([L]DATTEMP,9,2)),val(mid$([L]DATTEMP,6,2)),val(left$([L]DATTEMP,4)))
    If [L]VLTBEG < [L]STRDAT & [L]VLTBEG > [F:PER]PERSTR
      [L]VLTBEGTIM = [F:ITF]VLTCODDAT(0)
    Endif
  Endif
  LCOUNTER = 0
  If LSUMMARY
    Gosub LOAD_SUMMARY_DATA
  Else
    Gosub LOAD_DETAIL_DATA
  Endif

  If [M:SVAL]TRAFLG = [V]CST_AYES
    Gosub LOAD_INTERSITE
  Endif

Return

#############################################################
# Summary report versions
#############################################################
$LOAD_SUMMARY_DATA

  # Handle all of the shared basic report setup stuff
  Gosub SHARED_REPORT_START

  # Set basic report header info
  Gosub SHARED_REPORT_HEADER

  # Verify again that the valuation method is part of the search criteria
  If ([M:SVAL]VLTSTR<>"" | [M:SVAL]VLTEND<>"") & ([F:TCM]VLTCOD < [M:SVAL]VLTSTR | [F:TCM]VLTCOD > [M:SVAL]VLTEND)
    Return
  Endif

  # Get the starting balance from the correct PIT table
  Case [F:TCM]ISSVLTCOD(ISSMET-1)
    When 1 #Standard
      LSTANDARD = 1
      LCSTTYP = [F:TCM]ISSVLTCOD(ISSMET-1)
      Gosub PIT_STD_SUMMARY
    When 2 #Revised Standard
      LSTANDARD = 1
      LCSTTYP = [F:TCM]ISSVLTCOD(ISSMET-1)
      Gosub PIT_STD_SUMMARY
    When 4 # Average Cost
      Gosub PIT_AVC_START
    When 5 #FIFO
      Gosub PIT_FIFO_SUMMARY
    When 6 # Average Lot Cost
      Gosub PIT_ALC_SUMMARY
    When 8 #LIFO
      Gosub PIT_FIFO_SUMMARY
    When Default
      # If no valuation method for this product, skip it
      Return
  Endcase

  Gosub CALC_TO_START
  Gosub CALC_TO_END

  # The value we put in STOCOU is always just LCOUNTER for summary reports
  LSTOCOU = LCOUNTER

  # Populate final details and write record
  Gosub SHARED_REPORT_END

Return


# Get the PIT starting balance for an Avg Lot Cost product (summary mode)
$PIT_ALC_SUMMARY
Local Char PREV_LOT(GLONLOT), PREV_SLO(GLONSLO)
Local Integer I

  Raz CRITERIA
  CRITERIA  = "ITMREF = [F:STV]ITMREF"
  CRITERIA -= "& STOFCY = [F:STV]STOFCY"
  CRITERIA -= "& PERSTR <= [L]STRDAT"
  CRITERIA -= "& VLTNUM = [L]ISSMET"

  Filter [SLFP] Where evalue(CRITERIA) Order By Key SLFP0 Desc
  For [F:SLFP]
    If [F:SLFP]LOT = PREV_LOT & [F:SLFP]SLO = PREV_SLO & I>0 : Goto NEXT_LOT : Endif
    PREV_LOT = [F:SLFP]LOT
    PREV_SLO = [F:SLFP]SLO
    I += 1

    If [F:SLFP]PERSTR = [F:PER]PERSTR
      [F:STV]QTYSTU += [F:SLFP]BEGBASQTY
      [F:STV]AMT    += [F:SLFP]BEGBASAMT
    Else
      [F:STV]QTYSTU += [F:SLFP]ENDBASQTY
      [F:STV]AMT    += [F:SLFP]ENDBASAMT
    Endif

    $NEXT_LOT
  Next
  Filter [SLFP]
Return

# Get the PIT starting balance for a FIFO product (summary mode)
$PIT_FIFO_SUMMARY
Local Decimal PREV_CSTCOU

  Raz CRITERIA
  CRITERIA  = "ITMREF = [F:STV]ITMREF"
  CRITERIA -= "& STOFCY = [F:STV]STOFCY"
  CRITERIA -= "& PERSTR <= [L]STRDAT"
  CRITERIA -= "& VLTNUM = [L]ISSMET"

  Filter [STPP] Where evalue(CRITERIA) Order By Key STPP0 Desc
  For [F:STPP]
    If [F:STPP]CSTCOU = PREV_CSTCOU : Goto NEXT_CSTCOU_SUM : Endif
    PREV_CSTCOU = [F:STPP]CSTCOU

    If [F:STPP]PERSTR = [F:PER]PERSTR
      [F:STV]QTYSTU += [F:STPP]PERBEGQTY
      [F:STV]AMT    += [F:STPP]PERBEGCST
    Else
      [F:STV]QTYSTU += [F:STPP]PERENDQTY
      [F:STV]AMT    += [F:STPP]PERENDCST
    Endif

    $NEXT_CSTCOU_SUM
  Next
  Filter [STPP]
Return

# Get the PIT starting balance for a STD product
$PIT_STD_SUMMARY
Local Char PREV_ECCMAJ(GLONICVVAL), PREV_ECCMIN(GLONICVVAL)
Local Integer I

  Raz CRITERIA
  CRITERIA  = "ITMREF = [F:STV]ITMREF"
  CRITERIA -= "& STOFCY = [F:STV]STOFCY"
  CRITERIA -= "& PERSTR <= [L]STRDAT"
  CRITERIA -= "& CSTTYP = [L]LCSTTYP"
  CRITERIA -= "& VLTNUM = [L]ISSMET"

  Filter [ITCP] Where evalue(CRITERIA) Order By Key ITCP0 Desc
  For [F:ITCP]
    If [F:ITCP]ECCVALMAJ = PREV_ECCMAJ & [F:ITCP]ECCVALMIN = PREV_ECCMIN & I>0 : Goto NEXT_VERSION : Endif
    PREV_ECCMAJ = [F:ITCP]ECCVALMAJ
    PREV_ECCMIN = [F:ITCP]ECCVALMIN
    I += 1

    If [F:ITCP]PERSTR = [F:PER]PERSTR
      [F:STV]QTYSTU += [F:ITCP]PERBEGQTY
      [F:STV]AMT    += [F:ITCP]PERBEGCST
    Else
      [F:STV]QTYSTU += [F:ITCP]PERENDQTY
      [F:STV]AMT    += [F:ITCP]PERENDCST
    Endif

    $NEXT_VERSION
  Next
  Filter [ITCP]
Return

#############################################################
# Detail report versions
#############################################################
$LOAD_DETAIL_DATA

  # Handle all of the shared basic report setup stuff
  Gosub SHARED_REPORT_START

  # Verify again that the valuation method is part of the search criteria
  If ([M:SVAL]VLTSTR<>"" | [M:SVAL]VLTEND<>"") & ([F:TCM]VLTCOD < [M:SVAL]VLTSTR | [F:TCM]VLTCOD > [M:SVAL]VLTEND)
    Return
  Endif

  # Call the correct report handler based on valuation method
  Case [F:TCM]ISSVLTCOD(ISSMET-1)
    When 1 #Standard
      LSTANDARD = 1
      LCSTTYP = [F:TCM]ISSVLTCOD(ISSMET-1)
      Gosub PIT_STD_DETAIL
    When 2 #Revised Standard
      LSTANDARD = 1
      LCSTTYP = [F:TCM]ISSVLTCOD(ISSMET-1)
      Gosub PIT_STD_DETAIL
    When 4 # Average Cost
      # Set basic report header info
      Gosub SHARED_REPORT_HEADER
      Gosub PIT_AVC_START
      Gosub CALC_TO_START
      Gosub CALC_TO_END
      LSTOCOU = LCOUNTER  # The value we put in STOCOU is always just LCOUNTER for summary reports
      Gosub SHARED_REPORT_END
    When 5 #FIFO
      Gosub PIT_FIFO_DETAIL
    When 6 # Average Lot Cost
      Gosub PIT_ALC_DETAIL
    When 8 #LIFO
      Gosub PIT_FIFO_DETAIL
    When Default
      # If no valuation method for this product, skip it
      Return
  Endcase

Return

$PIT_ALC_DETAIL
Local Char DETAIL_LOT(GLONLOT), DETAIL_SLO(GLONSLO)
Local Integer I

  # Get each Lot/SLO to process for the detail report
  CRITERIA  = "SELECT DISTINCT LOT_0, SLO_0 FROM STOLOTFCYPIT"
  CRITERIA -= "WHERE ITMREF_0 = '" + [F:ITF]ITMREF + "'"
  CRITERIA -= "  AND STOFCY_0 = '" + [F:ITF]STOFCY + "'"
  CRITERIA -= "  AND VLTNUM_0 = '" + num$([L]ISSMET) + "'"
  CRITERIA -= "ORDER BY LOT_0, SLO_0"

  For (Char LOT, Char SLO) From num$(GTYPDBA*2+1) Sql CRITERIA As [SLFPD]
    DETAIL_LOT  = [F:SLFPD]LOT
    DETAIL_SLO  = [F:SLFPD]SLO

    # Set basic report header info
    Gosub SHARED_REPORT_HEADER

    Raz CRITERIA2
    CRITERIA2  = "ITMREF = [F:STV]ITMREF"
    CRITERIA2 -= "& STOFCY = [F:STV]STOFCY"
    CRITERIA2 -= "& PERSTR <= [L]STRDAT"
    CRITERIA2 -= "& LOT = [L]DETAIL_LOT"
    CRITERIA2 -= "& SLO = [L]DETAIL_SLO"

    Filter [SLFP] Where evalue(CRITERIA2) Order By Key SLFP0 Desc
    Read [F:SLFP] First
    Filter [SLFP]
    If !fstat
      If [F:SLFP]PERSTR = [F:PER]PERSTR
        [F:STV]QTYSTU += [F:SLFP]BEGBASQTY
        [F:STV]AMT    += [F:SLFP]BEGBASAMT
      Else
        [F:STV]QTYSTU += [F:SLFP]ENDBASQTY
        [F:STV]AMT    += [F:SLFP]ENDBASAMT
      Endif
    Endif

    Gosub CALC_TO_START
    Gosub CALC_TO_END

    # For detail reports - LSTOCOU is the detail count (done by 10s + the LCOUNTER)
    LDETCNT += 10
    LSTOCOU = LDETCNT + LCOUNTER
    Gosub SHARED_REPORT_END
  Next

Return

$PIT_FIFO_DETAIL
Local Decimal DETAIL_CSTCOU

  Raz CRITERIA

  # Get each CSTCOU to process for the detail report
  CRITERIA  = "SELECT DISTINCT CSTCOU_0, CSTDAT_0, CSTTIM_0 FROM STOCOSTPIT"
  CRITERIA -= "WHERE ITMREF_0 = '" + [F:ITF]ITMREF + "'"
  CRITERIA -= "  AND STOFCY_0 = '" + [F:ITF]STOFCY + "'"
  CRITERIA -= "  AND VLTNUM_0 = '" + num$([L]ISSMET) + "'"
  CRITERIA -= "ORDER BY CSTDAT_0, CSTTIM_0, CSTCOU_0"

  For (Decimal CSTCOU, Date CSTDAT, Char CSTTIM) From num$(GTYPDBA*2+1) Sql CRITERIA As [STPPD]
    [L]DETAIL_CSTCOU = [F:STPPD]CSTCOU

    # Set basic report header info
    Gosub SHARED_REPORT_HEADER

    Raz CRITERIA2
    CRITERIA2  = "ITMREF = [F:STV]ITMREF"
    CRITERIA2 -= "& STOFCY = [F:STV]STOFCY"
    CRITERIA2 -= "& PERSTR <= [L]STRDAT"
    CRITERIA2 -= "& CSTCOU = [L]DETAIL_CSTCOU"

    Filter [STPP] Where evalue(CRITERIA2) Order By Key STPP0 Desc
    Read [F:STPP] First
    Filter [STPP]
    If !fstat
      If [F:STPP]PERSTR = [F:PER]PERSTR
        [F:STV]QTYSTU += [F:STPP]PERBEGQTY
        [F:STV]AMT    += [F:STPP]PERBEGCST
      Else
        [F:STV]QTYSTU += [F:STPP]PERENDQTY
        [F:STV]AMT    += [F:STPP]PERENDCST
      Endif
    Endif

    Gosub CALC_TO_START
    Gosub CALC_TO_END

    # For detail reports - LSTOCOU is the detail count (done by 10s + the LCOUNTER)
    LDETCNT += 10
    LSTOCOU = LDETCNT + LCOUNTER
    Gosub SHARED_REPORT_END
  Next

Return

# Get the PIT starting balance for a STD product
$PIT_STD_DETAIL
Local Char DETAIL_ECCMAJ(GLONICVVAL), DETAIL_ECCMIN(GLONICVVAL)
Local Integer I

  Raz CRITERIA

  # Get each CSTCOU to process for the detail report
  CRITERIA  = "SELECT DISTINCT ECCVALMAJ_0, ECCVALMIN_0 FROM ITMCOSTPIT"
  CRITERIA -= "WHERE ITMREF_0 = '" + [F:ITF]ITMREF + "'"
  CRITERIA -= "  AND STOFCY_0 = '" + [F:ITF]STOFCY + "'"
  CRITERIA -= "  AND VLTNUM_0 = '" + num$([L]ISSMET) + "'"
  CRITERIA -= "ORDER BY ECCVALMAJ_0, ECCVALMIN_0"

  For (Char ECCVALMAJ, Char ECCVALMIN) From num$(GTYPDBA*2+1) Sql CRITERIA As [ITCPD]
    [L]DETAIL_ECCMAJ = [F:ITCPD]ECCVALMAJ
    [L]DETAIL_ECCMIN = [F:ITCPD]ECCVALMIN

    # Set basic report header info
    Gosub SHARED_REPORT_HEADER

    Raz CRITERIA2
    CRITERIA2  = "ITMREF = [F:STV]ITMREF"
    CRITERIA2 -= "& STOFCY = [F:STV]STOFCY"
    CRITERIA2 -= "& PERSTR <= [L]STRDAT"
    CRITERIA2 -= "& CSTTYP = [L]LCSTTYP"
    CRITERIA2 -= "& ECCVALMAJ = [L]DETAIL_ECCMAJ"
    CRITERIA2 -= "& ECCVALMIN = [L]DETAIL_ECCMIN"

    Filter [ITCP] Where evalue(CRITERIA2) Order By Key ITCP0 Desc
    Read [F:ITCP] First
    Filter [ITCP]
    If !fstat
      If [F:ITCP]PERSTR = [F:PER]PERSTR
        [F:STV]QTYSTU += [F:ITCP]PERBEGQTY
        [F:STV]AMT    += [F:ITCP]PERBEGCST
      Else
        [F:STV]QTYSTU += [F:ITCP]PERENDQTY
        [F:STV]AMT    += [F:ITCP]PERENDCST
      Endif
    Endif

    Gosub CALC_TO_START
    Gosub CALC_TO_END

    # For detail reports - LSTOCOU is the detail count (done by 10s + the LCOUNTER)
    LDETCNT += 10
    LSTOCOU = LDETCNT + LCOUNTER
    Gosub SHARED_REPORT_END
  Next

Return

##########################################################################################
##  Average cost is shared between summary and detail
##########################################################################################

# Get the PIT starting balance for a Avg Cost product
$PIT_AVC_START

  Raz CRITERIA

  CRITERIA  = "ITMREF = [F:STV]ITMREF"
  CRITERIA -= "& STOFCY = [F:STV]STOFCY"
  CRITERIA -= "& PERSTR <= [L]STRDAT"
  CRITERIA -= "& VLTNUM = [L]ISSMET"

  Filter [ITVP] Where evalue(CRITERIA) Order By Key ITVP0 Desc
  Read [F:ITVP] First
  Filter [ITVP]
  If !fstat
    If [F:ITVP]PERSTR = [F:PER]PERSTR
      [F:STV]QTYSTU += [F:ITVP]BEGBASQTY
      [F:STV]AMT    += [F:ITVP]BEGBASAMT
    Else
      [F:STV]QTYSTU += [F:ITVP]ENDBASQTY
      [F:STV]AMT    += [F:ITVP]ENDBASAMT
    Endif
  Endif
Return

##########################################################################################
##  Routines for getting the STOJOU data
##########################################################################################
#Calculate STOJOU records from the Period start to the start date
$CALC_TO_START
Local Date STJBEG
Local Integer DET_FIFO, LMVTTYP

  If [L]STRDAT = [0/0/0] : Return : Endif

  # Don't get from Period start date if we are dealing with a changed valuation meth
  If [L]VLTBEG <> [0/0/0] & [L]VLTBEG > [F:PER]PERSTR
    [L]STJBEG = [L]VLTBEG
  Else
    [L]STJBEG = [F:PER]PERSTR
  Endif

  Raz CRITERIA, CRITERIA2, DET_FIFO

  CRITERIA  = "ITMREF = [F:STV]ITMREF"
  CRITERIA -= "& STOFCY = [F:STV]STOFCY"
  CRITERIA -= "& ((ACCDAT =[0/0/0] & IPTDAT < [L]STRDAT & IPTDAT >= [F:PER]PERSTR)"
  CRITERIA -= "OR (ACCDAT<>[0/0/0] & ACCDAT < [L]STRDAT & ACCDAT >= [F:PER]PERSTR))"
  If [L]VLTBEGTIM <> gdatetime$("0000-00-00T00:00:00Z")
    CRITERIA -= "& CREDATTIM >= [L]VLTBEGTIM"
  Endif
  If [L]VLTENDTIM <> gdatetime$("0000-00-00T00:00:00Z")
    CRITERIA -= "& CREDATTIM < [L]VLTENDTIM"
  Endif

  #X3-89541 MIHAL. Remove [F:STJ]NUMVCR<>"" and add [F:STJ]PITVALFLG=2 & [F:STJ]ENTCOD<>''
  If [M:SVAL]DETFLG = [V]CST_ANO | [F:TCM]ISSVLTCOD(ISSMET-1) = 4
    # If summary - we don't care about Type 22
    CRITERIA2 = "[F:STJ]"+LPITVALFLG+" & [F:STJ]ENTCOD<>''"
  Else
    # We only care about Type 22 when detail and ALC
    CRITERIA2 = "([F:STJ]"+LPITVALFLG+" & [F:STJ]ENTCOD<>'' | [F:STJ]TRSTYP=22)"
  Endif

  If [M:SVAL]DETFLG = [V]CST_AYES
    #If detail mode, add in additional criteria for the detail record we are on
    Case [F:TCM]ISSVLTCOD(ISSMET-1)
      When 1, 2 # Standard & Revised standard
        CRITERIA2 -= "& ECCVALMAJ = [L]DETAIL_ECCMAJ"
        CRITERIA2 -= "& ECCVALMIN = [L]DETAIL_ECCMIN"
      When 5, 8 #FIFO, LIFO
        DET_FIFO = 1
      When 6 # Average Lot Cost
        CRITERIA2 -= "& LOT    = [L]DETAIL_LOT"
        CRITERIA2 -= "& SLO    = [L]DETAIL_SLO"
    Endcase
  Endif

  If ISSMET = 1
    CRITERIA2 -= "& PITVALFLG = 2"
  Else
    CRITERIA2 -= "& PITVALFLG2 = 2"
  Endif

  Filter [STJ] Where evalue(CRITERIA) & evalue(CRITERIA2)
  For [F:STJ]
    If [F:STJ]TRSTYP = 22 & [F:TCM]ISSVLTCOD(ISSMET-1) <> 6
      Goto NEXT_BEG
    Endif
    If DET_FIFO
      Call GETMVTTYP([F:STJ]TRSTYP, LMVTTYP) From STKPITLIB
      If [F:STJ]CSTCOU<>[L]DETAIL_CSTCOU & !find(LMVTTYP,2,3)
        Goto NEXT_BEG
      Endif
      If LMVTTYP = 2
        If [F:STJ]CSTCOU = 0 : Goto NEXT_BEG : Endif
        # We are in detail mode for FIFO - look to SMC to see what portion is this transaction
        For [SMC]SMC0 Where CSTCOU=[F:STPPD]CSTCOU & CSTTIM=[F:STPPD]CSTTIM & CSTDAT=[F:STPPD]CSTDAT
&                         & VCRNUM=[F:STJ]VCRNUM & VCRLIN=[F:STJ]VCRLIN & VCRTYP=[F:STJ]VCRTYP
          [F:STV]QTYSTU  -= [F:SMC]QTYSTU
          [F:STV]AMT     -= [F:SMC]CST
        Next
        Goto NEXT_BEG
      Elsif LMVTTYP = 3  # Value changes
        # Issue X3-89542
        # We are in detail mode for FIFO - look to CGVD to see what value change goes to this tier
        Filter [F:CGVD] Where CSTCOU=[F:STPPD]CSTCOU & CSTTIM=[F:STPPD]CSTTIM & CSTDAT=[F:STPPD]CSTDAT
&                           & CGVNUM=[F:STJ]VCRNUM & CGVTYP = 2
        For [CGVD]
          [F:STV]AMT += [F:CGVD]AMT - [F:CGVD]AMTORI
        Next
        Filter [F:CGVD]
        Goto NEXT_BEG
        # End issue X3-89542
      Endif
    Endif
    [F:STV]QTYSTU += [F:STJ]QTYSTU
    If ISSMET = 1
      [F:STV]AMT    += [F:STJ]VARVAL
      If !LSTANDARD
        [F:STV]AMT  += [F:STJ]AMTDEV
      Endif
    Else
      [F:STV]AMT    += [F:STJ]VARVAL2
      If !LSTANDARD
        [F:STV]AMT  += [F:STJ]AMTDEV2
      Endif
    Endif
    $NEXT_BEG
  Next
  Filter [STJ]

Return

#Calculate STOJOU records from the start date to the end date
$CALC_TO_END
Local Integer LMVTTYP
Local Decimal VARVAL, FIFO_CST, FIFO_QTY
Local Integer DET_FIFO
Local Char    VCRLIST(50) (0..)
Local Integer VCRCOUNT

  Raz CRITERIA, CRITERIA2, DET_FIFO

  CRITERIA  = "ITMREF = [F:STV]ITMREF"
  CRITERIA -= "& STOFCY = [F:STV]STOFCY"
  CRITERIA -= "& ((ACCDAT =[0/0/0] & IPTDAT >= [L]STRDAT & IPTDAT <= [L]ENDDAT)"
  CRITERIA -= "OR (ACCDAT<>[0/0/0] & ACCDAT >= [L]STRDAT & ACCDAT <= [L]ENDDAT))"
  If [L]VLTBEGTIM <> gdatetime$("0000-00-00T00:00:00Z")
    CRITERIA -= "& CREDATTIM >= [L]VLTBEGTIM"
  Endif
  If [L]VLTENDTIM <> gdatetime$("0000-00-00T00:00:00Z")
    CRITERIA -= "& CREDATTIM < [L]VLTENDTIM"
  Endif

  #X3-89541 MIHAL. Remove [F:STJ]NUMVCR<>"" and add [F:STJ]PITVALFLG=2 & [F:STJ]ENTCOD<>''
  If [M:SVAL]DETFLG = [V]CST_ANO | [F:TCM]ISSVLTCOD(ISSMET-1) <> 6
    # If summary - we don't care about Type 22
    CRITERIA2 = "[F:STJ]"+LPITVALFLG+" & [F:STJ]ENTCOD<>''"
  Else
    # We only care about Type 22 when detail and ALC
    CRITERIA2 = "([F:STJ]"+LPITVALFLG+" & [F:STJ]ENTCOD<>'' | [F:STJ]TRSTYP=22)"
  Endif

  If [M:SVAL]DETFLG = [V]CST_AYES
    #If detail mode, add in additional criteria for the detail record we are on
    Case [F:TCM]ISSVLTCOD(ISSMET-1)
      When 1, 2 # Standard & Revised standard
        CRITERIA2 -= "& ECCVALMAJ = [L]DETAIL_ECCMAJ"
        CRITERIA2 -= "& ECCVALMIN = [L]DETAIL_ECCMIN"
      When 5, 8 #FIFO, LIFO
        DET_FIFO = 1
      When 6 # Average Lot Cost
        CRITERIA2 -= "& LOT    = [L]DETAIL_LOT"
        CRITERIA2 -= "& SLO    = [L]DETAIL_SLO"
    Endcase
  Endif

  If ISSMET = 1
    CRITERIA2 -= "& PITVALFLG = 2"
  Else
    CRITERIA2 -= "& PITVALFLG2 = 2"
  Endif

  Filter [STJ] Where evalue(CRITERIA) & evalue(CRITERIA2)
  For [F:STJ]

    If [F:STJ]TRSTYP = 22 & [F:TCM]ISSVLTCOD(ISSMET-1) <> 6
      Goto NEXT_END
    Endif
    If ISSMET = 1
      [L]VARVAL = [F:STJ]VARVAL
    Else
      [L]VARVAL = [F:STJ]VARVAL2
    Endif

    Call GETMVTTYP([F:STJ]TRSTYP, LMVTTYP) From STKPITLIB
    Case LMVTTYP
      When 1        # Receipt
        If DET_FIFO & [F:STJ]CSTCOU<>[L]DETAIL_CSTCOU
          Goto NEXT_END
        Endif
        [F:STV]QTYSTURCP += [F:STJ]QTYSTU
        [F:STV]AMTRCP += [L]VARVAL
      When 2        # Issue
        If DET_FIFO
          If [F:STJ]CSTCOU = 0 : Goto NEXT_END : Endif
          Raz FIFO_QTY, FIFO_CST
          # We are in detail mode for FIFO - look to SMC to see what portion is this transaction
          For [SMC]SMC0 Where CSTCOU=[F:STPPD]CSTCOU & CSTTIM=[F:STPPD]CSTTIM & CSTDAT=[F:STPPD]CSTDAT
&                           & VCRNUM=[F:STJ]VCRNUM & VCRLIN=[F:STJ]VCRLIN & VCRTYP=[F:STJ]VCRTYP
&                           & !find(VCRNUM,VCRLIST)
            [L]FIFO_QTY -= [F:SMC]QTYSTU
            [L]FIFO_CST -= [F:SMC]CST
          Next
          VCRCNT = maxtab(TXFR_DET_VCR)+1
          VCRLIST(VCRCNT) = [F:STJ]VCRNUM

          [F:STV]QTYSTUISS  += [L]FIFO_QTY
          [F:STV]AMTISS     += [L]FIFO_CST
        Else
          [F:STV]QTYSTUISS += [F:STJ]QTYSTU
          [F:STV]AMTISS += [L]VARVAL
        Endif
      When 3        # Value changes
        # Issue X3-89542 - 2018-05-09 by ERMIL : Handle value change transactions when detail and FIFO
        If DET_FIFO
          # We are in detail mode for FIFO - look to CGVD to see what value change goes to this tier
          Raz [L]VARVAL
          Filter [F:CGVD] Where CSTCOU=[F:STPPD]CSTCOU & CSTTIM=[F:STPPD]CSTTIM & CSTDAT=[F:STPPD]CSTDAT
&                             & CGVNUM=[F:STJ]VCRNUM & CGVTYP = 2
          For [CGVD]
            [L]VARVAL += [F:CGVD]AMT - [F:CGVD]AMTORI
          Next
          Filter [F:CGVD]
        Endif
        # End issue X3-89542
        If [L]VARVAL>0
          [F:STV]AMTRCP += [L]VARVAL
        Else
          [F:STV]AMTISS += [L]VARVAL
        Endif
      When Default  # Misc - base the movement type on the sign
        If DET_FIFO & [F:STJ]CSTCOU<>[L]DETAIL_CSTCOU
          Goto NEXT_END
        Endif
        If [F:STJ]QTYSTU>0
          [F:STV]QTYSTURCP += [F:STJ]QTYSTU
          [F:STV]AMTRCP += [L]VARVAL
        Else
          [F:STV]QTYSTUISS += [F:STJ]QTYSTU
          [F:STV]AMTISS += [L]VARVAL
        Endif
    Endcase

    If ISSMET = 1
      [F:STV]AMTDEV += [F:STJ]AMTDEV
    Else
      [F:STV]AMTDEV += [F:STJ]AMTDEV2
    Endif

    If [M:SVAL]TRAFLG = [V]CST_AYES
      Gosub CHECK_INTERSITE
    Endif

    $NEXT_END
  Next
  Filter [STJ]

  [F:STV]ENDQTYSTU = [F:STV]QTYSTU + [F:STV]QTYSTURCP + [F:STV]QTYSTUISS
  [F:STV]ENDAMT    = [F:STV]AMT + [F:STV]AMTRCP + [F:STV]AMTISS
  # If not standard - include AMTDEV in the final
  If ![L]LSTANDARD
    [F:STV]ENDAMT  += [F:STV]AMTDEV
  Endif

Return

#############################################################
# Record level starting and ending shared routines
#############################################################
$SHARED_REPORT_START

  # Make sure we didn't end up with a start date that is above the end date
  If [L]STRDAT > [M]REFDAT : [L]STRDAT = [M]REFDAT : Endif

  # Get the start of the period we are running for
  Call GETPERSOC(GSOCIETE,GTYPGEN,[L]STRDAT,LEXE,LPER) From CPTSUB

  # Clear LSTANDARD flag (let's us know if a Standard cost product)
  Raz [L]LSTANDARD
  Raz [L]TXFR_RECORD

  # Get the correct record read into TCM for the date the report is running for
  If [L]VLTCHG <> ""
    If LCOUNTER <> 0
      [L]STRDATTIM = [F:ITF]VLTCODDAT(LCOUNTER-1)
      Call GETPITTCM([F:ITF]ITMREF, [F:ITF]STOFCY, [L]STRDATTIM, LTCM, LRET) From STKPITLIB
      If LRET : Return : Endif
    Else
      Call GETTCM([F:ITF]ITMREF,[F:ITF]STOFCY,GBIDC1,GBIDI1) From STKVAL
    Endif
  Elsif [L]STRDAT <> date$
    [L]STRDATTIM = gdatetime$(format$("DZ:YYYY[-]MM[-]DD",[L]STRDAT)+"T00:00:00Z")
    Call GETPITTCM([F:ITF]ITMREF, [F:ITF]STOFCY, [L]STRDATTIM, LTCM, LRET) From STKPITLIB
    If LRET : Return : Endif
  Else
    Call GETTCM([F:ITF]ITMREF,[F:ITF]STOFCY,GBIDC1,GBIDI1) From STKVAL
  Endif

Return

$SHARED_REPORT_HEADER
  # Clear out the current STV record and initialize the basics
  Raz [F:STV]
  [F:STV]PRONUM = num$(adxuid(1))
  [F:STV]ITMREF = [F:ITF]ITMREF
  [F:STV]STOFCY = [F:ITF]STOFCY
Return

$SHARED_REPORT_END
Local Integer J

  # Only write out the record if there are values to report on
  If [F:STV]STA="TRA"  | [F:STV]ENDQTYSTU<> 0 | [F:STV]QTYSTU<> 0 | [F:STV]QTYSTURCP<> 0 | [F:STV]QTYSTUISS<> 0
&  | [F:STV]ENDAMT<> 0 | [F:STV]AMT<> 0       | [F:STV]AMTRCP<> 0 | [F:STV]AMTISS<>0     | [F:STV]AMTDEV<>0
    # Now set all the rest of the data needed since we will write out a record
    [F:STV]PCU        = [F:ITM]STU
    [F:STV]STU        = [F:ITM]STU

    J = find([F:STV]STU,WUOMV(0..WUOMI-1))
    If J <> 0
      [F:STV]STUDEC = WUOMD(J-1)
    Endif
    [F:STV]CSTCOD     = [F:TCM]ISSVLTCOD(ISSMET-1)
    [F:STV]CUR        = WCUR
    # Always set the start and end to the criteria start and end to start with
    [F:STV]REFDAT     = [M:SVAL]REFDAT
    [F:STV]STRDAT     = [M:SVAL]STRDAT
    # If we have a val change, modify the start and end as needed
    If [L]VLTCHG <> "" & [L]VLTBEGTIM <> gdatetime$("0000-00-00T00:00:00Z")
      [L]DATTEMP      = num$(VLTBEGTIM)
      [F:STV]STRDAT   = gdat$(val(mid$([L]DATTEMP,9,2)),val(mid$([L]DATTEMP,6,2)),val(left$([L]DATTEMP,4)))
    Endif
    If [L]VLTCHG <> "" & [L]VLTENDTIM <> gdatetime$("0000-00-00T00:00:00Z")
      [L]DATTEMP      = num$(VLTENDTIM)
      [F:STV]REFDAT   = gdat$(val(mid$([L]DATTEMP,9,2)),val(mid$([L]DATTEMP,6,2)),val(left$([L]DATTEMP,4)))
    Endif
    [F:STV]CREUSR     = GUSER
    [F:STV]CREDAT     = date$
    [F:STV]AMTDEVDAT  = [M:SVAL]STRDAT
    [F:STV]VLTCOD     = [F:TCM]VLTCOD # Use the valuation method stored in TABCOSTMET because we might have a valuation method change
    [F:STV]ACCCOD     = [F:ITM]ACCCOD
    [F:STV]VALMTHDCHG = [L]VLTCHG
    [F:STV]STOCOU     = [L]LSTOCOU    # Set a new STOCOU value so we get a new record in case there are multiple

    [F:STV]ENDAMT     = func REPORT_CURR([F:STV]ENDAMT)
    [F:STV]AMT        = func REPORT_CURR([F:STV]AMT)
    [F:STV]AMTRCP     = func REPORT_CURR([F:STV]AMTRCP)
    [F:STV]AMTISS     = func REPORT_CURR([F:STV]AMTISS)
    [F:STV]AMTDEV     = func REPORT_CURR([F:STV]AMTDEV)
    If [F:STV]QTYSTU <> 0
      [F:STV]CST      = arr([F:STV]AMT/[F:STV]QTYSTU,GRNDVAL)
    Endif
    If [F:STV]ENDQTYSTU <> 0
      [F:STV]ENDCST  = arr([F:STV]ENDAMT/[F:STV]ENDQTYSTU,GRNDVAL)
    Endif

    If !LSUMMARY & !TXFR_RECORD
      Case [F:TCM]ISSVLTCOD(ISSMET-1)
        When 1, 2
          [F:STV]ECCVALMAJ  = [F:ITCPD]ECCVALMAJ
          [F:STV]ECCVALMIN  = [F:ITCPD]ECCVALMIN
        When 6
          [F:STV]LOT        = [F:SLFPD]LOT
          [F:STV]SLO        = [F:SLFPD]SLO
        When 5, 8
          [F:STV]CSTCOU     = [F:STPPD]CSTCOU
          [F:STV]CSTDAT     = [F:STPPD]CSTDAT
          [F:STV]CSTTIM     = [F:STPPD]CSTTIM
      Endcase
    Endif

    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:STV]ITMDES1, "[F:ITM]") From TRTX3

    GPOINT = "BEFWRISTV"
    Gosub ENTREE From EXEFNC
    Write [STV]
    If fstat
      Call FSTA("STV") From GLOCK
    Endif
  Else
    Raz [F:STV]
  Endif

Return

#############################################################
# Calculate Intersite transfer balances
#############################################################
#$LOAD_INTERSITE_SUMMARY
#Local Decimal TRXQTY, TRXAMT
#Local Decimal RECQTY, RECAMT
#
#  TXFR_RECORD = 1
#
#  Gosub SHARED_REPORT_HEADER
#
#  # Get all intersite transfer orders and subtract already received stock
#  Columns [STJ2] (VCRNUM,VCRLIN,ACTQTY,VARVAL,VARVAL2)
#  Filter [SRD]  Where PNHNUM<>""
#  Link [STJ] With [SDH]SDH0 ~= [F:STJ]VCRNUM As [STJLNKD]
#& Where [F:STJ]STOFCY=[F:ITF]STOFCY & [F:STJ]VCRTYP=4 & [F:STJ]ITMREF=[F:ITF]ITMREF & [F:STJ]VCRTYPORI<>36 & [F:STJ]UPDCOD=2
#&     & [F:STJ]NUMVCR<>"" & [F:STJ]ACCDAT<=[M:SVAL]REFDAT & [F:SDH]BETFCY=2 & [F:SDH]BETCPY=1
#  Columns [STJLNKD] ([F:STJ]ACTQTY, [F:STJ]VARVAL, [F:STJ]VARVAL2, [F:STJ]VCRNUM, [F:STJ]VCRLIN)
#  For [STJLNKD]STJ1(3)
#    For [STJLNKD]STJ1(4)
#      Raz [L]TRXQTY, [L]TRXAMT, [L]RECQTY
#      For [STJLNKD]STJ1
#        [L]TRXQTY -= [F:STJ]ACTQTY
#        If ISSMET = 1
#          [L]TRXAMT -= [F:STJ]VARVAL
#        Else
#          [L]TRXAMT -= [F:STJ]VARVAL2
#        Endif
#      Next
#      If [L]TRXQTY<>0
#        For [STJ2]STJ1(4) Where find(VCRTYP,6,13)<>0
#&                         & ITMREF=[F:ITF]ITMREF & OWNER=STOFCY & NUMVCR<>"" & VCRTYPORI=4
#&                         & VCRNUMORI=[F:STJ]VCRNUM & VCRLINORI=[F:STJ]VCRLIN # & ACCDAT<=[M:SVAL]REFDAT
#          Look [SRD]SRD0 = [F:STJ2]VCRNUM;[F:STJ2]VCRLIN
#          If fstat>2
#            For [STJ2]STJ1
#              [L]RECQTY += [F:STJ2]ACTQTY
#            Next
#          Endif
#        Next
#      Endif
#      [F:STV]ENDQTYSTU  += [L]TRXQTY-[L]RECQTY
#      If [L]TRXQTY <> 0
#        [F:STV]ENDAMT     += [L]TRXAMT*(([L]TRXQTY-[L]RECQTY)/[L]TRXQTY)
#      Endif
#    Next
#  Next
#  Columns [STJLNKD]
#  Filter [SRD]
#  Columns [STJ2]
#
#  Columns [STJ2] (ACTQTY,VARVAL,VARVAL2)
#  Columns [SRD] (STOFCY, SRHNUM, SRDLIN)
#  Link [STJ] With [PNH]PNH0 ~= [F:STJ]VCRNUM As [STJLNKP]
#& Where [F:STJ]STOFCY=[F:ITF]STOFCY & [F:STJ]VCRTYP=8 & [F:STJ]ITMREF=[F:ITF]ITMREF & [F:STJ]VCRTYPORI<>36 & [F:STJ]UPDCOD=2
#&     & [F:STJ]NUMVCR<>"" & [F:STJ]ACCDAT<=[M:SVAL]REFDAT & [F:PNH]BETFCY=2 & [F:PNH]BETCPY=1
#  Columns [STJLNKP] ([F:STJ]ACTQTY, [F:STJ]VARVAL, [F:STJ]VCRNUM, [F:STJ]VCRLIN)
#  For [STJLNKP]STJ1(3)
#    For [STJLNKP]STJ1(4)
#      Raz [L]TRXQTY, [L]TRXAMT, [L]RECQTY
#      For [STJLNKP]STJ1
#        [L]TRXQTY -= [F:STJ]ACTQTY
#        If ISSMET = 1
#          [L]TRXAMT -= [F:STJ]VARVAL
#        Else
#          [L]TRXAMT -= [F:STJ]VARVAL2
#        Endif
#      Next
#      If [L]TRXQTY <> 0
#        For [SRD] Where PNHNUM=[F:STJ]VCRNUM & PNDLIN=[F:STJ]VCRLIN
#          For [STJ2]STJ1 Where STOFCY=[F:SRD]STOFCY & VCRTYP=13 & VCRNUM=[F:SRD]SRHNUM & VCRLIN=[F:SRD]SRDLIN
#&                            & ITMREF=[F:ITF]ITMREF & STOFCY=OWNER & NUMVCR<>"" # & ACCDAT<=[M:SVAL]REFDAT
#            [L]RECQTY += [F:STJ2]ACTQTY
#          Next
#        Next
#      Endif
#      [F:STV]ENDQTYSTU  += [L]TRXQTY-[L]RECQTY
#      If [L]TRXQTY <> 0
#        [F:STV]ENDAMT     += [L]TRXAMT*(([L]TRXQTY-[L]RECQTY)/[L]TRXQTY)
#      Endif
#    Next
#  Next
#  Columns [STJ2]
#  Columns [STJLNKP]
#  Columns [SRD]
#
#  If [F:STV]ENDQTYSTU<> 0 | [F:STV]ENDAMT<> 0
#    [L]LSTOCOU = dim([F:ITF]VLTCODDAT)+1
#    [F:STV]STA = "TRA"
#    Gosub SHARED_REPORT_END
#  Else
#    Raz [F:STV]
#  Endif
#
#Return

$LOAD_INTERSITE
Local Integer DETCNT, VCRCNT
Local Decimal TRXQTY, TRXAMT
Local Decimal RECQTY, RECAMT
Local Char    DET_FILTER(255)

  # Update the counters used for STOCOU to keep unique in STV table
  [L]LDETCNT += 10
  [L]LCOUNTER = 0
  [L]TXFR_RECORD = 1

  Columns [SRD] (STOFCY, SRHNUM, SRDLIN)
  Columns [STJ2] (VCRNUM,VCRLIN,ACTQTY,VARVAL)

  # Loop through the data collected earlier and check if received at destination site during report period
  For DETCNT = 1 To maxtab(TXFR_DET_MAJ)

    # Start a new record for each detail level
    Gosub SHARED_REPORT_HEADER

    If LSUMMARY | find([F:TCM]ISSVLTCOD(ISSMET-1),4,5,8)
      DET_FILTER = "1=1"
    Else
      Case [F:TCM]ISSVLTCOD(ISSMET-1)
        When 1, 2 # Standard & Revised standard
          DET_FILTER = "ECCVALMAJ=[L]TXFR_DET_MAJ(DETCNT) & ECCVALMIN=[L]TXFR_DET_MIN(DETCNT)"
        When 6 # Average Lot Cost
          DET_FILTER = "LOT=[L]TXFR_DET_LOT(DETCNT) & SLO=[L]TXFR_DET_SLO(DETCNT)"
      Endcase
    Endif

    # Get the sum of all in-transit intersite
    For VCRCNT = 1 To maxtab(TXFR_DET_VCR)
      Raz TRXQTY, TRXAMT, RECQTY, RECAMT

      If [L]TXFR_DET_QTY(VCRCNT) <> 0 & TXFR_DET_VCR(VCRCNT) = DETCNT

        [L]TRXQTY = TXFR_DET_QTY(VCRCNT)
        [L]TRXAMT = TXFR_DET_AMT(VCRCNT)

        If TXFR_DET_TYP(VCRCNT) = 4
          Filter [SRD]  Where PNHNUM<>""
          For [STJ2]STJ1(4) Where find(VCRTYP,6,13)<>0
&                           & ITMREF=[F:ITF]ITMREF & OWNER=STOFCY & evalue(LPITVALFLG) & ENTCOD<>'' & VCRTYPORI=4
&                           & VCRNUMORI=TXFR_DET_NUM(VCRCNT) & VCRLINORI=TXFR_DET_LIN(VCRCNT) & evalue(DET_FILTER)
            #X3-89541 MIHAL. Remove [F:STJ]NUMVCR<>"" and add [F:STJ]PITVALFLG=2 & [F:STJ]ENTCOD<>''

            Look [SRD]SRD0 = [F:STJ2]VCRNUM;[F:STJ2]VCRLIN
            If fstat>2
              For [STJ2]STJ1
                [L]RECQTY += [F:STJ2]ACTQTY
              Next
            Endif
          Next
          Filter [SRD]
        Else
          For [SRD] Where PNHNUM=TXFR_DET_NUM(VCRCNT) & PNDLIN=TXFR_DET_LIN(VCRCNT)
            For [STJ2]STJ1 Where STOFCY=[F:SRD]STOFCY & VCRTYP=13 & VCRNUM=[F:SRD]SRHNUM & VCRLIN=[F:SRD]SRDLIN
&                              & ITMREF=[F:ITF]ITMREF & STOFCY=OWNER & evalue(LPITVALFLG) & ENTCOD<>'' & evalue(DET_FILTER)
              #X3-89541 MIHAL. Remove [F:STJ]NUMVCR<>"" and add [F:STJ]PITVALFLG=2 & [F:STJ]ENTCOD<>''

              [L]RECQTY += [F:STJ2]ACTQTY
            Next
          Next
        Endif

        # Update the STV record with the final totals for this transaction
        [F:STV]ENDQTYSTU  += [L]TRXQTY-[L]RECQTY
        If [L]TRXQTY <> 0
          [F:STV]ENDAMT     += [L]TRXAMT*(([L]TRXQTY-[L]RECQTY)/[L]TRXQTY)
        Endif

      Endif
    Next

    If ![L]LSUMMARY
      Case [F:TCM]ISSVLTCOD(ISSMET-1)
        When 1, 2 # Standard & Revised standard
          [F:STV]ECCVALMAJ = [L]TXFR_DET_MAJ(DETCNT)
          [F:STV]ECCVALMIN = [L]TXFR_DET_MIN(DETCNT)
        When 6 # Average Lot Cost
          [F:STV]LOT = [L]TXFR_DET_LOT(DETCNT)
          [F:STV]SLO = [L]TXFR_DET_SLO(DETCNT)
      Endcase
    Endif

    # All done with the transactions for this detail level - write out the record
    If [F:STV]ENDQTYSTU<> 0 | [F:STV]ENDAMT<> 0
      [L]LCOUNTER += 1
      [L]LSTOCOU = [L]LDETCNT + [L]LCOUNTER
      [F:STV]STA = "TRA"
      Gosub SHARED_REPORT_END
    Else
      Raz [F:STV]
    Endif

  Next

Return

$CHECK_INTERSITE
Local Integer DETCNT, VCRCNT, LDETFND, LVCRFND

  # Intersite deliveries is VCRTYP 4, Intersite returns is VCRTYP 8
  #X3-89541 MJH. Remove [F:STJ]NUMVCR<>"" and add [F:STJ]PITVALFLG=2 & [F:STJ]ENTCOD<>''
  #X3-109345 MJH. Add [F:STJ] before LPITVALFLG
  If find([F:STJ]VCRTYP,4,8) & [F:STJ]VCRTYPORI<>36 & [F:STJ]UPDCOD=2 & evalue("[F:STJ]"+LPITVALFLG) & [F:STJ]ENTCOD<>''

    If [F:STJ]VCRTYP = 4
      # Check to see if the STOJOU record we are processing is intersite.
      Filter [SDH] Where SDHNUM = [F:STJ]VCRNUM & [F:SDH]BETFCY=2 & [F:SDH]BETCPY=1
      Look [SDH]SDH0 First
      Filter [SDH]
    Else
      # Check to see if the STOJOU record we are processing is intersite.
      Filter [PNH] Where PNHNUM=[F:STJ]VCRNUM & [F:PNH]BETFCY=2 & [F:PNH]BETCPY=1
      Look [PNH]PNH0 First
      Filter [PNH]
    Endif
    If !fstat

      # Record found - this is an intersite transaction
      Raz LDETFND, LVCRFND

      # Check if we already have this detail level in our arrays
      If LSUMMARY | find([F:TCM]ISSVLTCOD(ISSMET-1),4,5,8)
        [L]DETCNT = 1 : LDETFND = 1
        For VCRCNT = 1 To maxtab(TXFR_DET_NUM)
          If TXFR_DET_VCR(VCRCNT)=DETCNT & TXFR_DET_TYP(VCRCNT)=[F:STJ]VCRTYP & TXFR_DET_NUM(VCRCNT)=[F:STJ]VCRNUM & TXFR_DET_LIN(VCRCNT)=[F:STJ]VCRLIN
            LVCRFND = 1 : Break
          Endif
        Next
      Else
        Case [F:TCM]ISSVLTCOD(ISSMET-1)
          When 1, 2 # Standard & Revised standard
            # Check to see if we have this Major/Minor version yet
            For DETCNT = 1 To maxtab(TXFR_DET_MAJ)
              If TXFR_DET_MAJ(DETCNT) = [F:STJ]ECCVALMAJ & TXFR_DET_MIN(DETCNT) = [F:STJ]ECCVALMIN
                # Ok - we hve the version - do we have this document?
                For VCRCNT = 1 To maxtab(TXFR_DET_NUM)
                  If TXFR_DET_VCR(VCRCNT)=DETCNT & TXFR_DET_TYP(VCRCNT)=[F:STJ]VCRTYP & TXFR_DET_NUM(VCRCNT)=[F:STJ]VCRNUM & TXFR_DET_LIN(VCRCNT)=[F:STJ]VCRLIN
                    LVCRFND = 1 : Break
                  Endif
                Next
                LDETFND = 1 : Break : # We have the detail - so use it, just a new document
              Endif
            Next
          When 6 # Average Lot Cost
            # Check to see if we have this Lot/SLO yet
            For DETCNT = 1 To maxtab(TXFR_DET_LOT)

              If TXFR_DET_LOT(DETCNT) = [F:STJ]LOT & TXFR_DET_SLO(DETCNT) = [F:STJ]SLO
                # Ok - we have the lot - do we have this document?
                For VCRCNT = 1 To maxtab(TXFR_DET_NUM)
                  If TXFR_DET_VCR(VCRCNT)=DETCNT & TXFR_DET_TYP(VCRCNT)=[F:STJ]VCRTYP & TXFR_DET_NUM(VCRCNT)=[F:STJ]VCRNUM & TXFR_DET_LIN(VCRCNT)=[F:STJ]VCRLIN
                    LVCRFND = 1 : Break
                  Endif
                Next
                LDETFND = 1 : Break : # We have the detail - so use it, just a new document
              Endif
            Next
        Endcase
      Endif

      If !LVCRFND
        # We did not find this document - so create new indexes for it
        If !LDETFND : DETCNT = maxtab(TXFR_DET_MAJ)+1 : Endif
        VCRCNT = maxtab(TXFR_DET_VCR)+1

        # Product specific
        TXFR_DET_MAJ(DETCNT) = [F:STJ]ECCVALMAJ
        TXFR_DET_MIN(DETCNT) = [F:STJ]ECCVALMIN
        TXFR_DET_LOT(DETCNT) = [F:STJ]LOT
        TXFR_DET_SLO(DETCNT) = [F:STJ]SLO

        # Document specific
        TXFR_DET_VCR(VCRCNT) = DETCNT # This one syncs the two arrays, you can't declare open ended multi-dimension
        TXFR_DET_TYP(VCRCNT) = [F:STJ]VCRTYP
        TXFR_DET_NUM(VCRCNT) = [F:STJ]VCRNUM
        TXFR_DET_LIN(VCRCNT) = [F:STJ]VCRLIN
        If [L]DET_FIFO
          TXFR_DET_QTY(VCRCNT)-= [L]FIFO_QTY
          TXFR_DET_AMT(VCRCNT)-= [L]FIFO_CST
        Else
          TXFR_DET_QTY(VCRCNT)-= [F:STJ]ACTQTY
          TXFR_DET_AMT(VCRCNT)-= [F:STJ]VARVAL
        Endif
      Else
        # This is an additional record for this document, so just add to old quantities
        If [L]DET_FIFO
          TXFR_DET_QTY(VCRCNT)-= [L]FIFO_QTY
          TXFR_DET_AMT(VCRCNT)-= [L]FIFO_CST
        Else
          TXFR_DET_QTY(VCRCNT)-= [F:STJ]ACTQTY
          TXFR_DET_AMT(VCRCNT)-= [F:STJ]VARVAL
        Endif
      Endif
    Endif
  Endif

Return

Funprog REPORT_CURR(CURRTEMP)
Value Decimal CURRTEMP
Local Integer LRET

  If [M:SVAL]RPTCUR = [V]CST_AYES
    Call CONVERT(GLOCALDEV,GSYSCUR,GLOCALDEV,1,datesyst,CURRTEMP,CURRTEMP,LRET) From TRTDEV
    CURRTEMP = arr(CURRTEMP,10^-[F:TCU]DECNBR)
  Else
    CURRTEMP = arr(CURRTEMP,GRNDVAL)
  Endif
End CURRTEMP

