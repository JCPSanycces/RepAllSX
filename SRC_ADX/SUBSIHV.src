#<AdxTL>@(#)0.0.0.0 $Revision$
# SUBSIHV
#  - Gestion fenêtre ISIHS : saisie champs analytiques des elts facture
#    click droit "Analytique" sur masque "Valorisation" de la facture
#  - Traitements liées à la gestion analytique des elts facture
#    appelés dans les actions CREATION / MODIF / ANNULE de la gestion des factures
######################################################################################
# Issue 111367 - 20160111 by LD : Imputation comptable élément de facturation

$ACTION
#--- Actions liés au type fenetres de saisie
Case ACTION
 When "OUVRE"       : Gosub OUV_SAISIHS
 When "DEBUT"       : Gosub DEB_SAISIHS
 When "ABA"         : Gosub ABA_SAISIHS
 When "APRES_MODIF" : Gosub APRES_MODIF #REP="M" # Issue X3-51824 - 2017-08-04 by CPO : Analytical sections on footer elements for sales documents
 When "ABA"         : Gosub ABA_SAISIHS
 When "OK"          : Gosub OK_SAISIHS
 When "FIN"         : Gosub FIN_SAISIHS
Endcase
Return
#-------------------------------------------------------------------------------------
# Issue X3-51824 - 2017-08-04 by CPO : Analytical sections on footer elements for sales documents
$APRES_MODIF

If    dim([M:SIHV]GREPFLG  )>0 and [M:SIHV]GREPFLG<>""
  #--no update mode : unstable situation for the original document
Elsif dim([M:SIHV]NOUPDCCEFLG)>0 and [M:SIHV]NOUPDCCEFLG=[V]CST_AYES
  #--no update mode : original document was validated(deliveries) or posted(invoices)
Else
  REP="M"
Endif

Return
#-------------------------------------------------------------------------------------
$OUV_SAISIHS
Local Integer NOLIG    :    NOLIG  = val(PARAM(1))   : # nolign-1
Local Integer  SAVNOLIGN
Local Char     WNOMDSP(20)
SAVNOLIGN=nolign

Return

#-------------------------------------------------------------------------------------
$DEB_SAISIHS

#----- Chargement des valeurs et affichage (foreground) -----#
[M]SFINUM=[M:SIHV]XFNUM(NOLIG)
[M]DSP=[M:SIHV]DSP(NOLIG)
For I=1 To GNBDIE
    [M]DIE(I-1)=GDIE(I)
    [M]NAMDIE(I-1)=GCOLDIE(I)
    If evalue("dim([M:SIHV]SFICCE"+num$(I)+")")>0
       [M]CCE(I-1)= evalue("[M:SIHV]SFICCE"+num$(I)+"(NOLIG)")
    Endif
Next I
[M]NBAXE=GNBDIE
For I=1 To max(GNBCOA,2)
    If evalue("dim([M:SIHV]SFIACC"+num$(I)+")")>0
       [M]ACC(I-1)= evalue("[M:SIHV]SFIACC"+num$(I)+"(NOLIG)")
    Endif
Next I
If [M]DSP<>"" : Raz [M]CCE : Grizo [M]CCE
   Else         Actzo [M]CCE
Endif

# 105887 : Saisie sections analytiques elt fac sur facture validée
If clalev([M:SIH1])<>0 :#-- 106913/105887 complément car plantage si accès depuis les autres documents
  If [M:SIH1]INVSTA=3  Diszo [M:SIHS]1-99  Endif
Endif
# 105887

# Issue X3-51824 - 2017-08-04 by CPO : Analytical sections on footer elements for sales documents
If    dim([M:SIHV]GREPFLG  )>0 and [M:SIHV]GREPFLG<>""
  Diszo [M:SIHS]1-99
Elsif dim([M:SIHV]NOUPDCCEFLG)>0 and [M:SIHV]NOUPDCCEFLG=[V]CST_AYES
  Diszo [M:SIHS]1-99
Endif
# End issue X3-51824



Affzo
Return

#-------------------------------------------------------------------------------------
$ABA_SAISIHS
[M]SFINUM=[M:SIHV]XFNUM(NOLIG)
[M]DSP=[M:SIHV]DSP(NOLIG)
For I=1 To GNBDIE
    [M]DIE(I-1)=GDIE(I)
    [M]NAMDIE(I-1)=GCOLDIE(I)
    If evalue("dim([M:SIHV]SFICCE"+num$(I)+")")>0
       [M]CCE(I-1)= evalue("[M:SIHV]SFICCE"+num$(I)+"(NOLIG)")
    Endif
Next I
[M]NBAXE=GNBDIE
For I=1 To max(GNBCOA,2)
    If evalue("dim([M:SIHV]SFIACC"+num$(I)+")")>0
       [M]ACC(I-1)= evalue("[M:SIHV]SFIACC"+num$(I)+"(NOLIG)")
    Endif
Next I
If [M]DSP<>"" : Raz [M]CCE : Grizo [M]CCE
   Else         Actzo [M]CCE
Endif
#GNBAFF=99
#REP = ""
Affzo
Return

#-------------------------------------------------------------------------------------
$OK_SAISIHS
# Si l'on est en création, modif ou duppli, la maj se fera en $CREATION ou $MODIF
If find (GREP, "C","M","D") Return Endif

# Issue X3-51824 - 2017-08-04 by CPO : Analytical sections on footer elements for sales documents
If    dim([M:SIHV]GREPFLG  )>0 and [M:SIHV]GREPFLG<>""
  #--no update mode : unstable situation for the original document
  Return
Elsif dim([M:SIHV]NOUPDCCEFLG)>0 and [M:SIHV]NOUPDCCEFLG=[V]CST_AYES
  #--no update mode : original document was validated(deliveries) or posted(invoices)
  Return
Else
  #--we continue with the updating
Endif

Call DEBTRANS From GLOCK
If clalev([F:CAL])=0 : Local File CPTANALIN [CAL] : Endif

GOK=1
Trbegin [CAL]
Delete [CAL] Where ABRFIC="SVF" & VCRTYP=[M:SIHV]VCRTYP & VCRNUM=[M:SIHV]NUM & VCRSEQ=[M]SFINUM

Raz [F:CAL]
[F:CAL]ABRFIC="SVF"
[F:CAL]VCRTYP=[M:SIHV]VCRTYP
[F:CAL]VCRNUM=[M:SIHV]NUM
[F:CAL]ANALIG=1
[F:CAL]VCRSEQ=[M]SFINUM

If dim([M:SIHV]DSP)>0 : [M:SIHV]DSP(NOLIG)=[M]DSP : Endif
For I=1 To GNBDIE
    If evalue("dim([M:SIHV]SFICCE"+num$(I)+"(NOLIG))")>0
       Assign ("[M:SIHV]SFICCE"+num$(I)+"(NOLIG)") With [M]CCE(I-1)
    Endif
Next I

For I=1 To max(GNBCOA,2)
    If evalue("dim([M:SIHV]SFIACC"+num$(I)+"(NOLIG))")>0
       Assign ("[M:SIHV]SFIACC"+num$(I)+"(NOLIG)") With [M]ACC(I-1)
    Endif
Next I

#----- Ecriture des comptes et sections des éléments de facturation -----#
If dim([M:SIHV]DSP)>0
  WNOMDSP="[M:SIHV]DSP"
Else
  WNOMDSP=""
Endif
Call ENREG_ACCCCE(NOLIG,"[M:SIHV]SFIACC",WNOMDSP,"[M:SIHV]SFICCE","SVF",
&                 [M:SIHV]VCRTYP,[M:SIHV]NUM,0,[M]SFINUM,"","C") From TRTX3CPT
If GOK<1  Return : Endif
#-----
Commit

Affzo [M:SIHV]

#mkstat=4
FIN=1
Return

#-------------------------------------------------------------------------------------
$FIN_SAISIHS

nolign=SAVNOLIGN

Return

######################################################################################
#  - Traitements liées à la gestion de la compta ( pour les elts de facturation )
######################################################################################

#-------------------------------------------------------------------------------------
# Suppression des enr. CAL
# - appelé dans ANNULE de SUBSIHA
#-------------------------------------------------------------------------------------
$ANU_DIE_FOOT
Delete [CAL] Where ABRFIC="SVF" & VCRTYP=[M:SIHV]VCRTYP & VCRNUM=[M:SIHV]NUM & VCRSEQ<>0
Return

#-------------------------------------------------------------------------------------
# Chargement du masque SIHV avec les enr. CAL
# - appelé dans LIENS de SUBSxHA
#-------------------------------------------------------------------------------------
$LIENS_DIE_FOOT
Local Integer ISJ0, ISJ1, ISJ2
If clalev([F:CAL])=0 : Local File CPTANALIN [CAL] : Endif
#-----

For ISJ0=0 To dim([M:SIHV]XFNUM)-1
    If [M:SIHV]XFNUM(ISJ0)=0 : Break : Endif
    Call CHARG_ACCCCE (ISJ0,"[M:SIHV]SFIACC","[M:SIHV]DSP","[M:SIHV]SFICCE","SVF",[M:SIHV]VCRTYP,[M:SIHV]NUM,0,[M:SIHV]XFNUM(ISJ0),"")
&                     From TRTX3CPT
Next ISJ0

Diszo [M:SIHV]15    : # Bug 72024

Return

#-------------------------------------------------------------------------------------
# Creation des enr.CAL
# - appelé dans CREATION et MODIF de SUBSxHA
# - appelé dans FIN_FACTURE de FUNAUTINVD FUNAUTINVO
#-------------------------------------------------------------------------------------
$CREMOD_DIE_FOOT
Local Integer ISJ0, ISJ1, ISJ2
Local Integer SAVNOLIGN
Local Char    WSECTION (50)
Local Char    TPLAN  (GLONCOA)(1..10)
Local Char    TCOMPTE(GLONGAC)(1..10)
Local Char    WNOMDSP(20)

Local Integer WSVGDSPLIN, WSVGVATRUL
Local Integer WSVGNOLIGN : WSVGNOLIGN = nolign # Issue X3-44998 - 2017-07-27 by CPO : Duplicated sale documents: analytical dimension not controlled (idem X3SUIVI93839)
Local Integer WTMPOK                           # Issue X3-51824 - 2017-08-04 by CPO : Analytical sections on footer elements for sales documents
Local Integer NE                               # Issue X3-51824 - 2017-08-04 by CPO : Analytical sections on footer elements for sales documents
Local Char    SAXECTRL(GLONCCE)                # Issue X3-51824 - 2017-08-04 by CPO : Analytical sections on footer elements for sales documents
Local Date    WTMPDATDOC

If clalev([F:CAL])=0 : Local File CPTANALIN [CAL] : Endif
Gosub OPEN_SFI From TRTX3CPY: #If clalev([F:SFI])=0 : Local File SFOOTINV   [SFI] : Endif

# X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/08/17)
# Code activité PJM actif et il existe un axe géré à l'affaire
# Active activity code PJM and a dimension type is managed by project
Local Integer WPJMDIENUM        : # N° de l'axe géré à l'affaire/Number of dimension type managed by project
Local Char    WCCEZON           : # Nom du champ de la section à initialiser/Dimension field name
If func ASYRFNC.ACTIV("PJM") & GPJMDIE <> ""
    # Après la modification du code affaire entête et la réinitialisation de la section sur l'entête
    # Il faut réinitialiser la section sur les élts de facturation
    # After the header project code modification and the header dimension initialization
    # It is necessary to reinitialize the dimension for the invoicing elements

    # Récupérer le n° de l'axe/Search for the dimension type number
    WPJMDIENUM=find(GPJMDIE,GDIE(1..GNBDIE))
Endif
# X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/08/17)

#-----
For ISJ0=0 To dim([M:SIHV]XFNUM)-1
    If [M:SIHV]XFNUM(ISJ0)=0 : Break : Endif
    Look [CAL]CAL0="SVF";[M:SIHV]VCRTYP;[M:SIHV]NUM;0;[M:SIHV]XFNUM(ISJ0);"";1
    If !fstat
       # L'enr concernant les sections analytiques existe :
       # --> On charge les comptes  de [F:CAL] vers [M:SIHV]SFIACC
       # --> On charge les sections de [F:CAL] vers [M:SIHV]SFICCE
       Call CHARG_ACCCCE (ISJ0,"[M:SIHV]SFIACC","[M:SIHV]DSP","[M:SIHV]SFICCE","SVF",[M:SIHV]VCRTYP,[M:SIHV]NUM,0,[M:SIHV]XFNUM(ISJ0),"") From TRTX3CPT
       # Issue 111367
       # Tax code has changed : It is necessary to play tax determination
       If [M:SIHV]VCRTYP=4
          If dim([M:SIHV]INIACCFLG)>0 & [M:SIHV]INIACCFLG(ISJ0)=2
            # Alimentation des comptes par évaluation de la pièce automatique
            # Il faut être positionné sur l'élément de facturation pour l'évaluation des comptes
            # (SIHI3 utilise SFOOTINV et [SFI] n'est pas lu par Subprog COMPTE de CPTCOD)
            If [F:SFI]SFINUM<>[M:SIHV]XFNUM(ISJ0)
                Read [SFI]SFI0=[M:SIHV]XFNUM(ISJ0)
                If fstat Raz [F:SFI] Endif
            Endif
            #  Pour forcer la condition de la pièce auto et charger le compte et la nature -----#
            WSVGDSPLIN=[F:SFI]DSPLIN : WSVGVATRUL=[F:SFI]VATRUL
            [F:SFI]DSPLIN=1 : [F:SFI]VATRUL=0
            Call INIT_ACC(WTRANSAC, "SIHV", ISJ0, TPLAN, TCOMPTE) From TRTVENFAC
            For I=1 To max(GNBCOA,2)
              Assign("[M:SIHV]SFIACC"+num$(I)+"(ISJ0)") With TCOMPTE(I)
            Next I
            [F:SFI]DSPLIN=WSVGDSPLIN : [F:SFI]VATRUL=WSVGVATRUL
          Endif
       Endif
       # End 111367

       # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/04/17)
       # Le n° de l'axe géré à l'affaire est alimenté/The dimension type number is ok
       If WPJMDIENUM<>0 & WPJMDIENUM<=GNBDIE
          # Il faut réinitialiser cet axe/It is necessary to initialize the dimension
          If [M:SIHV]DSP(ISJ0)=""
              WCCEZON="[M:SIHV]SFICCE"+num$(WPJMDIENUM)+"(ISJ0)"
              Assign WCCEZON With ""
              # Si CCE non init (pas d'origine ou origine sans CCE),
              #  on initialise le CCE
              Raz WSECTION
              SAVNOLIGN=nolign : nolign=ISJ0+1
              Local Char CODSEC(GLONCDE)
              Case [M:SIHV]VCRTYP
                When 1 : CODSEC="SQV"
                When 2 : CODSEC="SDV"
                When 4 : CODSEC="SIV"
                When 20: CODSEC="SOV"
              Endcase
              Call INIT_CCE (WSECTION,WPJMDIENUM,[L]CODSEC,"",0) From TRTX3CPT
              nolign=SAVNOLIGN
              Assign WCCEZON With WSECTION
              #Infbox "WCCEZON="-WCCEZON-evalue(WCCEZON)
           Endif
       Endif
       # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/04/17)
    Else
       # L'enr concernant les sections analytiques n'existe pas :
       # --> On initialise les comptes  [M:SIHV]SFIACC
       # --> On initialise les sections [M:SIHV]SFICCE
       # Alimentation des comptes par évaluation de la pièce automatique
       # Il faut être positionné sur l'élément de facturation pour l'évaluation des comptes
       # (SIHI3 utilise SFOOTINV et [SFI] n'est pas lu par Subprog COMPTE de CPTCOD)
       If [F:SFI]SFINUM<>[M:SIHV]XFNUM(ISJ0)
           Read [SFI]SFI0=[M:SIHV]XFNUM(ISJ0)
           If fstat Raz [F:SFI] Endif
       Endif

       # ACA : on ne charge les comptes que pour les factures
       If [M:SIHV]VCRTYP=4
          #  Pour forcer la condition de la pièce auto et charger le compte et la nature -----#
          WSVGDSPLIN=[F:SFI]DSPLIN : WSVGVATRUL=[F:SFI]VATRUL
          [F:SFI]DSPLIN=1 : [F:SFI]VATRUL=0
          Call INIT_ACC(WTRANSAC, "SIHV", ISJ0, TPLAN, TCOMPTE) From TRTVENFAC
          For I=1 To max(GNBCOA,2)
            Assign("[M:SIHV]SFIACC"+num$(I)+"(ISJ0)") With TCOMPTE(I)
          Next I
          [F:SFI]DSPLIN=WSVGDSPLIN : [F:SFI]VATRUL=WSVGVATRUL
       Endif

       #ACA - On initialise les sections si pas encore renseigné, avec le bon code section par défaut
       # ACA (2010-03-04) Bug 63011 : Repartition analytique
       If [M:SIHV]DSP(ISJ0)=""

         # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/04/17)
         # Le n° de l'axe géré à l'affaire est alimenté/The dimension type number is ok
         # Il faut réinitialiser cet axe/It is necessary to initialize the dimension
         If WPJMDIENUM<>0 & WPJMDIENUM<=GNBDIE
             WCCEZON="[M:SIHV]SFICCE"+num$(WPJMDIENUM)+"(ISJ0)"
             Assign WCCEZON With ""
         Endif
         # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/04/17)

         For ISJ1=1 To GNBDIE
             # Si CCE non init (pas d'origine ou origine sans CCE),
             #  on initialise le CCE
             If evalue ("[M:SIHV]SFICCE"+num$(ISJ1)+"(ISJ0)") = ""
                 Raz WSECTION
                 SAVNOLIGN=nolign : nolign=ISJ0+1
                 Local Char CODSEC(3)
                 Case [M:SIHV]VCRTYP
                  When 1 : CODSEC="SQV"
                  When 2 : CODSEC="SDV"
                  When 4 : CODSEC="SIV"
                  When 20: CODSEC="SOV"
                 Endcase
                 Call INIT_CCE (WSECTION,ISJ1,[L]CODSEC,"",0) From TRTX3CPT
                 nolign=SAVNOLIGN
                 Assign("[M:SIHV]SFICCE"+num$(ISJ1)+"(ISJ0)") With WSECTION
             Endif
         Next ISJ1
       Endif
    Endif
Next ISJ0

#-----
Delete [CAL] Where ABRFIC="SVF" & VCRTYP=[M:SIHV]VCRTYP & VCRNUM=[M:SIHV]NUM & VCRSEQ<>0

#-----
Raz [F:CAL]
[F:CAL]ABRFIC="SVF"
[F:CAL]VCRTYP=[M:SIHV]VCRTYP
[F:CAL]VCRNUM=[M:SIHV]NUM
[F:CAL]ANALIG=1

For IJS0=0 To dim([M:SIHV]XFNUM)-1
  If [M:SIHV]XFNUM(IJS0)=0 : Break : Endif
  #----- Ecriture des comptes et sections des éléments de facturation -----#
  If dim([M:SIHV]DSP)>0
    WNOMDSP="[M:SIHV]DSP"
  Else
    WNOMDSP=""
  Endif

  #--------------------------------------
  # Issue X3-51824 - 2017-08-04 by CPO : Analytical sections on footer elements for sales documents
  #--will be fixed by another US for Update by adding an invoice elt/Create/Duplicate (because of the way that analytical dimensions are set by calling of INISEC as there is no CPTANALIN record)
  If (dim([M:SIHV]DSP)<=0 or (dim([M:SIHV]DSP)>0 and [M:SIHV]DSP(IJS0)=""))
    # Issue X3-38251 - 2017-11-10 by CPO : [110949] FUNAUTFAE - calcul date extourne
    #--got non existing field error during FUNAUTFAE
    Local Char SAV_DEF_MSK(255) : SAV_DEF_MSK=dbgstr(1)
    Default Mask [M:SIHV] #--as CTRL_CCE uses default [M] to access CCE properties...
    # End issue X3-38251
    For NE = 1 To 20
      If evalue("type([M:SIHV]SFICCE" + num$(NE) + "(IJS0)) >= 0") Then
        SAXECTRL = evalue("[M:SIHV]SFICCE" + num$(NE) + "(IJS0)")
        If SAXECTRL <> "" Then
          nolign = IJS0 + 1
          #--for the ENAFLG flag
          Call CONTSEL("CCE","!",SAXECTRL,num$(GDIE(NE)),mkstat) From CONTOBJ
          If !mkstat
            Case [M:SIHV]VCRTYP
              When 1 : WTMPDATDOC = [M:SQH0]QUODAT
              When 2 : WTMPDATDOC = [M:SDH1]DLVDAT
              When 4 : WTMPDATDOC = [M:SIH0]INVDAT
              When 20: WTMPDATDOC = [M:SOH0]ORDDAT
            Endcase
            # Issue X3-38251 - 2017-11-10 by CPO : [110949] FUNAUTFAE - calcul date extourne
            #Call CTRL_CCE(SAXECTRL, NE, "", GFINRSP, WTMPDATDOC) From TRTX3CPT
            Call CTRL_CCE_NOMCCE(SAXECTRL, NE, "", GFINRSP, WTMPDATDOC,"[M:SIHV]SFICCE") From TRTX3CPT
            # End issue X3-38251
          Endif
          If mkstat Then
            GMESSAGE = mess(523,197,1)-num$([M:SIHV]XFNUM(IJS0))-"("+[M:SIHV]XFSHO(IJS0)+")"-":"-GMESSAGE
            If GTRACE <> ""
               Call ECR_TRACE(GMESSAGE,2) From GESECRAN
               Raz GMESSAGE : mkstat=0
            Else
                GERR=2 : WTMPOK = 2
                Call AVERTIR(GMESSAGE,WTMPOK) From GESECRAN
                Raz GMESSAGE : Raz mkstat
                #--if user wants to abort, we give him the opportunity...
                If WTMPOK <> 2 : GOK=0 : Break : Endif
                #--only one message is sent if no log opened
                Break
            Endif
          Endif
        Endif
      Endif
    Next NE
    Default Mask SAV_DEF_MSK # Issue X3-38251 - 2017-11-10 by CPO : [110949] FUNAUTFAE - calcul date extourne
    If GOK < 1 Then
      Break
    Endif
  Endif
  # End issue X3-51824
  #--------------------------------------
  Call ENREG_ACCCCE(IJS0,"[M:SIHV]SFIACC",WNOMDSP,"[M:SIHV]SFICCE","SVF",
&                   [M:SIHV]VCRTYP,[M:SIHV]NUM,0,[M:SIHV]XFNUM(IJS0),"","C") From TRTX3CPT
  If GOK<1  Break : Endif
  #-----
Next IJS0

nolign = WSVGNOLIGN # Issue X3-44998 - 2017-07-27 by CPO : Duplicated sale documents: analytical dimension not controlled (idem X3SUIVI93839)

Return
######################################################################################

$AFF_TITCOL
If !GIMPORT & dim([M:SIHV]SFICCE1)>0 & dim([M]NBFOOT)>0
  Local Char BASPAG(10)
  BASPAG="NBFOOT" : Gosub TIT_COL From W1SIHV
  #----- Pour forcer utilisation des formats évalués si tableau vide -----#
  If [M:SIHV]NBFOOT=0 : [M:SIHV]NBFOOT=1 : Affzo [SIHV]1-99 : [M:SIHV]NBFOOT=0 : Endif
Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran SIHV) 20/07/2006 10:17:40 (JL)
######################################################################################
Subprog IB_NBFOOT
# ACA (2009-07-15)
If find(GFONCTION, "GESSIH", "GESSOH", "GESSQH", "GESSDH")=0
  Raz GBOUT1
Endif

# ACA (2009-10-29) Bug 59340 : Accès aux sections uniquement lorsque le document est créé
Local Integer SCREFLG
Case GFONCTION
 When "GESSIH"       : SCREFLG = sum([M:SIH4]CREFLG)
 When "GESSOH"       : SCREFLG = sum([M:SOH4]CREFLG)
 When "GESSQH"       : SCREFLG = sum([M:SQH2]CREFLG)
 When "GESSDH"       : SCREFLG = sum([M:SDH1]CREFLG)
 When Default
    If dim([M]CREFLG)>0
      SCREFLG = sum([M]CREFLG)
    Else
      SCREFLG = 1
    Endif
Endcase
If GREP="C" or SCREFLG=0
  Raz GBOUT1
Endif
End

######################################################################################

Subprog AM_DSP(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   If dim([M]NBAXE)>0 : Raz [M]CCE : Affzo [M]CCE : Grizo [M]CCE : Endif
Else
   If dim([M]NBAXE)>0 : Actzo [M]CCE : Endif
Endif
End

######################################################################################

#gbn-81683
Subprog AV_BASDEP(VALEUR)
Variable Decimal VALEUR
 Call DISPLAY_BASDEP From TRTVENFACDEP
End


######################################################################################

######################################################################################
## Section automatically added (screen SIHV) 09/18/2018 13:59:26 (LUCUE)
######################################################################################
#X3-107954 (LCC-19/09/18) Add an icon on sales invoices Valuation tab
Subprog CL_VALUATION(VALEUR)
Variable Char    VALEUR()
# It is not neccesary any action. The action is done in AP_NBLIG with a status = 20 at the
# moment of the click on this icon field
End


######################################################################################

