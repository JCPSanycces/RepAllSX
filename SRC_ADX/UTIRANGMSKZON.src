#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# X3PLAT-2092: Fill rank RANG on AMSKZON from blocks of screen AMSK
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Fill rank RANG on AMSKZON") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub RANGMSK
End

#-------------------#
$RANGMSK

Local Integer OK,IBLC,WCOUNT,WCOUNTTOT

Local File =DOSSIER+".AMSKZON" [AMZ__]
Local File =DOSSIER+".AMSK" [AMK__]

If dim([F:AMZ__]RANG)>0
Trbegin [AMZ__]
For [AMK__]CODMSK Where left$(CODMSK,1)<>"W"
 WCOUNT=0
 For IBLC=0 To [AMK__]NBBLOC-1
  Update [AMZ__] Where  [F:AMZ__]CODMSK=[F:AMK__]CODMSK & [F:AMZ__]RANG=0 & [F:AMZ__]NUMBLOC=IBLC+1
&  With [F:AMZ__]RANG=[F:AMK__]RANG(IBLC)
  If fstat
   Call ERREUR("AMSKZON"-[F:AMK__]CODMSK-"NUMBLOC="+num$(IBLC+1)-"RANG->"+num$([F:AMK__]RANG(IBLC)),2) From DOSDIC
  Else
   WCOUNT+=[S]adxuprec
  Endif
 Next IBLC
 WCOUNTTOT+=WCOUNT
Next AM__
Commit
Endif

Call ECR_TRACE(mess(192,124,1)-":"-num$(WCOUNTTOT),0) From GESECRAN

Close Local File [AMK__],[AMZ__]
Return

