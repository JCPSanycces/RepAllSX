#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACOPDOZ","ACOPDOZ",3,"") From GTRAITE
End

###############################################################
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "EXEC"       : Gosub EXEC
Endcase
Return

###################################################################
$INIT
Local Mask ACOPDOZ [COP]
Raz [M:COP]
[M:COP]ALLLAN  = 1
[M:COP]ALLCOD  = 1
[M:COP]LAN     = PARAM(1)
[M:COP]COD     = PARAM(2)
[M:COP]HLPZON  = max(1,val(PARAM(3)))
If [M:COP]LAN="" : [M:COP]LAN = GLANGUE : Endif
[M:COP]DOSORG  = nomap
Return

$EXEC
Call COPOBJ([M:COP]DOSORG,[M:COP]DOSDES,"ADZ",[M:COP]LAN,[M:COP]COD,num$([M:COP]HLPZON),"") From ACOPIE
Return

######################################################################################
Subprog C_ALLLAN(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]LAN = "" : Affzo LAN : Grizo LAN
Else
 Actzo LAN
Endif
End

Subprog AS_LAN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = GLANGUE
Endif
End

Subprog C_ALLCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]COD = "" : Affzo COD : Grizo COD
Else
 Actzo COD
Endif
End

Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
Call D_DOSORG(VALEUR) From ACOPIE
End

Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AS_DOSORG(VALEUR) From ACOPIE
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
Call AS_DOSDES(VALEUR) From ACOPIE
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call C_DOSDES(VALEUR) From ACOPIE
End
