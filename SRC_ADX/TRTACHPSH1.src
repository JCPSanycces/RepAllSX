#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################################
# TRTACHPSH1           Traitements liés aux DA                Module Achat #
# ------------------------------------------------------------------------ #
# Sous-programmes :                                                        #
# Gosub                                                                    #
#   - MGT_PSH    : Gestion auto des DA à partir du plan de travail         #
# Call                                                                     #
#   - MAJ_PSH    : Gestion auto des DA à partir du plan de travail         #
# ------------------------------------------------------------------------ #
# ACTIONS modélisation WEB (Affichage divers GACTION)                      #
#   - DIVPSHITM  : Après modif de référence article dans une DA uniquement #
#                                                                          #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                     #
#   - SAIPECB3   : Prise en compte des besoins d'achat                     #
#                                                                          #
# ACTIONS modélisation WEB (Traitement divers)                             #
#   - TRTCLEPSH  : Bouton Solde d'une DA                                   #
#   - TRTPSHGEN  : Génération commande depuis les DA                       #
############################################################################


$ACTION
Case ACTION
 When "TRT_DIV"
  Case TRAIT
   When "DIVPSHITM"  : Gosub DIVPSHITM
  Endcase
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
   When "SAIPECB3"    : Gosub OUV_SAIPECB3
  Endcase
 When "TITRE"
  #-------------------------------------------#
  # Titre juste avant ouverture de la fenêtre #
  #-------------------------------------------#
  Case GACTION
   When "SAIPECB3"    : TIT=mess(42,195,1)
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "SAIPECB3"    : Gosub DEB_SAIPECB3
  Endcase
 When "OK"
  #--------------------------------#
  # Après l'exécution du bouton OK #
  #--------------------------------#
  Case GACTION
   When "SAIPECB3"    : Gosub OK_SAIPECB3
  Endcase
 When "ABA"
  #-------------------------------------#
  # Après l'exécution du bouton ABANDON #
  #-------------------------------------#
  Case GACTION
   When "SAIPECB3"    : Gosub ABA_SAIPECB3
  Endcase
 When "APRES_MODIF"
  #------------------------------------#
  # Après chaque modification de champ #
  #------------------------------------#
  Case GACTION
   When "SAIPECB3"    : REP="M"
  Endcase
 When "FINSAI"
  #------------------------------------------#
  # Avant de revenir à la fenêtre précédente #
  #------------------------------------------#
  Case GACTION
   When "SAIPECB3"    : Gosub FINSAI_SAIPECB3
  Endcase
 When Default
Endcase
Return


#######################################################################
# Actions sur la saisie de fenêtre (GSAISIE)                HN 12/00  #
# ------------------------------------------------------------------- #
# SAIPECB3   : Prise en compte des besoins d'achat                    #
# FOURN    : Numéro du fournisseur                                    #
# REFART   : Référence de l'article                                   #
# ACHETEUR : Code de l'acheteur                                       #
# QTEAOF   : Quantité de l'appel d'offre sélectionné en UA            #
# UA       : Unité d'achat de la commande et de la qté ci-dessus      #
# CODE     : Code traitement  1 = Prise en compte des "POS"           #
#                                 sans filtre acheteur                #
#                             2 = Prise en compte des "POP"           #
#                             3 = Prise en compte des "POS" & "POP"   #
#                             4 = Prise en compte des "SCF"           #
#                             5 = Prise en compte des "POS" & "POP"   #
#                                 générés par la production           #
#                             6 = Prise en compte des DA pour les     #
#                                 articles non gérés en stock         #
#                             7 = Prise en compte des "TRS" & "TRP"   #
#                                 générés par les besoins inter-sites #
#                                 sans filtre acheteur                #
#                             8 = idem codes 2 + 7                    #
# RETQTY   : Quantité totale prise en compte en US                    #
# RETDAT   : Plus petite date de fin des besoins pris en compte       #
# WRETOUR  : Code retour = 0 Pas de besoin                            #
# WENDDAT  : Date de fin maxi pour la prise en compte des besoins     #
# RCPFCY   : Site de réception (Si la zone est renseignée alors les   #
#            besoins sont filtrés sur ce site)                        #
#######################################################################
#   PARAM(1) = BPSNUM : Numéro du fournisseur                         #
#   PARAM(2) = ITMREF : Référence de l'article                        #
#   PARAM(3) = BUY    : Code de l'acheteur                            #
#   PARAM(4) = QTEAOF : Quantité en UA de l'appel d'offre sélectionné #
#   PARAM(5) = UA     : Unité d'achat                                 #
#   PARAM(6) = TRAIT  : Code traitement (idem ci-dessus)              #
#   PARAM(7) = CODFNC : Code fonction ("PSH", "POH", "POD")           #
#######################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_SAIPECB3
Local Char     FOURN   (GLONBPS) : FOURN=PARAM(1)
Local Char     REFART  (GLONITM) : REFART=PARAM(2)
Local Char     ACHETEUR(GLONAUS) : ACHETEUR=PARAM(3)
Local Decimal  QTEAOF            : QTEAOF=val(PARAM(4))
Local Char     UA(GLONUOM)       : UA=PARAM(5)
Local Integer  CODE              : CODE=val(PARAM(6))
Local Char     FONCTION(3)       : FONCTION=PARAM(7)
#----- VARIABLES LOCALES -----#
Local    Integer  OK, WRETOUR, SNOLIGN, WNBLIG
Local    Shortint NOL, I, WSAI : NOL=nolign-1
Local    Decimal  GROPRI, DISCRGVAL(0..8), NETPRI
Local    Char     CRITERES(250), CRITLNK(70)
Local    Char     RCPFCY(GLONFCY), SHIFCY(GLONFCY), WNOMSITE(6)
Local    Date     WENDDAT
Local   Integer   GRET
#-----
SNOLIGN = nolign
WNBLIG  = [M:PSH1]NBLIG
# Issue 112754 - 2016-09-23 by SR : Pas d'ouverture si article service
If FONCTION = "PSH" & [M:PSH1]ITMKND(SNOLIGN-1) <> 1 : mkstat=0 : FIN=1 : WSAI=1 : Return : Endif
#----------------------------------------------------------------#
# La date de fin maxi n'est renseignée que pour les cde ouvertes #
# Si date de fin maxi nulle alors pas de limitation              #
#----------------------------------------------------------------#
If CODE=1 Raz WENDDAT : Endif
Raz RCPFCY, SHIFCY
#----- Si aucun besoin n'existe, ne pas ouvrir fenêtre de picking -----#
If CODE<>6 Goto VERIF_ORD_PICKING : Endif
#----- Vérification existence des besoins dans le fichier des DA  -----#
CRITERES='LINORDFLG=1 & ITMREF=REFART & LINCLEFLG=1 & LINAPPFLG>2'
If GBUYFLT=2  CRITERES +=' & (LINBUY=ACHETEUR | LINBUY="")' : Endif
If RCPFCY<>"" CRITERES +=' & PRHFCY=RCPFCY' : Endif
For [PSD] Where evalue(CRITERES)
  If clalev([F:PWO])>0
    For [PWO] PWO0 Where PRONUM=adxuid(1)
&                      & CODFNC=FONCTION
&                      & WIPTYP=2
&                      & WIPNUM=[F:PSD]PSHNUM &
&                        PSDLIN=[F:PSD]PSDLIN & ITMREF=[F:PSD]ITMREF
      [F:PSD]ORDQTYSTU+=[F:PWO]QTYSTU
    Next
  Endif
  If [F:PSD]QTYSTU>[F:PSD]ORDQTYSTU
    #----- Contrôle existence du site et appartenance à la même sté juridique -----#
    If [F:FCY]FCY<>[F:PSD]PSHFCY
      Read [FCY] FCY0=[F:PSD]PSHFCY : If fstat Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY=GSOCIETE WRETOUR=1 : Break : Endif
  Endif
Next

If WRETOUR=0 : mkstat=0 : FIN=1 : WSAI=1 : Endif
Return
#----- Vérification existence des besoins dans le fichier encours -----#
$VERIF_ORD_PICKING
Case CODE
  When 1 : CRITERES='WIPTYP=2 & WIPSTA=3 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
  When 2 : CRITERES='WIPTYP=2 & WIPSTA=2 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
  When 3 : CRITERES='WIPTYP=2 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
  When 4 : CRITERES='WIPTYP=4 & WIPSTA=1 & ITMREF=REFART'
  When 5 : CRITERES='WIPTYP=2 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO" & ABBFIL<>"PSD"'
  When 7 : CRITERES='WIPTYP=7 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
  When 8 : CRITERES ='(WIPTYP=2 & WIPSTA=2 & ITMREF=REFART & left$(ABBFIL,2)<>"PO") |'
           CRITERES-='(WIPTYP=7 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO")'
Endcase
#----- Filtre sur site de réception et site d'expédition -----#
If RCPFCY<>""          CRITERES-='& STOFCY=RCPFCY' : Endif
If SHIFCY<>"" & CODE>6 CRITERES-='& (ORIFCY=SHIFCY | WIPTYP<>7)' : Endif
#----- Filtre sur acheteur -----#
If GBUYFLT=2 & CODE<>1 & CODE<>7
  CRITLNK='[F:ITF]BUY=ACHETEUR | [F:ITF]BUY="" | [F:ORD]WIPTYP=7'
Else
  CRITLNK="1=1"
Endif
#-----
WRETOUR = 0
Filter [ORD] Where evalue(CRITERES)
Link [ORD] With [ITF] ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY As [ORF]
For [ORF] Where evalue(CRITLNK)
  If clalev([F:PWO])>0
    For [PWO] PWO0 Where PRONUM=adxuid(1)
&                      & CODFNC=FONCTION
&                      & WIPTYP=[F:ORD]WIPTYP
&                      & WIPNUM=[F:ORD]WIPNUM
&                      & ITMREF=[F:ORD]ITMREF
      [F:ORD]RMNEXTQTY-=[F:PWO]QTYSTU
    Next
  Endif
  If [F:ORD]RMNEXTQTY>0 & ([F:ORD]ENDDAT<=WENDDAT | WENDDAT=[0/0/0])
    #----- Contrôle existence du site et appartenance à la même sté juridique -----#
    If [F:FCY]FCY<>[F:ORD]STOFCY
      Read [FCY] FCY0=[F:ORD]STOFCY : If fstat Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY=GSOCIETE
      #---- "POP" demande d'achat : Prise en compte si ligne complètement signée ----#
      If [F:ORD]WIPSTA=2 & [F:ORD]ABBFIL="PSD"
        Read [PSD] PSD0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
        If fstat Raz [F:PSD] : Endif
        If [F:PSD]LINAPPFLG>2 WRETOUR=1 : Break : Endif
      #---- "POS","TRS" et "SCF" Besoins production : Prise en compte sans restrition ----#
      Else
        WRETOUR=1 : Break
      Endif
    Endif
  Endif
Next
Filter [ORD]
If WRETOUR=0  mkstat=0 : FIN=1 : WSAI=1 : Endif
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_SAIPECB3
Raz [M:PPI1]
#----- Ouverture fichier table des unités si nécessaire -----#
If clalev([F:TUN])=0 Local File TABUNIT [TUN] : Endif
#----- Lecture fournisseur et article si nécessaire -----#
If [F:BPS]BPSNUM<>FOURN
  Read [BPS] BPS0=FOURN  : If fstat Raz [F:BPS] : Endif
Endif
# Issue 78167 - 2011-11-24 by VPO : designation traduite selon la langue du fourn
#lecture BPR
If [F:BPR]BPRNUM<>FOURN
  Read [BPR] BPR0=FOURN
  If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
If [F:ITM]ITMREF<>REFART
  Read [ITM] ITM0=REFART : If fstat Raz [F:ITM] : Endif
Endif
[M:PPI1]POCFLG=1
#----- Chargement des zones dans le masque -----#
If WENDDAT<>[0/0/0]
  [M:PPI1]WBORNE=WENDDAT   : [M:PPI1]POCFLG=2 : # Cas des commandes ouvertes
Endif
If [M:PPI1]POCFLG=2
   [M:PPI1]MAXDAT=[M:PPI1]WBORNE
Endif
[M:PPI1]BPSNUM =FOURN        : [M:PPI1]BPSNAM=[F:BPS]BPSNAM
[M:PPI1]ITMREF =REFART
#[M:PPI1]ITMDES=[F:ITM]ITMDES1
# Issue 78167 - 2011-11-24 by VPO : designation traduite selon la langue du fourn
#Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PPI1]ITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:PPI1]ITMDES, "[F:ITM]") From TRTX3
[M:PPI1]UOM    =[F:ITM]STU   : [M:PPI1]ORDBUY=ACHETEUR
[M:PPI1]PUU    =UA           : [M:PPI1]QTEAOF=QTEAOF
[M:PPI1]CODE   =CODE         : [M:PPI1]CHXDAT=2
[M:PPI1]RCPFCY =RCPFCY       : [M:PPI1]SHIFCY=SHIFCY
[M:PPI1]WCODFNC=FONCTION
Call PCAL_QTY(QTEAOF,UA,[M:PPI1]PPDQTY,[M:PPI1]UOM,REFART,FOURN,1,GBIDD1) From TRTACHQTE1
#----- Affichage foreground -----#
If [M:PPI1]QTEAOF=0 Grizo PPDQTY : Endif
# Issue 120896 - 2017-01-13 by MUARN : ajout fenêtre critère
[M:PPI1]FCY=[M:PSH0]PSHFCY
Affzo [PPI1]1-99
# Issue 120896 - 2017-01-13 by MUARN : pas de contremarque en DA
[M:PPI1]CTMFLG=1
Diszo [M:PPI1]CTMFLG

# Issue 71069 - 2013-08-20 by MUARN : PJT
If GPJTSNGDOC=2 & [M:PSH0]PJTH<>""
  [M:PPI1]PJTSTR=[M:PSH0]PJTH
  [M:PPI1]PJTEND=[M:PSH0]PJTH
  # champ PJTDOC afin de savoir le code affaire encours sur PEC en mono affaire
  [M:PPI1]PJTDOC=[M:PSH0]PJTH
Endif

Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAIPECB3
Local Char SWMESS(80),WZONE  # Issue 71069 - 2013-08-22 by SR : PJT
If [M:PPI1]TOTQTY=0 : FIN = 1 : Return : Endif
#----- Tri du tableau de picking par type d'ordre & site réception -----#
Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]WIPSTA(indice),
&                                          [M:PPI1]STOFCY(indice)
#----- Contrôle quantité prise avec quantité de l'appel d'offre (en DA) -----#
If clalev([M:PSH1])<>0
  If [M:PSH1]PQHNUM(NOL)<>"" & [M:PPI1]TOTQTY<[M:PPI1]PPDQTY
    OK=2 : Call AVERTIR(mess(87,194,1),OK) From GESECRAN
    If OK=1 mkstat=1 : [M:PPI1]TOTQTY=0 : FIN = 1 :  Return : Endif
  Endif
  If [M:PPI1]TOTQTY <> 0
    nolign = SNOLIGN
    Default Mask [PSH1]
    Gosub INSERTION_BESOIN From SUBPSH
    nolign = SNOLIGN
    # Issue 71069 - 2013-08-22 by SR : PJT
    WSAI=1
    If mkstat <> 0 | GERR
      Raz [M:PSH1]ITMREF(NOL),ITMDES(NOL),ITMDES1(NOL),PRHFCY(NOL),QTYSTU(NOL),QTYPUU(NOL),EXTRCPDAT(NOL),PJT(NOL),VALEUR
      Affzo [M:PSH1]1-99
      mkstat = 1
      FIN = 1
    Else
      #-- gmodif pour ne pas entrer en saisie sur la ligne
      #-- sinon probleme si escape sur la ligne
       GMODIF = 0
      #------------------------------------------#
      # Affichage site de réception et quantités #
      #------------------------------------------#
      [M:PSH1]ITMREF(NOL)=VALEUR
      [M:PSH1]NBLIG = WNBLIG
      [M:PSH0]NBCRELIG=[M:PPI1]NBCRELIG
    Endif
  Endif
Endif
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA_SAIPECB3
Raz REP
Gosub DEB_SAIPECB3
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAIPECB3
If WSAI=1
  If !GIMPORT
    Affzo [PSH1]ITMDES(NOL),ITMDES1(NOL),PRHFCY(NOL),EXTRCPDAT(NOL),PUU(NOL),QTYPUU(NOL),
&     STU(NOL),QTYSTU(NOL),PJT(NOL),NETPRI(NOL), GROPRI(NOL),CUR(NOL)
   # Issue 71069 - 2015-12-21 by SR : PJT
   Affzo [PSH0]PJTH
   # End issue 71069
   nolign=SNOLIGN : # Le nolign peut être perdu à cause de l'Affzo !
  Endif
Endif
Return

#########################################################################
#    Après modif de référence article dans une DA uniquement            #
#########################################################################
#    DIVPSHITM   : Traitement divers                                    #
#########################################################################
$DIVPSHITM
Local Integer    WRETOUR
#-----------------------------------------------------------------------#
# On doit vérifier que l'article n'a pas fait l'objet d'une cde ouverte #
#-----------------------------------------------------------------------#
Filter [POC] Where ITMREF=VALEUR & STRDAT<=date$ & ENDDAT>=date$
Look [POC] POC2 First
Filter [POC]
If fstat=0
  GMESSAGE=mess(1,194,1) : WRETOUR=2
  Call AVERTIR(GMESSAGE,WRETOUR) From GESECRAN
  If WRETOUR=1
    mkstat=2
  Endif
Endif
If WRETOUR=1  : Return :  Endif
Local Integer   STAT
#-------------------------------------------#
# INITIALISATION DU PRIX NET                #
# RéCUPéRATION DU PRIX STANDARD ARTICLE     #
#-------------------------------------------#
If clalev([F:ITC])=0  Local File ITMCOST [ITC] : Endif
#---------------------------------------#
# EN CREATION SITE NON CHARGé           #
# donc attention en apres modif du site #
#---------------------------------------#
If [M:PSH1]PRHFCY (nolign-1) = "" : Return : Endif
If [M:PSH1]NETPRI (nolign-1) <> 0 : Return : Endif
Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
If dim([M:PSH1]ECCVALMAJ)>0
    [L]LECCMAJ  =[M:PSH1]ECCVALMAJ(nolign-1)
    [L]LECCMIN  =[M:PSH1]ECCVALMIN(nolign-1)
Endif
Call GETPRI(VALEUR,LECCMAJ,LECCMIN,[M:PSH1]PRHFCY(nolign-1),[M:PSH0]PRQDAT,1,"","",1,GBIDD3,STAT) From STKVAL
If STAT = 0
  GBIDD3 = [F:ITC]VLTTOT
  #-------------------------------------------------#
  # LE COUT STANDARD EST EN DEVISE SITE STOCKAGE    #
  # DONC LA DEVISE EST GCUR (MEME SOCIETE JURIDIQUE)#
  # plus de diviseur prix le 16 oct 98  cg          #
  #-------------------------------------------------#
  If GCUR <> [M:PSH1]CUR (nolign-1)
     Call CONVERT2(GCUR,[M:PSH1]CUR (nolign-1),GCUR,[M:PSH1]CHGTYP(nolign-1),datesyst,
&                  [F:ITC]VLTTOT,GBIDD3,STAT) From TRTDEV
  Endif
  #------ Conversion si nécessaire à cause de l'unité ------#
  If [F:ITM]PUU<>[F:ITM]STU
    #----- Appel du S/P pour chargement du coefficient avec précision maxi -----#
    Call PCAL_QTY([M:PSH1]QTYPUU(nolign-1),[F:ITM]PUU,GBIDD1,[F:ITM]STU,
&                 [F:ITM]ITMREF,[M:PSH1]BPSNUM(nolign-1),1,GBIDD2) From TRTACHQTE1
    If GBIDD2=0 GBIDD2=1 : Endif
    GBIDD3=GBIDD3*GBIDD2
  Endif
  [M:PSH1]NETPRI (nolign-1) = arr(GBIDD3,10^-GDECPRI)
  [M:PSH1]GROPRI (nolign-1) = [M:PSH1]NETPRI (nolign-1)
  #-------------------#
  # motif  prix brut  #
  #-------------------#
  If dim([M:PSH1]PRIREN)>0 [M:PSH1]PRIREN(nolign-1)=GUPDPRIPUR : Endif
Endif
Return

################################################################################
Subprog TRTCLEPSH
Local Char WPSHNUM(GLONPSH) : WPSHNUM=[M:PSH0]PSHNUM
Local Integer WNBPCE
If !clalev([M:ORDK])  Local Mask ORDK [ORDK] : Endif
Gosub TR_SOLDE
End

#---------------#
# Solde complet #
#---------------#
$TR_SOLDE
Call DEBTRANS From GLOCK
Local Integer WRET, WMSGFLG
Local Libelle WORIFLG
Local Char    WMSG(80)
#-----
$TR1_SOLDE
GOK=1
Trbegin [PSD]
For [PSD] PSD0 Where PSHNUM=WPSHNUM
  If [F:PSD]LINCLEFLG=1
    Readlock [PSD] Curr
    If fstat=1
      GOK=-1 : GLOCK="$PREQUISD"-WPSHNUM : Break
    Elsif fstat
      GOK=0  : Call RSTA("PSD",WPSHNUM) From GLOCK : Break
    Endif
    #-----
    WORIFLG=1 : # Appel hors Workflow (annulation suivi)
    WMSGFLG=0 : # Pas de message d'erreur
    Gosub MAJ_PSDCLE From TRTACHDIV1
    If GOK<1  Break : Endif
    #----- Réécriture de la ligne DA avec Indicateur SOLDE à OUI -----#
    Rewrite [PSD]
    If fstat  GOK=0 : Call FSTA("PSD") From GLOCK : Break : Endif
  Endif
Next
If GOK=-1
  Goto ROLL_TR1_SOLDE
Elsif GOK=0
  Rollback
Else
  Call ECR_TRACE([F:PSH]PSHNUM-mess(105,195,1),0) From GESECRAN
  WNBPCE = 1
  #----- Mise a jour entête DA -----#
  Readlock [PSH] PSH0=WPSHNUM
  If fstat=1
    GOK=-1 : GLOCK="$PREQUIS"-WPSHNUM : Goto ROLL_TR1_SOLDE
  Elsif fstat
    GOK=0  : Call RSTA("POH",CLECUR1) From GLOCK : Rollback
  Else
    #----- Postionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
    If GAPPPSH>1 & [F:PSH]APPFLG<3 & GPSHAPPHEA=2
      Call ANNULE_SUIVI("PSH",mess(654,197,1),1,[L]WRET) From TRTACHDIV1
      If GOK<1  Rollback : Return : Endif
    Endif
    #-----
    [F:PSH]CLELINNBR=[F:PSH]LINNBR : [F:PSH]CLEFLG=2
    Rewrite [PSH]
    If fstat
      GOK=0 : Call FSTA("PSH") From GLOCK : Rollback
    Else
      Commit
    Endif
  Endif
Endif
Return
#-----
$ROLL_TR1_SOLDE
Rollback
Call ROLL From GLOCK
If GROLL  Return  Else  Goto TR1_SOLDE : Endif
Return

#############################################################################
# Génération des commandes depuis les DA                                    #
#############################################################################
Subprog TRTPSHGEN
#--- Zones inter-sites
Local Integer  WBETFCY, WBETCPY    : # inter-site et inter-soc
Local Char     WBPCORD   (GLONBPC) : # numéro client
Local Char     WSALFCY   (GLONFCY) : # site de vente
Local Char     WPOHFCY   (GLONFCY) : # site de commande
Local Char     WLINSTOFCY(GLONFCY) : # site d'expédition
Local Char     WFINRSP   (GLONFCY) : # site de facturation
Local Char     WBPCINV   (GLONBPC) : # client facture
Local Integer  WDME, WSOHCAT       : # commande complète - type de commande
#----
If !clalev([M:PMG])  Local Mask PURMGT     [PMG] : Endif
If !clalev([F:ITM])  Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITF])  Local File ITMFACILIT [ITF] : Endif
If !clalev([F:FCY])  Local File FACILITY   [FCY] : Endif
If !clalev([F:ITFY]) Link [ITF] With [FCY] FCY0=[F:ITF]STOFCY As [ITFY] : Endif
#-----
# Issue 71069 - 2015-12-14 by SR : PJT
Local Char SWPJTMSG(250)
If [M:PSH0]PJTH <> "" & GPJTSNGDOC = 2
   If func TRTPJT.IS_PJT_AVAILABLE([M:PSH0]PJTH, "[M:PSH0]PJTH", SWPJTMSG) = G_NON Then
      Call PJT_ADD_MSG([M:PSH0]PJTH, SWPJTMSG) From TRTPJT
      Call PJT_INFO_MFG From TRTPJT
      End
   Endif
Endif
# End issue 71069

Raz [M:PMG]
[M:PMG]MAJCOD = "C"
[M:PMG]MAJTYP = "F"
[M:PMG]RGRFLG = 2
[M:PMG]MSGFLG = 2
[M:PMG]TRAFLG = 2
#[M:PMG]REQUSR = [M:PSH0]REQUSR
[M:PMG]PSHFCY = [M:PSH0]PSHFCY
[M:PMG]TARGRP = 1
[M:PMG]PRTFLG = 1 : # Pas d'impression bon de cde
# Issue 71069 - 2015-12-15 by SR : PJT
[M:PMG]PJTH = [M:PSH0]PJTH
For [PSD] PSD0 Where PSHNUM=[M:PSH0]PSHNUM
&                  & LINCLEFLG<>2
&                  & LINORDFLG<>2
&                  & LINAPPFLG>2
  If [M:PMG]NBLIG>dim([M:PMG]WIPTYP)-1 : Break : Endif
  # Issue 71069 - 2015-12-14 by SR : PJT
  If [F:PSD]PJT <> ""
     If func TRTPJT.IS_PJT_AVAILABLE([F:PSD]PJT, "[M:PSH1]PJT", SWPJTMSG) = G_NON Then
      Call PJT_ADD_MSG([F:PSD]PJT, SWPJTMSG) From TRTPJT
      Goto NEXT_PSD
     Endif
  Endif
  # End issue 71069
  If [F:PSD]QTYSTU>[F:PSD]ORDQTYSTU | [F:PSD]QTYPUU>[F:PSD]ORDQTYPUU
    [M:PMG]WIPTYP([M:PMG]NBLIG)    = 2
    [M:PMG]WIPSTA([M:PMG]NBLIG)    = 2
    [M:PMG]WIPNUM([M:PMG]NBLIG)    = [F:PSD]WIPNUM
    [M:PMG]VCRTYP([M:PMG]NBLIG)    = 14 : # Type commande c'est volontaire !
    [M:PMG]VCRNUM([M:PMG]NBLIG)    = [F:PSD]PSHNUM
    [M:PMG]VCRLIN([M:PMG]NBLIG)    = [F:PSD]PSDLIN
    [M:PMG]ITMREF([M:PMG]NBLIG)    = [F:PSD]ITMREF
    # Issue 71276 - 2015-03-02 by SR : Versions
    If dim([M:PMG]ECCVALMAJ) > 0
     [M:PMG]ECCVALMAJ([M:PMG]NBLIG) = [F:PSD]ECCVALMAJ
     [M:PMG]ECCVALMIN([M:PMG]NBLIG) = [F:PSD]ECCVALMIN
    Endif
    # End issue 71276
    [M:PMG]ORIFCY([M:PMG]NBLIG)    = [F:PSD]PSHFCY
    [M:PMG]ORDFCY([M:PMG]NBLIG)    = [F:PSD]PSHFCY
    [M:PMG]STOFCY([M:PMG]NBLIG)    = [F:PSD]PRHFCY
    [M:PMG]PJT([M:PMG]NBLIG)       = [F:PSD]PJT
    [M:PMG]BPRNUM([M:PMG]NBLIG)    = [F:PSD]BPSNUM
    [M:PMG]ENDDAT([M:PMG]NBLIG)    = [F:PSD]EXTRCPDAT
    [M:PMG]STU([M:PMG]NBLIG)       = [F:PSD]STU
    [M:PMG]EXTSTUQTY([M:PMG]NBLIG) = [F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
    [M:PMG]PUU([M:PMG]NBLIG)       = [F:PSD]PUU
    [M:PMG]EXTPUUQTY([M:PMG]NBLIG) = [F:PSD]QTYPUU-[F:PSD]ORDQTYPUU
    #-- Si le fournisseur est renseigné ! Est-on en inter-site ???
    If [F:PSD]BPSNUM<>""
      GRCPFCY=[F:PSD]PRHFCY
      Call CTRL_INTERSITE([F:PSD]PSHFCY,[F:PSD]BPSNUM,1,WBETFCY,WBETCPY,
&                         WSALFCY,WLINSTOFCY,WBPCORD,WFINRSP,WBPCINV,WDME) From TRTACHCTL1
      #----- On est en inter-sites -----#
      If WBETFCY=2
        If [F:ITM]ITMREF<>[F:PSD]ITMREF
          Read [ITM] ITM0=[F:PSD]ITMREF : If fstat  Raz [F:ITM] : Endif
        Endif
        #----- Si article géré en stock, l'article-site d'expédition doit exister -----#
        If [F:ITM]STOMGTCOD>1 & WLINSTOFCY<>""
          Read [ITF] ITF0=[F:PSD]ITMREF;WLINSTOFCY
          If fstat  Raz [F:ITF], WLINSTOFCY : Endif
        Endif
        #----- Le site d'expédition n'a pas été trouvé -----#
        If WLINSTOFCY=""
          If [F:ITM]STOMGTCOD>1
            #----- Si géré en stock recherche à partir des article-sites -----#
            If WBETCPY<>2
              Filter [ITFY] Where [F:ITF]ITMREF=[F:PSD]ITMREF
&                               & [F:FCY]LEGCPY=GSOCIETE
&                               & [F:FCY]FCY  <>[F:PSD]PRHFCY
            Else
              Filter [ITFY] Where [F:ITF]ITMREF=[F:PSD]ITMREF
&                               & [F:FCY]LEGCPY=GCPY
&                               & [F:FCY]FCY<>[F:PSD]PRHFCY
            Endif
            Read [ITFY] ITF0 First
            If !fstat  WLINSTOFCY=[F:FCY]FCY  Else  Raz [F:ITF], [F:FCY] : Endif
            Filter [ITFY]
          Else
            #----- Non géré en stock recherche à partir des sites -----#
            If WBETCPY<>2
              Filter [FCY] Where LEGCPY=GSOCIETE & WRHFLG=2 & FCY<>[F:PSD]PRHFCY
            Else
              Filter [FCY] Where LEGCPY=GCPY     & WRHFLG=2 & FCY<>[F:PSD]PRHFCY
            Endif
            Read [FCY] FCY1 First
            If !fstat  WLINSTOFCY=[F:FCY]FCY  Else  Raz [F:FCY] : Endif
            Filter [FCY]
          Endif
        Endif
        #[M:PMG]ORIFCY([M:PMG]NBLIG)=WLINSTOFCY
      Endif
    Endif
    [M:PMG]NBLIG+=1
  Endif
# Issue 71069 - 2015-12-14 by SR : PJT
$NEXT_PSD
Next
If [M:PMG]NBLIG>0
  Call MGT_PURCHASE From TRTACHMGT1
Else
  Call MESSAGE(mess(347,194,1)) From GESECRAN
Endif
# Issue 71069 - 2015-12-14 by SR : PJT
Call PJT_INFO_MSG From TRTPJT
End

#############################################################################
# MAJ_PSH : S/P de gestion des DA à partir du plan de travail               #
#           de l'approvisionneur                               MBT 31/08/99 #
# ------------------------------------------------------------------------- #
# Subprog MAJ_PSH                                                           #
#     Les paramètres sont passés par l'écran PSHMGT [PSM]                   #
# Gosub MGT_PSH                                                             #
#     Les paramètres sont passés par l'écran PURMGT [PMG]                   #
#     ---------------- A l'appel du sous-programme --------------------     #
#     MAJCOD   : Code mise à jour                                           #
#                  C = Création                                             #
#                  M = Modification                                         #
#                  A = Suppression                                          #
#     MAJTYP   : Statut de l'ordre à créer "P" = POP de Da                  #
#     RGRFLG   : Code regroupement des lignes à traiter                     #
#                0-1 = Non (1 ligne = 1 demande d'achat)                    #
#                  2 = Oui (1 regroupement  = 1 demande d'achat)            #
#                  3 = Oui (X regroupements = X lignes sur même DA)         #
#                  4 = Oui (1 regroupement  = 1 cde/da ssi tout est ok )    #
#     MSGFLG   : Code affichage message de temporisation                    #
#                0-1 = Non                                                  #
#                  2 = Oui ("Mise à jour demande d'achat en cours ...")     #
#     TRAFLG   : Code fichier trace                                         #
#                0-1 = Non                                                  #
#                  2 = Oui écriture des messages dans un fichier trace      #
#     REQUSR   : Code demandeur                                             #
#                  par défaut GUSER                                         #
#     PSHFCY   : Site de la demande d'achat                                 #
#                  par défaut ORIFCY() de la ligne traitée                  #
#     PRQDAT   : Date de la demande d'achat                                 #
#                  par défaut date du jour (date$)                          #
#     NBLIG    : Nombre de lignes à traiter (par défaut 1)                  #
#                  si création de 1 à 50                                    #
#                  si modification ou suppression 1                         #
#     Tableau des lignes à traiter                                          #
#     WIPTYP()    WIPSTA() WIPNUM() ITMREF() ORIFCY() STOFCY() PJT()        #
#     BPRNUM()    VCRTYP() VCRNUM() VCRLIN() VCRSEQ() ENDDAT() STU()        #
#     EXTSTUQTY()          PUU()    EXTPUUQTY()       BUY()    ERRLIN()     #
#     ---------------- Au retour du sous-programme --------------------     #
#     ERRCOD  : Code erreur au retour du S/P                                #
#                0 = OK pas d'erreur                                        #
#                1 = Module Achats Affectation des compteurs non trouvée !  #
#                2 = Module Stocks Affectation des compteurs non trouvée !  #
#                3 = Compteur en-cours incorrect ou non défini (max 15 car) #
#                4 = La structure par défaut des tarifs n'existe pas !      #
#                5 = Code mise à jour incorrect !                           #
#                6 = xxx Problème lors de la récupération du compteur       #
#                7 = 2 xxxxxxxxxxxxxxx Problème de mise à jour des encours  #
#                8 = Problème en mise à jour des pré-engagements            #
#                9 = xxx Problème en mise à jour des statistiques           #
#               10 = Type d'ordre non traité !                              #
#               11 = xxxxxxxxxxxxxxx Demande d'achat introuvable !          #
#               12 = xxxxxxxxxxxxxxx 9999999 Demande d'achat introuvable !  #
#               13 = xxxxxxxxxxxxxxx 9999999 Ligne DA soldée. Modif........ #
#               14 = xxxxxxxxxxxxxxx 9999999 Ligne DA commandée ou ........ #
#               15 = xxxxxxxxxxxxxxx 9999999 Ligne DA signée ou partiell... #
#               16 = $PREQUIS xxxxxxxxxxxxxx Modification en cours sur .... #
#               17 = Paramétrage règles signature inexistant pour la soc... #
#               18 = xxx Le site n'est pas sur la même société juridique    #
#                    Sites : xxx Fiche inexistante                          #
#               19 = xxx Unité d'achat incorrecte !                         #
#               20 = Période indisponible du : 99/99/99 au : 99/99/99       #
#               21 = xxxxxxxxxx Tiers non autorisé pour cette société       #
#               22 = xxxxxxxxxxxxxxxx L'article n'est pas référencé chez .. #
#               23 = xxxxxxxxxxxxxxxx xxxxxxxxxx L'article est en litige    #
#               24 = La référence article est nécessaire                    #
#               25 = xxxxxxxxxxxxxxxx : Code article inexistant             #
#               26 = xxxxxxxxxxxxxxxx : Article inactif                     #
#                    xxxxxxxxxxxxxxxx : Article non acheté                  #
#                    xxxxxxxxxxxxxxxx : Article sous-traitance non autorisé #
#               27 = xxx Unité de stock incorrecte ! (xxx)                  #
#               28 = Fournisseurs : xxxxxxxxxx Fiche inexistante            #
#                    xxxxxxxxxx : Fournisseur inactif                       #
#                    xxxxxxxxxx : Fournisseur prospect                      #
#                    xxxxxxxxxx : Fournisseur douteux                       #
#               99 = Erreurs diverses                                       #
#     ERRLIN(): Code erreur ligne au retour du S/P (indicé de 0 à 19)       #
#                0 = OK pas d'erreur, ligne traitée                         #
#                1 = Erreur ligne non traitée                               #
#     GMESSAGE: Contient le texte de l'erreur (ERRCOD=1-28)                 #
#                      ou de la dernière erreur recontrée (ERRCOD=99)       #
#############################################################################
Subprog MAJ_PSH
#----- Message pour patienter -----#
If [M:PSM]MSGFLG=2 Call TEMPON(mess(217,197,1)) From GESECRAN : Endif
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
[M:PSM]ERRCOD=0
If [M:PSM]NBLIG=0 [M:PSM]NBLIG=1 : Endif
If [M:PSM]NBLIG>dim([M:PSM]WIPTYP) [M:PSM]NBLIG=dim([M:PSM]WIPTYP) : Endif
For I=0 To [M:PSM]NBLIG-1 : [M:PSM]ERRLIN(I)=1 : Next I
#----- Ouverture du nouveau masque écran -----#
If clalev([M:PMG])=0 Local Mask PURMGT [PMG] : Endif
[M:PMG]=[M:PSM]
Gosub MGT_PSH
[M:PSM]=[M:PMG]
#----- Effacement message -----#
If [M:PSM]MSGFLG=2 Call TEMPOFF From GESECRAN : Endif
#----- Fermeture et lecture du fichier trace si nécessaire -----#
If GPURTRACE>0
  Call FERME_TRACE From LECFIC : # Call LEC_TRACE From LECFIC
  GPURTRACE=0 : GTRACE=""
Endif
#----- Restauration variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
End

##############################################
# Gestion des DA à partir du plan de travail #
##############################################
$MGT_PSH
Local Libelle WCHGTYP, CONSOFLG
Local Integer I, J, K, L, RETOUR, OUVFICFLG, STAT,GRET
Local Decimal MT, GROPRI, DISCRGVAL(0..8), NETPRI, QTY
Local Char    FICHIER(GLONATB), ABRFIC(3)
Local Char    SYMBOL2(30), CLEFIC(33), WMSG(80), WCUR(GLONCUR), WPSHFCY(GLONFCY)
Local Char    WGRPDEB(GLONVCR)
Local Char    SAV_GABREV(5) : [L]SAV_GABREV=GABREV : GABREV="PSH"
# Issue X3-55891 - 2018-09-28 by SR : Déclinaison par site
Local  Integer  WITMBPS, WRETOUR
Local  Integer  SAV_GIMPORT          : SAV_GIMPORT=GIMPORT
If !clalev([F:TB0])  Local File PREQUISD  [TB0] : Endif
If !clalev([F:TB2])  Local File CPTANALIN [TB2] : Endif
Raz GMESSAGE, GSOC_ACTIVE
# Issue X3-55891 - 2018-09-28 by SR : Oucrir la trace comme dans TRTACHPOH1
##----- Ouverture fichier trace si nécessaire -----#
#If [M:PMG]TRAFLG=2 & GTRACE=""
#  Call OUVRE_TRACE(mess(218,197,1)) From LECFIC : GPURTRACE=1
#Endif
#----- Ouverture fichier trace si nécessaire -----#
If ([M:PMG]TRAFLG=2 & GTRACE="") | ([M:PMG]MAJCOD="C" & GTRACE="")
  Call OUVRE_TRACE(mess(238,197,1)) From LECFIC : GPURTRACE=1
Endif
#----- Ouverture tables si nécessaire -----#
If clalev([F:PSH])=0 : Local File PREQUIS    [PSH] : Endif
If clalev([F:PSD])=0 : Local File PREQUISD   [PSD] : Endif
If clalev([F:CAL])=0 : Local File CPTANALIN  [CAL] : Endif
If clalev([F:PFI])=0 : Local File PFOOTINV   [PFI] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITP])=0 : Local File ITMBPS     [ITP] : Endif
If clalev([F:ITS])=0 : Local File ITMSALES   [ITS] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:ITG])=0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:TUV])=0 : Local File TABUNAVAIL [TUV] : Endif
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev([F:TCO])=0 : Local File TABCOEFF   [TCO] : Endif
If clalev([F:TCA])=0 : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:CAC])=0 : Local File GACCCODE   [CAC] : Endif
If clalev([F:GAG])=0 : Local File GAUTACEF   [GAG] : Endif
If clalev([F:GAD])=0 : Local File GAUTACED   [GAD] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS    [AUS] : Endif
If clalev([F:PPR])=0 : Local File PPREASON   [PPR] : Endif
If clalev([F:PPK])=0 : Local File PPRICLINK  [PPK] : Endif
If clalev([F:PPC])=0 : Local File PPRICCONF  [PPC] : Endif
If clalev([F:ORD])=0 : Local File ORDERS     [ORD] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
If clalev([F:TVB])=0 : Local File TABVACBPR  [TVB] : Endif : # 71937 : Multilégislation
If clalev([F:AGC])=0 : Local File AGRPCPY    [AGC] : Endif : # 71937 : Multilégislation
If clalev([F:ITPF])=0 : Local File ITMBPSFCY [ITPF] : Endif # Issue X3-55891 - 2018-08-31 by MUARN : exploitation table article/fournisseur/site
If GMODU(2)=2 : # Compta
  Local File BALANA, BUD, BUDPAR
Endif
#----- Ouverture masques si nécessaire -----#
If GMODU(5)=2
  If !clalev([M:SORW]) Local Mask SORW      [SORW] : Endif
Endif
If !clalev([M:ORDK])   Local Mask ORDK      [ORDK] : Endif
#----- contrôle que la structure tarif par défaut existe -----#
STAT=0
If clalev([F:PRS])=0 Local File PRICSTRUCT [PRS] : OUVFICFLG=1 : Endif
Read [PRS] PRS0=2;""
If fstat
  GMESSAGE=mess(81,199,1) : Call ECR_TRACE(1)
  [M:PMG]ERRCOD=4 : Goto FIN_MAJ_PSH
Endif
If OUVFICFLG=1 Close Local File [PRS] : Raz OUVFICFLG : Endif
#----- Chargement des paramètres par défaut de la gestion tarif -----#
Raz GPLISTC
Call COLREM("C",2,"") From TRTPRICE
Call TYPREM(2,"")     From TRTPRICE
Call TARIFCHGT(6)     From TRTPRICE
#----- Appel du point d'entrée PECBESOINS pour conversion qtés en unité physique -----#
Local Char     ABREV(4) : [L]ABREV="PMG"
Local Shortint TRAIT    : [L]TRAIT=4
Local Decimal  RMNQTY
For I=0 To [M:PMG]NBLIG-1
  If [M:PMG]EXTSTUQTY(I)=0
    Call PCAL_QTY ([M:PMG]EXTPUUQTY(I),[M:PMG]PUU(I),[L]RMNQTY,
&           [M:PMG]STU(I),[M:PMG]ITMREF(I),[M:PMG]BPRNUM(I),1,GBIDD1) From TRTACHQTE1
  Else
    [L]RMNQTY=[M:PMG]EXTSTUQTY(I)
  Endif
  #-----
  Gosub POINT_PECBESOINS From TRTACHMGT1
  #-----
  [M:PMG]EXTSTUQTY(I)=[L]RMNQTY
  Call PCAL_QTY ([M:PMG]EXTSTUQTY(I),[M:PMG]STU(I),[M:PMG]EXTPUUQTY(I),
&           [M:PMG]PUU(I),[M:PMG]ITMREF(I),[M:PMG]BPRNUM(I),1,GBIDD1) From TRTACHQTE1
Next I
#----- Vérification si transformation d'une POP de DL en POP de DA -----#
If [M:PMG]MAJCOD="M" & [M:PMG]WIPNUM(0)<>"" & [M:PMG]NBLIG=1
  Read [ORD] ORD0=[M:PMG]WIPTYP(0);[M:PMG]WIPNUM(0);[M:PMG]ITMREF(0)
  If !fstat & [F:ORD]ABBFIL="POC"
    Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrée ORDLEC
    [M:PMG]MAJCOD="X"
    If !clalev([F:PSO])  Local File PREQUISO   [PSO] : Endif
    If !clalev([F:PWO])  Local File PWRKORDERS [PWO] : Endif
    #----- Calcul quantité en UA ou US -----#
    If [M:PMG]EXTSTUQTY(0)=0
      Call PCAL_QTY ([M:PMG]EXTPUUQTY(0),[M:PMG]PUU(0),[M:PMG]EXTSTUQTY(0),
&         [M:PMG]STU(0),[M:PMG]ITMREF(0),[M:PMG]BPRNUM(0),1,GBIDD1) From TRTACHQTE1
    Else
      Call PCAL_QTY ([M:PMG]EXTSTUQTY(0),[M:PMG]STU(0),[M:PMG]EXTPUUQTY(0),
&         [M:PMG]PUU(0),[M:PMG]ITMREF(0),[M:PMG]BPRNUM(0),1,GBIDD1) From TRTACHQTE1
    Endif
    Raz [F:PWO]
    [F:PWO]ITMREF=[M:PMG]ITMREF(0)
    [F:PWO]QTYPUU=[M:PMG]EXTPUUQTY(0)
    [F:PWO]PUU   =[M:PMG]PUU(0)
    [F:PWO]QTYSTU=[M:PMG]EXTSTUQTY(0)
    [F:PWO]STU   =[M:PMG]STU(0)
  Endif
Endif
# Issue X3-55891 - 2018-10-01 by SR : Pour avoir tous les messages dans la trace
GIMPORT = 1
#----- Sélection du traitement demandé -----#
Case [M:PMG]MAJCOD
  When "C","X" : Gosub CREATION_PSH
  When "M"     : Gosub MODIFICATION_PSH
  When "A"     : Gosub SUPPRESSION_PSH
  When Default : GMESSAGE=mess(227,197,1) : Call ECR_TRACE(1) : [M:PMG]ERRCOD=5
Endcase
$FIN_MAJ_PSH
#----- Déblocage logique entête DA si nécessaire (cas modif ou suppression) -----#
If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
GABREV=[L]SAV_GABREV
# Issue X3-55891 - 2018-09-28 by SR : Déclinaison par site
GIMPORT=SAV_GIMPORT
Return

#------------------------------------------------------------------#
# Création d'une demande d'achat à partir d'une ou plusieurs "POS" #
#------------------------------------------------------------------#
$CREATION_PSH
#----- Variables locales -----#
Local Char     SECTION(GLONCCE)
Local Integer  WPSDLIN, MAXLIGNE
Local Char     TPLAN   (GLONCOA)(1..10)
Local Char     TCOMPTE (GLONGAC)(1..10)
Local Char     PLAN    (GLONCOA)
Local Char     COMPTE  (GLONGAC)
Local Char     ID1(20)(1..5), ID2(20)(1..5)
Local Shortint I_PECB
Local Libelle  WVCRTYP
Local Char     WVCRNUM(GLONVCR)
Local Integer  WVCRLIN, WVCRSEQ
Local Integer  GRET
#----- Récupération nombre de lignes maxi d'une DA -----#
If clalev([F:ACV])=0 Local File ACTIV [ACV] : OUVFICFLG=1 : Endif
Read [ACV] CODACT="PSH" : If fstat Raz [F:ACV] : [F:ACV]DIME=21 : Endif
MAXLIGNE=[F:ACV]DIME
If OUVFICFLG=1 Close Local File [ACV] : Raz OUVFICFLG : Endif
#----------------------------------------------------------------------#
# Point d'entrée CREATEPSH pour modifier la gestion des regroupements  #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée :                        #
# La classe [M:PMG]                                                    #
# [M:PMG]RGRFLG : Code regroupement des lignes à traiter               #
#                 0-1 = Non (1 ligne = 1 demande d'achat)              #
#                   2 = Oui (1 regroupement  = 1 demande d'achat)      #
#                   3 = Oui (X regroupements = X lignes sur même DA)   #
# WSRTFLG   : Indicateur de tri (0=Tri à faire,  1=Tri effectué)       #
# -------------------------------------------------------------------- #
# Variable modifiable par le point d'entrée :                          #
# ECLAT_DAT : Eclatement par dates de besoin      (1=Non / 2=Oui)      #
#----------------------------------------------------------------------#
Local Libelle WSRTFLG   : WSRTFLG=0
Local Libelle ECLAT_DAT : ECLAT_DAT=1
GPOINT="CREATEPSH" : Gosub ENTREE From EXEFNC
#----- Tri des lignes du tableau -----#
If !WSRTFLG & [M:PMG]RGRFLG>1 & [M:PMG]NBLIG>1
  # Issue 89149 - 2013-04-08 by MUARN : ajout tri par date
#  Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]ITMREF(indice),
#&                                          [M:PMG]STOFCY(indice),
#&                                          [M:PMG]BPRNUM(indice)
  Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]ITMREF(indice),
&                                          [M:PMG]ENDDAT(indice),
&                                          [M:PMG]STOFCY(indice),
&                                          [M:PMG]BPRNUM(indice)
Endif
Call DEBTRANS From GLOCK
$TR_CREATION
#----- Effacement des buffers DA -----#
GOK=1 : Raz WMSG, [F:PSH], [F:PSD], WPSDLIN, CONSOFLG, WGRPDEB
For I=0 To [M:PMG]NBLIG-1 : [M:PMG]ERRLIN(I)=1 : Next I
Trbegin ADOVAL
  #----- Transformation d'une POP de DL en POP de DA -----#
  If [M:PMG]MAJCOD="X"
    #----- Mise à jour de l'ordre POP de la DL -----#
    Raz [M:ORDK]
    [M:ORDK]=[F:ORD]
    [M:ORDK]MAJCOD    = "M"
    [M:ORDK]WIPTYP    = [M:PMG]WIPTYP(0)
    [M:ORDK]WIPNUM    = [M:PMG]WIPNUM(0)
    [M:ORDK]ITMREF    = [M:PMG]ITMREF(0)
    [M:ORDK]EXTQTY   -= [M:PMG]EXTSTUQTY
    If left$([M:ORDK]ABBFIL,1)<>"P"  [M:ORDK]ABBFIL="PUR" : Endif
    Call WIP From TRTWIP
    If GOK=-1  Goto ROLL_CREATION : Endif
    If GOK=0   Goto AB_CREATION   : Endif
    #----- Mise à jour de la DL elle même -----#
    Gosub CONSOMMATION_LIGNE_DL From SUBPOHB
    If GOK=-1  Goto ROLL_CREATION : Endif
    If GOK=0   Goto AB_CREATION   : Endif
    [M:PMG]MAJCOD="C" : [M:PMG]WIPNUM(0)=""
    Raz WMSG, [F:PSH], [F:PSD], WPSDLIN
    [L]CONSOFLG=1
  Endif
  #----- Boucle de lecture des lignes de besoins pris en compte (POS) -----#
  For I=0 To [M:PMG]NBLIG-1
    #----- Traitement des "POS" uniquement -----#
    If (!find([M:PMG]WIPTYP(I),2,7) | [M:PMG]WIPSTA(I)>3) & [M:PMG]WIPNUM(I)<>""        # 66469
      GMESSAGE=mess(219,197,1) : # Type d'ordre non traité !
      Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
    Endif
    #----- Test si ligne chargée et pas de regroupement -----#
    If [F:PSD]ITMREF<>""
      If [M:PMG]RGRFLG<2 |
&        [F:PSD]ITMREF   <>[M:PMG]ITMREF(I) |
&        [F:PSD]PRHFCY   <>[M:PMG]STOFCY(I) |
&        [F:PSD]BPSNUM   <>[M:PMG]BPRNUM(I) |
&       ([F:PSD]EXTRCPDAT<>[M:PMG]ENDDAT(I) & ECLAT_DAT>1)
        Gosub CREATION_LIGNE : If GOK<1 Break : Endif
      Endif
    Endif
    #----- Chargement du site demande et des paramètres -----#
    If [F:PSH]PSHNUM=""
      If    [M:PMG]PSHFCY   <>""  WPSHFCY=[M:PMG]PSHFCY
      Elsif [M:PMG]ORDFCY(I)<>""  WPSHFCY=[M:PMG]ORDFCY(I) # Issue 99743 GA 09/2014 idem TRTACHPOH1
      Else                        WPSHFCY=[M:PMG]ORIFCY(I) : Endif
      #----- Site demande non renseigné -----#
      If WPSHFCY=""
        Read [FCY] FCY0=[M:PMG]STOFCY(I) : If fstat  Raz [F:FCY] : Endif
        GBIDI2=[F:FCY]PURFLG
        GBIDC2=[F:FCY]LEGCPY
        If GFCYDEF(6)<>""
          #----- Site d'achat habituel de l'opérateur si même société -----#
          Read [FCY] FCY0=GFCYDEF(6) : If fstat  Raz [F:FCY] : Endif
          If [F:FCY]PURFLG=2 & [F:FCY]LEGCPY=GBIDC2
            WPSHFCY=GFCYDEF(6)
          Endif
        Endif
        If WPSHFCY=""
          If GBIDI2=2
            #----- Site de réception si celui-ci est également site d'achat -----#
            WPSHFCY=[M:PMG]STOFCY(I)
          Else
            #----- 1er site d'achat appartenant à la même société -----#
            Filter [FCY] Where LEGCPY=GBIDC2 & PURFLG=2
            Read [FCY] FCY1 First : If !fstat  WPSHFCY=[F:FCY]FCY : Endif
            Filter [FCY]
          Endif
        Endif
      Endif
      #-----
      Gosub CHARG_PARAM
      If GMESSAGE<>""
        Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
      Endif
    Endif
    #----- Contrôle validité des champs -----#
    Call CONTROLE_ZONES(I)
    If GMESSAGE<>""
      Call ECR_TRACE(1) : [M:PMG]ERRCOD=0 : Gosub ECR_NON_TRAITEE :  Goto SUITE_CREATION
    Endif
    #----- Si nouvelle DA, chargement de l'entête et des paramètres -----#
    If [F:PSH]PSHNUM=""
      If    [M:PMG]PSHFCY   <>""  [F:PSH]PSHFCY=[M:PMG]PSHFCY
      Elsif [M:PMG]ORDFCY(I)<>""  [F:PSH]PSHFCY=[M:PMG]ORDFCY(I) # Issue 99743 GA 09/2014 idem TRTACHPOH1
      Else                        [F:PSH]PSHFCY=[M:PMG]ORIFCY(I) : Endif
      If [M:PMG]PRQDAT<>[0/0/0] [F:PSH]PRQDAT=[M:PMG]PRQDAT
                           Else [F:PSH]PRQDAT=date$   : Endif
      If [M:PMG]REQUSR<>""      [F:PSH]REQUSR=[M:PMG]REQUSR
                           Else [F:PSH]REQUSR=GUSER   : Endif
      [F:PSH]APPFLG=1
      [F:PSH]ORDFLG=1
      [F:PSH]CLEFLG=1
      [F:PSH]PRNFLG=1
      [F:PSH]CREUSR=GUSER
      [F:PSH]CREDAT=date$
      [F:PSH]EXPNUM=[C]EXPORT
      Call NUMERO(GCODNUM,[F:PSH]PSHFCY,[F:PSH]PRQDAT,"",[F:PSH]PSHNUM,RETOUR) From SUBANM
      If GOK<0
        WMSG=GCODNUM-mess(60,199,1) : # Problème lors de la récupération du compteur
        [M:PMG]ERRCOD=6 : Break
      Elsif GOK<1 | RETOUR<>0
        GMESSAGE=GCODNUM-mess(60,199,1) : [M:PMG]ERRCOD=6
        Raz [F:PSH] : GOK=0
        Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Break
      Endif
      Raz WPSDLIN
    Endif
    #----- Nouvelle ligne DA -----#
    If [F:PSD]ITMREF=""
      WPSDLIN+=1000
      [F:PSD]PSHNUM   =[F:PSH]PSHNUM
      [F:PSD]PSHFCY   =[F:PSH]PSHFCY
      [F:PSD]PSDLIN   =WPSDLIN
      [F:PSD]ITMREF   =[M:PMG]ITMREF(I)
      [F:PSD]PRHFCY   =[M:PMG]STOFCY(I)
      [F:PSD]PJT      =[M:PMG]PJT(I)
      [F:PSD]BPSNUM   =[M:PMG]BPRNUM(I)
      [F:PSD]EXTRCPDAT=[M:PMG]ENDDAT(I)
      [F:PSD]STU      =[M:PMG]STU(I)
      [F:PSD]QTYSTU   =[M:PMG]EXTSTUQTY(I)
      [F:PSD]LINCLEFLG=1
      [F:PSD]LINORDFLG=1
      [F:PSD]ORI      =1
      [F:PSD]FBUFLG   =1
      [F:PSD]CREUSR   =GUSER
      [F:PSD]CREDAT   =date$
      I_PECB=I+1
      WVCRTYP=[M:PMG]VCRTYP(I)
      WVCRNUM=[M:PMG]VCRNUM(I)
      WVCRLIN=[M:PMG]VCRLIN(I)
      WVCRSEQ=[M:PMG]VCRSEQ(I)
      # Issue 104943 - 2015-06-29 by BEEBE : Implementing Versioning
      If dim([M:PMG]ECCVALMAJ)>0
          [F:PSD]ECCVALMAJ=[M:PMG]ECCVALMAJ(I)
          [F:PSD]ECCVALMIN=[M:PMG]ECCVALMIN(I)
      Endif
    #----- Cumul des qtés et maj date de réception -----#
    Else
      [F:PSD]QTYSTU+=[M:PMG]EXTSTUQTY(I)
      If [F:PSD]EXTRCPDAT>[M:PMG]ENDDAT(I) [F:PSD]EXTRCPDAT=[M:PMG]ENDDAT(I) : Endif
      Raz I_PECB
    Endif
    #----- Mise à jour des ordres POS (Consommation) -----#
    If [M:PMG]WIPNUM(I)<>""
      Read [ORD] ORD0=[M:PMG]WIPTYP(I);[M:PMG]WIPNUM(I);[M:PMG]ITMREF(I)
      If fstat
        Raz [F:ORD]
      Else
        Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrée ORDLEC
        If [F:ORD]VCRTYPORI>0 & [F:ORD]VCRNUMORI<>""
          WVCRTYP=[F:ORD]VCRTYPORI
          WVCRNUM=[F:ORD]VCRNUMORI
          WVCRLIN=[F:ORD]VCRLINORI
          WVCRSEQ=[F:ORD]VCRSEQORI
        Endif
      Endif
      [M:ORDK]=[F:ORD]
      [M:ORDK]MAJCOD  = "M"
      [M:ORDK]WIPTYP  = [M:PMG]WIPTYP(I)
      [M:ORDK]WIPNUM  = [M:PMG]WIPNUM(I)
      [M:ORDK]ITMREF  = [M:PMG]ITMREF(I)
      [M:ORDK]EXTQTY -= [M:PMG]EXTSTUQTY(I)
      If left$([M:ORDK]ABBFIL,1)<>"P"  [M:ORDK]ABBFIL="PUR" : Endif
      Call WIP From TRTWIP
      If GOK<1
        WMSG="2"-[M:PMG]WIPNUM-[M:PMG]ITMREF-mess(92,197,1) : # Problème en maj encours
        [M:PMG]ERRCOD=7 : Break
      Endif
      #----- Mise à jour des ordres TRS (Consommation) -----#              # 66469
      If [M:PMG]WIPTYP(I)=7
        Read [ORD] ORD0=8;[M:PMG]WIPNUM(I);[M:PMG]ITMREF(I)
        If !fstat
          Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrée ORDLEC
          [M:ORDK]=[F:ORD]
          [M:ORDK]MAJCOD  = "M"
          [M:ORDK]WIPTYP  = 8
          [M:ORDK]WIPNUM  = [M:PMG]WIPNUM(I)
          [M:ORDK]ITMREF  = [M:PMG]ITMREF(I)
          [M:ORDK]EXTQTY -= [M:PMG]EXTSTUQTY(I)
          If left$([M:ORDK]ABBFIL,1)<>"P"  [M:ORDK]ABBFIL="PUR" : Endif
          Call WIP From TRTWIP
          If GOK<1
            WMSG ="8"
            WMSG-=[M:PMG]WIPNUM(I)-[M:PMG]ITMREF(I)-mess(92,197,1) : # Problème en maj encours
            [M:PMG]ERRCOD=7 : Break
          Endif
        Else
          Raz [F:ORD]
        Endif
      Endif

    Endif
    #----- Indicateur ligne traitée et chargement No et ligne DA -----#
    [M:PMG]ERRLIN(I)=0
    [M:PMG]VCRNUM(I)=[F:PSD]PSHNUM
    [M:PMG]VCRLIN(I)=[F:PSD]PSDLIN
$SUITE_CREATION
  Next I
  If GOK=-1 Goto ROLL_CREATION : Endif
  If GOK=0  Goto AB_CREATION   : Endif
  If [F:PSD]ITMREF<>""
    Gosub CREATION_LIGNE
    If GOK=-1 Goto ROLL_CREATION : Endif
    If GOK=0  Goto AB_CREATION   : Endif
  Endif
  If [F:PSH]PSHNUM<>""
    Gosub CREATION_ENTETE
    If GOK=-1 Goto ROLL_CREATION : Endif
    If GOK=0  Goto AB_CREATION   : Endif
  Endif
Commit
#----- Envoi des messages groupe workflow signature -----#
If WGRPDEB<>""  Call ENVOI_GROUPE(WGRPDEB) From AWRK : WGRPDEB="" : Endif
Return

$ROLL_CREATION
Rollback
#----- Suppression des message groupe workflow signature -----#
If WGRPDEB<>""  Call VIRE_GROUPE(WGRPDEB)  From AWRK : GOK=0 : WGRPDEB="" : Endif
#-----
Call ROLL From GLOCK
If GROLL
  Gosub AB_TRANSACTION_MSG
  Return
Else
  Goto TR_CREATION
Endif
$AB_CREATION
Rollback
#----- Suppression des message groupe workflow signature -----#
If WGRPDEB<>""  Call VIRE_GROUPE(WGRPDEB)  From AWRK : GOK=0 : WGRPDEB="" : Endif
#-----
Gosub AB_TRANSACTION_MSG
Return

#----------------------------#
# Création d'une ligne de DA #
#----------------------------#
$CREATION_LIGNE
#------ Lecture si nécessaire de l'ITMMASTER et l'ITMFACILIT -----#
If [F:ITM]ITMREF<>[F:PSD]ITMREF
  Read [ITM] ITM0=[F:PSD]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[F:PSD]ITMREF | [F:ITF]STOFCY<>[F:PSD]PSHFCY
  Read [ITF] ITF0=[F:PSD]ITMREF;[F:PSD]PSHFCY
  If fstat Raz [F:ITF] : [F:ITF]OFS=[F:ITM]OFS : Endif
Endif
#----- Lecture si nécessaire du BPARTNER, du BPSUPPLIER et de l'ITMBPS -----#
If [F:PSD]BPSNUM<>""
  If [F:BPR]BPRNUM<>[F:PSD]BPSNUM
    Read [BPR] BPR0=[F:PSD]BPSNUM
    If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
  Endif
  If [F:BPS]BPSNUM<>[F:PSD]BPSNUM
    Read [BPS] BPS0=[F:PSD]BPSNUM
    If fstat Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
  Endif
  [F:PSD]CUR=[F:BPS]CUR
  # Issue X3-55891 - 2018-08-31 by MUARN : exploitation table article/fournisseur/site
  #If [F:ITP]ITMREF<>[F:PSD]ITMREF | [F:ITP]BPSNUM<>[F:PSD]BPSNUM
  #  Read [ITP] ITP0=[F:PSD]ITMREF;[F:PSD]BPSNUM
  #  If fstat
  #    Raz [F:ITP] : [F:ITP]PUU=[F:ITM]PUU
  #  Elsif [F:ITP]DOUFLG=2
  #    GMESSAGE=[F:PSD]ITMREF-[F:PSD]BPSNUM-mess(8,194,1) : Call ECR_TRACE(0)
  #    Raz GMESSAGE
  #  Endif
  #Endif
  Call CTRL_DOUFLG(1,[F:PSD]ITMREF,[F:PSD]BPSNUM,[F:PSD]PRHFCY,WITMBPS,WRETOUR) From TRTACHCTL1
  If WRETOUR <> 0
     GOK = 0
     Call ECR_TRACE(1)
     If WRETOUR =1 : [M:PMG]ERRCOD=23
     Else          : [M:PMG]ERRCOD=22
     Endif
     Return
  Endif
  # End issue X3-55891
Else
  Raz [F:ITP], [F:BPS], [F:BPR]
Endif
# Issue 112754 - 2016-10-27 by SR : Services
[F:PSD]ITMKND = 1
If [F:ITM]SCSFLG = 2 : [F:PSD]ITMKND = 3 : Endif
# End issue 112754
#----- Récupération des liens texte article ou article-fournisseur -----#
[F:PSD]LINTEX=[F:ITM]PURTEX
If [F:PSD]BPSNUM<>"" & [F:ITP]TEX<>""  [F:PSD]LINTEX=[F:ITP]TEX : Endif
#----- Chargement acheteur, devise, type cours, unité achat et cours -----#
If [F:ITF]BUY   <>"" [F:PSD]LINBUY=[F:ITF]BUY    Else [F:PSD]LINBUY=[F:ITM]BUY : Endif
If [F:PSD]BPSNUM<>"" [F:PSD]CUR   =[F:BPS]CUR    Else [F:PSD]CUR   =GLOCALDEV  : Endif
If [F:BPS]CHGTYP<>0  [F:PSD]CHGTYP=[F:BPS]CHGTYP Else [F:PSD]CHGTYP=GPURCHGTYP : Endif
If [F:ITP]PUU<>""    [F:PSD]PUU   =[F:ITP]PUU    Else [F:PSD]PUU   =[F:ITM]PUU : Endif
Call COURSITE([F:PSD]CUR,[F:PSD]PSHFCY,[F:PSD]CHGTYP,[F:PSH]PRQDAT,
&            [F:PSD]CHGCOE,RETOUR) From TRTDEV
#----- Chargement du régime de taxe et du type de régime -----#
If [F:PSD]BPSNUM=""
  [F:PSD]VACBPR=GPURVACBPR
Else
  Call INIT_REGIME([F:PSD]BPSNUM,[F:PSD]PSHFCY,"F",[F:PSD]VACBPR) From CPTSUB
Endif
# 71937 : Multilégislation
#If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[F:PSD]VACBPR
#  Read [ADI] CODE=1;[F:PSD]VACBPR : If fstat Raz [F:ADI] : Endif
#Endif
#[F:PSD]VACTYP=[F:ADI]N1
Call LEC_TVB_LEG(GCURLEG,[F:PSD]VACBPR,GRET) From TRTLECLEG
If GRET Raz [F:TVB] : Endif
[F:PSD]VACTYP=[F:TVB]REGVAC
# 71937 : Multilégislation
#----- Chargement des désignations article -----#
#Call CHARGE_ITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:PSD]ITMDES) From TRTX3
#If [F:PSD]ITMDES="" [F:PSD]ITMDES=[F:ITM]ITMDES1 : Endif
# Issue 78167 - 2011-11-24 by VPO : designation traduite selon la langue du fourn
#Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:PSD]ITMDES, "[F:ITM]") From TRTX3  # FGR 29/06/2009 : X3SUIVI56129
Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[F:PSD]ITMDES, "[F:ITM]") From TRTX3

#[F:PSD]ITMDES1=[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:PSD]ITMDES1,"[F:ITM]") From TRTX3  # FGR 29/06/2009 : X3SUIVI56129
#----- Calcul quantité en UA -----#
Call PCAL_QTY([F:PSD]QTYSTU,[F:PSD]STU,[F:PSD]QTYPUU,[F:PSD]PUU,
&             [F:PSD]ITMREF,[F:PSD]BPSNUM,1,GBIDD1) From TRTACHQTE1
#----- Calcul date théorique de commande -----#
[F:PSD]EXTORDDAT=[F:PSD]EXTRCPDAT-[F:ITF]OFS
#----------------------------------------------------------------------#
# Point d'entrée CALORDDAT pour modifier la date théorique de commande #
# -------------------------------------------------------------------- #
# [F:PSD]EXTORDDAT : Date théorique de commande                        #
# [F:PSD]EXTRCPDAT : Date de réception souhaitée                       #
# [F:ITF]OFS       : Délai de réappro                                  #
# [F:ITF]QUALTI    : Délai contrôle qualité                            #
# Exemple d'ajustement en fonction du délai contrôle qualité           #
#   [F:PSD]EXTORDDAT=[F:PSD]EXTORDDAT-[F:ITF]QUALTI                    #
#----------------------------------------------------------------------#
GPOINT="CALORDDAT" : Gosub ENTREE From EXEFNC
#-----
If [F:BPS]UVYCOD<>""
  Call CTL_PER([F:PSD]EXTORDDAT,[F:BPS]UVYCOD) From CONTX3
  If mkstat
    GMESSAGE=[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)-GMESSAGE
    Call ECR_TRACE(0) : Raz mkstat : # Période indisponible du : 99/99/99 ...
    Raz GMESSAGE
  Endif
Endif
#----- Recherche tarif et codes taxes de la ligne -----#
Gosub TARIF_TAX_LIGNE
#----- Calcul du montant ligne HT -----#
[F:PSD]LINAMT=[F:PSD]NETPRI*[F:PSD]QTYPUU
Call ARRDEV([F:PSD]LINAMT,[F:PSD]CUR) From TRTDIV
MT=[F:PSD]LINAMT
If [F:PSD]CUR<>GLOCALDEV
  Call CONVERT([F:PSD]CUR,GLOCALDEV,GLOCALDEV,[F:PSD]CHGTYP,datesyst,
&              [F:PSD]LINAMT,MT,GBIDI1) From TRTDEV
Endif
#----- Calcul bases et montants taxes -----#
Call MAJ_CALTAX_LIG("PSD",0) From TRTACHDIV1
#----- Initialisation comptes et type d'achat -----#
[F:TB0]=[F:PSH] : [F:TB0]=[F:PSD]
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="PSD"
[F:TB2]VCRNUM=[F:PSH]PSHNUM
[F:TB2]VCRLIN=[F:PSD]PSDLIN
[F:TB2]VCRSEQ=1
[F:TB2]ANALIG=1
For J=1 To max(GNBCOA,2)
  K=GTYPLED(J)
  If K
    [F:TB2]LED(K-1)=GLEDSOC(J)
    [F:TB2]COA(K-1)=GCOA(J)
  Endif
Next J
For J=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(J-1)=GDIE(J)
Next J
#-----
Raz ID1,ID2
Call COMPTE("PQUIS",1,ID1,ID2,TPLAN,TCOMPTE,STAT,WMSG) From CPTCOD
If STAT
  Raz TPLAN, TCOMPTE, GMESSAGE
  [F:PSD]LINPURTYP=1
Else
  #----- Récupération compte général -----#
  Call LECPLAN(GSOCIETE,GTYPGEN,PLAN) From CPTDIV
  K=find(PLAN,TPLAN(1..10))
  If K  COMPTE=TCOMPTE(K) : Endif
  If [F:GAC]COA<>PLAN | [F:GAC]ACC<>COMPTE
    Read [GAC] GAC0=PLAN;COMPTE : If fstat  Raz [F:GAC] : Endif
  Endif
  #----- Initialisation type d'achat -----#
  If [F:GAC]VATIPT=5
    [F:PSD]LINPURTYP=3
  Elsif [F:GAC]VATIPT=4
    [F:PSD]LINPURTYP=2
  Else
    [F:PSD]LINPURTYP=1
  Endif
Endif
#----- Ecriture des comptes et sections analytiques dans la table CPTANALIN -----#
Raz [F:CAL]
[F:CAL]ABRFIC="PSD"
[F:CAL]VCRNUM=[F:PSD]PSHNUM
[F:CAL]VCRLIN=[F:PSD]PSDLIN
[F:CAL]ANALIG=1
#----- Mise à jour des comptes -----#
For J=1 To 10
  K=GTYPLED(J)
  If K
    [F:CAL]LED(K-1)=GLEDSOC(J)
    [F:CAL]COA(K-1)=GCOA(J)
    L=find(GCOA(J),TPLAN(1..10))
    If L
      [F:CAL]ACC(K-1)=TCOMPTE(L)
    Else
      Raz [F:CAL]ACC(K-1)
    Endif
  Endif
Next J
#----- Initialisation des sections analytiques de la ligne -----#
For J=1 To max(GNBDIE,GOPTCANA)
  [F:CAL]DIE(J-1)=GDIE(J)
  Call INISEC(SECTION,"PSM",GDIE(J)) From SUBCDE
  [F:CAL]CCE(J-1)=SECTION
Next J
#-----
CLEFIC="PSD"-[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)
WMSG=mess(13,100,1)-"CPTANALIN"-CLEFIC : # Erreur d'écriture sur le fichier ...
Write [CAL]
If fstat  GOK=0 : Call FSTA("CAL") From GLOCK : Return : Endif
#-----
If [F:ITF]ITMREF<>[F:PSD]ITMREF | [F:ITF]STOFCY<>[F:PSD]PRHFCY
  Read [ITF] ITF0=[F:PSD]ITMREF;[F:PSD]PRHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
#----- Création de l'encours "POP" -----#
If [F:ITF]STOMGTCOD>1
  Call NUMERO(GWIP,[F:PSD]PRHFCY,[F:PSD]EXTORDDAT,"",[F:PSD]WIPNUM,RETOUR) From SUBANM
  If GOK<0
    WMSG=GWIP-mess(60,199,1) : [M:PMG]ERRCOD=6 : Return
  Elsif GOK<1 | RETOUR<>0
    WMSG=GWIP-mess(60,199,1) : [M:PMG]ERRCOD=6 : GOK=0 : Return
  Endif
  [M:ORDK]MAJCOD    = "C"
  [M:ORDK]WIPTYP    = 2
  [M:ORDK]WIPSTA    = 2
  [M:ORDK]WIPNUM    = [F:PSD]WIPNUM
  [M:ORDK]ITMREF    = [F:PSD]ITMREF
  [M:ORDK]ORIFCY    = [F:PSD]PSHFCY
  [M:ORDK]STOFCY    = [F:PSD]PRHFCY
  [M:ORDK]PJT       = [F:PSD]PJT
  [M:ORDK]BPRNUM    = [F:PSD]BPSNUM
  [M:ORDK]STRDAT    = [F:PSD]EXTORDDAT
  [M:ORDK]ENDDAT    = [F:PSD]EXTRCPDAT
  [M:ORDK]VCRTYP    = 14
  [M:ORDK]VCRNUM    = [F:PSD]PSHNUM
  [M:ORDK]VCRLIN    = [F:PSD]PSDLIN
  [M:ORDK]VCRSEQ    = 0
  [M:ORDK]EXTQTY    = [F:PSD]QTYSTU
  [M:ORDK]CPLQTY    = [F:PSD]ORDQTYSTU
  [M:ORDK]ALLQTY    = 0
  [M:ORDK]SHTQTY    = 0
  [M:ORDK]FMI       = 1
  [M:ORDK]MRPMES    = 1
  # Issue 71276 - 2015-02-27 by SR : Versions
  If dim([M:ORDK]ECCVALMAJ)> 0
     [M:ORDK]ECCVALMAJ = [F:PSD]ECCVALMAJ
     [M:ORDK]ECCVALMIN = [F:PSD]ECCVALMIN
  Endif
  # End issue 71276
  If I_PECB>0 & I_PECB<=[M:PMG]NBLIG
    #----- Si un seul besoin pris en compte, on charge la pièce d'origine -----#
    [M:ORDK]VCRTYPORI = WVCRTYP
    [M:ORDK]VCRNUMORI = WVCRNUM
    [M:ORDK]VCRLINORI = WVCRLIN
    [M:ORDK]VCRSEQORI = WVCRSEQ
  Else
    [M:ORDK]VCRTYPORI = 0
    [M:ORDK]VCRNUMORI = ""
    [M:ORDK]VCRLINORI = 0
    [M:ORDK]VCRSEQORI = 0
  Endif
  [M:ORDK]BOMALT    = 0
  [M:ORDK]ORI       = 1
  [M:ORDK]ABBFIL    = "PSD"
  Call WIP From TRTWIP
  If GOK<1
    WMSG="2"-[F:PSD]WIPNUM-[F:PSD]ITMREF-mess(92,197,1) : # Problème en maj des encours
    [M:PMG]ERRCOD=7
    Return
  Endif
Endif
#----- Mise à jour indicateur budget dépassé -----#
If GMODU(2)=2 & GNBDIE>0 & GPURCMMPRP=2
  Call CTLBUD(RETOUR) From TRTACHPSH1
  If RETOUR<1
    [F:PSD]FBUFLG=2
  Else
    [F:PSD]FBUFLG=1
  Endif
Endif
#----- Mise à jour indicateur signature ligne -----#
If GAPPPSH>1
  If [F:PSD]LINCLEFLG<>2
    [F:PSD]LINAPPFLG=0 : # La màj du suivi et le workflow se fera à la création entête !
  Else
    [F:PSD]LINAPPFLG=1
  Endif
Else
  [F:PSD]LINAPPFLG=4
Endif
#----- Mise à jour du pré-engagement -----#
[F:PSD]CMMPRPTAX=max(GPURCMMTAX,1)
If GMODU(2)=2 & GPURCMMPRP=2 & (GAPPPSH<2 | GPSHCMMLEV=3)
  [F:TB0]=[F:PSH] : [F:TB0]=[F:PSD] : [F:TB2]=[F:CAL]
  Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,+1,1,"PSD",2,RETOUR) From TRTACHDIV1
  Raz GERR
  If RETOUR<>0
    WMSG=mess(169,197,1) : # Erreur en mise à jour budget
    If GMESSAGE=""
      If RETOUR=6  GMESSAGE=mess(93,197,1) Else GMESSAGE=mess(173,197,1) : Endif
    Endif
    GMESSAGE+="\"+mess(18,197,1)-num$([F:PSD]PSDLIN)
    If RETOUR=6  Call ECR_TRACE(GMESSAGE,1) From GESECRAN : [M:PMG]ERRCOD=8 : Endif
    If GBUDCTLPSH=2
      If GCTLBUD =2
        Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Else
        Call ECR_TRACE(GMESSAGE,0) From GESECRAN
      Endif
    Else
      GBUDCTLPSH=1 : GOK=1 : GERR = 0 : Raz GMESSAGE
    Endif
  Endif
  If GOK<1  Return : Endif
Endif
#-----
[F:PSD]CPY=GSOCIETE
#------------------------------------------------------------------#
# Point d'entrée GENPSH pour alimentation de zones spécifiques     #
# ---------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                      #
#                                                                  #
# FICHIER : Nom de la table qui va être écrite                     #
# ABRFIC  : Abréviation de la table qui va être écrite             #
# La  classe  [F:PSD] est modifiable avant le Write                #
# GOK = 0 permet d'abandonner la transaction de création           #
#------------------------------------------------------------------#
FICHIER="PREQUISD"
ABRFIC ="PSD"
GPOINT="GENPSH" : Gosub ENTREE From EXEFNC
If GOK<1  Return : Endif
#----- Mise à jour des statistiques ligne DA -----#
Call VALSTA("PSD",+1) From SUBPS2
If GOK<1
  WMSG="PSD"-mess(226,197,1) : # Problème en maj des statistiques
  [M:PMG]ERRCOD=9
  Return
Endif
#----- Ecriture ligne DA -----#
CLEFIC=[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)
WMSG=mess(13,100,1)-"PREQUISD"-CLEFIC : # Erreur d'écriture sur le fichier ...
Write [PSD]
If fstat GOK=0 : Call FSTA("PSD") From GLOCK : Return : Endif
Raz WMSG
#----- Message : Demande d'achat XXXXXXXXXXXXXXX 9999999 créée ! -----#
GMESSAGE=mess(222,197,1)-[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)-mess(224,197,1)
Call ECR_TRACE(0) : Raz GMESSAGE
#----- Mise à jour total HT et nbre de lignes créées,signées sur entête DA -----#
[F:PSH]TOTPRQ+=MT
[F:PSH]LINNBR+=1
If [F:PSD]LINAPPFLG>2 [F:PSH]APPLINNBR+=1 : Endif
Raz [F:PSD]
If [M:PMG]RGRFLG<3 | WPSDLIN/1000>MAXLIGNE-2 Gosub CREATION_ENTETE : Endif
Return


#--------------------------------------------#
# Recherche tarif et codes taxes de la ligne #
#--------------------------------------------#
$TARIF_TAX_LIGNE
#----- Chargement des paramètres de la gestion tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call TARIFCHGT(6)                From TRTPRICE
Endif
#----- Recherche tarif suivant le paramètre valorisation des lignes de DA -----#
If GPSHVLT=2 Call RECH_TARIF("PSM",0) From TRTACHTAR1 : Endif
#----- Si le prix unitaire net est nul prendre le prix standard suivant GPURPRICE -----#
If ([F:PSD]NETPRI=0 & GPURPRICE=2) | GPSHVLT=1
  If clalev([F:ITC])=0 Local File ITMCOST [ITC] : OUVFICFLG=1 : Endif
  Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
  [L]LECCMAJ  =[F:PSD]ECCVALMAJ
  [L]LECCMIN  =[F:PSD]ECCVALMIN
  Call GETPRI([F:PSD]ITMREF,LECCMAJ,LECCMIN,[F:PSD]PRHFCY,[F:PSH]PRQDAT,1,"","",1,MT,GBIDI1) From STKVAL
  If GBIDI1
    Raz [F:ITC]
  Else
    MT=[F:ITC]VLTTOT
    If [F:PSD]CUR<>GLOCALDEV
      Call CONVERT2(GLOCALDEV,[F:PSD]CUR,GLOCALDEV,[F:PSD]CHGTYP,datesyst,
&                   [F:ITC]VLTTOT,MT,GBIDI1) From TRTDEV
    Endif
    If [F:PSD]PUU<>[F:PSD]STU
      Call PCAL_QTY([F:PSD]QTYPUU,[F:PSD]PUU,GBIDD1,[F:PSD]STU,
&                   [F:PSD]ITMREF,[F:PSD]BPSNUM,1,GBIDD2) From TRTACHQTE1
      If GBIDD2=0 GBIDD2=1 : Endif
      MT=MT*GBIDD2
    Endif
    [F:PSD]GROPRI=arr(MT,10^-GDECPRI)
    [F:PSD]NETPRI=[F:PSD]GROPRI
    [F:PSD]PRIREN=GUPDPRIPUR
  Endif
  If OUVFICFLG=1 Close Local File [ITC] : Raz OUVFICFLG : Endif
Endif
#----- Alimentation des codes taxe -----#
Call ALIVATCOD(2,[F:PSD]BPSNUM,[F:PSD]ITMREF,"PSD",0) From TRTX3
Return


#-----------------------------#
# Création d'une entête de DA #
#-----------------------------#
$CREATION_ENTETE
#----- Mise à jour indicateur signée -----#
If [F:PSH]APPLINNBR=0 [F:PSH]APPFLG=1 Else [F:PSH]APPFLG=2 : Endif
If [F:PSH]LINNBR<=[F:PSH]APPLINNBR [F:PSH]APPFLG=3 : Endif
If GAPPPSH<2                       [F:PSH]APPFLG=4 : Endif
If [F:PSH]APPFLG=3
  Filter [PSD] Where PSHNUM=[F:PSH]PSHNUM & LINAPPFLG<>3
  Look [PSD] PSD0 First
  If !fstat  [F:PSH]APPFLG=5 : Endif
  Filter [PSD]
Elsif [F:PSH]APPFLG=1
  Filter [PSD] Where PSHNUM=[F:PSH]PSHNUM & LINAPPFLG>1
  Look [PSD] PSD0 First
  If !fstat  [F:PSH]APPFLG=2 : Endif
  Filter [PSD]
Endif
#-----
If GAPPPSH>1 & [F:PSH]CLEFLG<>2
  [F:PSH]APPFLG=0 : # Pour activation du workflow !
Endif
[F:PSH]CPY=GSOCIETE
#------------------------------------------------------------------#
# Point d'entrée GENPSH pour alimentation de zones spécifiques     #
# ---------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                      #
#                                                                  #
# FICHIER : Nom de la table qui va être écrite                     #
# ABRFIC  : Abréviation de la table qui va être écrite             #
# La  classe  [F:PSH] est modifiable avant le Write                #
# GOK = 0 permet d'abandonner la transaction de création           #
#------------------------------------------------------------------#
FICHIER="PREQUIS"
ABRFIC ="PSH"
GPOINT="GENPSH" : Gosub ENTREE From EXEFNC
If GOK<1  Return : Endif
#----- Mise à jour des statistiques entête DA -----#
Call VALSTA("PSH",+1) From SUBPS2
If GOK<1
  WMSG="PSH"-mess(226,197,1) : # Problème en maj des statistiques
  [M:PMG]ERRCOD=9
  Return
Endif
#----- Ecriture entête DA -----#
CLEFIC=[F:PSH]PSHNUM
WMSG=mess(13,100,1)-"PREQUIS"-CLEFIC : # Erreur d'écriture sur le fichier ...
Write [PSH]
If fstat GOK=0 : Call FSTA("PSH") From GLOCK : Return : Endif
Raz WMSG
#----- Mise à jour du suivi workflow signature -----#
If GAPPPSH>1
  Call WORKPLUS(2,"PSH","C",[F:PSH]PSHNUM,"",0,1,0,WGRPDEB) From AWRK
  If GOK<1  Return : Endif
Endif
#----- Message : Demande d'achat XXXXXXXXXXXXXXX créée ! -----#
GMESSAGE=mess(222,197,1)-[F:PSH]PSHNUM-mess(224,197,1) : Call ECR_TRACE(0)
Raz [F:PSH], WPSDLIN, GMESSAGE
Return

#----------------------------------------------------#
# Modification de demandes d'achat à partir de "POP" #
#----------------------------------------------------#
$MODIFICATION_PSH
Gosub CONTROLE : If [M:PMG]ERRCOD<>0 Return : Endif
Call CONTROLE_ZONES (0)
If GMESSAGE<>"" Call ECR_TRACE(1)  : Return : Endif
Call DEBTRANS From GLOCK
$TR_MODIFICATION
GOK=1 : Raz WMSG, WGRPDEB
Trbegin ADOVAL
  #----- Lecture avec blocage physique de l'entête de DA à modifier -----#
  CLEFIC=[M:PMG]VCRNUM(0)
  WMSG=mess(12,100,1)-"PREQUIS"-CLEFIC : # Erreur d'accès sur le fichier ...
  Readlock [PSH] PSH0=[M:PMG]VCRNUM(0)
  If fstat=1
    GOK=-1 : GLOCK="$PREQUIS"-[M:PMG]VCRNUM(0)
    Goto ROLL_MODIFICATION
  Elsif fstat
    GOK=0  : Call RSTA("PSH",[M:PMG]VCRNUM(0)) From GLOCK
    Goto AB_MODIFICATION
  Endif
  Raz WMSG
  #----- Postionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
  If GAPPPSH>1 & GPSHAPPHEA=2
    Call ANNULE_SUIVI("PSH",mess(652,197,1),1,GBIDI1) From TRTACHDIV1
    If GOK=-1  Goto ROLL_MODIFICATION : Endif
    If GOK=0   Goto AB_MODIFICATION   : Endif
  Endif
  #----- Mise à jour inverse des statistiques entête DA avant modif -----#
  Call VALSTA("PSH",-1) From SUBPS2
  If GOK<1
    WMSG="PSH"-mess(226,197,1) : # Problème en maj des statistiques
    [M:PMG]ERRCOD=9
    Goto AB_MODIFICATION
  Endif
  #----- Lecture avec blocage physique de la ligne de DA à modifier -----#
  CLEFIC=[M:PMG]VCRNUM(0)-num$([M:PMG]VCRLIN(0))
  WMSG=mess(12,100,1)-"PREQUISD"-CLEFIC : # Erreur d'accès sur le fichier ...
  Readlock [PSD] PSD0=[M:PMG]VCRNUM(0);[M:PMG]VCRLIN(0)
  If fstat=1
    GOK=-1 : GLOCK="$PREQUISD"-[M:PMG]VCRNUM(0)-num$([M:PMG]VCRLIN(0))
    Goto ROLL_MODIFICATION
  Elsif fstat
    GOK=0  : Call RSTA("PSD",[M:PMG]VCRNUM(0)-num$([M:PMG]VCRLIN(0))) From GLOCK
    Goto AB_MODIFICATION
  Endif
  Raz WMSG
  #----- Lecture des comptes et sections de la ligne DA -----#
  Read [CAL] CAL0="PSD";0;[F:PSD]PSHNUM;[F:PSD]PSDLIN;0;"";1
  If fstat  Raz [F:CAL] : Endif
  #----- Mise à jour inverse des statistiques ligne DA -----#
  Call VALSTA("PSD",-1) From SUBPS2
  If GOK<1
    WMSG="PSD"-mess(226,197,1) : # Problème en maj des statistiques
    [M:PMG]ERRCOD=9
    Goto AB_MODIFICATION
  Endif
  #----- Suppression du pré-engagement -----#
  If GMODU(2)=2 & GPURCMMPRP=2 & (GAPPPSH<2 | [F:PSD]CMMPRPFLG=1)
    Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,-1,1,"PSD1",2,RETOUR) From TRTACHDIV1
    Raz GERR
    If RETOUR<>0
      WMSG=mess(169,197,1) : # Erreur en mise à jour budget
      If GMESSAGE=""
        If RETOUR=6  GMESSAGE=mess(93,197,1) Else GMESSAGE=mess(173,197,1) : Endif
      Endif
      GMESSAGE+="\"+mess(18,197,1)-num$([F:PSD]PSDLIN)
       If RETOUR=6  Call ECR_TRACE(GMESSAGE,1) From GESECRAN : [M:PMG]ERRCOD=8 : Endif
       If GBUDCTLPSH=2
          If GCTLBUD =2
                 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
          Else   Call ECR_TRACE(GMESSAGE,0) From GESECRAN
          Endif
       Else
        GBUDCTLPSH=1 : GOK=1 : GERR = 0 : Raz GMESSAGE
       Endif
    Endif
    If GOK=0 : Goto AB_MODIFICATION : Endif
  Endif
  [F:PSD]CMMPRPFLG=0
  #----- Postionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
  If GAPPPSH>1 & GPSHAPPHEA<2
    Call ANNULE_SUIVI("PSD",mess(652,197,1),1,GBIDI1) From TRTACHDIV1
    If GOK=-1  Goto ROLL_MODIFICATION : Endif
    If GOK=0   Goto AB_MODIFICATION   : Endif
  Endif
  #----- Soustraction anciennes valeurs de la ligne sur l'entête DA -----#
  MT=[F:PSD]LINAMT
  If [F:PSD]CUR<>GLOCALDEV
    Call CONVERT([F:PSD]CUR,GLOCALDEV,GLOCALDEV,[F:PSD]CHGTYP,datesyst,
&                [F:PSD]LINAMT,MT,GBIDI1) From TRTDEV
  Endif
  [F:PSH]TOTPRQ-=MT
  If [F:PSD]LINAPPFLG>2 [F:PSH]APPLINNBR-=1 : Endif
  If [F:PSD]LINORDFLG>1 [F:PSH]ORDLINNBR-=1 : Endif : # Impossible mais par sécurité
  If [F:PSD]LINCLEFLG>1 [F:PSH]CLELINNBR-=1 : Endif : # Impossible mais par sécurité
  #----- Chargement des valeurs modifiées -----#
  [F:PSD]PRHFCY=[M:PMG]STOFCY(0)
  [F:PSD]PJT   =[M:PMG]PJT(0)
  [F:PSD]QTYPUU=[M:PMG]EXTPUUQTY(0)
  [F:PSD]PUU   =[M:PMG]PUU(0)
  [F:PSD]QTYSTU=[M:PMG]EXTSTUQTY(0)
  #----- Si changement fournisseur, changement devise et type de cours -----#
  If [M:PMG]BPRNUM(0)<>[F:PSD]BPSNUM
    If [M:PMG]BPRNUM(0)=""
      #----- Chargement du régime de taxe et de la devise -----#
      If GPURVACBPR<>""
        [F:PSD]VACBPR=GPURVACBPR
      Else
        # 71937 : Multilégislation
#        Filter [ADI] Where NUMTAB=1 & DEFVAL=2
#        Read [ADI] CODE First
#        Filter [ADI]
#        If !fstat
#          [F:PSD]VACBPR=[F:ADI]CODE
#        Else
#          If func AFNC.ACTIV("LEG") & GCURLEG<>""
#            GBIDC2=GCURLEG
#          Else
#            GBISC2=GDOSLEG(1)
#          Endif
#          Filter [ADI] Where NUMTAB=1 & LEG=GBIDC2 & N1=1
#          Read [ADI] CODE First
#          Filter [ADI]
#          If !fstat
#            [F:PSD]VACBPR=[F:ADI]CODE
#          Else
#            Filter [ADI] Where NUMTAB=1 & LEG="" & N1=1
#            Read [ADI] CODE First
#            Filter [ADI]
#            If !fstat
#              [F:PSD]VACBPR=[F:ADI]CODE
#            Endif
#          Endif
#        Endif
        # Recherche d'un régime actif pour la leg
        Filter [TVB] Where LEG=GCURLEG & REGVAC=1 & ENAFLG=2
        For [TVB]TVB0
            # Si le régime est lié à un groupe on ne prend que si le groupe est ok pour la société
            If [F:TVB]SOC<>""
              Look [AGC]AGC0 = [F:TVB]SOC;GSOCIETE
              If !fstat Break Endif
            Else
              fstat=0 : Break
            Endif
        Next
        Filter [TVB]
        If !fstat
          [F:PSD]VACBPR=[F:TVB]VACBPR
        Else
          # Aucune régime trouvé avec la leg : Recherche d'un régime actif ss leg
          Filter [TVB] Where LEG="" & REGVAC=1 & ENAFLG=2
          For [TVB]TVB0
            # Si le régime est lié à un groupe on ne prend que si le groupe est ok pour la société
            If [F:TVB]SOC<>""
              Look [AGC]AGC0 = [F:TVB]SOC;GSOCIETE
              If !fstat Break Endif
            Else
              fstat=0 : Break
            Endif
          Next
          Filter [TVB]
          If !fstat
            [F:PSD]VACBPR=[F:TVB]VACBPR
          Endif
        Endif
        # 71937 : Multilégislation
      Endif
      #----- Chargement du type de régime taxe -----#
      # 71937 : Multilégislation
#      If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[F:PSD]VACBPR
#        Read [ADI] CODE=1;[F:PSD]VACBPR : If fstat  Raz [F:ADI] : Endif
#      Endif
#      [F:PSD]VACTYP=[F:ADI]N1
      Call LEC_TVB_LEG(GCURLEG,[F:PSD]VACBPR,GRET) From TRTLECLEG
      If GRET  Raz [F:TVB] : Endif
      [F:PSD]VACTYP=[F:TVB]REGVAC
      # 71937 : Multilégislation
      #-----
      [F:PSD]CUR   =GLOCALDEV
      [F:PSD]CHGTYP=GPURCHGTYP
    Else
      #----- Lecture Business Partner si nécessaire -----#
      If [F:BPR]BPRNUM<>[M:PMG]BPRNUM(0)
        Read [BPR] BPR0=[M:PMG]BPRNUM(0)
        If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
      Endif
      #----- Lecture fournisseur si nécessaire -----#
      If [F:BPS]BPSNUM<>[M:PMG]BPRNUM(0)
        Read [BPS] BPS0=[M:PMG]BPRNUM(0)
        If fstat Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : [F:BPS]CHGTYP=GPURCHGTYP : Endif
      Endif
      #----- Chargement du régime de taxe -----#
      [F:PSD]VACBPR=[F:BPS]VACBPR
      Call INIT_REGIME([M:PMG]BPRNUM(0),[F:PSD]PSHFCY,"F",[F:PSD]VACBPR) From CPTSUB
      #----- Chargement du type de régime taxe -----#
      # 71937 : Multilégislation
#      If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[F:PSD]VACBPR
#        Read [ADI] CODE=1;[F:PSD]VACBPR : If fstat  Raz [F:ADI] : Endif
#      Endif
#      [F:PSD]VACTYP=[F:ADI]N1
      Call LEC_TVB_LEG(GCURLEG,[F:PSD]VACBPR,GRET) From TRTLECLEG
      If GRET Raz [F:TVB] : Endif
      [F:PSD]VACTYP=[F:TVB]REGVAC
      # 71937 : Multilégislation
      #-----
      [F:PSD]CUR   =[F:BPS]CUR
      [F:PSD]CHGTYP=[F:BPS]CHGTYP
      #----- Chargement du cours -----#
      Call COURSITE([F:PSD]CUR,[F:PSD]PSHFCY,[F:PSD]CHGTYP,[F:PSH]PRQDAT,
&                  [F:PSD]CHGCOE,RETOUR)    From TRTDEV
      #----- Lecture article si nécessaire -----#
      If [F:ITM]ITMREF<>[F:PSD]ITMREF
        Read [ITM] ITM0=[F:PSD]ITMREF : If fstat  Raz [F:ITM] : Endif
      Endif
      #----- Lecture article-fournisseur -----#
      Read [ITP] ITP0=[F:PSD]ITMREF;[M:PMG]BPRNUM(0)
      If fstat
        Raz [F:ITP] : [F:ITP]PUU=[F:ITM]PUU
      #----- Récupération du texte article-fournisseur -----#
      Elsif !find(left$([F:PSD]LINTEX,3),"PSD") & [F:ITP]TEX<>""
        [F:PSD]LINTEX=[F:ITP]TEX
      Endif
      #----- Modification de l'unité si elle ne convient pas -----#
      If !find([F:PSD]PUU,[F:ITM]PCU(0..dim([F:ITM]PCU)-1)) & [F:PSD]PUU<>[F:ITP]PUU
        [F:PSD]PUU=[F:ITP]PUU
        #----- Recalcul de la quantité en UA à partir de la quantité US -----#
        Call PCAL_QTY([F:PSD]QTYSTU,[F:PSD]STU,[F:PSD]QTYPUU,[F:PSD]PUU,
&                     [F:PSD]ITMREF,[M:PMG]BPRNUM(0),1,GBIDD1) From TRTACHQTE1
        #-----
      Endif
    Endif
    [F:PSD]BPSNUM=[M:PMG]BPRNUM(0)
    #----- Chargement du cours -----#
    Call COURSITE([F:PSD]CUR,[F:PSD]PSHFCY,[F:PSD]CHGTYP,[F:PSH]PRQDAT,
&                [F:PSD]CHGCOE,RETOUR)    From TRTDEV
    #----- Recherche tarif et codes taxes de la ligne -----#
    Gosub TARIF_TAX_LIGNE
  Endif
  #-----
  If [F:PSD]EXTRCPDAT<>[M:PMG]ENDDAT(0)
    [F:PSD]EXTRCPDAT=[M:PMG]ENDDAT(0)
    If [F:ITM]ITMREF<>[F:PSD]ITMREF
      Read [ITM] ITM0=[F:PSD]ITMREF : If fstat Raz [F:ITM] : Endif
    Endif
    If [F:ITF]ITMREF<>[F:PSD]ITMREF | [F:ITF]STOFCY<>[F:PSD]PSHFCY
      Read [ITF] ITF0=[F:PSD]ITMREF;[F:PSD]PSHFCY
      If fstat Raz [F:ITF] : [F:ITF]OFS=[F:ITM]OFS : Endif
    Endif
    [F:PSD]EXTORDDAT=[F:PSD]EXTRCPDAT-[F:ITF]OFS
    #----------------------------------------------------------------------#
    # Point d'entrée CALORDDAT pour modifier la date théorique de commande #
    # -------------------------------------------------------------------- #
    # [F:PSD]EXTORDDAT : Date théorique de commande                        #
    # [F:PSD]EXTRCPDAT : Date de réception souhaitée                       #
    # [F:ITF]OFS       : Délai de réappro                                  #
    # [F:ITF]QUALTI    : Délai contrôle qualité                            #
    # Exemple d'ajustement en fonction du délai contrôle qualité           #
    #   [F:PSD]EXTORDDAT=[F:PSD]EXTORDDAT-[F:ITF]QUALTI                    #
    #----------------------------------------------------------------------#
    GPOINT="CALORDDAT" : Gosub ENTREE From EXEFNC
    #-----
  Endif
  #----- Calcul du montant ligne HT -----#
  [F:PSD]LINAMT=[F:PSD]NETPRI*[F:PSD]QTYPUU
  Call ARRDEV([F:PSD]LINAMT,[F:PSD]CUR) From TRTDIV
  MT=[F:PSD]LINAMT
  If [F:PSD]CUR<>GLOCALDEV
    Call CONVERT([F:PSD]CUR,GLOCALDEV,GLOCALDEV,[F:PSD]CHGTYP,datesyst,
&                [F:PSD]LINAMT,MT,GBIDI1) From TRTDEV
  Endif
  #----- Calcul bases et montants taxes -----#
  Call MAJ_CALTAX_LIG("PSD",0) From TRTACHDIV1
  #----- Modification de l'encours "POP" -----#
  If [F:PSD]WIPNUM<>""
    Read [ORD] ORD0=2;[F:PSD]WIPNUM;[F:PSD]ITMREF
    If fstat  Raz [F:ORD] : Endif
    [M:ORDK]          = [F:ORD]
    [M:ORDK]MAJCOD    = "M"
    [M:ORDK]WIPTYP    = 2
    [M:ORDK]WIPSTA    = 2
    [M:ORDK]WIPNUM    = [F:PSD]WIPNUM
    [M:ORDK]ITMREF    = [F:PSD]ITMREF
    [M:ORDK]STOFCY    = [F:PSD]PRHFCY
    [M:ORDK]PJT       = [F:PSD]PJT
    [M:ORDK]BPRNUM    = [F:PSD]BPSNUM
    [M:ORDK]STRDAT    = [F:PSD]EXTORDDAT
    [M:ORDK]ENDDAT    = [F:PSD]EXTRCPDAT
    [M:ORDK]VCRTYP    = 14
    [M:ORDK]VCRNUM    = [F:PSD]PSHNUM
    [M:ORDK]VCRLIN    = [F:PSD]PSDLIN
    [M:ORDK]VCRSEQ    = 0
    [M:ORDK]EXTQTY    = [F:PSD]QTYSTU
    [M:ORDK]CPLQTY    = [F:PSD]ORDQTYSTU
    [M:ORDK]ALLQTY    = 0
    [M:ORDK]SHTQTY    = 0
    [M:ORDK]FMI       = 1
    [M:ORDK]MRPMES    = 1
    # Issue 71276 - 2015-02-27 by SR : Versions
    If dim([M:ORDK]ECCVALMAJ)> 0
     [M:ORDK]ECCVALMAJ = [F:PSD]ECCVALMAJ
     [M:ORDK]ECCVALMIN = [F:PSD]ECCVALMIN
    Endif
    # End issue 71276
    #----- Chargement infos origine si erreur lecture sur l'ordre à modifier -----#
    If [F:ORD]WIPNUM=""
      [M:ORDK]ORIFCY    = [F:PSD]PSHFCY
      [M:ORDK]VCRTYPORI = 0
      [M:ORDK]VCRNUMORI = ""
      [M:ORDK]VCRLINORI = 0
      [M:ORDK]VCRSEQORI = 0
    Endif
    #-----
    [M:ORDK]BOMALT    = 0
    [M:ORDK]ORI       = 1
    [M:ORDK]ABBFIL    = "PSD"
    Call WIP From TRTWIP
    If GOK<1
      WMSG="2"-[F:PSD]WIPNUM-[F:PSD]ITMREF-mess(92,197,1) : # Problème en maj des encours
      [M:PMG]ERRCOD=7
      Goto AB_MODIFICATION
    Endif
  Endif
  #----- Mise à jour indicateur budget dépassé -----#
  If GMODU(2)=2 & GNBDIE>0 & GPURCMMPRP=2
    Call CTLBUD(RETOUR) From TRTACHPSH1
    If RETOUR<1
      [F:PSD]FBUFLG=2
    Else
      [F:PSD]FBUFLG=1
    Endif
  Endif
  #----- Mise à jour indicateur signature -----#
  If GAPPPSH>1
    If [F:PSD]LINCLEFLG<>2
      [F:PSD]LINAPPFLG=0 : # La màj du suivi et le workflow se fera à réécriture entête !
    Endif
  Else
    [F:PSD]LINAPPFLG=4
  Endif
  #----- Mise à jour du pré-engagement -----#
  If GMODU(2)=2 & GPURCMMPRP=2 & [F:PSD]LINCLEFLG<>2 & (GAPPPSH<2 | GPSHCMMLEV=3)
    Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,+1,1,"PSD1",2,RETOUR) From TRTACHDIV1
    Raz GERR
    If RETOUR<>0
      WMSG=mess(169,197,1) : # Erreur en mise à jour budget
      If GMESSAGE=""
        If RETOUR=6  GMESSAGE=mess(93,197,1) Else GMESSAGE=mess(173,197,1) : Endif
      Endif
      GMESSAGE+="\"+mess(18,197,1)-num$([F:PSD]PSDLIN)
      If RETOUR=6  Call ECR_TRACE(GMESSAGE,1) From GESECRAN : [M:PMG]ERRCOD=8 : Endif
      If GBUDCTLPSH=2
            If GCTLBUD =2
                   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
            Else   Call ECR_TRACE(GMESSAGE,0) From GESECRAN
            Endif
      Else
        GBUDCTLPSH=1 : GOK=1 : GERR = 0 : Raz GMESSAGE
      Endif
    Endif
    If GOK=0 : Goto AB_MODIFICATION : Endif
  Endif
  #----- Mise à jour des statistiques ligne DA -----#
  Call VALSTA("PSD",+1) From SUBPS2
  If GOK<1
    WMSG="PSD"-mess(226,197,1) : # Problème en maj des statistiques
    [M:PMG]ERRCOD=9
    Goto AB_MODIFICATION
  Endif
  #----- Mise a jour date et opérateur dernière modification -----#
  [F:PSD]UPDUSR=GUSER
  [F:PSD]UPDDAT=date$
  #----- Réécriture de la ligne de DA -----#
  CLEFIC=[M:PMG]VCRNUM(0)-num$([M:PMG]VCRLIN(0))
  WMSG=mess(13,100,1)-"PREQUISD"-CLEFIC : # Erreur d'écriture sur le fichier ...
  Rewrite [PSD]
  If fstat
    GOK=0  : Call FSTA("PSD") From GLOCK
    Goto AB_MODIFICATION
  Endif
  Raz WMSG
  #----- Addition nouvelles valeurs de la ligne sur l'entête DA -----#
  [F:PSH]TOTPRQ+=MT
  If [F:PSD]LINAPPFLG>2  [F:PSH]APPLINNBR+=1 : Endif
  If [F:PSD]LINORDFLG>1  [F:PSH]ORDLINNBR+=1 : Endif : # Impossible mais par sécurité
  If [F:PSD]LINCLEFLG>1  [F:PSH]CLELINNBR+=1 : Endif : # Impossible mais par sécurité
  If [F:PSH]APPLINNBR=0  [F:PSH]APPFLG=1 Else [F:PSH]APPFLG=2 : Endif
  If [F:PSH]LINNBR<=[F:PSH]APPLINNBR  [F:PSH]APPFLG=3 : Endif
  If GAPPPSH<2  [F:PSH]APPFLG=4 : Endif
  If [F:PSH]APPFLG=3
    Filter [PSD] Where PSHNUM=[F:PSH]PSHNUM & LINAPPFLG<>3
    Look [PSD] PSD0 First
    If !fstat  [F:PSH]APPFLG=5 : Endif
    Filter [PSD]
  Endif
  If [F:PSH]LINNBR<=[F:PSH]ORDLINNBR [F:PSH]ORDFLG=2 Else [F:PSH]ORDFLG=1 : Endif
  If [F:PSH]LINNBR<=[F:PSH]CLELINNBR [F:PSH]CLEFLG=2 Else [F:PSH]CLEFLG=1 : Endif
  #----- Mise à jour des statistiques entête DA après modif -----#
  Call VALSTA("PSH",+1) From SUBPS2
  If GOK<1
    WMSG="PSH"-mess(226,197,1) : # Problème en maj des statistiques
    [M:PMG]ERRCOD=9
    Goto AB_MODIFICATION
  Endif
  #----- Mise a jour date et opérateur dernière modification -----#
  If GAPPPSH>1 & [F:PSH]CLEFLG<>2
    [F:PSH]APPFLG=0 : # Pour activation du workflow !
  Endif
  [F:PSH]UPDUSR=GUSER
  [F:PSH]UPDDAT=date$
  #----- Réécriture entête DA -----#
  CLEFIC=[M:PMG]VCRNUM(0)
  WMSG=mess(13,100,1)-"PREQUIS"-CLEFIC : # Erreur d'écriture sur le fichier ...
  Rewrite [PSH]
  If fstat
    GOK=0  : Call FSTA("PSH") From GLOCK
    Goto AB_MODIFICATION
  Endif
  Raz WMSG
  #----- Mise à jour du suivi workflow signature -----#
  If GAPPPSH>1
    Call WORKPLUS(2,"PSH","M",[F:PSH]PSHNUM,"",0,1,0,WGRPDEB) From AWRK
    If GOK<1  Return : Endif
  Endif
  #----- Message : Demande d'achat XXXXXXXXXXXXXXX 9999999 modifiée ! -----#
  GMESSAGE=mess(222,197,1)-[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)-mess(223,197,1)
  Call ECR_TRACE(0) : Raz GMESSAGE : [M:PMG]ERRLIN(0)=0
Commit
#----- Envoi des messages groupe workflow signature -----#
If WGRPDEB<>""  Call ENVOI_GROUPE(WGRPDEB) From AWRK : WGRPDEB="" : Endif
Return
$ROLL_MODIFICATION
Rollback
#----- Suppression des message groupe workflow signature -----#
If WGRPDEB<>""  Call VIRE_GROUPE(WGRPDEB)  From AWRK : GOK=0 : WGRPDEB="" : Endif
#-----
Call ROLL From GLOCK
If GROLL
  Gosub AB_TRANSACTION_MSG
  Return
Else
  Goto TR_MODIFICATION
Endif
$AB_MODIFICATION
Rollback
#----- Suppression des message groupe workflow signature -----#
If WGRPDEB<>""  Call VIRE_GROUPE(WGRPDEB)  From AWRK : GOK=0 : WGRPDEB="" : Endif
#-----
Gosub AB_TRANSACTION_MSG
Return

#---------------------------------------------------#
# Suppression de demandes d'achat à partir de "POP" #
#---------------------------------------------------#
$SUPPRESSION_PSH
Gosub CONTROLE : If [M:PMG]ERRCOD<>0 Return : Endif
Call DEBTRANS From GLOCK
$TR_SUPPRESSION
GOK=1 : Raz WMSG
Trbegin ADOVAL
  #----- Suppression du texte ligne si nécessaire -----#
  If left$([F:PSD]LINTEX,3)="PSD"
    Call SUP_CLOB([F:PSD]LINTEX,GBIDI1) From TRTX3TEX
  Endif
  #----- Suppression de l'encours "POP" -----#
  If [F:PSD]WIPNUM<>""
    [M:ORDK]MAJCOD = "A"
    [M:ORDK]WIPTYP = 2
    [M:ORDK]WIPNUM = [F:PSD]WIPNUM
    [M:ORDK]ITMREF = [F:PSD]ITMREF
    Call WIP From TRTWIP
    If GOK<1
      WMSG="2"-[F:PSD]WIPNUM-[F:PSD]ITMREF-mess(92,197,1) : # Problème en maj des encours
      [M:PMG]ERRCOD=7
      Goto AB_SUPPRESSION
    Endif
  Endif
  #----- Suppression du pré-engagement -----#
  If GMODU(2)=2 & GPURCMMPRP=2 & (GAPPPSH<2 | [F:PSD]CMMPRPFLG=1)
    Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,-1,1,"PSD",2,RETOUR) From TRTACHDIV1
    Raz GERR
    If RETOUR<>0
      WMSG=mess(169,197,1) : # Erreur en mise à jour budget
      If GMESSAGE=""
        If RETOUR=6  GMESSAGE=mess(93,197,1) Else GMESSAGE=mess(173,197,1) : Endif
      Endif
      GMESSAGE+="\"+mess(18,197,1)-num$([F:PSD]PSDLIN)
      If RETOUR=6  Call ECR_TRACE(GMESSAGE,1) From GESECRAN : [M:PMG]ERRCOD=8 : Endif
      If GBUDCTLPSH=2
        If GCTLBUD =2
               Call ECR_TRACE(GMESSAGE,1) From GESECRAN
        Else   Call ECR_TRACE(GMESSAGE,0) From GESECRAN
        Endif
      Else
        GBUDCTLPSH=1 : GOK=1 : GERR = 0 : Raz GMESSAGE
      Endif
    Endif
    If GOK=0 : Goto AB_SUPPRESSION : Endif
  Endif
  #----- Postionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
  If GAPPPSH>1 & GPSHAPPHEA<2
    Call ANNULE_SUIVI("PSD",mess(653,197,1),1,GBIDI1) From TRTACHDIV1
    If GOK<1  Goto AB_SUPPRESSION : Endif
  Endif
  #----- Mise à jour inverse des statistiques ligne DA -----#
  Call VALSTA("PSD",-1) From SUBPS2
  If GOK<1
    WMSG="PSD"-mess(226,197,1) : # Problème en maj des statistiques
    [M:PMG]ERRCOD=9
    Goto AB_SUPPRESSION
  Endif
  #----- Lecture avec blocage physique de l'entête DA -----#
  CLEFIC=[M:PMG]VCRNUM(0)
  WMSG=mess(12,100,1)-"PREQUIS"-CLEFIC : # Erreur d'accès sur le fichier ...
  Readlock [PSH] PSH0=[M:PMG]VCRNUM(0)
  If fstat=1
    GOK=-1 : GLOCK="$PREQUIS"-[M:PMG]VCRNUM(0)
    Goto ROLL_SUPPRESSION
  Elsif fstat
    GOK=0  : Call RSTA("PSH",[M:PMG]VCRNUM(0)) From GLOCK
    Goto AB_SUPPRESSION
  Endif
  Raz WMSG
  #----- Mise à jour inverse des statistiques entête DA -----#
  Call VALSTA("PSH",-1) From SUBPS2
  If GOK<1
    WMSG="PSH"-mess(226,197,1) : # Problème en maj des statistiques
    [M:PMG]ERRCOD=9
    Goto AB_SUPPRESSION
  Endif
  #----- Décrémentation du nombre de lignes -----#
  [F:PSH]LINNBR-=1
  If [F:PSH]LINNBR=0
    #----- Postionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
    If GAPPPSH>1 & GPSHAPPHEA=2
      Call ANNULE_SUIVI("PSH",mess(653,197,1),1,GBIDI1) From TRTACHDIV1
      If GOK<1  Goto AB_SUPPRESSION : Endif
    Endif
    #----- Suppression entête DA -----#
    CLEFIC=[M:PMG]VCRNUM(0)
    WMSG=mess(12,100,1)-"PREQUIS"-CLEFIC : # Erreur d'accès sur le fichier ...
    Delete [PSH] Where PSHNUM=[M:PMG]VCRNUM(0)
    If fstat=1
      GOK=-1 : GLOCK="$PREQUIS"-[M:PMG]VCRNUM(0)
      Goto ROLL_SUPPRESSION
    Elsif fstat
      GOK=0  : Call RSTA("PSH",[M:PMG]VCRNUM(0)) From GLOCK
      Goto AB_SUPPRESSION
    Endif
    #-----
    Raz WMSG
    #----- Message : Demande d'achat XXXXXXXXXXXXXXX supprimée ! -----#
    GMESSAGE=mess(222,197,1)-[F:PSH]PSHNUM-mess(170,197,1) : Call ECR_TRACE(0)
    Raz GMESSAGE
    #----- Suppression texte entête et pied si nécessaire -----#
    If left$([F:PSH]TEX1,3)="PSH"
      Call SUP_CLOB([F:PSH]TEX1,GBIDI1) From TRTX3TEX
    Endif
    If left$([F:PSH]TEX2,3)="PSH"
      Call SUP_CLOB([F:PSH]TEX2,GBIDI1) From TRTX3TEX
    Endif
  Else
    #----- Modification entête DA -----#
    MT=[F:PSD]LINAMT
    If [F:PSD]CUR<>GLOCALDEV
      Call CONVERT([F:PSD]CUR,GLOCALDEV,GLOCALDEV,[F:PSD]CHGTYP,datesyst,
&                  [F:PSD]LINAMT,MT,GBIDI1) From TRTDEV
    Endif
    [F:PSH]TOTPRQ-=MT
    If [F:PSD]LINAPPFLG>2  [F:PSH]APPLINNBR-=1 : Endif
    If [F:PSD]LINORDFLG>1  [F:PSH]ORDLINNBR-=1 : Endif : # Impossible mais par sécurité
    If [F:PSD]LINCLEFLG>1  [F:PSH]CLELINNBR-=1 : Endif : # Impossible mais par sécurité
    If [F:PSH]APPLINNBR=0  [F:PSH]APPFLG=1 Else [F:PSH]APPFLG=2 : Endif
    If [F:PSH]LINNBR<=[F:PSH]APPLINNBR  [F:PSH]APPFLG=3 : Endif
    If GAPPPSH<2  [F:PSH]APPFLG=4 : Endif
    If [F:PSH]APPFLG=3
      Filter [PSD] Where PSHNUM=[F:PSH]PSHNUM & LINAPPFLG<>3
      Look [PSD] PSD0 First
      If !fstat  [F:PSH]APPFLG=5 : Endif
      Filter [PSD]
    Endif
    If [F:PSH]LINNBR<=[F:PSH]ORDLINNBR [F:PSH]ORDFLG=2 Else [F:PSH]ORDFLG=1 : Endif
    If [F:PSH]LINNBR<=[F:PSH]CLELINNBR [F:PSH]CLEFLG=2 Else [F:PSH]CLEFLG=1 : Endif
    #----- Mise a jour date et opérateur dernière modification -----#
    [F:PSH]UPDUSR=GUSER
    [F:PSH]UPDDAT=date$
    #----- Réécriture entête DA -----#
    CLEFIC=[M:PMG]VCRNUM(0)
    WMSG=mess(13,100,1)-"PREQUIS"-CLEFIC : # Erreur d'écriture sur le fichier ...
    Rewrite [PSH]
    If fstat
      GOK=0  : Call FSTA("PSH") From GLOCK
      Goto AB_SUPPRESSION
    Endif
    Raz WMSG
    #----- Mise à jour des statistiques entête DA -----#
    Call VALSTA("PSH",+1) From SUBPS2
    If GOK<1
      WMSG="PSH"-mess(226,197,1) : # Problème en maj des statistiques
      [M:PMG]ERRCOD=9
      Goto AB_SUPPRESSION
    Endif
  Endif
  #----- Suppression de la ligne de DA -----#
  CLEFIC=[M:PMG]VCRNUM(0)-num$([M:PMG]VCRLIN(0))
  WMSG=mess(12,100,1)-"PREQUISD"-CLEFIC : # Erreur d'accès sur le fichier ...
  Delete [PSD] Where PSHNUM=[M:PMG]VCRNUM(0) & PSDLIN=[M:PMG]VCRLIN(0)
  If fstat=1
    GOK=-1 : GLOCK="$PREQUISD"-[M:PMG]VCRNUM(0)-num$([M:PMG]VCRLIN(0))
    Goto ROLL_SUPPRESSION
  Elsif fstat
    GOK=0  : Call RSTA("PSD",[M:PMG]VCRNUM(0)-num$([M:PMG]VCRLIN(0))) From GLOCK
    Goto AB_SUPPRESSION
  Endif
  Raz WMSG
  #----- Suppression comptes et sections de la ligne DA -----#
  Delete [CAL] Where ABRFIC="PSD" & VCRNUM=[M:PMG]VCRNUM(0) & VCRLIN=[M:PMG]VCRLIN(0)
  #----- Message : Demande d'achat XXXXXXXXXXXXXXX 9999999 supprimée ! -----#
  GMESSAGE=mess(222,197,1)-[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)-mess(170,197,1)
  Call ECR_TRACE(0) : Raz GMESSAGE : [M:PMG]ERRLIN(0)=0
Commit
Return
$ROLL_SUPPRESSION
Rollback : Call ROLL From GLOCK
If GROLL
  Gosub AB_TRANSACTION_MSG
  Return
Else
  Goto TR_SUPPRESSION
Endif
$AB_SUPPRESSION
Rollback
Gosub AB_TRANSACTION_MSG
Return

#---------------------------------------------#
# Messages en cas d'abandon de la transaction #
#---------------------------------------------#
$AB_TRANSACTION_MSG
If WMSG<>"" GMESSAGE=WMSG : Call ECR_TRACE(1) : Endif
WMSG=GMESSAGE
GMESSAGE=mess(157,199,1)  : Call ECR_TRACE(1) : # Transaction abandonnée
GMESSAGE=WMSG : Raz WMSG
If [M:PMG]ERRCOD=0 [M:PMG]ERRCOD=99 : Endif
Return

#---------------------------------------------------------------#
# Contrôles avant modification ou suppression d'une ligne de DA #
#---------------------------------------------------------------#
$CONTROLE
#----- Contrôle que le type d'ordre est une "POP" -----#
# If [M:PMG]WIPTYP(0)<>2 | [M:PMG]WIPSTA(0)<>2
#   GMESSAGE=mess(219,197,1) : Call ECR_TRACE(1)
#   [M:PMG]ERRCOD=10 : Return
# Endif
#----- Lecture entête DA -----#
Read [PSH] PSH0=[M:PMG]VCRNUM(0)
If fstat
  GMESSAGE=[M:PMG]VCRNUM(0)-mess(220,197,1) : Call ECR_TRACE(1)
  [M:PMG]ERRCOD=11 : Return
Endif
#----- Lecture ligne DA -----#
Read [PSD] PSD0=[M:PMG]VCRNUM(0);[M:PMG]VCRLIN(0)
If fstat
  GMESSAGE=[M:PMG]VCRNUM(0)-num$([M:PMG]VCRLIN(0))-mess(220,197,1) : Call ECR_TRACE(1)
  [M:PMG]ERRCOD=12 : Return
Endif
#----- Modif ou suppression interdite si ligne soldée, commandée ou signée -----#
If [F:PSD]LINCLEFLG=2
  GMESSAGE=mess(21,194,1) : [M:PMG]ERRCOD=13 : # Ligne DA soldée
Endif
If [F:PSD]LINORDFLG=2 | [F:PSD]ORDQTYPUU<>0
  GMESSAGE=mess(19,194,1) : [M:PMG]ERRCOD=14 : # Ligne DA commandée
Endif
If [F:PSD]LINAPPFLG=2 | [F:PSD]LINAPPFLG=3
  GMESSAGE=mess(18,194,1) : [M:PMG]ERRCOD=15 : # Ligne DA signée
Endif
If GMESSAGE<>""
  GMESSAGE=[M:PMG]VCRNUM(0)-num$([M:PMG]VCRLIN(0))-GMESSAGE : Call ECR_TRACE(1)
  Return
Endif
#----- Blocage logique de l'entête de DA -----#
SYMBOL2="PSH"+[M:PMG]VCRNUM(0)
Lock=SYMBOL2
If fstat
  GMESSAGE="$PREQUIS"-[M:PMG]VCRNUM(0)-mess(10,100,1) : Call ECR_TRACE(1)
  [M:PMG]ERRCOD=16 : Return
Endif
#----- Chargement des paramètres -----#
WPSHFCY=[F:PSH]PSHFCY
Gosub CHARG_PARAM
If GMESSAGE<>"" Call ECR_TRACE(1) : Return : Endif
Return

#---------------------------#
# Chargement des paramètres #
#---------------------------#
$CHARG_PARAM
Raz GMESSAGE
Call DEFSITE(WPSHFCY) From TRTACHDEF1
Call GLOBVAR(WPSHFCY) From WWGLOBACH
If GMODU(2)=2
  Call GLOBVAR(GFINRSP) From WWGLOBBUD
Endif
Call DEFBUD("PSH",WPSHFCY)   From TRTACHDEF1
Call DEFRCPFCY(WPSHFCY)      From TRTACHDEF1
Call GETCPY(WPSHFCY,"",0,"") From TRTX3CPT  : If GFINRSP=""  GFINRSP=WPSHFCY : Endif
#----- Lecture des affectations compteur si changement société -----#
If GSOC_UPDFLG
  If dim(OK)<1  Local Integer OK : Endif
  #----- Compteur des demandes d'achat -----#
  Call LECTCA(6,OK) From SUBTCA
  If fstat | !OK
    GMESSAGE=mess(58,105,1)-mess(6,14,1)-mess(250,199,1) : [M:PMG]ERRCOD=1 : Return
  Endif
  GCODNUM=[F:TCA]CODNUM(1)
  #----- Compteur des encours article -----#
  Call LECTCA(7,OK) From SUBTCA
  If fstat | !OK
    GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1) : [M:PMG]ERRCOD=2 : Return
  Endif
  GWIP=[F:TCA]CODNUM(8)
  #----- Contrôle longueur compteur pas supérieure à 15 caractères -----#
  #Call CTRCPT(GWIP,25,OK) From STKLIB
  #If OK<>0
  #  GMESSAGE=mess(222,199,1) : [M:PMG]ERRCOD=3 : Return
  #Endif
Endif
Return

#---------------------------------------#
# Ecriture du message ligne non traitée #
#---------------------------------------#
$ECR_NON_TRAITEE
WMSG=GMESSAGE
GMESSAGE=num$([M:PMG]WIPTYP(I))-[M:PMG]WIPNUM(I)-[M:PMG]ITMREF(I)-mess(225,197,1)
Call ECR_TRACE(1) : # 9 XXXXXXX XXXXXXX Ligne non traitée !
If [M:PMG]ERRCOD=0 [M:PMG]ERRCOD=99 : Endif
GMESSAGE=WMSG
If CONSOFLG=1  Raz WMSG : GOK=0 : Endif
Return

#-----------------------------------------#
# Ecriture du fichier trace si nécessaire #
#-----------------------------------------#
Subprog ECR_TRACE (TRAIT)
Value Integer TRAIT
# Issue X3-55891 - 2018-09-28 by SR : si création on force la trace puisqu'on a forcé son ouverture
If ([M:PMG]TRAFLG=2 | [M:PMG]MAJCOD="C")  & GMESSAGE<>""
  Call ECR_TRACE(GMESSAGE,TRAIT) From GESECRAN
  If GPURTRACE=1 GPURTRACE=2 : Endif
Endif
End

#---------------------------------------------#
# Contrôles zones en création ou modification #
#---------------------------------------------#
Subprog CONTROLE_ZONES (NOL)
Value Integer NOL
Raz GMESSAGE

# Issue X3-55891 - 2018-08-31 by MUARN : exploitation table article/fournisseur/site
Local Integer WRETOUR
Local Integer WITMBPS : WITMBPS = 0

#----- Valeur par défaut des zones à contrôler -----#
If [M:PMG]MAJCOD<>"C" : # En modification
  [M:PMG]ITMREF(NOL)=[F:PSD]ITMREF
  [M:PMG]STU(NOL)   =[F:PSD]STU
  If [M:PMG]STOFCY(NOL)=""      [M:PMG]STOFCY(NOL)=[F:PSD]PRHFCY    : Endif
  If [M:PMG]PJT(NOL)   =""      [M:PMG]PJT(NOL)   =[F:PSD]PJT       : Endif
  If [M:PMG]PUU(NOL)   =""      [M:PMG]PUU(NOL)   =[F:PSD]PUU       : Endif
  If [M:PMG]ENDDAT(NOL)=[0/0/0] [M:PMG]ENDDAT(NOL)=[F:PSD]EXTRCPDAT : Endif
  If [M:PMG]EXTPUUQTY(NOL)=0 & [M:PMG]EXTSTUQTY(NOL)=0
    [M:PMG]EXTSTUQTY(NOL)=[F:PSD]QTYSTU
  Endif
Else                  : # En création
  If [M:PMG]ITMREF(NOL)=""       : # La référence article est nécessaire en création
    mkstat=1 : GMESSAGE=mess(107,194,1) : [M:PMG]ERRCOD=24 : End
  Endif
  If [F:ITM]ITMREF<>[M:PMG]ITMREF(NOL)
    Read [ITM] ITM0=[M:PMG]ITMREF(NOL)
    If fstat
      Raz [F:ITM] : mkstat=1     : # Code article inexistant
      GMESSAGE=[M:PMG]ITMREF(NOL)-":"-mess(134,100,1) : [M:PMG]ERRCOD=25 : End
    Endif
  Endif
  # Issue 112754 - 2016-09-27 by SR : Services
  Call C_ITMREF("PSD",[F:ITM]ITMREF) From TRTACHCTL1
  If mkstat                      : # Article inactif ou non acheté
    [M:PMG]ERRCOD=26 : End
  Elsif [F:ITM]ITMSTA<>1 & [F:ITM]ITMSTA<>3
    GMESSAGE=[M:PMG]ITMREF(NOL)-":"-mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")"
    mkstat=1 : [M:PMG]ERRCOD=26 : End
  Endif
  If [M:PMG]STU(NOL)<>[F:ITM]STU : # Unité de stock incorrecte !
    mkstat=1 : GMESSAGE=[M:PMG]STU(NOL)-mess(228,197,1)-"("+[F:ITM]STU+")"
    [M:PMG]ERRCOD=27 : End
  Endif
  If [M:PMG]PUU(NOL)="" [M:PMG]PUU(NOL)=[F:ITM]PUU : Endif
Endif
#----- Contrôle site de réception -----#
Call C_PRHFCY ([M:PMG]STOFCY(NOL),[M:PMG]ITMREF(NOL)) From TRTACHCTL1
If mkstat [M:PMG]ERRCOD=18 : End : Endif
#----- Contrôle unité d'achat -----#
# Issue 106566 - 2015-02-25 by MUARN : Manque nol pour BPRNUM
Call PCOUOM   ([M:PMG]PUU(NOL),[M:PMG]BPRNUM(NOL),[M:PMG]ITMREF(NOL),3,5) From TRTACHCTL1 : # 3,1) From TRTACHCTL1
If mkstat [M:PMG]ERRCOD=19 : GMESSAGE=[M:PMG]PUU(NOL)-mess(221,197,1) : End : Endif
#----- Contrôle date de réception prévue -----#
If [F:FCY]FCY<>[M:PMG]STOFCY(NOL)
  Read [FCY] FCY0=[M:PMG]STOFCY(NOL) : If fstat Raz [F:FCY] : Endif
Endif
If [M:PMG]PRQDAT=[0/0/0] [M:PMG]PRQDAT=date$ : Endif
Call CTL_JOU2([M:PMG]ENDDAT(NOL),[M:PMG]PRQDAT,[F:FCY]UVYDAY,[F:FCY]UVYCOD,1) From CONTX3
If mkstat [M:PMG]ERRCOD=20 : End : Endif

#----- Contrôle fournisseur -----#
If [M:PMG]BPRNUM(NOL)<>""
  # Issue X3-55891 - 2018-08-31 by MUARN : exploitation table article/fournisseur/site
  # Issue X3-55891 - 2018-09-28 by SR : Déclinaison par site
  Call CTRL_DOUFLG(1,[M:PMG]ITMREF(NOL),[M:PMG]BPRNUM(NOL),[M:PMG]STOFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
  If WRETOUR <> 0
     If WRETOUR =1 : [M:PMG]ERRCOD=23 : End
     Else          : [M:PMG]ERRCOD=22 : End
     Endif
  Endif
  Call CONTROLE("BPS","ABC",[M:PMG]BPRNUM(NOL),"",mkstat) From CONTOBJ
  If mkstat [M:PMG]ERRCOD=28 : End : Endif
  Call CTLBPRCPY ([M:PMG]BPRNUM(NOL),[F:PSH]PSHFCY) From CONTX3
  If mkstat [M:PMG]ERRCOD=21 : End : Endif
  # Issue X3-55891 - 2018-08-31 by MUARN : exploitation table article/fournisseur/site
  # Fait dans CTRL_DOUFLG
# #---- Contrôle article-fournisseur -----#
  #If [F:ITP]ITMREF<>[M:PMG]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:PMG]BPRNUM(NOL)
  #  Read [ITP] ITP0=[M:PMG]ITMREF(NOL);[M:PMG]BPRNUM(NOL)
  #  If fstat Raz [F:ITP]
#    If WRETOUR = 0
#      # Issue 77999 - 2011-11-18 by VPO : référencement inutile si fournisseur de type Divers
#      If [F:BPS]BPSNUM<>[M:PMG]BPRNUM(NOL)
#        Read [BPS] BPS0=[M:PMG]BPRNUM(NOL) : If fstat Raz [F:BPS] : Endif
#      Endif
#      #----- Si fournisseur <> Divers -----#
#      If [F:BPS]BPSTYP<>3
#        If [F:ITM]ITMREF<>[M:PMG]ITMREF(NOL)
#          Read [ITM] ITM0=[M:PMG]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
#        Endif
#        #----- Si article non générique -----#
#        If [F:ITM]GENFLG<>2
#          If GITMBPS=1        : # Article-fournisseur obligatoire !
#            mkstat=1 : GMESSAGE=[M:PMG]ITMREF(NOL)-mess(8,194,1)
#            [M:PMG]ERRCOD=22 : End
#          Endif
#        Endif
#      Endif
    # Issue X3-55891 - 2018-08-31 by MUARN : exploitation table article/fournisseur/site
    #Elsif [F:ITP]DOUFLG=3 : # Article douteux pour ce fournisseur !
  #Endif
Endif
#----- Calcul quantité en UA ou US -----#
If [M:PMG]EXTSTUQTY(NOL)=0
  Call PCAL_QTY ([M:PMG]EXTPUUQTY(NOL),[M:PMG]PUU(NOL),[M:PMG]EXTSTUQTY(NOL),
&     [M:PMG]STU(NOL),[M:PMG]ITMREF(NOL),[M:PMG]BPRNUM(NOL),1,GBIDD1) From TRTACHQTE1
Else
  Call PCAL_QTY ([M:PMG]EXTSTUQTY(NOL),[M:PMG]STU(NOL),[M:PMG]EXTPUUQTY(NOL),
&     [M:PMG]PUU(NOL),[M:PMG]ITMREF(NOL),[M:PMG]BPRNUM(NOL),1,GBIDD1) From TRTACHQTE1
Endif
End

#-------------------------------------------------------------------#
# Contrôle budget d'une ligne DA pour màj indicateur de dépassement #
#-------------------------------------------------------------------#
Subprog CTLBUD (RETOUR)
Variable Integer RETOUR
RETOUR=1
#-----
If GMODU(2)<>2 | GNBDIE<1 | GBUDCTLPSH<>2 | GBUDCTLPSL<>2 | GCTLBUD<2
  End
Endif
#-----
Local Integer I
Local Char    WCOA   (GLONCOA)
Local Char    TBDIE  (GLONDIE)(1..max(GNBDIE,GOPTCANA))
Local Char    TBCCE  (GLONCCE)(1..max(GNBDIE,GOPTCANA))
Local Char    TBDIE2 (GLONDIE)(1..max(GNBDIE,GOPTCANA))
Local Char    TBCCE2 (GLONCCE)(1..max(GNBDIE,GOPTCANA))
Local Char    WCPTANA(GLONGAC)
Local Decimal WQTE
#----- Récupération compte analytique -----#
Call LECPLAN(GSOCIETE,GTYPANA,WCOA) From CPTDIV
I=find(WCOA,[F:CAL]COA(0..9))
If I
  WCPTANA=[F:CAL]ACC(I-1)
  If [F:GAC]COA<>WCOA | [F:GAC]ACC<>WCPTANA
    Read [GAC] GAC0=WCOA;WCPTANA
    If fstat  Raz [F:GAC] : [F:GAC]UOM=[F:PSD]STU : Endif
  Endif
Else
  End
Endif
#----- Chargement des axes et sections -----#
For I=1 To max(GNBDIE,GOPTCANA)
  TBDIE(I)=[F:CAL]DIE(I-1)
  TBCCE(I)=[F:CAL]CCE(I-1)
Next I
#----- Filtrage des codes et sections analytiques sur référentiel analytique -----#
Call SETCCEAXE(GSOCIETE,GTYPANA,TBDIE,TBCCE,TBDIE2,TBCCE2) From CPTDIV
#----- Traitement de la quantité en unité d'oeuvre -----#
WQTE=[F:PSD]QTYPUU
If [F:GAC]UOM<>[F:PSD]PUU
  If [F:GAC]UOM=[F:PSD]STU
    WQTE=[F:PSD]QTYSTU
  Else
    Call PCAL_QTY([F:PSD]QTYPUU,[F:PSD]PUU,WQTE,[F:GAC]UOM,
&                 [F:PSD]ITMREF,[F:PSD]BPSNUM,1,GBIDD1) From TRTACHQTE1
    If [F:TCO]UOM1="" & [F:TCO]COEUOM=1
      Call PCAL_QTY([F:PSD]QTYSTU,[F:PSD]STU,WQTE,[F:GAC]UOM,
&                   [F:PSD]ITMREF,[F:PSD]BPSNUM,1,GBIDD1) From TRTACHQTE1
    Endif
  Endif
Endif
#-----
Call BUDGET([F:PSD]EXTRCPDAT,GFINRSP,GTYPANA,[F:PSD]CUR,WCPTANA,
&           TBDIE2,TBCCE2,[F:PSD]LINAMT,WQTE,0,RETOUR,GMESSAGE) From CPTBUD
End


####################################################################
# Appel du point d'entrée CONSOPSH depuis :                        #
#     - le traitement SUBPOIA (prise en compte DA depuis les plans #
#     - le traitement SUBPOHB (prise en compte DA depuis les cdes  #
# ---------------------------------------------------------------- #
# Permet de solder une ligne DA partiellement consommée            #
# [L]WSOLDPSH : Indicateur de solde de la ligne de DA              #
#               0-1=Gestion normale du solde                       #
#                 2=Le solde est forcé à OUI                       #
####################################################################
$POINT_CONSOPSH
Local Libelle WSOLDPSH : [L]WSOLDPSH=1
GPOINT="CONSOPSH" : Gosub ENTREE From EXEFNC
#----- Si la qté consommée solde naturellement la ligne DA, mettre l'indicateur à 1 -----#
If [L]WSOLDPSH=2 & [F:PWO]QTYSTU>=[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
  [L]WSOLDPSH=1
Endif
#----- Si solde forcé alors suppression de l'encours POP -----#
If [L]WSOLDPSH=2 & [F:PWO]PSDLIN=0 & [F:PWO]WIPTYP=2
  [M:ORDK]MAJCOD="A"
  [M:ORDK]WIPTYP=2
  [M:ORDK]WIPNUM=[F:PSD]WIPNUM
  [M:ORDK]ITMREF=[F:PSD]ITMREF
  Call WIP From TRTWIP
Endif
Return

