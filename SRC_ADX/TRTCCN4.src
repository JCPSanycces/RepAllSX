#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################
#   Recherche d'un interlocuteur                                     Module CRM         27 février 2001  #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  If PARAM(1) <> "" Then
    [M:CCN4]CCNLNA = PARAM(1)
    Affzo [M:CCN4]CCNLNA
  Endif
  If PARAM(2) <> "" Then
    [M:CCN4]CCNFNA = PARAM(2)
    Affzo [M:CCN4]CCNFNA
  Endif
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:CCN4]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      If (nolign-1) >= 0 Then
        If [M:CCN4]CCNNUM(nolign-1) <> "" Then
          VALEUR = [M:CCN4]CCNNUM(nolign-1)
          FIN = 1
        Endif
      Endif
    When "C"
      Gosub ONLOAD
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONLOAD
Local Char SZWHERE(250)
Local Char SZVALEUR(250)
Local Char SZRECHERCHE(250)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL

  Raz SZWHERE
  Raz SZVALEUR
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Effzo [M:CCN4]15
  [M:CCN4]NBREC = 0
  SZWHERE = " [F:AIN]CNTTYP=1 "
  If [M:CCN4]CCNLNA <> "" Then
    SZVALEUR = [M:CCN4]CCNLNA
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE = SZWHERE + " and pat(toupper([F:AIN]CNTLNA)," + SZRECHERCHE + ")<>0 "
  Endif
  If [M:CCN4]CCNFNA <> "" Then
    SZVALEUR = [M:CCN4]CCNFNA
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE = SZWHERE + " and pat(toupper([F:AIN]CNTFNA)," + SZRECHERCHE + ")<>0 "
  Endif
  If SZWHERE <> "" Then
    Filter [AIN] Where evalue(SZWHERE) Order By [F:AIN]CNTLNA Desc; [F:AIN]CNTFNA Desc
  Else
    Filter [AIN] Order By [F:AIN]CNTLNA Desc; [F:AIN]CNTFNA Desc
  Endif
  INBLIGNETOTAL = rowcount([AIN])
  For [AIN]
    If ILIGNE >= dim([M:CCN4]NAM)-1 Then
      Break
    Endif
    Call BUILDFULNAM("AIN", [M:CCN4]NAM(ILIGNE)) From CRMUTIL140
    [M:CCN4]CCNNUM(ILIGNE) = [F:AIN]CNTNUM
    [M:CCN4]ZIP(ILIGNE) = [F:AIN]ZIP
    [M:CCN4]CTY(ILIGNE) = [F:AIN]CTY
    [M:CCN4]TEL(ILIGNE) = [F:AIN]CNTETS
    [M:CCN4]CRY(ILIGNE) = [F:AIN]CRY
    ILIGNE += 1
  Next
  Filter [AIN]
  [M:CCN4]NBREC = ILIGNE
  Affzo [M:CCN4]1-99
  If ILIGNE < INBLIGNETOTAL Then
    #Tous les enregistrements n'ont pas pu être affichés, un critère plus discriminant doit être saisi.
    GMESSAGE = mess(963,182,1)
    GERR = 2
  Endif
  Affzo [M:CCN4]1-99
Return
