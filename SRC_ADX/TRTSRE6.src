#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
#   Précision d'un site tiers sur une demande de service            Module CRM           1 juillet 2002 #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub FINSAI
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GPRESRE6NOL
Global Char GSZSRE6BPC(GLONBPC)

  GPRESRE6NOL = 0
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
Return

##########################################################################################################
$DEBUT
  GSZSRE6BPC = [M:SRE0]SREBPC
  Call LOADSRE6
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:SRE6]
  Kill GSZSRE6BPC
  Kill GPRESRE6NOL
Return

##########################################################################################################
$ONOK
  If [M:SRE0]SRENUM = "" Then
    #On est en création
    #On se contente d'alimenter le champ Ecran
    [M:SRE0]SREBPAADD = [M:SRE6]CURBPAADD
    Read [BPR]BPR0=[M:SRE0]SREBPC
    If fstat Then
      [M:SRE0]SREBPCCLA = [M:SRE0]SREBPC
      [M:SRE0]SREBPAADD = ""
    Else
      [M:SRE0]SREBPCCLA = [F:BPR]BPRNAM
      Read [BPA]BPA0=1;[M:SRE0]SREBPC;[M:SRE6]CURBPAADD
      If !fstat Then
        If [F:BPA]BPADES = "" Then
          [M:SRE0]SREBPCCLA = [M:SRE0]SREBPCCLA + " / " + [F:BPA]BPAADD
        Else
          [M:SRE0]SREBPCCLA = [M:SRE0]SREBPCCLA + " / " + [F:BPA]BPADES
        Endif
      Endif
    Endif
  Else
    Call DEBTRANS From GLOCK
    Trbegin [SRE]
    Readlock [SRE]SRE0=[M:SRE0]SRENUM
    If fstat Then
      #Erreur lors de la définition du site client.
      GMESSAGE = mess(775,196,1)
      GERR = 1
      Rollback
    Else
      [F:SRE]SREBPAADD = [M:SRE6]CURBPAADD
      Rewrite [SRE]
      If fstat Then
        #Erreur lors de la définition du site client.
        GMESSAGE = mess(775,196,1)
        GERR = 1
        Rollback
      Else
        Commit
        Unlock [SRE]
        [M:SRE0]SREBPAADD = [M:SRE6]CURBPAADD
        Read [BPR]BPR0=[M:SRE0]SREBPC
        If fstat Then
          [M:SRE0]SREBPCCLA = [M:SRE0]SREBPC
          [M:SRE0]SREBPAADD = ""
        Else
          [M:SRE0]SREBPCCLA = [F:BPR]BPRNAM
          Read [BPA]BPA0=1;[M:SRE0]SREBPC;[M:SRE6]CURBPAADD
          If !fstat Then
            If [F:BPA]BPADES = "" Then
              [M:SRE0]SREBPCCLA = [M:SRE0]SREBPCCLA + " / " + [F:BPA]BPAADD
            Else
              [M:SRE0]SREBPCCLA = [M:SRE0]SREBPCCLA + " / " + [F:BPA]BPADES
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  Affzo [M:SRE0]SREBPC, SREBPCCLA
Return

###########################################################################################################
# Sous-programmes
############################################################################
Subprog LOADSRE6

Local Integer ITER

  ITER = 0
  Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [M:SRE0]SREBPC Order By [F:BPA]BPAADD
  For [BPA]
    If ITER >= dim([M:SRE6]CODADR) Then
      Break
    Endif
    If ITER = 0 Then
      [M:SRE6]NBADRSEL(ITER) = "->"
    Else
      [M:SRE6]NBADRSEL(ITER) = ""
    Endif
    [M:SRE6]CODADR(ITER) = [F:BPA]BPAADD
    [M:SRE6]BPADES(ITER) = [F:BPA]BPADES
    [M:SRE6]POSCOD(ITER) = [F:BPA]POSCOD
    [M:SRE6]CTY(ITER) = [F:BPA]CTY
    [M:SRE6]SAT(ITER) = [F:BPA]SAT
    [M:SRE6]BPACRY(ITER) = [F:BPA]CRY
    If ITER = 0 Then
      [M:SRE6]CURBPAADD = [M:SRE6]CODADR(ITER)
      Call SETCURADD(1, [F:BPA]BPANUM, [F:BPA]BPAADD)
    Endif
    ITER += 1
  Next
  Filter [BPA]
  [M:SRE6]NBADR = ITER
  Affzo [M:SRE6]1-99
End

##########################################################################################################
Subprog SETCURADD(ITYP, SZBPANUM, SZBPAADD)
Value Integer ITYP
Value Char SZBPANUM
Value Char SZBPAADD

  Local File BPADDRESS [BPA2]
  Read [BPA2]BPA0=ITYP;SZBPANUM;SZBPAADD
  If !fstat
    [M:SRE6]XBPADES = [F:BPA2]BPADES
    [M:SRE6]XLIG(0) = [F:BPA2]BPAADDLIG(0)
    [M:SRE6]XLIG(1) = [F:BPA2]BPAADDLIG(1)
    [M:SRE6]XLIG(2) = [F:BPA2]BPAADDLIG(2)
    [M:SRE6]XBPACRY = [F:BPA2]CRY
    [M:SRE6]XSAT = [F:BPA2]SAT
    [M:SRE6]XPOSCOD = [F:BPA2]POSCOD
    [M:SRE6]XCTY = [F:BPA2]CTY
    [M:SRE6]XTEL = [F:BPA2]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA2]TEL
    [M:SRE6]XFAX = [F:BPA2]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA2]FAX
    [M:SRE6]XWEB = [F:BPA2]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA2]WEB
  Endif
End

