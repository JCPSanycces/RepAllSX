# Class EMPLOIDESS


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"              : Gosub AREAD_AFTER
    Endcase
Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

$AREAD_AFTER
#Set attributes(visible) based on legislation
Gosub SET_ATT_LEG
Return

$SET_ATT_LEG

If func DIVPAYE.IS_KZA(this.IDES.TCH_LEG)
  ASTATUS = fmet this.ASETLINKENABLE("EMPLOIDESKZA",[V]CST_AFFLNKREC)
Else
  ASTATUS = fmet this.ASETLINKDISABLE("EMPLOIDESKZA",[V]CST_AFFLNKREC)
Endif

If func DIVPAYE.IS_AFRICA_LEG(this.IDES.TCH_LEG)
  ASTATUS = fmet this.ASETLINKENABLE("EPLOIDESKFR",[V]CST_AFFLNKREC)
Else
  ASTATUS = fmet this.ASETLINKDISABLE("EPLOIDESKFR",[V]CST_AFFLNKREC)
Endif







