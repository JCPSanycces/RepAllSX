#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
#   Gestion des reports d'appels                         Module CRM         18 juillet 2000
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
#PARAM(1) : Date rendez-vous
#PARAM(1) : Heure rendez-vous
#PARAM(3) : Code appel
#PARAM(4) : Numéro tiers
#PARAM(5) : Code contact
#PARAM(6) : Représentant 1
#PARAM(7) : Fonction appelante
#PARAM(8) : Numéro de la ligne couran

##########################################################################################################
$OUVRE
Local Integer ISAOBLOCKED

  ISAOBLOCKED = 0
  #Vérification du lock superviseur posé sur l'enregistrement
  Call ISAOB2LOCKED(PARAM(3), "CLL", ISAOBLOCKED) From CRMUTIL140
  If ISAOBLOCKED Then
    #Modification en cours sur un autre poste.
    GMESSAGE = mess(10,100,1)
    GERR = 2
    FIN = 1 
    Return
  Endif
  If !clalev ([F:CTT]) : Local File CALLATTEMP [CTT] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:CLL6]TECDRDAT = PARAM(1) : # FGR 13/05/2008 : X3SUIVI47211 pour remplacer la variable DRDAT
  [M:CLL6]TECHRHOU = PARAM(2) : # FGR 13/05/2008 : X3SUIVI47211 pour remplacer la variable SZRHOU
  # FGR 09/08/2011 : X3SUIVI75657 (début)
  #Grizo [M:CLL6]DEYDAT
  #Grizo [M:CLL6]DEYHOU
  #[M:CLL6]DEY1 = 1
  #[M:CLL6]DEYDAT = [00/00/00]
  #[M:CLL6]DEYHOU = ""
  If [M:CLL6]TECDRDAT > date$ or ([M:CLL6]TECDRDAT = date$ and [M:CLL6]TECHRHOU > time$) Then
    [M:CLL6]DEY1 = 6
    Diszo [M:CLL6]DEY1
    [M:CLL6]DEYDAT = [M:CLL6]TECDRDAT
    [M:CLL6]DEYHOU = [M:CLL6]TECHRHOU
  Else
    [M:CLL6]DEY1 = 1
    [M:CLL6]DEYDAT = [00/00/00]
    [M:CLL6]DEYHOU = ""
    Diszo [M:CLL6]DEYDAT
    Diszo [M:CLL6]DEYHOU
  Endif
  # FGR 09/08/2011 : X3SUIVI75657 (fin)
  Affzo [M:CLL6]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONOK
  Gosub CONFDEY
Return

##########################################################################################################
# Traitement du bouton de confirmation du report
$CONFDEY
Local Integer CTTLASTKEY
Local Char SZNHOU
Local Date DRDAT
Local Char SZRHOU
Local Char SZCALL
Local Char SZCALFUN
Local Integer INOLIGNE

  CTTLASTKEY = 0
  SZNHOU = ""
  ILIGNE = val(PARAM(8))
  DRDAT = PARAM(1)
  SZRHOU = PARAM(2)
  SZCALL = PARAM(3)
  SZCALFUN = PARAM(7)
  If [M:CLL6]DEY1 = 1 Then
    #Report de 5 minutes
    DRDAT = date$
    SZRHOU = left$(time$, 2) + mid$(time$, 4, 2)
    Call GETNEWHOUR(SZRHOU, 5, SZNHOU) From CRM_UTIL
    SZRHOU = SZNHOU
  Elsif [M:CLL6]DEY1 = 2 Then
    #Report de 10 minutes
    DRDAT = date$
    SZRHOU = left$(time$, 2) + mid$(time$, 4, 2)
    Call GETNEWHOUR(SZRHOU, 10, SZNHOU) From CRM_UTIL
    SZRHOU = SZNHOU
  Elsif [M:CLL6]DEY1 = 3 Then
    #Report de une demi-heure
    DRDAT = date$
    SZRHOU = left$(time$, 2) + mid$(time$, 4, 2)
    Call GETNEWHOUR(SZRHOU, 30, SZNHOU) From CRM_UTIL
    SZRHOU = SZNHOU
  Elsif [M:CLL6]DEY1 = 4 Then
    #Report de une heure
    DRDAT = date$
    SZRHOU = left$(time$, 2) + mid$(time$, 4, 2)
    Call GETNEWHOUR(SZRHOU, 60, SZNHOU) From CRM_UTIL
    SZRHOU = SZNHOU
  Elsif [M:CLL6]DEY1 = 5 Then
    #Report de une journée
    DRDAT += 1
    SZRHOU = left$(time$, 2) + mid$(time$, 4, 2)
  Elsif [M:CLL6]DEY1 = 6 Then
    #Report personnalisé
    DRDAT = [M:CLL6]DEYDAT
    SZRHOU = [M:CLL6]DEYHOU
  Endif
  #Calcul tout d'abord une nouvelle clé de tentative d'appel
  CTTLASTKEY= nbrecord([CTT]) + 1
  While 1
    Read [CTT]CTT0=num$(CTTLASTKEY)
    If fstat Then
      Break
    Endif
    CTTLASTKEY += 1
  Wend
  #Enregistrement du report sur l'appel en cours.
  Read [CLL]CLL0=SZCALL
  If fstat Then
    GMESSAGE = mess(157,199,1) #Transaction abandonnée. Erreur ou conflit d'accès.
    GERR = 1
    Return
  Else
    Call DEBTRANS From GLOCK
    Trbegin [CLL], [CTT]
    [F:CLL]CLLDAT = DRDAT
    [F:CLL]CLLHOU = SZRHOU 
    [F:CLL]CLLWEE = week(DRDAT)
    [F:CLL]CLLDATX = DRDAT 
    [F:CLL]CLLTNTPRE += 1
    Rewrite [CLL]
    If fstat Then
      Rollback
      GMESSAGE = mess(157,199,1) #Transaction abandonnée. Erreur ou conflit d'accès.
      GERR = 1
      Return
    Endif
  Endif
  #Enregistrement d'une tentative d'appel supplémentaire.
  [F:CTT]CTTNUM = num$(CTTLASTKEY)
  [F:CTT]CTTDAT = date$
  [F:CTT]HOUCRE = left$(time$, 2) + mid$(time$, 4, 2)
  [F:CTT]CLLNUM = PARAM(3)
  [F:CTT]CTTCMP = PARAM(4)
  [F:CTT]CTTCCN = PARAM(5)
  [F:CTT]CTTREP = PARAM(6)
  Write [CTT]
  If fstat Then
    Rollback
    GMESSAGE = mess(157,199,1) #Transaction abandonnée. Erreur ou conflit d'accès.
    GERR = 1
    Return
  Endif
  Commit
  If SZCALFUN = "OCLL" Then
    [M:CLL1]CLLDAT = DRDAT
    [M:CLL1]CLLHOU = SZRHOU 
    [M:CLL1]CLLWEE = week(DRDAT)
    [M:CLL1]CLLDATX = DRDAT
    Affzo [M:CLL1]1-99
    [M:CLL3]CLLTNTPRE += 1
    Affzo [M:CLL3]1-99
  Elsif SZCALFUN = "CRM2" Then
    [M:CRM2]CLLDAT(ILIGNE) = DRDAT
    [M:CRM2]CLLHOU(ILIGNE) = SZRHOU 
    [M:CRM2]CLLWEEK(ILIGNE) = num$(week(DRDAT))
    [M:CRM2]NBRTNT(ILIGNE) += 1
    Affzo [M:CRM2]CLLDAT(ILIGNE)
    Affzo [M:CRM2]CLLHOU(ILIGNE)
    Affzo [M:CRM2]CLLWEEK(ILIGNE)
    Affzo [M:CRM2]NBRTNT(ILIGNE)
  Elsif SZCALFUN = "CRM5" Then
    [M:CRM5]DAT(ILIGNE) = DRDAT
    [M:CRM5]HOU(ILIGNE) = SZRHOU 
    [M:CRM5]TNT(ILIGNE) += 1
    Affzo [M:CRM5]DAT(ILIGNE)
    Affzo [M:CRM5]HOU(ILIGNE)
    Affzo [M:CRM5]TNT(ILIGNE)
  Endif
Return
