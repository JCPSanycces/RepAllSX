#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management VXINDO


$ACTION
  Case ACTION
    When "DEBUT"         : Gosub DEBUT
    When "OK"            : Gosub OK
  Endcase
Return

######################################################################################
$DEBUT
  Raz [M:XINDO]
  Affzo [M:XINDO]
Return

######################################################################################
$OK
  Local Instance SFTTXN Using C_SFTTXN
  SFTTXN = NewInstance C_SFTTXN AllocGroup null
  Local Integer   CSTATUS
  Local Datetime  STOPTIME
  Local Char      ERRMSG(255)

  Local Integer  SFTTYP(1)
  Local Char     INDREF(20)(1)
  Local Integer  SFTSEQ(1)
  Local Integer  INDTYP(1)
  Local Integer  BLANK_INT(1) : BLANK_INT = AVOID.AINT
  Local Integer  ONE_INT (1)    : ONE_INT = [V]CST_ANO     # TODAN-119641.n

  Local Integer EMPLIST(1..)
  EMPLIST(1) = [M:XINDO]EMPNUM
  Call TEAM_LIST ([M:XINDO]EMPNUM, "A", EMPLIST) From SFTLIB

  Local File SFTTXN [SFTX]
  Filter [SFTX] Where EMPNUM = EMPLIST(1) and INDREF = [M:XINDO]INDREF and UTCENDDATTIM = AVOID.ADATTIM
  Read [SFTX] First
  If fstat
    GMESSAGE = mess(23,100,1)
    mkstat = 1
    Return
  Endif


  [L]STOPTIME = datetime$

  SFTTYP(0) = [F:SFTX]SFTTYP
  INDREF(0) = ""
  SFTSEQ(0) = [F:SFTX]SFTSEQ
  INDTYP(0) = [F:SFTX]INDTYP

  Call STOP_OPERATIONS([M:XINDO]EMPNUM, [M:XINDO]FCY, SFTTYP, INDREF, AVOID.AINT, SFTSEQ,
&                       INDTYP, BLANK_INT, BLANK_INT, BLANK_INT, ONE_INT, 1) From SFTLIB   # TODAN-119090/119641.n
#  Call STOP_OPERATIONS([M:XINDO]EMPNUM, [M:XINDO]FCY, SFTTYP, INDREF, AVOID.AINT, SFTSEQ, INDTYP, BLANK_INT, BLANK_INT, BLANK_INT, BLANK_INT, 1) From SFTLIB

  FreeGroup SFTTXN

  Local Date ODATE
  Local Char OTIME(5)
  Call TIMESTAMP([M:XINDO]FCY, ODATE, OTIME) From SFTLIB
  OTIME = left$(OTIME,2) + ":" + right$(OTIME,3)
  Call MESSAGE(func AFNC.MES2(mess(78,2422,1), [M:XINDO]INDREF, OTIME)) From GESECRAN

Return
######################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal VALEUR

  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif
  Read [TMA]TMA0=VALEUR
  If fstat
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 1
    End
  Endif

  LogicClose File [TMA]

  If func SFTLIB.EMPLOYEEACTIVE(VALEUR) = [V]CST_ANO
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(2,126,1)
    mkstat = 1
    End
  Endif

End

######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR

  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif

  Read [TMA]TMA0=VALEUR

  [M:XINDO]EMPDES = [F:TMA]EMPDES
  [M:XINDO]FCY=[F:TMA]DEFFCY
  [M:XINDO]EMPTYP = [F:TMA]EMPTYP

  LogicClose File [TMA]

End

######################################################################################
Subprog C_INDREF(VALEUR)
Variable Char    VALEUR()

  Local Integer EMPLIST(1..)
  EMPLIST(1) = [M:XINDO]EMPNUM
  Call TEAM_LIST ([M:XINDO]EMPNUM, "A", EMPLIST) From SFTLIB

  Local File SFTTXN [SFTX]
  Filter [SFTX] Where INDREF  = VALEUR and EMPNUM = EMPLIST(1) and FCY = [M:XINDO]FCY and UTCENDDATTIM  = AVOID.ADATTIM
  Look [SFTX] First
  If fstat
    GMESSAGE = func AFNC.MES1(mess(80,2422,1), VALEUR)
    mkstat = 1
    End
  Endif
  LogicClose File [SFTX]

End

######################################################################################
Subprog AM_INDREF(VALEUR)
Variable Char    VALEUR()

  Local File SFTINDREF [SFTIR]
  Read [SFTIR]SFTAG0 = VALEUR

  [M:XINDO]INDTYP = [F:SFTIR]INDTYP

  LogicClose File [SFTIR]

End

######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer  EMP_LIST(1..)

  Local Char PARAMRET(4)
  Raz PARAMRET

  # check if clock in is needed for this site
  Call PARAM(VALEUR,"SFTEMPCLK",PARAMRET) From ADOVAL
  If val([L]PARAMRET) = [V]CST_AYES
    If [M:XINDO]EMPTYP = 2
      #X3-1717 sn
      # Check if team members are clocked in or not on any individual activities
      Call TEAM_LIST ([M:XINDO]EMPNUM, 'A', EMP_LIST) From SFTLIB
      If maxtab(EMP_LIST) = 0   # No team member found
        Call ERREUR(func AFNC.MES1(mess(110,2422,1), num$([M:XINDO]EMPNUM))) From GESECRAN
        mkstat = 1
        End
      Endif
      #X3-1717 en
    Else #Detailed teams dont clock in
      If func SFTLIB.EMPLOYEE_CLOCKED_IN([M:XINDO]EMPNUM) = [V]CST_ANO
        Call ERREUR(func AFNC.MES1(mess(12,2422,1), num$([M:XINDO]EMPNUM))) From GESECRAN #CT-1797
        mkstat = 1
        End
      Endif
    Endif
  Elsif [M:XINDO]EMPTYP = 2 #Detailed teams must be on sites that require clock-in
    GMESSAGE = func AFNC.MES1(mess(111,2422,1), "SFTEMPCLK")
    mkstat = 1
    End
  Endif

End


######################################################################################

