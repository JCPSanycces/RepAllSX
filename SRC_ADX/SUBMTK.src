Subprog AS_CPLOPETIM(VALEUR)
Variable Decimal VALEUR
End

########################################
#Saisie des temps par borne début et fin
Subprog B3_CPLOPETIM(VALEUR)
Variable Decimal VALEUR
#Local Char WMANIP
Call AM_CPLOPETIM(VALEUR)
End

########################################
Subprog AM_CPLOPETIM(VALEUR)
Variable Decimal VALEUR
If instr(1,dbgstr(1),"MTO1")
    #recalcul du tps unitaire
    If [M:MTO1]CPLUNTTIM <> 0 & [M:MTO1]CPLQTY <> 0
         [M:MTO1]COEFFTPS = (VALEUR / [M:MTO1]CPLQTY)/[M:MTO1]CPLUNTTIM
    Else [M:MTO1]COEFFTPS = 1
    Endif
    If [M:MTO1]CPLQTY <> 0 & [M:MTO1]ROOTIMCOD <> 3 : # FQ 42739 01/2008 sauf si temps forfait
        [M:MTO1]CPLUNTTIM =  VALEUR / [M:MTO1]CPLQTY
    Endif

     # 11.06 demande 38402
     [M:MTO1]CPLUNTTIM = func TRTX3.ARRTYP("","","TIH",[M:MTO1]CPLUNTTIM)
    Affzo [M:MTO1]CPLUNTTIM
Else
    #recalcul du tps unitaire
    If [M:MTK1]CPLUNTTIM(nolign-1) <> 0 & [M:MTK1]CPLQTY(nolign-1) <> 0
         [M:MTK1]COEFFTPS(nolign-1) = (VALEUR / [M:MTK1]CPLQTY(nolign-1))/[M:MTK1]CPLUNTTIM(nolign-1)
    Else [M:MTK1]COEFFTPS(nolign-1) = 1
    Endif
    If [M:MTK1]CPLQTY(nolign-1) <> 0 & [M:MTK1]ROOTIMCOD(nolign-1) <> 3 : # FQ 42739 01/2008
        [M:MTK1]CPLUNTTIM(nolign-1) =  VALEUR / [M:MTK1]CPLQTY(nolign-1)
    Endif
     # 11.06 demande 38402
     [M:MTK1]CPLUNTTIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLUNTTIM(nolign-1))
    Affzo [M:MTK1]CPLUNTTIM(nolign-1)
Endif

End

