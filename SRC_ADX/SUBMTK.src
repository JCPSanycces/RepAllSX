########################################
Subprog C_OPEUOM(VALEUR)
Variable Char    VALEUR()
If instr(1,dbgstr(1),"MTO1")
   If GREP = "C" & [M:MTO1]ROUOPENUM <> 0 & !find(VALEUR,[F:MFG]STU,[M:MTO1]XOPEUOM)
                   GMESSAGE = mess(23,100,1)
                    mkstat = 1
                    End
   Endif
Else
   If GREP = "C" & !find(VALEUR,[F:MFG]STU,[M:MTK1]XOPEUOM(nolign-1))
                    GMESSAGE = mess(23,100,1)
                    mkstat = 1
                     End
   Endif
Endif
End

########################################
Subprog AS_TABREJQTY(VALEUR)
Variable Decimal VALEUR
# CCC (2009-12-18) Bug 60767 : Initialiser la quantité que sur une nouvelle ligne
If VALEUR=0
    VALEUR = [M:MTO3]REJCPLQTY - sum([M:MTO3]TABREJQTY)
Endif
If VALEUR < 0 : VALEUR = 0 : Endif
End

########################################
Subprog AS_OPEUOM(VALEUR)
Variable Char    VALEUR()
If [F:MTS]OPEUOMMOD = 1 : mkstat = 2 : End : Endif
End

