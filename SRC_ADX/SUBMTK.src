########################################
Subprog AM_OPEUOM(VALEUR)
Variable Char    VALEUR()
Local Decimal WCOEFF,MCOEFF
If instr(1,dbgstr(1),"MTO1")
   If VALEUR = [M:MTO1]XOPEUOM
                       [M:MTO1]OPESTUCOE = [M:MTO1]OPEWORCOE
                       [M:MTO1]CPLQTY    = [M:MTO1]CPLQTY    * [M:MTO1]OPESTUCOE
                       Call QTEARR([M:MTO1]CPLQTY,VALEUR) From TRTDIV
                       [M:MTO1]REJCPLQTY = [M:MTO1]REJCPLQTY * [M:MTO1]OPESTUCOE
                       Call QTEARR([M:MTO1]REJCPLQTY,VALEUR) From TRTDIV
                       [M:MTO1]EXTQTY    = [M:MTO1]EXTQTY    * [M:MTO1]OPESTUCOE
                       Call QTEARR([M:MTO1]EXTQTY,VALEUR) From TRTDIV
                       [M:MTO1]OKQTY     = [M:MTO1]OKQTY     * [M:MTO1]OPESTUCOE
                       Call QTEARR([M:MTO1]OKQTY,VALEUR) From TRTDIV
                       [M:MTO1]CPLUNTTIM = [M:MTO1]CPLUNTTIM / [M:MTO1]OPESTUCOE
                       [M:MTO1]OPEWORCOE = 1
   Else
                       [M:MTO1]CPLQTY    = [M:MTO1]CPLQTY    / [M:MTO1]OPESTUCOE
                       Call QTEARR([M:MTO1]CPLQTY,VALEUR) From TRTDIV
                       [M:MTO1]REJCPLQTY = [M:MTO1]REJCPLQTY / [M:MTO1]OPESTUCOE
                       Call QTEARR([M:MTO1]REJCPLQTY,VALEUR) From TRTDIV
                       [M:MTO1]EXTQTY    = [M:MTO1]EXTQTY    / [M:MTO1]OPESTUCOE
                       Call QTEARR([M:MTO1]EXTQTY,VALEUR) From TRTDIV
                       [M:MTO1]OKQTY     = [M:MTO1]OKQTY     / [M:MTO1]OPESTUCOE
                        Call QTEARR([M:MTO1]OKQTY,VALEUR) From TRTDIV
                       [M:MTO1]CPLUNTTIM = [M:MTO1]CPLUNTTIM * [M:MTO1]OPESTUCOE
                       [M:MTO1]OPEWORCOE = [M:MTO1]OPESTUCOE
                       [M:MTO1]OPESTUCOE = 1
  Endif
  # 11.06 demande 38402
  [M:MTO1]CPLUNTTIM = func TRTX3.ARRTYP("","","TIH",[M:MTO1]CPLUNTTIM)
  Affzo [M:MTO1]OPEWORCOE, CPLQTY,REJCPLQTY,EXTQTY,OKQTY,CPLUNTTIM
Else
  If VALEUR = [M:MTK1]XOPEUOM(nolign-1)
                       [M:MTK1]OPESTUCOE(nolign-1) = [M:MTK1]OPEWORCOE(nolign-1)
                       [M:MTK1]CPLQTY(nolign-1)    = [M:MTK1]CPLQTY(nolign-1)    * [M:MTK1]OPESTUCOE(nolign-1)
                       Call QTEARR([M:MTK1]CPLQTY(nolign-1),VALEUR) From TRTDIV
                       [M:MTK1]REJCPLQTY(nolign-1) = [M:MTK1]REJCPLQTY(nolign-1) * [M:MTK1]OPESTUCOE(nolign-1)
                       Call QTEARR([M:MTK1]REJCPLQTY(nolign-1),VALEUR) From TRTDIV
                       [M:MTK1]EXTQTY(nolign-1)    = [M:MTK1]EXTQTY(nolign-1)    * [M:MTK1]OPESTUCOE(nolign-1)
                       Call QTEARR([M:MTK1]EXTQTY(nolign-1),VALEUR) From TRTDIV
                       [M:MTK1]OKQTY(nolign-1)     = [M:MTK1]OKQTY(nolign-1)     * [M:MTK1]OPESTUCOE(nolign-1)
                       Call QTEARR([M:MTK1]OKQTY(nolign-1),VALEUR) From TRTDIV
                       [M:MTK1]CPLUNTTIM(nolign-1) = [M:MTK1]CPLUNTTIM(nolign-1) / [M:MTK1]OPESTUCOE(nolign-1)
                       [M:MTK1]OPEWORCOE(nolign-1) = 1
  Else
                       [M:MTK1]CPLQTY(nolign-1)    = [M:MTK1]CPLQTY(nolign-1)    / [M:MTK1]OPESTUCOE(nolign-1)
                       Call QTEARR([M:MTK1]CPLQTY(nolign-1),VALEUR) From TRTDIV
                       [M:MTK1]REJCPLQTY(nolign-1) = [M:MTK1]REJCPLQTY(nolign-1) / [M:MTK1]OPESTUCOE(nolign-1)
                       Call QTEARR([M:MTK1]REJCPLQTY(nolign-1),VALEUR) From TRTDIV
                       [M:MTK1]EXTQTY(nolign-1)    = [M:MTK1]EXTQTY(nolign-1)    / [M:MTK1]OPESTUCOE(nolign-1)
                       Call QTEARR([M:MTK1]EXTQTY(nolign-1),VALEUR) From TRTDIV
                       [M:MTK1]OKQTY(nolign-1)     = [M:MTK1]OKQTY(nolign-1)     / [M:MTK1]OPESTUCOE(nolign-1)
                       Call QTEARR([M:MTK1]OKQTY(nolign-1),VALEUR) From TRTDIV
                       [M:MTK1]CPLUNTTIM(nolign-1) = [M:MTK1]CPLUNTTIM(nolign-1) * [M:MTK1]OPESTUCOE(nolign-1)
                       [M:MTK1]OPEWORCOE(nolign-1) = [M:MTK1]OPESTUCOE(nolign-1)
                       [M:MTK1]OPESTUCOE(nolign-1) = 1
  Endif
  # 11.06 demande 38402
  [M:MTK1]CPLUNTTIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLUNTTIM(nolign-1))
  Affzo [M:MTK1]OPEWORCOE(nolign-1),CPLQTY(nolign-1),REJCPLQTY(nolign-1),
&                                 EXTQTY(nolign-1)
Endif
End

##########################################
Subprog C_CPLLAB(VALEUR)
Variable Char     VALEUR
Local Integer OK

If VALEUR <> ""
    # contrôle existence et poste de type main-d'oeuvre
    If instr(1,dbgstr(1),"MTK1")
           If VALEUR = [M:MTK1]CPLWST(nolign-1) : GMESSAGE=mess(26,193,1) : mkstat=1 : End : Endif
    Else
       If VALEUR = [M:MTO1]CPLWST : GMESSAGE=mess(26,193,1) : mkstat=1 : End : Endif
    Endif
    Read [MWS]WST0=VALEUR;[M:MTK0]MFGFCY
    If fstat
       GMESSAGE=VALEUR+"\"+mess(23,100,1) : mkstat=2
       End
    Else
       If [F:MWS]WSTTYP <> 2
          GMESSAGE=VALEUR - mess(4,193,1) : mkstat=2
          End
       Endif
       If [F:MWS]WCRFCY <> [M:MTK0]MFGFCY
          GMESSAGE = mess(116,193,1) - [M:MTK0]MFGFCY
          mkstat = 1
          End
       Endif
    Endif
Endif
#
# Issue 110979/2 - 2016-03-25 by CCC : Warning message when modifying an existing operation of a versioned routing
If VALEUR<>[M:MTK1]CPLLAB(nolign-1) & [M:MTK1]ROUOPENUM(nolign-1)<>0
    If [F:MFG]MFGNUM<>[M:MTK0]MFGNUM(nolign-1)
        Read [F:MFG]MFG0 = [M:MTK0]MFGNUM(nolign-1)
    Endif
    If [F:MFG]ROUECCMAJ <> ""
        If [F:MFO]MFGNUM<>[M:MTK0]MFGNUM(nolign-1) | [F:MFO]OPENUM<>[M:MTK1]OPENUM(nolign-1) | [F:MFO]OPESPLNUM<>[M:MTK1]OPESPLNUM(nolign-1)
            Raz [F:MFO]
            Read [F:MFO]MFO0 = [M:MTK0]MFGNUM(nolign-1);[M:MTK1]OPENUM(nolign-1);[M:MTK1]OPESPLNUM(nolign-1)
        Endif
        If [F:MFO]MFGNUM<>"" & VALEUR<>[F:MFO]EXTLAB
            OK=1
            Call AVERTIR(mess(346,193,1),OK) From GESECRAN
            If OK = 1 : mkstat=1 : End : Endif # Cancel
        Endif
    Endif
Endif
End

########################################
Subprog AV_WOPE1(VALEUR)
Variable Decimal VALEUR
End

########################################
Subprog AM_WOPE2(VALEUR)
Variable Decimal VALEUR
Local Integer WVALEUR, WRET
Local Char WMFGNUM(GLONVCR)
If VALEUR < [M:MTK1]WOPE1
   Call ERREUR(mess(044,199,1)) From GESECRAN
   mkstat = 1
   End
Endif
Raz [M:MTK1]NBOPE,[M:MTK1]OPENUM,[M:MTK1]ROUOPENUM,[M:MTK1]CPLQTY,[M:MTK1]OPEPREC,[M:MTK1]TECCRD, [M:MTK0]WOPEPROD
WMFGNUM = [M:MTK0]MFGNUM
#Chargement de l'écran Opé selon sélection
# 10.01 Ne charger le tableau des articles lancés que si l'opération de production
# est présente demande (tester WOPEPROD) 10683
If [M:MTK0]OPETRKFLG = 2 & [F:MTS]FILTFLG <> 1
     [M:MTK1]WOPE2 = VALEUR
     [M:MTK1]FILTOPE = [F:MTS]FILTDEF
     Call CHARG_OPE([M:MTK0]MFGNUM,[M:MTK1]FILTOPE) From SUBMTKB
     If [M:MTK1]NBOPE = 0 Call MESSAGE(mess(99,100,1)) From GESECRAN
                           mkstat = 1
                           End
     Endif
     If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2
        Grizo [M:MTK2]5
        Effzo [M:MTK2]10
        If [M:MTK0]WOPEPROD = 2
            Call DELSTOENTW(-1,-1,"MTK2",1,1,[M:MTK0]MFGFCY,1,"") From STKENT
            Call  CHARG_ITM([M:MTK0]MFGNUM,0,1) From SUBMTKB
        Endif
        Affzo [M:MTK2]
     Endif
Endif
#Chargement de l'écran mat selon sélection
If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]FILTFLG <> 1
        Effzo [M:MTK3]15
#        [M:MTK3]STOCOD  = 3
        [M:MTK3]WOPE1   = [M:MTK1]WOPE1
        [M:MTK3]WOPE2   = VALEUR
        [M:MTK3]FILTMAT = [F:MTS]FILTDEF
        Call DELSTOSORW(-1,0,"MTK3",[M:MTK0]MFGFCY,WRET) From STKSOR
        Call CHARG_MAT([M:MTK0]MFGNUM,[M:MTK3]FILTMAT,0,0) From SUBMTKB
        If [M:MTK3]NBMAT = 0 : Call MESSAGE(mess(99,100,1)) From GESECRAN
                               mkstat = 1
                               End
        Endif
        Grizo [M:MTK3]5
        Affzo [M:MTK3]
Endif
End

########################################
Subprog AM_WOPE1(VALEUR)
Variable Decimal VALEUR
Effzo [M:MTK1]10
Raz [M:MTK1]WOPE2
End

