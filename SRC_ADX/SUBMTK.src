#<AdxTL>@(#)9.0.0.0 $Revision$
# SUBMTK
#Actions sur champs pour masques MTK0, MTK1, MTO1
#                                               sr Novembre 1998
#################################################################

$ACTION
#--- Dem 78142
# Entry point reserved for ETO
GPOINT=ACTION
GPE=0
Gosub ENTREE From EXEFNC
If GPE=1 : Return : Endif
#---

Case ACTION
 When "DEFTRANS"          : Gosub DEFTRANS     From SUBMTKA
 When "VARIANTE"          : Gosub VARIANTE     From SUBMTKA
 When "SETTRANS"          : Gosub SETTRANS     From SUBMTKA
 When "OUVRE"             : Gosub OUVRE        From SUBMTKA
 When "OUVRE_BOITE"       : Gosub OUVRE_BOITE  From SUBMTKA
 When "HINTCLE"           : Gosub HINTCLE      From SUBMTKA
 When "FILTRE"            : Gosub FILTRE       From SUBMTKA
 When "STATUT"            : Gosub STATUT       From SUBMTKA
 When "ABANDON"           : Gosub ABANDON      From SUBMTKA
 When "RAZCRE"            : Gosub RAZCRE       From SUBMTKA
 When "SETBOUT"           : Gosub SETBOUT      From SUBMTKA
 When "EXEBOUT"           : Gosub EXEBOUT      From SUBMTKA
 When "LIENS"             : Gosub LIENS        From SUBMTKA
 When "FERME"             : Gosub FERME        From SUBMTKA
 When "FIN"               : Call  RAZSTOSORW   From STKSOR
 When "VERIF_CRE"         : Gosub VERIF_CRE    From SUBMTKA
 When "INICRE"            : Gosub INICRE       From SUBMTKA
 When "CREATION"          : Gosub CREATION     From SUBMTKA
 When "AB_CREATION"       : Gosub AB_CREATION  From SUBMTKA
 When "APRES_CRE"         : Gosub APRES_CRE    From SUBMTKA
 When "AVANT_MODFIC"      : Gosub AVANT_MODFIC From SUBMTKA
 When "APRES_MODIF"       : Gosub APRES_MODIF  From SUBMTKA
 When "GRISE"             : Gosub GRISE        From SUBMTKA
 When "VERF_ANU"          : Gosub VERF_ANU     From SUBMTKA
 When "ANNULE"            : Gosub ANNULE       From SUBMTKA
 When "AP_ANNULE"         : Gosub AP_ANNULE    From SUBMTKA
 When "FILGAUCHE"         : Gosub FILGAUCHE    From SUBMTKA
 When "TIROIR"            : Gosub TIROIR       From SUBMTKA
 When "DEB_PICK"          : Gosub DEB_PICK     From SUBMTKA
 When "PICKE"             : Gosub PICKE        From SUBMTKA
 When "DEPICK"            : Gosub DEPICK       From SUBMTKA
 When "FIN_PICK"          : Gosub FIN_PICK     From SUBMTKA
 When "CHX_TABLE"         : Gosub CHX_TABLE    From SUBMTKA

 When "AB3_MFGNUM"   : Gosub AB3_MFGNUM
 When "BB3_MFGNUM"   : Gosub BB3_MFGNUM
 When "BB3_NBOPE"    : Gosub BB3_MFGNUM
 When "AB4_NBOPE"    : Gosub AB4_NBOPE
 When "AB6_NBOPE"    : Gosub AB6_NBOPE
 When "BB6_NBOPE"    : Gosub BB6_NBOPE
 When "BB7_NBOPE"    : Gosub BB7_NBOPE
 When "AB8_NBOPE"    : Gosub AB8_NBOPE
 When "BB8_NBOPE"    : Gosub BB8_NBOPE
 When "AB10_NBOPE"   : Gosub AB10_NBOPE
 When "AB11_NBOPE"   : Gosub AB11_NBOPE
 When "AB1_REJCPLQTY": Gosub AB1_REJCPLQTY
 When "BB1_REJCPLQTY": Gosub BB1_REJCPLQTY
 When "AB2_SCANUM1"  : Gosub AB2_SCANUM1
 When "BB2_SCANUM1"  : Gosub BB2_SCANUM1

When Default
Endcase
Return

##############################################
$AB3_MFGNUM
Return

##############################################
$BB3_MFGNUM
#----- Relecture transaction de saisie  -----#
Read [MTS] MTS0=2;GMTSNUM : If fstat Raz [F:MTS] : Endif
End
Return

##############################################
$AB4_NBOPE
Local Integer WTRT
Local Integer WMOD
# pourquoi ? (llc)
#If GREP = "C" : GCONSULT = 0 : Else  : GCONSULT = 1 : Endif
If GREP <> "C" & [M:MTK1]TIMTYP(nolign-1) = 1
    Read [F:MFG]MFG0 = [M:MTK1]MFGNUMOP(nolign-1)
    If fstat : Raz [F:MFG] : Endif
    If [F:MFG]MFGSTA = 4 : WMOD = 1 : Endif
Endif
Return

##############################################
$AB6_NBOPE
Local Integer     WMOD
WMOD = 0
Return

##############################################
$BB6_NBOPE
If GREP = "C"
    If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]CONSMAT <> 1
       Affzo [M:MTK3]15
    Endif
Endif
mkstat = 99
Return


##############################################
$BB7_NBOPE
If mkstat=4 & GREP=""
   Trbegin [MKO]
   Call DEBTRANS From GLOCK
   Read [F:MKO]MKO0 = [M:MTK0]MFGTRKNUM;[M:MTK1]OPETRKLIN(nolign-1)
   If fstat : Raz [F:MKO] : Return : Endif
   Gosub UPDATE_TEXTE
   If GOK = 1 : Commit : Else : Rollback : Endif
   Raz mkstat
Endif

Return

########################################################################
$UPDATE_TEXTE
Local Integer WRET
# on a viré le texte en modif
If [M:MTK1]MKOTEX(nolign-1) = "" & [F:MKO]MKOTEX <> "" & left$([F:MKO]MKOTEX,3) = "MKO"
   Call SUP_CLOB([F:MKO]MKOTEX,WRET) From TRTX3TEX
Else
    If    [M:MTK1]MKOTEX(nolign-1) <> ""
          [F:MKO]MKOTEX  = [M:MTK1]MKOTEX(nolign-1)
           If left$([F:MKO]MKOTEX,3)="MKO"
                  Call CRE_CLOB([F:MKO]MKOTEX,GOK) From TRTX3TEX
                  If GOK<1 Return Endif
           Elsif  !find(left$([F:MKO]MKOTEX,3),"ROT","ROO")
                  Call DUP_CLOB("MKO",[F:MKO]MKOTEX,GOK) From TRTX3TEX
                  If GOK<1 Return Endif
           Endif
    Endif
Endif
Readlock [F:MKO]MKO0 = [M:MTK0]MFGTRKNUM;[M:MTK1]OPETRKLIN(nolign-1)
If fstat=1  GOK=-1 : GLOCK="$MFGOPETRK"-[M:MTK0]MFGTRKNUM - num$([M:MTK1]OPETRKLIN(nolign-1)) :  Return
Elsif fstat GOK=0  : Call RSTA("MKO",[M:MTK0]MFGTRKNUM) From GLOCK :  Return
Endif
[F:MKO]MKOTEX = [M:MTK1]MKOTEX(nolign-1)
Rewrite [F:MKO]
If fstat
   GOK = 0 : Call FSTA("MKO") From GLOCK :  Return
Endif

Return



##############################################
$AB8_NBOPE
Local Integer     WMOD
WMOD = 1
# CCC (2010-04-28) Bug 54558 : Vérifier que l'OF n'est pas en cours de modif
If func MFGLIB.CHKMFGLOCK([M:MTK1]MFGNUMOP(nolign-1),1)
    Call ERREUR(mess(280,193,1)) From GESECRAN
    WMOD = 0
    Return
Endif
# Issue 90462 - 2013-06-13 by CCC
GSAVMFGNUM = [M:MTK1]MFGNUMOP(nolign-1)
Return

##############################################
$BB8_NBOPE
# Issue 90462 - 2013-06-13 by CCC
#Unlock ="MFG"+[M:MTK1]MFGNUMOP(nolign-1)
Unlock ="MFG"+GSAVMFGNUM
Gosub LIENS From SUBMTKA
Affzo [M:MTK1]10
Return

##############################################
$AB10_NBOPE
Local Integer WTRT
WTRT = 2
Return

##############################################
$AB11_NBOPE
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1(GLONVCR)
Local Char     WCLE2(GLONVCR) (2)
WCLE2(0) = [M:MTK0]MFGFCY
WCLE2(1)   = num$([M:MTK1]ROUALT(nolign-1))
#    If clalev([F:TRO])<=0 : Local File TABROUALT [TRO] : Endif
#    Local Integer NBTRO
#    #   SéLECTIONNER les alt. de gammes compatibles avec site de prod
#    Filter [TRO] Where ([F:TRO]FCY=[M:MTK0]MFGFCY | [F:TRO]FCY="") & [F:TRO]MFGUSE=2
#    For [TRO]TRO0
#         GROUALT (NBTRO) = [F:TRO]ROUALT
#         NBTRO += 1
#    Next
#    Filter [TRO]
WCLE1       = [M:MTK1]ITMREF(nolign-1)
#Local File ROUTING [ROH] Where find(ROUALT, GROUALT) & ITMREF=WCLE1 & FCY = [M:MTK0]MFGFCY
Local File ROUTING [ROH] Where ROUALT = [M:MTK1]ROUALT(nolign-1)  & ITMREF=WCLE1 & FCY = [M:MTK0]MFGFCY
GDATEREF   = [M:MTK0]MFGTRKDAT
Return

##############################################
$AB1_REJCPLQTY
Return

##############################################
$BB1_REJCPLQTY
If instr(1,dbgstr(1),"MTO1")
   [M:MTO1]SCANUM1 = [M:MTO1]SCANUM(0)
   If [M:MTO1]SCANUM1 <> 0 : Read [F:TSR]TSR0 = [M:MTO1]SCANUM1
                             # FGR 18/09/2009 : X3SUIVI57920
                             #If !fstat [M:MTO1]SCADES = [F:TSR]SCADES : Endif
                             If !fstat Then
                               Call LECTEXTRA([M:MTO1]SCADES,"TABSCA","SCADESAXX",num$([F:TSR]SCANUM),"") From ATEXTRA
                             Endif
   Else                    : Raz [M:MTO1]SCADES
   Endif
   Default Mask [MTO1]
   Affzo [M:MTO1]OKQTY, SCANUM1, SCADES
Endif
Return

##############################################
$AB2_SCANUM1
Return

##############################################
$BB2_SCANUM1
If instr(1,dbgstr(1),"MTO1")
   If VALEUR <> 0 : Read [F:TSR]TSR0 = VALEUR
                    # FGR 18/09/2009 : X3SUIVI57920
                    #If !fstat [M:MTO1]SCADES = [F:TSR]SCADES : Endif
                    If !fstat Then
                      Call LECTEXTRA([M:MTO1]SCADES,"TABSCA","SCADESAXX",num$([F:TSR]SCANUM),"") From ATEXTRA
                    Endif
   Else           : Raz [M:MTO1]SCADES
   Endif
   Default Mask [MTO1]
   Affzo [M:MTO1]SCADES
Endif
Return


#-------------------- Action sur écran MTK0 -------------------------------#
########################################
Subprog AS_MFGFCY(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
GFCY=VALEUR : Gosub CHARG_PARAM From SUBMTKA
If GMESSAGE<>""
    Call ERREUR(GMESSAGE) From GESECRAN
    GFCY=[M:MTK0]MFGFCY : Gosub CHARG_PARAM From SUBMTKA
    mkstat=1
    End
Endif
Raz [M:MTK0]MFGNUM
Effzo [M:MTK1]10
Effzo [M:MTK2]10
Effzo [M:MTK3]15
Gosub AFF_TITCOL From SUBMTKA
#--- Bug 65478
If dim([M:MTK0]WRHE)>0
    Effzo [M:MTK0]WRHE
    If [M:MTK0]ITMTRKFLG=2
        Call WRHINIT([M:MTK0]WRHE,VALEUR,2) From STKWRH
    Elsif [M:MTK0]MATTRKFLG=2
        Call WRHINIT([M:MTK0]WRHE,VALEUR,8) From STKWRH
    Endif
    Affzo [M:MTK0]WRHE
Endif
#---
# Actzo ou Grizo des dépôts selon le site
[M:MTK0]MFGFCY=VALEUR         : # Bug 60503
Gosub WRH_ETAT From SUBMTKA
End

########################################
Subprog AS_WRHE(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2 & VALEUR<>""
& & ( dim([M:MTK2]NBITM)>0 & [M:MTK2]NBITM<>0
&   | dim([M:MTK2]NBMAT)>0 & [M:MTK2]NBMAT<>0)
   GMESSAGE=mess(342,184,1) : mkstat=2
Endif
End

########################################
Subprog AS_MFGTRKNUM(VALEUR)
Variable Char    VALEUR()
End


########################################
Subprog C_MFGTRKNUM(VALEUR)
Variable Char    VALEUR()
#    Rien d'affiché, vérif si un enregistrement existe
Case GREP
    When "C"     : Look [MTK]MTK0=VALEUR
                   If fstat : End : Endif
                   GMESSAGE=mess(22,100,1) : mkstat=1 : End
    When Default : Look [MTK]MTK0=VALEUR
                   If fstat GMESSAGE=mess(23,100,1) : mkstat=1 : End : Endif
Endcase
End

########################################
Subprog C_MFGTRKDAT(VALEUR)
Variable Date    VALEUR
If GREP <> "C" : End : Endif
#On ne peut pas saisir une date > date du jour
If VALEUR > date$ : GMESSAGE = mess(129,194,1) : mkstat = 1 : End : Endif
GMESSAGE = ""
Call STKCTRIPT(VALEUR,[M:MTK0]MFGFCY,"1") From STKLIB
If GMESSAGE <> "": mkstat = 1 : End : Endif

#--- Bug 62980
#--- Contrôle date entrée par rapport aux dates mouvements en attente
If VALEUR<>[M:MTK0]MFGTRKDAT & [M:MTK2]NBITM>0
  Local Integer I
  Local Date    LDATRUP, LDAT
  Local Decimal LQTYRUP
  For I=0 To [M:MTK2]NBITM-1
    Call CTLRUP([M:MTK0]MFGFCY,[M:MTK2]ITMREF(I),VALEUR,0,LDATRUP,LQTYRUP) From STKLIB
    If LDAT<LDATRUP LDAT=LDATRUP Endif
  Next I
  If LDAT<>[0/0/0]
      Call MESSAGE(mess(354,184,1)-":\"+mess(355,184,1)-format$("DD2",LDAT)+
&                  "\"+mess(357,184,1)-format$("DD2",LDAT)) From GESECRAN
  Endif
Endif
#---

End


########################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
Read [F:MFG]MFG0 = VALEUR
If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
If GREP <> "C" : End : Endif
#L'OF doit être complet
If [F:MFG]TYPMOD = 1    : GMESSAGE = mess(51,190,1) : mkstat = 1 : End : Endif
#L'OF doit être ferme
If [F:MFG]MFGSTA <> 1   : GMESSAGE = mess(19,190,1) : mkstat = 1 : End : Endif
#L'OF ne doit pas être suspendu
If [F:MFG]SUSFLG = 2   : GMESSAGE = mess(180,190,1) : mkstat = 1 : End : Endif
#Selon paramètre général l'OF doit être alloué complètement
If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
     GMESSAGE = mess(18,190,1)
     mkstat = 1
     End
Endif
mkstat = 0
#Selon paramètre général, l'OF doit être édité
If  [F:MFG]MFGTRKFLG < 3 &  GDOSFAB = 2 : GMESSAGE = mess(20,190,1) : mkstat = 1 : End : Endif
mkstat = 0
#BOUCLE d'analyse des matières bloquantes si rupture
For [MFM] Where MFGNUM = [F:MFG]MFGNUM
    If [F:MFM]SHTQTY <> 0
        Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
        If !fstat & [F:ITF]MFGSHTCOD = 1
            GMESSAGE = mess(105,193,1)+" ("+[F:MFM]ITMREF+")"
            mkstat = 1
            Break
        Endif
    Endif
Next
If mkstat = 1 : End : Endif
[M:MTK0]MFGTRKFLG = [F:MFG]MFGTRKFLG
[M:MTK0]MFGTRKDAT = date$
[M:MTK0]MTKTEX    = [F:MFG]MFGTEX
End

########################################
Subprog AM_MFGNUM(VALEUR)
Variable Char    VALEUR()
Local Integer WVALEUR, WRET
Local Char WMFGNUM(GLONVCR)
Effzo [M:MTK1]10
Effzo [M:MTK2]10
Effzo [M:MTK3]15
Raz [M:MTK0]WOPEPROD

If [F:MFG]MFGFCY <> [M:MTK0]MFGFCY : [M:MTK0]MFGFCY = [F:MFG]MFGFCY
                                     GFCY=[M:MTK0]MFGFCY : Gosub CHARG_PARAM From SUBMTKA
                                     Affzo [M:MTK0]MFGFCY
                                     Affzo [M:MTK0]ZMFGFCY   # llc 08.02 15437
Endif
[M:MTK0]OPETRKFLG = [F:MTS]OPETRKFLG
[M:MTK0]ITMTRKFLG = [F:MTS]ITMTRKFLG
[M:MTK0]MATTRKFLG = [F:MTS]MATTRKFLG
WMFGNUM = VALEUR
#Chargement des zones du masque.
Case [F:MFG]MFGMOD
     When 2 : If [F:MTS]OPETRKFLG = 2
                 [M:MTK0]OPETRKFLG = 1
                 [M:MTK1]QTESUIVOPE = 0
                 Affzo [M:MTK0]OPETRKFLG
                 Grizo [M:MTK0]OPETRKFLG
                 Affzo [M:MTK1]QTESUIVOPE
                 Grizo [M:MTK1]
              Endif
     When 3 : If [F:MTS]MATTRKFLG = 2
                 [M:MTK0]MATTRKFLG = 1
                 Affzo [M:MTK0]MATTRKFLG
                 Grizo [M:MTK0]MATTRKFLG
                 Grizo [M:MTK3]
              Endif
     When Default
Endcase
If [F:MFG]ITMLINNBR = 1
    Filter [F:MFI] Where MFGNUM = [F:MFG]MFGNUM
    Read [F:MFI]MFI0 First
    If fstat Call ERREUR(mess(23,100,1)) From GESECRAN
        Filter [F:MFI]
        mkstat = 1
        End
    Endif
    Filter [F:MFI]
    If [F:MFI]UOMSTUCOE = 0 : [F:MFI]UOMSTUCOE = 1 : Endif
    If [M:MTK0]OPETRKFLG = 2  : [M:MTK1]UOM = [F:MFI]UOM
                                If [F:MFG]TRKFIRST = [0/0/0]
                                   [M:MTK1]QTESUIVOPE = [F:MFI]RMNEXTQTY / [F:MFI]UOMSTUCOE
                                   Call QTEARR([M:MTK1]QTESUIVOPE,[M:MTK1]UOM) From TRTDIV
                                Endif
                                 Affzo [M:MTK1]5
   Endif
   If [M:MTK0]ITMTRKFLG = 2 : [M:MTK2]UL = [F:MFI]UOM
                             If [F:MFG]TRKFIRST = [0/0/0]
                                [M:MTK2]QTESUIVITM = [F:MFI]RMNEXTQTY / [F:MFI]UOMSTUCOE
                                Call QTEARR([M:MTK2]QTESUIVITM,[M:MTK2]UL) From TRTDIV
                             Endif
                             Affzo [M:MTK2]5
   Endif
   If [M:MTK0]MATTRKFLG = 2 : [M:MTK3]UOM = [F:MFI]UOM
                              If [F:MFG]TRKFIRST = [0/0/0]
                                 [M:MTK3]QTESUIVMAT = [F:MFI]RMNEXTQTY / [F:MFI]UOMSTUCOE
                                 Call QTEARR([M:MTK3]QTESUIVMAT,[M:MTK3]UOM) From TRTDIV
                              Endif
                              Affzo [M:MTK3]5
   Endif

Else
   If [M:MTK0]OPETRKFLG = 2 : If [F:MFG]TRKFIRST = [0/0/0]
                                 [M:MTK1]QTESUIVOPE = [F:MFG]RMNEXTQTY
                              Endif
                              [M:MTK1]UOM = [F:MFG]STU
                              Affzo [M:MTK1]5
   Endif
   If [M:MTK0]ITMTRKFLG = 2 : If [F:MFG]TRKFIRST = [0/0/0]
                                [M:MTK2]QTESUIVITM = [F:MFG]RMNEXTQTY
                             Endif
                             [M:MTK2]UL = [F:MFG]STU
                             Affzo [M:MTK2]5
   Endif
   If [M:MTK0]MATTRKFLG = 2 : If [F:MFG]TRKFIRST = [0/0/0]
                                 [M:MTK3]QTESUIVMAT = [F:MFG]RMNEXTQTY
                              Endif
                              [M:MTK3]UOM = [F:MFG]STU
                              Affzo [M:MTK3]5
   Endif
Endif
# 02.07 Demande 39866
If [M:MTK0]MATTRKFLG =  2 &  [F:MFG]DETALLNBR <> 0  : Grizo [M:MTK3]10 : Endif

#Chargement de l'écran Opé selon sélection
#  10.01 Ne charger le tableau des articles lancés que si l'opération de production
# est présente demande (tester WOPEPROD) 10683
[M:MTK0]MFGNUM = VALEUR
If [M:MTK0]OPETRKFLG = 2 & [F:MTS]FILTFLG <> 1
     WVALEUR = [F:MTS]FILTDEF
    [M:MTK1]FILTOPE = [F:MTS]FILTDEF
    Call CHARG_OPE(VALEUR,[F:MTS]FILTDEF) From SUBMTKB
    If [F:MTS]ITMTRKFLG = 2
       Call DELSTOENTW(-1,-1,"MTK2",1,1,[M:MTK0]MFGFCY,1,"") From STKENT
       Grizo [M:MTK2]5
       Effzo [M:MTK2]10
       If [M:MTK0]WOPEPROD = 2
           Call CHARG_ITM(VALEUR,0,1) From SUBMTKB
       Endif
       Affzo [M:MTK2]
    Endif
    Affzo [M:MTK1]10
Endif
#Chargement de l'écran mat selon sélection
If [M:MTK0]MATTRKFLG = 2  & [F:MTS]FILTFLG <> 1
        Call DELSTOSORW(-1,0,"MTK3",[M:MTK0]MFGFCY,WRET) From STKSOR
        [M:MTK3]FILTMAT = [F:MTS]FILTDEF
        Call CHARG_MAT(VALEUR,[F:MTS]FILTDEF,0,0) From SUBMTKB
        If [M:MTK3]NBMAT = 0 : Call MESSAGE(mess(99,100,1)) From GESECRAN
        Endif
        Grizo [M:MTK3]5
        Affzo [M:MTK3]
Endif
If [F:MTS]FILTFLG <> 1 & ([M:MTK0]OPETRKFLG = 2 | [M:MTK0]MATTRKFLG = 2) : # GH 03/06/2014 bug 90309 If [F:MTS]FILTFLG <> 1
    Local Integer WNBOPE,WNBITM,WNBMAT
    If dim([M:MTK1]NBOPE) > 0 : WNBOPE = [M:MTK1]NBOPE : Endif
    If dim([M:MTK2]NBITM) > 0 : WNBITM = [M:MTK2]NBITM : Endif
    If dim([M:MTK3]NBMAT) > 0 : WNBMAT = [M:MTK3]NBMAT : Endif
    If WNBOPE = 0 & WNBITM = 0 & WNBMAT = 0
        Call MESSAGE(mess(99,100,1)) From GESECRAN
    Endif
Endif
Affzo [M:MTK0]10
End

########################################
#Pas de suivi opération si mode de lancement OF = matières seules
Subprog AS_OPETRKFLG(VALEUR)
Variable Integer VALEUR
If [F:MFG]MFGMOD = 2 : VALEUR = 1 : mkstat = 2 : End : Endif
End

########################################
Subprog AM_OPETRKFLG(VALEUR)
Variable Integer VALEUR
#  11.02 demande 16531
If VALEUR = 1 : Raz   [M:MTK1]
                Grizo [M:MTK1]5,10
                If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2
                    Actzo [M:MTK2]5
                Endif
                # Issue 121922 13/03/2017 by GH - only material tracking is still ticked
                If [M:MTK0]ITMTRKFLG <> 2 & [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2
                    Actzo [M:MTK3]5
                Endif
Else          : Actzo [M:MTK1]5,10
                If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2
                    Grizo [M:MTK2]5
                Endif
                # Issue 121922 13/03/2017 by GH - material tracking is no more the only ticked
                If [M:MTK0]ITMTRKFLG <> 2 & [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2
                    Grizo [M:MTK3]5
                Endif
Endif
Affzo [M:MTK1]
End

########################################
Subprog AS_ITMTRKFLG(VALEUR)
Variable Integer VALEUR
End

########################################
Subprog AM_ITMTRKFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 : Effzo [M:MTK2]10
                Grizo [M:MTK2]5,10
               # GA 05/2011 Ctrl des sources Erreur liste paramètres
               # Call  DELSTOENTW(-1,-1,"MTK2",1) From STKENT      # Issue 73263 - 2011-04-18 by CCC : Mise à jour de ENTW
                Call DELSTOENTW(-1,-1,"MTK2",1,1,[M:MTK0]MFGFCY,1,"") From STKENT
                # Issue 121922 13/03/2017 by GH - only material tracking is still ticked
                If [M:MTK0]OPETRKFLG <> 2 & [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2
                   Actzo [M:MTK3]5
                Endif
Else          : Actzo [M:MTK2]5,10
                # Issue 121922 13/03/2017 by GH - production grid is empty & operation tracking is ticked
                # we tick production tracking -> block 5 is still not enterable
                If [M:MTK0]OPETRKFLG = 2
                   Grizo [M:MTK2]5
                Endif
                # Issue 121922 13/03/2017 by GH - material tracking is no more the only ticked
                If [M:MTK0]OPETRKFLG <> 2 & [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2
                   Grizo [M:MTK3]5
                Endif
Endif
Affzo [M:MTK2]
End

#######################################
#Pas de suivi matière si mode de lancement OF = opérations seules
Subprog AS_MATTRKFLG(VALEUR)
Variable Integer VALEUR
If [F:MFG]MFGMOD = 3 : VALEUR = 1 : mkstat = 2 : End : Endif
End

########################################
Subprog AM_MATTRKFLG(VALEUR)
Variable Integer VALEUR
Local Integer WRET
If VALEUR = 1 : Effzo [M:MTK3]15
                Grizo [M:MTK3]5,10,15
                Call DELSTOSORW(-1,0,"MTK3",[M:MTK0]MFGFCY,WRET) From STKSOR   # Issue 73263 - 2011-04-18 by CCC : Mise à jour de SOW
                If WRET : mkstat=2 : Endif
Else          : Actzo [M:MTK3]5,10,15
                # Issue 121922 13/03/2017 by GH - material tracking is unticked & operation or production tracking is ticked
                # we tick material tracking -> block 5 is still not enterable
                If [M:MTK0]ITMTRKFLG = 2 | [M:MTK0]OPETRKFLG = 2
                   Grizo [M:MTK3]5
                Endif
Endif
Affzo [M:MTK3]
End

#-------------------- Action sur écran MTK1-------------------------------#
########################################
Subprog AP_FILTOPE(VALEUR)
Variable Integer VALEUR
Local Integer WVALEUR, WRET
Local Char WMFGNUM(GLONVCR)
WMFGNUM = [M:MTK0]MFGNUM
WVALEUR = VALEUR
If (GREP <> "C" | [M:MTK1]NBOPE <> 0) & VALEUR = [M:MTK1]FILTOPE : End : Endif
If [M:MTK0]OPETRKFLG <> 2 : End : Endif
#Chargement de l'écran Opé selon sélection
Effzo [M:MTK1]10
Raz [M:MTK0]WOPEPROD
Call CHARG_OPE(WMFGNUM,VALEUR) From SUBMTKB
[M:MTK1]FILTOPE = VALEUR
Affzo [M:MTK1]
If [M:MTK1]NBOPE = 0 : Call MESSAGE(mess(99,100,1)) From GESECRAN
Endif
If  [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2
#    [M:MTK3]STOCOD  = 3
    [M:MTK3]FILTMAT = VALEUR
    If [M:MTK1]NBOPE <> 0 :  [M:MTK3]WOPE1   = [M:MTK1]OPENUM(0)
                             [M:MTK3]WOPE2   = [M:MTK1]OPENUM(NBOPE-1)
    Endif
    Grizo [M:MTK3]5
    Effzo [M:MTK3]15
    Call DELSTOSORW(-1,0,"MTK3",[M:MTK0]MFGFCY,WRET) From STKSOR
    Call CHARG_MAT([M:MTK0]MFGNUM,VALEUR,0,0) From SUBMTKB
    # CCC (2010-04-20) Bug 64171 : Afficher GMESSAGE au cas où il serait remis à blanc dans CHARG_ITM
    If GMESSAGE<>"" : Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE : Endif
    Local Char LMSG(len(GMESSAGE)+1)
    LMSG=GMESSAGE
    Affzo [M:MTK3]
Endif
# 10.01 Ne charger le tableau des articles lancés que si l'opération de production
# est présente demande (tester WOPEPROD) 10683
If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2
    Grizo [M:MTK2]5
    Effzo [M:MTK2]10
    If [M:MTK0]WOPEPROD = 2
       Call DELSTOENTW(-1,-1,"MTK2",1,1,[M:MTK0]MFGFCY,1,"") From STKENT
       Call CHARG_ITM([M:MTK0]MFGNUM,0,1) From SUBMTKB
    Endif
    Affzo [M:MTK2]
    If GMESSAGE="" & dim(LMSG)>0
        GMESSAGE = LMSG
    Endif
Endif
End

########################################
Subprog AV_FILTOPE(VALEUR)
Variable Integer VALEUR
#----- Relecture transaction de saisie si nécessaire -----#
If [F:MTS]MTSTYP<>2 | [F:MTS]MTSNUM<>GMTSNUM
   Read [MTS] MTS0=2;GMTSNUM : If fstat Raz [F:MTS] : Endif
Endif
If [M:MTK1]NBOPE = 0 : VALEUR = [F:MTS]FILTDEF : Endif
End

########################################
Subprog AS_QTESUIVOPE(VALEUR)
Variable Decimal VALEUR
If [F:MFG]TRKFIRST = [0/0/0] & VALEUR = 0
    If [M:MTK1]FILTOPE <> 3
       Case [F:MFG]ITMLINNBR
            When 1 :         VALEUR = [F:MFI]RMNEXTQTY / [F:MFI]UOMSTUCOE
                             Call QTEARR(VALEUR,[F:MFI]UOM) From TRTDIV
            When Default :   VALEUR = [F:MFG]RMNEXTQTY
       Endcase
       If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2
            [M:MTK2]QTESUIVITM = VALEUR
        Endif
       If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2
            [M:MTK3]QTESUIVMAT = VALEUR
        Endif
    Endif
Endif
End

########################################
Subprog AM_QTESUIVOPE(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0
   Case [F:MFG]ITMLINNBR
       When 1       : # Issue 78551 - 2011-12-12 by CCC : [MFI] peut-être positionné sur le sous-produit
                      Filter [MFI] Where MFGNUM=[M:MTK0]MFGNUM
                      Read [MFI]MFI0 First
                      Filter [MFI]
                      [M:MTK1]WCOEFF = VALEUR / [F:MFI]UOMEXTQTY
       When Default : [M:MTK1]WCOEFF = VALEUR / [F:MFG]EXTQTY
   Endcase
# 04.02 demande 13793
Else
   [M:MTK1]WCOEFF = 0
Endif
# 01.02 demande 12597
# 02.03 demande 17092
# CCC (27/11/08) Bug 50667 : Pas d'arondi du coef. mais des résultats uniquement
#[M:MTK1]WCOEFF = arr([M:MTK1]WCOEFF,0.00000001)
Gosub INIT_QTY From SUBMTKB : Affzo [M:MTK1]10
If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2
   [M:MTK2]QTESUIVITM = VALEUR
   Affzo [M:MTK2]5
Endif
If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2
   [M:MTK3]QTESUIVMAT = VALEUR
   Affzo [M:MTK3]QTESUIVMAT
Endif
# 04.02 demande 13793
#Else
#   [M:MTK1]WCOEFF = 1

#Endif
End

########################################
Subprog AVANT_NBOPE
Local Integer OK
Local Integer J,NOL : NOL = nolign-1
# 06.02 demande 14752
#   02.07 demande 39600
If GREP <> "C" | GCTLOPEPRE <> 2 | NOL = 0 | [M:MTK1]OPENUM(NOL) = 0 | [M:MTK1]OPEPREC(NOL)=0 : End : Endif
Filter [MFO] Where MFGNUM = [M:MTK1]MFGNUMOP(NOL) & OPENUM = [M:MTK1]OPEPREC(NOL)
Read [MFO]MFO0 First
If fstat : Raz [F:MFO] : Endif
Filter [MFO]
If [F:MFO]TRKFIRST <> [0/0/0] | [F:MFO]OPESTA = 6 : End : Endif
# GH 05/12/2013 bug 90095 test que l'opération précédente peut être suivie
Read [SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
If fstat : Raz [F:SCH] : Endif
If [F:SCH]DACMST = 1 : End : Endif
#
J = find ([M:MTK1]OPEPREC(NOL),[M:MTK1]OPENUM(0..NOL-1))
If J & [M:MTK1]MODIFLG(J-1) = 0 &
&      ([M:MTK1]CPLQTY(J-1)<>0 |[M:MTK1]CPLOPETIM(J-1)<>0 | [M:MTK1]CPLSETTIM(J-1) <> 0)
        End
Endif
Call AVERTIR(mess(82,193,1),OK) From GESECRAN
If OK = 1 : mkstat = 1 : GMODIF = 1 : End : Endif
End

########################################
Subprog C_NBOPE
Local Integer NOL, OK

Local Integer WNCSLINFLG
WNCSLINFLG = 0

#
# pour bug moteur

If [M:MTK1]NBOPE > 0
  If [M:MTK1]CPLWST([M:MTK1]NBOPE-1) = ""
    status=65 : nolign=[M:MTK1]NBOPE
    Dela [M:MTK1]NBOPE-1,1,[M:MTK1]NBOPE-1 [M:MTK1]NBOPE : [M:MTK1]NBOPE-=1
  Endif
Endif
GMODIF=2    # pour bug moteur
Case status
    When 75:          NOL=nolign-1                    # Modification
                      Gosub TEST_MOD
    When 82:          If GREP <> "C"
                          NOL=nolign-1                    # Reprise
                          GMODIF=1    # pour bug moteur
                          mkstat=2
                          End
                      Endif
                      # Issue 110979/2 - 2016-03-25 by CCC : Warning message when routing is versioned (warning on the first add)
                      If [F:MFG]MFGNUM<>[M:MTK0]MFGNUM
                          Read [F:MFG]MFG0 = [M:MTK0]MFGNUM
                      Endif
                      If [F:MFG]ROUECCMAJ <> "" & !find(0,[M:MTK1]ROUOPENUM(0..[M:MTK1]NBOPE-1))
                          OK=1
                          Call AVERTIR(mess(345,193,1),OK) From GESECRAN
                          If OK = 1 : mkstat = 1 : End : Endif # Cancel
                      Endif
Endcase
End

########################################
$TEST_MOD
Local Integer OK,J
GMODIF = 2
# si ope exclue ou  suivi automatiquement par borne ou si fiche technique
If [M:MTK1]MODIFLG(NOL) = 1:  GMESSAGE = mess(83,193,1)
    GMODIF = 1
    mkstat = 1
    Return
Endif
If  [M:MTK1]DACMST(NOL) = 1 : mkstat = 1 : GMODIF = 1 : Return : Endif
#Si opération précedente non suivie message d'erreur selon GCTLOPEPRE
# 06.02 demande 14752
If GCTLOPEPRE <> 3 | [M:MTK1]OPEPREC(NOL) = 0 :  Return : Endif
Filter [MFO] Where MFGNUM = [M:MTK1]MFGNUMOP(NOL) & OPENUM = [M:MTK1]OPEPREC(NOL)
Read [MFO]MFO0 First
If fstat : Raz [F:MFO] : Endif
Filter [MFO]
If [F:MFO]TRKFIRST <> [0/0/0] | [F:MFO]OPESTA = 6 : Return : Endif
# GH 05/12/2013 bug 90095 test que l'opération précédente peut être suivie
Read [SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
If fstat : Raz [F:SCH] : Endif
If [F:SCH]DACMST = 1 : Return : Endif
#
If NOL > 0
    J = find ([M:MTK1]OPEPREC(NOL),[M:MTK1]OPENUM(0..NOL-1))
Endif
If J & [M:MTK1]MODIFLG(J-1) = 0 &
&     ([M:MTK1]CPLQTY(J-1)<>0 | [M:MTK1]CPLOPETIM(J-1)<>0 | [M:MTK1]CPLSETTIM(J-1) <> 0)
      Return
Endif
GMESSAGE = mess(22,190,1)-num$([M:MTK1]OPENUM(NOL))
mkstat = 1 : GMODIF = 1 : Return
Return

########################################
Subprog B5_NBOPE
#Activation,suppression opé
Local Integer I, OK
Local Integer NOL : NOL = nolign-1
If [M:MTK1]ROUOPENUM(NOL) <> 0
    Case[M:MTK1]MODIFLG(NOL)
        When 0 : [M:MTK1]CPLQTY(NOL)  = 0
                 [M:MTK1]MODIFLG(NOL) = 1
                 If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2
                     I = nolign
                     Gosub SUP_MAT From SUBMTKB
                 Endif
                 If [M:MTK1]DACMST(NOL) = 3 : Gosub SUP_OPE From SUBMTKB : Endif
         When 1 : [M:MTK1]CPLQTY(NOL)  = [M:MTK1]WANCQTY(NOL)
                 [M:MTK1]MODIFLG(NOL) = 0
                 If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2
                     I = nolign
                     Gosub REACTIV_MAT From SUBMTKB
                 Endif
                 If [M:MTK1]DACMST(NOL) = 3 : Gosub REACTIVE_OPE From SUBMTKB : Endif
     Endcase
    If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2
        Affzo [M:MTK3]15
    Endif
Else
    Dela NOL,1,[M:MTK1]NBOPE-1 [M:MTK1]NBOPE : [M:MTK1]NBOPE-=1
Endif
Affzo [M:MTK1]10
mkstat = 4
End



########################################
Subprog APRES_NBOPE
# JAMCC JIRA TICKET X3-63085
If status = 6
    # Recalculate Grid
    Call CALCULATE_CPLQTY
Endif

End

########################################
Subprog C_OPENUM(VALEUR)
Variable Decimal VALEUR
Local Integer J
#Pas 2 fois la même opération
Filter [F:MFO] Where MFGNUM = [M:MTK0]MFGNUM & OPENUM = VALEUR
Look [F:MFO]MFO0 First
If !fstat GMESSAGE = mess(70,193,1) : mkstat = 1 : Filter [F:MFO] : End : Endif
If instr(1,dbgstr(1),"MTK1")
    #Le solde est pré-chargé avec la valeur "OUI"
    [M:MTK1]CLEFLG(nolign-1) = 2
    #On récupère l'unité de temps
    [M:MTK1]TIMUOMCOD(nolign-1) = [M:MTK0]TIMUOMCOD
    [M:MTK1]OPESTUCOE(nolign-1) = 1
    # suivi normal
    [M:MTK1]DACMST(nolign-1) = 2
    If [M:MTK1]OPETRKLIN(nolign-1) = 0
        [M:MTK1]OPETRKLIN(nolign-1) = [M:MTK1]NBOPE+1
    Endif
    # 06.06 demande 36551
    [M:MTK1]OPEWORCOE(nolign-1) = 1
Else
    #Le solde est pré-chargé avec la valeur "OUI"
    [M:MTO1]CLEFLG = 2
    #On récupère l'unité de temps
    [M:MTO1]TIMUOMCOD = [M:MTK0]TIMUOMCOD
    [M:MTO1]OPESTUCOE = 1
    # suivi normal
    [M:MTO1]DACMST = 2
    # 06.06 demande 36551
    [M:MTO1]OPEWORCOE = 1
Endif
Filter [F:MFO]
End

########################################
Subprog C_STDOPENUM(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : End : Endif
If clalev([ROT])=0 : Local File ROUOPESTD  [ROT] : Endif
If clalev([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
Read [F:ROT]ROT0 = VALEUR;[M:MTK0]MFGFCY
If fstat : GMESSAGE = mess(133,193,1) : mkstat = 1 : End : Endif
#Pas d'opération de sous-traitance
Read [F:MWS]WST0 = [F:ROT]WST;[M:MTK0]MFGFCY
If fstat : Raz [F:MWS] : Endif
If [F:MWS]WSTTYP = 3 : GMESSAGE = mess(30,190,1) : mkstat = 1 : End : Endif
End

########################################
Subprog AM_STDOPENUM(VALEUR)
Variable Decimal VALEUR
Local Integer OK
Local Decimal WCOEFF
If VALEUR <> 0
 OK=1
 Call OUINON(mess(1,190,1),OK) From GESECRAN
 If OK=2
    If instr(1,dbgstr(1),"MTK1")
        Read [ROT]ROT0=VALEUR;[M:MTK0]MFGFCY
        If !fstat
             If [F:ROT]OPEUOM="" :[F:ROT]OPEUOM = [M:MTK1]UOM : Endif
             [M:MTK1]                  = [F:ROT]
             # FGR 21/09/2009 : X3SUIVI57981
             #[M:MTK1]ROODES(nolign-1)  = [F:ROT]STDOPEDES
             # FGR 01/10/2009 : X3SUIVI58277 : il y avait GLANGUE comme paramètre en trop
             Call LECTEXTRA([M:MTK1]ROODES(nolign-1),"ROUOPESTD","STDOPEDESAXX",num$([F:ROT]STDOPENUM),[F:ROT]FCY) From ATEXTRA
             [M:MTK1]CPLWST            = [F:ROT]WST
             Read [F:MWS]WST0          = [M:MTK1]CPLWST;[M:MTK0]MFGFCY
             If !fstat
                # [M:MTK1]WSTSHO(nolign-1)  = [F:MWS]WSTSHO : # GH 28/02/2014 bug 95952
                Call LECTEXTRA([M:MTK1]WSTSHO(nolign-1),"WORKSTATIO","WSTSHOAXX",[M:MTK1]CPLWST,[M:MTK0]MFGFCY) From ATEXTRA
                [M:MTK1]WSTTYP(nolign-1)  = [F:MWS]WSTTYP
             Endif
             [M:MTK1]CPLLAB(nolign-1)      = [F:ROT]LABWST
             [M:MTK1]TECCRD(nolign-1)      = [F:ROT]TECCRD
        Endif
    Else
        Read [ROT]ROT0=VALEUR;[M:MTK0]MFGFCY
        If !fstat
             If [F:ROT]OPEUOM="" :[F:ROT]OPEUOM = [M:MTK1]UOM : Endif
             [M:MTO1]                  = [F:ROT]
             # FGR 21/09/2009 : X3SUIVI57981
             #[M:MTO1]ROODES            = [F:ROT]STDOPEDES
             # FGR 01/10/2009 : X3SUIVI58277 : il y avait GLANGUE comme paramètre en trop
             Call LECTEXTRA([M:MTO1]ROODES,"ROUOPESTD","STDOPEDESAXX",num$([F:ROT]STDOPENUM),[F:ROT]FCY) From ATEXTRA
             [M:MTO1]CPLWST            = [F:ROT]WST
             Read [F:MWS]WST0          = [M:MTO1]CPLWST;[M:MTK0]MFGFCY
             If !fstat
                #[M:MTO1]WSTSHO  = [F:MWS]WSTSHO : # GH 28/02/2014 bug 95952
                Call LECTEXTRA([M:MTO1]WSTSHO,"WORKSTATIO","WSTSHOAXX",[M:MTO1]CPLWST,[M:MTK0]MFGFCY) From ATEXTRA
                [M:MTO1]WSTTYP  = [F:MWS]WSTTYP
             Endif
             [M:MTO1]CPLLAB      = [F:ROT]LABWST
             [M:MTO1]TECCRD      = [F:ROT]TECCRD
        Endif
    Endif
  Endif
Endif
If instr(1,dbgstr(1),"MTK1")
    # RECHERCHE coefficient US/UO
    Call RECH_COEFF([M:MTK1]UOM, [M:MTK1]OPEUOM(nolign-1), WCOEFF) From MFGLIB
    If WCOEFF <> 0
       [M:MTK1]OPEWORCOE(nolign-1) = WCOEFF
    Else
       [M:MTK1]OPEWORCOE(nolign-1) = 1
    Endif
    If WCOEFF <> 1
       [M:MTK1]CPLQTY(nolign-1) = [M:MTK1]QTESUIVOPE * WCOEFF
    Else
        [M:MTK1]CPLQTY(nolign-1) = [M:MTK1]QTESUIVOPE
    Endif
    [M:MTK1]TIMUOMCOD(nolign-1) = [M:MTK0]TIMUOMCOD
    Affzo [MTK1]10
Else
    # RECHERCHE coefficient US/UO
    Call RECH_COEFF([M:MTK1]UOM, [M:MTO1]OPEUOM, WCOEFF) From MFGLIB
    If WCOEFF <> 0
       [M:MTO1]OPEWORCOE = WCOEFF
    Else
       [M:MTO1]OPEWORCOE = 1
    Endif
    If WCOEFF <> 1
       [M:MTO1]CPLQTY = [M:MTK1]QTESUIVOPE * WCOEFF
    Else
        [M:MTO1]CPLQTY = [M:MTK1]QTESUIVOPE
    Endif
    [M:MTO1]TIMUOMCOD = [M:MTK0]TIMUOMCOD
    Affzo [MTO1]
 Endif

End


########################################
Subprog AS_OPESPLNUM(VALEUR)
Variable Decimal VALEUR
End

###########################################
Subprog C_CPLWST(VALEUR)
Variable Char     VALEUR
Local Integer OK

If instr(1,dbgstr(1),"MTK1")
    # contrôle existence
    If VALEUR <> ""
            Read [MWS]WST0=VALEUR;[M:MTK0]MFGFCY
            If fstat
               GMESSAGE= VALEUR+"\"+mess(23,100,1) : mkstat=1
            Else
              If [F:MWS]WCRFCY <> [M:MTK0]MFGFCY
                  GMESSAGE = mess(116,193,1) - [M:MTK0]MFGFCY
                  mkstat = 1
                  End
               Endif
           Endif
    Endif
Else
    # contrôle existence
    If VALEUR <> ""
            Read [MWS]WST0=VALEUR;[M:MTO1]MFGFCY
            If fstat
               GMESSAGE= VALEUR+"\"+mess(23,100,1) : mkstat=1
            Else
              If [F:MWS]WCRFCY <> [M:MTO1]MFGFCY
                  GMESSAGE = mess(116,193,1) - [M:MTO1]MFGFCY
                  mkstat = 1
                  End
               Endif
           Endif
    Endif
Endif
#
# Issue 110979/2 - 2016-03-25 by CCC : Warning message when modifying an existing operation of a versioned routing
If VALEUR<>[M:MTK1]CPLWST(nolign-1) & [M:MTK1]ROUOPENUM(nolign-1)<>0
    If [F:MFG]MFGNUM<>[M:MTK0]MFGNUM(nolign-1)
        Read [F:MFG]MFG0 = [M:MTK0]MFGNUM(nolign-1)
    Endif
    If [F:MFG]ROUECCMAJ <> ""
        If [F:MFO]MFGNUM<>[M:MTK0]MFGNUM(nolign-1) | [F:MFO]OPENUM<>[M:MTK1]OPENUM(nolign-1) | [F:MFO]OPESPLNUM<>[M:MTK1]OPESPLNUM(nolign-1)
            Raz [F:MFO]
            Read [F:MFO]MFO0 = [M:MTK0]MFGNUM(nolign-1);[M:MTK1]OPENUM(nolign-1);[M:MTK1]OPESPLNUM(nolign-1)
        Endif
        If [F:MFO]MFGNUM<>"" & VALEUR<>[F:MFO]EXTWST
            OK=1
            Call AVERTIR(mess(346,193,1),OK) From GESECRAN
            If OK = 1 : mkstat=1 : End : Endif # Cancel
        Endif
    Endif
Endif
End

########################################
Subprog AM_CPLWST(VALEUR)
Variable Char    VALEUR()
Local Char    WCCE(15)

If instr(1,dbgstr(1),"MTK1")
    Read [F:MWS]WST0 = VALEUR;[M:MTK0]MFGFCY
    If !fstat
        If [F:MWS]WSTTYP = 3 : Call ERREUR(mess(30,190,1)) From GESECRAN
            mkstat = 1
            End
        Endif
        #[M:MTK1]WSTSHO(nolign-1) = [F:MWS]WSTSHO : # GH 28/02/2014 bug 95952
        Call LECTEXTRA([M:MTK1]WSTSHO(nolign-1),"WORKSTATIO","WSTSHOAXX",VALEUR,[M:MTK0]MFGFCY) From ATEXTRA
        [M:MTK1]WSTTYP(nolign-1) = [F:MWS]WSTTYP
        #Chargement des sections ana
        For J = 1 To GNBDIE
            Call INISEC(WCCE,"MKO", J) From TRTX3CPT
            Assign "[M:MTK1]CCE"+num$(J)+"(nolign-1)" With WCCE
        Next
    Endif
Else
    Read [F:MWS]WST0 = VALEUR;[M:MTO1]MFGFCY
    If !fstat
        If [F:MWS]WSTTYP = 3 : Call ERREUR(mess(30,190,1)) From GESECRAN
            mkstat = 1
            End
        Endif
        #[M:MTO1]WSTSHO = [F:MWS]WSTSHO : # GH 28/02/2014 bug 95952
        Call LECTEXTRA([M:MTO1]WSTSHO,"WORKSTATIO","WSTSHOAXX",VALEUR,[M:MTO1]MFGFCY) From ATEXTRA
        [M:MTO1]WSTTYP = [F:MWS]WSTTYP
        # FQ 55248 GA 05/2009
        If dim([M:MTO1]CCE1)>0 & dim(GNBDIE)>0
          #Chargement des sections ana
          For J = 1 To GNBDIE
              Call INISEC(WCCE,"MKO", J) From TRTX3CPT
              Assign "[M:MTO1]CCE"+num$(J) With WCCE
          Next
        Endif
    Endif
Endif
End

Subprog C_CPLQTY(VALEUR)
Variable Decimal VALEUR
# JAMCC - Jira ticket X3-63085
# display error message if changed will result in a negative
# total actual quanity
# only check if modifying the first row of the grid
If nolign-1 = 0
    Local Integer TOT_REJ
    For CTL = 0 To [M:MTK1]NBOPE-2 # Do not include last row of grid
        TOT_REJ = TOT_REJ + [M:MTK1]REJCPLQTY(CTL)
    Next
    If VALEUR - TOT_REJ < 0
        Call ERREUR(mess(258,190,1)) From GESECRAN
        mkstat = 1
    Endif
Endif
End

########################################
Subprog AS_CPLQTY(VALEUR)
Variable Decimal VALEUR
End

########################################
Subprog AM_CPLQTY(VALEUR)
Variable Decimal VALEUR
Local Decimal WCOEFF
Local Integer NOL,LRET,I,OK
Local Char WZONE(12) : WZONE = "CPLQTY"

If instr(1,dbgstr(1),"MTO1")
#    Initialisation du flag solde opé apres modif de la qté réalisée
     If (GREP = "C" & VALEUR > [M:MTO1]EXTQTY) |
&       (GREP <> "C" & VALEUR - [M:MTK1]CPLQTY > [M:MTO1]EXTQTY)
        If [M:MTO1]ROUOPENUM <> 0
            Call AVERTIR(mess(54,190,1),OK) From GESECRAN
            If OK = 1 : mkstat = 1 : End : Endif
        Endif
        [M:MTO1]CLEFLG = 2
     Endif

#    Proposition de solde si qté prévue - qté réalisée correspond <= % de tolérance
     Call CONT_SOLDE_OPE([M:MTO1]MFGFCY,[M:MTO1]CPLWST,VALEUR,[M:MTO1]EXTQTY,LRET) From MFGLIBO
     If LRET = 1 : [M:MTO1]CLEFLG = 2
     Else          [M:MTO1]CLEFLG = 1
     Endif

#    Ajustement du tps réalisé opé ssi temps non forfaitaire
     If [M:MTO1]ROOTIMCOD <> 3   | VALEUR = 0
        # Issue 82636 - 2012-07-02 by CCC : Si le temps unitaire n'était pas renseigné (qté prcédenteà 0)
        #                                   on le calcule à partir du temps opératoire
        If VALEUR<>0 & [M:MTO1]CPLUNTTIM=0
            [M:MTO1]CPLUNTTIM = [M:MTO1]CPLOPETIM/VALEUR
        Else
            [M:MTO1]CPLOPETIM = VALEUR * [M:MTO1]CPLUNTTIM
            # Issue 88561 - 2013-03-15 by CCC
            If [M:MTO1]ROOTIMCOD = 2
                # GH 08/10/2014 bug 101352
                #[M:MTO1]CPLOPETIM = VALEUR / [M:MTO1]CAD / ([M:MTO1]EFF / 100)
                [M:MTO1]CPLOPETIM = VALEUR * [M:MTO1]OPEWORCOE / [M:MTO1]CAD / ([M:MTO1]EFF / 100)
            Endif
        Endif
     Else
         If VALEUR <> 0 : [M:MTO1]CPLUNTTIM =  [M:MTO1]CPLOPETIM / VALEUR : Endif        # llc 06.04 15812
     Endif

     If VALEUR = 0 : Raz [M:MTO1]CPLSETTIM : Endif
     # 11.06 demande 38402
     [M:MTO1]CPLUNTTIM = func TRTX3.ARRTYP("","","TIH",[M:MTO1]CPLUNTTIM)
     [M:MTO1]CPLOPETIM = func TRTX3.ARRTYP("","","TIH",[M:MTO1]CPLOPETIM)
     [M:MTO1]CPLSETTIM = func TRTX3.ARRTYP("","","TIH",[M:MTO1]CPLSETTIM)
#    Initialisation de la qté OK
     [M:MTO1]OKQTY = VALEUR - [M:MTO1]REJCPLQTY
     [M:MTO1]CPLQTY = VALEUR
     Affzo [M:MTO1]
Else
     NOL = nolign-1
#    Initialisation du flag solde opé apres modif de la qté réalisée
     If [M:MTK1]MFOEXTQTY(NOL) <> 0
         WCOEFF = VALEUR / ([M:MTK1]MFOEXTQTY(NOL) / [M:MTK1]OPEWORCOE(NOL))
     Endif
     If (GREP = "C" & VALEUR > [M:MTK1]EXTQTY(NOL))
# CCC (11/03/09) Bug 53390  : La modif est impossible sur cet écran MTK1
#&     | (GREP <> "C" & VALEUR - [M:MTK1]CPLQTY(NOL) > [M:MTK1]EXTQTY(NOL))
          If [M:MTK1]ROUOPENUM(NOL) <> 0
                Call AVERTIR(mess(54,190,1),OK) From GESECRAN
                If OK = 1 : mkstat = 1 : End
                 Endif
          Endif
          [M:MTK1]CLEFLG(NOL) = 2
     Endif
     [M:MTK1]CPLQTY(NOL) = VALEUR
#    Proposition de solde si qté prévue - qté réalisée correspond <= % de tolérance
     Call CONT_SOLDE_OPE([M:MTK0]MFGFCY,[M:MTK1]CPLWST(NOL),VALEUR,[M:MTK1]EXTQTY(NOL),LRET) From MFGLIBO
     If LRET = 1 : [M:MTK1]CLEFLG(NOL) = 2
     Else          [M:MTK1]CLEFLG(NOL) = 1
     Endif
#    Maj de la qté réalisée au niveau article lancé si déclaration de prod et si opé de prod
     If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2 & [M:MTK1]MFGMST(NOL) = 2
        Gosub REAJUST_ITM From SUBMTKB
        Affzo [M:MTK2]10
     Endif
#    Réajustement des qtés consommées des matières concernées
     If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]CONSMAT <> 1
         I = NOL + 1
         Gosub REAJUST_OPEMAT From SUBMTKB
     Endif

#    Ajustement du tps réalisé opé ss temps non forfaitaire
     If [M:MTK1]ROOTIMCOD(NOL) <> 3 | VALEUR = 0
        # Issue 82636 - 2012-07-02 by CCC : Si le temps unitaire n'était pas renseigné (qté prcédenteà 0)
        #                                   on le calcule à partir du temps opératoire
        #[M:MTK1]CPLOPETIM(NOL) = VALEUR * [M:MTK1]CPLUNTTIM(NOL)
        If VALEUR<>0 & [M:MTK1]CPLUNTTIM(NOL)=0
            [M:MTK1]CPLUNTTIM(NOL) = [M:MTK1]CPLOPETIM(NOL)/VALEUR
        Else
            [M:MTK1]CPLOPETIM(NOL) = VALEUR * [M:MTK1]CPLUNTTIM(NOL)
            # Issue 88561 - 2013-03-15 by CCC
            If [M:MTK1]ROOTIMCOD(NOL) = 2
                # GH 08/10/2014 bug 101352
                #[M:MTK1]CPLOPETIM(NOL) = VALEUR / [M:MTK1]CAD(NOL) / ([M:MTK1]EFF(NOL) / 100)
                [M:MTK1]CPLOPETIM(NOL) = VALEUR  * [M:MTK1]OPEWORCOE(NOL) / [M:MTK1]CAD(NOL) / ([M:MTK1]EFF(NOL) / 100)
            Endif
        Endif
     Else
         If VALEUR <> 0 : [M:MTK1]CPLUNTTIM(NOL) =  [M:MTK1]CPLOPETIM(NOL) / VALEUR : Endif        # llc 06.04 15812
     Endif
     If VALEUR = 0 : Raz [M:MTK1]CPLSETTIM(NOL) : Endif
     # 11.06 demande 38402
     [M:MTK1]CPLUNTTIM(NOL) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLUNTTIM(NOL))
     [M:MTK1]CPLOPETIM(NOL) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLOPETIM(NOL))
     [M:MTK1]CPLSETTIM(NOL) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLSETTIM(NOL))

    [M:MTK1]OKQTY(NOL) = VALEUR - [M:MTK1]REJCPLQTY(NOL)
#    si opération borne calcul des qtés réalisées et tps pour toutes les opérations
#    à suivre en auto.
     If [M:MTK1]DACMST(NOL) = 3 : Gosub CALC_QTY From SUBMTKB : Endif
#
     If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]CONSMAT <> 1
     Affzo [M:MTK3]15
     Endif
Endif

# JAMCC - Jira ticket X3-63085
If instr(1,dbgstr(1),"MTK1") or instr(1,dbgstr(1),"MTO1")
    # After user enters value recalculate next row (Total Actual Qty) to ensure
    # all values are up to date before recalculating whole grid
    # Only do if not on last line of the grid
    If nolign<>[M:MTK1]NBOPE
       [M:MTK1]CPLQTY(nolign) = [M:MTK1]CPLQTY(nolign-1) - VALEUR
       Affzo [M:MTK1]CPLQTY(nolign)
    Endif
    # Recalculate Grid
    Call CALCULATE_CPLQTY
Endif

    # X3-80367 - Check if a NC exists for this Production tracking
    Call CHECK_NCS_EXISTS (0)
    If OK = 1
        End
    Endif

End

########################################
Subprog C_REJCPLQTY(VALEUR)
Variable Decimal VALEUR

Local Decimal LCPLQTY

If instr(1,dbgstr(1),"MTO1")
    LCPLQTY = [M:MTO1]CPLQTY
Elsif instr(1,dbgstr(1),"MTO3")
    LCPLQTY = [M:MTO3]CPLQTY
Else
    LCPLQTY = [M:MTK1]CPLQTY(nolign-1)
Endif
If VALEUR > LCPLQTY
    Call ERREUR(mess(21,190,1)) From GESECRAN
    mkstat = 1
    End
Endif

# JAMCC - Jira ticket X3-63085
# display error message if entered actual rejected qty will result in a negative
# total actual quanity
# do not check if on last line of grid
If nolign<>[M:MTK1]NBOPE
   Local Integer TOT_REJ
   Local Integer CHECK_TOT_REJ
   # calculate existing total rejected qty
   For CTL = 0 To [M:MTK1]NBOPE-2 # Do not include last row of grid
       TOT_REJ = TOT_REJ + [M:MTK1]REJCPLQTY(CTL)
   Next
   # Calculate the total rejected qty if change permitted
   CHECK_TOT_REJ = TOT_REJ - [M:MTK1]REJCPLQTY(nolign-1) + VALEUR
   # check if the change is permitted will not = a negative figuer
   If [M:MTK1]CPLQTY(0) - CHECK_TOT_REJ < 0
      Call ERREUR(mess(258,190,1)) From GESECRAN
      mkstat = 1
   Endif
Endif

End

########################################
Subprog AM_REJCPLQTY(VALEUR)
Variable Decimal VALEUR
Local Integer NOL, OK, WI
Local Char WZONE(12) : WZONE = "REJCPLQTY"
Local Decimal WCOEFF
If instr(1,dbgstr(1),"MTO1")
        If VALEUR = 0
           For WI = 0 To 14
               Raz [M:MTO1]TABREJQTY(WI), SCANUM(WI), SCANUM1
           Next WI
        Else
            If [M:MTO1]TABREJQTY(1) <> 0
               [M:MTO1]REJCPLQTY = VALEUR
#               Call B1_REJCPLQTY(VALEUR)
            Else
               [M:MTO1]TABREJQTY(0) = VALEUR
            Endif
        Endif
        [M:MTO1]OKQTY = [M:MTO1]CPLQTY - VALEUR
        Affzo [M:MTO1]OKQTY
Elsif instr(1,dbgstr(1),"MTO3")
        If VALEUR = 0
         For WI = 0 To 14
             Raz [M:MTO3]TABREJQTY(WI), SCANUM(WI)
         Next WI
        Endif
        [M:MTO3]OKQTY = [M:MTO3]CPLQTY - VALEUR
Else
        NOL = nolign-1
        If VALEUR = 0
           For WI = 1 To 15
               Assign "[M:MTK1]TAREJQTY"+num$(WI) With 0
               Assign "[M:MTK1]SCANUM"+num$(WI)   With 0
           Next WI
        Else
            If [M:MTK1]TAREJQTY2(nolign-1) <> 0
               [M:MTK1]REJCPLQTY(nolign-1) = VALEUR
#               Call B1_REJCPLQTY(VALEUR)
            Else
               [M:MTK1]TAREJQTY1(nolign-1) = VALEUR
            Endif
        Endif
        [M:MTK1]OKQTY(NOL) = [M:MTK1]CPLQTY(NOL) - VALEUR
        [M:MTK1]REJCPLQTY(NOL) = VALEUR
        If [M:MTK1]MFOEXTQTY(NOL) <> 0
            WCOEFF = VALEUR / ([M:MTK1]MFOEXTQTY(NOL) / [M:MTK1]OPEWORCOE(NOL))
        Endif
        # CCC (2009-04-10) Bug 54310 : La quantité de rebut concernen uniquement l'opération en cours de saisie pour éviter de cumuler les qté rejetées
        ##Si opération borne maj des qté rejetées des opé à suivre automatiquement
        #If [M:MTK1]DACMST(NOL) = 3 : Gosub CALC_QTY From SUBMTKB : Endif
Endif

# JAMCC - Jira ticket X3-63085
If instr(1,dbgstr(1),"MTK1") or instr(1,dbgstr(1),"MTO1")
    # After user enters value recalculate next row (Total Acdtual Qty) to ensure
    # all values are up to date before recalculating whole grid
    # Only do if not on last line of grid
    If nolign<>[M:MTK1]NBOPE
        [M:MTK1]CPLQTY(nolign) = [M:MTK1]CPLQTY(nolign-1) - VALEUR
        Affzo [M:MTK1]CPLQTY(nolign)
    Endif
    # Recalculate Grid
    Call CALCULATE_CPLQTY
Endif

    # X3-80367 - Check if a NC exists for this Production tracking
    Call CHECK_NCS_EXISTS (0)
    If OK = 1
        End
    Endif

End

########################################
Subprog AM_CPLUNTTIM(VALEUR)
Variable Decimal VALEUR
#Recalcul du tps opé réalisé
If instr(1,dbgstr(1),"MTO1")
    If [M:MTO1]ROOTIMCOD <> 3    : # FQ 42739 01/2008 sauf temps forfaitaire
       [M:MTO1]CPLOPETIM = [M:MTO1]CPLQTY * VALEUR
    Endif
     # 11.06 demande 38402
     [M:MTO1]CPLOPETIM = func TRTX3.ARRTYP("","","TIH",[M:MTO1]CPLOPETIM)
    Affzo [M:MTO1]CPLOPETIM
Else
    If [M:MTK1]ROOTIMCOD(nolign-1) <> 3    : # FQ 42739 01/2008 sauf temps forfaitaire
       [M:MTK1]CPLOPETIM(nolign-1) = [M:MTK1]CPLQTY(nolign-1) * VALEUR
    Endif
     # 11.06 demande 38402
     [M:MTK1]CPLOPETIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLOPETIM(nolign-1))
    Affzo [M:MTK1]CPLOPETIM(nolign-1)
Endif
End

