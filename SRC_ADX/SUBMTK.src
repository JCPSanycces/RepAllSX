##########################################################################
## Etiquette ajoutée par le superviseur 05/09/2003 14:11:35 (SR)
##########################################################################
Subprog AM_CPLLAB(VALEUR)
Variable Char    VALEUR()
Local Char    WCCE(15)
Local Integer J
If instr(1,dbgstr(1),"MTK1")
   Read [F:MWS]WST0 = VALEUR;[M:MTK0]MFGFCY
   If !fstat
       If [F:MWS]WSTTYP = 3 : Call ERREUR(mess(30,190,1)) From GESECRAN
           mkstat = 1
           End
       Endif
       #Chargement des sections ana
       For J = 1 To GNBDIE
           Call INISEC(WCCE,"MKOLAB",J) From TRTX3CPT
           Assign "[M:MTK1]LABCCE"+num$(J)+"(nolign-1)" With WCCE
           Affzo ="[M:MTK1]LABCCE"+num$(J)+"(nolign-1)" : # Issue 38424 GH 24/10/2017 - displays labor dimensions
       Next
    Else
        #RAZ des sections ana
        For J = 1 To GNBDIE
            Assign "[M:MTK1]LABCCE"+num$(J)+"(nolign-1)" With ""
            Affzo ="[M:MTK1]LABCCE"+num$(J)+"(nolign-1)" : # Issue 38424 GH 24/10/2017 - displays labor dimensions
        Next
    Endif
Else
    If VALEUR <> ""
        Read [F:MWS]WST0 = VALEUR;[M:MTO1]MFGFCY
        If !fstat
            If [F:MWS]WSTTYP = 3 : Call ERREUR(mess(30,190,1)) From GESECRAN
                mkstat = 1
                End
            Endif
        Endif
        # FQ 55248 GA 05/2009
        If dim([M:MTO1]LABCCE1)>0 & dim(GNBDIE)>0
          #Chargement des sections ana
          For J = 1 To GNBDIE
              # Issue 38424 GH 24/10/2017 - Use default dimension code MKOLAB instead of MKO
              #Call INISEC(WCCE,"MKO",J) From TRTX3CPT
              Call INISEC(WCCE,"MKOLAB",J) From TRTX3CPT
              Assign "[M:MTO1]LABCCE"+num$(J) With WCCE
          Next
        Endif
    Else
        # FQ 55248 GA 05/2009
        If dim([M:MTO1]LABCCE1)>0 & dim(GNBDIE)>0
          #RAZ des sections ana
          For J = 1 To GNBDIE
              Assign "[M:MTO1]LABCCE"+num$(J) With ""
          Next
        Endif
    Endif
Endif
End

