##########################################################################
Subprog IB_MFGNUM
Raz GBOUT1,GBOUT2,GBOUT3,GBOUT4,GBOUT5,GBOUT6,GBOUT7,GBOUT8
If clalev ([M:MFG0]) <= 0 : GBOUT3 = mess(166,198,1) : Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 27/05/2003 11:05:31 (SR)
##########################################################################
Subprog IB_NBOPE
Local Integer NOL, I, W_SAICCE : NOL = nolign-1
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8, GBOUT9, GBOUT10, GBOUT11, GBOUT12, GBOUT13, GBOUT14
#Bouton fiche technique
If [M:MTK1]TECCRD(NOL) <>  "" : GBOUT4 = mess(77,198,1) : Endif
#Si opé normale
#  Bouton détail suivi et bouton détail Opé , tunnel OF/gamme/poste
If [M:MTK1]ROUOPENUM(NOL) <> 0 & [M:MTK1]TIMTYP(NOL) = 1
    Read [F:MWS]WST0 = [M:MTK1]CPLWST(NOL);[M:MTK0]MFGFCY
    If !fstat & [F:MWS]WSTTYP <> 3
        GBOUT1  = mess(242,198,1)
    Else
        GBOUT13 = mess(242,198,1)
    Endif
    GBOUT2 = mess(243,198,1)
    If clalev ([M:MFG0]) <= 0 :
       GBOUT3 =  mess(166,198,1)
    Endif
#  Bouton ne pas suivre et réactiver sauf pour opé suivies automatiquement ou rajoutée
   If [M:MTK1]DACMST(NOL) > 1 & GREP = "C"
    Case [M:MTK1]MODIFLG(NOL)
         When 0 : GBOUT5 = mess(415,198,1)
         When 1 : GBOUT5 = mess(185,198,1)
    Endcase
   Endif
#  Bouton Saisie manuelle
   If GREP = "C" :  GBOUT6 = mess(252,198,1)
   Else          :  GBOUT6 = mess(181,198,1)
   Endif
#Rajout du bouton correction
# 11.04 demande 26906 on autorise désormais la modification sur les suivis d'opé suivies par borne à l'origine
    If GREP <> "C" & [F:MTK]PTHNUM = ""
        # 07.02 demande 15172 contrôle du  statut de l'OF (OF à la ligne)
        If [M:MTK0]MFGNUM = ""
            Read [F:MFG]MFG0 = [M:MTK1]MFGNUMOP(NOL)
            If fstat : Raz [F:MFG] : Endif
        Endif
        If [F:MFG]MFGSTA <> 4 & [F:MFG]SUSFLG <> 2
           GBOUT8 = mess(284,198,1)
        Endif
    Endif
#Rajout du bouton détail codes rebut si nécessaire
    If GREP <> "C" & [M:MTK1]SCANUM1(NOL) <> 0
        GBOUT10 = mess(413,198,1)
    Endif
#si opé rajoutée ou suivi issu du suivi des temps et pas d'OF
Else
#  Bouton ajouter une opé non prévue, exclure, suivi manuel ou mode fiche
   If [M:MTK1]OPENUM(NOL) = 0 & GREP = "C"     :  GBOUT6 = mess(244,198,1)
   Elsif [M:MTK1]OPENUM(NOL) <> 0 & GREP = "C" :  GBOUT6 = mess(252,198,1)
                                               :  GBOUT5 = mess(415,198,1)
   Elsif [M:MTK1]CPLWST(NOL) <> ""             :  GBOUT6 = mess(181,198,1)
   Endif
#Rajout du bouton correction
   If [M:MTK1]CPLWST(NOL) <> "" & GREP <> "C"
      # 07.02 demande 15172 Contrôle OF à la ligne
      If [M:MTK1]TIMTYP(NOL) = 1 & [M:MTK0]MFGNUM = ""
         Read [F:MFG]MFG0 = [M:MTK1]MFGNUMOP(NOL)
         If fstat : Raz [F:MFG] : Endif
      Endif
      If [M:MTK1]TIMTYP(NOL) <> 1 | [F:MFG]MFGSTA <> 4
         GBOUT8 = mess(284,198,1)
      Endif
   Endif
#Rajout du bouton détail codes rebut si nécessaire
   If GREP <> "C" & [M:MTK1]SCANUM1(NOL) <> 0
       GBOUT10 = mess(413,198,1)
   Endif
Endif
#  Texte
If [M:MTK1]CPLWST(NOL) <> "" : GBOUT7 = mess(38,198,1) : Endif

If [M:MTK1]ROUOPENUM(NOL) <> 0 & [M:MTK1]TIMTYP(NOL) = 2
    GBOUT11 = mess(63,198,1)
Elsif [M:MTK1]TIMTYP(NOL) = 3
    GBOUT12 = mess(29,198,1)
Endif

#Bouton sections analytiques
If clalev([F:MWC]) = 0 Local File WORKCOST [MWC] Endif
Raz [F:MWS]
Read [F:MWS]WST0 = [M:MTK1]CPLWST(nolign-1);[M:MTK0]MFGFCY
Read [F:MWC]WCT0 = [F:MWS]VLTCCE;[M:MTK0]MFGFCY
If !fstat
  For I=0 To GNBDIE-1
    If [F:MWC]CCECOD(I) = 1 : W_SAICCE = 1 : Break : Endif
  Next
  If W_SAICCE = 1
    GBOUT14 = mess(36,103,1)
  Endif
Endif

# Issue 83491 - 2012-08-21 by CCC : Interdiction modif si période de stock "Interdit"
Call STKCTRIPT( [M:MTK0]MFGTRKDAT,[M:MTK0]MFGFCY, "1") From STKLIB
If find(GERR,1,2)
    Raz GBOUT8
    Raz GERR, GMESSAGE, mkstat
Endif
End

