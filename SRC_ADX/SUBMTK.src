######################################################################################


$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE : Return : Endif
If [F:MWS]WST <> [M:MTK1]CPLWST(nolign-1) | [F:MWS]WCRFCY <> [M:MTK0]MFGFCY
    Read [MWS]WST0=[M:MTK1]CPLWST(nolign-1);[M:MTK0]MFGFCY
    If fstat : Raz [F:MWS] : Endif
Endif
Call INIT_CCE(VALEUR,AXE,"MKO","",0) From TRTX3CPT
Return

$D_LABCCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE : Return : Endif
If [M:MTK1]CPLLAB(nolign-1) = "" : Return : Endif
If [F:MWS]WST <> [M:MTK1]CPLLAB(nolign-1) | [F:MWS]WCRFCY <> [M:MTK0]MFGFCY
    Read [MWS]WST0=[M:MTK1]CPLLAB(nolign-1);[M:MTK0]MFGFCY
    If fstat : Raz [F:MWS] : Endif
Endif
Call INIT_CCE(VALEUR,AXE,"MKOLAB","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$AS_LABCCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
If [M:MTK1]CPLLAB(nolign-1) = "" : mkstat = 2 : Return : Endif
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
# Issue 72051 - 2011-03-04 by CCC : initialisation de la date avec la date d'imputation au lieu de [0/0/0]
Local Date WDATE : WDATE = [M:MTK0]MFGTRKDAT
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,WDATE) From TRTX3CPT
Return

Subprog IB_CPLQTY
End

# JAMCC Jira ticket X3-63085
# Recalculate Total Actual Qty for all rows in grid
Subprog CALCULATE_CPLQTY
Local Integer TOT_REJCPLQTY
# loop through each row on grid loop to -2 so not to exceed grid array size
For CTL = 0 To [M:MTK1]NBOPE-2
    # Recalculate Total Actual Qty for all rows in grid
    [M:MTK1]CPLQTY(CTL+1) = [M:MTK1]CPLQTY(CTL) - [MTK1]REJCPLQTY(CTL)
    Affzo [M:MTK1]CPLQTY(CTL+1)
    # Calculate total rejected items on grid
    TOT_REJCPLQTY = TOT_REJCPLQTY + [M:MTK1]REJCPLQTY(CTL)
Next

# Only perform if Production Reporting has been ticked and rows exists
If [M:MTK2]NBITM > 0
    # Update all rows on Material Tab [MTK2] with total rejected items divided by
    # the number of products listed on manufacturing tab
    TOT_REJCPLQTY = ([M:MTK1]CPLQTY(0) - TOT_REJCPLQTY) / [M:MTK2]NBITM
    For CTL = 0 To [M:MTK2]NBITM-1
        [M:MTK2]UOMCPLQTY(CTL) = TOT_REJCPLQTY
        [M:MTK2]CPLQTY(CTL) = TOT_REJCPLQTY
        Affzo [M:MTK2]UOMCPLQTY(CTL)
        Affzo [M:MTK2]CPLQTY(CTL)
    Next
Endif

# Update "Enter Detailed quantities" screen
For CTL = 0 To [M:ENTW]NBLIG
    [M:ENTW]QTYPCU(CTL) = TOT_REJCPLQTY
    [M:ENTW]QTYSTU(CTL) = TOT_REJCPLQTY
Next

End

Subprog CHECK_NCS_EXISTS (DELETION)
Value Integer DELETION
    # X3-80367 - STWIL - Before we change the operation tracking
    # check if this document is in any non-conformances
    If func AFNC.ACTIV ("NCS")
        Local Integer EXISTS
        Local Integer LOK
        Local Char NCSMESS(255)
        [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (3, [M:MTK0]MFGTRKNUM, 0, [L]NCSMESS, DELETION)
        If [L]EXISTS > 0 & GNCSLINFLG = 0
            Call OUINON([L]NCSMESS,LOK) From GESECRAN
            GNCSLINFLG = 1
            If LOK = 1
                GMESSAGE = ""
                mkstat = 2
                End
            Endif
        Endif
    Endif
End

