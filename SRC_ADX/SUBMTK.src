########################################
Subprog IB_SCANUM1
Raz GBOUT1,GBOUT2,GBOUT3,GBOUT4,GBOUT5,GBOUT6,GBOUT7,GBOUT8
If [F:MTS]REBUT = 1      : mkstat = 2 : End : Endif
If instr(1,dbgstr(1),"MTK1")
    If [M:MTK1]REJCPLQTY(nolign-1) = 0 : mkstat = 2 : End : Endif
Else
    If [M:MTO1]REJCPLQTY = 0 : mkstat = 2 : End : Endif
Endif
GBOUT1 = mess(383,198,1)
GBOUT2 = mess(411,198,1)
End

