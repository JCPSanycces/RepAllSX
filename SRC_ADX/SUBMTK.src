    Call CONTROLE("TSR","",WSCANUM,"",mkstat) From CONTOBJ
Endif
End

########################################
Subprog AM_SCANUM1(VALEUR)
Variable Decimal VALEUR
VALEUR          = [F:TSR]SCANUM

If instr(1,dbgstr(1),"MTO1")
    [M:MTO1]SCANUM(0) =  VALEUR
    # FGR 18/09/2009 : X3SUIVI57920
    #[M:MTO1]SCADES  = [F:TSR]SCADES
    Call LECTEXTRA([M:MTO1]SCADES,"TABSCA","SCADESAXX",num$([F:TSR]SCANUM),"") From ATEXTRA
    Affzo [M:MTO1]SCADES
Endif
End

########################################
Subprog C_NBLIG
If status=73 | status=82
    If dim([M:MTO3]SCANUM)<[M:MTO3]NBLIG+1
          GMESSAGE=mess(122,199,1)
          mkstat=2
          End
    Endif
Endif

# X3-80367 - If we are deleting a line check for a NC
If find (status, 65, 68, 83)
    Call CHECK_NCS_EXISTS (0)
    If OK = 1
        End
    Endif
Endif
End

