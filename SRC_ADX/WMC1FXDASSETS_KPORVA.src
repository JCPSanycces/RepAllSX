#<AdxTL>@(#)0.0.0.0 $Revision$Class Asset
# Supervisor
## ACLA-CLASSE ## FXDASSETS_KPORVA
# 2018-11-06 07:07:23 100


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : KANOREAV Revaluation year ( Field L 4)
####################################################################

$SET_KANOREAV
If [L]_AOLDVAL<>this.KANOREAV
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_KANOREAV
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.KANOREAV
 Gosub PROPAGATE_KANOREAV
Endif
Return

$INIT_KANOREAV
Gosub DECLARE_VAR From WMC0FXDASSETS_KPORVA
[L]CURPRO = "KANOREAV"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_KANOREAV
Gosub DECLARE_VAR From WMC0FXDASSETS_KPORVA
[L]CURPRO = "KANOREAV"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_KANOREAV              : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_KANOREAV              : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_KANOREAV
[L]CURPRO = "KANOREAV"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.KANOREAV=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_KANOREAV
[L]CURPRO = "KANOREAV"
Return

$_AOTHERS_KANOREAV
[L]CURPRO = "KANOREAV"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_KANOREAV
[L]CURPRO = "KANOREAV"
Return

$PROPAGATE_KANOREAV
this.isReadonly = 0
[L]CURPRO = "KANOREAV"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_KANOREAV
Gosub DECLARE_VAR From WMC0FXDASSETS_KPORVA
[L]CURPRO = "KANOREAV"
$_LNKPRO_KANOREAV
Return


