#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIPAR7 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone OPTDEV
mkstat = 0
zoncou = "OPTDEV"
indice = 0
IMPENT = [M]OPTDEV
If varinit([M]OPTDEV,indice)=0
 IMPENT = 2
Endif
If varmode([M]OPTDEV,indice)=0
 [M]OPTDEV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPTDEV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OPTDEV(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_OPTDEV(IMPENT) From SUBSIP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "OPTDEV" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]OPTDEV = IMPENT

## Zone OPTMULDEV
mkstat = 0
zoncou = "OPTMULDEV"
indice = 0
IMPENT = [M]OPTMULDEV
If varinit([M]OPTMULDEV,indice)=0
 IMPENT = 1
Endif
If varmode([M]OPTMULDEV,indice)=0
 [M]OPTMULDEV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPTMULDEV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OPTMULDEV(indice)
 Endif
Endif
[M]OPTMULDEV = IMPENT

## Zone AMTDIF
mkstat = 0
zoncou = "AMTDIF"
indice = 0
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M]CURCPY,GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]AMTDIF : Endif
If !mkstat
 If varinit([M]AMTDIF,indice)=0
  [M]AMTDIF = 0
 Endif
Endif
If varmode([M]AMTDIF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AMTDIF" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone OPTDIF
mkstat = 0
zoncou = "OPTDIF"
indice = 0
IMPENT = [M]OPTDIF
If varinit([M]OPTDIF,indice)=0
 IMPENT = 1
Endif
If varmode([M]OPTDIF,indice)=0
 [M]OPTDIF(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPTDIF" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OPTDIF(indice)
 Endif
Endif
[M]OPTDIF = IMPENT

## Zone ACCRNDDEB
mkstat = 0
zoncou = "ACCRNDDEB"
indice = 0
SAVACT = GACTION : GACTION = "INIACCFMT"
Call INIACCFMT(num$([M:SIP5]COA)) From SETGLBCOA
GACTION = SAVACT
If mkstat=1 : Raz [M]ACCRNDDEB : Endif
If !mkstat
 If varmode([M]ACCRNDDEB,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ACCRNDDEB" : Gosub ACTION From =IMPTRT
  Endif
  Call CONTROLE("GAC","!G",[M]ACCRNDDEB,num$([M:SIP5]COA),mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "ACCRNDDEB" : GZNUM = 32449 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ACCRNDCDT
mkstat = 0
zoncou = "ACCRNDCDT"
indice = 0
SAVACT = GACTION : GACTION = "INIACCFMT"
Call INIACCFMT(num$([M:SIP5]COA)) From SETGLBCOA
GACTION = SAVACT
If mkstat=1 : Raz [M]ACCRNDCDT : Endif
If !mkstat
 If varmode([M]ACCRNDCDT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ACCRNDCDT" : Gosub ACTION From =IMPTRT
  Endif
  Call CONTROLE("GAC","!G",[M]ACCRNDCDT,num$([M:SIP5]COA),mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "ACCRNDCDT" : GZNUM = 32448 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SIPAR7"
Return

