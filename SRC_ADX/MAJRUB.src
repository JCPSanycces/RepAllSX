#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du masque TPSVAR
GACTION = "MAJRUB5"
Local Char PARAM(30)(1..3) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,GACTION,"MAJRUB","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "ABA"         : Gosub ABANDON
 When "ENR"         : Gosub ENREGISTRE
 #54868
 When "AVANT_ENR"   : Gosub CONTROLE
 When "FIN"       : Gosub FIN
 #
Endcase
Return

$OUVRE
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
Local Integer FLMOD , OKRUB , PLEIN
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$DEBUT
If dim([M]LEG)<0
  GCURLEG = GDOSLEG
  Gosub CHARGE
Elsif GLEGFIL<>""
  GCURLEG = GLEGFIL
  Gosub CHARGE
Else
 Raz [M]LEG
Endif
Return

$CHARGE
Raz [M]
nolign = 0
PLEIN = 0
For [RUB]RUB1 Where [RUB]LEG=GCURLEG
 Gosub TEST

 If OKRUB
  If nolign>=dim([M]COD)
   PLEIN = 1 : Break
  Endif
  nolign += 1
  [M] = [F:RUB]
  [M]ROW(nolign-1) = [F:RUB]ROW
  Gosub LIRE
 Endif
Next
[M]NBLIG = nolign
Affzo
If PLEIN
 Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
Endif
Return

$APRES_MODIF
FLMOD = 1
Return

$SETBOUT
If FLMOD
 ETABOU(GENRE) = 1
 ETABOU(GABAN) = 1
Else
 ETABOU(GENRE) = 0
 ETABOU(GABAN) = 0
Endif
Return

$ABANDON
If dim([M]LEG)<0
  GCURLEG = GDOSLEG
Elsif GLEGFIL<>""
  GCURLEG = GLEGFIL
Endif
Gosub CHARGE
FLMOD = 0
Return

$ENREGISTRE
Call DEBTRANS From GLOCK
Gosub TR1
FLMOD = 0
Return

###########################################################################
$TEST

Case GACTION
 When "MAJRUB1"
  OKRUB = ([F:RUB]ATTSAL<>"" or [F:RUB]ATTASS<>"" or [F:RUB]BNSALC<>"" or [F:RUB]ATTHIL<>"" or [F:RUB]ATTAT<>"" or [F:RUB]STCPRN<>"")
 When "MAJRUB2"
  OKRUB = ([F:RUB]AMTPRN>1)
 When "MAJRUB3"
  OKRUB = find(2,[F:RUB]PRNFLG(0..1))
 When "MAJRUB4"
  OKRUB = ([F:RUB]CUMNUMADI<>"")
 When "MAJRUB5"
  OKRUB = ([F:RUB]CODGRP<>"" or [F:RUB]TYPMAS<>"")
Endcase
Return

$RAZE
Case GACTION
 When "MAJRUB1"
  [F:RUB]ATTSAL = ""
  [F:RUB]ATTASS = ""
  [F:RUB]BNSALC = ""
  [F:RUB]ATTHIL = ""
  [F:RUB]ATTAT  = ""
  [F:RUB]STCPRN = ""
 When "MAJRUB2"
  [F:RUB]AMTPRN = 1
  Raz [F:RUB]LFEBEF,[F:RUB]LFEAFT,[F:RUB]DESPRN,[F:RUB]TEXVRI
 When "MAJRUB3"
  [F:RUB]PRNFLG(0) = 1
  [F:RUB]PRNFLG(1) = 1
 When "MAJRUB4"
  [F:RUB]CUMNUMADI = ""
 When "MAJRUB5"
  [F:RUB]CODGRP  = ""
  [F:RUB]TYPMAS  = ""
  [F:RUB]NOSUMMS = 1
  [F:RUB]EFF1MS  = 1
  [F:RUB]EFF2MS  = 1
Endcase
Return

$LIRE
Case GACTION
 When "MAJRUB2"
  [M]TEXVRI1(nolign-1) = [F:RUB]TEXVRI(0)
  [M]TEXVRI2(nolign-1) = [F:RUB]TEXVRI(1)
  [M]LFEBEF(nolign-1)  = min(max([F:RUB]LFEBEF,1),2)
  [M]LFEAFT(nolign-1)  = min(max([F:RUB]LFEAFT,1),2)
 When "MAJRUB3"
  [M]PRNFLG1(nolign-1)  = min(max([F:RUB]PRNFLG(0),1),2)
  [M]PRNFLG2(nolign-1)  = min(max([F:RUB]PRNFLG(1),1),2)
Endcase
Return

$ECRIRE
Case GACTION
 When "MAJRUB2"
  [F:RUB]TEXVRI(0) = [M]TEXVRI1(nolign-1)
  [F:RUB]TEXVRI(1) = [M]TEXVRI2(nolign-1)
 When "MAJRUB3"
  [F:RUB]PRNFLG(0) = [M]PRNFLG1(nolign-1)
  [F:RUB]PRNFLG(1) = [M]PRNFLG2(nolign-1)
Endcase
Return

###########################################################################

$TR1
GOK = 1
Trbegin [RUB]
 For nolign=1 To [M]NBLIG
  Readlock [RUB]RUB0 = GCURLEG;[M]COD(nolign-1)
  If fstat=1
   GOK = -1 : GLOCK = "$RUBRIQUE"-[M]COD(nolign-1) : Break
  Elsif fstat
   GOK = 0 : Call RSTA("RUB",[M]COD(nolign-1)) From GLOCK : Break
  Endif
  [F:RUB] = [M]
  Gosub ECRIRE
  Rewrite [RUB]
  If fstat
   GOK = 0 : Call FSTA("RUB") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 For [RUB]RUB0 Where LEG=GCURLEG
  Gosub TEST
  If OKRUB
   If !find([F:RUB]COD,[M]COD(0..[M]NBLIG-1))
    Readlock [RUB]RUB0 Curr
    If fstat=1
     GOK = -1 : GLOCK = "$RUBRIQUE"-[F:RUB]COD : Break
    Elsif fstat
     GOK = 0 : Call RSTA("RUB",[F:RUB]COD) From GLOCK : Break
    Endif
    Gosub RAZE
    Rewrite [RUB]
    If fstat
     GOK = 0 : Call FSTA("RUB") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Call SETPAR From GENPLAN  : # 71092
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#54868
$CONTROLE
If GACTION <>"MAJRUB1" : Return : Endif
If clalev ([F:RUB3])=0 : Local File RUBRIQUE [RUB3] : Endif
If clalev ([F:ADI2])=0 : Local File ATABDIV  [ADI2] : Endif
Local Integer NBZONE
NBZONE=30
#Maladie
##For [F:ADI2]CODE Where NUMTAB=10373
Filter [F:ADI2] Where NUMTAB=10373 and LEG=GCURLEG
For [F:ADI2]
 Filter [F:RUB3] Where ATTHIL=[F:ADI2]CODE and LEG=GCURLEG
 If NBZONE<rowcount([F:RUB3])
  # Trop de rubriques paramétrées sur la zone d'attestation maladie
  GMESSAGE =mess(43,10708,1)-":"-[F:ADI2]CODE
  GERR = 1 : Break
 Endif
Next
Filter [F:ADI2]
If GERR : Return : Endif
# At
##For [F:ADI2]CODE Where NUMTAB=10390
Filter [F:ADI2] Where NUMTAB=10390 and LEG=GCURLEG
For [F:ADI2]
 Filter [F:RUB3] Where ATTAT=[F:ADI2]CODE and LEG=GCURLEG
 If NBZONE<rowcount([F:RUB3])
  # Trop de rubriques paramétrées sur la zone d'attestation AT
  ##GMESSAGE =mess(44,10708,1)-":"-[M:RUB5]ATTAT
  GMESSAGE =mess(44,10708,1)-":"-[F:ADI2]CODE
  GERR=1 : Break
 Endif
Next
Filter [F:ADI2]
If GERR : Return : Endif
Return

########################################
## Ecran MAJRUBi
########################################
Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]COD(0..[M]NBLIG-1)) From OBJDIV
If mkstat : End : Endif
Call LECTURE("RUB",VALEUR,GCURLEG) From CONTOBJ
[M]ROW(nolign-1) = [F:RUB]ROW
Affzo ROW(nolign-1)
End

########################################
## Ecran MAJRUB5
########################################
Subprog B2_CODGRP(VALEUR)
Variable Char    VALEUR()
Local Integer I , NOL
NOL = nolign-1
For I=NOL+1 To [M]NBLIG-1
 [M:MAJ]CODGRP(I) = VALEUR
 Affzo [M:MAJ]CODGRP(I)
Next
End

Subprog B2_TYPMAS(VALEUR)
Variable Char    VALEUR()
Local Integer I , NOL
NOL = nolign-1
For I=NOL+1 To [M]NBLIG-1
 [M:MAJ]TYPMAS(I) = VALEUR
 Affzo [M:MAJ]TYPMAS(I)
Next
End



Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
Gosub CHARGE
If NBLIG=0
  [M]LEG=GCURLEG
  Affzo [M]LEG
Endif
End

