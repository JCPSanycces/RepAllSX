######################################################################################
## Section automatically added (screen MAJRUB4) 2014/03/20 12:39:13 (JASMI)
######################################################################################

Subprog AS_CUMNUMADI(VALEUR)
Variable Integer VALEUR
# JASMI - 2014/03/20 - Requirement 95019 US 2547
# Adding items to Local Menu 349 and show only items for RSA
  Call DISPLAY_ML10349() From DIVPAYE
# JASMI - 2014/03/20 - Requirement 95019 US 2547

End
