#<AdxTL>@(#)1.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Effacement de BPA.BPABID lorsque le compte n'existe pas dans BID
# FGR 04/04/2012 : X3SUIVI81100
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Correction of the bank on BPAADDRESS table") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub BPABPABID
End

#-------------------#
$BPABPABID
#CHECK IGNORE_BEGIN
Local Char REQSQL(250)(9)

  # ------------------------------
  Local File =DOSSIER+".BPADDRESS" [BPA]
  Local File =DOSSIER+".BID" [BID]
  # ------------------------------
  Trbegin [BPA]
  Onerrgo ERR_SQL
  REQSQL(0) = "UPDATE " + DOSSIER + ".BPADDRESS "
  REQSQL(1) = "SET BPADDRESS.BPABID_0 = ' ' "
  REQSQL(2) = "WHERE BPADDRESS.BPABID_0 <> ' ' "
  REQSQL(3) = "  and not exists (select 'x' "
  REQSQL(4) = "                  from " + DOSSIER + ".BID BID "
  REQSQL(5) = "                  where BID.BPATYP_0 = BPADDRESS.BPATYP_0 and BID.BPANUM_0 = BPADDRESS.BPANUM_0 and BID.BIDNUM_0 = BPADDRESS.BPABID_0 and BID.BPAADD_0 = ' ') "
  REQSQL(6) = "  and not exists (select 'x' "
  REQSQL(7) = "                  from " + DOSSIER + ".BID BID "
  REQSQL(8) = "                  where BID.BPATYP_0 = BPADDRESS.BPATYP_0 and BID.BPANUM_0 = BPADDRESS.BPANUM_0 and BID.BIDNUM_0 = BPADDRESS.BPABID_0 and BID.BPAADD_0 = BPADDRESS.BPAADD_0) "
  Execsql From num$(GTYPDBA*2+1) Sql REQSQL
  Onerrgo
  If GOK < 1 Then
    Rollback
  Else
    Commit
    Call ECR_TRACE("BID on addresses updated" - "at" - time$,0) From GESECRAN
  Endif
  #CHECK IGNORE_END
Return

$ERR_SQL
  GMESSAGE = errp - "(" + num$(errl) + ")" + "\" + mess(6,123,1) - num$(errn) - ":" - errmes$(errn) + "\" + errm
  Call ECR_TRACE(GMESSAGE, 1) From GESECRAN
  GOK = 0
Resume

# Issue SAM121863 - 2017-04-06 by FGR : Missing subroutine
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If fstat  Raz [F:ADS] : Endif
#
Gosub BPABPABID
End

