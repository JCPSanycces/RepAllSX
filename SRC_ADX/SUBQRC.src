#<AdxTL>@(#)0.0.0.0 $Revision$
  ######################################################################################################
# Project       : Swiss QR-Code
# File          : SUBQRC
# Version       : 1.0
# Author        : Anton Gregolec
# Creation Date : 22.05.18
######################################################################################################
# Module        : Purchasing / AP/AR Accounting
# Description   : - QR-Code handling in purchase invoices (GESBIS / GESPIH)
######################################################################################################
# Updates :
# Date       |Author   |Version|Description
# 2018-05-25 |Bader    |2018.R5|Add DEBUT, check for changes in WRITETOREC
# 2018-06-05 |Bader    |2018.R5|DEBUT: distinguish between GESBIS and GESPIH
# 2018-06-12 |Bader    |2018.R5|X3-95015 add AM_QRCLINES
# 2018-06-13 |Bader    |2018.R5|rename SWIQRCLIB to SWIQRCLIB2 > SWIQRCLIB now interface to bank file definition for ISO3 bank file
# 2018-06-26 |Bader    |2018.R6|DEBUT: disable fields when invoice is posted even if no QR code data
######################################################################################################

$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "OK" : Gosub OK
    When Default
  Endcase
Return

#*****************************************************************************************************
# OUVRE: Open files
#*****************************************************************************************************
$OUVRE
If !clalev([F:XTPT])  : Local File TABPAYTERM [XTPT]  : Endif
If !clalev([F:XTRA])  : Local File TABRATVAT  [XTRA]  : Endif
If !clalev([F:XBPS])  : Local File BPSUPPLIER [XBPS]  : Endif
If !clalev([F:XCAC])  : Local File GACCCODE   [XCAC]  : Endif
If !clalev([F:XGAC])  : Local File GACCOUNT   [XGAC]  : Endif
Return
#*****************************************************************************************************

#*****************************************************************************************************
# OUVRE_BOITE: Load referential and analytic axis
#*****************************************************************************************************
$OUVRE_BOITE
If GFONCTION = "GESBIS" and (GREP="C") and ([M:BIS3]NBLIG = 0)  # GESBIS
  Local Char    XPARAM(10)
  Local Char    CODLED(GLONLED), MESSA(250)
  Local Integer STAT : STAT = 0
  Call LECTURE("FCY",[M:BIS0]FCY,"") From CONTOBJ
  [M:BIS0]CPY = [F:FCY]LEGCPY
  Call LECTURE("CPY",[M:BIS0]CPY,"") From CONTOBJ
  Call GETSOC([M:BIS0]FCY) From DEVSUB
  [M:BIS0]CPYNAM = [F:CPY]CPYSHO
  Affzo [M:BIS0]CPY
  Affzo [M:BIS0]CPYNAM
  ## Global initialisations plans, ...
  Call INI_GLOBAL(2,[M:BIS0]CPY,STAT,MESSA) From SUBBICS
  If STAT
   GMESSAGE = MESSA
   mkstat = 2 : End
  Endif
  ## Display of columns ...
  If !GIMPORT Then
    Call AFFCOL(2) From SUBBICS
    Gosub SETCHPLST From SUBBICS
  Endif
  #--- Parameter to suppress invoices
  Call PARAM([M:BIS0]FCY,"PIVSUP",XPARAM) From ADOVAL
  GPIVSUP=val(XPARAM)
  #--- Parameter for creation of null lines
  Call PARAM([M:BIS0]FCY,"SIVNULL",XPARAM) From ADOVAL
  GSIVNULL=val(XPARAM)
  #--- tax code
  Call PARAM([M:BIS0]FCY,"EXETAX",XPARAM) From ADOVAL
  GEXETAX  = XPARAM
  #--- VAT rounding
  Call PARAM([M:BIS0]FCY,"VATRND",XPARAM) From ADOVAL
  GVATRND  = val(XPARAM)
Endif
Return
#*****************************************************************************************************


#*****************************************************************************************************
# DEBUT: when showing the window
#*****************************************************************************************************
$DEBUT
Local Clbfile QRFILE
Raz QRFILE, [M:SWIQRC]QRCLINES
Raz [F:SWIQTMP]
If [F:SWIQRC]QRCODTYP = "SPC"
  QRFILE += [F:SWIQRC]QRCODTYP+chr$(10)
  QRFILE += [F:SWIQRC]VER+chr$(10)
  QRFILE += [F:SWIQRC]CHRCODTYP+chr$(10)
  QRFILE += [F:SWIQRC]IBACOD+chr$(10)
  QRFILE += [F:SWIQRC]CDTRNAM+chr$(10)
  QRFILE += [F:SWIQRC]CDTRSTRNAM+chr$(10)
  QRFILE += [F:SWIQRC]CDTRBLDGNBR+chr$(10)
  QRFILE += [F:SWIQRC]CDTRPSTCOD+chr$(10)
  QRFILE += [F:SWIQRC]CDTRCTY+chr$(10)
  QRFILE += [F:SWIQRC]CDTRCRY+chr$(10)
  QRFILE += [F:SWIQRC]UCDTRNAM+chr$(10)
  QRFILE += [F:SWIQRC]UCDTRSTRNAM+chr$(10)
  QRFILE += [F:SWIQRC]UCDTRBLDGNBR+chr$(10)
  QRFILE += [F:SWIQRC]UCDTRPSTCOD+chr$(10)
  QRFILE += [F:SWIQRC]UCDTRCTY+chr$(10)
  QRFILE += [F:SWIQRC]UCDTRCRY+chr$(10)
  QRFILE += [F:SWIQRC]AMT+chr$(10)
  QRFILE += [F:SWIQRC]CUR+chr$(10)
  QRFILE += [F:SWIQRC]DUEDAT+chr$(10)
  QRFILE += [F:SWIQRC]UDBTRNAM+chr$(10)
  QRFILE += [F:SWIQRC]UDBTRSTRNAM+chr$(10)
  QRFILE += [F:SWIQRC]UDBTRBLDGNBR+chr$(10)
  QRFILE += [F:SWIQRC]UDBTRPSTCOD+chr$(10)
  QRFILE += [F:SWIQRC]UDBTRCTY+chr$(10)
  QRFILE += [F:SWIQRC]UDBTRCRY+chr$(10)
  QRFILE += [F:SWIQRC]PAYREFTYP+chr$(10)
  QRFILE += [F:SWIQRC]REF+chr$(10)
  QRFILE += [F:SWIQRC]USTREF+chr$(10)
  QRFILE += [F:SWIQRC]ALTPAR1+chr$(10)
  QRFILE += [F:SWIQRC]ALTPAR2
  [M:SWIQRC]QRCLINES = QRFILE
  If GFONCTION = "GESPIH"
    [M:SWIQRC]TOTAMT   = [M:PIH1]TOTATIAMT1
    [M:SWIQRC]TOTVAT   = [M:PIH1]TOTTAXAMT1
  Endif
Endif
If GFONCTION = "GESBIS"
  If [M:BIS1]STA = 3
    Diszo [M:SWIQRC]QRCLINES
  Else
    Actzo [M:SWIQRC]QRCLINES
  Endif
Else
  If [M:PIH1]STA = 3
     Diszo [M:SWIQRC]QRCLINES
     Diszo [M:SWIQRC]TOTVAT
  Else
     Actzo [M:SWIQRC]QRCLINES
     Actzo [M:SWIQRC]TOTVAT
  Endif
Endif
Affzo [M:SWIQRC]
Return
#*****************************************************************************************************


#*****************************************************************************************************
# OK: OK button is pressed
#*****************************************************************************************************
$OK
Local Char QRLIN(140)(30)
Call READFILE([M:SWIQRC]QRCLINES,QRLIN)
Gosub VERIF_QRC From SWIQRCLIB2

If [F:SWIQTMP]VER = "NOK"
  FIN = 0
Else
  Gosub WRITETOREC
  Gosub INIT_SCREEN
Endif
Return
#*****************************************************************************************************


#*****************************************************************************************************
#read qr file in array
Subprog READFILE(QRFILE, QRLIN)
Value Clbfile QRFILE
Variable Char QRLIN()()
Local Integer I, C
  Raz QRLIN
  Repeat
    If QRFILE <> ""
      I = instr(1, QRFILE, chr$(10))
      If I>0
        QRLIN(C) = left$(QRFILE, I-1)
        QRFILE = right$(QRFILE,I+1)
      Elsif I = 0
        QRLIN(C) = QRFILE
        QRFILE = ""
      Endif
    Endif
    C += 1
  Until QRFILE = ""
End
#*****************************************************************************************************


#*****************************************************************************************************
#write qr data to file record if something changed. Set [F:SWIQTMP]QRCODTYP = "CHG" if something changed
$WRITETOREC
  If [F:SWIQRC]QRCODTYP     <> QRLIN(0)  : [F:SWIQRC]QRCODTYP = QRLIN(0)      : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]VER          <> QRLIN(1)  : [F:SWIQRC]VER = QRLIN(1)           : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]CHRCODTYP    <> QRLIN(2)  : [F:SWIQRC]CHRCODTYP = QRLIN(2)     : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]IBACOD       <> QRLIN(3)  : [F:SWIQRC]IBACOD  = QRLIN(3)       : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]CDTRNAM      <> QRLIN(4)  : [F:SWIQRC]CDTRNAM = QRLIN(4)       : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]CDTRSTRNAM   <> QRLIN(5)  : [F:SWIQRC]CDTRSTRNAM = QRLIN(5)    : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]CDTRBLDGNBR  <> QRLIN(6)  : [F:SWIQRC]CDTRBLDGNBR = QRLIN(6)   : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]CDTRPSTCOD   <> QRLIN(7)  : [F:SWIQRC]CDTRPSTCOD = QRLIN(7)    : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]CDTRCTY      <> QRLIN(8)  : [F:SWIQRC]CDTRCTY = QRLIN(8)       : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]CDTRCRY      <> QRLIN(9)  : [F:SWIQRC]CDTRCRY = QRLIN(9)       : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]UCDTRNAM     <> QRLIN(10) : [F:SWIQRC]UCDTRNAM = QRLIN(10)     : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]UCDTRSTRNAM  <> QRLIN(11) : [F:SWIQRC]UCDTRSTRNAM = QRLIN(11)  : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]UCDTRBLDGNBR <> QRLIN(12) : [F:SWIQRC]UCDTRBLDGNBR = QRLIN(12) : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]UCDTRPSTCOD  <> QRLIN(13) : [F:SWIQRC]UCDTRPSTCOD = QRLIN(13)  : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]UCDTRCTY     <> QRLIN(14) : [F:SWIQRC]UCDTRCTY = QRLIN(14)     : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]UCDTRCRY     <> QRLIN(15) : [F:SWIQRC]UCDTRCRY = QRLIN(15)     : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]AMT          <> QRLIN(16) : [F:SWIQRC]AMT = QRLIN(16)          : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]CUR          <> QRLIN(17) : [F:SWIQRC]CUR = QRLIN(17)          : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]DUEDAT       <> QRLIN(18) : [F:SWIQRC]DUEDAT = QRLIN(18)       : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]UDBTRNAM     <> QRLIN(19) : [F:SWIQRC]UDBTRNAM = QRLIN(19)     : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]UDBTRSTRNAM  <> QRLIN(20) : [F:SWIQRC]UDBTRSTRNAM = QRLIN(20)  : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]UDBTRBLDGNBR <> QRLIN(21) : [F:SWIQRC]UDBTRBLDGNBR = QRLIN(21) : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]UDBTRPSTCOD  <> QRLIN(22) : [F:SWIQRC]UDBTRPSTCOD = QRLIN(22)  : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]UDBTRCTY     <> QRLIN(23) : [F:SWIQRC]UDBTRCTY = QRLIN(23)     : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]UDBTRCRY     <> QRLIN(24) : [F:SWIQRC]UDBTRCRY = QRLIN(24)     : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]PAYREFTYP    <> QRLIN(25) : [F:SWIQRC]PAYREFTYP = QRLIN(25)    : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]REF          <> QRLIN(26) : [F:SWIQRC]REF = QRLIN(26)          : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]USTREF       <> QRLIN(27) : [F:SWIQRC]USTREF = QRLIN(27)       : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]ALTPAR1      <> QRLIN(28) : [F:SWIQRC]ALTPAR1 = QRLIN(28)      : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
  If [F:SWIQRC]ALTPAR2      <> QRLIN(29) : [F:SWIQRC]ALTPAR2 = QRLIN(29)      : [F:SWIQTMP]QRCODTYP = "CHG" : Endif
Return
#*****************************************************************************************************


#*****************************************************************************************************
$INIT_SCREEN
If GFONCTION = "GESBIS"
  If [M:BIS1]STA<>3
      If (GREP="C" | GREP="D" | GREP="")
        If [M:BIS0]PIVTYP = ""            # init invoice type if empty
          Call PARAM([M:BIS0]FCY,"TYPINVSUP",[M:BIS0]PIVTYP) From ADOVAL
        Endif
        Gosub SET_PIVTYP From SUBBIS
      Endif
      If !GIMPORT & GREP="" & [M:BIS0]INVTYP<>[F:TPV]INVTYP
        # different invoice types
        GMESSAGE = mess(60,119,1)
        mkstat=2 : End
      Endif
      Call OK_QRC() From SWIQRCLIB1
      [M:BIS1]PURPRITYP=2
      Affzo [M:BIS1]PURPRITYP
      mkstat=4
  Endif
Else
  If [M:PIH1]STA<>3
      Call OK_QRC() From SWIQRCLIB1
      mkstat=4
  Endif
Endif
Return
#*****************************************************************************************************


######################################################################################
Subprog AM_QRCLINES(VALEUR)
Variable Clbfile VALEUR
Local Char QRLIN(140)(30)
Call READFILE(VALEUR,QRLIN)
If QRLIN(16) <> ""                    # Amount given?
    [M:SWIQRC]TOTAMT = val(QRLIN(16))
    Affzo [M:SWIQRC]TOTAMT
    Actzo [M:SWIQRC]TOTVAT
Else
    Diszo [M:SWIQRC]TOTVAT
Endif
End


######################################################################################
Subprog C_TOTVAT(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 and [M:SWIQRC]TOTAMT <> 0
    If VALEUR > [M:SWIQRC]TOTAMT          # tax value shouldn't exceed total value
        mkstat   = 2
        GMESSAGE = mess(98,3648,1)
    Endif
Endif
End


######################################################################################

