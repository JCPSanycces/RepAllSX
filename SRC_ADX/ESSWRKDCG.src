#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION

Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase

Return


$OUVRE
If clalev([F:AWS])    = 0 : Local File AWRKHISSUI     [AWS]     : Endif
If clalev([F:ID])     = 0 : Local File EMPLOID        [ID]      : Endif
If clalev([F:DCG])    = 0 : Local File DEMCONGE       [DCG]     : Endif

Return

$DEBUT

#Update header icon
#[M]WSTA2 = func ESS_FUNCTIONS.SET_ICON(2)
#[M]WSTADES2 = 2
#[M]WSTA5 = func ESS_FUNCTIONS.SET_ICON(5)
#[M]WSTADES5 = 5

nolign =0
Filter [F:AWS] Where DEST = GUSER and FLGSIG =3 and (CODEVT="DCG" | CODEVT = "DCGMOD" | CODEVT = "ESSDCGMOD" | CODEVT = "ESSDCG" )
For [F:AWS]AWS0
  nolign +=1
  If nolign > dim([M:ESWDG]REFNUM) : Break : Endif
  [M:ESWDG] = [F:AWS]
  Read [F:DCG]DCG3 = [F:AWS]VALCTX1;val([F:AWS]VALCTX4)
  If !fstat
    [M:ESWDG] = [F:DCG]
    #[M:ESWDG]WSTA(nolign-1) = func ESS_FUNCTIONS.SET_ICON([F:DCG]STA)
  Endif

  Read [F:ID]ID0 = [F:AWS]VALCTX1
  If !fstat
    [M:ESWDG]NAM(nolign-1) = [F:ID]NAM
    [M:ESWDG]SRN(nolign-1) = [F:ID]SRN
  Endif

  [M:ESWDG]NBRLIN = nolign
Next

Affzo [M:ESWDG]1-99
Return


$REFRESH_ESSWRKDCG
Local Integer TOTLINE, I
##This routine is used to refresh the screen after an approval has been made to remove the record(s) from the screen

[L]TOTLINE = [M:ESWDG]NBRLIN
[L]I = [L]TOTLINE
For nolign = 1 To TOTLINE
  If [M:ESWDG]WWRK(nolign-1) = "S" #signed
    Dela nolign-1 [M:ESWDG]NBRLIN
    [L]I-=1
  Endif
Next
[M:ESWDG]NBRLIN = [L]I
Affzo [M:ESWDG]1-99
Return

