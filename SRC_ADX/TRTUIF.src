Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTUIF","GENUIF",4,"") From GTRAITE
End

#########################################
## Traitement des actions : TRTUIF
#########################################
$ACTION
Case ACTION
 When "INIT"       : Gosub OUVRE
 When "EXEC"       : Gosub EXEC
 When "CONTROLE"   : Gosub CONTROLE
 When "DEBUT"      : Affzo [UFE]: Setmok [UFE] With 0
 When "OK"         : FIN = 1 : GOK = 1
 When "END"        : FIN = 1
Endcase
Return

#########################################
$OUVRE
Gosub OUVFIC

Local Mask GENUIF [UFE]
Raz [UFE]
Gosub DECLARATION
#ADNGO - 2017-06-05 - X3-11427 - START
  GCURLEG = 'ZAF'
  [M:UFE]LEG = GCURLEG
#ADNGO - 2017-06-05 - X3-11427 - END
Return

#########################################
$OUVFIC
If clalev([F:ID])=0     : Local File EMPLOID      [ID]    : Endif
If clalev([F:ESA])=0    : Local File EMPLOIDSA    [ESA]   : Endif
#ADNGO - 2017-06-05 - X3-11427 - START
#If clalev([F:CTR])=0    : Local File EMPLOCTR     [CTR]   : Endif
If clalev([F:HRCTR])=0    : Local File EMPLOCTR     [HRCTR]   : Endif
#ADNGO - 2017-06-05 - X3-11427 - END
If clalev([F:CTRSA])=0  : Local File EMPLOCTRSA   [CTRSA] : Endif
If clalev([F:FCY])=0    : Local File FACILITY     [FCY]   : Endif
#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - START
#If clalev([F:FCYSA])=0  : Local File HRFACILITYSA [FCYSA] : Endif
#If clalev([F:CPY])=0    : Local File COMPANY      [CPY]   : Endif
If clalev([F:FGR])=0    : Local File FACGROUP     [FGR]   : Endif
If clalev([F:CPYKSA])=0 : Local File HRCOMPANYKSA [CPYKSA]  : Endif
#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - END
If clalev([F:HSP])=0    : Local File HISTOPAYE    [HSP]   : Endif
If clalev([F:VEP])=0    : Local File VALEMP       [VEP]   : Endif
### IGNORE BANK DETAILS FOR NOW ###
#If clalev([F:RIB])=0    : Local File EMPLORIB     [RIB]   : Endif
If clalev([F:CNT])=0    : Local File CONTACT      [CNT]   : Endif
If clalev([F:CNTSA])=0  : Local File CONTACTSA    [CNTSA] : Endif
If clalev([F:AIN])=0    : Local File CONTACTCRM   [AIN]   : Endif
If clalev([F:TCA])=0    : Local File TABCOUAFF    [TCA]   : Endif
#JASMI - 2017-11-09 - X3-63536 - START
If clalev([F:HRXGD])=0 : Local File HRXITGRD [HRXGD] : Endif
#JASMI - 2017-11-09 - X3-63536 - END
If clalev([F:ADI])=0    : Local File ATABDIV     [ADI]   : Endif


If clalev([F:CTR9])=0    : Local File EMPLOCTR     [CTR9]   : Endif
If clalev([F:CTRSA3])=0  : Local File EMPLOCTRSA   [CTRSA3] : Endif


Return

#########################################
$DECLARATION
Local Char     FICHIER (GDIMFIC), FICCLI(GDIMFIC) , URL(GDIMFIC)
Local Integer  STAT,CTRIND,UIFCHECK
Local Decimal  GRSTAXREM, REMSBJUIF, UIFCTR, COMINC, PENINC
#JASMI - 2015-06-09 - Requirement 108198 US 3581 - START
#Local Char     UIFREFNUM (10), PAYREFNUM (10)
#JASMI - 2017-04-10 - Req. 122480 - START
#Local Char     UIFREFNUM (9), PAYREFNUM (10)
#JASMI - 2017-11-15 - X3-63536 - START
#Local Char     UIFREFNUM (8), PAYREFNUM (10)
Local Char     UIFREFNUM (9), PAYREFNUM (10)
#JASMI - 2017-11-15 - X3-63536 - END
#JASMI - 2017-04-10 - Req. 122480 - END
#JASMI - 2015-06-09 - Requirement 108198 US 3581 - END
Local Decimal  TOTGRSTAXREM, TOTREMSBJUIF, TOTUIFCTR
Local Decimal  RPTGRSTAXREM, RPTREMSBJUIF, RPTUIFCTR
Local Integer  EMPCNT
Local Char     BNKBRHCOD (8), BNKACCNUM (16), BNKACCTYP (2)
Local Char     EMPEMLADR (50)
#JASMI - 2017-04-10 - Req. 122480 - START
#Local Char     UIFNUM (9)
#JASMI - 2017-11-15 - X3-63536 - START
#Local Char     UIFNUM (8)
Local Char     UIFNUM (9)
#JASMI - 2017-11-15 - X3-63536 - END
#JASMI - 2017-04-10 - Req. 122480 - END
Local Char     LIVTST (4)
Local Char     SELSITE (5)
Local Char     PAYMTH (6)
Local Char     IDENUM (13)
Local Char     OTHNUM (16)
Local Char     ALTNUM (25)
Local Char     SURNAM (120)
Local Char     FSTNAM (90)
Local Char     DATBTH (8)
Local Char     DATEMPFRM (8)
Local Char     DATEMPFIN (8)
Local Char     EMPSTA (2)
Local Char     SNNONCTR (2)
Local Clbfile  STRREC
#JASMI - 2015-11-24 - Req. 112578 - START
Local Char     CONTRACT_NO (20), PAYSLIP_NO (20)
Local Integer UIF_STATUS
#JASMI - 2015-11-24 - Req. 112578 - END
Return

#########################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#########################################
$EXEC
TIT=mess(20, 11662, 1)
Call OUVRE_TRACE(TIT) From LECFIC
#TRACE HEADING
Call ECR_TRACE(TIT,0) From GESECRAN

Call GET_FILENAME_AUTO_EXTENSION

If [M:UFE]TYPRUN = 2 Then
  LIVTST = "LIVE"
Else
  LIVTST = "TEST"
Endif
PAYMTH = format$("D:YYYYMM", [M:UFE]STRDAT)
#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - START
#If [M:UFE]ALLFCY = 2 Then
#  SELSITE = "ALL"
#Else
#  SELSITE = [M:UFE]FCY
#Endif
#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - END

#TRACE PARAMETERS
Call ECR_TRACE(string$(100, "-"), 0) From GESECRAN
#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - START
#Call ECR_TRACE(mess(2, 45, 1)     + ": " + [M:UFE]CPY + "  - " +
#&              mess(3, 45, 1)     + ": " + SELSITE    + "  - " +
#&              mess(23, 11662, 1) + ": " + PAYMTH     + "  - " +
#&              mess(243, 123, 1)  + ": " + LIVTST     + "  - " +
#&              mess(4, 95, 1)     + ": " + [M:UFE]FILNAM+"."+[M:UFE]EXT, 0) From GESECRAN
Call ECR_TRACE(mess(237,133,1)    + ": " + [M:UFE]CPY + "  - " +
&              mess(23, 11662, 1) + ": " + PAYMTH     + "  - " +
&              mess(243, 123, 1)  + ": " + LIVTST     + "  - " +
&              mess(4, 95, 1)     + ": " + [M:UFE]FILNAM+"."+[M:UFE]EXT, 0) From GESECRAN
#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - END
Call ECR_TRACE(string$(100, "-"), 0) From GESECRAN
Call ECR_TRACE("", 0) From GESECRAN

OK=1
Gosub OUVRE_FICHIER
If OK
  Gosub TR1
  Gosub FERME_FICHIER
Endif

Call FERME_TRACE From LECFIC

Return

$OUVRE_FICHIER
[L]FICHIER=[M:UFE]FILNAM
If [M:UFE]TYPEXP=2
 [L]FICHIER=filpath([V]GDIRBQE, [M:UFE]FILNAM, [M:UFE]EXT, 0)
Else
 [L]FICCLI=[L]FICHIER
 Call SET_FICNAM([L]FICCLI, [L]FICHIER, [L]URL) From ORDSYS
Endif

Openo FICHIER,0 Using [FIC]

SAVIFS = adxifs : SAVIRS = adxirs
adxifs = "," : adxirs = chr$(13)+chr$(10)

Return

#########################################
$FERME_FICHIER
Openo Using [FIC]
adxifs = SAVIFS : adxirs = SAVIRS

If [M:UFE]TYPEXP<2 Then
 [L]FICCLI+="."+[M:UFE]EXT
 Call COPCLI([L]FICHIER,[L]FICCLI,[L]STAT) From ORDSYS
 If [L]STAT<>0 : [L]TRA = 0 : Endif
Endif

Return

#########################################
$TR1
UIFREFNUM  = ""
PAYREFNUM  = ""
TOTGRSTAXREM = 0
TOTREMSBJUIF = 0
TOTUIFCTR = 0
RPTGRSTAXREM = 0
RPTREMSBJUIF = 0
RPTUIFCTR = 0
EMPCNT = 0
EMPEMLADR = ""

### WRITE CREATION SITE RECORD (HEADER) ###
Gosub ENREG_DEB

### FIND AND WRITE EMPLOYEE RECORDs (DETAIL) ###
Link [HRCTR]  With    [ID]ID0         ~= [F:HRCTR]REFNUM,
&                   [ESA]ESA0       ~= [F:HRCTR]REFNUM,
&                   [CTRSA]CTRSA0   ~= [F:HRCTR]REFNUM; [F:HRCTR]CTRNUM; [F:HRCTR]CTRDAT,
&                   [FCY]FCY0       ~= [F:HRCTR]ETRFCY,
&                   [FGR]FGR0       ~= [M:UFE]CPY; [F:HRCTR]ETRFCY,
&                   [CPYKSA]CPYKSA0 ~= [FCY]LEGCPY
&            As     [LNK]
&            Where  (([F:HRCTR]XITDAT  = [0/0/0] or ([F:HRCTR]XITDAT >= [M:UFE]STRDAT)) or ([F:HRCTR]DATXITFNL >= [M:UFE]STRDAT)) &
&                   [FGR]CPY        = [M:UFE]CPY &
&                   ([F:CTRSA]UIFSTA <> 6 & [F:CTRSA]UIFSTA <> 7)& [F:HRCTR]CTRDAT <= [M:UFE]ENDDAT
&            Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Desc

#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - Removed FCYSA and added CPYKSA above
# JASMI - 2014/06/13 - Requirement 93913 US 2748 - Added code above "([F:CTRSA]UIFSTA <> 6 & [F:CTRSA]UIFSTA <> 7)"
# JASMI - 2014/07/09 - Test results from parallel run - Added code above "; [F:CTR]CTRNUM"


#JASMI - 2015-11-24 - Req. 112578 - START
[L]CONTRACT_NO=""
#JASMI - 2015-11-24 - Req. 112578 - END
For [LNK]

#JASMI - 2015-11-24 - Req. 112578 - START
  If [L]CONTRACT_NO<>[HRCTR]CTRNUM
    [L]CONTRACT_NO=[HRCTR]CTRNUM
#JASMI - 2015-11-24 - Req. 112578 - END
      GRSTAXREM = 0
      REMSBJUIF = 0
      UIFCTR = 0

      COMINC = 0
      PENINC = 0

      BNKBRHCOD  = ""
      BNKACCNUM  = ""
      BNKACCTYP  = ""

    #JASMI - 2015-06-09 - Requirement 108198 US 3581 - START
    #  If [F:CPYKSA]UIFNUM = "" Then
      If [F:CPYKSA]UIFRGTNUM = 0 Then
    #JASMI - 2015-06-09 - Requirement 108198 US 3581 - END
        Call ECR_TRACE(mess(16,11662,1),0) From GESECRAN
        OK=0 : Break
      Endif

    #JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - START
    #  If [M:UFE]ALLFCY = 2 or [M:UFE]FCY = [F:CTR]ETRFCY Then
    #JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - END
        If UIFREFNUM = "" Then
        #JASMI - 2015-06-09 - Requirement 108198 US 3581 - START
        #  UIFREFNUM  = [F:CPYKSA]UIFNUM
#JASMI - 2017-04-10 - Req. 122480 - START
#          UIFREFNUM  = format$("N0:9",[F:CPYKSA]UIFRGTNUM)
#JASMI - 2017-11-15 - X3-63536 - START
#          UIFREFNUM  = format$("N0:8",[F:CPYKSA]UIFRGTNUM)
          UIFREFNUM  = format$("N0:9",[F:CPYKSA]UIFRGTNUM)
#JASMI - 2017-11-15 - X3-63536 - END
#JASMI - 2017-04-10 - Req. 122480 - END
        #JASMI - 2015-06-09 - Requirement 108198 US 3581 - END
          PAYREFNUM  = [F:CPYKSA]PAYREFNUM
        Endif

      #JASMI - 2015-06-09 - Requirement 108198 US 3581 - START
      #  If UIFREFNUM <> [F:CPYKSA]UIFNUM Then
#JASMI - 2017-04-10 - Req. 122480 - START
#        If UIFREFNUM <> format$("N0:9",[F:CPYKSA]UIFRGTNUM) Then
#JASMI - 2017-11-15 - X3-63536 - START
#        If UIFREFNUM <> format$("N0:8",[F:CPYKSA]UIFRGTNUM) Then
        If UIFREFNUM <> format$("N0:9",[F:CPYKSA]UIFRGTNUM) Then
#JASMI - 2017-11-15 - X3-63536 - END
#JASMI - 2017-04-10 - Req. 122480 - END
      #JASMI - 2015-06-09 - Requirement 108198 US 3581 - END
        #JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - START
    #      Filter [CNT] Where BPATYP = 3 & BPANUM = [F:CTR]ETRFCY
     #     Filter [CNT] Where BPATYP = 2 & BPANUM = [F:CPYKSA]CPY
        #JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - END
      #    Read [CNT] First
      #    If [F:CNT]BPATYP = 2 & [F:CNT]BPANUM = [F:CPYKSA]CPY Then
      #      EMPEMLADR = [F:CNT]WEB
 #  Endif
     Filter [CNTSA] Where BPATYP = 2 & BPANUM = [F:FCY]LEGCPY & RSACNTTYP = 4
          Read [CNTSA] First
          If !fstat
            If [F:CNTSA]BPATYP = 2 & [F:CNTSA]BPANUM = [F:FCY]LEGCPY & [F:CNTSA]RSACNTTYP = 4 Then
              Filter [CNT]
              Read [CNT]CNT0 = 2; [F:FCY]LEGCPY; [F:CNTSA]CCNCRM
              If !fstat
                EMPEMLADR = [F:CNT]WEB
              Endif
            Endif
          Endif


          Gosub ENREG_FIN

        #JASMI - 2015-06-09 - Requirement 108198 US 3581 - START
        #  UIFREFNUM  = [F:CPYKSA]UIFNUM
#JASMI - 2017-04-10 - Req. 122480 - START
#          UIFREFNUM  = format$("N0:9",[F:CPYKSA]UIFRGTNUM)
#JASMI - 2017-11-15 - X3-63536 - START
#          UIFREFNUM  = format$("N0:8",[F:CPYKSA]UIFRGTNUM)
          UIFREFNUM  = format$("N0:9",[F:CPYKSA]UIFRGTNUM)
#JASMI - 2017-11-15 - X3-63536 - END
#JASMI - 2017-04-10 - Req. 122480 - END
        #JASMI - 2015-06-09 - Requirement 108198 US 3581 - END
          PAYREFNUM  = [F:CPYKSA]PAYREFNUM

          TOTGRSTAXREM = 0
          TOTREMSBJUIF = 0
          TOTUIFCTR = 0
          EMPCNT = 0
          EMPEMLADR = ""
        Endif

    #JASMI - 2015-11-24 - Req. 112578 - START
    #    Link [HSP]  With    [VEP]VEP5     ~= [F:HSP]BUL
    #&               As      [LNK2]
    #&               Where   [F:HSP]DAT    >= [M:UFE]STRDAT & [F:HSP]DAT <= [M:UFE]ENDDAT &
    #&                       ([F:HSP]RUB   = func AFNC.PARAM("MTDGRSINC","") or [F:HSP]RUB = func AFNC.PARAM("MTDUIFCTR","") or
    #&                        [F:HSP]RUB   = func AFNC.PARAM("MTDCOMMINC","") or [F:HSP]RUB = func AFNC.PARAM("MTDPENSINC","") or
    #&                        [F:HSP]RUB   = func AFNC.PARAM("MTDUIFINC","")) &
    #&                       [F:VEP]CTRNUM = [F:CTR]CTRNUM
        Link [HSP]  With    [VEP]VEP5     ~= [F:HSP]BUL
&                   As      [LNK2]
&                   Where   [VEP]PYRDAT >= [M:UFE]STRDAT & [VEP]PYRDAT <= [M:UFE]ENDDAT &
&                           ([HSP]RUB   = func AFNC.PARAM("MTDGRSINC","ZAF") or [F:HSP]RUB = func AFNC.PARAM("MTDUIFCTR","ZAF") or
&                            [HSP]RUB   = func AFNC.PARAM("MTDCOMMINC","ZAF") or [F:HSP]RUB = func AFNC.PARAM("MTDPENSINC","ZAF") or
&                            [HSP]RUB   = func AFNC.PARAM("MTDUIFINC","ZAF")) and [F:HSP]TYP=6 &
&                           [VEP]EMP = [HRCTR]REFNUM &
&                           [VEP]CTRNUM = [HRCTR]CTRNUM
&                   Order By [VEP]CTRDAT Desc; [VEP]BUL Desc
    #JASMI - 2015-11-24 - Req. 112578 - END

    # JASMI - 2014/07/10 - Test results from parallel run - Added code above "[F:HSP]RUB   = func AFNC.PARAM("TOTUIFINC","")"
    # JASMI - 2014/07/15 - Test results from parallel run - Changed code above "TOTTAXINC" to "GRSREM"

      #JASMI - 2015-11-24 - Req. 112578 - START
        [L]PAYSLIP_NO=""
      #JASMI - 2015-11-24 - Req. 112578 - END
        For [LNK2]
        #JASMI - 2015-11-24 - Req. 112578 - START
          If [L]PAYSLIP_NO=""
            [L]PAYSLIP_NO=[VEP]BUL
          Else
            If [L]PAYSLIP_NO<>[VEP]BUL
              Break
            Endif
          Endif
        #JASMI - 2015-11-24 - Req. 112578 - END
        # JASMI - 2014/07/15 - Test results from parallel run - START
    #      If [F:HSP]RUB = func AFNC.PARAM("TOTTAXINC","") Then
    #        GRSTAXREM = GRSTAXREM + [F:HSP]BAS
          If [F:HSP]RUB = func AFNC.PARAM("MTDGRSINC","ZAF") Then
            GRSTAXREM = GRSTAXREM + [F:HSP]AMT
        # JASMI - 2014/07/15 - Test results from parallel run - END
          Endif
          If [F:HSP]RUB = func AFNC.PARAM("MTDUIFCTR","ZAF") Then
          # JASMI - 2014/07/10 - Test results from parallel run - START
    #        REMSBJUIF = REMSBJUIF + [F:HSP]BAS
          # JASMI - 2014/07/10 - Test results from parallel run - END
            UIFCTR = UIFCTR + [F:HSP]AMT
          Endif
          If [F:HSP]RUB = func AFNC.PARAM("MTDCOMMINC","ZAF") Then
            COMINC = COMINC + [F:HSP]AMT
          Endif
          If [F:HSP]RUB = func AFNC.PARAM("MTDPENSINC","ZAF") Then
            PENINC = PENINC + [F:HSP]AMT
          Endif
        # JASMI - 2014/07/10 - Test results from parallel run - START
          If [F:HSP]RUB = func AFNC.PARAM("MTDUIFINC","ZAF") Then
            REMSBJUIF = REMSBJUIF + [F:HSP]AMT
          Endif
        # JASMI - 2014/07/10 - Test results from parallel run - END
        Next

    ### IGNORE BANK DETAILS FOR NOW ###
    #    Filter [RIB] Where REFNUM = [F:CTR]REFNUM
    #    Read [RIB] First
    #    If [F:RIB]REFNUM = [F:CTR]REFNUM Then
    #      BNKBRHCOD  = [F:RIB]TYPPAY
    #      BNKACCNUM  = [F:RIB]BIDNUM
    #      BNKACCTYP  = [F:RIB]TYPPAY
    #    Endif

        Gosub ENREG_EN

        Call VALIDATE_RSA_IDNUM([F:ESA]RSAID)

    #JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - START
    #  Endif
    #JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - END
  #JASMI - 2015-11-24 - Req. 112578 - START
    Endif
  #JASMI - 2015-11-24 - Req. 112578 - END
Next

#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - START
#Filter [CNT] Where BPATYP = 3 & BPANUM = [F:CTR]ETRFCY
Filter [CNT] Where BPATYP = 2 & BPANUM = [F:CPYKSA]CPY
#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - END
#Read [CNT] First
#If [F:CNT]BPATYP = 2 & [F:CNT]BPANUM = [F:CPYKSA]CPY Then
#  EMPEMLADR = [F:CNT]WEB
#Endif
          Filter [CNTSA] Where BPATYP = 2 & BPANUM = [F:FCY]LEGCPY & RSACNTTYP = 4
          Read [CNTSA] First
          If !fstat
            If [F:CNTSA]BPATYP = 2 & [F:CNTSA]BPANUM = [F:FCY]LEGCPY & [F:CNTSA]RSACNTTYP = 4 Then
              Filter [CNT]
              Read [CNT]CNT0 = 2; [F:FCY]LEGCPY; [F:CNTSA]CCNCRM
              If !fstat
                EMPEMLADR = [F:CNT]WEB
              Endif
            Endif
          Endif

Gosub ENREG_FIN

#TRACE Totals Line
Call ECR_TRACE(format$("K:81X", "*") +
&              format$("K:12X", "------------") + " " +
&              format$("K:12X", "------------") + " " +
&              format$("K:7X", "-------"), 0) From GESECRAN

#TRACE Totals
#JASMI - 2015-11-18 - Req. 112578 - START
#Call ECR_TRACE(format$("K:76X", mess(120, 2281, 1)) + " " +
#&              format$("N:13.2", [L]RPTGRSTAXREM), 0)  From GESECRAN
#
#Call ECR_TRACE(format$("K:90X", "*") +
#&              format$("N:13.2", [L]RPTREMSBJUIF), 0)  From GESECRAN
#
#Call ECR_TRACE(format$("K:98X", "*") +
#&              format$("N:13.2", [L]RPTUIFCTR), 0)  From GESECRAN
Call ECR_TRACE(format$("K:76X", mess(120, 2281, 1)) + " " +
&              format$("-N:13.2", [L]RPTGRSTAXREM), 0)  From GESECRAN

Call ECR_TRACE(format$("K:90X", "*") +
&              format$("-N:13.2", [L]RPTREMSBJUIF), 0)  From GESECRAN

Call ECR_TRACE(format$("K:98X", "*") +
&              format$("-N:13.2", [L]RPTUIFCTR), 0)  From GESECRAN
#JASMI - 2015-11-18 - Req. 112578 - END

Return

#########################################
$ENREG_DEB
#JASMI - 2015-06-09 - Requirement 108198 US 3581 - START
#UIFNUM = mid$([M:UFE]UIFNUM, 2, len([M:UFE]UIFNUM))
UIFNUM = [M:UFE]UIFNUM
#JASMI - 2015-06-09 - Requirement 108198 US 3581 - END

Wrseq "8000"; '"UICR"';
&     "8010"; '"U1"';
&     "8015"; '"E03"';
&     "8020"; '"' + UIFNUM + '"';
&     "8030"; '"' + LIVTST + '"';
&     "8040"; '"' + [M:UFE]CNTFNA - [M:UFE]CNTLNA + '"';
&     "8050"; '"0' + [M:UFE]CNTETS + '"';
&     "8060"; '"' + [M:UFE]CNTEMA + '"';
&     "8070"; PAYMTH
&                   Using [FIC]

#TRACE Column Headings
Call ECR_TRACE(format$("K:18X", mess(3, 76, 1)) + " " +
&              format$("K:18X", mess(69, 10701,1)) + " " +
&              format$("K:18X", mess(22, 11662,1)) + " " +
&              format$("K:8X", mess(27, 114, 1)) + " " +
&              format$("K:8X", mess(65, 123, 1)) + " " +
&              format$("K:2X", "St") + " " +
&              format$("K:2X", "Cd") + " " +
&              format$("K>:12X", "Gross Rem") + " " +
&              format$("K>:12X", "UIF Rem") + " " +
&              format$("K>:7X", "UIF Ctr"), 0) From GESECRAN

#TRACE Heading Line
Call ECR_TRACE(format$("K:18X", "------------------") + " " +
&              format$("K:18X", "------------------") + " " +
