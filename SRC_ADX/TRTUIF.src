Subprog AS_VOLFIL(VALEUR)
Variable Char    VALEUR()
  Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
  mkstat = func ASYRSTO.CTL_VOLFIL([M:DIA]TYPEXP,VALEUR,[M:DIA]FILNAM,E_TYPE_FILEWRITE,GMESSAGE)
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
  If [M]TYPEXP=2 Then
    VALEUR='['+[V]GDIRBQR+']/'+VALEUR
  Endif
  Affzo VOLFIL
End

