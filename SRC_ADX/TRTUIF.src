Endif
#JASMI - 2015-11-18 - Req. 112578 - ENDSTRREC = STRREC + '8150,' + format$("N0:15", EMPCNT) + ','
#MAPAD
 STRREC = STRREC + '8150,' + format$("N0:15", EMPCNT) + ','

#MAPAD
If EMPEMLADR <> "" Then
  STRREC = STRREC + '8160,"' + EMPEMLADR + '"'
Endif

If right$(STRREC, len(STRREC)) = "," : STRREC = left$(STRREC, len(STRREC) - 1) : Endif

