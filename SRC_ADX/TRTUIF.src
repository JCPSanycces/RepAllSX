#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - START
Subprog GET_COMPANY_INFO(VALEUR)
Variable Char VALEUR()

[M:UFE]UIFNUM = ""
[M:UFE]CCNCRM = ""
[M:UFE]CNTFNA = ""
[M:UFE]CNTLNA = ""
[M:UFE]CNTETS = ""
[M:UFE]CNTEMA = ""

Filter [FGR] Where CPY = VALEUR
Read [FGR] First
If !fstat
  Read [FCY]FCY0 = [F:FGR]FCY
  If !fstat
    Read [CPYKSA]CPYKSA0 = [F:FCY]LEGCPY
    If !fstat
    #JASMI - 2015-06-09 - Requirement 108198 US 3581 - START
    #  [M:UFE]UIFNUM = [F:CPYKSA]UIFNUM
#JASMI - 2017-04-10 - Req. 122480 - START
#      [M:UFE]UIFNUM = format$("N0:9",[F:CPYKSA]UIFRGTNUM)
#JASMI - 2017-11-15 - X3-63536 - START
#      [M:UFE]UIFNUM = format$("N0:8",[F:CPYKSA]UIFRGTNUM)
      [M:UFE]UIFNUM = format$("N0:9",[F:CPYKSA]UIFRGTNUM)
#JASMI - 2017-11-15 - X3-63536 - END
#JASMI - 2017-04-10 - Req. 122480 - END
    #JASMI - 2015-06-09 - Requirement 108198 US 3581 - END
    Endif
  Endif
Endif
Affzo [M:UFE]UIFNUM

Filter [CNTSA] Where BPATYP = 2 & BPANUM = [F:FCY]LEGCPY & RSACNTTYP = 4
Read [CNTSA] First
If !fstat
  If [F:CNTSA]BPATYP = 2 & [F:CNTSA]BPANUM = [F:FCY]LEGCPY & [F:CNTSA]RSACNTTYP = 4 Then
    Filter [CNT]
    Read [CNT]CNT0 = 2; [F:FCY]LEGCPY; [F:CNTSA]CCNCRM
    If !fstat
      [M:UFE]CCNCRM = [F:CNT]CCNCRM
      [M:UFE]CNTETS = [F:CNT]TEL
      [M:UFE]CNTEMA = [F:CNT]WEB
    Else
      GMESSAGE = mess(17,11662,1)
      GERR = 1
    Endif
  Else
    GMESSAGE = mess(17,11662,1)
    GERR = 1
  Endif
Else
  GMESSAGE = mess(17,11662,1)
  GERR = 1
  Filter [CNT] Where BPATYP = 2 & BPANUM = [F:FCY]LEGCPY
  Read [CNT] First
  If [F:CNT]BPATYP = 2 & [F:CNT]BPANUM = [F:FCY]LEGCPY Then
    [M:UFE]CCNCRM = [F:CNT]CCNCRM
    [M:UFE]CNTETS = [F:CNT]TEL
    [M:UFE]CNTEMA = [F:CNT]WEB
  Endif
Endif
Affzo [M:UFE]CCNCRM
Affzo [M:UFE]CNTETS
Affzo [M:UFE]CNTEMA

If [M:UFE]CNTETS = "" Then
  GMESSAGE = mess(18,11662,1)
  GERR = 1
Endif
If [M:UFE]CNTEMA = "" Then
  GMESSAGE = mess(19,11662,1)
  GERR = 1
Endif

If [M:UFE]CCNCRM <> "" Then
  Read [AIN]AIN0 = [M:UFE]CCNCRM
  If !fstat
    [M:UFE]CNTFNA = [F:AIN]CNTFNA
    [M:UFE]CNTLNA = [F:AIN]CNTLNA
  Endif
Endif
Affzo [M:UFE]CNTFNA
Affzo [M:UFE]CNTLNA

End
#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - END

Subprog GET_FILENAME_AUTO_EXTENSION()
Local Integer STAT
Local Char    COUNTER (8)
#ADNGO - 2017-06-05 - X3-11427 - START
#Call LECTCA(2, STAT) From SUBTCA
Call LECTCA(15, STAT) From SUBTCA
#ADNGO - 2017-06-05 - X3-11427 - END
If !STAT
  GMESSAGE = mess(21, 11662, 1)
  GOK = 0 : End
Else
  #ADNGO - 2017-06-05 - X3-11427 - START
  #COMPTEUR= [F:TCA]CODNUM(14)
  COMPTEUR= [F:TCA]CODNUM(21)
  #ADNGO - 2017-06-05 - X3-11427 - END
Endif
#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - START
#Call NUMERO(COMPTEUR, [M:UFE]CREFCY, date$, "", COUNTER, STAT) From SUBANM
Call NUMERO(COMPTEUR, [M:UFE]CPY, date$, "", COUNTER, STAT) From SUBANM
#JASMI - 2015-05-12 - MOVED LEGAL DATA TO COMPANY - END
If STAT
  GMESSAGE = mess(104,117,1)-COMPTEUR
  GOK = 0 : End
Endif
[M:UFE]EXT = right$(COUNTER, len(COUNTER) - 2)

End

Subprog VALIDATE_RSA_IDNUM(VALEUR)
Variable Char    VALEUR()

Local Integer RSAID_NUM(1..13)
Local Integer COUNTER
Local Integer TEMP_CALC1, TEMP_CALC2, TEMP_CALC3
Local Char    TEMP_CHAR1

  If VALEUR="0" or VALEUR="" Then
    Call ECR_TRACE("*** " + mess(24, 11662, 1) + " ***", 0) From GESECRAN
    End
  Endif

  COUNTER=0
  For COUNTER=1 To 13
    If ascii(mid$(VALEUR,COUNTER,1))>=48 &ascii(mid$(VALEUR,COUNTER,1)) <=57
      RSAID_NUM(COUNTER)=val(mid$(VALEUR,COUNTER,1))
    Else
      Call ECR_TRACE("*** " + mess(24, 11662, 1) + " ***", 0) From GESECRAN
      End
    Endif
  Next
  TEMP_CALC1=RSAID_NUM(1)+RSAID_NUM(3)+RSAID_NUM(5)+RSAID_NUM(7)+RSAID_NUM(9)+RSAID_NUM(11)
  TEMP_CALC2=(RSAID_NUM(2)*100000)+(RSAID_NUM(4)*10000)
&           +(RSAID_NUM(6)*1000)+(RSAID_NUM(8)*100)+(RSAID_NUM(10)*10)+(RSAID_NUM(12))
  TEMP_CALC2=TEMP_CALC2*2

  TEMP_CHAR1=num$(TEMP_CALC2)

  For COUNTER=1 To val(string$(TEMP_CALC2<1000000,"6")+string$(TEMP_CALC2>=1000000,"7"))
    TEMP_CALC3+=val(mid$(TEMP_CHAR1,COUNTER,1))
  Next
  TEMP_CALC3+=TEMP_CALC1
  TEMP_CALC3=mod(TEMP_CALC3,10)
  If TEMP_CALC3<>0 Then
    TEMP_CALC3=10-TEMP_CALC3
  Endif
  If TEMP_CALC3<>RSAID_NUM(13) Then
    Call ECR_TRACE("*** " + mess(24, 11662, 1) + " ***", 0) From GESECRAN
    End
  Endif
End

