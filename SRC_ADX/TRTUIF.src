Subprog AV_FILNAM(VALEUR)
Variable Char    VALEUR()
#JASMI - 2015-06-09 - Requirement 108198 US 3581 - START
#  If [M:UFE]UIFNUM <> "" & len([M:UFE]UIFNUM) > 1 Then
  #  VALEUR = mid$([M:UFE]UIFNUM, 2, len([M:UFE]UIFNUM))
