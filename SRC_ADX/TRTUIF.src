&              format$("K:2X", "--") + " " +
&              format$("K:2X", "--") + " " +
&              format$("K:12X", "------------") + " " +
&              format$("K:12X", "------------") + " " +
&              format$("K:7X", "-------"), 0) From GESECRAN

Return

