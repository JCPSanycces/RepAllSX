$ENREG_EN
STRREC     = '8001,"UIWK",'

#JASMI - 2015-06-09 - Requirement 108198 US 3581 - START
#UIFNUM     = mid$([F:CPYKSA]UIFNUM, 2, len([F:CPYKSA]UIFNUM))
#JASMI - 2017-04-10 - Req. 122480 - START
#UIFNUM     = format$("N0:9",[F:CPYKSA]UIFRGTNUM)
#JASMI - 2017-11-15 - X3-63536 - START
#UIFNUM     = format$("N0:8",[F:CPYKSA]UIFRGTNUM)
UIFNUM     = format$("N0:9",[F:CPYKSA]UIFRGTNUM)
#JASMI - 2017-11-15 - X3-63536 - END
#JASMI - 2017-04-10 - Req. 122480 - END
#JASMI - 2015-06-09 - Requirement 108198 US 3581 - END
STRREC     = STRREC + '8110,"' + UIFNUM + '",'

IDENUM     = [F:ESA]RSAID
If IDENUM <> "" : STRREC = STRREC + '8200,' + IDENUM + ',' : Endif

OTHNUM     = [F:ESA]PASNUM(0)
If OTHNUM <> "" : STRREC = STRREC + '8210,"' + OTHNUM + '",' : Endif

ALTNUM     = [F:HRCTR]REFNUM
STRREC     = STRREC + '8220,"' + ALTNUM + '",'

SURNAM     = [F:ID]SRN
STRREC     = STRREC + '8230,"' + SURNAM + '",'

FSTNAM     = [F:ID]NAM
STRREC     = STRREC + '8240,"' + FSTNAM + '",'

DATBTH     = format$("D:YYYYMMDD", [F:ID]DATBRN)
STRREC     = STRREC + '8250,' + DATBTH + ','





#MAPAD check if TaxUser has 2 contracts with 2 chronos, then display CTRDAT
MULTICTR = ""
CTRIND = 0
UIFCHECK = 0

Filter [F:CTR9]



Filter [F:CTR9] Where [FGR]CPY        = [M:UFE]CPY & [F:HRCTR]CTRDAT <= [M:UFE]ENDDAT &  REFNUM =[F:HRCTR]REFNUM




If rowcount([F:CTR9]) > 1 #Multiple contracts
  For [F:CTR9]
   # Read [CTR9]CTR0 Last

    If MULTICTR = [F:CTR9]CTRNUM   Then
       CTRIND=1
    Endif

    MULTICTR = [F:CTR9]CTRNUM
  Next

   Filter [F:CTR9]
   MULTICTR = ""

  If CTRIND = 1 Then
    DATEMPFRM  = format$("D:YYYYMMDD", [F:HRCTR]DATANC)
    STRREC     = STRREC + '8260,' + DATEMPFRM + ','
  Else
    DATEMPFRM  = format$("D:YYYYMMDD", [F:HRCTR]CTRDAT)
    STRREC     = STRREC + '8260,' + DATEMPFRM + ','
  Endif

Else
    DATEMPFRM  = format$("D:YYYYMMDD", [F:HRCTR]DATANC)
    STRREC     = STRREC + '8260,' + DATEMPFRM + ','

Endif






#JASMI - 2017-10-18 - X3-60401 - START
#If [F:CTR]XITDAT <> [0/0/0000] Then


#MAPAD X3-89738 09/05/2018 - start
#If ([F:CTR]XITDAT<>[0/0/0]) & ([F:CTR]XITDAT<=[M:UFE]ENDDAT) Then
##JASMI - 2017-10-18 - X3-60401 - END
#  DATEMPFIN  = format$("D:YYYYMMDD", [F:CTR]XITDAT)
#  STRREC = STRREC + '8270,' + DATEMPFIN + ','
#Endif


If ([F:HRCTR]XITDAT<>[0/0/0]) & ([F:HRCTR]XITDAT<=[M:UFE]ENDDAT) & ([F:HRCTR]XITFNL =2) Then
  DATEMPFIN  = format$("D:YYYYMMDD", [F:HRCTR]XITDAT)
  STRREC = STRREC + '8270,' + DATEMPFIN + ','
Endif

If [F:HRCTR]XITGRD = "" Then
  If [F:CTRSA]UIFSTA = 8 Then
     EMPSTA = "9"
  Elsif [F:CTRSA]UIFSTA = 10
    EMPSTA = "10"
  Elsif [F:CTRSA]UIFSTA = 9
    EMPSTA   = "5"
  Else
    EMPSTA   = "1"
  Endif
Else
#MAPAD X3-89738 09/05/2018 - START GET LEGAL CODE FROM MISC 359

If [F:HRCTR]XITDAT <= [M:UFE]ENDDAT Then
  Read [HRXGD]HRXGD0 = [F:HRCTR]XITGRD;"ZAF"

  If !fstat Then
    EMPSTA   = [F:HRXGD]LEGCOD
  Endif
#  Read[F:ADI]=359;EMPSTA
#
#  If !fstat
#    If [F:ADI]A4  <> "" Then
#       EMPSTA = [F:ADI]A4
#    Endif
#  Endif



Else
EMPSTA = "1"
Endif

#MAPAD X3-89738 09/05/2018 - END
Endif
STRREC     = STRREC + '8280,' + format$("N0:2", EMPSTA) + ','

RSNNONCTR  = ""
If UIFCTR  = 0 Then
  Case [F:CTRSA]UIFSTA
  When 2
    RSNNONCTR  = "3"
  When 3
    RSNNONCTR  = "2"
  When 4
    RSNNONCTR  = "4"
  When 5
    RSNNONCTR  = "1"
  When 1
    If GRSTAXREM = COMINC Then
      RSNNONCTR  = "5"
    Endif
    If GRSTAXREM = PENINC Then
      RSNNONCTR  = "8"
    Endif
    If GRSTAXREM = 0 Then
      RSNNONCTR  = "6"
    Endif
  #ADNGO - 2018-10-10 - X3-109721 - START
  When 11
     RSNNONCTR = "06"
  #ADNGO - 2018-10-10 - X3-109721 - END
  Endcase
Endif
If RSNNONCTR <> ""  : STRREC = STRREC + '8290,' + format$("N0:2", RSNNONCTR) + ',' : Endif

#JASMI - 2015-11-18 - Req. 112578 - START
#STRREC = STRREC + '8300,' + format$("N0:13.2", GRSTAXREM) + ','
If val(format$("-N0:13.2", GRSTAXREM))=val(format$("-N0:13", GRSTAXREM))
  STRREC = STRREC + '8300,' + format$("-N0:13", GRSTAXREM) + ','
Else
  STRREC = STRREC + '8300,' + format$("-N0:13.2", GRSTAXREM) + ','
Endif
#JASMI - 2015-11-18 - Req. 112578 - END
TOTGRSTAXREM = TOTGRSTAXREM + GRSTAXREM
RPTGRSTAXREM = RPTGRSTAXREM + GRSTAXREM
If RSNNONCTR = "" Then
#JASMI - 2015-11-18 - Req. 112578 - START
#  STRREC = STRREC + '8310,' + format$("N0:13.2", REMSBJUIF) + ','
  If val(format$("-N0:13.2", REMSBJUIF))=val(format$("-N0:13", REMSBJUIF))
    STRREC = STRREC + '8310,' + format$("-N0:13", REMSBJUIF) + ','
  Else
    STRREC = STRREC + '8310,' + format$("-N0:13.2", REMSBJUIF) + ','
  Endif
#JASMI - 2015-11-18 - Req. 112578 - END
  TOTREMSBJUIF = TOTREMSBJUIF + REMSBJUIF
  RPTREMSBJUIF = RPTREMSBJUIF + REMSBJUIF
Endif
If RSNNONCTR = "" Then
#JASMI - 2015-11-18 - Req. 112578 - START
#  STRREC = STRREC + '8320,' + format$("N0:13.2", UIFCTR) + ','
  If val(format$("-N0:13.2", UIFCTR))=val(format$("-N0:13", UIFCTR))
    STRREC = STRREC + '8320,' + format$("-N0:13", UIFCTR) + ','
  Else
    STRREC = STRREC + '8320,' + format$("-N0:13.2", UIFCTR) + ','
  Endif
#JASMI - 2015-11-18 - Req. 112578 - END
  TOTUIFCTR = TOTUIFCTR + UIFCTR
  RPTUIFCTR = RPTUIFCTR + UIFCTR
Endif

### IGNORE BANK DETAILS FOR NOW ###
#If BNKBRHCOD <> ""  : STRREC = STRREC + '8330,' + BNKBRHCOD + ',' : Endif
#If BNKBRHCOD <> ""  : STRREC = STRREC + '8340,' + BNKACCNUM + ',' : Endif
#If BNKBRHCOD <> ""  : STRREC = STRREC + '8350,' + BNKACCTYP       : Endif

EMPCNT = EMPCNT + 1

If right$(STRREC, len(STRREC)) = "," : STRREC = left$(STRREC, len(STRREC) - 1) : Endif

Wrseq STRREC
&                   Using [FIC]

#TRACE Detail Line
Call ECR_TRACE(format$("K:18X", ALTNUM) + " " +
&              format$("K:18X", FSTNAM) + " " +
&              format$("K:18X", SURNAM) + " " +
&              format$("K:8X", DATEMPFRM) + " " +
&              format$("K:8X", DATEMPFIN) + " " +
&              format$("K:2X", EMPSTA) + " " +
&              format$("K:2X", RSNNONCTR) + " " +
&              format$("N:9.2", GRSTAXREM) + " " +
&              format$("N:9.2", REMSBJUIF) + " " +
&              format$("N:4.2", UIFCTR), 0) From GESECRAN

Return

