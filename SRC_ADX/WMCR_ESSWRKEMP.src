#<AdxTL>@(#)0.0.0.0 $Revision$Class Employee
# Supervisor
## CRUD-CLASSE ## ESSWRKEMP
# 2018-10-23 06:53:22 512


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File ESSWRKEMP [EWID_]

If !SILENCE : Call TRACE("2 --> Local Instance C_ESSWRKEMP") From ASYRCOM : Endif
Local Instance ESSWRKEMP Using C_ESSWRKEMP

If !SILENCE : Call TRACE("3 --> New Instance C_ESSWRKEMP") From ASYRCOM : Endif
ESSWRKEMP = NewInstance C_ESSWRKEMP AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [EWID_]EWID0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of ESSWRKEMP") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP.AREAD([EWID_]UID))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("ESSWRKEMP.UID ="-num$(ESSWRKEMP.UID)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(ESSWRKEMP.AKEYS)
  Call TRACE("-"-num$(I)-":"-ESSWRKEMP.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [EWID_]
FreeGroup ESSWRKEMP
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(ESSWRKEMP,ACLE,ASTATUS,_ETAG)
Variable Instance ESSWRKEMP Using C_ESSWRKEMP
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Integer _UID
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_UID = val([L]CLE(1)) : Endif
Raz [L]_ETAG
Local File ESSWRKEMP [EWID]
Default File [F:EWID]
Read [F:EWID]EWID0 = [L]_UID
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:EWID]UPDTICK)>0
 [L]_ETAG = num$([F:EWID]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(ESSWRKEMP,ACLE,ASTATUS)
Variable Instance ESSWRKEMP Using C_ESSWRKEMP
Value Char ACLE
Variable Integer ASTATUS
Local Integer _UID
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_UID = val([L]CLE(1)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP.AREAD([L]_UID))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(ESSWRKEMP,_UID,ASTATUS)
Variable Instance ESSWRKEMP Using C_ESSWRKEMP
Value Integer _UID
Variable Integer ASTATUS

If ESSWRKEMP = null : End : Endif

Gosub AVARIABLES From WMC00ESSWRKEMP
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If ESSWRKEMP.APARENT=null
 [L]A_I = ESSWRKEMP.freeSnapshot
 ESSWRKEMP.snapshotEnabled = 0
 ESSWRKEMP.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & ESSWRKEMP.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If ESSWRKEMP.APARENT=null
 ESSWRKEMP.snapshotEnabled = 1
 ESSWRKEMP.setAccessorEnabled = 1
Endif
LogicClose File [EWID]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP._ACTION_PARAM("AREAD_BEFORE",[L]_UID))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:EWID]
Read [F:EWID]EWID0 = [L]_UID
If fstat
[L]A_ERROR = num$([L]_UID)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(ESSWRKEMP,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:EWID]AUUID)>0 & [F:EWID]AUUID=NullUuid
 [F:EWID]AUUID = getUuid
Endif
SetInstance ESSWRKEMP With [F:EWID]
ESSWRKEMP.ASTALIN = [V]CST_ALL

[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



