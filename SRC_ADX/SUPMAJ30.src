     Call MAJTEXTRA([F:PSL]AMTDES,"PARSTALIG","INTITVAR",[F:PSL]COD,num$(I))
     [F:PSL]AMTDES = ""
     Rewrite [PSL]
     If fstat
      Call ERREUR("PARSTALIG"-[F:PSL]COD,2) From DOSDIC
     Endif
    Endif
   Next
  Next
 Commit
Endif

Close Local File [PSL],[AXX]
End

