Call UUMAJTCYIB(DOSVAL)                : # Mise à jour champ FLIBAN
Call UUMAJTUNAMK(DOSVAL)               : # Suppression tunnel a tort
Call UUCTLVUE(DOSVAL)                  : # Contrôle abréviation vue non utilisé pour une table
Call TABCOUAFF(DOSVAL,DOSREF)          : # Rajout des nouveaux compteurs dans la table "Affectation des compteurs"
Call UTICOPMSK(DOSVAL)                 : # Copie de l'écran LECFIC
Call UTISUPMIG01(DOSVAL)               : # Reprise téléphones CONTACT V5
If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
Return

######################################################################
Subprog ARCHIVEADX(DOSSIER)
Value Char DOSSIER

Local Char    MACHINE(GLONAMC) , APPLI(GLONADS) , COMMAND(250)
Local Char    TRAIT(GLONADC)(30000)
Local Integer I , NBTRAIT , STAT

If val(DOSVERS)<25 : End : Endif : # C'est que la mise à jour 25 a déjà été faite

Call ECR_TRACE("Update process"-time$,0) From GESECRAN

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

# Suppression de l'archive
Call EFFACE(filpath("","archive","atx",APPLI,"",MACHINE),STAT) From ORDSYS
Call EFFACE(filpath("","atx","ind",APPLI,"",MACHINE),STAT) From ORDSYS
Call EFFACE(filpath("","vers","atx",APPLI,"",MACHINE),STAT) From ORDSYS

# Création version de l'archive
System COMMAND=MACHINE+'@archive -n -f -d'-APPLI

# Création de l'archive
System COMMAND=MACHINE+'@archive -d'-APPLI-'-t'-'-c "*"'

End

######################################################################
Subprog EPURMSKFEN(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE('Purge Windows & screens "W*"'-time$,0) From GESECRAN

Local File =DOSSIER+".AWINDOW"  [AWI], =DOSSIER+".AWINPAR" [AWP]
&        , =DOSSIER+".AWINBOUT" [AWT], =DOSSIER+".AWINBRO" [AWB]
&        , =DOSSIER+".AMSK"     [AMK], =DOSSIER+".AMSKZON" [AMZ]
&        , =DOSSIER+".AMSKPAR"  [AMP], =DOSSIER+".AMSKACT" [AMA]

Trbegin [AWI]
 Delete [AWI] Where left$(WIN,1)="W"
 Delete [AWP] Where left$(WIN,1)="W"
 Delete [AWT] Where left$(WIN,1)="W"
 Delete [AWB] Where left$(WIN,1)="W"
 Delete [AMK] Where left$(CODMSK,1)="W"
 Delete [AMZ] Where left$(CODMSK,1)="W"
 Delete [AMP] Where left$(CODAFF,1)="W" & TYPAFF=1
 Delete [AMA] Where left$(CODAFF,1)="W" & TYPAFF=1
Commit

Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
End

######################################################################
Subprog AVOCAB(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AVOCAB" [AVO]

Call ECR_TRACE(mess(81,125,1)-": AVOCAB"-time$,0) From GESECRAN : # maj table

Trbegin [AVO]
 Delete [AVO] Where (TXT="Assuré" or TXT="Formule") & VER=0
 For [AVO]
  If [F:AVO]VER=0
   [F:AVO]VER = 1
   [F:AVO]CUR = 1
   Rewrite [AVO]
   If fstat
    Call ERREUR("AVOCAB"-num$([F:AVO]LAN),1) From DOSDIC
   Endif
  Endif
 Next AVO
Commit

Close Local File [AVO]
End

######################################################################
Subprog ADOSSOL(DOSSIER)
Value Char DOSSIER

Local Integer I

Local Char    DOSX3(GLONADS) , APPLI(GLONADS) , MACHINE(GLONAMC)
Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 DOSX3 = [F:ADW]VALEUR
Endif
Close Local File [ADW]
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If APPLI<>DOSX3 : End : Endif

Local File =DOSSIER+".ADOSSIER" [XADS]
Local File =DOSSIER+".ADOSSOL"  [XADD]

Read [XADD]ADD0 First
If !fstat : Close Local File : End : Endif

# Mise à jour de la table ADOSSOL
Call ECR_TRACE(mess(81,125,1)-"ADOSSOL :"-time$,0) From GESECRAN

Trbegin [XADD]
 For [XADS]DOSSIER
  For I=1 To [F:XADS]LNBLIEN
   Raz [F:XADD]
   [F:XADD]LTYPLIEN = [F:XADS]LTYPLIEN(I-1)
   [F:XADD]LLIENACT = [F:XADS]LLIENACT(I-1)
   [F:XADD]LDOSTARG = [F:XADS]LDOSTARG(I-1)
   [F:XADD]LMAC     = [F:XADS]LMAC(I-1)
   [F:XADD]LSERV    = [F:XADS]LSERV(I-1)
   [F:XADD]LREP     = [F:XADS]LREP(I-1)
   [F:XADD]LTYPOS   = [F:XADS]LTYPOS(I-1)
   [F:XADD]LSOL     = [F:XADS]LSOL(I-1)
   [F:XADD]LTYPDBA  = [F:XADS]LTYPDBA(I-1)
   [F:XADD]LDBA     = [F:XADS]LDBA(I-1)
   [F:XADD]LSRC     = [F:XADS]LSRC(I-1)
   [F:XADD]LUSR     = [F:XADS]LUSR(I-1)
   [F:XADD]LPWD     = [F:XADS]LPWD(I-1)
   [F:XADD]DOSSIER  = [F:XADS]DOSSIER
   [F:XADD]NUMLIG   = I
   Write [XADD]
   If fstat
    Call ERREUR("ADOSSOL"-[F:XADS]DOSSIER-num$(I),1) From DOSDIC
   Endif
  Next I
 Next XADS
Commit

Close Local File
End

######################################################################
$RIEN
Resume

######################################################################
Subprog MAJRQT(DOSSIER)
Value Char DOSSIER

Local Integer I,J,NUMREQ

Local Char    DOSX3(GLONADS) , APPLI(GLONADS) , MACHINE(GLONAMC)
Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 DOSX3 = [F:ADW]VALEUR
Endif
Close Local File [ADW]
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If APPLI<>DOSX3 : End : Endif

Local File =DOSSIER+".ABATRQT"  [ABR]
Local File =DOSSIER+".ABATRQTL" [ABL]

Read [ABL]NUMREQ First
If !fstat : Close Local File [ABL] ,[ABR] : End : Endif

Call ECR_TRACE(mess(81,125,1)-":"-mess(92,134,1)-"(ABATRQT & ABATRQTL)"-time$,0) From GESECRAN : # maj table

# Recuperation des requetes batch dans la nouvelle table
Trbegin [ABR] , [ABL]
 Read [ABR]NUMREQ First
 While !fstat
  If [L]NUMREQ= 0
   [L]NUMREQ = [F:ABR]NUMREQ
   J=0
  Endif
  [F:ABL]NUMREQ = [L]NUMREQ
  For I=0 To dim([F:ABR]DEB)-1
   If [F:ABR]DEB(I) = "&" : Break : Endif
   If [F:ABR]DEB(I) <> ""
    J += 1
    [F:ABL]PARAM   = [F:ABR]DEB(I)
    [F:ABL]VALEUR  = [F:ABR]FIN(I)
    [F:ABL]NUM     = J
    Write [F:ABL]
    If fstat : Call ERREUR("ABATRQTL :"-num$([F:ABL]NUMREQ)-[F:ABL]PARAM,1) From DOSDIC : Endif
   Endif
  Next I
  If [F:ABR]DEB(dim([F:ABR]DEB)-1) <> "&"
   Raz [L]NUMREQ
  Endif
  If [L]NUMREQ > 0
   [F:ABR]DEB(0) = "&&&"
   Rewrite [F:ABR]
   If fstat
    Call ERREUR("ABATRQT :"-num$([F:ABR]NUMREQ),2) From DOSDIC
   Endif
  Endif
  Read [ABR]NUMREQ Next
 Wend
 Delete [ABR] Where [F:ABR]DEB(0) = "&&&"
 If fstat : Call ERREUR("ABATRQT",3) From DOSDIC : Endif
Commit
Close Local File [ABR] , [ABL]
End

######################################################################
Subprog MAJABD(DOSSIER)
Value Char DOSSIER

Local Integer I,J,LIG

Local Char    DOSX3(GLONADS) , APPLI(GLONADS) , MACHINE(GLONAMC)
Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 DOSX3 = [F:ADW]VALEUR
Endif
Close Local File [ADW]
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If APPLI<>DOSX3 : End : Endif

Local File =DOSSIER+".ABATABTD" [ABD]

If dim([F:ABD]DEB)<=0 :  Close Local File [ABD] : End : Endif

Call ECR_TRACE(mess(81,125,1)-":"-mess(96,134,1)-"(ABATABTD)"-time$,0) From GESECRAN : # maj table

# Recuperation des abonnements
Trbegin [ABD]
 Filter [ABD] Where PARAM="" Order By Key CLE=CODABT;CODTAC;LIG;NUM
 Read [ABD]CLE First
 While !fstat
  If [L]LIG= 0
   [L]LIG= [F:ABD]LIG
   J=0
  Endif
  [F:ABD]LIG= [L]LIG
  If [F:ABD]DEB(0) <> ""
   For I=0 To dim([F:ABD]DEB)-1
    If [F:ABD]DEB(I) = "&" : Break : Endif
    If [F:ABD]DEB(I) <> ""
     J += 1
     [F:ABD]PARAM   = [F:ABD]DEB(I)
     [F:ABD]VALEUR  = [F:ABD]FIN(I)
     [F:ABD]NUM     = J
     [F:ABD]DEB(0)  = "&&&&"
     Write [ABD]
     If fstat
      Call ERREUR("ABATABTD :"-[F:ABD]CODABT-[F:ABD]CODTAC-num$([F:ABD]LIG)-[F:ABD]PARAM,1) From DOSDIC
     Endif
    Endif
   Next I
  Else
   [F:ABD]DEB(0)  = "&&&&"
   Rewrite [ABD]
   If fstat
    Call ERREUR("ABATABTD :"-[F:ABD]CODABT-[F:ABD]CODTAC-num$([F:ABD]LIG)-[F:ABD]PARAM,2) From DOSDIC
   Endif
  Endif
  If [F:ABD]DEB(dim([F:ABD]DEB)-1) <> "&"
   Raz [L]LIG
  Endif
  Read [ABD]CLE Next
 Wend
 Filter [ABD]
 Delete [ABD] Where [ABD]DEB(0) <> "&&&&"
 If fstat : Call ERREUR("ABATABTD",3) From DOSDIC : Endif
Commit
Close Local File [ABD]
End

######################################################################
Subprog MAJPARECR(DOSSIER,TYP,PARAM,VALEUR)
Value Char DOSSIER,TYP,PARAM,VALEUR

Call ECR_TRACE(mess(81,125,1)-" AMSKPAR :"-TYP+"/"+PARAM-time$,0) From GESECRAN : # maj table

Local File =DOSSIER+".AMSKZON" [AMZ]
Local File =DOSSIER+".AMSKPAR" [AMP]

Trbegin [AMP]
 For [AMZ]CODE  Where CODTYP=[L]TYP
  Read [AMP]CODPAR = 1;[F:AMZ]CODMSK;[F:AMZ]CODZON;[L]PARAM
  If fstat
   [F:AMP]TYPAFF = 1
   [F:AMP]CODAFF = [F:AMZ]CODMSK
   [F:AMP]CODZON = [F:AMZ]CODZON
   [F:AMP]VALPAR = [L]VALEUR
   [F:AMP]CODPAR = [L]PARAM
   Write [AMP]
   If fstat : Call ERREUR("AMSKPAR:"-num$([F:AMP]TYPAFF)-[F:AMP]CODAFF-[F:AMP]CODZON,1) From DOSDIC : Endif
  Endif
 Next AMZ
Commit
Close Local File [AMZ] , [AMP]
End

######################################################################
Subprog MAJGRA(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".ALISTED" [ALD]
Local File =DOSSIER+".ALISTEH" [ALH]

If dim([F:ALH]GRA)>0
 Call ECR_TRACE(mess(81,125,1)-":"-"(ALISTED)"-time$,0) From GESECRAN : # maj table
 ## champ GRA et REP deplacé de la table ALISTEH vers la table ALISTED
 Trbegin [ALD]
  For [ALH]ALH0 Where TYPGRA>0
   For [ALD]ALD0 Where COD = [F:ALH]COD & [F:ALD]LIG<80
    [F:ALD]GRA = [F:ALH]GRA([F:ALD]LIG-1)
    [F:ALD]REP = [F:ALH]REP([F:ALD]LIG-1)
    Rewrite [ALD]
    If fstat
     Call ERREUR("ALISTED"-[F:ALH]COD-num$([F:ALD]LIG),1) From DOSDIC
    Endif
   Next ALD
  Next ALH
 Commit
Endif

Close Local File [ALH] , [ALD]
End

######################################################################
Subprog MAJAFC(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AFONCTION" [AFC]

Call ECR_TRACE(mess(81,125,1)-":"-"AFONCTION"-time$,0) From GESECRAN : # maj table

Trbegin [AFC]
 Update [AFC] Where NAVIG<1 With NAVIG=1
Commit

Close Local File [AFC]
End

############################################################################
# Mise a jour champ DES  dans champ INTIT de type AXX de la table AOBJEXTR #
############################################################################
Subprog MAJAOR(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AOBJEXTR"    [AOR]
Local File =DOSSIER+".ATEXTRA"     [AXX]

If dim([F:AOR]DES)>0
 # Mise à jour de la table AOBJEXTR(Transcodage Import/Export)
 Call ECR_TRACE(mess(81,125,1)-"AOBJEXTR("+mess(3,26,1)-mess(26,127,1)+") :"-time$,0) From GESECRAN
 Trbegin [AXX],[AOR]
  For [AOR]AOR0
   If [F:AOR]DES <> ""
    Call MAJTEXTRA([F:AOR]DES,"AOBJEXTR","INTIT",num$([F:AOR]NUMTAB),"")
    [F:AOR]DES = ""
    [F:AOR]NUMCAR = num$([F:AOR]NUMTAB)
    Rewrite [F:AOR]
    If fstat
     Call ERREUR("AOBJEXTR"-num$([F:AOR]NUMTAB),1) From DOSDIC
    Endif
   Endif
  Next
 Commit
Endif

Close Local File [AOR],[AXX]
End

#########################################################################################
# Mise à jour forcée de l'onglet sélection des objets et des champs RPT1 RPT2 et STA
#########################################################################################
Subprog AOBJLST(DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF

Local Char WOBJET(GLONAOB)

Local File =DOSSIER+".AOBJLST" [AOL] , =DOSREF+".AOBJLST" [AOL2] , =DOSSIER+".ALSTRD" [ALS]
&        , =DOSSIER+".AOBJET"  [AOB] , =DOSREF+".AOBJET"  [AOB2]

Call ECR_TRACE(mess(81,125,1)-": AOBJLST"-time$,0) From GESECRAN : # maj table

Trbegin [AOL]

 # Onglet sélection

 For WOBJET = "AOR","AMI","ASU","TFO","FCY","APN","AFT","APM","AUS","AIU","AME"
&            ,"ADV","ALH","ALT","ALQ","AMD","AOP","AF0","AEV","ACL","ACS"
&            ,"ABA","ABT","ACT","ADC","ADZ","AF1","AFC","AGB","AGF","AIN","ALH"
&            ,"AO3","AOB","AOE","AON","APR","AR0","ASB","AST","ATB","ATN","AMK"
&            ,"ANM","ATY","AWA"

  Read [AOL]AOL0 = WOBJET
  If !fstat
   Read [AOL2]AOL0 = WOBJET
   If !fstat
    [F:AOL] = [F:AOL2]
    Rewrite [AOL]
    If fstat
     Call ERREUR("AOBJLST"-WOBJET,2) From DOSDIC
    Endif
   Endif
  Endif
  Delete [ALS] Where OBJ=WOBJET
 Next WOBJET

 # Champs RPT1 RPT2 et STA

 For WOBJET = "AEN","AMD","ATR","ATT"
  Read [AOB]ABREV=WOBJET
  If !fstat
   Read [AOB2]ABREV=WOBJET
   If !fstat
    [F:AOB]RPT1 = [F:AOB2]RPT1
    [F:AOB]RPT2 = [F:AOB2]RPT2
    [F:AOB]STA  = [F:AOB2]STA
    Rewrite [AOB2]
    If fstat
     Call ERREUR("AOBJET"-WOBJET,2) From DOSDIC
    Endif
   Endif
  Endif
 Next WOBJET

Commit
Close Local File

End

#########################################################################################

Subprog MAJTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
Value    Char    VALEUR, TABLE, CHAMP, CLE1, CLE2
Local Char OLANGUE(GLONLAN)
OLANGUE = GLANGUE
If clalev([F:ADS])>0
 GLANGUE = [F:ADS]LANDEF
Else
 GLANGUE = "FRA"
Endif
Call MAJTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2) From ATEXTRA
GLANGUE = OLANGUE
End

#########################################################################################
# Mise à jour des champ des liens en type "technique" : Merci JPGA
#########################################################################################

Subprog MAJABZ(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","ABITABFLD","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS(DOSSIER,"ABI") : End : Endif

Local File =DOSSIER+".ABITABFLD"    [ABZ]
Local File =DOSSIER+".ABITABLNK"    [ABK]

Local Char CHAMP(80)(0..250),WCHP(80)
Local Integer I,J
# Mise à jour de la table ABITABFLD(Champs table de fait)
Call ECR_TRACE(mess(81,125,1)-"ABITABFLD("+mess(3,26,1)-mess(63,148,1)+") :"-time$,0) From GESECRAN

Trbegin [ABZ]
 For [ABK]ABK0
  If [F:ABK]EXPLNK <> ""
   I=instr(1,[F:ABK]EXPLNK,";")
   J =0
   If I
    CHAMP(J) = left$([F:ABK]EXPLNK,I-1)
    WCHP = right$([F:ABK]EXPLNK,I+1)
    I=instr(1,WCHP,";")
    While I
     J+=1
     CHAMP(J) = left$(WCHP,I-1)
     WCHP = right$(WCHP,I+1)
     I=instr(1,WCHP,";")
    Wend
    J +=1
    CHAMP(J) = WCHP
   Else
    CHAMP(0) =  [F:ABK]EXPLNK
   Endif
   For I=0 To J
    Read [ABZ]ABZ1 = [F:ABK]CODABF;CHAMP(I)
    If !fstat  & [F:ABZ]TYPFLD <> 4
     [F:ABZ]TYPFLD = 4
     Rewrite [F:ABZ]
     If fstat
      Call ERREUR("ABITABFLD"-[F:ABK]CODABF-CHAMP(I),1) From DOSDIC
     Endif
    Endif
   Next I
  Endif
 Next
Commit

Close Local File [ABZ],[ABK]
End

######################################################################
Subprog ACTION(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".ACTION" [ACT]

If dim([F:ACT]NOWEB)>=0
 Call ECR_TRACE(mess(81,125,1)-":"-"ACTION"-time$,0) From GESECRAN : # maj table
 Trbegin [ACT]
  Update [ACT] Where NOWEB<1 With NOWEB=1
  Update [ACT] Where PUBFLG<1 With PUBFLG=1
 Commit
Endif

Close Local File [ACT]
End

################################################################
Subprog MAJLNGADI(DOSSIER)
Value Char DOSSIER
Call ECR_TRACE("Update field length ADI on AMSKZON"-time$,0) From GESECRAN
Local File =DOSSIER+".AMSKZON" [AMZ] , =DOSSIER+".AMSKPAR" [AMP]
Local Integer X
Trbegin [AMZ]
 For [AMZ] Where CODTYP="ADI" & CODMSK<"W"
  Read [AMP]CODPAR=1;[F:AMZ]CODMSK;[F:AMZ]CODZON;"ADI"
  If !fstat
   If [F:AMP]VALPAR>="0" & [F:AMP]VALPAR<="9999"
    X = 1
   Elsif (len([F:AMP]VALPAR)>2 & find(left$([F:AMP]VALPAR,1),"'",'"')) or find(left$([F:AMP]VALPAR,6),"num$('",'num$("')
    X = 1
   Else
    X = 0
   Endif
   If !X & [F:AMZ]LONG=0
    [F:AMZ]LONG = 5
    Rewrite [AMZ]
    If fstat : Call ERREUR("AMSKZON",2) From DOSDIC : Endif
    Call ECR_TRACE("Screen"-[F:AMZ]CODMSK-", Field"-[F:AMZ]CODZON-", Length -> 5",0) From GESECRAN
   Endif
  Endif
 Next AMZ
Commit
Close Local File
End

################################################################
Subprog DOSLEG(DOSSIER)
Value Char DOSSIER

Local Char    DOSX3(GLONADS) , APPLI(GLONADS) , MACHINE(GLONAMC)
Local Integer K

Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 DOSX3 = [F:ADW]VALEUR
Endif
Close Local File [ADW]
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If MACHINE="" or DOSX3=""
 Local File ADOSSIER [ADX2]
Else
 Local File =MACHINE+"@"+DOSX3+".ADOSSIER" [ADX2]
Endif
Local File =DOSSIER+".ADOVAL" [ADW_]

Gosub SETLEG

If dim([F:ADX2]NBLEG)>0
 Call ECR_TRACE(mess(81,125,1)-":"-"ADOSSIER"-time$,0) From GESECRAN : # maj table ADOSSIER
 Trbegin [ADX2]
  Read [ADX2]DOSSIER=APPLI
  If !fstat
   If [F:ADX2]NBLEG=0
    K = find([F:ADX2]CRYDEF,TBCRY(1..NBLEG))
    If K
     [F:ADX2]DOSLEG(0) = TBLEG(K)
     [F:ADX2]NBLEG = 1
     Rewrite [ADX2]
     If fstat : Call ERREUR("ADOSSIER",2) From DOSDIC : Endif
    Endif
   Endif
   If [F:ADX2]NBLEG>0
    Read [ADW_]ADW0 = "";"";"DOSLEG"
    If fstat
     Raz [F:ADW_]
     [F:ADW_]PARAM  = "DOSLEG"
     [F:ADW_]VALEUR = sigma(0,[F:ADX2]NBLEG-1,string$(indcum>0,"~")+[F:ADX2]DOSLEG(indcum))
     Write [ADW_]
    Else
     [F:ADW_]VALEUR = sigma(0,[F:ADX2]NBLEG-1,string$(indcum>0,"~")+[F:ADX2]DOSLEG(indcum))
     Rewrite [ADW_]
    Endif
    If fstat
     Call ERREUR("ADOVAL",1) From DOSDIC
    Endif
   Endif
  Endif
 Commit
Endif
Close Local File [ADX2] , [ADW_]
End

$SETLEG
Local Integer NBLEG
Local Char    TBCRY(GLONCRY)(1..20) , TBLEG(GLONADI)(1..20)
NBLEG += 1 : TBCRY(NBLEG) = "GB"  : TBLEG(NBLEG) = "BRI"
NBLEG += 1 : TBCRY(NBLEG) = "FR"  : TBLEG(NBLEG) = "FRA"
NBLEG += 1 : TBCRY(NBLEG) = "IT"  : TBLEG(NBLEG) = "ITA"
NBLEG += 1 : TBCRY(NBLEG) = "PT"  : TBLEG(NBLEG) = "POR"
NBLEG += 1 : TBCRY(NBLEG) = "ES"  : TBLEG(NBLEG) = "SPA"
NBLEG += 1 : TBCRY(NBLEG) = "US"  : TBLEG(NBLEG) = "USA"
NBLEG += 1 : TBCRY(NBLEG) = "DE"  : TBLEG(NBLEG) = "GER"
NBLEG += 1 : TBCRY(NBLEG) = "CN"  : TBLEG(NBLEG) = "CHI"
NBLEG += 1 : TBCRY(NBLEG) = "CH"  : TBLEG(NBLEG) = "SWI"
NBLEG += 1 : TBCRY(NBLEG) = "PL"  : TBLEG(NBLEG) = "POL"
Return

#################################################################
Subprog MAJAPLINI(DOSSIER)
Value Char DOSSIER
Local Char    DOSX3(GLONADS) , APPLI(GLONADS) , MACHINE(GLONAMC) , OLDVAL(20) , NEWVAL(20)
Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 DOSX3 = [F:ADW]VALEUR
Endif
Close Local File [ADW]
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If MACHINE="" or DOSX3=""
 Local File ADOSSIER [ADX2]
Else
 Local File =MACHINE+"@"+DOSX3+".ADOSSIER" [ADX2]
Endif

Call LECAPL(APPLI,"maxmem",OLDVAL)

Trbegin [ADX2]
 Read [ADX2]DOSSIER=APPLI
 NEWVAL =  num$(max(30,val(OLDVAL)/1024,[F:ADX2]SYSPAR(0)))
 [F:ADX2]SYSPAR(0) = int(val(NEWVAL))
 Rewrite [ADX2]
 If fstat : Call ERREUR("ADOSSIER",2) From DOSDIC : Endif
Commit

Call ECR_TRACE("Update maxmem : "-NEWVAL-time$,0) From GESECRAN

Close Local File [ADX2]
End

#############################################
Subprog LECAPL(APPLI,VARSYS,VALEUR)
Value Char APPLI
Value Char VARSYS
Variable Char VALEUR

Local Char    VOLUME(1) , MACHINE(GDIMFIC)
Local Char    NOMFIC(GDIMFIC)
Local Integer K
Local Char    LIGNE(250)

If clalev([F:ADX2])=0 : Local File ADOSSIER [ADX2] : Endif

Read [ADX2]DOSSIER=APPLI
If fstat : End : Endif

APPLI  = [F:ADX2]DOSSIER
VOLUME = [F:ADX2]VOLUME
MACHINE = adxmac(0)

# Fichier APL.ini
NOMFIC = filpath("","APL","ini",APPLI,VOLUME,MACHINE)
If filinfo(NOMFIC,0)<0
 End
Endif
Openi NOMFIC Using [AI]
Iomode adxifs "" Using [AI]
Iomode adxirs chr$(10) Using [AI]
Iomode adxium GUTF8 Using [AI]
fstat = 0
Repeat
 Rdseq LIGNE Using [AI]
 If !fstat
  K = instr(1,LIGNE,"=")
  If K
   If vireblc(left$(LIGNE,K-1),2)=VARSYS
    VALEUR = vireblc(right$(LIGNE,K+1),2)
    Break
   Endif
  Endif
 Endif
Until fstat
Openi Using [AI]
End

################################################################
Subprog TABFOR(DOSSIER)
Value Char DOSSIER

Local Char    DOSX3(GLONADS) , APPLI(GLONADS) , MACHINE(GLONAMC)
Local Integer K , I

Local File =DOSSIER+".TABFOR" [TFO] , =DOSSIER+".ATEXTRA" [AXX]

If dim([F:TFO]FORDES)>0
 # Mise table TABFOR
 Call ECR_TRACE(mess(81,125,1)-": TABFOR"-time$,0) From GESECRAN
 Local File =DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0="";"";"SUPDOS"
 If !fstat & [F:ADW]VALEUR<>""
  DOSX3 = [F:ADW]VALEUR
 Endif
 Close Local File [ADW]
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
 If MACHINE="" or DOSX3=""
  Local File ADOSSIER [ADX2]
 Else
  Local File =MACHINE+"@"+DOSX3+".ADOSSIER" [ADX2]
 Endif
 Gosub SETLEG
 Read [ADX2]DOSSIER=APPLI
 If !fstat
  If [F:ADX2]NBLEG=0
   K = find([F:ADX2]CRYDEF,TBCRY(1..NBLEG))
   If K
    [F:ADX2]DOSLEG = TBLEG(K)
    [F:ADX2]NBLEG = 1
   Endif
  Endif
 Endif
 Trbegin [AXX]
  For [TFO]TFO0
   [F:TFO]FORNUM = num$([F:TFO]FORTYP)
   If [F:TFO]FORTYP=21 & GPRODUIT=0 : # Pièces auto
    For I=0 To [F:ADX2]NBLEG-1
     [F:TFO]LEG(I) = [F:ADX2]DOSLEG(I)
    Next I
   Endif
   If [F:TFO]FORDES<>""
    Call MAJTEXTRA([F:TFO]FORDES,"TABFOR","DES",[F:TFO]FORNUM,[F:TFO]FORCOD)
    [F:TFO]FORDES = ""
   Endif
   If [F:TFO]FORSHO<>""
    Call MAJTEXTRA([F:TFO]FORSHO,"TABFOR","DESSHO",[F:TFO]FORNUM,[F:TFO]FORCOD)
    [F:TFO]FORSHO = ""
   Endif
   Rewrite [TFO]
   If fstat
    Call ERREUR("TABFOR"-[F:TFO]FORNUM-[F:TFO]FORCOD,2) From DOSDIC
   Endif
  Next TFO
 Commit
 Close Local File [ADX2]
Endif

Close Local File [TFO],[AXX]
End

###################################################
# Maj texte traduisibles des transaction sytemes
###################################################
Subprog DESAMI(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AMAINT"    [AMI]
Local File =DOSSIER+".ATEXTE"    [ATX]

If dim([F:AMI]DES)>0
 # Mise à jour de la table AMAINT (Transactions système)
 Call ECR_TRACE(mess(81,125,1)-"AMAINT :"-time$,0) From GESECRAN
 Trbegin [AMI]
  For [AMI]AMI0
   If [F:AMI]DES <> ""
    Call NUMERO ([F:AMI]DES,[F:AMI]INTIT)
   Endif
   If [F:AMI]DESSHO <> ""
    Call NUMERO ([F:AMI]DESSHO,[F:AMI]INTITSHO)
   Endif
   For I=0 To [F:AMI]NBRVAR-1
    Call NUMERO ([F:AMI]VARDES(I),[F:AMI]VARINTIT(I))
   Next I
   Rewrite [AMI]
   If fstat : Call ERREUR("AMAINT",2) From DOSDIC : Endif
  Next
 Commit
Endif

Close Local File [AMI],[ATX]
End

#################################################
Subprog NUMERO(VALEUR,NUM)
Value    Char    VALEUR
Variable Integer NUM
Local Integer ASTATUS
Local Char MESSAGE(250)
Local    Integer PREM , DERN
If VALEUR="" : NUM = 0 : End : Endif
Read [ATX]TEXTE = GLANGUE;VALEUR
If fstat=0
 NUM = [F:ATX]NUMERO
Else
 Lock [ATX]
 If fstat
  NUM = 0 : End
 Endif
 If dim([V]GADONIX)>0 & GADONIX<>2
  PREM = GMAXTXTSTD : DERN = GMAXTXTSPE
 Else
  PREM = 0 : DERN = GMAXTXTSTD
 Endif
 If DERN = GMAXTXTSTD & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
  Gosub INIT_LANGS
  ASTATUS = func ATXTSVC.CREATE_TEXT_CHAR(GPRODUIT,GLANGUE,LANGS,VALEUR, "",NUM,MESSAGE)
  If ASTATUS<>[V]CST_AOK
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
   NUM = 0 : End
  Endif
 Else
  Filter [ATX] Where NUMERO>PREM & NUMERO<DERN Order By Key CLE=NUMERO;LAN
  Read [ATX] Last
  Filter [ATX]
  If fstat : NUM = PREM+1 : Else : NUM = [F:ATX]NUMERO+1 : Endif
 Endif
 Raz [F:ATX]
 [F:ATX]NUMERO = NUM
 [F:ATX]TEXTE  = VALEUR
 [F:ATX]LONG   = 30
 [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
 [F:ATX]LAN = GLANGUE
 If dim([F:ATX]LANORI)>0 & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
  ASTATUS = func ATXTSVC.GET_LANORI(GPRODUIT, NUM, GLANGUE,[F:ATX]LANORI,MESSAGE)
 Endif
 If dim([F:ATX]UPDDAT)>0 : [F:ATX]UPDDAT = date$ : Endif
 Write [ATX]
 If fstat
  Call ERREUR("ATEXTE",1) From DOSDIC
  NUM = 0 : End
 Endif
Endif
End


$INIT_LANGS
Local Char LANGS(3)(0..)
Local Integer NBLANGS
Local File ADOSSIER [ADS]
Local Integer AI
If func DOSSUB.FILL_ADS(nomap)
 For AI=0 To [F:ADS]NBRLAN-1
  LANGS(AI) = [F:ADS]LAN(AI)
  NBLANGS+=1
 Next AI
Endif
Return

################################################################
Subprog ACTL(DOSSIER)
Value Char DOSSIER
Local Integer K

Local File =DOSSIER+".ACTL" [ACL]
Local File =DOSSIER+".ATEXTRA"   [AXX]

If dim([F:ACL]INTIT)>0

 # Mise table ACTL
 Call ECR_TRACE(mess(81,125,1)-": ACTL"-time$,0) From GESECRAN

 Trbegin [ACL]
  For [ACL]ACL0
   K = 0
   If [F:ACL]MSG<>"" & !find(left$([F:ACL]MSG,1),"'",'"')
    [F:ACL]MSG = '"'+[F:ACL]MSG+'"' : K = 1
   Endif
   If [F:ACL]MSG2<>"" & !find(left$([F:ACL]MSG2,1),"'",'"')
    [F:ACL]MSG2 = '"'+[F:ACL]MSG2+'"' : K = 1
   Endif
   If [F:ACL]MSG3<>"" & !find(left$([F:ACL]MSG3,1),"'",'"')
    [F:ACL]MSG3 = '"'+[F:ACL]MSG3+'"' : K = 1
   Endif
   If [F:ACL]INTIT<>""
    Call MAJTEXTRA([F:ACL]INTIT,"ACTL","DES",[F:ACL]CTL,"")
    [F:ACL]INTIT = ""
    K = 1
   Endif
   If K
    Rewrite [ACL]
    If fstat
     Call ERREUR("ACTL"-[F:ACL]CTL,2) From DOSDIC
    Endif
   Endif
  Next ACL
 Commit
Endif

Close Local File [ACL],[AXX]
End

############################################################################################
# Remplacement du type de données ADJ par ADI pour éviter des erreurs de validation
############################################################################################
Subprog AMSKZONADJ(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AMSKZON" [AMZ]

# Mise à jour de la table AMSKZON
Call ECR_TRACE(mess(81,125,1)-"AMSKZON (ADJ) :"-time$,0) From GESECRAN

Trbegin [AMZ]
 For [AMZ] Where CODTYP="ADJ" & left$(CODMSK,1)="W"
  [F:AMZ]CODTYP = "ADI"
  Rewrite [AMZ]
  If fstat : Call ERREUR("AMSKZON",2) From DOSDIC : Endif
 Next
Commit

Close Local File [AMZ]
End

#########################################################################################
# Mise à jour des champs option de jointures
#########################################################################################
Subprog MAJOPTJNT(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","ABITABFLD","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS(DOSSIER,"ABI") : End : Endif

Local File =DOSSIER+".ABIDIMFLD"    [ABJ]

# Mise à jour de la table ABIDIMFLD (Champs table de dimension)
Call ECR_TRACE(mess(81,125,1)-"ABIDIMFLD"-time$,0) From GESECRAN

Trbegin [ABJ]
 For [ABJ]ABJ0
  If [F:ABJ]DIMFAT<>"" & [F:ABJ]OPTJNT = 0
   [F:ABJ]OPTJNT = 1
   Rewrite [F:ABJ]
   If fstat
    Call ERREUR("ABIDIMFLD"-[F:ABJ]CODDIM,1) From DOSDIC
   Endif
  Endif
 Next
Commit

Close Local File [ABJ]
End

#########################################################################################
# Mise à jour des champs mesure et code ansi
#########################################################################################
Subprog MAJABM(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","ABIDATMRT","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS(DOSSIER,"ABI") : End : Endif


Local File =DOSSIER+".ABIDATMRT"    [ABM]

# Mise à jour de la table ABIDATMRT(Champs table de datamart)
Call ECR_TRACE(mess(81,125,1)-"ABIDATMRT"-time$,0) From GESECRAN

Trbegin [ABM]
 For [ABM]ABM0
  If dim([F:ABM]ANSI)>0 & [F:ABM]ANSI = 0
   [F:ABM]ANSI=1
  Endif
  If dim([F:ABM]MESURE)>0 & [F:ABM]MESURE = 0
   [F:ABM]MESURE=1
  Endif
  If dim([F:ABM]DATNUL)>0 & [F:ABM]DATNUL= 0
   [F:ABM]DATNUL=1
  Endif
  If dim([F:ABM]PREFIX)>0 & [F:ABM]PREFIX= 0
   [F:ABM]PREFIX=2
  Endif
  Rewrite [F:ABM]
  If fstat
   Call ERREUR("ABIDATMRT"-[F:ABM]COD,1) From DOSDIC
  Endif
 Next
Commit

Close Local File [ABM]
End

#########################################################################################
# Mise à jour législation dans la table COMPANY
#########################################################################################
Subprog COMPANY(DOSSIER)
Value Char DOSSIER
Local Integer K
Local Char    DOSX3(GLONADS) , APPLI(GLONADS) , MACHINE(GLONAMC) , NEWLEG(GLONADI) , PAYS(GLONCRY)
Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 DOSX3 = [F:ADW]VALEUR
Endif
Close Local File [ADW]
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
If MACHINE="" or DOSX3=""
 Local File ADOSSIER [ADX2]
Else
 Local File =MACHINE+"@"+DOSX3+".ADOSSIER" [ADX2]
Endif
Gosub SETLEG
Read [ADX2]DOSSIER=APPLI
If !fstat
 PAYS = [F:ADX2]CRYDEF
 If [F:ADX2]NBLEG=0
  K = find(PAYS,TBCRY(1..NBLEG))
  If K
   [F:ADX2]DOSLEG = TBLEG(K)
   [F:ADX2]NBLEG = 1
  Endif
 Endif
Endif
NEWLEG = [F:ADX2]DOSLEG
Close Local File [ADX2]
If NEWLEG=""
 Call ECR_TRACE("Country:"+PAYS-"Update company failed",-1) From GESECRAN
 End
Endif

Local File =DOSSIER+".COMPANY" [CPY]

# Mise à jour de la table COMPANY
Call ECR_TRACE(mess(81,125,1)-"COMPANY :"-time$,0) From GESECRAN

Trbegin [CPY]
 Update [CPY] Where CPYLEGFLG=2 & LEG="" With LEG=NEWLEG
Commit

Close Local File
End

