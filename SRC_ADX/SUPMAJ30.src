#################################################
# Mise à jour champ GEN de la table ADOCFLD
#################################################
Subprog ADOCFLD(DOSSIER)
Value Char DOSSIER
Local File =DOSSIER+".ADOCFLD" [ADZ]

# Mise à jour de la table ADOCFLD
Call ECR_TRACE(mess(81,125,1)-"ADOCFLD:"-time$,0) From GESECRAN
Trbegin [ADZ]
 For [ADZ] Where GEN=0
  [F:ADZ]GEN = 1
  Rewrite [ADZ]
  If fstat
   Call ERREUR("ADOCFLD"-[F:ADZ]LAN-[F:ADZ]MOTCLE,2) From DOSDIC
  Endif
 Next
Commit

Close Local File [ADZ]
End

###################################################
# Maj texte traduisibles des Paramétrage tableau/import
###################################################
Subprog INTAEV(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AEXPV3"     [AEV]
Local File =DOSSIER+".ATEXTRA"    [AXX]

If dim([F:AEV]DES)<0
 Close Local File [AEV],[AXX]
 End
Endif

# Mise à jour de la table AEXPV3
Call ECR_TRACE(mess(81,125,1)-"AEXPV3:"-time$,0) From GESECRAN
Trbegin [AEV]
 For [AEV]AEV0
  If [F:AEV]DES <> ""
   Call MAJTEXTRA([F:AEV]DES,"AEXPV3","INTIT",[F:AEV]CODE,"")
   [F:AEV]DES = ""
   Rewrite [AEV]
   If fstat
    Call ERREUR("AEXPV3"-[F:AEV]CODE,2) From DOSDIC
   Endif
  Endif
 Next
Commit

Close Local File [AEV],[AXX]
End

######################################################################
Subprog AGLOBVAR(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AGLOBVAR" [AGB]

Call ECR_TRACE(mess(81,125,1)-":"-"AGLOBVAR"-time$,0) From GESECRAN : # maj table
Trbegin [AGB]
 Update [AGB] Where PUBFLG<1 With PUBFLG=1
Commit
Close Local File [AGB]
End

######################################################################
Subprog ATABDIV(DOSSIER,DOSREF,DOSCOP,NUMTAB)
Value Char DOSSIER , DOSREF , DOSCOP
Value Integer NUMTAB

Local File =DOSCOP+".ATABDIV" [ADI1] , =DOSSIER+".ATABDIV" [ADI2]
&        , =DOSCOP+".ATEXTRA" [AXX1] , =DOSSIER+".ATEXTRA" [AXX2]
&        , =DOSREF+".ATABDIV" [ADV1] , =DOSSIER+".ATABTAB" [ADV2]

Call ECR_TRACE(mess(81,125,1)-":"-"ATABDIV ("+num$(NUMTAB)+")"-time$,0) From GESECRAN : # maj table

Trbegin [ADI2]
 Read [ADV1]CODE = [L]NUMTAB
 If !fstat
  For [ADI1] Where [F]NUMTAB=[L]NUMTAB
   Read [ADI2]CODE=[L]NUMTAB;[F:ADI1]CODE
   If fstat
    [F:ADI2] = [F:ADI1]
    Call COPTEXTRA("ATABDIV","LNGDES",num$([L]NUMTAB),[F:ADI1]CODE) From ATEXTRA
    Call COPTEXTRA("ATABDIV","SHODES",num$([L]NUMTAB),[F:ADI1]CODE) From ATEXTRA
    Write [ADI2]
    If fstat
     Call ERREUR("ATABDIV"-num$([F:ADI1]NUMTAB)-[F:ADI1]CODE,1) From DOSDIC
    Endif
    Read [ADV2]CODE=[L]NUMTAB
    If fstat
     [F:ADV2] = [F:ADV1]
     Call COPTEXTRA("ATABTAB","LNGDES",num$([L]NUMTAB),"") From ATEXTRA
     Call COPTEXTRA("ATABTAB","SHODES",num$([L]NUMTAB),"") From ATEXTRA
     Call COPTEXTRA("ATABTAB","ALPDES1",num$([L]NUMTAB),"") From ATEXTRA
     Call COPTEXTRA("ATABTAB","ALPDES2",num$([L]NUMTAB),"") From ATEXTRA
     Call COPTEXTRA("ATABTAB","NUMDES1",num$([L]NUMTAB),"") From ATEXTRA
     Call COPTEXTRA("ATABTAB","NUMDES2",num$([L]NUMTAB),"") From ATEXTRA
     Write [ADV2]
     If fstat
      Call ERREUR("ATABTAB"-num$([F:ADV1]NUMTAB),1) From DOSDIC
     Endif
    Endif
   Endif
  Next SADI
 Endif
Commit

Close Local File [ADI1] , [ADI2] , [ADV2] , [ADV1] , [AXX1] , [AXX2]
End

#################################################
# Mise à jour champ de la table GTABACC
#################################################
Subprog GTABACC(DOSSIER,DOSREF)
Value Char DOSSIER
Value Char DOSREF

Local File =DOSSIER+".GTABACC"  [GTC] : Local File =DOSREF+".GTABACC"  [RGTC]
Local File =DOSSIER+".AMSKZON"  [AMZ]
Local File =DOSSIER+".ACONSULT" [ACN]
Local File =DOSSIER+".AWINDOW"  [AWI]
Local File =DOSSIER+".ACTIV"    [ACV]

Local Integer  I , J , OK , K , N , M
Local Shortint DIME : DIME = dim([F:GTC]FLD)-1
Local Char     FLD_(GLONAVA)(0..DIME)
Local Integer  GRA_(0..DIME) , REP_(0..DIME) , DAC_(0..DIME) , NBRFLD_
Local Char     MSKREF(GLONAMK) , WINREF(GLONFEN) , CONSCOD(80)

# Mise à jour de la table GTABACC
Call ECR_TRACE(mess(81,125,1)-"GTABACC:"-time$,0) From GESECRAN

Trbegin [GTC]
 For [GTC]
  Gosub MSKREF
  Raz NBRFLD_,FLD_,DAC_,GRA_,REP_
  For I=0 To [F:GTC]NBRFLD-1
   [L]NBRFLD_ += 1
   [L]FLD_(NBRFLD_-1) = [F:GTC]FLD(I)
   [L]DAC_(NBRFLD_-1) = [F:GTC]DAC(I)
   [L]GRA_(NBRFLD_-1) = [F:GTC]GRA(I)
   [L]REP_(NBRFLD_-1) = [F:GTC]REP(I)
  Next I
  Raz [F:GTC]NBRFLD,[F:GTC]FLD,[F:GTC]DAC,[F:GTC]GRA,[F:GTC]REP
  # On garde les champs existants et on vire ceux qui n'existe plus
  For I=0 To [L]NBRFLD_-1
   CHP = [L]FLD_(I)
   Gosub EXISTE_CHP
   If OK
    [F:GTC]NBRFLD += 1
    [F:GTC]FLD([F:GTC]NBRFLD-1) = CHP
    [F:GTC]DAC([F:GTC]NBRFLD-1) = [L]DAC_(I)
    If [F:GTC]REPGRA>1
     [F:GTC]GRA([F:GTC]NBRFLD-1) = [L]GRA_(I)
     [F:GTC]REP([F:GTC]NBRFLD-1) = [L]REP_(I)
    Endif
   Endif
  Next I
  # On rajoute les nouveaux champs
  Read [F:RGTC]GTC0 = [F:GTC]CNSCOD;[F:GTC]COD
  If !fstat
   For I=0 To [F:RGTC]NBRFLD-1
    CHP = [F:RGTC]FLD(I)
    If !find(CHP,[F:GTC]FLD(0..[F:GTC]NBRFLD-1))
     Gosub EXISTE_CHP
     If OK
      [F:GTC]NBRFLD += 1
      [F:GTC]FLD([F:GTC]NBRFLD-1) = CHP
      [F:GTC]DAC([F:GTC]NBRFLD-1) = [F:RGTC]DAC(I)
      If [F:GTC]REPGRA>1
       [F:GTC]GRA([F:GTC]NBRFLD-1) = [F:RGTC]GRA(I)
       [F:GTC]REP([F:GTC]NBRFLD-1) = [F:RGTC]REP(I)
      Endif
     Endif
    Endif
   Next I
  Endif
  # Vérifications : si l'option graphique est cochée et qu'il n'y a pas de libellé ou trop, on désactive
  Raz K ,  M , N
  For I=0 To [F:GTC]NBRFLD-1
   If [F:GTC]DAC(I)<>0                   : K += 1 : Endif : # Ordre
   If [F:GTC]GRA(I)=3                    : N += 1 : Endif : # Libellé
   If [F:GTC]GRA(I)=1 or [F:GTC]GRA(I)=2 : M += 1 : Endif : # Valeur
  Next I
  If !K
   # Aucun champs sélectionné
   [F:GTC]ENAFLG = 1
  Elsif [F:GTC]REPGRA>1 & ( N<>1 or M=0 ) & [F:GTC]ENAFLG = 2
   # Il faut au moins un champ de type libellé pour utiliser le graphisme
   [F:GTC]ENAFLG = 1
  Endif
  Rewrite [GTC]
  If fstat
   Call ERREUR("GTABACC"-[F:GTC]CNSCOD-[F:GTC]COD,2) From DOSDIC
  Endif
 Next
Commit

Close Local File [GTC],[AMZ] , [ACN] , [AWI] , [RGTC] , [ACV]
End

$MSKREF
CONSCOD = [F:GTC]CNSCOD
MSKREF = ""
Call LECTURE("ACN",CONSCOD,"") From CONTOBJ
If !fstat
 WINREF = [F:ACN]WND1
 Read [AWI]AWI0 = WINREF
 If !fstat
  MSKREF = [F:AWI]NOMMSK(0)
 Endif
Endif
Return

$EXISTE_CHP
Read [AMZ]CODE = MSKREF;"NBLIG"
If fstat=0 : J = [F:AMZ]NUMBLOC : Else J = 0 : Endif
OK = 0
For [AMZ]CODZON Where CODMSK=MSKREF & [F:AMZ]CODZON=CHP
 OK = 1
 If [F:AMZ]CODTYP="ABS" or [F:AMZ]SAIAFF=3 or (J & [F:AMZ]NUMBLOC<>J)
  OK = 0
 Endif
 If [F:AMZ]CODACT<>""
  Read [ACV]CODACT = [F:AMZ]CODACT
  If fstat or [F:ACV]FLACT<>2 : OK = 0 : Endif
 Endif
Next AMZ
Return

#############################################################
# Mise à jour NBRCOL et NBRLIG sur les écrans standard
#############################################################
Subprog MAJCOLLIN(DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF
Local Integer SPE , I
Local Char  CHAINE(250)

# Mise à jour de la table AMSK
Call ECR_TRACE(mess(81,125,1)-"AMSK:"-time$,0) From GESECRAN

Local File =DOSSIER+".AMSK" [AMK] , =DOSSIER+".AMSKZON" [AMZ] , =DOSREF+".AMSK" [AMK2]

Trbegin [AMK]
 For [AMK] Where CODMSK<GXX
  SPE = 0
  If [F:AMK]CODACT<>""
   Call SPEC([F:AMK]CODACT,SPE) From DOSSUB
  Endif
  If !SPE
   Read [AMK2]CODMSK=[F:AMK]CODMSK
   If !fstat & [F:AMK]NBRLIG>[F:AMK2]NBRLIG : # Si le nb de ligne de l'écran de référence est inférieur à celui validé
    For I=0 To min([F:AMK]NBLIGT-1,dim([F:AMK]ACTBLOC)-1)
     If [F:AMK]ACTBLOC(I)<>""
      Call SPEC([F:AMK]ACTBLOC(I),SPE) From DOSSUB
      If SPE : Break : Endif
     Endif
    Next I
    If !SPE
     For [F:AMZ]CODE Where CODMSK=[F:AMK]CODMSK
      If [F:AMZ]CODACT<>""
       Call SPEC([F:AMZ]CODACT,SPE) From DOSSUB
       If SPE : Break : Endif
      Endif
     Next AMZ
    Endif
    CHAINE = "NBRLIG ("+num$([F:AMK]NBRLIG)+"->"+num$([F:AMK2]NBRLIG)+")"
    If !SPE
     Call ECR_TRACE([F:AMK]CODMSK-":"-"Update"-CHAINE,0) From GESECRAN
     [F:AMK]NBRLIG = [F:AMK2]NBRLIG : # on met à jour le nombre de lignes de l'écran validé
     Rewrite [AMK]
     If fstat
      Call ERREUR("AMSK"-[F:AMK]CODMSK,2) From DOSDIC
     Endif
    Else
     Call ECR_TRACE([F:AMK]CODMSK-":"-"No update"-CHAINE,-1) From GESECRAN
    Endif
   Endif
  Endif
 Next AMK
Commit

Close Local File [AMK] ,  [AMK2] , [AMZ]
End

#########################################################
# Remplacement code évènement ANU par CAN dans AWRKPAR
#########################################################
Subprog MAJAWA(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".ATABDIV" [ADI]
Read [ADI]CODE=908;"CAN"
Close Local File [ADI]
If fstat : End : Endif

# Mise à jour de la table AWRKPAR
Call ECR_TRACE(mess(81,125,1)-"AWRKPAR:"-time$,0) From GESECRAN

Local File =DOSSIER+".AWRKPAR" [AWA]

Trbegin [AWA]
 Update [AWA] Where TYPEVT=1 & CODEVT="ANU" With CODEVT="CAN"
 If fstat
  Call ERREUR("AWKPAR",2) From DOSDIC
 Endif
Commit

Close Local File
End


#########################################################
# Suppression des ~ inutiles dans IDENT2
#########################################################
Subprog MAJAOBJTXT(APPLI)
Value Char APPLI
Local File =APPLI+".ACLOB" [ACB] , =APPLI+".ABLOB" [ABB] , =APPLI+".AOBJTXT" [AOX] , =APPLI+".AOBJTXTA" [AOM]
&        , =APPLI+".ACLOB" [ACB2] , =APPLI+".ABLOB" [ABB2] , =APPLI+".AOBJTXT" [AOX2] , =APPLI+".AOBJTXTA" [AOM2]
&        , =APPLI+".AOBJET" [AOB]
Local Integer I , ER , OK , NBID , TEST , K
Local Char    OBJET(20) , CLEID(50)(1..20) , CHAINE(250) , PREF(10) , NEWKEY(250) , OLDKEY(250) , NUMCAR(10)
TEST = 0
Call ECR_TRACE("Update ACLOB/ABLOB for PJ_ & CO_",0) From GESECRAN

Trbegin [ACB]
 If GTYPDBA=1
  For [ACB]ACB0(1) Where left$(CODBLB,3)="CO_"
   Gosub ACLOB_CO
  Next ACB(1)
 Else
  For [ACB]ACB0(1) Where left$(CODBLB,3)="CO_" With Stability
   Gosub ACLOB_CO
  Next ACB(1)
 Endif
Commit
Trbegin [ACB]
 If GTYPDBA=1
  For [ACB]ACB0(1) Where left$(CODBLB,3)="PJ_"
   Gosub ACLOB_PJ
  Next ACB(1)
 Else
  For [ACB]ACB0(1) Where left$(CODBLB,3)="PJ_" With Stability
   Gosub ACLOB_PJ
  Next ACB(1)
 Endif
Commit
Trbegin [ABB]
 If GTYPDBA=1
  For [ABB]ABB0(1) Where left$(CODBLB,3)="PJ_"
   Gosub ABLOB
  Next ABB(1)
 Else
  For [ABB]ABB0(1) Where left$(CODBLB,3)="PJ_" With Stability
   Gosub ABLOB
  Next ABB(1)
 Endif
Commit
Trbegin [AOX]
 If GTYPDBA=1
  For [AOX]AOX0(1)
   Gosub AOBJTXT
  Next AOX(1)
 Else
  For [AOX]AOX0(1) With Stability
   Gosub AOBJTXT
  Next AOX(1)
 Endif
Commit
Trbegin [AOM]
 If GTYPDBA=1
  For [AOM]AOM0(1)
   Gosub AOBJTXTA
  Next AOM(1)
 Else
  For [AOM]AOM0(1) With Stability
   Gosub AOBJTXTA
  Next AOM(1)
 Endif
Commit
Close Local File
End

$ACLOB_CO
 OBJET = right$([F:ACB]CODBLB,4)
 Look [AOB]ABREV=OBJET
 If fstat
  OK = 0
 Else
  ER = 0
  Onerrgo ER
  Gosub SETCLE From ="WO"+OBJET
  Onerrgo
  OK = !ER
  If OK
   OK *= (CLESEC(0)<>"" or OBJET="MFG")
  Endif
 Endif
 For [ACB]ACB0
  If OK
   OLDKEY = [F:ACB]IDENT2
   CHAINE = OLDKEY
   Gosub SETID
   Gosub SETNEW
   If NEWKEY<>[F:ACB]IDENT2
    If !TEST
     Look [ACB2]ACB0=[F:ACB]CODBLB;[F:ACB]IDENT1;NEWKEY;[F:ACB]IDENT3
     If fstat
      [F:ACB]IDENT2 = NEWKEY
      CHAINE = [F:ACB]NAMBLB
      Gosub VIRE_TILDE
      [F:ACB]NAMBLB = CHAINE
      Rewrite [ACB]
      If fstat
       Call ERREUR("ACB"-[F:ACB]CODBLB-[F:ACB]IDENT1-NEWKEY-[F:ACB]IDENT3,2) From DOSDIC
      Endif
     Else
      Delete [ACB2] Where CODBLB=[F:ACB]CODBLB & IDENT1=[F:ACB]IDENT1 & IDENT2=[F:ACB]IDENT2 & IDENT3=[F:ACB]IDENT3
      If fstat
       Call ERREUR("ACB"-[F:ACB]CODBLB-[F:ACB]IDENT1-[F:ACB]IDENT2-[F:ACB]IDENT3,1) From DOSDIC
      Endif
     Endif
    Endif
    CHAINE = "ACB Old key="+[F:ACB]CODBLB-[F:ACB]IDENT1-OLDKEY-[F:ACB]IDENT3
    CHAINE += " , New key="+[F:ACB]CODBLB-[F:ACB]IDENT1-NEWKEY-[F:ACB]IDENT3
    Call ECR_TRACE(CHAINE,0) From GESECRAN
   Endif
  Endif
 Next ACB
Return

$ACLOB_PJ
 OBJET = right$([F:ACB]CODBLB,4)
 Look [AOB]ABREV=OBJET
 If fstat
  OK = 0
 Else
  ER = 0
  Onerrgo ER
  Gosub SETCLE From ="WO"+OBJET
  Onerrgo
  OK = !ER
  If OK
   OK *= (CLESEC(0)<>"" or OBJET="MFG")
  Endif
 Endif
 For [ACB]ACB0
  If OK
   OLDKEY = [F:ACB]IDENT2
   CHAINE = OLDKEY
   Gosub SETID
   Gosub SETNEW
   If NEWKEY<>[F:ACB]IDENT2
    If !TEST
     Look [ACB2]ACB0=[F:ACB]CODBLB;[F:ACB]IDENT1;NEWKEY;[F:ACB]IDENT3
     If fstat
      [F:ACB]IDENT2 = NEWKEY
      CHAINE = [F:ACB]NAMBLB
      Gosub VIRE_TILDE
      [F:ACB]NAMBLB = CHAINE
      Rewrite [ACB]
      If fstat
       Call ERREUR("ACB"-[F:ACB]CODBLB-[F:ACB]IDENT1-NEWKEY-[F:ACB]IDENT3,2) From DOSDIC
      Endif
     Else
      Delete [ACB2] Where CODBLB=[F:ACB]CODBLB & IDENT1=[F:ACB]IDENT1 & IDENT2=[F:ACB]IDENT2 & IDENT3=[F:ACB]IDENT3
      If fstat
       Call ERREUR("ACB"-[F:ACB]CODBLB-[F:ACB]IDENT1-[F:ACB]IDENT2-[F:ACB]IDENT3,1) From DOSDIC
      Endif
     Endif
    Endif
    CHAINE = "ACB Old key="+[F:ACB]CODBLB-[F:ACB]IDENT1-OLDKEY-[F:ACB]IDENT3
    CHAINE += " , New key="+[F:ACB]CODBLB-[F:ACB]IDENT1-NEWKEY-[F:ACB]IDENT3
    Call ECR_TRACE(CHAINE,0) From GESECRAN
   Endif
  Endif
 Next ACB
Return

$ABLOB
 OBJET = right$([F:ABB]CODBLB,4)
 Look [AOB]ABREV=OBJET
 If fstat
  OK = 0
 Else
  ER = 0
  Onerrgo ER
  Gosub SETCLE From ="WO"+OBJET
  Onerrgo
  OK = !ER
  If OK
   OK *= (CLESEC(0)<>"" or OBJET="MFG")
  Endif
 Endif
 For [ABB]ABB0
  If OK
   OLDKEY = [F:ABB]IDENT2
   CHAINE = OLDKEY
   Gosub SETID
   Gosub SETNEW
   If NEWKEY<>[F:ABB]IDENT2
    If !TEST
     Look [ABB2]ABB0=[F:ABB]CODBLB;[F:ABB]IDENT1;NEWKEY;[F:ABB]IDENT3
     If fstat
      [F:ABB]IDENT2 = NEWKEY
      CHAINE = [F:ABB]NAMBLB
      Gosub VIRE_TILDE
      [F:ABB]NAMBLB = CHAINE
      Rewrite [ABB]
      If fstat
       Call ERREUR("ABB"-[F:ABB]CODBLB-[F:ABB]IDENT1-NEWKEY-[F:ABB]IDENT3,2) From DOSDIC
      Endif
     Else
      Delete [ABB2] Where CODBLB=[F:ABB]CODBLB & IDENT1=[F:ABB]IDENT1 & IDENT2=[F:ABB]IDENT2 & IDENT3=[F:ABB]IDENT3
      If fstat
       Call ERREUR("ABB"-[F:ABB]CODBLB-[F:ABB]IDENT1-[F:ABB]IDENT2-[F:ABB]IDENT3,1) From DOSDIC
      Endif
     Endif
    Endif
    CHAINE = "ABB Old key="+[F:ABB]CODBLB-[F:ABB]IDENT1-OLDKEY-[F:ABB]IDENT3
    CHAINE += " , New key="+[F:ABB]CODBLB-[F:ABB]IDENT1-NEWKEY-[F:ABB]IDENT3
    Call ECR_TRACE(CHAINE,0) From GESECRAN
   Endif
  Endif
 Next ABB
Return

$AOBJTXT
 OBJET = [F:AOX]ABREV
 Look [AOB]ABREV=OBJET
 If fstat
  OK = 0
 Else
  ER = 0
  Onerrgo ER
  Gosub SETCLE From ="WO"+OBJET
  Onerrgo
  OK = !ER
  If OK
   OK *= (CLESEC(0)<>"" or OBJET="MFG")
  Endif
 Endif
 For [AOX]AOX0
  If OK
   OLDKEY = [F:AOX]IDENT2
   CHAINE = OLDKEY
   Gosub SETID
   Gosub SETNEW
   If NEWKEY<>[F:AOX]IDENT2
    If !TEST
     Look [AOX2]AOX0=[F:AOX]ABREV;[F:AOX]IDENT1;NEWKEY;[F:AOX]IDENT3
     If fstat
      [F:AOX]IDENT2 = NEWKEY
      Rewrite [AOX]
      If fstat
       Call ERREUR("AOX"-[F:AOX]ABREV-[F:AOX]IDENT1-NEWKEY-[F:AOX]IDENT3,2) From DOSDIC
      Endif
     Else
      Delete [AOX2] Where ABREV=[F:AOX]ABREV & IDENT1=[F:AOX]IDENT1 & IDENT2=[F:AOX]IDENT2 & IDENT3=[F:AOX]IDENT3
      If fstat
       Call ERREUR("AOX"-[F:AOX]ABREV-[F:AOX]IDENT1-[F:AOX]IDENT2-[F:AOX]IDENT3,1) From DOSDIC
      Endif
     Endif
    Endif
    CHAINE = "AOX Old key="+[F:AOX]ABREV-[F:AOX]IDENT1-OLDKEY-[F:AOX]IDENT3
    CHAINE += " , New key="+[F:AOX]ABREV-[F:AOX]IDENT1-NEWKEY-[F:AOX]IDENT3
    Call ECR_TRACE(CHAINE,0) From GESECRAN
   Endif
  Endif
 Next AOX
Return

$AOBJTXTA
 OBJET = [F:AOM]ABREV
 Look [AOB]ABREV=OBJET
 If fstat
  OK = 0
 Else
  ER = 0
  Onerrgo ER
  Gosub SETCLE From ="WO"+OBJET
  Onerrgo
  OK = !ER
  If OK
   OK *= (CLESEC(0)<>"" or OBJET="MFG")
  Endif
 Endif
 For [AOM]AOM0
  If OK
   OLDKEY = [F:AOM]IDENT2
   CHAINE = OLDKEY
   Gosub SETID
   Gosub SETNEW
   If NEWKEY<>[F:AOM]IDENT2
    If !TEST
     Look [AOM2]AOM0=[F:AOM]ABREV;[F:AOM]IDENT1;NEWKEY;[F:AOM]IDENT3
     If fstat
      [F:AOM]IDENT2 = NEWKEY
      Rewrite [AOM]
      If fstat
       Call ERREUR("AOM"-[F:AOM]ABREV-[F:AOM]IDENT1-NEWKEY-[F:AOM]IDENT3,2) From DOSDIC
      Endif
     Else
      Delete [AOM2] Where ABREV=[F:AOM]ABREV & IDENT1=[F:AOM]IDENT1 & IDENT2=[F:AOM]IDENT2 & IDENT3=[F:AOM]IDENT3
      If fstat
       Call ERREUR("AOM"-[F:AOM]ABREV-[F:AOM]IDENT1-[F:AOM]IDENT2-[F:AOM]IDENT3,1) From DOSDIC
      Endif
     Endif
    Endif
    CHAINE = "AOM Old key="+[F:AOM]ABREV-[F:AOM]IDENT1-OLDKEY-[F:AOM]IDENT3
    CHAINE += " , New key="+[F:AOM]ABREV-[F:AOM]IDENT1-NEWKEY-[F:AOM]IDENT3
    Call ECR_TRACE(CHAINE,0) From GESECRAN
   Endif
  Endif
 Next AOM
Return

$SETID
Raz CLEID , NBID
While CHAINE<>""
 NBID += 1
 I = instr(1,CHAINE,"~")
 If I & NBID<16
  CLEID(NBID) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLEID(NBID) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

$SETNEW
NEWKEY = ""
If sum(CLEID)<>""
 For I=1 To dim(CLESEC)
  If I>1 : NEWKEY += "~" : Endif
  If CLESEC(I-1)<>CLELIG & I<=dim(CLEID)
   NEWKEY += CLEID(I)
  Endif
 Next I
Endif
Return

$ER
ER = errn
Resume

$VIRE_TILDE
While CHAINE<>""
 If right$(CHAINE,len(CHAINE))<>"~"
  Break
 Endif
 CHAINE = left$(CHAINE,len(CHAINE)-1)
Wend
Return

##########################################################################
# Création du paramètre DEMO sur le dossier DEMO (utilisateurs nommés)
##########################################################################
Subprog DEMO(DOSSIER)
Value Char DOSSIER

Local Char    DOSX3(GLONADS) , APPLI(GLONADS) , MACHINE(GLONAMC)
Local Integer OK , ER

Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 DOSX3 = [F:ADW]VALEUR
Endif
Close Local File [ADW]
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If MACHINE="" or DOSX3=""
 Local File ADOSSIER [ADX2]
Else
 Local File =MACHINE+"@"+DOSX3+".ADOSSIER" [ADX2]
Endif
OK = 0
For [ADX2]
 ER = 0
 Onerrgo ER
 If MACHINE<>""
  Local File =MACHINE+"@"+[F:ADX2]DOSSIER+".ADOVAL" [ADW]
 Else
  Local File =[F:ADX2]DOSSIER+".ADOVAL" [ADW]
 Endif
 Look [ADW]ADW0="";"";"ADEMO"
 Onerrgo
 If !ER
  If !fstat : OK = 1 : Endif
  Close Local File [ADW]
  If OK : Break : Endif
 Endif
Next ADX2
If !OK
 For [ADX2] Where pat(DOSSIER,"*DEMO*")
  ER = 0
  Onerrgo ER
  If MACHINE<>""
   Local File =MACHINE+"@"+[F:ADX2]DOSSIER+".ADOVAL" [ADW]
  Else
   Local File =[F:ADX2]DOSSIER+".ADOVAL" [ADW]
  Endif
  If !ER
   Trbegin [ADW]
    Raz [F:ADW]
    [F:ADW]PARAM = "ADEMO"
    [F:ADW]CREUSR = GUSER
    [F:ADW]CREDAT = date$
    If dim([F:ADW]CRETIM)>0 : [F:ADW]CRETIM = time : Endif
    Write [ADW]
    If fstat
     Call ERREUR("ADW ADEMO",1) From DOSDIC
    Endif
   Commit
   Close Local File [ADW]
   If !ER
    Break
   Endif
  Endif
  Onerrgo
 Next ADX2
Endif
Close Local File
End

###########################################################################################################
# Suppression des tables diverses si le paramétrage de la table est inexistant (reliquat 140)
###########################################################################################################

Subprog ANUTABDIV(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".ATABDIV" [ADI], =DOSSIER+".ATABDIV" [ADI2], =DOSSIER+".ATABTAB" [ADV], =DOSSIER+".ATEXTRA" [AXX]
Trbegin [ADI2]
 For [ADI]CODE(1)
  Read [ADV]CODE=[F:ADI]NUMTAB
  If fstat
   Call ECR_TRACE("Delete"-num$([F:ADI]NUMTAB),0) From GESECRAN
   Delete [ADI2] Where NUMTAB=[F:ADI]NUMTAB
   If fstat : Call ERREUR("ATABDIV"-num$([F:ADI]NUMTAB),3) From DOSDIC : Endif
   Delete [AXX] Where CODFIC="ATABDIV" & IDENT1=num$([F:ADI]NUMTAB)
   If fstat : Call ERREUR("ATEXTRA ATABDIV/"+num$([F:ADI]NUMTAB),3) From DOSDIC : Endif
  Endif
 Next ADI
Commit
Close Local File
End

##############################################################################
## Mise à jour table affectation des compteurs pour le superviseur
##############################################################################
Subprog TABCOUAFFSUP(DOSSIER)
Value Char DOSSIER

If DOSSIER=GDOSX3 or GDOSX3="" : End : Endif
Local File =DOSSIER+".TABCOUAFF" [TCA] , =GDOSX3+".TABCOUAFF" [STCA]

Trbegin [TCA]
 Read [TCA]TCA0(1)=1
 If fstat
  Read [STCA]TCA0(1)=1
  If !fstat
   [F:TCA] = [F:STCA]
   Write [TCA]
   If fstat
    Call ERREUR("TABCOUAFF",2) From DOSDIC
   Else
    # Mise à jour de la table TABCOUAFF
    Call ECR_TRACE(mess(81,125,1)-"TABCOUAFF:"-time$,0) From GESECRAN
   Endif
  Endif
 Endif
Commit

Close Local File
End

#################################################
## Init champ TYPUTI de la table ACTION
#################################################
Subprog ACTION_TYPUTI(DOSSIER)
Value Char DOSSIER
Local File =DOSSIER+".ACTION" [ACT]

If dim([F:ACT]TYPUTI)>0
 # Mise à jour de la table ACTION
 Call ECR_TRACE(mess(81,125,1)-"ACTION:"-time$,0) From GESECRAN
 Trbegin [ACT]
  For [ACT]
   OK = 0
   If [F:ACT]TYPUTI=0
    [F:ACT]TYPUTI = 1
    Rewrite [ACT]
    If fstat
     Call ERREUR("ACTION"-[F:ACT]ACTION,2) From DOSDIC
    Endif
   Endif
  Next
 Commit
Endif

Close Local File [ACT]
End

#####################################################################
### Suppression ou deacativation des indexs d'optimisation obsolete
#####################################################################
Subprog AINDEX(DOSSIER)
Value Char DOSSIER
Local File =DOSSIER+".AINDEX"  [ANX]
Local File =DOSSIER+".ATABLE"  [ATB]
Local File =DOSSIER+".ATABZON" [ATZ]

Local Integer NBCLE , I , OK , J
Local Char    CLE(30)(1..50) , ZONE(GLONAVA)

# Mise à jour de la table AINDEX
Call ECR_TRACE(mess(81,125,1)-"AINDEX:"-time$,0) From GESECRAN

Trbegin [ANX]
 For [ANX]ANX1
  OK= 1
  Read [F:ATB]CODFIC = [F:ANX]TABLE
  If !fstat
   Call SETCLE(NBCLE,CLE,[F:ANX]DESCRIPT) From LNKSUB
   For I=1 To NBCLE
    J = instr(1,CLE(I),"(")
    If J
     ZONE = left$(CLE(I),J-1)
    Else
     ZONE = CLE(I)
    Endif
    Read [ATZ]CODZONE = [F:ATB]CODFIC;ZONE
    If fstat
     OK= 0
     Break
    Endif
   Next I
   If !OK & [F:ANX]FLACT=2
    Call ECR_TRACE([F:ANX]TABLE-":"-[F:ANX]CODIND-mess(166,139,1),0) From  GESECRAN
    [F:ANX]FLACT    = 1
    Rewrite [ANX]
    If fstat
     Call ERREUR("AINDEX"-[F:ANX]TABLE-[F:ANX]CODIND,2) From DOSDIC
    Endif
   Endif
  Else
   Call ECR_TRACE([F:ANX]TABLE-":"-[F:ANX]CODIND-mess(53,123,1)-"("+mess(124,124,1)+")",0) From  GESECRAN
   Delete [ANX] Curr
   If fstat
    Call ERREUR("AINDEX"-[F:ANX]TABLE-[F:ANX]CODIND,3) From DOSDIC
   Endif
  Endif
 Next
Commit

Close Local File [ANX], [ATB] , [ATZ]
End

##############################################################################
## Mise à jour table intitulé traduisibles sur table des codes d'accès
##############################################################################

Subprog ACCCOD(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".ACCCOD"    [ACS]
Local File =DOSSIER+".ATEXTRA"   [AXX]

If dim([F:ACS]INTACC)<0
 Close Local File [ACS],[AXX]
 End
Endif

# Mise à jour de la table ACCCOD
Call ECR_TRACE(mess(81,125,1)-"ACCCOD:"-time$,0) From GESECRAN
Trbegin [ACS]
 For [ACS]ACS0
  If [F:ACS]INTACC<>""
   Call MAJTEXTRA([F:ACS]INTACC,"ACCCOD","DESACC",[F:ACS]CODACC,"") From ATEXTRA
   [F:ACS]INTACC = ""
   Rewrite [ACS]
  Endif
 Next
Commit

Close Local File [ACS],[AXX]
End


