##############################################
# Copie d'un style
##############################################
Subprog MAJASY(DOSREF,DOSVAL)
Value Char DOSREF,DOSVAL

Local File =DOSVAL+".ASTYLE" [ASY] , =DOSREF+".ASTYLE" [ASYR]

Local Integer MAXLIG

# Mise à jour de la table AREPORTX (code impression)
Call ECR_TRACE(mess(81,125,1)-"ASTYLE :"-time$,0) From GESECRAN

Trbegin [ASY]
 For [ASYR]ASY0
  Read [ASY]ASY0=[ASYR]COD
  If fstat
   MAXLIG = 0
   For [ASY]ASY0
    If [ASY]LIG > MAXLIG
     MAXLIG = [F:ASY]LIG
    Endif
   Next ASY
   MAXLIG +=1
   Raz [F:ASY]
   [F:ASY] = [F:ASYR]
   [F:ASY]LIG = MAXLIG
   [F:ASY]CREDAT = date$
   [F:ASY]CREUSR = GUSER
   If dim([F:ASY]CRETIM)>0 : [F:ASY]CRETIM = time  : Endif
   Write [ASY]
   If fstat : Call ERREUR("ASTYLE",1) From DOSDIC : Endif
  Endif
 Next
Commit

Close Local File [ASYR] , [ASY]
End


