#<AdxTL>@(#)1.0.0.0 $Revision$
#CHECK MIGRATE_SOURCE
Local Char DOSVAL(GLONADS) , DOSREF(GLONADS) , DOSCOP(GLONADS)
#X3-76171
If dim(GMAXSPEACV)>=0 & GMAXSPEACV>0
  Global Char    GSPE(GLONACV)(1..GMAXSPEACV)
Else
  Global Char    GSPE(GLONACV)(1..300)
Endif
#X3-76171
Global Integer GNBSPE
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "TEST2"
If fstat : End : Endif
DOSVAL = [F:ADS]DOSSIER
DOSREF  = [F:ADS]DOSREF
DOSCOP  = [F:ADS]DOSCOP
Local File ADOSACT [ADA]
GNBSPE = 0
For [ADA]ADA0 Where [F]DOSSIER=[L]DOSVAL & CODACT>="X"
 GNBSPE += 1
 GSPE(GNBSPE) = [F:ADA]CODACT
Next ADA
Close Local File [ADA]
Call OUVRE_TRACE("") From LECFIC
Call SUP_ASEND(DOSVAL)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

######################################################################
Subprog MAJDIC
Local Integer I , J , K , OK , OKCOP , DETAIL , OUVFIC , EXISTE
Local Char    X3(20) , OBJET(15), APPLI(15) , MESSA(80)
Local Char    TABSPE(GLONATB)(1..100), TABACTS(GLONACV)(1..300)
Local Integer NBSPE , NBACTS , NBFLD , DIME , VERCUR

VERCUR = 160
DETAIL = 0
APPLI = [F:ADS]DOSSIER

If val(DOSVERS)<25 & func DOSSUB.ISHISTFOLD(APPLI)=0 : End : Endif : # C'est que la mise à jour 25 a déjà été faite

#107271
If func DOSVUE.ISVIEW(APPLI,"ATYPE")=0
 MESSA = "Update Data Types"
 If GINFO
  Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
 Endif
 Call MAJ_ATYATY
 Call ECR_TRACE(MESSA,0) From GESECRAN
 Gosub DOSMAJATY From DOSMAJATY
Endif

#107271
If func DOSVUE.ISVIEW(APPLI,"ACTIV")=0
 MESSA = "Update Activity Codes"
 If GINFO
  Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
 Endif
 Call ECR_TRACE(MESSA,0) From GESECRAN
 Gosub DOSMAJACV From DOSMAJACV
Endif

#107271
If func DOSVUE.ISVIEW(APPLI,"ATABLE")=0
 MESSA = "Update tables"
 If GINFO
  Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
 Endif
 Call ECR_TRACE(MESSA,0) From GESECRAN
 If func DOSSUB.ISHISTFOLD(APPLI)=0
  Gosub DOSMAJATB From DOSMAJATB
 Else
  Gosub DOSMAJATBHIS From DOSMAJATB
 Endif
Endif

# Pour forcer la validation des vues parce que l'intégration d'une sauvegarde
# d'un dossier d'une version différente de la version courante ne revalide pas les vues

MESSA = "Update views"
If GINFO
 Call AFF_VLC("Dictionnary",MESSA) From GESECRAN
Endif
Call ECR_TRACE(MESSA,0) From GESECRAN
If dim(GVALIDE)>=11
 GVALIDE(11) = 1
Endif
End

####################################################################################
##  Mise a jour type de données ATY
####################################################################################

Subprog MAJ_ATYATY

Local File =[F:ADS]DOSREF+".ATYPE"     [SATY]
Local File =[F:ADS]DOSSIER+".ATYPE"    [ATY]

Local Char    TABLE(30)
Local Integer OK

OK = 0
Read [SATY]CODTYP = "ATY"
If !fstat
 Read [ATY]CODTYP = "ATY"
 If !fstat & [F:ATY]LNGTYP>0 & [F:ATY]LNGTYP<[F:SATY]LNGTYP
    OK = 1
    Trbegin [ATY]
        [F:ATY]LNGTYP=[F:SATY]LNGTYP
        Rewrite [F:ATY]
        If fstat
          GOK = 0 : Call FSTA("ATY") From GLOCK : Goto AB_TR1
        Endif
    Commit
 Endif
Endif

Read [SATY]CODTYP = "ABR"
If !fstat
 Read [ATY]CODTYP = "ABR"
 If !fstat & [F:ATY]LNGTYP>0 & [F:ATY]LNGTYP<[F:SATY]LNGTYP
    OK = 1
    Trbegin [ATY]
        [F:ATY]LNGTYP=[F:SATY]LNGTYP
        Rewrite [F:ATY]
        If fstat
          GOK = 0 : Call FSTA("ATY") From GLOCK : Goto AB_TR1
        Endif
    Commit
 Endif
Endif
Close Local File [SATY]
Close Local File [ATY]

Local File =[F:ADS]DOSSIER+".ATABZON"  [ATZ]
Read [ATZ]CODZONE="ATABLE";"ABRFIC"
If !fstat & [F:ATZ]CODTYP="A"
 If [F:ATZ]LONG<8
    OK = 1
    Trbegin [ATZ]
        [F:ATZ]CODTYP="ABR"
        Raz [F:ATZ]LONG
        Rewrite [F:ATZ]
        If fstat
          GOK = 0 : Call FSTA("ATZ") From GLOCK : Goto AB_TR1
        Endif
    Commit
 Endif
Endif
Close Local File [ATZ]

If OK
 Local File =[F:ADS]DOSSIER+".ATABLE"   [ATB]
 Local File =[F:ADS]DOSSIER+".ATABZON"  [ATZ]
 Local File =[F:ADS]DOSSIER+".ATABIND"  [ATI]
 Local File =[F:ADS]DOSSIER+".AINDEX"   [ANX]
 Local File =[F:ADS]DOSSIER+".AMSKPAR"  [AMP]
 Local File =[F:ADS]DOSSIER+".ATYPE"    [ATY]
 Local File =[F:ADS]DOSSIER+".ATEXTE"   [ATX]
 Local File =[F:ADS]DOSSIER+".ACTIV"    [ACV]
 For TABLE="ATYPE","ATABZON","AMSKZON","ATABLE"
  Call MAJTAB(TABLE,0) From DOSTAB
 Next TABLE
 Close Local File [ATB] , [ATZ] , [ATI] , [ANX] , [AMP] , [ATY] , [ATX] , [ACV]
 Local File =[F:ADS]DOSSIER+".ATYPE"    [ATY]
 Local File =[F:ADS]DOSREF+".ATYPE"     [SATY]
 Trbegin [ATY]
  For TABLE="AUUID","ADATIM"
   Read [SATY]CODTYP=TABLE
   If !fstat
    Read [ATY]CODTYP=TABLE
    If fstat
     [F:ATY] = [F:SATY]
     Write [ATY]
     If fstat
      GOK = 0 : Call FSTA("ATY") From GLOCK : Goto AB_TR1
     Endif
    Endif
   Endif
  Next TABLE
 Commit
 Close Local File [ATY] , [SATY]
 Call ECR_TRACE("Update data type ATY",0) From GESECRAN
Endif

End

$AB_TR1
Rollback
Return
######################################################################
Subprog AMAJ
#107271
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER) : End : Endif

Local Char DOSVAL(GLONADS) , DOSREF(GLONADS) , DOSCOP(GLONADS)
DOSVAL = [F:ADS]DOSSIER
DOSREF = [F:ADS]DOSREF
DOSCOP = [F:ADS]DOSCOP

Call EPURMSKFEN(DOSVAL) : # Epuration des écrans et fenêtres générées W*
For I=1 To len(mess(0,14,1))
 GVALTRANS(I) = 2
Next I

Gosub AMAJSUP
Read [ADS]DOSSIER Curr
End

##################################
$AMAJSUP
If GINFO
 Call AFF_VLC(mess(93,125,1),"Update Supervisor") From GESECRAN
Endif
Call ARCHIVEADX(DOSVAL)                : # Génération de l'archive v6
Call AVOCAB(DOSVAL)                    : # Mise à jour des nouveaux champs
Call ADOSSOL(DOSVAL)                   : # Mise à jour table des liens solutions
Call MAJABD(DOSVAL)                    : # Mise a jour tables abonnements Batch
Call MAJRQT(DOSVAL)                    : # Mise a jour tables requetes Batch
Call MAJPARECR(DOSVAL,"VCR","VCROBJ",'""')  : # Mise à jour new paramètre VCROBJ sur type de données VCR
Call MAJPARECR(DOSVAL,"VCR","OBJZON",'""')  : # Mise à jour new paramètre OBJZON sur type de données VCR
Call MAJPARECR(DOSVAL,"FIC","AFICCLI",'""') : # Mise à jour new paramètre AFICCLI sur type de données FIC
Call MAJGRA(DOSVAL)                    : # Mise a jour table ALISTED , champ GRA et REP
Call MAJAFC(DOSVAL)                    : # Init du champ NAVIG
Call MAJAOR(DOSVAL)                    : # Mise a jour champ DES  dans champ INTIT de type AXX de la table AOBJEXTR
Call MAJABZ(DOSVAL)                    : # Mise à jour des champ des liens en type "technique"
Call ACTION(DOSVAL)                    : # Mise à jour nouveau champ dans la table ACTION
Call AOBJLST(DOSVAL,DOSREF)            : # Mise à jour forcée de l'onglet sélection des objets et des champs RPT1 RPT2 et STA
Call MAJLNGADI(DOSVAL)                 : # Rajout longueur taille diverse si le paramètre ADI contient une variable ou mal initialisé
Call DOSLEG(DOSVAL)                    : # Intitialisation du tableau des legislation avec la legisaltion / pays par defaut
Call TABFOR(DOSVAL)                    : # Initialisation nouveaux champs AXX
Call DESAMI(DOSVAL)                    : # Mise a jour champ DES et DESSHO  dans champ INTIT et INTITSHO de type AXX
Call ACTL(DOSVAL)                      : # Saisie d'une formule dans les messages + Intitulé traduisible
Call AMSKZONADJ(DOSVAL)                : # Remplacement du type de données ADJ par ADI pour éviter des erreurs de validation
Call MAJOPTJNT(DOSVAL)                 : # Initialisation champ optiion de jointure dans les champs des dimensions
Call MAJABM(DOSVAL)                    : # Initialisation champ ANSI et mesure dans les datamarts
Call MAJABI(DOSVAL)                    : # Init zone SUPVID 0--> 1
Call MAJAPLINI(DOSVAL)                 : # Mise à jour maxmem à 30
Call COMPANY(DOSVAL)                   : # Mise à jour législation dans la table COMPANY
Call MAJASY(DOSREF,DOSVAL)             : # Mise à jour des nouveaux styles V6
Call INTUSR(DOSVAL)                    : # Initialisation nouveaux champs AXX  INTUSR
Call INTFONCT(DOSVAL)                  : # Initialisation nouveaux champs AXX  INTPRF
Call INTPROFIL(DOSVAL)                 : # Initialisation nouveaux champs AXX  INTPRF
Call INTMET(DOSVAL)                    : # Initialisation nouveaux champs AXX  INTMET
Call INTSURBI(DOSVAL)                  : # Initialisation champ impression liée
Call IMPLIE(DOSVAL)                    : # Maj champ IMPLIE dans AREPORT ( impression liés)
Call MAJDICTRT(DOSVAL)                 : # Maj clob Texte du dico des traitements
Call PARSTALIG(DOSVAL)                 : # Intitulé traduisible
Call INTAOP(DOSVAL)                    : # Intitulé traduisible AOBJPROP
Call AMEMO(DOSVAL,DOSREF)              : # Liste des codes mémos non protégés par un code activité
Call AMSKPAR(DOSVAL)                   : # Mise à jour du paramètre ETAT sur un champ code postal
Call NBOPTAFC(DOSVAL)                  : # Mise à jour champ NBOPT suite passage de 20 --> 19 des options
Call ASUBPROG(DOSVAL)                  : # Mise à jour nouveau champ TYPASU
Call AOBJBURMOD(DOSVAL)                : # Mise à jour législation dans la table AOBJBURMOD
Call FACILITY(DOSVAL)                  : # Mise à jour législation dans la table FACILITY
Call ADOCFLD(DOSVAL)                   : # Mise à jour champ GEN de la table ADOCFLD
Call INTAEV(DOSVAL)                    : # Initialisation nouveaux champs AXX  INTAEV
Call ATABDIV(DOSVAL,DOSREF,DOSCOP,51)  : # Mise à jour table diverses 51 (workflow)
Call ATABDIV(DOSVAL,DOSREF,DOSCOP,54)  : # Mise à jour table diverses 54 (workflow)
Call ATABDIV(DOSVAL,DOSREF,DOSCOP,55)  : # Mise à jour table diverses 55 (workflow)
Call MAJCOLLIN(DOSVAL,DOSREF)          : # Mise à jour NBRCOL et NBRLIG sur les écrans standard
Call MAJAOBJTXT(DOSVAL)                : # Suppression des ~ inutiles dans IDENT2
Call DEMO(DOSVAL)                      : # Création du paramètre DEMO sur le dossier DEMO (utilisateurs nommés)
Call ANUTABDIV(DOSVAL)                 : # Suppression des tables diverses si le paramétrage de la table est inexistant (reliquat 140)
Call TABCOUAFFSUP(DOSVAL)              : # Mise à jour table affectation des compteurs pour le superviseur
Call ACTION_TYPUTI(DOSVAL)             : # Init champ TYPUTI de la table ACTION
Call AINDEX(DOSVAL)                    : # Suppression ou deacativation des indexs d'optimisation obsolete
Call ACCCOD(DOSVAL)                    : # Mise à jour table intitulé traduisibles sur table des codes d'accès
Call SUP_ASEND(DOSVAL)                 : # Suppression de la table ASEND
Call CHGAPROCTEXT(DOSVAL)              : # Mise à jour de la table APROCTEXTE Bug 71166    CC - 27/02/2012
If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
Return

