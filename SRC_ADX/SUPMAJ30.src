###############################################################
# Liste des codes mémos non protégés par un code activité
###############################################################
Subprog AMEMO(DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF
Local Integer SPEC
Local Char WINTIT(GLONDES)

Local File =DOSSIER+".AMEMO" [AMM] , =DOSREF+".AMEMO" [AM2]

For [AMM]
 Read [AM2]AMM0=[F:AMM]MEMO
 If fstat
  Call SPEC([F:AMM]CODACT,SPEC) From DOSSUB
  If !SPEC
   Call TEXTE([F:AMM]DES,WINTIT) From OBJDIV
   Call ECR_TRACE("Deleted MEMO cod"-[F:AMM]MEMO-"("+WINTIT+") on"-[AMM]WIN,0) From GESECRAN
  Endif
 Endif
Next AMM

Close Local File

End

###########################################################################
# Mise à jour du paramètres ETAT et COMMUNE sur un champ code postal
###########################################################################
Subprog AMSKPAR(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AMSKPAR" [AMP] , =DOSSIER+".AMSKACT" [AMA]
&        , =DOSSIER+".AMSKZON" [AMZ] , =DOSSIER+".ATYPE" [ATY]

Local Char    CHAINE(250) , TBTYP(GLONATY)(1..20) , TBACT(GLONACT)(1..30)
Local Integer I , NBTYP , NBACT

Call ECR_TRACE("Insert parameter cod ETAT & COMMUNE",0) From GESECRAN

NBACT = 0
For CHAINE="ATUNPOS","CPCONT","SELCTY","SELCTY2","SELPOS","VILCONT"
 NBACT += 1 : TBACT(NBACT) = CHAINE
Next CHAINE

# Rajout paramètre ETAT dans les écrans
Gosub CHERCHE_ACT
CHAINE = "ETAT" : Gosub MAJPAR

NBACT = 0
For CHAINE="ATUNPOS","SELPOS"
 NBACT += 1 : TBACT(NBACT) = CHAINE
Next CHAINE

# Rajout paramètre COMMUNE dans les écrans
Gosub CHERCHE_ACT
CHAINE = "COMMUNE" : Gosub MAJPAR

Close Local File

End

################
$CHERCHE_ACT
NBTYP = 0
For [ATY]
 For I=1 To dim([F:ATY]ACTION)
  If find([F:ATY]ACTION(I-1),TBACT(1..NBACT))
   If !find([F:ATY]CODTYP,TBTYP(1..NBTYP))
    NBTYP += 1 : TBTYP(NBTYP) = [F:ATY]CODTYP : Break
   Endif
  Endif
 Next I
Next ATY
Return

################
$MAJPAR
Trbegin [AMP]
 For [AMA] Where find([F:AMA]ACTION,TBACT(1..NBACT))<>0
  Look [AMP]CODPAR=1;[F:AMA]CODAFF;[F:AMA]CODZON;CHAINE
  If fstat
   Raz [F:AMP]
   [F:AMP]TYPAFF = 1
   [F:AMP]CODAFF = [F:AMA]CODAFF
   [F:AMP]CODZON = [F:AMA]CODZON
   [F:AMP]CODPAR = CHAINE
   [F:AMP]VALPAR = '""'
   Write [AMP]
   If fstat
    Call ERREUR("AMSKPAR"-[F:AMA]CODAFF-[F:AMA]CODZON,2) From DOSDIC
   Endif
  Endif
 Next AMA
 For [AMZ] Where find([F:AMZ]CODTYP,TBTYP(1..NBTYP))<>0
  Look [AMP]CODPAR=1;[F:AMZ]CODMSK;[F:AMZ]CODZON;CHAINE
  If fstat
   Raz [F:AMP]
   [F:AMP]TYPAFF = 1
   [F:AMP]CODAFF = [F:AMZ]CODMSK
   [F:AMP]CODZON = [F:AMZ]CODZON
   [F:AMP]CODPAR = CHAINE
   [F:AMP]VALPAR = '""'
   Write [AMP]
   If fstat
    Call ERREUR("AMSKPAR"-[F:AMA]CODAFF-[F:AMA]CODZON,2) From DOSDIC
   Endif
  Endif
 Next AMZ
Commit
Return


###################################################
# Maj champ nbopt suite passage de 20---> 19 options
###################################################
Subprog NBOPTAFC(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AFONCTION"    [AFC]

# Mise à jour de la table AFONCTION
Call ECR_TRACE(mess(81,125,1)-"AFONCTION:"-time$,0) From GESECRAN
Trbegin [AFC]
 For [AFC] Where NBOPT=20
  [F:AFC]NBOPT = 19
  Rewrite [F:AFC]
  If fstat
   Call ERREUR("AFONCTION"-[F:AFC]CODINT,2) From DOSDIC
  Endif
 Next
Commit

Close Local File [AFC]
End

#################################################
# MISE à jour nouveau champ TYPASU
#################################################
Subprog ASUBPROG(DOSSIER)
Value Char DOSSIER
Local File =DOSSIER+".ASUBPROG" [ASU]
Local Integer OK

# Mise à jour de la table ASUBPROG
Call ECR_TRACE(mess(81,125,1)-"ASUBPROG:"-time$,0) From GESECRAN
Trbegin [ASU]
 For [ASU]
  OK = 0
  If [F:ASU]TYPASU=0
   [F:ASU]TYPASU = 1 : OK = 1
  Endif
  If [F:ASU]TYPFCT=0 & [F:ASU]FONCTION=2
   [F:ASU]TYPFCT = 1 : OK = 1
  Endif
  If OK
   Rewrite [ASU]
   If fstat
    Call ERREUR("ASUBPROG"-[F:ASU]PRG-[F:ASU]SUBPRG,2) From DOSDIC
   Endif
  Endif
 Next
Commit

Close Local File [ASU]
End

