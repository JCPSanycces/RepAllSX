####################################################################################
## Rajout des nouveaux compteurs dans la table "Affectation des compteurs"
####################################################################################
Subprog TABCOUAFF(DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF

# Mise à jour de la table TABCOUAFF
Call ECR_TRACE(mess(81,125,1)-"TABCOUAFF:"-time$,0) From GESECRAN

Local File =DOSREF+".TABCOUAFF"  [TCA]
Local File =DOSSIER+".TABCOUAFF" [DTCA]
Local File =DOSSIER+".ACODNUM"   [DANM]

Local Integer I , OKMODIF

Trbegin [DTCA]
 For [TCA]TCA0(1)
  Read [DTCA]TCA0(1)=[F:TCA]MODULE
  If fstat
   [F:DTCA] = [F:TCA]
   [F:DTCA]CREDAT = date$
   [F:DTCA]CREUSR = GUSER
   If dim([F:DTCA]CRETIM)>0 : [F:DTCA]CRETIM = time : Endif
   Write [DTCA]
   If fstat : Call ERREUR("TABCOUAFF"-num$([F:DTCA]MODULE)-[F:DTCA]CPY,2) From DOSDIC : Endif
  Else
   For [DTCA]TCA0 Where [F:DTCA]MODULE=[F:TCA]MODULE
    OKMODIF = 0
    For I=0 To min(dim([F:TCA]CODNUM)-1,dim([F:DTCA]CODNUM)-1)
     If [F:TCA]CODNUM(I)<>"" & [F:DTCA]CODNUM(I)=""
      Look [DANM]ANM0=[F:TCA]CODNUM(I)
      If !fstat
       [F:DTCA]CODNUM(I) = [F:TCA]CODNUM(I)
       [F:DTCA]MANCOU(I) = [F:TCA]MANCOU(I)
       OKMODIF = 1
      Endif
     Endif
    Next I
    If OKMODIF
     [F:DTCA]UPDDAT = date$
     [F:DTCA]UPDUSR = GUSER
     If dim([F:DTCA]UPDTIM)>0 : [F:DTCA]UPDTIM = time : Endif
     Rewrite [DTCA]
     If fstat : Call ERREUR("TABCOUAFF"-num$([F:DTCA]MODULE)-[F:DTCA]CPY,2) From DOSDIC : Endif
    Endif
   Next DTCA
  Endif
 Next TCA(1)
Commit

Close Local File [TCA] , [DTCA] , [DANM]
End

####################################################################################
## Chargement de la table APROCTEXTE en migration
####################################################################################
Subprog CHGAPROCTEXT(DOSSIER)
Value Char DOSSIER

# Mise à jour de la table APROCTEXTE
Call ECR_TRACE(mess(81,125,1)-"APROCTEXTE:"-time$,0) From GESECRAN

Local File =DOSSIER+".APROCESSUS" [APR]
Local File =DOSSIER+".APROCTEXTE" [AXP]

Local Clbfile CLBPR(10)
Local Integer ERR
Local Clbfile CLBF(5)
Local Char LANGORI

For [APR]
  CLBPR=[F:APR]CLOB
  LANGORI=[F:APR]LANGDESC
  If LANGORI="" : LANGORI=GLANGUE : Endif
  Call ECR_TRACE(mess(88,134,1)-[F:APR]CODPRO,0) From GESECRAN : # Processus xxxx
  Gosub TRLPROC
Next
End

$TRLPROC
ERR=0
Gosub RECHTXT
If ERR<>0 : Return : Endif
# Mise jour table des textes
Local Integer TFLAG(1..500)
Local Integer MAJEC
If adxlog=0 : MAJEC=1 : Trbegin [AXP] : Endif
Local Char ABFIC : ABFIC="AXP"
Filter [AXP] Where CODPRO=[F:APR]CODPRO and CODLEG=[F:APR]CODLEG and LANG=LANGORI
For [AXP]
 IND=find([F:AXP]UNIQIDP,UNIQUEID(1..ITXT))
 If IND=0
   Delete [AXP]
 Else
   TFLAG(IND)=1
   CLBF=mid$(CLBPR,TDEB(IND),TFIN(IND)-TDEB(IND)+1)
   If CLBF<>[F:AXP]CLBTEXT
     [F:AXP]CLBTEXT=CLBF
     Gosub INIMOD From GOBJSUB
     Rewrite [AXP]
   Endif
 Endif
Next
Filter [AXP]
For I=1 To ITXT
  If TFLAG(I)=0
    [F:AXP]CODPRO=[F:APR]CODPRO
    [F:AXP]CODLEG=[F:APR]CODLEG
    [F:AXP]UNIQIDP=UNIQUEID(I)
    [F:AXP]LANG=GLANGUE
    [F:AXP]CLBTEXT=mid$(CLBPR,TDEB(I),TFIN(I)-TDEB(I)+1)
    Gosub INICRE From GOBJSUB
    Write [AXP]
  Endif
Next I
If MAJEC=1 : Commit : Endif
Return

$RECHTXT
Local Integer DEB,DEBUN,DEBU1,FIN,FINP,FINUN,ITXT,IUNIQ,IND,TDEB(1..500),TFIN(1..500)
Local Char UNIQUEID(30)(1..500),UNIQ1
DEB=1
While DEB<>0
 DEB=instr(DEB,CLBPR,'"xtext":"<TEXTFORMAT')
#            ----   Nouvel algorithme : on cherche uniqueid qui suit et ensuite on revient en arriere
#                                       pour chercher soit </TEXTFORMAT>" soit </P>"
 If DEB<>0
   DEBUN=instr(DEB,CLBPR,'uniqueID":')
   FIN=0 : FINP=0
   If DEBUN<>0
     FIN=instr(DEB+1,CLBPR,'</TEXTFORMAT>"')
     If FIN=0 or FIN>DEBUN
       FINP=1
       FIN=instr(DEB+1,CLBPR,'</P>"')
     Endif
     If FIN>DEBUN : FIN=0 : Endif
   Endif
   If FIN<>0
     ITXT+=1
     TDEB(ITXT)=DEB+9
     If FINP=0
       TFIN(ITXT)=FIN+12
     Else
       TFIN(ITXT)=FIN+3
     Endif
     FINUN=instr(DEBUN,CLBPR,'"}')
     UNIQUEID(ITXT)=mid$(CLBPR,DEBUN+11,FINUN-DEBUN-11)
   Endif
   DEB=DEBUN
 Endif
Wend
Return

##############################################################################################
# Suppression de la table ASEND
##############################################################################################
Subprog SUP_ASEND(DOSSIER)
Value Char DOSSIER
Local File =DOSSIER+".ATABLE"  [ATB]
Local File =DOSSIER+".ATABIND" [ATI]
Local File =DOSSIER+".ATABZON" [ATZ]
Local File =DOSSIER+".AMSKPAR" [AMP]
Call EFFACE("ASEND",DOSSIER)
Close Local File
End

Subprog EFFACE(TABLE,DOSSIER)
Value Char TABLE,DOSSIER
Local Integer STAT
Local Char    SUF(10) , FICTRT(GDIMFIC) , HISAPL(GLONADS) , APPLI(GLONADS)
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If [F:ADS]DOSSIER<>[L]DOSSIER
 Read [ADS]DOSSIER=[L]DOSSIER
Endif
APPLI = [F:ADS]DOSSIER
HISAPL = [F:ADS]DOSHIS
Call ECR_TRACE(mess(53,125,1)-TABLE,0) From GESECRAN
Call SUPP_TRT("ZZINI"+TABLE) From DOSSUB
Delete [ATI] Where CODFIC=TABLE
If fstat=1 : Call ERREUR("ATABIND"-TABLE,3) From DOSDIC : Endif
Delete [ATZ] Where CODFIC=TABLE
If fstat=1 : Call ERREUR("ATABZON"-TABLE,3) From DOSDIC : Endif
Delete [AMP] Where TYPAFF=2 & CODAFF=TABLE
If fstat=1 : Call ERREUR("AMSKPAR"-TABLE,3) From DOSDIC : Endif
Delete [ATB] Where CODFIC=TABLE
If fstat=1 : Call ERREUR("ATABLE"-TABLE,3)  From DOSDIC : Endif
If filinfo(filpath("FIL",TABLE,"fde",APPLI),0)>0
 Call SYSTEME(adxmac(0),"valfil -n"-APPLI-TABLE,"",STAT) From ORDSYS
 Call SYSTEME(adxmac(0),"valfil -d"-APPLI-TABLE,"",STAT) From ORDSYS
 For SUF = "srf", "fde", "dat", "idx" , "cfg"
  FICTRT = filpath("FIL",TABLE,SUF,APPLI)
  If filinfo(FICTRT,0)>=0
   Call EFFACE(FICTRT,STAT) From ORDSYS
  Endif
 Next SUF
 If HISAPL<>"" & filinfo(filpath("FIL",TABLE,"fde",HISAPL),0)>0
  Call SYSTEME(adxmac(0),"valfil -n"-HISAPL-TABLE,"",STAT) From ORDSYS
  Call SYSTEME(adxmac(0),"valfil -d"-HISAPL-TABLE,"",STAT) From ORDSYS
  For SUF = "srf", "fde", "viw" , "dat" , "idx" , "cfg"
   FICTRT = filpath("FIL",TABLE,SUF,HISAPL)
   If filinfo(FICTRT,0)>=0
    Call EFFACE(FICTRT,STAT) From ORDSYS
   Endif
  Next SUF
 Endif
Endif
End

