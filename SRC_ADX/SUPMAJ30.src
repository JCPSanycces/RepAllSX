###################################################
# Maj texte clob du dico des traitements
###################################################
Subprog MAJDICTRT(DOSSIER)
Value Char DOSSIER

Local Integer I
Local Char    DOSX3(GLONADS) , APPLI(GLONADS) , MACHINE(GLONAMC)
Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 DOSX3 = [F:ADW]VALEUR
Endif
Close Local File [ADW]
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If APPLI<>DOSX3 : End : Endif

Local File =DOSSIER+".ADICTRT" [ADC]

If dim([F:ADC]COM)>0
 # Mise à jour de la table
 Call ECR_TRACE(mess(81,125,1)-"ADICTRT:"-time$,0) From GESECRAN
 Trbegin [ADC]
  For [ADC]ADC0
   Raz [F:ADC]TEXTE
   For I=0 To dim([F:ADC]COM)-1
    If [F:ADC]COM(I)<>""
     If I>0 : Append [F:ADC]TEXTE," " : Endif
     Append [F:ADC]TEXTE,[F:ADC]COM(I)
    Endif
   Next I
   Rewrite [ADC]
   If fstat
    Call ERREUR("ADICTRT"-[F:ARP]CODTRT,2) From DOSDIC
   Endif
  Next
 Commit
Endif

Close Local File [ADC]
End

