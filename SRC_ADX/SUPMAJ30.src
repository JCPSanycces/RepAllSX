# Mise à jour des champs SUPVID dans les dimensions
#########################################################################################
Subprog MAJABI(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","ABIDIM","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS(DOSSIER,"ABI") : End : Endif

