#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# PJMACTBUD
##########################################################################################################
# dbgmode = 1 : dbgaff
# We are in an action mandatory called from OPJM object
# So, globale instance GZINSPJM is mandatory existing too.
# But to be sure, It's possible to check it in $OUVRE action (**1**)
##########################################################################################################
##########################################################################################################
# Issue X3-7285/119926 - 2016-11-21 ALMON   : Begin Changed Process drivers from LM Codes to Numbers     #
##########################################################################################################
$ACTION

  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    When "OK"                          : Gosub OK_BUTTON
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If dim(GZINSPJM) <= 0 Then
    GMESSAGE = mess(186,123,1)
    FIN = 0
  Endif
  # -----------------------------
  NAVIG = GACTION
  # -----------------------------
Return

##########################################################################################################
$DEBUT
#Dbgaff
Local Char STUNBUD(GLONPBU)  # Contain the budget given by parameter
Local Char STUNOPP(GLONPIM)  # Contain the Project given by parameter

  Raz STUNOPP
  If PARAM(1) <> "" Then
    STUNOPP = PARAM(1)
  Endif

  Raz STUNBUD
  If PARAM(2) <> "" Then
    STUNBUD = PARAM(2)
  Endif
  Gosub LOAD_GRID
Return

##########################################################################################################
##########################################################################################################
# Processing
##########################################################################################################
$LOAD_GRID
Local Integer ISHOWLINE
Local Integer WRKMSGNO
Local Integer GRDSUB
Local Char    MESSAGE(250)
Local Char    MESCOD(250)

  Effzo [M:PJBU9]1-99

  # -------------------------------------------------------
  If STUNOPP = STUNBUD
    STUNBUD = ""
  Endif
  [M:PJBU9]OPPNUM = STUNOPP
  [M:PJBU9]PBUCOD = STUNBUD
  # -------------------------------------------------------
  WRKMSGNO = 1
  GRDSUB = 0
  MESCOD = mess (0,7716,1)
  MESSAGE = mess(WRKMSGNO,7716,1)
  While MESSAGE <> ""
    If MESSAGE <> ""
      ##########################################################################################################
      # Issue X3-7285/119926 - 2016-11-21 ALMON   : Begin Changed Process drivers from LM Codes to Numbers     #
      #                                                   PRCCOD becomes Redundant use WRKMSGNO to populate    #
      #                                                   [M:PJBU9]LMCOD(GRDSUB)                               #
      ##########################################################################################################
      # Issue X3-26714 - 2017-03-10 by ALMON : Include Products Option
      #If WRKMSGNO <> 2 # "P" Exclude Products
        [M:PJBU9]LMCOD(GRDSUB) = WRKMSGNO # PRCCOD
        [M:PJBU9]LANMES(GRDSUB) = MESSAGE
        [M:PJBU9]PAANS(GRDSUB) = 1
        If [M:PJBU9]LMCOD(GRDSUB) = 1 #"A"  BUDGET At PROJECT Level IE ALL Budget Codes
              [M:PJBU9]PAANS(GRDSUB) = [V]CST_AYES
        # Issue X3-26714 - 2017-03-10 by ALMON : Include Products Option
        Elsif [M:PJBU9]LMCOD(GRDSUB) = 2  #"P" BUDGET At Product Level
              [M:PJBU9]PAANS(GRDSUB) = [V]CST_AYES
        Elsif [M:PJBU9]LMCOD(GRDSUB) = 3  #"O" BUDGET At Operation Level
              [M:PJBU9]PAANS(GRDSUB) = [V]CST_AYES
        Elsif [M:PJBU9]LMCOD(GRDSUB) = 4 #"E" BUDGET Overwrite
              [M:PJBU9]PAANS(GRDSUB) = [V]CST_ANO
        Elsif [M:PJBU9]LMCOD(GRDSUB) = 5 #"L" BUDGET Logging
              [M:PJBU9]PAANS(GRDSUB) = [V]CST_AYES
        Elsif [M:PJBU9]LMCOD(GRDSUB) = 6 #"D" BUDGET Deletes
              [M:PJBU9]PAANS(GRDSUB) = [V]CST_ANO
        Endif
        # Issue X3-7285/119926 - 2016-11-21 ALMON   : End     #
        GRDSUB = GRDSUB+1
      #Endif
      # Issue X3-26714 - 2017-03-10 by ALMON : END
    Endif
    WRKMSGNO += 1
    MESSAGE = mess(WRKMSGNO,7716,1)
  Wend
  [M:PJBU9]NBLIG = GRDSUB

  Affzo [M:PJBU9]1-99
Return
#--------------------------------------------------------------------------------------------------------
#-- BOUTON action
$OK_BUTTON
 Local Integer NB
 Local Char    CODEAFF(GLONOPP)
 Local Char    CODEBUD(GLONPBU)
 Local Integer IRET
 #Local Instance BUDLOG Using C_ALOG : #


      Local Integer IRET
      Local Instance TECBUDAUT Using C_TECBUDAUT
  # --------------------------------------
      TECBUDAUT = NewInstance C_TECBUDAUT AllocGroup null
      TECBUDAUT.PBUCOD  = [M:PJBU9]PBUCOD
  #If TECBUDAUT.INCLOG = [V]CST_AYES
      Local Instance BUDLOG Using C_ALOG
      BUDLOG = NewInstance C_ALOG AllocGroup null
      LRET = fmet BUDLOG.ABEGINLOG(mess(900,2260,1)-": "-OPPNUM)
      TECBUDAUT.LOGNAME = fmet BUDLOG.AGETNAME()
  #Endif
  # ------------------------------------
      # Issue X3-7285/119926 - 2016-11-21 ALMON   : Begin Changed Process drivers from LM Codes to Numbers     #
      For NB = 0 To [M:PJBU9]NBLIG -1
        Case [M:PJBU9]LMCOD(NB)
          When 1 #"A"
            TECBUDAUT.INCALL  = [M:PJBU9]PAANS(NB)
          When 3 #"O"
            TECBUDAUT.INCOPE  = [M:PJBU9]PAANS(NB)
          When 2 # "P"
            TECBUDAUT.INCITM  = [M:PJBU9]PAANS(NB)
          When 4 #"E"
            TECBUDAUT.INCOWRT = [M:PJBU9]PAANS(NB)
          When 5 #"L"
            TECBUDAUT.INCLOG  = [M:PJBU9]PAANS(NB)
          When 6 #"D"
            TECBUDAUT.INCDAL  = [M:PJBU9]PAANS(NB)
        Endcase
      Next
      # Issue X3-7285/119926 - 2016-11-21 ALMON   : End    #
  # --------------------------------
      IRET = fmet GZINSPJM.PJM_BUDGET_AUTOMATION([M:PJBU9]OPPNUM,TECBUDAUT,BUDLOG)
      If TECBUDAUT.INCLOG = [V]CST_AYES and TECBUDAUT.LOGNAME <> AVOID.ACHAR Then
          Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(GZINSPJM, BUDLOG) From SYRSTACKTOOLS
          GTRACE = TECBUDAUT.LOGNAME
          LRET = fmet BUDLOG.AENDLOG()
          Call LEC_TRACE From LECFIC
      Endif
      FreeGroup BUDLOG
      If TECBUDAUT <> null Then
        FreeGroup TECBUDAUT
      Endif
Return
# ---------------------------------------------------------------------------------
##########################################################################################################
##########################################################################################################
# Subroutines
##########################################################################################################

