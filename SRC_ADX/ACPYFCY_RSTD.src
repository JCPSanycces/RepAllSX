#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure ACPYFCY_RSTD
##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
      When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
      When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
      When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER

    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return



##########################################################################################################
# METHODS
##########################################################################################################

$AQUERY_DECODE_CRITERIA_AFTER
  Raz NBPRO
  NBPRO += 1
  TBPRO(NBPRO) = "FCY"       : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ACPYFCY.FCY"       : TBFIL(NBPRO) = "[LNK_]FCY"
  NBPRO += 1
  TBPRO(NBPRO) = "CPYFCYNAM" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ACPYFCY.CPYFCYNAM" : TBFIL(NBPRO) = "[LNK_]CPYFCYNAM"
  NBPRO += 1
  TBPRO(NBPRO) = "TYP"       : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ACPYFCY.TYP"       : TBFIL(NBPRO) = "[LNK_]TYP"
Return

$AQUERY_PRIMARYKEYS_AFTER
  ASTDKEY = "[LNK_]TYP;[LNK_]FCY"
Return

$AQUERY_OPEN_AFTER
  Local File    FACILITY [QRY_FCY]
  Local File    COMPANY  [QRY_CPY]
  Local Integer I : I=0
  Local Char    TFCY(GLONFCY)(1..)
  Local Char    TFCYNAM(GLONDES)(1..)
  Local Char    TTYP(10)(1..)

  For [QRY_FCY]FCY0
   I += 1
   TFCY(I)    = [F:QRY_FCY]FCY
   TFCYNAM(I) = [F:QRY_FCY]FCYNAM
   # Site
   TTYP(I)       =  mess(3,45,1)
  Next

  For [QRY_CPY]CPY0
   I += 1
   TFCY(I)    = [F:QRY_CPY]CPY
   TFCYNAM(I) = [F:QRY_CPY]CPYNAM
   # Company
   TTYP(I)       = mess(2,45,1)
  Next

  Local File (Char FCY(GLONFCY),Char CPYFCYNAM(GLONDES),Char TYP(10)) From Variable TFCY,TFCYNAM,TTYP As [LNK_]
Return

$AQUERY_TRANS_AFTER
  this.ACPYFCY.FCY       = [LNK_]FCY
  this.ACPYFCY.CPYFCYNAM = [LNK_]CPYFCYNAM
  this.ACPYFCY.TYP       = [LNK_]TYP
Return

$AQUERY_CLOSE_AFTER
  Close Local File [LNK_]
  LogicClose File  [QRY_FCY]
  LogicClose File  [QRY_CPY]
Return

