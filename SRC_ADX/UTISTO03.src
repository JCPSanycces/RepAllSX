#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################
# UTISTO03   Moulinette pour initialiser [F:ITG]ALLRULSCC   Module STOCK #
# ---------------------------------------------------------------------- #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTISTO03(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTISTO03(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTISTO03: Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:ITG])  =0  Local File =DOSSIER+".ITMCATEG"   [ITG] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK
Trbegin [ITG]
For [ITG]
  Readlock [ITG] Curr    
  If !fstat
    [F:ITG]ALLRULSCC=[F:ITG]ALLRULMFG
    Rewrite [F:ITG]
  Endif
  COMPTEUR += 1
Next
Commit
Close Local File [ITG]

Call ECR_TRACE("UTISTO03 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call MAJ_UTISTO03(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
Call MAJ_UTISTO03(APPLI)        
End
