#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ , GTRACE , GNBMASKOUV
Call OBJET("AVW",GBIDC1,GBIDC2) From GOBJET
End

#-----------------------------------------------------------------------------#
# Mise à jour vue (validation dico + patch)
#-----------------------------------------------------------------------------#

Subprog MAJVUE(VUE,APPLI)
Value Char VUE , APPLI
Local Integer OK
If clalev([F:AVW])=0 : Local File =APPLI+".AVIEW"   [AVW] : Endif
If clalev([F:AVD])=0 : Local File =APPLI+".AVIEWD"  [AVD] : Endif
If clalev([F:AVC])=0 : Local File =APPLI+".AVIEWC"  [AVC] : Endif
If clalev([F:AVB])=0 : Local File =APPLI+".AVIEWB"  [AVB] : Endif
If clalev([F:ATX])=0 : Local File =APPLI+".ATEXTE"  [ATX] : Endif
If clalev([F:ATZ])=0 : Local File =APPLI+".ATABZON" [ATZ] : Endif
If clalev([F:ATY])=0 : Local File =APPLI+".ATYPE"   [ATY] : Endif
If clalev([F:ACV])=0 : Local File =APPLI+".ACTIV"   [ACV] : Endif
Local File =APPLI+".ADOVAL"  [AD_]
If clalev([F:ADS])=0 : Local File ADOSSIER          [ADS] : Endif
Local Char HISAPL(GLONADS)
Read [ADS]DOSSIER = APPLI
Read [AD_]ADW0 = "";"";"HISDOS"
If !fstat
 HISAPL = [F:AD_]VALEUR
Endif
If VUE="ADICADX" & nomap=GDOSX3
 Call GENDROIT
Endif
Call CREVUE(VUE,APPLI,[F:ADS]TYPDBA,[F:ADS]CODDBA,OK)
#107271 dossier histo uniquement sur GEODE
If GPRODUIT=1 & HISAPL<>"" & HISAPL<>APPLI
 Call CREVUE(VUE,HISAPL,[F:ADS]TYPDBA,[F:ADS]CODDBA,OK)
Endif
Close Local File
End

#-----------------------------------------------------------------------------#
# Mise à jour structure vue (validation dossier)
#-----------------------------------------------------------------------------#

Subprog VUE
Local Integer OK
Local File =[F:ADS]DOSSIER+".AVIEW"   [AVW]
Local File =[F:ADS]DOSSIER+".AVIEW"   [AVW2]
Local File =[F:ADS]DOSSIER+".AVIEWD"  [AVD]
Local File =[F:ADS]DOSSIER+".AVIEWC"  [AVC]
Local File =[F:ADS]DOSSIER+".AVIEWB"  [AVB]
Local File =[F:ADS]DOSSIER+".ATEXTE"  [ATX]
Local File =[F:ADS]DOSSIER+".ATABZON" [ATZ]
Local File =[F:ADS]DOSSIER+".ATYPE"   [ATY]
Local File =[F:ADS]DOSSIER+".ACTIV"   [ACV]
Local File =[F:ADS]DOSSIER+".ADOVAL"  [AD_]
Local Char HISAPL(GLONADS)
Read [AD_]ADW0 = "";"";"HISDOS"
If !fstat
 HISAPL = [F:AD_]VALEUR
Endif
If GINFO
 Call AFF_VLC(mess(125,125,1),"") From GESECRAN
# MAJ structure vues
Endif
Call ECR_TIME(mess(125,125,1)) From DOSSUB
If adxmac(0)<>""
 # MAJ structure vues\Opération impossible sur machine distante
 Call ECR_TRACE(mess(125,125,1)+"\"+mess(129,125,1),1) From GESECRAN
 End
Endif
OK = 0
If dim(GVALIDE)>=11
 OK = GVALIDE(11)
 OK += GVALIDE(1)
Else
 OK = GVALIDE(1)
Endif
If !OK
 Filter [AVW2] Where UPDFLG=1 & CODVUE<GXX
Endif
If GCRE
 Call GENDROIT
Endif
For [AVW2]
 Call CREVUE([F:AVW2]CODVUE,[F:ADS]DOSSIER,[F:ADS]TYPDBA,[F:ADS]CODDBA,OK)
 #107271 dossier histo uniquement sur GEODE
 If GPRODUIT=1 & HISAPL<>""
  Call CREVUE([F:AVW2]CODVUE,HISAPL,[F:ADS]TYPDBA,[F:ADS]CODDBA,OK)
 Endif
Next
Filter [AVW2]
Close Local File
# Pour regénérer les vues cassées par la validation des tables
Call GENVUE([F:ADS]DOSSIER)
End

#-----------------------------------------------------------------------------#
# Création des vues à l'installation du dossier
#-----------------------------------------------------------------------------#

Subprog INSTALL_VUE(APPLI,OK)
Value Char APPLI
Variable Integer OK
Local Integer K
Local Char    CRITERE(30) , HISAPL(GLONADS)
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER = APPLI
If fstat
 Call ECR_TRACE(APPLI-":"-mess(7,125,1),1) From GESECRAN : # Dossier inexistant
 End
Endif
Local File =[F:ADS]DOSSIER+".AVIEW"   [AVW]
Local File =[F:ADS]DOSSIER+".AVIEW"   [AVW2]
Local File =[F:ADS]DOSSIER+".AVIEWD"  [AVD]
Local File =[F:ADS]DOSSIER+".AVIEWC"  [AVC]
Local File =[F:ADS]DOSSIER+".AVIEWB"  [AVB]
Local File =[F:ADS]DOSSIER+".ATEXTE"  [ATX]
Local File =[F:ADS]DOSSIER+".ATABZON" [ATZ]
Local File =[F:ADS]DOSSIER+".ATYPE"   [ATY]
Local File =[F:ADS]DOSSIER+".ACTIV"   [ACV]
If adxmac(0)<>""
 # MAJ structure vues\Opération impossible sur machine distante
 Call ECR_TRACE(mess(125,125,1)+"\"+mess(129,125,1),1) From GESECRAN
 End
Endif
CRITERE = "1=1"
Local File =[F:ADS]DOSSIER+".ADOVAL"  [AD_]
Read [AD_]ADW0 = "";"";"SUPDOS"
If !fstat
 If [F:ADS]DOSSIER=[F:AD_]VALEUR
  CRITERE = "MODULE=1"
 Endif
Elsif [F:ADS]DOSSIER="X3"
 CRITERE = "MODULE=1"
Endif
Read [AD_]ADW0 = "";"";"HISDOS"
If !fstat & [F:AD_]VALEUR<>"" & filinfo(filpath("","","",[F:AD_]VALEUR),0)>=0
 HISAPL = [F:AD_]VALEUR
Endif
OK = 1
Call GENDROIT
For [AVW2] Where evalue(CRITERE)
 Call SUPVUE_SIL([F:AVW2]CODVUE,[F:ADS]DOSSIER,[F:ADS]TYPDBA)
 Call CREVUE([F:AVW2]CODVUE,[F:ADS]DOSSIER,[F:ADS]TYPDBA,[F:ADS]CODDBA,K)
 If !K : OK = 0 : Endif
 #107271 dossier histo uniquement sur GEODE
 If GPRODUIT=1 & HISAPL<>""
  Call CREVUE([F:AVW2]CODVUE,HISAPL,[F:ADS]TYPDBA,[F:ADS]CODDBA,K)
  If !K : OK = 0 : Endif
 Endif
Next AVW2
Filter [AVW2]
Close Local File
End

#--------------------------------------------------------------------------------------#
# Regénération des vues invalides après une validation de table (Seulement Oracle)
#--------------------------------------------------------------------------------------#

Subprog GENVUE_OLD(APPLI)
Value Char APPLI
Local Char HISAPL(GLONADS) , DOSSIER(GLONADS)
Local Integer OK
If GTYPDBA<>1 : End : Endif
Local File =APPLI+".AVIEW" [AV__] , =APPLI+".ADOVAL" [AD__] , =APPLI+".ACTIV" [AC__]
HISAPL = ""
Read [AD__]ADW0="";"";"HISAPL"
If !fstat
 HISAPL = [F:AD__]VALEUR : # Nom du dossier histo
Endif
For [AV__]AVW0
 OK = 1
 If [F:AV__]CODACT<>""
  Read [AC__]CODACT = [F:AV__]CODACT
  If fstat or [F:AC__]FLACT<>2
   OK = 0
  Endif
 Endif
 If OK
  For   (Char DOSCOD(GLONADS))
& From "3"
& Sql "Select all_views.OWNER From all_views, all_objects"
& +" Where OBJECT_NAME=VIEW_NAME"
& +" and all_objects.OWNER=all_views.OWNER"
& +" and NVL(status,'?')<>'VALID'"
& +" and all_views.OWNER in ('"+APPLI+"','"+HISAPL+"')"
& +" and all_views.VIEW_NAME='"+[F:AV__]CODVUE+"'"
& As [AW__]
   OK = 0 : Break
  Next AW__
  If !OK
   Call MAJVUE([F:AV__]CODVUE,APPLI)
  Endif
 Endif
Next AV__
End

Subprog GENVUE(APPLI)
Value Char APPLI
Local Char HISAPL(GLONADS) , DOSSIER(GLONADS)
Local Char TABVUE(GLONAVW)(1..)
Local Integer NBVUE
Local Integer OK,I
If GTYPDBA<>1 : End : Endif
Local File =APPLI+".AVIEW" [AV__] , =APPLI+".ADOVAL" [AD__] , =APPLI+".ACTIV" [AC__]
HISAPL = ""
Read [AD__]ADW0="";"";"HISAPL"
If !fstat
 HISAPL = [F:AD__]VALEUR : # Nom du dossier histo
Endif
# list of views incorect
For   (Char DOSCOD(GLONADS) , Char VUE(GLONAVW))
& From "3"
& Sql "Select all_views.OWNER, all_views.VIEW_NAME From all_views, all_objects"
& +" Where OBJECT_NAME=VIEW_NAME"
& +" and all_objects.OWNER=all_views.OWNER"
& +" and NVL(status,'?')<>'VALID'"
& +" and all_views.OWNER in ('"+APPLI+"','"+HISAPL+"')"
& As [AW__]
 If find([AW__]VUE,TABVUE(1..NBVUE))=0
  NBVUE +=1
  TABVUE(NBVUE) = [AW__]VUE
 Endif
Next

# check codact before MAJVUE
For I=1 To NBVUE
 Read [AV__]AVW0 = TABVUE(NBVUE)
 If !fstat
  OK = 1
  If [F:AV__]CODACT<>""
   Read [AC__]CODACT = [F:AV__]CODACT
   If fstat or [F:AC__]FLACT<>2
    OK = 0
   Endif
  Endif
  If OK
   Call MAJVUE([F:AV__]CODVUE,APPLI)
  Endif
 Endif
Next
End

#-----------------------------------------------------------------------------#
# Création d'une vue
#-----------------------------------------------------------------------------#

Subprog CREVUE(VUE,APPLI,TYPDBA,CDBA,OK)
Value Char    VUE , APPLI
Value Integer TYPDBA , CDBA
Variable Integer OK

Read [AVW]AVW0=VUE
If fstat
 Call ECR_TRACE(VUE-":"-mess(76,139,1),1) From GESECRAN : # Vue inexistante
 End
Endif
If [F:AVW]CODACT<>""
 Read [ACV]CODACT = [F:AVW]CODACT
 If fstat or [F:ACV]FLACT<>2
  Call ECR_TRACE(VUE-":"-mess(283,139,1),-1) From GESECRAN : # Vue inactive
  End
 Endif
Endif

OK = 1

If GTRACE<>""
 Call ECR_TRACE(mess(121,125,1)-APPLI+"."+VUE,0) From GESECRAN : # Création de la vue
Endif

# Création des .srf et viw et maj .cfg
Call CREVUE_FIC(VUE,APPLI,TYPDBA,CDBA,OK)
If !OK : End : Endif

If filinfo(filpath("FIL",VUE,"viw",APPLI),0)<0
 If GTRACE<>""
  Call ECR_TRACE(mess(100,141,1)-APPLI+"."+VUE,1) From GESECRAN : # Erreur création
 Endif
 End
Endif

If GTRACE<>""
 Call ECR_TRACE(mess(84,139,1)-APPLI+"."+VUE,0) From GESECRAN : # Validation de la vue
Endif

# Création de la vue dans la base
Call CREVUE_BASE(VUE,APPLI,TYPDBA,OK)

End

#-----------------------------------------------------------------------------#
# Création des .srf et viw et maj .cfg
#-----------------------------------------------------------------------------#

Subprog CREVUE_FIC(VUE,APPLI,TYPDBA,CDBA,OK)
Value    Char    VUE , APPLI
Value    Integer TYPDBA , CDBA
Variable Integer OK

Local Char     FICSRF(GDIMFIC) , FICVIW(GDIMFIC) , FICCFG(GDIMFIC)
Local Integer  NBCLE
Local Char     TEXTE(250)
Local Char     LIGNE(250)
Local Decimal  LNGZON , LNGTOT , LNGDEC
Local Integer  REPET , TYPZON
Local Char     SELECT(250)(1..500) , REQUETE(250)(1..500) , LIGNE(250)
Local Integer  NBSEL , NBREQ
Local Char     MESSAGE(250) , ERM(250)
Local Shortint MAXCOL : MAXCOL = 500
Local Char     FLD(30)(1..MAXCOL) , DIME(5)(1..MAXCOL) , TYP(3)(1..MAXCOL) , LNG(10)(1..MAXCOL)
Local Integer  NBFLD , RES(MAXCOL) , NBCOL , COLNUM(MAXCOL)
Local Char     COLNAM(30)(1..MAXCOL)
Local Char     CHAINE(250) , VALVAR(250)
Local Char     ACTION(20) , TRTDEV(GLONADC)
Local Integer  I , J , K , M , N , ER , OKTRT
Local Clbfile  CLOB(5) , CLOB_LF(5)

TRTDEV = "DOSVUEB"
Call EXISTE_ADX("","",TRTDEV,OKTRT) From ORDSYS
If OKTRT
 ACTION = "INIT_VUE" : Gosub ACTION From =TRTDEV
Endif

Raz ER, MESSAGE

FICSRF = filpath("FIL",VUE,"srf",APPLI)

# Création du .srf
Openo FICSRF , 0 Using [ECR_]
Iomode adxifs ""       Using [ECR_]
Iomode adxirs chr$(10) Using [ECR_]
Iomode adxium GUTF8    Using [ECR_]

# Entête
Call TEXTE([F:AVW]INTIT,TEXTE) From OBJDIV
Wrseq "#<AdxF"+GADOVERS+">@(#)%I% "+TEXTE Using [ECR_]
Wrseq [F:AVW]ABRVUE Using [ECR_]
Wrseq '"#V"' Using [ECR_]
Case TYPDBA
 When 1 : Wrseq "3" Using [ECR_] : # Oracle
 When 2 : Wrseq "5" Using [ECR_] : # SQL-server
 When 3 : Wrseq "2" Using [ECR_] : # Cisam
 When 4 : Wrseq "6" Using [ECR_] : # DB2
Endcase

# Champs
NBFLD = 0
Filter [AVD] Where CODVUE=VUE
Wrseq num$(rowcount([F:AVD])) Using [ECR_]
Filter [AVD]
Iomode adxifs chr$(9) Using [ECR_]
For [AVD]AVD0 Where CODVUE=VUE
 Read [ATY]CODTYP = [F:AVD]CODTYP
 If fstat or !find([F:ATY]TYPTYP,9,10)
  Gosub ECRIZONE
 Endif
Next AVD
# On met les blobs/clobs à la fin
For [AVD]AVD0 Where CODVUE=VUE
 Read [ATY]CODTYP = [F:AVD]CODTYP
 If !fstat & find([F:ATY]TYPTYP,9,10)
  Gosub ECRIZONE
 Endif
Next AVD

# Index
NBCLE = 0
For [AVC]AVC1 Where CODVUE=VUE
 NBCLE += 1
Next AVC
If NBCLE=0
 Wrseq "1" Using [ECR_]
 For [AVD]AVD0 Where CODVUE=VUE
  Wrseq [F:AVD]FLDVUE , "1" , [F:AVD]FLDVUE Using [ECR_]
  Break
 Next AVD
Else
 Wrseq num$(NBCLE) Using [ECR_]
 For [AVC]AVC1 Where CODVUE=VUE
  K = 1 : # Avec homonymes
  If dim([F:AVC]KEYDUP)>0 & [F:AVC]KEYDUP=1
   K = 2 : # Sans homonymes
  Endif
  Wrseq [F:AVC]CODCLE , num$(K) , [F:AVC]DESCLE Using [ECR_]
 Next AVC
Endif
Openo Using [ECR_]

# Chargement de la requête (Select)
Read [AVB]AVB0 = VUE;TYPDBA
If fstat
 MESSAGE = mess(102,139,1) : # Requête sql inexistante
 Gosub ERREUR : OK = 0 : End
Endif

# Pour virer les CR
CLOB_LF = ctrans([F:AVB]TEXTE,chr$(13),"")

# Mise en forme de la requête
OK = 1

# Suppression des commentaires
If left$(CLOB_LF,1)="#" : # Commentaire en début de clob
 I = 1
Else
 I = instr(1,CLOB_LF,chr$(10)+"#") : # Pour être sûr que le # soit en début de ligne
Endif
J = instr(I+1,CLOB_LF,chr$(10))
While I & J>I
 CLOB_LF = left$(CLOB_LF,I-1)+right$(CLOB_LF,J)
 I = instr(I,CLOB_LF,chr$(10)+"#")
 J = instr(I+1,CLOB_LF,chr$(10))
Wend

# Décodage des variables (%var%) ou like 'BM%%3%%'

I = instr(1,CLOB_LF,"%")
J = instr(I+1,CLOB_LF,"%")
MESSAGE = ""
While I & J>I
 If J=I+1
  CLOB_LF = left$(CLOB_LF,I)+right$(CLOB_LF,J+1)
 Else
  ER = 0
  Onerrgo ERRSQL
  VALVAR  = evalue(seg$(CLOB_LF,I+1,J-1))
  Onerrgo
  If !ER
   CLOB_LF = left$(CLOB_LF,I-1)+VALVAR+right$(CLOB_LF,J+1)
   J = I+len(VALVAR)
  Else
   If MESSAGE<>""
    MESSAGE += "\"
   Endif
   MESSAGE += seg$(CLOB_LF,I+1,J-1)-"->"-mess(6,123,1)-num$(ER)-ERM : # Erreur
   J += 1
  Endif
 Endif
 I = instr(J,CLOB_LF,"%")
 J = instr(I+1,CLOB_LF,"%")
Wend
If MESSAGE<>""
 Gosub ERREUR : OK = 0 : End
Endif

# Suppression des lignes vides
I = instr(1,CLOB_LF,chr$(10)+chr$(10))
While I
 CLOB_LF = left$(CLOB_LF,I-1)+right$(CLOB_LF,I+1)
 I = instr(I,CLOB_LF,chr$(10)+chr$(10))
Wend
If right$(CLOB_LF,len(CLOB_LF))=chr$(10) : # Fin de script
 CLOB_LF = left$(CLOB_LF,len(CLOB_LF)-1)
Endif

If len(CLOB_LF)=0
 MESSAGE = mess(81,139,1) : # Requête vide
 Gosub ERREUR : OK = 0 : End
Endif

# Transfert du clob dans un texte pour anasql
CLOB = ctrans(CLOB_LF,chr$(10)," ")
Setlob SELECT With CLOB
NBSEL = dim(SELECT)
While SELECT(NBSEL)=""
 NBSEL -= 1
Wend

# Constitution du début de la requête de création de la vue (Liste des champs sans le Create)
Raz REQUETE , NBREQ
NBREQ += 1
Raz NBCOL , COLNUM
For I=1 To NBFLD
 For J=1 To val(DIME(I))
  If !NBCOL
   LIGNE = " ( "
  Else
   LIGNE = " , "
  Endif
  LIGNE += FLD(I)+"_"+num$(J-1)
  Gosub INC
  NBCOL += 1
  COLNUM(NBCOL) = I
  COLNAM(NBCOL) = FLD(I)+"_"+num$(J-1)
 Next J
Next I
If NBCOL>0
 LIGNE = " ) As "
Endif
Gosub INC
If NBSEL+NBREQ>dim(REQUETE)
 MESSAGE = mess(161,115,1) : # Trop de lignes
 Gosub ERREUR : OK = 0 : End
Endif

# Analyse du select
Gosub SET_DBA
If APPLI=nomap
 Onerrgo ERRSQL
 Anasql From DBA Sql SELECT(1..NBSEL) Using RES
 Onerrgo
 Gosub RESULTAT_SELECT
 If !OK : End : Endif
Endif

# Création du .viw
FICVIW = filpath("FIL",VUE,"viw",APPLI)
Openo FICVIW,0 Using [ECR_]
Iomode adxifs ""       Using [ECR_]
Iomode adxirs chr$(10) Using [ECR_]
Iomode adxium GUTF8    Using [ECR_]
For I=1 To NBREQ
 Wrseq REQUETE(I) Using [ECR_]
Next I
Wrseq CLOB_LF Using [ECR_]
Openo Using [ECR_]

# Vérification du .cfg
K = 0
FICCFG = filpath("FIL",VUE,"cfg",APPLI)
If filinfo(FICCFG,0)>0
 Openi FICCFG Using [FIC]
 Iomode adxifs ""       Using [FIC]
 Iomode adxirs chr$(10) Using [FIC]
 Iomode adxium GUTF8    Using [FIC]
 Rdseq CHAINE Using [FIC]
 While !fstat
  If instr(1,toupper(CHAINE),'{"LEVEL1"}')
   K = 1 : Break
  Elsif instr(1,toupper(CHAINE),'{"LEVEL0"}')
   K = 2 : Break
  Endif
  Rdseq CHAINE Using [FIC]
 Wend
 Openi Using [FIC]
Endif
If dim([F:AVW]SECURE)>0
 If ([F:AVW]SECURE=2 & (K=0 or K=1)) or ([F:AVW]SECURE<>2 & K=2)
  Call MODIF_CFG(FICCFG,[F:AVW]SECURE) From SUBATB
 Endif
Endif

End

#--------------#
$ECRIZONE
REPET = [F:AVD]DIME
Call REPTAB([F:AVD]FLDACT,REPET) From DOSSUB
If REPET<>0
 Call TEXTE([F:AVD]FLDINT,TEXTE) From OBJDIV
 LNGZON = 0
 Read [ATY]CODTYP = [F:AVD]CODTYP
 If fstat
  TYPZON = 7
  LNGZON = 1
  REPET  = 1
  Read [ATY]CODTYP = "A"
 Else
  REPET = abs(REPET)
  If find([F:ATY]TYPTYP,4,7,9,10) : # DCB, Alpha, Blob, Clob
   If [F:ATY]LNGTYP<>0 : LNGZON = [F:ATY]LNGTYP
   Else                : LNGZON = [F:AVD]LNG
   Endif
  Endif
 Endif
 # Problème des nombres avec SQL-serveur :
 # pour les dcb, on ne peut pas dépasser 28, à répartir entre la partie entière et décimale.
 If [F:ATY]TYPTYP=4
  LNGTOT = min(int(LNGZON),28)
  LNGDEC = LNGZON-LNGTOT
  While int(LNGDEC)<>LNGDEC
   LNGDEC *= 10
  Wend
  If instr(1,[F:AVD]OPTION,"F") or instr(1,[F:ATY]OPTION,"F")
   If LNGDEC>0
    LNGTOT = min(14,LNGTOT+LNGDEC)
   Endif
   LNGDEC = min(LNGTOT-1,28-LNGDEC) : # Il ne faut pas dépasser 28
  Else : # On ajoute le nombre de décimales à la partie entière
   LNGTOT += max(min(LNGDEC,28-LNGTOT-LNGDEC),0)
   LNGDEC += 1       : # Par sécurité
  Endif
  If LNGTOT+LNGDEC>28 : LNGDEC = 28-LNGTOT : Endif
  NBFLD += 1
  FLD(NBFLD)  = [F:AVD]FLDVUE
  TYP(NBFLD)  = num$([F:ATY]TYPTYP)
  LNG(NBFLD)  = num$(LNGTOT)+"."+num$(LNGDEC)
  DIME(NBFLD) = num$(REPET)
 Else
  Case [F:ATY]TYPTYP
   When 7 : # ,12 112337 view with field CREDATTIM : CCL
    Case CDBA
     When 2       : TYPZON = 79 : # Unicode
     When Default : TYPZON = 7  : # Ascii
    Endcase
   When 9         : TYPZON = 81 : # Blob
   When 10        : TYPZON = 82 : # Clob
   When 11        : TYPZON = 84 : # Uuid
   When 12        : TYPZON = 85 : # Datetime
   When Default   : TYPZON = [F:ATY]TYPTYP
  Endcase
  NBFLD += 1
  FLD(NBFLD)  = [F:AVD]FLDVUE
  TYP(NBFLD)  = num$(TYPZON)
  LNG(NBFLD)  = num$(LNGZON)
  DIME(NBFLD) = num$(REPET)
 Endif
 Wrseq FLD(NBFLD), TYP(NBFLD), LNG(NBFLD), DIME(NBFLD), '"'+TEXTE+'"' Using [ECR_]
Endif
Return

#----------------------------#
$INC
If len(REQUETE(NBREQ))+len(LIGNE)+1>80
 REQUETE(NBREQ) += " "
 NBREQ += 1
Endif
REQUETE(NBREQ) += LIGNE
Return

#----------------------------#
$ERREUR
Call ECR_TRACE(mess(77,139,1)-APPLI+"."+VUE-":\"+MESSAGE,max(1,ER)) From GESECRAN
Return

#-----------------------------------------------------------------------------#
$RESULTAT_SELECT
OK = 1
If RES(0)<=0 & ER
 OK = 0 : MESSAGE = errmes$(abs(ER))+"\"+ERM
Elsif RES(0)<>NBCOL
 OK = 0 : MESSAGE = mess(80,139,1)
 # Les nombres de champs déclarés dans la vue et dans la requête doivent être identiques
Elsif RES(0)>dim(RES)-1
 OK = 0 : MESSAGE = mess(213,123,1)-"("+num$(RES(0))+"/"+num$(dim(RES)-1)+")"
 # Nombre de colonnes trop grand
Else
 For I=1 To RES(0)
  Case RES(I)
   When 1       : N = 3  : # Menu local => Entier
   When 2       : N = 3  : # Shortint   => Entier
   When 3       : N = 8  : # Date
   When 4       : N = 3  : # Integer    => Entier
   When 5       : N = 4  : # Flottant   => Decimal
   When 6       : N = 4  : # Double     => Decimal
   When 7       : N = 4  : # Decimal
   When 8,9     : N = 4  : # Decimal
   When 522     : N = 9  : # Blob
   When 523     : N = 10 : # Clob
   When 525     : N = 11 : # Uuid
   When 526     : N = 12 : # Datetime
   When Default : N = 7  : # Alpha
  Endcase
  K = COLNUM(I)
  Case val(TYP(K))
   When 1,2,3     : M = 3  : # Menu, Shortint   => Entier
   When 4,5,6     : M = 4  : # Décimal, Flottant, Double => Decimal
   When 7,79      : M = 7  : # Alpha
   When 81        : M = 9  : # Blob
   When 82        : M = 10 : # Clob
   When 84        : M = 11 : # Uuid
   #When 85        : M = 12 : # Datetime X3-113486.o
   # X3-113486.sn
   # Anasql provides the wrong answer for an internal data type of "DATE"
   # on SQL Server only (not Oracle) and we must override this
   # until the runtime is corrected and fully regression tested.
   When 85        : If DBA = "5" : M = 8 : Else M = 12 : Endif # Datetime X3-113486.en Nov 2 2018
   When Default   : M = val(TYP(K))
  Endcase
  If !(find(N,3,4) & find(M,3,4)) : # Tout calcul sur des champs numériques dans une vue est du type décimal
   If M<>N
    MESSAGE = mess(82,139,1)
    # Les types des champs déclarés dans la vue et dans la requête doivent correspondre
    OK = 0 : Break
   Endif
  Endif
 Next I
Endif
If OK<>1
 If GSERVEUR | GTRACE<>""
  Call ECR_TRACE(mess(77,139,1)-APPLI+"."+VUE-":"-MESSAGE,1) From GESECRAN : # Vue
 Else
  Call OUVRE_TRACE(mess(79,139,1)-VUE) From LECFIC : # Résultat de l'analyse de la vue
  If RES(0)<=0 or ER
   For I=1 To NBSEL
    Call ECR_TRACE(SELECT(I),0) From GESECRAN
   Next I
  Endif
  Call ECR_TRACE(MESSAGE,1) From GESECRAN
  If RES(0)>0
   MESSAGE = "\"
   MESSAGE += format$("K:10X",mess(36,124,1)) : # Champ
   MESSAGE += format$("K:20X",mess(18,134,1)) : # Requête
   MESSAGE += format$("K:30X",mess(77,139,1)) : # Vue
   Call ECR_TRACE(MESSAGE,0) From GESECRAN
   Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
   For I=1 To RES(0)
    MESSAGE = format$("K:10X",num$(I))
    Case RES(I)
     When 1       : N = 1  : # Menu local
     When 2       : N = 2  : # Shortint
     When 3       : N = 8  : # Date
     When 4       : N = 3  : # Integer
     When 5       : N = 5  : # Flottant
     When 6       : N = 6  : # Double
     When 7       : N = 4  : # Decimal
     When 8,9     : N = 4  : # Decimal
     When 522     : N = 9  : # Blob
     When 523     : N = 10 : # Clob
     When 525     : N = 11 : # Uuid
     When 526     : N = 12 : # Datetime
     When Default : N = 7  : # Alpha
    Endcase
    If N>0
     If N=7
      MESSAGE += format$("K:20X",mess(N,30,1)-num$(RES(I)-10))
     Else
      MESSAGE += format$("K:20X",mess(N,30,1))
     Endif
    Else
     MESSAGE += format$("K:20X","")
    Endif
    K = COLNUM(I)
    M = 0
    If K>0
     Case val(TYP(K))
      When 7, 79   : M = 7  : # Alpha
      When 81      : M = 9  : # Blob
      When 82      : M = 10 : # Clob
      When 84      : M = 11 : # Uuid
      When 85      : M = 12 : # Datetime
      When Default : M = val(TYP(K))
     Endcase
     If M>0
      If M=7
       MESSAGE += format$("K:30X",COLNAM(I)-"("+mess(M,30,1)-LNG(K)+")")
      Else
       MESSAGE += format$("K:30X",COLNAM(I)-"("+mess(M,30,1)+")")
      Endif
     Else
      MESSAGE += format$("K:30X",COLNAM(I))
     Endif
    Endif
    Call ECR_TRACE(MESSAGE,-(M<>N)) From GESECRAN
   Next I
   If RES(0)<NBCOL
    For I=RES(0)+1 To NBCOL
     MESSAGE = format$("K:30X",num$(I))
     MESSAGE += format$("K:30X",COLNAM(I))
     Call ECR_TRACE(MESSAGE,-1) From GESECRAN
    Next I
   Endif
  Endif
  Call ECR_TRACE("\"+mess(18,134,1),0) From GESECRAN : # Requête
  Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
  For I=1 To NBREQ
   Call ECR_TRACE(REQUETE(I),0) From GESECRAN
  Next I
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
 Endif
Endif
If OK=-1
 If GSERVEUR | GTRACE<>""
  OK = 1
 Else
  # L'analyse de la requête a révélé une anomalie non bloquante\Voulez-vous continuer
  Call AVERTIR(mess(77,139,1)-VUE+"\"+mess(112,139,1)+"\"+mess(205,100,1),OK) From GESECRAN
  If OK=2 : OK = 1 : Else : OK = 0 : Endif
 Endif
Endif
Return

#--------------#
$SET_DBA
Local Char DBA(1)
Case TYPDBA
 When 1 : DBA = "3"
 When 2 : DBA = "5"
 When 3 : DBA = "2"
 When 4 : DBA = "4"
Endcase
Return

#----------------------------#
$ERRSQL
ER = errn
ERM = errm
Resume

#-----------------------------------------------------------------------------#
# Création de la vue dans la base
#-----------------------------------------------------------------------------#

Subprog CREVUE_BASE(VUE,APPLI,TYPDBA,OK)
Value Char    VUE , APPLI
Value Integer TYPDBA
Variable Integer OK

Local Char    DOSSIER(GLONADS) , MACHINE(GDIMFIC) , VOLUME(GDIMFIC)
Call MACHINE(APPLI,MACHINE,DOSSIER) From ORDSYS
Call VOLUME(MACHINE,DOSSIER,VOLUME) From ORDSYS

Local Integer STAT , ER
Local Char    MESSAGE(250) , ERM(250) , LIGNE(250)
Local Char    FICTRA(GDIMFIC)
Local Char    ORDSYS(250)(1..2)

FICTRA = filpath("tmp",VUE,"tra",APPLI)
If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA,STAT) From ORDSYS
Endif

# Génération du .fde
#ORDSYS(1) = "valfil -s"-APPLI-VUE
#ORDSYS(2)  = FICTRA
#
#Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
ORDSYS(1) = "valfil -s"-DOSSIER-VUE
ORDSYS(2)  = FICTRA

Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
Openi FICTRA Using [LEC_]
Iomode adxifs ""       Using [LEC_]
Iomode adxirs chr$(10) Using [LEC_]
Raz LIGNE , MESSAGE
Rdseq LIGNE Using [LEC_]
If LIGNE<>""
 MESSAGE = mess(78,139,1) : # Erreur en validation de la vue
 MESSAGE += "\|"+LIGNE
 Rdseq LIGNE Using [LEC_]
 MESSAGE += "|\|"+LIGNE
 Rdseq LIGNE Using [LEC_]
 MESSAGE += "|\|"+LIGNE
 Rdseq LIGNE Using [LEC_]
 MESSAGE += "|\|"+LIGNE
Endif
Openi Using [LEC_]
If MESSAGE<>""
 Gosub ERREUR : OK = 0 : End
Endif
OK = 1
End

#-----------------------------------------------------------------------------#
# Suppression d'une vue
#-----------------------------------------------------------------------------#

Subprog SUPVUE_SIL(VUE,APPLI,TYPDBA)
Value Char    VUE , APPLI
Value Integer TYPDBA
Local Integer SILENCE
Goto SUP_VUE

Subprog SUPVUE(VUE,APPLI,TYPDBA)
Value Char    VUE , APPLI
Value Integer TYPDBA

$SUP_VUE
Local Integer STAT , ER
Local Char    MESSAGE(250) , ERM(250) , LIGNE(250)
Local Char    FICTRA(GDIMFIC)
Local Char    ORDSYS(250)(1..2)
Local Char    SUF(10) , FICHIER(GDIMFIC)

FICTRA = filpath("tmp",VUE,"tra",APPLI)
If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA,STAT) From ORDSYS
Endif

# Si ce n'est pas une vue, on se casse
If filinfo(filpath("FIL",VUE,"fde",APPLI),0)<=0
 STAT = 0
Else
 Call VUE_OK(VUE,APPLI,"FIL",STAT) From DOSVUE
Endif
If !STAT : End : Endif

# Suppression de la vue
If filinfo(filpath("FIL",VUE,"viw",APPLI),0)>0
 ORDSYS(1) = "valfil -s -d"-APPLI-VUE
 ORDSYS(2)  = FICTRA
 Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
 Openi FICTRA Using [LEC_]
 Iomode adxifs ""       Using [LEC_]
 Iomode adxirs chr$(10) Using [LEC_]
 Raz LIGNE , MESSAGE
 Rdseq LIGNE Using [LEC_]
 If LIGNE<>""
  MESSAGE = mess(185,125,1) : # Erreur en suppression de la vue
  MESSAGE += "\|"+LIGNE
  Rdseq LIGNE Using [LEC_]
  MESSAGE += "|\|"+LIGNE
  Rdseq LIGNE Using [LEC_]
  MESSAGE += "|\|"+LIGNE
 Endif
 Openi Using [LEC_]
 If MESSAGE<>"" & dim([L]SILENCE)<=0
  Gosub ERREUR : End
 Endif
Endif

# Suppression des fichiers adonix
For SUF = "srf", "fde", "viw","cfg"
 FICHIER = filpath("FIL",VUE,SUF,APPLI)
 If filinfo(FICHIER,0)>=0
  Call EFFACE(FICHIER,STAT) From ORDSYS
 Endif
Next SUF
End

#-----------------------------------------------------#
Subprog VUE_OK(FICHIER,APPLI,REPERT,VUE)
Value Char       FICHIER , APPLI , REPERT
Variable Integer VUE
Local Char    FICSRC(GDIMFIC) , LIGNE(250) , FLAG(10)
FICSRC = filpath(REPERT,FICHIER,"srf",APPLI)
If filinfo(FICSRC,0)<=0
 VUE = 1
Else
 Openi FICSRC Using [VUE]
 Iomode adxifs "" Using [VUE]
 Iomode adxirs chr$(10) Using [VUE]
 Iomode adxium GUTF8 Using [VUE]
 Rdseq LIGNE Using [VUE] : # En-tête
 Rdseq LIGNE Using [VUE] : # Abréviation
 Rdseq FLAG  Using [VUE] : #
 Openi Using [VUE]
 VUE = (FLAG='"#V"')
Endif
End

Funprog ISVIEW(PDOSSIER,PTABLE)
Value    Char    PDOSSIER,PTABLE
Local Char    FICSRC(GDIMFIC) , LIGNE(250) , FLAG(10)
FICSRC = filpath("FIL",PTABLE,"srf",PDOSSIER)
If filinfo(FICSRC,0)<=0
 End 1
Endif
If filinfo(filpath("FIL",PTABLE,"viw",PDOSSIER),0) >= 0 : End 1 : Endif
End 0

#--------------------------------------------------------------------------------#
# Chaine de caractères constituée d'après les occurences d'un champ d'une table
# Utilisé dans les requêtes SQL
#--------------------------------------------------------------------------------#

Funprog FLDVUE(TAB,FLD)
Value Char    TAB : # Table
Value Char    FLD : # Champs (n'est pas le premier utilisé dans le Select si précédé du caractère ",")
Local Integer I , REP , PREM
Local Char    CHAINE(250)
Raz CHAINE , PREM
If FLD<>"" & TAB<>""
 If left$(FLD,1)<>","
  PREM = 1
 Else
  FLD = vireblc(right$(FLD,2),2)
 Endif
 Read [ATZ]CODZONE = TAB ; FLD
 If !fstat
  REP = [F:ATZ]DIME
  Call REPTAB([F:ATZ]CODACT,REP) From DOSSUB
  If REP
   If !PREM
    CHAINE = ", "
   Endif
   CHAINE += FLD+"_0"
   Read [ATY]CODTYP = [F:ATZ]CODTYP
   If !fstat
    REP = abs(REP)
    For I=1 To REP-1
     CHAINE += ", "+FLD+"_"+num$(I)
    Next I
   Endif
  Endif
 Endif
Endif
End CHAINE

#--------------------------------------------------------------------------------#
# Génération d'un script d'après les champs définis dans la vue
# Avec UNION sur les applis mère
#--------------------------------------------------------------------------------#

Funprog AUTO(VUE,TAB)
Value Char    VUE : # Vue à générer
Value Char    TAB : # Table
Local Integer A , K , I , REPET
Local Clbfile CLOB
Gosub LEC_DOS
CLOB = ""
For A=1 To NBDOS
 If A>1
  Append CLOB," UNION "
 Endif
 Append CLOB,"SELECT DISTINCT"
 K = 0
 For [AVD] Where CODVUE=VUE
  K += 1
  If K>1
   Append CLOB," , "
  Else
   Append CLOB," "
  Endif
  If [F:AVD]FLDVUE="DOSSIER"
   Append CLOB,"'"+TBDOS(A)+"'"
  Else
   REPET = [F:AVD]DIME
   Call REPTAB([F:AVD]FLDACT,REPET) From DOSSUB
   If REPET<>0
    For I=0 To REPET-1
     If I>0
      Append CLOB," , "
     Endif
     Append CLOB,[F:AVD]FLDVUE+"_"+num$(I)
    Next I
   Else
    Append CLOB,[F:AVD]FLDVUE+"_0"
   Endif
  Endif
 Next AVD
 Append CLOB," FROM "+TBDOS(A)+"."+TAB
Next A
End CLOB

#-------------------------------------------#
$LEC_DOS
Local Integer I , NBDOS
Local Char    FICAPL(250) , LIGNE(250) , TBDOS(GLONADS)(1..10) , APPLI(GLONADS)
APPLI  = [F:ADS]DOSSIER
FICAPL = filpath("","APL","ini",APPLI)
If filinfo(FICAPL,0)>=0
 Openi FICAPL Using [VUE]
 Rdseq LIGNE Using [VUE]
 While fstat=0
  LIGNE = vireblc(LIGNE,2)
  If left$(LIGNE,10)="adxmother("
   J = instr(1,LIGNE,"=")
   If J
    LIGNE = vireblc(right$(LIGNE,J+1),2)
    LIGNE = seg$(LIGNE,2,len(LIGNE)-1)
    If !find(LIGNE,TBDOS(1..NBDOS)) & filinfo(filpath("","","",LIGNE),0)>=0
     NBDOS += 1
     TBDOS(NBDOS) = LIGNE
    Endif
   Endif
  Endif
  Rdseq LIGNE Using [VUE]
 Wend
 Openi Using [VUE]
Endif
If !find(APPLI,TBDOS)
 NBDOS += 1
 TBDOS(NBDOS) = APPLI
Endif
Return

#--------------------------------------------------------------------------------#
# Affectation des droits sur la table ADICTRT après la création d'un nouvel user
# pour la création de la vue ADICADX
#--------------------------------------------------------------------------------#

Subprog GENDROIT
Local Integer I , NBTAB
Local Char    COMMAND(250) , TBTAB(GLONATB)(1..10)
If dim([F:ADS]DOSSIER)<=0 or [F:ADS]DOSSIER=""
 End
Endif
Gosub LEC_DOS
NBTAB = 1 : TBTAB(NBTAB) = "ADICTRT"
For J=1 To NBTAB
 For I=1 To NBDOS
  If GTRACE<>""
   # Table x/Mise à jour des droits dossier y
   Call ECR_TRACE(mess(106,142,1)-TBTAB(J)-":"-mess(191,139,1)-TBDOS(I),0) From GESECRAN
  Endif
  System COMMAND=adxmac(0)+'@valfil -r'-TBDOS(I)-TBTAB(J)
 Next I
Next J
End

