#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-25054/1 - 2017-07-10 by BAKHA : get reason code when excluding/reinstating line

$ACTION
Case ACTION
    When "DEBUT"       : Gosub DEBUT
    When "OK"         : Gosub OK
Endcase
Return

$DEBUT
[MFGR]REVREASON = PARAM(1)
Return

# if OK clicked, copy revision reason, this is copied to the component line
$OK
  PARAM(1) = [MFGR]REVREASON
Return

