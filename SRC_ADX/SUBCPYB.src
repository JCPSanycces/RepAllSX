Subprog AM_BDFECOCOD(VALEUR)
Variable Char    VALEUR()

  # FQ72121 - MABON 04/03/11 - Le code 060 n'est plus obligatoire
#  If VALEUR<>"" and VALEUR<>"060" Then
#    mkstat=2
#  Endif
End

Subprog AM_SCINUM(VALEUR)
Variable Char    VALEUR()
# Positions 1 and 2 contain the ISO country code
# Positions 3 and 4 contain the check digits
# Positions 5 to 7 contain the Creditor Business Code. When the Creditor Business Code is not used, then the value is set to ‘ZZZ’.
# The Creditor Business Code cannot contain spaces.
# Positions 8 up to 35 contain the country-specific identifier
# Note: the calculation of the check digit requires the following preliminary steps:
# - Disregard positions 5 to 7
# - Take the country-specific part, positions 8 to 35, and delete all non-alphanumeric characters
# - Add the ISO country code and ‘00’ to the right-hand end
# - Convert letters to digits in accordance with conversion table 1 (A=10, B=11, ... Z=35)
# - Apply the check character system MOD 97-10 (see ISO 7064)

Local Char T(27), T2(250), L(2)
Local Integer N, COD

If len(VALEUR)=0 : End : Endif

# - Disregard positions 5 to 7
T = toupper(right$(VALEUR, 8))

# delete all non-alphanumeric characters
For N=1 To len(T)
 L = mid$(T, N, 1)
 COD = ascii(L)
 If (COD>=ascii('0') and COD<=ascii('9')) or (COD>=ascii('A') and COD<=ascii('Z'))
  T2 += mid$(T, N, 1)
 Endif
Next
T = T2

# - Add the ISO country code and ‘00’ to the right-hand end
T +=  left$(VALEUR, 2) + "00"

# - Convert letters to digits in accordance with conversion table 1 (A=10, B=11, ... Z=35)
Raz T2
For N=1 To len(T)
 L = mid$(T, N, 1)
 COD = ascii(L)
 If COD>=ascii('A') and COD<=ascii('Z') # it's a letter, let's convert it
  L = num$(COD-55)
 Endif
 T2 += L
Next

# Apply the check character system MOD 97-10 (see ISO 7064)
# Compute modulo 97 of the number stored in T2
# The number stored in T2 is split in blocks of at most 9 digits to prevent overflow errors when converting to integer

Repeat
 T2 = num$(mod(val(left$(T2, 9)), 97)) + right$(T2, 10)
Until len(T2)<=9
N = 98 - mod(val(T2), 97)
L = num$(N)
If len(L)=1 : L = '0' + L : Endif

If L <> mid$(VALEUR, 3, 2)
 GMESSAGE = mess(83,123,1)
 mkstat=2
Endif
End

