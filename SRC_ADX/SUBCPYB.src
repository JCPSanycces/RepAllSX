$INIDIE
If dim([M:CPY3]DIE)<=0 : Return : Endif
Raz [M:CPY3]DIE
Raz [M:CPY3]CCE
GSOCIETE = [M]CPY
Call SETPLAN2(ACMCUR,NBPLAN,GPLAN,REFTYP,NBAXE,[M:CPY3]DIE,OBLIG) From CPTDIV
[M:CPY3]BASTAB = NBAXE
For I=0 To [M:CPY3]BASTAB-1
 If find([M:CPY3]DIE(I),[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
  For J=0 To dim([F:CPY]DIE)-1
   If [F:CPY]DIE(J)=[M:CPY3]DIE(I)
    [M:CPY3]CCE(I) = [F:CPY]CCE(J)
    [M:CPY3]OBYDIE(I) = [F:CPY]OBYDIE(J)
    [M:CPY3]DACDIE(I) = [F:CPY]DACDIE(J)
    Break
   Endif
  Next J
 Else
  [M:CPY3]OBYDIE(I) = 1
  [M:CPY3]DACDIE(I) = 2
 Endif
 If ACTION="APRES_MODIF" & COUZON="ACM" & GREP="C"
  [M:CPY3]DACDIE(I) = 2
 Endif
Next I
Return


