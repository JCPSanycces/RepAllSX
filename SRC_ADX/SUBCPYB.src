#JASMI - 2016-09-07 - ISSUE 118387 - START
### Added for HCM
If func CHECK_HRMOD()
  If OK & filinfo(filpath("FIL","EMPLOID","fde"),0)>0 & filinfo(filpath("FIL","EMPLOCTR","fde"),0)>0
   Local File EMPLOID  [ID]
   Local File FACILITY [FCYB]
   Link [ID] With [F:FCYB]FCY0=[F:ID]FCYORI As [LNK] Where [F:FCYB]LEGCPY=[M]CPY
  # For [ID] Where CPY=[M]CPY
  #  OK = 0 : Break
  # Next
   For [F:LNK]
    OK = 0 : Break
   Next
   Close File [ID]
   If OK Then
     Local File EMPLOCTR  [CTR]
     Link [F:CTR] With [F:FCYB]FCY0=[F:CTR]ETRFCY As [LNK] Where [F:FCYB]LEGCPY=[M]CPY
     For [F:LNK]
      OK = 0 : Break
     Next
     Close File [CTR]
   Endif
   Close File [FCYB]
  Endif

  If OK & filinfo(filpath("FIL","CAISSE","fde"),0)>0
   Local File CAISSE [PCA]
   For [PCA] Where CPY=[M]CPY
    OK = 0 : Break
   Next
   Close File [PCA]
  Endif
Endif
#JASMI - 2016-09-07 - ISSUE 118387 - END

If !OK
 GMESSAGE = mess(9,123,1) : # Modification impossible
 mkstat = 1 : Return
Endif
GCURLEG = VALEUR

#JOJAC - 2016-08-25 - X3PEOP-1318 - START
If func CHECK_HRMOD()>0
  Gosub STYLE
Endif
#JOJAC - 2016-08-25 - X3PEOP-1318 - END

Return

