#DIRAS - 2017/04/04 - X3-11731 - START
If GMODU(2)=2 | GMODU(15)=2 & [M]ACM<>""
#If GMODU(2)=2 & [M]ACM<>""
#DIRAS - 2017/04/04 - X3-11731 - END
 Read [GCM]GCM0 = [M]ACM
 VALEUR = [F:GCM]CUR([F:GCM]GENLEDTYP-1)
 mkstat = 2
Endif
