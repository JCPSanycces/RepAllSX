$VERIF_MOD
# Initialisation FLGCPYLEG pour vérifier que la modification de la fiche société concerne le
# Flag "Société juridique"
# Initialisation CPYLEG pour vérifier que la modification de la fiche société concerne le
# champ "Legislation"
Local Integer FLGCPYLEG, CPYLEG
If [F:CPY]CPYLEGFLG<>[M:CPY1]CPYLEGFLG & [F:CPY]CPYLEGFLG=2
 [L]FLGCPYLEG = 1
Else
 [L]FLGCPYLEG = 0
 If dim([M:CPY1]LEG)>0 & [F:CPY]LEG<>[M:CPY1]LEG
  [L]CPYLEG = 1
 Else
  [L]CPYLEG = 0
 Endif
Endif
# On ne peut pas changer le modèle comptable si la société est mouvementée (sauf si le nouveau modèle
# a un paramétrage identique à l'ancien modèle : le sous-programme VERFMDL vérifie cela)
# On recharge la table CPY2 seulement si nécessaire
If [F:CPY2]CPY<>[M]CPY : Read [F:CPY2]CPY0=[M]CPY : Endif
If [M:CPY3]ACM<>[F:CPY2]ACM
 Local Integer DIFF : DIFF = 0
 Call VERFMDL([F:CPY2]ACM,[M:CPY3]ACM,DIFF)
 If DIFF
  Local Integer OKMVT
  Call VERFMVT([M]CPY,OKMVT)
  If !OKMVT
   # Changement de modèle comptable impossible
   Call ERREUR(mess(180,105,1)) From GESECRAN
   [M:CPY3]ACM = [F:CPY2]ACM : Affzo [CPY3]ACM
   OK = 0
  Endif
 Endif
Endif
Return

$AVANT_MODFIC
# Données légales - Changement d'EECNUM
#** Legal datas
If find(GCURLEG,"GER","AUT")
GOON=0
 If [F:ADI]NUMTAB<>959 or [F:ADI]CODE<>GCURLEG
  Read [ADI]CODE = 959;GCURLEG
  If !fstat & [F:ADI]A1<>"" : GOON=1 : Endif
 Else
  If [F:ADI]A1<>"" : GOON=1 : Endif
 Endif
 If GOON
  Local Integer IMPACT : IMPACT=0
  Local Integer ARYSET : ARYSET=0
  For I=0 To dim([F:CPY]GEREECNUM)-1
   If [F:CPY]GEREECNUM(I)<>""
    ARYSET=1 : Break
   Endif
  Next
  If !ARYSET :# les GEREECNUM n'ont pas encore été renseignés ou sont vides
   If [M:CPY1]EECNUM<>""
    [F:CPY]GERDEFVAL(0)=2
    [F:CPY]GEREECNUM(0)=[M:CPY1]EECNUM
   Endif
  Else :#  les GEREECNUM ont déjà été renseignés
   Local Integer A,B
   Local Integer INDOLD,INDNEW
   A=([F:CPY]EECNUM<>"")
   B=([M:CPY1]EECNUM<>"")
   Case A
    When 0 :# old vide
     If B :# new renseigné
      INDNEW = find([M:CPY1]EECNUM,[F:CPY]GEREECNUM(0..7))
      If INDNEW :# new déjà présent dans GEREECNUM, on ne fait rien
      Else :#New pas présent dans GEREECNUM, on l'ajoute
       I=0
       While [F:CPY]GEREECNUM(I)<>""
        I+=1
       Wend
       [F:CPY]GEREECNUM(I)=[M:CPY1]EECNUM
       IMPACT=1
      Endif
     Else
      #new vide => on ne fais rien
     Endif
    When 1 :# old renseigné
     INDOLD = find([F:CPY]EECNUM,[F:CPY]GEREECNUM(0..7))
     If B :#new renseigné
      INDNEW = find([M:CPY1]EECNUM,[F:CPY]GEREECNUM(0..7))
      If INDNEW :#new déjà présent
       #EECNUM present dans GEREECNUM on le coche
      Else :#new pas présent=>on ajoute
       I=0
       While [F:CPY]GEREECNUM(I)<>""
        I+=1
       Wend
       [F:CPY]GEREECNUM(I)=[M:CPY1]EECNUM
       IMPACT=1
      Endif
     Else :# New vide
      #-----
      If INDOLD :#on supprime l'old EECNUM
       For I=INDOLD-1 To 6
        [F:CPY]GERDEFVAL(I)=[F:CPY]GERDEFVAL(I+1)
        [F:CPY]GEREECNUM(I)=[F:CPY]GEREECNUM(I+1)
        [F:CPY]GERTAXCEN(I)=[F:CPY]GERTAXCEN(I+1)
        [F:CPY]GERTAXIDT(I)=[F:CPY]GERTAXIDT(I+1)
       Next
       [F:CPY]GERDEFVAL(7)=1
       [F:CPY]GEREECNUM(7)=""
       [F:CPY]GERTAXCEN(7)=""
       [F:CPY]GERTAXIDT(7)=""
       Local Integer DEFOK : DEFOK=0
       For I=0 To 6
        If [F:CPY]GERDEFVAL(I)=2
         DEFOK=1 : Break
        Endif
       Next
       If !DEFOK
        [F:CPY]GERDEFVAL(0)=2
       Endif
       IMPACT=1
      Endif
      #-----
     Endif
   Endcase
  Endif
  If IMPACT
   #Attention ! Impacts sur les données légales. Veuillez les vérifier
   Call MESSAGE(mess(156,104,1)) From GESECRAN
  Endif
 Endif
Endif

Gosub SDD_AMENDMENT
Return

##############################################################################
# SDD : Amendment : Update the HISTOAMD table
##############################################################################

$SDD_AMENDMENT
Local Char SDD(1)
Call PARAML([M]CPY, "SDDMGT", SDD) From ADOVAL
If SDD<>"2" : Return : Endif

Local Char    V_FLDCOD(GLONAVA)(1..2)
Local Char    V_OLDFLD(50)(1..2)
Local Char    V_NEWFLD(50)(1..2)
Local Integer I, WRK1, WRK2
If !clalev([F:MDT]) : Local File MANDATE  [MDT] : Endif
If !clalev([F:HAM]) : Local File HISTOAMD [HAM] : Endif

Raz V_FLDCOD
Raz WRK1, WRK2

If [F:CPY]CPYNAM<>[M]CPYNAM
 V_FLDCOD(1) = "CPYNAM"
 V_OLDFLD(1) = evalue("[F:CPY]"+V_FLDCOD(1))
 V_NEWFLD(1) = evalue("[M]"+V_FLDCOD(1))
Endif

If [F:CPY]SCINUM<>[M]SCINUM
 V_FLDCOD(2) = "SCINUM"
 V_OLDFLD(2) = evalue("[F:CPY]"+V_FLDCOD(2))
 V_NEWFLD(2) = evalue("[M]"+V_FLDCOD(2))
Endif

# No amended field updated
If V_FLDCOD(1)="" & V_FLDCOD(2)="" : Return : Endif

# Loop if some approved or adjorned mandates exist with this creditor (company)
For [MDT] Where CPY=[M]CPY & (STA=2 | STA=3)
 GOK = func SUBMDT.AMENDEMENT([M]CPY,[F:MDT]UMRNUM,V_FLDCOD,V_OLDFLD,V_NEWFLD,0,WRK1,WRK2)
 If GOK<=0 : Break : Endif
Next
If GOK<=0 : Return : Endif

If WRK1 : Call WORKFLOW(1, "DIV", "", "") From AWRK : Endif
If WRK2 : Call WORKFLOW(1, "AMD", "", "") From AWRK : Endif

 # NNE amendment (NTLMIGIDT field)

If [F:CPY]SCINUM<>[M]SCINUM
 Raz V_FLDCOD, WRK1, WRK2
 # Initial mandate with the migration flag ticked
 Filter [MDT] Where CPY=[M]CPY & STA=1 & MIGFLG=2
 For [F:MDT]
  # The NNE isn't encapsulated in the new SCINUM
  If [F:MDT]NTLMIGIDT<>mid$([M]SCINUM,8,6)
   V_FLDCOD(1) = "SCINUM"
   V_OLDFLD(1) = [F:MDT]NTLMIGIDT
   V_NEWFLD(1) = [M]SCINUM
   WRK2 = 9 :# Indicates that this amendment concerns NNE
   GOK = func SUBMDT.AMENDEMENT([F:MDT]CPY,[F:MDT]UMRNUM,V_FLDCOD,V_OLDFLD,V_NEWFLD,0,WRK1,WRK2)
   If GOK<1 : Break : Endif
  Elsif [F:MDT]NTLMIGIDT<>mid$([F:CPY]SCINUM,8,6)
   # The NNE is encapsulated in the new SCINUM but wasn't encapsulated in the previous SCINUM.
   # A recording exists and must be deleted
   Delete [HAM]HAM0=[F:MDT]CPY;[F:MDT]UMRNUM;"SCINUM";""
   If fstat=1 : GOK=-1 : Break : Endif
  Endif
 Next
 Filter [MDT]
Endif

Return

Subprog VERFMDL(OLDMDL,NEWMDL,DIFF)
Value    Char OLDMDL()
Value    Char NEWMDL()
Variable Integer DIFF
If clalev([F:ATZ2])=0 : Local File ATABZON [ATZ2] : Endif
#JOJAC - 2016-08-25 - X3PEOP-1318 - START
#If clalev([F:GCM2])=0 : Local File GACM    [GCM2] : Endif
#If clalev([F:GCM3])=0 : Local File GACM    [GCM3] : Endif
#FRLAA - 2016-05-24 - REQUIREMENT 114309 US 11 - START
If func CHECK_HRMOD()>0
  If clalev([F:GCM2])=0 : Local File =GTABCPT+"GACM"    [GCM2] : Endif
  If clalev([F:GCM3])=0 : Local File =GTABCPT+"GACM"    [GCM3] : Endif
Else
  If clalev([F:GCM2])=0 : Local File GACM    [GCM2] : Endif
  If clalev([F:GCM3])=0 : Local File GACM    [GCM3] : Endif
Endif
#FRLAA - 2016-05-24 - REQUIREMENT 114309 US 11 - END
#JOJAC - 2016-08-25 - X3PEOP-1318 - END

Local Integer I
Read [GCM2]GCM0 = OLDMDL
Read [GCM3]GCM0 = NEWMDL

DIFF = 0
For [ATZ2]CODZONE Where CODFIC="GACM" & !find(CODZONE,"GCM","CREDAT","CREUSR","CRETIM","UPDDAT","UPDUSR","UPDTIM","DES","DESSHO","DESTRA","SHOTRA","EXPNUM","CREDATTIM","UPDDATTIM","AUUID")
 If [F:ATZ2]DIME = 1
  If evalue("[F:GCM2]"+[F:ATZ2]CODZONE)<>evalue("[F:GCM3]"+[F:ATZ2]CODZONE)
   DIFF = 1 : Break
  Endif
 Else
  For I=0 To [F:ATZ2]DIME-1
   If evalue("[F:GCM2]"+[F:ATZ2]CODZONE+"("+num$(I)+")")<>evalue("[F:GCM3]"+[F:ATZ2]CODZONE+"("+num$(I)+")")
    DIFF = 1 : Break 2
   Endif
  Next
 Endif
Next
End

Subprog VERFMVT(SOC,OK)
Value    Char    SOC
Variable Integer OK
#JOJAC - 2016-08-25 - X3PEOP-1318 - START
#Local File GACCENTRY [HAE]
#FRLAA - 2016-05-24 - REQUIREMENT 114309 US 11 - START
#FQ92876-US2483
If func CHECK_HRMOD()>0
  Local File =GTABCPT+"GACCTMP" [HAE]
Else
  Local File GACCENTRY [HAE]
Endif
#Local File GACCENTRY [HAE]
#FRLAA - 2016-05-24 - REQUIREMENT 114309 US 11 - END
#JOJAC - 2016-08-25 - X3PEOP-1318 - END
Filter [HAE] Where CPY=SOC
Read [HAE]First
Filter [HAE]
If fstat<=2
 OK = 0
Else
 OK = 1
Endif
End

$MODIF
If GMODU(2)=2  :# Compta
 If DAS
  Gosub CREDCP
  If GOK < 1 : Return : Endif
 Endif
 If CPT
  If [L]FLGCPYLEG
   If filinfo(filpath("FIL","GAJOUSTA","fde"),0)>0
    Gosub DELJOUSTA
    If GOK < 1 : Return : Endif
   Endif
  Elsif [L]CPYLEG
   If filinfo(filpath("FIL","GAJOUSTA","fde"),0)>0
    Gosub UPDJOUSTA
    If GOK < 1 : Return : Endif
   Endif
  Endif
 Endif
Endif
If [M:CPY3]ACM<>[F:CPY2]ACM
  #JOJAC - 2017-03-23 - X3-11731 - START
  #If filinfo(filpath("FIL","RUBASSDEF","fde"),0)>0
  If filinfo(filpath("FIL","RUBASSDEF","fde",nomap),0)>0
  #JOJAC - 2017-03-23 - X3-11731 - END
    Gosub MAJ_RUBASSO
    If GOK < 1 : Return : Endif
  Endif
Endif
Return

################################################################
# Création des deux premiers exercices et des périodes associées
################################################################
$CREPER
If [M:CPY1]CPYLEGFLG <>2 : Return : Endif

Local Integer EXER  : # Exercice
Local Integer PERIO : # Période
Local Integer NBPER : # Compteur nombre de périodes créées
Local Integer PERMAX
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
PERMAX = 12
Read [ACV]CODACT = "PER"
If !fstat : PERMAX = min(12,[F:ACV]DIME) : Endif

Read [CPY]CPY0=[M:CPY0]CPY
Read [GCM]GCM0=[CPY]ACM

# pour tous les types de référentiels
For N=1 To len(mess(0,2644,1))
 If [F:GCM]LED(N-1)<>""
  For EXER=1 To 2
   Raz [FIY]
   [F:FIY]CPY    = [M:CPY0]CPY
   [F:FIY]LEDTYP = N # [F:AST]LANMES
   [F:FIY]FIYNUM = EXER
   [F:FIY]FIYSTR = addmonth([M:CPY3]STRPER,12*(EXER-1))
   [F:FIY]FIYEND = addmonth([M:CPY3]STRPER,12*EXER)-1
   [F:FIY]FIYSTA = 1
   [F:FIY]CREDAT = date$
   [F:FIY]CREUSR = GUSER
   If [F:GCM]CFMAUT(N-1) = 2 : [F:FIY]LEDTYPAUT = 2 : Endif
   Write [FIY]
   If fstat
    GOK=0 : Call FSTA("FIY") From GLOCK : Break 2
   Endif
   For PERIO=1 To PERMAX
    Raz [PER]
    [F:PER]CPY    = [M:CPY0]CPY
    [F:PER]LEDTYP = N
    [F:PER]FIYNUM = EXER
    [F:PER]PERNUM = PERIO
    [F:PER]PERSTA = 1
    [F:PER]PERSTOSTA = 1
    [F:PER]PERSTR = addmonth([F:FIY]FIYSTR,PERIO-1)
    If PERIO=PERMAX
     [F:PER]PEREND = [F:FIY]FIYEND
    Else
     [F:PER]PEREND = addmonth([F:FIY]FIYSTR,PERIO)-1
    Endif
    [F:PER]LEDTYPAUT = [F:FIY]LEDTYPAUT
    Write [PER]
    If fstat
     GOK=0 : Call FSTA("PER") From GLOCK : Break 3
    Endif
   Next PERIO
  Next EXER
 Endif
Next N
If GOK<1 : Return : Endif
Return

########################################################################
## En création d'une société, on va créer pour chaque journal
## les enregistrements dans GAJOUSTA (Etat journal par périodes)
########################################################################
$CREJOUSTA
If [M:CPY1]CPYLEGFLG <>2 : Return : Endif
For [JOU]JOU0(1)
 [F:JST]CPY       = [M:CPY0]CPY
 [F:JST]JOU       = [F:JOU]JOU
 [F:JST]OPGSTRDAT = [M:CPY3]STRPER
 [F:JST]OPGENDDAT = [0/0/0]
 If dim([M:CPY1]LEG)>0
  [F:JST]LEG      = [M:CPY1]LEG
 Else
  [F:JST]LEG      = GDOSLEG
 Endif
 Call FLDCRE("JST") From OBJDIV
 Write [JST]
 If fstat
  GOK=0 : Call FSTA("JST") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif
Return

$DELJOUSTA
Delete [JST] Where CPY=[M:CPY0]CPY
If fstat=1
 GOK = -1
 GLOCK = "$GAJOUSTA"-[M:CPY0]CPY
 Return
Elsif fstat>5
 GOK = 0
 Call RSTA("JST",[M:CPY0]CPY) From GLOCK
 Return
Endif
Return

$UPDJOUSTA
If dim([M:CPY1]LEG)>0
 Update [JST] Where CPY=[M:CPY0]CPY With LEG=[M:CPY1]LEG, UPDDAT=date$, UPDUSR=GUSER, EXPNUM=[C]EXPORT
Endif
If fstat=1
 GOK = -1
 GLOCK = "$GAJOUSTA"-[M:CPY0]CPY
 Return
Elsif fstat
 GOK = 0
 Call RSTA("JST",[M:CPY0]CPY) From GLOCK
 Return
Endif
Return

##########################################################
$CREDCP
Call CREDCP([M:CPY0]CPY) From TRTDCP
If GOK <1 : Return : Endif
Return
##############################################################
## Si le modèle de la société a été modifié, il faut mettre à
## jour les tables des associations (module immobilisations)
##############################################################
$MAJ_RUBASSO
If clalev([F:RDE])=0 : Local File RUBASSDEF    [RDE] : Endif
If clalev([F:RDP])=0 : Local File RUBASSDEFP   [RDP] : Endif
If clalev([F:RVA])=0 : Local File RUBASSVAL    [RVA] : Endif
If clalev([F:RVP])=0 : Local File RUBASSVALP   [RVP] : Endif
Filter [RDE] Where CPY=[M:CPY0]CPY
For [RDE]
 [F:RDE]ACM = [M:CPY3]ACM
 [F:RDE]NUMASS= sum(num$([F:RDE]REFOBJ),num$([F:RDE]DETAAS),[F:RDE]ACM,[F:RDE]CPY)
 Rewrite [RDE]
 If fstat
  GOK=0 : Call FSTA("RDE") From GLOCK : Break
 Endif
Next
Filter [RDE]
If GOK<1 : Return : Endif


Filter [RDP] Where CPY=[M:CPY0]CPY
For [RDP]
 [F:RDP]ACM = [M:CPY3]ACM
 [F:RDP]NUMASS= sum(num$([F:RDP]REFOBJ),num$([F:RDP]DETAAS),[F:RDP]ACM,[F:RDP]CPY)
 Rewrite [RDP]
 If fstat
  GOK=0 : Call FSTA("RDP") From GLOCK : Break
 Endif
Next
Filter [RDP]
If GOK<1 : Return : Endif

Filter [RVA] Where CPY=[M:CPY0]CPY
For [RVA]
 [F:RVA]ACM = [M:CPY3]ACM
 [F:RVA]NUMASS= sum(num$([F:RVA]REFOBJ),num$([F:RVA]DETAAS),[F:RVA]ACM,[F:RVA]CPY)
 Rewrite [RVA]
 If fstat
  GOK=0 : Call FSTA("RVA") From GLOCK : Break
 Endif
Next
Filter [RVA]
If GOK<1 : Return : Endif

Filter [RVP] Where CPY=[M:CPY0]CPY
For [RVP]
 [F:RVP]ACM = [M:CPY3]ACM
 [F:RVP]NUMASS= sum(num$([F:RVP]REFOBJ),num$([F:RVP]DETAAS),[F:RVP]ACM,[F:RVP]CPY)
 Rewrite [RVP]
 If fstat
  GOK=0 : Call FSTA("RVP") From GLOCK : Break
 Endif
Next
Filter [RVP]
If GOK<1 : Return : Endif
Return

