$SETBOUT
#   Données légales/Législation
#** Legal datas/Legislation
LEGOK=0
If [M:CPY1]CPYLEGFLG=2
 If [F:ADI]NUMTAB<>959 or [F:ADI]CODE<>GCURLEG
  Read [ADI]CODE = 959;GCURLEG
  If !fstat & [F:ADI]A1<>"" :  LEGOK=1 : Endif
 Else
  If [F:ADI]A1<>"" : LEGOK=1 : Endif
 Endif
Else :# Group
  If clalev([F:AGC])=0  : Local File AGRPCPY [AGC]  : Endif
  If clalev([F:CPY2])=0 : Local File COMPANY [CPY2] : Endif

  Filter [AGC] Where GRP=[M:CPY0]CPY
  N=0
  GOON=1
  Local Char LLG(GLONADI)(1..max(1,nbrecord([AGC])))
  For [AGC]AGC0
   Read [F:CPY2]CPY0 = [F:AGC]CPY
   If !fstat
    N+=1
    LLG(N)=[F:CPY2]LEG
    If N>1
     If LLG(N)<>LLG(N-1)
      GOON=0 : Break
     Endif
    Endif
   Endif
  Next
  Filter [AGC]

  If GOON
   If [F:ADI]NUMTAB<>959 or [F:ADI]CODE<>LLG(1)
    Read [ADI]CODE = 959;LLG(1)
    If !fstat & [F:ADI]A7<>"" : LEGOK=1 : Endif
   Else
    If [F:ADI]A7<>"" : LEGOK=1 : Endif
   Endif
  Endif
Endif
If REP="C" | REP="D" | !LEGOK
 Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
Return

