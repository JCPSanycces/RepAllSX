#Call CONTDEV(VALEUR,[M]STRPER) From TRTDEV
End

Subprog AS_STRPER(VALEUR)
Variable Date    VALEUR
If [M:CPY1]CPYLEGFLG<>2
 mkstat = 1 : End
Endif
If VALEUR = [0/0/0] : VALEUR = gdat$(1,1,year(date$)) : Endif
If !find(GREP,"C","D")
 mkstat = 2 : End
Endif
End

Subprog AS_ACCCOD(VALEUR)
Variable Char     VALEUR
If [M:CPY1]CPYLEGFLG<>2 : mkstat = 2 : Endif
End

# ajout pyramide des sites attachés à la société
$FILL_PYRAMIDE
Local Char WCPY

  If !clalev([M:CPYP]) Then Return Endif
  # Vider le XSL des composants
  Effzo [M:CPYP]5

  If !clalev([F:FCYP]) Then Local File FACILITY [FCYP] Endif

  # Recherche des sites associés à la société
  Read [FCYP]FCY1 = [M:CPY0]CPY
  If fstat : FIN = 1 : Return : Endif

  If dim(L)<0 Then
    Local Integer L, WLEVEL, WLIGNE, WPLIGNE
  Endif
  nolign  = 1
  L       = nolign -1
  WLEVEL  = 0 : WLIGNE  = 0 : WPLIGNE = 0
  WCPY    = [M:CPY0]CPY

  Gosub LISTE_IMAGES
  Gosub ADD_CPY

  WLEVEL += 1
  Gosub ADD_FCY

  [M:CPYP]NBLIG = L+1
  Affzo [M:CPYP]
Return

$LISTE_IMAGES
Local Char WICO_CPY(30), WICO_FCY(30), WICO_FCY_MAIN(30)

#  If func CTL_FIC_IMAGE("group.gif")=2
  If func CTL_FIC_IMAGE("societe.gif")=2
    WICO_CPY = "societe.gif"
  Else
    WICO_CPY = "mvt2.gif"
  Endif
#  If func CTL_FIC_IMAGE("head.gif")=2
  If func CTL_FIC_IMAGE("site.gif")=2
    WICO_FCY = "site.gif"
  Else
    WICO_FCY = "mvt2.gif"
  Endif
#  If func CTL_FIC_IMAGE("element.gif")=2
  If func CTL_FIC_IMAGE("siteprinc.gif")=2
    WICO_FCY_MAIN = "siteprinc.gif"
  Else
    WICO_FCY_MAIN = "mvt2.gif"
  Endif
Return

Funprog CTL_FIC_IMAGE(LNOMIMAGE)
Value Char LNOMIMAGE
Local Integer WOK : WOK=2
Local Char WREPERT(200),WDIRSEP

  Case GOS(1)
    When "dos"   : WDIRSEP = "\"
    When Default : WDIRSEP = "/"
  Endcase

  WREPERT=filpath(nomap+WDIRSEP+"RES","","","X3_PUB")
  If LNOMIMAGE<>"" & filinfo(WREPERT+WDIRSEP+LNOMIMAGE,0)<0
    WOK = 1
  Endif
End WOK

$ADD_CPY
  [M:CPYP]LIBL1(L)  = WCPY            : # Texte principal
  [M:CPYP]LIBL2(L)  = [M:CPY0]CPYNAM  : # info bulle
  [M:CPYP]IMG(L)    = WICO_CPY
  [M:CPYP]LIGNE(L)  = WLIGNE
  [M:CPYP]PARLIN(L) = -1
  [M:CPYP]LEV(L)    = WLEVEL
  [M:CPYP]CPYP(L)   = WCPY
  # FQ100614 - 07/07/14 - Affectation du code pays pour la société
  [M:CPYP]CRYP(L)   = [M:CPY1]CRY
  Gosub ADD_HNOM
Return

$ADD_FCY
  For [FCYP]FCY0 Where LEGCPY=WCPY
    WLIGNE += 1
    L += 1
    [M:CPYP]LIBL1(L)  = [F:FCYP]FCY     : # Texte principal
    If [F:FCYP]FCY = [M:CPY1]MAIFCY Then
      If [F:FCYP]FCYNAM<>"" Then
        [M:CPYP]LIBL2(L)  = [F:FCYP]FCYNAM  : # info bulle
      Else
        [M:CPYP]LIBL2(L)  = [F:FCYP]FCY   : # info bulle
      Endif
      [M:CPYP]IMG(L)    = WICO_FCY_MAIN
    Else
      If [F:FCYP]FCYNAM<>"" Then
        [M:CPYP]LIBL2(L)  = [F:FCYP]FCYNAM  : # info bulle
      Else
        [M:CPYP]LIBL2(L)  = [F:FCYP]FCY   : # info bulle
      Endif
      [M:CPYP]IMG(L)    = WICO_FCY
    Endif
    [M:CPYP]LIGNE(L)  = WLIGNE
    [M:CPYP]PARLIN(L) = WPLIGNE
    [M:CPYP]LEV(L)    = WLEVEL
    [M:CPYP]CPYP(L)   = WCPY
    [M:CPYP]FCYP(L)   = [F:FCYP]FCY
    [M:CPYP]CRYP(L)   = [F:FCYP]CRY
    Gosub ADD_HNOM
  Next
Return

$ADD_HNOM
  [M:CPYP]KEYC(L)      = num$([M:CPYP]LEV(L))+"-"+[M:CPYP]CPYP(L) +"-"+ [M:CPYP]FCYP(L)
  If [M:CPYP]PARLIN(L)<>-1
    [M:CPYP]PARKEY(L) = [M:CPYP]KEYC([M:CPYP]PARLIN(L))
  Else
    [M:CPYP]PARKEY(L) = ""
  Endif
  # Niveau plié/déplié
  If dim([M:CPYP]EXPFLG)>0
    If [M:CPYP]PARLIN(L) =-1
      [M:CPYP]EXPFLG(L) = 2
    Else
      # le niveau sera présenté Plié avec la valeur 1, et non 0
      [M:CPYP]EXPFLG(L) = 1
    Endif
  Endif
Return

$FIN
  If dim(GZONCOUP)>0 Then Kill GZONCOUP Endif
Return

