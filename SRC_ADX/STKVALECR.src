#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################################
# Sous-programmes de gestion des écrans de travail pour la valorisation
######################################################################################
#<gen>
# COPSDP2SVWVAL : copie les valeurs de SDP vers SVW en multipliant par un coef
# COPSVW : additionne ou copie les valeurs d'une ligne SVW
#          vers une autre en appliquant un coef
#          PADD = 1 : addition
#          PORDVAL : modulo 1 = Sur les valeurs d'ordre
#                    modulo 2 = Sur les valeurs de valo
# COPSVWD : additionne ou copie les valeurs d'une ligne SVWD (valeurs d'entrée d'un transfert inter-sites)
#           vers une autre en appliquant un coef
#           PADD = 1 : addition
#           PORDVAL : modulo 1 = Sur les valeurs d'ordre
#                     modulo 2 = Sur les valeurs de valo
# COPVAL2ORD : Copie les valeurs des champs de [SVW] Vxx vers Oxx
# SJV2SVW : Copie les valeurs de [F:SJV] et [F:STJ] vers le masque [M:SVW]
# SVW2SJV : Copie les valeurs de [M:SVW] vers [F:SJV]
# SVWD2SJV : Copie les valeurs de [M:SVWD] (valeurs d'entrée inter-sites) vers [F:SJV]
#</gen>
######################################################################################


#######################################################
# RAZTABVALW: Remet à 0 le tableau de VALW
#######################################################
Subprog RAZTABVALW
If clalev([M:VALW])
    Local Char LTMP1(30), LTMP2(30)    # ZONPRI contient aussi l'abréviation du masque
    LTMP1 = [M:VALW]ZONPRI
    LTMP2 = [M:VALW]ZONPRIORD
    Raz [M:VALW]
    [M:VALW]ZONPRI = LTMP1
    [M:VALW]ZONPRIORD = LTMP2
Endif
End

#######################################################
# COPSDP2SVWVAL : copie les valeurs de SDP vers SVW en multipliant par un coef
#######################################################
# Paramètres E : PIND = Indice de la ligne SVW à remplir
#                PCOE = coefficient multiplicateur
#                PNUMVLT = n° méthode de valo (1=première méthode)
#                                             (2=2ème méthode)
#                                             (3 ou 0 = les 2 méthodes)
#                PARR = arrondi
#######################################################
Subprog COPSDP2SVWVAL(PIND,PCOE)
Value Integer PIND
Value Decimal PCOE
If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
# Issue 80993 - 2012-05-10 by CCC
#If GRNDVAL = 0 : GRNDVAL = 10^-6 : Endif
Call INIRNDVAL("","") From STKVALECR

Call COPSDP2SVWVALA_2(PIND,PCOE,GRNDVAL,0)

End

Subprog COPSDP2SVWVAL_2(PIND,PCOE,PNUMVLT)
Value Integer PIND
Value Decimal PCOE
Value Integer PNUMVLT

If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
# Issue 80993 - 2012-05-10 by CCC
#If GRNDVAL = 0 : GRNDVAL = 10^-6 : Endif
Call INIRNDVAL("","") From STKVALECR

Call COPSDP2SVWVALA_2(PIND,PCOE,GRNDVAL,PNUMVLT)

End

Subprog COPSDP2SVWVALA(PIND,PCOE,PARR)
Value Integer PIND
Value Decimal PCOE
Value Decimal PARR

Call COPSDP2SVWVALA_2(PIND,PCOE,PARR,0)

End

Subprog COPSDP2SVWVALA_2(PIND,PCOE,PARR,PNUMVLT)
Value Integer PIND
Value Decimal PCOE
Value Decimal PARR
Value Integer PNUMVLT

Local Integer I
Local Decimal LTABVAL(1+GACTMAT+GACTMAC+GACTLAB+1+1+4+1)
Local Decimal LTMPVAL
Local Mask SAIDECPRI [SDPX]

If (mod(PNUMVLT,2)=1 | PNUMVLT=0) & clalev([M:SDP])

    [M:SDPX] = [M:SDP]
    Call LOADVAR(LTABVAL, "[M:SDPX]", 0, "", PCOE, 0, 0) From STKVALECR
    LTMPVAL = [M:SVW]AMTVAL(PIND)
    Call REPVAL(LTMPVAL,LTABVAL, PARR, LTABVAL) From STKVALECR
    Call LOADFIC("[M:SDPX]", LTABVAL, "", "CST", 1, 0) From STKVALECR

    #---- Matière ----#
    For I=0 To GACTMAT-1
        [M:SVW]VMATCST(PIND*GACTMAT+I)  = arr([M:SDPX]MATCST(I),PARR)
    Next

    [M:SVW]VMATTOT(PIND)   = sum([M:SVW]VMATCST(PIND*GACTMAT..(PIND+1)*GACTMAT-1))

    [M:SVW]VOVEMATTOT(PIND)= arr([M:SDPX]OVEMATCST,PARR)

    #---- Machine ----#
    For I=0 To GACTMAC-1
        [M:SVW]VMACCST(PIND*GACTMAC+I)  = arr([M:SDPX]MACCST(I),PARR)
    Next

    [M:SVW]VMACTOT(PIND)   = sum([M:SVW]VMACCST(PIND*GACTMAC..(PIND+1)*GACTMAC-1))

    [M:SVW]VOVEMACTOT(PIND)= arr([M:SDPX]OVEMACCST,PARR)

    #---- Main d'oeuvre ----#
    For I=0 To GACTLAB-1
        [M:SVW]VLABCST(PIND*GACTLAB+I)  = arr([M:SDPX]LABCST(I),PARR)
    Next

    [M:SVW]VLABTOT(PIND)   = sum([M:SVW]VLABCST(PIND*GACTLAB..(PIND+1)*GACTLAB-1))

    [M:SVW]VOVELABTOT(PIND)= arr([M:SDPX]OVELABCST,PARR)

    #---- Sous-traitance ----#
    [M:SVW]VSCOTOT(PIND)   = arr([M:SDPX]SCOTOT,PARR)
    [M:SVW]VOVESCOTOT(PIND)= arr([M:SDPX]OVESCOCST,PARR)

    #---- Eléments de facture ----#
    [M:SVW]VINVDTA(PIND)   = arr([M:SDPX]INVDTACST,PARR)

    [M:SVW]PRIVAL(PIND)    = [M:SDPX]PRI
Endif

######################### 2ème méthode ###############################
If (mod(PNUMVLT,4)>=2 | PNUMVLT=0) & clalev([M:SDP2]) & GACTVLT2

    [M:SDPX] = [M:SDP2]
    Call LOADVAR(LTABVAL, "[M:SDPX]", 0, "", PCOE, 0, 0) From STKVALECR
    LTMPVAL = [M:SVW]AMTVAL2(PIND)
    Call REPVAL(LTMPVAL,LTABVAL, PARR, LTABVAL) From STKVALECR
    Call LOADFIC("[M:SDPX]", LTABVAL, "", "CST", 1, 0) From STKVALECR

    #---- Matière ----#
    For I=0 To GACTMAT-1
        [M:SVW]V2MATCST(PIND*GACTMAT+I)  = arr([M:SDPX]MATCST(I),PARR)
    Next

    [M:SVW]V2MATTOT(PIND)   = sum([M:SVW]V2MATCST(PIND*GACTMAT..(PIND+1)*GACTMAT-1))

    [M:SVW]V2OVEMAT(PIND)   = arr([M:SDPX]OVEMATCST,PARR)

    #---- Machine ----#
    For I=0 To GACTMAC-1
        [M:SVW]V2MACCST(PIND*GACTMAC+I)  = arr([M:SDPX]MACCST(I),PARR)
    Next

    [M:SVW]V2MACTOT(PIND)   = sum([M:SVW]V2MACCST(PIND*GACTMAC..(PIND+1)*GACTMAC-1))

    [M:SVW]V2OVEMAC(PIND)   = arr([M:SDPX]OVEMACCST,PARR)

    #---- Main d'oeuvre ----#
    For I=0 To GACTLAB-1
        [M:SVW]V2LABCST(PIND*GACTLAB+I)  = arr([M:SDPX]LABCST(I),PARR)
    Next

    [M:SVW]V2LABTOT(PIND)   = sum([M:SVW]V2LABCST(PIND*GACTLAB..(PIND+1)*GACTLAB-1))

    [M:SVW]V2OVELAB(PIND)   = arr([M:SDPX]OVELABCST,PARR)

    #---- Sous-traitance ----#
    [M:SVW]V2SCOTOT(PIND)   = arr([M:SDPX]SCOTOT,PARR)
    [M:SVW]V2OVESCO(PIND)   = arr([M:SDPX]OVESCOCST,PARR)

    #---- Eléments de facture ----#
    [M:SVW]V2INVDTA(PIND)   = arr([M:SDPX]INVDTACST,PARR)

    [M:SVW]PRIVAL2(PIND)     = [M:SDPX]PRI

Endif
End

#**----------------------------------------------------------------<br/>
#* COPSVW : add or copy values from a SVW line to another one multiplying by a coef
#**<br/>----------------------------------------------------------------<br/>
#* @param PFROM : index from where to copy
#* @param PTO : index to where to copy
#* @param PCOE : coefficient
#* @param PADD : add (=1) or copy (=0)
#* @param PORDVAL : modulo 1 = ORD values<br/>
#*                  modulo 2 = VAR & VAR2 values<br/>
#**<br/>----------------------------------------------------------------
#*!
Subprog COPSVW(PFROM,PTO,PCOE,PADD,PORDVAL)
Value Integer PFROM
Value Integer PTO
Value Decimal PCOE
Value Integer PADD
Value Integer PORDVAL

Call COPSVW2(PFROM,PTO,PCOE,PCOE,PADD,PORDVAL)
End

#**----------------------------------------------------------------<br/>
#* COPSVW2 : idem COPSVW but with a specific coefficient for overheads categories
#**<br/>----------------------------------------------------------------<br/>
#* @param PFROM : index from where to copy
#* @param PTO : index to where to copy
#* @param PCOE : coefficient
#* @param PCOEONA : coefficient for overheads
#* @param PADD : add (=1) or copy (=0)
#* @param PORDVAL : modulo 1 = ORD values<br/>
#*                  modulo 2 = VAR & VAR2 values<br/>
#**<br/>----------------------------------------------------------------
#*!
Subprog COPSVW2(PFROM,PTO,PCOE,PCOEONA,PADD,PORDVAL)
Value Integer PFROM
Value Integer PTO
Value Decimal PCOE
Value Decimal PCOEONA
Value Integer PADD
Value Integer PORDVAL

If mod(PORDVAL,4)>=2 & mod(PORDVAL,8)<4
    PORDVAL+=4
Endif
Call COPSVW3(PFROM,PTO,PCOE,PCOEONA,PADD,PORDVAL)
End

#**----------------------------------------------------------------<br/>
#* COPSVW3 : idem COPSVW2 but it enables to copy only VAR or VAR2
#**<br/>----------------------------------------------------------------<br/>
#* @param PFROM : index from where to copy
#* @param PTO : index to where to copy
#* @param PCOE : coefficient
#* @param PCOEONA : coefficient for overheads
#* @param PADD : add (=1) or copy (=0)
#* @param PORDVAL : modulo 1 = ORD values<br/>
#*                  modulo 2 = VAR values<br/>
#*                  modulo 4 = VAR2 values<br/>
#**<br/>----------------------------------------------------------------
#*!
Subprog COPSVW3(PFROM,PTO,PCOE,PCOEONA,PADD,PORDVAL)
Value Integer PFROM
Value Integer PTO
Value Decimal PCOE
Value Decimal PCOEONA
Value Integer PADD
Value Integer PORDVAL

Local Integer I, J
Local Integer LOIND : # bug 91926 02/09/13

# Issue 96694 - 2014-03-31 by CCC : Calculate detail values as a function of global value AMTxxx
Local Decimal LTABVAL(1+GACTMAT+GACTMAC+GACTLAB+1+1+4+1)
Local Decimal LTMPVAL

#--- ORDRE ---#
If mod(PORDVAL,2)>=1

    LTMPVAL = arr([M:SVW]AMTORD(PFROM)*PCOE,GRNDVAL)
    [M:SVW]AMTORD(PTO) = [M:SVW]AMTORD(PTO)*PADD + LTMPVAL
    If dim([M:STW]QTYSTUACT)>0 & [M:STW]QTYSTUACT(PTO)
        If PADD
            [M:SVW]PRIORD(PTO) = arr([M:SVW]AMTORD(PTO)/[M:STW]QTYSTUACT(PTO),GRNDVAL)
        Else
            [M:SVW]PRIORD(PTO) = [M:SVW]PRIORD(PFROM)
        Endif
    Endif
    If GACTDECCST
        Call LOADVAR3(LTABVAL, "[M:SVW]", 0, "O", "CST", PFROM, PCOE, 0, 0) From STKVALECR
        Call REPVAL(LTMPVAL,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
        Call LOADFIC2("[M:SVW]", LTABVAL, "O", "CST", PTO, 1, PADD) From STKVALECR

        [M:SVW]OMATTOT(PTO)   = sigma(0,GACTMAT-1,[M:SVW]OMATCST(PTO*GACTMAT+indcum))

        [M:SVW]OMACTOT(PTO)   = sigma(0,GACTMAC-1,[M:SVW]OMACCST(PTO*GACTMAC+indcum))

        [M:SVW]OLABTOT(PTO)   = sigma(0,GACTLAB-1,[M:SVW]OLABCST(PTO*GACTLAB+indcum))

        If [M:SVW]LNK(PFROM)<>0
            For I=0 To [M:SVW]NBONA-1
                If [M:SVW]OLNK(I)=[M:SVW]LNK(PFROM)
                    If [M:SVW]LNK(PTO)>0
                        Raz J
                        LOIND = sigma(0,[M:SVW]NBONA-1, (indcum+1)
&                                                      *([M:SVW]OLNK(indcum)=[M:SVW]LNK(PTO)
&                                                      & [M:SVW]OVENAT(indcum)=[M:SVW]OVENAT(I)
&                                                      & J=0 & sigma(J=1,1,1)))
                    Endif
                    If LOIND>0
                        LOIND -= 1
                    Else
                        LOIND = [M:SVW]NBONA
                        [M:SVW]OVENAT(LOIND) = [M:SVW]OVENAT(I)
                        [M:SVW]ONATYP(LOIND) = [M:SVW]ONATYP(I)
                        [M:SVW]NBONA+=1
                        If [M:SVW]LNK(PTO)=0
                            [M:SVW]LNK(PTO)   = max([M:SVW]LNK)+1
                        Endif
                        [M:SVW]OLNK(LOIND)   = [M:SVW]LNK(PTO)
                    Endif
                    [M:SVW]ONAAMT(LOIND) = [M:SVW]ONAAMT(LOIND)*PADD + arr([M:SVW]ONAAMT(I)*PCOEONA,GRNDVAL)
                Endif
            Next
            Call REPOVESVW(PTO,GRNDVAL) From STKVALECR
        Endif
    Endif
Endif

#--- VALO ---#
If mod(PORDVAL,4)>=2

    LTMPVAL = arr([M:SVW]AMTVAL(PFROM)*PCOE,GRNDVAL)
    [M:SVW]AMTVAL(PTO) = [M:SVW]AMTVAL(PTO)*PADD + LTMPVAL
    If dim([M:STW]QTYSTUACT)>0 & [M:STW]QTYSTUACT(PTO)
        If PADD
            [M:SVW]PRIVAL(PTO) = arr([M:SVW]AMTVAL(PTO)/[M:STW]QTYSTUACT(PTO),GRNDVAL)
        Else
            [M:SVW]PRIVAL(PTO) = [M:SVW]PRIVAL(PFROM)
        Endif
    Endif
    [M:SVW]PRINAT(PTO)    = [M:SVW]PRINAT(PFROM)

    If GACTDECCST
        Call LOADVAR3(LTABVAL, "[M:SVW]", 0, "V", "CST", PFROM, PCOE, 0, 0) From STKVALECR
        Call REPVAL(LTMPVAL,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
        Call LOADFIC2("[M:SVW]", LTABVAL, "V", "CST", PTO, 1, PADD) From STKVALECR

        [M:SVW]VMATTOT(PTO)   = sigma(0,GACTMAT-1,[M:SVW]VMATCST(PTO*GACTMAT+indcum))

        [M:SVW]VMACTOT(PTO)   = sigma(0,GACTMAC-1,[M:SVW]VMACCST(PTO*GACTMAC+indcum))

        [M:SVW]VLABTOT(PTO)   = sigma(0,GACTLAB-1,[M:SVW]VLABCST(PTO*GACTLAB+indcum))
    Endif
Endif

    ########################### 2ème méthode ################################
If mod(PORDVAL,8)>=4 & GACTVLT2
    LTMPVAL = arr([M:SVW]AMTVAL2(PFROM)*PCOE,GRNDVAL)
    [M:SVW]AMTVAL2(PTO) = [M:SVW]AMTVAL2(PTO)*PADD + LTMPVAL
    If dim([M:STW]QTYSTUACT)>0 & [M:STW]QTYSTUACT(PTO)
        If PADD
            [M:SVW]PRIVAL2(PTO) = arr([M:SVW]AMTVAL2(PTO)/[M:STW]QTYSTUACT(PTO),GRNDVAL)
        Else
            [M:SVW]PRIVAL2(PTO) = [M:SVW]PRIVAL2(PFROM)
        Endif
    Endif
    [M:SVW]PRINAT2(PTO)    = [M:SVW]PRINAT2(PFROM)

    If GACTDECCST
        Call LOADVAR3(LTABVAL, "[M:SVW]", 0, "V2", "CST", PFROM, PCOE, 0, 0) From STKVALECR
        Call REPVAL(LTMPVAL,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
        Call LOADFIC2("[M:SVW]", LTABVAL, "V2", "CST", PTO, 1, PADD) From STKVALECR

        [M:SVW]V2MATTOT(PTO)   = sigma(0,GACTMAT-1,[M:SVW]V2MATCST(PTO*GACTMAT+indcum))

        [M:SVW]V2MACTOT(PTO)   = sigma(0,GACTMAC-1,[M:SVW]V2MACCST(PTO*GACTMAC+indcum))

        [M:SVW]V2LABTOT(PTO)   = sigma(0,GACTLAB-1,[M:SVW]V2LABCST(PTO*GACTLAB+indcum))
    Endif
Endif
End

#######################################################
# COPSVWD : additionne ou copie les valeurs d'une ligne SVWD (valeurs d'entrée d'un transfert inter-sites)
#           vers une autre en appliquant un coef
#######################################################
# Paramètres E : PADD = 1 : addition
#                PORDVAL : modulo 1 = Sur les valeurs d'ordre
#                          modulo 2 = Sur les valeurs de valo
#######################################################
Subprog COPSVWD(PFROM,PTO,PCOE,PADD,PORDVAL)
Value Integer PFROM
Value Integer PTO
Value Decimal PCOE
Value Integer PADD
Value Integer PORDVAL

Local Integer I, J
Local Integer LOIND : # bug 91926 02/09/13

# Issue 96694 - 2014-03-31 by CCC : Calculate detail values as a function of global value AMTxxx
Local Decimal LTABVAL(1+GACTMAT+GACTMAC+GACTLAB+1+1+4+1)
Local Decimal LTMPVAL

#--- ORDRE ---#
If mod(PORDVAL,2)>=1

    LTMPVAL = arr([M:SVWD]AMTORD(PFROM)*PCOE,GRNDVAL)
    [M:SVWD]AMTORD(PTO) = [M:SVWD]AMTORD(PTO)*PADD + LTMPVAL
    If dim([M:STW]QTYSTUACT)>0 & [M:STW]QTYSTUACT(PTO)
        If PADD
            [M:SVWD]PRIORD(PTO) = arr([M:SVWD]AMTORD(PTO)/[M:STW]QTYSTUACT(PTO),GRNDVAL)
        Else
            [M:SVWD]PRIORD(PTO) = [M:SVWD]PRIORD(PFROM)
        Endif
    Endif
    If GACTDECCST
        Call LOADVAR3(LTABVAL, "[M:SVWD]", 0, "O", "CST", PFROM, PCOE, 0, 0) From STKVALECR
        Call REPVAL(LTMPVAL,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
        Call LOADFIC2("[M:SVWD]", LTABVAL, "O", "CST", PTO, 1, PADD) From STKVALECR

        [M:SVWD]OMATTOT(PTO)   = sigma(0,GACTMAT-1,[M:SVWD]OMATCST(PTO*GACTMAT+indcum))

        [M:SVWD]OMACTOT(PTO)   = sigma(0,GACTMAC-1,[M:SVWD]OMACCST(PTO*GACTMAC+indcum))

        [M:SVWD]OLABTOT(PTO)   = sigma(0,GACTLAB-1,[M:SVWD]OLABCST(PTO*GACTLAB+indcum))

        If [M:SVWD]LNK(PFROM)<>0
            For I=0 To [M:SVWD]NBONA-1
                If [M:SVWD]OLNK(I)=[M:SVWD]LNK(PFROM)
                    If [M:SVWD]LNK(PTO)>0
                        Raz J
                        LOIND = sigma(0,[M:SVWD]NBONA-1, (indcum+1)
&                                                      *([M:SVWD]OLNK(indcum)=[M:SVWD]LNK(PTO)
&                                                      & [M:SVWD]OVENAT(indcum)=[M:SVWD]OVENAT(I)
&                                                      & J=0 & sigma(J=1,1,1)))
                    Endif
                    If LOIND>0
                        LOIND -= 1
                    Else
                        LOIND = [M:SVWD]NBONA
                        [M:SVWD]OVENAT(LOIND) = [M:SVWD]OVENAT(I)
                        [M:SVWD]ONATYP(LOIND) = [M:SVWD]ONATYP(I)
                        [M:SVWD]NBONA+=1
                        If [M:SVWD]LNK(PTO)=0
                            [M:SVWD]OLNK(LOIND)   = max([M:SVWD]LNK)+1
                        Else
                            [M:SVWD]OLNK(LOIND)   = [M:SVWD]LNK(PTO)
                        Endif
                    Endif
                    [M:SVWD]ONAAMT(LOIND) = [M:SVWD]ONAAMT(LOIND)*PADD + arr([M:SVWD]ONAAMT(I)*PCOE,GRNDVAL)
                Endif
            Next
        Endif
    Endif
Endif

#--- VALO ---#
If mod(PORDVAL,4)>=2

    LTMPVAL = arr([M:SVWD]AMTVAL(PFROM)*PCOE,GRNDVAL)
    [M:SVWD]AMTVAL(PTO) = [M:SVWD]AMTVAL(PTO)*PADD + LTMPVAL
    If dim([M:STW]QTYSTUACT)>0 & [M:STW]QTYSTUACT(PTO)
        If PADD
            [M:SVWD]PRIVAL(PTO) = arr([M:SVWD]AMTVAL(PTO)/[M:STW]QTYSTUACT(PTO),GRNDVAL)
        Else
            [M:SVWD]PRIVAL(PTO) = [M:SVWD]PRIVAL(PFROM)
        Endif
    Endif

    If GACTDECCST
        Call LOADVAR3(LTABVAL, "[M:SVWD]", 0, "V", "CST", PFROM, PCOE, 0, 0) From STKVALECR
        Call REPVAL(LTMPVAL,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
        Call LOADFIC2("[M:SVWD]", LTABVAL, "V", "CST", PTO, 1, PADD) From STKVALECR

        [M:SVWD]VMATTOT(PTO)   = sigma(0,GACTMAT-1,[M:SVWD]VMATCST(PTO*GACTMAT+indcum))

        [M:SVWD]VMACTOT(PTO)   = sigma(0,GACTMAC-1,[M:SVWD]VMACCST(PTO*GACTMAC+indcum))

        [M:SVWD]VLABTOT(PTO)   = sigma(0,GACTLAB-1,[M:SVWD]VLABCST(PTO*GACTLAB+indcum))
    Endif

    ########################### 2ème méthode ################################
    If GACTVLT2
        LTMPVAL = arr([M:SVWD]AMTVAL2(PFROM)*PCOE,GRNDVAL)
        [M:SVWD]AMTVAL2(PTO) = [M:SVWD]AMTVAL2(PTO)*PADD + LTMPVAL
        If dim([M:STW]QTYSTUACT)>0 & [M:STW]QTYSTUACT(PTO)
            If PADD
                [M:SVWD]PRIVAL2(PTO) = arr([M:SVWD]AMTVAL2(PTO)/[M:STW]QTYSTUACT(PTO),GRNDVAL)
            Else
                [M:SVWD]PRIVAL2(PTO) = [M:SVWD]PRIVAL2(PFROM)
            Endif
        Endif

        If GACTDECCST
            Call LOADVAR3(LTABVAL, "[M:SVWD]", 0, "V2", "CST", PFROM, PCOE, 0, 0) From STKVALECR
            Call REPVAL(LTMPVAL,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
            Call LOADFIC2("[M:SVWD]", LTABVAL, "V2", "CST", PTO, 1, PADD) From STKVALECR

            [M:SVWD]V2MATTOT(PTO)   = sigma(0,GACTMAT-1,[M:SVWD]V2MATCST(PTO*GACTMAT+indcum))

            [M:SVWD]V2MACTOT(PTO)   = sigma(0,GACTMAC-1,[M:SVWD]V2MACCST(PTO*GACTMAC+indcum))

            [M:SVWD]V2LABTOT(PTO)   = sigma(0,GACTLAB-1,[M:SVWD]V2LABCST(PTO*GACTLAB+indcum))
        Endif
    Endif
Endif
End

####################################################################
# COPVAL2ORD : Copie les valeurs des champs de [SVW] Vxx vers Oxx
####################################################################
Subprog COPVAL2ORD(PIND)
Value Integer PIND

Local Integer I

    #---- Matière ----#
    For I=0 To GACTMAT-1
        [M:SVW]OMATCST(PIND*GACTMAT+I)  = [M:SVW]VMATCST(PIND*GACTMAT+I)
    Next

    [M:SVW]OMATTOT(PIND)   = sigma(0,GACTMAT-1,[M:SVW]VMATCST(PIND*GACTMAT+indcum))

    [M:SVW]OOVEMATTOT(PIND)= [M:SVW]VOVEMATTOT(PIND)

    #---- Machine ----#
    For I=0 To GACTMAC-1
        [M:SVW]OMACCST(PIND*GACTMAC+I)  = [M:SVW]VMACCST(PIND*GACTMAC+I)
    Next

    [M:SVW]OMACTOT(PIND)   = sigma(0,GACTMAC-1,[M:SVW]VMACCST(PIND*GACTMAC+indcum))

    [M:SVW]OOVEMACTOT(PIND)= [M:SVW]VOVEMACTOT(PIND)

    #---- Main d'oeuvre ----#
    For I=0 To GACTLAB-1
        [M:SVW]OLABCST(PIND*GACTLAB+I)  = [M:SVW]VLABCST(PIND*GACTLAB+I)
    Next

    [M:SVW]OLABTOT(PIND)   = sigma(0,GACTLAB-1,[M:SVW]VLABCST(PIND*GACTLAB+indcum))

    [M:SVW]OOVELABTOT(PIND)= [M:SVW]VOVELABTOT(PIND)

    #---- Sous-traitance ----#
    [M:SVW]OSCOTOT(PIND)   = [M:SVW]VSCOTOT(PIND)
    [M:SVW]OOVESCOTOT(PIND)= [M:SVW]VOVESCOTOT(PIND)

    [M:SVW]OINVDTA(PIND)   = [M:SVW]VINVDTA(PIND)

    [M:SVW]PRIORD(PIND)    = [M:SVW]PRIVAL(PIND)
    [M:SVW]AMTORD(PIND)    = [M:SVW]AMTVAL(PIND)
End

#**----------------------------------------------------------------<br/>
#* SJV2SVW2 : Copy values from STOJOU/STOJOUVAL table to STOVALWRK mask
#**<br/>----------------------------------------------------------------<br/>
#* @param PIND : index in [M:SVW]
#* @param PORDVAL : modulo 1 = copy ORD values<br/>
#*                  modulo 2 = copy VAR & VAR2 values<br/>
#*                  modulo 4 = copy ORD in VAR & VAR2 values
#* @param PADD : addition (1=yes, 0=no)
#**<br/>----------------------------------------------------------------
#*!
Subprog SJV2SVW(PIND,PORDVAL,PADD)
Value Integer PIND
Value Integer PORDVAL
Value Integer PADD

# If modulo 2 and/or modulo 4 => add modulo 8
If PORDVAL>1 & PORDVAL<8
    PORDVAL+=8
Endif
# If not modulo 2 but modulo 4 => add modulo 2
If mod(PORDVAL,4)<2 & mod(PORDVAL,8)>=4
    PORDVAL+=2
Endif
Call SJV2SVW2(PIND,PORDVAL,PADD)

End

#**----------------------------------------------------------------<br/>
#* SJV2SVW2 : Copy values from STOJOU/STOJOUVAL table to STOVALWRK mask
#**<br/>----------------------------------------------------------------<br/>
#* @param PIND : index in [M:SVW]
#* @param PORDVAL : modulo 1 = copy SJV in ORD values<br/>
#*                  modulo 2 = copy in VAR values<br/>
#*                  modulo 4 = copy SJV ORD in VAR and/or VAR2 values
#*                  modulo 8 = copy in VAR2 values
#* @param PADD : addition (1=yes, 0=no)
#**<br/>----------------------------------------------------------------
#*!
Subprog SJV2SVW2(PIND,PORDVAL,PADD)
Value Integer PIND
Value Integer PORDVAL
Value Integer PADD

Local Integer I

If mod(PORDVAL,2)>=1
    #---- Matière ----#
    For I=0 To GACTMAT-1
        [M:SVW]OMATCST(PIND*GACTMAT+I)  = [F:SJV]OMATCST(I)+PADD*[M:SVW]OMATCST(PIND*GACTMAT+I)
    Next

    [M:SVW]OMATTOT(PIND)   = [F:SJV]OMATTOT+PADD*[M:SVW]OMATTOT(PIND)

    [M:SVW]OOVEMATTOT(PIND)= [F:SJV]OOVEMATTOT+PADD*[M:SVW]OOVEMATTOT(PIND)


    #---- Machine ----#
    For I=0 To GACTMAC-1
        [M:SVW]OMACCST(PIND*GACTMAC+I)  = [F:SJV]OMACCST(I)+PADD*[M:SVW]OMACCST(PIND*GACTMAC+I)
    Next

    [M:SVW]OMACTOT(PIND)   = [F:SJV]OMACTOT+PADD*[M:SVW]OMACTOT(PIND)

    [M:SVW]OOVEMACTOT(PIND)= [F:SJV]OOVEMACTOT+PADD*[M:SVW]OOVEMACTOT(PIND)


    #---- Main d'oeuvre ----#
    For I=0 To GACTLAB-1
        [M:SVW]OLABCST(PIND*GACTLAB+I)  = [F:SJV]OLABCST(I)+PADD*[M:SVW]OLABCST(PIND*GACTLAB+I)
    Next

    [M:SVW]OLABTOT(PIND)   = [F:SJV]OLABTOT+PADD*[M:SVW]OLABTOT(PIND)

    [M:SVW]OOVELABTOT(PIND)= [F:SJV]OOVELABTOT+PADD*[M:SVW]OOVELABTOT(PIND)

    #---- Sous-traitance ----#
    [M:SVW]OSCOTOT(PIND)   = [F:SJV]OSCOTOT+PADD*[M:SVW]OSCOTOT(PIND)
    [M:SVW]OOVESCOTOT(PIND)= [F:SJV]OOVESCOTOT+PADD*[M:SVW]OOVESCOTOT(PIND)

    [M:SVW]OINVDTA(PIND)   = [F:SJV]OINVDTATOT+PADD*[M:SVW]OINVDTA(PIND)

    [M:SVW]PRIORD(PIND)    = [F:STJ]PRIORD
    [M:SVW]AMTORD(PIND)    = [F:STJ]AMTORD+PADD*[M:SVW]AMTORD(PIND)
Endif

If mod(PORDVAL,8)<4
    If mod(PORDVAL,4)>=2
        For I=0 To GACTMAT-1
            [M:SVW]VMATCST(PIND*GACTMAT+I)  = [F:SJV]VMATCST(I)+PADD*[M:SVW]VMATCST(PIND*GACTMAT+I)
        Next

        [M:SVW]VMATTOT(PIND)   = [F:SJV]VMATTOT+PADD*[M:SVW]VMATTOT(PIND)

        [M:SVW]VOVEMATTOT(PIND)= [F:SJV]VOVEMATTOT+PADD*[M:SVW]VOVEMATTOT(PIND)

        For I=0 To GACTMAC-1
            [M:SVW]VMACCST(PIND*GACTMAC+I)  = [F:SJV]VMACCST(I)+PADD*[M:SVW]VMACCST(PIND*GACTMAC+I)
        Next

        [M:SVW]VMACTOT(PIND)   = [F:SJV]VMACTOT+PADD*[M:SVW]VMACTOT(PIND)

        [M:SVW]VOVEMACTOT(PIND)= [F:SJV]VOVEMACTOT+PADD*[M:SVW]VOVEMACTOT(PIND)

        For I=0 To GACTLAB-1
            [M:SVW]VLABCST(PIND*GACTLAB+I)  = [F:SJV]VLABCST(I)+PADD*[M:SVW]VLABCST(PIND*GACTLAB+I)
        Next

        [M:SVW]VLABTOT(PIND)   = [F:SJV]VLABTOT+PADD*[M:SVW]VLABTOT(PIND)

        [M:SVW]VOVELABTOT(PIND)= [F:SJV]VOVELABTOT+PADD*[M:SVW]VOVELABTOT(PIND)

        [M:SVW]VSCOTOT(PIND)   = [F:SJV]VSCOTOT+PADD*[M:SVW]VSCOTOT(PIND)
        [M:SVW]VOVESCOTOT(PIND)= [F:SJV]VOVESCOTOT+PADD*[M:SVW]VOVESCOTOT(PIND)

        [M:SVW]VINVDTA(PIND)   = [F:SJV]VINVDTATOT+PADD*[M:SVW]VINVDTA(PIND)

        [M:SVW]PRIVAL(PIND)    = [F:STJ]PRIVAL
        [M:SVW]AMTVAL(PIND)    = [F:STJ]AMTVAL+PADD*[M:SVW]AMTVAL(PIND)
        [M:SVW]PRINAT(PIND)    = [F:STJ]PRINAT
    Endif

    ################### 2ème méthode ##############################
    If mod(PORDVAL,16)>=8 & GACTVLT2
            For I=0 To GACTMAT-1
                [M:SVW]V2MATCST(PIND*GACTMAT+I)  = [F:SJV]V2MATCST(I)+PADD*[M:SVW]V2MATCST(PIND*GACTMAT+I)
            Next

            [M:SVW]V2MATTOT(PIND)   = [F:SJV]V2MATTOT+PADD*[M:SVW]V2MATTOT(PIND)

            [M:SVW]V2OVEMAT(PIND)   = [F:SJV]V2OVEMAT+PADD*[M:SVW]V2OVEMAT(PIND)

            For I=0 To GACTMAC-1
                [M:SVW]V2MACCST(PIND*GACTMAC+I)  = [F:SJV]V2MACCST(I)+PADD*[M:SVW]V2MACCST(PIND*GACTMAC+I)
            Next

            [M:SVW]V2MACTOT(PIND)   = [F:SJV]V2MACTOT+PADD*[M:SVW]V2MACTOT(PIND)

            [M:SVW]V2OVEMAC(PIND)   = [F:SJV]V2OVEMAC+PADD*[M:SVW]V2OVEMAC(PIND)

            For I=0 To GACTLAB-1
                [M:SVW]V2LABCST(PIND*GACTLAB+I)  = [F:SJV]V2LABCST(I)+PADD*[M:SVW]V2LABCST(PIND*GACTLAB+I)
            Next

            [M:SVW]V2LABTOT(PIND)   = [F:SJV]V2LABTOT+PADD*[M:SVW]V2LABTOT(PIND)

            [M:SVW]V2OVELAB(PIND)   = [F:SJV]V2OVELAB+PADD*[M:SVW]V2OVELAB(PIND)

            [M:SVW]V2SCOTOT(PIND)   = [F:SJV]V2SCOTOT+PADD*[M:SVW]V2SCOTOT(PIND)
            [M:SVW]V2OVESCO(PIND)   = [F:SJV]V2OVESCO+PADD*[M:SVW]V2OVESCO(PIND)

            [M:SVW]V2INVDTA(PIND)   = [F:SJV]V2INVDTA+PADD*[M:SVW]V2INVDTA(PIND)

            [M:SVW]PRIVAL2(PIND)    = [F:STJ]PRIVAL2
            [M:SVW]AMTVAL2(PIND)    = [F:STJ]AMTVAL2+PADD*[M:SVW]AMTVAL2(PIND)
            [M:SVW]PRINAT2(PIND)    = [F:STJ]PRINAT2
    Endif
Endif

# Issue 95566 - 2014-01-10 by CCC : récup de la valeur d'ordre ligne par ligne
If mod(PORDVAL,8)>=4
    If mod(PORDVAL,4)>=2
        For I=0 To GACTMAT-1
            [M:SVW]VMATCST(PIND*GACTMAT+I)  =  [F:SJV]OMATCST(I)+PADD*[M:SVW]VMATCST(PIND*GACTMAT+I)
        Next

        [M:SVW]VMATTOT(PIND)   = [F:SJV]OMATTOT+PADD*[M:SVW]VMATTOT(PIND)

        [M:SVW]VOVEMATTOT(PIND)= [F:SJV]OOVEMATTOT+PADD*[M:SVW]VOVEMATTOT(PIND)

        For I=0 To GACTMAC-1
            [M:SVW]VMACCST(PIND*GACTMAC+I)  = [F:SJV]OMACCST(I)+PADD*[M:SVW]VMACCST(PIND*GACTMAC+I)
        Next

        [M:SVW]VMACTOT(PIND)   = [F:SJV]OMACTOT+PADD*[M:SVW]VMACTOT(PIND)

        [M:SVW]VOVEMACTOT(PIND)= [F:SJV]OOVEMACTOT+PADD*[M:SVW]VOVEMACTOT(PIND)

        For I=0 To GACTLAB-1
            [M:SVW]VLABCST(PIND*GACTLAB+I)  = [F:SJV]OLABCST(I)+PADD*[M:SVW]VLABCST(PIND*GACTLAB+I)
        Next

        [M:SVW]VLABTOT(PIND)   = [F:SJV]OLABTOT+PADD*[M:SVW]VLABTOT(PIND)

        [M:SVW]VOVELABTOT(PIND)= [F:SJV]OOVELABTOT+PADD*[M:SVW]VOVELABTOT(PIND)

        [M:SVW]VSCOTOT(PIND)   = [F:SJV]OSCOTOT+PADD*[M:SVW]VSCOTOT(PIND)
        [M:SVW]VOVESCOTOT(PIND)= [F:SJV]OOVESCOTOT+PADD*[M:SVW]VOVESCOTOT(PIND)

        [M:SVW]VINVDTA(PIND)   = [F:SJV]OINVDTATOT+PADD*[M:SVW]VINVDTA(PIND)

        [M:SVW]PRIVAL(PIND)    = [F:STJ]PRIORD
        [M:SVW]AMTVAL(PIND)    = [F:STJ]AMTORD+PADD*[M:SVW]AMTVAL(PIND)
        [M:SVW]PRINAT(PIND)    = 8
    Endif

################### 2ème méthode ##############################
    If mod(PORDVAL,16)>=8 & GACTVLT2
        For I=0 To GACTMAT-1
            [M:SVW]V2MATCST(PIND*GACTMAT+I)  = [F:SJV]OMATCST(I)+PADD*[M:SVW]V2MATCST(PIND*GACTMAT+I)
        Next

        [M:SVW]V2MATTOT(PIND)   = [F:SJV]OMATTOT+PADD*[M:SVW]V2MATTOT(PIND)

        [M:SVW]V2OVEMAT(PIND)   = [F:SJV]OOVEMATTOT+PADD*[M:SVW]V2OVEMAT(PIND)

        For I=0 To GACTMAC-1
            [M:SVW]V2MACCST(PIND*GACTMAC+I)  = [F:SJV]OMACCST(I)+PADD*[M:SVW]V2MACCST(PIND*GACTMAC+I)
        Next

        [M:SVW]V2MACTOT(PIND)   = [F:SJV]OMACTOT+PADD*[M:SVW]V2MACTOT(PIND)

        [M:SVW]V2OVEMAC(PIND)   = [F:SJV]OOVEMACTOT+PADD*[M:SVW]V2OVEMAC(PIND)

        For I=0 To GACTLAB-1
            [M:SVW]V2LABCST(PIND*GACTLAB+I)  = [F:SJV]OLABCST(I)+PADD*[M:SVW]V2LABCST(PIND*GACTLAB+I)
        Next

        [M:SVW]V2LABTOT(PIND)   = [F:SJV]OLABTOT+PADD*[M:SVW]V2LABTOT(PIND)

        [M:SVW]V2OVELAB(PIND)   = [F:SJV]OOVELABTOT+PADD*[M:SVW]V2OVELAB(PIND)

        [M:SVW]V2SCOTOT(PIND)   = [F:SJV]OSCOTOT+PADD*[M:SVW]V2SCOTOT(PIND)
        [M:SVW]V2OVESCO(PIND)   = [F:SJV]OOVESCOTOT+PADD*[M:SVW]V2OVESCO(PIND)

        [M:SVW]V2INVDTA(PIND)   = [F:SJV]OINVDTATOT+PADD*[M:SVW]V2INVDTA(PIND)

        [M:SVW]PRIVAL2(PIND)    = [F:STJ]PRIORD
        [M:SVW]AMTVAL2(PIND)    = [F:STJ]AMTORD+PADD*[M:SVW]AMTVAL2(PIND)
        [M:SVW]PRINAT2(PIND)    = 8
    Endif
Endif
End

######################################
# SJO2SVW : Copie les valeurs de [F:SJO] vers le masque [M:SVW]
######################################
Subprog SJO2SVW(PIND)
Value Integer PIND

    Call SJO2SVW2(PIND,1)

End

Subprog SJO2SVW2(PIND,PCOE)
Value Integer PIND
Value Decimal PCOE

Local Integer LOIND, I

    If [M:SVW]LNK(PIND)
        LOIND = sigma(0,[M:SVW]NBONA-1, (indcum+1)
&                                      *([M:SVW]OLNK(indcum)=[M:SVW]LNK(PIND)
&                                      & [M:SVW]OVENAT(indcum)=[F:SJO]OVENAT
&                                      & I=0 & sigma(I=1,1,1)))
    Endif
    If LOIND>0
        LOIND -= 1
    Else
        LOIND = [M:SVW]NBONA
        [M:SVW]OVENAT(LOIND) = [F:SJO]OVENAT
        [M:SVW]ONATYP(LOIND) = [F:SJO]TYPCST
        [M:SVW]NBONA+=1
        [M:SVW]OLNK(LOIND)   = [M:SVW]LNK(PIND)
    Endif
    [M:SVW]ONAAMT(LOIND) += arr([F:SJO]ONAAMT*PCOE,GRNDVAL)

End

######################################
# SVW2VALW : Copie les valeurs de [M:SVW] vers [M:VALW]
######################################
Subprog SVW2VALW(PINDVALW, PCOE)
Value Integer PINDVALW
Value Decimal PCOE

Local Integer I
Local Decimal LCOE
LCOE=PCOE
If LCOE=0
    LCOE=1
Endif

    Raz [M:VALW]PRI(PINDVALW)

    #---- Matière ----#
    For I=0 To GACTMAT-1
        [M:VALW]OMATCST(PINDVALW*GACTMAT+I) = sigma(0,[M:STW]NBLIG-1,[M:SVW]OMATCST(indcum*GACTMAT+I))*LCOE
        [M:VALW]PRI(PINDVALW) += [M:VALW]OMATCST(PINDVALW*GACTMAT+I)
    Next

    [M:VALW]OOVEMATCST(PINDVALW) = sum([M:SVW]OOVEMATTOT)*LCOE
    [M:VALW]PRI(PINDVALW) += [M:VALW]OOVEMATCST(PINDVALW)


    #---- Machine ----#
    For I=0 To GACTMAC-1
        [M:VALW]OMACCST((PINDVALW*GACTMAC+I)) = sigma(0,[M:STW]NBLIG-1,[M:SVW]OMACCST(indcum*GACTMAC+I))*LCOE
        [M:VALW]PRI(PINDVALW) += [M:VALW]OMACCST((PINDVALW*GACTMAC+I))
    Next

    [M:VALW]OOVEMACCST(PINDVALW) = sum([M:SVW]OOVEMACTOT)*LCOE
    [M:VALW]PRI(PINDVALW) += [M:VALW]OOVEMACCST(PINDVALW)



    #---- Main d'oeuvre ----#
    For I=0 To GACTLAB-1
        [M:VALW]OLABCST(PINDVALW*GACTLAB+I) = sigma(0,[M:STW]NBLIG-1,[M:SVW]OLABCST(indcum*GACTLAB+I))*LCOE
        [M:VALW]PRI(PINDVALW) += [M:VALW]OLABCST(PINDVALW*GACTLAB+I)
    Next

    [M:VALW]OOVELABCST(PINDVALW) = sum([M:SVW]OOVELABTOT)*LCOE
    [M:VALW]PRI(PINDVALW) += [M:VALW]OOVELABCST(PINDVALW)

    #---- Sous-traitance ----#
    [M:VALW]OSCOTOT(PINDVALW)    = sum([M:SVW]OSCOTOT)*LCOE
    [M:VALW]PRI(PINDVALW) += [M:VALW]OSCOTOT(PINDVALW)
    [M:VALW]OOVESCOCST(PINDVALW) = sum([M:SVW]OOVESCOTOT)*LCOE
    [M:VALW]PRI(PINDVALW) += [M:VALW]OOVESCOCST(PINDVALW)

    [M:VALW]OINVDTACST(PINDVALW) = sum([M:SVW]OINVDTA)*LCOE
    [M:VALW]PRI(PINDVALW) += [M:VALW]OINVDTACST(PINDVALW)

    # Issue 95566 - 2014-01-07 by CCC : On assure la cohérence entre le détail et le total
    #[M:VALW]PRI(PINDVALW) = [M:SVW]PRIORD(0)
End

######################################
# SVW2SJV : Copie les valeurs de [M:SVW] vers [F:SJV] (!! utilise [F:STJ]PRINAT2 !!)
######################################
# Issue 81304 - 2012-06-06 by CCC : le signe est déjà correct dans SVW
#Subprog SVW2SJV(PIND, PSGN, PCOE)
#Value Integer PIND
#Value Integer PSGN
#Value Decimal PCOE
#
#Call SVW2SJV2(PIND, 0, PSGN, PCOE)
#End
#
#Subprog SVW2SJV2(PIND, PADD, PSGN, PCOE)
Subprog SVW2SJV(PIND, PCOE)
Value Integer PIND
Value Decimal PCOE

Call SVW2SJV2(PIND, 0, PCOE)
End

Subprog SVW2SJV2(PIND, PADD, PCOE)
Value Integer PIND
Value Integer PADD
Value Decimal PCOE

Local Integer I
Local Decimal LCOE
LCOE=PCOE
If LCOE=0
    LCOE=1
Endif

    #---- Matière ----#
    For I=0 To GACTMAT-1
        [F:SJV]OMATCST(I) = PADD*[F:SJV]OMATCST(I) + ([M:SVW]OMATCST(PIND*GACTMAT+I))*LCOE
    Next

    [F:SJV]OMATTOT    = PADD*[F:SJV]OMATTOT + ([M:SVW]OMATTOT(PIND))*LCOE

    [F:SJV]OOVEMATTOT = PADD*[F:SJV]OOVEMATTOT + ([M:SVW]OOVEMATTOT(PIND))*LCOE


    #---- Machine ----#
    For I=0 To GACTMAC-1
        [F:SJV]OMACCST(I) = PADD*[F:SJV]OMACCST(I) + ([M:SVW]OMACCST(PIND*GACTMAC+I))*LCOE
    Next

    [F:SJV]OMACTOT    = PADD*[F:SJV]OMACTOT + ([M:SVW]OMACTOT(PIND))*LCOE

    [F:SJV]OOVEMACTOT = PADD*[F:SJV]OOVEMACTOT + ([M:SVW]OOVEMACTOT(PIND) )*LCOE


    #---- Main d'oeuvre ----#
    For I=0 To GACTLAB-1
        [F:SJV]OLABCST(I) = PADD*[F:SJV]OLABCST(I) + ([M:SVW]OLABCST(PIND*GACTLAB+I))*LCOE
    Next

    [F:SJV]OLABTOT    = PADD*[F:SJV]OLABTOT + ([M:SVW]OLABTOT(PIND))*LCOE

    [F:SJV]OOVELABTOT = PADD* [F:SJV]OOVELABTOT + ([M:SVW]OOVELABTOT(PIND))*LCOE

    #---- Sous-traitance ----#
    [F:SJV]OSCOTOT    = PADD*[F:SJV]OSCOTOT + ([M:SVW]OSCOTOT(PIND))*LCOE
    [F:SJV]OOVESCOTOT = PADD*[F:SJV]OOVESCOTOT + ([M:SVW]OOVESCOTOT(PIND))*LCOE

    [F:SJV]OINVDTATOT = PADD*[F:SJV]OINVDTATOT + ([M:SVW]OINVDTA(PIND))*LCOE

############## 1ère méthode ######################
    For I=0 To GACTMAT-1
        [F:SJV]VMATCST(I) = PADD*[F:SJV]VMATCST(I) + ([M:SVW]VMATCST(PIND*GACTMAT+I))*LCOE
    Next

    [F:SJV]VMATTOT    = PADD*[F:SJV]VMATTOT + ([M:SVW]VMATTOT(PIND))*LCOE

    [F:SJV]VOVEMATTOT = PADD*[F:SJV]VOVEMATTOT + ([M:SVW]VOVEMATTOT(PIND))*LCOE
    For I=0 To GACTMAC-1
        [F:SJV]VMACCST(I) = PADD*[F:SJV]VMACCST(I) + ([M:SVW]VMACCST(PIND*GACTMAC+I))*LCOE
    Next

    [F:SJV]VMACTOT    = PADD*[F:SJV]VMACTOT + ([M:SVW]VMACTOT(PIND))*LCOE

    [F:SJV]VOVEMACTOT = PADD*[F:SJV]VOVEMACTOT + ([M:SVW]VOVEMACTOT(PIND))*LCOE
    For I=0 To GACTLAB-1
        [F:SJV]VLABCST(I) = PADD*[F:SJV]VLABCST(I) + ([M:SVW]VLABCST(PIND*GACTLAB+I))*LCOE
    Next

    [F:SJV]VLABTOT    = PADD*[F:SJV]VLABTOT + ([M:SVW]VLABTOT(PIND))*LCOE

    [F:SJV]VOVELABTOT = PADD*[F:SJV]VOVELABTOT + ([M:SVW]VOVELABTOT(PIND))*LCOE

    [F:SJV]VSCOTOT    = PADD*[F:SJV]VSCOTOT + ([M:SVW]VSCOTOT(PIND))*LCOE
    [F:SJV]VOVESCOTOT = PADD*[F:SJV]VOVESCOTOT + ([M:SVW]VOVESCOTOT(PIND))*LCOE

    [F:SJV]VINVDTATOT = PADD*[F:SJV]VINVDTATOT + ([M:SVW]VINVDTA(PIND))*LCOE

############## 2ème méthode ######################
    If GACTVLT2
        For I=0 To GACTMAT-1
            [F:SJV]V2MATCST(I) = PADD*[F:SJV]V2MATCST(I) + ([M:SVW]V2MATCST(PIND*GACTMAT+I))*LCOE
        Next

        [F:SJV]V2MATTOT    = PADD*[F:SJV]V2MATTOT + ([M:SVW]V2MATTOT(PIND))*LCOE

        [F:SJV]V2OVEMAT    = PADD*[F:SJV]V2OVEMAT + ([M:SVW]V2OVEMAT(PIND))*LCOE

        For I=0 To GACTMAC-1
            [F:SJV]V2MACCST(I) = PADD*[F:SJV]V2MACCST(I) + ([M:SVW]V2MACCST(PIND*GACTMAC+I))*LCOE
        Next

        [F:SJV]V2MACTOT    = PADD*[F:SJV]V2MACTOT + ([M:SVW]V2MACTOT(PIND))*LCOE

        [F:SJV]V2OVEMAC    = PADD*[F:SJV]V2OVEMAC + ([M:SVW]V2OVEMAC(PIND))*LCOE
        For I=0 To GACTLAB-1
            [F:SJV]V2LABCST(I) = PADD*[F:SJV]V2LABCST(I) + ([M:SVW]V2LABCST(PIND*GACTLAB+I))*LCOE
        Next

        [F:SJV]V2LABTOT    = PADD*[F:SJV]V2LABTOT + ([M:SVW]V2LABTOT(PIND))*LCOE

        [F:SJV]V2OVELAB    = PADD*[F:SJV]V2OVELAB + ([M:SVW]V2OVELAB(PIND))*LCOE

        [F:SJV]V2SCOTOT    = PADD*[F:SJV]V2SCOTOT + ([M:SVW]V2SCOTOT(PIND))*LCOE
        [F:SJV]V2OVESCO    = PADD*[F:SJV]V2OVESCO + ([M:SVW]V2OVESCO(PIND))*LCOE

        [F:SJV]V2INVDTA    = PADD*[F:SJV]V2INVDTA + ([M:SVW]V2INVDTA(PIND))*LCOE
    Endif

#---------------------------
# Delta
#---------------------------

    #---- Matière ----#
    For I=0 To GACTMAT-1
        [F:SJV]DOMATCST(I) = [F:SJV]OMATCST(I)
    Next

    [F:SJV]DOMATTOT    = [F:SJV]OMATTOT

    [F:SJV]DOOVEMAT    = [F:SJV]OOVEMATTOT


    #---- Machine ----#
    For I=0 To GACTMAC-1
        [F:SJV]DOMACCST(I) = [F:SJV]OMACCST(I)
    Next

    [F:SJV]DOMACTOT    = [F:SJV]OMACTOT

    [F:SJV]DOOVEMAC    = [F:SJV]OOVEMACTOT


    #---- Main d'oeuvre ----#
    For I=0 To GACTLAB-1
        [F:SJV]DOLABCST(I) = [F:SJV]OLABCST(I)
    Next

    [F:SJV]DOLABTOT    = [F:SJV]OLABTOT

    [F:SJV]DOOVELAB    = [F:SJV]OOVELABTOT

    #---- Sous-traitance ----#
    [F:SJV]DOSCOTOT    = [F:SJV]OSCOTOT
    [F:SJV]DOOVESCO    = [F:SJV]OOVESCOTOT

    [F:SJV]DOINVDTA    = [F:SJV]OINVDTATOT

    #---- Matière ----#
    For I=0 To GACTMAT-1
        [F:SJV]DVMATCST(I) = [F:SJV]VMATCST(I)
    Next

    [F:SJV]DVMATTOT    = [F:SJV]VMATTOT

    [F:SJV]DVOVEMAT    = [F:SJV]VOVEMATTOT


    #---- Machine ----#
    For I=0 To GACTMAC-1
        [F:SJV]DVMACCST(I) = [F:SJV]VMACCST(I)
    Next

    [F:SJV]DVMACTOT    = [F:SJV]VMACTOT

    [F:SJV]DVOVEMAC    = [F:SJV]VOVEMACTOT

    #---- Main d'oeuvre ----#
    For I=0 To GACTLAB-1
        [F:SJV]DVLABCST(I) = [F:SJV]VLABCST(I)
    Next

    [F:SJV]DVLABTOT    = [F:SJV]VLABTOT

    [F:SJV]DVOVELAB    = [F:SJV]VOVELABTOT

    #---- Sous-traitance ----#
    [F:SJV]DVSCOTOT    = [F:SJV]VSCOTOT
    [F:SJV]DVOVESCO    = [F:SJV]VOVESCOTOT

    [F:SJV]DVINVDTA    = [F:SJV]VINVDTATOT

#---------------------
# Ecart non absorbé
#---------------------
    #---- Matière ----#
    For I=0 To GACTMAT-1
        [F:SJV]DEVMATCST(I) = [F:SJV]DOMATCST(I)-[F:SJV]DVMATCST(I)
    Next

    [F:SJV]DEVOVEMAT    = [F:SJV]DOOVEMAT-[F:SJV]DVOVEMAT

    #---- Machine ----#
    For I=0 To GACTMAC-1
        [F:SJV]DEVMACCST(I) = [F:SJV]DOMACCST(I)-[F:SJV]DVMACCST(I)
    Next

    [F:SJV]DEVOVEMAC    = [F:SJV]DOOVEMAC-[F:SJV]DVOVEMAC

    #---- Main d'oeuvre ----#
    For I=0 To GACTLAB-1
        [F:SJV]DEVLABCST(I) = [F:SJV]DOLABCST(I)-[F:SJV]DVLABCST(I)
    Next

    [F:SJV]DEVOVELAB    = [F:SJV]DOOVELAB-[F:SJV]DVOVELAB

    #---- Sous-traitance ----#
    [F:SJV]DEVSCOCST    = [F:SJV]DOSCOTOT-[F:SJV]DVSCOTOT
    [F:SJV]DEVOVESCO    = [F:SJV]DOOVESCO-[F:SJV]DVOVESCO

    [F:SJV]DEVINVDTA    = [F:SJV]DOINVDTA-[F:SJV]DVINVDTA

############## 2ème méthode ######################
    If GACTVLT2
        #---- Matière ----#
        For I=0 To GACTMAT-1
            [F:SJV]DV2MATCST(I) = [F:SJV]V2MATCST(I)
        Next

        [F:SJV]DV2MATTOT    = [F:SJV]V2MATTOT

        [F:SJV]DV2OVEMAT    = [F:SJV]V2OVEMAT


        #---- Machine ----#
        For I=0 To GACTMAC-1
            [F:SJV]DV2MACCST(I) = [F:SJV]V2MACCST(I)
        Next

        [F:SJV]DV2MACTOT    = [F:SJV]V2MACTOT

        [F:SJV]DV2OVEMAC    = [F:SJV]V2OVEMAC

        #---- Main d'oeuvre ----#
        For I=0 To GACTLAB-1
            [F:SJV]DV2LABCST(I) = [F:SJV]V2LABCST(I)
        Next

        [F:SJV]DV2LABTOT    = [F:SJV]V2LABTOT

        [F:SJV]DV2OVELAB    = [F:SJV]V2OVELAB

        #---- Sous-traitance ----#
        [F:SJV]DV2SCOTOT    = [F:SJV]V2SCOTOT
        [F:SJV]DV2OVESCO    = [F:SJV]V2OVESCO

        [F:SJV]DV2INVDTA    = [F:SJV]V2INVDTA

    #---------------------
    # Ecart non absorbé
    #---------------------
        #---- Matière ----#
        For I=0 To GACTMAT-1
            [F:SJV]DEVMATCST2(I) = [F:SJV]DOMATCST(I)-[F:SJV]DV2MATCST(I)
        Next

        [F:SJV]DEVOVEMAT2    = [F:SJV]DOOVEMAT-[F:SJV]DV2OVEMAT

        #---- Machine ----#
        For I=0 To GACTMAC-1
            [F:SJV]DEVMACCST2(I) = [F:SJV]DOMACCST(I)-[F:SJV]DV2MACCST(I)
        Next

        [F:SJV]DEVOVEMAC2    = [F:SJV]DOOVEMAC-[F:SJV]DV2OVEMAC

        #---- Main d'oeuvre ----#
        For I=0 To GACTLAB-1
            [F:SJV]DEVLABCST2(I) = [F:SJV]DOLABCST(I)-[F:SJV]DV2LABCST(I)
        Next

        [F:SJV]DEVOVELAB2    = [F:SJV]DOOVELAB-[F:SJV]DV2OVELAB

        #---- Sous-traitance ----#
        [F:SJV]DEVSCOCST2    = [F:SJV]DOSCOTOT-[F:SJV]DV2SCOTOT
        [F:SJV]DEVOVESCO2    = [F:SJV]DOOVESCO-[F:SJV]DV2OVESCO

        [F:SJV]DEVINVDTA2    = [F:SJV]DOINVDTA-[F:SJV]DV2INVDTA

    Endif
End

######################################
# SVWD2SJV : Copie les valeurs de [M:SVWD] (valeurs d'entrée inter-sites) vers [F:SJV]
######################################

# Issue 81304 - 2012-06-06 by CCC : le signe est déjà correct dans SVW
#Subprog SVWD2SJV(PIND, PSGN, PCOE)
#Value Integer PIND
#Value Integer PSGN
#Value Decimal PCOE
Subprog SVWD2SJV(PIND, PCOE)
Value Integer PIND
Value Decimal PCOE

Local Integer I
Local Decimal LCOE
LCOE=PCOE
If LCOE=0
    LCOE=1
Endif

    #---- Matière ----#
    For I=0 To GACTMAT-1
        [F:SJV]OMATCST(I) = (([M:SVWD]OMATCST(PIND*GACTMAT+I)))*LCOE
    Next

    [F:SJV]OMATTOT    = (([M:SVWD]OMATTOT(PIND)))*LCOE

    [F:SJV]OOVEMATTOT = (([M:SVWD]OOVEMATTOT(PIND)))*LCOE


    #---- Machine ----#
    For I=0 To GACTMAC-1
        [F:SJV]OMACCST(I) = (([M:SVWD]OMACCST(PIND*GACTMAC+I)))*LCOE
    Next

    [F:SJV]OMACTOT    = (([M:SVWD]OMACTOT(PIND)))*LCOE

    [F:SJV]OOVEMACTOT = (([M:SVWD]OOVEMACTOT(PIND) ))*LCOE


    #---- Main d'oeuvre ----#
    For I=0 To GACTLAB-1
        [F:SJV]OLABCST(I) = (([M:SVWD]OLABCST(PIND*GACTLAB+I)))*LCOE
    Next

    [F:SJV]OLABTOT    = (([M:SVWD]OLABTOT(PIND)))*LCOE

    [F:SJV]OOVELABTOT = (([M:SVWD]OOVELABTOT(PIND)))*LCOE

    #---- Sous-traitance ----#
    [F:SJV]OSCOTOT    = (([M:SVWD]OSCOTOT(PIND)))*LCOE
    [F:SJV]OOVESCOTOT = (([M:SVWD]OOVESCOTOT(PIND)) )*LCOE

    [F:SJV]OINVDTATOT = (([M:SVWD]OINVDTA(PIND)))*LCOE

############## 1ère méthode ######################
    For I=0 To GACTMAT-1
        [F:SJV]VMATCST(I) = (([M:SVWD]VMATCST(PIND*GACTMAT+I)))*LCOE
    Next

    [F:SJV]VMATTOT    = (([M:SVWD]VMATTOT(PIND)))*LCOE

    [F:SJV]VOVEMATTOT = (([M:SVWD]VOVEMATTOT(PIND)))*LCOE

    For I=0 To GACTMAC-1
        [F:SJV]VMACCST(I) = (([M:SVWD]VMACCST(PIND*GACTMAC+I)))*LCOE
    Next

    [F:SJV]VMACTOT    = (([M:SVWD]VMACTOT(PIND)))*LCOE

    [F:SJV]VOVEMACTOT = (([M:SVWD]VOVEMACTOT(PIND)))*LCOE

    For I=0 To GACTLAB-1
        [F:SJV]VLABCST(I) = (([M:SVWD]VLABCST(PIND*GACTLAB+I)))*LCOE
    Next

    [F:SJV]VLABTOT    = (([M:SVWD]VLABTOT(PIND)))*LCOE

    [F:SJV]VOVELABTOT = (([M:SVWD]VOVELABTOT(PIND)))*LCOE

    [F:SJV]VSCOTOT    = (([M:SVWD]VSCOTOT(PIND)))*LCOE
    [F:SJV]VOVESCOTOT = (([M:SVWD]VOVESCOTOT(PIND)))*LCOE

    [F:SJV]VINVDTATOT = (([M:SVWD]VINVDTA(PIND)))*LCOE

############## 2ème méthode ######################
    If GACTVLT2
        For I=0 To GACTMAT-1
            [F:SJV]V2MATCST(I) = (([M:SVWD]V2MATCST(PIND*GACTMAT+I)))*LCOE
        Next

        [F:SJV]V2MATTOT    = (([M:SVWD]V2MATTOT(PIND)))*LCOE

        [F:SJV]V2OVEMAT    = (([M:SVWD]V2OVEMAT(PIND)))*LCOE

        For I=0 To GACTMAC-1
            [F:SJV]V2MACCST(I) = (([M:SVWD]V2MACCST(PIND*GACTMAC+I)))*LCOE
        Next

        [F:SJV]V2MACTOT    = (([M:SVWD]V2MACTOT(PIND)))*LCOE

        [F:SJV]V2OVEMAC = (([M:SVWD]V2OVEMAC(PIND)))*LCOE

        For I=0 To GACTLAB-1
            [F:SJV]V2LABCST(I) = (([M:SVWD]V2LABCST(PIND*GACTLAB+I)))*LCOE
        Next

        [F:SJV]V2LABTOT    = (([M:SVWD]V2LABTOT(PIND)))*LCOE

        [F:SJV]V2OVELAB = (([M:SVWD]V2OVELAB(PIND)))*LCOE

        [F:SJV]V2SCOTOT    = (([M:SVWD]V2SCOTOT(PIND)))*LCOE
        [F:SJV]V2OVESCO = (([M:SVWD]V2OVESCO(PIND)))*LCOE

        [F:SJV]V2INVDTA    = (([M:SVWD]V2INVDTA(PIND)))*LCOE
    Endif

#---------------------------
# Delta
#---------------------------

    #---- Matière ----#
    For I=0 To GACTMAT-1
        [F:SJV]DOMATCST(I) = [F:SJV]OMATCST(I)
    Next

    [F:SJV]DOMATTOT    = [F:SJV]OMATTOT

    [F:SJV]DOOVEMAT    = [F:SJV]OOVEMATTOT


    #---- Machine ----#
    For I=0 To GACTMAC-1
        [F:SJV]DOMACCST(I) = [F:SJV]OMACCST(I)
    Next

    [F:SJV]DOMACTOT    = [F:SJV]OMACTOT

    [F:SJV]DOOVEMAC    = [F:SJV]OOVEMACTOT


    #---- Main d'oeuvre ----#
    For I=0 To GACTLAB-1
        [F:SJV]DOLABCST(I) = [F:SJV]OLABCST(I)
    Next

    [F:SJV]DOLABTOT    = [F:SJV]OLABTOT

    [F:SJV]DOOVELAB    = [F:SJV]OOVELABTOT

    #---- Sous-traitance ----#
    [F:SJV]DOSCOTOT    = [F:SJV]OSCOTOT
    [F:SJV]DOOVESCO    = [F:SJV]OOVESCOTOT

    [F:SJV]DOINVDTA    = [F:SJV]OINVDTATOT

    #---- Matière ----#
    For I=0 To GACTMAT-1
        [F:SJV]DVMATCST(I) = [F:SJV]VMATCST(I)
    Next

    [F:SJV]DVMATTOT    = [F:SJV]VMATTOT

    [F:SJV]DVOVEMAT    = [F:SJV]VOVEMATTOT


    #---- Machine ----#
    For I=0 To GACTMAC-1
        [F:SJV]DVMACCST(I) = [F:SJV]VMACCST(I)
    Next

    [F:SJV]DVMACTOT    = [F:SJV]VMACTOT

    [F:SJV]DVOVEMAC    = [F:SJV]VOVEMACTOT

    #---- Main d'oeuvre ----#
    For I=0 To GACTLAB-1
        [F:SJV]DVLABCST(I) = [F:SJV]VLABCST(I)
    Next

    [F:SJV]DVLABTOT    = [F:SJV]VLABTOT

    [F:SJV]DVOVELAB    = [F:SJV]VOVELABTOT

    #---- Sous-traitance ----#
    [F:SJV]DVSCOTOT    = [F:SJV]VSCOTOT
    [F:SJV]DVOVESCO    = [F:SJV]VOVESCOTOT

    [F:SJV]DVINVDTA    = [F:SJV]VINVDTATOT

############## 2ème méthode ######################
    If GACTVLT2
        For I=0 To GACTMAT-1
            [F:SJV]DV2MATCST(I) = [F:SJV]V2MATCST(I)
        Next

        [F:SJV]DV2MATTOT    = [F:SJV]V2MATTOT

        [F:SJV]DV2OVEMAT    = [F:SJV]V2OVEMAT

        For I=0 To GACTMAC-1
            [F:SJV]DV2MACCST(I) = [F:SJV]V2MACCST(I)
        Next

        [F:SJV]DV2MACTOT    = [F:SJV]V2MACTOT

        [F:SJV]DV2OVEMAC    = [F:SJV]V2OVEMAC

        For I=0 To GACTLAB-1
            [F:SJV]DV2LABCST(I) = [F:SJV]V2LABCST(I)
        Next

        [F:SJV]DV2LABTOT    = [F:SJV]V2LABTOT

        [F:SJV]DV2OVELAB    = [F:SJV]V2OVELAB

        [F:SJV]DV2SCOTOT    = [F:SJV]V2SCOTOT
        [F:SJV]DV2OVESCO    = [F:SJV]V2OVESCO

        [F:SJV]DV2INVDTA    = [F:SJV]V2INVDTA
    Endif
End

######################################
# SVW2SJO : Copie les valeurs de [M:SVW] vers [F:SJO]
######################################
# Issue 81304 - 2012-06-06 by CCC : le signe est déjà correct dans SVW
#Subprog SVW2SJO(PIND, PSGN, PADD, PCOE)
#Value Integer PIND
#Value Integer PSGN
#Value Integer PADD
#Value Decimal PCOE
Subprog SVW2SJO(PIND, PADD, PCOE)
Value Integer PIND
Value Integer PADD
Value Decimal PCOE

Local Decimal LCOE
LCOE=PCOE
If LCOE=0
    LCOE=1
Endif

    [F:SJO]OVENAT = [M:SVW]OVENAT(PIND)
    [F:SJO]TYPCST = [M:SVW]ONATYP(PIND)
    [F:SJO]ONAAMT = [M:SVW]ONAAMT(PIND)*LCOE + PADD*[F:SJO]ONAAMT

End

######################################
# SVWD2SJO : Copie les valeurs de [M:SVW] vers [F:SJO]
######################################
# Issue 81304 - 2012-06-06 by CCC : le signe est déjà correct dans SVW
#Subprog SVWD2SJO(PIND, PSGN, PCOE)
#Value Integer PIND
#Value Integer PSGN
#Value Decimal PCOE
Subprog SVWD2SJO(PIND, PCOE)
Value Integer PIND
Value Decimal PCOE

Local Decimal LCOE
LCOE=PCOE
If LCOE=0
    LCOE=1
Endif

    [F:SJO]OVENAT = [M:SVWD]OVENAT(PIND)
    [F:SJO]TYPCST = [M:SVWD]ONATYP(PIND)
    [F:SJO]ONAAMT = [M:SVWD]ONAAMT(PIND)*LCOE

End

######################################
# DELTA2SJO : Copie les valeurs d'une variable dimensionnée vers [F:SJV]
######################################
Subprog DELTA2SJV(PDELTA, PAMTDEV, PNUMVLT, PVAR)
Value Decimal PDELTA()
Value Decimal PAMTDEV()
Value Integer PNUMVLT
Value Integer PVAR

Local Integer I,J

        I=1
        For J=0 To GACTMAT-1
            If PNUMVLT=0
                [F:SJV]OMATCST(J) += PDELTA(I)
                [F:SJV]DOMATCST(J)+= PDELTA(I)
                If PVAR
                    [F:SJV]VMATCST(J) += PDELTA(I)
                    [F:SJV]DVMATCST(J)+= PDELTA(I)
                Else
                    Raz [F:SJV]DVMATCST
                Endif
                [F:SJV]DEVMATCST(J) += PAMTDEV(I)
            Else
                If PVAR
                    [F:SJV]V2MATCST(J) += PDELTA(I)
                    [F:SJV]DV2MATCST(J)+= PDELTA(I)
                Else
                    Raz [F:SJV]DV2MATCST
                Endif
                [F:SJV]DEVMATCST2(J) += PAMTDEV(I)
            Endif

            I+=1
        Next
        If PNUMVLT=0
            [F:SJV]OMATTOT = sum([F:SJV]OMATCST)
            [F:SJV]DOMATTOT = sum([F:SJV]DOMATCST)
            [F:SJV]VMATTOT = sum([F:SJV]VMATCST)
            [F:SJV]DVMATTOT = sum([F:SJV]DVMATCST)
        Else
            [F:SJV]V2MATTOT = sum([F:SJV]V2MATCST)
            [F:SJV]DV2MATTOT = sum([F:SJV]DV2MATCST)
        Endif

        For J=0 To GACTMAC-1
            If PNUMVLT=0
                [F:SJV]OMACCST(J) += PDELTA(I)
                [F:SJV]DOMACCST(J)+= PDELTA(I)
                If PVAR
                    [F:SJV]VMACCST(J) += PDELTA(I)
                    [F:SJV]DVMACCST(J)+= PDELTA(I)
                Else
                    Raz [F:SJV]DVMACCST
                Endif
                [F:SJV]DEVMACCST(J) += PAMTDEV(I)
            Else
                If PVAR
                    [F:SJV]V2MACCST(J) += PDELTA(I)
                    [F:SJV]DV2MACCST(J)+= PDELTA(I)
                Else
                    Raz [F:SJV]DV2MACCST
                Endif
                [F:SJV]DEVMACCST2(J) += PAMTDEV(I)
            Endif

            I+=1
        Next
        If PNUMVLT=0
            [F:SJV]OMACTOT = sum([F:SJV]OMACCST)
            [F:SJV]DOMACTOT = sum([F:SJV]DOMACCST)
            [F:SJV]VMACTOT = sum([F:SJV]VMACCST)
            [F:SJV]DVMACTOT = sum([F:SJV]DVMACCST)
        Else
            [F:SJV]V2MACTOT = sum([F:SJV]V2MACCST)
            [F:SJV]DV2MACTOT = sum([F:SJV]DV2MACCST)
        Endif

        For J=0 To GACTLAB-1
            If PNUMVLT=0
                [F:SJV]OLABCST(J) += PDELTA(I)
                [F:SJV]DOLABCST(J)+= PDELTA(I)
                If PVAR
                    [F:SJV]VLABCST(J) += PDELTA(I)
                    [F:SJV]DVLABCST(J)+= PDELTA(I)
                Else
                    Raz [F:SJV]DVLABCST
                Endif
                [F:SJV]DEVLABCST(J) += PAMTDEV(I)
            Else
                If PVAR
                    [F:SJV]V2LABCST(J) += PDELTA(I)
                    [F:SJV]DV2LABCST(J)+= PDELTA(I)
                Else
                    Raz [F:SJV]DV2LABCST
                Endif
                [F:SJV]DEVLABCST2(J) += PAMTDEV(I)
            Endif


            I+=1
        Next
        If PNUMVLT=0
            [F:SJV]OLABTOT = sum([F:SJV]OLABCST)
            [F:SJV]DOLABTOT = sum([F:SJV]DOLABCST)
            [F:SJV]VLABTOT = sum([F:SJV]VLABCST)
            [F:SJV]DVLABTOT = sum([F:SJV]DVLABCST)
        Else
            [F:SJV]V2LABTOT = sum([F:SJV]V2LABCST)
            [F:SJV]DV2LABTOT = sum([F:SJV]DV2LABCST)
        Endif

        If PNUMVLT=0
            [F:SJV]OSCOTOT += PDELTA(I)
            [F:SJV]DOSCOTOT+= PDELTA(I)
            If PVAR
                [F:SJV]VSCOTOT += PDELTA(I)
                [F:SJV]DVSCOTOT+= PDELTA(I)
            Endif
            [F:SJV]DEVSCOCST += PAMTDEV(I)
        Else
            If PVAR
                [F:SJV]V2SCOTOT += PDELTA(I)
                [F:SJV]DV2SCOTOT+= PDELTA(I)
            Else
                Raz [F:SJV]DV2SCOTOT
            Endif
            [F:SJV]DEVSCOCST2 += PAMTDEV(I)
        Endif


        I+=1

        If PNUMVLT=0
            [F:SJV]OINVDTATOT += PDELTA(I)
            [F:SJV]DOINVDTA   += PDELTA(I)
            If PVAR
                [F:SJV]VINVDTATOT += PDELTA(I)
                [F:SJV]DVINVDTA   += PDELTA(I)
            Endif
            [F:SJV]DEVINVDTA += PAMTDEV(I)
        Else
            If PVAR
                [F:SJV]V2INVDTA  += PDELTA(I)
                [F:SJV]DV2INVDTA += PDELTA(I)
            Else
                Raz [F:SJV]DV2INVDTA
            Endif
            [F:SJV]DEVINVDTA2 += PAMTDEV(I)
        Endif


        I+=1

        If PNUMVLT=0
            [F:SJV]OOVEMATTOT += PDELTA(I)
            [F:SJV]DOOVEMAT+= PDELTA(I)
            If PVAR
                [F:SJV]VOVEMATTOT += PDELTA(I)
                [F:SJV]DVOVEMAT+= PDELTA(I)
            Endif
            [F:SJV]DEVOVEMAT += PAMTDEV(I)
        Else
            If PVAR
                [F:SJV]V2OVEMAT += PDELTA(I)
                [F:SJV]DV2OVEMAT+= PDELTA(I)
            Else
                Raz [F:SJV]DV2OVEMAT
            Endif
            [F:SJV]DEVOVEMAT2 += PAMTDEV(I)
        Endif


        I+=1

        If PNUMVLT=0
            [F:SJV]OOVEMACTOT += PDELTA(I)
            [F:SJV]DOOVEMAC+= PDELTA(I)
            If PVAR
                [F:SJV]VOVEMACTOT += PDELTA(I)
                [F:SJV]DVOVEMAC+= PDELTA(I)
            Endif
            [F:SJV]DEVOVEMAC += PAMTDEV(I)
        Else
            If PVAR
                [F:SJV]V2OVEMAC += PDELTA(I)
                [F:SJV]DV2OVEMAC+= PDELTA(I)
            Else
                Raz [F:SJV]DV2OVEMAC
            Endif
            [F:SJV]DEVOVEMAC2 += PAMTDEV(I)
        Endif


        I+=1

        If PNUMVLT=0
            [F:SJV]OOVELABTOT += PDELTA(I)
            [F:SJV]DOOVELAB+= PDELTA(I)
            If PVAR
                [F:SJV]VOVELABTOT += PDELTA(I)
                [F:SJV]DVOVELAB+= PDELTA(I)
            Endif
            [F:SJV]DEVOVELAB += PAMTDEV(I)
        Else
            If PVAR
                [F:SJV]V2OVELAB += PDELTA(I)
                [F:SJV]DV2OVELAB+= PDELTA(I)
            Else
                Raz [F:SJV]DV2OVELAB
            Endif
            [F:SJV]DEVOVELAB2 += PAMTDEV(I)
        Endif


        I+=1

        If PNUMVLT=0
            [F:SJV]OOVESCOTOT += PDELTA(I)
            [F:SJV]DOOVESCO+= PDELTA(I)
            If PVAR
                [F:SJV]VOVESCOTOT += PDELTA(I)
                [F:SJV]DVOVESCO+= PDELTA(I)
            Endif
            [F:SJV]DEVOVESCO += PAMTDEV(I)
        Else
            If PVAR
                [F:SJV]V2OVESCO += PDELTA(I)
                [F:SJV]DV2OVESCO+= PDELTA(I)
            Else
                Raz [F:SJV]DV2OVESCO
            Endif
            [F:SJV]DEVOVESCO2 += PAMTDEV(I)
        Endif

End

###############################################
# Initialisation de la variable GRNDVAL selon
# le type de donnée de la zone passée en paramètre.
# Sinon, c'est la variable GDECPRI qui est utilisée.
###############################################
# Paramètre E : PTAB = nom table
#               PZON = nom de zone
###############################################
Subprog INIRNDVAL(PTAB,PZON)
Value Char PTAB
Value Char PZON

If PTAB<>"" & PZON<>""
   GRNDVAL=0
   If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
   Read [F:ATZ]CODZONE=PTAB;PZON
   If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
   Read [ATY]CODTYP=[F:ATZ]CODTYP
   If fstat = 0
      GRNDVAL= 10^-(mod([F:ATY]LNGTYP,1)*10)
   Endif
Endif
If GRNDVAL=0
    GRNDVAL=10^-GDECPRI
Endif
End

#################################################
# Affecte une variable indicée avec les valeur d'un masque de détail de coût
#################################################
Subprog LOADVAR(PVAR,PFIC,PNUM, PREFIX, PCOE, PADD, PRND)
Variable Decimal PVAR()
Value    Char    PFIC
Value    Integer PNUM
Value    Char    PREFIX
Value    Decimal PCOE
Value    Integer PADD
Value    Decimal PRND

Call LOADVAR3(PVAR,PFIC,PNUM, PREFIX, "CST",0, PCOE, PADD, PRND)

End

# Issue 80461 - 2012-03-14 by CCC : Nécessité de préciser le suffixe
#################################################
Subprog LOADVAR2(PVAR,PFIC,PNUM, PREFIX, PSUF, PCOE, PADD, PRND)
Variable Decimal PVAR()
Value    Char    PFIC
Value    Integer PNUM
Value    Char    PREFIX
Value    Char    PSUF
Value    Decimal PCOE
Value    Integer PADD
Value    Decimal PRND

Call LOADVAR3(PVAR,PFIC,PNUM, PREFIX, PSUF, 0, PCOE, PADD, PRND)

End

#################################################
Subprog LOADVAR3(PVAR,PFIC,PNUM, PREFIX, PSUF, PIND, PCOE, PADD, PRND)
Variable Decimal PVAR()
Value    Char    PFIC
Value    Integer PNUM
Value    Char    PREFIX
Value    Char    PSUF
Value    Integer PIND
Value    Decimal PCOE
Value    Integer PADD
Value    Decimal PRND
Local Integer I, J

# Start issue 115322 - Causing valuation errors when SDP inactive
# Issue 106399 - 2015-09-10 by CCC
#If !GACTDECCST
#    End
#Endif
# End issue 115322

J=1
#---- Matière ----#
For I=0 To GACTMAT-1
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"MAT"+PSUF+string$(PNUM,"2")+"(GACTMAT*PIND+I)")*PCOE
    J+=1
Next

#---- Machine ----#
For I=0 To GACTMAC-1
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"MAC"+PSUF+string$(PNUM,"2")+"(GACTMAC*PIND+I)")*PCOE
    J+=1
Next

#---- Main d'oeuvre ----#
For I=0 To GACTLAB-1
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"LAB"+PSUF+string$(PNUM,"2")+"(GACTLAB*PIND+I)")*PCOE
    J+=1
Next
#---- /s-traitance ----#
If evalue("dim("+PFIC+PREFIX+"SCO"+PSUF+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"SCO"+PSUF+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"SCOTOT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"SCOTOT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Endif
J+=1

#---- éléments de facturation ----#
If evalue("dim("+PFIC+PREFIX+"INVDTA"+PSUF+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"INVDTA"+PSUF+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"INVDTATOT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"INVDTATOT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"INVDTA"+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0    # Dans SJV il n'a pas été possible de mettre xINVDATTOT pour tous les champs
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"INVDTA"+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Endif
J+=1

#---- Frais généraux ----#
If evalue("dim("+PFIC+PREFIX+"OVEMAT"+PSUF+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"OVEMAT"+PSUF+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVEMATTOT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"OVEMATTOT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVEMAT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"OVEMAT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Endif
J+=1

If evalue("dim("+PFIC+PREFIX+"OVEMAC"+PSUF+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"OVEMAC"+PSUF+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVEMACTOT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"OVEMACTOT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVEMAC"+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"OVEMAC"+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Endif
J+=1

If evalue("dim("+PFIC+PREFIX+"OVELAB"+PSUF+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"OVELAB"+PSUF+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVELABTOT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"OVELABTOT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVELAB"+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"OVELAB"+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Endif
J+=1

If evalue("dim("+PFIC+PREFIX+"OVESCO"+PSUF+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"OVESCO"+PSUF+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVESCOTOT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"OVESCOTOT"+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVESCO"+string$(PNUM,"2")+string$(PIND>0,"(PIND)")+")")>0
    PVAR(J) = PVAR(J)*PADD + evalue(PFIC+PREFIX+"OVESCO"+string$(PNUM,"2")+string$(PIND>0,"(PIND)"))*PCOE
Endif

If PRND>0
# Issue 88646 - 2013-03-28 by CCC : arrondir sans perte
#    For I=1 To J
#        PVAR(I) = arr(PVAR(I),PRND)
#    Next
    Call REPVAL(sum(PVAR(1..J)), PVAR(1..J), PRND, PVAR(1..J))
Endif
End

#################################################
# Affecte une classe de fichier avec les valeurs d'une variable indicée
#################################################
Subprog LOADFIC(PFIC,PVAR, PREFIX, PSUF, PCOE, PADD)
Value    Char    PFIC
Value    Decimal PVAR()
Value    Char    PREFIX
Value    Char    PSUF
Value    Decimal PCOE
Value    Integer PADD

Call LOADFIC2(PFIC,PVAR, PREFIX, PSUF, 0, PCOE, PADD)
End

#################################################
Subprog LOADFIC2(PFIC,PVAR, PREFIX, PSUF, PIND, PCOE, PADD)
Value    Char    PFIC
Value    Decimal PVAR()
Value    Char    PREFIX
Value    Char    PSUF
Value    Integer PIND
Value    Decimal PCOE
Value    Integer PADD
Local Integer I, J
Local Char LSUF(10)

If PSUF="2"
    LSUF = "CST2"
Else
    LSUF = PSUF
Endif

J=1
#---- Matière ----#
For I=0 To GACTMAT-1
    Assign PFIC+PREFIX+"MAT"+LSUF+"(GACTMAT*PIND+I)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"MAT"+LSUF+"(GACTMAT*PIND+I)")
    J+=1
Next

#---- Machine ----#
For I=0 To GACTMAC-1
    Assign PFIC+PREFIX+"MAC"+LSUF+"(GACTMAC*PIND+I)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"MAC"+LSUF+"(GACTMAC*PIND+I)")
    J+=1
Next

#---- Main d'oeuvre ----#
For I=0 To GACTLAB-1
    Assign PFIC+PREFIX+"LAB"+LSUF+"(GACTLAB*PIND+I)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"LAB"+LSUF+"(GACTLAB*PIND+I)")
    J+=1
Next
#---- /s-traitance ----#
If evalue("dim("+PFIC+PREFIX+"SCO"+LSUF+")")>0
    Assign PFIC+PREFIX+"SCO"+LSUF+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"SCO"+LSUF+"(PIND)")
Endif
If evalue("dim("+PFIC+PREFIX+"SCOTOT)")>0
    Assign PFIC+PREFIX+"SCOTOT"+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"SCOTOT"+"(PIND)")
Endif
J+=1

If PSUF="2"
    LSUF="2"
Endif

#---- élément fact. ----#
If evalue("dim("+PFIC+PREFIX+"INVDTA"+LSUF+")")>0
    Assign PFIC+PREFIX+"INVDTA"+LSUF+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"INVDTA"+LSUF+"(PIND)")
Elsif PSUF="CST" & evalue("dim("+PFIC+PREFIX+"INVDTA)")>0
    Assign PFIC+PREFIX+"INVDTA"+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"INVDTA"+"(PIND)")
Endif
If evalue("dim("+PFIC+PREFIX+"INVDTATOT)")>0
    Assign PFIC+PREFIX+"INVDTATOT"+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"INVDTATOT"+"(PIND)")
Endif
J+=1

#---- Frais généraux ----#
If evalue("dim("+PFIC+PREFIX+"OVEMAT"+LSUF+")")>0
    Assign PFIC+PREFIX+"OVEMAT"+LSUF+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"OVEMAT"+LSUF+"(PIND)")
Elsif evalue("dim("+PFIC+PREFIX+"OVEMATTOT)")>0
    Assign PFIC+PREFIX+"OVEMATTOT"+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"OVEMATTOT"+"(PIND)")
Elsif PSUF="CST" & evalue("dim("+PFIC+PREFIX+"OVEMAT)")>0
    Assign PFIC+PREFIX+"OVEMAT"+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"OVEMAT"+"(PIND)")
Endif
J+=1

If evalue("dim("+PFIC+PREFIX+"OVEMAC"+LSUF+")")>0
    Assign PFIC+PREFIX+"OVEMAC"+LSUF+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"OVEMAC"+LSUF+"(PIND)")
Elsif evalue("dim("+PFIC+PREFIX+"OVEMACTOT)")>0
    Assign PFIC+PREFIX+"OVEMACTOT"+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"OVEMACTOT"+"(PIND)")
Elsif PSUF="CST" & evalue("dim("+PFIC+PREFIX+"OVEMAC)")>0
    Assign PFIC+PREFIX+"OVEMAC"+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"OVEMAC"+"(PIND)")
Endif
J+=1

If evalue("dim("+PFIC+PREFIX+"OVELAB"+LSUF+")")>0
    Assign PFIC+PREFIX+"OVELAB"+LSUF+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"OVELAB"+LSUF+"(PIND)")
Elsif evalue("dim("+PFIC+PREFIX+"OVELABTOT)")>0
    Assign PFIC+PREFIX+"OVELABTOT"+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"OVELABTOT"+"(PIND)")
Elsif PSUF="CST" & evalue("dim("+PFIC+PREFIX+"OVELAB)")>0
    Assign PFIC+PREFIX+"OVELAB"+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"OVELAB"+"(PIND)")
Endif
J+=1

If evalue("dim("+PFIC+PREFIX+"OVESCO"+LSUF+")")>0
    Assign PFIC+PREFIX+"OVESCO"+LSUF+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"OVESCO"+LSUF+"(PIND)")
Elsif evalue("dim("+PFIC+PREFIX+"OVESCOTOT)")>0
    Assign PFIC+PREFIX+"OVESCOTOT"+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"OVESCOTOT"+"(PIND)")
Elsif PSUF="CST" & evalue("dim("+PFIC+PREFIX+"OVESCO)")>0
    Assign PFIC+PREFIX+"OVESCO"+"(PIND)" With PVAR(J)*PCOE + PADD*evalue(PFIC+PREFIX+"OVESCO"+"(PIND)")
Endif

End


##############################################################
# Répartition d'une valeur (PVAL) dans le vecteur PVALREP
# au prorata de PCLEREP, en arrondissant selon PRND
##############################################################
Subprog REPVAL(PVAL, PCLEREP, PRND, PVALREP)
Value Decimal PVAL
Value Decimal PCLEREP()
Value Decimal PRND
Variable Decimal PVALREP()

Local Integer I
Local Decimal LTOT, LCUMCLE, LCUMREP

Raz PVALREP

LTOT = sum(PCLEREP)
# Issue 88646 - 2013-03-28 by CCC
#If LTOT=0 | PVAL=0
#    End
#Endif
If LTOT=0 & PVAL=0
    LTOT=1
    PVAL=1
Elsif LTOT=0
    End
Endif

Raz LCUMREP, LCUMCLE
For I=0 To dim(PCLEREP)-1
    If PCLEREP(I)<>0    # Issue 107154 - 2015-03-20 by CCC : Performance
        LCUMCLE += PCLEREP(I)
        PVALREP(I) = PVAL*LCUMCLE/LTOT-LCUMREP
        If PRND<>0
            PVALREP(I) = arr(PVALREP(I),PRND)
        Endif
        LCUMREP+=PVALREP(I)
    Endif
Next

End


##############################################################
# Issue 81476 - 2012-08-06 by CCC
##############################################################
# SUMSJV2SDP : Alimente SDP avec la somme des valeurs d'ordre de STOJOUVAL
##############################################################
# Paramètres E : PFILTER = Filtre des mouvements à cumuler
#                PCOE    = Coefficient à appliquer aux valeurs
#                PADD    = 0: pas de cumul dans SDP
#                          1: cumuler avec les valeurs déjà présentes dans SDP
##############################################################
Subprog SUMSJV2SDP(PFILTER, PCOE, PADD)
Value Char    PFILTER()
Value Decimal PCOE
Value Integer PADD
Local Integer LIND  # 118200.n

		If !clalev([F:SJO]) : Local File STOJOUOVE [SJO] : Endif # 118200.n

    If dim(GDIMCST)<=0
        Global Integer GDIMCST
        GDIMCST = GACTMAT+GACTMAC+GACTLAB+2+4     # = dim mat + dim mac + dim lab + sco + invdta + fg mat + fg mac + fg lab + fg sco
    Endif
    Local Decimal LDELTA(1+GDIMCST)

    If PADD=0
        Raz [M:SDP]
    Endif
    For [STJ] Where evalue(PFILTER)
        [M:SDP]QTY += [F:STJ]ACTQTY
        # Issue 108950 - 2015-09-08 by CCC : VARORD is not enough. We have to take into account a possible value in not absorbed amount
        #LDELTA(0)+=[F:STJ]VARORD
        LDELTA(0)+=[F:STJ]VARVAL
        LDELTA(0)+=[F:STJ]AMTDEV
        If GACTDECCST
            Read [SJV]SJV0=[F:STJ]STOFCY;[F:STJ]UPDCOD;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
            If !fstat
                # Issue 108950 - 2015-09-08 by CCC
                #Call LOADVAR(LDELTA, "[F:SJV]", 0, "DO", PCOE, 1, 0) From STKVALECR
                Call LOADVAR(LDELTA, "[F:SJV]", 0, "DV", PCOE, 1, 0) From STKVALECR
                Call LOADVAR(LDELTA, "[F:SJV]", 0, "DEV", PCOE, 1, 0) From STKVALECR

                # Issue 118200 - 2016-09-26 by ERMIL : Get overhead values from STOJOUOVE
                For [SJO] Where STOFCY=[F:STJ]STOFCY & UPDCOD=2 & ITMREF=[F:STJ]ITMREF & IPTDAT=[F:STJ]IPTDAT & MVTSEQ=[F:STJ]MVTSEQ & MVTIND=[F:STJ]MVTIND
                  LIND = find([F:SJO]OVENAT,[M:SDP]OVENAT)
                  If LIND>0
                    LIND-=1
                  Else
                    LIND = [M:SDP]NBONA
                    [M:SDP]OVENAT(LIND) = [F:SJO]OVENAT
                    [M:SDP]ONATYP(LIND) = [F:SJO]TYPCST
                    [M:SDP]NBONA += 1
                  Endif
                  [M:SDP]ONAAMT(LIND) += ([F:SJO]ONAAMT * PCOE)
                Next
                # End issue 118200
            Endif
        Endif
    Next
    If GACTDECCST
        Call LOADFIC("[M:SDP]",LDELTA,"","CST",1,PADD) From STKVALECR
        Gosub CAL_TOT From SUBSDP    # Calcule PRI = somme de toutes les composantes
        [M:SDP]AMTTOT = [M:SDP]PRI
    Else
        [M:SDP]AMTTOT = LDELTA(0)
    Endif
    If [M:SDP]QTY<>0
        [M:SDP]PRI = [M:SDP]AMTTOT/[M:SDP]QTY
    Endif
End

#**----------------------------------------------------------------<br/>
#* REPOVESVW : Round overhead nature amounts for a SVW line according to OVExxxCST amounts
#**<br/>----------------------------------------------------------------<br/>
#* @param PIND = line indice in SVW
#* @param PRND = rounding
#**<br/>----------------------------------------------------------------
#*!
Subprog REPOVESVW(PIND, PRND)
Value Integer PIND
Value Decimal PRND

# Issue 107154 - 2015-03-20 by CCC : Performance
If [M:SVW]NBONA=0
    End
Endif

Local Integer I, ITYP
Local Char    TYP(5)    # Issue 105433 - 2015-01-28 by CCC
# Issue 107154 - 2015-03-20 by CCC : Performance
#Local Decimal LTABOVEAMT(dim([M:SVW]OLNK))
Local Decimal LTABOVEAMT([M:SVW]NBONA)
ITYP=1
For TYP="MAT","MAC","LAB","SCO"
    ITYP+=1
    Raz LTABOVEAMT
    For I=0 To [M:SVW]NBONA-1
        If [M:SVW]OLNK(I) = [M:SVW]LNK(PIND) & (ITYP=[M:SVW]ONATYP(I) | (ITYP=2 & [M:SVW]ONATYP(I)=1))
            LTABOVEAMT(I) = [M:SVW]ONAAMT(I)
        Endif
    Next
    # Issue 107154 - 2015-03-20 by CCC : Performance
    #Call REPVAL(evalue("[M:SVW]OOVE"+TYP+"TOT(PIND)"),LTABOVEAMT, GRNDVAL, LTABOVEAMT) From STKVALECR
    Case TYP :
        When "MAT" : Call REPVAL([M:SVW]OOVEMATTOT(PIND),LTABOVEAMT, PRND, LTABOVEAMT) From STKVALECR
        When "MAC" : Call REPVAL([M:SVW]OOVEMACTOT(PIND),LTABOVEAMT, PRND, LTABOVEAMT) From STKVALECR
        When "LAB" : Call REPVAL([M:SVW]OOVELABTOT(PIND),LTABOVEAMT, PRND, LTABOVEAMT) From STKVALECR
        When "SCO" : Call REPVAL([M:SVW]OOVESCOTOT(PIND),LTABOVEAMT, PRND, LTABOVEAMT) From STKVALECR
    Endcase
    For I=0 To [M:SVW]NBONA-1
        If [M:SVW]OLNK(I) = [M:SVW]LNK(PIND) & (ITYP=[M:SVW]ONATYP(I) | (ITYP=2 & [M:SVW]ONATYP(I)=1))
            [M:SVW]ONAAMT(I) = LTABOVEAMT(I)
        Endif
    Next
Next

End

#**----------------------------------------------------------------<br/>
#* ADDOVE : Add OVERHEAD from a vector to another one
#**<br/>----------------------------------------------------------------<br/>
#* @param PTABNAT1 = overhead natures to copy
#* @param PTABTYP1 = overhead nature types to copy
#* @param PTABFXD1 = fixed overhead amount to copy
#* @param PTABVAR1 = variable overhead amount to copy
#* @param PTABNAT2 = overhead natures in which to copy
#* @param PTABTYP2 = overhead nature types in which to copy
#* @param PNATAMT2 = overhead amount in which to copy
#**<br/>----------------------------------------------------------------
#*!
Subprog ADDOVE(PTABNAT1, PTABTYP1, PTABFXD1, PTABVAR1, PCOE, PTABNAT2, PTABTYP2, PNATAMT2)
Value    Char    PTABNAT1()
Value    Integer PTABTYP1()
Value    Decimal PTABFXD1()
Value    Decimal PTABVAR1()
Value    Decimal PCOE
Variable Char    PTABNAT2()
Variable Integer PTABTYP2()
Variable Decimal PNATAMT2()

Local Integer I
    For I=0 To dim(PTABTYP1)-1
        If PTABNAT1(I)="" : Break : Endif
        J=find(PTABNAT1(I),PTABNAT2)-1
        If J<0
            J=find("",PTABNAT2)-1
            If J<0 : Break : Endif
        Endif
        PTABNAT2(J) = PTABNAT1(I)
        PTABTYP2(J) = PTABTYP1(I)
        PNATAMT2(J) += PCOE*(PTABFXD1(I)+PTABVAR1(I))
    Next
End

#**----------------------------------------------------------------<br/>
#* SJO2VAR : Add SJO record to an array
#**<br/>----------------------------------------------------------------<br/>
#* @param PTABNAT = array of overhead natures
#* @param PTABAMT = array of overhead nature amounts
#**<br/>----------------------------------------------------------------
#*!
Subprog SJO2VAR(PTABNAT, PTABTYP, PTABAMT)
Variable Char    PTABNAT()
Variable Integer PTABTYP()
Variable Decimal PTABAMT()

Local Integer I

If [F:SJO]OVENAT="" : End : Endif

I= find([F:SJO]OVENAT,PTABNAT)-1
If I<0
    I=find("",PTABNAT)-1
Endif

PTABNAT(I)  = [F:SJO]OVENAT
PTABTYP(I)  = [F:SJO]TYPCST
PTABAMT(I) += [F:SJO]ONAAMT

End

