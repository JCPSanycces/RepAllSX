#<AdxTL>@(#)1.0.0.0 $Revision$
###############################################################################################
#           programme - process  AYTDLOGIN
#           EXEMPLE DE SOUS-PROGRAMME DE LOGIN XTEND - XTEND SAMPLE LOGIN SUBPROGRAM
#
#           Pour invalider le login il faut poster une erreur via AWEB.ADDMESSERR("Message utilisteur")
#           To invalidate login you have to throw an error via AWEB.ADDMESSERR("User message")
################################################################################################

    # TEST
    Local Char     WXPARCOD(50)(0..20)
    Local Char     WXPARVAL(100)(0..20)
    Local Char     WAXUSERCODE(100)
    Local Char     WAXPWD(100)
    Local Char     WAXPROFILE(100)
    Local Char     WAX3SOL(100)   (0..20)
    Local Char     WAX3FLDR(100)  (0..20)
    Local Char     WAX3LANG(100)  (0..20)
    Local Char     WAX3USER(100)  (0..20)
    Local Char     WAX3PWD(100)   (0..20)
    Local Char     WAXLOGCOD(100) (0..20) 
    Local Char     WAXLOGVAL(100) (0..20)
    Local Char     WSHIPADR1(100)(0..20)
    Local Char     WSHIPADR2(100)(0..20)
    Local Char     WSHIPCITY(100)(0..20)
    Local Char     WSHIPZIP(100)(0..20)

    # LOGIN PARAMETERS
    WAXUSERCODE="admin"
    WAXPWD=""
    WXPARCOD(0)="SITCOD"   
    WXPARVAL(0)="ATEMPLATE"
    # Init
    Call INITABMES From AWEB
    # Call
    Call ACTION(WXPARCOD,WXPARVAL,WAXUSERCODE,WAXPWD,WAXPROFILE,WAX3SOL,WAX3FLDR,WAX3LANG,WAX3USER,WAX3PWD,WAXLOGCOD,WAXLOGVAL,WSHIPADR1,WSHIPADR2,WSHIPCITY,WSHIPZIP)
    # Messages
    Call VISUALLMES From AWEB
    # Display
    If GSTATUS=1
        Local Clbfile WTRACE(3)
        WTRACE+="USER[" + WAXUSERCODE + "] - PROFILE[" + WAXPROFILE + "]" + chr$(13)
        Local Integer WMAX
        WMAX=dim (WAX3SOL)-1
        For I=0 To WMAX
            If len(WAX3SOL(I))<>0
                WTRACE+=WAX3SOL(I)+"-"+WAX3FLDR(I)+"-"+WAX3LANG(I)+"-"+WAX3USER(I)+ "-"+WAX3PWD(I)+chr$(13)
            Endif
        Next
        WMAX=dim (WAXLOGCOD)-1
        For I=0 To WMAX
            If len(WAXLOGCOD(I))<>0
                WTRACE+=WAXLOGCOD(I)+ "["+ WAXLOGVAL(I)+ "]" +chr$(13)
            Endif
        Next
        WMAX=dim (WSHIPADR1)-1
        For I=0 To WMAX
            If len(WSHIPADR1(I))<>0
                WTRACE+=WSHIPADR1(I)+ " - "+ WSHIPADR2(I)+ " - " + WSHIPCITY(I)+ " - " + WSHIPZIP(I) +chr$(13)
            Endif
        Next
        Local Integer WNBINFBOX
        WNBINFBOX=len(WTRACE)/255
        For I=0 To WNBINFBOX
            Infbox mid$(WTRACE,(I*255)+1,255)
        Next
    Endif
End

####################################################################################################
# Subprogram ACTION                                                                                      #
####################################################################################################
Subprog ACTION(AXPARCOD,AXPARVAL,AXUSERCODE,AXPWD,AXUSERPROF,AX3SOL,AX3FLDR,AX3LANG,AX3USER,AX3PWD,AXLOGCOD,AXLOGVAL,SHIPADR1,SHIPADR2,SHIPCITY,SHIPZIP)
    # Paramètres contextuels valorisés par le serveur XTEND - Contient le code site 'SITCOD'
    # Contextual parameters settled by XTEND server - Contains Xtend site's code 'SITCOD'
    Variable Char     AXPARCOD()()
    Variable Char     AXPARVAL()()
    # Paramètres obligatoires de login saisis par l'utilisateur 
    # Input parameters (HTML FORM)
    Variable Char     AXUSERCODE()
    Value    Char     AXPWD()
    # Paramètres obligatoires valorisés par le sous-programme
    # Mandatory parameters that must be returned to XTEND server
    Variable Char     AXUSERPROF()    
    #Tableau des login X3 utilisé pour l'appel des web services    
    #Array of X3 logins per SOLUTION/FOLDER - Used to cal web services
    Variable Char     AX3SOL()()
    Variable Char     AX3FLDR()() 
    Variable Char     AX3LANG()()   
    Variable Char     AX3USER()()
    Variable Char     AX3PWD()()
    # Paramètres optionnels valorisés par le sous-programme
    # --> Informations complementaires (CODE/VALEUR) sur l'utilisateur (tel, email, nom...) qui seront copiés dasn la sessions XTEND (ASESSION)
    # --> Evite de créer autant de paramètres que de champs et facilite l'ajout de nouveaux champs 
    # Optional parameters returned to XTEND server
    # --> Additional user information (KEY/VALUE) (phone, email, name...) that will be mapped to XTEND session(ASESSION)
    # --> Avoid to create as many parameters as user information fields and facilitate addition of new parameters
    Variable Char     AXLOGCOD()()   
    Variable Char     AXLOGVAL()()
    # Informations complementaires traitées par mapping dans l'action de login
    # Additional user information performed by field mapping in login action
    Variable Char     SHIPADR1()()
    Variable Char     SHIPADR2()()
    Variable Char     SHIPCITY()()
    Variable Char     SHIPZIP()()

    Local Integer WOK:WOK=1
    AXUSERCODE=toupper(vireblc(AXUSERCODE,0))
    If len(AXUSERCODE)=0
        Call ADDMESSERR("User code is empty" ) From AWEB
        WOK=0
    Else
        AXPWD=vireblc(AXPWD,0)
        If AXUSERCODE="SAGE" and toupper(AXPWD)="SAGE"
            WOK=1
        Else
            If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
            Read [AUS]LOGIN=AXUSERCODE
            If fstat
                Call ADDMESSERR("User code"-"["+ AXUSERCODE +"]"-"not found") From AWEB
                WOK=0
            Else
                Local Char WSITEXTEND(30) : WSITEXTEND="" 
                Integer WIDX:WIDX=find("SITCOD",AXPARCOD)
                If WIDX<>0
                    WSITEXTEND=AXPARVAL(WIDX-1)
                    Call USERX3(WSITEXTEND,AXUSERCODE,AXUSERPROF,WOK) From SUBAUS  
                    If WOK=1
                        If [AUS]ENAFLG = 2
                            If [AUS]USRCONXTD= 2 
                                # Vérifie le mot de passe
                                Call CTLPAS(AXPWD, WOK) From GESUSER
                                If WOK=0
                                    Call ADDMESSERR(mess(00025,00100,1)) From AWEB : # Mot de passe incorrect
                                Else
                                    WOK=1
                                Endif
                            Else
                                Call ADDMESSERR(mess(00096,09137,1)-"[" + AXUSERCODE +"]") From AWEB : # Connexion non autorisée
                                WOK=0 
                            Endif
                        Else
                            Call ADDMESSERR("Inactive user"-"[" + AXUSERCODE + "]") From AWEB
                            WOK=0 
                        Endif
                    Else
                        Call ADDMESSERR("unauthorized site" -"[" + WSITEXTEND + "]") From AWEB
                        WOK=0 
                    Endif
                Else        
                    Call ADDMESSERR("Web site not set") From AWEB
                    WOK=0
                Endif
            Endif
        Endif
    Endif    
    If WOK
        ############################################################################################
        #EXEMPLE de code pour montrer comment valoriser les informations du compte utilisateur
        #SAMPLE code that shows how to set user account information
        ############################################################################################
        # PAS DE PROFIL XTEND PAR DEFAUT
        # EMPTY XTEND PROFILE
        AXUSERPROF=""
        # DONNEES COMPLEMENTAIRES MAPPEES AUTOMATIQUEMENT DANS ASESSION
        # ADDITIONNAL USER INFORMATION AUTOMATICALLY MAPPED TO ASESSION
        AXLOGCOD(0)="NAME"     
        AXLOGCOD(1)="FIRSTNAME"
        AXLOGCOD(2)="EMAIL"          
        AXLOGCOD(3)="PHONE"
        #LOGIN LIST FOR ALL X3 FOLDER CONNECTED TO XTEND SITE
        #-->2 X3FOLDERS IN THIS SAMPLE
        #LOGIN X3 FOR FOLDER SOLSUPV6/SUPERV
        AX3SOL(0)="SOLSUPV6"
        AX3FLDR(0)="SUPERV"  
        AX3LANG(0)="FRA"
        #LOGIN X3 FOR FOLDER SOLPAIEV6/PAIEV6
        AX3SOL(1)="SOLPAIEV6"
        AX3FLDR(1)="PAIEV6"  
        AX3LANG(1)="FRA"
        If AXUSERCODE="DIS001"
            # DONNEES COMPLEMENTAIRES
            # ADDITIONNAL USER INFORMATION
            AXLOGVAL(0)="DAL BO"   
            AXLOGVAL(1)="Frédéric"   
            AXLOGVAL(2)="dalbo.frederic@sage.com"  
            AXLOGVAL(3)="01020305405"
            #LOGIN X3 FOR FOLDER SOLSUPV6/SUPERV
            AX3USER(0)="FDB"
            AX3PWD(0)=""
            #LOGIN X3 FOR FOLDER SOLPAIEV6/PAIEV6
            AX3USER(1)="ADMIN"
            AX3PWD(1)=""

         Else
            # DONNEES COMPLEMENTAIRES
            # ADDITIONNAL USER INFORMATION
            AXLOGVAL(0)="BARBIER"   
            AXLOGVAL(1)="Stéphane"
            AXLOGVAL(2)="barbier.stephane@sage.com"  
            AXLOGVAL(3)="0504030201"
            #LOGIN X3 FOR FOLDER SOLSUPV6/SUPERV
            AX3USER(0)="SB"
            AX3PWD(0)=""            
            #LOGIN X3 FOR FOLDER SOLPAIEV6/PAIEV6
            AX3USER(1)="ADMIN"
            AX3PWD(1)=""
         Endif 
  
        
        # DONNEES COMPLEMENTAIRES TRAITES PAR MAPPING DANS LA FICHE ACTION XTEND
        # ADDITIONNAL USER INFORMATION PEFORMED BY MAPPING IN XTEND ACTION PARAMETER FORM

        SHIPADR1(0)="Sage MGE"       
        SHIPADR2(0)="5 Avenue Victor Hugo"   
        SHIPCITY(0)="Echirolles"
        SHIPZIP(0)="38130"

        SHIPADR1(1)="Sage Lyon new"       
        SHIPADR2(1)="1 boulevard Marius Vivier Merle"   
        SHIPCITY(1)="LYON"
        SHIPZIP(1)="69443"

        SHIPADR1(2)="Sage PARIS"       
        SHIPADR2(2)="10 rue Fructidor"   
        SHIPCITY(2)="PARIS"
        SHIPZIP(2)="75834"

        SHIPADR1(3)="Sage Production"       
        SHIPADR2(3)="20 Av. du président Allende"   
        SHIPCITY(3)="MONTREUIL"
        SHIPZIP(3)="93100"

        SHIPADR1(4)="Sage Bordeaux"       
        SHIPADR2(4)="14 avenue de Pythagore"   
        SHIPCITY(4)="MERIGNAC"
        SHIPZIP(4)="33700"  

        SHIPADR1(5)="Sage Metz"       
        SHIPADR2(5)="Saint Julien lès Metz"   
        SHIPCITY(5)="METZ"
        SHIPZIP(5)="57076"   

        If (WOK=1)    
            Call ADDMESSINF("You are connected with the user "+AXUSERCODE) From AWEB
        Endif
    Endif
End


$TEST
Return
