#<AdxTL>@(#)12.0.0.0 $Revision$
#MIPEA SOURCE REMERGE
GMOIPAY=[01/06/2011]
Raz GPILOBJ, GBIDC1, GBIDC2
Call OBJET("VEP",GBIDC1,GBIDC2) From GOBJET
End

###########################################################################
$ACTION
Case GACTION
 When "EXCEPTSAL"
  Case ACTION
   When "EXEC"    : Gosub EXCEPTION : # obsolète, maintenat il y a VEPEXC
  Endcase
 When "REGUL"
  Case ACTION
   When "EXEC"    : Gosub REGUL
  Endcase
 When "RETRO"
  Case ACTION
   When "EXEC"    : Gosub RETRO
  Endcase
 When "VEPHSR"
  Case ACTION
   When "OUVRE"    : Gosub OUVRE_HSR
   When "DEBUT"    : Gosub DEBUT_HSR
   When "OK"       : Gosub OK_HSR
  Endcase
Endcase
Return

###########################################################################
## Lecture bulletin => [M:VEPX]
###########################################################################
$OUVPAY
If clalev([F:HSP])=0 : Local File HISTOPAYE [HSP] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE  [RUB] : Endif
If clalev([F:CUM])=0 : Local File CUMUL     [CUM] : Endif
Local Integer I , J , K
If dim([L]BULCUM)<=0
 If clalev([F:ADW])=0 : Local File ADOVAL    [ADW] : Endif
 Local Char    BULCUM(GLONCUM)(1..6) , SALNET(GLONRUB) , LIBNET(GLONDES)
 Local Char    LIBCUM(20)(1..6)
#MIPEA - 2016-08-08 - X3PEOP-785 - START
 #For [ADW]ADW1 Where CMP="*" & FCY=GCURLEG & PARAM>="BULCUM1" & PARAM<="BULCUM6"
 For [ADW]ADW0 Where CMP="*" & FCY=GCURLEG & PARAM>="BULCUM1" & PARAM<="BULCUM6"
#MIPEA - 2016-08-08 - X3PEOP-785 - START
  J = val(right$([F:ADW]PARAM,7))
  If J>=1 & J<=dim([L]BULCUM)
   BULCUM(J) = [F:ADW]VALEUR
   Read [CUM]CUM0 = GCURLEG;BULCUM(J)
   LIBCUM(J) = [F:CUM]CUMPRN
  Endif
 Next
 #LIPET - 2018-09-06 - X3-92125 - START
 #Read [ADW]ADW0 = "";"";"PAERUB"
 Read [ADW]ADW0 = "*";GCURLEG;"PAERUB"
 #LIPET - 2018-09-06 - X3-92125 - END
 If !fstat
  [L]SALNET = [F:ADW]VALEUR
  Call LECTEXTRA([L]LIBNET,"RUBRIQUE","DES",GCURLEG,[L]SALNET) From ATEXTRA
 Endif
Endif
Return

$LECPAY
Raz [M:VEPX]
For J=1 To dim([L]BULCUM)
 Case J
  When 1 : [M:VEPX]LIB1 = LIBCUM(J)
  When 2 : [M:VEPX]LIB2 = LIBCUM(J)
  When 3 : [M:VEPX]LIB3 = LIBCUM(J)
  When 4 : [M:VEPX]LIB4 = LIBCUM(J)
  When 5 : [M:VEPX]LIB5 = LIBCUM(J)
 Endcase
Next J
I = 0
Link [HSP] With [RUB]RUB0 =[F:HSP]LEG;[F:HSP]RUB As [LHSP]
For [LHSP]HSP2 Where [F:HSP]BUL=[F:VEP]BUL
 If [F:HSP]TYP=6
  J = find([F:HSP]RUB,BULCUM)
  Case J
   When 1 : [M:VEPX]CUM11 = [F:HSP]AMT-[F:HSP]BAS : [M:VEPX]CUM21 = [F:HSP]AMT
   When 2 : [M:VEPX]CUM12 = [F:HSP]AMT-[F:HSP]BAS : [M:VEPX]CUM22 = [F:HSP]AMT
   When 3 : [M:VEPX]CUM13 = [F:HSP]AMT-[F:HSP]BAS : [M:VEPX]CUM23 = [F:HSP]AMT
   When 4 : [M:VEPX]CUM14 = [F:HSP]AMT-[F:HSP]BAS : [M:VEPX]CUM24 = [F:HSP]AMT
   When 5 : [M:VEPX]CUM15 = [F:HSP]AMT-[F:HSP]BAS : [M:VEPX]CUM25 = [F:HSP]AMT
   When 6 : [M:VEPX]NET   = [F:HSP]AMT-[F:HSP]BAS
  Endcase
 Elsif [F:RUB]AMTPRN>1 or [M:VEP0]DETAIL<>0
  ## Rubrique imprimable ou visu de toutes les rubriques calculées (clic droit Détail)
  Case [F:HSP]TYP
   When 1,7 : # Part salariale d'une cotisation ou d'une régul
    J = I
    I += 1
    Gosub SETRUB
    Case [F:RUB]AMTPRN
     When 1,2,4
      [M:VEPX]TX1(J) = [F:HSP]RAT
      [M:VEPX]MT1(J) = [F:HSP]AMT
### AWAITING MULTI CURRENCY
#MIPEA - 2017-05-12- US X3-11287- START
#JASMI - 2017-11-14 - X3-59363 - START
#      [M:VEPX]CONAMT(J) = [F:HSP]AMT * [F:VEP]CUREXC
      [M:VEPX]CONAMT(J) = [F:HSP]CONAMT
#JASMI - 2017-11-14 - X3-59363 - END
#MIPEA - 2017-05-12- US X3-11287- END
     When 3,5
      [M:VEPX]TX1(J) = -[F:HSP]RAT
      [M:VEPX]MT1(J) = -[F:HSP]AMT
### AWAITING MULTI CURRENCY
#MIPEA - 2017-05-12- US X3-11287- START
#JASMI - 2017-11-14 - X3-59363 - START
#      [M:VEPX]CONAMT(J) = -[F:HSP]AMT * [F:VEP]CUREXC
      [M:VEPX]CONAMT(J) = -[F:HSP]CONAMT
#JASMI - 2017-11-14 - X3-59363 - END
#MIPEA - 2017-05-12- US X3-11287- END
    Endcase
    If [F:HSP]RUB=[L]SALNET
     [M:VEPX]SALNET = [F:HSP]AMT
    Endif
   When 2,8 : # Part patronale d'une cotisation ou d'une régul
    If I<>0 & [F:HSP]RUB=[M:VEPX]RUB(I-1) & [F:HSP]TYP=2 & [F:HSP]BAS=[M:VEPX]BAS(I-1)
     J = I-1
    Else
     J = I
     I += 1
    Endif
    Gosub SETRUB
    Case [F:RUB]AMTPRN
     When 1,2,4
      [M:VEPX]TX2(J) = [F:HSP]RAT
      [M:VEPX]MT2(J) = [F:HSP]AMT
### AWAITING MULTI CURRENCY
#MIPEA - 2017-05-12- US X3-11287- START
#JASMI - 2017-11-14 - X3-59363 - START
#      [M:VEPX]CONAMT(J) = [F:HSP]AMT * [F:VEP]CUREXC
      [M:VEPX]CONAMT(J) = [F:HSP]CONAMT
#JASMI - 2017-11-14 - X3-59363 - END
#MIPEA - 2017-05-12- US X3-11287- END
     When 3,5
      [M:VEPX]TX2(J) = -[F:HSP]RAT
      [M:VEPX]MT2(J) = -[F:HSP]AMT
### AWAITING MULTI CURRENCY
#MIPEA - 2017-05-12- US X3-11287- START
#JASMI - 2017-11-14 - X3-59363 - START
#      [M:VEPX]CONAMT(J) = -[F:HSP]AMT * [F:VEP]CUREXC
      [M:VEPX]CONAMT(J) = -[F:HSP]CONAMT
#JASMI - 2017-11-14 - X3-59363 - END
#MIPEA - 2017-05-12- US X3-11287- END
    Endcase
  Endcase
 Endif
Next
[M:VEPX]NBLIG  = I
[M:VEPX]LIBNET = LIBNET
Return

$SETRUB
Local Char RUBDES(GLONAX3)
[M:VEPX]ROW(J) = [F:HSP]ROW
[M:VEPX]RUB(J) = [F:HSP]RUB
###**72216
[M:VEPX]TYP(J) = [F:HSP]TYP
If [F:RUB]AMTPRN=1 or [F:RUB]AMTPRN>=4
 [M:VEPX]BAS(J) = [F:HSP]BAS
Endif
#MIPEA - 2016-07-13 - REQ 114309 US274 - START
#Added "[L]" for local char RUBDES
Call LECTEXTRA([L]RUBDES,"RUBRIQUE","DES",[F:RUB]LEG,[F:RUB]COD) From ATEXTRA
If find([F:HSP]TYP,7,8)
 [M:VEPX]INTIT(J) = mess(101,10702,1)-[L]RUBDES : # régularisation
Else
 [M:VEPX]INTIT(J) = [L]RUBDES
Endif
[M:VEPX]PRN(J) = [F:RUB]AMTPRN
#MIPEA - 2016-07-13 - REQ 114309 US274 - END
Return

##########################################################################
## Ecran VEPX
##########################################################################
Subprog C_NBLIG
If status=75
 mkstat = 2
Endif
End

Subprog B2_NBLIG
If [M:VEP0]DETAIL
 [M:VEP0]DETAIL = 0
Else
 [M:VEP0]DETAIL = 1
Endif
Gosub OUVPAY
Gosub LECPAY
Affzo [M:VEPX]
If [M:VEP0]DETAIL
 Local Integer I
 For I=0 To [M:VEPX]NBLIG-1
  If [M:VEPX]PRN(I)=1
   Diszo [VEPX]ROW(I),RUB(I),INTIT(I)
  Endif
 Next I
Else
 Actzo [VEPX]NBLIG
Endif
mkstat = 99
End

##########################################################################
## Calcul avec prise en compte paye à l'envers
##########################################################################
$CALCUL
Local Integer PASAPAS, WOK , ENVERS
Local Decimal SAV_OBJ
If [M:VEP1]PST>1
 Call MESSAGE(mess(12,10703,1)) From GESECRAN
 # Opération impossible : ce bulletin a été comptabilisé
 Return
Endif
ENVERS = (val(PARAM(1))=1)
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
If ENVERS & dim(ENV_OBJRUB)<=0
 Local Char    ENV_OBJRUB(GLONRUB) , ENV_OBJVAR(GLONVRA) , ENV_INCVAR(GLONVRA)
 Local Char    SAV_OBJRUB(GLONRUB) , SAV_OBJVAR(GLONVRA) , SAV_INCVAR(GLONVRA)
 Local Integer SAV_TWDPAY
 Local Decimal SAV_VALEUR

 If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
 #LIPET - 2018-09-06 - X3-92125 - START
# Read [ADW]ADW0 = "";"";"PAERUB"
# ENV_OBJRUB = [F:ADW]VALEUR
# Read [ADW]ADW0 = "";"";"PAEVAR"
# ENV_INCVAR = [F:ADW]VALEUR
# Read [ADW]ADW0 = "";"";"PAEVAL"
# ENV_OBJVAR = [F:ADW]VALEUR
 Read [ADW]ADW0 = "*";GCURLEG;"PAERUB"
 ENV_OBJRUB = [F:ADW]VALEUR
 Read [ADW]ADW0 = "*";GCURLEG;"PAEVAR"
 ENV_INCVAR = [F:ADW]VALEUR
 Read [ADW]ADW0 = "*";GCURLEG;"PAEVAL"
 ENV_OBJVAR = [F:ADW]VALEUR
 #LIPET - 2018-09-06 - X3-92125 - END
Endif
GOK = 1
Trbegin [HSP]
 GFLGERR = 0
 If ENVERS
  Filter [HRCTR] Where REFNUM=[F:VEP]EMP & CTRNUM=[M:VEP0]CTRNUM & CTRDAT<=[M:VEP1]ENDDAT
  Readlock [HRCTR]CTR0 Last
  Filter [HRCTR]
  If fstat
   GOK = 0 : Call RSTA("HRCTR",[M:VEP0]CTRNUM) From GLOCK : Goto AB_TR1
  Endif
  SAV_TWDPAY = [F:HRCTR]TWDPAY
  SAV_OBJRUB = [F:HRCTR]OBJRUB
  SAV_OBJVAR = [F:HRCTR]OBJVAR
  SAV_INCVAR = [F:HRCTR]INCVAR
  [F:HRCTR]OBJRUB = ENV_OBJRUB
  [F:HRCTR]OBJVAR = ENV_OBJVAR
  [F:HRCTR]INCVAR = ENV_INCVAR
  [F:HRCTR]TWDPAY = 2
  Rewrite [HRCTR]
  If fstat
   GOK = 0 : Call FSTA("HRCTR") From GLOCK : Goto AB_TR1
  Endif
  Readlock [VLA]VLA0 = 4;"";"";"";[M:VEP0]EMP;[M:VEP0]PYRDAT;ENV_OBJVAR;[M:VEP0]BUL
  If fstat
   Raz [F:VLA]
   [F:VLA]TYP    = 4
   [F:VLA]BUL    = [M:VEP0]BUL
   [F:VLA]EMP    = [M:VEP0]EMP
   [F:VLA]DAT    = [M:VEP0]PYRDAT
   [F:VLA]VARCOD = ENV_OBJVAR
   [F:VLA]VARVAL = [M:VEPE]OBJ
   Write [VLA]
   SAV_VALEUR    = 0
  Else
   SAV_VALEUR    = [F:VLA]VARVAL
   [F:VLA]VARVAL = [M:VEPE]OBJ
   Rewrite [VLA]
  Endif
  If fstat
   GOK = 0 : Call FSTA("VLA") From GLOCK : Goto AB_TR1
  Endif
 Endif

#JASMI - 2017-05-16 - START
 Filter [F:HRPEOD]
 Read [F:HRPEOD]HRPEOD0 = [F:VEP]PERCOD; [F:VEP]PERYEA; [F:VEP]PERNUM
 If fstat : GOK = 0 : Call FSTA("HRPEOD") From GLOCK : Goto AB_TR1 : Endif
 Read [F:HRPEOH]HRPEOH0 = [F:VEP]PERYEA; [F:VEP]PERCOD
 If fstat : GOK = 0 : Call FSTA("HRPEOH") From GLOCK : Goto AB_TR1 : Endif
If func DIVPAYE.IS_KZA(GCURLEG)
  #ADNGO - 2017-06-07 - START
  #Read [F:ETR]ETR0 = [F:VEP]EMP; [F:VEP]CTRNUM; [F:VEP]CTRDAT; [F:VEP]PERYEA
  #Filter [F:ETR] Where REFNUM=[VEP]EMP and CTRNUM=[VEP]CTRNUM and TAXYEA=[VEP]PERYEA
  #Read [F:ETR]ETR0 Last
  #If fstat : GOK = 0 : Call FSTA("ETR") From GLOCK : Goto AB_TR1 : Endif
  Filter [F:ETR] Where REFNUM=[VEP]EMP and CTRNUM=[VEP]CTRNUM and TAXYEA=[VEP]PERYEA
   If fstat
      GOK = 0
      Call FSTA("ETR") From GLOCK
      Goto AB_TR1
   Else
      Read [F:ETR]ETR0 Last
   Endif
  #ADNGO - 2017-06-07 - END
Endif
If func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
  #ADNGO - 2017-06-07 - START
  #Read [F:ETA]ETA0 = [F:VEP]EMP; [F:VEP]CTRNUM; [F:VEP]CTRDAT; [F:VEP]PERYEA
  #Filter [F:ETA] Where REFNUM=[VEP]EMP and CTRNUM=[VEP]CTRNUM and TAXYEA=[VEP]PERYEA
  #Read [F:ETA]ETA0 Last
  #If fstat : GOK = 0 : Call FSTA("ETA") From GLOCK : Goto AB_TR1 : Endif
  Filter [F:ETA] Where REFNUM=[VEP]EMP and CTRNUM=[VEP]CTRNUM and TAXYEA=[VEP]PERYEA
  If fstat
    GOK = 0
    Call FSTA("ETA") From GLOCK
    Goto AB_TR1
  Else
    Read [F:ETA]ETA0 Last
  Endif
  #ADNGO - 2017-06-07 - END
Endif
#JASMI - 2017-05-16 - END

 Call PLAN([M:VEP0]BUL,PASAPAS,0) From GPLAN
 #82486 : Amélio des perfs
 If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif
 If GOK<1 : Goto AB_TR1 : Endif
 If ENVERS
  Filter [HRCTR] Where REFNUM=[F:VEP]EMP & CTRNUM=[M:VEP0]CTRNUM & CTRDAT<=[M:VEP1]ENDDAT
  Readlock [HRCTR]CTR0 Last
  Filter [HRCTR]
  If fstat
   GOK = 0 : Call RSTA("HRCTR",[M:VEP0]CTRNUM) From GLOCK : Goto AB_TR1
  Endif
  [F:HRCTR]OBJRUB = SAV_OBJRUB
  [F:HRCTR]OBJVAR = SAV_OBJVAR
  [F:HRCTR]INCVAR = SAV_INCVAR
  [F:HRCTR]TWDPAY = SAV_TWDPAY
  Rewrite [HRCTR]
  If fstat
   GOK = 0 : Call FSTA("HRCTR") From GLOCK : Goto AB_TR1
  Endif
 Endif
Commit
[M:VEP1]STA = [F:VEP]STA
Return

$AB_TR1
Rollback
Return

##########################################################################
## Exceptions de calcul du salarié
##########################################################################
$EXCEPTION
Call OUVRE_TRACE(mess(107,10703,1)) From LECFIC : # Liste des exceptions de calcul
Call EXCEPTSAL([M:VEP0]EMP,[M:VEP0]PYRDAT)
Call FERME_TRACE From LECFIC
TRA = 1
Return

Subprog EXCEPTSAL(MATRI,DATMAT)
Value Char MATRI
Value Date DATMAT
Local Char VRUBDES(GLONAX3)
Local Char ECHDES([V]GLONAX3)

If clalev([F:ECH])=0 : Local File EXCEPTH  [ECH] : Endif
If clalev([F:ECD])=0 : Local File EXCEPTD  [ECD] : Endif
If clalev([F:ECV])=0 : Local File EXCEPTV  [ECV] : Endif
If clalev([F:ECC])=0 : Local File EXCEPTC  [ECC] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
If clalev([F:VRA])=0 : Local File VARIA    [VRA] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA   [HRPOA] : Endif
If clalev([F:VEP])=0 : Local File VALEMP   [VEP] : Endif
Gosub OUVRE From WPDEFTABLE
Local Integer NBEX , TET , WOK
Local Char    LIGNE(250) , TIT(80), DES (GLONAX3)
Read [VEP]VEP0(2) = MATRI;DATMAT
Gosub LECEMP From WPDEFTABLE
Call ECR_TRACE(MATRI-[F:ID]NAM-[F:ID]SRN-format$("D:"+GFMDAT4,DATMAT),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
NBEX = 0
#MIPEA - 2016-07-13 - REQ 114309 US274 - START
#Added "[L]" for lacal char ECHDES and VRUBDES as defined in previous addition
For [ECH] Where LEG=GCURLEG
 Call LECTEXTRA([L]ECHDES,"EXCEPTH","DES",GCURLEG,[F:ECH]COD) From ATEXTRA
 TIT = mess(113,10703,1)-":"-[F:ECH]COD-[L]ECHDES
 TET = 0
 WOK = 1
 If ([F:ECH]FCY<>"" & [F:VEP]FCY<>[F:ECH]FCY)
& | ([F:ECH]PRF<>"" & [F:VEP]PRF<>[F:ECH]PRF)
& | ([F:ECH]SRV<>"" & [F:VEP]SRV<>[F:ECH]SRV)
& | ([F:ECH]EMPSTR<>"" & MATRI<[F:ECH]EMPSTR)
& | ([F:ECH]EMPEND<>"" & MATRI>[F:ECH]EMPEND)
  WOK = 0
 Endif
 If WOK & [F:ECH]POP<>""
  Read [HRPOA]POA0 = [F:ECH]POP;MATRI;[F:VEP]CTRNUM;[F:VEP]CTRDAT
  If fstat
   WOK = 0
  Endif
 Endif
 If WOK & [F:ECH]CRI<>""
  If !evalue([F:ECH]CRI)
   WOK = 0
  Endif
 Endif
 If WOK
  For [ECD]ECD0 Where LEG=GCURLEG and COD=[F:ECH]COD
   If ([F:ECD]DATSTR=[0/0/0] or DATMAT>[F:ECD]DATSTR)
&   & ([F:ECD]DATEND=[0/0/0] or DATMAT<[F:ECD]DATEND)
    Call LECTEXTRA([L]VRUBDES,"RUBRIQUE","DES",GCURLEG,[F:ECD]RUB) From ATEXTRA
    If [F:ECD]CCL=2
     LIGNE = mess(108,10703,1) : # Rubrique calculée
    Else
     LIGNE = mess(109,10703,1) : # Rubrique non calculée
    Endif
    LIGNE -= ":"-format$("K:"+num$(GLONRUB+2)+"X",[F:ECD]RUB)+[L]VRUBDES
    Gosub LIGNE
   Endif
  Next
#MIPEA - 2016-07-13 - REQ 114309 US274 - END
  For [ECC]ECC0 Where LEG=GCURLEG and COD=[F:ECH]COD
   If ([F:ECC]DATSTR=[0/0/0] or DATMAT>[F:ECC]DATSTR)
&   & ([F:ECC]DATEND=[0/0/0] or DATMAT<[F:ECC]DATEND)
    LIGNE = mess(110,10703,1)-mess([F:ECC]PER,10334,1)-":"-[F:ECC]TYP : # Périodicité cumuls
    Gosub LIGNE
   Endif
  Next
  For [ECV]ECV0 Where LEG=GCURLEG and COD=[F:ECH]COD
   If ([F:ECV]DATSTR=[0/0/0] or DATMAT>[F:ECV]DATSTR)
&   & ([F:ECV]DATEND=[0/0/0] or DATMAT<[F:ECV]DATEND)
    #Read [VRA]VRA0 = [F:ECV]VRA;GCURLEG
    Call LECTEXTRA([L]DES,"VARIA","DES",GCURLEG,[F:ECV]VRA) From ATEXTRA
    LIGNE = mess(114,10703,1)-format$("K:"+num$(GLONRUB+2)+"X",[F:ECV]VRA)+[L]DES-":"-mess([F:ECV]TYPINI,10315,1)
#    Réinitialisation variable
    If [F:ECV]VALSTD<>0
     LIGNE -= "("+num$([F:ECV]VALSTD)+")"
    Endif
    Gosub LIGNE
   Endif
  Next
 Endif
 If TET
  Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
 Endif
Next
If NBEX=0
 Call ECR_TRACE(mess(111,10703,1),0) From GESECRAN : # Pas d'exception de calcul
Else
 Call ECR_TRACE(mess(112,10703,1)-":"-num$(NBEX),0) From GESECRAN : # Nombre d'exceptions de calcul actives
Endif
End

$LIGNE
Gosub TETE
Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

$TETE
If !TET
 If TIT<>""
  Call ECR_TRACE(TIT,0) From GESECRAN : # Exception
  Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
 Endif
 TET = 1
 NBEX += 1
Endif
Return

##########################################################################
## Régularisations
##########################################################################
$REGUL
Call OUVRE_TRACE(mess(119,10703,1)) From LECFIC : # Liste des régularisations
Call REGULSAL([M:VEP0]EMP,[M:VEP0]PYRDAT,[M:VEP0]CTRDAT)
Call FERME_TRACE From LECFIC
TRA = 1
Return

Subprog REGULSAL(MATRI,DATMAT,CTRDAT)
Value Char MATRI
Value Date DATMAT
Value Date CTRDAT
If clalev([F:RGL])=0 : Local File REGUL    [RGL] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA   [HRPOA] : Endif
If clalev([F:VEP])=0 : Local File VALEMP   [VEP] : Endif
Gosub OUVRE From WPDEFTABLE
Local Integer NBEX , TET , WOK
Local Char    LIGNE(250) , TIT(80)
Local Char    RGLDES(GLONAX3)

Local Char CTR([V]GLONHRCTR), CTRCRI([V]GLONEML+[V]GLONHRCTR+1+10)

Read [VEP]VEP0(2) = MATRI;DATMAT
[L]CTR = [F:VEP]CTRNUM
##**82073
[L]CTRCRI = [L]MATRI + "~" + [L]CTR + "~" + format$("D:YYYYMMDD",[L]CTRDAT)

Gosub LECEMP From WPDEFTABLE

Call ECR_TRACE(MATRI-[F:ID]NAM-[F:ID]SRN-[F:HRCTR]CTRNUM-format$("D:"+GFMDAT4,DATMAT),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
NBEX = 0
For [RGL] Where LEG=GCURLEG
 TIT = ""
 TET = 0
 WOK = 1
 If ([F:RGL]FCY<>"" & [F:VEP]FCY<>[F:RGL]FCY)
& | ([F:RGL]PRF<>"" & [F:VEP]PRF<>[F:RGL]PRF)
& | ([F:RGL]SRV<>"" & [F:VEP]SRV<>[F:RGL]SRV)
& | ([F:RGL]EMPSTR<>"" & MATRI<[F:RGL]EMPSTR)
& | ([F:RGL]EMPEND<>"" & MATRI>[F:RGL]EMPEND)
& | ([F:RGL]ENASTR<>[0/0/0] & DATMAT<[F:RGL]ENASTR)
& | ([F:RGL]ENAEND<>[0/0/0] & DATMAT>[F:RGL]ENAEND)
  WOK = 0
 Endif
 If WOK & [F:RGL]POP<>""
  Read [HRPOA]POA0 = [F:RGL]POP;MATRI;[F:VEP]CTRNUM;[F:VEP]CTRDAT
  If fstat
   WOK = 0
  Endif
 Endif
 If WOK & [F:RGL]CRI<>""
  If !evalue([F:RGL]CRI)
   WOK = 0
  Endif
 Endif

 If [L]WOK & dim([F:RGL]CTRCRI) > 0 & [F:RGL]CTRCRI(0) <> ""
    If !find([L]CTRCRI, [F:RGL]CTRCRI)
        [L]WOK = 0
    Endif
 Endif

 If WOK
  Call LECTEXTRA(RGLDES,"REGUL","DES",[F:RGL]LEG,[F:RGL]COD) From ATEXTRA
  LIGNE = mess(101,10702,1)-":"-[F:RGL]COD-RGLDES
  Gosub LIGNE
 Endif
Next
If NBEX=0
 Call ECR_TRACE(mess(120,10703,1),0) From GESECRAN : # Pas de régularisation
Else
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
 Call ECR_TRACE(mess(121,10703,1)-":"-num$(NBEX),0) From GESECRAN : # Nombre de régularisations
Endif
End

##########################################################################
## Rétroactivités
##########################################################################
$RETRO
Call OUVRE_TRACE(mess(211,10702,1)) From LECFIC : # Liste des fiches de rétroactivité
Call RETROSAL([M:VEP0]BUL,[M:VEP0]EMP,[M:VEP0]CTRNUM)
Call FERME_TRACE From LECFIC
TRA = 1
Return

Subprog RETROSAL(BULLETIN,MATRI,CTR)
Value Char BULLETIN
Value Char MATRI
Value Char CTR

If ! clalev([F:ID])  : Local File EMPLOID [ID] : Endif
If ! clalev([F:REC]) : Local File RETROCAL [REC] : Endif

Read [F:ID]ID0=MATRI
If !fstat
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
 Call ECR_TRACE(MATRI-[F:ID]NAM-[F:ID]SRN-CTR-mess(104,10703,1)-":"-BUL,0) From GESECRAN
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
 NBEX = 0
 For [REC] Where RECBUL=BUL & RECREFNUM=MATRI & RECCTRNUM=CTR
   NBEX+=1
#MIPEA - 2016-07-13 - REQ 114309 US274 - START
    Call ECR_TRACE( mess(2,10725,1)-":"-[F:REC]RETNUM,0) From GESECRAN    :#Fiche de rétroactivité
   #Call ECR_TRACE( mess(2,10646,1)-":"-[F:REC]RETNUM,0) From GESECRAN    :#Fiche de rétroactivité
#MIPEA - 2016-07-13 - REQ 114309 US274 - END
 Next
 If NBEX=0
  Call ECR_TRACE(mess(212,10702,1),0) From GESECRAN : # Pas de rétroactivité pratiquée dans ce bulletin.
 Else
  Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Call ECR_TRACE(mess(213,10702,1)-":"-num$(NBEX),0) From GESECRAN : # Nombre de rétroactivité intégrées sur ce bulletin
 Endif
Else
  Call ECR_TRACE(mess(83,10702,1),1) From GESECRAN : # Matricule inexistant
Endif
End

##########################################
#Historique des réguls
##########################################

###**72216
Subprog IB_NBLIG
If [VEPX]TYP(nolign-1)<>7 & [VEPX]TYP(nolign-1)<>8
 Raz [V]GBOUT3
Endif
End

$OUVRE_HSR
If clalev([F:THR])=0  : Local File TMPHSR [THR] : Endif
Local Char BULCUR (GLONVCR)
Local Char RUBCUR (GLONRUB)
Local Char RETCUR (GLONVCR)
Local Char MATCUR (GLONEML)
#MIPEA - 2016-08-12 - X3PEOP-763 - START
Local Char CTRCUR (GLONHRCTR)
#Local Char CTRCUR (GLONCTR)
#MIPEA - 2016-08-12 - X3PEOP-763 - START
Local Date DATCUR
Local Char TRT (GLONADC)
Local Char CRITERE (250)
Raz GBIDD1, GBIDD2, GBIDI1
Return

$DEBUT_HSR
Raz [M:VEHR]
[L]BULCUR=PARAM(1) : [L]RUBCUR=PARAM(2) : [L]RETCUR=PARAM(3)
[L]MATCUR=PARAM(4) : [L]CTRCUR=PARAM(5) : [L]DATCUR=gdat$(PARAM(6))
[L]TRT=PARAM(7)

If [L]RUBCUR='' & ([L]BULCUR='' | [L]RETCUR='')
 Return
Endif
[M:VEHR]RUBCOD=[L]RUBCUR
nolign=0

CRITERE="RUB='"+[L]RUBCUR+"'"
If [L]BULCUR<>''
 CRITERE-="& BUL='"+[L]BULCUR+"'"
Endif
If [L]RETCUR<>''
 CRITERE-="& RETNUM='"+[L]RETCUR+"'"
Endif
If [L]MATCUR<>''
 CRITERE-="& EMP='"+[L]MATCUR+"'"
Endif
If [L]CTRCUR<>''
 CRITERE-="& CTRNUM='"+[L]CTRCUR+"'"
Endif
If [L]DATCUR<>[0/0/0]
 CRITERE-="& CTRDAT=["+num$([L]DATCUR)+"]"
Endif
If [L]TRT<>''
 CRITERE-="& CODTRT='"+[L]TRT+"'"
Endif

For [F:THR]THR0 Where evalue(CRITERE)
 nolign+=1
 [M:VEHR]=[F:THR]
 [M:VEHR]SALPAT(nolign-1)=[F:THR]TYP-6
 [M:VEHR]FLGMOD(nolign-1)=0
 Case [F:THR]TYP
  When 7 : [M:VEHR]TOTAMT1 += [F:THR]AMT
  When 8 : [M:VEHR]TOTAMT2 += [F:THR]AMT
 Endcase
Next
[M:VEHR]NBHSR=nolign
Affzo [M:VEHR]
Return

$OK_HSR
#Régul déjà passée en paie : modif interdite
If [L]BULCUR<>'' : Return : Endif

Local Integer I
GOK=1
For I=1 To [M:VEHR]NBHSR
 If [M:VEHR]FLGMOD(I-1)=1
  Readlock [F:THR]THR0=[L]TRT;[L]RETCUR;[M:VEHR]BUL(I-1);[M:VEHR]RUBCOD;[M:VEHR]TYP(I-1);[M:VEHR]ORIBUL(I-1)
  If !fstat
   [F:THR]AMT = [M:VEHR]AMT(I-1)
   [F:THR]TYPAMT = [M:VEHR]TYPAMT(I-1)
   Rewrite [F:THR]
   If fstat
    GOK = 0
    Call FSTA("THR") From GLOCK
    Break
   Endif
   GBIDI1=1
  Else
   GOK=0 : Break
  Endif
 Endif
Next
If !GOK
 Call ERREUR('MAJ impossible') From GESECRAN
Endif
If dim([M:RET3]NBVCAL)>=0
 GBIDD1=[M:VEHR]TOTAMT1 : GBIDD2=[M:VEHR]TOTAMT2
Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran VEPHSR) 09/07/2013 19:07:28 (DBA)
######################################################################################
$SETNOL
Local Integer NOL
[L]NOL = nolign-1
Return

Subprog AS_AMT(VALEUR)
Variable Decimal VALEUR
#Régul déjà passée en paie : modif interdite
Gosub SETNOL
If [M:VEHR]BUL([L]NOL)<>'': mkstat=2 : End : Endif
End

Subprog AM_AMT(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If [M:VEHR]TYPAMT([L]NOL)<>2
 [M:VEHR]TYPAMT([L]NOL)=2
Endif
[M:VEHR]FLGMOD([L]NOL)=1
End

Subprog APRES_NBHSR
Gosub RECALTOT
End

$RECALTOT
Local Integer I
Raz [M:VEHR]TOTAMT1,TOTAMT2
For I=1 To [M:VEHR]NBHSR
 Case [M:VEHR]TYP
  When 7 :  [M:VEHR]TOTAMT1 += [M:VEHR]AMT (I-1)
  When 8 :  [M:VEHR]TOTAMT2 += [M:VEHR]AMT (I-1)
 Endcase
Next
Affzo [M:VEHR]TOTAMT1,TOTAMT2
Return

