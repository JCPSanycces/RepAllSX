#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ENTSAL1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:08"
A_USER  = "DOC"
A_STAMP = "20181109230408"
Return

$TITRES
Chgtzn [M:ENT1]ADD1 With [F:TCY]ADRNAM(0)
Chgtzn [M:ENT1]ADD2 With [F:TCY]ADRNAM(1)
Chgtzn [M:ENT1]ADD3 With [F:TCY]ADRNAM(2)
Return

$CHG_FMT
Case zoncou
 When "NBRCHEF"
  If [M]NBRCHEF=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ENTSAL1 [ENT1]
Gosub HORODAT
Local Inpbox "ENTSAL1" From GFONCTION At A_STAMP With A_WINDPREV Mask [ENT1] As [SIM_]
Grizo [ENT1]10
Grizo [ENT1]20
Grizo [ENT1]30
Grizo [ENT1]40
Grizo [ENT1]50
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ENT1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=64 : Y1(0)=1 : Y2(0)=8
X1(1)=1 : X2(1)=64 : Y1(1)=9 : Y2(1)=23
X1(2)=65 : X2(2)=96 : Y1(2)=1 : Y2(2)=5
X1(3)=65 : X2(3)=96 : Y1(3)=6 : Y2(3)=8
X1(4)=65 : X2(4)=96 : Y1(4)=9 : Y2(4)=23
Return

$ON_CRY
Onevent CONTROL Call C_CRY(zc) From W1ENTSAL1
Onevent AFTER_CHANGE Gosub AMM_CRY From W1ENTSAL1
Onevent BEFORE_INPUT Call AS_CRY(zc) From W1ENTSAL1
Onevent INIT_AREA Call D_CRY(zc) From W1ENTSAL1
Return

Subprog D_CRY(VALEUR)
Variable Char    VALEUR()
If varinit([M]CRY,indice)=0
 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_CRY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(53316,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CRY(zc) From W1ENTSAL1
Onkey   2 Titled GBOUTS Call S_CRY(zc) From W1ENTSAL1
Onkey 144 Titled GBOUTP Call P_CRY(zc) From W1ENTSAL1
Onkey 146 Titled GBOUTA Call SA_CRY(zc) From W1ENTSAL1
Gosub _AFF
End

Subprog C_CRY(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
If !mkstat
 ## Action STD
 Call C_CRY(VALEUR) From SUBHRENT
 If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
Endif
Gosub _AFF
End

$AMM_CRY
Call AM_CRY(zc)
If !mkstat & GOBJET
 zoncou = "CRY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CRY(VALEUR)
Variable Char    VALEUR()
## Action INIPAYS
Call INIPAYS(VALEUR,[M]CRYNAM) From TRTDIV
If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
Gosub _AFF
End

Subprog S_CRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CRY(VALEUR)
Variable Char    VALEUR()
Call OBJET("TCY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CRY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_CRYNAM
Onevent BEFORE_INPUT Call AS_CRYNAM(zc) From W1ENTSAL1
Return

Subprog AS_CRYNAM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
If !GWEBSERV
 ## Action SAIPAYS
 Call SAIPAYS([M]CRY) From TRTDIV
 If mkstat=2
  [M]CRYNAM(INDIC) = VALEUR
  Affzo CRYNAM(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

$ON_ADD1
Onevent BEFORE_AREA Gosub AV_ADD1 From W1ENTSAL1
Return

$AV_ADD1
## Action FMTADRPAY
Call FMTADRPAY([M]CRY) From TRTDIV
If GFMT<>""
 Chgfmt [M]ADD1(indice) With "K:"+GFMT
Else
 Chgfmt [M]ADD1(indice) With "-K:1X"
Endif
Gosub _AFF
Return

