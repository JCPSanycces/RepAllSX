Return

Subprog D_SEX(VALEUR)
Variable Integer VALEUR
If varinit([M]SEX,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SEX(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10314) From COMBOS
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10314,1))))
Endif
If !mkstat
 Discombo 0 From SEX(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From SEX(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_SEX(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SEX" : GZNUM = 44770 : Endif
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

