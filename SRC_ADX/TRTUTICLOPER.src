#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTUTICLOPER","FUTICLOPER",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
 When "SORTIE"      : Gosub SORTIE # <JFL>
Endcase
Return

$OUVRE
If clalev([F:CPY])=0   : Local File COMPANY     [CPY]   : Endif
If clalev([F:GCM])=0   : Local File GACM        [GCM]   : Endif
If clalev([F:FIY])=0   : Local File FISCALYEAR  [FIY]   : Endif
If clalev([F:PER])=0   : Local File PERIOD      [PER]   : Endif
If clalev([F:DAE])=0   : Local File GACCENTRYD  [DAE]   : Endif
If clalev([F:BAL])=0   : Local File BALANCE     [BAL]   : Endif
If clalev([F:BLA])=0   : Local File BALANA      [BLA]   : Endif
If clalev([F:BLM])=0   : Local File BLACMM      [BLM]   : Endif
If func AFNC.ACTIV("REGBC")
 If clalev([F:BCREG])=0 : Local File BANKCASHREG [BCREG] : Endif
Endif
If func AFNC.ACTIV("FIFRC")
 If clalev([F:BAN])   =0  : Local File BANK        [BAN]    : Endif
 If clalev([F:FIFCV]) =0  : Local File FIFOCONVAR  [FIFCV]  : Endif
 If clalev([F:FIFCV2])=0  : Local File FIFOCONVAR  [FIFCV2] : Endif
 If clalev([F:PER2])  =0  : Local File PERIOD      [PER2]   : Endif
Endif

Local Decimal EXERCICE , PERIODE
Local Integer ANOUV, AREF , CONFIRM
Local Integer FLGOK(0..len(mess(0,2644,1))-1)
For I=0 To len(mess(0,2644,1))-1
 FLGOK(I)=1
Next
Return

$INIT
Gosub OUVRE
Return

$INIT_DIA
Return

$CONTROLE
# <JFL>
Call LOCKCPY([M:DIA]CPY, OK) From AX3MONO
If !OK : FIN=1 : Endif
# </JFL>

#Boucle sur les types de référentiel
For I=0 To [M]NBLIG-1
 CONFIRM = 0
 If [M]CLOPER(I)=2
  Call GETPERSOC([M:DIA]CPY,[M:DIA]LEDTYP(I),[M:DIA]STRDAT(I),EXERCICE,PERIODE) From CPTSUB
  Read [PER]PER0 = [M:DIA]CPY;[M:DIA]LEDTYP(I);EXERCICE;PERIODE
  Filter [DAE] Where CPY=[M:DIA]CPY & LEDTYP=[M:DIA]LEDTYP(I) & ACCDAT>=[F:PER]PERSTR & ACCDAT<=[F:PER]PEREND
  Read [DAE]DAE4 First
  If !fstat
   # Période mouvementée, fermeture impossible (référentiel)
   Call ECR_TRACE(mess(54,101,1)-"("+mess([M:DIA]LEDTYP(I),2644,1)+")",0)  From GESECRAN
   FLGOK(I)=0
  Endif

  If GMODU(14)=G_OUI
   Local Integer RCNX, RPLN
   If func GLOBIENS.IS_PERCPT_CLOSABLE([M:DIA]CPY, [M:DIA]LEDTYP(I), [M:DIA]STRDAT(I), [M:DIA]ENDDAT(I), RCNX, RPLN) <> 1
    # Période correspondante dans les immos ne permet pas la fermeture
    Call ECR_TRACE(func GLOFUNC.SUBSTIT2(mess(269,7770,1),
&                                        mess(RPLN,3101,1),
&                                        mess(RCNX,3100,1)),0)  From GESECRAN
    FLGOK(I)=0
   Endif
  Endif

  If FLGOK(I)
   # Il n'y a pas de mouvement sur la période sur laquelle on se trouve, on peut donc la refermer...
   # mais si on se trouve sur la première période d'un exercice, il peut dans la balance y avoir
   # des reports à nouveaux. On demande donc l'autorisation de les supprimer
   # Ici, si on ne peut lire d'enregistrement c'est que l'on se trouve bien
   # sur la premiere période d'un exercice, on vérifie donc les anouveaux
   Filter [PER] Where CPY=[M:DIA]CPY & LEDTYP=[M:DIA]LEDTYP(I) & FIYNUM=EXERCICE & PERNUM<>PERIODE & PERSTA<>1
   Read [PER]PER0 First
   If fstat : CONFIRM=1 : Endif :
   Filter [PER]
   If CONFIRM
    Raz ANOUV
    # ANX simulés mettent à jour la balance.
    # Si ANX sont réels, des pièces comptables seraient générées et donc il y aurait blocage
    # au contrôle précédent.

    Filter [BAL] Where CPY=[M:DIA]CPY & LEDTYP=[M:DIA]LEDTYP(I) & FIY=EXERCICE & (CDT(0)<>0 | DEB(0)<>0 | CDTLED(0)<>0 | DEBLED(0)<>0)
    Read [BAL]BAL0 First
    If !fstat : ANOUV=1 : Endif
    Filter [BAL]

    Filter [BLA] Where CPY=[M:DIA]CPY & LEDTYP=[M:DIA]LEDTYP(I) & FIY=EXERCICE & (CDT(0)<>0 | DEB(0)<>0 | CDTLED(0)<>0 | DEBLED(0)<>0)
    Read [BLA]BLA0 First
    If !fstat : ANOUV+=2 : Endif
    Filter [BLA]

    If ANOUV
     # Suppression d'A-nouveaux simulés (référentiel) /  Voulez vous continuer ?
     Call AVERTIR (mess(124,116,1)-"("+mess([M:DIA]LEDTYP(I),2644,1)+")"-"\"+mess(205,100,1),OK) From GESECRAN
     If OK=2
      FLGOK(I)=ANOUV
     Else
      FLGOK(I)=0
     Endif
    Endif :# ANOUV
   Endif :# CONFIRM
  Endif :# FLGOK(I)
 Endif :# [M]CLOPER=2
 If func AFNC.ACTIV("FIFRC")
  If func AFNC.PARAM("FIFRC",[M:DIA]CPY) = "2"
   Gosub FIFRC_CLOPER
  Endif
 Endif
Next I
If func AFNC.ACTIV("REGBC")
  If func AFNC.PARAM("BCREG",[M:DIA]CPY) = "2"
    Gosub BCREG_CLOPER
  Endif
Endif
TMP=1
Return

$SORTIE
Call UNLOCKCPY() From AX3MONO # <JFL>
Return

$EXEC
TIT = mess(101,107,1)  :# Fermeture période
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ

OK=0
Call DEBTRANS From GLOCK
Gosub TR1

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
TRA = 1
Return


$TR1
Trbegin [PER], [FIY], [BAL], [BLA]
OK=0
For I=0 To [M]NBLIG-1
 If [M]CLOPER(I)=2
  If FLGOK(I)>0 : # cf $CONTROLE
   Call CLOPER([M]CPY,[M]LEDTYP(I),[M]STRDAT(I),FLGOK(I),OK)
   If OK : Break : Endif
  Endif
 Endif
Next I
Case OK
 When 1 : Goto AB_TR1
 When 2 : Goto ROLL_TR1
Endcase
Commit
Return


Subprog CLOPER(SOC,LEDTYP,DATDEB,ANOUV,STAT)
Value Char        SOC
Value Integer     LEDTYP
Value Date        DATDEB
Value Integer     ANOUV
Variable Integer  STAT

Local Integer AREF
Local Decimal EXERCICE, PERIODE

Call GETPERSOC(SOC,LEDTYP,DATDEB,EXERCICE,PERIODE) From CPTSUB

Readlock [PER]PER0 = SOC ; LEDTYP ; EXERCICE ; PERIODE
If fstat=1
 GOK = -1 : GLOCK="$PERIOD"-SOC-num$(LEDTYP)-num$(EXERCICE)-num$(PERIODE) : STAT=2 : End
Elsif fstat
 GOK = 0 : Call RSTA("PER",SOC-num$(LEDTYP)-num$(EXERCICE)-num$(PERIODE)) From GLOCK : STAT=1 : End
Else
 [F:PER]PERSTA = 1
 Rewrite [PER]
 If fstat
  GOK = 0 : Call FSTA("PER") From GLOCK : STAT=1 : End
 Endif
 Call PERAUT(SOC,LEDTYP,EXERCICE,PERIODE,GOK) From SUBPER
 If !GOK : STAT=1 : End : Endif
 If GTRACE<>""
  Call ECR_TRACE(mess(2,116,1)-":"-SOC-mess(3,116,1)-num$(EXERCICE)-mess(59,116,1)-num$(PERIODE)-"("+mess(LEDTYP,2644,1)+")",0)
&  From GESECRAN
 Endif

 Filter [PER] Where CPY=SOC & LEDTYP=[L]LEDTYP & FIYNUM=EXERCICE & PERSTA<>1
 Read [PER]PER0 First
 If fstat
  # Bug 11171 : il faut fermer aussi les exercices suivants
  For [FIY]FIY0 Where CPY=SOC & LEDTYP=[L]LEDTYP & FIYNUM>=EXERCICE & FIYSTA<>1
   Readlock [FIY] Curr
   If fstat=1
    GOK = -1 : GLOCK="$FISCALYEAR"-SOC-num$(LEDTYP)-num$([F:FIY]FIYNUM) : STAT=2 : Break
   Elsif fstat
    GOK = 0 : Call RSTA("FIY",SOC-num$(LEDTYP)-num$([F:FIY]FIYNUM)) From GLOCK : STAT=1 : Break
   Else
    [F:FIY]FIYSTA = 1
    Rewrite [FIY]
    If fstat
     GOK = 0 : Call FSTA("FIY") From GLOCK : STAT=1 : Break
    Endif
    Call FIYAUT(SOC,LEDTYP,EXERCICE,GOK) From SUBFIY
    If !GOK : STAT=1 : Break : Endif
   Endif
  Next
  If GOK <=0 : End : Endif

  # Suppression des ANX simulés
  Case ANOUV
   When 1 : # Uniquement balance générale
    Gosub RAZANXBAL
   When 2 : # Uniquement balance analytique
    Gosub RAZANXBLA
   When 3 : # Balance géné ET analytique
    Gosub RAZANXBAL
    Gosub RAZANXBLA
  Endcase
 Endif
 Filter [PER]
Endif
End

$RAZANXBAL
Filter [BAL] Where CPY=SOC & LEDTYP=[L]LEDTYP & FIY=EXERCICE & (CDT(0)<>0 | DEB(0)<>0 | CDTLED(0)<>0 | DEBLED(0)<>0)
For [BAL]BAL0
 Readlock [BAL] Curr
 If fstat=1
  GOK = -1 : GLOCK="$BALANCE"-SOC-num$(LEDTYP)-num$([F:FIY]FIYNUM) : STAT=2 : Break
 Elsif fstat
  GOK = 0 : Call RSTA("BALANCE",SOC-num$(LEDTYP)-num$([F:FIY]FIYNUM)) From GLOCK : STAT=1 : Break
 Else
  [F:BAL]CDT(0)    = 0
  [F:BAL]DEB(0)    = 0
  [F:BAL]CDTLED(0) = 0
  [F:BAL]DEBLED(0) = 0
  Rewrite [BAL]
  If fstat
   GOK = 0 : Call FSTA("BAL") From GLOCK : STAT=1 : Break
  Endif
 Endif
Next
Filter [BAL]
If GOK <= 0 : Return : Endif
Return

$RAZANXBLA
Filter [BLA] Where CPY=SOC & LEDTYP=[L]LEDTYP & FIY=EXERCICE & (CDT(0)<>0 | DEB(0)<>0 | CDTLED(0)<>0 | DEBLED(0)<>0)
For [BLA]BLA0
 Readlock [BLA] Curr
 If fstat=1
  GOK = -1 : GLOCK="$BALANA"-SOC-num$(LEDTYP)-num$([F:FIY]FIYNUM) : STAT=2 : Break
 Elsif fstat
  GOK = 0 : Call RSTA("BALANA",SOC-num$(LEDTYP)-num$([F:FIY]FIYNUM)) From GLOCK : STAT=1 : Break
 Else
  [F:BLA]DEB(0)    = 0
  [F:BLA]CDT(0)    = 0
  [F:BLA]DEBLED(0) = 0
  [F:BLA]CDTLED(0) = 0
  Rewrite [BLA]
  If fstat
   GOK = 0 : Call FSTA("BLA") From GLOCK : STAT=1 : Break
  Endif
 Endif
Next
Filter [BLA]
If GOK<=0 : Return : Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
#########################################################
$BCREG_CLOPER
Filter [F:BCREG] Where [F:BCREG]CPY = [M:DIA]CPY  & [F:BCREG]STA <> 2 &
& (([F:BCREG]STARTDAT >= [F:PER]PERSTR & [F:BCREG]STARTDAT <= [F:PER]PEREND) or
& ([F:BCREG]FINDAT >= [F:PER]PERSTR & [F:BCREG]FINDAT <= [F:PER]PEREND))
Look [F:BCREG] First
If !fstat
  Call ECR_TRACE( func AFNC.MES1(mess(40,7702,1),[M:DIA]CPY) ,1) From GESECRAN : FIN =1
Endif
Filter [F:BCREG]
Return
#########################################################
#########################################################
$FIFRC_CLOPER
Local Date FIFRCPERSTR, FIFRCPEREND
Local Integer  LI, LPF
[L]LI = 1 : [L]LPF = 1

Filter [F:PER2] Where [F:PER2]CPY=[M:DIA]CPY and [F:PER2]LEDTYP=[M:DIA]LEDTYP(I) and [F:PER2]FIYNUM=EXERCICE
Read [F:PER2]PER0 First
[L]FIFRCPERSTR = [PER2]PERSTR

Read [F:PER2]PER0 Last
[L]LPF         = [PER2]PERNUM
[L]FIFRCPEREND = [PER2]PEREND
Filter [F:PER2]

If [L]LPF <> [F:PER]PERNUM
 Filter [F:FIFCV] Where [F:FIFCV]CPY = [M:DIA]CPY and [F:FIFCV]FLDPOS <> 2 and
&                       (([F:FIFCV]STARTDAT >= [F:PER]PERSTR and [F:FIFCV]STARTDAT <= [F:PER]PEREND) or
&                        ([F:FIFCV]FINDAT >= [F:PER]PERSTR and [F:FIFCV]FINDAT <= [F:PER]PEREND))
Else
 Filter [F:FIFCV] Where [F:FIFCV]CPY = [M:DIA]CPY and [F:FIFCV]FLDPOS <> 2 and
&                       (([F:FIFCV]STARTDAT >= [L]FIFRCPERSTR and [F:FIFCV]STARTDAT <= [L]FIFRCPEREND) or
&                        ([F:FIFCV]FINDAT >= [L]FIFRCPERSTR and [F:FIFCV]FINDAT <= [L]FIFRCPEREND))
Endif
Read [F:FIFCV] First
#Issue X3-70885 & X3-71035 – 2018-01-18 by MADOR - Additional FIFO conversions - Closing last period
If !fstat
 Call AVERTIR(mess(17,7708,1)-mess(432,7773,1), [L]LI) From GESECRAN
 If [L]LI <> 2 : FIN = 1 : Endif
Else
 Gosub CHECK_IF_FIFO_EXIST
Endif
#Issue end
Filter [F:FIFCV]
Return
#########################################################
# Etiquettes du masque UTICLOPER
#########################################################

Subprog C_CPY(VALEUR)
Variable Char     VALEUR()

Filter [PER] Where CPY=VALEUR & PERSTA=2
Read [PER]PER0 Last
If fstat
 Effzo STRDAT, ENDDAT
 # Il n'y a aucune période à refermer
 GMESSAGE = mess(53,101,1)
 mkstat = 2 : End
Endif
Filter [PER]

# DBA le 18/03/03 : Sugg 15007
#Subprog AP_CPY(VALEUR)
#Variable Char     VALEUR()
#Filter [PER] Where CPY=VALEUR & PERSTA=2
#Read [PER]PER0 Last
#If !fstat
# [M]STRDAT = [F:PER]PERSTR
# [M]ENDDAT = [F:PER]PEREND
# Affzo STRDAT, ENDDAT
#Else
# Effzo STRDAT, ENDDAT
# # Il n'y a aucune période à refermer
# GMESSAGE = mess(53,101,1)
# mkstat = 2 : End
#Endif
#Filter [PER]

If VALEUR<>""
 Call LECTURE("CPY",VALEUR,"") From CONTOBJ
 Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ

 Raz [M]NBLIG
 NOK=0
 For I=0 To len(mess(0,2644,1))-1
  If [F:GCM]LED(I)<>"" & [F:GCM]CFMAUT(I)<>2
   [M]LEDTYP([M]NBLIG)=I+1
   Filter [PER] Where LEDTYP=[M]LEDTYP([M]NBLIG) & CPY=VALEUR & PERSTA=2
   Read [PER]PER0 Last
   If !fstat
    [M]STRDAT([M]NBLIG) = [F:PER]PERSTR
    [M]ENDDAT([M]NBLIG) = [F:PER]PEREND
    Affzo STRDAT([M]NBLIG), ENDDAT([M]NBLIG)
   Elsif fstat
    Effzo STRDAT([M]NBLIG), ENDDAT([M]NBLIG)
    Grizo CLOPER([M]NBLIG)
    NOK+=1
   Endif
   [M]NBLIG+=1
   Filter [PER]
  Endif
 Next I
 If NOK=[M]NBLIG
  # Il n'y a aucune période à refermer
  GMESSAGE = mess(53,101,1)
  mkstat = 2 : End
 Endif
 Affzo [M:DIA]
Endif
End


$SETNOL
Local Integer NOL
NOL=nolign-1
Return
######################################################################################
$CHECK_IF_FIFO_EXIST
#Issue X3-70885 & X3-71035 – 2018-01-18 by MADOR - Additional FIFO conversions - Closing last period
Local Date FIRSTSTARTDAT #Start date of first fifo record for some bank/cash
Filter [F:BAN] Where [F:BAN]CPY = [M:DIA]CPY and [F:BAN]FLDFIFCP = 2 and [F:BAN]FLDSDA <= [F:PER]PERSTR
For [F:BAN]BAN1
    Filter [F:FIFCV2] Where [F:FIFCV2]FIFCOD = [F:BAN]BAN and
&                           (([F:FIFCV2]STARTDAT >= [F:PER]PERSTR and [F:FIFCV2]STARTDAT <= [F:PER]PEREND) or
&                            ([F:FIFCV2]FINDAT >= [F:PER]PERSTR and [F:FIFCV2]FINDAT <= [F:PER]PEREND) or
&                            ([F:FIFCV2]STARTDAT < [F:PER]PERSTR and [F:FIFCV2]FINDAT > [F:PER]PEREND))
    Read [F:FIFCV2] First
    If fstat
        Call AVERTIR(func AFNC.MES1(mess(22,7708,1)-mess(432,7773,1), [F:BAN]BAN), [L]LI) From GESECRAN
        If [L]LI <> 2 : FIN = 1 : Break : Endif
    Endif
Next

Filter [F:BAN]
Filter [F:FIFCV2]
#Issue end
Return

