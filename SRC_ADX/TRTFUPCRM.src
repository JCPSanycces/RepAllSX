#<AdxTL>@(#)7.0.0.0 $Revision$
# Creation of task with status "Not completed"

######################################################################################
# création d'une tâche CRM pour une échéance donnée
######################################################################################

Local Char PARAM(10)(1..2), VALEUR(10)
GERR = 0
GPROG    = "TRTCFUP"
GTYPPROG = 4
GWINDOW  = "DFUP"
GWINCRIT = "CRITFUP"
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GWINCRIT,GTYPPROG,"") From GTRAITE
End

######################################################################################
# création d'une tâche CRM pour une échéance donnée
######################################################################################
Subprog CRM()

Local Char TSKNUM        # task code
Local Integer ERRCOD     # error code

# we use the standard sub-program for task creation
# the necessary information for task creation is stored in masks TK0, TK1 and TK2
Call CRETSK("TRTFUPCRM", 0, 0, TSKNUM, ERRCOD) From SUBTSKCC
End

$TSK_SET_HEA_INFO
Case IMPZON

 When "SALFCY"
  [M:TSK0]SALFCY = [F:DUD]FCY

 When "TSKNUM"
  Local Clbfile TSKDES
  [M:TSK0]TSKNUM = ""
  [L]TSKDES = ""
  # rajouter le solde global relancé
  [M:TSK2]FULRPO = [M:TK2]FULRPO
  [M:TSK0]TSKDON = [M:TK0]TSKDON

 When "TSKCMP"
  [M:TSK0]TSKCMP = [F:TFP4]BPC

 When "TSKDON"
  [M:TSK0]TSKDON = [M:TK0]TSKDON

 When "TSKSTR"
  # Début = date de création de la campagne
  [M:TSK1]TSKSTR = [M:CFP0]CREDAT

  # FGR 08/03/2010 : X3SUIVI62924 (début)
  #[M:TSK1]TSKORI = 7 # Origine = Campagne de relance
  [M:TSK1]TSKORIADI = "CPT4" # Origine = Campagne de relance
  [M:TSK1]TSKORIAOB = func CRMUTIL150.GET_AOB_FROM_ORI([M:TSK1]TSKORIADI)
  Call DEFOBJORI([M:TSK1]TSKORIAOB, [M:TSK1]TSKORIAVA) From CRMUTIL150    # FGR 08/03/2010 : X3SUIVI62924
  # FGR 08/03/2010 : X3SUIVI62924 (début)

  [M:TSK1]TSKORIVCR = [M:CFP0]QURNUM # numéro de la campagne de relance
  [M:TSK1]TSKORITYP = 2 # Généré
  [M:TSK1]TSKORIVCRL = [M:TK1]TSKORIVCRL # nb d'échéances relancées pour ce tiers
  [M:TSK2]TSKSAO = ""
  #[M:TSK1]TSKORIOBC = "FUP"  # FGR 08/03/2010 : X3SUIVI62924

 When "TSKDAT"
# échéance = date de la validation
  [M:TSK1]TSKDAT = date$

 When "TSKTYP"
# type de tâche
  Call PARAM("", "FUPTSKTYP", [M:TSK1]TSKTYP) From ADOVAL

 When "TSKPIOLEV"
# priority level
  Call DEFVALADI(405, [M:TSK1]TSKPIOLEV) From CRMUTIL140
  If [M:TSK1]TSKPIOLEV="" # Pas de valeur par défaut dans la table diverse
   Read [ADI]CODE=405
   If fstat
    [M:TSK1]TSKPIOLEV = ""
   Else
    [M:TSK1]TSKPIOLEV = [F:ADI]CODE
   Endif
  Endif

 When "TSKREP"
# représentant (tâche à effectuer par ...)
# Le représentant est initialisé dans AM_TSKCMP From SUBTSK avec [F:BPC]REP(0) (ou avec [F:BPC]REP(1) si [F:BPC]REP(0) est vide)
# APRES ce contrôle, on passe ici, et si le représentant est toujours vide (car [F:BPC]REP(1) est vide aussi), on initialise avec GUSER
# si c'est aussi un représentant valide
  If [M:TSK1]TSKREP=""
   Read [F:REP]REP0=GUSER
   If !fstat : [M:TSK1]TSKREP = [F:REP]REPNUM : Endif
  Endif

 When "TSKDEL"
# signaler le retard au bout de zero jour
  [M:TSK1]TSKDEL = 0

 When "FULOBJ"
  [M:TSK1]FULOBJ = [M:TK1]FULOBJ

 When "TSKRPO"
  [M:TSK2]TSKRPO = [M:TK2]TSKRPO

Endcase
Return

$TSK_SET_DET_INFO
Return
