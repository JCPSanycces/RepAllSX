#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque USACUSSEA 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:07:00"
A_USER  = "DOC"
A_STAMP = "20181109230700"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask USACUSSEA [CUSS]
Gosub HORODAT
Local Inpbox "USACUSSEA" From GFONCTION At A_STAMP With A_WINDPREV Mask [CUSS] As [SIM_]
Grizo [CUSS]2
Grizo [CUSS]4
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CUSS]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=37 : X2(0)=75 : Y1(0)=8 : Y2(0)=14
X1(1)=37 : X2(1)=75 : Y1(1)=15 : Y2(1)=21
Return

$ON_BPCTYP
Onevent INIT_AREA Call D_BPCTYP(zc) From W1USACUSSEA
Onevent BEFORE_INPUT Call AS_BPCTYP(zc) From W1USACUSSEA
Return

Subprog D_BPCTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]BPCTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_BPCTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_DEFADD
Onevent INIT_AREA Call D_DEFADD(zc) From W1USACUSSEA
Onevent BEFORE_INPUT Call AS_DEFADD(zc) From W1USACUSSEA
Return

Subprog D_DEFADD(VALEUR)
Variable Integer VALEUR
If varinit([M]DEFADD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_DEFADD(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CTY
Onevent BEFORE_INPUT Call AS_CTY(zc) From W1USACUSSEA
Return

Subprog AS_CTY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
If !GWEBSERV
 ## Action VILINI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "VILINI"
 Call S_AFF_CHAR(VALEUR,PARMSK,"INIVIL","SUBPOS","") From GACTION
 GACTION = SAVACT
 If mkstat=2
  [M]CTY(INDIC) = VALEUR
  Affzo CTY(INDIC) : mkstat = 2
 Endif
Endif
Onkey   2 Titled GBOUTS Call S_CTY(zc) From W1USACUSSEA
Gosub _AFF
End

Subprog S_CTY(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCTY
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCTY"
 PARMSK(1) = [M]CRY
 PARMSK(2) = [M]POSCOD
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCTY","SUBPOS","") From GACTION
 [M]POSCOD = PARMSK(2)
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_CRY
Onevent CONTROL Call C_CRY(zc) From W1USACUSSEA
Onevent BEFORE_INPUT Call AS_CRY(zc) From W1USACUSSEA
Onevent AFTER_CHANGE Gosub AMM_CRY From W1USACUSSEA
Onevent INIT_AREA Call D_CRY(zc) From W1USACUSSEA
Return

Subprog D_CRY(VALEUR)
Variable Char    VALEUR()
If varinit([M]CRY,indice)=0
 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_CRY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(53316,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CRY(zc) From W1USACUSSEA
Onkey   2 Titled GBOUTS Call S_CRY(zc) From W1USACUSSEA
Onkey 144 Titled GBOUTP Call P_CRY(zc) From W1USACUSSEA
Onkey 146 Titled GBOUTA Call SA_CRY(zc) From W1USACUSSEA
Gosub _AFF
End

Subprog C_CRY(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 263 : Endif
Gosub _AFF
End

$AMM_CRY
Call AM_CRY(zc)
If !mkstat & GOBJET
 zoncou = "CRY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CRY(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCRY)")>indice
 [M]CRY(indice) = VALEUR
 Affzo ZCRY(indice)
Endif
Gosub _AFF
End

Subprog S_CRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CRY(VALEUR)
Variable Char    VALEUR()
Call OBJET("TCY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CRY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCRY
Onevent BEFORE_AREA Gosub AV_ZCRY From W1USACUSSEA
Return

$AV_ZCRY
Call LECTEXTRA(zc,"TABCOUNTRY","CRYDES",num$([M]CRY(indice)),"") From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


