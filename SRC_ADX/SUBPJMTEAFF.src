#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Mask Management PJMTIMDAFF
###################################################################################################
$ACTION
  Case ACTION
    When "BB1_NBLIG"    : Gosub BB1_NBLIG
  Endcase
Return

###################################################################################################
$BB1_NBLIG
  Gosub SEARCH From SUBPJMTEA
Return

###################################################################################################
Subprog AV_NBLIG
  # Issue X3-99928 - 2018-08-24 by FGR : BEGIN : needed for Authorizations
  If nolign > 0 Then
    GFCY = [M:PTEAFF]FCY(nolign-1)
  Endif
  # Issue X3-99928 - 2018-08-24 by FGR : END
  If [M:PTEAFF]PTEDAT(nolign-1) = [0/0/0] Then
    Grizo [M:PTEAFF]BTLIGAFF(nolign-1)
  Else
    Actzo [M:PTEAFF]BTLIGAFF(nolign-1)
  Endif
  # Issue X3-66474 - 2018-02-02 by SINGC/FGR : BEGIN
  If [M:PTEDIE]SEARCH <> [V]CST_AYES and [M:PTEAFF]COLLIN(nolign-1) > 0 Then
    Call SHOW_CDIE([M:PTEAFF]COLLIN(nolign-1)) From SUBPJMTEA
  Endif
  # Issue X3-66474 - 2018-02-02 by SINGC/FGR : END
End

###################################################################################################
Subprog AS_PTEDAT(VALEUR)
Variable Date    VALEUR

Local Integer IRET
Local Integer ILINE

  Local File PJMTSK [PJTA]
  # -----------------------------
  If [M:PTEAFF]COLLIN(nolign-1) = 0 Then
    ILINE = fmet GZINSPJMTH.ADDLINE("TIMENT", [V]CST_ALASTPOS)
    If ILINE <> [V]CST_ANOTDEFINED Then
      # 1°) Get the date from the class in the screen (given by the INIT in the class)[M:PTEAFF]PTEDAT(COLLIN) = GZINSPJMTH.TIMENT(ILINE).PTEDAT
      VALEUR = GZINSPJMTH.TIMENT(ILINE).PTEDAT
      Read [PJTA]PTA0=[M:PTEAFF]OPPNUM(nolign-1);[M:PTEAFF]TASCOD(nolign-1)
      If fstat
        GMESSAGE = mess(266,2260,1)
        mkstat = 2
        End
      Else
        GZINSPJMTH.TIMENT(ILINE).PIMTASCOD = [F:PJTA]KEYCONCAT
      Endif
      # 2°) Copy the screen in the class for give to the class the others properties
      If [M:PTEAFF]PTEUOM(nolign-1) <> AVOID.ACHAR Then
        GZINSPJMTH.TIMENT(ILINE).PTEUOM = [M:PTEAFF]PTEUOM(nolign-1)
      Endif
      GZINSPJMTH.TIMENT(ILINE).OPENUM = [M:PTEAFF]OPENUM(nolign-1)
      GZINSPJMTH.TIMENT(ILINE).OPESPLNUM = [M:PTEAFF]OPESPLNUM(nolign-1)
      GZINSPJMTH.TIMENT(ILINE).POANUM = [M:PTEAFF]POANUM(nolign-1)
      # 3°) Show the line from the class to the screen (Call SHOW_TIMENT_LINE(ILINE) From SUBPJMTEAFFA)
      Call SHOW_TIMENT_LINE(ILINE) From SUBPJMTEAFFA
    Else
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJMTH)
      GERR = 4
      mkstat = 2
      GOK = 1
      End
    Endif
  Endif
End

###################################################################################################
Subprog AM_PTEDAT(VALEUR)
Variable Date    VALEUR

  GZINSPJMTH.TIMENT([M:PTEAFF]COLLIN(nolign-1)).PTEDAT = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH) From SUBPJMTEA
  If GERR = 1 Then
    GZINSPJMTH.TIMENT([M:PTEAFF]COLLIN(nolign-1)).PTEDAT = GZINSPJMTH.TIMENT([M:PTEAFF]COLLIN(nolign-1)).snapshot.PTEDAT
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_TIMENT_LINE([M:PTEAFF]COLLIN(nolign-1)) From SUBPJMTEAFFA
    Affzo [M:PTEAFF]1-99
  Endif
  # -----------------------------
  Actzo [M:PTEAFF]BTLIGAFF(nolign-1)
End

###################################################################################################
Subprog AS_PTEQTY(VALEUR)
Variable Decimal VALEUR

  If [M:PTEAFF]COLLIN(nolign-1) = 0 Then
    Call AS_PTEDAT([M:PTEAFF]PTEDAT(nolign-1))
  Endif
End

###################################################################################################
Subprog AM_PTEQTY(VALEUR)
Variable Decimal VALEUR

Local Integer IRET

  GZINSPJMTH.TIMENT([M:PTEAFF]COLLIN(nolign-1)).PTEQTY = VALEUR
  If [M:PTEAFF]PJMPCC(nolign-1) = AVOID.ACHAR Then
    IRET = fmet GZINSPJMTH.TIMENT([M:PTEAFF]COLLIN(nolign-1)).GET_PJMPCC(GZINSPJMTH.TIMENT([M:PTEAFF]COLLIN(nolign-1)).PJMPCC)
  Endif
  If [M:PTEAFF]PTEUOM(nolign-1) = AVOID.ACHAR Then
    IRET = fmet GZINSPJMTH.TIMENT([M:PTEAFF]COLLIN(nolign-1)).GET_PTEUOM(GZINSPJMTH.TIMENT([M:PTEAFF]COLLIN(nolign-1)).PTEUOM)
  Endif
  If [M:PTEAFF]CLBPCC(nolign-1) = AVOID.ACHAR Then
    IRET = fmet GZINSPJMTH.TIMENT([M:PTEAFF]COLLIN(nolign-1)).GET_CLBPCC(GZINSPJMTH.TIMENT([M:PTEAFF]COLLIN(nolign-1)).CLBPCC)
  Endif
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH) From SUBPJMTEA
  If GERR = 1 Then
    GZINSPJMTH.TIMENT([M:PTEAFF]COLLIN(nolign-1)).PTEQTY = GZINSPJMTH.TIMENT([M:PTEAFF]COLLIN(nolign-1)).snapshot.PTEQTY
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_TIMENT_LINE([M:PTEAFF]COLLIN(nolign-1)) From SUBPJMTEAFFA
    Affzo [M:PTEAFF]1-99
  Endif
End

