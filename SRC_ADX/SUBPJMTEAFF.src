###################################################################################################
# PJMTIMDAFF - Subroutines
###################################################################################################
Funprog GET_KEYCONCAT_SCREEN_PJMTIMDAFF()

Local Char SARENDRE(250)

  SARENDRE = func PJMOPEAFF_CSTD_PROGS.GET_KEYCONCAT_VARIABLES([M:PTEAFF]OPPNUM(nolign-1),
&                                                              [M:PTEAFF]TASCOD(nolign-1),
&                                                              [M:PTEAFF]OPENUM(nolign-1),
&                                                              [M:PTEAFF]OPESPLNUM(nolign-1),
&                                                              [M:PTEAFF]POANUM(nolign-1))
End SARENDRE

