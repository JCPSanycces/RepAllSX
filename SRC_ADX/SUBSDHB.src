#########################################################################
# SECTION contenant des SOUS-PROGRAMMES appelés depuis SUBSDH,SUBSDHA   #
#########################################################################

#########################################################################
#---------------------------------------#
# Traitement avant ligne                #
#---------------------------------------#
Subprog AVANT_LIGNE(NOL)
Value Integer NOL

Local Integer WRET

# Décrémentation des montants et poids livraison
Gosub SUB_TOT

# Si suppression
If GMODIF = 1
   # Annulation d'un composé de kit
   If find([M]LINTYP(NOL),2,10) GMODIF=3 Endif
   If find([M]LINTYP(NOL),6)    GMODIF=4 Endif
   # 105445 : (LD:05/06/15) : Suppression d'une ligne à l'origine d'un gratuit ou suppression d'un gratuit
   # Si la ligne à l'origine d'un gratuit est issue d'une cde, le gratuit lié n'est pas forcément sur cette liv
   # --> Ne pas gérer la suppression du gratuit
   # Si la ligne de gratuit est issue d'une cde, la ligne à l'origine du gratuit lié n'est pas forcément sur cette liv
   # --> Ne pas gérer la modification de la ligne à l'origine du gratuit
   #GFOCFLG = [M]FOCFLG(NOL)
   GFOCFLG = 1
   If [M:SDH1]XSOHNUM(NOL)=""
      GFOCFLG = [M]FOCFLG(NOL)
   Endif
   # 105445
Endif

End

#########################################################################
#----------------------------------------------------------------------------------#
# Vérification des codes taxes :                                                   #
# Appelé en fin de saisie de ligne pour vérifier si les codes taxes ont changé     #
#        suite à modification d'un champs entrant dans la détermination de la taxe #
# --> Si changement : Chargement des codes taxes                                   #
#                     Recalcul des montants de base calcul taxe (CLCAMT1 et 2)     #
#                     Dde recherche tarif si TTC                                   #
#                     Recalcul de la marge                                         #
#----------------------------------------------------------------------------------#
Subprog VERIF_VATCOD (NLIG)
Value Integer NLIG

Local Char    WVAT(GLONVAT)(3)
Local Integer INICPRPRI : INICPRPRI=1

Call RECHVATCOD(1,1,[M:SDH0]BPCORD,[M:SDH1]ITMREF(NLIG),"SDH1",NLIG,WVAT) From TRTX3

If [M:SDH1]VAT1(NLIG)<>WVAT(0) | [M:SDH1]VAT2(NLIG)<>WVAT(1) | [M:SDH1]VAT3(NLIG)<>WVAT(2)
    [M:SDH1]VAT1(NLIG) = WVAT(0)
    [M:SDH1]VAT2(NLIG) = WVAT(1)
    [M:SDH1]VAT3(NLIG) = WVAT(2)
    # 101874 : V9 : Taxe code control
    #Call TRTRECTARD("SDH", [M:SDH1]CUR, NLIG) From TRTVENTAR
    Local Integer WOK : WOK=1
    If !GIMPORT Call OUINON (mess(247,191,1)-":"-mess(21,191,1),WOK) From GESECRAN : Endif
    If WOK=2
      Call TRTRECTARD("SDH", [M:SDH1]CUR, NLIG) From TRTVENTAR
    Endif
    # 101874
    Call CLCPFM([M:SDH0]STOFCY, [M]PRITYP, [M]CHGTYP, [M:SDH1]SHIDAT, [M:SDH1]CUR,
&           NLIG,INICPRPRI) From TRTVENPRI
Endif

End
#########################################################################
#---------------------------------------#
# Traitement apres ligne                #
#---------------------------------------#
Subprog APRES_LIGNE(NOL, AFF)
Value Integer NOL
Value Integer AFF

mkstat=0

# X3-1152 : Non invoiceable deliveries
If [M]SDHCAT<>4
# X3-1152 : Non invoiceable deliveries
  # --> Contrôle du prix net
  Call CTLNETPRI([M]BPCORD,[M]CHGTYP,[M]SHIDAT,[M]CUR,NOL) From TRTVENPRI
  #If mkstat=2 End Endif
  # --> Contrôle de la marge
  Call CTLPFM([M]CUR,[M]CPRPRI(NOL), NOL) From TRTVENPRI
  #If mkstat=2 End Endif
  # --> Calcul du montant liv ht et ttc de la ligne
# X3-1152 : Non invoiceable deliveries
Endif
# X3-1152 : Non invoiceable deliveries

Gosub CALC_DLV
Local Integer NLIG : NLIG=NOL
Gosub CALC_DSP From TRTVENDIV

# Incrémentation des montants et poids livraison
Gosub ADD_TOT

End

#########################################################################
#----------------------------------------------------------------#
# Suppression d'une ligne dans le tableau (gratuit ou composant) #
#----------------------------------------------------------------#
Subprog SUP_LIG(NOL, WRET)
Value Integer NOL
Variable Integer WRET    : WRET = 0

# Décrémentation des montants et poids livraison
Gosub SUB_TOT

If [M:SDH1]STOMGTCOD(NOL)<>1
   # Nettoyage de l'écran de travail STOSORW
   Call DELSTOSORW(NOL,NOL,"SDH1",[M:SDH0]STOFCY,WRET) From STKSOR
   If WRET<>0 OK=0 : End Endif
Endif

If dim([M]ITMREF)=[M]NBLIG
   Dela NOL,1 [M]NBLIG
Else
   Dela NOL,1,[M]NBLIG-1 [M]NBLIG
Endif
[M]NBLIG -= 1

End

#########################################################################
#--------------------------------------------------------------------#
# Recherche dernier no livraison d'une ligne cde suite à suppression #
#--------------------------------------------------------------------#
Subprog RECH_DERLIVSOQ()

#If clalev([F:SDD1])=0 Local File SDELIVERYD [SDD1] Endif
Filter [SDD1] Where SOHNUM=[F:SOQ]SOHNUM & SOPLIN=[F:SOQ]SOPLIN
&               & SOQSEQ=[F:SOQ]SOQSEQ
&            Order By Key NEWCLE=SOHNUM;SOPLIN;SOQSEQ;SHIDAT;SDHNUM
Read [SDD1]NEWCLE Last
If fstat = 0
   If ([F:SDD1]SDHNUM=[F:SDD]SDHNUM) & ([F:SDD1]SDDLIN=[F:SDD]SDDLIN)
      Read [SDD1]NEWCLE Prev
      If fstat = 0
         [F:SOQ]SDHNUM = [F:SDD1]SDHNUM
         [F:SOQ]SDDLIN = [F:SDD1]SDDLIN
      Else
         Raz [F:SOQ]SDHNUM, [F:SOQ]SDDLIN
      Endif
   Else
      [F:SOQ]SDHNUM = [F:SDD1]SDHNUM
      [F:SOQ]SDDLIN = [F:SDD1]SDDLIN
   Endif
Else
   Raz [F:SOQ]SDHNUM, [F:SOQ]SDDLIN
Endif
Filter [SDD1]
#Close Local File [SDD1]

End

#########################################################################
#--------------------------------------------------------------------#
# Recherche dernier no livraison d'une commande suite à suppression  #
#--------------------------------------------------------------------#
Subprog RECH_DERLIVSOH(WTRTLIG)
Value Char WTRTLIG

Local Shortint WOK
Local Char     CRITERE(50)

# Si date ligne livraison <= date dernière liv de la cde, on ne change rien
#15380
#If [F:SOH]LASDLVDAT > [F:SDD]SHIDAT End Endif

#If clalev([F:SDD1])=0 Local File SDELIVERYD [SDD1] Endif
#Filter [SDD1] Where SOHNUM=[F:SOQ]SOHNUM
#&             Order By Key NEWCLE=SOHNUM;SHIDAT;SDHNUM

# Pour trouver la dernière livraison d'une commande
# On recherche toutes les lignes de livraison de la commande
CRITERE="SOHNUM=[F:SOH]SOHNUM"
# En suppression livraison, on peut exclure les lignes de la livraison en cours de suppression
If GREP="A" CRITERE -= "& SDHNUM<>[F:SDD]SDHNUM" Endif

Filter [SDD1] Where evalue(CRITERE) Order By Key NEWCLE=SOHNUM;SHIDAT;SDHNUM

WOK = 1
Raz [F:SOH]LASDLVNUM, [F:SOH]LASDLVDAT
Read [SDD1]NEWCLE Last
If fstat
   WOK = 0
   Goto RECH_FIN
Endif

While [F:SDD1]SDHNUM = [F:SDD]SDHNUM
#15380 : Modification de la date
   If WTRTLIG="M"
      Read [SDD1]NEWCLE Prev
   Elsif !find([F:SDD1]SOHNUM,[M:SDH1]XSOHNUM(0..[M:SDH1]NBLIG-1))
      Read [SDD1]NEWCLE Prev
   Else
      WOK = 1 : Break
   Endif
   If fstat WOK=0 : Break : Endif
Wend

$RECH_FIN
If WTRTLIG="M"  : #15380 : Modification de la date
    If WOK=0 | [F:SDD]SHIDAT > [F:SDD1]SHIDAT
       [F:SOH]LASDLVNUM = [F:SDD]SDHNUM
       [F:SOH]LASDLVDAT = [F:SDD]SHIDAT
    Elsif WOK=1
       [F:SOH]LASDLVNUM = [F:SDD1]SDHNUM
       [F:SOH]LASDLVDAT = [F:SDD1]SHIDAT
    Endif
#15380
Elsif WOK = 1
   [F:SOH]LASDLVNUM = [F:SDD1]SDHNUM
   [F:SOH]LASDLVDAT = [F:SDD1]SHIDAT
Endif

Filter [SDD1]
#Close Local File [SDD1]

End

# 79705 : V7 : SAT in SPRICLINK :
# -> Ajout du sous-pro nécessaire à la recherche tarif
#--------------------------------------------------------------------#
# Lecture de ts les fichiers utiles à une ligne                      #
#--------------------------------------------------------------------#
Subprog LECT_FIC(NLIG)
Value Integer NLIG

If [F:ITS]ITMREF <> [M:SDH1]ITMREF(NLIG)
     Read [F:ITS]ITS0 = [M:SDH1]ITMREF(NLIG)
     If fstat  Raz [F:ITS] : Endif
Endif
If [F:ITM]ITMREF <> [M:SDH1]ITMREF(NLIG)
     Read [F:ITM]ITM0 = [M:SDH1]ITMREF(NLIG)
     If fstat  Raz [F:ITM] : Endif
Endif

End
# 79705 : V7 : SAT in SPRICLINK
#########################################################################
# $GES_GLOB                                                             #
