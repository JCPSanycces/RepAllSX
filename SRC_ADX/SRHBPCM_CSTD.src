#############################################################################
# Traitement SRHBPCM_CSTD : Liste retour  --> 2 onglets sur mobile          #
#   Classe représentation SRHBPCM : Liste retour  (2 onglets sur mobile)    #
#   Classe données        SRHBPCM : Liste retour  (2 onglets sur mobile)    #
#############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
        Endcase
     When "C_RETURN"
        Case [L]AEVENT
          When "AREAD_AFTER"     : Gosub AREAD_AFTER_SRETURN
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------
######################################################################################################
$PROPERTIES
  #Case [L]CURPRO
  #Endcase
Return

######################################################################################################
$AREAD_AFTER_SRETURN
 #--Chargement du libellé de SRHTYP à partir de la LEG de l"enr courant (SRETURN) --#
Local Char VCURRLEG(GLONADI)

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, this.SALFCY, VCURRLEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_SRHTYP_LEG(this, this.SRHTYP, this.CPY, this.SALFCY, VCURRLEG, this.SRHTYP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  If func ASYRFNC.ACTIV("DEB")>0 #AFNC.ACTIV("DEB") = 1 # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_EECNAT_LEG(this, this.EECNAT, this.CPY, this.SALFCY, VCURRLEG, this.EECNAT_LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_EECSCH_LEG(this, this.EECSCH, this.CPY, this.SALFCY, VCURRLEG, this.EECSCH_LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

Return

