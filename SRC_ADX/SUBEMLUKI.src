#<AdxTL>@(#)0.0.0.0 $Revision$
$OUVRE
  Read [ACV]CODACT="KUK"
  If !fstat & [F:ACV]FLACT=2
    NBTBL += 1 : TBTABLE(NBTBL) = "EMPLOIDUKI" : TYPTABLE(NBTBL) = 1
    MSKTAB(NBTBL) = "5" : TBABREV(NBTBL) = "IDUKI" :
    If clalev([F:IDUKI])=0 : Local File EMPLOIDUKI [IDUKI] : Endif
  Endif

Return

#ANCOA - 2017-05-22 - JIRA X3-36916 - START
$LIENS

#[M:EMPB]RECBEROCCPEN, ANNPENAMTOCC
#[M:EMPB]RECBERSATPEN, ANNPENAMTSAT

#If GCURLEG="BRI" Then
