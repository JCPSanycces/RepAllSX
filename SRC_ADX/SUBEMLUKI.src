#ANCOA - 2017-04-10 - JIRA X3-18818 - START
$VERIF
# check the percentages
If MA
  mkstat = 0
  Call VER_NBRRIB From SUBEMLUKI
  If mkstat
    Raz mkstat
    GERR = 1
    Return
  Endif
Endif

# check the default bank account flag
mkstat = 0
Call VER_BNKDEF From SUBEMLUKI
If mkstat
  Raz mkstat
  GERR = 1
  Return
Endif

Return
#ANCOA - 2017-04-10 - JIRA X3-18818 - END

