#DEKEE - 2016/11/29 - JIRA X3PEOP-4412 - START
Subprog C_PSD(VALEUR)
Variable Char    VALEUR()

If len(VALEUR)>20 : mkstat = 2 : GMESSAGE = mess(76,00126,1)-num$(20) Endif

End
#DEKEE - 2016/11/29 - JIRA X3PEOP-4412 - END

#DEKEE - 2016/11/30 - JIRA X3PEOP-4412 - START

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()

If len(VALEUR)>10 : mkstat = 2 : GMESSAGE = mess(76,00126,1)-num$(10) Endif

End

Subprog C_NAM(VALEUR)
Variable Char    VALEUR()

If len(VALEUR)>30 : mkstat = 2 : GMESSAGE = mess(76,00126,1)-num$(30) Endif

End

Subprog C_SRN(VALEUR)
Variable Char    VALEUR()

If len(VALEUR)>25 : mkstat = 2 : GMESSAGE = mess(76,00126,1)-num$(25) Endif

End
