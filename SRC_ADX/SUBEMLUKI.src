#MASHI - 2017-03-22 - JIRA X3-18818 - START
Subprog C_BANACCTYP1(VALEUR)
Variable Integer    VALEUR()

If VALEUR=2 # Building Society
  Actzo [M:EMP7]BSOROL #(nolign-1)
Else
  Raz [M:EMP7]BSOROL #(nolign-1)
  Grizo [M:EMP7]BSOROL #(nolign-1)
Endif
End
#MASHI - 2017-03-22 - JIRA X3-18818 - END

#MASHI - 2017-03-22 - JIRA X3-18818 - START
Subprog C_BNKSRTCOD(VALEUR)
Variable Char VALEUR
Local Char IBAN(9)
Local Char BICCOD(11)
  If len(VALEUR) <> 6 Then
   GMESSAGE = mess(00013,11800,1)
   mkstat=2
   End
Endif

IBAN   = [M:EMP7]IBAN(nolign-1)
BICCOD = [M:EMP7]BICCOD(nolign-1)
# Error if nothing enter
If IBAN = "" and BICCOD = "" and VALEUR = ""
   GMESSAGE = mess(00014,11800,1)
   mkstat=2

Endif


End
#MASHI - 2017-03-22 - JIRA X3-18818 - END
