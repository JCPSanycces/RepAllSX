Subprog C_BNKACCNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR>999999999
 [V]GMESSAGE=mess(00010,11800,1)
 mkstat     =2
Endif

End
#MASHI - 2017-03-22 - JIRA X3-18818 - END

#MASHI - 2017-03-22 - JIRA X3-18818 - START
Subprog C_BNKDEF(VALEUR)
Variable Integer VALEUR
End

# Verifies that if bank accounts are entered then one and only one have been marked as default
# sets mkstat=2 and GMESSAGE to appropriate message if validation fails
Subprog VER_BNKDEF
Local Integer TOTDEFS

If [M]NBRRIB > 0
  TOTDEFS = 0
  For I=0 To [M]NBRRIB-1
    If [M]BNKDEF(I)=2
      TOTDEFS += 1
    Endif
  Next

  If TOTDEFS <> 1
    GMESSAGE = mess(00011,11800,1)
    mkstat = 2
  Endif
Endif

End

#MASHI - 2017-03-22 - JIRA X3-18818 - END
#MASHI - 2017-03-22 - JIRA X3-18818 - START


# Validate percentage
Subprog VER_NBRRIB
Local Decimal TOTPERC
Local Integer C_VERIF : C_VERIF = 0
If [M]NBRRIB > 0
  TOTPERC = 0
  For I=0 To [M]NBRRIB-1
    If [M]PAYSPT(I)<2
      C_VERIF = 1
#MIPEA - 2017-05-19- US X3-11287- START
      TOTPERC += [M]PAYPCT(I)
#      TOTPERC += [M]PAYPRC(I)
#MIPEA - 2017-05-19- US X3-11287- END
    Endif
  Next
#TODO : Once a Payment split is selected to Fixed amount, the percentage will always give this error of "Incorrect format"
#TODO : I would just place a check here so that when Percentage is selected to run this.
#  If TOTPERC <> 100
#    GMESSAGE = mess(00149,00100,1)
#    mkstat = 2
#  Endif
  If C_VERIF = 1 Then
    If TOTPERC <> 100
      GMESSAGE = mess(00020,11800,1) # Percentage splits must total 100%
      mkstat = 2
    Endif
  Endif
Endif

End

#MASHI - 2017-03-22 - JIRA X3-18818 - END
#MASHI - 2017-03-22 - JIRA X3-18818 - START
Subprog AM_BNKSRTCOD(VALEUR)
Variable Char    VALEUR()
Local Char FTWO(5), STWO(5), STR(8)
FTWO = left$(VALEUR,2) : FTWO = FTWO+"-"
STWO = right$(left$(VALEUR,4),3) : STWO = STWO+"-"
STR = FTWO+STWO+right$(VALEUR,5)
VALEUR = STR
Affzo [M:EMP7]BNKSRTCOD(nolign-1)

End
#MASHI - 2017-03-22 - JIRA X3-18818 - END

#MASHI - 2017-03-22 - JIRA X3-18818 - START
Subprog AS_BNKSRTCOD(VALEUR)
Variable Char    VALEUR()
Local Char LEF(2), MID(2) ,RIG(2)
LEF = left$(VALEUR,2)
MID = right$(left$(VALEUR,5),4)
RIG = right$(VALEUR,7)

VALEUR = LEF+MID+RIG
Affzo [M:EMP7]BNKSRTCOD(nolign-1)

End
#MASHI - 2017-03-22 - JIRA X3-18818 - END

