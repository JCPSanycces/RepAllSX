     If WCHAR<>[M]NATCOD2(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_NATCOD2([M]NATCOD2(indice)) From SUBSTY
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "NATCOD2" : GZNUM = 47180 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

