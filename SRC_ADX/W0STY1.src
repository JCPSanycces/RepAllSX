#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque STY1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone FIRDAY
mkstat = 0
zoncou = "FIRDAY"
indice = 0
IMPENT = [M]FIRDAY
If varinit([M]FIRDAY,indice)=0
 IMPENT = 1
Endif
If varmode([M]FIRDAY,indice)=0
 [M]FIRDAY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FIRDAY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FIRDAY(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_FIRDAY(IMPENT) From SUBSTY
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FIRDAY" : GZNUM = 45280 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]FIRDAY = IMPENT

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
WCHAR = [M]COD
If varmode([M]COD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]COD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]COD
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]COD = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTSTY"
   Call CONTSTY([M]COD) From SUBSTY
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]COD or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_COD([M]COD) From SUBSTY
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varmode([M]DES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DES" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SHO
mkstat = 0
zoncou = "SHO"
indice = 0
If varmode([M]SHO,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SHO" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]LEG,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]LEG,"909","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]LEG,"909",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]LEG or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_LEG([M]LEG) From SUBSTY
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRDAY
mkstat = 0
zoncou = "NBRDAY"
indice = 0
status = 1
zoncou = "NBRDAY"
If varmode([M]NBRDAY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRDAY" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRDAY
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRDAY = nolign
   status = 75
   Call SAI_NBRDAY(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone UPDHRS
mkstat = 0
zoncou = "UPDHRS"
indice = 0
If varinit([M]UPDHRS,indice)=0
 [M]UPDHRS = 0
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRDAY(IMPFIC,ACTION,IMPTRT)
