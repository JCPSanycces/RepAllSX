###############################################################################
# Representation Class EDIFLO                                                 #
# Author : JUCON+RBA                                                          #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS

  Case CURPTH
    When ""
      Case [L]AEVENT
         When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
         When "AREAD_AFTER"           : Gosub AREAD_AFTER  # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
      Endcase
    When "EDF"
      Case [L]AEVENT
         When "AREAD_AFTER"           : Gosub EDF_AREAD_AFTER
     Endcase
    When "EDF.EFLD"
      Case [L]AEVENT
         When "AREAD_AFTER"           : Gosub EDF_EFLD_AREAD_AFTER
     Endcase
    When "EDF.EFLA"
      Case [L]AEVENT
         When "AREAD_AFTER"           : Gosub EDF_EFLA_AREAD_AFTER
         When "ADDLINE_AFTER"         : Gosub EDF_EFLA_ADDLINE_AFTER
     Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "EDF.PARCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDF_PARCOD_PROPAGATE
      Endcase
    When "EDF.PARTYP"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDF_PARTYP_PROPAGATE
      Endcase
    When "EDF.CATCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDF_CATCOD_PROPAGATE
      Endcase
    When "EDF.VALID"
      Case [L]ARULE
        When "PROPAGATE": Gosub EDF_VALID_PROPAGATE
      Endcase
    When "EDF.CATACT"
      Case [L]ARULE
        When "PROPAGATE": Gosub EDF_CATACT_PROPAGATE
      Endcase
    When "EDF.EFLD.MSGTYP"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDF_EFLD_MSGTYP_PROPAGATE
      Endcase
    When "EDF.EFLD.MSGCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDF_EFLD_MSGCOD_PROPAGATE
      Endcase
    When "EDF.EFLD.MSGREL"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDF_EFLD_MSGREL_PROPAGATE
      Endcase
    When "EDF.EFLD.MSGFOR" #SAM 112148
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDF_EFLD_MSGFOR_PROPAGATE
      Endcase
    When "EDF.EFLD.SIGNATURE" #SAM 112148
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDF_EFLD_SIGNATURE_PROPAGATE
      Endcase
    # Init Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
    When "EDF.EFLA.GENFLG"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDF_EFLA_GENFLG_PROPAGATE
      Endcase
    When "EDF.EFLA.FIXNAM"
      Case [L]ARULE
        When "PROPAGATE" :  Gosub EDF_EFLA_FIXNAM_PROPAGATE
      Endcase
    When "EDF.EFLP.ALIAS"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDF_EFLP_ALIAS_PROPAGATE
      Endcase
    When "EDF.EFLP.CONSTANT"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDF_EFLP_CONSTANT_PROPAGATE
      Endcase
  # End Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
  Endcase
Return

####################################################################

$EDF_PARCOD_PROPAGATE
  Call EDF_DISPLAY(this)
Return

####################################################################

$EDF_PARTYP_PROPAGATE
#  Call EDF_DISPLAY(this)
  Local Integer I
  For I = 1 To maxtab(this.EFLD)
    Call EDF_EFLD_DISPLAY(this.EFLD(I))
  Next I
Return

###################################################################

$EDF_CATCOD_PROPAGATE
  Call EDF_DISPLAY(this)

  Local Integer WCATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  WCATOPE = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.APARENT.CATOPE = 2 #Create
  Else
    this.APARENT.CATOPE = WCATOPE
  Endif
Return

#####################################################################

$EDF_VALID_PROPAGATE
  Call EDF_DISPLAY(this)
Return

#####################################################################

$EDF_CATACT_PROPAGATE
  Call EDF_DISPLAY(this)
Return

#####################################################################

$EDF_EFLD_MSGTYP_PROPAGATE
  Call EDF_EFLD_DISPLAY(this)
Return

#####################################################################

$EDF_EFLD_MSGCOD_PROPAGATE
  Call EDF_EFLD_DISPLAY(this)
Return

#####################################################################

$EDF_EFLD_MSGREL_PROPAGATE
  Call EDF_EFLD_DISPLAY(this)
Return

#####################################################################

#Init SAM 112148. New fields for XML signature
$EDF_EFLD_MSGFOR_PROPAGATE
  Call EDF_EFLD_DISPLAY(this)
Return

#####################################################################

$EDF_EFLD_SIGNATURE_PROPAGATE
  Call EDF_EFLD_DISPLAY(this)
Return
#End SAM 112148

#####################################################################
# Ini Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
$EDF_EFLA_GENFLG_PROPAGATE
  Call EDF_EFLA_DISPLAY_ADDLINE(this)
Return

#####################################################################
$EDF_EFLA_FIXNAM_PROPAGATE
  Local Integer I, WOK
  If  this.APARENT.EFLA(this.AORDER).GENFLG=2 or this.FIXNAM=2
    If this.APARENT.EFLA(this.AORDER).FIXNAM=1
      WOK = fmet this.APARENT.EFLA(this.AORDER).ASETATTRIBUTE("FICNAM", "$isDisabled", "true" ) #display property
      WOK = fmet this.APARENT.EFLA(this.AORDER).ASETATTRIBUTE("FICVOL", "$isDisabled", "true" ) #display property
    Else
      WOK = fmet this.APARENT.EFLA(this.AORDER).ASETATTRIBUTE("FICNAM", "$isDisabled", "false") #entry property
      WOK = fmet this.APARENT.EFLA(this.AORDER).ASETATTRIBUTE("FICVOL", "$isDisabled", "false") #entry property
    Endif
  Else
    WOK = fmet this.APARENT.EFLA(this.AORDER).ASETATTRIBUTE("FICNAM", "$isDisabled", "false") #entry property
    WOK = fmet this.APARENT.EFLA(this.AORDER).ASETATTRIBUTE("FICVOL", "$isDisabled", "false") #entry property
  Endif

Return

#####################################################################
$EDF_EFLP_ALIAS_PROPAGATE
If this.ALIAS<>""
  this.CONSTANT=""
  WOK = fmet this.ASETATTRIBUTE('CONSTANT', '$isDisabled', 'true' )
Else
  WOK = fmet this.ASETATTRIBUTE('CONSTANT', '$isDisabled', 'false')
Endif

Return

#####################################################################
$EDF_EFLP_CONSTANT_PROPAGATE
If this.CONSTANT<>""
  this.ALIAS=""
  WOK = fmet this.ASETATTRIBUTE('ALIAS', '$isDisabled', 'true' )
Else
  WOK = fmet this.ASETATTRIBUTE('ALIAS', '$isDisabled', 'false')
Endif
Return
# End Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)

#####################################################################
$AREAD_AFTER # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  Local Integer WCATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  WCATOPE = fmet this.EDF.ACTX.ACACHE.ECA.AGETVALNUM(this.EDF.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.CATOPE = 2 #Create
  Else
    this.CATOPE = WCATOPE
  Endif
Return

#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#*
#*!
$EDF_AREAD_AFTER
  Call EDF_DISPLAY(this)
Return

#********************************************************************
# Method EDF_EFLD_AREAD_AFTER
#********************************************************************
#*
#*!
$EDF_EFLD_AREAD_AFTER
  Call EDF_EFLD_DISPLAY(this)
Return

# Ini Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
#********************************************************************
# Method EDF_EFLA_AREAD_AFTER
#********************************************************************
#*
#*!
$EDF_EFLA_AREAD_AFTER
  Call EDF_EFLA_DISPLAY_AREAD(this)
Return


# End Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
#********************************************************************
# Method AQUERY_TRANS_AFTER
#********************************************************************
#*
#*!
$AQUERY_TRANS_AFTER
  this.EDF.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.EDF.CATCOD,"CATDES")
  this.EDF.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.EDF.PARCOD,"PARDES")
  this.EDF.PTCDES = fmet this.ACTX.ACACHE.EPT.AGETVALCHAR(this.EDF.PTCCOD,"PTCDES")

  Local Integer WCATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  WCATOPE = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.EDF.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.CATOPE = 2 #Create
  Else
    this.CATOPE = WCATOPE
  Endif
Return


#********************************************************************
# Subprog EDF_DISPLAY
#********************************************************************
#
#* Switch the display
#* @param WOBJECT
#*!
Subprog EDF_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
#  Local Integer I, WOK

#  If WOBJECT.VALID=1
#    WOK = fmet WOBJECT.ASETATTRIBUTE('FLGACT', '$isDisabled', 'true')
#  Else
#    WOK = fmet WOBJECT.ASETATTRIBUTE('FLGACT', '$isDisabled', 'false')
#  Endif
End

#********************************************************************
# Method EDF_EFLA_ADDLINE_AFTER
#********************************************************************
#*
#*!
$EDF_EFLA_ADDLINE_AFTER
  Call EDF_EFLA_DISPLAY_ADDLINE(this)
Return

#********************************************************************
# Subprog EDF_EFLD_DISPLAY
#********************************************************************
#
#* Switch the line display
#* @param WOBJECT
#*!
Subprog EDF_EFLD_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer I, WOK
#Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
#  If WOBJECT.APARENT.PARTYP = 1 #sage
#    WOK = fmet WOBJECT.ASETATTRIBUTE("PTCCOD", "$isDisabled", "true") #hide property
#  Else
#    WOK = fmet WOBJECT.ASETATTRIBUTE("PTCCOD", "$isDisabled", "false") #display property
#  Endif
#Init SAM 112148. New fields for XML signature ## Ini X3-4752 Setup of the EDI flow toolkit (JUCON 22/11/16)
  If WOBJECT.MSGFOR = 1
    WOK = fmet WOBJECT.ASETATTRIBUTE("SIGNATURE", "$isDisabled", "true" ) #hide property
    WOK = fmet WOBJECT.ASETATTRIBUTE("SIGNAEXT" , "$isDisabled", "true" ) #hide property
  Elsif WOBJECT.MSGFOR = 2
    WOK = fmet WOBJECT.ASETATTRIBUTE("SIGNATURE", "$isDisabled", "false") #display property
    If WOBJECT.SIGNATURE>1
      WOK = fmet WOBJECT.ASETATTRIBUTE("SIGNAEXT" , "$isDisabled", "false") #display property
    Else
      WOK = fmet WOBJECT.ASETATTRIBUTE("SIGNAEXT" , "$isDisabled", "true") #display property
    Endif
  Endif
 #End SAM 112148    ## Ini X3-4752 Setup of the EDI flow toolkit (JUCON 22/11/16)

End

#********************************************************************
# Subprog EDF_EFLA_DISPLAY_AREAD
#********************************************************************
#
#* Switch the line display
#* @param WOBJECT
#*!
Subprog EDF_EFLA_DISPLAY_AREAD(WOBJECT)
Variable Instance WOBJECT Using OBJECT
#Variable Integer NUM
  Local Integer I, WOK, WNUM

  WNUM=WOBJECT.AORDER

  If WOBJECT.APARENT.CATACT=1
    If WOBJECT.APARENT.EFLA(WNUM).GENFLG=2
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("EXCMSG", "$isDisabled", "false") #entry property
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("SGNFLG", "$isDisabled", "false") #entry property
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("CRUSED", "$isDisabled", "false") #entry property
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("DESTIN", "$isDisabled", "false") #entry property
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("FIXNAM", "$isDisabled", "false") #entry property
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("FICNAM", "$isDisabled", "true" ) #display property
      If WOBJECT.APARENT.EFLA(WNUM).FIXNAM=1
        WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("FICVOL", "$isDisabled", "true" ) #display property
      Else
        WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("FICVOL", "$isDisabled", "false") #entry property
      Endif
    Else
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("EXCMSG", "$isDisabled", "true" ) #display property
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("SGNFLG", "$isDisabled", "true" ) #display property
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("CRUSED", "$isDisabled", "true" ) #display property
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("DESTIN", "$isDisabled", "true" ) #display property
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("FIXNAM", "$isDisabled", "true" ) #display property
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("FICNAM", "$isDisabled", "false") #entry property
      WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("FICVOL", "$isDisabled", "false") #entry property
    Endif
  Else
    WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("EXCMSG", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("GENFLG", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("SGNFLG", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("CRUSED", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("DESTIN", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("FIXNAM", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("FICNAM", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.APARENT.EFLA(WNUM).ASETATTRIBUTE("FICVOL", "$isDisabled", "true" ) #display property

    WOK = fmet WOBJECT.APARENT.EFLD(WNUM).ASETATTRIBUTE("PARNAM"  , "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.APARENT.EFLD(WNUM).ASETATTRIBUTE("PARDES"  , "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.APARENT.EFLD(WNUM).ASETATTRIBUTE("ALIAS"   , "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.APARENT.EFLD(WNUM).ASETATTRIBUTE("PROPERTY", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.APARENT.EFLD(WNUM).ASETATTRIBUTE("CONSTANT", "$isDisabled", "true" ) #display property

  Endif

End

#********************************************************************
# Subprog EDF_EFLA_DISPLAY_ADDLINE
#********************************************************************
#
#* Switch the line display
#* @param WOBJECT
#*!
Subprog EDF_EFLA_DISPLAY_ADDLINE(WOBJECT)
Variable Instance WOBJECT Using OBJECT

  Local Integer I, WOK, WNUM
  WNUM=WOBJECT.AORDER

  If WOBJECT.APARENT.CATACT=1
    If WOBJECT.GENFLG=2 and WOBJECT.CREUSR=""  #generated
      WOK = fmet WOBJECT.ASETATTRIBUTE("EXCMSG", "$isDisabled", "false") #entry property
      WOK = fmet WOBJECT.ASETATTRIBUTE("SGNFLG", "$isDisabled", "false") #entry property
      WOK = fmet WOBJECT.ASETATTRIBUTE("CRUSED", "$isDisabled", "false") #entry property
      WOK = fmet WOBJECT.ASETATTRIBUTE("DESTIN", "$isDisabled", "false") #entry property
      WOK = fmet WOBJECT.ASETATTRIBUTE("FIXNAM", "$isDisabled", "false") #entry property
      WOK = fmet WOBJECT.ASETATTRIBUTE("FICNAM", "$isDisabled", "true" ) #display property
      If WOBJECT.FIXNAM=1
        WOK = fmet WOBJECT.ASETATTRIBUTE("FICVOL", "$isDisabled", "true" ) #display property
      Else
        WOK = fmet WOBJECT.ASETATTRIBUTE("FICVOL", "$isDisabled", "false") #entry property
      Endif
    Else
      WOK = fmet WOBJECT.ASETATTRIBUTE("EXCMSG", "$isDisabled", "true" ) #display property
      WOK = fmet WOBJECT.ASETATTRIBUTE("SGNFLG", "$isDisabled", "true" ) #display property
      WOK = fmet WOBJECT.ASETATTRIBUTE("CRUSED", "$isDisabled", "true" ) #display property
      WOK = fmet WOBJECT.ASETATTRIBUTE("DESTIN", "$isDisabled", "true" ) #display property
      WOK = fmet WOBJECT.ASETATTRIBUTE("FIXNAM", "$isDisabled", "true" ) #display property
      WOK = fmet WOBJECT.ASETATTRIBUTE("FICNAM", "$isDisabled", "false") #entry property
      WOK = fmet WOBJECT.ASETATTRIBUTE("FICVOL", "$isDisabled", "false") #entry property
    Endif
  Else
    WOK = fmet WOBJECT.ASETATTRIBUTE("EXCMSG", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.ASETATTRIBUTE("GENFLG", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.ASETATTRIBUTE("SGNFLG", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.ASETATTRIBUTE("CRUSED", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.ASETATTRIBUTE("DESTIN", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.ASETATTRIBUTE("FIXNAM", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.ASETATTRIBUTE("FICNAM", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.ASETATTRIBUTE("FICVOL", "$isDisabled", "true" ) #display property

    WOK = fmet WOBJECT.ASETATTRIBUTE("PARNAM"  , "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.ASETATTRIBUTE("PARDES"  , "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.ASETATTRIBUTE("ALIAS"   , "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.ASETATTRIBUTE("PROPERTY", "$isDisabled", "true" ) #display property
    WOK = fmet WOBJECT.ASETATTRIBUTE("CONSTANT", "$isDisabled", "true" ) #display property

  Endif
End

