#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################################################################
#################################################################################################
$PARSE_XML

Local Char     BUFFER(255)   : BUFFER    = ""
Local Char     READTMP(255)  : READTMP   = ""
Local Char     CHRTOFIND(1)  : CHRTOFIND = "<"  # "<", ">", "/"
Local Integer  TAGTYP        : TAGTYP    = 0    # 0 indefinido; 1 opening; 2 closing
Local Integer  T
Local Integer  T2
Local Integer  P
Local Char     LVAL(255)
Local Char     LTAG(255)
Local Shortint SAVFSTAT

Local Integer YI : YI = 0
Local Integer TESTMODE : [L]TESTMODE = 0

Openi P_FILE                        Using [XMLF]
Iomode adxirs ''                    Using [XMLF]
Iomode adxifs ''                    Using [XMLF]
Iomode adxium 50                    Using [XMLF]

Repeat
  Rdseq  BUFFER Using [XMLF]
  SAVFSTAT = fstat
  Gosub PARSE_BUF
Until SAVFSTAT <> 0

Return
#################################################################################################
#################################################################################################
$PARSE_BUF

P = 0

While P < 255
    T = instr(P, BUFFER, CHRTOFIND)
    If T = 0
      READTMP += mid$(BUFFER,P,len(BUFFER)-P+1)
      P        = 255
    Else
        Case CHRTOFIND
            When "<"
                If READTMP=""
                  READTMP += mid$(BUFFER,P,T-P)
                Else
                  READTMP += mid$(BUFFER,P+1,T-P-1)
                Endif
                If len(BUFFER)>T+2
                  If mid$(BUFFER,T+1,1) = "/"
                    If TAGTYP = 1 : Gosub VAL_TAG : Endif
                    TAGTYP = 2
                    READTMP = ""
                  Else
                    TAGTYP = 1
                  Endif
                  CHRTOFIND = ">"
                  P = T
                Else
                  P         = 255
                Endif
            When ">"
                READTMP = ctrans(READTMP, chr$(9)+chr$(10)+chr$(13), "")
                READTMP = vireblc(READTMP,0)
                If READTMP=""
                  READTMP += mid$(BUFFER,P,T+1-P)
                Else
                  READTMP += mid$(BUFFER,P+1,T-P)
                Endif
                If TAGTYP = 1
                  Gosub INI_TAG
                Else
                  Gosub END_TAG
                Endif
                READTMP = ""
                CHRTOFIND = "<"
                P = T+1
            When "/"
                If len(BUFFER)>T+2
                  If mid$(BUFFER,P+1,1) = "/"
                    #The begining of a closing tag
                  Endif
                Endif
            When Default
                #error
        Endcase
    Endif
Wend

Return
#################################################################################################
#################################################################################################
$INI_TAG

If GTRACE <> "" & [L]TESTMODE = 1
  Call ECR_TRACE(ctrans(READTMP,chr$(10)+chr$(13)+chr$(9),""), 0) From GESECRAN
Endif

LTAG = ctrans(READTMP,chr$(10)+chr$(13)+chr$(9),"")

Gosub PARSE_TAG
Gosub INI_TAG From =LTRT

Return
#################################################################################################
#################################################################################################
$VAL_TAG

If GTRACE <> "" & [L]TESTMODE = 1
  Call ECR_TRACE(READTMP, 0) From GESECRAN
Endif

LVAL = READTMP

Gosub VAL_TAG From =LTRT

Return
#################################################################################################
#################################################################################################
$END_TAG

If GTRACE <> "" & [L]TESTMODE = 1
  Call ECR_TRACE(ctrans(READTMP,chr$(10)+chr$(13)+chr$(9),""), 0) From GESECRAN
Endif

LTAG = ctrans(READTMP,chr$(10)+chr$(13)+chr$(9),"")

Gosub PARSE_TAG
Gosub END_TAG From =LTRT

Return
#################################################################################################
#################################################################################################
$PARSE_TAG

T2 = instr(1, LTAG, " ")

If T2 <> 0
  LTAG=left$(LTAG,T2-1)+">"
Endif

Return
#################################################################################################
#################################################################################################
