Subprog DISPLAY_HIDE()

  Call HIDE_ACTIVITYFIELDS From WCPYLEGMIDHIDE
  Call SHOW_LEGACTCALLS From WCPYLEGMIDSHOW

  #show all SPECIFIC fields
  If clalev([F:AMKW])=0     : Local File AMSK [AMKW]       : Endif
  If clalev([F:AMZW])=0     : Local File AMSKZON [AMZW]    : Endif
  Local Char WSIGN(1)
  Local Char WSAV_LEG(5)
  #WSAV_LEG= GCURLEG
  #GCURLEG=""
  #Gosub SHOW_ALL_SPECIFIC
  #GCURLEG=WSAV_LEG
  WSIGN="-"
  Gosub HIDE_SPECIFIC
  #hide SPECIFIC fields
End

#$SHOW_ALL_SPECIFIC
#  # hide fields
#  Gosub HIDE_SPECIFIC
#Return

$HIDE_SPECIFIC
If func DIVPAYE.IS_KAE_LEG(GCURLEG)>0 Then
##  Chgfmt [M:CLMID]SPOTYP With WSIGN+"-LA:11736"
##  Chgfmt [M:CLMID]SPOBOX With WSIGN+"-K:10X"
##  Chgfmt [M:CLMID]SPOTIT With WSIGN+"-LA:11731"
##  Chgfmt [M:CLMID]SPONAM With WSIGN+"-K:60X"
##  Chgfmt [M:CLMID]SPOADD With WSIGN+"-K:80X"
##  Chgfmt [M:CLMID]SPOOWN With WSIGN+"-K:3X"
##
  If WSIGN = "-"
    Chgtzn [M:CLMID]AGNID  With mess(00028,11738,1)
##    Raz [M:CLMID]SPOTYP
##    Raz [M:CLMID]SPOBOX
##    Raz [M:CLMID]SPOTIT
##    Raz [M:CLMID]SPONAM
##    Raz [M:CLMID]SPOADD
##    Raz [M:CLMID]SPOOWN
  Endif
Endif

#Saudi Arabia
If func DIVPAYE.IS_KSAU_LEG(GCURLEG)>0  Then
    Chgfmt [M:CLMID]SPOTYP With WSIGN+"-LA:11736" : Raz [M:CLMID]SPOTYP
    Chgfmt [M:CLMID]SPOBOX With WSIGN+"-K:10X"    : Raz [M:CLMID]SPOBOX
    Chgfmt [M:CLMID]SPOTIT With WSIGN+"-LA:11731" : Raz [M:CLMID]SPOTIT
    Chgfmt [M:CLMID]SPONAM With WSIGN+"-K:60X"    : Raz [M:CLMID]SPONAM
    Chgfmt [M:CLMID]SPOADD With WSIGN+"-K:80X"    : Raz [M:CLMID]SPOADD
#JASMI - 2018-01-12 - X3-70809 - START
#    Chgfmt [M:CLMID]SPOOWN With WSIGN+"-K:3X"     : Raz [M:CLMID]SPOOWN
    Chgfmt [M:CLMID]SPOOWN With WSIGN+"-N:3"      : Raz [M:CLMID]SPOOWN
#JASMI - 2018-01-12 - X3-70809 - END

  If WSIGN = "-"
    Chgtzn [M:CLMID]AGNID  With mess(00029,11738,1)
    Raz [M:CLMID]SPOTYP
    Raz [M:CLMID]SPOBOX
    Raz [M:CLMID]SPOTIT
    Raz [M:CLMID]SPONAM
    Raz [M:CLMID]SPOADD
    Raz [M:CLMID]SPOOWN
  Endif
Endif

#QATAR / #Bahrain
#ADNGO - 2017-11-24 - X3-60298 - START
#If func DIVPAYE.IS_KZA_LEG(GCURLEG)>0 or func DIVPAYE.IS_KQA_LEG(GCURLEG)>0 Then
If func DIVPAYE.IS_KSA_LEG(GCURLEG)>0 or func DIVPAYE.IS_KQA_LEG(GCURLEG)>0 Then
#ADNGO - 2017-11-24 - X3-60298 - END
  Chgfmt [M:CLMID]SPOTYP With WSIGN+"-LA:11736"
  Chgfmt [M:CLMID]SPOBOX With WSIGN+"-K:10X"
  Chgfmt [M:CLMID]SPOTIT With WSIGN+"-LA:11731"
  Chgfmt [M:CLMID]SPONAM With WSIGN+"-K:60X"
  Chgfmt [M:CLMID]SPOADD With WSIGN+"-K:80X"
#JASMI - 2018-01-12 - X3-70809 - START
#  Chgfmt [M:CLMID]SPOOWN With WSIGN+"-K:3X"
  Chgfmt [M:CLMID]SPOOWN With WSIGN+"-N:3"
#JASMI - 2018-01-12 - X3-70809 - END
  Chgfmt [M:CLMID]CPYPRC With WSIGN+"-K:3X"

  If WSIGN = "-"
    Chgtzn [M:CLMID]AGNID  With mess(00028,11738,1)
    Raz [M:CLMID]SPOTYP
    Raz [M:CLMID]SPOBOX
    Raz [M:CLMID]SPOTIT
    Raz [M:CLMID]SPONAM
    Raz [M:CLMID]SPOADD
    Raz [M:CLMID]SPOOWN
    Raz [M:CLMID]CPYPRC
  Endif
Endif


Return

