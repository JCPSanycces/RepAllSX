#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char VALBOUT(250) , PARBOUT(250)(1..20) 
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","AEXPBATCH","AEXPBATCH",3,"") From GTRAITE
End

Close Mask
Raz GPILOBJ , GNBMASKOUV
GBIDC1 = "SUPERV"
Call OBJET("ADS",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
  When "INIT"
   TMP = 1
   TIT = mess(73,127,1) : # "Création du fichier BATCH.tmp"
  When "EXEC"
   Call CREPAR([M]DEB,[M]FIN)
Endcase
Return

Subprog CREPAR(DEB,FIN)
Value Char DEB
Value Char FIN
# Est-ce que le dossier existe
If filinfo(filpath("","","",GDOSX3,""),0)<0 : End : Endif

Local Char FICPAR(GDIMFIC)

If FIN="" : FIN="ZZZZZZ" : Endif

Local File ATABZON [ATZ]
Local File ATEXTE  [ATX]
FICPAR=filpath("","BATCH","tmp",GDOSX3,"")

Openo FICPAR, 0 Using [P]
Iomode adxifs "" Using [P]
Iomode adxirs chr$(10) Using [P]
Iomode adxium GUTF8 Using [P]
### Les taches
Local File ABATTAC [ABT]
For [ABT]CODTAC Where CODTAC>=DEB & CODTAC<=FIN
 Call ECRIT("ABT","ABATTAC")
Next ABT
### Les groupes de taches
Local File ABATGRP [ABG] 
For [ABG]ABG0 Where CODGRP>=DEB & CODGRP<=FIN
 Call ECRIT("ABG","ABATGRP")
Next ABG
### Les abonnements
Local File ABATABT [ABA]
For [ABA]CODABT Where CODABT>=DEB & CODABT<=FIN
 Call ECRIT("ABA","ABATABT")
Next ABA
### Calendrier serveur batch
Local File ABATCAL [ABC]
For [ABC]ABC0  Where COD>=DEB & COD<=FIN
 Call ECRIT("ABC","ABATCAL")
Next ABC
### Calendrier serveur batch
Local File ABATHOR [ABH]
For [ABH]ABH0 Where COD>=DEB & COD<=FIN
 Call ECRIT("ABH","ABATHOR")
Next ABH
Openo Using [P]
End


######################################################################################

Subprog ECRIT(CLASSE,TABLE)
Value Char CLASSE
Value Char TABLE
Local Integer I , J , NBVAR , DIME , TYP
Local Char    VARIA(GLONAVA)
Wrseq "#"+CLASSE Using [P]
NBVAR = evalue("clanbs([F:"+CLASSE+"],1)")
For I=1 To NBVAR
 VARIA = evalue("clavar([F:"+CLASSE+"],"+num$(I)+")")
 If left$(VARIA,1)<>"~"
  DIME  = evalue("dim([F:"+CLASSE+"]"+VARIA+")")
  TYP   = evalue("type([F:"+CLASSE+"]"+VARIA+")")
  Read [ATZ]CODZONE = TABLE;VARIA
  If !fstat & [F:ATZ]CODTYP="ATX"
   TYP = 99
  Endif
  For J=1 To DIME
   Wrseq VARIA Using [P]
   Wrseq J Using [P]
   Case TYP
    When 3
     Wrseq format$("D:YYYYMMDD",evalue("[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")")) Using [P]
    When 99 : # cas ATX pour ABT et ABG
     For [ATX] Where NUMERO=evalue("[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")")
      Wrseq evalue("[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")"); Using [P]
      Wrseq "~"+[F:ATX]LAN+"~"+[F:ATX]TEXTE Using [P]
     Next
     Wrseq "***" Using [P]
    When Default
     Wrseq evalue("[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")") Using [P]
   Endcase
  Next J
 Endif
Next I
Wrseq "#" Using [P]
End

$ERREUR
GERREUR = errn
GMESSAGE = errp+"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)+"\"+errmes$(GERREUR)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Raz GERREUR , GMESSAGE
Resume


######################################################################################
## Etiquette de  l'ecran
######################################################################################
Subprog C_FIN(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]DEB
 GMESSAGE = mess(252,123,1) : # Borne supérieure plus petite que la borne INFéRIEURE
 mkstat = 2 : End
Endif
End


