#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Update ACLAPARFLD and ASHWPAR FOR DATA TYPE ADI
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update ACLAPARFLD and ASHWPAR FOR DATA TYPE ADI") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub ACLAPARDEF
Gosub ASHWPARDEF
End

#-------------------#
$ACLAPARDEF
Local File =DOSSIER+".ACLAFLD"   [ACLAF]
Local File =DOSSIER+".ACLAPARFLD"   [ACLFP]
Local File =DOSSIER+".ACLAPARFLD"   [ACLF2]
Local Char MYVALUE (80)
Local Integer AERROR

Call ECR_TRACE("Update ACLAPARFLD" - time$,0) From GESECRAN
AERROR=0
Trbegin [ACLFP]
  For [ACLAF] Where [F:ACLAF]CODTYP="ADI"
    Read [ACLFP]ACLFP0=[F:ACLAF]CODCLA;1;1;[F:ACLAF]FLDCLA;"NUMTAB"
    If fstat= 0
      If [F:ACLFP]TYPINT= 7
        #Need to be update
        Read [ACLF2]ACLFP0=[F:ACLAF]CODCLA;1;2;[F:ACLAF]FLDCLA;"CODE"
        If fstat= 0
          If [F:ACLF2]VALEUR=""
            If [F:ACLAF]FLDGRP<>""
            [F:ACLF2]VALEUR=[F:ACLAF]FLDGRP+"."+[F:ACLAF]FLDCLA
            Else
            [F:ACLF2]VALEUR=[F:ACLAF]FLDCLA
            Endif
             Rewrite  [ACLF2]
             If fstat <> 0
               AERROR=1
             Endif
          Endif
        Else
          Raz [ACLF2]
          [F:ACLF2]CODCLA=[F:ACLFP]CODCLA
          [F:ACLF2]TYPPAR=1
          [F:ACLF2]FLDCLA=[F:ACLFP]FLDCLA
          [F:ACLF2]NUMPAR=[F:ACLFP]NUMPAR
          [F:ACLF2]CODPAR="CODE"
          [F:ACLF2]TYPKEY=2
          [F:ACLF2]TYPINT=7
          [F:ACLF2]ADRVAL=2
          If [F:ACLAF]FLDGRP<>""
          [F:ACLF2]VALEUR=[F:ACLAF]FLDGRP+"."+[F:ACLAF]FLDCLA
          Else
          [F:ACLF2]VALEUR=[F:ACLAF]FLDCLA
          Endif
          [F:ACLF2]AWMAJTYP=0
          Write  [ACLF2]
          If fstat <> 0
            AERROR=1
          Endif
        Endif
        If AERROR= 0
          Raz MYVALUE
          Read [ACLF2]ACLFP0=[F:ACLAF]CODCLA;1;2;[F:ACLAF]FLDCLA;"NUMTAB"
          If fstat= 0
            Gosub CHANGE_VALUE_ACLFP
            [F:ACLF2]VALEUR=MYVALUE
            Rewrite  [ACLF2]
            If fstat <> 0
              AERROR=1
            Endif
          Else
            Raz [ACLF2]
            [F:ACLF2]CODCLA=[F:ACLFP]CODCLA
            [F:ACLF2]TYPPAR=1
            [F:ACLF2]FLDCLA=[F:ACLFP]FLDCLA
            [F:ACLF2]NUMPAR=[F:ACLFP]NUMPAR
            [F:ACLF2]CODPAR="NUMTAB"
            [F:ACLF2]TYPKEY=2
            [F:ACLF2]TYPINT=2
            [F:ACLF2]ADRVAL=2
            Gosub CHANGE_VALUE_ACLFP
            [F:ACLF2]VALEUR= MYVALUE
            [F:ACLF2]AWMAJTYP=0
            Write  [ACLF2]
            If fstat <> 0
              AERROR=1
            Endif
          Endif
          If AERROR=0
            #update existing record
            [F:ACLFP]TYPINT=2
            If MYVALUE=""
              Gosub CHANGE_VALUE_ACLFP
            Endif
            [F:ACLFP]VALEUR=MYVALUE
            Rewrite [ACLFP]
            If fstat <> 0
              AERROR=1
            Endif
            Endif
          Endif
        If AERROR= 0
          # Paramètres mis à jour
          Call ECR_TRACE(  [F:ACLAF]CODCLA - "/" - [F:ACLAF]FLDCLA -  mess(208,143,1)-time$,0) From GESECRAN
        Else
          # erreur
          Call ECR_TRACE(  [F:ACLAF]CODCLA - "/" - [F:ACLAF]FLDCLA -  mess(7,21,1)-time$,0) From GESECRAN
        Endif

      Endif
      Read [ACLFP]ACLFP0=[F:ACLAF]CODCLA;1;1;[F:ACLAF]FLDCLA;"DEPCOD"
      If fstat=0
        If [F:ACLFP]NUMPAR<>1
          [F:ACLFP]NUMPAR=1
          Rewrite [ACLFP]
          If fstat<>0
            Call ECR_TRACE(  [F:ACLAF]CODCLA +"/1/1/"+[F:ACLAF]FLDCLA+"/DEPCOD" - mess(27,125,1),0) From GESECRAN
          Endif
        Endif
      Else
        Call ECR_TRACE(  [F:ACLAF]CODCLA +"/1/1/"+[F:ACLAF]FLDCLA+"/DEPCOD" - mess(49,125,1),0) From GESECRAN
      Endif

      Read [ACLFP]ACLFP0=[F:ACLAF]CODCLA;1;1;[F:ACLAF]FLDCLA;"NUMTAB"
      If fstat=0
        If [F:ACLFP]NUMPAR<>4
          [F:ACLFP]NUMPAR=4
          Rewrite [ACLFP]
          If fstat<>0
            Call ECR_TRACE(  [F:ACLAF]CODCLA +"/1/1/"+[F:ACLAF]FLDCLA+"/NUMTAB" - mess(27,125,1),0) From GESECRAN
          Endif
        Endif
      Else
        Call ECR_TRACE(  [F:ACLAF]CODCLA +"/1/1/"+[F:ACLAF]FLDCLA+"/NUMTAB" - mess(49,125,1),0) From GESECRAN
      Endif
      Read [ACLFP]ACLFP0=[F:ACLAF]CODCLA;1;2;[F:ACLAF]FLDCLA;"CODE"
      If fstat=0
        If [F:ACLFP]NUMPAR<>3
          [F:ACLFP]NUMPAR=3
          Rewrite [ACLFP]
          If fstat<>0
            Call ECR_TRACE(  [F:ACLAF]CODCLA +"/1/2/"+[F:ACLAF]FLDCLA+"/CODE" - mess(27,125,1),0) From GESECRAN
          Endif
        Endif
      Else
        Call ECR_TRACE(  [F:ACLAF]CODCLA +"/1/2/"+[F:ACLAF]FLDCLA+"/CODE" - mess(49,125,1),0) From GESECRAN
      Endif
      Read [ACLFP]ACLFP0=[F:ACLAF]CODCLA;1;2;[F:ACLAF]FLDCLA;"NUMTAB"
      If fstat=0
        If [F:ACLFP]NUMPAR<>2
          [F:ACLFP]NUMPAR=2
          Rewrite [ACLFP]
          If fstat<>0
            Call ECR_TRACE(  [F:ACLAF]CODCLA +"/1/2/"+[F:ACLAF]FLDCLA+"/NUMTAB" - mess(27,125,1),0) From GESECRAN
          Endif
        Endif
      Else
        Call ECR_TRACE(  [F:ACLAF]CODCLA +"/1/2/"+[F:ACLAF]FLDCLA+"/NUMTAB" - mess(49,125,1),0) From GESECRAN
      Endif
    Endif
  Next
If AERROR= 0
  Commit
 Else
  Rollback
Endif

Close Local File [ACLAF]
Close Local File [ACLFP]
Close Local File [ACLF2]

Return


$CHANGE_VALUE_ACLFP

#Change the value
If left$([F:ACLFP]VALEUR, 1) ='"' or left$([F:ACLFP]VALEUR, 1) ="'"
  # value= "nnnn"
  MYVALUE=mid$([F:ACLFP]VALEUR,2,  len([F:ACLFP]VALEUR)-2)
  #If MYVALUE=""
  #  MYVALUE=0
  #Endif
Elsif left$([F:ACLFP]VALEUR, 1) ='='
  # value= =n$(nnn)
 Local Integer  ISEARCH
 For ISEARCH= 1 To len ([F:ACLFP]VALEUR)
   If mid$([F:ACLFP]VALEUR, ISEARCH,1 ) ="("
     MYVALUE=right$([F:ACLFP]VALEUR, ISEARCH+1)
     Break
   Endif
 Next
 For ISEARCH= len (MYVALUE) To 1 Step -1
   If mid$(MYVALUE, ISEARCH, 1) =")"
     MYVALUE=left$(MYVALUE, ISEARCH-1)
     Break
   Endif
 Next
Elsif left$([F:ACLFP]VALEUR, 5) ="AVOID"
  MYVALUE="AVOID.ASHORT"
Else
  # it's a property
  MYVALUE="=val("+[F:ACLFP]VALEUR+")"
Endif
MYVALUE = vireblc(MYVALUE,4)
Return



#-------------------#
$ASHWPARDEF
Local File =DOSSIER+".ASHWFLD"   [ASWF]
Local File =DOSSIER+".ASHWPAR"   [ASWP]
Local File =DOSSIER+".ASHWPAR"   [ASWP2]

Call ECR_TRACE("Update ASHWPAR" - time$,0) From GESECRAN
Local Char MYVALUE (80)
AERROR=0
Trbegin [ASWP]
  For   [ASWF] Where [F:ASWF]CODTYP="ADI"
    Read [ASWP]ASWP0=[F:ASWF]CODREP;1;1;[F:ASWF]CODFLD;"";1;"NUMTAB"
    If fstat= 0
      If [F:ASWP]TYPINT= 7
        #Need to be update
        Read [ASWP2]ASWP0=[F:ASWF]CODREP;1;2;[F:ASWF]CODFLD;"";1;"CODE"
        If fstat= 0
          If [F:ASWP2]VALEUR=""
            If [F:ASWF]FLDGRP<>""
            [F:ASWP2]VALEUR=[F:ASWF]FLDGRP+"."+[F:ASWF]CODFLD
            Else
            [F:ASWP2]VALEUR=[F:ASWF]CODFLD
            Endif
             Rewrite  [ASWP2]
             If fstat <> 0
               AERROR=1
             Endif
          Endif
        Else
          Raz [ASWP2]
          [F:ASWP2]CODREP=[F:ASWP]CODREP
          [F:ASWP2]TYPPAR=1
          [F:ASWP2]CODFLD=[F:ASWP]CODFLD
          [F:ASWP2]NUMPAR=[F:ASWP]NUMPAR
          [F:ASWP2]CODLNK=[F:ASWP]CODLNK
          [F:ASWP2]AFFLNK=[F:ASWP]AFFLNK
          [F:ASWP2]CODPAR="CODE"
          [F:ASWP2]TYPKEY=2
          [F:ASWP2]TYPINT=7
          [F:ASWP2]ADRVAL=2
            If [F:ASWF]FLDGRP<>""
            [F:ASWP2]VALEUR=[F:ASWF]FLDGRP+"."+[F:ASWF]CODFLD
            Else
            [F:ASWP2]VALEUR=[F:ASWF]CODFLD
            Endif
          [F:ASWP2]AWMAJTYP=0
          Write  [ASWP2]
          If fstat <> 0
            AERROR=1
          Endif
        Endif
        If AERROR= 0
          Raz MYVALUE
          Read [ASWP2]ASWP0=[F:ASWF]CODREP;1;2;[F:ASWF]CODFLD;"";1;"NUMTAB"
          If fstat= 0
            Gosub CHANGE_VALUE_ASWP
            [F:ASWP2]VALEUR=MYVALUE
            Rewrite  [ASWP2]
            If fstat <> 0
              AERROR=1
            Endif
          Else
            Raz [ASWP2]
            [F:ASWP2]CODREP=[F:ASWP]CODREP
            [F:ASWP2]TYPPAR=1
            [F:ASWP2]CODFLD=[F:ASWP]CODFLD
            [F:ASWP2]NUMPAR=[F:ASWP]NUMPAR
            [F:ASWP2]CODLNK=[F:ASWP]CODLNK
            [F:ASWP2]AFFLNK=[F:ASWP]AFFLNK
            [F:ASWP2]CODPAR="NUMTAB"
            [F:ASWP2]TYPKEY=2
            [F:ASWP2]TYPINT=2
            [F:ASWP2]ADRVAL=2
            Gosub CHANGE_VALUE_ASWP
            [F:ASWP2]VALEUR= MYVALUE
            [F:ASWP2]AWMAJTYP=0
            Write  [ASWP2]
            If fstat <> 0
              AERROR=1
            Endif
          Endif
          If AERROR=0
            #update existing record
            [F:ASWP]TYPINT=2
            If MYVALUE=""
              Gosub CHANGE_VALUE_ASWP
            Endif
            [F:ASWP]VALEUR=MYVALUE
            Rewrite [ASWP]
            If fstat <> 0
              AERROR=1
            Endif
            Endif
          Endif
        If AERROR= 0
          # Paramètres mis à jour
          Call ECR_TRACE(  [F:ASWF]CODREP - "/" - [F:ASWF]CODFLD -  mess(208,143,1)-time$,0) From GESECRAN
        Else
          # erreur
          Call ECR_TRACE(  [F:ASWF]CODREP - "/" - [F:ASWF]CODFLD -  mess(7,21,1)-time$,0) From GESECRAN
        Endif

      Endif

      Read [ASWP]ASWP0=[F:ASWF]CODREP;1;1;[F:ASWF]CODFLD;"";1;"DEPCOD"
      If fstat=0
        If [F:ASWP]NUMPAR<>1
          [F:ASWP]NUMPAR=1
          Rewrite [ASWP]
          If fstat<>0
            Call ECR_TRACE([F:ASWF]CODREP +"/1/1/"+[F:ASWF]CODFLD+"/ /1/DEPCOD" - mess(27,125,1),0) From GESECRAN
          Endif
        Endif
      Else
        Call ECR_TRACE([F:ASWF]CODREP +"/1/1/"+[F:ASWF]CODFLD+"/ /1/DEPCOD" - mess(49,125,1),0) From GESECRAN
      Endif
      Read [ASWP]ASWP0=[F:ASWF]CODREP;1;1;[F:ASWF]CODFLD;"";1;"NUMTAB"
      If fstat=0
        If [F:ASWP]NUMPAR<>4
          [F:ASWP]NUMPAR=4
          Rewrite [ASWP]
          If fstat<>0
            Call ECR_TRACE([F:ASWF]CODREP +"/1/1/"+[F:ASWF]CODFLD+"/ /1/NUMTAB" - mess(27,125,1),0) From GESECRAN
          Endif
        Endif
      Else
        Call ECR_TRACE([F:ASWF]CODREP +"/1/1/"+[F:ASWF]CODFLD+"/ /1/NUMTAB" - mess(49,125,1),0) From GESECRAN
      Endif
      Read [ASWP]ASWP0=[F:ASWF]CODREP;1;2;[F:ASWF]CODFLD;"";1;"CODE"
      If fstat=0
        If [F:ASWP]NUMPAR<>3
          [F:ASWP]NUMPAR=3
          Rewrite [ASWP]
          If fstat<>0
            Call ECR_TRACE([F:ASWF]CODREP +"/1/2/"+[F:ASWF]CODFLD+"/ /1/CODE" - mess(27,125,1),0) From GESECRAN
          Endif
        Endif
      Else
        Call ECR_TRACE([F:ASWF]CODREP +"/1/2/"+[F:ASWF]CODFLD+"/ /1/CODE" - mess(49,125,1),0) From GESECRAN
      Endif
      Read [ASWP]ASWP0=[F:ASWF]CODREP;1;2;[F:ASWF]CODFLD;"";1;"NUMTAB"
      If fstat=0
        If [F:ASWP]NUMPAR<>2
          [F:ASWP]NUMPAR=2
          Rewrite [ASWP]
          If fstat<>0
            Call ECR_TRACE([F:ASWF]CODREP +"/1/2/"+[F:ASWF]CODFLD+"/ /1/NUMTAB" - mess(27,125,1),0) From GESECRAN
          Endif
        Endif
      Else
        Call ECR_TRACE([F:ASWF]CODREP +"/1/2/"+[F:ASWF]CODFLD+"/ /1/NUMTAB" - mess(49,125,1),0) From GESECRAN
      Endif
    Endif
  Next
If AERROR= 0
  Commit
 Else
  Rollback
Endif

Close Local File   [ASWF]
Close Local File [ASWP]
Close Local File [ASWP2]


Return


$CHANGE_VALUE_ASWP

#Change the value
If left$([F:ASWP]VALEUR, 1) ='"' or left$([F:ASWP]VALEUR, 1) ="'"
  # value= "nnnn"
  MYVALUE=mid$([F:ASWP]VALEUR,2,  len([F:ASWP]VALEUR)-2)
  #If MYVALUE=""
  #  MYVALUE=0
  #Endif
Elsif left$([F:ASWP]VALEUR, 1) ='='
  # value= =n$(nnn)
 Local Integer  ISEARCH
 For ISEARCH= 1 To len ([F:ASWP]VALEUR)
   If mid$([F:ASWP]VALEUR, ISEARCH,1 ) ="("
     MYVALUE=right$([F:ASWP]VALEUR, ISEARCH+1)
     Break
   Endif
 Next
 For ISEARCH= len (MYVALUE) To 1 Step -1
   If mid$(MYVALUE, ISEARCH, 1) =")"
     MYVALUE=left$(MYVALUE, ISEARCH-1)
     Break
   Endif
 Next
Elsif left$([F:ASWP]VALEUR, 5) ="AVOID"
  MYVALUE="AVOID.ASHORT"
Else
  # it's a property
  MYVALUE="=val("+[F:ASWP]VALEUR+")"
Endif
MYVALUE = vireblc(MYVALUE,4)
Return

