#<AdxTL>@(#)9.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,"APAREPU","APAREPU",3) From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
Endcase
Return

$OUVRE
If clalev([F:AEP])=0 : Local File AEPUR  [AEP] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
Local Integer OK , I
Return

$INIT_DIA
Raz [M:DIA]
nolign = 0
For [AEP]AEP0
 nolign += 1
 [M]COD(nolign-1) = [F:AEP]COD
 Call TEXTE([F:AEP]INTIT,[M]INTIT(nolign-1)) From OBJDIV
 [M]TEMPS(nolign-1) = [F:AEP]TEMPS
Next
[M]NBLIG = nolign
Return

$EXEC
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [AEP]
 For I=1 To [M]NBLIG
  Update [AEP] Where COD=[M]COD(I-1) With TEMPS=[M]TEMPS(I-1)
  If fstat=1
   GOK = -1 : GLOCK = "$AEPUR"-[M]COD(I-1) : Break
  Elsif fstat
   GOK = 0 : Call RSTA("AEP",[M]COD(I-1)) From GLOCK : Break
  Endif
 Next I
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

