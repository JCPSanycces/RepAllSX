#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# STKPITLIB   Code library for Point in Time Valuation
########################################################################
# Subroutines
#-----------------------------------------------------------------------
# PITUPDATE Main entry point for updating PIT tables
# PITWIPUPD Called from WIP posting. Loops relevant STOJOU records
#
# GETMVTTYP Determine if the movement is an issue or receipt
#
# REG_AVC   Handle all Avg Cost PIT updates
# GETITVP   Get/Create the correct PIT history record for Avg Cost
#
# REG_ALC   Handle all Avg Lot Cost PIT updates
# GETSLFP   Get/Create the correct PIT history record for Avg Lot Cost
#
# REG_FIFO  Handle all FIFO/LIFO PIT updates
# GETSTPP   Get/Create the correct PIT history record for FIFO/LIFO
#
# ECRPIT    Write new record in corresponding PIT table
# REWPIT    Re-write existing record in corresponding PIT table
#
########################################################################

########################################################################
# PITUPDATE   Record point in time valuation for primary and secondary
#             valuation methods.
#             Update flags in STOJOU if successful.
########################################################################
Subprog PITUPDATE
Local Char LTCM(3)
Local Integer LRET, LMVTTYP, UPDSTJ

  If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif

  Call GETPITTCM([F:STJ]ITMREF,[F:STJ]STOFCY,[F:STJ]CREDATTIM,LTCM,LRET)
  If LRET | LTCM="" : End : Endif

  Call GETMVTTYP([F:STJ]TRSTYP, LMVTTYP)

  Raz UPDSTJ
  # Register for the primary valuation method
  If [F:STJ]PITVALFLG<2
    Raz LRET
    Case [F:TCM]ISSVLTCOD(0)
      When 1 #Standard
        Call REG_STD([L]LMVTTYP,1,LRET)
      When 2 #Revised Standard
        Call REG_STD([L]LMVTTYP,1,LRET)
      When 4 # Average Cost
        Call REG_AVC([L]LMVTTYP,1,LRET)
      When 5 #FIFO
        Call REG_FIFO([L]LMVTTYP,1,LRET)
      When 6 # Average Lot Cost
        Call REG_ALC([L]LMVTTYP,1,LRET)
      When 8 #LIFO
        Call REG_FIFO([L]LMVTTYP,1,LRET)
      When Default
        LRET = [V]CST_ANO
    Endcase

    If LRET = [V]CST_AOK
      [F:STJ]PITVALFLG = [V]CST_AYES
      UPDSTJ = [V]CST_AYES
    Endif
  Endif

  # Register for the secondary valuation method if applicable
  If GACTVLT2
    If [F:STJ]PITVALFLG2<2 & [F:TCM]ISSVLTCOD(1)>0 & [F:TCM]ISSVLTCOD(1)<>[F:TCM]ISSVLTCOD(0)
&      & !(find([F:TCM]ISSVLTCOD(0),5,8) & find([F:TCM]ISSVLTCOD(1),5,8))
      Raz LRET
      Case [F:TCM]ISSVLTCOD(1)
        When 1 #Standard
          Call REG_STD([L]LMVTTYP,2,LRET)
        When 2 #Revised Standard
          Call REG_STD([L]LMVTTYP,2,LRET)
        When 4    # Average Cost
          Call REG_AVC([L]LMVTTYP,2,LRET)
        When 5    # FIFO
          Call REG_FIFO([L]LMVTTYP,2,LRET)
        When 6    # Average Lot Cost
          Call REG_ALC([L]LMVTTYP,2,LRET)
        When 8    # LIFO
          Call REG_FIFO([L]LMVTTYP,2,LRET)
        When Default
          LRET = [V]CST_ANO
      Endcase

      If LRET = [V]CST_AOK
        [F:STJ]PITVALFLG2 = [V]CST_AYES
        UPDSTJ = [V]CST_AYES
      Endif
    Else
      # No secondary valuation or both set to the same
      [F:STJ]PITVALFLG2 = 2
      UPDSTJ = [V]CST_AYES
    Endif
  Endif

  If UPDSTJ : Rewrite [STJ] : Endif

End

########################################################################
# PITWIPUPD     Run PIT Update from the WIP posting process
#               Any records that would be marked as posted in STOJOU
#               get passed to here to get included.
########################################################################
# Parameters :  PITM    = Product
#               PFCY    = Manufacturing (stock) facilty
#               PVCRTYP = Document Type
#               PTRKNUM = MFG Tracking number
#               PTRKLIN = MFG Tracking line
#
########################################################################
Subprog PITWIPUPD(PITM, PFCY, PVCRTYP, PTRKNUM, PTRKLIN)
Value Char    PITM
Value Char    PFCY
Value Integer PVCRTYP
Value Char    PTRKNUM
Value Integer PTRKLIN

Local Char    LCRIT(250)

  If !clalev([F:STJ]) : Local File STOJOU [STJ] : Endif

  LCRIT =  "(PITVALFLG<>2 | PITVALFLG2<>2) & "
  LCRIT += "STOFCY = '" + PFCY + "' & "
  LCRIT += "VCRNUM = '" + PTRKNUM + "' & "
  LCRIT += "VCRLIN = " + num$(PTRKLIN) + " & "
  # If we have a VCRTYP, we want all products for this VCRNUM, VCRLIN and VCRTYP combo
  # If not, just for this one product for that VCRNUM and VCRLIN
  If PVCRTYP <> 0
    LCRIT += "VCRTYP = " + num$(PVCRTYP)
  Else
    LCRIT += "ITMREF = '" + PITM + "'"
  Endif

  # Filter for all relevant STOJOU records and call PITUPDATE
  Filter [STJ] Where evalue(LCRIT) Order By STOFCY;IPTDAT;ITMREF;MVTSEQ;MVTIND
  For [STJ]
    Call PITUPDATE
  Next
  Filter [STJ]

End

########################################################################
# PITPRIADJ     Updates PIT records with the new issue values after
#               running price adjustment
########################################################################
# Parameters :  PITM    = Product
#               PFCY    = Manufacturing (stock) facilty
#               PVCRTYP = Document Type
#               PTRKNUM = MFG Tracking number
#               PTRKLIN = MFG Tracking line
#
########################################################################
Subprog PITPRIADJ(PAMTRCP,PAMTISS,PDEV)
Value Decimal PAMTRCP
Value Decimal PAMTISS
Value Decimal PDEV

  #If origional record has not been poted to PIT already
  # We do not need to update the record now.
  If !clalev([F:STJT]) : Local File STOJOU [STJT] : Endif
  If clalev([F:STJ])
    If [F:STJ]PITVALFLG <> 2
      Goto $END_PRIADJ
    Endif
    [F:STJT] = [F:STJ]
    Raz [F:STJ]

  Else
    Goto $END_PRIADJ
  Endif

  [F:STJ]ITMREF = [STJT]ITMREF
  [F:STJ]IPTDAT = [STJT]IPTDAT
  [F:STJ]ACCDAT = [STJT]ACCDAT
  [F:STJ]STOFCY = [STJT]STOFCY
  If PAMTRCP <> 0
    [F:STJ]VARVAL = PAMTRCP
  Else
    [F:STJ]VARVAL = PAMTISS
  Endif
  [F:STJ]CSTCOU = [STJT]CSTCOU
  [F:STJ]CSTTIM = [STJT]CSTTIM
  [F:STJ]CSTDAT = [STJT]CSTDAT
  [F:STJ]LOT = [STJT]LOT
  [F:STJ]SLO = [STJT]SLO
  [F:STJ]AMTDEV = PDEV
  [F:STJ]TRSTYP = [STJT]TRSTYP
  [F:STJ]VCRNUM = [STJT]VCRNUM
  [F:STJ]VCRTYP = [STJT]VCRTYP
  [F:STJ]PITVALFLG = 0

  Call PITUPDATE

  Raz [F:STJ]
  [F:STJ] = [F:STJT]
  Rewrite [STJ]
  $END_PRIADJ
End

########################################################################
# VLTCODCHG     Create new records in PIT tables for any stock on hand
#                 when valuation method is changed for a product
########################################################################
# Parameters :  PITM    = Product
#               PFCY    = Stock facilty
#               PTCM    = Vaulation method
#
########################################################################
Subprog VLTCODCHG(PITM, PFCY, PTCM)
Value Char PITM
Value Char PFCY
Value Char PTCM

Local Integer I

  Local File TABCOSTMET [TCM]

  Read [TCM]TCM0=PTCM
  If fstat : End : Endif

  # Create initial balances for product valuation
  For I = 0 To dim([F:TCM]ISSVLTCOD)-1
    Case [F:TCM]ISSVLTCOD(I)
      When 1 : Call ITCPBEGBAL(PITM, PFCY, 1, I+1)   # Standard
      When 2 : Call ITCPBEGBAL(PITM, PFCY, 2, I+1)   # Revised Standard
      When 4 : Call ITVPBEGBAL(PITM, PFCY, I+1)      # Average Cost
      When 5 : Call STPPBEGBAL(PITM, PFCY, I+1)      # FIFO
      When 6 : Call SLFPBEGBAL(PITM, PFCY, I+1)      # Average lot cost
      When 8 : Call STPPBEGBAL(PITM, PFCY, I+1)      # LIFO
    Endcase
  Next

End

########################################################################
# GETTCM : Get the valuation method for a Product Site
#          based on a specific point in time.
#          Reposition the table TABCOSTMET to the correct record
########################################################################
# Parameters E : PITM    = Product
#                PFCY    = Site
#                PDAT    = Date for valuation
#            S : PTCM    = Vaulation method
#                PRET    = Error code  (0 : OK
#                                       2 : Error reading the product
#                                       3 : No valuation method )
########################################################################
Subprog GETPITTCM(PITM, PFCY, PDAT, PTCM, PRET)
Value    Char     PITM
Value    Char     PFCY
Value    Datetime PDAT
Variable Char     PTCM
Variable Integer  PRET

  Local Integer I
  Raz PTCM, PRET

  If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
  If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
  If !clalev([F:ITG]) : Local File ITMCATEG   [ITG] : Endif

  #----- Read the product site if needed -----#
  If [F:ITF]ITMREF<>PITM | [F:ITF]STOFCY<>PFCY
    Read [ITF] ITF0=PITM;PFCY
    If fstat  : PRET = 2 : End : Endif
  Endif

  # Default to the current product valuation method
  PTCM = [F:ITF]VLTCOD

  # Check the history for a relevant method at the given date/time
  For I = dim([F:ITF]VLTCODDAT)-1 To 0 Step -1
    If [F:ITF]VLTCODDAT(I) >= PDAT
      PTCM = [F:ITF]VLTCODHIS(I)
      Break
    Endif
  Next

# MJH X3-102842. Do not use VLTCOD from product catagory. It is now required on product site.

#  # We did not find a method on the product or history, check the category (no history here)
#  If PTCM=""
#    If [F:ITM]ITMREF<>PITM
#        Read [ITM]ITM0=PITM
#        If fstat : PRET = 2 : End : Endif
#    Endif
#    If [F:ITG]STOFCY<>PFCY | [F:ITG]TCLCOD<>[F:ITM]TCLCOD
#        Read [ITG]ITG0=PFCY;[F:ITM]TCLCOD
#    Endif
#    If fstat | [F:ITG]VLTCOD=""
#        Read [ITG]ITG0="";[F:ITM]TCLCOD
#        If fstat : PRET = 2 : End : Endif
#        If [F:ITG]VLTCOD=""
#            PRET=3
#            End
#        Endif
#    Endif
#    PTCM = [F:ITG]VLTCOD
#  Endif

  If clalev([F:TCM]) & [F:TCM]VLTCOD<>PTCM
    Read [TCM]TCM0=PTCM
  Endif

End

########################################################################
# GETMVTTYP     Return if transaction if an issue or receipt
########################################################################
# Parameters :  PTRSTYP = Transaction Type
#            :  PMVTTYP = Movement Type (1 = Receipt, 2 = Issue, 3 = Value change, 4 = Misc)
#
########################################################################
Subprog GETMVTTYP(PTRSTYP,PMVTTYP)
Value     Integer PTRSTYP
Variable  Integer PMVTTYP

  Case [F:STJ]TRSTYP
    When 1,3,5,12,19  : PMVTTYP = 1 # Receipt
    When 2,4,6,11     : PMVTTYP = 2 # Issue
    When 23           : PMVTTYP = 3 # Value changes only - no quantity - get their own bucket
    When Default      : PMVTTYP = 4 # Misc - Base update on the sign
  Endcase

End

########################################################################
# REG_AVC       Register the PIT updates for AVC valuation
########################################################################
# Parameters :  PMVTTYP = Movement Type (1 = Receipt, 2 = Issue, 3 = Misc)
#               PVLTNUM = Is this the first or second valuation method?
#            :  PRET    = 0, success
#
########################################################################
Subprog REG_AVC (PMVTTYP,PVLTNUM, PRET)
Value     Integer PMVTTYP
Value     Integer PVLTNUM
Variable  Integer PRET

Local Integer LRET
Local Decimal ENDQTY, ENDAMT, AMTDEV, VARVAL
Local Char    LERR(250)
Local Date    PITDATE

  # For Put-away plan transactions, nothing to process
  If [F:STJ]TRSTYP = 22 : End : Endif

  If !clalev([F:ITVP]) : Local File ITMMVTPIT [ITVP] : Endif

  # Use ACCDAT if there is one, IPTDAT if not
  [L]PITDATE = [F:STJ]ACCDAT
  If [L]PITDATE=[0/0/0] : [L]PITDATE=[F:STJ]IPTDAT : Endif

  Call GETITVP([F:STJ]ITMREF, [F:STJ]STOFCY, [L]PITDATE, [L]PVLTNUM, 1, LRET)
  If LRET
    PRET=LRET
    LERR = "ITMMVTPIT"-mess(12,100,1)
    Call ECR_TRACE(LERR,1) From GESECRAN
    End
  Endif

  If PVLTNUM = 1
    [L]AMTDEV = [F:STJ]AMTDEV
    [L]VARVAL = [F:STJ]VARVAL
  Else
    [L]AMTDEV = [F:STJ]AMTDEV2
    [L]VARVAL = [F:STJ]VARVAL2
  Endif

  # For Lot Modifications - the Issue does not have a VARVAL value - so use unit price * qty
  # The receipt does have a value, so this has to be there to off-set it
  If [F:STJ]VCRTYP = 35 & [F:STJ]TRSTYP = 2
    [L]VARVAL = [F:STJ]VARORD
  Endif

  Case PMVTTYP
    When 1        # Receipt
      [F:ITVP]PERRCPQTY += [F:STJ]QTYSTU
      [F:ITVP]PERRCPAMT += [L]VARVAL
    When 2        # Issue
      [F:ITVP]PERISSQTY += [F:STJ]QTYSTU
      [F:ITVP]PERISSAMT += [L]VARVAL
    When 3        # Value changes
      [F:ITVP]PERVALCHG += [L]VARVAL
    When Default  # Misc - base the movement type on the sign
      If [F:STJ]QTYSTU>0
        [F:ITVP]PERRCPQTY += [F:STJ]QTYSTU
        [F:ITVP]PERRCPAMT += [L]VARVAL
      Else
        [F:ITVP]PERISSQTY += [F:STJ]QTYSTU
        [F:ITVP]PERISSAMT += [L]VARVAL
      Endif
  Endcase

  # Sum up AMTDEV for the period
  [F:ITVP]PERAMTDEV += [L]AMTDEV

  # Update the period cumulative and end balances
  [F:ITVP]PERCUMQTY += [F:STJ]QTYSTU
  [F:ITVP]PERCUMAMT += [L]VARVAL
  [F:ITVP]ENDBASQTY += [F:STJ]QTYSTU
  [F:ITVP]ENDBASAMT += [L]VARVAL

  If [F:STJ]TRSTYP = 35
    [F:ITVP]PERCUMAMT += [L]AMTDEV
    [F:ITVP]ENDBASAMT += [L]AMTDEV
  Endif

  If [F:ITVP]PERCUMQTY <> 0
    [F:ITVP]PERCUMAVC = [F:ITVP]PERCUMAMT/[F:ITVP]PERCUMQTY
  Else
    Raz [F:ITVP]PERCUMAVC
  Endif
  If [F:ITVP]ENDBASQTY <> 0
    [F:ITVP]ENDAVC = [F:ITVP]ENDBASAMT/[F:ITVP]ENDBASQTY
  Else
    Raz [F:ITVP]ENDAVC
  Endif

  Call REWPIT('ITVP',LRET)
  If LRET
    PRET=LRET
    LERR = "ITMMVTPIT"-mess(12,100,1)
    Call ECR_TRACE(LERR,1) From GESECRAN
    End
  Endif

  # Save off the end balance for updating future periods
  ENDQTY = [F:ITVP]ENDBASQTY
  ENDAMT = [F:ITVP]ENDBASAMT

  # Check if any future periods exist and need their balances updated.
  Filter [ITVP] Where ITMREF = [F:STJ]ITMREF
&                   & STOFCY = [F:STJ]STOFCY
&                   & PERSTR > [L]PITDATE
&                   & VLTNUM = PVLTNUM
  For [ITVP]ITVP0
    [F:ITVP]BEGBASQTY = ENDQTY
    [F:ITVP]BEGBASAMT = ENDAMT
    If [F:ITVP]BEGBASQTY <> 0
      [F:ITVP]BEGAVC = [F:ITVP]BEGBASAMT/[F:ITVP]BEGBASQTY
    Else
      Raz [F:ITVP]BEGAVC
    Endif

    [F:ITVP]ENDBASQTY = [F:ITVP]BEGBASQTY + [F:ITVP]PERCUMQTY
    [F:ITVP]ENDBASAMT = [F:ITVP]BEGBASAMT + [F:ITVP]PERCUMAMT
    If [F:ITVP]ENDBASQTY <> 0
      [F:ITVP]ENDAVC = [F:ITVP]ENDBASAMT/[F:ITVP]ENDBASQTY
    Else
      Raz [F:ITVP]ENDAVC
    Endif

    Call REWPIT('ITVP',LRET)
    If LRET
      PRET=LRET
      LERR = "ITMMVTPIT"-mess(12,100,1)
      Call ECR_TRACE(LERR,1) From GESECRAN
      End
    Endif

    # Save off the end balance for updating future periods
    ENDQTY = [F:ITVP]ENDBASQTY
    ENDAMT = [F:ITVP]ENDBASAMT

  Next
  Filter [ITVP]

End

########################################################################
# GETITVP       Lookup or create the PIT record for Avg Cost
########################################################################
# Parameters :  PITM = Product
#               PFCY = Site
#               PDAT = Transaction date
#               PLOK = 0 -> Read
#                      1 -> readlock
########################################################################
Subprog GETITVP(PITM,PFCY,PDAT,PVLTNUM,PLOK,PRET)
Value    Char    PITM
Value    Char    PFCY
Value    Date    PDAT
Value    Integer PVLTNUM
Value    Integer PLOK
Variable Integer PRET

If !clalev([F:PER]) : Local File PERIOD [PER] : Endif

Local Decimal LBEGAMT,LBEGQTY,LAVC
Local Decimal LEXE, LPER
Local Integer LTRBEGIN
Local Date    CURPERSTR,CURPEREND,PREVPEREND
Raz LEXE, LPER

  Call OPEN_PERIOD(PFCY, PDAT,LEXE,LPER)

  # Save the Period start we used for locking this record later
  CURPERSTR = [F:PER]PERSTR
  CURPEREND = [F:PER]PEREND

  # Check to see if this record exists or if we need to create
  Look [ITVP]ITVP0=PITM;PFCY;CURPERSTR;PVLTNUM
  If find(fstat,4,5)

    Gosub CREITVP
    If PRET : End : Endif

    # Check to see if we need to fill in the gap between old and current
    If PREVPEREND <> [0/0/0]
      While CURPERSTR - PREVPEREND > 1
        # Look for the next period from the original
        PREVPEREND += 1
				Call OPEN_PERIOD(PFCY, PREVPEREND,LEXE,LPER)
        Gosub CREITVP
        If PRET : End : Endif
        PREVPEREND = [F:ITVP]PEREND
      Wend
    Else
      # This record is the beginning period for this key combo
      # Did back dating cause a gap between this and the previous oldest?
      Filter [ITVP] Where ITMREF = PITM & STOFCY = PFCY & PERSTR > CURPEREND & VLTNUM = PVLTNUM
      Read [ITVP] ITVP0 First
      Filter [ITVP]
      While [F:ITVP]PERSTR - CURPEREND > 1

        CURPEREND += 1

        Call OPEN_PERIOD(PFCY, CURPEREND,LEXE,LPER)
        Gosub CREITVP
        If PRET : End : Endif

        CURPEREND = [F:PER]PEREND

        Filter [ITVP] Where ITMREF = PITM & STOFCY = PFCY & PERSTR > CURPEREND & VLTNUM = PVLTNUM
        Read [ITVP] ITVP0 First
        Filter [ITVP]

      Wend
    Endif

  Endif

  # Record(s) have been created.  So now read or lock the wanted record
  If !PLOK
    Read [ITVP]ITVP0=PITM;PFCY;CURPERSTR;PVLTNUM
  Else
    Readlock [ITVP]ITVP0=PITM;PFCY;CURPERSTR;PVLTNUM
  Endif

End

##############################################################
# Populate all the needed data for a new record in ITMMVTPIT
##############################################################
$CREITVP
    If adxlog=0
        Trbegin [ITVP]
        LTRBEGIN=1
    Else
        LTRBEGIN=0
    Endif

    # Look for the previous record so we can set the beginning balances
    Filter [ITVP] Where ITMREF = PITM
&                     & STOFCY = PFCY
&                     & PERSTR < [F:PER]PERSTR
&                     & VLTNUM = PVLTNUM
    Read [ITVP] ITVP0 Last
    Filter [ITVP]
    # Record found - save off the end info for new start
    If !fstat
      [L]LBEGAMT = [F:ITVP]ENDBASAMT
      [L]LBEGQTY = [F:ITVP]ENDBASQTY
      If [L]LBEGQTY<>0
        [L]LAVC  = [L]LBEGAMT/[L]LBEGQTY
      Endif

      # Get the end date of the previous.
      #If not in line with desired one, we need to fill the gap
      PREVPEREND = [F:ITVP]PEREND
    Endif

    Raz [F:ITVP]
    [F:ITVP]ITMREF    = PITM
    [F:ITVP]STOFCY    = PFCY
    [F:ITVP]VLTNUM    = PVLTNUM
    [F:ITVP]PERSTR    = [F:PER]PERSTR
    [F:ITVP]PEREND    = [F:PER]PEREND
    [F:ITVP]FIYNUM    = LEXE
    [F:ITVP]PERNUM    = LPER
    [F:ITVP]BEGBASAMT = [L]LBEGAMT
    [F:ITVP]BEGBASQTY = [L]LBEGQTY
    [F:ITVP]BEGAVC    = [L]LAVC
    # At this point - no transcations, so Beg = End
    [F:ITVP]ENDBASAMT = [L]LBEGAMT
    [F:ITVP]ENDBASQTY = [L]LBEGQTY
    [F:ITVP]ENDAVC    = [L]LAVC

    Call ECRPIT('ITVP',PRET)
    If PRET
      If LTRBEGIN : Rollback : Endif
    Else
      If LTRBEGIN : Commit : Endif
    Endif
Return

####################################################################
# Create beginning balances for AVC when changing valuation method
####################################################################
Subprog ITVPBEGBAL(PITM, PFCY, PVLTNUM)
Value Char    PITM
Value Char    PFCY
Value Integer PVLTNUM

Local Integer LFIY, LPER, LRET

  Local File ITMMVTPIT [ITVP]
  Local File ITMMVT    [ITV]
  Local File PERIOD     [PER]

  Call GETPERIOD(PFCY, 1, date$, LFIY, LPER) From CPTSUB

  # If the record already exists, just end
  Read [ITVP]ITVP0=PITM;PFCY;[F:PER]PERSTR;PVLTNUM
  If !fstat : End : Endif

  # Find the current ITMMVT records for the Product/Site
  Read [ITV]ITV0=PITM;PFCY
  If !fstat
    Raz [F:ITVP]

    [F:ITVP]ITMREF    = PITM
    [F:ITVP]STOFCY    = PFCY
    [F:ITVP]VLTNUM     = PVLTNUM

    [F:ITVP]BEGBASAMT = [F:ITV]AVCBASAMT
    [F:ITVP]BEGBASQTY = [F:ITV]AVCBASQTY
    [F:ITVP]BEGAVC    = [F:ITV]AVC
    # At this point - no transcations, so Beg = End
    [F:ITVP]ENDBASAMT = [F:ITV]AVCBASAMT
    [F:ITVP]ENDBASQTY = [F:ITV]AVCBASQTY
    [F:ITVP]ENDAVC    = [F:ITV]AVC

    [F:ITVP]PERSTR    = [F:PER]PERSTR
    [F:ITVP]PEREND    = [F:PER]PEREND
    [F:ITVP]FIYNUM    = LFIY
    [F:ITVP]PERNUM    = LPER

    Call ECRPIT('ITVP',LRET)
  Endif

End

########################################################################
# REG_ALC       Register the PIT updates for Average Lot Cost
########################################################################
# Parameters :  PMVTTYP = Movement Type (1 = Receipt, 2 = Issue, 3 = Misc)
#               PVLTNUM = Is this the first or second valuation method?
#            :  PRET    = 0, success
#
########################################################################
Subprog REG_ALC (PMVTTYP,PVLTNUM, PRET)
Value     Integer PMVTTYP
Value     Integer PVLTNUM
Variable  Integer PRET

Local Integer LRET
Local Decimal ENDQTY, ENDAMT, AMTDEV, VARVAL
Local Char    LERR(250)
Local Char    LLOT(GLONLOT), LSLO(GLONSLO)
Local Date    PITDATE

  If !clalev([F:SLFP]) : Local File STOLOTFCYPIT [SLFP] : Endif

  LLOT = [F:STJ]LOT : LSLO = [F:STJ]SLO

  If PVLTNUM = 1
    [L]AMTDEV = [F:STJ]AMTDEV
    [L]VARVAL = [F:STJ]VARVAL
  Else
    [L]AMTDEV = [F:STJ]AMTDEV2
    [L]VARVAL = [F:STJ]VARVAL2
  Endif

  # For a value change when ALC is secondary, lot info won't be in STOJOU
  # Need to look it up from the CGVDET records
  If PMVTTYP = 3 and PVLTNUM = 2
    If !clalev([F:CGVD]): Local File CGVDET [CGVD]: Endif
    Filter [F:CGVD] Where CGVNUM = [F:STJ]VCRNUM and CGVTYP = 3
    For [CGVD]
      [L]VARVAL = [F:CGVD]AMT - [F:CGVD]AMTORI
      [L]LLOT   = [F:CGVD]LOT
      [L]LSLO   = [F:CGVD]SLO
      Gosub REG_ALC_MAIN
    Next
    Filter [F:CGVD]
  Else
    Gosub REG_ALC_MAIN
  Endif

End

$REG_ALC_MAIN
  # Use ACCDAT if there is one, IPTDAT if not
  [L]PITDATE = [F:STJ]ACCDAT
  If [L]PITDATE=[0/0/0] : [L]PITDATE=[F:STJ]IPTDAT : Endif

  Call GETSLFP([F:STJ]ITMREF, LLOT, LSLO, [F:STJ]STOFCY, [L]PITDATE, PVLTNUM, 1, LRET)
  If LRET
    PRET=LRET
    LERR = "STOLOTFCYPIT"-mess(12,100,1)
    Call ECR_TRACE(LERR,1) From GESECRAN
    End
  Endif

  Case PMVTTYP
    When 1        # Receipt
      [F:SLFP]PERRCPQTY += [F:STJ]QTYSTU
      [F:SLFP]PERRCPAMT += [L]VARVAL
    When 2        # Issue
      [F:SLFP]PERISSQTY += [F:STJ]QTYSTU
      [F:SLFP]PERISSAMT += [L]VARVAL
    When 3        # Value changes
      [F:SLFP]PERVALCHG += [L]VARVAL
    When Default  # Misc - base the movement type on the sign
      If [F:STJ]QTYSTU>0
        [F:SLFP]PERRCPQTY += [F:STJ]QTYSTU
        [F:SLFP]PERRCPAMT += [L]VARVAL
      Else
        [F:SLFP]PERISSQTY += [F:STJ]QTYSTU
        [F:SLFP]PERISSAMT += [L]VARVAL
      Endif
  Endcase

  # Sum up AMTDEV for the period
  [F:SLFP]PERAMTDEV += [L]AMTDEV

  # Update the period cumulative and end balances
  [F:SLFP]PERCUMQTY += [F:STJ]QTYSTU
  [F:SLFP]PERCUMAMT += [L]VARVAL
  [F:SLFP]ENDBASQTY += [F:STJ]QTYSTU
  [F:SLFP]ENDBASAMT += [L]VARVAL

  If [F:STJ]TRSTYP = 35
    [F:SLFP]PERCUMAMT += [L]AMTDEV
    [F:SLFP]ENDBASAMT += [L]AMTDEV
  Endif

  If [F:SLFP]PERCUMQTY <> 0
    [F:SLFP]PERCUMAVC = [F:SLFP]PERCUMAMT/[F:SLFP]PERCUMQTY
  Else
    Raz [F:SLFP]PERCUMAVC
  Endif

  If [F:SLFP]ENDBASQTY <> 0
    [F:SLFP]ENDAVC = [F:SLFP]ENDBASAMT/[F:SLFP]ENDBASQTY
  Else
    Raz [F:SLFP]ENDAVC
  Endif

  Call REWPIT('SLFP',LRET)
  If LRET
    PRET=LRET
    LERR = "STOLOTFCYPIT"-mess(12,100,1)
    Call ECR_TRACE(LERR,1) From GESECRAN
    End
  Endif

  # Save off the end balance for updating future periods
  ENDQTY = [F:SLFP]ENDBASQTY
  ENDAMT = [F:SLFP]ENDBASAMT

  # Check if any future periods exist and need their balances updated.
  Filter [SLFP] Where ITMREF = [F:STJ]ITMREF
&                   & LOT    = [F:STJ]LOT
&                   & SLO    = [F:STJ]SLO
&                   & STOFCY = [F:STJ]STOFCY
&                   & PERSTR > [L]PITDATE
&                   & VLTNUM = PVLTNUM
  For [SLFP]SLFP0
    [F:SLFP]BEGBASQTY = ENDQTY
    [F:SLFP]BEGBASAMT = ENDAMT
    If [F:SLFP]BEGBASQTY <> 0
      [F:SLFP]BEGAVC = [F:SLFP]BEGBASAMT/[F:SLFP]BEGBASQTY
    Else
      Raz [F:SLFP]BEGAVC
    Endif

    [F:SLFP]ENDBASQTY = [F:SLFP]BEGBASQTY + [F:SLFP]PERCUMQTY
    [F:SLFP]ENDBASAMT = [F:SLFP]BEGBASAMT + [F:SLFP]PERCUMAMT
    If [F:SLFP]ENDBASQTY <> 0
      [F:SLFP]ENDAVC = [F:SLFP]ENDBASAMT/[F:SLFP]ENDBASQTY
    Else
      Raz [F:SLFP]ENDAVC
    Endif

    Call REWPIT('SLFP',LRET)
    If LRET
      PRET=LRET
      LERR = "STOLOTFCYPIT"-mess(12,100,1)
      Call ECR_TRACE(LERR,1) From GESECRAN
      End
    Endif

    # Save off the end balance for updating future periods
    ENDQTY = [F:SLFP]ENDBASQTY
    ENDAMT = [F:SLFP]ENDBASAMT

  Next
  Filter [SLFP]

Return

########################################################################
# GETSLFP       Lookup or create the PIT record for Avg Lot Cost
########################################################################
# Parameters :  PITM = Product
#               PLOT = Lot
#               PSLO = Sub-Lot
#               PFCY = Site
#               PDAT = Transaction date
#               PLOK = 0 -> Read
#                      1 -> readlock
########################################################################
Subprog GETSLFP(PITM,PLOT,PSLO,PFCY,PDAT,PVLTNUM,PLOK,PRET)
Value    Char    PITM
Value    Char    PLOT
Value    Char    PSLO
Value    Char    PFCY
Value    Date    PDAT
Value    Integer PVLTNUM
Value    Integer PLOK
Variable Integer PRET

If !clalev([F:PER]) : Local File PERIOD [PER] : Endif

Local Decimal LBEGAMT,LBEGQTY,LAVC
Local Decimal LEXE, LPER
Local Integer LTRBEGIN
Local Date    CURPERSTR,CURPEREND,PREVPEREND
Raz LEXE, LPER

  Call OPEN_PERIOD(PFCY,PDAT,LEXE,LPER)

  # Save the Period start we used for locking this record later
  CURPERSTR = [F:PER]PERSTR
  CURPEREND = [F:PER]PEREND

  # Check to see if this record exists or if we need to create
  Look [SLFP]SLFP0=PITM;PLOT;PSLO;PFCY;CURPERSTR;PVLTNUM
  If find(fstat,4,5)

    Gosub CRESLFP
    If PRET : End : Endif

    # Check to see if we need to fill in the gap between old and current
    If PREVPEREND <> [0/0/0]
      While CURPERSTR - PREVPEREND > 1
        # Look for the next period from the original
        PREVPEREND += 1
        Call OPEN_PERIOD(PFCY,PREVPEREND,LEXE,LPER)
        Gosub CRESLFP
        If PRET : End : Endif
        PREVPEREND = [F:SLFP]PEREND
      Wend
    Else
      # This record is the beginning period for this key combo
      # Did back dating cause a gap between this and the previous oldest?
      Filter [SLFP] Where ITMREF=PITM & LOT=PLOT & SLO = PSLO & STOFCY=PFCY & PERSTR>CURPEREND & VLTNUM = PVLTNUM
      Read [SLFP] SLFP0 First
      Filter [SLFP]
      While [F:SLFP]PERSTR - CURPEREND > 1

        CURPEREND += 1

        Call OPEN_PERIOD(PFCY,CURPEREND,LEXE,LPER)
        Gosub CRESLFP
        If PRET : End : Endif

        CURPEREND = [F:PER]PEREND

        Filter [SLFP] Where ITMREF=PITM & LOT=PLOT & SLO = PSLO & STOFCY=PFCY & PERSTR>CURPEREND & VLTNUM = PVLTNUM
        Read [SLFP] SLFP0 First
        Filter [SLFP]

      Wend
    Endif

  Endif

  # Record(s) have been created.  So now read or lock the wanted record
  If !PLOK
    Read [SLFP]SLFP0=PITM;PLOT;PSLO;PFCY;CURPERSTR;PVLTNUM
  Else
    Readlock [SLFP]SLFP0=PITM;PLOT;PSLO;PFCY;CURPERSTR;PVLTNUM
  Endif

End

################################################################
# Populate all the needed data for a new record in STOLOTFCYPIT
################################################################
$CRESLFP
    If adxlog=0
        Trbegin [SLFP]
        LTRBEGIN=1
    Else
        LTRBEGIN=0
    Endif

    # Look for the previous record so we can set the beginning balances
    Filter [SLFP] Where ITMREF = PITM
&                     & LOT    = PLOT
&                     & SLO    = PSLO
&                     & STOFCY = PFCY
&                     & PERSTR < [F:PER]PERSTR
&                     & VLTNUM = PVLTNUM
    Read [SLFP] SLFP0 Last
    Filter [SLFP]
    # Record found - save off the end info for new start
    If !fstat
      [L]LBEGAMT = [F:SLFP]ENDBASAMT
      [L]LBEGQTY = [F:SLFP]ENDBASQTY
      If [L]LBEGQTY<>0
        [L]LAVC  = [L]LBEGAMT/[L]LBEGQTY
      Endif

      # Get the end date of the previous.
      #If not in line with desired one, we need to fill the gap
      PREVPEREND = [F:SLFP]PEREND
    Endif

    Raz [F:SLFP]
    [F:SLFP]ITMREF    = PITM
    [F:SLFP]LOT       = PLOT
    [F:SLFP]SLO       = PSLO
    [F:SLFP]STOFCY    = PFCY
    [F:SLFP]VLTNUM    = PVLTNUM
    [F:SLFP]PERSTR    = [F:PER]PERSTR
    [F:SLFP]PEREND    = [F:PER]PEREND
    [F:SLFP]FIYNUM    = LEXE
    [F:SLFP]PERNUM    = LPER
    [F:SLFP]BEGBASAMT = [L]LBEGAMT
    [F:SLFP]BEGBASQTY = [L]LBEGQTY
    [F:SLFP]BEGAVC    = [L]LAVC
    # At this point - no transcations, so Beg = End
    [F:SLFP]ENDBASAMT = [L]LBEGAMT
    [F:SLFP]ENDBASQTY = [L]LBEGQTY
    [F:SLFP]ENDAVC    = [L]LAVC

    Call ECRPIT('SLFP',PRET)
    If PRET
      If LTRBEGIN : Rollback : Endif
    Else
      If LTRBEGIN : Commit : Endif
    Endif
Return

####################################################################
# Create beginning balances for ALC when changing valuation method
####################################################################
Subprog SLFPBEGBAL(PITM, PFCY, PVLTNUM)
Value Char    PITM
Value Char    PFCY
Value Integer PVLTNUM

Local Integer LFIY, LPER, LRET

  Local File STOLOTFCYPIT [SLFP]
  Local File STOLOTFCY    [SLF]
  Local File PERIOD       [PER]

  Call GETPERIOD(PFCY, 1, date$, LFIY, LPER) From CPTSUB

  # Loop through the current SLF records for this Product/site combo
  Filter [SLF] Where ITMREF=PITM & STOFCY = PFCY
  For [SLF]
    If [F:SLF]AVCBASAMT = 0 & [F:SLF]AVCBASQTY = 0 : Goto NEXTLOT : Endif

    Read [SLFP]SLFP0=PITM;[F:SLF]LOT;[F:SLF]SLO;PFCY;[F:PER]PERSTR;PVLTNUM
    If !fstat : Goto NEXTLOT : Endif

    Raz [F:SLFP]

    [F:SLFP]ITMREF    = PITM
    [F:SLFP]STOFCY    = PFCY
    [F:SLFP]LOT       = [F:SLF]LOT
    [F:SLFP]SLO       = [F:SLF]SLO
    [F:SLFP]VLTNUM     = PVLTNUM

    [F:SLFP]BEGBASAMT = [F:SLF]AVCBASAMT
    [F:SLFP]BEGBASQTY = [F:SLF]AVCBASQTY
    [F:SLFP]BEGAVC    = [F:SLF]AVC
    # At this point - no transcations, so Beg = End
    [F:SLFP]ENDBASAMT = [F:SLF]AVCBASAMT
    [F:SLFP]ENDBASQTY = [F:SLF]AVCBASQTY
    [F:SLFP]ENDAVC    = [F:SLF]AVC

    [F:SLFP]PERSTR    = [F:PER]PERSTR
    [F:SLFP]PEREND    = [F:PER]PEREND
    [F:SLFP]FIYNUM    = LFIY
    [F:SLFP]PERNUM    = LPER

    Call ECRPIT('SLFP',LRET)
    $NEXTLOT
  Next
  Filter [SLF]

End

########################################################################
# REG_FIFO      Register the PIT updates for FIFO valuation
########################################################################
# Parameters :  PMVTTYP = Movement Type (1 = Receipt, 2 = Issue, 3 = Misc)
#            :  PVLTNUM = Is this the first or second valuation method?
#            :  PRET = 1 if a record was created
########################################################################
Subprog REG_FIFO (PMVTTYP,PVLTNUM,PRET)
Value     Integer PMVTTYP
Value     Integer PVLTNUM
Variable  Integer PRET

Local Integer LRET
Local Decimal ENDQTY, ENDAMT, LCSTCOU, LCST, LQTY
Local Char    LERR(250), LTIM(6), CRIT(255)
Local Date    LDAT
Local Date    PITDATE

  # For Put-away plan transactions, nothing to process
  If [F:STJ]TRSTYP = 22 : End : Endif

  If !clalev([F:STPP]) : Local File STOCOSTPIT [STPP] : Endif
  If !clalev([F:STJ2]) : Local File STOJOU     [STJ2] : Endif
  If !clalev([F:SMC2]) : Local File STOMVTCOST [SMC2] : Endif

  # X3-58152 - 2017-11-06 MJH deleting a receipt creates SCM records that need to be placed correctly
#  If PMVTTYP = 2 or (PMVTTYP = 4 and [F:STJ]QTYSTU<0)
  If PMVTTYP = 2 or (find(PMVTTYP,1,4) and [F:STJ]QTYSTU<0) #Issues

    #We are summing the entire STOMVTCOST table to get the cost per tier
    # so it is not necessary to calculate it for all records, only when
    # REGFLG = 1
    If [F:STJ]REGFLG <> 1 and PMVTTYP = 2
      End
    Endif

    #We need to look at all CSTCOU for the document in case the issue comes
    # from multiple tiers
    If !clalev([F:SMC])  : Local File STOMVTCOST [SMC]  : Endif
    If !clalev([F:SMC2]) : Local File STOMVTCOST [SMC2] : Endif
    #We need to look at all CSTCOU for the document
    Filter [F:SMC] Where VCRNUM = [F:STJ]VCRNUM and  VCRTYP  = [F:STJ]VCRTYP and ITMREF = [F:STJ]ITMREF
    For [SMC]
      PMVTTYP = 2 # X3-58152.N - 2017-11-06 MJH we are treating these as issues even if they are receipts
      LCSTCOU = [SMC]CSTCOU
      LTIM    = [SMC]CSTTIM
      LDAT    = [SMC]CSTDAT
      Gosub REG_FIFO_MAIN
    Next
    Filter [F:SMC]
  Endif

  If PMVTTYP = 3  # Value change
    If !clalev([F:CGVD]): Local File CGVDET [CGVD]: Endif
    Filter [F:CGVD] Where CGVNUM = [F:STJ]VCRNUM and CGVTYP = 2
    For [CGVD]
      LCSTCOU = [F:CGVD]CSTCOU
      LTIM    = [F:CGVD]CSTTIM
      LDAT    = [F:CGVD]CSTDAT
      LQTY    = [F:CGVD]ACTQTY - [F:CGVD]ACTQTYORI
      LCST    = [F:CGVD]AMT - [F:CGVD]AMTORI
      Gosub REG_FIFO_MAIN
    Next
    Filter [F:CGVD]
  Elsif PMVTTYP <> 2 #Receipt
    LCSTCOU = [F:STJ]CSTCOU
    If PVLTNUM = 1
      LCST  = [F:STJ]VARVAL
    Else
      LCST  = [F:STJ]VARVAL2
    Endif
    LQTY    = [F:STJ]QTYSTU
    LTIM    = [F:STJ]CSTTIM
    LDAT    = [F:STJ]CSTDAT
    Gosub REG_FIFO_MAIN
  Endif

End

#Main calls
$REG_FIFO_MAIN

Local Decimal LCST2, LQTY2

  # Use ACCDAT if there is one, IPTDAT if not
  [L]PITDATE = [F:STJ]ACCDAT
  If [L]PITDATE=[0/0/0] : [L]PITDATE=[F:STJ]IPTDAT : Endif

  Call GETSTPP([F:STJ]ITMREF, [F:STJ]STOFCY, LDAT, [L]PITDATE, LTIM, LCSTCOU, PVLTNUM, 1, LRET)
  If LRET
    PRET=LRET
    LERR = "STOCOSTPIT"-mess(12,100,1)
    Call ECR_TRACE(LERR,1) From GESECRAN
    End
  Endif

# X3-58152 - 2017-10-06 MJH.so
#  If PMVTTYP = 2 or (PMVTTYP = 4 and [F:STJ]QTYSTU<0) #Issue
#    #Sum issues for this period to be stored
#    Local Char REQ(250) (15)
#    Local Char STJ(30)
#    Local Char SMC(30)
#    If dim(GDOS)>0 #If we are coming from the upgrade script we need this
#      STJ = GDOS+"STOJOU"
#      SMC = GDOS+"STOMVTCOST"
#    Else
#      STJ = "STOJOU"
#      SMC = "STOMVTCOST"
#    Endif
#
#    Raz REQ
#    REQ(0)  -= "SELECT " + SMC + ".VCRNUM_0 As VCR0, " + SMC + ".VCRLIN_0 As VCR1, " + SMC + ".CSTCOU_0 As COU0, sum(DISTINCT " + SMC + ".QTYSTU_0) As QTY0, sum(DISTINCT " + SMC + ".CST_0) As CST0"
#    REQ(1)  -= "From " + SMC + " JOIN " + STJ
#    REQ(2)  -= "ON "   + SMC + ".VCRNUM_0 = " + STJ + ".VCRNUM_0"
#    REQ(3)  -= "and " + SMC + ".VCRLIN_0 = " + STJ + ".VCRLIN_0"
#    REQ(4)  -= "and " + SMC + ".VCRTYP_0 = " + STJ + ".VCRTYP_0"
#    REQ(5)  -= "Where " + SMC + ".ITMREF_0 = '"+ [F:STJ]ITMREF +"'"
#    REQ(6)  -= "and " + SMC + ".STOFCY_0 = '"+ [F:STJ]STOFCY +"'"
#    REQ(7)  -= "and " + SMC + ".CSTCOU_0 = " + num$(LCSTCOU)
#    REQ(8)  -= "and REGFLG_0 = 1"
#    Case GTYPDBA
#      When 1
#        REQ(9)-= "AND IPTDAT_0 <= "+ "TO_DATE('"+format$("D:DD[/]MM[/]YYYY",[F:STPP]PEREND)+"','DD/MM/YYYY')"
#        REQ(10)-= "AND IPTDAT_0 >= "+ "TO_DATE('"+format$("D:DD[/]MM[/]YYYY",[F:STPP]PERSTR)+"','DD/MM/YYYY')"
#      When 2
#        REQ(9)-= "AND IPTDAT_0 <= "+"CONVERT(datetime,'"+format$("D:YYYYMMDD",[F:STPP]PEREND)+"',112)"
#        REQ(10)-= "AND IPTDAT_0 >= "+"CONVERT(datetime,'"+format$("D:YYYYMMDD",[F:STPP]PERSTR)+"',112)"
#    Endcase
#    #MJH
#    REQ(11)  -= "GROUP By " + SMC + ".VCRNUM_0, " + SMC + ".VCRLIN_0, " + SMC + ".CSTCOU_0"
#
#    Raz LQTY,LCST
#    For (Char VCR0, Integer VCR1, Decimal COU0, Decimal QTY0, Decimal CST0) From num$(GTYPDBA*2+1) Sql REQ As [SQLW]
#      LQTY -= [SQLW]QTY0
#      LCST -= [SQLW]CST0
#    Next
#  Endif
# X3-58152 - 2017-10-06 MJH.eo

# X3-58152 - 2017-10-06 MJH.sn
  If PMVTTYP = 2
    Local Char VCRLIST(GLONVCR) (255), VCRNEXT(GLONVCR)
    Local Integer COUNTER, CONTINUE
    CONTINUE = 1

    While CONTINUE = 1
      #Get list of all VCRNUMs in that period
      Raz COUNTER, VCRLIST

      CRIT =  'STOFCY = [F:STJ]STOFCY & ITMREF = [F:STJ]ITMREF'
      CRIT -= ' & ((ACCDAT<>[0/0/0] & ACCDAT <= [F:STPP]PEREND & ACCDAT >= [F:STPP]PERSTR)'
      CRIT -= '| (ACCDAT=[0/0/0] & IPTDAT <= [F:STPP]PEREND & IPTDAT >= [F:STPP]PERSTR))'
      Filter [STJ2] Where evalue(CRIT)
      For [STJ2] Where VCRNUM > VCRNEXT
        If !find([STJ2]VCRNUM,VCRLIST)
          VCRLIST(COUNTER) = [STJ2]VCRNUM
          COUNTER +=1
          If COUNTER = 255#Our list is at max capacity
            VCRNEXT = [STJ2]VCRNUM
            Break
          Endif
        Endif
      Next

      #Sum all QTY and AMT that are in that list for the current CSTCOU
      For [F:SMC2] Where find(VCRNUM,VCRLIST) and CSTCOU = LCSTCOU
        LQTY2 -= [F:SMC2]QTYSTU
        LCST2 -= [F:SMC2]CST
      Next

      #If our list was not at max, we have finished
      If COUNTER < 255
        CONTINUE = 0
      Endif
    Wend
    Filter [STJ2]
  Endif
  # X3-58152 - 2017-10-06 MJH.en

  #We store the value for issues because it is already the sum for the tier/period
  Case PMVTTYP
    When 1        # Receipt
      [F:STPP]PERRCPQTY += LQTY
      [F:STPP]PERRCPCST += LCST
    When 2        # Issue
      [F:STPP]PERISSQTY  = LQTY2
      [F:STPP]PERISSCST  = LCST2
    When 3        # Value change
      [F:STPP]PERVALCHGQTY  += LQTY
      [F:STPP]PERVALCHG     += LCST
    When Default  # Misc - base the movement type on the sign
      If [F:STJ]QTYSTU>=0
        [F:STPP]PERRCPQTY += LQTY
        [F:STPP]PERRCPCST += LCST
      Else
        [F:STPP]PERISSQTY  = LQTY2
        [F:STPP]PERISSCST  = LCST2
      Endif
  Endcase

  # Sum up AMTDEV for the period
  If PVLTNUM = 1
    [F:STPP]PERAMTDEV += [F:STJ]AMTDEV
  Else
    [F:STPP]PERAMTDEV += [F:STJ]AMTDEV2
  Endif

  # Update the period cumulative and end balances

  [F:STPP]PERCUMQTY = [F:STPP]PERRCPQTY + [F:STPP]PERISSQTY + [F:STPP]PERVALCHGQTY
  [F:STPP]PERCUMCST = [F:STPP]PERRCPCST + [F:STPP]PERISSCST + [F:STPP]PERVALCHG
  If [F:STJ]TRSTYP = 35
    [F:STPP]PERCUMCST += [F:STPP]PERAMTDEV
  Endif

  [F:STPP]PERENDQTY = [F:STPP]PERBEGQTY + [F:STPP]PERCUMQTY
  [F:STPP]PERENDCST = [F:STPP]PERBEGCST + [F:STPP]PERCUMCST

  Call REWPIT('STPP',LRET)

  If LRET
    PRET=LRET
    LERR = "STOCOSTPIT"-mess(12,100,1)
    Call ECR_TRACE(LERR,1) From GESECRAN
    End
  Endif

  # Save off the end balance for updating future periods
  ENDQTY = [F:STPP]PERENDQTY
  ENDAMT = [F:STPP]PERENDCST

  # Check if any future periods exist and need their balances updated.
  Filter [STPP] Where ITMREF = [F:STJ]ITMREF & STOFCY = [F:STJ]STOFCY & PERSTR > [L]PITDATE & CSTCOU = LCSTCOU & VLTNUM = PVLTNUM
  For [STPP]STPP0
    [F:STPP]PERBEGQTY = ENDQTY
    [F:STPP]PERBEGCST = ENDAMT

    [F:STPP]PERENDQTY = [F:STPP]PERBEGQTY + [F:STPP]PERCUMQTY
    [F:STPP]PERENDCST = [F:STPP]PERBEGCST + [F:STPP]PERCUMCST

    Call REWPIT('STPP',LRET)
    If LRET
      PRET=LRET
      LERR = "STOCOSTPIT"-mess(12,100,1)
      Call ECR_TRACE(LERR,1) From GESECRAN
      End
    Endif

    # Save off the end balance for updating future periods
    ENDQTY = [F:STPP]PERENDQTY
    ENDAMT = [F:STPP]PERENDCST

  Next
  Filter [STPP]

Return

########################################################################
# GETSTPP       Lookup or create the PIT record for FIFO valuation
########################################################################
# Parameters :  PITM = Product
#               PFCY = Site
#               PDAT = Transaction date
#               PTIM = Transaction time
#               PCOU = FIFO tier
#               PLOK = 0 -> Read
#                      1 -> readlock
########################################################################
Subprog GETSTPP(PITM,PFCY,PDAT,PPERDAT,PTIM,PCOU,PVLTNUM,PLOK,PRET)
Value    Char    PITM
Value    Char    PFCY
Value    Date    PDAT
Value    Date    PPERDAT
Value    Char    PTIM
Value    Decimal PCOU
Value    Integer PVLTNUM
Value    Integer PLOK
Variable Integer PRET

If !clalev([F:PER]) : Local File PERIOD [PER] : Endif

Local Decimal LBEGAMT,LBEGQTY,LAVC
Local Decimal LEXE, LPER
Local Integer LTRBEGIN
Local Date    PREVPEREND,CURPERSTR
Raz LEXE, LPER

  Call OPEN_PERIOD(PFCY,PPERDAT,LEXE,LPER)

  # Save the Period start we used for locking this record later
  CURPERSTR = [F:PER]PERSTR

  # Check to see if this record exists or if we need to create
  Look [STPP]STPP0=PITM;PFCY;PDAT;PTIM;PCOU;CURPERSTR;PVLTNUM
  If find(fstat,4,5)

    Gosub CRESTPP
    If PRET : End : Endif

    # Check to see if we need to fill in the gap between old and current
    If PREVPEREND <> [0/0/0]
      While CURPERSTR - PREVPEREND > 1
        # Look for the next period from the original
        PREVPEREND += 1
        Call OPEN_PERIOD(PFCY,PREVPEREND,LEXE,LPER)
        Gosub CRESTPP
        If PRET : End : Endif
        PREVPEREND = [STPP]PEREND
      Wend
    Endif

  Endif

  # Record(s) have been created.  So now read or lock the wanted record
  If !PLOK
    Read [STPP]STPP0=PITM;PFCY;PDAT;PTIM;PCOU;CURPERSTR;PVLTNUM
  Else
    Readlock [STPP]STPP0=PITM;PFCY;PDAT;PTIM;PCOU;CURPERSTR;PVLTNUM
  Endif

End

#Create record for FIFO
$CRESTPP
    If adxlog=0
        Trbegin [STPP]
        LTRBEGIN=1
    Else
        LTRBEGIN=0
    Endif

    # Look for the previous record so we can set the beginning balances
    Filter [STPP] Where ITMREF  = PITM
&                     & STOFCY  = PFCY
&                     & CSTDAT  = PDAT
&                     & CSTTIM  = PTIM
&                     & CSTCOU  = PCOU
&                     & PERSTR < [F:PER]PERSTR
&                     & VLTNUM  = PVLTNUM
    Read [STPP] STPP0 Last

    Filter [STPP]
    # Record found - save off the end info for new start
    If !fstat
      [L]LBEGAMT = [F:STPP]PERENDCST
      [L]LBEGQTY = [F:STPP]PERENDQTY

      # Get the end date of the previous.
      #If not in line with desired one, we need to fill the gap
      PREVPEREND = [F:STPP]PEREND
    Endif

    Raz [F:STPP]

    [F:STPP]ITMREF    = PITM
    [F:STPP]STOFCY    = PFCY
    [F:STPP]CSTDAT    = PDAT
    [F:STPP]CSTTIM    = PTIM
    [F:STPP]CSTCOU    = PCOU
    [F:STPP]VLTNUM    = PVLTNUM
    [F:STPP]PERSTR    = [F:PER]PERSTR
    [F:STPP]PEREND    = [F:PER]PEREND
    [F:STPP]FIYNUM    = LEXE
    [F:STPP]PERNUM    = LPER
    [F:STPP]PERBEGCST = [L]LBEGAMT
    [F:STPP]PERBEGQTY = [L]LBEGQTY

    # At this point - no transcations, so Beg = End
    [F:STPP]PERENDCST = [L]LBEGAMT
    [F:STPP]PERENDQTY = [L]LBEGQTY

    Call ECRPIT('STPP',PRET)
    If PRET
      If LTRBEGIN : Rollback : Endif
    Else
      If LTRBEGIN : Commit : Endif
    Endif
Return

####################################################################
# Create beginning balances for FIFO/LIFO when changing valuation method
####################################################################
Subprog STPPBEGBAL(PITM, PFCY, PVLTNUM)
Value Char    PITM
Value Char    PFCY
Value Integer PVLTNUM

Local Integer LFIY, LPER, LRET

  Local File STOCOSTPIT [STPP]
  Local File STOCOST    [STP]
  Local File PERIOD     [PER]

  Call GETPERIOD(PFCY, 1, date$, LFIY, LPER) From CPTSUB

  # Loop through the current SLF records for this Product/site combo
  Filter [STP] Where ITMREF=PITM & STOFCY=PFCY
  For [STP]
    If [F:STP]QTYSTUACT = 0 & [F:STP]CST = 0 : Goto NEXTTIER : Endif

    Read [STPP]STPP0=PITM;PFCY;[F:STP]CSTDAT;[F:STP]CSTTIM;[F:STP]CSTCOU;[F:PER]PERSTR;PVLTNUM
    If !fstat : Goto NEXTTIER : Endif

    Raz [F:STPP]

    [F:STPP]ITMREF    = PITM
    [F:STPP]STOFCY    = PFCY
    [F:STPP]CSTDAT    = [F:STP]CSTDAT
    [F:STPP]CSTTIM    = [F:STP]CSTTIM
    [F:STPP]CSTCOU    = [F:STP]CSTCOU
    [F:STPP]VLTNUM     = PVLTNUM

    [F:STPP]PERSTR    = [F:PER]PERSTR
    [F:STPP]PEREND    = [F:PER]PEREND
    [F:STPP]FIYNUM    = LFIY
    [F:STPP]PERNUM    = LPER

    [F:STPP]PERBEGCST = [F:STP]CST
    [F:STPP]PERBEGQTY = [F:STP]QTYSTUACT
    # At this point - no transcations, so Beg = End
    [F:STPP]PERENDCST = [F:STP]CST
    [F:STPP]PERENDQTY = [F:STP]QTYSTUACT


    Call ECRPIT('STPP',LRET)
    $NEXTTIER
  Next
  Filter [STP]

End

########################################################################
# REG_STD       Register the PIT updates for Standard Cost valuation
########################################################################
# Parameters :  PMVTTYP = Movement Type (1 = Receipt, 2 = Issue, 3 = Misc)
#               PVLTNUM = Is this the first or second valuation method?
#            :  PRET    = 0, success
#
########################################################################
Subprog REG_STD (PMVTTYP, PVLTNUM, PRET)
Value     Integer PMVTTYP
Value     Integer PVLTNUM
Variable  Integer PRET


Local Integer LRET
Local Decimal ENDQTY, ENDAMT, AMTDEV, VARVAL
Local Char    LERR(250)
Local Char    LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
Local Date    PITDATE

  # For Put-away plan transactions, nothing to process
  If [F:STJ]TRSTYP = 22 : End : Endif

  If !clalev([F:ITCP]) : Local File ITMCOSTPIT  [ITCP] : Endif
  If !clalev([F:ITC])  : Local File ITMCOST     [ITC]  : Endif
  If !clalev([F:PER])  : Local File PERIOD      [PER]  : Endif

  If dim([F:STJ]ECCVALMAJ)>0
    LECCMAJ=[F:STJ]ECCVALMAJ
    LECCMIN=[F:STJ]ECCVALMIN
  Endif

  # Read the correct standard cost record
  Call GET_STD_COST([F:STJ]ITMREF, [F:STJ]STOFCY, [F:STJ]IPTDAT, LECCMAJ, LECCMIN, [F:TCM]ISSVLTCOD(PVLTNUM-1))

  # Use ACCDAT if there is one, IPTDAT if not
  [L]PITDATE = [F:STJ]ACCDAT
  If [L]PITDATE=[0/0/0] : [L]PITDATE=[F:STJ]IPTDAT : Endif

  Call GETITCP([F:STJ]ITMREF, [F:STJ]STOFCY, LECCMAJ, LECCMIN, [L]PITDATE, 1, PVLTNUM, LRET)
  If LRET
    PRET=LRET
    LERR = "ITMCOSTPIT"-mess(12,100,1)
    Call ECR_TRACE(LERR,1) From GESECRAN
    End
  Endif

  If PVLTNUM = 1
    [L]AMTDEV = [F:STJ]AMTDEV
    [L]VARVAL = [F:STJ]VARVAL
  Else
    [L]AMTDEV = [F:STJ]AMTDEV2
    [L]VARVAL = [F:STJ]VARVAL2
  Endif

  Case PMVTTYP
    When 1        # Receipt
      [F:ITCP]PERRCPQTY += [F:STJ]QTYSTU
      [F:ITCP]PERRCPCST += [L]VARVAL
    When 2        # Issue
      [F:ITCP]PERISSQTY += [F:STJ]QTYSTU
      [F:ITCP]PERISSCST += [L]VARVAL
    When 3
      [F:ITCP]PERVALCHG += [L]VARVAL
    When Default  # Misc - base the movement type on the sign
      If [F:STJ]QTYSTU>0
        [F:ITCP]PERRCPQTY += [F:STJ]QTYSTU
        [F:ITCP]PERRCPCST += [L]VARVAL
      Else
        [F:ITCP]PERISSQTY += [F:STJ]QTYSTU
        [F:ITCP]PERISSCST += [L]VARVAL
      Endif
  Endcase

  # Sum up AMTDEV for the period.
  [F:ITCP]PERAMTDEV += [L]AMTDEV

  # Update the period cumulative and end balances
  [F:ITCP]PERCUMQTY += [F:STJ]QTYSTU
  [F:ITCP]PERCUMCST += [L]VARVAL
  [F:ITCP]PERENDQTY += [F:STJ]QTYSTU
  [F:ITCP]PERENDCST += [L]VARVAL

  Call REWPIT('ITCP',LRET)
  If LRET
    PRET=LRET
    LERR = "ITMCOSTPIT"-mess(12,100,1)
    Call ECR_TRACE(LERR,1) From GESECRAN
    End
  Endif

  # Save off the end balance for updating future periods
  ENDQTY = [F:ITCP]PERENDQTY
  ENDAMT = [F:ITCP]PERENDCST

  Local Decimal LEXE, LPER
  Call OPEN_PERIOD([F:STJ]STOFCY,[L]PITDATE,LEXE,LPER)#X3-64009 MJH.n We need to have [PER] on the correct record


  #X3-64009 MJH.n
  #We need CSTCHGDAT to be within the current period for it to be relevant
  # Check if any future periods exist and need their balances updated.
  Filter [ITCP] Where ITMREF    = [F:STJ]ITMREF
&                   & STOFCY    = [F:STJ]STOFCY
&                   & ECCVALMAJ = LECCMAJ
&                   & ECCVALMIN = LECCMIN
&                   & PERSTR > [L]PITDATE
&                   & VLTNUM    = PVLTNUM
  For [ITCP]ITCP0
    [F:ITCP]PERBEGQTY = ENDQTY
    [F:ITCP]PERBEGCST = ENDAMT

    [F:ITCP]PERENDQTY = [F:ITCP]PERBEGQTY + [F:ITCP]PERCUMQTY
    [F:ITCP]PERENDCST = [F:ITCP]PERBEGCST + [F:ITCP]PERCUMCST

    Call REWPIT('ITCP',LRET)
    If LRET
      PRET=LRET
      LERR = "ITMCOSTPIT"-mess(12,100,1)
      Call ECR_TRACE(LERR,1) From GESECRAN
      End
    Endif

    # Save off the end balance for updating future periods
    ENDQTY = [F:ITCP]PERENDQTY
    ENDAMT = [F:ITCP]PERENDCST

  Next
  Filter [ITCP]

End

########################################################################
# GETITCP       Lookup or create the PIT record for Standard Cost
########################################################################
# Parameters :  PITM    = Product
#               PFCY    = Site
#               PECCMAJ = Major version
#               PECCMIN = Minor version
#               PDAT    = Transaction date
#               PCHGDAT = Cost Change Date
#               PLOK    = 0 -> Read
#                         1 -> readlock
#               PECC    = Use Versions
#               PECCMAJ = Major Version
#               PECCMIN = Minor Version
########################################################################
Subprog GETITCP(PITM,PFCY,PECCMAJ,PECCMIN,PDAT,PLOK,PVLTNUM,PRET)
Value    Char    PITM
Value    Char    PFCY
Value    Char    PECCMAJ
Value    Char    PECCMIN
Value    Date    PDAT
Value    Integer PLOK
Value    Integer PVLTNUM
Variable Integer PRET

If !clalev([F:PER]) : Local File PERIOD [PER] : Endif

Local Decimal LBEGCST,LBEGQTY,LAMTDEV
Local Decimal LEXE, LPER, LSTDCST
Local Integer LTRBEGIN
Local Date    CURPERSTR,CURPEREND,PREVPEREND, LITCSTRDAT
#LITCSTRDAT = [F:ITC]ITCSTRDAT


  Raz LEXE, LPER

  Call OPEN_PERIOD(PFCY,PDAT,LEXE,LPER)

  # Save the Period start we used for locking this record later
  CURPERSTR = [F:PER]PERSTR
  CURPEREND = [F:PER]PEREND

  # Check to see if this record exists or if we need to create
  # Issue 84265 - 2018-03-26 by ERMIL : Temp fix for removing key field - to be removed soon
  #Look [ITCP]ITCP0=PITM;PFCY;PECCMAJ;PECCMIN;CURPERSTR;[F:TCM]ISSVLTCOD(PVLTNUM-1);PVLTNUM
  Look [ITCP]ITCP0=PITM;PFCY;PECCMAJ;PECCMIN;CURPERSTR;CURPERSTR;[F:TCM]ISSVLTCOD(PVLTNUM-1);PVLTNUM
  If find(fstat,4,5)

    Gosub CREITCP
    If PRET : End : Endif

    # Check to see if we need to fill in the gap between old and current
    If PREVPEREND <> [0/0/0]
      INDEX = 0
      While CURPERSTR - PREVPEREND > 1
        # Look for the next period from the original
        PREVPEREND += 1
        Call OPEN_PERIOD(PFCY,PREVPEREND,LEXE,LPER)
        Call GET_STD_COST(PITM, PFCY, PREVPEREND, PECCMAJ, PECCMIN, [F:TCM]ISSVLTCOD(PVLTNUM-1))

        Gosub CREITCP
        If PRET : End : Endif
        PREVPEREND = [F:ITCP]PEREND
      Wend
    Else
      # This record is the beginning period for this key combo
      # Did back dating cause a gap between this and the previous oldest?
      Filter [ITCP] Where ITMREF=PITM & STOFCY=PFCY & ECCVALMAJ=PECCMAJ & ECCVALMIN=PECCMIN & PERSTR>CURPEREND & CSTTYP = [F:TCM]ISSVLTCOD(PVLTNUM-1) & VLTNUM = PVLTNUM
      Read [ITCP] ITCP0 First
      Filter [ITCP]
      While [F:ITCP]PERSTR - CURPEREND > 1

        CURPEREND += 1

        Call OPEN_PERIOD(PFCY,CURPEREND,LEXE,LPER)
				Call GET_STD_COST(PITM, PFCY, CURPEREND, PECCMAJ, PECCMIN, [F:TCM]ISSVLTCOD(PVLTNUM-1))

        Gosub CREITCP
        If PRET : End : Endif

        CURPEREND = [F:PER]PEREND

        Filter [ITCP] Where ITMREF=PITM & STOFCY=PFCY & ECCVALMAJ=PECCMAJ & ECCVALMIN=PECCMIN & PERSTR>CURPEREND & CSTTYP = [F:TCM]ISSVLTCOD(PVLTNUM-1) & VLTNUM = PVLTNUM
        Read [ITCP] ITCP0 First
        Filter [ITCP]

      Wend
    Endif

  Endif

  # Record(s) have been created.  So now read or lock the wanted record
  If !PLOK
# Issue 84265 - 2018-03-26 by ERMIL : Temp fix for removing key field - to be removed soon
#    Read [ITCP]ITCP0=PITM;PFCY;PECCMAJ;PECCMIN;CURPERSTR;[F:TCM]ISSVLTCOD(PVLTNUM-1);PVLTNUM
    Read [ITCP]ITCP0=PITM;PFCY;PECCMAJ;PECCMIN;CURPERSTR;CURPERSTR;[F:TCM]ISSVLTCOD(PVLTNUM-1);PVLTNUM
  Else
# Issue 84265 - 2018-03-26 by ERMIL : Temp fix for removing key field - to be removed soon
#    Readlock [ITCP]ITCP0=PITM;PFCY;PECCMAJ;PECCMIN;CURPERSTR;[F:TCM]ISSVLTCOD(PVLTNUM-1);PVLTNUM
    Readlock [ITCP]ITCP0=PITM;PFCY;PECCMAJ;PECCMIN;CURPERSTR;CURPERSTR;[F:TCM]ISSVLTCOD(PVLTNUM-1);PVLTNUM
  Endif

End

##############################################################
# Populate all the needed data for a new record in ITMCOSTPIT
##############################################################
$CREITCP
  Local Integer LSEQ

  If adxlog=0
      Trbegin [ITCP]
      LTRBEGIN=1
  Else
      LTRBEGIN=0
  Endif

  # Look for the previous record so we can set the beginning balances
  Filter [ITCP] Where ITMREF    = PITM
&                   & STOFCY    = PFCY
&                   & ECCVALMAJ = PECCMAJ
&                   & ECCVALMIN = PECCMIN
&                   & PERSTR < [F:PER]PERSTR
&                   & CSTTYP    = [F:TCM]ISSVLTCOD(PVLTNUM-1)
&                   & VLTNUM    = PVLTNUM
  Read [ITCP] ITCP0 Last
  Filter [ITCP]

  # Record found - save off the end info for new start
  If !fstat
    [L]LBEGCST = [F:ITCP]PERENDCST
    [L]LBEGQTY = [F:ITCP]PERENDQTY
    # Get the end date of the previous.
    #If not in line with desired one, we need to fill the gap
    PREVPEREND = [F:ITCP]PEREND
  Endif

  Raz [F:ITCP]
  [F:ITCP]ITMREF    = PITM
  [F:ITCP]STOFCY    = PFCY
  # Issue 84265 - 2018-03-26 by ERMIL : Restore key to original state
  #[F:ITCP]CSTCHGDAT = [F:ITC]ITCSTRDAT
  [F:ITCP]CSTCHGDAT = [F:PER]PERSTR
  [F:ITCP]ECCVALMAJ = PECCMAJ
  [F:ITCP]ECCVALMIN = PECCMIN
  [F:ITCP]VLTNUM    = PVLTNUM
  [F:ITCP]PERSTR    = [F:PER]PERSTR
  [F:ITCP]PEREND    = [F:PER]PEREND
  [F:ITCP]STDCST    = [F:ITC]CSTTOT
  [F:ITCP]FIYNUM    = LEXE
  [F:ITCP]PERNUM    = LPER
  [F:ITCP]PERBEGCST = [L]LBEGCST
  [F:ITCP]PERBEGQTY = [L]LBEGQTY
  # At this point - no transcations, so Beg = End
  [F:ITCP]PERENDCST = [L]LBEGCST
  [F:ITCP]PERENDQTY = [L]LBEGQTY
  [F:ITCP]CSTTYP    = [F:TCM]ISSVLTCOD(PVLTNUM-1)

  Call ECRPIT('ITCP',PRET)
  If PRET
    If LTRBEGIN : Rollback : Endif
  Else
    If LTRBEGIN : Commit : Endif
  Endif
Return

####################################################################
# Create beginning balances for Standard cost when changing valuation method
####################################################################
Subprog ITCPBEGBAL(PITM, PFCY, PTYP, PVLTNUM)
Value Char    PITM
Value Char    PFCY
Value Integer PTYP
Value Integer PVLTNUM

Local Decimal LPRI, LQTY
Local Date    LDAT
Local Integer LFIY, LPER, LRET
Local Char    REQ(250)
Local Integer IREQ

  Local File ITMMASTER  [ITM]
  Local File ITMCOST    [ITC]
  Local File ITMCOSTPIT [ITCP]
  Local File ITMMVT     [ITV]
  Local File PERIOD     [PER]

  Call GETPERIOD(PFCY, 1, date$, LFIY, LPER) From CPTSUB

  Read [ITM]ITM0=PITM

  # Check if this product is using versioning
  If [F:ITM]ECCSTO = 1
    # Use ITMMVT table to get the current QTY on hand
    Read [ITV]ITV0=PITM;PFCY
    If !fstat
      LQTY = [F:ITV]AVCBASQTY
    Endif

    # If nothing on hand, no record to write, so exit
    If LQTY = 0 : End : Endif

    # Get the current standard cost
    Call GETPRISTD(PITM,"","",PFCY,date$,0,PTYP,LPRI,LRET) From STKVAL
    LDAT = [F:ITC]ITCSTRDAT
    If [F:ITC]ITCSTRDAT = [0/0/0] : LDAT = date$ : Endif

    # Make sure that this record does not already exist
# Issue 84265 - 2018-03-26 by ERMIL : Temp fix for removing key field - to be removed soon
#    Read [ITCP]ITCP0=PITM;PFCY;"";"";[F:PER]PERSTR;PTYP;PVLTNUM
    Read [ITCP]ITCP0=PITM;PFCY;"";"";[F:PER]PERSTR;[F:PER]PERSTR;PTYP;PVLTNUM
    If !fstat : End : Endif

    Raz [F:ITCP]
    [F:ITCP]ITMREF     = PITM
    [F:ITCP]STOFCY     = PFCY
# Issue 84265 - 2018-03-26 by ERMIL : Temp fix for removing key field - to be removed soon
#    [F:ITCP]CSTCHGDAT  = LDAT
    [F:ITCP]CSTCHGDAT  = [F:PER]PERSTR
    [F:ITCP]PERSTR     = [F:PER]PERSTR
    [F:ITCP]PEREND     = [F:PER]PEREND
    [F:ITCP]STDCST     = LPRI
    [F:ITCP]FIYNUM     = LFIY
    [F:ITCP]PERNUM     = LPER
    [F:ITCP]CSTTYP     = PTYP
    [F:ITCP]VLTNUM     = PVLTNUM

    [F:ITCP]PERBEGCST = [F:ITV]AVCBASQTY * LPRI
    [F:ITCP]PERBEGQTY = [F:ITV]AVCBASQTY
    # At this point - no transcations, so Beg = End
    [F:ITCP]PERENDCST = [F:ITV]AVCBASQTY * LPRI
    [F:ITCP]PERENDQTY = [F:ITV]AVCBASQTY

    Call ECRPIT('ITCP',LRET)
  Else
    Call ADDCRIT(REQ, IREQ, "", "SELECT ECCVALMAJ_0, ECCVALMIN_0, sum(ACTQTY_0) From STOJOU", " ") From GOBJSUB
    Call ADDCRIT(REQ, IREQ, "", "WHERE STOFCY_0='"+PFCY+"'", " ") From GOBJSUB
    Call ADDCRIT(REQ, IREQ, "",   "and ITMREF_0='"+PITM+"'", " ") From GOBJSUB
    Call ADDCRIT(REQ, IREQ, "", "GROUP BY ECCVALMAJ_0, ECCVALMIN_0", " ") From GOBJSUB
    For (Char ECCMAJ, Char ECCMIN, Decimal QTY) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
      If [F:SQLX]QTY <> 0
        # Get the current standard cost
        Call GETPRISTD(PITM,[F:SQLX]ECCMAJ,[F:SQLX]ECCMIN,PFCY,date$,0,PTYP,LPRI,LRET) From STKVAL
        LDAT = [F:ITC]ITCSTRDAT
        If [F:ITC]ITCSTRDAT = [0/0/0] : LDAT = date$ : Endif

        # If record does not already exist, go ahead and create
        # Issue 84265 - 2018-03-26 by ERMIL : Temp fix for removing key field - to be removed soon
        #Read [ITCP]ITCP0=PITM;PFCY;ECCMAJ;ECCMIN;[F:PER]PERSTR;PTYP
        Read [ITCP]ITCP0=PITM;PFCY;ECCMAJ;ECCMIN;[F:PER]PERSTR;[F:PER]PERSTR;PTYP
        If fstat

          Raz [F:ITCP]
          [F:ITCP]ITMREF    = PITM
          [F:ITCP]STOFCY    = PFCY
          # Issue 84265 - 2018-03-26 by ERMIL : Temp fix for removing key field - to be removed soon
          #[F:ITCP]CSTCHGDAT = LDAT
          [F:ITCP]CSTCHGDAT = [F:PER]PERSTR
          [F:ITCP]ECCVALMAJ = ECCMAJ
          [F:ITCP]ECCVALMIN = ECCMIN
          [F:ITCP]PERSTR    = [F:PER]PERSTR
          [F:ITCP]PEREND    = [F:PER]PEREND
          [F:ITCP]STDCST    = LPRI
          [F:ITCP]FIYNUM    = LFIY
          [F:ITCP]PERNUM    = LPER
          [F:ITCP]CSTTYP    = PTYP

          [F:ITCP]PERBEGCST = [F:SQLX]QTY * LPRI
          [F:ITCP]PERBEGQTY = [F:SQLX]QTY
          # At this point - no transcations, so Beg = End
          [F:ITCP]PERENDCST = [F:SQLX]QTY * LPRI
          [F:ITCP]PERENDQTY = [F:SQLX]QTY

          Call ECRPIT('ITCP',LRET)
        Endif
      Endif
    Next
  Endif
End

Subprog GET_STD_COST(PITM, PFCY, PDAT, PECCMAJ, PECCMIN, PTYP)
Value Char    PITM
Value Char    PFCY
Value Date    PDAT
Value Char    PECCMAJ
Value Char    PECCMIN
Value Integer PTYP

  Local Char LCRITECC(255)

  LCRITECC = "1=1"
  If PECCMAJ <> "" : LCRITECC += " and ECCVALMAJ='"+PECCMAJ+"'" : Endif
  If PECCMIN <> "" : LCRITECC += " and ECCVALMIN='"+PECCMIN+"'" : Endif

  Filter [ITC] Where STOFCY=PFCY & ITMREF=PITM & CSTTYP=PTYP & ITCSTRDAT<=PDAT & PDAT<=ITCENDDAT & UID=0 & evalue(LCRITECC) Order By Key ITC0
  Read [ITC] First

  # If the standard cost is not found for the current year, try for the previous year
  If fstat
    Filter [ITC] Where STOFCY=PFCY & ITMREF=PITM & CSTTYP=PTYP & ITCSTRDAT<=PDAT & UID=0 & evalue(LCRITECC) Order By Key ITC2
    Read [ITC]ITC2 Last
    If fstat
      Raz [F:ITC]
    Endif
  Endif

  Filter [ITC]

End
########################################################################

Subprog OPEN_PERIOD(PFCY,PDAT,LEXE,LPER)
Value Char PFCY
Value Date PDAT
Variable Decimal LEXE
Variable Decimal LPER

  If dim(GDOS)>0 #If we are coming from the upgrade script
    Read [F:FCY]FCY0 = [F:STJ]STOFCY
    GSOCIETE = [F:FCY]LEGCPY
    Filter [F:PER]
    Filter [F:PER] Where CPY = [F:FCY]LEGCPY and PERSTR <= PDAT and PEREND >= PDAT and LEDTYP = 1
    Read [F:PER]PER0 Last
    LEXE = [F:PER]FIYNUM
    LPER = [F:PER]PERNUM
  Else
    Call GETSOC(PFCY) From DEVSUB
    Call GETPERSOC(GSOCIETE,GTYPGEN,PDAT,LEXE,LPER) From CPTSUB
  Endif

End

########################################################################
# ECRPIT        Write out a new record
########################################################################
# Parameters  : PABR = Table abbreviation
#             : PLOK = 0 - OK, 1 - error writing record
########################################################################
Subprog ECRPIT(PABR, PRET)
Value     Char    PABR
Variable  Integer PRET

  #GPOINT = "BEFWRIITVP"
  #Gosub ENTREE From EXEFNC

  Case PABR
    When 'ITVP' : Write [ITVP]
    When 'SLFP' : Write [SLFP]
    When 'STPP' : Write [STPP]
    When 'ITCP' : Write [ITCP]
  Endcase
  If fstat : PRET=1 : Endif
End

########################################################################
# REWPIT        Re-Write an existing record
########################################################################
# Parameters  : PABR = Table abbreviation
#             : PLOK = 0 - OK, 1 - error writing record
########################################################################
Subprog REWPIT(PABR, PRET)
Value     Char    PABR
Variable  Integer PRET

  #GPOINT = "BEFREWITVP"
  #Gosub ENTREE From EXEFNC

  Case PABR
    When 'ITVP' : Rewrite [ITVP] : Unlock [ITVP]
    When 'SLFP' : Rewrite [SLFP] : Unlock [SLFP]
    When 'STPP' : Rewrite [STPP] : Unlock [STPP]
    When 'ITCP' : Rewrite [ITCP] : Unlock [ITCP]
  Endcase
  If fstat : PRET=1 : Endif

End

########################################################################
# VAL_METH_CHK  Mark if a valuation change has occurred
#               during a given date range
#               Used by PIT inqiry and valuation report
########################################################################
# Parameters  : LCHGDAT = Date array of VLTCOD change dates
#             : LPERSTR = Start date
#             : LPEREND = End date
########################################################################
Funprog VAL_METH_CHK(LCHGDAT, LPERSTR, LPEREND)
Value Datetime LCHGDAT()
Value Date LPERSTR
Value Date LPEREND

Local Char DATE_STR(10)
Local Date LDATE
DATE_STR = num$(LCHGDAT)

If DATE_STR = "0000-00-00" : End "" : Endif

  For I = 0 To dim(LCHGDAT)-1
    LDATE = gdat$(val(mid$(DATE_STR,9,2)),val(mid$(DATE_STR,6,2)),val(left$(DATE_STR,4)))
    If LDATE <= LPEREND and LDATE >= LPERSTR
      End '*'
    Endif
  Next

End ""

