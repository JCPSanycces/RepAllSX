#<AdxTL>@(#)5.0.0.0 $Revision$
#####################################################################################
#                                       Module Ventes - Janvier  2007               #
#                                                                                   #
#                 CONSULTATIONS GRAPHIQUES FACTURES                                 #
#                                                                                   #
#####################################################################################
#                                                                                   #
#                                                                                   #
#            Factures par période                                                   #
#            ----------------------                                                 #
# GACTION  : TRTGRHSIH1 : Sélections                                                #
#            (Fenêtre : DGRHSIH1)                                                   #
#            (Ecran   : SGRHSIH1 DIA)                                               #
#            VISUGRHSI1 : Montant HT                                                #
#            (Fenêtre : IGRHSIH1)                                                   #
#            (Ecran   : SGI1    SGI1)                                               #
#            (Param ABREV : Abrév du masque contenant les critères)                 #
#            (Param TYPCOD: Type de graphique (par catégorie=1 ou réglé=2)          #
#            (Param DATDEB: Date début)                                             #
#            (Param DATFIN: Date fin)                                               #
#                                                                                   #
#            Factures par représentant                                              #
#            -------------------------                                              #
# GACTION  : TRTGRHSIH3 : Sélections                                                #
#            (Fenêtre : DGRHSIH3)                                                   #
#            (Ecran   : SGRHSIH3 DIA)                                               #
#            VISUGRHSQ3 : Montant HT                                                #
#            (Fenêtre : IGRHSIH3)                                                   #
#            (Ecran   : SGI3    SGI3)                                               #
#            (Param ABREV : Abrév du masque contenant les critères)                 #
#            (Param TYPCOD: Type de graphique (par représentant=3)                  #
#            (Param DATDEB: Date début)                                             #
#            (Param DATFIN: Date fin)                                               #
#                                                                                   #
#            Palmarès Facture                                                       #
#            ------------------                                                     #
# GACTION  : TRTGRHSIH2 : Sélections                                                #
#            (Fenêtre : DGRHSIH2)                                                   #
#            (Ecran   : SGRHSIH2 DIA)                                               #
#            VISUGRHSI2 : Palmarès                                                  #
#            (Fenêtre : IGRHSIH2)                                                   #
#            (Ecran   : SGD2    SGD2)                                               #
#            (Param ABREV   : Abrév du masque contenant les critères)               #
#            (Param TYPTIERS: Type de graphique (palmarès clt=1,rep=2,payeur=3)     #
#            (Param DATDEB  : Date début)                                           #
#            (Param DATFIN  : Date fin)                                             #
#                                                                                   #
#                                                                                   #
#####################################################################################
# Prérequis VISUGRHSI1 et 2 : Le masque contenant les critères doit être ouvert     #
#####################################################################################
#####################################################################################
$ACTION
Case ACTION
    When "OUVRE"          :
        Case GACTION
            When "TRTGRHSIH1"  :  Gosub OUVRE_TRTGRHSIH
            When "TRTGRHSIH3"  :  Gosub OUVRE_TRTGRHSIH
            When "VISUGRHSI1"  :  Gosub OUVRE_VISUGRHSI1
            When "VISUGRHSI3"  :  Gosub OUVRE_VISUGRHSI1
            When "TRTGRHSIH2"  :  Gosub OUVRE_TRTGRHSIH
            When "VISUGRHSI2"  :  Gosub OUVRE_VISUGRHSI2
        Endcase
    When "DEBUT"          :
        Case GACTION
            When "TRTGRHSIH1"  :  Gosub DEBUT_TRTGRHSIH1
            When "TRTGRHSIH3"  :  Gosub DEBUT_TRTGRHSIH1
            When "VISUGRHSI1"  :  Gosub DEBUT_VISUGRHSI1
            When "VISUGRHSI3"  :  Gosub DEBUT_VISUGRHSI1
            When "TRTGRHSIH2"  :  Gosub DEBUT_TRTGRHSIH2
            When "VISUGRHSI2"  :  Gosub DEBUT_VISUGRHSI2
        Endcase
    When "TITRE"
        Case GACTION
            When "VISUGRHSI1"  :  Gosub TIT_VISUGRHSI1
            When "VISUGRHSI2"  :  Gosub TIT_VISUGRHSI2
            When "VISUGRHSI3"  :  Gosub TIT_VISUGRHSI1
        Endcase
    When "SETBOUT"          :
        Case GACTION
            When "TRTGRHSIH2"  :  Gosub SETB_TRTGRHSIH2
        Endcase
    When "BOUTON"
        Case GACTION
            When "TRTGRHSIH1"  :  Gosub BOUT_TRTGRHSIH
            When "TRTGRHSIH3"  :  Gosub BOUT_TRTGRHSIH
            When "TRTGRHSIH2"  :  Gosub BOUT_TRTGRHSIH
            When "VISUGRHSI1"  :  Gosub BOUT_VISUGRHSI1
            When "VISUGRHSI3"  :  Gosub BOUT_VISUGRHSI1
            When "VISUGRHSI2"  :  Gosub BOUT_VISUGRHSI2
        Endcase
    When "FIN"
        Case GACTION
            When "VISUGRHSI1"  :  Gosub FIN_VISUGRHSI1
            When "VISUGRHSI2"  :  Gosub FIN_VISUGRHSI2
            When "VISUGRHSI3"  :  Gosub FIN_VISUGRHSI1
        Endcase
    When "OK"
        Case GACTION
            When "TRTGRHSIH3"  :  Gosub OK_TRTGRHSIH
        Endcase
    When Default
Endcase
Return

###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION TRTGRHSIH1,TRTGRHSIH3            #
#                                TRTGRHSIH2                       #
#                                                                 #
###################################################################
###################################################################
$OUVRE_TRTGRHSIH

Gosub OUVRE

Return
###################################################################


###################################################################
$OUVRE

If clalev([F:SIH])=0 Local File SINVOICE   [SIH]  : Endif
If clalev([F:SIV])=0 Local File SINVOICEV  [SIV]  : Endif
If clalev([F:SID])=0 Local File SINVOICED  [SID]  : Endif
If clalev([F:SVF])=0 Local File SVCRFOOT   [SVF]  : Endif
If clalev([F:SVV])=0 Local File SVCRVAT    [SVV]  : Endif
If clalev([F:BPC])=0 Local File BPCUSTOMER [BPC]  : Endif
If clalev([F:CPY])=0 Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0 Local File FACILITY   [FCY]  : Endif
If clalev([F:TCU])=0 Local File TABCUR     [TCU]  : Endif
If clalev([F:PER])=0 Local File PERIOD     [PER]  : Endif
If clalev([F:ACN])=0 Local File ACONSULT   [ACN]  : Endif
If clalev([F:DUD])=0 Local File GACCDUDATE [DUD]  : Endif

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Local Integer INVCA_ON
Local Char    V_LEG(20)

[L]INVCA_ON = 0
If func AFNC.ACTIV("INVCA") = 1 : [L]INVCA_ON = 1 : Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

Return
###################################################################
$DEBUT

[M]SALFCY=GFCYDEF(5)
If [M]SALFCY <> "" : # Parametre Site
    If [F:FCY]FCY <> [M]SALFCY  Read [F:FCY]FCY0 = [M]SALFCY
                                If fstat Raz [F:FCY], [M]SALFCY Endif
    Endif
    If GUSRFCY(1)="\" | find([M]SALFCY,GUSRFCY(1..GNBAUZ))
        If [M]SALFCY <> ""
             Call GETDEV([M]SALFCY) From DEVSUB
             [M]CPY  = GSOCIETE
        Endif
    Endif
Endif

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Raz [L]V_LEG
Call GETLEG([M:DIA]CPY,"",[L]V_LEG) From TRTLECLEG

If func AFNC.ACTIV("INVCA") = 1
  If func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
    Chgfmt [M:DIA]INVCANCAT With "LA:1"
    Chgfmt [M:DIA]INVCANSTA With "LA:1"
  Else
    Chgfmt [M:DIA]INVCANCAT With "-LA:1"
    Chgfmt [M:DIA]INVCANSTA With "-LA:1"
  Endif

  Affzo [M:DIA]INVCANCAT
  Affzo [M:DIA]INVCANSTA
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

Return
#####################################################################
#                                                                   #
#        TRAITEMENTS LIES ACTION TRTGRHSIH1 TRTGRHSIH3              #
#                                                                   #
#                    HT par catégorie ou réglé ou par représentant  #
#                                                                   #
#####################################################################
#####################################################################
$DEBUT_TRTGRHSIH1

Raz [M:DIA]

If dim([M]PERCOD)>0
    [M]PERCOD=4         : # Init. de la périodicité au mois
    [M]PERNBR=3         : # Init. du nombre de période à 3
Endif

[M]INVDATFIN=eomonth(date$)
[M]INVDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))

[M:DIA]INVTYPFAC=2    :    # On prend les factures
[M:DIA]INVTYPAVO=2    :    # On prend les avoirs
[M:DIA]INVTYPPRF=1    :    # On ne prend pas les proformas

[M:DIA]INVSTAO=2      :    # On prend les factures et les avoirs validés
If val(PARAM(2))=2
    [M:DIA]INVSTAN=1  :    # HT réglé     : On ne prend que les factures et avoirs validées
Else
    [M:DIA]INVSTAN=2  :    # HT/Catégorie : On prend tout
Endif

[M:DIA]ORIMODVEN=2    :    # On prend les factures/avoirs vente
[M:DIA]ORIMODTIE=1    :    # On ne prend pas les factures/Avoirs tiers

#105200 RICAR 2015/05/25 - INV CANCELATION - BEGIN
Raz [L]V_LEG
Call GETLEG([M:DIA]CPY,"",[L]V_LEG) From TRTLECLEG

If [L]INVCA_ON = 1  & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
  If !find([M:DIA]INVCANCAT,1,2) : [M:DIA]INVCANCAT = 1 : Endif
  If !find([M:DIA]INVCANSTA,1,2) : [M:DIA]INVCANSTA = 1 : Endif
Endif
#105200 RICAR 2015/05/25 - INV CANCELATION - End

Gosub DEBUT
#FQ 67641
#If GACTION="TRTGRHSQH1"
If GACTION="TRTGRHSIH1"
#fin FQ 67641
    Call LECMEMO ("STD","[M:DIA]","vg7") From GMEMO
Else
    Call LECMEMO ("STD","[M:DIA]","vga") From GMEMO
Endif
Affzo [DIA]1-99

Return
###################################################################
# -------------------------------------------------------------------------- #
# Réaffichage de l'écran de sélection                                        #
# -------------------------------------------------------------------------- #
$BOUT_TRTGRHSIH

Case BOUT
    When "1", "2" :
        Affzo [M:DIA]1-99
Endcase

Return
###################################################################
# -------------------------------------------------------------------------- #
# Réaffichage de l'écran de sélection                                        #
# -------------------------------------------------------------------------- #
$OK_TRTGRHSIH
Affzo [M:DIA]1-99
FIN=0
Return

###################################################################
#                                                                 #
#                                                                 #
#        TRAITEMENTS LIES ACTION TRTGRHSIH2                       #
#                                                                 #
#                    Palmarès HT facturé clt,représentant,payeur  #
#                                                                 #
###################################################################
###################################################################
$DEBUT_TRTGRHSIH2

Raz [M:DIA]

[M]INVDATFIN=eomonth(date$)
[M]INVDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))

[M:DIA]INVTYPFAC=2    :    # On prend les factures
[M:DIA]INVTYPAVO=2    :    # On prend les avoirs
[M:DIA]INVTYPPRF=1    :    # On ne prend pas les proformas

[M:DIA]INVSTAO=2      :    # On prend les factures et les avoirs validés
If val(PARAM(2))=3
    [M:DIA]INVSTAN=1  :    # Palmarès tiers payeur : On ne prend que les factures et avoirs validées
Else
    [M:DIA]INVSTAN=2  :    # Autre                 : On prend tout
Endif

[M:DIA]ORIMODVEN=2    :    # On prend les factures/avoirs vente
[M:DIA]ORIMODTIE=1    :    # On prend les factures/Avoirs tiers

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Raz [L]V_LEG
Call GETLEG([M:DIA]CPY,"",[L]V_LEG) From TRTLECLEG

If [L]INVCA_ON = 1  & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
If !find([M:DIA]INVCANCAT,1,2) : [M:DIA]INVCANCAT = 1 : Endif
If !find([M:DIA]INVCANSTA,1,2) : [M:DIA]INVCANSTA = 1 : Endif
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

Gosub DEBUT

Call LECMEMO ("STD","[M:DIA]","vg8") From GMEMO

Affzo [DIA]1-99

Return
###################################################################
$SETB_TRTGRHSIH2

# Pas de palmarès client si la consultation n'est pas multi-client
If [M:DIA]BPCINV<>"" ETABOU(GSPE4) = 0 : Endif

# Pas de palmarès représentant si la consultation n'est pas multi-client ou si les représentants ne sont pas gérés
If [M:DIA]BPCINV<>""
    ETABOU(GSPE5) = 0
Else
    If func AFNC.ACTIV("REP")<1
        ETABOU(GSPE5) = 0
    Endif
Endif

Return

###################################################################
###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION VISUGRHSI1                       #
#                                                                 #
###################################################################
###################################################################
$OUVRE_VISUGRHSI1

Local Integer  WSAVPERCOD, WPERCOD : # Périodicité 1=jour,2=Semaine,3=Quinz.,4=Mois,5=Trimestre,6=Semestre,7=Année,8=Décade
Local Date     WSAVDATDEB, WDATDEB : # Date début
Local Date     WSAVDATFIN, WDATFIN : # Date fin
Local Integer  WSAVPERNBR, WPERNBR : # Nombre de période

Local Char     WCURS(GLONCUR)    : # Devise société
Local Char     WCURD(GLONCUR)    : # Devise dossier

Local Char     WPROGSPE(GLONADC) : # Nom du programme spécifique
Local Integer  WOK

# Variables communes avec la consultation facture
Local Integer  CHGPAG      : CHGPAG=1
Local Char     WFIL(250), WFIL1(250), WFIL2(250)

# Abréviation du masque contenant les critères ("DIA" ou "CCSI")
# -- > "DIA"  : On vient de la fonction graphique factures par période
# -- > "CCSI" : On vient de la consultation factures
Local Char    WABREV : WABREV=PARAM(1)
# Type de graphique
# -- > 1 : Montant HT par catégorie
# -- > 2 : Montant HT réglé
# -- > 3 : Montant HT par représentant
Local Integer WTYP : WTYP=val(PARAM(2))

Gosub OUVRE

# Ouverture systématique des écrans consultations factures
# --> Pour pouvoir exploiter l'action FILTRE spécifique
# --> (Pour pouvoir évaluer   les filtres depuis les actions champs)
If WABREV<>"CCSI"
   If !clalev([M:CSI1])  Local Mask CONSCSI1 [CSI1] : Endif
   If !clalev([M:CCSI])  Local Mask CRITCSI  [CCSI] : Endif
Endif

# -------------------------------------------------------------------------- #
# Récupération des paramètres de l'écran                                     #
# -------------------------------------------------------------------------- #

If evalue("dim([M:"+WABREV+"]PERCOD)")>0
    WPERCOD=evalue("[M:"+WABREV+"]PERCOD")
    WSAVPERCOD=WPERCOD
Else
    WPERCOD=4
Endif
If evalue("dim([M:"+WABREV+"]INVDATDEB)")>0
    WDATDEB=evalue("[M:"+WABREV+"]INVDATDEB")
    WSAVDATDEB=WDATDEB
    If WPERCOD=4 WDATDEB=gdat$(01,month(WDATDEB),year(WDATDEB)) : Endif
Else
    WDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))
Endif
If evalue("dim([M:"+WABREV+"]INVDATFIN)")>0
    WDATFIN=evalue("[M:"+WABREV+"]INVDATFIN")
    WSAVDATFIN=WDATFIN
    If WPERCOD=4 WDATFIN=eomonth(WDATFIN) Endif
Else
    WDATFIN=eomonth(date$)
Endif

If evalue("dim([M:"+WABREV+"]PERNBR)")>0
    WPERNBR=evalue("[M:"+WABREV+"]PERNBR")
    WSAVPERNBR=WPERNBR
Else
#    WPERNBR=3
    If year(WDATFIN)=year(WDATDEB)
        WPERNBR=month(WDATFIN)-month(WDATDEB)+1
    Else
        WPERNBR=13-month(WDATDEB)+month(WDATFIN)
    Endif
    WPERNBR=max(1,WPERNBR)
Endif

Gosub CHARGE_CCSI

Return
###################################################################
$TIT_VISUGRHSI1
# -------------------------------------------------------------------------- #
# Changement du titre de la fenêtre                                          #
# -------------------------------------------------------------------------- #
If WTYP=1
    TIT=mess(283,195,1)
Elsif WTYP=2
    TIT=mess(284,195,1)
Else
    TIT=mess(282,195,1)
Endif

If [M:CCSI]BPCINV<>"" TIT=TIT-mess(99,197,1)-[M:CCSI]BPCINV Endif

Return

###################################################################
$DEBUT_VISUGRHSI1

# -------------------------------------------------------------------------- #
# Chargement de l'écran graphique                                            #
# -------------------------------------------------------------------------- #
Raz [M]
[M]CPY=[M:CCSI]CPY
If WTYP<>3
    [M]PERCOD=WPERCOD
    [M]PERNBR=WPERNBR
Endif
[M]INVDATDEB=WDATDEB
[M]INVDATFIN=WDATFIN
[M]CURS=WCURS
[M]WTYP=WTYP
If [M]WTYP=1
    [M]WLIBAMT1=mess(369,198,1)
    [M]WLIBAMT2=mess(331,197,1)
Else
    [M]WLIBAMT1=mess(686,197,1)
    [M]WLIBAMT2=mess(687,197,1)
Endif

# Si la société est renseignée, le montant HT est dans la devise société sinon il est en devise dossier
If [M:CCSI]CPY<>"" [M]CUR=[M]CURS Else [M]CUR=GSYSCUR Endif

# -- Chargement des périodes
Effzo [M]10
If WTYP<>3 Gosub CHARGE_PERIODE_SGI1 Endif

[M:CCSI]INVDATDEB=[M]INVDATDEB
[M:CCSI]INVDATFIN=[M]INVDATFIN
Gosub ENTCRIT From WWCNSCSI    : # Charge [M:CSI1] à partir de [M:CCSI]
# -- Positionnement des Filtres
Gosub LOAD_FILTER From CNSCSISTD
# -- On ne prend pas les pro-forma
#WFIL1 += "&[F:SIH]INVTYP<>5"#Gbn-Fq80727
# -- HT Réglé et HT par représentant
# --> Il faut que les factures/avoirs soient validées
#If find(WTYP,2,3)  WFIL1 += "&[F:SIH]STA=3" Endif #Gbn-Fq82650
# -- HT par représentant
# --> Il faut que le représentant 1 soit renseigné
If WTYP=3 WFIL1 += "&[F:SIV]REP(0)<>''" Endif #Gbn-Fq82650

If WPROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =WPROGSPE
Endif
# -- Sauvegarde des filtres ds [M:SGI1]
# --> Pr pouvoir les utiliser depuis les actions chps (Periodicité, date début, nbr période)
[M]WFIL =WFIL
[M]WFIL1=WFIL1
[M]WFIL2=WFIL2
# -- Chargement des données
Gosub CHARGE_DONNEES_SGI1

Affzo [M]1-99

Return

###################################################################
# -------------------------------------------------------------------------- #
# Rechargement du tableau des donnees                                        #
# -------------------------------------------------------------------------- #
$BOUT_VISUGRHSI1

Case BOUT
    When "R" :
        # -- Rechargement du tableau
        # -- Chargement des périodes
        Effzo [M]10
        If WTYP<>3 Gosub CHARGE_PERIODE_SGI1 Endif
        [M:CCSI]INVDATDEB=[M]INVDATDEB
        [M:CCSI]INVDATFIN=[M]INVDATFIN
        Gosub ENTCRIT From WWCNSCSI    : # Charge [M:CSI1] à partir de [M:CCSI]
        # -- Chargement des données
        Gosub CHARGE_DONNEES_SGI1
        Affzo [M]10
Endcase

Return
###################################################################
# -------------------------------------------------------------------------- #
# Restitution des critères de date de départ                                 #
# -------------------------------------------------------------------------- #
$FIN_VISUGRHSI1
PARAM(3)=WSAVDATDEB
PARAM(4)=WSAVDATFIN
PARAM(5)=num$(WSAVPERCOD)
PARAM(6)=num$(WSAVPERNBR)
Return

###################################################################
# -------------------------------------- #
# Chargement des périodes                #
# -------------------------------------- #
$CHARGE_PERIODE_SGI1
Local Date    WDTE
Local Integer WPER, WMOIS
Local Char    WLIB
Local Integer I,WCOUNT

Effzo [M]10

WDTE=[M]INVDATDEB
WPER=[M]PERCOD
For I = 0 To [M]PERNBR-1
    If I > dim([M]WABS) - 1 : Break Endif
    WCOUNT+=1
    [M]WSTRDAT(I) = WDTE
    Gosub DET_PER_LIB From TRTVENGRH : [M]WABS(I)=WLIB
    Case [M]PERCOD
        When 1 : [M]WENDDAT(I) = WDTE                                 : # jour
        When 2 : [M]WENDDAT(I) = WDTE + (7-dayn(WDTE))                : # Semaine
        When 3 :                                                      : # Quinzaine
        When 4 : [M]WENDDAT(I) = eomonth([M]WSTRDAT(I))               : # Mois
        When 5 : WMOIS=month([M]WSTRDAT(I))                           : # Trimestre
                 Case WMOIS
                    When 1,2,3    : [M]WENDDAT(I)=gdat$(31,03,year([M]WSTRDAT(I)))
                    When 4,5,6    : [M]WENDDAT(I)=gdat$(30,06,year([M]WSTRDAT(I)))
                    When 7,8,9    : [M]WENDDAT(I)=gdat$(30,09,year([M]WSTRDAT(I)))
                    When 10,11,12 : [M]WENDDAT(I)=gdat$(31,12,year([M]WSTRDAT(I)))
                 Endcase
        When 6 : WMOIS=month([M]WSTRDAT(I))                           : # Semestre
                 Case WMOIS
                    When 1,2,3,4,5,6    : [M]WENDDAT(I)=gdat$(30,06,year([M]WSTRDAT(I)))
                    When 7,8,9,10,11,12 : [M]WENDDAT(I)=gdat$(31,12,year([M]WSTRDAT(I)))
                 Endcase
        When 7 : [M]WENDDAT(I) = gdat$(31,12,year([M]WSTRDAT(I)))     : # Année
        When 8 :                                                      : # Décade
    Endcase
    WDTE = [M]WENDDAT(I) + 1
Next I
[M]NBLIGG=WCOUNT
Return
###################################################################
# -------------------------------------- #
# Chargement des données                 #
# -------------------------------------- #
$CHARGE_DONNEES_SGI1

Local Decimal WAMT1,WAMT2
Local Decimal WMNTORG(0..2), WMNTDES(0..2)
Local Integer SPSTAT, WI, WJ
Local Char    WCUR

Case WTYP
  When 1,2:    # HT par catégorie et HT réglé/non réglé
    #-- Application des Filtres
    Filter [SIH] Where evalue([M]WFIL) & evalue([M]WFIL1) & evalue([M]WFIL2)

    #-- lecture
    $BOUCLE_SIH11
    For [SIH] With Nohint

        # Filtre sur la société
        If [M]CPY <> ""
            If [F:FCY]FCY <> [F:SIH]FCY  Read [F:FCY]FCY0 = [F:SIH]FCY
                                         If fstat  Raz [F:FCY] : Endif
                                         Endif
            If [F:FCY]LEGCPY <> [M:CCSI]CPY Goto SUIV_SIH11 : Endif
        Endif
        If [M]CPY="" & [M:CCSI]SALFCY=""
            Call GETDEV([F:SIH]FCY) From DEVSUB
            WCUR=GLOCALDEV
        Else
            WCUR=[M]CURS
        Endif
        Raz WAMT1, WAMT2

        Case WTYP
          When 1 :
            # --------------------- #
            # HT par catégorie      #
            # --------------------- #
            #Gbn-Fq80727
            If [F:SIH]INVTYP=1 | [F:SIH]INVTYP=5
                WAMT1 = [F:SIH]AMTNOT
            Elsif [F:SIH]INVTYP=2
                WAMT2 = [F:SIH]AMTNOT*-1
            Endif
          When 2
            # --------------------- #
            # HT réglé/non réglé    #
            # --------------------- #
            For [DUD]DUD0 Where TYP=[F:SIH]GTE & NUM=[F:SIH]NUM & ACCNUM=[F:SIH]ACCNUM
                WAMT1 += [F:DUD]TMPCUR+[F:DUD]PAYCUR
                WAMT2 += [F:DUD]AMTCUR-([F:DUD]TMPCUR+[F:DUD]PAYCUR)
            Next
            If [F:SIH]INVTYP=2 WAMT1*=-1 :  WAMT2*=-1 Endif
        Endcase

        # Recherche de la période à laquelle appartient la facture
        For WJ=0 To [M]NBLIGG-1
            If [F:SIH]BPRDAT>=[M]WSTRDAT(WJ) & [F:SIH]BPRDAT<=[M]WENDDAT(WJ) Break Endif
        Next

        Gosub TRT_LIGNE_SGI1

      $SUIV_SIH11
    Next
    Filter [SIH]
  When 3 :
    # ----------------------------------- #
    # HT réglé/non réglé par représentant #
    # ----------------------------------- #
    #-- Application des Filtres
    Link [SIV] With [SIH]SIH0=[SIV]NUM As [KSIV]
    Filter [KSIV] Where evalue([M]WFIL) & evalue([M]WFIL1) & evalue([M]WFIL2)
&                 Order By Key CLE=[F:SIV]REP(0)
    #-- lecture
    $BOUCLE_SIH12
    For [KSIV] With Nohint

        # Filtre sur la société
        If [M]CPY <> ""
            If [F:FCY]FCY <> [F:SIH]FCY  Read [F:FCY]FCY0 = [F:SIH]FCY
                                         If fstat  Raz [F:FCY] : Endif
                                         Endif
            If [F:FCY]LEGCPY <> [M:CCSI]CPY Goto SUIV_SIH12 : Endif
        Endif
        If [M]CPY="" & [M:CCSI]SALFCY=""
            Call GETDEV([F:SIH]FCY) From DEVSUB
            WCUR=GLOCALDEV
        Else
            WCUR=[M]CURS
        Endif
        Raz WAMT1, WAMT2

        For [DUD]DUD0 Where TYP=[F:SIH]GTE & NUM=[F:SIH]NUM & ACCNUM=[F:SIH]ACCNUM
            WAMT1 += [F:DUD]TMPCUR+[F:DUD]PAYCUR
            WAMT2 += [F:DUD]AMTCUR-([F:DUD]TMPCUR+[F:DUD]PAYCUR)
        Next
        If [F:SIH]INVTYP=2 WAMT1*=-1 :  WAMT2*=-1 Endif

        # Recherche du représentant dans la liste des représentants déjà chargés dans le graphe
        WJ=find ([F:SIV]REP(0), [M]WABS(0..[M]NBLIGG-1))
        If WJ=0 & [M]NBLIGG<dim([M]WABS)
            # Le réprésentant n'est pas encore dans le graphe : On le charge
            [M]NBLIGG+=1
            WJ=[M]NBLIGG : [M]WABS(WJ-1)=[F:SIV]REP(0)
        Elsif WJ=0
            # Le tableau est plein : On ne peut plus charger de nvx réprésentants
            Break
        Endif
        WJ-=1

        Gosub TRT_LIGNE_SGI1

      $SUIV_SIH12
    Next
    Filter [KSIV]
Endcase

Return


# ----------------------- #
# Traitement d'une ligne  #
# ----------------------- #
$TRT_LIGNE_SGI1

If WJ<[M]NBLIGG & WJ>=0
    # Conversion des montants calculés dans la devise d'affichage
    If [F:SIH]CUR <> [M]CUR
        WMNTORG (0) = WAMT1
        WMNTORG (1) = WAMT2
        Call CONVERT2([F:SIH]CUR, [M]CUR, WCUR, [F:SIH]CURTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
        Call CONVERT2([F:SIH]CUR, [M]CUR, WCUR, [F:SIH]CURTYP, datesyst, WMNTORG(1), WMNTDES(1),SPSTAT) From TRTDEV
        If [F:TCU]CUR <> [M]CUR
            Read [F:TCU]TCU0 = [M]CUR
            If fstat Raz [F:TCU] : Endif
        Endif
        [M]WAMT1(WJ) += arr(WMNTDES(0),[F:TCU]CURRND)
        [M]WAMT2(WJ) += arr(WMNTDES(1),[F:TCU]CURRND)
    Else
        [M]WAMT1(WJ) += WAMT1
        [M]WAMT2(WJ) += WAMT2
    Endif
    #--- Dem 96780-Gbn-To complete the result grid
    GPOINT="CPLGRHSIH" : Gosub ENTREE From EXEFNC
Endif

Return
###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION VISUGRHSI2                       #
#                                                                 #
###################################################################
###################################################################
$OUVRE_VISUGRHSI2

Local Date    WSAVDATDEB            :    # Date début
Local Date    WSAVDATFIN            :    # Date fin

Local Char    WCURS(GLONCUR)        :    # Devise société
Local Char    WCURD(GLONCUR)        :    # Devise dossier

Local Char    WPROGSPE(GLONADC)     :    # Nom du programme spécifique
Local Integer WOK

# Variables communes avec la consultation facture
Local Integer  CHGPAG      : CHGPAG=1
Local Char     WFIL(250), WFIL1(250), WFIL2(250)

# Abréviation du masque contenant les critères ("DIA" ou "CCSI")
# -- > "DIA"  : On vient de la fonction graphique Palmarès facture
# -- > "CCSI" : On vient de la consultation facture
Local Char WABREV : WABREV=PARAM(1)
# -- > 1 : Palmarès Client
# -- > 2 : Palmarès Représentant
# -- > 3 : Palmarès Tiers payeur
Local Integer WTYPTIERS : WTYPTIERS=val(PARAM(2))

Gosub OUVRE

# Ouverture systématique des écrans consultations factures
# --> Pour pouvoir exploiter l'action FILTRE spécifique
# --> (Pour pouvoir évaluer   les filtres depuis les actions champs)
If WABREV<>"CCSI"
   If !clalev([M:CSI1])  Local Mask CONSCSI1 [CSI1] : Endif
   If !clalev([M:CCSI])  Local Mask CRITCSI  [CCSI] : Endif
Endif

WSAVDATDEB=evalue("[M:"+WABREV+"]INVDATDEB")
WSAVDATFIN=evalue("[M:"+WABREV+"]INVDATFIN")

Return
###################################################################
$TIT_VISUGRHSI2
# -------------------------------------------------------------------------- #
# Changement du titre de la fenêtre                                          #
# -------------------------------------------------------------------------- #

If WTYPTIERS=1    TIT=mess(279,195,1)
Elsif WTYPTIERS=2 TIT=mess(281,195,1)
Else              TIT=mess(280,195,1) Endif

Return

###################################################################
$DEBUT_VISUGRHSI2

# -------------------------------------------------------------------------- #
# Récupération des paramètres de l'écran                                     #
# -------------------------------------------------------------------------- #
Gosub CHARGE_CCSI

# -------------------------------------------------------------------------- #
# Chargement de l'écran graphique                                            #
# -------------------------------------------------------------------------- #
Raz [M:SGI2]
[M:SGI2]CPY=[M:CCSI]CPY
[M:SGI2]INVDATDEB=[M:CCSI]INVDATDEB
[M:SGI2]INVDATFIN=[M:CCSI]INVDATFIN
[M:SGI2]CURS=WCURS
[M:SGI2]WTYPTIERS=WTYPTIERS
If [M:SGI2]WTYPTIERS=3 [M:SGI2]WLIBAMT=mess(670,197,1) Else [M:SGI2]WLIBAMT=mess(669,197,1) Endif

# Si la société est renseignée, le montant HT est dans la devise société sinon il est en devise dossier
If [M:CCSI]CPY<>"" [M:SGI2]CUR=[M:SGI2]CURS Else [M:SGI2]CUR=GSYSCUR Endif

If [M:SGI2]WTYPTIERS=3 [M:SGI2]NBRTOP=20 Else [M:SGI2]NBRTOP=10 Endif

Gosub ENTCRIT From WWCNSCSI    : # Charge [M:CSI1] à partir de [M:CCSI]
# -- Positionnement des Filtres
Gosub LOAD_FILTER From CNSCSISTD
# -- On ne prend pas pro-forma
#WFIL1 += "&[F:SIH]INVTYP<>5"#Gbn-Fq80727
# -- Palmarès représentant
# --> Il faut que le représentant 1 soit renseigné
If WTYPTIERS=2 WFIL1 += "&[F:SIV]REP(0)<>''" Endif #Gbn-Fq82650
# -- Palmarès tiers payeur
# --> Il faut que les factures/avoirs soient validées
#If WTYPTIERS=3 WFIL1 += "&[F:SIH]STA=3" Endif #Gbn-Fq82650
If WPROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =WPROGSPE
Endif
# -- Sauvegarde des filtres ds [M:SGI2]
# --> Pr pouvoir les utiliser depuis les actions chps (Periodicité, date début, nbr période)
[M:SGI2]WFIL =WFIL
[M:SGI2]WFIL1=WFIL1
[M:SGI2]WFIL2=WFIL2
# -- Chargement des données
Gosub CHARGE_DONNEES_SGI2

Affzo [M:SGI2]1-99

Return

###################################################################
# -------------------------------------------------------------------------- #
# Rechargement du tableau des donnees                                        #
# -------------------------------------------------------------------------- #
$BOUT_VISUGRHSI2

Case BOUT
    When "R" :
        # -- Chargement des données
        [M:CCSI]INVDATDEB=[M:SGI2]INVDATDEB
        [M:CCSI]INVDATFIN=[M:SGI2]INVDATFIN
        Gosub ENTCRIT From WWCNSCSI    : # Charge [M:CSI1] à partir de [M:CCSI]
        # -- Chargement des données
        Gosub CHARGE_DONNEES_SGI2

        Affzo [M:SGI2]10
Endcase

Return

###################################################################
# -------------------------------------------------------------------------- #
# Restitution des critères de date de départ                                 #
# -------------------------------------------------------------------------- #
$FIN_VISUGRHSI2
PARAM(3)=WSAVDATDEB
PARAM(4)=WSAVDATFIN
Return

###################################################################
# -------------------------------------- #
# Chargement des données                 #
# -------------------------------------- #
$CHARGE_DONNEES_SGI2

Local Decimal WAMT

Local Decimal WMNT
Local Decimal WMNTORG(0..2), WMNTDES(0..2)
Local Integer SPSTAT, WI, WJ
Local Char    WCUR

Local Char    WBPR
Local Integer WTOP

WTOP=[M:SGI2]NBRTOP

#Dbgaff
Effzo [M:SGI2]10
#-- Application des Filtres
Case [M:SGI2]WTYPTIERS
    When 1,3 :    # Palmarès Client et Tiers payeur
        If [M:SGI2]WTYPTIERS=1
            Filter [SIH]  Where evalue([M:SGI2]WFIL) & evalue([M:SGI2]WFIL1) & evalue([M:SGI2]WFIL2)
&                         Order By Key SIH1
        Else
            Filter [SIH]  Where evalue([M:SGI2]WFIL) & evalue([M:SGI2]WFIL1) & evalue([M:SGI2]WFIL2)
&                         Order By Key CLE=[F:SIH]BPRPAY
        Endif
        #-- lecture
        $BOUCLE_SIH21
        For [SIH] With Nohint

            # Filtre sur la société
            If [M:SGI2]CPY <> ""
                If [F:FCY]FCY <> [F:SIH]FCY  Read [F:FCY]FCY0 = [F:SIH]FCY
                                             If fstat  Raz [F:FCY] : Endif
                                             Endif
                If [F:FCY]LEGCPY <> [M:CCSI]CPY Goto SUIV_SIH21 : Endif
            Endif
            If [M:SGI2]CPY="" & [M:CCSI]SALFCY=""
                Call GETDEV([F:SIH]FCY) From DEVSUB
                WCUR=GLOCALDEV
            Else
                WCUR=[M:SGI2]CURS
            Endif

            Gosub TRT_LIGNE_SGI2

            $SUIV_SIH21
        Next
        Filter [SIH]

    When 2 :      # Palmarès Représentant
        Link [SIV] With [SIH]SIH0=[SIV]NUM As [KSIV]
        Filter [KSIV] Where evalue([M:SGI2]WFIL) & evalue([M:SGI2]WFIL1) & evalue([M:SGI2]WFIL2)
&                     Order By Key CLE=[F:SIV]REP(0)

        #-- lecture
        $BOUCLE_SIH22
        For [KSIV] With Nohint

            # Filtre sur la société
            If [M:SGI2]CPY <> ""
                If [F:FCY]FCY <> [F:SIH]FCY  Read [F:FCY]FCY0 = [F:SIH]FCY
                                             If fstat  Raz [F:FCY] : Endif
                                             Endif
                If [F:FCY]LEGCPY <> [M:CCSI]CPY Goto SUIV_SIH22 : Endif
            Endif
            If [M:SGI2]CPY="" & [M:CCSI]SALFCY=""
                Call GETDEV([F:SIH]FCY) From DEVSUB
                WCUR=GLOCALDEV
            Else
                WCUR=[M:SGI2]CURS
            Endif

            Gosub TRT_LIGNE_SGI2

            $SUIV_SIH22
        Next
        Filter [KSIV]
Endcase

If WAMT<>0 Gosub CHARGE_BPR Endif
If [M:SGI2]NBLIGG<WTOP
    Sorta [M:SGI2]NBLIGG [M:SGI2]NBLIGG Order By [M:SGI2]WAMT(indice)*-1
Else
    [M:SGI2]WABSBPR(WTOP)=[M:SGI2]WABSBPR(WTOP+1)
    [M:SGI2]WAMT(WTOP)=[M:SGI2]WAMT(WTOP+1)
    Raz [M:SGI2]WABSBPR(WTOP+1), [M:SGI2]WAMT(WTOP+1)
Endif

#Dbgaff
# Une fois le chargement terminé, il faut enlever les valeurs négatives du graph
#If [M:SGI2]NBLIGG>0
#    While [M:SGI2]WAMT([M:SGI2]NBLIGG-1)<0 & [M:SGI2]NBLIGG>=0
#        Raz [M:SGI2]WAMT([M:SGI2]NBLIGG-1), [M:SGI2]WABSBPR([M:SGI2]NBLIGG-1)
#        [M:SGI2]NBLIGG-=1
#        If [M:SGI2]NBLIGG=0 Break Endif
#    Wend
#Endif

# Une fois le chargement terminé, il faut mettre à 0 les valeurs négatives du graph
If [M:SGI2]NBLIGG>0
    WI=[M:SGI2]NBLIGG
    While [M:SGI2]WAMT(WI-1)<0
        Raz [M:SGI2]WAMT(WI-1)
        WI-=1 : If WI=0 Break Endif
    Wend
    #--- Dem 96780-Gbn-To complete the result grid
    For WI=1 To [M:SGI2]NBLIGG
     GPOINT="CPLGRHSIH" : Gosub ENTREE From EXEFNC
    Next WI
Endif
Return

# ----------------------- #
# Traitement d'une ligne  #
# ----------------------- #
$TRT_LIGNE_SGI2

If WBPR=""
    If [M:SGI2]WTYPTIERS=1
        WBPR=[F:SIH]BPR
    Elsif [M:SGI2]WTYPTIERS=2
        WBPR=[F:SIV]REP(0)
    Else
        WBPR=[F:SIH]BPRPAY
    Endif
    Raz WAMT
Endif

# Changement de tiers : chargement du tiers qui vient d'être traité dans le graphique
If (WBPR<>[F:SIH]BPR    & [M:SGI2]WTYPTIERS=1) | (WBPR<>[F:SIV]REP(0) & [M:SGI2]WTYPTIERS=2) |
&  (WBPR<>[F:SIH]BPRPAY & [M:SGI2]WTYPTIERS=3)
    If WAMT<>0 Gosub CHARGE_BPR Endif
    If [M:SGI2]WTYPTIERS=1 WBPR=[F:SIH]BPR
    Elsif [M:SGI2]WTYPTIERS=2 WBPR=[F:SIV]REP(0)
    Else                      WBPR=[F:SIH]BPRPAY : Endif
    Raz WAMT
Endif
If (WBPR=[F:SIH]BPR & [M:SGI2]WTYPTIERS=1) | (WBPR=[F:SIV]REP(0) & [M:SGI2]WTYPTIERS=2)
    # Même tiers traité : On cumule le montant HT facture
    WMNT=[F:SIH]AMTNOT
Elsif (WBPR=[F:SIH]BPRPAY & [M:SGI2]WTYPTIERS=3)
    # Même tiers traité : On cumule le montant non réglé
    # Recherche des échéaces non réglées de la facture
    Raz WMNT

    For [DUD]DUD6 Where FLGCLE<>2 & ACCNUM=[F:SIH]ACCNUM & TYP=[F:SIH]GTE & NUM=[F:SIH]NUM
        WMNT+=[F:DUD]AMTCUR-([F:DUD]TMPCUR+[F:DUD]PAYCUR)
    Next
Endif
# Conversion des montants calculés dans la devise d'affichage
If [F:SIH]CUR <> [M:SGI2]CUR
    WMNTORG (0) = WMNT
    Call CONVERT2([F:SIH]CUR, [M:SGI2]CUR, WCUR, [F:SIH]CURTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
    If [F:TCU]CUR <> [M:SGI2]CUR
        Read [F:TCU]TCU0 = [M:SGI2]CUR
        If fstat Raz [F:TCU] : Endif
    Endif
    If [F:SIH]INVTYP=2 WAMT -= arr(WMNTDES(0),[F:TCU]CURRND) Else WAMT += arr(WMNTDES(0),[F:TCU]CURRND) Endif
Else
    If [F:SIH]INVTYP=2 WAMT -= WMNT Else WAMT += WMNT Endif
Endif

Return

# ------------------------------------------------------------------------------------ #
# Chargement des valeurs du tiers (client ou représentant ou payeur) dans le tableau   #
# ------------------------------------------------------------------------------------ #
$CHARGE_BPR

If [M:SGI2]NBLIGG<WTOP
    # On charge les 10 (ou les 20) premiers tiers
    [M:SGI2]WABSBPR([M:SGI2]NBLIGG)=WBPR
    [M:SGI2]WAMT([M:SGI2]NBLIGG)=WAMT
    [M:SGI2]NBLIGG+=1
    If [M:SGI2]NBLIGG=WTOP
        Sorta [M:SGI2]NBLIGG [M:SGI2]NBLIGG Order By [M:SGI2]WAMT(indice)*-1
    Endif
Else
#Dbgaff
    # On met le tiers qui vient d'être traité en dernière position (11ème ou 21ème) et on trie les 11 (21) lignes du tableau
    [M:SGI2]WABSBPR(WTOP)=WBPR
    [M:SGI2]WAMT(WTOP)=WAMT
    Sorta WTOP+1 [M:SGI2]NBLIGG Order By [M:SGI2]WAMT(indice)*-1
    # On bascule le dernier tiers (11ème ou 21ème) dans la position Autres (12ème ou 22ème position)
    [M:SGI2]WABSBPR(WTOP+1)=mess(20,127,1)
    [M:SGI2]WAMT(WTOP+1)+=[M:SGI2]WAMT(WTOP)
    Raz [M:SGI2]WABSBPR(WTOP), [M:SGI2]WAMT(WTOP)
    [M:SGI2]NBLIGG=WTOP+1
Endif

Return

###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION VISUGRHSI1                       #
#                                VISUGRHSI2                       #
#                                                                 #
###################################################################
# -------------------------------------------------------------------------- #
# Chargement systématique des écrans consultations facture                   #
# --> Pour pouvoir exploiter l'action FILTRE spécifique                      #
# --> Pour pouvoir évaluer   les filtres depuis les actions champs           #
# -------------------------------------------------------------------------- #
$CHARGE_CCSI

If WABREV<>"CCSI"
   [M:CCSI]CPY       =evalue("[M:"+WABREV+"]CPY")
   [M:CCSI]SALFCY    =evalue("[M:"+WABREV+"]SALFCY")
   [M:CCSI]BPCINV    =evalue("[M:"+WABREV+"]BPCINV")
   [M:CCSI]NUMDEB    =evalue("[M:"+WABREV+"]NUMDEB")
   [M:CCSI]NUMFIN    =evalue("[M:"+WABREV+"]NUMFIN")
   [M:CCSI]INVDATDEB =evalue("[M:"+WABREV+"]INVDATDEB")
   [M:CCSI]INVDATFIN =evalue("[M:"+WABREV+"]INVDATFIN")
   [M:CCSI]INVTYPFAC =evalue("[M:"+WABREV+"]INVTYPFAC")
   [M:CCSI]INVTYPAVO =evalue("[M:"+WABREV+"]INVTYPAVO")
   [M:CCSI]INVTYPPRF =evalue("[M:"+WABREV+"]INVTYPPRF")
   [M:CCSI]INVSTAO   =evalue("[M:"+WABREV+"]INVSTAO")
   [M:CCSI]INVSTAN   =evalue("[M:"+WABREV+"]INVSTAN")
   [M:CCSI]ORIMODVEN =evalue("[M:"+WABREV+"]ORIMODVEN")
   [M:CCSI]ORIMODTIE =evalue("[M:"+WABREV+"]ORIMODTIE")
   #105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
   Raz [L]V_LEG
   Call GETLEG([M:CCSI]CPY,"",[L]V_LEG) From TRTLECLEG
   If [L]INVCA_ON = 1 & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
     [M:CCSI]INVCANCAT = evalue("[M:"+WABREV+"]INVCANCAT")
     [M:CCSI]INVCANSTA = evalue("[M:"+WABREV+"]INVCANSTA")
   Endif
   #105200 RICAR 2015/05/25 - Inv Cancelation - END
Endif

If !find([M:CSI1]INVTYPFAC,1,2) : [M:CSI1]INVTYPFAC = 2 : Endif
If !find([M:CSI1]INVTYPAVO,1,2) : [M:CSI1]INVTYPAVO = 2 : Endif
If !find([M:CCSI]INVTYPPRF,1,2) : [M:CCSI]INVTYPPRF = 2 : Endif
If !find([M:CCSI]INVSTAO,1,2)   : [M:CCSI]INVSTAO = 2   : Endif
If !find([M:CCSI]INVSTAN,1,2)   : [M:CCSI]INVSTAN = 2   : Endif
If !find([M:CCSI]ORIMODVEN,1,2) : [M:CCSI]ORIMODVEN = 2 : Endif
If !find([M:CCSI]ORIMODTIE,1,2) : [M:CCSI]ORIMODTIE = 2 : Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Raz [L]V_LEG
Call GETLEG([M:CCSI]CPY,"",[L]V_LEG) From TRTLECLEG
If [L]INVCA_ON = 1 & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
  Gosub SETDEFAULT_VALUES
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

# -- Récupération du nom du traitement spécifique pour pouvoir utiliser l'action FILTRE
Read [ACN] ACN0="CSI" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif

# -------------------------------------------------------------------------- #
# Analyse paramères, initialisations                                         #
# -------------------------------------------------------------------------- #
If [M:CCSI]SALFCY<>"" & GUSRFCY(1)<>"\" & !find([M:CCSI]SALFCY,GUSRFCY(1..GNBAUZ)) [M:CCSI]SALFCY="" Endif

If [M:CCSI]BPCINV <> "" : # Parametre Client
    If [F:BPC]BPCNUM<>[M:CCSI]BPCINV Read [F:BPC]BPC0 = [M:CCSI]BPCINV
                                     If fstat Raz [F:BPC], [M:CCSI]BPCINV  Endif
    Endif
Endif

If [M:CCSI]SALFCY <> "" : # Paramètre Site
    If [F:FCY]FCY <> [M:CCSI]SALFCY  Read [F:FCY]FCY0 = [M:CCSI]SALFCY
                                     If fstat Raz [F:FCY], [M:CCSI]SALFCY Endif
    Endif
    If GUSRFCY(1)="\" | find([M:CCSI]SALFCY,GUSRFCY(1..GNBAUZ))
        If [M:CCSI]SALFCY <> ""
             Call GETDEV([M:CCSI]SALFCY) From DEVSUB
             [M:CCSI]CPY  = GSOCIETE
             WCURS = GLOCALDEV
        Endif
    Endif
Elsif [M:CCSI]CPY<>""
    If [F:CPY]CPY <> [M:CCSI]CPY  Read [F:CPY]CPY0 = [M:CCSI]CPY
                           If fstat Raz [F:CPY], [M:CCSI]CPY Endif
    Endif
    WCURS = [F:CPY]ACCCUR
Endif

Return
#############################################################################
#                                                                           #
##     Etiquettes masques SGRHSIH1, SGRHSIH2                               ##
#                                                                           #
#############################################################################
