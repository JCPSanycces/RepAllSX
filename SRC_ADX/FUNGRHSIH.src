## Etiquette ajoutée par le superviseur (écran SGI2) 05/04/2007 11:13:46 (LD)
######################################################################################
Subprog C_NBRTOP(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 | VALEUR>60
  GMESSAGE=mess(6,199,1) : mkstat=1 : End : # Valeur incorrecte !
Endif
End


######################################################################################
######################################################################################
## Section automatically added (screen SGRHSIH1) 06/24/2015 11:09:57 (RICAR)
######################################################################################
Subprog AM_INVTYPFAC(VALEUR)
Variable Integer VALEUR

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Local Char V_LEG(20)
Call GETLEG([M:DIA]CPY,"",[L]V_LEG) From TRTLECLEG
If func AFNC.ACTIV("INVCA") = 1 & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
  If VALEUR = 2 & [M:DIA]INVTYPAVO = 2
    Chgfmt [M:DIA]INVCANCAT With "LA:1"
    Chgfmt [M:DIA]INVCANSTA With "LA:1"
  Elsif VALEUR = 2 & [M:DIA]INVTYPAVO = 1
    Chgfmt [M:DIA]INVCANCAT With "-LA:1"
    Chgfmt [M:DIA]INVCANSTA With "LA:1"
  Elsif VALEUR = 1 & [M:DIA]INVTYPAVO = 2
    Chgfmt [M:DIA]INVCANCAT With "LA:1"
    Chgfmt [M:DIA]INVCANSTA With "-LA:1"
  Else
    Chgfmt [M:DIA]INVCANCAT With "-LA:1"
    Chgfmt [M:DIA]INVCANSTA With "-LA:1"
  Endif

  If VALEUR = 1
    [M:DIA]INVCANSTA = 1
  Endif

  Affzo [M:DIA]INVCANSTA
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

End

Subprog AM_INVTYPAVO(VALEUR)
Variable Integer VALEUR

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Local Char V_LEG(20)
Call GETLEG([M:DIA]CPY,"",[L]V_LEG) From TRTLECLEG
If func AFNC.ACTIV("INVCA") = 1 & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
  If VALEUR = 2 & [M:DIA]INVTYPFAC = 2
    Chgfmt [M:DIA]INVCANCAT With "LA:1"
    Chgfmt [M:DIA]INVCANSTA With "LA:1"
  Elsif VALEUR = 2 & [M:DIA]INVTYPFAC = 1
    Chgfmt [M:DIA]INVCANCAT With "LA:1"
    Chgfmt [M:DIA]INVCANSTA With "-LA:1"
  Elsif VALEUR = 1 & [M:DIA]INVTYPFAC = 2
    Chgfmt [M:DIA]INVCANCAT With "-LA:1"
    Chgfmt [M:DIA]INVCANSTA With "LA:1"
  Else
    Chgfmt [M:DIA]INVCANCAT With "-LA:1"
    Chgfmt [M:DIA]INVCANSTA With "-LA:1"
  Endif

  If VALEUR = 1
    [M:DIA]INVCANCAT = 1
  Endif

  Affzo [M:DIA]INVCANCAT
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

End


######################################################################################
$SHOWHIDE

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Local Char SHOWSIGN(1),V_FIELD(4),V_LEG(20)
[L]SHOWSIGN = ""
[L]V_FIELD  = "LA:1"

Call GETLEG(VALEUR,"",[L]V_LEG) From TRTLECLEG

If func AFNC.ACTIV("INVCA") = 1
  If func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
    Chgfmt [M:DIA]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
    Chgfmt [M:DIA]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
  Else
    [L]SHOWSIGN = "-"
    Chgfmt [M:DIA]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
    Chgfmt [M:DIA]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
    [M:DIA]INVCANCAT = 1
    [M:DIA]INVCANSTA = 1
  Endif

  Affzo [M:DIA]INVCANCAT
  Affzo [M:DIA]INVCANSTA
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

Return
