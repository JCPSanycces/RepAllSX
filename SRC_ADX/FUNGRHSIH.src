######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SGRHSIH1) 15/01/2007 16:11:27 (LD)
######################################################################################
Subprog AS_PERCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1 : # Quinzaine
GMENLOC(8)=1 : # Décade
End
########################################
Subprog AM_PERCOD(VALEUR)
Variable Integer VALEUR
# -- Recalcul du nbre de périodes
Call CALPERNBR([M]PERCOD,VALEUR,[M]PERNBR) From TRTX3DAT
Affzo [M]PERNBR
# -- Recalcul date début en fonction de la périodicité et du nbre de périodes
Local Date WDATE
Call CALDATPER(VALEUR,[M]PERNBR,"-",[0/0/0],[M]INVDATFIN,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]INVDATDEB=WDATE : Affzo [M]INVDATDEB
Endif
End
########################################
Subprog C_PERNBR(VALEUR)
Variable Decimal VALEUR
#If VALEUR<1 | VALEUR>24 mkstat=2 Endif
End
########################################
Subprog AM_PERNBR(VALEUR)
Variable Decimal VALEUR
# -- Recalcul date début en fonction de la périodicité et du nbre de périodes
Local Date WDATE
Call CALDATPER([M]PERCOD,VALEUR,"-",[0/0/0],[M]INVDATFIN,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]INVDATDEB=WDATE : Affzo [M]INVDATDEB
Endif
End
######################################################################################
######################################################################################
#                                                                                    #
##     Etiquettes masques SGRHSIH1,SGRHSIH2,SGI1,SGI2                               ##
#                                                                                    #
######################################################################################
########################################
Subprog AM_INVDATDEB(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)>0
  # -- Recalcul date fin en fonction de la périodicité et du nbre de périodes
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]INVDATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]INVDATFIN=WDATE : Affzo [M]INVDATFIN
  Endif
  #-----
#Elsif VALEUR>[M]DATFIN
#  [M]DATFIN=VALEUR
Elsif VALEUR <> [0/0/0]
  [M]INVDATFIN= VALEUR
Endif
End
########################################
Subprog AM_INVDATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)>0
  #----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]INVDATFIN,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]INVDATDEB=WDATE : Affzo [M]INVDATDEB
  Endif
  #-----
Endif
End
