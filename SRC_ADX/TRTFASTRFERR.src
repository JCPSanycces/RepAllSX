#<AdxTL>@(#)12.0.0.0 $Revision$
$ACTION
 Case ACTION
  When "INIT"    : Gosub INIT
  When "DEBUT"   : Gosub DEBUT
  When "TERMINE" : Gosub TERMINE
  When Default
 Endcase
Return

$INIT
 Global Char AASREFERR
 AASREFERR=PARAM(1)
Return

$DEBUT
 Local Integer I_ERR
 Raz nolign
 For I_ERR=1 To NBR_ERREUR
  nolign+=1
  [M:FASE]ZON(nolign-1)=TAB_ZONERR(I_ERR-1)
  [M:FASE]ERR(nolign-1)=TAB_ERREUR(I_ERR-1)
 Next I_ERR
 [M:FASE]NBERR=nolign
 Affzo [M:FASE]
Return

$TERMINE
 Kill AASREFERR
Return
