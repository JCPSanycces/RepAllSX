#<AdxTL>@(#)3.0.0.0 $Revision$
#*************************************************************************************
#* Exigence 82615 : Déclaration 281.5 des honoraires Belge
#* Traitement HON281DCL : Extraction des honoraires 281.5
#*************************************************************************************!

# Issue X3-107197 - 2018-09-11 by CBO : PARAMETER AND ACTIVITY CODE

Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","HON281DCL","HON281DCL",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
Return

$OUVRE
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif
If clalev([F:DAE1])=0 : Local File GACCENTRYD [DAE1] : Endif
If clalev([F:DAE2])=0 : Local File GACCENTRYD [DAE2] : Endif
If clalev([F:BPS])=0  : Local File BPSUPPLIER [BPS]  : Endif
If clalev([F:BPS2])=0 : Local File BPSUPPLIER [BPS2] : Endif
If clalev([F:PRV])=0  : Local File HONPRV     [PRV]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:HHO])=0  : Local File HON281     [HHO]  : Endif
If clalev([F:DHO])=0  : Local File HON281D    [DHO]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:PYD])=0  : Local File PAYMENTD   [PYD]  : Endif
If clalev([F:ACV])=0  : Local File ACTIV      [ACV]  : Endif
If clalev([F:PIH])=0  : Local File PINVOICE   [PIH]  : Endif
Return

$INIT
Gosub OUVRE
TMP = 1 : TRA = 1
Return

$EXEC
Call HON281DCL
Return

Subprog HON281DCL
Gosub DECLARE
Gosub OUVRE
TIT = mess(14,122,1)-mess(4,3602,1) : # Extraction des lignes d'honoraires 281.5

Call LECTURE("CPY",[M:DIA]CPY,"") From CONTOBJ
Call LECTURE("TCU",[F:CPY]ACCCUR,"") From CONTOBJ
NBDEC = 1/(10^[F:TCU]DECNBR)

If GSERVEUR
 [M:DIA]TRC = 2
Endif

If !GSERVEUR & [M:DIA]TRC=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

If [M:DIA]TRC=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(104,"-"),0) From GESECRAN

# Paramètres de lancement ---------------------------------------------------------------------
 Call ECR_TRACE(mess(2,45,1)-":"-[M:DIA]CPY,0) From GESECRAN                : #Société
 Call ECR_TRACE(mess(4,116,1)-":"-mess([M:DIA]ALLFCY,1,1),0) From GESECRAN  : #Tous sites
 If [M:DIA]ALLFCY<>2
  Call ECR_TRACE(mess(3,45,1)-":"-[M:DIA]FCY,0) From GESECRAN               : #Site
 Endif
 Call ECR_TRACE(mess(2,47,1)-":"-num$(year([M:DIA]STRDAT)),0) From GESECRAN : #Année
 Call ECR_TRACE(mess(20,197,1)-mess(17,122,1)-":"-mess([M:DIA]ALLPRVNUM,1,1),0) From GESECRAN : #Tous Prestaire
 If [M:DIA]ALLPRVNUM<>2
  Call ECR_TRACE(mess(17,122,1)-":"-[M:DIA]PRVNUM,0) From GESECRAN          : #Prestataire
 Endif
 Call ECR_TRACE(mess(4,446,1)-":"-mess([M:DIA]ALLTYP,1,1),0) From GESECRAN  : #Toutes catégories
 If [M:DIA]ALLTYP<>2
  Call ECR_TRACE(mess(3423,200,1)-":"-mess([M:DIA]TYP281,3623,1),0) From GESECRAN : #Catégorie 281.5
 Endif
 Call ECR_TRACE( mess(1,290,1)-":"-mess([M:DIA]ERA281,1,1),0) From GESECRAN : #Remise à zéro
 Call ECR_TRACE(string$(104,"-"),0) From GESECRAN
 #----------------------------------------------------------------------------------------------
Endif

If [M]ALLFCY=2
 SYMBOLE = "HON281"+"\"+[M]CPY
Else
 SYMBOLE = "HON281"+"\"+[M]CPY+"\"+[M]FCY
Endif
Lock =SYMBOLE
If fstat
 # Opération en cours sur autre poste
 Call ECR_TRACE(mess(30,100,1),1) From GESECRAN : End
Endif

Filter [GTE] Where LEG=[F:CPY]LEG| LEG="" Order By Key CLE=TYP Asc ; LEG Desc
Local Char    TTYPREG(GLONGTE)(1..rowcount([F:GTE])+1) : # Table types pièces de règlement
Local Char    TTYPDAS(GLONGTE)(1..rowcount([F:GTE])+1) : # Table types pièces 281.5
Raz NBTYPREG,TTYPREG,NBTYPDAS,TTYPDAS
For [GTE]CLE(1)
 If [F:GTE]DAS2=2
  NBTYPDAS += 1
  TTYPDAS(NBTYPDAS) = [F:GTE]TYP
 Endif
 If [F:GTE]VATPAI=2
  NBTYPREG += 1
  TTYPREG(NBTYPREG) = [F:GTE]TYP
 Endif
Next
Filter [GTE]

Gosub CRITERE

If [M:DIA]ERA281=2
 Gosub DEL_HON281D
Endif

Gosub TR0  # Montants facturés
Gosub TR1  # Montants payés (idem DAS2)

If GOK<1 & [M:DIA]TRC=2
 Call ECR_TRACE(mess(17,107,1),1) From GESECRAN : # Abandon suite à erreur dans la transaction
Endif

If !NBLIN
 Call ECR_TRACE(mess(15,122,1),0) From GESECRAN : # Aucune ligne d'honoraire à traiter
Endif
If !GSERVEUR & [M:DIA]TRC=2
 Call FERME_TRACE From LECFIC
Endif

Unlock =SYMBOLE
End

$DECLARE
Local Integer OK,NBLIN,N,I,AFF,OKLEC,OKHHO
Local Integer NBTYPREG           : # Nombre de types de pièces de règlement
Local Integer NBTYPDAS           : # Nombre de types de pièces 281.5
Local Char    CRITHHO(250),CRITDHO(250),CRITDAE(250),CRITDAE1(250),CRITFAC(250)
Local Char    SYMBOLE(30)
Local Char    TIT(70)
Local Char    PREST(10)
Local Char    PARAM(10)
Local Decimal TTC                : # Total TTC d'une pièce
Local Decimal NBDEC              : # Nombre de décimales de la devise locale
N = len(mess(0,3623,1))          : # 3623 : Catégorie 281.5
Local Decimal HTDAS(1..N)        : # Montant HT par type d'honoraire d'une pièce
Local Decimal MTDAS(1..N)        : # Montant à déclarer par type d'honoraire
Local Integer SNS(1..N)          : # Sens comptable des comptes DAS2
Local Integer TYP_REG, STAT
Local Char    NUMREG(GLONVCR)
Local Decimal PRORATA
Local Decimal MTREGFAC
Local Integer OKREG
Local Integer OKFAC
Local Integer LINNUM
Return

$CRITERE
# Critère sur HON281 pour faire la RAZ
CRITHHO = 'CPY = "'+[M:DIA]CPY+'"'
If [M:DIA]ALLPRVNUM<>2
 CRITHHO -= '& PRVNUM = "'+[M:DIA]PRVNUM+'"'
Endif
If [M:DIA]STRDAT<>[0/0/0]
 CRITHHO -= '& YEA='+num$(year([M:DIA]STRDAT))
Endif

# Critère sur HON281D pour faire la RAZ
CRITDHO = CRITHHO
If [M:DIA]ALLFCY<>2
 CRITDHO -= '& FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLTYP<>2
 CRITDHO -= '& TYP281 = '+num$([M:DIA]TYP281)
Endif

# Critère sur GACCENTRYD pour rechercher les règlements
Call SETMAINREF([M:DIA]CPY,GTYPGEN,GTYPANA) From CPTDIV
CRITDAE  = 'CPY = "'+[M:DIA]CPY+'"'
CRITDAE -= '& LEDTYP='+num$(GTYPGEN)
If [M:DIA]ALLFCY<>2
 CRITDAE -= '& FCYLIN = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]STRDAT<>[0/0/0]
 CRITDAE -= '& ACCDAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
Endif
If [M:DIA]ENDDAT<>[0/0/0]
 CRITDAE -= '& ACCDAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
Endif
If [M:DIA]ALLPRVNUM<>2
 CRITDAE -= '& BPR = "'+[M:DIA]PRVNUM+'"'
Else
 CRITDAE -= '& BPR <>""'
Endif
CRITFAC=CRITDAE
CRITFAC -= "& find(TYP,TTYPDAS(1.."+num$(NBTYPDAS)+"))"
CRITDAE -= '& MTC<>"" & find(TYP,TTYPREG(1..NBTYPREG))'

# Critère sur GACCENTRYD pour rechercher les factures
CRITDAE1  = 'CPY = "'+[M:DIA]CPY+'"'
CRITDAE1 -= '& LEDTYP='+num$(GTYPGEN)
# on exploitera plus loin le flag DAS2 de la pièce correspondant à la facture....
CRITDAE1 -= "& find(TYP,TTYPDAS(1.."+num$(NBTYPDAS)+"))"
Return

$ROLL_TR0
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR0 : Endif
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$AB_TR0
$AB_TR1
Rollback
Return

$TR0
 If GOK<1 : Return : Endif
 If [M:DIA]TRC=2
  Call ECR_TRACE(string$(70,"="),0) From GESECRAN
  Call ECR_TRACE (mess(14,122,1)+" - "+mess(1,3624,1),0) From GESECRAN
  Call ECR_TRACE(string$(70,"="),0) From GESECRAN
 Endif
 Call DEBTRANS From GLOCK
 Trbegin [HHO],[DHO]
 # Recherche des factures d'honoraires
 Link [DAE]With [HAE]HAE0=[DAE]TYP;[DAE]NUM
&  As [LNK]
& Where evalue(CRITFAC) & [F:HAE]STA=2 & [F:HAE]FLGDAS=2
& Order By Key CLE = BPR;FCYLIN;ACCDAT;ACC;NUM;ACCNUM
 For [LNK]CLE(1)
  Raz PREST, OKHHO
  For [LNK]CLE(5)
   Read [BPS]BPS0 = [F:DAE]BPR
   If !fstat & [F:BPS]FLG281=2
    If [F:BPS]PRVNUM=""
     If [M:DIA]TRC=2 & PREST<>[F:BPS]BPSNUM
      If AFF : Call ECR_TRACE("",0) From GESECRAN : Endif
      Call ECR_TRACE ([F:BPS]BPSNUM,0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      AFF =0
     Endif
     PREST = [F:BPS]BPSNUM
    Else
     If [M:DIA]TRC=2 & PREST<>[F:BPS]PRVNUM
      If AFF : Call ECR_TRACE("",0) From GESECRAN : Endif
      Call ECR_TRACE ([F:BPS]BPSNUM-mess(17,122,1)-[F:BPS]PRVNUM,0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      AFF = 0
     Endif
     PREST = [F:BPS]PRVNUM
    Endif
   Else : # Si le fournisseur n'est pas flaggé 281.5 : pas d'extraction
    If [M:DIA]TRC=2
     If [F:BPS]PRVNUM=""
      PREST=[F:DAE]BPR
     Else
      PREST=[F:BPS]PRVNUM
     Endif
     Read [PRV]PRV0=PREST
     If !fstat & [F:PRV]FLG281=2
      OK=0
      For [BPS2] Where PRVNUM=PREST and FLG281=2
       OK=1 : Break
      Next
      If !OK
       Call ECR_TRACE(PREST-":"-mess(88,122,1),1) From GESECRAN
      Endif
     Endif
    Endif
    Raz PREST : # Quoi qu'il arrive, pas d'extraction si BPS non flaggé 281.5
   Endif
   If PREST<>""
    Read [PRV]PRV0 = PREST
    If !fstat & [F:PRV]FLG281=2
     Gosub TR_MTT_FAC
     If GOK<1 : Break : Endif
    Else
     If [M:DIA]TRC=2
      Call ECR_TRACE(mess(12,107,1)-[F:DAE]TYP-[F:DAE]NUM-":"-mess(5,122,1)-PREST,1) From GESECRAN
      # Piece typ num : prestataire inexistant xxxxxx
     Endif
    Endif
   Endif : # PREST<>""
  Next
 Next
 Filter [DAE]
 If GOK<0   : Goto ROLL_TR0
 Elsif !GOK : Goto AB_TR0
 Endif
Commit
Return

$TR_MTT_FAC

  Raz TTC,HTDAS,SNS,OK

  # Parcours des lignes des factures
  Link [DAE2] With [GAC]GAC0=[F:DAE2]COA;[F:DAE2]ACC
& As [LNK2]
& Where [DAE2]TYP=[F:DAE]TYP & [DAE2]NUM=[F:DAE]NUM & [DAE2]LEDTYP=GTYPGEN
&   and [F:GAC]FLG281=2 & ([F:GAC]TYP281=[M:DIA]TYP281 | [M:DIA]ALLTYP=2)

  For [LNK2]
    HTDAS([F:GAC]TYP281) +=[F:DAE2]AMTLED*[F:DAE2]SNS
    SNS([F:GAC]TYP281)    = [F:GAC]SNSBLC
    OK = 1
  Next

  If OK : # La pièce comptabilise un compte de type 281.5
    For I=1 To N
     HTDAS(I) = arr(HTDAS(I),NBDEC)
     If HTDAS(I)<>0
      AFF = 1
      Gosub MAJ_HON281D_FAC
      If GOK<1 : Break 2 : Endif
     Endif: # HTDAS(i)<>0
    Next I
  Endif : # OK

Return

$TR1
 If GOK<1 : Return : Endif
 If [M:DIA]TRC=2
  Call ECR_TRACE(" ",0) From GESECRAN
  Call ECR_TRACE(string$(70,"="),0) From GESECRAN
  Call ECR_TRACE (mess(14,122,1)+" - "+mess(2,3624,1),0) From GESECRAN
  Call ECR_TRACE(string$(70,"="),0) From GESECRAN
 Endif
 Call DEBTRANS From GLOCK
 Trbegin [HHO],[DHO]
 # Recherche des règlements de factures d'honoraires
 Filter [DAE] Where evalue(CRITDAE) Order By Key CLE = BPR;FCYLIN;ACCDAT;ACC;MTC;NUM;ACCNUM
 For [DAE]CLE(1)
  Raz PREST, OKHHO
  For [DAE]CLE(6)
   Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
   NUMREG = vireblc(right$([F:DAE]REFINTLIN,4),2)
   If !fstat & [F:HAE]STA=2
    Read [BPS]BPS0 = [F:DAE]BPR
    If !fstat & [F:BPS]FLG281=2
     If [F:BPS]PRVNUM=""
      If [M:DIA]TRC=2 & PREST<>[F:BPS]BPSNUM
       If AFF : Call ECR_TRACE("",0) From GESECRAN : Endif
       Call ECR_TRACE ([F:BPS]BPSNUM,0) From GESECRAN
       Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
       AFF =0
      Endif
      PREST = [F:BPS]BPSNUM
     Else
      If [M:DIA]TRC=2 & PREST<>[F:BPS]PRVNUM
       If AFF : Call ECR_TRACE("",0) From GESECRAN : Endif
       Call ECR_TRACE ([F:BPS]BPSNUM-mess(17,122,1)-[F:BPS]PRVNUM,0) From GESECRAN
       Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
       AFF = 0
      Endif
      PREST = [F:BPS]PRVNUM
     Endif
    Else : # Si le fournisseur n'est pas flaggé 281.5 : pas d'extraction
    If [M:DIA]TRC=2
     If [F:BPS]PRVNUM=""
      PREST=[F:DAE]BPR
     Else
      PREST=[F:BPS]PRVNUM
     Endif
     Read [PRV]PRV0=PREST
     If !fstat & [F:PRV]FLG281=2
      OK=0
      For [BPS2] Where PRVNUM=PREST and FLG281=2
       OK=1 : Break
      Next
      If !OK
       Call ECR_TRACE(PREST-":"-mess(88,122,1),1) From GESECRAN
      Endif
     Endif
    Endif
    Raz PREST : # Quoi qu'il arrive, pas d'extraction si BPS non flaggé 281.5
    Endif
    If PREST<>""
     Read [PRV]PRV0 = PREST
     If !fstat & [F:PRV]FLG281=2
      Gosub TR_MTT_PAY
      If GOK<1 : Break : Endif
     Else
      If [M:DIA]TRC=2
       Call ECR_TRACE(mess(12,107,1)-[F:DAE]TYP-[F:DAE]NUM-":"-mess(5,122,1)-PREST,1) From GESECRAN
       # Piece typ num : prestataire inexistant xxxxxx
      Endif
     Endif
    Endif : # PREST<>""
   Endif
  Next
 Next
 Filter [DAE]
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$TR_MTT_PAY
Filter [DAE1] Where MTC=[F:DAE]MTC & BPR=[F:DAE]BPR & SAC=[F:DAE]SAC &
&                   ACC=[F:DAE]ACC & evalue(CRITDAE1)

For [DAE1]DAE6  #DAE6 : LEDTYP+ACC+BPR+MTC+TYP+NUM+LIN+ACCNUM
 OKREG = 0
 If NUMREG = "" : OKREG = 1 : Endif
 For [PYD]PYD0 Where NUM = NUMREG & (VCRNUM="" or (VCRTYP = [F:DAE1]TYP & VCRNUM = [F:DAE1]NUM))
  OKREG=1 : Break
 Next
 If OKREG

  Raz TTC,HTDAS,SNS,OK

  Read[HAE]HAE0 = [F:DAE1]TYP;[F:DAE1]NUM
  If !fstat & [F:HAE]FLGDAS=2
   # Parcours des lignes des factures
   For [DAE2]DAE0 Where TYP=[F:DAE1]TYP & NUM=[F:DAE1]NUM & LEDTYP=GTYPGEN

    If [F:DAE2]MTC=[F:DAE]MTC & [F:DAE2]BPR=[F:DAE]BPR & [F:DAE2]SAC=[F:DAE]SAC &
&      [F:DAE2]ACC=[F:DAE]ACC
     TTC +=[F:DAE2]AMTLED*[F:DAE2]SNS
    Else
     Read [GAC]GAC0 = [F:DAE2]COA;[F:DAE2]ACC
     If !fstat & [F:GAC]FLG281=2 & ([F:GAC]TYP281=[M:DIA]TYP281 | [M:DIA]ALLTYP=2)
      HTDAS([F:GAC]TYP281) +=[F:DAE2]AMTLED*[F:DAE2]SNS
      SNS([F:GAC]TYP281)   = [F:GAC]SNSBLC
      OK = 1
     Endif
    Endif
   Next

   MTREGFAC = 0 : OKLEC = 0
   For [PYD]PYD0 Where NUM = NUMREG & VCRTYP = [F:DAE1]TYP & VCRNUM = [F:DAE1]NUM & ACCTYP=1
    MTREGFAC += [F:PYD]PAYLOCLIN : OKLEC = 1
   Next
   PRORATA = 1
   If TTC<>0 & OKLEC
    PRORATA = abs(MTREGFAC)/abs(TTC)
   Endif

   ### Si l'avoir est lettré à la facture dès la comptabilisation de l'avoir,
   # le règlement est donc à la hauteur du solde entre la facture et son avoir
   # et l'avoir n'apparait donc pas dans le règlement
   # dans ce cas de figure, il ne faut pas prendre en compte l'avoir. (DdM40740)
   If !OKLEC
    Read [PIH]PIH0 = [F:DAE1]NUM
    If !fstat & [F:PIH]INVNUM<>""
     For [PYD]PYD0 Where NUM = NUMREG &  VCRNUM = [F:PIH]INVNUM & ACCTYP=1
      Raz OK : Break
     Next
    Endif
   Endif

   If OK : # La pièce comptabilise un compte de type 281.5
     For I=1 To N
      HTDAS(I) = arr(HTDAS(I)*PRORATA,NBDEC)
      If HTDAS(I)<>0
       AFF = 1
       Gosub MAJ_HON281D_PAY
       If GOK<1 : Break 2 : Endif
      Endif: # HTDAS(i)<>0
     Next I
   Endif : # OK
  Endif
 Endif
Next : # DAE1
Filter [DAE1]
Return

$DEL_HON281D
Delete [DHO] Where evalue(CRITDHO)
If fstat=1
 GOK = -1 : GLOCK="$HON281D" : Goto ROLL_TR1
Elsif fstat>5
 GOK = 0 : Call RSTA("DHO","") From GLOCK : Goto AB_TR1
Endif

# suppression des lignes d'entêtes (seulement si plus aucune ligne de détail)
If [M:DIA]ALLTYP=2 and [M:DIA]ALLFCY=2 : # dans ce cas, on peut tout supprimer !
 Gosub DEL_HON281
Else : # Dans ce cas, il faut regarder s'il ne reste pas des lignes de détail
 Filter [F:DHO] Where evalue(CRITHHO)
 Read [F:DHO] First
 Filter [F:DHO]
 If fstat
  Gosub DEL_HON281
 Endif
Endif
Return

$DEL_HON281
Delete [HHO] Where evalue(CRITHHO)
If fstat=1
 GOK = -1 : GLOCK="$HON281" : Goto ROLL_TR1
Elsif fstat>5
 GOK = 0 : Call RSTA("HHO","") From GLOCK : Goto AB_TR1
Endif
Return

$MAJ_HON281  # table entête
If !OKHHO
 OKHHO=1
 Filter [HHO] Where CPY=[M:DIA]CPY & PRVNUM=PREST & YEA=year([M:DIA]STRDAT)
 Read [HHO]HHO0 First
 Filter [HHO]
 If fstat
  Raz [F:HHO]
  [F:HHO]          = [F:PRV]
  [F:HHO]CPY       = [M:DIA]CPY
  [F:HHO]YEA       = year([M:DIA]STRDAT)
  [F:HHO]PRVNUM    = PREST
  [F:HHO]CREDAT    = date$
  [F:HHO]UPDDAT    = date$
  Write [HHO]
  If fstat
   GOK = 0 : Call FSTA("HHO") From GLOCK : Return
  Endif
 Endif
Endif
Return

$MAJ_HON281D_FAC # table détails
# DHO0 : CPY+LED+YEA+PRVNUM+TYPLIN+NUM+LIN
Filter [DHO] Where CPY=[M:DIA]CPY & PRVNUM=PREST & YEA=year([M:DIA]STRDAT) & TYPLIN=1 & NUM=[F:DAE]NUM
Read [DHO]DHO0 Last
If !fstat
 LINNUM = [F:DHO]LIN + 1
Else
 LINNUM = 1
Endif
Filter [DHO]
Raz [F:DHO]
[F:DHO]CPY       = [M:DIA]CPY
[F:DHO]YEA       = year([M:DIA]STRDAT)
[F:DHO]PRVNUM    = PREST
[F:DHO]FCY       = [F:DAE]FCYLIN
[F:DHO]TYPLIN    = 1                   : # Montants facturés
[F:DHO]LIN       = LINNUM
[F:DHO]TYP       = [F:DAE2]TYP         : # Facture
[F:DHO]NUM       = [F:DAE2]NUM         : # Facture
[F:DHO]ACCDATINV = [F:DAE]ACCDAT
[F:DHO]AMTLEDINV = arr(HTDAS(I),NBDEC) : # On ramène le montant HT
[F:DHO]SNSINV    = SNS(I)              : # sens
[F:DHO]JOU       = [F:HAE]JOU
[F:DHO]TYP281    = I
[F:DHO]CREDAT    = date$
[F:DHO]UPDDAT    = date$
Write [DHO]
If fstat
 GOK = 0 : Call FSTA("DHO") From GLOCK : Return
Endif
If [M:DIA]TRC=2
 Call ECR_TRACE (format$("D:"+GFMDAT,[F:DAE]ACCDAT)-mess(16,122,1)
& -[F:DAE2]TYP-[F:DAE2]NUM-mess(I,3623,1)-num$([F:DHO]AMTLEDINV),0) From GESECRAN
Endif
NBLIN +=1
Gosub MAJ_HON281
Return

$MAJ_HON281D_PAY # table détails
# DHO0 : CPY+LED+YEA+PRVNUM+TYPLIN+NUM+LIN
Filter [DHO] Where CPY=[M:DIA]CPY & PRVNUM=PREST & YEA=year([M:DIA]STRDAT) & TYPLIN=2 & NUM=[F:DAE2]NUM
Read [DHO]DHO0 Last
If !fstat
 LINNUM = [F:DHO]LIN + 1
Else
 LINNUM = 1
Endif
Filter [DHO]
Raz [F:DHO]
[F:DHO]CPY       = [M:DIA]CPY
[F:DHO]YEA       = year([M:DIA]STRDAT)
[F:DHO]PRVNUM    = PREST
[F:DHO]FCY       = [F:DAE]FCYLIN
[F:DHO]TYPLIN    = 2                           : # Montants payés
[F:DHO]LIN       = LINNUM
[F:DHO]TYP       = [F:DAE1]TYP                 : # Facture
[F:DHO]NUM       = [F:DAE1]NUM                 : # Facture
[F:DHO]ACCDATINV = [F:DAE1]ACCDAT
[F:DHO]AMTLEDINV = arr(HTDAS(I)/PRORATA,NBDEC) : # Montant facture HT 281.5
[F:DHO]SNSINV    = [F:DAE1]SNS                 : # sens
[F:DHO]JOU       = [F:HAE]JOU                  : # journal de la facture
[F:DHO]TYP281    = I
[F:DHO]MTC       = [F:DAE]MTC                  : # lettre
[F:DHO]NUMPAY    = [F:DAE]NUM                  : # Pièce de Règlement
[F:DHO]ACCDATPAY = [F:DAE]ACCDAT
[F:DHO]AMTLEDPAY = arr(HTDAS(I),NBDEC)         : # On ramène le montant HT
[F:DHO]SNSPAY    = [F:DAE]SNS                  : # sens règlement
[F:DHO]CREDAT    = date$
[F:DHO]UPDDAT    = date$
Write [DHO]
If fstat
 GOK = 0 : Call FSTA("DHO") From GLOCK : Return
Endif
If [M:DIA]TRC=2
 Call ECR_TRACE (format$("D:"+GFMDAT,[F:DAE]ACCDAT)-[F:DAE]TYP-[F:DAE]NUM-mess(16,122,1)
& -[F:DAE2]TYP-[F:DAE2]NUM-mess(I,3623,1)-num$([F:DHO]AMTLEDPAY),0) From GESECRAN
Endif
NBLIN +=1
Gosub MAJ_HON281
Return

######################################################################################
# Sélection des sociétés gérant la déclaration des honoraires 281.5
######################################################################################
$SEL_LISTE
Case LISTE
 When "SELCPY281" : Gosub SELCPY281
 When Default
Endcase
Return

$SELCPY281
Local Integer NBTEX
Local Char    LPARAM
Local Char    TEXTE(80)(1..200,1..3)

NBTEX = 0

TIT(0) = mess(10, 16,1)-mess(2,45,1)-mess(4,3602,1) : # Choix Société 281.5
TIT(1) = mess( 2, 45,1)                             : # Société
TIT(2) = mess(38,100,1)                             : # Nom
TIT(3) = mess( 3,675,1)                             : # Intitulé court

If clalev([F:ADW])=0  : Local File ADOVAL   [ADW]  : Endif
If clalev([F:WCPY])=0 : Local File COMPANY  [WCPY] : Endif

Link [ADW] With [WCPY]CPY0=[ADW]CMP As [LNK] Where PARAM="DCLFEES" and VALEUR="4"
For [LNK]
 NBTEX         += 1
 TEX(NBTEX)     = [F:WCPY]CPY
 TEXTE(NBTEX,1) = [F:WCPY]CPY
 TEXTE(NBTEX,2) = [F:WCPY]CPYNAM
 TEXTE(NBTEX,3) = [F:WCPY]CPYSHO
Next

If NBTEX=0
 GERR=2
 GMESSAGE=mess(191,7770,1) : #Aucune société n'est éligible pour ce traitement.
 mkstat=2
Endif
Return


#********************************************************************************************
#* Gestion du masque HON281DCL
#********************************************************************************************!

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("FEE") and func AFNC.PARAM("DCLFEES", VALEUR)<>"4" # Issue X3-107197
  # Société non définie pour traiter la 281.5
  GMESSAGE=mess(87,122,1)
  mkstat=2
Endif
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
Call AS_FCY(VALEUR) From CPTTRT
End

Subprog AS_PRVNUM(VALEUR)
Variable Char    VALEUR()
If [M]ALLPRVNUM = 2 : mkstat = 1 : End : Endif
End

Subprog AS_TYP281(VALEUR)
Variable Integer VALEUR
If [M]ALLTYP = 2 : mkstat = 1 : End : Endif
End

Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(1,1,year(datesyst)-1) : # Année civile précédente
Endif
End

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 GMESSAGE=mess(1,762,1) : # Saisie obligatoire
 mkstat=2
Endif
End

Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
[M]STRDAT=gdat$(1,1,year(VALEUR))
[M]ENDDAT=gdat$(31,12,year(VALEUR))
Affzo [M]STRDAT
Affzo [M]ENDDAT
End

Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(31,12,year([M]STRDAT))
Endif
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 GMESSAGE=mess(1,762,1) : # Saisie obligatoire
 mkstat=2
Endif
End

Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
[M]STRDAT=gdat$(1,1,year(VALEUR))
[M]ENDDAT=gdat$(31,12,year(VALEUR))
Affzo [M]STRDAT
Affzo [M]ENDDAT
End

Subprog AS_DATPCE(VALEUR)
Variable Date     VALEUR
If VALEUR=[0/0/0]
 VALEUR = [M]ENDDAT
Endif
End

#*************************************************************************************!

