#<AdxTL>@(#)6.0.0.0 $Revision$
#######################################################################
# TRTBOM  Traitement pour les nomenclatures modélisées
# Actions pour les boutons du tableau des liens de nomenclature
# Sous-pro pour le controle des droits sur les alternatives
# Subprog CONTALT
# Subprog CTLACCALT
# Subprog CTLVISALT # pour appel depuis traitement
# Subprog CTLMODALT
# Subprog CTLCONSALT # pour écrans
#######################################################################
# petit message pendant le temps que je modélise !
$MSGTB
$ACTION
Case ACTION
 When "SEL_TABLE"         Gosub SEL_TABLE
 When "SEL_LISTE"         Gosub SEL_LISTE
 When "VERF_TABLE"        Gosub VERF_TABLE
 # actions pour GSAISIE
 When "OUVRE"             Gosub OUVRE
 When "DEBUT"
        Case GACTION
         When "SAIBOD"    Gosub DEB_BOD
         When "SAIBODP"   Gosub DEB_BODP
         When "SAIBODS"   Gosub DEB_BODS : # GA 23/11/2005
         When "SAIBOSS"   Gosub DEB_BOSS : # GA 10/01/2006
        Endcase
 When "OK"
         Case GACTION
          When "SAIBOD"   Gosub OK_BOD
          When "SAIBODP"  Gosub OK_BODP
          When "SAIBODS"  Gosub OK_BODS : # GA 23/11/2005
          When "SAIBOSS"  Gosub OK_BOSS : # GA 10/01/2006
         Endcase

 When "APRES_MODIF"       UPD = 1

 When "END"               UPD = 0    :#pour ne pas passer en modif si btn Fin
 When "FINSAI"            If UPD = 1  mkstat = 4  Endif
                          # 30793 MM 06.05
                          If dim([M:BOD1]BOMUOM(nolign-1))<0    # UML inactif
                              [M:BOH0]CUMQTE += [M:BOD1]LIKQTY(LIG-1)
                          Else
                              [M:BOH0]CUMQTE += [M:BOD1]BOMQTY(LIG-1)
                          Endif

 # actions pour trt std
 When "INIT"              Gosub INIT
 When "INIT_DIA"
         Case GACTION
          When "TRTBRP0"  Gosub INIT_DIA0
          When "TRTBRP1"  Gosub INIT_DIA1
          When "TRTBRP2"  Gosub INIT_DIA2 : # GA 23/11/2005 renum opérations nom ss-trait
          When "TRTBRP3"  Gosub INIT_DIA3 : # GA 23/11/2005
         Endcase
 When "EXEC"
         Case GACTION
          When "TRTBRP0"  Gosub EXEC0
          When "TRTBRP1"  Gosub EXEC1
          When "TRTBRP2"  Gosub EXEC2 : # GA 23/11/2005 renum opérations nom ss-trait
          When "TRTBRP3"  Gosub EXEC3 : # GA 23/11/2005
          When "TRTBOF"   Gosub EXEFUS
         Endcase
 When "TERMINE"           If GACTION = "TRTBOF"  TRA=1  Endif # Lecture trace
 When "SORTIE"            Gosub SORTIE
 When Default
Endcase
Return

#######################################################################
$OUVRE
Local Integer LIG : LIG = nolign # nécessaire car nolign est cassé plus tard

Local Integer    UPD

# ATTENTION si on rajoute un sous-pro AM_ dans la fiche
#  il faut déclarer UPD en global et l'alimenter dans tous les sous-pros AM_xxx  !!!
#  car GOBJET = 0 et après l'action AM_ on ne passerait pas en $MOD_FICH

# 30793 MM 06.05
If dim([M:BOD1]BOMUOM(nolign-1))<0    # UML inactif
    [M:BOH0]CUMQTE -= [M:BOD1]LIKQTY(nolign-1)
Else
    [M:BOH0]CUMQTE -= [M:BOD1]BOMQTY(nolign-1)
Endif
Return

#######################################################################
# saisie des liens de nomenclature en fiche
# nomenclature commerciale
$DEB_BOD
nolign = LIG : #!! nolign mis à 1 dans OUVRE_BOITE en 140
# Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
If [M:BOD1]CPNITMREF(nolign-1) <> "" | [M:BOD1]FORSEL(nolign-1) <> ""
   [M:BOM2] = [M:BOD1] :# le masque par défaut est le dernier ouvert !
   # Issue 77263 - 2011-11-24 by MUARN : sur fenetre de saisie pas de controle des champs
   #Affzo [M:BOM2]
   Affzo [M:BOM2]1-99
   # fin Issue 77263 - 2011-11-24 by MUARN : sur fenetre de saisie pas de controle des champs
Else
   Raz [M:BOM2]
   [M:BOM2]BOMSTRDAT = [M:BOH0]BOHSTRDAT
   [M:BOM2]BOMENDDAT = [M:BOH0]BOHENDDAT
   Affzo [BOM2]CPNTYP, LIKQTYCOD, QTYRND, BOMSTRDAT, BOMENDDAT, OCNPRN,NDEPRN,INVPRN
Endif
Call LEC_TEX("BOM2",nolign-1)
# Issue 77263 - 2011-11-24 by MUARN : sur fenetre de saisie pas de controle des champs
#Affzo [M:BOM2]
Affzo [M:BOM2]1-99
# fin Issue 77263 - 2011-11-24 by MUARN : sur fenetre de saisie pas de controle des champs

# Issue 110957 - 2015-10-13 by SLL
If dim([M:BOM2]CRID)>0
   Diszo [M:BOM2]CRID
Endif

Return

#######################################################################
# nomenclature production
$DEB_BODP
nolign = LIG : # nolign mis à 1 dans OUVRE_BOITE en 140
If [M:BOD1]CPNITMREF(nolign-1) <> "" | [M:BOD1]CPNTYP(nolign-1) = 5
   [M:BOM1] = [M:BOD1]
   # (llc 05.00 sous-produit)
   If [M:BOD1]CPNTYP(nolign-1) = 1 :
     Grizo [M:BOM1]CSTFLG
     Actzo [M:BOM1]SCA
     Actzo [M:BOM1]PICPRN
   Elsif [M:BOD1]CPNTYP(nolign-1) = 5
     Grizo CPNITMREF
     Grizo [M]21-35
     Actzo BOMSTRDAT, BOMENDDAT, CPNOPE, BOMSHO
   Else
     Actzo [M:BOM1]CSTFLG
     Grizo [M:BOM1]SCA
     Grizo [M:BOM1]PICPRN
   Endif
   Affzo [M:BOM1]
Else
   Raz [M:BOM1]
   #[M:BOM1]BOMSTRDAT = [M:BOH0]BOHSTRDAT : # versioning
   #[M:BOM1]BOMENDDAT = [M:BOH0]BOHENDDAT : # versioning
   # (llc 05.00 sous-produit)
   Grizo [M:BOM1]CSTFLG
   Affzo [BOM1]CPNTYP, LIKQTYCOD, QTYRND, BOMSTRDAT, BOMENDDAT, CSTFLG, PICPRN
   If dim([M:BOM1]PKC)>0  Affzo [BOM1]PKC Endif # rajouté 22/02/01
Endif
Call LEC_TEX("BOM1",nolign-1)

# FGR 03/02/2010 : X3SUIVI58003 (début)
  # clé non modifiable
  If (GREP = "M" | GREP = "") & [M:BOD1]CPNITMREF(nolign-1) <> "" & [M:BOD1]CREFLG(nolign-1) > 0 Then
    Diszo [M:BOM1]CPNITMREF
  Endif
# FGR 03/02/2010 : X3SUIVI58003 (fin)

# Issue 110957 - 2015-09-21 by GH
If dim([M:BOM1]CRID)>0
   Diszo [BOM1]CRID
Endif

Affzo [M:BOM1]
Return

#######################################################################
# GA 23/11/2005 écran BOM3 => abrmsk=BOM1, écran BOD3 => abrmsk=BOD1
# nomenclature de sous-traitance
$DEB_BODS
nolign = LIG  # nolign mis à 1 dans OUVRE_BOITE en 140
If [M:BOD1]CPNITMREF(nolign-1) <> ""
   [M:BOM1] = [M:BOD1]
   Affzo [M:BOM1]
Else
   Raz [M:BOM1]
   #[M:BOM1]BOMSTRDAT = [M:BOH0]BOHSTRDAT : # versioning
   #[M:BOM1]BOMENDDAT = [M:BOH0]BOHENDDAT : # versioning
Endif
Call LEC_TEX("BOM1",nolign-1)

# Issue 110957 - 2015-09-21 by GH
If dim([M:BOM1]CRID)>0
   Diszo [BOM1]CRID
Endif

Affzo [M:BOM1]
Return

#######################################################################
# GA 10/01/2006 écrans liste=BOS2, fiche=BOS3
# Fiche service de nomenclature de sous-traitance
$DEB_BOSS
nolign = LIG  # nolign mis à 1 dans OUVRE_BOITE en 140
If [M:BOS2]CPNITMREF(nolign-1) <> ""
   [M:BOS3] = [M:BOS2]
   Affzo [M:BOS3]
Else
   Raz [M:BOS3]
   [M:BOS3]BOMSTRDAT = [M:BOH0]BOHSTRDAT
   [M:BOS3]BOMENDDAT = [M:BOH0]BOHENDDAT
Endif
Return

#######################################################################
$OK_BOD
# confirmation de validation
# quel est le btn par défaut ??   dans GSAISIE : 'OK' s'il y est

  # cas de création en mode fiche => incrémenter le nb de lignes tableau
  # Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
  If [M:BOD1]CREFLG(LIG-1) = 0 & [M:BOD1]CPNITMREF(LIG-1) = "" & [M:BOD1]FORSEL(LIG-1) = ""
     [M:BOD1]NBLIG +=1
  Endif
  # le transclasse a besoin de nolign : (19/01/01)
  nolign = LIG
  [M:BOD1]=[M:BOM2]
  [M:BOD1]CONCATKEY(LIG-1) = num$([M:BOM2]BOMSEQ)+[M:BOM2]CPNITMREF
  [M:BOD1]UPDFLG(LIG-1)    = 1

## 03.07 Demande 40156
##  [M:BOD1]ITMDES1(LIG-1) =[M:BOM2]ZCPNITMREF # l'intitulé
#  If dim([M:BOD1]ZCPNITMREF)>0 & dim([M:BOM2]ZCPNITMREF)=1 : # GH 21/01/2015 bug 105623 ajout du test
#     [M:BOD1]ZCPNITMREF(LIG-1) = [M:BOM2]ZCPNITMREF
#     Affzo [BOD1]ZCPNITMREF(LIG-1)
#  Endif
#
#  Affzo [BOD1]BOMSEQ(LIG-1), BOMSEQNUM(LIG-1),CPNITMREF(LIG-1)
#  # Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
#  Affzo [BOD1]FORSEL(LIG-1), FORQTY(LIG-1)
#
#  Affzo [BOD1]CPNTYP(LIG-1), BOMSHO(LIG-1)   ,BOMSTRDAT(LIG-1),BOMENDDAT(LIG-1)
#  Affzo [BOD1]LIKQTY(LIG-1), QTYRND(LIG-1)   ,LIKQTYCOD(LIG-1),BOMTEXNUM(LIG-1)
## 03.07 Demande 40156
##  Affzo [BOD1]OCNPRN(LIG-1), NDEPRN(LIG-1)   ,INVPRN(LIG-1)   , ITMDES1(LIG-1)
## GH 21/01/2015 bug 105623
##  Affzo  [BOD1]OCNPRN(LIG-1), NDEPRN(LIG-1)   ,INVPRN(LIG-1)   , CPNITMREF(LIG-1), ZCPNITMREF(LIG-1)
#  Affzo [BOD1]OCNPRN(LIG-1), NDEPRN(LIG-1)   ,INVPRN(LIG-1)   , CPNITMREF(LIG-1)
#  Affzo [BOD1]STU(LIG-1)
#
#  # Issue 110957 - 2015-10-13 by SLL
#  If dim([M:BOD1]CRID)>0
#     Affzo [BOD1]CRID(LIG-1)
#  Endif
#  If dim([M:BOD1]CRFLG)>0
#     Affzo [BOD1]CRFLG(LIG-1)
#  Endif
  Call AFFLIG("BOD2","BOD1","NBLIG",LIG-1) From OBJSIM : # GH 11/2015 # enhancement

  #MAE, bg 78723
  #Call VERIF_TEX("BOM2",LIG)
  Call VERIF_TEX("BOM2",LIG-1)

  FIN = 1
Return

#######################################################################
$OK_BODP
# validation fiche composant production
  # cas de création en mode fiche => incrémenter le nb de lignes tableau
  # GB 26.07.2017 ISSUE X3-47324 : add a selection crieria to put a white line at the rigth time in component product : & [M:BOD1]NBLIG < LIG
  If [M:BOD1]CREFLG(LIG-1) = 0 & [M:BOD1]CPNITMREF(LIG-1) = ""  & [M:BOD1]CPNTYP(LIG-1) <> 5 & [M:BOD1]NBLIG < LIG
     [M:BOD1]NBLIG +=1
  Endif
  # le transclasse a besoin de nolign : (19/01/01)
  nolign = LIG
  [M:BOD1]=[M:BOM1]
  [M:BOD1]CONCATKEY(LIG-1) = num$([M:BOM1]BOMSEQ)+[M:BOM1]CPNITMREF
  [M:BOD1]UPDFLG(LIG-1)  = 1


## 03.07 Demande 40156
##  [M:BOD1]ITMDES1(LIG-1) =[M:BOM1]ZCPNITMREF # l'intitulé
#  If dim([M:BOD1]ZCPNITMREF)>0 & dim([M:BOM1]ZCPNITMREF)=1 : # GH 21/01/2015 bug 105623 ajout du test
#     [M:BOD1]ZCPNITMREF(LIG-1)=[M:BOM1]ZCPNITMREF
#     Affzo [BOD1]ZCPNITMREF(LIG-1)
#  Endif
#
## 03.07 Demande 40156
##  Affzo [BOD1]BOMSEQ(LIG-1), CPNITMREF(LIG-1),ITMDES1(LIG-1)
## GH 21/01/2015 bug 105623
##  Affzo [BOD1]BOMSEQ(LIG-1), CPNITMREF(LIG-1), ZCPNITMREF(LIG-1)
#  Affzo [BOD1]BOMSEQ(LIG-1), CPNITMREF(LIG-1)
#  Affzo [BOD1]BOMSHO(LIG-1), BOMSTRDAT(LIG-1),BOMENDDAT(LIG-1)
#  If dim([M:BOD1]BOMSTRLOT) > 0
#     Affzo [BOD1]BOMSTRLOT(LIG-1),BOMENDLOT(LIG-1)
#  Endif
#  Affzo [BOD1]LIKQTY(LIG-1), QTYRND(LIG-1), LIKQTYCOD(LIG-1), BOMTEXNUM(LIG-1)
#  Affzo [BOD1]PICPRN(LIG-1), SCA(LIG-1)   , CPNOPE(LIG-1)   , BOMOFS(LIG-1)
#  Affzo [BOD1]STU(LIG-1), CPNTYP(LIG-1)   , CSTFLG(LIG-1)    # llc 05.00 sous-produits
#  If dim([M:BOD1]PKC)>0
#    Affzo [BOD1]PKC(LIG-1)
#  Endif
#  # process 03.03 MM
#  If dim([M:BOD1]BOMUOM(LIG-1))>0
#    Affzo [BOD1]BOMUOM(LIG-1),BOMSTUCOE(LIG-1),BOMQTY(LIG-1)
#  Endif
#  # versioning
#  If dim([M:BOD1]ECCVALMAJ)=1
#     Affzo [BOD1]ECCVALMAJ(LIG-1), ECCVALMIN(LIG-1)
#  Endif
#  # Issue 110957 - 2015-09-21 by GH
#  If dim([M:BOD1]CRID)>0
#     Affzo [BOD1]CRID(LIG-1)
#  Endif
# If dim([M:BOD1]CRFLG)>0
#     Affzo [BOD1]CRFLG(LIG-1)
#  Endif
  Call AFFLIG("BOD1","BOD1","NBLIG",LIG-1) From OBJSIM : # GH 11/2015 # enhancement

  #MAE, bg 78723
  #Call VERIF_TEX("BOM1",LIG)
  Call VERIF_TEX("BOM1",LIG-1)
  # fin process 03.03 MM
  FIN = 1

Return

#######################################################################
$OK_BODS
# GA 23/11/2005 écran BOM3 => abrmsk=BOM1, écran BOD3 => abrmsk=BOD1
# validation fiche composant sous-traitance
  # cas de création en mode fiche => incrémenter le nb de lignes tableau
  If [M:BOD1]CREFLG(LIG-1) = 0 & [M:BOD1]CPNITMREF(LIG-1) = ""
     [M:BOD1]NBLIG +=1
  Endif
  # le transclasse a besoin de nolign : (19/01/01)
  nolign = LIG
  [M:BOD1]=[M:BOM1]
  [M:BOD1]CONCATKEY(LIG-1) = num$([M:BOM1]BOMSEQ)+[M:BOM1]CPNITMREF
  [M:BOD1]UPDFLG(LIG-1)  = 1

##  [M:BOD1]ITMDES1(LIG-1) =[M:BOM1]ZCPNITMREF # l'intitulé
#  If dim([M:BOD1]ZCPNITMREF)>0 & dim([M:BOM1]ZCPNITMREF)=1 : # GH 21/01/2015 bug 105623 ajout du test
#     [M:BOD1]ZCPNITMREF(LIG-1)=[M:BOM1]ZCPNITMREF
#     Affzo [BOD1]ZCPNITMREF(LIG-1)
#  Endif
#
##  Affzo [BOD1]BOMSEQ(LIG-1), CPNITMREF(LIG-1),ITMDES1(LIG-1)
#  Affzo [BOD1]BOMSEQ(LIG-1), CPNITMREF(LIG-1)
#  Affzo [BOD1]BOMSHO(LIG-1), BOMSTRDAT(LIG-1), BOMENDDAT(LIG-1)
#  If dim([M:BOD1]BOMSTRLOT) > 0
#     Affzo [BOD1]BOMSTRLOT(LIG-1), BOMENDLOT(LIG-1)
#  Endif
#  Affzo [BOD1]LIKQTY(LIG-1), QTYRND(LIG-1), LIKQTYCOD(LIG-1), BOMTEXNUM(LIG-1)
#
## Issue 77260 - 2011-11-21 by MUARN : Nomenclature sous-traitance pas de CPNOPE
#  Affzo [BOD1]PICPRN(LIG-1), SCA(LIG-1)   , BOMOFS(LIG-1), SCOFLG(LIG-1)
##  Affzo [BOD1]PICPRN(LIG-1), SCA(LIG-1)   , CPNOPE(LIG-1)   , BOMOFS(LIG-1)
## fin Issue 77260 - 2011-11-21 by MUARN : controle type alternative
#
#  Affzo [BOD1]STU(LIG-1), CPNTYP(LIG-1)   , CSTFLG(LIG-1)    # llc 05.00 sous-produits
#  If dim([M:BOD1]BOMUOM(LIG-1))>0
#    Affzo [BOD1]BOMUOM(LIG-1),BOMSTUCOE(LIG-1),BOMQTY(LIG-1)
#  Endif
#  # versioning
#  If dim([M:BOD1]ECCVALMAJ)=1
#     Affzo [BOD1]ECCVALMAJ(LIG-1), ECCVALMIN(LIG-1)
#  Endif
#  # Issue 110957 - 2015-09-21 by GH
#  If dim([M:BOD1]CRID)>0
#     Affzo [BOD1]CRID(LIG-1)
#  Endif
#  If dim([M:BOD1]CRFLG)>0
#     Affzo [BOD1]CRFLG(LIG-1)
#  Endif
  Call AFFLIG("BOD3","BOD1","NBLIG",LIG-1) From OBJSIM : # GH 11/2015 # enhancement

  #MAE, bg 78723
  #Call VERIF_TEX("BOM1",LIG)
  Call VERIF_TEX("BOM1",LIG-1)
  FIN = 1
Return

#######################################################################
$OK_BOSS
# GA 10/01/2006 écrans liste=BOS2, fiche=BOS3
# validation fiche composant sous-traitance
  # cas de création en mode fiche => incrémenter le nb de lignes tableau
  If [M:BOS2]CREFLG(LIG-1) = 0 & [M:BOS2]CPNITMREF(LIG-1) = ""
     [M:BOS2]NBLIG +=1
  Endif
  # le transclasse a besoin de nolign : (19/01/01)
  nolign = LIG
  [M:BOS2]=[M:BOS3]
  [M:BOS2]CONCATKEY(LIG-1) = num$([M:BOS3]BOMSEQ)+[M:BOS3]CPNITMREF
  [M:BOS2]UPDFLG(LIG-1)  = 1

  Affzo [BOS2]
  FIN = 1
Return

#######################################################################
# Action de changement de séquence et fusion : trt standard
#----------------------------------------------------------#
$INIT
Local Integer LIG : LIG = nolign  # sauvegarde nécessaire
Local Integer UPD
# Issue 101112,101113- 2014-09-17 by JUSYN : Opened file BOM again to avoid to have filter from previous functions like GESITF and GESITM.
If GACTION = "TRTBOF"
    Local File BOM [F:BOH]
Endif

Return

#######################################################################
$INIT_DIA0
[M:DIA]BOMSEQ    = [M:BOD1]BOMSEQ(nolign -1)
[M:DIA]CPNITMREF = [M:BOD1]CPNITMREF(nolign -1)
Return

#######################################################################
$INIT_DIA1
[M:DIA]BOMSEQINC = GBOMSTE
Return

#######################################################################
$INIT_DIA2
# GA 23/11/2005 renum opérations nom ss-trait => idem INIT_DIA0
[M:DIA]BOMSEQ    = [M:BOS2]BOMSEQ(nolign -1)
[M:DIA]CPNITMREF = [M:BOS2]CPNITMREF(nolign -1)
Return

#######################################################################
$INIT_DIA3
# GA 23/11/2005 renum opérations nom ss-trait => idem INIT_DIA1
[M:DIA]BOMSEQINC = GBOMSTE
Return

#######################################################################
$EXEC0
UPD = 1   # parce que le ok ne semble pas bien positionné !!! (24/01)
[M:BOD1]BOMSEQ(LIG -1) = [M:DIA]NEWSEQ
[M:BOD1]CREFLG(LIG-1)  = 0 :# pour considérer la ligne comme nouvelle
[M:BOD1]UPDFLG(LIG-1)  = 1
[M:BOD1]CONCATKEY(LIG-1) = num$([M:DIA]NEWSEQ) + [M:BOD1]CPNITMREF(LIG-1)
If !GIMPORT : Affzo [BOD1]BOMSEQ(LIG - 1) : Endif
Return

#######################################################################
$EXEC1
# confirmation de validation de renumérotation globale
Local Integer I, J, LASTSEQ
UPD = 1
LASTSEQ = 0
J = 0
For I = 0 To [M:BOD1]NBLIG - 1
     If [M:DIA]PHASE = 2
         If [M:BOD1]BOMSEQ(I) <> LASTSEQ | LASTSEQ = 0
             LASTSEQ            = [M:BOD1]BOMSEQ(I)
             [M:BOD1]BOMSEQ(I)  = (J + 1 ) * [M:DIA]BOMSEQINC
             J += 1
         Else
             [M:BOD1]BOMSEQ(I)  = [M:BOD1]BOMSEQ(I-1)
         Endif
     Else
             [M:BOD1]BOMSEQ(I)  = (I + 1 ) * [M:DIA]BOMSEQINC
     Endif
     [M:BOD1]CREFLG(I)  = 0 :# pour considérer la ligne comme nouvelle
     [M:BOD1]UPDFLG(I)  = 1
     [M:BOD1]CONCATKEY(I) = num$([M:BOD1]BOMSEQ) + [M:BOD1]CPNITMREF(I)
     If !GIMPORT : Affzo [BOD1]BOMSEQ(I) : Endif
Next I
Return

#######################################################################
$EXEC2
# GA 23/11/2005 renum opérations nom ss-trait => idem EXEC0
# NEWSEQ => NEWSEQS pour contrôle C_NEWSEQS dans le SUBBRP
UPD = 1   # parce que le ok ne semble pas bien positionné !!! (24/01)
[M:BOS2]BOMSEQ(LIG-1)  = [M:DIA]NEWSEQS
[M:BOS2]CREFLG(LIG-1)  = 0 :# pour considérer la ligne comme nouvelle
[M:BOS2]UPDFLG(LIG-1)  = 1
[M:BOS2]CONCATKEY(LIG-1) = num$([M:DIA]NEWSEQS) + [M:BOS2]CPNITMREF(LIG-1)
If !GIMPORT : Affzo [BOS2]BOMSEQ(LIG-1) : Endif
Return

#######################################################################
$EXEC3
# GA 23/11/2005 renum opérations nom ss-trait => idem EXEC1
# confirmation de validation de renumérotation globale
Local Integer I, J, LASTSEQ
UPD = 1
LASTSEQ = 0
J = 0
For I = 0 To [M:BOS2]NBLIG - 1
     If [M:DIA]PHASE = 2
         If [M:BOS2]BOMSEQ(I) <> LASTSEQ | LASTSEQ = 0
             LASTSEQ            = [M:BOS2]BOMSEQ(I)
             [M:BOS2]BOMSEQ(I)  = (J + 1 ) * [M:DIA]BOMSEQINC
             J += 1
         Else
             [M:BOS2]BOMSEQ(I)  = [M:BOS2]BOMSEQ(I-1)
         Endif
     Else
             [M:BOS2]BOMSEQ(I)  = (I + 1 ) * [M:DIA]BOMSEQINC
     Endif
     [M:BOS2]CREFLG(I)  = 0 :# pour considérer la ligne comme nouvelle
     [M:BOS2]UPDFLG(I)  = 1
     [M:BOS2]CONCATKEY(I) = num$([M:BOS2]BOMSEQ) + [M:BOS2]CPNITMREF(I)
     If !GIMPORT : Affzo [BOS2]BOMSEQ(I) : Endif
Next I
Return

#######################################################################
$SORTIE
# pour se mettre en modif au retour du btn
If UPD = 1  mkstat = 4  Endif
# rétablir la classe TBO          23/05/02 (si FIN après boite dialogue Fusion)
If [F:TBO]BOMALT <> [M:BOH0]BOMALT | [F:TBO]BOMALTTYP <> [M:BOH0]BOMALTTYP
    Read [TBO]TBO0=[M:BOH0]BOMALTTYP;[M:BOH0]BOMALT
Endif
Return

#######################################################
# Bouton de Fusion ouvrant la fenêtre de sélection    #
# et rajoutant les liens à la suite des liens existant#
#######################################################
$EXEFUS
# confirmation de validation de fusion
Local Integer LIG
LIG = [M:BOD1]NBLIG
Call OUVRE_TRACE(mess(110,198,1)) From LECFIC
ERR_TRA = mess(34,197,1)-mess(40,197,1)-[M:DIA]ITMSEL-num$([M:DIA]ALTFUS)
Call ECR_TRACE(ERR_TRA,0) From GESECRAN
ERR_TRA = mess(34,197,1)-mess(41,197,1)-[M:BOH0]ITMREF-num$([M:BOH0]BOMALT)
Call ECR_TRACE(ERR_TRA,0) From GESECRAN

Default Mask [BOD1]    : # pour éviter erreur du sous-pro C_...

# rétablir la classe TBO          23/05/02
If [F:TBO]BOMALT <> [M:BOH0]BOMALT | [F:TBO]BOMALTTYP <> [M:BOH0]BOMALTTYP
    Read [TBO]TBO0=[M:BOH0]BOMALTTYP;[M:BOH0]BOMALT
Endif

nolign = [M:BOD1]NBLIG : # les lignes fusionnées seront à la fin
For [BOD] Where ITMREF=[M:DIA]ITMSEL & BOMALT=[M:DIA]ALTFUS & BOMALTTYP = [M:BOH0]BOMALTTYP
    nolign += 1 : # pour simuler une saisie et profiter du C_CPNITMREF
    [M:BOD1]BOMSEQ(nolign-1) = [F:BOD]BOMSEQ :# pour le Ctrl lien
    Raz GMESSAGE
    If [F:BOD]CPNTYP <> 5
        Read [ITM]ITM0=[F:BOD]CPNITMREF  # rajouté le 16/01/02 pour STU et DES1
        Raz GMESSAGE, GERR               # 16/01/02
        Call C_CPNITMREF([F:BOD]CPNITMREF) From SUBBOD
    Endif
    # controles bloquant du composant --> ligne non chargée
    If GMESSAGE <> "" : # tracer l'erreur
       ERR_TRA = GMESSAGE - [F:BOD]CPNITMREF - num$([F:BOD]BOMSEQ)
       If GERR = 2          # seul msg non bloquant (ITF inexistant)
          Call ECR_TRACE(ERR_TRA,0) From GESECRAN
       Else
          nolign -= 1 : # rétablir le bon numero
          Call ECR_TRACE(ERR_TRA,1) From GESECRAN
       Endif
    Endif
    If GMESSAGE = "" | GERR = 2
       Raz GMESSAGE
       Call C_BOMSTRDAT([F:BOD]BOMSTRDAT) From SUBBOD
       Call C_BOMENDDAT([F:BOD]BOMENDDAT) From SUBBOD
       If GMESSAGE <> ""
          ERR_TRA = GMESSAGE-[F:BOD]CPNITMREF-num$([F:BOD]BOMSEQ)
          nolign -= 1 : # rétablir le bon numero (exclusif avec l'autre If)
          Call ECR_TRACE(ERR_TRA,1) From GESECRAN
          Raz GMESSAGE, GERR              # 16/01/02
       Else
          [M:BOD1] = [F:BOD]
          Call APRES_NBLIG  From SUBBOD : # comme pour une ligne saisie !
       Endif
    Endif
Next
[M:BOD1]NBLIG = nolign
If [M:BOD1]NBLIG > LIG
   UPD = 1     # passer en modif seulement si ligne rajoutée (17/01/02)
   Affzo [BOD1]
Endif
Call FERME_TRACE From LECFIC
Return

#######################################################################
$SEL_TABLE
Case GACTION
    When "SELBOM"           : Gosub S_BOM
    When "SELBOMOBJ"        : Gosub S_BOMOBJ
    When "SELBOM2"          : Gosub S_BOM2

Endcase
Return
#######################################################################
$VERF_TABLE

Case GACTION
    When "SELBOMOBJ"   : Gosub VERF_BOMOBJ
Endcase
Return

#######################################################
$S_BOM
# pour l'action SELBOM modélisée
Local Char    WITM(GLONITM)   : WITM = VALEUR
Local Char    WOPT(3)         : WOPT = PARAM(3)            # hcb 37511
Local Integer ICRITERE        :ICRITERE = 0    #gbe 10.08
If clalev([F:BOH]) = 0 : Local File BOM       [BOH] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX] : Endif  # FGR 02/10/2009 : X3SUIVI57935
#
TIT(0) = mess(414,198,1) # Sélection entête nomenclature

# FGR 02/10/2009 : X3SUIVI57935
# FQ 69633 GA 12/2010 il manque GLANGUE dans l'accès AXX0
Link [BOH] With [AXX]AXX0="BOM";"BOMDESAXX";GLANGUE;[F:BOH]IDENT1;num$([F:BOH]BOMALTTYP) As [NEW]

NBCOL  += 1 : COL(NBCOL) = "ITMREF"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "BOMALT"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL +=1  : COL(NBCOL)="mess([F:BOH]BOMALTTYP,224,1)"
Call TEXTFIC("BOM" , "BOMALTTYP", 1,TIT(NBCOL) ) From OBJDIV
# FGR 02/10/2009 : X3SUIVI57935
#NBCOL += 1 : COL(NBCOL) = "BOMDES"
#Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "BOMDESAXX"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
COL(NBCOL) = "[F:AXX]TEXTE"

#
#    When "A" :  CRITERE = "BOMALTTYP = 1"
#    When "B" :  CRITERE = "BOMALTTYP = 2"
#    When "D" :  CRITERE = "BOMALTTYP = 3"
Case WOPT
    When "A" :  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","BOMALTTYP = 1","&") From GOBJSUB
    When "B" :  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","BOMALTTYP = 2","&") From GOBJSUB
    When "D" :  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","BOMALTTYP = 3","&") From GOBJSUB
    When "BD" : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","(BOMALTTYP = 2|BOMALTTYP = 3)","&") From GOBJSUB   # hcb 37511
    When "AB" : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","(BOMALTTYP = 1|BOMALTTYP = 2)","&") From GOBJSUB   # hcb 37511
    When "ABU" : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","(BOMALTTYP = 1|BOMALTTYP = 2) & USESTA = 2","&") From GOBJSUB   # hcb 37511

Endcase

#If CRITERE="" : CRITERE="1=1" : Endif    # mm 03.07

DEFPAG  = 1     : # GA 10/2008 pour que la pagination se fasse
#SIZLIG  = 140
#SIZCOL  = 180
If val(PARAM(1)) <> 0
#  CRITERE += " & BOMALT = val(PARAM(1))"
#  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","BOMALT = "+PARAM(1),"&") From GOBJSUB
  CRITCAR = "BOMALT = "+PARAM(1)
Endif
If PARAM(3) <> ""
#  CRITERE += "& ITMREF = PARAM(3)"
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","ITMREF = '"+PARAM(3)+"'","&") From GOBJSUB
Endif

If CRITERE="" CRITERE = "1=1" Endif

# FGR 02/10/2009 : X3SUIVI57935
#Default File [BOH]
Default File [NEW]

START ='ITMREF'
ORDRE = 'ITMREF;BOMALT;BOMALTTYP'

Return
#######################################################
$S_BOM2
