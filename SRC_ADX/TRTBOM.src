Link [BOHX] With [AXX]AXX0="BOM";"BOMDESAXX";GLANGUE;[F:BOHX]IDENT1;num$([F:BOHX]BOMALTTYP) As [NEW]

NBCOL  += 1 : COL(NBCOL) = "ITMREF"
