NBCOL  += 1 : COL(NBCOL) = "BOMALT"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL +=1  : COL(NBCOL)="mess([F:BOHX]BOMALTTYP,224,1)"
