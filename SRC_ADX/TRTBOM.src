#######################################################
$S_BOMOBJ
# pour l'action SELBOMOBJ modélisée
Local Char    WITM(GLONITM)   : WITM = PARAM(1)
Local Char    WFCY(GLONFCY)   : WFCY = PARAM(2)
Local Integer ICRITERE        :ICRITERE = 0    #gbe 10.08
#
If clalev([F:BOH]) = 0 : Local File BOM       [BOH] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX] : Endif  # FGR 02/10/2009 : X3SUIVI57935

TIT(0) = mess(414,198,1) # Sélection entête nomenclature

# FGR 02/10/2009 : X3SUIVI57935
# FQ 69633 GA 12/2010 il manque GLANGUE dans l'accès AXX0
Link [BOH] With [AXX]AXX0="BOM";"BOMDESAXX";GLANGUE;[F:BOH]IDENT1;num$([F:BOH]BOMALTTYP) As [NEW]

NBCOL  += 1 : COL(NBCOL) = "ITMREF"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "BOMALT"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
# FGR 02/10/2009 : X3SUIVI57935
#NBCOL += 1 : COL(NBCOL) = "BOMDES"
#Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "BOMDESAXX"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
COL(NBCOL) = "[F:AXX]TEXTE"
#
DEFPAG  = 1     : # GA 10/2008 pour que la pagination se fasse
#SIZLIG  = 140
#SIZCOL  = 180
#    When "BOMC" :  CRITERE = "BOMALTTYP = 1"
#    When "BOMP" :  CRITERE = "BOMALTTYP = 2"
#    When "BOMS" :  CRITERE = "BOMALTTYP = 3"
Case GFONBOD
    When "BOMC" :  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","BOMALTTYP = 1","&") From GOBJSUB
    When "BOMP" :  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","BOMALTTYP = 2","&") From GOBJSUB
    When "BOMS" :  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","BOMALTTYP = 3","&") From GOBJSUB
Endcase
If PARAM(1) <> ""
#  CRITERE += "& ITMREF >= WITM"
#  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","ITMREF >= '"+WITM+"'","&") From GOBJSUB
  CRITCAR = "ITMREF >= '"+WITM+"'"
Endif
If WFCY <> ""
#  CRITERE += '[F:BOH]FCY=WFCY | [F:BOH]FCY= ""'
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","([F:BOH]FCY='"+WFCY+"' | [F:BOH]FCY= '')","&") From GOBJSUB
Endif
# FGR 02/10/2009 : X3SUIVI57935
#Default File [BOH]
Default File [NEW]

START ='ITMREF'
ORDRE = 'ITMREF;BOMALT;BOMALTTYP'
Return

############################################################
$SEL_LISTE
Case GACTION
    When "SELBOMALT"        : Gosub S_BOMALT
    When "SELBOMALTM"       : Gosub S_BOMALTM
Endcase
Return


###################################################################
#  sélection des alternatives de nomenclature                     #
###################################################################
$S_BOMALT
Local   Char    WFCY(GLONFCY)
Local   Integer WALTTYP
Local Char    TEX(30)(0..300) , TEXTE(50)(0..300)
Local Char    TIT(30)
Local Integer NBTEX
Local Char    TLIN(60)(300)
Local Integer NLIN : NLIN = 0
Local Integer WLIN : WLIN = 0
Local Char    CRITERE(250)
Local Integer ICRITERE        :ICRITERE = 0    #gbe 10.08
Local Char    SZTBODESAXX(GLONDES) # FGR 16/09/2009 : X3SUIVI57824

If clalev([F:TBO]) = 0 : Local File TABBOMALT [TBO] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA [AXX] : Endif  # FGR 16/09/2009 : X3SUIVI57824

If PARAM(1) <> "" : WFCY    = PARAM(1)      : Endif
If PARAM(2) <> "" : WALTTYP = val(PARAM(2)) : Endif
#CRITERE = "1=1"
If WFCY <> ""
#  CRITERE = '[F:TBO]FCY=WFCY | [F:TBO]FCY= ""'
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","([F:TBO]FCY='"+WFCY+"' | [F:TBO]FCY= '')","&") From GOBJSUB
Endif
If WALTTYP <> 0
#  CRITERE += ' & [F:TBO]BOMALTTYP = WALTTYP'
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","[F:TBO]BOMALTTYP = "+num$(WALTTYP),"&") From GOBJSUB
Endif

If CRITERE="" CRITERE = "1=1" Endif
TIT = mess(26,195,1)
NBTEX  = 0
Filter [TBO] Where evalue(CRITERE)
If WALTTYP = 0
    For [F:TBO]
        # FGR 16/09/2009 : X3SUIVI57824
        Call LECTEXTRA(SZTBODESAXX,"TABBOMALT","TBOSHOAXX",num$([F:TBO]BOMALTTYP),num$([F:TBO]BOMALT)) From ATEXTRA
#        TLIN(NLIN)    = format$("K:2X",num$([F:TBO]BOMALT))-
#&                       format$("K:10X", [F:TBO]TBOSHO) -
#&                       format$("K:10X", mess([F:TBO]BOMALTTYP,224,1))
        TLIN(NLIN)    = format$("K:2X",num$([F:TBO]BOMALT))-
&                       format$("K:10X", SZTBODESAXX) -
&                       format$("K:10X", mess([F:TBO]BOMALTTYP,224,1))
        NLIN += 1
    Next
Else
    For [F:TBO]
        # FGR 16/09/2009 : X3SUIVI57824
        Call LECTEXTRA(SZTBODESAXX,"TABBOMALT","TBOSHOAXX",num$([F:TBO]BOMALTTYP),num$([F:TBO]BOMALT)) From ATEXTRA
#        TLIN(NLIN)    = format$("K:2X",num$([F:TBO]BOMALT))-
#&                       format$("K:10X", [F:TBO]TBOSHO)
        TLIN(NLIN)    = format$("K:2X",num$([F:TBO]BOMALT))-
&                       format$("K:10X", SZTBODESAXX)
        NLIN += 1
    Next
Endif
Filter [TBO]
If NLIN <> 0
   For WLIN = 0 To NLIN-1
       NBTEX += 1 : TEX(NBTEX) = TLIN(WLIN)
   Next
Endif
SIZLIG = 75
SIZCOL = 300
Return

###################################################################
#  sélection des alternatives de nomenclature (multitype)         #
###################################################################
$S_BOMALTM
Local   Char    WFCY(GLONFCY)
Local   Integer WALTTYP
Local Char    TEX(30)(0..300) , TEXTE(50)(0..300)
Local Char    TIT(30)
Local Integer NBTEX
Local Char    TLIN(60)(300)
Local Integer NLIN : NLIN = 0
Local Integer WLIN : WLIN = 0
Local Char    CRITERE(250)
Local Integer ICRITERE        :ICRITERE = 0    #gbe 10.08
Local Char    SZTBODESAXX(GLONDES) # FGR 16/09/2009 : X3SUIVI57824

If clalev([F:TBO]) = 0 : Local File TABBOMALT [TBO] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA [AXX] : Endif  # FGR 16/09/2009 : X3SUIVI57824

If PARAM(1) <> "" : WFCY    = PARAM(1)      : Endif
If PARAM(2) <> "" : WALTTYP = val(PARAM(2)) : Endif
#CRITERE = "1=1"
If WFCY <> ""
#  CRITERE = '[F:TBO]FCY=WFCY | [F:TBO]FCY= ""'
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","([F:TBO]FCY='"+WFCY+"' | [F:TBO]FCY= '')","&") From GOBJSUB
Endif

#    When 1:    CRITERE += ' & [F:TBO]BOMALTTYP = 1'
#    When 2:    CRITERE += ' & [F:TBO]BOMALTTYP = 2'
#    When 3:    CRITERE += ' & find([F:TBO]BOMALTTYP,1,2)'
#    When 4:    CRITERE += ' & [F:TBO]BOMALTTYP = 3'
#    When 5:    CRITERE += ' & find([F:TBO]BOMALTTYP,1,3)'
#    When 6:    CRITERE += ' & find([F:TBO]BOMALTTYP,2,3)'
Case WALTTYP
    When 1:    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","[F:TBO]BOMALTTYP = 1","&") From GOBJSUB
    When 2:    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","[F:TBO]BOMALTTYP = 2","&") From GOBJSUB
    When 3:    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","find([F:TBO]BOMALTTYP,1,2)","&") From GOBJSUB
    When 4:    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","[F:TBO]BOMALTTYP = 3","&") From GOBJSUB
    When 5:    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","find([F:TBO]BOMALTTYP,1,3)","&") From GOBJSUB
    When 6:    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","find([F:TBO]BOMALTTYP,2,3)","&") From GOBJSUB
    When 7:    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","find([F:TBO]BOMALTTYP,1,2,3)","&") From GOBJSUB
Endcase

If CRITERE="" CRITERE = "1=1" Endif
TIT = mess(26,195,1)
NBTEX  = 0
Filter [TBO] Where evalue(CRITERE)

For [F:TBO]
    # FGR 16/09/2009 : X3SUIVI57824
    Call LECTEXTRA(SZTBODESAXX,"TABBOMALT","TBOSHOAXX",num$([F:TBO]BOMALTTYP),num$([F:TBO]BOMALT)) From ATEXTRA
#    TLIN(NLIN)    = format$("K:2X",num$([F:TBO]BOMALT))-
#&                   format$("K:10X", [F:TBO]TBOSHO) -
#&                   format$("K:10X", mess([F:TBO]BOMALTTYP,224,1))
    TLIN(NLIN)    = format$("K:2X",num$([F:TBO]BOMALT))-
&                   format$("K:10X", SZTBODESAXX) -
&                   format$("K:10X", mess([F:TBO]BOMALTTYP,224,1))
    NLIN += 1
Next

If NLIN <> 0
   For WLIN = 0 To NLIN-1
       NBTEX += 1 : TEX(NBTEX) = TLIN(WLIN)
   Next
Endif
SIZLIG = 75
SIZCOL = 300
Return

##############################################################################
Subprog CONTALT(LALT,LTYP)
Value    Integer LALT
Value    Integer LTYP
If LALT = 0 : End : Endif
If clalev([F:TBO]) <= 0 : Local File TABBOMALT [TBO] : Endif
Read [TBO]TBO0=LTYP;LALT
# FQ 60751 GA 12/2009 remplacé par une option de l'objet TBO car trop contraignant ici
#If fstat  | (LTYP = 2 & [F:TBO]MFGUSE <> 2)
If fstat
     GMESSAGE = mess(23,100,1)
     mkstat = 2
     End
Endif
End

##############################################################################
# GA 08/2007 ajout du type d'alternative pour la V6
Subprog CONTALTMPS(LALT,LFCY)
Value    Integer LALT
Value    Char    LFCY

If LALT = 0 : End : Endif

If clalev([F:TBO]) <= 0 : Local File TABBOMALT [TBO] : Endif

Local Integer WTYP  : WTYP=2

Read [TBO]TBO0=WTYP;LALT
If !fstat
    If [F:TBO]FCY <> "" & [F:TBO]FCY <> LFCY
        GMESSAGE = mess(48,193,1)
        mkstat = 2
        End
    Endif
    If [F:TBO]MPSUSE <> 2
        GMESSAGE = mess(15,187,1)
        mkstat = 2
        End
    Endif
Endif
End

##############################################################################
# GA 08/2007 ajout du type d'alternative pour la V6
Subprog CONTALTMRP(LALT,LFCY)
Value    Integer LALT
Value    Char    LFCY

If LALT = 0 : End : Endif

If clalev([F:TBO]) <= 0 : Local File TABBOMALT [TBO] : Endif

Local Integer WTYP  : WTYP=2

Read [TBO]TBO0=WTYP;LALT
If !fstat
    If [F:TBO]FCY <> "" & [F:TBO]FCY <> LFCY
        GMESSAGE = mess(48,193,1)
        mkstat = 2
        End
    Endif
    If [F:TBO]MRPUSE <> 2
        GMESSAGE = mess(15,187,1)
        mkstat = 2
        End
    Endif
Else
    Read [TBO]TBO0=3;LALT
    If !fstat
        If [F:TBO]FCY <> "" & [F:TBO]FCY <> LFCY
            GMESSAGE = mess(48,193,1)
            mkstat = 2
            End
        Endif
        If [F:TBO]MRPUSE <> 2
            GMESSAGE = mess(15,187,1)
            mkstat = 2
            End
        Endif
    Else
        GMESSAGE = mess(23,100,1)
        mkstat = 2
        End
    Endif
Endif
End

#######################################################
Subprog CTLMODALT(LALT,LTYP)
Value Integer LALT
Value Integer LTYP
Goto MODALT
End  # FGR 09/02/2010 : X3SUIVI60986

Subprog CTLACCALT(LALT,LTYP)
Value    Integer LALT
Variable Integer LTYP
# s'il n'y a pas eu de select on doit lire la table ACCES
$MODALT
If LALT <> [F:TBO]BOMALT | LTYP <> [F:TBO]BOMALTTYP
    Read [TBO]TBO0=LTYP;LALT
    #  Alternative de nomenclature inexistante
    If fstat GMESSAGE = mess(154,193,1) : mkstat = 2 : End : Endif
Endif
If GUSRACS=2 End Endif       :# all authorizations !
If [F:TBO]ACSCOD <> "" : # saisie directe de ALTS dans le tableau
   Read [ACC]CODACC = GUSER;[F:TBO]ACSCOD
   If !fstat & [F:ACC]MODIF < 2
     #  "Pas d'autorisation de modif sur cette alternative"
     mkstat=2 : GMESSAGE = mess(144,199,1) : End
   Endif
Endif
End

Subprog CTLVISALT(LALT,LTYP)
Value Integer  LALT     # pour appel depuis traitements (en Variable ça plante!)
Value Integer  LTYP     # pour appel depuis traitements (en Variable ça plante!)
Goto CTLALT
End  # FGR 09/02/2010 : X3SUIVI60986

Subprog CTLCONSALT(LALT,LTYP)
Value    Integer LALT
Variable Integer LTYP

$CTLALT
If GUSRACS=2 : End : Endif       : # all authorizations !
If LALT <> [F:TBO]BOMALT | LTYP <> [F:TBO]BOMALTTYP
    Read [TBO]TBO0=LTYP;LALT
    #  Alternative de nomenclature inexistante
    If fstat GMESSAGE = mess(154,193,1) : mkstat = 2 : End : Endif
Endif
If [F:TBO]ACSCOD <> ""  : # droit de consultation ?
  Call ACCES2([F:TBO]ACSCOD) From OBJDIV
  If mkstat = 2
#  "Pas d'autorisation de consultation sur cette alternative"
     GMESSAGE = mess(296,199,1)
  Endif
Endif
End

#####################################################################
# Gestion du clob dans les fiches nomenclatures                     #
# STANT le 16/10/2008                                               #
# ecran -> le code de l'écran de destination                        #
# Nol -> le n° de ligne de l'écran d'origine                        #
#####################################################################

Subprog LEC_TEX(ECRAN,NOL)
Value Integer NOL
Value Char ECRAN
Local Integer STAT
Local Char PARAM(20)(1..6)
Local Char ACTION(20)
If !clalev([M:ACL]) : Local Mask ACLOB   [ACL] : Endif
If !clalev([F:TXC]) : Local File TEXCLOB [TXC] : Endif

PARAM(1) = [M:BOD1]BOMTEXNUM(NOL)
PARAM(2) = "BOD"
PARAM(3) = "TRTX3TEX"
PARAM(4) = ECRAN
PARAM(5) = num$(NOL+1)
PARAM(6) = num$(GINTTEX)
ACTION = "INIT_DIA"
Gosub ACTION From ACLOB
Assign ("[M:"+ECRAN+"]TEXTE") With [M:ACL]CLOB
End

Subprog VERIF_TEX(ECRAN,NOL)
Value Char ECRAN
Value Integer NOL
Local Integer STAT
Local Char PARAM(20)(1..6)
Local Char ACTION(20)
# variable pour les action dans TRTX3TEX
Local Integer WEXIST
Local Integer WDBASE

WDBASE = 1  # Texte 'donnée de base'

If !clalev([M:ACL]) : Local Mask ACLOB   [ACL] : Endif
If !clalev([F:TXC]) : Local File TEXCLOB [TXC] : Endif
PARAM(1) = [M:BOD1]BOMTEXNUM(NOL)
PARAM(2) = "BOD"
PARAM(3) = "TRTX3TEX"
PARAM(4) = ECRAN
PARAM(5) = num$(NOL+1)
PARAM(6) = num$(GINTTEX)

ACTION = "EXEC"
If [M:ACL]CLOB <> evalue("[M:"+ECRAN+"]TEXTE")
   OMODIF=1
   [M:ACL]CLOB = evalue("[M:"+ECRAN+"]TEXTE")
Endif
Gosub ACTION From ACLOB
#MAE, bg 78723
#[M:BOD1]BOMTEXNUM(NOL-1) = PARAM(1)
[M:BOD1]BOMTEXNUM(NOL) = PARAM(1)
If clalev([M:ACL]) : Close Local Mask [M:ACL] : Endif
End

#####################################################################
# Issue 107513 GA 04/2015 : ECC
########################################################################
# BOMCTRECC : Contrôle versions
########################################################################
# Parameters E : PITM       = Product
#                PMAJ       = Major version
#                PMIN       = Minor version
#                PLOT       = lot
#                PORI       = controled from ... :
#                 0 = Field STRDAT
#                 1 = Field ECCVALMAJ : Mandatory
#                 2 = Field ECCVALMIN : Mandatory
#                 3 = Field ECCVALMAJ : Optional field
#                 4 = Field ECCVALMIN : Optional field
#                PBOMALT    = BOM alternative
#                PTYP       = ECCTYP Flow type Local menu 2059 : 1=Sale, 2=Mfg, 3=Subcontract, [4=Stock]
#                PDATE      = Document date
#
# pre-requesite  : Row [F:ITM] ITMMASTER has to be already loaded
########################################################################
Subprog BOMCTRECC(PITM,PMAJ,PMIN,PLOT,PORI,PBOMALT,PTYP,PDATE)
Value Char    PITM
Value Char    PMAJ
Value Char    PMIN
Value Char    PLOT
Value Integer PORI
Value Integer PBOMALT
Value Integer PTYP
Value Date    PDATE

# ECCTYP Flow type Local menu 2059: 1=Sale, 2=Mfg, 3=Subcontract, [4=Stock]
Local Integer LTYP : LTYP=PTYP
If LTYP=0 LTYP=4 Endif

If GIMPORT
   Global Integer GIMPORT_ERR
   Raz GIMPORT_ERR
Endif

If PORI = 0 & PDATE = [0/0/0] : End : Endif
If PORI = 3 & PMAJ = "" : End : Endif
If PORI = 4 & PMIN = "" : End : Endif

# BOM version management is different of Stock version management

# existence Major version for current product
If !clalev([F:ECS]) : Local File ECCSTA [ECS] : Endif
Read [ECS]ECS0=PITM;PMAJ
If fstat
   If !GIMPORT
      mkstat = 2
      GMESSAGE = mess(406,184,1)-PITM-PMAJ # Version inexistante  !
      End
   Else
      GIMPORT_ERR = 50
      End
   Endif
Endif

If PORI = 3 & PMIN = "" : End : Endif

# existence Major/Minor version for current flow type
If !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif
Read [EVL]EVL1=PITM;PMAJ;PMIN;PTYP
If fstat
   If !GIMPORT
      mkstat = 2
      GMESSAGE = mess(406,184,1)-PITM-PMAJ-PMIN-num$(PBOMALT)-mess(PTYP,2059,1) # Version inexistante !
      End
   Else
      GIMPORT_ERR = 50
      End
   Endif
Else
   Local Date WDATE : WDATE=PDATE
   If WDATE<>[0/0/0] & [F:EVL]STRDAT<>[0/0/0]
     # Issue 111235 - 2016-02-26 by CCC : Derogation date was not considered correctly
     #If WDATE<[F:EVL]STRDAT | ([F:EVL]ENDDAT<>[0/0/0] & WDATE > max([F:EVL]ENDDAT,[F:EVL]EXNDAT))
     If WDATE<[F:EVL]STRDAT
&     | ([F:EVL]ENDDAT<>[0/0/0] & [F:EVL]ENDDAT<WDATE & [F:EVL]EXNFLG=1)
&     | ([F:EVL]EXNDAT<>[0/0/0] & [F:EVL]EXNDAT<WDATE & [F:EVL]EXNFLG=2)
        GMESSAGE = mess(432,184,1)-num$(WDATE) # 'Unavailable version at this date:'
        If PORI=0 : mkstat = 2 : Endif
     Endif
   Endif
   If PBOMALT<>0 & PBOMALT<>[F:EVL]BOMALT
      mkstat = 2
      GMESSAGE = mess(15,187,1)-PITM-PMAJ-PMIN-num$(PBOMALT)-mess(PTYP,224,1) # BOM alternative not authorized
      End
   Endif
Endif

End


# Issue 107513 GA 04/2015 : ECC
########################################################################
# BOMFINDECC : Find version compatible with specified date for BOM
########################################################################
# Parameters E : PITM       = Product
#                PMAJ       = Major version
#                PMIN       = Minor version
#                PLOT       = lot
#                PALTTYP    = BOMALTTYP 2=Production, 3=Subcontracting
#                PBOMALT    = BOM alternative
#                PDATE      = Document date
#
# pre-requesite  : Row [F:ITM] ITMMASTER has to be already loaded
########################################################################
Subprog BOMFINDECC(PITM,PMAJ,PMIN,PLOT,PBOMALT,PALTTYP,PDATE)
Value    Char    PITM
Variable Char    PMAJ
Variable Char    PMIN
Value    Char    PLOT
Value    Integer PBOMALT
Value    Integer PALTTYP
Value    Date    PDATE

Local Date WDATE : WDATE=PDATE

# BOM version management is different thant Stock version management
If PBOMALT=0 End Endif

If WDATE=[0/0/0] WDATE=date$ Endif

# existence Major/Minor version for current flow type (= BOM alterntive type in this case)
If !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif
Filter [EVL] Where ITMREF=PITM & ECCTYP=PALTTYP & BOMALT=PBOMALT Order By EXNFLG
For [EVL]
   If WDATE>=[F:EVL]STRDAT & ([F:EVL]ENDDAT=[0/0/0] | WDATE <= max([F:EVL]ENDDAT,[F:EVL]EXNDAT))
      PMAJ=[F:EVL]ECCVALMAJ
      PMIN=[F:EVL]ECCVALMIN
      Break
   Endif
Next
Filter [EVL]

End

