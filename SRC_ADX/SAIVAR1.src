#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du masque SAIVAR
#CHECK UNUSED_SOURCE

$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "SEL_TABLE" : Gosub SEL_TABLE
Endcase
Return

$OUVRE
Local File GVARIA [VRI]
Return

$SEL_TABLE
Case TABLE
  When "SELMAT"
  OBJET = "GRH"
  START = "MATRI"
  CRITERE="FLAG=2"
  ORDRE = "MATRI"
Endcase
Return



