$AB_CREATION
  # FGR 21/08/2009 : X3SUIVI57317 : Le Unlock ne fonctionne pas dans une transaction. Mettre en APRES_CRE
  #Dévérouillage de la demande
  Call UNLOCKSRE([M:ITN0]SRVDEMNUM) From SUBITNB1
Return

##########################################################################################################
$FILTRE
  Default File [ITN]
Return

##########################################################################################################
$FILGAUCHE
Local Integer IITNPEFLT
Local Integer IMAINITNPEFLT

  Default File [ITN]
  IMAINITNPEFLT = 0
  IITNPEFLT = 0
  #Délégation du filgauche complet à un point d'entrée
  Gosub PE_MAINITNFLT From TRTCRMPE
  If IMAINITNPEFLT Then
    Return
  Endif
  If currbox = GBOXITN Then
    #Interventions à effectuer
    Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "DON <> 2", "&") From GOBJSUB
  Elsif currbox = GBOXIT2 Then
    #Interventions effectuées
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "DON = 2", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "ITN") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Elsif currbox = "GAU_CHE9" Then
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "ITN") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Else
    #Gestion des browsers générés par transaction de saisie
    IITNPEFLT = 0
    #Les filtres sont posés par point d'entrée.
    Gosub PE_ITNFLT From TRTCRMPE
    If IITNPEFLT Then
      Return
    Endif
    Case currbox
      When GBOXITNSP1
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZITNFILGAUFLT(0), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "ITN") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
      When GBOXITNSP2
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZITNFILGAUFLT(1), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "ITN") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
      When GBOXITNSP3
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZITNFILGAUFLT(2), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "ITN") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
      When GBOXITNSP4
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZITNFILGAUFLT(3), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "ITN") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
      When GBOXITNSP5
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZITNFILGAUFLT(4), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "ITN") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
      When GBOXITNSP6
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZITNFILGAUFLT(5), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "ITN") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
      When GBOXITNSP7
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZITNFILGAUFLT(6), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "ITN") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
    Endcase
  Endif
Return

##########################################################################################################
$LIENS
Local Integer INBRER
Local Char SZCODPLC

  Raz [M:ITN0]RERDEL
  [M:ITN0]ITNSYM = SYMBOLE
  GITNUDDHDTFLG = ""
  [M:ITN0]CREFBDFLG = 0
  If GFCY <> [M:ITN0]SALFCY Then
    GFCY = [M:ITN0]SALFCY
    Call INIT_GLOBAL_CPT(GFCY,"HTR",3,GHDKTRSITN) From TRTX3CPT
  Endif
  # Issue X3-38449 - 2017-10-09 by FGR : BEGIN was missing here
  Local Char    WPLISTC(250)

  Call ALICOLREM (1,0,"","ITN8", "", 1,WPLISTC) From TRTPRICE
  # Issue X3-38449 - 2017-10-09 by FGR : END
  #----- Affichage entêtes de colonne variables -----#
  Gosub AFF_TITCOL From SUBITNB1
  #---------------------------------------------------#
  # Sorties de stock
  #---------------------------------------------------#
  Raz GITN8HDTISSISS
  Raz GITN8DIRTYISSISS
  [M:ITN0]STKFLG = 1
  Call SETENTCOD([M:ITN0]SRVDEMNUM, [M:ITN0]ENTCOD, [M:ITN0]TRSFAM, [M:ITN0]TRSCOD) From SUBITNB3
  INBRER = 0
  #Lecture du clob compte-rendu
  Gosub LOADHD2 From SUBITNB1
  #Enregistrement des horodatages
  If GIITN8TIMFLG Then
    Call MNGHORO(GIITN8TIMITNNUM, GIITN8TIMHDTNUM, GIITN8TIMNOL, 0) From SUBITNB2
  Endif
  #---------------------------------------------------#
  # Origine
  #---------------------------------------------------#
  If [M:ITN1]CREUSR <> "" Then
     Read [AUS]CODUSR=[M:ITN1]CREUSR
     [M:ITN1]FULNAMUSR = [F:AUS]NOMUSR
     Affzo [M:ITN1]FULNAMUSR
  Endif
  If [M:ITN1]ITNORI = 0 Then
    [M:ITN1]ITNORI = 1
  Endif
  #Définition du type de pièce
  Case [M:ITN1]ITNORI
    When 1
      [M:ITN1]ITNORITYP = ""
    When 2
      [M:ITN1]ITNORITYP = ""
    When Default
  Endcase
  Diszo [M:ITN1]ITNORIVCR
  #---------------------------------------------------#
  # Affiche les champs totaux de gestion du temps
  #---------------------------------------------------#
  [M:ITN8]HOUTIT = mess(1,301,1)
  [M:ITN8]MNTTIT = mess(2,301,1)
  [M:ITN8]TITSVCPLN = mess(233,182,1)
  [M:ITN8]TITSVCDON = mess(234,182,1)
  [M:ITN8]TITSVCRMN = mess(158,182,1)
  [M:ITN8]TITTIMSPG= mess(415,177,1)
  Affzo [M:ITN8]HOUTIT, MNTTIT, TITSVCPLN, TITSVCDON, TITSVCRMN, TITTIMSPG
  #---------------------------------------------------#
  # Affiche l'intervenant
  #---------------------------------------------------#
  If [M:ITN1]SCO = 2 Then
    If [M:ITN1]SCONUM = "" Then
      [M:ITN1]ITNASS = ""
      [M:ITN1]ITNASSCLA = ""
    Else
      Read [BPR]BPR0=[M:ITN1]SCONUM
      If fstat Then
        [M:ITN1]ITNASS = ""
        [M:ITN1]ITNASSCLA = ""
      Else
        [M:ITN1]ITNASS = [F:BPR]BPRNUM
        [M:ITN1]ITNASSCLA = [F:BPR]BPRNAM
      Endif
    Endif
  Else
    If [M:ITN1]REP = "" Then
      [M:ITN1]ITNASS = ""
      [M:ITN1]ITNASSCLA = ""
    Else
      Read [AUS]CODUSR=[M:ITN1]REP
      If fstat Then
        [M:ITN1]ITNASS = ""
        [M:ITN1]ITNASSCLA = ""
      Else
        [M:ITN1]ITNASS = [F:AUS]USR
        [M:ITN1]ITNASSCLA = [F:AUS]NOMUSR
      Endif
    Endif
  Endif
  If [M:ITN1]SCO = 2 Then
    Actzo [M:ITN1]SCOAMT
    Actzo [M:ITN1]CUR
  Else
    Grizo [M:ITN1]SCOAMT
    Grizo [M:ITN1]CUR
  Endif
  #Contrôle du pays
  If [M:ITN3]CRY = "" Then
    [M:ITN3]CRY = GPAYS
  Endif
  #Initialisation des champs d'expression d'unité
  [M:ITN3]TRITIMX = mess(2,301,1)
  [M:ITN1]DURX = mess(1,976,1)
  If GIDISTYP = 0
    [M:ITN3]DTCKILX = mess(1,2964,1) #Kilomètres
  Else
    [M:ITN3]DTCKILX = mess(GIDISTYP,2964,1) #Kilomètres ou Miles
  Endif
  [M:ITN4]TIMSPGX = mess(1,976,1)  #Heures
  [M:ITN4]TIMSPGY = mess(933,182,1)   #Minutes
  #Obtenir une adresse toujours fraiche
  If [M:ITN3]ITNTYPADD < 99 Then
    SZCODPLC = func SUBITNB1.GET_LIEU_ITN([M:ITN1]TYP, 0)
    If (SZCODPLC = "OUT" or SZCODPLC = "IN") and [M:ITN3]ITNRECADD <> "" Then
      Call LOADITNPLC From SUBITNB1
    Else
      Call SET_LIEU_ITN([M:ITN1]TYP, [M:ITN0]SALFCY, [M:ITN0]BPC, [M:ITN0]CCN) From SUBITNB1
    Endif
  Endif
  # Calcul de NBRER pour le tableau des ressources.
  [M:ITN7]NBRER = 0
  For INBRER = 0 To dim([F:ITN]RER)-1
    If [M:ITN7]RER(INBRER) = "" Then
      Break
    Else
      Call LECTURE_RESRES (INBRER, [M:ITN7]RER(INBRER)) From SUBITNB1  # FGR 24/07/2009 : X3SUIVI56702
    Endif
    [M:ITN7]NBRER += 1
  Next
  #Chargement des consommations
  Call RAZSTOSORW From STKSOR
  Call LOADHDT([M:ITN0]NUM) From SUBITNB2
  Call ETAZONSOR("ITN8") From STKECR
  #Variable pour la saisie d'une fiche solution
  GIITNCOUNT = 0
  #---------------------------------------------------#
  # Gestion des valeurs modifiées
  #---------------------------------------------------#
  Gosub SETPREVAL From SUBITNB3
  #---------------------------------------------------#
  # Contrôle du statut clôturé d'une demande
  #---------------------------------------------------#
  [M:ITN0]SRESTOFCY = ""
  If [M:ITN0]SRVDEMNUM = "" Then
    Grizo [M:ITN8]5
  Else
    Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
    If fstat Then
      Grizo [M:ITN8]5
    Else
      If [F:SRE]SREASS = 5 Then
        Grizo [M:ITN8]5
      Else
        Actzo [M:ITN8]5
      Endif
      [M:ITN0]SRESTOFCY = [F:SRE]STOFCY
    Endif
  Endif
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBITNB1
  # FGR 15/02/2010 : X3SUIVI62427 (fin)
  Read [BPC]BPC0=[M:ITN0]BPC
  Call DISPICON_BPC([F:BPC]OSTCTL) From SUBITNB1
  # FGR 15/02/2010 : X3SUIVI62427 (fin)
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBITNB1
  #---------------------------------------------------#
  # Calcul le nombre maximum d'intervention que l'on peut ajouter sur une intervention.
  #---------------------------------------------------#
  Call ITNNBRSREHDT From SUBITNB3
  Call SETTZN From SUBITNB3
  Diszo [M:ITN0]SRVDEMNUM
  Diszo [M:ITN0]BPC
  [M:ITN0]CURSRETUN = [M:ITN0]SRVDEMNUM
  [M:ITN0]CURBPCTUN = [M:ITN0]BPC
  If [M:ITN8]NBLIG > 0 Then
    Grizo [M:ITN0]SALFCY
  Else
    Actzo [M:ITN0]SALFCY
  Endif
  Actzo [M:ITN4]PBLSOL
  Actzo [M:ITN4]HTOTTIMSPG
  Actzo [M:ITN4]MTOTTIMSPG
  Actzo [M:ITN8]HTIMSPG
  Actzo [M:ITN8]MTIMSPG
  #
  Affzo [M:ITN0]1-99
  Affzo [M:ITN3]TRITIMX
  Affzo [M:ITN1]DURX
  Affzo [M:ITN3]DTCKILX
  Affzo [M:ITN4]TIMSPGX
  Affzo [M:ITN4]TIMSPGY
  # Issue SAM120376 - 2017-01-09 by FGR : BEGIN
  For ILINDEB = 0 To [M:ITN8]NBLIG-1
    Call SET_HDTAMTINV_ENABLE_DISABLE([M:ITN8]HDTINV(ILINDEB), ILINDEB)
  Next ILINDEB
  # Issue SAM120376 - 2017-01-09 by FGR : END
Return

##########################################################################################################
$AAPRES_NBLIG
Local Integer NOL
Local Integer WRET

  NOL = nolign-1
  Raz WRET
  Raz GOUVSOR
  # Si suppression ligne
  If find(status,65,68,83) Then
    Return
  Endif
  # Si sortie tableau non validante
  If adxgtb = 1 Then
    Return
  Endif
  If [M:ITN8]HDTTYP(nolign-1) = 2 Then
    If [M:ITN8]HDTDONDAT(nolign-1) <> [00/00/00] Then
      If [M:ITN8]HDTSTOISS(nolign-1) = 2 Then
        If [M:ITN8]HDTISSQTY(nolign-1) > 0 Then
          If [M:ITN8]HDTISSISS(nolign-1) <= 0 Then
            Gosub ALI_ALP From SUBITNB2
            # Détermination du stock à sortir (automatisme, saisie)
            Call OUVSOR("ITN8", NOL, [M:ITN8]NBLIG, [M:ITN8]WSTOSEQ(NOL), [M:ITN0]STKFLG, WRET) From STKSOR
            # FGR 05/08/2010 : X3SUIVI66063 (début)
            If WRET = 0 Then
              [M:ITN8]HDTISSISS(nolign-1) = [M:ALP]QTY
              [M:ITN8]HDTISSQTY(nolign-1) = [M:ALP]QTY
              If [M:ITN8]HDTISSISS(nolign-1) = 0 Then
                [M:ITN8]HDTSTOISS(nolign-1) = 1
                [M:ITN8]SAVSTOISS(nolign-1) = 1
              Endif
            Endif
            # FGR 05/08/2010 : X3SUIVI66063 (fin)
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$AB2_NBLIG
  #-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
  # hcb 27842
Local Integer NOL

  NOL = nolign-1
  Raz GBIDI2
  GFCY=[M:ITN8]HDTSTOFCY(NOL)
  GBIDC2 = "K"
  Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2 Then
    GMESSAGE = mess(2,104,1)
    GOUVSOR = 0
    Return
  Else
   GOUVSOR = 1
  Endif
Return

##########################################################################################################
$BB2_NBLIG
Local Integer NOL

  # FGR 13/10/2010 : X3SUIVI68214 : Si annulation sortie de stock décocher aussi
  NOL = nolign-1
  If [M:ITN8]HDTISSISS(NOL) = 0 Then
    [M:ITN8]HDTSTOISS(NOL) = 1
    [M:ITN8]SAVSTOISS(NOL) = 1
    [M:ITN8]HDTISSQTY(NOL) = 0
    Affzo [M:ITN8]HDTSTOISS(NOL)
  Endif
Return

##########################################################################################################
$BB6_ITNASS
  # FGR 01/03/2010 : X3SUIVI62972
  Affzo [M:ITN1]ITNASS
  Affzo [M:ITN1]DAT
  Affzo [M:ITN1]HOU
  Affzo [M:ITN1]DATEND
  Affzo [M:ITN1]HOUEND
Return

##########################################################################################################
Subprog SET_HDTAMTINV_ENABLE_DISABLE(IHDTINV, ILINE)
Value Integer IHDTINV
Value Integer ILINE

  # Issue SAM120376 - 2017-01-09 by FGR
  If IHDTINV = 2 Then
    Actzo [M:ITN8]HDTAMTINV(ILINE)
  Else
    Diszo [M:ITN8]HDTAMTINV(ILINE)
  Endif
End

