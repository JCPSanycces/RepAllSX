$AVANTBOUT
Return

##########################################################################################################
$AVANT_CHOI

  If GBCRMFLGNEW = 1 Then
    REPONSE = GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    GBCRMFLGNEW = 0
  Endif
Return

##########################################################################################################
$RAZCRE
Local Char SZNVGCOD
Local Integer IUPDSRE
Local Char SZITNNUM(GLONVCR)
Local Char SZMESS(250)
Local Integer IERRINF
Local Integer IONREP       # FGR 15/02/2010 : X3SUIVI62427
Local Char SZMESS(250)     # FGR 15/02/2010 : X3SUIVI62427

  Raz SZNVGCOD
  [M:ITN0]ITNSYM = ""
  IERRINF = 0
  #Contrôle que l'on peut créer une intervention
  #LSE 09/01/2007
  If GPILNAV > 1 Then
    Case GNAVIG(GPILNAV-1)
      When "GESSRE"
        Call LOCKSRE([M:SRE0]SRENUM, IUPDSRE) From SUBITNB1
      When "FUNHDKAGD"
        Call LOCKSRE([M:ITN0]SRVDEMNUM, IUPDSRE) From SUBITNB1
      When Default
        IUPDSRE = 0
    Endcase
  Endif
  # Issue X3-38449 - 2017-10-09 by FGR : BEGIN was missing here
  Local Char    WPLISTC(250)

  Call ALICOLREM (1,0,"","ITN8", "", 1,WPLISTC) From TRTPRICE
  # Issue X3-38449 - 2017-10-09 by FGR : END
  #LSE 21/12/2005 Import intervention FQ 33982
  If GIMPORT Then
    IUPDSRE = 1
  Endif
  If !IUPDSRE Then
    #Modification impossible. Intervention en cours de saisie sur un autre poste.
    SZMESS = mess(592,182,1)
    GMESSAGE = SZMESS
    GERR = 2
    Raz [M:ITN0]
    Raz [M:ITN1]
    Raz [M:ITN3]
    Raz [M:ITN7]
    Raz [M:ITN8]
    Raz [M:ITN4]
    [M:ITN0]CREFBDFLG = 1
    Return
  Endif
  #
  #Photo des points pour abandon
  Call PITAVANTMOD([M:ITN0]SRVDEMNUM, IERRINF) From SUBSREB3
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
    Raz [M:ITN0]
    Raz [M:ITN1]
    Raz [M:ITN3]
    Raz [M:ITN7]
    Raz [M:ITN8]
    Raz [M:ITN4]
    Return
  Endif
  #Enregistrement des horodatages
  If GIITN8TIMFLG Then
    GITNUDDHDTFLG = "RAZCRE"
    Call MNGHORO(GIITN8TIMITNNUM, GIITN8TIMHDTNUM, GIITN8TIMNOL, 0) From SUBITNB2
    GITNUDDHDTFLG = ""
  Endif
  #
  #---------------------------------------------------#
  #  Affiche les champs totaux de gestion du temps
  #---------------------------------------------------#
  [M:ITN8]HOUTIT = mess(1,301,1)
  [M:ITN8]MNTTIT = mess(2,301,1)
  [M:ITN8]TITSVCPLN = mess(233,182,1)
  [M:ITN8]TITSVCDON = mess(234,182,1)
  [M:ITN8]TITSVCRMN = mess(158,182,1)
  [M:ITN8]TITTIMSPG= mess(415,177,1)
  Affzo [M:ITN8]HOUTIT, MNTTIT, TITSVCPLN, TITSVCDON, TITSVCRMN, TITTIMSPG
  #Initialise les valeurs par défaut de l'enregistrement
  #
  #LSE V150 09/08/2005
  #On initialise le site
  Call SITECRMDEF("HDK", [M:ITN0]SALFCY) From CRM_UTIL
  If GFCY <> [M:ITN0]SALFCY Then
    GFCY = [M:ITN0]SALFCY
    Call INIT_GLOBAL_CPT(GFCY,"HTR",3,GHDKTRSITN) From TRTX3CPT
    Call GLOBVAR(GFCY) From WWGLOBTC  # FGR 05/12/2008 : Chargement des paramètres tronc commun
  Endif
  #
  Raz [M:ITN0]RERDEL
  Call DEFVALADI(407, [M:ITN1]TYP) From CRMUTIL140
  [M:ITN3]TRITIMX = mess(2,301,1)   #Minutes
  [M:ITN1]DURX = mess(1,976,1)      #Heures
  If GIDISTYP = 0 Then
    [M:ITN3]DTCKILX = mess(1,2964,1) #Kilomètres
  Else
    [M:ITN3]DTCKILX = mess(GIDISTYP,2964,1) #Kilomètres ou Miles
  Endif
  #[M:ITN2]SRVCONCOV = 1
  [M:ITN1]CUR = ""
  [M:ITN1]SCO = 1
  Grizo [M:ITN1]SCONUM
  Grizo [M:ITN1]SCOAMT
  Grizo [M:ITN1]CUR
  #
  [M:ITN3]CRY = GPAYS
  [M:ITN4]TIMSPGX = mess(1,976,1)   #Heures
  [M:ITN4]TIMSPGY = mess(933,182,1)   #Minutes
  #Grizo [M:ITN1]DUR # FGR 05/09/2008 : X3SUIVI33081 : la durée reste toujours modifiable
  Grizo [M:ITN1]DURX
  #
  [M:ITN1]CREDAT = date$
  [M:ITN1]CREUSR = GUSER
  If [M:ITN1]CREUSR <> "" Then
     Read [AUS]CODUSR=[M:ITN1]CREUSR
     [M:ITN1]FULNAMUSR = [F:AUS]NOMUSR
     Affzo [M:ITN1]FULNAMUSR
  Endif
  [M:ITN1]ITNORITYP = ""
  [M:ITN1]ITNORI = 1
  Diszo [M:ITN1]ITNORIVCR
  #
  #Définit les valeurs liées à la demande de service.
  Call SETSREINF("RAZCRE") From SUBITNB1
  #Variable pour la saisie d'une fiche solution
  GIITNCOUNT = 0
  #
  If TUNNEL = 0 Then
    #On ne vient de nulle part
    SZNVGCOD = "1"
  Elsif GPILNAV > 1 Then
    Case GNAVIG(GPILNAV-1)
      When "GESSRE"
        SZNVGCOD = [M:SRE0]NVGCOD
      When "FUNHDKAGD"
        SZNVGCOD = [M:HDK0]NVGCOD
      When Default
        SZNVGCOD = "1"
    Endcase
  Endif
  If SZNVGCOD = "" Then
    # FGR 20/08/2009 : X3SUIVI57304 : Si vide, par défaut c'est "1"
    SZNVGCOD = "1"
  Endif
  # --------------------------------------
  # FGR 25/08/2016 : X3SUIVI114897 (début)
  #  If SZNVGCOD = "1" Then
  #    #Intervention à planifier
  #    [M:ITN0]DON = 1
  #    [M:ITN1]DAT = date$ + 1
  #    [M:ITN1]HOU = "0900"
  #  Elsif SZNVGCOD = "2" Then
  #    #Intervention effectuée
  #    [M:ITN0]DON = 2
  #    [M:ITN1]DAT = date$
  #    [M:ITN1]HOU = left$(time$, 2) + mid$(time$, 4, 2)
  #  Endif
  #  #Planification par défaut
  #  Call SETDEFPLN([M:ITN1]DAT, [M:ITN1]HOU, [M:ITN8]HOUSVCPLN, [M:ITN8]MNTSVCPLN) From SUBITNB2
  #
  Local Integer IPEFORCEHOU

  IPEFORCEHOU = 0
  Gosub PE_ITNFORCEHOU From TRTCRMPE
  If IPEFORCEHOU = 0 Then
    If SZNVGCOD = "1" Then
      #Intervention à planifier
      [M:ITN0]DON = 1
      [M:ITN1]DAT = date$ + 1
      [M:ITN1]HOU = "0900"
    Elsif SZNVGCOD = "2" Then
      #Intervention effectuée
      [M:ITN0]DON = 2
      [M:ITN1]DAT = date$
      [M:ITN1]HOU = left$(time$, 2) + mid$(time$, 4, 2)
    Endif
    #Planification par défaut
    Call SETDEFPLN([M:ITN1]DAT, [M:ITN1]HOU, [M:ITN8]HOUSVCPLN, [M:ITN8]MNTSVCPLN) From SUBITNB2
  Endif
  # FGR 25/08/2016 : X3SUIVI114897 (fin)
  # --------------------------------------
  #---------------------------------------------------#
  # Gestion des valeurs modifiées
  #---------------------------------------------------#
  Gosub SETPREVAL From SUBITNB3
  #Utilisation ou non du site du représentant
  Call SITECRMINTREP("HDK", [M:ITN1]ITNASS, [M:ITN0]SALFCY) From CRM_UTIL
  Call SETSITECRM("HDK", [M:ITN0]BPC, "", [M:ITN0]SALFCY) From CRM_UTIL
  If GFCY <> [M:ITN0]SALFCY Then
    GFCY = [M:ITN0]SALFCY
    Call INIT_GLOBAL_CPT(GFCY,"HTR",3,GHDKTRSITN) From TRTX3CPT
    Call GLOBVAR(GFCY) From WWGLOBTC  # FGR 05/12/2008 : Chargement des paramètres tronc commun
  Endif
  #----- Affichage entêtes de colonnes variables -----
  Gosub AFF_TITCOL From SUBITNB1
  #---------------------------------------------------#
  # Sorties de stock
  #---------------------------------------------------#
  [M:ITN0]STKFLG = 1
  Call RAZSTOSORW From STKSOR
  Raz GITN8HDTISSISS
  Raz GITN8DIRTYISSISS
  [M:ITN0]CREFBDFLG = 0
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBITNB1
  # FGR 15/02/2010 : X3SUIVI62427 (début)
  Read [BPC]BPC0=[M:ITN0]BPC
  If [F:BPC]OSTCTL = 3 Then
    SZMESS = [M:ITN0]BPC - ":" - mess(2,178,1)
    Call OUINON(SZMESS, IONREP) From GESECRAN
    If IONREP <> 2 Then
      # Client bloqué
      GMESSAGE = SZMESS
      GERR = 2
      Raz [M:ITN0]
      Raz [M:ITN1]
      Raz [M:ITN3]
      Raz [M:ITN7]
      Raz [M:ITN8]
      Raz [M:ITN4]
      Return
    Endif
  Endif
  # FGR 15/02/2010 : X3SUIVI62427 (fin)
  Call DISPICON_BPC([F:BPC]OSTCTL) From SUBITNB1
  # FGR 15/02/2010 : X3SUIVI62427 (fin)
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBITNB1
  #---------------------------------------------------#
  # Calcul le nombre maximum d'intervention que l'on peut ajouter sur une intervention.
  #---------------------------------------------------#
  Call ITNNBRSREHDT From SUBITNB3
  Call SETTZN From SUBITNB3
  Diszo [M:ITN0]SRVDEMNUM
  Diszo [M:ITN0]BPC
  [M:ITN0]CURSRETUN = [M:ITN0]SRVDEMNUM
  [M:ITN0]CURBPCTUN = [M:ITN0]BPC
  If [M:ITN8]NBLIG > 0 Then
    Grizo [M:ITN0]SALFCY
  Else
    Actzo [M:ITN0]SALFCY
  Endif
  If [M:ITN0]DON <> 2 Then
    Grizo [M:ITN4]PBLSOL
    Grizo [M:ITN4]HTOTTIMSPG
    Grizo [M:ITN4]MTOTTIMSPG
    Grizo [M:ITN8]HTIMSPG
    Grizo [M:ITN8]MTIMSPG
  Endif
  #Vérifie si l'intervention est associée à une demande de service
  If !GERR Then
    #LSE 21/12/2005 Import intervention FQ 33982
    If !GIMPORT Then
      If [M:ITN0]SRVDEMNUM = "" Then
        #Aucune demande de service n'est associée à cette intervention. Création refusée.
        GMESSAGE = mess(236,182,1)
        GERR = 2
      Endif
    Endif
  Endif
  Affzo [M:ITN0]1-99
  Affzo [M:ITN1]1-99
  Affzo [M:ITN3]1-99
  Affzo [M:ITN4]1-99
  Affzo [M:ITN8]1-99
Return

##########################################################################################################
$ABANDON
Local Integer ITERABA
Local Integer ISTOERR
Local Integer IERRINF
Local Integer ZH

  ISTOERR = 0
  IERRINF = 0
  # Sortie de stock
  Raz GITN8HDTISSISS
  Raz GITN8DIRTYISSISS
  For ITERABA = 0 To [M:ITN8]NBLIG-1
    Call DELSTOSORW(ITERABA, ITERABA, "ITN8", [M:ITN8]HDTSTOFCY(ITERABA), ISTOERR) From STKSOR
    If ISTOERR Then
      Break
    Endif
  Next
  If ISTOERR Then
    Return
  Endif
  #Clobs temporaires sur consommations
  Call DEBTRANS From GLOCK
  Trbegin [HD7]
  Delete [HD7] Where [F:HD7]PRONUM = adxuid(1)
  If fstat Then
    #Erreur lors de la suppression des textes saisis sur les consommations.
    GMESSAGE = mess(907,182,1)
    GERR = 1
    Rollback
    Return
  Else
    Commit
  Endif
  #On déverrouille la demande
  Call UNLOCKSRE([M:ITN0]SRVDEMNUM) From SUBITNB1
  #Restauration des points
  Call PITABANDON([M:ITN0]SRVDEMNUM, IERRINF) From SUBSREB3
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
    Return
  Endif
  #Supprime les éventuelles réservations de ressources effectuées
  If [M:ITN0]NUM = "" Then
    Call DEBTRANS From GLOCK
    Trbegin [RRS]
    For ZH = 0 To [M:ITN7]NBRER-1
      If [M:ITN7]RER(ZH) <> "" Then
        Read [RRS]RRS0=[M:ITN7]RER(ZH)
        If !fstat Then
          Delete [RRS]Curr
          If fstat Then
            GERR = 1
            #Erreur lors de la suppression des réservations de ressources. Suppression interrompue.
            GMESSAGE = mess(476,196,1)
            Rollback
            Break
          Endif
        Endif
      Endif
    Next
    If GERR Then
      Return
    Endif
    For ZH = 0 To dim([M:ITN0]RERDEL)-1
      If [M:ITN0]RERDEL(ZH) <> "" Then
        Read [RRS]RRS0=[M:ITN0]RERDEL(ZH)
        If !fstat Then
          Delete [RRS]Curr
          If fstat Then
            GERR = 1
            #Erreur lors de la suppression des réservations de ressources. Suppression interrompue.
            GMESSAGE = mess(476,196,1)
            Rollback
            Break
          Endif
        Endif
      Endif
    Next
    If GERR Then
      Return
    Endif
    Commit
  Endif
  Raz [M:ITN0]RERDEL
  #Suppression du contrôle de session
  Call RAZPRONUM From SUBSREB3
  [M:ITN0]CREFBDFLG = 0
  Actzo [M:ITN4]PBLSOL
  Actzo [M:ITN4]HTOTTIMSPG
  Actzo [M:ITN4]MTOTTIMSPG
  Actzo [M:ITN8]HTIMSPG
  Actzo [M:ITN8]MTIMSPG
Return

##########################################################################################################
$AVANT_MOD
Local Char SZITNNUM(GLONVCR)
Local Integer IERRINF

  IERRINF = 0
  #Si la demande est lockée, on ne vas pas plus loin
  Gosub AVMCTLLOCKITN From SUBITNB3
  If !IUPDSRE Then
    OK = 0
    Return
  Endif
  #Photo des points pour abandon
  Call PITAVANTMOD([M:ITN0]SRVDEMNUM, IERRINF) From SUBSREB3
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
    Return
  Endif
  If !GERR Then
    If [M:ITN0]SRVDEMNUM <> "" Then
      Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
      If !fstat Then
        If [F:SRE]SREASS = 5 Then
          #Vous modifiez une intervention relative à une demande de service clôturée.
          GMESSAGE = mess(2,177,1)
          GERR = 2
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

Local Integer STAT
Local Char SZSITE(GLONFCY)

  SZSITE = ""
  Call READ_COUNTER([M:ITN0]SALFCY, 13, 0, GSOCIETE, GCURLEG, GCITNCPT, GMANCOU) From CRM_UTIL     # FGR 20/04/2015 : X3SUIVI107768 : traite le cas où SALFCY n'est pas saisissable
  # Récupération du compteur de contrat de service.
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK", [M:ITN0]SALFCY, GCITNCPT, date$, "", [M:ITN0]NUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:ITN]NUM = [M:ITN0]NUM
      Affzo [M:ITN0]NUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:ITN]TYPFULOBJ = "ITNOBJ"
  [F:ITN]NUMFULOBJ = [M:ITN0]NUM
  [F:ITN]TYPFULRPO = "ITN"
  [F:ITN]NUMFULRPO = [M:ITN0]NUM
  [M:ITN1]TYPFULOBJ = "ITNOBJ"
  [M:ITN1]NUMFULOBJ = [M:ITN0]NUM
  [M:ITN4]TYPFULRPO = "ITN"
  [M:ITN4]NUMFULRPO = [M:ITN0]NUM
  [F:ITN]CREHOU = left$(time$, 2) + mid$(time$, 4, 2)
Return

##########################################################################################################
$VERF_ANU
Local Integer ITERITN8
Local Integer ICANDELITN
Local Integer IDELITNERR

  ICANDELITN = 1
  IDELITNERR = 0
  #Interdit la suppression d'interventions pour lesquelles un travail a été effectué.
  For ITERITN8 = 0 To [M:ITN8]NBLIG-1
    If [M:ITN8]HDTDONDAT <> [00/00/00] Then
      ICANDELITN = 0
      Break
    Endif
    If [M:ITN8]SPGTIMHOU > 0 Then
      ICANDELITN = 0
      Break
    Endif
    If [M:ITN8]SPGTIMMNT > 0 Then
      ICANDELITN = 0
      Break
    Endif
  Next
  If ICANDELITN = 0 Then
    #Il est interdit de supprimer une intervention contenant des consommations effectuées ou en cours de réalisation.
    GMESSAGE = mess(143,177,1)
    GERR = 1
    OK = 0
    Return
  Endif
  #On déplanifie les interventions associées à l'intervention à supprimer
  Call DEBTRANS From GLOCK
  Trbegin [HDT]
  Filter [HDT] Where [F:HDT]ITNNUM = [M:ITN0]NUM and [F:HDT]TPL <> 2
  For [HDT] Hint Key HDT2
    Raz [F:HDT]HDTPLNDAT
    Raz [F:HDT]ITNNUM
    Rewrite [HDT]
    If fstat Then
      IDELITNERR = 1
      Break
    Endif
  Next
  Filter [HDT]
  If IDELITNERR Then
    #Erreur lors de la déplanification des consommations associées à l'intervention. Suppression abandonnée.
    GMESSAGE = mess(144,177,1)
    GERR = 1
    OK = 0
    Return
  Else
    Commit
  Endif
Return

##########################################################################################################
$VERIF_CRE_MOD
Local Integer ISTOERR
Local Integer I

  #Vérifie si un site de stokage est bien présent sur une consomation de type pièce
  For I = 0 To [M:ITN8]NBLIG-1
    If [M:ITN8]HDTTYP(I) = 2 Then
      #consomation de type pièce
      #LSE 10/04/2007 FQ40765
      If [M:ITN8]STOMGTCOD(I) = 2 Then
        If [M:ITN8]HDTSTOFCY(I) = "" Then
          GMESSAGE = mess(204,177,1) #Il faut obligatoirement saisir un site de stockage.
          GERR = 2
          OK = 0
          Break
        Endif
      Endif
    Endif
  Next
  If OK = 0 Then
    Return
  Endif
  # FGR 30/09/2009 : X3SUIVI57245 : à ne faire que s'il y a des lignes de saisies
  If [M:ITN8]NBLIG > 0 Then
    #Sortie de stock
    Call CTLSTOSOR ("ITN8", "HDTISSQTY", [M:ITN8]NBLIG, ISTOERR) From STKECR
    If ISTOERR Then
      OK = 0
      Return
    Endif
  Endif
  #Vérifie si l'intervention est associée à une demande de service
  If [M:ITN0]SRVDEMNUM = "" Then
    #Aucune demande de service n'est associée à cette intervention. Création refusée.
    GMESSAGE = mess(236,182,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #LSE 10/01/2006 FQ 34170 Une demande cloturé ne peut pas être en date flou
  If [M:ITN0]DON = 2 Then
    If [M:ITN1]DAT = [00/00/00] or [M:ITN1]DATEND = [00/00/00] or [M:ITN1]HOU = "" or [M:ITN1]HOUEND = "" Then
      #Les dates de début et de fin sont obligatoires pour une intervention effectuée.
      GMESSAGE = mess(213,177,1)
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
  #La date de fin doit ne doit jamais être inférieure à la date de début.
  If [M:ITN1]DAT = [00/00/00] Then
    Raz [M:ITN1]HOU
    Raz [M:ITN1]DATEND
    Raz [M:ITN1]HOUEND
    [M:ITN1]FULDAY = 1
  Else
    If [M:ITN1]DATEND = [00/00/00] Then
      #La date de fin n'a pas été précisée.
      GMESSAGE = mess(98,177,1)
      GERR = 2
      OK = 0
      Return
    Else
      If [M:ITN1]DATEND < [M:ITN1]DAT Then
        #La date de fin ne doit pas être inférieure à la date de début.
        GMESSAGE = mess(99,177,1)
        GERR = 2
        OK = 0
        Return
      Endif
    Endif
  Endif
  #Vérifie si un technicien ou un sous-traitant a été saisi pour l'intervention
  If [M:ITN1]REP = "" and [M:ITN1]SCONUM = "" Then
    GMESSAGE = mess(301,196,1) # Aucun intervenant n'a été renseigné pour cette intervention.
    GERR = 2
    OK = 0
    Return
  Endif
  #Affectation du pays par défaut.
  If [M:ITN3]CRY = "" Then
    [M:ITN3]CRY = GPAYS
  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (début)
  #  # Vérifie la disponibilité du technicien
  #  Gosub CHKITNDISP From SUBITNB3
  #  #Assure enregistrement Synthèse Complément d'informations
  #  If [M:ITN1]FULOBJ = "" Then
  #    [M:ITN1]OBJ = ""
  #  Else
  #    [M:ITN1]OBJ = left$([M:ITN1]FULOBJ,250)
  #  Endif
  #  #Assure enregistrement Synthèse Compte-rendu
  #  If [M:ITN4]FULRPO = "" Then
  #    [M:ITN4]RPO = ""
  #  Else
  #    [M:ITN4]RPO = left$([M:ITN4]FULRPO,250)
  #  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (fin)
  # Issue X3-63006 - 2018-02-23 by FGR : BEGIN : commented by error in X3SUIVI95250
  # Vérifie la disponibilité du technicien
  Gosub CHKITNDISP From SUBITNB3
  # Issue X3-63006 - 2018-02-23 by FGR : END
  #Une intervention contenant un compte-rendu doit toujours être effectuée
  If [M:ITN4]RPO <> "" Then
    If [M:ITN0]DON <> 2 Then
      # FGR 11/03/2011 : X3SUIVI72030 : ... Et seulement si toutes les sorties de stock ont été effectuées
      [M:ITN0]DON = 2
      Call AM_DON([M:ITN0]DON) From SUBITN
      If mkstat Then
        GMESSAGE = ""
        mkstat = 0
        [M:ITN0]DON = 1
      Endif
      Affzo [M:ITN0]DON
    Endif
  Endif
  #Calcul le temps total réellement passé
  Call CPTSPGTIM From SUBITNB1
  GITNUDDHDTFLG = ""
Return

##########################################################################################################
$VERIF_CRE
  GOK = 1
  If [M:ITN0]CREFBDFLG > 0 Then
    #La création de cette intervention est refusée en raison d'une modification en cours sur un autre poste.
    GMESSAGE = mess(596,182,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
  GOK = 1
  #
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$CREATION
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer ZH
Local Char SZMESSAGE (250)

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Raz SZMESSAGE
  # FGR 21/08/2009 : X3SUIVI57317 : Le Unlock ne fonctionne pas dans une transaction. Mettre en APRES_CRE
  #Dévérouillage de la demande
  #Call UNLOCKSRE([M:ITN0]SRVDEMNUM) From SUBITNB1
  #Enregistrement du CLOB compte-rendu
  Gosub SAVEHD2 From SUBITNB1
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_CREATION From SUBITNB3
  If GOK < 1 Then
    Return
  Endif
  #Suppression des caches abandon
  Call PITAPRESMOD([M:ITN0]SRVDEMNUM, IERRINF) From SUBSREB3
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  #Enregistrement des consommations
  Call SAVEHDTCRE([M:ITN0]SRVDEMNUM, [M:ITN0]NUM) From SUBITNB2
  If GOK < 1 Then
    Return
  Endif
  #Supprime les réservations de ressources supprimées
  For ZH = 0 To dim([M:ITN0]RERDEL)-1
    If [M:ITN0]RERDEL(ZH) <> "" Then
      Read [RRS]RRS0=[M:ITN0]RERDEL(ZH)
      If !fstat Then
        Delete [RRS]Curr
        If fstat Then
          #Erreur lors de la suppression des réservations de ressources. Suppression interrompue.
          GMESSAGE = mess(476,196,1)
          GERR = 1
          Call FSTA("RRS") From GLOCK
          GOK = 0
          Break
        Endif
      Endif
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  Call UPDRRSORI From SUBITNB1
  If GOK < 1 Then
    Return
  Endif
  Call UPDRRSITN From SUBITNB1
  If GOK < 1 Then
    Return
  Endif
  Call CLEANRRSORI (3, [M:ITN0]NUM, "[M:ITN7]RER", SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GOK = 0
    GMESSAGE = SZMESSAGE
    GERR = 1
    Return
  Endif
  #Clôture relative à la facturation
  Call CLOITN([M:ITN0]SRVDEMNUM, [M:ITN0]NUM, [M:ITN0]BPC, [M:ITN4]PBLSOL,
&             [M:ITN4]PREPBLSOL, [M:ITN4]WISCLOFLG, [M:ITN4]WISSATFLG,
&             [M:ITN8]DONDATFLG, "ITN", IERRINF, ICHAPTER, IBRETOUR) From SUBITNB1
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    Return
  Endif
  #Enregistrement des points mobilisés
  Call SAVEHDTWKEY("C", "ITN",SZMESSAGE,IBRETOUR) From SUBSREB2
  If IBRETOUR = 0 Then
    GOK = 0
    GMESSAGE = SZMESSAGE
    GERR = 1
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("ITN",1) From SUBPS2
Return

##########################################################################################################
$MODIF
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer ZH
Local Char SZMESSAGE(250)

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Raz SZMESSAGE
  # FGR 21/08/2009 : X3SUIVI57317 : Le Unlock ne fonctionne pas dans une transaction. Mettre en APRES_CRE
  #Dévérouillage de la demande
  #Call UNLOCKSRE([M:ITN0]SRVDEMNUM) From SUBITNB1
  #Enregistrement du CLOB compte-rendu
  Gosub SAVEHD2 From SUBITNB1
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_MODIF From SUBITNB3
  If GOK < 1 Then
    Return
  Endif
  #Suppression des caches abandon
  Call PITAPRESMOD([M:ITN0]SRVDEMNUM, IERRINF) From SUBSREB3
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  #Enregistrement des consommations
  Call SAVEHDT([M:ITN0]SRVDEMNUM, [M:ITN0]NUM) From SUBITNB2
  If GOK < 1 Then
    Return
  Endif
  #Supprime les réservations de ressources supprimées
  For ZH = 0 To dim([M:ITN0]RERDEL)-1
    If [M:ITN0]RERDEL(ZH) <> "" Then
      Read [RRS]RRS0=[M:ITN0]RERDEL(ZH)
      If !fstat Then
        Delete [RRS]Curr
        If fstat Then
          #Erreur lors de la suppression des réservations de ressources. Suppression interrompue.
          GMESSAGE = mess(476,196,1)
          GERR = 1
          Call FSTA("RRS") From GLOCK
          GOK = 0
          Break
        Endif
      Endif
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  Call UPDRRSORI From SUBITNB1
  If GOK < 1 Then
    Return
  Endif
  Call UPDRRSITN From SUBITNB1
  If GOK < 1 Then
    Return
  Endif
  Call CLEANRRSORI (3, [M:ITN0]NUM, "[M:ITN7]RER", SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GOK = 0
    GMESSAGE = SZMESSAGE
    GERR = 1
    Return
  Endif
  #Clôture relative à la facturation
  Call CLOITN([M:ITN0]SRVDEMNUM, [M:ITN0]NUM, [M:ITN0]BPC, [M:ITN4]PBLSOL,
&             [M:ITN4]PREPBLSOL, [M:ITN4]WISCLOFLG, [M:ITN4]WISSATFLG,
&             [M:ITN8]DONDATFLG, "ITN", IERRINF,ICHAPTER,IBRETOUR) From SUBITNB1
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    Return
  Endif
  #Enregistrement des points mobilisés
  Call SAVEHDTWKEY("M", "ITN",SZMESSAGE,IBRETOUR) From SUBSREB2
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    GERR = 1
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("ITN",-1) From SUBPS2
  Call VALSTA("ITN",1) From SUBPS2
Return

##########################################################################################################
$AV_ANNULE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer ITER        # FGR 11/03/2011 : X3SUIVI70680

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #Suppression du clob compte-rendu
  Gosub DELHD2 From SUBITNB1
  If GOK < 1 Then
    Return
  Endif
  #Suppression des réservations de ressources
  Call DELRRS([M:ITN0]NUM) From SUBITNB1
  If GOK < 1 Then
    Return
  Endif
  # FGR 12/08/2009 : X3SUIVI57005 : C'est pas là que ça doit être
  #Enregistrement des données pour les encours
  #Gosub GERE_LCM_ANNULE From SUBITNB3
  #If GOK < 1 Then
  #  Return
  #Endif
  # Suppression des axe analytiques
  # FGR 11/03/2011 : X3SUIVI70680 (début) : Il faut le faire pour toutes les lines !
  #Call ENREG_ACCCCE(0, "", "", "", "HDT", 0, [F:HDT]HDTNUM, 0, 0, "", "A") From TRTX3CPT
  For ITER = 0 To [M:ITN8]NBLIG-1
    If [M:ITN8]HDTNUM(ITER) <> "" Then
      Call ENREG_ACCCCE(0, "", "", "", "HDT", 0, [M:ITN8]HDTNUM(ITER), 0, 0, "", "A") From TRTX3CPT
      If GOK < 1 Then
        Break
      Endif
    Endif
  Next ITER
  # FGR 11/03/2011 : X3SUIVI70680 (fin)
  If GOK < 1 Then
    #Erreur lors de la suppression des axes analytiques associés aux consommations de l'intervention.
    GMESSAGE = mess(430,177,1)
    Return
  Endif
Return

##########################################################################################################
$ANNULE
  # Maj des statistiques
  Call VALSTA("ITN",-1) From SUBPS2
Return

##########################################################################################################
$APRES_ANNULE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # FGR 12/08/2009 : X3SUIVI57005 : Pour le moment, il n'y a que là qu'on peut le mettre
  #                  Le pb c'est que ça n'est pas dans la transaction, donc si ça échoue,
  #                  L'enregistrement sera détruit, mais les Premier/Dernier/Prochain ne seront pas forcément à jour
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_ANNULE From SUBITNB3
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$APRES_CRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # FGR 21/08/2009 : X3SUIVI57317 : Le Unlock ne fonctionne pas dans une transaction. Mettre en APRES_CRE
  #Dévérouillage de la demande
  Call UNLOCKSRE([M:ITN0]SRVDEMNUM) From SUBITNB1
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Raz [M:ITN0]RERDEL
  [M:ITN0]ITNSYM = ""
  [M:ITN1]CREHOU = [F:ITN]CREHOU
  Affzo [M:ITN1]1-99
  Call LOADHDT([M:ITN0]NUM) From SUBITNB2
  Gosub SETPREVAL From SUBITNB3
  [M:ITN0]CREFBDFLG = 0
  #---------------------------------------------------#
  #Suppression du contrôle de session
  Call RAZPRONUM From SUBSREB3
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBITNB1
  #---------------------------------------------------#
  # Contrôle du statut clôturé d'une demande
  #---------------------------------------------------#
  If [M:ITN0]SRVDEMNUM = "" Then
    Grizo [M:ITN8]5
  Else
    Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
    If fstat Then
      Grizo [M:ITN8]5
    Else
      If [F:SRE]SREASS = 5 Then
        Grizo [M:ITN8]5
      Else
        Actzo [M:ITN8]5
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  # Calcul le nombre maximum d'intervention que l'on peut ajouter sur une intervention.
  #---------------------------------------------------#
  Call ITNNBRSREHDT From SUBITNB3
  GITNUDDHDTFLG = ""
  Call SETTZN From SUBITNB3
  Diszo [M:ITN0]SRVDEMNUM
  Diszo [M:ITN0]BPC
  [M:ITN0]CURSRETUN = [M:ITN0]SRVDEMNUM
  [M:ITN0]CURBPCTUN = [M:ITN0]BPC
  If [M:ITN8]NBLIG > 0 Then
    Grizo [M:ITN0]SALFCY
  Else
    Actzo [M:ITN0]SALFCY
  Endif
  Actzo [M:ITN4]PBLSOL
  Actzo [M:ITN4]HTOTTIMSPG
  Actzo [M:ITN4]MTOTTIMSPG
  Actzo [M:ITN8]HTIMSPG
  Actzo [M:ITN8]MTIMSPG
  Affzo [M:ITN0]1-99
  Affzo [M:ITN4]1-99
  Affzo [M:ITN8]1-99
Return

##########################################################################################################
$APRES_MOD
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # FGR 21/08/2009 : X3SUIVI57317 : Le Unlock ne fonctionne pas dans une transaction. Mettre en APRES_CRE
  #Dévérouillage de la demande
  Call UNLOCKSRE([M:ITN0]SRVDEMNUM) From SUBITNB1
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Raz [M:ITN0]RERDEL
  [M:ITN0]ITNSYM = SYMBOLE
  Call LOADHDT([M:ITN0]NUM) From SUBITNB2
  Gosub SETPREVAL From SUBITNB3
  [M:ITN0]CREFBDFLG = 0
  #---------------------------------------------------#
  #Suppression du contrôle de session
  Call RAZPRONUM From SUBSREB3
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBITNB1
  #---------------------------------------------------#
  # Contrôle du statut clôturé d'une demande
  #---------------------------------------------------#
  If [M:ITN0]SRVDEMNUM = "" Then
    Grizo [M:ITN8]5
  Else
    Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
    If fstat Then
      Grizo [M:ITN8]5
    Else
      If [F:SRE]SREASS = 5 Then
        Grizo [M:ITN8]5
      Else
        Actzo [M:ITN8]5
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  # Calcul le nombre maximum d'intervention que l'on peut ajouter sur une intervention.
  #---------------------------------------------------#
  Call ITNNBRSREHDT From SUBITNB3
  Call SETTZN From SUBITNB3
  GITNUDDHDTFLG = ""
  Diszo [M:ITN0]SRVDEMNUM
  Diszo [M:ITN0]BPC
  [M:ITN0]CURSRETUN = [M:ITN0]SRVDEMNUM
  [M:ITN0]CURBPCTUN = [M:ITN0]BPC
  If [M:ITN8]NBLIG > 0 Then
    Grizo [M:ITN0]SALFCY
  Else
    Actzo [M:ITN0]SALFCY
  Endif
  Actzo [M:ITN4]PBLSOL
  Actzo [M:ITN4]HTOTTIMSPG
  Actzo [M:ITN4]MTOTTIMSPG
  Actzo [M:ITN8]HTIMSPG
  Actzo [M:ITN8]MTIMSPG
  Affzo [M:ITN0]1-99
  Affzo [M:ITN4]1-99
  Affzo [M:ITN8]1-99
Return

