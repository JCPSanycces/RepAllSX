$AB_MODIF
  # FGR 21/08/2009 : X3SUIVI57317 : Le Unlock ne fonctionne pas dans une transaction. Mettre en APRES_CRE
  #Dévérouillage de la demande
  Call UNLOCKSRE([M:ITN0]SRVDEMNUM) From SUBITNB1
Return

