#<AdxTL>@(#)6.0.0.0 $Revision$
Call OBJET ("ITN", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$AVANT_OUVRE
Return

##########################################################################################################
$DEFTRANS
  #--------------------------------------------------------#
  # Avant lecture des transactions de saisie disponibles : #
  # Si GFLAG est renseigné la transaction est déja choisie #
  # par le menu. Vérifier si elle est valide               #
  #--------------------------------------------------------#
Local Shortint OUVFICFLG

  If clalev ([F:HTR])=0 Local File HDKTRS [HTR] : Endif
  If GFLAG <> "" Then
    Read [HTR]HTR0=3;GFLAG
    If fstat or [F:HTR]ENAFLG = 1 Then
      Raz GFLAG
      Goto FIN_DEFTRANS
    Endif
    If [F:HTR]ACSCOD <> "" and GPROFIL <> GSUPER Then
      If clalev ([F:ACC])=0 Local File ACCES [ACC] : OUVFICFLG = 1 : Endif
      Read [ACC]CODACC=GUSER;[F:HTR]ACSCOD
      If fstat or [F:ACC]EXEC <> 2 Then
        Raz GFLAG
        Goto FIN_DEFTRANS
      Endif
    Endif
  Endif
  Goto FIN_DEFTRANS # FGR 03/12/2008 on va toujours à FIN_DEFTRANS mais c'était pas propre
Return

##########################################################################################################
$FIN_DEFTRANS
  If OUVFICFLG=1 Close File [ACC] : Raz OUVFICFLG : Endif
Return

##########################################################################################################
$VARIANTE
  #---------------------------------------#
  # Après lecture de chaque transaction : #
  # La transaction est-elle valide ?      #
  # VARCOD contient le code transaction.  #
  # Mettre OK à zéro si non valide.       #
  #---------------------------------------#
  Read [HTR]HTR0=3;VARCOD
  If fstat or [F:HTR]ENAFLG = 1 Then
    OK = 0
  Endif
Return

##########################################################################################################
$SETTRANS
  #-------------------------------------#
  # Après sélection de la transaction : #
  # GFLAG = code transaction choisie    #
  #-------------------------------------#
  Read [HTR]HTR0=3;GFLAG
  If fstat Then
    Raz [F:HTR]
  Endif
  #MAE, le 31/01/08, GRP_SITE
  GGRPFCY = [F:HTR]GFY
Return

##########################################################################################################
$OUVRE
Global Char GCITNCPT(GLONANM)     # Code compteur
Global Char GSR2CITNCPT(GLONANM)  # Code compteur pour numéro de séquence.
Global Char GITN1REP(GLONREP)     # Idem variable REP mais globale cette fois-ci
Global Char GITN1CFLRS(GLONVCR)(10)
Global Integer GIITNCOUNT
#Stockage code transaction
Global Char GHDKTRSITN
#Gestion des valeurs modifiées
Global Char GITNUDDHDTFLG
Global Integer GIITN1RRSUPD
Global Integer GIITN8TIMFLG
Global Integer GIITN8TIMNOL
Global Integer GIITN8STRDAYCTL
Global Integer GIITN8STRSODCTL
Global Char GIITN8TIMITNNUM
Global Char GIITN8TIMHDTNUM
Global Char GSZITNFILGAUFLT(250)(7)
Global Char GSITNNAMESPE(10)(7)
Global Char GBOXITN(10)
Global Char GBOXIT2(10)
Global Char GBOXITNSP1(10)
Global Char GBOXITNSP2(10)
Global Char GBOXITNSP3(10)
Global Char GBOXITNSP4(10)
Global Char GBOXITNSP5(10)
Global Char GBOXITNSP6(10)
Global Char GBOXITNSP7(10)
  If dim([M:ITN8]HDTISSQTY) > 1 Then
    Global Decimal GITN8HDTISSISS(dim([M:ITN8]HDTISSQTY))
    Global Decimal GITN8DIRTYISSISS(dim([M:ITN8]HDTISSQTY))
  Else
    Global Decimal GITN8HDTISSISS
    Global Decimal GITN8DIRTYISSISS
  Endif
Global Char GITNHTRNUM
#Global Integer GMANCOU12   # FGR 20/12/2012 : X3SUIVI71937
Global Integer  GMANCOUITN12      # FGR 13/17/2015 : X3SUIVI111665 renommée

Local Integer ITERFLT
Local Char SZSITE(GLONFCY)

  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:PCT2]) : Local File PITCOUNT [PCT2] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:ITG]) : Local File ITMCATEG [ITG] : Endif    : # FGR 10/02/2009 : X3SUIVI52386 Table non ouverte
  If GMODU(2) = 2 Then
    #si module compta actif
    If !clalev([F:GCM]) : Local File GACM[GCM] : Endif
  Endif

  GHDKTRSITN = [F:HTR]HTRNUM
  #Contrôle des clobs temporaires
  If !GIMPORT Then
    Gosub CLEANHD7 From SUBSREB3
  Endif
  GCITNCPT = ""
  GIITNCOUNT = 0
  GITN1REP = ""
  GITN1CFLRS = ""
  GITNUDDHDTFLG = ""
  Raz GSZITNFILGAUFLT
  Raz GSITNNAMESPE
  GITNHTRNUM = ""
  GIITN1RRSUPD = 0
  Raz GITN8HDTISSISS
  Raz GITN8DIRTYISSISS
  Raz GSOC_ACTIVE
  SZSITE = ""
  Call SITECRMDEF ("HDK", SZSITE) From CRM_UTIL
  GFCY = SZSITE
  Call INIT_GLOBAL_CPT(SZSITE,"HTR",3,GHDKTRSITN) From TRTX3CPT
  Call GLOBVAR(GFCY) From WWGLOBTC  # FGR 05/12/2008 : Chargement des paramètres tronc commun
  #-----
  GORITITCOL = 1
  #Gestion des sorties de stock
  Gosub SETSTORES From SUBSREB3
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  Read [TCA]TCA0=13
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(0)
  #  GCITNCPT = [F:TCA]CODNUM(0)
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GSR2CITNCPT = [F:TCA]CODNUM(11)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
  #Renouvellement des garanties à tacite reconduction
  Call REWWARRANTY From SUBCONB2
  If !GIMPORT Then
    If IERRINFHD7 Then
      #Le contrôle de cohérence des textes sur consommation a échoué.
      GMESSAGE = mess(908,182,1)
      GERR = 2
    Endif
  Endif
  #Transactions de saisie
  GITNHTRNUM = [F:HTR]HTRNUM
  For ITERFLT = 0 To dim(GSITNNAMESPE)-1
    GSITNNAMESPE(ITERFLT) = [F:HTR]OBJLIS(ITERFLT)
    GSZITNFILGAUFLT(ITERFLT) = [F:HTR]FLTLIS(ITERFLT)
  Next
Return

##########################################################################################################
$BOITE
Local Char STRTSUB(GLONADC)

  # FGR 31/07/2014 : X3SUIVI101463
  STRTSUB = "SUBITNA"
  Gosub BOITE_GOBJET From CRMUTIL150
Return

##########################################################################################################
$REDEFINE_LINK
  If !clalev([F:I_TN]) Then
    # FGR 11/02/2015 : X3SUIVI106120 : Si [I_TN] pas ouvert c'est que les browsers ont été redéfinis en SPE/SPV.
    # On part, c'est à ce niveau qu'on doit faire ce travail.
    Return
  Endif
  #---------------------------------------------------#
  # FGR 30/07/2014 : X3SUIVI101463
  Link [ITN] With [I_TN]ITN0=[F:ITN]NUM,
&                 [AFF]AFF0~=[F:ITN]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:ITN]SALFCY,
&                 [FCY]FCY0=[F:ITN]SALFCY
&              As [IT2_]
Return

##########################################################################################################
$OUVRE_BOITE
  #---------------------------------------------------#
  #Chargement des noms des cuurbox de chaque tiroir
  If OBJLIS(0) = "ITN" Then
    GBOXITN= "GAU_CHE"
  Else
    GBOXITN = "GAU_CHE"+num$(find("ITN",OBJLIS(1..8))) : #Interventions à effectuer
  Endif
  If OBJLIS(0) = "IT2" Then
    GBOXIT2= "GAU_CHE"
  Else
    GBOXIT2 = "GAU_CHE"+num$(find("IT2",OBJLIS(1..8))) : #Interventions effectuées
  Endif
  If GSITNNAMESPE(0) <> "" Then
    If OBJLIS(0) = GSITNNAMESPE(0) Then
      GBOXITNSP1= "GAU_CHE"
    Else
      GBOXITNSP1 = "GAU_CHE"+num$(find(GSITNNAMESPE(0),OBJLIS(1..8))) : #Liste spécifique 1
    Endif
  Endif
  If GSITNNAMESPE(1) <> "" Then
    If OBJLIS(0) = GSITNNAMESPE(1) Then
      GBOXITNSP2= "GAU_CHE"
    Else
      GBOXITNSP2 = "GAU_CHE"+num$(find(GSITNNAMESPE(1),OBJLIS(1..8))) : #Liste spécifique 2
    Endif
  Endif
  If GSITNNAMESPE(2) <> "" Then
    If OBJLIS(0) = GSITNNAMESPE(2) Then
      GBOXITNSP3= "GAU_CHE"
    Else
      GBOXITNSP3 = "GAU_CHE"+num$(find(GSITNNAMESPE(2),OBJLIS(1..8))) : #Liste spécifique 3
    Endif
  Endif
  If GSITNNAMESPE(3) <> "" Then
    If OBJLIS(0) = GSITNNAMESPE(3) Then
      GBOXITNSP4= "GAU_CHE"
    Else
      GBOXITNSP4 = "GAU_CHE"+num$(find(GSITNNAMESPE(3),OBJLIS(1..8))) : #Liste spécifique 4
    Endif
  Endif
  If GSITNNAMESPE(4) <> "" Then
    If OBJLIS(0) = GSITNNAMESPE(4) Then
      GBOXITNSP5= "GAU_CHE"
    Else
      GBOXITNSP5 = "GAU_CHE"+num$(find(GSITNNAMESPE(4),OBJLIS(1..8))) : #Liste spécifique 5
    Endif
  Endif
  If GSITNNAMESPE(5) <> "" Then
    If OBJLIS(0) = GSITNNAMESPE(5) Then
      GBOXITNSP6= "GAU_CHE"
    Else
      GBOXITNSP6 = "GAU_CHE"+num$(find(GSITNNAMESPE(5),OBJLIS(1..8))) : #Liste spécifique 6
    Endif
  Endif
  If GSITNNAMESPE(6) <> "" Then
    If OBJLIS(0) = GSITNNAMESPE(6) Then
      GBOXITNSP7= "GAU_CHE"
    Else
      GBOXITNSP7 = "GAU_CHE"+num$(find(GSITNNAMESPE(6),OBJLIS(1..8))) : #Liste spécifique 7
    Endif
  Endif
Return

##########################################################################################################
$FERME
  Raz GORITITCOL
  #Termine l'éventuel horodatage en cours.
  If GIITN8TIMFLG Then
    Call MNGHORO([M:ITN0]NUM, GIITN8TIMHDTNUM, 0, 0) From SUBITNB2
  Endif
  Kill GITNUDDHDTFLG
  Kill GSR2CITNCPT
#  If find("GESSRE", GNAVIG(1..GPILNAV-0)) = 0 Then
#    # FGR 23/07/2014 : X3SUIVI101619
#    # On ne le supprime pas si on vient des demandes de service. C'est la même globale, mais on ne s'en sert pas
#    Kill GMANCOU12             # FGR 11/07/2014 : X3SUIVI101410
#  Endif
  Kill GMANCOUITN12      # FGR 13/17/2015 : X3SUIVI111665 renommée
  Kill GCITNCPT   #Code compteur
  Kill GITN1REP
  Kill GIITNCOUNT
  Kill GITN1CFLRS
  Kill GIITN1RRSUPD
  Kill GIITN8TIMFLG
  Kill GIITN8TIMNOL
  Kill GIITN8STRDAYCTL
  Kill GIITN8STRSODCTL
  Kill GIITN8TIMITNNUM
  Kill GIITN8TIMHDTNUM
  Kill GITN8DIRTYISSISS
  Kill GITN8HDTISSISS
  Kill GITNHTRNUM
  Kill GSZITNFILGAUFLT
  Kill GSITNNAMESPE
  #LSE 22/12/2005 FQ 33987
  If dim(GBOXITN) > 0 Then
    Kill GBOXITN
    Kill GBOXIT2
    Kill GBOXITNSP1
    Kill GBOXITNSP2
    Kill GBOXITNSP3
    Kill GBOXITNSP4
    Kill GBOXITNSP5
    Kill GBOXITNSP6
    Kill GBOXITNSP7
  Endif
  If dim (GHDKTRSITN) > 0 Then
    Kill GHDKTRSITN
  Endif
  #Affichage de la demande de service
  #LSE 09/01/2007
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESSRE" Then
      # Issue X3-38449 - 2017-10-09 by FGR : BEGIN was missing here
      Local Char    WPLISTC(250)

      Call ALICOLREM (1,0,"","SRE9", "", 1,WPLISTC) From TRTPRICE
      # Issue X3-38449 - 2017-10-09 by FGR : END
      If [M:ITN0]SRVDEMNUM = "" Then
        #---------------------------------------------------#
        #Chargement des consommations
        #---------------------------------------------------#
        Call LOADHDT([M:SRE0]SRENUM) From SUBSREB1
        Gosub AFFSRE2MIS From SUBSREB2
        Affzo [M:SRE2]1-99
        Affzo [M:SRE9]1-99
      Else
        If [M:SRE0]SRENUM = [M:ITN0]SRVDEMNUM Then
          #---------------------------------------------------#
          #Chargement des consommations
          #---------------------------------------------------#
          Call LOADHDT([M:ITN0]SRVDEMNUM) From SUBSREB1
          Gosub AFFSRE2MIS From SUBSREB2
          Affzo [M:SRE2]1-99
          Affzo [M:SRE9]1-99
        Endif
      Endif
    Endif
  Endif
  #LSE 4/01/2006 PB import batch FQ 34106
  #Remise en ordre des paramètres de déconnexion automatique.
  If !GIMPORT Then
    Local Char RETOUR
    Local Char SZTIMEHGUP1
    Local Char SZTIMEHGUP2
    Local Integer ITIMEHGUP1
    Local Integer ITIMEHGUP2

    Call PARAMUTIL("TIMEHGUP1", SZTIMEHGUP1, GUSER, "") From SUBAUS
    If SZTIMEHGUP1 = "" Then
      ITIMEHGUP1 = 3600
    Else
      ITIMEHGUP1 = val(SZTIMEHGUP1)
    Endif
    Call PARAMUTIL("TIMEHGUP2", SZTIMEHGUP2, GUSER, "") From SUBAUS
    If SZTIMEHGUP2 = "" Then
      ITIMEHGUP2 = 3600
    Else
      ITIMEHGUP2 = val(SZTIMEHGUP2)
    Endif
    Callui RETOUR="" With "UIAction="+chr$(1)+"Sethangup",
&                         "UITimehangup1="+chr$(1)+num$(ITIMEHGUP1),
&                         "UITimehangup2="+chr$(1)+num$(ITIMEHGUP2)
  Endif
Return

##########################################################################################################
$SETBOUT
  # FGR 23/06/2015 : X3SUIVI107642 : $SETBOUT revu
  If REP = "" Then
    CHMEN += "I"
    CHMEN += "D"  # FGR 19/01/2012 : X3SUIVI71278 Traçabilité des pièces "D"
    # FGR 03/06/2015 : X3SUIVI108602 (début) Envoie par email
    If func CRMUTIL140.EMAIL_POSSIBLE(GUSER, "ITN", [M:ITN0]NUM) = [V]CST_AYES Then
      CHMEN += "7"
    Endif
    # FGR 03/06/2015 : X3SUIVI108602 (fin)
  Endif
  GITN1REP = REP
  CHMEN += "5"     # Option / Transaction de saisie.
  If REP = "" Then
    If func SUBITNB1.GET_LIEU_ITN([M:ITN1]TYP, 1) = "OUT" Then
      # Itinéraire que pour les interventions en dehors (OUT)
      CHMEN += "1236"
    Endif
  Endif
  # ---------------------------------------------------
  # Objet intervention accédé directement depuis le menu général.
  If TUNNEL = 0 Then
    Call VIREBOUT(CHAINE,"CD") From GOBJET
  Else
    If GPILNAV > 1 Then
      If GNAVIG(GPILNAV-1) <> "GESSRE" Then
        # La création n'est autorisée que depuis les demandes de service.
        Call VIREBOUT(CHAINE,"CD") From GOBJET
      Endif
    Endif
  Endif
  # ---------------------------------------------------
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

