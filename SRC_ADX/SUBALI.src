#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du fichier ALINK
Local    Char PARAM(250)(1..2) , VALEUR(10)
PARAM(1) = "AWI"
PARAM(2) = "OAMK"
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBALI","ALINK",3,"SPEALI") From GTRAITE
End

#####################################################
$ACTION
Case ACTION
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "FIN_TABLE"  : Gosub FIN_TABLE
 When "INIT"       : Gosub INIT
 When "EXEC"       : Gosub EXEC
 When "INIT_DIA"   : Gosub INIT_DIA
Endcase
Return

#####################################################
$INIT
If clalev([F:ALI])=0 : Local File ALINK  [ALI] : Endif
If clalev([F:AOB])=0 : Local File AOBJET [AOB] : Endif
Return

#####################################################
$INIT_DIA
Raz [M:ALK]
Filter [ALI] Where USRCOD=GLIAISON & SRCOBJ=PARAM(1) & SRCKEY=PARAM(2) & ENAFLG=2 & AUTFLG<>2
nolign = 0
For [ALI]ALI0
 nolign += 1
 [M:ALK] = [F:ALI]
 [M:ALK]INVFLG(nolign-1) = 1
 If nolign>=dim([M:ALK]DSTOBJ) : Break : Endif
Next
If nolign<dim([M:ALK]DSTOBJ)
 Filter [ALI] Where USRCOD=GLIAISON & DSTOBJ=PARAM(1) & DSTKEY=PARAM(2) & ENAFLG=2 & AUTFLG<>2
 For [ALI]ALI0
  nolign += 1
  [M:ALK] = [F:ALI]
  [M:ALK]DSTOBJ(nolign-1) = [F:ALI]SRCOBJ
  [M:ALK]DSTKEY(nolign-1) = [F:ALI]SRCKEY
  [M:ALK]INVFLG(nolign-1) = 2
  If nolign>=dim([M:ALK]DSTOBJ) : Break : Endif
 Next
Endif
[M:ALK]NBLIG = nolign
Filter [ALI]
Return

#####################################################
$EXEC
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [ALI]
 Delete [ALI] Where USRCOD=GLIAISON & SRCOBJ=PARAM(1) & SRCKEY=PARAM(2) & ENAFLG=2 & AUTFLG<>2  
 If fstat=1
  GOK = -1 : GLOCK = "$ALINK"-GLIAISON-PARAM(1)-PARAM(2) : Goto ROLL_TR1
 Endif
 Delete [ALI] Where USRCOD=GLIAISON & DSTOBJ=PARAM(1) & DSTKEY=PARAM(2) & ENAFLG=2 & AUTFLG<>2  
 If fstat=1
  GOK = -1 : GLOCK = "$ALINK"-GLIAISON-PARAM(1)-PARAM(2) : Goto ROLL_TR1
 Endif
 For nolign=1 To [M:ALK]NBLIG
  [F:ALI] = [M:ALK]
  If [M:ALK]INVFLG(nolign-1)=2
   [F:ALI]SRCOBJ = [F:ALI]DSTOBJ
   [F:ALI]SRCKEY = [F:ALI]DSTKEY
   [F:ALI]DSTOBJ = PARAM(1)
   [F:ALI]DSTKEY = PARAM(2)
   Call DESIG(PARAM(1),PARAM(2),[F:ALI]DSTDES)
  Else
   [F:ALI]SRCOBJ = PARAM(1)
   [F:ALI]SRCKEY = PARAM(2)
   Call DESIG([F:ALI]DSTOBJ,[F:ALI]DSTKEY,[F:ALI]DSTDES)
  Endif
  [F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
  [F:ALI]USRCOD = GLIAISON
  [F:ALI]AUTFLG = 1
  [F:ALI]ENAFLG = 2
  Read [AOB]ABREV = [F:ALI]DSTOBJ
  If dim([F:AOB]LIBSHO)>0 & [F:AOB]LIBSHO<>0
   [F:ALI]DSTTIT = [F:AOB]LIBSHO
  Else
   [F:ALI]DSTTIT = [F:AOB]LIBEL
  Endif
  If [F:ALI]CREDAT=[0/0/0]
   [F:ALI]CREDAT = date$
   [F:ALI]CREUSR = GUSER
   If dim([F:ALI]CRETIM)>0 : [F:ALI]CRETIM = time  : Endif
  Elsif [M:ALK]MODIF(nolign-1)=1
   [F:ALI]UPDDAT = date$
   [F:ALI]UPDUSR = GUSER
   If dim([F:ALI]UPDTIM)>0 : [F:ALI]UPDTIM = time  : Endif
  Endif
  Write [ALI]
  If fstat
   GOK = 0 : Call FSTA("ALI") From GLOCK : Goto AB_TR1
  Endif
 Next nolign
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

###################################################################
Subprog DESIG(OBJET,CLE,DESIG)
Value    Char OBJET
Value    Char CLE
Variable Char DESIG
Local Char    CLE2(GLONID1) , SUPP(GLONID2)
Local Integer I
Gosub NOMFIC From ="WO"+OBJET
If NOMINT<>""
 If evalue("clalev([F:"+ABFIC+"])")=0
  Gosub OUVFIC From ="WO"+OBJET
 Endif
 I = instr(1,CLE,"~")
 If I
  CLE2 = left$(CLE,I-1)
  SUPP = right$(CLE,I+1)
 Else
  CLE2 = CLE
  SUPP = ""
 Endif
 Call LECTURE(OBJET,CLE2,SUPP) From CONTOBJ
 If evalue("type([F:"+ABFIC+"]"+NOMINT+")")>10
  DESIG = evalue("[F:"+ABFIC+"]"+NOMINT)
 Elsif evalue("dim([F:"+ABFIC+"]"+NOMINT+")")<=0
  Call LECTEXTRA(DESIG,NOMFIC,NOMINT,CLE2,SUPP) From ATEXTRA
 Else
  K = evalue("[F:"+ABFIC+"]"+NOMINT)
  Call TEXTE(K,DESIG) From OBJDIV
 Endif
Else
 DESIG = ""
Endif
End

###############################################################
# Action Création liaison
###############################################################

Subprog CRELNK(USR,LNK,INV,SRC_OBJ,SRC_KEY,DST_OBJ,DST_KEY)
Value Char USR       : # Groupe de liaison
Value Char LNK       : # Code liaison
Value Integer INV    : # Génération liaison inverse
Value Char SRC_OBJ   : # Objet origine
Value Char SRC_KEY   : # Clé de lien
Value Char DST_OBJ   : # Objet destination
Value Char DST_KEY   : # Clé de lien
Local Char GROUPE(10) , LNKINV(GLONADI)
Local Integer SNS
If clalev([F:ALI])=0 : Local File ALINK   [ALI] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
If clalev([F:AOB])=0 : Local File AOBJET  [AOB] : Endif
Read [ADI]CODE = 61;LNK
If fstat
 GOKWRK = 0 : End
Endif
LNKINV = [F:ADI]A1
If USR<>""
 GROUPE = USR
Else
 GROUPE = GLIAISON
Endif
SNS = 1
Gosub TRC
If GOK<1
 GOKWRK = 0 : End
Elsif INV & LNKINV<>""
 SNS = 2
 Gosub TRC
Endif
GOKWRK = 1
End

$TRC
GOK = 1
Trbegin [ALI]
 If SNS=2
  Readlock [ALI]ALI0 = GROUPE;DST_OBJ;DST_KEY;SRC_OBJ;SRC_KEY
  If fstat=1
   GOK = -1 : GLOCK = "$ALINK"-GROUPE-DST_OBJ-DST_KEY : Goto ROLL_TRC
  Endif
 Else
  Readlock [ALI]ALI0 = GROUPE;SRC_OBJ;SRC_KEY;DST_OBJ;DST_KEY
  If fstat=1
   GOK = -1 : GLOCK = "$ALINK"-GROUPE-SRC_OBJ-SRC_KEY : Goto ROLL_TRC
  Endif
 Endif
 If !fstat
  If SNS=2
   [F:ALI]INVFLG = 2
   [F:ALI]LNK    = LNKINV
  Else
   [F:ALI]INVFLG = 1
   [F:ALI]LNK    = LNK
  Endif
  [F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
  [F:ALI]USRCOD = GROUPE
  [F:ALI]AUTFLG = 1
  [F:ALI]ENAFLG = 2
  Call DESIG([F:ALI]DSTOBJ,[F:ALI]DSTKEY,[F:ALI]DSTDES)
  Read [AOB]ABREV = [F:ALI]DSTOBJ
  If dim([F:AOB]LIBSHO)>0 & [F:AOB]LIBSHO<>0
   [F:ALI]DSTTIT = [F:AOB]LIBSHO
  Else
   [F:ALI]DSTTIT = [F:AOB]LIBEL
  Endif
  [F:ALI]UPDDAT = date$
  [F:ALI]UPDUSR = GUSER
  If dim([F:ALI]UPDTIM)>0 : [F:ALI]UPDTIM = time  : Endif
  Rewrite [ALI]
  If fstat
   GOK = 0 : Call FSTA("ALI") From GLOCK : Goto AB_TRC
  Endif
 Else
  Raz [F:ALI]
  If SNS=2
   [F:ALI]SRCOBJ = DST_OBJ
   [F:ALI]SRCKEY = DST_KEY
   [F:ALI]DSTOBJ = SRC_OBJ
   [F:ALI]DSTKEY = SRC_KEY
   [F:ALI]LNK    = LNKINV
   [F:ALI]INVFLG = 2
  Else
   [F:ALI]SRCOBJ = SRC_OBJ
   [F:ALI]SRCKEY = SRC_KEY
   [F:ALI]DSTOBJ = DST_OBJ
   [F:ALI]DSTKEY = DST_KEY
   [F:ALI]LNK    = LNK
   [F:ALI]INVFLG = 1
  Endif
  [F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
  [F:ALI]USRCOD = GROUPE
  [F:ALI]AUTFLG = 1
  [F:ALI]ENAFLG = 2
  Call DESIG([F:ALI]DSTOBJ,[F:ALI]DSTKEY,[F:ALI]DSTDES)
  Read [AOB]ABREV = [F:ALI]DSTOBJ
  If dim([F:AOB]LIBSHO)>0 & [F:AOB]LIBSHO<>0
   [F:ALI]DSTTIT = [F:AOB]LIBSHO
  Else
   [F:ALI]DSTTIT = [F:AOB]LIBEL
  Endif
  [F:ALI]CREDAT = date$
  [F:ALI]CREUSR = GUSER
  If dim([F:ALI]CRETIM)>0 : [F:ALI]CRETIM = time  : Endif
  Write [ALI]
  If fstat
   GOK = 0 : Call FSTA("ALI") From GLOCK : Goto AB_TRC
  Endif
 Endif
Commit
Return

$AB_TRC
Rollback
Return

$ROLL_TRC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRC : Endif

###############################################################
# Action Suppression liaison
###############################################################

Subprog SUPLNK(USR,LNK,SNS,SRC_OBJ,SRC_KEY,DST_OBJ,DST_KEY)
Value Char USR       : # Groupe de liaison
Value Char LNK       : # Code liaison
Value Integer INV    : # Suppression liaison inverse
Value Char SRC_OBJ   : # Objet origine
Value Char SRC_KEY   : # Clé de lien
Value Char DST_OBJ   : # Objet destination
Value Char DST_KEY   : # Clé de lien
Local Char GROUPE(10) , LNKINV(GLONADI)
Local Integer SNS
If clalev([F:ALI])=0 : Local File ALINK   [ALI] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Read [ADI]CODE = 61;LNK
If fstat
 GOKWRK = 0 : End
Endif
LNKINV = [F:ADI]A1
If USR<>""
 GROUPE = USR
Else
 GROUPE = GLIAISON
Endif
SNS = 1
If !adxlog
 Gosub TR_ANULIA
Else
 Gosub ANULIA
Endif
If GOK<1
 GOKWRK = 0 : End
Elsif INV & LNKINV<>""
 SNS = 2
 If !adxlog
  Gosub TR_ANULIA
 Else
  Gosub ANULIA
 Endif
Endif
GOKWRK = 1
End

$TR_ANULIA
GOK = 1
Trbegin [ALI]
 Gosub ANULIA
 If    GOK=0  : Goto AB_ANULIA
 Elsif GOK=-1 : Goto ROLL_ANULIA
 Endif
Commit
Return

$AB_ANULIA
Rollback
Return

$ROLL_ANULIA
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANULIA : Endif

$ANULIA
If SNS=2
 Readlock [ALI]ALI0 = GROUPE;DST_OBJ;DST_KEY;SRC_OBJ;SRC_KEY
 If fstat=1
  GOK = -1 : GLOCK = "$ALINK"-GROUPE-DST_OBJ-DST_KEY : Return
 Endif
Else
 Readlock [ALI]ALI0 = GROUPE;SRC_OBJ;SRC_KEY;DST_OBJ;DST_KEY
 If fstat=1
  GOK = -1 : GLOCK = "$ALINK"-GROUPE-SRC_OBJ-SRC_KEY : Return
 Endif
Endif
Delete [ALI]ALI0 Curr
If !fstat
 GOK = 0 : Call FSTA("ALI") From GLOCK : Return
Endif
Return

########################################
## Sélection d'une clé
########################################
$SEL_TABLE
Case TABLE
 When "SELALI"
  OBJET = [M]DSTOBJ(nolign-1)
Endcase
Return

$FIN_TABLE
Case TABLE
 When "SELALI"
  Gosub NOMFIC From ="WO"+OBJET
  Gosub SETCLE From ="WO"+OBJET
  VALEUR = num$(evalue("[F:"+ABFIC+"]"+CLEPRIM))
  For I=0 To dim(CLESEC)-1
   If CLESEC(I)<>""
    VALEUR += "~"+num$(evalue("[F:"+ABFIC+"]"+CLESEC(I)))
   Endif
  Next I
Endcase
Return

########################################
## Annulation d'objet
########################################
Subprog ANUCOD(APPLI,OBJET,CLE1,CLE2)
Value    Char APPLI
Value    Char OBJET   
Value    Char CLE1   
Value    Char CLE2()(1..)   
Goto ANUCOD_SUB

Subprog ANNULE(OBJET,CLE1,CLE2)
Value    Char OBJET   
Value    Char CLE1   
Value    Char CLE2()(1..)   
 
$ANUCOD_SUB
Local Char    IDENT(50)
If dim([L]APPLI)>0 & [L]APPLI<>""
 If clalev([F:ALI])=0 : Local File =APPLI+".ALINK" [ALI] : Endif
Else
 If clalev([F:ALI])=0 : Local File ALINK [ALI] : Endif
Endif
Call IDENT3(OBJET,IDENT,CLE1,CLE2) From GOBJTXT
Call DEBTRANS From GLOCK
Gosub TR2
End

$TR2
GOK = 1
Trbegin [ALI]
 Delete [ALI] Where SRCOBJ=OBJET & SRCKEY=IDENT
 If fstat
  GOK = -1 : GLOCK = "$ALINK"-OBJET-IDENT : Goto ROLL_TR2
 Endif
 Delete [ALI] Where DSTOBJ=OBJET & DSTKEY=IDENT
 If fstat
  GOK = -1 : GLOCK = "$ALINK"-OBJET-IDENT : Goto ROLL_TR2
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

####################################################### 
## Changement de code 
####################################################### 

Subprog CHGCOD(APPLI,OBJET,OCLE1,OCLE2,NCLE1,NCLE2)   
Value    Char APPLI
Value    Char OBJET   
Value    Char OCLE1   
Value    Char OCLE2()(1..)   
Value    Char NCLE1 
Value    Char NCLE2()(1..) 
Goto CHGCOD_SUB

Subprog CHANGE(OBJET,OCLE1,OCLE2,NCLE1,NCLE2)   
Value    Char OBJET   
Value    Char OCLE1   
Value    Char OCLE2()(1..)   
Value    Char NCLE1 
Value    Char NCLE2()(1..) 
 
$CHGCOD_SUB

Local Char    OIDENT(GLONID) , NIDENT(GLONID) 
 
If dim([L]APPLI)>0 & [L]APPLI<>""
 If clalev([F:ALI])=0 : Local File =APPLI+".ALINK" [ALI] : Endif
Else
 If clalev([F:ALI])=0 : Local File ALINK [ALI] : Endif
Endif

Call IDENT3(OBJET,OIDENT,OCLE1,OCLE2) From GOBJTXT
Call IDENT3(OBJET,NIDENT,NCLE1,NCLE2) From GOBJTXT

If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR3
Else
 Gosub MAJ3
Endif
End

$TR3
GOK = 1
Trbegin [ALI]
 Gosub MAJ3
 If GOK=0 : Goto AB_TR3 : Endif
Commit
Return

$AB_TR3
Rollback
Return

$MAJ3
Update [ALI] Where SRCOBJ=OBJET & SRCKEY=OIDENT With SRCKEY=NIDENT
If fstat
 GOK = 0 : Call FSTA("ALI") From GLOCK : Return
Endif
For [ALI] Where DSTOBJ=OBJET & DSTKEY=OIDENT
 [F:ALI]DSTKEY = NIDENT
 [F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
 Rewrite [ALI]
 If fstat
  GOK = 0 : Call FSTA("ALI") From GLOCK : Break
 Endif
Next
Return

########################################
Subprog AVANT_NBLIG
[M]MODIF(nolign-1) = 1
End

Subprog C_NBLIG
End

Subprog C_DSTKEY(VALEUR)
Variable Char    VALEUR()
Local Char    CLE(GLONID1) , SUPP(GLONID2) , OBJET(GLONAOB)
Local Integer I , NOL
NOL = nolign-1
OBJET = [M]DSTOBJ(nolign-1)
CLE = VALEUR
I = instr(1,CLE,"~")
If I
 SUPP = right$(CLE,I+1)
 CLE  = left$(CLE,I-1)
Else
 SUPP = ""
Endif
mkstat = 0
Call CONTROLE(OBJET,"#",CLE,SUPP,mkstat) From CONTOBJ
If mkstat : End : Endif
For I=0 To [M]NBLIG-1
 If I<>NOL & [M]DSTOBJ(I)=[M]DSTOBJ(NOL) & [M]DSTKEY(I)=VALEUR & [M]INVFLG(I)=[M]INVFLG(NOL)
  GERR = 1 : GMESSAGE = mess(24,123,1)-num$(I+1) : mkstat = 2 : Break
 Endif
Next I
If mkstat : End : Endif
End

