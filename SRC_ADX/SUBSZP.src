#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################################
## Etiquette ajoutée par le superviseur (Objet SZP) 26/01/2010 14:16:39 (VPO)
######################################################################################
$ACTION
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "RAZCRE"    : Gosub RAZCRE
 When "VERIF_CRE"    : Gosub VERIF
 When "VERIF_MOD"    : Gosub VERIF
 When Default
Endcase
Return

######################################################################################
$SETBOUT
If [M]HISSDHFLG=2
    Actzo [M]SDHFOR
Else
    Grizo [M]SDHFOR
Endif
Return

######################################################################################
$RAZCRE

[M]PCU0FLG      =2 : # Flag unité de conditionnement 1
[M]PCU1FLG      =2 : # Flag unité de conditionnement 2
[M]PCU2FLG      =2 : # Flag unité de conditionnement 3
[M]PCU3FLG      =2 : # Flag unité de conditionnement 4
[M]ITMCRITYP    =1 : # Type extraction code
[M]TSICOD0FLG    =2 : # Flag famille statistique 1
[M]TSICOD1FLG    =2 : # Flag famille statistique 2
[M]TSICOD2FLG    =2 : # Flag famille statistique 3
[M]TSICOD3FLG    =2 : # Flag famille statistique 4
[M]TSICOD4FLG    =2 : # Flag famille statistique 5
[M]TCLCODFLG    =2 : # Flag catégorie
[M]CFGLINFLG    =2 : # Flag ligne de produit
[M]PLANNERFLG    =2 : # Flag gestionnaire
[M]FCYCRITYP    =1 : # Type extraction code
[M]CRYFLG      =2 : # Flag pays
[M]BCGCODFLG    =2 : # Flag catégorie
[M]TSCCOD0FLG    =2 : # Flag famille statistique 1
[M]TSCCOD1FLG    =2 : # Flag famille statistique 2
[M]TSCCOD2FLG    =2 : # Flag famille statistique 3
[M]TSCCOD3FLG    =2 : # Flag famille statistique 4
[M]TSCCOD4FLG    =2 : # Flag famille statistique 5
[M]BPCINVFLG    =2 : # Flag client facturé
[M]BPCGRUFLG    =2 : # Flag client groupe
[M]SOHGRU      =1 : # Niveau d'agrégation
[M]HISSOHFLG    =1 : # Commandes
[M]HISSDHFLG    =2 : # Livraisons/factures
Actzo [M]SDHFOR
[M]SOSDLTFLG    =2 : # Suppression article
[M]SOSRAZFLG    =1 : # Raz des prévisions

Affzo [M:SZP1]
Return

######################################################################################
$VERIF
If ([M]HISSOHFLG=1 & [M]HISSDHFLG=1) | ([M]HISSOHFLG=2 & [M]HISSDHFLG=2)
    GERR=1 : GMESSAGE=mess(79,7710,1) : OK=0 : Return
Endif
Return
######################################################################################
######################################################################################
Subprog AM_HISSOHFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    [M]HISSDHFLG=1 : Affzo [M]HISSDHFLG
    Grizo [M]SDHFOR
Else
    [M]HISSDHFLG=2 : Affzo [M]HISSDHFLG
    Actzo [M]SDHFOR
Endif
End

Subprog AM_HISSDHFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    [M]HISSOHFLG=1 : Affzo [M]HISSOHFLG
    Actzo [M]SDHFOR
Else
    Grizo [M]SDHFOR
Endif
End


######################################################################################
Subprog AM_SOSDLTFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M]SOSRAZFLG=2
    [M]SOSRAZFLG=1 : Affzo [M]SOSRAZFLG
Endif
End

Subprog AM_SOSRAZFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M]SOSDLTFLG=2
    [M]SOSDLTFLG=1 : Affzo [M]SOSDLTFLG
Endif
End


######################################################################################

# Issue 98930 - 2014-07-04 by RBA : Volumes managment evolution
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1)
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]VOLFILWRK
 Grizo [M]VOLFILWRK
 Raz [M]VOLFILSTO
 Grizo [M]VOLFILSTO
Else
 Actzo [M]VOLFILWRK
 Actzo [M]VOLFILSTO
Endif
Affzo [M]VOLFILWRK
Affzo [M]VOLFILSTO
End

Subprog C_VOLFILWRK(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTWRK,E_TYPE_FOLDER,GMESSAGE)
End

Subprog C_VOLFILSTO(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTSTO,E_TYPE_FOLDER,GMESSAGE)
End
#/ Issue 98930 - 2014-07-04 by RBA : Volumes managment evolution
