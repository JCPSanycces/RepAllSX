#<AdxTL>@(#)4.0.0.0 $Revision$
#**
#* Location class
#* CRUD method of class + other public or private method
#*
#* @author CBO
#* Issue ${100398} - ${2015-07-29} by ${cfavre} : {Refactoring code}
#*!

$EVENTS

Case [L]CURPTH
  When AVOID.ACHAR
    Case [L]AEVENT
      When "AINSERT_CONTROL_BEFORE"       : Gosub AINSERT_CONTROL_BEFORE
      When "AINSERT_CONTROL_AFTER"        : Gosub AINSERT_CONTROL_AFTER
      When "AUPDATE_CONTROL_BEFORE"       : Gosub AUPDATE_CONTROL_BEFORE
      When "AUPDATE_CONTROL_AFTER"        : Gosub AUPDATE_CONTROL_AFTER
      When "AINSERT_BEFORE"               : Gosub AINSERT_BEFORE   # FQ110511
      When "AINSERT_AFTER"                : Gosub AINSERT_AFTER
      When "AUPDATE_AFTER"                : Gosub AUPDATE_AFTER
    Endcase
  Endcase

Return

$METHODS

Case [L]CURPTH
  When AVOID.ACHAR
    Case [L]AMETHOD
      When "_IS_BAC_UNIQUE"               : Gosub _IS_BAC_UNIQUE
    Endcase
  Endcase

Return

$OPERATIONS

Case [L]CURPTH
  When AVOID.ACHAR
    Case [L]AOPERATION
      When "GET_PROPERTIES_VALUE"         : Gosub GET_PROPERTIES_VALUE # Get some physical element properties values
      When "_PHYLCT_DUPLICATE_OPE"        : Gosub _PHYLCT_DUPLICATE_OPE    # Duplicate Physical  localisation
    Endcase
  Endcase

Return

$PROPERTIES

  Case [L]CURPRO
    When "GEOLOC"           : Gosub GEOLOC
  Endcase

Return

$AINSERT_CONTROL_BEFORE

  #**
  #* PHYLCT-xx Object already exists
  #*!
  Local File PHYLCT [LCT]
  Read [F:LCT]LCT0 = this.LCTCOD
  If fstat = [V]CST_AOK
    [L]ASTATUS = fmet this.ASETERROR("LCTCOD", mess(54,[V]CST_MSGMIS, 1), [V]CST_AERROR)
  Endif

  #**
  #* ==> CPY > If the facility is filled and the company is empty, company is inhereted from the facility
  #*!
  If this.CPY = AVOID.ACHAR and this.FCY <> AVOID.ACHAR
    this.CPY =  fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY, "LEGCPY")
  Endif

  Gosub INSERT_UPDATE_BEFORE

Return

$AINSERT_CONTROL_AFTER

Local Char WMSGERR(250)
Local Integer WCODERR, WDFLT_EXISTS

  #**
  #* PHYLCT-01 Only one default’s localization for à facility.
  #*!
  WDFLT_EXISTS = func EXIST_DEFAULT_LOCATION(this.LCTCOD, this.FCY, WCODERR, WMSGERR)
  If this.DFLFLG = [V]CST_AYES
    If WDFLT_EXISTS = [V]CST_ATRUE
      [L]ASTATUS = fmet this.ASETERROR(AVOID.ACHAR, WMSGERR, [V]CST_AERROR)
    Endif
  Else
    If WDFLT_EXISTS <> [V]CST_ATRUE
      this.DFLFLG = [V]CST_AYES
    Endif
  Endif

Return

$AUPDATE_CONTROL_BEFORE

  Gosub INSERT_UPDATE_BEFORE

Return

$AUPDATE_CONTROL_AFTER

Local Char WMSGERR(250)
Local Integer WCODERR
Local Integer WHYNBR, WIVYNBR

  #**
  #* PHYLCT-01 Only one default’s localization for à facility.
  #*!
  If this.DFLFLG = [V]CST_AYES
    If func EXIST_DEFAULT_LOCATION(this.LCTCOD, this.FCY, WCODERR, WMSGERR) = [V]CST_ATRUE
      [L]ASTATUS = fmet this.ASETERROR("DFLFLG", WMSGERR, [V]CST_AERROR)
    Endif
  Endif

  #**
  #* PHYLCT-02 No modification allowed once a PA attached to location.
  #*!
  If this.snapshot.FCY <> AVOID.ACHAR and this.snapshot.FCY <> this.FCY

    If func PHYELT_C_MPR._GET_LCT_PHY_NBR(this.LCTCOD, this.CPY, WHYNBR, WIVYNBR) = [V]CST_AFALSE
      [L]ASTATUS = fmet this.ASETERROR(AVOID.ACHAR, func AFNC.MES1(mess(95, [V]CST_MSGMIS, 1), num$(fstat)), [V]CST_AERROR)
    Endif
    If WHYNBR
      [L]ASTATUS = fmet this.ASETERROR(AVOID.ACHAR, func AFNC.MES1(mess(103, [V]CST_MSGMIS, 1), num$(fstat)), [V]CST_AERROR)
    Endif

  Endif

Return


$AINSERT_BEFORE
Local Char    ERRMSG(140)
Local Integer RET

  # Issue number 110511
  Local Integer LCTAUTNUM
  #  AGETVALCHAR, AGETVALNUM, AGETVALDAT (Def. Level, level value, Parameter name)
  # Definition level : folder ALEVFOLD,  Company ALEVCPY, Facility ALEVFCY, User ALEVUSR, legislation ALEVLEG, 0= not specified
  # Level value      : folder, company, facility, user or legislation (according to Definition Level)
  # Parameter name
  [L]LCTAUTNUM = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,this.CPY,"LCTAUTNUM")
  If find([L]LCTAUTNUM, [V]CST_NAAUCUNE, [V]CST_NAFACUL, [V]CST_NAOBLIG )= 0
    [L]LCTAUTNUM = [V]CST_NAAUCUNE
  Endif

  #**
  #* ==> LCTCOD > If LCTAUTNUM parameter value is "None", location reference must be filled : It is mandatory.
  #*!
  If [L]LCTAUTNUM = [V]CST_NAAUCUNE and not (this.LCTCOD <> AVOID.ACHAR) Then
    [L]ASTATUS = fmet this.ASETERROR("LCTCOD",mess(19,[V]CST_MSGPHY,1), [V]CST_AERROR)
    Return
  Endif

  #**
  #* ==> LCTCOD > If LCTAUTNUM parameter value is "mandatory" or ("optional" and location reference is empty)
  #*     the location reference is determined according to automatic numbering mechanism
  #*!
  If [L]LCTAUTNUM = [V]CST_NAOBLIG or ( [L]LCTAUTNUM = [V]CST_NAFACUL and this.LCTCOD = AVOID.ACHAR) Then
    # Automatic numbering for location reference
    Call GET_NEW_REFERENCE("LCT",9,1,this.CPY,this.FCY,date$,this.LCTCOD,[L]RET) From FXDFCT_SYRA
    If ([L]RET) Then
      # Error in the automatic numbering
      [L]ERRMSG = func ASYRFNC.MES1(mess(22,[V]CST_MSGPAR, 1), "LCTCOD")
      [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
      Return
    Endif
  Endif
  # End issue number 110511

Return

$AINSERT_AFTER
  #**
  #* PHYLCT-xx If barcode is entered, it must be unique in the folder or in the company according to CPYBACUNY parameter value
  #*!
  If this.BAC <> AVOID.ACHAR
    Local Tinyint B_BAC_UNIQUE
    If fmet this._IS_BAC_UNIQUE([L]B_BAC_UNIQUE) = [V]CST_AOK
      If [L]B_BAC_UNIQUE <> [V]CST_ATRUE
        [L]ASTATUS = fmet this.ASETERROR("BAC", mess(937,[V]CST_MSGFAS,1), [V]CST_AERROR)
      Endif
    Else
      # Method/Operation IS_BAC_UNIQUE error
      [L]ASTATUS = fmet this.AGETMAXERROR(AVOID.ACHAR)
    Endif
  Endif

Return

$AUPDATE_AFTER
  #**
  #* PHYLCT-xx If barcode is entered, it must be unique in the folder or in the company according to CPYBACUNY parameter value
  #*!
  If not (this.BAC = AVOID.ACHAR)
    Local Tinyint B_BAC_UNIQUE
    If not (fmet this._IS_BAC_UNIQUE([L]B_BAC_UNIQUE) = [V]CST_AOK)
      # Method/Operation IS_BAC_UNIQUE error
      [L]ASTATUS = fmet this.AGETMAXERROR(AVOID.ACHAR)
    Else
      If not ([L]B_BAC_UNIQUE = [V]CST_ATRUE)
        [L]ASTATUS = fmet this.ASETERROR("BAC", mess(937,[V]CST_MSGFAS,1), [V]CST_AERROR)
      Endif
    Endif
  Endif
Return


$INSERT_UPDATE_BEFORE
  #**
  #* ==> GEOLOC > If geographical location is not entered, it heritates the geographical location
  #*              of the building to which the location is linked.
  #*!
  If this.GEOLOC = AVOID.ACHAR
    # Get geographical position from building
    If this.BUICOD <> AVOID.ACHAR
      Local Instance BUI Using C_PHYBUI : BUI = NewInstance C_PHYBUI AllocGroup null
      Local Char PROPERTIES(GLONAVA)(1..1)
      Local Char VALUES(255)        (1..1)
      Local Integer RET
      [L]PROPERTIES(1) = "GEOLOC"
      [L]RET = fmet BUI.GET_PROPERTIES_VALUE(this.BUICOD, [L]PROPERTIES, [L]VALUES)
      this.GEOLOC = VALUES(1)
      FreeInstance BUI
    Endif
  Endif

Return

###############################################################################################
$GEOLOC
  Case [L]ARULE
    When "GET"
      # No double quote or comma in the geolocation
      Local Integer I
      For I=1 To len(this.GEOLOC)
        If find(seg$(this.GEOLOC,I,I),'"',',') : this.GEOLOC = func GLOFUNC.SETRNGSTR(this.GEOLOC,I," ") : Endif
      Next
 Endcase
Return

#**
#* Is Bac unique
#* Search if BAC unique in folder or company
#*
#* @param R_BAC_UNIQUE Boolean returned
#* @return (ARET_VALUE) CST_AOK if no error, CST_AERROR otherwise
#*!
$_IS_BAC_UNIQUE

  ARET_VALUE  = [V]CST_AOK

  If this.BAC = AVOID.ACHAR
    #**
    #* Barecode field value is mandatory
    #*!
    R_BAC_UNIQUE = [V]CST_AFALSE
    [L]ARET_VALUE = fmet this.ASETERROR(AVOID.ACHAR, mess(61, [V]CST_MSGMIS, 1), [V]CST_AERROR)
    Return
  Endif

  Local File PHYLCT [LCT]

  Local Integer CPYBACUNY
  # CPYBACUNY will search BAC by folder if equal to Yes or by company if equal to No
  [L]CPYBACUNY = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFLD, AVOID.ACHAR, "CPYBACUNY")

  If ([L]CPYBACUNY = [V]CST_AYES)
    Filter [LCT] Where BAC = this.BAC and CPY = this.CPY and LCTCOD <> this.LCTCOD
  Else
    Filter [LCT] Where BAC = this.BAC and LCTCOD <> this.LCTCOD
  Endif
  Read [LCT]LCT2 First
  Filter [LCT]
  If fstat = [V]CST_AOK
    R_BAC_UNIQUE = [V]CST_AFALSE
  Else
    R_BAC_UNIQUE = [V]CST_ATRUE
  Endif

  LogicClose File [LCT]

  ARET_VALUE= [V]CST_AOK
Return

#**
#* Location value properties
#* Get the value of some properties of a Location
#*    1- Read the physical asset reference
#*    2- Get the value of PROPERTIES (char array) into VALUES (char array)
#*
#* @param LCTCOD      : Location reference
#* @param PROPERTIES  : Name of each property
#* @param VALUES      : Value of each property
#* @return ARET_VALUE : [V]CST_AOK if OK, else [V]CST_AERROR (check error message stack)
#*!
$GET_PROPERTIES_VALUE

  [L]ARET_VALUE = [V]CST_AOK

  # Parameters control
  Local Shortint NB_PRO : [L]NB_PRO = dim([L]PROPERTIES)
  If not ( [L]NB_PRO > 0 )
    [L]ERRMSG = func ASYRFNC.MES2(mess(60, [V]CST_MSGMIS, 1), "PROPERTIES", "GET_PROPERTIES_VALUE")
    [L]ARET_VALUE = fmet this.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    Raz [L]VALUES
    Return
  Endif

  # Read location reference
  If fmet this.AREAD(LCTCOD) <> [V]CST_AOK
    # Reading error on table PHYELT => PHYREF=xxxxxx
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(76,127,1) + "PHYLCT => LCTCOD =" - LCTCOD, [V]CST_AERROR)
    Return
  Endif
  # Get the value of each property into VALUES
  Local Shortint PRO
  For [L]PRO = 1 To [L]NB_PRO
    If PROPERTIES([L]PRO) <> AVOID.ACHAR # FQ113984
      Case evalue("type(this." + PROPERTIES([L]PRO) + ")")
        When 1, 2, 4, 5, 6, 7, 9
          VALUES([L]PRO) = evalue("num$(this."+PROPERTIES([L]PRO)+")")
        When 3
          VALUES([L]PRO) = format$("D:DDMMYYYY", evalue("this."+PROPERTIES([L]PRO)))
        When Default
          VALUES([L]PRO) = evalue("this."+PROPERTIES([L]PRO))
      Endcase
    Endif
  Next

Return

#**
#* Exist an another default location in the same FCY
#*
#* @param PLCTCOD localisation
#* @param PFCY    facility
#* @param RCODERR error code
#* @param RMSGERR error message
#* @return        CST_ATRUE if found, CST_AFALSE otherwise
#*!
Funprog EXIST_DEFAULT_LOCATION(PLCTCOD, PFCY, RCODERR, RMSGERR)
Value Char PLCTCOD(), PFCY()
Variable Integer RCODERR
Variable Char RMSGERR()

  RCODERR = 0
  RMSGERR = AVOID.ACHAR

  If PLCTCOD = AVOID.ACHAR or PFCY = AVOID.ACHAR
    RCODERR = 1
    RMSGERR = func AFNC.MES1(mess(96, [V]CST_MSGMIS, 1), "LCTCOD")
    End [V]CST_AFALSE
  Endif

  Local File PHYLCT [FXX]
  Filter [FXX] Where FCY = PFCY and LCTCOD <> PLCTCOD and DFLFLG = [V]CST_AYES
  Read [FXX]LCT1 First
  Filter [FXX]
  If fstat
    RCODERR = 0
    RMSGERR = AVOID.ACHAR
    End [V]CST_AFALSE
  Endif

  RCODERR = 2
  RMSGERR = func AFNC.MES2(mess(99, [V]CST_MSGMIS, 1), PFCY, [F:FXX]LCTCOD)

End [V]CST_ATRUE

#**
#* Give the default location of a FCY
#*
#* @param PFCY          facility
#* @param RCODERR error code
#* @param RMSGERR error message
#* @return              default location of the FCY
#*!
Funprog GET_DEFAULT_LOCATION(PFCY, RCODERR, RMSGERR)
Value Char PFCY()
Variable Integer RCODERR
Variable Char RMSGERR()

  RCODERR = 0
  RMSGERR = AVOID.ACHAR

  If PFCY = AVOID.ACHAR
    RCODERR = 1
    RMSGERR = func AFNC.MES1(mess(96, [V]CST_MSGMIS, 1), "FCY")
    End AVOID.ACHAR
  Endif

  Local File PHYLCT [FXX]
  Filter [FXX] Where FCY = PFCY and DFLFLG = [V]CST_AYES
  Read [FXX]LCT1 First
  Filter [FXX]
  If fstat = [V]CST_AOK
    RCODERR = 0
    RMSGERR = AVOID.ACHAR
    End [F:FXX]LCTCOD
  Endif

  RCODERR = 2
  RMSGERR = func AFNC.MES1(mess(101, [V]CST_MSGMIS, 1), PFCY)

End AVOID.ACHAR

#**
#* Give the facility of a location
#*
#* @param PLCTCOD location
#* @param RCODERR error code
#* @param RMSGERR error message
#* @return        facility code
#*!
Funprog GET_FACILITY_FROM_LOCATION(PLCTCOD, RCODERR, RMSGERR)
Value Char PLCTCOD()
Variable Integer RCODERR
Variable Char RMSGERR()

  RCODERR = 0
  RMSGERR = AVOID.ACHAR

  If PLCTCOD = AVOID.ACHAR
    RCODERR = 1
    RMSGERR = func AFNC.MES1(mess(96, [V]CST_MSGMIS, 1), "LCTCOD")
    End AVOID.ACHAR
  Endif

  Local File PHYLCT [FXX]
  Read [FXX]LCT0 = PLCTCOD
  If fstat = [V]CST_AOK
    RCODERR = 0
    RMSGERR = AVOID.ACHAR
    End [F:FXX]FCY
  Endif

  RCODERR = 2
  RMSGERR = mess(166, 7775, 1)

End AVOID.ACHAR

#**
#* Duplicate Physical Assrt
#*
#* @param LCTCOD      : Location reference
#* @return ARET_VALUE : [V]CST_AOK if OK, else [V]CST_AERROR (check error message stack)
#*!
$_PHYLCT_DUPLICATE_OPE

  ARET_VALUE = [V]CST_AOK

  #New Instance to create
  Local Instance OLDPYLCT Using C_PHYLCT : OLDPYLCT = NewInstance C_PHYLCT AllocGroup null
  [L]ARET_VALUE =   fmet OLDPYLCT.AREAD(LCTCOD)
  Local Instance NEWPHYLCT Using C_PHYLCT : NEWPHYLCT = NewInstance C_PHYLCT AllocGroup OLDPYLCT

    If clalev([F:LCT])=0  : Local File PHYLCT [LCT]     : Endif

  SetInstanceNoSys   [LCT] With OLDPYLCT #transclass
  SetInstanceNoSys   NEWPHYLCT With [LCT]

  #[L]ASTATUS = fmet NEWPHYLCT.AINIT()# Initialize the Class to create
  If [L]ASTATUS=[V]CST_AOK

    #No auto sequence number - Use numeric increment « _nnn » ?
    NEWPHYLCT.LCTCOD = func NUMINCREMENT(NEWPHYLCT.LCTCOD,"PHYLCT")
    # End of Use numeric increment « _nnn » ?

    #Initialise fields with confluence doc pageId=151948993
    NEWPHYLCT.BAC =AVOID.ACHAR
    NEWPHYLCT.DFLFLG=[V]CST_ANO #NON
    NEWPHYLCT.CREDATTIM=date$
    NEWPHYLCT.UPDDATTIM=date$
    NEWPHYLCT.AUUID=getUuid
    NEWPHYLCT.CREUSR=GACTX.USER
    NEWPHYLCT.UPDUSR=GACTX.USER

    # Create new Instance in database #INSERT
    [L]ASTATUS = fmet NEWPHYLCT.AINSERT()
    If [L]ASTATUS<>[V]CST_AOK
      [L]ASTATUS = fmet this.ASETERROR("",mess(00100,00141,1)-NEWPHYLCT.LCTCOD,[V]CST_AERROR)
     Else
      [L]ASTATUS = func COPYPHOTO("PHYLOC",OLDPYLCT.LCTCOD,NEWPHYLCT.LCTCOD )
      If not [L]ASTATUS = [V]CST_AOK

      Endif
      [L]ASTATUS = fmet this.ASETERROR("",mess(00032,00141,1)-NEWPHYLCT.LCTCOD,[V]CST_ASUCCESS)
    Endif
  Else
      [L]ASTATUS = fmet this.ASETERROR("",mess(00091,00143,1)-NEWPHYLCT.LCTCOD,[V]CST_AERROR)
  Endif

  [L]ARET_VALUE = fmet this.AGETMAXERROR("")

  FreeGroup OLDPYLCT
Return

#** Function numIncrement_( KEYINCR , CLASS )
#*
#* Inrement the key
#*
#* Parameters :
#* @param KEYINCR          Variable Char() The key to increment
#* @param CLASS            The Class of the Key
#* @return newIncrement Key
#*
#* !
Funprog NUMINCREMENT( KEYINCR , CLASS )
Value Char KEYINCR()
Value Char CLASS()

Local Integer INDEXLCT
Local Char INDEXLCTSTR(30)
Local Integer I
Local Integer UNDERSCOREINDEX
Local Char RETOUR(50)

  I=0
  Repeat # Looking for last occurencies of "_"
    UNDERSCOREINDEX = I
    I = instr(I+1,KEYINCR,"_")
  Until I=0

  KEYINCRDEB =  KEYINCR
  INDEXLCT = 1

  If(UNDERSCOREINDEX=0)
    RETOUR=KEYINCR+"_1"
  Else
    INDEXLCTSTR =right$(KEYINCR,UNDERSCOREINDEX+1)
    If func ISNUMERIC(INDEXLCTSTR) # see what's happend when we have a char after _
      INDEXLCT = val(INDEXLCTSTR) #We have a number after _
      INDEXLCT=INDEXLCT+1 #Increment the key
      KEYINCRDEB=left$(KEYINCR,UNDERSCOREINDEX-1)
      RETOUR = KEYINCRDEB+"_"+format$("Nv:5",INDEXLCT)
     Else
       RETOUR=KEYINCR+"_1" # if _ have char after not numeric
       KEYINCRDEB=KEYINCRDEB
    Endif
  Endif
  If CLASS<>"" # IF no class we don't check the uniq ID
    Local File PHYLCT [FXX]
    Repeat
      Read [FXX]LCT0 = RETOUR
      If fstat = [V]CST_AOK
        INDEXLCT=INDEXLCT+1
        RETOUR = KEYINCRDEB +"_"+format$("Nv:5",INDEXLCT)
      Endif
    Until not fstat=0
  Endif
End RETOUR

#**
#*
#* Function:  ISNUMERIC
#*
#* Purpose:   Check if NUMBER consists only of numerical characters ( "0", "1", ... "9" )
#*            and prepends zeroes until NUMBER has the given SIZE. ISNUMERIC returns
#*            TRUE (1) for success and FALSE (0) for failure.
#*
#* Parameters:
#* @param NUMBER          Variable Char() The number to check
#* @param SIZE            Value integer   The size upto which NUMBER should filled with
#*                                        prepending zeroes
#*
#*!
Funprog ISNUMERIC( NUMBER )
Variable Char NUMBER()

    Local Integer LENGTH : LENGTH = len( NUMBER )
    Local Integer I
    # Check if NUMBER consists only of numerical characters.
    For I = 1 To LENGTH
        If ( mid$( NUMBER, I, 1) < "0" ) or ( mid$( NUMBER, I, 1) > "9" )
            # Nonnumerical character found. End with FALSE (failure).
            End 0
        Endif
    Next
    # End with TRUE (success).
End 1

#**
#*
#* Function:  COPYPHOTO
#*
#* Purpose:  Copy the blob photo on the FXTABLE table, return result of copy ( fstat )
#*
#* Parameters:
#* @param CODBLOB          Variable Char() CodeBLOB To copy
#* @param IDENTOLD            OLD ident
#* @param IDENTNEW            New ident
#*
#*!
Funprog COPYPHOTO(CODBLOB, IDENTOLD , IDENTNEW)
Value Char CODBLOB()
Value Char IDENTOLD()
Value Char IDENTNEW()

 Local File FXBLOB [FBB]
 Read [FBB]ABB0= CODBLOB;IDENTOLD
 If fstat = [V]CST_AOK
  [FBB]IDENT1=IDENTNEW
  [FBB]AUUID= getUuid
  Write  [FBB]
 Endif
Close Local File [FBB]

End fstat

