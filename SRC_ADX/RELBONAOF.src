#<AdxTL>@(#)9.0.0.0 $Revision$
#########################################################################
# RELBONAOF : Impression des relances appels d'offre                    #
# --------------------------------------------------------------------- #
# Chargement des paramètres  #
#########################################################################


#########################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
#-----
Call EXEC(NBPAR,PARAMETRE)
#-----
End

#########################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR 
Variable Char    PARAMETRE()()
#-----
Gosub OUVRE   : # Ouverture des tables
If GERREUR  GERREUR=0 : End : Endif 
#-----
Gosub DECLARE : # Déclaration des variables locales
#-----
[L]CRITERE = "1=1"
For I=1 To NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM  = left$([L]PARAMETRE(I),J-1)
    Call GETPARAM([L]PARAM,NBPAR,PARAMETRE,[L]VALEUR) From ETAT
    Case [L]PARAM
      When "X3ETA"           : [L]ETAT     = [L]VALEUR
      When "__REQUETE"       : [L]NUMREQ   = val([L]VALEUR)
      When "sitedeb"         : [L]CRITERE -= "& PQHFCY>='"+[L]VALEUR+"'"
      When "sitefin"         : [L]CRITERE -= "& PQHFCY<='"+[L]VALEUR+"'" 
      When "fournisseurdeb"  : [L]CRITERE -= "& BPSNUM>='"+[L]VALEUR+"'" 
      When "fournisseurfin"  : [L]CRITERE -= "& BPSNUM<='"+[L]VALEUR+"'"
      When "appeldeb"        : [L]CRITERE -= "& PQHNUM>='"+[L]VALEUR+"'" 
      When "appelfin"        : [L]CRITERE -= "& PQHNUM<='"+[L]VALEUR+"'"
#                              [PQF]FUPNBR : filtre sur le Nombre de relances
      When "fournrelances"   : If val([L]VALEUR) = 0
                                  [L]CRITERE -= "& FUPNBR = 0"
                               Else 
                                  [L]CRITERE -= "& FUPNBR > 0"
                               Endif     
#                              TRT_PQH : Traitement filtrant les réponses incomplètes
      When "repincompletes"  : WINCOMPLET = val([L]VALEUR)
#                              TRT_PQH : Traitement filtrant la date de limite réponse
      When "limappeloffre"   : WLIMITE = val([L]VALEUR)
      When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
      When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
      When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
    Endcase
  Endif
Next
# Issue 89114 - 2013-04-04 by SR : etat enchaine
Look [ARM]ARM0 = [L]NUMREQ;GUSER;[F:ARP]RPTCOD;1
If !fstat
  # Enreg trouvé, car lancement enchainé
  # On bloque la boucle
  End
  #On laisse GOK=1 sinon l'état ne sort pas
Endif

#-----
Filter [PQF] Where evalue([L]CRITERE)
Gosub TRT_PQF
End

#########################################################################

$TRT_PQF
Raz WNUMLIG 
Default File [PQF]
For [PQF] PQF0
  Gosub TRT_PQH
  If PQH_PRENDRE
    Call DEBTRANS From GLOCK 
    Gosub TR
  Endif
Next 
Return

#########################################################################

$TRT_PQH
# Par défaut, on prend la l'enregistrement
PQH_PRENDRE = 1

# Lecture de l'entête d'appel d'offre PQH
Read [PQH]PQH0 = [PQF]PQHNUM
If fstat  
   PQH_PRENDRE = 0
Else
# Test 1 sur les Appels d'offres incomplètes
# Si on ne doit pas prendre en compte les Appels d'offres incompletes :
# Alors on lit PQUOTAT pour voir si le nombre d'articles de l'offre est =
# au nombre de réponses de PQUOTATF (car on a 1 réponse par ligne)
  If ! WINCOMPLET
    If [PQF]RSPNBR <> [PQH]LINNBR
      PQH_PRENDRE = 0
    Endif
  Endif
#
# Test 2 sur le délai limite de réponse
  If WLIMITE
    WDATEREP = date$ + WLIMITE
    If WDATEREP > [PQH]RSPDEA
      PQH_PRENDRE = 0
    Endif
  Endif
Endif
Return

##########################################################################

$TR
Trbegin [ARM]
#----- Création d'un enregistrement dans la table AREPORTM -----#
WNUMLIG += 1
Raz [F:ARM]
[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = [F:ARP]RPTCOD
[F:ARM]NUMREQ = [L]NUMREQ
[F:ARM]NUMLIG = WNUMLIG
[F:ARM]CLEA1  = [F:PQF]PQHNUM
[F:ARM]CLEA2  = [F:PQF]BPSNUM
[F:ARM]CREDAT = date$
Write [F:ARM]   
If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR : Endif
#-----
Commit
Return 
 
$ROLL_TR
Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR : Endif 
 
$AB_TR 
Rollback 
Return 

########################################################################### 
 
$OUVRE 
Local File PQUOTATF [PQF], PQUOTAT [PQH], AREPORTM [ARM]
Return 
 
$DECLARE 
Local Char    CRITERE(255), PARAM(30) , VALEUR(30) , ETAT(GLONARP) 
Local Integer WNUMLIG, NUMREQ, IMPR, I, J, WINCOMPLET, PQH_PRENDRE, WLIMITE
Local Date    WDATEREP
Return 
