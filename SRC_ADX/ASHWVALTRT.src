#<AdxTL>@(#)8.0.0.0 $Revision$
Gosub TEST From ASHWVAL
End

#---------------------------------------------------------------------------------------------------#
# Ecriture du traitement
#---------------------------------------------------------------------------------------------------#
Subprog VALSTR_REP(DOSSIER,CODREP,VALP,TYPAGE,ASHW,AERR)
Value Char DOSSIER , CODREP
Value Integer VALP
Variable Integer TYPAGE
Variable  Instance  ASHW  Using OBJECT
Variable  Instance  AERR(1..) Using C_AERROR

Gosub DEFVAR

Call STC_VERF(ASHW.ACLAV.NOMSTC,ASHW.ACLAV.IDENTSTC,[L]APPLI,[L]MACHINE,"STC",[L]OK,AERR) From ACLASUB
If OK

 # creation du fichiet stc (classe)
 Call CREATE_STC(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ASHW,AERR)
 If maxtab(AERR)>0  : End : Endif

 # Creation du traitement de mapping cle/propriété
 Call CREATE_TRTCTLSUP(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ASHW,AERR) From ASHWCTLSUP
 If maxtab(AERR)>0  : End : Endif

 # Creation du fichier WCLA0 , qui integre les methodes, operations ,
 Call CREATE_TRT(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ASHW,AERR)
 If maxtab(AERR)>0  : End : Endif

 # Creation du fichier d'init, et format
 Call CREATE_TRTINI(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ASHW,AERR) From ACLAVALTRT
 If maxtab(AERR)>0  : End : Endif

  # Creation du fichier de control globale
 Call CREATE_TRTCTL(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ASHW,AERR) From ACLAVALTRT
 If maxtab(AERR)>0  : End : Endif

 # Creation du traitement des champs
 Call CREATE_PRG(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ASHW,AERR)
 If maxtab(AERR)>0  : End : Endif

 # Creation du traitement std
 Call CREATE_TRTSTD(ASHW,ASHW.ASWTRT,AERR) From ACLAVALTRT
 If maxtab(AERR)>0  : End : Endif


Endif
Close Local File
End

#-------------------------------------------------------#
#-------------------------------------------------------#
Subprog CREATE_STC(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ASHW,AERR): # fichier STC
Value Integer VALP
Variable Integer TYPAGE
Value Char MACHINE
Value Char APPLI
Value Char DOSSIER
Variable Instance ASHW Using OBJECT
Variable  Instance  AERR(1..) Using C_AERROR

Local Clbfile    CLOB(9)
Local Integer   DIF,OK
Local Char      LIGNE(250)

If ASHW.TEST : Call ECR_TRACE("- Create STC"-ASHW.ACLAV.NOMSTC,0) From GESECRAN  : Endif

Gosub STC_FIELD
Gosub SUB_COM_STD From ACLAVALTRT
Call   STC_CONSTRUCTOR(ASHW,[L]LIGNE,[L]CLOB,[L]DIF) From ACLAVALSTC
Call   STC_CONSTRUCTOR_CLA(ASHW,[L]LIGNE,[L]CLOB,[L]DIF) From ACLAVALSTC
Call   STC_MET_GLO(ASHW,[L]LIGNE,[L]CLOB,[L]DIF) From ACLAVALSTC
Call   STC_INIT(ASHW,[L]LIGNE,[L]CLOB,[L]DIF)  From ACLAVALSTC
Call   STC_CONTROL(ASHW,[L]LIGNE,[L]CLOB,[L]DIF) From ACLAVALSTC
Gosub STC_METHODES
Call   STC_MET_WRIGHT(ASHW,[L]LIGNE,[L]CLOB,[L]DIF)
Call   STC_MTD_STD(ASHW.ACLAV,ASHW.ACLA,ASHW.CODREP,[L]LIGNE,[L]CLOB,[L]DIF) From ACLAVALSTC
Call   STC_ALL(ASHW,[L]LIGNE,[L]CLOB,[L]DIF) From ACLAVALSTC
If ASHW.NBRGRP>0
 Call STC_METHODES_TAB(ASHW,[L]LIGNE,[L]CLOB,[L]DIF)  From ACLAVALSTC
Endif
Call STC_ADELINSTANCE(ASHW,LIGNE,CLOB,DIF) From ACLAVALSTC
Call STC_ADDINSTANCE_BOUND(ASHW,[L]LIGNE,[L]CLOB,[L]DIF) From ACLAVALSTC
Call STC_DEB([L]APPLI,[L]MACHINE,ASHW.ACLAV.NOMSTC,ASHW.ACLAV.IDENTSTC,ASHW.CODECLA,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"STC") From ACLASUB
Call STC_FIN([L]CLOB,ASHW.ACLAV.NOMSTC,ASHW.FLGACTX,[L]DOSSIER,"STC",[L]VALP,[L]TYPAGE,[L]OK,AERR) From ACLASUB
If maxtab(AERR)>0  : End : Endif
End


#-------------------------------------------------------#
#-------------------------------------------------------#
Subprog CREATE_TRT(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ASHW,AERR)  : # Fichier WCLA0***
Value Integer VALP
Variable Integer TYPAGE
Value Char MACHINE
Value Char APPLI
Value Char DOSSIER
Variable Instance ASHW Using OBJECT
Variable  Instance  AERR(1..) Using C_AERROR

Local Clbfile    CLOB(9)
Local Integer   DIF,OK
Local Char      LIGNE(250)

Call TRT_ACTION(ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
Call TRT_ADDTRT(ASHW,ASHW.ASWTRT,LIGNE,CLOB,DIF) From ACLAVALTRT
Call TRT_DECLARE_VAR(ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
Gosub TRT_METHODES
Gosub SUB_COM_STD From ACLAVALTRT
Call TRT_INIT(ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
Call TRT_CONTROL(ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
Call TRT_AERROR(ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
Call TRT_ADELERROR(ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
Call TRT_RICHMEDIA(ASHW,[L]DOSSIER,LIGNE,CLOB,DIF) From ACLAVALTRT
Call METTABGEN("ADELLINE",ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
Call METTABGEN("ADDLINE",ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
Call METTABGEN("AGETDIM",ASHW,LIGNE,CLOB,DIF)  From ACLAVALTRT
Call METTABGEN("AGETMIN",ASHW,LIGNE,CLOB,DIF)  From ACLAVALTRT
Call TRT_EXEMETHOD(ASHW,"OPERATION",LIGNE,CLOB,DIF)
Call TRT_EXEMETHOD(ASHW,"METHOD",LIGNE,CLOB,DIF)
Call TRT__ADELINSTANCE(ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
Call TRT_ADDINSTANCE_BOUND([L]DOSSIER,ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
Call STC_DEB(APPLI,MACHINE,ASHW.ACLAV.CTLPRG,ASHW.ACLAV.IDENTSTC,ASHW.CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
Call TRT_FIN(CLOB,ASHW.ACLAV.CTLPRG,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
If maxtab(AERR)>0 : End : Endif
End

#-------------------------------------------------------#
Subprog CREATE_PRG(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ASHW,AERR)  : # Fichier WCLA0***
Value Integer VALP
Variable Integer TYPAGE
Value Char MACHINE
Value Char APPLI
Value Char DOSSIER
Variable Instance ASHW Using OBJECT
Variable  Instance  AERR(1..) Using C_AERROR

Local Clbfile    CLOB(9)
Local Integer   DIF,OK
Local Char      LIGNE(250)

Raz ASHW.ACLAV.NBPRG
Call SUB_DEF_TRT(ASHW) From ACLAVALTRT
LIGNE = " " : Gosub ADDCLB
Gosub SUB_COM_TRT From ACLAVALTRT
LIGNE = " " : Gosub ADDCLB
For F=1 To maxtab(ASHW.ACLAF)
 If ASHW.ACLAF(F).FLDCLA<>"" & ASHW.ACLAF(F).LNKCLA=""
  Call SUB_COM_FIELD(F,ASHW.ACLAF(F),CLOB,DIF) From ACLAVALTRT
  LIGNE = " " : Gosub ADDCLB
  If ASHW.ACLAF(F).ATY<>null & ASHW.ACLAF(F).ATY.CODTYP<>"" & !find(ASHW.ACLAF(F).ATY.CODTYP,"")
   If ASHW.ACLAF(F).FLGACCGET=2 : Call PRG_FIELD_GET(4,ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT : Endif
   Call PRG_FIELD_SET(0,ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
   Call PRG_FIELD_INIT(1,ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
   Call PRG_FIELD_CONTROL(0,ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
   Call PRG_FIELD_MANDATORY(0,ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
   Call PRG_FIELD_FORMAT(0,ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
   Call PRG_FIELD_OTHERS(2,ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
   Call PRG_FIELD_OTHERS_REF(2,ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
   Call PRG_FIELD_PROPAGATE(3,ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
   Call PRG_FIELD_LNKPRO(10,ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
   Call PRG_FIELD_ATTRIBUTE(0,ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALTRT
   LIGNE = ""  : Gosub ADDCLB
  Endif
  If mod(F,func ACLAVALLEC.MAXPRO)=0 : # find(F,30,60,90,120,150,180,210,240,270,300)>0
   Call STC_DEB(APPLI,MACHINE,ASHW.ACLAV.NOMPRG,ASHW.ACLAV.IDENTSTC,ASHW.CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
   Call TRT_FIN(CLOB,ASHW.ACLAV.NOMPRG,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
   If maxtab(AERR)>0: Break : Endif
   Call SUB_DEF_TRT(ASHW) From ACLAVALTRT
   Raz CLOB
   Gosub SUB_COM_TRT From ACLAVALTRT
   LIGNE = " " : Gosub ADDCLB
  Endif
 Endif
Next
If maxtab(AERR)>0 : End : Endif
Call STC_DEB(APPLI,MACHINE,ASHW.ACLAV.NOMPRG,ASHW.ACLAV.IDENTSTC,ASHW.CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
Call TRT_FIN(CLOB,ASHW.ACLAV.NOMPRG,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
If maxtab(AERR)>0  : End : Endif
LIGNE = ""   : Gosub ADDCLB
End

#-------------------------------------------------------#
$DEFVAR
Local Char    MACHINE(GDIMFIC) , APPLI(GLONADS)  , WCODPRO(250)
Local Integer OK,M
Local Integer NBRATT
Local Integer NBPRG  : # Nombre de traitement genereé WCLA1 , WCLA2..
Gosub OPEN_FILE From ASHWVALLEC
Gosub DEFVAR From ASHWVALLEC
Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS
Return

#-------------------------------------------------------#
$PRG_SET_AZC
AZC =""
VAREVL = ""
AZC = "this."+ASHW.ACLAF(F).FLDCLA
#If ASHW.ACLAF(F).DIME<>1
# AZC += "("+VARIND+")"
# VAREVL = '+"("+num$('+VARIND+')+")"'
#Endif
Return

#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$STC_FIELD
Local Integer NBRFIELD
DIF = 0
Raz ASHW.ACLAV.NBPRG
Call SUB_DEF_TRT(ASHW) From ACLAVALTRT
LIGNE = " " : Gosub ADDCLB
Gosub SUB_COM_TRT From ACLAVALTRT
For F=1 To maxtab(ASHW.ACLAF)
 If ASHW.ACLAF(F).LNKCLA<>"" or (ASHW.ACLAF(F).ATY<>null & find(ASHW.ACLAF(F).ATY.CODTYP))
  NBRFIELD += 1
  Call SUB_COM_FIELD(NBRFIELD,ASHW.ACLAF(F),CLOB,DIF) From ACLAVALTRT
  If ASHW.ACLAF(F).LNKCLA<>ASHW.CODCLA
   Call STC_DEFCLA(ASHW.ACLAF(F),func SUBASW.PREFIX_REP,ASHW,LIGNE,CLOB,DIF) From ACLAVALSTC : # Déclaration de la sous-classe
  Else
   Call STC_DEFCLA(ASHW.ACLAF(F),func SUBACLA.PREFIX_CLA,ASHW,LIGNE,CLOB,DIF) From ACLAVALSTC : # Déclaration de la sous-classe
  Endif
 Elsif ASHW.ACLAF(F).ATY<>null & ASHW.ACLAF(F).ATY.CODTYP<>"" & !find(ASHW.ACLAF(F).ATY.CODTYP,"") & ASHW.ACLAF(F).LNKCLA=""
  NBRFIELD += 1 : Call SUB_COM_FIELD(NBRFIELD,ASHW.ACLAF(F),CLOB,DIF) From ACLAVALTRT
  Call STC_FIELD_DECLARE(ASHW.ACLAF(F),LIGNE,CLOB,DIF) From ACLAVALSTC        : # Déclaration du champ
  LIGNE -= "{" : Gosub ADDCLB
  WFLD = ASHW.ACLAF(F).FLDCLA
  WDIME =  1 : #  ASHW.ACLAF(F).DIME
  WTYPTYP = ASHW.ACLAF(F).ATY.TYPTYP
  If ASHW.ACLAF(F).FLGACCGET=2 : Call STC_FIELD_GET(ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALSTC : Endif
  Call STC_FIELD_SET(ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALSTC
  Call STC_FIELD_INIT(ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALSTC
  Call STC_FIELD_CONTROL(ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALSTC
  Call STC_FIELD_LNKPRO(ASHW.ACLAF(F),ASHW,LIGNE,CLOB,DIF) From ACLAVALSTC
  Call STC_FIELD_ATEXTRA(ASHW.ACLAF(F),LIGNE,CLOB,DIF) From ACLAVALSTC
  Call STC_FIELD_ATEXTE(ASHW.ACLAF(F),LIGNE,CLOB,DIF) From ACLAVALSTC
  LIGNE = "}"  : Gosub ADDCLB
  LIGNE = ""  : Gosub ADDCLB
 Endif
 If mod(F,func ACLAVALLEC.MAXPRO)=0 : Call SUB_DEF_TRT(ASHW) From ACLAVALTRT : Endif : # find(F,30,60,90,120,150,180,210,240,270,300)>0
Next
Call STC_FIELD_OBLIG(ASHW,LIGNE,CLOB,DIF) From ACLAVALSTC
LIGNE = ""   : Gosub ADDCLB
LIGNE = "%% # End Classe" : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB
Return

#-------------------------------------------------------#

Subprog STC_MET_WRIGHT(ASHW,LIGNE,CLOB,DIF)
Variable Instance ASHW Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Char     MET(1),PROGRAM(20)
Local Integer OKMET
Local Integer BEHAVIOR:BEHAVIOR=0:#SAM 118140

Gosub INTERLINE From ACLAVALTRT
For MET="C","U","D"
 PROGRAM = "AGETWRIGHT"+[L]MET
 LIGNE = "# Fmethod : "+PROGRAM  : Gosub ADDCLB
 LIGNE = "Fmethod "+PROGRAM : Gosub ADDCLB
 OKMET = 0
 #{SAM 118140
 BEHAVIOR += 1
 If ASHW.ENACOM(BEHAVIOR) <> 2
   LIGNE = 'End func ASYRSUB._ASETSTATUS(this,"",0,[V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,mess('+num$(358+BEHAVIOR)+',139,1))' : Gosub ADDCLB
 Else
  #SAM 118140}
  If ASHW.AFCRIGHT<>""
   For MT=1 To maxtab(ASHW.ACLA.ACLAT)
     If ASHW.ACLA.ACLAT(MT).CODMETSTD=[L]MET
      OKMET = 1 : Break
    Endif
   Next
  Endif
  If ASHW.AFCRIGHT="" or OKMET=0
   LIGNE = "If fmet this.ACTX.AGETLIC_EXPIRED(func ASYRLIC.GET_CHPRODUCTSTDCODE)=[V]CST_ATRUE" : Gosub ADDCLB
   DIF += 1
   LIGNE = 'End func ASYRSUB._ASETSTATUS(this,"",0,[V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,mess(327,139,1)-mess(328,139,1))' : Gosub ADDCLB
   DIF -= 1
   LIGNE = "Endif" : Gosub ADDCLB
   LIGNE = "End [V]CST_AOK" : Gosub ADDCLB
  Else
   LIGNE = "Local Integer ASTATUS"  : Gosub ADDCLB
   LIGNE = '[L]ASTATUS = fmet this.ACTX.AGETAFCRIGHT(this,"'+ASHW.AFCRIGHT+'",[V]CST_ATRUE)' : Gosub ADDCLB
   LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif' : Gosub ADDCLB
   If ASHW.ACLA.FCYSTR<>""
    LIGNE = '[L]ASTATUS = fmet this.ACTX.AGETAFCRIGHT'+[L]MET+'(this,"'+ASHW.AFCRIGHT+'",this.'+ASHW.ABRCLA+"."+ASHW.ACLA.FCYSTR+',[V]CST_ATRUE)' : Gosub ADDCLB
   Else
    LIGNE = '[L]ASTATUS = fmet this.ACTX.AGETAFCRIGHT'+[L]MET+'(this,"'+ASHW.AFCRIGHT+'","",[V]CST_ATRUE)' : Gosub ADDCLB
   Endif
   LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif' : Gosub ADDCLB
   If [L]MET="R"
    If ASHW.ACLA.ACCSTR<>""
     LIGNE = '[L]ASTATUS = fmet this.ACTX.AGETACSRIGHTC(this,this.'+ASHW.ABRCLA+"."+ASHW.ACLA.ACCSTR+',[V]CST_ATRUE)' : Gosub ADDCLB
     LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif' : Gosub ADDCLB
    Endif
   Elsif find([L]MET,"U","D")>0
    If ASHW.ACLA.ACCSTR<>""
     LIGNE = '[L]ASTATUS = fmet this.ACTX.AGETACSRIGHTM(this,this.'+ASHW.ABRCLA+"."+ASHW.ACLA.ACCSTR+',[V]CST_ATRUE)' : Gosub ADDCLB
     LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif' : Gosub ADDCLB
    Endif
   Endif
   LIGNE = "End [L]ASTATUS" : Gosub ADDCLB
  Endif
 Endif  #SAM 118140
 LIGNE = " " : Gosub ADDCLB
Next
End

#-------------------------------------------------------#
$STC_METHODES
For M=1 To maxtab(ASHW.ACLAM)
 If M=1 : Gosub SUB_COM_METHOD From ACLAVALTRT : Endif
 Call STC_MET(ASHW,ASHW.ACLAM(M),LIGNE,CLOB,DIF) From ACLAVALSTC
Next
Return

#-------------------------------------------------------#
$TRT_METHODES
For M=1 To maxtab(ASHW.ACLAM)
 If M=1 : Gosub SUB_COM_METHOD From ACLAVALTRT : Endif
 Call TRT_MET(ASHW.ACLAM(M),LIGNE,CLOB,DIF)  From ACLAVALTRT
Next
Return

Subprog TRT_EXEMETHOD(ASHW,EXEMET,LIGNE,CLOB,DIF)
Variable Instance ASHW Using OBJECT
Value Char EXEMET
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Char TABOPE(GLONASM)(1..)
Local Char TABMET(GLONASM)(1..)

Gosub INTERLINE From ACLAVALTRT
LIGNE = "# EXEC"-EXEMET : Gosub ADDCLB
Gosub INTERLINE From ACLAVALTRT
LIGNE = "Subprog EXE_"+EXEMET+"(WCLA,_"+EXEMET
If EXEMET="METHOD"
 LIGNE += ",NAME_INSTANCE"
Elsif  EXEMET="OPERATION"
 LIGNE += ",ACLBRETURN" : #109788
 LIGNE += ",ACLE"
Endif
LIGNE += ",ATBPAR,TBVAL)" : Gosub ADDCLB
LIGNE = "Variable Instance WCLA Using OBJECT" : Gosub ADDCLB
If EXEMET="METHOD"
 LIGNE = "Value    Char  NAME_INSTANCE" : Gosub ADDCLB
Endif
LIGNE = "Value    Char _"+EXEMET : Gosub ADDCLB
If  EXEMET="OPERATION"
 LIGNE = "Variable Clbfile ACLBRETURN" : Gosub ADDCLB : #109788
 LIGNE = "Value    Char ACLE" : Gosub ADDCLB
Endif
LIGNE = "Variable Char ATBPAR()(1..)" : Gosub ADDCLB
LIGNE = "Variable Char TBVAL()(1..)" : Gosub ADDCLB
LIGNE = "Local Integer ASTATUS" : Gosub ADDCLB
LIGNE = "Case [L]_"+EXEMET : Gosub ADDCLB
DIF += 1
For I=1 To maxtab(ASHW.ASWK)
 If find(ASHW.ASWK(I).TYPLNK,2,3)>0
  Call EXEMETHOD(ASHW,ASHW.ASWK(I),EXEMET,LIGNE,CLOB,DIF,TABOPE,TABMET)
 Endif
Next
#For I=1 To maxtab(ASHW.ASWR)
# For J=1 To maxtab(ASHW.ASWR(I).ASWK)
#  If find(ASHW.ASWR(I).ASWK(J).TYPLNK,2,3)>0
#   Call EXEMETHOD(ASHW,ASHW.ASWR(I).ASWK(J),EXEMET,LIGNE,CLOB,DIF,TABOPE,TABMET)
#  Endif
# Next
#Next
LIGNE = "When Default" : Gosub ADDCLB
DIF -= 1
LIGNE = "Endcase " : Gosub ADDCLB
LIGNE = "End" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End


Subprog EXEMETHOD(ASHW,ASWK,EXEMET,LIGNE,CLOB,DIF,TABOPE,TABMET)
Variable Instance ASHW Using OBJECT
Variable Instance ASWK Using OBJECT
Value Char EXEMET
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Variable Char TABOPE()(1..)
Variable Char TABMET()(1..)

 If (!find(ASWK.CODOPELNK,[L]TABOPE) & EXEMET="OPERATION") or (!find(ASWK.CODMETLNK,[L]TABMET) & EXEMET="METHOD")
  If find(ASWK.TYPLNK,2)>0 & EXEMET="METHOD"
   [L]TABMET(maxtab(TABMET)+1) = ASWK.CODMETLNK
  Elsif EXEMET="OPERATION"
   [L]TABOPE(maxtab(TABOPE)+1) = ASWK.CODOPELNK
  Endif
  LIGNE = 'When "'+string$(ASWK.CODOPELNK<>"",ASWK.CODOPELNK)+ASWK.CODMETLNK+'"' : Gosub ADDCLB
  DIF += 1
  For J=1 To maxtab(ASWK.ATBKEY)
   LIGNE = "# Keys" : Gosub ADDCLB
   LIGNE = "Local"-func ACLAVALTRT.DECLARE_TYPTYP(ASWK.ATBKEY(J).TYPINT)-"_"+ASWK.ATBKEY(J).CODPAR
   If ASWK.ATBKEY(J).TYPINT=7
    LIGNE += "(250)"
   Endif
   Gosub ADDCLB
  Next
  If  EXEMET="OPERATION" : LIGNE = "Gosub SET_CLE From ASYRSUB" : Gosub ADDCLB : Endif
  For J=1 To maxtab(ASWK.ATBKEY)
   LIGNE = "[L]_"+ASWK.ATBKEY(J).CODPAR+" = "
   Case ASWK.ATBKEY(J).TYPINT
    When 1,2,3,4,5,6       : LIGNE += "val(" : #"Integer"
    When 7,11,12      : LIGNE += "num$(" : #"Char , UUid , DateTime
     #When 4           : LIGNE += 'format$("D:DD[/]MM[/]YYYY"," : #"Date"'
    When 8             : LIGNE += 'func ASYRSUB.DATE_TO_ADX('
    When 9,10       : LIGNE += "num$(" : #"Blbfile ,clob
   Endcase
   LIGNE += "[L]CLE("+num$(J)+"))"
   Gosub ADDCLB
  Next
  LIGNE = "# Parameters value" : Gosub ADDCLB
  For J=1 To maxtab(ASWK.ATBPAR)
   LIGNE = "Local"-func ACLAVALTRT.DECLARE_TYPTYP(ASWK.ATBPAR(J).TYPINT)-"_"+ASWK.ATBPAR(J).CODPAR
   If ASWK.ATBPAR(J).TYPINT=7
    LIGNE += "(250)"
   Endif
   Gosub ADDCLB
   LIGNE = "[L]_"+ASWK.ATBPAR(J).CODPAR+ " = func ASYRSUB."
   Case ASWK.ATBPAR(J).TYPINT
    When 7,9,10,12  : LIGNE += "PARAM_CHAR"
    When 1,2,3,4,5,6        : LIGNE += "PARAM_NUM"
    When 8            : LIGNE += "PARAM_DAT"
    When 11           : LIGNE += "PARAM_UUID"
   Endcase
   LIGNE += '("'+ASWK.ATBPAR(J).CODPAR+'",ATBPAR,TBVAL)'
   Gosub ADDCLB
  Next
  LIGNE = "# Call "+tolower(EXEMET) : Gosub ADDCLB
  LIGNE = "Local "
  #AML7843
  Case ASWK.TYPRETMET
   When 1 : LIGNE += "Date"
   When 2 : LIGNE += "Char"
   When 3 : LIGNE += "Integer"
   When 4 : LIGNE += "Decimal"
   When 5 : LIGNE += "Clbfile"
   When 6 : LIGNE += "Blbfile"
   When Default : LIGNE += "Integer"
  Endcase
  LIGNE += " ARETURN"
  If ASWK.TYPRETMET=2
   LIGNE += "(250)"
  Endif
  Gosub ADDCLB
  If EXEMET="METHOD"
   LIGNE =  'If [L]NAME_INSTANCE=""' :  Gosub ADDCLB
   DIF += 1 : LIGNE =  '[L]NAME_INSTANCE = "WCLA"' : Gosub ADDCLB :  DIF -= 1
   LIGNE =  'Else' : Gosub ADDCLB
   DIF += 1 : LIGNE =  '[L]NAME_INSTANCE = "WCLA."+[L]NAME_INSTANCE' : Gosub ADDCLB :  DIF -= 1
   LIGNE =  'Endif' : Gosub ADDCLB
   LIGNE = "[L]ARETURN = evalue('fmet'-NAME_INSTANCE+'."
  Else
   LIGNE = "[L]ARETURN = fmet WCLA."
  Endif
  LIGNE += string$(ASWK.CODOPELNK<>"",ASWK.CODOPELNK)+ASWK.CODMETLNK
  LIGNE += "("
  M = 0 : N = 0 : L=0
  For J=1 To maxtab(ASWK.ATBKEY)
   If J>1 : LIGNE += "," : Endif
   LIGNE += "[L]_"+ASWK.ATBKEY(J).CODPAR
   M=1
  Next
  For J=1 To maxtab(ASWK.ATBPAR)
    N +=1
    If N>1 or M>0 : LIGNE += "," : Endif
    LIGNE += "[L]_"+ASWK.ATBPAR(J).CODPAR
  Next
  LIGNE += ")"
  If EXEMET="METHOD"
   LIGNE += "')"
  Endif
  Gosub ADDCLB
  If EXEMET="OPERATION" : #109788
   LIGNE =  "[L]ACLBRETURN='"
   LIGNE+=  '{ "$type":"'
   #AML7843
   Case ASWK.TYPRETMET
    When 1 : LIGNE += func ASYRJSO.TYP('date')
    When 2 : LIGNE += func ASYRJSO.TYP('string')
    When 3 : LIGNE += func ASYRJSO.TYP('integer')
    When 4 : LIGNE += func ASYRJSO.TYP('decimal')
    When 5 : LIGNE += "text"
    When 6 : LIGNE += func ASYRJSO.TYP('binary')
    When Default : LIGNE += func ASYRJSO.TYP('integer')
   Endcase
   LIGNE+=  '", "$value":'+"'"
   Gosub ADDCLB
   #AML7843
   LIGNE=""
   Case ASWK.TYPRETMET
    When 1 : LIGNE = 'If [L]ARETURN=[0/0/0] : '+"[L]ACLBRETURN+='"+'""'+"'" : Gosub ADDCLB
             LIGNE = "Else [L]ACLBRETURN+='"+'"'+"'+"+'format$("D:YYYY[-]MM[-]DD",[L]ARETURN)'+"+'"+'"'+"'" : Gosub ADDCLB
             LIGNE = 'Endif'
    When 2 : LIGNE = "[L]ACLBRETURN+='"+'"'+"'+"+'escJson([L]ARETURN)'+"+'"+'"'+"'"
    When 3 : LIGNE = "[L]ACLBRETURN+=num$([L]ARETURN)"
    When 4 : LIGNE = "[L]ACLBRETURN+=num$([L]ARETURN)"
    When 5 : LIGNE = "[L]ACLBRETURN+='"+'"'+"'+"+'escJson([L]ARETURN)'+"+'"+'"'+"'"
    When 6 : LIGNE = 'If len([L]ARETURN)=0 : '+"[L]ACLBRETURN+='"+'""'+"'" : Gosub ADDCLB
             LIGNE = "Else [L]ACLBRETURN+='"+'"'+"'+"+'func ASYRJSO.ENCODE64_BLOB([L]ARETURN)'+"+'"+'"'+"'" : Gosub ADDCLB
             LIGNE = 'Endif'
    When Default : LIGNE = "[L]ACLBRETURN+=num$([L]ARETURN)"
   Endcase
   Gosub ADDCLB
   LIGNE = "[L]ACLBRETURN+=' } '"
   Gosub ADDCLB
  Endif
  DIF -=1
 Endif
End

