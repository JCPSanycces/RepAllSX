#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure PINVOICE

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER
      Endcase
  # Issue 103757 - 2014-11-07 by SR
   When "PID"
     Case [L]AEVENT
       When "AREAD_AFTER"      : Gosub PID_AREAD_AFTER
     Endcase
   Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "LEG" :
      Case [L]ARULE
        When "GET"     : Gosub LEG_GET
      Endcase
  Endcase
Return


#######################################################################################
$AREAD_AFTER
  Local Decimal TOTALAMT
  Local Decimal TOTTAXAMT
  Local Decimal INVELEMENTTOT
  Local Decimal SUMLINAMT
  Local Integer X
  Local Integer LEDTYP

  Local File PINVOICED [PID]
  Local File PINVOICEV [PIV]
  Local File PVCRFOOT [PVF]
  Local File PVCRVAT [PVV]
  Local File GACCDUDATE [GAC]
  Local File COMPANY [CPY]
  Local File ATEXTRA [AXX]

  #Set Invoice type description.  No Representation for Purchase invoice type to link to.
  Read [AXX]AXX0 = "TABPIVTYP";"DESAXX";this.ACTX.LAN;this.PIVTYP;""
  If !fstat
    this.PIVTYPDES = [AXX]TEXTE
  Endif

  #Set currency and rate fields.  First need GENLEDTYP field from GACM table (Account Core Model) which will replace
  #the GTYPEGEN global variable from V6.
  #Local Instance COMPANY Using C_COMPANY
  #COMPANY = NewInstance With C_COMPANY
  #[L]ASTATUS = fmet COMPANY.AREAD(this.CPY)
  Read [CPY]CPY0 = this.CPY

  Local Instance GACM Using C_GACM
  GACM = NewInstance C_GACM AllocGroup null
  [L]ASTATUS = fmet GACM.AREAD([CPY]ACM)
  LEDTYP = GACM.GENLEDTYP

  #This logic came from V6 routine CHARG_RATCUR in TRTX3CPT.
  this.RAT1 = [F:PIH]RATDIV(LEDTYP - 1)
  this.CURDIV = [F:PIH]CUR
  this.RAT2 = [F:PIH]RATMLT(LEDTYP - 1)
  this.CURMLT = [F:PIH]CURLED(LEDTYP - 1)

  #Add up tax amounts.  This is from PIV (PINVOICEV) which is a one to one relationship.  No need to loop.
  Read [PIV]PIV0 = this.NUM
  If !fstat
    TOTALAMT = [PIV]TOTLINAMT + [PIV]TOTTAXAMT
  Endif

  #Calculate Var -tax
  this.DIFLINAMT = [PIV]TOTLINAMT - [PIV]CLCLINAMT

  #Add up invoice line element amounts.  Also, add invoice element descriptions in same loop.
  For [PVF] Where VCRNUM=this.NUM & VCRTYP=8
    INVELEMENTTOT = INVELEMENTTOT + [PVF]INVDTAAMT
  Next PVF
  TOTALAMT = TOTALAMT + INVELEMENTTOT

  #Add up net price by line.
  For [PID] Where NUM=this.NUM
    SUMLINAMT = SUMLINAMT + [PID]AMTNOTLIN
  Next PVF
  this.CUMLINAMT1 = SUMLINAMT
  this.WCUR = this.CUR

  #Set property
  this.TOTATIAMT1 = TOTALAMT

  #Calculate Tax variance
  #Add up tax amounts from PVCRVAT
  TOTALAMT = 0
  For [PVV] Where VCRNUM=this.NUM & VCRTYP=8
    TOTALAMT = TOTALAMT + [PVV]AMTTAX
  Next PVF
  TOTALAMT = [PIV]TOTTAXAMT - TOTALAMT
  this.DIFTAXAMT = TOTALAMT

  #Var +tax
  this.DIFAMTATI = this.DIFLINAMT + this.DIFTAXAMT

  #Set CUR2 and CUR3 properties
  this.CUR2 = this.CUR
  this.CUR3 = this.CUR

  #Set EECICT2 and ICTCTY2 properties
  this.ICTCTY2 = this.ICTCTY
  this.EECICT2 = this.EECICT

  #Set purchase cost properties
  this.DOCCUR = this.CUR
  this.CPYCUR = this.CURMLT

  #Tax excl line total
  #X = fmet this.ADDLINE("COL_COSTS",[V]CST_ALASTPOS)
  #this.COL_COSTS(1).COSTTITLE = mess(00442,00194,1)
  #this.COL_COSTS(1).DOCCURAMT = [PIV]CLCLINAMT
  #this.COL_COSTS(1).CPYCURAMT = [PIV]CLCLINAMT * this.RAT2

  #Direct cost total
  #X = fmet this.ADDLINE("COL_COSTS",[V]CST_ALASTPOS)
  #this.COL_COSTS(2).COSTTITLE = mess(00443,00194,1)

  #Invoicing element total (Upd)
  #X = fmet this.ADDLINE("COL_COSTS",[V]CST_ALASTPOS)
  #this.COL_COSTS(3).COSTTITLE = mess(00444,00194,1)
  #this.COL_COSTS(3).DOCCURAMT = INVELEMENTTOT
  #this.COL_COSTS(3).CPYCURAMT = INVELEMENTTOT

  #Landed cost total (Coef + FCU)
  #X = fmet this.ADDLINE("COL_COSTS",[V]CST_ALASTPOS)
  #this.COL_COSTS(4).COSTTITLE = mess(00445,00194,1)

  #Additional invoice total
  #X = fmet this.ADDLINE("COL_COSTS",[V]CST_ALASTPOS)
  #this.COL_COSTS(5).COSTTITLE = mess(00446,00194,1)

  #Non-deductible tax total
  #X = fmet this.ADDLINE("COL_COSTS",[V]CST_ALASTPOS)
  #this.COL_COSTS(6).COSTTITLE = mess(00447,00194,1)

  #Cost total
  #X = fmet this.ADDLINE("COL_COSTS",[V]CST_ALASTPOS)
  #this.COL_COSTS(7).COSTTITLE = mess(00448,00194,1)

  #Invoicing element total (Min)
  #X = fmet this.ADDLINE("COL_COSTS",[V]CST_ALASTPOS)
  #this.COL_COSTS(8).COSTTITLE = mess(00450,00194,1)

  #Purchase cost total
  #X = fmet this.ADDLINE("COL_COSTS",[V]CST_ALASTPOS)
  #this.COL_COSTS(9).COSTTITLE = mess(00449,00194,1)

  #Set price/quantity variance flag (I'm not sure why the caption for this field is "Reason")
  Local Char REASONMESSAGE(80)
  REASONMESSAGE = ""
  If [PIV]QTYLINNBR<>0 & [PIV]PRILINNBR<>0 REASONMESSAGE = mess(154,194,1) : End : Endif
  If [PIV]QTYLINNBR<>0 REASONMESSAGE = mess(152,194,1) : Endif
  If [PIV]PRILINNBR<>0 REASONMESSAGE = mess(153,194,1) : Endif
  this.LIBPAZ = REASONMESSAGE

  #Get due date
  Read [GAC]DUD0 = this.GTE;this.NUM;1;1
  If !fstat
    this.DUDAT1 = [GAC]DUDDAT
  Endif

  #Set billing address name and address lines.  This address record is always in the header.
  this.BPRNAME1 = [F:PIH]BPRNAM(0)
  this.BPRNAME2 = [F:PIH]BPRNAM(1)
  this.BPAADDLIG1 = [F:PIH]BPAADDLIG(0)
  this.BPAADDLIG2 = [F:PIH]BPAADDLIG(1)
  this.BPAADDLIG3 = [F:PIH]BPAADDLIG(2)
  #Set payment address.  This is not stored in the header unless a change has been made.
  Local Integer TMP

  # Read address from BPADDRESS if address has not been modified
  If this.BPYADDLIG1 = AVOID.ACHAR and
&    this.BPYADDLIG2 = AVOID.ACHAR and
&    this.BPYADDLIG3 = AVOID.ACHAR and
&    this.BPYCTY     = AVOID.ACHAR and
&    this.BPYPOSCOD  = AVOID.ACHAR and
&    this.BPYSAT     = AVOID.ACHAR and
&    this.BPYCRY     = AVOID.ACHAR and
&    this.BPAPAY    <> AVOID.ACHAR
    Local Instance BPARTNER Using C_BPARTNER
    BPARTNER = NewInstance C_BPARTNER AllocGroup GACM
    [L]ASTATUS = fmet BPARTNER.AREAD(this.BPRPAY)
    For TMP=1 To maxtab(BPARTNER.C_BPRNAM)
      Assign "this.BPYNAME"+num$(TMP) With BPARTNER.C_BPRNAM(TMP).BPRNAM
    Next
    Local Instance BPADDRESS Using C_BPADDRESS
    BPADDRESS = NewInstance C_BPADDRESS AllocGroup GACM
    [L]ASTATUS = fmet BPADDRESS.AREAD(1, this.BPRPAY, this.BPAPAY)
    If [L]ASTATUS=[V]CST_AOK
      this.BPYADDLIG1 = BPADDRESS.BPAADDLIG1
      this.BPYADDLIG2 = BPADDRESS.BPAADDLIG2
      this.BPYADDLIG3 = BPADDRESS.BPAADDLIG3
      this.BPYCTY        = BPADDRESS.CTY
      this.BPYPOSCOD     = BPADDRESS.POSCOD
      this.BPYSAT        = BPADDRESS.SAT
      this.BPYCRY        = BPADDRESS.CRY
      this.BPYCRYNAM     = BPADDRESS.CRYNAM
    Endif
    BPARTNER = null
    BPADDRESS = null
  Else
    # Separate multi-dimensional fields into individual properties
    this.BPYNAME1 = [F:PIH]BPYNAM(0)
    this.BPYNAME2 = [F:PIH]BPYNAM(1)
    this.BPYADDLIG1 = [F:PIH]BPYADDLIG(0)
    this.BPYADDLIG2 = [F:PIH]BPYADDLIG(1)
    this.BPYADDLIG3 = [F:PIH]BPYADDLIG(2)
  Endif

  Close File[PID]
  Close File[PVV]
  Close File[PVF]
  Close File[PIV]
  Close File[GAC]
  Close File[CPY]
  Close File[AXX]
  FreeGroup GACM
  GACM = null
Return

#######################################################################################
# Issue 103757 - 2014-11-07 by SR
$PID_AREAD_AFTER
  this.CRY = this.APARENT.CRY
Return

#######################################################################################
$LEG_GET
  Local Instance FACILITY Using C_FACILITY
  FACILITY = NewInstance C_FACILITY AllocGroup null
  [L]ASTATUS = fmet FACILITY.AREAD(this.FCY)

  If [L]ASTATUS=[V]CST_AOK
    Local Instance VATX Using C_TABVAT
    VATX = NewInstance C_TABVAT AllocGroup FACILITY
    [L]ASTATUS = fmet VATX.AREAD("this.LEG",FACILITY.LEG)
    If [L]ASTATUS<>[V]CST_AOK
      [L]ASTATUS = fmet VATX.AREAD("this.LEG",AVOID.ACHAR)
    Endif
    If [L]ASTATUS=[V]CST_AOK
        this.LEG = VATX.LEG
    Endif
    VATX = null
  Endif

  FreeGroup FACILITY
  FACILITY = null
Return

