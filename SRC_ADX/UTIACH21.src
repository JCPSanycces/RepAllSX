#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################
# UTIACH21      Utilitaire de correction des valeurs        Module ACHAT #
#               par défaut de l'état BONRCP suite à                      #
#               une migration v5 vers v6                      01/09/2010 #
# ---------------------------------------------------------------------- #
#   Changer les "[M:PTH1]" par "[M:PTH0]" dans les valeurs par défaut    #
##########################################################################


Call MAJ_UTIACH21
End


Subprog MAJ_UTIACH21
Local Char DOSSIER(30)
DOSSIER=nomap
#--- Issue 108760 by TS
#Call SAIDOS(DOSSIER,"UTIACH21 - Default values adjustment for report BONRCP") From SAIDOS
Call SAIDOSHIS(DOSSIER,"UTIACH21 - Default values adjustment for report BONRCP") From SAIDOSHIS
#---
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH21 : Default values adjustment utility for report BONRCP") From LECFIC
  Call ECR_TIME("UTIACH21 : Starting process on folder "+DOSSIER) From DOSSUB
  Call EXE_UTIACH21(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIACH21(DOSSIER)
Value Char     DOSSIER
#----- Variables locales -----#
Local Char     WMSG(90)
Local Integer  NBENR, NBCOR
Local Char     WFONCTION(GLONAFC)
Local Integer  TYPCOD
Local Char     WETAT(15)
Local Char     WPARAM(30)
Local Char     WVALDEF1(250), WVALDEF2(250)
Local Libelle  WFLAG
Local Libelle  WTRACE : WTRACE=2 : # WTRACE=2 --> Trace détaillée
#-----
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
#----- Ouverture du fichier -----#
If !clalev([F:ARV])  Local File =DOSSIER+".AREPORTV"    [ARV] : Endif
#----- Début du traitement -----#
Raz NBENR, NBCOR
Gosub TRT_AREPORTV
#----- Fin du traitement -----#
$FIN_UTIACH21
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
WMSG ="UTIACH21 : Number of processed records :"-num$(NBENR)
WMSG+=" corrected :"-num$(NBCOR)

Call ECR_TIME(WMSG) From DOSSUB
Close Local File [ARV]
End


#---------------------------#
# Traitement table AREPORTV #
#---------------------------#
$TRT_AREPORTV
Call DEBTRANS From GLOCK
GOK=1
#-----
Trbegin [ARV]
  For [ARV] ARV1 Where TYPCOD=1 & ETAT="BONRCP"
    NBENR+=1
    WFONCTION=[F:ARV]FONCTION
    WTYPCOD  =[F:ARV]TYPCOD
    WETAT    =[F:ARV]ETAT
    WPARAM   =[F:ARV]PARAM
    WVALDEF1 =[F:ARV]VALDEF1
    WVALDEF2 =[F:ARV]VALDEF2
    Raz WFLAG
    #-----
    If instr(1,WVALDEF1,"[M:PTH1]RCPDAT")
      WVALDEF1="[M:PTH0]RCPDAT"
    Elsif instr(1,WVALDEF1,"[M:PTH1]BPSNUM")
      WVALDEF1="[M:PTH0]BPSNUM"
    Elsif instr(1,WVALDEF1,"[M:PTH1]PTHNUM")
      WVALDEF1="[M:PTH0]PTHNUM"
    Elsif instr(1,WVALDEF1,"[M:PTH1]PRHFCY")
      WVALDEF1="[M:PTH0]PRHFCY"
    Endif
    #-----
    If instr(1,WVALDEF2,"[M:PTH1]RCPDAT")
      WVALDEF2="[M:PTH0]RCPDAT"
    Elsif instr(1,WVALDEF2,"[M:PTH1]BPSNUM")
      WVALDEF2="[M:PTH0]BPSNUM"
    Elsif instr(1,WVALDEF2,"[M:PTH1]PTHNUM")
      WVALDEF2="[M:PTH0]PTHNUM"
    Elsif instr(1,WVALDEF2,"[M:PTH1]PRHFCY")
      WVALDEF2="[M:PTH0]PRHFCY"
    Endif
    #-----
    If [F:ARV]VALDEF1<>WVALDEF1
      WFLAG=1
      If WTRACE=2
        WMSG ="Record"-[F:ARV]FONCTION-num$([F:ARV]TYPCOD)-[F:ARV]ETAT-[F:ARV]PARAM
        WMSG-="VALDEF1 :"-[F:ARV]VALDEF1-"-->"-WVALDEF1
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
    Endif
    If [F:ARV]VALDEF2<>WVALDEF2
      WFLAG=1
      If WTRACE=2
        WMSG ="Record"-[F:ARV]FONCTION-num$([F:ARV]TYPCOD)-[F:ARV]ETAT-[F:ARV]PARAM
        WMSG-="VALDEF2 :"-[F:ARV]VALDEF2-"-->"-WVALDEF2
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
    Endif
    #-----
    If WFLAG
      Update [ARV] Where FONCTION=WFONCTION
&                      & TYPCOD  =WTYPCOD
&                      & ETAT    =WETAT
&                      & PARAM   =WPARAM
&                  With VALDEF1=WVALDEF1, VALDEF2=WVALDEF2
      If fstat
        WMSG=mess(13,100,1)-"AREPORTV"-WFONCTION-num$(WTYPCOD)-WETAT-WPARAM
        Call ECR_TRACE(WMSG-"Error="+num$(fstat),1) From GESECRAN
        Break
      Endif
      NBCOR+=1
    Endif
    #-----
  Next
Commit
#-----
Return


###################################################
# Pour exécution automatique  en gestion de patch #
###################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=DOSSIER : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(DOSSIER)=0 : End : Endif
#---
If [F:ADS]MODULE(5)=2
  #--- Issue 108760 by TS
  If filinfo(filpath("FIL","AREPORTV","fde",DOSSIER),0)<=0 : End : Endif   : # XXXXXX= name of table
  If func DOSVUE.ISVIEW(DOSSIER,"AREPORTV") : End : Endif                  : # For Archive folder
  #---
  Call ECR_TRACE("UTIACH21 : Default values adjustment utility for report BONRCP",0) From GESECRAN
  Call EXE_UTIACH21(DOSSIER)
Endif
#-----
End


#########################################################
# Pour exécution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If [F:ADS]MODULE(5)=2
  #--- Issue 108760 by TS
  If filinfo(filpath("FIL","AREPORTV","fde",DOSSIER),0)<=0 : End : Endif   : # XXXXXX= name of table
  If func DOSVUE.ISVIEW(DOSSIER,"AREPORTV") : End : Endif                  : # For Archive folder
  #---
  Call ECR_TRACE("UTIACH21 : Default values adjustment utility for report BONRCP",0) From GESECRAN
  Call EXE_UTIACH21(DOSSIER)
Endif
#-----
End

