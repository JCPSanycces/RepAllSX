#<AdxTL>@(#)0.0.0.0 $Revision$
End

########################################################################################
# UTICPT72   UTI process                                                  Module CPT   #
#            Migration From UP8/UP9 to UP10
#
#  - Step 0 : Update abbreviation (add U9)
#  - Step 1 : Copy of data : DCLVATBEL  => DCLVATBOXH
#  - Step 2 : Copy of data : DCLVATBELD => DCLVATBOXDBD
#  - Step 3 : Initialization DCLVATTYP by 1         (new field of table DCLVATBOXH)
#  - Step 4 : Initialization VATFNC    by DCLVATBEL (new field of table DCLVATBOXH)
#  - Step 5 : Update APE VATFNC (old DCLVATFRA => new DCLVATOTH)
########################################################################################


Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT72(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT72(DOSSIER)
Value Char DOSSIER

Local Integer ERR
Local Char REQSQL(250)

Call ECR_TRACE("UTICPT72 : Start of process on : "+DOSSIER,0) From GESECRAN


# Step 0 : Update abbreviation (add U9)
If filinfo(filpath("FIL","DCLVATBEL","fde",DOSSIER),0)>0 & func DOSVUE.ISVIEW(DOSSIER,"DCLVATBEL")=0
 If clalev([F:ZZZ])<>0  : Close Local File [ZZZ] : Endif
 Local File =DOSSIER+".ATABLE" [ZZZ]
 GOK = 1
 Trbegin [ZZZ]
 Update [ZZZ] Where CODFIC="DCLVATBEL" With ABRFIC="DLVBU9"
 If !fstat
  Call ECR_TRACE("UTICPT72 : File ATABLE,  Code DCLVATBEL, update abbreviation",0) From GESECRAN
 Else
  Call ECR_TRACE("UTICPT72 : File ATABLE, ERROR while update ="-num$(fstat),1) From GESECRAN : GOK=0
 Endif
 If GOK<1
  Rollback
 Else
  Commit
 Endif
 Close Local File [ZZZ]
Endif
If filinfo(filpath("FIL","DCLVATBELD","fde",DOSSIER),0)>0 & func DOSVUE.ISVIEW(DOSSIER,"DCLVATBELD")=0
 If clalev([F:ZZZ])<>0  : Close Local File [ZZZ] : Endif
 Local File =DOSSIER+".ATABLE" [ZZZ]
 GOK = 1
 Trbegin [ZZZ]
 Update [ZZZ] Where CODFIC="DCLVATBELD" With ABRFIC="DLVBDU9"
 If !fstat
  Call ECR_TRACE("UTICPT72 : File ATABLE,  Code DCLVATBELD, update abbreviation",0) From GESECRAN
 Else
  Call ECR_TRACE("UTICPT72 : File ATABLE, ERROR while update ="-num$(fstat),1) From GESECRAN : GOK=0
 Endif
 If GOK<1
  Rollback
 Else
  Commit
 Endif
 Close Local File [ZZZ]
Endif

# Step 1 : Copy of data : DCLVATBEL  => DCLVATBOXH
If filinfo(filpath("FIL","DCLVATBEL","fde",DOSSIER),0)>0 & func DOSVUE.ISVIEW(DOSSIER,"DCLVATBEL")=0
 Raz ERR : Call MIGTABDUP(DOSSIER,"DCLVATBOXH","DCLVATBEL",ERR) From TRTMIG
 If !ERR : Call ECR_TIME("UTICPT72 : The DCLVATBOXH table is updated.") From DOSSUB : Endif
Endif

# Step 2 : Copy of data : DCLVATBELD => DCLVATBOXDBD
If filinfo(filpath("FIL","DCLVATBELD","fde",DOSSIER),0)>0 & func DOSVUE.ISVIEW(DOSSIER,"DCLVATBELD")=0
 Raz ERR : Call MIGTABDUP(DOSSIER,"DCLVATBOXDBD","DCLVATBELD",ERR) From TRTMIG
 If !ERR : Call ECR_TIME("UTICPT72 : The DCLVATBOXDBD table is updated.") From DOSSUB : Endif
Endif

# Steps 3 & 4 : Initialization DCLVATTYP & VATFNC  (new fields of table DCLVATBOXH)
If filinfo(filpath("FIL","DCLVATBOXH","fde",DOSSIER),0)>0 & func DOSVUE.ISVIEW(DOSSIER,"DCLVATBOXH")=0

 Call DEBTRANS From GLOCK
 Gosub SET_FIRST From TRTFIRST

 If clalev([F:DLVB])  =0  Local File =DOSSIER+".DCLVATBOXH"   [DLVB] : Endif

 Trbegin [DLVB]
 GOK = 1
 Onerrgo ERR_SQL
 REQSQL = "UPDATE"-DOSSIER+".DCLVATBOXH SET DCLVATTYP_0=1"
 Execsql From num$(GTYPDBA*2+1) Sql REQSQL
 Onerrgo
 If GOK<1
  Call ECR_TRACE("UTICPT72 : The DCLVATTYP field is not updated.",0) From GESECRAN
  Rollback
 Else
  Call ECR_TRACE("UTICPT72 : The DCLVATTYP field is updated.",0) From GESECRAN
  Commit
 Endif

 Trbegin [DLVB]
 GOK = 1
 Onerrgo ERR_SQL
 REQSQL = "UPDATE"-DOSSIER+".DCLVATBOXH SET VATFNC_0='DCLVATBEL'"
 Execsql From num$(GTYPDBA*2+1) Sql REQSQL
 Onerrgo
  If GOK<1
  Call ECR_TRACE("UTICPT72 : The VATFNC field is not updated.",0) From GESECRAN
  Rollback
 Else
  Call ECR_TRACE("UTICPT72 : The VATFNC field is updated.",0) From GESECRAN
  Commit
 Endif

 Gosub UNSET_FIRST From TRTFIRST
Endif

#  - Step 5 : Update APE VATFNC (old DCLVATFRA => new DCLVATOTH)
If filinfo(filpath("FIL","AENTREE","fde",DOSSIER),0)>0 & func DOSVUE.ISVIEW(DOSSIER,"AENTREE")=0

 If clalev([F:APE])  =0  Local File =DOSSIER+".AENTREE"   [APE] : Endif
 GOK = 1
 Trbegin [APE]
 Update [APE] Where TRTSTD="DCLVATFRA" With TRTSTD="DCLVATOTH"
 If !fstat
  Call ECR_TRACE("UTICPT72 : File AENTREE, Field TRTSTD : "+num$(adxuprec)+" records processed",0) From GESECRAN
 Else
  Call ECR_TRACE("UTICPT72 : File AENTREE, ERROR while update ="-num$(fstat),1) From GESECRAN : GOK=0
 Endif
 If GOK<1
  Rollback
 Else
  Commit
 Endif

 Close Local File [APE]
Endif


Call ECR_TRACE("UTICPT72 : End of process on : "+DOSSIER,0) From GESECRAN
End

###################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK=0
Resume


########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT72 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

If [F:ADS]MODULE(1)<>2 : End : Endif
Call MAJ_UTICPT72(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(1)<>2 : End : Endif
Call MAJ_UTICPT72(APPLI)
End

