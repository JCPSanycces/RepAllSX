#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTACT0A 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone WSTTYP
mkstat = 0
zoncou = "WSTTYP"
indice = 0
IMPENT = [M]WSTTYP
If varinit([M]WSTTYP,indice)=0
 IMPENT = 0
Endif
[M]WSTTYP = IMPENT

## Zone EXTWST
mkstat = 0
zoncou = "EXTWST"
indice = 0
WCHAR = [M]EXTWST
If varmode([M]EXTWST,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXTWST" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]EXTWST,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "EXTWST" : GZNUM = 42413 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]EXTWST or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_EXTWST([M]EXTWST) From SUBPJTAC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "EXTWST" : GZNUM = 42413 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone LABWSTTYP
mkstat = 0
zoncou = "LABWSTTYP"
indice = 0
IMPENT = [M]LABWSTTYP
If varinit([M]LABWSTTYP,indice)=0
 IMPENT = 0
Endif
[M]LABWSTTYP = IMPENT

## Zone EXTLAB
mkstat = 0
zoncou = "EXTLAB"
indice = 0
WCHAR = [M]EXTLAB
If varmode([M]EXTLAB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXTLAB" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]EXTLAB or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_EXTLAB([M]EXTLAB) From SUBPJTAC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "EXTLAB" : GZNUM = 42414 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMTACT0A"
Return

