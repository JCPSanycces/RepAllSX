#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Gestion du masque OFI1 (Organisme financeur)
# Gestion de fiche ORGANISME (table ORGANISME)
## On utilise le même traitement que les organismes de formation
#
#
# Creation :
#     SEGAY -  - 19/07/10 - EXI 66191 LOT 1
#                         - Rajout tableau spécificité, Siret, Site Internet
#                           Statut actif
#                         - Rajout pour les organismes financeurs (GESOFI)
#                         - Tableau des versements
# Modification :
#     SEGAY -  - 13/06/12 - EXI 81085 US 460
#     Remplacement fiche ORGANISME par ORGFINTRA (table ORGFINTRA)
#     MABOS -  - 30/05/13 - FQ81084 - US1612 -
#                         - field hidden / LEG in creation
#                         - value of GCURLEG
#                         - test dim([M:OFI0]LEG)
######################################################################################
Raz GPILOBJ
Call OBJET("OFI",GBIDC1,"") From GOBJET
End


$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "FILTRE"     : Gosub FILTRE
 When "LIENS"      : Gosub LIENS
 When "INIMOD"     : Gosub INIMOD
 When "INICRE"     : Gosub INICRE #--SEGAY filtre sur les organisme de formation
 When "RAZCRE"      : Gosub RAZCRE #SEGAY -  - 19/07/10 - EXI 66191 LOT 1
 When "RAZDUP"      : Gosub RAZDUP #SEGAY -  - 19/07/10 - EXI 66191 LOT 1
 When "FERME"       : Gosub FERME #--SEGAY 81085 LEG
 When "ABANDON"     : Gosub ABANDON #--SEGAY 81085 LEG

Endcase
Return

$OUVRE
If clalev([F:OFT])=0 : Local File ORGFINTRA  [OFT] : Endif
#--STA_EXI 66191 LOT 1
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
#--SEGAY 81085 LEG
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Return

$FERME
#--SEGAY 81085 LEG
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$ABANDON
#--SEGAY 81085 LEG
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
  Call DISPLAY_HIDE() From SUBOFILEG   :#MABOS-FQ81084-US1612
Return

#**#####################################################################################
#* SEGAY - 30/12/10 - En création, on initialise l'icone web
#*!
$RAZCRE
Call ACTIV_ICOORFWEB([M:OFI1]ORFWEB)
Affzo [M:OFI1]ICOORFWEB
#SEGAY - 13/06/12 - EXI 81085 US 460
Raz GCURLEG
GCURLEG = GLEGFIL :#MABOS-FQ81084-US1612
If dim([M:OFI0]LEG)>0 Then
  [M:OFI0]LEG=GLEGFIL
  Affzo [M:OFI0]LEG
  Call DISPLAY_HIDE() From SUBOFILEG :#MABOS-FQ81084-US1612
Endif

Return
#**#####################################################################################
#* SEGAY - 30/12/10 - En création, on initialise l'icone web
#*!
$RAZDUP
Call ACTIV_ICOORFWEB([M:OFI1]ORFWEB)
Affzo [M:OFI1]ICOORFWEB
Return

$INICRE
#--STA_EXI 66191 LOT 1
#--SEGAY filtre sur les organisme de formation
[F:OFT]TYP=2 : #Organisme financeurs uniquement ("GESOFI")
Gosub SAUVE_ECRAN
#--STA_EXI 66191 LOT 1
#-- Segay 05/11/10 On ne saisi plus de versement
#Gosub SAUVE_VERS
Return

$INIMOD
#--STA_EXI 66191 LOT 1
#--SEGAY filtre sur les organisme de formation
[F:OFT]TYP=2 : #Organisme financeurs uniquement ("GESOFI")
Gosub SAUVE_ECRAN
#--STA_EXI 66191 LOT 1
#-- Segay 05/11/10 On ne saisi plus de versement
#Gosub SAUVE_VERS
Return

$FILTRE
#--STA_EXI 66191 LOT 1
#--SEGAY filtre sur les organisme de formation
#--SEGAY 81085 add LEG to filter as well as type
If FILTSUP<>"" : FILTSUP += " & " : Endif
#Not OK error Oracle
#FILTSUP += "(TYP=6)" :#Organisme de formation uniquement
#FILTSUP += "((find([F:OFT]LEG,'"+GLEGFIL+"','')>0) | [F:OFT]LEG='' | GLEGFIL='') "
#FILTSUP += "((find([F:OFT]LEG,'"+GLEGFIL+"','')>0) & (TYP=6)) | ([F:OFT]LEG='' & (TYP=6)) | (GLEGFIL='' & (TYP=6))"
FILTSUP += "(TYP=2)" :#Organisme de formation uniquement


Return

$LIENS
#--SEGAY 81085 LEG
GCURLEG = [F:OFT]LEG :#MABOS-FQ81084-US1612- come from below
If GNBLEG=1 : GCURLEG = GDOSLEG : Endif

[M:OFI1]ADD1=[F:OFT]ADD(0)
[M:OFI1]ADD2=[F:OFT]ADD(1)
[M:OFI1]ADD3=[F:OFT]ADD(2)
#--STA_EXI 66191 LOT 1
# Segay FORMATION V6.1
# Pas de Taleau de 10 Spécialités dans organisme financeur
Call ACTIV_ICOORFWEB([M:OFI1]ORFWEB)
#--STA_EXI 66191 LOT 1
#-- Segay 05/11/10 On ne saisi plus de versement
#Gosub CHARGE_VERS
#--END_EXI 66191 LOT 1
# SEGAY 81085 LEG - Show\hide fields based on legislation
#GCURLEG = [F:OFT]LEG :#MABOS-FQ81084-US1612- move above
If dim([M:OFI0]LEG)>0 :[M:OFI0]LEG=GCURLEG :Endif :#MABOS-FQ81084-US1612
Call DISPLAY_HIDE() From SUBOFILEG

Return

$SAUVE_ECRAN
[F:OFT]ADD(0)=[M:OFI1]ADD1
[F:OFT]ADD(1)=[M:OFI1]ADD2
[F:OFT]ADD(2)=[M:OFI1]ADD3
Return

#--STA_EXI 66191 LOT 1
#**#####################################################################################
#* Clique sur l'icône du site web
#* SEGAY
#* @since 19/07/10
#* @param VALEUR :
#*!
Subprog CL_ICOORFWEB(VALEUR)
Variable Char    VALEUR()
If  [M]ORFWEB <> "" Then
 Callui RETOUR="" With "UIAction="+chr$(1)+"OpenFile",
& "UILocalDir="+ chr$(1) +"HTTP",
& "UILocalFile="+ chr$(1) + [M:OFI1]ORFWEB
Endif

End

#**#####################################################################################
#* Activation/Déactivation de l'icône site web
#* SEGAY
#* @since 19/07/10
#* @param VALEUR : Valeur du site web
#*!
Subprog ACTIV_ICOORFWEB(VALEUR)
Variable Char    VALEUR()
If  VALEUR <> "" Then
    Actzo [M:OFI1]ICOORFWEB
  Else
    Grizo [M:OFI1]ICOORFWEB
Endif
End

#**#####################################################################################
#* Aprés modification du site web
#* SEGAY
#* @since 19/07/10
#* @param VALEUR : Valeur du site web
#*!
Subprog AM_ORFWEB(VALEUR)
Variable Char    VALEUR()
Call ACTIV_ICOORFWEB(VALEUR)
End

#LIPET - 20-03-2017 - X3-29534 - START
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End
#LIPET - 20-03-2017 - X3-29534 - END

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran OFI2) 29/03/2011 13:00:01 (DBA)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
End

Subprog C_DATV(VALEUR)
Variable Date    VALEUR
End


######################################################################################

######################################################################################
## Section automatically added (screen OFI1) 05/25/2017 10:17:14 (TIVAN)
######################################################################################
Subprog AM_CRY(VALEUR)
Variable Char    VALEUR()
# TIVAN 25/05/2017 - Start
  If VALEUR <> [M:OFI1]CRY
    Raz [M:OFI1]POS, CTY
    Affzo [M:OFI1]POS, CTY
    If VALEUR = ""
      Raz [M:OFI1]CRYNAM
      Affzo [M:OFI1]CRYNAM
    Endif
  Endif
# TIVAN 25/05/2017 - End
End


