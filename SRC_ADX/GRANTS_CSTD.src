#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe GRANTS


###################
# CLASS GRANTS
###################
$ACTION
  Case CURPRO
    When ""         : Gosub METHODS    : # If CURPRO is empty, we are on class methods
    When Default    : Gosub PROPERTIES : # Otherwise it is a hook called on properties
  Endcase
Return

###############
###############
# METHOD
###############
###############
$EVENTS
  Case CURPTH
    When ""
      Case AEVENT
        When "AREAD_AFTER"       : Gosub AREAD_AFTER       : # Get method attached to NBMVT
        When Default
      Endcase
    When "LINE"
    When Default
  Endcase
Return

$METHODS
Return

###################################################################
#            METHODES DE LA CLASSE  -  LAYOUTFAS
###################################################################
$AREAD_AFTER

Return


###############
###############
# PROPERTY
###############
###############
$PROPERTIES
  Case CURPRO
    When "CASHTOT"    : Gosub CASHTOT
    When Default
    Endcase
  Return


###################################################################
#            METHODES SUR LA PROPRIETE  -  CUR
###################################################################
$CASHTOT
  Case ACTION
    When "INIT"       : Gosub INIT_CASHTOT      : # Init method attached to CASHTOT
    When "CONTROL"    : Gosub CONTROL_CASHTOT   : # Control method attached to CASHTOT
    When "PROPAGATE"  : Gosub PROPAGATE_CASHTOT : # Propagate method attached to CASHTOT
    When "GET"        : Gosub GET_CASHTOT       : # Get method attached to CASHTOT
    When Default
  Endcase
Return
#------------
$INIT_CASHTOT
Return
#------------
$CONTROL_CASHTOT
Return
#------------
$PROPAGATE_CASHTOT
Return
#------------
GET_CASHTOT
    this.CASHTOT = 0
    Local Integer I_ENC : I_ENC = 1
    While this.CASHING(I_ENC) <> null
     this.CASHTOT += this.CASHING(I_ENC).CASHAMT
     I_ENC += 1
    Wend
Return

$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

