######################################################################################
Subprog AM_RCSDAT(VALEUR)
Variable Date    VALEUR
#Check if appeal date is smaller or equal to the sanction date
If VALEUR <= [M:HRDS0]SANDAT  Then
    mkstat=2 : GERR=1 : GMESSAGE=mess(4,10684,1)
  Endif
End


