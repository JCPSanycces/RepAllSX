#<AdxTL>@(#)0.0.0.0 $Revision$
#FRLAA - 2015-02-05 - Requirement 104591 US 3340 - START
$ACTION
Case ACTION
  When "OUVRE"     : Gosub OUVRE
  When "RAZCRE"    : Gosub RAZCRE
  When "LIENS"     : Gosub LIENS
  #When "STYLE"     : Gosub STYLE
  When "MODIF"     : Gosub MODIF
  When "CREATION"  : Gosub CREATION
  #When "FILTRE"    : Gosub FILTRE
  When Default
Endcase
Return

$OUVRE
If clalev([F:ID])     = 0 : Local File EMPLOID          [ID]            : Endif
If clalev([F:HRCTR])  = 0 : Local File EMPLOCTR         [HRCTR]         : Endif
If clalev([F:HRDCM])  = 0 : Local File HRDCOMMIT        [HRDCM]         : Endif
If clalev([F:HRDRR])  = 0 : Local File HRDRECOUR        [HRDRR]         : Endif
If clalev([F:HRDST])  = 0 : Local File HRDSANCTRANS     [HRDST]         : Endif
If clalev([F:HRDSW])  = 0 : Local File HRDSANCWITN      [HRDSW]         : Endif
Return

$RAZCRE
[M:HRDS0]STRDAT = date$
[M:HRDS0]ENDDAT = date$
[M:HRDS0]SANDAT = date$
#ADNGO - 2017-07-21 - X3-12018 - START
Raz GCURLEG
#ADNGO - 2017-07-21 - X3-12018 - END
Affzo [M:HRDS0]
Return


$LIENS
#ADNGO - 2017-07-21 - X3-12018 - START
  If !clalev([F:HRCTR3]) : Local File EMPLOCTR [HRCTR3] : Endif
  If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
  Filter  [HRCTR3] Where CTRNUM=[M:HRDS0]CTRNUM
  Read [HRCTR3] First
  Filter [HRCTR3]
  Read [FCY2]FCY0 = [F:HRCTR3]ETRFCY
  If !fstat
   GCURLEG = [F:FCY2]LEG
   [M:HRDS0]LEG = GCURLEG
   Affzo [M:HRDS0]LEG
  Endif
#ADNGO - 2017-07-21 - X3-12018 - END
#FRLAA - 2015-07-10 - Requirement 104591 US 3740 - START
#Action taken by employee - Name & Surname
If clalev([F:ID]) = 0 : Local File EMPLOID    [ID]         : Endif
If [F:HRDSNH]ACNEMP <> ""
  Read [ID]ID0 = [F:HRDSNH]ACNEMP
  If !fstat
    [M:HRDS0]ACNSRN = [F:ID]NAM-[F:ID]SRN
  Endif
Endif

#FRLAA - 2015-02-05 - Requirement 104591 US 3740 - END


#Committee members
  nolign = 0
  For [F:HRDCM]HRDCM0 Where [F:HRDCM]SANNBR=[M:HRDS0]SANNBR
    nolign += 1
    [M:HRDS2] = [F:HRDCM]
  Next

#Recourse
  nolign = 0
  For [F:HRDRR]HRDRR0 Where [F:HRDRR]SANNBR=[M:HRDS0]SANNBR
    nolign += 1
    [M:HRDS3] = [F:HRDRR]
  Next

#Transgression
  nolign = 0
  For [F:HRDST]HRDST0 Where [F:HRDST]SANNBR=[M:HRDS0]SANNBR
    nolign += 1
    [M:HRDS1] = [F:HRDST]
  Next

#Witnesses
  nolign = 0
  For [F:HRDSW]HRDSW0 Where [F:HRDSW]SANNBR=[M:HRDS0]SANNBR
    nolign += 1
    [M:HRDS1] = [F:HRDSW]
  Next
Return


$CREATION
$MODIF
#Committee members
Delete [F:HRDCM] Where [F:HRDCM]SANNBR=[M:HRDS0]SANNBR
If fstat=1 | fstat>5
  GOK=0 : Call RSTA("HRDCM",[M:HRDS0]SANNBR) From GLOCK : Return
Endif

 #Recourse
 Delete [F:HRDRR] Where [F:HRDRR]SANNBR=[M:HRDS0]SANNBR
 If fstat=1 | fstat>5
    GOK=0 : Call RSTA("HRDRR",[M:HRDS0]SANNBR) From GLOCK : Return
 Endif

#Transgression
 Delete [F:HRDST] Where [F:HRDST]SANNBR=[M:HRDS0]SANNBR
 If fstat=1 | fstat>5
    GOK=0 : Call RSTA("HRDST",[M:HRDS0]SANNBR) From GLOCK : Return
 Endif

#Witnesses
 Delete [F:HRDSW] Where [F:HRDSW]SANNBR=[M:HRDS0]SANNBR
 If fstat=1 | fstat>5
    GOK=0 : Call RSTA("HRDSW",[M:HRDS0]SANNBR) From GLOCK : Return
 Endif


#Committee members
For nolign=1 To [M:HRDS2]LIGNBR
    Raz [F:HRDCM]
    [F:HRDCM] = [M:HRDS0]
    [F:HRDCM] = [M:HRDS2]
    [F:HRDCM]LIGNBR = nolign
    Write [F:HRDCM]
    If fstat
      GOK=0 : Call FSTA("HRDCM") From GLOCK : Break
    Endif
  Next nolign

#Recourse
For nolign=1 To [M:HRDS3]RCSNBR
    Raz [F:HRDRR]
    [F:HRDRR] = [M:HRDS0]
    [F:HRDRR] = [M:HRDS3]
    [F:HRDRR]RCSNBR = nolign
    Write [F:HRDRR]
    If fstat
      GOK=0 : Call FSTA("HRDRR") From GLOCK : Break
    Endif
  Next nolign

#Transgression
For nolign=1 To [M:HRDS1]TGSNBR
    Raz [F:HRDST]
    [F:HRDST] = [M:HRDS0]
    [F:HRDST] = [M:HRDS1]
    [F:HRDST]TGSNBR = nolign
    Write [F:HRDST]
    If fstat
      GOK=0 : Call FSTA("HRDST") From GLOCK : Break
    Endif
  Next nolign

#Witnesses
For nolign=1 To [M:HRDS1]WTSNBR
    Raz [F:HRDSW]
    [F:HRDSW] = [M:HRDS0]
    [F:HRDSW] = [M:HRDS1]
    [F:HRDSW]WTSNBR = nolign
    Write [F:HRDSW]
    If fstat
      GOK=0 : Call FSTA("HRDSW") From GLOCK : Break
    Endif
  Next nolign

Return

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Read[F:ID]ID0=VALEUR
  If !fstat Then
    [M:HRDS0]NAM = [F:ID]NAM
    [M:HRDS0]SRN = [F:ID]SRN
Endif
End

Subprog C_CTRNUM(VALEUR)
Variable Char     VALEUR
Local Char COUNTER(20)
Local Char COMPTEUR(5)
Local Integer  STAT
Local Integer OK
[M]CTRDAT = [F:HRCTR]CTRDAT
[M]FCY = [F:HRCTR]ETRFCY

If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif
Filter [HRCTR2] Where CTRNUM = VALEUR and CTRDAT = [F:HRCTR]CTRDAT
Read [HRCTR2] First
If !fstat
  If clalev([F:TCA])=0    : Local File TABCOUAFF    [TCA]   : Endif

  Call LECTCA(9, STAT) From SUBTCA
  If !STAT

    GMESSAGE = mess(104,117,1)
    GOK = 0 : End
  Else
    COMPTEUR= [F:TCA]CODNUM(4)
  Endif
  Call NUMERO(COMPTEUR, [F:HRCTR]ETRFCY, date$, "", COUNTER, STAT) From SUBANM
   If STAT
    GMESSAGE = mess(104,117,1)-COMPTEUR
    GOK = 0 : End
  Endif
 [M:HRDS0]SANNBR = COUNTER
 Affzo [M:HRDS0]SANNBR
Endif
#ADNGO - 2017-07-21 - X3-12018 - START
  If !clalev([F:HRCTR3]) : Local File EMPLOCTR [HRCTR3] : Endif
  If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
  Filter  [HRCTR3] Where CTRNUM=VALEUR
  Read [HRCTR3] First
  Filter [HRCTR3]
  Read [FCY2]FCY0 = [F:HRCTR3]ETRFCY
  If !fstat
   GCURLEG = [F:FCY2]LEG
   [M:HRDS0]LEG = GCURLEG
   Affzo [M:HRDS0]LEG
  Endif
#ADNGO - 2017-07-21 - X3-12018 - END

End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()

End


Subprog IB_DATCTR
End

Subprog AM_SANTYP(VALEUR)
Variable Char    VALEUR()
End

Subprog IB_STRDAT
End

Subprog C_STRDAT(VALEUR)
  Variable Date    VALEUR

  #Check if start date is not greater than end date
   If VALEUR > [M:HRDS0]ENDDAT and [M:HRDS0]ENDDAT <>[0/0/0]  Then
     mkstat=2 : GERR=1 : GMESSAGE=mess(1,10684,1)
   Endif
 End

Subprog C_ENDDAT(VALEUR)
  Variable Date    VALEUR
  #Check if end date is not less than end 10684 date
  If VALEUR < [M:HRDS0]STRDAT and [M:HRDS0]STRDAT <>[0/0/0] Then
    mkstat=2 : GERR=1 : GMESSAGE=mess(2,10684,1)
  Endif
End

Subprog AM_REFNUMWTS(VALEUR)
Variable Char    VALEUR()
Read[F:ID]ID0=VALEUR
 If !fstat Then
  [M:HRDS1]NAMSRN(nolign-1) = [F:ID]NAM+" "+[F:ID]SRN
Endif
End


Subprog AM_REFNUMCOM(VALEUR)
  Variable Char    VALEUR()
  Read[F:ID]ID0=VALEUR
    If !fstat Then
      [M:HRDS2]NAMSRN(nolign-1) = [F:ID]NAM+" "+[F:ID]SRN
    Endif
End

#FRLAA - 2015-02-05 - Requirement 104591 US 3340 - END

#FRLAA - 2015-07-10 - Requirement 104591 US 3740 - START
Subprog AM_ACNEMP(VALEUR)
Variable Char    VALEUR()
If clalev([F:ID]) = 0 : Local File EMPLOID    [ID]         : Endif
Read [ID]ID0 = VALEUR
If !fstat
  [M:HRDS0]ACNSRN = [F:ID]NAM-[F:ID]SRN
Endif
End
#FRLAA - 2015-07-10 - Requirement 104591 US 3740 - END

