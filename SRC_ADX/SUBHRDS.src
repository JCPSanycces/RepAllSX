Subprog AM_TGSDAT(VALEUR)
Variable Date    VALEUR
#Check if transgression date is greater or equal to the sanction date
#DEHEN - JIRRA : X3PEOP-2256 - 2016-09-27 - START
  #If VALEUR < [M:HRDS0]SANDAT  Then #Old Code Source
  If VALEUR > [M:HRDS0]SANDAT  Then
    mkstat=2 : GERR=1 : GMESSAGE=mess(3,10684,1)
    End
  Endif
#DEHEN - JIRRA : X3PEOP-2256 - 2016-09-27 - END
  #DEHEN - Requriement 114362 - 2016-05-30 - START
  #ADNGO - 2017-07-21 - X3-12018 - START
  #If !func AFNC.ACTIV("KFR")  & !func AFNC.ACTIV("KPO") Then
  If !func DIVPAYE.IS_KFR_LEG(GCURLEG)  & !func DIVPAYE.IS_KPO_LEG(GCURLEG) Then
  #ADNGO - 2017-07-21 - X3-12018 - END
    #ADNGO - 2017-07-21 - X3-12018 - START
    #If func AFNC.ACTIV("KMIEA") Then
    If func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG) Then
    #ADNGO - 2017-07-21 - X3-12018 - END
      Infbox mess(30,11738,1)
    Endif
  Endif
  #DEHEN - Requriement 114362 - 2016-05-30 - END
End


