#DEHEN - JIRRA : X3PEOP-2256 - 2016-09-27 - START
Subprog AM_SANDAT(VALEUR)
Variable Date    VALEUR
  If [M:HRDS1]TGSDAT > VALEUR  Then
    mkstat=2 : GERR=1 : GMESSAGE=mess(3,10684,1)
    End
  Endif
End
#DEHEN - JIRRA : X3PEOP-2256 - 2016-09-27 - END

