End



#** ##############################################################################################
#*
#* Procedure:  DISCOUNT_MANAGEMENT
#*
#* Purpose:    Starts discount management dialog (if not suppressed by entry point)
#*
#* @param AMOUNT        Variable Decimal      | Return value: Amount
#* @param RAT_DISCOUNT  Variable Decimal      | Return value: Discount/Charge rate (signed)
#* @param AMT_DISCOUNT  Variable Decimal      | Return value: Discount/Charge amount (signed)
#* @param DENCOD        Variable Char         | Return value: Payment attribute
#* @param CUR           Value    Char         | Value parameter: Currency
#* @param ROUNDING      Value    Char         | Value parameter: Currency rounding value
#* @param DENCODDIS     Value    Char         | Value parameter: Payment attribute for early discount
#* @param DENCODAGIO    Value    Decimal      | Value parameter: Payment attribute for late charge
#* @param CURRENTDATE   Value    Date         | Value parameter: Reference date for [M:PAYDIS]DISOVR(I)
#*
#*! ###############################################################################################

Subprog DISCOUNT_MANAGEMENT(AMOUNT, RAT_DISCOUNT, AMT_DISCOUNT, DENCOD, CUR, RSTINPAMT, RSTINPCUR, ROUNDING, DENCODDIS, DENCODAGIO, CURRENTDATE)
    Variable Decimal AMOUNT                # Return value: Amount
    Variable Decimal RAT_DISCOUNT          # Return value: Discount/Charge rate (signed)
    Variable Decimal AMT_DISCOUNT          # Return value: Discount/Charge amount (signed)
    Variable Char    DENCOD                # Return value: Payment attribute
    Value    Char    CUR                   # Value parameter: Currency
    Value    Decimal RSTINPAMT             # Value parameter: Rest input amount
    Value    Char    RSTINPCUR             # Value parameter: Currency of the rest input amount
    Value    Decimal ROUNDING              # Value parameter: Currency rounding value
    Value    Char    DENCODDIS             # Value parameter: Payment attribute for early discount
    Value    Char    DENCODAGIO            # Value parameter: Payment attribute for late charge
    Value    Date    CURRENTDATE           # Value parameter: Reference date for [M:PAYDIS]DISOVR(I)
    Local Char PARAM (250)(1..10)
    Local Char RESULT(255)
    Local Integer OK
    Local Char WINDOW(GLONFEN)           # Window (AWI) name to be opened
    Local Char SCREEN(GLONAMK)           # Screen (AMK) name to be opened
    Local Char PROG(GLONADC)             # Standard processing for the discount dialog
    Local Char PROGSPE(GLONADC)          # SPEcific processing for the discount dialog
    Local Integer EXTERNAL               # If set to !0 in entry point the whole window opening etc. must
                                         #    be done in the entry point's code!
    [L]PARAM(1) = DENCODDIS
    [L]PARAM(2) = DENCODAGIO
    [L]PARAM(3) = num$(AMOUNT + AMT_DISCOUNT)
    [L]PARAM(4) = num$(RAT_DISCOUNT)
    [L]PARAM(5) = num$(AMT_DISCOUNT)
    [L]PARAM(6) = format$("D:YYYYMMDD", CURRENTDATE) # CURRENTDATE
    [L]PARAM(7) = CUR
    [L]PARAM(8) = num$(ROUNDING)
    [L]PARAM(9) = num$(RSTINPAMT)
    [L]PARAM(10) = RSTINPCUR

    WINDOW = "PAYDISMSK"                    # Standard window is PAYSKO. Can be overwritten in entry point.

    # Provide an entry point (WINDOW) for additional export templates.
    #
    # Note: If you want to use a totally different treatment set EXTERNAL to 1. Do anything you want.
    #       Set OK to 1 on exit if you want to return values using PARAM array:
    #         - [L]PARAM(3)   Payment amount
    #         - [L]PARAM(4)   Discount/Charge rate
    #         - [L]PARAM(5)   Discount/Charge amount
    #       Paramters do display or for usage:
    #         - [L]PARAM(1)   Payment attribute for early discount
    #         - [L]PARAM(2)   Payment attribute for late charge
    #         - [L]PARAM(6)   Reference date for "days over ..."
    #         - [L]PARAM(7)   Currency
    #         - [L]PARAM(8)   Currency rounding
    #         - [L]PARAM(9)   Remaining for allocation amount
    #         - [L]PARAM(10)  Remaining for allocation currency
    #       Otherwise change the window name in WINDOW variable and let the standard code do the rest.
    #
    GPOINT = "WINDOW" : Gosub ENTREE From EXEFNC

    If not EXTERNAL
        # Read the (1st) screen that belongs to the window.
        SCREEN = func BIDLOC.GETWINDOWSCREEN( WINDOW, 0 )

        # Get the standard and specific processing names for the discount dialog
        Call GETSCREENTRT( SCREEN, PROG, PROGSPE ) From BIDLOC

        Call TRAITE_CHAR( RESULT, [L]PARAM, "", PROG, WINDOW, 3, PROGSPE ) From GTRAITE
        OK = ( RESULT = "OK" )
    Endif

    If OK
        AMT_DISCOUNT = val( PARAM(5) )
        AMOUNT       = val( PARAM(3) ) - AMT_DISCOUNT
        RAT_DISCOUNT = AMT_DISCOUNT / AMOUNT * 100                          # Rate is in % so we multiply by 100.
        If    RAT_DISCOUNT < 0 or ( RAT_DISCOUNT = 0 and AMT_DISCOUNT < 0 ) # Early Discount
            DENCOD = DENCODDIS
        Elsif RAT_DISCOUNT > 0 or ( RAT_DISCOUNT = 0 and AMT_DISCOUNT > 0 ) # Late Charge
            DENCOD = DENCODAGIO
        Else
            Raz DENCOD
        Endif
    Endif
End

########################################################################################################################



#**###############################################################################################
## Window/screen event handler.
#!###############################################################################################

$ACTION
    Case ACTION
        When "INIT_DIA" : Gosub INIT_DIA    # Initialize the dialog
        When "CONTROLE" : Gosub CONTROLE
        When "EXEC"     : Gosub EXEC        # EXEC event. Sets return values.
        When "TRT_DIV"  : Gosub TRT_DIV
    Endcase
Return

#**###############################################################################################
## Handler for INIT_DIA event.
#!###############################################################################################

$INIT_DIA
    #
    # The following tables are opened and positioned onto the correct records:
    #   - GACCDUDATE
    #   - TABDEPAGIO
    #

    Case [F:DUD]BPRTYP
        When 1: # Customer
            # Position SINVOICE correctly if not yet done
            If [F:SIH]NUM <> [F:DUD]NUM Then
                Read [F:SIH]SIH0 = [F:DUD]NUM
            Endif
        When 2: # Supplier
            # Position PINVOICE correctly if not yet done
            If [F:PIH]NUM <> [F:DUD]NUM Then
                Read [F:PIH]PIH0 = [F:DUD]NUM
            Endif
    Endcase

    Local Char LTMP(1)

    #
    # DATDEP -> 2620
    #   - Open item due date
    #   - Invoice date
    #
    Call PARAML([F:DUD]CPY, "DATDEP", [L]LTMP) From ADOVAL
    Local Integer LDATDEP
    [L]LDATDEP = val([L]LTMP)
    #
    # DEPMGTMOD -> 2279
    #   - Rebate on VAT
    #   - Breakdown by VAT (invoice level)
    #   - Global calculation
    #   - Breakdown by VAT (account level)
    #   - Discount on VAT (exempt) / Global
    #
    Call PARAML([F:DUD]CPY, "DEPMGTMOD", [L]LTMP) From ADOVAL
    Local Integer LDEPMGTMOD : [L]LDEPMGTMOD = val([L]LTMP)

    # Rounding digits for currency rounding
    [M:PAYDIS]CURRND = val(PARAM(8))

    # block 1; line 1
    Case [F:DUD]BPRTYP
        When 1: # Customer
            [M:PAYDIS]INVAMT = [F:SIH]AMTATI
            [M:PAYDIS]INVCUR = [F:SIH]CUR
            [M:PAYDIS]INVNUM = [F:SIH]NUM
        When 2: # Supplier
            [M:PAYDIS]INVAMT = [F:PIH]AMTATI
            [M:PAYDIS]INVCUR = [F:PIH]CUR
            [M:PAYDIS]INVNUM = [F:PIH]NUM
    Endcase

    # block 1; line 2
    # take split open items into account
    Local File GACCDUDATE [DUD_] Where [F:DUD_]TYP = [F:DUD]TYP and [F:DUD_]NUM = [F:DUD]NUM
    For [F:DUD_]
        [M:PAYDIS]PREPAYAMT += [F:DUD_]PAYCUR + [F:DUD_]TMPCUR
    Next
    Close Local File [DUD_]
    [M:PAYDIS]PRECUR    = [F:DUD]CUR
    Case [F:DUD]BPRTYP
        When 1: # Customer
            [M:PAYDIS]ACCDAT = [F:SIH]ACCDAT
        When 2: # Supplier
            [M:PAYDIS]ACCDAT = [F:PIH]ACCDAT
    Endcase

    # block 1; line 3
    Local Decimal RAT_CURRENCY, AMT_RESULT
    Local Integer STA

    Link [F:PYD] With [F:PYH]PYH0 ~= [F:PYD]NUM As [LNKPY]
&   Where [F:PYD]DUDNUM = [F:DUD]ACCNUM
&     and [F:PYD]DENCOD = [L]PARAM(1)
    Columns [LNKPY] ([F:PYD]CURLIN, [F:PYD]AMTLIN, [F:PYH]ACCDAT)

    For [LNKPY]
        If [F:PYD]CURLIN = [M:PAYDIS]INVCUR Then
            [M:PAYDIS]PREDISAMT += [F:PYD]AMTLIN
        Else
            # Discount amount is not in invoice currency. So calculate it in invoice currency.
            #
            # Note: This is a rough way but to show the user some information I (DNE) think this should
            #       be OK.
            #
            Case [F:DUD]BPRTYP
                When 1: # Customer
                    Call COURDEV([F:PYD]CURLIN, [M:PAYDIS]INVCUR, [F:SIH]CURTYP, [F:PYH]ACCDAT, [L]RAT_CURRENCY, [L]STA) From TRTDIV
                When 2: # Supplier
                    Call COURDEV([F:PYD]CURLIN, [M:PAYDIS]INVCUR, [F:PIH]CURTYP, [F:PYH]ACCDAT, [L]RAT_CURRENCY, [L]STA) From TRTDIV
            Endcase
            If ![L]STA
                Call CONVERT([F:PYD]AMTLIN, [F:PYD]CURLIN, [L]AMT_RESULT, [M:PAYDIS]INVCUR, [L]RAT_CURRENCY) From TRTDIV
                [M:PAYDIS]PREDISAMT += [L]AMT_RESULT
            Endif
        Endif
    Next
    # adjust 'Previous payment'
    [M:PAYDIS]PREPAYAMT -= [M:PAYDIS]PREDISAMT
    [M:PAYDIS]PREDISCUR  = [M:PAYDIS]INVCUR
    Case [F:DUD]BPRTYP
        When 1: # Customer
            [M:PAYDIS]INVTYP = [F:SIH]SIVTYP
        When 2: # Supplier
            [M:PAYDIS]INVTYP = [F:PIH]PIVTYP
    Endcase

    # block 1; line 4
    [M:PAYDIS]OSTAMT    = [F:DUD]AMTCUR - [F:DUD]TMPCUR - [F:DUD]PAYCUR
    [M:PAYDIS]OSTCUR    = [F:DUD]CUR

    # block 1; line 5
    [M:PAYDIS]DEP       = [F:DUD]DEP
    Case [F:DUD]BPRTYP
        When 1: # Customer
            [M:PAYDIS]BASDAT = [F:SIH]STRDUDDAT
        When 2: # Supplier
            [M:PAYDIS]BASDAT = [F:PIH]STRDUDDAT
    Endcase

    # block 1; line 6
    Case [F:DUD]BPRTYP
        When 1: # Customer
            [M:PAYDIS]PTE = [F:SIH]PTE
        When 2: # Supplier
            [M:PAYDIS]PTE = [F:PIH]PTE
    Endcase
    [M:PAYDIS]DUDDAT    = [F:DUD]DUDDAT

    # block 3
    Case [F:DUD]BPRTYP
        When 1: # Customer
            [M:PAYDIS]DISBAS = func GET_DISCOUNTABLE_AMOUNT([L]LDEPMGTMOD, [F:DUD]TYP, [F:DUD]NUM, [F:DUD]ACCNUM,
&               [F:DUD]CPY, [F:DUD]CUR, [F:DUD]BPRTYP, [F:DUD]DEP, [M:PAYDIS]INVAMT, [F:DUD]AMTCUR, [F:SIH]AMTATI)
        When 2: # Supplier
            [M:PAYDIS]DISBAS = func GET_DISCOUNTABLE_AMOUNT([L]LDEPMGTMOD, [F:DUD]TYP, [F:DUD]NUM, [F:DUD]ACCNUM,
&               [F:DUD]CPY, [F:DUD]CUR, [F:DUD]BPRTYP, [F:DUD]DEP, [M:PAYDIS]INVAMT, [F:DUD]AMTCUR, [F:PIH]AMTATI)
    Endcase

    # block 2
    Local Integer I, J, DELAI
    If !clalev( [F:TDA] ) : Local File TABDEPAGIO [TDA] : Endif

    Local Decimal DISBASOSTAMT
    [L]DISBASOSTAMT = [M:PAYDIS]DISBAS * [M:PAYDIS]OSTAMT / [M:PAYDIS]INVAMT
    [M:PAYDIS]PAYACCDAT = gdat$(val(right$([L]PARAM(6), 7)),
&                               val(mid$(  [L]PARAM(6), 5, 2)),
&                               val(left$( [L]PARAM(6), 4)))
    For [L]I = 0 To dim([F:TDA]DEPDAY) - 1
        Call LEC_TDA( GCURLEG, [F:DUD]DEP ) From CPTLEC
        If [F:TDA]DEPDAY([L]I) < 999 and [F:TDA]DEPRAT([L]I) <= 0 Then # Only discounts!
            Case [L]LDATDEP
                When 1 # Open item due date
                    [M:PAYDIS]DISDAT([L]J) = [M:PAYDIS]DUDDAT + [F:TDA]DEPDAY([L]I) - 1
                When 2 # Invoice date
                    If [L]I + 1 >= dim([F:TDA]DEPDAY) Then
                      [M:PAYDIS]DISDAT([L]J) = [M:PAYDIS]ACCDAT + 999
                    Else
                      [M:PAYDIS]DISDAT([L]J) = [M:PAYDIS]ACCDAT + [F:TDA]DEPDAY([L]I + 1) - 1
                    Endif
            Endcase
            [M:PAYDIS]DISRAT([L]J) = [F:TDA]DEPRAT([L]I)
            [M:PAYDIS]DISOVR([L]J) = [M:PAYDIS]PAYACCDAT - [M:PAYDIS]DISDAT([L]J)
            [M:PAYDIS]DISESTAMT([L]J) = abs(arr([M:PAYDIS]DISBAS * [M:PAYDIS]DISRAT([L]J) / 100, [M:PAYDIS]CURRND))
            [M:PAYDIS]DISOSTAMT([L]J) = abs(arr([L]DISBASOSTAMT * [M:PAYDIS]DISRAT([L]J) / 100, [M:PAYDIS]CURRND))
            [L]J += 1
            [M:PAYDIS]NBLIG += 1
            [S]nolign += 1
        Endif
    Next [L]I

    # block 3
    [M:PAYDIS]DISMGT    = [L]LDEPMGTMOD
    [M:PAYDIS]DISREF    = [L]LDATDEP

    # block 4; line 1
    [M:PAYDIS]RSTINPAMT = val([L]PARAM(9))
    [M:PAYDIS]RSTINPCUR = [M:PAYDIS]OSTCUR
    If [L]PARAM(10) = "" Then
        # use the currency of the open item
        [L]PARAM(10) = [M:PAYDIS]RSTINPCUR
    Endif
    If [M:PAYDIS]RSTINPCUR <> [L]PARAM(10) Then
        # Rest input amount currency differs from invoice currency. Recalculate the rest input amount.
        Case [F:DUD]BPRTYP
            When 1: # Customer
                Call COURDEV([L]PARAM(10), [M:PAYDIS]RSTINPCUR, [F:SIH]CURTYP, [F:PYH]ACCDAT, [L]RAT_CURRENCY, [L]STA) From TRTDIV
            When 2: # Supplier
                Call COURDEV([L]PARAM(10), [M:PAYDIS]RSTINPCUR, [F:PIH]CURTYP, [F:PYH]ACCDAT, [L]RAT_CURRENCY, [L]STA) From TRTDIV
        Endcase
        If ![L]STA
            Call CONVERT([M:PAYDIS]RSTINPAMT, [L]PARAM(10), [L]AMT_RESULT, [M:PAYDIS]RSTINPCUR, [L]RAT_CURRENCY) From TRTDIV
            [M:PAYDIS]RSTINPAMT = [L]AMT_RESULT
        Endif
    Endif
# X3-99653 Bader 2018-07-10 begin
#    If [M:PAYDIS]RSTINPAMT <> 0 Then
    If [M:PAYDIS]RSTINPAMT <> 0 and val([L]PARAM(3)) > val([L]PARAM(9)) Then
# X3-99653 Bader 2018-07-10 end
        [M:PAYDIS]PAYAMT = min([M:PAYDIS]OSTAMT, [M:PAYDIS]RSTINPAMT)
    Else
        [M:PAYDIS]PAYAMT = val(PARAM(3))
    Endif
    [M:PAYDIS]PAYCUR    = [M:PAYDIS]OSTCUR

    # block 4; line 2
# X3-99653 Bader 2018-07-10 begin
#    If [M:PAYDIS]RSTINPAMT <> 0 Then
#        Local Integer LDELAI
#        Local Decimal LTAUX_ESC, LMONT_ESC
#        Call ESC_AGIO([F:DUD]DEP, [M:PAYDIS]PAYAMT, [M:PAYDIS]ACCDAT, [M:PAYDIS]DUDDAT,
#&           [L]LDELAI, [L]LTAUX_ESC, [L]LMONT_ESC, [F:DUD]ACCNUM, [F:DUD]DUDLIG) From TRTDIV
#        [M:PAYDIS]DISAMT = abs(arr([L]LMONT_ESC, [M:PAYDIS]CURRND))
#        # adjust amount
#        [M:PAYDIS]PAYAMT -= [M:PAYDIS]DISAMT
#    Else
# X3-99653 Bader 2018-07-10 end
     [M:PAYDIS]DISAMT = abs(val(PARAM(5)))
# X3-99653 Bader 2018-07-10 begin
#    Endif
# X3-99653 Bader 2018-07-10 end
    [M:PAYDIS]DISCUR    = [M:PAYDIS]PAYCUR
#    [M:PAYDIS]RSTOSTAMT = [M:PAYDIS]OSTAMT - [M:PAYDIS]PAYAMT - [M:PAYDIS]DISAMT
    [M:PAYDIS]RSTOSTCUR = [M:PAYDIS]OSTCUR

    # Update percentage values of block 4.
    Gosub UPDATE_PERCENTAGE

    # Move cursor to PAYAMT edit control to prevent a pre-loading of values
    # based on grid in block 2.
#    zonsui = "PAYAMT"
Return

$UPDATE_PERCENTAGE
    If [M:PAYDIS]INVAMT <> 0 Then
        [M:PAYDIS]PAYSKO    = ar2([M:PAYDIS]PAYAMT * 100 / [M:PAYDIS]INVAMT)
        [M:PAYDIS]DISSKOINV = ar2([M:PAYDIS]DISAMT * 100 / [M:PAYDIS]INVAMT)
    Else
        [M:PAYDIS]PAYSKO    = 100
        [M:PAYDIS]DISSKOINV = 100
    Endif
    If [M:PAYDIS]PAYAMT <> 0 Then
        [M:PAYDIS]DISSKOPAY = ar2([M:PAYDIS]DISAMT * 100 / [M:PAYDIS]PAYAMT)
    Else
        [M:PAYDIS]DISSKOPAY = 100
    Endif
    [M:PAYDIS]RSTOSTAMT = [M:PAYDIS]OSTAMT - [M:PAYDIS]PAYAMT - [M:PAYDIS]DISAMT
    Affzo [M:PAYDIS]PAYSKO, DISSKOPAY, DISSKOINV, RSTOSTAMT
Return

#**##############################################################################################
## Handler for EXEC event.
#!###############################################################################################

$EXEC
    PARAM(3) = num$( [M:PAYDIS]PAYAMT )
    PARAM(5) = num$( -[M:PAYDIS]DISAMT )  # Must be negative for discounts.
    VALEUR   = "OK"                       # Signal "to be processed" (not cancelled).
Return

#**##############################################################################################
## Handler for CONTROLE event.
#!###############################################################################################

$CONTROLE
# X3-99653 Bader 2018-07-10 begin
#    If [M:PAYDIS]RSTINPAMT <> 0 Then
#        If [M:PAYDIS]PAYAMT + [M:PAYDIS]DISAMT > [M:PAYDIS]RSTINPAMT Then
#            [V]GMESSAGE = mess(396,107,1) # Allocated amount exceeds available amount!
#            [V]GERR = 1
#        Endif
#    Else
# X3-99653 Bader 2018-07-10 end
        If [M:PAYDIS]PAYAMT + [M:PAYDIS]DISAMT > [M:PAYDIS]OSTAMT Then
            [V]GMESSAGE = mess(397,107,1) # Allocated amount exceeds open amount!
            [V]GERR = 1
        Endif
# X3-99653 Bader 2018-07-10 begin
#    Endif
# X3-99653 Bader 2018-07-10 end
Return

#**##############################################################################################
## Handler for TRT_DIV event.
#!###############################################################################################

$TRT_DIV
    Case TRAIT
        When "PAYDISRAT":
            # Recalculate discount/charge amount based on open item amount and the clicked/marked grid line.
# 2016-01-05 DNE MODIF BEGIN
#            Local Integer DELAI : Raz DELAI
#
#            Call ESC_AGIO( [F:DUD]DEP, [M:PAYDIS]OSTAMT, [M:PAYDIS]DISDAT(nolign - 1), [F:DUD]DUDDAT, DELAI,
#&                  [M:PAYDIS]DISRAT(nolign - 1), [M:PAYDIS]DISAMT, [F:DUD]ACCNUM, [F:DUD]DUDLIG ) From TRTDIV
#            [M:PAYDIS]DISAMT = abs( [M:PAYDIS]DISAMT )
# 2016-01-05 DNE MODIF ORIG
#            [M:PAYDIS]DISAMT = abs(arr([M:PAYDIS]OSTAMT * [M:PAYDIS]DISRAT(nolign - 1) / 100, [M:PAYDIS]CURRND))
# 2016-01-05 DNE MODIF END
# 2016-04-15 TOGAN MODIF BEGIN
            [M:PAYDIS]DISAMT = abs(arr([M:PAYDIS]DISBAS * [M:PAYDIS]OSTAMT * [M:PAYDIS]DISRAT(nolign - 1) / [M:PAYDIS]INVAMT / 100, [M:PAYDIS]CURRND))
# 2016-04-15 TOGAN MODIF ORIG
#            [M:PAYDIS]DISAMT = abs(arr([M:PAYDIS]DISBAS * [M:PAYDIS]DISRAT(nolign - 1) / 100, [M:PAYDIS]CURRND))
# 2016-04-15 TOGAN MODIF END
            [M:PAYDIS]PAYAMT = [M:PAYDIS]OSTAMT - [M:PAYDIS]DISAMT
            Affzo [M:PAYDIS]PAYAMT, DISAMT
            Gosub UPDATE_PERCENTAGE           # Update percentage values of block 4.
    Endcase
Return

#################################################################################################
## Field event handlers
#################################################################################################

#**##############################################################################################
## Control of payment amount value.
#!###############################################################################################

Subprog C_PAYAMT(VALEUR)
    Variable Decimal VALEUR

    If VALEUR <= 0 Then
        mkstat = 2
    Endif
End

#**##############################################################################################
## After modification of payment amount.
#!###############################################################################################

Subprog AM_PAYAMT(VALEUR)
    Variable Decimal VALEUR

    [M:PAYDIS]PAYAMT = VALEUR
    Gosub UPDATE_PERCENTAGE           # Update percentage values of block 4.
End

#**##############################################################################################
## After modification of discount/charge amount.
#!###############################################################################################

Subprog AM_DISAMT(VALEUR)
    Variable Decimal VALEUR

    [M:PAYDIS]DISAMT = VALEUR
    Affzo [M:PAYDIS]PAYAMT
    Gosub UPDATE_PERCENTAGE           # Update percentage values of block 4.
End

#**##############################################################################################
## Control of '% of invoice' rate.
#!###############################################################################################

Subprog C_PAYSKO(VALEUR)
    Variable Decimal VALEUR
    If VALEUR > 100 Then
        mkstat = 2
    Endif
End

#**##############################################################################################
## After modification of '% of invoice' rate in block 4 line 1.
#!###############################################################################################

Subprog AM_PAYSKO(VALEUR)
    Variable Decimal VALEUR

    # Recalculate discount/charge amount
    [M:PAYDIS]PAYAMT = arr([M:PAYDIS]INVAMT * VALEUR / 100, [M:PAYDIS]CURRND)
    Affzo [M:PAYDIS]PAYAMT
    Gosub UPDATE_PERCENTAGE           # Update percentage values of block 4.
    VALEUR = [M:PAYDIS]PAYSKO         # Reset VALEUR to the value calculated in $UPDATE_PERCENTAGE.
End

#**##############################################################################################
## Control of '% of invoice' rate.
#!###############################################################################################

Subprog C_DISSKOINV(VALEUR)
    Variable Decimal VALEUR
    If VALEUR > 100 Then
        mkstat = 2
    Endif
End

#**##############################################################################################
## After modification of '% of invoice' rate in block 4 line 2.
#!###############################################################################################

Subprog AM_DISSKOINV(VALEUR)
    Variable Decimal VALEUR

    # Recalculate discount/charge amount
    [M:PAYDIS]DISAMT = arr([M:PAYDIS]INVAMT * VALEUR / 100, [M:PAYDIS]CURRND)
    Affzo [M:PAYDIS]DISAMT
    Gosub UPDATE_PERCENTAGE           # Update percentage values of block 4.
    VALEUR = [M:PAYDIS]DISSKOINV      # Reset VALEUR to the value calculated in $UPDATE_PERCENTAGE.
End

#**##############################################################################################
## Control of '% of payment' rate.
#!###############################################################################################

Subprog C_DISSKOPAY(VALEUR)
    Variable Decimal VALEUR
    If VALEUR > 100 Then
        mkstat = 2
    Endif
End

#**##############################################################################################
## After modification of '% of payment' rated in block 4 line 2.
#!###############################################################################################

Subprog AM_DISSKOPAY(VALEUR)
    Variable Decimal VALEUR

    # Recalculate discount/charge amount
    [M:PAYDIS]DISAMT = arr( [M:PAYDIS]PAYAMT * VALEUR / 100, [M:PAYDIS]CURRND )
    Affzo [M:PAYDIS]DISAMT
    Gosub UPDATE_PERCENTAGE           # Update percentage values of block 4.
    VALEUR = [M:PAYDIS]DISSKOPAY      # Reset VALEUR to the value calculated in $UPDATE_PERCENTAGE.
End

########################################################################################################################

Funprog GET_DISCOUNTABLE_AMOUNT(VDEPMGTMOD, VTYP, VNUM, VACCNUM, VCPY, VCUR, VBPRTYP, VDEP, VAMTPAY, VAMT1, VAMT2)
    Value Integer VDEPMGTMOD  # DEPMGTMOD parameter
    Value Char VTYP()         # open item type
    Value Char VNUM()         # and number
    Value Integer VACCNUM     # its ACCNUM
    Value Char VCPY()         # the company
    Value Char VCUR()         # currency
    Value Integer VBPRTYP     # BP type
    Value Char VDEP()         # bank discount/charge code
    Value Decimal VAMTPAY     # invoice amount
    Value Decimal VAMT1       # open item "Amount in currency"
    Value Decimal VAMT2       # invoice "Amount + tax"
    Local Decimal LRESULT

    If VDEPMGTMOD = 1 and dim(GLASINTNUM) > 0 and GLASINTNUM > 0 and VACCNUM <= GLASINTNUM Then
        [L]LRESULT = VAMT1
        Call CALBASDEP_BRIMOD(VCPY, VDEP, [L]LRESULT) From PAYDEPLIB3
    Elsif VDEPMGTMOD = 4 Then
        [L]LRESULT = VAMT1
        Call CALBASDEP_GERMOD(VBPRTYP, VTYP, VNUM, VACCNUM, VCUR, [L]LRESULT) From PAYDEPLIB3
    Elsif ((VDEPMGTMOD = 1 or VDEPMGTMOD = 2) and dim(GLASINTNUM) > 0 and GLASINTNUM > 0 and VACCNUM > GLASINTNUM)
&       or VDEPMGTMOD = 3 or VDEPMGTMOD = 5 Then
        [L]LRESULT = VAMT2
        Call CALBASDEP(VBPRTYP, VNUM, VDEP, VCUR, VAMTPAY, [L]LRESULT) From PAYDEPLIB3
    Endif
End [L]LRESULT

########################################################################################################################

