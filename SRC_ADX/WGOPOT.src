#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OPOT

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:14:52"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OPOT",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="POT0;POT1;POT2;POT3;POT6;POT4;POT5;POT7;POT8;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 1
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
OBJLIS(0) = "POT"
CHGLIS(0) = 2
BROLIS(0) = 2
TRELIS(0) = 1
DESLIS(0) = "COD"
OBJLIS(1) = "HRPO1"
CHGLIS(1) = 2
BROLIS(1) = 2
TRELIS(1) = 2
DESLIS(1) = "CPYPOT+FCYPOT+SRVPOT+COD"
If clalev([M:POT0])=0 : Local Mask POT0 [POT0] : Endif
If clalev([M:POT1])=0 : Local Mask POT1 [POT1] : Endif
If clalev([M:POT2])=0 : Local Mask POT2 [POT2] : Endif
If clalev([M:POT3])=0 : Local Mask POT3 [POT3] : Endif
If clalev([M:POT6])=0 : Local Mask POT6 [POT6] : Endif
If clalev([M:POT4])=0 : Local Mask POT4 [POT4] : Endif
If clalev([M:POT5])=0 : Local Mask POT5 [POT5] : Endif
If clalev([M:POT7])=0 : Local Mask POT7 [POT7] : Endif
If clalev([M:POT8])=0 : Local Mask POT8 [POT8] : Endif
Gosub TIT
nolign = 1
If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:AXX])=0 : Local file ATEXTRA [AXX] : Endif
Link [POT] With
& [AFF]AFF0~=[F:POT]FCYPOT;GPROFIL;GUSRFCT,
& [FGR]FGR0=GGRPFCY;[F:POT]FCYPOT,
& [AXX]AXX0="POSTE";"DES";GLANGUE;[F:POT]COD;""
& As [POT_]
If clalev([F:POT])=0 : Local file POSTE [POT] : Endif
If clalev([F:CPY])=0 : Local file COMPANY [CPY] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:SRV])=0 : Local file SERVICE [SRV] : Endif
If clalev([F:AX3])=0 : Local file ATEXTRA [AX3] : Endif
If clalev([F:AX4])=0 : Local file ATEXTRA [AX4] : Endif
Link [POT] With
& [CPY]CPY0=[F:POT]CPYPOT,
& [FCY]FCY0=[F:POT]FCYPOT,
& [SRV]SRV0=[F:POT]SRVPOT,
& [AX3]AXX0="COURSEI";"DES";GLANGUE;num$([F:POT]SRVPOT);num$(""),
& [AX4]AXX0="POSTE";"DES";GLANGUE;[F:POT]COD;""
& As [POT4]
& Order By Key POT4
Return

$DEF_BOITE
Gosub HORODAT From WGOPOT
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPOT" From GFONCTION At A_STAMP With A_WINDPREV Mask [POT0]
&   Folder Mask [POT1]
& , Folder Mask [POT2]
& , Folder Mask [POT3]
& , Folder Mask [POT6]
& , Folder Mask [POT4]
& , Folder Mask [POT5]
& , Folder Mask [POT7]
& , Folder Mask [POT8]
&  Listbox [POT_] GAU_CHE
&   [L]SAIRAP(1) = [F:POT]COD Using "K:10c" Titled TITSEL(1) ,
&   [L]SAIRAP(2) = [F:AXX]TEXTE Using "K:10X" Titled TITSEL(2) ,
&   [L]SAIRAP(3) = [F:POT]DATSTRVLY Using "" Titled TITSEL(3) ,
&   [L]SAIRAP(4) = [F:POT]DATENDVLY Using "" Titled TITSEL(4) ,
&   [L]SAIRAP(5) = string$([F:POT]LEG<>'',[F:POT]LEG)+string$([F:POT]LEG='',mess(91,187,1)) Using "K:10X" Titled TITSEL(5)
&  Listbox [POT9] GAU_CHE9
&   [L]SAIRAP(1) = [F:POT9]A_TAB1 Using "K:10c" Titled TITSEL9(1)  ,
&   [L]SAIRAP(2) = [F:POT9]A_TAB2 Using "K:10X" Titled TITSEL9(2) ,
&   [L]SAIRAP(3) = [F:POT9]A_TAB3 Using "" Titled TITSEL9(3)  ,
&   [L]SAIRAP(4) = [F:POT9]A_TAB4 Using "" Titled TITSEL9(4)  ,
&   [L]SAIRAP(5) = [F:POT9]A_TAB5 Using "K:10X" Titled TITSEL9(5)
&  Treebox [POT4] GAU_CHE1
&   [F:POT]CPYPOT-[F:CPY]CPYNAM Using "" Titled TITSEL1(1) ,
&   [F:POT]FCYPOT-[F:FCY]FCYNAM Using "" Titled TITSEL1(2) ,
&   [F:POT]SRVPOT-[F:AX3]TEXTE Using "" Titled TITSEL1(3) ,
&   [F:POT]COD
&   +" "+[F:AX4]TEXTE
&   Titled ""
& As [POT1]
Titled [POT1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOPOT
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPOT" From GFONCTION At A_STAMP With A_WINDPREV Mask [POT0]
&   Folder Mask [POT1]
& , Folder Mask [POT2]
& , Folder Mask [POT3]
& , Folder Mask [POT6]
& , Folder Mask [POT4]
& , Folder Mask [POT5]
& , Folder Mask [POT7]
& , Folder Mask [POT8]
& As [POT1]
Titled [POT1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [POT1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [POT1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [POT1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS(30)
Call TEXTE(22321,TITLIS) From OBJDIV
Local Char TITLIS9(30)
TITLIS9 = mess(196,123,1)
Local Char TITLIS1(30)
Call TEXTE(48398,TITLIS1) From OBJDIV
Local Char TITSEL(30)(1..5)
Call TEXTE(22321,TITSEL(1)) From OBJDIV
Call TEXTE(35,TITSEL(2)) From OBJDIV
Call TEXTE(1805,TITSEL(3)) From OBJDIV
Call TEXTE(1806,TITSEL(4)) From OBJDIV
Call TEXTE(26213,TITSEL(5)) From OBJDIV
Local Char TITSEL9(30)(1..5)
Call TEXTE(22321,TITSEL9(1)) From OBJDIV
Call TEXTE(35,TITSEL9(2)) From OBJDIV
Call TEXTE(1805,TITSEL9(3)) From OBJDIV
Call TEXTE(1806,TITSEL9(4)) From OBJDIV
Call TEXTE(26213,TITSEL9(5)) From OBJDIV
Local Char TITSEL1(30)(1..5)
Call TEXTE(1343,TITSEL1(1)) From OBJDIV
Call TEXTE(1344,TITSEL1(2)) From OBJDIV
Call TEXTE(18735,TITSEL1(3)) From OBJDIV
Call TEXTE(22321,TITSEL1(4)) From OBJDIV
Call TEXTE(35,TITSEL1(5)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(22321,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Gosub SETCLE_
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""  : CRITERE  = "1=1" : Endif
 If FILTSUP=""  : FILTSUP  = "1=1" : Endif
 If FILROLE=""  : FILROLE  = "1=1" : Endif
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [POT_] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(0)<>'' or NOHLIS(0)<>0
 Fillbox [POT1] GAU_CHE Hint Key =HINTLIS(0)
Else
 Gosub CALNOHOBJ From GOBJET
 If A_NOH
  Fillbox [POT1] GAU_CHE
 Else
  Fillbox [POT1] GAU_CHE Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [POT_]
Return

$REMPLIT_1
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""   : CRITERE   = "1=1" : Endif
 If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif
 If FILSUITE=""  : FILSUITE  = "1=1" : Endif
 Filter [POT4] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
&       Order By Key POT4
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(1)<>'' or NOHLIS(1)<>0
 Fillbox [POT1] GAU_CHE1 Hint Key =HINTLIS(1)
Else
 Gosub CALNOH From GOBJET
 If A_NOH
  Fillbox [POT1] GAU_CHE1
 Else
  Fillbox [POT1] GAU_CHE1 Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [POT4]
Return

$SETCLE_
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 1
GAUTRELIS = 1
CLELISTE = "COD"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$SETCLE_1
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 4
SNSLIS = 1
LENLIS = 4
GAUTRELIS = 2
CLELISTE = "CPYPOT;FCYPOT;SRVPOT;COD"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 0 : Default file [POT_]
 When 1 : Default file [POT4]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [POT_] Order With CLELISTE
  Setlbox [POT1] GAU_CHE
  Filter [POT_]
 When "GAU_CHE9"
  Gosub CLE_DERLU From =PROGOBJ
  Setlbox [POT1] GAU_CHE9
 When "GAU_CHE1"
  Setlbox [POT1] GAU_CHE1
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [POT_] Order With CLELISTE
Endcase
Return

$ENDORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [POT_]
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "POT0"         : ABMSK(0)  = "POT0"     : AMA(0) = 1
NOMMSK(1) = "POT1"         : ABMSK(1)  = "POT1"     : AMA(1) = 1
NOMMSK(2) = "POT2"         : ABMSK(2)  = "POT2"     : AMA(2) = 1
NOMMSK(3) = "POT3"         : ABMSK(3)  = "POT3"     : AMA(3) = 1
NOMMSK(4) = "POT6"         : ABMSK(4)  = "POT6"     : AMA(4) = 1
NOMMSK(5) = "POT4"         : ABMSK(5)  = "POT4"     : AMA(5) = 1
NOMMSK(6) = "POT5"         : ABMSK(6)  = "POT5"     : AMA(6) = 1
NOMMSK(7) = "POT7"         : ABMSK(7)  = "POT7"     : AMA(7) = 1
NOMMSK(8) = "POT8"         : ABMSK(8)  = "POT8"     : AMA(8) = 1
NBMASK = 8
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:POT0])>0 : Default Mask [POT0] : Endif
 When 1 : If clalev([M:POT1])>0 : Default Mask [POT1] : Endif
 When 2 : If clalev([M:POT2])>0 : Default Mask [POT2] : Endif
 When 3 : If clalev([M:POT3])>0 : Default Mask [POT3] : Endif
 When 4 : If clalev([M:POT6])>0 : Default Mask [POT6] : Endif
 When 5 : If clalev([M:POT4])>0 : Default Mask [POT4] : Endif
 When 6 : If clalev([M:POT5])>0 : Default Mask [POT5] : Endif
 When 7 : If clalev([M:POT7])>0 : Default Mask [POT7] : Endif
 When 8 : If clalev([M:POT8])>0 : Default Mask [POT8] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:POT0])>0 : Gosub TITRES From W1POT0 : Endif
 When 1 : If clalev([M:POT1])>0 : Gosub TITRES From W1POT1 : Endif
 When 2 : If clalev([M:POT2])>0 : Gosub TITRES From W1POT2 : Endif
 When 3 : If clalev([M:POT3])>0 : Gosub TITRES From W1POT3 : Endif
 When 4 : If clalev([M:POT6])>0 : Gosub TITRES From W1POT6 : Endif
 When 5 : If clalev([M:POT4])>0 : Gosub TITRES From W1POT4 : Endif
 When 6 : If clalev([M:POT5])>0 : Gosub TITRES From W1POT5 : Endif
 When 7 : If clalev([M:POT7])>0 : Gosub TITRES From W1POT7 : Endif
 When 8 : If clalev([M:POT8])>0 : Gosub TITRES From W1POT8 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:POT0])>0 : Close Local Mask [POT0] : Endif
If clalev([M:POT1])>0 : Close Local Mask [POT1] : Endif
If clalev([M:POT2])>0 : Close Local Mask [POT2] : Endif
If clalev([M:POT3])>0 : Close Local Mask [POT3] : Endif
If clalev([M:POT6])>0 : Close Local Mask [POT6] : Endif
If clalev([M:POT4])>0 : Close Local Mask [POT4] : Endif
If clalev([M:POT5])>0 : Close Local Mask [POT5] : Endif
If clalev([M:POT7])>0 : Close Local Mask [POT7] : Endif
If clalev([M:POT8])>0 : Close Local Mask [POT8] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:POT0])>0 : Raz [M:POT0] : Endif
 When 1 : If clalev([M:POT1])>0 : Raz [M:POT1] : Endif
 When 2 : If clalev([M:POT2])>0 : Raz [M:POT2] : Endif
 When 3 : If clalev([M:POT3])>0 : Raz [M:POT3] : Endif
 When 4 : If clalev([M:POT6])>0 : Raz [M:POT6] : Endif
 When 5 : If clalev([M:POT4])>0 : Raz [M:POT4] : Endif
 When 6 : If clalev([M:POT5])>0 : Raz [M:POT5] : Endif
 When 7 : If clalev([M:POT7])>0 : Raz [M:POT7] : Endif
 When 8 : If clalev([M:POT8])>0 : Raz [M:POT8] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:POT0])>0 : Affzo [M:POT0] : Endif
 When 1 : If clalev([M:POT1])>0 : Affzo [M:POT1] : Endif
 When 2 : If clalev([M:POT2])>0 : Affzo [M:POT2] : Endif
 When 3 : If clalev([M:POT3])>0 : Affzo [M:POT3] : Endif
 When 4 : If clalev([M:POT6])>0 : Affzo [M:POT6] : Endif
 When 5 : If clalev([M:POT4])>0 : Affzo [M:POT4] : Endif
 When 6 : If clalev([M:POT5])>0 : Affzo [M:POT5] : Endif
 When 7 : If clalev([M:POT7])>0 : Affzo [M:POT7] : Endif
 When 8 : If clalev([M:POT8])>0 : Affzo [M:POT8] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 0 : If clalev([M:POT0])>0 : [F:POT] = [M:POT0] : Endif
 When 1 : If clalev([M:POT1])>0 : [F:POT] = [M:POT1] : Endif
 When 2 : If clalev([M:POT2])>0 : [F:POT] = [M:POT2] : Endif
 When 3 : If clalev([M:POT3])>0 : [F:POT] = [M:POT3] : Endif
 When 4 : If clalev([M:POT6])>0 : [F:POT] = [M:POT6] : Endif
 When 5 : If clalev([M:POT4])>0 : [F:POT] = [M:POT4] : Endif
 When 6 : If clalev([M:POT5])>0 : [F:POT] = [M:POT5] : Endif
 When 7 : If clalev([M:POT7])>0 : [F:POT] = [M:POT7] : Endif
 When 8 : If clalev([M:POT8])>0 : [F:POT] = [M:POT8] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 0 : If clalev([M:POT0])>0 : [M:POT0] = [F:POT] : Endif
 When 1 : If clalev([M:POT1])>0 : [M:POT1] = [F:POT] : Endif
 When 2 : If clalev([M:POT2])>0 : [M:POT2] = [F:POT] : Endif
 When 3 : If clalev([M:POT3])>0 : [M:POT3] = [F:POT] : Endif
 When 4 : If clalev([M:POT6])>0 : [M:POT6] = [F:POT] : Endif
 When 5 : If clalev([M:POT4])>0 : [M:POT4] = [F:POT] : Endif
 When 6 : If clalev([M:POT5])>0 : [M:POT5] = [F:POT] : Endif
 When 7 : If clalev([M:POT7])>0 : [M:POT7] = [F:POT] : Endif
 When 8 : If clalev([M:POT8])>0 : [M:POT8] = [F:POT] : Endif
Endcase
Return

$GRISE_CLE
If AMA(0)
 Grizo [POT0]COD
Else
 Grizo [POT1]COD
Endif
Return

$DEGRISE_CLE
If AMA(0)
 Actzo [POT0]COD
Else
 Actzo [POT1]COD
Endif
Return

$BOUTON
STDBOUT = "ECSAN09<>RHILJMP"
NBTEX  = 0
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
NBMEN += 1
NMEN(NBMEN) = 10 : Call TEXTE(1043,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "2" : LMEN(NBMEN) = 2001 : Call TEXTE(45545,TMEN(NBMEN)) From OBJDIV
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
 When "2"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:POT0]COD
  PARBOUT(2) = num$(2)
  PARBOUT(3) = num$(2)
  FLGEXE = 1
  GACTION = "TRTSALMED"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTSALMED","TRTSALMED",4,"XYTRTSALMED") From GTRAITE
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


