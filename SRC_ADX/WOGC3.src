$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Libelle  A_BUF1(0..GNBDERNIER)
Local Char     A_BUF2(10)(0..GNBDERNIER)
Local Char     A_BUF3(30)(0..GNBDERNIER)
Local Char     A_BUF4(20)(0..GNBDERNIER)
Local Char     A_BUF5(30)(0..GNBDERNIER)
Local Char     A_BUF6(10)(0..GNBDERNIER)
If clalev([F:GCP9])>0 : Close Local File [GCP9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Libelle  A_TAB1,
& Char     A_TAB2(10),
& Char     A_TAB3(30),
& Char     A_TAB4(20),
& Char     A_TAB5(30),
& Char     A_TAB6(10)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6
& As [GCP9]
Return

$LEC_DERLU
Read [AXM]AXX0="ATABDIV";"LNGDES";GLANGUE;"10460";[F:GCP]JOBGRP
If fstat : Raz [F:AXM] : Endif
Read [ADI]CODE=10460;[F:GCP]JOBGRP
If fstat : Raz [F:ADI] : Endif
Read [AXF]AXX0="ATABDIV";"LNGDES";GLANGUE;"10459";[F:ADI]DEPCOD
If fstat : Raz [F:AXF] : Endif
Return

$CHARGE_DERLU
If clalev([F:GCP9])>0
 Read [GCP9] = [F:GCP9]A_TABI
 [L]CLE = [F:GCP9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:GCP9])>0
 Filter [GCP9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [GCP] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:GCP9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:GCP]UOMGRP+"~"
 A_CLEDERLU += num$([F:GCP]LEVGRP)+"~"
 A_CLEDERLU += [F:GCP]JOBGRP+"~"
 A_CLEDERLU += [F:GCP]CPCFAM+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:GCP9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:GCP9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:GCP]LEVGRP"
Call TEXTE(5230,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 1
SELFMT(NBSEL) = "LA10938:15X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:GCP]LEVGRP"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(2)"
SELEXP(NBSEL) = "[F:ADI]DEPCOD"
Call TEXTE(13912,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(3)"
SELEXP(NBSEL) = "[F:AXF]TEXTE"
Call TEXTE(8,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = "K:30X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[F:GCP]JOBGRP"
Call TEXTE(46541,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:GCP]JOBGRP"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(5)"
SELEXP(NBSEL) = "[F:AXM]TEXTE"
Call TEXTE(8,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = "K:30X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(6)"
SELEXP(NBSEL) = "string$([F:GCP]LEG<>'',[F:GCP]LEG)+string$([F:GCP]LEG='',mess(91,187,1))"
Call TEXTE(26213,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
If clalev([F:GCP_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:AXM])=0 : Local file ATEXTRA [AXM] : Endif
If clalev([F:ADI])=0 : Local file ATABDIV [ADI] : Endif
If clalev([F:AXF])=0 : Local file ATEXTRA [AXF] : Endif
Link [GCP] With
& [AXM]AXX0="ATABDIV";"LNGDES";GLANGUE;"10460";[F:GCP]JOBGRP,
& [ADI]CODE=10460;[F:GCP]JOBGRP,
& [AXF]AXX0="ATABDIV";"LNGDES";GLANGUE;"10459";[F:ADI]DEPCOD
& As [GCP_]
Return

$DEFAUT_LISTE
