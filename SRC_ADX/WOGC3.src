& Char     A_TABJ3(20),
& Char     A_TABJ4(20),
& Char     A_TABJ5(15),
& Char     A_TABJ6(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3, A_BUFJ4, A_BUFJ5, A_BUFJ6
& As [PCEJ]
Return

$TIT_JOIN
