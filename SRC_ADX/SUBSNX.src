########################################
Subprog AM_MAXLIG(VALEUR)
Variable Decimal VALEUR
If VALEUR > GCOD_INV | VALEUR  < 1
   mkstat = 2
Endif
End

########################################
Subprog AM_PRCLIG(VALEUR)
Variable Decimal VALEUR
If VALEUR > 100
   mkstat = 2
Endif
If VALEUR <> 0
    [M:SNU1]MAXLIGCAL = ([M:SNU1]MAXLIG * VALEUR)/100
    If [M:SNU1]MAXLIGCAL < 1                      # hcb 89457
       [M:SNU1]MAXLIGCAL = 1
    Endif
    [M:SNU1]PRCLIG = VALEUR
    Affzo [M:SNU1]MAXLIGCAL
Endif

End

