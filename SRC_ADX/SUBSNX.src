#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du fichier STOCUN

Call OBJET("SNX",GBIDC1,GBIDC2) From GOBJET
End

#call inivar a enlever des que le superviseur le fera ...........

$ACTION
Case ACTION
  When "AVANT_OUVRE"   : Gosub AVANT_OUVRE       # hcb 99644
  When "OUVRE"         : Gosub OUVRE
  When "FERME"         : Gosub FERME
  When "LIENS"         : Gosub LIENS
  When "RAZCRE"        : Gosub RAZCRE
  When "RAZDUP"        : Gosub RAZDUP
  When "INICRE"        : Gosub INICRE
  When "APRES_CRE"     : Gosub APRES_CRE
  When "ABANDON"       : Gosub ABANDON
  When "SETBOUT"       : Gosub SETBOUT
  When "VERF_ANU"      : Gosub VERF_ANU
  When "ANNULE"        : Gosub ANNULE
  When "AV_IMPRIME"    : Gosub COP_ECRAN
  When "INIMOD"        : Gosub INIMOD
  When "AFFMASK"       : Gosub AFFMASK
                         OK = 0
 When Default
Endcase
Return
#                          hcb  99644 deb
$AVANT_OUVRE
ANOUPDTICK = 1
Return

#                          hcb  99644 end


$AFFMASK

Diszo [M:SNU0]STOFCY

Return


$SETBOUT

#si pas dernier lu
If  [F:CUN]CUNSSSNUM  = ""
   Call VIREBOUT(CHAINE,"abc") From GOBJET
Endif
#si pas situation stable (modif ou creation
If  GREP <> ""
   Call VIREBOUT(CHAINE,"abc") From GOBJET
Endif


# en creation bouton simulation et generation interdit ...
If GREP="C"
   Call VIREBOUT(CHAINE,"abc") From GOBJET
Endif
If  [F:CUN]CUNSSSSTA > 1
   Call VIREBOUT(CHAINE,"ab") From GOBJET
Endif
# si session close suppression interdite  ...
If [F:CUN]CUNSSSSTA = 3
   Call VIREBOUT(CHAINE,"Ac") From GOBJET
Endif
# si session en creation  suppression liste interdite  ...
If [F:CUN]CUNSSSSTA = 1
   Call VIREBOUT(CHAINE,"c") From GOBJET
Endif

Return

$ANNULE
Local Integer WOK
#suppression détails
Call DEL_CUD([M:SNU0]STOFCY,[M:SNU0]CUNSSSNUM,"",WOK) From STKINV
If WOK <> 2
   GOK = 0
   Return
Endif
#suppression listes
Call DEL_CUL([M:SNU0]STOFCY,[M:SNU0]CUNSSSNUM,WOK) From STKINV
If WOK <> 2
   GOK = 0
   OK = 0
   Return
Endif
Return

$VERF_ANU
Local Integer WOK
# Suppression interdite si session close
If [F:CUN]CUNSSSSTA = 3
   Call MESSAGE(mess(422,199,1)) From GESECRAN
   GOK = 0
   OK = 0
   Return
Endif

# Suppression interdite si des listes associées sont validées ou cloturées
Filter [CUL] Where CUNSSSNUM = [F:CUN]CUNSSSNUM  &
&                  CUNLISSTA > 2
Look [CUL]CUL0 First
Filter [CUL]
If !fstat
   Call MESSAGE(mess(423,199,1)) From GESECRAN
   GOK = 0
   OK = 0
   Return
Endif


# Suppression interdite si des détails sont comptées
Filter [CUD] Where CUNSSSNUM = [F:CUN]CUNSSSNUM  &
&                  CUNLISSTA > 1
Look [CUD]CUD0 First
Filter [CUD]
If !fstat
   Call OUINON(mess(196,199,1),WOK) From GESECRAN
   If WOK <> 2
      GOK = 0
      OK = 0
      Return
   Endif
Endif

Return

$OUVRE
If clalev([F:ACV])=0 Local File ACTIV      [ACV]  Endif
#lecture code activite nombre de lignes par liste d inventaire

If dim(GCOD_INV)<1
   Global Integer GCOD_INV
Endif
Read [ACV] CODACT="INV"
     If !fstat GCOD_INV=[F:ACV]DIME
Endif
If dim(GCOD_INL)<1
   Global Integer GCOD_INL
Endif
Read [ACV] CODACT="INL"
     If !fstat GCOD_INL=[F:ACV]DIME
Endif
If dim(GCOD_EMP)<1
   Global Integer GCOD_EMP
Endif
Read [ACV] CODACT="EMP"
     If !fstat GCOD_EMP=[F:ACV]FLACT
Endif
Call INIVAR From GLOBSTO

GFCY=GFCYDEF(7)                                                # Ana
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY(GFCY,"",6,"") From TRTX3CPT
If GMODU(2)=2 : # Si module compta actif                       # Ana
   If !clalev([F:GCM])   Local File GACM       [GCM] : Endif    # Ana
Endif                                                          # Ana
If GWRHACT = 2
   If clalev([F:ITW]) = 0 : Local File ITMWRH    [ITW] : Endif
   If clalev([F:WRH]) = 0 : Local File WAREHOUSE [WRH] : Endif
Endif

Global Integer GWRHGES    # globale gestion depot du site
Global Integer GITMWRH
Raz GITMWRH
#                                                 # hcb 110327 deb
# PE pour desactiver le controle bloquant d une ligne desynchronisée ds la cas de serie global
Global Integer GCTRSYNCHRO
Raz GCTRSYNCHRO
GPOINT = "CTRSYNCHRO"
Gosub  ENTREE From EXEFNC
#                                                 # hcb 110327 deb
Return


$FERME
Call IMPSCR From ATRTX3
If  GCONSULT = 2
    Return
Endif

If dim(GCOD_INV) > 0
   Kill GCOD_INV
Endif
If dim(GCOD_INL) > 0
   Kill GCOD_INL
Endif
If dim(GCOD_EMP) > 0
   Kill GCOD_EMP
Endif

Return

$LIENS
Global Integer GCOD_INV
Read [ACV]CODACT="INV"
If !fstat
   GCOD_INV =[F:ACV]DIME
Endif
#lecture code activite nombre de listes d inventaire par session
Global Integer GCOD_INL
Read [ACV]CODACT="INL"
If !fstat
   GCOD_INL =[F:ACV]DIME
Endif
#lecture code activite gestion emplacement
Global Integer GCOD_EMP
Read[ACV]CODACT="EMP"
If !fstat
   GCOD_EMP =[F:ACV]FLACT
Endif


Call INIVAR From GLOBSTO


Actzo [M:SNU2]
Actzo [M:SNU1]

       # Chargement globales référenciels, comptes et sections de la société
GFCY = [M:SNU0]STOFCY
Gosub CHARG_PARAM From SUBSNXA

If GWRHACT = 2
   If [M]STOFCY<>[F:FCY]FCY
      Read [FCY]FCY0=[M]STOFCY
   Endif
   GWRHGES =[F:FCY]WRHGES
Endif

[M:SNU0]CUR  = GLOCALDEV

# si pas de gestion des emplacements type d inventaire = article , tri = article/emplacement
If GCOD_EMP = 1
   Grizo [M:SNU1]CUNSSSTYP
   Grizo [M:SNU1]CUNSRTCOD
Endif


If [M:SNU1]CUNSSSTYP = 2
   Grizo [M:SNU1]CUNLASFLG            # Global
   Grizo [M:SNU1]CUNNULSTK            # Articles sans stock
   If dim([M:SNU1]CUNITMWRH) > 0
      Grizo [M:SNU1]CUNITMWRH         # Articles depot
   Endif
   Grizo [M:SNU1]ITMNBR               # Nombre article
   Grizo [M:SNU1]MULLISFLG            # Multi-listes
   Grizo [M:SNU1]10                   # mode inventaire
   Grizo [M:SNU1]35                   # Classe ABCD
Endif
If [M:SNU1]CUNSSSTYP= 1
   If dim([M:SNU1]LOCPOS) > 0
      Grizo [M:SNU1]LOCPOS
   Endif
   Actzo [M:SNU1]35                   # Classe ABCD
   Actzo [M:SNU1]ITMNBR               # Nombre article
   Actzo [M:SNU1]MULLISFLG            # Multi-listes
   Actzo [M:SNU1]10                   # mode inventaire
   If dim([M:SNU1]CUNITMWRH) > 0
      If GWRHGES = 2                  # hcb 70190
         Actzo [M:SNU1]CUNITMWRH         # Articles depot
      Else
         Grizo [M:SNU1]CUNITMWRH         # Articles depot
      Endif                           # hcb 70190
      If [M:SNU1]CUNITMWRH  = 2
         Grizo [M:SNU1]MULLISFLG            # Multi-listes
 #       Grizo [M:SNU1]CUNLASFLG            # Global
      Endif
   Endif

Endif

[M:SNU2]NUMSELFOR   = 18
GITMWRH             = [F:CUN]CUNITMWRH
If dim([M:SNU1]CUNITMWRH) > 0
   If [M:SNU1]CUNITMWRH = 1 | GWRHGES <> 2
#      If [M:SNU1]CUNLASFLG = 2   # hcb 70190
      Grizo [M:SNU2]SELFOR3
      Grizo [M:SNU2]WRHSTR
      Grizo [M:SNU2]WRHEND
#      Endif                      # hcb 70190
      [M:SNU2]NUMSELFOR   = 18
   Else
      Actzo [M:SNU2]SELFOR3
      Actzo [M:SNU2]WRHSTR
      Actzo [M:SNU2]WRHEND
      [M:SNU2]NUMSELFOR = 42
   Endif
Endif

If [M:SNU1]CUNSSSMOD <> 2
   Grizo [M:SNU1]CUNNBRA
   Grizo [M:SNU1]CUNNBRB
   Grizo [M:SNU1]CUNNBRC
   Grizo [M:SNU1]CUNNBRD
Else
   Actzo [M:SNU1]CUNNBRA
   Actzo [M:SNU1]CUNNBRB
   Actzo [M:SNU1]CUNNBRC
   Actzo [M:SNU1]CUNNBRD
Endif

If [M:SNU1]CUNLASFLG = 2
#  Grizo [M:SNU2]SELFOR          # hcb 60614
#  Grizo [M:SNU2]SELFOR0         # hcb 60614
   Grizo [M:SNU2]SELFOR1
   If dim([M:SNU2]SELFOR2) > 0   # hcb 78971
      Grizo [M:SNU2]SELFOR2
   Endif
   If dim([M:SNU2]LOTSTR)>0
       Grizo [M:SNU2]LOTSTR
       Grizo [M:SNU2]LOTEND
   Endif
#  Grizo [M:SNU2]TCLCODSTR      # hcb 60614
#  Grizo [M:SNU2]TCLCODEND      # hcb 60614
#  Grizo [M:SNU2]BUYSTR         # hcb 60614
#  Grizo [M:SNU2]BUYEND         # hcb 60614
#  If dim([M:SNU2]TSICODSTR)>0  # hcb 60614
#      Grizo [M:SNU2]TSICODSTR  # hcb 60614
#      Grizo [M:SNU2]TSICODEND  # hcb 60614
#  Endif                        # hcb 60614
   If dim([M:SNU2]LOCTYPSTR)>0
       Grizo [M:SNU2]LOCTYPSTR
       Grizo [M:SNU2]LOCTYPEND
       Grizo [M:SNU2]LOCSTR
       Grizo [M:SNU2]LOCEND
   Endif
   If dim([M:SNU2]BPRNUMSTR)>0
       Grizo [M:SNU2]BPRNUMSTR
       Grizo [M:SNU2]BPRNUMEND
   Endif
   If dim([M:SNU1]CUNITMWRH) > 0   # hcb 70190
      Grizo [M:SNU2]SELFOR3
      Grizo [M:SNU2]WRHSTR
      Grizo [M:SNU2]WRHEND
   Endif

Else
   Actzo [M:SNU2]SELFOR
   Actzo [M:SNU2]SELFOR0
   Actzo [M:SNU2]SELFOR1
   If dim([M:SNU2]SELFOR2) > 0   # hcb 78971
      Actzo [M:SNU2]SELFOR2
   Endif
   If dim([M:SNU2]LOTSTR)>0
       Actzo [M:SNU2]LOTSTR
       Actzo [M:SNU2]LOTEND
   Endif
   Actzo [M:SNU2]TCLCODSTR
   Actzo [M:SNU2]TCLCODEND
   Actzo [M:SNU2]BUYSTR
   Actzo [M:SNU2]BUYEND
   If dim([M:SNU2]TSICODSTR)>0
       Actzo [M:SNU2]TSICODSTR
       Actzo [M:SNU2]TSICODEND
   Endif
   If dim([M:SNU2]LOCTYPSTR)>0
       Actzo [M:SNU2]LOCTYPSTR
       Actzo [M:SNU2]LOCTYPEND
       Actzo [M:SNU2]LOCSTR
       Actzo [M:SNU2]LOCEND
   Endif
   If dim([M:SNU2]BPRNUMSTR)>0
       Actzo [M:SNU2]BPRNUMSTR
       Actzo [M:SNU2]BPRNUMEND
   Endif
   If [M:SNU1]CUNSSSTYP = 2
      Grizo [M:SNU2]10                   # Articles
      Grizo [M:SNU2]15                   # Familles statistique
   Endif
   If [M:SNU1]CUNSSSTYP= 1 & dim([M:SNU2]BPRNUMSTR)>0
      Grizo [M:SNU2]BPRNUMSTR             # tiers
      Grizo [M:SNU2]BPRNUMEND
   Endif
   Actzo [M:SNU2]ITMSTA006          # hcb 61368
Endif

# si les listes sont génerées
#   chargement de l onglet listes
#   modification impossible des caracteristiques
If [M:SNU0]CUNSSSSTA > 1              # hcb 84267
   Call  LOAD_SNU3 From SUBSNXA
Endif

Return
$RAZDUP

[M:SNU0]CUNSSSSTA  = 1
# hcb 60445  deb
[M:SNU1]CPLCUNNBRA = 0
[M:SNU1]CPLCUNNBRB = 0
[M:SNU1]CPLCUNNBRC = 0
[M:SNU1]CPLCUNNBRD = 0
[M:SNU1]CUNSSSDAT  = date$
# hcb 60445  deb


Raz   [M:SNU3]
Affzo [M:SNU3]
Gosub LIENS   # hcb 84267
Return

$RAZCRE
# Valeurs par défaut
[M:SNU1]MAXLIG    = GCOD_INV
[M:SNU1]CUNSSSTYP = 1
[M:SNU1]CUNSSSMOD = 1
[M:SNU1]CUNSRTCOD = 1
[M:SNU1]CUNNULSTK = 2            # Articles sans stock
[M:SNU1]CUNLASFLG = 2

[M:SNU1]ITMNBR    = 9999         # Nombre article
[M:SNU1]MULLISFLG = 1            # Multi-listes
[M:SNU1]MULCTGFLG = 1            # Multi-comptages                                        # hcb 71659

If dim([M:SNU1]LOCPOS) > 0
   [M:SNU1]LOCPOS    = 10
Endif
[M:SNU1]PRCLIG    = 80
[M:SNU1]CUNSSSDAT = date$
[M:SNU1]ABCCLSA   = 2
[M:SNU1]ABCCLSB   = 2
[M:SNU1]ABCCLSC   = 2
[M:SNU1]ABCCLSD   = 2

Affzo [M:SNU1]
Affzo [M:SNU2]
Gosub GRISE_CLE From SUBSNXA
#Grizo [M:SNU2]SELFOR         # hcb 60614
#Grizo [M:SNU2]SELFOR0        # hcb 60614
Grizo [M:SNU2]SELFOR1
If dim([M:SNU2]SELFOR2) > 0   # hcb 78971
   Grizo [M:SNU2]SELFOR2
Endif
[M:SNU2]NUMSELFOR   = 18
If dim([M:SNU1]CUNITMWRH) > 0
   [M:SNU1]CUNITMWRH = 1         # Articles depot
#  Grizo  [M:SNU1]CUNITMWRH
   Grizo  [M:SNU2]SELFOR3
   Grizo  [M:SNU2]WRHSTR
   Grizo  [M:SNU2]WRHEND
   [M:SNU2]NUMSELFOR   = 18
Endif

If dim([M:SNU2]LOTSTR)>0
    Grizo [M:SNU2]LOTSTR
    Grizo [M:SNU2]LOTEND
Endif
#Grizo [M:SNU2]TCLCODSTR      # hcb 60614
#Grizo [M:SNU2]TCLCODEND      # hcb 60614
#Grizo [M:SNU2]BUYSTR         # hcb 60614
#Grizo [M:SNU2]BUYEND         # hcb 60614
#If dim([M:SNU2]TSICODSTR)>0  # hcb 60614
#    Grizo [M:SNU2]TSICODSTR  # hcb 60614
#    Grizo [M:SNU2]TSICODEND  # hcb 60614
#Endif                        # hcb 60614
If dim([M:SNU2]LOCTYPSTR)>0
    Grizo [M:SNU2]LOCTYPSTR
    Grizo [M:SNU2]LOCTYPEND
    Grizo [M:SNU2]LOCSTR
    Grizo [M:SNU2]LOCEND
Endif
If dim([M:SNU2]BPRNUMSTR)>0
    Grizo [M:SNU2]BPRNUMSTR
    Grizo [M:SNU2]BPRNUMEND
Endif
Raz GITMWRH
Return

$APRES_CRE

#affichage numero de session
Affzo [M:SNU0]CUNSSSNUM

Gosub DEGRISE_CLE From SUBSNXA
Return

$ABANDON
Gosub DEGRISE_CLE From SUBSNXA
Return


$INICRE
Local Char    LSSS

# Création du numéro de session si nécessaire
If GSTKCPTMAN(13)<>2 | [M:SNU0]CUNSSSNUM = ""
   Call NUM_SSS([M:SNU0]STOFCY,[M:SNU1]CUNSSSDAT,LSSS) From SUBSNXA
   If LSSS = ""
      mkstat = 2 :
      GMESSAGE= GSTKCPT(13)-":"-mess(104,117,1)
      Return
   Endif
   [M:SNU0]CUNSSSNUM = LSSS
   [F:CUN]CUNSSSNUM  = LSSS
Endif

Gosub INIMOD

Return

$INIMOD
Raz GITMWRH    # Hcb 70190
If dim([M:SNU1]CUNITMWRH)> 0
   If [M:SNU1]CUNITMWRH = 1 | GWRHGES <> 2
      GITMWRH = 1
   Else
      GITMWRH = 2
   Endif
Endif

# en import il ne faut pas modifier la valeur CUNLASFLG importée
If GIMPORT
   Return
Endif

If   [F:CUN]CUNSSSTYP <> 1
     Return
Endif

Local Char WTSI
Local Integer I

If dim([F:CUN]TSICODEND) > 0                # familles statistiques
    For I = 0 To dim([F:CUN]TSICODEND)-1
        If [F:CUN]TSICODEND(I) <> ""
            WTSI = [F:CUN]TSICODEND(I)
            Break
        Endif
    Next I
Endif
If GITMWRH =  2
#  [F:CUN]CUNLASFLG  = 1
   [F:CUN]MULLISFLG  = 1
Endif
#    [F:CUN]SELFOR     = ""   # hcb 60614
#    [F:CUN]SELFOR0    = ""   # hcb 60614
#    [F:CUN]TCLCODEND  = ""   # hcb 60614
#    [F:CUN]BUYEND     = ""   # hcb 60614
#    WTSI              = ""   # hcb 60614
# hcb 70190 rajout test GITMWRH  + 78803 rajout du |

If   [F:CUN]CUNSSSTYP  = 1    &
&    [F:CUN]SELFOR1    = ""   &
&    [F:CUN]SELFOR2    = ""   &
&    [F:CUN]LOTEND     = ""   &
&    [F:CUN]LOCTYPEND  = ""   &
&    [F:CUN]LOCEND     = ""   &
&    [F:CUN]BPRNUMEND  = ""   &
&    ((GITMWRH <> 2 & [F:CUN]SELFOR3 = "" & [F:CUN]WRHEND = "")  | (GITMWRH = 2))
     [F:CUN]CUNLASFLG  = 2
Else
     [F:CUN]CUNLASFLG  = 1
Endif

[M:SNU1]CUNLASFLG = [F:CUN]CUNLASFLG
Affzo [M:SNU1]CUNLASFLG
# hcb 72178 deb
If [M:SNU1]CUNLASFLG = 2
   Grizo [M:SNU2]SELFOR1
   If dim([M:SNU2]SELFOR2) > 0   # hcb 78971
      Grizo [M:SNU2]SELFOR2
   Endif
   If dim([M:SNU2]LOTSTR)>0
       Grizo [M:SNU2]LOTSTR
       Grizo [M:SNU2]LOTEND
   Endif
   If dim([M:SNU2]LOCTYPSTR)>0
       Grizo [M:SNU2]LOCTYPSTR
       Grizo [M:SNU2]LOCTYPEND
       Grizo [M:SNU2]LOCSTR
       Grizo [M:SNU2]LOCEND
   Endif
   If dim([M:SNU2]BPRNUMSTR)>0
       Grizo [M:SNU2]BPRNUMSTR
       Grizo [M:SNU2]BPRNUMEND
   Endif
   If dim([M:SNU1]CUNITMWRH) > 0
      Grizo [M:SNU2]SELFOR3
      Grizo [M:SNU2]WRHSTR
      Grizo [M:SNU2]WRHEND
   Endif
Endif
# hcb 72178 fin


Return

#########################################################################
$COP_ECRAN
Call PRTSCR("SNU0","SNU0",[M:SNU0]CUNSSSNUM-[M:SNU0]CUNSSSDES,0,0) From ATRTX3
Call PRTSCR("SNU1","SNU1",[M:SNU0]CUNSSSNUM-[M:SNU0]CUNSSSDES,0,0) From ATRTX3
Call PRTSCR("SNU2","SNU2",[M:SNU0]CUNSSSNUM-[M:SNU0]CUNSSSDES,0,0) From ATRTX3
Return

########################################
Subprog C_CUNSSSNUM(VALEUR)
Variable Char    VALEUR()
#
#-- Il faut une valeur saisie ou retournée par un compteur sinon erreur
If (VALEUR="" &  GSTKCPT(13)="")
    mkstat = 2
    End
Endif
#-- Si on est en création , n° saisi vide et un compteur est présent on sort
If (GREP="C" & VALEUR="" &  GSTKCPT(13)<>"")
   End
Endif

#-- Si dernier lu non chargé, on vérifie l'existence du n° saisi
If [M:SNU0]CUNSSSNUM="" & GREP<>"C"
   Look [F:CUN]CUN0=VALEUR
   If fstat
      GMESSAGE=mess(421,199,1)
      mkstat=2
      End
   Endif
Endif

If VALEUR<>"" & GSTKCPTMAN(13)<>2
   Look [F:CUN]CUN0=VALEUR
   If fstat
      Raz VALEUR
      End
   Endif
Endif
End



########################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
#
Read [STE]STE0=VALEUR;""
If fstat
  mkstat = 2
  GMESSAGE = mess(174,199,1)
  End                                                        # hcb x3-47481
Else
   GFCY = VALEUR
   Gosub CHARG_PARAM From SUBSNXA
  [M:SNU0]CUR  = GLOCALDEV
Endif

If GWRHACT = 2
   If VALEUR <> [F:FCY]FCY
      Read [FCY]FCY0=VALEUR
   Endif
   GWRHGES =[F:FCY]WRHGES
   If dim([M:SNU1]CUNITMWRH) > 0
      Raz      [M:SNU1]CUNITMWRH         # Articles depot
      If GWRHGES <> 2
         Grizo [M:SNU1]CUNITMWRH         # Articles depot
      Else
         Actzo [M:SNU1]CUNITMWRH         # Articles depot
      Endif
      Affzo    [M:SNU1]CUNITMWRH         # Articles depot

   Endif
Endif


End


########################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFEND = ""     : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
End


########################################
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End


########################################
Subprog AM_LOTSTR(VALEUR)
Variable Char    VALEUR()
If [M]LOTEND = ""     : [M]LOTEND = VALEUR : Affzo [M]LOTEND : Endif
If [M]LOTEND < VALEUR : [M]LOTEND = VALEUR : Affzo [M]LOTEND : Endif

End

########################################
Subprog C_LOTEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]LOTSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

