########################################
Subprog AP_CUNSSSTYP(VALEUR)
Variable Integer VALEUR
#[M:SNU1]CUNSSSTYP = VALEUR                  # hcb 83012

If VALEUR = 2 & [M:SNU1]CUNSSSTYP <> VALEUR  # hcb 83012
   [M:SNU1]CUNSSSTYP = VALEUR                # hcb 83012
   [M:SNU1]CUNSSSMOD = 1
   [M:SNU1]ITMNBR    = 9999
   [M:SNU1]MULLISFLG = 1            # Multi-listes
   Raz   [M:SNU1]CUNNBRA
   Raz   [M:SNU1]CUNNBRB
   Raz   [M:SNU1]CUNNBRC
   Raz   [M:SNU1]CUNNBRD

   [M:SNU1]ABCCLSB = 2
   [M:SNU1]ABCCLSB = 2
   [M:SNU1]ABCCLSC = 2
   [M:SNU1]ABCCLSD = 2
   [M:SNU1]CUNSRTCOD = 2
   [M:SNU1]CUNLASFLG = 1
   [M:SNU1]CUNNULSTK = 1
   [M:SNU2]NUMSELFOR = 18            # hcb 60614
   If dim([M:SNU1]CUNITMWRH) > 0
      [M:SNU1]CUNITMWRH = 1           # Articles depot
      [M:SNU2]NUMSELFOR = 18
      Grizo [M:SNU1]CUNITMWRH
   Endif

   Grizo [M:SNU1]CUNLASFLG            # Global
   Grizo [M:SNU1]CUNNULSTK            # Articles sans stock
   Grizo [M:SNU1]ITMNBR
   Grizo [M:SNU1]MULLISFLG            # Multi-listes

   If dim([M:SNU1]LOCPOS) > 0
      Actzo [M:SNU1]LOCPOS
   Endif
   Grizo [M:SNU1]10                   # mode inventaire
   Grizo [M:SNU1]35                   # Classe ABCD

   If [M:SNU1]CUNLASFLG = 1
      Raz [M:SNU2]SELFOR              # hcb 60614
      Raz [M:SNU2]SELFOR0             # hcb 60614
      Raz   [M:SNU2]ITMREFSTR
      Raz   [M:SNU2]ITMREFEND
      If dim([M:SNU2]LOTSTR) > 0
         Raz   [M:SNU2]LOTSTR
      Endif
      If dim([M:SNU2]LOTEND) > 0
         Raz   [M:SNU2]LOTEND
      Endif
      Raz   [M:SNU2]TCLCODSTR
      Raz   [M:SNU2]TCLCODEND
      Raz   [M:SNU2]BUYSTR
      Raz   [M:SNU2]BUYEND
      If dim([M:SNU2]TSICODSTR) > 0
         Raz   [M:SNU2]TSICODSTR
      Endif
      If dim([M:SNU2]TSICODEND) > 0
         Raz   [M:SNU2]TSICODEND
      Endif
      Grizo [M:SNU2]10                   # Articles
      Grizo [M:SNU2]15                   # Familles statistique
      Actzo [M:SNU2]20
      Raz   [M:SNU2]ITMSTA006          # hcb 61368
      Actzo [M:SNU2]ITMSTA006          # hcb 61368
#     Actzo [M:SNU2]SELFOR

   Endif
Endif
If VALEUR = 1  & [M:SNU1]CUNSSSTYP <> VALEUR  # hcb 83012
   [M:SNU1]CUNSSSTYP = VALEUR                 # hcb 83012
   If dim([M:SNU1]LOCPOS) > 0
      [M:SNU1]LOCPOS = 10
      Grizo [M:SNU1]LOCPOS
    Endif
   [M:SNU1]ABCCLSB = 2
   [M:SNU1]ABCCLSB = 2
   [M:SNU1]ABCCLSC = 2
   [M:SNU1]ABCCLSD = 2
   [M:SNU1]CUNSRTCOD = 1
   Actzo [M:SNU1]35                   # Classe ABCD
   Gosub CAL_COMPTAGE From SUBSNXA

   Actzo [M:SNU1]ITMNBR
   Actzo [M:SNU1]MULLISFLG            # Multi-listes

   Actzo [M:SNU1]CUNSSSMOD
   Raz   [M:SNU2]               # hcb 60614

# en import il ne faut pas modifier la valeur CUNLASFLG importée
   If !GIMPORT
      [M:SNU1]CUNLASFLG = 2
      [M:SNU1]CUNNULSTK = 2              # Articles sans stock
      If dim([M:SNU1]CUNITMWRH) > 0
         [M:SNU1]CUNITMWRH = 1           # Articles depot
         [M:SNU2]NUMSELFOR   = 18
         If GWRHGES <> 2
            Grizo  [M:SNU1]CUNITMWRH
         Else
            Actzo  [M:SNU1]CUNITMWRH
          Endif
      Endif
   Endif

   Actzo [M:SNU1]CUNLASFLG            # Global
   Actzo [M:SNU1]CUNNULSTK            # Articles sans stock

#  Raz   [M:SNU2]               # hcb 60614
   Grizo [M:SNU2]
   Actzo [M:SNU2]ITMREFSTR
   Actzo [M:SNU2]ITMREFEND
   Actzo [M:SNU2]SELFOR         # hcb 60614
   Actzo [M:SNU2]SELFOR0        # hcb 60614
   Actzo [M:SNU2]TCLCODSTR      # hcb 60614
   Actzo [M:SNU2]TCLCODEND      # hcb 60614
   Actzo [M:SNU2]BUYSTR         # hcb 60614
   Actzo [M:SNU2]BUYEND         # hcb 60614
   If dim([M:SNU2]TSICODSTR)>0  # hcb 60614
       Actzo [M:SNU2]TSICODSTR  # hcb 60614
       Actzo [M:SNU2]TSICODEND  # hcb 60614
   Endif                        # hcb 60614
   Actzo [M:SNU2]ITMSTA006      # hcb 61368

Endif

Affzo [M:SNU1]
Affzo [M:SNU2]
End

########################################
Subprog AP_CUNSSSMOD(VALEUR)
Variable Integer VALEUR

[M:SNU1]CUNSSSMOD = VALEUR

If VALEUR <> 2
   Raz   [M:SNU1]CUNNBRA
   Raz   [M:SNU1]CUNNBRB
   Raz   [M:SNU1]CUNNBRC
   Raz   [M:SNU1]CUNNBRD
   Grizo [M:SNU1]CUNNBRA
   Grizo [M:SNU1]CUNNBRB
   Grizo [M:SNU1]CUNNBRC
   Grizo [M:SNU1]CUNNBRD
Else
   Gosub CAL_COMPTAGE From SUBSNXA
   Actzo [M:SNU1]CUNNBRA
   Actzo [M:SNU1]CUNNBRB
   Actzo [M:SNU1]CUNNBRC
   Actzo [M:SNU1]CUNNBRD

Endif
Affzo [M:SNU1]

End

########################################
Subprog IB_NBLIG
Gosub SET_NOL From STKINV

# Déblocage
GBOUT1 = mess(425,199,1)
# Comptage liste
GBOUT2= mess(453,199,1)

If  [M:SNU3]CUNLOKFLG(NOL)  = 1
    GBOUT1 = ""
Endif
End

########################################
Subprog B1_NBLIG
Gosub SET_NOL From STKINV
# test pour contrer le retour d un deblocage , en effet suite à un déblocage on ne repasse pas par ib_nblig
If  [M:SNU3]CUNLOKFLG(NOL)  = 1
    mkstat = 2
    End
Endif

Local Char LFILTRE(250)
Local Char CRITER1(250)(3)
Local Char LCUL
Local Decimal LG
LG = NOL
CRITER1 = "1=1"

LFILTRE = "[F:CUD]STOFCY=[M:SNU0]STOFCY & [F:CUD]CUNSSSNUM=[M:SNU0]CUNSSSNUM & [F:CUD]CUNLISNUM=[M:SNU3]CUNLISNUM(LG)& [F:CUD]CUNLOKFLG=2"
Call TRT_DEBLOCAGE(LFILTRE,CRITER1,LG,LCUL) From STKINV

If LCUL <> ""
   If LCUL = "O"
     [M:SNU3]CUNLOKFLG(NOL) = 1
   Else
     [M:SNU3]CUNLOKFLG(NOL) = 3
   Endif
   Affzo [M:SNU3]CUNLOKFLG(NOL)
Endif


End

Subprog B2_NBLIG
Gosub SET_NOL From STKINV
Call OBJET("SNL",[M:SNU3]CUNLISNUM(NOL),[M:SNU0]CUNSSSNUM) From GOBJET

If [F:CUN]CUNSSSNUM <> [M:SNU0]CUNSSSNUM
   Read [CUN]CUN0=[M:SNU0]CUNSSSNUM
   If fstat
      Raz [F:CUN]
   Endif
Endif

[M:SNU0]CUNSSSSTA = [F:CUN]CUNSSSSTA
Affzo  [M:SNU0]CUNSSSSTA
If [F:CUN]CUNSSSSTA > 1
   Call  LOAD_SNU3 From SUBSNXA
Endif

End

Subprog AV_MAXLIGCAL(VALEUR)
Variable Decimal VALEUR
VALEUR  = [M:SNU1]MAXLIG
If [M:SNU1]PRCLIG <> 0
    VALEUR =     ([M:SNU1]MAXLIG *  [M:SNU1]PRCLIG)/100
    If VALEUR < 1                      # hcb 89457
       VALEUR = 1
    Endif
Endif

End


Subprog AP_CUNLASFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2  & [M:SNU1]CUNLASFLG <> VALEUR  # hcb 83012
#   Raz   [M:SNU2]SELFOR          # hcb 60614
#   Raz   [M:SNU2]SELFOR0         # hcb 60614
   Raz   [M:SNU2]SELFOR1
   If dim([M:SNU2]SELFOR2) > 0   # hcb 78971
      Raz [M:SNU2]SELFOR2
   Endif
   If dim([M:SNU2]LOTSTR)>0
       Raz   [M:SNU2]LOTSTR
       Raz   [M:SNU2]LOTEND
   Endif
#   Raz   [M:SNU2]TCLCODSTR       # hcb 60614
#   Raz   [M:SNU2]TCLCODEND       # hcb 60614
#   Raz   [M:SNU2]BUYSTR          # hcb 60614
#   Raz   [M:SNU2]BUYEND          # hcb 60614
#  Grizo [M:SNU2]SELFOR           # hcb 60614
#  Grizo [M:SNU2]SELFOR0          # hcb 60614
   Grizo [M:SNU2]SELFOR1
   If dim([M:SNU2]SELFOR2) > 0   # hcb 78971
      Grizo [M:SNU2]SELFOR2
   Endif
   If dim([M:SNU2]LOTSTR)>0
       Grizo [M:SNU2]LOTSTR
       Grizo [M:SNU2]LOTEND
   Endif
#   Grizo [M:SNU2]TCLCODSTR       # hcb 60614
#   Grizo [M:SNU2]TCLCODEND       # hcb 60614
#   Grizo [M:SNU2]BUYSTR          # hcb 60614
#   Grizo [M:SNU2]BUYEND          # hcb 60614
#   If dim([M:SNU2]TSICODSTR)>0   # hcb 60614
#       Raz   [M:SNU2]TSICODSTR   # hcb 60614
#       Raz   [M:SNU2]TSICODEND   # hcb 60614
#       Grizo [M:SNU2]TSICODSTR   # hcb 60614
#       Grizo [M:SNU2]TSICODEND   # hcb 60614
#  Endif                          # hcb 60614
   If dim([M:SNU2]LOCTYPSTR)>0
       Raz   [M:SNU2]LOCTYPSTR
       Raz   [M:SNU2]LOCTYPEND
       Raz   [M:SNU2]LOCSTR
       Raz   [M:SNU2]LOCEND
   Endif
   If dim([M:SNU2]BPRNUMSTR)>0
       Raz   [M:SNU2]BPRNUMSTR
       Raz   [M:SNU2]BPRNUMEND
   Endif
   If dim([M:SNU2]LOCTYPSTR)>0
       Grizo [M:SNU2]LOCTYPSTR
       Grizo [M:SNU2]LOCTYPEND
       Grizo [M:SNU2]LOCSTR
       Grizo [M:SNU2]LOCEND
   Endif
   If dim([M:SNU2]BPRNUMSTR)>0
       Grizo [M:SNU2]BPRNUMSTR
       Grizo [M:SNU2]BPRNUMEND
   Endif
# hcb 60855 deb
   If dim([M:SNU1]CUNITMWRH) > 0
      If [M:SNU1]CUNITMWRH = 2
         Actzo [M:SNU2]SELFOR3
         Actzo [M:SNU2]WRHSTR
         Actzo [M:SNU2]WRHEND
      Else
         Raz   [M:SNU2]SELFOR3
         Raz   [M:SNU2]WRHSTR
         Raz   [M:SNU2]WRHEND
         Grizo [M:SNU2]SELFOR3
         Grizo [M:SNU2]WRHSTR
         Grizo [M:SNU2]WRHEND
      Endif
   Endif
# hcb 60855 fin
Else
  If [M:SNU1]CUNLASFLG <> VALEUR  # hcb 83012
   Actzo [M:SNU2]SELFOR
   Actzo [M:SNU2]SELFOR0
   Actzo [M:SNU2]SELFOR1
   If dim([M:SNU2]SELFOR2) > 0   # hcb 78971
      Actzo [M:SNU2]SELFOR2
   Endif
   If dim([M:SNU2]LOTSTR)>0
       Actzo [M:SNU2]LOTSTR
       Actzo [M:SNU2]LOTEND
   Endif
   Actzo [M:SNU2]TCLCODSTR
   Actzo [M:SNU2]TCLCODEND
   Actzo [M:SNU2]BUYSTR
   Actzo [M:SNU2]BUYEND
   If dim([M:SNU2]TSICODSTR)>0
       Actzo [M:SNU2]TSICODSTR
       Actzo [M:SNU2]TSICODEND
   Endif
   If dim([M:SNU2]LOCTYPSTR)>0
       Actzo [M:SNU2]LOCTYPSTR
       Actzo [M:SNU2]LOCTYPEND
       Actzo [M:SNU2]LOCSTR
       Actzo [M:SNU2]LOCEND
   Endif
   If dim([M:SNU2]BPRNUMSTR)>0
       Actzo [M:SNU2]BPRNUMSTR
       Actzo [M:SNU2]BPRNUMEND
   Endif
   If [M:SNU1]CUNSSSTYP = 2
      Grizo [M:SNU2]10                   # Articles
      Grizo [M:SNU2]15                   # Familles statistique
   Endif
   Actzo [M:SNU2]ITMSTA006          # hcb 61368
   If [M:SNU1]CUNSSSTYP= 1 & dim([M:SNU2]BPRNUMSTR)>0
      Grizo [M:SNU2]BPRNUMSTR             # tiers
      Grizo [M:SNU2]BPRNUMEND
   Endif
   If dim([M:SNU1]CUNITMWRH) > 0
      If GWRHGES <> 2
         Grizo [M:SNU1]CUNITMWRH    # hcb 70190
         Grizo [M:SNU2]SELFOR3      # hcb 70190
         Grizo [M:SNU2]WRHSTR       # hcb 70190
         Grizo [M:SNU2]WRHEND       # hcb 70190
      Else
         Actzo [M:SNU1]CUNITMWRH
         Actzo [M:SNU2]SELFOR3
         Actzo [M:SNU2]WRHSTR
         Actzo [M:SNU2]WRHEND
      Endif
   Endif
  Endif  # hcb 83012

Endif
Affzo [M:SNU2]

End

Subprog AM_WRHSTR(VALEUR)
Variable Char    VALEUR()
If [M]WRHEND = ""     : [M]WRHEND = VALEUR : Affzo [M]WRHEND : Endif
If [M]WRHEND < VALEUR : [M]WRHEND = VALEUR : Affzo [M]WRHEND : Endif
End

Subprog C_WRHEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]WRHSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End

Subprog AP_CUNITMWRH(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
   Raz   [M:SNU1]MULLISFLG            # Multi-listes
   Actzo [M:SNU1]MULLISFLG            # Multi-listes
   Actzo [M:SNU1]CUNLASFLG            # Global
   If [M:SNU1]CUNLASFLG =2            # Global
#                          hcb 70190 deb
      Raz   [M:SNU2]SELFOR3
      Raz   [M:SNU2]WRHSTR
      Raz   [M:SNU2]WRHEND
      Affzo [M:SNU2]SELFOR3
      Affzo [M:SNU2]WRHSTR
      Affzo [M:SNU2]WRHEND
#                          hcb 70190 fin

      Diszo [M:SNU2]SELFOR3
      Diszo [M:SNU2]WRHSTR
      Diszo [M:SNU2]WRHEND
   Else
      Actzo [M:SNU2]SELFOR3
      Actzo [M:SNU2]WRHSTR
      Actzo [M:SNU2]WRHEND
   Endif
   [M:SNU2]NUMSELFOR = 18
Else
   Raz   [M:SNU1]MULLISFLG            # Multi-listes
   Grizo [M:SNU1]MULLISFLG            # Multi-listes
   Actzo [M:SNU2]SELFOR3
   Actzo [M:SNU2]WRHSTR
   Actzo [M:SNU2]WRHEND
   [M:SNU2]NUMSELFOR = 42
Endif
End

