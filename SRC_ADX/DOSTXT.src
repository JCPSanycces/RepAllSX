#<AdxTL>@(#)187.0.0.0 $Revision$
########################################################
## DOSTXT   Gestion des textes
########################################################
$DICTXT
Call ECR_TRACE(mess(44,125,1),0) From GESECRAN
# Mise à jour des textes
# Mise en conformité avec le dossier mère pour les développements à 3 niveaux
If GINFO
    Call AFF_VLC(mess(44,125,1),"") From GESECRAN
Endif
# Pas de copie des textes >50000 dans les dossiers d'indus ni dans les dossiers de développement Adonix
If filinfo(filpath("","sophia_gaillard","",GDOSX3),0)<=0
    Call MAJTXT([F:ADS]DOSSIER,[F:ADS]DOSREF,[F:ADS]LAN(0)) From DOSMAJTXT
Endif
Local File =GDOSREF+".ATEXTE" [ATX] , =[F:ADS]DOSSIER+".ATEXTE" [DATX]
Local File =GDOSX3+".TABLAN" [TLA]

Local Integer LANCUR , OKLAN , VERCUR
Local Char    LANGUE(GLONLAN) , TXCRIT(250)
Local Integer SPEI , SPENB
Local Char    SPECLE(10)(1..3000)
Local Char    SPETXT(123)(1..3000)
OKLAN = 0
For LANCUR=0 To [F:ADS]NBRLAN-1
    LANGUE = [F:ADS]LAN(LANCUR)
    Read [TLA]TLA0 = LANGUE
    If !fstat & [F:TLA]LANSTD=2 : # On respecte les langues spécifiques
          Gosub COPTXT
    Endif
    If [F:ADS]LAN(LANCUR)=GLANDEF : OKLAN = 1 : Endif
Next LANCUR
If !OKLAN
    LANGUE = GLANDEF : Gosub COPTXT
Endif
# end of the copy
Call ECR_TRACE(mess (124,100,1)+": "+mess(44,125,1),0) From GESECRAN
Close Local File [ATX] , [DATX] , [TLA]
Return

$COPTXT
If GINFO
     Call AFF_VLC(mess(44,125,1)-LANGUE,"") From GESECRAN
Endif
SPENB = 0
If filinfo(filpath("FIL","AVOCAB","fde",[F:ADS]DOSSIER),0)>=0
  If clalev([F:AVO])=0 : Local File =[F:ADS]DOSSIER+".AVOCAB" [AVO] : Endif
  Read [AVO]AVO0(1) = LANGUE
  If !fstat & dim([F:AVO]CUR)>0 & [F:AVO]CUR<>0
      VERCUR = [F:AVO]CUR
      For [AVO]AVO0 Where LAN=LANGUE & TYP=1 & VER=VERCUR
          SPENB += 1
          SPECLE(SPENB) = num$([F:AVO]NUM)
          SPETXT(SPENB) = [F:AVO]TXT
          If SPENB>=dim(SPECLE) : Break : Endif
      Next AVO
  Endif
Endif
#
Trbegin [DATX]
 K = 0
 TXCRIT = 'LAN = "'+LANGUE+'" & NUMERO>=0' : # Il faut copier tous les textes, même si > 50000
 If filinfo(filpath("","sophia_gaillard","",GDOSX3),0)>0
    #115210/6
    TXCRIT -= '& (NUMERO<'+num$(GMAXTXTSTD)-'| NUMERO>'+num$(GNEWTXTSTD)+')': # Sauf si l'APPLICATION X3 EST L'appli d'INDUS
 Endif
 For [ATX]NUMERO Where evalue(TXCRIT)
    Read [DATX]NUMERO = [F:ATX]LAN;[F:ATX]NUMERO
    If fstat
      Raz [F:DATX]
      [F:DATX] = [F:ATX]
      [F:DATX]UPDDAT = date$
      #115210/6
      If [F:ATX]NUMERO<GMAXTXTSTD | [F:ATX]NUMERO>GNEWTXTSTD: # ce sont les nôtres
        If !find([F:ATX]NUMERO,GMAJTXTSTD)
          If GNBRTXTSTD<dim(GMAJTXTSTD)
            GNBRTXTSTD += 1
            GMAJTXTSTD(GNBRTXTSTD) = [F:ATX]NUMERO
          Else
            GDERTXTSTD = [F:ATX]NUMERO
          Endif
        Endif
      Else
        If !find([F:ATX]NUMERO,GMAJTXTSPE)
           If GNBRTXTSPE<dim(GMAJTXTSPE)
              GNBRTXTSPE += 1
              GMAJTXTSPE(GNBRTXTSPE) = [F:ATX]NUMERO
           Else
              GDERTXTSPE = [F:ATX]NUMERO
           Endif
        Endif
      Endif
      Gosub SPETXT
      Write [DATX]
      If fstat
          # jira 69361 more detail in log
          Call LOG_ERROR_DETAILS(1, "DATX",[F:ATX]LAN+"~"+num$([F:ATX]NUMERO),"") From GLOCK
      Endif
    Elsif [F:ATX]TEXTE<>[F:DATX]TEXTE or [F:ATX]COMMENT<>[F:DATX]COMMENT
      [F:DATX] = [F:ATX]
      [F:DATX]UPDDAT = date$
      #115210/6
      If [F:ATX]NUMERO<GMAXTXTSTD | [F:ATX]NUMERO>GNEWTXTSTD
        If !find([F:ATX]NUMERO,GMAJTXTSTD)
          If GNBRTXTSTD<dim(GMAJTXTSTD)
            GNBRTXTSTD += 1
            GMAJTXTSTD(GNBRTXTSTD) = [F:ATX]NUMERO
          Else
            GDERTXTSTD = [F:ATX]NUMERO
          Endif
        Endif
      Else
        If !find([F:ATX]NUMERO,GMAJTXTSPE)
          If GNBRTXTSPE<dim(GMAJTXTSPE)
            GNBRTXTSPE += 1
            GMAJTXTSPE(GNBRTXTSPE) = [F:ATX]NUMERO
          Else
            GDERTXTSPE = [F:ATX]NUMERO
          Endif
        Endif
      Endif
      Gosub SPETXT
      Rewrite [DATX]
      If fstat
            # jira 69361 more detail in log
            Call LOG_ERROR_DETAILS(2,"DATX",[F:ATX]LAN+"~"+num$([F:ATX]NUMERO),"") From GLOCK
      Endif
    Endif
    K += 1
    If mod(K,100)=0
      If GINFO
          Call AFF_VLC(mess(44,125,1)-LANGUE,num$([F:ATX]NUMERO)) From GESECRAN
      Endif
    Endif
 Next
# Textes virés (standard)
#115210/6
 For [DATX]NUMERO Where LAN=LANGUE & (NUMERO<GMAXTXTSTD | NUMERO>GNEWTXTSTD)
    Read [ATX]NUMERO = [F:DATX]LAN;[F:DATX]NUMERO
    If fstat
          Delete [DATX]
    Endif
 Next
Commit
Return

$SPETXT
SPEI = find(num$([F:DATX]NUMERO),SPECLE(1..SPENB))
If SPEI
    [F:DATX]TEXTE = SPETXT(SPEI)
Endif
Return

####################################################################
$DICAPL
Local Char    LANGUE(GLONLAN)
Local Integer DECAL , VERCUR , OKMEN
Call ECR_TRACE(mess(45,125,1),0) From GESECRAN
# Mise à jour des messages
Local File =GDOSREF+".APLSTD"         [AST]
Local File =GDOSREF+".AMENLOC"        [AML]
Local File =[F:ADS]DOSSIER+".APLSTD"  [DAST]
Local File =[F:ADS]DOSSIER+".AMENLOC" [DAML]
Local File =GDOSX3+".TABLAN"          [TLA]
Local File =GDOSX3+".AMENLOC"         [SAML]
OKLAN = 0
For LANCUR=0 To [F:ADS]NBRLAN-1
    LANGUE = [F:ADS]LAN(LANCUR)
    Read [TLA]TLA0 = LANGUE
    If !fstat & [F:TLA]LANSTD=2
          Gosub COPAPL
    Endif
    If LANGUE=GLANDEF : OKLAN = 1 : Endif
Next LANCUR
If !OKLAN
 LANGUE = GLANDEF : Gosub COPAPL
Endif
# Suppression des menus inexistants dans le dossier de référence
For [DAML]
     K = ([F:DAML]MENLOC<>0 & [F:DAML]MENLOC<>200)
     # Spécifique
     K *= !([F:DAML]MENLOC>=160 & [F:DAML]MENLOC<=164)
     K *= !([F:DAML]MENLOC>=6000 & [F:DAML]MENLOC<=6999)
     # Vertical
     K *= !([F:DAML]MENLOC>=165 & [F:DAML]MENLOC<=169)
     K *= !([F:DAML]MENLOC>=1000 & [F:DAML]MENLOC<=1999)
     K *= !([F:DAML]MENLOC>=5000 & [F:DAML]MENLOC<=5999)
     # Filiales
     K *= !([F:DAML]MENLOC>=8000 & [F:DAML]MENLOC<=8599)
     K *= !([F:DAML]MENLOC>=8890 & [F:DAML]MENLOC<=8949)
     #103099 ADDONV7ML/ new number convention
     # Filiales
     K *= !([F:DAML]MENLOC>=13000 & [F:DAML]MENLOC<=13259)
     K *= !([F:DAML]MENLOC>=13300 & [F:DAML]MENLOC<=13499)
     #
     If K & !find([F:DAML]CODACT,GSPE(1..GNBSPE))
         #Read [SAML]MENLOC=[F:DAML]MENLOC
         Read [AML]MENLOC=[F:DAML]MENLOC
         If fstat
              Gosub ANNULE
         Elsif [F:AML]AUZMOD<>2
              Gosub ANULIG
         Endif
     Endif
Next
# end of the copie
Call ECR_TRACE(mess (124,100,1)+": "+mess(45,125,1),0) From GESECRAN
Close Local File [AST] , [AML] , [DAST] , [DAML] , [TLA] , [SAML]
Return

$ANNULE
Call ECR_TRACE(mess(189,125,1)-num$([F:DAML]MENLOC),0) From GESECRAN : # Suppression du chapitre
Trbegin [DAST]
    Delete [DAST] Where LANCHP=[F:DAML]MENLOC
    If fstat
          # jira 69361 more detail in log
          Call LOG_ERROR_DETAILS(3, "DAST",num$([F:DAML]MENLOC),"") From GLOCK
    Else
          Delete [DAML] Curr
          If fstat
              # jira 69361 more detail in log
              Call LOG_ERROR_DETAILS(3, "DAML",num$([F:DAML]MENLOC),"") From GLOCK
          Endif
    Endif
Commit
Return

$ANULIG
Trbegin [DAST]
  For [DAST] Where LANCHP=[F:DAML]MENLOC
      Look [AST]CLE=[F:DAST]LANCHP;[F:DAST]LANNUM;"FRA"
      If fstat
          # Suppression du menu
          Call ECR_TRACE(mess(190,125,1)-'"'+[F:DAST]LAN+'"'-"mess("+num$([F:DAST]LANNUM)+","+num$([F:DAML]MENLOC)+",1)",0) From GESECRAN
          Delete [DAST] Curr
          If fstat
              # jira 69361 more detail in log
              Call LOG_ERROR_DETAILS(3, "DAST",num$([F:DAML]MENLOC)+"~0~"+[F:DAST]LAN,"") From GLOCK
          Endif
      Endif
  Next
Commit
Return

$COPAPL
If GINFO
   Call AFF_VLC(mess(45,125,1)-LANGUE,"") From GESECRAN
Endif
SPENB = 0
If filinfo(filpath("FIL","AVOCAB","fde",[F:ADS]DOSSIER),0)>=0
    If clalev([F:AVO])=0 : Local File =[F:ADS]DOSSIER+".AVOCAB" [AVO] : Endif
    Read [AVO]AVO0(1) = LANGUE
    If !fstat & dim([F:AVO]CUR)>0 & [F:AVO]CUR<>0
        VERCUR = [F:AVO]CUR
        For [AVO]AVO0 Where LAN=LANGUE & TYP=2 & VER=VERCUR
            SPENB += 1
            SPECLE(SPENB) = num$([F:AVO]CHP)-num$([F:AVO]NUM)
            SPETXT(SPENB) = [F:AVO]TXT
            If SPENB>=dim(SPECLE) : Break : Endif
        Next
    Endif
Endif
For [AST]CLE(1) Where LAN=LANGUE
  If GINFO
       Call AFF_VLC(mess(45,125,1)-LANGUE,num$([F:AST]LANCHP)) From GESECRAN
  Endif
  Read [AML]MENLOC = [F:AST]LANCHP
  If fstat = 0
    If [F:AST]LANCHP=0
        Gosub CHAP0
    Elsif [F:AST]LANCHP=200
        Gosub CHAP200
        # On réserve la plage 160..164 pour les spécifiques de 3ème niveau
    Elsif [F:AST]LANCHP>=160 & [F:AST]LANCHP<=164
      # Pas de copie
      # On réserve la plage 165..169 pour les spécifiques de 2ème niveau
    Elsif [F:AST]LANCHP>=165 & [F:AST]LANCHP<=169
        If GDOSREF<>GDOSX3
             Gosub COPIE
        Endif
    Else
        Read [DAML]MENLOC = [F:AST]LANCHP
        If !fstat & !find([F:DAML]CODACT,GSPE(1..GNBSPE))
            Gosub MODIF
        Endif
        Filter [DAST] Where LAN=LANGUE
        Read [DAST]CLE(1) = [F:AST]LANCHP
        Filter [DAST]
        If fstat or (!find([F:DAML]CODACT,GSPE(1..GNBSPE)) & ([F:AML]AUZMOD<>2 or (GADONIX=2 & pat([F:ADS]DOSSIER,"*REF*"))))
              Gosub COPIE
        Endif
    Endif
  Endif
Next
Return

$MODIF
Trbegin [DAML]

 Read [AML]MENLOC = [F:AST]LANCHP
 If !fstat
    Readlock [DAML]MENLOC = [F:AST]LANCHP
    If fstat<=1 & [F:DAML]MODULE<>[F:AML]MODULE
       If fstat=1
            # jira 69361 more detail in log
            Call LOG_ERROR_DETAILS(4, "DAML",num$([F:AST]LANCHP),"") From GLOCK
       Else
           [F:DAML]MODULE = [F:AML]MODULE
           Rewrite [DAML]
           If fstat
                # jira 69361 more detail in log
                Call LOG_ERROR_DETAILS(2, "DAML",num$([F:AST]LANCHP),"") From GLOCK
           Endif
       Endif
    Endif
 Endif

Commit
Return

$COPIE
Trbegin [DAST]

 Delete [DAST] Where LAN=LANGUE & LANCHP=[F:AST]LANCHP
 If fstat=1
      # jira 69361 more detail in log
      Call LOG_ERROR_DETAILS(3, "DAST",num$([F:AST]LANCHP)+"~0~"+LANGUE,"") From GLOCK
 Endif
 For [AST]CLE
      [F:DAST] = [F:AST]
      Gosub SPEAPL
      Write [DAST]
      If fstat
          # jira 69361 more detail in log
           Call LOG_ERROR_DETAILS(1, "DAST",num$([F:DAST]LANCHP)+"~"+num$([F:DAST]LANNUM)+"~"+[F:DAST]LAN,"") From GLOCK
      Endif
 Next
 Read [AML]MENLOC = [F:AST]LANCHP
 If !fstat
    Read [DAML]MENLOC = [F:AST]LANCHP
    If fstat
        [F:DAML] = [F:AML]
        Write [DAML]
        If fstat
             # jira 69361 more detail in log
             Call LOG_ERROR_DETAILS(1, "DAML",num$([F:AST]LANCHP),"") From GLOCK
        Endif
    Else
          [F:DAML] = [F:AML]
          Rewrite [DAML]
          If fstat
             # jira 69361 more detail in log
             Call LOG_ERROR_DETAILS(2, "DAML",num$([F:AST]LANCHP),"") From GLOCK
          Endif
    Endif
 Endif
Commit
Return

$CHAP0
DECAL = 0
Goto CHAP_TIT

$CHAP200
DECAL = 200
Goto CHAP_TIT

$CHAP_TIT
Trbegin [DAST]
 For [AST]CLE
    Read [DAML]MENLOC = DECAL+[F:AST]LANNUM
    # mb 9.12.14 bug 104549
    If !fstat : OKMEN = 1 : Else : OKMEN = 0 : Endif
    If !OKMEN or !find([F:DAML]CODACT,GSPE(1..GNBSPE))
          Read [DAST]CLE = [F:AST]LANCHP;[F:AST]LANNUM;[F:AST]LAN
          If fstat or !OKMEN or (OKMEN & [F:DAML]AUZMOD<>2) or (GADONIX=2 & pat([F:ADS]DOSSIER,"*REF*"))
                  If fstat
                        [F:DAST] = [F:AST]
                        Gosub SPEAPL
                        Write [DAST]
                        If fstat
                              # jira 69361 more detail in log
                              Call LOG_ERROR_DETAILS(1, "DAST",num$([F:DAST]LANCHP)+"~"+num$([F:DAST]LANNUM)+"~"+[F:DAST]LAN,"") From GLOCK
                       Endif
                  Else
                        [F:DAST] = [F:AST]
                        Gosub SPEAPL
                        # if message is identical no need to rewrite
                        If [F:DAST]LANMES <> [F:AST]LANMES
                          Rewrite [DAST]
                          If fstat
                              # jira 69361 more detail in log
                              Call LOG_ERROR_DETAILS(2, "DAST",num$([F:DAST]LANCHP)+"~"+num$([F:DAST]LANNUM)+"~"+[F:DAST]LAN,"") From GLOCK
                          Endif
                        Endif
                  Endif
          Endif
    Endif
 Next
Commit
Return

$SPEAPL
SPEI = find(num$([F:DAST]LANCHP)-num$([F:DAST]LANNUM),SPECLE(1..SPENB))
If SPEI
     [F:DAST]LANMES = SPETXT(SPEI)
Endif
Return

