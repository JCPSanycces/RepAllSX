#<AdxTL>@(#)0.0.0.0 $Revision$
#------------------------------------------------------------------------------------------------------
#            Script containing calls for handling an order line scheduling invoice
#------------------------------------------------------------------------------------------------------

#------------------------------------------------------------------------------------------------------
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
$AM_ORDDAT_UPDATE_INVCNDDAT
Local Integer IJCPO, MY_STATUS,WCPO_SAVENOLIGN,WSIGMA,WTEMPSIGMA,WRET

  For IJCPO=0 To [M:SOH4]NBLIG-1
    If [M:SOH4]DINVCND(IJCPO)<>""

      WCPO_SAVENOLIGN=nolign
      nolign=IJCPO+1
      Gosub UPDATE_VCRINVCND_FROM_CURR_LINE From LIBSAL_INVCND_SOH
      nolign=WCPO_SAVENOLIGN
      If GERR=1 : Break : Endif
      #--Does the schedule invoice have ohter lines than 'To be invoiced' ?
      WTEMPSIGMA = sigma(1,maxtab(GSOHVCRINVCND_UPD(IJCPO).VCRINVCNDLIN),
&        ( GSOHVCRINVCND_UPD(IJCPO).VCRINVCNDLIN(indcum)<>null and
&          GSOHVCRINVCND_UPD(IJCPO).VCRINVCNDLIN(indcum).INVCNDSTA>1 and find(GSOHVCRINVCND_UPD(IJCPO).VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)
&       &( WSIGMA=0 and sigma(WSIGMA=1,1,1)))
      #--If 'No', we can proceed
      If WTEMPSIGMA=0
        MY_STATUS = fmet GSOHVCRINVCND_UPD(IJCPO).CHANGE_SCHEDULING_DATE([M:SOH3]VCRINVCNDDAT)
        If (MY_STATUS > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
          # Error management
          GMESSAGE  = mess(3,61,1)-num$(IJCPO+1)-mess(162,154,1)-[M:SOH4]ITMREF(IJCPO)-mess(483,192,1)-[M:SOH4]DINVCND(IJCPO)-":"
          Local Char WMESSAGE(255)
          MY_STATUS = func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSOHVCRINVCND_UPD(IJCPO), [V]CST_ALL, [V]CST_AYES, WMESSAGE)
          GMESSAGE += WMESSAGE
          If MY_STATUS>=[V]CST_AERROR
            GERR=1 : Break
          Else
            GERR = 2
          Endif
        Endif
        [M:SOH4]DINVCNDTOUPD(IJCPO)=[V]CST_AYES #CPO 18/01/2016 Optimisation
      Endif
    Endif
  Next

Return
# End issue 107888
#------------------------------------------------------------------------------------------------------
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
$P1_NBLIG_DINVCND_UPD
Local Integer WRET

  #--Changing the quantity or doing a price search, the invoice schedule has to be updated
  If [M:SOH4]DINVCND(NOL)<>"" and [M:SOH4]DINVCNDTOUPD(NOL)=[V]CST_AYES
&    and ([M:SOH4]CREFLG(NOL)<>0 or ([M:SOH4]CREFLG(NOL)=0 and GSOHVCRINVCND_UPD(NOL)<>null)) #CPO 20/01/2015
    If [M:SOH4]DINVCNDTODIS(NOL)<>[V]CST_ANO
      Local Integer WOK
      WOK = 2 #WOK=1 : If GIMPORT : WOK=2 : Endif
      If not(dim(IS_RECALC_GROUP)>0 and IS_RECALC_GROUP=[V]CST_AYES)
&    and not(dim(IS_FROM_MODBOM) >0 and IS_FROM_MODBOM =[V]CST_AYES) # Issue 107888 - 2016-09-09 by CPO : US155 Kit & flexible kit scheduled invoices
        Call OUINON(mess(481,192,1),WOK) From GESECRAN
      Endif
      If WOK=2
        Local Integer WCPO_SAVENOLIGN : WCPO_SAVENOLIGN=nolign
        nolign=NOL+1
        Gosub UPDATE_VCRINVCND_FROM_CURR_LINE From LIBSAL_INVCND_SOH
        nolign=WCPO_SAVENOLIGN
        If GERR=1 : mkstat=2 : Return : Endif
        WOK=2 #WOK=1 : If GIMPORT : WOK=2 : Endif
        If not(dim(IS_RECALC_GROUP)>0 and IS_RECALC_GROUP=[V]CST_AYES)
          # Issue 107888 - 2016-09-09 by CPO : US155 Kit & flexible kit scheduled invoices
          If not(dim(IS_FROM_MODBOM)>0  and IS_FROM_MODBOM =[V]CST_AYES)
&            or (dim(IS_FROM_MODBOM)>0  and IS_FROM_MODBOM_SET_SAME_ANSWER = 0)
          # End issue 107888 US155
            Call OUINON(mess(482,192,1),WOK) From GESECRAN
          # Issue 107888 - 2016-09-09 by CPO : US155 Kit & flexible kit scheduled invoices
            If dim(IS_FROM_MODBOM)>0
              IS_FROM_MODBOM_SET_SAME_ANSWER = WOK
            Endif
          Elsif dim(IS_FROM_MODBOM)>0
            WOK=IS_FROM_MODBOM_SET_SAME_ANSWER
          Endif
          # End issue 107888 US155
        Endif
        If WOK=2
          WRET = fmet GSOHVCRINVCND_UPD(NOL).DISPATCH_ON_ALL_LINES()
        Else
          WRET = fmet GSOHVCRINVCND_UPD(NOL).DISPATCH_ON_LASTLINE()
        Endif
        If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
          # Error management
          WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSOHVCRINVCND_UPD(NOL), [V]CST_ALL, [V]CST_AYES, GMESSAGE)
          If WRET>=[V]CST_AERROR
            GERR=1 : mkstat = 2
          Else
            GERR = 2
          Endif
        Endif
      Else
        #[M:SOH4]DINVCNDTOUPD(NOL)=[V]CST_ANO #CPO 18/01/2016 Optimisation
        If !GWEBSERV
         Local Decimal BASPAG
         ## Action SAISVIC
         Local Char    PARMSK(250)(1..20) , SAVACT(20)
         SAVACT = GACTION : GACTION = "SAISVIC"
         PARMSK(1) = "SOH4"
         PARMSK(2) = num$(nolign)
         PARMSK(3) = "10"
         PARMSK(4) = [M:SOH0]SOHNUM
         PARMSK(5) = num$([M:SOH4]SOPLIN(nolign-1))
         PARMSK(6) = num$([M:SOH4]SOPLIN(nolign-1))
         PARMSK(7) = "C_SVCRINVCND"
         PARMSK(8) = "GSOHVCRINVCND"
         Call TRAITE_NUM(BASPAG,PARMSK,"ISVIC","TRTSAISVIC","",1,"") From GTRAITE
         GACTION = SAVACT
        Endif
        If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
      Endif
      If mkstat>0 : Return : Endif
      #[M:SOH4]DINVCNDTOUPD(NOL)=[V]CST_ANO #CPO 18/01/2016 Optimisation
      #--While in "TRTSAISVIC", if the user does quit without saving, the DINVCNDTOUPD is left as it is
      #--Here, as the TRTSAISVIC is forced, the flag has to be set to AYES !
      #--(In case of user asked TRTSAISVIC action with cancelling, the flag has to remain to ANO)
      [M:SOH4]DINVCNDTOUPD(NOL)=[V]CST_AYES #CPO 18/01/2016 Optimisation
      [M:SOH4]DINVCNDTODIS(NOL)=[V]CST_ANO  #CPO 18/01/2016 Thus, we only do it once after an order line modification
    Endif
  Endif

Return
# End issue 107888
#------------------------------------------------------------------------------------------------------
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
$P1_NBLIG_DINVCND_INS

  If [M:SOH4]DINVCND(NOL)<>""
    #--In order to trigger the creation in VALLIG
    #[M:SOH4]DINVCNDTOUPD(NOL)=[V]CST_AYES
  Endif

Return
# End issue 107888
#------------------------------------------------------------------------------------------------------
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
$AVANT_NBLIG_DINVCND_DEL

  #--1. Calling the Dela on the GSOHVCRINVCND_UPD array list of instances
  #--Freeing the instance
  If dim(GSOHVCRINVCND_UPD)>0 and GSOHVCRINVCND_UPD(NOL)<>null
    FreeGroup GSOHVCRINVCND_UPD(NOL)
    GSOHVCRINVCND_UPD(NOL)=null
  Endif
  #--Re-ordering the indexes (to keep the bijection nolign-1 => GSOHVCRINVCND_UPD(noling-1)
  If NOL<=maxtab(GSOHVCRINVCND_UPD)
    Dela NOL, 1 , maxtab(GSOHVCRINVCND_UPD) GSOHVCRINVCND_UPD
  Endif

Return
# End issue 107888
#------------------------------------------------------------------------------------------------------
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
#CPO 18/01/2016
$AVANT_NBLIG_DINVCND_INS

  #--Re-ordering the indexes (to keep the bijection nolign-1 => GSOHVCRINVCND_UPD(noling-1)
  If NOL<=maxtab(GSOHVCRINVCND_UPD)
    Insa NOL, 1 , maxtab(GSOHVCRINVCND_UPD) GSOHVCRINVCND_UPD
  Endif

Return
# End issue 107888
#########################################################################
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
#**
#* Label CREATE_VCRINVCND_FROM_CURR_LINE is used to instantiate and load an instance of C_SVCRINVCND class with [M:SOH4] current line (given by noling-1)
#* If the instance is not null, it'll freegroup the actual instance index and then do a newinstance
#* It'll load the actual nolign index of GSVCRINVCND() dimensioned instance variable with [M:SOHx] values
#* and then calls the C_SVCRINVCND class's method CREATE_DETAIL_SCHEDINV that will created the scheduling invoice lines according to order line's invoice condition if any
#* It return GERR=1 if an error occurs
#* @param nolign-1 the current order line in the [M:SOH4] mask
#* @param GSOHVCRINVCND_UPD a collection of C_SVCRINVCND instances (indexed on [M:SOH4] nolign values)
#*
#*!
$CREATE_VCRINVCND_FROM_CURR_LINE

  #--No need to go further if no invoicing condition
  If nolign<1 or [M:SOH4]DINVCND(nolign-1)="" : Return : Endif

  Local Integer MY_STATUS,NOLCPO,WRET
  NOLCPO = nolign-1

  #--Newly inserted line => we start from scratch
  If dim(GSOHVCRINVCND_UPD)>0 and GSOHVCRINVCND_UPD(NOLCPO)<>null
    FreeGroup GSOHVCRINVCND_UPD(NOLCPO)
    GSOHVCRINVCND_UPD(NOLCPO)=null
  Endif

  GSOHVCRINVCND_UPD(NOLCPO) = NewInstance C_SVCRINVCND AllocGroup null

  # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
  #--Mandatory to call in order to have the context ACTX set before the first snapshot
  MY_STATUS = fmet GSOHVCRINVCND_UPD(NOLCPO).AINIT()
  If (MY_STATUS > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
    # Error management
    MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSOHVCRINVCND_UPD(NOLCPO), [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If MY_STATUS>=[V]CST_AERROR
      GERR=1
    Else
      GERR=2
    Endif
  Endif
  If GERR=1 : Return : Endif
  # End issue X3-38457

  #--1.Init header properties from current order
  MY_STATUS = func LIBSAL_INVCND_SOH.INIT_SVCRINVCND_FROM_ORDER_M(NOLCPO,GSOHVCRINVCND_UPD(NOLCPO))
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    GMESSAGE  = mess(3,61,1)-num$(NOLCPO+1)-mess(162,154,1)-[M:SOH4]ITMREF(NOLCPO)-mess(483,192,1)-[M:SOH4]DINVCND(NOLCPO)-":"
    Local Char WMESSAGE(255)
    WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSOHVCRINVCND_UPD(NOLCPO), [V]CST_ALL, [V]CST_AYES, WMESSAGE)
    GMESSAGE += WMESSAGE
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GERR = 1 : Return
    Else
      GERR = 2
    Endif
    #FreeGroup GSOHVCRINVCND_UPD(NOLCPO) #=> The user has to be able to modify the record if needed
    #GSOHVCRINVCND_UPD(NOLCPO)=null
    #Return
  Endif

  #--2. Generating the invoice scheduling lines
  MY_STATUS = fmet GSOHVCRINVCND_UPD(NOLCPO).CREATE_DETAIL_SCHEDINV()
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    GMESSAGE  = mess(3,61,1)-num$(NOLCPO+1)-mess(162,154,1)-[M:SOH4]ITMREF(NOLCPO)-mess(483,192,1)-[M:SOH4]DINVCND(NOLCPO)-":"
    Local Char WMESSAGE(255)
    MY_STATUS = func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSOHVCRINVCND_UPD(NOLCPO), [V]CST_ALL, [V]CST_AYES, WMESSAGE)
    GMESSAGE += WMESSAGE
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GERR = 1 : Return
    Else
      GERR = 2
    Endif
    #FreeGroup GSOHVCRINVCND_UPD(NOLCPO) #=> The user has to be able to modify the record if needed
    #GSOHVCRINVCND_UPD(NOLCPO)=null
    #Return
  Endif

Return
# End issue 107888
#-----------------------------------------------------------------------------------
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
#**
#* Label UPDATE_VCRINVCND_FROM_CURR_LINE is used to instantiate (if needed) and load an instance of C_SVCRINVCND class with [M:SOH4] current line (given by noling-1)
#* If the instance is not null, it'll load the actual nolign index of GSVCRINVCND() dimensioned instance variable with [M:SOHx] values and also, in case of no scheduling invoice lines,
#* it'll perform a call to C_SVCRINVCND class's method CREATE_DETAIL_SCHEDINV
#* If the instance is null, and according to the order's line status (new one, existing one etc), it'll do a call to AREAD method if the schedule already exist, if not it'll perform like a new
#* creation
#* It return GERR=1 if an error occurs
#* @param nolign-1 the current order line in the [M:SOH4] mask
#* @param GSOHVCRINVCND_UPD a collection of C_SVCRINVCND instances (indexed on [M:SOH4] nolign values)
#*
#*!
$UPDATE_VCRINVCND_FROM_CURR_LINE

  #--No need to go further if no invoicing condition
  If nolign<1 or [M:SOH4]DINVCND(nolign-1)="" : Return : Endif

  If clalev([SVIC])=0 : Local File SVCRINVCND [SVIC] : Endif

  Local Integer MY_STATUS,NOLCPO,TO_GENERATE,WRET
  NOLCPO = nolign-1

  If [M:SOH4]DINVCND(NOLCPO)<>""
    If GSOHVCRINVCND_UPD(NOLCPO)=null
      #--If <null> means that the user did not accessed the schedule throught the right clic
      GSOHVCRINVCND_UPD(NOLCPO) = NewInstance C_SVCRINVCND AllocGroup null

      # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
      #--Mandatory to call in order to have the context ACTX set before the first snapshot
      MY_STATUS = fmet GSOHVCRINVCND_UPD(NOLCPO).AINIT()
      If (MY_STATUS > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
        # Error management
        MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSOHVCRINVCND_UPD(NOLCPO), [V]CST_ALL, [V]CST_AYES, GMESSAGE)
        If MY_STATUS>=[V]CST_AERROR
          GERR=1
        Else
          GERR=2
        Endif
      Endif
      If GERR=1 : Return : Endif
      # End issue X3-38457

      TO_GENERATE=[V]CST_AYES
      #--Was the order line modified ?
      If ([M:SOH4]CREFLG(NOLCPO)>0 or [M:SOH4]UPDFLG(NOLCPO)>0)and find(GREP,"C","D")=0
        #--Only during modification of existing order line
        #--Does the record exist ? => in case of previous created order but without invoice condition
        Look [SVIC]SVIC0=10;[M:SOH0]SOHNUM;[M:SOH4]SOPLIN(NOLCPO);[M:SOH4]SOPLIN(NOLCPO)
        If fstat=0
          MY_STATUS = fmet GSOHVCRINVCND_UPD(NOLCPO).AREAD(10,[M:SOH0]SOHNUM,[M:SOH4]SOPLIN(NOLCPO),[M:SOH4]SOPLIN(NOLCPO))
          If ([L]MY_STATUS > [V]CST_AOK)
            # Error management
            GMESSAGE  = mess(3,61,1)-num$(NOLCPO+1)-mess(162,154,1)-[M:SOH4]ITMREF(NOLCPO)-mess(483,192,1)-[M:SOH4]DINVCND(NOLCPO)-":"
            Local Char WMESSAGE(255)
            MY_STATUS = func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSOHVCRINVCND_UPD(NOLCPO), [V]CST_ALL, [V]CST_AYES, WMESSAGE)
            GMESSAGE += WMESSAGE
            If ([L]MY_STATUS >= [V]CST_AERROR)
              GERR = 1 : Return
            Else
              GERR = 2
            Endif
            #FreeGroup GSOHVCRINVCND_UPD(NOLCPO) #=> The user has to be able to modify the record if needed
            #GSOHVCRINVCND_UPD(NOLCPO)=null
            #Return
          Endif
          TO_GENERATE=[V]CST_ANO
        Endif
      Endif

      #--1.Init header properties from current order
      #--Doing this, will allow to have on the scheduling invoice header, the actual properties of the curent eventually modified order line
      #--Hence, the AUPDATE/ACREATE method on the instance will do the controls and detect an error if something changed
      MY_STATUS = func LIBSAL_INVCND_SOH.INIT_SVCRINVCND_FROM_ORDER_M(NOLCPO,GSOHVCRINVCND_UPD(NOLCPO))
      If ([L]MY_STATUS > [V]CST_AOK)
        # Error management
        GMESSAGE  = mess(3,61,1)-num$(NOLCPO+1)-mess(162,154,1)-[M:SOH4]ITMREF(NOLCPO)-mess(483,192,1)-[M:SOH4]DINVCND(NOLCPO)-":"
        Local Char WMESSAGE(255)
        MY_STATUS = func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSOHVCRINVCND_UPD(NOLCPO), [V]CST_ALL, [V]CST_AYES, WMESSAGE)
        GMESSAGE += WMESSAGE
        If ([L]MY_STATUS >= [V]CST_AERROR)
          GERR = 1 : Return
        Else
          GERR = 2
        Endif
        #FreeGroup GSOHVCRINVCND_UPD(NOLCPO) #=> The user has to be able to modify the record if needed
        #GSOHVCRINVCND_UPD(NOLCPO)=null
        #Return
      Endif

      #--If the invoice schedule code was changed on the order line, we have to re-create the schedule invoice detail
      If [M:SOH4]DINVCNDTODEL(NOLCPO)=[V]CST_AYES or find([M:SOH4]DINVCNDPREV(NOLCPO),"",GSOHVCRINVCND_UPD(NOLCPO).INVCND)=0
        TO_GENERATE=[V]CST_AYES
      Endif

      If [M:SOH4]CREFLG(NOLCPO)=0 or TO_GENERATE=[V]CST_AYES or
&        sigma(1,maxtab(GSOHVCRINVCND_UPD(NOLCPO).VCRINVCNDLIN),
&              GSOHVCRINVCND_UPD(NOLCPO).VCRINVCNDLIN(indcum)<>null and
&        (find(GSOHVCRINVCND_UPD(NOLCPO).VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))<1
        #--Only for new added order lines
        #--2. Generating the invoice scheduling lines
        MY_STATUS = fmet GSOHVCRINVCND_UPD(NOLCPO).CREATE_DETAIL_SCHEDINV()
        If ([L]MY_STATUS > [V]CST_AOK)
          # Error management
          GMESSAGE  = mess(3,61,1)-num$(NOLCPO+1)-mess(162,154,1)-[M:SOH4]ITMREF(NOLCPO)-mess(483,192,1)-[M:SOH4]DINVCND(NOLCPO)-":"
          Local Char WMESSAGE(255)
          MY_STATUS = func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSOHVCRINVCND_UPD(NOLCPO), [V]CST_ALL, [V]CST_AYES, WMESSAGE)
          GMESSAGE += WMESSAGE
          If ([L]MY_STATUS >= [V]CST_AERROR)
            GERR = 1 : Return
          Else
            GERR = 2
          Endif
          #FreeGroup GSOHVCRINVCND_UPD(NOLCPO) #=> The user has to be able to modify the record if needed
          #GSOHVCRINVCND_UPD(NOLCPO)=null
          #Return
        Endif
      Endif
    Else
      #--This case is harder to handle
      #--Taking new values
      #--In case of something changed, when calling the AUPDATE method, there will be errors raised if
      #--Header important properties were changed (especially those being dispatched on line level : qty/amt/ etc)
      #--Doing this, will allow to have on the scheduling invoice header, the actual properties of the curent eventually modified order line
      #--Hence, the AUPDATE/ACREATE method on the instance will do the controls and detect an error if something changed
      MY_STATUS = func LIBSAL_INVCND_SOH.INIT_SVCRINVCND_FROM_ORDER_M(NOLCPO,GSOHVCRINVCND_UPD(NOLCPO))
      If ([L]MY_STATUS > [V]CST_AOK)
        # Error management
        GMESSAGE  = mess(3,61,1)-num$(NOLCPO+1)-mess(162,154,1)-[M:SOH4]ITMREF(NOLCPO)-mess(483,192,1)-[M:SOH4]DINVCND(NOLCPO)-":"
        Local Char WMESSAGE(255)
        MY_STATUS = func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSOHVCRINVCND_UPD(NOLCPO), [V]CST_ALL, [V]CST_AYES, WMESSAGE)
        GMESSAGE += WMESSAGE
        If ([L]MY_STATUS >= [V]CST_AERROR)
          GERR = 1 : Return
        Else
          GERR = 2
        Endif
        #FreeGroup GSOHVCRINVCND_UPD(NOLCPO) #=> The user has to be able to modify the record if needed
        #GSOHVCRINVCND_UPD(NOLCPO)=null
        #Return
      Endif
      #--If not schedule lines, we have to generate schedule invoice lines
      If sigma(1,maxtab(GSOHVCRINVCND_UPD(NOLCPO).VCRINVCNDLIN),
&              GSOHVCRINVCND_UPD(NOLCPO).VCRINVCNDLIN(indcum)<>null and
&        (find(GSOHVCRINVCND_UPD(NOLCPO).VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))<1
        #--Only for new added order lines
        #--2. Generating the invoice scheduling lines
        MY_STATUS = fmet GSOHVCRINVCND_UPD(NOLCPO).CREATE_DETAIL_SCHEDINV()
        If ([L]MY_STATUS > [V]CST_AOK)
          # Error management
          GMESSAGE  = mess(3,61,1)-num$(NOLCPO+1)-mess(162,154,1)-[M:SOH4]ITMREF(NOLCPO)-mess(483,192,1)-[M:SOH4]DINVCND(NOLCPO)-":"
          Local Char WMESSAGE(255)
          MY_STATUS = func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSOHVCRINVCND_UPD(NOLCPO), [V]CST_ALL, [V]CST_AYES, WMESSAGE)
          GMESSAGE += WMESSAGE
          If ([L]MY_STATUS >= [V]CST_AERROR)
            GERR = 1 : Return
          Else
            GERR = 2
          Endif
          #FreeGroup GSOHVCRINVCND_UPD(NOLCPO) #=> The user has to be able to modify the record if needed
          #GSOHVCRINVCND_UPD(NOLCPO)=null
          #Return
        Endif
      Endif
      #--V1 : for now, no re-dispatching is done on the invoice scheduling lines...
      #--If an error is raised, then the user will access the schedule invoice and dispatch whatever is needed
      #--TODO
    Endif
  Endif

Return
# End issue 107888
