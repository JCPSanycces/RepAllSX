#<AdxTL>@(#)10.0.0.0 $Revision$
#########################################################################
#                                                                       #
#    MODELISATION E-COMMERCE                                            #
#                                                                       #
# ACTIONS :
#           TRTMULTIWX : Action traitement planification multi-niveaux  #
#           SAIMULTIWX : Action traitement planification MTO à la cde   #
#                                                                       #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
# GA 03/2008 Planification MTO     FQ 46650                             #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "TERMINE"    : Gosub TERMINE
 When Default
Endcase
#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "BOUTON"     : Gosub BOUTON
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "CONTROLE"   : Gosub CONTROLE
 When "APRES_MODIF": Gosub APRES_MODIF
Endcase
Return

#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################
$INIT
Case GACTION
 When "TRTMULTIWX" : Gosub INI_TRTMULTIWX
 When "SAIMULTIWX" : Gosub INI_SAIMULTIWX
Endcase
Return

#######################################################################
#    Détail des actions liées au traitement standard                  #
#######################################################################
$INI_TRTMULTIWX

# llc 02.02 13155
Local Char    WMFGFCY(GLONFCY)       : WMFGFCY    = PARAM(1)
Local Char    WITMREF(GLONITM)       : WITMREF    = PARAM(2)
Local Integer WMFGSTA                : WMFGSTA    = val(PARAM(3))
Local Decimal WQTYSTU                : WQTYSTU    = val(PARAM(4))
Local Char    WDATEFIN               : WDATEFIN   = PARAM(5)
Local Integer WVCRTYP                : WVCRTYP    = val(PARAM(6))
Local Char    WVCRNUM(GLONVCR)       : WVCRNUM    = PARAM(7)
Local Integer WVCRLIN                : WVCRLIN    = val(PARAM(8))
Local Integer WVCRSEQ                : WVCRSEQ    = val(PARAM(9))
Local Integer WWIPTYP                : WWIPTYP    = val(PARAM(10))
Local Char    WWIPNUM(GLONVCR)       : WWIPNUM    = PARAM(11)
Local Char    WORI                   : WORI       = PARAM(12)
Local Char    WPJT(GLONPJT)          : If dim(PARAM(13))>0 WPJT    = PARAM(13) Endif
Local Char    WMTOREF(GLONVCR)       : If dim(PARAM(14))>0 WMTOREF = PARAM(14) Endif : # V6 Réseau MTO FQ 46650
Local Char    WBPRNUM(GLONBPR)       : If dim(PARAM(15))>0 WBPRNUM = PARAM(15) Endif : # FQ 75172 GA 11/2011
Local Char    WPLANNER(GLONAUS)      : If dim(PARAM(16))>0 WPLANNER = PARAM(16) Endif : # GH 06/06/2013 bug 90273 V7
Local Char    WECCVALMAJ(GLONICVVAL) : If dim(PARAM(17))>0 WECCVALMAJ = PARAM(17) Endif : # Issue 104943 by BEEBE - 07/02/2015 - Implementing Versioning
Local Char    WECCVALMIN(GLONICVVAL) : If dim(PARAM(18))>0 WECCVALMIN = PARAM(18) Endif : # Issue 104943 by BEEBE - 07/02/2015 - Implementing Versioning

Local Date    WENDDAT
If WDATEFIN <> ""
    If instr(1,WDATEFIN,"/")
        WENDDAT = "["+WDATEFIN+"]"
    Else
        WENDDAT = WDATEFIN
    Endif
Endif

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev ([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev ([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
If clalev ([F:TBO]) = 0 : Local File TABBOMALT  [TBO] : Endif
If clalev ([F:ORD]) = 0 : Local File ORDERS     [ORD] : Endif
If clalev ([F:ITP]) = 0 : Local File ITMBPS     [ITP] : Endif
If clalev ([F:BPR]) = 0 : Local File BPARTNER   [BPR] : Endif
If clalev ([F:BPS]) = 0 : Local File BPSUPPLIER [BPS] : Endif
If clalev ([F:ARP]) = 0 : Local File AREPORT    [ARP] : Endif
If clalev ([F:AIM]) = 0 : Local File APRINTER   [AIM] : Endif
If clalev ([F:AID]) = 0 : Local File APRINTDES  [AID] : Endif
If clalev ([F:ACC]) = 0 : Local File ACCES      [ACC] : Endif : # FQ 47978 GA 06/2008
If clalev ([F:AUS]) = 0 : Local File AUTILIS    [AUS] : Endif
If !clalev([F:PTO]) = 0 : Local File PARMTO     [PTO] : Endif  : # Règles d'affectations MTO

If GMODU(8) = 2
    Gosub OPEN_FILES_MFG From MFGLIB
    If clalev ([F:MTS]) = 0: Local File MFGTRS     [MTS] : Endif
    If clalev ([F:MFP]) = 0: Local File MFGPRN     [MFP] : Endif
    If clalev ([F:TRO]) = 0: Local File TABROUALT  [TRO] : Endif
    If clalev ([F:ROH]) = 0: Local File ROUTING    [ROH] : Endif
    If clalev ([F:PJA]) = 0: Local File PARJAL     [PJA] : Endif
    If clalev ([F:TWD]) = 0: Local File TABWEEDIA  [TWD] : Endif
    If clalev ([F:MWS]) = 0: Local File WORKSTATIO [MWS] : Endif
    If clalev ([F:ROO]) = 0: Local File ROUOPE     [ROO] : Endif
    If clalev ([F:ROS]) = 0: Local File ROUSCD     [ROS] : Endif
    If clalev ([F:TUV]) = 0: Local File TABUNAVAIL [TUV] : Endif
    If clalev ([F:CPV]) = 0: Local File CAPVAR     [CPV] : Endif
    If clalev ([M:MFGK])= 0: Local Mask MFGK       [MFGK]: Endif
    If clalev ([M:JALK])= 0: Local Mask JALK       [JALK]: Endif
Endif

If GMODU(6) = 2
    If clalev ([F:PSD]) = 0 : Local File PREQUISD   [PSD] : Endif
    If clalev ([F:POH]) = 0 : Local File PORDER     [POH] : Endif
    If clalev ([F:POC]) = 0 : Local File PORDERC    [POC] : Endif
    If clalev ([F:POP]) = 0 : Local File PORDERP    [POP] : Endif
    If clalev ([F:POQ]) = 0 : Local File PORDERQ    [POQ] : Endif
    If clalev ([M:PMG]) = 0 : Local Mask PURMGT     [PMG] : Endif
    If clalev ([M:POM]) = 0 : Local Mask PODMGT     [POM] : Endif
    If clalev ([M:SCOK])= 0 : Local Mask SCOK       [SCOK]: Endif
    Gosub OPEN_FILES_SCO From SCOLIB
Endif

If GMODU(5)=2 : # Si module Ventes présent
    If clalev([F:SOH])  = 0 : Local File SORDER     [SOH] : Endif
    If clalev([F:SOQ])  = 0 : Local File SORDERQ    [SOQ] : Endif        # llc 05.03 17939
Endif

If clalev ([M:ORDK]) = 0: Local Mask ORDK       [ORDK]: Endif
If clalev ([M:MUXB]) = 0: Local Mask MULTIWOX1  [MUXB]: Endif

Return

#######################################################################
# Appel depuis la saisie des commandes de vente:
# Planification à la commande ATP/CTP  (Available/Capable to Promise)
#######################################################################
$INI_SAIMULTIWX
Local Char    WMFGFCY(GLONFCY)       : WMFGFCY    = PARAM(1)
Local Char    WITMREF(GLONITM)       : WITMREF    = PARAM(2)
Local Integer WMFGSTA                : WMFGSTA    = val(PARAM(3))
Local Decimal WQTYSTU                : WQTYSTU    = val(PARAM(4))
Local Char    WDATEFIN               : WDATEFIN   = PARAM(5)
Local Integer WVCRTYP                : WVCRTYP    = val(PARAM(6))
Local Char    WVCRNUM(GLONVCR)       : WVCRNUM    = PARAM(7)
Local Integer WVCRLIN                : WVCRLIN    = val(PARAM(8))
Local Integer WVCRSEQ                : WVCRSEQ    = val(PARAM(9))
Local Integer WWIPTYP                : WWIPTYP    = val(PARAM(10))
Local Char    WWIPNUM(GLONVCR)       : WWIPNUM    = PARAM(11)
Local Char    WORI                   : WORI       = PARAM(12)
Local Char    WPJT(GLONPJT)          : If dim(PARAM(13))>0 WPJT    = PARAM(13) Endif
Local Char    WMTOREF(GLONVCR)       : If dim(PARAM(14))>0 WMTOREF = PARAM(14) Endif : # V6 Réseau MTO FQ 46650
Local Char    WBPRNUM(GLONBPR)       : If dim(PARAM(15))>0 WBPRNUM = PARAM(15) Endif : # FQ 75172 GA 11/2011
Local Char    WPLANNER(GLONAUS)      : If dim(PARAM(16))>0 WPLANNER = PARAM(16) Endif : # GH 06/06/2013 bug 90273 V7
Local Char    WECCVALMAJ(GLONICVVAL) : If dim(PARAM(17))>0 WECCVALMAJ = PARAM(17) Endif : # Issue 104943 by BEEBE - 07/02/2015 - Implementing Versioning
Local Char    WECCVALMIN(GLONICVVAL) : If dim(PARAM(18))>0 WECCVALMIN = PARAM(18) Endif : # Issue 104943 by BEEBE - 07/02/2015 - Implementing Versioning
Local Date    WENDDAT
If WDATEFIN <> ""
    If instr(1,WDATEFIN,"/")
        WENDDAT = "["+WDATEFIN+"]"
    Else
        WENDDAT = WDATEFIN
    Endif
Endif

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev ([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev ([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
If clalev ([F:TBO]) = 0 : Local File TABBOMALT  [TBO] : Endif
If clalev ([F:ORD]) = 0 : Local File ORDERS     [ORD] : Endif
If clalev ([F:ITP]) = 0 : Local File ITMBPS     [ITP] : Endif
If clalev ([F:BPR]) = 0 : Local File BPARTNER   [BPR] : Endif
If clalev ([F:BPS]) = 0 : Local File BPSUPPLIER [BPS] : Endif
If clalev ([F:ARP]) = 0 : Local File AREPORT    [ARP] : Endif
If clalev ([F:AIM]) = 0 : Local File APRINTER   [AIM] : Endif
If clalev ([F:AID]) = 0 : Local File APRINTDES  [AID] : Endif
If clalev ([F:AUS]) = 0 : Local File AUTILIS    [AUS] : Endif
If !clalev([F:PTO]) = 0 : Local File PARMTO     [PTO] : Endif  : # Règles d'affectations MTO

If GMODU(8) = 2
    If clalev ([F:MTS]) = 0: Local File MFGTRS     [MTS] : Endif
    If clalev ([F:MFP]) = 0: Local File MFGPRN     [MFP] : Endif
    If clalev ([F:TRO]) = 0: Local File TABROUALT  [TRO] : Endif
    If clalev ([F:ROH]) = 0: Local File ROUTING    [ROH] : Endif
    If clalev ([F:PJA]) = 0: Local File PARJAL     [PJA] : Endif
    If clalev ([F:TWD]) = 0: Local File TABWEEDIA  [TWD] : Endif
    If clalev ([F:MWS]) = 0: Local File WORKSTATIO [MWS] : Endif
    If clalev ([F:ROO]) = 0: Local File ROUOPE     [ROO] : Endif
    If clalev ([F:ROS]) = 0: Local File ROUSCD     [ROS] : Endif
    If clalev ([F:TUV]) = 0: Local File TABUNAVAIL [TUV] : Endif
    If clalev ([F:CPV]) = 0: Local File CAPVAR     [CPV] : Endif
    If clalev ([M:MFGK])= 0: Local Mask MFGK       [MFGK]: Endif
    If clalev ([M:JALK])= 0: Local Mask JALK       [JALK]: Endif
Endif

If GMODU(6) = 2
    If clalev ([F:PSD]) = 0 : Local File PREQUISD   [PSD] : Endif
    If clalev ([F:POH]) = 0 : Local File PORDER     [POH] : Endif
    If clalev ([F:POC]) = 0 : Local File PORDERC    [POC] : Endif
    If clalev ([F:POP]) = 0 : Local File PORDERP    [POP] : Endif
    If clalev ([F:POQ]) = 0 : Local File PORDERQ    [POQ] : Endif
    If clalev ([M:PMG]) = 0 : Local Mask PURMGT     [PMG] : Endif
    If clalev ([M:POM]) = 0 : Local Mask PODMGT     [POM] : Endif
    If clalev ([M:SCOK])= 0 : Local Mask SCOK       [SCOK]: Endif
Endif

If GMODU(5)=2 : # Si module Ventes présent
    If clalev([F:SOQ])  = 0 : Local File SORDERQ    [SOQ] : Endif        # llc 05.03 17939
Endif

If clalev ([M:ORDK]) = 0: Local Mask ORDK       [ORDK]: Endif
If clalev ([M:MUXB]) = 0: Local Mask MULTIWOX1  [MUXB]: Endif

# Chargement de l'écran [M:DIA]
If clalev ([M:DIA])  = 0: Local Mask MULTIWOX   [DIA]: Endif
Gosub INIT_DIA
Return

#######################################################################
$INIT_DIA

Local Char    TIT(50) : TIT = mess(231,195,1)
Local Char    WMTSNUM(GLONTRS)

# llc 02.02 13155
Local Date    WORIDAT
Local Char    WORIFCY(GLONFCY)
Local Integer WLTI
Local Decimal XLTI
Local Integer ILTI
Local Decimal WRMD
Local Decimal WQTY
Local Char    WSNS(1)
# impression 140
Local Char    LPRT(GLONAIM)
Local Integer LOBL

Raz [M:DIA] : LOBL=0

# llc 02.02 13155
If WMFGFCY <> ""
    [M:DIA]MFGFCY = WMFGFCY
Elsif GMODU(8)<>2 : # GH 12/04/2013
    Call FIND_GFCYDEF(7) From TRTX3
    [M:DIA]MFGFCY = GFCY
Else
    Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
    [M:DIA]MFGFCY = GFCY
Endif
GFCY = [M:DIA]MFGFCY
Gosub CHARG_PARAM

# GH 06/06/2013 bug 90273 V7
If WPLANNER<>""
  [M:DIA]PLANNER = WPLANNER
Else
  [M:DIA]PLANNER = GUSER
Endif

$DEB_DIA
If WITMREF <> ""
    [M:DIA]ITMREF = WITMREF
    mkstat=0 : # GH 16/04/2013
    Call C_ITMREF([M:DIA]ITMREF) From SUBMUTX
    mkstat=0 : # GH 15/05/2013 bug 89596
    #If !mkstat
    # Issue 104943 by BEEBE - 07/02/2015 - Implementing Versioning
    [M:DIA]ECCERRCOD=0
    If dim(WECCVALMAJ)>0 & dim([M:DIA]ECCVALMAJ)>0
        [M:DIA]ECCVALMAJ = WECCVALMAJ
        [M:DIA]ECCVALMIN = WECCVALMIN
        [M:DIA]ECCERRCOD = -1
    Endif

       Call AM_ITMREF([M:DIA]ITMREF) From SUBMUTX
    #Endif
    # GH 15/04/13 redondant avec C_ITMREF et AM_ITMREF
    # FQ 75172 GA 11/2011
    #Read [ITF]ITF0=WITMREF;WMFGFCY
    #If fstat : Raz [F:ITF] : Endif
    #If [F:ITF]REOCOD=5 : [M:DIA]BOMALTTYP=3  # Sous-traitance
    #Else               : [M:DIA]BOMALTTYP=2  # Fabrication
    #Endif
    #Endif
Endif

Case WMFGSTA
    When 1:    [M:DIA]MFGSTA = 2    # ferme
    When 2:    [M:DIA]MFGSTA = 1    # planifié
Endcase

[M:DIA]EXTQTY = WQTYSTU

# la date de début est demain repoussée à un jour ouvré
If [M:DIA]STRDAT=[0/0/0]
   [M:DIA]STRDAT=date$+1
Endif
mkstat=0
Call CONTROL_DATE_PLN([M:DIA]STRDAT,[M:DIA]MFGFCY) From MFGLIB
If mkstat
   GMESSAGE=""
   WORIDAT=[M:DIA]STRDAT
   Call CALCUL_DATE_PLN(WORIDAT, 1, [M:DIA]MFGFCY, 0, [M:DIA]STRDAT) From MFGLIB
Endif

If [M:DIA]BOMALT = 0 & [M]BOMALTTYP=3 & !LOBL
    # Recherche de la nomenclature SST et du délai
    Call RECH_NOM([M:DIA]MFGFCY, [M:DIA]STRDAT, [M:DIA]BOMALT,[M:DIA]BOMALTTYP) From BENCHLIB
    If [M]BOMALT<>0
       Gosub DELAI_SST From SUBMUTX
    Endif
Endif

If WENDDAT <> [0/0/0]
  # la date de fin est avancée à un jour ouvré
  mkstat=0
  Call CONTROL_DATE_PLN(WENDDAT,[M:DIA]MFGFCY) From MFGLIB
  If mkstat
     GMESSAGE=""
     WORIDAT=WENDDAT
     Call CALCUL_DATE_PLN(WORIDAT, 1, [M:DIA]MFGFCY, 1, WENDDAT) From MFGLIB
  Endif
  #  WORIDAT       = WENDDAT
  #  WORIFCY       = [M:DIA]MFGFCY
  #  WLTI          = 0

  # GA 03/2008 Planif. MTO on reçoit la date de fin
  #            - calcul de la date de début
  #            - appel de RECH_NOM et RECH_GAM pour le site et la date
  ###  # lecture article site
  ###    Read [ITF]ITF0=[M:MUX1]ITMREF;[M:MUX1]MFGFCY
  ###    If fstat : Raz [F:ITF] : Endif
  ###    WQTY = [M:DIA]EXTQTY
  ###    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
  ###    ILTI    = int(XLTI)
  ###    WRMD    = XLTI - ILTI
  ###    If WRMD <> 0 : ILTI += 1 : Endif
  ###    WLTI=ILTI
  ###    # calcul date
  ###    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:DIA]STRDAT) From MFGLIB
    If !LOBL
       mkstat=0  : # GH 16/04/2013
       Call C_ENDDAT(WENDDAT) From SUBMUTX
    Endif
    # recalcul de la date début à partir de la date fin et du délai
    mkstat=0 : # GH 15/05/2013 bug 89596
    #If !mkstat
       Call AM_ENDDAT(WENDDAT) From SUBMUTX
    #Endif
    [M:DIA]ENDDAT = WENDDAT
Endif

If [M:DIA]BOMALT<>0 & [M:DIA]BOMALTTYP=3 & !LOBL
   # la nomenclature est-elle toujours valide à la date début ?
   mkstat=0
   Call AM_BOMALT([M:DIA]BOMALT) From SUBMUTX
   If mkstat : # non
      Raz [M:DIA]
      [M:DIA]MFGFCY = GFCY
      LOBL=1
      Goto DEB_DIA
   Endif
Endif
LOBL=0

[M:DIA]VCRTYPORI = WVCRTYP
[M:DIA]VCRNUMORI = WVCRNUM
[M:DIA]VCRLINORI = WVCRLIN
[M:DIA]VCRSEQORI = WVCRSEQ
[M:DIA]WIPTYP    = WWIPTYP    # 10.02 MM
[M:DIA]WIPNUM    = WWIPNUM    # 10.02 MM
[M:DIA]ORI       = WORI
If dim([M:DIA]PJT)>0 & dim(WPJT)>0
   [M:DIA]PJT    = WPJT      : # V6
Endif
If dim([M:DIA]MTOREF)>0 & dim(WMTOREF)>0 & WMTOREF<>""
   [M:DIA]MTOREF = WMTOREF       : # V6 Réseau MTO FQ 46650
Endif

# Tiers
If dim(WBPRNUM)>0 & WBPRNUM <> "" & WVCRTYP = 2 # FQ 75172 GA 11/2011 Appel depuis GESSOH
   [M:DIA]BPCNUM = WBPRNUM
# 10.02 MM If [M:DIA]VCRNUMORI<>""
Elsif [M:DIA]VCRNUMORI<>"" & WWIPTYP>0 & WWIPNUM<>""
    Read [ORD]ORD0=WWIPTYP;WWIPNUM;[M:DIA]ITMREF
    If !fstat : [M:DIA]BPCNUM = [F:ORD]BPRNUM   : Endif
Endif
#

# FQ 75172 ssi nomenclature de prod # FQ 66126 GA 09/2010 ssi module GPAO # Bug 79790 GH 01/02/12 si BOMALTTYP non initialisée
If GMODU(8) = 2  : #  & find([M:DIA]BOMALTTYP,0,2) : # GH 12/04/2013
    # transaction OF
    If [M:DIA]MTSNUM = ""
        If GMFGMTSNUM <> ""
            WMTSNUM = GMFGMTSNUM
        Else
            Raz [F:MTS]
        Endif
    Else
        WMTSNUM = [M:DIA]MTSNUM
    Endif

    If WMTSNUM <> "" & ([F:MTS]MTSTYP <> 1 | [F:MTS]MTSNUM <> WMTSNUM )
        Read [MTS]MTS0=1;WMTSNUM
        If fstat : Raz [F:MTS] : Endif
    Endif

    ETAT = "DOSFAB"
    Read [ARP]ARP0 = ETAT
    If fstat : Raz [F:ARP] : Endif

    # impression 140
    Call DEFIMP(ETAT, GUSER, "", LPRT, LOBL) From IMPRIME
    [M:DIA]PRT = LPRT
    [M:DIA]OBL = LOBL
    Call C_PRT([M:DIA]PRT) From SUBMUTX
    If [M:DIA]OBL = 1 : Diszo [DIA]PRT : Endif
    Affzo [DIA]PRT
Endif

zonsui="" : # GH 15/05/2013 bug 89596
Return

#######################################################################
$TERMINE

TRA=1
Call FERME_TRACE From LECFIC

# FQ 63448 GA 03/2010 pb d'icones
Kill    WICO_PRODG,WICO_ENDG,WICO_TRFG
# Issue 111414 - 2016-02-22 by JUSYN : Global variable handling routing
Kill    GROUTINGX
# Issue 111414 /116- 2016-04-07 by JUSYN : Global variable handling routing code
Kill    GROUTINGCX

Return

#########################################################################
$OUVRE
Local Char    CRITERE(250), CRITERE1(250)
Local Integer OK, NBOF, NBEO, NBACH, NBINT, L, LEVEL, LIGNE, PLIGNE
Local Char    WMESS(80), WMESS1(80), WMESS2(80), WMESS3(80)
Local Date    WORIDAT
Local Char    WORIFCY(GLONFCY)
Local Integer WLTI
Local Decimal XLTI
Local Integer ILTI
Local Decimal WRMD
Local Decimal WQTY
Local Char    WSNS(1)
Local Date    REFDAT
Local Char    ETAT(20)
Local Decimal WDIS
Local Decimal WCOEF

Local Char PARAM_CLC(250)(1..14) , VAL_CLC(250)

# FQ 63448 GA 03/2010 pb d'icones
Global Char    WICO_PRODG(30),WICO_ENDG(30),WICO_TRFG(30)
# Issue 111414/11 - 2016-02-22 by JUSYN : Global variable for handling routing changings.
Global Integer GROUTINGX
# Issue 111414/116 - 2016-04-07 by JUSYN : Global variable for handling routing code changings.
Global Integer GROUTINGCX


Gosub LISTE_ICONES

Return


#########################################################################
$CONTROLE

If [M:DIA]MTSNUM = "" | GMODU(8)<>2 : Return : Endif

Read [MTS]MTS0 = 1;[M:DIA]MTSNUM
If fstat : FOK = 0 : Return : Endif

If [F:MTS]MODJAL = 2 & [M:DIA]LTICOD = 1
    GERR = 3
    FOK = 0
    GMESSAGE = mess(153,190,1)
Endif

Return

#########################################################################
$SETBOUT
ETABOU(GSPE1) = 1
ETABOU(GSPE2) = 1
ETABOU(GSPE3) = 1
ETABOU(GSPE4) = 1
# Issue Jira X3-3192 - 2016-09-02 by JUSYN : Missing return caused unwanted reinitialization that caused an error.
Return

#########################################################################
$BOUTON
Case BOUT
    When "a"  :   # réinitialiser
                  OK = 2
                  Call OUINON(mess(420,198,1),OK) From GESECRAN
                  If OK = 2
                      Raz [M:MUX1]
                      Gosub DEBUT
                  Endif
    When "b"  :   # Inclure
                  Gosub INC_ALL
    When "c"  :   # Exclure
                  Gosub EX_ALL
    When "d"  :   # générer
                  Gosub MODIF
                  FIN=1
                  GERR=2
    When Default:
Endcase
Return


#########################################################################
$DEBUT
Case GACTION
 When "TRTMULTIWX" : Gosub CHARG_TRTMULTIWX
 When "SAIMULTIWX" : Gosub CHARG_SAIMULTIWX
Endcase
Return

$CHARG_TRTMULTIWX
$CHARG_SAIMULTIWX
Local Char    TIT(50) : TIT = mess(231,195,1)

Default Mask [MUX1]

Call TEMPON(mess(412,197,1)) From GESECRAN

Gosub CHARGE_TAB

Call TEMPOFF From GESECRAN

# Issue 111414/116 - 2016-04-07 by JUSYN : ROUNUM/ROUALT not enterable when product and routing versioned.
Local Integer I
For I = 0 To [M:MUX1]NBLIG - 1
    If (func ECCLIB.NBRCPN([M:MUX1]ITMREF(I)) > 0) & (func RVMLIB.NBRCPNROU([M:MUX1]ROUNUM(I)) > 0)
        Diszo [M:MUX1]ROUNUM(I)
        Diszo [M:MUX1]ROUALT(I)
        Affzo [M:MUX1]ROUNUM(I)
        Affzo [M:MUX1]ROUALT(I)
    Endif
Next

If dim([M:MUX1]ROUECCMAJ) > 0
    For I = 0 To [M:MUX1]NBLIG - 1
        If (func RVMLIB.NBRCPNROU([M:MUX1]ROUNUM(I)) = 0)
            Diszo [M:MUX1]ROUECCMAJ(I)
            Diszo [M:MUX1]ROUECCMIN(I)
            [M:MUX1]ROUECCMAJ(I) = ""
            [M:MUX1]ROUECCMIN(I) = ""
            Affzo [M:MUX1]ROUECCMAJ(I)
            Affzo [M:MUX1]ROUECCMIN(I)
        Endif
    Next
Endif

# Issue 110957 - 2015-10-19 by GH - Setting values for Change Request screen fields
If dim([M:MUX1]CRID)>0
   Diszo [MUX1]CRID
Endif
Diszo [MUX1]LEVEL
Affzo [MUX1]1-99

Return

#----------------------------------------------------------------------
# chargement du tableau des ordres à planifier
$CHARGE_TAB
Raz [M:MUX1]
Raz [M:MUXB]
# lecture site
[M:MUX1]MFGFCY=[M:DIA]MFGFCY
Call LECTURE("FCY",[M:MUX1]MFGFCY,"") From CONTOBJ
[M:MUX1]FCYDES = [F:FCY]FCYNAM

[M:MUX1]TRI = 1
[M:MUX1]LTICOD  = [M:DIA]LTICOD
[M:MUX1]PLANNER = [M:DIA]PLANNER
[M:MUX1]MFGSTA  = [M:DIA]MFGSTA   : # Menu local 370: 1=Planifié, 2=Ferme, 3=Au choix
Case [M:DIA]MFGSTA
   When 2 :  [M:MUX1]WIPSTA  = 1   : # Ferme
   When 1 :  [M:MUX1]WIPSTA  = 2   : # Planifié
Endcase
[M:MUX1]ORI      = [M:DIA]ORI

# génération de la liste
nolign = 1
L      = nolign -1
LEVEL  = 0
LIGNE  = 0
PLIGNE = 0

# ajout première ligne = produit lancé
Gosub ADD_PROD

# 15119 10.02 MM
Gosub DISPREV

# génération de la liste de planification
# Issue 87646 LLC/GA 02/2013: passer en paramètre la date début calculée du niveau 0 (produit fini) au lieu de la date début demandée en sélection
#                             car la date début change si la transaction auto est en mode jalonnement amont.
#Call GEN_LISTE(L, LEVEL, LIGNE, PLIGNE, [M:DIA]MFGFCY, [M:DIA]ITMREF, [M:DIA]BOMALT, [M:DIA]BOMALTTYP, [M:DIA]STRDAT, [M:DIA]EXTQTY)
# Issue 111414/11 - 2016-02-11 by JUSYN : Calculate start date of versioned BOM
#Call GEN_LISTE(L, LEVEL, LIGNE, PLIGNE, [M:DIA]MFGFCY, [M:DIA]ITMREF, [M:DIA]BOMALT, [M:DIA]BOMALTTYP, [M:MUX1]STRDAT(0), [M:DIA]EXTQTY)
Local Date WLDAT
If dim([M:MUX1]ECCVALMAJ)>0
    If [M:MUX1]ECCVALMAJ(0) <> ""
        Call CORDAT([M:DIA]ITMREF , [M:MUX1]ECCVALMAJ(0) , [M:MUX1]ECCVALMIN(0) , [M:DIA]BOMALTTYP , WLDAT) From ECCLIB
    Else
        WLDAT = [M:MUX1]STRDAT(0)
    Endif
Else
    WLDAT = [M:MUX1]STRDAT(0)
Endif
Call GEN_LISTE(L, LEVEL, LIGNE, PLIGNE, [M:DIA]MFGFCY, [M:DIA]ITMREF, [M:DIA]BOMALT, [M:DIA]BOMALTTYP, [M:MUX1]STRDAT(0), [M:DIA]EXTQTY , WLDAT)

Call BILAN

Return

#----------------------------------------------------------------------
# lecture récursive de la nomenclature ...
# l'ensemble des liens sont copiés dans le masque MUXB, seuls les liens
# correspondant aux sélections sont affichés (masque par défaut [M:MUX1])
# on a besoin de tous les liens pour recalculer les nouvelles dates si l'utilisateur
# saisit une nouvelle date de 1er appro.
Subprog GEN_LISTE(L, LEVEL, LIGNE, PLIGNE, LFCY, LITM, LALT, LTYP, LDAT, LQTY , LRDAT)
Variable Integer  L
Variable Integer  LEVEL
Variable Integer  LIGNE
Variable Integer  PLIGNE
Value    Char     LFCY
Value    Char     LITM
Value    Integer  LALT
Value    Integer  LTYP     : # ajout V6
Value    Date     LDAT
Value    Decimal  LQTY
# Issue 111414_11 - 2016-02-11 by JUSYN : Date to resolve BOM
Value    Date     LRDAT

Local    Decimal  WQTY, WDIS, WQTYN, WQTYNA, WQTYB, WQTYBA, WLIEN
Local    Decimal  WBASQTY
Local    Integer  WLIKQTYCOD
Local    Decimal  WLIKQTY
Local    Integer  WQTYRND
Local    Decimal  WLSCA
Local    Integer  WSCATIA, I, OK

Local    Char     WSTU(GLONUOM)     # llc 01.02 UOM
Local    Char     WMSG(250)
Local    Integer  WRET
Local    Integer  OK
Local    Decimal  WWRK, WCOEF

Local    Date     WORIDAT
Local    Char     WORIFCY(GLONFCY)
Local    Integer  WLTI, WLIN
Local    Date     WDSTDAT, REFDAT
Local    Decimal  WQTY, WRMD
Local    Decimal  XLTI
Local    Integer  ILTI
Local    Char     WSNS(1)
Local    Decimal  WBOMALT : WBOMALT = LALT
Local    Decimal  WALTTYP : WALTTYP = LTYP    : # ajout V6
Local    Decimal  WALTTYPR                    : # ajout V6
Local    Decimal  WROUALT : WROUALT = [M:DIA]ROUALT
Local    Integer  XBOMALT, XROUALT
Local    Date     WMEMDAT : WMEMDAT = LDAT
Local    Integer  WMEMPL
Local    Integer  NOADD : NOADD = 0
Local    Char     WPOHNUM(GLONVCR)
Local    Char     WBPSNUM(GLONBPS)
Local    Char     WERRITF(250) : WERRITF="" # FQ 58796
Local    Integer  WGHOST : WGHOST=1         # FQ 72412
Local    Char     WSRVITMREF(GLONITM)       # FQ 88882
Local    Integer  WLTIJO                    # FQ 88882

# lecture entête
Gosub LEC_FILES

# FQ 49868 LLC 10/2008
# incrémentation niveau et changement de parent à ignorer si fantôme
If [F:ITM]PHAFLG <> 2
    LEVEL  += 1
    PLIGNE = LIGNE
Else WGHOST=2   # FQ 72412
Endif

# Issue 111414/11 - 2016-02-11 by JUSYN : Date to resolve BOM LRDAT
If LRDAT = [0/0/0]
    LRDAT = LDAT
Endif

# lecture liens
Local File BOMD [BOD] Where ITMREF = LITM & BOMALT = WBOMALT & BOMALTTYP=WALTTYP       &
&                   (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= LRDAT)) &
&                   (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= LRDAT)) &
&                    !find(CPNTYP,4,5,6,7)

# comptage n°ligne courant OF/EO
WLIN=1000
# lecture premier enregistrement
Read [BOD]BOD0 First                  # 10.02 Performances
While !fstat

    # FQ 77526 GA 11/2011 [F:BOH]perdu si on est descendu dans l'arborescence
    If [F:BOH]ITMREF<>LITM
       Gosub LEC_FILES
    Endif

    # lecture composant
    Read [ITM]ITM0=[F:BOD]CPNITMREF
    If fstat  :  Goto NEXT_BOD :  Endif

    # llc 01.02 12406
    # lecture article site
    Read [ITF]ITF0=[F:BOD]CPNITMREF;LFCY
    # FQ 58796 ajout liste des ITF manquants
    If fstat : Gosub ERR_ITF :  Goto NEXT_BOD :  Endif

    # llc 01.02 12406
    mkstat=0 : # GH 16/04/2013
# 107513
#    Call CONTMATITM(LFCY, 1) From MFGLIB
#    If mkstat
#        Raz GMESSAGE
#        mkstat = 0
#        Goto NEXT_BOD
#    Endif
    Raz WRET # Issue 111835 by BEEBE - 28/10/2015 - has to be initialized
    Call CONTMATITM([F:BOD]CPNITMREF,LFCY, "MFM", WRET, WMSG) From MFGLIB
    If find(WRET,1,4)
        Raz WMSG
        Goto NEXT_BOD
    Endif

    If [F:ITF]REOCOD <= 1 : Goto NEXT_BOD : Endif

    # calcul quantité
    If [F:BOD]LIKQTY <> 0
       WQTY         = LQTY
       WSTU         = [F:ITM]STU
       WBASQTY      = [F:BOH]BASQTY
       WLIKQTYCOD   = [F:BOD]LIKQTYCOD
       WLIKQTY      = [F:BOD]LIKQTY
       WQTYRND      = [F:BOD]QTYRND
       WSCA         = [F:BOD]SCA
       Call LIKQTY(WQTY,WSTU,WBASQTY,WLIKQTYCOD,WLIKQTY,WQTYRND,
&           WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
       If WSCATIA
          WLIEN = WQTYBA
       Else
          WLIEN = WQTYNA
       Endif
    Else
       WLIEN = 0
    Endif

#         If WLIEN  = 0 : Goto NEXT_BOD : Endif

    NOADD = 0
    # si article fantôme descente par récursivité
    If ([F:ITM]PHAFLG <> 2)
        # test catégorie début
        If [M:DIA]TCLCODSTR <> ""
           If [F:ITM]TCLCOD < [M:DIA]TCLCODSTR : NOADD = 1 : Endif
        Endif

        # test catégorie fin
        If [M:DIA]TCLCODEND <> ""
            If [F:ITM]TCLCOD > [M:DIA]TCLCODEND : NOADD = 1 : Endif
        Endif

        # AML 2338 mode gestion [F:ITM]STDFLG: 2=A l'affaire, 3=Sur stock, 4=A la commande
        Case [M:DIA]MGTCOD
            When 1:    If [F:ITM]STDFLG <> 3 : NOADD = 1 : Endif
            When 2:    If [F:ITM]STDFLG <> 4 : NOADD = 1 : Endif
            When 3:    If !find([F:ITM]STDFLG, 3, 4) : NOADD = 1 : Endif
            When 4:    If !find([F:ITM]STDFLG, 2, 3) : NOADD = 1 : Endif # FQ 76917 new 4=A l'affaire dans AML 2338
        Endcase

        Raz GMESSAGE
        If [M:DIA]MFGSTA = 1
            Call CTLPLNFLT(LFCY, [F:ITM]ITMREF, [M:DIA]PLANNER) From MFGLIB
            If GMESSAGE <> "" : mkstat = 0 : NOADD = 1 : Endif
        Elsif [F:ITF]REOCOD = 3
            Call CTLPLNFLT(LFCY, [F:ITM]ITMREF, [M:DIA]PLANNER) From MFGLIB
            If GMESSAGE <> "" : mkstat = 0 : NOADD = 1 : Endif
        Elsif find([F:ITF]REOCOD,2,4,5)
            If GBUYFLT = 2 & [F:ITF]BUY <> [M:DIA]PLANNER & [F:ITF]BUY <> "" : NOADD = 1 : Endif    # 04.05 29950
        Endif

        # llc 01.02
        # prise en compte du délai CQ
        WORIDAT = WMEMDAT
        WORIFCY = [M:MUX1]MFGFCY
        WLTI    = [F:ITF]QUALTI
        # calcul date
        Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, WDSTDAT) From MFGLIB
        LDAT    = WDSTDAT
        Gosub ADD_LINE

      # comptage n°ligne courant OF/EO
        WLIN+=1000

    Endif

    # si achat ou intersite, pas de traversée (20736)
    # FQ 49868 LLC 10/2008 pas de ligne [F:ITF] sur les fantômes, il faut inverser le test : find([F:ITF]REOCOD,2,4)
    If [F:ITM]PHAFLG <> 2 & !find([F:ITF]REOCOD,3,5) : Goto NEXT_BOD : Endif

    WMEMPL = PLIGNE

    # Issue 87646 LLC/GA 02/2013: si on est sur un semi-fini et que l'indicateur NOADD est à 1 (pas de réappro car il y a du stock), on ne descend pas sa nomenclature
    If find([F:ITF]REOCOD,3,5) & NOADD : Goto NEXT_BOD : Endif

    # V6 production ou sous-traitance ?
    If [F:ITF]REOCOD=5 WALTTYPR=3 Else WALTTYPR=2 Endif
    # Issue 111414/11 - 2016-02-11 by JUSYN : Calculate start date of versioned BOM
    # Call GEN_LISTE(L, LEVEL, LIGNE, PLIGNE, LFCY, [F:ITM]ITMREF, WBOMALT, WALTTYPR, LDAT, WLIEN)
    Local Date WLDAT
    If dim([M:MUX1]ECCVALMAJ)>0
        If [M:MUX1]ECCVALMAJ(L-1) <> ""
            Call CORDAT([F:ITM]ITMREF , [M:MUX1]ECCVALMAJ(L-1) , [M:MUX1]ECCVALMIN(L-1) , [M:MUX1]BOMALTTYP(L-1) , WLDAT) From ECCLIB
        Else
            WLDAT = LDAT
        Endif
    Else
        WLDAT = LDAT
    Endif
    Call GEN_LISTE(L, LEVEL, LIGNE, PLIGNE, LFCY, [F:ITM]ITMREF, WBOMALT, WALTTYPR, LDAT, WLIEN , WLDAT)

    PLIGNE = WMEMPL
$NEXT_BOD
    WBOMALT = LALT
    LDAT = WMEMDAT
    If dim([M:MUX1]ITMREF) < [M:MUX1]NBLIG + 2 : Break : Endif
    Read [BOD]BOD0 Next                 # 10.02 Performances
Wend

# FQ 72412 GA 03/2011 code sorti de la boucle
Gosub LEC_FILES
# FQ 49868 GA 10/2008
# décrémentation niveau et changement de parent à ignorer si fantôme
#If [F:ITM]PHAFLG <> 2 # sauf si on a traversé un Fantome
If WGHOST<>2  # FQ 72412
   LEVEL -= 1
   PLIGNE = WMEMPL
Endif

# FQ 58796 Liste des articles non chargés suite erreur [F:ITF]
If WERRITF<>""
   # Article-site inexistant
   WMESS=mess(139,197,1)-": ("-LFCY-")"-WERRITF
   Call ECR_TRACE(WMESS,0) From GESECRAN
Endif

# FQ 66126 GA 09/2010
Close Local File [BOD]

End
# FQ 58796 Liste des articles non chargés suite erreur [F:ITF]
$ERR_ITF
If [F:BOD]CPNITMREF<>"" & !find([F:BOD]CPNITMREF,WERRITF) & len(WERRITF)<240
   If WERRITF<>"" WERRITF+="," Endif
   WERRITF+=[F:BOD]CPNITMREF
Endif
Return  # FQ 66126 GA 08/2010

#----------------------------------------------------------------------
# alimentation du tableau
$ADD_PROD
[M:MUX1]PECFLG(L)    = 2
[M:MUX1]LEVEL(L)     = LEVEL
[M:MUX1]ITMREF(L)    = [M:DIA]ITMREF
# GA 02/2008 V6
#Case [M:MUX1]MFGSTA
#    When 1: [M:MUX1]PLNTYP(L)    = mess(5,341,1)+mess(2,342,1)
#    When 2: [M:MUX1]PLNTYP(L)    = mess(5,341,1)+mess(1,342,1)
#Endcase
[M:MUX1]BOMALTTYP(L) = [M:DIA]BOMALTTYP
Case [M:DIA]BOMALTTYP
   When 2 : [M:MUX1]WIPTYP(L) = 5
   When 3 : [M:MUX1]WIPTYP(L) = 13
Endcase
[M:MUX1]PLNTYP(L) = mess([M:MUX1]WIPTYP(L),341,1)+mess([M:MUX1]WIPSTA,342,1)
[M:MUX1]PARENT    = ""
[M:MUX1]PARLIN(L) = -1

# lecture article
If [F:ITM]ITMREF <> [M:DIA]ITMREF
    Read [ITM]ITM0=[M:DIA]ITMREF
    If fstat : Raz [F:ITM] : Endif
Endif
# 14123 10.02 MM
If find([F:ITM]LOTMGTCOD, 2, 3)
    [M:MUX1]LOT(L)       = mess(62,193,1)
Endif
#
#[M:MUX1]ITMDES1(L)   = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MUX1]ITMDES1(L), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:MUX1]PURFLG(L)    = [F:ITM]PURFLG
[M:MUX1]MFGFLG(L)    = [F:ITM]MFGFLG
[M:MUX1]SCPFLG(L)    = [F:ITM]SCPFLG
[M:MUX1]SCSFLG(L)    = [F:ITM]SCSFLG
[M:MUX1]PHAFLG(L)    = [F:ITM]PHAFLG
[M:MUX1]GENFLG(L)    = [F:ITM]GENFLG
[M:MUX1]TOOFLG(L)    = [F:ITM]TOOFLG
[M:MUX1]DLVFLG(L)    = [F:ITM]DLVFLG
[M:MUX1]SALFLG(L)    = [F:ITM]SALFLG
[M:MUX1]INTFLG(L)    = [F:ITM]INTFLG
[M:MUX1]REOCOD(L)    = [F:ITF]REOCOD
[M:MUX1]PLANNER2(L)  = [F:ITF]PLANNER
[M:MUX1]BUY(L)       = [F:ITF]BUY
[M:MUX1]EXTQTY(L)    = [M:DIA]EXTQTY
[M:MUX1]STU(L)       = [M:DIA]STU
# 15119 10.02 MM
#Local Integer WRET
Local Decimal WDIS
Raz WDIS : #,WRET
#--- Issue 115110 & 120426 : Added LECCVAL parameter in 10th position
#Call STODISALL([M:MUX1]MFGFCY,[F:ITM]ITMREF,10,1,2,1,2,"","",WDIS,WRET) From STKALL
Call STODISALL([M:MUX1]MFGFCY,[F:ITM]ITMREF,func TRTX3FNC.VALFLD_C("[M:DIA]ECCVALMAJ"),WDIS) From MFGLIBM
[M:MUX1]AVASTO(L)    = WDIS
#
[M:MUX1]STRDAT(L)    = [M:DIA]STRDAT
[M:MUX1]ENDDAT(L)    = [M:DIA]ENDDAT

[M:MUX1]BOMALT(L)    = [M:DIA]BOMALT
[M:MUX1]ROUNUM(L)    = [M:DIA]ROUNUM
[M:MUX1]ROUALT(L)    = [M:DIA]ROUALT

# Issue 111414/113 - 2016-03-29 by JUSYN : Moved here because Routing version needed for Scheduling
# Issue 111414/11 - 2016-02-11 by JUSYN : Receive Routing Version
If dim([M:MUX1]ROUECCMAJ) > 0
    [M:MUX1]ROUECCMAJ(L) = [M:DIA]ROUECCMAJ
    [M:MUX1]ROUECCMIN(L) = [M:DIA]ROUECCMIN
Endif

# 03.06 34891
If GMODU(8)=2 & [M:MUX1]LTICOD = 2 & [M:MUX1]ROUNUM <> "" & [M:MUX1]ROUALT <> 0
    If [F:MTS]SCDMODSAI=2
       REFDAT = [M:DIA]STRDAT : Gosub CAL_JAL_AV
    Else
       REFDAT = [M:DIA]ENDDAT : Gosub CAL_JAL_AM
    Endif
Endif

[M:MUX1]MFGDES(L)    = [M:DIA]MFGDES
[M:MUX1]PJT(L)       = [M:DIA]PJT
[M:MUX1]BPRNUM(L)    = [M:DIA]BPCNUM
[M:MUX1]VCRTYPORI(L) = [M:DIA]VCRTYPORI
[M:MUX1]VCRNUMORI(L) = [M:DIA]VCRNUMORI   : # Origine de la planif multi-niveaux
[M:MUX1]VCRLINORI(L) = [M:DIA]VCRLINORI
[M:MUX1]VCRSEQORI(L) = [M:DIA]VCRSEQORI
[M:MUX1]TCLCOD(L)    = [F:ITM]TCLCOD
[M:MUX1]MGTCOD(L)    = [F:ITM]STDFLG
[M:MUX1]BOMSEQ(L)    = 0
[M:MUX1]LIGNE(L)     = 0
[M:MUX1]PROFLG(L)    = 1

If [M:MUX1]BOMALTTYP(L) = 3 : ## GH 15/04/2013
   # recherche fournisseur unité d'achat et coeff UA-US
   [M:MUX1]PUU(L) = [F:ITM]PUU
   [M:MUX1]PUUSTUCOE(L) = [F:ITM]PUUSTUCOE
   Filter [ITP] Where ITMREF=[M:MUX1]ITMREF(L) & BOMALT=[M:MUX1]BOMALT(L) Order By Key ITP1
   Read [ITP] First
   Filter [ITP]
   If fstat
      Raz [F:ITP]
   Else
      [M:MUX1]BPSNUM(L)     = [F:ITP]BPSNUM
      [M:MUX1]PUU(L)        = [F:ITP]PUU
      [M:MUX1]PUUSTUCOE(L)  = [F:ITP]PUUSTUCOE
   Endif
   Call PCAL_QTY([M:MUX1]EXTQTY(L), [M:MUX1]STU(L),[M:MUX1]PUUPECQTY(L),[M:MUX1]PUU(L),
&                [M:MUX1]ITMREF(L),[M:MUX1]BPSNUM(L),1,WCOEF) From TRTACHQTE1
   If WCOEF <> 0 : [M:MUX1]PUUSTUCOE(L) = 1/WCOEF : Endif        # 05.01 llc
Endif

# Issue 111414/113 - 2016-03-29 by JUSYN : move update call after receipt of versions
# Issue 111414/11 - 2016-02-11 by JUSYN : versions flag
#Call UPD_PECFLG(L,L,1)

# 10.02 MM contremarque/OF
If [M:DIA]VCRNUMORI <>""
    If [M:DIA]WIPNUM<>""
       Read [ORD]ORD0 = [M:DIA]WIPTYP;[M:DIA]WIPNUM;[M:DIA]ITMREF
    Else
       # Issue 78352 GA 01/2012 sometimes there's no WIPNUM ???
       # Index ORD3=STOFCY+VCRTYP+VCRNUM+VCRLIN+VCRSEQ
       Read [ORD]ORD3 = [M:MUX1]MFGFCY;[M:DIA]VCRTYPORI;[M:DIA]VCRNUMORI;[M:DIA]VCRLINORI;[M:DIA]VCRSEQORI
       [M:DIA]WIPTYP = [F:ORD]WIPTYP
       [M:DIA]WIPNUM = [F:ORD]WIPNUM
    Endif
    If !fstat : [M:MUX1]FMI(L) = [F:ORD]FMI : Endif
    # llc 05.03 17939    # Issue 78352 GA 01/2012 + contremarque EO
    If find([M:MUX1]FMI(L),5,6)
        Read [SOQ]SOQ0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
        If !fstat & [F:SOQ]FMINUM <> "" : [M:MUX1]FMI(L) = 1 : Endif
    Endif
Endif

# Issue 104943 by BEEBE - 07/02/2015 - Implementing Versioning
If dim([M:MUX1]ECCVALMAJ)>0
    [M:MUX1]ECCVALMAJ(L)=[M:DIA]ECCVALMAJ
    [M:MUX1]ECCVALMIN(L)=[M:DIA]ECCVALMIN
Endif

# Issue 111414/113 - 2016-03-29 by JUSYN : move update call after receipt of versions
Call UPD_PECFLG(L,L,1)

# Issue 110957 - 2015-10-19 by GH - Setting values for Change Request screen fields
If dim([M:MUX1]CRID)>0
    [M:MUX1]CRID(L)=[M:DIA]CRID
    If dim([M:MUX1]CRFLG)>0
       [M:MUX1]CRFLG(L)=[M:DIA]CRFLG
    Endif
Endif

# GA 02/2008 nomenclature verticale
Gosub ADD_VNOM

# 62779 mm 02.10 - PE permettent d'intervenir sur les lignes du tableau
GPOINT="MULTIMAJ" : Gosub ENTREE From EXEFNC

# copie dans le masque de travail MUXB
nolign = 1
Gosub COP_LINE

L += 1
[M:MUX1]NBLIG = L

Return


#----------------------------------------------------------------------
# alimentation du tableau
$ADD_LINE
[M:MUX1]PECFLG(L)    = 2
# Issue 111414/113 - 2016-03-30 by CCC : Increase LIGNE just if the line is really added (see at the end of $ADD_LINE)
#LIGNE += 1
#[M:MUX1]LIGNE(L)      = LIGNE
[M:MUX1]LIGNE(L)      = LIGNE+1
[M:MUX1]LEVEL(L)      = LEVEL
[M:MUX1]BOMSEQ(L)     = [F:BOD]BOMSEQ
[M:MUX1]PARENT(L)     = [M:MUXB]ITMREF(PLIGNE)            # llc 01.02
[M:MUX1]PARLIN(L)     = PLIGNE
[M:MUX1]PROFLG(L)     = 1
[M:MUX1]ITMREF(L)     = [F:BOD]CPNITMREF

# Issue 111835 - 2015-10-26 by BEEBE : get version for BOD-Line
If dim([M:MUX1]ECCVALMAJ)>0
  [M:MUX1]ECCVALMAJ(L) = [F:BOD]ECCVALMAJ
  [M:MUX1]ECCVALMIN(L) = [F:BOD]ECCVALMIN
Endif

# lecture article
If [F:ITM]ITMREF <> [F:BOD]CPNITMREF
   Read [ITM]ITM0=[F:BOD]CPNITMREF
   If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF <> [F:BOD]CPNITMREF | [F:ITF]ITMREF <> LFCY
   Read [ITF]ITF0=[F:BOD]CPNITMREF;LFCY
   If fstat : Raz [F:ITF] : Endif
Endif

#[M:MUX1]ITMDES1(L)   = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MUX1]ITMDES1(L), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:MUX1]PURFLG(L)    = [F:ITM]PURFLG
[M:MUX1]MFGFLG(L)    = [F:ITM]MFGFLG
[M:MUX1]SCPFLG(L)    = [F:ITM]SCPFLG
[M:MUX1]SCSFLG(L)    = [F:ITM]SCSFLG
[M:MUX1]PHAFLG(L)    = [F:ITM]PHAFLG
[M:MUX1]GENFLG(L)    = [F:ITM]GENFLG
[M:MUX1]TOOFLG(L)    = [F:ITM]TOOFLG
[M:MUX1]DLVFLG(L)    = [F:ITM]DLVFLG
[M:MUX1]SALFLG(L)    = [F:ITM]SALFLG
[M:MUX1]INTFLG(L)    = [F:ITM]INTFLG
[M:MUX1]REOCOD(L)    = [F:ITF]REOCOD
[M:MUX1]PLANNER2(L)  = [F:ITF]PLANNER
[M:MUX1]BUY(L)       = [F:ITF]BUY
[M:MUX1]EXTQTY(L)    = WLIEN
[M:MUX1]STU(L)       = WSTU
# 15119 10.02 MM
#Local Integer WRET
Local Decimal WDIS
Raz WDIS : #,WRET
# FQ 76917 GA 09/2011 Vérifier si on a déjà cet article et qté stock dans le tableau
Local Integer ICPN,WREOCOD
# le find ne peut pas partir du dernier élement du tableau (dernier stock dispo)
# ICPN=find([F:ITM]ITMREF,[M:MUXB]ITMREF([M:MUXB]NBLIG-1..0)
If [M:MUXB]NBLIG>1
  For ICPN = [M:MUXB]NBLIG-1 To 1 Step -1
     If [F:ITM]ITMREF=[M:MUXB]ITMREF(ICPN-1)
        Break
     Endif
  Next
Endif
If ICPN>0
   If [M:MUXB]AVASTO(ICPN-1)>[M:MUXB]EXTQTY(ICPN-1)
      WDIS=[M:MUXB]AVASTO(ICPN-1)-[M:MUXB]EXTQTY(ICPN-1)
   Else WDIS=0
   Endif
Else
   #--- Issue 115110 & 120426 : Added LECCVAL parameter in 10th position
   #Call STODISALL([M:MUX1]MFGFCY,[F:ITM]ITMREF,10,1,2,1,2,"","",,WDIS,WRET) From STKALL
   Call STODISALL([M:MUX1]MFGFCY,[F:ITM]ITMREF,func TRTX3FNC.VALFLD_C("[M:MUX1]ECCVALMAJ("+num$(L)+")"),WDIS) From MFGLIBM
Endif
# FQ 66126 & 64659 GA 07/2010 ne pas proposer un OF si stock dispo
If WDIS>=WLIEN & dim([M:DIA]STODISFLG)>0 & [M:DIA]STODISFLG=2
 # Stock disponible suffisant, on n'affiche pas la ligne (et on ne descend pas plus la nomenclature)
   NOADD=1     #### :  Return # FQ 76917 GA 09/2011 stocker dans [M:MUXB]
   WREOCOD=1
Else
   WREOCOD=[F:ITF]REOCOD
Endif
[M:MUX1]AVASTO(L)    = WDIS
#
[M:MUX1]TCLCOD(L)    = [F:ITM]TCLCOD
[M:MUX1]MGTCOD(L)    = [F:ITM]STDFLG
[M:MUX1]PJT(L)       = [M:DIA]PJT
[M:MUX1]BPRNUM(L)    = [M:DIA]BPCNUM

[M:MUX1]VCRTYPORI(L) = [M:DIA]VCRTYPORI
[M:MUX1]VCRNUMORI(L) = [M:DIA]VCRNUMORI
[M:MUX1]VCRLINORI(L) = [M:DIA]VCRLINORI
[M:MUX1]VCRSEQORI(L) = [M:DIA]VCRSEQORI

[M:MUX1]POHIND(L)    = 1
[M:MUX1]FMI(L)       = 1        ## GH bug 84918 11/10/12 avant ça, n'était fait que pour l'inter_site

# comptage n° ligne courant OF/EO
[M:MUX1]VCRLIN(L)    = WLIN

Case WREOCOD
    When 1  :   # Pas de réappro
                Return
    When 2  :   # Achats
                [M:MUX1]WIPTYP(L) = 2   # POP,POF
                # Issue 82388 GA 06/2012
                # Ctrl si DA obligatoire, on force la POP même si Lancement Ferme demandé
                If [F:ITM]PRQFLG=2 & [M:MUX1]WIPSTA=1
                   [M:PMG]MAJTYP     ="P"
                   [M:PMG]WIPSTA(0)  = 2
                   [M:MUX1]PLNTYP(L) = mess([M:MUX1]WIPTYP(L),341,1)+mess(2,342,1)
                Else
                   [M:MUX1]PLNTYP(L) = mess([M:MUX1]WIPTYP(L),341,1)+mess([M:MUX1]WIPSTA,342,1)
                Endif

                WORIFCY = LFCY
                WORIDAT = LDAT
                WLTI    = [F:BOD]BOMOFS
                # GH 10/04/2013 bug 88882
                #Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB
                #[M:MUX1]ENDDAT(L)   = WDSTDAT
                WLTIJO  = ([F:BOD]BOMALTTYP=2)
                Gosub CAL_BOMOFS_ENDDAT

                # lecture article site - déjà fait + haut
                #Read [ITF]ITF0=[M:MUX1]ITMREF(L);[M:MUX1]MFGFCY
                #If fstat : Raz [F:ITF] : Endif
                WLTI    = [F:ITF]OFS

                WORIFCY = [M:MUX1]MFGFCY
                WORIDAT = [M:MUX1]ENDDAT(L)
               # Issue 88210 GA 02/2013 délai d'achat en jours calendaires, sauf si le PE active GPE
               # calcul date
               # Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MUX1]STRDAT(L)) From MFGLIB
                WLTIJO = 0
                Gosub CAL_PURSTRDAT

                LDAT = [M:MUX1]ENDDAT(L)

                [M:MUX1]PUU(L) = [F:ITM]PUU
                [M:MUX1]PUUSTUCOE(L) = [F:ITM]PUUSTUCOE

                # vérification présence contrat
                OK = 0
                [M:MUX1]POHIND(L) = 1
                ## GH 27/06/2012 bug 83199
                #Filter [POC] Where ITMREF = [M:MUX1]ITMREF(L) & ENDDAT >= WDATEREF & PRHFCY = [M:MUX1]MFGFCY
                ## GH 11/01/2013 bug 87167 WDATEREF remplacé par LDAT
                # Filter [POC] Where ITMREF = [M:MUX1]ITMREF(L) & ENDDAT >= WDATEREF & PRHFCY = [M:MUX1]MFGFCY & STRDAT <= WDATEREF
                Filter [POC] Where ITMREF = [M:MUX1]ITMREF(L) & ENDDAT >= LDAT & PRHFCY = [M:MUX1]MFGFCY & STRDAT <= LDAT
                WPOHNUM = ""
                For [POC]POC2
                    If fstat : Break : Endif
                    If [F:POH]POHNUM <> [F:POC]POHNUM
                        Read [POH]POH0 = [F:POC]POHNUM
                        If fstat : Goto N_POC2 : Endif
                    Endif
                    If !find([F:POH]APPFLG,3,4,5): Goto N_POC2 : Endif
                    If [F:POH]BETFCY = 2 & [F:POH]BETCPY <> 2 : Goto N_POC2 : Endif
                    [M:MUX1]POHIND(L) = 2
                    # si contrat = oui, on récupère le n° de contrat + fournisseur
                    If WPOHNUM = "" : WPOHNUM = [F:POH]POHNUM :  WBPSNUM = [F:POH]BPSNUM : Endif
                    If [M:MUX1]POHNUM(L) <> "" & [F:POC]POHNUM = [M:MUX1]POHNUM(L)
                        [M:MUX1]PUU(L) = [F:POC]PUU
                        OK = 1
                    Endif
$N_POC2
                Next
                Filter [POC]
                #If !OK : [M:MUX1]POHNUM(L) = "" : Endif : ## GH 21/01/13 bug 87000
                If !OK : [M:MUX1]POHNUM(L) = "" : [M:MUX1]BPSNUM(L)="" : Endif
                If [M:MUX1]POHIND(L) = 2  & [M:MUX1]POHNUM(L) = ""
                    [M:MUX1]POHNUM(L) = WPOHNUM
                    [M:MUX1]BPSNUM(L) = WBPSNUM
                Endif
                # recherche fournisseur
                If [M:MUX1]BPSNUM(L) = "" & [M:MUX1]POHIND(L) = 1
                    Filter [ITP] Where ITMREF=[M:MUX1]ITMREF(L) Order By Key ITP1
                    Read [ITP] First
                    If fstat
                        Raz [F:ITP]
                    Else
                        [M:MUX1]BPSNUM(L) = [F:ITP]BPSNUM
                        [M:MUX1]PUU(L)    = [F:ITP]PUU
                        [M:MUX1]PUUSTUCOE(L)    = [F:ITP]PUUSTUCOE
                    Endif
                    Filter [ITP]
                Endif

                Call PCAL_QTY([M:MUX1]EXTQTY(L), [M:MUX1]STU(L),[M:MUX1]PUUPECQTY(L),[M:MUX1]PUU(L),
&                         [M:MUX1]ITMREF(L),[M:MUX1]BPSNUM(L),1,WCOEF) From TRTACHQTE1
                If WCOEF <> 0 : [M:MUX1]PUUSTUCOE(L) = 1/WCOEF : Endif        # 05.01 llc

                [M:MUX1]ROUNUM(L) = ""
                [M:MUX1]BOMALTTYP(L) = 0
                [M:MUX1]ROUALT(L) = 0
                [M:MUX1]BOMALT(L) = 0

    When 3:     # Fabrication
                #Case [M:MUX1]MFGSTA    # GA 02/2008 en V6
                #    When 1: [M:MUX1]PLNTYP(L)    = mess(5,341,1)+mess(2,342,1)
                #    When 2: [M:MUX1]PLNTYP(L)    = mess(5,341,1)+mess(1,342,1)
                #Endcase
                [M:MUX1]WIPTYP(L) = 5 # WOP, WOF
                [M:MUX1]PLNTYP(L) = mess([M:MUX1]WIPTYP(L),341,1)+mess([M:MUX1]WIPSTA,342,1)

                # application du délai par rapport à date début OF
                WORIDAT         = LDAT
                WORIFCY         = LFCY
                WLTI            = [F:BOD]BOMOFS
                # GH 10/04/2013 bug 88882
                #Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB
                #[M:MUX1]ENDDAT(L )   = WDSTDAT
                WLTIJO  = ([F:BOD]BOMALTTYP=2)
                If !WLTIJO : WLTIJO=2 : Endif : # même avec un délai calendaire, il faut tomber sur un jour ouvré
                Gosub CAL_BOMOFS_ENDDAT

                # contrôle présence nomenclature
                Read [TBO]TBO0=2;WBOMALT
                #If fstat : Return : Endif # si WBOMALT KO, recherche d'une autre nomenclature prod
                If fstat : Raz [F:TBO] : Endif

                Read [BOH]BOH0=[F:BOD]CPNITMREF;WBOMALT;2
                If fstat
                    XBOMALT = 0
                Else
                    XBOMALT = WBOMALT
                    Call CONTMFGNOM([M:MUX1]MFGFCY, XBOMALT, LDAT, 0) From MFGLIB
                Endif
                If XBOMALT = 0
                    Call RECH_NOM([M:MUX1]MFGFCY, LDAT, WBOMALT,2) From BENCHLIB
                Endif
                [M:MUX1]BOMALTTYP(L) = 2
                [M:MUX1]BOMALT(L)    = WBOMALT

                If [F:MTS]MFGMODC = 2 | [F:MTS]MFGMODO = 2
                    If [F:ITF]MFGROU = ""
                        [M:MUX1]ROUNUM(L) = [M:MUX1]ITMREF(L)
                    Else
                        [M:MUX1]ROUNUM(L) = [F:ITF]MFGROU
                    Endif

                    Call RECH_GAM([M:MUX1]MFGFCY, LDAT, [M:MUX1]ROUNUM(L), WLIEN, WSTU, WBOMALT, WROUALT)   From BENCHLIB
                    # llc 06.04 22880
                    If WROUALT <> 0
                        [M:MUX1]ROUALT(L) = WROUALT
                    Else
                        [M:MUX1]ROUNUM(L) = ""
                    Endif
                Endif

                REFDAT = [M:MUX1]ENDDAT(L)
                # jalonnement amont
                Gosub CAL_JAL_AM

                LDAT = [M:MUX1]STRDAT(L)

                # 14123 10.02 MM
                If find([F:ITM]LOTMGTCOD, 2, 3) & NOADD<>1
                    [M:MUX1]LOT(L)       = mess(62,193,1)
                Endif
                #
                [M:MUX1]MFGDES(L)    = [M:DIA]MFGDES

                [M:MUX1]PUU(L) = ""
                [M:MUX1]PUUSTUCOE(L) = 0
                [M:MUX1]PUUPECQTY(L) = 0 : ## GH 03/05/2013 bug 89734
                [M:MUX1]POHIND(L) = 1
                [M:MUX1]POHNUM(L) = ""
                [M:MUX1]BPSNUM(L) = ""

    When 4:     # intersite
                #Case [M:MUX1]MFGSTA    # GA 02/2008 en V6
                #    When 1: [M:MUX1]PLNTYP(L)    = mess(7,341,1)+mess(2,342,1)
                #    When 2: [M:MUX1]PLNTYP(L)    = mess(7,341,1)+mess(1,342,1)
                #Endcase
                [M:MUX1]WIPTYP(L) = 7
                [M:MUX1]PLNTYP(L) = mess([M:MUX1]WIPTYP(L),341,1)+mess([M:MUX1]WIPSTA,342,1)

                WORIDAT         = LDAT
                WORIFCY         = LFCY
                WLTI            = [F:BOD]BOMOFS
                # GH 10/04/2013 bug 88882
                #Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB
                #[M:MUX1]ENDDAT(L )   = WDSTDAT
                WLTIJO  = ([F:BOD]BOMALTTYP=2)
                Gosub CAL_BOMOFS_ENDDAT

                # lecture article site - déjà fait + haut
                #Read [ITF]ITF0=[M:MUX1]ITMREF(L);[M:MUX1]MFGFCY
                #If fstat : Raz [F:ITF] : Endif
                WLTI    = [F:ITF]OFS

                [M:MUX1]ORIFCY(L) = [F:ITF]REOFCY
                WORIDAT = [M:MUX1]ENDDAT(L)
                WORIFCY = [M:MUX1]MFGFCY

               # Issue 88210 GA 02/2013 délai d'achat en jours calendaires, sauf si le PE active GPE
               # calcul date
               # Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MUX1]STRDAT(L)) From MFGLIB
                WLTIJO = 0
                Gosub CAL_PURSTRDAT

                LDAT = [M:MUX1]ENDDAT(L)

                If [M:MUX1]ITMREF(L) = "" : [M:MUX1]ITMREF(L) = [F:BOD]CPNITMREF : Endif

                # vérification présence contrat
                OK = 0
                [M:MUX1]POHIND(L) = 1
                # GH 27/06/2012 bug 83199
                #Filter [POC] Where ITMREF = [M:MUX1]ITMREF(L) & ENDDAT >= WDATEREF & PRHFCY = [M:MUX1]MFGFCY
                ## GH 11/01/2013 bug 87167 WDATEREF remplacé par LDAT
                # Filter [POC] Where ITMREF = [M:MUX1]ITMREF(L) & ENDDAT >= WDATEREF & PRHFCY = [M:MUX1]MFGFCY & STRDAT <= WDATEREF
                Filter [POC] Where ITMREF = [M:MUX1]ITMREF(L) & ENDDAT >= LDAT & PRHFCY = [M:MUX1]MFGFCY & STRDAT <= LDAT
                WPOHNUM = ""
                For [POC]POC2
                    If fstat : Break : Endif
                    If [F:POH]POHNUM <> [F:POC]POHNUM
                        Read [POH]POH0 = [F:POC]POHNUM
                        If fstat : Goto N_POC1 : Endif
                    Endif
                    If !find([F:POH]APPFLG,3,4,5): Goto N_POC1 : Endif
                    If [F:POH]BETFCY <> 2 | [F:POH]BETCPY = 2 : Goto N_POC1 : Endif
                    [M:MUX1]POHIND(L) = 2
                    # si contrat = oui, on récupère le n° de contrat + fournisseur
                    If WPOHNUM = "" : WPOHNUM = [F:POH]POHNUM :  WBPSNUM = [F:POH]BPSNUM : Endif
                    If [M:MUX1]POHNUM(L) <> "" & [F:POC]POHNUM = [M:MUX1]POHNUM(L)
                        [M:MUX1]PUU(L) = [F:POC]PUU
                        OK = 1
                    Endif
$N_POC1
                Next
                Filter [POC]
                #If !OK : [M:MUX1]POHNUM(L) = "" : Endif : ## GH 21/01/13 bug 87000
                If !OK : [M:MUX1]POHNUM(L) = "" : [M:MUX1]BPSNUM(L)="" : Endif
                If [M:MUX1]POHIND(L) = 2  & [M:MUX1]POHNUM(L) = ""
                    [M:MUX1]POHNUM(L) = WPOHNUM
                    [M:MUX1]BPSNUM(L) = WBPSNUM
                Endif
                # recherche fournisseur
                If [M:MUX1]BPSNUM(L) = "" & [M:MUX1]POHIND(L) = 1
                    Filter [ITP] Where ITMREF=[M:MUX1]ITMREF(L) Order By Key ITP1
                    Read [ITP] First
                    If fstat
                        Raz [F:ITP]
                    Else
                        [M:MUX1]BPSNUM(L) = [F:ITP]BPSNUM
                        [M:MUX1]PUU(L)    = [F:ITP]PUU
                        [M:MUX1]PUUSTUCOE(L)    = [F:ITP]PUUSTUCOE
                    Endif
                    Filter [ITP]
                Endif

                Call PCAL_QTY([M:MUX1]EXTQTY(L), [M:MUX1]STU(L),[M:MUX1]PUUPECQTY(L),[M:MUX1]PUU(L),
&                             [M:MUX1]ITMREF(L),[M:MUX1]BPSNUM(L),1,WCOEF) From TRTACHQTE1
                If WCOEF <> 0 : [M:MUX1]PUUSTUCOE(L) = 1/WCOEF : Endif

                [M:MUX1]ROUNUM(L) = ""
                [M:MUX1]ROUALT(L) = 0
                [M:MUX1]BOMALT(L) = 0

    When 5:     # Sous-traitance V6 GA 02/2008
                If [M:MUX1]SCPFLG(L) = 2      # Article sous-traité/ Subconctract order
                   [M:MUX1]WIPTYP(L) = 13     # GA 02/2008 en V6 EOP,EOF
                Elsif [M:MUX1]SCSFLG(L) = 2   # Article sous-traitance/ Subcontracted service
                   [M:MUX1]WIPTYP(L) = 4      # GA 02/2008 en V6 SCP,SCF
                Endif
                [M:MUX1]PLNTYP(L) = mess([M:MUX1]WIPTYP(L),341,1)+mess([M:MUX1]WIPSTA,342,1)

                # application du délai par rapport à date début OF
                WORIDAT         = LDAT
                WORIFCY         = LFCY
                WLTI            = [F:BOD]BOMOFS
                # GH 10/04/2013 bug 88882
                #Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB
                #[M:MUX1]ENDDAT(L )   = WDSTDAT
                WLTIJO  = ([F:BOD]BOMALTTYP=2)
                If !WLTIJO : WLTIJO=2 : Endif : # même avec un délai calendaire, il faut tomber sur un jour ouvré
                Gosub CAL_BOMOFS_ENDDAT

                # contrôle présence nomenclature
                Read [TBO]TBO0=3;WBOMALT
                #If fstat : Return : Endif # si WBOMALT KO, recherche d'une autre nomenclature SST
                If fstat : Raz [F:TBO] : Endif

                Read [BOH]BOH0=[M:MUX1]ITMREF(L);WBOMALT;3
                If fstat
                   XBOMALT = 0
                Else
                   XBOMALT = WBOMALT
                   Call CONTSCONOM([M:MUX1]MFGFCY, XBOMALT, LDAT, 0) From SCOLIB
                Endif
                If XBOMALT = 0
                    Call RECH_NOM([M:MUX1]MFGFCY, LDAT, WBOMALT,3) From BENCHLIB
                Endif
                [M:MUX1]BOMALTTYP(L) = 3
                [M:MUX1]BOMALT(L) = WBOMALT

                [M:MUX1]BPSNUM(L) = "" : # [M:MUX1]BPSNUM(L) = WBPSNUM : ## GH 21/01/13 bug 87000
                # recherche du fournisseur par défaut
                Call FIND_BPRNUM([M:MUX1]ITMREF(L),WBOMALT,"",LFCY,[M:MUX1]BPSNUM(L)) From SCOLIB
                # recherche du délai du service associé
                WSRVITMREF = "" : XLTI=0
                # Call FIND_LTI ([M:MUX1]ITMREF(L),[M:MUX1]BPSNUM(L),LFCY,WLTI) From SCOLIB
                Call FIND_SCI_LTI([M:MUX1]ITMREF(L),[M:MUX1]BPSNUM(L),LFCY,WBOMALT,WSRVITMREF,XLTI) From SCOLIB
                WLTI = XLTI

                WORIDAT = [M:MUX1]ENDDAT(L)
                WORIFCY = [M:MUX1]MFGFCY
               # Issue 88210 GA 02/2013 délai d'achat en jours calendaires, sauf si le PE active GPE
               # calcul date
               # Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MUX1]STRDAT(L)) From MFGLIB
                WLTIJO = 2
                Gosub CAL_PURSTRDAT

                #LDAT = [M:MUX1]ENDDAT(L) : # GH 24/05/2013
                LDAT = [M:MUX1]STRDAT(L)

                ## GH 12/04/2013
                If find([F:ITM]LOTMGTCOD, 2, 3) & NOADD<>1
                    [M:MUX1]LOT(L)       = mess(62,193,1)
                Endif
                [M:MUX1]MFGDES(L)    = [M:DIA]MFGDES

                # recherche unité d'achat et coeff UA-US
                [M:MUX1]PUU(L) = [F:ITM]PUU
                [M:MUX1]PUUSTUCOE(L) = [F:ITM]PUUSTUCOE
                [M:MUX1]POHNUM(L) = "" : # [M:MUX1]POHNUM(L) = WPOHNUM : ## GH 21/01/13 bug 87000
                If [M:MUX1]BPSNUM(L)="" : # & [M:MUX1]POHIND(L) = 1
                    Filter [ITP] Where ITMREF=[M:MUX1]ITMREF(L) & BOMALT=WBOMALT Order By Key ITP1
                    Read [ITP] First
                    Filter [ITP]
                Elsif [F:ITP]ITMREF<>[M:MUX1]ITMREF(L) | [F:ITP]BPSNUM<>[M:MUX1]BPSNUM(L)
                   Read [ITP]ITP0=[M:MUX1]ITMREF(L);[M:MUX1]BPSNUM(L)
                Endif
                If fstat
                   Raz [F:ITP]
                Else
                   [M:MUX1]BPSNUM(L)     = [F:ITP]BPSNUM
                   [M:MUX1]PUU(L)        = [F:ITP]PUU
                   [M:MUX1]PUUSTUCOE(L)  = [F:ITP]PUUSTUCOE
                Endif

                Call PCAL_QTY([M:MUX1]EXTQTY(L), [M:MUX1]STU(L),[M:MUX1]PUUPECQTY(L),[M:MUX1]PUU(L),
&                         [M:MUX1]ITMREF(L),[M:MUX1]BPSNUM(L),1,WCOEF) From TRTACHQTE1
                If WCOEF <> 0 : [M:MUX1]PUUSTUCOE(L) = 1/WCOEF : Endif        # 05.01 llc

                [M:MUX1]ROUNUM(L) = ""
                [M:MUX1]ROUALT(L) = 0
Endcase

# Issue 111414/11 - 2016-02-11 by JUSYN : Moved for check versions
#Call UPD_PECFLG(L,L)

# Issue 111835 - 2015-10-26 by BEEBE : check version for BOD-Line, if version couldn´t
#                be selected from BOD
If dim([M:MUX1]ECCVALMAJ)>0 & [M:MUX1]ECCVALMAJ(L)=""
    If func ECCLIB.NBRCPN([M:MUX1]ITMREF(L))
        If WREOCOD=3 | WREOCOD=5
            # if WOP/WOF or EOP/EOF
            Local Integer LALT

            # ECC preload of major and minor version + BOM code
            LALT = [M:MUX1]BOMALT(L)

            If WREOCOD=3
                Call INIECCBOM([M:MUX1]ITMREF(L), [M:MUX1]MFGFCY, [M:MUX1]STRDAT(L), 2, [M:MUX1]ECCVALMAJ(L),[M:MUX1]ECCVALMIN(L),LALT) From MFGECCLIB
            Else
                Call INIECCBOM([M:MUX1]ITMREF(L), [M:MUX1]MFGFCY, [M:MUX1]STRDAT(L), 3, [M:MUX1]ECCVALMAJ(L),[M:MUX1]ECCVALMIN(L),LALT) From MFGECCLIB
            Endif
            [M:MUX1]BOMALT(L)=LALT
            Affzo [M:MUX1]BOMALT(L)
        Else
            # else if POP/POF/TPF/TPP
            Call INIECCITM([M:MUX1]ITMREF(L), [M:MUX1]MFGFCY, [M:MUX1]STRDAT(L), [M:MUX1]ECCVALMAJ(L),[M:MUX1]ECCVALMIN(L),4) From MFGECCLIB
        Endif
        Affzo [M:MUX1]ECCVALMAJ(L), ECCVALMIN(L)
    Else
        Effzo [M:MUX1]ECCVALMAJ(L), ECCVALMIN(L)
    Endif
Endif

# Issue 110957 - 2015-10-19 by GH - Setting values for Change Request screen fields
If dim([M:MUX1]CRID)>0
    [M:MUX1]CRID(L) = func TRTX3FNC.CCMID([M:MUX1]ITMREF(L)
&                                        ,func TRTX3FNC.VALFLD_C("[M:MUX1]ECCVALMAJ("+num$(L)+")")
&                                        ,func TRTX3FNC.VALFLD_C("[M:MUX1]ECCVALMIN("+num$(L)+")"))
    If dim([M:MUX1]CRFLG)>0
       [M:MUX1]CRFLG(L) = string$([M:MUX1]CRID(L)<>"","151")
    Endif
Endif

# Issue 111414/11 - 2016-02-11 by JUSYN : LOAD OF ROUTE VERSIONS
If dim([M:MUX1]ROUECCMAJ(L)) > 0
    If WREOCOD=3
        # Route versions taken by scheduling because production scheduling is always in backward mode are calculated by end date.
        If func RVMLIB.NBRCPNROU([M:MUX1]ROUNUM(L)) > 0
            Call INIECCROU([M:MUX1]ROUNUM(L),[M:MUX1]MFGFCY,[M:MUX1]ENDDAT(L),[M:MUX1]ROUALT(L),[M:MUX1]ROUECCMAJ(L),[M:MUX1]ROUECCMIN(L)) From RVMLIB
        Endif
    Endif
Endif

# Issue 111414/11 - 2016-02-11 by JUSYN : Moved for check versions
Call UPD_PECFLG(L,L,1)

If !NOADD       # FQ 66126 GA 09/2010 ADD_VNOM avant COP_LINE sauf si NOADD
  # GA 02/2008 nomenclature verticale
    Gosub ADD_VNOM
Endif

# 62779 mm 02.10 - PE permettent d'intervenir sur les lignes du tableau
GPOINT="MULTIMAJ" : Gosub ENTREE From EXEFNC

# si indicateur NOADD = 1, on a calculé la ligne pour obtenir la date, mais pas d'affichage
# donc on copie dans masque travail MUXB
Gosub COP_LINE
If NOADD Return Endif   # FQ 66126

# Issue 111414/113 - 2016-03-30 by CCC : Increase LIGNE just if the line is really added
LIGNE+=1

L += 1
[M:MUX1]NBLIG = L

# 15119 10.02 MM : Disponibilité à date
Gosub DISPREV

Return


$ADD_VNOM
############################################################################
# GA 02/2008 nomenclature verticale certains noms de champs sont prédéfinis
# NBLIG  : variable <Bas de tableau>
# PARKEY : clé précédente   (composé)
# KEYC   : clé courante     (composant)
# LIBL1  : libellé long
# LIBSH  : info-bulle       (facultatif)
# EXP    : ouvrir le niveau (facultatif)
############################################################################
If dim([M:MUX1]KEYC)  >0
   [M:MUX1]KEYC(L)      = [M:MUX1]ITMREF(L) +"-"+ num$([M:MUX1]BOMSEQ(L))
   If [M:MUX1]PARLIN(L)<>-1
      [M:MUX1]PARKEY(L) = [M:MUXB]KEYC([M:MUX1]PARLIN(L))
   Else
      [M:MUX1]PARKEY(L) = ""
   Endif
Endif
If dim([M:MUX1]LIBL1) >0 [M:MUX1]LIBL1(L)   = [M:MUX1]PLNTYP(L) - [M:MUX1]ITMREF(L) - [M:MUX1]ITMDES1(L)      Endif
If dim([M:MUX1]LIBSH) >0 [M:MUX1]LIBSH(L)   = mess([M:MUX1]WIPTYP(L),306,1) - mess([M:MUX1]MFGSTA,370,1) Endif
# icône associée nomenclature verticale
If dim([M:MUX1]ICO)>0
   Case [M:MUX1]WIPTYP(L)
      When 5,13 :  [M:MUX1]ICO(L)=WICO_PRODG        # FQ 63448 "folder_gear.png"
      When 2    :  [M:MUX1]ICO(L)=WICO_ENDG         # FQ 63448 "folder_into.png"
      When 7    :  [M:MUX1]ICO(L)=WICO_TRFG         # FQ 63448 "mvt2.gif"
      When Default  :  [M:MUX1]ICO(L)=WICO_ENDG     # FQ 63448 "Folder.gif"
   Endcase
Endif
Return
########################################################################
$LISTE_ICONES                                               # FQ 63448 #
# Production (WOx)
If func CTL_FIC_ICONE("folder_gear.png")=2
   WICO_PRODG = "folder_gear.png"
Else
   WICO_PRODG = "produit.png"
Endif

# feuilles de l'arborescence (POx)
If func CTL_FIC_ICONE("folder_into.png")=2
   WICO_ENDG = "folder_into.png"
Else
   WICO_ENDG = "matierepremiere.gif" # "box_closed.png"
Endif

# inter-site transferts (TRx)
If func CTL_FIC_ICONE("mvt2.gif")=2
   WICO_TRFG = "mvt2.gif"
Endif

Return
############################################################
Funprog CTL_FIC_ICONE (LNOMICON)                # FQ 63448 #
Value Char LNOMICON
Local Integer WOK : WOK=2

Local Char WREPERT(200),WDIRSEP
Case GOS(1)
 When "dos"  : WDIRSEP="\"
 When Default : WDIRSEP="/"
Endcase

WREPERT=filpath("X3_ROOT"+WDIRSEP+"RESSTD"+WDIRSEP+"IMG","","","X3_PUB")
If LNOMICON<>"" & filinfo(WREPERT+WDIRSEP+LNOMICON,0)<0
   WOK = 1
Endif
End WOK
############################################################
#----------------------------------------------------------------------
# 15119 10.02 MM
# Disponibilité des composants à date
$DISPREV
Local Decimal WPHY
Local Decimal WTRF
Local Decimal WALL
Local Decimal WRER
Local Decimal WWAI
Local Decimal WQTY
Local Decimal WEXT,WEXT2
Local Decimal WSTO
Local Char    WSIG(1)
Local Date    WFIRAVADAT
Local Date    TODAY : TODAY = date$
Local Integer WRET

Raz WPHY,WTRF,WALL,WRER,WWAI,WEXT,WEXT2
Call LECITV2([M:MUX1]MFGFCY,[M:MUX1]ITMREF(nolign-1),WRET)From MFGLIB
If WRET<>0 : Return : Endif

WPHY += [F:ITV]PHYSTO
WTRF += [F:ITV]TRFSTO
WALL += [F:ITV]PHYALL    + [F:ITV]CTLALL     + [F:ITV]REJALL
WRER += [F:ITV]GLOALL
WWAI += [F:ITV]WAISTO

If WPHY <>0
 WSTO = WPHY
 WSIG ="+"
 Gosub LOA_INI
Endif

If WTRF <>0
 WSTO = WTRF
 WSIG = "+"
 Gosub LOA_INI
Endif

If WALL <>0
 WSTO = WALL
 WSIG ="-"
 Gosub LOA_INI
Endif

If WRER<>0
 WSTO = WRER
 WSIG = "-"
 Gosub LOA_INI
Endif

If WWAI<>0
 WSTO= WWAI
 WSIG="-"
 Gosub LOA_INI
Endif

Filter [ORD] Where STOFCY=[M:MUX1]MFGFCY &
&                  ITMREF=[M:MUX1]ITMREF(nolign-1)
&                  Order By Key ORD1

WFIRAVADAT= [0/0/0]

For [ORD]

    # --------- 03.06 34890
    GPE = 0
    GPOINT="CHECKORD" : Gosub ENTREE From EXEFNC
    If GPE : Goto SPREV : Endif
    #----------

    If [F:ORD]WIPTYP=1 & [F:ORD]WIPSTA=3 : Goto SPREV : Endif
    If find([F:ORD]WIPTYP,1,3,4,6,8)
        WSIG ="-"
    Else
        WSIG ="+"
    Endif
    WQTY = ([F:ORD]RMNEXTQTY-[F:ORD]ALLQTY)
    Case WSIG
        When "-" : If [F:ORD]ENDDAT <[M:MUX1]STRDAT(nolign-1)
                        WEXT  -=WQTY
                        WEXT2 -=WQTY
                   Else
                        WEXT2 -=WQTY
                   Endif
        When "+": If [F:ORD]ENDDAT <[M:MUX1]STRDAT(nolign-1)
                        WEXT  +=WQTY
                        WEXT2 +=WQTY
                  Else
                        WEXT2 +=WQTY
                  Endif
    Endcase
    If WFIRAVADAT=[0/0/0]
        If WEXT2 >0 : WFIRAVADAT=[F:ORD]ENDDAT : Endif
    Endif
    If WFIRAVADAT <>[0/0/0] & WFIRAVADAT< TODAY & [F:ORD]ENDDAT < TODAY
        If WEXT2 <=0 : WFIRAVADAT=[0/0/0] : Endif
    Endif
$SPREV
Next

If  WFIRAVADAT <>[0/0/0] & WFIRAVADAT< TODAY  :  WFIRAVADAT = TODAY : Endif
Filter [ORD]

[M:MUX1]DISSTO(nolign-1)= WEXT
[M:MUX1]FIRAVADAT(nolign-1)=WFIRAVADAT

Return
#----------------------------------------------------------------------
# 15119 10.02 MM
$LOA_INI
Case WSIG
    When "-" : WEXT  -= WSTO
               WEXT2 -= WSTO
    When "+" : WEXT  += WSTO
               WEXT2 += WSTO
Endcase

Return
#----------------------------------------------------------------------
# copie ligne de [M:MUX1] vers [M:MUXB]
$COP_LINE
nolign = [M:MUXB]NBLIG + 1
[M:MUXB]LIGNE(nolign-1)     = [M:MUX1]LIGNE(L)
[M:MUXB]LEVEL(nolign-1)     = [M:MUX1]LEVEL(L)

[M:MUXB]ITMREF(nolign-1)    = [M:MUX1]ITMREF(L)
[M:MUXB]BOMSEQ(nolign-1)    = [M:MUX1]BOMSEQ(L)
[M:MUXB]PARENT(nolign-1)    = [M:MUX1]PARENT(L)
[M:MUXB]PARLIN(nolign-1)    = [M:MUX1]PARLIN(L)
[M:MUXB]PROFLG(nolign-1)    = [M:MUX1]PROFLG(L)

[M:MUXB]ITMDES1(nolign-1)   = [M:MUX1]ITMDES1(L)
[M:MUXB]PURFLG(nolign-1)    = [M:MUX1]PURFLG(L)
[M:MUXB]MFGFLG(nolign-1)    = [M:MUX1]MFGFLG(L)
[M:MUXB]SCPFLG(nolign-1)    = [M:MUX1]SCPFLG(L)
[M:MUXB]SCSFLG(nolign-1)    = [M:MUX1]SCSFLG(L)
[M:MUXB]PHAFLG(nolign-1)    = [M:MUX1]PHAFLG(L)
[M:MUXB]GENFLG(nolign-1)    = [M:MUX1]GENFLG(L)
[M:MUXB]TOOFLG(nolign-1)    = [M:MUX1]TOOFLG(L)
[M:MUXB]DLVFLG(nolign-1)    = [M:MUX1]DLVFLG(L)
[M:MUXB]SALFLG(nolign-1)    = [M:MUX1]SALFLG(L)
[M:MUXB]INTFLG(nolign-1)    = [M:MUX1]INTFLG(L)
[M:MUXB]REOCOD(nolign-1)    = [M:MUX1]REOCOD(L)
[M:MUXB]AVASTO(nolign-1)    = [M:MUX1]AVASTO(L)   # FQ 76917 GA 09/2011
[M:MUXB]DISSTO(nolign-1)    = [M:MUX1]DISSTO(L)   # FQ 76917 GA 09/2011
[M:MUXB]EXTQTY(nolign-1)    = [M:MUX1]EXTQTY(L)
[M:MUXB]STU(nolign-1)       = [M:MUX1]STU(L)
[M:MUXB]TCLCOD(nolign-1)    = [M:MUX1]TCLCOD(L)
[M:MUXB]MGTCOD(nolign-1)    = [M:MUX1]MGTCOD(L)
[M:MUXB]PJT(nolign-1)       = [M:MUX1]PJT(L)
[M:MUXB]BPRNUM(nolign-1)    = [M:MUX1]BPRNUM(L)
[M:MUXB]VCRTYPORI(nolign-1) = [M:MUX1]VCRTYPORI(L)
[M:MUXB]VCRNUMORI(nolign-1) = [M:MUX1]VCRNUMORI(L)
[M:MUXB]VCRLINORI(nolign-1) = [M:MUX1]VCRLINORI(L)
[M:MUXB]VCRSEQORI(nolign-1) = [M:MUX1]VCRSEQORI(L)
[M:MUXB]PLANNER2(nolign-1)  = [M:MUX1]PLANNER2(L)
[M:MUXB]BUY(nolign-1)       = [M:MUX1]BUY(L)
[M:MUXB]POHIND(nolign-1)    = [M:MUX1]POHIND(L)
[M:MUXB]POHNUM(nolign-1)    = [M:MUX1]POHNUM(L)
[M:MUXB]LOT(nolign-1)       = [M:MUX1]LOT(L)                # 14123 10.02 MM
[M:MUXB]PLNTYP(nolign-1)    = [M:MUX1]PLNTYP(L)
[M:MUXB]WIPTYP(nolign-1)    = [M:MUX1]WIPTYP(L)             # GA 02/2008 V6
[M:MUXB]ORIFCY(nolign-1)    = [M:MUX1]ORIFCY(L)
[M:MUXB]STRDAT(nolign-1)    = [M:MUX1]STRDAT(L)
[M:MUXB]ENDDAT(nolign-1)    = [M:MUX1]ENDDAT(L)
[M:MUXB]POPLIN(nolign-1)    = [M:MUX1]POPLIN(L)

[M:MUXB]BPSNUM(nolign-1)    = [M:MUX1]BPSNUM(L)
[M:MUXB]PUU(nolign-1)       = [M:MUX1]PUU(L)

[M:MUXB]PUUPECQTY(nolign-1) = [M:MUX1]PUUPECQTY(L)
[M:MUXB]PUUSTUCOE(nolign-1) = [M:MUX1]PUUSTUCOE(L)

[M:MUXB]BOMALT(nolign-1)    = [M:MUX1]BOMALT(L)
[M:MUXB]ROUNUM(nolign-1)    = [M:MUX1]ROUNUM(L)
[M:MUXB]ROUALT(nolign-1)    = [M:MUX1]ROUALT(L)

If dim([M:MUXB]VCRNUM)>0                                    # GA 04/2008 V6 Réseau MTO FQ 46650
   [M:MUXB]VCRTYP(nolign-1) = [M:MUX1]VCRTYP(L)
   [M:MUXB]VCRNUM(nolign-1) = [M:MUX1]VCRNUM(L)
   [M:MUXB]VCRLIN(nolign-1) = [M:MUX1]VCRLIN(L)
   [M:MUXB]VCRSEQ(nolign-1) = [M:MUX1]VCRSEQ(L)
Endif

# GA 02/2008 nomenclature verticale
If dim([M:MUXB]KEYC)>0
  [M:MUXB]PARKEY(nolign-1)  = [M:MUX1]PARKEY(L)
  [M:MUXB]KEYC  (nolign-1)  = [M:MUX1]KEYC  (L)
  [M:MUXB]LIBL1 (nolign-1)  = [M:MUX1]LIBL1 (L)
  [M:MUXB]LIBSH (nolign-1)  = [M:MUX1]LIBSH (L)
  [M:MUXB]ICO   (nolign-1)  = [M:MUX1]ICO   (L)
Endif

# Issue 111835 - 2015-10-26 by BEEBE : copy version fields
If dim([M:MUXB]ECCVALMAJ)>0
    [M:MUXB]ECCVALMAJ(nolign-1) = [M:MUX1]ECCVALMAJ(L)
    [M:MUXB]ECCVALMIN(nolign-1) = [M:MUX1]ECCVALMIN(L)
Endif

# Issue 111414/11 - 2016-02-11 by JUSYN : copy routing version fields
If dim([M:MUXB]ROUECCMAJ)>0
    [M:MUXB]ROUECCMAJ(nolign-1) = [M:MUX1]ROUECCMAJ(L)
    [M:MUXB]ROUECCMIN(nolign-1) = [M:MUX1]ROUECCMIN(L)
Endif

[M:MUXB]NBLIG=nolign
Return

#----------------------------------------------------------------------
# lecture fichiers
$LEC_FILES
# lecture entete nomenclature
Read [BOH]BOH0=LITM;LALT;LTYP
If fstat : Return : Endif

# FQ 72412 GA 03/2011
If [F:ITM]ITMREF <> LITM
    Read [ITM]ITM0= LITM
Endif

WSCATIA = 0
# lecture article/site composé
If [F:ITF]ITMREF <> LITM | [F:ITF]STOFCY <> LFCY
    Read [ITF]ITF0=LITM;LFCY
    If fstat : WSCATIA = 1 : Endif
Endif
If WSCATIA = 0
    If [F:ITF]RELSCATIA <> 1 : WSCATIA = 1 : Endif
Endif

Return

#----------------------------------------------------------------------
# recalcul en aval
$REJAL
Local Integer I,J,L
Local Date    REFDAT
Local Date    MINDAT  : MINDAT = [0/0/0]

Call TEMPON(mess(413,197,1)) From GESECRAN

# avant de commencer on raffraichit [MUXB]
For I = 0 To [M:MUX1]NBLIG - 1
    For L = 0 To [M:MUXB]NBLIG - 1
        If [M:MUXB]LIGNE(L) = [M:MUX1]LIGNE(I)
            [M:MUXB]STRDAT(L) = [M:MUX1]STRDAT(I)
            [M:MUXB]ENDDAT(L) = [M:MUX1]ENDDAT(I)
            [M:MUXB]EXTQTY(L) = [M:MUX1]EXTQTY(I)
            [M:MUXB]BOMALT(L) = [M:MUX1]BOMALT(I)
            [M:MUXB]ROUNUM(L) = [M:MUX1]ROUNUM(I)
            [M:MUXB]ROUALT(L) = [M:MUX1]ROUALT(I)
            # Issue 111414/113 - 2016-03-31 by JUSYN : route version missing for scheduling
            If dim([M:MUX1]ROUECCMAJ) > 0
                [M:MUXB]ROUECCMAJ(L) = [M:MUX1]ROUECCMAJ(I)
                [M:MUXB]ROUECCMIN(L) = [M:MUX1]ROUECCMIN(I)
            Endif
        Endif
    Next L
Next I

# recherche date la + ancienne parmi les lignes cochées ou toutes les lignes si aucune ligne cochée
J=find(2,[M:MUX1]PECFLG(0..[M:MUX1]NBLIG-1))
For I = 0 To [M:MUX1]NBLIG - 1
    If J & [M:MUX1]PECFLG(I) = 1 : Goto NREJ : Endif
    If MINDAT = [0/0/0] : MINDAT = [M:MUX1]STRDAT(I) : Endif
    If [M:MUX1]STRDAT(I) < MINDAT : MINDAT = [M:MUX1]STRDAT(I) : L = I : Endif
$NREJ
Next I

# correspondance dans MUXB
For J = 0 To [M:MUXB]NBLIG - 1
    If [M:MUXB]LIGNE(J) = [M:MUX1]LIGNE(L) : L = J : Break : Endif
Next J

# recalcul date fin pour la ligne la + ancienne
I = 0
REFDAT = [M:MUX1]FIRRELDAT
Gosub CAL_JAL_AVB                # 03.06 34891
[M:MUXB]PROFLG(L) = 2

# répercution de ce changement
Call RECAL_TAB_UP([M:MUXB]PARENT(L), [M:MUXB]PARLIN(L), [M:MUXB]ENDDAT(L))

# mise à jour affichage
For I = 0 To [M:MUX1]NBLIG - 1
    For L = 0 To [M:MUXB]NBLIG - 1
        If [M:MUXB]LIGNE(L) = [M:MUX1]LIGNE(I)
            [M:MUX1]STRDAT(I) = [M:MUXB]STRDAT(L)
            [M:MUX1]ENDDAT(I) = [M:MUXB]ENDDAT(L)
        Endif
    Next L
Next I

# raz du flag recalcul
For I = 0 To [M:MUXB]NBLIG - 1
    [M:MUXB]PROFLG(I) = 1
Next I

# Issue 111414/11 - 2016-02-11 by JUSYN : Versions flag
# revision flag PEC
Call UPD_PECFLG(0,[M:MUX1]NBLIG-1,1)

# revision bilan
Call BILAN

Call TEMPOFF From GESECRAN

Affzo [MUX1]1-99
Return

# Issue 111414/11 - 2016-02-11 by JUSYN : Versions flag ICTLECCFLG
#----------------------------------------------------------------------
Subprog UPD_PECFLG(IDEB,IFIN,ICTLECCFLG)
Value Integer IDEB, IFIN, ICTLECCFLG
Local Integer I
Local Integer LRET
Local Char    LMESSAGE(250)

For I = IDEB To IFIN
    If [M:MUX1]STRDAT(I) < date$
       [M:MUX1]PECFLG(I) = 1
    Else
       Case [M:MUX1]REOCOD(I)
        When 4,5:    # Intersite, SST # GH 15/04/2013 ajout du cas 5 (sous-traitance)
                     If [M:MUX1]BPSNUM(I) = "" | [M:MUX1]PUUPECQTY(I) = 0
                        [M:MUX1]PECFLG(I) = 1
                     Endif
        When 2:      # Achat # GH 15/04/2013 retrait du cas 5 (sous-traitance)
                     If  ([M:MUX1]MFGSTA = 2 & [M:MUX1]BPSNUM(I) = "") | [M:MUX1]PUUPECQTY(I) = 0
                         [M:MUX1]PECFLG(I) = 1
                     Endif
        When 3:      # Fabrication
                     If ([F:MTS]MFGMODM = 1  &  [M:MUX1]ROUNUM(I) = "") |
&                       ([F:MTS]MFGMODM = 1  &  [M:MUX1]ROUALT(I) = 0)  |
&                        [M:MUX1]BOMALT(I) = 0
                         [M:MUX1]PECFLG(I) = 1
                     Endif
                     # Issue 111414/11 - 2016-02-11 by JUSYN :
                     # BOM / Route version consistency check
                     If ICTLECCFLG > 0
                         If dim([M:MUX1]ROUECCMAJ) > 0 & func RVMLIB.NBRCPNROU([M:MUX1]ROUNUM(I)) > 0
                             # Check whether route versions are valid for start date
                             If [M:MUX1]ROUNUM(I) <> ""
                                 Call CTRROUECC([M:MUX1]ROUNUM(I),[M]MFGFCY,"MUX1","STRDAT",[M:MUX1]ROUECCMAJ(I),[M:MUX1]ROUECCMIN(I),
&                                               [M:MUX1]STRDAT(I),LRET,LMESSAGE) From RVMLIB
                             Endif
                             If find(LRET,1,4)
                                 [M:MUX1]PECFLG(I) = 1
                             Endif
                         Endif
                         # BOM version consistency check
                         # Check whether BOM versions are valid for start date
                         If dim([M:MUX1]ECCVALMAJ) > 0 & func ECCLIB.NBRCPN([M:MUX1]ITMREF(I)) > 0
                             Call CTRECC([M:MUX1]ITMREF(I),"MUX1","STRDAT",[M:MUX1]ECCVALMAJ(I),[M:MUX1]ECCVALMIN(I),
&                                        [M:MUX1]STRDAT(I),LRET,LMESSAGE) From ECCLIB
                             If find(LRET,1,4)
                                 [M:MUX1]PECFLG(I) = 1
                             Endif
                         Endif
                     Endif
       Endcase
    Endif
Next I
End

#----------------------------------------------------------------------
# Affichage du bilan

Subprog BILAN
Local Integer I

[M:MUX1]AVADAT     = [M:DIA]ENDDAT
[M:MUX1]ANADAT     = [0/0/0]
[M:MUX1]FIRRELDAT  = [0/0/0]

For I = 0 To [M:MUX1]NBLIG - 1
    If [M:MUX1]PECFLG(I) = 2
      If [M:MUX1]ANADAT    = [0/0/0] : [M:MUX1]ANADAT    = [M:MUX1]ENDDAT(I) : Endif
      If [M:MUX1]FIRRELDAT = [0/0/0] : [M:MUX1]FIRRELDAT = [M:MUX1]STRDAT(I) : Endif
      If [M:MUX1]ENDDAT(I) > [M:MUX1]ANADAT    : [M:MUX1]ANADAT    = [M:MUX1]ENDDAT(I) : Endif
      If [M:MUX1]STRDAT(I) < [M:MUX1]FIRRELDAT : [M:MUX1]FIRRELDAT = [M:MUX1]STRDAT(I) : Endif
    Endif
Next I
# If [M:MUX1]FIRRELDAT < date$ : [M:MUX1]ANADAT = [0/0/0] : Endif : # GH 17/04/2013
End

#----------------------------------------------------------------------
# recalcul tableau si modification d'une ligne
$UPDATE_TAB
Local Integer I,J,L, WOK
# 04.06 35464
Local Integer IOK, WLTI
Local Date    WORIDAT, WDSTDAT
Local Char    WORIFCY(GLONFCY)
Local Date    WORISTRDAT, WORIENDDAT # Issue 111835 by BEEBE - 28/10/2015 - for version control

Local Date    REFDAT

I = nolign-1
WOK = 0            # llc 01.02
GOK = 1 # Issue 111835 - 2015-11-26 by BEEBE : initialize GOK, after rejecting the data a second propagation should be possible

# les dates ont-elles changées ?
For L = 0 To [M:MUXB]NBLIG - 1
        If [M:MUXB]LIGNE(L) = [M:MUX1]LIGNE(I)
            If [M:MUXB]STRDAT(L) <> [M:MUX1]STRDAT(I) | [M:MUXB]ENDDAT(L) <> [M:MUX1]ENDDAT(I)
                WOK = 2
#               Call OUINON("Souhaitez vous répercuter cette modification ?",WOK) From GESECRAN
                Call OUINON(mess(295,193,1),WOK) From GESECRAN
                If WOK <> 2 : WOK = 0 : Endif
            Endif
            Break
        Endif
Next L

# Issue 111835 by BEEBE - 28/10/2015 - saving origin date
WORISTRDAT=[M:MUXB]STRDAT(L)
WORIENDDAT=[M:MUXB]ENDDAT(L)

Call TEMPON(mess(413,197,1)) From GESECRAN

# avant de commencer on raffraichit [MUXB]
For I = 0 To [M:MUX1]NBLIG - 1
    For L = 0 To [M:MUXB]NBLIG - 1
        If [M:MUXB]LIGNE(L) = [M:MUX1]LIGNE(I)
            [M:MUXB]STRDAT(L) = [M:MUX1]STRDAT(I)
            [M:MUXB]ENDDAT(L) = [M:MUX1]ENDDAT(I)
            [M:MUXB]EXTQTY(L) = [M:MUX1]EXTQTY(I)
            [M:MUXB]BOMALT(L) = [M:MUX1]BOMALT(I)
            [M:MUXB]ROUNUM(L) = [M:MUX1]ROUNUM(I)
            [M:MUXB]ROUALT(L) = [M:MUX1]ROUALT(I)
            # Issue 111414/113 - 2016-03-31 by JUSYN : route version missing for scheduling
            If dim([M:MUX1]ROUECCMAJ) > 0
                [M:MUXB]ROUECCMAJ(L) = [M:MUX1]ROUECCMAJ(I)
                [M:MUXB]ROUECCMIN(L) = [M:MUX1]ROUECCMIN(I)
            Endif
            Break                            # 04.06 35464
        Endif
    Next L
Next I

# llc 01.02
If !WOK : Goto UPDATE_BILAN : Endif

L = nolign-1

# correspondance dans MUXB
For J = 0 To [M:MUXB]NBLIG - 1
    If [M:MUXB]LIGNE(J) = [M:MUX1]LIGNE(L) : L = J : Break : Endif
Next J

[M:MUXB]PROFLG(J) = 2

# 04.06 35464 application délai CQ si nécessaire
Read [ITF]ITF0=[M:MUXB]ITMREF(L);[M:MUX1]MFGFCY
If fstat :   Raz [F:ITF] :  Endif

WORIDAT = [M:MUXB]ENDDAT(L)
WORIFCY = [M:MUX1]MFGFCY
WLTI    = [F:ITF]QUALTI
# calcul date
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB
REFDAT  = WDSTDAT

# répercution de ce changement
Call RECAL_TAB_UP([M:MUXB]PARENT(L), [M:MUXB]PARLIN(L), REFDAT)
# Issue 111835 by BEEBE - 28/10/2015 - when one of the versions not valid
#                         -> reject the modifications
If GOK=0
    # Undo all modifications
    [M:MUX1]STRDAT(nolign-1) = WORISTRDAT
    [M:MUX1]ENDDAT(nolign-1) = WORIENDDAT

    For I = 0 To [M:MUX1]NBLIG - 1
        For L = 0 To [M:MUXB]NBLIG - 1
            If [M:MUXB]LIGNE(L) = [M:MUX1]LIGNE(I)
                [M:MUXB]STRDAT(L) = [M:MUX1]STRDAT(I)
                [M:MUXB]ENDDAT(L) = [M:MUX1]ENDDAT(I)
            Endif
        Next L
    Next I

    Goto UPDATE_BILAN
Endif

# mise à jour affichage
For I = 0 To [M:MUX1]NBLIG - 1
    For L = 0 To [M:MUXB]NBLIG - 1
        If [M:MUXB]LIGNE(L) = [M:MUX1]LIGNE(I)
            [M:MUX1]STRDAT(I) = [M:MUXB]STRDAT(L)
            [M:MUX1]ENDDAT(I) = [M:MUXB]ENDDAT(L)
        Endif
    Next L
Next I

# raz du flag recalcul
For I = 0 To [M:MUXB]NBLIG - 1
    [M:MUXB]PROFLG(I) = 1
Next I

# Issue 111414/11 - 2016-02-11 by JUSYN : versions flag
# revision flag PEC
Call UPD_PECFLG(0,[M:MUX1]NBLIG-1,1)

# llc 01.02
$UPDATE_BILAN
# révision bilan
Call BILAN

Call TEMPOFF From GESECRAN

Affzo [MUX1]1-99

Return

#----------------------------------------------------------------------
# recalcul des éléments parents
Subprog RECAL_TAB_UP(LPARENT, LPARLIN, LENDDAT)
Value Char     LPARENT
Value Integer  LPARLIN
Value Date     LENDDAT

Local Integer I, L, IOK, WLTI
Local Date    REFDAT

# si on est déjà sur la racine
If LPARENT = ""
    Call RECAL_TAB_DOWN
    End
Endif

IOK = 0
# recherche de la ligne parent
For I = 0 To [M:MUXB]NBLIG - 1
    If [M:MUXB]ITMREF(I) = LPARENT & [M:MUXB]LIGNE(I) = LPARLIN : IOK = 1 : Break : Endif
Next I

If !IOK : End : Endif

# recalcul date fin du parent
L = I
I = 0
REFDAT = LENDDAT

Gosub CAL_JAL_AVB            # 03.06 34891
# Issue 111835 - 2015-11-24 by BEEBE : checking valid version - GOK must be tested
If GOK=0 : End : Endif

[M:MUXB]PROFLG(L) = 2

# tant qu'on est pas sur le produit fini on remonte ...
# si on arrive au produit fini on redescent ...
If [M:MUXB]LEVEL(L) > 0
    Call RECAL_TAB_UP([M:MUXB]PARENT(L), [M:MUXB]PARLIN(L), [M:MUXB]ENDDAT(L))
Else
    Call RECAL_TAB_DOWN
Endif
End

#----------------------------------------------------------------------
# recalcul des éléments enfants
Subprog RECAL_TAB_DOWN
Local Integer I, J, L, JOK
Local Date    WORIDAT, WDSTDAT
Local Char    WORIFCY(GLONFCY)
Local Integer WLTI
Local Date    REFDAT

$LOOP
# tous les éléments ont ils été recalculés ?
#If find(1,[M:MUXB]PROFLG(0..[M:MUXB]NBLIG-1)) : End : Endif : # GH 09/12/13 bug 95027
I = find(1,[M:MUXB]PROFLG(0..[M:MUXB]NBLIG-1))-1
If I<0 : End : Endif

JOK = 0
# recherche du parent
For J = 0 To [M:MUXB]NBLIG - 1
    If [M:MUXB]ITMREF(J) = [M:MUXB]PARENT(I) & [M:MUXB]LIGNE(J) = [M:MUXB]PARLIN(I) : JOK = 1 : Break : Endif
Next J
If !JOK : End : Endif

L = I
I = 0
REFDAT = [M:MUXB]STRDAT(J)

# llc 01.02
# prise en compte du délai CQ
Read [ITF]ITF0=[M:MUXB]ITMREF(L);[M:MUX1]MFGFCY
If fstat :   Raz [F:ITF] :  Endif

WORIDAT = REFDAT
WORIFCY = [M:MUX1]MFGFCY
WLTI    = [F:ITF]QUALTI
# calcul date
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, WDSTDAT) From MFGLIB
REFDAT  = WDSTDAT

Gosub CAL_JAL_AMB
# Issue 111835 - 2015-11-24 by BEEBE : checking valid version - GOK must be tested
If GOK=0 : End : Endif
[M:MUXB]PROFLG(L) = 2

# on boucle pour trouver les éléments non calculés suivants
Goto LOOP
End

$CAL_JAL_DEF
Local Date    WORIDAT
Local Char    WORIFCY(GLONFCY)
Local Integer WLTI
Local Decimal XLTI
Local Integer ILTI
Local Decimal WRMD
Local Decimal WQTY
Local Char    WSNS(1)
Local Integer I
Local Integer WLTIJO
Return

#----------------------------------------------------------------------
# calcul délai en aval
# 03.06 34891
$CAL_JAL_AV
Gosub CAL_JAL_DEF

If find([M:MUX1]REOCOD(L),2,4,5)
    WORIDAT = REFDAT
    WORIFCY = [M:MUX1]MFGFCY

    If [M:MUX1]REOCOD(L)=5 : # GH 24/05/2013
      WSRVITMREF = "" : XLTI=0
      Call FIND_SCI_LTI([M:MUX1]ITMREF(L),[M:MUX1]BPSNUM(L),[M:MUX1]MFGFCY,[M:MUX1]BOMALT(L),WSRVITMREF,XLTI) From SCOLIB
      WLTI   = XLTI
      WLTIJO = 2
    Else
      # lecture article site
      Read [ITF]ITF0=[M:MUX1]ITMREF(L);[M:MUX1]MFGFCY
      If fstat : Raz [F:ITF] : Endif
      WLTI   = [F:ITF]OFS
      WLTIJO = 0
    Endif

    # calcul date
    # GH 08/04/13 suite au bug 88210 corrigé par GA
    # Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MUX1]ENDDAT(L)) From MFGLIB
    WSNS="+"
    Gosub CAL_PURDAT
    [M:MUX1]ENDDAT(L) = WDAT
    Return
Endif

I = 0                                            # 03.06 34891
If [M:MUX1]LTICOD = 2
    Raz [M:JALK]
    [M:JALK]CODORI     = 0
    [M:JALK]CODMAJ     = 2
    [M:JALK]CODTRS     = 0
    [M:JALK]MFGFCY     = [M:MUX1]MFGFCY
    # Issue 111414/116 - 2016-04-07 by JUSYN : ITMREF not automatically the routing number. Must be taken from ROUNUM.
    # [M:JALK]ROUNUM     = [M:MUX1]ITMREF(L)
    [M:JALK]ROUNUM     = [M:MUX1]ROUNUM(L)
    [M:JALK]ROUALT     = [M:MUX1]ROUALT(L)
    [M:JALK]REOMINQTY  = [M:MUX1]EXTQTY(L)
    [M:JALK]TRTDAT     = date$
    [M:JALK]STRDAT     = REFDAT
    [M:JALK]ENDDAT     = [M:MUX1]ENDDAT(L)
    [M:JALK]JAVFLG     = 1
    [M:JALK]SCDMOD     = 2                        # 12.05 33887
    # Issue 111414/113 - 2016-03-29 by JUSYN : Correct date to read routing needed
    Local    Date    WDAT
    If func RVMLIB.NBRCPNROU([M:JALK]ROUNUM) > 0
        Call INIECCROUDAT([M:MUX1]ITMREF(L),[M:JALK]MFGFCY,[M:JALK]ROUALT,[M:MUX1]ROUECCMAJ(L),[M:MUX1]ROUECCMIN(L),WDAT) From RVMLIB
        If WDAT = [0/0/0] : WDAT = [M:JALK]STRDAT : Endif
        [M:JALK]ROUDAT = WDAT
    Endif
    Call JALONNE From JALLIB
    I = ([M:JALK]CODRET <> 0)
    [M:MUX1]ENDDAT(L) = [M:JALK]ENDDAT
    # Issue 111414/113 - 2016-03-29 by JUSYN : Versioned routing in scheduling mode backwards with invalid version at start date taken to report error in MULTIWOX1.
    If [M:JALK]ROUDAT <> [0/0/0] & [M:JALK]CODRET = 2 : I = 0  : Endif
    # 09.05 32175
    If [F:ITM]ITMREF <> [M:MUX1]ITMREF(L)
        Read [ITM]ITM0=[M:MUX1]ITMREF(L)
        If fstat : Raz [F:ITM] : Endif
    Endif
    # 09.10
    If [F:ITF]ITMREF <> [M:MUX1]ITMREF(L) | [F:ITF]STOFCY <> [M:MUX1]MFGFCY
       Read [ITF]ITF0=[M:MUX1]ITMREF(L);[M:MUX1]MFGFCY
       If fstat : Raz [F:ITF] : Endif
    Endif
Endif

If [M:MUX1]LTICOD = 1 | I = 1
    WORIDAT = REFDAT
    WORIFCY = [M:MUX1]MFGFCY
    WLTI=0

    # lecture article site
    Read [ITF]ITF0=[M:MUX1]ITMREF(L);[M:MUX1]MFGFCY
    If fstat : Return : Endif
    WQTY = [M:MUX1]EXTQTY(L)
    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
    ILTI    = int(XLTI)
    WRMD    = XLTI - ILTI
    If WRMD <> 0 : ILTI += 1 : Endif
    WLTI=ILTI

    # calcul date
    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MUX1]ENDDAT(L)) From MFGLIB
Endif
Return

#----------------------------------------------------------------------
# calcul délai en aval, sur masque MUXB
# 03.06 34891
$CAL_JAL_AVB
Gosub CAL_JAL_DEF

# Issue 111835 - 2015-10-30 by BEEBE : validation modified start date -> the version may not change
Call CHECK_VERSION_STRDAT(REFDAT , L)
If GOK=0 : Return : Endif

If find([M:MUXB]REOCOD(L),2,4,5)
    WORIDAT = REFDAT
    WORIFCY = [M:MUX1]MFGFCY

    If [M:MUX1]REOCOD(L)=5 : # GH 24/05/2013
      WSRVITMREF = "" : XLTI=0
      Call FIND_SCI_LTI([M:MUXB]ITMREF(L),[M:MUXB]BPSNUM(L),[M:MUX1]MFGFCY,[M:MUXB]BOMALT(L),WSRVITMREF,XLTI) From SCOLIB
      WLTI   = XLTI
      WLTIJO = 2
    Else
      # lecture article site
      Read [ITF]ITF0=[M:MUXB]ITMREF(L);[M:MUX1]MFGFCY
      If fstat : Raz [F:ITF] : Endif
      WLTI   = [F:ITF]OFS
      WLTIJO = 0
    Endif

    # calcul date
    # GH 08/04/13 suite au bug 88210 corrigé par GA
    # Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MUXB]ENDDAT(L)) From MFGLIB
    WSNS="+"
    Gosub CAL_PURDAT
    [M:MUXB]ENDDAT(L) = WDAT
    [M:MUXB]STRDAT(L) = REFDAT
    Return
Endif

I = 0                                            # 03.06 34891
If [M:MUX1]LTICOD = 2
    Raz [M:JALK]
    [M:JALK]CODORI     = 0
    [M:JALK]CODMAJ     = 2
    [M:JALK]CODTRS     = 0
    [M:JALK]MFGFCY     = [M:MUX1]MFGFCY
    # Issue 111414/116 - 2016-04-07 by JUSYN : ITMREF not automatically the routing number. Must be taken from ROUNUM.
    # [M:JALK]ROUNUM     = [M:MUXB]ITMREF(L)
    [M:JALK]ROUNUM     = [M:MUXB]ROUNUM(L)
    [M:JALK]ROUALT     = [M:MUXB]ROUALT(L)
    [M:JALK]REOMINQTY  = [M:MUXB]EXTQTY(L)
    [M:JALK]TRTDAT     = date$
    [M:JALK]STRDAT     = REFDAT
    [M:JALK]ENDDAT     = [M:MUXB]ENDDAT(L)
    [M:JALK]JAVFLG     = 1
    [M:JALK]SCDMOD     = 2                        # 12.05 33887
    # Issue 111414/113 - 2016-03-29 by JUSYN : Correct date to read routing needed
    Local    Date    WDAT
    If func RVMLIB.NBRCPNROU([M:JALK]ROUNUM) > 0
        Call INIECCROUDAT([M:MUXB]ITMREF(L),[M:JALK]MFGFCY,[M:JALK]ROUALT,[M:MUXB]ROUECCMAJ(L),[M:MUXB]ROUECCMIN(L),WDAT) From RVMLIB
        If WDAT = [0/0/0] : WDAT = [M:JALK]STRDAT : Endif
        [M:JALK]ROUDAT = WDAT
    Endif
    Call JALONNE From JALLIB
    I = ([M:JALK]CODRET <> 0)
    [M:MUXB]ENDDAT(L) = [M:JALK]ENDDAT
    # Issue 111414/113 - 2016-03-29 by JUSYN : Versioned routing in scheduling mode backwards with invalid version at start date taken to report error in MULTIWOX1.
    If [M:JALK]ROUDAT <> [0/0/0] & [M:JALK]CODRET = 2 : I = 0  : Endif
    # 09.05 32175
    If [F:ITM]ITMREF <> [M:MUXB]ITMREF(L)
        Read [ITM]ITM0=[M:MUXB]ITMREF(L)
        If fstat : Raz [F:ITM] : Endif
    Endif
    # 09.10
    If [F:ITF]ITMREF <> [M:MUX1]ITMREF(L) | [F:ITF]STOFCY <> [M:MUX1]MFGFCY
       Read [ITF]ITF0=[M:MUX1]ITMREF(L);[M:MUX1]MFGFCY
       If fstat : Raz [F:ITF] : Endif
    Endif
Endif

If [M:MUX1]LTICOD = 1 | I = 1
    WORIDAT = REFDAT
    WORIFCY = [M:MUX1]MFGFCY
    WLTI=0

    # lecture article site
    Read [ITF]ITF0=[M:MUXB]ITMREF(L);[M:MUX1]MFGFCY
    If fstat : Return : Endif
    WQTY = [M:MUXB]EXTQTY(L)
    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
    ILTI    = int(XLTI)
    WRMD    = XLTI - ILTI
    If WRMD <> 0 : ILTI += 1 : Endif
    WLTI=ILTI

    # calcul date
    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MUXB]ENDDAT(L)) From MFGLIB
Endif

[M:MUXB]STRDAT(L) = REFDAT
Return

#----------------------------------------------------------------------
# calcul délai en amont
$CAL_JAL_AM
Gosub CAL_JAL_DEF

If find([M:MUX1]REOCOD(L),2,4,5)
    WORIDAT = REFDAT
    WORIFCY = [M:MUX1]MFGFCY

    If [M:MUX1]REOCOD(L)=5 : # GH 24/05/2013
      WSRVITMREF = "" : XLTI=0
      Call FIND_SCI_LTI([M:MUX1]ITMREF(L),[M:MUX1]BPSNUM(L),[M:MUX1]MFGFCY,[M:MUX1]BOMALT(L),WSRVITMREF,XLTI) From SCOLIB
      WLTI   = XLTI
      WLTIJO = 2
    Else
      # lecture article site
      Read [ITF]ITF0=[M:MUX1]ITMREF(L);[M:MUX1]MFGFCY
      If fstat : Raz [F:ITF] : Endif
      WLTI   = [F:ITF]OFS
      WLTIJO = 0
    Endif

    # calcul date
    # GH 08/04/13 suite au bug 88210 corrigé par GA
    # Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MUX1]STRDAT(L)) From MFGLIB
    WSNS = "-"
    Gosub CAL_PURDAT
    [M:MUX1]STRDAT(L) = WDAT
    [M:MUX1]ENDDAT(L) = REFDAT
    Return
Endif

I = 0
If [M:MUX1]LTICOD = 2
    Raz [M:JALK]
    [M:JALK]CODORI     = 2
    [M:JALK]CODMAJ     = 2
    [M:JALK]CODTRS     = 0
    [M:JALK]MFGFCY     = [M:MUX1]MFGFCY
    # Issue 111414/116 - 2016-04-07 by JUSYN : ITMREF not automatically the routing number. Must be taken from ROUNUM.
    # [M:JALK]ROUNUM     = [M:MUX1]ITMREF(L)
    [M:JALK]ROUNUM     = [M:MUX1]ROUNUM(L)
    [M:JALK]ROUALT     = [M:MUX1]ROUALT(L)
    [M:JALK]REOMINQTY  = [M:MUX1]EXTQTY(L)
    [M:JALK]TRTDAT     = date$
    [M:JALK]STRDAT     = [M:MUX1]STRDAT(L)
    [M:JALK]ENDDAT     = REFDAT
    [M:JALK]JAVFLG     = 1
    [M:JALK]SCDMOD     = 1  ## GH 12/04/2013
    # ROUDAT = Date to read the routing in JALLIB.JALLONE. Take start date not end date when routing is versioned in order to schedule backwards
    #               Routing version entered in MULTIWOX has to be taken. End date would probably look for another version.
    # Issue 111414/113 - 2016-03-29 by JUSYN : Precise ROUDAT for selection in JALONNE.
    #                                          For Product STRDAT although backward scheduling because to keep routing version of criteria screen.
    #                                          For all other components ENDDAT because of backward scheduling and real start date isn't known before scheduling done.
    # If func RVMLIB.NBRCPNROU([M:JALK]ROUNUM) > 0 & L = 0
    # Issue 111414/113 - 2016-03-29 by JUSYN : work date for start date of routing
    Local    Date    WDAT
    If func RVMLIB.NBRCPNROU([M:JALK]ROUNUM) > 0
        If L = 0
            # Issue 111414 - 2016-02-17 by JUSYN : Initialize route reading date
            # [M:JALK]ROUDAT     = [M:JALK]STRDAT
            Call INIECCROUDAT([M:MUX1]ITMREF(L),[M:JALK]MFGFCY,[M:JALK]ROUALT,[M:MUX1]ROUECCMAJ(L),[M:MUX1]ROUECCMIN(L),WDAT) From RVMLIB
            If WDAT = [0/0/0] : WDAT = [M:JALK]ENDDAT : Endif
            [M:JALK]ROUDAT = WDAT
        Else
            [M:JALK]ROUDAT     = [M:JALK]ENDDAT
        Endif
    Endif
    Call JALONNE From JALLIB
    I = ([M:JALK]CODRET <> 0)
    # Issue 111414/11 - 2016-02-17 by JUSYN : Versioned routing in scheduling mode backwards with invalid version at start date taken to report error in MULTIWOX.
    If [M:JALK]ROUDAT <> [0/0/0] & [M:JALK]CODRET = 2 : I = 0  : Endif

    [M:MUX1]STRDAT(L) = [M:JALK]STRDAT
    # 09.05 32175
    If [F:ITM]ITMREF <> [M:MUX1]ITMREF(L)
        Read [ITM]ITM0=[M:MUX1]ITMREF(L)
        If fstat : Raz [F:ITM] : Endif
    Endif
    # 09.10
    If [F:ITF]ITMREF <> [M:MUX1]ITMREF(L) | [F:ITF]STOFCY <> [M:MUX1]MFGFCY
       Read [ITF]ITF0=[M:MUX1]ITMREF(L);[M:MUX1]MFGFCY
       If fstat : Raz [F:ITF] : Endif
    Endif
Endif

If [M:MUX1]LTICOD = 1 | I = 1
    # calcul de la date de début
    WORIDAT         = REFDAT
    WORIFCY         = [M:MUX1]MFGFCY
    WLTI            = 0

    # lecture article site
    Read [ITF]ITF0=[M:MUX1]ITMREF(L);[M:MUX1]MFGFCY
    If fstat : Return : Endif

    WQTY            = [M:MUX1]EXTQTY(L)
    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
    ILTI            = int(XLTI)
    WRMD            = XLTI - ILTI
    If WRMD <> 0 : ILTI += 1 : Endif
    WLTI            = ILTI

    # calcul date
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MUX1]STRDAT(L)) From MFGLIB
Endif

[M:MUX1]ENDDAT(L) = REFDAT
Return

#----------------------------------------------------------------------
# calcul délai en amont, sur masque MUXB
$CAL_JAL_AMB
Gosub CAL_JAL_DEF

If find([M:MUXB]REOCOD(L),2,4,5)
    WORIDAT = REFDAT
    WORIFCY = [M:MUX1]MFGFCY

    If [M:MUX1]REOCOD(L)=5 : # GH 24/05/2013
      WSRVITMREF = "" : XLTI=0
      Call FIND_SCI_LTI([M:MUXB]ITMREF(L),[M:MUXB]BPSNUM(L),[M:MUX1]MFGFCY,[M:MUXB]BOMALT(L),WSRVITMREF,XLTI) From SCOLIB
      WLTI   = XLTI
      WLTIJO = 2
    Else
      # lecture article site
      Read [ITF]ITF0=[M:MUXB]ITMREF(L);[M:MUX1]MFGFCY
      If fstat : Raz [F:ITF] : Endif
      WLTI   = [F:ITF]OFS
      WLTIJO = 0
    Endif

    # calcul date
    # GH 08/04/13 suite au bug 88210 corrigé par GA
    # Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MUXB]STRDAT(L)) From MFGLIB
    WSNS = "-"
    Gosub CAL_PURDAT
    # Issue 111835 - 2015-10-30 by BEEBE : validation modified start date -> the version may not change
    Call CHECK_VERSION_STRDAT(WDAT , L)
    If GOK=0 : Return : Endif
    [M:MUXB]STRDAT(L) = WDAT
    [M:MUXB]ENDDAT(L) = REFDAT
    Return
Endif

I = 0
If [M:MUX1]LTICOD = 2
    Raz [M:JALK]
    [M:JALK]CODORI     = 2
    [M:JALK]CODMAJ     = 2
    [M:JALK]CODTRS     = 0
    [M:JALK]MFGFCY     = [M:MUX1]MFGFCY
    # Issue 111414/116 - 2016-04-07 by JUSYN : ITMREF not automatically the routing number. Must be taken from ROUNUM.
    # [M:JALK]ROUNUM     = [M:MUXB]ITMREF(L)
    [M:JALK]ROUNUM     = [M:MUXB]ROUNUM(L)
    [M:JALK]ROUALT     = [M:MUXB]ROUALT(L)
    [M:JALK]REOMINQTY  = [M:MUXB]EXTQTY(L)
    [M:JALK]TRTDAT     = date$
    [M:JALK]STRDAT     = [M:MUXB]STRDAT(L)
    [M:JALK]ENDDAT     = REFDAT
    [M:JALK]JAVFLG     = 1
    [M:JALK]SCDMOD     = 1  ## GH 12/04/2013
    # Issue 111414/113 - 2016-03-29 by JUSYN : Correct date to read routing needed
    Local    Date    WDAT
    If func RVMLIB.NBRCPNROU([M:JALK]ROUNUM) > 0
        Call INIECCROUDAT([M:MUXB]ITMREF(L),[M:JALK]MFGFCY,[M:JALK]ROUALT,[M:MUXB]ROUECCMAJ(L),[M:MUXB]ROUECCMIN(L),WDAT) From RVMLIB
        If WDAT = [0/0/0] : WDAT = [M:JALK]ENDDAT : Endif
        [M:JALK]ROUDAT = WDAT
    Endif
    Call JALONNE From JALLIB
    I = ([M:JALK]CODRET <> 0)

    # Issue 111835 - 2015-10-30 by BEEBE : validation modified start date -> the version may not change
    Call CHECK_VERSION_STRDAT([M:JALK]STRDAT , L)
    If GOK=0 : Return : Endif

    [M:MUXB]STRDAT(L) = [M:JALK]STRDAT
    # Issue 111414/113 - 2016-03-29 by JUSYN : Versioned routing in scheduling mode backwards with invalid version at start date taken to report error in MULTIWOX1.
    If [M:JALK]ROUDAT <> [0/0/0] & [M:JALK]CODRET = 2 : I = 0  : Endif
    # 09.05 32175
    If [F:ITM]ITMREF <> [M:MUXB]ITMREF(L)
        Read [ITM]ITM0=[M:MUXB]ITMREF(L)
        If fstat : Raz [F:ITM] : Endif
    Endif
    # 09.10
    If [F:ITF]ITMREF <> [M:MUX1]ITMREF(L) | [F:ITF]STOFCY <> [M:MUX1]MFGFCY
       Read [ITF]ITF0=[M:MUX1]ITMREF(L);[M:MUX1]MFGFCY
       If fstat : Raz [F:ITF] : Endif
    Endif
Endif

If [M:MUX1]LTICOD = 1 | I = 1
    # calcul de la date de début
    WORIDAT         = REFDAT
    WORIFCY         = [M:MUX1]MFGFCY
    WLTI            = 0

    # lecture article site
    Read [ITF]ITF0=[M:MUXB]ITMREF(L);[M:MUX1]MFGFCY
    If fstat : Return : Endif

    WQTY            = [M:MUXB]EXTQTY(L)
    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
    ILTI            = int(XLTI)
    WRMD            = XLTI - ILTI
    If WRMD <> 0 : ILTI += 1 : Endif
    WLTI            = ILTI

    # Issue 111835 - 2015-11-24 by BEEBE : validation modified start date -> the version may not change
    Local Date LSTRDAT

    # calcul date
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, LSTRDAT) From MFGLIB

    Call CHECK_VERSION_STRDAT(LSTRDAT , L)
    If GOK=0 : Return : Endif
    [M:MUXB]STRDAT(L)=LSTRDAT
Endif

[M:MUXB]ENDDAT(L) = REFDAT
Return

##########################################################################
# Traitement des actions evenementielles            #
$APRES_MODIF
REP="M"
Gosub SETBOUT
Return

##########################################################################
# Lecture des postes                                #
$LIRE
REP=""
Raz [M:MUX1]
nolign=0

If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif

[M:MUX1]NBLIG = nolign

If [M:MUX1]NBLIG > 0
    Affzo [MUX1]
Endif
Return

##########################################################################
# Enregistrement des modifications
$MODIF
Call TEMPON("V") From GESECRAN

If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

Gosub GEN
If !NBOF & !NBEO & !NBACH & !NBINT
    WMESS1=mess(414,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif
Call TEMPOFF From GESECRAN
Return

##########################################################################
# génération
$GEN
If !find(2,[M:MUX1]PECFLG(0..[M:MUX1]NBLIG-1)) : Return : Endif

# V6 Réseau MTO FQ 46650
# désactivé 57771
# Gosub MAJ_MTO

# on traite d'abord les OF
Gosub MAJOF
If NBOF
    WMESS1=num$(NBOF)-mess(415,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif
#sr 08.04 demande24291
If [M:MFGK]CODRET <> 0 : Return : Endif

# puis les éventuelles DA/commandes
Gosub MAJACH
If NBACH
    Case [M:MUX1]MFGSTA
        When 1: WMESS1=num$(NBACH)-mess(418,197,1)
                Call ECR_TRACE(WMESS1,0) From GESECRAN
        When 2: WMESS1=num$(NBACH)-mess(419,197,1)
                Call ECR_TRACE(WMESS1,0) From GESECRAN
    Endcase
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif
#sr 08.04 demande24291
If [M:PMG]ERRCOD <> 0 : Return : Endif

Gosub MAJINT
# puis les éventuels ordres intersites
If NBINT
    WMESS1=num$(NBINT)-mess(420,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

# on traite ensuite les EO - V6 achats de sous-traitance
Gosub MAJEO
If NBEO
    WMESS1=num$(NBEO)-mess(718,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif
If [M:SCOK]CODRET <> 0 : Return : Endif

Return

##########################################################################
$MAJOF
NBOF = 0
    For L=0 To [M:MUX1]NBLIG - 1
        If [M:MUX1]PECFLG(L) <> 2                    : Goto NEXTNO : Endif
        If [M:MUX1]MFGFLG(L) <> 2                    : Goto NEXTNO : Endif
        If [M:MUX1]REOCOD(L) <> 3 & [M:MUX1]LEVEL(L)<> 0  : Goto NEXTNO : Endif   # 06.07 mm 41980
        If [M:MUX1]WIPTYP(L) <> 5                    : Goto NEXTNO : Endif  # FQ 75172 GA 11/2011 Cas d'un EOF
        Call DEBTRANS From GLOCK
        GOK=1
        Trbegin ADOVAL

        Raz [M:MFGK]

        [M:MFGK]CODMAJ = "C"
        [M:MFGK]CODTRS = 0
        If NBOF = 0 & [M:MUX1]MTOREF<>""      : # On a calculé la réf du 1er OF pour insérer le Réseau MTO
           [M:MFGK]RMFGNUM = [M:MUX1]MTOREF   : # V6 Réseau MTO FQ 46650
        Else
           [M:MFGK]RMFGNUM = ""
        Endif
        [M:MFGK]MFGNUM = ""
        [M:MFGK]MFGLIN = 1000                 : # V6 avant 0
        [M:MFGK]MFGFCY = [M:MUX1]MFGFCY
        Case [M:MUX1]MFGSTA
            When 1: [M:MFGK]MFGSTA = 2
            When 2: [M:MFGK]MFGSTA = 1
        Endcase
        [M:MFGK]ITMREF = [M:MUX1]ITMREF(L)
        [M:MFGK]PRVQTY = 0
        [M:MFGK]EXTQTY = [M:MUX1]EXTQTY(L)
        [M:MFGK]STRDAT = [M:MUX1]STRDAT(L)
        [M:MFGK]ENDDAT = [M:MUX1]ENDDAT(L)
        [M:MFGK]BOMALT = [M:MUX1]BOMALT(L)
        [M:MFGK]ROUNUM = [M:MUX1]ROUNUM(L)
        [M:MFGK]ROUALT = [M:MUX1]ROUALT(L)
        # 10.02 MM
        [M:MFGK]FMI    = [M:MUX1]FMI(L)
        # llc 05.03 17939 + 19138 + 19584
        # If [M:MUX1]FMI(L)=5 & [M:MUX1]VCRNUMORI(L) <> "" & [M:MUX1]LEVEL(L) = 0 : # GH 11/10/12 bug 84918
        If find([M:MUX1]FMI(L),1,5) & [M:MUX1]VCRNUMORI(L) <> "" & [M:MUX1]LEVEL(L) = 0
            # lecture encours
            If [M:DIA]WIPNUM<>""
               Read [ORD]ORD0 = [M:DIA]WIPTYP;[M:DIA]WIPNUM;[M:DIA]ITMREF
            Else
               # Issue 78352 GA 01/2012 sometimes there's no WIPNUM ???
               # Index ORD3=STOFCY+VCRTYP+VCRNUM+VCRLIN+VCRSEQ
               Read [ORD]ORD3 = [M:MUX1]MFGFCY;[M:DIA]VCRTYPORI;[M:DIA]VCRNUMORI;[M:DIA]VCRLINORI;[M:DIA]VCRSEQORI
               [M:DIA]WIPTYP = [F:ORD]WIPTYP
               [M:DIA]WIPNUM = [F:ORD]WIPNUM
            Endif
            # If !fstat : [M:MFGK]CODMAJ = "P"  : Endif : # GH 11/10/12 bug 84918
            If !fstat & [M:MUX1]FMI(L)=[F:ORD]FMI : [M:MFGK]CODMAJ = "P"  : Endif
        Endif
        # GH 11/10/12 bug 84918
        # s'il existe déjà une affectation sur la pce origine et que les affectations sont gérées en lien 1=1 pour l'article-site
        If [M:MFGK]CODMAJ = "P"
&        & func MTOLINKLIB.LINK_EXISTS([F:ORD]STOFCY, [F:ORD]VCRTYP, [F:ORD]VCRNUM, [F:ORD]VCRLIN, [F:ORD]VCRSEQ, [F:ORD]WIPTYP)
&        & func MTOLINKLIB.IS_DIRECT_ORDER_CTX([F:ORD]STOFCY, [F:ORD]ITMREF)
           [M:MFGK]CODMAJ = "C"
        Endif
        #
        [M:MFGK]BPRNUM = [M:MUX1]BPRNUM(L)
        [M:MFGK]PJT    = [M:MUX1]PJT(L)
        If dim([M:MFGK]MTOREF)>0 & [M:MUX1]MTOREF<>""
           [M:MFGK]MTOREF = [M:MUX1]MTOREF       : # V6 Réseau MTO FQ 46650
        Endif
        [M:MFGK]MFGDES = [M:MUX1]MFGDES(L)                # llc 01.02 12183
        [M:MFGK]PIO    = 1

        #  V6 Réseau MTO FQ 46650: OF/EO et ligne OF/EO père
        Gosub RECH_VCRNUMORI
        [M:MFGK]VCRTYPORI = [M:MUX1]VCRTYPORI(L)
        [M:MFGK]VCRNUMORI = [M:MUX1]VCRNUMORI(L)
        [M:MFGK]VCRLINORI = [M:MUX1]VCRLINORI(L)
        [M:MFGK]VCRSEQORI = [M:MUX1]VCRSEQORI(L)

        # Issue 78352 GA 01/2012 + contremarque EO
        # If find([M:MUX1]FMI(L),5,6) & [M:MUX1]VCRNUMORI(L) <> "" & [M:MUX1]LEVEL(L) = 0 : #  GH 11/10/12 bug 84918
        If [M:MFGK]CODMAJ = "P"
           [M:MFGK]WIPTYP = [M:DIA]WIPTYP         # llc 05.03 17939 + 19138
           [M:MFGK]WIPNUM = [M:DIA]WIPNUM         # llc 05.03 17939 + 19138
        Else
           [M:MFGK]WIPTYP = 0
           [M:MFGK]WIPNUM = ""
        Endif

        # 14123 10.02 MM
        Read [ITM]ITM0 = [M:MUX1]ITMREF(L)
        If !fstat & [F:ITM]LOTMGTCOD = 4 & [M:MUX1]LOT(L) <>""
            [M:MFGK]LOT =  [M:MUX1]LOT(L)
        Endif
        [M:MFGK]AUTOTRT = 2                # llc 09.03 16930
        # llc 03.02 12520
        Case [F:MTS]SCDMODSAI
            When 1:    [M:MFGK]SCDMOD = 1
            When 2:    [M:MFGK]SCDMOD = 2
            When Default: [M:MFGK]SCDMOD = 1
        Endcase

        # Issue 112743 - 2015-11-27 by BEEBE : load the version fields from MUX1 to be inserted
        If dim([M:MUX1]ECCVALMAJ)>0
            [M:MFGK]ECCVALMAJ = [M:MUX1]ECCVALMAJ(L)
            [M:MFGK]ECCVALMIN = [M:MUX1]ECCVALMIN(L)
        Endif

        # Issue 111414/11 - 2016-02-11 by JUSYN : load routing versions
        If dim([M:MUX1]ROUECCMAJ) > 0
            [M:MFGK]ROUECCMAJ = [M:MUX1]ROUECCMAJ(L)
            [M:MFGK]ROUECCMIN = [M:MUX1]ROUECCMIN(L)
        Endif

        Call MAJ_OF From MFGAUTLIB
        If [M:MFGK]CODRET <> 0
            WMESS = mess(156,197,1)+" "+mess([M:MFGK]MFGSTA,317,1)+" "+[M:MFGK]MFGNUM-[M:MFGK]ITMREF
            Call ECR_TRACE(WMESS,1) From GESECRAN
            Call ECR_TRACE(GMESSAGE,1) From GESECRAN
            Goto AB_MAJ
        Endif

        # GA 04/2008 Réseau MTO (FQ 46650) stockage du n° OF généré => repris en VCRTYPORI/VCRNUMORI des fils
        If dim([M:MUX1]VCRNUM)>0
           [M:MUX1]VCRTYP(L)=10
           [M:MUX1]VCRNUM(L)=[M:MFGK]MFGNUM
           [M:MUX1]VCRLIN(L)=[M:MFGK]MFGLIN
        Endif

        WMESS = mess(156,197,1)+" "+mess([M:MFGK]MFGSTA,317,1)+" "+[M:MFGK]MFGNUM
        Call ECR_TRACE(WMESS,0) From GESECRAN
        WMESS = mess(80,197,1)+":"-[M:MFGK]ITMREF - mess(417,197,1)-num$([M:MUX1]LEVEL(L))-
&               mess(4,197,1)-format$(GFMD,[M:MFGK]STRDAT)-mess(38,197,1)-format$(GFMD,[M:MFGK]ENDDAT)-
&               ","-num$([M:MFGK]EXTQTY)-[M:MUX1]STU(L)
        Call ECR_TRACE(WMESS,0) From GESECRAN
        Call ECR_TRACE(" ",0) From GESECRAN
        NBOF += 1
        Commit

        If [M:MFGK]MFGSTA = 1 & [M:DIA]IMPFLG = 2
            GDEFIMP = [M:DIA]PRT
            Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
            Read [MFP]MFP0 = [M:MFGK]MFGNUM
            If fstat : Raz [F:MFP] : Endif
            TBPAR(1)="codimp"        : TBVAL(1) = num$([F:MFP]MFGFDRFLG)
            TBPAR(2)="mfgfcydeb"     : TBVAL(2) = [M:MFGK]MFGFCY
            TBPAR(3)="mfgfcyfin"     : TBVAL(3) = [M:MFGK]MFGFCY
            TBPAR(4)="mfgnumdeb"     : TBVAL(4) = [M:MFGK]MFGNUM
            TBPAR(5)="mfgnumfin"     : TBVAL(5) = [M:MFGK]MFGNUM
            Call ETAT("DOSFAB",GDEFIMP,"",1,"",TBPAR,TBVAL) From AIMP3
        Endif

## GH 09/04/2014 bug 99047
#        #--------------------------------------------------#
#        # v140 Calcul automatique des coûts prévisionnels # (CPT et CPL) 15/04/03
#        #--------------------------------------------------#
#        # Issue 74259 - 2011-06-08 by CCC
#        #If GCLCWOCAUT=2
#        If GCLCWOCAUT>=2
#            # appel direct possible car aucune saisie (compatible Web ?)
#            # charger les paramètres (! ne pas écraser les PARAM de ce GSAISIE)
#            PARAM_CLC(1) = [M:MFGK]MFGFCY
#            PARAM_CLC(2) = [M:MFGK]MFGNUM
#            PARAM_CLC(4) = "1"
#            PARAM_CLC(5) = "4"
#            PARAM_CLC(12) = "2" # pas d'edition !
#            PARAM_CLC(13) = "0"   # Issue 89622 - 2013-06-05 by CCC
#            PARAM_CLC(14) = "10"
#            Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBMCC","",3,"") From GTRAITE
#        Endif
$NEXTNO
    Next L

$FIN_MAJOF
Return

##########################################################################
$MAJEO   : # V6 achats de sous-traitance
NBEO = 0
    For L=0 To [M:MUX1]NBLIG - 1
        If [M:MUX1]PECFLG(L) <> 2  : Goto NEXTLEO : Endif
        If [M:MUX1]SCPFLG(L) <> 2  : Goto NEXTLEO : Endif
        If [M:MUX1]REOCOD(L) <> 5  : Goto NEXTLEO : Endif
        Call DEBTRANS From GLOCK
        GOK=1
        Trbegin ADOVAL

        Raz [M:SCOK]
        [M:SCOK]CODMAJ = "C"
        [M:SCOK]CODTRS = 0
        [M:SCOK]SCONUM = ""
        [M:SCOK]SCILIN = 1000
        [M:SCOK]POHFCY = [M:MUX1]MFGFCY
        [M:SCOK]MFGFCY = [M:MUX1]MFGFCY
        [M:SCOK]STOFCY = [M:MUX1]MFGFCY
        Case [M:MUX1]MFGSTA
            When 1: [M:SCOK]SCOSTA = 2
            When 2: [M:SCOK]SCOSTA = 1
        Endcase
        [M:SCOK]ITMREF = [M:MUX1]ITMREF(L)
        [M:SCOK]PRVQTY = 0
        [M:SCOK]EXTQTY = [M:MUX1]EXTQTY(L)
        [M:SCOK]STRDAT = [M:MUX1]STRDAT(L)
        [M:SCOK]ENDDAT = [M:MUX1]ENDDAT(L)
        [M:SCOK]BOMALT = [M:MUX1]BOMALT(L)
        #
        [M:SCOK]BPRNUM = [M:MUX1]BPSNUM(L)
        [M:SCOK]PJT    = [M:MUX1]PJT(L)
        If dim([M:SCOK]FMI) : [M:SCOK]FMI = [M:MUX1]FMI(L) : Endif  # Issue 78352 GA 01/2012 + contremarque EO
        If dim([M:SCOK]MTOREF)>0 & [M:MUX1]MTOREF<>""
           [M:SCOK]MTOREF = [M:MUX1]MTOREF       : # V6 Réseau MTO FQ 46650
        Endif
        [M:SCOK]SCODES = [M:MUX1]MFGDES(L)
        [M:SCOK]PIO    = 1

        #  V6 Réseau MTO FQ 46650: OF/EO et ligne OF/EO père
        Gosub RECH_VCRNUMORI
        [M:SCOK]VCRTYPORI = [M:MUX1]VCRTYPORI(L)
        [M:SCOK]VCRNUMORI = [M:MUX1]VCRNUMORI(L)
        [M:SCOK]VCRLINORI = [M:MUX1]VCRLINORI(L)
        [M:SCOK]VCRSEQORI = [M:MUX1]VCRSEQORI(L)

        [M:SCOK]WIPTYP = [M:DIA]WIPTYP

        Read [ITM]ITM0 = [M:MUX1]ITMREF(L)
        If !fstat & [F:ITM]LOTMGTCOD = 4 & [M:MUX1]LOT(L) <>""
           [M:SCOK]LOT =  [M:MUX1]LOT(L)
        Endif
        [M:SCOK]WIPNUM = [M:DIA]WIPNUM
        [M:SCOK]AUTOTRT = 2

        # Issue 112743 - 2015-11-27 by BEEBE : load the version fields from MUX1 to be inserted
        If dim([M:MUX1]ECCVALMAJ)>0
            [M:SCOK]ECCVALMAJ = [M:MUX1]ECCVALMAJ(L)
            [M:SCOK]ECCVALMIN = [M:MUX1]ECCVALMIN(L)
        Endif

        Call MAJ_SCO From SCOAUTLIB
        If [M:SCOK]CODRET <> 0
            WMESS = mess(641,197,1)-[M:SCOK]SCONUM-[M:SCOK]ITMREF+"/"+[M:SCOK]BPRNUM
            Call ECR_TRACE(WMESS,1) From GESECRAN
            Call ECR_TRACE(GMESSAGE,1) From GESECRAN
            Goto AB_MAJ
        Endif

        # GA 04/2008 Réseau MTO (FQ 46650) stockage du n° EO généré => repris en VCRTYPORI/VCRNUMORI des fils
        If dim([M:MUX1]VCRNUM)>0
           [M:MUX1]VCRTYP(L)=36
           [M:MUX1]VCRNUM(L)=[M:SCOK]SCONUM
           [M:MUX1]VCRLIN(L)=[M:SCOK]SCILIN
        Endif

        WMESS = mess(641,197,1)+" "+mess([M:SCOK]SCOSTA,317,1)+" "+[M:SCOK]SCONUM
        Call ECR_TRACE(WMESS,0) From GESECRAN
        WMESS = mess(80,197,1)+":"-[M:SCOK]ITMREF - mess(417,197,1)-num$([M:MUX1]LEVEL(L))-
&               mess(4,197,1)-format$(GFMD,[M:SCOK]STRDAT)-mess(38,197,1)-format$(GFMD,[M:SCOK]ENDDAT)-
&               ","-num$([M:SCOK]EXTQTY)-[M:MUX1]STU(L)
        Call ECR_TRACE(WMESS,0) From GESECRAN
        Call ECR_TRACE(" ",0) From GESECRAN
        NBEO += 1
        Commit

        #--------------------------------------------------#
        # v140 Calcul automatique des coûts prévisionnels # (CPT et CPL) 15/04/03
        #--------------------------------------------------#
        # Issue 74259 - 2011-06-08 by CCC
        #If GCLCWOCAUT=2
        If GCLCEOCAUT>=2
            # appel direct possible car aucune saisie (compatible Web ?)
            # charger les paramètres (! ne pas écraser les PARAM de ce GSAISIE)
            PARAM_CLC(1) = [M:SCOK]MFGFCY
            PARAM_CLC(2) = [M:SCOK]SCONUM
            PARAM_CLC(4) = "1"
            PARAM_CLC(5) = "4"
            PARAM_CLC(12) = "2" # pas d'edition !
            PARAM_CLC(13) = "0"   # Issue 89622 - 2013-06-05 by CCC
            PARAM_CLC(14) = "36"
            Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBSCC","",3,"") From GTRAITE
        Endif
$NEXTLEO
    Next L

$FIN_MAJEO
Return


##########################################################################
$MAJACH
NBACH = 0
    For L=0 To [M:MUX1]NBLIG - 1

        If [M:MUX1]PECFLG(L) <> 2   : Goto NEXTNA : Endif
        If [M:MUX1]PURFLG(L) <> 2   : Goto NEXTNA : Endif
        If [M:MUX1]REOCOD(L) <> 2   : Goto NEXTNA : Endif

        # si ferme et pas de fournisseur ou qté un UA nulle, pas de mise à jour
        If [M:MUX1]STRDAT(L) < date$ | ([M:MUX1]MFGSTA = 2 & [M:MUX1]BPSNUM(L) = "") |
&                        [M:MUX1]PUUPECQTY(L) = 0
            Goto NEXTNA
        Endif

        Raz [M:PMG]
        [M:PMG]MAJCOD         = "C"
        Case [M:MUX1]MFGSTA
            When 1: [M:PMG]MAJTYP         = "P"
                    [M:PMG]WIPSTA(0)      = 2
            When 2: [M:PMG]MAJTYP         = "F"
                    [M:PMG]WIPSTA(0)      = 1
        Endcase

        # Issue 82388 GA 06/2012
        # Ctrl si DA obligatoire, sauf si le besoin est une DA (VCRTYP=14 & WIPSTA=2)
        If [F:ITM]ITMREF<>[M:MUX1]ITMREF(L)
           Read [ITM]ITM0=[M:MUX1]ITMREF(L)
        Endif
        If [F:ITM]PRQFLG=2 & [M:PMG]MAJTYP="F" & [M:MUX1]VCRTYPORI(L)<>14
           [M:PMG]MAJTYP     ="P"
           [M:PMG]WIPSTA(0)  = 2
        Endif

        [M:PMG]RGRFLG         = 1
        [M:PMG]MSGFLG         = 1
        [M:PMG]TRAFLG         = 2
        If [M:MUX1]POHNUM(L) <> ""
            # contrat
            [M:PMG]WRCPDAT        = ""
            [M:PMG]USEPLC         = ""
            [M:PMG]NBLIG          = 1
            [M:PMG]POCNUM(0)      = [M:MUX1]POHNUM(L)
            [M:PMG]WIPTYP(0)      = 2
            [M:PMG]WIPNUM(0)      = ""
            [M:PMG]ITMREF(0)      = [M:MUX1]ITMREF(L)
            [M:PMG]ORIFCY(0)      = [M:MUX1]MFGFCY
            [M:PMG]STOFCY(0)      = [M:MUX1]MFGFCY
            [M:PMG]ENDDAT(0)      = [M:MUX1]ENDDAT(L)
            [M:PMG]STU(0)         = [M:MUX1]STU(L)
            [M:PMG]EXTSTUQTY(0)   = [M:MUX1]EXTQTY(L)
            [M:PMG]PUU(0)         = [M:MUX1]PUU(L)
            [M:PMG]EXTPUUQTY(0)   = [M:MUX1]PUUPECQTY(L)
        Else
            # hors contrat
            [M:PMG]REQUSR         = [M:MUX1]PLANNER
            [M:PMG]PSHFCY         = [M:MUX1]MFGFCY
            [M:PMG]PRQDAT         = date$
            [M:PMG]NBLIG          = 1
            [M:PMG]WIPTYP(0)      = 2   # "PO"
            [M:PMG]WIPNUM(0)      = ""
            [M:PMG]ITMREF(0)      = [M:MUX1]ITMREF(L)
            [M:PMG]ORIFCY(0)      = [M:MUX1]MFGFCY
            [M:PMG]STOFCY(0)      = [M:MUX1]MFGFCY
            [M:PMG]PJT(0)         = [M:MUX1]PJT(L)
            [M:PMG]BPRNUM(0)      = [M:MUX1]BPSNUM(L)
            [M:PMG]ENDDAT(0)      = [M:MUX1]ENDDAT(L)
            [M:PMG]STU(0)         = [M:MUX1]STU(L)
            [M:PMG]EXTSTUQTY(0)   = [M:MUX1]EXTQTY(L)
            [M:PMG]PUU(0)         = [M:MUX1]PUU(L)
            [M:PMG]EXTPUUQTY(0)   = [M:MUX1]PUUPECQTY(L)
        Endif
        If dim([M:PMG]MTOREF)>0 & [M:MUX1]MTOREF<>""
           [M:PMG]MTOREF = [M:MUX1]MTOREF       : # V6 Réseau MTO FQ 46650
        Endif

        #  V6 Réseau MTO FQ 46650: OF/EO et ligne OF/EO père
        Gosub RECH_VCRNUMORI
        If dim([M:PMG]VCRTYPORI)>0  [M:PMG]VCRTYPORI(0) = [M:MUX1]VCRTYPORI(L) Endif
        If dim([M:PMG]VCRNUMORI)>0  [M:PMG]VCRNUMORI(0) = [M:MUX1]VCRNUMORI(L) Endif
        If dim([M:PMG]VCRLINORI)>0  [M:PMG]VCRLINORI(0) = [M:MUX1]VCRLINORI(L) Endif
        If dim([M:PMG]VCRSEQORI)>0  [M:PMG]VCRSEQORI(0) = [M:MUX1]VCRSEQORI(L) Endif

        # Issue 112743 - 2015-11-27 by BEEBE : load the version fields from MUX1 to be inserted
        If dim([M:MUX1]ECCVALMAJ)>0
            [M:PMG]ECCVALMAJ = [M:MUX1]ECCVALMAJ(L)
            [M:PMG]ECCVALMIN = [M:MUX1]ECCVALMIN(L)
        Endif

        If [M:PMG]EXTPUUQTY(0) = 0 : Goto NEXTNA : Endif
        Call MGT_PURCHASE From TRTACHMGT1
        If [M:PMG]ERRCOD = 0
            NBACH += 1
        Endif

        # GA 04/2008 Réseau MTO (FQ 46650) stockage du n° PO généré (il n'y a pas de fils)
        If dim([M:MUX1]VCRNUM)>0 & [F:POH]POHNUM<>""
           [M:MUX1]VCRTYP(L)=14
           [M:MUX1]VCRNUM(L)=[F:POQ]POHNUM
           [M:MUX1]VCRLIN(L)=[F:POQ]POPLIN
        Endif

        WMESS = mess(80,197,1)+":"-[M:MUX1]ITMREF(L) - mess(417,197,1)-num$([M:MUX1]LEVEL(L))-
&               mess(4,197,1)-format$(GFMD,[M:MUX1]STRDAT(L))-mess(38,197,1)-format$(GFMD,[M:MUX1]ENDDAT(L))-
&               ","-num$([M:MUX1]EXTQTY(L))-[M:MUX1]STU(L)
        Call ECR_TRACE(WMESS,0) From GESECRAN

        Call ECR_TRACE(" ",0) From GESECRAN

$NEXTNA
    Next L

$FIN_MAJACH
Return

##########################################################################
$MAJINT
NBINT = 0
   For L=0 To [M:MUX1]NBLIG - 1

        If [M:MUX1]PECFLG(L) <> 2   : Goto NEXTNI : Endif
        If [M:MUX1]REOCOD(L) <> 4   : Goto NEXTNI : Endif

        # si ferme et pas de fournisseur ou qté un UA nulle, pas de mise à jour
        If [M:MUX1]STRDAT(L) < date$ | [M:MUX1]POHNUM(L) = "" | [M:MUX1]PUUPECQTY(L) = 0
            Goto NEXTNI
        Endif
        Raz [M:PMG]
        [M:PMG]MAJCOD         = "C"
        Case [M:MUX1]MFGSTA
            When 1: [M:PMG]MAJTYP         = "P"
                    [M:PMG]WIPSTA(0)      = 2
            When 2: [M:PMG]MAJTYP         = "F"
                    [M:PMG]WIPSTA(0)      = 1
        Endcase
        [M:PMG]RGRFLG         = 1
        [M:PMG]MSGFLG         = 1
        [M:PMG]TRAFLG         = 2
        If [M:MUX1]POHNUM(L) <> ""
            # contrat
            [M:PMG]WRCPDAT        = ""
            [M:PMG]USEPLC         = ""
            [M:PMG]NBLIG          = 1
            [M:PMG]POCNUM(0)      = [M:MUX1]POHNUM(L)
            [M:PMG]WIPTYP(0)      = 7
            [M:PMG]ITMREF(0)      = [M:MUX1]ITMREF(L)
            [M:PMG]ORIFCY(0)      = [M:MUX1]ORIFCY(L)
            [M:PMG]STOFCY(0)      = [M:MUX1]MFGFCY
            [M:PMG]ENDDAT(0)      = [M:MUX1]ENDDAT(L)
            [M:PMG]STU(0)         = [M:MUX1]STU(L)
            [M:PMG]EXTSTUQTY(0)   = [M:MUX1]EXTQTY(L)
            [M:PMG]PUU(0)         = [M:MUX1]PUU(L)
            [M:PMG]EXTPUUQTY(0)   = [M:MUX1]PUUPECQTY(L)
         Else
            # hors contrat
            [M:PMG]PSHFCY         = [M:MUX1]MFGFCY
            [M:PMG]PRQDAT         = date$
            [M:PMG]NBLIG          = 1
            [M:PMG]WIPTYP(0)      = 7
            [M:PMG]ITMREF(0)      = [M:MUX1]ITMREF(L)
            [M:PMG]ORIFCY(0)      = [M:MUX1]ORIFCY(L)
            [M:PMG]STOFCY(0)      = [M:MUX1]MFGFCY(L)
            [M:PMG]PJT(0)         = [M:MUX1]PJT(L)
            [M:PMG]BPRNUM(0)      = [M:MUX1]BPSNUM(L)
            [M:PMG]ENDDAT(0)      = [M:MUX1]ENDDAT(L)
            [M:PMG]STU(0)         = [M:MUX1]STU(L)
            [M:PMG]EXTSTUQTY(0)   = [M:MUX1]EXTQTY(L)
            [M:PMG]PUU(0)         = [M:MUX1]PUU(L)
            [M:PMG]EXTPUUQTY(0)   = [M:MUX1]PUUPECQTY(L)
        Endif
        #  V6 Réseau MTO FQ 46650: OF/EO et ligne OF/EO père
        Gosub RECH_VCRNUMORI
        If dim([M:PMG]VCRTYPORI)>0  [M:PMG]VCRTYPORI(0) = [M:MUX1]VCRTYPORI(L) Endif
        If dim([M:PMG]VCRNUMORI)>0  [M:PMG]VCRNUMORI(0) = [M:MUX1]VCRNUMORI(L) Endif
        If dim([M:PMG]VCRLINORI)>0  [M:PMG]VCRLINORI(0) = [M:MUX1]VCRLINORI(L) Endif
        If dim([M:PMG]VCRSEQORI)>0  [M:PMG]VCRSEQORI(0) = [M:MUX1]VCRSEQORI(L) Endif

        # Issue 112743 - 2015-11-27 by BEEBE : load the version fields from MUX1 to be inserted
        If dim([M:MUX1]ECCVALMAJ)>0
            [M:PMG]ECCVALMAJ = [M:MUX1]ECCVALMAJ(L)
            [M:PMG]ECCVALMIN = [M:MUX1]ECCVALMIN(L)
        Endif

        If dim([M:PMG]MTOREF)>0 & [M:MUX1]MTOREF<>""
           [M:PMG]MTOREF = [M:MUX1]MTOREF       : # V6 Réseau MTO FQ 46650
        Endif
        If [M:PMG]EXTPUUQTY(0) = 0 : Return : Endif
        Call MGT_PURCHASE From TRTACHMGT1
        If [M:PMG]ERRCOD = 0
            NBINT += 1
        Endif

        WMESS = mess(80,197,1)+":"-[M:MUX1]ITMREF(L) - mess(417,197,1)-num$([M:MUX1]LEVEL(L))-
&               mess(4,197,1)-format$(GFMD,[M:MUX1]STRDAT(L))-mess(38,197,1)-format$(GFMD,[M:MUX1]ENDDAT(L))-
&               ","-num$([M:MUX1]EXTQTY(L))-[M:MUX1]STU(L)
        Call ECR_TRACE(WMESS,0) From GESECRAN

        Call ECR_TRACE(" ",0) From GESECRAN

$NEXTNI
    Next L

$FIN_MAJINT
Return

$AB_MAJ
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

###########################################################################
$INC_ALL
For  I = 0 To [M:MUX1]NBLIG - 1
    [M:MUX1]PECFLG(I)  = 2
Next I

# Issue 111414/11 - 2016-02-11 by JUSYN : versions flag
Call UPD_PECFLG(0,[M:MUX1]NBLIG-1,1)

# revision bilan
Call BILAN

Affzo [MUX1]1-99
Return

###########################################################################
$EX_ALL
For  I = 0 To [M:MUX1]NBLIG - 1
    [M:MUX1]PECFLG(I)  = 1
Next I

# revision bilan
Call BILAN

Affzo [MUX1]1-99
Return

########################################################################
# Nouveau Réseau MTO: avant génération # FQ 46650 #
# ------------------------------------ #
#CHECK UNUSED_BEGIN
$MAJ_MTO
Local Integer STAT : STAT=0
If !func AFNC.ACTIV("MTO") : Return : Endif # FQ 52359
If [M:MUX1]MTOREF=""
  # récupération compteur OF
  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  # FQ 70628 GA 01/2011 ne pas utiliser GCODNUM=[F:TCA]CODNUM(0)
  Call NUMERO(8,7,"",[M:DIA]MFGFCY,[M:DIA]STRDAT,"",[M:MUX1]MTOREF,STAT) From TRTX3TCA
  If STAT <> 0 : Call ERREUR([F:TCA]CODNUM(7)-mess(60,199,1)-num$(STAT)) From GESECRAN
     # GOK=0  # à revoir par la suite ???
     Return
  Endif
Endif
#
If clalev([F:MTO])<=0 : Local File MTOHEAD [F:MTO] : Endif
[F:MTO]VCRTYP = 10                   : # OF uniquement pour le moment
[F:MTO]MTOREF = [M:MUX1]MTOREF
[F:MTO]MTODES = [M:DIA]MFGDES
[F:MTO]PJT    = [M:DIA]PJT
[F:MTO]STRDAT = [M:DIA]STRDAT
[F:MTO]ENDDAT = [M:DIA]ENDDAT
Gosub WRITE_MTO From MTOAUTLIB

Return
#CHECK UNUSED_END

########################################################################
# VCRNUMORI: recherche de la ligne document d'origine       # FQ 46650 #
########################################################################
# GA 04/2008 Réseau MTO FQ 46650
$RECH_VCRNUMORI
# Issue 79728 - GA 02/2012 all documents must have the same VCRNUMORI
Return

$RECH_VCRNUMORI_KO
Local Integer WLIGNE : WLIGNE = [M:MUX1]PARLIN(L)
If WLIGNE>=0 & dim([M:MUX1]VCRNUM)>WLIGNE & [M:MUX1]VCRNUM(WLIGNE)<>""
   [M:MUX1]VCRTYPORI(L) = [M:MUX1]VCRTYP(WLIGNE)
   [M:MUX1]VCRNUMORI(L) = [M:MUX1]VCRNUM(WLIGNE)
   [M:MUX1]VCRLINORI(L) = [M:MUX1]VCRLIN(WLIGNE)
         Filter [F:ORD]
&        Where STOFCY=[M:MUX1]MFGFCY & VCRTYPORI=[M:MUX1]VCRTYP(WLIGNE)
&            & VCRNUMORI=[M:MUX1]VCRNUM(WLIGNE) & VCRLINORI=[M:MUX1]VCRLIN(WLIGNE)
&            & find(WIPTYP,2,6,3)
         For [F:ORD] Hint Key ORD3
             If [F:ORD]ITMREF=[M:MUX1]ITMREF(L) & [F:ORD]EXTQTY=[M:MUX1]EXTQTY(L)
                [M:MUX1]VCRSEQORI(L) = [F:ORD]VCRSEQ
                Break
             Endif
         Next
         Filter [F:ORD]
Endif
Return

# -----------------------------------------------------------------------------------
# Issue 88210 GA 02/2013 délai d'achat en jours calendaires, sauf si le PE active GPE
# WORIDAT contient la date de réception souhaitée
# -----------------------------------------------------------------------------------
$CAL_PURSTRDAT
WSNS = "-"
Gosub CAL_PURDAT
[M:MUX1]STRDAT(L) = WDAT
Return

$CAL_PURDAT
Local Integer  WCOR     :     # Arrondi date
Local Integer  WCOD     :     # Type de délai
Local Decimal  WDEL     :     # Délai réappro
Local Decimal  WCAP(1)  : WCAP(0)=1
Local Date     WDAT, WDSTDAT

Local Shortint GPE : GPE=0
GPOINT="PURSTRDAT" : Gosub ENTREE From EXEFNC # Issue 87401 GA 02/2013
WCOR = 8
WDEL = WLTI
If !GPE
  WCOD = 1  # délai en jours calendaires
  # correction appliquée dans le CBN, ignorée ici pour le moment voir FUNCBN(CALDATSUG)
  #Call CORDEL(WDEL,WSUG,WCOE,WLOT) From CBNLIB
  Call CALDAT(WSNS,WCOR,WORIDAT,WCOD,WDEL,WCAP,WORIDAT,WDAT) From CBNLIB
  If WLTIJO=2 : ## GH 03/06/2013 bug 90223
     # la date doit tomber sur un jour ouvré
     mkstat=0
     Call CONTROL_DATE_PLN(WDAT,WORIFCY) From MFGLIB
     If mkstat
        GMESSAGE=""
        Call CALCUL_DATE_PLN(WDAT, 1, WORIFCY, (WSNS="-"), WDSTDAT) From MFGLIB
        WDAT = WDSTDAT
     Endif
  Endif
Else
  # délai en jours ouvrés
  Call CALCUL_DATE_PLN(WORIDAT, WDEL, WORIFCY, (WSNS="-"), WDAT) From MFGLIB
Endif
Return

$CAL_BOMOFS_ENDDAT : # GH 10/04/2013 bug 88882
If find(WLTIJO,0,2)
  # délai en jours calendaires
  Local Integer  WCOR     :     # Arrondi date
  Local Integer  WCOD     :     # Type de délai
  Local Decimal  WDEL     :     # Délai réappro
  Local Decimal  WCAP(1) : WCAP(0)=1
  Local Date     WDAT
  WCOR     = 8
  WDEL     = WLTI
  WCOD     = 1
  Call CALDAT("+",WCOR,WORIDAT,WCOD,WDEL,WCAP,WORIDAT,WDAT) From CBNLIB
  [M:MUX1]ENDDAT(L) = WDAT
  If WLTIJO=2
     # la date doit tomber sur un jour ouvré
     mkstat=0
     Call CONTROL_DATE_PLN([M:MUX1]ENDDAT(L), WORIFCY) From MFGLIB
     If mkstat
        GMESSAGE=""
        Call CALCUL_DATE_PLN(WDAT, 1, WORIFCY, 0, WDSTDAT) From MFGLIB
        [M:MUX1]ENDDAT(L) = WDSTDAT
     Endif
  Endif
Else
  # délai en jours ouvrés
  Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB
  [M:MUX1]ENDDAT(L) = WDSTDAT
Endif
Return

########################################################################
$CHARG_PARAM
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
# GA 02/2008 pour la V6
If GMODU(2)=2 : # Dossier avec module comptabilité
  Call GLOBVAR(GFCY)  From WWGLOBCPT
  #----- Chargement des globales référentiels, comptes et sections de la société -----#
  Call GETCPY(GFCY,"",0,"") From TRTX3CPT
Endif
Return

########################################
# Issue 111835 - 2015-10-30 by BEEBE : validation modified start date -> the version may not change
Subprog CHECK_VERSION_STRDAT(PSTRDAT, POCC)
Variable Date PSTRDAT()
Variable Integer POCC()

Local Integer LECCTYP
Local Integer LFOUND : LFOUND=0

If dim([M:MUXB]ECCVALMAJ)>0 & [M:MUXB]ECCVALMAJ(POCC)<>""
    Case [M:MUXB]WIPTYP(POCC)
        When 5       : LECCTYP=2
        When 13,4    : LECCTYP=3
        When Default : LECCTYP=4
    Endcase

    If !clalev([F:ECS]) : Local File ECCSTA [ECS] : Endif
    If !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif

    # Is the actual version valid for the new start date ?
    # selection depends of the flow-type
    If LECCTYP=4
        Link [EVL] With [ECS]ECS0=[EVL]ITMREF;[EVL]ECCVALMAJ
&                  As [LNK]
&                  Where [EVL]ITMREF=[M:MUXB]ITMREF(POCC)
&                      & [EVL]ECCVALMAJ=[M:MUXB]ECCVALMAJ(POCC)
&                      & [EVL]ECCVALMIN=[M:MUXB]ECCVALMIN(POCC)
&                      & [EVL]ECCTYP=4
&                      & [EVL]USESTA=2
&                      & [ECS]STRDAT<=PSTRDAT
&                      & ([F:ECS]ENDDAT=[0/0/0] | [F:ECS]ENDDAT>=PSTRDAT | [F:ECS]EXNFLG=2)
&                      & ([F:ECS]EXNDAT=[0/0/0] | [F:ECS]EXNDAT>=PSTRDAT | [F:ECS]EXNFLG=1)
&                      & [F:ECS]ECCSTA<>3
&               Order By EXNFLG;ECCSEQ
    Else
        Link [EVL] With [ECS]ECS0=[EVL]ITMREF;[EVL]ECCVALMAJ
&                  As [LNK]
&                  Where [EVL]ITMREF=[M:MUXB]ITMREF(POCC)
&                      & [EVL]ECCVALMAJ=[M:MUXB]ECCVALMAJ(POCC)
&                      & [EVL]ECCVALMIN=[M:MUXB]ECCVALMIN(POCC)
&                      & [EVL]ECCTYP=LECCTYP
&                      & [EVL]USESTA=2
&                      & [EVL]STRDAT<=PSTRDAT
&                      & ([F:EVL]ENDDAT=[0/0/0] | [F:EVL]ENDDAT>=PSTRDAT | [F:EVL]EXNFLG=2)
&                      & ([F:EVL]EXNDAT=[0/0/0] | [F:EVL]EXNDAT>=PSTRDAT | [F:EVL]EXNFLG=1)
&                      & [F:ECS]ECCSTA<>3
&               Order By EXNFLG;ECCSEQ
    Endif

    # LFOUND=1 -> the version is valid for the new start date
    For [LNK]
        LFOUND=1
        Break
    Next

    # LFOUND=False -> the version is not valid, the start date has to be
    #                 set to the origin start date
    If !LFOUND
        # Error Message
        WMESS=mess(80,197,1)+":"-[M:MUXB]ITMREF(POCC) - mess(417,197,1)-num$([M:MUXB]LEVEL(POCC))
        WMESS1=mess(432,184,1)-num$(PSTRDAT)-mess(852,197,1)+":"-[M:MUXB]ECCVALMAJ(POCC)
        If [M:MUXB]ECCVALMIN(POCC)<>""
            WMESS1 =WMESS1-mess(853,197,1)+":"-[M:MUXB]ECCVALMIN(POCC)
        Endif
        Call ECR_TRACE(WMESS-WMESS1,0) From GESECRAN
        # Trace Message in a Log-File
        If GTRACE = ""
            Local Char LCOMMENT(250) : LCOMMENT=mess(231,195,1)
            Call OUVRE_TRACE(LCOMMENT) From LECFIC
            Call ECR_TRACE(WMESS,0) From GESECRAN
            Call ECR_TRACE(WMESS1,0) From GESECRAN
        Endif
        GOK=0 # Issue 111835 - 2015-11.25 by BEEBE : in error case set GOK=0 instead of mkstat=2
        GERR=1
    Endif
Endif
End

######################################################################################

