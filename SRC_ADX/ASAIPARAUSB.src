#<AdxTL>@(#)5.0.0.0 $Revision$
$ACTION
Case ACTION
 When "C_VALEUR" : Gosub C_VALEUR
Endcase
Return

$C_VALEUR
Case [M]PARAM(nolign-1)
 When "SCHSAISIE"
  If filinfo(filpath("FIL","GDIAENTRY","fde",nomap),0)>=0
   If clalev([F:GDE])=0 : Local File GDIAENTRY [GDE] : Endif
   Call CONTROLE("GDE","!",VALEUR,"",mkstat) From CONTOBJ 
  Endif
  # La transaction "Standard" de type "Saisie par lot" doit être flagué "Par lot"
  If !mkstat & clalev([F:GDE])>0 & VALEUR<>"" & [F:GDE]FLGLOT=2
   # Schéma de saisie incorrect
   GMESSAGE = mess(130,104,1) : mkstat = 2 : End
  Endif
 When "SCHSAILOT"
  If filinfo(filpath("FIL","GDIAENTRY","fde",nomap),0)>=0
   If clalev([F:GDE])=0 : Local File GDIAENTRY [GDE] : Endif
   Call CONTROLE("GDE","!",VALEUR,"",mkstat) From CONTOBJ 
  Endif
  # La transaction "Standard" de type "Saisie par lot" doit être flagué "Par lot"
  If !mkstat & clalev([F:GDE])>0 & VALEUR<>"" & [F:GDE]FLGLOT<>2
   # Schéma de saisie incorrect
   GMESSAGE = mess(130,104,1) : mkstat = 2 : End
  Endif
Endcase
Return
