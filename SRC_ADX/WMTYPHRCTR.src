#<AdxTL>@(#)0.0.0.0 $Revision$Class Employment contract
# Supervisor
## ATY-ATYPE ## HRCTR
# 2018-11-09 07:14:27 149

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,REFNUM,CTRNUM,CTRDAT,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char REFNUM
Value Char CTRNUM
Value Date CTRDAT
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File EMPLOCTR [HRCTR]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".EMPLOCTR" [HRCTR]
Endif

Default File [F:HRCTR]
Read [F:HRCTR]CTR0 = [L]REFNUM;[L]CTRNUM;[L]CTRDAT
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]REFNUM)+"~"+num$([L]CTRNUM)+"~"+num$([L]CTRDAT)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]REFNUM)+"~"+num$([L]CTRNUM)+"~"+num$([L]CTRDAT)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


