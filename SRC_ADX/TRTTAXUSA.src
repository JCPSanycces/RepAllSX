#<AdxTL>@(#)1.0.0.0 $Revision$
#############################################################################
#                                                                           #
#      TRAITEMENTS LIES AUX TAXES AMERICAINES                               #
#                                                                 Juin 2000 #
#                                                                           #
#############################################################################
#                                                                           #
# Subprog CLCTAXEUSA(WABMSK,WKU_MAJ)                                        #
#       Calcul d'une taxe américaine                                        #
#                                                                           #
# $PLUS_LIGNE_USA                                                           #
#       En plus dans le tableau des lignes si taxe américaines              #
#                                                                           #
# $CAL_FACTURE_USA                                                          #
#       Calcul de la facture si taxe americaines                            #
#                                                                           #
# $VALID_SIV_USA                                                            #
#       Validation d'une facture de vente                                   #
#                                                                           #
#                                                                           #
# SST_CALCTAX          - Retrieves sales tax for unposted document
# POST_TAX             - Sets Tax so that it can be commited
# COMMIT_TAX           - Retrieves updated tax, then sends a commit request
# CANCEL_TAX           - Sends a cancel request against saved invoice document
#                                                                           #
#############################################################################

# TODO: Table PARTAXUSA is no longer used - mask PARTAXUSA is used.

#**
#* CLCTAXEUSA = This subprogram is called from several programs. Its only purpose now is to
#* the 'tax by document' flag for the 'FUN' programs.
#*
#* @param WABMSK - Left in place for historical reasons. The routines that call this subprogram pass
#*        these two parameters but neither are used
#* @param WSSTFLG - No  longer  used.
#*!
Subprog CLCTAXEUSA(WABMSK,WSSTFLG)
Value    Char       WABMSK()
Value Char       WSSTFLG()
If  func AFNC.ACTIV("LTA")                    # Sage Sales Tax - tax by document and not line.
    If GFONCTION="FUNAUTDLV" | left$(GFONCTION,9)="FUNAUTINV"
        GTAXBYDOC = 1
    Endif
Endif
End

#**
#* Build SIHX mask prior to calling tax calc
#*  called From TRTVENFACC & TRTTAXUSA
#*!
$PLUS_LIGNE_USA
Local Integer RV
Raz RV

LIG=[M:SIHX]LIGNE-1                             # Number of the current product detail line to process into SIHX
If LIG<0 or [M:SIH4]ITMREF(LIG)="" : Return : Endif  # Verify a valid value

Local Integer RV
Raz RV

[M:SIH4]UPDFLG(LIG)=1
If [F:TCU]CUR<>[M:SIH0]CUR
  Read [TCU]TCU0=[M:SIH0]CUR
Endif

WVAT=[M:SIH4]VAT1(LIG)
# si taxe principale absente : c'est une taxe exo
If WVAT="" : WVAT=GEXETAX : Endif

RV = find(WVAT,[M:SIHX]XVTAX(0..dim([M:SIHX]XVTAX)-1))
# Tax code  in SIHX mask
If !RV
    RV=find("",[M:SIHX]XVTAX(0..dim([M:SIHX]XVTAX)-1))        # Find Empty Position in SIHX
    If  RV
        Gosub LEC_VAT From TRTVENFACC                         # Get Tax Information
        If  [F:TVT]VAT<>""
            Gosub CHARG_VAT From TRTVENFACC                   # Load Tax =Information
            [M:SIHX]NBVAT= RV
        Endif
        [M:SIHX]XVRAT(RV-1) = [M:SIH4]RATTAXLIN(LIG)
    Endif
Endif

#  Determine Tax
If RV                             : # un poste pour cette taxe
  ZAMTNOT(0) = 0
  ZAMTATI(0) = 0

  If [M:SIHX]XVBAS(RV-1)<2
    ZAMTNOT(0) = arr([M:SIH4]NETPRINOT(LIG)*[M:SIH4]QTY(LIG),[F:TCU]CURRND)
    ZAMTATI(0) = arr([M:SIH4]NETPRIATI(LIG)*[M:SIH4]QTY(LIG),[F:TCU]CURRND)
  Endif
  ZVAT(0)=WVAT
  ZRV(0)=RV
  ZRAT(0)=[M:SIHX]XVRAT(RV-1)
  ZBASTAX(0)=ZAMTNOT(0)
 # Calculate Tax Amount
  ZAMTTAX(0)= ZAMTATI(0)-ZAMTNOT(0)
 # Re-calculate Tax Rate
  If ZAMTNOT(0) <> 0
      ZRAT(0)=((ZAMTATI(0)-ZAMTNOT(0))/ZAMTNOT(0))*100
  Endif
Else
# Tax element not found
  Return
Endif
#------------------------------------------------------------------------
# Pas de traitement de la Taxe secondaire 1
#------------------------------------------------------------------------
# Pas de traitement de la Taxe secondaire 2
#------------------------------------------------------------------------
# Pas d'appel nécessaire à CALCULTAXE
# m.a.j. de la ligne
[M:SIH4]AMTNOTLIN(LIG)=ZAMTNOT(0)
[M:SIH4]BASTAXLIN1(LIG)=ZBASTAX(0)
[M:SIH4]RATTAXLIN(LIG)=ZRAT(0)
[M:SIH4]AMTTAXLIN1(LIG)=ZAMTTAX(0)
[M:SIH4]AMTATILIN(LIG) =ZAMTATI

# Fill out Tax Mask

JL=ZRV(0)-1
[M:SIHX]XVNOT(JL) += ZAMTNOT
[M:SIHX]XVSMI(JL) += ZBASTAX(0)
[M:SIHX]XVSMIP(JL) += ZBASTAX(0)
[M:SIHX]XVSMITP(JL) = 0
[M:SIHX]XVSMITS(JL) = 0
[M:SIHX]XVAMT(JL) += ZAMTTAX(0)
[M:SIHX]XVSUP(JL) = 0
[M:SIHX]XVATI(JL) += ZAMTATI
If [M:SIHX]XVSMI(JL)<>0
  [M:SIHX]XVRAT(JL) = ([M:SIHX]XVAMT(JL)/[M:SIHX]XVSMI(JL))*100
Else
  [M:SIHX]XVRAT(JL) = 0
Endif

For JL = 0 To dim([M:SIHX]XFNUM)-1
  If [M:SIHX]XFLCOLTAR(JL) <> 0  # Colonne de tarif qui va dans un pied
   If evalue ("dim([M:SIH4]DISCRGVAL"+num$([M:SIHX]XFLCOLTAR(JL))+"(LIG))") > 0
    WMT1 = evalue("[M:SIH4]DISCRGVAL"+num$([M:SIHX]XFLCOLTAR(JL))+"(LIG)")
#      on saute les elts liés au document
    If [M:SIHX]XFLCLCRUL(JL)<>3 & WMT1 <> 0
#        le sens (majoration/minoration)
      If [M:SIHX]XFLINCDCR(JL)=2 WSENS=-1 Else WSENS=1 Endif
#        si valeur est % du prix net
      If [M:SIHX]XFLVALTYP(JL)>1 : WMT1=([M:SIH4]NETPRI(LIG)*WMT1)/100 : Endif
#        si valeur est par unité
      If [M:SIHX]XFLCLCRUL(JL)=1 : WMT1=WMT1*[M:SIH4]QTY(LIG) : Endif
      If WMT1<>0
        ZAMTTAX(0)=0
        WMT1=arr(WMT1*WSENS,[F:TCU]CURRND)
        If [M:SIHX]VATRUL(JL)=1                          : # taxe produit
          WVAT=[M:SIH4]VAT1(LIG)
          If WVAT="" : WVAT=GEXETAX : Endif
          RV = find(WVAT,[M:SIHX]XVTAX(0..dim([M:SIHX]XVTAX)-1))
          If RV
            Local Shortint JL1
            For JL1=1 To dim([M:SIHX]XVTAX)
                If evalue ("dim([M:SIHX]DTAVAT"+format$("N0:2",JL1)+")")>0
                   If evalue ("[M:SIHX]DTAVAT"+format$("N0:2",JL1)+"("+num$(JL)+")")=WVAT
                      # On a trouve le poste correspondant à la taxe :
                      If [M:SIH1]PRITYP=1
                          # On cumule le montant soumis
                          WDTANET  = evalue ("[M:SIHX]DTANET"+format$("N0:2",JL1)+"("+num$(JL)+")")
                          WDTANET += WMT1
                          Assign ("[M:SIHX]DTANET"+format$("N0:2",JL1)+"("+num$(JL)+")") With WDTANET
                      Else
                          # On cumule le montant ttc
                          WDTAATI  = evalue ("[M:SIHX]DTAATI"+format$("N0:2",JL1)+"("+num$(JL)+")")
                          WDTAATI += WMT1
                          Assign ("[M:SIHX]DTAATI"+format$("N0:2",JL1)+"("+num$(JL)+")") With WDTAATI
                      Endif
                      Break
                   Elsif evalue ("[M:SIHX]DTAVAT"+format$("N0:2",JL1)+"("+num$(JL)+")")=""
                      # On a pas trouve le poste correspondant à la taxe : On prend le 1er poste dispo
                      Assign ("[M:SIHX]DTAVAT"+format$("N0:2",JL1)+"("+num$(JL)+")") With WVAT
                      Assign ("[M:SIHX]DTAVATRT"+format$("N0:2",JL1)+"("+num$(JL)+")") With [M:SIHX]XVRAT(RV-1)
                      If [M:SIH1]PRITYP=1
                          Assign ("[M:SIHX]DTANET"+format$("N0:2",JL1)+"("+num$(JL)+")") With WMT1
                      Else
                          Assign ("[M:SIHX]DTAATI"+format$("N0:2",JL1)+"("+num$(JL)+")") With WMT1
                      Endif
                      Break
                   Endif
                Endif
            Next JL1
          Endif
        Else                   : # autres taxes (calcul taxe dans traitement pied)
          # Nvx calcul V6 : garnissage du tableau des taxes de l'élément
          If dim([M:SIHX]DTANET01)>0
              If [M:SIH1]PRITYP=1
                  [M:SIHX]DTANET01(JL)+=WMT1   : # On garnit le montant soumis
              Else
                  [M:SIHX]DTAATI01(JL)+=WMT1   : # On garnit le montant ttc
              Endif
          Endif
        Endif
        # Nvx calcul V6 : garnissage du tableau des taxes de l'élément
        If [M:SIH1]PRITYP=1
            [M:SIHX]XFNOTL(JL) += WMT1
            [M:SIHX]XFSMIL(JL) += WMT1
        Else
            [M:SIHX]XFATIL(JL) += WMT1
        Endif
      Endif
    Endif
   Endif
  Endif
Next JL

Gosub PE_CPLVALLIG From TRTVENFACC

[M:SIHX]INVNOT = sum([M:SIHX]XVNOT)+sum([M:SIHX]XFNOT)
[M:SIHX]INVATI = sum([M:SIHX]XVATI)+sum([M:SIHX]XFATI)
[M:SIH4]INVATI = [M:SIHX]INVATI
[M:SIH4]INVNOT = [M:SIHX]INVNOT

Return

#**
#* CAL_FACTURE_USA - Core to filling out the masks for taxing and requesting the SST Tax calculation connector.
#*
#* Called by TRTVENFACC
#*!
$CAL_FACTURE_USA
If func AFNC.ACTIV("LTA") & GTAXBYDOC
  Raz GTAXBYDOC       # GTAXBYDOC indicates that the tax calculation is to occur. clear immediately at the start of tax calc routines.
Else
  Return
Endif
Local Integer ERR
Local Char ERRMSG(250)
Local Integer  WNBXVTAX : WNBXVTAX=dim([M:SIHX]XVTAX)-1   : # Bug 74556 : Optimisation
Local Integer  WNBXFNUM : WNBXFNUM=dim([M:SIHX]XFNUM)-1   : # Bug 74556 : Optimisation
Local Decimal  TVASMITS   (0..dim([M:SIHX]XVTAX)-1)
Local Shortint TVAUPDSMIP (0..dim([M:SIHX]XVTAX)-1)
# Garnissage des tables internes taxes
Raz JTVA, JTPA, JTSP, NBTVA, NBTPA, NBTSP
Raz TVACOD, TVANOT, TVASMI,  TVASMIP, TVASMIF, TVASMITP, TVASMITS, TVATAUX, TVAAMT,
&   TVASUP, TVAATI, TVARANG, TVASMITS, TVAUPDSMIP
Raz TPACOD, TPANOT, TPASMIP, TPATAUX, TPAAMT, TPARANG
Raz TSPCOD, TSPNOT, TSPSMIP, TSPTAUX, TSPAMT, TSPRANG
For JL=0 To dim([M:SIHX]XVTAX)-1
  If [M:SIHX]XVTAX(JL)<>""
    If [M:SIHX]XVTYP(JL) = 1     : # taxe TVA
      TVACOD(JTVA)=[M:SIHX]XVTAX(JL) : TVANOT(JTVA)=[M:SIHX]XVNOT(JL)
      TVASMI(JTVA)=[M:SIHX]XVSMI(JL)
      TVASMIP(JTVA)=[M:SIHX]XVSMIP(JL) : TVASMIF(JTVA)=[M:SIHX]XVSMIF(JL)
      TVASMITP(JTVA)=[M:SIHX]XVSMITP(JL) : TVASMITS(JTVA)=[M:SIHX]XVSMITS(JL)
      TVATAUX(JTVA) =[M:SIHX]XVRAT(JL)   : TVAAMT(JTVA)  =[M:SIHX]XVAMT(JL)
      TVASUP(JTVA)  =[M:SIHX]XVSUP(JL)   : TVAATI(JTVA)  =[M:SIHX]XVATI(JL)
      TVARANG(JTVA) =JL
      JTVA += 1
    Endif
#   Pas de traitement des taxes Parafiscale - Skip Additional tax XVTYP=2
#   Pas de traitement des taxes Spéciale - Skip Special tax XVTYP=3
  Endif
Next JL
NBTVA=JTVA : NBTPA=JTPA : NBTSP=JTSP
If [M:SIH0]CUR<>GSYSCUR
  # manip pour recuperer coefficient ( mt devise dossier * coefficient = mt devise facture )
  Call CONVERT(GSYSCUR,[M:SIH0]CUR,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,1000000.00,WMT2,STAT) From TRTDEV
  If STAT=0 & WMT2<>0
    COEFDEVISE=WMT2/1000000.00
  Else
    COEFDEVISE=1
  Endif
Endif
If [F:TCU]CUR<>[M:SIH0]CUR
  Read [TCU]TCU0=[M:SIH0]CUR
Endif
# Load SIHX footer values from invoice elements
For JL=0 To dim([M:SIH2]INVDTA)-1
  If [M:SIH2]INVDTA(JL)<>0
    RF=find([M:SIH2]INVDTA(JL),[M:SIHX]XFNUM(0..dim([M:SIHX]XFNUM)-1))
    If RF
       [M:SIHX]XFDTAAMT(RF-1)=[M:SIH2]INVDTAAMT(JL)
    Endif
  Endif
Next JL

# Recalculation of Tax Rate
For JL=0 To dim([M:SIHX]XVTAX)-1
  If [M:SIHX]XVTAX(JL)<>""
      If [M:SIHX]XVSMI(JL) <> 0
          [M:SIHX]XVRAT(JL) = (([M:SIHX]XVATI(JL)-[M:SIHX]XVSMI(JL))/[M:SIHX]XVSMI(JL))*100
      Endif
  Endif
Next JL

# transfert dans SIHV (écran SIHX après saisie ne doit pas être modifié par le calcul
#(MGG 08/05/2017) X3-33114
#[M:SIHV]=[M:SIHX]
Raz [M:SIHV]
Transmask [M:SIHX] To [M:SIHV]
#END(MGG 08/05/2017) X3-33114

# initialisation dans tableau des montants saisis en pied dans XF
Raz [M:SIHV]XFNOTP, [M:SIHV]XFSMIP
# si en dehors de la sélection, on remet à zero la valeur et le pied ne sera pas traité
For JL=0 To dim([M:SIHV]XFNUM)-1
  If [M:SIHV]PROCOD(JL)=2   :
#   modifiable invoice element
    [M:SIHV]XFDTAAMT(JL)=[M:SIHV]DEFVAL(JL) # Default Value of invoice element
    If [M:SIHV]AMTCOD(JL)=2  : # if amount passed in currency then rounding
      [M:SIHV]XFDTAAMT(JL)=arr([M:SIHV]XFDTAAMT(JL)*COEFDEVISE,[F:TCU]CURRND)
    Endif
  Endif
  If [M:SIHV]XFDTAAMT(JL)<>0 : # If footer amount
#   if tax code or min threshold not zero or max threshold not 0
    If [M:SIHV]XFMCLCVAT(JL)<>"" | [M:SIHV]TSDMIN(JL)<>0 | [M:SIHV]TSDMAX(JL)<>0
      WMT1=0
      For JL1=0 To dim([M:SIHV]XVTAX)-1
        If [M:SIHV]XVTYP(JL1)=1 : # Select primary tax type (VAT tax)
          If [M:SIHV]XFMCLCVAT(JL)=""
            WMT1 += [M:SIHV]XVNOT(JL1)
          Else
            If [M:SIHV]XFMCLCVAT(JL)=[M:SIHV]XVTAX(JL1)
              WMT1 += [M:SIHV]XVNOT(JL1)
            Endif
          Endif
        Endif
      Next JL1
      If [M:SIHV]XFMCLCVAT(JL)<>"" & WMT1=0   : # pas de ligne pour le niveau de s?lection taxe
        Raz [M:SIHV]XFDTAAMT(JL), [M:SIHV]XFNOTL(JL), [M:SIHV]XFSMIL(JL)
      Endif
      If [M:SIHV]TSDMIN(JL)<>0 & WMT1<([M:SIHV]TSDMIN(JL)*COEFDEVISE)
        Raz [M:SIHV]XFDTAAMT(JL), [M:SIHV]XFNOTL(JL), [M:SIHV]XFSMIL(JL)
      Endif
#     Si seuil maxi, raz valeur si mnt HT < seuil mini
      If [M:SIHV]TSDMAX(JL)<>0 & WMT1>([M:SIHV]TSDMAX(JL)*COEFDEVISE)
        Raz [M:SIHV]XFDTAAMT(JL), [M:SIHV]XFNOTL(JL), [M:SIHV]XFSMIL(JL)
      Endif
    Endif
  Endif
Next JL
# ------------------------------------ #
#  traitement des pieds                #
# ------------------------------------ #
#  eclatement des pieds par taxes

If sum([M:SIHV]INVFOOBRD)<>0    ### Exploded elements only
  Gosub CAL_ECLATEMENT From TRTVENFACC
Endif
# Pas de distinction entre les pieds s'appliquant sur du HT ou sur du TTC

For JL=0 To dim([M:SIHV]XFNUM)-1  #

#   Calcul du montant HT
    If [M:SIHV]XFDTAAMT(JL)<>0 : # si une valeur dans le pied
        Gosub CAL_PIED_USA
    Endif
    [M:SIHV]XFSMIP(JL)=ZFSMIP : Raz ZFSMIP
    [M:SIHV]XFNOT(JL) = [M:SIHV]XFNOTP(JL)+[M:SIHV]XFNOTL(JL)
    [M:SIHV]XFSMI(JL) = [M:SIHV]XFSMIP(JL)+[M:SIHV]XFSMIL(JL)
    [M:SIHV]XFATI(JL) = [M:SIHV]XFNOT(JL)+[M:SIHV]XFVATAMT(JL) : # bug 21921 29/03/04

Next JL
Call CALCTAX("SIHV",ERR,ERRMSG)
Return

#############################################################################


#------------------------------------------------------------------------
# Calcul un pied de facture sur HT
# Calcul du montant HT et soumis frais pied XFNOTP
$CAL_PIED_USA
Raz ZFSMIP, ZFNOTP
If [M:SIHV]INCDCR(JL)=1 WSENS=1 Else WSENS=-1 Endif

Gosub PE_CALPIEDHT From TRTVENFACC  : # appel du point d'entree CALPIEDHT

If ZFNOTP<>0                        : # HT pied garni par point d'entree
  [M:SIHV]XFNOTP(JL)=ZFNOTP*WSENS
  If [M:SIHV]AMTCOD(JL)=1 & [M:SIHV]CLCBAS(JL)=2
    Raz ZFSMIP
  Else ZFSMIP=[M:SIHV]XFNOTP(JL)
  Endif
  Raz ZFNOTP

Else                                : # pas de modif. du HT pied par point entree

# calcul du montant
  If [M:SIHV]AMTCOD(JL)=2           : # c'est un montant
    [M:SIHV]XFNOTP(JL)=[M:SIHV]XFDTAAMT(JL)*WSENS
    ZFSMIP=[M:SIHV]XFNOTP(JL)
  Endif
  If [M:SIHV]AMTCOD(JL)=1           : # c'est un taux
    Raz WMNTCLCBAS  # 102255.n
    If [M:SIHV]CLCBAS(JL)=1         : # sur le HT
      If [M:SIHV]XFMCLCVAT(JL)<>""  : # application de la sélection taxe pour le calcul
        JLT=find([M:SIHV]XFMCLCVAT(JL),TVACOD(0..NBTVA-1))
        If JLT
          If WMNTCLCBAS=0 WMNTCLCBAS=TVANOT(JLT-1) Endif
          [M:SIHV]XFNOTP(JL)=arr(WMNTCLCBAS*[M:SIHV]XFDTAAMT(JL)/100,[F:TCU]CURRND)*WSENS
        Endif
      Else
        If WMNTCLCBAS=0 WMNTCLCBAS=sum(TVANOT) Endif
        [M:SIHV]XFNOTP(JL)=arr(WMNTCLCBAS*[M:SIHV]XFDTAAMT(JL)/100,[F:TCU]CURRND)*WSENS
      Endif
      ZFSMIP=[M:SIHV]XFNOTP(JL)
    Endif
    If [M:SIHV]CLCBAS(JL)=2         : # sur le TTC
      If [M:SIHV]XFMCLCVAT(JL)<>""  : # application de la sélection taxe pour le calcul
        JLT=find([M:SIHV]XFMCLCVAT(JL),TVACOD(0..NBTVA-1))
        If JLT
          If WMNTCLCBAS=0 WMNTCLCBAS=TVAATI(JLT-1) Endif
          [M:SIHV]XFNOTP(JL)=arr(WMNTCLCBAS*[M:SIHV]XFDTAAMT(JL)/100,[F:TCU]CURRND)*WSENS
        Endif
      Else
        If WMNTCLCBAS=0 WMNTCLCBAS=sum(TVAATI) Endif
        [M:SIHV]XFNOTP(JL)=arr(WMNTCLCBAS*[M:SIHV]XFDTAAMT(JL)/100,[F:TCU]CURRND)*WSENS
      Endif
      ZFSMIP=[M:SIHV]XFNOTP(JL)
    Endif
  Endif
Endif
Return

#------------------------------------------------------------------------
# calcul total HT, taxes et TTC du pied
$CAL_PIED_F_USA
[M:SIHV]XFSMIP(JL)=ZFSMIP : Raz ZFSMIP
[M:SIHV]XFNOT(JL) = [M:SIHV]XFNOTP(JL)+[M:SIHV]XFNOTL(JL)
[M:SIHV]XFSMI(JL) = [M:SIHV]XFSMIP(JL)+[M:SIHV]XFSMIL(JL)

# Branchement du sous-pro de calcul pour les usa
If [M:SIHV]XFSMI(JL)<>0 : # si une valeur dans le pied
        [M:SIHV]XFVATAMT(JL) = 0
        [M:SIHV]XFATI(JL)=[M:SIHV]XFNOT(JL)
Endif
Return

#**
#* VALID_SIV_USA - validate invoice document - called from TRTVENFACR
#*!
$VALID_SIV_USA
Local Integer NLIG, STAT
Local Char    WKU_MAJ

If clalev([M:SIH0])=0 : Local Mask SIH0 [SIH0] : Raz [SIH0] : Endif
If clalev([M:SIH1])=0 : Local Mask SIH1 [SIH1] : Raz [SIH1] : Endif
If clalev([M:SIH2])=0 : Local Mask SIH2 [SIH2] : Raz [SIH2] : Endif
If clalev([M:ADB2])=0 : Local Mask ADRBPC [ADB2] : Raz [ADB2] : Endif

Local Decimal WDTANET, WDTAVATRAT, WDTAVATAMT, WDTAATI
Local Decimal WXFVATAMTP, WXFMNT
# Tableau interne de calcul des taxes
Local Decimal TDTAMNT (0..dim([M:SIHV]XVTAX)-1)            : # Montant
Local Decimal TDTAMAN (0..dim([M:SIHV]XVTAX)-1)            : # Zone de manoeuvre
Local Char    TDTAVAT (GLONVAT) (0..dim([M:SIHV]XVTAX)-1)  : # Code taxe
Local Decimal TDTAVATRT (0..dim([M:SIHV]XVTAX)-1)          : # Taux taxe

# Pour la modification de la base de calcul d'un élément
Local Char    WACTCLCBAS  : # Action à executer pour alimenter la base de calcul d'un élément
Local Char    WPRGCLCBAS  : # Programme contenant l'action à executer
Local Decimal WMNTCLCBAS  : # Montant contenant la base de calcul d'un élément
Local Char    WSVGACT(GLONACT)

# V6.2 : 60763 Settlements Discounts
Local Integer WDTADISVAT  : # N° de l'élément qui va contenir la remise sur taxe
Local Integer WDTADISIND  : # N° de l'indice de cet élément dans le tableau des élts

Gosub OUVRE_SIHX From TRTVENFACC

# --------------------------------- #
# Chargement des ecrans nécessaires #
# --------------------------------- #
[M:SIH0] = [F:SIH] : [M:SIH0] = [F:SIV]
[M:SIH0]CHGTYP = [F:SIH]CURTYP
[M:SIH1] = [F:SIH] : [M:SIH1] = [F:SIV]
[M:SIH1]VACBPR = [F:SIH]VAC
Gosub NEW_REGIME From TRTVENFACC
[M:SIH2] = [F:SIH] : [M:SIH2] = [F:SIV]

If [F:SIV]BPINAM(0) <> ""
    [M:SIH1]BPCNAM = [F:SIV]BPINAM(0)
Else
    If [F:BPC]BPCNUM <> [F:SIV]BPCINV
       Read [BPC]BPC0 = [F:SIV]BPCINV
    Endif
    [M:SIH0]BPINAM = [F:BPC]BPCNAM
Endif
[M:SIH1]BPCNAM = [M:SIH0]BPINAM
# --- adresse livraison
[M:ADB2]ADBBPR       = [F:SIV]BPCORD
[M:ADB2]BPRNAM(0)    = [F:SIV]BPDNAM(0)
[M:ADB2]BPRNAM(1)    = [F:SIV]BPDNAM(1)
[M:ADB2]BPAADDLIG(0) = [F:SIV]BPDADDLIG(0)
[M:ADB2]BPAADDLIG(1) = [F:SIV]BPDADDLIG(1)
[M:ADB2]BPAADDLIG(2) = [F:SIV]BPDADDLIG(2)
[M:ADB2]POSCOD       = [F:SIV]BPDPOSCOD
[M:ADB2]CTY          = [F:SIV]BPDCTY
[M:ADB2]SAT          = [F:SIV]BPDSAT
[M:ADB2]CRY          = [F:SIV]BPDCRY
[M:ADB2]CRYNAM       = [F:SIV]BPDCRYNAM

If [M:ADB2]BPRNAM <> "" |  [M:ADB2]BPAADDLIG <> "" |
&  [M:ADB2]POSCOD <> "" |  [M:ADB2]CTY <> "" |
&  [M:ADB2]SAT    <> "" |
&  [M:ADB2]CRY    <> "" |  [M:ADB2]CRYNAM <> ""
    [M:ADB2]ADBFLG = 3
Else
    [M:ADB2]ADBFLG = 0
Endif


Gosub CHARGE_SIHV

If clalev([F:SFI]) <> 0 Close Local File [SFI] : Endif
#     les totaux
#  garnissage des zones de cumul et zones euro
[M:SIHV]INVNOT = sum([M:SIHV]XVNOT)+sum([M:SIHV]XFNOT)
[M:SIHV]INVATI = sum([M:SIHV]XVATI)+sum([M:SIHV]XFATI)
# CH mail 29/09 : Pour Béryl exprimer ces montants en devise société
[M:SIHV]DEVRPT1 = GLOCALDEV : [M:SIHV]DEVRPT2 = GLOCALDEV
If [M:SIH0]CUR<>GLOCALDEV
    Call CONVERT([M:SIH0]CUR,GLOCALDEV,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,
&                [M:SIHV]INVNOT,[M:SIHV]INVNOTRPT,STAT) From TRTDEV
    Call CONVERT([M:SIH0]CUR,GLOCALDEV,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,
&                [M:SIHV]INVATI,[M:SIHV]INVATIRPT,STAT) From TRTDEV
Endif

[M:SIH4]INVNOT = [M:SIHV]INVNOT
[M:SIH4]INVATI = [M:SIHV]INVATI
Raz [M:SIH4]PFMTOT

# Recalcul de la facture
If [M:SIH4]NBLIG=0 Return Endif

Gosub CHARG_TABLEAUX From TRTVENFACC

Local Decimal  WMT1, WMT2, COEFDEVISE
Local Decimal  ZFSMIP    : # pour calcul le montant soumis du pied
Local Decimal  ZFNOTP    : # pour chgt ht pied par point d'entrée
Local Shortint WSENS                       : # positif=1 / négatif=-1
Local Shortint JL, JLT, JTVA, JTPA, JTSP, NBTVA, NBTPA, NBTSP
Local Integer  STAT

Local Char     TVACOD (3) (0..dim([M:SIHX]XVTAX)-1) : # tableau interne des TVA
Local Decimal  TVANOT     (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TVASMI     (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TVASMIP    (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TVASMIF    (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TVASMITP   (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TVASMITS   (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TVATAUX    (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TVAAMT     (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TVASUP     (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TVAATI     (0..dim([M:SIHX]XVTAX)-1)
Local Shortint TVARANG    (0..dim([M:SIHX]XVTAX)-1)

Local Char     TPACOD (3) (0..dim([M:SIHX]XVTAX)-1) : # tableau interne Taxes parafiscales
Local Decimal  TPANOT     (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TPASMIP    (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TPATAUX    (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TPAAMT     (0..dim([M:SIHX]XVTAX)-1)
Local Shortint TPARANG    (0..dim([M:SIHX]XVTAX)-1)

Local Char     TSPCOD (3) (0..dim([M:SIHX]XVTAX)-1) : # tableau interne Taxes spéciales
Local Decimal  TSPNOT     (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TSPSMIP    (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TSPTAUX    (0..dim([M:SIHX]XVTAX)-1)
Local Decimal  TSPAMT     (0..dim([M:SIHX]XVTAX)-1)
Local Shortint TSPRANG    (0..dim([M:SIHX]XVTAX)-1)
COEFDEVISE=1

# Appel du sous-pro de calcul avec stockage
Gosub CAL_FACTURE_USA

[M:SIHV]INVNOT = sum([M:SIHV]XVNOT)+sum([M:SIHV]XFNOT)
[M:SIHV]INVATI = sum([M:SIHV]XVATI)+sum([M:SIHV]XFATI)

Return

#**
#* Charg SIHV mask with header and footer data from SVCRVAT and SVCRFOOT
#*!
$CHARGE_SIHV

Local Decimal WDTAVATAMT
Local Integer WRET       :#--CPO 71937
# SVCRVAT load
#     le tableau des taxes
For [SVV]SVV1 Where VCRTYP=4 & VCRNUM=[M:SIH0]NUM #VCRTYP=20 & VCRNUM=[M:SOH0]SOHNUM
  If [F:SVV]VAT<>"" & [F:SVV]VATNET<>0
    #--CPO 71937 TVT and LEG as part of the key
    Call LEC_TVT_LEG(GCURLEG,[F:SVV]VAT,WRET) From TRTLECLEG
    If WRET : Raz [F:TVT] : Endif
    #Read [F:TVT]TVT0=[F:SVV]VAT
    #If fstat : Raz [F:TVT] : Endif
    #--/CPO
    [M:SIHV]XVTAX([M:SIHV]NBVAT) = [F:SVV]VAT
    [M:SIHV]XVTYP([M:SIHV]NBVAT) = [F:TVT]VATTYP : [M:SIHV]XVBAS([M:SIHV]NBVAT) = [F:TVT]VATBAS
    Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:SIHV]XVSHO([M:SIHV]NBVAT)) From TRTX3TEX
    [M:SIHV]XVNOT([M:SIHV]NBVAT) = [F:SVV]VATGRO
    [M:SIHV]XVSMI([M:SIHV]NBVAT) = [F:SVV]VATNET
    [M:SIHV]XVRAT([M:SIHV]NBVAT) = [F:SVV]VATRAT
    [M:SIHV]XVAMT([M:SIHV]NBVAT) = [F:SVV]VATAMT
    [M:SIHV]XVSUP([M:SIHV]NBVAT) = [F:SVV]VATSUPAMT
    If [F:TVT]VATTYP=1                        : # colonne TTC uniquement si taxe principale
      [M:SIHV]XVATI([M:SIHV]NBVAT) = [F:SVV]VATGRO+[F:SVV]VATAMT+[F:SVV]VATSUPAMT
    Endif

    # RCB - What  is this doing - if Tax Type = local tax then set product line tax to the vatamt
       If [F:SVV]VATTYP>3                  : # colonne TTC car les taxes annexes (calces facture)
          [M:SIHV]XVATI([M:SIHV]NBVAT) = [F:SVV]VATAMT : # ne sont pas répercutées sur les lignes taxes principales
       Endif                               : # liées aux produits


    [M:SIHV]NBVAT += 1
  Endif
Next

# SVCRFOOT Load
#     le tableau des elements  - RCB - VCRTYP=4 means VCRTYP = invoice
For [SVF]SVF2 Where VCRTYP=4 & VCRNUM=[M:SIH0]NUM #VCRTYP=20 & VCRNUM=[M:SOH0]SOHNUM
  If [F:SVF]DTA<>0
     RF = find([F:SVF]DTA,[M:SIHX]XFNUM(0..dim([M:SIHX]XFNUM)-1))
     If RF
       [M:SIHV]XFSHO([M:SIHV]NBFOOT) = [M:SIHX]XFSHO(RF-1)
     Else
       Gosub OPEN_SFI From TRTX3CPY
       Read [SFI]SFI0=[F:SVF]DTA
       If !fstat
         Read [AXX]AXX0="SFOOTINV";"SHOAXX";GLANGUE;num$([F:SFI]SFINUM);""
         If !fstat : [M:SIHV]XFSHO([M:SIHV]NBFOOT) = [F:AXX]TEXTE : Endif
       Endif
     Endif
     [M:SIHV]XFNUM([M:SIHV]NBFOOT)    = [F:SVF]DTA
     [M:SIHV]XFNOT([M:SIHV]NBFOOT)    = [F:SVF]DTANOT
     [M:SIHV]XFSMI([M:SIHV]NBFOOT)    = [F:SVF]DTANOT

     Raz [M:SIHV]XFSMI([M:SIHV]NBFOOT)
     Raz [M:SIHV]XFVATAMT([M:SIHV]NBFOOT)

     For I=0 To dim([F:SVF]DTANET)-1
         If [F:SVF]DTAVAT(I)="" Break Endif
         Assign "[M:SIHV]DTANOT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATNOT(I)
         Assign "[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTANET(I)
         Assign "[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVAT(I)
         Assign "[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATRAT(I)
         Assign "[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATAMT(I)
         [M:SIHV]XFSMI([M:SIHV]NBFOOT)+=[F:SVF]DTANET(I)
         [M:SIHV]XFVATAMT([M:SIHV]NBFOOT)+=[F:SVF]DTAVATAMT(I)
     Next
     If I=1    # RCB - why  not set it in the loop? Is this even correct?
         [M:SIHV]XFTAX([M:SIHV]NBFOOT)    = [F:SVF]DTAVAT(I-1)
         [M:SIHV]XFRAT([M:SIHV]NBFOOT)    = [F:SVF]DTAVATRAT(I-1)
     Endif

     [M:SIHV]XFDTAAMT([M:SIHV]NBFOOT) = [F:SVF]DTAAMT
     [M:SIHV]XFATI([M:SIHV]NBFOOT)    = [F:SVF]DTANOT+[M:SIHV]XFVATAMT([M:SIHV]NBFOOT)
     [M:SIHV]NBFOOT += 1
  Endif
Next

Affzo[M:SIHV]
Return

#**
#* Load PARTAXUSA data -
#*    PARTAXUSA contains a set of data used to calculate taxes regardless of the X3 source.
#*    Functional source can be GESOH, GESSQH, GESSIH, GESSDH, GESBIC, FUNAUTDLV, FUNAUTINVO, FUNAUTINVD
#*
#* @param WABMSK
#* @param ERR
#*!
Subprog CALCTAX(WABMSK, ERR, ERRMSG)
Value    Char    WABMSK
Variable Integer ERR
Variable Char    ERRMSG()

##101089 SST Syracuse integratio Add GFONCTION<>"BPCVAL" to If statement.  SAM Issue 101381/SST add GFONCTION<>"FUNCFMINV".
#added GFONCTION<> "FUNPREDLV"  108593 MJH 10/23/2015
If GREP="" & left$(GFONCTION,3)<>"GES" & left$(GFONCTION,9)<>"FUNAUTINV" & GFONCTION<>"FUNAUTDLV" & GFONCTION<>"BPCVAL" & GFONCTION<>"FUNCFMINV" & GFONCTION<> "FUNPREDLV": End : Endif

Local Decimal WAMTLIN
Local Integer WBPAFLG,NLIG, XNLIG,ERR
Local Char XWABMSK(10),VACBPR(GLONBPR),VCRNUM(GLONVCR)
#  Local Char ERRMSG(250),DEFMSK(250) SAM 108593.o MJH 10/23/2015
Local Char DEFMSK(250)
If dim(ERRMSG) < 0 : Local Char ERRMSG(250) : Endif #SAM 108593.n
DEFMSK = [S]dbgstr(1)

If !clalev([M:PTU])  Local Mask PARTAXUSA [PTU]  Endif
If !clalev([M:ADC])  Local Mask ADRBPC    [ADC]  Endif
If !clalev([M:ADB])  Local Mask ADRBPR    [ADB]  Endif
If !clalev([M:ADB2]) Local Mask ADRBPR    [ADB2] Endif
If !clalev([M:SIHV]) Local Mask SIHV      [SIHV] Endif
If !clalev([M:SIHX]) Local Mask SIHV      [SIHX] Endif
If !clalev([M:LTA1]) Local Mask LTA1      [LTA1] Endif
If !clalev([M:SFIT]) Local Mask SFITRF    [SFIT] Endif

If !clalev([F:FCY])  Local File FACILITY  [FCY]  Endif
If !clalev([F:BPA])  Local File BPADDRESS [BPA]  Endif
If !clalev([F:SFI])  Local File SFOOTINV  [SFI]  Endif
If !clalev([F:LTP])  Local File LTAPAR    [LTP]  Endif
If !clalev([F:SID])  Local File SINVOICED [SID]  Endif
If !clalev([F:SIV1]) Local File SINVOICEV [SIV1] Endif
If !clalev([F:SRD])  Local File SRETURND  [SRD]  Endif

If !clalev([F:BPR])  Local File BPARTNER  [BPARTNER]  Endif    #109282.n

Case left$(GFONCTION,9)
     When "GESSOH" : If !find(WABMSK,"SOH4","SIHV") : End : Endif
                     XWABMSK="SOH4"
                     SOURCE= "SOH"
                     [L]VACBPR = [M:SOH1]VACBPR
     When "GESSQH" : If !find(WABMSK,"SQH2","SIHV") : End : Endif
                     XWABMSK="SQH2"
                     SOURCE= "SQH"
                     [L]VACBPR = [M:SQH1]VACBPR
     When "GESSIH" : If !find(WABMSK,"SIH4","SIHV") : End : Endif
                     XWABMSK="SIH4"
                     SOURCE= "SIH"
                     [L]VACBPR = [M:SIH1]VACBPR
                     [L]VCRNUM = [M:SIH0]NUM
     When "GESSDH" : If !find(WABMSK,"SDH1","SIHV") : End : Endif
                     XWABMSK="SDH1"
                     SOURCE= "SDH"
                     [L]VACBPR = [M:SDH2]VACBPR
     When "GESBIC" : If !find(WABMSK,"BIC3","SIHV") : End : Endif
                     XWABMSK="BIC3"
                     SOURCE= "BIC"
                     [L]VACBPR = [M:BIC1]VAC
     When "FUNAUTDLV" : If !find(WABMSK,"SDH1","SIHV") : End: Endif
                        XWABMSK="SDH1"
                        SOURCE= "SDH"
                        [L]VACBPR = [M:SDH2]VACBPR
     When "FUNAUTINV" : If !find(WABMSK,"SIH4","SIHV") : End : Endif
                        XWABMSK="SIH4"
                        SOURCE= "SIH"
                        [L]VACBPR = [M:SIH1]VACBPR
                        [L]VCRNUM = [F:SIH]NUM
     #101089 SST Syracuse integration. Add this case.
     When "BPCVAL" : If !find(WABMSK,"BIC3","SIHV") : End : Endif
                     XWABMSK="BIC3"
                     SOURCE= "BIC"
                     [L]VACBPR = [M:BIC1]VAC
     #101089 SST Syracuse integration and SAM issue 101381. Add this case.
     When "FUNCFMINV" : If !find(WABMSK,"SIH4","SIHV") : End : Endif
                       XWABMSK="SIH4"
                       SOURCE= "SIH"
                       [L]VACBPR = [M:SIH1]VACBPR
                       [L]VCRNUM = [F:SIH]NUM
     # 104662 SST for Picking tickets. Add this case.
     When "FUNPREDLV" : If !find(WABMSK,"SDH1","SIHV") : End : Endif
                        XWABMSK="SDH1"
                        SOURCE= "SDH"
                        [L]VACBPR = [M:SDH2]VACBPR
     When Default : ERR=1
                    ERRMSG = mess(9,137,1)-"["+GFONCTION+"]"
                    End
Endcase

Local Char X3_CPY(GLONCPY)

If  GSOCIETE<>""
    [L]X3_CPY = GSOCIETE
Else
    [L]X3_CPY = GDEFSOC
Endif
If !clalev([F:LTP])  Local File LTAPAR  [LTP]  Endif
Read [F:LTP]LTP0=nomap
If  fstat
    GOK=0
    GMESSAGE=mess(141,105,1)- "[LTAPAR-"+nomap+"]"
    Goto CALCTAX_END
Endif

##SST Syracuse integration            101089.os
#Call SST_ADXDOPEN([L]X3_CPY, ERR, GMESSAGE) From SSTLIB
#If  ERR
#  GOK=0
#  Goto CALCTAX_END
#Endif                                #101089.oe

Raz [M:PTU]                                            # Clear Data to be sent to Tax routines
Gosub PTU_HEADER                                         # Load document Header Information
If  !ERR  : Gosub PTU_DETAILS : Endif                      # Load Item Detail Information
If  !ERR  : Gosub PTU_INVOICE_ELEMENTS : Endif             # Load Invoice Elements
If  ERR
  GOK=0
  GERR=1
  Goto CALCTAX_END
Endif

##SST Syracuse integration                        101089.os
## Two attempts to calculate tax. If a document status is returned on a calc tax then set document to uncommitted.
#If  [F:LTP]CLCALL = 2
#  Call SST_CALCTAX(ERR,ERRMSG) From SSTTAXLIB                   # Send all docs flag set to send all docs to Sage Sales Tax
#    If  ERR
#      If instr(1,toupper(vireblc(ERRMSG,4)),"DOCSTATUSISINVALID") & find(SOURCE,"SIH","BIC")
#        Call SST_UNCOMMITTAX([M:PTU]CPY,[M:PTU]VCRNUM,[F:SIH]INVTYP,ERR,ERRMSG)
#        If !ERR
#          Call SST_CALCTAX(ERR,ERRMSG) From SSTTAXLIB
#        Endif
#      Endif
#  Endif
#Elsif [M:PTU]SSTENTCOD = ""                                       # do not send all doc, just those with SST entity oode set
#    Call SST_CALCTAX(ERR,ERRMSG) From SSTTAXLIB                   # Send all docs flag set to send all docs to Sage Sales Tax
#    If  ERR
#      If instr(1,toupper(vireblc(ERRMSG,4)),"DOCSTATUSISINVALID") & find(SOURCE,"SIH","BIC")
#        Call SST_UNCOMMITTAX([M:PTU]CPY,[M:PTU]VCRNUM,[F:SIH]INVTYP,ERR,ERRMSG)
#        If !ERR
#          Call SST_CALCTAX(ERR,ERRMSG) From SSTTAXLIB
#        Endif
#      Endif
#  Endif
#Endif
#101089.oe
If  [F:LTP]CLCALL = 2 | [M:PTU]SSTENTCOD = ""    #101089.ns
  Call SST_CALCTAX(ERR,ERRMSG) From SSTTAXLIB
Endif                                            #101089.ne
If ERR                     # Block invoice creation or modification and allow orders/shipments  to proceed
    If  find(SOURCE,"SIH","BIC")
        GOK=0
        GERR=1
        GMESSAGE=ERRMSG
    Else
        GERR=2
        GMESSAGE=ERRMSG
    Endif
    Goto CALCTAX_END
Endif

# Issue 117247 - 2016-07-13 by ERMIL : Large invoices posting performance
If GSSTCOMMIT=1 : Goto CALCTAX_END : Endif

If  [F:LTP]CLCALL<>2 & [M:PTU]SSTENTCOD <> "" & find(SOURCE,"SIH","BIC")            # Have to cancel existing doc if SSTENTCOD is not blank
  Call CANCEL_TAX([M:PTU]CPY,[M:PTU]VCRNUM,[F:SIH]INVTYP)                           # send all docs is no
  GOK=1                                                                             # Clear errors on cancel
  GERR=0
Endif

#101089 SST Syracuse integration - add If statement around LOADTAXES.  With the new Avalara REST API, we must provide
#all invoice information (address, amounts, etc.) to perform a commit which is why that function runs through TRTTAXUSA now.
#Validate customer BP invoices does not load the masks used by LOADTAXES and is not looking for the return values provided by LOADTAXES.
If GFONCTION<>"BPCVAL"
  Gosub LOADTAXES                    # Copy Tax to X3 Masks
  If XWABMSK="SIH4" : Gosub CAL_BASDEP : Endif                  # TODAN-118710. Calculate discount basis
Endif

$CALCTAX_END
Default Mask DEFMSK

End

####################################################################################
$POST_TAX
Local Char VCRTYP(20),VCRNUM(GLONVCR)
Local Char ERRMSG(250)
Local Integer ERR,INVTYP

If !clalev([F:LTP])  Local File LTAPAR [LTP]  Endif
If [F:LTP]DOSSIER <> nomap    #ns 103960 Need to load record if just opening file
  Read [F:LTP]LTP0=nomap
Endif                         #ne 103960
# Skip post and commit if not sending all docs and SST entity code is not blank
If  [F:SIH]SSTENTCOD<>"" & [F:LTP]CLCALL<>2
  Return
Endif

If  [F:SIH]INVTYP=1 | [F:SIH]INVTYP=3
    [L]VCRTYP="SalesInvoice"
Elsif [F:SIH]INVTYP=2 | [F:SIH]INVTYP=4
      [L]VCRTYP="ReturnInvoice"
Else Return
Endif

Raz GMESSAGE
GOK=1

#SST Syracuse integration.                                                      101089.os
# 1st post the document on SST. If the erro returned is docstatus is invalid, then uncommit the document and try to post on sst again.
#Call SST_POSTTAX([F:SIH]CPY,[F:SIH]NUM,[L]VCRTYP,[F:SIH]ACCDAT,[F:SIH]AMTNOT,[F:SIH]AMTATI-[F:SIH]AMTNOT) From SSTTAXLIB
#If  !GOK
#  If instr(1,toupper(vireblc(GMESSAGE,4)),"DOCSTATUSISINVALID")
#    Call SST_UNCOMMITTAX([F:SIH]CPY,[F:SIH]NUM,[F:SIH]INVTYP,ERR,ERRMSG)
#    If !ERR
#      GOK=1
#      Raz GMESSAGE
#      Call SST_POSTTAX([F:SIH]CPY,[F:SIH]NUM,[L]VCRTYP,[F:SIH]ACCDAT,[F:SIH]AMTNOT,[F:SIH]AMTATI-[F:SIH]AMTNOT) From SSTTAXLIB
#      If !GOK : Return : Endif
#    Else
#      GMESSAGE=ERRMSG
#      Return
#    Endif
#  Endif
#Endif
## 2nd step is to commit the document on SST. If the error returned is docstatus is invalid, then uncommit the document and try to commit on sst again.
#Call SST_COMMITTAX([F:SIH]CPY,[F:SIH]NUM,VCRTYP) From SSTTAXLIB
#If  !GOK
#  If instr(1,toupper(vireblc(GMESSAGE,4)),"DOCSTATUSISINVALID")
#    Call SST_UNCOMMITTAX([F:SIH]CPY,[F:SIH]NUM,[F:SIH]INVTYP,ERR,ERRMSG)
#    If !ERR
#      GOK=1
#      Raz GMESSAGE
#      Call SST_COMMITTAX([F:SIH]CPY,[F:SIH]NUM,VCRTYP) From SSTTAXLIB
#      If !GOK : Return : Endif
#    Else
#      GMESSAGE=ERRMSG
#      Return
#    Endif
#  Endif
#Endif                                                                          #101089.oe
GSSTCOMMIT = 1                                                                 #101089.ns
GTAXBYDOC = 1
Gosub CAL_FACTURE_USA
GSSTCOMMIT = 0                                                                 #101089.ne

Return

#101089 SST Syracuse integration.  Add this Subprog for Validate customer BP invoices.
#Load minimal amount of mask information in order to perform a CALCTAX.
####################################################################################
Subprog POSTBPINV(ERR,ERRMSG)

  Variable Integer ERR
  Variable Char    ERRMSG()
  Variable Integer X

  If clalev([M:BIC0]) = 0 : Local Mask BIC0 [BIC0] : Endif
  If clalev([M:BIC1]) = 0 : Local Mask BIC1 [BIC1] : Endif
  If clalev([M:BIC3]) = 0 : Local Mask BIC3 [BIC3] : Endif
  If clalev([F:SIL]) = 0 : Local File BPCINVLIG [SIL] : Endif

  #Load header info into masks
  [M:BIC0] = [F:SIH]
  [M:BIC1] = [F:SIH]

  #Load neccesary line information into mask.  These are the only fields required to run a CALCTAX.
  X = 0
  For [F:SIL] Where NUM = [F:SIH]NUM
    [M:BIC3]AMTNOTLIN(X) = [F:SIL]AMTNOTLIN
    [M:BIC3]FCYLIN(X) = [F:SIL]FCYLIN
    [M:BIC3]CPYLIN(X) = [F:SIL]CPYLIN
    [M:BIC3]ACC1(X) = [F:SIL]ACC(0)
    [M:BIC3]SSTCOD(X) = [F:SIL]SSTCOD
    [M:BIC3]ACC1(X) = [F:SIL]ACC(0)
    [M:BIC3]AMTVAT(X) = [F:SIL]AMTVAT
    [M:BIC3]AMTATILIN(X) = [F:SIL]AMTATILIN
    [M:BIC3]AMTTAX1(X) = [F:SIL]AMTTAX1
    [M:BIC3]AMTTAX2(X) = [F:SIL]AMTTAX2
    X += 1
  Next
  [M:BIC3]NBLIG = X
  #Just initialize  These are just populated after calculating taxes.
  [M:BIC3]TOTNOT = 0
  [M:BIC3]TOTATI = 0

  Call CALCTAX("BIC3",ERR,ERRMSG)
  If ERR
    GERR=2
    GMESSAGE=ERRMSG
  Endif

End


####################################################################################
#Subprog SST_UNCOMMITTAX(X3_CPY,X3_VCRNUM,X3_INVTYP,ERR,ERRMSG)     #101089.o  Change Subprog name to reflect what the routine is actually doing.
Subprog SST_UNCOMMITBPINV(X3_CPY,X3_VCRNUM,X3_INVTYP,ERR,ERRMSG)   #101089.n

Value Char X3_CPY(),X3_VCRNUM()
Value Integer X3_INVTYP
Variable Integer ERR
Variable Char ERRMSG()

Local Char SST_INVTYP(20),ADJ_DES(50)
Local Integer  ADJ_COMMIT
Local Shortint ADJ_REASON

Local Char CANREA(30),VCRTYP(30)

ADJ_COMMIT=0
ADJ_REASON=2
ADJ_DES=mess(93,117,1)

If  find([L]X3_INVTYP,1,3)
    [L]SST_INVTYP="SalesInvoice"
Elsif find([L]X3_INVTYP,2,4)
      [L]SST_INVTYP="ReturnInvoice"
Else Return
Endif

#101089 SST Syracuse integration.  Changing the way that an invoice is uncommitted based on the new Avalara REST API.
#Call SST_ADJCMT([L]X3_CPY,[L]X3_VCRNUM,[L]SST_INVTYP,ADJ_COMMIT, ADJ_REASON, ADJ_DES,ERR,ERRMSG) From SSTTAXLIB      #101089.O
Raz ERR,ERRMSG                                                                                                       #101089.ns

#First void the document
CANREA = "DocVoided"
Call SST_CANTAX([L]X3_CPY,[L]X3_VCRNUM,[L]SST_INVTYP,[L]CANREA,ERR,ERRMSG) From SSTTAXLIB
If ERR
  GERR=2
  GMESSAGE=ERRMSG
  Goto UNCOMMIT_END
Endif

#Next delete the document
CANREA = "DocDeleted"
Call SST_CANTAX([L]X3_CPY,[L]X3_VCRNUM,[L]SST_INVTYP,[L]CANREA,ERR,ERRMSG) From SSTTAXLIB
If ERR
  GERR=2
  GMESSAGE=ERRMSG
  Goto UNCOMMIT_END
Endif

#Last, re-add document as uncommited (commit = false)
Call CALCTAX("BIC3",ERR,ERRMSG)
If ERR
  GERR=2
  GMESSAGE=ERRMSG
  Goto UNCOMMIT_END
Endif

$UNCOMMIT_END                                                                                                        #101089.ne

End


#101089 SST Syracuse Integration.  Remove SST_POST and SST_COMMIT subprogs.  With new Avalara REST API,
