####################################################################################
# Subroutine : Cancel_TAX
#
# Description : Cancel Sales Tax
####################################################################################
Subprog CANCEL_TAX(X3_CPY,VCRNUM,INVTYP)

Value Char X3_CPY(),VCRNUM()
Value Shortint INVTYP
Local Char CANREA(30),VCRTYP(30),ERRMSG(250)
Local Integer ERR
Raz ERR,ERRMSG

If [L]INVTYP=1 | [L]INVTYP=3
  [L]VCRTYP="SalesInvoice"
Elsif [L]INVTYP=2 | [L]INVTYP=4
  [L]VCRTYP="ReturnInvoice"
Else
  End
Endif

CANREA = "DocDeleted"

# Cancel SST document. If the error returned is docstatus is invalid, then uncommit the document and try to cancel on sst again.
Call SST_CANTAX([L]X3_CPY,[L]VCRNUM,[L]VCRTYP,[L]CANREA,ERR,ERRMSG) From SSTTAXLIB

#101089 SST Syracuse integration.
#If  !GOK                                                                                   #101089.os
#  If instr(1,toupper(vireblc(GMESSAGE,4)),"DOCSTATUSISINVALID")
#    Call SST_UNCOMMITTAX([L]X3_CPY,[L]VCRNUM,[L]INVTYP,ERR,ERRMSG)
#    If !ERR
#      GOK=1
#      Raz GMESSAGE
#      Call SST_CANTAX([L]X3_CPY,[L]VCRNUM,[L]VCRTYP,[L]CANREA,ERR,ERRMSG) From SSTTAXLIB
#      If !GOK : Return : Endif
#    Endif
#  Endif
#Endif                                                                                      #101089.oe
If !GOK                                                                                    #101089.ns
  GERR = ERR
  GMESSAGE=ERRMSG
  End
Endif                                                                                      #101089.ne

#116637 - Ensure table LTV is open before we attempt a delete
If !clalev([LTV]) : Local File LTAVCR [LTV] : Endif

Delete [F:LTV] Where VCRTYP=4 & VCRNUM = [L]VCRNUM

End

####################################################
# Save LTA1 tax detail data - called from INICRE
$CREMOD_LTV
Local Char DEFMSK(250)
DEFMSK = [S]dbgstr(1)

If !clalev([M:SIHV]) Local Mask SIHV [SIHV] : Endif
If !clalev([F:LTV]) Local File LTAVCR [LTV] : Endif
  Local Integer VCRTYP
  Local Char VCRNUM(GLONVCR)
  Raz [L]VCRTYP, [L]VCRNUM
#  Case GFONCTION  # maf.o
  Case left$(GFONCTION,9)
    When "FUNAUTDLV"
      [L]VCRTYP = 2
      # 116639 - Depending on where it is coming from the mask may not exist
      If dim([M]SDHNUM)>0
        [L]VCRNUM = [M]SDHNUM
      Else
        [L]VCRNUM = [F:SDH]SDHNUM
      Endif
    When "FUNPREDLV" # 108593.sn MJH 10/28/2015
      [L]VCRTYP = 2
      # 116439 - Depending on where it is coming from the mask may not exist
      If dim([M]SDHNUM)>0
        [L]VCRNUM = [M]SDHNUM
      Else
        [L]VCRNUM = [F:SDH]SDHNUM
      Endif # 108593.en
    When "FUNAUTINV"
      [L]VCRTYP = 4
      [L]VCRNUM = [F:SIH]NUM
    When "GESBIC"
      [L]VCRTYP = 100     # Force GESBIC VCRTYP to a value outside range of menu 701
      [L]VCRNUM = [M:BIC0]NUM
  Endcase

  If [L]VCRTYP=0 & [M:SIHV]VCRTYP<>0 & [M:SIHV]NUM<>""
    [L]VCRTYP = [M:SIHV]VCRTYP
    [L]VCRNUM = [M:SIHV]NUM
  Elsif [L]VCRTYP=0
    [L]VCRTYP = 4              # VCRTYP coming through as 0 on invoices.
    [L]VCRNUM = [M:SIHV]NUM
  Endif
  # Delete all rows from LTV because invalid rows be left a jurisdiction changed in the edit
  Delete [F:LTV] Where VCRTYP=[L]VCRTYP & VCRNUM = [L]VCRNUM
  If GREP = "A" : Return : Endif
# Valuation
  For nolign = 0 To [M:LTA1]NBVAT-1
    [F:LTV]VCRTYP = [L]VCRTYP
    [F:LTV]VCRNUM = [L]VCRNUM
    [F:LTV]TAXNAM = [M:LTA1]TAXNAM(nolign)
    [F:LTV]AMTNOT = [M:LTA1]AMTNOT(nolign)
    [F:LTV]AMTTAX = [M:LTA1]AMTTAX(nolign)
    [F:LTV]BASTAX = [M:LTA1]BASTAX(nolign)
    [F:LTV]CUR    = [M:LTA1]CUR(nolign)
    [F:LTV]JURNAM = [M:LTA1]JURNAM(nolign)
    [F:LTV]JURTYP = [M:LTA1]JURTYP(nolign)
    [F:LTV]PAYS   = [M:LTA1]PAYS(nolign)
    [F:LTV]SAT    = [M:LTA1]SAT(nolign)
    [F:LTV]TAXDAT = [M:LTA1]TAXDAT(nolign)
    [F:LTV]TAXNAM = [M:LTA1]TAXNAM(nolign)
    [F:LTV]TAXRAT = [M:LTA1]TAXRAT(nolign)
    [F:LTV]LTVSEQ = nolign
    [F:LTV]DTA    = 0
    Write [F:LTV]
    If fstat <> 0:GOK=0:Call FSTA("LTV") From GLOCK : End : Endif
  Next

# Invoice elements
  For nolign = 0 To [M:LTA1]NBFOOT-1
    [F:LTV]VCRTYP = [L]VCRTYP
    [F:LTV]VCRNUM = [L]VCRNUM
    [F:LTV]TAXNAM = [M:LTA1]DTATAXNAM(nolign)
    [F:LTV]AMTNOT = [M:LTA1]DTAAMTNOT(nolign)
    [F:LTV]AMTTAX = [M:LTA1]DTAAMTTAX(nolign)
    [F:LTV]BASTAX = [M:LTA1]DTABASTAX(nolign)
    [F:LTV]CUR    = [M:LTA1]DTACUR(nolign)
    [F:LTV]JURNAM = [M:LTA1]DTAJURNAM(nolign)
    [F:LTV]JURTYP = [M:LTA1]DTAJURTYP(nolign)
    [F:LTV]PAYS   = [M:LTA1]DTAPAYS(nolign)
    [F:LTV]SAT    = [M:LTA1]DTASAT(nolign)
    [F:LTV]TAXDAT = [M:LTA1]DTATAXDAT(nolign)
    [F:LTV]TAXNAM = [M:LTA1]DTATAXNAM(nolign)
    [F:LTV]TAXRAT = [M:LTA1]DTATAXRAT(nolign)
    [F:LTV]DTA    = [M:LTA1]DTA(nolign)
    [F:LTV]LTVSEQ = [M:LTA1]NBVAT+nolign
    Write [F:LTV]
    If fstat <> 0:GOK=0:Call FSTA("LTV") From GLOCK : End : Endif
  Next

Default Mask DEFMSK
Return



####################################################
# Load Data from Document into PARTAXUSA mask
$PTU_HEADER
  Local Char TAX_DOCTYP(20)
  Local Char EUID(20) #115280.n

  Raz [M:PTU]

  If  GSOCIETE<>""
      [M:PTU]CPY       = GSOCIETE
  Else
      [M:PTU]CPY       = GDEFSOC
  Endif

  Raz EUID #115280.n

  Case SOURCE
       When "SQH"
                   : If dim([M:SQH0]BPIEECNUM)>0 : EUID=[M:SQH0]BPIEECNUM : Endif  #115280.n
                   : Call PTU_HEADER_FLDS([M:SQH0]SQHNUM, [M:SQH0]QUODAT, [M:SQH0]BPCORD,  "SalesOrder", [M:SQH1]SSTENTCOD, [M:SQH0]CUR, EUID, [M:SQH2]NBLIG) #115280.n
#                  : Call PTU_HEADER_FLDS([M:SQH0]SQHNUM, [M:SQH0]QUODAT, [M:SQH0]BPCORD,  "SalesOrder", [M:SQH1]SSTENTCOD, [M:SQH0]CUR, [M:SQH0]BPIEECNUM, [M:SQH2]NBLIG) #115280.o
#                  : Call PTU_HEADER_FLDS([M:SQH0]SQHNUM, [M:SQH0]QUODAT, [M:SQH0]BPCORD,  "SalesOrder", [M:SQH1]SSTENTCOD, [M:SQH0]CUR,[M:SQH2]NBLIG) #109282.o
                   : Call SHIP_FROM("[M:SQH1]STOFCY",1)
                   : Call SHIP_TO("[M:SQH1]BPAADD",1)
                   : Call SHIP_FROM("[M:SQH2]DSTOFCY",[M:SQH2]NBLIG)
                   : Call SHIP_TO("[M:SQH2]DBPAADD",[M:SQH2]NBLIG)
       When "SOH"
                   : If dim([M:SOH0]BPIEECNUM)>0 : EUID=[M:SOH0]BPIEECNUM : Endif #115280.n
                   : Call PTU_HEADER_FLDS([M:SOH0]SOHNUM, [M:SOH0]ORDDAT, [M:SOH0]BPCORD,  "SalesOrder", [M:SOH1]SSTENTCOD, [M:SOH0]CUR, EUID, [M:SOH4]NBLIG) #115280.n
#                  : Call PTU_HEADER_FLDS([M:SOH0]SOHNUM, [M:SOH0]ORDDAT, [M:SOH0]BPCORD,  "SalesOrder", [M:SOH1]SSTENTCOD, [M:SOH0]CUR, [M:SOH0]BPIEECNUM, [M:SOH4]NBLIG) #115280.o
#                  : Call PTU_HEADER_FLDS([M:SOH0]SOHNUM, [M:SOH0]ORDDAT, [M:SOH0]BPCORD,  "SalesOrder", [M:SOH1]SSTENTCOD, [M:SOH0]CUR, [M:SOH4]NBLIG) #109282.o
                   : Call SHIP_FROM("[M:SOH2]STOFCY",1)
                   : Call SHIP_TO("[M:SOH1]BPAADD",1)
                   : Call SHIP_FROM("[M:SOH4]DSTOFCY",[M:SOH4]NBLIG)
                   : Call SHIP_TO("[M:SOH4]DBPAADD",[M:SOH4]NBLIG)
       When "SDH"
                   : If dim([M:SDH0]BPIEECNUM)>0 : EUID=[M:SDH0]BPIEECNUM : Endif #115280.n
                   : Call PTU_HEADER_FLDS([M:SDH0]SDHNUM, [M:SDH1]DLVDAT, [M:SDH0]BPCORD,  "SalesOrder", [M:SDH2]SSTENTCOD, [M:SDH1]CUR, EUID, [M:SDH1]NBLIG) #115280.n
#                  : Call PTU_HEADER_FLDS([M:SDH0]SDHNUM, [M:SDH1]DLVDAT, [M:SDH0]BPCORD,  "SalesOrder", [M:SDH2]SSTENTCOD, [M:SDH1]CUR, [M:SDH0]BPIEECNUM, [M:SDH1]NBLIG) #115280.o
#                  : Call PTU_HEADER_FLDS([M:SDH0]SDHNUM, [M:SDH1]DLVDAT, [M:SDH0]BPCORD,  "SalesOrder", [M:SDH2]SSTENTCOD, [M:SDH1]CUR, [M:SDH1]NBLIG) #109282.o
                   : Call SHIP_FROM("[M:SDH0]STOFCY",1)
                   : Call SHIP_TO("[M:SDH0]BPAADD",1)

       When "SIH"
                   : TAX_DOCTYP = "SalesInvoice"
                   : If dim([M:SIH0]INVTYP)>0 & ([M:SIH0]INVTYP = 2 | [M:SIH0]INVTYP = 4) : TAX_DOCTYP = "ReturnInvoice" : Endif
                   : If dim([M:SIH0]BPIEECNUM)>0 : EUID=[M:SIH0]BPIEECNUM : Endif #115280.n
                   : # X3-49027.sn
                   : If dim([M:SIH1]BPCORD)>0 and [M:SIH1]BPCORD <> ""
                   :   Call PTU_HEADER_FLDS([L]VCRNUM,[M:SIH0]INVDAT, [M:SIH1]BPCORD, TAX_DOCTYP, [M:SIH1]SSTENTCOD, [M:SIH0]CUR, EUID, [M:SIH4]NBLIG)
                   : Else
                   :   Call PTU_HEADER_FLDS([L]VCRNUM,[M:SIH0]INVDAT, [M:SIH0]BPCINV, TAX_DOCTYP, [M:SIH1]SSTENTCOD, [M:SIH0]CUR, EUID, [M:SIH4]NBLIG) # X3-49027.n
                   : Endif
                   : # X3-49027.en
#                  : Call PTU_HEADER_FLDS([L]VCRNUM,[M:SIH0]INVDAT, [M:SIH0]BPCINV, TAX_DOCTYP, [M:SIH1]SSTENTCOD, [M:SIH0]CUR, EUID, [M:SIH4]NBLIG) #115280.n  #X3-49027.o
#                  : Call PTU_HEADER_FLDS([L]VCRNUM,[M:SIH0]INVDAT, [M:SIH0]BPCINV, TAX_DOCTYP, [M:SIH1]SSTENTCOD, [M:SIH0]CUR, [M:SIH0]BPIEECNUM, [M:SIH4]NBLIG) #115280.o
#                  : Call PTU_HEADER_FLDS([L]VCRNUM,[M:SIH0]INVDAT, [M:SIH0]BPCINV, TAX_DOCTYP, [M:SIH1]SSTENTCOD, [M:SIH0]CUR,[M:SIH4]NBLIG) #109282.o
                   : If dim([M:SIH1]STOFCY)>0 : [M:PTU]STOFCY = [M:SIH1]STOFCY : Else [M:PTU]STOFCY = [M:SIH0]SALFCY : Endif   #118393.n
                   : Call SHIP_FROM("[M:SIH0]SALFCY",1)
                   : Call SHIP_FROM("[M:SIH4]DSTOFCY",[M:SIH4]NBLIG)
                   : Call SHIP_TO("[M:SIH1]BPAADD",1)

       When "BIC"
                   : TAX_DOCTYP = "SalesInvoice"
                   : If find(GREP,"C","D") & [M:BIC0]NUM="" : [M:BIC0]NUM=[F:SIH]NUM : Endif
                   : If dim([M:BIC0]INVTYP)>0 & ([M:BIC0]INVTYP = 2 |[M:BIC0]INVTYP = 4) : TAX_DOCTYP = "ReturnInvoice" : Endif
                   : Read [F:BPR]BPR0=[M:BIC0]BPR  #109282.n
                   : If dim([F:BPR]EECNUM)>0 : EUID=[F:BPR]EECNUM : Endif #115280.n
                   : Call PTU_HEADER_FLDS([M:BIC0]NUM,  [M:BIC1]BPRDAT, [M:BIC0]BPR, TAX_DOCTYP, [M:BIC1]SSTENTCOD, [M:BIC1]CUR, EUID, [M:BIC3]NBLIG) #115280.n
#                  : Call PTU_HEADER_FLDS([M:BIC0]NUM,  [M:BIC1]BPRDAT, [M:BIC0]BPR, TAX_DOCTYP, [M:BIC1]SSTENTCOD, [M:BIC1]CUR, [F:BPR]EECNUM, [M:BIC3]NBLIG) #115280.o
#                  : Call PTU_HEADER_FLDS([M:BIC0]NUM,  [M:BIC1]BPRDAT, [M:BIC0]BPR, TAX_DOCTYP, [M:BIC1]SSTENTCOD, [M:BIC1]CUR,[M:BIC3]NBLIG) #109282.o
                   : Call SHIP_FROM("[M:BIC3]FCYLIN",[M:BIC3]NBLIG)
                   : Call SHIP_TO("[M:BIC0]BPAINV",1)
       When Default: ERR=1
                   : ERRMSG = mess(583,197,1)-SOURCE
  Endcase
  If !ERR
   Call SST_CUR(1, [M:PTU]CPY, [M:PTU]CPYCUR, [M:PTU]CUR, [M:PTU]VCRDAT, [M:PTU]CHGRAT, [M:PTU]CHGSTRDAT)
  Endif

Return

########################################################################
#  Load PTU Header data
#Subprog PTU_HEADER_FLDS(VCRNUM, VCRDAT, BPR, VCRTYP, SSTENTCOD, CUR, NBLIG)    #109282.o
Subprog PTU_HEADER_FLDS(VCRNUM, VCRDAT, BPR, VCRTYP, SSTENTCOD, CUR, BPIEECNUM, NBLIG)  #109282.n
  Value Char VCRNUM(), BPR(), VCRTYP(), SSTENTCOD(), CUR(), BPIEECNUM() #115280.n
  Value Integer NBLIG
  Value Date VCRDAT
  [M:PTU]VCRNUM    = [L]VCRNUM
  [M:PTU]VCRDAT    = [L]VCRDAT
  [M:PTU]BPR       = [L]BPR
  [M:PTU]VCRTYP    = [L]VCRTYP                # SST Temporary document
  [M:PTU]SSTENTCOD = [L]SSTENTCOD
  [M:PTU]CUR       = [L]CUR
  If dim([M:PTU]BPIEECNUM)>0 : [M:PTU]BPIEECNUM = [L]BPIEECNUM : Endif #115280.n
  [M:PTU]NBLIG3    = [L]NBLIG


  Read [F:BPC] BPC0=[M:PTU]BPR
  If  !fstat
      [M:PTU]VATEXN    = [F:BPC]VATEXN
  Endif

End

# ----------------------------------------------------------- #
$PTU_DETAILS

For NLIG=0 To [M:PTU]NBLIG3-1
    Case SOURCE
         When "SQH"  : Gosub PTU_SQD
         When "SOH"  : Gosub PTU_SOD
         When "SDH"  : Gosub PTU_SDD
         When "SIH"  : Gosub PTU_SID
         When "BIC"  : Gosub PTU_BID
         When Default : ERR=1
                      : GMESSAGE=AFNC.MES2(mess(87,144,1),SOURCE,"SST")
                      : Break
    Endcase
Next

Return

#----- Quote Details   ---------------------#
$PTU_SQD
nolign = NLIG+1
# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales valuation process (cannot use transmask here; no common NBLIG block variable)
[M:PTU] = [M:SQH2]

[M:PTU]NUMLIN(NLIG)    = right$(num$(100000+[M:SQH2]SQDLIN(NLIG)),2)
[M:PTU]DTAXDAT(NLIG)   = [M:PTU]VCRDAT

[M:PTU]DSTOFCY(NLIG)   = [M:SQH2]DSTOFCY(NLIG)
[M:PTU]DBPAADD(NLIG)   = [M:SQH2]DBPAADD(NLIG)
[M:PTU]ITMREF(NLIG)    = [M:SQH2]ITMREF(NLIG)
[M:PTU]ITMDES(NLIG)    = [M:SQH2]ITMDES(NLIG)
[M:PTU]QTY(NLIG)       = [M:SQH2]QTY(NLIG)
[M:PTU]DTAXDAT(NLIG)   = [M:PTU]VCRDAT
[M:PTU]NUMLIN(NLIG)    = right$(num$(100000+[M:SQH2]SOPLIN(NLIG)),2)
[M:PTU]PRITYP(NLIG)    = [M:SQH1]PRITYP
[M:PTU]SSTCOD(NLIG)    = [M:SQH2]SSTCOD(NLIG)                   # 101380.n

#Read [ITM]ITM0=[M:PTU]ITMREF(NLIG)                             # 101380.o
# If !fstat : [M:PTU]SSTCOD(NLIG) =  [ITM]SSTCOD : Endif        # 101380.o

[M:PTU]AMTLIN(NLIG) = [M:SQH2]QTY(NLIG) * [M:SQH2]NETPRI(NLIG)
Call ARRDEV ([M:PTU]AMTLIN(NLIG), [M:PTU]CUR) From TRTDIV

Return

#----- Order Details ---------------------#
$PTU_SOD

[M:PTU]DSTOFCY(NLIG)   = [M:SOH4]DSTOFCY(NLIG)
[M:PTU]DBPAADD(NLIG)   = [M:SOH4]DBPAADD(NLIG)
[M:PTU]ITMREF(NLIG)    = [M:SOH4]ITMREF(NLIG)
[M:PTU]ITMDES(NLIG)    = [M:SOH4]ITMDES(NLIG)
[M:PTU]QTY(NLIG)       = [M:SOH4]QTY(NLIG)
[M:PTU]DTAXDAT(NLIG)   = [M:SOH4]DSHIDAT(NLIG)
[M:PTU]NUMLIN(NLIG)    = right$(num$(100000+[M:SOH4]SOPLIN(NLIG)),2)
[M:PTU]PRITYP(NLIG)    = [M:SOH1]PRITYP
[M:PTU]SSTCOD(NLIG)    = [M:SOH4]SSTCOD(NLIG)             #101380.n

#Read [ITM]ITM0=[M:PTU]ITMREF(NLIG)                       #101380.o
#  If !fstat : [M:PTU]SSTCOD(NLIG) =  [ITM]SSTCOD : Endif #101380.o

[M:PTU]AMTLIN(NLIG) = [M:SOH4]QTY(NLIG) * [M:SOH4]NETPRI(NLIG)
Call ARRDEV ([M:PTU]AMTLIN(NLIG), [M:PTU]CUR) From TRTDIV

Return

#----- Shipments  --------------------#
$PTU_SDD
nolign = NLIG+1
# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales valuation process (cannot use transmask here; no common NBLIG block variable)
[M:PTU]=[M:SDH1]

[M:PTU]DSTOFCY(NLIG)    = [M:SDH0]STOFCY
[M:PTU]DBPAADD(NLIG)    = [M:SDH0]BPAADD
[M:PTU]DTAXDAT(NLIG)    = [M:SDH1]SHIDAT
[M:PTU]NUMLIN(NLIG)     = right$(num$(100000+[M:SDH1]SDDLIN(NLIG)),2)
[M:PTU]SSTCOD(NLIG)     = [M:SDH1]SSTCOD(NLIG)            # 101380.n

#Read [ITM]ITM0=[M:PTU]ITMREF(NLIG)                       # 101380.o
# If !fstat : [M:PTU]SSTCOD(NLIG) =  [ITM]SSTCOD : Endif  # 101380.o

[M:PTU]AMTLIN(NLIG) = [M:SDH1]QTY(NLIG) * [M:SDH1]NETPRI(NLIG)
Call ARRDEV ([M:PTU]AMTLIN(NLIG), [M:PTU]CUR) From TRTDIV

Return

#----- Invoices ------------------------#
$PTU_SID
Local Date TAXDAT
nolign = NLIG+1

Call SID_SHIP_TO(NLIG)
# TODAN-X3-3508 118393.n: Check if the shipment site on the detail line exists.
# If not, check the shipment site on the Management tab.
# Else, assign to sales site.
If [M:SIH4]DSTOFCY(NLIG) <> AVOID.ACHAR
  [M:PTU]DSTOFCY(NLIG) = [M:SIH4]DSTOFCY(NLIG)
Elsif [M:SIH1]STOFCY <> AVOID.ACHAR
  [M:PTU]DSTOFCY(NLIG) = [M:SIH1]STOFCY
Else
  [M:PTU]DSTOFCY(NLIG) = [M:SIH0]SALFCY
Endif
#[M:PTU]DSTOFCY(NLIG) = [M:SIH4]DSTOFCY(NLIG)  #TODAN-X3-3508 118393.o
[M:PTU]ITMREF(NLIG) = [M:SIH4]ITMREF(NLIG)
[M:PTU]ITMDES(NLIG) = [M:SIH4]ITMDES(NLIG)
[M:PTU]QTY(NLIG)    = [M:SIH4]QTY(NLIG)
[M:PTU]PRITYP(NLIG) = [M:SIH1]PRITYP
[M:PTU]SSTCOD(NLIG) = [M:SIH4]SSTCOD(NLIG)              # 101380.n

[M:PTU]NUMLIN(NLIG)         = right$(num$(100000+[M:SIH4]SIDLIN(NLIG)),2)
[M:PTU]DTAXDAT(NLIG)        = [M:PTU]VCRDAT

#Read [ITM]ITM0=[M:PTU]ITMREF(NLIG)                     # 101380.o
#If !fstat : [M:PTU]SSTCOD(NLIG) =  [ITM]SSTCOD : Endif # 101380.o

[M:PTU]AMTLIN(NLIG) = [M:SIH4]QTY(NLIG) * [M:SIH4]NETPRINOT(NLIG)
Call ARRDEV ([M:PTU]AMTLIN(NLIG), [M:PTU]CUR) From TRTDIV

If  [M:PTU]CDTIND = "1"
    [M:PTU]AMTLIN(NLIG) = [M:PTU]AMTLIN(NLIG) * -1
Endif

# Credit Memo - Determine Tax Date
Raz ERR,TAXDAT

If [M:SIH0]INVTYP = 2
  If [M:SIH1]SIHORI = 4                # Base for credit memo is invoice
    Call GET_SIH_TAXDAT([M:SIH4]XSIHORINUM(NLIG),[M:SIH4]SIDORILIN(NLIG),TAXDAT)
    [M:PTU]ORINUM(NLIG) = [M:SIH4]XSIHORINUM(NLIG)
  Elsif [M:SIH1]SIHORI = 6              # Base for credit memo is a return
    Call GET_SRD_TAXDAT([M:SIH4]SRHNUM(NLIG),[M:SIH4]SRDLIN(NLIG),TAXDAT)
    [M:PTU]ORINUM(NLIG) = [M:SIH4]SRHNUM(NLIG)
  Endif

  #122792.sn - CATUA
  #Perform tax date override only if credit memo is linked to invoice/return
  If TAXDAT<>[00/00/00]
  #122792.en - CATUA
    [M:PTU]DTLOVRTYP(NLIG) = "TaxDate"
  #  [M:PTU]DTLOVRDAT(NLIG) = format$("D:DD[-]MM[-]YYYY",TAXDAT)  #121467.o - JOBRO
    [M:PTU]DTLOVRDAT(NLIG) = format$("D:YYYY[-]MM[-]DD",TAXDAT) #121467.n - JOBRO
    [M:PTU]DTLOVRREA(NLIG) = [M:PTU]DTLOVRTYP(NLIG)
  Endif
Endif

Return

#----- Miscellaneou Invoices ------------------------#
$PTU_BID

[M:PTU]ITMREF(NLIG)   = "ARINV"
[M:PTU]ITMDES(NLIG)   = [M:BIC3]ACC1(NLIG)
[M:PTU]DSTOFCY(NLIG)  = [M:BIC3]FCYLIN(NLIG)
[M:PTU]PRITYP(NLIG)   = [M:BIC1]SALPRITYP

If  [M:BIC3]FCYLIN(NLIG) <> ""
    [M:PTU]STOFCY(NLIG)  = [M:BIC3]FCYLIN(NLIG)
Else
    [M:PTU]STOFCY(NLIG)  = [M:BIC0]FCY
Endif

# BIC tax ship to based on header BP (not bpr on lines)
[M:PTU]BPR             = [M:BIC0]BPR
[M:PTU]DBPAADD(NLIG)   = [M:BIC0]BPAINV

[M:PTU]NUMLIN(NLIG)    = right$(num$(100000+NLIG),2)
[M:PTU]SSTCOD(NLIG)    = [M:BIC3]SSTCOD(NLIG)
[M:PTU]QTY(NLIG)       = 1
[M:PTU]AMTLIN(NLIG)    = [M:BIC3]AMTNOTLIN(NLIG)

Return

#######################################################
#Invoice ELements
$PTU_INVOICE_ELEMENTS
Local Char TAXDAT_ELE(10)
Local Integer I,LIG
Raz TAXDAT_ELE

# Find earliest Override Date
For I=0 To [M:PTU]NBLIG3-1
    If  ctrans([M:PTU]DTLOVRDAT(I),"- ","") <> ""
        If  ctrans([L]TAXDAT_ELE,"- ","")=""
            #[M:PTU]DTLOVRDAT is an aphanumeric field (cannot perform format)
            #[L]TAXDAT_ELE = format$("D:DD[-]MM[-]YYYY",[M:PTU]DTLOVRDAT(I))
            [L]TAXDAT_ELE = [M:PTU]DTLOVRDAT(I) #122849.n - CATUA
        Else
            [L]TAXDAT_ELE = min([M:PTU]DTLOVRDAT(I),[L]TAXDAT_ELE)
        Endif
    Endif
Next

For I=0 To [M:SIHV]NBFOOT-1
    If [M:PTU]CDTIND = "1"
        [M:PTU]AMTSFI(I) = [M:SIHV]XFNOT(I) * -1
    Else
        [M:PTU]AMTSFI(I) = [M:SIHV]XFNOT(I)
    Endif

    [M:PTU]SFINUM(I)     = num$([M:SIHV]XFNUM(I))
    Call  LECTEXTRA([M:PTU]SFIDES(XNLIG), "SFOOTINV", "DESAXX", num$([M:SIHV]XFNUM(I)), "" ) From ATEXTRA

    Read [F:SFI]SFI0=[M:SIHV]XFNUM(I)
    If  !fstat
        [M:PTU]SFISSTCOD(I)=func GET_SFISSTCOD([M:SIHV]XFNUM(I))  # 101380.n
        #[M:PTU]SFISSTCOD(I)=[F:SFI]SSTCOD                        # 101380.o
        If [F:SFI]VALTYP=1                      # Tax excluded or percent meant tax excluded.
          [M:PTU]SFIPRITYP(I)=1
        Elsif [F:SFI]VALTYP=2
          [M:PTU]SFIPRITYP(I)=2                 # Tax included
        Else
          [M:PTU]SFIPRITYP(I)=[F:SFI]CLCBAS
          If [M:PTU]CDTIND = "1"
              [M:PTU]AMTSFI(I) = [M:SIHV]XFATI(I) * -1
          Else
              [M:PTU]AMTSFI(I) = [M:SIHV]XFATI(I)
          Endif
        Endif
        If [F:SFI]CLCBAS<>1 & [M:PTU]AMTSFI(I)<>0
          GMESSAGE=func AFNC.MES3(mess(373,192,1), mess([F:SFI]CLCBAS,2219,1), num$([M:SIHV]XFNUM(I)),[M:PTU]SFIDES(XNLIG))
          GERR=1
          ERR=1
          Break
        Endif
        If [F:SFI]VATRUL<>4 & [M:PTU]AMTSFI(I)<>0  # 105815.ns
          GMESSAGE=func AFNC.MES3(mess(373,192,1), mess([F:SFI]VATRUL,283,1), num$([M:SIHV]XFNUM(I)),[M:PTU]SFIDES(XNLIG))
          GERR=1
          ERR=1
          Break
        Endif  # 105815.ne
    Else
        [M:PTU]SFISSTCOD(I)=""
        [M:PTU]SFIPRITYP(I)=1
    Endif

    [M:PTU]SFISTOFCY(I) = [M:PTU]DSTOFCY(0)
    [M:PTU]SFIBPAADD(I) = [M:PTU]DBPAADD(0)
Next

If !GOK
  Return
Endif

[M:PTU]NBLIG4 = [M:SIHV]NBFOOT

#Invoice elements are just additional lines to SST
# Send only non-zero footer elemements through Avatax
[L]LIG = [M:PTU]NBLIG3

For I=0 To [M:PTU]NBLIG4-1
  If  [M:PTU]AMTSFI(I) <> 0
    [M:PTU]NUMLIN(LIG) = num$(100000+I+1)
    [M:PTU]ITMREF(LIG) = [M:PTU]SFINUM(I)
    [M:PTU]ITMDES(LIG) = [M:PTU]SFIDES(I)
    [M:PTU]QTY(LIG)    = 1
    [M:PTU]AMTLIN(LIG) = [M:PTU]AMTSFI(I)
    [M:PTU]SSTCOD(LIG) = [M:PTU]SFISSTCOD(I) # 102309.n
    [M:PTU]PRITYP(LIG) = [M:PTU]SFIPRITYP(I)
    If  ctrans([L]TAXDAT_ELE,"- ","") <> ""
        [M:PTU]DTLOVRTYP(LIG) = "TaxDate"
        #TAXDAT_ELE is an aphanumeric field (cannot perform format)
        #[M:PTU]DTLOVRDAT(LIG) = format$("D:DD[-]MM[-]YYYY",TAXDAT_ELE)
        [M:PTU]DTLOVRDAT(LIG) = TAXDAT_ELE #122849.n - CATUA
        [M:PTU]DTLOVRREA(LIG) = [M:PTU]DTLOVRTYP(LIG)
    Endif
    [M:PTU]DSTOFCY(LIG) = [M:PTU]SFISTOFCY(I)
    [M:PTU]DBPAADD(LIG) = [M:PTU]SFIBPAADD(I)
    [M:PTU]DTA(LIG)     = [M:PTU]SFINUM(I)

    [L]LIG+=1
  Endif
Next
[M:PTU]SFILIG = [L]LIG-[M:PTU]NBLIG3
[M:PTU]NBLIG3 = [L]LIG
Return

# Issue 117773 - 2016-07-27 by ERMIL
# Call any validations that can be done pre-tax calculations
# Can be called when ADXLOG=1 during Create/Update
Subprog VALIDATE_INV_ELEM
  Local Integer I, INVELEMS, INVELEM
  Local Char SFIDES(30)
  Local Decimal ELEMAMT

  If !clalev([F:SFI]) : Local File SFOOTINV [SFI] : Endif

  Case GFONCTION
    When "GESSIH" : [L]INVELEMS = dim([F:SIV]INVDTA)-1
    When "GESSOH" : [L]INVELEMS = dim([M:SOH3]INVDTA)-1
    When Default  : [L]INVELEMS = [M:SIHV]NBFOOT-1
  Endcase

  For I=0 To [L]INVELEMS
    Case GFONCTION
      When "GESSIH" : [L]INVELEM = [F:SIV]INVDTA(I)  : [L]ELEMAMT = [F:SIV]INVDTAAMT(I)
      When "GESSOH" : [L]INVELEM = [M:SOH3]INVDTA(I) : [L]ELEMAMT = [M:SOH3]INVDTAAMT(I)
      When Default  : [L]INVELEM = [M:SIHV]XFNUM(I)  : [L]ELEMAMT = [M:SIHV]XFATI(I)
    Endcase

    If [L]ELEMAMT<>0
      Read [F:SFI]SFI0=[L]INVELEM
      If !fstat
        If [F:SFI]CLCBAS<>1
          GMESSAGE=func AFNC.MES1(mess(373,192,1), mess([F:SFI]CLCBAS,2219,1))
          GERR=1 : ERR=1 : Break
        Endif
        If [F:SFI]VATRUL<>4
          GMESSAGE=func AFNC.MES1(mess(373,192,1), mess([F:SFI]VATRUL,283,1))
          GERR=1 : ERR=1 : Break
        Endif
      Endif
    Endif
  Next I
End

#**
#* GET_SIH_TAXDAT - used to determine tax date from previous invoice
#*
#* @param SIHNUM - Invoice number
#* @param SIDLIN - Invoice line number
#* @param TAXDAT - Return tax date, defaults to date$
#*!
Subprog GET_SIH_TAXDAT(SIHNUM,SIDLIN,TAXDAT)
  Value Char SIHNUM()
  Value Integer SIDLIN
  Variable Date TAXDAT

  #TAXDAT=date$ #122699.o
  If [M:SIH2]VATDAT=[00/00/00] #122699.n - CATUA
    Read [F:SID]SID0 = [L]SIHNUM;[L]SIDLIN
    If !fstat
      TAXDAT=[F:SID]INVDAT
    Endif
  Else
    #Set tax date to VATDAT field when its linked to a sales invoice
    #VATDAT is based on the date of the FIRST linked invoice
    TAXDAT=[M:SIH2]VATDAT #122699.n - CATUA
  Endif
End

#**
#* GET_SRD_TAXDAT - used to determine tax date on returns
#*
#* @param SRHNUM - Return number
#* @param SRDLIN - Return line
#* @param TAXDAT - Return tax date, defaults to date$
#*!
Subprog GET_SRD_TAXDAT(SRHNUM,SRDLIN,TAXDAT)
  Value Char SRHNUM()
  Value Integer SRDLIN
  Variable Date TAXDAT

  #TAXDAT=date$ #122699.o
  If [M:SIH2]VATDAT=[00/00/00] #122699.n - CATUA
    Read [F:SRD]SRD0 = [L]SRHNUM;[L]SRDLIN                    # Determine shipment number from return data
    If !fstat
      Read [F:SID]SID3 = [F:SRD]SDHNUM;[F:SRD]SDDLIN      # Use shipment to determine invoice and invoice date
      If !fstat
        TAXDAT=[F:SID]INVDAT
      Endif
    Endif
  Else
    #Set tax date to VATDAT field when its linked to a sales return
    #VATDAT is based on the date of the FIRST linked return
    TAXDAT=[M:SIH2]VATDAT #122699.n - CATUA
  Endif
End

# ------------------------------------------------------ #
# Recalcul des prix de la ligne                          #
# ------------------------------------------------------ #
$LOADTAXES_LIGV
Local Integer  NOL,LIG, WTYPREG
Local Decimal WNETPRI,WNOTPRI,WATIPRI,WNOTLIN,WATILIN,WDLRQTY
If [V]GFONCTION = "FUNPREDLV" : Local Mask SIH4 [M:SIH4] : Endif #108593.n MJH 10/28/2015

WTYPREG = func TRTVENFACC.RECH_TYPREG ([L]VACBPR)     # Used in TRTVENFACC to determine tax exempt status (not equals 1 means tax exempt)
                                                      #  here Sage Sales Tax has determined tax amount

If [M:PTU]PRITYP(NLIG)<>2           # Tax excluded
  WATILIN=[M:PTU]AMTLIN(NLIG) + [M:PTU]TOTAMTTAX(NLIG)
  WNOTLIN=[M:PTU]AMTLIN(NLIG)
Else                                # Tax included
  WATILIN=[M:PTU]AMTLIN(NLIG)
  WNOTLIN=[M:PTU]AMTLIN(NLIG) - [M:PTU]TOTAMTTAX(NLIG)
Endif
[M:SIHX]LIGNE = NLIG+1


If [M:PTU]QTY(NLIG)<> 0
    WNOTPRI= WNOTLIN/ [M:PTU]QTY(NLIG)
    WATIPRI= WATILIN/ [M:PTU]QTY(NLIG)
Endif
                                          # Calculate SIHX when called TRTTAXUSA

If SOURCE = "SDH"
  If [M:PTU]PRITYP(NLIG)<>2            # Tax Excluded
    [M:SDH1]LINDLVATI(NLIG) = [M:SDH1]LINDLVNOT(NLIG) + [M:PTU]TOTAMTTAX(NLIG)
    [M:SIH4]AMTATILIN(NLIG) = [M:SIH4]AMTNOTLIN(NLIG) + [M:PTU]TOTAMTTAX(NLIG)
  Else                                 # Tax Included
    [M:SDH1]LINDLVNOT(NLIG) = [M:SDH1]LINDLVATI(NLIG) - [M:PTU]TOTAMTTAX(NLIG)
    [M:SIH4]AMTNOTLIN(NLIG) = [M:SIH4]AMTATILIN(NLIG) - [M:PTU]TOTAMTTAX(NLIG)
  Endif

  [M:SDH1]NETPRIATI(NLIG) = WATIPRI
  [M:SIH4]NETPRIATI(NLIG) = WATIPRI
  [M:SDH1]NETPRINOT(NLIG) = WNOTPRI
  [M:SIH4]NETPRINOT(NLIG) = WNOTPRI

  [M:SDH1]DLVINVATI      += [M:SDH1]LINDLVATI(NLIG)
  [M:SDH1]DLVINVNOT      += [M:SDH1]LINDLVNOT(NLIG)
  [M:SIH4]RATTAXLIN(NLIG) = [M:PTU]TOTLINRAT(NLIG)*100
  Gosub PLUS_LIGNE_USA From TRTTAXUSA
Endif

If SOURCE="SOH"
  If [F:SOH]SOHCAT = 3
    WDLRQTY = [M:SOH4]QTY - [M:SOH4]INVQTY - [M:SOH4]ODLQTY
  Else
    WDLRQTY = [M:SOH4]QTY - [M:SOH4]DLVQTY - [M:SOH4]ODLQTY
  Endif
  If [M:PTU]PRITYP(NLIG)<>2            # Tax Excluded
    [M:SOH4]LINORDATI(NLIG) = [M:SOH4]LINORDNOT(NLIG) + [M:PTU]TOTAMTTAX(NLIG)
    [M:SIH4]AMTATILIN(NLIG) = [M:SIH4]AMTNOTLIN(NLIG) + [M:PTU]TOTAMTTAX(NLIG)
  Else                                 # Tax Included
    [M:SOH4]LINORDNOT(NLIG) = [M:SOH4]LINORDATI(NLIG) - [M:PTU]TOTAMTTAX(NLIG)
    [M:SIH4]AMTNOTLIN(NLIG) = [M:SIH4]AMTATILIN(NLIG) - [M:PTU]TOTAMTTAX(NLIG)
  Endif

  [M:SOH4]LINDLRATI(NLIG) = WATIPRI*WDLRQTY
  [M:SOH4]LINDLRNOT(NLIG) = WNOTPRI*WDLRQTY
  [M:SOH4]NETPRIATI(NLIG) = WATIPRI
  [M:SIH4]NETPRIATI(NLIG) = WATIPRI
  [M:SOH4]NETPRINOT(NLIG) = WNOTPRI
  [M:SIH4]NETPRINOT(NLIG) = WNOTPRI

  [M:SOH4]ORDINVATI      += [M:SOH4]LINORDATI(NLIG)
  [M:SOH4]ORDATI         += [M:SOH4]LINORDATI(NLIG)
  [M:SOH4]DLRATI         += [M:SOH4]LINDLRATI(NLIG)
  [M:SOH4]ORDINVNOT      += [M:SOH4]LINORDNOT(NLIG)
  [M:SOH4]ORDNOT         += [M:SOH4]LINORDNOT(NLIG)
  [M:SOH4]DLRNOT         += [M:SOH4]LINDLRNOT(NLIG)
  [M:SIH4]RATTAXLIN(NLIG) = [M:PTU]TOTLINRAT(NLIG)*100
  Gosub PLUS_LIGNE_USA From TRTTAXUSA
Endif

Assign "[M:"+XWABMSK+"]NETPRIATI(NLIG)" With WATIPRI
Assign "[M:"+XWABMSK+"]NETPRINOT(NLIG)" With WNOTPRI


If SOURCE="SQH"
  If [M:PTU]PRITYP(NLIG)<>2            # Tax Excluded
    [M:SQH2]LINQUOATI(NLIG) = [M:SQH2]LINQUONOT(NLIG) + [M:PTU]TOTAMTTAX(NLIG)
    [M:SIH4]AMTATILIN(NLIG) = [M:SIH4]AMTNOTLIN(NLIG) + [M:PTU]TOTAMTTAX(NLIG)
  Else                                 # Tax Included
    [M:SQH2]LINQUONOT(NLIG) = [M:SQH2]LINQUOATI(NLIG) - [M:PTU]TOTAMTTAX(NLIG)
    [M:SIH4]AMTNOTLIN(NLIG) = [M:SIH4]AMTATILIN(NLIG) - [M:PTU]TOTAMTTAX(NLIG)
  Endif

  [M:SQH2]NETPRIATI(NLIG) = WATIPRI
  [M:SIH4]NETPRIATI(NLIG) = WATIPRI
  [M:SQH2]NETPRINOT(NLIG) = WNOTPRI
  [M:SIH4]NETPRINOT(NLIG) = WNOTPRI

  [M:SQH2]QUOINVATI      += [M:SQH2]LINQUOATI(NLIG)
  [M:SQH2]QUOATI         += [M:SQH2]LINQUOATI(NLIG)
  [M:SQH2]QUOINVNOT      += [M:SQH2]LINQUONOT(NLIG)
  [M:SQH2]QUONOT         += [M:SQH2]LINQUONOT(NLIG)
  [M:SIH4]RATTAXLIN(NLIG) = [M:PTU]TOTLINRAT(NLIG)*100
  Gosub PLUS_LIGNE_USA From TRTTAXUSA
Endif


If SOURCE="SIH"
  If GEXETAX <> [M:SIHV]XVTAX  # To separate Taxable from NT lines
    WTYPREG = 1
  Else
    WTYPREG = 0
  Endif

  If [M:PTU]PRITYP(NLIG)<>2            # Tax Excluded
    [M:SIH4]NETPRIATI(NLIG) = WATIPRI
    [M:SIH4]NETPRINOT(NLIG) = WNOTPRI
    [M:SIH4]AMTATILIN(NLIG) = [M:SIH4]AMTNOTLIN(NLIG) + [M:PTU]TOTAMTTAX(NLIG)
  Else                                 # Tax Included
    [M:SIH4]NETPRIATI(NLIG) = WATIPRI
    [M:SIH4]NETPRINOT(NLIG) = WNOTPRI
    [M:SIH4]AMTNOTLIN(NLIG) = [M:SIH4]AMTATILIN(NLIG) - [M:PTU]TOTAMTTAX(NLIG)
  Endif
  [M:SIH4]INVATI+=[M:SIH4]AMTATILIN(NLIG)
  [M:SIH4]INVNOT+=[M:SIH4]AMTNOTLIN(NLIG)
  [M:SIH4]RATTAXLIN(NLIG) = [M:PTU]TOTLINRAT(NLIG)*100

  Gosub PLUS_LIGNE_USA From TRTTAXUSA
Endif


Case XWABMSK
 When "SQH2"  :
        Default Mask "[SQH3],[SQH2],[SQH1],[SQH0]"
        If [M:PTU]PRITYP=2
            Call CLCPFM([M:SQH2]DSTOFCY(NLIG), [M:SQH1]PRITYP, [M:SQH0]CHGTYP, [M:SQH0]QUODAT, [M:SQH0]CUR,
&                   NLIG,0) From TRTVENPRI
        Endif
        Gosub CALC_QUO From SUBSQHB
        [M:SQH2]UPDFLG(NLIG) = 1
        #Affzo [M:SQH2]  # 117041.o - now called outside of loop - don't referesh every time through

 When "SOH4"  :
        Default Mask "[SOH4],[SOH3],[SOH2],[SOH1],[SOH0]"
        If [M:PTU]PRITYP=2
            Call CLCPFM([M:SOH4]DSTOFCY(NLIG), [M:SOH1]PRITYP, [M:SOH0]CHGTYP, [M:SOH0]ORDDAT, [M:SOH0]CUR,
&                   NLIG,0) From TRTVENPRI
        Endif
        Gosub CALC_ORD From SUBSOHB
        If [M:SOH4]DEMSTA(NLIG) <> 1
            Raz [M:SOH4]LINDLRNOT(NLIG)
            Raz [M:SOH4]LINDLRATI(NLIG)
        Else
            Gosub CALC_DLR  From SUBSOHB
        Endif
        [M:SOH4]UPDFLG(NLIG) = 1
        If GREV=2 [M:SOH4]LINREVNUM(NLIG) = [M:SOH0]REVNUM : Endif
        #Affzo [M:SOH4]  # 117041.o - now called outside of loop - don't referesh every time through

 When "SDH1"  :
        Default Mask "[SDH3],[SDH2],[SDH1],[SDH0]"
        If [M:PTU]PRITYP=2
            Call CLCPFM([M:SDH0]STOFCY, [M:SDH1]PRITYP, [M:SDH0]CHGTYP, [M:SDH1]SHIDAT, [M:SDH1]CUR,
&                   NLIG,0) From TRTVENPRI
        Endif
        NOL=NLIG
        Gosub CALC_DLV From SUBSDHB
        [M:SDH1]UPDFLG(NLIG) = 1
        #Affzo [M:SDH1]  # 117041.o - now called outside of loop - don't referesh every time through
 When "SIH4"  :
        Default Mask "[SIH4],[SIH2],[SIH1],[SIH0]"
        If [M:PTU]PRITYP=2
            Call CLCPFM([M:SIH4]DSTOFCY(NLIG), [M:SIH1]PRITYP, [M:SIH0]CHGTYP, [M:SIH0]INVDAT,
&                   [M:SIH0]CUR, NLIG,0) From TRTVENPRI
        Endif

        Call ADD_TOT(NLIG) From SUBSIHB
        [M:SIH4]UPDFLG(NLIG) = 1
        #Affzo [M:SIH4]  # 117041.o - now called outside of loop - don't referesh every time through
Endcase

Return

# ------------------------------------------------------ #
# Tax on invoice elements                                #
# ------------------------------------------------------ #
$LOADTAXES_LIGF
Local Integer I,SSTELE,LIG,STAT

SSTELE = [M:PTU]NBLIG3-[M:PTU]SFILIG
#For I=SSTELE To dim([M:SIHV]XFATI)-1   # 117282.o
For I=SSTELE To [M:PTU]NBLIG3-1         # 117282.n
  [L]LIG = find(val([M:PTU]ITMREF(I)),[M:SIHV]XFNUM)-1
  If [L]LIG<0 | [M:PTU]ITMREF(I)="0" :Break : Endif

  If  [M:PTU]PRITYP(I) <>2       # Tax Excluded
    [M:SIHV]XFATI(LIG)      = [M:PTU]AMTLIN(I)+[M:PTU]TOTAMTTAX(I)
    [M:SIHV]XFSMI(LIG)      = [M:PTU]AMTLIN(I)
    [M:SIHV]XFNOT(LIG)      = [M:PTU]AMTLIN(I)
  Else                           # Tax Included
    [M:SIHV]XFNOT(LIG)      = [M:PTU]AMTLIN(I)-[M:PTU]TOTAMTTAX(I)
    [M:SIHV]XFSMI(LIG)      = [M:PTU]AMTLIN(I)-[M:PTU]TOTAMTTAX(I)
    [M:SIHV]XFATI(LIG)      = [M:PTU]AMTLIN(I)
  Endif
  [M:SIHV]DTANET01(LIG)   = [M:SIHV]XFSMI(LIG)
  Call  LECTEXTRA([M:SIHV]XFSHO(LIG), "SFOOTINV", "SHOAXX", num$([M:PTU]ITMREF(I)), "" ) From ATEXTRA

  [M:SIHV]XFRAT(LIG)      = [M:PTU]TOTLINRAT(I)*100
  [M:SIHV]XFVATAMT(LIG)   = [M:PTU]TOTAMTTAX(I)

  [M:SIHV]DTAVATMT01(LIG) = [M:SIHV]XFVATAMT(LIG)
  [M:SIHV]DTAVATRT01(LIG) = [M:SIHV]XFRAT(LIG)
  [M:SIHV]DTAVAT01(LIG)   = [M:SIHV]XFTAX(LIG)
Next

[M:SIHV]INVNOT = sum([M:SIHV]XVNOT)+sum([M:SIHV]XFNOT)
[M:SIHV]INVATI = sum([M:SIHV]XVATI)+sum([M:SIHV]XFATI)

Local Integer  WNBXVTAX : WNBXVTAX=dim([M:SIHV]XVTAX)-1   : # Optimisation
Local Integer  WNBXFNUM : WNBXFNUM=dim([M:SIHV]XFNUM)-1   : # Optimisation
Local Decimal TDTAMNT (0..WNBXVTAX)            : # Montant
Local Decimal TDTAMAN (0..WNBXVTAX)            : # Zone de manoeuvre
Local Char    TDTAVAT (GLONVAT) (0..WNBXVTAX)  : # Code taxe
Local Decimal TDTAVATRT (0..WNBXVTAX)          : # Taux taxe

Gosub CALC_DTAVATNOT From TRTVENFACC

#  suppression des lignes à 0 des tableaux taxes et tri par taxes
[M:SIHV]NBVAT=dim([M:SIHV]XVTAX)   : # on charge NBVAT
RV=find("",[M:SIHV]XVTAX(0..dim([M:SIHV]XVTAX)-1))
If RV : [M:SIHV]NBVAT=RV-1 : Endif
If [M:SIHV]NBVAT>0
  Sorta [M:SIHV]NBVAT [M:SIHV]NBVAT Order By [M:SIHV]XVTYP(indice),[M:SIHV]XVTAX(indice),[M:SIHV]XVRAT(indice)
  For JL=[M:SIHV]NBVAT To 1 Step -1
    [M:SIHV]XVRAT(JL-1) = ar2([M:SIHV]XVRAT(JL-1))
    If [M:SIHV]XVNOT(JL-1)=0 & [M:SIHV]XVSMI(JL-1)=0
      Dela JL-1,1 [M:SIHV]NBVAT : [M:SIHV]NBVAT -= 1
    Endif
  Next JL
Endif

[M:SIHV]NBFOOT=dim([M:SIHV]XFNUM)  : # on charge NBFOOT
RV=find(0,[M:SIHV]XFNUM(0..dim([M:SIHV]XFNUM)-1))
If RV : [M:SIHV]NBFOOT=RV-1 : Endif
If [M:SIHV]NBFOOT>0
  Sorta [M:SIHV]NBFOOT [M:SIHV]NBFOOT Order By [M:SIHV]XFCPT(indice)
  For JL=[M:SIHV]NBFOOT To 1 Step -1
    [M:SIHV]XFRAT(JL-1) = ar2([M:SIHV]XFRAT(JL-1))
    If [M:SIHV]XFNOT(JL-1)=0
      Dela JL-1,1 [M:SIHV]NBFOOT : [M:SIHV]NBFOOT -= 1
    Endif
  Next JL
Endif
[M:SIHV]DEVRPT1 = GLOCALDEV : [M:SIHV]DEVRPT2 = GLOCALDEV
If (dim([M:SIH2]CUR)>0 & [M:SIH2]CUR<>GLOCALDEV)
    Local Decimal WCOURS : WCOURS=0 : If [M:SIH2]RAT1<>0 WCOURS=arr([M:SIH2]RAT2/[M:SIH2]RAT1, 10^-GDECRCU) : Endif
    Call COURMNT([M:SIH2]CUR,GLOCALDEV,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,1,
&                [M:SIHV]INVNOT,[M:SIHV]INVNOTRPT,WCOURS,STAT) From TRTDEV
    Call COURMNT([M:SIH2]CUR,GLOCALDEV,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,1,
&                [M:SIHV]INVATI,[M:SIHV]INVATIRPT,WCOURS,STAT) From TRTDEV
Elsif (dim([M:BIC1]CUR)>0 & [M:BIC1]CUR<>GLOCALDEV)
    Local Decimal WCOURS : WCOURS=0 : If [M:BIC1]RAT1<>0 WCOURS=arr([M:BIC1]RAT2/[M:BIC1]RAT1, 10^-GDECRCU) : Endif
    Call COURMNT([M:BIC1]CUR,GLOCALDEV,GLOCALDEV,[M:BIC1]CURTYP,[M:BIC1]BPRDAT,1,
&                [M:SIHV]INVNOT,[M:SIHV]INVNOTRPT,WCOURS,STAT) From TRTDEV
    Call COURMNT([M:BIC1]CUR,GLOCALDEV,GLOCALDEV,[M:BIC1]CURTYP,[M:BIC1]BPRDAT,1,
&                [M:SIHV]INVATI,[M:SIHV]INVATIRPT,WCOURS,STAT) From TRTDEV
Else
    [M:SIHV]INVNOTRPT=[M:SIHV]INVNOT
    [M:SIHV]INVATIRPT=[M:SIHV]INVATI
Endif

# Calculate total fields
If SOURCE="SDH"
  [M:SDH1]DLVNOT            = sum([M:SDH1]LINDLVNOT(0..([M:SDH1]NBLIG-1)))
  [M:SDH1]DLVATI            = sum([M:SDH1]LINDLVATI(0..([M:SDH1]NBLIG-1)))
  [M:SDH1]DLVINVNOT         = sum([M:SDH1]LINDLVNOT(0..([M:SDH1]NBLIG-1))) + sum([M:SIHV]XFNOT(0..([M:SIHV]NBFOOT-1)))
  [M:SDH1]DLVINVATI         = sum([M:SDH1]LINDLVATI(0..([M:SDH1]NBLIG-1))) + sum([M:SIHV]XFATI(0..([M:SIHV]NBFOOT-1)))
  #Affzo [M:SDH1]  # 117041.o - Performance enhancements
Endif

If SOURCE="SOH"
  [M:SOH4]ORDNOT            = sum([M:SOH4]LINORDNOT(0..([M:SOH4]NBLIG-1)))
  [M:SOH4]ORDATI            = sum([M:SOH4]LINORDATI(0..([M:SOH4]NBLIG-1)))
  [M:SOH4]ORDINVNOT         = sum([M:SOH4]LINORDNOT(0..([M:SOH4]NBLIG-1))) + sum([M:SIHV]XFNOT(0..([M:SIHV]NBFOOT-1)))
  [M:SOH4]ORDINVATI         = sum([M:SOH4]LINORDATI(0..([M:SOH4]NBLIG-1))) + sum([M:SIHV]XFATI(0..([M:SIHV]NBFOOT-1)))
  [M:SOH4]DLRATI            = sum([M:SOH4]LINDLRATI(0..([M:SOH4]NBLIG-1)))
  [M:SOH4]DLRNOT            = sum([M:SOH4]LINDLRNOT(0..([M:SOH4]NBLIG-1)))
  #Affzo [M:SOH4] # 117041.o - Performance enhancements
Endif

If SOURCE="SQH"
   [M:SQH2]QUONOT            = sum([M:SQH2]LINQUONOT(0..([M:SQH2]NBLIG-1)))
   [M:SQH2]QUOATI            = sum([M:SQH2]LINQUOATI(0..([M:SQH2]NBLIG-1)))
   [M:SQH2]QUOINVNOT         = sum([M:SQH2]LINQUONOT(0..([M:SQH2]NBLIG-1))) + sum([M:SIHV]XFNOT(0..([M:SIHV]NBFOOT-1)))
   [M:SQH2]QUOINVATI         = sum([M:SQH2]LINQUOATI(0..([M:SQH2]NBLIG-1))) + sum([M:SIHV]XFATI(0..([M:SIHV]NBFOOT-1)))
   #Affzo [M:SQH2] # 117041.o - Performance enhancements
Endif

If SOURCE="SIH"
   [M:SIH4]INVNOT         = sum([M:SIH4]AMTNOTLIN(0..([M:SIH4]NBLIG-1))) + sum([M:SIHV]XFNOT(0..([M:SIHV]NBFOOT-1)))
   [M:SIH4]INVATI         = sum([M:SIH4]AMTATILIN(0..([M:SIH4]NBLIG-1))) + sum([M:SIHV]XFATI(0..([M:SIHV]NBFOOT-1)))
   #Affzo [M:SIH4] # 117041.o - Performance enhancements
Endif

#Affzo [M:SIHV] # 117041.o - Performance enhancements
Return

# Load detail taxes
$LOADTAXES_LTA1

Raz [M:LTA1]NBVAT, [M:LTA1]NBFOOT

For nolign = 0 To [M:PTU]NBLIG5-1
  If  [M:PTU]DTADTL(nolign)=""
    [M:LTA1]NBVAT +=1
    [M:LTA1]JURTYP([M:LTA1]NBVAT-1) = [M:PTU]JURTYP(nolign)
    [M:LTA1]SAT([M:LTA1]NBVAT-1)    = [M:PTU]SAT(nolign)
    [M:LTA1]JURNAM([M:LTA1]NBVAT-1) = [M:PTU]JURNAM(nolign)
    [M:LTA1]TAXNAM([M:LTA1]NBVAT-1) = [M:PTU]TAXNAM(nolign)
    [M:LTA1]BASTAX([M:LTA1]NBVAT-1) = [M:PTU]BASTAX(nolign)
    [M:LTA1]TAXRAT([M:LTA1]NBVAT-1) = [M:PTU]TAXRAT(nolign)
    [M:LTA1]AMTTAX([M:LTA1]NBVAT-1) = [M:PTU]AMTTAX(nolign)
    [M:LTA1]TAXDAT([M:LTA1]NBVAT-1) = [M:PTU]TAXDAT(nolign)
    [M:LTA1]AMTNOT([M:LTA1]NBVAT-1) = [M:PTU]AMTNOT(nolign)
    [M:LTA1]PAYS([M:LTA1]NBVAT-1) = [M:PTU]PAYS(nolign)
    [M:LTA1]AMTATI([M:LTA1]NBVAT-1)=[M:LTA1]AMTNOT([M:LTA1]NBVAT-1)+[M:LTA1]AMTTAX([M:LTA1]NBVAT-1)
    [M:LTA1]CUR([M:LTA1]NBVAT-1)=[M:PTU]CUR
  Else
    [M:LTA1]NBFOOT +=1
    [M:LTA1]DTA([M:LTA1]NBFOOT-1)       = val([M:PTU]DTADTL(nolign))
    Call  LECTEXTRA([M:LTA1]DTASHO([M:LTA1]NBFOOT-1), "SFOOTINV", "SHOAXX", num$([M:LTA1]DTA([M:LTA1]NBFOOT-1)), "" ) From ATEXTRA
    [M:LTA1]DTASAT([M:LTA1]NBFOOT-1)    = [M:PTU]SAT(nolign)
    [M:LTA1]DTAJURTYP([M:LTA1]NBFOOT-1) = [M:PTU]JURTYP(nolign)
    [M:LTA1]DTAJURNAM([M:LTA1]NBFOOT-1) = [M:PTU]JURNAM(nolign)
    [M:LTA1]DTATAXNAM([M:LTA1]NBFOOT-1) = [M:PTU]TAXNAM(nolign)
    [M:LTA1]DTABASTAX([M:LTA1]NBFOOT-1) = [M:PTU]BASTAX(nolign)
    [M:LTA1]DTATAXRAT([M:LTA1]NBFOOT-1) = [M:PTU]TAXRAT(nolign)
    [M:LTA1]DTAAMTTAX([M:LTA1]NBFOOT-1) = [M:PTU]AMTTAX(nolign)
    [M:LTA1]DTATAXDAT([M:LTA1]NBFOOT-1) = [M:PTU]TAXDAT(nolign)
    [M:LTA1]DTAAMTNOT([M:LTA1]NBFOOT-1) = [M:PTU]AMTNOT(nolign)
    [M:LTA1]DTAPAYS([M:LTA1]NBFOOT-1) = [M:PTU]PAYS(nolign)
    [M:LTA1]DTAAMTATI([M:LTA1]NBFOOT-1)=[M:LTA1]DTAAMTNOT([M:LTA1]NBFOOT-1)+[M:LTA1]DTAAMTTAX([M:LTA1]NBFOOT-1)
    [M:LTA1]DTACUR([M:LTA1]NBFOOT-1)=[M:PTU]CUR
  Endif
Next

Sorta [M:LTA1]NBVAT [M:LTA1]NBVAT Order By [M:LTA1]PAYS(indice),[M:LTA1]SAT(indice),[M:LTA1]TAXNAM(indice)

#Added | GFONCTION = "FUNPREDLV" 108593.sn MJH 10/28/2015
If GFONCTION="FUNAUTDLV" | left$(GFONCTION,9)="FUNAUTINV" | GFONCTION="GESBIC" | GFONCTION = "FUNPREDLV"
  Gosub CREMOD_LTV
Endif

Return

##################################################
# TODAN-118710 Early discount calculation
##################################################
$CAL_BASDEP

  # Get out if the Settlement discount is blank OR Discount management mode is NOT Global calculation
  If [M:SIH2]DEP = AVOID.ACHAR | GDEPMGTMOD<>3
    [M:SIHV]BASDEP = 0 : Return
  Endif

  # Get out if not sales invoices function and invoice type is not 'Invoice'.
  # Following the core code except "& GDEPMGTMOD<>5" since we only support 3-Global calculation
  If GFONCTION="GESSIH" & [M:SIH0]INVTYP<>1 : Return : Endif

  If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif
  Read [TDA]TDA0 = [M:SIH2]DEP
  If !fstat
    Case [F:TDA]DEPTYP
      When 1
        [M:SIHV]BASDEP = [M:SIHV]INVNOT
      When 2
        [M:SIHV]BASDEP = [M:SIHV]INVATI
    Endcase
  Endif
  Affzo [M:SIHV]BASDEP
Return

# ------------------------------------------------------ #
# Tax on BP Customer Invoice                             #
# ------------------------------------------------------ #
$LOADTAXES_BIC
Local Integer SNS

If [M:BIC3]AMTNOTLIN(NLIG)<>0                # Sign on taxes matches sign on no tax amount
    [L]SNS = [M:BIC3]AMTNOTLIN(NLIG)/abs([M:BIC3]AMTNOTLIN(NLIG))
Else
    [L]SNS = 1
Endif

[M:BIC3]AMTVAT(NLIG)  = [L]SNS*abs([M:PTU]TOTAMTTAX(NLIG))
If [M:PTU]PRITYP(NLIG)<>2           # Tax excluded
  #[M:BIC3]AMTATILIN(NLIG) = [L]SNS*([M:BIC3]AMTNOTLIN(NLIG)+[M:BIC3]AMTVAT(NLIG))  # 115704.o
  [M:BIC3]AMTATILIN(NLIG) = [M:BIC3]AMTNOTLIN(NLIG)+[M:BIC3]AMTVAT(NLIG)            # 115704.n
  WNOTLIN=[M:PTU]AMTLIN(NLIG)
Else                                # Tax included
  WATILIN=[M:PTU]AMTLIN(NLIG)
  #[M:BIC3]AMTNOTLIN(NLIG) = [L]SNS*([M:BIC3]AMTATILIN(NLIG)-[M:BIC3]AMTVAT(NLIG))  # 115704.o
  [M:BIC3]AMTNOTLIN(NLIG) = [M:BIC3]AMTATILIN(NLIG)-[M:BIC3]AMTVAT(NLIG)            # 115704.n
Endif

[M:BIC3]TOTNOT += [M:BIC3]AMTNOTLIN(NLIG)
[M:BIC3]TOTATI += [M:BIC3]AMTATILIN(NLIG)
[M:BIC1]AMTATI += [M:BIC3]AMTATILIN(NLIG)
[M:BIC1]AMTNOT += [M:BIC3]AMTNOTLIN(NLIG)

Default Mask "[M:BIC3],[M:BIC1],[M:BIC0],[M:SCL]"

Affzo [M:BIC3]
Affzo [M:BIC1]
Return

##################################################
$LOADTAXES
Local Integer NLIGV

Case XWABMSK
    When "SOH4"  : Raz [M:SOH4]ORDATI,[M:SOH4]DLRATI,[M:SOH4]ORDINVATI, [M:SOH4]LINORDATI, [M:SOH4]LINDLRATI, [M:SOH4]NETPRIATI
                   Raz [M:SOH4]ORDNOT,[M:SOH4]DLRNOT,[M:SOH4]ORDINVNOT, [M:SOH4]LINORDNOT, [M:SOH4]LINDLRNOT, [M:SOH4]NETPRINOT
    When "SQH2"  : Raz [M:SQH2]QUONOT,[M:SQH2]QUOATI,[M:SQH2]PFMTOT,[M:SQH2]QUOINVATI
    When "SIH4"  : Raz [M:SIH4]INVNOT,[M:SIH4]INVATI,[M:SIH4]PFMTOT,[M:SIH4]AMTATILIN
    When "BIC3"  : Raz [M:BIC3]AMTTAX1,[M:BIC3]AMTTAX2,[M:BIC1]AMTATI,[M:BIC1]AMTNOT,[M:BIC3]TOTNOT,[M:BIC3]TOTATI
    When Default:
Endcase

Raz [M:SIHX]NBVAT, [M:SIHX]XVTAX, [M:SIHX]XVBAS
Raz [M:SIHX]XVNOT, [M:SIHX]XVSMI, [M:SIHX]XVSMIP, [M:SIHX]XVSMITP, [M:SIHX]XVSMITS, [M:SIHX]XVAMT,[M:SIHX]XVSUP
Raz [M:SIHX]XVATI, [M:SIHX]XVATI, [M:SIHX]XVSMI
Raz [M:SIHX]INVNOT, [M:SIHX]INVNOTRPT, [M:SIHX]DEVRPT1, [M:SIHX]INVATI, [M:SIHX]INVATIRPT, [M:SIHX]DEVRPT2

# Valuation [M:SIHX] for line items (products)
For NLIG=0 To [M:PTU]NBLIG3-[M:PTU]SFILIG-1
  If  XWABMSK="BIC3"
      Gosub LOADTAXES_BIC
  Else
      Gosub LOADTAXES_LIGV
  Endif
Next
#(MGG 08/05/2017) X3-33114
#[M:SIHV]=[M:SIHX]  # LOADTAXES_LIGV uses SIHX, and LOADTAXES_LIGF uses SIHV
 Raz [M:SIHV]
 Transmask [M:SIHX] To [M:SIHV]
#END(MGG 08/05/2017) X3-33114
# Process Footer (Invoice) elements

#Affzo [M:SIHV]  # 117041.o - Performance enhancements
Gosub LOADTAXES_LIGF                            # Process footer invoice elements
#Affzo [M:SIHV]  # 117041.o - Performance enhancements
Gosub LOADTAXES_LTA1                            # Detail Info

# Issue 117041 - 2016-06-08 by ERMIL : Comment AFFZO from inside of LOADTAXES_LIGV
Case SOURCE
  When "SQH" : Affzo [M:SQH2]
  When "SOH" : Affzo [M:SOH4]
  When "SDH" : Affzo [M:SDH1]
  When "SIH" : Affzo [M:SIH4]
Endcase
Affzo [M:SIHV]

Return

#**
#* Ship From addresses used on this document
#* Loads mask [PTU] with unique ship from addresses that are used on the detail lines.
#*
#* @param SHIP_FROMS string containing mask variable that has all the ship from codes on the document. For example: SHIP_FROMS="[M:SOH4]STOFCY
#* @param FR_LINES integer - Total lines have ship from data. E.g., [M:SOH4]nblig
#*!
Subprog SHIP_FROM(SHIP_FROMS,FR_LINES)
Value Char SHIP_FROMS()
Value Integer FR_LINES
  Local Integer I
  Local Char SHIP_FROM(10)
  nolign = find("",[M:PTU]STOFCY(0..[M:PTU]NBLIG1))
  If nolign
    nolign-=1
  Endif
  GERR=0

  For I=0 To FR_LINES-1
    Assign "[L]SHIP_FROM" With evalue(SHIP_FROMS+"("+num$(I)+")")
    If [L]SHIP_FROM="" : [L]SHIP_FROM=[M:PTU]STOFCY(0) : Endif        # Certain invoices may not have ship_from(contracts)
    If [L]SHIP_FROM<>"" & nolign>=0 & !find([L]SHIP_FROM,[M:PTU]STOFCY(0..nolign-1))
      # No blank entries available or reached max addresses in PTU mask
      If nolign>=0 & nolign<dim([M:PTU]STOFCY)
        [M:PTU]STOFCY(nolign) = [L]SHIP_FROM
        # Determine default address code
        If [F:FCY]FCY <> [M:PTU]STOFCY(nolign)
          Read [FCY]FCY0 = [M:PTU]STOFCY(nolign)  #109565 add the nolign index.
          If fstat
              Raz [F:FCY]
          Endif
        Endif

        If [F:BPA]BPATYP <> 3 | [F:BPA]BPANUM <> [M:PTU]STOFCY(nolign)| [F:BPA]BPAADD <> [F:FCY]BPAADD
          Read [BPA] BPA0=3;[M:PTU]STOFCY(nolign);[F:FCY]BPAADD
          If fstat Raz [F:BPA] : Endif
        Endif

        [M:PTU]STOFCYCRY(nolign)       = [F:BPA]CRY
        [M:PTU]STOFCYCTY(nolign)       = [F:BPA]CTY
        [M:PTU]STOFCYPOS(nolign)       = [F:BPA]POSCOD
        [M:PTU]STOFCYLIG1(nolign)      = [F:BPA]BPAADDLIG(0)
        [M:PTU]STOFCYLIG2(nolign)      = [F:BPA]BPAADDLIG(1)
        [M:PTU]STOFCYLIG3(nolign)      = [F:BPA]BPAADDLIG(2)
        [M:PTU]STOFCYSAT(nolign)       = [F:BPA]SAT
        nolign +=1
      Else
        GERR=1
        Break
      Endif
    Else
      If !find("",[M:PTU]STOFCY(0..dim([M:PTU]STOFCY)-1))
        GERR=1
        Break
      Endif
    Endif
  Next
  If  GERR
    GMESSAGE = mess(1081,196,1)-"[PTU]STOFCYxxx"-num$(dim([M:PTU]STOFCY)-1)-mess(8,133,1)
  Endif
  [M:PTU]NBLIG1 = nolign
End


#**
#* Ship To addresses used on this document
#* Loads mask [PTU] with unique ship to addresses that are used on the detail lines.
#*
#* @param TO_CODES string containing mask variable that has all the ship to codes on the document. For example: TO_CODES="[M:SOH4]DBPAADD"
#* @param TO_LINES integer - Total lines have ship from data. E.g., [M:SOH4]nblig
#*!
Subprog SHIP_TO(TO_CODES,TO_LINES)
Value Char TO_CODES()
Value Integer TO_LINES
  Local Integer I,FND_ADDRESS
  Local Char SHIP_TO(GLONBPD)
  nolign = find("",[M:PTU]BPAADD(0..dim([M:PTU]BPAADD)-1))
  If nolign
    nolign-=1
  Endif
  GERR = 0

  For I=0 To TO_LINES-1
    Assign "[L]SHIP_TO" With evalue(TO_CODES+"("+num$(I)+")")
    If !([L]SHIP_TO<>"" & nolign>=0 & find([L]SHIP_TO,[M:PTU]BPAADD(0..nolign-1)))
      # No blank entries available
      If nolign>=0 & nolign<dim([M:PTU]BPAADD)
        [M:PTU]BPAADD(nolign) = [L]SHIP_TO

        If [F:BPA]BPATYP <> 1 | [F:BPA]BPANUM <> [M:PTU]BPR | [F:BPA]BPAADD <> [M:PTU]BPAADD(nolign)
          Read [BPA] BPA0=1;[M:PTU]BPR;[M:PTU]BPAADD(nolign)
          If fstat Raz [F:BPA] : Endif
        Endif

        # ADBFLG=0 means address is not loaded  into ADB mask
        # ADB2 = Ship To addresses
        If GFONCTION="GESBIC" & dim([M:BIC0]CTY)>0
          [M:PTU]BPDCRY(nolign)      = [M:BIC0]CRY
          [M:PTU]BPDCTY(nolign)      = [M:BIC0]CTY
          [M:PTU]BPDPOS(nolign)      = [M:BIC0]POSCOD
          [M:PTU]BPDSAT(nolign)      = [M:BIC0]SAT
          [M:PTU]BPDADDLIG1(nolign) = [M:BIC0]BPAADDLIG(0)
          [M:PTU]BPDADDLIG2(nolign) = [M:BIC0]BPAADDLIG(1)
          [M:PTU]BPDADDLIG3(nolign) = [M:BIC0]BPAADDLIG(2)
          If [M:PTU]BPDCTY = ""
            [M:PTU]BPDCRY(nolign)      = [F:BPA]CRY
            [M:PTU]BPDCTY(nolign)      = [F:BPA]CTY
            [M:PTU]BPDPOS(nolign)      = [F:BPA]POSCOD
            [M:PTU]BPDSAT(nolign)      = [F:BPA]SAT
            [M:PTU]BPDADDLIG1(nolign) = [F:BPA]BPAADDLIG(0)
            [M:PTU]BPDADDLIG2(nolign) = [F:BPA]BPAADDLIG(1)
            [M:PTU]BPDADDLIG3(nolign) = [F:BPA]BPAADDLIG(2)
            FND_ADDRESS = 1
          Else
            FND_ADDRESS = 1
          Endif
        Elsif dim([M:ADB2]ADBFLG)>0 & [M:ADB2]ADBFLG=0
          # X3-47279 .sn - BODEL
          If GFONCTION = "FUNAUTINVD"
          # When you click the invoice button directly from the shipment, within the UI of X3
          # the ship to address is used as a third address sent to Avalara.
          # Making FUNAUTINVD use the same approach as invoice entry invoked from the delivery function (GESSDH).
          # However, the BPA file does not contain this address at this point so we need to re-read to get it
            If !clalev([F:SIV2]) : Local File SINVOICEV [SIV2] : Endif
            Read [F:SIV2]SIV0=[M:PTU]VCRNUM # Read by the invoice number
            If !fstat
              # Read Successful, and found the original document, is there an address now?
              If [F:SIV2]BPDCTY <> ""
                Gosub SET_PTU_BY_SIV2
              Else
                # Unable to read and still don't have an address, so read the default address on file for the bill to
                 Gosub SET_PTU_BY_DEFAULT_ADDR
              Endif
            Endif
          Else # X3-47279 .en - BODEL
            [M:PTU]BPDCRY(nolign)      = [F:BPA]CRY
            [M:PTU]BPDCTY(nolign)      = [F:BPA]CTY
            [M:PTU]BPDPOS(nolign)      = [F:BPA]POSCOD
            [M:PTU]BPDSAT(nolign)      = [F:BPA]SAT
            [M:PTU]BPDADDLIG1(nolign) = [F:BPA]BPAADDLIG(0)
            [M:PTU]BPDADDLIG2(nolign) = [F:BPA]BPAADDLIG(1)
            [M:PTU]BPDADDLIG3(nolign) = [F:BPA]BPAADDLIG(2)
            FND_ADDRESS = 1
          Endif
        Elsif GFONCTION="FUNAUTDLV"
            [M:PTU]BPDCRY(nolign)      = [F:SDH]BPDCRY
            [M:PTU]BPDCTY(nolign)      = [F:SDH]BPDCTY
            [M:PTU]BPDPOS(nolign)      = [F:SDH]BPDPOSCOD
            [M:PTU]BPDSAT(nolign)      = [F:SDH]BPDSAT
            [M:PTU]BPDADDLIG1(nolign)  = [F:SDH]BPDADDLIG(0)
            [M:PTU]BPDADDLIG2(nolign)  = [F:SDH]BPDADDLIG(1)
            [M:PTU]BPDADDLIG3(nolign)  = [F:SDH]BPDADDLIG(2)
            FND_ADDRESS=1
        Elsif (dim([M:ADB2]ADBFLG)>0 & [M:ADB2]ADBFLG<>0) and nolign=0           # Applies only to document address. Doc address is first address loaded
            [M:PTU]BPDCRY(nolign)      = [M:ADB2]CRY
            [M:PTU]BPDCTY(nolign)      = [M:ADB2]CTY
            [M:PTU]BPDPOS(nolign)      = [M:ADB2]POSCOD
            [M:PTU]BPDSAT(nolign)      = [M:ADB2]SAT
            [M:PTU]BPDADDLIG1(nolign) = [M:ADB2]BPAADDLIG(0)
            [M:PTU]BPDADDLIG2(nolign) = [M:ADB2]BPAADDLIG(1)
            [M:PTU]BPDADDLIG3(nolign) = [M:ADB2]BPAADDLIG(2)
         Else
            [M:PTU]BPDCRY(nolign)      = [F:BPA]CRY
            [M:PTU]BPDCTY(nolign)      = [F:BPA]CTY
            [M:PTU]BPDPOS(nolign)      = [F:BPA]POSCOD
            [M:PTU]BPDSAT(nolign)      = [F:BPA]SAT
            [M:PTU]BPDADDLIG1(nolign) = [F:BPA]BPAADDLIG(0)
            [M:PTU]BPDADDLIG2(nolign) = [F:BPA]BPAADDLIG(1)
            [M:PTU]BPDADDLIG3(nolign) = [F:BPA]BPAADDLIG(2)
        Endif
        nolign +=1
      Else
        GERR=1
        Break
      Endif
    Else
#     If !find("",[M:PTU]BPAADD(0..[M:PTU]NBLIG2))  # 107169.o
      If !find("",[M:PTU]BPAADD(0..[M:PTU]NBLIG2)) & nolign>=0 & nolign>dim([M:PTU]BPAADD)  # 107169.n
        GERR=1
        Break
      Endif
    Endif
  Next
  If GERR
    GMESSAGE = mess(474,177,1)-"[PTU]BPDxxxxxx"-num$(dim([M:PTU]BPDADD)-1)-mess(8,133,1)
  Endif
  [M:PTU]NBLIG2=nolign
End

# SIV2 was read in FUNAUTINVD branch above, so set the buffer
# X3-47279 .sn - BODEL
$SET_PTU_BY_SIV2
  # SIV1 is populated, we're good to go, just set the PTU record, no read required.
  [M:PTU]BPDCRY(nolign)       = [F:SIV2]BPDCRY
  [M:PTU]BPDCTY(nolign)       = [F:SIV2]BPDCTY
  [M:PTU]BPDPOS(nolign)       = [F:SIV2]BPDPOSCOD
  [M:PTU]BPDSAT(nolign)       = [F:SIV2]BPDSAT
  [M:PTU]BPDADDLIG1(nolign)   = [F:SIV2]BPDADDLIG(0)
  [M:PTU]BPDADDLIG2(nolign)   = [F:SIV2]BPDADDLIG(1)
  [M:PTU]BPDADDLIG3(nolign)   = [F:SIV2]BPDADDLIG(2)

  FND_ADDRESS = 1

  LogicClose File [SIV2]
Return # X3-47279 .en - BODEL

# X3-47279 .sn - BODEL
$SET_PTU_BY_DEFAULT_ADDR
  # Get the default address for the partner. Edge case.
  Filter [BPA] Where BPAADDFLG=2 and BPATYP=1 and BPANUM=[M:PTU]BPR
  Read [BPA] First
  If !fstat
    [M:PTU]BPDCRY(nolign)       = [F:BPA]CRY
    [M:PTU]BPDCTY(nolign)       = [F:BPA]CTY
    [M:PTU]BPDPOS(nolign)       = [F:BPA]POSCOD
    [M:PTU]BPDSAT(nolign)       = [F:BPA]SAT
    [M:PTU]BPDADDLIG1(nolign)   = [F:BPA]BPAADDLIG(0)
    [M:PTU]BPDADDLIG2(nolign)   = [F:BPA]BPAADDLIG(1)
    [M:PTU]BPDADDLIG3(nolign)   = [F:BPA]BPAADDLIG(2)

    FND_ADDRESS = 1
  Endif
  Filter [BPA]
Return # X3-47279 .en - BODEL

#**
#* SID ship to addresses are determined by the source docuemnt. Since 2 source documents could have the same address code but pointing to different addresses,
#* We add the document number to the address code. For example, "001" on doocument "A" has an overridden address.  While document "B" has an overridden address
#* another location.  So we cannot use "001" along to determine address. We can use the doc number + "001" to determine a unique address code.
#* Loads mask [PTU] with unique ship to addresses that are used on the detail lines.
#*
#* @param NLIG - Invoice detail line number (nolign)
#*!
Subprog SID_SHIP_TO(NLIG)
Value Integer NLIG
Local Integer NXT_ADRLIG,NEW_ADDRESS
Local Char TMP_VCRNUM(GLONVCR)

Raz  NEW_ADDRESS,TMP_VCRNUM
NXT_ADRLIG = find("", [M:PTU]BPAADD(0..dim([M:PTU]BPAADD)-1))
If NXT_ADRLIG<>0
  NXT_ADRLIG-=1
Endif
    If  [M:SIH4]SDHNUM(NLIG)<>""
      Read [F:SDH]SDH0 = [M:SIH4]SDHNUM(NLIG)
      If  !fstat
          If !find([M:SIH4]SDHNUM(NLIG)+"_"+[F:SDH]BPAADD,[M:PTU]BPAADD(0..dim([M:PTU]BPAADD)-1))
            If  [F:SDH]BPDCTY <> ""
              [M:PTU]BPAADD(NXT_ADRLIG) = [M:SIH4]SDHNUM(NLIG)+"_"+[F:SDH]BPAADD
              [M:PTU]DBPAADD(NLIG)      = [M:SIH4]SDHNUM(NLIG)+"_"+[F:SDH]BPAADD
              [M:PTU]BPDCRY(NXT_ADRLIG)      = [F:SDH]BPDCRY
              [M:PTU]BPDCTY(NXT_ADRLIG)      = [F:SDH]BPDCTY
              [M:PTU]BPDPOS(NXT_ADRLIG)      = [F:SDH]BPDPOSCOD
              [M:PTU]BPDSAT(NXT_ADRLIG)      = [F:SDH]BPDSAT
              [M:PTU]BPDADDLIG1(NXT_ADRLIG) = [F:SDH]BPDADDLIG(0)
              [M:PTU]BPDADDLIG2(NXT_ADRLIG) = [F:SDH]BPDADDLIG(1)
              [M:PTU]BPDADDLIG3(NXT_ADRLIG) = [F:SDH]BPDADDLIG(2)
              NEW_ADDRESS=1
          Else
              Read [F:BPA]BPA0=1;[M:PTU]BPR;[F:SDH]BPAADD
              If  !fstat
                  [M:PTU]BPAADD(NXT_ADRLIG) = [M:SIH4]SDHNUM(NLIG)+"_"+[F:SDH]BPAADD
                  [M:PTU]DBPAADD(NLIG)      = [M:SIH4]SDHNUM(NLIG)+"_"+[F:SDH]BPAADD
                  [M:PTU]BPDCRY(NXT_ADRLIG)      = [F:BPA]CRY
                  [M:PTU]BPDCTY(NXT_ADRLIG)      = [F:BPA]CTY
                  [M:PTU]BPDPOS(NXT_ADRLIG)      = [F:BPA]POSCOD
                  [M:PTU]BPDSAT(NXT_ADRLIG)      = [F:BPA]SAT
                  [M:PTU]BPDADDLIG1(NXT_ADRLIG) = [F:BPA]BPAADDLIG(0)
                  [M:PTU]BPDADDLIG2(NXT_ADRLIG) = [F:BPA]BPAADDLIG(1)
                  [M:PTU]BPDADDLIG3(NXT_ADRLIG) = [F:BPA]BPAADDLIG(2)
                  NEW_ADDRESS=1
              Endif
          Endif
      Endif
    Endif
Endif

# Address from SORDER orders

If  [M:SIH4]SOHNUM(NLIG)<>"" & [M:SIH4]SOPLIN(NLIG)<>0 & [M:SIH4]SOQSEQ(NLIG)<>0 & NEW_ADDRESS=0
    If !clalev ([F:SOQ]) : Local File SORDERQ  [SOQ] : Endif                              # 106275.n
    If !clalev ([F:SOH]) : Local File SORDER   [SOH] : Endif                              # 106275.n
    Read [F:SOQ]SOQ0=[M:SIH4]SOHNUM(NLIG);[M:SIH4]SOPLIN(NLIG);[M:SIH4]SOQSEQ(NLIG)
    If  !fstat
        Read [F:SOH]SOH0 = [M:SIH4]SOHNUM(NLIG)
        If  !fstat
          [M:PTU]DBPAADD(NLIG)      = [M:SIH4]SOHNUM(NLIG)+"_"+[F:SOQ]BPAADD
          If !find([M:SIH4]SOHNUM(NLIG)+"_"+[F:SOQ]BPAADD,[M:PTU]BPAADD(0..dim([M:PTU]BPAADD)-1))
            [M:PTU]BPAADD(NXT_ADRLIG) = [M:SIH4]SOHNUM(NLIG)+"_"+[F:SOQ]BPAADD
            If  [F:SOQ]BPAADD = [F:SOH]BPAADD
                If  [F:SOH]BPDCTY <> ""
                    [M:PTU]BPDCRY(NXT_ADRLIG)      = [F:SOH]BPDCRY
                    [M:PTU]BPDCTY(NXT_ADRLIG)      = [F:SOH]BPDCTY
                    [M:PTU]BPDPOS(NXT_ADRLIG)      = [F:SOH]BPDPOSCOD
                    [M:PTU]BPDSAT(NXT_ADRLIG)      = [F:SOH]BPDSAT
                    [M:PTU]BPDADDLIG1(NXT_ADRLIG) = [F:SOH]BPDADDLIG(0)
                    [M:PTU]BPDADDLIG2(NXT_ADRLIG) = [F:SOH]BPDADDLIG(1)
                    [M:PTU]BPDADDLIG3(NXT_ADRLIG) = [F:SOH]BPDADDLIG(2)
                    NEW_ADDRESS=1
                Endif
             Endif
             If NEW_ADDRESS=0
              Read [F:BPA]BPA0=1;[F:SOH]BPCORD;[F:SOQ]BPAADD
              If  !fstat
                  [M:PTU]BPDCRY(NXT_ADRLIG)      = [F:BPA]CRY
                  [M:PTU]BPDCTY(NXT_ADRLIG)      = [F:BPA]CTY
                  [M:PTU]BPDPOS(NXT_ADRLIG)      = [F:BPA]POSCOD
                  [M:PTU]BPDSAT(NXT_ADRLIG)      = [F:BPA]SAT
                  [M:PTU]BPDADDLIG1(NXT_ADRLIG) = [F:BPA]BPAADDLIG(0)
                  [M:PTU]BPDADDLIG2(NXT_ADRLIG) = [F:BPA]BPAADDLIG(1)
                  [M:PTU]BPDADDLIG3(NXT_ADRLIG) = [F:BPA]BPAADDLIG(2)
                  NEW_ADDRESS=1
              Endif
            Endif
         Else
         # Address already in list of document addresses
          End
         Endif
      Endif
    Endif
Endif

# Address from SINVOICE invoice
If  NEW_ADDRESS=0
    TMP_VCRNUM=[M:SIH0]NUM
    If [M:SIH4]XSIHORINUM(NLIG)<>"" : TMP_VCRNUM=[M:SIH4]XSIHORINUM(NLIG) : Endif
    # Document number is the same line document number
    If TMP_VCRNUM=[M:SIH0]NUM
      If clalev([M:ADB2]) & [M:ADB2]CTY<>""
          [M:PTU]BPAADD(NXT_ADRLIG)= TMP_VCRNUM+"_"+[M:ADB2]BPAADD
          [M:PTU]DBPAADD(NLIG)     = TMP_VCRNUM+"_"+[M:ADB2]BPAADD
          [M:PTU]BPDCRY(NXT_ADRLIG)      = [M:ADB2]CRY
          [M:PTU]BPDCTY(NXT_ADRLIG)      = [M:ADB2]CTY
          [M:PTU]BPDPOS(NXT_ADRLIG)      = [M:ADB2]POSCOD
          [M:PTU]BPDSAT(NXT_ADRLIG)      = [M:ADB2]SAT
          [M:PTU]BPDADDLIG1(NXT_ADRLIG) = [M:ADB2]BPAADDLIG(0)
          [M:PTU]BPDADDLIG2(NXT_ADRLIG) = [M:ADB2]BPAADDLIG(1)
          [M:PTU]BPDADDLIG3(NXT_ADRLIG) = [M:ADB2]BPAADDLIG(2)
          NEW_ADDRESS = 1
      Else          # Line document number same as header document number but different address or ADB2 not open
          Read [F:BPA]BPA0=1;[M:SIH1]BPCORD;[M:SIH1]BPAADD
          If  !fstat
              [M:PTU]BPAADD(NXT_ADRLIG)= TMP_VCRNUM+"_"+[F:BPA]BPAADD
              [M:PTU]DBPAADD(NLIG)     = TMP_VCRNUM+"_"+[F:BPA]BPAADD
              [M:PTU]BPDCRY(NXT_ADRLIG)      = [F:BPA]CRY
              [M:PTU]BPDCTY(NXT_ADRLIG)      = [F:BPA]CTY
              [M:PTU]BPDPOS(NXT_ADRLIG)      = [F:BPA]POSCOD
              [M:PTU]BPDSAT(NXT_ADRLIG)      = [F:BPA]SAT
              [M:PTU]BPDADDLIG1(NXT_ADRLIG) = [F:BPA]BPAADDLIG(0)
              [M:PTU]BPDADDLIG2(NXT_ADRLIG) = [F:BPA]BPAADDLIG(1)
              [M:PTU]BPDADDLIG3(NXT_ADRLIG) = [F:BPA]BPAADDLIG(2)
              NEW_ADDRESS = 1
          Endif
      Endif
    Else # Line document number is different than header document number - lookup address
      Read [F:SIV1]SIV0=TMP_VCRNUM
        If !fstat
          If  [F:SIV1]BPDCTY<>""
              [M:PTU]BPAADD(NXT_ADRLIG)= TMP_VCRNUM+"_"+[F:SIV1]BPAADD
              [M:PTU]DBPAADD(NLIG)     = TMP_VCRNUM+"_"+[F:SIV1]BPAADD
              [M:PTU]BPDCRY(NXT_ADRLIG)      = [F:SIV1]BPDCRY
              [M:PTU]BPDCTY(NXT_ADRLIG)      = [F:SIV1]BPDCTY
              [M:PTU]BPDPOS(NXT_ADRLIG)      = [F:SIV1]BPDPOSCOD
              [M:PTU]BPDSAT(NXT_ADRLIG)      = [F:SIV1]BPDSAT
              [M:PTU]BPDADDLIG1(NXT_ADRLIG) = [F:SIV1]BPDADDLIG(0)
              [M:PTU]BPDADDLIG2(NXT_ADRLIG) = [F:SIV1]BPDADDLIG(1)
              [M:PTU]BPDADDLIG3(NXT_ADRLIG) = [F:SIV1]BPDADDLIG(2)
              NEW_ADDRESS = 1
          Else
              Read [F:BPA]BPA0=1;[F:SIV1]BPCORD;[F:SIV1]BPAADD
              If  !fstat
                  [M:PTU]BPAADD(NXT_ADRLIG)= TMP_VCRNUM+"_"+[F:BPA]BPAADD
                  [M:PTU]DBPAADD(NLIG)     = TMP_VCRNUM+"_"+[F:BPA]BPAADD
                  [M:PTU]BPDCRY(NXT_ADRLIG)      = [F:BPA]CRY
                  [M:PTU]BPDCTY(NXT_ADRLIG)      = [F:BPA]CTY
                  [M:PTU]BPDPOS(NXT_ADRLIG)      = [F:BPA]POSCOD
                  [M:PTU]BPDSAT(NXT_ADRLIG)      = [F:BPA]SAT
                  [M:PTU]BPDADDLIG1(NXT_ADRLIG) = [F:BPA]BPAADDLIG(0)
                  [M:PTU]BPDADDLIG2(NXT_ADRLIG) = [F:BPA]BPAADDLIG(1)
                  [M:PTU]BPDADDLIG3(NXT_ADRLIG) = [F:BPA]BPAADDLIG(2)
                  NEW_ADDRESS = 1
            Endif
          Endif
        Endif
    Endif
Endif

If NEW_ADDRESS
  If [M:PTU]NBLIG2 < dim([M:PTU]BPAADD)#116955.n MJH 7/11/2016
    [M:PTU]NBLIG2+=1
  Endif
Endif
End

# Open statements Detail Local tax
$OUVRE_LTA
# Detail local tax data
If func AFNC.ACTIV("LTA")
  If !clalev([F:LTP])  Local File LTAPAR [LTP]  Endif
  If !clalev([F:LTV])  Local File LTAVCR [LTV]  Endif
  If !clalev([M:LTA1]) Local Mask LTA1   [LTA1] Endif
  If [F:LTP]DOSSIER <> nomap              # Read in default folder
    Read [F:LTP]LTP0=nomap                # Note, LTP may not exist if creating parameters, skip errors
  Endif
Endif
Return

#**
#* INICREMOD_SIH - called from SUBSIHA
#*!
$INICREMOD_SIH
Local Integer ERR
Local Char ERRMSG(250)
Local Decimal  WMT1, WMT2, COEFDEVISE
Local Decimal  ZFSMIP    : # pour calcul le montant soumis du pied
Local Decimal  ZFNOTP    : # pour chgt ht pied par point d'entrée
Local Decimal  ZFATIP    : # pour chgt ttc pied par point d'entrée
Local Shortint WSENS                       : # positif=1 / négatif=-1
Local Shortint JL, JLT, JLT1, JLE, JTVA, JTPA, JTSP, NBTVA, NBTPA, NBTSP
Local Integer  STAT

Local Integer  WNBXVTAX : WNBXVTAX=dim([M:SIHX]XVTAX)-1   : # Bug 74556 : Optimisation
Local Integer  WNBXFNUM : WNBXFNUM=dim([M:SIHX]XFNUM)-1   : # Bug 74556 : Optimisation

Local Char     TVACOD (GLONVAT) (0..WNBXVTAX) : # tableau interne des TVA
Local Decimal  TVANOT     (0..WNBXVTAX)
Local Decimal  TVASMI     (0..WNBXVTAX)
Local Decimal  TVASMIP    (0..WNBXVTAX)
Local Decimal  TVASMIF    (0..WNBXVTAX)
Local Decimal  TVASMITP   (0..WNBXVTAX)
Local Decimal  TVASMITS   (0..WNBXVTAX)
Local Decimal  TVASMIX    (0..WNBXVTAX) : # total des soumis autre que produit
Local Decimal  TVATAUX    (0..WNBXVTAX)
Local Decimal  TVAAMT     (0..WNBXVTAX)
Local Decimal  TVASUP     (0..WNBXVTAX)
Local Decimal  TVAATI     (0..WNBXVTAX)
Local Shortint TVARANG    (0..WNBXVTAX)
Local Shortint TVAUPDSMIP (0..WNBXVTAX) : # =1 si soumis taxe modifie par element pied

Local Char     TPACOD (GLONVAT) (0..WNBXVTAX) : # tableau interne Taxes parafiscales
Local Decimal  TPANOT     (0..WNBXVTAX)
Local Decimal  TPASMIP    (0..WNBXVTAX)
Local Decimal  TPATAUX    (0..WNBXVTAX)
Local Decimal  TPAAMT     (0..WNBXVTAX)
Local Shortint TPARANG    (0..WNBXVTAX)

Local Char     TSPCOD (GLONVAT) (0..WNBXVTAX) : # tableau interne Taxes spéciales
Local Decimal  TSPNOT     (0..WNBXVTAX)
Local Decimal  TSPSMIP    (0..WNBXVTAX)
Local Decimal  TSPTAUX    (0..WNBXVTAX)
Local Decimal  TSPAMT     (0..WNBXVTAX)
Local Shortint TSPRANG    (0..WNBXVTAX)

Local Decimal WDTANET, WDTAVATRAT, WDTAVATAMT, WDTAATI
Local Decimal WXFVATAMTP, WXFMNT
# Tableau interne de calcul des taxes
Local Decimal TDTAMNT (0..WNBXVTAX)            : # Montant
Local Decimal TDTAMAN (0..WNBXVTAX)            : # Zone de manoeuvre
Local Char    TDTAVAT (GLONVAT) (0..WNBXVTAX)  : # Code taxe
Local Decimal TDTAVATRT (0..WNBXVTAX)          : # Taux taxe

# Pour la modification de la base de calcul d'un élément
Local Char    WACTCLCBAS  : # Action à executer pour alimenter la base de calcul d'un élément
Local Char    WPRGCLCBAS  : # Programme contenant l'action à executer
Local Decimal WMNTCLCBAS  : # Montant contenant la base de calcul d'un élément
Local Char    WSVGACT(GLONACT)

# V6.2 : 60763 Settlements Discounts
Local Integer WDTADISVAT  : # N° de l'élément qui va contenir la remise sur taxe
Local Integer WDTADISIND  : # N° de l'indice de cet élément dans le tableau des élts

GTAXBYDOC = 1

Gosub CAL_FACTURE_USA

If  ERR : GOK=0 : Return : Endif

# 117130 - Since calls are not after the commit - we have to write to the Database here
#Trbegin [SIH]  #122614 - JOBRO - rework of SST transaction management
Readlock [SIH]SIH0 = [M:SIH0]NUM With lockwait=3
#If fstat : Call FSTA("SIH") From GLOCK : Endif #122614 - JOBRO
If fstat : Call FSTA("SIH") From GLOCK : GOK=0 : Return : Endif #122614 - JOBRO
# [F:SIH] has already been loaded, update to SST  amounts
[F:SIH]AMTNOT   = [M:SIHV]INVNOT
[F:SIH]AMTATI   = [M:SIHV]INVATI
[F:SIH]AMTTAX(0)= [M:SIHV]INVATI-[M:SIHV]INVNOT
[F:SIH]BASTAX(0)= [M:SIHV]INVNOT
[F:SIH]AMTNOTL  = [M:SIHV]INVNOTRPT
[F:SIH]AMTATIL  = [M:SIHV]INVATIRPT
[M:SIHV]NUM     = [M:SIH0]NUM
[M:SIHV]VCRTYP  = 4                 # JOBRO-122698
[F:SIH]BASDEP   = [M:SIHV]BASDEP    # TODAN-118710

# 117130.n
Rewrite [SIH]
If fstat
  Call FSTA("SIH") From GLOCK
#  Rollback               #122614 - JOBRO
  GOK=0                   #122614 - JOBRO
  Return                  #122614 - JOBRO
#Else
#  Commit
Endif

# Update LTV
Gosub CREMOD_LTV From TRTTAXUSA

If !GOK : Return : Endif
Return

#**
#* IB_LTAINVATI - Display or Hide LTA - SST button
#*  Applies to fields QUOINVATI,  ORDINVATI, DLVINVATI, etc.
#*  Called from IB_xxxINVATI in standard SUBs
#*
#* @param WBOUT - Button number on the field to be hidden or left to display
#*!
Subprog IB_LTAINVATI(WBOUT)
Value Shortint WBOUT
# If !(func AFNC.ACTIV("LTA") & GLOCUSATAX)   # 106867.o
If !(func AFNC.ACTIV("LTA")) | [F:CPY]SSTTAXACT <> 2   # 106867.n
  Assign "[V]GBOUT"+num$(WBOUT) With ""
Endif

End

#**
#* LTAGREP - Creates and sets a global variable GLTAGREP, so that SUBLTA can know the status of GREP
#*        Called from TRTVENFACR
#*!
Subprog LTAGREP
If dim(GLTAGREP)<1
  Global Char GLTAGREP(1)
Endif
GLTAGREP = GREP
End

#**
#* ALISIDTAX - Update SINVOICED detail with values in mask SIH4
#*        Called from FUNAUTINVO, FUNAUTINVD, SUBSIHB
#* #*
#* @param WNUM - Document number
#*!
Subprog ALISIDTAX(WNUM)
Value Char WNUM

Local Integer JNOL, JL1

For [SID]SID0 Where NUM=WNUM

  Readlock [SID] Curr

  If fstat=1
    GOK=-1 : GLOCK="$SINVOICED"-[F:SIV]NUM          : Break
  Elsif fstat
    GOK=0  : Call RSTA("SID",[F:SIV]NUM) From GLOCK : Break
  Endif

  JNOL +=1

  If dim([M:SIH4]NETPRINOT)>=JNOL   : [F:SID]NETPRINOT    = [M:SIH4]NETPRINOT(JNOL-1)   : Endif
  If dim([M:SIH4]NETPRIATI)>=JNOL   : [F:SID]NETPRIATI    = [M:SIH4]NETPRIATI(JNOL-1)   : Endif
  If dim([M:SIH4]PFM)>=JNOL         : [F:SID]PFM          = [M:SIH4]PFM(JNOL-1)         : Endif

  If dim([M:SIH4]AMTNOTLIN)>=JNOL   : [F:SID]AMTNOTLIN    = [M:SIH4]AMTNOTLIN(JNOL-1)   : Endif
  If dim([M:SIH4]BASTAXLIN1)>=JNOL  : [F:SID]BASTAXLIN(0) = [M:SIH4]BASTAXLIN1(JNOL-1)  : Endif
  If dim([M:SIH4]AMTTAXLIN1)>=JNOL  : [F:SID]AMTTAXLIN(0) = [M:SIH4]AMTTAXLIN1(JNOL-1)  : Endif
  If dim([M:SIH4]AMTATILIN)>=JNOL   : [F:SID]AMTATILIN    = [M:SIH4]AMTATILIN(JNOL-1)   : Endif
  If dim([M:SIH4]RATTAXLIN)>=JNOL   : [F:SID]RATTAXLIN    = [M:SIH4]RATTAXLIN(JNOL-1)   : Endif  # 117130.n

#  If dim([M:SIHV]DDTANUM01)>=JNOL
#    If [M:SIHV]DDTANUM01(JNOL-1)>0
#      [F:SID]DDTANUM(0)   = [M:SIHV]DDTANUM01(JNOL-1)
#      [F:SID]DDTANOT(0)   = [M:SIHV]DDTANOT01(JNOL-1)
#    Endif
#  Endif
#
#  If dim([M:SIHV]DDTANUM02)>=JNOL
#    If [M:SIHV]DDTANUM02(JNOL-1)>0
#      [F:SID]DDTANUM(1)   = [M:SIHV]DDTANUM02(JNOL-1)
#      [F:SID]DDTANOT(1)   = [M:SIHV]DDTANOT02(JNOL-1)
#    Endif
#  Endif

  #CATUA X3-84760.sn
  #Assign invoice line allocation values [F:SID]DDTANUM(X) & [F:SID]DDTANOT(X) for invoice elements
  For JL1=1 To G_VALSFL
    If evalue ("dim([M:SIHV]DDTANUM"+format$("N0:2",JL1)+")")>=JNOL
      If evalue ("[M:SIHV]DDTANUM"+format$("N0:2",JL1)+"("+num$(JNOL-1)+")")<>0
        Assign ("[F:SID]DDTANUM"+"("+num$(JL1-1)+")") With  evalue ("[M:SIHV]DDTANUM"+format$("N0:2",JL1)+"("+num$(JNOL-1)+")")
        Assign ("[F:SID]DDTANOT"+"("+num$(JL1-1)+")") With  evalue ("[M:SIHV]DDTANOT"+format$("N0:2",JL1)+"("+num$(JNOL-1)+")")
      Endif
    Endif
  Next JL1
  #CATUA X3-84760.en

  Rewrite [SID]
  If fstat
    GOK=0 : Call FSTA("SID") From GLOCK
    Break
  Endif
Next

End

#**
#* Return exchange rate based on CURTYP, currency origin, currency destination and
#* transaction date
#*
#* @param CURTYP - corresponds to rate type - local menu 202
#* @param CPY    - X3 Company
#* @param CURDEN - currency destination
#* @param TXNDAT - transaction date used to evaluate exchange info
#* @param EXCRAT - Exchange rate
#* @param EXCEFFDAT - Effective date of the Exchange rate (start date for the exchange rate)
#*!
Subprog SST_CUR(CURTYP, CPY, CURORG, CURDEN, TXNDAT, EXCRAT, EXCEFFDAT)
Value Shortint CURTYP
Value Char CPY(), CURDEN()
Value Date TXNDAT
Variable Decimal EXCRAT
Variable Date EXCEFFDAT
Variable Char CURORG()

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  Read [F:CPY]CPY0 = [L]CPY
  If  !fstat
    [L]CURORG = [F:CPY]ACCCUR
    If  [L]CURORG = [L]CURDEN
      EXCRAT=1
      EXCEFFDAT=[L]TXNDAT
    Else
      If !clalev([F:TCH]) : Local File TABCHANGE [TCH] : Endif
      Filter [F:TCH] Where CHGTYP=[L]CURTYP & [F:TCH]CURDEN=[L]CURDEN & [F:TCH]CUR=[L]CURORG & [F:TCH]CHGSTRDAT<=[L]TXNDAT
      Read [F:TCH]Last
      If  !fstat
        [L]EXCRAT=[F:TCH]CHGRAT
        [L]EXCEFFDAT=[F:TCH]CHGSTRDAT
      Else
        [L]EXCRAT=1
        [L]EXCEFFDAT=[L]TXNDAT
        GERR=1
        GMESSAGE=mess(13,199,1)-[L]CURDEN
      Endif
    Endif
  Else
    GERR=1
    GMESSAGE=mess(132,100,1)-[L]CPY
  Endif
End


