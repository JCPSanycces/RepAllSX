# Retrieve the SSTCOD for the invoicing element from the header if avail
# If not, get from the invoicing element table
#101380.sn
Funprog GET_SFISSTCOD(SFINUM)
Value Integer SFINUM
Local Char    SFISSTCOD(8)
Local Integer SFIIDX, SFIIDXMAX

Case left$(GFONCTION,9)
  When "GESSQH"
    If dim([F:SQH]SFISSTCOD)>0
      SFIIDXMAX = dim([F:SQH]INVDTA)-1
      SFIIDX    = find(SFINUM,[F:SQH]INVDTA(0..SFIIDXMAX))
      If SFIIDX>0 : SFISSTCOD = [F:SQH]SFISSTCOD(SFIIDX-1) : Endif
    Endif
  When "GESSOH"
    If dim([F:SOH]SFISSTCOD)>0
      SFIIDXMAX = dim([F:SOH]INVDTA)-1
      SFIIDX    = find(SFINUM,[F:SOH]INVDTA(0..SFIIDXMAX))
      If SFIIDX>0 : SFISSTCOD = [F:SOH]SFISSTCOD(SFIIDX-1) : Endif
    Endif
  When "GESSDH","FUNAUTDLV"
    If dim([F:SDH]SFISSTCOD)>0
      SFIIDXMAX = dim([F:SDH]INVDTA)-1
      SFIIDX    = find(SFINUM,[F:SDH]INVDTA(0..SFIIDXMAX))
      If SFIIDX>0 : SFISSTCOD = [F:SDH]SFISSTCOD(SFIIDX-1) : Endif
    Endif
  When "GESSIH","FUNAUTINV"
    If dim([F:SIV]SFISSTCOD)>0
      SFIIDXMAX = dim([F:SIV]INVDTA)-1
      SFIIDX    = find(SFINUM,[F:SIV]INVDTA(0..SFIIDXMAX))
      If SFIIDX>0 : SFISSTCOD = [F:SIV]SFISSTCOD(SFIIDX-1) : Endif
    Endif
  When Default
    #If not defined here - just get from the table SFI
    SFISSTCOD = [F:SFI]SSTCOD
Endcase

End SFISSTCOD
#101380.en

