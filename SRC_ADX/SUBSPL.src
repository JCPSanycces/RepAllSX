######################################## Code devise ####################
Subprog AS_CUR(VALEUR)
Variable Char     VALEUR
Local    Integer  NOL
#  si devise deja chargée pas d'init
If VALEUR<>"" : End : Endif
#  si devise dans parametrage : =devise du paramétrage et pas de saisie
If [F:SPC]CUR<>"" : VALEUR=[F:SPC]CUR : mkstat=2
#  si client dans les critères : =devise du client en init.
  Elsif [F:SPC]CRIBPCNUM<>0
     If clalev([F:BPC])<=0  Local File BPCUSTOMER [BPC]  Endif
     CLE=evalue("[M]CRIT"+num$([F:SPC]CRIBPCNUM)+"(nolign-1)")
#     Call LECTURE("BPC",evalue("[M]CRIT"+num$([F:SPC]CRIBPCNUM)+"(nolign-1)"),"") From CONTOBJ
     Read [BPC]BPC0=CLE
     If !fstat : VALEUR=[F:BPC]CUR : Endif
#  sinon devise du site financier actif en init.
       Elsif VALEUR=GLOCALDEV
Endif
End

######################################## Code unité #####################
Subprog AS_UOM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL
#  si unité deja chargée pas d'init
If VALEUR<>"" : End : Endif
#  article dans les critères : =unité de vente en init.
If [F:SPC]CRIITMNUM<>0
 CLE=evalue("[M]CRIT"+num$([F:SPC]CRIITMNUM)+"(nolign-1)")
#Call LECTURE("ITM",evalue("[M]CRIT"+num$([F:SPC]CRIITMNUM)+"(nolign-1)"),"") From CONTOBJ
 Read [ITM]ITM0=CLE
 If !fstat : VALEUR=[F:ITM]SAU : Endif
Endif
End
#---------------------------------------
Subprog C_UOM(VALEUR)
Variable Char    VALEUR()
# Controle uniquement si absence joker *
If VALEUR="*" : End : Endif
Call CONTROLE("TUN","",VALEUR,"",mkstat) From CONTOBJ
End
#---------------------------------------
Subprog S_UOM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TUN"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub AFF From GSAISIE
End

######################################## Quantité maxi ##################
Subprog AS_MAXQTY(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 : End : Endif
If clalev([F:TUN])<=0 : Local File TABUNIT[TUN] : Endif
Read [TUN]TUN0=[M]UOM(nolign-1)
If !fstat
  If [F:TUN]UOMDEC=0 : VALEUR=99999999999     : Endif
  If [F:TUN]UOMDEC=1 : VALEUR=9999999999.9    : Endif
  If [F:TUN]UOMDEC=2 : VALEUR=999999999.99    : Endif
  If [F:TUN]UOMDEC=3 : VALEUR=99999999.999    : Endif
  If [F:TUN]UOMDEC=4 : VALEUR=9999999.9999    : Endif
  If [F:TUN]UOMDEC=5 : VALEUR=999999.99999    : Endif
  If [F:TUN]UOMDEC=6 : VALEUR=99999.999999    : Endif
Endif
End

######################################## Article gratuit ################
Subprog IB_FOCITMREF
Variable Char     VALEUR
GBOUT1=mess(22,198,1)  : # def. bouton article
End
#---------------------------------------
Subprog AS_FOCITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer NOL          : NOL=nolign-1
Local Char    CLEVISU (30) : CLEVISU=num$([M]FOCITMREF(NOL))
GSPLTYP="ITS"
GSPLZON="FOCITMREF" : Gosub VISU_LIB : Raz GSPLZON
End
#---------------------------------------
Subprog AM_FOCITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : Raz [M]FOCUOM(nolign-1) : Raz [M]FOCQTY(nolign-1) : Endif
Affzo FOCUOM(nolign-1), FOCQTY(nolign-1)
If VALEUR="" : Grizo FOCUOM(nolign-1), FOCQTY(nolign-1) : Endif
End

######################################## Unité gratuit ##################
Subprog D_FOCUOM(VALEUR)
Variable Char    VALEUR()
If [M]FOCITMREF(nolign-1)<>""
  Read [ITM]ITM0=[M]FOCITMREF(nolign-1) : #Call LECTURE("ITM",[M]FOCITMREF(nolign-1),"") From CONTOBJ
  If !fstat : VALEUR=[F:ITM]SAU : Endif
Endif
End
#---------------------------------------
Subprog AS_FOCUOM(VALEUR)
Variable Char     VALEUR
If !GIMPORT : GERR=4 : Raz GMESSAGE : Endif #gbn-82702
# --- pour import : ceinture et bretelle
If [M]FOCITMREF(nolign-1)="" : mkstat=2 : Endif
End

#########################################################################
#########################################################################

#------------------------------------------------------------------------
# --- Visu du libellé dans cadre du bas
#------------------------------------------------------------------------
$VISU_LIB

Local Integer ICRIT    : # no de critère
If len(GSPLZON)=5 & mid$(GSPLZON,1,4)="CRIT"
   ICRIT=val(mid$(GSPLZON,5,1))
 Else ICRIT=0
Endif
If ICRIT>0
  GSPLTYP=[F:SPC]FLDTYP(ICRIT-1)
Endif

# FGR 04/02/2010 : X3SUIVI61570 (début)
If ICRIT > 0 Then  # FGR 17/02/2010 : X3SUIVI62676 : ça manquait un peu
  If [F:SPC]FLD(ICRIT-1) = "PJT" and GMODU(13) = 2 Then
    GSPLTYP = "OPP"
  Endif
Endif
# FGR 04/02/2010 : X3SUIVI61570 (fin)

Case GSPLTYP
  When "ITS", "BPC", "BPD", "BPT", "REP", "OPP" : If CLEVISU="" Return Endif  # FGR 04/02/2010 : X3SUIVI61570
  When Default Return
Endcase
Raz [M]AFFLIB
If GSPLTYP= "ITS"
  If clalev([F:ITM])<=0  Local File ITMMASTER [ITM]  Endif
  Read [ITM]ITM0=CLEVISU : #Call LECTURE("ITM",CLEVISU,"") From CONTOBJ
  #If !fstat : [M]AFFLIB=[F:ITM]ITMDES1 : Endif
  If !fstat
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]AFFLIB, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
  Endif
Endif
If GSPLTYP= "BPC" | GSPLTYP="BPD" | GSPLTYP="BPT" | GSPLTYP="REP"
  If clalev([F:BPR])<=0  Local File BPARTNER [BPR]  Endif
  Read [BPR]BPR0=CLEVISU : #Call LECTURE("BPR",CLEVISU,"") From CONTOBJ
  If !fstat : [M]AFFLIB=[F:BPR]BPRNAM : Endif
Endif
# FGR 04/02/2010 : X3SUIVI61570 (début)
If GSPLTYP = "OPP" Then
  #Affaire
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
  Read [OPP]OPP0=CLEVISU
  If !fstat Then
    # 71065 : PJT
    #[M]AFFLIB=[F:OPP]OPPDES
    # 71065 : PJT
  Endif
Endif
# FGR 04/02/2010 : X3SUIVI61570 (fin)
GERR=4 : GMESSAGE=[M]AFFLIB
Return


#------------------------------------------------------------------------
# --- Chargement de cur et uom si dans critères
#------------------------------------------------------------------------
$VAL_DEFAUT
Local Integer ICRIT    : # no de critère
If len(GSPLZON)=5 & mid$(GSPLZON,1,4)="CRIT"
   ICRIT=val(mid$(GSPLZON,5,1))
 Else ICRIT=0
Endif
If ICRIT<>0 & ICRIT=[F:SPC]CRICURNUM : [M]CUR(nolign-1)=VALEUR : Endif
If ICRIT<>0 & ICRIT=[F:SPC]CRIUOMNUM : [M]UOM(nolign-1)=VALEUR : Endif

# FGR 04/02/2010 X3SUIVI61570 (début)
If ICRIT > 0 Then
  If [F:SPC]FLD(ICRIT-1) = "PJT" and GMODU(13) = 2 Then
    Local Char SZMESSAGE(250)
    Local Char SZVALEUR(GLONVCR)
    Local Integer IBRETOUR
    Local Char SZCONTROL(50)

    If GMODU(13) = 2 Then
      If GCTLOPPCOD = 2 Then
        If VALEUR <> "" Then
          #SZVALEUR = toupper(ctrans(VALEUR)) # Note FGR on ne peut pas ici parce qu'on n'a pas le droit de modifier VALEUR
          #                                   # C'est pour ça qu'on ne peut pas utiliser CRMUTIL150.CTRL_CODE_OPP
          SZCONTROL = "***" # Pas de controle du site
          Call VERIFOBJCODE("OPP", SZCONTROL, SZVALEUR, SZMESSAGE, IBRETOUR) From CRMUTIL150
          If IBRETOUR = 0 Then
            GMESSAGE = SZMESSAGE
            mkstat = 1
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
Endif
# FGR 04/02/2010 X3SUIVI61570 (fin)
Return

#------------------------------------------------------------------------
# --- Chargement de cur et uom si client et article des critères sont modifiés
#------------------------------------------------------------------------
$SI_BPCITS
Local Integer ICRIT    : # no de critère
If len(GSPLZON)=5 & mid$(GSPLZON,1,4)="CRIT"
   ICRIT=val(mid$(GSPLZON,5,1))
 Else ICRIT=0
Endif
If ICRIT>0
  If find([F:SPC]FLDTYP(ICRIT-1),"BPR","BPC","BPT")
    Local Char WCUR (GLONCUR)
    If [F:SPC]FLDTYP(ICRIT-1)="BPC"
        If clalev([F:BPC])<=0  Local File BPCUSTOMER [BPC]  Endif
        Read [BPC]BPC0=VALEUR : WCUR=[F:BPC]CUR
    Elsif [F:SPC]FLDTYP(ICRIT-1)="BPT"
        If clalev([F:BPT])<=0  Local File BPCARRIER  [BPT]  Endif : # Bug 73065
        Read [BPT]BPT0=VALEUR : WCUR=[F:BPT]CUR
    Else
        If clalev([F:BPR])<=0  Local File BPARTNER   [BPR]  Endif : # Bug 73065
        Read [BPR]BPR0=VALEUR : WCUR=[F:BPR]CUR
    Endif
    If !fstat
      [M]CUR(nolign-1)=WCUR : Affzo [M]CUR(nolign-1)
      If [F:SPC]CRICURNUM>ICRIT
        Case [F:SPC]CRICURNUM
          When 1 : [M]CRIT1(nolign-1)=WCUR : Affzo [M]CRIT1(nolign-1)
          When 2 : [M]CRIT2(nolign-1)=WCUR : Affzo [M]CRIT2(nolign-1)
          When 3 : [M]CRIT3(nolign-1)=WCUR : Affzo [M]CRIT3(nolign-1)
          When 4 : [M]CRIT4(nolign-1)=WCUR : Affzo [M]CRIT4(nolign-1)
          When 5 : [M]CRIT5(nolign-1)=WCUR : Affzo [M]CRIT5(nolign-1)
        Endcase
      Endif
    Endif
  Endif

  If find([F:SPC]FLDTYP(ICRIT-1),"ITM","ITS")
    Read [ITM]ITM0=VALEUR : #Call LECTURE("ITM",VALEUR,"") From CONTOBJ
    If !fstat
      [M]UOM(nolign-1)=[F:ITM]SAU : Affzo [M]UOM(nolign-1)
      If [F:SPC]CRIUOMNUM>ICRIT
        Case [F:SPC]CRIUOMNUM
          When 1 : [M]CRIT1(nolign-1)=[F:ITM]SAU : Affzo [M]CRIT1(nolign-1)
          When 2 : [M]CRIT2(nolign-1)=[F:ITM]SAU : Affzo [M]CRIT2(nolign-1)
          When 3 : [M]CRIT3(nolign-1)=[F:ITM]SAU : Affzo [M]CRIT3(nolign-1)
          When 4 : [M]CRIT4(nolign-1)=[F:ITM]SAU : Affzo [M]CRIT4(nolign-1)
          When 5 : [M]CRIT5(nolign-1)=[F:ITM]SAU : Affzo [M]CRIT5(nolign-1)
        Endcase
      Endif
    Endif
  Endif
Endif
Return

#------------------------------------------------------------------------
# --- Init Qté mini et montant mini si changement critères
#------------------------------------------------------------------------
$INI_QTYAMT
If [M]MINQTY(nolign-1)<>0 and [M]MINQTY(nolign-1)>[M]MAXQTY(nolign-1)
  [M]MINQTY(nolign-1)=0 : [M]MAXQTY(nolign-1)=0
  Affzo [M]MINQTY(nolign-1), MAXQTY(nolign-1)
Endif
If [M]MINAMT(nolign-1)<>0 and [M]MINAMT(nolign-1)>[M]MAXAMT(nolign-1)
  [M]MINAMT(nolign-1)=0 : [M]MAXAMT(nolign-1)=0
  Affzo [M]MINAMT(nolign-1), MAXAMT(nolign-1)
Endif
Return


#------------------------------------------------------------------------
# --- definition des boutons des champs (critères, devise,unité, qté début)
#------------------------------------------------------------------------
$DEFBOUT_CRIT
Local Integer I, I1, I2, I3, I4, NOL
Local Char    TD_CRIT (3)   : # type de donnée

GBOUT1 = ""              : # pour les tunnels
Raz [M]OBJET
GFONBOD="BOMC"
Case GSPLZON
  When  "CRIT1"     : TD_CRIT=[F:SPC]FLDTYP(0) : I3=0
  When  "CRIT2"     : TD_CRIT=[F:SPC]FLDTYP(1) : I3=1
  When  "CRIT3"     : TD_CRIT=[F:SPC]FLDTYP(2) : I3=2
  When  "CRIT4"     : TD_CRIT=[F:SPC]FLDTYP(3) : I3=3
  When  "CRIT5"     : TD_CRIT=[F:SPC]FLDTYP(4) : I3=4
  When Default
Endcase

# FGR 04/02/2010 : X3SUIVI61570 (début)
If [F:SPC]FLD(I3) = "PJT" and GMODU(13) = 2 Then
  TD_CRIT = "OPP"
Endif
# FGR 04/02/2010 : X3SUIVI61570 (fin)

#--- positionnement globale GBPCNUM pour filtre objet BPD
If dim(GBPCNUM)>0 : Raz GBPCNUM : Endif
If I3>0 & TD_CRIT="BPD"
   I4=find("BPC",[F:SPC]FLDTYP(0..I3-1))
   If I4 : GBPCNUM=evalue("[M]CRIT"+num$(I4)+"(nolign-1)") : Endif
Endif

#--- Bouton1=Tunnel
Case TD_CRIT
  When "ITM", "ITS"  : GBOUT1=mess(22,198,1)  : [M]OBJET="ITM"
  When "BPR", "BPC"  : GBOUT1=mess(72,198,1)  : [M]OBJET="BPC"
  When "BPD"         : GBOUT1=mess(42,191,1)  : [M]OBJET="BPD"
  When "REP"         : GBOUT1=mess(140,198,1) : [M]OBJET="REP"
  When "OPP"         : GBOUT1=mess(274,197,1) : [M]OBJET="OPP"   # FGR 04/02/2010 : X3SUIVI61570
  When Default
Endcase
#---

GBOUT2 = GXPLBOULIB(1)    : # pour critère-1 suivant
GBOUT3 = GXPLBOULIB(2)    : # pour critère-2 suivant
GBOUT4 = GXPLBOULIB(3)    : # pour critère-3 suivant
GBOUT5 = GXPLBOULIB(4)    : # pour critère-4 suivant
GBOUT6 = GXPLBOULIB(5)    : # pour critère-5 suivant
GBOUT7 = GXPLBOULIB(6)    : # pour devise suivante
GBOUT8 = GXPLBOULIB(7)    : # pour unité vente suivante

# Suppression des Boutons 2 à 8 (suivants) ?

If GBOUT2<>""  : # critère-1 + si BPR BPC BPT ITM ITS REP à partir ligne 2
  If !find ([F:SPC]FLDTYP(0),"BPR","BPC","BPT","ITM","ITS","REP") | nolign<2
    Raz GBOUT2
  Endif
Endif

If nolign<4 : Raz GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8 : Endif

If GBOUT3<>""
  NOL=nolign-1 : I1=nolign : I2=nolign
  For I=NOL-1 To 0 Step -1
    If [M]CRIT2(I)<>[M]CRIT2(NOL-1) : I1=I : Break : Endif
  Next I
  If I1<nolign
    For I=I1 To 0 Step -1
      If [M]CRIT2(I)=[M]CRIT2(NOL-1) : I2=I+1 : Break : Endif
    Next I
  Endif
  If I2=nolign : Raz GBOUT3 : Endif
Endif

If GBOUT4<>""
  NOL=nolign-1 : I1=nolign : I2=nolign
  For I=NOL-1 To 0 Step -1
    If [M]CRIT3(I)<>[M]CRIT3(NOL-1) : I1=I : Break : Endif
  Next I
  If I1<nolign
    For I=I1 To 0 Step -1
      If [M]CRIT3(I)=[M]CRIT3(NOL-1) : I2=I+1 : Break : Endif
    Next I
  Endif
  If I2=nolign : Raz GBOUT4 : Endif
Endif

If GBOUT5<>""
  NOL=nolign-1 : I1=nolign : I2=nolign
  For I=NOL-1 To 0 Step -1
    If [M]CRIT4(I)<>[M]CRIT4(NOL-1) : I1=I : Break : Endif
  Next I
  If I1<nolign
    For I=I1 To 0 Step -1
      If [M]CRIT4(I)=[M]CRIT4(NOL-1) : I2=I+1 : Break : Endif
    Next I
  Endif
  If I2=nolign : Raz GBOUT5 : Endif
Endif

If GBOUT6<>""
  NOL=nolign-1 : I1=nolign : I2=nolign
  For I=NOL-1 To 0 Step -1
    If [M]CRIT5(I)<>[M]CRIT5(NOL-1) : I1=I : Break : Endif
  Next I
  If I1<nolign
    For I=I1 To 0 Step -1
      If [M]CRIT5(I)=[M]CRIT5(NOL-1) : I2=I+1 : Break : Endif
    Next I
  Endif
  If I2=nolign : Raz GBOUT6 : Endif
Endif

If GBOUT7<>""
  NOL=nolign-1 : I1=nolign : I2=nolign
  For I=NOL-1 To 0 Step -1
    If [M]CUR(I)<>[M]CUR(NOL-1) : I1=I : Break : Endif
  Next I
  If I1<nolign
    For I=I1 To 0 Step -1
      If [M]CUR(I)=[M]CUR(NOL-1) : I2=I+1 : Break : Endif
    Next I
  Endif
  If I2=nolign : Raz GBOUT7 : Endif
Endif

If GBOUT8<>""
  NOL=nolign-1 : I1=nolign : I2=nolign
  For I=NOL-1 To 0 Step -1
    If [M]UOM(I)<>[M]UOM(NOL-1) : I1=I : Break : Endif
  Next I
  If I1<nolign
    For I=I1 To 0 Step -1
      If [M]UOM(I)=[M]UOM(NOL-1) : I2=I+1 : Break : Endif
    Next I
  Endif
  If I2=nolign : Raz GBOUT8 : Endif
Endif

Return



#------------------------------------------------------------------------
# --- Bouton Critère-1 Suivant
#------------------------------------------------------------------------
$CRIT1_SUIVANT
# uniquement si critère alpha et certains fihiers
If nolign<2 : Return : Endif
Case [F:SPC]FLDTYP(0)
  When "BPR", "BPC"           : Gosub BPC_SUIVANT
  When "BPT"                  : Gosub BPT_SUIVANT
  When "ITM", "ITS"           : Gosub ITS_SUIVANT
  When "REP"                  : Gosub REP_SUIVANT
  When Default
Endcase
Return

$BPC_SUIVANT
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
Read [BPC]BPC0>[M]CRIT1(nolign-2)     : # Nota : pas de lecture client par societe
If !fstat
  [M]CRIT1(nolign-1)=[F:BPC]BPCNUM
  If GSPLZON="CRIT1" : VALEUR=[M]CRIT1(nolign-1) : Endif
  Affzo [M]CRIT1(nolign-1)
  mkstat=99
Endif
Return

$BPT_SUIVANT
If clalev([F:BPT])=0 : Local File BPCARRIER  [BPT] : Endif
Read [BPT]BPT0>[M]CRIT1(nolign-2)
If !fstat
  [M]CRIT1(nolign-1)=[F:BPT]BPTNUM
  If GSPLZON="CRIT1" : VALEUR=[M]CRIT1(nolign-1) : Endif
  Affzo [M]CRIT1(nolign-1)
  mkstat=99
Endif
Return

$ITS_SUIVANT
If clalev([F:ITS])=0 : Local File ITMSALES   [ITS] : Endif
Read [ITS]ITS0>[M]CRIT1(nolign-2)      : # Nota : pas de lecture article par societe
If !fstat
  [M]CRIT1(nolign-1)=[F:ITS]ITMREF
  If GSPLZON="CRIT1" : VALEUR=[M]CRIT1(nolign-1) : Endif
  Affzo [M]CRIT1(nolign-1)
  mkstat=99
Endif
Return

$REP_SUIVANT
If clalev([F:REP])=0 : Local File SALESREP   [REP] : Endif
Read [REP]REP0>[M]CRIT1(nolign-2)
If !fstat
  [M]CRIT1(nolign-1)=[F:REP]REPNUM
  If GSPLZON="CRIT1" : VALEUR=[M]CRIT1(nolign-1) : Endif
  Affzo [M]CRIT1(nolign-1)
  mkstat=99
Endif
Return


#------------------------------------------------------------------------
# --- Bouton Critère-2 Suivant
#------------------------------------------------------------------------
$CRIT2_SUIVANT
Local Integer I, I1, I2, NOL
If nolign<4 : Return : Endif
NOL=nolign-1
For I=NOL-1 To 0 Step -1 : # on remonte pour retrouver le prédédent différent
  I1=nolign
  If [M]CRIT2(I)<>[M]CRIT2(NOL-1) : I1=I : Break : Endif
Next I
If I1<nolign             : # on a trouve un précédent différent
  For I=I1 To 0 Step -1  : # on remonte maintenant pour trouver le même
    I2=nolign
    If [M]CRIT2(I)=[M]CRIT2(NOL-1) : I2=I+1 : Break : Endif
  Next I
  If I2<nolign
    [M]CRIT2(NOL)=[M]CRIT2(I2)
    Affzo [M]CRIT2(NOL)
  Endif
Endif
Return


