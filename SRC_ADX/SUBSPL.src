#<AdxTL>@(#)10.0.0.0 $Revision$

GFLTPLI="JLESS"
Call OBJET("SPL",GBIDC1,GFLTPLI) From GOBJET
End
#########################################################################
$ACTION
# Call MESSAGE("Action:" + ACTION) From GESECRAN
Case ACTION

 When "DEFTRANS"   : Gosub DEFTRANS   : # ts
 When "VARIANTE"   : Gosub VARIANTE   : # ts
 When "SETTRANS"   : Gosub SETTRANS   : # ts
 When "OUVRE"      : Gosub OUVRE      : # initialisations
 When "DEFLIG"     : Gosub DEFLIG
 When "SETBOUT"    : Gosub SETBOUT
 When "FILTRE"     : Gosub FILTRE     : # eb 03.02.98 depuis art. ou client
 When "FILGAUCHE"  : Gosub FILTRE     : # jl 29.09.99
 When "RAZCRE"     : Gosub RAZCRE
 When "RAZDUP"     : Gosub RAZCRE     : # sr 20.08.98 pb depuis art,client,cdes
 When "VERIF_CRE"  : Gosub VERIF
 When "VERIF_MOD"  : Gosub VERIF
 When "INICRE"     : Gosub INICRE
 When "INICRE_LIG" : Gosub INICM_LIG  : # concaténation des critères
 When "CREATION"   : Gosub CREATION
 When "APRES_CRE"  : Gosub APRES_CRE
 When "APRES_MOD"  : Gosub APRES_MOD
 When "INIMOD"     : Gosub INIMOD
 When "INIMOD_LIG" : Gosub INICM_LIG  : # concaténation des critères
 When "MODIF"      : Gosub MODIF
 When "LIENS"      : Gosub LIENS      : # chgt des lignes de la fiche
 When "LIENS_LIG"  : Gosub LIENS_LIG  : # éclatement des critères
 When "ANNULE"     : Gosub ANNULE
 When "AV_IMPRIME" : #OK=0 : Gosub COP_ECRAN
 When "FERME"      : Gosub FERME
 When Default
Endcase
Return

#########################################################################
######################### ACTIONS  GOBJET ###############################
#########################################################################
#------------------------------------------------------------------------
$SETBOUT
#--- pas de changement de clé, pas de menu transaction dans la ToolBar
Call VIREBOUT(CHAINE,"HT") From GOBJET
#--- si appel depuis gestion tarifs achats (inter-sociétés)
#    pas de saisie des tarifs
If find(GFONC1,"GESPPL","FUNPPSI")
   Call VIREBOUT(CHAINE,"CMADH") From GOBJET
Endif
Return

#------------------------------------------------------------------------
$DEFTRANS                                  : #ts

If GIMPORT & GFLAG=""
  If clalev ([F:SPC])<=0 : Local File SPRICCONF [SPC] : Endif
  Read [SPC] First
  GFLTPLI= [F:SPC]PLI
  GFLAG=   [F:SPC]PLI
Endif
Local Char WVARIBOI                        : #ts
# Issue 110740 - 2015-09-07 by CPO : Using deferred deletion, if user did not go on the same pricelist, it don't work
#--For the ADELETE fonction, the GFONC1 is "", go for the SAVCLE2
#If GFONC1<>"GESSPL"                        : #ts
If GFONC1<>"GESSPL" and GFONC1<>""
# End issue 110740
   GFLAG=GFLTPLI                           : #ts
Elsif dim(SAVCLE2)>0 & SAVCLE2<>"" : # Appel depuis pièce jointe d'un workflow
   GFLAG=SAVCLE2
Endif                                      : #ts
Return                                     : #ts

#------------------------------------------------------------------------
$VARIANTE                                  : #ts
If [F:AWI]TRN="" OK=0 Endif                : #ts
Return                                     : #ts

#------------------------------------------------------------------------
$SETTRANS                                  : #ts
If GFONC1="GESSPL"                         : #ts
   GFLTPLI=GFLAG                           : #ts
Endif                                      : #ts
Return                                     : #ts

#------------------------------------------------------------------------
$OUVRE
#----- Retrouver le dernier lu du code tarif concerné -----#
If GLECOBJ=2 & GNBDERNIER>0 & GFLTPLI<>"" & clalev([F:ALS])
  If CLE2(0)<>GFLTPLI
    Filter [ALS] Where USR=GUSER & OBJ="SPL" & pat(CLES,"*~"+GFLTPLI+"~*")
    Read [ALS] ALS0 Last
    Filter [ALS]
    If !fstat
      CLE1   =left$([F:ALS]CLES,instr(1,[F:ALS]CLES,"~")-1)
      CLE2(0)=GFLTPLI
    Else
      Raz CLE2
    Endif
  Endif
Endif
#----- Nota : Le GIMPORT n'est pas positionné avec l'option "Test" -----#
If (GIMPORT & GFLAG="") | (dim([M:IMP2]TEST)>0 & [M:IMP2]TEST=2 & GFLAG="")
  If clalev([M:SPLW])<=0 : Local Mask SPLW     [SPLW] : Endif
  If clalev ([F:SPC])<=0 : Local File SPRICCONF [SPC] : Endif
  Read [SPC] First
  GFLTPLI= [F:SPC]PLI
  GFLAG=   [F:SPC]PLI
Endif

If clalev([F:TUN])<=0 : Local File TABUNIT  [TUN] : Endif
If clalev([F:TCU])<=0 : Local File TABCUR   [TCU] : Endif
If clalev([F:SPR])<=0 : Local File SPREASON [SPR] : Endif
If clalev([F:CAC])<=0 : Local File GACCCODE [CAC] : Endif : # 95699 : Nécessaire pour permettre la saisie des codes comptables

#----- Sauvegarde des variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
Gosub DECLARE From TABLEAUX
If dim(GFLTPLI)<0
  GERR=1 : GMESSAGE=mess(179,199,1)
# Pas de tarif selectionné ou écran de saisie de tarif inexistant
  OK=0
  Return
Endif

Local  Char FLDTYPEXT (3)   : # Type du critère
Local  Char FLDTYPINT (3)   : # Type interne du critère

Global Char GSPLTYP (3)     : # pour appel des s/p
Global Char GSPLZON (20)    : # pour appel des s/p

#--- Lecture du paramétrage tarifs
Read [F:SPC]SPC0=GFLTPLI
If fstat
    If GFLTPLI<>""
      GERR=1 : GMESSAGE=mess(179,199,1)
#     pas de tarif selectionné ou écran de saisie de tarif inexistant
      OK=0
    Endif
  Return
Endif
#--- Lecture de la structure des tarifs
Read [F:PRS]PRS0=1;[F:SPC]PLISTC
If fstat : OK=0 : Return : Endif
Call COLREM("C",1,[F:SPC]PLISTC) From TRTPRICE

#--- Lecture du motif du tarif
If [F:SPC]PRIREN<>0
  Read [SPR]SPR0=[F:SPC]PRIREN : #Call LECTURE ("SPR",num$([F:SPC]PRIREN),"") From CONTOBJ
Endif

#--- Alimentation du compteur fiche tarif -----#
If !clalev([F:TCA])  Local File TABCOUAFF  [TCA] Endif
Local Char SAV_GSOCIETE(GLONCPY)
SAV_GSOCIETE=GSOCIETE
#--CPO 108088 Paramétrage d'un critère sur table diverse
#--Le CONTADI appelle le CONTOBJ qui va faire un contrôle sur GCURLEG si ce dernier est renseigné
#--Il ne faut initialiser le GCURLEG que dans le cas d'un dossier mono-leg
#GCURLEG = GDOSLEG # Gbn-Fq100110
If func AFNC.ACTIV("LEG")=0
  GCURLEG = GDOSLEG(1)
Endif
#--/
Raz GSOCIETE : Call LECTCA(5,OK) From SUBTCA
GSOCIETE=SAV_GSOCIETE
If fstat | !OK
  GERR=1 : GMESSAGE=mess(64,199,1) : OK=0 : Return
Endif
GMANCOU=[F:TCA]MANCOU(8)
GCODNUM=[F:TCA]CODNUM(8)

Default Mask [SPLW]
Actzo [SPLW]1-99
[M]PLI=GFLTPLI
[M]PIO=[F:SPC]PIO
[M]PLIENAFLG=[F:SPC]PLIENAFLG

Gosub LES_BOUTONS
Return

$LES_BOUTONS
# --- Constitution des libelles boutons champs (pour alimentation suivant)
#     critère, devise, unité, borne qté suivants
Local  Integer LENUMBLOC              : # no. du bloc ayant les critères, dev, etc...
Local  Decimal LENOZONE
Global Char    GXPLBOULIB (20) (1..9)
Global Char    GXPLBOUZC  (20) (1..9)
Global Char    GXPLBOUZS  (20) (1..9)

Raz GXPLBOULIB, GXPLBOUZC, GXPLBOUZS
GXPLBOUZC(1)="CRIT1" : GXPLBOUZC(2)="CRIT2" : GXPLBOUZC(3)="CRIT3"
GXPLBOUZC(4)="CRIT4" : GXPLBOUZC(5)="CRIT5" : GXPLBOUZC(6)="CUR"
GXPLBOUZC(7)="UOM"   : GXPLBOUZC(8)=""

If clalev ([F:AMZ])<=0 : Local File AMSKZON [AMZ] : Endif
# les critères 1 à 5 suivants
If [F:SPC]ABB(0)<>""
  WCRIDES=[F:SPC]CRIDES(0)
  Call CHARCRIDES([F:SPC]FIL(0),[F:SPC]FLD(0),WCRIDES) From TRTPARAM
  GXPLBOULIB(1)=WCRIDES-"+"
Endif
If [F:SPC]ABB(1)<>""
  WCRIDES=[F:SPC]CRIDES(1)
  Call CHARCRIDES([F:SPC]FIL(1),[F:SPC]FLD(1),WCRIDES) From TRTPARAM
  GXPLBOULIB(2)=WCRIDES-"+"
Endif
If [F:SPC]ABB(2)<>""
  WCRIDES=[F:SPC]CRIDES(2)
  Call CHARCRIDES([F:SPC]FIL(2),[F:SPC]FLD(2),WCRIDES) From TRTPARAM
  GXPLBOULIB(3)=WCRIDES-"+"
Endif
If [F:SPC]ABB(3)<>""
  WCRIDES=[F:SPC]CRIDES(3)
  Call CHARCRIDES([F:SPC]FIL(3),[F:SPC]FLD(3),WCRIDES) From TRTPARAM
  GXPLBOULIB(4)=WCRIDES-"+"
Endif
If [F:SPC]ABB(4)<>""
  WCRIDES=[F:SPC]CRIDES(4)
  Call CHARCRIDES([F:SPC]FIL(4),[F:SPC]FLD(4),WCRIDES) From TRTPARAM
  GXPLBOULIB(5)=WCRIDES-"+"
Endif
# la devise suivante
Read [AMZ]CODE="WB1"+num$(GFLTPLI)+"1"; "CUR"
If !fstat
  If [F:AMZ]SAIAFF<>3 : GXPLBOULIB(6)=mess(18,105,1)-"+" : Endif
  LENUMBLOC = [F:AMZ]NUMBLOC
Endif
# l'unité vente suivante
Read [AMZ]CODE="WB1"+num$(GFLTPLI)+"1"; "UOM"
If !fstat
  If [F:AMZ]SAIAFF<>3 : GXPLBOULIB(7)=mess(6,191,1)-"+" : Endif
Endif
# la borne suivante
Case [F:SPC]PRIQTYFLG
  When 2,3   : GXPLBOUZC(8)="MINQTY"
  When 4     : GXPLBOUZC(8)="MINAMT"
  When Default
Endcase
# Recherche de la zone de saisie suivante (variable suivant le paramétrage tarif
For I=1 To 8
  Raz LENOZONE
  Filter [AMZ]
  Read [AMZ]CODE="WB1"+num$(GFLTPLI)+"1"; GXPLBOUZC(I)
  If !fstat
    LENOZONE=[F:AMZ]NOZONE                           : # suivant la zone active
  Endif
  Filter [AMZ]Where CODMSK="WB1"+num$(GFLTPLI)+"1"
&                 & NUMBLOC=LENUMBLOC
&                 & SAIAFF=1
&                 & NOZONE>LENOZONE
&                   Order By NOZONE Asc
  Read First
  If !fstat
    GXPLBOUZS(I)=[F:AMZ]CODZON
  Endif
Next I

Filter [AMZ]

Return

$ARRET
GERR=1 : GMESSAGE=mess(179,199,1)
# pas de tarif selectionné ou écran de saisie de tarif inexistant
OK=0
Resume

#------------------------------------------------------------------------
$FILTRE
Default File [SPF]
If   GFLTPLI <> ""
     FILTSUP =  "PLI = GFLTPLI"
Endif
Return

#------------------------------------------------------------------------
$RAZCRE
If !GIMPORT : GERR=4 : Raz GMESSAGE : Endif #gbn-82702
##VPO 25/05/09 49087 pb en duplication
##Raz [M]PLICRD
Read [SPC] SPC0=GFLAG
[M]PLI      = [F:SPC]PLI
[M]PIO      = [F:SPC]PIO
[M]PLIENAFLG= [F:SPC]PLIENAFLG
[M]PLIPRITYP= [F:SPC]PRITYP
If [F:SPC]PRIREN<>0
  Read [SPR]SPR0=[F:SPC]PRIREN : #Call LECTURE ("SPR",num$([F:SPC]PRIREN),"") From CONTOBJ
  If !fstat
    [M]X1PRIREN=[F:SPR]PRIREN
#    [M]X2PRIREN=[F:SPR]DES
    Call GET_ATEXTRA("SPREASON","DESAXX",GLANGUE,[M]X2PRIREN) From TRTX3TEX
  Endif
Endif
Diszo PLI, ZPLI, PIO, PLIENAFLG, PLIPRITYP, X1PRIREN, X2PRIREN
If !GIMPORT Affzo [M]1-99 : Endif
Return

#------------------------------------------------------------------------
$VERIF
If [M]NBLIG=0
  GERR=1 : GMESSAGE=mess(61,199,1)
# pas de ligne saisie : mise à jour impossible
  OK=0
Endif
Return

#------------------------------------------------------------------------
$INICRE
[F:SPF]LINNBR=[M]NBLIG
Local Integer STAT
Local Char    SITE                     : # site : permet egalement de retrouver la societe
Local Char    COMPLEMENT (15)
If GMANCOU<>2 | (GMANCOU=2 & vireblc([M:SPLW]PLICRD,2)="")
  If [F:SPF]PLICRDIDX<>"" COMPLEMENT=[F:SPF]PLICRDIDX
    Else                  COMPLEMENT=[F:SPF]PLI
  Endif
  SITE=GFCYDEF(5)                      : # site de vente par défaut
  Call NUMERO(GCODNUM,SITE,[F:SPF]PLISTRDAT,COMPLEMENT,[F:SPF]PLICRD,STAT) From SUBANM
  If STAT=0
    [F:SPF]PLICRD=vireblc([F:SPF]PLICRD,4)
    [M]PLICRD=[F:SPF]PLICRD
    Affzo [M]PLICRD
  Else
    GERR=1 : GMESSAGE=mess(60,199,1)
# problème lors de la récupération du compteur
    GOK=0
  Endif
Endif
Return

#------------------------------------------------------------------------
$INIMOD
[F:SPF]LINNBR=[M]NBLIG
Return

#------------------------------------------------------------------------
$INICM_LIG
Local Integer TOTMAX
TOTMAX=mod(type([F:SPL]PLICRI)-15,256)  : # -10 (standard) -5 (les séparateurs)
[F:SPL]PLI=[F:SPF]PLI
[F:SPL]PLICRD=[F:SPF]PLICRD
[F:SPL]PLISTRDAT=[F:SPF]PLISTRDAT
[F:SPL]PLIENDDAT=[F:SPF]PLIENDDAT
# --- concaténation critères et critéres inverses ( 2 premiers)
Local Char WCRIT (50) (6)
Raz [F:SPL]PLICRI
Raz [F:SPL]PLICRI1, [F:SPL]PLICRI2, [F:SPL]PLICRI3, [F:SPL]PLICRI4, [F:SPL]PLICRI5
Raz WCRIT
# --- si la somme des critères dépasse le max autorisé, raz des critères

If sum(len(num$([M]CRIT1(nolign-1))),
&      len(num$([M]CRIT2(nolign-1))),
&      len(num$([M]CRIT3(nolign-1))),
&      len(num$([M]CRIT4(nolign-1))),
&      len(num$([M]CRIT5(nolign-1)))) > TOTMAX
  Raz [M]CRIT1(nolign-1),[M]CRIT2(nolign-1),[M]CRIT3(nolign-1),[M]CRIT4(nolign-1),[M]CRIT5(nolign-1)
Endif

For RG=1 To 5
 FLDTYPEXT=[F:SPC]FLDTYP(RG-1) : FLDTYPINT=FLDTYPEXT
 Onerrgo ERR_INICM
 Gosub TYPE_CRITERES From = "WBT"+GFLTPLI
 Onerrgo

# Case [F:SPC]FLDTYP(RG-1)
 Case FLDTYPINT
  When "C", "L", "DCB", "M" :
   WCRIT (RG) = num$(evalue("[M]CRIT"+num$(RG)+"("+num$(nolign-1)+")"))+"~"
  When Default :
   WCRIT(RG)=evalue("[M]CRIT"+num$(RG)+"("+num$(nolign-1)+")")+"~"
 Endcase
Next RG
[F:SPL]PLICRI=WCRIT(1)+WCRIT(2)+WCRIT(3)+WCRIT(4)+WCRIT(5)
If len(WCRIT(1))>1 : [F:SPL]PLICRI1=mid$(WCRIT(1),1,(len(WCRIT(1))-1)) : Endif
If len(WCRIT(2))>1 : [F:SPL]PLICRI2=mid$(WCRIT(2),1,(len(WCRIT(2))-1)) : Endif
If len(WCRIT(3))>1 : [F:SPL]PLICRI3=mid$(WCRIT(3),1,(len(WCRIT(3))-1)) : Endif
If len(WCRIT(4))>1 : [F:SPL]PLICRI4=mid$(WCRIT(4),1,(len(WCRIT(4))-1)) : Endif
If len(WCRIT(5))>1 : [F:SPL]PLICRI5=mid$(WCRIT(5),1,(len(WCRIT(5))-1)) : Endif
For RG=1 To 9
 [F:SPL]DCGVAL(RG-1)=evalue("XFRAREM"+num$(RG)+"(nolign-1)")
Next RG
Return
# --- si tarif composant garnir la zone composant avec le critère
[F:SPL]CPNITMREF=""
If [F:SPC]PLITYP=4
 If [F:SPC]CRIITMNUM<>0
  [F:SPL]CPNITMREF=evalue("[M]CRIT"+num$(CRIITMNUM)+"("+num$(nolign-1)+")")
 Endif
Endif
#
Return

$ERR_INICM
Resume

#------------------------------------------------------------------------
$CREATION
Gosub CREATION From TABLEAUX
If GOK<1 : Return : Endif
Return

#------------------------------------------------------------------------
$APRES_CRE
Gosub LIENS From TABLEAUX
Return

#------------------------------------------------------------------------
$APRES_MOD
Gosub LIENS From TABLEAUX
Return

#------------------------------------------------------------------------
$MODIF
Gosub MODIF From TABLEAUX
If GOK<1 : Return : Endif
Return

#------------------------------------------------------------------------
$LIENS
If !GIMPORT : GERR=4 : Raz GMESSAGE : Endif #gbn-82702
# lecture des lignes
Gosub LIENS From TABLEAUX
If [F:SPC]PLI<>GFLAG
  Read [SPC] SPC0=GFLAG : If fstat  Raz [F:SPC] : Endif
Endif
[M]PLI       = [F:SPC]PLI
[M]PIO       = [F:SPC]PIO
[M]PLIENAFLG = [F:SPC]PLIENAFLG
[M]PLIPRITYP = [F:SPC]PRITYP
If [F:SPC]PRIREN<>0
  Read [SPR]SPR0=[F:SPC]PRIREN : #Call LECTURE ("SPR",num$([F:SPC]PRIREN),"") From CONTOBJ
  If !fstat
    [M]X1PRIREN=[F:SPR]PRIREN
#    [M]X2PRIREN=[F:SPR]DES
    Call GET_ATEXTRA("SPREASON","DESAXX",GLANGUE,[M]X2PRIREN) From TRTX3TEX
  Endif
Endif
Diszo PLI, ZPLI, PIO, PLIENAFLG, PLIPRITYP, X1PRIREN, X2PRIREN
Return

#------------------------------------------------------------------------
$LIENS_LIG
# éclatement des critères
MANIP=[F:SPL]PLICRI
For RG=1 To dim([F:SPC]FLD)
 JK=instr(1,MANIP,"~")
 If JK
  FLDTYPEXT=[F:SPC]FLDTYP(RG-1) : FLDTYPINT=FLDTYPEXT
  Onerrgo ERR_LIENS
  Gosub TYPE_CRITERES From = "WBT"+GFLTPLI
  Onerrgo
#  Case [F:SPC]FLDTYP(RG-1)
  Case FLDTYPINT
   When "C","L","DCB","M","SFI","RAT","COE","WEI"
    Assign "[M]CRIT"+num$(RG)+"(nolign-1)" With val(left$(MANIP,JK-1))
   When Default :
    Assign "[M]CRIT"+num$(RG)+"(nolign-1)" With left$(MANIP,JK-1)
  Endcase
  MANIP=(right$(MANIP,JK+1))
 Endif
Next RG
For RG=1 To 9
 Assign "[M]XFRAREM"+num$(RG)+"(nolign-1)" With [F:SPL]DCGVAL(RG-1)
Next RG
Return

$ERR_LIENS
Resume

#------------------------------------------------------------------------
$DEFLIG
Default File [SPL]
Default Mask [SPLW]
CRIT = 'PLI = "'+ [M]PLI+'" & PLICRD = "' + [M]PLICRD + '"'
FICLIG = "SPRICLIST" : ABLIG = "SPL"
ZONLIG = "PLILIN"
Return

#------------------------------------------------------------------------
$ANNULE
Gosub ANNULE From TABLEAUX
If GOK<1 : Return : Endif
Return

#------------------------------------------------------------------------
# l'onglet etat de l'objet doit etre renseigne
$COP_ECRAN
Call PRTSCR("WB1"+num$(GFLTPLI)+"1","SPLW","",0,0) From ATRTX3
Return

#------------------------------------------------------------------------
$FERME
If !GIMPORT : GERR=4 : Raz GMESSAGE : Endif #gbn-82702
If GFONC1<>"GESSPL"                                           : #ts
   Close Mask [SPLW]
   OK=0
Else                                                          : #ts
   Raz GFONC1                                                 : #ts
Endif                                                         : #ts
#----- Restitution des variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
Call IMPSCR From ATRTX3
Return

#########################################################################
########## Masque SPLW ##################################################
#########################################################################

######################################## code tarif #####################
Subprog D_PLI(VALEUR)
Variable Char    VALEUR()
VALEUR=[F:SPC]PLI : Diszo [M:SPLW]PLI
End

######################################## fiche tarif ####################
Subprog AS_PLICRD(VALEUR)
Variable Char     VALEUR
#  saisie si compteur manuel uniquement
If GREP = "C" | GREP= "D"
  If GMANCOU = 1 : mkstat = 2 : Endif
Elsif [M]PLI=""
  If [F:SPC]PLI<>GFLAG
    Read [SPC] SPC0=GFLAG : If fstat  Raz [F:SPC] : Endif
  Endif
  [M]PLI = [F:SPC]PLI
  [M]PLI      = [F:SPC]PLI
  [M]PIO      = [F:SPC]PIO
  [M]PLIENAFLG= [F:SPC]PLIENAFLG
  [M]PLIPRITYP= [F:SPC]PRITYP
  If [F:SPC]PRIREN<>0
     Read [SPR]SPR0=[F:SPC]PRIREN : #Call LECTURE ("SPR",num$([F:SPC]PRIREN),"") From CONTOBJ
     If !fstat
        [M]X1PRIREN=[F:SPR]PRIREN
#        [M]X2PRIREN=[F:SPR]DES
        Call GET_ATEXTRA("SPREASON","DESAXX",GLANGUE,[M]X2PRIREN) From TRTX3TEX
     Endif
  Endif
  Affzo [M]
Endif
End

#---------------------------------------
Subprog C_PLICRD(VALEUR)
Variable Char    VALEUR()
If GREP <> "C" & GREP <> "D"
  If [M]PLICRD <> ""
    Look [F:SPF]SPF0 = [M]PLI; [M]PLICRD
    If fstat
      Look [F:SPF]SPF0 = [M]PLI; VALEUR
#     il n'y avait pas d'enreg. en ligne et la clé saisie n'existe pas --> création interdite
      If fstat
        GERR=1 : GMESSAGE=mess(178,199,1)
        mkstat=2
      Endif
    Endif
  Else
    Look [F:SPF]SPF0 = [M]PLI; VALEUR
#   il n'y avait pas d'enreg. en ligne et la clé saisie n'existe pas --> création interdite
    If fstat
      GERR=1 : GMESSAGE=mess(178,199,1)
      mkstat=2
    Endif
  Endif
Endif
End

######################################## date début validité ############
Subprog AM_PLISTRDAT(VALEUR)
Variable Date     VALEUR
For I=0 To NBLIG-1 : [M]UPDFLG(I)=1 : Next I
End

######################################## date fin validité ##############
Subprog AM_PLIENDDAT(VALEUR)
Variable Date     VALEUR
For I=0 To NBLIG-1 : [M]UPDFLG(I)=1 : Next I
End

######################################## Bas Tableau ####################
Subprog AVANT_NBLIG
Local Integer NOL : NOL=nolign-1

If !GIMPORT : GERR=4 : Raz GMESSAGE : Endif  #gbn-82702

#--- Test nouvelle ligne (init)
If status=73 or status=82
  If NOL>0
    [M:SPLW]CRIT1(NOL)     =[M:SPLW]CRIT1(NOL-1)
    [M:SPLW]CRIT2(NOL)     =[M:SPLW]CRIT2(NOL-1)
    [M:SPLW]CRIT3(NOL)     =[M:SPLW]CRIT3(NOL-1)
    [M:SPLW]CRIT4(NOL)     =[M:SPLW]CRIT4(NOL-1)
    [M:SPLW]CRIT5(NOL)     =[M:SPLW]CRIT5(NOL-1)
    [M:SPLW]CPNITMREF(NOL) =[M:SPLW]CPNITMREF(NOL-1)
    [M:SPLW]CUR(NOL)       =[M:SPLW]CUR(NOL-1)
    [M:SPLW]UOM(NOL)       =[M:SPLW]UOM(NOL-1)
    Case [F:SPC]PRIQTYFLG
      When 2,3 : Gosub MINQTY_SUIVANT
      When 4   : Gosub MINAMT_SUIVANT
    Endcase
    Affzo [M:SPLW]CRIT1(NOL), CRIT2(NOL), CRIT3(NOL), CRIT4(NOL), CRIT5(NOL),
&            CPNITMREF(NOL), CUR(NOL), UOM(NOL), MINQTY(NOL), MINAMT(NOL)

  Endif
  [M]COMCOE(NOL)    =1

Endif
End

$MINQTY_SUIVANT
If clalev([F:TUN])<=0 : Local File TABUNIT[TUN] : Endif
Read [TUN]TUN0=[M:SPLW]UOM(NOL)
If !fstat
  If [F:TUN]UOMDEC=0 : [M:SPLW]MINQTY(NOL)=[M:SPLW]MAXQTY(NOL-1)+1        : Endif
  If [F:TUN]UOMDEC=1 : [M:SPLW]MINQTY(NOL)=[M:SPLW]MAXQTY(NOL-1)+0.1      : Endif
  If [F:TUN]UOMDEC=2 : [M:SPLW]MINQTY(NOL)=[M:SPLW]MAXQTY(NOL-1)+0.01     : Endif
  If [F:TUN]UOMDEC=3 : [M:SPLW]MINQTY(NOL)=[M:SPLW]MAXQTY(NOL-1)+0.001    : Endif
  If [F:TUN]UOMDEC=4 : [M:SPLW]MINQTY(NOL)=[M:SPLW]MAXQTY(NOL-1)+0.0001   : Endif
  If [F:TUN]UOMDEC=5 : [M:SPLW]MINQTY(NOL)=[M:SPLW]MAXQTY(NOL-1)+0.00001  : Endif
  If [F:TUN]UOMDEC=6 : [M:SPLW]MINQTY(NOL)=[M:SPLW]MAXQTY(NOL-1)+0.000001 : Endif
Endif
Return

$MINAMT_SUIVANT
If clalev([F:TCU])<=0 : Local File TABCUR [TCU] : Endif
Read [TCU]TCU0=[M:SPLW]CUR(NOL)
If !fstat
  [M:SPLW]MINAMT(NOL)=[M:SPLW]MAXAMT(NOL-1)+[F:TCU]CURRND
Endif
Return

#---------------------------------------
Subprog APRES_NBLIG
Local Integer OK
Local Decimal TOTLIG
# --- si saisie d'une ligne sans valeur, message d'avertissement
If find(status,1,71,92,93) : # Return, Tab fin ligne, Enregistrer ou Créer
   If dim([M]PRI)>0       : TOTLIG += [M]PRI(nolign-1)       : Endif
   If dim([M]XFRAREM1)>0  : TOTLIG += [M]XFRAREM1(nolign-1)  : Endif
   If dim([M]XFRAREM2)>0  : TOTLIG += [M]XFRAREM2(nolign-1)  : Endif
   If dim([M]XFRAREM3)>0  : TOTLIG += [M]XFRAREM3(nolign-1)  : Endif
   If dim([M]XFRAREM4)>0  : TOTLIG += [M]XFRAREM4(nolign-1)  : Endif
   If dim([M]XFRAREM5)>0  : TOTLIG += [M]XFRAREM5(nolign-1)  : Endif
   If dim([M]XFRAREM6)>0  : TOTLIG += [M]XFRAREM6(nolign-1)  : Endif
   If dim([M]XFRAREM7)>0  : TOTLIG += [M]XFRAREM7(nolign-1)  : Endif
   If dim([M]XFRAREM8)>0  : TOTLIG += [M]XFRAREM8(nolign-1)  : Endif
   If dim([M]XFRAREM9)>0  : TOTLIG += [M]XFRAREM9(nolign-1)  : Endif
   If dim([M]FOCQTY)>0    : TOTLIG += [M]FOCQTY(nolign-1)    : Endif
   If dim([M]COMCOE)>0    : TOTLIG += [M]COMCOE(nolign-1)    : Endif
   If TOTLIG=0 & [F:SPC]PRIPRO<>5
      Call MESSAGE (mess(7,111,1)) From GESECRAN
   Endif
Endif
# --- si saisie d'une ligne critères identiques,  message d'avertissement
If find(status,1,71,92,93) : # Return, Tab fin ligne, Enregistrer ou Créer
   Gosub DOUBLON
Endif
End

#------------------------------------------------------------------------
$DOUBLON
Local Integer I, NOL, DOUBLON
Local Integer BORNFIN                       : # indice fin boucle comparaison
Local Char TST_DB     (250) (0..[M]NBLIG+1) : # NBLIG+1 ( car NBLIG pas encore m.a.j.)
Local Char TST_PLICRI (250)

BORNFIN=dim(TST_DB)-1
If BORNFIN>dim([M]CRIT1)-1 : BORNFIN=dim([M]CRIT1)-1 : Endif

# si import et traitement entete : pas de controle
If GIMPORT & dim(G_IMPFIC)>0 & G_IMPFIC="SPF" : Return : Endif

# constitution table comparaison
For I=0 To BORNFIN
    TST_DB(I)=num$([M]CRIT1(I))+"~"+num$([M]CRIT2(I))+"~"+num$([M]CRIT3(I))+"~"+
&             num$([M]CRIT4(I))+"~"+num$([M]CRIT5(I))+"~"+[M]CUR(I)+"~"+[M]UOM(I)+"~"
Next I

NOL=nolign-1 : Raz GMESSAGE : Raz DOUBLON

# test sur cette fiche : lignes avant
If !DOUBLON
   For I=0 To NOL-1
       If DOUBLON : Break : Endif
       Gosub DB_FICHE
   Next I
Endif

# test sur cette fiche : lignes apres
If !DOUBLON
   For I=NOL+1 To BORNFIN
       If DOUBLON : Break : Endif
       Gosub DB_FICHE
   Next I
Endif

# test sur autres fiches
If !DOUBLON
   Gosub DB_TARIF
Endif

# avertissement
If DOUBLON
   Call MESSAGE (GMESSAGE) From GESECRAN
Endif

Return

#---------------------------------------
$DB_FICHE

# controle critères
If TST_DB(NOL)<> TST_DB(I) : Return : Endif

# si bornes qtes et bornes montants non significatives
If [M]MAXQTY(I)=0 & [M]MAXAMT(I)=0 : DOUBLON=1 : Endif
# controle bornes quantités
If [M]MAXQTY(NOL)<>0                    : # les quantites sont significatives
   If [M]MINQTY(NOL)>=[M]MINQTY(I) & [M]MINQTY(NOL)<=[M]MAXQTY(I) : DOUBLON=1 : Goto DB_F1 : Endif
   If [M]MAXQTY(NOL)>=[M]MINQTY(I) & [M]MAXQTY(NOL)<=[M]MAXQTY(I) : DOUBLON=1 : Goto DB_F1 : Endif
   If [M]MINQTY(NOL)<=[M]MINQTY(I) & [M]MAXQTY(NOL)>=[M]MAXQTY(I) : DOUBLON=1 : Goto DB_F1 : Endif
Endif
# controle bornes montants
If [M]MAXAMT(NOL)<>0                    : # les montants sont significatifs
   If [M]MINAMT(NOL)>=[M]MINAMT(I) & [M]MINAMT(NOL)<=[M]MAXAMT(I) : DOUBLON=1 : Goto DB_F1 : Endif
   If [M]MAXAMT(NOL)>=[M]MINAMT(I) & [M]MAXAMT(NOL)<=[M]MAXAMT(I) : DOUBLON=1 : Goto DB_F1 : Endif
   If [M]MINAMT(NOL)<=[M]MINAMT(I) & [M]MAXAMT(NOL)>=[M]MAXAMT(I) : DOUBLON=1 : Goto DB_F1 : Endif
Endif

$DB_F1
If DOUBLON
   GMESSAGE =mess(814,196,1)+" :  "
   If GIMPORT : GMESSAGE +=mess(61,100,1)-num$(NOL+1)+"  &  " : Endif
   GMESSAGE +=mess(61,100,1)-num$(I+1)
Endif

Return

#---------------------------------------
$DB_TARIF

TST_PLICRI=num$([M]CRIT1(NOL))+"~"+num$([M]CRIT2(NOL))+"~"+num$([M]CRIT3(NOL))+"~"+
&          num$([M]CRIT4(NOL))+"~"+num$([M]CRIT5(NOL))+"~"
Filter [SPL] Where [M]PLI=PLI & [L]TST_PLICRI=PLICRI & [M]PLICRD<>PLICRD &
&                  [M]CUR(NOL)=CUR & [M]UOM(NOL)=UOM &
&                  !([M]PLISTRDAT>PLIENDDAT | [M]PLIENDDAT<PLISTRDAT)
&            Order By Key SPL1
For [SPL]
  # si bornes qtes et bornes montants non significatives
  If [M]MAXQTY(NOL)=0 & [M]MAXAMT(NOL)=0 : DOUBLON=1 : Endif
  # controle bornes quantités
  If [M]MAXQTY(NOL)<>0                    : # les quantites sont significatives
    If [M]MINQTY(NOL)>=[F:SPL]MINQTY & [M]MINQTY(NOL)<=[F:SPL]MAXQTY : DOUBLON=1 : Break : Endif
    If [M]MAXQTY(NOL)>=[F:SPL]MINQTY & [M]MAXQTY(NOL)<=[F:SPL]MAXQTY : DOUBLON=1 : Break : Endif
    If [M]MINQTY(NOL)<=[F:SPL]MINQTY & [M]MAXQTY(NOL)>=[F:SPL]MAXQTY : DOUBLON=1 : Break : Endif
  Endif
  # controle bornes montants
  If [M]MAXAMT(NOL)<>0                    : # les quantites sont significatives
    If [M]MINAMT(NOL)>=[F:SPL]MINQTY & [M]MINAMT(NOL)<=[F:SPL]MAXQTY : DOUBLON=1 : Break : Endif
    If [M]MAXAMT(NOL)>=[F:SPL]MINQTY & [M]MAXAMT(NOL)<=[F:SPL]MAXQTY : DOUBLON=1 : Break : Endif
    If [M]MINAMT(NOL)<=[F:SPL]MINQTY & [M]MAXAMT(NOL)>=[F:SPL]MAXQTY : DOUBLON=1 : Break : Endif
  Endif
Next
Filter [SPL]

If DOUBLON
   GMESSAGE =mess(814,196,1)+" :  "
   If GIMPORT : GMESSAGE +=mess(61,100,1)-num$(NOL+1)+"  &  " : Endif
   GMESSAGE  +=mess(15,197,1)-[F:SPL]PLI+"  "+mess(9,432,1)-[F:SPL]PLICRD
   If !GIMPORT : GMESSAGE +="\" : Else : GMESSAGE +="   " : Endif
   GMESSAGE +="( "
   If num$([M]CRIT1(NOL))<>""
      GMESSAGE +=num$([M]CRIT1(NOL))
   Endif
   If num$([M]CRIT2(NOL))<>""
      GMESSAGE +=" / "+num$([M]CRIT2(NOL))
   Endif
   If num$([M]CRIT3(NOL))<>""
      GMESSAGE +=" / "+num$([M]CRIT3(NOL))
   Endif
   If num$([M]CRIT4(NOL))<>""
      GMESSAGE +=" / "+num$([M]CRIT4(NOL))
   Endif
   If num$([M]CRIT5(NOL))<>""
      GMESSAGE +=" / "+num$([M]CRIT5(NOL))
   Endif
   GMESSAGE +=" )"
Endif

Return

