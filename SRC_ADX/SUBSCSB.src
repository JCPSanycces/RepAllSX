#<AdxTL>@(#)0.0.0.0 $Revision$ Autorisation saisie zone
Local Integer N(3)
Local Char S(2)(3)
Local Integer I, J
N(0) = 2
N(1) = 1
N(2) = 1
S(0) = "s1"
S(1) = "s0"
S(2) = "s"
Raz I
J = sigma(0,dim(N)-1,N(indcum)=1 & I=0 & sigma(I=indcum+1,indcum,0))
Infbox num$(I)-num$(indcum)

I=find(2,N)-1
If I>=0
    J=sigma(I,dim(N)-1,N(indcum)=2 | sigma(dim(N),dim(N),0))
    Infbox num$(I)-num$(J)-num$(min(S(I..I+J-1)))
Endif
End
###############################################################################
# OUVCHG : Détermine la nécessité d'ouvrir ou non le détail
#          des changements d'emplacement
###############################################################################
# Paramètres E : PABR   = Abréviation de l'écran
#                PNOL   = Numéro de ligne à controler
#                PFCY   = Site de départ
#
#            S : GOUVENT positionnée
###############################################################################
Subprog OUVCHG( PABR, PNOL, PFCY)
Value    Char    PABR
Value    Integer PNOL
Value    Char    PFCY

Local Integer LRET
Local Integer LNBDET
Local Decimal LQTY
Local Char    LSTA(GLONSTA)
Local Char    LLOCTYP(GLONTLO)
Local Char    LLOC(GLONLOC)
Local Char    LSER(GLONSER), LSERF(GLONSER)
Local Integer LQLYFLG
Local Integer I, J1, J2, I1, I2
Local Integer LWSTOSEQ
Local Char    LMABR(10) : LMABR="[M:"+PABR+"]"
Local Char    LPAL(GLONPAL)                   # hcb 110505 28601
Local Char    LCTR(GLONCTR)                   # hcb 110505 28601
Local Char    LLPN(GLONLPN)                   # hcb X3-67989

Raz GOUVENT


# Si aucune quantité n'a été saisie on ne va pas plus loin
# Cela peut se produire dans le contrôle qualité où on ne saisirait que la quantité contrôlée
If evalue("[M:"+PABR+"]QTYSTUDES(PNOL)") = 0
    End
Endif
LWSTOSEQ = evalue("[M:"+PABR+"]WSTOSEQ(PNOL)")

If adxgtb<>1 & !find(status,65,68,83)

    Call CTRLIG(PABR,PNOL, LRET)
    If LRET
        If mod(LRET,512)>=256
           Call ERREUR(mess(67,184,1)) From GESECRAN
        Endif
        GOUVENT = 2
        Assign "[M:"+PABR+"]WSTOFLG(PNOL)" With 0
    Else
        Assign "[M:"+PABR+"]WSTOFLG(PNOL)" With 1
# Normalement cela se fait s'il y a plusieurs lignes de détail
# aussi bien dans le changement stock que dans le contrôle qualité
#        Call DISZOSTO(PABR, PNOL) From SUBSCSB
    Endif
Else
    LNBDET = func SUBSCSB.CALCNBDET(LWSTOSEQ)
    If LNBDET=1 & [M:SGW]WLOCSEQCUR>100000 | LNBDET=0
        Call STKDELRES([M:SGW]WLOCSEQCUR, "", "", LRET) From STKLOC
        [M:SGW]WLOCSEQCUR = 99999999
    Endif
    End
Endif

LQTY=-1    # On initialise à -1 pour dire que rien n'est fait
# Dans le cas du QC on a déjà alimenté WSTOSEQ sans rien avoir dans STOCHGW (c'est pour la fiche qualité)
  If LWSTOSEQ=0 | !find(LWSTOSEQ,[M:SGW]WSTOSEQ)
    If LWSTOSEQ=0
        Call STKWSTOSEQ (PABR, PNOL, evalue("[M:"+PABR+"]NBLIG"), 2, LWSTOSEQ, LRET) From STKECR
        If LRET : End : Endif
        #--- Fillchgw => LQTY>=0
        Assign "[M:"+PABR+"]WSTOSEQ(PNOL)" With LWSTOSEQ
    Endif

    If [F:ITM]SERMGTCOD = 4                                              # hcb 110327
       Gosub CTR_SERIES_GLOBALE From SUBSCSB                             # hcb 110327
       If WQTYSTOCOU <> WQTYSAISIE                                       # hcb 110327
          Call FILLCHGW(PABR, PNOL, 1, LWSTOSEQ, PFCY, LRET, LQTY)       # hcb 110327
       Endif                                                             # hcb 110327
    Else                                                                 # hcb 110327
       Call FILLCHGW(PABR, PNOL, 1, LWSTOSEQ, PFCY, LRET, LQTY)
    Endif                                                                # hcb 110327

    # La ligne chargée n'est pas correcte
    If LRET<>0 | GERR=2
       Assign "[M:"+PABR+"]WSTOFLG(PNOL)" With 0
    Endif

Else
    #                                                        # hcb 110327 deb
    If [F:ITM]SERMGTCOD = 4 & PABR="SCS1" & [M:SCS1]ENRDETFLG(PNOL) = 1
       LNBDET = 1
    Else
#                                                        # hcb 110327 deb
       LNBDET = func SUBSCSB.CALCNBDET(LWSTOSEQ)
    Endif                                                # hcb 110327
#    # S'il y a eu modification de la quantité...
#    If  evalue("[M:"+PABR+"]QTYPCUDES(PNOL)") <> sigma( 0, [M:SGW]NBLIG-1, (LWSTOSEQ=[M:SGW]WSTOSEQ(indcum))
#&                                                          * [M:SGW]WQTYPCUDES(indcum) )
#&     | evalue("[M:"+PABR+"]QTYSTUDES(PNOL)") <> sigma( 0, [M:SGW]NBLIG-1, (LWSTOSEQ=[M:SGW]WSTOSEQ(indcum))
#&                                                          * [M:SGW]WQTYSTUDES(indcum) )
        # ... et qu'il y a plusieurs lignes de détails déjà saisies, on rouvre le détail
        If LNBDET>1
&        & evalue("[M:"+PABR+"]QTYSTUDES(PNOL)") <> sigma( 0, [M:SGW]NBLIG-1, (LWSTOSEQ=[M:SGW]WSTOSEQ(indcum))
&                                                           * [M:SGW]WQTYSTUDES(indcum) )

            GOUVENT = 2
            Assign "[M:"+PABR+"]WSTOFLG(PNOL)" With 0
        # ... sinon on revient au cas de la saisie initiale
        Elsif LNBDET=1
            J1 = find(LWSTOSEQ,[M:SGW]WSTOSEQ)-1    # --> pour sections ana
            Call DELSTOCHGW(PABR, PFCY, PNOL, PNOL, 1, LRET) From SUBSCSB
            #--- Fillchgw => LQTY>=0
            If [F:ITM]SERMGTCOD = 4                                              # hcb 110327
               Gosub CTR_SERIES_GLOBALE From SUBSCSB                             # hcb 110327
               If WQTYSTOCOU <> WQTYSAISIE                                       # hcb 110327
                  Call FILLCHGW(PABR, PNOL, 1, LWSTOSEQ, PFCY, LRET, LQTY)       # hcb 110327
               Endif                                                             # hcb 110327
            Else                                                                 # hcb 110327
               Call FILLCHGW(PABR, PNOL, 1, LWSTOSEQ, PFCY, LRET, LQTY)
            Endif                                                                # hcb 110327

            # La ligne chargée n'est pas correcte
            If LRET<>0 | GERR=2
               Assign "[M:"+PABR+"]WSTOFLG(PNOL)" With 0
            Endif
            If find(PABR,"SCS1","SCD") & PFCY<>[M:SGW]FCYDES
                J2 = find(LWSTOSEQ,[M:SGW]WSTOSEQ)-1
                For I1=J2 To [M:SGW]NBLIG-1
                    For I2=1 To GNBDIE   #   hcb ana
                        If PABR="SCS1"
                            Assign "[M:SGW]CCE"+num$(I2)+"(I1)" With evalue("[M:SGW]CCE"+num$(I2)+"(J1)")
                            Assign "[M:SGW]CCS"+num$(I2)+"(I1)" With evalue("[M:SGW]CCS"+num$(I2)+"(J1)")
                        Elsif PABR="SCD"
                            Assign "[M:SGW]CCE"+num$(I2)+"(I1)" With [M:SCD]CCE(I2)
                            Assign "[M:SGW]CCS"+num$(I2)+"(I1)" With [M:SCD]CCS(I2)
                        Endif
                    Next
                Next
            Endif
        Endif
Endif

If dim(GSTOPRET)>0
    GSTOPRET = LRET
Endif
If LRET
    End
Endif

Raz mkstat
If LQTY>=0 & LQTY<>evalue("[M:"+PABR+"]QTYSTUDES(PNOL)")
    If LQTY=0
        Call ERREUR(mess(367,199,1)) From GESECRAN
        mkstat=2
    Else
        Call MESSAGE( mess(275,198,1)-":"-num$(LQTY)-"/"-num$(evalue("[M:"+PABR+"]QTYSTUDES(PNOL)")) ) From GESECRAN
        Assign "[M:"+PABR+"]QTYSTUDES(PNOL)" With LQTY
        Assign "[M:"+PABR+"]QTYPCUDES(PNOL)" With LQTY/evalue("[M:"+PABR+"]COEDES(PNOL)")
        Default Mask "[M:"+PABR+"]"
#        Affzo [M]QTYSTUDES(PNOL),QTYPCUDES(PNOL)
        #Bg 82442
        #If evalue("[M:"+PABR+"]SERNUM(PNOL)")<>""
        If evalue("dim([M:"+PABR+"]SERNUM(PNOL))")>0 & evalue("[M:"+PABR+"]SERNUM(PNOL)")<>""
#                            rajout LLPN    # hcb X3-67989
            Call RECCHG_M(evalue("[M:"+PABR+"]WSTOSEQ(PNOL)"), LSTA, LLOCTYP, LLOC, LSER, LSERF, LQLYFLG, PABR, PNOL, PPAL, PCTR, LLPN)
&           From SUBSCSB
            Assign "[M:"+PABR+"]SERNUM(PNOL)"    With LSER
            Assign "[M:"+PABR+"]SERNUMF(PNOL)"   With LSERF
            Assign "[M:"+PABR+"]QTYPCU(PNOL)"    With LQTY
            Assign "[M:"+PABR+"]QTYSTUDES(PNOL)" With LQTY
            If evalue("dim([M:"+PABR+"]QLYCTLFLG)")>0
                Assign "[M:"+PABR+"]QLYCTLFLG(PNOL)" With LQLYFLG
            Endif
            Default Mask "[M:"+PABR+"]"
#            Affzo [M]SERNUM(PNOL),SERNUMF(PNOL)
#            Affzo [M]QTYSTUDES(PNOL),QTYPCU(PNOL)
        Endif
    Endif
Endif


End


###############################################################################
# CTRLIG : Controle la conformité de la ligne
###############################################################################
# Paramètres E : PABR  = Abréviation de l'écran dont la ligne est à contrôler
#                PNOL  = Indice de la ligne à controler
#
#            S : PRET  = 0 si OK
#                        +1   si PCUDES    KO
#                        +2   si QTYPCUDES KO
#                        ....
#                        +128 si rien n'est modifié
#                        +256 si ligne de stock destination est en inventaire
###############################################################################
Subprog CTRLIG( PABR, PNOL, PRET )
Value    Char    PABR
Value    Integer PNOL
Variable Integer PRET

Local Char LMABR : LMABR = "[M:"+PABR+"]"
Local Integer LNOLORI
Local Decimal LSTOCOU
Local Char    LFCY(GLONFCY)
Local Char    WLOT(GLONLOT)
Local Char    WSLO(GLONSLO)
Local Char    WPAL(GLONPAL)
Local Char    WCTR(GLONCTR)
Local Char    WLOC(GLONLOC)
Local Char    WLPN(GLONLPN)     : #--- Issue X3-53322
# hcb 34747
Local Char    WPAL(GLONPAL)
Local Char    WPALDES(GLONPAL)
Local Char    WCTR(GLONCTR)
Local Char    WCTRDES(GLONCTR)
Raz WPAL
Raz WPALDES
Raz WCTR
Raz WCTRDES
# hcb 34747

Raz PRET
Case PABR
    When "SCS1","SCD" : LFCY = [M]FCYDES
    When Default      : LFCY = [M]STOFCY
Endcase

If evalue(LMABR+"PCUDES(PNOL)")=""
    PRET += 1
Else

Endif

If evalue(LMABR+"QTYPCUDES(PNOL)")=0
    PRET += 2
Endif

If evalue(LMABR+"COEDES(PNOL)")=0
    PRET += 4
Endif

If evalue(LMABR+"STADES(PNOL)")=""
    PRET += 8
Endif

If [F:ITFD]LOCMGTCOD = 2
    If evalue("dim("+LMABR+"LOCTYPDES(PNOL))")>0 & evalue(LMABR+"LOCTYPDES(PNOL)")=""
        PRET += 16
    Endif
    If evalue("dim("+LMABR+"LOCDES(PNOL))")>0 & evalue(LMABR+"LOCDES(PNOL)")=""
        PRET += 32
    Endif
Endif
# Dans le cas de transfert inter-site, les n° de série gérés en sortie sont obligatoires
If [F:ITM]SERMGTCOD=2 & [F:ITM]SERCOU="" & evalue("dim("+LMABR+"BETCPY)")>0 & evalue("dim("+LMABR+"SERNUM)")>0 & evalue(LMABR+"SERNUM(PNOL)")="" & evalue(LMABR+"BETCPY")=2
    PRET += 64
Endif
#                                                                                       # hcb 110327 deb
# Dans le cas serie  série gérés en entrée sortie globale la saisie est obligatoire

If [F:ITM]SERMGTCOD=4 & !find(LMABR,"[M:STQ1]","[M:SCS1]","[M:SMP]")
&   & evalue("dim("+LMABR+"SERNUM)")>0 & evalue(LMABR+"SERNUM(PNOL)")=""
    PRET += 512
Endif
#                                                                                       # hcb 110327 end

# hcb 34747
If evalue("dim("+LMABR+"PALNUMDES(PNOL))")>0
   WPALDES = evalue(LMABR+"PALNUMDES(PNOL)")
   WPAL    = evalue(LMABR+"PALNUM(LNOLORI)")
Endif
If evalue("dim("+LMABR+"CTRNUMDES(PNOL))")>0
   WCTRDES =  evalue(LMABR+"CTRNUMDES(PNOL)")
   WCTR    =  evalue(LMABR+"CTRNUM(LNOLORI)")
Endif
# hcb 34747

# hcb 110501 28601
If !PRET
    LNOLORI = (evalue("dim("+LMABR+"PCU)")>1)*PNOL
    If    evalue(LMABR+"PCUDES(PNOL)")=evalue(LMABR+"PCU(LNOLORI)")
&       & evalue(LMABR+"COEDES(PNOL)")=evalue(LMABR+"PCUSTUCOE(LNOLORI)")
&       & evalue(LMABR+"STADES(PNOL)")=evalue(LMABR+"STA(LNOLORI)")
&       & WPALDES = WPAL
&       & WCTRDES = WCTR
        If  [F:ITFD]LOCMGTCOD = 2 & [F:SRT]BETFCYCOD<>2             # HCB 270105 28029
            If evalue("dim("+LMABR+"LOCDES(PNOL))")>0 & evalue(LMABR+"LOCDES(PNOL)")=evalue(LMABR+"LOC(LNOLORI)")
                PRET += 128
            Endif
        Elsif [F:SRT]BETFCYCOD<>2
            PRET += 128
        Endif
    Endif
Endif

# hcb 34747
If !PRET
   If  [F:ITFD]LOCMGTCOD = 2 & [F:SRT]BETFCYCOD<>2
       If evalue("dim("+LMABR+"LOCDES(PNOL))")>0 & evalue(LMABR+"LOCDES(PNOL)")=evalue(LMABR+"LOC(LNOLORI)")
          If [F:TLO]STOFCY<>LFCY | [F:TLO]LOCTYP<>evalue(LMABR+"LOCTYPDES(PNOL)")
                Read [TLO]TLO0=LFCY;evalue(LMABR+"LOCTYPDES(PNOL)")
                If fstat
                   Raz  [F:TLO]
                Endif
          Endif
          # test si type quai
          If [F:TLO]LOCCAT = 2
            PRET += 128
          Endif
       Endif
   Endif
Endif
# hcb 34747



#-------- Teste si la ligne de stock destination est en inventaire ---------------#
If !PRET
    If evalue("string$(dim("+LMABR+"SERNUM)>0,"+"sigma(PNOL+1,"+
&             "(PNOL+1)*(dim("+LMABR+"SERNUM)>0),"+LMABR+"SERNUM(indcum-1)))")=""

        WLOT=evalue("string$(dim("+LMABR+"LOT)>0,sigma(PNOL+1,(PNOL+1)*(dim("+LMABR+"LOT)>0),"+LMABR+"LOT((indcum-1)*(dim("+LMABR+"LOT)>1))))")
        WSLO=evalue("string$(dim("+LMABR+"SLO)>0,sigma(PNOL+1,(PNOL+1)*(dim("+LMABR+"SLO)>0),"+LMABR+"SLO((indcum-1)*(dim("+LMABR+"LOT)>1))))")
        WPAL=evalue("string$(dim("+LMABR+"PALNUM)>0,sigma(PNOL+1,(PNOL+1)*(dim("+LMABR+"PALNUM)>0),"+LMABR+"PALNUM((indcum-1)*(dim("+LMABR+"LOT)>1))))")
        WCTR=evalue("string$(dim("+LMABR+"CTRNUM)>0,sigma(PNOL+1,(PNOL+1)*(dim("+LMABR+"CTRNUM)>0),"+LMABR+"CTRNUM((indcum-1)*(dim("+LMABR+"LOT)>1))))")
        WLOC=evalue("string$(dim("+LMABR+"LOCDES)>0,sigma(PNOL+1,(PNOL+1)*(dim("+LMABR+"LOCDES)>0),"+LMABR+"LOCDES(indcum-1)))")
        WSF1=evalue("string$(dim("+LMABR+"STOFLD1)>0,sigma(PNOL+1,(PNOL+1)*(dim("+LMABR+"STOFLD1)>0),"+LMABR+"STOFLD1((indcum-1)*(dim("+LMABR+"LOT)>1))))")
        WSF2=evalue("string$(dim("+LMABR+"STOFLD2)>0,sigma(PNOL+1,(PNOL+1)*(dim("+LMABR+"STOFLD2)>0),"+LMABR+"STOFLD2((indcum-1)*(dim("+LMABR+"LOT)>1))))")
        #--- Issue X3-53322
        WLPN=evalue("string$(dim("+LMABR+"LPNNUM)>0,sigma(PNOL+1,(PNOL+1)*(dim("+LMABR+"LPNNUM)>0),"+LMABR+"LPNNUM((indcum-1)*(dim("+LMABR+"LOT)>1))))")
# hcb 110505 28601 deb
        If [F:SRT]BETFCYCOD = 1
           If evalue("dim("+LMABR+"PALNUMDES)")>0
              WPAL=evalue("string$(dim("+LMABR+"PALNUMDES)>0,sigma(PNOL+1,(PNOL+1)*(dim("+LMABR+"PALNUMDES)>0),"+LMABR+"PALNUMDES(indcum-1)))")
           Endif
           If evalue("dim("+LMABR+"CTRNUMDES)")>0
              WCTR=evalue("string$(dim("+LMABR+"CTRNUMDES)>0,sigma(PNOL+1,(PNOL+1)*(dim("+LMABR+"CTRNUMDES)>0),"+LMABR+"CTRNUMDES(indcum-1)))")
           Endif
        Endif
# hcb 110505 28601 fin
        If clalev([F:STO1])>0
            #--- Issue X3-53322 : Ajout LPN
            LSTOCOU = func STKLIB.CLESTOFUN(LFCY,evalue(LMABR+"ITMREF(PNOL*(dim("+LMABR+"ITMREF)>1))"),
&                                           WLOT,WSLO,WPAL,WCTR,evalue(LMABR+"STADES(PNOL)"),WLOC,
&                                           evalue(LMABR+"PCUDES(PNOL)"),evalue(LMABR+"COEDES(PNOL)"),
&                                           "","",evalue(LMABR+"OWNER"),WSF1,WSF2,"STO1",WLPN)
            If LSTOCOU
                Read [STO1]STO0=LFCY;LSTOCOU
                If [STO1]CUNLOKFLG = 2
                    PRET += 256
                Endif
            Endif
        Else
            #--- Issue X3-53322 : Ajout LPN
            LSTOCOU = func STKLIB.CLESTOFUN(LFCY,evalue(LMABR+"ITMREF(PNOL*(dim("+LMABR+"ITMREF)>1))"),
&                                           WLOT,WSLO,WPAL,WCTR,evalue(LMABR+"STADES(PNOL)"),WLOC,
&                                           evalue(LMABR+"PCUDES(PNOL)"),evalue(LMABR+"COEDES(PNOL)"),
&                                           "","",evalue(LMABR+"OWNER"),WSF1,WSF2,"STO",WLPN)
            If LSTOCOU
                Read [STO]STO0=LFCY;LSTOCOU
                If [STO]CUNLOKFLG = 2
                    PRET += 256
                Endif
            Endif
        Endif
    Endif
Endif

End



###############################################################################
# FILLCHGW : Remplit STOCHGW à partir du masque passé en paramètre
###############################################################################
# Paramètres E : PABR   = Abréviation de l'écran source
#                PNOL   = Indice de la ligne de départ
#                PNBLIG = Nombre de ligne(s) à copier
#                PSEQ   = WSTOSEQ
#                PSTOFCY= Site de départ
#
#            S : PRET   = Code retour (0=OK, 1=Erreur, 2=SGW plein)
#                PQTY   = Quantité qui a pu être réservée
#
# Cas particulier : Alimentation du champ WSTOCOU différent à partir de "SCD" ou "SQD"
###############################################################################
Subprog FILLCHGW( PABR, PNOL, PNBLIG, PSEQ, PSTOFCY, PRET, PQTY )
Value    Char    PABR
Value    Integer PNOL
Value    Integer PNBLIG
Value    Integer PSEQ
Value    Char    PSTOFCY
Variable Integer PRET
Variable Decimal PQTY

Local Char    LMABR
Local Integer I, J, IND
Local Decimal LSTOCOU
Local Decimal LWIPQTY, LWIPQTA
Local Decimal LPOT
Local Decimal LQTY, LQTYRES, LCUMQTY
Local Char    LITM
Local Char    LPCU(GLONUOM)
Local Char    LSTA(GLONSTA)
Local Char    LLOC(GLONLOC),  WLOC(GLONLOC)
Local Char    LSER(GLONSER), LSERF(GLONSER)
Local Char    LSF1(GLONSF1), LSF2(GLONSF2)
Local Char    LLPN(GLONLPN)                               # hcb X3-77043

If [F:ITM]SERMGTCOD=3
Else
    If [M:SGW]NBLIG+PNBLIG>=dim([M:SGW]WSTOSEQ)-1
        PRET = 2
        mkstat=2
        #-- ECR_TRACE au lieu de ERREUR car Funstop/funstolti se lancent en batch --#
        Call ECR_TRACE(mess(36,184,1)+"\"+mess(353,199,1),1) From GESECRAN
        End
    Endif
Endif
LMABR = "[M:"+PABR+"]"
Raz PQTY, LQTY
Raz PRET

LITM = evalue(LMABR+"ITMREF(PNOL*(dim("+LMABR+"ITMREF)>1))")

If clalev([F:STO1])=0  Local File STOCK   [STO1]  Endif
If clalev([F:SWW]) =0  Local File STOWIPW [SWW]   Endif

Raz WLOC
If evalue("dim("+LMABR+"LOC)")>0
    Case PABR
      When 'SCS1'  : WLOC = evalue(LMABR+"LOC(PNOL)")
      When 'STQ1'  : WLOC = evalue(LMABR+"LOC(PNOL)")  # hcb 56275
      When 'LPNA'  : WLOC = evalue(LMABR+"LOC(PNOL)")  # Issue X3-67963 - 2018-01-05 by MAE
      When 'LPNO'  : WLOC = evalue(LMABR+"LOC(PNOL)")  # Issue X3-67963 - 2018-01-05 by MAE
      When Default : WLOC = evalue(LMABR+"LOC")
    Endcase
Endif

For I=PNOL To PNOL+PNBLIG-1

    If LMABR = "[M:SQD]"  & [M:SQD]WSTJFLG(I) = 1      # hcb 43323
       Goto NEXT_I                                     # hcb 43323
    Endif                                              # hcb 43323
    #les  echantillonnages detail ([M:SMP]MODFLG = 2) ne sont pas pris en compte ils sont deja chargés par TRTSTOSMP1
    If LMABR = "[M:SMP]"  & [M:SMP]MODFLG (I) = 2      # hcb 50343
       Goto NEXT_I                                     # hcb 50343
    Endif                                              # hcb 50343

    Raz LSER                                                                                    # hcb 110327
    If ([F:ITM]SERMGTCOD = 2 | [F:ITM]SERMGTCOD = 3) & evalue("dim("+LMABR+"SERNUM(I))")>0      # hcb 110327
        LSER = evalue(LMABR+"SERNUM(I)")
#---                             # ts  120448
        # Si série en sortie et inter-sites inter-sociétés ou transfert sst, il faut lire le stock sur no série
        # car il a peut être été saisi pour la sortie et par conséquent n'existe pas encore
        If LSER<>"" & [F:ITM]SERMGTCOD=2 & PABR="SCS1" & (([M:SCS1]BETFCYCOD=2&[M:SCS1]BETCPY=2)|[M:SCS1]BETFCYCOD=4)
           Read [STO]STO5=LITM;LSER
           If fstat LSER="" Endif
        Endif
#---
    Endif
    If LSER<>""
        If [M:SGW]NBLIG>=dim([M:SGW]WSTOSEQ)
            #----- On affiche une erreur, mais on ne bloque pas la suite -----#
            #-- ECR_TRACE au lieu de ERREUR car Funstop/funstolti se lance en batch --#
            Call ECR_TRACE(mess(36,184,1),1) From GESECRAN
            PRET = 2
            Break
        Endif
        [M:SGW]WSERNUM([M:SGW]NBLIG) = LSER
        Read [STO]STO5=LITM;LSER
        LPCU = [F:STO]PCU
        LSTA = [F:STO]STA
        LLOC = [F:STO]LOC
        LLOT = [F:STO]LOT
        LSLO = [F:STO]SLO
        LPAL = [F:STO]PALNUM
        LCTR = [F:STO]CTRNUM
        LSF1 = [F:STO]STOFLD1
        LSF2 = [F:STO]STOFLD2
        LLPN = [F:STO]LPNNUM                                   # hcb X3-77043
        LSERF  = LSER
        LQTY = 0
        LCUMQTY = 0
        If evalue("dim("+LMABR+"WLOCSEQ(I))")>0
            [M:SGW]WLOCSEQ([M:SGW]NBLIG)    = evalue(LMABR+"WLOCSEQ(I)")
        Else
            Call STKWLOCSEQ("SGW", [M:SGW]NBLIG, PRET) From STKECR
        Endif
        LLOCSEQ = [M:SGW]WLOCSEQ([M:SGW]NBLIG)
        For J=1 To evalue(LMABR+"QTYSTUDES(I)")
            # Contrôle la disponibilité du n° de série, et le réserve si dispo
#                                             rajout LLPN                           # hcb X3-77043
            Call CTRSERNUM(LITM, PSTOFCY, LSERF, PSEQ, LPCU, LSTA, LLOC, LLOT,
&                          LSLO, LPAL, LCTR, LSF1, LSF2, LLPN, 1, PRET) From SUBSCSB
            If PRET
                If LCUMQTY>0
                    Break
                Endif
            Else
                LQTY = 1
                LCUMQTY += LQTY
                LSTOCOU = [F:STO]STOCOU
                Gosub ADDCHGW
                If GOK = -1       # hcb 56014
                   Break 2
                Endif
                [M:SGW]WSERNUM([M:SGW]NBLIG)  = LSERF
                [M:SGW]WSERNUMF([M:SGW]NBLIG) = LSERF
                [M:SGW]WWIPQTY([M:SGW]NBLIG) = [F:STO]CUMWIPQTY
                [M:SGW]WWIPQTA([M:SGW]NBLIG) = [F:STO]CUMWIPQTA
                [M:SGW]NBLIG += 1
            Endif
            If J<evalue(LMABR+"QTYSTUDES(I)")
                Call PLUS_UN(LSERF,LSERF,PRET) From STKLIB
            Endif
        Next
        If LCUMQTY>0                # La gestion au niveau détail est identique au niveau du document
           If evalue(LMABR+"WLOCSEQ(I)")>100000
                [M:SGW]WLOCSEQ([M:SGW]NBLIG-1) = evalue(LMABR+"WLOCSEQ(I)")-100000
            Else
                [M:SGW]WLOCSEQ([M:SGW]NBLIG-1) = evalue(LMABR+"WLOCSEQ(I)")
            Endif
            For J=2 To LCUMQTY
                [M:SGW]WLOCSEQ([M:SGW]NBLIG-J) = [M:SGW]WLOCSEQ([M:SGW]NBLIG-1)
            Next J
            Call STKDELRES([M:SGW]WLOCSEQ([M:SGW]NBLIG-1), [M:SGW]FCYDES,"",PRET) From STKLOC

            If !find(LMABR,"[M:LPNA]","[M:LPNO]")   # Issue X3-73341 - 2018-02-22 by MAE : les controles sur l'emplacement st faits dans l'écran des affectations
              Call STKCTRTLO([M:SGW]WLOCSEQ([M:SGW]NBLIG-1),
&                          [M:SGW]TRSTYP,[M:SGW]TRSCOD,
&                          [M:SGW]FCYDES,
&                          evalue(LMABR+"ITMREF(I*(dim("+LMABR+"ITMREF)>1))"),
&                          [M:SGW]WPCUDES([M:SGW]NBLIG-1),
&                          LCUMQTY,
&                          [M:SGW]WSTADES([M:SGW]NBLIG-1),
&                          0,
&                          [M:SGW]WLOCTYPDES([M:SGW]NBLIG-1),
&                          mkstat,
&                          string$([M:SGW]WLOCDES([M:SGW]NBLIG-1)=WLOC,"QU"),
&                          "",
&                          [M:SGW]WWRHDES([M:SGW]NBLIG-1)) From STKLOC

            Call STKCTREMP([M:SGW]WLOCSEQ([M:SGW]NBLIG-1),
&                          [M:SGW]TRSTYP,[M:SGW]TRSCOD,
&                          [M:SGW]FCYDES,
&                          evalue(LMABR+"ITMREF(I*(dim("+LMABR+"ITMREF)>1))"),
&                          [M:SGW]WPCUDES([M:SGW]NBLIG-1),
&                          LCUMQTY,
&                          [M:SGW]WSTADES([M:SGW]NBLIG-1),
&                          [M:SGW]WLOCTYPDES([M:SGW]NBLIG-1),
&                          [M:SGW]WLOCDES([M:SGW]NBLIG-1),
&                          "",
&                          0,
&                          mkstat,
&                          GBIDD1,
&                          string$([M:SGW]WLOCDES([M:SGW]NBLIG-1)=WLOC,"QU"),
&                          "",
&                          [M:SGW]WWRHDES([M:SGW]NBLIG-1)) From STKLOC
            [M:SGW]WLOCSEQCUR = 99999999

            # S'il y a des erreurs on continue quand même de remplir, mais il faudra ouvrir la fenêtre de détail
            If mkstat
                GOUVENT = GOUVENT-mod(GOUVENT,32)+mod(GOUVENT,16)+16
            Endif
         Endif  # End issue X3-73341

        Endif
        PQTY += LCUMQTY
    Else
        If PABR = "SCD" | PABR="SQD"
            LSTOCOU = evalue(LMABR+"WSTOCOU(0)")
#                                                                      # hcb 110327 deb
            If  LSTOCOU = 0
                LSTOCOU =  evalue(LMABR+"WSTOCOU1")
            Endif
#                                                                      # hcb 110327 end
        Elsif PABR = "SMP1"                               # hcb 50343
            LSTOCOU = evalue(LMABR+"WSTOCOU")
        Elsif (PABR = "CHGS" | PABR = "LPNC")                               # hcb 110327
            LSTOCOU = evalue(LMABR+"STOCOU")              # hcb 110327
        Else
            LSTOCOU = evalue(LMABR+"WSTOCOU(I)")
        Endif
        If PABR = "SMP"                                    # hcb V6CQ
           LQTY = evalue(LMABR+"QTYSTU(I)")                # hcb V6CQ
        Else                                               # hcb V6CQ
           LQTY = evalue(LMABR+"QTYSTUDES(I)")             # hcb V6CQ
        Endif                                              # hcb V6CQ

#                                                                      # hcb 110327 deb

        If [F:ITM]SERMGTCOD = 4
           Local Decimal WQTY
           WQTY = LQTY
           LSER = evalue(LMABR+"SERNUM(I)")
        Endif
#                                                                      # hcb 110327 end


        Gosub CRERESSTO    # --> Modifie LQTY, calcule LQTYRES et LPOT
#                                                           # hcb 110327 deb
        If [F:ITM]SERMGTCOD = 4
           If  WQTY <> LQTY & evalue(LMABR+"SERNUM(I)") <> ""
               GMESSAGE = mess(302,199,1)   # Désynchronisation des numéros de série (Stock / Séries)
           Else
               # Création série en cours de traitement
               If LSER <> ""
                  Call CRE_STOSERW(LITM,LSER,LQTY,PRET) From STKLIB
                  If PRET <>0
                     Break
                  Endif
               Endif
           Endif
        Endif
#                                                                      # hcb 110327 end


        PQTY += LQTY
        If LQTY<>0
            Gosub ADDCHGW
            If GOK = -1       # hcb 56014
               Break
            Endif
            [M:SGW]WLIGDET([M:SGW]NBLIG) = I-PNOL+1
            If evalue("dim("+LMABR+"SERNUM)")>0
                [M:SGW]WSERNUM([M:SGW]NBLIG) = evalue(LMABR+"SERNUM(I)")
            Endif
            If evalue("dim("+LMABR+"SERNUMF)")>0
                [M:SGW]WSERNUMF([M:SGW]NBLIG)= evalue(LMABR+"SERNUMF(I)")
            Endif
            [M:SGW]WWIPQTY([M:SGW]NBLIG) = LQTYRES
            [M:SGW]WWIPQTA([M:SGW]NBLIG) = LQTYRES*LPOT
            [M:SGW]NBLIG += 1
        Endif
    Endif

$NEXT_I           # hcb 43323
Next

# TS le 07.05.04
# Si tout va bien mais qu'il y a un message de chargé => warning
If GMESSAGE<>"" & mkstat=0 GERR=2 Endif
# Erreur
If mkstat PRET=1 Endif

End

###############################################################################
# Remplit SGW à partir des informations contenues dans l'écran LMABR
#
# Attention: ne pas modifier la classe [STO]
###############################################################################
$ADDCHGW
Local Integer ADD_I
Local Char    SVGGMESSAGE(250)


If [M:SGW]NBLIG + 1 >  dim([M:SGW]WSTOSEQ)             # hcb 47940
   Call ERREUR(mess(36,184,1)) From GESECRAN
   GOK = -1
   Return
Endif
    [M:SGW]WSTOSEQ([M:SGW]NBLIG)    = PSEQ
    [M:SGW]WLIGDET([M:SGW]NBLIG)    = I-PNOL+1
    [M:SGW]WSTOCOU([M:SGW]NBLIG)    = LSTOCOU
    If PABR = "SMP"                                                     # hcb V6CQ
       [M:SGW]WPCUDES([M:SGW]NBLIG)    = evalue(LMABR+"PCU(I)")         # hcb V6CQ
       [M:SGW]WCOEDES([M:SGW]NBLIG)    = evalue(LMABR+"PCUSTUCOE(I)")   # hcb V6CQ
       [M:SGW]VCRLIN ([M:SGW]NBLIG)    = evalue(LMABR+"VCRLIN(I)")      # hcb V6CQ
    Elsif PABR = "SMP1"                                                 # hcb 50343
       [M:SGW]WPCUDES([M:SGW]NBLIG)    = evalue(LMABR+"PCUDES(I)")      # hcb 50343
       [M:SGW]WCOEDES([M:SGW]NBLIG)    = evalue(LMABR+"COEDES(I)")      # hcb 50343
       [M:SGW]VCRLIN ([M:SGW]NBLIG)    = evalue(LMABR+"VCRLIN")         # hcb 50343
#                                                                                    # hcb 110327 deb
    Elsif PABR = "CHGS"
       [M:SGW]WPCUDES   ([M:SGW]NBLIG)    = evalue(LMABR+"PCUDES(I)")
       [M:SGW]WCOEDES   ([M:SGW]NBLIG)    = evalue(LMABR+"COEDES(I)")
       [M:SGW]VCRLIN    ([M:SGW]NBLIG)    = evalue(LMABR+"VCRLIN")
       [M:SGW]WLPNNUMDES([M:SGW]NBLIG)    = evalue(LMABR+"LPNNUMDES(I)")
#                                                                                    # hcb 110327 end
    Else
       [M:SGW]WPCUDES([M:SGW]NBLIG)    = evalue(LMABR+"PCUDES(I)")
       [M:SGW]WCOEDES([M:SGW]NBLIG)    = evalue(LMABR+"COEDES(I)")
    Endif
    [M:SGW]WQTYSTUDES([M:SGW]NBLIG) = LQTY

    If [M:SGW]WCOEDES([M:SGW]NBLIG)<>0
        [M:SGW]WQTYPCUDES([M:SGW]NBLIG) = LQTY/[M:SGW]WCOEDES([M:SGW]NBLIG)
    Else
        [M:SGW]WQTYPCUDES([M:SGW]NBLIG) = 0
    Endif
#                                                                       # hcb 113039 deb
    If PABR = "SQD"
       If LQTY = [M:SQD]QTYSTUDES(I)
          [M:SGW]WQTYPCUDES([M:SGW]NBLIG) = [M:SQD]QTYPCUDES(I)
       Endif
    Endif
#                                                                       # hcb 113039 fin
    If evalue("dim("+LMABR+"STADES(I))")>0    # Issue X3-67963 - 2018-01-05 by MAE
      [M:SGW]WSTADES([M:SGW]NBLIG)    = evalue(LMABR+"STADES(I)")
    Endif
    [M:SGW]QLYCTLFLG([M:SGW]NBLIG)  = 1
    If evalue("dim("+LMABR+"QLYCTLFLG)")>0 & left$([M:SGW]WSTADES([M:SGW]NBLIG),1)="Q"
        [M:SGW]QLYCTLFLG([M:SGW]NBLIG)  = evalue(LMABR+"QLYCTLFLG(I)")
    Endif
    If evalue("dim("+LMABR+"WRHDES(I))")>0
        [M:SGW]WWRHDES([M:SGW]NBLIG) = evalue(LMABR+"WRHDES(I)")
    Endif
    # Issue 102210 - 2014-08-26 by SR : ssi article géré en emplacement sur le site destination
    If evalue("dim("+LMABR+"LOCTYPDES(I))")>0 & [F:ITFD]LOCMGTCOD > 1
        [M:SGW]WLOCTYPDES([M:SGW]NBLIG) = evalue(LMABR+"LOCTYPDES(I)")
    Endif
# hcb 110505 28601 deb
    If evalue("dim("+LMABR+"PALNUMDES(I))")>0
        [M:SGW]WPALNUMDES([M:SGW]NBLIG) = evalue(LMABR+"PALNUMDES(I)")
    Else
        If LMABR = "[M:SQD]"                                                # hcb 43019
          If dim([M:SGW]WPALNUMDES([M:SGW]NBLIG))>0                         # hcb 43019
             If evalue("dim("+LMABR+"PALNUM)")>0
               [M:SGW]WPALNUMDES([M:SGW]NBLIG) = evalue(LMABR+"PALNUM")      # hcb 44915
             Endif
          Endif                                                            # hcb 43019
        Endif                                                               # hcb 43019
        If LMABR = "[M:STQ1]"                                               # hcb 44915
           If dim([M:SGW]WPALNUMDES([M:SGW]NBLIG))>0                        # hcb 44915
              If evalue("dim("+LMABR+"PALNUM)")>0
                [M:SGW]WPALNUMDES([M:SGW]NBLIG) = evalue(LMABR+"PALNUM(I)")   # hcb 44915
              Endif
           Endif                                                            # hcb 44915
        Endif                                                               # hcb 44915
        If LMABR = "[M:SMP1]"                                               # hcb 89707 deb
           If dim([M:SGW]WPALNUMDES([M:SGW]NBLIG))>0
              If evalue("dim("+LMABR+"PALNUM)")>0
                [M:SGW]WPALNUMDES([M:SGW]NBLIG) = evalue(LMABR+"PALNUM")
              Endif
           Endif
        Endif                                                               # hcb 89707 fin

    Endif
    If evalue("dim("+LMABR+"CTRNUMDES(I))")>0
        [M:SGW]WCTRNUMDES([M:SGW]NBLIG) = evalue(LMABR+"CTRNUMDES(I)")
    Else
        If LMABR = "[M:SQD]"                                                # hcb 43019
           If dim([M:SGW]WCTRNUMDES([M:SGW]NBLIG))>0                        # hcb 43019
              If evalue("dim("+LMABR+"CTRNUM)")>0
                 [M:SGW]WCTRNUMDES([M:SGW]NBLIG) = evalue(LMABR+"CTRNUM")      # hcb 44915
              Endif
           Endif                                                            # hcb 43019
        Endif                                                               # hcb 43019
        If LMABR = "[M:STQ1]"                                               # hcb 44915
           If dim([M:SGW]WCTRNUMDES([M:SGW]NBLIG))>0                        # hcb 44915
              If evalue("dim("+LMABR+"CTRNUM)")>0
                 [M:SGW]WCTRNUMDES([M:SGW]NBLIG) = evalue(LMABR+"CTRNUM(I)")   # hcb 44915
              Endif
           Endif                                                            # hcb 44915
        Endif                                                               # hcb 44915
        If LMABR = "[M:SMP1]"                                               # hcb 89707 deb
           If dim([M:SGW]WCTRNUMDES([M:SGW]NBLIG))>0
              If evalue("dim("+LMABR+"CTRNUM)")>0
                 [M:SGW]WCTRNUMDES([M:SGW]NBLIG) = evalue(LMABR+"CTRNUM")
              Endif
           Endif
        Endif                                                               # hcb 89707 fin

    Endif
# hcb 110505 28601 fin
    # Issue X3-67963 - 2018-01-05 by MAE : Gestion des LPN    # hcb X3-77043
#     If LMABR = "[M:LPNA]"
#        If evalue("dim("+LMABR+"LPNNUM(I))")>0
#           [M:SGW]WLPNNUMDES([M:SGW]NBLIG) = evalue(LMABR+"LPNNUM(I)")
#        Endif
#     Elsif (LMABR = "[M:STQ1]" | LMABR ="[M:CHGS]" | LMABR ="[M:SQD]"| LMABR ="[M:SMP]"| LMABR ="[M:SMP1]" | LMABR = "[M:LPNO]")
#        If evalue("dim("+LMABR+"LPNNUMDES(I))")>0
#          [M:SGW]WLPNNUMDES([M:SGW]NBLIG) = evalue(LMABR+"LPNNUMDES(I)")
#        Endif
#     Else
     If LMABR = "[M:SCD]"
        If evalue("dim("+LMABR+"LPNNUM)")>0
           If find([F:SRT]BETFCYCOD,2,5)                                       # hcb X3-67989
             [M:SGW]WLPNNUMDES([M:SGW]NBLIG) = evalue(LMABR+"LPNNUMDES(I)")    # hcb X3-67989
           Else                                                                # hcb X3-67989
             [M:SGW]WLPNNUMDES([M:SGW]NBLIG) = evalue(LMABR+"LPNNUM")
           Endif
        Endif
     Else
      If evalue("dim("+LMABR+"LPNNUMDES(I))")>0
          [M:SGW]WLPNNUMDES([M:SGW]NBLIG) = evalue(LMABR+"LPNNUMDES(I)")
        Endif
     Endif
    # End issue X3-67963
    If evalue("dim("+LMABR+"LOCDES(I))")>0 & [F:ITFD]LOCMGTCOD > 1   # hcb 36036

        Raz SVGGMESSAGE
        If dim([M:SCS1]LOCDESH)>0 & [M:SCS1]LOCDESH<>""
          If GMESSAGE<>"" SVGGMESSAGE=GMESSAGE Endif
        Endif

        If evalue(LMABR+"WLOCSEQ(I)")>100000
          [M:SGW]WLOCSEQ([M:SGW]NBLIG) = evalue(LMABR+"WLOCSEQ(I)")-100000
        Else
          [M:SGW]WLOCSEQ([M:SGW]NBLIG) = evalue(LMABR+"WLOCSEQ(I)")
        Endif
        Call STKDELRES([M:SGW]WLOCSEQ([M:SGW]NBLIG), [M:SGW]FCYDES,"",PRET) From STKLOC
        [M:SGW]WLOCDES([M:SGW]NBLIG)    = evalue(LMABR+"LOCDES(I)")
        If GWRHACT=2 & [M:SGW]WWRHDES([M:SGW]NBLIG)=""
           Read [STC]STC0=[M:SGW]FCYDES;[M:SGW]WLOCDES([M:SGW]NBLIG)
           If !fstat [M:SGW]WWRHDES([M:SGW]NBLIG)=[F:STC]WRH Endif
        Endif

        Call STKCTREMP([M:SGW]WLOCSEQ([M:SGW]NBLIG),
&                      [M:SGW]TRSTYP,[M:SGW]TRSCOD,
&                      [M:SGW]FCYDES,LITM,
&                      [M:SGW]WPCUDES([M:SGW]NBLIG),[M:SGW]WQTYPCUDES([M:SGW]NBLIG),
&                      [M:SGW]WSTADES([M:SGW]NBLIG),
&                      [M:SGW]WLOCTYPDES([M:SGW]NBLIG),[M:SGW]WLOCDES([M:SGW]NBLIG),
&                      "",0,mkstat,GBIDD1,
&                      string$([M:SGW]WLOCDES([M:SGW]NBLIG)=WLOC,"QU"),"",
&                      [M:SGW]WWRHDES([M:SGW]NBLIG)) From STKLOC
        Assign LMABR+"WLOCSEQ(I)" With [M:SGW]WLOCSEQ([M:SGW]NBLIG)

        If SVGGMESSAGE<>"" GMESSAGE=SVGGMESSAGE Endif

    Endif
    [M:SGW]WPOT([M:SGW]NBLIG) = LPOT
    # Dans le contrôle qualité on peut modifier les caractéristiques du lot => il faut les récupérer
    If PABR="STQ1" | PABR="SQD" | PABR="CHGS"                             # hcb 110327
        Call SETCPTLOT(PABR,LITM, I*evalue("dim("+LMABR+"LOT)>1"), [M:SGW]NBLIG) From SUBSTQB
    Endif
    If evalue("dim("+LMABR+"LBEFMT(I))")>0
       [M:SGW]WLBEFMT([M:SGW]NBLIG) = evalue(LMABR+"LBEFMT(I)")
    Endif
    If evalue("dim("+LMABR+"LBENBR(I))")>0
        [M:SGW]WLBENBR([M:SGW]NBLIG) = evalue(LMABR+"LBENBR(I)")
    Endif
    #---------- Les sections analytiques n'existent que pour les transferts inter-sites ---------#
    If LMABR="[M:SCD]"
        For ADD_I=1 To GNBDIE   # hcb ana
            Assign "[M:SGW]CCE"+num$(ADD_I)+"([M:SGW]NBLIG)" With [M:SCD]CCE(ADD_I-1)
            Assign "[M:SGW]CCS"+num$(ADD_I)+"([M:SGW]NBLIG)" With [M:SCD]CCS(ADD_I-1)
        Next
    Endif
#                                                                                   # hcb 110327 deb
    If  LMABR="[M:CHGS]"
        For ADD_I=1 To GNBDIE
            Assign "[M:SGW]CCE"+num$(ADD_I)+"([M:SGW]NBLIG)" With evalue("[M:CHGS]CCE"+num$(ADD_I)+"("+num$(I)+")")
            Assign "[M:SGW]CCS"+num$(ADD_I)+"([M:SGW]NBLIG)" With evalue("[M:CHGS]CCS"+num$(ADD_I)+"("+num$(I)+")")
        Next
    Endif

    If [F:ITM]SERMGTCOD = 4
       Local Integer LSEQIND
       Local Integer LRET
       If  LMABR="[M:CHGS]"
           # Issue X3-68496 : LPN split merge
           Call WSTOSEQIND ("CHGS", 0, LSEQIND, LRET) From SUBSCSB
           [M:CHGS]WSTOSEQIND(I) = LSEQIND
           #Call WSTOSEQIND (PABR, 0, LSEQIND, LRET) From SUBSCSB
           #Assign LMABR+"WSTOSEQIND(I)" With LSEQIND
       Else
           If evalue("dim("+LMABR+"WSTOSEQIND(I))")>0
              LSEQIND = evalue(LMABR+"WSTOSEQIND(I)")
           Endif
           If LSEQIND = 0
              Call WSTOSEQIND ("", 0, LSEQIND, LRET)     From SUBSCSB
           Endif
       Endif
       If LRET
          Return
       Endif
       [M:SGW]WSTOSEQIND([M:SGW]NBLIG) = LSEQIND
    Endif
#                                                                                   # hcb 110327 end
    # Transfert zones des écrans STOCHG, STOQUA (et SCS1) vers l'écran STOCHGW
    GPOINT="SCDSQD_SGW" : Gosub ENTREE From EXEFNC

Return

###############################################################################
# CTRSERNUM : contrôle que le numéro de série est utilisable
###############################################################################
# Paramètres E : PITM    = article
#                PFCY    = Site
#                PSER    = Numéro à contrôler
#                PSEQEX  = Numéro de séquence WSTOSEQ en cours
#                PPCU    = Unité à respecter
#                PSTA    = Statut à respecter
#                PLOC    = Emplacement à respecter
#                PSF1
#                PSF2
#                PLOC    = Contenant à respecter
#                PRES    = Réserver si ctrl OK (0=non / 1=Oui)
#
#            S : PRET    = Code retour
#                                0 : OK
#                                1 : N° déjà dans SGW
#                                2 : N° de série inexistant
#                                3 : Stock indisponible
#                                4 : Caractéristiques incorrectes
#
# La table STOCK est positionnée
###############################################################################
Subprog CTRSERNUM(PITM, PFCY, PSER, PSEQEX, PPCU, PSTA, PLOC, PLOT, PSLO, PPAL, PCTR, PSF1, PSF2, PLPN, PRES, PRET)
Value    Char    PITM
Value    Char    PFCY
Value    Char    PSER
Value    Integer PSEQEX
Value    Char    PPCU
Value    Char    PSTA
Value    Char    PLOC
Value    Char    PLOT  # FGR 18/01/2010 : X3SUIVI60986
Value    Char    PSLO  # FGR 18/01/2010 : X3SUIVI60986
Value    Char    PPAL  # FGR 18/01/2010 : X3SUIVI60986
Value    Char    PCTR  # FGR 18/01/2010 : X3SUIVI60986
Value    Char    PSF1
Value    Char    PSF2
Value    Char    PLPN    # hcb X3-77043
Value    Integer PRES
Variable Integer PRET

Local Integer F

Local Integer WTRBEGIN
# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [STO]
   WTRBEGIN=1
Endif

        #--- Issue 93226
        #------- Est-ce que le numéro est utilisé dans SGW?  -----#
        #F = sigma(0, [M:SGW]NBLIG-1, ( [M:SGW]WSTOSEQ(indcum)<>PSEQEX )
#&                                      & ( [M:SGW]WSTOSEQ(indcum)<>0 )
#&                                      & ( len([M:SGW]WSERNUM(indcum)) = len(PSER) )
#&                                      & ( [M:SGW]WSERNUM(indcum)  <= PSER )
#&                                      & ( [M:SGW]WSERNUMF(indcum) >= PSER ) )
        #If F
        #    PRET = 1
        #Else
        #---
            #------- Stock existant?  -----#
            Read [STO]STO5=PITM;PSER
            If fstat | [F:STO]STOFCY<>PFCY
                PRET = 2
            #------- Stock disponible?  -----#
            # On ne tient pas compte de ce qui est alloué (sauf en inter-sites): on doit juste avertir
            Elsif [F:STO]CUMWIPQTY+([F:STO]CUMALLQTY*([F:SRT]BETFCYCOD=2))>=[F:STO]QTYSTU
&               & !sigma(0, [M:SGW]NBLIG-1, ( [M:SGW]WSTOSEQ(indcum)=PSEQEX )
&                                      & ( len([M:SGW]WSERNUM(indcum)) = len(PSER) )
&                                      & ( [M:SGW]WSERNUM(indcum)  <= PSER )
&                                      & ( [M:SGW]WSERNUMF(indcum) >= PSER ) )
&               | [F:STO]CUNLOKFLG=2
                PRET = 3
            #------- Caractéristiques Stock OK?  -----#
#                                       rajout  [F:STO]LPNNUM<>PLPN    # hcb X3-77043
            Elsif  [F:STO]PCU<>PPCU
&                | [F:STO]STA<>PSTA
&                | [F:STO]LOC<>PLOC
&                | [F:STO]LOC<>PLOC
&                | [F:STO]LPNNUM<>PLPN
&                | [F:STO]SLO<>PSLO
&                | [F:STO]PALNUM<>PPAL
&                | [F:STO]CTRNUM<>PCTR
&                | [F:STO]STOFLD1<>PSF1
&                | [F:STO]STOFLD2<>PSF2
                PRET = 4
            Elsif PRES
                Readlock [F:STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
                If !fstat                                                    # hcb 120310
                   [F:STO]CUMWIPQTY = [F:STO]QTYSTU-[F:STO]CUMALLQTY
                   [F:STO]CUMWIPQTA = [F:STO]QTYSTUACT-[F:STO]CUMALLQTA
                   Rewrite [STO]
                   # Création quantité en cours de traitement
                   Call CRE_STOWIPW([F:STO]STOCOU,[F:STO]CUMWIPQTY,[F:STO]CUMWIPQTA) From STKLIB
                Endif                                                        # hcb 120310
            Endif
        #--- Issue 93226
        #Endif

# Si on a ouvert une transaction
If WTRBEGIN=1
   Commit
   Raz WTRBEGIN
Endif

End

###############################################################################
# PFCY    = site
# LSTOCOU = Chrono stock
# LQTY    = Quantité à réserver
# LPOT    = coef. permettant de calculer la quantité en UA
# LQTYRES = Quantité réservée

$CRERESSTO
Local Integer WTRBEGIN
# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [STO]
   WTRBEGIN=1
Endif
Readlock [STO]STO0=PSTOFCY;LSTOCOU
If !fstat
    If [F:ITF]STOMGTCOD=3
        If [F:STL]ITMREF<>[F:STO]ITMREF | [F:STL]LOT<>[F:STO]LOT | [F:STL]SLO<>[F:STO]SLO
            Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
        Endif
        LPOT = [F:STL]POT/100
    Else
        LPOT = 1
    Endif
  If dim([F:SRT]BETFCYCOD) > 0    # Issue X3-67963 - 2017-12-19 by MAE
    LQTY = max(0, min(LQTY, [F:STO]QTYSTU-[F:STO]CUMWIPQTY-([F:STO]CUMALLQTY*([F:SRT]BETFCYCOD=2))) )
  Else
    LQTY = max(0, min(LQTY, [F:STO]QTYSTU-[F:STO]CUMWIPQTY))
  Endif

    # Si mouvement interne avec chgt emplacement et priorité aux allocations
    If PABR="SCS1" & [M:SCS1]BETFCYCOD=1 & [F:SRT]CHGEMPCOD=2 & [F:SRT]PIOQTY=3
       LQTYRES = max(0,LQTY-[F:STO]CUMALLQTY)
    Else
       LQTYRES = min(LQTY,[F:STO]QTYSTU-[F:STO]CUMWIPQTY-[F:STO]CUMALLQTY)
    Endif

    If LQTY>0
        [F:STO]CUMWIPQTY += LQTYRES
        [F:STO]CUMWIPQTA += LQTYRES*LPOT
        Rewrite [STO]
        # Création quantité en cours de traitement
        Call CRE_STOWIPW([F:STO]STOCOU,LQTYRES,LQTYRES*LPOT) From STKLIB
#      l eventuel appel au CRE_STOSERW est fait au retour du CRERESSTO      # hcb 110327
    Else
        Unlock [STO]
    Endif
Endif

# Si on a ouvert une transaction
If WTRBEGIN=1
   Commit
   Raz WTRBEGIN
Endif

Return

###############################################################################
# DELSTOCHGW : Efface le détail de N lignes de document changement stock
###############################################################################
# Paramètres E : PABR   = Abréviation de l'écran document
#                PFCY   = Site de départ
#                PLIG   = Premier indice de ligne de document supprimé
#                         (= -1 -> supprime toutes les lignes par RAZ)
#                PLIG1  = N-ième indice de ligne de document à supprimer
#                PDELLOC= Indique s'il faut supprimer les réservations d'emplacement
#
#            S : PRET   = Code retour (0=OK, 1=Erreur)
#
# Appelé dans le cadre de la suppression d'un bloc de ligne
# ou de toutes les lignes
###############################################################################
Subprog DELSTOCHGW( PABR, PFCY, PLIG, PLIG1, PDELLOC, PRET )
Value    Char    PABR
Value    Char    PFCY
Value    Integer PLIG
Value    Integer PLIG1
Value    Integer PDELLOC
Variable Integer PRET

    Call DELSTOCHGW2( PABR, PFCY, PLIG, PLIG1, PDELLOC, 1, PRET )

End

# Issue 120553 - 2017-01-17 by CCC : Need to not reset VALW
# Idem DELSTOCHGW but with 1 more parameter
#   PPRI = 0:Reset VALW ; 1:don't reset VALW
Subprog DELSTOCHGW2( PABR, PFCY, PLIG, PLIG1, PDELLOC, PPRI, PRET )
Value    Char    PABR
Value    Char    PFCY
Value    Integer PLIG
Value    Integer PLIG1
Value    Integer PDELLOC
Value    Integer PPRI
Variable Integer PRET

Local Integer I, IND, F

Local Integer WTRBEGIN
Local Decimal LSTOCOU
Local Decimal LWIPQTY, LWIPQTA
Local Integer LTRSTYP
Local Char    LTRSCOD(5), LFCYDES(5)

Raz WTRBEGIN

If clalev([F:STO1])=0  Local File STOCK   [STO1]  Endif
If clalev([F:SWW]) =0  Local File STOWIPW [SWW]   Endif

# On fait 2 boucles pour ne pas déphaser les qtes en cours de traitement
# de la table [STO1] et l'écran de stockage des lignes à sortir en cas de
# problème sur la table stock

# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [STO1]
   WTRBEGIN=1
Endif
For I=0 To [M:SGW]NBLIG-1
    If [M:SGW]WSTOSEQ(I)>0 & (PLIG=-1 | evalue("find([M:SGW]WSTOSEQ(I),[M:"+PABR+"]WSTOSEQ(PLIG..PLIG1))"))
        Readlock [STO1]STO0=PFCY;[M:SGW]WSTOCOU(I)
        If fstat
            If fstat=1
                GOK=0
                Call RSTA("STO1",PFCY-num$([M:SGW]WSTOCOU(I))) From GLOCK
                LRET=1 : Break
            Endif
        Else
            # Dans le cas où l'on serait passé en négatif
            If [F:STO1]SERNUM<>""
                LWIPQTY = [F:STO1]QTYSTU
                LWIPQTA = [F:STO1]QTYSTUACT
            Else
                LWIPQTY = [M:SGW]WWIPQTY(I)
                LWIPQTA = [M:SGW]WWIPQTA(I)
            Endif
            [F:STO1]CUMWIPQTY  = max(0,[F:STO1]CUMWIPQTY-LWIPQTY)
            [F:STO1]CUMWIPQTA  = max(0,[F:STO1]CUMWIPQTA-LWIPQTA)

            # Suppression qté en cours de traitement
            LSTOCOU = [F:STO1]STOCOU
            Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB
            Rewrite [STO1]
            If fstat
                GOK=0  : Call FSTA("STO1") From GLOCK
                LRET=1 : Break
            Endif
#                                                                                               # hcb 110327 deb
            If [M:SGW]WSTOSEQIND(I) <> 0 & [M:SGW]WSERNUM(I) <> ""
               # Suppression série en cours de traitement
               Call DEL_STOSERW([F:STO1]ITMREF,[M:SGW]WSERNUM(I),[M:SGW]WQTYSTUDES(I),PRET) From STKLIB
               If PRET <>0
                  Break
               Endif
             Endif
            [M:SGW]WSTOSEQ(I) = 0
#                                                                                               # hcb 110327 fin
            [M:SGW]WSTOCOU(I) = 0
            IND+=1
        Endif
    Endif
Next I

# Si on a ouvert une transaction
If WTRBEGIN=1
    If GOK=0
        Rollback
        End
    Else
        Commit
        Raz WTRBEGIN
    Endif
Endif

# Si traitement de toutes les lignes (abandon de la saisie document)
If PLIG=-1
    Call STKDELRES(0, "", "", PRET) From STKLOC
    If !PRET
        LTRSTYP = [M:SGW]TRSTYP
        LTRSCOD = [M:SGW]TRSCOD
        LFCYDES = [M:SGW]FCYDES
        Raz [M:SGW]
        [M:SGW]TRSTYP = LTRSTYP
        [M:SGW]TRSCOD = LTRSCOD
        [M:SGW]FCYDES = LFCYDES
        If clalev([M:VALW])
            Local Char LTMP1(30), LTMP2(30)    # ZONPRI contient aussi l'abréviation du masque
            LTMP1 = [M:VALW]ZONPRI
            LTMP2 = [M:VALW]ZONPRIORD
            Raz [M:VALW]
            [M:VALW]ZONPRI = LTMP1
            [M:VALW]ZONPRIORD = LTMP2
        Endif
    Endif
    End
Endif

For I=0 To [M:SGW]NBLIG-1
    If evalue("find([M:SGW]WSTOSEQ(I),[M:"+PABR+"]WSTOSEQ(PLIG..PLIG1))")
        If PDELLOC
            Call STKDELRES([M:SGW]WLOCSEQ(I), "", "", PRET) From STKLOC
        Endif
        Raz [M:SGW]WSTOSEQ(I),[M:SGW]WQTYPCUDES(I)
    Endif
# Issue 120553 - 2017-01-16 by CCC
#    If clalev([M:VALW])
#        J=evalue("find([M:VALW]WSTOSEQ(I),[M:"+PABR+"]WSTOSEQ(PLIG..PLIG1))")
#        If J>0
#            Raz [M:VALW]WSTOSEQ(J-1)
#        Endif
#    Endif

Next I

# Issue 120553 - 2017-01-16 by CCC
If PPRI=1 & clalev([M:VALW])
    For I=0 To [M:VALW]NBLIG-1
        J=evalue("find([M:VALW]WSTOSEQ(I),[M:"+PABR+"]WSTOSEQ(PLIG..PLIG1))")
        If J>0
            Raz [M:VALW]WSTOSEQ(I)
        Endif
    Next I
Endif

End


###############################################################################
# CTLSTOCHG : Effectue divers contrôle pour s'assurer d'un bon enregistrement
###############################################################################
# Paramètres S : POK = Indique si le contrôle est bon
#                      (0=Erreur / 1=OK)
###############################################################################
Subprog CTLSTOCHG( POK )
Variable Integer POK

Local Decimal WARR, WQTYPCU
Local Integer I, J, K, L                      # hcb X3-67989

Raz POK,I,J

If GREP<>"M" & sigma( 0,[M:SCS1]NBLIG-1, [M:SCS1]CREFLG(indcum)=0)=0
    End
Endif
If sigma( 0,[M:SCS1]NBLIG-1, ([M:SCS1]WSTOFLG(indcum)=0) & ([M:SCS1]CREFLG(indcum)=0) & I=0 & sigma(I=indcum+1,indcum+1,1))
    Call ECR_TRACE( mess(17,104,1)-num$(I-1)+chr$(13)+mess(7,111,1),1 ) From GESECRAN
    End
Endif

# Pour ne pas effectuer le contrôle suivant
GPOINT="NO_CTLSTOCHG" : Gosub ENTREE From EXEFNC
If POK=1 End Endif

# Contrôle que la qté US correspond à un nombre entier d'UC
# (fonction du nb de décimales de l'UC)
If !clalev([F:TUN]) Local File TABUNIT [TUN] Endif

#--- Issue 113595
POK=1

For I=0 To [M:SGW]NBLIG-1
    If [M:SGW]WSTOSEQ(I)<>0 & !find([M:SGW]WCOEDES(I),0,1)
        Read [TUN]TUN0=[M:SGW]WPCUDES(I)
        If !fstat
            Case [F:TUN]UOMDEC
             When 1       : WARR=0.1
             When 2       : WARR=0.01
             When 3       : WARR=0.001
             When 4       : WARR=0.0001
             When 5       : WARR=0.00001
             When 6       : WARR=0.000001
             When Default : WARR=1
            Endcase
            WQTYPCU = arr([M:SGW]WQTYPCUDES(I),WARR)
            If WQTYPCU<>[M:SGW]WQTYPCUDES(I)
                J=find([M:SGW]WSTOSEQ(I),[M:SCS1]WSTOSEQ(0..[M:SCS1]NBLIG-1))
                If J<>0
                    Call ECR_TRACE([M:SCS1]ITMREF(J-1)-":"-mess(160,184,1)-"("+[M:SGW]WPCUDES(I)+")",1) From GESECRAN
                Else
                    Call ECR_TRACE(mess(160,184,1)-"("+[M:SGW]WPCUDES(I)+")",1) From GESECRAN
                Endif
                #--- Issue 113595
                #End
                POK=0 : Break
                #---
            Endif
        Endif
    Endif
#                                                             # hcb X3-67989 deb
# controle meme emplacement pour chaque contenant
    If find([F:SRT]BETFCYCOD,2,5) & [F:ITFD]LPNMGTCOD = 2 & [F:SRT]CHGEMPCOD = 2 &  [M:SGW]WSTOSEQ(I)<>0 & [M:SGW]WLPNNUMDES(I) <> ""
#---contrôle du mono-emplacement par LPN
       K=sigma(I+1,[M:SGW]NBLIG-1,1*([M:SGW]WLPNNUMDES(indcum)=[M:SGW]WLPNNUMDES(I) & [M:SGW]WSTOSEQ(indcum)<>0))
       L=sigma(I+1,[M:SGW]NBLIG-1,1*([M:SGW]WLPNNUMDES(indcum)=[M:SGW]WLPNNUMDES(I) & [M:SGW]WSTOSEQ(indcum)<>0
&                & [M:SGW]WLOCDES(indcum)=[M:SGW]WLOCDES(I)))
       If K<>L
          Call ERREUR(func AFNC.MES2(mess(521,184,1),[M:SGW]WLPNNUMDES(I),[M:SGW]WLOCDES(I))) From GESECRAN
          POK = 0
          Break
       Endif
    Endif
#                                                             # hcb X3-67989 fin

Next I

If POK = 0                                                        # hcb X3-67989
   End                                                            # hcb X3-67989
Endif                                                             # hcb X3-67989
#--- Issue 113595
#POK = 1
#                                                                  # hcb 110327 deb
For I=0 To [M:SCS1]NBLIG-1
    If [F:ITM]ITMREF<>[M:SCS1]ITMREF(I)
       Read [ITM]ITM0=[M:SCS1]ITMREF(I)
       If fstat
          Raz [F:ITM]
       Endif
    Endif
    If [F:ITM]SERMGTCOD = 4 & [M:SCS1]WSTOSEQ(I)<>0
        J=find([M:SCS1]WSTOSEQ(I),[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))
          If [M:SGW]WSERNUM(J-1) = "" & [M:SGW]WQTYSTUDES(J-1) <> 0
             GMESSAGE=mess(3,40,1)-num$(I+1)-mess(246,199,1)
             POK=0    : Break
          Endif
   Endif
Next
#                                                                  # hcb 110327 end

End

###############################################################################
# ALISTW : Alimente le masque STOWORK et effectue la mise à jour des tables stock
###############################################################################
# Paramètres E : PNOL = indice de la ligne en cours d'enregistrement
###############################################################################
Subprog ALISTW( PNOL )
Value Integer PNOL
Local Decimal LQTA
Local Decimal LSHT
Local Integer LRET
Local Integer LNBR, LNBJ
# Initialisation de l'en-tête

[M:STW]STOFCY     = [M:SCS1]STOFCY      # Site
[M:STW]TRFFCY     = [M:SCS1]FCYDES
[M:STW]TRSTYP     = [M:SCS1]TRSTYP      # Type mouvement (M.704)
[M:STW]VCRTYP     = [M:SCS1]VCRTYP      # Type pièce (M.701)
[M:STW]VCRNUM     = [F:SGD]VCRNUM       # Numéro pièce
[M:STW]VCRLIN     = [F:SGD]VCRLIN       # Numero ligne pièce
[M:STW]ITMREF     = [M:SCS1]ITMREF(PNOL) # Article
[M:STW]MVTDES     = [M:SCS1]MVTDES(PNOL) # Désignation mouvement
If GIMPORT                                # hcb 119744
   [M:STW]MVTDES     = [F:STJ]MVTDES      # hcb 119744
Endif                                     # hcb 119744
[M:STW]TRSFAM     = [M:SCS1]TRSFAM      # Famille mouvement
[M:STW]ENTCOD     = [M:SCS1]ENTCOD      # Famille mouvement
[M:STW]IPTDAT     = [M:SCS1]IPTDAT      # Date imputation
[M:STW]TRSCOD     = [M:SCS1]TRSCOD      # Code mouvement
[M:STW]BETCPY     = [M:SCS1]BETCPY
[M:STW]PJT        = [M:SCS1]PJT         # Affaire
[M:STW]MISFLG     = [M:SCS1]MISFLG      # = 9 (origine re-controle pour creer STOQLYH avec fiche technique de re-controle)

If [M:SCS1]BETFCYCOD=1 & [F:SRT]CHGEMPCOD=2
   [M:STW]PIOQTY = [F:SRT]PIOQTY
Endif

If [M:SCS1]BETCPY=2
   [M:STW]CCECOD     = "STJICOE"
   [M:STW]CCSCOD     = "STJICOI"
   # Conversion du prix dans la devise du site destination
   If [M:SCS1]CUR<>[M:SCS1]CURDES
      Call CONVERT2([M:SCS1]CUR,[M:SCS1]CURDES,[M:SCS1]CURDES,[M:SCS1]CHGTYP,
&          [M:SCS1]IPTDAT,[M:SCS1]PRI(PNOL),[M:STW]PRIORDH,LRET) From TRTDEV
   Else
      [M:STW]PRIORDH = [M:SCS1]PRI(PNOL)
   Endif
   [M:STW]CUR        = [M:SCS1]CURDES
Elsif [M:SCS1]STOFCY<>[M:SCS1]FCYDES
   [M:STW]CCECOD     = "STJTRSE"
   [M:STW]CCSCOD     = "STJTRSI"
Endif
Call ALISTOWORK( 7, [M:SCS1]WSTOSEQ(PNOL), LQTA, LSHT, LNBR, LNBJ, LRET ) From STKINT

If !LRET
   Call MAJ_STOCK From STKMAJ
Else
   GOK = 0
Endif

End

##################################################################################
# Action SAIZONCHG appelée en avant saisie de chaque champ stock de la ligne     #
#         Permet d'interdire la saisie d'un champ si Diszo et Grizo non utilisés #
##################################################################################
# Paramètres E : LZON = Nom du champ
#                LLIN = Indice de la ligne en cours de saisie (nolign-1)
#                La classe [M] par défaut est celle du tableau des lignes article
##################################################################################
Subprog SAIZONCHG(LZON,LLIN)
Value    Char     LZON
Value    Integer  LLIN
#-----
Local    Libelle WPOS
Local    Integer I
#-----
If dim([M]WSAIFLG)>0
  Case LZON
    When "QTYSTUDES"    : WPOS=0
    When "PCUDES"       : WPOS=1
    When "COEDES"       : WPOS=2
    When "STADES"       : WPOS=3
    When "LOCTYPDES"    : WPOS=4
    When "LOCDES"       : WPOS=5
    When "LPNNUMDES"    : WPOS=6                                       # hcb X3-77043
    When Default        : WPOS=0
  Endcase
  If WPOS
    I=instr(0,[M]WSAIFLG(LLIN),"2")
    mkstat= ((I>0)&(I<=WPOS))*2
  Endif
Endif
End

##################################################################################
Subprog CALCSAIZON( POK, PNOMZON )
Value    Integer  POK
Value    Char     PNOMZON
#-----
Local    Libelle  WPOS
#-----
If dim([M]WSAIFLG)>0
  Case PNOMZON
    When "QTYSTUDES"    : WPOS=1
    When "PCUDES"       : WPOS=2
    When "COEDES"       : WPOS=3
    When "STADES"       : WPOS=4
    When "LOCTYPDES"    : WPOS=5
    When "LOCDES"       : WPOS=6
    When "LPNNUMDES"    : WPOS=7                                       # hcb X3-77043

  Endcase
  If WPOS
    If POK
        If WPOS=1
          [M]WSAIFLG(nolign-1) = "0000"+right$([M]WSAIFLG(nolign-1),5)
        Else
          [M]WSAIFLG(nolign-1) = string$(WPOS+1,"0")+right$([M]WSAIFLG(nolign-1),WPOS+2)
        Endif
    Else
        [M]WSAIFLG(nolign-1) = string$(WPOS-1,"0")+"2"+right$([M]WSAIFLG(nolign-1),WPOS+1)
    Endif
  Endif
Endif
End

###############################################################################
# Mise à jour des quantités après saisie du détail
# LABR doit contenir l'abréviation du masque concerné
###############################################################################
$MAJ_LIG_DOC
Default Mask "[M:"+LABR+"]"
#             Rajour test LPNNUMDES                      # hcb X3-77043
    If LPCU="" | LCOEF=0
&    | [M]STADES(LLIGDOC) = "$" | evalue("dim([M:"+LABR+"]QLYCTLDEM)>0") & [M]QLYCTLDEM(LLIGDOC)<>""
&    | evalue("dim([M:"+LABR+"]LOCTYPDES)")>0 & evalue("dim([M:"+LABR+"]LOCDES)")>0 & ([M]LOCTYPDES(LLIGDOC) = "$" | [M]LOCDES(LLIGDOC) = "$")
&    | evalue("dim([M:"+LABR+"]LPNNUMDES)")>0 & ([M]LPNNUMDES(LLIGDOC) = "$")
        If dim([M]SERNUM)>0
            Diszo [M]SERNUM(LLIGDOC)
        Endif
        Diszo [M]PCUDES(LLIGDOC)
        Diszo [M]STADES(LLIGDOC)
        If dim([M]LOCTYPDES)>0
            Diszo [M]LOCTYPDES(LLIGDOC), LOCDES(LLIGDOC)
        Endif
        If dim([M]LPNNUMDES)>0                                            # hcb X3-77043
            Diszo [M]LPNNUMDES(LLIGDOC)                                   # hcb X3-77043
        Endif                                                             # hcb X3-77043
        [M]WSAIFLG(LLIGDOC)="222222"
    Else
        If dim([M]SERNUM)>0 & [M]SERNUM(LLIGDOC)="" Actzo [M]PCUDES(LLIGDOC) Endif
        Actzo [M]STADES(LLIGDOC)
        If dim([M]LPNNUMDES)>0                                                     # hcb X3-77043
           Diszo [M]LOCTYPDES(LLIGDOC), LOCDES(LLIGDOC)                            # hcb X3-77043
           Actzo [M]LPNNUMDES(LLIGDOC)                                             # hcb X3-77043
        Else                                                                       # hcb X3-77043
           If dim([M]LOCTYPDES)>0
              Actzo [M]LOCTYPDES(LLIGDOC), LOCDES(LLIGDOC)
           Endif
        Endif                                                                      # hcb X3-77043
        [M]WSAIFLG(LLIGDOC)="000000"
    Endif
    If (LPCU="" | LCOEF=0) & LQTYSTU<> 0
        [M]PCUDES(LLIGDOC) = "$"
        [M]COEDES(LLIGDOC) = 0
        [M]QTYPCUDES(LLIGDOC)= 0
    Elsif LQTYSTU=0
        [M]PCUDES(LLIGDOC) = [M]PCU(LLIGDOC)
        [M]COEDES(LLIGDOC) = [M]PCUSTUCOE(LLIGDOC)
        [M]QTYPCUDES(LLIGDOC)= 0
    Else
        [M]PCUDES(LLIGDOC) = LPCU
        [M]COEDES(LLIGDOC) = LCOEF
        [M]QTYPCUDES(LLIGDOC)= LQTYSTU / LCOEF
        Call QTEARR([M]QTYPCUDES(LLIGDOC), LPCU) From TRTDIV
    Endif
    [M]QTYSTUDES(LLIGDOC) = LQTYSTU
    If [M]PCUSTUCOE(LLIGDOC)<>0 & clalev([M:SCS1])    # On ne met à jour la quantité UC de base que pour les changements stock
        [M]QTYPCU(LLIGDOC)    = LQTYSTU / [M]PCUSTUCOE(LLIGDOC)
    Endif
    Call QTEARR([M]QTYPCU(LLIGDOC),[M]PCU(LLIGDOC)) From TRTDIV

    Affzo [M]QTYPCU(LLIGDOC),QTYSTUDES(LLIGDOC),PCUDES(LLIGDOC), COEDES(LLIGDOC),
&            QTYPCUDES(LLIGDOC), STADES(LLIGDOC)
    If evalue("dim([M:"+LABR+"]QLYCTLFLG)")>0
        If [M]NBLIG=1 & [M]QLYCTLFLG(LLIGDOC)=2
            Actzo QLYCTLFLG(LLIGDOC)
        Else
            Diszo QLYCTLFLG(LLIGDOC)
        Endif
        Affzo QLYCTLFLG(LLIGDOC)
    Endif
   If evalue("dim([M:"+LABR+"]LPNNUMDES)")>0                                      # hcb X3-77043
        Affzo [M]LPNNUMDES(LLIGDOC)                                               # hcb X3-77043
    Endif                                                                         # hcb X3-77043
    If evalue("dim([M:"+LABR+"]LOCTYPDES)")>0 & evalue("dim([M:"+LABR+"]LOCDES)")>0
        Affzo [M]LOCTYPDES(LLIGDOC), LOCDES(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]SERNUM)")>0
        Affzo[M]SERNUM(LLIGDOC),SERNUMF(LLIGDOC)
    Endif


    If evalue("dim([M:"+LABR+"]MVTDES)")>0
        Affzo [M]MVTDES(LLIGDOC)
    Endif
# hcb 110505 28601 deb
    If evalue("dim([M:"+LABR+"]PALNUMDES)")>0
        Affzo [M]PALNUMDES(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]CTRNUMDES)")>0
        Affzo [M]CTRNUMDES(LLIGDOC)
    Endif
# hcb 110505 28601 fin

    If evalue("dim([M:"+LABR+"]IPTDAT)")>0
        Affzo [M]IPTDAT(LLIGDOC)
    Endif

# Normalement cela se fait s'il y a plusieurs lignes de détail
# aussi bien dans le changement stock que dans le contrôle qualité
#    Call DISZOSTO( LABR, LLIGDOC ) From SUBSCSB
#                                                             # hcb   110327 deb
    If evalue("dim([M:"+LABR+"]ENRDETFLG)")>0
       [M]ENRDETFLG(LLIGDOC) = 2
    Endif
#                                                             # hcb   110327 end
    mkstat = 4
    GRAFFRAICHISCS = 1

Return

###############################################################################
# RECCHG_M : Renvoie les valeurs à afficher dans le document, à partir
#            des données contenues dans STOCHGW
###############################################################################
# Paramètres E : PSEQ    = WSTOSEQ
#
#            S : PSTA    = Retourne le statut s'il est unique sinon $
#                PLOCTYP = Retourne le type d'emplacement s'il est unique sinon $
#                PLOC    = Retourne l'emplacement s'il est unique sinon $
#                PSER    = Retourne le premier n° de série
#                PSERF   = Retourne le dernier n° de série si la suite est continue
#                          sinon $
#                PQLYFLG = Indique s'il y a eu un contrôle qualité généré
#                PABR    = Abréviation du masque
#                PNOL    = No ligne écran du masque (nolign-1)
#                PPAL    = Retourne l'identifiant 1 s il est unique sinon $
#                PCTR    = Retourne l'identifiant 2 s il est unique sinon $
#                PLPN    = Retourne le contenant  2 s il est unique sinon $                  # hcb X3-67989

###############################################################################
Subprog RECCHG_M( PSEQ, PSTA, PLOCTYP, PLOC, PSER, PSERF, PQLYFLG, PABR, PNOL,PPAL,PCTR,PLPN)
Value    Integer PSEQ
Variable Char    PSTA
Variable Char    PLOCTYP
Variable Char    PLOC
Variable Char    PSER
Variable Char    PSERF
Variable Integer PQLYFLG
Value    Char    PABR
Value    Integer PNOL
Variable Char    PPAL                     # hcb 110505 28601
Variable Char    PCTR                     # hcb 110505 28601
Variable Char    PLPN                     # hcb X3-67989
Raz PPAL, PCTR                            # hcb 110505 28601
Local Char PCAR : PCAR = "$"
Local Integer I,J
Local Integer LRET
Local Integer LNBDET, LNBEG
I = find(PSEQ,[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))
If I>0
    I-=1
    PSTA    = [M:SGW]WSTADES   (I)
    PLOCTYP = [M:SGW]WLOCTYPDES(I)
    PLOC    = [M:SGW]WLOCDES   (I)
    If dim([M:SGW]WLPNNUMDES) > 0          # hcb X3-67989
       PLPN = [M:SGW]WLPNNUMDES(I)         # hcb X3-67989
    Endif                                  # hcb X3-67989
    If dim([M:SGW]WPALNUMDES) > 0          # hcb 110505 28601
       PPAL = [M:SGW]WPALNUMDES(I)         # hcb 110505 28601
    Endif                                  # hcb 110505 28601
    If dim([M:SGW]WCTRNUMDES) > 0          # hcb 110505 28601
       PCTR = [M:SGW]WCTRNUMDES(I)         # hcb 110505 28601
    Endif                                  # hcb 110505 28601
    LNBDET = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ))
    LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WSTADES(indcum)=PSTA) )
    If LNBEG<>LNBDET
        PSTA = PCAR
    Endif
#---
    LNBEG = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&(left$([M:SGW]WSTADES(indcum),1)="Q") )
    PQLYFLG = 1
    If LNBEG>0 & PABR="SCS1"
       If [M:SCS1]BETFCYCOD=2
          PQLYFLG=[F:SRU]QLYCTLFLG
       Elsif [M:SCS1]BETFCYCOD=1 & left$([M:SCS1]STA(PNOL),1)<>"Q"
          PQLYFLG=[F:SRU]QLYCTLFLG
       Endif
    Endif
#---
    If PLPN<>""                                                                                             # hcb X3-67989
        LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WLPNNUMDES(indcum)=PLPN) )   # hcb X3-67989
        If LNBEG<>LNBDET                                                                                    # hcb X3-67989
            PLPN = PCAR                                                                                     # hcb X3-67989
        Endif                                                                                               # hcb X3-67989
    Endif                                                                                                   # hcb X3-67989
    If PLOCTYP<>""
        LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WLOCTYPDES(indcum)=PLOCTYP) )
        If LNBEG<>LNBDET
            PLOCTYP = PCAR
        Endif
        LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WLOCDES(indcum)=PLOC) )
        If LNBEG<>LNBDET
            PLOC = PCAR
        Endif
    Endif
# hcb 110505 28601 deb
#---
    If PPAL<>""
        LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WPALNUMDES(indcum)=PPAL) )
        If LNBEG<>LNBDET
            PPAL = PCAR
        Endif
    Endif
    If PCTR<>""
        LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WCTRNUMDES(indcum)=PCTR) )
        If LNBEG<>LNBDET
            PCTR = PCAR
        Endif
    Endif
# hcb 110505 28601 fin

    If [M:SGW]WSERNUM<>""
        Local Char LTABSER(GLONSER)(LNBDET)
        Local Char LTABSERF(GLONSER)(LNBDET)
        For J=0 To LNBDET-1
            LTABSER(J)  = [M:SGW]WSERNUM(I+J)
            LTABSERF(J) = [M:SGW]WSERNUMF(I+J)
        Next
        Sorta LTABSER, LTABSERF
        PSER  = LTABSER(0)
        PSERF = LTABSERF(0)
        For J=1 To LNBDET-1
            Call PLUS_UN(LTABSERF(J-1),LTABSERF(J-1), LRET) From STKLIB
            If LTABSER(J) <> LTABSERF(J-1)
                PSERF = PCAR
            Else
                PSERF = LTABSERF(J)
            Endif
        Next
    Endif
Endif

End



###############################################################################
# DEPICK : Depick d'une ligne de stock
###############################################################################
# Paramètres E : PSTOFCY = Site
#                PSTOCOU = Chrono stock
#                PABR    = Abréviation de l'écran document
#                PRET    = Code retour (0=OK, 1=Erreur)
#
# Il faut faire Affzo du mask en sortie
###############################################################################
Subprog DEPICK(PSTOFCY, PSTOCOU, PABR, PRET)
Value Char    PSTOFCY
Value Decimal PSTOCOU
Value Char    PABR
Variable Integer PRET

Local Integer  LRET
Local Shortint WRET
Local Integer  LSEQ
Local Integer  I1, LLIGDOC
Local Decimal  LWIPQTY, LWIPQTA
Local Integer  LNB
Local Char     LPCU(GLONUOM)
Local Decimal  LCOEF, LQTYSTYU
Local Decimal  LSTOCOU
Local Char     LSERF(GLONSER)
Local Integer  WTRBEGIN



Local Char     LABR(10) : LABR = PABR    # Utilisée dans MAJ_LIG_DOC


#-- Toute sortie prématurée est signe d'erreur
PRET = 1

Raz WTRBEGIN
If clalev([F:STO1])=0  Local File STOCK   [STO1]  Endif
If clalev([F:SWW]) =0  Local File STOWIPW [SWW]   Endif

# Si pas de transaction en cours
If adxlog<>1
#   GOK=0     hcb  40625
   Trbegin [STO1]
   WTRBEGIN=1
Endif

Readlock [STO1]STO0=PSTOFCY;PSTOCOU
If fstat
    Goto ENDTRANSAC
Endif


If [F:STO1]SERNUM<>""
    I1 = find(PSTOCOU, [M:SGW]WSTOCOU(0..[M:SGW]NBLIG-1))
    If !I1 : Goto ENDTRANSAC : Endif
    I1 -= 1
    LSEQ = [M:SGW]WSTOSEQ(I1)
    LLIGDOC = evalue("find(LSEQ, [M:"+PABR+"]WSTOSEQ(0..[M:"+PABR+"]NBLIG))")
    If !LLIGDOC : Goto ENDTRANSAC : Else LLIGDOC-=1 : Endif
    If [F:STO1]SERNUM<>evalue("[M:"+PABR+"]SERNUMF(LLIGDOC)")
        GMESSAGE = mess(58,184,1)+evalue("[M:"+PABR+"]SERNUMF(LLIGDOC)")
        Goto ENDTRANSAC
    Endif
    [M:SGW]WSTOSEQ(I1)   = 0
    [M:SGW]WSTOCOU(I1)   = 0
    [M:SGW]WQTYPCUDES(I1)= 0
#    [M:SGW]WQTYSTUDES(I1)= 0                                 # hcb 110327


    # Dans le cas où l'on serait passé en négatif
    LWIPQTY = min([F:STO1]CUMWIPQTY, [F:STO1]QTYSTU)
    LWIPQTA = min([F:STO1]CUMWIPQTA, [F:STO1]QTYSTUACT)
    [F:STO1]CUMWIPQTY -= LWIPQTY
    [F:STO1]CUMWIPQTA -= LWIPQTA
    # Suppression qté en cours de traitement
    LSTOCOU = [F:STO1]STOCOU
    Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB
    Rewrite [F:STO1]
#                                                                                               # hcb 110327 deb
    If [M:SGW]WSTOSEQIND(I1) <> 0 & [M:SGW]WSERNUM(I1) <> ""
       # Suppression série en cours de traitement
       Call DEL_STOSERW([F:STO]ITMREF,[M:SGW]WSERNUM(I1),[M:SGW]WQTYSTUDES(I1),PRET) From STKLIB
       If PRET <>0
          Goto ENDTRANSAC
       Endif
    Endif
    [M:SGW]WQTYSTUDES(I1)= 0
#                                                                                               # hcb 110327 fin
    If evalue("[M:"+PABR+"]QTYSTUDES(LLIGDOC)")=1
        # Issue 120553 - 2017-01-17 by CCC : the line is removed => remove corresponding price
        If clalev([M:VALW])>0
            I1=find([M:SCS1]WSTOSEQ(LLIGDOC), [M:VALW]WSTOSEQ)
            If I1>0
                Raz [M:VALW]WSTOSEQ(I1-1)
            Endif
        Endif

        Dela LLIGDOC,1 [M:SCS1]NBLIG
        [M:SCS1]NBLIG -= 1
    Else
        LNB = sigma(0,[M:SGW]NBLIG-1,[M:SGW]WSTOSEQ(indcum)=LSEQ)
        I1 = find (LSEQ,[M:SGW]WSTOSEQ)-1
        If I1>=0
            LPCU = [M:SGW]WPCUDES(I1)
            LCOEF = [M:SGW]WCOEDES(I1)
            LPCU = string$( !!( sigma(I1,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=LSEQ)&(LPCU=[M:SGW]WPCUDES(indcum)))=LNB), LPCU)
            LCOEF = (!!( sigma(0,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=LSEQ)&([M:SGW]WCOEDES(indcum)=LCOEF))=LNB))* LCOEF
            LQTYSTU = sigma(0,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=LSEQ)*[M:SGW]WQTYSTUDES(indcum))
            If evalue("dim([M:"+PABR+"]SERNUMF(LLIGDOC))")>0
                Call MOINS_UN([F:STO1]SERNUM,LSERF,LRET) From STKLIB
                Assign "[M:"+PABR+"]SERNUMF(LLIGDOC)" With LSERF
            Endif
            Gosub MAJ_LIG_DOC
        Endif
        nolign=LLIGDOC+1
        Gosub MAJ_STUDIS
    Endif
Else
    #--- On cherche la ligne dans le document
    LLIGDOC = evalue("find(PSTOCOU, [M:"+PABR+"]WSTOCOU(0..[M:"+PABR+"]NBLIG))")
    If !LLIGDOC : Goto ENDTRANSAC : Else LLIGDOC-=1 : Endif

    #--- On fait le ménage dans STOCHGW et dans le document
    Call DELSTOCHGW(PABR, PSTOFCY, LLIGDOC, LLIGDOC, 1, LRET) From SUBSCSB
    Dela LLIGDOC,1 [M:SCS1]NBLIG
    [M:SCS1]NBLIG -= 1
Endif

#MAE, RET_SSTRT
#If [F:SRT]BETFCYCOD=4
If find([F:SRT]BETFCYCOD,4,5) # transfert ou retour sous-traitant
    If [M:SCS1]NBLIG>0
        Diszo [M:SCS1]SCOLOC
    Else
        Actzo [M:SCS1]SCOLOC
    Endif
Endif

# Il ne faut pas afficher si on utilise le bouton 'Tout exclure' (performances)
If dim(GALLINCEXC)<0 | (dim(GALLINCEXC)>0 & GALLINCEXC<>1)
  Affzo [M:SCS1]
Endif

Raz PRET

GOK=1

$ENDTRANSAC
# Si on a ouvert une transaction
If WTRBEGIN=1
   If GOK : Commit : Else : Rollback : Endif
   Raz WTRBEGIN
Endif

End


###############################################################################
# COPSGW : Copie la ligne I sur la ligne [M:SGW]NBLIG
###############################################################################
$COPSGW
    [M:SGW]WSTOSEQ([M:SGW]NBLIG)    = [M:SGW]WSTOSEQ(I)
    [M:SGW]WQTYPCUDES([M:SGW]NBLIG) = [M:SGW]WQTYPCUDES(I)
    [M:SGW]WPCUDES([M:SGW]NBLIG)    = [M:SGW]WPCUDES(I)
    [M:SGW]WCOEDES([M:SGW]NBLIG)    = [M:SGW]WCOEDES(I)
    [M:SGW]WSERNUM([M:SGW]NBLIG)    = [M:SGW]WSERNUM(I)
    [M:SGW]WSERNUMF([M:SGW]NBLIG)   = [M:SGW]WSERNUMF(I)
    [M:SGW]WSTADES([M:SGW]NBLIG)    = [M:SGW]WSTADES(I)
    [M:SGW]WWRHDES([M:SGW]NBLIG)    = [M:SGW]WWRHDES(I)
    [M:SGW]WLPNNUMDES([M:SGW]NBLIG) = [M:SGW]WLPNNUMDES(I)          # hcb X3-67989
    [M:SGW]WLOCDES([M:SGW]NBLIG)    = [M:SGW]WLOCDES(I)
    [M:SGW]WLOCTYPDES([M:SGW]NBLIG) = [M:SGW]WLOCTYPDES(I)
    [M:SGW]WLOCSEQ([M:SGW]NBLIG)    = [M:SGW]WLOCSEQ(I)
    [M:SGW]WPOT([M:SGW]NBLIG)       = [M:SGW]WPOT(I)
    [M:SGW]WPALNUMDES([M:SGW]NBLIG) = [M:SGW]WPALNUMDES(I)          # hcb 110505 28601
    [M:SGW]WCTRNUMDES([M:SGW]NBLIG) = [M:SGW]WCTRNUMDES(I)          # hcb 110505 28601
Return


###############################################################################
# ALI_DOC : Alimente la ligne de document en cours (nolign-1) avec [F:STO]
#            Les valeurs de destination sont initialisées
###############################################################################
$ALI_DOC
Local Shortint WPBSTA, WPBLOC
Local Shortint WRET
Local Integer  LRET, I
Local Char     LSEC
Local Char     VAT(GLONVAT)(3)
Local Decimal  WQTE
    #---- Positionnement sur les tables ------------#
    Call POSTABLE([M:SCS1]FCYDES, [F:STO]ITMREF, [F:STO]LOT, [F:STO]SLO, LRET)
    If LRET
        OK=0
        Return
    Endif

    # Ouverture de la ligne
    nolign = [M:SCS1]NBLIG
    Insa nolign,1,[M:SCS1]NBLIG [M:SCS1]NBLIG
    [M:SCS1]NBLIG += 1
    nolign = [M:SCS1]NBLIG
    NOL = nolign-1
    status = 73
    Call INSERE("VCRLIN") From TABLEAUX
    status = 71
    Call LINNUM("VCRLIN") From TABLEAUX
    status = 0


    Actzo [M]QTYSTUDES(NOL)
    Actzo [M]QTYPCU(NOL)
    Actzo [M]PCUDES(NOL)
    Actzo [M]QTYPCUDES(NOL)
    Actzo [M]COEDES(NOL)
    Actzo [M]STADES(NOL)
    If dim([M:SCS1]QLYCTLFLG)>0
        Actzo [M]QLYCTLFLG(NOL)
    Endif
    If dim([M:SCS1]WRHDES)>0
        Actzo [M]WRHDES(NOL)
    Endif
    If dim([M:SCS1]LOCDES)>0
        Actzo [M]LOCDES(NOL)
    Endif
    If dim([M:SCS1]LOCTYPDES)>0
        Actzo [M]LOCTYPDES(NOL)
    Endif
    If dim([M:SCS1]MVTDES)>0
        Actzo [M]MVTDES(NOL)
    Endif

    [M:SCS1]ITMREF(NOL) = [F:STO]ITMREF
    #[M:SCS1]ITMDES1(NOL)= [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SCS1]ITMDES1(NOL), "[F:ITM]") From TRTX3 # FGR 03/07/2009 : X3SUIVI56319
    If dim([M:SCS1]LOT)>0
        [M:SCS1]LOT(NOL)    = [F:STO]LOT
    Endif
    If dim([M:SCS1]SLO)>0
        [M:SCS1]SLO(NOL)    = [F:STO]SLO
    Endif
    #--- TS 106217
    If dim([M:SCS1]ECCVALMAJ)>0
        [M:SCS1]ECCVALMAJ(NOL) = [F:STO]ECCVALMAJ
    Endif
    #---
    If dim([M:SCS1]PALNUM)>0
        [M:SCS1]PALNUM(NOL) = [F:STO]PALNUM
    Endif
    If dim([M:SCS1]CTRNUM)>0
        [M:SCS1]CTRNUM(NOL) = [F:STO]CTRNUM
    Endif
# hcb 100505 28601 deb
    If dim([M:SCS1]PALNUMDES)>0
        [M:SCS1]PALNUMDES(NOL) = [F:STO]PALNUM
    Endif
    If dim([M:SCS1]CTRNUMDES)>0
        [M:SCS1]CTRNUMDES(NOL) = [F:STO]CTRNUM
    Endif
# hcb 100505 28601 fin
    [M:SCS1]STA(NOL)    = [F:STO]STA
    If dim([M:SCS1]LOC)>0
       [M:SCS1]LOC(NOL) = [F:STO]LOC
    Endif
    If dim([M:SCS1]LOCTYP)>0
       [M:SCS1]LOCTYP(NOL) = [F:STO]LOCTYP
    Endif
    If dim([M:SCS1]WRH)>0
       [M:SCS1]WRH(NOL) = [F:STO]WRH
    Endif
    If dim([M:SCS1]SERNUM)>0
        [M:SCS1]SERNUM(NOL) = [F:STO]SERNUM
    Endif
     If dim([M:SCS1]STOFLD1)>0
        [M:SCS1]STOFLD1(NOL) = [F:STO]STOFLD1
    Endif
    If dim([M:SCS1]STOFLD2)>0
        [M:SCS1]STOFLD2(NOL) = [F:STO]STOFLD2
    Endif
#                                                              # hcb x3-67989 deb
    If dim([M:SCS1]LPNNUM)>0
       [M:SCS1]LPNNUM(NOL) = [F:STO]LPNNUM
# si la transaction ne permet pas la modification de l'emplacement la selection sur LPNNUMDES
# affiche les Contenants ayant le meme emplacement ou ceux n ayant pas d'emplacement
       Raz [M:SCS1]LOCSELLPN(nolign-1)
       If dim([M:SCS1]LPNNUM)>0 & [M:SCS1]LPNNUM(nolign-1) <> "" & [F:SRT]CHGEMPCOD <> 2
         [M:SCS1]LOCSELLPN(nolign-1) = [M:SCS1]LOC(nolign-1)
       Endif
    Endif
#                                                              # hcb x3-67989 deb

    [M:SCS1]OWNER(NOL)     = [F:STO]OWNER
    [M:SCS1]PCU(NOL)       = [F:STO]PCU
    [M:SCS1]PCUSTUCOE(NOL) = [F:STO]PCUSTUCOE
    [M:SCS1]QTYPCU(NOL)    = [F:STO]QTYPCU
    [M:SCS1]QLYCTLDEM(NOL) = [F:STO]QLYCTLDEM

    [M:SCS1]WSTOCOU(NOL) = [F:STO]STOCOU

    #---------- sections analytiques ------------------#
    If [M:SCS1]STOFCY<>[M:SCS1]FCYDES
        For I=1 To GNBDIE
                If [M:SCS1]BETCPY=2
                    Call INISEC (LSEC, "ICOD", I) From TRTX3CPT
                Else
                    Call INISEC (LSEC, "TRSD", I) From TRTX3CPT
                Endif
                Assign "[M:SCS1]CCE"+num$(I)+"(NOL)" With  LSEC
        Next
    Endif

    Case [F:ITFD]STOMGTCOD
        When 3       : [M:SCS1]POT = [F:STL]POT
        When 4       : [M:SCS1]POT = [F:STL]ACT/100
        When Default : [M:SCS1]POT = 1
    Endcase

    [M:SCS1]STU(NOL) = [F:ITM]STU
    nolign=NOL+1
    Gosub MAJ_STUDIS




    # Si mvt interne avec chgt emplacement, on alimente la quantité à traiter
    # selon [F:SRT]PIOQTY (tout, qté non allouée ou qté allouée)
    #MAE, RET_SSTRT
    If find([M:SCS1]BETFCYCOD,1,5) & [F:SRT]CHGEMPCOD=2 & GFONCTION<>"FUNSTOP" & GFONCTION<>"FUNSTOLTI"     # hcb 51026
       Case [F:SRT]PIOQTY
        When 2 :      If [F:STO]QTYSTU-[F:STO]CUMWIPQTY-[F:STO]CUMALLQTY>0
                         [M:SCS1]QTYSTUDES(NOL) = [F:STO]QTYSTU-[F:STO]CUMWIPQTY-[F:STO]CUMALLQTY
                      Else
                         [M:SCS1]QTYSTUDES(NOL) = [M:SCS1]STUDIS(NOL)
                      Endif
        When 3 :      If [F:STO]CUMALLQTY>0
                         [M:SCS1]QTYSTUDES(NOL) = [F:STO]CUMALLQTY
                      Else
                         [M:SCS1]QTYSTUDES(NOL) = [M:SCS1]STUDIS(NOL)
                      Endif
        When Default: [M:SCS1]QTYSTUDES(NOL) = [M:SCS1]STUDIS(NOL)
       Endcase
    Else
#                                                                              # hcb 110327 deb
#      [M:SCS1]QTYSTUDES(NOL) = [M:SCS1]STUDIS(NOL)
       If GIMPORT & [F:ITM]SERMGTCOD = 4
          [M:SCS1]QTYSTUDES(NOL) = [F:SGD]QTYPCU
          [M:SCS1]SERNUM   (NOL) = [F:SGD]SERNUM
          [M:SCS1]SERNUMF  (NOL) = [F:SGD]SERNUMF
       Else
          [M:SCS1]QTYSTUDES(NOL) = [M:SCS1]STUDIS(NOL)
       Endif
#                                                                              # hcb 110327 fin
    Endif


    # hcb : Modification quantité demande 46549
    GPOINT="QTYSTUDES" : Gosub ENTREE From EXEFNC

    Call MAJQTY(2,[M:SCS1]QTYSTUDES(NOL),LRET)
    [M:SCS1]PCUDES(NOL)    = [M:SCS1]PCU(NOL)
    [M:SCS1]QTYPCUDES(NOL) = [M:SCS1]QTYPCU(NOL)
    [M:SCS1]COEDES(NOL)    = [M:SCS1]PCUSTUCOE(NOL)
    If [M:SCS1]PCU(NOL) = [F:ITM]STU
        Diszo [M:SCS1]PCU(NOL),QTYPCU(NOL),PCUSTUCOE(NOL),COEDES(NOL)
    Else
        Local Char LUSCAV
        Local Char LFMT
        Local Integer LMODIF
        Local Decimal LCOE
        Call CTLUOM ([M:SCS1]ITMREF(NOL),3,"", [M:SCS1]PCU(NOL),LCOE, LUSCAV,
&                    LFMT, LMODIF) From STKACT
        If LMODIF=2
            Actzo [M:SCS1]COEDES(NOL)
        Else
            Diszo [M:SCS1]COEDES(NOL)
        Endif
    Endif

    # Si inter-société, alim. des champs nécessaires pour la recherche tarif
    If [M:SCS1]BETCPY=2
       # Recherche taxes
       #Call ALITAXEV([M:SCS1]VACBPR,[F:ITM]VACITM,VAT) From TRTX3
       Call RECHVATCOD(1,1,[M:SCS1]BPCNUM,[M:SCS1]ITMREF(NOL),"SCS1",NOL,VAT) From TRTX3
       [M:SCS1]VAT1(NOL) = VAT(0)
       [M:SCS1]VAT2(NOL) = VAT(1)
       [M:SCS1]VAT3(NOL) = VAT(2)
       # Calcul des montants base calcul taxe
       Call ALICLCAMT([M:SCS1]ITMREF(NOL),[M:SCS1]QTYSTUDES(NOL),NOL,"SCS1",
&                     [M:SCS1]CLCAMT1(NOL),[M:SCS1]CLCAMT2(NOL)) From TRTX3

       # Recherche tarif si module vente et inter-société
       # avec client connu et article vente existant
       If GMODU(5)=2 & [M:SCS1]BPCNUM<>""
          Read [ITS]ITS0=[M:SCS1]ITMREF(NOL)
          If !fstat
             WQTE = [M:SCS1]QTYSTUDES(NOL)
             Gosub RECH_PRIX
          Endif
       Endif
    Endif

    # Si ligne avec no série pas d'accés qte en US
    If dim([M:SCS1]SERNUM)>0 & [M:SCS1]SERNUM(NOL)<>""
       If dim([M]QTYSTUDES)>0 Diszo [M:SCS1]QTYSTUDES(NOL) Endif
    Endif

    # Si gestion n° de série
    Case [F:ITM]SERMGTCOD
        When 2:       If [M:SCS1]BETCPY=2
                         Actzo [M:SCS1]SERNUM(NOL)
                         [M:SCS1]PCUDES(NOL)    = [F:ITM]STU
                         [M:SCS1]COEDES(NOL)    = 1
                         [M:SCS1]QTYPCUDES(NOL) = [M:SCS1]QTYSTUDES(NOL)
                         Diszo [M:SCS1]PCUDES(NOL),COEDES(NOL)
                      Else
                         Diszo [M:SCS1]SERNUM(NOL)
                      Endif

        When 3:       Diszo [M:SCS1]SERNUM(NOL)
                      Diszo [M:SCS1]PCUDES(NOL),COEDES(NOL)
        When Default: If dim([M:SCS1]SERNUM(NOL))>0
                         Diszo [M:SCS1]SERNUM(NOL)
                      Endif
    Endcase

    Raz WPBSTA, WPBLOC

    # Si statut destination renseigné
    If dim([M:SCS1]STADESH)>0 & [M:SCS1]STADESH<>"" &  [M:SCS1]QLYCTLDEM(NOL) = ""
       [M:SCS1]STADES(NOL) = [M:SCS1]STADESH
    Else
       [M:SCS1]STADES(NOL) = [M:SCS1]STA(NOL)
       # Si statut par défaut
       If [F:SRU]DEFSTA<>""
          # Initialisation si trf inter-sites
          If [M:SCS1]BETFCYCOD=2
             [M:SCS1]STADES(NOL) = [F:SRU]DEFSTA
          # Initialisation si chgt stock avec uniquement chgt statut
          Elsif [M:SCS1]BETFCYCOD=1 & [F:SRT]CHGSTACOD=2 &
&            [F:SRT]CHGEMPCOD<>2 & [F:SRT]CHGPCUCOD<>2
             [M:SCS1]STADES(NOL) = [F:SRU]DEFSTA
          Endif
       Endif
    Endif

    If [M:SCS1]BETFCYCOD=1 & [F:SRT]CHGSTACOD=2 & [M:SCS1]STADES(NOL)<>[M:SCS1]STA(NOL)
       # Contrôle du statut
       Call STKCTRSTA([M:SCS1]STADES(NOL),[F:SRU]AUZSST,1,2,0,WRET) From STKACT
       If WRET=2
          If dim([M:SCS1]STADESH)>0 & [M:SCS1]STADESH<>"" WPBSTA=1 Endif
          [M:SCS1]STADES(NOL) = [M:SCS1]STA(NOL)
          #Raz [M:SCS1]STADES(NOL)
          Raz WRET, GMESSAGE
       Endif
       #--- Issue 99815
       # Si mouvement interne et changement de statut, contrôle disponibilité stock
       Local Integer WSTA
       Local Decimal WDISPO
       If left$([M:SCS1]STADES(NOL),1)<>left$([M:SCS1]STA(NOL),1)
         WSTA=0
         WDISPO=0
         If [F:ITG]GLOAAAFLG = 2   WSTA += 1  Endif
         If [F:ITG]GLOQQQFLG = 2   WSTA += 2  Endif
         If [F:ITG]GLORRRFLG = 2   WSTA += 4  Endif
         Call STODISTOT("",1,WSTA,"",WDISPO) From STKLIB
         # Le stock dispo a été calculé selon la valeur de WSTA (prise en compte de 'A' et/ou 'Q' et/ou 'R')
         # On diminue donc ce disponible si la ligne stock était dispo de part son statut
         # alors qu'elle ne le sera plus, de part son nouveau statut.
         # Les cas d'augmentation du stock disponible ne sont pas calculés car sans intérêt
         Case WSTA
           When 0,1 : If left$([M:SCS1]STA(NOL),1)="A" WDISPO-=[M:SCS1]QTYSTUDES(NOL) Endif
           When 2   : If left$([M:SCS1]STA(NOL),1)="Q" WDISPO-=[M:SCS1]QTYSTUDES(NOL) Endif
           When 3   : If find(left$([M:SCS1]STA(NOL),1),"A","Q") & left$([M:SCS1]STADES(NOL),1)="R"
                        WDISPO-=[M:SCS1]QTYSTUDES(NOL)
                      Endif
           When 4   : If left$([M:SCS1]STA(NOL),1)="R" WDISPO-=[M:SCS1]QTYSTUDES(NOL) Endif
           When 5   : If find(left$([M:SCS1]STA(NOL),1),"A","R") & left$([M:SCS1]STADES(NOL),1)="Q"
                        WDISPO-=[M:SCS1]QTYSTUDES(NOL)
                      Endif
           When 6   : If find(left$([M:SCS1]STA(NOL),1),"Q","R") & left$([M:SCS1]STADES(NOL),1)="A"
                        WDISPO-=[M:SCS1]QTYSTUDES(NOL)
                      Endif
           When 7   :
         Endcase
         #--- Issue X3-88248
         #If WDISPO<=0
         If WDISPO<0
         #---
           Call MESSAGE(mess(421,184,1)) From GESECRAN
         Endif
       Endif
       #---
    Endif

    Case [M:SCS1]BETFCYCOD
     When 1   : If [M:SCS1]QLYCTLDEM(NOL)<>""
                  [M:SCS1]QLYCTLFLG(NOL) = 1
                  Grizo [M:SCS1]QLYCTLFLG(NOL)
                Elsif left$([M:SCS1]STADES(NOL),1)="Q"     # hcb 44028
                  [M:SCS1]QLYCTLFLG(NOL) = [F:SRU]QLYCTLFLG
                  Actzo [M:SCS1]QLYCTLFLG(NOL)
                Else
                  [M:SCS1]QLYCTLFLG(NOL) = 1
                  Diszo [M:SCS1]QLYCTLFLG(NOL)
                Endif
     When 2   : If left$([M:SCS1]STADES(NOL),1)="Q"
                  [M:SCS1]QLYCTLFLG(NOL) = [F:SRU]QLYCTLFLG
                  Actzo [M:SCS1]QLYCTLFLG(NOL)
                Else
                  [M:SCS1]QLYCTLFLG(NOL) = 1
                  Diszo [M:SCS1]QLYCTLFLG(NOL)
                Endif
     When 3,4,5 : [M:SCS1]QLYCTLFLG(NOL)=1
                Diszo [M:SCS1]QLYCTLFLG(NOL)
    Endcase

    If [M:SCS1]QLYCTLDEM(NOL)<>""
       Diszo [M:SCS1]STADES(NOL)
    Endif

    # Si pas de gestion d'emplacement, transfert sous-traitant
    If ([F:ITFD]LOCMGTCOD<>2 | [F:SRT]BETFCYCOD=4) & dim([M:SCS1]LOCTYPDES)>0
        Diszo [M:SCS1]LOCTYPDES(NOL)
        Diszo [M:SCS1]LOCDES(NOL)
        If dim([M:SCS1]WRHDES)>0
            Diszo [M:SCS1]WRHDES(NOL)
        Endif
    Else
        If dim([M:SCS1]LOCTYPDES)> 0
            Actzo [M:SCS1]LOCTYPDES(NOL)
            Actzo [M:SCS1]LOCDES(NOL)
            If dim([M:SCS1]WRHDES)>0
                Actzo [M:SCS1]WRHDES(NOL)
            Endif
        Endif
    Endif
    If [M:SCS1]WLOCSEQ(NOL)=0
        Call STKWLOCSEQ("SCS1", NOL, LRET) From STKECR
    Endif

    # Initialisation de l'emplacement
    If dim([M:SCS1]LOCDES)>0 & [F:ITFD]LOCMGTCOD > 1    # hcb 36036
        If dim([M:SCS1]WRHDESH) > 0
          WWRH=[M:SCS1]WRHDESH
          # Si article-dépôt(entête) inexistant, raz du dépôt
          If WWRH<>""
            Read [ITW]ITW0=[M:SCS1]ITMREF(NOL);WWRH
            If fstat WWRH="" Endif
          Endif
        Else
          WWRH=""
        Endif
# hcb 103833 deb
        Local    Char    WWRH1(GLONWRH)
        Raz WWRH1
        If dim([M:SCS1]WRHDESH)>0
             WWRH1 = [M:SCS1]WRH(NOL)
        Endif
# hcb 103833 fin

        # Si transfert ou retour sous-traitance
        If [F:SRT]BETFCYCOD=4
            [M:SCS1]LOCDES(NOL)    = [M:SCS1]SCOLOC
            [M:SCS1]LOCTYPDES(NOL) = [M:SCS1]SCOLOCTYP
        # Si emplacement destination renseigné
        Elsif dim([M:SCS1]LOCDESH)>0 & [M:SCS1]LOCDESH<>"" & (dim([M:SCS1]LPNNUM) > 0 &  [M:SCS1]LPNNUM(NOL) = "")    # hcb x3-77043
            [M:SCS1]LOCDES(NOL)    = [M:SCS1]LOCDESH
            [M:SCS1]LOCTYPDES(NOL) = [M:SCS1]LOCTYPDESH
            Call STKCTREMP([M:SCS1]WLOCSEQ(NOL),[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,[M:SCS1]FCYDES,
&                          [M:SCS1]ITMREF(NOL),[M:SCS1]PCUDES(NOL),[M:SCS1]QTYPCUDES(NOL),
&                          [M:SCS1]STADES(NOL),[M:SCS1]LOCTYPDES(NOL),[M:SCS1]LOCDES(NOL),"",
&                          0,mkstat,GBIDD1,"",GFILLOCENT,WWRH) From STKLOC
            If mkstat<>0
                WPBLOC=1 : Raz mkstat
                [M:SCS1]LOCTYPDES(NOL) = [M:SCS1]LOCTYP(NOL)
                [M:SCS1]LOCDES(NOL)    = [M:SCS1]LOC(NOL)
            Endif
        # Si mvt interne sans chgt emplacement
        # ou mvt interne avec chgt emplacement et (chgt statut ou UC)
        #    mais dépôt destination non renseigné ou identique à dépôt origine
        Elsif [F:SRT]BETFCYCOD=1 & ([F:SRT]CHGEMPCOD<>2 | ([F:SRT]CHGEMPCOD =2
&               & ([F:SRT]CHGPCUCOD =2 | [F:SRT]CHGSTACOD=2)
&               & (WWRH="" | WWRH=WWRH1)))                         # hcb 103833
                [M:SCS1]LOCTYPDES       (NOL) = [M:SCS1]LOCTYP(NOL)
                [M:SCS1]LOCDES          (NOL) = [M:SCS1]LOC   (NOL)
                If dim([M:SCS1]LPNNUMDES) > 0                                     # hcb x3-77043
                       [M:SCS1]LPNNUMDES(NOL) = [M:SCS1]LPNNUM(NOL)              # hcb x3-77043
                Endif                                                             # hcb x3-77043
        # Si trf inter-site ou chgt emplacement seul (et fonction chgt de stock)
        #MAE, RET_SSTRT, si retour sous-traitant
        Elsif GFONC1="GESSIS" & [F:SRT]BETFCYCOD=2
&           | GFONC1="GESSCS" & ([F:SRT]BETFCYCOD=1 & [F:SRT]CHGEMPCOD=2)
&           | GFONC1="GESSTR" & [F:SRT]BETFCYCOD=5
            Local Char WSTOFCY           # hcb 38295
            WSTOFCY = [M:SCS1]STOFCY     # hcb 38295
            If GFONC1="GESSIS"           # hcb 38295
               WSTOFCY = [M:SCS1]FCYDES  # hcb 38295
            Endif                        # hcb 38295
            #--- Bug 72649 ajout paramètre emplacement
            Call STKSUGTLO([M:SCS1]WLOCSEQ(NOL),[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,
&                          WSTOFCY,[M:SCS1]ITMREF(NOL),[M:SCS1]PCUDES(NOL),
&                          [M:SCS1]QTYPCUDES(NOL),[M:SCS1]STADES(NOL),
&                          [M:SCS1]LOCTYPDES(NOL),"QU",GFILLOCENT,WWRH,
&                          [M:SCS1]LOCDES(NOL)) From STKLOC
            Call STKSUGEMP([M:SCS1]WLOCSEQ(NOL),[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,
&                          WSTOFCY,[M:SCS1]ITMREF(NOL),[M:SCS1]PCUDES(NOL),
&                          [M:SCS1]QTYPCUDES(NOL),[M:SCS1]STADES(NOL),
&                          [M:SCS1]LOCTYPDES(NOL),[M:SCS1]LOCDES(NOL),"","",
&                          GFILLOCENT,WWRH) From STKLOC

        Endif
        If GIMPORT & dim([M:SCS1]LPNNUMDES) > 0                                     # hcb x3-98706
           [M:SCS1]LPNNUMDES(NOL) = [M:SCS1]LPNNUM(NOL)                             # hcb x3-98706
        Endif                                                                       # hcb x3-98706

        #--- Issue X3-75842
        # Si le nouveau statut n'est pas autorisé pour l'emplacement
        # et que le changement d'emplacement est permis, il faut effacer
        # l'emplacement qui pourra ainsi être réinitialisé
        If [M:SCS1]STADES(NOL)<>[M:SCS1]STA(NOL) & [F:SRT]CHGEMPCOD=2 & [M:SCS1]LOCTYPDES(NOL)<>""
          Call STKCTRTLO([M:SCS1]WLOCSEQ(NOL),[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,
&                        [M:SCS1]STOFCY,[M:SCS1]ITMREF,[M:SCS1]PCUDES(NOL),
&                        [M:SCS1]QTYPCUDES(NOL),[M:SCS1]STADES(NOL),0,[M:SCS1]LOCTYPDES(NOL),
&                        mkstat,"QU","",WWRH) From STKLOC
          If mkstat
            Raz [M:SCS1]LOCTYPDES(NOL), [M:SCS1]LOCDES(NOL), mkstat, GMESSAGE
          Elsif [M:SCS1]LOCDES(NOL)<>""
            Call STKCTREMP([M:SCS1]WLOCSEQ(NOL),[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,
&                          [M:SCS1]STOFCY,[M:SCS1]ITMREF,[M:SCS1]PCUDES(NOL),
&                          [M:SCS1]QTYPCUDES(NOL),[M:SCS1]STADES(NOL),[M:SCS1]LOCTYPDES(NOL),
&                          [M:SCS1]LOCDES(NOL),"",0,mkstat,GBIDD1,"","",WWRH) From STKLOC
            If mkstat
              Raz [M:SCS1]LOCTYPDES(NOL), [M:SCS1]LOCDES(NOL), mkstat
            Endif
          Endif
        Endif
        #--- End issue X3-75842

        Call STKMODREMP([M:SCS1]WLOCSEQ(NOL),
&                       [M:SCS1]STOFCY,
&                       [M:SCS1]ITMREF(NOL),
&                       [M:SCS1]PCU(NOL),
&                       [M:SCS1]QTYPCU(NOL),
&                       [M:SCS1]STA(NOL),
&                       [M:SCS1]LOC(NOL),
&                       "",mkstat,"") From STKLOC
        If dim([M:SCS1]WRHDES) > 0
            fstat=0
            If [F:STC]LOC<>[M:SCS1]LOCDES(NOL)
                Read [STC]STC0=[M:SCS1]STOFCY;[M:SCS1]LOCDES(NOL)
            Endif
            #--- Bug 68675
            #If !fstat [M:SCS1]WRHDES(NOL)=[F:STC]WRH Endif
            # Si mvt interne sans chgt emp, alimentation dépôt destination
            # sinon pas d'alimentation pour rendre possible le multi-dépôt
            #--- Bug 81497
            #If !fstat & [F:SRT]BETFCYCOD=1 & [F:SRT]CHGEMPCOD<>2
            #   [M:SCS1]WRHDES(NOL)=[F:STC]WRH
            #Endif
            # Si mvt interne, sans chgt emp ou avec dépôt destination entête
            # renseigné, alimentation dépôt destination
            # sinon pas d'alimentation pour rendre possible le multi-dépôt
            If !fstat & [F:SRT]BETFCYCOD=1
               If [F:SRT]CHGEMPCOD<>2 | WWRH<>""
                  [M:SCS1]WRHDES(NOL)=[F:STC]WRH
               Endif
            Endif
            #---
            #---
        Endif
    Endif

    GPOINT="ALI_DOC_SCS1" : Gosub ENTREE From EXEFNC     # hcb 82046

    If dim([M:SCS1]LOCDES)>0
       Call CALCSAIZON([M:SCS1]LOCDES(NOL)<>"", "LOCDES") From SUBSCSB
       Call CALCSAIZON([M:SCS1]LOCTYPDES(NOL)<>"", "LOCTYPDES") From SUBSCSB
    Endif
    Call CALCSAIZON([M:SCS1]STADES(NOL)<>""&[M:SCS1]QLYCTLDEM(NOL)<>"", "STADES") From SUBSCSB
    Call CALCSAIZON([M:SCS1]COEDES(NOL)>0, "COEDES") From SUBSCSB
    Call CALCSAIZON([M:SCS1]PCUDES(NOL)<>"", "PCUDES") From SUBSCSB
    Call CALCSAIZON([M:SCS1]QTYSTUDES(NOL)>0, "QTYSTUDES") From SUBSCSB

    Call OUVCHG( "SCS1", NOL, [M:SCS1]STOFCY)

    Call SETNEWPRI([M:SCS1]ITMREF(NOL),"","",[M:SCS1]FCYDES,[M:SCS1]IPTDAT,[M:SCS1]WSTOSEQ(NOL),[M:SCS1]PRI(NOL),"") From STKVAL

Return

###############################################################################
$RECH_PRIX
Local Char     VAT(GLONVAT)(3)
Local Decimal  MAJREM(0..8), WPRI, NETPRI
Local Integer  I

If [F:FCY]FCY<>[M:SCS1]STOFCY
   Read [FCY]FCY0=[M:SCS1]STOFCY
   If fstat Raz [F:FCY] Endif
Endif
GSOCIETE=[F:FCY]LEGCPY

# --> Recherche tarif
Call RECH_TARIF(1,[M:SCS1]ITMREF(NOL),NOL,WQTE,"SCS",WPRI)
&               From TRTVENTAR

# --> Calcul du prix net
For I=1 To 9
    If evalue("dim([M:SCS1]DISCRGVAL"+num$(I)+"(NOL))")>0
       MAJREM(I-1)=evalue("[M:SCS1]DISCRGVAL"+num$(I)+"(NOL)")
    Endif
Next I
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE
    If fstat Raz [F:CPY] Endif
Endif
If dim(GCALNETLIN)>0 : GCALNETLIN=NOL+1      : Endif
If dim(GCALNETABR)>0 : GCALNETABR="[M:SCS1]" : Endif
Call CALNET (1,[F:CPY]PLISTC,WPRI,MAJREM,WQTE,NETPRI,[M:SCS1]CUR) From TRTPRICE
[M:SCS1]PRI(NOL) = NETPRI
# --> Calcul du prix en HT si le type de prix est TTC
If [M:SCS1]PRITYP=2
   VAT(0)  = [M:SCS1]VAT1(NOL)
   VAT(1)  = [M:SCS1]VAT2(NOL)
   VAT(2)  = [M:SCS1]VAT3(NOL)
   Call CLCTAXEPRIV(NETPRI,VAT,[M:SCS1]PRITYP,GSOCIETE,[M:SCS1]IPTDAT,WQTE,[M:SCS1]VACBPR,
&       [M:SCS1]CLCAMT1(NOL),[M:SCS1]CLCAMT2(NOL),[M:SCS1]PRI(NOL)) From TRTX3
Endif

# Conversion du prix en US
If [M:SCS1]PCU(NOL)<>[M:SCS1]STU(NOL)
   If [M:SCS1]PCUSTUCOE(NOL)=0 [M:SCS1]PCUSTUCOE(NOL)=1 Endif
   [M:SCS1]PRI(NOL) = [M:SCS1]PRI(NOL)/[M:SCS1]PCUSTUCOE(NOL)
Endif

Return

###############################################################################
$MAJ_STUDIS

Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS, WTOTACTDIS, WDISPO
Local Integer LTYPLOC, LSTA
#--- Bug 78712
Local Decimal WACTDIS

# On autorise de faire des changements même sur ce qui est alloué sauf en inter-sites
# Il faut juste avoir la trace au moment de l'enregistrement et un message au picking

If [F:SRT]BETFCYCOD<>2
   [M:SCS1]STUDIS(nolign-1) = [F:STO]QTYSTU-[F:STO]CUMWIPQTY
   #--- Bug 78712
   WACTDIS = [F:STO]QTYSTUACT-[F:STO]CUMWIPQTA
Else
   [M:SCS1]STUDIS(nolign-1) = [F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY
   #--- Bug 78712
   WACTDIS = [F:STO]QTYSTUACT-[F:STO]CUMALLQTA-[F:STO]CUMWIPQTA
Endif

If [F:SRT]BETFCYCOD>1
   #--- Lecture cumuls article
   If [F:ITV]STOFCY<>[M:SCS1]STOFCY
      Read [ITV]ITV0=[F:ITM]ITMREF;[M:SCS1]STOFCY
      If fstat Raz [F:ITV] Endif
   Endif
   # Calcul du stock disponible sur l'article
   # Si retour sous-traitant, stock dispo article sur emplacement sous-traitant
   If [F:SRT]BETFCYCOD=5
      LTYPLOC = -4
   Else
      LTYPLOC = 1
      If [F:STO]LOCCAT=3 LTYPLOC+=2 Endif
      If [F:STO]LOCCAT=4 LTYPLOC+=4 Endif
   Endif
   LSTA    = 0
   # Statuts autorisés par les règles de gestion d'E/S
   If find([F:SRU]AUZSTA,1,3,5,7) LSTA+=1  Endif
   If find([F:SRU]AUZSTA,2,3,6,7) LSTA+=2  Endif
   If find([F:SRU]AUZSTA,4,5,6,7) LSTA+=4  Endif
   Call STODISTOT("[F:ITV]",LTYPLOC,LSTA,"",WTOTACTDIS) From STKLIB

   #--- Issue 94494
   #--- Issue 96990
   #WTOTACTDIS-=sum([M:SCS1]QTYSTUDES)
   WTOTACTDIS-=sigma(I=0,[M:SCS1]NBLIG-1,[M:SCS1]QTYSTUDES(I)*([M:SCS1]CREFLG(I)=0)*([F:STO]ITMREF=[M:SCS1]ITMREF(I)))
   WTOTACTDIS+=[M:SCS1]QTYSTUDES(nolign-1)
   #---

   # Contrôle du disponible pour sortie sur la ligne de stock
   Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB

   # Disponible = min(dispo ligne stock, dispo article)
   WDISPO = min(WSTUACTDIS,WTOTACTDIS)

   #--- Bug 78712
   #[M:SCS1]STUDIS(nolign-1)=WSTUDIS
   If WACTDIS>WDISPO
      WACTDIS=WDISPO
      [M:SCS1]STUDIS(nolign-1)=WACTDIS
      If [F:ITM]STOMGTCOD=3
         If [M:SCS1]POT(nolign-1)<>0
            [M:SCS1]STUDIS(nolign-1)=WACTDIS*100/[M:SCS1]POT(nolign-1)
            Call QTEARR([M:SCS1]STUDIS(nolign-1),[M:SCS1]STU(nolign-1)) From TRTDIV
         Endif
      Endif
   Endif
   #---

Endif

If [M:SCS1]WSTOSEQ(nolign-1)>0
   [M:SCS1]STUDIS(nolign-1) += sigma(0,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=[M:SCS1]WSTOSEQ(nolign-1))*[M:SGW]WWIPQTY(indcum))
Endif
Affzo [M:SCS1]STUDIS(nolign-1)

Return

###############################################################################
# MAJQTY : Mise à jour des quantités et n° de série après modif
#            de QTYPCU ou QTYSTUDES
###############################################################################
# Paramètres E : PCOD = 1: MAJ de QTYPCU
#                       2: MAJ de QTYSTUDES
#                PVAL = Nouvelle valeur
#            S : PRET = Code retour (0:OK / 1:Erreur)
###############################################################################
Subprog MAJQTY( PCOD, PVAL, PRET )
Value    Integer PCOD
Value    Decimal PVAL
Variable Integer PRET

Local Decimal LQTYSTU
Local Integer LNOL          : LNOL = nolign-1
Local Char    LSERF(GLONSER)

Raz PRET

If PCOD=1
    LQTYSTU = PVAL*[M:SCS1]PCUSTUCOE(LNOL)
    Call QTEARR(LQTYSTU, [M:SCS1]STU(LNOL)) From TRTDIV
Else
    LQTYSTU=PVAL
Endif

If [F:ITM]SERMGTCOD=3
# Ne me parait pas utile, car le test est fait dans FILLCHGW
#    If [M:SGW]NBLIG+LQTYSTU>=dim([M:SGW]WSTOSEQ)
#        Call ERREUR(mess(36,184,1)) From GESECRAN
#        mkstat=2
#        End
#    Endif
    LSERF = [M:SCS1]SERNUM(LNOL)
    For I=2 To LQTYSTU
        Call PLUS_UN(LSERF,LSERF,PRET) From STKLIB
        If PRET : Break : Endif
    Next
    If PRET
        GMESSAGE = mess(476,197,1)
        PRET = 1
        End
    Endif
    [M:SCS1]SERNUMF(LNOL) = LSERF
Else
    If [M:SCS1]STUDIS(LNOL)<LQTYSTU
        GMESSAGE = mess(207,197,1)
        PRET = 1
        End
    Endif
Endif

If [M:SCS1]COEDES(LNOL)>0
    [M:SCS1]QTYPCUDES(LNOL) = LQTYSTU / [M:SCS1]COEDES(LNOL)
Endif

[M:SCS1]QTYSTUDES(LNOL) = LQTYSTU    # On l'affecte dans tous les cas pour le calcul de STUDIS
If PCOD=1
    Affzo [M:SCS1]QTYSTUDES(LNOL)
Else
    [M:SCS1]QTYPCU(LNOL) = LQTYSTU / [M:SCS1]PCUSTUCOE(LNOL)
    Affzo [M:SCS1]QTYPCU(LNOL)
Endif

Gosub MAJ_STUDIS

End

###############################################################################
# DISZOSTO: Diszo des champs STADES, LOCTYPDES, LOCDES
###############################################################################
# Paramètres E : PNOL = indice de la ligne concernée
#
# Attention : le masque par défaut est modifié: SCS1
###############################################################################
Subprog DISZOSTO(PABR, PNOL)
Value Char PABR   # FGR 18/01/2010 : X3SUIVI60986
Value Integer PNOL

    Default Mask "["+PABR+"]"
    Diszo STADES(PNOL),LOCTYPDES(PNOL),LOCDES(PNOL)

End

########################################################################
# RECSTO_F
# Cherche pour une ligne de document donné si dans le détail de cette ligne:
#    - Le statut qualité est unique ou multiple
#    - Le type d'emplacement est unique ou multiple
#    - L'emplacement est unique ou multiple
#    - Désignation du mouvement unique.
# Cette fonction permet de faire apparaître un $ pour montrer la décomposition du champ
########################################################################
# Paramètres E : ABR  = Ecran "XYZ"
#              : FCY  = Site
#              : VCR  = Numéro document
#              : TYP  = Type de document
#              : NOL  = Indice de ligne dans le tableau du document (nolign-1)
#              : LSUP = Inutilisé (paramètre supplémentaire au cas où)
#
# Prérequis : Fichier STOJOU [STJ] ouvert
#             Fichier ITMMASTER [ITM] ouvert et positionné
#             Fichier ITMFACILIT [ITF] ouvert et positionné
########################################################################
# A supprimer
########################################################################
Subprog RECSTO_F (ABR,FCY,TYP,VCR,LIN,NOL,LSUP)
Value Char    ABR
Value Char    FCY
Value Integer TYP
Value Char    VCR
Value Integer LIN
Value Integer NOL
Value Char    LSUP

Local Char    LMABR(10)
Local Char    LITM(GLONITM)
Local Char    PSTA(GLONSTA)
Local Char    PPCU(GLONUOM)
Local Decimal PCOE
Local Decimal PQTYPCU
Local Char    PLOCTYP(GLONTLO)
Local Char    PLOC(GLONEMP)
Local Char    PLPN(GLONLPN)                          # hcb X3-67989

Local Integer I
Local Integer LRET

Local Shortint CLOC    # 1=vérifie la décomposition en plusieurs emplacecments
Local Shortint CLPN    # 1=vérifie la décomposition en plusieurs contenants               # hcb X3-67989
Local Char CAR(1) : CAR = "$"

############
# Init des variables locales
LMABR  = "[M:"+ABR+"]"
LITM   = evalue(LMABR+"ITMREF(NOL)")

Raz I
Raz PSTA
Raz PPCU
Raz PCOE
Raz PQTYPCU
Raz PLOC
Raz PLOCTYP
Raz PLPN                                                           # hcb X3-67989
If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
If !clalev([F:STC]) : Local File STOLOC     [STC] : Endif
If !clalev([F:ITFD])
    Local File ITMFACILIT [ITFD]
    Read [ITFD]ITF0=LITM;FCY
Elsif [F:ITFD]ITMREF<>LITM |  [F:ITFD]STOFCY<>FCY
    Read [ITFD]ITF0=LITM;FCY
Endif

CLOC = evalue("dim("+LMABR+"LOC)")>0 & [F:ITFD]LOCMGTCOD = 2
CLPN = evalue("dim("+LMABR+"LPNNUMDES)")>0 & [F:ITFD]LPNMGTCOD = 2   # hcb X3-67989
################################
# Recherche pour STA, LOC et PCU
Filter [STJ] Where STOFCY = FCY & VCRTYP = TYP & VCRNUM = VCR & VCRLIN = LIN & REGFLG <> 2 & QTYSTU > 0
For [STJ] Hint Key STJ1
    I+=1
    PQTYPCU += [F:STJ]QTYPCU
    # Au 1er tour on initialise les variables qui permettront les comparaisons
    If I=1
        PSTA = [F:STJ]STA
        PPCU = [F:STJ]PCU
        PCOE = [F:STJ]PCUSTUCOE
        If CLPN=1                                      # hcb X3-67989
            PLPN = [F:STJ]LPNNUM                       # hcb X3-67989
         Endif                                         # hcb X3-67989

        If CLOC=1
            PLOC = [F:STJ]LOC
            Read [STC]STC0=FCY;PLOC
            If !fstat
                PLOCTYP = [F:STC]LOCTYP
            Endif
        Endif

        If evalue("dim("+LMABR+"MVTDES)")>0
            Assign LMABR+"MVTDES(NOL)" With [F:STJ]MVTDES
        Endif
    ###########
    # Aux tours suivants on regarde les différences
    Else
        If [F:STJ]STA <> PSTA
            PSTA = CAR
        Endif
        If [F:STJ]PCU <> PPCU
            PPCU = CAR
        Endif
        If [F:STJ]PCUSTUCOE <> PCOE
            PCOE = 0
        Endif
        If CLPN                                      # hcb X3-67989
            If [F:STJ]LPNNUM <> PLPN                 # hcb X3-67989
                PLPN = CAR                           # hcb X3-67989
             Endif                                   # hcb X3-67989
        Endif
        If CLOC
            If [F:STJ]LOC <> PLOC
                PLOC = CAR
                Read [STC]STC0=FCY;[F:STJ]LOC
                If !fstat
                    If [F:STC]LOCTYP <> PLOCTYP
                        PLOCTYP = CAR
                    Endif
                Endif
            Endif
        Endif
    Endif
Next

Filter [STJ]

Assign LMABR+"STADES(NOL)" With PSTA

Assign LMABR+"PCUDES(NOL)" With PPCU
If PPCU=CAR | PCOE=0
    Assign LMABR+"QTYPCUDES(NOL)" With 0
    Assign LMABR+"COEDES(NOL)"    With 0
Else
    Assign LMABR+"COEDES(NOL)" With PCOE
    Assign LMABR+"QTYPCUDES(NOL)" With PQTYPCU
Endif
If CLPN=1                                                          # hcb X3-67989
    Assign LMABR+"LPNNUMDES(NOL)" With PLPN                        # hcb X3-67989
Endif                                                              # hcb X3-67989
If CLOC=1
    Assign LMABR+"LOCTYPDES(NOL)" With PLOCTYP
    Assign LMABR+"LOCDES(NOL)" With PLOC
Endif

End

########################################################################
# CALCNBDET
########################################################################
Funprog CALCNBDET(PWSTOSEQ)
Value Integer PWSTOSEQ
    If PWSTOSEQ=0
        End 0
    Endif
End sigma( 0, [M:SGW]NBLIG-1, (PWSTOSEQ=[M:SGW]WSTOSEQ(indcum))
&                           & (indcum=0 | [M:SGW]WSTOSEQ(indcum)<>[M:SGW]WSTOSEQ(indcum-1) | [M:SGW]WLIGDET(indcum)<>[M:SGW]WLIGDET(indcum-1)) )


########################################################################
# POSTABLE : Positionnement sur les tables ITM, ITF, ITFD, ITG, STL
########################################################################
Subprog POSTABLE(PFCYDES, PITM, PLOT, PSLO, PRET)
Value    Char PFCYDES
Value    Char PITM
Value    Char PLOT
Value    Char PSLO
Variable Integer PRET

#---- Positionnement sur les tables ------------#
Call LECITM2( PFCYDES, PITM, "", PRET ) From STKLIB
If PRET<>0 End Endif

If [F:STL]LOT<>PLOT | [F:STL]SLO<>PSLO
   Read [STL]STL0=PITM;PLOT;PSLO
   If fstat
      Call RSTA("STL",PITM+";"+PLOT+";"+PSLO) From GLOCK
      PRET = 1
      End
   Endif
Endif

If [F:ITFD]ITMREF<>PITM | [F:ITFD]STOFCY<>PFCYDES               # hcb 31986
    Read [ITFD]ITF0=PITM;PFCYDES
    If fstat
        Call RSTA("ITF",PITM+";"+PFCYDES) From GLOCK
        PRET = 1
        End
    Endif
Endif

End



################################################################
# VERALL : Vérifie les allocations et indique les documents concernés
#-----------------------------------------------------------------
# Paramètre d'entrée : PABR : Abréviation du masque du document
#
# Valeur renvoyée    : 0 = Pas d'allocation
#                      1 = Au moins une ligne modifie une allocation
#
# !!! La trace doit être ouverte !!!
################################################################
Funprog VERALL( PABR )
Value Char PABR   # FGR 18/01/2010 : X3SUIVI60986

Local Integer I
Local Integer LALL    # 0=pas d'alloc ; 1=il y a des lignes avec allocations
Local Integer LALLLIG # 0=pas d'alloc sur la ligne en cours ; 1=alloc exist. sur la ligne en cours
Local Integer LNBLIG
Local Char LITM(GLONITM)
Default Mask "["+PABR+"]"
LNBLIG = [M]NBLIG
If !clalev([F:STA]) : Local File STOALL [STA] : Endif
For I=0 To LNBLIG-1
    Raz LALLLIG
    Case PABR
        When "SCS1" : If [M:SCS1]CREFLG(I)>0 : Goto NEXTI : Endif
                      LITM = [M:SCS1]ITMREF(I)
        When "STQ1" : If [M:STQ1]WSTJQTY(I)>[M:STQ1]QTYSTUDES(I) : Goto NEXTI : Endif    # hcb 86427
                      LITM = [M:STQ1]ITMREF
        When "LPNA" : If [M:LPNA]CREFLG(I)>0 : Goto NEXTI : Endif     # Issue 67963 - 2017-12-18 by MAE : LPN
                      LITM = [M:LPNA]ITMREF(I)
        When "LPNO" : If [M:LPNO]CREFLG(I)>0 : Goto NEXTI : Endif     # Issue 67963 - 2017-12-18 by MAE : LPN
                      LITM = [M:LPNO]ITMREF(I)
    Endcase
    If dim([M]SERNUM(I))>0 & [M]SERNUM(I)<>""
        For J=0 To [M:SGW]NBLIG-1
            If [M:SGW]WQTYSTUDES(J)>[M:SGW]WWIPQTY(J) & [M:SGW]WSTOSEQ(J) = [M]WSTOSEQ(I)
                Read [STO]STO5=LITM;[M:SGW]WSERNUM(J)
                If [F:STO]CUMALLQTY>0
                    If !LALLLIG
                        Call ECR_TRACE(mess(3,40,1)-num$(I+1)-" : "+mess(82,184,1),0) From GESECRAN
                        LALLLIG = 1
                    Endif
                    Read [STA]STA0(3)=[M]STOFCY;LITM;[F:STO]STOCOU
                    [G:STA]currlen=0
                    If !fstat
                        Call ECR_TRACE(mess(83,184,1)-[F:STA]VCRNUM,0) From GESECRAN
                        LALL = 1
                    Endif
                Endif
            Endif
        Next
    Else
        If sigma(0,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=[M]WSTOSEQ(I))&([M:SGW]WQTYSTUDES(indcum)>[M:SGW]WWIPQTY(indcum)))
            For [STA] Where STOFCY=[M]STOFCY & STOCOU=[M]WSTOCOU(I)
                If !LALLLIG
                    Call ECR_TRACE(mess(3,40,1)-num$(I+1)-" : "+mess(82,184,1),0) From GESECRAN
                    LALLLIG = 1
                Endif
                Call ECR_TRACE(mess(83,184,1)-[F:STA]VCRNUM,0) From GESECRAN
                LALL = 1
            Next
        Endif
    Endif
    $NEXTI
Next
End LALL

##########################################################
# SCOLOC : récupère l'emplacement lié à un fournisseur
#---------------------------------------------------------
# PBPS = Code fournisseur
# PBPA = Code adresse (Facultatif)
##########################################################
Subprog SCOLOC(PBPS, PBPA)
Value Char PBPS
Value Char PBPA
Effzo [M:SCS1]SCOLOC
Read [BPD]BPD0=PBPS;PBPA
If !fstat & [F:BPD]SCOLOC <>""
   Read [STC]STC0=[M:SCS1]STOFCY;[F:BPD]SCOLOC
   If fstat
      GMESSAGE=[F:BPD]SCOLOC-":"-mess(233,192,1)-[M:SCS1]STOFCY
   Elsif [F:STC]LOCCAT=4
      [M:SCS1]SCOLOC = [F:BPD]SCOLOC
      [M:SCS1]SCOLOCTYP = [F:STC]LOCTYP
   Endif
Endif
If [M:SCS1]SCOLOC=""
   Read [BPS]BPS0=PBPS
   If !fstat & [F:BPS]LOC <> ""
      Read [STC]STC0=[M:SCS1]STOFCY;[F:BPS]LOC
      If fstat
         If GMESSAGE=""
            GMESSAGE=[F:BPS]LOC-":"-mess(233,192,1)-[M:SCS1]STOFCY
         Endif
      Elsif [F:STC]LOCCAT=4
         [M:SCS1]SCOLOC    = [F:BPS]LOC
         [M:SCS1]SCOLOCTYP = [F:STC]LOCTYP
      Endif
   Endif
Endif
If GMESSAGE<>"" Call MESSAGE(GMESSAGE) From GESECRAN Endif
End
#                                                                          # hcb 110327 deb

##############################################################################################
# CTR_SERIES_GLOBALES
# permet de rechercher les numeros de series dans STOSER par rapport au STOCOU pour un article
# qui gère les series en "entrées sorties globales"
#
# appelé depuis le composant OUVCHG de SUBSCSB
#      (FIN de ligne des controles qualités , changement de stock , inters-sites)
#      dans ce cas il y a recherche + supression et alimentation du STOSGW
# appelé depuis le composant CHARG_TAB_CHGS de TRTCHGSERE
#      dans ce cas il y uniquement la recherche car l alimentation se du STOCHGW se fera
#      à l enregistrement de la fenetre SAICHGSERE ou à l enregistrement de la fenetre STOSMP1
##############################################################################################
$CTR_SERIES_GLOBALE
Local Decimal WQTYSTOCOU
Local Decimal WQTYSAISIE
Local Decimal LCOU
Local Decimal LQTYSTU
Local Integer LSEQ
Local Integer LSEQIND
Local Integer LRET
Local Char    WITM
Local Char    PSER(GLONSER)
Local Decimal I
Local Integer WLIGNE
Raz WLIGNE
Raz I
Raz LRET
If clalev([F:STS])  = 0  Local File STOSER      [STS]  Endif
If clalev([M:CHGS]) = 0  Local Mask STOCHGSERE  [CHGS] Endif
Case PABR
     When "STQ1" : WQTYSTOCOU = [M:STQ1]QTYSTU   (PNOL)
                   WQTYSAISIE = [M:STQ1]QTYSTUDES(PNOL)
                   WCOU       = WSTOCOU          (PNOL)
                   WITM       = [M:STQ1]ITMREF

     When "SQD"  : If [F:STO]STOFCY <> [M:SQD]STOFCY | [F:STO]STOCOU <> [M:SQD]WSTOCOU1
                      Read [STO]STO0=[M:SQD]STOFCY;[M:SQD]WSTOCOU1
                      If fstat
                         Raz [F:STO]
                      Endif
                   Endif
                   WQTYSTOCOU = [F:STO]QTYSTU
                   WQTYSAISIE = [M:SCD]QTYSTUDES(PNOL)
                   WCOU       = [M:SQD]WSTOCOU1
                   WITM       = [M:SQD]ITMREF

     When "SCD"  : If [F:STO]STOFCY <> [M:SCD]STOFCY | [F:STO]STOCOU <> [M:SCD]WSTOCOU1
                      Read [STO]STO0=[M:SCD]STOFCY;[M:SCD]WSTOCOU1
                      If fstat
                         Raz [F:STO]
                      Endif
                   Endif
                   WQTYSTOCOU = [F:STO]QTYSTU
                   WQTYSAISIE = [M:SCD]QTYSTUDES(PNOL)
                   WCOU       = [M:SCD]WSTOCOU1
                   WITM       = [M:SCD]ITMREF

     When "SMP"  : If [F:STO]STOFCY <> [M:SMP]STOFCY | [F:STO]STOCOU <> [M:SMP]WSTOCOU(PNOL)
                      Read [STO]STO0=[M:SMP]STOFCY;[M:SMP]WSTOCOU(PNOL)
                      If fstat
                         Raz [F:STO]
                      Endif
                   Endif
                   WQTYSTOCOU = [F:STO]QTYSTU
                   WQTYSAISIE = [M:SMP]QTYSTUDES(PNOL)
                   WCOU       = [M:SMP]WSTOCOU  (PNOL)
                   WITM       = [M:SMP]ITMREF

     When "SCS1" : If [F:STO]STOFCY <> [M:SCS1]STOFCY | [F:STO]STOCOU <> [M:SCS1]WSTOCOU(PNOL)
                      Read [STO]STO0=[M:SCS1]STOFCY;[M:SCS1]WSTOCOU(PNOL)
                      If fstat
                         Raz [F:STO]
                      Endif
                   Endif
                   WQTYSTOCOU = [F:STO]QTYSTU
                   WQTYSAISIE = [M:SCS1]QTYSTUDES(PNOL)
                   WCOU       = [M:SCS1]WSTOCOU  (PNOL)
                   WITM       = [M:SCS1]ITMREF   (PNOL)

     When "QCR1" : WQTYSTOCOU = [F:STO]QTYSTU
                   WQTYSAISIE = [F:STO]QTYSTU
                   WCOU       = [F:STO]STOCOU
                   WITM       = [F:STO]ITMREF

     When "SLM1" : WQTYSTOCOU = [F:STO]QTYSTU
                   WQTYSAISIE = [F:STO]QTYSTU
                   WCOU       = [F:STO]STOCOU
                   WITM       = [F:STO]ITMREF
     # Issue 110327  test MAE
     When "XASC" : If [F:STO]STOFCY <> [M:XASC]STOFCY | [F:STO]STOCOU <> [F:STS]STOCOU
                      Read [STO]STO0=[M:XASC]STOFCY;[F:STS]STOCOU
                      If fstat
                         Raz [F:STO]
                      Endif
                   Endif
                   WQTYSTOCOU = [F:STO]QTYSTU
                   WQTYSAISIE = [M:XASC]QTYSTUDES
                   WCOU       = [F:STS]STOCOU
                   WITM       = [M:XASC]ITMREF
      # Issue X3-67963 - 2017-12-19 by MAE : ajout de l'écran d'affectation des LPN
      When "LPNA" : If [F:STO]STOCOU <> [M:LPNA]WSTOCOU(PNOL)
                      Read [STO]STO0=[M:LPNA]STOFCY;[M:LPNA]WSTOCOU(PNOL)
                      If fstat
                         Raz [F:STO]
                      Endif
                   Endif
                   WQTYSTOCOU = [F:STO]QTYSTU
                   WQTYSAISIE = [M:LPNA]QTYSTUDES(PNOL)
                   WCOU       = [M:LPNA]WSTOCOU  (PNOL)
                   WITM       = [M:LPNA]ITMREF   (PNOL)
      # End issue X3-67963
      # Issue X3-68496 - 2017-12-19 by MAE : ajout de l'écran d'opération sur les LPN
      When "LPNO" : If [F:STO]STOCOU <> [M:LPNO]WSTOCOU(PNOL)
                      Read [STO]STO0=[M:LPNO]STOFCY;[M:LPNO]WSTOCOU(PNOL)
                      If fstat
                         Raz [F:STO]
                      Endif
                   Endif
                   WQTYSTOCOU = [F:STO]QTYSTU
                   WQTYSAISIE = [M:LPNO]QTYSTUDES(PNOL)
                   WCOU       = [M:LPNO]WSTOCOU  (PNOL)
                   WITM       = [M:LPNO]ITMREF   (PNOL)
      # End issue X3-67963

      When Default:
Endcase

Gosub CHARG_BC1_CHGS From TRTCHGSERE
If GACTION <> "SAICHGSERE"
   If [M:CHGS]WSTOCKAGE    = 1
      Call DELSTOCHGW([M:CHGS]STOFCY, [M:CHGS]WSTOSEQ,[M:CHGS]STOCOU, 0, LRET) From TRTSTOSMPB
   Endif
Endif
# si la quantité saisie egale la quantitée en stock alors résupération des numéros de séries
LRET = 9
If WQTYSTOCOU = WQTYSAISIE
   Filter [STS] Where [F:STS]ITMREF = WITM &
&                     [F:STS]STOCOU = WCOU
&               Order By Key STS3
   For [STS]
       Raz LRET
       If [M:CHGS]SERNUM    (I) = ""
          If GACTION <> "SAICHGSERE"
             Gosub CHARG_TAB_CHGS From TRTCHGSERE
          Endif
          [M:CHGS]QTYSTUDES (I) = 1
          [M:CHGS]STUDIS    (I) = 1
          [M:CHGS]SERNUM    (I) = [F:STS]SERNUM
          [M:CHGS]SERNUMF   (I) = [F:STS]SERNUM
          If [M:CHGS]WSTOCKAGE    = 1
             Call WSTOSEQIND ("CHGS", I+1, LSEQIND, LRET) From SUBSCSB
             If LRET
                Return
             Endif
             [M:CHGS]WSTOSEQIND(I) = LSEQIND
          Endif
       Else
          PSER = [M:CHGS]SERNUMF (I)
          Call PLUS_UN(PSER,PSER,LRET) From STKLIB
          If PSER = [F:STS]SERNUM
             [M:CHGS]SERNUMF   (I) =  [F:STS]SERNUM
             [M:CHGS]QTYSTUDES (I) += 1
             [M:CHGS]STUDIS    (I) += 1
          Else
             I+=1
             If GACTION <> "SAICHGSERE"
                Gosub CHARG_TAB_CHGS From TRTCHGSERE
             Endif
             [M:CHGS]QTYSTUDES (I) = 1
             [M:CHGS]STUDIS    (I) = 1
             [M:CHGS]SERNUM    (I) = [F:STS]SERNUM
             [M:CHGS]SERNUMF   (I) = [F:STS]SERNUM
             If [M:CHGS]WSTOCKAGE    = 1
                Call WSTOSEQIND ("CHGS", I+1, LSEQIND, LRET) From SUBSCSB
                If LRET
                   Return
                Endif
                [M:CHGS]WSTOSEQIND(I) = LSEQIND
             Endif
          Endif
       Endif
   Next
   Filter [STS]
   If GACTION = "SAICHGSERE"
      Return
   Endif
    If LRET = 9
      If GFONCTION = "FUNSTOP" | GFONCTION = "FUNSTOLTI"
         Call ECR_TRACE(WITM-" / "-num$(WCOU)-" / "-mess(93,182,1),1) From GESECRAN  # Numéros de série manquant
      Else
         Call ECR_TRACE(mess(93,182,1),0) From GESECRAN  # Numéros de série manquant
      Endif
      Return
    Endif

   [M:CHGS]NBLIG = I+1
   If [M:CHGS]WSTOCKAGE    = 1
      LSEQ = [M:CHGS]WSTOSEQ
      Call FILLCHGW("CHGS", 0, [M:CHGS]NBLIG, LSEQ, [M:CHGS]STOFCY, LRET, LQTYSTU) From SUBSCSB
      If LRET <>0
         Return
      Endif
      If LQTYSTU=0
         LRET = 2
         If GFONCTION = "FUNSTOP" | GFONCTION = "FUNSTOLTI"
            Call ECR_TRACE(WITM-" / "-num$(WCOU)-" / "-mess(367,199,1),1) From GESECRAN  # Pas de stock disponible
         Else
            Call ECR_TRACE(mess(367,199,1),0) From GESECRAN  # Pas de stock disponible
         Endif
         Return
      Endif
   Else
      Gosub CHARG_TABLEAU From TRTCHGSERE
   Endif
Else
   If GIMPORT & PABR = "SCS1"
      Gosub CHARG_TAB_CHGS From TRTCHGSERE
   Endif
Endif
Return
#                                                                          # hcb 110327 end

###########################################################################
# WSTOSEQIND Calcule le nouveau numéro de séquence indice servant de lien #
#            entre le document et le détail                               #
###########################################################################
# Paramètres E : LABR   = Ecran origine
#                LNOL   = Indice de la ligne (nolign-1)
#                LNBLIG = Nb ligne écran origine
#
# Paramètres S : LSEQ   = Lien
#                LRET   = code erreur
#
#########################################################################
Subprog WSTOSEQIND (LABR, LNBLIG, LSEQ, LRET)
Value    Char    LABR
Value    Integer LNBLIG
Variable Integer LSEQ
Variable Integer LRET
Raz LRET
LSEQ=0
If LABR <> ""
   If LNBLIG > 0
      LSEQ = evalue ("max([M:"+LABR+"]WSTOSEQIND(0..LNBLIG-1))")
   Endif
Endif
If [M:SGW]NBLIG > 0
   LSEQ = evalue ("max(LSEQ,[M:SGW]WSTOSEQIND(0..[M:SGW]NBLIG-1))")
Endif
LSEQ +=1
End

# Issue 110327 - 2016-09-13 by MAE : Raz de l'écran STOCHGW
########################################################################
# RAZSTOCHGW     Remise à zéro de l'écran de travail STOCHGW
########################################################################
# Prérequis    : L'écran de travail STOCHGW [SGW] doit être ouvert
#
########################################################################
Subprog RAZSTOCHGW

Raz [M:SGW]

End
# End issue 110327

