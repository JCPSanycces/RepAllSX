#<AdxTL>@(#)6.0.0.0 $Revision$
Raz GPILOBJ
GBIDC2="" : GBIDC3="" : GFLAG="RUSSE"
Call OBJET("GAS",GBIDC2,GBIDC3) From GOBJET
End

# Function GESGAS : Accounting/Financials  Journal Entry
#
# Localization for Russia - Integration of "Double Entry Method"


$OUVRE_KRU
If filinfo(filpath("FIL","BALDEM","fde",0),0)>=0
 If clalev([F:BAM])  = 0 : Local File BALDEM    [BAM] : Endif  # Double Entry Balance
 If clalev([F:BAI])  = 0 : Local File BALDEMIDT [BAI] : Endif  # Double Entry Balance (index table)
Endif
Return

$DECLARE_KRU
If !clalev([F:DAE3]) : Local File GACCENTRYD [DAE3] : Endif
Local Integer FLGDEM, NUMORI
Local Decimal WDEB,WCDT, WQTY,WAMTLED, WAMTFLG, WAMTLED1, WINDDOE
Local Integer NBDOE
Local Char LIBDEB(80), LIBCDT(80), LIBPTR(80)
Call TEXTE(5252,LIBDEB) From OBJDIV
Call TEXTE(5253,LIBCDT) From OBJDIV
Call TEXTE(30019,LIBPTR) From OBJDIV

Local Char    LSTORITYPLED(10)
Local Integer CHKTYPLED
Return

$LIENS_KRU
# A russian ledger is a double entry method ledger. This ledger is a automatical ledger.
# The new field "ACCNUMDOE pointer" is on the automatical ledger.
# Journal Entry don't display automatical ledger : X3 use ACCNUMORI automatic ledger to find source type ledger via ACCNUM.
# (Except for the tab journal entry transaction, then the algorithm is different)

Gosub DECLARE_KRU
Call FLGDEM([F:HAE]CPY,[L]FLGDEM) From CPTDIV
If [L]FLGDEM = 2
 Filter [DAE] Where [M]TYP=TYP & [M]NUM=NUM & [F:DAE]ACCNUMDOE>1
 # Row entry type or  Column entry type
 If [F:GDE]TYPENT=1 or [F:GDE]TYPENT=2
  For [DAE]DAE0
   LINORI = find([F:DAE]ACCNUMORI,[M]ACCNUM(0..NOL))
   If LINORI
    Read [DAE3]DAE2 = [F:DAE]ACCNUMDOE
    If !fstat
     NUMORI = find([F:DAE3]ACCNUMORI,[M:HAEW]ACCNUM(0..[M:HAEW]NB-1))
     If NUMORI : Assign "[M]DOEPTR("+num$(LINORI-1)+")" With [M:HAEW]LINREF(NUMORI-1) : Endif
    Endif
   Endif
  Next
 Else
  ODBGSTR = dbgstr(1)
  For [DAE]DAE0
   # Tab of automatical ledge
   NBLED = find([F:DAE]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   If NBLED>=0
    ABR= "[M:HAE"+num$(NBLED+1)+"]"
    If evalue("dim("+ABR+"NBLIG)>0")
     Default Mask ABR
     LINORI = find([F:DAE]ACCNUMDOE,[M]ACCNUM(0..NOL))
     If LINORI
      NUMORI = find([F:DAE]ACCNUM,[M:HAEW]ACCNUM(0..[M:HAEW]NB-1))
      If NUMORI : Assign "[M]DOEPTR("+num$(LINORI-1)+")" With [M:HAEW]LINREF(NUMORI-1) : Endif
     Endif
    Endif
   Endif
   # Tab of source type ledge link of automatical ledge
   Call ORILEDTYP([F:HAE]CPY,[F:DAE]LEDTYP,[L]ORITYP) From CPTDIV
   NBLED = find([L]ORITYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   If NBLED>=0
    ABR= "[M:HAE"+num$(NBLED+1)+"]"
    If evalue("dim("+ABR+"NBLIG)>0")
     Default Mask ABR
     LINORI = find([F:DAE]ACCNUMORI,[M]ACCNUM(0..NOL))
     If LINORI
      Read [DAE3]DAE2 = [F:DAE]ACCNUMDOE
      If !fstat
       NUMORI = find([F:DAE3]ACCNUMORI,[M:HAEW]ACCNUM(0..[M:HAEW]NB-1))
       If NUMORI : Assign "[M]DOEPTR("+num$(LINORI-1)+")" With [M:HAEW]LINREF(NUMORI-1) : Endif
      Endif
     Endif
    Endif
   Endif
  Next
  Default Mask ODBGSTR
 Endif
 Filter [DAE]
Endif
Return

$VERIF_KRU
# Control between each split line and its dependent line
#   - a split line : if the new field "ACCNUMDOE pointer" is null, this line do to be spit.
#   - a dependent line : if the new field "ACCNUMDOE pointer" is not null, this numeric number is the line number part of the double entry.

#  A dependent line must do point to split line
#  X3 display error message : "Double entry number : Invalid Value (Line xxx)"
Call FLGDEM([M]CPY,[L]FLGDEM) From CPTDIV
If FLGDEM=2 & dim([M]DOEPTR)>0
 OK = 1
 Call LEDTYPDEM([M]CPY,LSTORITYPLED)
 Call MSKABR("DOEPTR",ABR) From SUBGASA
 For NOL=0 To [M]NBLIG-1
  Raz CHKTYPLED
  Case [M:HAEF]TYPENT
   When 1
    #  Saisie en colonne
    For TYD=1 To [M:HAEF]NBRLED
     WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
     WACC = evalue("[M:"+ABR+"]ACC"+num$(TYD)+"(NOL)")
     If WACC<>"" & instr(1,LSTORITYPLED,num$(WTYP)) : CHKTYPLED=1 : Break : Endif
    Next
   When 2
    # Saisie en ligne
    WTYP = evalue("[M:"+ABR+"]LEDTYP(NOL)")
    If instr(1,LSTORITYPLED,num$(WTYP)) : CHKTYPLED=1 : Endif
  Endcase
  If CHKTYPLED=1
   If [M]DOEPTR(NOL)>0
    If [M]DOEPTR([M]DOEPTR(NOL)-1)<>0
     # Double entry number : Invalid Value (Line xxx)
     STAT = 45 : Gosub MESSAGE From CPTAUTO : GMESSAGE = MESSA : mkstat = 2
     GMESSAGE = MESSA-"("+mess(1,114,1)-num$(NOL+1)+")" : OK = 0 : Break
    Endif
   Else
    If !find(NOL+1,[M]DOEPTR(0..[M]NBLIG-1))
     # Double entry number : Invalid Value (Line xxx)
     STAT = 45 : Gosub MESSAGE From CPTAUTO : GMESSAGE = MESSA : mkstat = 2
     GMESSAGE = MESSA-"("+mess(1,114,1)-num$(NOL+1)+")" : OK = 0 : Break
    Endif
   Endif
  Endif
 Next NOL
 If !OK : Return : Endif
Endif
Return

$EQUIL_KRU
# Balance Control between each split line and his dependent line.
# Variable NBDOE = Number of dependent lines (DOEPTR field >0)
For NOL=INDD To INDF
 K = [M:HAEW]DOEPTR(NOL)
 If NBDOE<=K : NBDOE+=1 : Endif
Next
If NBDOE
 # Declaration of work variables versus NBDOE (Number of dependents lines)
 NBDOE+=1
 Local Decimal DOEDEB(NBDOE), DOECDT(NBDOE), DOEIND(NBDOE)
 Raz DOEDEB, DOECDT, NBDOE
 # Total of the amounts to the same dependant line (same number of dependent)
 DOEIND(0) = 0 : NBDOE = 1 # Total of the amounts to the same split line
 For NOL=INDD To INDF
  K = find([M:HAEW]DOEPTR(NOL),DOEIND(0..NBDOE-1))
  If !K
   DOEIND(NBDOE) =  [M:HAEW]DOEPTR(NOL)
   DOEDEB(NBDOE) += [M:HAEW]DEB(NOL)
   DOECDT(NBDOE) += [M:HAEW]CDT(NOL)
   NBDOE+=1
  Else
   DOEDEB(K-1) += [M:HAEW]DEB(NOL)
   DOECDT(K-1) += [M:HAEW]CDT(NOL)
  Endif
 Next
 # Balance Control between the amounts of the dependents lines & the amount of the "split" line.
 For K = 1 To NBDOE-1
  If DOECDT(K)-DOEDEB(K)<>[M]DEB(DOEIND(K)-1)-[M]CDT(DOEIND(K)-1)
   If DOEDEB(K)<>[M]CDT(DOEIND(K)-1)
   # Unbalanced Journal
   GMESSAGE = mess(16,106,1)-"\"-mess(WTYP,2644,1)-[L]LIBPTR-num$(DOEIND(K))-"\"-[L]LIBDEB-num$(DOEDEB(K))-[L]LIBCDT-+num$([M]CDT(DOEIND(K)-1)) : mkstat = 2 : Break
   Endif
   If DOECDT(K)<>[M]DEB(DOEIND(K)-1)
    # Unbalanced Journal
    GMESSAGE = mess(16,106,1)-"\"-mess(WTYP,2644,1)-[L]LIBPTR-num$(DOEIND(K))-"\"-[L]LIBCDT-num$(DOECDT(K))-[L]LIBDEB-+num$([M]DEB(DOEIND(K)-1)) : mkstat = 2 : Break
   Endif
  Endif
 Next
Endif
Return

# Subprog call from CPTBATCH... the same control that $VERIF_KRU
$CONTZONE_KRU
Gosub DECLARE_KRU
# Control between each split line and its dependent line
#   - a split line : if the new field "ACCNUMDOE pointer" is null, this line do to be spit.
#   - a dependent line : if the new field "ACCNUMDOE pointer" is not null, this numeric number is the line number part of the double entry.

#  A dependent line must do point to split line
#  X3 display error message : "Double entry number : Invalid Value (Line xxx)"

Call FLGDEM([M]CPY,[L]FLGDEM) From CPTDIV
If FLGDEM = 2 & dim([M]DOEPTR)>0
 OK = 0
 For NOL=0 To [M]NBLIG-1
  If [M]DOEPTR(NOL)>0
   If [M]DOEPTR([M]DOEPTR(NOL)-1)<>0
    # Double entry number : Invalid Value (Line xxx)
    STAT = 45 : Gosub MESSAGE From CPTAUTO : Break
   Endif
  Else
   If !find(NOL+1,[M]DOEPTR(0..[M]NBLIG-1))
    # Double entry number : Invalid Value (Line xxx)
    STAT = 45 : Gosub MESSAGE From CPTAUTO : Break
   Endif
  Endif
 Next NOL
 If STAT
  If [M]AUTACE<>"" & [M]LIGPCEAUTO(NOL)<>0
   MESSA -= "("+[M]AUTACE-mess(1,114,1)-num$([M]LIGPCEAUTO(NOL))+")" : # Line...
  Else
   MESSA -= "("+mess(1,114,1)-num$(NOL+1)+")" : # Line...
  Endif
 Endif
Endif
Return

$CONTDOE
Call FLGDEM([M]CPY,[L]FLGDEM) From CPTDIV
# Issue X3-103268
#If FLGDEM = 2 & dim([M]DOEPTR)>0 & func AFNC.PARAM("RUSCTLACC",[M]CPY)="2" : # Paramètre à Oui
If FLGDEM = 2 & dim([M]DOEPTR)>0 & func AFNC.ACTIV("KRU") & func AFNC.PARAM("RUSCTLACC",[M]CPY)="2" : # Paramètre à Oui
 Sorta [M:HAEW]NB [M:HAEW]NB Order By [M:HAEW]NUMLIN(indice)
 For NOL=0 To [M:HAEW]NB-1
  If [M:HAEW]DOEPTR(NOL)>0
   If  [M:HAEW]SNS(NOL)=1
    # Dependent line at Debit - a split line at Credit
    Call CONTACCDOE([M:HAEW]ACC(NOL),[M:HAEW]ACC([M:HAEW]DOEPTR(NOL)-1),[M:HAEW]LED(NOL))
    If mkstat : Break : Endif
   Else
    # dependent line at Credit - a split line at Debit
    Call CONTACCDOE([M:HAEW]ACC([M:HAEW]DOEPTR(NOL)-1),[M:HAEW]ACC(NOL),[M:HAEW]LED(NOL))
    If mkstat : Break : Endif
   Endif
  Endif
 Next
Endif
Return

###########################################################################################################
Subprog CONTACCDOE(ACCDEB,ACCCDT,LED)
Value Char    ACCDEB()
Value Char    ACCCDT()
Value Char    LED

If clalev([F:GCA])=0 : Local File GACCAUZ  [GCA] : Endif

Local Integer IND,AXI,NBAUZ,OKAUZ
Call INDLED([L]LED,"",IND,AXI) From CPTDIV
Filter [GCA] Where COA=GLEDCOA(IND)
NBAUZ = rowcount([GCA])
If NBAUZ
 Local Char TABACC(GLONGAC)(0..NBAUZ)
 Local Integer INDDEB,INDCDT
 Raz INDDEB, INDCDT, TABACC
 # Loop debited account to find the account or its roots
 # Write of account in null index and these root from one index
 LNGMAX = GLONGAC
 For LNG=GLONGAC To 1 Step -1
  Filter [GCA] Where COA=GLEDCOA(IND) & len([F:GCA]ACCDEB)=LNG
  For [GCA]
   If TABACC(0)="" & [L]ACCDEB=[F:GCA]ACCDEB
    TABACC(0) = [L]ACCDEB : INDDEB+=1
   Endif
   If left$([L]ACCDEB,len([F:GCA]ACCDEB))=[F:GCA]ACCDEB
    If !find([F:GCA]ACCDEB,TABACC(0..INDDEB))
     INDDEB+=1
     TABACC(INDDEB) = [F:GCA]ACCDEB
    Endif
   Endif
  Next
 Next
 # For credited account, X3 just wish to known if at least one exists to display an error message
 LNGMAX = GLONGAC
 For LNG=GLONGAC To 1 Step -1
  Filter [GCA] Where COA=GLEDCOA(IND) & len([F:GCA]ACCCDT)=LNG
  For [GCA]
   If [L]ACCCDT=[F:GCA]ACCCDT
    INDCDT=1 : Break 2
   Elsif left$([L]ACCCDT,len([F:GCA]ACCCDT))=[F:GCA]ACCCDT
    INDCDT=1 : Break 2
   Endif
  Next
 Next
 If INDDEB>0 or INDCDT>0
  # There is a consistency of accounts rule for a pair of accounts, this rule must be consistent, else error message
  Raz OKAUZ
  For I=0 To INDDEB
   Filter [GCA] Where COA=GLEDCOA(IND) and ACCDEB=TABACC(I)
   For [F:GCA]
    If left$([L]ACCCDT,len([F:GCA]ACCCDT))=[F:GCA]ACCCDT
     OKAUZ = 1 : Break 2
    Endif
   Next
  Next
  If !OKAUZ
   # Double entry number : Unauthorized entry
   STAT = 46 : Gosub MESSAGE From CPTAUTO : GMESSAGE = MESSA-"("+ACCDEB-"/"-ACCCDT+")" : mkstat = 2
  Endif
 Endif
Endif
Filter [GCA]
End

# Write of records "Double Entry Method"
$LEDAUT_KRU

# Management of linked account
Gosub LIAISON_DOE
If !OK :  Return : Endif

NB    = [M:HAEW]NB
NBLIN = [M:HAEW]NB
Raz LIN1
While LIN1<[L]NB

 If [M:HAEW]LEDTYP(LIN1)=[F:GCM]ORILEDTYP(INDLED)
  # Look for the number of rows with the same ledger
  Raz NBIDT
  LIN2=LIN1
  While [M:HAEW]LEDTYP(LIN1)=[M:HAEW]LEDTYP(LIN2)
   LIN2+=1 : NBIDT+=1
   If LIN2>=[L]NB : Break : Endif
  Wend

  # Loop on all lines of ledge
  LIN2=LIN1  # For each ledge
  Raz PRO
  While LIN2<LIN1+NBIDT
   If LIN2>=[L]NB : Break : Endif
   # a dependent line = the fiels "ACCNUMDOE pointer" is not null
   If [M:HAEW]ACCNUMDOE(LIN2)>0
    If [M:HAEW]DSP(LIN2)<>"" & [M:HAEW]DSP(LIN2)<>"$"
     [M:VTL]TOTREP  = [M:HAEW]DEB(LIN2)+[M:HAEW]CDT(LIN2)
     [M:VTL]QTOTREP = [F:DAE]QTY
     #--- Loading allocation
     Call LEC_TCU([M]CUR) From CPTLEC
     Call CHARGE_VTE_STR([M:HAEW]DSP(LIN2),[M:HAEW]UOM(LIN2),[M:HAEW]LED(LIN2),[M:HAEW]ACC(LIN2),"") From VENTILE
     PRO=[M:HAEW]ACCNUMDOE(LIN2)
     WLEDTYP = INDLED+1 :   WLED = [M:HAEW]LED(LIN2)
     WCOA    = [M:HAEW]COA(LIN2) : WACC = [M:HAEW]ACC(LIN2) : WSAC = [M:HAEW]SAC(LIN2)
     WACCNUM = [M:HAEW]ACCNUM(LIN2)
     NOL     = [M:HAEW]LINREF(LIN2)-1
     # Ledge amount...
     Raz WAMTLED, WAMTFLG, WAMTLED1
     Call LEC_TCU([M:HAEW]CURLED(LIN2)) From CPTLEC
     AROLED = [F:TCU]CURRND
     If [M:HAEW]AMTFLG(LIN2)<>0 & [M:HAEW]AMTCUR(LIN2)<>0
      K = 0
      For INDANA=0 To [M:VTL]BAS-1
       If INDANA<>[M:VTL]BAS-1
        TMPLED(K) = arr([M:VTL]AMT(INDANA) * [M:HAEW]AMTLED1(LIN2)/[M:HAEW]AMTCUR(LIN2),AROLED)
       Else
        TMPLED(K) = [M:HAEW]AMTLED1(LIN2)-sum(TMPLED(0..K-1))
       Endif
       K += 1
      Next INDANA
     Else
      If [M:HAEF]RATDIVC([M:HAEW]LEDTYP(LIN2)-1)=1 # Behavior V140
       COURS  = [M:HAEF]RATMLTC([M:HAEW]LEDTYP(LIN2)-1)
      Else
       # Normally, the field RADICV is not null !
       If [M:HAEF]RATDIVC([M:HAEW]LEDTYP(LIN2)-1)=0
         # No Currency Exchange Rate
        GOK=0 : Call ERREUR(mess(16,114,1)) From GESECRAN
        Return
       Endif
       COURS  = [M:HAEF]RATMLTC([M:HAEW]LEDTYP(LIN2)-1)/[M:HAEF]RATDIVC([M:HAEW]LEDTYP(LIN2)-1)
      Endif
      Call CONVERT_DEV([M]CUR,[M:HAEW]CURLED(LIN2),[F:CPY]ACCCUR,[M:VTL]BAS
&                     ,[M:VTL]AMT,TMPLED,COURS
&                     ,[M]TYPRAT,[M]RATDAT,AROLED) From CPTSUB
    Endif
    K = 0
     For RUSANA=0 To [M:VTL]BAS-1
      If [M:HAEW]DEB(LIN2)<>0
       WDEB    = [M:VTL]AMT(RUSANA) : WCDT =0
      Else
       WCDT    = [M:VTL]AMT(RUSANA) : WDEB =0
      Endif
      WQTY = [M:VTL]QTY(RUSANA)
      WINDDOE = NBLIN+2+[M:VTL]BAS-1
      WAMTLED = TMPLED(K)
      WAMTFLG = [M:HAEW]AMTFLG(LIN2)
      WAMTLED1 = TMPLED(K)
      K+=1
      Gosub MAJ From SUBGASB
      #  To avoid key duplicad
      [M:HAEW]LIN(NBLIN-1) = NBLIN
      # After, the allocation must be delete allocation
      For J=1 To GLEDDIENBR(IND)
       AXE = find(evalue("GDIE"+num$(J)+"("+num$(IND)+")"),[M:VTL]DIE(0..19))
       If AXE>0
        WCCE = evalue("[M:VTL]CCE"+num$(AXE)+"("+num$(RUSANA)+")")
        If WCCE<>""
         Assign "[M:HAEW]CCE"+num$(J)+"("+num$(NBLIN-1)+")"  With WCCE
        Endif
       Endif
      Next
      [M:HAEW]DSP(NBLIN-1) = ""
      [M:HAEW]IDTLIN(NBLIN-1) = "RUS"+[M:HAEW]IDTLIN(NBLIN-1)
     Next

    Elsif [M:HAEW]PTV(LIN2)=[M:HAEW]PTF(LIN2)
     PRO=[M:HAEW]ACCNUMDOE(LIN2)
     WLEDTYP = INDLED+1 :   WLED = [M:HAEW]LED(LIN2)
     WCOA    = [M:HAEW]COA(LIN2) : WACC = [M:HAEW]ACC(LIN2) : WSAC = [M:HAEW]SAC(LIN2)
     WACCNUM = [M:HAEW]ACCNUM(LIN2)
     WDEB    = [M:HAEW]DEB(LIN2) :  WCDT    = [M:HAEW]CDT(LIN2) : WQTY    = [M:HAEW]QTY(LIN2)
     WAMTLED = evalue("[M]AMT"+num$(INDLED+1)+"(LIN2)") : WAMTFLG  = evalue("[M]AMTFLG"+num$(INDLED+1)+"(LIN2)") : WAMTLED1 = evalue("[M]AMTFRC"+num$(INDLED+1)+"(LIN2)")
     NOL     = [M:HAEW]LINREF(LIN2)-1
     WINDDOE = NBLIN+2
     Gosub MAJ From SUBGASB
    Else
     PRO=[M:HAEW]ACCNUMDOE(LIN2)
     WLEDTYP = INDLED+1 :   WLED = [M:HAEW]LED(LIN2)
     WCOA    = [M:HAEW]COA(LIN2) : WACC = [M:HAEW]ACC(LIN2) : WSAC = [M:HAEW]SAC(LIN2)
     WACCNUM = [M:HAEW]ACCNUM(LIN2)
     NOL     = [M:HAEW]LINREF(LIN2)-1
     # Ledge amount...
     Raz WAMTLED, WAMTFLG, WAMTLED1
     Call LEC_TCU([M:HAEW]CURLED(LIN2)) From CPTLEC
     AROLED = [F:TCU]CURRND
     If [M:HAEW]AMTFLG(LIN2)<>0 & [M:HAEW]AMTCUR(LIN2)<>0
      K = 0
      For INDANA=[M:HAEW]PTV(LIN2) To [M:HAEW]PTF(LIN2)
       If INDANA<>[M:HAEW]PTF(NOL)
        TMPLED(K) = arr([M:VT2]TBAMT(INDANA) * [M:HAEW]AMTLED1(LIN2)/[M:HAEW]AMTCUR(LIN2),AROLED)
       Else
        TMPLED(K) = [M:HAEW]AMTLED1(LIN2)-sum(TMPLED(0..K-1))
       Endif
       K += 1
      Next INDANA
     Else
      If [M:HAEF]RATDIVC([M:HAEW]LEDTYP(LIN2)-1)=1 # Behavior V140
       COURS  = [M:HAEF]RATMLTC([M:HAEW]LEDTYP(LIN2)-1)
      Else
       # Normally, the field RADICV is not null !
       If [M:HAEF]RATDIVC([M:HAEW]LEDTYP(LIN2)-1)=0
        # No Currency Exchange Rate
        GOK=0 : Call ERREUR(mess(16,114,1)) From GESECRAN
        Return
       Endif
       COURS  = [M:HAEF]RATMLTC([M:HAEW]LEDTYP(LIN2)-1)/[M:HAEF]RATDIVC([M:HAEW]LEDTYP(LIN2)-1)
      Endif
      Call CONVERT_DEV([M]CUR,[M:HAEW]CURLED(LIN2),[F:CPY]ACCCUR,[M:HAEW]PTF(LIN2)-[M:HAEW]PTV(LIN2)+1
&                     ,[M:VT2]TBAMT([M:HAEW]PTV(LIN2)..[M:HAEW]PTF(LIN2)),TMPLED,COURS
&                     ,[M]TYPRAT,[M]RATDAT,AROLED) From CPTSUB
     Endif
     K = 0
     For RUSANA=[M:HAEW]PTV(LIN2) To [M:HAEW]PTF(LIN2)
      If [M:HAEW]DEB(LIN2)<>0
       WDEB    = [M:VT2]TBAMT(RUSANA) : WCDT =0
      Else
       WCDT    = [M:VT2]TBAMT(RUSANA) : WDEB =0
      Endif
      WQTY = [M:VT2]TBQTY(RUSANA)
      WINDDOE = NBLIN+2+[M:HAEW]PTF(LIN2)-[M:HAEW]PTV(LIN2)
      WAMTLED = TMPLED(K)
      WAMTFLG = [M:HAEW]AMTFLG(LIN2)
      WAMTLED1 = TMPLED(K)
      K+=1
      Gosub MAJ From SUBGASB
      #  To avoid key duplicad
      [M:HAEW]LIN(NBLIN-1) = NBLIN
      # After, the allocation must be delete allocation
      For J=1 To GLEDDIENBR(IND)
       AXE = find(evalue("GDIE"+num$(J)+"("+num$(IND)+")"),[M:HAEF]DIE(0..19))
       If AXE>0
        WCCE = evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$(RUSANA)+")")
        If WCCE<>""
         Assign "[M:HAEW]CCE"+num$(J)+"("+num$(NBLIN-1)+")"  With WCCE
        Endif
       Endif
      Next
      [M:HAEW]DSP(NBLIN-1) = ""
      [M:HAEW]IDTLIN(NBLIN-1) = "RUS"+[M:HAEW]IDTLIN(NBLIN-1)
     Next
    Endif
    # A split line
    # Loop again all the lines of group (same ledge) to find the split line
    SVG_LIN2 = LIN2
    LIN2=LIN1
    While LIN2<LIN1+NBIDT
     If LIN2>[L]NB : Break 3 : Endif
     If PRO=[M:HAEW]LINREF(LIN2)
      WLEDTYP = INDLED+1 : WLED    = [M:HAEW]LED(LIN2)
      WCOA    = [M:HAEW]COA(LIN2) : WACC = [M:HAEW]ACC(LIN2) : WSAC = [M:HAEW]SAC(LIN2)
      WACCNUM = [M:HAEW]ACCNUM(LIN2)
      NOL     = [M:HAEW]LINREF(LIN2)-1
      If [M:HAEW]DSP(SVG_LIN2)<>"" & [M:HAEW]DSP(SVG_LIN2)<>"$"
       K=0
       For RUSANA=0 To [M:VTL]BAS-1
        If [M:HAEW]DEB(SVG_LIN2)<>0
         WCDT = [M:VTL]AMT(RUSANA) : WDEB = 0
        Else
         WDEB = [M:VTL]AMT(RUSANA) : WCDT = 0
        Endif
        WQTY = [M:VT2]TBQTY(RUSANA)
        WAMTLED = TMPLED(K)
        WAMTFLG = [M:HAEW]AMTFLG(LIN2)
        WAMTLED1 = TMPLED(K)
        K+=1
        Gosub MAJ From SUBGASB
        #  To avoid key duplicad
        [M:HAEW]LIN(NBLIN-1) = NBLIN
       Next
      Elsif [M:HAEW]PTV(SVG_LIN2)=[M:HAEW]PTF(SVG_LIN2)
       WDEB = [M:HAEW]CDT(SVG_LIN2) : WCDT = [M:HAEW]DEB(SVG_LIN2) : WQTY = [M:HAEW]QTY(SVG_LIN2)
       WAMTLED  = evalue("[M:HAEW]AMTLED("+num$(SVG_LIN2)+")")
       WAMTFLG  = evalue("[M:HAEW]AMTFLG("+num$(SVG_LIN2)+")")
       WAMTLED1 = evalue("[M:HAEW]AMTLED1("+num$(SVG_LIN2)+")")
       Gosub MAJ From SUBGASB
       #  To avoid key duplicad
       [M:HAEW]LIN(NBLIN-1) = NBLIN
      Else
       K=0
       For RUSANA=[M:HAEW]PTV(SVG_LIN2) To [M:HAEW]PTF(SVG_LIN2)
        If [M:HAEW]DEB(SVG_LIN2)<>0
         WCDT = [M:VT2]TBAMT(RUSANA) : WDEB = 0
        Else
         WDEB = [M:VT2]TBAMT(RUSANA) : WCDT = 0
        Endif
        WQTY = [M:VT2]TBQTY(RUSANA)
        WAMTLED = TMPLED(K)
        WAMTFLG = [M:HAEW]AMTFLG(LIN2)
        WAMTLED1 = TMPLED(K)
        K+=1
        Gosub MAJ From SUBGASB
        #  To avoid key duplicad
        [M:HAEW]LIN(NBLIN-1) = NBLIN
       Next
      Endif
      Break
     Endif
     LIN2+=1
    Wend
    LIN2 = SVG_LIN2
   Endif
   LIN2+=1
  Wend
 Endif
 LIN1+=NBIDT
 Break
Wend
Return

$LIAISON_DOE
# Declaration of work variables
# the journal entry multi-sites is it ?
# ------ the first loop to compute the facility amount
Local Char    TBFCY(GLONFCY)(1..GNBSITE)
Local Integer NBFCY, OKLIAIS
Local Integer NBLINCNT

Sorta [M:HAEW]NB [M:HAEW]NB Order By [M:HAEW]LEDTYP(indice), [M:HAEW]DOEPTR(indice)

Local Integer NBLEDTYP
Local Integer NBDOEPTR
Local Integer LIN1_LEDTYP, LIN2_LEDTYP
Local Integer LIN1_DOEPTR, LIN2_DOEPTR

Raz LIN1
While LIN1<[L]NB

 If [M:HAEW]LEDTYP(LIN1)=[F:GCM]ORILEDTYP(INDLED)
  # Look for the number of rows with the same ledger
  Raz NBLEDTYP
  LIN1_LEDTYP=LIN1
  While [M:HAEW]LEDTYP(LIN1_LEDTYP)=[M:HAEW]LEDTYP(LIN2_LEDTYP)
   If LIN2_LEDTYP>=[L]NB : Break : Endif
   LIN2_LEDTYP+=1 : NBLEDTYP+=1
  Wend

  LIN2_DOEPTR=LIN1_LEDTYP  #  Loop on all lines of ledge
  WTYP=[F:GCM]ORILEDTYP(INDLED)
  WLED=[M:HAEW]LED(LIN2_DOEPTR)
  Call INDLED(WLED,"",IND,AXE) From CPTDIV

  While LIN2_DOEPTR<LIN1_LEDTYP+NBLEDTYP
   If LIN2_DOEPTR>=[L]NB : Break 2 : Endif
   If [M:HAEW]DOEPTR(LIN2_DOEPTR)>0
    Raz NBDOEPTR, NBFCY, TBFCY
    # Search the number od the lines with the same ledge/double entrey line
    LIN1_DOEPTR=LIN2_DOEPTR
    While [M:HAEW]DOEPTR(LIN1_DOEPTR)=[M:HAEW]DOEPTR(LIN2_DOEPTR)
     If [M:HAEW]FCYLIN(LIN2_DOEPTR)<>[M]FCY
      If !find([M:HAEW]FCYLIN(LIN2_DOEPTR),TBFCY(1..NBFCY+1))
       NBFCY += 1
       If NBFCY>dim(TBFCY)
        GMESSAGE = mess(31,106,1) : # Too Many Different Sites
        mkstat = 2 : Break 3
       Else
        TBFCY(NBFCY)  = [M:HAEW]FCYLIN(LIN2_DOEPTR)
       Endif
      Endif
     Endif
     LIN2_DOEPTR+=1 : NBDOEPTR+=1
    Wend
    LIN2 = find([M:HAEW]DOEPTR(LIN1_DOEPTR)-1,[M:HAEW]NUMLIN(0..[L]NB))-1
    If LIN2<0 : Break 2 : Endif
    If [M:HAEW]FCYLIN(LIN2)<>[M]FCY
     If !find([M:HAEW]FCYLIN(LIN2),TBFCY(1..NBFCY+1))
      NBFCY += 1
      If NBFCY>dim(TBFCY)
       GMESSAGE = mess(31,106,1) : # Too Many Different Sites
       mkstat = 2 : Break 2
      Else
       TBFCY(NBFCY)  = [M:HAEW]FCYLIN(LIN2)
      Endif
     Endif
    Endif

    If NBFCY
     Local Decimal TBMNT(1..NBFCY), TBMNTLED(1..NBFCY)
     Local Char    ZON(20), MES(50)
     Local Char    TBSAC(GLONSAC)(1..NBFCY), TBACC(GLONGAC)(1..NBFCY), TBBPR(GLONBPR)(1..NBFCY), TBCOA(GLONCOA)(1..NBFCY)
     Local Char    REFSAC(GLONSAC)
     Local Libelle TBFLGLED(1..NBFCY)
     Local Integer OK1 , OK2, INDDOE, TBDOE(1..NBFCY)
     Local Integer NUM_LIAIS1(0..NBFCY),NUM_LIAIS2(0..NBFCY),NUM_LIAIS3(0..NBFCY),NUM_LIAIS4(0..NBFCY),NUM_LIAIS5(0..NBFCY)
     Local Integer NUM_LIAIS6(0..NBFCY),NUM_LIAIS7(0..NBFCY),NUM_LIAIS8(0..NBFCY),NUM_LIAIS9(0..NBFCY),NUM_LIAIS10(0..NBFCY)


     LIN2_DOEPTR=LIN1_DOEPTR   # Loop again all the lines of group (same ledge)

     Raz NBFCY, TBFCY,TBMNT,TBMNTLED,TBSAC,TBACC,TBBPR,TBCOA, TBFLGLED
     While LIN2_DOEPTR<LIN1_DOEPTR+NBDOEPTR
      If LIN2_DOEPTR>=[L]NB : Break 2 : Endif
      NOL = LIN2_DOEPTR : Gosub CONTLIA_DOE
      LIN2_DOEPTR+=1
     Wend

     # the split line
     NOL = find([M:HAEW]DOEPTR(LIN1_DOEPTR)-1,[M:HAEW]NUMLIN(0..[L]NB))-1
     If NOL<0 : Break 2 : Endif
     Gosub CONTLIA_DOE

     # Controls
     If NBFCY
      Gosub CONTLIA2_DOE
      If OK
       Gosub LIAISON2_DOE
      Endif
     Endif
    Endif
   Else
    LIN2_DOEPTR+=1
   Endif
   If LIN2_DOEPTR>=[L]NB : Break 2 : Endif
  Wend
  LIN1 = LIN2_DOEPTR
 Else
  LIN1 += 1
 Endif
Wend

# Restore of sort
Sorta [M:HAEW]NB [M:HAEW]NB Order By [M:HAEW]LEDTYP(indice), [M:HAEW]LIN(indice)
Return


$CONTLIA_DOE
If [M:HAEW]FCYLIN(NOL)<>[M]FCY
 K = find([M:HAEW]FCYLIN(NOL),TBFCY(1..dim(TBFCY)))
 If !K
  NBFCY += 1
  If NBFCY>dim(TBCOA)
   GMESSAGE = mess(31,106,1) : # Too Many Different Sites
   mkstat = 2 : Return
  Else
   K = NBFCY
   TBFCY(K)  = [M:HAEW]FCYLIN(NOL)
   TBCOA(K)  = [M:HAEW]COA(NOL)
   TBDOE(K)  = [M:HAEW]DOEPTR(NOL)
   TBFLGLED(K)= 1
  Endif
 Endif
 If [M:HAEW]DEB(NOL)<>0    : INDDOE=1
 Elsif [M:HAEW]CDT(NOL)<>0 : INDDOE=-1
 Else                      : INDDOE=1
 Endif
 If [M:HAEW]AMTFLG(NOL)<>0 : [M:HAEW]AMTLED(NOL)=[M:HAEW]AMTLED1(NOL)
 Else TBFLGLED(K)=0
 Endif
 TBMNT(K)    += [M:HAEW]DEB(NOL) - [M:HAEW]CDT(NOL)
 TBMNTLED(K) += INDDOE*[M:HAEW]AMTLED(NOL)
Endif
Return

$CONTLIA2_DOE
# Second loop to check the balance by site
OKLIAIS = 0
For INDDOE=1 To NBFCY
 If TBMNT(INDDOE)<>0
  OKLIAIS = 1 : Break
 Endif
Next
If !OKLIAIS : Return : Endif
# The end loop to check parameter.
For K=1 To NBFCY
 If TBMNT(K)<>0
  Read [TCK]TCK0 =  TBCOA(K);TBFCY(K);[M]FCY
  If fstat
   Read [TCK]TCK0 =  TBCOA(K);[M]FCY;TBFCY(K)
   If fstat
    Read [TCK]TCK0 =  TBCOA(K);"";""
    If fstat
     GMESSAGE = mess(32,106,1)-TBFCY(K)-"("+TBCOA(K)+")" : # Linked Account for Inter-site is not defined for
     mkstat = 2 : Break
    Endif
   Endif
  Endif
  Raz GNBSTR
  Call CONTACC([F:TCK]ACC,WTYP,WLED,[M]FCY,[M]CUR,[M]ACCDAT) From SUBGA1 #CHECK IGNORE_LINE
  If mkstat : Break : Endif
  TBSAC(K)  = [F:TCK]SAC
  TBACC(K)  = [F:TCK]ACC
  TBBPR(K)  = [F:TCK]BPR
 Endif
Next
If [M]CAT=4 : # Exceptional
 GMESSAGE = mess(56,106,1) : # Automatic generation of connection entries not possible
 mkstat = 2
Endif
If mkstat : OK=0 : Endif
Return

$LIAISON2_DOE
Gosub AJOUT_HAEW
Gosub AJOUT_HAEX
Return

$AJOUT_HAEW
If !OK | NBFCY=0 : Return : Endif
For INDDOE=1 To NBFCY
 If TBMNT(INDDOE)<>0

  # Write of 2 news lines
  Gosub CONTTAB From SUBGA1 : If !OK : Break : Endif
  NOL = [M:HAEW]NB
  [M:HAEW]FCYLIN(NOL) = [M]FCY
  [M:HAEW]SAC(NOL)    = TBSAC(INDDOE)
  [M:HAEW]ACC(NOL)    = TBACC(INDDOE)
  [M:HAEW]BPR(NOL)    = TBBPR(INDDOE)
  If TBMNT(INDDOE)>=0
    [M:HAEW]DEB(NOL)  = TBMNT(INDDOE)
  Else
    [M:HAEW]CDT(NOL)  = -TBMNT(INDDOE)
  Endif
  If TBFLGLED(INDDOE)
   [M:HAEW]AMTFLG(NOL) = 1
   [M:HAEW]AMTLED1(NOL) = TBMNTLED(INDDOE)*(([M:HAEW]DEB(NOL)<>0)-([M:HAEW]CDT(NOL)<>0))
  Endif
  [M:HAEW]IDTLIN(NOL) = "LIAIS"
  # Initialization again of ACCNUMDOE
  OK2=0
  LIN2=LIN1_LEDTYP
  While LIN2<LIN2_LEDTYP
   If [M:HAEW]FCYLIN(LIN2)=[M:HAEW]FCYLIN(NOL) &  (TBDOE(INDDOE)=[M:HAEW]DOEPTR(LIN2) or TBDOE(INDDOE)=[M:HAEW]NUMLIN(LIN2)+1)
    [M:HAEW]ACCNUMDOE(LIN2) = NOL+1 : OK2=1
   Endif
   LIN2+=1
  Wend
  If !OK2
   # NOT Initialization of ACCNUMDOE => this new line will be initialize
   # [M:HAEW]ACCNUMDOE(NOL) = TBDOE(INDDOE)
  Endif
  Gosub NEWLIN From SUBGA1  : OK=1

  Gosub CONTTAB From SUBGA1 : If !OK : Break : Endif
  NOL = [M:HAEW]NB
  [M:HAEW]FCYLIN(NOL) = TBFCY(INDDOE)
  [M:HAEW]SAC(NOL)    = TBSAC(INDDOE)
  [M:HAEW]ACC(NOL)    = TBACC(INDDOE)
  [M:HAEW]BPR(NOL)    = TBBPR(INDDOE)
  If TBMNT(INDDOE)>=0
    [M:HAEW]CDT(NOL)  = TBMNT(INDDOE)
  Else
    [M:HAEW]DEB(NOL)  = -TBMNT(INDDOE)
  Endif
  If TBFLGLED(INDDOE)
   [M:HAEW]AMTFLG(NOL) = 1
   [M:HAEW]AMTLED1(NOL) = TBMNTLED(INDDOE)*(([M:HAEW]CDT(NOL)<>0)-([M:HAEW]DEB(NOL)<>0))
  Endif
  [M:HAEW]IDTLIN(NOL) = "LIAIS"

  # Initialization again of ACCNUMDOE
  LIN2=LIN1_LEDTYP
  While LIN2<LIN2_LEDTYP
   If [M:HAEW]FCYLIN(LIN2)=[M:HAEW]FCYLIN(NOL) &  (TBDOE(INDDOE)=[M:HAEW]DOEPTR(LIN2) or TBDOE(INDDOE)=[M:HAEW]NUMLIN(LIN2)+1)
    [M:HAEW]ACCNUMDOE(LIN2) = NOL+1 : OK2=1
   Endif
   LIN2+=1
  Wend
  If !OK2
   # NOT Initialization of ACCNUMDOE => this new line will be initialize
   # [M:HAEW]ACCNUMDOE(NOL) = TBDOE(INDDOE)
  Endif
  Gosub NEWLIN From SUBGA1  : OK=1
 Endif
Next INDDOE
Gosub CALTOT From SUBGA1
Return


$AJOUT_HAEX
If !OK | NBFCY=0 : Return : Endif
For INDDOE=1 To NBFCY
 If TBMNT(INDDOE)<>0

  # Write of 2 news lines
  #  Gosub CONTTAB From SUBGA1 : If !OK : Break : Endif
  NOL = [M]NBLIG
  [M]FCYLIN(NOL) = [M]FCY
  If [M:HAEF]TYPENT=2  # saisie ligne
   [M]ACC1(NOL) = TBACC(INDDOE)
   [M]SAC1(NOL) = TBSAC(INDDOE)
  Else
   INDL = find(WTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   Assign "[M]ACC"+num$(INDL)+"(NOL)" With  TBACC(INDDOE)
   Assign "[M]SAC"+num$(INDL)+"(NOL)" With  TBSAC(INDDOE)
  Endif

  [M]BPR(NOL)    = TBBPR(INDDOE)
  If TBMNT(INDDOE)>=0
    [M]DEB(NOL)  = TBMNT(INDDOE)
  Else
    [M]CDT(NOL)  = -TBMNT(INDDOE)
  Endif
  If TBFLGLED(INDDOE)
    Assign "[M]AMTFRC"+num$(WTYP)+"("+num$(NOL)+")" With TBMNTLED(INDDOE)*(([M]DEB(NOL)<>0)-([M]CDT(NOL)<>0))
    Assign "[M]AMTFLG"+num$(WTYP)+"("+num$(NOL)+")" With 1
  Endif
  [M]IDTLIN(NOL) = "LIAIS"

  # Initialization again of ACCNUMDOE
  OK2=0
  For K=0 To [M]NBLIG-1
   If [M]FCYLIN(K)=[M]FCYLIN(NOL) &  (TBDOE(INDDOE)=[M]DOEPTR(K) or TBDOE(INDDOE)=K+1)
    [M]DOEPTR(K) = NOL+1 : OK2=1
   Endif
  Next
  If !OK2
   # NOT Initialization of DOEPTR => this new line will be initialize
   # [M]DOEPTR(NOL) = TBDOE(INDDOE)
  Endif
  Gosub NEWLIN  : OK=1 : # Ligne sur le compte de liaison du site de la pièce


#  Gosub CONTTAB From SUBGA1 : If !OK : Break : Endif
  NOL = [M]NBLIG
  [M]FCYLIN(NOL) = TBFCY(INDDOE)
  If [M:HAEF]TYPENT=2  # saisie ligne
   [M]ACC1(NOL) = TBACC(INDDOE)
   [M]SAC1(NOL) = TBSAC(INDDOE)
  Else
   INDL = find(WTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   Assign "[M]ACC"+num$(INDL)+"(NOL)" With  TBACC(INDDOE)
   Assign "[M]SAC"+num$(INDL)+"(NOL)" With  TBSAC(INDDOE)
  Endif

  [M]BPR(NOL)    = TBBPR(INDDOE)
  If TBMNT(INDDOE)>=0
    [M]CDT(NOL)  = TBMNT(INDDOE)
  Else
    [M]DEB(NOL)  = -TBMNT(INDDOE)
  Endif
  If TBFLGLED(INDDOE)
    Assign "[M]AMTFRC"+num$(WTYP)+"("+num$(NOL)+")" With TBMNTLED(INDDOE)*(([M]CDT(NOL)<>0)-([M]DEB(NOL)<>0))
    Assign "[M]AMTFLG"+num$(WTYP)+"("+num$(NOL)+")" With 1
  Endif
  [M]IDTLIN(NOL) = "LIAIS"

  # Initialization again of ACCNUMDOE
  OK2=0
  For K=0 To [M]NBLIG-1
   If [M]FCYLIN(K)=[M]FCYLIN(NOL) &  (TBDOE(INDDOE)=[M]DOEPTR(K) or TBDOE(INDDOE)=K+1)
    [M]DOEPTR(K) = NOL+1 : OK2=1
   Endif
  Next
  If !OK2
   # NOT Initialization of DOEPTR => this new line will be initialize
   #   [M]DOEPTR(NOL) = TBDOE(INDDOE)
  Endif
  Gosub NEWLIN  : OK=1

 Endif
Next INDDOE
If !OK : Return : Endif
#Gosub CALTOT From SUBGA1
Return


$NEWLIN
For ZON="DES", "TAX", "UOM", "QTY" :    Gosub INIZON :  Next ZON

#Dimensional initialization
If GLEDFLGANA(IND)=2
 If [F:GAC]DSP<>""
  [M]DSP(NOL) = [F:GAC]DSP
 Else
  Call LEC_GDE([M:HAEF]DACDIA) From CPTLEC
  For K=1 To GLEDDIENBR(IND)
   WDIE = evalue("GDIE"+num$(K)+"("+num$(IND)+")")
   Call INICCE(WCCE,WDIE,[M:HAEW]LED(NOL),[M:HAEW]ACC(NOL),[F:GDE]CDE) From CPTINI
   Assign "[M]CCE"+num$(K)+"("+num$(NOL)+")" With WCCE
  Next K
 Endif
Endif

If dim([M]NUMLIN(NOL))>0 : [M]NUMLIN(NOL) = NOL : Endif
[M]NBLIG += 1  : AFF = 1
Return

########
$INIZON
Gosub SETABR From SUBGA1
nolign = NOL+1
Case ZON
 When "DES"
  Call D_DES([M]DES(NOL)) From SUBGA0
  If [M]DES(NOL)=""
   Call LEC_GAC([M]ACC(NOL),[M]COA(NOL)) From CPTLEC
   Call LECTEXTRA([M]DES(NOL),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  Endif
 When "TAX"
  Call D_TAX([M]TAX(NOL)) From SUBGA0
 When "UOM"
  Call D_UOM([M]UOM(NOL)) From SUBGA0
  If [F:GAC]FLGUOM=2 : [M]UOM(NOL) = [F:GAC]UOM :  Endif
 When "QTY"
  Call D_QTY([M]QTY(NOL)) From SUBGA0
Endcase
If GCOMPTA<>3
 Read [GDD]GDD0 = [F:GDE]DIA;ZON
 If fstat=0 & [F:GDD]DEFVAL<>""
  Assign "[M]"+ZON+"("+num$(NOL)+")" With evalue([F:GDD]DEFVAL)
 Endif
Endif
Return



$REPART_KRU

  #--- Total of ledge amount
     Raz TMPAMT
   K = 0
   For I=[M:HAEW]PTV(NOL) To [M:HAEW]PTF(NOL)
    If I<>[M:HAEW]PTF(NOL)
     [L]TMPAMT(K) = arr([M:VT2]TBAMT(I) * [F:DAE]AMTCUR/[L]TOTANA,AROLED)
    Else
     [L]TMPAMT(K) = [F:DAE]AMTCUR-sum([L]TMPAMT(0..K-1))
    Endif
    K += 1
   Next I


  If [M:HAEW]AMTFLG(NOL)<>0 & [F:DAE]AMTCUR<>0
   K = 0
   For I=[M:HAEW]PTV(NOL) To [M:HAEW]PTF(NOL)
    If I<>[M:HAEW]PTF(NOL)
     TMPLED(K) = arr([L]TMPAMT(K) * [F:DAE]AMTLED/[F:DAE]AMTCUR,AROLED)
    Else
     TMPLED(K) = [F:DAE]AMTLED-sum(TMPLED(0..K-1))
    Endif
    K += 1
   Next I
  Else
   If [M:HAEF]RATDIVC([F:DAE]LEDTYP-1)=1 # Behavior V140
    COURS  = [M:HAEF]RATMLTC([F:DAE]LEDTYP-1)
   Else
     # Normally, the field RADICV is not null !
    If [M:HAEF]RATDIVC([F:DAE]LEDTYP-1)=0
      # No Currency Exchange Rate
     GOK=0 : Call ERREUR(mess(16,114,1)) From GESECRAN
     Return
    Endif
    COURS  = [M:HAEF]RATMLTC([F:DAE]LEDTYP-1)/[M:HAEF]RATDIVC([F:DAE]LEDTYP-1)
   Endif
   Call CONVERT_DEV([M]CUR,[M:HAEW]CURLED(NOL),[F:CPY]ACCCUR,[M:HAEW]PTF(NOL)-[M:HAEW]PTV(NOL)+1
&     ,[L]TMPAMT(0..K-1),TMPLED,COURS
&     ,[M]TYPRAT,[M]RATDAT,AROLED) From CPTSUB
  Endif

  #--- Save
  K = 0
  For I=[M:HAEW]PTV(NOL) To [M:HAEW]PTF(NOL)
   K += 1
   Raz [F:DAA]
   [F:DAA] = [F:HAE]
   [F:DAA] = [F:DAE]
   [F:DAA]AMTCUR = [L]TMPAMT(K-1)
   [F:DAA]AMTLED = [L]TMPLED(K-1)
   [F:DAA]QTY    = [M:VT2]TBQTY(I)
   If [F:DAE]SNS=-1 & [M:HAEW]CDT(NOL)=0 # DdM51478
    [F:DAA]QTY    = -[F:DAA]QTY
   Endif
   [F:DAA]ANALIN = K

   Call INDLED([F:DAA]LED,"",IND,J) From CPTDIV
   If IND
    Call LEC_GAC([F:DAE]ACC,[F:DAE]COA) From CPTLEC
    For J=1 To GLEDDIENBR(IND)
     [F:DAA]DIE(J-1) = evalue("GDIE"+num$(J)+"("+num$(IND)+")")
     If find([F:DAA]DIE(J-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
      AXE = find([F:DAA]DIE(J-1),[M:VT2]TBDIE(0..dim([M:VT2]TBDIE)-1))
     If AXE
      [F:DAA]CCE(J-1) = evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$(I)+")")
     Endif
   Endif
    Next
   Endif

   Write [DAA]
   If fstat
    GOK = 0 : Call FSTA("DAA") From GLOCK : Return
   Endif
  Next I

Return



# Import - call GASIMPORT
$IMP_DECLARE
Local Char    ZONE(50),IDT(50)
Local Integer NUMORI,FLGDEM
Return

# Import - call GASIMPORT
$IMP_SAIMSK
If dim([F:DAE]ACCNUMDOE)>0 & dim([M:HAE2]IDT)>0 & dim([M:HAE2]DOEPTR)>0
 NUMORI = find([F:DAE]ACCNUMORI,[M:HAEW]ACCNUM(0..[M:HAEW]NB))
 If NUMORI
  NUMORI = [M:HAEW]LINREF(NUMORI-1)
 Endif
 If [F:DAE]ACCNUMDOE>0
  If NUMORI : Assign "[M:HAE2]DOEPTR("+num$(NUMORI-1)+")" With [F:DAE]ACCNUMDOE*-1 : Endif
 Else
  If NUMORI : Assign "[M:HAE2]IDT("+num$(NUMORI-1)+")" With evalue("[M:HAE2]IDT("+num$(NUMORI-1)+")")+"/"+num$([F:DAE]ACCNUM) : Endif
 Endif
Endif
Return

# Import - call GASIMPORT
$IMP_VALID
If dim([F:DAE]ACCNUMDOE)>0 & dim([M:HAE2]IDT)>0 & dim([M:HAE2]DOEPTR)>0
 # Initialiaze DOEPTR via IDT
 For NOL=0 To [M:HAE2]NBLIG-1
  If [M:HAE2]IDT(NOL)<>""
   ZONE = right$([M:HAE2]IDT(NOL),2)
   K = instr(1,ZONE,"/")
   If K
    While ZONE<>""
     K = instr(1,ZONE,"/")
     If K
      [L]IDT  = left$(ZONE,K-1)
      ZONE = right$(ZONE,K+1)
     Else
      [L]IDT = ZONE
      ZONE = ""
     Endif
     NUMORI = find(val([L]IDT)*-1,[M:HAE2]DOEPTR(0..[M:HAE2]NBLIG-1))
     If NUMORI : Assign "[M:HAE2]DOEPTR("+num$(NUMORI-1)+")" With NOL+1 : Endif
    Wend
   Else
    K = instr(1,ZONE,"/")
    If K
     [L]IDT  = left$(ZONE,K-1)
     ZONE = right$(ZONE,K+1)
    Else
     [L]IDT = ZONE
     ZONE = ""
    Endif
    NUMORI = find(val([L]IDT)*-1,[M:HAE2]DOEPTR(0..[M:HAE2]NBLIG-1))
    If NUMORI : Assign "[M:HAE2]DOEPTR("+num$(NUMORI-1)+")" With NOL+1 : Endif
   Endif
  Endif
 Next
Endif
Return

Subprog LEDTYPDEM(SOCIETE,LSTTYPLED)
Value    Char    SOCIETE()
Variable Char    LSTTYPLED()

If !clalev([F:GCM]) : Local File GACM [GCM] : Endif
Local Char MODELE(GLONGCM)
Local Integer LEDTYP
Call SETGCM(SOCIETE,MODELE) From CPTDIV
Call LEC_GCM(MODELE) From CPTLEC
If !fstat
 For LEDTYP = 1 To len(mess(0,2644,1))
  If dim([F:GCM]DOELED)>0 & [F:GCM]DOELED(LEDTYP-1) = 2
   LSTTYPLED += num$([F:GCM]ORILEDTYP(LEDTYP-1))
  Endif
 Next
Endif
End

