#<AdxTL>@(#)0.0.0.0 $Revision$ 
########################################################################
# Developer testing
########################################################################
Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0 Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI Testing") From LECFIC
  Call MAJ_UTICST201808001(WDOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

End

########################################################################
# Executed during integration of patches from EXE patch element type
########################################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER

  # Do not execute in GDOSX3 exception being GADONIX being set (SCM)
  If [L]DOSSIER = GDOSX3 and GADONIX <> 2 Then
      End
  Endif

  #Open the folder table and read the current record
  #you don't need to do this in UTI_MOUL because it will be done for you
  If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  # Check if module is active
  If [F:ADS]MODULE(8) <> 2 : End : Endif

  # Check that all tables exist and are not views
  If !func TABLE_CHECK([L]DOSSIER) Then
      End
  Endif

  # Perform the updates
  Call MAJ_UTICST201808001(DOSSIER)
End

#######################################################################
# Executed during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (DOSSIER)
Value Char DOSSIER

  # Do not execute in GDOSX3 exception being GADONIX being set (SCM)
  If [L]DOSSIER = GDOSX3 and GADONIX <> 2
    End
  Endif

  # Check if module is active
  If [F:ADS]MODULE(8) <> 2 : End : Endif

  # Check that all tables exist and are not views
  If !func TABLE_CHECK([L]DOSSIER)
    End
  Endif

  # Perform the updates
  Call MAJ_UTICST201808001(DOSSIER)

End

########################################################################
# Check for the existence of every table needed
# Verify that the tables are not a view - indicates historic folder
# If any fail this check, do not run the script
########################################################################
Funprog TABLE_CHECK(DOSSIER)
Value Char DOSSIER

  If filinfo(filpath("FIL","ITMFACILIT","fde",DOSSIER),0)<=0 : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "ITMFACILIT") : End 0 : Endif

  If filinfo(filpath("FIL","ITMCATEG","fde",DOSSIER),0)<=0 : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "ITMCATEG") : End 0 : Endif

  If filinfo(filpath("FIL","ITMMASTER","fde",DOSSIER),0)<=0 : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "ITMMASTER") : End 0 : Endif


End 1

########################################################################
# This subprogram will perform the updates!
########################################################################
Subprog MAJ_UTICST201808001(DOSSIER)
Value Char DOSSIER()

  Local Integer KOUNT
  Local Integer IERR

  Call ECR_TIME("UTICST201808001 : Start of process on : " - DOSSIER) From DOSSUB

  Local File =DOSSIER+".ITMCATEG"   [ITG]
  Local File =DOSSIER+".ITMMASTER"  [ITM]
  Local File =DOSSIER+".ITMFACILIT" [ITF]

  Trbegin [F:ITF]

  #Update all product-site records with blank valuation methods to be the same as the product catagory
  For [F:ITF] Where VLTCOD = "" and STOMGTCOD <> 1
    Read [ITM]ITM0 = [F:ITF]ITMREF
    If fstat
      Call ECR_TRACE("[F:ITF]ITMREF : "+[F:ITF]ITMREF,0) From GESECRAN
      IERR = 1
      Break
    Endif

    Read [ITG]ITG0 = [F:ITF]STOFCY;[F:ITM]TCLCOD
    If fstat
      Read [ITG]ITG0 = "";[F:ITM]TCLCOD
      If fstat
        Call ECR_TRACE("[F:ITF]ITMREF : "+[F:ITF]ITMREF + ". [F:ITF]STOFCY : " +[F:ITF]STOFCY,0) From GESECRAN
        IERR = 1
        Break
      Endif
    Endif

    If [F:ITF]VLTCOD <> [F:ITG]VLTCOD
      [F:ITF]VLTCOD = [F:ITG]VLTCOD
      Rewrite [F:ITF]
      KOUNT += 1
    Endif
  Next

  If !IERR
    Commit
    Call ECR_TRACE("UTICST201808001 : "+num$(KOUNT)+" records were processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTICST201808001 : records processed with error(s).",0) From GESECRAN
  Endif

  Close Local File [ITF]
  Close Local File [ITM]
  Close Local File [ITG]

  #Display an ending message with time to the log
  Call ECR_TIME("UTICST201808001 : End of process on : " - DOSSIER) From DOSSUB

End



#

