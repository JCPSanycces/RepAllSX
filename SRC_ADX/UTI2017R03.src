#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTI2017R03 UTI process for 2017R43 of X3
# ---------------------------------------------------------------------- #
#      moulinettes à passer en fin du patch de la 2017R3 - passage de R2 vers R3
#
#      correction utility to be done at the end of the patch - move from R2 to R3
#
##########################################################################
# Issue 122499 - 20170505 by LD : Grouped price list priority in a modification context

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI2017R03 Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
  #Infbox "only update folder by patch"
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2017R03 (APPLI)

End

###################################################
Subprog EXE_UTI2017R03(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2017R03-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti..
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx..
#-------------------------------------------------------------#

  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTIPJM019              # Issue X3-34418 - 2017-05-02 by FGR
    Call PATCH(LDOSSIER) From SUBMFL                 # Issue X3-44225 - 2017-06-14 by ALSHE
  Endif
  # Issue X3-38669 - 2017-05-23 by SR : Amounts on Receipt header
  If [F:ADS]MODULE(5) = 2 Then
    Call PATCH(LDOSSIER) From UTIACHJ38669
    # Issue 122499
    Call PATCH(LDOSSIER) From SUBPPC
    # End Issue 122499
  Endif
  # Issue 122499
  If [F:ADS]MODULE(6) = 2 Then
    Call PATCH(LDOSSIER) From SUBSPC
  Endif
  # End Issue 122499
  #Issue 44536 – 2017-06-13  by MADOR - FROCURRAT : Variable Non-existent
  If [F:ADS]MODULE(2) = 2 Then
      Call PATCH(LDOSSIER) From SUBTPY
  Endif
  #Issue end

#--- Issue 44718 : For SAM 110327 global serial
If [F:ADS]MODULE(4)=2
  Call PATCH(LDOSSIER) From SUBSLI
  Call PATCH(LDOSSIER) From SUBSLL
  Call PATCH(LDOSSIER) From SUBSLR
  Call PATCH(LDOSSIER) From SUBSLS
Endif
If [F:ADS]MODULE(5)=2
  Call PATCH(LDOSSIER) From SUBPTR
Endif
If [F:ADS]MODULE(6)=2
  # Transactions saisie
  Call PATCH(LDOSSIER) From SUBPBY
  Call PATCH(LDOSSIER) From SUBSRG
  Call PATCH(LDOSSIER) From SUBSRT
  Call PATCH(LDOSSIER) From SUBSNP
  Call PATCH(LDOSSIER) From SUBSCT
  Call PATCH(LDOSSIER) From SUBSLT
  Call PATCH(LDOSSIER) From SUBSQT
  # Consultations
  Call PATCH(LDOSSIER) From CNSSADSTD
  Call PATCH(LDOSSIER) From CNSSDESTD
  Call PATCH(LDOSSIER) From CNSSSESTD
Endif
If [F:ADS]MODULE(7)=2
  Call PATCH(LDOSSIER) From SUBMIL
  Call PATCH(LDOSSIER) From SUBMRE
  Call PATCH(LDOSSIER) From SUBMTL
Endif
#--- End issue 44718

Call ECR_TRACE("END : UTI2017R03-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2017R03
End

