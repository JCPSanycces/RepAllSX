#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################################################
# Traitement TRTSTCDOC -  Gestion de l'écran de consultation des totaux par  -V7 #
#                         nature de charge pour le document       MUARN 23/01/13 #
#     Ecran appelant :                                                           #
#     Document  : Code   Abrev                                                   #
#     Commande  : CSTPOH CSTO                                                    #
#     Réception : CSTPTH CSTP                                                    #
#     Facture   : CSTPIH CSTI                                                    #
##################################################################################

$ACTION
Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "DEBUT"         : Gosub DEBUT
  When "FIN"           : Gosub FIN
  When Default
Endcase
Return

#########################################################################
$OUVRE
Local Char    LABR            # abréviation écran
Local Char    LVCRNUM         # numéro document
Local Integer LVCRTYP
Local Decimal LCHGCOE
Local Integer J
Local Char    LCSTDOC


If clalev([F:STCD])=0    Local File COSTSTCD     [STCD]   Endif
If clalev([F:STCL])=0    Local File COSTSTCL     [STCL]   Endif

If clalev([M:STCDOC])=0
  Local Mask STCDOC   [STCDOC]
Endif

Case PARAM(1)
  When "POH2" : LCSTDOC = "CSTO"
  When "PTH1" : LCSTDOC = "CSTT"
  When "PIH3" : LCSTDOC = "CSTI"
  # Issue 110325 - 2015-10-28 by MAE : landed cost
  When "SHIP1": LCSTDOC = "CSTS"
Endcase

LABR      = evalue("[M:"+LCSTDOC+"]WLABR")
LVCRNUM   = evalue("[M:"+LCSTDOC+"]WVCRNUM")
LVCRTYP   = evalue("[M:"+LCSTDOC+"]WVCRTYP")
LCHGCOE   = evalue("[M:"+LCSTDOC+"]WCHGCOE")

Return

#########################################################################
$DEBUT

Raz [M:STCDOC]
Filter [STCD]  Where VCRTYP=LVCRTYP & VCRNUM=LVCRNUM Order By FCSNAT
For [STCD]
  If J>0 & [M:STCDOC]LIB(J-1) = [F:STCD]FCSNAT
    If [F:STCD]CUR = GCUR
      [M:STCDOC]TOTDOC(J-1) += [F:STCD]FCSAMT
    Else
      # Lecture devise document pour traitement de l'arrondi
      If [F:TCU]CUR<>GCUR
        Read [TCU]TCU0=GCUR
        If fstat  Raz [F:TCU]  Endif
      Endif
      [M:STCDOC]TOTDOC(J-1) += arr([F:STCD]FCSAMTSOC/LCHGCOE,[F:TCU]CURRND)
    Endif
    [M:STCDOC]TOTSOC(J-1) += [F:STCD]FCSAMTSOC
  Else
    [M:STCDOC]LIB(J)    = [F:STCD]FCSNAT
    If  [F:STCD]CUR = GCUR
      [M:STCDOC]TOTDOC(J) = [F:STCD]FCSAMT
    Else
      # Lecture devise document pour traitement de l'arrondi
      If [F:TCU]CUR<>GCUR
        Read [TCU]TCU0=GCUR
        If fstat  Raz [F:TCU]  Endif
      Endif
      [M:STCDOC]TOTDOC(J) = arr([F:STCD]FCSAMTSOC/LCHGCOE,[F:TCU]CURRND)
    Endif
    [M:STCDOC]TOTSOC(J) = [F:STCD]FCSAMTSOC
    [M:STCDOC]NBCST +=1
    J+=1
  Endif
Next
Filter [STCD]

Affzo [M:STCDOC]1-99

Return

#########################################################################
$FIN

Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran CSTPIH) 14/03/2013 16:16:38 (MUARN)
######################################################################################
Subprog AS_STCD(VALEUR)
Variable Char    VALEUR()
If dim([M:PIH0]PIHTYP)>0 & [M:PIH0]PIHTYP<>1
  mkstat=2
Elsif dim([M:POH0]POHFCY)>0 & [M:CSTO]NBCST<1
  mkstat=2
Elsif dim([M:PTH0]PRHFCY)>0 & [M:CSTT]NBCST<1
  mkstat=2
# Issue 66911 - 2017-12-05 by MAE
Elsif dim([M:SHIP0]FCY)>0 & [M:CSTS]NBCST<1
  mkstat=2
Endif
End


######################################################################################

