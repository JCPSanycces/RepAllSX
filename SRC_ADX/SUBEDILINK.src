#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
 Case ACTION
   When "TRT_DIV"
     Case TRAIT
      When "LIEN" : Gosub LIEN
     Endcase
  When Default
 Endcase
Return


$LIEN
  Local Integer WCATTYP : WCATTYP = func GET_CATTYP(PARAM(2))
  If WCATTYP <> 0
    Local Char WOBJCLE(GLONCON) : WOBJCLE = PARAM(1)
#    Local Char SAVACT(20) : SAVACT = GACTION
    GACTION = "GOBJET"

  #1 - Facture d'achat
  #2 - Facture de vente
  #3 - Commande d'achat
  #4 - Commande de vente
  #5 - Livraison de vente
    Local Char W0BJ(10)
    Case WCATTYP #[M:ELK0]CATTYP
      When 1 : WOBJ = "PIH"
      When 2 : WOBJ = "SIH"
      When 3 : WOBJ = "POH"
      When 4 : WOBJ = "SOH"
      When 5 : WOBJ = "SDH"
    Endcase

    Call OBJET(WOBJ,WOBJCLE,"") From GOBJET
#    GACTION = SAVACT
#    If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
#    Gosub AFF From GSAISIE
  Endif
  FIN = 1
Return


#********************************************************************
#
#* Get the GET_CATTYP from EDICAT using CATCOD
#*
#* @param WCATCOD
#* @param WCATTYP
#*!
Funprog GET_CATTYP(WCATCOD)
Value Char WCATCOD

  Local Integer WOK : WOK = [V]CST_AOK

  If WCATCOD <> ""
#    Local Instance MY_EDICAT Using C_EDICAT  # Issue 116339- 2016-04-29 by RBA : optimization
#    MY_EDICAT = NewInstance C_EDICAT AllocGroup null
#    WOK = fmet MY_EDICAT.AREAD(WCATCOD)
#    If WOK = [V]CST_AOK
#      WCATTYP = MY_EDICAT.CATTYP
#    Else
#      WCATTYP = 0
#    Endif
#    FreeGroup MY_EDICAT : MY_EDICAT=null
    Local File EDICAT [ECA]
    Read [ECA]ECA0 = WCATCOD
    If !fstat
      WCATTYP = [F:ECA]CATTYP
    Else
      WCATTYP = 0
    Endif
    Close File [ECA]
  Else
    WOK = [V]CST_AERROR
    WCATTYP = 0
  Endif
End WCATTYP

