#<AdxTL>@(#)8.0.0.0 $Revision$

#-----------------------------------------------------#
# Retourne le nom du dossier X3 avec le nom de machine
#-----------------------------------------------------#

Funprog DOSX3(DOSSIER)
Value Char DOSSIER
Local Char    DOSX3(GLONADD)
Local Char    MACHINE(GLONAMC) , APPLI(GLONADS)
Local Integer ER
DOSX3 = ""
Onerrgo ERDOS
If DOSSIER="" or DOSSIER=nomap
 Local File ADOVAL [ADW_]
Else
 Local File =DOSSIER+".ADOVAL" [ADW_]
Endif
Read [ADW_]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW_]VALEUR<>""
 DOSX3 = [F:ADW_]VALEUR
Endif
Onerrgo
If !ER & DOSX3<>""
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS
 If MACHINE<>""
  DOSX3 = MACHINE+"@"+DOSX3
 Endif
Endif
End DOSX3

$ERDOS
ER = errn
Resume


#**
#* return the default language of the given folder
#*
#* @param DOSSIER
#* @return RES_LANDEF
#*!
Funprog GET_LANDEF(DOSSIER)
Value Char DOSSIER
Local Char RES_LANDEF(GLONLAN)
 Local Char MACHINE(250), APPLI(250), MACDOS(GLONAMC)
 If DOSSIER <> ""
  MACDOS = func DOSX3(DOSSIER)
  If MACDOS=nomap
   Local File ADOSSIER [ADS]
  Else
   Local File =[L]MACDOS+".ADOSSIER" [ADS]
  Endif
  Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS
  Read [ADS]DOSSIER = APPLI
  If !fstat
   RES_LANDEF = [ADS]LANDEF
  Else
   For [ADS] Where DOSHIS=APPLI
    RES_LANDEF = [F:ADS]DOSSIER : Break
   Next ADS
  Endif
 Endif
End RES_LANDEF




#**
#* check if the given LAN is activated for the given folder.
#*
#* @param DOSSIER
#* @param LAN
#* @return RES_OK  1-activated, 0-not activated
#*!
Funprog CHECK_LAN(DOSSIER, LAN)
Value Char DOSSIER, LAN
Local Integer RES_OK
 Local Char MACHINE(250), APPLI(250) , MACDOS(GLONAMC)
 Local Integer I
 If DOSSIER<>"" and LAN <> ""
  MACDOS = func DOSX3(DOSSIER)
  If MACDOS=nomap
   Local File ADOSSIER [ADS]
  Else
   Local File =[L]MACDOS+".ADOSSIER" [ADS]
  Endif
  Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS
  Read [ADS]DOSSIER = APPLI
  If !fstat
   If find(LAN,[F:ADS]LAN) : RES_OK = 1 : Endif
  Else
   For [ADS] Where DOSHIS=APPLI
    If find(LAN, [F:ADS]LAN) : RES_OK = 1 : Endif
    Break
   Next ADS
  Endif
 Endif
End RES_OK


#**
#* return the X3 Lan code for the given ISOLAN
#*
#* @param DOSSIER
#* @param ISOLAN
#*!
Funprog SEARCH_LANX3(DOSSIER, ISOLAN)
Value Char DOSSIER,ISOLAN
Local Char RES_X3LAN(GLONLAN)
 If [L]ISOLAN<>"" and [L]DOSSIER <> ""
  If DOSSIER=nomap
   Local File TABLAN [TLA]
  Else
   Local File =[L]DOSSIER+".TABLAN" [TLA]
  Endif
  For [TLA] Where tolower([F]LANISO)=tolower([L]ISOLAN)
   RES_X3LAN = [F:TLA]LAN : Break
  Next TLA
 Endif
End RES_X3LAN

#**
#* return the X3 backup Language code for the given LAN
#*
#* @param DOSSIER
#* @param LAN
#*!
Funprog SEARCH_LANRPL(DOSSIER, LAN)
Value Char DOSSIER,LAN
Local Char RES_X3RPL(GLONLAN)
 If [L]LAN<>"" and [L]DOSSIER <> ""
  If DOSSIER=nomap
   Local File TABLAN [TLA]
  Else
   Local File =[L]DOSSIER+".TABLAN" [TLA]
  Endif
  For [TLA] Where [F]LAN=[L]LAN
   RES_X3RPL = [F:TLA]LANRPL : Break
  Next TLA
 Endif
End RES_X3RPL

#**
#* return the lan ISO code for the given X3 lan
#*
#* @param DOSSIER
#* @param ISOLAN
#*!
Funprog SEARCH_ISOLAN(DOSSIER,LANX3 )
Value Char DOSSIER,LANX3
Local Char RES_ISOLAN(10)
 If [L]LANX3<>"" and [L]DOSSIER <> ""
  If DOSSIER=nomap
   Local File TABLAN [TLA]
  Else
   Local File =[L]DOSSIER+".TABLAN" [TLA]
  Endif
  For [TLA] Where tolower([F]LAN)=tolower([L]LANX3)
   RES_ISOLAN = [F:TLA]LANISO : Break
  Next TLA
 Endif
End RES_ISOLAN


# ------------------------------------------------------------------------------
#origin=PARAMLINKL from INTRUTILA
# ------------------------------------------------------------------------------
Funprog PARAMLINK(ACTX,DOSSIER,TYPLIEN,MAC,SERV,DOSS,SOL,RET,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char DOSSIER
Value Integer TYPLIEN
Variable Char MAC,DOSS,SOL
Variable Integer SERV,RET
Variable Char    ERRMES()

Local Integer FOUND
Local Integer ASTATUS : [L]ASTATUS=[V]CST_AOK
# Rend les paramètres de définition du lien pour le dossier DOSSIER
# TYPLIEN=1    Divers
#        =2    Lien comptable
#        =3    Lien Immo
#        =4    Lien Paye
#        =5    Lien logistique

# Code retour
# RET = 0     OK
# RET = 1     Dossier inexistant
# RET = 2     Lien non trouvé
# RET = 3     Lien non actif

Raz MAC,SERV,DOSS,RET

If ACTX.AFOLDER=nomap
 Local File ADOSSIER [ADSW]
 Local File ADOSSOL  [ADDW]
Else
 Local File =ACTX.AFOLDER+".ADOSSIER" [ADSW]
 Local File =ACTX.AFOLDER+".ADOSSOL"  [ADDW]
Endif

Read [ADSW]DOSSIER=[L]DOSSIER
If fstat<>0 : RET=1 : [L]ASTATUS=[V]CST_AERROR : ERRMES=mess(7,125,1)-DOSSIER : End [L]ASTATUS : Endif

For [ADDW] Where DOSSIER=[F:ADSW]DOSSIER
 If [F:ADDW]LTYPLIEN=TYPLIEN
  MAC=[F:ADDW]LMAC
  SERV=[F:ADDW]LSERV
  DOSS=[F:ADDW]LDOSTARG
  SOL=[F:ADDW]LSOL
  If [F:ADDW]LLIENACT<>2 : RET=3 : ERRMES=mess(45,105,1)-DOSSIER-mess(2,920,1) : Endif
  FOUND=1
  Break 1
 Endif
Next ADDW
If FOUND=0 : RET=2 : ERRMES=mess(253,139,1)-DOSSIER-mess(2,920,1) : Endif
If RET
 [L]ASTATUS=[V]CST_AERROR
Endif
End [L]ASTATUS

#102739
Funprog ISTRUSTEDENV()
End (dim(ADXSECUREDENVIRONMENT)<0 | ADXSECUREDENVIRONMENT=1)


#102739
Funprog ISTRUSTEDTRT(TRT)
Value Char TRT()
Local Integer ISTRUSTED : ISTRUSTED=1
If find(left$(TRT,1),"Y","Z")>0
 ISTRUSTED=0
Elsif find(left$(TRT,3),"SPV","SPE")>0
 ISTRUSTED=0
Elsif find(left$(TRT,4),"SUBY","SUBZ","CNSY","CNSZ")>0
 ISTRUSTED=0
Elsif pat(TRT,"CNS*SPE")>0
 ISTRUSTED=0
Elsif pat(TRT,"*_CSPE")>0 | pat(TRT,"*_CSPV")>0 | pat(TRT,"*_CVER")>0
 ISTRUSTED=0
Endif
End ISTRUSTED

#102739
Funprog ISTRUSTEDSTC(STC)
Value Char STC()
Local Integer ISTRUSTED : ISTRUSTED=1
If find(left$(STC,3),"C_Y","C_Z","R_Y","R_Z")>0
 ISTRUSTED=0
Endif
End ISTRUSTED
