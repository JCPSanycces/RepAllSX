#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC17          Moulinette de Migration              Module TRC  #
#                                                                        #
#          Update of new field BOMALTTYP                                 #
#                                                                        #
##########################################################################
# From TRCMAJ30  : UPDCSC   : Update of CFGSCE    new field BOMALTTYP    #
##########################################################################
# Issues 80101 & 80102 & get VERSION number - GA 02/2012
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(WDOSSIER,"") From SAIDOS
Endif
If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 107271 - 2015-08-05 by CCC
  #Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif
  If !func DOSSUB.FILL_ADS(WDOSSIER): End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC17") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRC17(WDOSSIER)
  Call MAJ_UUMGTRTTRC17(WDOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
  If APPLI=GDOSX3 : End : Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 107271 - 2015-08-05 by CCC
  #Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If !func DOSSUB.FILL_ADS(APPLI): End : Endif
  Call MAJ_UUMGTRTTRC17(APPLI)
End


#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC17(APPLI)
End

##########################################################################
Subprog MAJ_UUMGTRTTRC17(WDOSSIER)
Value Char WDOSSIER

adxftl=10
adxwrb=10
NEWMOTEUR=1

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 107271 - 2015-08-05 by CCC
#Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif
If !func DOSSUB.FILL_ADS(WDOSSIER): End : Endif

# Présence du Configurateur dans le dossier cible: code activité CFG
Local File =WDOSSIER+".ACTIV"    [ACV]
Local Integer WCFG
Call LECACT("CFG",WCFG) From TRTX3

# Présence du Configurateur
If WCFG=1
  GOK=1
  Gosub LOA_BOM From UUMGTRTTRC00

  Gosub UPDCSC
  If GOK<=0
      Call ECR_TRACE("UUMGTRTTRC17 table CFGSCE Incorrectly Processed : Update CSC"-WDOSSIER,1) From GESECRAN
  Endif
Else
  Call ECR_TRACE("UUMGTRTTRC17: CFG not activated on folder"-WDOSSIER,0) From GESECRAN
  Local Integer ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC17",3,ERR) From TRTMIG : #3=Terminée
Endif

End
##########################################################################
Subprog RAZ_UUMGTRTTRC17(WDOSSIER)
Value Char WDOSSIER

Local Integer ERR

GOK=1

#1 - verifications
####################

If [F:ADS]MODULE(8)<>2 | [F:ADS]MODULE(7)<>2 : End : Endif          : # N= no module

Local Char WNAMFICM
Call MIGTABNAME (WDOSSIER,"CFGSCE",WNAMFICM,ERR) From TRTMIG
If ERR : End : Endif

##2 - On vide les fichiers selon le cas
#######################################

If  filinfo(filpath("FIL","CFGSCE","fde",WDOSSIER),0)>0
& & filinfo(filpath("FIL",WNAMFICM,"fde",WDOSSIER),0)>0
  #Call ECR_TRACE("RAZ_UUMGTRTTRC17 Raz table CFGSCE"-WDOSSIER,0) From GESECRAN
  Call MIGTABRAZ (WDOSSIER,"CFGSCE",ERR) From TRTMIG
  Call MIGRAZKEY (WDOSSIER,"UUMGTRTTRC17",ERR) From TRTMIG
Endif

End

####################################################################################
$UPDCSC
Local Integer ERR

GOK=1

##1 - verifications
####################

If [F:ADS]MODULE(8)<>2 | [F:ADS]MODULE(6)<>2  : # Modules 9=Tronc commun et 7=Stocks
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC17",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

If filinfo(filpath("FIL","CFGSCE","fde",WDOSSIER),0) <=0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC17",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

Call ECR_TRACE("UUMGTRTTRC17 Start trace : CFGSCE => BOMALTTYP" ,0) From GESECRAN

Local Char WNAMFICM
Call MIGTABNAME (WDOSSIER,"CFGSCE",WNAMFICM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC17",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif

#----- Is old renamed file ok ?...  -----#
If filinfo(filpath("FIL",WNAMFICM,"fde",WDOSSIER),0) < 0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC17",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC17",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (WDOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC17",7,ERR) From TRTMIG : #7=Erreur
  Return : # End # 2015-11-09 by GH
Endif

###################

Call ECR_TIME("UUMGTRTTRC17 table CFGSCE Process : Update CSC") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC17:Process Start on : "+WDOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (WDOSSIER,"CFGSCE",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:CSC])  = 0 : Local File =WDOSSIER+".CFGSCE"    [CSC]  : Endif   # Fichier X3 "Vide"
If clalev([F:CSCM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM [CSCM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
Local Char WTAB_CSC (100) (adxwrb) : # Issue 112303 - 2015-11-09 by GH - not to do before MIG_OUVRE
Local Shortint WCPT_CSC

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30) # Issue 80101 ajout HINTSPE
Local Integer NBMIGKEY : NBMIGKEY=2
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE

# Déclaration des variables communes de travail
Local Integer I, J

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (WDOSSIER,"UUMGTRTTRC17",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC17" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CSC00
Raz NB
# Clé CSC0=SCENUM (ancienne table)
If STOP = 1
 STOP = 0
 CRITERE = "[F:CSCM]SCENUM>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [CSC]
GOK = 1

For [CSCM] Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS += 1

  # PE pour exclure ligne
  If FILTRELIN
      ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_CSC : Endif
  Endif

  #Raz [F:CSC]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_CSC
  Endif

  [F:CSC] = [F:CSCM]

  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_CSC
    If GOK<1 : Break : Endif
  Endif

  # --- alimentation des champs et écriture enreg
  If NEWMOTEUR
      Gosub CSC_STK : # pour stocker ref
      WriteB [F:CSC]
  Else
      Write [F:CSC]
  Endif
  If fstat
    If NEWMOTEUR & adxwrb>1
      Call ECR_TRACE("File CFGSCE, Error ="-num$(fstat),1) From GESECRAN
      Gosub CSC_ERRTRA : # pour afficher les ref
    Else
      Call ECR_TRACE("File CFGSCE(SCENUM)"-[F:CSC]SCENUM+", ERROR ="-num$(fstat),1) From GESECRAN
    Endif
    GOK=0 : Break
  Endif

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:CSCM]SCENUM   # Issue 80145 avant ITMREF
    STOP=1
    Break
  Endif
$NEXT_CSC
Next

$END_CSC
If GOK<1
  Rollback
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC17",7,ERR) From TRTMIG : #7=Erreur
Else
  If NEWMOTEUR & adxwrb>1
    Flush [F:CSC]
    If fstat
        Call ECR_TRACE("File CFGSCE, Error ="-num$(fstat),1) From GESECRAN
        Gosub CSC_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_CSC : #on part sur rollback
    Endif
  Endif
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  # Stocker les valeurs de ACLE1/ACLE2/STOP dans la table AMIGKEY.
  Call MIGSTKKEY (WDOSSIER,FLUX,NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto END_CSC
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (WDOSSIER,"UUMGTRTTRC17",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_CSC00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [CSC]
Close Local File [CSCM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (WDOSSIER,"CFGSCE",ERR) From TRTMIG
Call MIGTRTEND (WDOSSIER,"UUMGTRTTRC17") From TRTMIG
Call ECR_TIME("UUMGTRTTRC17:"+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
Return

#######################################################################
$CSC_STK
Call STK (WTAB_CSC,WCPT_CSC,[F:CSC]SCENUM) From TRTMIG
Return

#######################################################################
$CSC_ERRTRA
Call ERRTRA (WTAB_CSC,WCPT_CSC,"File CFGSCE(SCENUM)=") From TRTMIG
Return

##########################################################################
$RAZV6_CSC
Raz [F:CSC]BOMALTTYP  # V6 new field
Raz [F:CSC]ALTTYPREF  # V6 new field
Raz [F:CSC]NBRCOL     # V6 new field
Raz [F:CSC]NBRLIG     # V6 new field
#Raz [F:CSC]SCEAXX     # V6 new field
Return

#######################################################################
# Code extrait de TRCMAJ30 - table CBNHEA
########################################################################
$MAJV6_CSC
If [F:CSC]BOMALT > 0 & [F:CSC]BOMALTTYP=0
   [F:CSC]BOMALTTYP = WBOMALTTYP([F:CSC]BOMALT)
Endif
If [F:CSC]BOMALTREF > 0 & [F:CSC]ALTTYPREF=0
   [F:CSC]ALTTYPREF = WBOMALTTYP([F:CSC]BOMALTREF)
Endif
#[F:CSC]UPDUSR=GUSER
#[F:CSC]UPDDAT=date$
Return

