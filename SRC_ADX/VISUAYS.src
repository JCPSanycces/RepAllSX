#<AdxTL>@(#)0.0.0.0 $Revision$ visu site web
Raz GPILOBJ,GNBMASKOUV
Local Char PARAM(10)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"VISUAYS","VISUAYS","") From GSAISIE
End


$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub DEBUT
 When "FIN"   : Gosub FIN
 When Default
Endcase
Return


$OUVRE
If dim(GAYTFCYWRK)<0 or GAYTFCYWRK="" : FIN =1 : Endif
If !clalev([APW])  : Local File APOOLWS   [APW]    : Endif
If !clalev([AYS])  : Local File AYTFCY    [AYS]    : Endif
If !clalev([AYO])  : Local File AYTPOOWEB [AYO]    : Endif
Local Integer OK,I
Local Char SERVEUR(200),PORT(20),PAGE(GLONAYG),LAN(GLONLAN)
PAGE = PARAM(1)
Return


$DEBUT
Effzo [M]
OK =0
Read [F:AYS]AYS0 = GAYTFCYWRK
If !fstat
 For I=0 To [F:AYS]LNKNBR-1
  If [F:AYS]LNKADSDEF(I) = 2
   OK =1
   Break
  Endif
 Next I
 For J=0 To [F:AYS]LANNBR-1
  If [F:AYS]LANDEF(J) = 2
   LAN = [F:AYS]LANCOD(J)
   OK =1
   Break
  Endif
 Next J
Endif
If !OK : FIN=1 : Return : Endif
Read [AYO]AYO0 =  [F:AYS]LNKADS(I)
If !fstat
 Read [APW]APW1 = [F:AYO]POOX3
 If !fstat
  SERVEUR = [F:APW]SERWEB
  PORT = num$([F:APW]PORTWEB)
 Endif
Endif
# http://ecintradon2:28880/xtend/page?SITE=SUPERV&SOL=SOLSUPV6&FLDR=SUPERV
GBIDC1  = "'http://"+SERVEUR+":"+PORT+'/xtend/page?SITE='+GAYTFCYWRK+'&SOL='+GINSTID+'&FLDR='+nomap
If PAGE<>""
 # &LANG=FRA&PAG=AABOUT
 GBIDC1 += "&LANG="+LAN+"&PAG="+PAGE
Endif
GBIDC1 += "'"
[M]CHEMIN = mid$(GBIDC1,9,len(GBIDC1)-9)
Affzo  [M]
Inftxt GBIDC1 At 1
Return

$FIN
Inftxt "" At 1
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUAYS) 07/09/2009 09:14:31 (CCL)
######################################################################################
Subprog CL_CLIC(VALEUR)
Variable Char    VALEUR()
Call OPEN_HTTP(CHEMIN) From ORDSYS
End


