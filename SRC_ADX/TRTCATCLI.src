###########################################################################
# Test de la saisie du code paramètre CODECATCLI
#
# Module CRM                                                    31 Mars 2003
############################################################################

Subprog VERF_PARAM(PARAM, TSTVALEUR, OK)
Value Char PARAM
Value Char TSTVALEUR
Variable Integer OK

If PARAM <> "CODECATCLI"
    #Erreur dans le code paramètre
    GMESSAGE = mess(204, 196, 2)
    GERR = 1
    OK = 0
    End
Endif

If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif

Read [ACV] CODACT = "STC"
If fstat
    #Aucun contrôle de conformité du code n'a pu être effectué. Création refusé.
    GMESSAGE = mess(205, 196, 2)
    GERR = 1
    OK = 0
    End
Endif

If val(TSTVALEUR) > [F:ACV]DIMFIL
    #Vous devez saisir une valeur inférieure à 
    GMESSAGE = mess(206, 196, 2) + num$([F:ACV]DIMFIL)
    GERR = 3
    OK = 0
    End
Endif

OK = 1
End



