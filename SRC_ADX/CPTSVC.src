#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion du masque CPTSVC
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE
#*X3-39795  MWA  Manage ORIGIN and ORICOD fields in GL Entry
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CPTSVC","CPTSVC",4,"") From GTRAITE
End


#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

#######################################################
## (Actions nécessaires à la saisie des paramètres)
#######################################################
$DEBUT
Affzo [DIA]
Setmok [DIA] With 0
Return

$OUVRE
Gosub OUVFIC

If dim(GCURFCY)>0 : Local Char SAV_GCURFCY(GLONFCY) : SAV_GCURFCY = GCURFCY   : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif

Local Char    OPTGNR(1)
Local Char    SITE(GLONFCY)
Local Char    IDENT(20)(1..10)
  # X3-39795 MWA Start
#Local Char    TZONE1(10)(1..6)  : # Table des zones à forcer pour génération réelle d'une pièce (Ex:réference simulation)
#Local Char    TZONE2(10)(1..3)  : # Table des zones à forcer pour simulation
#Local Char    TVAL1(10)(1..6)   : # Table des valeurs des zones à forcer pour génération réelle d'une pièce
#Local Char    TVAL2(10)(1..3)   : # Table des valeurs des zones à forcer pour simulation
Local Char    TZONE1(10)(1..10)  : # Table des zones à forcer pour génération réelle d'une pièce (Ex:réference simulation)
Local Char    TZONE2(10)(1..10)  : # Table des zones à forcer pour simulation
Local Char    TVAL1(30)(1..10)   : # Table des valeurs des zones à forcer pour génération réelle d'une pièce
Local Char    TVAL2(30)(1..10)   : # Table des valeurs des zones à forcer pour simulation
  # X3-39795 MWA End

Local Char    PCEAUTO(GLONGAU)
Local Char    MESSACPY(10)
Local Char    MESSAFCY(10)
Local Char    MESSA(100)
Local Char    ABR(5)
Local Char    NUMFAC(GLONVCR)
Local Char    CRITERE(255), CRIT(255)
Local Char    CRIT1(255), SCRIT1(255)
Local Char    CRIT3(255), SCRIT3(255)
Local Integer AXE, STAT, K
Local Integer NBPIECE, OKHEADER
Local Decimal AMTNOTSVC       : # Accruals amounts of an invoice
Local Decimal CUMAMT          : # Cumul montant facture
Local Decimal CUMSVC          : # Cumul montant CCA ou PCA
Local Decimal CUMAMTSIG       : # Cumul montant facture signé
Local Decimal CUMSVCSIG       : # Cumul montant CCA ou PCA signé
Local Char    CURCPY(GLONCPY) : # Current company
Local Char    SYMBOLE(80)

TIT = mess(117,107,1) : # Expenses and revenues with apportionment

Local Mask CPTSVC [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","svc") From GMEMO
Gosub OUVRE2

Local Integer EP_CPTSVC : Raz EP_CPTSVC
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("CPTSVC",GENTSTD(1..GNBENTREE))
 EP_CPTSVC=1
Endif
Return


$OUVRE2
If clalev([M:HAE0])=0 : Local Mask GACCENT0   [HAE0] : Endif
If clalev([M:HAE1])=0 : Local Mask GACCENT1   [HAE1] : Endif
If clalev([M:HAE2])=0 : Local Mask GACCENT2   [HAE2] : Endif
If clalev([M:HAEW])=0 : Local Mask GACCENTW   [HAEW] : Endif
If clalev([M:HAEF])=0 : Local Mask GACCENTFMT [HAEF] : Endif
If clalev([M:VTL])=0  : Local Mask VENTILE    [VTL]  : Endif
If clalev([M:VT2])=0  : Local Mask VENTILE2   [VT2]  : Endif

If clalev([F:GAU])=0 : Local File GAUTACE     [GAU] : Endif
If clalev([F:GAD])=0 : Local File GAUTACED    [GAD] : Endif
If clalev([F:GAG])=0 : Local File GAUTACEF    [GAG] : Endif
If clalev([F:CAC])=0 : Local File GACCCODE    [CAC] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT    [GAC] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE   [TCH] : Endif
If clalev([F:TCK])=0 : Local File TABACCLIK   [TCK] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif
If clalev([F:CCE])=0 : Local File CACCE       [CCE] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR  [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD      [PER] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER    [BPR] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT     [TUN] : Endif
If clalev([F:DSP])=0 : Local File CADSP       [DSP] : Endif
If clalev([F:AUZ])=0 : Local File CAAUZ       [AUZ] : Endif
If clalev([F:ANM])=0 : Local File ACODNUM     [ANM] : Endif
If clalev([F:AVN])=0 : Local File AVALNUM     [AVN] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON     [ATZ] : Endif
If clalev([F:ATI])=0 : Local File ATABIND     [ATI] : Endif
If clalev([F:CCE2])=0 : Local File CACCE      [CCE2] : Endif
If clalev([F:ATB])=0  : Local File ATABLE     [ATB]  : Endif
If clalev([F:HAE2])=0 : Local File GACCTMP    [HAE2] : Endif
If GMODU(2)=2  :# Compta
 If clalev([F:GDE])=0 : Local File GDIAENTRY   [GDE] : Endif
 If clalev([F:GDD])=0 : Local File GDIAENTRYD  [GDD] : Endif
 If clalev([F:PBS])=0 : Local File GAPARBSE    [PBS] : Endif
 If clalev([F:JST])=0 : Local File GAJOUSTA    [JST] : Endif
 If clalev([F:HAE1])=0 : Local File GACCENTRY  [HAE1] : Endif
Endif
Return

$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP=1
Endif

If FIN : Return : Endif
If [M:DIA]GENECR = 2
 Call AVERTDGI([M:DIA]ALLCPY,[M:DIA]CPY,[M:DIA]TYP,SAI) From CPTDIV2
Endif
If SAI : Return : Endif

Local Integer OK
If [M:DIA]ALLCPY=2
 SOC=""
Else
 SOC=[M:DIA]CPY
Endif
Call LOCKCPY(SOC, OK) From AX3MONO
If !OK : FIN=1 : Endif
Return


$EXEC

If GSERVEUR
 [M:DIA]TRACE = 2
Endif

If !GSERVEUR & [M:DIA]TRACE=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
If [M:DIA]TRACE=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

If GNBLEG=1
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG=[M:DIA]LEG
Endif

## Rappel des critères de lancement dans le fichier de trace
Call ECR_TRACE(mess(14,103,1)-":",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
If [M:DIA]ALLCPY = 2 : MESSACPY = mess(6,190,1)  : Else : MESSACPY = [M:DIA]CPY : Endif
If [M:DIA]ALLFCY = 2 : MESSAFCY = mess(20,197,1) : Else : MESSAFCY = [M:DIA]FCY : Endif
Call ECR_TRACE(mess(2,45,1)-":"-MESSACPY-"    "-mess(3,45,1)-":"-MESSAFCY-"/"-GCURLEG,0) From GESECRAN
Call ECR_TRACE(mess(3,14,1)-":"-[M:DIA]BPRDEB-[M:DIA]BPRFIN,0) From GESECRAN
Call ECR_TRACE(mess(111,107,1)-":"-[M:DIA]VCRDEB-[M:DIA]VCRFIN,0) From GESECRAN
Call ECR_TRACE(mess(112,107,1)-":"-format$(GFMDAT,[M:DIA]DATDEB)-format$(GFMDAT,[M:DIA]DATFIN),0) From GESECRAN
Call ECR_TRACE(mess(7,190,1)-":"-format$(GFMDAT,[M:DIA]DATREF),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

For [CPY2] Where ([M:DIA]ALLCPY=2 | CPY=[M:DIA]CPY) & CPYLEGFLG=2 & LEG=GCURLEG
 Gosub LOOP_CPY
Next
If !GSERVEUR & [M:DIA]TRACE=2
 Call FERME_TRACE From LECFIC
Endif
Return


$LOOP_CPY

Raz CUMAMT, CUMSVC, CUMAMTSIG, CUMSVCSIG
OK = 1

CURCPY = [F:CPY2]CPY
Case [M:DIA]TYPSVC
 When 1
  SYMBOLE = "CCA\"+CURCPY
 When 2
  SYMBOLE = "PCA\"+CURCPY
Endcase
Lock =SYMBOLE
If fstat
 OK = 0 : Call ECR_TRACE(mess(2,116,1)-CURCPY-":"-mess(30,100,1),1) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
Endif
If OK
 Case [M:DIA]TYPSVC
  When 1
   PCEAUTO = ""
   If func AFNC.ACTIV("SVC")   # Issue X3-107197
    Call PARAM([F:CPY2]CPY,"GAUCCA",PCEAUTO) From ADOVAL
   Endif   # Issue X3-107197
   If PCEAUTO="" : PCEAUTO = "CCA" : Endif
  When 2
   PCEAUTO = ""
   If func AFNC.ACTIV("SVC")   # Issue X3-107197
    Call PARAM([F:CPY2]CPY,"GAUPCA",PCEAUTO) From ADOVAL
   Endif   # Issue X3-107197
   If PCEAUTO="" : PCEAUTO = "PCA" : Endif
 Endcase
# If func AFNC.PARAM("ITAPRE",[F:CPY2]CPY)<>"2"
 If (func AFNC.ACTIV("KIT") and func AFNC.PARAM("ITAPRE", [F:CPY2]CPY) <> "2") or func AFNC.ACTIV("KIT") = 0
  If func AFNC.ACTIV("SVC")   # Issue X3-107197
    Call PARAM([F:CPY2]CPY,"TYPGNRSVC",OPTGNR) From ADOVAL
  Endif   # Issue X3-107197
  If [M:DIA]GENECR = 2
   Gosub ANUPCE : # annulation pièces de simulation
  Endif
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE(mess(2,45,1)-":"-[F:CPY2]CPY,0) From GESECRAN
  Call ECR_TRACE(string$(50,"-"),0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  SITE = [F:CPY2]MAIFCY
  If SITE<>""
   Gosub TRAITEMENT
   GPOINT = "LOGCPY" : Gosub ENTREE From EXEFNC
  Else
   Call ECR_TRACE(mess(68,107,1)-[F:CPY2]CPY,1) From GESECRAN
  Endif
 Endif
 Unlock =SYMBOLE
Endif
Return


$TRAITEMENT

Case [M:DIA]TYPSVC
 When 1 : Gosub FACFOU
 When 2 : Gosub FACCLI
Endcase

If GOK & NBPIECE = 0
 Case [M:DIA]TYPSVC
  When 1
   Call ECR_TRACE(mess(118,107,1),0) From GESECRAN
  When 2
   Call ECR_TRACE(mess(119,107,1),0) From GESECRAN
 Endcase
 Call ECR_TRACE("",0) From GESECRAN
Endif
Return

$REMPLI_CRIT
CRITERE = "1=1"
CRITERE -= '& CPY="'+[F:CPY2]CPY+'"'
CRITERE -= "& STA=3"
If [M:DIA]ALLFCY<>2 & [M:DIA]FCY<>""
 CRITERE -= "& FCY='"+[M:DIA]FCY+"'"
Endif
If [M:DIA]VCRDEB<>""
 CRITERE -= "& NUM>='"+[M:DIA]VCRDEB+"'"
Endif
If [M:DIA]VCRFIN<>""
 CRITERE -= "& NUM<='"+[M:DIA]VCRFIN+"'"
Endif
If [M:DIA]BPRDEB<>""
 CRITERE -= "& BPR>='"+[M:DIA]BPRDEB+"'"
Endif
If [M:DIA]BPRFIN<>""
 CRITERE -= "& BPR<='"+[M:DIA]BPRFIN+"'"
Endif
If [M:DIA]DATDEB<>[0/0/0]
 CRITERE -= '& ACCDAT>=['+format$(GFMD,[M:DIA]DATDEB)+']'
Endif
If [M:DIA]DATFIN<>[0/0/0]
 CRITERE -= '& ACCDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'
Endif
## NB : LASDATSVC contient la date de dernière comptabilisation des CCA/PCA
CRITERE -= '& LASDATSVC<['+format$(GFMD,[M:DIA]DATREF)+']' : # Pour pas comptabiliser 2 fois une même facture...
CRITERE -= '& ACCDAT<=['+format$(GFMD,[M:DIA]DATREF)+']'   : # Dmd33595
Return

$REMPLI_CRIT1
CRIT1 = "1=1" : SCRIT1 = "1=1"
If [M:DIA]TYPSVC = 1
 CRIT1 -= '& [F:PIH2]CPY="'+[F:CPY2]CPY+'"'
 CRIT1 -= "& [F:PIH2]STA=3"
 If [M:DIA]ALLFCY<>2 & [M:DIA]FCY<>""
  CRIT1 -= "& [F:PIH2]FCY='"+[M:DIA]FCY+"'"
 Endif
 If [M:DIA]BPRDEB<>""
  CRIT1 -= "& [F:PIH2]BPR>='"+[M:DIA]BPRDEB+"'"
 Endif
 If [M:DIA]BPRFIN<>""
  CRIT1 -= "& [F:PIH2]BPR<='"+[M:DIA]BPRFIN+"'"
 Endif
 If [M:DIA]DATDEB<>[0/0/0]
  CRIT1 -= '& [F:PIH2]ACCDAT>=['+format$(GFMD,[M:DIA]DATDEB)+']'
 Endif
 If [M:DIA]DATFIN<>[0/0/0]
  CRIT1 -= '& [F:PIH2]ACCDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'
 Endif
 CRIT1 -= '& [F:PIH2]ACCDAT<=['+format$(GFMD,[M:DIA]DATREF)+']'   : # Dmd33595
 CRIT1 -= '& [F:PIH2]LASDATSVC<['+format$(GFMD,[M:DIA]DATREF)+']' : # Pour pas comptabiliser 2 fois une même facture...
Else
 CRIT1 -= '& [F:SIH2]CPY="'+[F:CPY2]CPY+'"'
 CRIT1 -= "& [F:SIH2]STA=3"
 If [M:DIA]ALLFCY<>2 & [M:DIA]FCY<>""
  CRIT1 -= "& [F:SIH2]FCY='"+[M:DIA]FCY+"'"
 Endif
 If [M:DIA]BPRDEB<>""
  CRIT1 -= "& [F:SIH2]BPR>='"+[M:DIA]BPRDEB+"'"
 Endif
 If [M:DIA]BPRFIN<>""
  CRIT1 -= "& [F:SIH2]BPR<='"+[M:DIA]BPRFIN+"'"
 Endif
 If [M:DIA]DATDEB<>[0/0/0]
  CRIT1 -= '& [F:SIH2]ACCDAT>=['+format$(GFMD,[M:DIA]DATDEB)+']'
 Endif
 If [M:DIA]DATFIN<>[0/0/0]
  CRIT1 -= '& [F:SIH2]ACCDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'
 Endif
 CRIT1 -= '& [F:SIH2]ACCDAT<=['+format$(GFMD,[M:DIA]DATREF)+']'   : # Dmd33595
 CRIT1 -= '& [F:SIH2]LASDATSVC<['+format$(GFMD,[M:DIA]DATREF)+']' : # Pour pas comptabiliser 2 fois une même facture...
Endif
If [M:DIA]VCRDEB<>""
 SCRIT1 -= "& NUM>='"+[M:DIA]VCRDEB+"'"
Endif
If [M:DIA]VCRFIN<>""
 SCRIT1 -= "& NUM<='"+[M:DIA]VCRFIN+"'"
Endif
SCRIT1 -= '& STRDAT<>[0/0/0]'
# On ne prend pas les factures dont date de fin prestations est inférieure ou égale à la date référence
SCRIT1 -= '& ENDDAT>['+format$(GFMD,[M:DIA]DATREF)+']'
Return

$REMPLI_CRIT2
CRIT = "1=1"
CRIT -= "& STA=3"
If [M:DIA]VCRDEB<>""
 CRIT -= "& NUM>='"+[M:DIA]VCRDEB+"'"
Endif
If [M:DIA]VCRFIN<>""
 CRIT -= "& NUM<='"+[M:DIA]VCRFIN+"'"
Endif
If [M:DIA]DATDEB<>[0/0/0]
 CRIT -= '& ACCDAT>=['+format$(GFMD,[M:DIA]DATDEB)+']'
Endif
If [M:DIA]DATFIN<>[0/0/0]
 CRIT -= '& ACCDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'
Endif
## NB : LASDATSVC contient la date de dernière comptabilisation des CCA/PCA
CRIT -= '& LASDATSVC<['+format$(GFMD,[M:DIA]DATREF)+']' : # Pour pas comptabiliser 2 fois une même facture...
CRIT -= '& ACCDAT<=['+format$(GFMD,[M:DIA]DATREF)+']'
Return

$REMPLI_CRIT3
CRIT3 = "1=1" : SCRIT3 = "1=1"
If [M:DIA]TYPSVC = 1
 CRIT3 -= '& [PIH2]CPY="'+[F:CPY2]CPY+'"'
 CRIT3 -= "& [PIH2]STA=3"
 If [M:DIA]ALLFCY<>2 & [M:DIA]FCY<>""
  CRIT3 -= "& [PIH2]FCY='"+[M:DIA]FCY+"'"
 Endif
 If [M:DIA]VCRDEB<>""
  CRIT3 -= "& [PIH2]NUM>='"+[M:DIA]VCRDEB+"'"
 Endif
 If [M:DIA]VCRFIN<>""
  CRIT3 -= "& [PIH2]NUM<='"+[M:DIA]VCRFIN+"'"
 Endif
 If [M:DIA]DATDEB<>[0/0/0]
  CRIT3 -= '& [PIH2]ACCDAT>=['+format$(GFMD,[M:DIA]DATDEB)+']'
 Endif
 If [M:DIA]DATFIN<>[0/0/0]
  CRIT3 -= '& [PIH2]ACCDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'
 Endif

 SCRIT3 -= "& [PIH2]BPR='"+[F:PIH3]BPR+"'"
 SCRIT3 -= "& [PIH2]CUR='"+[F:PIH3]CUR+"'"
 SCRIT3 -= '& [PIH2]LASDATSVC<['+format$(GFMD,[M:DIA]DATREF)+']' : # Pour pas comptabiliser 2 fois une même facture...
 SCRIT3 -= '& [PIH2]ACCDAT<=['+format$(GFMD,[M:DIA]DATREF)+']'

Else
 CRIT3 -= '& [SIH2]CPY="'+[F:CPY2]CPY+'"'
 CRIT3 -= "& [SIH2]STA=3"
 If [M:DIA]ALLFCY<>2 & [M:DIA]FCY<>""
  CRIT3 -= "& [SIH2]FCY='"+[M:DIA]FCY+"'"
 Endif
 If [M:DIA]VCRDEB<>""
  CRIT3 -= "& [SIH2]NUM>='"+[M:DIA]VCRDEB+"'"
 Endif
 If [M:DIA]VCRFIN<>""
  CRIT3 -= "& [SIH2]NUM<='"+[M:DIA]VCRFIN+"'"
 Endif
 If [M:DIA]DATDEB<>[0/0/0]
  CRIT3 -= '& [SIH2]ACCDAT>=['+format$(GFMD,[M:DIA]DATDEB)+']'
 Endif
 If [M:DIA]DATFIN<>[0/0/0]
  CRIT3 -= '& [SIH2]ACCDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'
 Endif
 SCRIT3 -= "& [SIH2]BPR='"+[F:SIH3]BPR+"'"
 SCRIT3 -= "& [SIH2]CUR='"+[F:SIH3]CUR+"'"
 ## NB : LASDATSVC contient la date de dernière comptabilisation des CCA/PCA
 SCRIT3 -= '& [SIH2]LASDATSVC<['+format$(GFMD,[M:DIA]DATREF)+']' : # Pour pas comptabiliser 2 fois une même facture...
 SCRIT3 -= '& [SIH2]ACCDAT<=['+format$(GFMD,[M:DIA]DATREF)+']'
Endif
Return


#########################################################################################
# Traitement des charges constatées d'avance
#########################################################################################

$FACFOU
# Parcours des factures fournisseurs issues du même site ou société en fonction du type
# de génération (1 pièce par site ou par société)

NBPIECE = 0
If OPTGNR = "2" : # Une pièce par facture (donc forcément par devise...)
 If GMODU(6)=2
  ## Traitement factures achats
  Link [PID] With [PIH2]PIH0=[F:PID]NUM As [LNK] Order By Key CLE = [PIH2]CUR;[PIH2]BPR;[F:PIH2]NUM
  Gosub FACFOU_2
  If GOK<1 : Return : Endif
 Endif
 ## Traitement factures tiers
 Link [PIL] With [PIH2]PIH0=[F:PIL]NUM As [LNK] Order By Key CLE = [PIH2]CUR;[PIH2]BPR;[F:PIH2]NUM
 Gosub FACFOU_2
 If GOK<1 : Return : Endif

Else : # Une pièce par tiers

 Gosub REMPLI_CRIT
 For [PIH3]CLE(2) Where evalue(CRITERE)
  Call LECTURE("BPS",[F:PIH3]BPR,"") From CONTOBJ
  Call GETSOC([F:PIH3]FCY) From DEVSUB
  Gosub REMPLI_CRIT2
  CRIT -= '& CPY="'+[PIH3]CPY+'"'
  CRIT -= '& CUR="'+[PIH3]CUR+'"'
  CRIT -= '& BPR="'+[PIH3]BPR+'"'
  OKHEADER = 0
  For [PIH3]CLE(3)

   If [F:PIH3]ORIMOD = 3 : # Factures tiers fournisseurs
    Link [PIL] With [PIH2]PIH0=[F:PIL]NUM As [LNK]
   Elsif GMODU(6)=2
    Link [PID] With [PIH2]PIH0=[F:PID]NUM As [LNK]
   Endif
   ## On regarde s'il y a au moins une ligne de facture sur ce tiers dont la date de fin de prestation est
   ## supérieure à la date de référence
   Gosub REMPLI_CRIT3
   Filter [LNK] Where evalue(CRIT3) & evalue(SCRIT3) & STRDAT<>[0/0/0] & ENDDAT>[M:DIA]DATREF
   Read [LNK] First
   Filter [LNK]
   If !fstat
    If [M:DIA]GENECR = 2
     Call DEBTRANS From GLOCK
     Gosub TR_CCA
    Else
     Gosub CCA_BPR
    Endif
    If STAT<>0 | GOK<1
      If [M:DIA]GENECR=2 : Break 2 : Endif
    Endif
    Break
   Endif
  Next
 Next
Endif
If GOK<1 : Return : Endif
Return

$FACFOU_2
Gosub REMPLI_CRIT1
For [LNK]CLE(2) Where evalue(CRIT1) & evalue(SCRIT1)
 Call GETSOC([F:PIH2]FCY) From DEVSUB
 Call LECTURE("BPS",[F:PIH2]BPR,"") From CONTOBJ
 OKHEADER = 0
 For [LNK]CLE(3)
  CRIT = 'NUM = "'+[F:PIH2]NUM+'"'
  SITE = [F:PIH2]FCY
  If [M:DIA]GENECR = 2
   Call DEBTRANS From GLOCK
   Gosub TR_CCA
  Else
   Gosub CCA_SIH
  Endif
  If STAT<>0 | GOK<1
   If [M:DIA]GENECR=2 : Break 2 : Endif
  Endif
 Next
Next
Return

$TR_CCA
GOK = 1
Trbegin [HAE], [DAE], [DAA], [PIH]
 If OPTGNR = "2"
  Gosub CCA_SIH
 Else
  Gosub CCA_BPR
 Endif
 If GOK<0   : Goto ROLL_TR_CCA
 Elsif !GOK : Goto AB_TR_CCA
 Endif
Commit
Return

$AB_TR_CCA
Rollback
Return

$ROLL_TR_CCA
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_CCA : Endif

$CCA_SIH
Gosub VALPCE
If STAT=0 & GOK=1
 CUMAMT += [F:PIH2]AMTNOT : CUMSVC += [M:HAEW]TOTDEB(GTYPGEN-1)
 If [F:PIH2]INVTYP=1 | [F:PIH2]INVTYP=3
  CUMAMTSIG += [F:PIH2]AMTNOT : CUMSVCSIG += [M:HAEW]TOTDEB(GTYPGEN-1)
 Else
  CUMAMTSIG -= [F:PIH2]AMTNOT : CUMSVCSIG -= [M:HAEW]TOTDEB(GTYPGEN-1)
 Endif
 If !OKHEADER
  Call ECR_TRACE(mess(113,107,1)-":"-[F:PIH2]BPR-":"-[F:BPS]BPSNAM+","-[F:PIH2]CUR,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  OKHEADER = 1
 Endif
 # Facture XXX [Montant facture] HT, [Montant pièce CCA] HT
 Call ECR_TRACE(mess(55,198,1)-":"-[F:PIH2]NUM+","-num$([F:PIH2]AMTNOT)-mess(1,243,1)+","
&              -mess(185,107,1)-":"-num$([M:HAEW]TOTDEB(GTYPGEN-1))-mess(1,243,1),0) From GESECRAN
 If [M:DIA]GENECR=2 & [M:DIA]TYP=1
  Readlock [PIH]PIH0 = [F:PIH2]NUM
  If fstat=1
   GOK=-1 : GLOCK="$PINVOICE"-[F:PIH2]NUM : Return
  Elsif fstat
   GOK=0 : Call RSTA("SIH",[F:PIH2]NUM) From GLOCK : Return
  Endif
  [F:PIH]LASDATSVC = [M:DIA]DATREF
  Rewrite [PIH]
  If fstat
   GOK=0 : Call FSTA("PIH") From GLOCK : Return
  Endif
 Endif
 If [M:DIA]GENECR=2
  # Création pièce [TYP] [NUMXX]
  Call ECR_TRACE(mess(40,107,1)-GTYPPCE-MESSA,0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
 Endif
 NBPIECE += 1
 Call ECR_TRACE("",0) From GESECRAN
Else
 Call ECR_TRACE(mess(55,198,1)-":"-[F:PIH2]NUM-":"-MESSA,1) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
 If [M:DIA]GENECR=2 : Return : Endif
Endif
Return

$CCA_BPR
Gosub VALPCE
If STAT=0 & GOK=1
 Sorta [M:HAEW]NB [M:HAEW]NB Order By [M:HAEW]LEDTYP(indice), [M:HAEW]CRITGRP(indice)
 For I=0 To [M:HAEW]NB-1
  If !find([M:HAEW]CRITGRP(I),"1=1","") & [M:HAEW]LEDTYP(I)=GTYPGEN
   K = instr(1,[M:HAEW]CRITGRP(I),"=") : NUMFAC = right$([M:HAEW]CRITGRP(I),K+1)

   If [M:DIA]GENECR=2 & [M:DIA]TYP=1
    Readlock [PIH]PIH0 = NUMFAC
    If fstat=1
     GOK=-1 : GLOCK="$PINVOICE"-NUMFAC : Break
    Elsif fstat
     GOK=0 : Call RSTA("PIH",NUMFAC) From GLOCK : Break
    Endif
    [F:PIH]LASDATSVC = [M:DIA]DATREF
    Rewrite [PIH]
    If fstat
     GOK=0 : Call FSTA("PIH") From GLOCK : Break
    Endif
   Else
    Read [PIH]PIH0 = NUMFAC
   Endif

   If [M:HAE1]RVS=1
    [L]AMTNOTSVC = [M:HAEW]DEB(I)-[M:HAEW]CDT(I)
   Else
    [L]AMTNOTSVC = [M:HAEW]CDT(I)-[M:HAEW]DEB(I)
   Endif
   While [M:HAEW]LEDTYP(I)=[M:HAEW]LEDTYP(I+1) & [M:HAEW]CRITGRP(I)=[M:HAEW]CRITGRP(I+1)
    If [M:HAE1]RVS=1
     [L]AMTNOTSVC += [M:HAEW]DEB(I+1)-[M:HAEW]CDT(I+1)
    Else
     [L]AMTNOTSVC += [M:HAEW]CDT(I+1)-[M:HAEW]DEB(I+1)
    Endif
    I+=1
   Wend

   CUMAMT += [F:PIH]AMTNOT : CUMSVC += [L]AMTNOTSVC
   If [F:PIH]INVTYP=1 | [F:PIH]INVTYP=3
    CUMAMTSIG += [F:PIH]AMTNOT : CUMSVCSIG += [L]AMTNOTSVC
   Else
    CUMAMTSIG -= [F:PIH]AMTNOT : CUMSVCSIG -= [L]AMTNOTSVC
   Endif

   If [F:PIH]INVTYP=2 | [F:PIH]INVTYP=4
    [L]AMTNOTSVC *= -1
   Endif

   If !OKHEADER
    Call ECR_TRACE(mess(113,107,1)-":"-[F:PIH]BPR-":"-[F:BPS]BPSNAM+","-[F:PIH]CUR,0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    OKHEADER = 1
   Endif
   # Facture XXX [Montant facture] HT, [Montant pièce CCA] HT
   Call ECR_TRACE(mess(55,198,1)-":"-NUMFAC+","-num$([F:PIH]AMTNOT)-mess(1,243,1)+","
&                -mess(185,107,1)-":"-num$([L]AMTNOTSVC)-mess(1,243,1),0) From GESECRAN
  Endif
 Next
 If GOK<=0 : Return : Endif
 If [M:DIA]GENECR=2
  # Création pièce [TYP] [XXNUM]
  Call ECR_TRACE(mess(40,107,1)-GTYPPCE-MESSA,0) From GESECRAN
 Endif
 NBPIECE += 1
 Call ECR_TRACE("",0) From GESECRAN
Else
 Call ECR_TRACE(MESSA,1) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
 If [M:DIA]GENECR=2 : Return : Endif
Endif
Return

#########################################################################################
# Traitement des produits constatées d'avance
#########################################################################################

$FACCLI
# Parcours des factures clients issues du même site ou société en fonction du type
# de génération (1 pièce par site ou par société)

NBPIECE = 0

If OPTGNR = "2" : # Une pièce par facture (donc forcément par devise...)
 If GMODU(5)=2
  ## Traitement factures ventes
  Link [SID] With [SIH2]SIH0=[F:SID]NUM As [LNK] Order By Key CLE = [SIH2]CUR;[SIH2]BPR;[F:SIH2]NUM
  Gosub FACCLI_2
  If GOK<1 : Return : Endif
 Endif
 ## Traitement factures tiers clients
 Link [SIL] With [SIH2]SIH0=[F:SIL]NUM As [LNK] Order By Key CLE = [SIH2]CUR;[SIH2]BPR;[F:SIH2]NUM
 Gosub FACCLI_2
 If GOK<1 : Return : Endif

Else : # Une pièce par tiers

 Gosub REMPLI_CRIT
 For [SIH3]CLE(2) Where evalue(CRITERE)

  Call GETSOC([F:SIH3]FCY) From DEVSUB
  Call LECTURE("BPC",[F:SIH3]BPR,"") From CONTOBJ
  Gosub REMPLI_CRIT2
  CRIT -= '& CPY="'+[SIH3]CPY+'"'
  CRIT -= '& CUR="'+[SIH3]CUR+'"'
  CRIT -= '& BPR="'+[SIH3]BPR+'"'
  OKHEADER = 0
  For [SIH3]CLE(3)
   If [F:SIH3]ORIMOD = 3 : # Factures tiers clients
    Link [SIL] With [SIH2]SIH0=[F:SIL]NUM As [LNK]
   Elsif GMODU(5)=2
    Link [SID] With [SIH2]SIH0=[F:SID]NUM As [LNK]
   Endif
   ## On regarde s'il y a au moins une ligne de facture sur ce tiers dont la date de fin de prestation
   ## est supérieure à la date de référence
   Gosub REMPLI_CRIT3
   Filter [LNK] Where evalue(CRIT3) & evalue(SCRIT3) & STRDAT<>[0/0/0] & ENDDAT>[M:DIA]DATREF
   Read [LNK] First
   Filter [LNK]
   If !fstat
    If [M:DIA]GENECR = 2
     Call DEBTRANS From GLOCK
     Gosub TR_PCA
    Else
     Gosub PCA_BPR
    Endif
    If STAT<>0 | GOK<1
      If [M:DIA]GENECR=2 : Break 2 : Endif
    Endif
    Break
   Endif
  Next
 Next
Endif
If GOK<1 : Return : Endif
Return

$FACCLI_2
Gosub REMPLI_CRIT1
For [LNK]CLE(2) Where evalue(CRIT1) & evalue(SCRIT1)
 Call GETSOC([F:SIH2]FCY) From DEVSUB

 Call LECTURE("BPC",[F:SIH2]BPR,"") From CONTOBJ
 OKHEADER = 0
 For [LNK]CLE(3)
  CRIT = 'NUM = "'+[F:SIH2]NUM+'"'
  SITE = [F:SIH2]FCY
  If [M:DIA]GENECR = 2
   Call DEBTRANS From GLOCK
   Gosub TR_PCA
  Else
   Gosub PCA_SIH
  Endif
  If STAT<>0 | GOK<1
   If [M:DIA]GENECR=2 : Break 2 : Endif
  Endif
 Next
Next
Return


$TR_PCA
GOK = 1
Trbegin [HAE], [DAE], [DAA], [SIH]
 If OPTGNR = "2"
  Gosub PCA_SIH
 Else
  Gosub PCA_BPR
 Endif
 If GOK<0   : Goto ROLL_TR_PCA
 Elsif !GOK : Goto AB_TR_PCA
 Endif
Commit
Return

$AB_TR_PCA
Rollback
Return

$ROLL_TR_PCA
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_PCA : Endif

$PCA_SIH
Gosub VALPCE
If STAT=0 & GOK=1
 CUMAMT += [F:SIH2]AMTNOT : CUMSVC += [M:HAEW]TOTDEB(GTYPGEN-1)
 If [F:SIH2]INVTYP=1 | [F:SIH2]INVTYP=3
  CUMAMTSIG += [F:SIH2]AMTNOT : CUMSVCSIG += [M:HAEW]TOTDEB(GTYPGEN-1)
 Else
  CUMAMTSIG -= [F:SIH2]AMTNOT : CUMSVCSIG -= [M:HAEW]TOTDEB(GTYPGEN-1)
 Endif
 If !OKHEADER
  Call ECR_TRACE(mess(114,107,1)-":"-[F:SIH2]BPR-":"-[F:BPC]BPCNAM+","-[F:SIH2]CUR,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  OKHEADER = 1
 Endif
 # Facture XXX [Montant facture] HT, [Date début prest] au [Date fin prestation] [Montant pièce PCA] HT
 Call ECR_TRACE(mess(55,198,1)-":"-[F:SIH2]NUM+","-num$([F:SIH2]AMTNOT)-mess(1,243,1)+","
&              -mess(186,107,1)-":"-num$([M:HAEW]TOTDEB(GTYPGEN-1))-mess(1,243,1),0) From GESECRAN
 If [M:DIA]GENECR=2 & [M:DIA]TYP=1
  Readlock [SIH]SIH0 = [F:SIH2]NUM
  If fstat=1
   GOK=-1 : GLOCK="$SINVOICE"-[F:SIH2]NUM : Return
  Elsif fstat
   GOK=0 : Call RSTA("SIH",[F:SIH2]NUM) From GLOCK : Return
  Endif
  [F:SIH]LASDATSVC = [M:DIA]DATREF
  Rewrite [SIH]
  If fstat
   GOK=0 : Call FSTA("SIH") From GLOCK : Return
  Endif
 Endif
 If [M:DIA]GENECR=2
  # Création pièce [TYP] [NUMXX]
  Call ECR_TRACE(mess(40,107,1)-GTYPPCE-MESSA,0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
 Endif
 NBPIECE += 1
 Call ECR_TRACE("",0) From GESECRAN
Else
 Call ECR_TRACE(mess(55,198,1)-":"-[F:SIH2]NUM-":"-MESSA,1) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
 If [M:DIA]GENECR=2 : Return : Endif
Endif
Return

$PCA_BPR
Gosub VALPCE
If STAT=0 & GOK=1
 Sorta [M:HAEW]NB [M:HAEW]NB Order By [M:HAEW]LEDTYP(indice), [M:HAEW]CRITGRP(indice)
 For I=0 To [M:HAEW]NB-1
  If !find([M:HAEW]CRITGRP(I),"1=1","") & [M:HAEW]LEDTYP(I)=GTYPGEN
   K = instr(1,[M:HAEW]CRITGRP(I),"=") : NUMFAC = right$([M:HAEW]CRITGRP(I),K+1)

   If [M:DIA]GENECR = 2 & [M:DIA]TYP=1
    Readlock [SIH]SIH0 = NUMFAC
    If fstat=1
     GOK=-1 : GLOCK="$SINVOICE"-NUMFAC : Break
    Elsif fstat
     GOK=0 : Call RSTA("SIH",NUMFAC) From GLOCK : Break
    Endif
    [F:SIH]LASDATSVC = [M:DIA]DATREF
    Rewrite [SIH]
    If fstat
     GOK=0 : Call FSTA("SIH") From GLOCK : Break
    Endif
   Else
    Read [SIH]SIH0 = NUMFAC
   Endif

   If [M:HAE1]RVS=1
    [L]AMTNOTSVC = [M:HAEW]CDT(I)-[M:HAEW]DEB(I)
   Else
    [L]AMTNOTSVC = [M:HAEW]DEB(I)-[M:HAEW]CDT(I)
   Endif
   While [M:HAEW]LEDTYP(I)=[M:HAEW]LEDTYP(I+1) & [M:HAEW]CRITGRP(I)=[M:HAEW]CRITGRP(I+1)
    If [M:HAE1]RVS=1
     [L]AMTNOTSVC += [M:HAEW]CDT(I+1)-[M:HAEW]DEB(I+1)
    Else
     [L]AMTNOTSVC += [M:HAEW]DEB(I+1)-[M:HAEW]CDT(I+1)
    Endif
    I+=1
   Wend

   CUMAMT += [F:SIH]AMTNOT : CUMSVC += [L]AMTNOTSVC
   If [F:SIH]INVTYP=1 | [F:SIH]INVTYP=3
    CUMAMTSIG += [F:SIH]AMTNOT : CUMSVCSIG += [L]AMTNOTSVC
   Else
    CUMAMTSIG -= [F:SIH]AMTNOT : CUMSVCSIG -= [L]AMTNOTSVC
   Endif

   If [F:SIH]INVTYP=2 | [F:SIH]INVTYP=4
    [L]AMTNOTSVC *= -1
   Endif

   If !OKHEADER
    Call ECR_TRACE(mess(114,107,1)-":"-[F:SIH]BPR-":"-[F:BPC]BPCNAM+","-[F:SIH]CUR,0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    OKHEADER = 1
   Endif
   # Facture XXX [Montant facture] HT, [Date début prest] au [Date fin prestation] [Montant pièce PCA] HT
   Call ECR_TRACE(mess(55,198,1)-":"-NUMFAC+","-num$([F:SIH]AMTNOT)-mess(1,243,1)+","
&                -mess(186,107,1)-num$([L]AMTNOTSVC)-mess(1,243,1),0) From GESECRAN
  Endif
 Next
 If GOK<=0 : Return : Endif
 If [M:DIA]GENECR=2
  # Création pièce [TYP] [XXNUM]
  Call ECR_TRACE(mess(40,107,1)-GTYPPCE-MESSA,0) From GESECRAN
 Endif
 NBPIECE += 1
 Call ECR_TRACE("",0) From GESECRAN
Else
 Call ECR_TRACE(MESSA,1) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
 If [M:DIA]GENECR=2 : Return : Endif
Endif
Return

###################################################################################################
# Traitements communs de validation de pièce de charges ou produits constatées d'avance
###################################################################################################
$VALPCE
STAT = 0 : GOK = 1
If [M:DIA]GENECR=2
 If [M:DIA]TYP=1
  TZONE1(1) = "REFSIM" : TVAL1(1) = ""
 Else
  TZONE1(1) = "REFSIM" : TVAL1(1) = [L]PCEAUTO+[F:CPY2]CPY
 Endif
 TZONE1(2) = "CAT"     : TVAL1(2) = num$([M:DIA]TYP)
 TZONE1(3) = "STA"     : TVAL1(3) = num$([M:DIA]STA)
 If [M:DIA]TYP = 1 & func AFNC.PARAM("FRADGI",GSOCIETE)="2"
  TZONE1(3) = "STA" : TVAL1(3) = num$(2)
 Elsif [M:DIA]TYP <> 1
  TZONE1(3) = "STA" : TVAL1(3) = num$(1)
 Endif
 TZONE1(4) = "FCY"     : TVAL1(4) = SITE
 TZONE1(5) = "TYP"     : TVAL1(5) = num$([M:DIA]TYPPCE)
 TZONE1(6) = "JOU"     : TVAL1(6) = num$([M:DIA]JOURNAL)
 TZONE1(7) = "ORIGIN"  : TVAL1(7) ="2"               : # X3-39795 MWA Automatic loading
 TZONE1(8) = "ORICOD"  : TVAL1(8) = [L]PCEAUTO       : # X3-39795 MWA
 If dim(EP_CPTSVC)>0 & EP_CPTSVC : GPOINT = "BEFGNRVCR" : Gosub ENTREE From EXEFNC : Endif
 Call VALPCE4(PCEAUTO,CRIT,STAT,MESSA,TZONE1,TVAL1) From CPTAUTO
 If STAT : GOK = 0 : Endif
Else
 TZONE2(1) = "CAT"     : TVAL2(1) = num$([M:DIA]TYP)
 TZONE2(2) = "STA"     : TVAL2(2) = num$([M:DIA]STA)
 If [M:DIA]TYP = 1 & func AFNC.PARAM("FRADGI",GSOCIETE)="2"
  TZONE1(2) = "STA" : TVAL1(2) = num$(2)
 Elsif [M:DIA]TYP <> 1
  TZONE1(2) = "STA" : TVAL1(2) = num$(1)
 Endif
 TZONE2(3) = "FCY"     : TVAL2(3) = SITE
 TZONE2(7)="ORIGIN"    : TVAL2(7) ="2"               : # X3-39795 MWA Automatic loading
 TZONE2(8)="ORICOD"    : TVAL2(8) = [L]PCEAUTO       : # X3-39795 MWA
 Call SIMPCE4(PCEAUTO,CRIT,STAT,MESSA,TZONE2,TVAL2) From CPTAUTO
Endif
If STAT
 Return
Endif
Return

#######################################################################################################
# Traitements communs d'annulation de pièce de simulation de charges ou produits constatées d'avance
######################################################################################################
$ANUPCE
REF_SIM = [L]PCEAUTO+[F:CPY2]CPY
GOK=1
If dim(EP_CPTSVC)>0 & EP_CPTSVC : GPOINT = "BEFDELSIM" : Gosub ENTREE From EXEFNC : Endif
Filter [HAE1] Where REFSIM=REF_SIM & CAT>1
For [HAE1]
 If GTRACE<>""
  # Annulation pièce
  Call ECR_TRACE(mess(41,107,1)-[F:HAE1]TYP-[F:HAE1]NUM,0) From GESECRAN
 Endif
 Call DELPCE([F:HAE1]TYP,[F:HAE1]NUM) From CPTBATCH
 If GOK<1: Break : Endif
 # Issue 64338
 Call DEL_JOURNAL_ENTRY_FR0M_BUDPURAUD([F:HAE1]TYP,[F:HAE1]NUM) From CPTBUD
 If GOK<1: Break : Endif
 # End issue 64338
Next
Filter [HAE1]
Return


#######################################################
## Traitement de fin (lecture trace éventuelle)
#######################################################
$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If dim(SAV_GCURFCY)>0 : GCURFCY = SAV_GCURFCY : Endif

If !GSERVEUR
 TRA = 1
Else
 TRA = 0
Endif
Return

$SORTIE
Call UNLOCKCPY() From AX3MONO
Return

$OUVFIC
If clalev([F:SIH])=0  : Local File SINVOICE   [SIH]  : Endif : # Factures clients
If clalev([F:SIH2])=0 : Local File SINVOICE   [SIH2] : Endif : # Factures clients
If clalev([F:PIH])=0  : Local File PINVOICE   [PIH]  : Endif : # Factures founisseurs
If clalev([F:PIH2])=0 : Local File PINVOICE   [PIH2] : Endif : # Factures founisseurs
If clalev([F:PIL])=0  : Local File BPSINVLIG  [PIL]  : Endif : # Lignes factures tiers founisseurs
If clalev([F:PIA])=0  : Local File BPSINVLIGA [PIA]  : Endif : # Lignes ana factures tiers founisseurs
If clalev([F:SIL])=0  : Local File BPCINVLIG  [SIL]  : Endif : # Lignes factures tiers clients
If clalev([F:SIA])=0  : Local File BPCINVLIGA [SIA]  : Endif : # Lignes ana factures tiers clients
If GMODU(5)=2
 If clalev([F:SID])=0  : Local File SINVOICED  [SID]  : Endif : # Lignes factures ventes
Endif
If GMODU(6)=2
 If clalev([F:PID])=0  : Local File PINVOICED  [PID]  : Endif : # Lignes factures achats
Endif

If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif : # Type de pièces
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif : # Cours devises
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif : # Sociétés
If clalev([F:CPY2])=0 : Local File COMPANY    [CPY2] : Endif : # Sociétés
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif : # Sites
If clalev([F:ADW])=0  : Local File ADOVAL     [ADW]  : Endif : # Valeur des paramètres
If clalev([F:JOU])=0  : Local File GJOURNAL   [JOU]  : Endif : # Journal
If clalev([F:BPS])=0  : Local File BPSUPPLIER [BPS]  : Endif : # Fournisseurs
If clalev([F:BPC])=0  : Local File BPCUSTOMER [BPC]  : Endif : # Clients
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif : # Pièces comptables
If clalev([F:HAE1])=0 : Local File GACCENTRY  [HAE1] : Endif : # Pièces comptables
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif : # Lignes pièces comptables
If clalev([F:DAA])=0  : Local File GACCENTRYA [DAA]  : Endif : # Analytique
#If clalev([F:AGC])=0  : Local File AGRPCPY    [AGC]  : Endif : # Goupe de sociétés
If clalev([F:PIH3])=0
 Local File PINVOICE [PIH3] Order By Key CLE = CUR ; BPR ; ORIMOD ; NUM
Endif
If clalev([F:SIH3])=0
 Local File SINVOICE [SIH3] Order By Key CLE = CUR ; BPR ; ORIMOD ; NUM
Endif
Return


############################################################################
# Etiquettes du masque CPTSVC
############################################################################
Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Call  D_INI(VALEUR) From CPTTRT
End

Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
Call AS_ALLCPY(VALEUR) From CPTTRT
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From CPTTRT
If [M:DIA]TYP=1 : Actzo STA : Endif
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Call AS_CPY(VALEUR) From CPTTRT
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If  [M]TYP=1
 If func AFNC.PARAM("FRADGI",VALEUR)="2" : # Paramètre à Oui
  [M]STA = 2 : Grizo STA
  Affzo STA
 Else
  Actzo STA
 Endif
Endif
Call C_CPY(VALEUR)From CPTTRT
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG(VALEUR)From CPTTRT
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
Call AS_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CPTTRT
End

Subprog AS_BPRFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]BPRDEB : VALEUR=[M]BPRDEB : Endif
End

Subprog C_BPRFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]BPRDEB
 GMESSAGE = mess(44,199,1)
 mkstat = 1
Endif
End

Subprog AS_VCRFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]VCRDEB : VALEUR=[M]VCRDEB : Endif
End

Subprog C_VCRFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]VCRDEB
 GMESSAGE = mess(44,199,1)
 mkstat = 1
Endif
End

Subprog AS_DATREF(VALEUR)
Variable Date    VALEUR()
If VALEUR=[0/0/0]
 VALEUR = datesyst
Endif
End

Subprog C_GENECR(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 Grizo STA, TYP, TYPPCE, JOURNAL, ACCDAT, EXTOURNE
 [M:DIA]ACCDAT = [M:DIA]DATREF
 [M:DIA]EXTOURNE = [M:DIA]DATREF+1
Else
 Actzo STA, TYP, TYPPCE, JOURNAL, ACCDAT, EXTOURNE
Endif
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>1 : Grizo STA : Else : Actzo STA : Endif
If VALEUR = 1
 If [M]CPY<>""
  If func AFNC.PARAM("FRADGI",[M]CPY)="2" : # Paramètre à Oui
   [M]STA = 2 : Grizo STA
  Else : Actzo STA
  Endif
 Else : Actzo STA
 Endif
Endif
End

Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
[M]TYPPCE=""
[M]JOURNAL=""
End

Subprog AS_STA(VALEUR)
Variable Integer VALEUR
End
If [M]CPY<>""
 If func AFNC.PARAM("FRADGI",[M]CPY)="2" : # Paramètre à Oui
  VALEUR = 2 : mkstat = 2 : End
 Endif
Endif
If VALEUR=0 : VALEUR = 1 : Endif
End

Subprog AS_TYPPCE(VALEUR)
Variable Char    VALEUR()
If (VALEUR="" & [M:DIA]TYP<>1)
 If [M]FCY<>""
  Call PARAML([M]FCY,"TYPACC",VALEUR) From ADOVAL
 Elsif [M]CPY<>""
  Call PARAML([M]CPY,"TYPACC",VALEUR) From ADOVAL
 Elsif GCURLEG<>""
  Call PARAM(GCURLEG,"TYPACC",VALEUR) From CPTLEC
 Endif
Elsif func AFNC.ACTIV("SVC") and (VALEUR="" & [M:DIA]TYP=1)    # Génaration Réelle    # Issue X3-107197
 If [M]FCY<>""
  Call PARAML([M]FCY,"VCRTYPSVC",VALEUR) From ADOVAL
 Elsif [M]CPY<>""
  Call PARAML([M]CPY,"VCRTYPSVC",VALEUR) From ADOVAL
 Elsif GCURLEG<>""
  Call PARAM(GCURLEG,"VCRTYPSVC",VALEUR) From CPTLEC
 Endif
Endif
End

Subprog C_TYPPCE(VALEUR)
Variable Char    VALEUR()
Call CONTEXE([F:GTE]ACS) From CPTSUB
If mkstat  End : Endif
If [M]TYP=1 & [F:GTE]VCRREA<>2
 GMESSAGE = mess(33,107,1)
 mkstat=2 : End
Elsif [M]TYP>=2 & [F:GTE]VCRSIM<>2
 GMESSAGE=mess(32,107,1)
 mkstat=2 : End
Elsif [M]TYP=1 & ([F:GTE]VAT=2 | [F:GTE]VATPAI=2)
 # Vu avec SDR : le type de pièce sur lequel on génère la CCA ou PCA ne doit pas être flagué 'gestion de TVA'
 # puisqu'on ne génère pas de la TVA. Si le compte de charge/produit est soumis à TVA, on aura un code taxe
 # sur la ligne d'écriture mais elle ne ressortira pas en erreur dans l'état CONTVAPCE qui fait maintenant
 # un filtre sur les types de pièce avec TVA
 # Pour les pièces de simulation, on ne fait pas le contrôle
 # Type de pièce avec gestion de TVA
 GMESSAGE=mess(120,107,1)
 mkstat=2 : End
Endif
End

Subprog AS_JOURNAL(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]TYPPCE<>""
 VALEUR = [F:GTE]DEFJOU
Endif
End

Subprog C_JOURNAL(VALEUR)
Variable Char    VALEUR()
Call CTL_JOUDES(VALEUR,GCURLEG) From CPTTRT
End

Subprog AS_ACCDAT(VALEUR)
Variable Date    VALEUR()
If VALEUR=[0/0/0]
 VALEUR = [M:DIA]DATREF
Endif
End

Subprog AP_ACCDAT(VALEUR)
Variable Date    VALEUR
## On initialise la date d'extourne au 1er jour du mois suivant la date de pièce
[M:DIA]EXTOURNE = gdat$(1,month(VALEUR)+1,year(VALEUR))
Affzo EXTOURNE
End

Subprog AS_TRACE(VALEUR)
Variable Integer VALEUR
If [M]GENECR = 2
 VALEUR = 2
 mkstat = 2 : End
Endif
End

Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

#########################################################################################
# Calcul montant de la CCA/PCA à générer : variable associée aux lignes de pièces auto
# générant les CCA/PCA
#########################################################################################
Subprog AMTSVC(DAT,TYPAMT,LEDTYP,AMTSVC,STAT)
Value    Date    DAT()
Value    Integer TYPAMT
Value    Integer LEDTYP
Variable Decimal AMTSVC
Variable Integer STAT
Local Char    CODLED(GLONLED), DEVLED(GLONCUR)
Local Decimal AMTLIN, BASE
Local Decimal COURS, ARRODEV
Raz AMTLIN
If clalev([F:TCU])=0  : Local File TABCUR  [TCU]  : Endif : # Cours devises
If clalev([F:CPY])=0  : Local File COMPANY [CPY]  : Endif : # Sociétés
Call LECTURE("TCU",[F:TB0]CUR,"") From CONTOBJ
ARRODEV = [F:TCU]CURRND

# Demande de prise en compte de la TVA non déductible
If dim([F:TB1]AMTVAT)>0 & dim([F:TB1]DEDVAT)>0 : # Factures tiers Fournisseurs
 [L]BASE = [F:TB1]AMTNOTLIN+([F:TB1]AMTVAT-[F:TB1]DEDVAT)
Elsif dim([F:TB1]AMTTAXLIN1)>0 & dim([F:TB1]DEDTAXLIN1)>0 : # Factures d'achats
 [L]BASE = [F:TB1]AMTNOTLIN+[F:TB1]AMTTAXLIN1-[F:TB1]DEDTAXLIN1
Else
 [L]BASE = [F:TB1]AMTNOTLIN
Endif
#

Call LECTURE("CPY",[M:HAE0]CPY,"") From CONTOBJ
Case TYPAMT
 When 1
  [L]AMTLIN = [L]BASE
 When 2
  Call LECLED([M:HAE0]CPY,LEDTYP,CODLED,DEVLED) From CPTDIV
  If CODLED<>"" & [M:HAE1]CUR<>[L]CODLED
   If [M:HAEF]RATDIVC(LEDTYP-1)=1
    COURS  = [M:HAEF]RATMLTC(LEDTYP-1)
   Else
    COURS  = [M:HAEF]RATMLTC(LEDTYP-1)/[M:HAEF]RATDIVC(LEDTYP-1)
   Endif
   If COURS<>0
    Call CONVERT3([M:HAE1]CUR,DEVLED,DEVLED,[F:TB0]CURTYP,[F:TB0]ACCDAT,[L]BASE,[L]AMTLIN,[L]COURS,STAT) From CPTSUB
    If STAT : End : Endif
    Call LEC_TCU(DEVLED) From CPTLEC
    ARRODEV = [F:TCU]CURRND
   Endif
  Endif
Endcase
If AMTLIN<>0
 If [L]DAT<[F:TB1]STRDAT
  AMTSVC = [L]AMTLIN
 Elsif [L]DAT>=[F:TB1]STRDAT & [L]DAT<=[F:TB1]ENDDAT
  AMTSVC = arr(([L]AMTLIN*([L]DAT-[F:TB1]ENDDAT))/([F:TB1]ENDDAT-[F:TB1]STRDAT+1),ARRODEV)
 Endif
 AMTSVC = abs(AMTSVC)*sgn(AMTLIN)
Endif
End


########################################################################################
# Calcul quantité sur CCA/PCA à générer : variable associée aux lignes de pièces auto
# générant les CCA/PCA
#########################################################################################
Subprog QTYSVC(DAT,QTYSVC,STAT)
Value Date DAT()
Variable Decimal QTYSVC
Variable Integer STAT
Local Decimal ARRONDI
If clalev([F:TUN])=0  : Local File TABUNIT [TUB]  : Endif : # Unités
If dim([F:TB1]UOM)>0 : # Unités dans les lignes de factures tiers (clients (BPCINVLIG) et founisseurs (BPSINVLIG))
 Call LECTURE("TUN",[F:TB1]UOM,"") From CONTOBJ
Elsif dim([F:TB1]STU)>0 : # Unités de vente dans les lignes de factures de ventes (SINVOICED)
 Call LECTURE("TUN",[F:TB1]STU,"") From CONTOBJ
Elsif dim([F:TB1]GLU)>0 : # Unités d'achat dans les lignes de factures d'achats (PINVOICED)
 Call LECTURE("TUN",[F:TB1]GLU,"") From CONTOBJ
Endif
ARRONDI = [F:TUN]UOMDEC
If [L]DAT<[F:TB1]STRDAT
 If dim([F:TB1]QTY)>0 : # Factures tiers
  QTYSVC = [F:TB1]QTY
 Elsif dim([F:TB1]QTYGLU)>0 : # Factures d'achats
  QTYSVC = [F:TB1]QTYGLU
 Elsif dim([F:TB1]QTYSTU)>0 : # Factures de ventes
  QTYSVC = [F:TB1]QTYSTU
 Endif
Elsif [L]DAT>=[F:TB1]STRDAT & [L]DAT<=[F:TB1]ENDDAT
 If dim([F:TB1]QTY)>0
  QTYSVC = arr(([F:TB1]QTY*([L]DAT-[F:TB1]ENDDAT))/([F:TB1]ENDDAT-[F:TB1]STRDAT+1),ARRONDI)
 Elsif dim([F:TB1]QTYUOM)>0
  QTYSVC = arr(([F:TB1]QTYUOM*([L]DAT-[F:TB1]ENDDAT))/([F:TB1]ENDDAT-[F:TB1]STRDAT+1),ARRONDI)
 Endif
Endif
QTYSVC = abs(QTYSVC)
End

######################################################################################

