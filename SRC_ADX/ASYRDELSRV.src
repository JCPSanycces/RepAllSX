#<AdxTL>@(#)8.0.0.0 $Revision$
End

#--------------------------------------------------------------#
# Load delta classe (ADELTA) with a sysnapshot
#--------------------------------------------------------------#

Subprog LOAD_DELTA(WREP,REP,UPD,ULN)
Variable Instance  WREP      Using OBJECT
Variable Instance  REP       Using C_AREPENT
Variable Instance  UPD(1..)  Using C_ADELTA
Variable Instance  ULN(1..)  Using C_ADELTALIN
Local Clbfile CLOB
Local Char    INS(80)
Local Uuident UIF
Local Uuident UID:#undeclared variable
INS = "WREP"
UIF = NullUuid
UID = evalue("WREP."+REP.ICL+".AUUID")
If GTRASYR : Call TRACE("asyrdelsrv start maxtab(upd)="+num$(maxtab(UPD))-"maxtab(uln)="+num$(maxtab(ULN))) From ASYRCOM : Endif
Gosub SYSTEM_INSTANCES From ASYRUID
# Search updates in syssnapshoted instances
Call LOOP_COLLECTION(WREP,REP,UPD,ULN,INS,UIF,UID,NAMSYS,NBRSYS)
# Restaure uncommited lines
Gosub UNCOMMITTED_LINES
End

#----------------------------------------------------------------------------------#
Subprog LOOP_COLLECTION(WREP,REP,UPD,ULN,INS,UIF,UID,NAMSYS,NBRSYS)
Variable Instance  WREP      Using OBJECT
Variable Instance  REP       Using C_AREPENT
Variable Instance  UPD(1..)  Using C_ADELTA
Variable Instance  ULN(1..)  Using C_ADELTALIN
Value    Char      INS
Value    Uuident   UIF , UID
Value    Char      NAMSYS()(1..)
Value    Integer   NBRSYS
Local Integer M , N , FMO , NBRINS
Local Char    WINS(250) , SNPFLD(250)(1..)
Local Integer TBORD(1..) , TBPOS(1..) , NBPOS
Local Integer SNPIND(1..) , ONE
Local Char    PRO(30)
M = evalue('maxtab('+INS+')')
Raz NBRINS , TBPOS , NBPOS
If M>0
 Call TYPSYR(REP,INS,ONE,PRO)
 If GTRASYR : Call TRACE("loop collection="+PRO-"ins="+INS-"1,1="+num$(ONE)) From ASYRCOM : Endif
 If ONE : # instance 1,1
  If evalue(INS)<>null
   Call LOOP_INSTANCES(WREP,REP,UPD,ULN,INS,UIF,UID,NBRINS,NAMSYS,NBRSYS)
  Endif
 Else
  For N=1 To M
   WINS = INS+'('+num$(N)+')'
   If evalue(WINS)<>null
    Gosub INSTANCE_MODIFIED
   Endif
  Next N
  # find instance not commited
  For N=1 To maxtab(ULN)
   If ULN(N).UIDPAR=UID
    NBRINS += 1
   Endif
  Next N
  If NBRINS>1
   If NBPOS>0 : # Send all instances in order
    Sorta NBPOS TBORD,TBPOS Order By TBORD(indice+1),TBPOS(indice+1)
    UIF = UID
    For N=1 To NBPOS
     WINS = INS+'('+num$(TBPOS(N))+')'
     UID = evalue(WINS+".AUUID")
     Assign WINS+".AORDER" With evalue(WINS+".AORDER")
     Call LOOP_INSTANCES(WREP,REP,UPD,ULN,WINS,UIF,UID,NBRINS,NAMSYS,NBRSYS)
    Next N
   Else : # All instances deleted
    UIF = UID
    NBRINS = -1
    For N=1 To M
     WINS = INS+'('+num$(N)+')'
     If evalue(WINS)<>null
      UID = evalue(WINS+".AUUID")
      Call LOOP_INSTANCES(WREP,REP,UPD,ULN,WINS,UIF,UID,NBRINS,NAMSYS,NBRSYS)
      Break
     Endif
    Next N
   Endif
  Else
   UIF = UID
   If NBPOS=0 : # Empty collection (mb 12.1.14 bug 95716)
    NBRINS = -1
    For N=1 To M
     WINS = INS+'('+num$(N)+')'
     If evalue(WINS)<>null
      UID = evalue(WINS+".AUUID")
      Call LOOP_INSTANCES(WREP,REP,UPD,ULN,WINS,UIF,UID,NBRINS,NAMSYS,NBRSYS)
      Break
     Endif
    Next N
   Else
    For N=1 To M
     WINS = INS+'('+num$(N)+')'
     If evalue(WINS)<>null
      UID = evalue(WINS+".AUUID")
      Call LOOP_INSTANCES(WREP,REP,UPD,ULN,WINS,UIF,UID,NBRINS,NAMSYS,NBRSYS)
     Endif
    Next N
   Endif
  Endif
 Endif
Endif
End

#-----------------------------------------------------------#
# How many instances modified in this collection
#-----------------------------------------------------------#

$INSTANCE_MODIFIED
If !find(evalue(WINS+".ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL)
 NBPOS += 1
 TBPOS(NBPOS) = N
 TBORD(NBPOS) = evalue(WINS+".AORDER")
Endif
FMO = evalue(WINS+".GETSYSMODIFIED(SNPFLD,SNPIND)")
NBRINS += FMO
Return

#----------------------------------------------------------------------------------#
Subprog LOOP_INSTANCES(WREP,REP,UPD,ULN,INS,UIF,UID,NBRINS,NAMSYS,NBRSYS)
Variable Instance WREP Using OBJECT
Variable Instance REP       Using C_AREPENT
Variable Instance UPD(1..)  Using C_ADELTA
Variable Instance ULN(1..)  Using C_ADELTALIN
Value    Char     INS
Value    Uuident  UIF , UID
Value    Integer  NBRINS
Value    Char     NAMSYS()(1..)
Value    Integer  NBRSYS
Local Char    PRO(30)
Local Integer J , K , P
If evalue(INS)=null
 End
Endif
Call SET_DELTA_INSTANCE(WREP,REP,UPD,ULN,INS,UIF,UID,NBRINS)
If !find(evalue(INS+".ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL)
 For P=1 To evalue(INS+'.Objectnbs')
  PRO = evalue(INS+'.Objectvar('+num$(P)+')')
  K = evalue('type('+INS+'.'+PRO+')')
  If K=524 & !find(PRO,NAMSYS(1..NBRSYS))
   Call LOOP_COLLECTION(WREP,REP,UPD,ULN,INS+'.'+PRO,UIF,UID,NAMSYS,NBRSYS)
  Endif
 Next P
Endif
End

#--------------------------------------------------------------------------#
# Create instance in ADELTA classe
#--------------------------------------------------------------------------#

Subprog SET_DELTA_INSTANCE(WREP,REP,UPD,ULN,WIDE,UIF,UID,NBRINS)
Variable Instance WREP Using OBJECT
Variable Instance REP       Using C_AREPENT
Variable Instance UPD(1..)  Using C_ADELTA
Variable Instance ULN(1..)  Using C_ADELTALIN
Value    Char     WIDE
Value    Uuident  UIF , UID
Value    Integer  NBRINS
Local Integer I , J , K , FMO , WIND , WORD , ONE
Local Char    SNPFLD(250)(1..)
Local Integer SNPIND(1..)
Local Char    WPRO(250) , WSNP(30) , WCHAINE(250) , WMES(250)
Local Char    PRO(80) , COLSYR(80)
Local Integer TYP , CAT , CATCOL , CATPRO
Local Integer FLGORD , FLGSTA , FLGPRO
Local Clbfile CLOB
Raz FLGORD , FLGPRO , FLGSTA
If evalue("maxtab("+WIDE+")")>0 & evalue(WIDE)<>null
 If NBRINS=-1 : # All instances deleted
  # Get the name of Syracuse collection
  Call COLSYR(REP,WIDE,COLSYR,ONE)
  Call CATCOL(REP,COLSYR,CATCOL)
  Call MAJ_FIELD(UPD,CATCOL,0,UIF,UID,1,COLSYR,func ASYRSUB.KILCOL,7,CLOB) From  ASYRDELSYS
  Call DESACTIVE_UNCOMMITED(ULN,UIF,"D")
 Else
  Raz SNPFLD , SNPIND
  FMO = evalue(WIDE+".GETSYSMODIFIED(SNPFLD,SNPIND)")
  If FMO>0
   Call COLSYR(REP,WIDE,COLSYR,ONE)
   Call CATCOL(REP,COLSYR,CATCOL)
   WORD = evalue(WIDE+".AORDER")
   If NBRINS>1
     #{SAM 111984 :
     # - the attribute $index must be present in the resource when the server sends a delta
     # - the attribute $index must not be present in the resource when the server sends the full collection
     # If the UPD(i).IND property is set to -1 then $index insn't set in the resource :
     # WORD = - 1 : #old
     WORD = - 1 - WORD : # from -1 to -.... 112782
     #}SAM 111984
    Call DESACTIVE_UNCOMMITED(ULN,UIF,"N")
   Endif
   For J=1 To FMO
    If !find(SNPFLD(J),"AINF","AREPLNK","APARENT","ATX","AXX","AUUID")
     WSNP = SNPFLD(J)
     WIND = SNPIND(J)
     Gosub TRT_PRO
    Endif
   Next J
   If ((FLGORD or FLGSTA or NBRINS>1) & !FLGPRO)
    Gosub TRT_LINE
   Endif
  Endif
 Endif
 If NBRINS=-1 or NBRINS>1 or FLGORD or FLGSTA or FLGPRO
  Call UPDATE_PARENT(WREP,REP,UPD,UIF)
 Endif
Endif
End

#--------------------------------#
$TRT_LINE
If NBRINS>1
 If GTRASYR : Call TRACE("all collection uid="+num$(UID)-"uif="+num$(UIF)-"col="+COLSYR) From ASYRCOM : Endif
 Call ONEPRO(REP,WIDE,PRO,TYP,CAT)
 If PRO<>""
  CLOB = num$(evalue(WIDE+"."+PRO))
  Call MAJ_FIELD(UPD,CAT,0,UIF,UID,WORD,COLSYR,PRO,TYP,CLOB) From  ASYRDELSYS
 Else
  Call MAJ_FIELD(UPD,CATCOL,0,UIF,UID,WORD,COLSYR,"",7,CLOB) From  ASYRDELSYS
 Endif
Elsif FLGORD>0
 If !find(evalue(WIDE+".ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL) : # Not deleted line
  CLOB = num$(WORD)
  Call MAJ_FIELD(UPD,CATCOL,0,UIF,UID,WORD,COLSYR,"AORDER",4,CLOB) From  ASYRDELSYS
  If GTRASYR : Call TRACE("update order uid="+num$(UID)-"uif="+num$(UIF)-"col="+COLSYR) From ASYRCOM : Endif
 Endif
Elsif FLGSTA>0
 Case FLGSTA
  When [V]CST_ADEL,[V]CST_ANEWDEL : # Delete line
   If GTRASYR : Call TRACE("delete line uid="+num$(UID)-"uif="+num$(UIF)-"col="+COLSYR) From ASYRCOM : Endif
   Call MAJ_FIELD(UPD,CATCOL,0,UIF,UID,WORD,COLSYR,"",0,CLOB) From  ASYRDELSYS
   # isDeleted
   Call MAJ_ATTRIBUT(UPD,CATCOL,0,UIF,UID,WORD,COLSYR,"",func ASYRSUB.CODATT("s"),func ASYRSUB.BOOLEAN_TO_SYR(2)) From  ASYRDELSYS
  When [V]CST_ANEW : # Add line
   If GTRASYR : Call TRACE("add line uid="+num$(UID)-"uif="+num$(UIF)-"col="+COLSYR) From ASYRCOM : Endif
   Call MAJ_FIELD(UPD,CATCOL,0,UIF,UID,WORD,COLSYR,"",0,CLOB) From  ASYRDELSYS
 Endcase
Endif
Return

#-----------------------------#
$TRT_PRO
WPRO = WSNP
If WIND<>0
 WPRO += "("+num$(WIND)+")"
Endif
WPRO = WIDE+"."+WPRO
Case WSNP
 When ""
 When "AORDER"
  FLGORD = 1
 When "ASTALIN"
  FLGSTA = evalue(WIDE+".ASTALIN")
 When "AATTRIBUTES"
  If evalue(WPRO)<>null
   FLGPRO = 1
   Call CATPRO(REP,WPRO,evalue(WPRO+".PRO"),PRO,CATPRO)
   #TODO
   Local Instance TMPINS Using OBJECT
   [L]TMPINS = evalue(WIDE)
   Call AGETADELTAATT([L]TMPINS,UPD,CATPRO,UIF,UID,WORD,COLSYR,PRO,SNPIND(J))
  Endif
 When "ATT"
  If evalue(WPRO)<>null
   FLGPRO = 1
   Call CATPRO(REP,WPRO,evalue(WPRO+".PRO"),PRO,CATPRO)
   Call MAJ_ATTRIBUT(UPD,CATPRO,0,UIF,UID,WORD,COLSYR,PRO,evalue(WPRO+".COD"),evalue(WPRO+".ATT")) From  ASYRDELSYS
  Endif
 When "AERROR"
  If evalue(WPRO)<>null
   FLGPRO = 1
   If evalue(WPRO+".DEL")=2
    WMES = ""
   Else
    WMES = evalue(WPRO+".MES")
   Endif
   Call CATPRO(REP,WPRO,evalue(WPRO+".PRO"),PRO,CATPRO)
   If PRO="" and evalue(WPRO+".PRO")<>"" : # CCL  bug 107727 add pro if the property doesn't exist in the representation
    WMES = evalue(WPRO+".PRO")-":"-WMES
   Endif
   Call MAJ_ERROR(UPD,CATPRO,0,UIF,UID,WORD,COLSYR,PRO,WMES,evalue(WPRO+".CREDATTIM"),evalue(WPRO+".STA")
&  ,evalue(WPRO+".NUM")) From  ASYRDELSYS
  Endif
 When "LNK"
  If evalue(WPRO)<>null
   FLGPRO = 1
   Call CATPRO(REP,WPRO,evalue(WPRO+".PRO"),PRO,CATPRO)
   Call MAJ_LINK(UPD,2,0,UIF,UID,WORD,COLSYR,PRO,evalue(WPRO+".COD"),evalue(WPRO+".CMP"),evalue(WPRO+".NAM")
& ,evalue(WPRO+".REP"),evalue(WPRO+".CLA")) From  ASYRDELSYS
  Endif
 When Default
  If evalue("dim("+WPRO+")")>0 & UID<>NullUuid
   Call TYPE_PROPERTY(REP,WPRO,PRO,TYP,CAT)
   If TYP<>0
    Case TYP
     When 8 , 9 : # Clob and Blob
     When 25 : # Textes superviseur
      FLGPRO = 1
      CLOB = evalue('fmet '+func ASYRDATDET.PREFIX_INSTANCE(WPRO)+'.AGETTEXT("'+func ASYRDATDET.FINAL_INSTANCE(WPRO)+'")')
      Call MAJ_FIELD(UPD,CAT,0,UIF,UID,WORD,COLSYR,PRO,TYP,CLOB) From  ASYRDELSYS
      CLOB = ""
     When Default
      FLGPRO = 1
      CLOB = num$(evalue(WPRO))
      If GTRASYR : Call TRACE("return to syracuse"-WPRO+"="+CLOB) From ASYRCOM : Endif
      Call MAJ_FIELD(UPD,CAT,0,UIF,UID,WORD,COLSYR,PRO,TYP,CLOB) From  ASYRDELSYS
      CLOB = ""
    Endcase
   Endif
  Endif
Endcase
Return

#---------------------------------------------#
Subprog CATCOL(REP,COL,CAT)
Variable Instance REP Using C_AREPENT
Value Char COL
Variable Integer CAT
Local Integer I , J , K
Raz J , K
For I=1 To maxtab(REP.PRO)
 If REP.PRO(I)<>null & ctrans(REP.PRO(I).GRI,".","")=COL
  If REP.PRO(I).PLK=2 : K = 1 : Endif
  J += 1 : If J>1 : Break : Endif
 Endif
Next I
If J=1 & K=1
 CAT = 2
Else
 CAT = 1
Endif
End

#---------------------------------------------#
Subprog CATPRO(REP,INSERR,NAMPRO,PRO,CAT)
Variable Instance REP Using C_AREPENT
Value    Char     INSERR
Value    Char     NAMPRO
Variable Char     PRO
Variable Integer  CAT
Local Integer I , K , TYP
Local Char    INSPRO(250)
Raz PRO , CAT
If NAMPRO=""
 CAT = 1
Else
 For I=len(INSERR) To 1 Step -1
  If mid$(INSERR,I,1)="."
   INSPRO = left$(INSERR,I-1)+"."+NAMPRO
   Call TYPE_PROPERTY(REP,INSPRO,PRO,TYP,CAT)
   Break
  Endif
 Next I
Endif
End

#----------------------------------------------------#
Subprog TYPE_PROPERTY(REP,INS,PRO,TYP,CAT)
Variable Instance REP       Using C_AREPENT
Value    Char     INS
Variable Char     PRO
Variable Integer  TYP
Variable Integer  CAT
Local Integer I , J , K
Local Char    CHAINE(250) , PATH(250)
CHAINE = right$(INS,6)
Raz PATH , PRO , TYP , CAT
While CHAINE<>""
 I = instr(1,CHAINE,".")
 If I
  CHR = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CHR = CHAINE
  CHAINE = ""
 Endif
 K += 1
 I = instr(1,CHR,"(")
 If I
  CHR = left$(CHR,I-1)
 Endif
 If PATH<>""
  PATH += "."
 Endif
 PATH += CHR
Wend
I = find(PATH,REP.PRO(1..maxtab(REP.PRO)).PTH)
If I
 PRO = REP.PRO(I).PRO
 TYP = REP.PRO(I).TYP
 CAT = REP.PRO(I).PLK
Endif
End

#--------------------------------------------------#
Subprog ONEPRO(REP,INS,PRO,TYP,CAT)
Variable Instance REP  Using C_AREPENT
Value    Char     INS
Variable Char     PRO
Variable Integer  TYP
Variable Integer  CAT
Local Char    CHAINE(250) , PATH(250) , CHR(80)
Local Integer I , J , K
CHAINE = right$(INS,6)
Raz PATH , PRO , TYP , CAT
While CHAINE<>""
 I = instr(1,CHAINE,".")
 If I
  CHR = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CHR = CHAINE
  CHAINE = ""
 Endif
 K += 1
 I = instr(1,CHR,"(")
 If I
  CHR = left$(CHR,I-1)
 Endif
 If PATH<>""
  PATH += "."
 Endif
 PATH += CHR
Wend
I = instr(1,PATH,"(")
If I
 PATH = left$(PATH,I-1)
Endif
I = find(PATH,REP.COL(1..maxtab(REP.COL)).GRI)
If I & REP.COL(I).NBR=1
 I = find(REP.COL(I).GRI,REP.PRO(1..maxtab(REP.PRO)).GRI)
 If I
  PRO = REP.PRO(I).PRO
  TYP = REP.PRO(I).TYP
  CAT = REP.PRO(I).PLK
 Endif
Endif
End

#-----------------------------------------------------------------#
# Create delta instance parent if not found in delta class
#-----------------------------------------------------------------#

Subprog UPDATE_PARENT(WREP,REP,UPD,UID)
Variable Instance WREP      Using OBJECT
Variable Instance REP Using C_AREPENT
Variable Instance UPD(1..)  Using C_ADELTA
Value Uuident UID
Local Integer I , ONE , ORD
Local Uuident UIF
Local Char    WINS(250) , COLSYR(250)
Local Clbfile CLOB
If UID=NullUuid or find(UID,UPD(1..maxtab(UPD)).UID) : End : Endif
Call FIND_UUID_INSTANCE_EX(WREP,REP,null,UID,"WREP",WINS) From ASYRUID

Call COLSYR(REP,WINS,COLSYR,ONE)
Call TRACE("update parent wins="+WINS-"colsyr="+COLSYR) From ASYRCOM
ORD = evalue(WINS+".AORDER")
UIF = NullUuid
If WINS="WREP."+REP.ICL
 UIF = NullUuid
 ORD = -1
Elsif instr(1,WINS,".")
 For I=len(WINS) To 1 Step -1
  If mid$(WINS,I,1)="."
   WINS = left$(WINS,I-1)
   UIF = evalue(WINS+".AUUID")
   #107736
   Break
  Endif
 Next I
Endif
If GTRASYR : Call TRACE("Update parent uif="+num$(UIF)-"uid="+num$(UID)) From ASYRCOM : Endif
Call MAJ_FIELD(UPD,1,0,UIF,UID,ORD,COLSYR,"",0,CLOB) From  ASYRDELSYS
If UIF<>NullUuid
 Call UPDATE_PARENT(WREP,REP,UPD,UIF)
Endif
End

#-----------------------------------------------------------------------------------------------#
# Send to Syracuse instances deleted or inserted by Syracuse but restored/deleted by the server
#-----------------------------------------------------------------------------------------------#

$UNCOMMITTED_LINES
For I=1 To maxtab(ULN)
 If ULN(I)<>null
  Case ULN(I).EVT
   When [V]CST_ADEL,[V]CST_ANEWDEL : # Uncommitted line deleted -> add line
    If GTRASYR : Call TRACE("Uncommitted line add collection"-ULN(I).COL-"uid="+num$(ULN(I).UID)) From ASYRCOM : Endif
    Call COLLECTION_UUID(REP,WREP,UPD,ULN(I).COL,ULN(I).UID) From ASYRUID
    Call UPDATE_PARENT(WREP,REP,UPD,ULN(I).UIDPAR)
   When [V]CST_ANEW : # Uncommitted line added -> delete line
    If GTRASYR : Call TRACE("Uncommitted line delete line"-num$(ULN(I).IND)-"uid="+num$(ULN(I).UID)) From ASYRCOM : Endif
    Call MAJ_FIELD(UPD,1,0,ULN(I).UIDPAR,ULN(I).UID,ULN(I).IND,ULN(I).COL,"",0,CLOB) From  ASYRDELSYS
    # isDeleted=true
    Call MAJ_ATTRIBUT(UPD,1,0,ULN(I).UIDPAR,ULN(I).UID,ULN(I).IND,ULN(I).COL,"",func ASYRSUB.CODATT("s"),func ASYRSUB.BOOLEAN_TO_SYR(2))
&   From  ASYRDELSYS
    Call UPDATE_PARENT(WREP,REP,UPD,ULN(I).UIDPAR)
  Endcase
 Endif
Next I
Return

#--------------------------------------------#
Subprog DESACTIVE_UNCOMMITED(ULN,UIF,FLG)
Variable Instance ULN(1..)  Using C_ADELTALIN
Value    Uuident  UIF
Value    Char     FLG
Local Integer I , OK
For I=1 To maxtab(ULN)
 If ULN(I).UIDPAR=UIF
  OK = 0
  Case FLG
   When ""  : OK = 1
   When "D" : OK = find(ULN(I).EVT,CST_ADEL,CST_ANEWDEL)
   When "N" : OK = find(ULN(I).EVT,CST_ANEW)
  Endcase
  If OK
   ULN(I).EVT = 0
  Endif
 Endif
Next I
End

#----------------------------------------------------#
# Search name of collection Syracuse
#----------------------------------------------------#

Subprog COLSYR(REP,INS,COL,ONE)
Variable Instance REP Using C_AREPENT
Value    Char     INS
Variable Char     COL
Variable Integer  ONE
Local Integer I , J , K
Local Char    CHAINE(250) , WINS(250) , WCOL(250) , CHR(30)
Local Integer TBNUM(1..)
ONE = 0
COL = ""
If INS="WREP" or INS="WREP."+REP.ICL
 ONE = 1
 End
Endif
WINS = right$(INS,6)
K = 0
CHAINE = WINS
WINS = ""
While CHAINE<>""
 I = instr(1,CHAINE,".")
 If I
  CHR = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CHR = CHAINE
  CHAINE = ""
 Endif
 K += 1
 I = instr(1,CHR,"(")
 If I
  TBNUM(K) = val(right$(CHR,I+1))
  CHR = left$(CHR,I-1)
 Else
  TBNUM(K) = 0
 Endif
 If WINS<>""
  WINS += "."
 Endif
 WINS += CHR
Wend
I = find(WINS,REP.COL(1..maxtab(REP.COL)).GRI)
While I
 If ONE=0
  ONE = (REP.COL(I).ONE=2)
 Endif
 If REP.COL(I).ONE=1
  WCOL = WINS
  Break
 Elsif instr(1,WINS,".")
  For J=len(WINS) To 1 Step -1
   If mid$(WINS,J,1)="."
    WINS = left$(WINS,J-1)
    Break
   Endif
  Next J
  I = find(WINS,REP.COL(1..maxtab(REP.COL)).GRI)
 Else
  Break
 Endif
Wend
COL = ctrans(WCOL,".","")
End

#--------------------------------------#
Subprog TYPSYR(REP,INS,ONE,PRO)
Variable Instance REP Using C_AREPENT
Value    Char     INS
Variable Integer  ONE
Variable Char     PRO
Local Integer I , J , K
Local Char    CHAINE(250) , WINS(250) , CHR(30)
Local Integer TBNUM(1..)
Local Char COL(250) :#undeclared variable
Raz ONE , PRO
COL = ""
If INS="WREP" or INS="WREP."+REP.ICL
 ONE = 1 : End
Endif
WINS = right$(INS,6)
K = 0
CHAINE = WINS
WINS = ""
While CHAINE<>""
 I = instr(1,CHAINE,".")
 If I
  CHR = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CHR = CHAINE
  CHAINE = ""
 Endif
 K += 1
 I = instr(1,CHR,"(")
 If I
  TBNUM(K) = val(right$(CHR,I+1))
  CHR = left$(CHR,I-1)
 Else
  TBNUM(K) = 0
 Endif
 If WINS<>""
  WINS += "."
 Endif
 WINS += CHR
Wend
I = find(WINS,REP.COL(1..maxtab(REP.COL)).GRI)
If I
 ONE = (REP.COL(I).ONE=2)
 If REP.COL(I).NBR=1
  I = find(REP.COL(I).GRI,REP.PRO(1..maxtab(REP.PRO)).GRI)
  If I
   PRO = REP.PRO(I).PRO
  Endif
 Endif
Else
 ONE = 1
Endif
End


#**
#* AGETADELTAATT
#*
#* @param OBJ
#* @param ATTNUM
#* @param UPDATT
#* @param GRP
#*!
#TODO
Subprog AGETADELTAATT(OBJ,UPD,CAT,UIF,UID,IND,COL,PRO,ATTNUM)
Variable Instance OBJ Using OBJECT
Variable Instance UPD(1..) Using C_ADELTA
Value Integer CAT
Value Uuident UIF , UID
Value Integer IND
Value Char COL
Value Char PRO
Value Integer     ATTNUM

Local Integer  AI,AJ,AK
Local Instance INS Using =OBJ.ObjectType()
Local Integer  FMO
Local Char     SNPFLD(250)(1..)
Local Integer  SNPIND(1..)
Local  Instance PUPD Using C_ADELTA

Local Char ATTBOOL(10)(0..1)
ATTBOOL(0) = "false"
ATTBOOL(1) = "true"

Gosub _GETATTNAMES From ASYRSUB

AI = maxtab(UPD)+1
UPD(AI) = NewInstance [UPD] With C_ADELTA
UPD(AI).PRO = [L]PRO
UPD(AI).UID = UID
UPD(AI).UIDPAR = UIF
UPD(AI).IND = IND
UPD(AI).COL = COL
UPD(AI).CAT = CAT

INS = cast( OBJ, =OBJ.ObjectType())

If INS.AATTRIBUTES(ATTNUM) =null or INS.AATTRIBUTES(ATTNUM).sysSnapshotEnabled =0 : End: Endif

FMO = INS.AATTRIBUTES(ATTNUM).getSysModified(SNPFLD,SNPIND)

For AK=1 To FMO
 Case SNPFLD(AK)
  When "AFSNA"
   For AJ=1 To [V]CST_ATTFCODMAX
    If getBit(INS.AATTRIBUTES(ATTNUM).AFSNA,AJ)
     UPD(AI).ATT(maxtab(UPD(AI).ATT)+1)     = NewInstance  C_ADELTAATT AllocGroup UPD
     UPD(AI).ATT(maxtab(UPD(AI).ATT)).COD = [V]CST_ATT(AJ)
     UPD(AI).ATT(maxtab(UPD(AI).ATT)).TYP = 5 :# word
     UPD(AI).ATT(maxtab(UPD(AI).ATT)).ATT = ATTBOOL(getBit(INS.AATTRIBUTES(ATTNUM).AFVAL,AJ))
    Endif
   Next AJ
  When "ALSNA"
   For AJ=1 To [V]CST_ATTLCODMAX
    If getBit(INS.AATTRIBUTES(ATTNUM).ALSNA,AJ)
     UPD(AI).ATT(maxtab(UPD(AI).ATT)+1)     = NewInstance  C_ADELTAATT AllocGroup UPD
     UPD(AI).ATT(maxtab(UPD(AI).ATT)).COD =  [V]CST_ATT(AJ-1+[V]CST_ATTLCODMIN)
     UPD(AI).ATT(maxtab(UPD(AI).ATT)).TYP = 4 :# number
     UPD(AI).ATT(maxtab(UPD(AI).ATT)).ATT = num$(INS.AATTRIBUTES(ATTNUM).ALVAL(AJ))
    Endif
   Next AJ
  When "ASSNA"
   For AJ=1 To [V]CST_ATTSCODMAX
    If getBit(INS.AATTRIBUTES(ATTNUM).ASSNA,AJ)
     UPD(AI).ATT(maxtab(UPD(AI).ATT)+1)     =NewInstance  C_ADELTAATT AllocGroup UPD
     UPD(AI).ATT(maxtab(UPD(AI).ATT)).COD =  [V]CST_ATT(AJ-1+[V]CST_ATTSCODMIN)
     UPD(AI).ATT(maxtab(UPD(AI).ATT)).TYP =  3 :# string
     If INS.AATTRIBUTES(ATTNUM).RES(AJ) <> null
      UPD(AI).ATT(maxtab(UPD(AI).ATT)).ATT = INS.AATTRIBUTES(ATTNUM).RES(AJ).CHR
     Else
      UPD(AI).ATT(maxtab(UPD(AI).ATT)).ATT = ""
     Endif
    Endif
   Next AJ
  When "ATT"
   If INS.AATTRIBUTES(ATTNUM).ATT <> null
    For AJ=1 To maxtab(INS.AATTRIBUTES(ATTNUM).ATT)
     UPD(AI).ATT(maxtab(UPD(AI).ATT)+1)     =NewInstance  C_ADELTAATT AllocGroup UPD
     UPD(AI).ATT(maxtab(UPD(AI).ATT)).COD = INS.AATTRIBUTES(ATTNUM).ATT(AJ).COD
     UPD(AI).ATT(maxtab(UPD(AI).ATT)).TYP =  3 :# string
     UPD(AI).ATT(maxtab(UPD(AI).ATT)).ATT = INS.AATTRIBUTES(ATTNUM).ATT(AJ).ATT
    Next AJ
   Endif
 Endcase
Next AK
#RAZ AFSNA for the next 'snapshot'
Raz INS.AATTRIBUTES(ATTNUM).AFSNA
Raz INS.AATTRIBUTES(ATTNUM).ASSNA
Raz INS.AATTRIBUTES(ATTNUM).ALSNA
End

