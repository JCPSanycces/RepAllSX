#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################
# Suppression d'une régul de type -N CP =>On pose des CP dans CNGEMP
#####################################################################################
Subprog SUPP_CPREG(JOUR)
Value Decimal JOUR(1..)

If !clalev([F:CNG])  : Local File CNGCPY [CNG]  : Endif
If !clalev([F:CNE])  : Local File CNGEMP [CNE]  : Endif
If !clalev([F:TIC])  : Local File TIMCNG [TIC]  : Endif

Local Integer I
Local Char    CPY([V]GLONCPY)

Delete [TIC] Where LIG=[F:TIG]LIG
If fstat
 [V]GOK=0
 Call FSTA("TIC") From GLOCK
 End
Endif


[L]CPY=func DIVPAYE.GETSOC([F:TIG]FCY)
Link [CNE] With [CNG]CNG0=[L]CPY;YEA;TIM As [LNK]
#JASMI - 2014-09-01 - START
#For [LNK]CNE1 Where REFNUM=[F:TIG]REFNUM & TIM=[F:TIG]TIM & CTRNUM=[F:TIG]CTRNUM & NBRPRI<NBRDAY
#&                 & [CNG]DEBDAT<=[F:TIG]ENDDAT & [CNG]FINDAT>=[F:TIG]STRDAT
Local Char     CRITERIA(100)
#ADNGO - 2017-01-12 - X3-11347 - START
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#ADNGO - 2017-01-12 - X3-11347 - END
  CRITERIA = '[CNE]EMPLEASTR<=[F:TIG]ENDDAT & [CNE]EMPLEAEND>=[F:TIG]STRDAT'
Else
  CRITERIA = '[CNG]DEBDAT<=[F:TIG]ENDDAT & [CNG]FINDAT>=[F:TIG]STRDAT'
Endif
For [LNK]CNE1 Where REFNUM=[F:TIG]REFNUM & TIM=[F:TIG]TIM & CTRNUM=[F:TIG]CTRNUM & NBRPRI<NBRDAY
&                        & evalue(CRITERIA)
#JASMI - 2014-09-01 - END
 For I=1 To dim([L]JOUR)
#JASMI - 2014-09-01 - START
#  If [L]JOUR(I)>0 & [F:TIG]STRDAT+I-1>=[F:CNG]DEBDAT
#   If [F:CNE]NBRPRI=[F:CNE]NBRDAY | [F:TIG]STRDAT+I-1>[F:CNG]FINDAT
#    Break
#   Elsif [F:CNE]NBRPRI+[L]JOUR(I)<[F:CNE]NBRDAY
#    [F:CNE]NBRPRI+=[L]JOUR(I)
#    [L]JOUR(I)    =0
#   Else
#    [L]JOUR(I)   -=[F:CNE]NBRDAY-[F:CNE]NBRPRI
#    [F:CNE]NBRPRI =[F:CNE]NBRDAY
#   Endif
#  Endif
#ADNGO - 2017-01-12 - X3-11347 - START
  #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#ADNGO - 2017-01-12 - X3-11347 - END
   If [L]JOUR(I)>0 & [F:TIG]STRDAT+I-1>=[F:CNE]EMPLEASTR
    If [F:CNE]NBRPRI=[F:CNE]NBRDAY | [F:TIG]STRDAT+I-1>[F:CNE]EMPLEAEND
     Break
    Elsif [F:CNE]NBRPRI+[L]JOUR(I)<[F:CNE]NBRDAY
     [F:CNE]NBRPRI+=[L]JOUR(I)
     [L]JOUR(I)    =0
    Else
     [L]JOUR(I)   -=[F:CNE]NBRDAY-[F:CNE]NBRPRI
     [F:CNE]NBRPRI =[F:CNE]NBRDAY
    Endif
   Endif
  Else
   If [L]JOUR(I)>0 & [F:TIG]STRDAT+I-1>=[F:CNG]DEBDAT
    If [F:CNE]NBRPRI=[F:CNE]NBRDAY | [F:TIG]STRDAT+I-1>[F:CNG]FINDAT
     Break
    Elsif [F:CNE]NBRPRI+[L]JOUR(I)<[F:CNE]NBRDAY
     [F:CNE]NBRPRI+=[L]JOUR(I)
     [L]JOUR(I)    =0
    Else
     [L]JOUR(I)   -=[F:CNE]NBRDAY-[F:CNE]NBRPRI
     [F:CNE]NBRPRI =[F:CNE]NBRDAY
    Endif
   Endif
  Endif
#JASMI - 2014-09-01 - END
 Next

 Rewrite [CNE]
 If fstat
  GOK=0
  Call FSTA("CNE") From GLOCK
  Break
 Endif

 If sum([L]JOUR)=0 : Break : Endif
Next

#Il reste des jours à poser mais le solde est insuffisant -> SOLDE négatif
If sum([L]JOUR)<>0
#JASMI - 2014-09-01 - START
# Filter [LNK] Where REFNUM=[F:TIG]REFNUM & TIM=[F:TIG]TIM & CTRNUM=[F:TIG]CTRNUM
#&                 & [CNG]DEBDAT<=[F:TIG]ENDDAT & [CNG]FINDAT>=[F:TIG]STRDAT
#ADNGO - 2017-01-12 - X3-11347 - START
 #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
 If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#ADNGO - 2017-01-12 - X3-11347 - END
  Filter [LNK] Where REFNUM=[F:TIG]REFNUM & TIM=[F:TIG]TIM & CTRNUM=[F:TIG]CTRNUM
&                 & [CNE]EMPLEASTR<=[F:TIG]ENDDAT & [CNE]EMPLEAEND>=[F:TIG]STRDAT
 Else
  Filter [LNK] Where REFNUM=[F:TIG]REFNUM & TIM=[F:TIG]TIM & CTRNUM=[F:TIG]CTRNUM
&                 & [CNG]DEBDAT<=[F:TIG]ENDDAT & [CNG]FINDAT>=[F:TIG]STRDAT
 Endif
#JASMI - 2014-09-01 - END
 Read [LNK]CNE1 Last
 Filter [LNK]
 If !fstat
  [F:CNE]NBRPRI +=sum([L]JOUR)
  Rewrite [CNE]
  If fstat
   GOK=0 : Call FSTA("CNE") From GLOCK
  Endif
 Endif
Endif

End

############################################################################################
# Saisie d'une régul de type -N CP =>Restitution des CP dans CNGEMP et création de TIMCNG
# [F:TIG] en ligne
# [L]JOUR tableau des jours de VALORDET From SUBPLN pour le [F:TIG] en ligne
############################################################################################
Subprog ADD_CPREG(JOUR)
Value Decimal JOUR(1..)

If !clalev([F:CNG]) : Local File CNGCPY [CNG] : Endif
If !clalev([F:CNE]) : Local File CNGEMP [CNE] : Endif
If !clalev([F:TIC]) : Local File TIMCNG [TIC] : Endif

Local Integer  I
Local Char     CPY([V]GLONCPY)

[L]CPY=func DIVPAYE.GETSOC([F:TIG]FCY)

# Création de l'enregistrement dans TIMCNG + maj CNGEMP

#JASMI - 2014-09-01 - START
#Link [CNE] With [CNG]CNG0=[L]CPY;YEA;TIM As [LNK]
#&  Where REFNUM=[F:TIG]REFNUM & TIM=[F:TIG]TIM & NBRPRI<>0 & [CNG]DEBDAT<=[F:TIG]ENDDAT &
#&  [CNG]FINDAT>=[F:TIG]STRDAT & CTRNUM=[F:TIG]CTRNUM
#&  Order By REFNUM;YEA Desc
#ADNGO - 2017-01-12 - X3-11347 - START
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
 If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#ADNGO - 2017-01-12 - X3-11347 - END
 Link [CNE] With [CNG]CNG0=[L]CPY;YEA;TIM As [LNK]
&   Where REFNUM=[F:TIG]REFNUM & TIM=[F:TIG]TIM & NBRPRI<>0 & [CNE]EMPLEASTR<=[F:TIG]ENDDAT &
&   [CNE]EMPLEAEND>=[F:TIG]STRDAT & CTRNUM=[F:TIG]CTRNUM
&   Order By REFNUM;YEA Desc
Else
 Link [CNE] With [CNG]CNG0=[L]CPY;YEA;TIM As [LNK]
&   Where REFNUM=[F:TIG]REFNUM & TIM=[F:TIG]TIM & NBRPRI<>0 & [CNG]DEBDAT<=[F:TIG]ENDDAT &
&   [CNG]FINDAT>=[F:TIG]STRDAT & CTRNUM=[F:TIG]CTRNUM
&   Order By REFNUM;YEA Desc
Endif
#JASMI - 2014-09-01 - END
For [LNK]

 [F:TIC]LIG   =[F:TIG]LIG
 [F:TIC]YEA   =[F:CNG]YEA
 [F:TIC]NBRDAY=[F:CNE]NBRPRI
 [F:TIC]FLGREG=1+(maskcou="TPSSTDR")
#JASMI - 2014-09-01 - START
# [F:TIC]FLGBEF=1+([F:TIG]STRDAT<[F:CNG]STRDAT)
#ADNGO - 2017-01-12 - X3-11347 - START
 #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
 If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#ADNGO - 2017-01-12 - X3-11347 - END
  [F:TIC]FLGBEF=1+([F:TIG]STRDAT<[F:CNE]EMPLEASTR)
 Else
  [F:TIC]FLGBEF=1+([F:TIG]STRDAT<[F:CNG]STRDAT)
 Endif
#JASMI - 2014-09-01 - END

 For I=1 To dim([L]JOUR)
#JASMI - 2014-09-01 - START
#  If [L]JOUR(I)>0 & [F:TIG]STRDAT+I-1>=[F:CNG]DEBDAT
#   If [F:CNE]NBRPRI=0 | [F:TIP]STRDAT+I-1>[F:CNG]FINDAT
#    Break
#   Elsif [F:CNE]NBRPRI-[L]JOUR(I)>0
#    [F:CNE]NBRPRI-=[L]JOUR(I)
#    [L]JOUR(I)    =0
#   Else
#    [L]JOUR(I)   -=[F:CNE]NBRPRI : # Pris=0.5 Jour=1 => 0.5-1<=0
#    [F:CNE]NBRPRI =0
#   Endif
#  Endif
#ADNGO - 2017-01-12 - X3-11347 - START
  #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#ADNGO - 2017-01-12 - X3-11347 - END
   If [L]JOUR(I)>0 & [F:TIG]STRDAT+I-1>=[F:CNE]EMPLEASTR
    If [F:CNE]NBRPRI=0 | [F:TIP]STRDAT+I-1>[F:CNE]EMPLEAEND
     Break
    Elsif [F:CNE]NBRPRI-[L]JOUR(I)>0
     [F:CNE]NBRPRI-=[L]JOUR(I)
     [L]JOUR(I)    =0
    Else
     [L]JOUR(I)   -=[F:CNE]NBRPRI : # Pris=0.5 Jour=1 => 0.5-1<=0
     [F:CNE]NBRPRI =0
    Endif
   Endif
  Else
   If [L]JOUR(I)>0 & [F:TIG]STRDAT+I-1>=[F:CNG]DEBDAT
    If [F:CNE]NBRPRI=0 | [F:TIP]STRDAT+I-1>[F:CNG]FINDAT
     Break
    Elsif [F:CNE]NBRPRI-[L]JOUR(I)>0
     [F:CNE]NBRPRI-=[L]JOUR(I)
     [L]JOUR(I)    =0
    Else
     [L]JOUR(I)   -=[F:CNE]NBRPRI : # Pris=0.5 Jour=1 => 0.5-1<=0
     [F:CNE]NBRPRI =0
    Endif
   Endif
  Endif
#JASMI - 2014-09-01 - END
 Next

 [F:TIC]NBRDAY=([F:TIC]NBRDAY-[F:CNE]NBRPRI)*-1
 Write [TIC]
 If fstat
  GOK=0
  Call FSTA("TIC") From GLOCK
  Break
 Endif

 Rewrite [CNE]
 If fstat
  GOK=0
  Call FSTA("CNE") From GLOCK
  Break
 Endif

 If sum([L]JOUR)=0 : Break : Endif
Next

End

