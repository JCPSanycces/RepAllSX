Subprog C_ENDPAY(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ENDPAY" : GZNUM = 4024 : Endif
If !mkstat
 ## Action STD
 Call C_ENDPAY(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "ENDPAY" : GZNUM = 4024 : Endif
 If !mkstat
  ## Action CTLDATV
  Call CTLDATV(VALEUR,[M:CTRA]STRPAY(nolign-1)) From CONTDIV
  If mkstat : GERR = 1 : GZONE = "ENDPAY" : GZNUM = 4024 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_ENDPAY(VALEUR)
Variable Date    VALEUR
If !GWEBSERV
 ## Action SELPAYBUL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPAYBUL"
 PARMSK(1) = [M:CTR0]REFNUM
 PARMSK(2) = [M:CTR0]CTRNUM
 PARMSK(3) = num$([M:CTRA]STRDAT(nolign-1))
 PARMSK(4) = "STRDAT>=[M:CTRA]RETDATEFF & STA>1 & RVS<>2 & RVSDAT=[0/0/0]"
 PARMSK(5) = [M:CTRA]ENDBUL(nolign-1)
 Call S_TAB_DAT(VALEUR,PARMSK,"SELPAYBUL","PAYSUB","") From GACTION
 [M:CTRA]ENDBUL(nolign-1) = PARMSK(5)
 GACTION = SAVACT
Endif
Gosub _AFF
End

