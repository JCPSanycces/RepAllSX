Subprog AS_STRPAY(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
## Action STD
Call AS_STRPAY(VALEUR) From SUBCTR
If mkstat=2
 [M]STRPAY(INDIC) = VALEUR
 Affzo STRPAY(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_STRPAY(zc) From W1CTR10
Gosub _AFF
End

Subprog C_STRPAY(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "STRPAY" : GZNUM = 47958 : Endif
If !mkstat
 ## Action STD
 Call C_STRPAY(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "STRPAY" : GZNUM = 47958 : Endif
Endif
Gosub _AFF
End

Subprog S_STRPAY(VALEUR)
Variable Date    VALEUR
If !GWEBSERV
 ## Action SELPAYBUL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPAYBUL"
 PARMSK(1) = [M:CTR0]REFNUM
 PARMSK(2) = [M:CTR0]CTRNUM
 PARMSK(3) = num$([M:CTRA]STRDAT(nolign-1))
 PARMSK(4) = "STRDAT>=[M:CTRA]RETDATEFF & STA>1 & RVS<>2 & RVSDAT=[0/0/0]"
 PARMSK(5) = [M:CTRA]STRBUL(nolign-1)
 Call S_TAB_DAT(VALEUR,PARMSK,"SELPAYBUL","PAYSUB","") From GACTION
 [M:CTRA]STRBUL(nolign-1) = PARMSK(5)
 GACTION = SAVACT
Endif
Gosub _AFF
End

