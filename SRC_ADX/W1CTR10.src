#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR10 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:41"
A_USER  = "DOC"
A_STAMP = "20181109230341"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRRCR"
  If [M]NBRRCR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTR10 [CTRA]
Gosub HORODAT
Local Inpbox "CTR10" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTRA] As [SIM_]
Grizo [CTRA]5
Grizo [CTRA]10
Grizo [CTRA]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTRA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=88 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=88 : Y1(1)=4 : Y2(1)=19
X1(2)=1 : X2(2)=88 : Y1(2)=20 : Y2(2)=22
Return

$ON_FLGRET
Onevent INIT_AREA Call D_FLGRET(zc) From W1CTR10
Return

Subprog D_FLGRET(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGRET,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_RETTYP
Onevent BEFORE_INPUT Call AS_RETTYP(zc) From W1CTR10
Onevent INIT_AREA Call D_RETTYP(zc) From W1CTR10
Onevent CONTROL Call C_RETTYP(zc) From W1CTR10
Return

Subprog D_RETTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]RETTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_RETTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10644) From COMBOS
## Action STD
Call AS_RETTYP(VALEUR) From SUBCTR
If mkstat=2
 [M]RETTYP(INDIC) = VALEUR
 Affzo RETTYP(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10644,1))))
Endif
If !mkstat
 Discombo 0 From RETTYP(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From RETTYP(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_RETTYP(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

