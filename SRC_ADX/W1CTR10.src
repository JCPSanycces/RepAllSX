Subprog D_RETGRD(VALEUR)
Variable Char    VALEUR()
If varinit([M]RETGRD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"443","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_RETGRD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"443") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_RETGRD(zc) From W1CTR10
Onkey   2 Titled GBOUTS Call S_RETGRD(zc) From W1CTR10
Onkey 144 Titled GBOUTP Call P_RETGRD(zc) From W1CTR10
Onkey 146 Titled GBOUTA Call SA_RETGRD(zc) From W1CTR10
Gosub _AFF
End

Subprog C_RETGRD(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"443","") From SUBADI
If mkstat : GERR = 1 : GZONE = "RETGRD" : GZNUM = 2675 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"443",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "RETGRD" : GZNUM = 2675 : Endif
Endif
Gosub _AFF
End

$AMM_RETGRD
Call AM_RETGRD(zc)
If !mkstat & GOBJET
 zoncou = "RETGRD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_RETGRD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZRETGRD)")>indice
 [M]RETGRD(indice) = VALEUR
 Affzo ZRETGRD(indice)
Endif
Gosub _AFF
End

Subprog S_RETGRD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "443"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_RETGRD(VALEUR)
