$ON_VALDEN
Onevent BEFORE_INPUT Call AS_VALDEN(zc) From W1CTR10
Onevent CONTROL Call C_VALDEN(zc) From W1CTR10
Return

Subprog IB_VALDEN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTBOUT
 Call BOUTSEL(VALEUR,[M]CODTYP(nolign-1),[M]NOLIB(nolign-1),"") From FMTVAR
Endif
Gosub _AFF
End

Subprog AS_VALDEN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(877,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_VALDEN(VALEUR)
## Action AFMTSAI
Call ASAISIE(VALEUR,[M]CODTYP(nolign-1)) From FMTVAR
If mkstat=2
 [M]VALDEN(INDIC) = VALEUR
 Affzo VALDEN(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action STD
 Call AS_VALDEN(VALEUR) From SUBCTR
 If mkstat=2
  [M]VALDEN(INDIC) = VALEUR
  Affzo VALDEN(INDIC) : mkstat = 2
 Endif
 Onkey 129 Titled GBOUT1 Call B1_VALDEN(zc) From W1CTR10
 Onkey   2 Titled GBOUTS Call S_VALDEN(zc) From W1CTR10
Endif
Gosub _AFF
End

Subprog C_VALDEN(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "VALDEN" : GZNUM = 5231 : Endif
If !mkstat
 ## Action AFMTCONT
 Call CONTROLE(VALEUR,[M]CODTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINTDEN(nolign-1)) From FMTVAR
 If mkstat : GERR = 1 : GZONE = "VALDEN" : GZNUM = 5231 : Endif
 If !mkstat
  ## Action ACONTACL
  Call CONTACL([M]VALINTDEN(nolign-1),[M]CODTYP(nolign-1),"","") From SUBACL
  If mkstat : GERR = 1 : GZONE = "VALDEN" : GZNUM = 5231 : Endif
  If !mkstat
   ## Action STD
   Call C_VALDEN(VALEUR) From SUBCTR
   If mkstat : GERR = 1 : GZONE = "VALDEN" : GZNUM = 5231 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_VALDEN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = [M]CODTYP(nolign-1)
 PARMSK(2) = num$([M]NOLIB(nolign-1))
 PARMSK(3) = num$([M]LONG(nolign-1))
 PARMSK(4) = [M]VALINTDEN(nolign-1)
 PARMSK(5) = [M]VALPAR(nolign-1)
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINTDEN(nolign-1) = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = [M]CODTYP(nolign-1)
 PARMSK(2) = num$([M]NOLIB(nolign-1))
 PARMSK(3) = num$([M]LONG(nolign-1))
 PARMSK(4) = [M]VALINTDEN(nolign-1)
 PARMSK(5) = [M]VALPAR(nolign-1)
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINTDEN(nolign-1) = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_VALDEN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTB1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTB1"
 PARMSK(1) = [M]CODTYP(nolign-1)
 PARMSK(2) = [M]VALPAR(nolign-1)
 PARMSK(3) = num$([M]NOLIB(nolign-1))
 PARMSK(4) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFMTB1","FMTVAR","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_LEACYCTYP
Onevent INIT_AREA Call D_LEACYCTYP(zc) From W1CTR10
Onevent BEFORE_INPUT Call AS_LEACYCTYP(zc) From W1CTR10
Return

Subprog D_LEACYCTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]LEACYCTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_LEACYCTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_LEARSMDAT
Onevent BEFORE_INPUT Call AS_LEARSMDAT(zc) From W1CTR10
Onevent BEFORE_AREA Gosub AV_LEARSMDAT From W1CTR10
Return

$AV_LEARSMDAT
Chgfmt [M]LEARSMDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_LEARSMDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action SUBCTRLEG
Call BEFORE_ENTRY(VALEUR) From SUBCTRLEG
If mkstat=2
 [M]LEARSMDAT(INDIC) = VALEUR
 Affzo LEARSMDAT(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$CHG_STY
Return


