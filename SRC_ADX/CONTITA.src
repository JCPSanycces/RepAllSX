Raz TOTALE

# CALCOLO TOTALE CIFRE PARI.

For I=2 To 14 Step 2
    CARATTERE = mid$(SIRET,I,1)
    For J=0 To 35
        If CARATTERE = ALFABETO(J)
            TOTALE += CHECKPARI(J)
