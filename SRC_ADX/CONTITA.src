##########################################################
##  Contrôle du RIB                                    ###
##########################################################
Subprog RIB(RIB,SPSTAT)
Value Char RIB()
Variable Integer SPSTAT

Local Char ALFABETO(1)(39)
Local Integer CHECKPARI(39)
Local Integer CHECKDISPARI(39)
Local Integer TOTALE
Local Char CARATTERE

# Inizializzazione variabili

ALFABETO (0)= "0"
ALFABETO (1)= "1"
ALFABETO (2)= "2"
ALFABETO (3)= "3"
ALFABETO (4)= "4"
ALFABETO (5)= "5"
ALFABETO (6)= "6"
