Local Integer I,J,K
If RIB=""          : SPSTAT=0 : End
Elsif len(RIB)<>22 : SPSTAT=2 : End
Elsif RIB=string$(22,"0") : SPSTAT=1 : End
Endif

TOTALE = 0

# CALCOLO TOTALE CIFRE PARI.

For I=2 To 22 Step 2
    CARATTERE = mid$(RIB,I,1)
    For J=0 To 38
        If CARATTERE = ALFABETO(J)
            TOTALE += CHECKPARI(J)
