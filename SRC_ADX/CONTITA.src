ALFABETO (21)= "L"
ALFABETO (22)= "M"
ALFABETO (23)= "N"
ALFABETO (24)= "O"
ALFABETO (25)= "P"
ALFABETO (26)= "Q"
ALFABETO (27)= "R"
ALFABETO (28)= "S"
ALFABETO (29)= "T"
ALFABETO (30)= "U"
ALFABETO (31)= "V"
ALFABETO (32)= "W"
ALFABETO (33)= "X"
ALFABETO (34)= "Y"
ALFABETO (35)= "Z"
ALFABETO (36)= "-"
ALFABETO (37)= "."
ALFABETO (38)= " "


CHECKPARI(0) = 0
CHECKPARI(1) = 1
CHECKPARI(2) = 2
CHECKPARI(3) = 3
CHECKPARI(4) = 4
CHECKPARI(5) = 5
CHECKPARI(6) = 6
CHECKPARI(7) = 7
CHECKPARI(8) = 8
CHECKPARI(9) = 9
CHECKPARI(10) = 0
CHECKPARI(11) = 1
CHECKPARI(12) = 2
CHECKPARI(13) = 3
CHECKPARI(14) = 4
CHECKPARI(15) = 5
CHECKPARI(16) = 6
CHECKPARI(17) = 7
CHECKPARI(18) = 8
CHECKPARI(19) = 9
CHECKPARI(20) = 10
CHECKPARI(21) = 11
CHECKPARI(22) = 12
CHECKPARI(23) = 13
CHECKPARI(24) = 14
CHECKPARI(25) = 15
CHECKPARI(26) = 16
CHECKPARI(27) = 17
CHECKPARI(28) = 18
CHECKPARI(29) = 19
CHECKPARI(30) = 20
CHECKPARI(31) = 21
CHECKPARI(32) = 22
CHECKPARI(33) = 23
CHECKPARI(34) = 24
CHECKPARI(35) = 25
CHECKPARI(36) = 26
CHECKPARI(37) = 27
CHECKPARI(38) = 28


CHECKDISPARI(0) = 1
CHECKDISPARI(1) = 0
CHECKDISPARI(2) = 5
CHECKDISPARI(3) = 7
CHECKDISPARI(4) = 9
CHECKDISPARI(5) = 13
CHECKDISPARI(6) = 15
CHECKDISPARI(7) = 17
CHECKDISPARI(8) = 19
CHECKDISPARI(9) = 21
CHECKDISPARI(10) = 1
CHECKDISPARI(11) = 0
CHECKDISPARI(12) = 5
CHECKDISPARI(13) = 7
CHECKDISPARI(14) = 9
CHECKDISPARI(15) = 13
CHECKDISPARI(16) = 15
CHECKDISPARI(17) = 17
CHECKDISPARI(18) = 19
CHECKDISPARI(19) = 21
CHECKDISPARI(20) = 2
CHECKDISPARI(21) = 4
CHECKDISPARI(22) = 18
CHECKDISPARI(23) = 20
CHECKDISPARI(24) = 11
CHECKDISPARI(25) = 3
CHECKDISPARI(26) = 6
CHECKDISPARI(27) = 8
CHECKDISPARI(28) = 12
CHECKDISPARI(29) = 14
CHECKDISPARI(30) = 16
CHECKDISPARI(31) = 10
CHECKDISPARI(32) = 22
CHECKDISPARI(33) = 25
CHECKDISPARI(34) = 24
CHECKDISPARI(35) = 23
CHECKDISPARI(36) = 27
CHECKDISPARI(37) = 28
CHECKDISPARI(38) = 26

Local Integer I,J,K
If RIB=""          : SPSTAT=0 : End
Elsif len(RIB)<>23 : SPSTAT=2 : End
Elsif RIB=string$(23,"0") : SPSTAT=1 : End
Endif

TOTALE = 0

# CALCOLO TOTALE CIFRE PARI.

For I=3 To 23 Step 2
    CARATTERE = mid$(RIB,I,1)
    For J=0 To 38
        If CARATTERE = ALFABETO(J)
            TOTALE += CHECKPARI(J)
        Endif
    Next J
Next I

# CALCOLO TOTALE CIFRE DISPARI

For I=2 To 22 Step 2
    CARATTERE = mid$(RIB,I,1)
    For J=0 To 38
        If CARATTERE = ALFABETO(J)
            TOTALE += CHECKDISPARI(J)
        Endif
    Next J
Next I

# PER CALCOLARE IL CHECK DIGIT FARE TOTALE/26 IL RESTO DA LA LETTERA DIGIT.

J=mod(TOTALE,26)
J+=10

CARATTERE = left$(RIB,1)
If CARATTERE = ALFABETO (J)
    SPSTAT = 0
Else
    SPSTAT = 1
Endif

End


