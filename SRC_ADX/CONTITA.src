##########################################################
##  Contrôle du SIRET                                  ###
##########################################################
Subprog SIRET(SIRET,SITE,SPSTAT)
Value Char SIRET()
Value Char SITE
Variable Integer SPSTAT

### Modif V137 Fc, 11/08/02
If len(SIRET) = 11            : # E' un azienda > Partita IVA
    Gosub PARTITA_IVA
Elsif len(SIRET) = 16         : # E' una personna fisica > Codice fiscale
    Gosub CODICE_FISCALE
Elsif SIRET = ""
    SPSTAT = 0
Else : SPSTAT = 2
Endif
End
### Fin controlo Partita IVA / Codice Fiscale

$CODICE_FISCALE
