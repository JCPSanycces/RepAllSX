$PARTITA_IVA
Local Integer TOT
Local Char STATO(2)
Local Char NUMERI(1)(11)

NUMERI(0)= "0"
NUMERI(1)= "1"
NUMERI(2)= "2"
NUMERI(3)= "3"
NUMERI(4)= "4"
NUMERI(5)= "5"
NUMERI(6)= "6"
NUMERI(7)= "7"
NUMERI(8)= "8"
NUMERI(9)= "9"
NUMERI(10)= "0"

# ciclo per i pari

TOTALE = 0
For I=1 To 9 Step 2
    CARATTERE = mid$(SIRET,I,1)
    For J=0 To 9
        If CARATTERE = NUMERI(J)
            TOTALE += J
        Endif
    Next J
Next I

# ciclo per i dispari

For I=2 To 10 Step 2
    CARATTERE = mid$(SIRET,I,1)
    For J=0 To 9
        If CARATTERE = NUMERI(J)
            TOT = J*2
            If TOT >= 10
               TOTALE += mod(TOT,10) + 1
            Else
               TOTALE += TOT
            Endif
        Endif
    Next J
Next I

J=mod(TOTALE,10)
J=10-J
CARATTERE = mid$(SIRET,11,1)
If CARATTERE = NUMERI(J)
    SPSTAT = 0
Else
    SPSTAT = 1
Endif
If len(SIRET)<>11 SPSTAT = 1 : Endif
Return


##########################################################
##  Contrôle du Numéro TVA                             ###
###  V137, aggiunto dei messagi per capire errori      ###
##########################################################
Subprog TVA(TVA,SPSTAT)
Value Char TVA()
Variable Integer SPSTAT
Local Integer TOTALE,TOT
Local Char CARATTERE,STATO(2)
Local Char NUMERI(1)(11)

NUMERI(0)= "0"
NUMERI(1)= "1"
NUMERI(2)= "2"
NUMERI(3)= "3"
NUMERI(4)= "4"
NUMERI(5)= "5"
NUMERI(6)= "6"
NUMERI(7)= "7"
NUMERI(8)= "8"
NUMERI(9)= "9"
NUMERI(10)= "0"

########################################
###  controllo unicità Partita IVA   ###
########################################
Local Shortint FLGPIVA
Local Char TERZO(20)
Local Integer ZOK
Local Integer RISP,FINE
Local Char MESSAGIO(80)

Raz FLGPIVA

If GFONCTION="GESBPR" : TERZO = [M:BPR0]BPRNUM : Endif
If GFONCTION="GESBPP" : TERZO = [M:BPP0]BPCNUM : Endif
If GFONCTION="GESBPC" : TERZO = [M:BPC0]BPCNUM : Endif
If GFONCTION="GESBPS" : TERZO = [M:BPS0]BPSNUM : Endif
If GFONCTION="GESREP" : TERZO = [M:REP0]REPNUM : Endif
If GFONCTION="GESBPT" : TERZO = [M:BPT0]BPTNUM : Endif


############################################
###  Controllo per evitare errori        ###
############################################
### FC, 05/11/03 aggiunto i messagi in francese
### modif FC 07/11/2003, Messagio non bloquante se Ident CEE esistente

Raz ZOK
Raz MESSAGIO
If len(TVA)<>13
#LSE 20/10/2006 FQ 38049
#   #If GLANGUE="FRA" : MESSAGIO = " Le code a une longueur différente de 13 caractères, continuer ?"
#   #Else : MESSAGIO = "Il codice non ha 13 caratteri?"
#   #Endif
    #Le code a une longueur différente de 13 caractères, continuer ?
    MESSAGIO=mess( 79,187,1)
    Call OUINON(MESSAGIO,ZOK) From GESECRAN
    If ZOK = 2 : End                                 : # Non controllo
    Else : SPSTAT = 1
    Endif
Endif


#### Controllo dell'unicità
Raz MESSAGIO, RISP, FINE
If TVA<>"" & filinfo(filpath("FIL","BPARTNER","fde"),0)>0 & TERZO <> ""
    If !clalev([F:BPX]) : Local File BPARTNER [BPX] : Endif

    For [BPX] Where [F:BPX]EECNUM = TVA & [F:BPX]BPRNUM<>TERZO & GFONCTION <> "GESBPR"
&                   | [F:BPX]EECNUM = TVA & GFONCTION = "GESBPR"
#LSE 20/10/2006 FQ 38049
#       #If GLANGUE="FRA" : MESSAGIO = " Identifiant CEE déjà existant, continuer?"
#       #Else : MESSAGIO = "Identificazione CEE già esistente, continuare?"
#       #Endif
        #Identifiant CEE déjà existant, continuer?
        MESSAGIO=mess( 80, 187,1)
        Call OUINON(MESSAGIO,RISP) From GESECRAN    : # V137
        If RISP = 2 : FINE = 1 : Break                           : # Modif FC 05/11/03 controllo non bloccando !
        Else
         FLGPIVA = 1 : Break
        Endif
    Next
    If FINE : End : Endif
Endif

If FLGPIVA
  SPSTAT = 1 : End
Endif


#CONTROLLO CODICE PAESE

## <PP 25/07/2002> Bug 15308
#STATO = mid$(TVA,1,2)
#If [F:TCY]CRY<>STATO
# Read [TCY]TCY0 = STATO
# If fstat <> 0 :SPSTAT = 1 :END
# Endif
#Endif

Raz MESSAGIO
If left$(TVA,len([F:TCY]CRYVATNUM))<>[F:TCY]CRYVATNUM
   SPSTAT = 1
#LSE 20/10/2006 FQ 38049
#   #If GLANGUE="FRA" : MESSAGIO = "L'identifiant doit comnencer par "-[F:TCY]CRYVATNUM
#   #Else : MESSAGIO = "Il codice deve cominciare per "-[F:TCY]CRYVATNUM
#   #Endif
    #L'identifiant doit commencer par "-[F:TCY]CRYVATNUM
    MESSAGIO=mess(81,187,1)-[F:TCY]CRYVATNUM
    Call ERREUR(MESSAGIO) From GESECRAN : End    : # V137
Endif


# ciclo per i pari

TOTALE = 0
For I=3 To 11 Step 2
    CARATTERE = mid$(TVA,I,1)
    For J=0 To 9
        If CARATTERE = NUMERI(J)
            TOTALE += J
        Endif
    Next J
Next I

# ciclo per i dispari

For I=4 To 12 Step 2
    CARATTERE = mid$(TVA,I,1)
    For J=0 To 9
        If CARATTERE = NUMERI(J)
            TOT = J*2
            If TOT >= 10
               TOTALE += mod(TOT,10) + 1
            Else
               TOTALE += TOT
            Endif
        Endif
    Next J
Next I

Raz MESSAGIO
J=mod(TOTALE,10)
J=10-J
CARATTERE = mid$(TVA,13,1)
If CARATTERE = NUMERI(J)
    SPSTAT = 0
Else
    SPSTAT = 1
#LSE 20/10/2006 FQ 38049
#   #If GLANGUE="FRA" : MESSAGIO = "Les chiffres sont incorrectes"
#   #Else : MESSAGIO = "I numeri non sono corretti"
#   #Endif
    #Les chiffres sont incorrects
    MESSAGIO=mess(82,187,1)
    Call ERREUR(MESSAGIO) From GESECRAN    : # V137
Endif
End
#### Fine modif V137 ####


######################################################
##  Contrôle du no d'immatriculation sociale       ###
######################################################
Subprog SS(NOSS,ETR,SEX,DNAISS,DEPT,COMNNO,SPSTAT)
Value Char NOSS(), DEPT(), COMNNO()
Value Integer SEX
Value Date DNAISS
Value Libelle ETR : # =1 si non etranger
Variable Integer SPSTAT

Local Char NO(13), CLE(2), MSG(240), CHAN(2), CHMOIS(2)
Local Integer OK

SPSTAT=0
NO=left$(NOSS,13)
CLE=right$(NOSS,14)
If val(CLE)<>0
 N1=97-mod(val(NO),97)
 If val(CLE)<>N1 : SPSTAT=1 : End
 Endif
Endif
MSG=""
If left$(NO,1)<>num$(SEX) & left$(NO,1)<>num$(SEX+6)
 MSG+=mess(24,131,1)+"\"
Endif
If !find(left$(NO,1),"7","8")
 If DNAISS<>[0/0/0]
  CHAN=format$("D:YY",DNAISS) : CHMOIS=format$("D:MM",DNAISS)
  If mid$(NO,2,2)<>CHAN
   MSG+=mess(25,131,1)+"\"
  Endif
  If mid$(NO,4,2)<>CHMOIS
   MSG+=mess(26,131,1)+"\"
  Endif
 Endif
 If ETR=1 & DEPT<>"" & mid$(NO,6,2)<>format$("N0:#B",DEPT)
  MSG+=mess(27,131,1)+"\"
 Endif
 If ETR=1 & COMNNO<>"" & mid$(NO,8,3)<>format$("N0:3#",COMNNO)
  MSG+=mess(28,131,1)+"\"
 Endif
Endif
If MSG<>""
 MSG=left$(MSG,len(MSG)-1)
 OK=1 : Call AVERTIR(MSG,OK) From GESECRAN
 If OK=1 : SPSTAT=3 : Endif
Endif
End

######################################################
##  Contrôle du no d'immatriculation sociale n°2   ###
######################################################
Subprog SS2(NOSS,ETR,SEX,DNAISS,DEPT,COMNNO,SPSTAT)
Value Char NOSS(), DEPT(), COMNNO()
Value Integer SEX
Value Date DNAISS
Value Libelle ETR : # =1 si non etranger
Variable Integer SPSTAT

End


###############################################################
##  Valeur par défaut du no d'immatriculation sociale       ###
###############################################################
Subprog VDSS(ETR,SEX,DNAISS,DEPT,COMNNO,NOSS)
Value Libelle ETR : # =1 si non etranger
Variable Char NOSS()
Value Integer SEX
Value Date DNAISS
Value Char DEPT
Value Char COMNO

NOSS=num$(SEX)
If DNAISS=[0/0/0]
 NOSS+="0000"
Else
 NOSS+=format$("D:YYMM",DNAISS)
Endif
If ETR=1
 NOSS+=format$("N0:#B",DEPT)+format$("N0:3#",COMNNO)
Endif
For I=len(NOSS) To 1 Step -1
 If mid$(NOSS,I,1)<>"0" : NOSS=left$(NOSS,I) : Break : Endif
Next I
End

###############################################################
##  Valeur par défaut du no d'immatriculation sociale 2     ###
###############################################################
Subprog VDSS2(ETR,SEX,DNAISS,DEPT,COMNNO,NOSS)
Value Libelle ETR : # =1 si non etranger
Variable Char NOSS()
Value Integer SEX
Value Date DNAISS
Value Char DEPT
Value Char COMNNO

End

##########################################################
##  Contrôle du SIRET                                  ###
##########################################################
Subprog PIVA(PIVA,SPSTAT)
Value Char PIVA()
Variable Integer SPSTAT
Local Integer TOTALE
Local Char CARATTERE,STATO(2)
Local Char NUMERI(1)(10)

NUMERI(0)= "0"
NUMERI(1)= "1"
NUMERI(2)= "2"
NUMERI(3)= "3"
NUMERI(4)= "4"
NUMERI(5)= "5"
NUMERI(6)= "6"
NUMERI(7)= "7"
NUMERI(8)= "8"
NUMERI(9)= "9"

# ******************************
# ***** controllo per evitare errori
If len(TVA)<>13 : SPSTAT=1 : End
Endif
# **********************************

#CONTROLLO CODICE PAESE

## <PP 25/07/2002> Bug 15308

#STATO = mid$(PIVA,1,2)
#If [F:TCY]CRY<>STATO
# Read [TCY]TCY0 = STATO
# If fstat <> 0 :SPSTAT = 1 :END
# Endif
#Endif

If left$(PIVA,len([F:TCY]CRYVATNUM))<>[F:TCY]CRYVATNUM
 SPSTAT = 1 : End
Endif

# ciclo per i pari

TOTALE = 0
For I=3 To 11 Step 2
    CARATTERE = mid$(PIVA,I,1)
    For J=0 To 9
        If CARATTERE = NUMERI(J)
            TOTALE += J
        Endif
    Next J
Next I

# ciclo per i dispari

For I=4 To 12 Step 2
    CARATTERE = mid$(PIVA,I,1)
    For J=0 To 9
        If CARATTERE = NUMERI(J)
            TOTALE += J*2
        Endif
    Next J
Next I

J=mod(TOTALE,10)
J=10-J
CARATTERE = mid$(PIVA,13,1)
If CARATTERE = NUMERI(J)
    SPSTAT = 0
Else
    SPSTAT = 1
Endif
End

#######################################################################
##   Mise à jour de l'enregistrement DEB : echanges CEE              ##
##     traitement des arrondis                                       ##
##-------------------------------------------------------------------##
##  Flux :  11 Introduction Achats     12 Introduction Ventes        ##
##          21 Expedition   Achats     22 Expedition   Ventes        ##
#######################################################################
Subprog DEB (FLUX, SPSTAT)
Value    Integer FLUX
Variable Integer SPSTAT

Call DEB (FLUX, SPSTAT) From CONTNUM

End





