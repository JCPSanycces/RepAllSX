#<AdxTL>@(#)9.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR 
Variable Char    PARAMETRE()()
#--- ouverture des tables
Gosub OUVRE 
#--- declaration des variables
Gosub DECLARE 

[L]CRITERE = "1=1 & VCRTYP = 28"
#--- analyse des paramètres
For I=1 To NBPAR 
    J=instr(1,[L]PARAMETRE(I),"=")
    If J
       [L]PARAM  = left$([L]PARAMETRE(I),J-1)
       [L]VALEUR = right$([L]PARAMETRE(I),J+1)
       Case [L]PARAM
            When "X3ETA"           : [L]ETAT   =     [L]VALEUR
            When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
            #--- alimentation des paramètres utilisateur 
            When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
            When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
            When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
            #--- préparation du filtre à appliquer sur la table CUD 
            When "stofcydeb"       : [L]CRITERE -= "& STOFCY>='"+[L]VALEUR+"'"
            When "stofcyfin"       : [L]CRITERE -= "& STOFCY<='"+[L]VALEUR+"'"
            When "analysedeb"      : [L]CRITERE -= "& VCRNUM>='"+[L]VALEUR+"'" 
            When "analysefin"      : [L]CRITERE -= "& VCRNUM<='"+[L]VALEUR+"'" 
       Endcase
    Endif
Next
Gosub PUR_WQL
Filter [F:QLH] Where evalue([L]CRITERE) 
For [QLH]
    Gosub TRT_QLD
Next
Filter [F:QLH]
End

###################################################################
$TRT_QLD
Local Char    WLOT(GLONLOT)                                                   
Local Char    LLOT(GLONLOT)                                                   
Local Integer WMAX
WMAX = dim([M:STQW]QLYCRD)     # mémorisation nombre de ligne maxi
Raz nolign
Raz WLOT
Raz [M:STQW]

Default File [QLD]
If [F:ITM]ITMREF    <> [F:QLH]ITMREF
   Read [F:ITM]ITM0 =  [F:QLH]ITMREF
   If fstat 
      Raz [F:ITM] 
   Endif
Endif
If [F:ITF]ITMREF    <> [F:QLH]ITMREF | [F:ITF]STOFCY <> [F:QLH]STOFCY
   Read [F:ITF]ITF0 =  [F:QLH]ITMREF;[F:QLH]STOFCY
   If fstat 
      Raz [F:ITF] 
   Endif
Endif
                                                              
If [F:ITF]SMPTYP > 1                                                        
   If [F:ITF]SMPMOD = 2                           
      Filter [QLD] Where VCRTYP    = [F:QLH]VCRTYP
&                      & VCRNUM    = [F:QLH]VCRNUM
&                  Order By Key QLD2
   Else
      Filter [QLD] Where VCRTYP    = [F:QLH]VCRTYP
&                      & VCRNUM    = [F:QLH]VCRNUM
&                  Order By Key QLD0
   Endif
   For [QLD]
       If nolign > WMAX -1 
          Call ERREUR(mess(70,184,1)) From GESECRAN
          Raz [M:STQW]
          Break
       Else
          If [M:STQW]NBLIG = 0
             Gosub NEWLINE_SMP
          Else
             If [F:ITF]SMPMOD = 2 & WLOT <> [F:QLD]LOT
                Gosub NEWLINE_SMP
             Else
                [M:STQW]QTYSTU          (nolign-1) += [F:QLD]QTYSTU
                If [M:STQW]LOT          (nolign-1) <> [F:QLD]LOT
                   [M:STQW]LOT          (nolign-1) =  "$"
                   [M:STQW]SLO          (nolign-1) =  "$"
                Else
                   If [M:STQW]SLO       (nolign-1) <> [F:QLD]SLO
                      [M:STQW]SLO       (nolign-1) =  "$"
                   Endif
                Endif
                If [M:STQW]PCU          (nolign-1) <> [F:QLD]PCU
                   [M:STQW]PCU          (nolign-1) =  "$"
                   Raz [M:STQW]QTYPCU   (nolign-1)
                   Raz [M:STQW]PCUSTUCOE(nolign-1)
                Else
                   [M:STQW]QTYPCU       (nolign-1) += [F:QLD]QTYPCU
                Endif
                If  [M:STQW]SERNUM      (nolign-1) <> [F:QLD]SERNUM
                    [M:STQW]SERNUM      (nolign-1) =  "$"
                Endif
                If [M:STQW]STA          (nolign-1) <> [F:QLD]STA      
                   [M:STQW]STA          (nolign-1) =  "$"
                Endif
                If [M:STQW]PALNUM       (nolign-1) <> [F:QLD]PALNUM
                   [M:STQW]PALNUM       (nolign-1) =  "$"
                Endif
                If [M:STQW]CTRNUM       (nolign-1) <> [F:QLD]CTRNUM
                   [M:STQW]CTRNUM       (nolign-1) =  "$"
                Endif
                If [M:STQW]OWNER        (nolign-1) <> [F:QLD]OWNER
                   [M:STQW]OWNER        (nolign-1) =  "$"
                Endif
             Endif
          Endif       
       Endif
   Next
   Filter [QLD]
Endif                                

#--- creation 
Gosub CRE_WQL

Return



$NEWLINE_SMP
nolign         += 1
WLOT      =  [F:QLD]LOT 
Raz LLOT
If [F:ITF]SMPMOD = 2                           
   LLOT = [F:QLD]LOT
Else
   Raz LLOT
Endif
# lecture STOQLYSMP (resultat echantillonnage)
Read [SMP]SMP0=[F:QLH]VCRTYP;[F:QLH]VCRNUM;[F:QLH]ITMREF;LLOT 
If fstat 
   Raz [F:SMP]
Endif
[M:STQW]       =  [F:SMP]
[M:STQW]       =  [F:QLD]
[M:STQW]NBLIG  += 1

Return                                  

########################################################################### 
$CRE_WQL
Local Decimal LQTY
Local Decimal LSMP
Local Decimal LACP

Trbegin [WQL]
For I=0 To [M:STQW]NBLIG-1
    Raz [F:WQL]
    [F:WQL]VCRTYP    = [F:QLH]VCRTYP      
    [F:WQL]VCRNUM    = [F:QLH]VCRNUM  
    [F:WQL]ITMREF    = [F:QLH]ITMREF   
    [F:WQL]STOFCY    = [F:QLH]STOFCY  

    [F:WQL]VCRLIN    = [M:STQW]VCRLIN   (I)
    [F:WQL]LOT       = [M:STQW]LOT      (I)
    [F:WQL]SLO       = [M:STQW]SLO      (I)
    [F:WQL]STA       = [M:STQW]STA      (I)
    [F:WQL]PCU       = [M:STQW]PCU      (I)
    [F:WQL]QTYPCU    = [M:STQW]QTYPCU   (I)
    [F:WQL]PCUSTUCOE = [M:STQW]PCUSTUCOE(I)
    [F:WQL]QTYSTU    = [M:STQW]QTYSTU   (I)
    [F:WQL]SERNUM    = [M:STQW]SERNUM   (I)
    [F:WQL]PALNUM    = [M:STQW]PALNUM   (I)
    [F:WQL]CTRNUM    = [M:STQW]CTRNUM   (I)
    [F:WQL]QLYCRD    = [M:STQW]QLYCRD   (I)
    [F:WQL]OWNER     = [M:STQW]OWNER    (I)
    [F:WQL]CRDSEQ    = [M:STQW]CRDSEQ   (I)

    [F:WQL]CODSMP    = [M:STQW]CODSMP   (I)
    [F:WQL]QTYSMP    = [M:STQW]QTYSMP   (I)
    [F:WQL]QTYACP    = [M:STQW]QTYACP   (I)
    [F:WQL]QTYSMPACP = [M:STQW]QTYSMPACP(I)
    [F:WQL]QTYSMPREF = [M:STQW]QTYSMPREF(I)
    [F:WQL]STASMP    = [M:STQW]STASMP   (I)
    [F:WQL]STASMPCAL = [M:STQW]STASMPCAL(I)
    [F:WQL]RENSMP    = [M:STQW]RENSMP   (I)

    If [F:WQL]QTYSMP  = 0  
# calcul code et taille
       LQTY = [F:WQL]QTYSTU 
       Call CALSMPCOD(1,LQTY,[F:WQL]CODSMP,LSMP) From CRDLIB
       [F:WQL]QTYSMP = LSMP
       # calcul taille rejet
       Call CALACPPRM([F:ITF]NQA,[F:WQL]CODSMP,LACP) From CRDLIB
       [F:WQL]QTYACP = LACP
       [F:WQL]SAICOD = "E"
    Endif     
    [F:WQL]USR       = GUSER
    [F:WQL]NUMREQ    = [L]NUMREQ
    [F:WQL]CREUSR    = GUSER 
    [F:WQL]CREDAT    = date$ 
    [F:WQL]UPDUSR    = GUSER 
    [F:WQL]UPDDAT    = date$ 
    Write [F:WQL]   
    If fstat 
       GOK = 0 
       Call FSTA("WQL") From GLOCK 
       Break 
    Endif
Next I 
Commit
Return 


###########################################################
$PUR_WQL
Trbegin [WQL]
Delete [WQL] Where CREUSR = GUSER 
fstat = 0
Delete [WQL] Where NUMREQ = [L]NUMREQ
fstat = 0
Commit
Return

###########################################################################  
$OUVRE 
Local File STOQLYH [QLH], STOQLYD [QLD], WSTOQLYD [WQL] , ITMMASTER [ITM] , ITMFACILIT [ITF]
Local File QLYCRDNQA  [NQA], STOQLYSMP [SMP],ATABDIV [ADI]
Local Mask STQW [STQW]
Return 
 
$DECLARE 
Local Char    CRITERE(255), PARAM(30) , VALEUR(30) , ETAT(15)
Local Integer I, J, NUMREQ 
Raz [M:STQW]
# LECSMPCOD  = Lecture et stockage taille echantillon                   #
Call LECSMPCOD From CRDLIB

Return 


