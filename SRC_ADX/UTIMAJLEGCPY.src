#<AdxTL>@(#)1.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Migration des sociétés en V6/V7 (LEG="" pour société non juridique)
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update LEG in COMPANY Table for non legal company") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJCPY
End

#-------------------#
$MAJCPY

If DOSSIER=GDOSX3
 Return
Endif

# Mise à jour de la table COMPANY

Call ECR_TRACE(mess(81,125,1)-"COMPANY:"-time$,0) From GESECRAN

Local File =DOSSIER+".COMPANY" [CPY]

Trbegin [CPY]

 For [CPY] Where CPYLEGFLG<>2
  [F:CPY]LEG = ""
  Rewrite [CPY]
  If fstat
   Call ERREUR("COMPANY"-[F:CPY]CPY,2) From DOSDIC
  Endif
 Next CPY

Commit

Close Local File [CPY]

Return

