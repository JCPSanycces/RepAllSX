#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque DUCSXTR
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTDUXTR","DUCSXTR",4,"") From GTRAITE
End

#############################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "DEBUT"       : Affzo [M:DIA]: Setmok [DIA] With 0
 When "EXEC"        : Gosub EXEC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1
 When "SORTIE"      : Gosub SORTIE
Endcase
Return


#############################
$OUVRE
Local Mask DUCSXTR [DIA]
Raz [M:DIA]
Gosub OUVFIC From INITDCH
If clalev([F:DUC])=0 : Local File PRMDUCS    [DUC] : Endif
If clalev([F:DCS])=0 : Local File DUCS0      [DCS] : Endif
If clalev([F:DCL])=0 : Local File DUCS1      [DCL] : Endif
If clalev([F:DCT])=0 : Local File DUCS2      [DCT] : Endif
If clalev([F:DCX])=0 : Local File DUCS3      [DCX] : Endif
If clalev([F:BAN])=0 : Local File BANK       [BAN] : Endif
If clalev([F:ORG])=0 : Local File ORGANISME  [ORG] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
If clalev([F:VLA])=0 : Local File VALEUR     [VLA] : Endif
If clalev([F:VFD])=0 : Local File VALFDR     [VFD] : Endif
If clalev([F:VCP])=0 : Local File VALCPY     [VCP] : Endif
If clalev([F:VFC])=0 : Local File VALFCY     [VFC] : Endif

If clalev([F:DCH2])=0 : Local File DECCHARGE  [DCH2] : Endif
If clalev([F:ORG2])=0 : Local File ORGANISME  [ORG2] : Endif
If clalev([F:CPY2])=0 : Local File COMPANY    [CPY2] : Endif
If clalev([F:ADI2])=0 : Local File ATABDIV    [ADI2] : Endif
If clalev([F:ORB])=0  : Local File ORGBAN    [ORB] : Endif

If clalev([F:HRXGD])=0  : Local File HRXITGRD [HRXGD]  : Endif
If clalev([F:HRCGD])=0 : Local File HRCTRGRD [HRCGD] : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Gosub DECLARATION From INITDCH

Gosub DECL_EFF
Local Integer NBFICHE
Local Char DEVISE (GLONCUR)
Local Char SYMBOLE (50)
Local Integer LIG, VAGF
Local Integer CAICOT (1..3)
Local Integer NBCAI , ICAI, ISEX

#Transport
Local Char INSEE (5)
Local Integer ITRS
Local Integer LIGTRS, LIGTAT

Local Char OLDCPY(GLONCPY)
Local Char VNUMAFF (50)
Local Char VNUMCTR (50)

Local Decimal QTY

Local Integer LASTMOIS
Local Char    VALPAR(10)

Local Date DATREF

Return

#############################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#############################
$EXEC
Local Char TIT (50)
TIT=mess(1,10714,1)
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN

CRITFCY="1=1"
If [M:DIA]ALLCPY<>2
 CRITFCY -= '& CPY="'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2
 CRITFCY -= '& FCY="'+[M:DIA]FCY+'"'
Endif

CRITDCH="1=1"
#Pas le transport
If [M:DIA]FLGTRS<>2 : CRITDCH-="& OPTSAL<>6 & OPTSAL<>7" : Endif

#Si toutes les sociétés : on ne traite que les société juridiques (pas les regroupements de sites)
If [M:DIA]ALLCPY=2
 Link [FGR] With
&   [CPY]CPY0 = [F:FGR]CPY
& , [FCY]FCY0 = [F:FGR]FCY
&   As [LNK]
&   Where [F:CPY]CPYLEGFLG=2 & evalue(CRITFCY)
Else
 Link [FGR] With
&  [FCY]FCY0 = [F:FGR]FCY
&   As [LNK]
&   Where  evalue(CRITFCY)
Endif

VDATDEB =[M:DIA]STRDAT
VDATFIN =[M:DIA]ENDDAT

SYMBOLE = "DUCS"+num$([M:DIA]CAI)+num$(VDATDEB)
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif

Call DEBTRANS From GLOCK
GOK = 1
Gosub TR1
Gosub ARRONDIR

Unlock =SYMBOLE
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

#############################
$TR1
Trbegin [DCS],[DCL],[DCT],[DCX]
Gosub CAI_REEL
Raz OLDCPY
For [F:LNK]
 OK=1
 If OLDCPY<>[F:FCY]LEGCPY
  OLDCPY=[F:FCY]LEGCPY
  Read[F:CPY2]CPY0=[F:FCY]LEGCPY
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(mess(42,10702,1)-":"- [F:FCY]LEGCPY-[F:CPY2]CPYNAM,0) From GESECRAN
  Gosub PARAM_GEN
 Endif
 If OK
  Gosub TR_INIT
  #Site :
  Call ECR_TRACE(mess(43,10702,1)-":"- [F:FCY]FCY-[F:FCY]FCYNAM,0) From GESECRAN
  Gosub TR_COMMUN
  Gosub TRACE_ORG
 Endif
Next
Commit
Return

########################################
$CAI_REEL
Raz CAICOT : NBCAI=1
Case [M:DIA]CAI
 When 1 : CAICOT(1)=GINDURS :#Urssaf
 When 2 : CAICOT(1)=GINDASS :#Assedic
 When 3 : CAICOT(1)=GINDPREV:#Prevoyance
 When 4 : CAICOT(1)=GINDARR :#Arrco
 When 5 : CAICOT(1)=GINDAGI :#Agirc
 When 6 : CAICOT(1)=GINDARR : CAICOT(2)=GINDAGI :#Arrco+Agirc
          NBCAI=2
 When 7 : CAICOT(1)=GINDARR : CAICOT(2)=GINDAGI : CAICOT(3)=GINDPREV  :#Arrco+Agirc+Prevoyance
          NBCAI=3
Endcase
Return


########################################
$TR_COMMUN
For ICAI=1 To NBCAI
 Gosub REINIT From INITDCH
 Filter [F:DCH] Where CAI=CAICOT(ICAI) & evalue(CRITDCH) Order By Key CLE= CAI;NUMORD
 For [F:DCH]CLE
  Gosub REINIT From INITDCH
  Gosub RECUP_RUB From INITDCH
  If OK =1
   Raz DATREF
   #87135: CICE
   Read[F:ADI]CODE=377;[F:DCH]CODDCS
   If !fstat | [F:DCH]CODDCS="" :#94707
    If [F:ADI]A2='400'
      Gosub TR_CICE
    Else
     For [F:VEP]VEP0(1) Where FCY=[F:FCY]FCY & STA>1 & PAYDAT>=VDATDEB & PAYDAT<=VDATFIN
      NBVEP=0
      MATRI=[F:VEP]EMP
      Read [ID]ID0=MATRI
      If [F:DCH]PEO<>"" : Read [AD]AD0=MATRI : Endif
      For [F:VEP]VEP0
       DATMAT=[F:VEP]ENDDAT
       CTR=[F:VEP]CTRNUM
       Gosub LECEMP From INITDCH
       DATREF=max(DATREF,[F:VEP]PAYDAT)
       FLAG=1 :  DREF=[F:VEP]PYRDAT
       Gosub CODEXO From INITDCH
       Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:VEP]CTRNUM,[L]ORGANISME,[F:DCH]CAI-1) From SUBORG
       If ([M:DIA]ORG<>"" & ORGANISME=[M:DIA]ORG ) | (ORGANISME<>"" & [M:DIA]ORG="")
        Gosub POPULATION From INITDCH
        If SALOK
         Gosub REINIT From INITDCH
         Gosub ORG_COURANT
         Case [F:DCH]CAI
          When GINDURS : Gosub TRAITE_URSSAF
          When GINDASS : Gosub TRAITE_ASSEDIC
          When GINDARR, GINDAGI, GINDPREV : Gosub TRAITE_IRCIP
         Endcase
        Endif
       Endif
      Next
     Next
    Endif
   Endif
  Endif
 Next
 Filter [F:DCH]
Next
Return

$ORG_COURANT
#par défaut
ORGCOURANT=ORGANISME
Read[F:ORG]ORG0=GCURLEG;ORGANISME
If !fstat & [F:ORG]TYPIRC>5
 I=0 : Raz [F:ORG2]
 While [F:ORG2]TYPIRC+1<>[F:DCH]CAI & I<[F:ORG]NBRLIG
  Read[F:ORG2]ORG0=GCURLEG;[F:ORG]GRPORG(I)
  If !fstat
   ORGCOURANT=[F:ORG]GRPORG(I)
  Endif
  I+=1
 Wend
Endif
Return

#########################################
$TR_CICE
Local Date DATDEBCICE
Local Decimal BASECICE, AMTCICE
Local Char DMA (2)
#92604: CICE applicable sur les bordereaux de type TR
#If [M:DIA]TYPFRM="BRV" | [M:DIA]TYPFRM="BRC"
 Raz DMA
 DMA=func AFNC.PARAM("DMA", [F:FCY]FCY)
 If DMA='' : DMA='12' : Endif
 If DMA='12'
  DATDEBCICE=gdat$(1,1,year(VDATFIN))
 Else
#   If month(VDATFIN)=val(DMA)+1
#    DATDEBCICE=gdat$(1,month(VDATFIN), year(VDATFIN))
#   Else
   DATDEBCICE=gdat$(1,val(DMA)+1,year(VDATFIN)-1)
#  Endif
 Endif
#92604 - Utilisation de la date de début de période de paie pour éviter de prendre en compte les bulletins de
#        novembre payés début décembre dans le cas du décalage de paie (01/12/N-1 au 30/11/N)
#For [F:VEP]VEP0(1) Where FCY=[F:FCY]FCY & STA>1 & PAYDAT>=DATDEBCICE & PAYDAT<=VDATFIN
 For [F:VEP]VEP0(1) Where FCY=[F:FCY]FCY & STA>1 & STRDAT>=DATDEBCICE & PAYDAT<=VDATFIN
  NBVEP=0
  MATRI=[F:VEP]EMP
  Read [ID]ID0=MATRI
  If [F:DCH]PEO<>"" : Read [AD]AD0=MATRI : Endif
  For [F:VEP]VEP0
   DATMAT=[F:VEP]ENDDAT
   CTR=[F:VEP]CTRNUM
   #63102 : Lectures inutiles = ralentissements
   #Gosub LECEMP From WPDEFTABLE
   Gosub LECEMP From INITDCH
   DATREF=max(DATREF,[F:VEP]PAYDAT)
   FLAG=1 :  DREF=[F:VEP]PYRDAT
   Gosub CODEXO From INITDCH
   Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:VEP]CTRNUM,[L]ORGANISME,[F:DCH]CAI-1) From SUBORG
   If ([M:DIA]ORG<>"" & ORGANISME=[M:DIA]ORG ) | (ORGANISME<>"" & [M:DIA]ORG="")
    Gosub POPULATION From INITDCH
    If SALOK
      Gosub REINIT From INITDCH
      Gosub ORG_COURANT
      Gosub TRAITE_URSSAF
    Endif
   Endif
  Next
 Next
#Endif
Return

#########################################
$TRACE_ORG
# X Organisme(s) traité(s)pour ce site
Call ECR_TRACE(num$(NBFICHE)-mess(3,10714,1),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
NBFICHE=0
Return

#########################################
$PARAM_GEN
OK=1
GCURLEG=[F:CPY2]LEG
#Recherche paramètrage exact
Read [F:DUC]DUC0=[M:DIA]CAI;[F:FCY]LEGCPY
If fstat & [M:DIA]CAI<3
 #Opération impossible - Paramétrage de la DUCS non défini
 Call ECR_TRACE(mess(4,10714,1)-":"-mess(2,45,1)-[F:FCY]LEGCPY,0) From GESECRAN
 OK=0  : Return
Elsif fstat & [M:DIA]CAI=3
 Filter [F:DUC] Where CPY=[F:FCY]LEGCPY & CAI=7
 Read [F:DUC]DUC0 First
 Filter [F:DUC]
 If fstat
  #Opération impossible - Paramétrage de la DUCS non défini
  Call ECR_TRACE(mess(4,10714,1)-":"-mess(2,45,1)-[F:FCY]LEGCPY,0) From GESECRAN
  OK=0  : Return
 Endif
Elsif fstat
 Filter [F:DUC] Where CPY=[F:FCY]LEGCPY & CAI>5
 Read [F:DUC]DUC0 First
 Filter [F:DUC]
 If fstat
  #Opération impossible - Paramétrage de la DUCS non défini
  Call ECR_TRACE(mess(4,10714,1)-":"-mess(2,45,1)-[F:FCY]LEGCPY,0) From GESECRAN
  OK=0  : Return
 Endif
Endif
Call PARAM([F:FCY]FCY,"DMA",VALPAR) From ADOVAL
If VALPAR="" | val(VALPAR)=0
 LASTMOIS=12
Else
 LASTMOIS=val(VALPAR)
Endif
If LASTMOIS=12
 VCOTDEB=VDATDEB
 VCOTFIN=VDATFIN
Else
 VCOTDEB=addmonth(VDATDEB,-1)
 VCOTFIN=eomonth(addmonth(VDATFIN,-1))
Endif
Return

#############################
#Suppression des données déjà existantes correspondant aux critères de l'extraction
$SUPPR_EXISTANT
Local Char CRITORG (100)
If [M:DIA]ORG<>"" :
 CRITORG="ORG=[M:DIA]ORG"
Else
 CRITORG="CAI=[M:DIA]CAI"
 Case [M:DIA]CAI
  When 3   : CRITORG-="| CAI=7"
  When 4,5 : CRITORG-="| CAI=6 | CAI=7"
  When 6   : CRITORG-="| CAI=4 | CAI=5 | CAI=7"
  When 7   : CRITORG-="| CAI=3 | CAI=4 | CAI=5 | CAI=6"
 Endcase
Endif
Delete[F:DCS] Where CPY=[F:FCY]LEGCPY & FCY=[F:FCY]FCY & STRDAT=VDATDEB & ENDDAT=VDATFIN & evalue(CRITORG)
Delete[F:DCL] Where CPY=[F:FCY]LEGCPY & FCY=[F:FCY]FCY & STRDAT=VDATDEB & ENDDAT=VDATFIN & evalue(CRITORG)
Delete[F:DCT] Where CPY=[F:FCY]LEGCPY & FCY=[F:FCY]FCY & STRDAT=VDATDEB & ENDDAT=VDATFIN & evalue(CRITORG)
Delete[F:DCX] Where CPY=[F:FCY]LEGCPY & FCY=[F:FCY]FCY & STRDAT=VDATDEB & ENDDAT=VDATFIN & evalue(CRITORG)
Delete[F:HRTDE] Where USR=GUSER & FCY=[F:FCY]FCY
Return

#Si pas de taux AT dans la fiche de param courante, on va chercher celui de sa fiche liée si il existe...
########################################
$AT_LNK
If !find(2,TAUX_AT(1..NRUB))
 Read[F:DCH2]DCH0=[F:DCH]DCHLNK
 If !fstat & find(2,[F:DCH2]ACCWRK(0..dim([F:DCH2]ACCWRK)-1))
  TAUXAT=0
  Read[F:WAC]WAC0=[F:HRCTR]RSKWRK
  If !fstat
   Filter [F:WAR] Where CODWAC=[F:WAC]CODWAC & DATWAC<=[F:VEP]PYRDAT
   Read [F:WAR]WAR0 Last
   Filter [F:WAR]
   If !fstat : TAUXAT=[F:WAR]RATWAC : Endif
  Endif
 Endif
Endif
Return

########################################
$TRAITE_URSSAF
If [F:DCH]DCHLNK<>"" : Gosub AT_LNK : Endif
For R=1 To NRUB
 Read[RUB]RUB0=GCURLEG;RUBCOD(R)
 If fstat : Break : Endif
 VDEBUT=0 : VFIN=0
 Case TYPECAL(R)
  When 1 : VDEBUT=1 : VFIN=1 : # PS
  When 2 : VDEBUT=2 : VFIN=2 : # PP
  When 3 : VDEBUT=1 : VFIN=2 : # PS+PP
 Endcase
 If VDEBUT
  Gosub RECUP_AT From INITDCH
  For I=VDEBUT To VFIN
   Read [HSP]HSP3=[F:VEP]BUL;RUBCOD(R);I
   If !fstat
    If FLGQTY(R)=2  :# Une quantité = Base
     QTY+=[F:HSP]BAS
    Else
     TAUX+=[F:HSP]RAT
     If I=1     :#salarial
      BASESAL=[F:HSP]BAS
     Else      :#patronal
      BASEPAT=[F:HSP]BAS
     Endif
     MONTANT+=[F:HSP]AMT
    Endif
    If [F:ADI]A2="400"
     AMTCICE+=[F:HSP]BAS
    Endif
   Endif
   Read [HSP]HSP3=[F:VEP]BUL;RUBCOD(R);I+6
   If !fstat & FLGQTY(R)<>2 :#pas une quantité
    MONTANT+=[F:HSP]AMT
    BASEREG+=[F:HSP]AMT
   Endif
  Next I
  LIMITE_BASE=0
  If [F:DCH]TYPBAS=2 :#cas particulier
   Gosub CAS_PART From INITDCH
  Endif
  Gosub AFFECT_BASE From INITDCH
  ###Régul non ventilée sur 2 lignes comme dans INITDCH*,donc ajout direct au montant si la base a changée (cas particulier)
  If LIMITE_BASE<>0
    MONTANT+=BASEREG
  ###Cas spécifique de déclenchement d'une fiche de paramétrage uniquement à cause d'une régul (sans cotisations).
  ### Il ne faut pas que les montants & taux soient cumulés mais il faut simplement prendre la régul seule.
  Elsif !BASE & BASEREG
    MONTANT=BASEREG
    TAUX=0
  Endif
  ###
  BASESAL=0 : BASEPAT=0
 Endif
Next R
If BASE+BASEREG<>0
 If [F:DCH]OPTSAL=6 | [F:DCH]OPTSAL=7
  Gosub TRANSPORT
 Else
  Read[F:ADI]CODE=10377;[F:DCH]CODDCS
  #Si on a demandé le transport on ne doit pas mettre les lignes de COT 900 & 901 !!!
  If !fstat & ([M:DIA]FLGTRS<>2 | ([M:DIA]FLGTRS=2 & [F:ADI]A2<>"900" & [F:ADI]A2<>"901"))
   If [F:ADI]A2="900" | [F:ADI]A2="901" : TAUXAT=TAUX : Endif
   Gosub LIGNES_URSSAF
  Endif
 Endif
Else
 TAUX=0
Endif
Return

########################################
$TRAITE_ASSEDIC
For R=1 To NRUB
 Read[RUB]RUB0=GCURLEG;RUBCOD(R)
 If fstat : Break : Endif
 Case TYPECAL(R)
  When 1 : VDEBUT=1 : VFIN=1 :#PS
  When 2 : VDEBUT=2 : VFIN=2 :#PP
  When 3 : VDEBUT=1 : VFIN=2 :#PS+PP
 Endcase
 For I=VDEBUT To VFIN
  Read [HSP]HSP3=[F:VEP]BUL;RUBCOD(R);I
  If !fstat
   TAUX+=[F:HSP]RAT
   If I=1     :#salarial
    BASESAL=[F:HSP]BAS
   Else      :#patronal
    BASEPAT=[F:HSP]BAS
   Endif
   MONTANT+=[F:HSP]AMT
  Endif
  Read [HSP]HSP3=[F:VEP]BUL;RUBCOD(R);I+6
  If !fstat
   MONTANT+=[F:HSP]AMT
   BASEREG+=[F:HSP]AMT
  Endif
 Next I
 LIMITE_BASE=0
 If [F:DCH]TYPBAS=2 :#cas particulier
  Gosub CAS_PART From INITDCH
 Endif
 Gosub AFFECT_BASE From INITDCH
  ###Régul non ventilée sur 2 lignes comme dans INITDCH*,donc ajout direct au montant si la base a changée (cas particulier)
  If LIMITE_BASE<>0 :  MONTANT+=BASEREG : Endif
  ###
 BASESAL=0 : BASEPAT=0
Next R
If BASE+BASEREG<>0
  Gosub ECRIT_LIGNES
Else
 TAUX=0
Endif
Return

########################################
$TRAITE_IRCIP
For R=1 To NRUB
 Read[RUB]RUB0=GCURLEG;RUBCOD(R)
 If fstat : Break : Endif
 Case TYPECAL(R)
  When 1 : VDEBUT=1 : VFIN=1 :#PS
  When 2 : VDEBUT=2 : VFIN=2 :#PP
  When 3 : VDEBUT=1 : VFIN=2 :#PS+PP
 Endcase
 For I=VDEBUT To VFIN
  Read [HSP]HSP3=[F:VEP]BUL;RUBCOD(R);I
  If !fstat
   TAUX+=[F:HSP]RAT
   If I=1  :#salarial
    BASESAL=[F:HSP]BAS
   Else
    BASEPAT=[F:HSP]BAS
   Endif
   MONTANT+=[F:HSP]AMT
  Endif
  Read [HSP]HSP3=[F:VEP]BUL;RUBCOD(R);I+6
  If !fstat
   MONTANT+=[F:HSP]AMT
   BASEREG+=[F:HSP]AMT
  Endif
 Next I
 LIMITE_BASE=0
 If [F:DCH]TYPBAS=2 :#cas particulier
  Gosub CAS_PART From INITDCH
 Endif
 Gosub AFFECT_BASE From INITDCH
  ###Régul non ventilée sur 2 lignes comme dans INITDCH*,donc ajout direct au montant si la base a changée (cas particulier)
  If LIMITE_BASE<>0 :  MONTANT+=BASEREG : Endif
  ###
 BASESAL=0 : BASEPAT=0
Next R
If BASE+BASEREG<>0
  Gosub ECRIT_LIGNES
Else
 TAUX=0
Endif
Return

####################################
$TRANSPORT
Gosub VALINSEE
If INSEE="" : Return : Endif
#87653 : Formatage pour avoir un code Insee sur 5 (Mettre des 0 devant)
If len(INSEE)<5
  INSEE=string$(5-len(INSEE), "0")+INSEE
Endif
ITRS=[F:DCH]OPTRAT-2
FLAG=0
Case [F:DCH]OPTSAL
When 6:
 Raz [F:DCT]
 For[F:DCT]DCT0 Where CPY=[F:FCY]LEGCPY & FCY=[F:FCY]FCY & ORG=ORGANISME & STRDAT=VDATDEB & ENDDAT=VDATFIN
  If [F:DCT]TRSCODSEE=INSEE & ([F:DCT]DCHRAT=[F:DCH]CODDCC | [F:DCT]DCHRAT=[F:DCH]DCHRAT)
   #Même code insee et taux nominal ou taux minoré lié au même taux nominal-> même ligne...
   FLAG=1
   [F:DCT]TRSRAT(ITRS)=TAUX
   [F:DCT]TRSBAS(ITRS)+=BASE
   Rewrite [F:DCT]
   If fstat<>0
    GOK = 0 : Call FSTA("DCT") From GLOCK : Break
   Endif
   Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
 If FLAG=0
  [F:DCT]CPY=[F:FCY]LEGCPY
  [F:DCT]FCY=[F:FCY]FCY
  [F:DCT]ORG=ORGANISME
  [F:DCT]STRDAT=VDATDEB
  [F:DCT]ENDDAT=VDATFIN
  [F:DCT]CAI=[M:DIA]CAI
  [F:DCT]TRSCODSEE=INSEE
  [F:DCT]TRSRAT(ITRS)=TAUX
  [F:DCT]TRSBAS(ITRS)=BASE
  LIGTRS+=1
  [F:DCT]NUMLIG=LIGTRS
  If [F:DCH]DCHRAT=""
   [F:DCT]DCHRAT=[F:DCH]CODDCC
  Else
   [F:DCT]DCHRAT=[F:DCH]DCHRAT
  Endif
  Write [F:DCT]
  If fstat<>0
   GOK = 0 : Call FSTA("DCT") From GLOCK : Return
  Endif
  If GOK<1 : Goto AB_TR1 : Endif
 Endif
When 7:
 Raz [F:DCX]
 For[F:DCX]DCX0 Where CPY=[F:FCY]LEGCPY & FCY=[F:FCY]FCY & ORG=ORGANISME & STRDAT=VDATDEB & ENDDAT=VDATFIN
  If [F:DCX]TATCODSEE=INSEE  & ([F:DCX]DCHRAT=[F:DCH]CODDCC | [F:DCX]DCHRAT=[F:DCH]DCHRAT)
   #Même code insee et même taux-> même ligne...
   FLAG=1
   [F:DCX]TATRAT(ITRS)=TAUX
   [F:DCX]TATBAS(ITRS)+=BASE
    Rewrite [F:DCX]
    If fstat<>0
     GOK = 0 : Call FSTA("DCX") From GLOCK : Break
    Endif
    Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
 If FLAG=0
  [F:DCX]CPY=[F:FCY]LEGCPY
  [F:DCX]FCY=[F:FCY]FCY
  [F:DCX]ORG=ORGANISME
  [F:DCX]STRDAT=VDATDEB
  [F:DCX]ENDDAT=VDATFIN
  [F:DCX]CAI=[M:DIA]CAI
  [F:DCX]TATCODSEE=INSEE
  [F:DCX]TATRAT(ITRS)=TAUX
  [F:DCX]TATBAS(ITRS)=BASE
  LIGTAT+=1
  [F:DCX]NUMLIG=LIGTAT
  If [F:DCH]DCHRAT=""
   [F:DCX]DCHRAT=[F:DCH]CODDCC
  Else
   [F:DCX]DCHRAT=[F:DCH]DCHRAT
  Endif
  Write [F:DCX]
  If fstat<>0
   GOK = 0 : Call FSTA("DCX") From GLOCK : Return
  Endif
  If GOK<1 : Goto AB_TR1 : Endif
 Endif
Endcase
BASE=0
TAUX=0
MONTANT=0
TAUXAT=0
QTY=0
Return

#############################
$VALINSEE
Raz INSEE

#87653: Gestion de l'alphanumérique pour le cas des Corses dans le code INSEE
If [F:DCH]FLGADD <> 2
  #Salarié
  Read [VLA]VLA0=4;"";"";"";[F:VEP]EMP;[F:VEP]PYRDAT;[F:DCH]CODVRA
  If !fstat & [F:VLA]VARVAL>0 : INSEE=num$(fix([F:VLA]VARVAL)) : Endif
  If INSEE<>"" : Return : Endif

  #Site
  #87653 : Add filter on FCY
  Filter [VFC] Where FCY=[F:FCY]FCY & DAT<=[F:VEP]PYRDAT
  Read [VFC]VFC0 Last
  If !fstat
   Read [VLA]VLA0=3;"";"";[F:FCY]FCY;"";[F:VFC]DAT;[F:DCH]CODVRA
   If !fstat & [F:VLA]VARVAL>0 : INSEE=num$(fix([F:VLA]VARVAL)) : Endif
  Endif
  If INSEE<>"" : Return : Endif

  #Société
  #87653 : Add filter on CPY
  Filter [VCP] Where CPY=[F:FCY]LEGCPY & DAT<=[F:VEP]PYRDAT
  Read [VCP]VCP0 Last
  If !fstat
   Read [VLA]VLA0=2;"";[F:FCY]LEGCPY;"";"";[F:VCP]DAT;[F:DCH]CODVRA
   If !fstat & [F:VLA]VARVAL>0 : INSEE=num$(fix([F:VLA]VARVAL)) : Endif
  Endif
  If INSEE<>"" : Return : Endif

  #Dossier
  Filter [VFD] Where DAT<=[F:VEP]PYRDAT
  Read [VFD]VFD0 Last
  If !fstat
   Read [VLA]VLA0=1;[F:VFD]LEG;"";"";"";[F:VFD]DAT;[F:DCH]CODVRA
   If !fstat & [F:VLA]VARVAL>0 : INSEE=num$(fix([F:VLA]VARVAL)) : Endif
  Endif
  If INSEE<>"" : Return : Endif

Else
#Site
  Filter [BPA] Where BPATYP=3 & BPANUM=[F:FCY]FCY & [BPA]BPAADDFLG=2
  Read [BPA]BPA0 First
  Filter [BPA]
  If !fstat : INSEE=[F:BPA]CODSEE : Endif
  If INSEE<>"" : Return : Endif

#Société
  Filter [BPA] Where BPATYP=2 & BPANUM=[F:FCY]LEGCPY & [BPA]BPAADDFLG=2
  Read [BPA]BPA0 First
  Filter [BPA]
  If !fstat : INSEE=[F:BPA]CODSEE : Endif
  If INSEE<>"" : Return : Endif
Endif
Return

#############################
$LIGNES_URSSAF
NBVEP+=1
GOK=1
Gosub ECRIT_ENTETES
If GOK<1 : Goto AB_TR1 : Endif
FLAG=0
Raz [F:DCL]

For[F:DCL]DCL0 Where CPY=[F:FCY]LEGCPY & FCY=[F:FCY]FCY & ORG=ORGANISME & STRDAT=VDATDEB & ENDDAT=VDATFIN & CODDCS=[F:DCH]CODDCS & RATWAC=TAUXAT
& & (CODDCH=[F:DCH]CODDCC |CODDCH=[F:DCH]DCHLNK)
  FLAG=1
  #Bases
  Read[F:ADI]CODE=10377;[F:DCH]CODDCS
  If fstat : Raz [F:ADI] : Endif
  #Générale (sauf cotisation transport)
  If [F:DCH]OPTSAL=1
   If [F:ADI]A2<>"900" & [F:ADI]A2<>"901"
    [F:DCL]AMT1+=BASE
    #Pas de taux pour Heures supp (Loi TEPA)
    #87135: Idem pour la loi Crédit d'Impôt pour la Compétitivité et l'Emploi (CICE)
    If [F:ADI]A2<>"003" & [F:ADI]A2<>"004" & [F:ADI]A2<>"005" & [F:ADI]A2<>"400"
     [F:DCL]RAT=TAUX
    Endif
   Else
    [F:DCL]AMT2+=BASE
   Endif
  #Salaire plafonné Urssaf ou Réduction Urssaf
  Else
   If [F:ADI]A2<>"003" & [F:ADI]A2<>"004" & [F:ADI]A2<>"005"
    [F:DCL]RAT2=TAUX
   Else
    [F:DCL]RAT2=100
   Endif
   ###Regul sur TEPA###
   If [F:ADI]A2="003" |[F:ADI]A2="004"| [F:ADI]A2="005": BASE+=BASEREG : Endif
   [F:DCL]AMT2+=BASE
  Endif
  #Quantité pour Heures supp (Loi TEPA)
  [F:DCL]QTY2+=QTY
  #Cotisations
  If [F:ADI]A2="003"
   If [F:DCL]AMT2>=0  : [F:DCL]AMT3=abs([F:DCL]AMT2)*-1 : Else  : [F:DCL]AMT3=abs([F:DCL]AMT2) : Endif
  #87135 : CICE
  Elsif [F:ADI]A2<>"400"
      [F:DCL]AMT3+=MONTANT
  Endif
  If [F:ADI]A2="400" & CODDCH=[F:DCH]CODDCC
   If NBVEP=1 & BASE>0
    [F:DCL]NBREMP1+=1
   Elsif BASE<0 & AMTCICE<=0
    [F:DCL]NBREMP1-=1
    NBVEP=0
   Endif
  Else
   If NBVEP=1 & CODDCH=[F:DCH]CODDCC
    [F:DCL]NBREMP1+=1
   Endif
  Endif
  #end 87135
  [F:DCL]PERDEB=min([F:VEP]STRDAT,[F:DCL]PERDEB)
  Rewrite [F:DCL]
  If fstat<>0
   GOK = 0 : Call FSTA("DCL") From GLOCK : Break
  Endif
  Break
Next
If GOK<1 : Goto AB_TR1 : Endif
If FLAG=0
 [F:DCL]CPY=[F:FCY]LEGCPY
 [F:DCL]FCY=[F:FCY]FCY
 [F:DCL]ORG=ORGANISME
 [F:DCL]CAI=[M:DIA]CAI
 [F:DCL]CAICOD=[F:DCH]CAI
 [F:DCL]ORGCOD=ORGCOURANT
 [F:DCL]STRDAT=VDATDEB
 [F:DCL]ENDDAT=VDATFIN
 [F:DCL]CODDCH=[F:DCH]CODDCC
 If [F:DCH]CODDCS <>""
  [F:DCL]CODDCS=[F:DCH]CODDCS
  [F:DCL]TYPDCS=0
 Else
  #Paramètrage XXX : Code DUCS non défini
  Call ECR_TRACE(mess(17,10714,1)-"'"+[F:DCH]CODDCC+"' :"-mess(10,10714,1),0) From GESECRAN
 Endif
 If [F:DCH]CODDCS2 <>""
  [F:DCL]CODDCS2=[F:DCH]CODDCS2
  [F:DCL]TYPDCS=0
 Else
  #Paramètrage XXX : Code DUCS non défini
  Call ECR_TRACE(mess(17,10714,1)-"'"+[F:DCH]CODDCC+"' :"-mess(11,10714,1),0) From GESECRAN
 Endif
 [F:DCL]LIBLIG=[F:DCH]DESEDT
 LIG+=1
 [F:DCL]NUMLIG=LIG
 #Bases
 Read[F:ADI]CODE=10377;[F:DCH]CODDCS
 If fstat : Raz [F:ADI] : Endif
 #Générale (sauf cotisation transport)
 If [F:DCH]OPTSAL=1
   If [F:ADI]A2<>"900" & [F:ADI]A2<>"901"
    [F:DCL]AMT1=BASE
    #87135: Idem pour la loi Crédit d'Impôt pour la Compétitivité et l'Emploi (CICE)
    If [F:ADI]A2<>"003" & [F:ADI]A2<>"004" & [F:ADI]A2<>"005" & [F:ADI]A2<>"400":  [F:DCL]RAT=TAUX :  Endif
   Else
    [F:DCL]AMT2=BASE
   Endif
  #Salaire plafonné Urssaf ou Réduction Urssaf
  Else
   If [F:ADI]A2<>"003" & [F:ADI]A2<>"004" & [F:ADI]A2<>"005"
    [F:DCL]RAT2=TAUX
   Else
    [F:DCL]RAT2=100
   Endif
   ###Regul sur TEPA###
   If [F:ADI]A2="003" |[F:ADI]A2="004"| [F:ADI]A2="005": BASE+=BASEREG : Endif
   [F:DCL]AMT2=BASE
  Endif
  #Quantité pour Heures supp (Loi TEPA)
  [F:DCL]QTY2=QTY
  #Cotisations
  If [F:ADI]A2="003"
   If [F:DCL]AMT2>=0  : [F:DCL]AMT3=abs([F:DCL]AMT2)*-1 : Else  : [F:DCL]AMT3=abs([F:DCL]AMT2) : Endif
  #87135 : Crédit d'impôt pour la compétitivité et l'emploi (CICE 400)
  Elsif [F:ADI]A2<>"400"
      [F:DCL]AMT3=MONTANT
  Endif
  #
 [F:DCL]RATWAC=TAUXAT
 #87135
 If [F:ADI]A2<>"400" | BASE>0
  [F:DCL]NBREMP1=1
 Endif
 #
 [F:DCL]PERDEB=[F:VEP]STRDAT
 Write [F:DCL]
 If fstat<>0
  GOK = 0 : Call FSTA("DCL") From GLOCK : Return
 Endif
 If GOK<1 : Goto AB_TR1 : Endif
Endif
BASE=0
TAUX=0
MONTANT=0
TAUXAT=0
QTY=0
Return

#############################
$ECRIT_LIGNES
NBVEP+=1
GOK=1
Gosub ECRIT_ENTETES
If GOK<1 : Goto AB_TR1 : Endif
FLAG=0
Raz [F:DCL]
For[F:DCL]DCL0 Where CPY=[F:FCY]LEGCPY & FCY=[F:FCY]FCY & ORG=ORGANISME & STRDAT=VDATDEB & ENDDAT=VDATFIN & CODDCH=[F:DCH]CODDCC
 If [F:DCL]RAT=TAUX & [F:DCL]RATWAC=TAUXAT
   #Même taux donc même ligne...
   FLAG=1
   #Bases
   If [F:DCH]CAI<3
    Read[F:ADI]CODE=10377;[F:DCH]CODDCS
    If fstat : Raz [F:ADI] : Endif
    If [F:DCH]OPTSAL=1 & [F:ADI]A2<>"900" & [F:ADI]A2<>"901"     :#Générale (sauf cotisation transport)
     [F:DCL]AMT1+=BASE
    Else                    :#Salaire plafonné Urssaf ou Réduction Urssaf ou Salaire Forfaitaire Assedic
     [F:DCL]AMT2+=BASE
    Endif
   Else
    #On n'alimente pas la base si forfait global.
    If [F:DCH]OPTSAL=1      :#Cotisations proportionnelles
     [F:DCL]AMT1+=BASE
    Elsif [F:DCH]OPTSAL=5   :#Forfait Unitaire
     #64379 : Notre plan de paie gère les forfaits de façon particulière car c'ets le taux qui contient la base !
     #[F:DCL]AMT2+=BASE
    Endif
   Endif
   #Cotisations
   [F:DCL]AMT3+=MONTANT
   #Effectif si pas ASSEDIC
   #Si le salarié a plusieurs payes on ne le compte qu'une fois.
   If NBVEP=1
    If [F:DCH]CAI=1
     [F:DCL]NBREMP1+=1
    Elsif [F:DCH]CAI>2
     Case [F:DCH]OPTSAL
        When 1 : [F:DCL]NBREMP1+=1       :#Nb Cotisant
        When 4 : [F:DCL]NBREMP2=1        :#Nb forfait global =1
        When 5 : [F:DCL]NBREMP2+=1       :#Nb forfait unitaire
     Endcase
    Endif
   Endif
   [F:DCL]PERDEB=min([F:VEP]STRDAT,[F:DCL]PERDEB)
   Rewrite [F:DCL]
   If fstat<>0
    GOK = 0 : Call FSTA("DCL") From GLOCK : Break
   Endif
   Break
 Endif
Next
If GOK<1 : Goto AB_TR1 : Endif
If FLAG=0
 [F:DCL]CPY=[F:FCY]LEGCPY
 [F:DCL]FCY=[F:FCY]FCY
 [F:DCL]ORG=ORGANISME
 [F:DCL]CAI=[M:DIA]CAI
 [F:DCL]CAICOD=[F:DCH]CAI
 [F:DCL]ORGCOD=ORGCOURANT
 [F:DCL]STRDAT=VDATDEB
 [F:DCL]ENDDAT=VDATFIN
 [F:DCL]CODDCH=[F:DCH]CODDCC
 [F:DCL]LIBREF1=[F:DCH]CODCPN
 [F:DCL]LIBREF2=[F:DCH]CODCSC
 If [F:DCH]CODDCS <>""
  [F:DCL]CODDCS=[F:DCH]CODDCS
  Read[ADI]CODE=10377;[F:DCH]CODDCS
  If (!fstat & [F:ADI]N1=912) | [F:DCH]FLGAGF=2  :#AGFF
   [F:DCL]TYPDCS=1
  Endif
 #
 Else
  #Paramètrage XXX : Code DUCS non défini
  Call ECR_TRACE(mess(17,10714,1)-"'"+[F:DCH]CODDCC+"' :"-mess(10,10714,1),0) From GESECRAN
 Endif
 If [F:DCH]CODDCS2 <>""
  [F:DCL]CODDCS2=[F:DCH]CODDCS2
   Read[ADI]CODE=10378;[F:DCH]CODDCS2
  If !fstat : Gosub CHR_TYP : Endif
 Else
  #Paramètrage XXX : Code DUCS non défini
  Call ECR_TRACE(mess(17,10714,1)-"'"+[F:DCH]CODDCC+"' :"-mess(11,10714,1),0) From GESECRAN
 Endif
 LIG+=1
 [F:DCL]LIBLIG=[F:DCH]DESEDT
 [F:DCL]NUMLIG=LIG
 #Bases
 If [F:DCH]CAI<3
  Read[F:ADI]CODE=10377;[F:DCH]CODDCS
  If fstat : Raz [F:ADI] : Endif
  If [F:DCH]OPTSAL=1 & [F:ADI]A2<>"900" & [F:ADI]A2<>"901"     :#Générale (sauf cotisation transport)
   [F:DCL]AMT1=BASE
   OLDLIG=LIG
  Else                    :#Salaire plafonné Urssaf ou Réduction Urssaf ou Salaire Forfaitaire Assedic
   [F:DCL]AMT2=BASE
  Endif
 Else
  #On n'alimente pas la base si forfait global.
  If [F:DCH]OPTSAL=1      :#Cotisations proportionnelles
   [F:DCL]AMT1=BASE
  Elsif [F:DCH]OPTSAL=5   :#Forfait Unitaire
   #Notre plan de paie gère les forfaits de façon particulière car c'est le taux qui contient la base !
   [F:DCL]AMT2=TAUX
  Endif
 Endif
 [F:DCL]RAT=TAUX
 [F:DCL]RATWAC=TAUXAT
 [F:DCL]AMT3=MONTANT
 #Effectif si pas ASSEDIC
 If [F:DCH]CAI=1
  [F:DCL]NBREMP1=1
 Elsif [F:DCH]CAI>2
  Case [F:DCH]OPTSAL
    When 1 : [F:DCL]NBREMP1=1        :#Nb Cotisant
    When 4 : [F:DCL]NBREMP2=1        :#Nb forfait global
    When 5 : [F:DCL]NBREMP2=1        :#Nb forfait unitaire
  Endcase
 Endif
 [F:DCL]PERDEB=[F:VEP]STRDAT
 Write [F:DCL]
 If fstat<>0
  GOK = 0 : Call FSTA("DCL") From GLOCK : Return
 Endif
 If GOK<1 : Goto AB_TR1 : Endif
Endif
BASE=0
TAUX=0
MONTANT=0
TAUXAT=0
Return

#############################
#Ajout test sur nouveau champ FLGAGF pour AGFF
$CHR_TYP
[F:DCL]TYPDCS=0
Case[F:DCL]CAICOD
 When GINDARR : #Arrco
  VAGF=val(right$([F:ADI]A2,1+len([F:ADI]A2)-2))
  If (VAGF>=30 & VAGF<=39) | [F:DCH]FLGAGF=2
   [F:DCL]TYPDCS=1
  Endif
 When GINDAGI :  #Agirc
  VAGF=val(right$([F:ADI]A2,1+len([F:ADI]A2)-2))
  If (VAGF>=30 & VAGF<=39) | [F:DCH]FLGAGF=2
   [F:DCL]TYPDCS=1
  Endif
 Endcase
Return

#############################
$ECRIT_ENTETES
GOK=1
Read[F:DCS]DCS0=[F:FCY]LEGCPY;[F:FCY]FCY;ORGANISME;VDATDEB;VDATFIN
If fstat<2
 If dim([F:DCS]UPDDAT)>0 : [F:DCS]UPDDAT = date$ : Endif
 If dim([F:DCS]UPDUSR)>0 : [F:DCS]UPDUSR = GUSER : Endif
 If dim([F:DCS]UPDTIM)>0 : [F:DCS]UPDTIM = time : Endif
 [F:DCS]FLGNEW = 2
 Rewrite [F:DCS]
 If fstat<>0
  GOK = 0 : Call FSTA("DCS") From GLOCK : Return
 Endif
Else
 NBFICHE+=1
 # ORGANISME - Extraction des cotisations pour la période du...
 Call ECR_TRACE(ORGANISME-mess(2,10714,1)-num$(VDATDEB)-num$(VDATFIN),0) From GESECRAN
 Raz[F:DCS]
 [F:DCS]CPY=[F:FCY]LEGCPY
 [F:DCS]FCY=[F:FCY]FCY
 [F:DCS]ORG=ORGANISME
 [F:DCS]CAI=[M:DIA]CAI
 [F:DCS]STRDAT=VDATDEB
 [F:DCS]ENDDAT=VDATFIN
 [F:DCS]STRCOT=VCOTDEB
 [F:DCS]ENDCOT=VCOTFIN
 [F:DCS]CUR=DEVISE
 #Effectif
 Read[F:HRTDE]TDE0=GUSER;[F:FCY]FCY;ORGANISME
 If !fstat : [F:DCS]=[F:HRTDE] : Endif
 If [F:DCH]CAI=GINDURS | [F:DCH]CAI=GINDASS
  If LASTMOIS=12
   [F:DCS]DATLIM=gdat$(5, month(VDATFIN)+1, year(VDATFIN))      :#5 du mois suivant
  Else
   If DATREF>gdat$(10, month(VDATFIN), year(VDATFIN))
    [F:DCS]DATLIM=gdat$(25, month(VDATFIN), year(VDATFIN))       :#25 du mois courant
   Else
    [F:DCS]DATLIM=gdat$(15, month(VDATFIN), year(VDATFIN))       :#15 du mois courant
   Endif
  Endif
  [F:DCS]DATOBG=[F:DCS]DATLIM
 Else
  [F:DCS]DATOBG=VDATFIN
  [F:DCS]DATLIM=VDATFIN+15
 Endif
 [F:DCS]DATPAYSAL=DATREF
 [F:DCS]ENDACT=1 :#fin d'activité
 [F:DCS]DATENDACT=[0/0/0] :#fin d'activité depuis le
 [F:DCS]NULEMP=1 :#plus d'employé
 [F:DCS]DATNULEMP=[0/0/0] :#plus d'employé depuis le
 [F:DCS]ENDCTR=1 :#arret definitif
 [F:DCS]EXCCTR=1 :#arret temporaire
 GPOINT = "INIDAT" : Gosub ENTREE From EXEFNC
 If GOK<1 : Return : Endif
 Call ORGAFFIL (ORGANISME,[F:VEP]FCY,"","",VNUMAFF,VNUMCTR) From SUBORA
 [F:DCS]NUMAFF=VNUMAFF
 [F:DCS]NUMCTR=VNUMCTR
 If dim([F:DCS]CREDAT)>0 : [F:DCS]CREDAT = date$ : Endif
 If dim([F:DCS]CREUSR)>0 : [F:DCS]CREUSR = GUSER : Endif
 If dim([F:DCS]CRETIM)>0 : [F:DCS]CRETIM = time : Endif
 [F:DCS]FLGNEW = 2
 Write [F:DCS]
 If fstat<>0
  GOK = 0 : Call FSTA("DCS") From GLOCK : Return
 Endif
Endif
Return

####################################
$AB_TR1
Rollback
Return

####################################
$ARRONDIR
Local Decimal OLDRAT, OLDWAC
Local Date OLDDAT
Local Char OLDCOD (GLONADI)

 For [F:DCS]DCS0 Where FLGNEW=2
 Raz [F:DCS]TOTAMT
 Raz [F:DCS]TOTREG

 Raz OLDRAT,OLDWAC,OLDDAT,OLDCOD

 For [F:DCL]DCL0 Where CPY=[F:DCS]CPY & FCY=[F:DCS]FCY & ORG=[F:DCS]ORG & STRDAT=[F:DCS]STRDAT & ENDDAT=[F:DCS]ENDDAT
  [F:DCL]AMT1=arr([F:DCL]AMT1,0.01)
  [F:DCL]AMT2=arr([F:DCL]AMT2,0.01)

  If [F:DCL]CAI=GINDURS
   Read[F:ADI]CODE=10377;[F:DCL]CODDCS
   If !fstat
    If [F:DCL]AMT2<0
     # Base des réduction doivent être positives...
     # Ajout code 673, 674 & 675 pour Exo ZFU
     # Ajout codes 462, 463 & 580 pour new reductions patronales
     If  ([F:ADI]A2="670" | [F:ADI]A2="671" | [F:ADI]A2="004" | [F:ADI]A2="005" | [F:ADI]A2="095"
&      |  [F:ADI]A2="673" | [F:ADI]A2="674" | [F:ADI]A2="675" | [F:ADI]A2="462" | [F:ADI]A2="463"
&      |  [F:ADI]A2="580" )
      [F:DCL]AMT2=abs([F:DCL]AMT2)
     Endif
    Else
     If [F:ADI]A2="671" | [F:ADI]A2="580"
      Case [F:ADI]A2
       When "671" : Filter [F:ADI] Where NUMTAB=10377 & A2="801"
                    Filter [F:ADI2] Where NUMTAB=10378 & A2="801"
       When "580" : Filter [F:ADI] Where NUMTAB=10377 & A2="570"
                    Filter [F:ADI2] Where NUMTAB=10378 & A2="570"
      Endcase
      # Code ducs EDI
      Read[F:ADI]CODE First
      Filter [F:ADI]
      If !fstat : [F:DCL]CODDCS=[F:ADI]CODE : Endif
      # Code ducs EDI
      Read[F:ADI2]CODE First
      Filter [F:ADI2]
      If !fstat : [F:DCL]CODDCS2=[F:ADI2]CODE : Endif
     Endif
    Endif

    #79274 : Fin de validité 2012
    If [F:DCL]STRDAT<=gdat$(31,12,2011)
     #Si FNAL deplafonné negatif en 236 alors créer une ligne en code 568.
     If [F:ADI]A2="236" & [F:DCL]AMT1<0
      Gosub ADD_LINE568
      Default File [F:DCL]
      If GOK
       Raz[F:DCL]AMT1
       Raz[F:DCL]RAT
       [F:DCL]AMT3=[F:DCL]AMT2*[F:DCL]RAT2/100
      Endif
     Endif
    Endif
   Endif
  Endif

  [F:DCS]TOTAMT+= [F:DCL]AMT3
  [F:DCL]AMT3=arr([F:DCL]AMT3,0.01)

  #La date est un critère de regroupement à la génération donc si même code & meêms taux -> modif pour même date
  If OLDCOD<>""
   If OLDCOD=[F:DCL]CODDCS &  OLDRAT=[F:DCL]RAT &  OLDWAC=[F:DCL]RATWAC
    [F:DCL]PERDEB=OLDDAT
   Endif
  Endif
  OLDCOD=[F:DCL]CODDCS
  OLDRAT=[F:DCL]RAT
  OLDWAC=[F:DCL]RATWAC
  OLDDAT=[F:DCL]PERDEB
  #

  Rewrite [F:DCL]
  If fstat<>0
   GOK = 0 : Call FSTA("DCL") From GLOCK : Break 2
  Endif
 Next
 [F:DCS]TOTAMT=arr([F:DCS]TOTAMT,0.01)
 [F:DCS]TOTREG=arr([F:DCS]TOTREG,0.01)
 [F:DCS]TOTMSS=arr([F:DCS]TOTMSS,0.01)
 [F:DCS]TOTBRT=arr([F:DCS]TOTBRT,0.01)
 [F:DCS]FLGNEW = 1
 Rewrite [F:DCS]
 If fstat<>0
  GOK = 0 : Call FSTA("DCS") From GLOCK : Break
 Endif
Next
Return

###########################
#Si FNAL deplafonné negatif en 236 alors créer une ligne en code 568.
$ADD_LINE568
If clalev([F:DCL2])=0 : Local File DUCS1      [DCL2] : Endif
GOK=1
Raz[F:DCL2]
[F:DCL2]=[F:DCL]
[F:DCL2]NUMLIG=[F:DCL]NUMLIG*100
Filter [F:ADI] Where NUMTAB=10377 & A2="568"
Read[F:ADI]CODE First
Filter [F:ADI]
If !fstat : [F:DCL2]CODDCS=[F:ADI]CODE : Endif
Filter [F:ADI] Where NUMTAB=10378 & A2="568"
Read[F:ADI]CODE First
Filter [F:ADI]
If !fstat : [F:DCL2]CODDCS2=[F:ADI]CODE : Endif
[F:DCL2]AMT3=arr(([F:DCL2]AMT1*[F:DCL2]RAT/100),0.01)
[F:DCL2]AMT1=[F:DCL2]AMT3
[F:DCL2]RAT =100
Raz [F:DCL2]AMT2
Raz [F:DCL2]RAT2
Write [F:DCL2]
If fstat<>0
 GOK = 0 : Call FSTA("DCL") From GLOCK
Endif
[F:DCS]TOTAMT+= [F:DCL2]AMT3
Return

##################################################################################################################
#                                                EFFECTIF                                                        #
##################################################################################################################

#############################
$DECL_EFF
If clalev([F:HRTDE])=0  : Local File TMPDUCSEFF [HRTDE] : Endif
#Effectif ventilé
Local Integer TYPCAI
Local Char NUMBORD (5)
Local Integer VALSAL
Local Integer INDCAI, INDCAI2, ICAISSE
Local Char OLDORG (GLONORG)
Local Char OLDFCY (GLONFCY)
Return

########################################
$TR_INIT
DEVISE=[F:CPY2]ACCCUR
LIG=0 : LIGTRS=0 : LIGTAT=0
Gosub SUPPR_EXISTANT
TYPCAI=[M:DIA]CAI
If !TYPCAI : Return : Endif
Gosub RECUP_BORD From TRTDCS
If !GOK : Return : Endif

##**96938
#Salariés présents sur la période
Filter [HRCTR] Where ETRFCY=[F:FCY]FCY & CTRDAT<=VCOTFIN & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=VCOTDEB)
For [HRCTR]CTR0 (1)
 Read [F:ID]ID0=[F:HRCTR]REFNUM
 For [HRCTR]CTR0
  Gosub CTRL_EFF
  If !GOK : Break 2 : Endif
  If VALSAL=1 : Break : Endif        :#compté donc on change de salarié
 Next
Next
Filter [HRCTR] 
#**

If GOK<1 : Goto AB_TR1 : Endif
Return

########################################
$CTRL_EFF
OK=0
VALSAL=1
INDCAI=TYPCAI : INDCAI2=TYPCAI
Case TYPCAI
 When 1 :
  Gosub EXCLU_BRC
  If NUMBORD="915" | NUMBORD="916" : Gosub EXCLU_TR : Endif
 When 2 :
  Gosub EXCLU_ADV
  If NUMBORD="922" | NUMBORD="923" : Gosub EXCLU_DRA : Endif
 When 3,4,5 : INDCAI=TYPCAI+1 : INDCAI2=TYPCAI+1 : OK=1
 When 6     : INDCAI=GINDARR  : INDCAI2=GINDAGI  : OK=1
 When 7     : INDCAI=GINDPREV : INDCAI2=GINDAGI  : OK=1
Endcase

If OK
 #Si le salarié doit être compter dans l'effectif-> stokage de son matricule...
 #Nb de salariés inscrits par site/organisme
 OLDORG=""
 For ICAISSE=INDCAI To INDCAI2
  Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:HRCTR]CTRNUM,[L]ORGANISME,ICAISSE-1) From SUBORG
  #Pour ne pas compter n fois le même salarié quand INDCAI <>INDCAI2
  If OLDORG<>ORGANISME
   Gosub ADD_EMP
   If !GOK : Break : Endif
   OLDORG=ORGANISME
  Endif
 Next
 If GOK<1 : Return : Endif
Endif
Return


#Exclusion commune aux BRC et TR de l'Urssaf
#********BRC : Attention normalement les sorties en cours de mois sont a exclure du nb d'inscrits mais pas du nb de rémunérés !!!****
####################################
$EXCLU_BRC
OK=0
# Exclu les stagiaires
# Exclu les VRP Multi-cartes
Case [F:HRCTR]CATJOB
 When "STD","STN","STR","RMU" : Return
Endcase
# Exclu les apprentis
# Exclu les intérimaires
Case [F:HRCTR]NATCON
 When "CAM","CAP","CTT": Return
Endcase
# Exclu les autres stagiaires
If [F:HRCTR]PROPRF="009" : Return : Endif
# Exclu les autres intérimaires
If [F:HRCTR]TYPJOB=3 : Return : Endif
# Exclu les salariés percevant des sommes après la rupture de leur contrat de travail (Code="VAR")
Read[F:HRCGD]HRCGD0=[F:HRCTR]CTRGRD;GCURLEG#Read[F:ADI]CODE=10386;[F:HRCTR]CTRGRD
If fstat | [F:HRCGD]CODN4H="095" : Return : Endif#If fstat | [F:ADI]A1="095" : Return : Endif
# Exclu les salariés déclarés au moyen des nouveaux dispositifs :
# Chèque emploi très petites entreprises
# Titre emploi entreprise occasionnels ou Chèque emploi associatif.
# Exclu les salariés régulièrement détachés en France en vertu de conventions ou de règlements internationaux
# --------->Pas géré dans SPRH
OK=1
Return

####################################
$EXCLU_TR
OK=0
#Exclu les salariés sorties avant la fin de période pour toutes les déclarations
#sauf si le motif de sortie n'est pas rattaché à un code TDS (Ex : mutation inter-service pour historique)
If [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT<=VDATFIN
 Call SIMPLEREAD([F:HRCTR]XITGRD,GCURLEG,GERRHRM) From SUBHRXGD
 If GERRHRM | [F:HRXGD]CODN4H<>"" : Return : Endif
Endif

# Exclu les autres contrats
Case [F:HRCTR]NATCON
 When "CPI","CPR","CDA","CDO","CNE","CEJ","CJ2","CIE","CII","CAE","CAV","CES","CIR","CID" : Return
Endcase
#Proratistion TP
If [F:HRCTR]TYPJOB=2 : VALSAL=[F:HRCTR]RATMIDWRK/100 : Endif
OK=1
Return

#Exclusion commune aux ADV et DRA de l'Assedic
####################################
$EXCLU_ADV
OK=0
#Exclu les salariés sorties avant la fin de période pour toutes les déclarations
#sauf si le motif de sortie n'est pas rattaché à un code TDS (Ex : mutation inter-service pour historique)
If [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT<=VDATFIN
 Call SIMPLEREAD([F:HRCTR]XITGRD,GCURLEG,GERRHRM) From SUBHRXGD
 If GERRHRM | [F:HRXGD]CODN4H<>"" : Return : Endif
Endif
# Exclu les stagiaires
Case [F:HRCTR]CATJOB
 When "STD","STN","STR": Return
Endcase
# Exclu les intérimaires
Case [F:HRCTR]NATCON
 When "CTT": Return
Endcase
# Exclu les autres stagiaires
If [F:HRCTR]PROPRF="009" : Return : Endif
# Exclu les autres intérimaires
If [F:HRCTR]TYPJOB=3 : Return : Endif
# Exclu les salariés percevant des sommes après la rupture de leur contrat de travail (Code="VAR")
Read[F:HRCGD]HRCGD0=[F:HRCTR]CTRGRD;GCURLEG#Read[F:ADI]CODE=10386;[F:HRCTR]CTRGRD
If fstat | [F:HRCGD]CODN4H="095" : Return : Endif#If fstat | [F:ADI]A1="095" : Return : Endif
# Exclu les salariés déclarés au moyen des nouveaux dispositifs :
# Chèque emploi très petites entreprises
# Titre emploi entreprise occasionnels ou Chèque emploi associatif.
# Exclu les salariés régulièrement détachés en France en vertu de conventions ou de règlements internationaux
# --------->Pas géré dans SPRH
#On proratise les TP < 8 heures/semaine
If val(func AFNC.PARAM("HOUWEKLEG",[F:HRCTR]ETRFCY))<>0
 If [F:HRCTR]TYPJOB=2 & [F:HRCTR]RATMIDWRK<((8*100)/val(func AFNC.PARAM("HOUWEKLEG",[F:HRCTR]ETRFCY)))
  VALSAL=[F:HRCTR]RATMIDWRK/100
 Endif
Endif
OK=1
Return

####################################
$EXCLU_DRA
OK=0
# Exclu les congès sans solde (Conversion, sabatique, parental..)
If [F:HRCTR]XITLEA<>"" : Return : Endif
OK=1
Return

###########################
$ADD_EMP
Readlock[F:HRTDE]TDE0=GUSER;[F:FCY]FCY;ORGANISME
If fstat=5
 Raz[F:HRTDE]
 [F:HRTDE]FCY=[F:FCY]FCY
 [F:HRTDE]ORG=ORGANISME
 [F:HRTDE]USR=GUSER
 Gosub AFFECT_EMP
 Write [HRTDE]
Elsif !fstat
 Gosub AFFECT_EMP
 Rewrite [HRTDE]
Endif
If fstat<>0
 GOK = 0 : Call FSTA("HRTDE") From GLOCK
Endif
Return

###########################
$AFFECT_EMP
#Nb H/F
If [F:ID]SEX=1
 [F:HRTDE]NBRMEN+=VALSAL
Else
 [F:HRTDE]NBRWOM+=VALSAL
Endif

#Nb inscrits
#Exclu des inscrits sorties en cours de période (non fait en amont dans le BRC car ils doivent compter dans les rémunérés...)
#sauf si le motif de sortie n'est pas rattaché à un code TDS (Ex : mutation inter-service pour historique)
If [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>VDATFIN
 [F:HRTDE]NBREMPMRK+=VALSAL
Else
 Call SIMPLEREAD([F:HRCTR]XITGRD,GCURLEG,GERRHRM) From SUBHRXGD
 If !GERRHRM & [F:HRXGD]CODN4H=""
  [F:HRTDE]NBREMPMRK+=VALSAL
 Endif
Endif

#Nb rémunérés = ayant au moins une paie calculée sur la période
Filter [F:VEP] Where EMP=[F:HRCTR]REFNUM & FCY=[F:FCY]FCY & CTRNUM=[F:HRCTR]CTRNUM & STRDAT<=VCOTFIN & ENDDAT>=VCOTDEB & STA>1
Read[F:VEP]VEP0 First
Filter [F:VEP]
If !fstat : [F:HRTDE]NBREMPPAY+=VALSAL : Endif

#Uniquement pour les DRA
If NUMBORD="922" | NUMBORD="923"
 #ventilation par contrat (Salariés de - de 65 ans)
 Case [F:HRCTR]NATCON
  When "CDD","CDA","CDO","CDQ","CID","CIE","CPR","CRE","CEJ","CJ2","CES"
   If [F:ID]DATBRN>=addmonth(VDATFIN,-65*12)
    If [F:ID]SEX=1 : [F:HRTDE]NBRCDD(0)+=VALSAL : Else : [F:HRTDE]NBRCDD(1)+=VALSAL : Endif
   Endif
  When "CDI","CII","CIR","CJE","CPI":
   If [F:ID]DATBRN>=addmonth(VDATFIN,-65*12)
    If [F:ID]SEX=1 : [F:HRTDE]NBRCDI(0)+=VALSAL : Else : [F:HRTDE]NBRCDI(1)+=VALSAL : Endif
   Endif
  When "CAM","CAP"
   If [F:ID]DATBRN>=addmonth(VDATFIN,-65*12)
     If [F:ID]SEX=1 : [F:HRTDE]NBRAPP(0)+=VALSAL : Else : [F:HRTDE]NBRAPP(1)+=VALSAL : Endif
   Endif
  # Ancien CES= CAE & CAV depuis le 01/01/05
  When "CES","CAE","CAV"
    If [F:ID]SEX=1 : [F:HRTDE]NBRCES(0)+=VALSAL : Else : [F:HRTDE]NBRCES(1)+=VALSAL : Endif
  When "CNE"
    If [F:ID]SEX=1 : [F:HRTDE]NBRCNE(0)+=VALSAL : Else : [F:HRTDE]NBRCNE(1)+=VALSAL : Endif
 Endcase
 If [F:ID]DATBRN>=addmonth(VDATFIN,-65*12)
 #Appartient à la direction (Salariés de - de 65 ans)
  Case[F:HRCTR]CATJOB
   When "DIR","GMS","GME","PDG","DGS","PDH","DGT" :
    If [F:ID]SEX=1 : [F:HRTDE]NBRDIR(0) +=VALSAL : Else : [F:HRTDE]NBRDIR(1)+=VALSAL : Endif
  Endcase
 Else
  #Salariés 65 ans et +
  If [F:ID]SEX=1 : [F:HRTDE]NBROLD(0) +=VALSAL : Else : [F:HRTDE]NBROLD(1)+=VALSAL : Endif
 Endif
Endif
Return

###########################
$SORTIE
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

################################################################################
#                         Etiquettes [M:DIA]
################################################################################

Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
Call AS_ALLCPY(VALEUR)From DIVPAYE
End

########################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR)From DIVPAYE
End

########################################
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Call AS_CPY(VALEUR)From DIVPAYE
End

########################################
Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
Call AS_ALLFCY(VALEUR)From DIVPAYE
End

########################################
Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR)From DIVPAYE
End

########################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR)From DIVPAYE
End

########################################
Subprog C_ORG(VALEUR)
Variable Char    VALEUR()
Call C_ORG(VALEUR)From TRTDCS
End

########################################
Subprog C_FLGTRS(VALEUR)
Variable Integer VALEUR
If [M:DIA]CAI<>1 : Effzo [M:DIA]FLGTRS : Grizo [M:DIA]FLGTRS : Else : Actzo  [M:DIA]FLGTRS : Endif
End

########################################
Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
Call AS_STRDAT(VALEUR)From TRTDCS
End

########################################
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
Call AS_ENDDAT(VALEUR)From TRTDCS
End

########################################
Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE
End

########################################
$GRISE
If dim([M:DCS0]CAI)>=0
 [M:DIA]CAI=[M:DCS0]CAI
 If[M:DCS0]CAI=1
  [M:DIA]NUMADI=374
 Elsif [M:DCS0]CAI=2
  [M:DIA]NUMADI=375
 Else
  [M:DIA]NUMADI=376
 Endif
 [M:DIA]ALLCPY=1
 [M:DIA]CPY=[M:DCS0]CPY
 [M:DIA]ALLFCY=1
 [M:DIA]FCY=[M:DCS0]FCY
 [M:DIA]ALLORG=1
 [M:DIA]ORG=[M:DCS0]ORG
 [M:DIA]STRDAT=[M:DCS0]STRDAT
 [M:DIA]ENDDAT=[M:DCS0]ENDDAT
 Affzo [M:DIA]CAI,ALLCPY,CPY,ALLFCY,FCY,ALLORG,ORG,STRDAT,ENDDAT
Else
 Gosub GRISE From DIVPAYE
 If [M]ALLORG=2 : Diszo ORG : Else : Actzo ORG : Endif
Endif
If [M:DIA]CAI<>1 : Effzo FLGTRS : Grizo FLGTRS : Else : Actzo FLGTRS : Endif
End

########################################
Subprog AM_CAI(VALEUR)
Variable Integer VALEUR
Call AM_CAI(VALEUR) From TRTDCS
If VALEUR<>1 : Effzo FLGTRS : Grizo FLGTRS : Else : Actzo FLGTRS : Endif
End

########################################
Subprog C_ALLORG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo ORG : Diszo ORG
Else
 Actzo ORG
Endif
End

########################################
Subprog AS_ORG(VALEUR)
Variable Char    VALEUR()
If [M]ALLORG = 2 : mkstat = 1 : End : Endif
End

########################################
Subprog AS_TYPFRM(VALEUR)
Variable Char    VALEUR()
Call AS_TYPFRM(VALEUR)From TRTDCS
End

########################################
Subprog AM_TYPFRM(VALEUR)
Variable Char    VALEUR()
[M:DIA]TYPFRM=VALEUR
End

