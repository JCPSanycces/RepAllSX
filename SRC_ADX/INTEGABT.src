#<AdxTL>@(#)8.0.0.0 $Revision$
#######################################################################
## INTEGABT  Intégration des Serveur batch (Tâches)
#######################################################################
$INTEG
Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
Call ECR_TRACE("Mise à jour des Serveur batch (Tâches)",0) From GESECRAN

Gosub OUVRE

For [SABT]CODTAC Where CODTAC<GXX
 OBJET = [F:SABT]CODTAC
 OKCOP = 1
 Call OKCOP([F:SABT]MODULE,"",OKCOP) From INTEGSUB
 If OKCOP
  Call ECR_TRACE(mess(77,145,1)-"ABT"-OBJET,0) From GESECRAN
  Gosub COPIE
 Else
  Call ECR_TRACE(mess(78,145,1)-"ABT"-OBJET,0) From GESECRAN
 Endif
Next

For [ABT]CODTAC Where MODULE=1 & CODTAC<GXX
 OBJET = [F:ABT]CODTAC
 Read [SABT]CODTAC = [F:ABT]CODTAC
 Call OKSUP(PRODUIT,fstat,"",[F:SABT]MODULE,"",OKSUP) From INTEGSUB
 If OKSUP
  Gosub SUPPRIME
 Endif
Next

Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
Gosub FERME
Return

#-------------------------------------------------------------#
$OUVRE
Local File ABATTAC [SABT]
Local File ATEXTE  [SATX]
Local File ACTIV   [SACV]
Local File =DOSSIER+".ABATTAC"  [ABT]
Local File =DOSSIER+".ATEXTE"   [ATX]
Local File =DOSSIER+".ACTIV"    [ACV]
Return

$FERME
Close Local File [SABT] , [SATX] , [SACV]
Close Local File [ABT]  , [ATX]  , [ACV]
Return

#-------------------------------------------------------------#
$COPIE
If TEST : Return : Endif
Read [ABT]CODTAC= OBJET
If !fstat
 Call VERF_MODULE([F:SABT]MODULE,[F:ABT]MODULE,TYPPRO,OKCOP) From INTEGSUB
Endif
If !OKCOP
 Call ECR_TRACE(func AFNC.MES2(mess(76,145,1),"ABT"-OBJET,LIBMOD([F:ABT]MODULE)),1) From GESECRAN
 Return
Endif
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [ABT]
 Read [ABT]CODTAC= OBJET
 If fstat
  Gosub TETE
  If GOK<1 : Goto AB_TR1 : Endif
  Write [ABT]
 Else
  Gosub TETE
  If GOK<1 : Goto AB_TR1 : Endif
  Rewrite [ABT]
 Endif
 If fstat
  GOK = 0 : Call FSTA("ABT") From GLOCK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#-------------------------------------------------------------#
$TETE
[F:ABT] = [F:SABT]
Call MODULE([F:SABT]MODULE,TYPPRO,[F:ABT]MODULE) From INTEGSUB
Call TEXTE(DOSSIER,[F:ABT]DES) From INTEGSUB
Return

#-------------------------------------------------------------#
$SUPPRIME
Call ECR_TRACE(mess(2,24,1)-"ABT"-OBJET,0) From GESECRAN
If TEST : Return : Endif
Call DEBTRANS From GLOCK
Gosub TR2
Return

$TR2
GOK = 1
Trbegin [ABT]
 Delete [ABT] Where CODTAC=OBJET
 If fstat=1
  GOK = -1 : GLOCK = "$ABATTAC"-OBJET : Goto ROLL_TR2
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

