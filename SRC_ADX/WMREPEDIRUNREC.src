#<AdxTL>@(#)0.0.0.0 $Revision$Class EDI inbound msg. generation
# Supervisor
## WMREP REPRESENTATION ## EDIRUNREC
# 2018-10-17 07:54:27 056

#-------------------------------------------------------#
$TEST2
Local Instance EDIRUNREC Using R_EDIRUNREC
EDIRUNREC = NewInstance R_EDIRUNREC AllocGroup null
Call ALOAD_LINKS_DET_PAGE(EDIRUNREC)
Infbox 'OK'
FreeGroup EDIRUNREC
End

#-------------------------------------------------------#
$TEST
Local Instance REP Using C_AREPENT
Call DESCRIPTION_REPRESENTATION(REP,"TEST")
Infbox 'OK'
FreeGroup REP
End

#-------------------------------------------------------#
Subprog DESCRIPTION_REPRESENTATION(REP,GRPINS)
Variable Instance REP Using C_AREPENT
Gosub DESCRIPTION
End

#-------------------------------------------------------#
$DESCRIPTION
Gosub HEAD_REP
Gosub SECTION_REP
Gosub LINK_REP
Gosub COLLECTIONS_REP
Gosub PROPERTY_REP From WMREP1EDIRUNREC
Return

#-------------------------------------------------------#
# Entete
#-------------------------------------------------------#
$HEAD_REP
REP = NewInstance =[L]GRPINS , C_AREPENT
REP.REP = "EDIRUNREC"
REP.CLA = "EDIRUN"
REP.ICL = "EDR"
REP.AFCRIGHT = "EDIRUNREC"
REP.NCL = 52222 : # Process launch
REP.DES = 52317 : # EDI inbound msg. generation
REP.TIT = ""
REP.ANX = "EDR0"
REP.CLE(1) = NewInstance C_AREPPAR AllocGroup REP : # Process number
     REP.CLE(1).PAR = 'NUM' : REP.CLE(1).TYP = 2 : REP.CLE(1).PRO= 'NUM' : REP.CLE(1).VPR= 'EDR.NUM' : REP.CLE(1).DES = 41947
REP.TRT(1) = NewInstance C_AREPTRT AllocGroup REP
     REP.TRT(1).TRT = 'EDIRUNREC_RSTD' : REP.TRT(1).TYP = 1
# Facets
REP.AENAFAC(1) = 2 : # Detail
REP.AENAFAC(2) = 2 : # Edit
REP.AENAFAC(3) = 2 : # Query
REP.AENAFAC(4) = 2 : # Lookup
REP.AENAFAC(5) = 2 : # Summary
Return

#-------------------------------------------------------#
# Section de la représentation
#-------------------------------------------------------#
$SECTION_REP
REP.SEC(1) = NewInstance C_AREPSEC AllocGroup REP
     REP.SEC(1).SEC = "HEADER" : REP.SEC(1).NSC = 3563 : # Identification
     REP.SEC(1).BLC(1)="HEADER" : REP.SEC(1).NBC(1)=3563 : # Identification
REP.SEC(2) = NewInstance C_AREPSEC AllocGroup REP
     REP.SEC(2).SEC = "PARAMETERS" : REP.SEC(2).NSC = 881 : # Parameters
     REP.SEC(2).BLC(1)="PARTNER" : REP.SEC(2).NBC(1)=52054 : # EDI partner
     REP.SEC(2).BLC(2)="CATEGORY" : REP.SEC(2).NBC(2)=707 : # Category
     REP.SEC(2).BLC(3)="FLOW" : REP.SEC(2).NBC(3)=24916 : # Flow
     REP.SEC(2).BLC(4)="PARAMETERS" : REP.SEC(2).NBC(4)=881 : # Parameters
Return

#-------------------------------------------------------#
# Liens de la représentation
#-------------------------------------------------------#
$LINK_REP
REP.LNK(1) = NewInstance C_AREPLNK AllocGroup REP : # Save
     Call ASET_AREPLNK(REP.LNK(1),'$save',1,'','',17,'EDIRUNREC',12413,4,'','',1,2,1,1,1) From ASYRSUBREP
     REP.LNK(1).ATT(1)= NewInstance C_AREPATT AllocGroup REP
          REP.LNK(1).ATT(1).COD = "$isHidden" : REP.LNK(1).ATT(1).ATT = "true"
     REP.LNK(1).ATT(2)= NewInstance C_AREPATT AllocGroup REP
          REP.LNK(1).ATT(2).COD = "$isDisabled" : REP.LNK(1).ATT(2).ATT = "false"
     REP.LNK(1).LNK(1) = NewInstance C_AREPLNK AllocGroup REP : # List
          Call ASET_AREPLNK(REP.LNK(1).LNK(1),'$query',1,'','EDIRUN',5,'EDIRUNREC',49616,4,'','',2,2,1,1,1) From ASYRSUBREP
     
     REP.LNK(1).LNK(2) = NewInstance C_AREPLNK AllocGroup REP : # Display
          Call ASET_AREPLNK(REP.LNK(1).LNK(2),'$details',1,'','EDIRUN',2,'EDIRUNREC',49838,4,'','',1,2,2,1,1) From ASYRSUBREP
          REP.LNK(1).LNK(2).CLE(1)  = NewInstance C_AREPPAR AllocGroup REP
               Call ASET_AREPPAR(REP.LNK(1).LNK(2).CLE(1),'NUM',2,'EDR.NUM','NUM',0,0,0,0,'NUM',1,1) From ASYRSUBREP
     
     REP.LNK(1).LNK(3) = NewInstance C_AREPLNK AllocGroup REP : # Edit
          Call ASET_AREPLNK(REP.LNK(1).LNK(3),'$edit',1,'','EDIRUN',3,'EDIRUNREC',12964,4,'','',2,2,1,1,1) From ASYRSUBREP
          REP.LNK(1).LNK(3).CLE(1)  = NewInstance C_AREPPAR AllocGroup REP
               Call ASET_AREPPAR(REP.LNK(1).LNK(3).CLE(1),'NUM',2,'EDR.NUM','NUM',0,0,0,0,'NUM',1,1) From ASYRSUBREP
     

REP.LNK(2) = NewInstance C_AREPLNK AllocGroup REP : # Cancel
     Call ASET_AREPLNK(REP.LNK(2),'$abort',1,'','',18,'EDIRUNREC',12409,4,'','',1,2,1,1,1) From ASYRSUBREP
     REP.LNK(2).ATT(1)= NewInstance C_AREPATT AllocGroup REP
          REP.LNK(2).ATT(1).COD = "$isHidden" : REP.LNK(2).ATT(1).ATT = "true"
     REP.LNK(2).ATT(2)= NewInstance C_AREPATT AllocGroup REP
          REP.LNK(2).ATT(2).COD = "$isDisabled" : REP.LNK(2).ATT(2).ATT = "false"
     REP.LNK(2).LNK(1) = NewInstance C_AREPLNK AllocGroup REP : # List
          Call ASET_AREPLNK(REP.LNK(2).LNK(1),'$query',1,'','EDIRUN',5,'EDIRUNREC',49616,4,'','',2,2,1,1,1) From ASYRSUBREP
     
     REP.LNK(2).LNK(2) = NewInstance C_AREPLNK AllocGroup REP : # Display
          Call ASET_AREPLNK(REP.LNK(2).LNK(2),'$details',1,'','EDIRUN',2,'EDIRUNREC',49838,4,'','',1,2,2,1,1) From ASYRSUBREP
          REP.LNK(2).LNK(2).CLE(1)  = NewInstance C_AREPPAR AllocGroup REP
               Call ASET_AREPPAR(REP.LNK(2).LNK(2).CLE(1),'NUM',2,'EDR.NUM','NUM',0,0,0,0,'NUM',1,1) From ASYRSUBREP
     

REP.LNK(3) = NewInstance C_AREPLNK AllocGroup REP : # Create
     Call ASET_AREPLNK(REP.LNK(3),'$create',1,'','EDIRUN',1,'EDIRUNREC',12414,4,'','',2,1,2,1,1) From ASYRSUBREP

REP.LNK(4) = NewInstance C_AREPLNK AllocGroup REP : # Display
     Call ASET_AREPLNK(REP.LNK(4),'$details',1,'','EDIRUN',2,'EDIRUNREC',49838,5,'','',1,1,2,1,1) From ASYRSUBREP
     REP.LNK(4).CLE(1)  = NewInstance C_AREPPAR AllocGroup REP
          Call ASET_AREPPAR(REP.LNK(4).CLE(1),'NUM',2,'EDR.NUM','NUM',0,0,0,0,'NUM',1,1) From ASYRSUBREP

REP.LNK(5) = NewInstance C_AREPLNK AllocGroup REP : # Edit
     Call ASET_AREPLNK(REP.LNK(5),'$edit',1,'','EDIRUN',3,'EDIRUNREC',12964,5,'','',1,1,2,1,1) From ASYRSUBREP
     REP.LNK(5).CLE(1)  = NewInstance C_AREPPAR AllocGroup REP
          Call ASET_AREPPAR(REP.LNK(5).CLE(1),'NUM',2,'EDR.NUM','NUM',0,0,0,0,'NUM',1,1) From ASYRSUBREP

REP.LNK(6) = NewInstance C_AREPLNK AllocGroup REP : # Edit
     Call ASET_AREPLNK(REP.LNK(6),'$edit',1,'','EDIRUN',3,'EDIRUNREC',12964,4,'','',2,1,1,1,1) From ASYRSUBREP
     REP.LNK(6).CLE(1)  = NewInstance C_AREPPAR AllocGroup REP
          Call ASET_AREPPAR(REP.LNK(6).CLE(1),'NUM',2,'EDR.NUM','NUM',0,0,0,0,'NUM',1,1) From ASYRSUBREP

REP.LNK(7) = NewInstance C_AREPLNK AllocGroup REP : # Delete
     Call ASET_AREPLNK(REP.LNK(7),'$delete',1,'','EDIRUN',4,'EDIRUNREC',12415,5,'','',1,1,2,1,1) From ASYRSUBREP
     REP.LNK(7).CLE(1)  = NewInstance C_AREPPAR AllocGroup REP
          Call ASET_AREPPAR(REP.LNK(7).CLE(1),'NUM',2,'EDR.NUM','NUM',0,0,0,0,'NUM',1,1) From ASYRSUBREP

REP.LNK(8) = NewInstance C_AREPLNK AllocGroup REP : # Delete
     Call ASET_AREPLNK(REP.LNK(8),'$delete',1,'','EDIRUN',4,'EDIRUNREC',12415,4,'','',2,1,1,1,1) From ASYRSUBREP
     REP.LNK(8).CLE(1)  = NewInstance C_AREPPAR AllocGroup REP
          Call ASET_AREPPAR(REP.LNK(8).CLE(1),'NUM',2,'EDR.NUM','NUM',0,0,0,0,'NUM',1,1) From ASYRSUBREP

REP.LNK(9) = NewInstance C_AREPLNK AllocGroup REP : # List
     Call ASET_AREPLNK(REP.LNK(9),'$query',1,'','EDIRUN',5,'EDIRUNREC',49616,4,'','',2,1,1,1,1) From ASYRSUBREP

REP.LNK(10) = NewInstance C_AREPLNK AllocGroup REP : # Help
     Call ASET_AREPLNK(REP.LNK(10),'$help',1,'','',22,'EDIRUNREC',78,4,'','',2,2,2,1,1) From ASYRSUBREP

REP.LNK(11) = NewInstance C_AREPLNK AllocGroup REP : # Execution
     Call ASET_AREPLNK(REP.LNK(11),'RUN_E',2,'','EDIRUN',0,'',194,4,'','',0,2,0,0,0) From ASYRSUBREP
     REP.LNK(11).ATT(1)= NewInstance C_AREPATT AllocGroup REP
          REP.LNK(11).ATT(1).COD = "$isRequested" : REP.LNK(11).ATT(1).ATT = "false"
     REP.LNK(11).MET  = NewInstance C_AREPMET AllocGroup REP
          REP.LNK(11).MET.COD= "MET_RUN_PROCESS" : REP.LNK(11).MET.INS= "EDR"

REP.LNK(12) = NewInstance C_AREPLNK AllocGroup REP : # Log reading
     Call ASET_AREPLNK(REP.LNK(12),'TRACE',4,'LECTRACE','',0,'',1135,4,'','',2,0,1,0,0) From ASYRSUBREP

REP.LNK(13) = NewInstance C_AREPLNK AllocGroup REP : # Execution
     Call ASET_AREPLNK(REP.LNK(13),'RUN_D',3,'','EDIRUN',0,'',194,4,'','',2,0,1,1,1) From ASYRSUBREP
     REP.LNK(13).CLE(1)  = NewInstance C_AREPPAR AllocGroup REP
          Call ASET_AREPPAR(REP.LNK(13).CLE(1),'NUM',2,'EDR.NUM','NUM',0,0,0,0,'',1,1) From ASYRSUBREP
     REP.LNK(13).MET  = NewInstance C_AREPMET AllocGroup REP
          REP.LNK(13).MET.COD= "OPE_RUN_PROCESS" : REP.LNK(13).MET.INS= "EDR"

REP.LNK(14) = NewInstance C_AREPLNK AllocGroup REP : # Execution
     Call ASET_AREPLNK(REP.LNK(14),'RUN_Q',3,'','EDIRUN',0,'',194,5,'','',1,0,2,1,1) From ASYRSUBREP
     REP.LNK(14).CLE(1)  = NewInstance C_AREPPAR AllocGroup REP
          Call ASET_AREPPAR(REP.LNK(14).CLE(1),'NUM',2,'EDR.NUM','NUM',0,0,0,0,'',1,1) From ASYRSUBREP
     REP.LNK(14).MET  = NewInstance C_AREPMET AllocGroup REP
          REP.LNK(14).MET.COD= "OPE_RUN_PROCESS" : REP.LNK(14).MET.INS= "EDR"

Return

#-------------------------------------------------------#
# Collections de la représentation
#-------------------------------------------------------#
$COLLECTIONS_REP
REP.COL(1) = NewInstance C_AREPCOL AllocGroup REP : # Filters
     Call ASET_AREPCOL(REP.COL(1),1,0,"EDR.EDRD","EDR.EDRD",1,1,1,1,2,1,20,11526) From ASYRSUBREP
Return

#-------------------------------------------------------#
# load links page
#-------------------------------------------------------#
Subprog ALOAD_LINKS_DET_PAGE(REP)
Variable Instance REP Using R_EDIRUNREC
REP._ASTADETLNK(1) = NewInstance C_ASTATUSLINK AllocGroup REP: # $create
     REP._ASTADETLNK(1).CODLNK = "$create"
     REP._ASTADETLNK(1).ORICODLNK = "4/ACREATE"
     REP._ASTADETLNK(1).ISDISABLED = [V]CST_AFALSE
REP._ASTADETLNK(2) = NewInstance C_ASTATUSLINK AllocGroup REP: # $edit
     REP._ASTADETLNK(2).CODLNK = "$edit"
     REP._ASTADETLNK(2).ORICODLNK = "5/AEDIT"
     REP._ASTADETLNK(2).ISDISABLED = [V]CST_AFALSE
REP._ASTADETLNK(3) = NewInstance C_ASTATUSLINK AllocGroup REP: # $delete
     REP._ASTADETLNK(3).CODLNK = "$delete"
     REP._ASTADETLNK(3).ORICODLNK = "5/ADELETE"
     REP._ASTADETLNK(3).ISDISABLED = [V]CST_AFALSE
REP._ASTADETLNK(4) = NewInstance C_ASTATUSLINK AllocGroup REP: # $query
     REP._ASTADETLNK(4).CODLNK = "$query"
     REP._ASTADETLNK(4).ORICODLNK = "4/AQUERY"
     REP._ASTADETLNK(4).ISDISABLED = [V]CST_AFALSE
REP._ASTADETLNK(5) = NewInstance C_ASTATUSLINK AllocGroup REP: # $help
     REP._ASTADETLNK(5).CODLNK = "$help"
     REP._ASTADETLNK(5).ORICODLNK = "4/AHELP"
     REP._ASTADETLNK(5).ISDISABLED = [V]CST_AFALSE
REP._ASTADETLNK(6) = NewInstance C_ASTATUSLINK AllocGroup REP: # TRACE
     REP._ASTADETLNK(6).CODLNK = "TRACE"
     REP._ASTADETLNK(6).ORICODLNK = "4/TRACE"
     REP._ASTADETLNK(6).ISDISABLED = [V]CST_AFALSE
REP._ASTADETLNK(7) = NewInstance C_ASTATUSLINK AllocGroup REP: # RUN_D
     REP._ASTADETLNK(7).CODLNK = "RUN_D"
     REP._ASTADETLNK(7).ORICODLNK = "4/RUN_D"
     REP._ASTADETLNK(7).ISDISABLED = [V]CST_AFALSE
End



