#<AdxTL>@(#)4.0.0.0 $Revision$
######################################################################################
##**72216
######################################################################################

#################################
# Chargement du tableau de l'onglet Retro
#################################
$LOAD_RETROCTR
If [F:HRCTR]FLGRET<>2
  Effzo [M:CTRA] : Grizo [M:CTRA]
Else
 #if this contrat is used in retroactivity record, we can't update it
 Filter [F:RES] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT
 Read [F:RES]RES1 Last
 Filter [F:RES]
 If fstat | [F:HRCTR]RETSTATUT<>3
   Actzo [M:CTRA]
   Raz [M:CTRA]RETNUM
   Grizo [M:CTRA]RETNUMICO
 Else
  [M:CTRA]RETNUM=[F:RES]RETNUM
  Grizo [M:CTRA]
  Actzo [M:CTRA]RETNUMICO
 Endif

 nolign=0
 For[RCR]RCR2 Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT
  nolign+=1
  If nolign > dim([M:CTRA]FLD)
    Break
  Endif
  [M:CTRA]=[F:RCR]
  Read [ATY]CODTYP=[F:RCR]CODTYP
  If !fstat
   [M:CTRA]CODOBJ(nolign-1) = [F:ATY]OBJLIEN
  Endif
  [M:CTRA]LIGUNI(nolign-1)=format$(GFMD,[M:CTRA]STRDAT(nolign-1))+'|'+ [M:CTRA]FLD(nolign-1)+'|'+ [M:CTRA]STRBUL(nolign-1) +'|'+ [M:CTRA]ENDBUL(nolign-1)
 Next
 [M]NBRRCR=nolign
Endif
Return

#################################
# Enregistrement du tableau de l'onglet Retro
#################################
$SAVE_RETROCTR
If [F:HRCTR]FLGRET=2
 Delete [RCR] Where  REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT
 If fstat=1
  GOK =-1 : GLOCK = "$RETROCTR" : Return
 Endif
 If GREP <> "A"
  For nolign=1 To [M:CTRA]NBRRCR
   [F:RCR]=[M:CTRA]
   [F:RCR]REFNUM=[F:HRCTR]REFNUM
   [F:RCR]CTRNUM=[F:HRCTR]CTRNUM
   [F:RCR]CTRDAT=[F:HRCTR]CTRDAT
   [F:RCR]LIG=nolign
   Write [RCR]
   If fstat<>0
    GOK = 0 : Call FSTA("RCR") From GLOCK : Break
   Endif
  Next
 Endif
Endif
Return

#################################
# Initialisation des zones invisibles du tableau de l'onglet Retro
# lors de son pré-chargement (Gestion zone de type AVA)
#################################
$LOAD_DICO
Read [ATZ]CODZONE="EMPLOCTR";[F:DIC]FLD
If !fstat
 Read [ATY]CODTYP=[F:ATZ]CODTYP
 If !fstat
  [M:CTRA]CODTYP(nolign-1) = [F:ATZ]CODTYP
  [M:CTRA]NOLIB(nolign-1)  = [F:ATZ]NOLIB
  L_LONG = [F:ATZ]LONG
  If !L_LONG
   L_LONG = [F:ATY]LNGTYP
  Endif
  [M:CTRA]LONG(nolign-1)   = L_LONG
  [M:CTRA]CODOBJ(nolign-1) = [F:ATY]OBJLIEN
 Else
  Raz [F:ATY]
 Endif
Else
 Raz [F:ATZ]
Endif
If [F:ATZ]CODTYP="ADI"
 Read [AMP]CODPAR=2;"EMPLOCTR";[F:DIC]FLD;[F:ATZ]CODTYP
 If !fstat
  # Certains paramètres ADI ont des " ou des '
  [F:AMP]VALPAR = ctrans([F:AMP]VALPAR,'"','')
  [F:AMP]VALPAR = ctrans([F:AMP]VALPAR,"'","")
  [M:CTRA]VALPAR(nolign-1) = [F:AMP]VALPAR
 Endif
Endif
Return


#################################
#Recherche générique d'une valeur d'origine et\ou de destination (+ valeur interne en lien)
Subprog VALRCR(MAT,CTR, DAT,FLDCOD,FLDNUM,VALSTD,VALINT)
Value Char MAT
Value Char CTR
Value Date DAT
Value Char FLDCOD       :# code champ
Value Integer FLDNUM    :# no du ML
Variable Char VALSTD    :# valeur std
Variable Char VALINT    :# valeur interne

If !clalev([F:CTRZ]): Local File EMPLOCTR    [CTRZ] : Endif

Raz VALSTD : Raz VALINT : Raz FLGADD

Read[F:CTRZ]CTR0=MAT;CTR;DAT
If fstat : End : Endif

Case evalue("type([F:CTRZ]"+[L]FLDCOD+")")
 When -1
  End        :# Champ inexistant
 When 1
  If evalue('[F:CTRZ]'+FLDCOD)=0
   VALSTD = mess(1,FLDNUM,1)
   VALINT = num$(1)
  Else
   VALSTD=mess(evalue('[F:CTRZ]'+FLDCOD),FLDNUM,1)
   VALINT=num$(evalue('[F:CTRZ]'+FLDCOD))
  Endif
 When 2,4,5,6,7,9
  VALSTD=num$(evalue('[F:CTRZ]'+FLDCOD))
  VALINT=num$(evalue('[F:CTRZ]'+FLDCOD))
 When 3
  If evalue('[F:CTRZ]'+FLDCOD) <> [0/0/0]
    VALSTD=format$(GFMD,evalue('[F:CTRZ]'+FLDCOD))
    VALINT=format$(GFMD,evalue('[F:CTRZ]'+FLDCOD))
  Endif
 When Default
  VALSTD=evalue('[F:CTRZ]'+FLDCOD)
  VALINT=evalue('[F:CTRZ]'+FLDCOD)
Endcase
End

#################################
# Pré-chargement du tableau de l'onglet Retro
# Via icone ou clic droit dans le tableau
############################"
$LOAD_RETTAB
If [M:CTRA]RETSTATUT=1 : GMESSAGE=mess(2,126,1) : Return : Endif    :#fiche inactive
Local Integer OK, FLGUPD
OK=2
If [M:CTRA]NBRRCR > 0
   # mess(161,702,1) : Attention, des données sont présentes, elles seront effacées.
   # mess(172,100,1) : Voulez-vous-poursuivre le traitement en cours
   OK=1
   Call OUINON(mess(161, 10702, 1)+"\"+mess(172, 100, 1),OK) From GESECRAN
Endif
If OK<>2 : Return : Endif
# La selection sur STRDAT a pu changer [F:HRCTR], donc on recharge...
Read [F:HRCTR]CTR0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT
If fstat : Return : Endif
Effzo [M:CTRA]10
Raz [M:CTRA]NBRRCR
If func AFNC.ACTIV("HIC") > 0
 Call LOAD_RETHICDIF (FLGUPD)         : #Chargement en fonction de la table HISTOCTX
Else
 Call LOAD_RETCTRDIF (FLGUPD)         : #Chargement en fonction de la table EMPLOCTR
Endif
If FLGUPD
 Sorta [M:CTRA]NBRRCR [M:CTRA]NBRRCR Order By [M]FLD(indice), [M]STRBUL(indice), [M]ENDBUL(indice)
 Affzo [M:CTRA]10
 mkstat=4
Endif
Return

###########################################################
#Chargement en fonction de la table EMPLOCTR
#Attention si [F:CTRW] est un avenant rétroactif : Cas particulier à gérer car les valeurs d'origines sont peut-être dans RETROCTR !
#Finalement non, les spec indiquent dans leur exemple que la valeur d'origine est celle du EMPLOCTR initial jamais celle de RETROCTR !!!
Subprog LOAD_RETCTRDIF (FLGUPD)
Variable Integer FLGUPD

If !clalev([F:CTRW]): Local File EMPLOCTR    [CTRW] : Endif
If !clalev([F:RCRW]): Local File RETROCTR    [RCRW] : Endif
If !clalev([F:VEPW]): Local File VALEMP      [VEPW] : Endif
If !clalev([F:DIC]) : Local File DICOEMP     [DIC]  : Endif
If !clalev([F:ATZ]) : Local File ATABZON     [ATZ]  : Endif
If !clalev([F:ATY]) : Local File ATYPE       [ATY]  : Endif
If !clalev([F:AMP]) : Local File AMSKPAR     [AMP]  : Endif
nolign=1 : FLGUPD=0
For [F:DIC]DIC0 Where TBL="EMPLOCTR" & FLGRET=2
 For [F:CTRW]CTR0 Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT<[F:HRCTR]CTRDAT & (XITDAT=[0/0/0] | XITDAT>=[F:HRCTR]RETDATEFF)
  If num$(evalue ('[F:CTRW]'+[F:DIC]FLD)) <> num$(evalue ('[F:HRCTR]'+[F:DIC]FLD))
   If nolign > dim ([M:CTRA]STRDAT)
    Break 2
   Endif
   [M:CTRA]STRDAT(nolign-1)=[F:CTRW]CTRDAT
   [M:CTRA]ENDDAT(nolign-1)=[F:CTRW]XITDAT
   If [F:CTRW]FLGVAR=2
    [M:CTRA]TYP(nolign-1)=3 :#VAR
   Elsif  [F:CTRW]FLGRET=2
    [M:CTRA]TYP(nolign-1)=2 :#Retro
   Else
   [M:CTRA]TYP(nolign-1)=1  :#Std
   Endif
   Filter [VEPW] Where EMP=[F:CTRW]REFNUM & CTRNUM=[F:CTRW]CTRNUM & CTRDAT=[F:CTRW]CTRDAT & STRDAT>=[F:HRCTR]RETDATEFF & STA>1 & RVS<>2 & RVSDAT=[0/0/0]
   Read [VEPW]VEP5 First
   #Filter [VEPW]
   If !fstat
    [M:CTRA]STRPAY(nolign-1)=[F:VEPW]PYRDAT
    [M:CTRA]STRBUL(nolign-1)=[F:VEPW]BUL
   Endif
   Read [VEPW]VEP5 Last
   Filter [VEPW]
   If !fstat
    [M:CTRA]ENDPAY(nolign-1)=[F:VEPW]PYRDAT
    [M:CTRA]ENDBUL(nolign-1)=[F:VEPW]BUL
   Endif
   # Pas de bulletin = Pas de ligne !
   If [M:CTRA]STRBUL(nolign-1)<>"" & [M:CTRA]ENDBUL(nolign-1)<>""
    [M:CTRA]FLD(nolign-1)=[F:DIC]FLD
    [M:CTRA]LIGUNI(nolign-1)=format$(GFMD,[M:CTRA]STRDAT(nolign-1))+'|'+ [M:CTRA]FLD(nolign-1)+'|'+ [M:CTRA]STRBUL(nolign-1) +'|'+ [M:CTRA]ENDBUL(nolign-1)
    Call TEXTE([F:DIC]DES,[M:CTRA]TIT(nolign-1)) From OBJDIV
    Gosub LOAD_DICO
    # Origine
    Call VALRCR([F:CTRW]REFNUM,[F:CTRW]CTRNUM,[F:CTRW]CTRDAT,[M:CTRA]FLD(nolign-1),[M:CTRA]NOLIB(nolign-1), [M:CTRA]VALORI(nolign-1),[M:CTRA]VALINTORI(nolign-1)) From SUBCTRRET
    # Destination
    Call VALRCR([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:CTRA]FLD(nolign-1),[M:CTRA]NOLIB(nolign-1), [M:CTRA]VALDEN(nolign-1),[M:CTRA]VALINTDEN(nolign-1)) From SUBCTRRET
    If [M:CTRA]VALINTORI(nolign-1)<>[M:CTRA]VALINTDEN(nolign-1)
     FLGUPD=1: nolign+=1
    Endif
   Endif
  Endif
 Next
Next
[M:CTRA]NBRRCR=nolign-1
End

#####################################################################
#Chargement en fonction de la table HISTOCTX
#Comparaison entre les infos du contrat utilisé dans chaque bulletin lié a la période d'activité
#et les infos du courant avenant
#Même si [F:CTRW] est un avenant rétroactif : pas de cas particulier à gérer car on a toujours dans HISTOCTX les valeurs réellement utilisées
#lors du calcul des bulletins... :)
Subprog LOAD_RETHICDIF (FLGUPD)
Variable Integer FLGUPD

If !clalev([F:HIC])  : Local File HISTOCTX [HIC] : Endif
If !clalev([F:CTRW]) : Local File EMPLOCTR [CTRW]  : Endif
If !clalev([F:VEPW]) : Local File VALEMP   [VEPW]  : Endif
If !clalev([F:DIC])  : Local File DICOEMP  [DIC]  : Endif

Link [VEPW] With
& [CTRW]CTR0 = [F:VEPW]EMP;[F:VEPW]CTRNUM;[F:VEPW]CTRDAT
& As [LNK] Where EMP=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT<[F:HRCTR]CTRDAT
&                & STRDAT>=[F:HRCTR]RETDATEFF & STA>1 & RVS<>2 & RVSDAT=[0/0/0]
&  Order By Key CLE = [F:VEPW]EMP ; [F:VEPW]CTRNUM ; [F:VEPW]CTRDAT ; [F:VEPW]BUL

Local Char WBULORI (GLONVCR)
Raz WBULORI
nolign=1
For [LNK]CLE
 WBULORI=[F:VEPW]BUL
 #nolign=1
 For [HIC]HIC1 Where HICATB='EMPLOCTR' & HICORI=1 & HICIDCLE='VEP' & HICCLE=WBULORI
  If nolign>dim ([M:CTRA]STRDAT)
   Break
  Endif
  If right$([F:HIC]HICATZ,1+len([F:HIC]HICATZ)-3)="(0)"
   [M:CTRA]FLD(nolign-1)=left$([F:HIC]HICATZ,len([F:HIC]HICATZ)-3)
  Else
   [M:CTRA]FLD(nolign-1)=[F:HIC]HICATZ
  Endif
  Read [F:DIC]DIC0=[M:CTRA]FLD(nolign-1)
  If !fstat & [F:DIC]FLGRET=2
   If [F:HIC]HICVAL<>num$(evalue('[F:HRCTR]'+[M:CTRA]FLD(nolign-1)))
    [M:CTRA]STRDAT(nolign-1)=[F:CTRW]CTRDAT
    [M:CTRA]ENDDAT(nolign-1)=[F:CTRW]XITDAT
    If [F:CTRW]FLGVAR=2
     [M:CTRA]TYP(nolign-1)=3 :#VAR
    Elsif  [F:CTRW]FLGRET=2
     [M:CTRA]TYP(nolign-1)=2 :#Retro
    Else
     [M:CTRA]TYP(nolign-1)=1  :#Std
    Endif
    [M:CTRA]STRPAY(nolign-1)=[F:VEPW]PYRDAT
    [M:CTRA]STRBUL(nolign-1)=[F:VEPW]BUL
    [M:CTRA]ENDPAY(nolign-1)=[F:VEPW]PYRDAT
    [M:CTRA]ENDBUL(nolign-1)=[F:VEPW]BUL
    [M:CTRA]LIGUNI(nolign-1)=format$(GFMD,[M:CTRA]STRDAT(nolign-1))+'|'+ [M:CTRA]FLD(nolign-1)+'|'+ [M:CTRA]STRBUL(nolign-1) +'|'+ [M:CTRA]ENDBUL(nolign-1)
    Call TEXTE([F:DIC]DES,[M:CTRA]TIT(nolign-1)) From OBJDIV
    Gosub LOAD_DICO
    Case evalue("type([F:HRCTR]"+[F:DIC]FLD+")")
     When 1
      If val([F:HIC]HICVAL)=0
       [M:CTRA]VALORI(nolign-1)=mess(1,[M:CTRA]NOLIB(nolign-1),1)
       [M:CTRA]VALINTORI(nolign-1)=num$(1)
      Else
       [M:CTRA]VALORI(nolign-1)=mess(val([F:HIC]HICVAL),[M:CTRA]NOLIB(nolign-1),1)
       [M:CTRA]VALINTORI(nolign-1)=[F:HIC]HICVAL
      Endif
      If evalue('[F:HRCTR]'+[F:DIC]FLD)=0
       [M:CTRA]VALDEN(nolign-1)=mess(1,[M:CTRA]NOLIB(nolign-1),1)
       [M:CTRA]VALINTDEN(nolign-1)=num$(1)
      Else
       [M:CTRA]VALDEN(nolign-1)=mess(evalue('[F:HRCTR]'+[F:DIC]FLD),[M:CTRA]NOLIB(nolign-1),1)
       [M:CTRA]VALINTDEN(nolign-1)=num$(evalue('[F:HRCTR]'+[F:DIC]FLD))
      Endif
     When 2,4,5,6,7,9
      [M:CTRA]VALORI(nolign-1)=[F:HIC]HICVAL
      [M:CTRA]VALINTORI(nolign-1)=[F:HIC]HICVAL
      [M:CTRA]VALDEN(nolign-1)=num$(evalue('[F:HRCTR]'+[F:DIC]FLD))
      [M:CTRA]VALINTDEN(nolign-1)=num$(evalue('[F:HRCTR]'+[F:DIC]FLD))
     When 3
      If [F:HIC]HICVAL <> ""
       [M:CTRA]VALORI(nolign-1)=format$(GFMD,[F:HIC]HICVAL)
       [M:CTRA]VALINTORI(nolign-1)=format$(GFMD,[F:HIC]HICVAL)
      Else
       Raz [M:CTRA]VALORI(nolign-1)
       Raz [M:CTRA]VALINTORI(nolign-1)
      Endif
      If evalue('[F:HRCTR]'+[F:DIC]FLD) <> [0/0/0]
       [M:CTRA]VALDEN(nolign-1)=format$(GFMD,evalue('[F:HRCTR]'+[F:DIC]FLD))
       [M:CTRA]VALINTDEN(nolign-1)=format$(GFMD,evalue('[F:HRCTR]'+[F:DIC]FLD))
      Else
       Raz [M:CTRA]VALDEN(nolign-1)
       Raz [M:CTRA]VALINTDEN(nolign-1)
      Endif
     When Default
      [M:CTRA]VALORI(nolign-1)=[F:HIC]HICVAL
      [M:CTRA]VALINTORI(nolign-1)=[F:HIC]HICVAL
      [M:CTRA]VALDEN(nolign-1)=evalue('[F:HRCTR]'+[F:DIC]FLD)
      [M:CTRA]VALINTDEN(nolign-1)=evalue('[F:HRCTR]'+[F:DIC]FLD)
     Endcase
     If [M:CTRA]VALINTORI(nolign-1)<>[M:CTRA]VALINTDEN(nolign-1)
      FLGUPD=1: nolign+=1
     Endif
    Endif
   Endif
  Next :#HIC
Next :#LNK
[M:CTRA]NBRRCR=nolign-1
Close File [HIC],[CTRW],[VEPW],[DIC]
End

#**
#* FQ85820 - 30/04/13 - On cherche si on a une fiche de rétroactivité relative aux champs PROPRF et ETRSRV
#*
#* @param EMP     : Matricule
#* @param CTR     : Contrat
#* @param CTRD    : Date contrat
#* @param DATREF  : Date de référence pour les mois de paie
#* @param FLDNAM  : Nom du champ à chercher
#* @param ALLFLD  : Case ALLxxx cochée ou non
#* @param DIAFLD  : Valeur du champ associé sélectionné si ALLFLD décoché
#* @param ABREV   : Abréviation de la table EMPLOCTR dans laquelle récupérer les infos si rien dans RETOCTR
#*!
Funprog VERIF_FLD(EMP,CTR,CTRD,DATREF,FLDNAM,ALLFLD,DIAFLD,ABREV)
Value Char    EMP(),CTR(),FLDNAM(),DIAFLD(),ABREV()
Value Date    CTRD,DATREF
Value Integer ALLFLD
Local Integer OKENR
Local Char    FLDVAL(30)

  OKENR=2
  If ALLFLD<>2 Then
    FLDVAL=func SUBCTRRET.FIND_RETRO_FLD([L]EMP, [L]CTR, [L]CTRD, [L]DATREF, [L]FLDNAM, [L]ABREV)
    If (ALLFLD<>2 & FLDVAL<>DIAFLD) Then OKENR=1 : Endif
  Endif
End OKENR

#**
#* FQ85820 - 30/04/13 - On cherche si on a une fiche de rétroactivité relative au champ FLD
#*
#* @param EMP     : Matricule
#* @param CTR     : Contrat
#* @param CTRD    : Date contrat
#* @param DATREF  : Date de référence pour les mois de paie
#* @param FLDNAM  : Nom du champ à chercher
#* @param ABREV   : Abréviation de la table EMPLOCTR dans laquelle récupérer les infos si rien dans RETOCTR
#*!
Funprog FIND_RETRO_FLD(EMP,CTR,CTRD,DATREF,FLDNAM,ABREV)
Value Char    EMP(),CTR(),FLDNAM(), ABREV()
Value Date    CTRD,DATREF
Local Char    FLDVAL(30)

#If GUSER='MABON' & FLDNAM="ETRSRV" Dbgaff Endif
  FLDVAL=""
  If evalue("[F:"+[L]ABREV+"]FLGRET")=2 & DATREF<>[0/0/0] & DATREF<CTRD Then
    If clalev([F:RCR])=0 : Local File RETROCTR [RCR] : Endif
    For [F:RCR] Where REFNUM=[L]EMP & CTRNUM=[L]CTR & CTRDAT=[L]CTRD
&                     & [L]DATREF>=STRPAY & [L]DATREF<=ENDPAY & FLD=[L]FLDNAM
      FLDVAL=[F:RCR]VALINTDEN
    Next
  Endif
  If FLDVAL="" Then FLDVAL=num$(evalue("[F:"+[L]ABREV+"]"+[L]FLDNAM)) : Endif
End FLDVAL

