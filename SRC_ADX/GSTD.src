#<AdxTL>@(#)0.0.0.0 $Revision$ Maintenance en ligne
#------------------------------------------------------------------#
#  Appel par TRT GSTD
#------------------------------------------------------------------#
Raz GNBMASKOUV , GPILOBJ
Close Local Mask
Call GSTD("ATABLE",nomap)
End

#------------------------------------------------------------------#
#  Appel par Call GSTD
#------------------------------------------------------------------#

Subprog GSTD(TABLE,DOSSIER)
Value Char TABLE, DOSSIER
Local Char PARAM(250)(1..3)
Local Char VALEUR(30)
PARAM(1) = DOSSIER
PARAM(2) = TABLE
PARAM(3) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"STD","GSTD","STDCRIT",3,"") From GTRAITE
End

#---------------------------#
$ACTION
Case ACTION

 When "INIT"         : Gosub INIT
 When "INIT_DIA"     : Gosub INIT_DIA
 When "EXEC"         : Gosub EXEC

 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "NEW"          : Gosub NOUVEAU
 When "SUP"          : Gosub ANNULER
 When "ENR"          : Gosub ENREGISTRER
 When "CRE"          : Gosub CREER
 When "FIR"          : Gosub PREMIER
 When "LAS"          : Gosub DERNIER
 When "SUI"          : Gosub SUIVANT
 When "PRE"          : Gosub PRECEDENT
 When "ABA"          : Gosub ABANDON
 When "FIN"          : Gosub FIN
 When "BUR"          : Gosub BUREAU
 When "BOUTON"       : Gosub BOUTON
 When "SEL"          : Gosub SELECTION
 When "SETBOUT"      : Gosub SETBOUT
 When "TITRE"        : Gosub TIT
 When Default
Endcase
Return

#------------------------------------------------------------------#
#                      ACTIONS GTRAITE
#------------------------------------------------------------------#

$INIT
Local Char     OBCRIT(30)
OBCRIT = BCRIT
#F_add_admca_managment
# If GPROFIL<>GSUPER & GADONIX<>2                      # Issue 109484 - 121082 revert
If GPROFIL<>GSUPER & GADONIX<>2 & GPROFIL<>"ADMCA"    # End issue 109484 - revert
 Call ERREUR(mess(145,124,1)) From GESECRAN : # Fonction réservée à l'administrateur
 FIN = 1 : Return
Elsif GHISTO<>0
 GCONSULT = 1
Endif
If func AFNC.PARAMUTIL("ASIGMNT","","")="2"
 Local Char VALSIG(10) , PARSIG(30)(1..2)
 PARSIG(1) = PARAM(1)
 PARSIG(2) = PARAM(3)
 mkstat = 0
 If GFUSION>0
  Call SAISIE_CHAR(VALSIG,PARSIG,"APASSMNTSYRA","APASSMNTSYRA","") From GSAISIE
 Else
  Call SAISIE_CHAR(VALSIG,PARSIG,"APASSWDMNT","APASSWDMNT","") From GSAISIE
 Endif
 If mkstat : FIN = 1 : Return : Endif
 PARAM(3)  = PARSIG(2)
Endif
If PARAM(1)<>"" & PARAM(2)<>""
 Call CONTDOS(PARAM(1))
 If !mkstat
  Local Mask GSTD [DIA]
  [M:DIA]DOSSIER = PARAM(1)
  Call C_FICH(PARAM(2))
  If !mkstat
   [M:DIA]FICH = PARAM(2)
   [M:DIA]MOTIF = PARAM(3)
   BCRIT = ""
  Else
   Close Local Mask [DIA]
  Endif
 Endif
Endif
Return

Subprog CONTDOS(VALEUR)
Value Char VALEUR
Call C_DOSSIER(VALEUR) From DOSCONT
If mkstat : End : Endif
Call CTL_DROIT_DOSSIER(VALEUR,"") From DOSCONT
If mkstat : End : Endif
Local Char    PARVAL(10) , PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "APASSWD"
PARMSK(1) = VALEUR
Call SAISIE_CHAR(PARVAL,PARMSK,"APASSWD","APASSWD","SPEPASSWD") From GSAISIE
GACTION = SAVACT
End

#---------------------------#
$INIT_DIA
If PARAM(1)<>"" : [M:DIA]DOSSIER = PARAM(1) : GMODIF = 0 : Endif
If PARAM(2)<>"" : [M:DIA]FICH    = PARAM(2) : GFILPATH = "" : Endif
If PARAM(3)<>"" : [M:DIA]MOTIF   = PARAM(3) : Endif
Return

#---------------------------#
$EXEC
If GSTATUT=GSTABOU2+1 : SAI = 1 : Endif
GMODIF = 0
BCRIT = OBCRIT
Return

#------------------------------------------------------------------#
#                      ACTIONS GSAISIE
#------------------------------------------------------------------#

$OUVRE
Local Integer  CLECUR , MA , CPT , NRMASK , LGMAX , LONG , MAXMASK , STAT
Local Char     REP(1) , FICH(GLONATB) , ABREV(GLONABR) , VAL1(30) , VAL2(30)
Local Char     CLE(250) , PRGMNT(GLONADC)
Local Char     CRITERE(250) , SAVCRIT(250)
Local Char     DOSSIER(GLONADD) , MOTIF(GLONADI)
Local Char     FMZONE1(30)(1..15,0..20) , FMZONE2(30)(1..15,0..20) , FMZONE3(30)(1..15,0..20)
Local Char     FMINT1(10)(1..15,0..20) , FMINT2(10)(1..15,0..20) , FMINT3(10)(1..15,0..20)
Local Char     FMW1(20)(1..15,0..20) , FMW2(20)(1..15,0..20) , FMW3(20)(1..15,0..20)
Local Char     INTIT1(20)(1..15,0..40) , INTIT2(20)(1..15,0..20) , INTIT3(20)(1..15,0..20)
Local Char     TBCLE(GLONAVA)(0..15) , FMCLE(20)(0..15) , FMINT(10)(0..15)
Local Char     FORMAT(30) , INTIT(20) , CHAINE(250)
Local Char     INTCLB(20) , INTPHO(20) , INTBUR(20) , TYPBLB(20) , ZONBLB(20)
Local Char     TIT(80)
Local Char     INTCLE(20)(0..15)
Local Integer  ER , Z , NBDIM
Local Integer  NCLE , NZ1(1..15) , NZ2(1..15) , NZ3(1..15)
Local Integer  TYPCL(0..15) , TYPZ1(1..15,0..20) , TYPZ2(1..15,0..20) , TYPZ3(1..15,0..20)
Local Char     CYP1(GLONATY)(1..15,0..20) , CYP2(GLONATY)(1..15,0..20) , CYP3(GLONATY)(1..15,0..20)
Local Char     VALCLE(GLONID)
Local Shortint NOLIB1(1..15,0..20) , NOLIB2(1..15,0..20) , NOLIB3(1..15,0..20)
Local Char     ERR_ZON(15)
Local Integer  CURIND , CURLEN , MODI
Local Char     TYPFMT(10) , OPTFMT(10) , CHFMT(30) , NUMFMT(10)
Local Char     SAVIRS(5) , SAVIFS(5)
Local Integer  SAVIUM
Local Char     CLEPRIM(GLONAVA), CLESEC(GLONAVA)(0..16), CLEESP(GLONID)
Local Integer  LNGZON , LNGSAI

FICH    = [M:DIA]FICH
DOSSIER = [M:DIA]DOSSIER
MOTIF   = [M:DIA]MOTIF

Gosub OUVRE From GSTD0
Return

#---------------------------#
$TIT
TIT = mess(181,123,1)-[M:DIA]FICH : # Maintenance de la table
If instr(1,[M:DIA]DOSSIER,"@")
 TIT -= "("+[M:DIA]DOSSIER+")"
Elsif adxmac(0)<>""
 TIT -= "("+adxmac(0)+"@"+[M:DIA]DOSSIER+")"
Else
 TIT -= "("+[M:DIA]DOSSIER+")"
Endif
Return

#---------------------------#
$DEBUT
CLECUR = 0
REP = ""
MODI = (FICH<>"AESPION") and !GHISTO
Gosub DEBUT From GSTD0
Return

#---------------------------#
$FIN
If dim(PRGMNT)>0 & PRGMNT<>""
 If filinfo(filpath("TRT",PRGMNT,"src",nomap),0)>0
  Call EFFACE(filpath("TRT",PRGMNT,"src",nomap),K) From ORDSYS
 Endif
 If filinfo(filpath("TRT",PRGMNT,"xrc",nomap),0)>0
  Call EFFACE(filpath("TRT",PRGMNT,"xrc",nomap),K) From ORDSYS
 Endif
 Call EFFACE_ADX("",nomap,PRGMNT,K) From ORDSYS
 If filinfo(filpath("TRT",PRGMNT,"adx",nomap),0)>0
  Call EFFACE(filpath("TRT",PRGMNT,"adx",nomap),K) From ORDSYS
 Endif
Endif
Return

#---------------------------#
$BOUTON
Case BOUT
 When "T"
  If func AFNC.PARAMUTIL("ASIGMNT","","")="2"
   Local Char VALSIG(10) , PARSIG(30)(1..2)
   PARSIG(1) = DOSSIER
   PARSIG(2) = MOTIF
   If GFUSION>0
    Call SAISIE_CHAR(VALSIG,PARSIG,"APASSMNTSYRA","APASSMNTSYRA","") From GSAISIE
   Else
    Call SAISIE_CHAR(VALSIG,PARSIG,"APASSWDMNT","APASSWDMNT","") From GSAISIE
   Endif
   If mkstat : Return : Endif
   MOTIF        = PARSIG(2)
   [M:DIA]MOTIF = MOTIF
  Endif
  [M:DIA]FICH = "" : GMODIF = 0 : FIN = 1 : Gosub FERME From GSTD0
Endcase
Return

#---------------------------#
$SETBOUT
If REP<>"" : Call VIREBOUT(CHMEN,"T") From GOBJET : Endif
If FICH="AESPION" or GHISTO : Call VIREBOUT(CHBOU,"SEC") From GOBJET : Endif
If CLECUR=0 : Call VIREBOUT(CHBOU,"S<>") From GOBJET : Endif
Return

#---------------------------#
$APRES_MODIF
COUZON = zoncou
If find(COUZON,"CLE1","CLE2","CLE3","CLE4")
 Assign "[M]"+COUZON+"("+num$(indice)+")" With num$(zc)
 Gosub SET_CLE
 Read [FFA_] =
 If fstat : # ça n'existe, pas on passe en création
  If CLECUR=0
   REP = "C" : GREP = "C"
  Else
   REP = "D" : GREP = "D"
  Endif
 Else : # Ca existe, on le charge si on a droit
  REP = "" : GREP = ""
  Gosub LECTURE
 Endif
Else :  # C'est pas une zone de clé
 Case REP
  When "" : # On tente d'entrer en modif
   If CLECUR<>0
    If !MODI
     Call ERREUR(mess(9,123,1)) From GESECRAN : # Modification impossible
     mkstat = 2 : Return
    Else
     REP = "M" : GREP = "M" : # on y est
     Gosub GRISE_CLE
    Endif
   Endif
 Endcase
Endif
Return

#--------------------------------------------#
$BUREAU
If INTBUR<>"" : Gosub BUREAU From =PRGMNT : Endif
Return

#---------------------------#
$GRISE_CLE
For I=1 To NCLE
 Case I
  When 1  : Grizo [STD0]CLE1(0)
  When 2  : Grizo [STD0]CLE1(1)
  When 3  : Grizo [STD0]CLE1(2)
  When 4  : Grizo [STD0]CLE1(3)
  When 5  : Grizo [STD0]CLE2(0)
  When 6  : Grizo [STD0]CLE2(1)
  When 7  : Grizo [STD0]CLE2(2)
  When 8  : Grizo [STD0]CLE2(3)
  When 9  : Grizo [STD0]CLE3(0)
  When 10 : Grizo [STD0]CLE3(1)
  When 11 : Grizo [STD0]CLE3(2)
  When 12 : Grizo [STD0]CLE3(3)
  When 13 : Grizo [STD0]CLE4(0)
  When 14 : Grizo [STD0]CLE4(1)
  When 15 : Grizo [STD0]CLE4(2)
  When 16 : Grizo [STD0]CLE4(3)
 Endcase
Next I
Return

#---------------------------#
$DEGRISE_CLE
For I=1 To NCLE
 Case I
  When 1  : Actzo [STD0]CLE1(0)
  When 2  : Actzo [STD0]CLE1(1)
  When 3  : Actzo [STD0]CLE1(2)
  When 4  : Actzo [STD0]CLE1(3)
  When 5  : Actzo [STD0]CLE2(0)
  When 6  : Actzo [STD0]CLE2(1)
  When 7  : Actzo [STD0]CLE2(2)
  When 8  : Actzo [STD0]CLE2(3)
  When 9  : Actzo [STD0]CLE3(0)
  When 10 : Actzo [STD0]CLE3(1)
  When 11 : Actzo [STD0]CLE3(2)
  When 12 : Actzo [STD0]CLE3(3)
  When 13 : Actzo [STD0]CLE4(0)
  When 14 : Actzo [STD0]CLE4(1)
  When 15 : Actzo [STD0]CLE4(2)
  When 16 : Actzo [STD0]CLE4(3)
 Endcase
Next I
Return

#---------------------------#
$ABANDON
Case REP
 When ""
  CLECUR = 0 : Gosub RELIT
 When "M"
  Gosub RELIT : REP = "" : GREP = ""
  Gosub DEGRISE_CLE
 When "C" , "D"
  Gosub RELIT : REP = "" : GREP = ""
Endcase
Return

#---------------------------#
$NOUVEAU
If REP="M"
 Gosub DEGRISE_CLE
Endif
CLECUR = 0 : Gosub EFFZONE
REP = "C" : GREP = REP
Return

#---------------------------#
$CREER
Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1 : Return : Endif
SAVCRIT = CRITERE
CRITERE="" : Gosub LECTURE
CRITERE = SAVCRIT
Call ESPION(FICH+"~"+MOTIF,1,CLEESP,"") From ESPION
Call TRACE(DOSSIER,FICH+"~"+MOTIF,CLEESP,mess(1,83,1),"") From ESPION : # Créat
CLECUR=1
REP = ""
Return

$TR1
GOK=1
Trbegin [FFA_]
 Raz [F:FFA_]
 For IMA=1 To NRMASK
  Gosub DECHARGE
 Next IMA
 If INTCLB<>"" | INTPHO<>"" | INTBUR<>""
  Gosub DECHARGE From =PRGMNT
 Endif
 If GOK=0 : Goto AB_TR1 : Endif
 Write [FFA_]
 If fstat
  GOK=0 : Call FSTA("FFA_") From GLOCK : Goto AB_TR1
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

#---------------------------#
$ENREGISTRER
Call DEBTRANS From GLOCK
Gosub TR2
If GOK<1 : Return : Endif
Call ESPION(FICH+"~"+MOTIF,2,CLEESP,"") From ESPION
Call TRACE(DOSSIER,FICH+"~"+MOTIF,CLEESP,mess(2,83,1),"GSTD") From ESPION : # Modif
REP = ""
Gosub DEGRISE_CLE
[F:FFB_] = [F:FFA_]
Return

#---------------------------#
$TRACE_ESPION
For I=1 To clanbs([F:FFA_],1)
 VARIA = clavar([F:FFA_],I)
 If left$(VARIA,1)<>"~"
  NBDIM = evalue("dim([F:FFA_]"+VARIA+")")
  If find(evalue("type([F:FFA_]"+VARIA+")"),522,523) : # Blob , Clob
   NBDIM = 0
  Endif
  For J=1 To NBDIM
   VAL1 = num$(evalue("[F:FFA_]"+VARIA+"("+num$(J-1)+")"))
   VAL2 = num$(evalue("[F:FFB_]"+VARIA+"("+num$(J-1)+")"))
   If VAL1<>VAL2
    Wrseq format$("K:15X",VARIA+"("+num$(J)+")"); Using [AESP]
    Wrseq "   "; Using [AESP]
    Wrseq format$("K:30X",VAL2); Using [AESP]
    Wrseq format$("K:30X",VAL1); Using [AESP]
    Wrseq Using [AESP]
   Endif
  Next J
 Endif
Next I
Wrseq string$(75,"-") Using [AESP]
Return

$TR2
GOK=1
Trbegin [FFA_]
 [G:FFA_]currind = CURIND
 [G:FFA_]currlen = 0
 Readlock [FFA_] Curr
 If fstat=1
  GOK=-1 : GLOCK="$"+FICH : Goto ROLL_TR2
 Elsif fstat
  GOK=0 : Call RSTA("FFA_","") From GLOCK : Goto AB_TR2
 Endif
 For IMA=1 To NRMASK
  Gosub DECHARGE
 Next IMA
 If INTCLB<>"" | INTPHO<>"" | INTBUR<>""
  Gosub DECHARGE From =PRGMNT
 Endif
 If GOK=0 : Goto AB_TR2 : Endif
 Rewrite [FFA_]
 If fstat
  GOK=0 : Call FSTA("FFA_") From GLOCK : Goto AB_TR2
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$AB_TR2
Rollback
Return

#---------------------------#
$SUIVANT
If CRITERE<>""
 Filter [FFA_] Where evalue(CRITERE)
Endif
[G:FFA_]currind = CURIND
[G:FFA_]currlen = 0
Read [FFA_] Next
If fstat
 Call ERREUR(mess(11,100,1)) From GESECRAN
 Read [FFA_] Last
Endif
Goto SUIVPREC

#---------------------------#
$PRECEDENT
If CRITERE<>""
 Filter [FFA_] Where evalue(CRITERE)
Endif
[G:FFA_]currind = CURIND
[G:FFA_]currlen = 0
Read [FFA_] Prev
If fstat
 Call ERREUR(mess(11,100,1)) From GESECRAN
 Read [FFA_] First
Endif
Goto SUIVPREC

#---------------------------#
$SUIVPREC
Filter [FFA_]
Gosub CHARGE : Gosub AFFZONE
CLECUR=1
Return

#---------------------------#
$PREMIER
If CRITERE<>""
 Filter [FFA_] Where evalue(CRITERE)
Endif
[G:FFA_]currind = CURIND
[G:FFA_]currlen = CURLEN
Read [FFA_] First
Goto PRDER

#---------------------------#
$DERNIER
If CRITERE<>""
 Filter [FFA_] Where evalue(CRITERE)
Endif
[G:FFA_]currind = CURIND
[G:FFA_]currlen = CURLEN
Read [FFA_] Last
Goto PRDER

#---------------------------#
$PRDER
Filter [FFA_]
If fstat>2
 CLECUR=0 : Gosub EFFZONE
Else
 CLECUR=1 : Gosub CHARGE : Gosub AFFZONE
Endif
Return

#---------------------------#
$ANNULER
Call DEBTRANS From GLOCK
Gosub TR3
If GOK=1
 CLECUR=0
 Gosub EFFZONE
 Call ESPION(FICH+"~"+MOTIF,3,CLEESP,"") From ESPION
 Call TRACE(DOSSIER,FICH+"~"+MOTIF,CLEESP,mess(3,83,1),"") From ESPION : # Annul
Else
 Gosub RELIT
Endif
Return

$TR3
GOK=1
Trbegin [FFA_]
 Delete [FFA_]
 If fstat=1
  GOK=-1 : GLOCK="$"+FICH : Goto ROLL_TR3
 Elsif fstat>5
  GOK=0 : Call RSTA(ABREV,"") From GLOCK : Goto AB_TR3
 Endif
Commit
Return

$ROLL_TR3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR3 : Endif

$AB_TR3
Rollback
Return

#---------------------------#
$SELECTION
CRITERE = [M]AFILTRE
ER = 0
If CRITERE<>""
 Onerrgo ERRSEL
 Filter [FFA_] Where evalue(CRITERE)
 Onerrgo
 If ER
  Gosub ERRCRIT From GSTD2
  CLECUR = 0 : Gosub EFFZONE
 Else
  If CLECUR=0
   Raz [F:FFA_]
  Else
   Gosub SET_CLE
  Endif
  Onerrgo ERRSEL
  [G:FFA_]currind = CURIND
  [G:FFA_]currlen = 0
  Filter [FFA_] Where evalue(CRITERE)
  Read [FFA_] >
  Filter [FFA_]
  If !ER
   For [FFA_] Where evalue(CRITERE)
    Break
   Next FFA_
   # Il se peut qu'il n'y ait pas d'erreur mais que le "filter" n'autorise pas cette fonction
   If ER
    Filter [FFA_]
    [G:FFA_]currind = CURIND
    [G:FFA_]currlen = 0
    Read [FFA_] >
    While fstat<=2
     ER=0
     If evalue(CRITERE,1)
      fstat=0 : Break
     Endif
     If ER : Break : Endif
     Read [FFA_] Next
    Wend
   Endif
  Endif
  Onerrgo
  If ER
   Gosub ERRCRIT From GSTD2
   CLECUR = 0 : Gosub EFFZONE
  Elsif fstat>2
   Call ERREUR(mess(11,100,1)) From GESECRAN : # Début/Fin de fichier
   CLECUR = 0 : Gosub EFFZONE
  Else
   Gosub CHARGE
   CLECUR=1
   Gosub AFFZONE
  Endif
 Endif
Endif
Filter [FFA_]
Return

$ERRSEL
ER = errn
Resume

#---------------------------#
$EFFZONE
For MA=0 To NRMASK
 Case MA
  When 0  : Effzo [STD0]CLE1, CLE2, CLE3, CLE4
  When 1  : Effzo [M1]ZONE1,  WZONE1, ZONE2, WZONE2, ZONE3, WZONE3
  When 2  : Effzo [M2]ZONE1,  WZONE1, ZONE2, WZONE2, ZONE3, WZONE3
  When 3  : Effzo [M3]ZONE1,  WZONE1, ZONE2, WZONE2, ZONE3, WZONE3
  When 4  : Effzo [M4]ZONE1,  WZONE1, ZONE2, WZONE2, ZONE3, WZONE3
  When 5  : Effzo [M5]ZONE1,  WZONE1, ZONE2, WZONE2, ZONE3, WZONE3
  When 6  : Effzo [M6]ZONE1,  WZONE1, ZONE2, WZONE2, ZONE3, WZONE3
  When 7  : Effzo [M7]ZONE1,  WZONE1, ZONE2, WZONE2, ZONE3, WZONE3
  When 8  : Effzo [M8]ZONE1,  WZONE1, ZONE2, WZONE2, ZONE3, WZONE3
  When 9  : Effzo [M9]ZONE1,  WZONE1, ZONE2, WZONE2, ZONE3, WZONE3
  When 10 : Effzo [M10]ZONE1, WZONE1, ZONE2, WZONE2, ZONE3, WZONE3
 Endcase
Next MA
Effzo [M11]ZONCLB
Effzo [M12]ZONPHO
Effzo [M13]ZONBUR
Return

#---------------------------#
$AFFZONE
For MA=0 To NRMASK
 Gosub AFFMASK From =WINPROG
Next MA
MA = 11 : Gosub AFFMASK From =WINPROG
MA = 12 : Gosub AFFMASK From =WINPROG
MA = 13 : Gosub AFFMASK From =WINPROG
Return

#---------------------------#
$LECTURE
Gosub SET_CLE
If CRITERE<>""
 Filter [FFA_] Where evalue(CRITERE)
Endif
[G:FFA_]currind = CURIND
[G:FFA_]currlen = 0
Read [FFA_] >=
Filter [FFA_]

$LECT2
If fstat<=2
 Gosub CHARGE
 Gosub AFFZONE
 CLECUR=1
 fstat=0
Else
 Call ERREUR(mess(23,100,1)) From GESECRAN : # Fiche inexistante
 CLECUR = 0
 Gosub EFFZONE
 fstat = 2
Endif
Return

#---------------------------#
$SET_CLE
Onerrgo ERR_INTCLE
 For I=0 To NCLE-1
  Case TYPCL(I)
   When 7,8
    If I<4
     VALCLE = [M]CLE1(I)
    Elsif I<8
     VALCLE = [M]CLE2(I-4)
    Elsif I<12
     VALCLE = [M]CLE3(I-8)
    Else
     VALCLE = [M]CLE4(I-12)
    Endif
    If TYPCL(I)=8 & VALCLE=""
     VALCLE="00000000"
    Endif
    Assign "[F:FFA_]"+INTCLE(I) With VALCLE
   When 11
    If I<4
     Assign "[F:FFA_]"+INTCLE(I) With toUuid([M]CLE1(I))
    Elsif I<8
     Assign "[F:FFA_]"+INTCLE(I) With toUuid([M]CLE2(I-4))
    Elsif I<12
     Assign "[F:FFA_]"+INTCLE(I) With toUuid([M]CLE3(I-8))
    Else
     Assign "[F:FFA_]"+INTCLE(I) With toUuid([M]CLE4(I-12))
    Endif
   When 12
    If I<4
     Assign "[F:FFA_]"+INTCLE(I) With gdatetime$([M]CLE1(I))
    Elsif I<8
     Assign "[F:FFA_]"+INTCLE(I) With gdatetime$([M]CLE2(I-4))
    Elsif I<12
     Assign "[F:FFA_]"+INTCLE(I) With gdatetime$([M]CLE3(I-8))
    Else
     Assign "[F:FFA_]"+INTCLE(I) With gdatetime$([M]CLE4(I-12))
    Endif
   When Default
    If I<4
     Assign "[F:FFA_]"+INTCLE(I) With val([M]CLE1(I))
    Elsif I<8
     Assign "[F:FFA_]"+INTCLE(I) With val([M]CLE2(I-4))
    Elsif I<12
     Assign "[F:FFA_]"+INTCLE(I) With val([M]CLE3(I-8))
    Else
     Assign "[F:FFA_]"+INTCLE(I) With val([M]CLE4(I-12))
    Endif
  Endcase
 Next I
Onerrgo
Return

#---------------------------#
$RELIT
If CLECUR=1
 [G:FFA_]currind = CURIND
 [G:FFA_]currlen = 0
 Read [FFA_] Curr
 Gosub LECT2
Endif
Return

#---------------------------#
$CHARGE
nolign=1
[F:FFB_] = [F:FFA_]

# Inspiré de TRT GOBJSUB/$SET_CLE et GOBJTXT/Subprog IDENT3
CLEESP = num$(evalue("[F:FFA_]"+CLEPRIM))
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>""
  CLEESP += "~"+num$(evalue("[F:FFA_]"+CLESEC(I)))
 Endif
Next I

Onerrgo ERR_INTCLE
For I=0 To NCLE-1
 Case TYPCL(I)
  When 8
   If I<4
    [M:STD0]CLE1(I) = evalue("[F:FFA_]"+INTCLE(I))
   Elsif I<8
    [M:STD0]CLE2(I-4) = evalue("[F:FFA_]"+INTCLE(I))
   Elsif I<12
    [M:STD0]CLE3(I-8) = evalue("[F:FFA_]"+INTCLE(I))
   Else
    [M:STD0]CLE4(I-12) = evalue("[F:FFA_]"+INTCLE(I))
   Endif
  When Default
   If I<4
    [M:STD0]CLE1(I) = num$(evalue("[F:FFA_]"+INTCLE(I)))
   Elsif I<8
    [M:STD0]CLE2(I-4) = num$(evalue("[F:FFA_]"+INTCLE(I)))
   Elsif I<12
    [M:STD0]CLE3(I-8) = num$(evalue("[F:FFA_]"+INTCLE(I)))
   Else
    [M:STD0]CLE4(I-12) = num$(evalue("[F:FFA_]"+INTCLE(I)))
   Endif
 Endcase
Next I
Onerrgo

For IMA=1 To NRMASK

 Onerrgo ERR_INTIT1
 For I=0 To NZ1(IMA)-1
  Case TYPZ1(IMA,I)
   When 8
    Assign "[M:M"+num$(IMA)+"]ZONE1("+num$(I)+")" With evalue("[F:FFA_]"+INTIT1(IMA,I))
   When 9,10 : # blob
   When Default
    Assign "[M:M"+num$(IMA)+"]ZONE1("+num$(I)+")" With num$(evalue("[F:FFA_]"+INTIT1(IMA,I)))
  Endcase
 Next I
 Onerrgo

 Onerrgo ERR_INTIT2
 For I=0 To NZ2(IMA)-1
  Case TYPZ2(IMA,I)
   When 8
    Assign "[M:M"+num$(IMA)+"]ZONE2("+num$(I)+")" With evalue("[F:FFA_]"+INTIT2(IMA,I))
   When 9,10 : # blob
   When Default
    Assign "[M:M"+num$(IMA)+"]ZONE2("+num$(I)+")" With num$(evalue("[F:FFA_]"+INTIT2(IMA,I)))
  Endcase
 Next I
 Onerrgo

 Onerrgo ERR_INTIT3
 For I=0 To NZ3(IMA)-1
  Case TYPZ3(IMA,I)
   When 8
    Assign "[M:M"+num$(IMA)+"]ZONE3("+num$(I)+")" With evalue("[F:FFA_]"+INTIT3(IMA,I))
   When 9,10 : # blob
   When Default
    Assign "[M:M"+num$(IMA)+"]ZONE3("+num$(I)+")" With num$(evalue("[F:FFA_]"+INTIT3(IMA,I)))
  Endcase
 Next I
 Onerrgo

Next IMA
If INTCLB<>"" | INTPHO<>"" | INTBUR<>"" : Gosub CHARGE From =PRGMNT : Endif

Return

#---------------------------#
$DECHARGE
nolign=1
Onerrgo ERR_INTCLE
For I=0 To NCLE-1
 Case TYPCL(I)
  When 7,8
   If I<4
    Assign "[F:FFA_]"+INTCLE(I) With [M:STD0]CLE1(I)
   Elsif I<8
    Assign "[F:FFA_]"+INTCLE(I) With [M:STD0]CLE2(I-4)
   Elsif I<12
    Assign "[F:FFA_]"+INTCLE(I) With [M:STD0]CLE3(I-8)
   Else
    Assign "[F:FFA_]"+INTCLE(I) With [M:STD0]CLE4(I-12)
   Endif
  When 11
   If I<4
    Assign "[F:FFA_]"+INTCLE(I) With toUuid([M:STD0]CLE1(I))
   Elsif I<8
    Assign "[F:FFA_]"+INTCLE(I) With toUuid([M:STD0]CLE2(I-4))
   Elsif I<12
    Assign "[F:FFA_]"+INTCLE(I) With toUuid([M:STD0]CLE3(I-8))
   Else
    Assign "[F:FFA_]"+INTCLE(I) With toUuid([M:STD0]CLE4(I-12))
   Endif
  When 12
   If I<4
    Assign "[F:FFA_]"+INTCLE(I) With gdatetime$([M:STD0]CLE1(I))
   Elsif I<8
    Assign "[F:FFA_]"+INTCLE(I) With gdatetime$([M:STD0]CLE2(I-4))
   Elsif I<12
    Assign "[F:FFA_]"+INTCLE(I) With gdatetime$([M:STD0]CLE3(I-8))
   Else
    Assign "[F:FFA_]"+INTCLE(I) With gdatetime$([M:STD0]CLE4(I-12))
   Endif
  When Default
   If I<4
    Assign "[F:FFA_]"+INTCLE(I) With val([M:STD0]CLE1(I))
   Elsif I<8
    Assign "[F:FFA_]"+INTCLE(I) With val([M:STD0]CLE2(I-4))
   Elsif I<12
    Assign "[F:FFA_]"+INTCLE(I) With val([M:STD0]CLE3(I-8))
   Else
    Assign "[F:FFA_]"+INTCLE(I) With val([M:STD0]CLE4(I-12))
   Endif
 Endcase
Next I
Onerrgo

Onerrgo ERR_INTIT1
For I=0 To NZ1(IMA)-1
 Case TYPZ1(IMA,I)
  When 7
   Assign "[F:FFA_]"+INTIT1(IMA,I) With evalue("[M:M"+num$(IMA)+"]ZONE1("+num$(I)+")")
  When 8
   Assign "[F:FFA_]"+INTIT1(IMA,I) With gdat$(left$(evalue("[M:M"+num$(IMA)+"]ZONE1("+num$(I)+")")+"00000000",8))
  When 9,10 : # Blob
  When 11 : # Uuid
   If GREP="C" or GREP="D"
    Assign "[F:FFA_]"+INTIT1(IMA,I) With getUuid
   Else
    Assign "[F:FFA_]"+INTIT1(IMA,I) With toUuid(evalue("[M:M"+num$(IMA)+"]ZONE1("+num$(I)+")"))
   Endif
  When 12 : # Datetime
   Assign "[F:FFA_]"+INTIT1(IMA,I) With gdatetime$(evalue("[M:M"+num$(IMA)+"]ZONE1("+num$(I)+")"))
  When Default
   Assign "[F:FFA_]"+INTIT1(IMA,I) With val(evalue("[M:M"+num$(IMA)+"]ZONE1("+num$(I)+")"))
 Endcase
Next I
Onerrgo

Onerrgo ERR_INTIT2
For I=0 To NZ2(IMA)-1
 Case TYPZ2(IMA,I)
  When 7
   Assign "[F:FFA_]"+INTIT2(IMA,I) With evalue("[M:M"+num$(IMA)+"]ZONE2("+num$(I)+")")
  When 8
   Assign "[F:FFA_]"+INTIT2(IMA,I) With gdat$(left$(evalue("[M:M"+num$(IMA)+"]ZONE2("+num$(I)+")")+"00000000",8))
  When 9,10 : # Blob
  When 11 : # Uuid
   If GREP="C" or GREP="D"
    Assign "[F:FFA_]"+INTIT2(IMA,I) With getUuid
   Else
    Assign "[F:FFA_]"+INTIT2(IMA,I) With toUuid(evalue("[M:M"+num$(IMA)+"]ZONE2("+num$(I)+")"))
   Endif
  When 12 : # Datetime
   Assign "[F:FFA_]"+INTIT2(IMA,I) With gdatetime$(evalue("[M:M"+num$(IMA)+"]ZONE2("+num$(I)+")"))
  When Default
   Assign "[F:FFA_]"+INTIT2(IMA,I) With val(evalue("[M:M"+num$(IMA)+"]ZONE2("+num$(I)+")"))
 Endcase
Next I
Onerrgo

Onerrgo ERR_INTIT3
For I=0 To NZ3(IMA)-1
 Case TYPZ3(IMA,I)
  When 7
   Assign "[F:FFA_]"+INTIT3(IMA,I) With evalue("[M:M"+num$(IMA)+"]ZONE3("+num$(I)+")")
  When 8
   Assign "[F:FFA_]"+INTIT3(IMA,I) With gdat$(left$(evalue("[M:M"+num$(IMA)+"]ZONE3("+num$(I)+")")+"00000000",8))
  When 9,10 : # Blob
  When 11 : # Uuid
   If GREP="C" or GREP="D"
    Assign "[F:FFA_]"+INTIT3(IMA,I) With getUuid
   Else
    Assign "[F:FFA_]"+INTIT3(IMA,I) With toUuid(evalue("[M:M"+num$(IMA)+"]ZONE3("+num$(I)+")"))
   Endif
  When 12 : # Datetime
   Assign "[F:FFA_]"+INTIT3(IMA,I) With gdatetime$(evalue("[M:M"+num$(IMA)+"]ZONE3("+num$(I)+")"))
  When Default
   Assign "[F:FFA_]"+INTIT3(IMA,I) With val(evalue("[M:M"+num$(IMA)+"]ZONE3("+num$(I)+")"))
 Endcase
Next I
Onerrgo

Return

#---------------------------#
$ERR_INTCLE
ERR_ZON=INTCLE(I)
Goto ERR
$ERR_INTIT1
ERR_ZON=INTIT1(IMA,I)
Goto ERR
$ERR_INTIT2
ERR_ZON=INTIT2(IMA,I)
Goto ERR
$ERR_INTIT3
ERR_ZON=INTIT3(IMA,I)
Goto ERR
$ERR
GOK=0 : Call ERREUR(errmes$(errn)-":"-ERR_ZON) From GESECRAN
Resume

#------------------------------------------------------------------#
# Etiquettes du masque GSTD
#------------------------------------------------------------------#

Subprog D_DOSSIER(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
GMODIF = 0
End

Subprog AS_DOSSIER(VALEUR)
Variable Char    VALEUR()
If !GMODIF : mkstat = 2 : Endif
GMODIF = 1
End

Subprog AS_FICH(VALEUR)
Variable Char     VALEUR
If GFILPATH="" : End : Endif
If [M]DOSSIER=nomap
 Local File ATABLE [ATB]
Else
 Local File =[M]DOSSIER+".ATABLE" [ATB]
Endif
Read [ATB]CODFIC = GFILPATH
If !fstat
 VALEUR = GFILPATH
Endif
End

Subprog C_FICH(VALEUR)
Variable Char VALEUR()
Local Char    MACHINE(GDIMFIC) , APPLI(GDIMFIC) , VOLUME(GDIMFIC) , FICHIER(GDIMFIC)
If [M]DOSSIER=nomap
 Local File ATABLE [ATB]
Else
 Local File =[M]DOSSIER+".ATABLE" [ATB]
Endif
Read [ATB]CODFIC = VALEUR
If fstat
 # Table non déclarée dans le dictionnaire
 Call ERREUR(VALEUR-mess(158,115,1)) From GESECRAN : mkstat=2 : End
Endif
Call MACHINE([M]DOSSIER,MACHINE,APPLI) From ORDSYS
Call VOLUME(MACHINE,APPLI,VOLUME) From ORDSYS
FICHIER = filpath("FIL",VALEUR,"fde",APPLI,VOLUME,MACHINE)
If filinfo(FICHIER,0)<0
 # Fichier inexistant
 Call ERREUR("|"+FICHIER-":"-mess(101,100,1)) From GESECRAN : mkstat=2 : End
Endif
GFILPATH = VALEUR
End

