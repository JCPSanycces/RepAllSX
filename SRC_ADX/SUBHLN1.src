# LS 29/12/98
# Lignes d'honoraires (saisie)

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M:DIA]FCY<>""
 VALEUR = [M:DIA]FCY
 mkstat = 2
 End
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & indice>0
 VALEUR = [M]FCY(indice-1)
 End
Endif
If VALEUR="" & indice=0
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2
 End
Endif
If [F:FCY]LEGCPY<>[M]CPY & !GIMPORT
 GMESSAGE = mess(30,106,1)-[F:FCY]LEGCPY : # Ce site est dans la société
 mkstat = 2
 End
Endif
If [F:FCY]FINFLG<>2
 GMESSAGE = mess(13,122,1) : # Site non financier
 mkstat = 2
 End
Endif
End

Subprog AS_PRVNUM(VALEUR)
Variable Char    VALEUR()
If [M:DIA]PRVNUM<>""
 VALEUR = [M:DIA]PRVNUM
 mkstat = 2
 End
Endif
End

Subprog C_PRVNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & indice>0
 VALEUR = [M]PRVNUM(indice-1)
 End
Endif
If VALEUR="" & indice=0
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2
 End
Endif
End

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:DIA]STRDAT | (VALEUR>[M:DIA]ENDDAT & [M:DIA]ENDDAT<>[00/00/00])
 GMESSAGE = mess(12,122,1)-format$(GFMD,[M:DIA]STRDAT)-"-"-format$(GFMD,[M:DIA]ENDDAT)
 # Date en dehors de la période
 mkstat = 2
 End
Endif
End

Subprog AM_AMTCUR(VALEUR)
Variable Decimal VALEUR
Local Integer STAT
If VALEUR<>0
 Call CONVERT([M]CUR(nolign-1),[M]CUR2,[M]CUR2,0,[M]DAT(nolign-1),VALEUR,
&             [M]AMTLOC(nolign-1),STAT) From TRTDEV
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char    VALEUR()
If [M]AMTCUR(nolign-1)<>0 & VALEUR="" 
 VALEUR = [M]CUR2
Elsif [M]AMTCUR(nolign-1)=0
 VALEUR = ""
Endif
End

Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
If [M]AMTCUR(nolign-1)<>0 & VALEUR=""
 ## Zone obligatoire
 GMESSAGE = mess(10,123,1)
 mkstat = 2 : End
Endif
Call CONTDEV(VALEUR,[M]DAT(nolign-1)) From TRTDEV
End

Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()
Local Integer STAT
If [M]AMTCUR(nolign-1)<>0
 Call CONVERT(VALEUR,[M]CUR2,[M]CUR2,0,[M]DAT(nolign-1),[M]AMTCUR(nolign-1),
&             [M]AMTLOC(nolign-1),STAT) From TRTDEV
Endif
End

Subprog AS_HON(VALEUR)
Variable Integer    VALEUR()
If [M:DIA]HON<>0
 VALEUR = [M:DIA]HON
 mkstat = 2
 End
Endif
End

Subprog AS_TYPHON(VALEUR)
Variable Char    VALEUR()
If !find([M]HON(indice),9,10,11)
 mkstat = 1
 End
Endif
End

Subprog C_TYPHON(VALEUR)
Variable Char    VALEUR()
Case [M]HON(indice)
 When 9  : Call VERIFTYPHON(VALEUR,"FRP")  : #Indemnités & Remboursements
 When 10 : Call VERIFTYPHON(VALEUR,"NLVA") : #Avantages en nature
 When 11 : Call VERIFTYPHON(VALEUR,"RD")   : #Retenues impôt s/revenu
Endcase
End

Subprog VERIFTYPHON(CHXHON,LISHON)
Variable Char    CHXHON()
Value    Char    LISHON()
Local    Char    VCHXHON(4)
Local    Integer I
If clalev([F:PRV])=0 : Local File HONPRV [PRV] : Endif
Read[PRV]PRV0=[M]PRVNUM(nolign-1)
VCHXHON = CHXHON
CHXHON  = ""
For I=1 To len(VCHXHON)
 Case mid$(VCHXHON,I,1)
  When "D"
   If [F:PRV]DFLG3=2 & LISHON="RD"  : CHXHON += "D" : Endif
  When "F"
   If [F:PRV]FFLG2=2 & LISHON="FRP" : CHXHON += "F" : Endif
  When "R"
   If [F:PRV]RFLG3=2 & LISHON="RD"  : CHXHON += "R" : Endif
   If [F:PRV]RFLG2=2 & LISHON="FRP" : CHXHON += "R" : Endif
  When "P"
   If [F:PRV]PFLG2=2 & LISHON="FRP" : CHXHON += "P" : Endif
  When "N"
   If [F:PRV]NFLG1=2 & LISHON="NLVA": CHXHON += "N" : Endif
  When "L"
   If [F:PRV]LFLG1=2 & LISHON="NLVA": CHXHON += "L" : Endif
  When "V"
   If [F:PRV]VFLG1=2 & LISHON="NLVA": CHXHON += "V" : Endif
  When "A"
   If [F:PRV]AFLG1=2 & LISHON="NLVA": CHXHON += "A" : Endif
  Endcase
Next I
VCHXHON = CHXHON
CHXHON  = ""
For I=1 To len(LISHON)
 If instr(1,VCHXHON,mid$(LISHON,I,1))
  CHXHON +=mid$(LISHON,I,1)
 Else
  CHXHON +=" "
 Endif
Next I
End

Subprog AVANT_NBLIG
[M]TOTAMTLOC -= [M]AMTLOC(nolign-1)
End

Subprog APRES_NBLIG
Local Integer STAT
[M]TOTAMTLOC += [M]AMTLOC(nolign-1)
Affzo [M]AMTLOC(nolign-1), TOTAMTLOC
End


########################################
# Bug 5570 : ajout de zoom (CP : 13/07/01)
Subprog IB_NBLIG
Local Integer NOL
Raz GBOUT1,GBOUT2

NOL = nolign-1
mkstat = 0
If NOL>=[M:HLN1]NBLIG | [M:HLN1]NBLIG=0 : End : Endif

## Bouton 1 : Zoom sur la facture
If [M:HLN1]TYPINV(NOL)<>"" and [M:HLN1]NUMINV(NOL)<>""
    
    If clalev([F:SIH])=0 : Local File SINVOICE  [SIH] : Endif
    If clalev([F:PIH])=0 : Local File PINVOICE  [PIH] : Endif 
    Read [F:SIH]SIH2 = [M:HLN1]TYPINV(NOL);[M:HLN1]NUMINV(NOL)
    If !fstat 
        Case [F:SIH]ORIMOD
            When 3 : GBOUT1 = mess(43,109,1) : # Facture tiers client
            When 5 : GBOUT1 = mess(45,109,1) : # Facture vente
        Endcase
    Elsif fstat=5
        Read [F:PIH]PIH2 = [M:HLN1]TYPINV(NOL);[M:HLN1]NUMINV(NOL)
        If !fstat        
            Case [F:PIH]ORIMOD
                When 3 : GBOUT1 = mess(44,109,1) : # Facture tiers fournisseur
                When 6 : GBOUT1 = mess(46,109,1) : # Facture achat
            Endcase
        Endif             
    Endif
Endif

## Bouton 2 : Zoom sur le réglement
If [M:HLN1]TYP(NOL)<>"" and [M:HLN1]NUM(NOL)<>""
    If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif
    Read [HAE]HAE0=[M:HLN1]TYP(NOL);[M:HLN1]NUM(NOL)
    If fstat : End : Endif
    If left$([F:HAE]REFINT,3)="PYH"
        GBOUT2 = mess(47,109,1) : # Règlement
    Endif
Endif
Close Local File
End


# Bug 5570
#########################################
## Tunnel vers les factures
#########################################
$B1_NBLIG
Raz GBIDC1
GCONSULT = 1
Case GBOUT1 
    When mess(43,109,1) : # Facture tiers client
        If clalev([F:SIH])=0 : Local File SINVOICE  [SIH] : Endif
        Call LECTURE("BIC",[M]NUMINV(nolign-1),"") From CONTOBJ
        If !fstat     
            GBIDC1 = "BIC"
            GBIDC2 = [M]NUMINV(nolign-1)
        Endif
    When mess(44,109,1) : # Facture tiers fournisseur
        If clalev([F:PIH])=0 : Local File PINVOICE  [PIH] : Endif
        Call LECTURE("BIS",[M]NUMINV(nolign-1),"") From CONTOBJ
        If !fstat
            GBIDC1="BIS"
            GBIDC2 = [M]NUMINV(nolign-1)
        Endif
    When mess(45,109,1) : # Facture vente
        If clalev([F:SIV])=0 : Local File SINVOICEV [SIV] : Endif
        Call LECTURE("SIH",[M]NUMINV(nolign-1),"") From CONTOBJ
        If !fstat
            GBIDC1="SIH"
            GBIDC2 = [M]NUMINV(nolign-1)
        Endif
    When mess(46,109,1) : # Facture achat
        If clalev([F:PIH])=0 : Local File PINVOICE [PIH] : Endif 
        Call LECTURE("PIH",[M]NUMINV(nolign-1),"") From CONTOBJ
        If !fstat
            GBIDC1="PIH"
            GBIDC2 = [M]NUMINV(nolign-1)
        Endif
Endcase
Close Local File
End

# Bug 5570 
#########################################
## Tunnel vers les règlements
#########################################
$B2_NBLIG
Local Char PYHNUM(GLONVCR)
Raz GBIDC1, GBIDC2
GCONSULT = 1
If clalev([F:PYH])=0 : Local File PAYMENTH  [PYH] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif
Read [HAE]HAE0=[M:HLN1]TYP(nolign-1);[M:HLN1]NUM(nolign-1)
If fstat : End : Endif
PYHNUM = vireblc(right$([F:HAE]REFINT,5),2)
Read [PYH]PYH0 = PYHNUM
If !fstat
   GBIDC1 = "PAY" 
   GBIDC2 = PYHNUM
Endif
End
