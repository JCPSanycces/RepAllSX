#<AdxTL>@(#)8.0.0.0 $Revision$
###############################################################################
# on doit avoir un paramétrage des tarifs tel que :
#    PLICRI1 = référence article
#    PLICRI2 = site de vente
#   
#    GIMP(1)    désignation article
#    GIMP(2)    désignation unité
#    GIMP(3)    montant en euro 
#   
#    GIMP(5)    désignation attribut alpha 1
#    GIMP(6)    désignation attribut alpha 2
#    GIMP(7)    désignation attribut alpha 3
#    GIMP(8)    désignation attribut alpha 4
#    GIMP(9)    désignation attribut alpha 5
#    GIMP(10)   désignation attribut alpha 6
#    
#    GIMP(11)   attribut num 1
#    GIMP(12)   désignation attribut num 1
#    GIMP(13)   attribut num 2
#    GIMP(14)   désignation attribut num 2
#    GIMP(15)   attribut num 3
#    GIMP(16)   désignation attribut num 3
#    GIMP(17)   attribut num 4
#    GIMP(18)   désignation attribut num 4
#    GIMP(19)   attribut num 5
#    GIMP(20)   désignation attribut num 5
#    GIMP(21)   attribut num 6
#    GIMP(22)   désignation attribut num 6
#
###############################################################################
$ACTION
Case ACTION
        When "EXP_OUVRE" : Gosub EXP_OUVRE
        When "EXPORT"    : Gosub EXPORT
        When Default
Endcase
Return

###############################################################################
$EXP_OUVRE
If clalev([F:ITM])=0    : Local File ITMMASTER  [ITM]   : Endif
If clalev([F:CPY])=0    : Local File COMPANY    [CPY]   : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
If clalev([F:TCY])=0    : Local File TABCOUNTRY [TCY]   : Endif
If clalev([F:TUN])=0    : Local File TABUNIT    [TUN]   : Endif
If clalev([F:TCU])=0    : Local File TABCUR     [TCU]   : Endif
If clalev([F:AXX])=0    : Local File ATEXTRA    [AXX]   : Endif
If clalev([F:SPC])=0    : Local File SPRICCONF  [SPC]   : Endif
If clalev([F:TLP])=0    : Local File TABLINCFG  [TLP]   : Endif
If clalev([F:TCT])=0    : Local File TABCTL     [TCT]   : Endif
Return

###############################################################################
$EXPORT
######### EXTRACTION ########
#------------------------------------------------------#
#  extraction des tarifs valides pour la date du jour  #
#------------------------------------------------------#
If [F:SPL]PLISTRDAT > date$ | [F:SPL]PLIENDDAT < date$ : OK = 0 : Return : Endif

#------------------------------------------------------#
#  extraction des tarifs sur quantité de 1             #
#------------------------------------------------------#
If [F:SPL]MINQTY > 1 : OK = 0: Return : Endif

#------------------------------------------------------#
#  extraction des tarifs type normal                   #
#------------------------------------------------------#
Read [SPC]SPC0=[F:SPL]PLI
If fstat : Raz [F:SPC] : Endif
If [F:SPC]PLITYP<>1 : OK = 0: Return : Endif

#----------------------------------------------------------------#
#  extraction des tarifs :                                       #
#    DEVISE = devise site de vente                               #
#    DEVISE <>devise site de vente & conversion devise autorisée #
#----------------------------------------------------------------#

#--- Lecture du site de vente
Read [FCY]FCY0=[F:SPL]PLICRI2
If fstat : Raz [F:FCY] : Endif

#--- Lecture du pays lié au site de vente (--> devise,langue)
Read [TCY]TCY0=[F:FCY]CRY
If fstat : Raz [F:TCY] : Endif

If [F:SPL]CUR <> [F:TCY]CUR and [F:SPC]CURCNVFLG=1: OK = 0: Return : Endif

#--- Lecture de la société (--> devise)
Read [CPY]CPY0=[F:FCY]LEGCPY
If fstat : Raz [F:CPY] : Endif

#--- Application du diviseur de prix
If [F:SPL]PRIDIV <> 0 & [F:SPL]PRIDIV <> 1 
   [F:SPL]PRI /= [F:SPL]PRIDIV
Endif

#--- conversion du prix dans la devise du site
Call CONVERT([F:SPL]CUR,[F:TCY]CUR,[F:CPY]ACCCUR,1,date$,[F:SPL]PRI,[F:SPL]PRI,GBIDI2) From TRTDEV
If GBIDI2 <> 0 : OK = 0 : Return : Endif



######### ALIMENTATION #################################

#------------------------------------------------------#
#  désignation article dans la langue du site          #
#------------------------------------------------------#
#--- Lecture des articles (--> no texte des.art)
Read [ITM]ITM0=[F:SPL]PLICRI1
If fstat : Raz [F:ITM] : Endif

#--- Lecture des textes (--> des.art)
#Read [AXX]AXX0=[F:TCY]LAN;[F:ITM]ITMNUM1
#Read [AXX]AXX0="ITMMASTER";"DES1AXX";[F:TCY]LAN;[F:ITM]ITMREF;""                       # FGR 30/06/2009 : X3SUIVI56189
#If fstat : Raz [F:AXX] : Endif                                                         # FGR 30/06/2009 : X3SUIVI56189
#GIMP(1) = [F:AXX]TEXTE                                                                 # FGR 30/06/2009 : X3SUIVI56189
#If GIMP(1)="" : GIMP(1)=[F:ITM]ITMDES1 : Endif                                         # FGR 30/06/2009 : X3SUIVI56189
Call CHARGE_DEFITMDES("DES1AXX",[F:TCY]LAN,[F:ITM]ITMREF,GIMP(1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189

#------------------------------------------------------#
#  désignation unité dans la langue du site            #
#------------------------------------------------------#
#--- Lecture des unites (--> no texte des.unité)
Read [TUN]TUN0=[F:SPL]UOM
If fstat : Raz [F:TUN] : Endif

#--- Lecture des textes (--> des.unité)
#Read [AXX]AXX0=[F:TCY]LAN;[F:TUN]DESNUM
Read [AXX]AXX0="TABUNIT";"DES";[F:TCY]LAN;[F:TUN]UOM;""
If fstat : Raz [F:AXX] : Endif

GIMP(2) = [F:AXX]TEXTE
#If GIMP(2)="" : GIMP(2)=[F:TUN]UOMDES : Endif 

#------------------------------------------------------#
#  conversion en euro                                  #
#------------------------------------------------------#
Read [TCU]TCU0=[F:TCY]CUR
If fstat : Raz [F:TCU] : Endif
If [F:TCU]EURFLG = 2 & [F:TCU]EURRAT <> 0
   GIMP(3) = num$(ar2([F:SPL]PRI/[F:TCU]EURRAT))
Else Raz GIMP(3)
Endif

#------------------------------------------------------#
# désignations attributs alpha                         #
#------------------------------------------------------#
#--- Lecture de la ligne de produit
Read [TLP]TLP0=[F:ITM]CFGLIN
If fstat : Raz [F:TLP] : Endif

# -- alim des désignations attributs alpha
Read [TCT]TCT1=[TLP]CFGALPTCT1;[F:ITM]CFGFLDALP1;0
If !fstat : GIMP(5)=[F:TCT]DESCOD Else GIMP(5)=[F:ITM]CFGFLDALP1: Endif

Read [TCT]TCT1=[TLP]CFGALPTCT2;[F:ITM]CFGFLDALP2;0
If !fstat : GIMP(6)=[F:TCT]DESCOD Else GIMP(6)=[F:ITM]CFGFLDALP2: Endif

Read [TCT]TCT1=[TLP]CFGALPTCT3;[F:ITM]CFGFLDALP3;0
If !fstat : GIMP(7)=[F:TCT]DESCOD Else GIMP(7)=[F:ITM]CFGFLDALP3: Endif

Read [TCT]TCT1=[TLP]CFGALPTCT4;[F:ITM]CFGFLDALP4;0
If !fstat : GIMP(8)=[F:TCT]DESCOD Else GIMP(8)=[F:ITM]CFGFLDALP4: Endif

Read [TCT]TCT1=[TLP]CFGALPTCT5;[F:ITM]CFGFLDALP5;0
If !fstat : GIMP(9)=[F:TCT]DESCOD Else GIMP(9)=[F:ITM]CFGFLDALP5: Endif
 
Read [TCT]TCT1=[TLP]CFGALPTCT6;[F:ITM]CFGFLDALP6;0
If !fstat : GIMP(10)=[F:TCT]DESCOD Else GIMP(10)=[F:ITM]CFGFLDALP6: Endif


#------------------------------------------------------#
# désignations attributs numérique                     #
#------------------------------------------------------#

Raz GIMP(11), GIMP(12), GIMP(13), GIMP(14), GIMP(15), GIMP(16), GIMP(17)
Raz GIMP(18), GIMP(19), GIMP(20), GIMP(21), GIMP(22)

If [F:ITM]CFGFLDNUM1 <> 0
   GIMP(11) = [F:ITM]CFGFLDNUM1 
   Read [TCT]TCT1=[TLP]CFGNUMTCT1;"";[F:ITM]CFGFLDNUM1
   If !fstat : GIMP(12)=[F:TCT]DESCOD Else GIMP(12)=num$([F:ITM]CFGFLDNUM1): Endif
Endif 

If [F:ITM]CFGFLDNUM2 <> 0
   GIMP(13) = [F:ITM]CFGFLDNUM2 
   Read [TCT]TCT1=[TLP]CFGNUMTCT2;"";[F:ITM]CFGFLDNUM2
   If !fstat : GIMP(14)=[F:TCT]DESCOD Else GIMP(14)=num$([F:ITM]CFGFLDNUM2): Endif
Endif 

If [F:ITM]CFGFLDNUM3 <> 0
   GIMP(15) = [F:ITM]CFGFLDNUM3 
   Read [TCT]TCT1=[TLP]CFGNUMTCT3;"";[F:ITM]CFGFLDNUM3
   If !fstat : GIMP(16)=[F:TCT]DESCOD Else GIMP(16)=num$([F:ITM]CFGFLDNUM3): Endif
Endif 

If [F:ITM]CFGFLDNUM4 <> 0
   GIMP(17) = [F:ITM]CFGFLDNUM4 
   Read [TCT]TCT1=[TLP]CFGNUMTCT4;"";[F:ITM]CFGFLDNUM4
   If !fstat : GIMP(18)=[F:TCT]DESCOD Else GIMP(18)=num$([F:ITM]CFGFLDNUM4): Endif
Endif 

If [F:ITM]CFGFLDNUM5 <> 0
   GIMP(19) = [F:ITM]CFGFLDNUM5
   Read [TCT]TCT1=[TLP]CFGNUMTCT5;"";[F:ITM]CFGFLDNUM5
   If !fstat : GIMP(20)=[F:TCT]DESCOD Else GIMP(20)=num$([F:ITM]CFGFLDNUM5): Endif
Endif 

If [F:ITM]CFGFLDNUM6 <> 0
   GIMP(21) = [F:ITM]CFGFLDNUM6
   Read [TCT]TCT1=[TLP]CFGNUMTCT6;"";[F:ITM]CFGFLDNUM6
   If !fstat : GIMP(22)=[F:TCT]DESCOD Else GIMP(22)=num$([F:ITM]CFGFLDNUM6): Endif
Endif 
Return 
