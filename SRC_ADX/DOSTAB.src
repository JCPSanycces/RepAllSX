#<AdxTL>@(#)10.0.0.0 $Revision$
###################################################
Subprog TRIGGER
# Création/MAJ des triggers
Onerrgo ERREUR

Local Integer I , J , K , NOMBRE , NBTAB
Local Char    OBJET(GLONATB) , TBTAB(GLONATB)(1..10)


# valdiation trigger si lmodif sur AUDITH ou AUDITBI
If !GVALIDE(1)
 Local Integer OKTRIG
 Local File =[F:ADS]DOSSIER+".ATABLE" [SATB]
 Read [SATB]CODFIC="AUDITH"
 If !fstat and [SATB]UPDFLG=1
  OKTRIG = 1
 Endif
 If !OKTRIG
  Read [SATB]CODFIC="AUDITBI"
  If !fstat and [SATB]UPDFLG=1
   OKTRIG = 1
  Endif
 Endif
 If OKTRIG = 1
  Call TRIGGER_ALL : End
 Endif
 Close Local File
Endif

If GINFO
 Call AFF_VLC(mess(234,125,1),"") From GESECRAN
# MAJ des triggers
Endif
Call ECR_TIME(mess(234,125,1)) From DOSSUB

# Mise à jour du trigger sur les tables superviseur pour éviter une erreur "changement de schéma"

NBTAB = 0
If GVALIDE(1)
 NBTAB += 1 : TBTAB(NBTAB) = "ATABLE"
 NBTAB += 1 : TBTAB(NBTAB) = "ATABIND"
 NBTAB += 1 : TBTAB(NBTAB) = "ATABZON"
 NBTAB += 1 : TBTAB(NBTAB) = "ATEXTE"
 NBTAB += 1 : TBTAB(NBTAB) = "ATYPE"
 NBTAB += 1 : TBTAB(NBTAB) = "ACTIV"
 NBTAB += 1 : TBTAB(NBTAB) = "AINDEX"
Else
 Local File =[F:ADS]DOSSIER+".ATABLE" [ATB]
 For OBJET="ATABLE","ATABIND","ATABZON","ATEXTE","ATYPE","ACTIV","AINDEX"
  Read [ATB]CODFIC=OBJET
  If !fstat & [F:ATB]UPDFLG=1
   NBTAB += 1 : TBTAB(NBTAB) = OBJET
  Endif
 Next OBJET
 Close Local File
Endif

For I=1 To NBTAB
 Local File =[F:ADS]DOSSIER+".ATABLE"  [ATB]
&          ,=[F:ADS]DOSSIER+".ATABIND" [ATI]
&          ,=[F:ADS]DOSSIER+".ATABZON" [ATZ]
&          ,=[F:ADS]DOSSIER+".ATEXTE"  [ATX]
&          ,=[F:ADS]DOSSIER+".ATYPE"   [ATY]
&          ,=[F:ADS]DOSSIER+".ACTIV"   [ACV]
&          ,=[F:ADS]DOSSIER+".AINDEX"  [ANX]
 Call MAJTRIG(TBTAB(I))
 Close Local File
Next I

# Mise à jour des autres tables

 Local File =[F:ADS]DOSSIER+".ATABLE"  [ATB]
&          ,=[F:ADS]DOSSIER+".ATABIND" [ATI]
&          ,=[F:ADS]DOSSIER+".ATABZON" [ATZ]
&          ,=[F:ADS]DOSSIER+".ATEXTE"  [ATX]
&          ,=[F:ADS]DOSSIER+".ATYPE"   [ATY]
&          ,=[F:ADS]DOSSIER+".ACTIV"   [ACV]
&          ,=[F:ADS]DOSSIER+".AINDEX"  [ANX]

If GVALIDE(1)
 GNBTBL = nbrecord([ATB])
Else
 Filter [ATB] Where UPDFLG=1 & TYPFIC<3 & CODFIC<GXX : # Superviseur et applicatif
 GNBTBL = rowcount([ATB])
Endif

Read [ATB]CODFIC First : # Pour éviter un "snapshot too old"
NOMBRE = 0
While fstat<=2
 NOMBRE += 1
 If !find([F:ATB]CODFIC,TBTAB(1..NBTAB))
  OBJET = [F:ATB]CODFIC
  If GINFO
   Call AFF_VLC(mess(234,125,1),mess(56,123,1)-[F:ATB]CODFIC-num$(NOMBRE)+"/"+num$(GNBTBL)) From GESECRAN
   # Table
  Endif
  Call MAJTRIG([F:ATB]CODFIC)
 Endif
 Read [ATB]CODFIC Next
Wend
Filter [ATB]

# Mise à jour des tables dico

If !GVALIDE(1)
 For [ATB] Where TYPFIC=4 & CODFIC<GXX & find(CODFIC,TBTAB(1..NBTAB))=0 & UPDFLG=1
  If GINFO
   Call AFF_VLC(mess(234,125,1),mess(56,123,1)-[F:ATB]CODFIC) From GESECRAN
  Endif
  Call MAJTRIG([F:ATB]CODFIC)
  If GERRDOS : Break : Endif
 Next ATB
Endif

Close Local File
End

###################################################
Subprog TRIGGER_ALL

Onerrgo ERREUR

If dim(GXX)<0
 Global Char    GXX(10)
 If GADONIX=2
  GXX = "X"       : # Chez nous on s'arrête là
 Else
  GXX = chr$(255) : # Chez le client on recopie les spécifiques
 Endif
Endif

Local File =[F:ADS]DOSSIER+".ATABLE"  [ATB]
&         ,=[F:ADS]DOSSIER+".ATABIND" [ATI]
&         ,=[F:ADS]DOSSIER+".ATABZON" [ATZ]
&         ,=[F:ADS]DOSSIER+".ATEXTE"  [ATX]
&         ,=[F:ADS]DOSSIER+".ATYPE"   [ATY]
&         ,=[F:ADS]DOSSIER+".ACTIV"   [ACV]
&         ,=[F:ADS]DOSSIER+".AINDEX"  [ANX]

Local Integer I , J , K , NOMBRE

If GINFO
 Call AFF_VLC(mess(234,125,1),"") From GESECRAN
# MAJ structure tables
Endif
Call ECR_TIME(mess(234,125,1)) From DOSSUB

Filter [ATB] Where TYPFIC=4 & CODFIC<GXX : # Dictionnaire
GNBTBL = rowcount([ATB])

Read [ATB]CODFIC First : # Pour éviter un "snapshot too old"
NOMBRE = 0
While fstat<=2
 NOMBRE += 1
 If GINFO
  Call AFF_VLC(mess(29,125,1),mess(56,123,1)-[F:ATB]CODFIC-num$(NOMBRE)+"/"+num$(GNBTBL)) From GESECRAN # Table
 Endif
 Call MAJTRIG([F:ATB]CODFIC)
 Read [ATB]CODFIC Next
Wend
Filter [ATB]

Filter [ATB] Where TYPFIC<3 & CODFIC<GXX : # Superviseur et applicatif
GNBTBL = rowcount([ATB])

Read [ATB]CODFIC First : # Pour éviter un "snapshot too old"
NOMBRE = 0
While fstat<=2
 NOMBRE += 1
 If GINFO
  Call AFF_VLC(mess(29,125,1),mess(56,123,1)-[F:ATB]CODFIC-num$(NOMBRE)+"/"+num$(GNBTBL)) From GESECRAN # Table
 Endif
 Call MAJTRIG([F:ATB]CODFIC)
 Read [ATB]CODFIC Next
Wend
Filter [ATB]
Close Local File
Onerrgo
End

###################################################
Subprog TABLEHIS(APPLI,HISTO,ALLTABLES,DICOVIEW,NOM)
Value Char    APPLI
Value Char    HISTO
Value Integer ALLTABLES,DICOVIEW
Value Char NOM

If func DOSVUE.ISVIEW(HISTO,"ATABLE") | func DOSVUE.ISVIEW(HISTO,"ATABZON") |  func DOSVUE.ISVIEW(HISTO,"ATABIND")
End
Endif

Local Char HISCOE(50)
Local Integer I , J , K , NOMBRE
Local Char    OBJET(GLONATB)
Local Char    LTAB(GLONATB)(1..)
Local Integer HISPTR,FORCE
Local Integer NBTAB,NOTAB
Local Integer NBFIC , NBREQ

Local Char CRITERE(100)
If !ALLTABLES
 CRITERE="CODFIC='"+NOM+"'"
Else
 CRITERE="1=1"
 If GINFO
  Call AFF_VLC(mess(29,125,1),"") From GESECRAN
 # MAJ structure tables
 Endif
 Call ECR_TIME(mess(29,125,1)) From DOSSUB
Endif
#mise à jour des dico du dossier histo
# Création/MAJ des structures des tables autres que dico
Onerrgo ERREUR

Local File =APPLI+".ATABLE"  [SATB]
&         ,=APPLI+".ATABIND" [SATI]
&         ,=APPLI+".ATABZON" [SATZ]

NBTAB=0
If !ALLTABLES
 For [SATB] Where evalue(CRITERE)
  NBTAB+=1
  LTAB(NBTAB)=[F:SATB]CODFIC
 Next
Else
 For [SATB] Where find(TYPFIC,1,2,4)<>0 & CODACT<>"MIG" & CODFIC<GXX
  NBTAB+=1
  LTAB(NBTAB)=[F:SATB]CODFIC
 Next
Endif


Local File =HISTO+".ATABLE"  [ATB]
&         ,=HISTO+".ATABIND" [ATI]
&         ,=HISTO+".ATABZON" [ATZ]

For NOTAB=1 To NBTAB
 If !ALLTABLES
   OBJET=LTAB(NOTAB)
   Gosub TR0
   Gosub TR1
 Else
  If func DOSVUE.ISVIEW(HISTO, LTAB(NOTAB))=0
   OBJET=LTAB(NOTAB)
   Gosub TR0
   Gosub TR1
  Endif
 Endif
Next I

If ALLTABLES
 # ne pas verifier les tables avec CODACT="MIG"
 For [ATB] Where CODACT<>"MIG"
  Read [SATB]CODFIC=[F:ATB]CODFIC
  If fstat
   OBJET=[F:ATB]CODFIC
   Gosub TR0
  Endif
 Next

 Call PURGE_TABLES(HISTO) From DOSMAJATB
 Call GETPAR(APPLI,"HISCOE",HISCOE) From SUBADS
 Close Local File

 For NOTAB=1 To NBTAB
  If func DOSVUE.ISVIEW(HISTO, LTAB(NOTAB))=0
   OBJET=LTAB(NOTAB)
   FORCE=0
   Call CRETABLE(APPLI,HISTO,[F:ADS]TYPDBA,OBJET,max(1,val(HISCOE)),FORCE) From CREHISTO :# sans dico
  Endif
 Next
Else
 Close Local File :#109304
Endif
Onerrgo
End

$TR0
HISPTR=0
Trbegin [ATB]
 If GPRODUIT=1
  Read [ATZ]CODZONE=OBJET;"HISPTR"
  If fstat=0
   HISPTR=1
  Endif
 Endif
 Delete [ATB] Where CODFIC=OBJET
 Delete [ATZ] Where CODFIC=OBJET
 Delete [ATI] Where CODFIC=OBJET
Commit
Return

$TR1
#HISPTR=0
Trbegin [ATB]
 Read [SATB]CODFIC=OBJET
 [F:ATB]=[F:SATB]
 Write [F:ATB]
 If fstat
  GOK = 0 : Call FSTA("ATB") From GLOCK : Goto AB_TR1
 Endif
 #
 I=0
 For [SATZ] Where CODFIC=OBJET
  I+=1
  [F:ATZ]=[F:SATZ]
  Write [F:ATZ]
  If fstat
   GOK = 0 : Call FSTA("ATZ") From GLOCK : Goto AB_TR1
  Endif
 Next
 #
 If ALLTABLES | !DICOVIEW
  Raz [F:ATZ]
  I+=1
  [F:ATZ]CODFIC=OBJET
  [F:ATZ]NUMLIG=I
  [F:ATZ]CODZONE="CREHISDAT"
  [F:ATZ]DIME=1
  [F:ATZ]CODTYP="D"
  [F:ATZ]OBLIG=1
  [F:ATZ]ZERO=1
  #texte 8713 : Interne X3
  [F:ATZ]NOCOURT=8713
  [F:ATZ]NOLONG=8713
  [F:ATZ]NOABREG=8713
  Write [F:ATZ]
  If fstat
   GOK = 0 : Call FSTA("ATZ") From GLOCK : Goto AB_TR1
  Endif
  #
  Raz [F:ATZ]
  I+=1
  [F:ATZ]CODFIC=OBJET
  [F:ATZ]NUMLIG=I
  [F:ATZ]CODZONE="CREHISUSR"
  [F:ATZ]DIME=1
  [F:ATZ]CODTYP="A"
  [F:ATZ]LONG=GLONAUS
  [F:ATZ]OBLIG=1
  [F:ATZ]ZERO=1
  #texte 8713 : Interne X3
  [F:ATZ]NOCOURT=8713
  [F:ATZ]NOLONG=8713
  [F:ATZ]NOABREG=8713
  Write [F:ATZ]
  If fstat
   GOK = 0 : Call FSTA("ATZ") From GLOCK : Goto AB_TR1
  Endif
 Endif
 #
 I=0
 For [SATI] Where CODFIC=OBJET
  I+=1
  [F:ATI]=[F:SATI]
  Write [F:ATI]
  If fstat
   GOK = 0 : Call FSTA("ATI") From GLOCK : Goto AB_TR1
  Endif
 Next
 If ALLTABLES | !DICOVIEW
  If HISPTR
   I+=1
   Raz [F:ATI]
   [F:ATI]CODFIC=OBJET
   [F:ATI]NUMLIG=I
   [F:ATI]CODIND="HISPTR"
   [F:ATI]DESCRIPT="HISPTR"
   [F:ATI]HOMONYM=2
   Write [F:ATI]
   If fstat
    GOK = 0 : Call FSTA("ATI") From GLOCK : Goto AB_TR1
   Endif
  Endif
 Endif
Commit
Return

$AB_TR1
Rollback
Return

###################################################
Subprog TABLE
# Création/MAJ des structures des tables autres que dico
# Tables de X3
# Tables du dossier
Onerrgo ERREUR

Local File =[F:ADS]DOSSIER+".ATABLE"  [ATB]
&         ,=[F:ADS]DOSSIER+".ATABIND" [ATI]
&         ,=[F:ADS]DOSSIER+".ATABZON" [ATZ]
&         ,=[F:ADS]DOSSIER+".ATEXTE"  [ATX]
&         ,=[F:ADS]DOSSIER+".ATYPE"   [ATY]
&         ,=[F:ADS]DOSSIER+".ACTIV"   [ACV]
&         ,=[F:ADS]DOSSIER+".AINDEX"  [ANX]

Local Integer I , J , K , NOMBRE
Local Char    OBJET(GLONATB)
Local Char    SCRIPT(250)(1..100) , REQUETE(250)(1..100) , LIGNE(250) , FILSCRIPT(250)
Local Char    IDENT(20) , RACINE(20)
Local Integer NBFIC , NBREQ

If GINFO
 Call AFF_VLC(mess(29,125,1),"") From GESECRAN
# MAJ structure tables
Endif
Call ECR_TIME(mess(29,125,1)) From DOSSUB

If GVALIDE(1)
 GNBTBL = nbrecord([ATB])
Else
 Filter [ATB] Where UPDFLG=1 & TYPFIC<3 & CODFIC<GXX : # Superviseur et applicatif
 GNBTBL = rowcount([ATB])
Endif
Read [ATB]CODFIC First : # Pour éviter un "snapshot too old"
NOMBRE = 0
While fstat<=2
 NOMBRE += 1
 OBJET = [F:ATB]CODFIC
 If GINFO
  Call AFF_VLC(mess(29,125,1),mess(56,123,1)-[F:ATB]CODFIC-num$(NOMBRE)+"/"+num$(GNBTBL)) From GESECRAN
# Table
 Endif
 Call MAJTAB([F:ATB]CODFIC,0)
 Call MAJTRIG([F:ATB]CODFIC)
 Read [ATB]CODFIC Next
Wend
Filter [ATB]
Close Local File

# Exécution de scripts (création de vues, ...)

IDENT = "%nomap%"
If GCRE
 RACINE = "credos"
Else
 RACINE = "majdos"
Endif
Call SYSTEME2(adxmac(0),'lsadx -a "'+GDOSREF-GDOSX3+'" PCD sql','',NBFIC,SCRIPT) From ORDSYS
For I=1 To NBFIC
 If left$(SCRIPT(I),len(RACINE))=RACINE
  NBREQ = 0
  fstat = 0
  FILSCRIPT = filpath("PCD",SCRIPT(I),"sql",GDOSREF)
  Openi FILSCRIPT
  Rdseq LIGNE
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   If LIGNE<>"" & left$(LIGNE,1)<>"#"
    Repeat
     K = instr(1,toupper(LIGNE),toupper(IDENT))
     If K
      LIGNE = left$(LIGNE,K-1)+[F:ADS]DOSSIER+right$(LIGNE,K+len(IDENT))
     Endif
    Until K=0
    NBREQ += 1
    REQUETE(NBREQ) = LIGNE
   Endif
   Rdseq LIGNE
  Wend
  Openi
  If NBREQ
#  Quand ça marchera
   Local Char BASE(1)
   Case [F:ADS]TYPDBA
    When 1 : BASE = "3"
    When 2 : BASE = "5"
    When 3 : BASE = "2"
    When 4 : BASE = "4"
   Endcase
   Execsql From BASE Sql REQUETE(1..NBREQ)
  Endif
 Endif
Next I
Onerrgo
End

###########################################################
Subprog MAJTABDOS(DOSSIER,TABLE,FORCE)
Value Char    DOSSIER
Value Char    TABLE
Value Integer FORCE
Local Char    APPLI(GLONADS) , MACHINE(GDIMFIC) , VOLUME(GDIMFIC)
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Call VOLUME(MACHINE,APPLI,VOLUME) From ORDSYS
#107271
If func DOSSUB.ISHISTFOLD(APPLI)
  Local Integer OKC
  If func DOSVUE.ISVIEW(APPLI,TABLE)
   Call SUPVUE_SIL([F:ADS]DOSREF,APPLI,[F:ADS]TYPDBA,TABLE,OKC) From CREHISTO
   OKC = 1
   Call CREVUE([F:ADS]DOSREF,APPLI,[F:ADS]TYPDBA,TABLE,OKC) From CREHISTO
   If !OKC
    Call ECR_TRACE(mess(6,123,1)-mess(148,125,1)-APPLI+"."+TABLE,0) From GESECRAN : # Erreur
    GERRDOS=1
   Endif
  Else
   Gosub FICSRF_HIST
   Call VALFILH(APPLI,TABLE,FORCE)
  Endif
  End
Endif
Goto MAJTABVAL

###########################################################
Subprog MAJTAB(TABLE,FORCE)
Value Char    TABLE
Value Integer FORCE
Local Char    APPLI(GLONADS) , MACHINE(GDIMFIC) , VOLUME(GDIMFIC)
APPLI   = [F:ADS]DOSSIER
VOLUME  = [F:ADS]VOLUME
MACHINE = adxmac(0)
#107271
If func DOSSUB.ISHISTFOLD(APPLI)
  Local Integer OKC
  If func DOSVUE.ISVIEW(APPLI,TABLE)
   Call SUPVUE_SIL([F:ADS]DOSREF,APPLI,[F:ADS]TYPDBA,TABLE,OKC) From CREHISTO
   OKC = 1
   Call CREVUE([F:ADS]DOSREF,APPLI,[F:ADS]TYPDBA,TABLE,OKC) From CREHISTO
   If !OKC
    Call ECR_TRACE(mess(6,123,1)-mess(148,125,1)-APPLI+"."+TABLE,0) From GESECRAN : # Erreur
    GERRDOS=1
   Endif
  Else
   Gosub FICSRF_HIST
   Call VALFILH(APPLI,TABLE,FORCE)
  Endif
  End
Endif

$MAJTABVAL
Local Integer STAT , DIFF , OK , EXISTE , REPET , VUE
Local Char    FNOMFIC(GDIMFIC) , FOLDFIC(GDIMFIC) , FICTRA(GDIMFIC)
Local Char    FNEWFIC(GDIMFIC) , FICCFG(GDIMFIC)
Local Char    MESSAGE(250)(1..5) , MESSA1(250)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Char    FINITIAL(20), OINITIAL(20) , FNEXT(20), FPCTINC(20)
Local Integer ONZON, ONIND
Local Char    OBID(250) , OABR(GLONABR) , ODBA(5)
Local Integer CDBA , KDBA , TDBA , MEXT
Local Char    ONOM(GLONAVA)(1..500), OTYP(5)(1..500), OLNG(5)(1..500)
Local Char    OREPET(5)(1..500) , OVERFIC(1)
# Issue 85234 - 2013-01-07 by VPO : autoriser 19 index : 15 sur ATABIND [ATI] + 4 AINDEX [ANX]
Local Char    ONOMCLE(GLONANX)(1..19), OTYPCLE(2)(1..19), OINDEX(250)(1..19) , ODECLI(2)(1..19)
Local Char    NNOMCLE(GLONANX)(1..19), NTYPCLE(2)(1..19), NINDEX(250)(1..19) , NDECLI(2)(1..19)
Local Integer I , J , K , NBZONE, NBINDEX, LNGENR, NBRIND
Local Integer LNGCLE, PARCLE, NBZTAB, TYPZON
Local Decimal TAILLE , LNGZON , LNGTOT , LNGDEC
Local Char    ORDSYS(GDIMFIC)(1..2)
Local Char    TEXTE(250) , STORAGE(250)
Local Decimal MAXCOL , MAXLNGCLE , MAXPARCLE , MAXLNG , MAXZON
Local Decimal NBBLOB , LGBLOB , MAXBLOB
Local Char    VERFIC(1)
Local Char    CHAINE(250) , CLE(20) , DESCRIPT(120)
Local Integer CLUSTER
Local Integer DEFCLUSTER #X3-100003 8/8/2018

If GTRACE<>""
 Call ECR_TRACE(mess(41,125,1)-TABLE,0) From GESECRAN : # Validation de la table
Endif

Read [ATB]CODFIC = TABLE
If fstat
 Call ECR_TRACE(TABLE-":"-mess(17,123,1),1) From GESECRAN : # Table non définie
 End
Endif
If [F:ATB]CODACT<>""
 Read [ACV]CODACT = [F:ATB]CODACT
 If fstat | [F:ACV]FLACT<>2
  Call ECR_TRACE(TABLE-":"-mess(126,133,1),-1) From GESECRAN : # Table inactive
  End
 Endif
Endif

If filpath("","","","",VOLUME,MACHINE)=""
 Call ECR_TRACE(VOLUME-":"-mess(5,125,1),1) From GESECRAN : # Volume inexistant
 If dim(GERRDOS)>0 : GERRDOS = 1 : Endif
 End
Endif

# Type de données Ascii ou Unicode

CDBA = [F:ADS]CODDBA

# Coefficient multiplicateur (uniquement pour le contrôle de la longueur de l'enregistrement)

If GADONIX=2
 KDBA = 2
Else
 Case [F:ADS]TYPDBA
  When 1 : # Oracle
   MEXT = val(getenv$("ADXEXTSIZE"))
   KDBA = val(getenv$("STUSIZE"))
   If KDBA<=0 : KDBA = 2 : Endif
  When 2 : # Sql
   Case CDBA
    When 1 : # Ascii
     KDBA = 1
    When 2 : # Unicode
     KDBA = 2
    When Default
     KDBA = 1
   Endcase
 Endcase
Endif
If MEXT<=0 : MEXT = 1536 : Endif

# Limites

########################################################################################
#
# La limite de 512 colonnes pour une table est imposée par Adonix
# Le nombre de colonnes maximum est de
#  1000 pour Oracle
#  1024 pour SQL7
#  pas de limite sous DB2
#
########################################################################################
#
# Le nombre de champs dans une table est limité à 255
# Il n'est possible d'utiliser les champs > 255 dans les clause where ou dans un index
#
########################################################################################
#
#  La taille maximum d'un enreg pour le moteur Adonix est 32k mais
#  les vraies limites sont en fait imposées par les bases de données
#
#  Oracle : Pas de limite connue
#
#  SQLServer 7 : 8060 octets
#
#  DB2 : Suivant le paramétrage des tables spaces
#  4005  octets si la taille de la page du table space est de 4k
#  8101  ---------------------------------------------------- 8k
#  16239 --------------------------------------------------- 16k
#  32677 --------------------------------------------------- 32k
#
########################################################################################
#
#  La longueur de la clé est limité à 500 octets (limite adonix)
#
########################################################################################

If dim([F:ATB]FLG130)>0 & [F:ATB]FLG130=2 : # Version 130
 VERFIC    = "J"
 MAXCOL    = 256
 MAXZON    = 255
 MAXLNGCLE = 250
 MAXPARCLE = 8
 MAXBLOB   = 65536
Else                  : # Version 140
 VERFIC    = GADOVERS
 MAXCOL    = 512
 MAXZON    = 255
 MAXLNGCLE = 500
 MAXPARCLE = 16
 MAXBLOB   = 65536
Endif
If GADONIX=2
 MAXLNG = 8060 : # Spécial développement
Else
 Case [F:ADS]TYPDBA
  When 1       : MAXLNG = 32000 : # Oracle
  When Default : MAXLNG = 32000 : #  : # SAM 114549 8060 SQLSERVER
 Endcase
Endif

FNOMFIC = filpath("FIL",TABLE,"srf",APPLI,VOLUME,MACHINE)
FOLDFIC = filpath("FIL",TABLE,"old",APPLI,VOLUME,MACHINE)
FNEWFIC = filpath("FIL",TABLE,"new",APPLI,VOLUME,MACHINE)
FICTRA  = filpath("tmp",TABLE,"tra",APPLI,VOLUME,MACHINE)
FICCFG  = filpath("FIL",TABLE,"cfg",APPLI,VOLUME,MACHINE)

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = chr$(9)
adxirs = chr$(10)
adxium = GUTF8

# Si le fichier TABLE.tra existe dans le répertoire tmp, on l'efface

If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA,STAT) From ORDSYS
Endif

# Si le fichier TABLE.srf existait déjà, on relit les infos

Raz FINITIAL, FNEXT, FPCTINC
If filinfo(FNOMFIC,0)>0
 Openi FNOMFIC Using [LEC_]
 Rdseq OBID Using [LEC_]  : # Commentaire
 OVERFIC = mid$(OBID,7,1)
 Rdseq OABR Using [LEC_]  : # Abréviation
 Rdseq OBID Using [LEC_]  : # Répertoire
 adxifs = "" : # Suivant les versions our choix, le nb de paramètres peut être différent
 Rdseq OBID Using [LEC_] : # Infos base
 Call PARBAS(OBID,ODBA,OINITIAL,FNEXT,FPCTINC)
 adxifs = chr$(9)
 Rdseq OBID Using [LEC_]  : # Nb zones
 ONZON = val(OBID)
 For I=1 To ONZON
  Rdseq ONOM(I) , OTYP(I) , OLNG(I) , OREPET(I) , OBID Using [LEC_]
 Next I
 adxifs = "" : # Index clusterisé possible
 Rdseq OBID Using [LEC_]
 adxifs = chr$(9)
 ONIND = min(val(OBID),dim(ONOMCLE))
 For I=1 To ONIND
  Rdseq ONOMCLE(I),OTYPCLE(I),OINDEX(I),ODECLI(I) Using [LEC_]
 Next I
 Openi Using [LEC_]
 EXISTE = 1
 DIFF = 0
Else
 EXISTE = 0
 DIFF = 1
Endif

If FORCE<>0
 DIFF = 1
Endif

# Création du ".new" ou du ".srf"

If EXISTE
 Openo FNEWFIC , 0 Using [ECR_]
Else
 Openo FNOMFIC , 0 Using [ECR_]
Endif
Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
If VERFIC<>OVERFIC : DIFF = 1 : Endif
Wrseq "#<AdxF"+VERFIC+">@(#)%I% "+TEXTE Using [ECR_]
If OABR<>[F:ATB]ABRFIC : DIFF = 1 : Endif
Wrseq [F:ATB]ABRFIC Using [ECR_]
Wrseq '""' Using [ECR_]

# Calcul et vérif de la longueur et du nombre de colonnes

NBZONE = 0
NBZTAB = 0
LNGENR = 0

For [ATZ]CODZONE Where CODFIC=TABLE & find(CODTYP,"AXX","AX1","AX2","AX3")=0
# Pour les tables la dimension est définie par X3
 REPET = [F:ATZ]DIME
 Call REPTAB([F:ATZ]CODACT,REPET) From DOSSUB
 If REPET<>0
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  If fstat
   If REPET<0
    REPET = 1
   Else
    Call ECR_TRACE([F:ATZ]CODZONE-":"-[F:ATZ]CODTYP-mess(7,150,1),1) From GESECRAN
    # Type de données inexistant
   Endif
   LNGZON = 1
  Else
   REPET = abs(REPET)
   Case [F:ATY]TYPTYP
    When 1 : LNGZON = 1                  : # Libellé
    When 2 : LNGZON = 2                  : # Entier court
    When 3 : LNGZON = 4                  : # Entier long
    When 4 : LNGZON = 8                  : # DCB
    When 5 : LNGZON = 4                  : # Float
    When 6 : LNGZON = 8                  : # Double
    When 7,12                            : # Alphanumérique/Datetime
     If [F:ATY]LNGTYP<>0
      LNGZON = [F:ATY]LNGTYP+1
     Else
      LNGZON = [F:ATZ]LONG+1
     Endif
     LNGZON *= KDBA                      : # Coeff x (Ascii/Utf8)
    When 8 : LNGZON = 3                  : # Date
    When 9,10                            : # Blob, clob
     LNGZON = 0
     NBBLOB += REPET
     If [F:ATY]LNGTYP<>0
      LGBLOB += REPET*1024*(2^[F:ATY]LNGTYP)
     Else
      LGBLOB += REPET*1024*(2^[F:ATZ]LONG)
     Endif
    When 11                              : # Uuid
     LNGZON = 16*KDBA
   Endcase
  Endif
  LNGENR += REPET * LNGZON
  NBZTAB += REPET
  NBZONE += 1
 Endif
Next

Gosub SET_NOLIMIT : # Exception de contrôle des limites

If NBZTAB>MAXCOL & !find(TABLE,TABMAXCOL(1..NBMAXCOL))
 MESSA1 = TABLE-":"-mess(213,123,1)-":"-num$(NBZTAB)-"("+num$(MAXCOL)+")" : # Nombre de colonnes trop grand
 Call ECR_TRACE(MESSA1,1) From GESECRAN
Endif

If NBZONE>MAXZON & !find(TABLE,TABMAXZON(1..NBMAXZON))
 MESSA1 = TABLE-":"-mess(49,123,1)-":"-num$(NBZONE)-"("+num$(MAXZON)+")" : # Nombre de zones trop grand
 Call ECR_TRACE(MESSA1,1) From GESECRAN
Endif

If LNGENR>MAXLNG & !find(TABLE,TABMAXLNG(1..NBMAXLNG))
 MESSA1 = TABLE-":"-mess(50,123,1)-":"-num$(LNGENR)-"("+num$(MAXLNG)+")" : # Longueur de ligne trop grande
 If dim(DOSVERS)>0 & dim(SUPVERS)>0 & DOSVERS<>SUPVERS : # Migration
  Call ECR_TRACE(MESSA1,-1) From GESECRAN
 Else
  Call ECR_TRACE(MESSA1,1) From GESECRAN
 Endif
Endif

If LGBLOB+LNGENR>MAXBLOB & NBBLOB>1
 MESSA1 = TABLE-":"-mess(212,123,1)-":"-num$(LGBLOB+LNGENR)-"("+num$(MAXBLOB)+")"
 Call ECR_TRACE(MESSA1,1) From GESECRAN :  # Longueur des blobs trop grande
Endif

# Vérif de la longueur et composantes des clés et comptage des nouveaux index
NBINDEX = 0
CLUSTER = 0
DEFCLUSTER = 0 #X3-100003 8/7/2018
For [ATI]NUMLIG Where CODFIC=TABLE
 [L]DESCRIPT=[F:ATI]DESCRIPT
 If [F:ATB]TYPFIC<3
  Call VERF_INDEX([L]DESCRIPT,TABLE,[F:ATI]CODIND,[F:ATI]CODACT,OK)
 Else
  OK = 1
 Endif
 If OK & [L]DESCRIPT<>""
  LNGCLE = 1
  PARCLE = 0
  CHAINE = [L]DESCRIPT
  While CHAINE<>""
   I = instr(1,CHAINE,"-")
   J = instr(1,CHAINE,"+")
   If    I & J  : I = min(I,J)
   Elsif J & !I : I = J
   Endif
   If I
    CLE    = left$(CHAINE,I-1)
    CHAINE = right$(CHAINE,I+1)
   Else
    CLE    = CHAINE
    CHAINE = ""
   Endif
   If CLE<>""
    PARCLE += 1
    LNGCLE += 2
    Read [ATZ]CODZONE = TABLE;CLE
    Read [ATY]CODTYP  = [F:ATZ]CODTYP
    If fstat
     Read [ATY]CODTYP = "A"
     LNGZON = 1
    Else
     Case [F:ATY]TYPTYP
      When 1,2,3,5
       LNGZON = 4
      When 4,6
       LNGZON = 8
      When 7,12
       If [F:ATY]LNGTYP<>0
        LNGZON = ([F:ATY]LNGTYP+1)*2
       Else
        LNGZON = ([F:ATZ]LONG+1)*2
       Endif
      When 8
       LNGZON = 3
      When 9,10
       LNGZON = 0
      When 11
       LNGZON = 16
     Endcase
    Endif
    LNGCLE += LNGZON
   Endif
  Wend
  OK = 1
  If LNGCLE>MAXLNGCLE
   MESSA1 = [F:ATI]CODIND-":"-mess(33,126,1)-num$(LNGCLE)+"("+num$(MAXLNGCLE)+")" : # Clé trop longue
   Call ECR_TRACE(MESSA1,1) From GESECRAN
   OK = 0
  Endif
  If PARCLE>MAXPARCLE
   MESSA1 = [F:ATI]CODIND-":"-num$(PARCLE)-mess(29,176,1) : # Trop de composantes de clé (maximum #)
   K = instr(1,MESSA1,"#")
   If K
    MESSA1 = left$(MESSA1,K-1)+num$(MAXPARCLE)+right$(MESSA1,K+1)
   Endif
   Call ECR_TRACE(MESSA1,1) From GESECRAN
   OK = 0
  Endif
  If OK
   For I=1 To NBINDEX
    If [L]DESCRIPT=NINDEX(I)
     # Composantes de clé déjà saisies pour l'index
     Call ECR_TRACE([F:ATI]CODIND-":"-mess(21,176,1)-NNOMCLE(I),1) From GESECRAN
     OK = 0 : Break
    Endif
   Next I
   If OK
    NBINDEX += 1
    NNOMCLE(NBINDEX) = [F:ATI]CODIND
    If [F:ATI]HOMONYM=2
     NTYPCLE(NBINDEX) = "1"
    Else
     NTYPCLE(NBINDEX) = "2"
    Endif
    NINDEX(NBINDEX) = [L]DESCRIPT
    If dim([F:ATI]NIVDEC)>0
     NDECLI(NBINDEX) = num$([F:ATI]NIVDEC)
    Else
     NDECLI(NBINDEX) = "0"
    Endif
    #X3-100003 - 8/7/2018
    If [F:ADS]TYPDBA=2 & dim([F:ATB]ORDINDSTA)>0 & [F:ATB]ORDINDSTA=2
      If [L]CLUSTER=0 & [F:ATI]DEFORDIND=2
        [L]DEFCLUSTER = 1
        [L]CLUSTER = NBINDEX
      Endif
      If [F:ATI]ORDIND=2 & ([L]CLUSTER=0 or [L]DEFCLUSTER)
        [L]CLUSTER = NBINDEX
      Endif
    Endif
    #X3-100003
   Endif
  Endif
 Endif
Next ATI
For [ANX]ANX1 Where TABLE=[L]TABLE & FLACT=2
 [L]DESCRIPT = [F:ANX]DESCRIPT
 Call VERF_INDEX([L]DESCRIPT,TABLE,[F:ANX]CODIND,"",OK)
 If OK & [L]DESCRIPT<>""
  If NBINDEX>=dim(ONOMCLE)
   # Le nombre d'index dans une table est limité à
   Call ECR_TRACE([L]TABLE-":"-mess(32,139,1)-num$(dim(ONOMCLE)),1) From GESECRAN
   Break
  Endif
  For I=1 To NBINDEX
   If [L]DESCRIPT=NINDEX(I)
    # Composantes de clé déjà saisies pour l'index
    Call ECR_TRACE([F:ANX]CODIND-":"-mess(21,176,1)-NNOMCLE(I),1) From GESECRAN
    OK = 0 : Break
   Endif
  Next I
  If OK
   NBINDEX += 1
   NNOMCLE(NBINDEX) = [F:ANX]CODIND
   NTYPCLE(NBINDEX) = "1"
   NINDEX(NBINDEX) = [L]DESCRIPT
   NDECLI(NBINDEX) = "0"
  Endif
 Endif
Next ANX

# Taille de la table

TAILLE = [F:ATB]NBENREG*LNGENR
TAILLE *= GCOEFTAB
If TAILLE > 10*1024*1024
 FINITIAL = num$(min(MEXT,int(TAILLE/(1024*1024))+1))+"M" : # On limite à 1,5 G0
Else
 FINITIAL = num$(int(TAILLE/1024)+1)+"K"
Endif

Case [F:ADS]TYPDBA
 When 1 : # Oracle
  If OINITIAL<>FINITIAL : DIFF = 1 : Endif
  Wrseq "3" , FINITIAL , FNEXT , FPCTINC Using [ECR_]
  If val(ODBA)<>3 : DIFF = 1 : Endif
 When 2 : # SQL-server
  Wrseq "5" Using [ECR_]
  If val(ODBA)<>5 : DIFF = 1 : Endif
 When 3 : # Cisam
  Wrseq "2" Using [ECR_]
  If val(ODBA)<>2 : DIFF = 1 : Endif
 When 4 : # DB2
  Wrseq "6" Using [ECR_]
  If val(ODBA)<>6 : DIFF = 1 : Endif
Endcase

# Ecriture des zones
# On met les blobs/clobs à la fin

Wrseq NBZONE Using [ECR_]
If NBZONE<>ONZON : DIFF = 1 : Endif

OK = 0
If dim([F:ATB]FLG130)>0 & [F:ATB]FLG130=2 : # Pour la 130, il faut trier les colonnes par ordre alphabétique

 For [ATZ]CODZONE Where CODFIC=TABLE & find(CODTYP,"AXX","AX1","AX2","AX3")=0
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  If fstat or !find([F:ATY]TYPTYP,9,10)
   Gosub ECRIZONE
  Endif
 Next

Else : # Pour la 140, il ne faut pas à cause de la p. de table SALTRS

 For [ATZ]NUMLIG Where CODFIC=TABLE & find(CODTYP,"AXX","AX1","AX2","AX3")=0
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  If fstat or !find([F:ATY]TYPTYP,9,10)
   Gosub ECRIZONE
  Endif
 Next
 # On met les blobs/clobs à la fin
 For [ATZ]NUMLIG Where CODFIC=TABLE & find(CODTYP,"AXX","AX1","AX2","AX3")=0
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  If !fstat & find([F:ATY]TYPTYP,9,10)
   Gosub ECRIZONE
  Endif
 Next

Endif

# Ecritures des index

If [L]CLUSTER<>0
 Wrseq NBINDEX,[L]CLUSTER Using [ECR_]
Else
 Wrseq NBINDEX Using [ECR_]
Endif
If NBINDEX<>ONIND : DIFF = 1 : Endif
For I=1 To NBINDEX
 J = find(NNOMCLE(I),ONOMCLE(1..ONIND))
 If J=0 or NINDEX(I)<>OINDEX(J)
  DIFF = 1
 Endif
 If NDECLI(I)<>"0"
  Wrseq NNOMCLE(I),NTYPCLE(I),NINDEX(I),NDECLI(I) Using [ECR_]
 Else
  Wrseq NNOMCLE(I),NTYPCLE(I),NINDEX(I) Using [ECR_]
 Endif
 If J<>0 & OTYPCLE(J)<>NTYPCLE(I) : DIFF = 1 : Endif
 If J<>0 & ODECLI(J)<>NDECLI(I) : DIFF = 1 : Endif
Next I

Openo Using [ECR_]

# Vérification du fichier de configuration

K = 0
If filinfo(FICCFG,0)>0
 Openi FICCFG Using [FIC]
 Iomode adxifs ""       Using [FIC]
 Iomode adxirs chr$(10) Using [FIC]
 Iomode adxium GUTF8    Using [FIC]
 Rdseq CHAINE Using [FIC]
 While !fstat
  If instr(1,toupper(CHAINE),'{"LEVEL1"}')
   K = 1 : Break
  Elsif instr(1,toupper(CHAINE),'{"LEVEL0"}')
   K = 2 : Break
  Endif
  Rdseq CHAINE Using [FIC]
 Wend
 Openi Using [FIC]
Endif
If dim([F:ATB]SECURE)>0
 If ([F:ATB]SECURE=2 & (K=0 or K=1)) or ([F:ATB]SECURE<>2 & K=2)
  FORCE = 1
  Call MODIF_CFG(FICCFG,[F:ATB]SECURE) From SUBATB
 Endif
Endif

# Pour ne pas valider la table ATEXTE sur le dossier X3DIAM et perdre les triggers

If TABLE="ATEXTE" & APPLI="X3DIAM"
 FORCE = 0
Endif

# Validation de la table

OK = 1
If DIFF
 If EXISTE
  Call MOVE(FNOMFIC,FOLDFIC,STAT) From ORDSYS
  Call MOVE(FNEWFIC,FNOMFIC,STAT) From ORDSYS
 Endif

 #Issue 85132 - 2012-10-15 by VPO : desactiver trigger avant valfil
 #Non c'est le valfil qui doit faire ça
 #Call SET_DISABLETRIG_TABLE(APPLI,TABLE,STAT)

################################################
## Options de valfil
################################################
# -s : Validation silencieuse
# -b : Validation semi-silencieuse
# -x : Validation "optimisée" (pas de recopie)
# -f : Validation forcée
# -o : Ajout d'une clause "storage"
# -d : Effacement de la table
# -z : Remise à zéro
# -c : Copie
# -m : Déplacement de fichier
# -t : Type de base
# -n : Génération du .fde seulement
# -a : Validation version 130
################################################

 ORDSYS(1) = "valfil -s" : # Silencieux
 If dim([F:ATB]FLG130)>0 & [F:ATB]FLG130=2
  ORDSYS(1) -= "-a"      : # Version 130
 Endif
 If FORCE
  ORDSYS(1) -= "-f"      : # Forcé
 Endif
 ORDSYS(1)  -= "-x"     : # Optimisé
 If STORAGE<>""
  ORDSYS(1) -= '-o'-'"'+STORAGE+'"'
 Endif
 ORDSYS(1) -= APPLI-TABLE
 ORDSYS(2)  = FICTRA
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 adxifs = ""
 adxirs = chr$(10)
 Openi FICTRA Using [TR_]
 Raz MESSAGE
 Rdseq MESSAGE(1) Using [TR_]
 Rdseq MESSAGE(2) Using [TR_]
 Rdseq MESSAGE(3) Using [TR_]
 Openi Using [TR_]
 If MESSAGE(1)<>""
  Call ECR_TRACE(mess(51,123,1)-TABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
  # Erreur en validation de la table
  OK = 0
 Endif
Else
 Call EFFACE(FNEWFIC,STAT) From ORDSYS
Endif
If OK
 If EXISTE
  Call EFFACE(FOLDFIC,STAT) From ORDSYS
 Endif
 Call EFFACE(FICTRA ,STAT) From ORDSYS
Else
 If dim(GERRDOS)>0 : GERRDOS = 1 : Endif
Endif

## Mise à jour éventuelle sur dossier historisé
If (dim(GCRE)<=0 or (dim(GCRE)>0 & GCRE=0))
& & DIFF<>0
& & [F:ATB]TYPFIC<>3
& & MACHINE=""
& & filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)>0
& & [F:ATB]CODACT<>"MIG" : #107271
 HISAPL = ""
 Local File =APPLI+".ADOVAL" [ADW_]
 Read [ADW_]ADW0 = "";"";"HISDOS"
 If !fstat
  HISAPL = [F:ADW_]VALEUR
 Endif
 If HISAPL<>""
  If adxmac(0)<>""
   # Mise à jour de la vue\Opération impossible sur machine distante
   Call ECR_TRACE(mess(130,125,1)-TABLE-"("+HISAPL+")"+"\"+mess(129,125,1),1) From GESECRAN
  Else
   # Tables qui ne doivent pas être des vues
   Gosub SET_NOVIEW From CREHISTO
   If find(TABLE,TABNOVIEW(1..NBNOVIEW))
    VUE = 0
   Else
    # VUE=1 si le .srf n'existe pas ou si le .srf contient "#V"
    Call VUE_OK(TABLE,HISAPL,"FIL",VUE) From DOSVUE
   Endif
   If !VUE
    #107271 uniquement sur GEODE ou dico
    If GPRODUIT=1 | find(TABLE,"ATABLE","ATABZON","ATABIND")>0
     Read [ADW_]ADW0 = "";"";"HISCOE"
     Call CRETABLE(APPLI,HISAPL,[F:ADS]TYPDBA,TABLE,val([F:ADW_]VALEUR),FORCE) From CREHISTO :#sans dico
    Endif
   Else
    Call CREVUE(APPLI,HISAPL,[F:ADS]TYPDBA,TABLE,K) From CREHISTO
   Endif
  Endif
 Endif
 Close Local File [ADW_]
Endif

## Mise à niveau du rowid sous SQL
# Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
If [F:ADS]TYPDBA=2 & find(TABLE,"AUDITH","AJSAUDIT","AUDITBI") : # Sql
  # Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
  #Call SET_ROWID(APPLI,STAT) From SUBTRIGGER
  Call SET_ROWID_TABLE(APPLI,TABLE,STAT) From SUBTRIGGER
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

GPOINT = "MAJTAB" : Gosub ENTREE From EXEFNC

End

Subprog VALFILH(PDOSSIER,PTABLE,FORCE)
Value Char    PDOSSIER,PTABLE
Value Integer FORCE
Local Integer STAT
Local Char    MESSAGE(250)(1..5) , MESSA1(250)
Local Char    ORDSYS(GDIMFIC)(1..2),MACHINE(GDIMFIC)
Local Char    FICORG(250) , FICSRF(250) , FICTRA(250),FICNEW(250)
Local Integer OK
OK = 1
MACHINE = adxmac(0)
 #Issue 85132 - 2012-10-15 by VPO : desactiver trigger avant valfil
 #Non c'est le valfil qui doit faire ça
 #Call SET_DISABLETRIG_TABLE(APPLI,TABLE,STAT)

################################################
## Options de valfil
################################################
# -s : Validation silencieuse
# -b : Validation semi-silencieuse
# -x : Validation "optimisée" (pas de recopie)
# -f : Validation forcée
# -o : Ajout d'une clause "storage"
# -d : Effacement de la table
# -z : Remise à zéro
# -c : Copie
# -m : Déplacement de fichier
# -t : Type de base
# -n : Génération du .fde seulement
# -a : Validation version 130
################################################
FICTRA  = filpath("tmp",PTABLE,"tra",PDOSSIER)
FICSRF  = filpath("tmp",PTABLE,"srf",PDOSSIER)
# Si le fichier TABLE.tra existe dans le répertoire tmp, on l'efface

If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA,STAT) From ORDSYS
Endif

 ORDSYS(1) = "valfil -s" : # Silencieux
 If dim([F:ATB]FLG130)>0 & [F:ATB]FLG130=2
  ORDSYS(1) -= "-a"      : # Version 130
 Endif
 If FORCE
  ORDSYS(1) -= "-f"      : # Forcé
 Endif
 ORDSYS(1)  -= "-x"     : # Optimisé
# If STORAGE<>""
#  ORDSYS(1) -= '-o'-'"'+STORAGE+'"'
# Endif
 ORDSYS(1) -= PDOSSIER-PTABLE
 ORDSYS(2)  = FICTRA
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 adxifs = ""
 adxirs = chr$(10)
 Openi FICTRA Using [TR_]
 Raz MESSAGE
 Rdseq MESSAGE(1) Using [TR_]
 Rdseq MESSAGE(2) Using [TR_]
 Rdseq MESSAGE(3) Using [TR_]
 Openi Using [TR_]
 If MESSAGE(1)<>""
  Call ECR_TRACE(mess(51,123,1)-PTABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
  # Erreur en validation de la table
  OK = 0
 Endif

If OK
 FICORG = filpath("FIL",PTABLE,"old",PDOSSIER)
 Call EFFACE(FICORG,STAT) From ORDSYS
 Call EFFACE(FICTRA ,STAT) From ORDSYS
Else
 If dim(GERRDOS)>0 : GERRDOS = 1 : Endif
Endif
End

#Issue 85132 - 2012-10-15 by VPO : desactiver trigger avant valfil
#Non c'est le valfil qui doit faire ça
#-------------------------------------------------------
#Subprog SET_DISABLETRIG_TABLE(APPLI,TABLE,STAT)
#Value    Char APPLI
#Value    Char TABLE
#Variable Integer STAT
##
#If filinfo(filpath("FIL",TABLE,"fde",APPLI),0)<=0 : End : Endif
##
#Local Char REQSQL (250)
#Local Integer TYPDBA : TYPDBA=[F:ADS]TYPDBA
#
#If [F:ADS]TYPDBA=2 : #Sql
#REQSQL="ALTER TABLE "-APPLI+"."+TABLE-"DISABLE TRIGGER ALL"
#Elsif [F:ADS]TYPDBA=1 : #Oracle
#REQSQL="ALTER TABLE"-APPLI+"."+TABLE-"DISABLE ALL TRIGGERS"
#Endif
#
#Trbegin ADOVAL
#
#Onerrgo ERREUR
#Execsql From num$(TYPDBA*2+1) Sql REQSQL
#Onerrgo
#
#Commit
#
#End

############################################################################################################
# Liste des tables dont la structure n'est pas à contrôler (Validation dossier/dico des tables)
############################################################################################################

$SET_NOLIMIT
Local Char TABMAXZON(GLONATB)(1..10) , TABMAXLNG(GLONATB)(1..25) , TABMAXCOL(GLONATB)(1..10)
Local Integer NBMAXZON , NBMAXLNG , NBMAXCOL

# mb 24.1.6 mb exception AMSK pour le passage de version 140/150

NBMAXCOL = 1  : TABMAXCOL(NBMAXCOL) = "AMSK"

# mb 1.3.4 mb exception SALTRS réclamée à cor et à cri
# mb 24.1.6 mb exception AMSK pour le passage de version 140/150
# mb 20.7.10 mb exception TMPFASMAS pour la migration 140/v5
# VPO 04/03/14 97056 exception FXDASSETS

NBMAXZON = 1  : TABMAXZON(NBMAXZON) = "SALTRS"
NBMAXZON += 1 : TABMAXZON(NBMAXZON) = "AMSK"
NBMAXZON += 1 : TABMAXZON(NBMAXZON) = "PURTRS"
NBMAXZON += 1 : TABMAXZON(NBMAXZON) = "TMPMASFAS"
NBMAXZON += 1 : TABMAXZON(NBMAXZON) = "EMPLOCTR"
#LSE 2016/02/01 SAM 114171
NBMAXZON += 1 : TABMAXZON(NBMAXZON) = "AQCPROC10"
NBMAXZON += 1 : TABMAXZON(NBMAXZON) = "FXDASSETS"

# mb 1.3.4 mb exception SALTRS réclamée à cor et à cri (bug 21738)
# mb 24.1.6 mb exception AMSK, AOBJLST et PARSTA2 pour le passage de version 140/150
# ccl exception ABIHIERA+PURTRS pour le passage V150 - V160
# mb 27.10.8 tables ADOSSIER et AWRKLNK pour le passage v5-v6
# mb 4.11.8 tables RUBRIQUE et EMPLOCTR à cause du type ADI qui passe à 20 en v6
# mb 24.6.9 table AOBJEXT indicateurs passent à #
# mb 4.3.11 table GAUTACED à cause des codes tables diverses (20 c)
# mb 24.10.13 tables RUBHIS et MSRUB pour la paie
#35546 : add table CACCEDEF

NBMAXLNG = 1  : TABMAXLNG(NBMAXLNG) = "AMSK"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "AOBJLST"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "PARSTA2"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "ABIHIERA"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "TABFOR"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "ADOSSIER"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "AWRKLNK"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "AOBJEXT"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "GAUTACED"

NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "SALTRS"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "PURTRS"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "CFGSEL"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "OPPOR"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "QUREXTRACT"

NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "TASSEDIC"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "RUBRIQUE"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "EMPLOCTR"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "TMPEMPLO"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "RUBHIS"
NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "MSRUB"

NBMAXLNG += 1 : TABMAXLNG(NBMAXLNG) = "CACCEDEF"   # X3-25279 CACCEDEF in the list of tables over the normal record size

GPOINT = "NOLIMIT" : Gosub ENTREE From EXEFNC

Return

######################################################################################
Subprog MAJTRIGDOS(DOSSIER,TABLE)
Value Char DOSSIER,TABLE
Local Char    APPLI(GLONADS) , MACHINE(GDIMFIC) , VOLUME(GDIMFIC)
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Call VOLUME(MACHINE,APPLI,VOLUME) From ORDSYS
Goto MAJTRIGVAL

######################################################################################
Subprog MAJTRIG(TABLE)
Value Char TABLE
Local Char    APPLI(GLONADS) , MACHINE(GDIMFIC) , VOLUME(GDIMFIC)
APPLI   = [F:ADS]DOSSIER
VOLUME  = [F:ADS]VOLUME
MACHINE = adxmac(0)

$MAJTRIGVAL
Local Integer K , L , OKBI , OKSD , OKTRT, OKTICK
Read [ATB]CODFIC = TABLE
If fstat
 End
Elsif [F:ATB]CODACT<>""
 Read [ACV]CODACT = [F:ATB]CODACT
 If fstat or [F:ACV]FLACT<>2
  End
 Endif
Endif
If filpath("","","","",VOLUME,MACHINE)=""
 End
Endif

Gosub SET_TABSYS From SUBATB
# Ajout trigger de table pour le champ UPDTICK si présence du champ "uuid" avec le type "Uuident"

If type([F:ATB]AUUID)=525 & !find(TABLE,TABSYS(1..NBSYS))
 OKTICK = 0
 For [ATZ]CODTYP Where CODFIC=TABLE & CODTYP="AUUID" : OKTICK = 1 : Break : Next ATZ
 If OKTICK : Call TRIGGER_UPDTICK(APPLI,TABLE) From ATRIGGERTICK : Endif
Endif

If TABLE="AJSAUDIT" & 0: # CCL desactivé car plantage en modification de donnée et inutile.
 OKTICK = 1
 Call TRIGGER_UPDTICK(APPLI,TABLE) From ATRIGGERTICK
Endif
K = 1
If find(TABLE,"ALOGIN","AUDITH","AUDITL","AUDITBI","AJSAUDIT") : # Les triggers utilisent ces tables
 K = 0
Elsif [F:ATB]TYPFIC=3 : # Tables système
 K = 0
Elsif APPLI=GDOSX3 & GADONIX<>2 : # On ne génère pas les triggers dans l'application X3
 K = 0
#Else
# Gosub SET_NOVIEW From CREHISTO : # Tables locales au dossier historisé (table de travail en général)
# K = !find(TABLE,TABNOVIEW(1..NBNOVIEW))
Endif
If K & (MACHINE="" or MACHINE=adxmac(0))
 K = 0
 If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)>0
  Local File =APPLI+".ACTIV" [ACV_]
  Read [ACV_]CODACT = "AUDIT"
  If !fstat & [F:ACV_]FLACT=2
   K = 1
  Endif
  OKBI = 0
  Read [ACV_]CODACT = "ABI"
  If !fstat & [F:ACV_]FLACT=2
   OKBI = 1
  Endif
  OKSD = 0
  Read [ACV_]CODACT = "ASD"
  If !fstat & [F:ACV_]FLACT=2
   OKSD = 1
  Endif
  Close Local File [ACV_]
 Endif
 If K
  Trbegin ADOVAL
   If !OKBI
    Read [ATB]CODFIC=TABLE
    If dim([F:ATB]AUDBI)>0 & [F:ATB]AUDBI<>1
     [F:ATB]AUDBI = 1
     Rewrite [ATB]
    Endif
   Endif
   Call TRIGGER(APPLI,TABLE,"I") From ATRIGGER
   Call TRIGGER(APPLI,TABLE,"U") From ATRIGGER
   Call TRIGGER(APPLI,TABLE,"D") From ATRIGGER
   If !OKSD
    Read [ATB]CODFIC=TABLE
    If dim([F:ATB]AUDSDA)>0 & [F:ATB]AUDSDA<>1
     [F:ATB]AUDSDA = 1
     Rewrite [ATB]
    Endif
   Endif
   Call EXISTE_ADX("","","ASDUTITR1",OKTRT) From ORDSYS
   If OKTRT
    Call SD_TRIGGER(APPLI,TABLE) From ASDUTITR1
   Endif
  Commit
 Else
  If dim([F:ATB]AUDCRE)>0 & ([F:ATB]AUDCRE=2 or [F:ATB]AUDUPD=2 or [F:ATB]AUDDEL=2 or (dim([F:ATB]AUDBI)>0 & [F:ATB]AUDBI=2))
   Trbegin ADOVAL
    Read [ATB]CODFIC=TABLE
    [F:ATB]AUDCRE = 1
    [F:ATB]AUDUPD = 1
    [F:ATB]AUDDEL = 1
    If dim([F:ATB]AUDBI)>0
     [F:ATB]AUDBI = 1
    Endif
    Rewrite [ATB]
    Call TRIGGER(APPLI,TABLE,"I") From ATRIGGER
    Call TRIGGER(APPLI,TABLE,"U") From ATRIGGER
    Call TRIGGER(APPLI,TABLE,"D") From ATRIGGER
   Commit
  Endif
  If dim([F:ATB]AUDSDA)>0 & [F:ATB]AUDSDA=2
   Trbegin ADOVAL
    Read [ATB]CODFIC=TABLE
    If dim([F:ATB]AUDSDA)>0
     [F:ATB]AUDSDA = 1
    Endif
    Rewrite [ATB]
    Call EXISTE_ADX("","","ASDUTITR1",OKTRT) From ORDSYS
    If OKTRT
     Call SD_TRIGGER(APPLI,TABLE) From ASDUTITR1
    Endif
   Commit
  Endif
 Endif
Endif
End

#######################################################################
$ECRIZONE
REPET = [F:ATZ]DIME
Call REPTAB([F:ATZ]CODACT,REPET) From DOSSUB
If REPET<>0
 Call TEXTE([F:ATZ]NOCOURT,TEXTE) From OBJDIV
 LNGZON = 0
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 If fstat
  # On a déjà mis un message d'erreur plus haut
  TYPZON = 7
  LNGZON = 1
  REPET  = 1
  Read [ATY]CODTYP = "A"
 Else
  REPET = abs(REPET)
  If find([F:ATY]TYPTYP,4,7,9,10) : # DCB, Alpha, Blob, Clob
   If [F:ATY]LNGTYP<>0
    LNGZON = [F:ATY]LNGTYP
   Else
    LNGZON = [F:ATZ]LONG
   Endif
  Endif
 Endif
 # Problème des nombres avec SQL-serveur :
 # pour les dcb, on ne peut pas dépasser 28, à répartir entre la partie entière et décimale.
 If [F:ATY]TYPTYP=4
  LNGTOT = min(int(LNGZON),28)
  LNGDEC = LNGZON-LNGTOT
  While int(LNGDEC)<>LNGDEC
   LNGDEC *= 10
  Wend
  If instr(1,[F:ATZ]OPTION,"F") or instr(1,[F:ATY]OPTION,"F")
   If LNGDEC>0
    LNGTOT = min(14,LNGTOT+LNGDEC)
   Endif
   LNGDEC = min(LNGTOT-1,28-LNGDEC) : # Il ne faut pas dépasser 28
  Else : # On ajoute le nombre de décimales à la partie entière
   LNGTOT += max(min(LNGDEC,28-LNGTOT-LNGDEC),0)
   LNGDEC += 1       : # Par sécurité
  Endif
  If LNGTOT+LNGDEC>28 : LNGDEC = 28-LNGTOT : Endif
  LNGZON = val(num$(LNGTOT)+"."+num$(LNGDEC))
  Wrseq [F:ATZ]CODZONE, [F:ATY]TYPTYP, num$(LNGTOT)+"."+num$(LNGDEC), REPET, '"'+TEXTE+'"' Using [ECR_]
 Else
  Case [F:ATY]TYPTYP
   When 7
    Case CDBA
     When 2
      If dim([F:ATB]FLG130)>0 & [F:ATB]FLG130=2
       TYPZON = 7  : # Obligatoirement Ascii
      Else
       TYPZON = 79 : # Unicode
      Endif
     When Default
      TYPZON = 7  : # Ascii
    Endcase
   When 9
    If dim([F:ATB]FLG130)>0 & [F:ATB]FLG130=2
     MESSA1 = [F:ATZ]CODZONE-":"-[F:ATY]CODTYP-mess(14,133,1) : # Type de données incorrect
     Call ECR_TRACE(MESSA1,1) From GESECRAN
     TYPZON = 7 : LNGZON = 1
    Else
     TYPZON = 81 : # Blob
    Endif
   When 10
    If dim([F:ATB]FLG130)>0 & [F:ATB]FLG130=2
     MESSA1 = [F:ATZ]CODZONE-":"-[F:ATY]CODTYP-mess(14,133,1) : # Type de données incorrect
     Call ECR_TRACE(MESSA1,1) From GESECRAN
     TYPZON = 7 : LNGZON = 1
    Else
     TYPZON = 82 : # Clob
    Endif
   When 11 : # Uuid
    TYPZON = 84
   When 12 : # Datetime
    TYPZON = 85
   When Default
    TYPZON = [F:ATY]TYPTYP
  Endcase
  Wrseq [F:ATZ]CODZONE, TYPZON, LNGZON, REPET, '"'+TEXTE+'"' Using [ECR_]
 Endif
 J = find([F:ATZ]CODZONE,ONOM(1..ONZON))
 If J=0 | TYPZON<>val(OTYP(J)) | LNGZON<>val(OLNG(J))
&  | REPET<>val(OREPET(J))
  DIFF = 1
 Endif
Endif
Return

#########################################################################
Subprog VERF_INDEX(NDESCRIPT,TABLE,INDEX,CODACT,OK)
#########################################################################
Variable Char    NDESCRIPT
Value    Char    TABLE , INDEX , CODACT
Variable Integer OK
Local Char    DESCRIPTEUR(120) , WINDEX(GLONAVA+5) , WSIGNE(1) , ZONE(GLONAVA) , MESSA(250)
Local Integer I , J , K , DIME , DIMAX
DESCRIPTEUR = NDESCRIPT
NDESCRIPT   = ""
WSIGNE      = ""
OK = 1
Call INDEX([F:ADS]DOSSIER,CODACT,OK) From DOSSUB
If !OK : End : Endif
While DESCRIPTEUR<>""
 WSIGNE = ""
 If find(left$(DESCRIPTEUR,1),"-","+")
  WSIGNE = left$(DESCRIPTEUR,1)
  DESCRIPTEUR = right$(DESCRIPTEUR,2)
 Endif
 I = instr(1,DESCRIPTEUR,"+")
 J = instr(1,DESCRIPTEUR,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 If I
  WINDEX = left$(DESCRIPTEUR,I-1)
  DESCRIPTEUR = right$(DESCRIPTEUR,I)
 Else
  WINDEX = DESCRIPTEUR
  DESCRIPTEUR = ""
 Endif
 If WINDEX<>""
  I = instr(1,WINDEX,"(")
  If I
   ZONE = left$(WINDEX,I-1)
   DIME = val(right$(WINDEX,I+1))+1
  Else
   ZONE = WINDEX
   DIME = 1
  Endif
  Read [ATZ]CODZONE = TABLE;ZONE
  If fstat
   # Zone inexistante
   MESSA = mess(10,176,1)-INDEX+"\"+ZONE-mess(11,176,1)
   Gosub TRACE
   WINDEX = ""
  Else
   DIMAX = [F:ATZ]DIME
   If [F:ATZ]CODACT<>""
    Read [ACV]CODACT = [F:ATZ]CODACT
    If fstat or [F:ACV]FLACT<>2
     # Index...Zone avec un code activité inactif
     MESSA = mess(10,176,1)-INDEX+"\"+ZONE-mess(22,176,1)
     Gosub TRACE
     WINDEX = ""
    Elsif [F:ACV]DIME<>0
     # mb 28.5.2014 bug 100047 Pourquoi avoir la ligne ci-dessous en commentaire ?
     DIMAX = [F:ACV]DIME
    Endif
   Endif
   If DIME>max(1,DIMAX)
    # Indice incorrect
    MESSA = INDEX-":"-mess(46,105,1)-"(0.."+num$(max(1,DIMAX)-1)+")"
    Gosub TRACE
    WINDEX = ""
   Endif
   If WINDEX<>""
#    If NDESCRIPT<>""      : #  CC 15/02/2013   pour autoriser index avec - dans la première colonne
     NDESCRIPT += WSIGNE
#    Endif
    NDESCRIPT += WINDEX
   Endif
  Endif
 Endif
Wend
End

#########################
$TRACE
If [F:ADS]DOSSIER<>GDOSX3
 Call ECR_TRACE(MESSA,1) From GESECRAN
 OK = 0
Else
 Call ECR_TRACE(MESSA,0) From GESECRAN
Endif
Return

#########################
$ERREUR
GERREUR = errn
# Erreur x ligne no y
Local Char _COD(GLONATB)
If dim([F:ATB]CODFIC)>0 : [L]_COD=[F:ATB]CODFIC : Endif
GMESSAGE = [L]_COD-mess(6,123,1)-num$(GERREUR)-mess(61,100,1)-num$(errl)-"("+errp+")\"+errmes$(GERREUR)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GMESSAGE = ""
Resume

#######################################################################################
Subprog ANNULE(DOSSIER,TABLE,OK)
Value Char DOSSIER , TABLE
Variable Integer OK
Local Char    MACHINE(GLONAMC) , APPLI(GLONADS) , ORDSYS(250)(1..2) , FICTRA(GDIMFIC)
Local Char    MESSAGE(250)(1..3) , SUF(10) , FICTRT(GDIMFIC)
Local Integer STAT
If DOSSIER=""
 APPLI = nomap
 MACHINE = adxmac(0)
Else
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Endif
If filinfo(filpath("FIL",TABLE,"fde",DOSSIER),0)>0
 FICTRA  = filpath("tmp",TABLE,"tra",DOSSIER)
 If filinfo(FICTRA,0)>0
  Call EFFACE(FICTRA,STAT) From ORDSYS
 Endif
 ORDSYS(1) = "valfil -d"
 ORDSYS(1) -= APPLI-TABLE
 ORDSYS(2)  = FICTRA
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 Openi FICTRA Using [TR_]
 Iomode adxifs "" Using [TR_]
 Iomode adxirs chr$(10) Using [TR_]
 Iomode adxium GUTF8 Using [TR_]
 Raz MESSAGE
 Rdseq MESSAGE(1) Using [TR_]
 Rdseq MESSAGE(2) Using [TR_]
 Rdseq MESSAGE(3) Using [TR_]
 Openi Using [TR_]
 Call EFFACE(FICTRA,STAT) From ORDSYS
 If MESSAGE(1)<>""
  Call ECR_TRACE(mess(183,125,1)-TABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
  # Erreur en suppression de la table
  OK = 0 : End
 Else
  For SUF = "srf", "fde", "dat", "idx" , "cfg"
   FICTRT = filpath("FIL",TABLE,SUF,DOSSIER)
   If filinfo(FICTRT,0)>=0
    Call EFFACE(FICTRT,STAT) From ORDSYS
   Endif
  Next SUF
 Endif
Endif
OK = 1
End

#######################################################################################
Subprog VIDE(DOSSIER,TABLE,OK)
Value Char DOSSIER , TABLE
Variable Integer OK
Local Char    MACHINE(GLONAMC) , APPLI(GLONADS) , ORDSYS(250)(1..2) , FICTRA(GDIMFIC)
Local Char    MESSAGE(250)(1..3) , SUF(10) , FICTRT(GDIMFIC)
Local Integer STAT
If DOSSIER=""
 APPLI = nomap
 MACHINE = adxmac(0)
Else
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Endif
If filinfo(filpath("FIL",TABLE,"fde",DOSSIER),0)>0
 FICTRA  = filpath("tmp",TABLE,"tra",DOSSIER)
 If filinfo(FICTRA,0)>0
  Call EFFACE(FICTRA,STAT) From ORDSYS
 Endif
 ORDSYS(1) = "valfil -s -z"
 ORDSYS(1) -= APPLI-TABLE
 ORDSYS(2)  = FICTRA
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 Openi FICTRA Using [TR_]
 Iomode adxifs "" Using [TR_]
 Iomode adxirs chr$(10) Using [TR_]
 Iomode adxium GUTF8 Using [TR_]
 Raz MESSAGE
 Rdseq MESSAGE(1) Using [TR_]
 Rdseq MESSAGE(2) Using [TR_]
 Rdseq MESSAGE(3) Using [TR_]
 Openi Using [TR_]
 Call EFFACE(FICTRA,STAT) From ORDSYS
 If MESSAGE(1)<>""
  Call ECR_TRACE(mess(183,125,1)-TABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
  # Erreur en suppression de la table
  OK = 0 : End
 Endif
Endif
OK = 1
End
#----------------------------------------------------------------------------#
# Décodage de la 5ième ligne d'un fichier .srf
#----------------------------------------------------------------------------#

Subprog PARBAS(LIGNE,OTYPDBA,OINITIAL,ONEXT,OPCTINC)
Value    Char LIGNE
Variable Char OTYPDBA,OINITIAL,ONEXT,OPCTINC
Local Integer I , J
Local Char    CHAINE(250)
Raz OTYPDBA , OINITIAL , ONEXT , OPCTINC , J
While LIGNE<>""
 J += 1
 I = instr(1,LIGNE,chr$(9))
 If I
  CHAINE = left$(LIGNE,I-1)
  LIGNE = right$(LIGNE,I+1)
 Else
  CHAINE = LIGNE
  LIGNE = ""
 Endif
 Case J
  When 1 : OTYPDBA  = CHAINE
  When 2 : OINITIAL = CHAINE
  When 3 : ONEXT    = CHAINE
  When 4 : OPCTINC  = CHAINE
 Endcase
Wend
End

#############################################
$FICSRF_HIST
Local File =APPLI+".ATABLE"  [ATB]
Local File =APPLI+".ATABZON" [ATZ]
Local File =APPLI+".ATABIND" [ATI]
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer I , STAT , SAVIUM , OK , NBCHAMP , NBCLE , HISPTR
Local Char    FICORG(250) , FICSRF(250) , FICTRA(250),FICNEW(250)
Local Char    LIGNE(250) , DBA(10) , INITIAL(20) , FNEXT(20) , PCTINC(20)
Local Char    SAVIFS(5) , SAVIRS(5) , CLUSTER(10)
Local Char    ORDSYS(250)(1..2)
Local Char    MESSAGE(250)(1..5)
Local Char DESCRIPT(250)
Local Integer OK,STAT
Local Integer LNGCLE, PARCLE, NBZTAB, TYPZON
Local Decimal TAILLE , LNGZON , LNGTOT , LNGDEC
Local Integer STAT , DIFF , OK , EXISTE , REPET , VUE

Local Char    FINITIAL(20), OINITIAL(20) , FNEXT(20), FPCTINC(20)
Local Integer ONZON, ONIND
Local Char    OBID(250) , OABR(GLONABR) , ODBA(5)
Local Integer CDBA , KDBA , TDBA , MEXT
Local Char    ONOM(GLONAVA)(1..500), OTYP(5)(1..500), OLNG(5)(1..500)
Local Char    OREPET(5)(1..500) , OVERFIC(1)
# Issue 85234 - 2013-01-07 by VPO : autoriser 19 index : 15 sur ATABIND [ATI] + 4 AINDEX [ANX]
Local Char    ONOMCLE(GLONANX)(1..19), OTYPCLE(2)(1..19), OINDEX(250)(1..19) , ODECLI(2)(1..19)
Local Char    NNOMCLE(GLONANX)(1..19), NTYPCLE(2)(1..19), NINDEX(250)(1..19) , NDECLI(2)(1..19)
Local Integer I , J , K , NBZONE, NBINDEX, LNGENR, NBRIND
Local Integer LNGCLE, PARCLE, NBZTAB, TYPZON
Local Decimal TAILLE , LNGZON , LNGTOT , LNGDEC
Local Char    TEXTE(250) , STORAGE(250)
Local Decimal MAXCOL , MAXLNGCLE , MAXPARCLE , MAXLNG , MAXZON
Local Decimal NBBLOB , LGBLOB , MAXBLOB
Local Char    VERFIC(1)
Local Char    CHAINE(250) , CLE(20) , DESCRIPT(120)
Local Integer CLUSTER

Read [ATB]CODFIC=TABLE

# Type de données Ascii ou Unicode

CDBA = [F:ADS]CODDBA

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = chr$(9)
adxirs = chr$(10)
adxium = GUTF8

FICNEW = filpath("FIL",TABLE,"new",APPLI)
FICSRF = filpath("FIL",TABLE,"srf",APPLI)
 Openo FICNEW , 0 Using [ECR_]

 Openi FICSRF Using [FSRF]
 Rdseq OBID Using [FSRF]  : # En-tête/Commentaire
 OVERFIC = mid$(OBID,7,1)
 Wrseq OBID Using [ECR_]
 Rdseq OABR Using [FSRF]  : # Abréviation
 Wrseq [F:ATB]ABRFIC Using [ECR_]
 Rdseq OBID Using [FSRF]  : # Répertoire
 #VUE = (FLAG='"#V"')
 Wrseq OBID Using [ECR_]
 adxifs = "" : # Suivant les versions our choix, le nb de paramètres peut être différent
 Rdseq OBID Using [FSRF] : # Infos base
 adxifs = chr$(9)
 Wrseq OBID Using [ECR_]
 Rdseq OBID Using [FSRF]  : # Nb zones
 ONZON = val(OBID)
 For I=1 To ONZON
  Rdseq ONOM(I) , OTYP(I) , OLNG(I) , OREPET(I) , OBID Using [FSRF]
 Next I
 ONZON=0
 For [ATZ]NUMLIG Where CODFIC=TABLE & find(CODTYP,"AXX","AX1","AX2","AX3")=0
  ONZON+=1
 Next
 Wrseq ONZON Using [ECR_]: # Nb zones
 For [ATZ]NUMLIG Where CODFIC=TABLE & find(CODTYP,"AXX","AX1","AX2","AX3")=0
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  If fstat or !find([F:ATY]TYPTYP,9,10)
   Gosub ECRIZONE From DOSTAB
  Endif
 Next
 # On met les blobs/clobs à la fin
 For [ATZ]NUMLIG Where CODFIC=TABLE & find(CODTYP,"AXX","AX1","AX2","AX3")=0
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  If !fstat & find([F:ATY]TYPTYP,9,10)
   Gosub ECRIZONE From DOSTAB
  Endif
 Next
 adxifs = "" : # Index clusterisé possible
 Rdseq OBID Using [FSRF]
 I = instr(1,OBID,chr$(9))
 If I
  OCLUSTER = right$(OBID,I+1)
 Else
  OCLUSTER = ""
 Endif
 adxifs = chr$(9)
# ONIND = min(val(OBID),dim(ONOMCLE))
# For I=1 To ONIND
#  Rdseq ONOMCLE(I),OTYPCLE(I),OINDEX(I),ODECLI(I) Using [FSRF]
# Next I
 I=0
 For [ATI]NUMLIG Where CODFIC=TABLE
  [L]DESCRIPT=[F:ATI]DESCRIPT
  Call VERF_INDEX( [L]DESCRIPT,TABLE,[F:ATI]CODIND,[F:ATI]CODACT,OK) From DOSTAB
  If OK & [L]DESCRIPT<>""
   I+=1
   ONOMCLE(I)=[F:ATI]CODIND
   If [F:ATI]HOMONYM=2
    OTYPCLE(I)="1"
   Else
    OTYPCLE(I)="2"
   Endif
   OINDEX(I)=[L]DESCRIPT
   ODECLI(I)=""
  Endif
 Next
 ONIND=I
 Wrseq ONIND,OCLUSTER Using [ECR_]
 For I=1 To ONIND
   Wrseq ONOMCLE(I),OTYPCLE(I),OINDEX(I),ODECLI(I) Using [ECR_]
 Next
 Openi Using [FSRF]
 Openo Using [ECR_]

 FICORG = filpath("FIL",TABLE,"old",APPLI)
 Call MOVE(FICSRF,FICORG,STAT) From ORDSYS
 Call MOVE(FICNEW,FICSRF,STAT) From ORDSYS

$FIN_FICSRF
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Close Local File
Return

