#######################################################################################
Funprog LOAD_ANALYTICAL_VALUES(PJMTE, TECDIECCE)
Variable Instance PJMTE Using C_PJMTIMEMP
Variable Instance TECDIECCE Using C_TECDIECCE

Local Integer IARENDRE
Local Char SOPPNUM(GLONOPP)

  # Issue X3-81871 - 2018-03-08 by FGR
  IARENDRE = [V]CST_AOK
  # -----------------------------
  Local File PIMPL [PIM]
  Local File OPPORPJM [OPPPJM]
  Local File OPPOR [OPP]
  # -----------------------------
  If PJMTE.PIMTASCOD <> AVOID.ACHAR Then
    Read [PIM]PIM0=PJMTE.PIMTASCOD
  Elsif PJMTE.PIMPBUCOD <> AVOID.ACHAR Then
    Read [PIM]PIM0=PJMTE.PIMPBUCOD
  Endif
  Read [OPPPJM]OPPPJM0=[F:PIM]OPPNUM
  Read [OPP]OPP0=[F:PIM]OPPNUM
  # -----------------------------
  IARENDRE = fmet TECDIECCE.SET_IDENTIFIER(2, [F:OPP]OPPCMP)
  IARENDRE = fmet TECDIECCE.SET_IDENTIFIER(7, [F:PIM]CPY)
  IARENDRE = fmet TECDIECCE.SET_IDENTIFIER(8, [F:PIM]FCY)
  IARENDRE = fmet TECDIECCE.SET_IDENTIFIER(9, [F:OPP]CUR)
  IARENDRE = fmet TECDIECCE.SET_IDENTIFIER(24, [F:PIM]OPPNUM)
End IARENDRE

