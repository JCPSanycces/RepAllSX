#######################################################################################
$_LOAD_MANAGED_CASES
Local Integer IWST
Local Char SWST(GLONWST)(1..)
Local Integer IAUS
Local Char SAUS(GLONAUS)(1..)
Local Integer NII

  # load STYP/SVALUE to manage all cases to check (WST, AUS...)
  IWST = 0
  IAUS = 0
  For NII = 1 To maxtab(STYP)
    If STYP(NII) = AVOID.ACHAR Then
      Break
    Else
      Case STYP(NII)
        When "WST"
          IWST += 1
          SWST(IWST) = SVALUE(NII)
        When "AUS"
          IAUS += 1
          SAUS(IAUS) = SVALUE(NII)
        When Default
          [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR("", func AFNC.MES1(mess(450,2260,1), STYP(NII)), [V]CST_AERROR))
      Endcase
    Endif
  Next NII
Return

#######################################################################################
Funprog IS_DAY_FCY_VALID(FCY, TDATE)
Value Char FCY
Value Date TDATE

Local Integer IRETURN_VALUE
Local Integer NI

  [L]IRETURN_VALUE = [V]CST_AYES
  # -----------------------------
  Local File FACILITY [FCY]
  # -----------------------------
  Read [FCY]FCY0=FCY
  If TDATE = [0/0/0] Then
    # Check if there is at least one day open
    [L]IRETURN_VALUE = [V]CST_ANO
    For NI = 0 To dim([F:FCY]UVYDAY)-1
      If [F:FCY]UVYDAY(NI) = [V]CST_AYES Then
        [L]IRETURN_VALUE = [V]CST_AYES
        Break
      Endif
    Next NI
  Else
    # Check if the date day is open
    If [F:FCY]UVYDAY(dayn(TDATE)-1) = [V]CST_ANO Then
      [L]IRETURN_VALUE = [V]CST_ANO
    Endif
  Endif
  # -----------------------------
End IRETURN_VALUE

#######################################################################################
Funprog IS_PERIOD_FCY_VALID(AINSTANCE, FCY, TDATE, SWHY)
Variable Instance AINSTANCE Using OBJECT
Value Char FCY
Value Date TDATE
Variable Char SWHY

Local Integer IRETURN_VALUE
Local Integer NI

  [L]IRETURN_VALUE = [V]CST_AYES
  # -----------------------------
  Local File FACILITY [FCY]
  Local File TABUNAVAIL [TUV]
  # -----------------------------
  Raz SWHY
  Read [FCY]FCY0=FCY
  # -----------------------------
  If [F:FCY]UVYCOD <> AVOID.ACHAR Then
    Read [F:TUV]UVY0=[F:FCY]UVYCOD
    For NI = 0 To [F:TUV]UVYNBR-1
      If TDATE >= [F:TUV]UVYSTRDAT(NI) and TDATE <= [F:TUV]UVYENDDAT(NI) Then
        [L]IRETURN_VALUE = [V]CST_ANO
        Call LECTEXTRA_SYR(AINSTANCE, AVOID.ACHAR, SWHY, "TABUNAVAIL", "UVYAXX", [F:TUV]UVYCOD, num$(val([F:TUV]UVYSTRDAT(NI)))) From ATEXTRA
        Break
      Endif
    Next NI
  Endif
  # -----------------------------
End IRETURN_VALUE

# Issue X3-47483 - 2017-08-21 by SINGC/FGR : START
#######################################################################################
Funprog _IS_DAY_WST_VALID(WST, FCY, TDATE)
Value Char WST()(1..)
Value Char FCY
Value Date TDATE

Local Integer IRETURN_VALUE
Local Integer NI

  [L]IRETURN_VALUE = [V]CST_AYES
  For NI = 1 To maxtab(WST)
    [L]IRETURN_VALUE = func IS_DAY_WST_VALID(WST(NI), FCY, TDATE)   # Issue X3-48424 - 2017-11-08 by SINGC/FGR : not "WST", but "WST(NI)"
    If [L]IRETURN_VALUE = [V]CST_ANO Then
      Break
    Endif
  Next NI
End IRETURN_VALUE

#######################################################################################
# Issue X3-48424 - 2017-11-08 by SINGC/FGR : BEGIN
Funprog IS_DAY_WST_VALID(WST, FCY, TDATE)
Value Char WST
Value Char FCY
Value Date TDATE

Local Integer IRETURN_VALUE
Local Integer NI
Local Char SFCY(GLONFCY)

  [L]IRETURN_VALUE = [V]CST_AYES
  # -----------------------------
  Local File WORKSTATIO [MWS]
  Local File CAPVAR     [CPV]
  # -----------------------------
  If WST <> AVOID.ACHAR Then
    For SFCY = FCY, ""
      Read [MWS]WST0=WST;SFCY
      If !fstat Then
        [L]IRETURN_VALUE = func IS_TABWEEDIA_VALID([F:MWS]TWD, TDATE, AVOID.ACHAR)
        If [L]IRETURN_VALUE = [V]CST_AYES Then
          Read [CPV]CPV0=[F:MWS]WST;[F:MWS]WCRFCY
          If !fstat Then
            For NI = 0 To dim([F:CPV]TWD)-1
              If [F:CPV]TWD(NI) = AVOID.ACHAR Then
                Break
              Endif
              If [F:CPV]STRDAT(NI) >= TDATE and [F:CPV]ENDDAT(NI) <= TDATE Then
                [L]IRETURN_VALUE = func IS_TABWEEDIA_VALID([F:CPV]TWD(NI), TDATE, AVOID.ACHAR)
              Endif
            Next NI
          Endif
        Endif
        Break
      Endif
    Next SFCY
  Endif
End IRETURN_VALUE

