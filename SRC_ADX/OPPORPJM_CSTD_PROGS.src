#######################################################################################
Funprog _IS_DAY_AUS_VALID(AUS, TDATE, THOUR)
Value Char AUS()(1..)
Value Date TDATE
Value Char THOUR

Local Integer IRETURN_VALUE
Local Integer NI

  # Issue X3-48424 - 2017-11-08 by SINGC/FGR
  [L]IRETURN_VALUE = [V]CST_AYES
  For NI = 1 To maxtab(AUS)
    [L]IRETURN_VALUE = func IS_DAY_AUS_VALID(AUS(NI), TDATE, THOUR)
    If [L]IRETURN_VALUE = [V]CST_ANO Then
      Break
    Endif
  Next NI
End IRETURN_VALUE

#######################################################################################
Funprog IS_DAY_AUS_VALID(SAUS, TDATE, THOUR)
Value Char SAUS
Value Date TDATE
Value Char THOUR

Local Integer IRETURN_VALUE
Local Integer IFOUND

  # Issue X3-48424 - 2017-11-08 by SINGC/FGR
  [L]IRETURN_VALUE = [V]CST_AYES
  # -----------------------------
  Local File PJMAUS     [PAUS]
  Local File PJMAUSCAVA [PJCV]
  # -----------------------------
  If SAUS <> AVOID.ACHAR Then
    Read [PAUS]PAUS=SAUS
    If !fstat Then
      IFOUND = [V]CST_ANO
      Filter [PJCV] Where [F:PJCV]PAUS = SAUS and [F:PJCV]STRDAT >= TDATE and [F:PJCV]ENDDAT <= TDATE
      For [PJCV]
        [L]IRETURN_VALUE = func IS_TABWEEDIA_VALID([F:PJCV]VARTWD, TDATE, THOUR)
        IFOUND = [V]CST_AYES
        Break
      Next
      Filter [PJCV]
      If [L]IRETURN_VALUE = [V]CST_AYES Then
        If IFOUND = [V]CST_ANO Then
          If [F:PAUS]TWD <> AVOID.ACHAR Then
            [L]IRETURN_VALUE = func IS_TABWEEDIA_VALID([F:PAUS]TWD, TDATE, THOUR)
          Endif
        Endif
      Endif
    Endif
  Endif
End IRETURN_VALUE

#######################################################################################
Funprog GET_DAY_AUS_VALID(SAUS, TDATE, THOUR)
Value Char SAUS
Variable Date TDATE
Variable Char THOUR

Local Integer IRETURN_VALUE
Local Integer IFOUND

  # Issue X3-48424 - 2017-11-08 by SINGC/FGR
  [L]IRETURN_VALUE = [V]CST_AYES
  # -----------------------------
  Local File PJMAUS     [PAUS]
  Local File PJMAUSCAVA [PJCV]
  # -----------------------------
  If SAUS <> AVOID.ACHAR Then
    Read [PAUS]PAUS=SAUS
    If !fstat Then
      IFOUND = [V]CST_ANO
      Filter [PJCV] Where [F:PJCV]PAUS = SAUS and [F:PJCV]STRDAT >= TDATE and [F:PJCV]ENDDAT <= TDATE
      For [PJCV]
        [L]IRETURN_VALUE = func GET_DIAHOU_VALID([F:PJCV]VARTWD, TDATE, THOUR)
        IFOUND = [V]CST_AYES
        Break
      Next
      Filter [PJCV]
      If [L]IRETURN_VALUE = [V]CST_AYES Then
        If IFOUND = [V]CST_ANO Then
          If [F:PAUS]TWD <> AVOID.ACHAR Then
            [L]IRETURN_VALUE = func GET_DIAHOU_VALID([F:PAUS]TWD, TDATE, THOUR)
          Endif
        Endif
      Endif
    Endif
  Endif
End IRETURN_VALUE

#######################################################################################
Funprog IS_TABWEEDIA_VALID(STWD, TDATE, THOUR)
Value Char STWD
Value Date TDATE
Value Char THOUR

Local Integer IRETURN_VALUE
Local Integer IFOUND
Local Integer NE

  # Issue X3-48424 - 2017-11-08 by SINGC/FGR
  [L]IRETURN_VALUE = [V]CST_AYES
  # -----------------------------
  Local File TABWEEDIA [TWD]
  Local File DIAHOU    [DIH]
  # -----------------------------
  Read [TWD]TWD0=STWD
  If TDATE = AVOID.ADATE Then
    # Check if there is at least one day open
    IFOUND = [V]CST_ANO
    For NE = 0 To dim([F:TWD]DAYCAP)-1
      If [F:TWD]DAYCAP(NE) > 0 Then
        IFOUND = [V]CST_AYES
        Break
      Endif
    Next NE
    If IFOUND = [V]CST_ANO Then
      [L]IRETURN_VALUE = [V]CST_ANO
    Endif
  Else
    # Check if the date day is open
    If [F:TWD]DAYCAP(dayn(TDATE)-1) = 0 Then
      [L]IRETURN_VALUE = [V]CST_ANO
    Endif
    If [L]IRETURN_VALUE = [V]CST_AYES Then
      If THOUR <> AVOID.ACHAR Then
        If [F:TWD]DAYCAP(dayn(TDATE)-1) > 0 and [F:TWD]DIAHOU(dayn(TDATE)-1) <> AVOID.ACHAR Then
          IFOUND = [V]CST_ANO
          Read [DIH]DIH0=[F:TWD]DIAHOU(dayn(TDATE)-1)
          For NE = 0 To dim([F:DIH]STRHOU)-1
            If [F:DIH]STRHOU(NE) <> AVOID.ACHAR and [F:DIH]ENDHOU(NE) <> AVOID.ACHAR Then
              If THOUR >= [F:DIH]STRHOU(NE) and THOUR <= [F:DIH]ENDHOU(NE) Then
                IFOUND = [V]CST_AYES
                Break
              Endif
            Endif
          Next NE
          If IFOUND = [V]CST_ANO Then
            [L]IRETURN_VALUE = [V]CST_ANO
          Endif
        Endif
      Endif
    Endif
  Endif
End IRETURN_VALUE

#######################################################################################
Funprog _GET_DIAHOU_VALID(SAUS, TDATE, THOUR)
Value Char SAUS()(1..)
Variable Date TDATE
Variable Char THOUR

Local Integer IRETURN_VALUE
Local Integer NI

  # Issue X3-48424 - 2017-11-08 by SINGC/FGR
  [L]IRETURN_VALUE = [V]CST_AYES
  # -----------------------------
  Local File PJMAUS [PAUS]
  Local File PJMAUSCAVA [PJCV]
  # -----------------------------
  For NI = 1 To maxtab(SAUS)
    Read [PAUS]PAUS=SAUS(NI)
    If !fstat Then
      Filter [PJCV] Where [F:PJCV]PAUS = SAUS(NI) and [F:PJCV]STRDAT >= TDATE and [F:PJCV]ENDDAT <= TDATE
      For [PJCV]
        [L]IRETURN_VALUE = func GET_DIAHOU_VALID([F:PJCV]VARTWD, TDATE, THOUR)
        If [L]IRETURN_VALUE = [V]CST_ANO Then
          Break
        Endif
      Next
      Filter [PJCV]
      # -----------------------------
      If [L]IRETURN_VALUE = [V]CST_AYES Then
        If [F:PAUS]TWD <> AVOID.ACHAR Then
          [L]IRETURN_VALUE = func GET_DIAHOU_VALID([F:PAUS]TWD, TDATE, THOUR)
          If [L]IRETURN_VALUE = [V]CST_ANO Then
            Break
          Endif
        Endif
      Endif
    Endif
  Next NI
End IRETURN_VALUE

#######################################################################################
Funprog GET_DIAHOU_VALID(STWD, TDATE, THOUR)
Value Char STWD
Variable Date TDATE
Variable Char THOUR

Local Integer IRETURN_VALUE
Local Integer IFOUND
Local Integer NE

  # Issue X3-48424 - 2017-11-08 by SINGC/FGR
  [L]IRETURN_VALUE = [V]CST_AYES
  If STWD <> AVOID.ACHAR and TDATE <> AVOID.ADATE and THOUR <> AVOID.ACHAR Then
    Local File TABWEEDIA [TWD]
    Local File DIAHOU    [DIH]
    Read [TWD]TWD0=STWD
    If [F:TWD]DAYCAP(dayn(TDATE)-1) > 0 and [F:TWD]DIAHOU(dayn(TDATE)-1) <> AVOID.ACHAR Then
      IFOUND = [V]CST_ANO
      Read [DIH]DIH0=[F:TWD]DIAHOU(dayn(TDATE)-1)
      For NE = 0 To dim([F:DIH]STRHOU)-1
        If [F:DIH]STRHOU(NE) <> AVOID.ACHAR and [F:DIH]ENDHOU(NE) <> AVOID.ACHAR Then
          If THOUR >= [F:DIH]STRHOU(NE) and THOUR <= [F:DIH]ENDHOU(NE) Then
            # If the hour is correct regarding the setup : hour is not replaced
            IFOUND = [V]CST_AYES
            Break
          Endif
        Endif
      Next NE
      If IFOUND = [V]CST_ANO Then
        For NE = 0 To dim([F:DIH]STRHOU)-1
          If [F:DIH]STRHOU(NE) <> AVOID.ACHAR and [F:DIH]ENDHOU(NE) <> AVOID.ACHAR Then
            # If hour is incorrect, replaced by the first one not empty
            THOUR = [F:DIH]STRHOU(NE)
            IFOUND = [V]CST_AYES
            Break
          Endif
        Next NE
      Endif
      If IFOUND = [V]CST_ANO Then
        [L]IRETURN_VALUE = [V]CST_ANO
      Endif
    Else
      # If the date is incorrect regarding the setup : hour is not replaced
      [L]IRETURN_VALUE = [V]CST_ANO
    Endif
  Endif
End IRETURN_VALUE

#######################################################################################
Funprog IS_PJMCLOB_EXIST(ACTX, SCODBLB, SIDENT1, SIDENT2, SIDENT3, SIDENT4)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SCODBLB
Value Char SIDENT1
Value Char SIDENT2
Value Char SIDENT3
Value Char SIDENT4

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-02-24 by SINGC/FGR
  IARENDRE = [V]CST_ANO
  # -----------------------------
  Local File VPJMCLOB [VPJCB]
  # -----------------------------
  Look [VPJCB]VPJCB0=SCODBLB;SIDENT1;SIDENT2;SIDENT3;SIDENT4
  If !fstat Then
    IARENDRE = [V]CST_AYES
  Endif
  # -----------------------------
End IARENDRE

#######################################################################################
Funprog CONTROL_HOURS_BEGIN_END(AINSTANCE, DBEGDAT, SBEGHOUPRO, SBEGHOU, DENDDAT, SENDHOUPRO, SENDHOU)
Variable Instance AINSTANCE Using OBJECT
Value Date DBEGDAT
Value Char SBEGHOUPRO
Value Char SBEGHOU
Value Date DENDDAT
Value Char SENDHOUPRO
Value Char SENDHOU

Local Integer IRETURN_VALUE
Local Char SFORMAT(250)
Local Char SBEGINH(250)
Local Char SENDH(250)

  # Issue X3-30028/122466 - 2017-04-10 by FGR
  [L]IRETURN_VALUE = [V]CST_AOK
  # -----------------------------
  If DBEGDAT = DENDDAT Then
    If SENDHOU < SBEGHOU Then
      SFORMAT = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALCHAR("HM", "FORTYP")
      SBEGINH = format$(SFORMAT, SBEGHOU)
      SENDH = format$(SFORMAT, SENDHOU)
      [L]IRETURN_VALUE = fmet AINSTANCE.SETERROR(SENDHOUPRO, func AFNC.MES2(mess(520,2260,1), SBEGINH, SENDH), [V]CST_AERROR)
    Endif
  Endif
  # -----------------------------
End IRETURN_VALUE

#######################################################################################
Funprog OPPDESTEX_EXIST(ACTX, SIDENT2)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-02-24 by SINGC/FGR
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "OPPORPJM", "OPPDESTEX", SIDENT2, AVOID.ACHAR, AVOID.ACHAR)
End IARENDRE

#######################################################################################
Funprog OPPCOMTEX_EXIST(ACTX, SIDENT2)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-02-24 by SINGC/FGR
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "OPPORPJM", "OPPCOMTEX", SIDENT2, AVOID.ACHAR, AVOID.ACHAR)
End IARENDRE

#######################################################################################
Funprog PJMCLOB_GET_ICON(ACTX, IBOOLEAN)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Integer IBOOLEAN

Local Char SARENDRE(GLONICO)

  # Issue X3-6422/120397 - 2017-03-17 by SINGC/FGR
  If IBOOLEAN = [V]CST_ATRUE Then
    SARENDRE = "159"
  Else
    SARENDRE = "138"
  Endif
End SARENDRE

#######################################################################################
Funprog GET_CUROPP_VALUE(ACTX, PROJECT, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char PROJECT
Variable Char SMESSAGE

Local Char SARENDRE(GLONCUR)

  # Issue X3-68131 - 2018-02-12 by FGR
  Raz SARENDRE
  Raz SMESSAGE
  If PROJECT = AVOID.ACHAR Then
    SMESSAGE = mess(9,135,1)
  Else
    # -------------------------
    Local File OPPORPJM [OPPPJM]
    # -------------------------
    Read [OPPPJM]OPPPJM0=PROJECT
    If fstat Then
      SMESSAGE = mess(243,107,1) - PROJECT
    Else
      SARENDRE = [F:OPPPJM]CUROPP
    Endif
    # -------------------------
  Endif
End SARENDRE

#######################################################################################
Funprog GET_ANALYTICAL(SOPPNUM, PJMTE)
Value Char SOPPNUM
Variable Instance PJMTE Using C_PJMTIMEMP

Local Integer IARENDRE
Local Integer NI
Local Integer ILINE
Local Char SMESSAGE(250)
Local Char SCPY(GLONCPY)

  # Issue X3-81871 - 2018-03-08 by FGR
  IARENDRE = [V]CST_AOK
  # -----------------------------
  Local File OPPORPJM [OPPPJM]
  # -----------------------------
  Read [OPPPJM]OPPPJM0=SOPPNUM
  If fstat Then
    IARENDRE = fmet PJMTE.SETERROR("", mess(163,2260,1), [V]CST_AERROR)
  Else
    IARENDRE = fmet PJMTE.CDIE_DELETE()
    If IARENDRE <= [V]CST_AERROR Then
      For NI = 0 To dim([F:OPPPJM]DIE)-1
        If [F:OPPPJM]DIE(NI) <> AVOID.ACHAR Then
          ILINE = fmet PJMTE.ADDLINE("CDIE", [V]CST_ALASTPOS)
          If ILINE = [V]CST_ANOTDEFINED Then
            IARENDRE = [V]CST_AERROR
            Break
          Endif
          PJMTE.CDIE(ILINE).DIE = [F:OPPPJM]DIE(NI)
        Else
          Break
        Endif
      Next NI
      # -----------------------------
      SCPY = fmet PJMTE.ACTX.ACACHE.AFCY.AGETVALCHAR(PJMTE.FCY, "LEGCPY")
      IARENDRE = func TECDIECCE_CSTD.GET_DEFAULT_VALUES(PJMTE, "PTE", SCPY, "CDIE", "DIE", "CCE", AVOID.ACHAR, SMESSAGE)
      If SMESSAGE <> AVOID.ACHAR Then
        IARENDRE = fmet PJMTE.SETERROR("", SMESSAGE, IARENDRE)
      Endif
      # -----------------------------
    Endif
  Endif
End IARENDRE

