#######################################################################################
# Issue X3-48424 - 2017-11-08 by SINGC/FGR : BEGIN
Funprog GET_OFFSET_RECTIFIED(AINSTANCE, FCY, STYP, SVALUE, TDATE, THOUR, IOFFSET, ITODO, ROFFSET)
Variable Instance AINSTANCE Using OBJECT
Value Char FCY
Value Char STYP()(1..)
Value Char SVALUE()(1..)
Value Date TDATE
Value Char THOUR
Value Integer IOFFSET
Value Integer ITODO
Variable Integer ROFFSET

Local Integer IRETURN_VALUE
Local Integer ICALDATE
Local Char SWHY(100)
Local Char SWHY2(100)
Local Integer NI
Local Integer NE
Local Integer NZ
Local Date DDATE
Local Char SHOUR(GLONHM)

  # Issue X3-53165 - 2017-10-11 by FGR
  [L]IRETURN_VALUE = [V]CST_AOK
  # -----------------------------
  ROFFSET = IOFFSET
  If ROFFSET <> 0 and TDATE <> [0/0/0] Then
    If ITODO <> 1 and ITODO <> 2 Then
      [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR("", func AFNC.MES1(mess(450,2260,1), num$(ITODO)), [V]CST_AERROR))
    Else
      # ---------------------
      If ITODO = 1 Then
        # increase the offset
        ICALDATE = 1
      Else
        # decrease the offset
        ICALDATE = -1
      Endif
      # ---------------------
      Gosub _LOAD_MANAGED_CASES  # Extract WST and AUS from STYP, SVALUE
      If [L]IRETURN_VALUE <= [V]CST_AWARNING Then
        # ---------------------
        # Neutralize days off in the IOFFSET period
        NZ = IOFFSET
        DDATE = TDATE
        SHOUR = THOUR
        Repeat
          NE = NZ
          NZ = 0
          For NI = 1 To abs(NE)
            If IOFFSET > 0 Then
              DDATE = DDATE + 1
            Else
              DDATE = DDATE - 1
            Endif
            If func IS_DAY_FCY_VALID(FCY, DDATE) = [V]CST_ANO or
&              func IS_PERIOD_FCY_VALID(AINSTANCE, FCY, DDATE, SWHY) = [V]CST_ANO or
&              func _IS_DAY_WST_VALID(SWST, FCY, DDATE) = [V]CST_ANO or
&              func _IS_DAY_AUS_VALID(SAUS, DDATE, SHOUR) = [V]CST_ANO
&           Then
              NZ += 1
              If IOFFSET > 0 Then
                # If from the current dat to the lag time (IOFFSET) their is not available date, we have to increase the lag time (ROFFSET)
                # => To start at really IOFFSET open day
                ROFFSET += 1
              Else
                # If from the current dat to the lag time (IOFFSET) their is not available date, we have to decrease the lag time (ROFFSET)
                # => To start at really IOFFSET open day
                ROFFSET -= 1
              Endif
            Endif
          Next NI
        Until NZ = 0
        # ---------------------
        DDATE = TDATE + ROFFSET
        If func IS_DAY_FCY_VALID(FCY, DDATE) = [V]CST_ANO or
&          func IS_PERIOD_FCY_VALID(AINSTANCE, FCY, DDATE, SWHY) = [V]CST_ANO or
&          func _IS_DAY_WST_VALID(SWST, FCY, DDATE) = [V]CST_ANO or
&          func _IS_DAY_AUS_VALID(SAUS, DDATE, SHOUR) = [V]CST_ANO
&       Then
          NI = 0
          Repeat
            ROFFSET += ICALDATE
            DDATE = TDATE + ROFFSET
            # -----------------------------
            If SHOUR <> AVOID.ACHAR Then
              IRET = func GET_DIAHOU_VALID(SAUS, DDATE, SHOUR)
            Endif
            # Manage a break case to not have a non-stop loop if setup is bad
            NI += 1
            If NI > 360 Then
              Raz DDATE
              Raz SHOUR
              Break
            Endif
            # -----------------------------
          Until func IS_DAY_FCY_VALID(FCY, DDATE) = [V]CST_AYES and
&               func IS_PERIOD_FCY_VALID(AINSTANCE, FCY, DDATE, SWHY2) = [V]CST_AYES and
&               func _IS_DAY_WST_VALID(SWST, FCY, DDATE) = [V]CST_AYES and
&               func _IS_DAY_AUS_VALID(SAUS, DDATE, SHOUR) = [V]CST_AYES
          If DDATE = [0/0/0] Then
            [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR("", func AFNC.MES2(mess(973,2260,1), format$(GFMDAT,TDATE), SWHY), [V]CST_AWARNING))
          Endif
        Endif
      Endif
    Endif
  Endif
End IRETURN_VALUE

