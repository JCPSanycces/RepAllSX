# Issue X3-48424 - 2017-11-08 by SINGC/FGR : BEGIN
Funprog CHECK_DATE_VALIDITY(AINSTANCE, SPROPERTY, FCY, STYP, SVALUE, TDATE, THOUR, ITODO, RDATE, RHOUR)
Variable Instance AINSTANCE Using OBJECT
Value Char SPROPERTY
Value Char FCY
Value Char STYP()(1..)
Value Char SVALUE()(1..)
Value Date TDATE
Value Char THOUR
Value Integer ITODO
Variable Date RDATE
Variable Char RHOUR

Local Integer IRETURN_VALUE
Local Integer IRET
Local Integer NI
Local Integer ICALDATE
Local Char SWHY(100)
Local Char SWHY2(100)
Local Char SFORMAT(250)

  [L]IRETURN_VALUE = [V]CST_AOK
  # -----------------------------
  Raz RDATE
  Raz RHOUR
  SFORMAT = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALCHAR("HM", "FORTYP")
  # -----------------------------
  If TDATE <> [0/0/0] Then
    If ITODO <> 1 and ITODO <> 2 and ITODO <> 3 and ITODO <> 4 Then
     [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR(SPROPERTY, func AFNC.MES1(mess(450,2260,1), num$(ITODO)), [V]CST_AERROR))
    Else
      Gosub _LOAD_MANAGED_CASES
      # -----------------------------
      If func IS_DAY_FCY_VALID(FCY, [0/0/0]) = [V]CST_ANO Then
        [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR(SPROPERTY, func AFNC.MES1(mess(453,2260,1), FCY), [V]CST_AERROR))
      Endif
      For NI = 1 To maxtab(SWST)
        If func IS_DAY_WST_VALID(SWST(NI), FCY, AVOID.ADATE) = [V]CST_ANO Then
          [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR(SPROPERTY, func AFNC.MES1(mess(965,2260,1), SWST(NI)), [V]CST_AERROR))
        Endif
      Next NI
      For NI = 1 To maxtab(SAUS)
        If func IS_DAY_AUS_VALID(SAUS(NI), AVOID.ADATE, AVOID.ACHAR) = [V]CST_ANO Then
          [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR(SPROPERTY, func AFNC.MES1(mess(1000,2260,1), SAUS(NI)), [V]CST_AERROR))
        Endif
      Next NI
      # -----------------------------
      If [L]IRETURN_VALUE < [V]CST_AERROR Then
        If ITODO = 3 or ITODO = 4 Then
          If ITODO = 3 Then
            IRET = [V]CST_AWARNING
          Else
            IRET = [V]CST_AERROR
          Endif
          If func IS_DAY_FCY_VALID(FCY, TDATE) = [V]CST_ANO Then
            [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR(SPROPERTY, func AFNC.MES2(mess(451,2260,1), mess(dayn(TDATE),742,1), FCY), IRET))
          Endif
          If func IS_PERIOD_FCY_VALID(AINSTANCE, FCY, TDATE, SWHY) = [V]CST_ANO Then
            [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR(SPROPERTY, func AFNC.MES3(mess(452,2260,1), format$(GFMDAT,TDATE), FCY, SWHY), IRET))
          Endif
          For NI = 1 To maxtab(SWST)
            If func IS_DAY_WST_VALID(SWST(NI), FCY, TDATE) = [V]CST_ANO Then
              [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR(SPROPERTY, func AFNC.MES2(mess(971,2260,1), format$(GFMDAT,TDATE), SWST(NI)), IRET))
            Endif
          Next NI
          For NI = 1 To maxtab(SAUS)
            If func IS_DAY_AUS_VALID(SAUS(NI), TDATE, THOUR) = [V]CST_ANO Then
              [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR(SPROPERTY, func AFNC.MES2(mess(1001,2260,1), format$(GFMDAT,TDATE), SAUS(NI)), IRET))
            Endif
          Next NI
        Else
          If ITODO = 1 Then
            ICALDATE = 1
          Else
            ICALDATE = -1
          Endif
          If func IS_DAY_FCY_VALID(FCY, TDATE) = [V]CST_ANO or
&            func IS_PERIOD_FCY_VALID(AINSTANCE, FCY, TDATE, SWHY) = [V]CST_ANO or
&            func _IS_DAY_WST_VALID(SWST, FCY, TDATE) = [V]CST_ANO or
&            func _IS_DAY_AUS_VALID(SAUS, TDATE, THOUR) = [V]CST_ANO
&         Then
            RDATE = TDATE
            RHOUR = THOUR
            NI = 0
            Repeat
              # -----------------------------
              If THOUR <> AVOID.ACHAR Then
                IRET = func _GET_DIAHOU_VALID(SAUS, RDATE, RHOUR)
                If IRET = [V]CST_ANO Then
                  RDATE = RDATE + ICALDATE
                  RHOUR = THOUR
                Endif
              Else
                RDATE = RDATE + ICALDATE
              Endif
              # -----------------------------
              # Manage a break case to not have a non-stop loop if setup is bad
              NI += 1
              If NI > 360 Then
                Raz RDATE
                Raz RHOUR
                Break
              Endif
              # -----------------------------
            Until func IS_DAY_FCY_VALID(FCY, RDATE) = [V]CST_AYES and
&                 func IS_PERIOD_FCY_VALID(AINSTANCE, FCY, RDATE, SWHY2) = [V]CST_AYES and
&                 func _IS_DAY_WST_VALID(SWST, FCY, RDATE) = [V]CST_AYES and
&                 func _IS_DAY_AUS_VALID(SAUS, RDATE, RHOUR) = [V]CST_AYES
            If RDATE <> [0/0/0] Then
              If THOUR <> RHOUR Then
                [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR(SPROPERTY, func AFNC.MES5(mess(1017,2260,1), format$(GFMDAT,TDATE), format$(SFORMAT,THOUR), SWHY,
&                                                                                format$(GFMDAT,RDATE), format$(SFORMAT,RHOUR)), [V]CST_AWARNING))
              Else
                [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR(SPROPERTY, func AFNC.MES3(mess(972,2260,1), format$(GFMDAT,TDATE), SWHY, format$(GFMDAT,RDATE)), [V]CST_AWARNING))
              Endif
            Else
              If THOUR <> RHOUR Then
                [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR(SPROPERTY, func AFNC.MES3(mess(1018,2260,1), format$(GFMDAT,TDATE), format$(SFORMAT,THOUR), SWHY), [V]CST_AWARNING))
              Else
                [L]IRETURN_VALUE = max([L]IRETURN_VALUE, fmet AINSTANCE.SETERROR(SPROPERTY, func AFNC.MES2(mess(973,2260,1), format$(GFMDAT,TDATE), SWHY), [V]CST_AWARNING))
              Endif
            Endif
          Else
            RDATE = TDATE
            RHOUR = THOUR
          Endif
        Endif
      Endif
    Endif
  Endif
  # -----------------------------
End IRETURN_VALUE

