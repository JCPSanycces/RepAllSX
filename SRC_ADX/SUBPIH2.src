#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque PDSYSIH

######################################################################################
## Clic droit Pièce sur la livraison
######################################################################################
Subprog IB_NBSDH

  GBOUT2 = mess(129,197,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESSDH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBSDH
Local Integer NOL

  Filter [F:SDH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PIH2]SDHNUM(NOL) 
  Call OBJET("SDH",[M:PIH2]SDHNUM(NOL),"") From GOBJET
  [M:PIH2]SDHNUM(NOL) = SAV_VCRNUM 

  GCONSULT = 0
End

######################################################################################
## Clic droit Pièce sur l'avoir/facture
######################################################################################
Subprog IB_NBSIH

  If clalev([M:PIH2]) Then
    GBOUT2 = mess(55,198,1)
  Elsif clalev([M:PII2]) Then
    GBOUT2 = mess(2,267,1)
  Endif
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESSIH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBSIH
Local Integer NOL

  If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif 
  Filter [F:SIH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  If clalev([M:PIH2]) Then
    SAV_VCRNUM = [M:PIH2]NUM(NOL)
    Call OBJET("SIH",[M:PIH2]NUM(NOL),"2") From GOBJET
    [M:PIH2]NUM(NOL) = SAV_VCRNUM 
  Elsif clalev([M:PII2]) Then
    SAV_VCRNUM = [M:PII2]NUM(NOL)
    Call OBJET("SIH",[M:PIH2]NUM(NOL),"1") From GOBJET
    [M:PII2]NUM(NOL) = SAV_VCRNUM 
  Endif

  GCONSULT = 0
End

######################################################################################
## Clic droit Pièce sur la commande
######################################################################################
Subprog IB_NBSOH

  GBOUT2 = mess(191,198,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If [M:PIH2]SOHCAT(nolign-1)<>4 Then
      If find("GESSOH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
    Else
      If find("GESSOQ",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
    Endif
  Endif
End

Subprog B2_NBSOH
Local Integer NOL

  Filter [F:SOH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PIH2]SOHNUM(NOL)
  If [M:PIH2]SOHCAT(NOL)<>4 Then
    Call OBJET("SOH",[M:PIH2]SOHNUM(NOL),"") From GOBJET
  Else
    Call OBJET("SOQ",[M:PIH2]SOHNUM(NOL),"") From GOBJET
  Endif
  [M:PIH2]SOHNUM(NOL) = SAV_VCRNUM 

  GCONSULT = 0
End


######################################################################################
## Clic droit Pièce sur la pièce d'origine
######################################################################################
Subprog IB_NBORI
Local Char NOM_FUNC

  Case [M]ORITYP(nolign-1)
    When 2 : GBOUT2=mess(191,198,1) : NOM_FUNC="GESSOH"  
    When 3 : GBOUT2=mess(129,197,1) : NOM_FUNC="GESSDH"
    When 4 : GBOUT2=mess(055,198,1) : NOM_FUNC="GESSIH"
    When 5 : GBOUT2=mess(121,198,1) : NOM_FUNC="GESSQH"
    When 6 : GBOUT2=mess(192,198,1) : NOM_FUNC="GESSRH"
  Endcase
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find(NOM_FUNC,GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBORI
Local Char    NOM_OBJET, SAV_VCRNUM
Local Integer NOL

  GCONSULT = 2
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1 
  SAV_VCRNUM = [M]ORINUM(NOL)

  If clalev([F:SOH])=0 : Local File SORDER     [SOH] : Endif
  If clalev([F:SDH])=0 : Local File SDELIVERY  [SDH] : Endif 
  If clalev([F:SQH])=0 : Local File SQUOTE     [SQH] : Endif 
  If clalev([F:SRH])=0 : Local File SRETURN    [SRH] : Endif 
  If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif 
  If clalev([F:CON])=0 : Local File CONTSERV   [CON] : Endif 
  If clalev([F:SIH])=0 : Local File SERREQUEST [SRE] : Endif 
  If clalev([F:SIH])=0 : Local File SCHGH      [SGH] : Endif 
   
  Case [M]ORITYP(NOL)
    When 2 : Filter [F:SOH] : NOM_OBJET = "SOH"
    When 3 : Filter [F:SDH] : NOM_OBJET = "SDH"
    When 4 : Filter [F:SIH] : NOM_OBJET = "SIH"
    When 5 : Filter [F:SQH] : NOM_OBJET = "SQH"
    When 6 : Filter [F:SRH] : NOM_OBJET = "SRH"
    When 7 : Filter [F:CON] : NOM_OBJET = "CON"
    When 8 : Filter [F:SRE] : NOM_OBJET = "SRE"
    When 9 : Filter [F:SGH] : NOM_OBJET = "SCS"
  Endcase

  Call OBJET(NOM_OBJET,[M]ORINUM(NOL),"") From GOBJET     
  [M]ORINUM(NOL) = SAV_VCRNUM 
  GCONSULT = 0
End


######################################################################################
## Clic droit Pièce sur le retour
######################################################################################
Subprog IB_NBSRH

  GBOUT2 = mess(192,198,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESSRH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBSRH
Local Integer NOL

  Filter [F:SRH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PII2]SRHNUM(NOL) 
  Call OBJET("SRH",[M:PII2]SRHNUM(NOL),"") From GOBJET
  [M:PII2]SRHNUM(NOL) = SAV_VCRNUM 

  GCONSULT = 0
End

