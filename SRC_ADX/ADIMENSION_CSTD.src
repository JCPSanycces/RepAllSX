#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure ADIMENSION
##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINSERT_CONTROL_BEFORE"       : Gosub AINSERT_CONTROL_BEFORE
      When "AUPDATE_CONTROL_BEFORE"       : Gosub AUPDATE_CONTROL_BEFORE
      When "AINSERT_AFTER"                : Gosub AINSERT_AFTER
      When "ADELETE_CONTROL_AFTER"        : Gosub DELETE_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "COD"                          : Gosub COD
  When "RANG"                         : Gosub RANG
  When "ORDRE"                        : Gosub ORDRE
  When "MODULE"                       : Gosub MODULE
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return







##########################################################################################################
$AINSERT_CONTROL_BEFORE
Gosub COD_UNIQUE_CONTROL
Return

##############################################################################################
$AUPDATE_CONTROL_BEFORE
Gosub COMBINE_ORDRE_RANG
Return

##########################################################################################################
$COD
  Case [L]ARULE
    When "COD" : Gosub COD_CONTROL
  Endcase
Return

$COD_CONTROL
this.COD = toupper(this.COD)
Gosub COD_UNIQUE_CONTROL
Return

##########################################################################################################
$MODULE
  Case [L]ARULE
    When "PROPAGATE" : Gosub MODULE_PROPAGATE
  Endcase
Return

$MODULE_PROPAGATE
  Gosub COMBINE_ORDRE_RANG
Return

##########################################################################################################
$RANG
  Case [L]ARULE
    When "PROPAGATE" : Gosub RANG_PROPAGATE
  Endcase
Return

$RANG_PROPAGATE
  Gosub COMBINE_ORDRE_RANG
Return

##############################################################################################
$ORDRE
  Case [L]ARULE
    When "CONTROL" : Gosub ORDRE_CONTROL
  Endcase
Return

$ORDRE_CONTROL
  Gosub COMBINE_ORDRE_RANG
Return

##############################################################################
Return
$AINSERT_AFTER

Return


###############################################################################################
$DELETE_AFTER
Return
##############################################################################################
$COD_UNIQUE_CONTROL
Local Char MESSAGE(250)
[L]ASTATUS = func COD_UNIQUE(this.COD,MESSAGE)
If [L]ASTATUS<>[V]CST_AOK
  [L]ASTATUS = fmet this.ASETERROR("COD",MESSAGE,[L]ASTATUS)
Endif
Return

###############################################################################################
COMBINE_ORDRE_RANG
  Case this.MODULE
   When 1       : this.ORDRE = 0
   When 9       : this.ORDRE = 1000
   When 2       : this.ORDRE = 2000
   When 3       : this.ORDRE = 3000
   When 4       : this.ORDRE = 4000
   When 7       : this.ORDRE = 5000
   When 5       : this.ORDRE = 6000
   When 6       : this.ORDRE = 7000
   When 8       : this.ORDRE = 8000
   When 10      : this.ORDRE = 9000
   When Default : this.ORDRE = 10000
  Endcase

  this.ORDRE += this.RANG
Return

##########################################################################################################
Funprog COD_UNIQUE(CODE,MESSAGE)
Value Char CODE
Variable Char MESSAGE

Local Integer MY_STATUS
Local Instance MY_ADIMENSION Using C_ADIMENSION
MY_ADIMENSION = NewInstance C_ADIMENSION AllocGroup null

[L]MY_STATUS=[V]CST_AOK
If fmet MY_ADIMENSION.AREAD([L]CODE)=[V]CST_AOK
  # Code already exists
  [L]MY_STATUS = [V]CST_AERROR
  [L]MESSAGE = [L]CODE - mess(33,137,1)
Endif
FreeGroup MY_ADIMENSION
End [L]MY_STATUS

