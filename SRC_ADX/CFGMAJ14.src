#<AdxTL>@(#)4.0.0.0 $Revision$
#################################################################################
# CFGMAJ14 : M.a.j à effectuer lors du passage à la V140/V5       Module Stock  #
#                  Sous-module configurateur
# ----------------------------------------------------------------------------- #
# Avant mise à jour                                                             #
#                                                                               #
# ----------------------------------------------------------------------------- #
# Après mise à jour                                                             #
#                                                                               #
#   - Table CFGSCE   Entete scénario                                            #
#           initialisation BLONBR et LINNBR                         FQ 52854    #
#                                                                               #
#################################################################################
# Issue 82300 CQU 8c => 10c mid$(W_VAR,3,8) devient mid$(W_VAR,3,GLONCQU)
#################################################################################

Subprog EXE_CFGMAJ14(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

# FQ 55949 GA 19/06/2009
Local Char WDOSSIER
If clalev ([F:ADS])  WDOSSIER=[F:ADS]DOSSIER  Else  WDOSSIER=nomap  Endif

Local Integer WOUV_TRACE
If GTRACE = ""    # FQ 55848 sauf si trace déjà en cours
   Call OUVRE_TRACE("CFGMAJ14 : Process for configurator"-APPLI) From LECFIC
   WOUV_TRACE=1
Endif

Gosub AV_CSC     # GA 26/02/2009 FQ 52854

If WOUV_TRACE=1     # FQ 55848 sauf si trace déjà en cours
   Call FERME_TRACE From LECFIC
   Raz GTRACE       # pour que le Superviseur n'enleve pas la dernière trace
Endif
End


#################################################################################
# Moulinette : Structure tables sans les nouveaux champs avant appel SUPMAJ14   #
#################################################################################
Subprog SAVCFGMAJ14
Local Char WDOSSIER
If clalev ([F:ADS])  WDOSSIER=[F:ADS]DOSSIER  Else  WDOSSIER=nomap  Endif
# GA 16/03/2008
If dim(S_DOSSIER) < 0   Global Char    S_DOSSIER(10) :  Endif
S_DOSSIER = WDOSSIER

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("SAVCFGMAJ14 : Process for configurator"-S_DOSSIER) From LECFIC
    WOUV_TRACE=1
Endif

Gosub SAV_CSC     # GA 09/03/2009 FQ 52854
Gosub AV_CSC      # GA 23/03/2009 FQ 52854 on essaye de renseigner [F:CSC]BLONBR et [F:CSC]LINNBR

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif
End


#################################################################################
# Moulinette : Structure tables avec anciens et nouveaux champs                 #
#################################################################################
Subprog ACFGMAJ14
End


#################################################################################
# Moulinette : Structure définitive des tables                                  #
#################################################################################
Subprog CFGMAJ14

Local Char WDOSSIER
If clalev ([F:ADS])  WDOSSIER=[F:ADS]DOSSIER  Else  WDOSSIER=nomap  Endif
# GA 16/03/2008
If dim(S_DOSSIER) < 0   Global Char    S_DOSSIER(10) :  Endif
S_DOSSIER = WDOSSIER

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("CFGMAJ14 : Process for configurator"-S_DOSSIER) From LECFIC
    WOUV_TRACE=1
Endif

Gosub RST_CSC    # GA 09/03/2009 FQ 52854
Gosub AV_CSC     # GA 26/02/2009 FQ 52854

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End

#-------------------------------------------------------------------------------#
#    ---> Concerne les scénarios configurateur CFGSCE                           #
#-------------------------------------------------------------------------------#
# Sauvegarde des écrans WUXaaaaa avant leur effacement par le Superviseur       #
#-------------------------------------------------------------------------------#
$SAV_CSC                                               # FQ 52854 GA 09/03/2009 #
If filinfo(filpath("FIL","CFGSCE","fde",WDOSSIER),0) <=0   Return   Endif
Call ECR_TIME("SAVCFGMAJ14 Configurator scripts : Update AMSK") From DOSSUB
Local File =WDOSSIER+".CFGSCE"  [CSC]

Local Char WAMKORG(30),WAMKDES(30),WABRDES(5)
Local Integer WCPT, WOK : WOK=1

Trbegin [CSC]
  # Sauvegarde des écrans WUXaaaaa
  For [F:CSC] Where QSTNUM(0)<>""
   WAMKORG = "WUX"+[F:CSC]SCENUM
   WAMKDES = "ZWUX"+[F:CSC]SCENUM
   Call COP_CFGWIN(WDOSSIER,WDOSSIER,WAMKORG,WAMKDES,WABRDES)
   WCPT+=1
  Next
Commit
If WCPT>0
   Call ECR_TIME("SAVCFGMAJ14 Number of configurator screen saved : CFGSCE"-num$(WCPT)) From DOSSUB
Endif

Close Local File [CSC]
Return

#-------------------------------------------------------------------------------#
#    ---> Concerne les scénarios configurateur CFGSCE                           #
#-------------------------------------------------------------------------------#
# Restauration des écrans WUXaaaaa                                              #
#-------------------------------------------------------------------------------#
$RST_CSC                                               # FQ 52854 GA 09/03/2009 #
If filinfo(filpath("FIL","CFGSCE","fde",WDOSSIER),0) <=0   Return   Endif
Call ECR_TIME("CFGMAJ14 Configurator scripts : Update AMSK") From DOSSUB
Local File =WDOSSIER+".CFGSCE"  [CSC]
Local Char WAMKORG(30),WAMKDES(30),WABRDES(5)
Local Integer WCPT, WOK : WOK=1

GOK=1
Trbegin [CSC]
  # Restauration des écrans WUXaaaaa
  For [F:CSC] Where QSTNUM(0)<>""
   WAMKORG = "ZWUX"+[F:CSC]SCENUM
   WAMKDES = "WUX"+[F:CSC]SCENUM
   Call COP_CFGWIN(WDOSSIER,WDOSSIER,WAMKORG,WAMKDES,WABRDES)
   #If GOK=1 Call DEL_WIN(WDOSSIER,WAMKORG,"","") Endif # conserver le ZWUX*
   WCPT+=1
  Next
Commit
If WCPT>0
   Call ECR_TIME("CFGMAJ14 Number of configurator screen restored : CFGSCE"-num$(WCPT)) From DOSSUB
Endif

Close Local File [CSC]
Return

#-------------------------------------------------------------------------------#
#    ---> Concerne les scénarios configurateur CFGSCE                           #
#-------------------------------------------------------------------------------#
# Stockage de la position des champs BLONBR(I) et LINNBR(I)                     #
#-------------------------------------------------------------------------------#
$AV_CSC                                                # FQ 52854 GA 26/02/2009 #
If filinfo(filpath("FIL","CFGSCE","fde",WDOSSIER),0) <=0   Return   Endif
Call ECR_TIME("CFGMAJ14 Configurator scripts : Update CFGSCE") From DOSSUB
#-----
Local File =WDOSSIER+".CFGSCE"  [CSC]
Local File =WDOSSIER+".AMSK"    [AMK2]
Local File =WDOSSIER+".AMSKZON" [AMZ2]

Trbegin [CSC]
  If dim([F:CSC]BLONBR)>0 & dim([F:CSC]LINNBR)>0
   For [F:CSC] Where QSTNUM(0)<>"" With Lock
      # M:modif, WUX:prefixe ecran, positions des blocs 1,2,3
      Call UPDATE_CSC_FROM_AMZ("MWUX234") From CFGLIBE
      Rewrite [F:CSC]
   Next
   Call ECR_TIME("CFGMAJ14 Configurator scripts : updated"-[F:CSC]SCENUM) From DOSSUB
  Else
   Call ECR_TIME("CFGMAJ14 Configurator scripts : not updated") From DOSSUB
  Endif
Commit
Close Local File [CSC]
Close Local File [AMK2]
Close Local File [AMZ2]
Return



############################################################
# Effacement fenetre generee
# LAPP = Dossier
# LMSK = Nom ecran
# LSTO = Classe pour stockage ancien numeros de ligne ou rien
# LBLO = Numero des blocs "1" et "2" de saisie (Si LSTO<>"")
############################################################
Subprog DEL_WIN(LAPP,LMSK,LSTO,LBLO)
Value    Char    LAPP
Value    Char    LMSK
Value    Char    LSTO
Value    Char    LBLO
#
Local    Integer W_STAT
Local    Char    W_SUF(4)
Local    Integer W_LAN
Local    Char    W_GLANGUE(3)
Local    Char    W_FICANU(GDIMFIC)
Local    Char    W_TRTANU(GDIMFIC)
Local    Char    W_INT(20)
Local    Integer W_I
Local    Integer WADS1 : WADS1=0
#
# FQ 53854 GA 17/03/2009 pour ne pas ouvrir les tables
#Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_PREFIXES From CFGLIB
#
If clalev([F:AMK2])= 0 :  Local File =LAPP+".AMSK"      [AMK2]  : Endif
If clalev([F:AMZ2])= 0 :  Local File =LAPP+".AMSKZON"   [AMZ2]  : Endif
If clalev([F:AMA2])= 0 :  Local File =LAPP+".AMSKACT"   [AMA2]  : Endif
If clalev([F:AMP2])= 0 :  Local File =LAPP+".AMSKPAR"   [AMP2]  : Endif
If clalev([F:ADS1])= 0 :  Local File ADOSSIER           [ADS1]  : Endif
############################################################
# Lecture parametres dossier
Read [ADS1]DOSSIER=LAPP
If fstat
  Call FSTA("ADS1") From GLOCK
  GOK = 0
  Goto DEL_WIN_FIN
Endif
# memorisation des anciens numéros de bloc et ligne
If LSTO <> ""
  If dim([F:AMK2]INTBLOC) > 0
    Read [AMK2]CODMSK=LMSK
    If fstat = 0
      For W_I = 0 To dim([F:AMK2]INTBLOC)-1
        If [F:AMK2]INTBLOC(W_I) <> ""
          W_INT = evalue([F:AMK2]INTBLOC(W_I))
          Assign LSTO+"INTBLOC(W_I)" With W_INT
        Endif
      Next W_I
    Endif
  Endif
  W_I = 0
  Filter [AMZ2] Where CODMSK = LMSK  &
&                     left$([F:AMZ2]CODZON,2) = W_PRQ
&               Order By Key CODZON
  For [AMZ2]
    Assign LSTO+"QSTNUM(W_I)" With mid$([F:AMZ2]CODZON,3,GLONCQU)
    Case [F:AMZ2]NUMBLOC
      When val(mid$(LBLO,1,1)) :
        Assign LSTO+"BLONBR(W_I)" With 1
      When val(mid$(LBLO,2,1)) :
        Assign LSTO+"BLONBR(W_I)" With 2
      When val(mid$(LBLO,3,1)) :
        Assign LSTO+"BLONBR(W_I)" With 3
    Endcase
    Assign LSTO+"LINNBR(W_I)" With [F:AMZ2]NOZONE
    W_I += 1
    Assign LSTO+"NBLIG"       With W_I
  Next
  Filter [AMZ2]
Endif
Call DEL_FEN(LAPP,LMSK)
###########################################################
# Effacement AMSK
Delete [AMK2] Where CODMSK=LMSK
fstat = 0
# Effacement AMSKZON
Delete [AMZ2] Where CODMSK=LMSK
fstat = 0
# Effacement AMSKACT
Delete [AMA2] Where CODAFF=LMSK
fstat = 0
#Effacement AMSKPAR
Delete [AMP2] Where CODAFF=LMSK
fstat = 0
#
$DEL_WIN_FIN
End
############################################################
# Effacement Fenetre
Subprog DEL_FEN(LAPP,LMSK)
Variable Char    LAPP
Value    Char    LMSK
#
If clalev([F:AWI2])= 0 :  Local File =LAPP+".AWINDOW"   [AWI2]  : Endif
If clalev([F:AWP2])= 0 :  Local File =LAPP+".AWINPAR"   [AWP2]  : Endif
# FQ 52854 GA 18/03/2009 tables inexistantes en v130
If  filinfo(filpath("FIL","AWINBOUT","fde",LAPP),0)>0
& & filinfo(filpath("FIL","AWINBRO","fde",LAPP),0)>0
  If clalev([F:AWT2])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT2]  : Endif
  If clalev([F:AWB2])= 0 :  Local File =LAPP+".AWINBRO"   [AWB2]  : Endif
Endif
#
#Effacement AWINDOW
Delete [AWI2] Where WIN = LMSK
fstat = 0
#Effacement AWINPAR
Delete [AWP2] Where WIN = LMSK
fstat = 0
#
If clalev([F:AWT2])>0
  #Effacement AWINBOUT
  Delete [AWT2] Where WIN = LMSK
  fstat = 0
Endif
If clalev([F:AWB2])>0
  #Effacement AWINBRO
  Delete [AWB2] Where WIN = LMSK
  fstat = 0
Endif
End

############################################################
# Creation ecran et fenetre sous scenarios par copie
############################################################
Subprog COP_WIN(LAPP,LREF,LMSK,LABR,LWEB)
Value    Char    LAPP
Value    Char    LREF
Value    Char    LMSK
Value    Char    LABR
Value    Char    LWEB
#
# Effacement ancien masque
Call DEL_WIN(LAPP,LMSK,"","")
If GOK <> 1
  Goto COP_WIN_FIN
Endif
Local    Integer W_I, W_J, W_K, W_L, W_M, W_N, W_O
#
If clalev([F:AMK1])= 0 :  Local File =LAPP+".AMSK"      [AMK1]  : Endif
If clalev([F:AMK2])= 0 :  Local File =LAPP+".AMSK"      [AMK2]  : Endif
If clalev([F:AMZ1])= 0 :  Local File =LAPP+".AMSKZON"   [AMZ1]  : Endif
If clalev([F:AMZ2])= 0 :  Local File =LAPP+".AMSKZON"   [AMZ2]  : Endif
If clalev([F:AMA1])= 0 :  Local File =LAPP+".AMSKACT"   [AMA1]  : Endif
If clalev([F:AMA2])= 0 :  Local File =LAPP+".AMSKACT"   [AMA2]  : Endif
If clalev([F:AMP1])= 0 :  Local File =LAPP+".AMSKPAR"   [AMP1]  : Endif
If clalev([F:AMP2])= 0 :  Local File =LAPP+".AMSKPAR"   [AMP2]  : Endif
If clalev([F:AWI1])= 0 :  Local File =LAPP+".AWINDOW"   [AWI1]  : Endif
If clalev([F:AWI2])= 0 :  Local File =LAPP+".AWINDOW"   [AWI2]  : Endif
If clalev([F:AWP1])= 0 :  Local File =LAPP+".AWINPAR"   [AWP1]  : Endif
If clalev([F:AWP2])= 0 :  Local File =LAPP+".AWINPAR"   [AWP2]  : Endif
# FQ 52854 GA 18/03/2009 tables inexistantes en v130
If  filinfo(filpath("FIL","AWINBOUT","fde",LAPP),0)>0
& & filinfo(filpath("FIL","AWINBRO","fde",LAPP),0)>0
  If clalev([F:AWT1])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT1]  : Endif
  If clalev([F:AWT2])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT2]  : Endif
  If clalev([F:AWB1])= 0 :  Local File =LAPP+".AWINBRO"   [AWB1]  : Endif
  If clalev([F:AWB2])= 0 :  Local File =LAPP+".AWINBRO"   [AWB2]  : Endif
Endif
If clalev([F:ADS1])= 0 :  Local File ADOSSIER           [ADS1]  : Endif
############################################################
# Lecture parametres dossier
Read [ADS1]DOSSIER=LAPP
If fstat
  Call FSTA("ADS1") From GLOCK
  GOK = 0
  Goto COP_WIN_FIN
Endif
# Duplication entete ecran
Read [AMK1]CODMSK=LREF
If fstat
  GOK = 0
  Call FSTA("AMK1") From GLOCK
  Goto COP_WIN_FIN
Else
  [F:AMK2]        = [F:AMK1]
  [F:AMK2]CODMSK  = LMSK
  [F:AMK2]ABRMSK  = LABR
  # [F:AMK2]ABRWEB  = LWEB        JPJ 12/09/03
  [F:AMK2]MDL     = 1
  Write [AMK2]
  If fstat
    GOK = 0
    Call FSTA("AMK2") From GLOCK
    Goto COP_WIN_FIN
  Endif
Endif
# Duplication des champs
Filter [AMZ1] Where CODMSK = LREF
&             Order By Key CODE
For [AMZ1]
  [F:AMZ2]       = [F:AMZ1]
  [F:AMZ2]CODMSK = LMSK
  Write [AMZ2]
  If fstat
    GOK = 0
    Call FSTA("AMZ2") From GLOCK
    Goto COP_WIN_FIN
  Endif
Next
Filter [AMZ1]
# Duplication actions ecran
Filter [AMA1] Where TYPAFF = 1    &
&                   CODAFF = LREF
&             Order By Key TYPAFF
For [AMA1]
  [F:AMA2]       = [F:AMA1]
  [F:AMA2]CODAFF = LMSK
  Write [AMA2]
  If fstat
    GOK = 0
    Call FSTA("AMA2") From GLOCK
    Goto COP_WIN_FIN
  Endif
Next
Filter [AMA1]
# Duplication parametres action

Filter [AMP1] Where TYPAFF = 1    &
&                   CODAFF = LREF
&             Order By Key CODPAR
For [AMP1]
  [F:AMP2]       = [F:AMP1]
  [F:AMP2]CODAFF = LMSK
  Write [AMP2]
  If fstat
    GOK = 0
    Call FSTA("AMP2") From GLOCK
    Goto COP_WIN_FIN
  Endif
Next
Filter [AMP1]
# Duplication fenetre
Read [AWI1]AWI0=LREF
If fstat
  GOK = 0
  Call FSTA("AWI1") From GLOCK
  Goto COP_WIN_FIN
Else
  [F:AWI2]          = [F:AWI1]
  [F:AWI2]WIN       = LMSK
  [F:AWI2]NOMMSK(0) = LMSK
  Write [AWI2]
  If fstat
    GOK = 0
    Call FSTA("AWI2") From GLOCK
    Goto COP_WIN_FIN
  Endif
Endif
# Duplication parametres fenetre
Filter [AWP1] Where WIN    = LREF
&             Order By Key AWP0
For [AWP1]
  [F:AWP2]       = [F:AWP1]
  [F:AWP2]WIN    = LMSK
  Write [AWP2]
  If fstat
    GOK = 0
    Call FSTA("AWP2") From GLOCK
    Goto COP_WIN_FIN
  Endif
Next
Filter [AWP1]

# FQ 52854 GA 18/03/2009 tables inexistantes en v130
If clalev([F:AWT1])>0 & clalev([F:AWB1])>0
    Filter [AWT1] Where WIN = LREF
    For [AWT1]
      [F:AWT2]    = [F:AWT1]
      [F:AWT2]WIN = LMSK
      Write [AWT2]
      If fstat
        Call FSTA("AWT2") From GLOCK
        Break
      Endif
    Next
    Filter [AWT1]
    Filter [AWB1] Where WIN = LREF
    For [AWB1]
      [F:AWB2]    = [F:AWB1]
      [F:AWB2]WIN = LMSK
      Write [AWB2]
      If fstat
        Call FSTA("AWB2") From GLOCK
        Break
      Endif
    Next
    Filter [AWB1]
#
Endif
adxmbm      = adxmbm
$COP_WIN_FIN
Close Local File [ADS1]
Close Local File [AMK1],[AMZ1], [AMA1] , [AMP1]
Close Local File [AWI1],[AWP1]
Close Local File [AMK2],[AMZ2], [AMA2] , [AMP2]
Close Local File [AWI2],[AWP2]
# FQ 52854 GA 18/03/2009 tables inexistantes en v130
If clalev([F:AWT1])>0 Close Local File [AWT1] Endif
If clalev([F:AWT2])>0 Close Local File [AWT2] Endif
If clalev([F:AWB1])>0 Close Local File [AWB1] Endif
If clalev([F:AWB2])>0 Close Local File [AWB2] Endif
End

############################################################
Subprog GEN_FEN(LAPP,LREF,LMSK)
Value    Char    LAPP
Value    Char    LREF
Value    Char    LMSK
#
Local    Integer W_I
#
If clalev([F:AWI1])= 0 :  Local File =LAPP+".AWINDOW"   [AWI1]  : Endif
If clalev([F:AWI2])= 0 :  Local File =LAPP+".AWINDOW"   [AWI2]  : Endif
If clalev([F:AWP1])= 0 :  Local File =LAPP+".AWINPAR"   [AWP1]  : Endif
If clalev([F:AWP2])= 0 :  Local File =LAPP+".AWINPAR"   [AWP2]  : Endif
# FQ 52854 GA 18/03/2009 tables inexistantes en v130
If  filinfo(filpath("FIL","AWINBOUT","fde",LAPP),0)>0
& & filinfo(filpath("FIL","AWINBRO" ,"fde",LAPP),0)>0
  If clalev([F:AWT1])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT1]  : Endif
  If clalev([F:AWT2])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT2]  : Endif
  If clalev([F:AWB1])= 0 :  Local File =LAPP+".AWINBRO"   [AWB1]  : Endif
  If clalev([F:AWB2])= 0 :  Local File =LAPP+".AWINBRO"   [AWB2]  : Endif
Endif
#
Read [AWI1]AWI0=LREF
If fstat = 0
  [F:AWI2]          = [F:AWI1]
  [F:AWI2]WIN       = LMSK
  [F:AWI2]NOMMSK(0) = LMSK
  [F:AWI2]MDL       = 1        # ecran normal
  Write [AWI2]
  Filter [AWP1] Where WIN = LREF
  For [AWP1]
    [F:AWP2]    = [F:AWP1]
    [F:AWP2]WIN = LMSK
    Write [AWP2]
    If fstat
      Call FSTA("AWP2") From GLOCK
      Break
    Endif
  Next
  Filter [AWP1]

  # FQ 52854 GA 18/03/2009 tables inexistantes en v130
  If clalev([F:AWT1])>0 & clalev([F:AWB1])>0
      Filter [AWT1] Where WIN = LREF
      For [AWT1]
        [F:AWT2]    = [F:AWT1]
        [F:AWT2]WIN = LMSK
        Write [AWT2]
        If fstat
          Call FSTA("AWT2") From GLOCK
          Break
        Endif
      Next
      Filter [AWT1]
      Filter [AWB1] Where WIN = LREF
      For [AWB1]
        [F:AWB2]    = [F:AWB1]
        [F:AWB2]WIN = LMSK
        Write [AWB2]
        If fstat
          Call FSTA("AWB2") From GLOCK
          Break
        Endif
      Next
      Filter [AWB1]

  Endif
Endif
End
############################################################
# Creation ecran et fenetre sous scenarios par copie
############################################################
Subprog COP_CFGWIN(LDOSORG,LDOSDES,LNOMORG,LNOMDES,LABRDES)
Value    Char    LDOSORG
Value    Char    LDOSDES # FQ 49403 pour copier d'un dossier à un autre
Value    Char    LNOMORG
Value    Char    LNOMDES
Value    Char    LABRDES
# Value    Char    LWEB # FQ 49403 non utilisé

Local    Integer W_O, WADS1 : WADS1=0
#
If clalev([F:ADS1])= 0 :  Local File ADOSSIER [ADS1] : WADS1=1  : Endif

# Effacement écran et fenêtre à regénérer
Call DEL_WIN(LDOSDES,LNOMDES,"","")
If GOK <> 1
  Goto COP_CFGWIN_FIN
Endif

############################################################
Local Char WDOSSIER
Local Integer WPOS : WPOS=instr(1,LDOSDES,"@")
If WPOS
 # si dossier distant, on n'a pas la ligne dans [ADS1]
   WDOSSIER=right$(LDOSDES,WPOS+1)
Else
   WDOSSIER=LDOSDES
   # Lecture parametres dossier
   Read [ADS1]DOSSIER=WDOSSIER
   If fstat
     Call FSTA("ADS1") From GLOCK
     GOK = 0
     Goto COP_CFGWIN_FIN
   Endif
Endif

# ----------------------------
# Copie et Validation ecran
# ----------------------------
Call COPY_AMK(LDOSORG,LDOSDES,LNOMORG,LNOMDES,LABRDES,W_O)
If W_O<>1 | GOK<>1 : GOK = 0 : Goto COP_CFGWIN_FIN : Endif

# ----------------------------
# Copie et Validation fenetre
# ----------------------------
Call COPY_AWI(LDOSORG,LDOSDES,LNOMORG,LNOMDES,W_O)
If W_O<>1 | GOK<>1 : GOK = 0 : Goto COP_CFGWIN_FIN : Endif
adxmbm      = adxmbm
$COP_CFGWIN_FIN
If WADS1=1 Close Local File [ADS1] Endif
End

######################################################
# Subprog COPY_AMK           (selon TRTCOP de SUBAMK)
# copie d'un masque écran dans les cas suivants:
# - pour duplication / renommé
# - d'un dossier à un autre
# Paramètres:
# - LDOSORG Dossier origine
# - LDOSDES Dossier destination
# - LAMKORG Ecran   origine
# - LAMKDES Ecran   destination
# - LABRDES Abréviation écran   destination
# - LOK     Code retour 1=Ok
# Cas d'utilisation:
# - copie des paramétrages CFG d'un dossier à un autre
######################################################
Subprog COPY_AMK(LDOSORG,LDOSDES,LAMKORG,LAMKDES,LABRDES,LOK)
Value    Char    LDOSORG
Value    Char    LDOSDES
Value    Char    LAMKORG
Value    Char    LAMKDES
Value    Char    LABRDES
Variable Integer LOK

Local Integer W_AMK_OK : W_AMK_OK = 0

LOK=1
If LDOSORG=nomap | LDOSORG=""
 Local File AMSK    [AMK1]
 Local File AMSKZON [AMZ1]
 Local File AMSKACT [AMA1]
 Local File AMSKPAR [AMP1]
 Local File ATEXTE  [ATX1]
Else
 Local File =LDOSORG+".AMSK"    [AMK1]
 Local File =LDOSORG+".AMSKZON" [AMZ1]
 Local File =LDOSORG+".AMSKACT" [AMA1]
 Local File =LDOSORG+".AMSKPAR" [AMP1]
 Local File =LDOSORG+".ATEXTE"  [ATX1]
Endif
If LDOSDES=nomap  | LDOSDES=""
 Local File AMSK    [AMK2]
 Local File AMSKZON [AMZ2]
 Local File AMSKACT [AMA2]
 Local File AMSKPAR [AMP2]
 Local File ATEXTE  [ATX2]
Else
 Local File =LDOSDES+".AMSK"    [AMK2]
 Local File =LDOSDES+".AMSKZON" [AMZ2]
 Local File =LDOSDES+".AMSKACT" [AMA2]
 Local File =LDOSDES+".AMSKPAR" [AMP2]
 Local File =LDOSDES+".ATEXTE"  [ATX2]
Endif
OK = 1
If GTRACE=""
 Read [AMK2]CODMSK = LAMKDES
 If !fstat
  OK=1 : Call AVERTIR(LDOSDES-LAMKDES-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP_AMK
Endif
Close Local File [AMK1], [AMZ1], [AMA1], [AMP1], [ATX1]
&              , [AMK2], [AMZ2], [AMA2], [AMP2], [ATX2]
End

$TR_COP_AMK
GOK = 1

Local Integer WUPDTRBEGIN : Raz WUPDTRBEGIN

# Si pas de transaction en cours
 If adxlog<>1
   GOK=1
   Trbegin [AMK2] , [AMZ2] , [AMA2] , [AMP2] , [ATX2]
   WUPDTRBEGIN=1
 Endif

 Delete [AMK2] Where CODMSK=LAMKDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AMSK" : Goto ROLL_TR_COP_AMK
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMK2","") From GLOCK : Goto AB_TR_COP_AMK
 Endif
 If dim(WNBZ)>0
  WNBZ = 0
  For [AMZ2] Where CODMSK=LAMKDES
   WNBZ += 1
   WZON(WNBZ) = [F:AMZ2]CODZON
   WMOT(WNBZ) = [F:AMZ2]MOTCLE
  Next AMZ2
 Endif
 Delete [AMZ2] Where CODMSK=LAMKDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AMSKZON" : Goto ROLL_TR_COP_AMK
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMZ2","") From GLOCK : Goto AB_TR_COP_AMK
 Endif
 Delete [AMA2] Where TYPAFF=1 & CODAFF=LAMKDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AMSKACT" : Goto ROLL_TR_COP_AMK
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMA2","") From GLOCK : Goto AB_TR_COP_AMK
 Endif
 Delete [AMP2] Where TYPAFF=1 & CODAFF=LAMKDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AMSKPAR" : Goto ROLL_TR_COP_AMK
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMP2","") From GLOCK : Goto AB_TR_COP_AMK
 Endif
 For [AMK1]CODMSK Where CODMSK=LAMKORG
  W_AMK_OK = 1
  [F:AMK2] = [F:AMK1]
  If LAMKORG<>LAMKDES & LAMKDES<>""
     [F:AMK2]CODMSK = LAMKDES
  Endif
  If [F:AMK1]ABRMSK<>LABRDES & LABRDES<>""
     [F:AMK2]ABRMSK = LABRDES
  Endif
  Call COPTEXTE([F:AMK1]INTMSK,[F:AMK2]INTMSK) From OBJDIV
  If GOK<1 : Break : Endif
  For I=0 To [F:AMK1]NBBLOC-1
   Call COPTEXTE([F:AMK1]TITBLOC(I),[F:AMK2]TITBLOC(I)) From OBJDIV
   If GOK<1 : Break 2 : Endif
  Next I
  If dim([F:AMK2]UPDUSR)>0 : [F:AMK2]UPDUSR = GUSER : Endif
  If dim([F:AMK2]UPDDAT)>0 : [F:AMK2]UPDDAT = date$ : Endif
  If dim([F:AMK2]UPDTIM)>0 : [F:AMK2]UPDTIM = time  : Endif
  Write [AMK2]
  If fstat
   GOK=0 : Call FSTA("AMK2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP_AMK
 Elsif !GOK : Goto AB_TR_COP_AMK
 Endif
 For [AMZ1]CODE Where CODMSK=LAMKORG
  [F:AMZ2] = [F:AMZ1]
  If LAMKORG<>LAMKDES [F:AMZ2]CODMSK=LAMKDES Endif
  Call COPTEXTE([F:AMZ1]INTIT,[F:AMZ2]INTIT) From OBJDIV
  If dim([F:AMZ1]INFBUL)>0 & dim([F:AMZ2]INFBUL)>0
   Call COPTEXTE([F:AMZ1]INFBUL,[F:AMZ2]INFBUL) From OBJDIV
   If GOK<1 : Break : Endif
  Endif
  If dim(WNBZ)>0
   I = find([F:AMZ1]CODZON,WZON(1..WNBZ))
   If I
    [F:AMZ2]MOTCLE = WMOT(I)
   Endif
  Endif
  Write [AMZ2]
  If fstat
   GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP_AMK
 Elsif !GOK : Goto AB_TR_COP_AMK
 Endif
 For [AMA1]TYPAFF Where TYPAFF=1 & CODAFF=LAMKORG
  [F:AMA2] = [F:AMA1]
  If LAMKORG<>LAMKDES [F:AMA2]CODAFF=LAMKDES Endif
  If dim([F:AMA2]INTITACT)>0
   Call COPTEXTE([F:AMA1]INTITACT,[F:AMA2]INTITACT) From OBJDIV
  Endif
  Write [AMA2]
  If fstat
   GOK=0 : Call FSTA("AMA2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR_COP_AMK : Endif
 For [AMP1]CODPAR Where TYPAFF=1 & CODAFF=LAMKORG
  [F:AMP2] = [F:AMP1]
  If LAMKORG<>LAMKDES [F:AMP2]CODAFF=LAMKDES Endif
  Write [AMP2]
  If fstat
   GOK=0 : Call FSTA("AMP2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR_COP_AMK : Endif
 # un petit message de trace
 Local Char W_MSG (250)
 If W_AMK_OK = 1
   W_MSG = mess(129,123,1)-LAMKORG
 Else
   # Erreur
   W_MSG = mess(7,21,1)-mess(129,123,1)-LAMKORG
 Endif
 Call ECR_TRACE(W_MSG,0) From GESECRAN

# Si on a ouvert une transaction
 If WUPDTRBEGIN=1
   Commit
   Raz WUPDTRBEGIN
 Endif
Return

$AB_TR_COP_AMK
# Si on a ouvert une transaction
If WUPDTRBEGIN=1
   Rollback
   Raz WUPDTRBEGIN
Endif
Return

$ROLL_TR_COP_AMK
# Si on a ouvert une transaction
If WUPDTRBEGIN=1
   Rollback
   Raz WUPDTRBEGIN
Endif
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP_AMK : Endif
Return

######################################################
# Subprog COPY_AWI           (selon TRTCOP de SUBAWI)
# copie d'une fenêtre dans les cas suivants:
# - pour duplication / renommé
# - d'un dossier à un autre
# Paramètres:
# - LDOSORG Dossier origine
# - LDOSDES Dossier destination
# - LWINORG Ecran   origine
# - LWINDES Ecran   destination
# - LOK     Code retour 1=Ok
# Cas d'utilisation:
# - copie des paramétrages CFG d'un dossier à un autre
######################################################
Subprog COPY_AWI(LDOSORG,LDOSDES,LWINORG,LWINDES,LOK)
Value    Char    LDOSORG
Value    Char    LDOSDES
Value    Char    LWINORG
Value    Char    LWINDES
Variable Integer LOK

Local Integer W_AWI_OK : W_AWI_OK = 0

LOK=1
If LDOSORG=nomap | LDOSORG=""
 Local File AWINDOW  [AWI1]
 Local File AWINPAR  [AWP1]
 # FQ 52854 GA 18/03/2009 tables inexistantes en v130
 If  filinfo(filpath("FIL","AWINBOUT","fde",LDOSORG),0)>0
&  & filinfo(filpath("FIL","AWINBRO" ,"fde",LDOSORG),0)>0
   Local File AWINBRO  [AWB1]
   Local File AWINBOUT [AWT1]
 Endif
 Local File ATEXTE   [ATX1]
Else
 Local File =LDOSORG+".AWINDOW"  [AWI1]
 Local File =LDOSORG+".AWINPAR"  [AWP1]
 # FQ 52854 GA 18/03/2009 tables inexistantes en v130
 If  filinfo(filpath("FIL","AWINBOUT","fde",LDOSORG),0)>0
&  & filinfo(filpath("FIL","AWINBRO" ,"fde",LDOSORG),0)>0
   Local File =LDOSORG+".AWINBRO"  [AWB1]
   Local File =LDOSORG+".AWINBOUT" [AWT1]
 Endif
 Local File =LDOSORG+".ATEXTE"   [ATX1]
Endif
If LDOSDES=nomap | LDOSDES=""
 Local File AWINDOW  [AWI2]
 Local File AWINPAR  [AWP2]
 # FQ 52854 GA 18/03/2009 tables inexistantes en v130
 If  filinfo(filpath("FIL","AWINBOUT","fde",LDOSDES),0)>0
&  & filinfo(filpath("FIL","AWINBRO" ,"fde",LDOSDES),0)>0
   Local File AWINBRO  [AWB2]
   Local File AWINBOUT [AWT2]
 Endif
 Local File ATEXTE   [ATX2]
Else
 Local File =LDOSDES+".AWINDOW"  [AWI2]
 Local File =LDOSDES+".AWINPAR"  [AWP2]
 # FQ 52854 GA 18/03/2009 tables inexistantes en v130
 If  filinfo(filpath("FIL","AWINBOUT","fde",LDOSDES),0)>0
&  & filinfo(filpath("FIL","AWINBRO" ,"fde",LDOSDES),0)>0
   Local File =LDOSDES+".AWINBRO"  [AWB2]
   Local File =LDOSDES+".AWINBOUT" [AWT2]
 Endif
 Local File =LDOSDES+".ATEXTE"   [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP_AWI
Close Local File [AWI1], [AWP1], [ATX1]
&              , [AWI2], [AWP2], [ATX2]
End

$TR_COP_AWI
GOK = 1
Local Integer WUPDTRBEGIN : Raz WUPDTRBEGIN

# Si pas de transaction en cours
 If adxlog<>1
   GOK=1
   # FQ 52854 GA 18/03/2009 tables inexistantes en v130
   If clalev([F:AWT2])>0 & clalev([F:AWB2])>0
      Trbegin [AWI2] , [AWP2] , [AWB2] , [AWT2] , [ATX2]
   Else
      Trbegin [AWI2] , [AWP2] , [ATX2]
   Endif
   WUPDTRBEGIN=1
 Endif

 Delete [AWI2] Where WIN=LWINDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AWINDOW" : Goto ROLL_TR_COP_AWI
 Endif
 Delete [AWP2] Where WIN=LWINDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AWINPAR" : Goto ROLL_TR_COP_AWI
 Endif
#
 # FQ 52854 GA 18/03/2009 tables inexistantes en v130
 If clalev([F:AWT2])>0 & clalev([F:AWB2])>0
     Delete [AWB2] Where WIN=LWINDES
     If fstat=1
      GOK=-1 : GLOCK = "$"+LDOSDES+".AWINBRO" : Goto ROLL_TR_COP_AWI
     Endif
     Delete [AWT2] Where WIN=LWINDES
     If fstat=1
      GOK=-1 : GLOCK = "$"+LDOSDES+".AWINBOUT" : Goto ROLL_TR_COP_AWI
     Endif
 Endif
#
 For [AWI1]AWI0 Where WIN=LWINORG
  W_AWI_OK = 1
  [F:AWI2] = [F:AWI1]
  If LWINORG<>LWINDES [F:AWI2]WIN=LWINDES Endif
  # configurateur : le nom de fenêtre est aussi le nom du masque
  If [F:AWI1]NOMMSK(0) = LWINORG [F:AWI2]NOMMSK(0) = LWINDES Endif
  Call COPTEXTE([F:AWI1]DES,[F:AWI2]DES) From OBJDIV
  If GOK<1 : Break : Endif
  For I=0 To [F:AWI1]NBMSK-1
   Call COPTEXTE([F:AWI1]INTMSK(I),[F:AWI2]INTMSK(I)) From OBJDIV
   If GOK<1 : Break 2 : Endif
  Next I
  If dim([F:AWI2]UPDUSR)>0 : [F:AWI2]UPDUSR = GUSER : Endif
  If dim([F:AWI2]UPDDAT)>0 : [F:AWI2]UPDDAT = date$ : Endif
  If dim([F:AWI2]UPDTIM)>0 : [F:AWI2]UPDTIM = time  : Endif
  Write [AWI2]
  If fstat
   GOK=0 : Call FSTA("AWI2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP_AWI
 Elsif !GOK : Goto AB_TR_COP_AWI
 Endif
 For [AWP1]AWP0 Where WIN=LWINORG
  [F:AWP2] = [F:AWP1]
  If LWINORG<>LWINDES [F:AWP2]WIN=LWINDES Endif
  Write [AWP2]
  If fstat
   GOK = 0 : Call FSTA("AWP2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP_AWI
 Elsif !GOK : Goto AB_TR_COP_AWI
 Endif
 # FQ 52854 GA 18/03/2009 tables inexistantes en v130
 If clalev([F:AWT1])>0 & clalev([F:AWB1])>0
     Read [AWB1]AWB0 = LWINORG
     If !fstat
      [F:AWB2] = [F:AWB1]
      If LWINORG<>LWINDES [F:AWB2]WIN=LWINDES Endif
      For I=0 To [F:AWB1]NBLIS-1
       Call COPTEXTE([F:AWB1]INTLIS(I),[F:AWB2]INTLIS(I)) From OBJDIV
       If GOK<1 : Break : Endif
      Next I
      Write [AWB2]
      If fstat
       GOK = 0 : Call FSTA("AWB2") From GLOCK
      Endif
     Endif
     For [AWT1]AWT0 Where WIN=LWINORG
      [F:AWT2] = [F:AWT1]
      If LWINORG<>LWINDES [F:AWT2]WIN=LWINDES Endif
      Call COPTEXTE([F:AWT1]TXTBOUT,[F:AWT2]TXTBOUT) From OBJDIV
      If GOK<1 : Break : Endif
      Write [AWT2]
      If fstat
       GOK = 0 : Call FSTA("AWT2") From GLOCK : Break
      Endif
     Next
     If   GOK<0 : Goto ROLL_TR_COP_AWI
     Elsif !GOK : Goto AB_TR_COP_AWI
     Endif
 Endif
 # un petit message de trace
 Local Char W_MSG (250)
 If W_AWI_OK = 1
   W_MSG = mess(91,123,1)-mess(14,126,1)-LWINORG
 Else
   # Erreur
   W_MSG = mess(7,21,1)-mess(91,123,1)-mess(14,126,1)-LWINORG
 Endif
 Call ECR_TRACE(W_MSG,0) From GESECRAN
# Si on a ouvert une transaction
 If WUPDTRBEGIN=1
   Commit
   Raz WUPDTRBEGIN
 Endif
Return

$AB_TR_COP_AWI
# Si on a ouvert une transaction
If WUPDTRBEGIN=1
   Rollback
   Raz WUPDTRBEGIN
Endif
Return

$ROLL_TR_COP_AWI
# Si on a ouvert une transaction
If WUPDTRBEGIN=1
   Rollback
   Raz WUPDTRBEGIN
Endif
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP_AWI : Endif
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call EXE_CFGMAJ14(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
Call EXE_CFGMAJ14(APPLI)
End
