#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Check for Payment processing hold
# Called from TRTVENCDT
# Syrapedia compatible in treatment SEPPCDT_SYRA : FGR 19/06/2013
####################################################################################
$CDTSTA

# Don't override 'prepayment not deposited'
If CDTSTA=4 : Return : Endif

# Skip if payment terms don't relate to Sage Exchange
Local Char PTE
If dim([F:SOH]PTE)>0 & [F:SOH]PTE<>""
  [L]PTE = [F:SOH]PTE
Else
  [L]PTE = [F:BPC]PTE
Endif
If !func SEPPLIB.SEPP_DOC([L]PTE) : Return : Endif

# Customer hold --> prepayment
If CDTSTA=2 & NUMPIE<>""
  Call CALACO(NUMPIE, date$, MONT) From TRTVENCDT
  If GLOKORD=2 & MONT<>0
    CDTSTA = 4 : Return
  Endif
Endif

CUR = ""
OSTAUZ = 9999999999.99
CDTSTA = 1
If NUMPIE<>"" & !func SEPP_OK(2,NUMPIE,1) & [F:SOH]ORDSTA<>2
  CDTSTA = 5
  Return
Endif
# If Sage Exchange document is in the process of being created, put on SE hold
If NUMPIE="" & find(GREP,"C","D") & GFONCTION="GESSOH"
  CDTSTA = 5
  Return
Endif
Return

####################################################################################
Funprog SEPP_OK(VCRTYP,VCRNUM,CDTCHK)
Value Integer VCRTYP
Value Char    VCRNUM
Value Integer CDTCHK  # 1 = Credit check/pop, 0 = Re-auth

If !clalev([F:SEU])  : Local File SEAUTH     [SEU]  : Endif
If !clalev([F:SER])  : Local File SEPRC      [SER]  : Endif

# Check for last card being rejected
# For reauth, return true so that auto-pop occurs
Filter [SEU] Where VCRTYP=[L]VCRTYP & VCRNUM=[L]VCRNUM
Read [SEU] Last
Filter [SEU]
If fstat               # No card
  Raz [F:SEU]
  End !CDTCHK | func SEPPLIB.GET_REMAIN_AMT_NMU([L]VCRTYP)=0
Elsif [F:SEU]STAFLG=4  # Last auth Rejected
  End !CDTCHK
Endif

Call GET_SER([F:SEU]PRCCOD) From SEPPLIB
If fstat : End 0 : Endif

# For Credits/Payments, a selected card is all that is needed
If find([L]VCRTYP,18,41,51) & [F:SEU]STAFLG=1 : End 1 : Endif

# Post order auth
# If verification flag set, card must be verified
If ([F:SEU]POSTAUT=2 & [F:SEU]STAFLG<3) | ([F:SER]VERIF=2 & [F:SEU]STAFLG=2)
  End 1
Endif

# Check that the AutAmt is less than the remaining order amt (sans markup)
# IF manual auth, must match, can't go over either.
Local Decimal AUTAMT,DOCAMT
AUTAMT = func SEPPLIB.GET_SEUAMT([L]VCRTYP,[L]VCRNUM,[F:SEU]STAFLG)
DOCAMT = func SEPPLIB.GET_REMAIN_AMT_NMU([L]VCRTYP)
If [F:SEU]MANAUT=2 & [L]VCRTYP<>2 & AUTAMT<>DOCAMT
  End 0
Elsif AUTAMT<DOCAMT & (CDTCHK | AUTAMT>0)
  End 0
Endif

# Check that the Auth has not expired - allow re-auth
If date$>[F:SEU]AUTDAT+[F:SER]AUTDAY & [F:SEU]STAFLG<4 : End CDTCHK : Endif

End 1
########################################################################################
Subprog SEPP_CUR_DOC(SOHNUM,CURVCRTYP,CURVCRNUM)
Value    Char    SOHNUM
Variable Integer CURVCRTYP
Variable Char    CURVCRNUM

If !clalev([F:SEU])  : Local File SEAUTH     [SEU]  : Endif
Filter [F:SEU] Where find(STAFLG,1,2,3,8) & SOHNUM=[L]SOHNUM
Read   [F:SEU] Last
Filter [F:SEU]
If fstat
  [L]CURVCRNUM = [L]SOHNUM
Else
  [L]CURVCRNUM = [F:SEU]VCRNUM
  [L]CURVCRTYP = [F:SEU]VCRTYP
Endif

End
