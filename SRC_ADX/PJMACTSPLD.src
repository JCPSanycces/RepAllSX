#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# PJMACTSPLD
##########################################################################################################
# We are in an action mandatory called from OPJM object
# So, globale instance GZINSPJM is mandatory existing too.
# But to be sure, It's possible to check it in $OUVRE action (**1**)
# This action code is called from 3 places
# 1-user is pressing "saleable products list" button from Project screen
#     we only receive the project
# 2-user is pressing "saleable products list" button from Budget screen
#     we only receive the project and budget
# 3-user is pressing "saleable products list" button from Task screen
#     we only receive the project and task
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    # Buttons
    When "ENR"                         : Gosub ENR               # save
    When "APRES_MODIF"                 : Gosub APRES_MODIF       # after field
    When "ABA"                         : Gosub ABANDON           # cancel
    When "MEN"                         : Gosub MENU              # Issue X3-107679 - 2018-09-10 by ALMON : BEGIN : Refresh after return from automation
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  Local File PJMSALITMD [PSPLD]
  Local File ITMMASTER [ITM]
  #
  NAVIG = GACTION
  GOK = 1
Return

##########################################################################################################
$DEBUT
Local Integer ACTION_ERROR   # check that parameters are passed in correctly

  If dim(GZINSPJM) <= 0 Then
    GMESSAGE = mess(186,123,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  # ------------------------------
  # PARAM(1) = "PJM" "PJMBUD"  "PJMTAS"
  # PARAM(2) = ""    PBUCOD    TASCOD
  # ------------------------------
  Effzo [M:SPLD0]
  [M:SPLD0]CALFRO = PARAM(1)
  Case [M:SPLD0]CALFRO
    When func CALLER_PROJECT()
      Raz [M:SPLD0]ACTLIN
      Chgfmt [M:SPLD0]PBUCOD With "-K:" + num$(GLONPBU) + "X"
      Chgfmt [M:SPLD0]TASCOD With "-K:" + num$(GLONTAC) + "X"
    When func CALLER_BUDGET()
      [M:SPLD0]PBUCOD = PARAM(2)
      [M:SPLD0]ACTLIN = fmet GZINSPJM.PJM(1).BUD_GET_INDEX(PARAM(2))
      Chgfmt [M:SPLD0]TASCOD With "-K:" + num$(GLONTAC) + "X"
      Diszo [M:SPLD1]PBUCOD
      Diszo [M:SPLD1]TASCOD
    When func CALLER_TASK()
      [M:SPLD0]TASCOD = PARAM(2)
      [M:SPLD0]ACTLIN = fmet GZINSPJM.PJM(1).TAS_GET_INDEX(PARAM(2))
      Chgfmt [M:SPLD0]PBUCOD With "-K:" + num$(GLONPBU) + "X"
      Diszo [M:SPLD1]PBUCOD
      Diszo [M:SPLD1]TASCOD
    When Default
      GMESSAGE = mess(186,123,1)
      GERR = 1
      FIN = 1
      Return
  Endcase
  [M:SPLD0]OPPNUM = GZINSPJM.OPPNUM
  # ------------------------------
  ACTION_ERROR = [V]CST_AOK
  If [M:SPLD0]OPPNUM = AVOID.ACHAR Then
    ACTION_ERROR = [V]CST_AERROR                 # no project
  Else
    If [M:SPLD0]PBUCOD <> AVOID.ACHAR and [M:SPLD0]TASCOD <> AVOID.ACHAR Then
      ACTION_ERROR = [V]CST_AERROR               # cannot have both a budget and a task
    Else
      If [M:SPLD0]PBUCOD <> AVOID.ACHAR Then
        If [M:SPLD0]ACTLIN = 0 Then
          ACTION_ERROR = [V]CST_AERROR           # no line number in collection
        Endif
      Else
        If [M:SPLD0]TASCOD <> AVOID.ACHAR Then
          If [M:SPLD0]ACTLIN = 0 Then
            ACTION_ERROR = [V]CST_AERROR         # no line number in collection
          Endif
        Endif
      Endif
    Endif
  Endif
  # ------------------------------
  If ACTION_ERROR = [V]CST_AOK Then
    Call LOAD_PAGE()
  Else
    GMESSAGE = mess(186,123,1) - GACTION
    GERR = 1
    FIN = 1
  Endif
Return

##########################################################################################################
# Buttons
##########################################################################################################
$APRES_MODIF
  If REP = AVOID.ACHAR Then
    REP = "M"
    [M:SPLD0]REP = REP
  Endif
Return

##########################################################################################################
$ABANDON
  If REP <> AVOID.ACHAR Then
    Gosub RELIT_GZINSPJM From SUBPJMA
    Call LOAD_PAGE()
    REP = AVOID.ACHAR
    [M:SPLD0]REP = REP
  Endif
Return

##########################################################################################################
$MENU
  # Issue X3-107679 - 2018-09-10 by ALMON
  Case BOUT
    When "-"
      Call LOAD_PAGE()
    When Default
  Endcase
Return

##########################################################################################################
$ENR
Local Integer MY_STATUS

  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  # ----------------------------------
  [L]MY_STATUS = fmet GZINSPJM.AUPDATE()
  If [L]MY_STATUS > [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(159,2260,1)
    Endif
    If [L]MY_STATUS > [V]CST_AWARNING Then
      Return
    Endif
  Endif
  Gosub RELIT_GZINSPJM From SUBPJMA
  # ----------------------------------
  Call LOAD_PAGE()
  Call DISPLAY_MARGIN()
  REP = AVOID.ACHAR
  [M:SPLD0]REP = REP
Return

##########################################################################################################
# SUBROUTINES
##########################################################################################################
Subprog COPY_SCREEN_TO_CLASS()

  Case [M:SPLD0]CALFRO
    When func CALLER_PROJECT()
      Call COPY_SCREEN_TO_CLASS_PROJECT()
    When func CALLER_BUDGET()
      Call COPY_SCREEN_TO_CLASS_BUDGET([M:SPLD0]BUD_LIN)
    When func CALLER_TASK()
      Call COPY_SCREEN_TO_CLASS_TASK([M:SPLD0]TAS_LIN)
  Endcase
End

##########################################################################################################
Subprog COPY_SCREEN_TO_CLASS_PROJECT()

Local Integer NI
Local Integer ASTATUS
Local Integer ILINE

  For NI = 1 To maxtab(GZINSPJM.PJM(1).SPLD)
    If GZINSPJM.PJM(1).SPLD(NI) <> null and find(GZINSPJM.PJM(1).SPLD(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSPJM.PJM(1).SPLD(NI).AUUID), [M:SPLD1]AUUID(0..[M:SPLD1]NBLIG-1))
      If ILINE = 0 Then
        ILINE = find(func GET_COLLINTXT(func CALLER_PROJECT(), NI), [M:SPLD1]COLLINTXT(0..[M:SPLD1]NBLIG-1))
      Endif
      If ILINE = 0 Then
        [L]ASTATUS = fmet GZINSPJM.PJM(1).ADELLINE("SPLD", GZINSPJM.PJM(1).SPLD(NI).AORDER)
        If [L]ASTATUS = [V]CST_ANOTDEFINED Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # --------------------------------
  For NI = 1 To maxtab(GZINSPJM.PJM(1).BUD)
    If GZINSPJM.PJM(1).BUD(NI) <> null and find(GZINSPJM.PJM(1).BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      Call COPY_SCREEN_TO_CLASS_BUDGET(NI)
      If GERR = 1 Then
        Break
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # ------------------------------------
  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS)
    If GZINSPJM.PJM(1).TAS(NI) <> null and find(GZINSPJM.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      Call COPY_SCREEN_TO_CLASS_TASK(NI)
      If GERR = 1 Then
        Break
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
End

##########################################################################################################
Subprog COPY_SCREEN_TO_CLASS_BUDGET(IBUDLIN)
Value Integer IBUDLIN

Local Integer NI
Local Integer ASTATUS
Local Integer ILINE

  For NI = 1 To maxtab(GZINSPJM.PJM(1).BUD(IBUDLIN).SPLD)
    If GZINSPJM.PJM(1).BUD(IBUDLIN).SPLD(NI) <> null and find(GZINSPJM.PJM(1).BUD(IBUDLIN).SPLD(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSPJM.PJM(1).BUD(IBUDLIN).SPLD(NI).AUUID), [M:SPLD1]AUUID(0..[M:SPLD1]NBLIG-1))
      If ILINE = 0 Then
        ILINE = find(func GET_COLLINTXT(func CALLER_BUDGET(), NI), [M:SPLD1]COLLINTXT(0..[M:SPLD1]NBLIG-1))
      Endif
      If ILINE = 0 Then
        [L]ASTATUS = fmet GZINSPJM.PJM(1).BUD(IBUDLIN).ADELLINE("SPLD", GZINSPJM.PJM(1).BUD(IBUDLIN).SPLD(NI).AORDER)
        If [L]ASTATUS = [V]CST_ANOTDEFINED Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
End

##########################################################################################################
Subprog COPY_SCREEN_TO_CLASS_TASK(ITASLIN)
Value Integer ITASLIN

Local Integer NI
Local Integer ASTATUS
Local Integer ILINE

  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS(ITASLIN).SPLD)
    If GZINSPJM.PJM(1).TAS(ITASLIN).SPLD(NI) <> null and find(GZINSPJM.PJM(1).TAS(ITASLIN).SPLD(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSPJM.PJM(1).TAS(ITASLIN).SPLD(NI).AUUID), [M:SPLD1]AUUID(0..[M:SPLD1]NBLIG-1))
      If ILINE = 0 Then
        ILINE = find(func GET_COLLINTXT(func CALLER_TASK(), NI), [M:SPLD1]COLLINTXT(0..[M:SPLD1]NBLIG-1))
      Endif
      If ILINE = 0 Then
        [L]ASTATUS = fmet GZINSPJM.PJM(1).TAS(ITASLIN).ADELLINE("SPLD", GZINSPJM.PJM(1).TAS(ITASLIN).SPLD(NI).AORDER)
        If [L]ASTATUS = [V]CST_ANOTDEFINED Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
End

##########################################################################################################
Subprog LOAD_PAGE()

  Effzo [M:SPLD1]10
  Call COPY_CLASS_TO_SCREEN()
  Affzo [M:SPLD1]1-99
End

##########################################################################################################
# copy class to screen
#
# Action called from the Project screen:
#   display all lines on the collection
# Action called from the Budget screen:
#   only display lines on the collection that have the same budget code as the budget code passed in from the Action
##########################################################################################################
Subprog DISPLAY_WITH_STYLE()
Local Integer NI

  Affzo [M:SPLD1]
  For NI = 0 To [M:SPLD1]NBLIG-1
    Call DISPLAY_WITH_STYLE_LINE(NI)
  Next NI
End

###########################################################################################################
Subprog DISPLAY_WITH_STYLE_LINE(NI)
Value Integer NI

  If [M:SPLD0]CALFRO = func CALLER_PROJECT() Then
    Case [M:SPLD1]LINTYP(NI)
      When func PJMACTSPLD.CALLER_PROJECT()
        # Project level
        Chgstl [M:SPLD1]ITMREF(NI) With "BACKGREEN"
      When func PJMACTSPLD.CALLER_BUDGET()
        # Budget level
        Chgstl [M:SPLD1]ITMREF(NI) With "BACKYELLOW"
      When func PJMACTSPLD.CALLER_TASK()
        # Task level
        Chgstl [M:SPLD1]ITMREF(NI) With "BACKORANGE"
    Endcase
  Endif
End

##########################################################################################################
Subprog DISPLAY_MARGIN()

Local Integer NI
Local Decimal DBASPRI
Local Decimal LINPRICE
Local Decimal DPRJAMT

  If [M:SPLD0]CALFRO = func CALLER_PROJECT() Then                              # Project level only
    DPRJAMT = fmet GZINSPJM.PJM(1).BUD_GET_PRJAMT()
    If DPRJAMT <> 0 and [M:SPLD1]NBLIG <> 0 Then
      [M:SPLD0]CUR = GZINSPJM.CUR                                              #SET Currency
      [M:SPLD0]BUDAMT = DPRJAMT                                                #GET Project budget amount
      # ------------------------------------
      For NI = 0 To [M:SPLD1]NBLIG-1
        LINPRICE = [M:SPLD1]BASPRI(NI) * [M:SPLD1]QTY(NI)                      #CALCULATE Saleable product line base price
        DBASPRI += LINPRICE                                                    #Accumulate Saleable products line base prices
      Next NI
      # ------------------------------------
      If DBASPRI <> 0 Then
        [M:SPLD0]DALPEC = ((DBASPRI - [M:SPLD0]BUDAMT) / DBASPRI) * 100        #CALCULATE and SET percentage#
        [M:SPLD0]BASPRITOT = DBASPRI                                           #SET total base price
        [M:SPLD0]SALBUDAMT = DBASPRI - [M:SPLD0]BUDAMT                         #SET Margin
      Endif
    Else
      Raz [M:SPLD0]BASPRITOT                                                   #Clear field
      Raz [M:SPLD0]SALBUDAMT                                                   #Clear field
      Raz [M:SPLD0]DALPEC                                                      #Clear field
    Endif
    #-------------------------------------
    # Negative values style
    If [M:SPLD0]SALBUDAMT < 0 Then
      Chgstl [M:SPLD0]SALBUDAMT With "TDBRED"
    Endif
    If [M:SPLD0]DALPEC < 0 Then
      Chgstl [M:SPLD0]DALPEC With "TDBRED"
    Endif
    # -------------------------------------
  Endif
End

##########################################################################################################
Subprog COPY_CLASS_TO_SCREEN()

  Case [M:SPLD0]CALFRO
    When func CALLER_PROJECT()
      Call COPY_CLASS_TO_SCREEN_PROJ()
    When func CALLER_BUDGET()
      Call COPY_CLASS_TO_SCREEN_BUD()
    When func CALLER_TASK()
      Call COPY_CLASS_TO_SCREEN_TAS()
  Endcase
End

##########################################################################################################
Subprog COPY_CLASS_TO_SCREEN_PROJ()

Local Integer NI

  nolign = 0
  For NI = 1 To maxtab(GZINSPJM.PJM(1).SPLD)
    If GZINSPJM.PJM(1).SPLD(NI) <> null and find(GZINSPJM.PJM(1).SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If nolign+1 > dim([M:SPLD1]ITMREF) Then
        Break
      Endif
      nolign += 1
      [M:SPLD1]LINTYP(nolign-1) = func CALLER_PROJECT()
      Call SHOW_SPLD_LINE(NI, 0)
    Endif
  Next NI
  # ------------------------------------
  For NI = 1 To maxtab(GZINSPJM.PJM(1).BUD)
    If GZINSPJM.PJM(1).BUD(NI) <> null and find(GZINSPJM.PJM(1).BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      Call _COPY_CLASS_TO_SCREEN_BUD(NI)
    Endif
  Next NI
  # ------------------------------------
  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS)
    If GZINSPJM.PJM(1).TAS(NI) <> null and find(GZINSPJM.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      Call _COPY_CLASS_TO_SCREEN_TAS(NI)
    Endif
  Next NI
  # ------------------------------------
  [M:SPLD1]NBLIG = nolign
  Call DISPLAY_WITH_STYLE()
  Call DISPLAY_MARGIN()
End

##########################################################################################################
Subprog COPY_CLASS_TO_SCREEN_BUD()

  nolign = 0
  Call _COPY_CLASS_TO_SCREEN_BUD([M:SPLD0]ACTLIN)
  [M:SPLD1]NBLIG = nolign
  [M:SPLD0]BUD_LIN = [M:SPLD0]ACTLIN
End

##########################################################################################################
Subprog _COPY_CLASS_TO_SCREEN_BUD(ACTION_LIN)
Value Integer ACTION_LIN

Local Integer NI

  For NI = 1 To maxtab(GZINSPJM.PJM(1).BUD(ACTION_LIN).SPLD)
    If GZINSPJM.PJM(1).BUD(ACTION_LIN).SPLD(NI) <> null and find(GZINSPJM.PJM(1).BUD(ACTION_LIN).SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      [M:SPLD1]LINTYP(nolign-1) = func CALLER_BUDGET()
      Call SHOW_SPLD_LINE(NI, ACTION_LIN)
    Endif
  Next NI
End

##########################################################################################################
Subprog COPY_CLASS_TO_SCREEN_TAS()

  nolign = 0
  Call _COPY_CLASS_TO_SCREEN_TAS([M:SPLD0]ACTLIN)
  [M:SPLD1]NBLIG = nolign
  [M:SPLD0]TAS_LIN = [M:SPLD0]ACTLIN
End

##########################################################################################################
Subprog _COPY_CLASS_TO_SCREEN_TAS(ACTION_LIN)
Value Integer ACTION_LIN

Local Integer NI

  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS(ACTION_LIN).SPLD)
    If GZINSPJM.PJM(1).TAS(ACTION_LIN).SPLD(NI) <> null and find(GZINSPJM.PJM(1).TAS(ACTION_LIN).SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      [M:SPLD1]LINTYP(nolign-1) = func CALLER_TASK()
      Call SHOW_SPLD_LINE(NI, ACTION_LIN)
    Endif
  Next NI
End

##########################################################################################################
Subprog SHOW_SPLD_LINE(VNLINE, ACTION_LIN)
Value Integer VNLINE
Value Integer ACTION_LIN

  Case [M:SPLD1]LINTYP(nolign-1)
    When func CALLER_PROJECT()
      SetInstance [M:SPLD1]10 With GZINSPJM.PJM(1).SPLD(VNLINE)
      Raz [M:SPLD1]BUDLIN(nolign-1)
      Raz [M:SPLD1]TASLIN(nolign-1)
    When func CALLER_BUDGET()
      SetInstance [M:SPLD1]10 With GZINSPJM.PJM(1).BUD(ACTION_LIN).SPLD(VNLINE)
      [M:SPLD1]BUDLIN(nolign-1) = ACTION_LIN
      Raz [M:SPLD1]TASLIN(nolign-1)
    When func CALLER_TASK()
      SetInstance [M:SPLD1]10 With GZINSPJM.PJM(1).TAS(ACTION_LIN).SPLD(VNLINE)
      Raz [M:SPLD1]BUDLIN(nolign-1)
      [M:SPLD1]TASLIN(nolign-1) = ACTION_LIN
  Endcase
  [M:SPLD1]COLLIN(nolign-1) = VNLINE   # Line index in the collection
  [M:SPLD1]COLLINTXT(nolign-1) = func GET_COLLINTXT([M:SPLD1]LINTYP(nolign-1), VNLINE)
End

##########################################################################################################
Funprog GET_COLLINTXT(SLINTYP, VNLINE)
Value Char SLINTYP
Value Integer VNLINE

Local Char SARENDRE(GLONDES)

  SARENDRE = SLINTYP + "~" + format$("N0:10",VNLINE)
End SARENDRE

##########################################################################################################
Funprog CALLER_PROJECT()

Local Char SARENDRE(GLONDES)

  SARENDRE = "PJM"
End SARENDRE

##########################################################################################################
Funprog CALLER_BUDGET()

Local Char SARENDRE(GLONDES)

  SARENDRE = "PJMBUD"
End SARENDRE

##########################################################################################################
Funprog CALLER_TASK()

Local Char SARENDRE(GLONDES)

  SARENDRE = "PJMTAS"
End SARENDRE

