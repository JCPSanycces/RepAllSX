###############################                         # Ana   deb
$CHARG_PARAM
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY(GFCY,"SRT",7,GBBYNUM) From TRTX3CPT          # hcb50197
Local Integer LRET
# Récupération des codes compteur et effacement fichier de travail
If clalev ([F:TCA])<=0
   Local File TABCOUAFF [TCA]
Endif
# Compteur module stock
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif
GSTKCPTMAN(16) = [F:TCA]MANCOU(16) # Cpt
GSTKCPT   (16) = [F:TCA]CODNUM(16)
#Controle compteur
Call CTRCPT(GSTKCPT(16),type([M:BBY0]VCRNUM), LRET) From STKLIB
If LRET<>0
   GMESSAGE = mess(12,114,1)  # compteur inexistant
   GERR = 1
   GOK  = 0
   Return
Endif

GSTKCPTMAN(0) = [F:TCA]MANCOU(0)
GSTKCPT   (0) = [F:TCA]CODNUM(0)
GSTKCPTMAN(2) = [F:TCA]MANCOU(2)
GSTKCPT   (2) = [F:TCA]CODNUM(2)

Return

#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL

If GSOC_UPDFLG & !GIMPORT & dim([M:BBY0]CCE1)>0
  Local Char BASPAG(10)


#                                                           composé
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WT07"+GBBYNUM+"0"         # hcb 50197
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:BBY0]NBLIG=0
    [M:BBY0]NBLIG=1 : Affzo [BBY0]10 : Effzo [BBY0]10
  Endif
#                                                           composant
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WT07"+GBBYNUM+"1"        # hcb 50197
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:BBY1]NBLIG=0
    [M:BBY1]NBLIG=1 : Affzo [BBY1]5 : Effzo [BBY1]5
  Endif
Endif
Raz GSOC_UPDFLG
Return


#########################################
$GRISE
# Accès à un document créé en multi-dépôt avec une transaction mono-dépôt
# --> pas d'application du mono-dépôt
If [F:SMH]WRHE="" & GWRHOBY=2
   GWRHOBY=1
   #--- Bug 62402
   #Call MESSAGE(mess(351,184,1)) From GESECRAN
   If [M:BBY0]STOFCY<>[F:FCY]FCY : Read [FCY]FCY0=[M:BBY0]STOFCY : Endif
   If [F:FCY]WRHGES=2 : Call MESSAGE(mess(351,184,1)) From GESECRAN : Endif
   #---
Endif
Return

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M:BBY0]STOFCY<>[F:FCY]FCY
   Read [FCY]FCY0=[M:BBY0]STOFCY
Endif

If [F:FCY]WRHGES=2
   If find(GREP,"C","D")
      Actzo [M:BBY0]WRHE
      If GWRHOBY=2
         Diszo [M:BBY0]WRH  :  #--- Bug 82156
         Diszo [M:BBY1]WRH
      Else
         Actzo [M:BBY0]WRH  :  #--- Bug 82156
         Actzo [M:BBY1]WRH
      Endif
   Elsif [M:BBY0]WRHE<>""
      Diszo [M:BBY0]WRHE
      Diszo [M:BBY0]WRH     :  #--- Bug 82156
      Diszo [M:BBY1]WRH
   Else
      Actzo [M:BBY0]WRHE
      Actzo [M:BBY0]WRH     :  #--- Bug 82156
      Actzo [M:BBY1]WRH
   Endif
Else
  Raz   [M:BBY0]WRHE
  Grizo [M:BBY0]WRHE
  Grizo [M:BBY0]WRH         :  #--- Bug 82156
  Grizo [M:BBY1]WRH
Endif
Return

