#<AdxTL>@(#)3.0.0.0 $Revision$

Call OBJET("BBY", GBIDC1, GBIDC2) From GOBJET
End


$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

#######################################################################
# Les etiquettes suivantes sont définies pour la gestion de l'objet   #
#######################################################################
$DEFTRANS
Local Shortint OUVFICFLG
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
If GFONC1 <> "GESBBY"  Raz GFLAG Endif
If GFLAG<>""
  Read [F:SRT] SRT0=7;GFLAG
  If fstat | [F:SRT]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:SRT]ACSCOD<>"" & GPROFIL<>GSUPER & [F:SRT]ABYTYP <> 1
    If clalev ([F:ACC])=0
        Local File ACCES  [ACC]
        OUVFICFLG=1
    Endif
    Read [ACC] CODACC=GUSER;[F:SRT]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1 Close File [ACC] : Raz OUVFICFLG : Endif
Return

######################################################################
$VARIANTE
# La transaction lue est elle utilisable ?
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
Read [SRT]SRT0=7;[F:AWI]TRN
If fstat | [F:SRT]ENAFLG<>2 | [F:SRT]ABYTYP <> 1
   OK = 0
Endif
Return
######################################################################
$SETTRANS
Global Integer  GCCECOD    : # Flag saisie des sections analytiques
If dim(GSVGWRHOBY)<0 Global Integer GSVGWRHOBY Endif

If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
Read [SRT]SRT0=7;GFLAG

GSLTSTKFLG  = [F:SRT]STKFLG

#MAE, le 29/01/08, GRP_SITE
GGRPFCY = [F:SRT]GFY
GBBYNUM = [F:SRT]SRTNUM

# Dépôt entête obligatoire ou non
If GWRHACT=2
  GWRHOBY = [F:SRT]WRHOBY
Else
  GWRHOBY = 1
Endif
GSVGWRHOBY = GWRHOBY

Return


######################################################################
$OUVRE
If dim(GSVGWRHOBY)<0 Global Integer GSVGWRHOBY Endif
Local  Integer  LRET
Raz GSOC_ACTIVE                                               # Ana

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB

    Global Integer GRELITSMR
    Raz GRELITSMR

    GSRTNUM = GFLAG
    GBBYNUM = GFLAG                        # hcb 50197

    # TRSTYP = type de mouvement stock (menu local 704)
    # Sa valeur est utilisée en particulier
    # pour le contrôle de statut

    If GFONCTION = "GESBBY"
      [M:BBY0]VCRTYP=31          #assemblage
    Endif
    If GFONCTION = "GESDBY"
      [M:BBY0]VCRTYP=32          #desassemblage
    Endif

   [M:BBY0]TRSTYP  = 1        # entrée pour le composé
   [M:BBY0]TRSTYPC = 2        # sortie pour les composants

    GFCY=GFCYDEF(7)                                                # Ana
    Gosub CHARG_PARAM                                              # Ana
    If GMODU(2)=2 : # Si module compta actif                       # Ana
      If !clalev([F:GCM])   Local File GACM       [GCM] : Endif    # Ana
    Endif                                                          # Ana
    GORITITCOL=1                                                   # Ana

    # Initialisation des tables nécessaires à la gestion d'emplacements
    Gosub STK_INILOC From STKLOC

    #  ecran stockage mvt du document entree
    If clalev([M:ENTW])=0
        Local Mask STOENTW   [ENTW]
    Endif
    [M:ENTW]WZONPCU = "PCU"
    [M:ENTW]WZONQUC = "QTYPCU"
    [M:ENTW]WZONCCS = "PCUSTUCOE"
    [M:ENTW]WZONQUS = "QTYSTU"
    [M:ENTW]WZONSTOUPD = ""

    Call DELSTOENTW(-1,-1,"BBY0",1,1,[M:BBY0]STOFCY,1,"") From STKENT


 #----- Ecran stockage mvt du document  sortie
    If clalev([M:SOW])=0
        Local Mask STOSORW   [SOW]
    Endif
    Raz [M:SOW]

    #  ecran de travail enreg mvt du document
    If clalev([M:STW])=0
        Local Mask STOWORK   [STW]
    Endif
    Raz [M:STW]
    If clalev([M:SDPA])=0
        Local Mask SAIDECPRI   [SDPA]    # Sert à cumuler les valeurs des sorties pour en déduire le coût de l'entrée
    Endif
    If clalev([M:VALW])=0
        Local Mask STOVALW   [VALW]
    Endif
    Raz [M:VALW]
    [M:VALW]ZONPRI = "[M:BBY0]PRIORD"
    [M:VALW]ZONPRIORD = "[M:BBY0]PRIORD"
    If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif
    If !clalev([M:SDP]) : Local Mask SAIDECPRI [SDP] : Endif
    Raz [M:SDP]

   #----- Ecran des paramètres d'allocations
    If clalev([M:ALP])=0
        Local Mask ALLPAR    [ALP]
    Endif

    If clalev([F:TRU])=0
        Local File TABALLRUL [TRU]
    Endif
    If clalev([F:SRU])=0
        Local File TABSTORUL [SRU]
    Endif
    If clalev([F:FCY])=0
        Local File FACILITY [FCY]
    Endif

    Gosub DECLARE From TABLEAUX
Return

$FILTRE
    Default File [SMH]
    # Limite les enregistrement de la liste gauche
    If GFONCTION = "GESBBY"
       FILTSUP = "VCRTYP=31"          #assemblage
    Endif
    If GFONCTION = "GESDBY"
       FILTSUP = "VCRTYP=32"          #desassemblage
    Endif
Return

$LIENS
Local Integer I
If GFCY<>[F:SMH]STOFCY GFCY=[F:SMH]STOFCY : Gosub CHARG_PARAM : Endif    # Ana
#----- Affichage entêtes de colonne variables -----#                     # Ana
Gosub AFF_TITCOL                                                         # Ana


Local Char    SECTION
# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDATBBY) > 0
   Kill GCTRDATBBY
Endif



Raz GRELITSMR
Call DELSTOENTW(-1,-1,"BBY0",1,1,[M:BBY0]STOFCY,1,"") From STKENT
Call RAZSTOSORW From STKSOR
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 7 | [F:SRT]SRTNUM <> GBBYNUM                   # hcb 50197
    Read [SRT]SRT0=7;GBBYNUM : If fstat Raz [F:SRT] : Endif
Endif
Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0
If fstat
   Raz [F:DTR]
Endif

[M:BBY0]CCECODS   = [F:DTR]HEACCECOD
 #---- Récupération des sections analytiques  entete ----#
Local Integer Y
For Y=1 To GNBDIE
    [M:BBY0]CCE(Y-1) = [F:SMH]CCE(Y-1)
Next


Actzo [M:BBY0]
#Actzo [M:BBY0]VCRNUM    # Car il y a un diszo en RAZCRE (et RAZDUP)
Grizo [M:BBY0]STOFCY
Grizo [M:BBY0]IPTDAT
Grizo [M:BBY0]PJT
Grizo [M:BBY0]TRSFAM
Grizo [M:BBY0]ENTCOD
Diszo [M:BBY0]VCRNUMORI # diszo pour conserver les menus contextuels   hcb 22993

[M:BBY0]TRSTYP  = 1        # entrée pour le composé
[M:BBY0]TRSTYPC = 2        # sortie pour les omposants

[M:BBY0]TRSCOD    = [F:SRT]TRSCOD              # hcb 50197
# Issue 105771 - 2015-01-27 by SR : Zone saisissable en création donc valeur stockée en table doit être conservée
#[M:BBY0]TRSFAM    = [F:SRT]TRSFAMDEF           # hcb 50197
[M:BBY0]PNTMVTCOD = [F:SRT]PNTMVTCOD           # hcb 50197
[M:BBY0]SRGWAIFLG = [F:SRT]SRGWAIFLG           # hcb 50197
[M:BBY0]STKFLG    = [F:SRT]STKFLG              # hcb 50197

Gosub LIENS From TABLEAUX
#                                                         # hcb 71276  deb
If [F:ITM]ECCSTO > 1 & dim([M:BBY0]ECCVALMAJ) >= 0
   If [M:BBY0]ECCVALMAJ(0) <> ""
      [M:BBY0]ECCVALMAJORI(0) = [M:BBY0]ECCVALMAJ(0)
      [M:BBY0]ECCVALMINORI(0) = [M:BBY0]ECCVALMIN(0)
      [M:BBY0]ECCSAIFLG   (0) = 9
   Endif
Endif
#                                                         # hcb 71276  fin

Gosub SANS_COMPOSE                                                                     # hcb 28649

# hcb 22993 deb
Local Char WMSG
If [F:SMH]VCRTYPORI = 32
    WMSG = "("
    If  [F:SMH]DBYFLG = 2
        WMSG = WMSG+ mess(231,184,1)
    Else
        WMSG = WMSG+ mess(223,184,1)
    Endif
    If [F:SMD]QTYPCU <> 0
       WMSG = WMSG+" : "+num$([F:SMD]QTYPCU-[F:SMD]QTYPCUORI)+"/"+num$([F:SMD]QTYPCU)
    Else
       WMSG = WMSG+" : "+num$([F:SMD]QTYSTU-[F:SMD]QTYSTUORI)+"/"+num$([F:SMD]QTYSTU)
    Endif
    WMSG = WMSG +")"
    [M:BBY0]PNTMVTLIB = WMSG
Endif

# hcb 22993 fin

Affzo [M:BBY0]10


Default Mask [BBY1]
Call ETAZONSOR("BBY1") From STKECR
Default Mask [BBY0]

#Call GETDEV([M:BBY0]STOFCY) From DEVSUB               # ana


Call STKCTRIPT( [M:BBY0]IPTDAT, [M:BBY0]STOFCY, "1") From STKLIB
If GERR=1
   Call ERREUR(GMESSAGE) From GESECRAN
   Raz GERR
   Raz GMESSAGE
   Grizo [M:BBY0]10
Elsif GERR=2
   Call MESSAGE(GMESSAGE) From GESECRAN
   Raz GERR
   Raz GMESSAGE
   Grizo [M:BBY0]10
Else
   Diszo [M:BBY0]
Endif
# nombre de lecture (sert pour la saisie ligne)
Local Integer WMAX
Local Integer WRET
WMAX = dim([M:BBY1]ITMREF)     # mémorisation nombre de ligne maxi
Raz [M:BBY1]
nolign = 1
# chargement tableau composants
Filter [SMD] Where VCRTYP = [M:BBY0]VCRTYP    &
&                  VCRNUM = [M:BBY0]VCRNUM    &
&                  LINTYP = 2
&            Order By Key SMD0
For [SMD]
    If nolign = WMAX : Break : Endif

    #--- Bug 82156
    [M:BBY1] = [F:SMD]
    #[M:BBY1]VCRLIN    (nolign-1) =  [F:SMD]VCRLIN
    #[M:BBY1]ITMREF    (nolign-1) =  [F:SMD]ITMREF
    #[M:BBY1]PRIORD    (nolign-1) =  [F:SMD]PRIORD
    #[M:BBY1]ITMDES1   (nolign-1) =  [F:SMD]ITMDES1
    #[M:BBY1]PCU       (nolign-1) =  [F:SMD]PCU
    #[M:BBY1]QTYPCU    (nolign-1) =  [F:SMD]QTYPCU
    #[M:BBY1]PCUSTUCOE (nolign-1) =  [F:SMD]PCUSTUCOE
    #[M:BBY1]STU       (nolign-1) =  [F:SMD]STU
    #[M:BBY1]QTYSTU    (nolign-1) =  [F:SMD]QTYSTU
    #[M:BBY1]VCRTYPORI (nolign-1) =  [F:SMD]VCRTYPORI
    #[M:BBY1]VCRNUMORI (nolign-1) =  [F:SMD]VCRNUMORI
    #[M:BBY1]VCRLINORI (nolign-1) =  [F:SMD]VCRLINORI
    #[M:BBY1]QTYPCUORI (nolign-1) =  [F:SMD]QTYPCUORI  # hcb 22993
    #[M:BBY1]QTYSTUORI (nolign-1) =  [F:SMD]QTYSTUORI  # hcb 22993
    #---

    [M:BBY1]FLT       (nolign-1) = "[F:STJ]VCRLIN="+num$([M:BBY1]VCRLIN(nolign-1))

    [M:BBY1]PRIORD_AV (nolign-1) =  [F:SMD]PRIORD     # hcb 28654
    [M:BBY1]QTYSTU_AV (nolign-1) =  [F:SMD]QTYSTU     # hcb 28654

    [M:BBY1]CREFLG    (nolign-1) =  1
    ############################### sections ligne composant  Ana   deb
    Call CHARG_ACCCCE(nolign-1,"","","[M:BBY1]CCE",
&                "SMD",[F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"") From TRTX3CPT
    ###############################                         # Ana   fin
# chargement specificité sortie ???????????????
    Read [F:ITM]ITM0 = [M:BBY1]ITMREF(nolign-1)
    # Alimentation des zones stock de la ligne
    # à partir de STOJOU ou STOALL
    Call RECSTOSOR (!([M:BBY0]CFMFLG)+1, "BBY1",nolign-1,[M:BBY0]STOFCY,[M:BBY1]ITMREF(nolign-1),31,
&                   [M:BBY0]VCRNUM,[M:BBY1]VCRLIN(nolign-1),"",WRET) From STKECR
# Lecture article et règle de gestion
    Call INIZONSOR("BBY1",[M:BBY1]ITMREF(nolign-1),[M:BBY0]STOFCY,(nolign-1),[M:BBY0]TRSTYPC,[M:BBY0]TRSCOD,"") From STKECR

     If [F:ITM]STOMGTCOD <= 1
        [M:BBY1]STOMGTCOD (nolign-1) =  [F:ITM]STOMGTCOD
     Else
        [M:BBY1]STOMGTCOD (nolign-1) =  [F:ITF]STOMGTCOD
     Endif
# hcb 28654 deb
    If [M:BBY1]STOMGTCOD (nolign-1) < 2
       If dim([M:BBY1]PRIORD)>0
          Actzo [M:BBY1]PRIORD(nolign-1)
       Endif
    Else
       If dim([M:BBY1]QTYPCU)>0
          Diszo [M:BBY1]QTYPCU(nolign-1)
       Endif
    Endif
# hcb 28654 fin

    [M:BBY1]NBLIG  = nolign
    nolign += 1
Next
Filter [SMD]

Call STKDISCOL("BBY1",[M:BBY1]NBLIG) From STKECR
Diszo [M:BBY1]ITMREF,ITMDES1
Actzo [M:BBY1]ITMREF([M:BBY1]NBLIG),ITMDES1([M:BBY1]NBLIG)
If dim([M:BBY1]PCU)>0
       Diszo [M:BBY1]PCU
       Actzo [M:BBY1]PCU([M:BBY1]NBLIG),QTYPCU([M:BBY1]NBLIG)
Endif
If dim([M:BBY1]PCUSTUCOE)>0
       Diszo [M:BBY1]PCUSTUCOE
       Actzo [M:BBY1]PCUSTUCOE([M:BBY1]NBLIG)
Endif
If dim([M:BBY1]STU)>0
       Diszo [M:BBY1]STU,QTYSTU
       Actzo [M:BBY1]STU([M:BBY1]NBLIG),QTYSTU([M:BBY1]NBLIG)
Endif

# Actzo ou Grizo des dépôts selon le site
GWRHOBY = GSVGWRHOBY
Gosub WRH_ETAT

Affzo [M:BBY1]5

Default Mask [BBY0]

Return


$DEFLIG
    Default Mask [BBY0]
    Default File [SMD]
    CRIT = 'VCRTYP='+num$([M:BBY0]VCRTYP)+' and VCRNUM="'+[M:BBY0]VCRNUM+'" and LINTYP = 1'
    FICLIG="SMVTD"
    ABLIG="SMD"
    ZONLIG="VCRLIN"
Return

################
# Chargement de la ligne en cours
$LIENS_LIG

Gosub SET_NOL
Read [F:ITM]ITM0 = [M:BBY0]ITMREF(NOL)
Call RECSTO_F ("BBY0", [M:BBY0]STOFCY, [M:BBY0]VCRTYP,
&              [M:BBY0]VCRNUM, [M:BBY0]VCRLIN(NOL), NOL, "") From STKECR

############################### sections ligne composé  Ana   deb
Call CHARG_ACCCCE(NOL,"","","[M:BBY0]CCE",
&                "SMD",[F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"") From TRTX3CPT
###############################                         # Ana   fin

Return

$RAZCRE
    Raz [M:BBY0]
    If GFCY<>GFCYDEF(7)                             # Ana
       GFCY=GFCYDEF(7) : Gosub CHARG_PARAM           # Ana
    Endif                                           # Ana
#----- Affichage entêtes de colonne variables -----#
    Gosub AFF_TITCOL                                # Ana

    If GSTKCPTMAN(16)<>2
        Effzo [M:BBY0]VCRNUM
        Diszo [M:BBY0]VCRNUM
    Endif
    Actzo [M:BBY0]STOFCY
    Actzo [M:BBY0]IPTDAT
    Actzo [M:BBY0]PJT
    Actzo [M:BBY0]TRSFAM
    Actzo [M:BBY0]ITMREF
    Diszo [M:BBY0]VCRNUMORI # diszo pour conserver les menus contextuels   hcb 22993

    If GFONCTION = "GESBBY"
       [M:BBY0]VCRTYP = 31          #assemblage
    Endif
    If GFONCTION = "GESDBY"
       [M:BBY0]VCRTYP = 32        #desassemblage
    Endif

    [M:BBY0]TRSTYP  = 1
    [M:BBY0]TRSTYPC = 2
    [M:BBY0]CFMFLG  = 2
    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
    #----- Relecture transaction de saisie  -----#
    If [F:SRT]SRTTYP <> 7 | [F:SRT]SRTNUM <> GBBYNUM                   # hcb 50197
       Read [SRT]SRT0=7;GBBYNUM : If fstat Raz [F:SRT] : Endif
    Endif
    Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0
    If fstat
       Raz [F:DTR]
    Endif

    [M:BBY0]TRSCOD    = [F:SRT]TRSCOD
    [M:BBY0]TRSFAM    = [F:SRT]TRSFAMDEF
    [M:BBY0]PNTMVTCOD = [F:SRT]PNTMVTCOD           # hcb 28649
    [M:BBY0]SRGWAIFLG = [F:SRT]SRGWAIFLG           # hcb 50197
    [M:BBY0]STKFLG    = [F:SRT]STKFLG              # hcb 50197

    Affzo [M:BBY0]TRSFAM
    [M:BBY0]ENTCOD = [F:SRT]ENTCOD
    If [M:BBY0]STOFCY = ""
       [M:BBY0]STOFCY = GFCYDEF(7)
    Endif
   [M:BBY0]CCECODS   = [F:DTR]HEACCECOD
Local Char SECTION
Gosub SANS_COMPOSE                              # hcb 28649

If [M:BBY0]PNTMVTCOD <> 1                       # hcb 28649
    For Y=1 To GNBDIE
        If dim([M:BBY0]CCE)>0
           Call INISEC(SECTION, "STKBBYH", Y) From TRTX3CPT
           [M:BBY0]CCE(Y-1)  = SECTION
           [F:SMH]CCE(Y-1)   = SECTION
        Endif
    Next
Endif                                          # hcb 28649
[F:SMD]VCRLINPNT =  [F:SMD]VCRLIN

If dim([M:BBY0]WRHE)>0
   Call WRHINIT([M:BBY0]WRHE,[M:BBY0]STOFCY,5) From STKWRH
Endif
# Actzo ou Grizo des dépôts selon le site
Gosub WRH_ETAT

Call RAZSTOSORW From STKSOR

Return

$RAZDUP
Local Integer  I
Local Shortint LRET
Local Integer NOL
    Gosub RAZCRE

    Raz [M:BBY0]VCRLIN
    Raz [M:BBY0]UPDFLG
    Raz [M:BBY0]CREFLG
    Raz [M:BBY0]BPSLOT
    If dim([M:BBY0]LOT) > 0
       Raz [M:BBY0]LOT
    Endif
    If dim([M:BBY0]NBSLO) > 0
       Raz [M:BBY0]NBSLO
       Raz [M:BBY0]SLO
       Raz [M:BBY0]SLOF
    Endif
    Raz [M:BBY0]GESLOT
    Raz [M:BBY0]STA
    If dim([M:BBY0]LOCTYP) > 0
       Raz [M:BBY0]LOCTYP
       Raz [M:BBY0]LOC
    Endif
    If dim([M:BBY0]SERNUM) > 0
       Raz [M:BBY0]SERNUM
       Raz [M:BBY0]SERNUMF
    Endif
    Raz [M:BBY0]PRIORD
    Raz [M:BBY0]MVTDES
    Raz [M:BBY0]PNTMVTLIB                        # hcb 28649
    #----- Relecture transaction de saisie  -----#
    If [F:SRT]SRTTYP <> 7 | [F:SRT]SRTNUM <> GBBYNUM                   # hcb 50197
       Read [SRT]SRT0=7;GBBYNUM : If fstat Raz [F:SRT] : Endif
    Endif
    [M:BBY0]TRSCOD    = [F:SRT]TRSCOD              # hcb 50197
    [M:BBY0]TRSFAM    = [F:SRT]TRSFAMDEF           # hcb 50197
    [M:BBY0]PNTMVTCOD = [F:SRT]PNTMVTCOD           # hcb 28649
    [M:BBY0]SRGWAIFLG = [F:SRT]SRGWAIFLG           # hcb 50197
    [M:BBY0]STKFLG    = [F:SRT]STKFLG              # hcb 50197

    Gosub SANS_COMPOSE                           # hcb 28649

    Affzo [M:BBY0]
    If [M:BBY0]PNTMVTCOD <> 1    # hcb 28649
       For I=0 To [M:BBY0]NBLIG-1
           Call OUVENT( [M:BBY0]STOFCY, "BBY0", [M:BBY0]TRSTYP, [M:BBY0]TRSCOD, "", 19, [M:BBY0]IPTDAT, I, [M:BBY0]NBLIG, "SRT", "", LRET) From STKENT
       Next I
    Endif                        # hcb 28649
    Affzo [M:BBY0]

    For NOL=0 To [M:BBY1]NBLIG-1
        # Lecture article et règle de gestion
        Call INIZONSOR("BBY1",[M:BBY1]ITMREF(NOL),[M:BBY0]STOFCY,NOL,[M:BBY0]TRSTYPC,[M:BBY0]TRSCOD,"") From STKECR
        # Alimentation de [M:ALP]
        Gosub ALI_ALP From SUBBBYA
        # Détermination du stock à sortir (automatisme, saisie)
        Call OUVSOR("BBY1",NOL,[M:BBY1]NBLIG,[M:BBY1]WSTOSEQ(NOL),[M:BBY0]STKFLG,LRET) From STKSOR         # hcb 50197
    Next I
    Affzo [M:BBY1]

Return

#########################################################################
$AVANT_MOD
# Modification impossible si sortie validée
#If [M:BBY0]CFMFLG=2
#    GERR=1
#    GMESSAGE=mess(30,184,1)
#    OK=0
#Endif
Return

#########################################################################
$AVANT_MODFIC
# Réalimenter [M]WRHE avec [F]WRHE pour ne pas écraser le mono-dépôt
If dim([M:BBY0]WRHE)>0
   [M:BBY0]WRHE = [F:SMH]WRHE
Endif
Return

#########################################################################
$INIMOD
Local Integer Y
For Y=1 To GNBDIE
    [F:SMH]CCE(Y-1)=  [M:BBY0]CCE(Y-1)
    [F:SMH]DIE(Y-1) =  GDIE(Y)                 # Ana
Next

Return


$SETBOUT
# hcb 28654  si suppression pas de bouton abandon ou enregistrer
If dim(GSUP) > 0
   GREP = ""
   REP  = ""
   Kill GSUP
Endif
# hcb 286954

If [M:BBY0]NBLIG>0
   Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
# Menu Options / Visu transaction
CHMEN += "c"
# Menu Options / Section analytique
CHMEN += "M"

# Pas de sections analytiques si invisible
If [F:DTR]HEACCECOD=3
   Call VIREBOUT(CHMEN,"M") From GOBJET
Endif

#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
Return

$VERIF_CRE
If [M:BBY0]PNTMVTCOD <> 1           # hcb 28649
   OK = 0
   Call CTLSTOENT( "BBY0", "QTYSTU", [M:BBY0]NBLIG, OK ) From STKECR
Endif                               # hcb 28649
If OK > 0
   Call CTLSTOSOR( "BBY1", "QTYSTU", [M:BBY1]NBLIG, OK ) From STKECR
   OK = !OK
Endif

# Issue X3-106909 - 2018-09-21 by MAE : Ajout du GSTOTRACE
If OK & !GIMPORT & GSTOTRACE>1
    Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
Endif
Return

$VERIF_MOD

If [M:BBY0]PNTMVTCOD <> 1           # hcb 28649
   Call CTLSTOENT( "BBY0", "QTYSTU", [M:BBY0]NBLIG, OK ) From STKECR
Endif                               # hcb 28649
If OK > 0
    Call CTLSTOSOR( "BBY1", "QTYSTU", [M:BBY1]NBLIG, OK ) From STKECR
    OK = !OK
Endif
# Issue X3-106909 - 2018-09-21 by MAE : Ajout du GSTOTRACE
If OK & !GIMPORT & GSTOTRACE >1
    Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
Endif
Return



$INICRE
Local Integer LSTAT
Local Char    LNUM
[F:SMH]VCRTYPORI = 0

    # Création du numéro de document si nécessaire
If GSTKCPTMAN(16)<>2 | [M:BBY0]VCRNUM = ""
   Call NUMERO(GSTKCPT(16), [M:BBY0]STOFCY, [M:BBY0]IPTDAT,
&                       "", LNUM, LSTAT) From SUBANM

        If GOK<0 Return Endif
        If LSTAT=0
          [M:BBY0]VCRNUM   = LNUM
          [F:SMH]VCRNUM    = LNUM
        Else
            GERR=1:GMESSAGE = mess(60,199,1)
            GOK=0
        Endif
Endif

#[M:BBY0]CFMFLG = !([M:BBY0]CFMCOD-1)+1
[M:BBY0]CFMFLG  = 2
[F:SMH]CFMFLG =   2
Local Integer Y
For Y=1 To GNBDIE
    [F:SMH]CCE(Y-1)=  [M:BBY0]CCE(Y-1)
    [F:SMH]DIE(Y-1) =  GDIE(Y)                 # Ana
Next

# Alimentation dépôt entête si mono-dépôt
If dim([M:BBY0]WRHE)>0 & GWRHOBY=2
  [F:SMH]WRHE = [M:BBY0]WRHE
Else
  [F:SMH]WRHE = ""
Endif

Return

$CREATION


# le gosub creation appel le Vallig
# decaler le gosub Gosub CREATION From TABLEAUX appres le next
# si priord de l entre = 0 lire les stojou  des sorties et cumuler AMTORD
# priord = AMTORD / qtystu de l entrée
# modif alistw
#[M:STW]priordh  = AMTORD / qtystu de l entrée

####  début modif pour la valorisation
#Gosub CREATION From TABLEAUX
# creation de la globale GSTK_CUMAMTVAL
Global Decimal GSTK_CUMAMTVAL
Raz GSTK_CUMAMTVAL
####  fin   modif pour la valorisation



Local Integer I
Local Integer WVCRLIN
WVCRLIN = 1000
Local Integer WECR
Local Char    WTCM(GLONTCM)
Local Integer WRET
Local Char    WECCMAJ(GLONECS)
Local Char    WECCMIN(GLONEVL)
Raz WECR

If !clalev([M:SDP]) : Local Mask SAIDECPRI [SDP] : Endif
Raz [M:SDP],[M:SDPA]

# creation globale pour MBT il cumul la valo de la sortie
# michel teste l existence de cette variable si existe il cumul
For I = 0 To [M:BBY1]NBLIG-1
    If [M:BBY1]QTYSTU (I) <> 0
       Raz [F:SMD]
       [F:SMD]VCRLINPNT = 1
       [F:SMD]PNTMVTCOD = 0                # hcb 28649
       [F:SMD]VCRTYP    = [F:SMH]VCRTYP
       [F:SMD]VCRNUM    = [F:SMH]VCRNUM
       [F:SMD]VCRLIN    = [M:BBY1]VCRLIN    (I)
       [F:SMD]ITMREF    = [M:BBY1]ITMREF    (I)
       [F:SMD]ITMDES1   = [M:BBY1]ITMDES1   (I)
       [F:SMD]PCU       = [M:BBY1]PCU       (I)
       [F:SMD]QTYPCU    = [M:BBY1]QTYPCU    (I)
       [F:SMD]PCUSTUCOE = [M:BBY1]PCUSTUCOE (I)
       [F:SMD]STU       = [M:BBY1]STU       (I)
       [F:SMD]QTYSTU    = [M:BBY1]QTYSTU    (I)
       [F:SMD]QTYSTUORI = [M:BBY1]QTYSTU    (I)  # hcb 22993
       [F:SMD]QTYPCUORI = [M:BBY1]QTYPCU    (I)  # hcb 22993
#                                                   # hcb 71276 deb
       If dim([M:BBY1]ECCVALMAJ) > 0
          [F:SMD]ECCVALMAJ = [M:BBY1]ECCVALMAJ (I)
          [F:SMD]ECCVALMIN = [M:BBY1]ECCVALMIN (I)
       Endif
#                                                   # hcb 71276 fin

       # Alimentation dépôt ligne si renseigné
       If dim([M:BBY1]WRH)>0 & [M:BBY1]WRH(I)<>""
         [F:SMD]WRH = [M:BBY1]WRH(I)
       Else
         [F:SMD]WRH = ""
       Endif
       [F:SMD]LINTYP    = 2
       [F:SMD]BOMALT    = [M:BBY0]BOMALT
       [F:SMD]CREDAT    = date$
       [F:SMD]CREUSR    = GUSER
       #Local Integer Y                                                          # ana
       #For Y=1 To GOPTCANA
       #    Assign "[F:SMD]CCE"+num$(Y) With evalue("[M:BBY1]CCE"+num$(Y)+"(I)")
       #Next
       If [M:BBY1]STOMGTCOD (I)  > 1                 # hcb 28654
          Call ALISTWSOR (I) From SUBBBYA
####  début modif pour la valorisation


####  fin   modif pour la valorisation
# valorisation de la sortie
          If [F:SMD]PRIORD = 0
             If [F:SMD]QTYSTU <> 0
                [F:SMD]PRIORD = [M:STW]ISSAMTVAL / [F:SMD]QTYSTU
                [M:BBY1]PRIORD    (I) =  [F:SMD]PRIORD                # hcb 28654
             Endif
          Endif

       Else                                                           # hcb 28654
          [F:SMD]PRIORD   = [M:BBY1]PRIORD  (I)                       # hcb 28654
          If [M:BBY1]PRIORD(I)=0
             Call GETTCM([F:SMD]ITMREF, [M:BBY0]STOFCY, WTCM, WRET) From STKVAL
             If WTCM<>"" & find([F:TCM]ISSVLTCOD,1,2)
                Raz WECCMAJ, WECCMIN
                If dim([M:BBY0]ECCVALMAJ)>0
                    # only one version is possible here
                    WECCMAJ = [M:BBY0]ECCVALMAJ
                    WECCMIN = [M:BBY0]ECCVALMIN
                Endif
                Call GETPRI([F:SMD]ITMREF,WECCMAJ,WECCMIN,[M:BBY0]STOFCY,[M:BBY0]IPTDAT,[M:BBY1]QTYSTU(I),
&                           "","",[F:TCM]ISSVLTCOD,[F:SMD]PRIORD,WRET) From STKVAL
                If WRET
                   GOK = 0
                   Break
                Endif
             Endif
          Endif
          # Issue 94486 - 2015-02-04 by CCC
          #GSTK_CUMAMTVAL += [F:SMD]PRIORD  * [M:BBY0]QTYSTU(nolign-1) # hcb 28654
          GSTK_CUMAMTVAL += [F:SMD]PRIORD  * [M:BBY1]QTYSTU(I) # hcb 28654

          If [F:ITM]ITMREF<>[M:BBY1]ITMREF(I)
              Read [ITM]ITM0 = [M:BBY1]ITMREF(I)
          Endif
          If fstat
            GOK = 0
            Call FSTA("ITM") From GLOCK
            Break
          Endif

          # Issue 94486 - 2015-02-04 by CCC
          #[M:SDPA]MATCST([F:ITM]BRDCOD-1) += [F:SMD]PRIORD  * [M:BBY0]QTYSTU(nolign-1)
          [M:SDPA]MATCST([F:ITM]BRDCOD-1) += [F:SMD]PRIORD  * [M:BBY1]QTYSTU(I)
       Endif                                                          # hcb 28654

       Write [SMD]
       If fstat
          GOK = 0
          Call FSTA("SMD") From GLOCK
          Break
       Endif
       WECR = 1
       #----- Ecriture des comptes et sections analytiques de la ligne du composant -----#    # hcb X3-43867 (remplacement nolign-1 par I)
       Call ENREG_ACCCCE(I,"","","[M:BBY1]CCE","SMD",
&                        [F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"",TRTLIG) From TRTX3CPT
       If GOK<1  Return : Endif
       #-----
    Endif
Next
# si pas de detail d ecrit GOK = 0
If WECR = 0
    GOK = 0
    Call ERREUR(mess(89,184,1)) From GESECRAN  # Création impossible ! Aucune ligne de  composant n' est valide ...
Endif
####  début modif pour la valorisation
If [M:BBY0]PRIORD(nolign-1) = 0
    If [M:BBY0]QTYSTU(nolign-1) <> 0
       # Issue X3-25079 - 2017-02-24 by ERMIL : Transmask performance changes
       #[M:SDP] = [M:SDPA] : Raz [M:SDPA]
       Raz [M:SDP]
       Transmask [M:SDPA] To [M:SDP]
       Raz [M:SDPA]

       Gosub CAL_TOT From SUBSDP    # PRI = somme des composantes
       [M:SDP]AMTTOT = [M:SDP]PRI
       [M:SDP]PRI /= [M:BBY0]QTYSTU(nolign-1)
       Call PROSDP("SDP",1/[M:BBY0]QTYSTU(nolign-1)) From SUBSDPCOM

       [M:BBY0]PRIORD(nolign-1) = [M:SDP]PRI
       Call COPSDP2VALW(0,"VALW","SDP") From SUBSDPCOM
       [M:VALW]WSTOSEQ(0) = [M:BBY0]WSTOSEQ(0)
       # Issue 64988 - 2010-05-26 by CCC
       [M:VALW]NBLIG=1
   Endif
    [M:BBY0]UPDPRI(nolign-1) = 1
Else
    [M:BBY0]UPDPRI(nolign-1) = 2
Endif
[M:BBY0]CFMFLG  = 2
[F:SMH]CFMFLG =   2
Gosub CREATION From TABLEAUX
Kill GSTK_CUMAMTVAL
####  fin   modif pour la valorisation

Return

$MODIF
Global Decimal GSTK_CUMAMTVAL
Raz GSTK_CUMAMTVAL
# hcb 28654 deb
Global Decimal GSTK_NONGERE
Raz GSTK_NONGERE
Local Decimal   LDELTA_AMT  # Différence de montant sur composé
Local Decimal   WCNVRPT    # Taux de conversion devise société vers devise dossier
Local Char      WTCM(GLONTCM)
Local Integer   WRET
# hcb 28654 fin
Local Char    WECCMAJ(GLONECS)
Local Char    WECCMIN(GLONEVL)

#Gosub MODIF From TABLEAUX                      # hcb 28654

#annulation des lignes de composants
Delete [F:SMD] Where VCRTYP     = [F:SMH]VCRTYP      &
&                    VCRNUM     = [F:SMH]VCRNUM    &
&                    LINTYP     = 2

#annulation des sections lignes de composants
Delete [F:CAL] Where VCRTYP     = [F:SMH]VCRTYP      &
&                    VCRNUM     = [F:SMH]VCRNUM      &
&                    VCRLIN     <> 1                 &
&                    ABRFIC     = "SMD"

# creation des lignes de composants
Local Integer I
Local Integer WVCRLIN
WVCRLIN = 1000

If !clalev([M:SDP]) : Local Mask SAIDECPRI [SDP] : Endif
Raz [M:SDP],[M:SDPA]

For I = 0 To [M:BBY1]NBLIG-1
    If [M:BBY1]QTYSTU <> 0
       Raz [F:SMD]PRIORD
       Raz [F:SMD]
       [F:SMD]VCRLINPNT = 1
       [F:SMD]PNTMVTCOD = 0                      # hcb 28649
       [F:SMD]VCRTYP    = [F:SMH]VCRTYP
       [F:SMD]VCRNUM    = [F:SMH]VCRNUM
       [F:SMD]VCRLIN    = [M:BBY1]VCRLIN    (I)
       [F:SMD]VCRTYPORI = [M:BBY1]VCRTYPORI (I)
       [F:SMD]VCRNUMORI = [M:BBY1]VCRNUMORI (I)
       [F:SMD]VCRLINORI = [M:BBY1]VCRLINORI (I)
       [F:SMD]QTYPCUORI = [M:BBY1]QTYPCUORI (I)  # hcb 22993
       [F:SMD]QTYSTUORI = [M:BBY1]QTYSTUORI (I)  # hcb 22993
#                                                   # hcb 71276 deb
       If dim([M:BBY1]ECCVALMAJ) > 0
          [F:SMD]ECCVALMAJ = [M:BBY1]ECCVALMAJ (I)
          [F:SMD]ECCVALMIN = [M:BBY1]ECCVALMIN (I)
       Endif
#                                                   # hcb 71276 fin
       [F:SMD]ITMREF    = [M:BBY1]ITMREF    (I)
       [F:SMD]PRIORD    = [M:BBY1]PRIORD    (I)
       [F:SMD]ITMDES1   = [M:BBY1]ITMDES1   (I)
       [F:SMD]PCU       = [M:BBY1]PCU       (I)
       [F:SMD]QTYPCU    = [M:BBY1]QTYPCU    (I)
       [F:SMD]PCUSTUCOE = [M:BBY1]PCUSTUCOE (I)
       [F:SMD]STU       = [M:BBY1]STU       (I)
       [F:SMD]QTYSTU    = [M:BBY1]QTYSTU    (I)
       [F:SMD]LINTYP    = 2
       [F:SMD]BOMALT    = [M:BBY0]BOMALT
       [F:SMD]CREDAT    = date$
       [F:SMD]CREUSR    = GUSER
#       Local Integer Y                                               # ana
#       For Y=1 To GOPTCANA
#           Assign "[F:SMD]CCE"+num$(Y) With evalue("[M:BBY1]CCE"+num$(Y)+"(I)")
#       Next
       Raz LDELTA_AMT
       If [M:BBY1]CREFLG(I) = 0
          If [M:BBY1]STOMGTCOD (I)  > 1          # hcb 28654
             Call ALISTWSOR (I) From SUBBBYA
             GSTK_CUMAMTVAL += [M:STW]ISSAMTVAL  # hcb 28654

# valorisation de la sortie
             If [F:SMD]PRIORD = 0
                If [F:SMD]QTYSTU <> 0
                   [F:SMD]PRIORD = [M:STW]ISSAMTVAL / [F:SMD]QTYSTU
                   [M:BBY1]PRIORD    (I) =  [F:SMD]PRIORD                # hcb 28654
                Endif
             Endif
          Else
              [F:SMD]PRIORD   = [M:BBY1]PRIORD  (I)                       # hcb 28654
              If [M:BBY1]PRIORD(I)=0
                 Call GETTCM([F:SMD]ITMREF, [M:BBY0]STOFCY, WTCM, WRET) From STKVAL
                 If WTCM<>"" & find([F:TCM]ISSVLTCOD,1,2)
                Raz WECCMAJ, WECCMIN
                If dim([M:BBY0]ECCVALMAJ)>0
                    # only one version is possible here
                    WECCMAJ = [M:BBY0]ECCVALMAJ
                    WECCMIN = [M:BBY0]ECCVALMIN
                Endif
                    Call GETPRI([F:SMD]ITMREF,WECCMAJ,WECCMIN,[M:BBY0]STOFCY,[M:BBY0]IPTDAT,[M:BBY1]QTYSTU(I),
&                               "","",[F:TCM]ISSVLTCOD,[F:SMD]PRIORD,WRET) From STKVAL
                    If WRET
                       GOK = 0
                       Break
                    Endif
                 Endif
              Endif
              LDELTA_AMT = [F:SMD]PRIORD  * [M:BBY1]QTYSTU(I)            # hcb 28654
          Endif                                                          # hcb 28654
       Else
          [F:SMD]PRIORD   = [M:BBY1]PRIORD  (I)
          If [M:BBY1]QTYSTU (I) <> [M:BBY1]QTYSTU_AV (I) | [M:BBY1]PRIORD (I) <> [M:BBY1]PRIORD_AV (I)
             LDELTA_AMT   = ([M:BBY1]PRIORD (I) * [M:BBY1]QTYSTU (I) - [M:BBY1]PRIORD_AV (I) * [M:BBY1]QTYSTU_AV (I))
          Endif
       Endif
       Write [SMD]
       If fstat
          GOK = 0
          Call FSTA("SMD") From GLOCK
          Break
       Endif
       #----- Ecriture des comptes et sections analytiques de la ligne du composant -----#
       Call ENREG_ACCCCE(nolign-1,"","","[M:BBY1]CCE","SMD",
&                        [F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"",TRTLIG) From TRTX3CPT
       If GOK<1  Return : Endif
       #-----
       GSTK_NONGERE += LDELTA_AMT
        If [F:ITM]ITMREF<>[M:BBY1]ITMREF(I)
            Read [ITM]ITM0 = [M:BBY1]ITMREF(I)
        Endif
        If fstat
          GOK = 0
          Call FSTA("ITM") From GLOCK
          Break
        Endif

        [M:SDP]PRI   += LDELTA_AMT
        [M:SDP]QTY    = 0    # On passe un delta
        [M:SDP]AMTTOT+= LDELTA_AMT

        [M:SDP]MATCST([F:ITM]BRDCOD-1)  += LDELTA_AMT
        [M:SDPA]MATCST([F:ITM]BRDCOD-1) += LDELTA_AMT
    Endif
Next

# hcb 28654 deb
If [M:BBY0]UPDPRI(0)=1    # Si le prix a été calculé on met à jour les mouvements et la ligne de doc du composé
    If GSTK_NONGERE <> 0
       If [M:BBY0]PNTMVTCOD <> 1
           Call CONVERT2(GLOCALDEV,GSYSCUR,GLOCALDEV,GCHGTYP,[M:BBY0]IPTDAT,
&                        1,WCNVRPT,WRET) From TRTDEV

           Call REGPRIX([M:BBY0]STOFCY, 1, [M:BBY0]ITMREF(0), [M:BBY0]IPTDAT,
&                       [M:BBY0]TRSCOD, [M:BBY0]VCRTYP, [M:BBY0]VCRNUM , 1,
&                       [M:BBY0]VCRTYP, [M:BBY0]VCRNUM, [M:BBY0]VCRLIN(0), WCNVRPT,
&                       WRET) From STKVALREG
           If WRET
              Call ERREUR([M:BBY0]VCRNUM-mess(519,197,1)-"("+num$(WRET)+")") From GESECRAN
              GOK=0
              Return
           Endif
        Endif
        GSTK_CUMAMTVAL += GSTK_NONGERE
    Endif

    If [M:BBY0]QTYSTU(0)<>0
        # Issue X3-25079 - 2017-02-24 by ERMIL : Transmask performance changes
        #[M:SDP] = [M:SDPA] : Raz [M:SDPA]
        # Make sure line number variables populated prior to Transmask
        If dim([M:SDPA]NBMAT)>0 : [M:SDPA]NBMAT=GACTMAT+1 : Endif
        If dim([M:SDPA]NBMAC)>0 : [M:SDPA]NBMAC=GACTMAC+1 : Endif
        If dim([M:SDPA]NBLAB)>0 : [M:SDPA]NBLAB=GACTLAB+1 : Endif
        Raz [M:SDP]
        Transmask [M:SDPA] To [M:SDP]
        Raz [M:SDPA]

        Gosub CAL_TOT From SUBSDP
        [M:BBY0]PRIORD(0) += [M:SDP]PRI/[M:BBY0]QTYSTU(0)
    Endif
    If [M:BBY0]UPDFLG(0)=0
       Readlock [SMD]SMD0=31;[M:BBY0]VCRNUM;1
       If fstat = 1
          GOK = -1
          GLOCK = "$SMVTD"-[M:BBY0]VCRNUM-num$(1)
          Return
       Elsif fstat
          GOK =  0
          Call RSTA ("SMD",[M:BBY0]VCRNUM-num$(1)) From GLOCK
          Return
       Endif
       [F:SMD]PRIORD =  [M:BBY0]PRIORD(0)
       Rewrite [SMD]
       If fstat
          GOK=0
          Call FSTA("SMD") From GLOCK
       Endif
    Endif
Endif

If [M:BBY0]UPDFLG(0) <> 0
   Gosub MODIF From TABLEAUX
Endif

Kill GSTK_NONGERE
# hcb 28654 fin

Kill GSTK_CUMAMTVAL

Return

$ANNULE
    Gosub ANNULE From TABLEAUX
Return

$INICRE_LIG
[F:SMD]VCRTYP    = [F:SMH]VCRTYP
[F:SMD]VCRNUM    = [F:SMH]VCRNUM
[F:SMD]LINTYP    = 1                    # Composé
[F:SMD]VCRLIN    = 1                    # on force a 1
[F:SMD]PNTMVTCOD = [M:BBY0]PNTMVTCOD     # hcb 50197

[F:SMD]QTYPCUORI = [F:SMD]QTYPCU        # hcb 22993
[F:SMD]QTYSTUORI = [F:SMD]QTYSTU        # hcb 22993
# Alimentation dépôt ligne si renseigné
If dim([M:BBY0]WRH)>0 & [M:BBY0]WRH(nolign-1)<>""
  [F:SMD]WRH = [M:BBY0]WRH(nolign-1)
Else
  [F:SMD]WRH = ""
Endif

Return

$INIMOD_LIG                             # hcb 22993
[F:SMD]QTYPCUORI = [F:SMD]QTYPCU        # hcb 22993
[F:SMD]QTYSTUORI = [F:SMD]QTYSTU        # hcb 22993
Return                                  # hcb 22993

$VALLIG
If [M:BBY0]PNTMVTCOD <> 1               # hcb 28649
   If SIGN=1
      Call ALISTW (nolign-1) From SUBBBYA
   Endif
# maj section composé
   #----- Ecriture des comptes et sections analytiques de la ligne du composé -----#
   Call ENREG_ACCCCE(nolign-1,"","","[M:BBY0]CCE","SMD",
&                    [F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"",TRTLIG) From TRTX3CPT
   If GOK<1  Return : Endif
   #-----
Endif                                   # hcb 28649

Return

$APRES_CRE
Gosub APRES_ENR
Return

$APRES_MOD
Gosub APRES_ENR
Return

$APRES_ENR
    Local Integer LRET
    Call STKDELRES(0,[M:BBY0]STOFCY,"",LRET) From STKLOC
    #----- Relecture transaction de saisie  -----#
    If [F:SRT]SRTTYP <> 7 | [F:SRT]SRTNUM <> GBBYNUM                   # hcb 50197
       Read [SRT]SRT0=7;GBBYNUM : If fstat Raz [F:SRT] : Endif
    Endif

    #--- Impression des étiquettes ----#
    If [F:SRT]PRNCOD1 > 1
        Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
        WPARAM(1) = [M:BBY0]STOFCY
        WPARAM(2) = num$([M:BBY0]VCRTYP)
        WPARAM(3) = [M:BBY0]VCRNUM
        WPARAM(4) = [M:BBY0]VCRNUM
        Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
    Endif

    #---- Régularisation des mouvements et alloc -----#
    Call REGFROMENT( 0, "BBY0", "[M:BBY0]CREFLG(I)=0", "ITMREF", [M:BBY0]STOFCY ) From TRTSHTCOM

    Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC

    Gosub LIENS
Return

$AB_CREATION
    Effzo [M:BBY0]VCRNUM
    If !GIMPORT & GTRACE<>""
        Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
    Endif
Return

$AB_MODIF
    If !GIMPORT & GTRACE<>""
        Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
    Endif
Return

$APRES_MODIF
    If GRELITSMR
        Gosub RELIT From GOBJSUB
        Raz GRELITSMR
        OK=0
    Endif
Return

$ABANDON
Local Integer WRET

    Actzo [M:BBY0]VCRNUM
    Call DELSTOENTW(-1,-1,"BBY0",1,1,[M:BBY0]STOFCY,1,"") From STKENT
    Call DELSTOSORW(-1,-1,"BBY1",[M:BBY0]STOFCY,WRET) From STKSOR
Return

$FERME
Raz GORITITCOL                                         # Ana

# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDATBBY) > 0
   Kill GCTRDATBBY
Endif
If GCONSULT <> 2                       # hcb 22993
   If dim(GRELITSMR) > 0
      Kill GRELITSMR
   Endif
Endif                                  # hcb 22993

#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB

Return




#########################################################################
# CHARG_PARAM_STOENT           chargement blocs entete parametrage STOENT
#########################################################################

Subprog CHARG_PARAM_STOENT(LLIG)
Value    Integer LLIG
Variable Integer LRET
[M:ENT]STOFCY    = [M:BBY0]STOFCY
[M:ENT]ITMREF    = [M:BBY0]ITMREF    (LLIG)
[M:ENT]QTYTOENT  = [M:BBY0]QTYPCU    (LLIG)
[M:ENT]PCUTOENT  = [M:BBY0]PCU       (LLIG)
[M:ENT]COETOENT  = [M:BBY0]PCUSTUCOE (LLIG)
[M:ENT]STU       = [M:BBY0]STU       (LLIG)
[M:ENT]VCRTYP    = 31
[M:ENT]VCRNUM    = [M:BBY0]VCRNUM
[M:ENT]VCRLIN    = [M:BBY0]VCRLIN    (LLIG)
[M:ENT]WSTOSEQ   = [M:BBY0]WSTOSEQ   (LLIG)
[M:ENT]MVTDES    = [M:BBY0]MVTDES    (LLIG)
#M:ENT]PRI       = [M:BBY0]PRIORD    (LLIG)
[M:ENT]QUAFLG    = [M:BBY0]QUAFLG    (LLIG)       # hcb V6CQ
[M:ENT]QUAFRE    = [M:BBY0]QUAFRE    (LLIG)       # hcb V6CQ
If dim([M:BBY0]WRH)>0
  [M:ENT]XWRH    = [M:BBY0]WRH(LLIG)
Endif
[M:ENT]TRSTYP    = 1
#                                                              # hcb 71276 deb
If dim([M:BBY0]ECCVALMAJORI)>0
   [M:ENT]ECCVALMAJORI  = [M:BBY0]ECCVALMAJORI(LLIG)   # version majeure origine
   [M:ENT]ECCVALMINORI  = [M:BBY0]ECCVALMINORI(LLIG)   # version mineure origine
   [M:ENT]ECCBOMFLG     = [M:BBY0]ECCSAIFLG   (LLIG)# origine nomenclature
Endif
[M:ENT]TYPBPR    = 1
#                                                          # hcb 71276 fin
[M:ENT]TRSCOD    = [M:BBY0]TRSCOD     # code mouvement
[M:ENT]TRSFAM    = [M:BBY0]TRSFAM     # famille mouvement
[M:ENT]IPTDAT    = [M:BBY0]IPTDAT     # date imputation
[M:ENT]CUR       = GLOCALDEV
[M:ENT]BPRNUM    = ""
[M:ENT]CCECODS   = [F:DTR]STOCCECOD

End

#########################################################################
# CHARG_PARAM_STOENTM         chargement blocs entete parametrage STOENTM
#########################################################################

Subprog CHARG_PARAM_STOENTM(LLIG)
Value Integer LLIG

[M:ENM]STOFCY    = [M:BBY0]STOFCY
[M:ENM]ITMREF    = [M:BBY0]ITMREF    (LLIG)
[M:ENM]QTYTOENT  = [M:BBY0]QTYPCU    (LLIG)
[M:ENM]PCUTOENT  = [M:BBY0]PCU       (LLIG)
[M:ENM]COETOENT  = [M:BBY0]PCUSTUCOE (LLIG)
[M:ENM]STU       = [M:BBY0]STU       (LLIG)
[M:ENM]VCRNUM    = [M:BBY0]VCRNUM
[M:ENM]VCRLIN    = [M:BBY0]VCRLIN    (LLIG)
[M:ENM]MVTDES    = [M:BBY0]MVTDES    (LLIG)
[M:ENM]QUAFLG    = [M:BBY0]QUAFLG    (LLIG)       # hcb V6CQ
[M:ENM]QUAFRE    = [M:BBY0]QUAFRE    (LLIG)       # hcb V6CQ
If dim([M:BBY0]WRH)>0
  [M:ENM]XWRH    = [M:BBY0]WRH(LLIG)
Endif
[M:ENM]PJT       = [M:BBY0]PJT
[M:ENM]TRSTYP    = 1                        # entree diverse
[M:ENM]TRSCOD    = [M:BBY0]TRSCOD           # code mouvement
[M:ENM]TRSFAM    = [M:BBY0]TRSFAM           # famille mouvement
[M:ENM]IPTDAT    = [M:BBY0]IPTDAT           # date imputation
[M:ENM]UPDPRI    = [M:BBY0]UPDPRI(LLIG)     # Prix saisi ou calculé
#                                                              # hcb 71276 deb
If dim([M:BBY0]ECCVALMAJORI)>0
   [M:ENM]ECCVALMAJORI  = [M:BBY0]ECCVALMAJORI(LLIG)   # version majeure origine
   [M:ENM]ECCVALMINORI  = [M:BBY0]ECCVALMINORI(LLIG)   # version mineure origine
   [M:ENM]ECCBOMFLG     = [M:BBY0]ECCSAIFLG   (LLIG)   # origine nomenclature
Endif
[M:ENM]TYPBPR    = 1
#                                                          # hcb 71276 fin

End

########################################################################
# MAJ_LIGNE_DOCUMENT          Mise à jour des quantités entrée SAISTOENT
########################################################################
$MAJ_LIGNE_DOCUMENT
# Vérifie que le coefficient UC/US peut être modifié,
# que le coef est unique (>0)
# et que l'unité est unique
[M:BBY0]QTYSTU(LLIGDOC) = LQTYSTU
If  LCOEF>0 & LPCU<>""
    [M:BBY0]PCU(LLIGDOC)       = LPCU
    [M:BBY0]PCUSTUCOE(LLIGDOC) = LCOEF
    [M:BBY0]QTYPCU(LLIGDOC)    = LQTYSTU / LCOEF
Else    # Met tout en US
    [M:BBY0]PCU(LLIGDOC)       = [M:BBY0]STU(LLIGDOC)
    [M:BBY0]PCUSTUCOE(LLIGDOC) = 1
    [M:BBY0]QTYPCU(LLIGDOC)    = LQTYSTU
Endif
Affzo [M:BBY0]QTYSTU(LLIGDOC), PCU(LLIGDOC), QTYPCU(LLIGDOC), PCUSTUCOE(LLIGDOC)

Return

########################################################################
# CTL_BBY0                      Controle des quantités entrée SAISTOENTM
########################################################################
$CTL_BBY0
#-- Contrôle à faire en creation document uniquement
# si quantite differente il faut repercuter sur les composants
If [M:BBY0]CREFLG(LLIGDOC) = 0
   If [M:ENT]PECQTY<>[M:ENT]QTYTOENT
      GMODIF = 2
   Endif
Endif



# quantite totale à zero interdit
#-- Contrôle à faire en modif document uniquement
If [M:BBY0]CREFLG(LLIGDOC)<>0
   If LQTYSTU = 0
       GMESSAGE=mess(9,184,1)
       mkstat=2
    Endif
Endif
If mkstat
   Call ERREUR(GMESSAGE) From GESECRAN
   GMESSAGE= ""
Endif
Return

########################################################################
# TRT_MAJ_DOCUMENT            Mise à jour des quantités sortie SAISTOENT
########################################################################
$TRT_MAJ_DOCUMENT
Local Integer LOK

# Mise à jour des quantités
Gosub MAJ_LIGNE_DOCUMENT

#-- Maj du détail entrées
# 1- Locker l'enregistrement de la ligne de document
Readlock [SMD]SMD0=[M:BBY0]VCRTYP;[M:BBY0]VCRNUM;[M:BBY0]VCRLIN(LLIGDOC)
If fstat = 1
   GOK = -1
   GLOCK = "$SMVTD"-[M:BBY0]VCRNUM-num$([M:BBY0]VCRLIN(LLIGDOC))
   Return
Elsif fstat
   GOK =  0
   Call RSTA ("SMD",[M:BBY0]VCRNUM-num$([M:BBY0]VCRLIN(LLIGDOC))) From GLOCK
   Return
Endif

# 3- Si la nouvelle quantité n'est pas nulle enregistrer cette nouvelle quantité
[F:SMD]QTYPCU    = [M:BBY0]QTYPCU (LLIGDOC)
[F:SMD]QTYSTU    = [M:BBY0]QTYSTU (LLIGDOC)

[F:SMD]QTYPCUORI = [F:SMD]QTYPCU        # hcb 22993
[F:SMD]QTYSTUORI = [F:SMD]QTYSTU        # hcb 22993

Rewrite [SMD]

# 4- Délocker l'enregistrement
If fstat
    GOK=0
    Call FSTA("SMD") From GLOCK
    Return
Endif

GRELITSMR = 1

Return

################################################
# Alimente le masque STOWORK entré
# Ce sous programme est à appeler sur les actions:
#    VALLIG
################################################
Subprog ALISTW( NOL )
Value Integer NOL

Local Decimal LQTA
Local Decimal LSHT
Local Integer LRET
Local Integer LNBR, LNBJ

# Initialisation de l'en-tête
Raz [M:STW]
[M:STW]STOFCY     = [M:BBY0]STOFCY      # Site
[M:STW]TRSTYP     = [M:BBY0]TRSTYP      # Type mouvement (M.704)
[M:STW]VCRTYP     = [M:BBY0]VCRTYP      # Type pièce (M.701)
[M:STW]VCRNUM     = [M:BBY0]VCRNUM      # Numéro pièce
[M:STW]VCRLIN     = [M:BBY0]VCRLIN(NOL) # Numero ligne pièce
[M:STW]ITMREF     = [M:BBY0]ITMREF(NOL) # Article
[M:STW]MVTDES     = [M:BBY0]MVTDES(NOL) # Désignation mouvement
[M:STW]PRIORDH    = [M:BBY0]PRIORD(NOL) # Prix de l'ordre
[M:STW]PJT        = [M:BBY0]PJT         # Affaire
[M:STW]TRSFAM     = [M:BBY0]TRSFAM      # Famille mouvement
[M:STW]ENTCOD     = [M:BBY0]ENTCOD      # Famille mouvement
[M:STW]IPTDAT     = [M:BBY0]IPTDAT      # Date imputation
[M:STW]TRSCOD     = [M:BBY0]TRSCOD      # Code mouvement
[M:STW]CCECOD     = "STJEND"            # CODE section analytique stock entrée
[M:STW]CUR       = GLOCALDEV
[M:STW]BPRNUM    = ""

Call ALISTOWORK( 2, [M:BBY0]WSTOSEQ(NOL), LQTA, LSHT, LNBR, LNBJ, LRET ) From STKINT
If LRET<>0 End Endif

Call MAJ_STOCK From STKMAJ
If GOK
   Call STKFREQCQ("BBY0",[M:BBY0]STOFCY,NOL,[M:BBY0]ITMREF(NOL),"","V",[M:BBY0]QUAFLG(NOL),0) From STKACT   # hcb V6CQ (freq)
Endif

End

########################################################################
# ECRAN BBY1   Composants Sortie
########################################################################


#########################################################################
# Chargement du masque de paramétrage pour composants stock             #
#########################################################################
$ALI_ALP

[M:ALP]TRSTYP     = [M:BBY0]TRSTYPC
[M:ALP]TRSCOD     = [M:BBY0]TRSCOD
[M:ALP]VCRTYP     = 31
[M:ALP]STOFCY     = [M:BBY0]STOFCY
[M:ALP]ITMREF     = [M:BBY1]ITMREF(NOL)
[M:ALP]PCU        = [M:BBY1]PCU(NOL)
[M:ALP]PCUSTUCOE  = [M:BBY1]PCUSTUCOE(NOL)
[M:ALP]QTY        = [M:BBY1]QTYSTU(NOL)
[M:ALP]TYPQTY     = 2
[M:ALP]BESDAT     = [M:BBY0]IPTDAT
[M:ALP]DLVDAT     = [M:BBY0]IPTDAT
Raz [M:ALP]ALLDAT
Raz [M:ALP]STOLOC
[M:ALP]PECINTLOC  = 2
[M:ALP]PECSCOLOC  = 1
[M:ALP]PECPLFLOC  = 2
[M:ALP]PECCUNLOK  = 1
[M:ALP]PECOWNER   = ""
Raz [M:ALP]FILSTO
#--- Bug 90028
Raz [M:ALP]ALLQTY

If dim([M:BBY1]LOT) > 0
   [M:ALP]LOT        = [M:BBY1]LOT(NOL)
Endif
If dim([M:BBY1]LOC) > 0
   [M:ALP]LOC        = [M:BBY1]LOC(NOL)
Endif
[M:ALP]STA        = [M:BBY1]STA(NOL)
[M:ALP]PECQLYCTL  = 1
If dim([M:BBY1]WRH)>0 [M:ALP]WRH=[M:BBY1]WRH(NOL) Endif
If dim([M:BBY1]ECCVALMAJ)>0 [M:ALP]ECCVALMAJ=[M:BBY1]ECCVALMAJ(NOL) Endif      # hcb 71276

Return

################################################
# Alimente le masque STOWORK sortie
################################################
Subprog ALISTWSOR( NOL )
Value Integer NOL  # FGR 01/02/2010 : X3SUIVI60986

Local Integer WRET
Local Decimal LQTA
Local Decimal LSHT
Local Integer LRET
Local Integer LNBR, LNBJ

# Initialisation de l'en-tête
[M:STW]STOFCY     = [M:BBY0]STOFCY      # Site
[M:STW]TRSTYP     = [M:BBY0]TRSTYPC     # Type mouvement (M.704)
[M:STW]VCRTYP     = [M:BBY0]VCRTYP      # Type pièce (M.701)
[M:STW]VCRNUM     = [M:BBY0]VCRNUM      # Numéro pièce
[M:STW]VCRLIN     = [M:BBY1]VCRLIN(NOL) # Numero ligne pièce
[M:STW]ITMREF     = [M:BBY1]ITMREF(NOL) # Article
[M:STW]MVTDES     = [M:BBY1]MVTDES(NOL) # Désignation mouvement
[M:STW]PRIORDH    = 0
[M:STW]PJT        = [M:BBY0]PJT         # Affaire
[M:STW]TRSFAM     = [M:BBY0]TRSFAM      # Famille mouvement
[M:STW]ENTCOD     = [M:BBY0]ENTCOD      # Famille mouvement
[M:STW]IPTDAT     = [M:BBY0]IPTDAT      # Date imputation
[M:STW]TRSCOD     = [M:BBY0]TRSCOD      # Code mouvement
[M:STW]CCECOD     = "STJSOR"            # CODE section analytique stock sortie
[M:STW]CUR       = GLOCALDEV
[M:STW]BPRNUM    = ""

Call ALISTOWORK( 3, [M:BBY1]WSTOSEQ(NOL), LQTA, LSHT, LNBR, LNBJ, WRET ) From STKINT
If WRET<>0
   GOK = 0
   End
Endif

Call MAJ_STOCK From STKMAJ


End




#########################################################################
$CHARGE_STOSOR
#-----------------------------------------------------------------------#
# Chargement des paramètres dans masque STOSOR pour saisie des sorties  #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSORA       #
#-----------------------------------------------------------------------#
[M:SOR]WSTOSEQ   = [M:BBY1]WSTOSEQ(LNOL)
[M:SOR]TRSTYP    = [M:BBY0]TRSTYPC
[M:SOR]TRSCOD    = [M:BBY0]TRSCOD
[M:SOR]TRFFCY    = ""
[M:SOR]VCRTYP    = 31
[M:SOR]VCRNUM    = [M:BBY0]VCRNUM
[M:SOR]VCRLIN    = [M:BBY1]VCRLIN(LNOL)
[M:SOR]MVTDES    = [M:BBY1]MVTDES(LNOL)
[M:SOR]STU       = [M:BBY1]STU(LNOL)
[M:SOR]PCU       = [M:BBY1]PCU(LNOL)
[M:SOR]PCUSTUCOE = [M:BBY1]PCUSTUCOE(LNOL)
[M:SOR]SORQTY    = [M:BBY1]QTYSTU(LNOL)
[M:SOR]SORQTYACT = [M:BBY1]QTYSTU(LNOL)
[M:SOR]RETDAT    = [M:BBY0]IPTDAT
[M:SOR]DLVDAT    = [M:BBY0]IPTDAT
[M:SOR]PECINTLOC = 2
[M:SOR]PECPLFLOC = 2
[M:SOR]PECSCOLOC = 1
[M:SOR]PECQLYCTL = 1

[M:SOR]STOLOC    = ""
[M:SOR]XLOT      = ""
[M:SOR]XLOC      = ""
[M:SOR]XSTA      = ""
[M:SOR]CUR       = GLOCALDEV
[M:SOR]BPRNUM    = ""
[M:SOR]GLOALLQTY = 0
If dim([M:BBY1]WRH)>0 [M:SOR]XWRH=[M:BBY1]WRH(LNOL) Endif
If dim([M:BBY1]ECCVALMAJ)>0 [M:SOR]WECCVALMAJ=[M:BBY1]ECCVALMAJ(LNOL) Endif            # hcb 71276

Return

#########################################################################

$CHARGE_STOSOM
#-----------------------------------------------------------------------#
# Chargement des paramètres dans masque STOSOM pour modification des    #
# sorties                                                               #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSOMA       #
#-----------------------------------------------------------------------#

[M:SOM]TRSTYP    = [M:BBY0]TRSTYPC
[M:SOM]TRSCOD    = [M:BBY0]TRSCOD
[M:SOM]TRFFCY    = ""
[M:SOM]VCRTYP    = 31
[M:SOM]VCRNUM    = [M:BBY0]VCRNUM
[M:SOM]VCRLIN    = [M:BBY1]VCRLIN(LNOL)
[M:SOM]STU       = [M:BBY1]STU(LNOL)
[M:SOM]PCU       = [M:BBY1]PCU(LNOL)
[M:SOM]PCUSTUCOE = [M:BBY1]PCUSTUCOE(LNOL)
[M:SOM]SORQTY    = [M:BBY1]QTYSTU(LNOL)
[M:SOM]SORQTYACT = [M:BBY1]QTYSTU(LNOL)
[M:SOM]DLVDAT    = [M:BBY0]IPTDAT
[M:SOM]PECINTLOC = 2
[M:SOM]PECPLFLOC = 2
[M:SOM]PECSCOLOC = 1
[M:SOM]PECQLYCTL = 1
[M:SOM]STOLOC    = ""
[M:SOM]XLOT      = ""
[M:SOM]XLOC      = ""
[M:SOM]XSTA      = ""
If dim([M:BBY1]WRH)>0 [M:SOM]XWRH=[M:BBY1]WRH(LNOL) Endif
If dim([M:BBY1]ECCVALMAJ)>0 [M:SOM]WECCVALMAJ= [M:BBY1]ECCVALMAJ(LNOL) Endif                       # hcb 71276

Return





#########################################################################
$APRES_STOSOR
#-----------------------------------------------------------------------#
# Mise à jour complémentaires après enregistrement
# - Recalcul des quantités sorties US, UC de la ligne de document
# - Réalimentation des zones dépendant de la quantité
# - Coloriage de la ligne document si la quantité est nulle
# - etc ...
#-----------------------------------------------------------------------#
#   [M:SOR]NBLIG     contient le nombre de ligne de stock traité
#   [M:SOR]SORQTY    contient la quantité US qui était à sortir
#   [M:SOR]SORQTYACT contient la quantité en UA qui était à sortir
#   [M:SOR]PECQTY    contient la quantité US sortie
#   [M:SOR]PECQTYACT contient la quantité en UA sortie
#   [M:SOR]SHTQTY    contient la quantité US sortie manquante
#   [M:SOR]SHTQTYACT contient la quantité en UA sortie manquante

If WGENR=1
    [M:BBY1]QTYSTU(LNOL) = [M:SOR]PECQTYACT+[M:SOR]SHTQTY
    If [M:BBY1]PCUSTUCOE(LNOL)=0
        [M:BBY1]PCUSTUCOE(LNOL)=1
    Endif
    [M:BBY1]QTYPCU(LNOL) = [M:BBY1]QTYSTU(LNOL)/[M:BBY1]PCUSTUCOE(LNOL)
Endif

Return

#########################################################################
$APRES_STOSOM
#-----------------------------------------------------------------------#
# Mise à jour complémentaires après enregistrement
# - Recalcul des quantités sorties US, UC de la ligne de document
# - Réalimentation des zones dépendant de la quantité
# - Coloriage de la ligne document si la quantité est nulle
# - etc ...
#-----------------------------------------------------------------------#
#   [M:SOM]NBLIG     contient le nombre de ligne de stock traité
#   [M:SOM]SORQTY    contient la quantité US qui était à sortir
#   [M:SOM]SORQTYACT contient la quantité en UA qui était à sortir
#   [M:SOM]PECQTY    contient la quantité US sortie
#   [M:SOM]PECQTYACT contient la quantité en UA sortie
#   [M:SOM]SHTQTY    contient la quantité manquante
If WGENR=1
    [M:BBY1]QTYSTU(LNOL) = [M:SOM]PECQTYACT+[M:SOM]SHTQTY
    If [M:BBY1]PCUSTUCOE(LNOL)=0
        [M:BBY1]PCUSTUCOE(LNOL)=1
    Endif
    [M:BBY1]QTYPCU(LNOL) = [M:BBY1]QTYSTU(LNOL)/[M:BBY1]PCUSTUCOE(LNOL)
Endif

Local    Decimal LQTY, LQTYSTU, DELTAQTY, DELTAQTYSTU
Local Decimal DELTAAMT

# Maj du détail sortie diverse
Readlock [SMD]SMD0=[M:BBY0]VCRTYP;[M:BBY0]VCRNUM;[M:BBY1]VCRLIN(LNOL)
If fstat = 1 GOK = -1
   GLOCK = "$SMVTD"-[M:BBY0]VCRNUM-num$([M:BBY1]VCRLIN(LNOL))
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SMD",[M:BBY0]VCRNUM-num$([M:BBY1]VCRLIN(LNOL))) From GLOCK
   Return
Endif

# Quantité traitée
LQTYSTU = [M:SOM]PECQTYACT + [M:SOM]SHTQTY

If LQTYSTU = 0
   LQTY = 0
Elsif LQTYSTU = [F:SMD]QTYSTU
   LQTY = [F:SMD]QTYPCU
Else
   LQTY = LQTYSTU * [F:SMD]QTYPCU / [F:SMD]QTYSTU
Endif

DELTAAMT = (LQTYSTU - [F:SMD]QTYSTU) * [F:SMD]PRIORD

If LQTYSTU = 0
   Delete [SMD]
    #----- Suppression  sections de la ligne de document  -----#     # ana
   Delete [CAL] Where ABRFIC="SMD" & VCRTYP=[F:SMD]VCRTYP & VCRNUM=[F:SMD]VCRNUM & VCRLIN=[F:SMD]VCRLIN # ana
   If fstat=1                                                                                           # ana
      GOK=-1 : GLOCK="$CPTANALIN SMD 0"-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN) : Return                      # ana
   Endif                                                                                                # ana
Else
   [F:SMD]QTYPCU    = LQTY
   [F:SMD]QTYSTU    = LQTYSTU
   [F:SMD]QTYPCUORI = [F:SMD]QTYPCU   # hcb 102514
   [F:SMD]QTYSTUORI = [F:SMD]QTYSTU   # hcb 102514
   Rewrite [SMD]
Endif
If fstat GOK=0 : Call FSTA("SMD") From GLOCK : Return Endif

#---- Màj du prix de l'ordre si nécessaire -----#
Readlock [SMD]SMD0=31;[M:BBY0]VCRNUM;1
If fstat GOK=0 : Call FSTA("SMD") From GLOCK : Return Endif
If [F:SMD]UPDPRI=1
    [F:SMD]PRIORD += DELTAAMT/[F:SMD]QTYSTU
    Rewrite [SMD]
    If fstat GOK=0 : Call FSTA("SMD") From GLOCK : Return Endif
Else
    # Unlock [SMD]    --> "inefficace" et en plus l'enregistrement sera délocké sur le commit ou le rollback qui suivent
Endif

GRELITSMR = 1

Return


