#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDIMSGDUP                                                        #
# Manages Duplicate class for EDIMSG                                          #
# Author : RBA                                                                #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"    : Gosub AREAD_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_DUPLICATE"  : Gosub MET_DUPLICATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "MSGCODNEW" :
      Case [L]ARULE
        When "CONTROL"   : Gosub MSGCODNEW_CONTROL
        When "PROPAGATE" : Gosub MSGCODNEW_PROPAGATE
      Endcase
    When "MSGRELNEW" :
      Case [L]ARULE
        When "CONTROL"   : Gosub MSGRELNEW_CONTROL
        When "PROPAGATE" : Gosub MSGRELNEW_PROPAGATE
      Endcase
  Endcase
Return

####################################################################

$MSGCODNEW_CONTROL
  If this.MSGCODNEW <> ""
    this.MSGCODNEW = func EDILIBA.FORMATVAL("MSGCOD", this.MSGCODNEW)
  Endif
Return

$MSGCODNEW_PROPAGATE
  ASTATUS = fmet this.ADELETEERROR("MSGCODNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGRELNEW")

  If this.MSGCODNEW <> "" and this.MSGRELNEW <> ""
    If func CTRL_EXIST_MSG(this.MSGCODNEW,this.MSGRELNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("MSGCODNEW",mess(45,7779,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW,[V]CST_AERROR)
    Endif
  Endif
Return

####################################################################

$MSGRELNEW_CONTROL
  If this.MSGRELNEW <> ""
    this.MSGRELNEW = func EDILIBA.FORMATVAL("MSGREL", this.MSGRELNEW)
  Endif
Return

$MSGRELNEW_PROPAGATE
  ASTATUS = fmet this.ADELETEERROR("MSGCODNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGRELNEW")

  If this.MSGCODNEW <> "" and this.MSGRELNEW <> ""
    If func CTRL_EXIST_MSG(this.MSGCODNEW,this.MSGRELNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("MSGRELNEW",mess(45,7779,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW,[V]CST_AERROR)
    Endif
  Endif
Return

####################################################################

$AREAD_AFTER
  If this.MSGCOD <> "" and this.MSGREL <> ""
    Local File EDIMSG [EMS]
    Read [EMS]EMS0 = this.MSGCOD; this.MSGREL
    If !fstat
      this.MSGDES    = [EMS]MSGDES
      this.MSGDESNEW = [EMS]MSGDES-"(Copy)"
    Else
      this.MSGDES    = ""
      this.MSGDESNEW = ""
    Endif
    LogicClose File [EMS]
  Endif
Return

####################################################################

$MET_DUPLICATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)

  ASTATUS = fmet this.ADELETEERROR("")
  If this.MSGCODNEW <> "" and this.MSGRELNEW <> ""
    ASTATUS = fmet this.ASETERROR("",mess(9,7983,1),[V]CST_AINFO)
    If func CTRL_EXIST_MSG(this.MSGCODNEW,this.MSGRELNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("MSGRELNEW",mess(45,7779,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Else
      If func COPY_MSG(this.MSGCOD, this.MSGREL, this.MSGCODNEW, this.MSGRELNEW, this.MSGDESNEW, WERR) = [V]CST_AERROR
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(9,2007,1)-this.MSGCODNEW+"~"+this.MSGRELNEW-WERR,[V]CST_AERROR)
        WRET_VALUE = [V]CST_AERROR
      Else
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(7,2007,1)-this.MSGCODNEW+"~"+this.MSGRELNEW,[V]CST_AINFO)
        WRET_VALUE = [V]CST_AOK
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETERROR("",mess(141,105,1),[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return

####################################################################

Funprog CTRL_EXIST_MSG(WMSGCOD,WMSGREL)
Value Char WMSGCOD
Value Char WMSGREL

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WMSGCOD <> "" and WMSGREL <> ""
    Local File EDIMSG [EMS]
    Read [EMS]EMS0 = WMSGCOD;WMSGREL
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [EMS]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

####################################################################

Funprog COPY_MSG(WMSGCOD, WMSGREL, WMSGCOD_NEW, WMSGREL_NEW, WMSGDES_NEW, WERR)
Value Char WMSGCOD
Value Char WMSGREL
Value Char WMSGCOD_NEW
Value Char WMSGREL_NEW
Value Char WMSGDES_NEW
Variable Char WERR
  Local Integer WOK : WOK = [V]CST_AOK

  If WOK = [V]CST_AOK
    Local File EDIMSGD [EMSD]
    Filter [EMSD] Where MSGCOD = WMSGCOD and MSGREL = WMSGREL
    For [EMSD]
      If WOK = [V]CST_AOK
        Local File EDIMSGD [C_EMSD]
        Trbegin [C_EMSD]
        [C_EMSD]          = [EMSD]
        [C_EMSD]MSGCOD    = WMSGCOD_NEW
        [C_EMSD]MSGREL    = WMSGREL_NEW
        Write [C_EMSD]
        If !fstat
          Commit
        Else
          WOK = [V]CST_AERROR
          WERR = "EDIMSGD ("+mess(3,40,1)-num$([C_EMSD]NUMLIN)+")"
          Rollback
        Endif
        LogicClose File [C_EMSD]
      Else
        #supprimer la copie
      Endif
    Next
    Filter [EMSD]
    LogicClose File [EMSD]
  Endif

  If WOK = [V]CST_AOK
    Local File EDIMSGA [EMSA]
    Filter [EMSA] Where MSGCOD = WMSGCOD and MSGREL = WMSGREL
    For [EMSA]
      If WOK = [V]CST_AOK
        Local File EDIMSGA [C_EMSA]
        Trbegin [C_EMSA]
        [C_EMSA]          = [EMSA]
        [C_EMSA]MSGCOD    = WMSGCOD_NEW
        [C_EMSA]MSGREL    = WMSGREL_NEW
        Write [C_EMSA]
        If !fstat
          Commit
        Else
          WOK = [V]CST_AERROR
          WERR = "EDIMSGA ("+mess(3,40,1)-num$([C_EMSA]NUMLIN)+")"
          Rollback
        Endif
        LogicClose File [C_EMSA]
      Else
        #supprimer la copie
      Endif
    Next
    Filter [EMSA]
    LogicClose File [EMSA]
  Endif

  If WOK = [V]CST_AOK
    Local File EDIMSG [EMS]
    Read [EMS]EMS0 = WMSGCOD;WMSGREL
    If !fstat
      Local File EDIMSG [C_EMS]
      Trbegin [C_EMS]
      [C_EMS]          = [EMS]
      [C_EMS]VALID     = [V]CST_ANO
      [C_EMS]CACHEUUID = NullUuid()
      [C_EMS]MSGDES    = WMSGDES_NEW #[EMS]MSGDES-"(Copy)"
      [C_EMS]MSGCOD    = WMSGCOD_NEW
      [C_EMS]MSGREL    = WMSGREL_NEW
      Write [C_EMS]
      If !fstat
        Commit
      Else
  #      WOK = 3#[V]CST_AERROR
        WOK = [V]CST_AERROR
        WERR = "EDIMSG ("+mess(1,7983,1)+")"
        Rollback
      Endif
      LogicClose File [C_EMS]
    Else
  #    WOK = 4#[V]CST_AERROR
      WOK = [V]CST_AERROR
      WERR = "EDIMSG ("+mess(7,7983,1)+")"
    Endif
    Filter [EMS]
    LogicClose File [EMS]
  Endif

End WOK

