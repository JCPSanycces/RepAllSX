#<AdxTL>@(#)0.0.0.0 $Revision$ Object management PJMOPSNP
###################################################################################################
# Object PJMOPSNP 12/14/2017 08:25:27 (TEJAC)
# Issue X3-68129 - 2017-12-22 by TEJAC
###################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "LIENS"                       : Gosub LIENS
    When "RAZCRE"                      : Gosub RAZCRE
    When "RAZDUP"                      : Gosub RAZDUP                # Issue X3-80673 - 2018-04-106 by SINGC
    When "INICRE"                      : Gosub INICRE
    When "CREATION"                    : Gosub CREATION
    When "MODIF"                       : Gosub MODIF
    When "APRES_MOD"                   : Gosub APRES_MOD
    When "ANNULE"                      : Gosub ANNULE
    When "AVANTBOUT"                   : Gosub AVANTBOUT             # Issue X3-99928 - 2018-07-19 by FGR
    When "SETBOUT"                     : Gosub SETBOUT
    When "EXEBOUT"                     : Gosub EXEBOUT
  Endcase
Return

###################################################################################################
$OUVRE
  Local File PJMOPSNPD [PJSNPD]
Return

###################################################################################################
$LIENS
  GFCY = func PIMPL_CSTD_PROGS.GET_FCY_VALUE(GACTX, [M:PJSNP0]OPPNUM, AVOID.ACHAR, AVOID.ACHAR, GMESSAGE)     # Issue X3-107215 - 2018-10-05 by FGR
  # ---------------------------
  Call LOAD_SNAPSHOT_LIST()
  # Issue X3-80673 - 2018-04-10 by SINGC : START
  If [M:PJSNP1]NBLIG > 0 Then
    Diszo [M:PJSNP0]OPPNUM
    Diszo [M:PJSNP0]SNPCOD
  Else
    If GNAVIG(GPILNAV-1) = "GESPJM" Then
      # Coming from GESPJM
      Diszo [M:PJSNP0]OPPNUM
    Else
      # Coming from GESPJMOPSNP
      Actzo [M:PJSNP0]OPPNUM
    Endif
    # ---------------------------
    Actzo [M:PJSNP0]SNPCOD
  Endif
  #Diszo [M:PJSNP0]OPPNUM
  # Issue X3-80673 - 2018-04-10 by SINGC : END
  # ---------------------------
  Affzo [M:PJSNP1]1-99
Return

# Issue X3-80673 - 2018-04-10 by SINGC : START
###################################################################################################
$RAZCRE
  If [M:PJSNP0]OPPNUM <> AVOID.ACHAR Then
    Diszo [M:PJSNP0]OPPNUM
    Call LOAD_SCREEN_DEFAULT([M:PJSNP0]OPPNUM)
  Endif
Return

#$RAZCRE
#  If [M:PJSNP0]OPPNUM <> AVOID.ACHAR Then
#    Diszo [M:PJSNP0]OPPNUM
#  Endif
#  [M:PJSNP0]SNPCREDAT = date$
#  [M:PJSNP0]DESAXX = AVOID.ACHAR
#Return
# Issue X3-80673 - 2018-04-10 by SINGC : END

##########################################################################################################
$RAZDUP
  # Issue X3-80673 - 2018-04-10 by SINGC
  Diszo [M:PJSNP0]OPPNUM
  Call LOAD_SCREEN_DEFAULT([M:PJSNP0]OPPNUM)
Return

###################################################################################################
$INICRE
Local Char SCPY(GLONCPY)
Local Char SFCY(GLONFCY)
Local Integer IERROR
Local Char SMESSAGE(250)
Local Integer IMANUAL
Local Char SCOMPTEUR(GLONANM)
Local Char SNUMERO(GLONVCR)
Local Integer ISTAT

  Call READ_COUNTER(GACTX, 9, 16, SCPY, SCOMPTEUR, IMANUAL, SMESSAGE, IERROR) From CRM_UTIL_SYRA
  If IERROR = [V]CST_AYES Then
    GERR = 1
    GOK = 0
    GMESSAGE = SMESSAGE
    Return
  Endif
  If SCOMPTEUR <> AVOID.ACHAR Then
    # Get the counter for the SNPP
    If IMANUAL <> [V]CST_AYES or (IMANUAL = [V]CST_AYES and vireblc([M:PJSNP0]SNPCOD,2) = AVOID.ACHAR) Then
      SFCY = func PIMPL_CSTD_PROGS.GET_FCY_VALUE(GACTX, [M:PJSNP0]OPPNUM, AVOID.ACHAR, AVOID.ACHAR, SMESSAGE)
      Call NUMERO(SCOMPTEUR, SFCY, [M:PJSNP0]SNPCREDAT, AVOID.ACHAR, SNUMERO, ISTAT) From SUBANM
      If GOK < 0 Then
        Return
      Endif
      If GOK > 0 and ISTAT = 0 Then
        [F:PJSNPH]SNPCOD = SNUMERO
        [M:PJSNP0]SNPCOD = SNUMERO
        Affzo [M:PJSNP0]SNPCOD
      Else
        GMESSAGE = mess(60,199,1) - "(" + SCOMPTEUR + ") : "
        Gosub MESSAGE From SUBANM
        GMESSAGE -= MESSA   # MESSA is created in "Gosub MESSAGE From SUBANM"
        GERR = 1
        GOK = 0
        Return
      Endif
    Endif
  Else
    If [M:PJSNP0]SNPCOD = AVOID.ACHAR Then
      GMESSAGE = mess(1,79,1)
      GERR = 1
      GOK = 0
      zonsui = "[M:PJSNP0]SNPCOD"
      Return
    Endif
  Endif
Return

###################################################################################################
$CREATION
  Gosub MAJ_ATEXTRA_HEADER
Return

###################################################################################################
$AVANTBOUT
  # Issue X3-99928 - 2018-07-19 by FGR
  Case BOUT
    When "1"
      # Snapshot extraction
      If func SUBPJMA.GET_AUTHORIZATION("1") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
  Endcase
Return

###################################################################################################
$SETBOUT
  If GREP <> AVOID.ACHAR or [M:PJSNP0]OPPNUM = AVOID.ACHAR Then
    Call VIREBOUT(CHAINE,"1") From GOBJET
  Endif
Return

###################################################################################################
$EXEBOUT
  Case BOUT
    When "1"
      # Snapshot Extract
      Gosub RELIT From GOBJSUB
  Endcase
Return

###################################################################################################
$MODIF
Local Integer NI
Local Integer IRET
Local Char SKEY(type([M:PJSNP1]KEYEXT)-10)

  # ------------------
  Gosub MAJ_ATEXTRA_HEADER
  # ------------------
  Filter [PJSNPD] Where [F:PJSNPD]SNPCOD = [M:PJSNP0]SNPCOD
  For [PJSNPD]
    NI = find([F:PJSNPD]SNPSEQ, [M:PJSNP1]SNPSEQ(0..[M:PJSNP1]NBLIG-1))
    If NI = 0 Then
      # Line has been deleted
      IRET = func PJMPSNPEXT.DELETE_SNP_TABLES([F:PJSNPD]KEYEXT)
      If IRET = [V]CST_AERROR Then
        Break
      Endif
      Call SUPTEXTRA("PJMOPSNPD", "DDESAXX", [M:PJSNP0]SNPCOD, num$([F:PJSNPD]SNPSEQ)) From ATEXTRA
      Delete [PJSNPD]Curr
      If fstat Then
        GMESSAGE = func AFNC.MES1(mess(1042,2260,1), num$([F:PJSNPD]SNPSEQ))
        GERR = 1
        GOK = 0
        Break
      Endif
      # ------------------
      # Issue X3-76853 - 2018-02-24 by FGR/TEJAC : BEGIN
      If [F:PJSNPD]DEFBAS = [V]CST_AYES and find([V]CST_AYES, [M:PJSNP1]DEFBAS(0..[M:PJSNP1]NBLIG-1)) = 0 Then
        # Line was default : must propote another one if there is not a new default one in the current project.
        # The new default one can be in the current project or in another one.
        If func UPDATE_DEFBAS_ANOTHER_KEYEXT([M:PJSNP0]SNPCOD, [V]CST_AYES) = [V]CST_AERROR Then
          Break
        Endif
      Endif
      # Issue X3-76853 - 2018-02-24 by FGR/TEJAC : END
      # ------------------
    Else
      # Line is updated
      Call MAJTEXTRA([M:PJSNP1]DDESAXX(NI-1), "PJMOPSNPD", "DDESAXX", [M:PJSNP0]SNPCOD, num$([F:PJSNPD]SNPSEQ)) From ATEXTRA
      SKEY = [M:PJSNP1]KEYEXT(NI-1)    # Need to use a variable because parameter is an array
      IRET = func SUBPJMCLA.UPDATE_PJMCLOB_TABLE("PJMOPSNP1", "CLOB", SKEY, [M:PJSNP1]CLOB(NI-1), [M:PJSNP1]ACT(NI-1), GMESSAGE)
      If IRET = [V]CST_AERROR Then
        GERR = 1
        GOK = 0
        Break
      Endif
      # ------------------
      # Issue X3-76853 - 2018-02-24 by FGR/TEJAC : BEGIN
      If [F:PJSNPD]DEFBAS <> [M:PJSNP1]DEFBAS(NI-1) Then
        # Values has changed
        # ------------------
        # Save the new value
        [F:PJSNPD]DEFBAS = [M:PJSNP1]DEFBAS(NI-1)
        Rewrite [PJSNPD]
        If fstat Then
          GMESSAGE = func AFNC.MES1(mess(1062,2260,1), num$([F:PJSNPD]SNPSEQ))
          GERR = 1
          GOK = 0
          Break
        Endif
        # ------------------
        If [M:PJSNP1]DEFBAS(NI-1) = [V]CST_ANO Then
          # has been deprecated : not default one from now if another line is not the default one on the screen
          If find([V]CST_AYES, [M:PJSNP1]DEFBAS(0..[M:PJSNP1]NBLIG-1)) = 0 Then
            If func UPDATE_DEFBAS_ANOTHER_KEYEXT([F:PJSNPD]SNPCOD, [V]CST_AYES) = [V]CST_AERROR Then
              Break
            Endif
          Endif
        Else
          # become default one
          If func UPDATE_DEFBAS_ANOTHER_KEYEXT([F:PJSNPD]SNPCOD, [V]CST_ANO) = [V]CST_AERROR Then
            Break
          Endif
        Endif
      Endif
      # Issue X3-76853 - 2018-02-24 by FGR/TEJAC : END
      # ------------------
    Endif
  Next
  Filter [PJSNPD]
Return

###################################################################################################
$APRES_MOD
  Gosub RELIT From GOBJSUB
Return

###################################################################################################
$ANNULE
  Call DELETE_DETAIL_ALL()
  If GOK < 1 Then
    Return
  Endif
Return

###################################################################################################
# Subroutines and functions
###################################################################################################
$MAJ_ATEXTRA_HEADER
  Call MAJTEXTRA([M:PJSNP0]DESAXX, "PJMOPSNPH", "DESAXX", [M:PJSNP0]SNPCOD, AVOID.ACHAR) From ATEXTRA
Return

###################################################################################################
Subprog LOAD_SCREEN_DEFAULT(SOPPNUM)
Value Char SOPPNUM()

  GFCY = func PIMPL_CSTD_PROGS.GET_FCY_VALUE(GACTX, SOPPNUM, AVOID.ACHAR, AVOID.ACHAR, GMESSAGE)   # Issue X3-107215 - 2018-10-05 by FGR
  # Issue X3-80673 - 2018-04-10 by SINGC
  [M:PJSNP0]DESAXX = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, SOPPNUM)
  [M:PJSNP0]SNPCREDAT = date$
  Affzo [M:PJSNP0]1-99
End

###################################################################################################
Subprog LOAD_SNAPSHOT_LIST()

Local Integer NI
Local Integer IBOOL
Local Char SKEY(type([M:PJSNP1]KEYEXT)-1)

  # ------------------
  Local File PJMOPSNPD [PJSNPD]
  # ------------------
  nolign = 0
  Filter [PJSNPD] Where [F:PJSNPD]SNPCOD = [M:PJSNP0]SNPCOD Order By SNPSEQ Desc
  For [PJSNPD]
    nolign += 1
    [M:PJSNP1] = [F:PJSNPD]
  Next
  Filter [F:PJSNPD]
  [M:PJSNP1]NBLIG = nolign
  Affzo [M:PJSNP1]
  For NI = 0 To [M:PJSNP1]NBLIG-1
    SKEY = [M:PJSNP1]KEYEXT(NI)
    IBOOL = func SUBPJMCLA.KEY_EXIST("PJMOPSNP1", "CLOB", SKEY)
    [M:PJSNP1]BTCMT(NI) = func OPPORPJM_CSTD_PROGS.PJMCLOB_GET_ICON(GACTX, IBOOL)
  Next NI
End

##########################################################################################################
Funprog GET_KEYEXT_DESC(SKEYEXT)
Value Char SKEYEXT

Local Char SNPDESC(GLONDCO)

  # Issue X3-76891 - 2018-03-26 by TEJAC
  Raz SNPDESC
  # ---------------------------
  Local File PJMOPSNPD [PSNPD]
  Local File ATEXTRA [AXX]
  # ---------------------------
  Filter [PSNPD] Where [F:PSNPD]KEYEXT = SKEYEXT
  Read [PSNPD]First
  If !fstat Then
    Call LECTEXTRA(SNPDESC, "PJMOPSNPD", "DDESAXX", [F:PSNPD]SNPCOD, num$([F:PSNPD]SNPSEQ)) From ATEXTRA
    SNPDESC = mess(1047,2260,1) - format$(GFMDAT, [F:PSNPD]DSNPCREDAT)
  Endif
  Filter [PSNPD]
End SNPDESC

###################################################################################################
Subprog DELETE_DETAIL_ALL()

Local Integer DETSUB
Local Integer IRET
Local Integer IISDEFBAS
Local Char SKEY(type([M:PJSNP1]KEYEXT)-10)

  # ------------------
  Local File PJMOPSNPD [PJSNPD]
  # ------------------
  IISDEFBAS = [V]CST_ANO
  For DETSUB = 0 To [M:PJSNP1]NBLIG-1
    If [M:PJSNP1]DEFBAS(DETSUB) = [V]CST_AYES Then
      IISDEFBAS = [V]CST_AYES
    Endif
    IRET = func PJMPSNPEXT.DELETE_SNP_TABLES([M:PJSNP1]KEYEXT(DETSUB))
    If IRET = [V]CST_AERROR Then
      Break
    Endif
    Call SUPTEXTRA("PJMOPSNPD", "DDESAXX", [M:PJSNP0]SNPCOD, num$([M:PJSNP1]SNPSEQ(DETSUB))) From ATEXTRA
    SKEY = [M:PJSNP1]KEYEXT(DETSUB)    # Need to use a variable because parameter is an array
    IRET = func SUBPJMCLA.UPDATE_PJMCLOB_TABLE("PJMOPSNP1", "CLOB", SKEY, [M:PJSNP1]CLOB(DETSUB), [V]CST_ADEL, GMESSAGE)
    If IRET = [V]CST_AERROR Then
      GERR = 1
      GOK = 0
      Break
    Endif
  Next DETSUB
  If GERR < 1 Then
    Delete [PJSNPD] Where [F:PJSNPD]SNPCOD = [M:PJSNP0]SNPCOD
    If fstat Then
      GOK = 0
      GMESSAGE = func AFNC.MES1(mess(1032,2260,1), [M:PJSNP0]SNPCOD)
      End
    Else
      # Issue X3-76853 - 2018-02-24 by FGR/TEJAC : BEGIN
      If IISDEFBAS = [V]CST_AYES Then
        If func UPDATE_DEFBAS_ANOTHER_KEYEXT(AVOID.ACHAR, [V]CST_AYES) = [V]CST_AERROR Then
          End
        Endif
      Endif
      # Issue X3-76853 - 2018-02-24 by FGR/TEJAC : END
    Endif
  Endif
End

###################################################################################################
Funprog UPDATE_DEFBAS_ANOTHER_KEYEXT(SSNPCOD, IDEFBAS)
Value Char SSNPCOD
Value Integer IDEFBAS

Local Integer IARENDRE
Local Integer IINDEX
Local Char SCRITERE(250)
Local Integer IDEFBASSEARCH

  # Issue X3-76853 - 2018-02-23 by FGR/TEJAC
  IARENDRE = [V]CST_AOK
  # ------------------
  Local File PJMOPSNPH [PJSNPH]
  Local File PJMOPSNPD [PJSNPD]
  Link [PJSNPD] With [F:PJSNPH]PJSNPH0=[F:PJSNPD]SNPCOD
&                 As [NEW]
&       Order By Key KEYNEW=[F:PJSNPD]CREDATTIM Asc
  # ------------------
  If IDEFBAS = [V]CST_AYES Then
    IDEFBASSEARCH = [V]CST_ANO
  Else
    IDEFBASSEARCH = [V]CST_AYES
  Endif
  # ------------------
  If SSNPCOD = AVOID.ACHAR Then
    SCRITERE = "(1=1)"
  Else
    SCRITERE = "([F:PJSNPD]SNPCOD <> SSNPCOD)"
  Endif
  Filter [NEW] Where [F:PJSNPH]OPPNUM = [M:PJSNP0]OPPNUM and [F:PJSNPD]DEFBAS = IDEFBASSEARCH and evalue(SCRITERE)
  Read [NEW]First
  If fstat = [V]CST_AOK Then
    [F:PJSNPD]DEFBAS = IDEFBAS
    Rewrite [PJSNPD]
    If fstat Then
      IARENDRE = [V]CST_AERROR
      GOK = 0
      GERR = 1
      GMESSAGE = func AFNC.MES1(mess(1060,2260,1), [F:PJSNPD]SNPCOD, num$([F:PJSNPD]SNPSEQ))
    Else
      If [F:PJSNPD]SNPCOD = [M:PJSNP0]SNPCOD Then
        # If updated line is on the current snapshot
        IINDEX = find([F:PJSNPD]KEYEXT, [M:PJSNP1]KEYEXT(0..[M:PJSNP1]NBLIG-1))
        If IINDEX > 0 Then
          [M:PJSNP1]DEFBAS(IINDEX-1) = [F:PJSNPD]DEFBAS
          Affzo [M:PJSNP1]DEFBAS(IINDEX-1)
        Endif
      Endif
      If IDEFBAS = [V]CST_AYES Then
        # Message to inform user about the NEW DEFAULT date
        Call MESSAGE(func AFNC.MES2(mess(1054,2260,1), num$([F:PJSNPD]SNPSEQ), [F:PJSNPD]SNPCOD)) From GESECRAN
      Endif
    Endif
  Endif
  Filter [NEW]
End IARENDRE


###################################################################################################
## screen PJMOPSNP0
###################################################################################################
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()

  # Issue X3-80673 - 2018-04-10 by SINGC
  Call LOAD_SCREEN_DEFAULT(VALEUR)
End

###################################################################################################
## screen PJMOPSNP1
###################################################################################################
Subprog IB_NBLIG
  # Issue X3-99928 - 2018-07-19 by FGR
  If GBOUT2 <> AVOID.ACHAR Then
    # 2 - Project overview
    If func SUBPJMA.GET_AUTHORIZATION_GESPJM("U") = [V]CST_ANO Then
      Raz GBOUT2
    Endif
  Endif
End

###################################################################################################
Subprog C_NBLIG

  # Issue X3-76853 - 2018-02-23 by TEJAC
  If status = 65 Then
    # Delete a line
    If [M:PJSNP1]DEFBAS(nolign-1) = [V]CST_AYES Then
      If [M:PJSNP1]NBLIG > 1 Then
        GMESSAGE = mess(1053,2260,1)
        GERR = 1
        GOK = 0
        mkstat = 2
      Endif
    Endif
  Endif
End

###################################################################################################
Subprog AM_DEFBAS(VALEUR)
Variable Integer VALEUR

Local Integer ILINE
Local Integer NI
Local Integer NI1

  If VALEUR = [V]CST_AYES and [M:PJSNP1]DEFBAS(nolign-1) = [V]CST_ANO Then
    # Become Yes : was No
    NI = find([V]CST_AYES, [M:PJSNP1]DEFBAS(0..[M:PJSNP1]NBLIG-1))
    While NI > 0
      If NI-1 <> nolign-1 Then
        Break
      Endif
      NI1 = NI
      NI = find([V]CST_AYES, [M:PJSNP1]DEFBAS(NI+1..[M:PJSNP1]NBLIG-1))
      If NI > 0 Then
        NI += NI1
      Endif
    Wend
    If NI > 0 Then
      [M:PJSNP1]DEFBAS(NI-1) = [V]CST_ANO
      Affzo [M:PJSNP1]DEFBAS(NI-1)
    Endif
  Elsif VALEUR = [V]CST_ANO and [M:PJSNP1]DEFBAS(nolign-1) = [V]CST_AYES Then
    # Become No : was Yes
    # The line was the default one
    # ------------------
    Local File PJMOPSNPD [PJSNPD]
    Local File PJMOPSNPH [PJSNPH]
    # ------------------
    Link [PJSNPD] With [F:PJSNPH]PJSNPH0=[F:PJSNPD]SNPCOD
&                   As [NEW]
&                Where [F:PJSNPH]OPPNUM = [M:PJSNP0]OPPNUM and [F:PJSNPH]SNPCOD <> [M:PJSNP0]SNPCOD
    Read [NEW]First
    If fstat Then
      # If there is not another snapshot for the project, and if there is one line on this one, it's forbiden to set it as DEFBAS=[V]CST_ANO
      If [M:PJSNP1]NBLIG = 1 Then
        VALEUR = [V]CST_AYES
        GMESSAGE = mess(1061,2260,1)
        GERR = 1
        GOK = 0
        mkstat = 2
        End
      Endif
    Endif
    # ------------------
    If [M:PJSNP1]NBLIG > 1 Then
      If nolign-1 > 0 Then
        # If deprecated line is not the first one, the new default one proposed is the previous one on the project
        NI = nolign - 1
      Else
        # If deprecated line is the first line, the new default one proposed is the next one on the project
        NI = nolign + 1
      Endif
      [M:PJSNP1]DEFBAS(NI-1) = [V]CST_AYES
      Affzo [M:PJSNP1]DEFBAS(NI-1)
    Endif
  Endif
End

