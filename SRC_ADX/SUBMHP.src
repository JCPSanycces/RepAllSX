#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion objet MHR
Raz GPILOBJ
Call OBJET("MHP",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Etiquette ajoutée par le superviseur (Objet MHP) 25/02/2009 13:36:13 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "INICRE"      : Gosub INICRE
 When "LIENS"       : Gosub LIENS
 When "LIENS2"      : Gosub LIENS2
 When "ANNULE"      : Gosub ANNULE
 When "MODIF"       : Gosub MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "RAZDUP"      : [M:MHP0]FLGCLO=1 : Affzo [M:MHP0]FLGCLO
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "FERME"       : Gosub FERME
Endcase
Return


#####################################
$OUVRE
If clalev ([F:MHP])=0 : Local File MSHYPENP  [MHP] : Endif
If clalev ([F:BCB])=0 : Local File BCLOB     [BCB] : Endif
If clalev ([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif
If clalev ([F:MCL])=0 : Local File MSSCENAL  [MCL] : Endif
If clalev ([F:MCH])=0 : Local File MSSCENAH  [MCH] : Endif
If clalev ([F:CPY])=0 : Local File COMPANY   [CPY] : Endif

Local Char    COMPTEUR(GLONANM)
Local Integer STAT

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = 'FRA' #Total Payroll is FRA only

Return

#####################################
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#####################################
$SETBOUT
If GREP<>"" | !VERROU | [M:MHP0]FLGCLO=2
 Call VIREBOUT (CHAINE,"AH") From GOBJET
Endif
If [M:MHP0]FLGCLO=2
 Call VIREBOUT (CHAINE,"M") From GOBJET
Endif
Return

#####################################
$LIENS
# On décoche Définitif si l'hypothèse n'est stockée dans aucun scénario définitif
Link [MCL] With [MCH]MCH0=[MCL]COD
& As [LMC]
& Where [MCH]FLGCLO=2 & [MCL]TYPHYP=3 & [MCL]CODHYP=[F:MHP]COD
Read [LMC]MCL1 First
If fstat
 [M:MHP0]FLGCLO = 1
 Call DEBTRANS From GLOCK
 Gosub TR_LIEN
Endif
Return

$TR_LIEN
Trbegin [MHP]
 [F:MHP]FLGCLO = 1
 Rewrite[MHP]
 If fstat : Call FSTA("MHP") From GLOCK : Rollback : Return : Endif
Commit
Return

#####################################
$LIENS2
Gosub CHARGE_STYLE
#CMT commun à toutes les lignes
Default Mask [M:MHP0]
Call CHARGE_CMT ("SUBMHP",[F:MHP]COD,"","","")From SUBMSR
Return

#####################################
$CHARGE_STYLE
# Affzo avant le chgstl sinon ça marche pas !?!
Affzo [M:MHP0]20
For nolign=1 To [M:MHP0]NBLIG
 If [M:MHP0]ENAFLG1(nolign-1)=2
  Chgstl [M:MHP0]NBLIG(nolign-1) With "CONTRAT"
 Else
  Chgstl [M:MHP0]NBLIG(nolign-1) With ""
 Endif
Next
Return

#####################################
$INICRE
## Affectation du compteur
If [F:MHP]COD=""
 Call LECTCA(15,STAT) From SUBTCA
 If !STAT
  GMESSAGE = mess(51,10722,1) : # Compteur MSR non défini
  GOK = 0 : Return
 Else
  COMPTEUR= [F:TCA]CODNUM(11)
 Endif
 Call NUMERO(COMPTEUR,"",date$,"",[F:MHP]COD,STAT) From SUBANM
 If STAT
  # Erreur sur compteur
  GMESSAGE = mess(4,10702,1)-COMPTEUR
  GOK = 0 : Return
 Endif
 Call VERIF_CPT([F:MHP]COD,COMPTEUR)
 If GOK=0 : Return : Endif
 [M:MHP0]COD = [F:MHP]COD
 Affzo [M:MHP0]COD
Endif
Return

####################################
$MODIF
#CMT commun à toutes les lignes
Default Mask [M:MHP0]
Call SAUVE_CMT ("SUBMHP",[F:MHP]COD,"","","")From SUBMSR
Return

####################################
Subprog VERIF_CPT(NUM,COMPTEUR)
Variable Char NUM
Value    Char COMPTEUR
Local Integer STAT
If clalev([F:MHPZ])=0 : Local File MSHYPENP [MHPZ] : Endif
Read [MHPZ]MHP0(1)=NUM
If fstat : End : Endif
While !fstat
 Call NUMERO(COMPTEUR,"",date$,"",NUM,STAT) From SUBANM
 Read [MHPZ]MHP0(1)=NUM
Wend
If STAT
 # Erreur sur compteur
 GMESSAGE = mess(4,10702,1)-COMPTEUR
 GOK = 0 : End
Endif
End

#####################################
## Changement de clé
$AP_CHANGE
Call APCHANGE(3,OCODE,NCODE) From SUBMHR
Return

#####################################
$ANNULE
#CMT commun à toutes les lignes
Call ANNULE_CMT ("SUBMHP",[F:MHP]COD,"","","")From SUBMSR
Return

#####################################
Subprog C_ENAFLG1(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Chgstl NBLIG(nolign-1) With "CONTRAT"
Else
 Chgstl NBLIG(nolign-1) With ""
Endif
End


######################################################################################
