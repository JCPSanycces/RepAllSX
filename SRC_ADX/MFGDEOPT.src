#<AdxTL>@(#)0.0.0.0 $Revision$
#---------------------------------------------------------------------------#
# Actions of work order optimization menu button                            #
# - SAIMFGDEOP    Set work order to 'pending'                               #
#---------------------------------------------------------------------------#
$ACTION
Case ACTION
    When "OUVRE":         Case GACTION
                              When "SAIMFGOPT" : Gosub OUVRE_MFGOPT
                          Endcase
    When "DEBUT":         Case GACTION
                              When "SAIMFGOPT" : Gosub DEBUT_MFGOPT
                          Endcase
    When "SETBOUT":       Case GACTION
                              When "SAIMFGOPT" : Gosub SETBOUT_MFGOPT
                          Endcase
    When "BOUTON":        Case GACTION
                              When "SAIMFGOPT" : Gosub BOUTON_MFGOPT
                          Endcase
    When "FIN":           Case GACTION
                              When "SAIMFGOPT":  Gosub FIN_MFGOPT
                          Endcase
    When Default
Endcase
Return

#---------------------------------------------------------------------------#
# Action SAIMFGOPT                                                          #
#---------------------------------------------------------------------------#
###########################################################################
# ouverture
$OUVRE_MFGOPT
    Local    Char    WMFGNUM(GLONVCR) : WMFGNUM = PARAM(1)
    Local    Char    WFCY(GLONFCY)
    Local    Integer WRET
    Local    Integer WLK  : WLK = 0
    Local    Integer WDLK : WDLK = 0

    If clalev ([F:MFG]) <= 0 : Local File MFGHEAD    [MFG] : Endif

Return

###########################################################################
# ouverture
$DEBUT_MFGOPT

    # Lock the work order
    WLK = 0
    If WDLK<>1
       WLK =  func TRTX3FNC.CHECK_LOCK("MFG",WMFGNUM,1,WDLK)
    Endif

Return

###########################################################################
# ouverture
$SETBOUT_MFGOPT
#Set the name of the menu Optimize or De-optimize
    Case WOPTFLG
        When 2:
            Call VIREBOUT(CHAINE, "5") From GOBJET
        When 4:
            Call VIREBOUT(CHAINE, "5") From GOBJET
        When Default:
            Call VIREBOUT(CHAINE, "6") From GOBJET
    Endcase

Return

###########################################################################
# ouverture
$BOUTON_MFGOPT
    Local Integer OK
    Call OUINON(mess(357,193,1), OK) From GESECRAN
    If (OK = 2)
        Readlock [MFG]MFG0=WMFGNUM
        If fstat : PARAM(2) = num$(1) : FIN = 1 : Return : Endif

        [F:MFG]OPTFLG = 1
        Rewrite [F:MFG]
    Endif
    PARAM(2) = 0
    FIN=0

Return

###########################################################################
# ouverture
$OK_MFGOPT
Return

###########################################################################
# ouverture
$FIN_MFGOPT
    If WDLK=1 # FQ 63906 GA 05/2010 pour dé-locker l'OF si et seulement si on l'a locké ici
       Unlock = "MFG"+WMFGNUM
    Endif
Return

