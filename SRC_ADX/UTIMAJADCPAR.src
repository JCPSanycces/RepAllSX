#<AdxTL>@(#)3.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour table paramètre TYPCOD sur champs avec type de données ADC
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update ADC type") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub DESADC
End

#-------------------#
$DESADC

Local Char CHAINE(250)

Local File =DOSSIER+".AMSKZON"   [AMZ] 
Local File =DOSSIER+".AMSKPAR"   [AMP]

# Mise à jour de la table AMSKPAR
Call ECR_TRACE(mess(81,125,1)-"AMSKPAR:"-time$,0) From GESECRAN

CHAINE = "TYPCOD"
Trbegin [AMP]
 For [AMZ] Where CODTYP="ADC"
  Look [AMP]CODPAR=1;[F:AMZ]CODMSK;[F:AMZ]CODZON;CHAINE
  If fstat
   Raz [F:AMP]
   [F:AMP]TYPAFF = 1
   [F:AMP]CODAFF = [F:AMZ]CODMSK
   [F:AMP]CODZON = [F:AMZ]CODZON
   [F:AMP]CODPAR = CHAINE
   [F:AMP]VALPAR = '""'
   Write [AMP] 
   If fstat
    Call ERREUR("AMSKPAR"-[F:AMA]CODAFF-[F:AMA]CODZON,2) From DOSDIC
   Endif
  Endif
 Next AMZ
Commit

Close Local File [AMZ],[AMP]

Return
