#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################
# UTITC001   Moulinette pour désactiver le code activité TPT             #
#            dans les tables ACTIV et ADOSACT                            #
# ---------------------------------------------------------------------- #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTITC001(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTITC001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer STAT
Local Char APPLI : APPLI = DOSSIER

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat Raz [F:ADS] : Endif

Call ECR_TRACE("UTITC001: Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:ACV])  =0  Local File =DOSSIER+".ACTIV"   [ACV] : Endif
If clalev([F:ADA])  =0  Local File =DOSSIER+".ADOSACT" [ADA] : Endif

Call DEBTRANS From GLOCK
Gosub OUVFIC From VALMSKLEC
#----- Maj du code activité TPT dans ACTIV -----#
Trbegin [ACV]
Update [ACV] Where CODACT="TPT" & FLACT=2
&            With FLACT=1
Commit
#----- Maj du code activité TPT dans ADOSACT -----#
Trbegin [ADA]
Update [ADA] Where CODACT="TPT" & DOSSIER = DOSSIER & FLACT=2
&            With FLACT=1
Commit

Call ECR_TRACE("UTITC001 : "+num$(adxuprec)+" records processed",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call MAJ_UTITC001(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call MAJ_UTITC001(APPLI)
End




