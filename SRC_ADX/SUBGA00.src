#<AdxTL>@(#)162.0.0.0 $Revision$
# Issue X3-93418 - 2018-08-09 by FHA : Code error fixed
#
Subprog C_NBLIG
Local Integer I
Local Char    CENTRAL(10), CENTBPR(10) , SCHEMA(10)
If status>=65 & status<=90
 Case status
  When 73,82 : # Insertion, Reprise
   If ([M]STA>1 & (GREP="M" or GREP=""))
    GMESSAGE = mess(85,106,1) : # Pièce définitive
    mkstat = 2 : End
   Elsif ([M]REFINT>="MTC" & [M]REFINT<="MTC9")
    GMESSAGE = mess(84,106,1) : # Pièce automatique
    mkstat = 2 : End
   Endif
   If GREP="M" or GREP=""
    For I=nolign To [M]NBLIG
     If [M]BPR(I-1)<>""
      # Insertion impossible  - Echéance déjà saisie en ligne
      GMESSAGE = mess(45,133,1)-"\"-mess(46,117,1)-num$(I) : mkstat = 2 : Break
     Endif
    Next I
    If mkstat=2 : End : Endif
   Endif
  When 65,68,83 : # Cancellation line

   If [M]STA>1 & (GREP="M" or GREP="") : mkstat = 2 : End : Endif
   If clalev([F:PAN]) = 0 : Local File PAYACCNUM  [PAN] : Endif    # Bug 10439 (CP : 14/09/01)
   If status=65
    Gosub SETNOL
    If [M]MTC(NOL)<>""  :  GMESSAGE = mess(69,106,1) : mkstat = 2 : End : Endif
    # Ecriture, lettrée, annulation impossible
    If [M]CHK(NOL)<>""  :  GMESSAGE = mess(74,106,1) : mkstat = 2 : End : Endif
    # Ecriture pointée, annulation impossible
    If [M]BPR(NOL)<>"" & [M]ORIMOD<>2
     GMESSAGE = mess(75,106,1)-mess([M]ORIMOD,14,1)  : mkstat = 2 : End : Endif
     # Ecriture du module ...
    If [M]AMTVAT(NOL)<>0 : GMESSAGE = mess(95,106,1) : mkstat = 2 : End : Endif
     # Cette piece comporte de la TVA déclarée
     Filter [PAN] Where ACCNUM=[M]ACCNUM(NOL)
     Read [F:PAN]PAN0 First
     If !fstat & [M]ACCNUM(NOL)<>0 : GMESSAGE = mess(75,106,1)-mess(3,14,1)  : mkstat = 2 : Filter [PAN] : End : Endif
     # Ecriture du module Tiers
   Else
    For I=nolign To nolign1
     If [M]MTC(I-1)<>""    : GMESSAGE = mess(69,106,1) : mkstat = 2 : Break : Endif
     If [M]CHK(I-1)<>""    : GMESSAGE = mess(74,106,1) : mkstat = 2 : Break : Endif
     If [M]AMTVAT(I-1)<>0  : GMESSAGE = mess(95,106,1) : mkstat = 2 : Break : Endif
     If [M]BPR(I-1)<>"" & [M]ORIMOD<>2
      GMESSAGE = mess(75,106,1)-mess([M]ORIMOD,14,1) : mkstat = 2 : Break
     Endif
     Filter [PAN] Where ACCNUM=[M]ACCNUM(I-1)
     Read [F:PAN]PAN0 First
     # Issue X3-93418 Code error fixed
     #If !fstat & [M]ACCNUM(I-0)<>0 : GMESSAGE = mess(75,106,1)-mess(3,14,1)  : mkstat = 2 : Break  : Endif
     If !fstat & [M]ACCNUM(I-1)<>0 : GMESSAGE = mess(75,106,1)-mess(3,14,1)  : mkstat = 2 : Break  : Endif
     # Ecriture du module Tiers
    Next I
   Endif
   Filter [PAN]
   If [M]NBLIG = 1 or status = 83 # We delete the last line or all the lines, so we reinitalize the main partner
    [M:HAEF]INICSLBPR = [V]CST_ANO
    [M:HAEF]MAINCSLBPR = ""
   Endif

 Endcase
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog D_CSLBPR(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" and GIMPORT = 0
    Local Integer INIT_BPR : INIT_BPR=1
    Goto INIT_CSLBPR
  Endif

End

Subprog AS_CSLBPR(VALEUR)
Variable Char    VALEUR()

If GIMPORT : End : Endif

$INIT_CSLBPR

Local Char WCOA(GLONCOA), WACC(GLONGAC), ABR(10)
Local Tinyint CSLFLG
Local Integer ASTATUS, ILED
Local Char ERRMES(250), WLED(GLONLED), WCUR(GLONCUR)

  Call MSKABR("CSLBPR", ABR) From SUBGASA
  If adxtyp=33 | !clalev([F:GAC2]) : Local File GACCOUNT  [GAC2] : Endif
  Gosub SETNOL
  mkstat = 1

  Case [M:HAEF]TYPENT
  When 1
    # Saisie en colonne
    For ILED = 1 To [M:HAEF]NBRLED
      WCOA = [M:HAEF]COA(ILED-1)
      If WCOA <> AVOID.ACHAR
        WACC = evalue("[M:"+ABR+"]ACC"+num$(ILED)+"(NOL)")
        If WACC <> AVOID.ACHAR
          Call LEC_GAC(WACC,WCOA) From CPTLEC


          # Control if a ledger is flagged "Consolidation"
          [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX, [M:HAEF]LED(ILED-1), CSLFLG, ERRMES)

          If [L]CSLFLG = [V]CST_AYES and (GREP="" or GREP="M") and [M]STA > 1
            Call CONTPER([M]ACCDAT,[M:HAEF]LEDTYP(ILED-1),[M]FCYLIN(nolign-1)) From CPTSUB
            If mkstat=2 : Raz GMESSAGE : Break : Endif
          Endif

          # Initialisation VALUE when coming from D_CSLBPR
          If dim(INIT_BPR)>0 & INIT_BPR=1

            If [L]CSLFLG = [V]CST_AYES

              [L]ASTATUS = func FINCSLLIB.GET_CSLBPR(GACTX, [M:HAEF]MAINCSLBPR, [M]CPY, [M:HAEF]LED(ILED-1), [M]BPR(NOL), WCOA, WACC, CSLFLG, VALEUR, ERRMES)
              Raz mkstat
              # When CSLBPR is hidden, we need to find the main partner (and the user can't change it)
              If varmode(CSLBPR) = 3
                Gosub _SET_MAIN_CSLBPR
              Endif
              Break # break after first consolited ledger
            Endif
          Else
            If [L]CSLFLG=[V]CST_AYES & func FINCSLLIB._GET_CSLBPRFLGACC(GACTX,WCOA,WACC)=[V]CST_AYES
              Raz mkstat
            Endif
          Endif
        Endif
      Endif
    Next

  When 2
    # Saisie en ligne
    WCOA = evalue("[M:"+ABR+"]COA1("+num$(NOL)+")")
    If WCOA<>""
      WACC = evalue("[M:"+ABR+"]ACC1("+num$(NOL)+")")
      Call LEC_GAC(WACC,WCOA) From CPTLEC

      [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(GACTX,[M]CPY,evalue("[M:"+ABR+"]LEDTYP("+num$(NOL)+")"),WLED,WCUR,ERRMES)
      If [L]ASTATUS>=[V]CST_AERROR
        End
      Endif

      # Control if this ledger is flagged "Consolidation"
      [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX, WLED, CSLFLG, ERRMES)

      If [L]CSLFLG = [V]CST_AYES and (GREP="" or GREP="M") and [M]STA > 1
       Call CONTPER([M]ACCDAT, evalue("[M:"+ABR+"]LEDTYP("+num$(NOL)+")"),[M]FCYLIN(NOL)) From CPTSUB
       If mkstat=2 : Raz GMESSAGE : End : Endif
      Endif

      # Initialisation VALUE when coming from D_CSLBPR
      If dim(INIT_BPR)>0 & INIT_BPR=1
        If [L]CSLFLG = [V]CST_AYES

          [L]ASTATUS = func FINCSLLIB.GET_CSLBPR(GACTX, [M:HAEF]MAINCSLBPR, [M]CPY, WLED, [M]BPR(NOL), WCOA, WACC, CSLFLG, VALEUR, ERRMES)
          Raz mkstat
          # When CSLBPR is hidden, we need to find the main partner (and the user can't change it)
          If varmode(CSLBPR) = 3
            Gosub _SET_MAIN_CSLBPR
          Endif
        Endif
      Else
        [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX, WLED, CSLFLG, ERRMES)
        If [L]CSLFLG=[V]CST_AYES & func FINCSLLIB._GET_CSLBPRFLGACC(GACTX,WCOA,WACC)=[V]CST_AYES
          Raz mkstat
        Endif
      Endif
    Endif
  Endcase

  If dim(INIT_BPR)>0 & INIT_BPR=1 : Raz mkstat : Endif

End

Subprog C_CSLBPR(VALEUR)
Variable Char    VALEUR()

Local Char WCOA(GLONCOA), WACC(GLONGAC), ABR(10)

Local Tinyint CSLFLG, FIRST_CSLLED
Local Integer ASTATUS
Local Char ERRMES(250), WLED(GLONLED), WCUR(GLONCUR)

  Call MSKABR("CSLBPR",ABR) From SUBGASA
  Gosub SETNOL

  Case [M:HAEF]TYPENT
  When 1
    # Saisie en colonne
    [L]FIRST_CSLLED = [V]CST_ANO
    For ILED=1 To [M:HAEF]NBRLED
     If !GIMPORT | ILED=evalue("[M:"+ABR+"]LEDTYP(NOL)")
      WCOA = [M:HAEF]COA(ILED-1)
      If WCOA <> AVOID.ACHAR
        WACC = evalue("[M:"+ABR+"]ACC"+num$(ILED)+"(NOL)")

        ## If SAC is imported ACC1 is initialized but not the other ACC (ACC3, ACC4..)
        If GIMPORT & WACC=AVOID.ACHAR & evalue("[M:"+ABR+"]SAC"+num$(ILED)+"(NOL)")<>AVOID.ACHAR
         Read [GAC]GAC1=WCOA;evalue("[M:"+ABR+"]SAC"+num$(ILED)+"(NOL)")
         WACC = [F:GAC]ACC
        Endif

        If WACC <> AVOID.ACHAR
          Call LEC_GAC(WACC,WCOA) From CPTLEC

          If func FINCSLLIB.CTL_CSLBPR(GACTX, [M:HAEF]LED(ILED-1), WCOA, WACC, CSLFLG, VALEUR, ERRMES) <> [V]CST_AOK
            GMESSAGE = ERRMES
            mkstat = 2
            Break
          Endif

          # Control if a ledger is flagged "Consolidation" (looking for only on the first one)
          [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX, [M:HAEF]LED(ILED-1), CSLFLG, ERRMES)
          If [L]CSLFLG = [V]CST_AYES and [L]FIRST_CSLLED = [V]CST_ANO
            Gosub _SET_MAIN_CSLBPR
            [L]FIRST_CSLLED = [V]CST_AYES
          Endif
        Endif
      Endif
     Endif
    Next

  When 2
    # Saisie en ligne
    WCOA = evalue("[M:"+ABR+"]COA1("+num$(NOL)+")")
    If WCOA <> AVOID.ACHAR
      WACC = evalue("[M:"+ABR+"]ACC1("+num$(NOL)+")")
      Call LEC_GAC(WACC,WCOA) From CPTLEC

      [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(GACTX,[M]CPY,evalue("[M:"+ABR+"]LEDTYP("+num$(NOL)+")"),WLED,WCUR,ERRMES)
      If [L]ASTATUS>=[V]CST_AERROR : End : Endif
      If func FINCSLLIB.CTL_CSLBPR(GACTX, WLED, WCOA, WACC, CSLFLG, VALEUR, ERRMES) <> [V]CST_AOK
        GMESSAGE = ERRMES
        mkstat = 2
        End
      Endif

      If [L]CSLFLG = [V]CST_AYES
        Gosub _SET_MAIN_CSLBPR
      Endif
    Endif
  Endcase
End

#* set the main CSL_BPR from the first collective and Entry partner account
$_SET_MAIN_CSLBPR

  # already initialized
  If [M:HAEF]INICSLBPR = [V]CST_AYES
    Return
  Endif

  If [F:GAC]SAC = [V]CST_AYES and [F:GAC]CSLFLGBPR > 1
    [M:HAEF]INICSLBPR = [V]CST_AYES
    [M:HAEF]MAINCSLBPR = VALEUR
  Endif

Return

#**
#* Initialiez the main partner when an accounting schema is used.
#* It's a mixed function of AS_CSLBPR and C_CSLBPR
#* @param NOL     line number
#*!
Subprog INIT_CSLBPR_SCHEMA(NOL)
Value Integer NOL

If func AFNC.ACTIV("PRCSL") = 0
  End
Endif

Local Char WCOA(GLONCOA), WACC(GLONGAC), ABR(10)
Local Tinyint CSLFLG, FIRST_CSLLED
Local Integer ASTATUS, ILED
Local Char ERRMES(250), WLED(GLONLED), WCUR(GLONCUR)

  Call MSKABR("CSLBPR", ABR) From SUBGASA

  Case [M:HAEF]TYPENT
  When 1
    # Saisie en colonne
    [L]FIRST_CSLLED = [V]CST_ANO
    For ILED = 1 To [M:HAEF]NBRLED
      WCOA = [M:HAEF]COA(ILED-1)
      If WCOA <> AVOID.ACHAR
        WACC = evalue("[M:"+ABR+"]ACC"+num$(ILED)+"(NOL)")
        If WACC <> AVOID.ACHAR
          Call LEC_GAC(WACC,WCOA) From CPTLEC

          # Control if a ledger is flagged "Consolidation"
          [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX, [M:HAEF]LED(ILED-1), CSLFLG, ERRMES)
          If [L]CSLFLG = [V]CST_AYES

            [L]ASTATUS = func FINCSLLIB.GET_CSLBPR(GACTX, [M:HAEF]MAINCSLBPR, [M]CPY, [M:HAEF]LED(ILED-1), [M]BPR(NOL), WCOA, WACC, CSLFLG, [M]CSLBPR(NOL), ERRMES)
            If [L]CSLFLG = [V]CST_AYES and [L]FIRST_CSLLED = [V]CST_ANO

              # Set the main bpr
              If [M:HAEF]INICSLBPR <> [V]CST_AYES and [F:GAC]SAC = [V]CST_AYES and [F:GAC]CSLFLGBPR > 1
                [M:HAEF]INICSLBPR = [V]CST_AYES
                [M:HAEF]MAINCSLBPR = [M]CSLBPR(NOL)
              Endif
              [L]FIRST_CSLLED = [V]CST_AYES
            Endif
            Break # break after first consolited ledger
          Endif
        Endif
      Endif
    Next

  When 2
    # Saisie en ligne
    WCOA = evalue("[M:"+ABR+"]COA1("+num$(NOL)+")")
    If WCOA<>""
      WACC = evalue("[M:"+ABR+"]ACC1("+num$(NOL)+")")
      Call LEC_GAC(WACC,WCOA) From CPTLEC

      [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(GACTX,[M]CPY,evalue("[M:"+ABR+"]LEDTYP("+num$(NOL)+")"),WLED,WCUR,ERRMES)
      If [L]ASTATUS>=[V]CST_AERROR
        End
      Endif

      # Control if this ledger is flagged "Consolidation"
      [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX, WLED, CSLFLG, ERRMES)
      If [L]CSLFLG = [V]CST_AYES

        [L]ASTATUS = func FINCSLLIB.GET_CSLBPR(GACTX, [M:HAEF]MAINCSLBPR, [M]CPY, WLED, [M]BPR(NOL), WCOA, WACC, CSLFLG, [M]CSLBPR(NOL), ERRMES)

        # Set the main bpr
        If [M:HAEF]INICSLBPR <> [V]CST_AYES and [F:GAC]SAC = [V]CST_AYES and [F:GAC]CSLFLGBPR > 1
          [M:HAEF]INICSLBPR = [V]CST_AYES
          [M:HAEF]MAINCSLBPR = [M]CSLBPR(NOL)
        Endif
#        Raz mkstat
      Endif
    Endif
  Endcase

End

##  D_CSLFLO is Mandatory if field CSLFLO is "displayed" in GESDE
Subprog D_CSLFLO(VALEUR)
Variable Char    VALEUR()
If varinit([M]CSLFLO,indice)=0 & VALEUR="" & !GIMPORT
 If func AFNC.ACTIV("PRCSL")
  Local Integer INIT_CSL : INIT_CSL=1
  Goto INIT_CSLFLO
 Endif
Endif
End

Subprog AS_CSLFLO(VALEUR)
Variable Char    VALEUR()

If GIMPORT  & func AFNC.ACTIV("PRCSL") : End : Endif

$INIT_CSLFLO

Local Char WCOA(GLONCOA),WACC(GLONGAC),ABR(10)
Local Tinyint FLGCSL, FLGCSLFLO
Local Integer ASTATUS
Local Char ERRMES(250), WLED(GLONLED), WCUR(GLONCUR)

Call MSKABR("CSLFLO",ABR) From SUBGASA
Local Integer I
Gosub SETNOL
mkstat = 1
Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  For I=1 To [M:HAEF]NBRLED
   WCOA = [M:HAEF]COA(I-1)
   If WCOA<>""
    WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
    If WACC<>""
     Call LEC_GAC(WACC,WCOA) From CPTLEC
     #--- Est il Gestion de conso ?
     If func AFNC.ACTIV("PRCSL")
      [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX, [M:HAEF]LED(I-1),FLGCSL,ERRMES)
      If [L]FLGCSL=[V]CST_AYES & (GREP="" | GREP="M") & [M]STA>1
       Call CONTPER([M]ACCDAT,[M:HAEF]LEDTYP(I-1),[M]FCYLIN(nolign-1)) From CPTSUB
       If mkstat=2 : Raz GMESSAGE : Break : Endif
      Endif

      # Initialisation VALUE when D_CSLFLO
      If dim(INIT_CSL)>0 & INIT_CSL=1
       If [M]CDT(NOL)<>0
        [L]ASTATUS = func FINCSLLIB.GET_CSLFLO(GACTX,[M]CPY,[M:HAEF]LED(I-1),[M]JOU,WCOA,WACC,-1,FLGCSLFLO,VALEUR,ERRMES)
       Else
        [L]ASTATUS = func FINCSLLIB.GET_CSLFLO(GACTX,[M]CPY,[M:HAEF]LED(I-1),[M]JOU,WCOA,WACC,1,FLGCSLFLO,VALEUR,ERRMES)
       Endif
       If [L]FLGCSLFLO=[V]CST_AYES : Raz mkstat : Break : Endif
       If [L]FLGCSL=[V]CST_AYES : Raz mkstat : Break : Endif
      Endif

      If [L]FLGCSL=[V]CST_AYES & func FINCSLLIB._GET_CSLFLOFLGACC(GACTX,WCOA,WACC)=[V]CST_AYES : Raz mkstat : Endif

     Elsif dim([F:GAC]CSLFLGFLW)>0 & [F:GAC]CSLFLGFLW>1
      If VALEUR=""
       If [F:GAC]FLODEB<>"" & [M]DEB(NOL)>0 : VALEUR =  [F:GAC]FLODEB : Endif
       If [F:GAC]FLOCDT<>"" & [M]CDT(NOL)>0 : VALEUR =  [F:GAC]FLOCDT : Endif
      Endif
      Raz mkstat
      If VALEUR<>"" : Break : Endif
     Endif
    Endif
   Endif
  Next
 When 2
  # Entry Type : Row
  WCOA = evalue("[M:"+ABR+"]COA1("+num$(NOL)+")")
  If WCOA<>""
   WACC = evalue("[M:"+ABR+"]ACC1("+num$(NOL)+")")
   Call LEC_GAC(WACC,WCOA) From CPTLEC
   #--- Est il Gestion de conso ?
   If func AFNC.ACTIV("PRCSL")
    [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(GACTX,[M]CPY,evalue("[M:"+ABR+"]LEDTYP("+num$(NOL)+")"),WLED,WCUR,ERRMES)
    If [L]ASTATUS>=[V]CST_AERROR : End : Endif

    [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,WLED,FLGCSL,ERRMES)

    If [L]FLGCSL=[V]CST_AYES & (GREP="" | GREP="M") & [M]STA>1
     Call CONTPER([M]ACCDAT,evalue("[M:"+ABR+"]LEDTYP("+num$(NOL)+")"),[M]FCYLIN(NOL)) From CPTSUB
     If mkstat=2 : Raz GMESSAGE : End : Endif
    Endif

    # Initialisation VALUE when D_CSLFLO
    If dim(INIT_CSL)>0 & INIT_CSL=1
     If [M]CDT(NOL)<>0
      [L]ASTATUS = func FINCSLLIB.GET_CSLFLO(GACTX,[M]CPY,WLED,[M]JOU,WCOA,WACC,-1,FLGCSLFLO,VALEUR,ERRMES)
     Else
      [L]ASTATUS = func FINCSLLIB.GET_CSLFLO(GACTX,[M]CPY,WLED,[M]JOU,WCOA,WACC,1,FLGCSLFLO,VALEUR,ERRMES)
     Endif
     If [L]FLGCSLFLO=[V]CST_AYES : Raz mkstat : Endif
     If [L]FLGCSL=[V]CST_AYES : Raz mkstat : Endif
    Endif

    If [L]FLGCSL=[V]CST_AYES & func FINCSLLIB._GET_CSLFLOFLGACC(GACTX,WCOA,WACC)=[V]CST_AYES : Raz mkstat : Endif
   Elsif dim([F:GAC]CSLFLGFLW)>0 & [F:GAC]CSLFLGFLW>1
    If VALEUR=""
     If [F:GAC]FLODEB<>"" & [M]DEB(NOL)>0 : VALEUR =  [F:GAC]FLODEB : Endif
     If [F:GAC]FLOCDT<>"" & [M]CDT(NOL)>0 : VALEUR =  [F:GAC]FLOCDT : Endif
    Endif
    Raz mkstat
   Endif
 Endif
Endcase
If dim(INIT_CSL)>0 & INIT_CSL=1 : Raz mkstat : Endif
If mkstat : End : Endif
End

Subprog C_CSLFLO(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif
Local Char WCOA(GLONCOA),WACC(GLONGAC),ABR(10),WFLO(15)
Local Tinyint FLGCSL
Local Integer ASTATUS
Local Char ERRMES(250), WLED(GLONLED), WCUR(GLONCUR)
Call MSKABR("CSLFLO",ABR) From SUBGASA
Local Integer OK
Gosub SETNOL
Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  For I=1 To [M:HAEF]NBRLED
   If !GIMPORT | I=evalue("[M:"+ABR+"]LEDTYP(NOL)")
    WCOA = [M:HAEF]COA(I-1)
    If WCOA<>""
     WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")

     ## If SAC is imported ACC1 is initialized but not the other ACC (ACC3, ACC4..)
     If GIMPORT & WACC=AVOID.ACHAR & evalue("[M:"+ABR+"]SAC"+num$(I)+"(NOL)")<>AVOID.ACHAR
      Read [GAC]GAC1=WCOA;evalue("[M:"+ABR+"]SAC"+num$(I)+"(NOL)")
      WACC = [F:GAC]ACC
     Endif

     If WACC<>""
      Call LEC_GAC(WACC,WCOA) From CPTLEC
      #--- Est il Gestion de conso ?
      If func AFNC.ACTIV("PRCSL")
       If func FINCSLLIB.CTL_CSLFLO(GACTX,[M:HAEF]LED(I-1),WCOA,WACC,FLGCSL,VALEUR,ERRMES)<>[V]CST_AOK
        GMESSAGE = ERRMES
        mkstat = 2 : Break
       Endif
      Elsif dim([F:GAC]CSLFLGFLW)>0 & [F:GAC]CSLFLGFLW=3
       GMESSAGE = mess(10,123,1)
       mkstat = 2 : Break
      Endif
     Endif
    Endif
   Endif
  Next
 When 2
  # Entry Type : Row
  WCOA = evalue("[M:"+ABR+"]COA1("+num$(NOL)+")")
  If WCOA<>""
   WACC = evalue("[M:"+ABR+"]ACC1("+num$(NOL)+")")
   Call LEC_GAC(WACC,WCOA) From CPTLEC
   #--- Est il Gestion de conso ?
   If func AFNC.ACTIV("PRCSL")
    [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(GACTX,[M]CPY,evalue("[M:"+ABR+"]LEDTYP("+num$(NOL)+")"),WLED,WCUR,ERRMES)
    If [L]ASTATUS>=[V]CST_AERROR : End : Endif
    If func FINCSLLIB.CTL_CSLFLO(GACTX,WLED,WCOA,WACC,FLGCSL,VALEUR,ERRMES)<>[V]CST_AOK
     GMESSAGE = ERRMES
     mkstat = 2
    Endif
   Elsif dim([F:GAC]CSLFLGFLW)>0 & [F:GAC]CSLFLGFLW=3
    GMESSAGE = mess(10,123,1)
    mkstat = 2
   Endif
 Endif
Endcase
End

