#<AdxTL>@(#)2.0.0.0 $Revision$
#################################################################
# UTITC69 : Initialization of CREDAT and UPDAT fields           #
#           Module =  Common data  (9)                          #
#################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
 If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("Initialization of CREDAT and UPDAT fields in MANDATE table") From LECFIC
 Call MAJ_UTITC69(DOSSIER)

 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End


#####################################################################################
Subprog MAJ_UTITC69(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTITC69: Process Start on : "+DOSSIER,0) From GESECRAN

If clalev([F:MDT])=0 : Local File =DOSSIER+".MANDATE" [MDT] : Endif

Local Integer N

Call DEBTRANS From GLOCK

Trbegin [MDT]

For [MDT]
 Gosub UPDATE_MDT
Next

Commit

Close Local File [MDT]

Call ECR_TRACE("UTITC69: "+num$(N)+" records processed",0) From GESECRAN

End

$UPDATE_MDT
 Readlock [MDT] Curr
 If fstat = 0
  If dim([F:MDT]CREDAT)>0
   [F:MDT]CREDAT = gdat$(day(gdatetime$([F:MDT]CREDATTIM)), month(gdatetime$([F:MDT]CREDATTIM)), year(gdatetime$([F:MDT]CREDATTIM)))
  Endif
  If dim([F:MDT]UPDDAT)>0
   [F:MDT]UPDDAT = date$
  Endif
  Rewrite [MDT]
  If !fstat : N+=1 : Endif
 Endif
Return

########################################################################
# Executed Automatically during patch integration                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif

If filinfo(filpath("FIL","MANDATE","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTITC69(APPLI)

End

#######################################################################
# Executed during Folder validation
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI

#If APPLI=GDOSX3 : End : Endif
If filinfo(filpath("FIL","MANDATE","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITC69(APPLI)
End
