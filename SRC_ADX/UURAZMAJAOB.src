#<AdxTL>@(#)9.0.0.0 $Revision$
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = nomap
If fstat : End : Endif
Call  TEMPON("F") From GESECRAN
Call OUVRE_TRACE("") From LECFIC
Call ARAZAXX([F:ADS]DOSSIER)            
Call FERME_TRACE From LECFIC
Call TEMPOFF From GESECRAN
Call LEC_TRACE From LECFIC
End
#################################################

Subprog PATCH_X3(APPLI)
Value Char APPLI
Call ARAZAXX(APPLI)   
End

Subprog PATCH(APPLI)
Value Char APPLI
Call ARAZAXX(APPLI)   
End

#################################################
# Mise à jour objet pour gestion AXX
#################################################
Subprog ARAZAXX(DOSSIER)
Value Char DOSSIER
 
Local File =DOSSIER+".AOBJTAB" [AOT]  

Local Char OBJ(GLONAOB)(0..10000),VERSION(20)
Local Integer OK,NBOBJ,I

VERSION = func AFNC.PARTSEP(ver$(0),2," ")

If VERSION>="16r.113" : End : Endif

# Mise à jour objet pour gestion AXX
Call ECR_TRACE(mess(81,125,1)-"AOBJTAB:"-time$,0) From GESECRAN

Trbegin [F:AOT]
 For [F:AOT] Where [F:AOT]TABFIC   = "ATEXTRA"
  If  instr(1,toupper([F:AOT]TABLIEN),"UM$(") & [F:AOT]TABABR>="AX3"
   Delete [F:AOT]Curr
   If fstat
    Call ERREUR("AOBJTAB"-[F:AOT]ABREV-"--"-num$([F:AOT]NUMLIG),3) From DOSDIC
   Endif
   OBJ(NBOBJ) = [F:AOT]ABREV
   NBOBJ +=1
  Endif
  If [F:AOT]ABREV ="ADI" & [F:AOT]TABABR="" & instr(1,toupper([F:AOT]TABLIEN),"LNGDES")
   [F:AOT]TABLIEN = '"ATABDIV";"LNGDES";GLANGUE;[F:ADI]NUMTAB;[F:ADI]CODE'
    Rewrite [F:AOT]
   If fstat
    Call ERREUR("AOT",2) From DOSDIC
    Endif
    If !find("ADI",OBJ(0..NBOBJ))
    OBJ(NBOBJ) = [F:AOT]ABREV
     NBOBJ +=1
    Endif
  Endif
 Next AOT
Commit


For I=0 To NBOBJ-1
 Call VALID(OBJ(I),DOSSIER,1,OK) From VALOBJ
Next I

Close Local File [AOT]
End

