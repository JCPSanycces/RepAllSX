#<AdxTL>@(#)3.0.0.0 $Revision$

####################################################
## Etats RELBANK02
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char    PARAM(30) , ETAT(GLONARP)
Local Char    BANK(GLONBAN)
Local Date    DATDEB, DATFIN
Local Char    CRITERE(250)
Local Integer NUMREQ , LIGNE , J , FLG

Call GETPARAM("bank",NBPAR,PARAMETRE,BANK)
Call GETPARAM("datedeb",NBPAR,PARAMETRE,PARAM) : DATDEB=PARAM
Call GETPARAM("datefin",NBPAR,PARAMETRE,PARAM) : DATFIN=PARAM
Call GETPARAM("X3ETA",NBPAR,PARAMETRE,PARAM)
J = instr(1,PARAM,".")
If J : PARAM = left$(PARAM,J-1) : Endif
ETAT = PARAM

If clalev([F:ARM])=0 : Local File AREPORTM  [ARM] : Endif
If clalev([F:RBK])=0 : Local File RELBANK   [RBK] : Endif
If clalev([F:BAN])=0 : Local File BANK      [BAN] : Endif
If clalev([F:ACC])=0 : Local File ACCES     [ACC] : Endif

####################################################
## Affectation du no de requête
####################################################
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) 
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT
NUMREQ = val(PARAM)

####################################################
## Effacement table temporaire
####################################################
Call DEBTRANS From GLOCK
Gosub TR3

####################################################
## Parcours des relevés
####################################################

Raz CRITERE
CRITERE = "1=1"

## Critères généraux
If BANK<>""
 CRITERE += '& [RBK]BAN="'+BANK+'"'
Endif

If DATDEB<>[0/0/0]
 CRITERE += '& [RBK]OPEDAT>=['+num$(DATDEB)+']'
Endif
If DATFIN<>[0/0/0]
 CRITERE += '& [RBK]OPEDAT<=['+num$(DATFIN)+']'
Endif

Link [RBK] With [BAN]BAN0~=[F:RBK]BAN , [ACC]CODACC=GUSER;[F:BAN]ACS
&   As [LNK]  
&   Where evalue(CRITERE) & [F:ACC]CONSUL=2 & RECTYP<>2
& Order By Key CLE=RBKNUM;RECTYP

GOK = 1
LIGNE = 0
Call DEBTRANS From GLOCK
Trbegin [ARM]

# Liste des relevés avec RECTYP=1 et RECTYP=3.
Raz FLG
For [F:LNK]CLE(2)
 If [F:RBK]RECTYP=1 : FLG=1 : Endif
 If [F:RBK]RECTYP=3 & FLG=1
  Raz FLG
  LIGNE += 1
  Raz [F:ARM]
  [F:ARM]RPTCOD = ETAT
  [F:ARM]USR    = GUSER
  [F:ARM]NUMREQ = NUMREQ
  [F:ARM]NUMLIG = LIGNE
  [F:ARM]CLEA1  = [F:LNK]RBKNUM
  [F:ARM]CREDAT = date$
  Write [ARM]
  If fstat
   GOK = 0 : Call FSTA("ARM") From GLOCK
  Endif
 Endif
Next
Commit
Call TEMPOFF From GESECRAN
End

$AB_TR1
Rollback
Return

$TR3
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=ETAT & USR=GUSER
Commit
Return
  
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End





