#<AdxTL>@(#)4.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Suppression des paramètres WSDIR et WSMAC
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Delete WSDIR and WSMAC parameters") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If !mkstat
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Local Char WPARAM(20)
WPARAM="WSDIR"
Gosub ANU
WPARAM="WSMAC"
Gosub ANU
End

#-------------------#
$ANU

Local File =DOSSIER+".ADOVAL" [ADW] , =DOSSIER+".ADOPAR" [ADP]

Local Integer ADW

Trbegin [ADW]
 Read [ADP]ADP1=WPARAM
 If !fstat
  ADW = 1
  Delete [ADP] Curr
  Delete [ADW] Where PARAM=WPARAM
 Endif
Commit

If ADW
 Call ECR_TRACE(WPARAM-"parameter deleted.",0) From GESECRAN
Endif

Close Local File [ADW],[ADP]

Return

