#    GLE - 19.12.2013 - FQ89043 : Correction NBMINFLX et Optimisation
#    GLE - 15.03.2013 - FQ88667 : Corrections dans la gestion de la sélection "Toutes sociétés"
#    MWA - 01.04.2012 - FQ77877 : Roumanie CALDIV2
#    MWA - 11.08.2011 - FQ75699 : Effet de bord suite à supression de [M:DIV]HRZEXE
#    GLE - 30.11.2010 - FQ69523 : Ajout d'un message d'avertissement lorsque le traitement se termine lorsque le temps imparti est écoulé
#    GLE - 15.11.2010 - FQ66894 : Optimisation
#    MWA - 01.03.2010 - FQ59441 : Gestion des modes russes (initialisation d'un nouveau champ dans le masque CALDIV)
#    GLE - 18.05.2010 - FQ64869 : Adaptation soumission batch
#    GLE - 11.03.2010 - FQ63172 : Correction problème de non exclusion des biens sortis dans un exercice antérieur pour l'un des contextes
#                                 Au passage, remplacement de G_MIN_DATE par le test du flag ISSFIYPRE
#    GLE - 11.03.2010 - FQ60745 : Seules les immobilisations de type En modèle ne doivent pas donner lieu à la génération de flux
#*********************************************************************
#
#GTAMUNI unitaire ou GTAMMAS massif
 Raz GPILOBJ
 Call DEFVAR From GLOBIMM
 Call INIVAR From GLOBIMM
 Call LAUNCH_ACT(GTAMMAS)
End
#==============================================================#
#            Gestion de l'action métier FASFLX                 #
#==============================================================#

####  Call ECR_TRACE("Informations à tracer",0) From GESECRAN

######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION
 #Infbox "TRTFASFLX /"-ACTION
 Case ACTION
  When "INIT"         : Gosub INIT
  When "INIT_DIA"     : Gosub INIT_DIA
  When "AVANT_PAR"    : Gosub AVANT_PAR
  When "OUVRE"        : Gosub OUVRE
  When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
  When "DEBUT"        : Gosub DEBUT
  When "APRES_MODIF"  : Gosub APRES_MODIF
  When "SETBOUT"      : Gosub SETBOUT
  When "AP_CHOIX"     : Gosub AP_CHOIX
  When "BOUTON"       : Gosub BOUTON
  When "END"          : Gosub END_BOITE
  When "OK"           : Gosub OK
  When "EXEC"         : Gosub EXEC
  When "CONTROLE"     : Gosub CONTROLE
  When "CONT_BATCH"   : Gosub CONT_BATCH
  When "FIN"          : Gosub FIN
  When "TERMINE"      : Gosub TERMINE
  When "SORTIE"       : Gosub SORTIE
  When Default
 Endcase
Return


#=====================================================================
$OUVRE_BATCH             # (Massif uniquement - Soumission batch uniquement)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT
 Gosub OUVRE_TABLES
Return

#=====================================================================
$INIT_DIA                    # (Massif - Saisie des paramètres)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT
 Gosub OUVRE_TABLES
Return

#=====================================================================
$INIT                    # (Massif uniquement - interactif et exécution batch)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT

 Gosub OUVRE_TABLES

 If GSERVEUR
  Gosub CREE_GLOBTRT
 Endif

Return

#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)
  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

  ##### Ouverture des masques de la fenêtre de l'action massive pour pouvoir les garder jusqu'à
  ##### EXEC - Ouverture manuelle des masques de la fenêtre.
  ##### Nécessaire jusqu'à ce qu'une modif permette de lancer une action massive avec plus
  ##### d'un écran de critère.

  Local Char WINACT : WINACT=ACTMETNAM+"M"
  Local Integer I_MSK
  If !clalev([F:AWI]) : Local File AWINDOW : Endif
  If !clalev([F:AMK]) : Local File AMSK    : Endif
  Read [AWI]AWI0=WINACT
  If !fstat
   Local Mask =[F:AWI]MSKENT
   For I_MSK=0 To [F:AWI]NBMSK
     Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
     Local Mask =[F:AMK]CODMSK
   Next I_MSK
  Endif

  # Pas d'appel à GETPAR car les masques sont ouverts par l'action métier (GTRAITE) et on ne
  # passe pas dans INIT_DIA. Or le superviseur appelle GET_PAR dans INIT_DIA.
  If GBATCH & 1=1
   Gosub INIT_WIN From TRMPROACT# Chargement de la boite
   # FQ64869
   #Gosub LEC_PARAM From ARQTPAB
   #If sum(ABCRIT)<>""
   # Call GETPAR(ABCRIT,P1,P2) From REQUETES
   #Endif
   Call GETPAR(ABCRIT) From REQUETES
   # Fin FQ64869
   Affzo [M:MHC]
   Affzo [M:FLX1]
  Endif

Return

#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)
  If dim(TRTMODACT)<0
   Global Char TRTMODACT
   TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Endif
  Gosub ACTION From =TRTMODACT

  If !GSERVEUR
   Gosub CREE_GLOBTRT
  Endif

Return

#=====================================================================
$DEBUT # (Massif et Unitaire)
 Gosub ACTION From =TRTMODACT

 # FQ64869
 If GBATCH
  Call ACTION_BLOCK (ACB_EFFZO, "FASFLX1", "NBCNX") From GLOBIENS
 Else
  Raz [M:FLX1]
 Endif

 If ( ACTTYPGES=GTAMMAS )
   # Pas de trace détaillé
   [M:MHC]FLGDET = G_NON
   Diszo [M:MHC]FLGDET
   Affzo [M:MHC]FLGDET
 Endif

 # Lancement de tâche batch.
 If GBATCH=1
  Affzo [FLX1]
 Endif

Return

#=====================================================================
$APRES_MODIF
  Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$SETBOUT                 # (Massif interactif et unitaire : )
  Gosub ACTION From =TRTMODACT

  # On grise le bouton OK si aucun flux provisoire n'est demandé
  #If [M:FLX1]SELCNX = 0 : # FQ64869
  If [M:FLX1]NBSELCNX = 0
   If ( dim(CHBOU)>0 ) Then : Call VIREBOUT (CHBOU,"O") From GOBJET : Endif
  Endif
Return

#=====================================================================
$AP_CHOIX                 # (Unitaire : )
 Gosub ACTION From =TRTMODACT

 Global Integer GCONTROLE

 GCONTROLE = G_OUI
Return

#=====================================================================
$BOUTON                  # (Massif interactif et unitaire)

 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$END_BOITE               # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT

 GCONTROLE = G_NON
Return

#=====================================================================
$OK                      # (Massif intéractif et unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$CONTROLE
 Local Integer  N_CPY
 Local Integer  N_CNX
 Local Integer  N_PLN
 Local Shortint GERE_FLUX

 #-------------------
 # On tri le tableau caché des contextes à traiter
 #-------------------
 Sorta [M:FLX1]NBSELCNX [M:FLX1]NBSELCNX Order By [M:FLX1]SELCPY(indice), [M:FLX1]SELCNX(indice)

 #-------------------
 # Lorsque la soumission est faite par le serveur de traitements batchs, on fait les contrôles pour
 # savoir si les contextes existent toujours, si les flux sont toujours gérés et si la société
 # a subit un calcul réel.
 #-------------------
 If (GSERVEUR = 1) Then

  # DEBUT FQ88667 : le code ci-dessous a été réécrit car les contrôles s'appuyaient à tort sur le tableau visible des contextes de l'écran de soumission
  #                 alors qu'ils doivent s'appuyer sur le tableau caché qui contient la liste complète des contextes qui seront traités.
  #                 Utiliser SVN pour voir les changements.

  #-------------------
  # Controle de l'existence des contextes sélectionnés
  #-------------------
  For N_CNX = 1 To [M:FLX1]NBSELCNX
    #-------------------
    # Controle de l'existence de la société (fait éventuellement plusieurs fois pour la même société mais ce n'est qu'un find dans un tableau en mémoire)
    #-------------------
    If !find([M:FLX1]SELCPY(N_CNX-1),GSOC) Then
      Call ECR_TRACE_ERREUR([M:FLX1]SELCPY(N_CNX-1), "", 99, G_OUI, [M:FLX1]SELCPY(N_CNX-1)+" - "+mess(1,401,1)) From TRCPROCOM : # Société inconnue
      FIN=1
      Break
    Endif

    Read [CNX]CNX0=[M:FLX1]SELCPY(N_CNX-1);[M:FLX1]SELCNX(N_CNX-1)
    If fstat > 1
      Call ECR_TRACE_ERREUR([M:FLX1]SELCPY(N_CNX-1), "", 99, G_OUI, mess([M:FLX1]SELCNX(N_CNX-1),300,1)+" - "+mess(121,GML_MSGFASPR,1)) From TRCPROCOM : # Contexte inexistant
      FIN=1
      Break
    Endif
    #-------------------
    # On vérifie que le contexte contient au moins un plan qui gère les flux
    #-------------------
    GERE_FLUX = 0
    For N_PLN = 1 To [F:CNX]NBPLC
      # On regarde si au moins un plan du contexte gère les flux liasse et/ou compte
      If  ( [F:CNX]FLUTRATXS(N_PLN-1) <> '' ) or ( [F:CNX]FLUTRAACC(N_PLN-1) = G_OUI )
        GERE_FLUX = 1
        Break
      Endif
    Next N_PLN
    If !GERE_FLUX
      Call ECR_TRACE_ERREUR([F:CNX]CPY, "", 99, G_OUI, mess([M:FLX1]SELCNX(N_CNX-1),300,1)+" - "+mess(203,GML_MSGFASPR,1)) From TRCPROCOM : # Ce contexte ne gère pas de flux
      FIN=1
      Break
    Endif
    #-------------------
    # Les biens ont-ils été calculés ?
    #-------------------
    #Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;[M:FLX1]PERFLX(N_CNX-1) : # FQ97987
    Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;[M:FLX1]SELFIY(N_CNX-1)  : # FQ97987

    If func GLOBIENS.IS_CNX_CALCULATE([F:CNX]CPY, [F:CNX]CNX, [F:FIS]DATENDFIY, [F:FIS]DATENDPER([F:FIS]INDCURPER-1))=G_NON Then
      #------------------------------
      Call ECR_TRACE_ERREUR([F:CNX]CPY, "", 99, G_OUI, mess([F:CNX]CNX,3100,1)+" - "+mess(204,7770,1)) From TRCPROCOM : # Ce contexte n'a pas subit de calcul réel
      FIN=1
      Break
    Endif
  Next N_CNX

  If FIN=1 : Return : Endif

  # FIN FQ88667

  # CRITACT contient les critères de sélection suppplémentaires à appliquer à la population à sélectionner
  # On prend les biens autres que "En modèle" ou "Annulé" qui ne sont pas sortis dans un exercice antérieur pour tous
  # leurs contextes
  #CRITACT=" (OWNTYP=GVML_TDPROPR) & (ISSDAT=[0/0/0] | EXTISSFLG=G_OUI | ISSDAT>=G_MIN_DATE) " # FQ60745 FQ63172
  CRITACT=" (OWNTYP<>GVML_TDMODEL) & (OWNTYP<>GVML_TDANNUL) & (ISSFIYPRE<>G_OUI) "
 Endif

 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$CONT_BATCH
 # La prise en charge de la sauvegarde des paramétres qui ne se fait pas
 # dans le cas où l'action est incluse dans un groupe de tâche ou abonnée.
 If dim([M:MHC]NBCPY)>0
  #Call SETPAR(ABRCRIT,P1,P2) From REQUETES : # FQ64869
 Endif
Return

#=====================================================================
$EXEC                    # (Massif intéractif et batch)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$FIN                     # ()
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$TERMINE                  # ()
 Gosub ACTION From =TRTMODACT

 If dim(GCONTROLE) >0    : Kill GCONTROLE    : Endif
 If dim(RERROR) > 0      : Kill RERROR       : Endif
 If dim(LMESSAGE) > 0    : Kill LMESSAGE     : Endif
 If dim(TRT_ERROR) > 0   : Kill TRT_ERROR    : Endif

Return

#=====================================================================
$SORTIE
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
# Lancement action en batch
$CREE_GLOBTRT
  Global Integer RERROR
  Global Char    LMESSAGE(250)
  Global Integer TRT_ERROR    : # Indique s'il y a eu au moins une erreur dans le traitement
  TRT_ERROR = 1
Return

#=====================================================================
Subprog AS_PERFLX(VALEUR)
Variable Integer VALEUR()

  # On ne peut pas choisir un exercice clos
  GMENLOC(GVML_TEPREC) = 1

  # On ne peut pas choisir le suivant+1
  GMENLOC(GVML_TESUIV2) = 1
End

Subprog AP_PERFLX(VALEUR)
Variable Integer VALEUR()

Local Integer N_I

  # Lecture de l'exercice courant ou suivant
  Read [FIS]FIY1=[M:FLX1]CPYCNX(nolign-1);[M:FLX1]CNX(nolign-1);VALEUR

  # Mise à jour des informations Exercice et Période
  [M:FLX1]DATSTRFIY(nolign-1) = [F:FIS]DATSTRFIY
  [M:FLX1]DATENDFIY(nolign-1) = [F:FIS]DATENDFIY
  [M:FLX1]DATSTRPER(nolign-1) = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
  [M:FLX1]DATENDPER(nolign-1) = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)

  # Mise à jour du tableau caché
  If [M:FLX1]SELFLX(nolign-1)=G_OUI
    For N_I = 0 To [M:FLX1]NBSELCNX-1
      If [M:FLX1]SELCPY(N_I) = [M:FLX1]CPYCNX(nolign-1) and [M:FLX1]SELCNX(N_I) = [M:FLX1]CNX(nolign-1)
        [M:FLX1]SELFIY(N_I) = VALEUR
        Break
      Endif
    Next
  Endif
End

Subprog AM_SELFLX(VALEUR)
Variable Integer VALEUR()

Local Integer N_I

  If VALEUR = G_NON
    # On enlève la ligne du tableau caché
    For N_I = [M:FLX1]NBSELCNX-1 To 0 Step -1
      If [M:FLX1]SELCPY(N_I) = [M:FLX1]CPYCNX(nolign-1) and [M:FLX1]SELCNX(N_I) = [M:FLX1]CNX(nolign-1)
        Dela N_I [M:FLX1]NBSELCNX
        [M:FLX1]NBSELCNX -= 1
        Break
      Endif
    Next
  Else
    # On ajoute la ligne au tableau caché
    [M:FLX1]SELCPY([M:FLX1]NBSELCNX) = [M:FLX1]CPYCNX(nolign-1)
    [M:FLX1]SELCNX([M:FLX1]NBSELCNX) = [M:FLX1]CNX(nolign-1)
    [M:FLX1]SELFIY([M:FLX1]NBSELCNX) = [M:FLX1]PERFLX(nolign-1)
    [M:FLX1]NBSELCNX                +=1
  Endif
End

######################################################################
# Points d'entrée de l'action métier communs unitaire / massif
######################################################################

$ACTMET
 #Infbox(ACTMET)
 Case ACTMET

  When "SET_GLO_MAS"        :   Gosub SET_GLO_MAS
  When "SET_CRITACT"        :   Gosub SET_CRITACT          # UM - CRITACT critère de sélection particulier à l'action métier
  When "FILL_HEA"           :   Gosub FILL_HEA             # U  - Alimentation partie spécifique en-tête

# Locker

  When "OUVR_LOCK"          :   Gosub OUVR_LOCK            # UM - Ouverture de tables annexes pour les lock
  When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # UM  - Exclusion élément de la population à sélectionner
  When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      # UM - Lock objet lié à l'enr en ligne de la population

# Charger

  When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       # UM - Ouverture de tables annexes pour l'alim des table tmp.
  When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de données -> tables tempo

# Applique_temp

  When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       # UM - Ouverture de tables annexes
  When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramètres de l'action aux enr de la table temporaire principale
  When "TPF1_APPL_TPF1"     :   Gosub TPF1_APPL_TPF1       # UM - Application des paramètres de l'action aux enr de la table temporaire annexe

# Report_mask Report objet principal dans les masques (unitaire uniquement)

  When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'écran
  When "TPF1_ALIM_MASK"     :   Gosub TPF1_ALIM_MASK       # U  - Tansfert table temporaire annexe     -> masques de l'écran
  When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       # U  - Tansfert tables temporaires -> masques de l'écran (pour réaffichage)

# Applique_dirt Mise à jour directe (massif uniquement)

  When "DEB_APPL_DIRT"      :   Gosub DEB_APPL_DIRT        # M  - Avant le début de la transaction
  When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
  When "CPY_APPL_DIRT"      :   Gosub CPY_APPL_DIRT        # M  - Rupture société
  When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise à jour directe des tables de données avec les paramètres de l'action
  When "END_APPL_DIRT"      :   Gosub END_APPL_DIRT        # M  - Fin de la mise à jour directe des tables de données avec les paramètres de l'action

# reporter

  When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture tables annexes avant report tables tempo -> tables de données
  When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # UM - Report table temporaire principale -> table de données
  When "TPF1_ALIM_TABLE"    :   Gosub TPF1_ALIM_TABLE      # UM - Report table temporaire par plan   -> table de données par plan

#
  When "SELTOUT"            :   Gosub SELTOUT              # M  - Sélection de toutes les sociétés/tous les sites FQ88667
  When "SELRIEN"            :   Gosub SELRIEN              # M  - Aucune société/aucun site                       FQ88667
  When "AS_NBCPY"           :   Gosub AS_NBCPY             # M  - Mise à jour de la table des contextes en fonction de la société choisie
  When "AM_FLGCPY"          :   Gosub AM_FLGCPY            # M  - Mise à jour de la table des contextes en fonction de la société choisie
  When "SET_CRIT_FCY"       :   Gosub SET_CRIT_FCY         # M  - Sélection métier sur les sites

  When Default

 Endcase
Return


#=====================================================================
# Unitaire / massif :
$SET_GLO_MAS
  G_FCYTAB_DISABLE = G_OUI : # On ne peut pas modifier la sélection des sites, c'est un traitement société
  G_CTRL_CPY       = G_OUI : # Le société complète doit être habilitée pour apparaitre dans la liste des sociétés

  # Message en cas de rejet fonctionnel de toutes les sociétés
  G_MESS_FCY(0)    = 528    : # Numéro
  G_MESS_FCY(1)    = 7773   : # Chapitre
Return


#=====================================================================
# Unitaire / massif : Critère de sélection particulier à l'action métier
$SET_CRITACT
  # CRITACT contient les critères de sélection suppplémentaires à appliquer à la population à sélectionner
  # On prend les biens autres que "En modèle" ou "Annulé" qui ne sont pas sortis dans un exercice antérieur pour tous
  # leurs contextes
  #CRITACT=" (OWNTYP=GVML_TDPROPR) & (ISSDAT=[0/0/0] | EXTISSFLG=G_OUI | ISSDAT>=G_MIN_DATE) " # FQ60745 FQ63172
  CRITACT=" (OWNTYP<>GVML_TDMODEL) & (OWNTYP<>GVML_TDANNUL) & (ISSFIYPRE<>G_OUI) "
Return

#=====================================================================
# Unitaire : Permet d'alimenter des zones spécifiques de l'en-tête de la fenêtre
$FILL_HEA
Return

#=====================================================================
# Unitaire et massif : Sert à ouvrir des tables utilisées dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
$OUVR_LOCK
  Gosub OUVRE_TABLES

  LOCK_CPY = 1 : # Lock de toute la société FQ89043
Return

#=====================================================================
# Unitaire / massif : contrôle élément pour retrait de la population
$MAS1_CONTROLE
  # FQ66894
  Local Integer N_CNX
  GOK=0
  For N_CNX = 0 To [M:FLX1]NBSELCNX-1
    If [M:FLX1]SELCPY(N_CNX) = [F:MAS1]CPY
      If ([M:FLX1]FLGFORCE = G_OUI) or mid$([F:MAS1]FLGCNXFLX,[M:FLX1]SELCNX(N_CNX),1) = num$(GVML_FLXNOTG)
        GOK=1
        Break
      Endif
    Endif
  Next
Return

#=====================================================================
# Unitaire / massif : Lock d'objet lié à l'enregistrement en ligne
#                     Alimenter RMES si un message soit apparaître
$MAS1_LOCK_AUTRE
Return

#=====================================================================
# Unitaire / massif : Sert à ouvrir des tables utilisées dans MAS1_ALIM_TMP1
$OUVR_ALIM_TMP1
Return

#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
$MAS1_ALIM_TMP1
Return

#=====================================================================
# Unitaire / massif : Ouverture de tables annexes
$OUVR_APPL_TMP1
Return

#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1
Return

#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire annexe (par plan)
$TPF1_APPL_TPF1
Return

#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TMP1_ALIM_MASK
Return

#=====================================================================
# Unitaire : Permet de reporter les infos de TPF1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TPF1_ALIM_MASK
Return

#=====================================================================
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs
#            y ont été reportées.
REAF_ALIM_MASK
Return

#===================================================================== FQ66894
# Massif : Sert à faire des actions avant le début de la transaction
$DEB_APPL_DIRT
  # Avant de générer les flux, il faut regarder s'il existe des modifications de gestion
  # des flux au niveau des contextes
  # Si c'est le cas, il faut mettre à jour le flag FLGCNXFLX des biens
  Local Integer N_CNX
  Local Integer RET

  For N_CNX = 0 To [M:FLX1]NBSELCNX-1
    Call UPD_WAI_TRT([M:FLX1]SELCPY(N_CNX),[M:FLX1]SELCNX(N_CNX),1,"*","FLU",RET) From UPDWAITRT
  Next
Return

#=====================================================================
# Massif : Sert à ouvrir des tables utilisées dans MAS1_APPL_MAS1
$OUVR_APPL_DIRT
  Local Integer N_CNX

  # FQ66894 : passage de Local à Global toutes les déclarations de masque
  If !clalev([M:CNX]) : Global Mask CALCNX    [CNX] : Endif
  If !clalev([M:DIV]) : Global Mask CALDIV    [DIV] : Endif
  If !clalev([M:DIV2]) : Global Mask CALDIV2   [DIV2] : Endif
  If !clalev([M:FIY]) : Global Mask CALFIY    [FIY] : Endif
  If !clalev([M:FPC]) : Global Mask FASPARCPY [FPC] : Endif

  For N_CNX = 0 To [M:FLX1]NBSELCNX-1
    Case [M:FLX1]SELCNX(N_CNX)
      When G301CPT : If !clalev([M:EGCF]) : Global Mask CALFIY [EGCF] : Endif
      When G300IAS : If !clalev([M:EIAS]) : Global Mask CALFIY [EIAS] : Endif
      When G300TEC : If !clalev([M:ETEC]) : Global Mask CALFIY [ETEC] : Endif
      When G300RET : If !clalev([M:ERET]) : Global Mask CALFIY [ERET] : Endif
      When G300SUB : If !clalev([M:ESUB]) : Global Mask CALFIY [ESUB] : Endif
      When G300LIB : If !clalev([M:ELI1]) : Global Mask CALFIY [ELI1] : Endif
      When G300SU1 : If !clalev([M:ELI2]) : Global Mask CALFIY [ELI2] : Endif
      When G300SU2 : If !clalev([M:ELI3]) : Global Mask CALFIY [ELI3] : Endif
      When G300SU3 : If !clalev([M:ELI4]) : Global Mask CALFIY [ELI4] : Endif
      When G300SU4 : If !clalev([M:ELI5]) : Global Mask CALFIY [ELI5] : Endif
      When G300SU5 : If !clalev([M:ELI6]) : Global Mask CALFIY [ELI6] : Endif
    Endcase
  Next

  # FQ66894 : prise de la date et de l'heure
  Local Date    FLXSTRDAT : FLXSTRDAT = date$
  Local Integer FLXSTRTIM : FLXSTRTIM = time/60
  Local Integer NBMINFLX
  Local Char    LPARM
  Call PARAM("","NBMINFLX",LPARM) From ADOVAL
  NBMINFLX = val(LPARM)

  # Nombre de biens par Commit
  # Valeur du champ "Dimension Ecran" de la transaction "Code activité" pour le code activité "BPC"
  Local Integer NBBCOTRA
  Local Integer NBBCO : NBBCO = 0
  NBBCOTRA = func AFNC.ACTIV("BPC")
  If !(NBBCOTRA) Then
    NBBCOTRA = 9999
  Endif
Return

#=====================================================================
# Massif : Rupture société
$CPY_APPL_DIRT
  Local Decimal PERROR
  Local Integer N_CNX
  Local Char    LPARAM

  # Nombre d'exercices à calculer
  [M:DIV]CSTFIYMAX = func AFNC.ACTIV("NFIY") : # FQ64639
  # FQ75699
  #Call PARAM([F:MAS1]CPY,"NBEXESTO",LPARAM) From ADOVAL
  #[M:DIV]HRZEXE    = val(LPARAM)
  #If ( [M:DIV]HRZEXE > 3 ) Then : [M:DIV]HRZPER = 3 : Else : [M:DIV]HRZPER = [M:DIV]HRZEXE : Endif

  # Mise en cache des contexte
  Call CAL_LEC_CONTEXTES([F:MAS1]CPY,PERROR) From GLOBB0

  For N_CNX = 0 To [M:FLX1]NBSELCNX-1
    If [M:FLX1]SELCPY(N_CNX) = [F:MAS1]CPY
      Call CAL_LEC_EXERCICES_PERIODES ( [F:MAS1]CPY, [M:FLX1]SELCNX(N_CNX) ) From GLOBB0
      If ( [M:DIV]ERROR ) Then
        Call ECR_TRACE_ERREUR([F:FAS]CPY, [F:FAS]AASREF, [F:CNX]PLNCAA(N_PLN), G_OUI,
&                       mess(124,7770,1)-num$([M:FLX1]SELCNX(N_CNX))) From TRCPROCOM
        TRT_ERROR = 0
        GOK = 0
        Return
      Endif

      Case [M:FLX1]SELCNX(N_CNX)
        When G301CPT : Raz [M:EGCF] : Transmask [M:FIY] To [M:EGCF]
        When G300IAS : Raz [M:EIAS] : Transmask [M:FIY] To [M:EIAS]
        When G300TEC : Raz [M:ETEC] : Transmask [M:FIY] To [M:ETEC]
        When G300RET : Raz [M:ERET] : Transmask [M:FIY] To [M:ERET]
        When G300SUB : Raz [M:ESUB] : Transmask [M:FIY] To [M:ESUB]
        When G300LIB : Raz [M:ELI1] : Transmask [M:FIY] To [M:ELI1]
        When G300SU1 : Raz [M:ELI2] : Transmask [M:FIY] To [M:ELI2]
        When G300SU2 : Raz [M:ELI3] : Transmask [M:FIY] To [M:ELI3]
        When G300SU3 : Raz [M:ELI4] : Transmask [M:FIY] To [M:ELI4]
        When G300SU4 : Raz [M:ELI5] : Transmask [M:FIY] To [M:ELI5]
        When G300SU5 : Raz [M:ELI6] : Transmask [M:FIY] To [M:ELI6]
      Endcase
    Endif
  Next
Return

#=====================================================================
# Massif : Application paramètres action aux tables de données : mise à jour directe
$MAS1_APPL_DIRT
  # FQ66894 : durée limite de traitement
  If NBMINFLX > 0
    Local Integer DUREE
    # DEBUT FQ89043
    #DUREE = (1440-FLXSTRTIM)+((date$-FLXSTRDAT-1)*1440)+(time/60)
    If date$ = FLXSTRDAT
      # Dans la même journée
      DUREE = (time/60)-FLXSTRTIM
    Else
      # Plus d'une journée
      #          1er jour     +   0 à n jours complets    + dernier jour
      DUREE = (1440-FLXSTRTIM)+((date$-FLXSTRDAT-1)*1440)+(time/60)
    Endif
    # FIN FQ89043
    If DUREE > NBMINFLX
      # "Dépassement du temps limite pour la génération des flux géré via le paramètre NBMINFLX."
      Call ECR_TRACE("", GTRC_TRTERRE, "\"+mess(816,GML_MSGFAS,1),-1,1) From TRACEABX3 : # FQ69523
      GOK = 99
      Return
    Endif
  Endif

  Gosub GENERATION_FLUX_PROVISOIRE

  NBBCO += 1

  # FQ66894 : commit intermédiaire
  If NBBCO > NBBCOTRA
    If FLGSIM=G_OUI
      Rollback
    Else
      Commit
    Endif
    NBBCO = 0
    Trbegin [MAS1]
  Endif
Return

#=====================================================================
# Massif : Fin de l'application paramètres action aux tables de données : mise à jour directe
$END_APPL_DIRT
  Local Integer N_CNX

  If clalev([M:CNX])   : Close Mask [CNX] : Endif
  If clalev([M:DIV])   : Close Mask [DIV] : Endif
  If clalev([M:DIV2])  : Close Mask [DIV2] : Endif   : # FQ77877
  If clalev([M:FIY])   : Close Mask [FIY] : Endif
  If clalev([M:FPC])   : Close Mask [FPC] : Endif

  For N_CNX = 0 To [M:FLX1]NBSELCNX-1
    Case [M:FLX1]SELCNX(N_CNX)
      When G301CPT : If clalev([M:EGCF]) : Close Mask [EGCF] : Endif
      When G300IAS : If clalev([M:EIAS]) : Close Mask [EIAS] : Endif
      When G300TEC : If clalev([M:ETEC]) : Close Mask [ETEC] : Endif
      When G300RET : If clalev([M:ERET]) : Close Mask [ERET] : Endif
      When G300SUB : If clalev([M:ESUB]) : Close Mask [ESUB] : Endif
      When G300LIB : If clalev([M:ELI1]) : Close Mask [ELI1] : Endif
      When G300SU1 : If clalev([M:ELI2]) : Close Mask [ELI2] : Endif
      When G300SU2 : If clalev([M:ELI3]) : Close Mask [ELI3] : Endif
      When G300SU3 : If clalev([M:ELI4]) : Close Mask [ELI4] : Endif
      When G300SU4 : If clalev([M:ELI5]) : Close Mask [ELI5] : Endif
      When G300SU5 : If clalev([M:ELI6]) : Close Mask [ELI6] : Endif
    Endcase
  Next

  If TRT_ERROR < 1
    GOK = 0
  Endif
Return

#=====================================================================
# Unitaire / massif : Ouverture de tables annexes avant report du contenu des tables temporaires dans les tables de données
$OUVR_ALIM_TABLE
Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$TMP1_ALIM_TABLE
Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire annexe dans la table de données annexe
$TPF1_ALIM_TABLE
Return

#===================================================================== FQ88667
# Massif : Sélection de toutes les sociétés/tous les sites
$SELTOUT
  VALEUR = G_OUI
  Gosub MAJ_FLX1
Return


#===================================================================== FQ88667
# Massif : Aucune société/aucun site
$SELRIEN
  VALEUR = G_NON
  Gosub MAJ_FLX1
Return

#===================================================================== FQ88667
# Mise à jour du tableau caché pour toutes les sociétés
$MAJ_FLX1
  Local Integer N_CPY, SAV_NOLIGN

  SAV_NOLIGN = nolign

  # Remise à zéro du tableau de sélection caché
  Raz [M:FLX1]NBSELCNX

  For N_CPY = 1 To [M:MHC]NBCPY
    # On saute la société courante sinon elle sera ajoutée deux fois : une fois maintenant et une fois sur le "vrai" appel à AM_FLGCPY
    If !(SAV_NOLIGN = N_CPY)
      nolign = N_CPY
      Gosub AM_FLGCPY
    Endif
  Next

  nolign = SAV_NOLIGN
  Gosub AM_FLGCPY
Return

#=====================================================================
# Massif : mise à jour du tableau des contextes dans la fenêtre de sélection
$AS_NBCPY
  Local Integer N_I, N_CNX, N_SELCNX
  Local Char SEL_CPY

  SEL_CPY = [M:MHC]CPY(nolign-1)

  # Lecture des contextes et alimentation du tableau
  N_CNX = 1

  For [CNX] Where CPY = SEL_CPY
    For N_I = 0 To [F:CNX]NBPLC-1
      # On regarde si au moins un plan du contexte gère les flux liasse et/ou compte
      If  ( [F:CNX]FLUTRATXS(N_I) <> '' ) or ( [F:CNX]FLUTRAACC(N_I) = G_OUI )
        # Un calcul réel a-t'il été fait sur ce contexte ?
        Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;GVML_TECOURA

        If func GLOBIENS.IS_CNX_CALCULATE([F:CNX]CPY, [F:CNX]CNX, [F:FIS]DATENDFIY, [F:FIS]DATENDPER([F:FIS]INDCURPER-1))=G_OUI
&       or GBATCH=1 Then
          # Si tous les biens ont été calculés ou qu'on est en phase d'abonnement
          # => On pourrait demander une génération des flux

          If [M:MHC]FLGCPY(nolign-1) = G_OUI
            # Mise à jour du flag de sélection à partir du tableau caché
            For N_SELCNX = 0 To [M:FLX1]NBSELCNX-1
              If [M:FLX1]SELCPY(N_SELCNX) = SEL_CPY and [M:FLX1]SELCNX(N_SELCNX) = [F:CNX]CNX
                [M:FLX1]PERFLX(N_CNX-1) = [M:FLX1]SELFIY(N_SELCNX)
                [M:FLX1]SELFLX(N_CNX-1) = G_OUI

                If [M:FLX1]PERFLX(N_CNX-1)=GVML_TESUIV
                  Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;GVML_TESUIV
                Endif
                Break : # FQ88667 inutile de chercher plus longtemps, on a trouvé la ligne
              Endif
            Next

            If N_SELCNX = [M:FLX1]NBSELCNX : # FQ88667
              # On n'a pas trouvé de ligne pour la société et le contexte dans le tableau caché, ce qui veut
              # dire que la société est cochée mais pas le contexte
              [M:FLX1]PERFLX(N_CNX-1) = GVML_TECOURA
              [M:FLX1]SELFLX(N_CNX-1) = G_NON
            Endif

            Actzo [M:FLX1]SELFLX(N_CNX-1) : # FQ88667
          Else
            [M:FLX1]PERFLX(N_CNX-1) = GVML_TECOURA
            [M:FLX1]SELFLX(N_CNX-1) = G_NON
            Grizo [M:FLX1]SELFLX(N_CNX-1) : # FQ88667
          Endif

          [M:FLX1]CPYCNX(N_CNX-1)    = SEL_CPY          : # Société (caché)
          [M:FLX1]CNX(N_CNX-1)       = [F:CNX]CNX       : # Contexte
          [M:FLX1]DATSTRFIY(N_CNX-1) = [F:FIS]DATSTRFIY
          [M:FLX1]DATENDFIY(N_CNX-1) = [F:FIS]DATENDFIY
          [M:FLX1]DATSTRPER(N_CNX-1) = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
          [M:FLX1]DATENDPER(N_CNX-1) = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)

          N_CNX += 1
          Break
        Endif
      Endif
    Next N_I
  Next

  [M:FLX1]NBCNX = N_CNX - 1

  # FQ88667 Remonté dans la boucle ci-dessus
#  If [M:MHC]FLGCPY(nolign-1) = G_NON
#    Grizo [M:FLX1]SELFLX(0)
#  Else
#    Actzo [M:FLX1]SELFLX(0)
#  Endif

  Affzo [M:FLX1]
Return

#=====================================================================
# Massif : mise à jour du tableau des contextes dans la fenêtre de sélection
$AM_FLGCPY

  Local Integer N_I, N_CNX
  Local Char SEL_CPY

  SEL_CPY = [M:MHC]CPY(nolign-1)

  # FQ88667
  For N_CNX = 0 To [M:FLX1]NBCNX-1
    [M:FLX1]SELFLX(N_CNX) = VALEUR

    # On met à jour le tableau caché
    If VALEUR = G_OUI
      # Ajout des entrées dans le tableau caché pour cette société
      [M:FLX1]SELCPY([M:FLX1]NBSELCNX) = SEL_CPY
      [M:FLX1]SELCNX([M:FLX1]NBSELCNX) = [M:FLX1]CNX(N_CNX)
      [M:FLX1]SELFIY([M:FLX1]NBSELCNX) = GVML_TECOURA
      [M:FLX1]NBSELCNX                +=1

      Actzo [M:FLX1]SELFLX(N_CNX)
    Else
      # Suppression des entrées dans le tableau caché pour cette société
      For N_I = [M:FLX1]NBSELCNX-1 To 0 Step -1
        If [M:FLX1]SELCPY(N_I) = SEL_CPY
          Dela N_I [M:FLX1]NBSELCNX
          [M:FLX1]NBSELCNX -= 1
        Endif
      Next

      Diszo [M:FLX1]SELFLX(N_CNX)
    Endif
  Next

  Affzo [M:FLX1]
#  If VALEUR = G_NON
#    # Suppression des entrées dans le tableau caché pour cette société
#    For N_I = [M:FLX1]NBSELCNX-1 To 0 Step -1
#      If [M:FLX1]SELCPY(N_I) = SEL_CPY
#        Dela N_I [M:FLX1]NBSELCNX
#        [M:FLX1]NBSELCNX -= 1
#      Endif
#    Next
#    Affzo [M:FLX1]
#  Else
#    For N_CNX = 0 To [M:FLX1]NBCNX-1
#      [M:FLX1]SELFLX(N_CNX) = G_OUI
#
#      # On met à jour le tableau caché
#      [M:FLX1]SELCPY([M:FLX1]NBSELCNX) = SEL_CPY
#      [M:FLX1]SELCNX([M:FLX1]NBSELCNX) = [M:FLX1]CNX(N_CNX)
#      [M:FLX1]SELFIY([M:FLX1]NBSELCNX) = GVML_TECOURA
#      [M:FLX1]NBSELCNX                +=1
#    Next
#
#    Actzo [M:FLX1]SELFLX(0)
#    Affzo [M:FLX1]SELFLX(0)
#  Endif
  # FIN FQ88667
Return

#=====================================================================
# Massif : filtre sur les sites ayant subit un calcul pour la période / exercice courant.
#     Site : [F:FCY]FCY
#     GOK  : 1 - on garde
#            0 - on ne garde pas
$SET_CRIT_FCY
  Local Integer N_I

  GOK = 0
  # On examine les contextes de la société pour savoir si au moins un contexte contient un plan qui gère les flux
  For [CNX]CNX0 Where CPY=[F:FCY]LEGCPY
    For N_I = 0 To [F:CNX]NBPLC-1
      # On regarde si au moins un plan du contexte gère les flux liasse et/ou compte
      If  ( [F:CNX]FLUTRATXS(N_I) <> '' ) or ( [F:CNX]FLUTRAACC(N_I) = G_OUI )
        #------------------------------
        # Un plan gère les flux. Il reste à savoir si les biens sont tous calculés
        #------------------------------
        # En préparation phase d'abonnement, on ne controle pas si les biens sont tous calculés
        #------------------------------
        If (GBATCH = 1) : GOK = 1 : Break 2 : Endif
        #------------------------------
        Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;GVML_TECOURA
        #------------------------------
        If func GLOBIENS.IS_CNX_CALCULATE([F:CNX]CPY, [F:CNX]CNX, [F:FIS]DATENDFIY, [F:FIS]DATENDPER([F:FIS]INDCURPER-1))=G_OUI Then
          GOK = 1
          Break 2 : # On sort des deux boucles For
        Endif
      Endif
    Next N_I
    #-------------------
    # Suite de la boucle
  Next CNX0
  #------------------
Return

########################################
#       TRAITEMENTS METIERS
########################################

#=====================================================================
# Traitement métier principal
#
$GENERATION_FLUX_PROVISOIRE
  Local Integer N_CNX, N_PLN, FLX_CNX_BCO : # FQ66894

  # Le traitement des flux TRTFLUX s'attend à trouver les classes [F:FAS] et [F:DEP] ouvertes et
  # alimentées avec le bien et le plan d'amortissement de la période / de l'exercice courant
  [F:FAS] = [F:MAS1]

  # Traitement de chaque contexte du bien en fonction des choix de la soumission
  # ------------------------------------------------------------------------------------------
  For N_CNX = 0 To [M:FLX1]NBSELCNX-1
    # FG66894
    If ([M:FLX1]FLGFORCE = G_OUI)
&   or (val(mid$([F:MAS1]FLGCNXFLX, [M:FLX1]SELCNX(N_CNX), 1)) = GVML_FLXNOTG)
&   or ([M:FLX1]SELFIY(N_CNX) = GVML_TESUIV)
      FLX_CNX_BCO = 1 : # FQ66894
      If [M:FLX1]SELCPY(N_CNX) = [F:FAS]CPY
        # Initialisation des classes [F:CNX] et [F:FIY]
        Gosub INIT_CNX_FIY

        # FQ63172 On ne traite pas les biens sortis dans un exercice antérieur
        If not ([F:FAS]ISSDAT<>[0/0/0] and [F:FAS]EXTISSFLG=G_NON and [F:FAS]ISSDAT<[F:FIS]DATSTRFIY)
          For N_PLN = 0 To [F:CNX]NBPLC-1 : # boucle sur les plans du contexte
            # FQ89043 : évite de rentrer dans FLUX_PROVISOIRE_PLAN et de faire un READ sur DEPREC si aucun flux n'est géré sur le plan
            If ([F:CNX]FLUTRATXS(N_PLN) <> '') or ([F:CNX]FLUTRAACC(N_PLN) = G_OUI)
              Gosub FLUX_PROVISOIRE_PLAN
            Endif
          Next N_PLN
        Endif

        # FQ66894 : mise à jour du flag d'optimisation s'il n'y a pas eu d'erreur lors de la génération et si la génération
        #           a eu lieu sur la période courante
        If FLX_CNX_BCO and ( [M:FLX1]SELFIY(N_CNX) = GVML_TECOURA )
          [F:MAS1]FLGCNXFLX = func GLOFUNC.SETRNGSTR([F:MAS1]FLGCNXFLX, [M:FLX1]SELCNX(N_CNX), num$(GVML_FLXGENE))
          Rewrite [F:MAS1]
          If fstat
            Case fstat
              When 1
                RMES=mess(226,403,1)-[F:MAS1]AASREF  # "Enregistrement en cours d'utilisation"
                GOK=-1
              When 3
                RMES=mess(129,403,1)-[F:MAS1]AASREF
                GOK=0
              When Default
            Endcase
            Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, 0, G_OUI, RMES) From TRCPROCOM
          Endif
        Endif
      Endif
    Endif
  Next N_CNX
Return

#=====================================================================
# Generation des flux pour un bien et un plan
#
$FLUX_PROVISOIRE_PLAN

  Read [F:DEP]DEP0=[F:FAS]AASREF;[F:CNX]PLNCAA(N_PLN);[F:FIS]DATENDFIY;[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
  If fstat Then
    Call ECR_TRACE_ERREUR([F:FAS]CPY, [F:FAS]AASREF, [F:CNX]PLNCAA(N_PLN), G_OUI,
&                         mess(193,7770,1)) From TRCPROCOM
    TRT_ERROR = 0
    Return
  Endif

  If [F:CNX]FLUTRATXS(N_PLN) <> ''   : # Flux liasse
    Call GENERE_FLUX ([F:CNX]PLNCAA(N_PLN), GML_TFPLIASS, [F:CNX]FLUTRATXS(N_PLN), GVML_TXSPRO, RERROR) From TRTFLUX
    If RERROR < 0 Then
      Call GERE_MSG_ERREUR_FLUX(RERROR, LMESSAGE) From TRTFLUX
      Call ECR_TRACE_ERREUR([F:FAS]CPY, [F:FAS]AASREF, [F:CNX]PLNCAA(N_PLN), G_OUI,
&                       mess(519,7773,1)-"-A-"-LMESSAGE
&                      ) From TRCPROCOM
      TRT_ERROR = 0
      FLX_CNX_BCO = 0 : # FQ66894
    Endif
  Endif

  If [F:CNX]FLUTRAACC(N_PLN) = G_OUI : # Flux compte
    Call GENERE_FLUX ([F:CNX]PLNCAA(N_PLN), GML_TFCOMPTE, "", GVML_TXSPRO, RERROR) From TRTFLUX
    If RERROR < 0 Then
      Call GERE_MSG_ERREUR_FLUX(RERROR, LMESSAGE) From TRTFLUX
      Call ECR_TRACE_ERREUR([F:FAS]CPY, [F:FAS]AASREF, [F:CNX]PLNCAA(N_PLN), G_OUI,
&                       mess(520,7773,1)-"-B-"-LMESSAGE
&                      ) From TRCPROCOM
      TRT_ERROR = 0
      FLX_CNX_BCO = 0 : # FQ66894
    Endif
  Endif
Return

##################################################################
# Traitement du ou des masques de paramètres de l'action massive #
# -----> PARAMETRES  FASFLX                                      #
##################################################################

#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#
#

#===================
$OUVRE_TABLES
#===================
  # Ouverture de tables liées à explorer ou à mettre à jour  par l'action massive
  If !(clalev([F:CNX]))   : Local File CONTEXT   [CNX]   : Endif
  If !(clalev([F:FIS]))   : Local File FISCYEAR  [FIS]   : Endif
  If !(clalev([F:FAS]))   : Local File FXDASSETS [FAS]   : Endif
  If !(clalev([F:DEP]))   : Local File DEPREC    [DEP]   : Endif
Return

#===================
$INIT_CNX_FIY
#===================
  # On lit dans le masque les informations sur les contextes
  nolign = find([M:FLX1]SELCNX(N_CNX),[M:CNX]CNX)
  Raz [F:CNX]
  [F:CNX]=[M:CNX]
  I = find([M:CNX]CNX(nolign-1),[M:DIV]PLNCNT)
  For N_PLN=1 To [M:CNX]NBPLC(nolign-1)
    [F:CNX]PLNCAA   (N_PLN-1) = [M:DIV]PLNCAA   (I-1)   : #  Code plan
    [F:CNX]ORIBASDPR(N_PLN-1) = [M:DIV]ORIBASDPR(I-1)   : #  Code plan
    [F:CNX]PLNSTD   (N_PLN-1) = [M:DIV]PLNSTD   (I-1)   : #  Norme
    [F:CNX]FLUTRATXS(N_PLN-1) = [M:DIV]FLUTRATXS(I-1)   : #  Suivi flux liasse
    [F:CNX]FLUTRAACC(N_PLN-1) = [M:DIV]FLUTRAACC(I-1)   : #  Suivi flux compte
    I += 1
  Next

  # Initialisation de [F:FIS] à partir du masque cache [M:FIY]
  Raz [M:FIY]
  Case [M:FLX1]SELCNX(N_CNX)
      When G301CPT : Transmask [M:EGCF] To [M:FIY]
      When G300IAS : Transmask [M:EIAS] To [M:FIY]
      When G300TEC : Transmask [M:ETEC] To [M:FIY]
      When G300RET : Transmask [M:ERET] To [M:FIY]
      When G300SUB : Transmask [M:ESUB] To [M:FIY]
      When G300LIB : Transmask [M:ELI1] To [M:FIY]
      When G300SU1 : Transmask [M:ELI2] To [M:FIY]
      When G300SU2 : Transmask [M:ELI3] To [M:FIY]
      When G300SU3 : Transmask [M:ELI4] To [M:FIY]
      When G300SU4 : Transmask [M:ELI5] To [M:FIY]
      When G300SU5 : Transmask [M:ELI6] To [M:FIY]
  Endcase

  N_EXE = find([M:FLX1]SELFIY(N_CNX),[M:FIY]STAFIY)

  If N_EXE = 0 Then
      Call ECR_TRACE_ERREUR([F:FAS]CPY, [F:FAS]AASREF, [F:CNX]PLNCAA(N_PLN), G_OUI,
&                         mess(124,7770,1)-[M:FLX1]DATSTRFIY(N_CNX)) From TRCPROCOM
      TRT_ERROR = 0
      GOK = 0
      Return
  Endif

  Raz [F:FIS]

  [F:FIS]DATSTRFIY    = [M:FIY]DATSTRFIY(N_EXE-1)
  [F:FIS]DATENDFIY    = [M:FIY]DATENDFIY(N_EXE-1)
  [F:FIS]INDCURPER    = [M:FIY]INDCURPER(N_EXE-1)
  [F:FIS]NBRPER       = [M:FIY]NBRPER(N_EXE-1)
  For N_PER = 0 To [F:FIS]NBRPER-1
    [F:FIS]DATSTRPER(N_PER) = [M:FIY]DATSTRPER([M:FIY]INDDEBPER(N_EXE-1)+N_PER-1)
    [F:FIS]DATENDPER(N_PER) = [M:FIY]DATENDPER([M:FIY]INDDEBPER(N_EXE-1)+N_PER-1)
  Next
Return

##########################################################################
##########################################################################

#RRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRR
# Points d'entrée objet de reprise
#RRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRR

#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================

#==============================================================#
# Cette action est appelée pour chaque enregistrement lu dans  #
# la table temporaire par plan pour l'objet métier sur lequel  #
# on vient de cliquer.                                         #
# Alimenter ici les zones du tableau par plan spécifique à l'  #
# action                                                       #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#
$LOADPLN
  # Chargement du masque tableau des infos "spécifiques" par plan suite à clique sur bien
  # Appelée pour chaque enreg de la table temporaire
  # Masque: [M:MFS0]   Table: [F:TPF]   Ligne courante: nolign
Return

#==============================================================#
# Cette action est appelée pour chaque enregistrement de la    #
# table temporaire à mettre à jour.                            #
# Alimenter ici les zones spécifiques à l'action de la table   #
# temporaire par plan à partir des zones du tableau par plan   #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#
$SAVEPLN
  # MAJ table temporaire avec les infos "spécifiques" du masque tableau des infos par plan
  # Appelée pour chaque enreg de la table temporaire
  # Table: [F:TPF]   Masque: [M:MFS0]   Ligne courante: nolign
Return


################################################################################
# Traitement du masque de reprise de l'action massive                          #
# -----> MFASTRFCR                                                             #
################################################################################

#==============================================================#
# Actions de contrôle sur champ                                #
#==============================================================#
#


##########################################################################

##########################################################################


#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#

################################################################################
# Traitement de gestion de la trace - informations particulières à l'action    #
################################################################################


#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#

#===============================
$GESTRACE
Local Char    LDES
Local Integer I, LERROR, ERROR
Local Char    LINE(115)
Local Integer IFIRST


  Case TRTYP
    When 1         # Ouverture de la trace
      Call OUVRE_TRACE(mess(518,7773,1),1) From TRACEABX3
    When 3         # Paramètres de l'action
      Gosub I_PARAM
    When 20        # Options de l'action
      Gosub P_PARAM
    When Default
  Endcase
Return

# FQ66894
$P_PARAM
  Local Char    LPARM
  Call PARAM("","NBMINFLX",LPARM) From ADOVAL
  LINE  = left$(mess(146,GML_MSGCAL,1)+space$(30),30)+":"
  LINE -= num$(ar2(val(LPARM)/60))
  Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3
  LINE  = left$(mess(147,GML_MSGCAL,1)+space$(30),30)+":"
  LINE -= num$(func AFNC.ACTIV("BPC"))
  Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3
  LINE  = left$(mess(814,GML_MSGFAS,1)+space$(30),30)+":"
  LINE -= mess([M:FLX1]FLGFORCE,1,1)
  Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3
Return

$I_PARAM
  Local Integer N_I, N_P
  Local Char FMTDAT2

  FMTDAT2="D:DD[/]MM[/]YY"

  LINE = "-----------------------------------------------------------------------------------------------------------"
  Call ECR_TRACE(RUPTURE_CPY, GTRC_CRACTIO, LINE,0,1) From TRACEABX3
  LINE  = left$(mess(521,7773,1)+space$(24),24) : # Contexte
  LINE += left$(mess(184,7773,1)+space$(15),15) : # Plan
  LINE += left$(mess(519,7773,1)+space$(15),15) : # Flux liasse
  LINE += left$(mess(520,7773,1)+space$(15),15) : # Flux compte
  LINE += left$(mess(63,7774,1)+space$(20),20)  : # Exercice
  LINE += left$(mess(64,7774,1)+space$(20),20)  : # Période
  Call ECR_TRACE(RUPTURE_CPY, GTRC_CRACTIO, LINE,0,1) From TRACEABX3
  LINE = "-----------------------------------------------------------------------------------------------------------"
  Call ECR_TRACE(RUPTURE_CPY, GTRC_CRACTIO, LINE,0,1) From TRACEABX3

  For N_CNX = 0 To [M:FLX1]NBSELCNX-1
    If [M:FLX1]SELCPY(N_CNX) = RUPTURE_CPY Then
      # Initialisation des classes [F:CNX] et [F:FIS]
      Gosub INIT_CNX_FIY

      For N_P = 0 To [F:CNX]NBPLC-1
        # On regarde si au moins un plan du contexte gère les flux liasse et/ou compte
        If  ( [F:CNX]FLUTRATXS(N_P) <> '' ) or ( [F:CNX]FLUTRAACC(N_P) = G_OUI )
          LINE  = left$(mess([F:CNX]CNX,3100,1)+space$(24),24)         : # Contexte
          LINE += left$(mess([F:CNX]PLNCAA(N_P),3101,1)+space$(15),15) : # Plan
          If [F:CNX]FLUTRATXS(N_P) = ""                               : # Flux liasse
            LINE += left$(mess(1,1,1)+space$(15),15)
          Else
            LINE += left$([F:CNX]FLUTRATXS(N_P)+space$(15),15)
          Endif
          LINE += left$(mess([F:CNX]FLUTRAACC(N_P),1,1)+space$(15),15) : # Flux compte
          LINE += left$(format$(FMTDAT2,[F:FIS]DATSTRFIY)+"->"+format$(FMTDAT2,[F:FIS]DATENDFIY)+space$(20),20) : # Exercice
          LINE += left$(format$(FMTDAT2,[F:FIS]DATSTRPER([F:FIS]INDCURPER-1))+"->"+format$(FMTDAT2,[F:FIS]DATENDPER([F:FIS]INDCURPER-1))+space$(20),20) : # Période
          Call ECR_TRACE(RUPTURE_CPY, GTRC_CRACTIO, LINE,0,1) From TRACEABX3
        Endif
      Next N_P
    Endif
  Next N_CNX
Return

######################################################################
# Sous-pro et routines communes
######################################################################

#=====================================================================
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

 Case PACTTYP
   When GTAMUNI
     Infbox mess(1,GML_MSGACT,1)
   When GTAMMAS
     Local Char PARAM(30)(1..5)
     Local Char VALEUR
     PARAM(1)=GTAMMAS            # Massif / unitaire
     PARAM(2)="FASFLX"           # Nom de l'action métier
     PARAM(3)=num$(GVML_OMBIEN)  # Objet métier de référence
     PARAM(4)=num$(G_NON)        # Multi société
     PARAM(5)=num$(G_OUI)        # Plan d'amortissement
     #  Traitement      Fenêtre
     Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASFLX","FASFLXM",4,"") From GTRAITE
   When Default
  Endcase
End
