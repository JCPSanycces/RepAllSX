#<AdxTL>@(#)3.0.0.0 $Revision$
#############################################################################
#                                                                           #
#     DCLVATBOXDEB                                                          #
#         Déclaration TVA sur Debits // Leg FRA BRI BEL                     #
#                                                                           #
#############################################################################
# Issue X3-74646 - 2018-02-05 by FHA : UK VAT Vat Box management
# Issue X3-82605 - 2018-03-20 by FHA : Making DCLVATDEB Subrog independant of DIA screen
# Issue X3-63066 - 2018-04-23 by FHA : Activity code of this process in the dictionary (GASADC) is set from VATBX to DCL
End

######################################################################################
Subprog DCLVATDEB(SOC,SIT,DATDEB,DATFIN,SIMUL,OPT,TTYP,NBTYP,TCOA,DEVLED,ERR_STOP,OFFFLG,LOGFLG,DIAGRU,DIACPY,DIAFCY)
Value Char       SOC()       : # The VAT declaration is running for this company
Value Char       SIT()       : # The VAT declaration is running for this site
Value Date       DATDEB      : # Starting declaration date
Value Date       DATFIN      : # Ending declaration date
Value Integer    SIMUL       : # 1=Not a simulation 2=Simulation
Value Char       OPT()       : # "1":Accounting date "2":source document date
Value Char       TTYP()(1..) : # List of GTE (document types) to take into account for th eVAT declaration
Value Integer    NBTYP       : # Number of document types (GTE)
Value Char       TCOA()      : # Chart of account
Value Char       DEVLED()    : # Currency of the general main ledger
Variable Integer ERR_STOP    : # If an error occurs,the program continue to complete the log file but no table is updated
Value Integer    OFFFLG      : # Issue number X3-82605 Off declaration flag
Value Integer    LOGFLG      : # Issue number X3-82605 log file flag
Value Char       DIAGRU()    : # Issue number X3-82605 Group Company of [DIA] screen (BEL)
Value Char       DIACPY()    : # Issue number X3-82605 Company of [DIA] screen (BEL)
Value Char       DIAFCY()    : # Issue number X3-82605 Site of [DIA] screen

Local Integer READ_OK, FIND_OK, ERR : # Miscellaneous variables
Local Integer SIGN                  : # Sign
Local Decimal MTTTC, WAMTLED
Local Decimal VTRAT                 : # tax rate

#
Local Char    CRITDEB(250)          : # Point d'entrée DAE_FILTER - filtre sur les débits

Local Integer INDBOX                : # Index of each vat box in the list
INDBOX =  rowcount([LNK_V])
If INDBOX=0 : End : Endif
Local Char    TBOX(5)(1..INDBOX)    : # List of the vat boxes
Local Decimal AMTBOX(1..INDBOX)     : # List of the tax amount for each vat box
Local Integer FLGVATBOX(1..INDBOX)  : # List of the FLGVAT value of the account
Local Integer VATIPTBOX(1..INDBOX)  : # List of the VATIPT value of the account
Local Integer LINBOX(1..INDBOX)     : # List of the line number of the vat box
Local Char    LLEG(GLONADI)         : # Legislation


Local Char    DLVB_UW(1)
Local Integer CALL_PT
Raz CALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("DCLVATBOXDEB",GENTSTD(1..GNBENTREE))
 CALL_PT=1
Endif

If CALL_PT : GPOINT = "DAE_FILTER" : Gosub ENTREE From EXEFNC : Endif

Raz INDBOX

LLEG = [F:CPY]LEG

If NBTYP<=50
 If OPT = "1"
   Link [DAE] With [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM , [GAC]GAC0=[F:DAE]COA;[F:DAE]ACC, [TVTD]TVT0(2)~=[F:DAE]TAX;LLEG
&  As [LNK_E]
&  Where [DAE]CPY=SOC & [DAE]FCYLIN=SIT & [DAE]LEDTYP=GTYPGEN & find([DAE]TYP,TTYP(1..NBTYP))<>0
&&       [DAE]AMTVAT=0 & [DAE]AMTLED<>0 & [HAE]CAT=1 & [DAE]ACCDAT>=DATDEB & [DAE]ACCDAT<=DATFIN
&&       [GAC]COA=[L]TCOA & [GAC]FLGVAT>1 & [GAC]FLGVAT<=5 #& [HAE]NUMDCL = 0#angre-- [HAE]NUMDCL = 0  avoid collecting previously collected data
 Else
   Link [DAE] With [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM , [GAC]GAC0=[F:DAE]COA;[F:DAE]ACC, [TVTD]TVT0(2)~=[F:DAE]TAX;LLEG
&  As [LNK_E]
&  Where [DAE]CPY=SOC & [DAE]FCYLIN=SIT & [DAE]LEDTYP=GTYPGEN & find([DAE]TYP,TTYP(1..NBTYP))<>0
&&       [DAE]AMTVAT=0 & [DAE]AMTLED<>0 & [HAE]CAT=1
&&       (([HAE]BPRDATVCR>=DATDEB & [HAE]BPRDATVCR<=DATFIN) | ([HAE]BPRDATVCR=[0/0/0] & [DAE]ACCDAT>=DATDEB & [DAE]ACCDAT<=DATFIN))
&&       [GAC]COA=[L]TCOA & [GAC]FLGVAT>1 & [GAC]FLGVAT<=5 #& [HAE]NUMDCL = 0#angre-- [HAE]NUMDCL = 0  avoid collecting previously collected data
 Endif
Else
 If OPT = "1"
   Link [DAE] With [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM , [GAC]GAC0=[F:DAE]COA;[F:DAE]ACC, [TVTD]TVT0(2)~=[F:DAE]TAX;LLEG
&  As [LNK_E]
&  Where [DAE]CPY=SOC & [DAE]FCYLIN=SIT & [DAE]LEDTYP=GTYPGEN & find([DAE]TYP,TTYP(1..NBTYP))
&&       [DAE]AMTVAT=0 & [DAE]AMTLED<>0 & [HAE]CAT=1 & [DAE]ACCDAT>=DATDEB & [DAE]ACCDAT<=DATFIN
&&       [GAC]COA=[L]TCOA & [GAC]FLGVAT>1 & [GAC]FLGVAT<=5# & [HAE]NUMDCL = 0#angre-- [HAE]NUMDCL = 0  avoid collecting previously collected data
 Else
   Link [DAE] With [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM , [GAC]GAC0=[F:DAE]COA;[F:DAE]ACC, [TVTD]TVT0(2)~=[F:DAE]TAX;LLEG
&  As [LNK_E]
&  Where [DAE]CPY=SOC & [DAE]FCYLIN=SIT & [DAE]LEDTYP=GTYPGEN & find([DAE]TYP,TTYP(1..NBTYP))
&&       [DAE]AMTVAT=0 & [DAE]AMTLED<>0 & [HAE]CAT=1
&&       (([HAE]BPRDATVCR>=DATDEB & [HAE]BPRDATVCR<=DATFIN) | ([HAE]BPRDATVCR=[0/0/0] & [DAE]ACCDAT>=DATDEB & [DAE]ACCDAT<=DATFIN))
&&       [GAC]COA=[L]TCOA & [GAC]FLGVAT>1 & [GAC]FLGVAT<=5 #& [HAE]NUMDCL = 0 #angre-- [HAE]NUMDCL = 0  avoid collecting previously collected data
 Endif
Endif

If OPT = "1"
 Read [LNK_E] First
 If fstat : End : Endif
Else
 Read [LNK_E] First
 If fstat : End : Endif
Endif

Call DEBTRANS From GLOCK
Gosub TR_CALDLV
If GOK<1 : End : Endif

End

######################################################################################
# Calculation
$TR_CALDLV
Trbegin [DLVB], [DLVBD], [HAE2], [DAE2]
 Raz INDBOX, TBOX, AMTBOX, FLGVATBOX, VATIPTBOX
 # Loop on the journal entry lines that contain a tax account or a subjected account

 For [LNK_E]DAE0
  Gosub MONTANT
  If GOK<1 : Break : Endif
 Next
 If GOK<0   : Goto ROLL_TR_CALDLV
 Elsif !GOK : Goto AB_TR_CALDLV
 Endif

 Gosub UPD_DCLVATBOXH
 If GOK<0   : Goto ROLL_TR_CALDLV
 Elsif !GOK : Goto AB_TR_CALDLV
 Endif

 # If one error occurs, the files are not updated
 #If ERR>0 & [M:DIA]TYPGEN=1 : ERR_STOP = 1 : Goto AB_TR_CALDLV : Endif   :# Issue X3-82605
 If ERR>0
  If SIMUL=1  or GFONCTION = "GESGSTPER" #angre US X3-82839 If called from Australian GST-Periods, don't update in case of error, even in simulation mode
   ERR_STOP = 1
   Goto AB_TR_CALDLV
  Endif
 Endif
Commit
Return

$AB_TR_CALDLV
Rollback
Return

$ROLL_TR_CALDLV
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_CALDLV : Endif
Return

######################################################################################
$MONTANT
## If a tax code is linked with the journal entry line and if the tax code is /debit
## we have to take into account the vat base or the vat amount
## S'il y a un code taxe associé à la ligne d'écriture et que cette taxe est due sur les débits,
## on doit prendre en compte la base TVA ou le montant de TVA
If [F:GAC]FLGVAT<>5 # Pas un compte d'acompte
 # TVA collectée ventes ou collectée immos ou régul entreprise ou BS(collectée services)
 If [F:GAC]VATIPT<=2 or [F:GAC]VATIPT=7 or [F:GAC]VATIPT=8
  SIGN = -1
 Else
  SIGN = 1                              : # TVA déductible sur achats ou immos
 Endif

 FIND_OK = 0
 [L]WAMTLED = [F:DAE]AMTLED
 Gosub AMOUNT_CASE
 If GOK<1 : Return : Endif
 If FIND_OK=1  : # The amount is assigned at least to one detail vat box
  # Update the declaration number in the journal entry
  Gosub UPD_NUMDCL
  If GOK<1 : Return : Endif
  If SIMUL=1  or [F:VTB]VATFNC = "DCLVATAUS" # angre US X3-82831for DCLVATAUS also in Simulation mode
   ## Actual declaration => update AMTVAT in the GACCENTRYD table
   ## On lance la déclaration de TVA sur débits en réel. On va donc
   ## mettre à jour le montant de TVA déclarée dans la ligne d'écriture (GACCENTRYD).
   Gosub UPD_AMTVAT
   If GOK<1 : Return : Endif
  Endif
 Endif

## We process the prepayment account linked with a vat tax code /debit
## On traite les comptes d'acompte associés à un code taxe TVA/débits
Elsif [F:GAC]FLGVAT=5 : # Compte d'acompte
 # TVA collectée ventes ou collectée immos ou régul pour entreprise ou BS(collectée services)
 If [F:GAC]VATIPT <= 2 or [F:GAC]VATIPT=7 or [F:GAC]VATIPT=8
  SIGN = -1
 Else
  SIGN = 1                              : # TVA déductible sur achats ou immos
 Endif

 Gosub LECTAXD
 If [L]VTRAT>0
  Call LEC_TCU([F:HAE]CUR) From CPTLEC
  [L]WAMTLED = arr([F:DAE]AMTLED/(1+([L]VTRAT/100)),[F:TCU]CURRND)
 Else
  [L]WAMTLED  = [F:DAE]AMTLED
 Endif

 FIND_OK = 0
 Gosub AMOUNT_CASE
 If GOK<1 : Return : Endif
 If FIND_OK=1  : # The amount is assigned at least to one detail vat box
  # Update the declaration number in the journal entry
  Gosub UPD_NUMDCL
  If GOK<1 : Return : Endif
  If SIMUL = 1
   ## Actual declaration => update AMTVAT in the GACCENTRYD table
   ## On lance la déclaration de TVA sur débits en réel. On va donc
   ## mettre à jour le montant de TVA déclarée dans la ligne d'écriture (GACCENTRYD).
   Gosub UPD_AMTVAT
   If GOK<1 : Return : Endif
  Endif
 Endif
Endif
Return

######################################################################################
# Update the tax amount declared in the GACCENTRYD table
$UPD_AMTVAT
If find([F:GAC]FLGVAT,2,3,4,5) : # Compte soumis à TVA et compte de TVA et compte d'acompte
 Readlock [DAE2]DAE2=[F:DAE]ACCNUM
 If !fstat
  [F:DAE2]AMTVAT = SIGN*[F:DAE2]SNS*[F:DAE2]AMTLED
  Rewrite [DAE2]
  If fstat
   GOK=0 : Call FSTA("DAE2") From GLOCK
  Endif
 Endif
Endif
Return

######################################################################################
## Search in the VATBOX table all the tax cases that matches with the journal entry
$AMOUNT_CASE
Call LEC_TVT_LEG([F:CPY]LEG,[F:DAE]TAX) From CPTLEC
If fstat : Return : Endif

If OPT="1"
 Filter [LNK_V] Where (VCRTYP=[F:HAE]TYP | VCRTYP="") & FLGVAT=[F:GAC]FLGVAT & VATIPT=[F:GAC]VATIPT & VAT=[F:DAE]TAX
&&    (VLYSTR=[0/0/0] | [F:DAE]ACCDAT>=VLYSTR) & (VLYEND=[0/0/0] | [F:DAE]ACCDAT<=VLYEND)
Elsif OPT="2"
 Filter [LNK_V] Where (VCRTYP=[F:HAE]TYP | VCRTYP="") & FLGVAT=[F:GAC]FLGVAT & VATIPT=[F:GAC]VATIPT & VAT=[F:DAE]TAX
&&    (VLYSTR=[0/0/0] | ([F:HAE]BPRDATVCR=[0/0/0] & [F:DAE]ACCDAT>=VLYSTR) | ([F:HAE]BPRDATVCR<>[0/0/0] & [F:HAE]BPRDATVCR>=VLYSTR))
&&    (VLYEND=[0/0/0] | ([F:HAE]BPRDATVCR=[0/0/0] & [F:DAE]ACCDAT<=VLYEND) | ([F:HAE]BPRDATVCR<>[0/0/0] & [F:HAE]BPRDATVCR<=VLYEND))
Endif

For [LNK_V]
 # The type of the vat box is necessarily "Detail" because the field "FLGVAT" is not empty for the "detail" vat boxes
 # but is empty for the "out of declaration" vat boxes
 FIND_OK = 1
 # Sum for each vat box
 I = find([F:VTD]VATBOX,TBOX(1..INDBOX))
 If !I
  INDBOX +=1
  TBOX(INDBOX)      = [F:VTD]VATBOX
  AMTBOX(INDBOX)    = [F:VTD]SNS*[L]WAMTLED*[F:DAE]SNS*SIGN
  FLGVATBOX(INDBOX) = [F:GAC]FLGVAT
  VATIPTBOX(INDBOX) = [F:GAC]VATIPT
  LINBOX(INDBOX)    = [F:VTB]LIN
 Else
  AMTBOX(I) += [F:VTD]SNS*[L]WAMTLED*[F:DAE]SNS*SIGN
 Endif
 Gosub UPD_DCLVATBOXDBD
 If GOK<1 : Break : Endif
Next
Filter [LNK_V]
If GOK<1 : Return : Endif

If FIND_OK=0
 Filter [LNK_V] Where VAT=[F:DAE]TAX & [VTB]TYPBOX=4
 # If TYPBOX=4 =(out declaration) Then VLYSTR=null VLYEND=null VCRTYP=null FLGVAT=null VATIPT=null
 For [LNK_V]
  FIND_OK = 2
  #If  [M:DIA]DETDCL=2 # We print the tax boxes "Out declaration"   : # Issue number X3-82605
  If  OFFFLG=2 # We print the tax boxes "Out declaration"           : # Issue number X3-82605
   Call ECR_TRACE(mess(367,107,1)+"-"+mess(12,107,1)-[F:DAE]TYP-[F:DAE]NUM-mess(136,105,1)-num$([F:DAE]LIN)+"-"+
&                mess(39,105,1)-[F:DAE]TAX-"("+mess([F:TVT]VATPAY,204,1)+")"-"-"-mess(45,102,1)-[F:DAE]ACC,0) From GESECRAN
  Else
   Break
  Endif
 Next
 Filter [LNK_V]
Endif

If FIND_OK=0
 ERR+=1
 #If [M:DIA]TRCFLG=2          : # Issue number X3-82605
 If LOGFLG=2                  : # Issue number X3-82605
  Call ECR_TRACE(mess(366,107,1)-"-"-mess(12,107,1)-[F:DAE]TYP-[F:DAE]NUM-mess(136,105,1)-num$([F:DAE]LIN)-"-"-
&                mess(39,105,1)-[F:DAE]TAX-"("+mess([F:TVT]VATPAY,204,1)+")"-"-"-mess(45,102,1)-[F:DAE]ACC,1) From GESECRAN
 Endif
Endif
Return


######################################################################################
$UPD_DCLVATBOXDBD
If [F:GAC]FLGVAT > 1
 Readlock [F:DLVBD]DLVBD0=SOC;SIT;DATDEB;[F:GAC]ACC;[F:VTD]VATBOX;GNUMRPT;[F:DAE]TYP;[F:DAE]NUM;[F:DAE]LIN
 If !fstat
  [F:DLVBD]AMT +=[F:VTD]SNS*[L]WAMTLED*[F:DAE]SNS*SIGN
  Rewrite [DLVBD]
  If fstat
   GOK=0 : Call FSTA("DLVBD") From GLOCK : Return
  Endif
 Elsif fstat=1
  GOK=0 : Call FSTA("DLVBD") From GLOCK : Return
 Else
  Raz [F:DLVBD]
  [F:DLVBD]CPY    = SOC
  [F:DLVBD]FCY    = SIT
  [F:DLVBD]STRDAT = DATDEB
  [F:DLVBD]ACC    = [F:GAC]ACC
  [F:DLVBD]VATBOX = [F:VTD]VATBOX
  [F:DLVBD]NUMRPT = GNUMRPT
  [F:DLVBD]TYP    = [F:DAE]TYP
  [F:DLVBD]NUM    = [F:DAE]NUM
  [F:DLVBD]LIN    = [F:DAE]LIN
  [F:DLVBD]ENDDAT = DATFIN
  [F:DLVBD]COA    = TCOA
  [F:DLVBD]FLGVAT = [F:VTD]FLGVAT
  [F:DLVBD]VATIPT = [F:VTD]VATIPT
  [F:DLVBD]CUR    = DEVLED
  [F:DLVBD]ORIMOD = [F:HAE]ORIMOD #X3-84019 new field ORIMOD
  Case [F:VTD]FLGVAT
    When 2, 5 : [F:DLVBD]TYPAMT = 1 : # Compte soumis à TVA (base)
    When 3, 4 : [F:DLVBD]TYPAMT = 2 : # Compte de TVA (montant)
  Endcase
  [F:DLVBD]AMT    = [F:VTD]SNS*[L]WAMTLED*[F:DAE]SNS*SIGN
  [F:DLVBD]ACCDAT = [F:DAE]ACCDAT
  [F:DLVBD]VAT    = [F:VTD]VAT
  [F:DLVBD]SIM    = SIMUL
  [F:DLVBD]OPTDAT = val(OPT)

  Gosub LECTAXD   :# Search the tax rate
  [F:DLVBD]VATRAT = [L]VTRAT
  Write [DLVBD]
  If fstat
   GOK=0 : Call FSTA("DLVBD") From GLOCK : Return
  Endif
 Endif
Endif
Return

######################################################################################
$UPD_DCLVATBOXH
For I=1 To INDBOX
 If AMTBOX(I)<>0
  # Issue X3-74646
  #If ([F:VTB]VATFNC = "DCLVATFRA")
  # Readlock [F:DLVB]DLVB0="";SOC;1;GNUMRPT;TBOX(I)
  #Endif
  #If ([F:VTB]VATFNC = "DCLVATBEL")
  # Readlock [F:DLVB]DLVB0=[M:DIA]GRU;[M:DIA]CPY;1;GNUMRPT;TBOX(I)
  #Endif
  If ([F:VTB]VATFNC = "DCLVATBEL")
    Readlock [F:DLVB]DLVB0=DIAGRU;DIACPY;1;GNUMRPT;TBOX(I)          : # Issue number X3-82605
  Else
    Readlock [F:DLVB]DLVB0="";SOC;1;GNUMRPT;TBOX(I)
  Endif
  # End issue X3-74646

  If !fstat
   [F:DLVB]AMT += AMTBOX(I)
   Case VATIPTBOX(I)
     When 1,2,7,8 : # Collected
       If [F:DLVB]FLGVAT=2 | [F:DLVB]FLGVAT=5     : # Opérations à la sortie (=MT HT collecté)
        [F:DLVB]AMTNOTCLT += AMTBOX(I)
        [F:DLVB]GRPVAT     = 1
       Elsif [F:DLVB]FLGVAT=3 | [F:DLVB]FLGVAT=4  : # Opérations à la sortie (= MT TVA collecté)
        [F:DLVB]AMTVATCLT += AMTBOX(I)
        [F:DLVB]GRPVAT     = 2
       Endif
     When 3,4,5,6 : # Deductible
       If [F:DLVB]FLGVAT=2 | [F:DLVB]FLGVAT=5     : # Opérations à la sortie (=MT HT déductible)
        [F:DLVB]AMTNOTDED += AMTBOX(I)
        [F:DLVB]GRPVAT     = 3
       Elsif [F:DLVB]FLGVAT=3 | [F:DLVB]FLGVAT=4  : # Opérations à la sortie (=MT TVA déductible)
        [F:DLVB]AMTVATDED += AMTBOX(I)
        [F:DLVB]GRPVAT     = 4
       Endif
   Endcase

   DLVB_UW = "U"
   Gosub PE_BEFWRIDLVB

   Rewrite [DLVB]
   If fstat
    GOK=0 : Call FSTA("DLVB") From GLOCK : Break
   Endif

  Elsif fstat=1
   GOK=0 : Call FSTA("DLVB") From GLOCK : Break

  Else
   Raz [F:DLVB]

   [F:DLVB]DCLVATTYP = 1 : # Débit
   [F:DLVB]NUMRPT = GNUMRPT
# Issue number X3-74646 X3-82605
   # If [F:VTB]VATFNC = "DCLVATFRA"
   #  [F:DLVB]GRPCPY = ""
   # Endif
   # If [F:VTB]VATFNC = "DCLVATBEL"
   #  [F:DLVB]GRPCPY = [M:DIA]GRU
   # Endif
   # If [F:VTB]VATFNC = "DCLVATFRA"
   #  [F:DLVB]CPY   = SOC
   # Elsif [F:VTB]VATFNC = "DCLVATBEL"
   #  [F:DLVB]CPY   = [M:DIA]CPY
   # Endif
   [F:DLVB]GRPCPY = DIAGRU
   [F:DLVB]CPY   = SOC
   If [F:VTB]VATFNC = "DCLVATBEL"
    [F:DLVB]CPY   = DIACPY
   Endif
# End issue X3-74646 X3-82605
   [F:DLVB]VATBOX = TBOX(I)
   #[F:DLVB]FCY    = [M:DIA]FCY   :# Issue number X3-82605
   [F:DLVB]FCY    = DIAFCY        :# Issue number X3-82605
   [F:DLVB]STRDAT = DATDEB
   [F:DLVB]ENDDAT = DATFIN
   [F:DLVB]FLGVAT = FLGVATBOX(I)
   [F:DLVB]VATIPT = VATIPTBOX(I)
   [F:DLVB]CUR    = DEVLED
   [F:DLVB]TYPBOX = 2
   Case FLGVATBOX(I)
     When 2, 5 : [F:DLVB]TYPAMT = 1               : # Compte soumis à TVA (base)
     When 3, 4 : [F:DLVB]TYPAMT = 2               : # Compte de TVA (montant)
   Endcase
   [F:DLVB]AMT    = AMTBOX(I)
   Case VATIPTBOX(I)
     When 1,2,7,8
       If [F:DLVB]FLGVAT=2 | [F:DLVB]FLGVAT=5     : # Opérations à la sortie (=MT HT collecté)
        [F:DLVB]AMTNOTCLT = [F:DLVB]AMT
        [F:DLVB]GRPVAT    = 1
       Elsif [F:DLVB]FLGVAT=3 | [F:DLVB]FLGVAT=4  : # Opérations à la sortie (= MT TVA collecté)
        [F:DLVB]AMTVATCLT = [F:DLVB]AMT
        [F:DLVB]GRPVAT    = 2
       Endif
     When 3,4,5,6
       If [F:DLVB]FLGVAT=2 | [F:DLVB]FLGVAT=5     : # Opérations à la sortie (=MT HT déductible)
        [F:DLVB]AMTNOTDED= [F:DLVB]AMT
        [F:DLVB]GRPVAT= 3
       Elsif [F:DLVB]FLGVAT=3 | [F:DLVB]FLGVAT=4  : # Opérations à la sortie (=MT TVA déductible)
        [F:DLVB]AMTVATDED = [F:DLVB]AMT
        [F:DLVB]GRPVAT    = 4
       Endif
   Endcase
   [F:DLVB]SIM    = SIMUL
   [F:DLVB]OPTDAT = val(OPT)
   [F:DLVB]LIN    = LINBOX(I)
   [F:DLVB]REFTEX = [F:VTB]LEG+"~"+num$(LINBOX(I))
   [F:DLVB]VATFNC    = [F:VTB]VATFNC

   DLVB_UW = "W"
   Gosub PE_BEFWRIDLVB

   Write [F:DLVB]
   If fstat
    GOK=0 : Call FSTA("DLVB") From GLOCK : Break
   Endif
  Endif
 Endif
Next
Return

########################################################################################################
$PE_BEFWRIDLVB
If CALL_PT : GPOINT = "BEFWRIDLVB" : Gosub ENTREE From EXEFNC : Endif
Return

########################################################################################################
$LECTAXD
VTRAT = 0
Call LEC_TVT_LEG([F:CPY]LEG,[F:DAE]TAX) From CPTLEC
Filter [F:TRA] Where VAT=[F:DAE]TAX & CPY=SOC & STRDAT<=[F:DAE]ACCDAT & LEG=[F:TVT]LEG
Read [F:TRA]TRA0 Last
If !fstat
 [L]VTRAT= [F:TRA]VATRAT
Else
 Filter [F:TRA] Where VAT=[F:DAE]TAX & CPY="" & STRDAT<=[F:DAE]ACCDAT & LEG=[F:TVT]LEG
 Read [F:TRA]TRA0 Last
 If !fstat
  [L]VTRAT= [F:TRA]VATRAT
 Endif
Endif
Filter [TRA]
Return

######################################################################################
# Update the request number NUMDCL in GACCENTRY
$UPD_NUMDCL
If [F:HAE]NUMDCL<>GNUMRPT
 # We update the request number in GACCENTRY table if the update has not been done before
 # by processing another line of the journal entry
 Readlock [HAE2]HAE0=[F:HAE]TYP;[F:HAE]NUM
 If !fstat
  [F:HAE2]NUMDCL = GNUMRPT
  Rewrite [HAE2]
  If fstat
   GOK=0 : Call FSTA("HAE2") From GLOCK
  Endif
 Endif
Endif
Return


######################################################################################
$TR_UPDREPORT_FRA

Trbegin [DLVB]
 ## Add the vat boxes whose type=Title or Total (VATBOX table) and validity period is ok, in the DCLVATBEL table
 # Issue X3-74646 Replacing DCLVATFRA by GDCLFNCORI
 For [VTB] Where VATFNC=GDCLFNCORI & LEG=[F:CPY]LEG & (TYPBOX=1 or TYPBOX=3)
&&               (VLYSTR=[0/0/0] | VLYSTR<=[M:DIA]ENDDAT) & (VLYEND=[0/0/0] | VLYEND>=[M:DIA]STRDAT)
  Raz [DLVB]
  [F:DLVB]DCLVATTYP = 1
  [F:DLVB]NUMRPT = GNUMRPT
  [F:DLVB]GRPCPY = ""
  [F:DLVB]CPY    = [F:CPY]CPY
  [F:DLVB]FCY    = [M:DIA]FCY
  [F:DLVB]STRDAT = [M:DIA]STRDAT
  [F:DLVB]ENDDAT = [M:DIA]ENDDAT
  [F:DLVB]VATBOX = [F:VTB]VATBOX
  [F:DLVB]TYPBOX = [F:VTB]TYPBOX
  [F:DLVB]SIM    = [M:DIA]TYPGEN
  [F:DLVB]LIN    = [F:VTB]LIN
  [F:DLVB]REFTEX = [F:VTB]LEG+"~"+num$([F:VTB]LIN)
  [F:DLVB]VATFNC = [F:VTB]VATFNC
  [F:DLVB]OPTDAT = val(OPT)
  If [F:DLVB]TYPBOX=3 : # Total
   [F:DLVB]AMT = func CALCFOR([F:VTB]CLCFOR)
   If ([F:VTB]CNDFOR = 2)
    # Balance must be positive
    If ([F:DLVB]AMT < 0) Then : [F:DLVB]AMT = 0 : Endif
   Elsif([F:VTB]CNDFOR = 3)
    # Balance must be negative
    If ([F:DLVB]AMT > 0) Then : [F:DLVB]AMT = 0 : Endif
   Endif
  Endif
  [F:DLVB]CUR    = [L]DEVLED
  Write [DLVB]
  If fstat
   GOK=0 : Call FSTA("DLVB") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Rollback : Return : Endif
 ## Add the vat boxes whose type=detail (VATBOX table) and validity period is ok (VATBOXD table) which don't
 ## have any record in DCLVATBEL

 #For [VTB] Where VATFNC="DCLVATFRA" & LEG=[F:CPY]LEG & [VTB]TYPBOX=2       :# Issue X3-74646
 For [VTB] Where VATFNC=GDCLFNCORI & LEG=[F:CPY]LEG & [VTB]TYPBOX=2         :# Issue X3-74646
  Look [DLVB]DLVB0="";[F:CPY]CPY;1;GNUMRPT;[F:VTB]VATBOX
  If fstat
   OK = 1
   #For [VTD] Where VATFNC="DCLVATFRA" & LEG=[F:CPY]LEG & VATBOX=[F:VTB]VATBOX    :# Issue X3-74646
   For [VTD] Where VATFNC=GDCLFNCORI & LEG=[F:CPY]LEG & VATBOX=[F:VTB]VATBOX      :# Issue X3-74646
    OK = 0
    If ([F:VTD]VLYSTR=[0/0/0] | [F:VTD]VLYSTR<=[M:DIA]ENDDAT) & ([F:VTD]VLYEND=[0/0/0] | [F:VTD]VLYEND>=[M:DIA]STRDAT)
     OK = 1 : Break
    Endif
   Next
   If OK=1
    Raz [DLVB]
    [F:DLVB]DCLVATTYP = 1
    [F:DLVB]NUMRPT = GNUMRPT
    [F:DLVB]GRPCPY = ""
    [F:DLVB]CPY    = [F:CPY]CPY
    [F:DLVB]FCY    = [M:DIA]FCY
    [F:DLVB]STRDAT = [M:DIA]STRDAT
    [F:DLVB]ENDDAT = [M:DIA]ENDDAT
    [F:DLVB]VATBOX = [F:VTB]VATBOX
    [F:DLVB]TYPBOX = [F:VTB]TYPBOX
    [F:DLVB]SIM    = [M:DIA]TYPGEN
    [F:DLVB]AMT    = 0
    [F:DLVB]LIN    = [F:VTB]LIN
    [F:DLVB]REFTEX = [F:VTB]LEG+"~"+num$([F:VTB]LIN)
    [F:DLVB]VATFNC = [F:VTB]VATFNC
    [F:DLVB]OPTDAT = val(OPT)
    [F:DLVB]CUR    = [L]DEVLED
    Write [DLVB]
    If fstat
     GOK=0 : Call FSTA("DLVB") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
 If GOK=0 : Rollback : Return : Endif
Commit
Return

Funprog CALCFOR(FORMULE)
Value    Char    FORMULE
Local Decimal TOTAL
Local Char    CHAINE1(250), CHAINE2(250)
Local Integer I, SNSNEG
TOTAL = 0
CHAINE1 = vireblc(FORMULE,2)
Repeat I = instr(1,CHAINE1," ")
 Raz SNSNEG
 If I<>0
  CHAINE2 = vireblc(left$(CHAINE1,I-1),2)
  CHAINE1 = vireblc(right$(CHAINE1,I+1),2)
 Else
  CHAINE2 = CHAINE1
 Endif
 If left$(CHAINE2,1)="-"
  CHAINE2 = right$(CHAINE2,2)
  SNSNEG = 1
 Endif
 Read [DLVB1]DLVB0="";[F:CPY]CPY;1;GNUMRPT;CHAINE2
 If !fstat
  If SNSNEG
   TOTAL -= [F:DLVB1]AMT
  Else
   TOTAL += [F:DLVB1]AMT
  Endif
 Endif
Until I=0
End TOTAL

