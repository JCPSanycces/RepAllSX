#<AdxTL>@(#)174.0.0.0 $Revision$
$ACTION
Case ACTION 
  When "OUVRE"       : Gosub OUVRE 
  When "APRES_MODIF" : Gosub APRES_MODIF
  When "SETBOUT"     : Gosub SETBOUT
  When "EXEACT"      : Gosub EXEACT
  When "VERIF_CRE"   : Gosub MAJ_REC 
  When "VERIF_MOD"   : Gosub MAJ_REC 
  When "APRES_CHOI"  : Gosub APRES_CHOI
  When "ANNULE"      : Gosub ANNULE
  When "CREATION"    : Gosub CREATION
  When "MODIF"       : Gosub MODIF
  When "CHANGE"      : Gosub CHANGE     # FGR 18/09/2009 : X3SUIVI57927
Endcase
Return 
 
########################################################### 
$OUVRE
# Demande 24415 11.04 MM 
If clalev([F:ROH]) = 0  : Local File ROUTING   [ROH] : Endif

Return

########################################################### 
## GH 05/10/11 bug 76847 on gère ici le cas d'un Local File TABROUALT [TRO] Where ... en amont 

$APRES_MODIF
If TUNNEL & COUZON="ROUALT"
 I=val(CZ)
 Look [TRO]TRO0 = I
 If fstat & func EXISTE(I)
  GERR=1 : GMESSAGE=mess(8,123,1) : # Accès impossible à cette fiche
  mkstat = 2
  OK=-1
 Endif
Endif
Return

Funprog EXISTE(VALEUR)
Value Integer VALEUR
Local File TABROUALT [TRO]
Look [TRO]TRO0 = VALEUR
If !fstat : End 1
Else      : End 0
Endif
End

########################################################### 
$SETBOUT  
Call VIREBOUT(CHAINE,"H") From GOBJET 
#  Autorisation de modif selon profil gestionnaire  
If CLECUR=1
 Read [ACC]CODACC=GUSER;[M:TRO1]ACSCOD   
 If !fstat & [F:ACC]MODIF = 1  
   Call VIREBOUT(CHAINE,"MAH") From GOBJET  
 Endif
Endif    
Return   

########################################################### 
$EXEACT 
# Demande 24415 11.04 MM + 30228

Case BOUT
    When "E" : If find([M:TRO1]ANSWER,1,2) : Call CHARGE_ACS([M:TRO1]ACSCOD): Endif
Endcase
Return

###########################################################
# Demande 24415 11.04 MM 
Subprog CHARGE_ACS(ACSCOD)
Value Char ACSCOD # FGR 14/01/2010 : X3SUIVI60986
# [M:TRO1]ANSWER=1 , on RAZ le code d'acces de toutes les gammes qui utilise l'alternative 
# de façon à éviter des incohérences dans les tables
# [M:TRO1]ANSWER=2 , on répercute le code d'accès dans ttes les gammes qui utilisent l'alt.


Trbegin [ROH] 
Filter [ROH] Where ROUALT= [M:TRO1]ROUALT
    For [ROH]
        If [M:TRO1]ANSWER=1  Raz [F:ROH]ACSCOD 
        Elsif [M:TRO1]ANSWER=2 [F:ROH]ACSCOD = ACSCOD Endif
        Rewrite [ROH]
        If fstat : Goto ABANDON : Endif
    Next 
Filter [ROH]
Commit

End

###########################################################
# Demande 24415 11.04 MM 
$ABANDON
Rollback
GERR=1 : Call ERREUR(mess(17,107,1)) From GESECRAN : GMESSAGE=""
End

###########################################################
$MAJ_REC       
If [M:TRO1]BOMALT2 = 0
    [M:TRO1]BOMALT2 = [M:TRO1]BOMALT3
    [M:TRO1]BOMALT3 = 0
    Affzo [M:TRO1]BOMALT2,BOMALT3
Endif
If [M:TRO1]BOMALT1 = 0
    [M:TRO1]BOMALT1 = [M:TRO1]BOMALT2
    [M:TRO1]BOMALT2 = [M:TRO1]BOMALT3
    [M:TRO1]BOMALT3 = 0
    Affzo [M:TRO1]BOMALT1,BOMALT2,BOMALT3
Endif 
If  [M:TRO1]MFGUSE = 1 & [M:TRO1]CSTUSE = 1 & [M:TRO1]RCCUSE = 1 
    Call MESSAGE(mess(40,193,1)) From GESECRAN 
    OK=0 
Elsif [M:TRO1]BOMALT1 = 0 & [M:TRO1]BOMALT2 = 0 & [M:TRO1]BOMALT3 = 0
    Call MESSAGE(mess(41,193,1)) From GESECRAN 
    OK=0 
Endif
Return

###########################################################
$APRES_CHOI
# Demande 24415 11.04 MM 
# Pour récupérer la main quand on appuie sur Entrée après l'affichage de la boite de dialogue
If REPONSE=GSTARET REPONSE=0 Endif
Return

#############################################################
$ANNULE
  #--- maj de la table des libéllés traduisibles
  #Delete [AXX] Where CODFIC="TABROUALT" & IDENT1=[L]CODE
  #If fstat=1 | fstat>5
  # GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
  #Endif
  # FGR 18/09/2009 : X3SUIVI57927
  #--- maj de la table des libéllés traduisibles
  Call SUPTEXTRA("TABROUALT","TRODESAXX",[L]CODE,"") From ATEXTRA
  Call SUPTEXTRA("TABROUALT","TROSHOAXX",[L]CODE,"") From ATEXTRA
Return

#############################################################
$CREATION
  # FGR 18/09/2009 : X3SUIVI57927
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:TRO1]TRODESAXX,"TABROUALT","TRODESAXX",num$([M:TRO1]ROUALT),"") From ATEXTRA
  Call MAJTEXTRA([M:TRO1]TROSHOAXX,"TABROUALT","TROSHOAXX",num$([M:TRO1]ROUALT),"") From ATEXTRA
Return

#############################################################
$MODIF
  # FGR 18/09/2009 : X3SUIVI57927
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:TRO1]TRODESAXX,"TABROUALT","TRODESAXX",num$([M:TRO1]ROUALT),"") From ATEXTRA
  Call MAJTEXTRA([M:TRO1]TROSHOAXX,"TABROUALT","TROSHOAXX",num$([M:TRO1]ROUALT),"") From ATEXTRA
Return

#############################################################
$CHANGE
  # FGR 18/09/2009 : X3SUIVI57927
  Call CHANGE_AXX("TABROUALT", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
Return

###########################################################
Subprog C_BOMALT1(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 & VALEUR = [M:TRO1]BOMALT2
  mkstat = 2
Endif
If VALEUR <> 0 & VALEUR = [M:TRO1]BOMALT3
  mkstat = 2
Endif
# FQ 60751 GA 12/2009
Call CTRL_BOMALT(VALEUR)
End
###########################################################
Subprog AS_BOMALT2(VALEUR)
Variable Decimal VALEUR
If [M:TRO1]BOMALT1 = 0
  mkstat = 2
Endif
End
###########################################################
Subprog C_BOMALT2(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 & VALEUR = [M:TRO1]BOMALT1
  mkstat = 2
Endif
If VALEUR <> 0 & VALEUR = [M:TRO1]BOMALT3
  mkstat = 2
Endif
# FQ 60751  GA 12/2009
Call CTRL_BOMALT(VALEUR)
End
###########################################################
Subprog AS_BOMALT3(VALEUR)
Variable Decimal VALEUR
If [M:TRO1]BOMALT2 = 0
  mkstat = 2
Endif
End
###########################################################
Subprog C_BOMALT3(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 & VALEUR = [M:TRO1]BOMALT1
  mkstat = 2
Endif
If VALEUR <> 0 & VALEUR = [M:TRO1]BOMALT2
  mkstat = 2
Endif
# FQ 60751  GA 12/2009
Call CTRL_BOMALT(VALEUR)
End
###########################################################
Subprog CTRL_BOMALT(LBOMALT)                   # FQ 60751 #
Variable Decimal LBOMALT
If LBOMALT= 0 End Endif
If !clalev([F:TBO]) Local File TABBOMALT [TBO] : Endif
Read [TBO]TBO0=2;LBOMALT
If !fstat 
    If [M:TRO1]MFGUSE=2
       # Alternative non utilisable en fabrication !
       If [F:TBO]MFGUSE<>2 Call MESSAGE(mess(49,193,1)) From GESECRAN Endif
    Endif
    If [M:TRO1]CSTUSE=2
     # Alternative non utilisable pour les couts !
       If [F:TBO]CSTUSE<>2 Call MESSAGE(mess(141,193,1)) From GESECRAN Endif
    Endif
    If [M:TRO1]RCCUSE=2
     # Alternative non utilisable pour le RCCP !
       If [F:TBO]MRPUSE<>2 & [F:TBO]MPSUSE<>2 Call MESSAGE(mess(279,193,1)) From GESECRAN Endif
    Endif
Endif
End
########################################
Subprog C_ROUALT(VALEUR)
Variable Decimal VALEUR
End
########################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
# avertissement en cas de modif du site               (07/02/00    TB)
If !find(GREP,"C","D") & VALEUR <> [F:TRO]FCY & !GIMPORT
# "Cette modification peut avoir des conséquences ! Vérifier les cas d'emploi"
   Call MESSAGE(mess(128,193,1)) From GESECRAN
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran TRO1) 24/11/2004 17:02:18 (MM)
######################################################################################
# Demande 24415 11.04 MM + 30228
Subprog AM_ACSCOD(VALEUR)
Variable Char    VALEUR()
Raz [M:TRO1]ANSWER

#"Voulez-vous appliquer la modification du code d'accès à l'ensemble\ des gammes
# utilisant cette alternative?"
If [M:TRO1]ACSCOD <> VALEUR
    GMESSAGE=mess(210,190,1)
    Call OUINON(GMESSAGE,[M:TRO1]ANSWER)From GESECRAN
    If ! find([M:TRO1]ANSWER,1,2) Raz [M:TRO1]ANSWER Endif
Endif

End


