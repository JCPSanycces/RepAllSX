#<AdxTL>@(#)10.0.0.0 $Revision$
################################################################
## Génération de la pièce d'écart de change
################################################################
# Issue X3-69590 - 2018-09-04 by CBO : Polish Entry point adding
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
Subprog GEN_PIECE(SITE,TYPREF,PLAN,COMPTE,TIERS,DAT,DEVISE,MONTDEV,DEVLED,MONTANT,MTAUTO,FLECART
&                 ,NBECH,TBECR,TBECH,TBIPT,TBIPT2,STAT,MESSA,PCETYP,PCENUM)
Value    Char    SITE
Value    Integer TYPREF
Value    Char    PLAN
Value    Char    COMPTE
Value    Char    TIERS
Variable Date    DAT
Value    Char    DEVISE
Value    Decimal MONTDEV
Value    Char    DEVLED
Value    Decimal MONTANT
Value    Decimal MTAUTO(1..)
Value    Integer FLECART
Variable Integer NBECH
Variable Integer TBECR(1..)
Variable Integer TBECH(1..)
Variable Decimal TBIPT(1..)
Variable Decimal TBIPT2(1..)
Variable Integer STAT
Variable Char    MESSA()
Variable Char    PCETYP()
Variable Char    PCENUM()

If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif

Local Integer SENS               : # Sens de la pièce
Local Char    SOCIETE(GLONCPY)   : # Société
Local Char    CPTCHG(GLONGAC)    : # Compte de contrepartie
Local Char    CODE(GLONGAU)      : # Pièce auto
Local Char    IDENT(30)(1..1)    : # Identifiant table
Local Char    INTREF(20)         : # Référence interne
#*X3-39795 Local Char    ZONE(10)(1..1)     : # Zones imposées
#*X3-39795 Local Char    VALEUR(50)(1..1)   : # Valeurs imposées
Local Char    ZONE(10)(1..10)     : # Zones imposées   #*X3-39795
Local Char    VALEUR(50)(1..10)   : # Valeurs imposées #*X3-39795
Local Integer I , J , K
Local Integer TYPLEDORI
Local Char    CPTCHGGAI(GLONGAC) : # Exchange gain
Local Char    CPTCHGLOS(GLONGAC) : # Exchange loss
Local Char    CPTRNDGAI(GLONGAC) : # Rounding gain matching
Local Char    CPTRNDLOS(GLONGAC) : # Rounding loss matching
Local Char    CPTVARGAI(GLONGAC) : # Debtor rounding variance
Local Char    CPTVARLOS(GLONGAC) : # Creditor rounding variance

Call LEC_FCY(SITE) From CPTLEC
SOCIETE = [F:FCY]LEGCPY

# Création d'une ligne dans MTCAUTO

Call LEC_COA(PLAN)         From CPTLEC
Call LEC_GAC(COMPTE,PLAN)  From CPTLEC
CPTCHGGAI = [F:GAC]CNVACC5
CPTCHGLOS = [F:GAC]CNVACC6
CPTRNDGAI = [F:GAC]CNVACC7
CPTRNDLOS = [F:GAC]CNVACC8
CPTVARGAI = [F:GAC]CNVACC10
CPTVARLOS = [F:GAC]CNVACC9
If CPTCHGGAI = "" : CPTCHGGAI = [F:COA]ACCMIS(8)  : Endif
If CPTCHGLOS = "" : CPTCHGLOS = [F:COA]ACCMIS(9)  : Endif
If CPTRNDGAI = "" : CPTRNDGAI = [F:COA]ACCMIS(13) : Endif
If CPTRNDLOS = "" : CPTRNDLOS = [F:COA]ACCMIS(14) : Endif
If CPTVARGAI = "" : CPTVARGAI = [F:COA]ACCMIS(12) : Endif
If CPTVARLOS = "" : CPTVARLOS = [F:COA]ACCMIS(11) : Endif

Case FLECART
 When 0 : # Ecart de change
  Call PARAM(SITE,"GAUMTC",CODE) From ADOVAL
  If CODE="" : CODE = "MTC" : Endif
  INTREF = "MTC1"
  Raz CPTCHG
  If MONTANT=0
   For I=1 To dim([F:MTU]AMTAUT)
    If MTAUTO(I)<>0
     Call ORILEDTYP(SOCIETE,I,TYPLEDORI) From CPTDIV
     If TYPREF=TYPLEDORI
      If MTAUTO(I)>0
       CPTCHG = CPTCHGGAI   : # Gain de change
      Else
       CPTCHG = CPTCHGLOS   : # Perte de change
      Endif
      Break
     Endif
    Endif
   Next I
  Endif
  If CPTCHG=""
   If MONTANT>0
    CPTCHG = CPTCHGGAI   : # Gain de change
   Else
    CPTCHG = CPTCHGLOS   : # Perte de change
   Endif
  Endif

 When 1 : # Ecart d'arrondi (euro)
  Call PARAM(SITE,"GAUMTR",CODE) From ADOVAL
  If CODE="" : CODE = "MTR" : Endif
  INTREF = "MTC2"
  Raz CPTCHG
  If MONTANT=0
   For I=1 To dim([F:MTU]AMTAUT)
    If MTAUTO(I)<>0
     Call ORILEDTYP(SOCIETE,I,TYPLEDORI) From CPTDIV
     If TYPREF=TYPLEDORI
      If MTAUTO(I)>0
       CPTCHG = CPTVARGAI   : # Gain d'arrondi (crédit)
      Else
       CPTCHG = CPTVARLOS   : # Perte d'arrondi (débit)
      Endif
      Break
     Endif
    Endif
   Next I
  Endif
  If CPTCHG=""
   If MONTANT>0
    CPTCHG = CPTVARGAI   : # Gain d'arrondi (crédit)
   Else
    CPTCHG = CPTVARLOS   : # Perte d'arrondi (débit)
   Endif
  Endif

 When 2 : # Perte et profit
  Call PARAM(SITE,"GAUMTP",CODE) From ADOVAL
  If CODE="" : CODE = "MTP" : Endif
  INTREF = "MTC3"
  If MONTANT>0
   CPTCHG = CPTRNDGAI   : # Profit (crédit)
  Else
   CPTCHG = CPTRNDLOS   : # Perte (débit)
  Endif
Endcase
If MONTANT>0
 SENS   = +1
Else
 MONTANT = -MONTANT
 MONTDEV = -MONTDEV
 SENS   = -1
Endif

Raz [MTU]
[F:MTU]NUM = uniqid([MTU])
[F:MTU]LEDTYP = TYPREF
[F:MTU]ACCDAT = DAT
[F:MTU]FCY    = SITE
[F:MTU]CPY    = SOCIETE
[F:MTU]COA    = PLAN
[F:MTU]ACC    = COMPTE
[F:MTU]BPR    = TIERS
[F:MTU]AMTCUR = MONTDEV
[F:MTU]CUR    = DEVISE
[F:MTU]AMTLED = MONTANT
[F:MTU]CURLED = DEVLED
[F:MTU]SNS    = SENS
[F:MTU]ACCMTC = CPTCHG
[F:MTU]REFINT = INTREF
For I=1 To dim([F:MTU]AMTAUT)
 If SENS=-1
  [F:MTU]AMTAUT(I-1) = -MTAUTO(I)
 Else
  [F:MTU]AMTAUT(I-1) = MTAUTO(I)
 Endif
Next I

# Issue X3-69590 Polish Legislation ENTRY POINT
If (find("POL", GDOSLEG) > 0) Then
  GPOINT = "XDMTCAUTO"
  Gosub ENTREE From EXEFNC
Endif
# End Issue X3-69590

Write [MTU]
If fstat
 GOK = 0 : Call FSTA("MTU") From GLOCK : End
Endif

# Pour récupérer le résultat

If clalev([M:HAE0])=0 : Local Mask GACCENT0   [HAE0] : Endif
If clalev([M:HAE1])=0 : Local Mask GACCENT1   [HAE1] : Endif
If clalev([M:HAE2])=0 : Local Mask GACCENT2   [HAE2] : Endif
If clalev([M:HAEW])=0 : Local Mask GACCENTW   [HAEW] : Endif

Raz [M:HAE0], [M:HAE1], [M:HAE2], [M:HAEW]

# Validation de la pièce (en réel)

IDENT(1)  = num$([F:MTU]NUM)
ZONE(1)   = "REFINT"
VALEUR(1) = INTREF
#*X3-39795  Manage ORIGIN and ORICOD
ZONE(5)   = "ORIGIN"
VALEUR(5) = "2"
ZONE(6)   = "ORICOD"
VALEUR(6) = CODE
#*X3-39795 END

Call VALPCER3(CODE,IDENT,STAT,MESSA,ZONE,VALEUR) From CPTAUTO
If STAT : End : Endif


If [M:HAEW]NB>0
 # Récupération résultat

 PCETYP  = [M:HAE0]TYP
 PCENUM  = [M:HAE0]NUM

 # Ajout de la nouvelle ligne à lettrer

 NBECH += 1
 TBECR(NBECH)  = [M:HAEW]ACCNUM(0)
 TBECH(NBECH)  = 1
 TBIPT(NBECH)  = MONTANT
 TBIPT2(NBECH) = 0
 DAT           = max(DAT,[M:HAE0]ACCDAT)
Endif

End

####################################################
## ACCDAT formula on MTE
####################################################
Funprog ACCDAT(DAT)
Value Date DAT
If dim([M:DIA]ACCDAT)>0 : End [M:DIA]ACCDAT : Endif
End [L]DAT

