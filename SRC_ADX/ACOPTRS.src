#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(30)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACOPTRS","ACOPTRS",3,"XYACOPTRS") From GTRAITE
End

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

$INIT
Gosub OUVRE
Local Char CRITFIC(250) , TABLE(30) , TEXTE(50) , TABLE2(30) , TABLE3(30)
Local Char ZTEX(10) , ZTYP(10) , ZCLE1(80) , ZCLE2(80) , ZTAB(30)
Local Char CHAINE1(250) , CHAINE2(250)
Local Integer TRN
TRA = 1
TMP = 1
Return

$OUVRE_BATCH
Gosub OUVRE
Return

$OUVRE
If clalev([F:ATN])=0 : Local File ATRANSAC [ATN] : Endif
If clalev([F:ATB])=0 : Local File ATABLE   [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON  [ATZ] : Endif
If clalev([F:AMP])=0 : Local File AMSKPAR  [AMP] : Endif
Return

$INIT_DIA
Raz [M]
nolign = 0
For [ATN]ATN0 Where ENAFLG=2 & COP=2
 If GMODU([F:ATN]MODULE)=2
  nolign += 1
  [M]COD(nolign-1) = [F:ATN]COD
  [M]OBJ(nolign-1) = [F:ATN]OBJ
  Call TEXTE([F:ATN]DES,[M]DES(nolign-1)) From OBJDIV
  [M]COP(nolign-1) = 1
 Endif
Next
[M]NBLIG = nolign
Return

$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(mess(70,133,1)) From LECFIC : # Copie transactions
Endif
For TRN=0 To [M]NBLIG-1
 If [M]COP(TRN)=2
  Call ECR_TRACE(mess(70,133,1)-":"-[M]COD(TRN)-[M]DES(TRN)-[M]DOSORG-"=>"-[M]DOSDES,0) From GESECRAN
  Read [ATN]ATN0 = [M]COD(TRN)
  ZTAB = [F:ATN]TBL
  Read [ATB]CODFIC = [F:ATN]TBL
  ZTEX = [F:ATB]INTIT
  Raz ZTYP , ZCLE1 , ZCLE2
  If ZTEX<>""
   Read [ATZ]CODZONE=[F:ATN]TBL;ZTEX
   ZTYP = [F:ATZ]CODTYP
   If find(ZTYP,"AXX","AX1","AX2","AX3")
    Read [AMP]CODPAR=2;[F:ATN]TBL;ZTEX;"CLECUR1"
    ZCLE1 = [F:AMP]VALPAR
    Read [AMP]CODPAR=2;[F:ATN]TBL;ZTEX;"CLECUR2"
    ZCLE2 = [F:AMP]VALPAR
   Endif
  Endif
  Local File =[M]DOSORG+"."+[F:ATN]TBL [AAA_]
  CRITFIC = [F:ATN]CND
  If [M]DEB(TRN)<>""
   If CRITFIC<>"" : CRITFIC -= "&" : Endif
   Case evalue("type([F:AAA_]"+[F:ATN]FLDCOD+")")
    When 1,2,4,5,6,7 : CRITFIC -= [F:ATN]FLDCOD+'>='+[M]DEB(TRN)
    When Default     : CRITFIC -= [F:ATN]FLDCOD+'>="'+[M]DEB(TRN)+'"'
   Endcase
  Endif
  If [M]FIN(TRN)<>""
   If CRITFIC<>"" : CRITFIC -= "&" : Endif
   Case evalue("type([F:AAA_]"+[F:ATN]FLDCOD+")")
    When 1,2,4,5,6,7 : CRITFIC -= [F:ATN]FLDCOD+'<='+[M]FIN(TRN)
    When Default     : CRITFIC -= [F:ATN]FLDCOD+'<="'+[M]FIN(TRN)+'"'
   Endcase
  Endif
  If dim([F:AAA_]ENAFLG)>0
   If CRITFIC<>"" : CRITFIC -= "&" : Endif
   CRITFIC -= "ENAFLG=2"
  Endif
  If CRITFIC="" : CRITFIC = "1=1" : Endif
  For [AAA_] Where evalue(CRITFIC)
   Gosub COPTRS
  Next
  Close Local File [AAA_]
 Endif
Next TRN
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

$COPTRS
GOK = 1
TABLE = evalue("[F:AAA_]"+[F:ATN]FLDCOD)
TABLE2 = [F:AAA_]CODLEG           # AKA X3-60633: Set legislation code ("" = all legislations or specific one: "FRA")
Gosub TRTCOP From =[F:ATN]CODTRT
TEXTE = ""
If GOK=1
 Onerrgo RIEN
 Case ZTYP
  When "AXX","AX1","AX2","AX3"
   Raz CHAINE1 , CHAINE2
   If ZCLE1<>""
    Default File [F:AAA_]
    CHAINE1 = num$(evalue(ZCLE1))
   Endif
   If ZCLE2<>""
    Default File [F:AAA_]
    CHAINE2 = num$(evalue(ZCLE2))
   Endif
   Call LECTEXTRA(TEXTE,ZTAB,ZTEX,CHAINE1,CHAINE2) From ATEXTRA
  When "ATX"
   Call TEXTE(evalue("[F:AAA_]"+ZTEX),VALEUR) From OBJDIV
  When Default
   If ZTEX<>""
    TEXTE = num$(evalue("[F:AAA_]"+ZTEX))
   Endif
 Endcase
 Onerrgo
 Call ECR_TRACE("---"-TABLE-TEXTE,0) From GESECRAN
Endif
Return

$RIEN
Resume

$SEL_TABLE
Case TABLE
 When "SELTRS" : Gosub SELTRS
Endcase
Return

$SELTRS
Read [ATN]ATN0 = PARAM(1)
OBJET = [F:ATN]OBJ
START = [F:ATN]FLDCOD
Return

#######################################################
## Ecran ACOPTRS
#######################################################
Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
GMODIF = 0
End

Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
If !GMODIF : mkstat = 2 : Endif
GMODIF = 1
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
If GDOSPATH="" : End : Endif
Call C_DOSSIER(GDOSPATH) From DOSCONT
If mkstat
 mkstat = 0
Else
 VALEUR = GDOSPATH
Endif
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call DOSORGDES([M]DOSORG,VALEUR) From DOSCONT
If mkstat : End : Endif
End

Subprog AS_DEB(VALEUR)
Variable Char VALEUR()
If [M]COP(nolign-1)<>2 : mkstat = 1 : End : Endif
End

Subprog S_DEB(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(255)(1..20)
PARAM(1) = [M]COD(nolign-1)
Call S_TAB_CHAR(VALEUR,PARAM,"SELTRS","ACOPTRS","") From GACTION
End

Subprog AS_FIN(VALEUR)
Variable Char VALEUR()
If [M]COP(nolign-1)<>2 : mkstat = 1 : End : Endif
End

Subprog S_FIN(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(255)(1..20)
PARAM(1) = [M]COD(nolign-1)
Call S_TAB_CHAR(VALEUR,PARAM,"SELTRS","ACOPTRS","") From GACTION
End

Subprog C_FIN(VALEUR)
Variable Char VALEUR()
If VALEUR<[M]DEB(nolign-1) : mkstat = 1 : End : Endif
End

Subprog B1_NBLIG
For I=nolign-1 To [M]NBLIG-1
 [M]COP(I) = 2 : # Oui
Next I
Affzo
End

Subprog B2_NBLIG
For I=nolign-1 To [M]NBLIG-1
 [M]COP(I) = 1 : # Non
Next I
Affzo
End

