# Supervisor
## ACLA-CLASSE ## EDIRUN
# 2018-10-17 07:54:26 490

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMR0EDIRUNREC
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
this._AFCRIGHT = "EDIRUNREC"
If this.EDR<>null
 [L]ASTATUS = fmet this.EDR.AINIT : Gosub TESTALLSTAT
Endif
Gosub AINIT From WMR0EDIRUNREC : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMR0EDIRUNREC
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMR0EDIRUNREC
If this.EDR<>null
 [L]ASTATUS = fmet this.EDR._ALNKPRO : Gosub TESTALLSTAT
Endif
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



