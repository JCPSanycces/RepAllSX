#<AdxTL>@(#)2.0.4.29 $Revision$
##########################################################################
##
## *** DO NOT EDIT *** without reporting changes to Eric Boureau
## This script is now automatically updated by SAFE X3 Studio.
##
##########################################################################

#Local Char A(250)
#A = func LISRDV
#A = num$(func EXERDV("","",GBIDC3,GBIDC1,GBIDC2)) : Infbox "Status:"+A-"Ident:"+gbidc3-"Traitement:"+gbidc1-"Info:"+GBIDC2
#A = num$(func STARDV("2",GBIDC2)) : Infbox "Status:"+A-"Info:"+GBIDC2
#A = num$(func ANURDV("44",GBIDC2)) : Infbox "Status:"+A-"Info:"+GBIDC2
#A = num$(func MAJRDV("44",1,GBIDC2)) : Infbox "Status:"+A-"Info:"+GBIDC2
#A = num$(func ADDRDV("TEST","","",GBIDC1,GBIDC2)) : Infbox "Status:"+A-"Identifiant:"+GBIDC1-"Info:"+GBIDC2
#A = num$(func EPURDV(GBIDC2)) : Infbox "Info:"+GBIDC2
End

#-------------------------------------------------------------------------------#
# ADDRDV : Ajout d'un rendez-vous
# ADDRD2 : Ajout d'un rendez-vous avec type ('EXE' ou 'DBG')
# ANURDV : Suppression d'un rendez-vous
# EPURDV : Epuration journalière des rendez-vous
# STARDV : Retrouver le statut d'un rendez-vous
# EXERDV : Recherche d'un rendez-vous en attente pour exécuter un traitement
# MAJRDV : Mise à jour du statut d'un rendez-vous
# LISRDV : Visualisation des rendez-vous
#-------------------------------------------------------------------------------#

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "RAF"         : Gosub RAF
 When "OK"          : Gosub OK
 When "FIN"         : Gosub DEVERROU
Endcase
Return

#-------------------------------------------------------------------#
$OUVRE
Local Char    TIMAFF(250)
Local Integer HH , MM , SS , TEMPS , PLEIN
If clalev([F:AEC])=0 : Local File AECLIRDV [AEC] : Endif
Gosub VERROU
Return

#----------------#
$VERROU
Local Char SYMBOLE(30)
Local Integer VERROU
SYMBOLE = "AECLIRDV"
Lock =SYMBOLE
If fstat : VERROU = 1 : Endif
Return

#----------------#
$DEVERROU
Unlock =SYMBOLE
Return

#----------------#
$SETBOUT
CHBOU += "="
If PLEIN or VERROU or REP<>"M"
 Call VIREBOUT(CHBOU,"O") From GOBJET
Endif
Return

#----------------#
$APRES_MODIF
REP = "M"
Return

#----------------#
$RAF
Gosub CHARGE
Affzo
If PLEIN or VERROU : Diszo : Endif
Return

#----------------------------------------------------------#
$DEBUT
PLEIN = 0
Gosub CHARGE
Affzo
If PLEIN or VERROU : Diszo : Endif
Return

#----------------#
$CHARGE
nolign = 0
For [AEC]AEC0
 If nolign+1>=dim([M:AEC1]NUMLIG)
  PLEIN = 1 : Break
 Endif
 nolign += 1
 [M:AEC1] = [F:AEC]
 TEMPS = [F:AEC]HEUDEB : Gosub HEURE : [M:AEC1]DEBAFF(nolign-1) = TIMAFF
 TEMPS = [F:AEC]HEUFIN : Gosub HEURE : [M:AEC1]FINAFF(nolign-1) = TIMAFF
 If dim([F:AEC]CRETIM)>0 : TEMPS = [F:AEC]CRETIM : Gosub HEURE : [M:AEC1]CREAFF(nolign-1) = TIMAFF : Endif
 If dim([F:AEC]UPDTIM)>0 : TEMPS = [F:AEC]UPDTIM : Gosub HEURE : [M:AEC1]UPDAFF(nolign-1) = TIMAFF : Endif
Next AEC
[M:AEC1]NBLIG = nolign
Return

#----------------#
$HEURE
If TEMPS<>0
 HH = int(TEMPS/3600)
 MM = int(mod(TEMPS,3600)/60)
 SS = mod(TEMPS,60)
Endif
TIMAFF = string$(TEMPS<>0,format$("N0:##",HH)+":"+format$("N0:##",MM)+":"+format$("N0:##",SS))
Return

#----------------#
$OK
GOK = 1
Trbegin [AEC]
 Delete [AEC] Where 1=1
 For nolign=1 To [M:AEC1]NBLIG
  [F:AEC] = [M:AEC1]
  Write [AEC]
  If fstat
   GOK=0 : Call FSTA("AEC") From GLOCK : Break
  Endif
 Next nolign
 If GOK<>1 : Goto AB_OK : Endif
Commit
Return

$AB_OK
Rollback
Return

#----------------#
$SET_LOGIN
Local Char    LOGIN(GLONALO) , APPLI(GLONADS)
LOGIN = tolower(adxusr)
APPLI = toupper(nomap)
Return

#--------------------------------#
$SET_GLOBAL_CONVERGENCE
If dim(GSERVEUR)<=0
 Global Integer GSERVEUR
Endif
Return

#---------------------------------------------------------#
# Ajout d'un rendez-vous
#---------------------------------------------------------#

Funprog ADDRDV(TRT,WRK,NAM,REF,MES)
Value    Char    TRT : # Nom du traitement
Value    Char    WRK : # Nom du Workspace IDE
Value    Char    NAM : # Alias de l'IDE
Variable Char    REF : # Identifiant interne du rendez-vous (unique pour la solution)
Variable Char    MES : # Message du statut en clair

Local Integer STA : # Statut de retour (1=tout va bien)
Local Integer TRC

#If GUSER="ERBOU" : TRC=1 : Endif
If TRC
  Call TRACE("ADDRDV - 1: adxusr=" + adxusr + ", nomap=" + nomap + ", TRT=" + TRT + ", WRK=" + WRK + ", NAM=" + NAM)
Endif
STA = func ADDRD2(TRT, WRK, NAM, "RUN", "0", "0", "", REF,MES)
End STA

#---------------------------------------------------------#
# Ajout d'un rendez-vous avec type ('EXE' ou 'DBG')
#---------------------------------------------------------#

Funprog ADDRD2(TRT,WRK,NAM,TYP,UID,PRT,MAC,REF,MES)
Value    Char    TRT : # Nom du traitement
Value    Char    WRK : # Nom du Workspace IDE
Value    Char    NAM : # Alias de l'IDE
Value    Char    TYP : # Type d'exécution : EXE ou DBG
Value    Char    UID : # Id unique (adxuid(2))
Value    Char    PRT : # Port de debug
Value    Char    MAC : # Machine de debug
Variable Char    REF : # Identifiant interne du rendez-vous (unique pour la solution)
Variable Char    MES : # Message du statut en clair

Local Integer STA : # Statut de retour (1=tout va bien)
Local Integer OGSERVEUR , NBSES , OK
Local Integer TRC
Gosub SET_GLOBAL_CONVERGENCE

#If GUSER="ERBOU" : TRC=1 : Endif

If TRC
  Call TRACE("ADDRDV2 - 1: adxusr=" + adxusr + ", nomap=" + nomap + ", TYP=" + TYP + ", TRT=" + TRT + ", WRK=" + WRK)
Endif

If clalev([F:AEC])=0 : Local File AECLIRDV [AEC] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif

Gosub SET_LOGIN

Raz REF , MES

If find(TYP, "PXS", "PXH") > 0
  # we can have only one PXS/PXH record per folder/login
  Delete [AEC] Where TYPEXE=TYP and DOSSIER=[L]APPLI and LOGIN=[L]LOGIN
  # clean PXS/PXH of old configurations to prevent debug issue
  Delete [AEC] Where (TYPEXE="PXS" or TYPEXE="PXH") and WRKIDE=WRK and ALIIDE<>NAM
Elsif TYP <> "ATT"
  # Recherche d'une session C/S libre (pour les rendez-vous autres que Attach)
  Call LIBRE([L]LOGIN,adxuid(1),[L]APPLI,OK,NBSES)
  If TRC
    Call TRACE("ADDRDV2 - 2: nbses=" + num$(NBSES) + ", ok=" + num$(OK) + ", adxtyp=" + num$(adxtyp))
  Endif
  If !NBSES
   STA = 2
   MES = mess(9,143,1) : # Pas d’affinités de session pour la prise de rendez-vous
   End STA
  Elsif !OK
   STA = 3
   MES = mess(10,143,1) : # Session avec affinité occupée
   End STA
  Endif
Endif

# Transaction
If !adxlog
 OGSERVEUR = GSERVEUR
 GSERVEUR = 1
 Gosub TR_ADD
 GSERVEUR = OGSERVEUR
Else
 Gosub ADD
Endif

# Status retour
REF = num$([F:AEC]NUMLIG)
If GOK<1
 Gosub ERR
Else
 STA = 1
 MES = REF-":"-mess(11,143,1) : # Rendez-vous ajouté
Endif

End STA

#--------------#
$TR_ADD
GOK=1
Trbegin [AEC]
 Gosub ADD
 If GOK=0 : Goto AB_TR_ADD : Endif
Commit
Return

$AB_TR_ADD
Rollback
Return

#--------------#
$ADD
Raz [F:AEC]
[F:AEC]NUMLIG  = uniqid([F:AEC])
Read [AUS]LOGIN=toupper([L]LOGIN)
If !fstat
 [F:AEC]CREUSR = [F:AUS]USR
Endif
[F:AEC]CREDAT  = date$
If dim([F:AEC]CRETIM)>0 : [F:AEC]CRETIM = time : Endif
[F:AEC]SRVAPP  = adxmac(0)
[F:AEC]SRVTRT  = adxmac(-1)
[F:AEC]SRVCLI  = adxmac(-2)
[F:AEC]LOGIN   = [L]LOGIN
[F:AEC]DOSSIER = [L]APPLI
[F:AEC]PORT    = adxtcp
[F:AEC]WRKIDE  = WRK
[F:AEC]ALIIDE  = NAM
[F:AEC]CODTRT  = TRT
[F:AEC]TYPRDV  = 1 : # En attente
If dim([F:AEC]TYPEXE) > -1 and dim(TYP) > -1 # Since 2011-05-20
  [F:AEC]TYPEXE = TYP
  [F:AEC]DBGMAC = MAC
  [F:AEC]UNICID = val(UID)
  [F:AEC]DBGPRT = val(PRT)
Endif
Write [AEC]
If fstat
 GOK=0 : Call FSTA("AEC") From GLOCK
Endif
Return

#--------------#
$ERR
Case left$(GMESSAGE,1)
 When "1"     : STA = 11 : MES = mess(60,100,1)  : # Enregistrement verrouillé
 When "2"     : STA = 12 : MES = mess(153,115,1) : # Clé suivante lue
 When "3"     : STA = 13 : MES = mess(22,100,1)  : # Clé déjà existante
 When "4"     : STA = 14 : MES = mess(11,100,1)  : # Début/fin de fichier
 When "5"     : STA = 15 : MES = mess(154,115,1) : # Pas d'enregistrement courant
 When Default : STA = 99 : MES = mess(155,115,1) : # Erreur grave
Endcase
Return

#-------------------------------------------------------#
Subprog LIBRE(LOGIN,CURSID,APPLI,OK,NBSES)
Value    Char    LOGIN
Value    Integer CURSID
Value    Char    APPLI
Variable Integer OK , NBSES

If func AXDTMAIN.ISMNGSESSIONS
 Call LIBRE_ASESSION(LOGIN,CURSID,APPLI,OK,NBSES) From ASESSIONS
 End
Endif

Local Char    SID(12) , SCLI(80) , SUSR(30) , SDOS(30) , STYP(10)
Local Char    FONCTION(GLONAFC) , CURLOG(30)
Local Integer MODULE
Local Integer TRC

#If GUSER="ERBOU" : TRC=1 : Endif

  If TRC
    Call TRACE("LIBRE - 1: LOGIN=" + LOGIN + ", CURSID=" + num$(CURSID) + ", APPLI=" + APPLI)
  Endif

If APPLI="" : APPLI = toupper(nomap) : Endif
Local File (SID,SCLI,SDOS,SUSR,STYP) From System adxmac(0)+"@psadx -t -u"-LOGIN-"-b"-APPLI As [SYS_] Where [SYS_]SUSR=LOGIN
Raz OK ,NBSES
# Il faut que l'utilisateur soit déjà connecté sur une session libre (Client qui n'est pas dans une fonction)
For [SYS_]
  If TRC
    Call TRACE("  LIBRE - 2: SID=" + num$([F:SYS_]SID) + ", CURSID=" + num$(CURSID) + ", STYP=" + [F:SYS_]STYP)
  Endif
 # Sessions éligibles : primaire et secondaire
 #If [F:SYS_]SID<>num$(CURSID) & find(val([F:SYS_]STYP),1,2)
 If [F:SYS_]SID<>num$(CURSID) & (mod(val([F:SYS_]STYP),8)=1 or mod(val([F:SYS_]STYP),8)=2)
  NBSES += 1
  FONCTION = ""
  Call GET_CURFCT(adxmac(0),APPLI,[F:SYS_]SID,FONCTION,MODULE,CURLOG) From PSADX
  # APTLREQ and APTLOB are pseudo functions for portal internal use
  If find(FONCTION, "", "APTLREQ", "APTLOBJ")
   OK = 1 : Break
  Endif
 Endif
Next SYS_
Close Local File [SYS_]
End

#---------------------------------------------------------#
# Suppression d'un rendez-vous
#---------------------------------------------------------#

Funprog ANURDV(REF,MES)
Value    Char    REF : # Identifiant interne du rendez-vous (unique pour la solution)
Variable Char    MES : # Message du statut en clair

Local Integer STA : # Statut de retour (1=tout va bien)
Local Integer OGSERVEUR
Local Integer TRC
Gosub SET_GLOBAL_CONVERGENCE

If TRC
  Call TRACE("ANURDV - 1: adxusr=" + adxusr + ", nomap=" + nomap)
Endif

If clalev([F:AEC])=0 : Local File AECLIRDV [AEC] : Endif

Raz MES

# Contrôle Rendez-vous
Read [AEC]AEC0=val(REF)
If fstat
 STA = 3
 MES = REF-":"-mess(12,143,1) : # Rendez-vous inexistant
 End STA
Elsif [F:AEC]TYPRDV=2 : # En cours
 STA = 2
 MES = REF-":"-mess(13,143,1) : # En cours d'exécution
 End STA
Endif

# Transaction
If !adxlog
 OGSERVEUR = GSERVEUR
 GSERVEUR = 1
 Gosub TR_ANU
 GSERVEUR = OGSERVEUR
Else
 Gosub ANU
Endif

# Status retour
If GOK<1
 Gosub ERR
Else
 STA = 1
 MES = REF-":"-mess(14,143,1) : # Rendez-vous supprimé
Endif

End STA

#--------------#
$TR_ANU
GOK=1
Trbegin [AEC]
 Gosub ANU
 If GOK=0 : Goto AB_TR_ANU : Endif
Commit
Return

$AB_TR_ANU
Rollback
Return

#--------------#
$ANU
Delete [AEC] Where NUMLIG=val(REF)
If fstat
 GOK=0 : Call FSTA("AEC") From GLOCK
Endif
Return

#---------------------------------------------------------#
# Epuration journalière des rendez-vous
#---------------------------------------------------------#

Funprog EPURDV(MES)
Variable Char    MES : # Message du statut en clair

Local Integer STA : # Statut de retour (1=tout va bien)
Local Integer OGSERVEUR , OKEPU
Local Integer TRC
Gosub SET_GLOBAL_CONVERGENCE

If TRC
  Call TRACE_CLEAR
  Call TRACE("EPURDV - 1: adxusr=" + adxusr + ", nomap=" + nomap)
Endif

If filinfo(filpath("FIL","AECLIRDV","fde"),0)<=0
 MES = ""
 End 0
Endif

If clalev([F:AEC])=0 : Local File AECLIRDV [AEC] : Endif

Raz MES

# Epuration si pas d'enregistrement rajoutés dans la journée
Filter [AEC] Where CREDAT=date$
Read [AEC]AEC0 Last
OKEPU = fstat
Filter [AEC]

If !OKEPU
 MES = mess(15,143,1) : # Aucun enregistrement à supprimer
 End 0
Endif

# Transaction
If !adxlog
 OGSERVEUR = GSERVEUR
 GSERVEUR = 1
 Gosub TR_EPU
 GSERVEUR = OGSERVEUR
Else
 Gosub EPU
Endif

# Status retour
If GOK<1
 Gosub ERR
Else
 STA = 1
 MES = mess(16,143,1) : # Rendez-vous épurés
Endif

End STA

#--------------#
$TR_EPU
GOK=1
Trbegin [AEC]
 Gosub EPU
 If GOK=0 : Goto AB_TR_EPU : Endif
Commit
Return

$AB_TR_EPU
Rollback
Return

#--------------#
$EPU
Delete [AEC] Where TYPEXE<>"PXS" & TYPEXE<>"PXH"
If fstat
 GOK=0 : Call FSTA("AEC") From GLOCK
Endif
Return

#---------------------------------------------------------#
# Statut d'un rendez-vous
#---------------------------------------------------------#

Funprog STARDV(REF,MES)
Value    Char    REF : # Identifiant interne du rendez-vous (unique pour la solution)
Variable Char    MES : # Message du statut en clair

Local Integer STA   : # Statut de retour
Local Integer NBSES : # Nbre de sessions dispo
Local Integer TRC

#If GUSER="ERBOU" : TRC=1 : Endif

If TRC
  Call TRACE("STARDV - 1: adxusr=" + adxusr + ", nomap=" + nomap)
Endif

If clalev([F:AEC])=0 : Local File AECLIRDV [AEC] : Endif

Gosub SET_LOGIN

# Status
#---------------#
# 1 Attente
# 2 En cours
# 3 Terminé
# 4 Avorté
# 5 Erreur

MES = ""

# Contrôle Rendez-vous
Read [AEC]AEC0=val(REF)
If fstat
 STA = 3
 MES = REF-":"-mess(12,143,1) : # Rendez-vous inexistant
Else
 Case [F:AEC]TYPRDV
  When 1 : STA = 1
  When 2 : STA = 2
  When 3 : STA = 4
  When 4 : STA = 6
  When 5 : STA = 6
 Endcase
 MES = mess([F:AEC]TYPRDV,7862,1)
Endif

If STA=1 : # En attente
 # Existe-t-il encore un client de libre
 Call LIBRE(LOGIN,adxuid(1),APPLI,OK,NBSES)
 If !OK
  STA = 5
  MES = mess(17,143,1) : # Plus de candidat potentiel pour le rendez-vous
  End STA
 Endif
Endif

End STA

#---------------------------------------------------------#
# Recherche d'un rendez-vous en attente
#---------------------------------------------------------#

Funprog EXERDV(WRK,NAM,REF,TRT,MES)
Value    Char    WRK : # Nom du Workspace IDE
Value    Char    NAM : # Alias de l'IDE
Variable Char    REF : # Identifiant interne du rendez-vous (unique pour la solution)
Variable Char    TRT : # Nom du traitement
Variable Char    MES : # Message du statut en clair

Local Integer STA : # Statut de retour (1=tout va bien)
Local Integer OGSERVEUR , OKTRT , ER , PRTD
Local Char    CRITERE(250) , ZON(30) , TYP(3) , MACD(250)
Local Integer TRC
Gosub SET_GLOBAL_CONVERGENCE

#If GUSER="ERBOU" : TRC=1 : Endif

If TRC
  Call TRACE("EXERDV - 1: adxusr=" + adxusr + ", nomap=" + nomap)
Endif

Gosub SET_LOGIN

If clalev([F:AEC])=0 : Local File AECLIRDV [AEC] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif

# Critères d'affinité
CRITERE = ""
For ZON="ALIIDE","LOGIN","DOSSIER","SRVCLI","PORT","TYPEXE"
 If ZON<>""
  If CRITERE<>"" : CRITERE += ' & ' : Endif
  Case ZON
   When "ALIIDE"  : If [L]NAM<>"" : CRITERE += 'ALIIDE="'+[L]NAM+'"' : Endif
   When "LOGIN"   : CRITERE += 'LOGIN="'+[L]LOGIN+'"'
   When "DOSSIER" : CRITERE += 'DOSSIER="'+[L]APPLI+'"'
   When "SRVCLI"  : CRITERE += 'SRVCLI="'+adxmac(-2)+'"'
   When "PORT"    : CRITERE += 'PORT='+num$(adxtcp)
   When "TYPEXE"  : If dim([F:AEC]TYPEXE) > -1 : CRITERE += 'TYPEXE<>"ATT" & TYPEXE<>"PXS" & TYPEXE<>"PXH"' : Endif
  Endcase
 Endif
Next ZON
If CRITERE="" : CRITERE = "1=1" : Endif

If TRC
  Call TRACE("EXERDV - 1a: critere=" + CRITERE)
Endif

# Recherche d'un rendez-vous
Raz REF , TRT , MES , OKTRT , TYP, PRTD, MACD
For [AEC] Where TYPRDV=1 & evalue(CRITERE)
 TRT = [F:AEC]CODTRT
 If dim([F:AEC]TYPEXE) > -1
  TYP = [F:AEC]TYPEXE
  PRTD = [F:AEC]DBGPRT
  MACD = [F:AEC]DBGMAC
 Endif
 REF = num$([F:AEC]NUMLIG)
 OKTRT = 1 : Break
Next AEC
If !OKTRT
 If TRT<>""
  STA = 4
  MES = TRT-":"-mess(90,123,1) : # Traitement inexistant
 Else
  STA = 2
  MES = mess(18,143,1) : # Pas de rendez-vous en attente
 Endif
 If TRC
  Call TRACE("EXERDV - 2: STA=" + num$(STA))
 Endif
 End STA
Endif

If TRC
  Call TRACE("EXERDV - 2: STA="-num$(STA) + ", PID=" + num$(adxpid) + ", TRT=" + TRT + ", TYP=" + TYP + ", port=" + num$(PRTD) + ", host=" + MACD)
  Call TRACE("EXERDV - 3: adxlog="-num$(adxlog))
Endif

# Transaction
If !adxlog
 OGSERVEUR = GSERVEUR
 GSERVEUR = 1
 Gosub TR_EXE
 GSERVEUR = OGSERVEUR
Else
 Gosub EXE
Endif

If TRC
  Call TRACE("EXERDV: GOK="-num$(GOK))
Endif
# Status retour
If GOK<1
 Gosub ERR
Else

  Call SET_DEBUG_GLOBAL(PRTD, MACD)

  If TRC
    Call TRACE("EXERDV - 4: GDBGPORT="-num$(GDBGPORT) + ", GDBGMAC=" + GDBGMAC)
  Endif

 #If func AFNC.PARTSEP(ver$(0),2," ")<="16r.114" #or func AFNC.PARTSEP(ver$(0),2," ")="Debug"
 If func AFNC.PARTSEP(ver$(0),2," ")<="16r.114"
  Onerrgo PBRUN
  If TYP = "DBG" # Start debugging if rdv is a debug one, since 2011-05-20
    If dim(GDBGRDV) < 0 : Global Integer GDBGRDV : Endif
    GDBGRDV = 1
    If TRC
      Call TRACE("EXERDV - 5a: dbgmode(1)=1 - GDBGRDV="-num$(GDBGRDV))
    Endif
    dbgmode(1)=1
    GDBGRDV = 0
  Endif
  Run =TRT
  Onerrgo
  If ER
   STA = 4 : # Erreur
  Else
   STA = 3 : # Terminé
  Endif
  ER = func MAJRDV(REF,STA,MES) : # Mise à jour flag
  MES = TRT-":"-mess(282,139,1) : # Traitement exécuté
 Else
  STA = 1
  MES = mess(19,143,1) : # Mise en relation établie
  If TYP = "DBG" # Start debugging if rdv is a debug one, since 2011-05-20
    If dim(GDBGRDV) < 0 : Global Integer GDBGRDV : Endif
    GDBGRDV = 1
    If TRC
      Call TRACE("EXERDV - 5b: dbgmode(1)=1 - GDBGRDV="-num$(GDBGRDV))
    Endif
    dbgmode(1)=1
    GDBGRDV = 0
  Endif
 Endif
Endif
End STA

$PBRUN
If dim(TRC) & TRC
  Call TRACE("RUN ERROR: "-num$(errn) - errmes$(errn))
Endif
ER = errn
Resume

#--------------#
$TR_EXE
GOK=1
Trbegin [AEC]
 Gosub EXE
 If GOK<0 : Goto ROLL_TR_EXE
 Elsif !GOK : Goto AB_TR_EXE
 Endif
Commit
Return

$AB_TR_EXE
Rollback
Return

$ROLL_TR_EXE
Rollback
Call ROLL From GLOCK
If !GROLL : Goto TR_EXE : Endif
Return

#--------------#
$EXE
Readlock [AEC]AEC0=val(REF)
If fstat=1
 GOK=-1 : GLOCK="$AECLIRDV"
Elsif fstat
 GOK=0 : Call FSTA("AEC") From GLOCK
Endif
If GOK=1
 [F:AEC]TYPRDV = 3 : # Terminé
 [F:AEC]UNICID = adxpid
 Read [AUS]LOGIN=toupper([L]LOGIN)
 If !fstat
  [F:AEC]UPDUSR = [F:AUS]USR
 Endif
 [F:AEC]UPDDAT  = date$
 [F:AEC]UPDTIM  = time
 [F:AEC]DATDEB  = date$
 [F:AEC]HEUDEB  = time
 Rewrite [AEC]
 If fstat
  GOK=0 : Call FSTA("AEC") From GLOCK
 Endif
Endif
Return

#---------------------------------------------------------#
# Mise à jour du statut d'un rendez-vous
#---------------------------------------------------------#

Funprog MAJRDV(REF,TYP,MES)
Value    Char    REF : # Identifiant interne du rendez-vous (unique pour la solution)
Value    Integer TYP : # Nouveau statut
Variable Char    MES : # Message du statut en clair

Local Integer STA : # Statut de retour (1=tout va bien)
Local Integer OGSERVEUR
Local Integer TRC
Gosub SET_GLOBAL_CONVERGENCE

If TRC
  Call TRACE("MAJRDV - 1: adxusr=" + adxusr + ", nomap=" + nomap)
Endif

Gosub SET_LOGIN

If clalev([F:AEC])=0 : Local File AECLIRDV [AEC] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif

MES = ""

# Contrôle Rendez-vous
Read [AEC]AEC0=val(REF)
If fstat
 STA = 3
 MES = REF-":"-mess(12,143,1) : # Rendez-vous inexistant
 End STA
Endif

# Transaction
If !adxlog
 OGSERVEUR = GSERVEUR
 GSERVEUR = 1
 Gosub TR_MAJ
 GSERVEUR = OGSERVEUR
Else
 Gosub MAJ
Endif

# Status retour
If GOK<1
 Gosub ERR
Else
 STA = 1
 MES = REF-":"-mess(20,143,1)-"->"-mess(TYP,7862,1) : # Nouveau statut
Endif

End STA

#--------------#
$TR_MAJ
GOK=1
Trbegin [AEC]
 Gosub MAJ
 If GOK<0 : Goto ROLL_TR_MAJ
 Elsif !GOK : Goto AB_TR_MAJ
 Endif
Commit
Return

$AB_TR_MAJ
Rollback
Return

$ROLL_TR_MAJ
Rollback
Call ROLL From GLOCK
If !GROLL : Goto TR_MAJ : Endif
Return

#--------------#
$MAJ
Readlock [AEC]AEC0=val(REF)
If fstat=1
 GOK=-1 : GLOCK="$AECLIRDV"
Elsif fstat
 GOK=0 : Call FSTA("AEC") From GLOCK
Endif
If GOK=1
 [F:AEC]TYPRDV = TYP
 [F:AEC]UNICID = adxpid
 Read [AUS]LOGIN=toupper([L]LOGIN)
 If !fstat
  [F:AEC]UPDUSR = [F:AUS]USR
 Endif
 [F:AEC]UPDDAT  = date$
 [F:AEC]UPDTIM  = time
 If TYP>=3 : # Terminé
  [F:AEC]DATFIN  = date$
  [F:AEC]HEUFIN  = time
 Endif
 Rewrite [AEC]
 If fstat
  GOK=0 : Call FSTA("AEC") From GLOCK
 Endif
Endif
Return

#---------------------------------------------------------#
# Liste des rendez-vous
#---------------------------------------------------------#

Funprog LISRDV
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"AECLIRDV","AECLIRDV","") From GSAISIE
# New AECLIRDV mask use SUBAEC1 but it is not called directly by eclipse so for compability
# with previous env we keep the old code
#Call SAISIE_CHAR(VALEUR,PARAM,"AECLIRDV","SUBAEC1","") From GSAISIE
End ""

#-----------------------------------------------------------#
Subprog TRACE(MESSAGE)
Value Clbfile MESSAGE
#If GOS="unix"
# Openo "/tmp/eclipse.log" Using [ZZZ]
#Else
# Openo "C:\eclipse.log" Using [ZZZ]
#Endif
Openo filpath("TRA","X3RDV_" + toupper(ctrans(adxusr,".\/|*@","______")),"tra" ,0) Using [ZZZ]
Wrseq date$-time$-MESSAGE Using [ZZZ]
Openo Using [ZZZ]
End

Subprog TRACE_CLEAR
  Openo filpath("TRA","X3RDV_" + toupper(ctrans(adxusr,".\/|*@","______")),"tra" ,0),0 Using [ZZZ]
  Openo Using [ZZZ]
End


#---------------------------------------------------------#
# Récupération d'un rendez-vous de type Attach (debug)
#---------------------------------------------------------#

#**
#* Find a pending debug event of type 'Attach' or 'Proxy'
#*!
Funprog ATTACHRDV(PID,WRK,NAM,REF,TRT,MES)
  Value    Integer PID : # Identifiant unique du process
  Variable Char    WRK : # Nom du Workspace IDE
  Variable Char    NAM : # Alias de l'IDE
  Variable Char    REF : # Identifiant interne du rendez-vous (unique pour la solution)
  Variable Char    TRT : # Nom du traitement
  Variable Char    MES : # Message du statut en clair

  Local Integer STA : # Statut de retour (1=tout va bien)
  Local Integer OGSERVEUR, OKTRT, ER, PRTD
  Local Char    CRITERE(250), ZON(30), TYP(3), PREFTYP(3), PREFTYP2(3), MACD(250)
  Gosub SET_GLOBAL_CONVERGENCE
  Gosub SET_LOGIN

  If clalev([F:AEC])=0 : Local File AECLIRDV [AEC] : Endif
  If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif

  #--------------------------------------------------------------------------------------------
  # Critères d'affinité
  CRITERE = '(UNICID=' + num$(PID) + ' & TYPEXE="ATT")'
  CRITERE += ' | (DOSSIER="' + [L]APPLI + '" & LOGIN="' + [L]LOGIN + '" & (TYPEXE="PXS" | TYPEXE="PXH"))'

  If func AXDTMAIN.IS_SYRACUSE_SESSION
    PREFTYP = "PXH" : PREFTYP2 = "PXS"
  Else
    PREFTYP = "PXS" : PREFTYP2 = "PXH"
  Endif

  # Recherche d'un rendez-vous
  Raz WRK, NAM, REF, TRT, MES, OKTRT, TYP, PRTD, MACD
  Filter [AEC] Where TYPRDV=1 & evalue(CRITERE) Order By TYPEXE
  For [AEC]
    WRK = [F:AEC]WRKIDE
    NAM = [F:AEC]ALIIDE
    TRT = [F:AEC]CODTRT
    TYP = [F:AEC]TYPEXE
    REF = num$([F:AEC]NUMLIG)
    OKTRT += 1
    If dim([F:AEC]DBGMAC) > -1
      PRTD = [F:AEC]DBGPRT
      MACD = [F:AEC]DBGMAC
      If find(TYP, "ATT", PREFTYP) > 0
        Break
      Else
        PREFTYP = PREFTYP2
      Endif
    Endif
  Next AEC
  Filter [AEC]

  If OKTRT
    Call SET_DEBUG_GLOBAL(PRTD, MACD)
    If find(TYP, "PXS", "PXH") = 0
      STA = func MAJRDV(REF, 3, MES) : # Rendez-vous pris en compte
    Else
      STA = 1
    Endif
  Else
    STA = 2
    MES = mess(18,143,1) : # Pas de rendez-vous en attente
  Endif
End STA

Subprog SET_DEBUG_GLOBAL(PORT, MACHINE)
Value Integer PORT
Value Char    MACHINE()
  If dim(GDBGPORT) < 0 : Global Integer GDBGPORT : Endif
  If dim(GDBGMAC) < 0 : Global Char GDBGMAC(250) : Endif
  If MACHINE <> ""
    GDBGMAC = MACHINE
  Endif

  If PORT > 0
    GDBGPORT = PORT
  Endif
End

