#<AdxTL>@(#)2.0.0.0 $Revision$
# Representation APLCOM

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
      When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
      When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
      When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
      When "AREAD_AFTER"                  : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "ACM.TYP"      : Gosub TYP
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return




##############################################################################################
$AREAD_AFTER
Gosub TYP_DISPLAY
Return


##############################################################################################
$TYP
  Case [L]ARULE
    When "PROPAGATE" : Gosub TYP_PROPAGATE
  Endcase
Return

$TYP_PROPAGATE
Gosub TYP_DISPLAY
Return
##############################################################################################

$TYP_DISPLAY
Local Integer MY_STATUS
If dim(this.TYP)>0 # Create
  If this.TYP=7                     # Alphanumeric
    [L]MY_STATUS = fmet this.ASETATTRIBUTE("LENGTH", "$isDisabled", "false")
  Else
    [L]MY_STATUS = fmet this.ASETATTRIBUTE("LENGTH", "$isDisabled", "true")
  Endif
Else                # Modify
  If this.ACM.TYP=7                     # Alphanumeric
    [L]MY_STATUS = fmet this.ACM.ASETATTRIBUTE("LENGTH", "$isDisabled", "false")
  Else
    [L]MY_STATUS = fmet this.ACM.ASETATTRIBUTE("LENGTH", "$isDisabled", "true")
    this.ACM.LENGTH = AVOID.AINT
  Endif
Endif
Return


##############################################################################################
$AQUERY_DECODE_CRITERIA_AFTER
Raz NBPRO
NBPRO += 1
TBPRO(NBPRO) = "COMNOM"
TBTYP(NBPRO) = 7
TBPTH(NBPRO) = "ACM.COMNOM"
TBFIL(NBPRO) = "[LNK_]COMNOM"
Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]COMNOM"
Return

$AQUERY_OPEN_AFTER
Local File APLCOM [QRY_ACM]
Local Integer I : I=0
Local Char TCOMNOM(12)(1..)
For [QRY_ACM]COMCLE(1)
 I+=1
 TCOMNOM(I) = [F:QRY_ACM]COMNOM
Next
If I=0
  Local File APLCOM [LNK_]
Else
  Local File (Char COMNOM   (100)) From Variable TCOMNOM As [LNK_]
Endif
Return

$AQUERY_TRANS_AFTER
this.ACM.COMNOM = [LNK_]COMNOM
Return

$AQUERY_CLOSE_AFTER
Close Local File [LNK_]
Return

