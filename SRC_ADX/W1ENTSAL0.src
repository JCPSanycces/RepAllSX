$ON_CIVA
Onevent BEFORE_INPUT Call AS_CIVA(zc) From W1ENTSAL0
Onevent CONTROL Call C_CIVA(zc) From W1ENTSAL0
Onevent AFTER_CHANGE Gosub AMM_CIVA From W1ENTSAL0
Return

Subprog IB_CIVA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTBOUT
 Call BOUTSEL(VALEUR,"M",[M]NOLIB,"") From FMTVAR
Endif
## Action STD
Call IB_CIVA From SUBHRENT
Gosub _AFF
End

Subprog AS_CIVA(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_CIVA(VALEUR)
## Action AFMTSAI
Call ASAISIE(VALEUR,"M") From FMTVAR
If mkstat=2
 [M]CIVA(INDIC) = VALEUR
 Affzo CIVA(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CIVA(zc) From W1ENTSAL0
Onkey   2 Titled GBOUTS Call S_CIVA(zc) From W1ENTSAL0
Gosub _AFF
End

Subprog C_CIVA(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
If !mkstat
 ## Action AFMTCONT
 Call CONTROLE(VALEUR,"M",[M]NOLIB,15,[M]VALINT) From FMTVAR
 If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
 If !mkstat
  ## Action ACONTACL
  Call CONTACL([M]VALINT,"M","","") From SUBACL
  If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CIVA
Call AM_CIVA(zc)
If !mkstat & GOBJET
 zoncou = "CIVA" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CIVA(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CIVA(VALEUR) From SUBHRENT
If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
Gosub _AFF
End

Subprog S_CIVA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]NOLIB)
 PARMSK(3) = "15"
 PARMSK(4) = [M]VALINT
 PARMSK(5) = [M]VALPAR
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINT = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]NOLIB)
 PARMSK(3) = "15"
 PARMSK(4) = [M]VALINT
 PARMSK(5) = [M]VALPAR
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINT = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CIVA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call B1_CIVA(VALEUR) From SUBHRENT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

