#<AdxTL>@(#)2.0.0.0 $Revision$
#//from SUPPAY2
Raz GBIDC1
Call OBJET("RBB",GBIDC1,GBIDC2) From GOBJET
End


$SELECH
Case ACTSELECH
 When "DEBUT"
  Local Char    OPT(1), ODEFMASK(200), CODE_ESC(10)
  Local Char    CRITERE(200), BPR(GLONBPR)
  Local Integer IND, CAS, FINTYP, I, J, K, WSTAT
  Local Integer BPROPT, FCYOPT
  Local Libelle BPRFIX, FLMT
  Local Decimal NNUM, NLIG
  Local Decimal MT, MTBAN

  If OPT="" : Call PARAM(VALEUR,"SEVFCYENT",OPT) From ADOVAL : Endif
  [L]FCYOPT=val(OPT) : # OD inter-sites
  Call PARAM(VALEUR,"SEVBPRENT",OPT) From ADOVAL
  [L]BPROPT=val(OPT) : # OD inter-tiers

  ODEFMASK=dbgstr(1)
  IND=SAVNOLIGN2-1 : NNUM=[M:RBK1]DUDNUM(IND) : NLIG=[M:RBK1]DUDLIG(IND)
  If NNUM<>0 & NLIG<>0
    If [F:DUD]ACCNUM<>NNUM | [F:DUD]DUDLIG<>NLIG
     Read [DUD]DUD1 = NNUM;NLIG
    Else
     fstat=0
    Endif
    If fstat=0 & [F:DUD]NUM=VALEUR
     CAS=3
    Endif
  Endif
  If CAS : FIN=1 : FINTYP=0 : Return : Endif
  If [L]FCYOPT=1 : CRITERE="FCY='"+[M:RBK1]FCYLIN([V]GCURR_NOLIGN-1)+"'"
  Else           : CRITERE="CPY='"+[M:RBK0]CPY+"'"
  Endif

  CRITERE += " & DUDSTA=2 & FLGPAZ>3"
  CRITERE += " & TYP='"+[M:RBK1]VCRTYP(IND)+"'"


  If VALEUR<>"" : CRITERE+=" & NUM='"+VALEUR+"'" : Endif

  [L]BPR=[M:RBK1]BPRNUM([V]GCURR_NOLIGN-1)
  Filter [DUD] Where evalue(CRITERE) & BPRPAY=[L]BPR

  Local Mask REGECHW [RECH]
  Default Mask ODEFMASK
  Raz [M:RECH] : I = dim([M:RECH]BPRPAY)
  nolign = 0 : J = 0
  #Repeat
  # If [L]BPR<>"" : [L]BPRFIX=![L]BPRFIX : Endif
  # If [L]BPR="" & VALEUR<>""
  #  Filter [DUD] Where evalue(CRITERE) Order By Key DUD0
  # Else
  #  Filter [DUD] Where evalue(CRITERE) Order By Key DUD3
  # Endif
   ## Chargement des échéances dans la masque de sélection : on fait apparaître uniquement les échéances
   ## qui ont un solde supérieur ou égal au montant du règlement
   For [DUD] Where FLGCLE=1 & ((BPRPAY=[L]BPR & [L]BPRFIX) | ![L]BPRFIX) With Nohint
    If nolign>=I : Break : Endif
    Call MTECHE(MT,MTBAN,-1,WSTAT)
    nolign+=1 : [M:RECH]=[F:DUD]
    [M:RECH]ACCLIG(nolign-1)=[F:DUD]DUDLIG
    [M:RECH]SOLDE(nolign-1)=MT
    [M:RECH]TOTAL += [M:RECH]AMTCUR(nolign-1)-[M:RECH]SOLDE(nolign-1)
    If !J & MT>0 : J=nolign : Endif
    If NNUM=[F:DUD]ACCNUM & NLIG=[F:DUD]DUDLIG : J=nolign : Endif
   Next :#[DUD]
   [M:RECH]DEVISE = [M:RECH]CUR(0)
  #Until nolign | ![L]BPRFIX
  Filter [DUD]
  If !J : J=1 : Endif
  [M:RECH]NECH=nolign
  If nolign>1 & !find("",[M:RECH]BPRFCT(0..[M:RECH]NECH-1))
   # Facture gérée par le factor XXX
   GMESSAGE=mess(89,121,1)-[M:RECH]BPRFCT(0) : GERR=1 :  FIN=1 : FINTYP=2 : Return
  Endif
  CHARGE=0 : Default Mask [RECH]

 When "FIN"
  If !CAS & PARAM(3)="1"
   NNUM=val(PARAM(1)) : NLIG=val(PARAM(2))
  Endif

  IND=SAVNOLIGN2-1 : PARAM(1)=num$([M:RBK1]DUDNUM(IND)) : PARAM(2)=num$([M:RBK1]DUDLIG(IND))
  Default Mask ODEFMASK
  If FINTYP=2 | (!CAS & PARAM(3)="-1") : mkstat=2 : Return
  Elsif !CAS & PARAM(3)="0" : # Pas d'échéance
   # Aucune échéance
   GMESSAGE=mess(10,117,1) : mkstat=2 : Return
  Endif

  GMESSAGE=""
  If CAS=0 | CAS=3
   ## Contrôles bloquants
   Read [DUD]DUD1 = NNUM;NLIG
   If fstat
    GOK=2 : Call RSTA("DUD",num$(NNUM)-num$(NLIG)) From GLOCK : mkstat=2 : Return
   Endif
   Gosub CTL_DUD
   If GMESSAGE<>"" : mkstat=2 : Return : Endif
   If NNUM<>[M:RBK0]OD1 | NLIG<>[M:RBK0]OD2
    Call MTECHE(MT,MTBAN,IND,WSTAT) : FLMT=1
    If WSTAT : mkstat=2 : Return : Endif
    # Echéance déjà soldée
    If [F:DUD]AMTCUR*MT<=0 : GMESSAGE+="\"+mess(15,117,1) :  mkstat=2 : Return : Endif
    Gosub VRF_DUD
    If instr(1,GMESSAGE,mess(28,121,1)) : mkstat=2 : Return : Endif
   Endif : # NNUM<>DUDNUM & NLIG<>DUDLIG
  Endif
  ## Avertissements
  If CAS<>2 & (NNUM<>[M:RBK0]OD1 | NLIG<>[M:RBK0]OD2)
   For I=0 To [M:RBK1]NBDUD-1
    If I<>IND & [M:RBK1]DUDNUM(I)=NNUM & [M:RBK1]DUDLIG(I)=NLIG
    GMESSAGE+="\"+mess(22,117,1)-num$(I+1) :# Echéance imputée ligne I+1
   Endif
  Next I
  If len(GMESSAGE)>=mod(type(GMESSAGE)-10,256)
   # Echéance imputée sur plusieurs lignes
   GMESSAGE="\"+mess(140,121,1)
  Endif
  If GMESSAGE<>""
   GMESSAGE=right$(GMESSAGE,2)
   I=2 : Call AVERTIR(GMESSAGE,I) From GESECRAN
   GMESSAGE="" : If I<>2 : mkstat=2 : Return : Endif
  Endif
 Endif

 If NNUM<>[M:RBK1]DUDNUM(IND) | NLIG<>[M:RBK1]DUDLIG(IND)
  PARAM(1)=num$(NNUM) : PARAM(2)=num$(NLIG)

  CODE_ESC = [F:DUD]DEP

  If [M:RBK1]BPRNUM([V]GCURR_NOLIGN-1)=""
   [M:RBK1]BPRNUM([V]GCURR_NOLIGN-1) = [F:DUD]BPRPAY
   Affzo [M:RBK1]BPRNUM([V]GCURR_NOLIGN-1)
  Endif
  [M:RBK1]DUDNUM(IND)    = NNUM
  [M:RBK1]DUDLIG(IND)    = NLIG
  [M:RBK1]DUDDAT(IND)    = [F:DUD]DUDDAT
  [M:RBK1]AMTLIN(IND)    = MTBAN
  [M:RBK1]AMTLINCUR(IND) = MT
  [M:RBK1]VCRNUM(IND)    = [F:DUD]NUM
 Endif
Endcase
Return

$CTL_DUD
If [F:DUD]BPRFCT<>""
 # Facture gérée par le factor FACTOR
 GMESSAGE = mess(89,121,1)-[F:DUD]BPRFCT
 Return
Endif

If [F:DUD]DUDSTA<>2 & !find([F:DUD]TYP,"*SO","*PO")
  ## Echéance non validée
  GMESSAGE = mess(28,121,1)
  Return
Endif

If [F:DUD]FLGPAZ=3
 # Echéance sans 'bon à payer'
 GMESSAGE = mess(16,117,1)- "("+mess([F:DUD]FLGPAZ,510,1)+")"
 Return
Endif

If [L]BPROPT=1 & [M:RBK1]BPRNUM([V]GCURR_NOLIGN-1)<>"" & !find([F:DUD]TYP,"*SO","*PO")
&  & ([F:DUD]BPR<>[M:RBK1]BPRNUM([V]GCURR_NOLIGN-1))
 # Génération OD-Tiers SAC BPR
 GMESSAGE = mess(19,117,1)-[F:DUD]SAC-[F:DUD]BPR
Endif

Read [F:HAE]HAE0=[F:DUD]NUM;[F:DUD]TYP
If !fstat
  If [F:HAE]CAT = 2 | [F:HAE]CAT = 3
     # Pièces de simulation interdites
     GMESSAGE = mess(6,107,1)
  Elsif [F:HAE]CAT = 5
     # Pièces modèles interdites
     GMESSAGE = mess(55,106,1)
  Elsif [F:HAE]FLGREP=2
    # Pièce de fin d'exercice
    GMESSAGE = mess(20,121,1)
  Endif
Endif

Return


$VRF_DUD
If [F:DUD]SOINUM<>"" & OPT<>"R" : # Echéance sur relevé SOINUM
 GMESSAGE+="\"+mess(17,117,1)-[F:DUD]SOINUM
Endif
If [L]FCYOPT=3 & [M:RBK1]FCYLIN([V]GCURR_NOLIGN-1)<>"" & [F:DUD]FCY<>[M:RBK1]FCYLIN([V]GCURR_NOLIGN-1) : # Génération OD-sites
 GMESSAGE+="\"+mess(18,117,1)-[M:RBK1]FCYLIN(nolign-1)-"->"-[F:DUD]FCY
Endif
If [L]BPROPT=3 & [M:RBK1]BPRNUM([V]GCURR_NOLIGN-1)<>"" & [F:DUD]BPR<>[M:RBK1]BPRNUM([V]GCURR_NOLIGN-1)
 # Génération OD-tiers
 GMESSAGE+="\"+mess(19,117,1)-[M:RBK1]BPRNUM([V]GCURR_NOLIGN-1)-"->"-[F:DUD]BPR
Endif
If !find([F:DUD]TYP,"*SO","*PO") & [F:DUD]DUDSTA<>2
 # Echéance non validée
 GMESSAGE+="\"+mess(28,121,1)
Endif
Return

#############################
#**
#*
#*
#* @param MT    : out -- montant disponible en devise echeance
#* @param MTBAN : out -- montant disponible en devise banque (saisie)
#* @param IND   : in  -- indice de la ligne
#* @param STAT  : out -- 0=OK
#*!
Subprog MTECHE(MT,MTBAN,IND,STAT)
#############################
Variable Decimal MT
Variable Decimal MTBAN
Value Integer IND
Variable Integer STAT
Local Decimal WCOURS
Local Integer I, SIGN, K, W_STATUT_RBD, WSTAT
STAT=0
MTBAN=0
MT=[F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR :#-- disponible
For I=0 To [M:RBK1]NBDUD-1
 If I<>IND  & [F:DUD]ACCNUM=[M:RBK1]DUDNUM(I) & [F:DUD]DUDLIG=[M:RBK1]DUDLIG(I)
  If [M:RBK1]DUDNUMORI(I)=[F:DUD]ACCNUM & [M:RBK1]DUDLIGORI(I)=[F:DUD]DUDLIG
    MT+=[M:RBK1]AMTLINCURORI(I)-[M:RBK1]AMTLINCUR(I)
  Else
    MT-=[M:RBK1]AMTLINCUR(I)
  Endif
 Endif
Next I

##
## pour le releve en cours, on soustrait le montant deja affecte sur l'echeance ...
## sur d'autre lignes non validées du relevé et qui n'avaient pas ete affectés a une echéance
For [F:RBW]RBW1 Where DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG & DUDNUMORI=0
&                   & RBKNUM=[V]GCURR_RBKNUM & RBKLIN<>[M:RBK1]WINDEX([V]GCURR_NOLIGN-1)
  Gosub FIND_STAT_LINE
  If [L]W_STATUT_RBD<>3 : MT-=[F:RBW]AMTLINCUR : Endif
Next
##
## pour le releve en cours, on soustrait le delta du montant affecte intitialement sur l'echeance
## sur les lignes non validées
For [F:RBW]RBW1 Where (DUDNUMORI=[F:DUD]ACCNUM & DUDLIGORI=[F:DUD]DUDLIG)
&                  & RBKNUM=[V]GCURR_RBKNUM
  Gosub FIND_STAT_LINE
  If [L]W_STATUT_RBD<>3
    If [F:RBW]DUDNUM=[F:DUD]ACCNUM  & [F:RBW]DUDLIG=[F:DUD]DUDLIG
      MT+=[F:RBW]AMTLINCURORI-[F:RBW]AMTLINCUR
     Else
      MT+=[F:RBW]AMTLINCURORI
    Endif
  Endif
Next

##
## conversion du montant devise echeance en devise de la banque
If IND < 0 : End : Endif
If [M:RBK1]DUDNUMORI(IND)=[F:DUD]ACCNUM & [M:RBK1]DUDLIGORI(IND)=[F:DUD]DUDLIG
  MT+=[M:RBK1]AMTLINCURORI(IND)
Endif
If [F:DUD]CUR=[M:RBK0]CUR or MT=0
  MTBAN=MT
  End
Endif

### Call LECTURE("TPY",[M:RBK1]PAYTYP([L]WK),"") From CONTOBJ :#-- @BACKPORTING@ pour V6
Call LEC_TPY_LEG([V]GCURLEG,[M:RBK1]PAYTYP([V]GCURR_NOLIGN-1)) From CPTLEC
WCOURS=0
If [F:TPY]RATINV=2  and [M:RBK0]CUR=[V]GL_DEVLED :##--application taux de la facture
  Read [HAE]HAE0 = [F:DUD]TYP;[F:DUD]NUM
  If fstat
    GMESSAGE=mess(49,125,1)-mess(12,107,1)-[F:DUD]TYP+"/"+[F:DUD]NUM
    STAT=1 : End
  Endif
  If [F:HAE]RATDIV(GTYPGEN-1)<>0
    WCOURS  = [F:HAE]RATMLT(GTYPGEN-1)/[F:HAE]RATDIV(GTYPGEN-1)
  Endif
  Call CONVERT3([F:DUD]CUR, [M:RBK0]CUR, [V]GL_DEVLED, [F:HAE]TYPRAT, [F:HAE]RATDAT, MT, MTBAN,
&               WCOURS, WSTAT) From CPTSUB
  If WSTAT
    ## Pas de cours de devises [F:DUD]CUR -> [M:RBK0]CUR
    GMESSAGE=mess(16,114,1)-[F:DUD]CUR-"->"-[M:RBK0]CUR-"("+format$("D:"+GFMDAT,[F:HAE]RATDAT)-")"
    STAT=1 : End
  Endif
Else
  Call CONVERT3([F:DUD]CUR, [M:RBK0]CUR, [V]GL_DEVLED, [F:TPY]RATTYP, [M:RBK1]ACCDAT([V]GCURR_NOLIGN-1), MT, MTBAN,
&                WCOURS, WSTAT) From CPTSUB
  If WSTAT
    ## Pas de cours de devises [F:DUD]CUR -> [M:RBK0]CUR
    GMESSAGE=mess(16,114,1)-[F:DUD]CUR-"->"-[M:RBK0]CUR-"("+format$("D:"+GFMDAT,[M:RBK1]ACCDAT([V]GCURR_NOLIGN-1))-")"
    STAT=1 : End
  Endif
Endif

End

$FIND_STAT_LINE
[L]K=find([F:RBW]RBKLIN,[M:RBK1]WINDEX(0..[M:RBK1]NBDET-1))
If [L]K>0
  [L]W_STATUT_RBD=[M:RBK1]STATUT([L]K-1)
Else
  ## cas: la ligne a été supprimée -> il faut tout réaffecter et pas seulement le delta
  [L]W_STATUT_RBD=0
  [F:RBW]AMTLINCUR=0
Endif
Return

############################################################################################################
############################################################################################################

