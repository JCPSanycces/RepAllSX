#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SITDIFGL 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone INI
mkstat = 0
zoncou = "INI"
indice = 0
If varinit([M]INI,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call D_INI([M]INI) From SITDGL
 GACTION = SAVACT
Endif

## Zone ALLJOU
mkstat = 0
zoncou = "ALLJOU"
indice = 0
IMPENT = [M]ALLJOU
If varinit([M]ALLJOU,indice)=0
 IMPENT = 2
Endif
If varmode([M]ALLJOU,indice)=0
 [M]ALLJOU(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ALLJOU" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ALLJOU(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ALLJOU" : GZNUM = 6055 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_ALLJOU(IMPENT) From SITDGL
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ALLJOU" : GZNUM = 6055 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]ALLJOU = IMPENT

## Zone JOUSTR
mkstat = 0
zoncou = "JOUSTR"
indice = 0
If varmode([M]JOUSTR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_JOUSTR([M]JOUSTR) From SITDGL
 GACTION = SAVACT
 If mkstat=1 : Raz [M]JOUSTR : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "JOUSTR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]JOUSTR,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "JOUSTR" : GZNUM = 1400 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTJOU"
   Call CONTJOU([M]JOUSTR,"","") From SUBJOU
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "JOUSTR" : GZNUM = 1400 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJN"
    Local Char    VALEUR(250)
    VALEUR = [M]JOUSTR
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
    [M]JOUSTR = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "JOUSTR" : GZNUM = 1400 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone ALLPER
mkstat = 0
zoncou = "ALLPER"
indice = 0
IMPENT = [M]ALLPER
If varinit([M]ALLPER,indice)=0
 IMPENT = 2
Endif
If varmode([M]ALLPER,indice)=0
 [M]ALLPER(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ALLPER" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ALLPER(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ALLPER(IMPENT) From SITDGL
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ALLPER" : GZNUM = 32401 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]ALLPER = IMPENT

## Zone PERSTR
mkstat = 0
zoncou = "PERSTR"
indice = 0
If varmode([M]PERSTR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_PERSTR([M]PERSTR) From SITDGL
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PERSTR : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PERSTR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]PERSTR=[0/0/0]
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "PERSTR" : GZNUM = 1400 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_PERSTR([M]PERSTR) From SITDGL
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PERSTR" : GZNUM = 1400 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PEREND
mkstat = 0
zoncou = "PEREND"
indice = 0
If varmode([M]PEREND,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_PEREND([M]PEREND) From SITDGL
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PEREND : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PEREND" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]PEREND=[0/0/0]
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "PEREND" : GZNUM = 1260 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_PEREND([M]PEREND) From SITDGL
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PEREND" : GZNUM = 1260 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "DATDEBFIN"
    Call DATDEBFIN([M]PEREND,[M:SIL]PERSTR) From EXEFNC
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PEREND" : GZNUM = 1260 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone HISGNR
mkstat = 0
zoncou = "HISGNR"
indice = 0
IMPENT = [M]HISGNR
If varinit([M]HISGNR,indice)=0
 IMPENT = 2
Endif
If varmode([M]HISGNR,indice)=0
 [M]HISGNR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "HISGNR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]HISGNR(indice)
 Endif
Endif
[M]HISGNR = IMPENT

## Zone BROGNR
mkstat = 0
zoncou = "BROGNR"
indice = 0
IMPENT = [M]BROGNR
If varinit([M]BROGNR,indice)=0
 IMPENT = 2
Endif
If varmode([M]BROGNR,indice)=0
 [M]BROGNR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "BROGNR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]BROGNR(indice)
 Endif
Endif
[M]BROGNR = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone DETBPR
mkstat = 0
zoncou = "DETBPR"
indice = 0
IMPENT = [M]DETBPR
If varinit([M]DETBPR,indice)=0
 IMPENT = 2
Endif
If varmode([M]DETBPR,indice)=0
 [M]DETBPR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DETBPR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DETBPR(indice)
 Endif
Endif
[M]DETBPR = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SITDIFGL"
Return

