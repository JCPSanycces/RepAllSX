$PROPERTIES
Case [L]CURPRO
  When "CIV"                        : Gosub EMPLOID_CIV
  When "CIVA"                       : Gosub EMPLOID_CIVA
  When "SRN"                        : Gosub EMPLOID_SRN
  When "PSD"                        : Gosub EMPLOID_PSD
  When "NCKNAM"                     : Gosub EMPLOID_NCKNAM
  When "CTYBRN"                     : Gosub EMPLOID_CTYBRN
  When "NAM"                        : Gosub EMPLOID_NAM
  When "SECNAM"                     : Gosub EMPLOID_SECNAM
  When "CTYBRN"                     : Gosub EMPLOID_CTYBRN
  When "EMPLOIDSA.RSAID"            : Gosub EMPLOIDSA_RSAID
  When "EMPLOCHD.CHDNAM"            : Gosub EMPLOCHD_CHDNAM
  When "SEX"                        : Gosub EMPLOID_SEX
#  When "PERCNT.SRNCNT"              : Gosub EMPLOID_PERCNT_SRNCNT #FRLAA X3-76638 2018-03-06
#  When "PERCNT.NAMCNT"              : Gosub EMPLOID_PERCNT_NAMCNT #FRLAA X3-76638 2018-03-06
#  When "PERCNT.CNTTYP"              : Gosub EMPLOID_PERCNT_CNTTYP #FRLAA X3-76638 2018-03-06
Endcase
Return

$EMPLOID_CIV
Case [L]ARULE
  When "INIT"
    Gosub EMPLOID_CIV_INIT
  When "PROPOGATE"
    Gosub EMPLOID_CIV_PROPOGATE
Endcase
Return

$EMPLOID_CIVA
Case [L]ARULE
  When "INIT"
    Gosub EMPLOID_CIVA_INIT
  When "PROPOGATE"
    Gosub EMPLOID_CIVA_PROPOGATE
Endcase
Return

$EMPLOID_SRN
Case [L]ARULE
When "CONTROL"
    Local Char VLEG(GLONADI)
    VLEG = this.TCH_LEG
    Gosub EMPLOID_SRN_CONTROL
When "PROPOGATE"
    Gosub EMPLOID_SRN_PROPAGATE
Endcase
Return

$EMPLOID_PSD
Case [L]ARULE
When "CONTROL"
    Local Char VLEG(GLONADI)
    VLEG = this.TCH_LEG
    Gosub EMPLOID_PSD_CONTROL
Endcase
Return

$EMPLOID_NCKNAM
Case [L]ARULE
  When "INIT"
    Gosub EMPLOID_NCKNAM_INIT
Endcase
Return

$EMPLOID_CTYBRN
Case [L]ARULE
 When "INIT"
  Gosub EMPLOID_CTYBRN_INIT
 When "CONTROL"
  Gosub EMPLOID_CTYBRN_CONTROL
 When "PROPOGATE"
  Gosub EMPLOID_CTYBRN_PROPOGATE
Endcase
Return

$EMPLOID_NAM
Case [L]ARULE
  When "PROPOGATE"
    Gosub EMPLOID_NAM_PROPOGATE
  When "CONTROL"
    Local Char VLEG(GLONADI)
    VLEG = this.TCH_LEG
    Gosub EMPLOID_NAM_CONTROL
Endcase
Return

$EMPLOID_SECNAM
Case [L]ARULE
  When "PROPOGATE"
    Gosub EMPLOID_SECNAM_PROPOGATE
Endcase
Return


$EMPLOIDSA_RSAID
Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOIDSA_RSAID_CONTROL
Endcase
Return

$EMPLOID_SEX
Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOID_SEX_CONTROL
Endcase
Return



$EMPLOCHD_CHDNAM
Case [L]ARULE
  When "INIT"
    Gosub EMPLOCHD_CHDNAM_INIT
Endcase
Return

$EMPLOID_PERCNT_SRNCNT
Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOID_PERCNT_SRNCNT_CONTROL
Endcase
Return

$EMPLOID_PERCNT_NAMCNT
Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOID_PERCNT_NAMCNT_CONTROL
Endcase
Return

$EMPLOID_PERCNT_CNTTYP
Local Char VLEG(GLONADI)
VLEG = this.APARENT.TCH_LEG

Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOID_PERCNT_CNTTYP_CONTROL
Endcase
Return

