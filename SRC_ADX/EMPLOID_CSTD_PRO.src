$EMPLOID_CIVA_INIT
Local File APLSTD  [AST]
If this.NOLIB<100
  Read [AST]CLE = 0;this.NOLIB;this.ACTX.LAN
Else
  Read [AST]CLE = 200;this.NOLIB-200;this.ACTX.LAN
Endif
#TODO
#GBOUT1=[F:AST]LANMES
LogicClose File [AST]
Return

$EMPLOID_CIVA_PROPOGATE
Local Integer WCIVI
this.CIV=val(this.VALINT)
WCIVI=this.CIV
Call GRISE_OLDNAM(WCIVI)
Return

$EMPLOID_NCKNAM_INIT
Local Char WNAM(40)
If this.OLDNAM=""
   WNAM=this.NAM
Else
   WNAM=this.OLDNAM
Endif
Gosub CAL_NCKNAM
Return

$EMPLOID_SRN_PROPAGATE
Local Char WNAM(40)
If this.OLDNAM=""
   WNAM=this.NAM
Else
   WNAM=this.OLDNAM
Endif
Call CAL_NCKNAM (VALEUR,WNAM)
Return

