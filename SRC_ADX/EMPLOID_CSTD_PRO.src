$EMPLOID_SEX_CONTROL
#Mandatory check as field can be cleared on the basic class
If this.SEX = 0
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00010,00123,1),[V]CST_AERROR)
Endif
Return

$EMPLOID_NAM_CONTROL
#Mandatory check as field can be cleared on the basic class
If this.NAM = ""
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00010,00123,1),[V]CST_AERROR)
Endif
If func DIVPAYE.IS_KUK_LEG(VLEG)
  Gosub EMPLOID_NAM_CONTROL From EMPLOIDUKI_CSTD_PRO
Endif
Return

