#<AdxTL>@(#)1.0.0.0 $Revision$
#Raz GPILOBJ,GNBMASKOUV
#Call VISU("AWI","ABIMOVETA","")
#End

Raz GPILOBJ,GNBMASKOUV
Call OBJET("AOP",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------------------------#
Subprog VISU(OBJET,VALEUR,SUPP)
Value Char OBJET
Value Char VALEUR
Value Char SUPP
Local Char PARAM(250)(1..4)
PARAM(1) = VALEUR
PARAM(2) = OBJET
PARAM(3) = SUPP
PARAM(4) = "1"
Call SAISIE_CHAR(VALEUR,PARAM,"AOPVISU","SUBAOP","SPEAOP") From GSAISIE
End

#-----------------------------------------------#
$ACTION
If dim(BOITE)>0 & BOITE="AOPVISU" : # Action AOPVISU
 Case ACTION
  When "OUVRE"    : Gosub OUVRE_VISU
  When "DEBUT"    : Gosub DEBUT_VISU
  When "TITRE"    : Gosub TITRE_VISU
  When "FIN"      : mkstat = 2
 Endcase
Else
 Case ACTION
  When "LIENS"    : Gosub LIENS
  When "LIENS2"   : Gosub LIENS2
  When "SETBOUT"  : Gosub SETBOUT
  When "CREATION" : Gosub CREATION
  When "MODIF"    : Gosub MODIF
  When "CHANGE"   : Gosub CHANGE
  When "ANNULE"   : Gosub ANNULE
#  When "DEBUT_MOD" : Gosub DEBUT_MOD
 Endcase
Endif
Return

#--------------------#
$LIENS
Return

#--------------------#
$LIENS2
Read [AOB]ABREV = CLECUR1
Call TEXTE([F:AOB]LIBEL,[M:AOP1]LIBEL) From OBJDIV
[M]OBJTBL = [F:AOB]NOMFIC
Return

#--------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

#--------------------#
$MODIF
$CREATION
Call MAJTEXTRA([M]INTIT(nolign-1),"AOBJPROP","INTIT",[M]OBJ,num$([M]NUM(nolign-1))) From ATEXTRA
Return

#--------------------#
$DEBUT_MOD
Delete [AXX] Where CODFIC="AOBJPROP" & ZONE = "INTIT"  & IDENT1=[M]OBJ
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
Return

#--------------------#
$CHANGE
Update [AXX] Where CODFIC="AOBJPROP" & ZONE = "INTIT" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA AOBJPROP"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#--------------------#
$ANNULE
Delete [AXX] Where CODFIC="AOBJPROP" & ZONE = "INTIT"  & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
Return

#---------------------------------#
$TITRE_VISU
TIT = mess(199,123,1) : # Propriétés
If dim([L]CLEVALEUR)<0 | (dim([L]PARAM)>=4 & [L]PARAM(4)="1")
 TIT -= CLE1
Else : ## GEODE
 J=find(CLEVALEUR,CLEPRIM,CLESEC(0..dim(CLESEC)-1))
 If    J=1 : TIT -= CLE1
 Elsif J>1 : TIT -= SUPP(J-2)
 Endif
Endif
Return

#---------------------------------#
$DEBUT_VISU
Raz [M]
For I=1 To VISNBR
 [M]DES(I-1)    = VISDES(I)
 [M]VALEUR(I-1) = VISVAL(I)
Next I
[M]NBLIG = VISNBR
Affzo
Return

#---------------------------------#
$OUVRE_VISU
Onerrgo ERREUR From CONTROLE
GERREUR = 0
If find(PARAM(2),GABRCPT(1..GNBTABCPT)) & GDOSCPT<>""
 If clalev([F:AOP]) : Close Local File [AOP] : Endif 
 If clalev([F:ATX]) : Close Local File [ATX] : Endif 
 If clalev([F:AXX]) : Close Local File [AXX] : Endif
 If clalev([F:AGD]) : Close Local File [AGD] : Endif  
 Local File =GTABCPT+"AOBJPROP" [AOP]
 Local File =GTABCPT+"ATEXTE"   [ATX]
 Local File =GTABCPT+"ATEXTRA"  [AXX] 
 If GSOPHIA & filinfo(filpath("FIL","AOBJGRPDEV","fde"),0)>0
  If clalev([F:AGD])=0 : Local File AOBJGRPDEV [AGD] : Endif
 Endif
Endif
If clalev([F:AOP])=0 : Local File AOBJPROP [AOP] : Endif
If clalev([F:AOB])=0 : Local File AOBJET   [AOB] : Endif
If clalev([F:ATB])=0 : Local File ATABLE   [ATB] : Endif

If GSOPHIA & filinfo(filpath("FIL","AOBJGRPDEV","fde"),0)>0
 If clalev([F:AGD])=0 : Local File AOBJGRPDEV [AGD] : Endif
Endif

Onerrgo
If GERREUR : GERREUR = 0 : FIN = 1 : Return : Endif

Local Char    CHAINE(250)
Local Char    PROGOBJ(GDIMFIC) , PROGSUB(GDIMFIC) , PROGOBJSPE(GDIMFIC) , PROGOBJSPV(GDIMFIC)
Local Integer PSUB , POBJSPE , PSTD, POBJSPV
Local Char    OBJET(GLONAOB), SUPP(GLONID2)(0..16), DEFFIL(10)
Local Char    VISDES(20)(1..20), VISVAL(60)(1..20)
Local Integer VISNBR
Local Integer I , J , K , ER , T , OKTRT
Local Integer TEMPS , HH , MM , SS
Local Char    CLE(GLONAVA)(1..16)
Local Integer NBCLE , CRE , UPD
Local Char    ZONE(80), ABREV(GLONABR)
Local Char    INTITULE(10), NOMFICHIER(15)
Local Integer NUMERO
Local Char    CLE1(GLONID1), CLE2(GLONID2)
Local Integer NUMIND , NUMPART
Local Char    NOMUSER(GLONDES)

CLE1  = PARAM(1)
OBJET = PARAM(2)
If OBJET="AOC"
 OBJET = "AOB"
Endif
CHAINE = PARAM(3)
I = 0
While CHAINE<>""
 K = instr(1,CHAINE,"~")
 If K
  SUPP(I) = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  SUPP(I) = CHAINE
  CHAINE = ""
 Endif
 I += 1
Wend

#--------------------------------------------------------#
# Lecture de l'objet
#--------------------------------------------------------#

Call SETPROG(OBJET,PROGOBJ,PROGSUB,PROGOBJSPE,PROGOBJSPV,PSTD,PSUB,POBJSPE,POBJSPV) From CONTOBJ
If !PSTD : FIN = 1 : Return : Endif

Gosub NOMFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ

If NOMFIC=""
 Call ERREUR(mess(193,133,1)) From GESECRAN : # Objet sans table principale
 FIN = 1 : Return
Endif

Onerrgo ERREUR From CONTROLE
If find(OBJET,GABRCPT(1..GNBTABCPT)) & GDOSCPT<>""
 Local File =GTABCPT+NOMFIC
Else
 If evalue("clalev([F:"+ABFIC+"])")=0
  Gosub OUVFIC From =PROGOBJ
 Endif
Endif
Onerrgo
If GERREUR : GERREUR = 0 : FIN = 1 : Return : Endif

If dim([L]CLEVALEUR)<0 | dim([L]PARAM)<4 | [L]PARAM(4)<>"1"
 # CLE1 -> CLEPRIM, SUPP(i) -> CLESEC(i)
 If evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")>=10
  Assign "[F:"+ABFIC+"]"+CLEPRIM With CLE1
 Elsif evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")=3
  If CLE1="" : CLE1 = "00000000" : Endif
  If instr(1,CLE1,"/")
   Assign "[F:"+ABFIC+"]"+CLEPRIM With evalue("["+CLE1+"]")
  Elsif len(CLE1)=8
   Assign "[F:"+ABFIC+"]"+CLEPRIM With CLE1
  Endif
 Else
  Assign "[F:"+ABFIC+"]"+CLEPRIM With val(CLE1)
 Endif

 For I=0 To dim(CLESEC)-1
  If CLESEC(I)<>""
   If evalue("type([F:"+ABFIC+"]"+CLESEC(I)+")")>10
    Assign "[F:"+ABFIC+"]"+CLESEC(I) With SUPP(I)
   Elsif evalue("type([F:"+ABFIC+"]"+CLESEC(I)+")")=3
    If SUPP(I)="" : SUPP(I) = "00000000" : Endif
    If instr(1,SUPP(I),"/")
     Assign "[F:"+ABFIC+"]"+CLESEC(I) With evalue("["+SUPP(I)+"]")
    Else
     Assign "[F:"+ABFIC+"]"+CLESEC(I) With SUPP(I)
    Endif
   Else
    Assign "[F:"+ABFIC+"]"+CLESEC(I) With val(SUPP(I))
   Endif
  Endif
 Next I

Else : # CLE1 -> CLEVALEUR, SUPP -> CLESUPP(i) : ## GEODE
 If evalue("type([F:"+ABFIC+"]"+CLEVALEUR+")")>=10
  Assign "[F:"+ABFIC+"]"+CLEVALEUR With CLE1
 Elsif evalue("type([F:"+ABFIC+"]"+CLEVALEUR+")")=3
  If CLE1="" : CLE1 = "00000000" : Endif
  If instr(1,CLE1,"/")
   Assign "[F:"+ABFIC+"]"+CLEVALEUR With evalue("["+CLE1+"]")
  Elsif len(CLE1)=8
   Assign "[F:"+ABFIC+"]"+CLEVALEUR With CLE1
  Endif
 Else
  Assign "[F:"+ABFIC+"]"+CLEVALEUR With val(CLE1)
 Endif

 For I=0 To dim(CLESUPP)-1
  If CLESUPP(I)<>""
   If evalue("type([F:"+ABFIC+"]"+CLESUPP(I)+")")>10
    Assign "[F:"+ABFIC+"]"+CLESUPP(I) With SUPP(I)
   Elsif evalue("type([F:"+ABFIC+"]"+CLESUPP(I)+")")=3
    If SUPP(I)="" : SUPP(I) = "00000000" : Endif
    If instr(1,SUPP(I),"/")
     Assign "[F:"+ABFIC+"]"+CLESUPP(I) With evalue("["+SUPP(I)+"]")
    Else
     Assign "[F:"+ABFIC+"]"+CLESUPP(I) With SUPP(I)
    Endif
   Else
    Assign "[F:"+ABFIC+"]"+CLESUPP(I) With val(SUPP(I))
   Endif
  Endif
 Next I

 If CLEFCY<>""
  If dim([M]FCY)>1    : Assign "[F:"+ABFIC+"]"+CLEFCY With [M]FCY(nolign-1) 
  Elsif dim([M]FCY)>0 : Assign "[F:"+ABFIC+"]"+CLEFCY With [M]FCY 
  Else                : Assign "[F:"+ABFIC+"]"+CLEFCY With GFCY
  Endif
 Endif
 If CLEDEP<>""
  If dim([M]DEP)>1    : Assign "[F:"+ABFIC+"]"+CLEDEP With [M]DEP(nolign-1)
  Elsif dim([M]DEP)>0 : Assign "[F:"+ABFIC+"]"+CLEDEP With [M]DEP
  Else                : Assign "[F:"+ABFIC+"]"+CLEDEP With GDEP
  Endif
 Endif
Endif

Gosub DEFAUT From =PROGOBJ
Assign "[G:"+ABFIC+"]currind" With 1
If TYPGES=3
 Assign "[G:"+ABFIC+"]currlen" With dim(CLESEC)
Else
 Assign "[G:"+ABFIC+"]currlen" With 0
Endif
Read =
If fstat>2
 Call MESSAGE(mess(23,100,1)) From GESECRAN : # Fiche inexistante
 Raz [F] : mkstat = 1 : # mb 6.5.2 bug 14205 Sinon on passe CONTOBJ qq soit CLE1
 FIN = 1
 Return
Endif

#--------------------------------------------------------#
# 2) Fichiers liés
#--------------------------------------------------------#

Read [AOP]AOP0(1) = OBJET
If fstat>2 or [F:AOP]NBRTBL=0
 Goto PROPRIETES
Endif

If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif

For K=0 To [F:AOP]NBRTBL-1
 Read [ATB]CODFIC = [F:AOP]TBL(K)
 ABREV = [F:ATB]ABRFIC
 Onerrgo ERREUR From CONTROLE
 If evalue("clalev([F:"+ABREV+"])")=0 
  Local File =[F:AOP]TBL(K)
 Else
  DEFFIL = "["+ABREV+"]"
  Default File DEFFIL
 Endif
 Onerrgo
 If GERREUR : Break : Endif
 Raz NUMIND , CHAINE
 If [F:AOP]CLELNK(K)<>""
  For [ATI]NUMLIG Where CODFIC=[F:AOP]TBL(K)
   Call INDEX(nomap,[F:ATI]CODACT,I) From DOSSUB
   If I
    NUMIND += 1
    If [F:AOP]CLELNK(K)=[F:ATI]CODIND
     CHAINE = [F:ATI]DESCRIPT
     Break
    Endif
   Endif
  Next ATI
  If CHAINE=""
   For [ANX]ANX1 Where TABLE=[F:AOP]TBL(K) & FLACT=2
    NUMIND += 1
    If [F:AOP]CLELNK(K)=[F:ANX]CODIND
     CHAINE = [F:ANX]DESCRIPT
     Break
    Endif
   Next ANX
  Endif
 Endif 
 If CHAINE=""
  NUMIND = 1
  Read [ATI]NUMLIG(2) = [F:AOP]TBL(K);NUMIND
  CHAINE = [F:ATI]DESCRIPT
 Endif
 NBCLE = 0
 While CHAINE<>""
  NBCLE += 1
  I = instr(1,CHAINE,"+")
  J = instr(1,CHAINE,"-")
  If    I & J  : I = min(I,J)
  Elsif J & !I : I = J
  Endif
  If I
   CLE(NBCLE) = left$(CHAINE,I-1)
   CHAINE     = right$(CHAINE,I+1)
  Else
   CLE(NBCLE) = CHAINE
   CHAINE     = ""
  Endif
 Wend
 CHAINE = [F:AOP]LNK(K)
 NUMPART = 0
 While CHAINE<>""
  NUMPART += 1
  I = instr(1,CHAINE,";")
  If I
   ZONE   = left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
  Else
   ZONE   = CHAINE
   CHAINE = ""
  Endif
  Onerrgo RIEN
  Assign "[F:"+ABREV+"]"+CLE(NUMPART) With evalue(ZONE)
  Onerrgo
 Wend
 If NUMPART=NBCLE : NUMPART = 0 : Endif
 If GERREUR : Break : Endif
 Assign "[G:"+ABREV+"]currind" With NUMIND
 Assign "[G:"+ABREV+"]currlen" With NUMPART
 Read =
Next K
If GERREUR : GERREUR = 0 : FIN = 1 : Return : Endif

#-----------------------------------------------------------#
# 3) Evaluation des expressions
#-----------------------------------------------------------#

$PROPRIETES
Raz VISNBR

Gosub DEFAUT From =PROGOBJ
Default [F] , [M] , [S] , [V] , [L]
For [AOP]AOP0 Where OBJ=[L]OBJET
 Onerrgo ERREUR
 [L]CHAINE = num$(evalue([F:AOP]FRM))
 Onerrgo
 VISNBR += 1
 Call LECTEXTRA(VISDES(VISNBR),"AOBJPROP","INTIT",[F:AOP]OBJ,num$([F:AOP]NUM)) From ATEXTRA
 VISVAL(VISNBR) = [L]CHAINE
Next
Default [L] , [V] , [S] , [F] , [M]
If VISNBR=0
 Call LECTURE("AOB",OBJET,"") From CONTOBJ
 NOMFICHIER = [F:AOB]NOMFIC
 Call LECTURE("ATB",NOMFICHIER,"") From CONTOBJ
 If [F:ATB]INTIT<>""
  INTITULE = [F:ATB]INTIT
 Elsif [F:ATB]INTITC<>""
  INTITULE = [F:ATB]INTITC
 Endif
 Case OBJET
  When "AOB" : Call LECTURE("AOB",[L]CLE1,"") From CONTOBJ
  When "ATB" : Call LECTURE("ATB",[L]CLE1,"") From CONTOBJ
 Endcase
 CHAINE = ""
 If INTITULE<>""
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
  Read [ATZ]CODZONE = NOMFICHIER;INTITULE
  If !fstat
   Case [F:ATZ]CODTYP
    When "ATX"
     If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
     Onerrgo ERREUR
     NUMERO = evalue("[F:"+ABFIC+"]"+INTITULE)
     Onerrgo
     Call TEXTE(NUMERO,CHAINE) From OBJDIV
    When "AXX","AX1","AX2","AX3"
     If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
     CLE1 = num$(evalue("[F:"+ABFIC+"]"+CLEPRIM))
     If CLESEC<>""
      CLE2 = num$(evalue("[F:"+ABFIC+"]"+CLESEC))
     Else
      CLE2 = ""
     Endif
     Call LECTEXTRA(CHAINE,NOMFICHIER,INTITULE,CLE1,CLE2) From ATEXTRA
    When Default
     Onerrgo ERREUR
     CHAINE = evalue("[F:"+ABFIC+"]"+INTITULE)
     Onerrgo
   Endcase
  Endif
 Endif
 If CHAINE<>""
  VISNBR = 1
  VISDES(1) = mess(82,123,1) : # Intitulé
  VISVAL(1) = CHAINE
 Endif

 Gosub DEFAUT From =PROGOBJ

 CRE = 0
 T = evalue("type([F:"+ABFIC+"]CREDATTIM)")
 If T=526 & num$(evalue("[F:"+ABFIC+"]CREDATTIM"))<>num$(GDATETIME$(""))
  CRE = 1
  VISNBR += 1
  VISDES(VISNBR) = mess(160,124,1) : # Créé le
  VISVAL(VISNBR) = num$(evalue("[F:"+ABFIC+"]CREDATTIM"))
 Elsif T>0 & T<>526 & evalue("[F:"+ABFIC+"]CREDATTIM")<>""
  CRE = 1
  VISNBR += 1
  VISDES(VISNBR) = mess(160,124,1) : # Créé le
  VISVAL(VISNBR) = func SUBADC.CNVMIL4(evalue("[F:"+ABFIC+"]CREDATTIM"))
 Elsif evalue("dim([F:"+ABFIC+"]CREDAT)")>0 & evalue("[F:"+ABFIC+"]CREDAT")<>[0/0/0]
  CRE = 1
  VISNBR += 1
  VISDES(VISNBR) = mess(160,124,1) : # Créé le
  VISVAL(VISNBR) = format$("D:"+GFMDAT,evalue("[F:"+ABFIC+"]CREDAT"))
  If evalue("dim([F:"+ABFIC+"]CRETIM)")>0
   TEMPS = evalue("[F:"+ABFIC+"]CRETIM")
   If TEMPS<>0
    HH = int(TEMPS/3600)
    MM = int(mod(TEMPS,3600)/60)
    SS = mod(TEMPS,60)
    VISVAL(VISNBR) -= num$(HH)+":"+num$(MM)+":"+num$(SS)
   Endif
  Endif
 Endif
 If CRE
  If evalue("dim([F:"+ABFIC+"]CREUSR)")>0
   NOMUSER = func NOMUSER(evalue("[F:"+ABFIC+"]CREUSR"))
   If NOMUSER<>""
    VISVAL(VISNBR) -= mess(161,124,1)-NOMUSER-"("+evalue("[F:"+ABFIC+"]CREUSR")+")" : # par
   Else
    VISVAL(VISNBR) -= mess(161,124,1)-evalue("[F:"+ABFIC+"]CREUSR") : # par
   Endif
  Endif
  If dim([L]CLEVALEUR)>0 & evalue("dim([F:"+ABFIC+"]CREOPE)")>0 & evalue("[F:"+ABFIC+"]CREOPE")<>""
   VISNBR += 1
   VISDES(VISNBR) = mess(25,310,1) : # Par l'opérateur
   Call LIENS("OPE","OPERATOR",evalue("[F:"+ABFIC+"]CREOPE"),"","NAM",VISVAL(VISNBR)) From CONTOBJ
  Endif
 Endif

 UPD = 0
 T = evalue("type([F:"+ABFIC+"]UPDDATTIM)")
 If T=526 & num$(evalue("[F:"+ABFIC+"]UPDDATTIM"))<>num$(GDATETIME$(""))
  UPD = 1
  VISNBR += 1
  VISDES(VISNBR) = mess(162,124,1) : # Modifié le
  VISVAL(VISNBR) = num$(evalue("[F:"+ABFIC+"]UPDDATTIM"))
 Elsif T>0 & T<>526 & evalue("[F:"+ABFIC+"]UPDDATTIM")<>""
  UPD = 1
  VISNBR += 1
  VISDES(VISNBR) = mess(162,124,1) : # Modifié le
  VISVAL(VISNBR) = func SUBADC.CNVMIL4(evalue("[F:"+ABFIC+"]UPDDATTIM"))
 Elsif evalue("dim([F:"+ABFIC+"]UPDDAT)")>0 & evalue("[F:"+ABFIC+"]UPDDAT")<>[0/0/0]
  UPD = 1
  VISNBR += 1
  VISDES(VISNBR) = mess(162,124,1) : # Modifié le
  VISVAL(VISNBR) = format$("D:"+GFMDAT,evalue("[F:"+ABFIC+"]UPDDAT"))
  If evalue("dim([F:"+ABFIC+"]UPDTIM)")>0
   TEMPS = evalue("[F:"+ABFIC+"]UPDTIM")
   If TEMPS<>0
    HH = int(TEMPS/3600)
    MM = int(mod(TEMPS,3600)/60)
    SS = mod(TEMPS,60)
    VISVAL(VISNBR) -= format$("N0:##",HH)+":"+format$("N0:##",MM)+":"+format$("N0:##",SS)
   Endif
  Endif
 Endif
 If UPD
  If evalue("dim([F:"+ABFIC+"]UPDUSR)")>0
   NOMUSER = func NOMUSER(evalue("[F:"+ABFIC+"]UPDUSR"))
   If NOMUSER<>""
    VISVAL(VISNBR) -= mess(161,124,1)-NOMUSER-"("+evalue("[F:"+ABFIC+"]UPDUSR")+")"
   Else
    VISVAL(VISNBR) -= mess(161,124,1)-evalue("[F:"+ABFIC+"]UPDUSR")
   Endif
  Endif
 Endif

 If dim([L]CLEVALEUR)>0 & evalue("dim([F:"+ABFIC+"]VLDDAT)")>0 : ## GEODE
  If evalue("[F:"+ABFIC+"]VLDDAT")<>[0/0/0]
   VISNBR += 1
   VISDES(VISNBR) = mess(24,310,1) : # Validé le
   VISVAL(VISNBR) = format$("D:"+GFMDAT,evalue("[F:"+ABFIC+"]VLDDAT"))
   If evalue("dim([F:"+ABFIC+"]VLDTIM)")>0
    TEMPS = evalue("[F:"+ABFIC+"]VLDTIM")
    If TEMPS<>0
     HH = int(TEMPS/3600)
     MM = int(mod(TEMPS,3600)/60)
     SS = mod(TEMPS,60)
     VISVAL(VISNBR) -= num$(HH)+":"+num$(MM)+":"+num$(SS)
    Endif
   Endif
   If evalue("dim([F:"+ABFIC+"]VLDUSR)")>0
    VISVAL(VISNBR) -= mess(161,124,1)-evalue("[F:"+ABFIC+"]VLDUSR") : # par
   Endif
   If evalue("dim([F:"+ABFIC+"]VLDOPE)")>0 & evalue("[F:"+ABFIC+"]VLDOPE")<>""
    VISNBR += 1
    VISDES(VISNBR) = mess(25,310,1) : # Par l'opérateur
    Call LIENS("OPE","OPERATOR",evalue("[F:"+ABFIC+"]VLDOPE"),"","NAM",VISVAL(VISNBR)) From CONTOBJ
   Endif
  Endif
 Endif

Endif

# On rajoute le groupe si c'est possible
If clalev([F:AGD])>0
 If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif
 Call LECTURE("AOB",OBJET,"") From CONTOBJ
 NOMFICHIER = [F:AOB]NOMFIC
 Call LECTURE("ATB",NOMFICHIER,"") From CONTOBJ
 Gosub SET_TYPOBJ From SUBXCB
 Local Char WCODE(250),CHPS(GLONAVA)(1..16)
 Local Char WCLE1(250),WCLE2(250)(0..16)
 Local Integer NBCHP 
 Case OBJET
  When "AOB" : Call LECTURE("AOB",[L]CLE1,"") From CONTOBJ
  When "ATB" : Call LECTURE("ATB",[L]CLE1,"") From CONTOBJ
 Endcase
 If find(OBJET,TYPOBJ(1..NBTYP))>0
  Read [ATI]NUMLIG(2)=NOMFICHIER;1 
  Call SETCLE(NBCHP,CHPS,[F:ATI]DESCRIPT) From LNKSUB
  If NBCHP>1
   Assign "WCLE1" With num$(evalue("[F:"+ABFIC+"]"+CHPS(2)))
   J = 0
   For I=1 To NBCHP
    If I<>2
     Assign "WCLE2("+num$(J)+")" With num$(evalue("[F:"+ABFIC+"]"+CHPS(I)))
     J+=1
    Endif
   Next
  Else
   Assign "WCLE1" With num$(evalue("[F:"+ABFIC+"]"+CHPS(1)))
  Endif
  Call CALCUL_CODE(OBJET,WCLE1,WCLE2,WCODE) From SUBXCB
  Read [AGD]AGD0 = OBJET;WCODE
  If !fstat
   VISNBR += 1
   VISDES(VISNBR) = mess(73,9953,1) : # Groupe 
   VISVAL(VISNBR) = [AGD]GRP-"("+func AFNC.TEXTRA("ATABDIV","LNGDES","98",[F:AGD]GRP)+")"
  Endif
 Endif
 Call EXISTE_ADX("","","MANHLDLIB",OKTRT) From ORDSYS
 If OKTRT
  Gosub HLD_PROP From MANHLDLIB  # order holds
 Endif
Endif

#-----------------------------------------------------------#
# 4) Affichage s'il y a quelque chose
#-----------------------------------------------------------#

If !VISNBR
 Call MESSAGE(mess(1,126,1)) From GESECRAN : # Pas de propriété
 FIN = 1
 Return
Endif

Return

$ERREUR
ER = errn
CHAINE = errmes$(ER)-errm
Resume

$RIEN
Resume

#---------------------------------#
Funprog NOMUSER(USER)
Value Char USER
Local Char NOMUSER(GLONDES)
If clalev([F:AUS2])=0 : Local File AUTILIS [AUS2] : Endif
Read [AUS2]CODUSR = USER
If !fstat
 NOMUSER = [F:AUS2]NOMUSR
Endif
Close Local File
End NOMUSER

#----------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File AOBJPROP  [AOP1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[M]DOSORG+".AOBJPROP"  [AOP1]
 Local File =[M]DOSORG+".ATEXTRA"   [AXX1] 
Endif 
If [M]DOSDES=nomap 
 Local File AOBJPROP  [AOP2] 
 Local File ATEXTRA   [AXX2] 
Else 
 Local File =[M]DOSDES+".AOBJPROP"  [AOP2]
 Local File =[M]DOSDES+".ATEXTRA"   [AXX2] 
Endif 
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AOP1], [AOP2],[AXX1] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AOP2]
 Delete [AOP2] Where OBJ=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AOBJPROP" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AOP2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AOP1]AOP0 Where OBJ=TABLE
  [F:AOP2] = [F:AOP1]
  Call COPTEXTRA("AOBJPROP","INTIT",TABLE,num$([F:AOP2]NUM)) From ATEXTRA
  If dim([F:AOP2]UPDUSR)>0 : [F:AOP2]UPDUSR = GUSER : Endif
  If dim([F:AOP2]UPDDAT)>0 : [F:AOP2]UPDDAT = date$ : Endif
  Write [AOP2]
  If fstat
   GOK=0 : Call FSTA("AOP2") From GLOCK : Break
  Endif
 Next
 If !GOK : Goto AB_TR_COP : Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#----------------------------------------------------------------#
Subprog C_OBJ(VALEUR)
Variable Char    VALEUR()
Call CONTROLE("AOB","",VALEUR,"",mkstat) From CONTOBJ
If [F:AOB]NOMFIC=""
 Call ERREUR(mess(193,133,1)) From GESECRAN : # Objet sans table principale
 mkstat = 1 : End
Endif
Call TEXTE([F:AOB]LIBEL,[M]LIBEL) From OBJDIV
[M]OBJTBL = [F:AOB]NOMFIC
End

Subprog AM_TBL(VALEUR)
Variable Char    VALEUR()
Call LECTURE("AOB",[M]OBJ,"") From CONTOBJ
Call LECTURE("ATB",[F:AOB]NOMFIC,"") From CONTOBJ
Read [ATZ]LIEN(2) = VALEUR;[F:AOB]NOMFIC
If fstat<=2
 If [F:ATZ]EXPLIEN=""
  [M]LNK(nolign-1) = "[F:"+[F:ATB]ABRFIC+"]"+[F:ATZ]CODZONE
 Else
  [M]LNK(nolign-1) = [F:ATZ]EXPLIEN
 Endif
Endif
End

Subprog C_LNK(VALEUR)
Variable Char    VALEUR()
Local Char    CHAINE(80)
Local Integer NB1 , NB2 , I , J
VALEUR = toupper(VALEUR)
Read [ATI]NUMLIG(2) = [M]TBL(nolign-1);1
CHAINE = [F:ATI]DESCRIPT
NB1 = 0
While CHAINE<>""
 NB1 += 1
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If    I & J  : I = min(I,J)
 Elsif J & !I : I = J
 Endif
 If I
  CHAINE = right$(CHAINE,I+1)
 Else
  CHAINE = ""
 Endif
Wend
CHAINE = VALEUR
NB2 = 0
While CHAINE<>""
 NB2 += 1
 I = instr(1,CHAINE,";")
 If I
  CHAINE = right$(CHAINE,I+1)
 Else
  CHAINE = ""
 Endif
Wend
If NB1<>NB2
 GMESSAGE = mess(101,123,1) : # Expression de lien incorrecte
 mkstat = 2 : End
Endif
End


