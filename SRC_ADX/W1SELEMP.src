#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SELEMP 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:21"
A_USER  = "DOC"
A_STAMP = "20181109230621"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
 When "NBEXP"
  If [M]NBEXP=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask SELEMP [SEL]
Gosub HORODAT
Local Inpbox "SELEMP" From GFONCTION At A_STAMP With A_WINDPREV Mask [SEL] As [SIM_]
Grizo [SEL]10
Grizo [SEL]20
Grizo [SEL]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [SEL]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=25 : X2(0)=88 : Y1(0)=5 : Y2(0)=13
X1(1)=25 : X2(1)=88 : Y1(1)=14 : Y2(1)=15
X1(2)=25 : X2(2)=88 : Y1(2)=16 : Y2(2)=23
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1SELEMP
Return

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBLIG From SELEMP
Gosub _AFF
End

$ON_INTIT
Onevent AFTER_AREA Call AP_INTIT(zc) From W1SELEMP
Return

Subprog AP_INTIT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TXTCONT
 Call TXTCONT(VALEUR,[M]INTIT(nolign-1),[M]DES(nolign-1),30,20,"DIC","DES") From OBJDIV
 If mkstat : GERR = 1 : GZONE = "INTIT" : GZNUM = 8 : Endif
Endif
Gosub _AFF
End

$ON_CODTYP
Return

$ON_NOLIB
Return

$ON_OPE
Onevent CONTROL Call C_OPE(zc) From W1SELEMP
Onevent INIT_AREA Call D_OPE(zc) From W1SELEMP
Onevent BEFORE_INPUT Call AS_OPE(zc) From W1SELEMP
Return

Subprog D_OPE(VALEUR)
Variable Integer VALEUR
If varinit([M]OPE,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_OPE(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_OPE(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_OPE(VALEUR) From SELEMP
If mkstat : GERR = 1 : GZONE = "OPE" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_VALEUR
Onevent BEFORE_INPUT Call AS_VALEUR(zc) From W1SELEMP
Onevent CONTROL Call C_VALEUR(zc) From W1SELEMP
Return

Subprog IB_VALEUR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTBOUT
 Call BOUTSEL(VALEUR,[M]TYP,[M]LIB,"") From FMTVAR
Endif
Gosub _AFF
End

Subprog AS_VALEUR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(877,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_VALEUR(VALEUR)
## Action AFMTSAI
Call ASAISIE(VALEUR,[M]TYP) From FMTVAR
If mkstat=2
 [M]VALEUR(INDIC) = VALEUR
 Affzo VALEUR(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_VALEUR(zc) From W1SELEMP
Onkey   2 Titled GBOUTS Call S_VALEUR(zc) From W1SELEMP
Gosub _AFF
End

Subprog C_VALEUR(VALEUR)
Variable Char    VALEUR()
## Action AFMTCONT
Call CONTROLE(VALEUR,[M]TYP,[M]LIB,[M]LNG,[M]VALINT) From FMTVAR
If mkstat : GERR = 1 : GZONE = "VALEUR" : GZNUM = 0 : Endif
If !mkstat
 ## Action ACONTACL
 Call CONTACL([M]VALINT,[M]TYP,"","") From SUBACL
 If mkstat : GERR = 1 : GZONE = "VALEUR" : GZNUM = 0 : Endif
Endif
Gosub _AFF
End

Subprog S_VALEUR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = [M]TYP
 PARMSK(2) = num$([M]LIB)
 PARMSK(3) = num$([M]LNG)
 PARMSK(4) = [M]VALINT
 PARMSK(5) = "[M]SUPP"
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINT = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = [M]TYP
 PARMSK(2) = num$([M]LIB)
 PARMSK(3) = num$([M]LNG)
 PARMSK(4) = [M]VALINT
 PARMSK(5) = "[M]SUPP"
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINT = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_VALEUR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTB1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTB1"
 PARMSK(1) = [M]TYP
 PARMSK(2) = "[M]SUPP"
 PARMSK(3) = num$([M]LIB)
 PARMSK(4) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFMTB1","FMTVAR","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_ETOU
Onevent INIT_AREA Call D_ETOU(zc) From W1SELEMP
Return

Subprog D_ETOU(VALEUR)
Variable Integer VALEUR
If varinit([M]ETOU,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_WOPE
Onevent INIT_AREA Call D_WOPE(zc) From W1SELEMP
Return

Subprog D_WOPE(VALEUR)
Variable Integer VALEUR
If varinit([M]WOPE,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


