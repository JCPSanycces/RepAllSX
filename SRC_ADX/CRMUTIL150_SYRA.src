##########################################################################################################
#     ENSEMBLE de sous-programmes utilitaires créés pour le CRM
##########################################################################################################
##########################################################################################################
# Rend un téléphone formaté selon le pays
##########################################################################################################
Funprog GET_TELFORMATED(STEL, SCRY)
Value Char STEL
Value Char SCRY

Local Char SARENDRE(200)

  # FGR 22/10/2015 : X3SUIVI111911
  Raz SARENDRE
  If STEL <> "" Then
    If SCRY = "" Then
      SARENDRE = STEL
    Else
      Local File TABCOUNTRY [TCY]
      Read [TCY]TCY0=SCRY
      SARENDRE = format$([F:TCY]TELFMT,STEL)
    Endif
  Endif
End SARENDRE

##########################################################################################################
# Rend la société à partir du site
##########################################################################################################
Funprog GET_CPY_FROM_FCY(SFCY)
Value Char SFCY

Local Char SARENDRE(GLONCPY)

  Raz SARENDRE
  If SFCY <> "" Then
    Local File FACILITY [FCY]
    Read [FCY]FCY0=SFCY
    If !fstat Then
      SARENDRE = [F:FCY]LEGCPY
    Endif
  Endif
End SARENDRE

##########################################################################################################
# Vérifie si le couple objet\code est correct
##########################################################################################################
Subprog VERIFOBJCODE(SZOBJET, SZCTRL, SZCODE, SZMESSAGE, IBRETOUR)
Value Char SZOBJET
Value Char SZCTRL
Value Char SZCODE
Variable Char SZMESSAGE
Variable Integer IBRETOUR

  Raz SZMESSAGE
  IBRETOUR = 1
  If SZOBJET = "" or SZCODE = "" Then
    End
  Endif
  Case SZOBJET
    When "SRE"
      #Demande de service
      Local File SERREQUEST [SRE]
      Read [SRE]SRE0=SZCODE
    When "OMM"
      #Publipostage
      Local File MAILING [OMM]
      Read [OMM]OMM0=SZCODE
    When "OMP"
      #Campagne d'appels
      Local File PHONING [OMP]
      Read [OMP]OMP0=SZCODE
    When "OMT"
      #Salons professionnels
      Local File TRADESHOW [OMT]
      Read [OMT]OMT0=SZCODE
    When "OMN"
      #Campagne presse
      Local File MEDIA [OMN]
      Read [OMN]OMN0=SZCODE
    When "CMG"
      #Campagne marketing
      Local File CMARKETING [CMG]
      Read [CMG]CMG0=SZCODE
    When "OPP"
      #Affaire
      Local File OPPOR [OPP]
      Read [OPP]OPP0=SZCODE
  Endcase
  If fstat <> 0 Then
    SZMESSAGE = mess(525,177,1)
    IBRETOUR = 0
  Else
    Case SZOBJET
      When "SRE"
        #Demande de service
        If [F:SRE]SALFCY <> SZCTRL and [F:SRE]SALFCY <> "" Then
          SZMESSAGE = mess(616,177,1)
          IBRETOUR = 0
        Endif
      When "OMM"
        #Publipostage
        If [F:OMM]FCY <> SZCTRL and [F:OMM]FCY <> "" Then
          SZMESSAGE = mess(616,177,1)
          IBRETOUR = 0
        Endif
      When "OMP"
        #Campagne d'appels
        If [F:OMP]FCY <> SZCTRL and [F:OMP]FCY <> "" Then
          SZMESSAGE = mess(616,177,1)
          IBRETOUR = 0
        Endif
      When "OMT"
        #Salons professionnels
        If [F:OMT]FCY <> SZCTRL and [F:OMT]FCY <> "" Then
          SZMESSAGE = mess(616,177,1)
          IBRETOUR = 0
        Endif
      When "OMN"
        #Campagne presse
        If [F:OMN]FCY <> SZCTRL and [F:OMN]FCY <> "" Then
          SZMESSAGE = mess(616,177,1)
          IBRETOUR = 0
        Endif
      When "CMG"
        #Campagne marketing
        If [F:CMG]FCY <> SZCTRL and [F:CMG]FCY <> "" Then
          SZMESSAGE = mess(616,177,1)
          IBRETOUR = 0
        Endif
      When "OPP"
        #Affaire
        If dim(SZCTRL) = 1 Then
          If [F:OPP]SALFCY <> SZCTRL and [F:OPP]SALFCY <> "" and SZCTRL <> "***" Then
            SZMESSAGE = mess(616,177,1)
            IBRETOUR = 0
          Endif
        Else
          # SZCTRL(0) = Site
          # SZCTRL(1) = Tiers
          If [F:OPP]SALFCY <> SZCTRL(0) and [F:OPP]SALFCY <> "" Then
            SZMESSAGE = mess(616,177,1)
            IBRETOUR = 0
            End
          Endif
          If dim(SZCTRL) > 1 Then
            If SZCTRL(1) <> "" and [F:OPP]OPPCMP <> SZCTRL(1) and [F:OPP]OPPCMP <> "" Then
              SZMESSAGE = mess(617,177,1)
              IBRETOUR = 0
              End
            Endif
          Endif
        Endif
    Endcase
  Endif
End

##########################################################################################################
# Rend le code de la campagne marketing associée lorsqu'il est alimenté
##########################################################################################################
Subprog GETCMG_OBJCODE(DOSSIER, SZOBJET, SZCODE, SZCMGNUM, SZMESSAGE, IBRETOUR)
Value Char DOSSIER
Value Char SZOBJET
Value Char SZCODE
Variable Char SZCMGNUM
Variable Char SZMESSAGE
Variable Integer IBRETOUR

  Raz SZMESSAGE
  Raz SZCMGNUM
  IBRETOUR = 1
  If SZOBJET = "" or SZCODE = "" Then
    End
  Endif
  Case SZOBJET
    When "OMM"
      #Publipostage
      If DOSSIER = "" Then
        Local File MAILING [OMM]
      Else
        Local File =DOSSIER+".MAILING" [OMM]
      Endif
      Read [OMM]OMM0=SZCODE
      SZCMGNUM = [F:OMM]CMGNUM
    When "OMP"
      #Campagne d'appels
      If DOSSIER = "" Then
        Local File PHONING [OMP]
      Else
        Local File =DOSSIER+".PHONING" [OMP]
      Endif
      Read [OMP]OMP0=SZCODE
      SZCMGNUM = [F:OMP]CMGNUM
    When "OMT"
      #Salons professionnels
      If DOSSIER = "" Then
        Local File TRADESHOW [OMT]
      Else
        Local File =DOSSIER+".TRADESHOW" [OMT]
      Endif
      Read [OMT]OMT0=SZCODE
      SZCMGNUM = [F:OMT]CMGNUM
    When "OMN"
      #Campagne presse
      If DOSSIER = "" Then
        Local File MEDIA [OMN]
      Else
        Local File =DOSSIER+".MEDIA" [OMN]
      Endif
      Read [OMN]OMN0=SZCODE
      SZCMGNUM = [F:OMN]CMGNUM
    When "CMG"
      #Campagne marketing
      If DOSSIER = "" Then
        Local File CMARKETING [CMG]
      Else
        Local File =DOSSIER+".CMARKETING" [CMG]
      Endif
      Read [CMG]CMG0=SZCODE
      SZCMGNUM = [F:CMG]NUM
  Endcase
  # --------------------------
  If fstat <> 0 Then
    #Numéro de pièce incorrect
    SZMESSAGE = mess(525,177,1)
    IBRETOUR = 0
    Raz SZCMGNUM
  Endif
End

##########################################################################################################
# Gestion des textes clob et du champ synthèse
##########################################################################################################
Subprog GERE_TEXTE_SYNTHESE(OLDTEXTE, NEWTEXTE, SYNTHESE)
Value Clbfile OLDTEXTE
Value Clbfile NEWTEXTE
Variable Char SYNTHESE

  If len(OLDTEXTE) > GLONCLE and len(NEWTEXTE) <= GLONCLE Then
    SYNTHESE = NEWTEXTE
  Elsif len(OLDTEXTE) <= GLONCLE and len(NEWTEXTE) <= GLONCLE Then
    SYNTHESE = NEWTEXTE
  Elsif len(NEWTEXTE) > GLONCLE and SYNTHESE = "" Then
    SYNTHESE = left$(NEWTEXTE,GLONCLE)
  Endif
End

##########################################################################################################
# Rend l'objet paramétré pour le code dans ADI=439
##########################################################################################################
Funprog GET_AOB_FROM_ORI(SCODEADI)
Value Char SCODEADI

Local Char SARENDRE(GLONAOB)

  Raz SARENDRE
  If SCODEADI = "MAN1" Then
    Raz SARENDRE
  Else
    Local File ATABDIV [ADI]
    Read [ADI]CODE=439;SCODEADI
    SARENDRE = [F:ADI]A1
  Endif
End SARENDRE

##########################################################################################################
# Rend l'utilisateur à partir du représentant
##########################################################################################################
Subprog GETUTIFROMREP(SZREP, SZUTI, SMESSAGE, IERROR)
Value Char SZREP
Variable Char SZUTI
Variable Char SMESSAGE
Variable Integer IERROR

  Raz SMESSAGE
  IERROR = [V]CST_ANO
  # ------------------------------------
  Local File SALESREP [REP]
  Read [REP]REP0=SZREP
  If fstat Then
    SMESSAGE = mess(209,177,1)
    IERROR = [V]CST_AYES
    End
  Endif
  SZUTI = [F:REP]AUSNUM
  If SZUTI = "" Then
    SMESSAGE = mess(209,177,1)
    IERROR = [V]CST_AYES
    End
  Endif
End

##########################################################################################################
Funprog GETREPFROMUTI(CTX, SMESSAGE, IERROR)
Value Instance CTX Using C_WMACONTEXT
Variable Char SMESSAGE
Variable Integer IERROR

Local Char SARENDRE(GLONREP)

  Raz SMESSAGE
  IERROR = [V]CST_ANO
  # ------------------------------------
  SARENDRE = fmet CTX.APARAM.AGETUSERVALCHAR("AUSCRMF")
End SARENDRE

##########################################################################################################
# Rend le champ de la clé primaire de l'objet indiqué
##########################################################################################################
Subprog DEFOBJORI(SAOB, SORIAVA)
Value Char SAOB
Variable Char SORIAVA

  #é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~
  # FLORENT ICI : ça ça va surement changer !~
  #é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~é~~
  Raz SORIAVA
  If SAOB <> "" Then
    Gosub SETCLE From ="WO" + SAOB
    SORIAVA = CLEPRIM
  Endif
End

