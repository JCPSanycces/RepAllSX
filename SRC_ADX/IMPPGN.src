#<AdxTL>@(#)9.0.0.0 $Revision$
$ACTION
Case ACTION
 When "EXPORT"   : Gosub EXPORT
 When "IMPORT"   : Gosub IMPORT
Endcase
Return

$EXPORT
If [F:CPG]TYP<>1 : # Export groupes natures uniquement
 OK = 0
Endif
Return

$IMPORT
Case IMPFIC
 When "CPN"
  I = find([F:CPN]CNA,[M]CNA(0..[M]NBRCNA-1))
  If I
   status = 75
   nolign = I
  Endif
Endcase
Return
