#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SORDER
#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AQUERY_TRANS_AFTER"        : Gosub AQUERY_TRANS_AFTER
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------
#######################################################################################
$AQUERY_TRANS_AFTER
  #Local File SORDER [SOH]         # Note FGR : pas la peine, là tout est en ligne
  #Read [SOH]SOH0=this.SOH.SOHNUM  # Note FGR : pas la peine, là tout est en ligne
  this.RREP1 = [F:SOH]REP(0)
  this.RBPCPOSCOD = [F:SOH]BPCPOSCOD
  this.RBPCCRY = [F:SOH]BPCCRY
Return

#######################################################################################
$PROPERTIES
  Case CURPRO
    When Default
  Endcase
Return

#######################################################################################
# A FACTORISER CAR UTILISABLE PAR LES AUTRES OBJETS
# A faire lorsqu'on saura si la solution de la collection C_LINES est conservée pour les commandes
# Pour les autres documents on a pas ce pb
#-------------------------------------------------------------#
# Calcul des montants ligne commande ht et ttc                #
#-------------------------------------------------------------#
$CALC_ORD
Local Decimal WMNTCALC
Local Date    WDATE

Local Char WVAT(GLONVAT)(3)

  WVAT (0) = [F:SOP]VAT(0)
  WVAT (1) = [F:SOP]VAT(1)
  WVAT (2) = [F:SOP]VAT(2)
  WDATE=REP.SOH.ORDDAT
  If REP.APARENT.PRITYP=1
    # Montant net HT commandé de la ligne
    WMNTCALC = [F:SOQ]QTY * [F:SOP]NETPRINOT
    Call ARRDEV (WMNTCALC, REP.APARENT.CUR) From TRTDIV
    WLINNOT = WMNTCALC
    # Montant net TTC commandé de la ligne
    Call CLCTAXEMNTV(WLINNOT,WVAT,REP.APARENT.PRITYP,REP.APARENT.CPY,WDATE,REP.APARENT.VACBPR,[F:SOP]CLCAMT1,[F:SOP]CLCAMT2,
&                   WMNTCALC) From TRTX3                                                                                              : # Bug 71296
    Call ARRDEV (WMNTCALC, REP.APARENT.CUR) From TRTDIV
    WLINATI = WMNTCALC
  Else
    # Montant net TTC commandé de la ligne
    WMNTCALC = [F:SOQ]QTY * [F:SOP]NETPRIATI
    Call ARRDEV (WMNTCALC, REP.APARENT.CUR) From TRTDIV
    WLINATI = WMNTCALC
    # Montant net HT commandé de la ligne
    Call CLCTAXEMNTV(WLINATI,WVAT,REP.APARENT.REP.APARENT.PRITYP,GSOCIETE,WDATE,REP.APARENT.VACBPR,[F:SOP]CLCAMT1(NLIG),[F:SOP]CLCAMT2,
&                   WMNTCALC) From TRTX3                                                                                              : # Bug 71296
     Call ARRDEV (WMNTCALC, REP.APARENT.CUR) From TRTDIV
    WLINNOT = WMNTCALC
  Endif
  # Marge de la ligne
  WMNTCALC = [F:SOQ]QTY * [F:SOP]PFM
  Call ARRDEV (WMNTCALC,  REP.APARENT.CUR) From TRTDIV
  WLINPFM = WMNTCALC
Return

