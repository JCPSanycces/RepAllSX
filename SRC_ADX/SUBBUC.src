$IB_CCE
Gosub SETAXE
If PYRAM=""
 [M]OBJET   = "CCE"
 [M]SUPP    = AXE
 [M]OBJCRIT = "BUDTRK=2"
 GBOUT1 = mess(36,103,1)
Else
 [M]OBJET   = "CRY"
 [M]SUPP    = PYRAM
 [M]OBJCRIT = "LEV="+num$(NIVEAU)+" & BUDTRK=2"
 GBOUT1 = mess(25,103,1)
Endif
If [M:BUC2]NBLIG2>0
 GBOUT2 = mess(4,124,1)
Endif
Return

$SETAXE
Call LECTURE("BUP",[M]BUD(0),"") From CONTOBJ
Local Char    AXE(GLONDIE) , PYRAM(GLONCYM)
Local Integer NIVEAU
AXE    = [F:BUP]DIE(IND)
PYRAM  = [F:BUP]PYMCCE(IND)
NIVEAU = [F:BUP]PYMCCELEV(IND)
Return

Subprog AS_CCE1(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BUP",[M]BUD(0),"") From CONTOBJ
If [F:BUP]DIE(0)="" : mkstat = 1 : End : Endif
If nolign=1 & VALEUR="" : VALEUR = "*" : Endif
End

