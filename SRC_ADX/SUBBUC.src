Subprog C_CCE1(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 0 : Gosub C_CCE
End

Subprog C_CCE2(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 1 : Gosub C_CCE
End

Subprog C_CCE3(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 2 : Gosub C_CCE
End

Subprog C_CCE4(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 3 : Gosub C_CCE
End

Subprog C_CCE5(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 4 : Gosub C_CCE
End

Subprog C_CCE6(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 5 : Gosub C_CCE
End

Subprog C_CCE7(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 6 : Gosub C_CCE
End

Subprog C_CCE8(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 7 : Gosub C_CCE
End

Subprog C_CCE9(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 8 : Gosub C_CCE
End

$C_CCE
Gosub SETAXE
VALEUR = toupper(VALEUR)
If VALEUR=""
 If nolign=1
  GMESSAGE = mess(10,123,1)
  mkstat = 2
 Endif
 Return
Endif
If func JOKER(VALEUR)
 Return
Endif
If left$(VALEUR,2)="V_"
 Call CTRL_VARCOD(VALEUR)
 If mkstat : Return : Endif
 Call CTL_VARIA(VALEUR)
 If mkstat : Return : Endif
 Return
Endif
If PYRAM=""
 Call CONTROLE("CCE","!",VALEUR,AXE,mkstat) From CONTOBJ
 If mkstat : Return : Endif
 If [F:CCE]BUDTRK<>2
  GMESSAGE = mess(5,103,1)
  mkstat = 2 : Return
 Elsif [F:BUP]LEV=1
  Call VERSOC([F:CCE]FCY,[M]CPY(nolign-1),"",VALEUR) From CFYSUB
  If mkstat : Return : Endif
 Elsif [F:BUP]LEV=2
  Call VERIF([F:CCE]FCY,[M]FCY(nolign-1),VALEUR) From CFYSUB
  If mkstat : Return : Endif
 Endif
 If [F:CCE]VLYEND<>[0/0/0] & [F:CCE]VLYEND<[M]STRDAT
&    | [F:CCE]VLYSTR<>[0/0/0] & [F:CCE]VLYSTR>[M]ENDDAT
  GMESSAGE = mess(7,103,1)
  mkstat=2 : Return
 Endif
Else
 Call CONTROLE("CRY","!",VALEUR,PYRAM,mkstat) From CONTOBJ
 If mkstat : Return : Endif
 If VALEUR<>""
  If [F:CRY]BUDTRK<>2
   GMESSAGE = mess(27,103,1)
   mkstat=2 : Return
  Elsif [F:CRY]LEV<>[F:BUP]PYMCCELEV(IND)
   GMESSAGE = mess(32,103,1)
   mkstat=2 : Return
  Endif
 Endif
Endif
Return

################################################################################
## Vérif validité d'une variable
################################################################################
Subprog CTRL_VARCOD(VALEUR)
Variable Char    VALEUR()
Local    Integer I
Local    Char    CHAINE(37) , CAR(1) , VARCOD(20)
CHAINE = "ABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789"
For I=1 To len(VALEUR)
 CAR = mid$(VALEUR,I,1)
 If !instr(1,CHAINE,CAR)
  GMESSAGE = mess(82,108,1)-":"-CAR
  mkstat = 2 : Break
 Endif
Next
If mkstat : End : Endif
If left$(VALEUR,2)<>"V_"
 VARCOD = VALEUR
Else
 VARCOD = right$(VALEUR,3)
Endif
If len(VARCOD)>8
 GMESSAGE = mess(115,105,1)
 mkstat   = 2 : End
Elsif len(VARCOD)<1 or left$(VARCOD,1)="_"
 GMESSAGE = mess(99,108,1)
 mkstat   = 2 : End
Else
 VALEUR = "V_"+VARCOD
Endif
End

Subprog CTL_VARIA(VALEUR)
Value Char VALEUR
Local Integer OK
If !find(VALEUR,[M:BUC2]VARCOD(0..[M:BUC2]NBLIG2-1))
 If [M:BUC2]NBLIG2>=dim([M:BUC2]VARCOD)
  GMESSAGE = mess(134,111,1)-VALEUR
  mkstat=2 : End
 Else
  GMESSAGE = mess(134,111,1)-":"-VALEUR
  GMESSAGE -= "\"-mess(142,111,1)
  OK = 2 : Call OUINON(GMESSAGE,OK) From GESECRAN
  Raz GMESSAGE
  If OK=2
   [M:BUC2]VARCOD([M:BUC2]NBLIG2) = VALEUR
   [M:BUC2]NBLIG2 += 1
   Affzo [M:BUC2]
  Else
   mkstat = 2
  Endif
 Endif
Endif
End

################################################################################
## Etiquettes Ecran BUC2 et BUC3
################################################################################

Subprog C_VARCOD(VALEUR)
Variable Char    VALEUR()
Call CTRL_VARCOD(VALEUR)
If mkstat : End : Endif
Call UNICITE(VALEUR,[M]VARCOD(0..[M]NBLIG2-1)) From OBJDIV
End

Subprog IB_VARVAL
Local Integer I
Local Char    INTIT(250)
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8, GBOUT9, GBOUT10
Call LECTURE("BUP",[M:BUC1]BUD(0),"") From CONTOBJ
Call LECTEXTRA(GBOUT1,"GCOA","COLHEA",[BUP]COA,"") From ATEXTRA
For I=0 To dim([BUP]DIE)-1
 If [BUP]DIE(I)<>""
  Call LECTEXTRA(INTIT,"GDIE","COLHEA",[BUP]DIE(I),"") From ATEXTRA
  Case I
   When 0 : If find([M:BUC2]VARCOD(nolign-1),[M:BUC1]CCE1(0..[M:BUC1]NBLIG-1)) : Assign "GBOUT"+num$(I+2) With INTIT : Endif
   When 1 : If find([M:BUC2]VARCOD(nolign-1),[M:BUC1]CCE2(0..[M:BUC1]NBLIG-1)) : Assign "GBOUT"+num$(I+2) With INTIT : Endif
   When 2 : If find([M:BUC2]VARCOD(nolign-1),[M:BUC1]CCE3(0..[M:BUC1]NBLIG-1)) : Assign "GBOUT"+num$(I+2) With INTIT : Endif
   When 3 : If find([M:BUC2]VARCOD(nolign-1),[M:BUC1]CCE4(0..[M:BUC1]NBLIG-1)) : Assign "GBOUT"+num$(I+2) With INTIT : Endif
   When 4 : If find([M:BUC2]VARCOD(nolign-1),[M:BUC1]CCE5(0..[M:BUC1]NBLIG-1)) : Assign "GBOUT"+num$(I+2) With INTIT : Endif
   When 5 : If find([M:BUC2]VARCOD(nolign-1),[M:BUC1]CCE6(0..[M:BUC1]NBLIG-1)) : Assign "GBOUT"+num$(I+2) With INTIT : Endif
   When 6 : If find([M:BUC2]VARCOD(nolign-1),[M:BUC1]CCE7(0..[M:BUC1]NBLIG-1)) : Assign "GBOUT"+num$(I+2) With INTIT : Endif
   When 7 : If find([M:BUC2]VARCOD(nolign-1),[M:BUC1]CCE8(0..[M:BUC1]NBLIG-1)) : Assign "GBOUT"+num$(I+2) With INTIT : Endif
   When 8 : If find([M:BUC2]VARCOD(nolign-1),[M:BUC1]CCE9(0..[M:BUC1]NBLIG-1)) : Assign "GBOUT"+num$(I+2) With INTIT : Endif
  Endcase
 Else
  Break
 Endif
Next
End

Subprog AM_VARVAL(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End

Subprog C_NBLIG2
Local Integer K
Local Char    SUITE(37)
If status=65 | status=68 | status=83
 SUITE    = "ABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789"
 If status=65 : nolign1 = nolign : Endif
 For K=nolign To nolign1
  I = instr(1,[M:BUC0]CLCFOR,[M:BUC2]VARCOD(K-1))
  If I & ( !instr(1,SUITE,mid$([M:BUC0]CLCFOR,I+len([M:BUC2]VARCOD(K-1)),1))
&      | len([M:BUC0]CLCFOR)=I+len([M:BUC2]VARCOD(K-1))-1 )
   GMESSAGE = [M:BUC2]VARCOD(K-1)-mess(84,108,1)
   mkstat   = 2
   Break
  Endif
  If find([M:BUC2]VARCOD(K-1),[M:BUC1]ACC(0..[M:BUC1]NBLIG-1))
&  | find([M:BUC2]VARCOD(K-1),[M:BUC1]CCE1(0..[M:BUC1]NBLIG-1))
&  | find([M:BUC2]VARCOD(K-1),[M:BUC1]CCE2(0..[M:BUC1]NBLIG-1))
&  | find([M:BUC2]VARCOD(K-1),[M:BUC1]CCE3(0..[M:BUC1]NBLIG-1))
&  | find([M:BUC2]VARCOD(K-1),[M:BUC1]CCE4(0..[M:BUC1]NBLIG-1))
&  | find([M:BUC2]VARCOD(K-1),[M:BUC1]CCE5(0..[M:BUC1]NBLIG-1))
&  | find([M:BUC2]VARCOD(K-1),[M:BUC1]CCE6(0..[M:BUC1]NBLIG-1))
&  | find([M:BUC2]VARCOD(K-1),[M:BUC1]CCE7(0..[M:BUC1]NBLIG-1))
&  | find([M:BUC2]VARCOD(K-1),[M:BUC1]CCE8(0..[M:BUC1]NBLIG-1))
&  | find([M:BUC2]VARCOD(K-1),[M:BUC1]CCE9(0..[M:BUC1]NBLIG-1))
&  | find([M:BUC2]VARCOD(K-1),[M:BUC1]VER(0..[M:BUC1]NBLIG-1))
   GMESSAGE = [M:BUC2]VARCOD(K-1)-mess(68,108,1)
   mkstat   = 2
   Break
  Endif
 Next K
 If mkstat=2 : End : Endif
Endif
End

Subprog AS_DEL(VALEUR)
Variable Integer VALEUR
If [M]OD=2
 VALEUR = 1 : mkstat = 2
Endif
End

##########################################################################
## Retourne s'il y a un joker dans la chaine
##########################################################################
Funprog JOKER(CHAINE)
Value Char CHAINE
If instr(1,CHAINE,"*") | instr(1,CHAINE,"?") | instr(1,CHAINE,"#") | instr(1,CHAINE,"!")
 End 1
Else
 End 0
Endif
End

