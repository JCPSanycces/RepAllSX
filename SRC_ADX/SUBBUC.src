#<AdxTL>@(#)8.0.0.0 $Revision$
GFONCTION="GESBUC"
Raz GPILOBJ
Call OBJET("BUC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "LIENS0"      : Gosub LIENS0
 When "LIENS2"      : Gosub LIENS2
 When "INICRE"      : Gosub INICRE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "VERF_LISTE"  : Gosub VERF_LISTE
 When "CHANGE"      : Gosub CHANGE
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
Endcase
Return

########################################
## Style pour la première ligne
########################################
$STYLE
Local Char STYLE(GLONASY)
STYLE = "ALERTE"
Return
########################################

$OUVRE
If clalev([F:BLA])=0  : Local File BALANA     [BLA]  : Endif
If clalev([F:BUD])=0  : Local File BUD        [BUD]  : Endif
If clalev([F:BUD2])=0 : Local File BUD        [BUD2] : Endif
If clalev([F:BVC])=0  : Local File BUDVARCAL  [BVC]  : Endif
If clalev([F:BUP])=0  : Local File BUDPAR     [BUP]  : Endif
If clalev([F:BUP2])=0 : Local File BUDPAR     [BUP2] : Endif
If clalev([F:CCE])=0  : Local File CACCE      [CCE]  : Endif
If clalev([F:DTP])=0  : Local File CADISTMP   [DTP]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:ATZ])=0  : Local File ATABZON    [ATZ]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:CRY])=0  : Local File GCCEGRUPYM [CRY]  : Endif
If clalev([F:GRY])=0  : Local File GACCGRUPYM [GRY]  : Endif
If clalev([F:BUV])=0  : Local File BUDVER     [BUV]  : Endif
MAXLIG=20
Local Integer MONOCPY
Gosub STYLE
Return

$SETBOUT
# Pour éviter de faire Exec avant d'avoir enregistré ses modifs,
# et donc d'exécuter avec les mauvais critères, on vire Exec si on est en modif
If !CLECUR or REP="M" or !VERROU
  Call VIREBOUT(CHAINE,"1") From GOBJET : # Bouton Exec
Endif
# suppression des boutons : annulation, modif, enregistrer, supprimer, dupliquer
If MONOCPY : Call VIREBOUT(CHAINE,"AMESD") From GOBJET : Endif
Return

$INICRE
If dim([F:BUC]DES)>0
 [F:BUC]DES = [M:BUC0]DESTRA
Endif
[F:BUC] = [M:BUC0]
[F:BUC] = [M:BUC1]
[F:BUC]LIN = nolign
For I=0 To dim([F:BUC]CCE)-1
 [F:BUC]CCE(I) = evalue("[M:BUC1]CCE"+num$(I+1)+"(nolign-1)")
Next I
Return

$INIMOD
If dim([F:BUC]DES)>0
 [F:BUC]DES = [M:BUC0]DESTRA
Endif
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Delete [BVC] Where BUDFOR=[M:BUC0]BUDFOR
If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$BUDVARCAL"-[M:BUC0]BUDFOR : Return
Endif
For nolign=1 To [M:BUC2]NBLIG2
 [F:BVC] = [M:BUC2]
 [F:BVC]BUDFOR = [M:BUC0]BUDFOR
 Write [BVC]
 If fstat
  GOK=0 : Call FSTA("BVC") From GLOCK : Break
 Endif
Next
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$LIENS0
nolign = 0
For [F:BVC]BVC0 Where [F:BVC]BUDFOR=[F:BUC]BUDFOR
 nolign += 1
 [M:BUC2] = [F:BVC]
Next
[M:BUC2]NBLIG2 = nolign
nolign = 0 : # sinon dans LIENS on démarre avec un nolign faux
Chgstl [M]NBLIG(0) With STYLE
Return

$LIENS
[M:BUC0] = [F:BUC]
Call LECTURE("BUP",[F:BUC]BUD,"") From CONTOBJ
If nolign=1 : # Budget à calculer
 Gosub LIBCPT
Endif
For I=1 To dim([F:BUP]DIE)
 Assign "[M:BUC1]CCE"+num$(I)+"(nolign-1)" With [F:BUC]CCE(I-1)
Next
If [F:BUP]LEV=1
 [M:BUC1]SIT(nolign-1) = [F:BUC]CPY
Else
 [M:BUC1]SIT(nolign-1) = [F:BUC]FCY
Endif
Call LECTEXTRA([M:BUC0]DESTRA,"BUDFORCAL","DESTRA",[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
Call LECTEXTRA([M:BUC0]SHOTRA,"BUDFORCAL","SHOTRA",[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
Return

$LIBCPT
Call LECTEXTRA([M:BUC1]LIBCPT, "GCOA","COLHEA",[BUP]COA,"") From ATEXTRA
Call LECTEXTRA([M:BUC1]LIBSEC1,"GDIE","COLHEA",[BUP]DIE(0),"") From ATEXTRA
Call LECTEXTRA([M:BUC1]LIBSEC2,"GDIE","COLHEA",[BUP]DIE(1),"") From ATEXTRA
Call LECTEXTRA([M:BUC1]LIBSEC3,"GDIE","COLHEA",[BUP]DIE(2),"") From ATEXTRA
Call LECTEXTRA([M:BUC1]LIBSEC4,"GDIE","COLHEA",[BUP]DIE(3),"") From ATEXTRA
Call LECTEXTRA([M:BUC1]LIBSEC5,"GDIE","COLHEA",[BUP]DIE(4),"") From ATEXTRA
Call LECTEXTRA([M:BUC1]LIBSEC6,"GDIE","COLHEA",[BUP]DIE(5),"") From ATEXTRA
Call LECTEXTRA([M:BUC1]LIBSEC7,"GDIE","COLHEA",[BUP]DIE(6),"") From ATEXTRA
Call LECTEXTRA([M:BUC1]LIBSEC8,"GDIE","COLHEA",[BUP]DIE(7),"") From ATEXTRA
Call LECTEXTRA([M:BUC1]LIBSEC9,"GDIE","COLHEA",[BUP]DIE(8),"") From ATEXTRA
Return

$SETFMT
If [F:BUP]DIE(0)=""
 Chgfmt [M:BUC1]CCE1 With "-K:15X"
Else
 Chgfmt [M:BUC1]CCE1 With "K:15X"
Endif
If [F:BUP]DIE(1)=""
 Chgfmt [M:BUC1]CCE2 With "-K:15X"
Else
 Chgfmt [M:BUC1]CCE2 With "K:15X"
Endif
If [F:BUP]DIE(2)=""
 Chgfmt [M:BUC1]CCE3 With "-K:15X"
Else
 Chgfmt [M:BUC1]CCE3 With "K:15X"
Endif
If [F:BUP]DIE(3)=""
 Chgfmt [M:BUC1]CCE4 With "-K:15X"
Else
 Chgfmt [M:BUC1]CCE4 With "K:15X"
Endif
If [F:BUP]DIE(4)=""
 Chgfmt [M:BUC1]CCE5 With "-K:15X"
Else
 Chgfmt [M:BUC1]CCE5 With "K:15X"
Endif
If [F:BUP]DIE(5)=""
 Chgfmt [M:BUC1]CCE6 With "-K:15X"
Else
 Chgfmt [M:BUC1]CCE6 With "K:15X"
Endif
If [F:BUP]DIE(6)=""
 Chgfmt [M:BUC1]CCE7 With "-K:15X"
Else
 Chgfmt [M:BUC1]CCE7 With "K:15X"
Endif
If [F:BUP]DIE(7)=""
 Chgfmt [M:BUC1]CCE8 With "-K:15X"
Else
 Chgfmt [M:BUC1]CCE8 With "K:15X"
Endif
If [F:BUP]DIE(8)=""
 Chgfmt [M:BUC1]CCE9 With "-K:15X"
Else
 Chgfmt [M:BUC1]CCE9 With "K:15X"
Endif
Return

$LIENS2
Call LECTURE("BUP",[M:BUC1]BUD(0),"") From CONTOBJ
Gosub SETFMT
Return

$CHANGE
For [BVC] Where BUDFOR=OCODE
 [F:BVC]BUDFOR = NCODE
 Rewrite [BVC]
 If fstat
  GOK = 0 : Call FSTA("BVC") From GLOCK : Break
 Endif
Next
Return

$AP_CHANGE
Call CHGTEXTRA("BUDFORCAL","DESTRA",[M:BUC0]BUDFOR,num$(0),NCODE,num$(0)) From ATEXTRA
Call CHGTEXTRA("BUDFORCAL","SHOTRA",[M:BUC0]BUDFOR,num$(0),NCODE,num$(0)) From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("BUDFORCAL","DESTRA",[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
Call SUPTEXTRA("BUDFORCAL","SHOTRA",[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
Delete [BVC] Where BUDFOR=CODE
If fstat=1
 GOK = -1 : Call RSTA("BUDVARCAL",CODE) From GLOCK
Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("BUDFORCAL","DESTRA",CLECUR1,num$(0),"BUDFORCAL","DESTRA",[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
 Call DUPTEXTRA("BUDFORCAL","SHOTRA",CLECUR1,num$(0),"BUDFORCAL","SHOTRA",[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
Endif
Call MAJTEXTRA([M:BUC0]DESTRA,"BUDFORCAL","DESTRA",[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
Call MAJTEXTRA([M:BUC0]SHOTRA,"BUDFORCAL","SHOTRA",[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
Return

#################################
$SEL_TABLE
Case GACTION
 When "SELBUD2"
  Local Char VAXE(GLONCCE)
  If [M:BUC1]NBLIG>0
   Call LEC_BUP([M:BUC1]BUD(0)) From CPTLEC
   Call ADDCRIT(CRITOBJ,ICRITOBJ,"COA","COA='"+[F:BUP]COA+"'","&") From GOBJSUB
   Call ADDCRIT(CRITOBJ,ICRITOBJ,"PYMACC","PYMACC='"+[F:BUP]PYMACC+"'","&") From GOBJSUB
   For I=0 To dim([F:BUP]DIE)-1
    VAXE = [F:BUP]DIE(I)
    If VAXE<>""
     Call ADDCRIT(CRITOBJ,ICRITOBJ,"DIE","find('"+VAXE+"',[F:BUP]DIE(0..9))<>0","&") From GOBJSUB
    Endif
   Next I
  Endif
  OBJET = "BUP"
Endcase
Return

#################################
$SEL_LISTE
Case GACTION
 When "SELVARBUD" : Gosub SEL_VAR
Endcase
Return

$SEL_VAR
Local Char SAV_VALEUR(250)
SAV_VALEUR = VALEUR
TIT = mess(12,123,1)-mess(8,108,1)
NBTEX = 0
For I=0 To [M:BUC2]NBLIG2-1
 NBTEX += 1
 TEX(NBTEX)   = [M:BUC2]VARCOD(I)
 TEXTE(NBTEX) = [M:BUC2]VARCOD(I)-":"-[M:BUC2]DES(I)
Next I
Return

#################################
$VERF_LISTE
# Ajout de la variable en fin de zone
If zoncou="CLCFOR"
 VALEUR = SAV_VALEUR + VALEUR
Endif
Return

################################################################################
## Etiquettes Ecran BUC0
################################################################################

Subprog C_CLCFOR(VALEUR)
Variable Char    VALEUR()
Local Integer E
Local  Integer I
Local  Char    CAR(1)
Local  Char    VZONE(250) , ZONE(250)

VALEUR = toupper(VALEUR)
If VALEUR="" : End : Endif
E = parse(VALEUR)
If E
 GMESSAGE = mess(37,124,1)+"\"+errmes$(E)
 mkstat = 2 : End
Endif

# Contrôle de l'existence des codes variables
ZONE = VALEUR
I = instr(1,ZONE,"V_")
While I & len(ZONE)>I
 ZONE = right$(ZONE,I)
 I = 3
 While len(ZONE)>=I
  CAR = mid$(ZONE,I,1)
  If (CAR>="0" & CAR<="9") | (CAR>="A" & CAR<="Z") | CAR="_"
   I += 1
  Else
   Break
  Endif
 Wend
 VZONE = left$(ZONE,I-1)
 Call CTRL_VARCOD(VZONE)
 If mkstat : Break : Endif
 Call CTL_VARIA(VZONE)
 If mkstat : Break : Endif
 I = instr(I,ZONE,"V_")
Wend
End

Subprog AM_FLGDSP(VALEUR)
Variable Integer VALEUR
If VALEUR=1 & [M]NBLIG>1
 Call VERIF_DAT
 If mkstat : End : Endif
Endif
End

################################################################################
## Etiquettes Ecran BUC1
################################################################################
Subprog C_NBLIG
Local Integer I, J, K, N, OK
Local Char    SUITE(10) , OLDFOR(10) , NEWFOR(10)
If (status=65 | status=83 | status=68)
 If nolign=1
  GMESSAGE = mess(81,108,1)
  mkstat = 2 : End
 Endif
 SUITE = "0123456789"
 If status=65 : nolign1 = nolign : Endif
 ## Contrôle que la/les ligne(s) supprimée(s) ne font pas partie de la formule
 ## nolign  = No première ligne supprimée / nolign1 = No dernière ligne supprimée
 For K=nolign To nolign1
  OLDFOR = [M:BUC1]FORNAM(K-1)
  I = instr(1,[M:BUC0]CLCFOR,OLDFOR)
  If I & ( !instr(1,SUITE,mid$([M:BUC0]CLCFOR,I+len(OLDFOR),1)) | len([M:BUC0]CLCFOR)=I+len(OLDFOR)-1)
   Call AVERTIR(OLDFOR-mess(80,108,1),OK) From GESECRAN
   If OK=1 : mkstat = 2 : Break : Endif
  Endif
 Next
 If mkstat : End : Endif
 J = nolign             : # J = No première ligne renumérotée
 N = 1+(nolign1-nolign) : # N = Nb de lignes supprimées
 For K=J To [M]NBLIG-N
  NEWFOR = "F"+num$(K-1)
  OLDFOR = "F"+num$(K-1+N)
  I = 0
  Repeat
   I = instr(I+1,[M:BUC0]CLCFOR,OLDFOR)
   If I & (!instr(1,SUITE,mid$([M:BUC0]CLCFOR,I+len(OLDFOR),1)) | len([M:BUC0]CLCFOR)=I+len(OLDFOR)-1)
    [M:BUC0]CLCFOR = left$([M:BUC0]CLCFOR,I-1)+NEWFOR+right$([M:BUC0]CLCFOR,I+len(OLDFOR))
    [M:BUC1]FORNAM(K-1) = NEWFOR
   Endif
  Until I=0
 Next
 Affzo [BUC0]CLCFOR
Endif
End

Subprog AS_NBLIG
If (status=65 | status=83 | status=68)
 Affzo FORNAM
Endif
End

Subprog APRES_NBLIG
If nolign=1
 Gosub STYLE
 Chgstl [M]NBLIG(0) With STYLE
Endif
End

Subprog AV_FORNAM(VALEUR)
Variable Char    VALEUR()
If nolign=1
 VALEUR = mess(64,108,1)
Else
 VALEUR = "F"+num$(nolign-1) : # F1, F2, F3
Endif
End

Subprog AS_FORNAM(VALEUR)
Variable Char    VALEUR()
mkstat = 2
End

Subprog AS_TYP(VALEUR)
Variable Integer VALEUR
If nolign=1
 VALEUR = 1 : mkstat = 2 : End
Endif
End

Subprog AS_BUD(VALEUR)
Variable Char    VALEUR()
If nolign>1 & VALEUR=""
 VALEUR = [M]BUD(nolign-2)
Endif
End

Subprog C_BUD(VALEUR)
Variable Char    VALEUR()
Local    Integer I , J , K , OKBUD
Call LECTURE("BUP",VALEUR,"") From CONTOBJ
Call CONTEXE([F:BUP]ACS)From CPTSUB
If mkstat : End : Endif
If nolign=1
 Gosub SETFMT
 Affzo NBLIG
 Gosub LIBCPT
 If !GIMPORT
  Titcol [M]NBLIG [M]LIBCPT  For ACC
  Titcol [M]NBLIG [M]LIBSEC1 For CCE1
  Titcol [M]NBLIG [M]LIBSEC2 For CCE2
  Titcol [M]NBLIG [M]LIBSEC3 For CCE3
  Titcol [M]NBLIG [M]LIBSEC4 For CCE4
  Titcol [M]NBLIG [M]LIBSEC5 For CCE5
  Titcol [M]NBLIG [M]LIBSEC6 For CCE6
  Titcol [M]NBLIG [M]LIBSEC7 For CCE7
  Titcol [M]NBLIG [M]LIBSEC8 For CCE8
  Titcol [M]NBLIG [M]LIBSEC9 For CCE9
 Endif
Endif
# - On contrôle que les axes/pyramides des codes budget servant de base de calcul
#   est le même que celui du budget à calculer
Read [BUP2]BUP0 = [M]BUD(0)
OKBUD  = 1
If nolign>1
 Gosub VERF_BUD
Else
 For J=1 To [M]NBLIG-1
  Read [BUP]BUP0 = [M]BUD(J)
  Gosub VERF_BUD
  If !OKBUD : Break : Endif
 Next J
Endif
If !OKBUD
 GMESSAGE = mess(37,108,1)-"("+GMESSAGE+")"
 mkstat = 2 : End
Endif
End

$VERF_BUD
OKBUD *= ([F:BUP2]COA=[F:BUP]COA & [F:BUP2]PYMACC=[F:BUP]PYMACC & [F:BUP2]PYMACCLEV=[F:BUP]PYMACCLEV)
If !OKBUD : GMESSAGE = [F:BUP2]COA  : Return : Endif
For I=0 To dim([F:BUP2]DIE)-1
 If [F:BUP2]DIE(I)<>""
  K = find([F:BUP2]DIE(I),[F:BUP]DIE)
  If K
   OKBUD *= ([F:BUP2]PYMCCE(I)=[F:BUP]PYMCCE(K-1) & [F:BUP2]PYMCCELEV(I)=[F:BUP]PYMCCELEV(K-1))
  Else
   OKBUD = 0
  Endif
 Endif
 If !OKBUD
  GMESSAGE = [F:BUP2]DIE(I) : Break
 Endif
Next I
Return

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
Call LECTURE("BUP",[M]BUD(nolign-1),"") From CONTOBJ
If [F:BUP]LEV=2 : mkstat = 2 : End : Endif
If nolign>1 & VALEUR=""
 VALEUR = [M]CPY(nolign-2)
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BUP",[M]BUD(nolign-1),"") From CONTOBJ
If VALEUR="" & [F:BUP]LEV=1
 GMESSAGE = mess(10,123,1)
 mkstat = 2 : End
Endif
If [F:BUP]LEV=1 : # Société
 # Contrôle que tous les sites d'une société sont accessibles
 Call CONTALLFCY(VALEUR) From CPTSUB
 If mkstat : End : Endif
 [M]SIT(nolign-1) = VALEUR
Endif
Gosub NBREF
If NB<1
 GMESSAGE = mess(97,108,1)
 mkstat   = 2 : End
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
Call LECTURE("BUP",[M]BUD(nolign-1),"") From CONTOBJ
If [F:BUP]LEV=1 : mkstat = 1 : End : Endif
If nolign>1 & VALEUR=""
 VALEUR = [M]FCY(nolign-2)
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BUP",[M]BUD(nolign-1),"") From CONTOBJ
If [F:BUP]LEV=2 : # Site
 # Contrôle que le site est autorisé pour la fonction courante
 Call CONTFCY([M:BUC1]FCY(nolign-1)) From CPTSUB
 If mkstat : End : Endif
 [M]SIT(nolign-1) = VALEUR
Endif
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
Gosub NBREF
If NB<1
 GMESSAGE = mess(97,108,1)
 mkstat   = 2 : End
Endif
[M]CPY(nolign-1) = [F:FCY]LEGCPY
Affzo [M]CPY(nolign-1)
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Call LECTURE("CPY",[M]CPY(nolign-1),"") From CONTOBJ
Gosub NBREF
If NB=1
 VALEUR = TYPREF : mkstat = 2 : End
Endif
End

$NBREF
Local Integer I, NB, TYPREF
Local Char TCODLED(GLONLED)(1..len(mess(0,2644,1))), CODLED(GLONLED), DEVLED(GLONCUR)

Call LECTURE("BUP",[M]BUD(0),"") From CONTOBJ
Read [GCM]GCM0 = [F:CPY]ACM

# on doit initialiser avec la valeur du type de référentiel analytique principal
Call SETREF([F:CPY]CPY,NB,TCODLED) From CPTDIV
# vérifier que le référentiel analytique principal est flaggé budget
Read [LED]LED0=TCODLED(1)
If [F:LED]BUD=2
 ## Recherche du code référentiel et devise référentiel associé au type de référentiel
 ## et à la société passés en paramètres
 Call LECLED([F:CPY]CPY,2,CODLED,DEVLED) From CPTDIV
 [M]LEDTYP(nolign-1)=[F:GCM]ANALEDTYP
 TYPREF = [F:GCM]ANALEDTYP
Endif

NB = 0
For I=1 To len(mess(0,2644,1))
 GMENLOC(I) = 1
 If [F:GCM]LED(I-1)<>"" & [F:GCM]CFMAUT(I-1)<>2 : # le référentiel ne doit pas être automatique
  Read [LED]LED0 = [F:GCM]LED(I-1)
  OK  = 1
  OK *= ([F:LED]BUD=2)
  OK *= ([F:LED]COA=[F:BUP]COA)
  OK *= (find([F:BUP]DIE(0),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(0)="")
  OK *= (find([F:BUP]DIE(1),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(1)="")
  OK *= (find([F:BUP]DIE(2),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(2)="")
  OK *= (find([F:BUP]DIE(3),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(3)="")
  OK *= (find([F:BUP]DIE(4),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(4)="")
  OK *= (find([F:BUP]DIE(5),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(5)="")
  OK *= (find([F:BUP]DIE(6),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(6)="")
  OK *= (find([F:BUP]DIE(7),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(7)="")
  OK *= (find([F:BUP]DIE(8),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(8)="")
  If OK
   NB    += 1
   TYPREF = I
   GMENLOC(I) = 0
  Endif
 Endif
Next I
Return

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Call LECTURE("BUP",[M]BUD(0),"") From CONTOBJ
Call LECTURE("CPY",[M]CPY(nolign-1),"") From CONTOBJ
Read [GCM]GCM0 = [F:CPY]ACM
If [F:GCM]LED(VALEUR-1)=""
 GMESSAGE = mess(105,104,1)-[M]CPY(nolign-1)
 mkstat = 2 : End
Else
 Read [LED]LED0 = [F:GCM]LED(VALEUR-1)
 If [F:GCM]CFMAUT(VALEUR-1)=2 or [F:LED]BUD<>2
  GMESSAGE = mess(201,111,1)
  mkstat = 2 : End
 Else
  If  ([F:LED]COA<>[F:BUP]COA)
&   | ([F:BUP]DIE(0)<>"" & !find([F:BUP]DIE(0),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(1)<>"" & !find([F:BUP]DIE(1),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(2)<>"" & !find([F:BUP]DIE(2),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(3)<>"" & !find([F:BUP]DIE(3),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(4)<>"" & !find([F:BUP]DIE(4),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(5)<>"" & !find([F:BUP]DIE(5),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(6)<>"" & !find([F:BUP]DIE(6),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(7)<>"" & !find([F:BUP]DIE(7),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(8)<>"" & !find([F:BUP]DIE(8),[F:LED]DIE(0..[F:LED]DIENBR-1)))
   GMESSAGE = mess(37,108,1)
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog AS_VER(VALEUR)
Variable Char    VALEUR()
If [M]TYP(nolign-1)<>1
 mkstat = 1 : End
Endif
End

Subprog C_VER(VALEUR)
Variable Char VALEUR()
Local Integer OK

If left$(VALEUR,2)="V_"
 Call CTRL_VARCOD(VALEUR)
 If mkstat : End : Endif
 Call CTL_VARIA(VALEUR)
 If mkstat : End : Endif
Else
 VALEUR = left$(VALEUR,type([F:BUD]VER)-10)
 Call CONTVER(VALEUR, [M:BUC1]BUD(nolign-1)) From SUBBUV
 If nolign=1
  If mkstat=2
   # Pour la ligne 1 si version non existante, on la crée sur demande
   OK = 2 : Call OUINON(mess(225,111,1)-":"-VALEUR-"\"-mess(142,111,1),OK) From GESECRAN
   If OK=2
    # création de la nouvelle version de budget
    Raz mkstat
    [F:BUV]BUD = [M:BUC1]BUD(nolign-1)
    [F:BUV]VER = VALEUR
    [F:BUV]STA = 1
    [F:BUV]DEF = 1
    [F:BUV]CTL = 1
    Write [F:BUV]
   Endif
  Else
   If [F:BUV]STA=2
    mkstat = 2
    GMESSAGE = mess(58,109,1)
   Endif
  Endif
 Endif
Endif
End

Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR
If nolign>1
 VALEUR = [M]STRDAT(nolign-2)
Else
 VALEUR = gdat$(1,1,year(datesyst))
Endif
End

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Local Decimal EXO
Local Date    DAT
Call GETEXE([M]CPY(nolign-1),[M]LEDTYP(nolign-1),VALEUR,EXO) From CPTSUB
If !EXO
 GMESSAGE = mess(52,116,1)
 mkstat = 2 : End
Endif
[M]FIYSTR(nolign-1) = EXO
DAT = VALEUR
For [PER]PER0 Where CPY=[M]CPY(nolign-1) & LEDTYP=[M]LEDTYP(nolign-1) & FIYNUM=EXO
 If DAT>=[F:PER]PERSTR
  VALEUR = [F:PER]PERSTR
  [M]PERDEB(nolign-1) = [F:PER]PERNUM
 Endif
Next
End

Subprog D_ENDDAT(VALEUR)
Variable Date    VALEUR
If nolign>1
 VALEUR = [M]ENDDAT(nolign-2)
Else
 VALEUR = gdat$(31,12,year([M]STRDAT(nolign-1)))
Endif
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Decimal EXO
Local Date DAT
Call GETEXE([M]CPY(nolign-1),[M]LEDTYP(nolign-1),VALEUR,EXO) From CPTSUB
If !EXO
 GMESSAGE = mess(52,116,1)
 mkstat = 2 : End
Endif
[M]FIYEND(nolign-1) = EXO
DAT = VALEUR
For [PER]PER0 Where CPY=[M]CPY(nolign-1) & LEDTYP=[M]LEDTYP(nolign-1) & FIYNUM=EXO
 If DAT>=[F:PER]PERSTR
  VALEUR = [F:PER]PEREND
  [M]PERFIN(nolign-1) = [F:PER]PERNUM
 Endif
Next
################################################################################
# "En montants par périodes", on contrôle que les budgets servant de base
# au calcul, ont le même nombre de périodes que le budget à calculer.
################################################################################
If [M]FLGDSP=1
 If nolign>1
  If ([M]PERFIN(nolign-1)-[M]PERDEB(nolign-1))<>([M]PERFIN(0)-[M]PERDEB(0))
   GMESSAGE = mess(75,108,1)
   mkstat = 2 : End
  Endif
  If ([M]FIYEND(nolign-1)-[M]FIYSTR(nolign-1))<>([M]FIYEND(0)-[M]FIYSTR(0))
   GMESSAGE = mess(76,108,1)
   mkstat = 2 : End
  Endif
 Else
  Call VERIF_DAT
  If mkstat : End : Endif
 Endif
Endif
End

Subprog VERIF_DAT
Local Integer I
For I=1 To [M]NBLIG-1
 If ([M]PERFIN(I)-[M]PERDEB(I))<>([M]PERFIN(0)-[M]PERDEB(0))
  GMESSAGE = mess(75,108,1)
  mkstat = 2 : Break
 Endif
 If ([M]FIYEND(I)-[M]FIYSTR(I))<>([M]FIYEND(0)-[M]FIYSTR(0))
  GMESSAGE = mess(76,108,1)
  mkstat = 2 : Break
 Endif
Next I
End

Subprog AS_ACC(VALEUR)
Variable Char VALEUR()
If nolign=1 & VALEUR="" : VALEUR = "*" : Endif
End

Subprog IB_ACC
Call LECTURE("BUP",[M]BUD(0),"") From CONTOBJ
If [F:BUP]PYMACC=""
 [M]OBJET   = "GAC"
 [M]SUPP    = [F:BUP]COA
 [M]OBJCRIT = "BUDTRK=2"
 GBOUT1 = mess(35,103,1)
Else
 [M]OBJET   = "GRY"
 [M]SUPP    = [F:BUP]PYMACC
 [M]OBJCRIT = "LEV="+num$([F:BUP]PYMACCLEV)+" & BUDTRK=2"
 GBOUT1 = mess(24,103,1)
Endif
If [M:BUC2]NBLIG2>0
 GBOUT2 = mess(4,124,1)
Endif
End

Subprog C_ACC(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
If VALEUR=""
 If nolign=1
  GMESSAGE = mess(10,123,1)
  mkstat = 2
 Endif
 End
Endif
If func JOKER(VALEUR)
 End
Endif
If left$(VALEUR,2)="V_"
 Call CTRL_VARCOD(VALEUR)
 If mkstat : End : Endif
 Call CTL_VARIA(VALEUR)
 If mkstat : End : Endif
 End
Endif
Call LECTURE("BUP",[M]BUD(0),"") From CONTOBJ
If [F:BUP]PYMACC=""
 Call CONTROLE("GAC","",VALEUR,[F:BUP]COA,mkstat) From CONTOBJ
 If mkstat : End : Endif
 Call LECTURE("GAC",VALEUR,[F:BUP]COA) From CONTOBJ
 If [F:GAC]BUDTRK<>2
  GMESSAGE = mess(4,103,1)
  mkstat=2 : End
 Endif
 If [F:BUP]LEV=1
  Call VERSOC([F:GAC]FCY,[M]CPY(nolign-1),"",VALEUR) From CFYSUB
  If mkstat : End : Endif
 Elsif [F:BUP]LEV=2
  Call VERIF([F:GAC]FCY,[M]FCY(nolign-1),VALEUR) From CFYSUB
  If mkstat : End : Endif
 Endif
 If [GAC]VLYEND<>[0/0/0] & [GAC]VLYEND<[M]STRDAT(nolign-1)
& | [GAC]VLYSTR<>[0/0/0] & [GAC]VLYSTR>[M]ENDDAT(nolign-1)
  # Nature inactive (Il faut au moins qu'un jour d'activité de la nature
  # se chevauche sur l'exercice pour que la nature soit active)
  GMESSAGE = mess(6,103,1)
  mkstat=2 : End
 Endif
Else
 Call CONTROLE("GRY","",VALEUR,[F:BUP]PYMACC,mkstat) From CONTOBJ
 If mkstat : End : Endif
 If [F:GRY]BUDTRK<>2
  GMESSAGE = mess(26,103,1)
  mkstat=2 : End
 Elsif [F:GRY]LEV<>[F:BUP]PYMACCLEV
  GMESSAGE = mess(31,103,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog IB_CCE1
Local Integer IND
IND = 0 : Gosub IB_CCE
End

Subprog IB_CCE2
Local Integer IND
IND = 1 : Gosub IB_CCE
End

Subprog IB_CCE3
Local Integer IND
IND = 2 : Gosub IB_CCE
End

Subprog IB_CCE4
