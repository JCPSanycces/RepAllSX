#<AdxTL>@(#)4.0.0.0 $Revision$
Call GSTD("","") From GSTD
End

$OUVRE
If FICH<>"AESPION"
 If DOSSIER=nomap
  Local File AESPION   [AES]
 Else
  Local File =DOSSIER+".AESPION"   [AES]
 Endif
Endif

If DOSSIER=nomap
 Local File ATABLE   [ATB]
 Local File ATABZON  [ATZ]
 Local File ATABIND  [ATI]
 Local File ATYPE    [ATY]
 Local File APLSTD   [STD]
 Local File =FICH    [FFB_]
 Local File =FICH    [FFA_]
Else
 Local File =DOSSIER+".ATABLE"   [ATB]
 Local File =DOSSIER+".ATABZON"  [ATZ]
 Local File =DOSSIER+".ATABIND"  [ATI]
 Local File =DOSSIER+".ATYPE"    [ATY]
 Local File =DOSSIER+".APLSTD"   [STD]
 Local File =DOSSIER+"."+FICH    [FFB_]
 Local File =DOSSIER+"."+FICH    [FFA_]
Endif

If DOSSIER=nomap
 Local File ABLBSYS [ASB]
Else
 Local File =func DOSCONT.DOSX3(DOSSIER)+".ABLBSYS" [ASB]
Endif

For I=1 To dim(FMZONE1,1)
 For J=0 To dim(FMZONE1,2)-1
  FMZONE1(I,J) = "-K:X"
  FMZONE2(I,J) = "-K:X"
  FMZONE3(I,J) = "-K:X"
  FMW1   (I,J) = "-K:X"
  FMW2   (I,J) = "-K:X"
  FMW3   (I,J) = "-K:X"
  FMINT1 (I,J) = "-K:X"
  FMINT2 (I,J) = "-K:X"
  FMINT3 (I,J) = "-K:X"
 Next J
Next I
For I=0 To dim(FMCLE)-1
 FMCLE(I) = "-K:X"
 FMINT(I) = "-K:X"
Next I
Raz INTCLE, INTIT1, INTIT2, INTIT3, NZ1, NZ2, NZ3, NOLIB1, NOLIB2, NOLIB3
Raz INTCLB, INTPHO, INTBUR, TYPBLB

Read [ATB]CODFIC = FICH
ABREV = [F:ATB]ABRFIC

Read [ATI]NUMLIG(2) = FICH;1
[G:FFA_]currind = 1
CURIND = 1
NRMASK = 1
MAXMASK = 10
LNGZON = GLONAVA+5
LNGSAI = 15

Local Mask STD1 [STD]

CHAINE = [F:ATI]DESCRIPT
NCLE = 0
While CHAINE<>""
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J     : I = min(I,J)
 Elsif J & !I : I = J
 Endif
 If I
  CLE    = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE    = CHAINE
  CHAINE = ""
 Endif
 Read [ATZ]CODZONE = FICH;CLE
 If fstat
  GERR = 1 : GMESSAGE = "\"+CLE-mess(157,115,1) : # Composante de clé inexistante
  Break
 Endif
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 If fstat
  Read [ATY]CODTYP = "A"
 Endif
 Gosub FORMAT
 TBCLE(NCLE)  = CLE
 If FICH="ADOVAL" & CLE="CMP" & right$(FORMAT,len(FORMAT))="c"
  #102728 K:5c -> K:5d
  FMCLE(NCLE)  = left$(FORMAT,len(FORMAT)-1)+"d"
 Else
  FMCLE(NCLE)  = FORMAT
 Endif
 FMINT(NCLE)  = "KP:"+num$(LNGZON)+"X"
 INTCLE(NCLE) = [F:ATZ]CODZONE
 TYPCL(NCLE)  = [F:ATY]TYPTYP
 NCLE += 1
Wend
If GERR : Return : Endif

If [F:ATI]HOMONYM=2
 CURLEN = NCLE
Else
 CURLEN = 0
Endif

I = 0 : Z = 1
For [ATZ]CODZONE Where CODFIC=FICH
 If !find([F:ATZ]CODZONE,TBCLE(0..NCLE-1))
  NBDIM = evalue("dim([F:FFA_]"+[F:ATZ]CODZONE+")")
  If NBDIM>0
   Read [ATY]CODTYP = [F:ATZ]CODTYP
   If fstat
    Read [ATY]CODTYP = "A"
   Endif
   If [F:ATY]TYPTYP=9 : # Blob
    INTPHO = [F:ATZ]CODZONE
    INTBUR = [F:ATZ]CODZONE
   Elsif [F:ATY]TYPTYP=10 : # Clob
    INTCLB = [F:ATZ]CODZONE
   Elsif find([F:ATY]CODTYP,"AXX","AX1","AX2","AX3")=0 : # Textes traduisibles
    Gosub FORMAT
    For J=1 To NBDIM
     If NBDIM>1
      INTIT = [F:ATZ]CODZONE+"("+num$(J-1)+")"
     Else
      INTIT = [F:ATZ]CODZONE
     Endif
     Case Z
      When 1
       If I>=dim([M:STD]ZONE1)
        Z=2 : I=0
       Endif
      When 2
       If I>=dim([M:STD]ZONE2)
        Z=3 : I=0
       Endif
      When 3
       If I>=dim([M:STD]ZONE3)
        Z=1 : I=0 : NRMASK += 1
       Endif
     Endcase
     If NRMASK>MAXMASK : NRMASK=MAXMASK : Break 2 : Endif
     If [F:ATY]CODTYP="AT"
      TYPBLB = [F:ATZ]CODZONE
      ZONBLB = num$(NRMASK)
      Case Z
       When 1 : ZONBLB += ","+num$(NZ1(NRMASK)+1)
       When 2 : ZONBLB += ","+num$(NZ2(NRMASK)+1)
       When 3 : ZONBLB += ","+num$(NZ3(NRMASK)+1)
      Endcase
      ZONBLB += ","+num$(Z)
     Endif
     Case Z
      When 1
       FMZONE1(NRMASK,I) = FORMAT
       INTIT1 (NRMASK,I) = INTIT
       TYPZ1  (NRMASK,I) = [F:ATY]TYPTYP
       CYP1   (NRMASK,I) = [F:ATY]CODTYP
       FMINT1 (NRMASK,I) = "KP:"+num$(LNGZON)+"X"
       If [F:ATZ]NOLIB<>0
        FMW1(NRMASK,I)   = "KP:"+num$(LNGSAI)+"X"
        NOLIB1(NRMASK,I) = [F:ATZ]NOLIB
       Elsif [F:ATY]NOLIB<>0
        FMW1(NRMASK,I)   = "KP:"+num$(LNGSAI)+"X"
        NOLIB1(NRMASK,I) = [F:ATY]NOLIB
       Endif
       NZ1(NRMASK) += 1
      When 2
       FMZONE2(NRMASK,I) = FORMAT
       INTIT2 (NRMASK,I) = INTIT
       TYPZ2  (NRMASK,I) = [F:ATY]TYPTYP
       CYP2   (NRMASK,I) = [F:ATY]CODTYP
       FMINT2 (NRMASK,I) = "KP:"+num$(LNGZON)+"X"
       If [F:ATZ]NOLIB<>0
        FMW2(NRMASK,I)   = "KP:"+num$(LNGSAI)+"X"
        NOLIB2(NRMASK,I) = [F:ATZ]NOLIB
       Elsif [F:ATY]NOLIB<>0
        FMW2(NRMASK,I)   = "KP:"+num$(LNGSAI)+"X"
        NOLIB2(NRMASK,I) = [F:ATY]NOLIB
       Endif
       NZ2(NRMASK) += 1
      When 3
       FMZONE3(NRMASK,I) = FORMAT
       INTIT3 (NRMASK,I) = INTIT
       TYPZ3  (NRMASK,I) = [F:ATY]TYPTYP
       CYP3   (NRMASK,I) = [F:ATY]CODTYP
       FMINT3 (NRMASK,I) = "KP:"+num$(LNGZON)+"X"
       If [F:ATZ]NOLIB<>0
        FMW3(NRMASK,I)   = "KP:"+num$(LNGSAI)+"X"
        NOLIB3(NRMASK,I) = [F:ATZ]NOLIB
       Elsif [F:ATY]NOLIB<>0
        FMW3(NRMASK,I)   = "KP:"+num$(LNGSAI)+"X"
        NOLIB3(NRMASK,I) = [F:ATY]NOLIB
       Endif
       NZ3(NRMASK) += 1
     Endcase
     I += 1
    Next J
   Endif
  Endif
 Endif
Next ATZ

Close Local Mask

Case NRMASK
 When 0
  GERR = 1 : GMESSAGE = mess(1,105,1) : # Ecran inexistant
 When Default
  Local Mask STD0  [STD0], CRITSEL [CRIT]
&          , STD1  [M1]  , STD2  [M2]  , STD3  [M3]  , STD4  [M4]
&          , STD5  [M5]  , STD6  [M6]  , STD7  [M7]  , STD8  [M8]
&          , STD9  [M9]  , STD10 [M10] , STD11 [M11] , STD12 [M12]
&          , STD13 [M13]
  Gosub SETFMT
Endcase

Call SETCLE(DOSSIER,FICH,TBCLE,NCLE,CLEPRIM,CLESEC)

If INTCLB<>"" or INTPHO<>"" or INTBUR<>""
 PRGMNT = "WWW"+num$(adxuid(1))
 Call GENTRT(PRGMNT,FICH,INTCLB,INTPHO,INTBUR,TYPBLB,ZONBLB)
Endif

Return

#---------------------------#
$FERME
If FICH<>"AESPION"
 Close Local File [AES]
Endif
Close Local File [ATB], [ATZ], [ATI], [ATY], [STD], [FFB_], [FFA_]
Close Local File [ASB]

If PRGMNT<>""
 Call EXISTE_ADX("","",PRGMNT,STAT) From ORDSYS
 If STAT>0
  Call EFFACE_ADX("","",PRGMNT,STAT) From ORDSYS
 Endif
 Call EFFACE(filpath("TRT",PRGMNT,"src"),STAT) From ORDSYS
Endif
Return

#---------------------------#
$DEBUT
For I=0 To dim([M:STD0]INTCLE)-1
 [M:STD0]FMINT(I)  = FMINT(I)
 [M:STD0]INTCLE(I) = INTCLE(I)
 [M:STD0]FMCLE(I)  = FMCLE(I)
Next I
Affzo [STD0]INTCLE1, INTCLE2, INTCLE3, INTCLE4
Affzo [STD0]CLE1, CLE2, CLE3, CLE4
For I=NCLE+1 To dim([M:STD0]INTCLE)
 Case I
  When 1  : Grizo [STD0]CLE1(0), INTCLE1(0)
  When 2  : Grizo [STD0]CLE1(1), INTCLE1(1)
  When 3  : Grizo [STD0]CLE1(2), INTCLE1(2)
  When 4  : Grizo [STD0]CLE1(3), INTCLE1(3)
  When 5  : Grizo [STD0]CLE2(0), INTCLE2(0)
  When 6  : Grizo [STD0]CLE2(1), INTCLE2(1)
  When 7  : Grizo [STD0]CLE2(2), INTCLE2(2)
  When 8  : Grizo [STD0]CLE2(3), INTCLE2(3)
  When 9  : Grizo [STD0]CLE3(0), INTCLE3(0)
  When 10 : Grizo [STD0]CLE3(1), INTCLE3(1)
  When 11 : Grizo [STD0]CLE3(2), INTCLE3(2)
  When 12 : Grizo [STD0]CLE3(3), INTCLE3(3)
  When 13 : Grizo [STD0]CLE4(0), INTCLE4(0)
  When 14 : Grizo [STD0]CLE4(1), INTCLE4(1)
  When 15 : Grizo [STD0]CLE4(2), INTCLE4(2)
  When 16 : Grizo [STD0]CLE4(3), INTCLE4(3)
 Endcase
Next I

For MA=1 To NRMASK
 For I=0 To dim([M:M1]FMZONE1)-1
  Assign "[M:M"+num$(MA)+"]FMZONE1("+num$(I)+")" With FMZONE1(MA,I)
  Assign "[M:M"+num$(MA)+"]FMZONE2("+num$(I)+")" With FMZONE2(MA,I)
  Assign "[M:M"+num$(MA)+"]FMZONE3("+num$(I)+")" With FMZONE3(MA,I)
  Assign "[M:M"+num$(MA)+"]FMINT1("+num$(I)+")"  With FMINT1(MA,I)
  Assign "[M:M"+num$(MA)+"]FMINT2("+num$(I)+")"  With FMINT2(MA,I)
  Assign "[M:M"+num$(MA)+"]FMINT3("+num$(I)+")"  With FMINT3(MA,I)
  Assign "[M:M"+num$(MA)+"]INTIT1("+num$(I)+")"  With INTIT1(MA,I)
  Assign "[M:M"+num$(MA)+"]INTIT2("+num$(I)+")"  With INTIT2(MA,I)
  Assign "[M:M"+num$(MA)+"]INTIT3("+num$(I)+")"  With INTIT3(MA,I)
  If INTIT1(MA,I)=""
   Case MA
    When 1  : Grizo [M1]INTIT1(I) , ZONE1(I)
    When 2  : Grizo [M2]INTIT1(I) , ZONE1(I)
    When 3  : Grizo [M3]INTIT1(I) , ZONE1(I)
    When 4  : Grizo [M4]INTIT1(I) , ZONE1(I)
    When 5  : Grizo [M5]INTIT1(I) , ZONE1(I)
    When 6  : Grizo [M6]INTIT1(I) , ZONE1(I)
    When 7  : Grizo [M7]INTIT1(I) , ZONE1(I)
    When 8  : Grizo [M8]INTIT1(I) , ZONE1(I)
    When 9  : Grizo [M9]INTIT1(I) , ZONE1(I)
    When 10 : Grizo [M10]INTIT1(I), ZONE1(I)
   Endcase
  Endif
  If INTIT2(MA,I)=""
   Case MA
    When 1  : Grizo [M1]INTIT2(I) , ZONE2(I)
    When 2  : Grizo [M2]INTIT2(I) , ZONE2(I)
    When 3  : Grizo [M3]INTIT2(I) , ZONE2(I)
    When 4  : Grizo [M4]INTIT2(I) , ZONE2(I)
    When 5  : Grizo [M5]INTIT2(I) , ZONE2(I)
    When 6  : Grizo [M6]INTIT2(I) , ZONE2(I)
    When 7  : Grizo [M7]INTIT2(I) , ZONE2(I)
    When 8  : Grizo [M8]INTIT2(I) , ZONE2(I)
    When 9  : Grizo [M9]INTIT2(I) , ZONE2(I)
    When 10 : Grizo [M10]INTIT2(I), ZONE2(I)
   Endcase
  Endif
  If INTIT3(MA,I)=""
   Case MA
    When 1  : Grizo [M1]INTIT3(I) , ZONE3(I)
    When 2  : Grizo [M2]INTIT3(I) , ZONE3(I)
    When 3  : Grizo [M3]INTIT3(I) , ZONE3(I)
    When 4  : Grizo [M4]INTIT3(I) , ZONE3(I)
    When 5  : Grizo [M5]INTIT3(I) , ZONE3(I)
    When 6  : Grizo [M6]INTIT3(I) , ZONE3(I)
    When 7  : Grizo [M7]INTIT3(I) , ZONE3(I)
    When 8  : Grizo [M8]INTIT3(I) , ZONE3(I)
    When 9  : Grizo [M9]INTIT3(I) , ZONE3(I)
    When 10 : Grizo [M10]INTIT3(I), ZONE3(I)
   Endcase
  Endif
 Next I
 Case MA
  When 1  : Affzo [M1]INTIT1 , INTIT2, INTIT3, ZONE1, ZONE2, ZONE3
  When 2  : Affzo [M2]INTIT1 , INTIT2, INTIT3, ZONE1, ZONE2, ZONE3
  When 3  : Affzo [M3]INTIT1 , INTIT2, INTIT3, ZONE1, ZONE2, ZONE3
  When 4  : Affzo [M4]INTIT1 , INTIT2, INTIT3, ZONE1, ZONE2, ZONE3
  When 5  : Affzo [M5]INTIT1 , INTIT2, INTIT3, ZONE1, ZONE2, ZONE3
  When 6  : Affzo [M6]INTIT1 , INTIT2, INTIT3, ZONE1, ZONE2, ZONE3
  When 7  : Affzo [M7]INTIT1 , INTIT2, INTIT3, ZONE1, ZONE2, ZONE3
  When 8  : Affzo [M8]INTIT1 , INTIT2, INTIT3, ZONE1, ZONE2, ZONE3
  When 9  : Affzo [M9]INTIT1 , INTIT2, INTIT3, ZONE1, ZONE2, ZONE3
  When 10 : Affzo [M10]INTIT1, INTIT2, INTIT3, ZONE1, ZONE2, ZONE3
 Endcase
Next MA

[M11]INTCLB = INTCLB : If INTCLB="" : Grizo [M11]INTCLB , ZONCLB : Endif
[M12]INTPHO = INTPHO : If INTPHO="" : Grizo [M12]INTPHO , ZONPHO : Endif
[M13]INTBUR = INTBUR : If INTBUR="" : Grizo [M13]INTBUR , ZONBUR : Endif
Affzo [M11]INTCLB , ZONCLB
Affzo [M12]INTPHO , ZONPHO
Affzo [M13]INTBUR , ZONBUR

For I = (NRMASK+1) To MAXMASK
 For CPT = 0 To dim([M1]INTIT1)-1
  Case I
    When 1  : Grizo [M1]INTIT1(CPT) , ZONE1(CPT)
            : Grizo [M1]INTIT2(CPT) , ZONE2(CPT)
            : Grizo [M1]INTIT3(CPT) , ZONE3(CPT)
    When 2  : Grizo [M2]INTIT1(CPT) , ZONE1(CPT)
            : Grizo [M2]INTIT2(CPT) , ZONE2(CPT)
            : Grizo [M2]INTIT3(CPT) , ZONE3(CPT)
    When 3  : Grizo [M3]INTIT1(CPT) , ZONE1(CPT)
            : Grizo [M3]INTIT2(CPT) , ZONE2(CPT)
            : Grizo [M3]INTIT3(CPT) , ZONE3(CPT)
    When 4  : Grizo [M4]INTIT1(CPT) , ZONE1(CPT)
            : Grizo [M4]INTIT2(CPT) , ZONE2(CPT)
            : Grizo [M4]INTIT3(CPT) , ZONE3(CPT)
    When 5  : Grizo [M5]INTIT1(CPT) , ZONE1(CPT)
            : Grizo [M5]INTIT2(CPT) , ZONE2(CPT)
            : Grizo [M5]INTIT3(CPT) , ZONE3(CPT)
    When 6  : Grizo [M6]INTIT1(CPT) , ZONE1(CPT)
            : Grizo [M6]INTIT2(CPT) , ZONE2(CPT)
            : Grizo [M6]INTIT3(CPT) , ZONE3(CPT)
    When 7  : Grizo [M7]INTIT1(CPT) , ZONE1(CPT)
            : Grizo [M7]INTIT2(CPT) , ZONE2(CPT)
            : Grizo [M7]INTIT3(CPT) , ZONE3(CPT)
    When 8  : Grizo [M8]INTIT1(CPT) , ZONE1(CPT)
            : Grizo [M8]INTIT2(CPT) , ZONE2(CPT)
            : Grizo [M8]INTIT3(CPT) , ZONE3(CPT)
    When 9  : Grizo [M9]INTIT1(CPT) , ZONE1(CPT)
            : Grizo [M9]INTIT2(CPT) , ZONE2(CPT)
            : Grizo [M9]INTIT3(CPT) , ZONE3(CPT)
    When 10 : Grizo [M10]INTIT1(CPT), ZONE1(CPT)
            : Grizo [M10]INTIT2(CPT), ZONE2(CPT)
            : Grizo [M10]INTIT3(CPT), ZONE3(CPT)
   Endcase
 Next CPT
Next I
Return

#---------------------------#
$SETFMT
For MA=0 To MAXMASK
 Case MA
  When 0  : Raz [M:STD0]
  When 1  : Raz [M:M1]
  When 2  : Raz [M:M2]
  When 3  : Raz [M:M3]
  When 4  : Raz [M:M4]
  When 5  : Raz [M:M5]
  When 6  : Raz [M:M6]
  When 7  : Raz [M:M7]
  When 8  : Raz [M:M8]
  When 9  : Raz [M:M9]
  When 10 : Raz [M:M10]
 Endcase
Next MA
Raz [M:M11]
Raz [M:M12]
Raz [M:M13]
For I=0 To dim([M:STD0]INTCLE)-1
 [M:STD0]FMINT(I) = "KP:"+num$(LNGZON)+"X"
 [M:STD0]FMCLE(I) = "K:"+num$(LNGSAI)+"X"
Next I
For MA=1 To MAXMASK
 For I=0 To dim([M:M1]FMZONE1)-1
  Assign "[M:M"+num$(MA)+"]FMZONE1("+num$(I)+")" With "K:"+num$(LNGSAI)+"X"
  Assign "[M:M"+num$(MA)+"]FMZONE2("+num$(I)+")" With "K:"+num$(LNGSAI)+"X"
  Assign "[M:M"+num$(MA)+"]FMZONE3("+num$(I)+")" With "K:"+num$(LNGSAI)+"X"
  Assign "[M:M"+num$(MA)+"]FMINT1("+num$(I)+")"  With "KP:"+num$(LNGZON)+"X"
  Assign "[M:M"+num$(MA)+"]FMINT2("+num$(I)+")"  With "KP:"+num$(LNGZON)+"X"
  Assign "[M:M"+num$(MA)+"]FMINT3("+num$(I)+")"  With "KP:"+num$(LNGZON)+"X"
 Next I
Next MA
Return

#---------------------------#
$FORMAT
LGMAX = 15
If [F:ATZ]NOLIB<>0 or [F:ATY]NOLIB<>0
 FORMAT = "N+:5#"
Elsif [F:ATY]TYPTYP=9
 FORMAT = "KP:10X"
Elsif [F:ATY]TYPTYP=11 : # uuid
 FORMAT = "KP:36X"
Elsif [F:ATY]TYPTYP=12 : # datetime
 FORMAT = "K:20X"
Else
 Local Decimal LONG
 If [F:ATY]LNGTYP<>0
  LONG = [F:ATY]LNGTYP
 Else
  LONG = [F:ATZ]LONG
 Endif
 Call FORMA(LGMAX,[F:ATY]TYPTYP,LONG,0,[F:ATZ]OPTION+[F:ATY]OPTION,[F:ATY]FORTYP,[L]TYPFMT,OPTFMT,CHFMT,NUMFMT) From SUBFMT
 If TYPFMT="D" or TYPFMT='="D'
  If !instr(1,OPTFMT,"z") : OPTFMT += "z" : Endif
  If !instr(1,OPTFMT,"Z") : OPTFMT += "Z" : Endif
  CHFMT = GFMDAT4
 Elsif TYPFMT="N" & left$([F:ATY]FORTYP,1)="="
  If right$(CHFMT,len(CHFMT))="#" : CHFMT = left$(CHFMT,len(CHFMT)-1) : Endif
  CHFMT = "15F"
 Endif
 K = instr(1,CHFMT,"F")
 If K & instr(1,CHFMT,".")
  CHFMT = left$(CHFMT,K-1)+"#"+right$(CHFMT,K+1)
 Endif
 FORMAT = TYPFMT+OPTFMT+":"+CHFMT
 If left$(FORMAT,1)="="
  Onerrgo RIEN
  FORMAT = evalue(right$(FORMAT,2))
  Onerrgo
 Endif
Endif
Return

$RIEN
Resume

#-----------------------------------------------------------#
Subprog SETCLE(DOSSIER,TABLE,TBCLE,NCLE,CLE1,CLE2)
#-----------------------------------------------------------#

Value    Char    DOSSIER(), TABLE(), TBCLE()()
Value    Integer NCLE
Variable Char    CLE1(), CLE2()()
Local    Char    PROGOBJ(GLONADC) , MAC(GDIMFIC) , DOS(GDIMFIC)
Local    Integer OKTRT
Raz CLE1, CLE2
If NCLE=1
 CLE1 = TBCLE(0)
Else
 If DOSSIER=nomap
  Local File AOBJET [AOB]
 Else
  Local File =DOSSIER+".AOBJET" [AOB]
 Endif
 Filter [AOB] Where NOMFIC=TABLE & TYPGES<>3
 Read [AOB] First
 If fstat
  Filter [AOB] Where NOMFIC=TABLE & TYPGES=3
  Read [AOB] First
 Endif
 Filter [AOB]
 If fstat>2
  PROGOBJ = ""
 Else
  PROGOBJ = "WO"+[F:AOB]ABREV
  Call MACHINE(DOSSIER,MAC,DOS) From ORDSYS
  Call EXISTE_ADX(MAC,DOS,PROGOBJ,OKTRT) From ORDSYS
  If !OKTRT
   PROGOBJ = "GES"+[F:AOB]ABREV
   If filinfo(filpath("TRT",PROGOBJ,"adx",DOSSIER),0)<=0
    PROGOBJ = ""
   Endif
  Endif
  If PROGOBJ<>""
   If DOSSIER=nomap
    Gosub SETCLE From =PROGOBJ
   Else
    Gosub SETCLE From =DOSSIER+"."+PROGOBJ
   Endif
   CLE1 = CLEPRIM
   For I=0 To dim(CLESEC)-1
    CLE2(I) = CLESEC(I)
   Next I
  Endif
 Endif
 If PROGOBJ=""
  CLE1 = TBCLE(0)
  For I=0 To NCLE-2
   CLE2(I) = TBCLE(I+1)
  Next I
 Endif
Endif
End

#------------------------------------------------------------------------------------#
Subprog GENTRT(PRGMNT,TABLE,INTCLB,INTPHO,INTBUR,TYPBLB,ZONBLB)
Value    Char PRGMNT , TABLE , INTCLB , INTPHO , INTBUR , TYPBLB , ZONBLB
Local Integer STAT , I , K , COO(1..3)
Local Char    TETADO(80) , FICTRT(GDIMFIC) , CHAINE(250)
TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
FICTRT = filpath("TRT",PRGMNT,"src")
Openo FICTRT,0 Using [WMNT]
Iomode adxifs "" Using [WMNT]
Iomode adxirs chr$(10) Using [WMNT]
Iomode adxium GUTF8 Using [WMNT]
Wrseq TETADO;" ";mess(181,123,1)-TABLE Using [WMNT] : # Maintenance de table
Wrseq "$CHARGE" Using [WMNT]
If INTCLB<>""
 Wrseq "[M:M11]ZONCLB = [F:FFA_]"+INTCLB Using [WMNT]
Else
 Wrseq "Effzo [M:M11]ZONCLB" Using [WMNT]
Endif
If INTPHO<>"" or INTBUR<>""
 If TYPBLB<>""
  Wrseq "If [F:FFA_]"+TYPBLB+"=3" Using [WMNT]
  Wrseq " [M:M12]ZONPHO = [F:FFA_]"+INTPHO Using [WMNT]
  Wrseq " Effzo [M:M13]ZONBUR" Using [WMNT]
  Wrseq "Elsif find([F:FFA_]"+TYPBLB+",4,5,6,7)" Using [WMNT]
  Wrseq " [M:M13]ZONBUR = [F:FFA_]"+INTBUR Using [WMNT]
  Wrseq " Effzo [M:M12]ZONPHO" Using [WMNT]
  Wrseq "Else" Using [WMNT]
  Wrseq " Effzo [M:M12]ZONPHO" Using [WMNT]
  Wrseq " Effzo [M:M13]ZONBUR" Using [WMNT]
  Wrseq "Endif" Using [WMNT]
 Else
  Wrseq "Effzo [M:M12]ZONPHO" Using [WMNT]
  Wrseq "Effzo [M:M13]ZONBUR" Using [WMNT]
 Endif
Endif
Wrseq "Return" Using [WMNT]
Wrseq "" Using [WMNT]
Wrseq "$DECHARGE" Using [WMNT]
If INTCLB<>""
 Wrseq "[F:FFA_]"+INTCLB+" = [M:M11]ZONCLB" Using [WMNT]
Endif
If TYPBLB<>"" and (INTPHO<>"" or INTBUR<>"")
 Wrseq "If [F:FFA_]"+TYPBLB+"=3" Using [WMNT]
 Wrseq " [F:FFA_]"+INTPHO+" = [M:M12]ZONPHO" Using [WMNT]
 Wrseq "Elsif find([F:FFA_]"+TYPBLB+",4,5,6,7)" Using [WMNT]
 Wrseq " [F:FFA_]"+INTBUR+" = [M:M13]ZONBUR" Using [WMNT]
 Wrseq "Endif" Using [WMNT]
Endif
Wrseq "Return" Using [WMNT]
Wrseq Using [WMNT]
Wrseq "$BUREAU" Using [WMNT]
If INTBUR<>"" & TYPBLB<>""
 Wrseq 'Local Integer TYPBLB' Using [WMNT]
 CHAINE = ZONBLB
 I = 0
 While CHAINE<>""
  I += 1
  K = instr(1,CHAINE,",")
  If K
   COO(I) = val(left$(CHAINE,K-1))
   CHAINE = right$(CHAINE,K+1)
  Else
   COO(I) = val(CHAINE)
   CHAINE = ""
  Endif
 Wend
 Wrseq 'Onerrgo RIEN' Using [WMNT]
 Wrseq 'TYPBLB = val(num$('+"[M:M"+num$(COO(1))+"]ZONE"+num$(COO(3))+"("+num$(COO(2)-1)+")"+'))' Using [WMNT]
 Wrseq 'Case TYPBLB' Using [WMNT]
 Wrseq ' When 6       : Read [ASB]ASB0="MIS";"EXCEL"' Using [WMNT]
 Wrseq ' When 7       : Read [ASB]ASB0="MIS";"POWERPOINT"' Using [WMNT]
 Wrseq ' When default : Read [ASB]ASB0="MIS";"WORD"' Using [WMNT]
 Wrseq 'Endcase' Using [WMNT]
 Wrseq 'If !fstat : [M:M13]ZONBUR = [F:ASB]BLOB : Affzo [M:M13]ZONBUR : Endif' Using [WMNT]
 Wrseq 'Onerrgo' Using [WMNT]
Endif
Wrseq 'Return' Using [WMNT]
Wrseq Using [WMNT]
Wrseq '$RIEN' Using [WMNT]
Wrseq 'Resume' Using [WMNT]
Openo Using [WMNT]
Call VALID("TRT",PRGMNT,nomap,STAT) From VALMSKSUB
End
