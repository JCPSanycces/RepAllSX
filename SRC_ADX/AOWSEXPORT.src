#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Web service Export
#*
#* @param I_MODEXP    : X3 template export
#* @param I_CHRONO    : Chrono management = YES or NO
#* @param I_TCRITERE  : Table of criterias
#* @param I_EXEC      : Type of execution = BATCH or REALTIME
#* @param I_RECORDSEP : Separator of records for the export file
#* @param O_FILE      : It is the output file
#* @param O_REQNUM    : If the type is BATCH the number of batch request
#* @param O_STATUS    : Status of Web service : 0=OK else >0 ERROR
#* @param O_MESSA     : Error if status>0
#*!
Subprog EXPORT(I_MODEXP, I_CHRONO, I_TCRITERE,I_EXEC,I_RECORDSEP,O_FILE,O_REQNUM,O_STATUS,O_MESSA)
Value     Char      I_MODEXP()
Value     Char      I_CHRONO
Value     Char      I_TCRITERE()()
Value     Char      I_EXEC()
Value     Char      I_RECORDSEP()
Variable  Clbfile   O_FILE()
Variable  Integer   O_REQNUM
Variable  Integer   O_STATUS
Variable  Char      O_MESSA()


Local Char     FIL1(GDIMFIC) : # name of the csv.file : ex : ol.csv
Local Char     FIL1FULL(GDIMFIC) : # Fullname of the csv file : ex c:/../tmp/ol.csv
Local Char     SEPENR(5)

Local Integer I,J
Local Integer NBLIG1, NBLIG2
Local Integer ZFSTAT
Local Clbfile LEC(6)#,TMP_FILE(6)
Local Integer IMPSTA
Local Char YEND(3) : YEND="END"
#If clalev([F:AOE])=0 : Local File AOBJEXT [AOE] : Endif
Gosub OUVRE From GEXPOBJ

If clalev([M:DIA])=0 : Local Mask EXPOBJ [DIA] : Endif
Raz O_FILE, O_REQNUM, O_STATUS,O_MESSA

If I_MODEXP=""
 O_STATUS = 1 : O_MESSA=func AFNC.MES1(mess(181,141,1),"I_MODEXP"): End : #" La valeur de I_MODEXP ne doit pas être vide"
Endif
Read [AOE]AOE0 = I_MODEXP
If fstat
 O_STATUS = 2 : O_MESSA=mess(182,141,1) : End :#"Template X3 not found"
Endif
If find(I_CHRONO,"YES","NO")=0
 O_STATUS = 3 : O_MESSA=func AFNC.MES3(mess(183,141,1),"I_CHRONO","YES","NO") : End :#"The value of I_CHRONO must be YES or NO"
Endif

If find(I_EXEC,"BATCH","REALTIME")=0
 O_STATUS = 4 : O_MESSA=func AFNC.MES3(mess(183,141,1),"I_EXEC","BATCH","REALTIME") : End :#"The value of I_EXEC must be BATCH or REALTIME"
Endif
If I_RECORDSEP=""
 O_STATUS = 5 : O_MESSA=func AFNC.MES1(mess(181,141,1),"I_RECORDSEP") : End : #"The value of I_RECORDSEP should not be empty"
Endif

FIL1 = func APREFIXTRT.GET_PREFIX_AOWS()+"_EXPORT"+"_"+I_MODEXP+"_"+GUSER+"_"+num$(adxuid(1))+num$(time)
If I_EXEC="BATCH"
 FIL1+= "_"+num$(ascii(I_RECORDSEP))
Endif
FIL1FULL = filpath("tmp",FIL1,"csv",nomap)

If I_EXEC="REALTIME"
 Gosub EXPORT_REALTIME
Elsif I_EXEC="BATCH"
 Gosub EXPORT_BATCH
Endif

End

$EXPORT_BATCH

Local Char TACHE(GLONABT) : TACHE = "EXPORT"
Local Char ABRMSKBATCH(5) : ABRMSKBATCH = "EXP2"
Gosub BATCH_START From AOWSIMPORT

If GERR : Return : Endif

Gosub TRT_BODY_EXPORT
If O_STATUS>0 : Return : Endif

Gosub BATCH_END From AOWSIMPORT

Return


$EXPORT_REALTIME

Gosub TRT_BODY_EXPORT
If O_STATUS>0 : Return : Endif

Call EXPORTSIL() From GEXPOBJ
 #IMPSTA = [M:EXP2]STAT
 #If IMPSTA : Gosub ERR_EXPORT : Endif
 #If GOK<1 : IMPSTA = 11 : Gosub ERR_EXPORT : Endif

Gosub TRT_FILE_TO_CLOB



Return

$TRT_BODY_EXPORT

Raz [M:AOE0], [M:AOE1], [M:AOE2], [M:EXP1], [M:EXP2]

SEPENR = func AOWSIMPORT.GET_SEPENR([F:AOE]SEPREC)

Case I_CHRONO
 When "YES" : [M:EXP2]CHRONO = 2 : [M:DIA]CHRONO = 2
 When "NO"  : [M:EXP2]CHRONO = 1 : [M:DIA]CHRONO = 1
Endcase

Call CHARGE_MODELE(I_MODEXP,IMPSTA) From GEXPOBJ
For I = 0 To [M:EXP1]NBFIC-1
 If I_TCRITERE(I)<>""
  [M:EXP1]CRITERE(I) = I_TCRITERE(I)
 Endif
Next
If IMPSTA
 O_STATUS = 10 : O_MESSA=mess(184,141,1) : Return : #"Error for charging export template "
Endif

[M:EXP2]=[M:EXP1]
[M:EXP2]MODELE = I_MODEXP
[M:EXP2]NOMEXP = [L]FIL1FULL
[M:EXP2]TYPEXP = 2


Return


$TRT_FILE_TO_CLOB

Openi FIL1FULL Using [CSV]

Iomode adxirs [L]SEPENR Using [CSV]
Iomode adxifs "" Using [CSV]

Case [F:AOE]CODDBA
 When 1 : #ASCII
  Iomode adxium GASCII Using [CSV]
 When 2 : #UTF-8
  Iomode adxium GUTF8 Using [CSV]
Endcase
[L]ZFSTAT=0
[L]O_FILE=""
Raz [L]NBLIG1,[L]NBLIG2

While [L]ZFSTAT=0
 Rdseq [L]LEC Using [CSV]
 [L]ZFSTAT=fstat
 If [L]ZFSTAT=0
  [L]NBLIG1 +=1
  Append O_FILE,[L]LEC
  Append O_FILE,I_RECORDSEP
 Endif
Wend
Openi Using [CSV]

I=0
J=1

Repeat
 I = instr(J,O_FILE,I_RECORDSEP)
 If I>0
  [L]NBLIG2+=1
  J=I+1
 Endif
Until I=0

If [L]NBLIG1=0
 O_STATUS = 30 : O_MESSA=func AFNC.MES1(mess(185,141,1),"0") : Return : #"The export have 0 line(s)"
Endif
If [L]NBLIG1<>[L]NBLIG2 or right$(O_FILE,len(O_FILE))<> I_RECORDSEP
 O_STATUS = 31 : O_MESSA=func AFNC.MES1(mess(186,141,1),"O_FILE") : Return : #"The value of O_FILE isn't completed"
Endif

Return

