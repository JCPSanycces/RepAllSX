#<AdxTL>@(#)5.0.0.0 $Revision$
#######################################################################
# TRTX3IMPS                                                           #
#             TRAITEMENTS COMMUN IMPORT SPECIFIQUE  X3                #
#                                                                     #
#######################################################################

# -------------------------------------------------------------- #
# Traitements de génération pour les imports spécifiques         #
# -------------------------------------------------------------- #

#------------------------------------------------------------------------
$DEFINE_IS
#-- Ecrans  
Local Integer  TISABMR       (15)  : # table ordre des masques dans la saisie 
Local Char     TISMSK   (12) (15)  : # table des masques
Local Char     TISABM   (5)  (15)  : # table des abbreviation des masques
Local Char     TISW1    (15) (15)  : # table des W1xxxxxx des masques
Local Char     TISMSKO  (10) (15)  : # table des masques secondaires de saisie si liés à la ligne    
#-- Tables
Local Char     TISFIC   (10) (10)  : # table des fichiers
Local Char     TISABF   (5)  (10)  : # table des abbreviation des fichiers
Local Char     TISMSKLG (12) (10)  : # nom du masque qui gère les lignes       
Local Char     TISFBTAB (12) (10)  : # nom de la variable bas de tableau qui gère les lignes   
Local Char     TISFCRIT (50) (10)  : # critere de selection pour répartition des champs du paramétrage
Local Integer  TISFLG              : # si =1  TISMSKLG  TISFBTAB  TISFCRIT sont a garnir dans IMPxxxx 
#-- Actions 
Local Char     TISACT   (10) (23)  : # table des actions écran utilisées en import  
Local Integer  TISCOG        (23)  : # table des actions type appel : 0=Call / 1=Gosub  

Local Char     TISTYP   (3)  (10)  : # table des types de données sans actions (les principales)

Local Integer  TISMKSTAT           : # stockage de la valeur du mkstat ( si besoin pour test) 
                                     # initialise a chaque integration de ligne
Local Integer  TISJUMP             : # flag de deroulement du traitement            
                                     # permet de ne pas dérouler le traitement de chargement d'un champ
Local Integer  TISVALID            : # flag de test de la validation ( si =1 on peut valider )

#--               Table des zones obligatoires dans paramétrage du modèle import
Local Shortint NBTO : NBTO=50 : # nombre de postes table
Local Char     TOABF (5)  (0..NBTO) : # - Abreviation fichier
Local Char     TOATZ (15) (0..NBTO) : # - zone de la table
Local Integer  TOFLG      (0..NBTO) : # - Flag de presence dans modele (0=non / 1=oui) 
   
#--               Recherche no de la ligne detail
Local Char     TRLDCLE (100) (0..8) : # données constituant la clé de recherche
Local Integer  TRLDBRK       (0..8) : # indicateur d'arrêt de la recherche  
   
#--               Correspondance fichier - masque
Local Shortint NBT : NBT=400 : # nombre postes table   
Local Shortint TRANG       (0..NBT) : # - Rang dans table de stockage 
Local Char     TABF   (5)  (0..NBT) : # - Abreviation de la table
Local Char     TATZ   (15) (0..NBT) : # - Zone de la table
Local Char     TABF_Z (20) (0..NBT) : # - Concatenation abreviation table + zone (AAA/ZZZ)
Local Integer  TATZ_M      (0..NBT) : # - Presence dans modele (0=non / 1=oui) 
Local Shortint TABM_R      (0..NBT) : # - Rang de saisie des masques          
Local Char     TABM   (5)  (0..NBT) : # - Abreviation du masque 
Local Char     TAMZ   (15) (0..NBT) : # - Champ du masque 
Local Char     TABM_Z (20) (0..NBT) : # - Concatenation abreviation masque + zone (AAA/ZZZ)
Local Shortint TAMZ_T      (0..NBT) : # - Type de champ du masque  
Local Shortint TAMZ_R      (0..NBT) : # - Rang du champ dans le masque (ordre de saisie)  
Local Shortint TAMZ_S      (0..NBT) : # - Champ masque saisissable (1=saisi /2=affiché/ 3=invisible) 
Local Shortint TAMZ_D      (0..NBT) : # - Champ masque dimension 
Local Char     TAMZ_B (10) (0..NBT) : # - Variable bas de tableau   
Local Char     TAMZ_A (10) (0..NBT) : # - Champ masque : actions à traiter dans l'import      
Local Char     TABM_O (5)  (0..NBT) : # - Abreviation du masque origine si masque complementaire 

#--               Table des noms différents entre fichier et masque  
Local Shortint NBTE : NBTE=150 : # nombre postes table   
Local Char     TEABF  (5)  (0..NBTE) : # - Abreviation fichier
Local Char     TEATZ  (15) (0..NBTE) : # - Champ fichier
Local Char     TEABM  (5)  (0..NBTE) : # - Abreviation masque 
Local Char     TEAMZ  (15) (0..NBTE) : # - Zone masque F
Local Char     TEABMO (5)  (0..NBTE) : # - Abreviation masque origine (si TEABM est masque complementaire)  
Local Char     TEAMZO (15) (0..NBTE) : # - Abreviation champ  origine (si TEABM est masque complementaire)  

Return

#------------------------------------------------------------------------
$PRESENCE_IS
Local Integer IJ1 
For IJ1=0 To dim(TOABF)-1
  If TOABF(IJ1)="" : Break : Endif 
  Call TST_CHAMP(TOABF(IJ1),TOATZ(IJ1),TOFLG(IJ1)) From SUBIMPOBJ 
  If TOFLG(IJ1)=0
    OK=0 : GERR=1 : GMESSAGE=mess(323,199,1)+" :  "+TOABF(IJ1)+"  /  "+TOATZ(IJ1) 
    Break
  Endif
Next IJ1
Return

#------------------------------------------------------------------------
$TRTSUP_IS

Local Integer IJRG, ITRI
Local Integer IJ1, IJ2, IJ3, IJ4, IJ5
Local Integer C_AMK, C_AMZ, C_AMA, C_ATY, C_ACV, C_ATB, I_ATZ, I_AOB : # fichiers à fermer (close si =1) 

Local Char     QUELMSK (12)  : # nom du masque ouvert sous [ZZZ]  
Local Char     QUELABM (5)   : # abrev du masque ouvert sous [ZZZ]  
Local Char     QUELAMZ (12)  : # nom du champ masque sans les (xx) 
Local Char     QUELATZ (20)  : # zone de travail 
Local Shortint TW1 (30)      : # garnie avec les no actions des types de données et des ecrans

If clalev([AMK])=0 : Local File AMSK     [AMK] : C_AMK=1 : Endif  
If clalev([AMZ])=0 : Local File AMSKZON  [AMZ] : C_AMZ=1 : Endif  
If clalev([AMA])=0 : Local File AMSKACT  [AMA] : C_AMA=1 : Endif  
If clalev([ATY])=0 : Local File ATYPE    [ATY] : C_ATY=1 : Endif  
If clalev([ACV])=0 : Local File ACTIV    [ACV] : C_ACV=1 : Endif  
If clalev([ATB])=0 : Local File ATABLE   [ATB] : C_ATB=1 : Endif  
If clalev([ATZ])=0 : Local File ATABZON  [ATZ] : C_ATZ=1 : Endif  
If clalev([AOB])=0 : Local File AOBJET   [AOB] : C_AOB=1 : Endif

# actions utilisées dans l'import 
# permet de generer le Call ou Gosub des actions dans les W1xxxxxx
# dans TISCOG (0=Call / 1=Gosub) 
# TISACT et TISCOG ecrans 
TISACT(2) ="AV_"    : TISCOG(2) =1 :        # Avant-Zone
TISACT(3) ="D_"     : TISCOG(3) =0 :        # Init
TISACT(4) ="AS_"    : TISCOG(4) =0 :        # Avant-Saisie    
TISACT(5) ="C_"     : TISCOG(5) =0 :        # Controle    
TISACT(6) ="AP_"    : TISCOG(6) =0 :        # Apres-Zone
TISACT(7) ="AMM_"   : TISCOG(7) =1 :        # Apres-Modif  
TISACT(13)="AVANT_" : TISCOG(13)=0 :        # Avant-Ligne 
TISACT(14)="APRES_" : TISCOG(14)=0 :        # Apres-Ligne  
 
# pour ne pas rechercher les actions dans ces types de données (gain de temps)
TISTYP(0)="A" : TISTYP(1)="C" : TISTYP(2)="D" : TISTYP(3)="DCB" : TISTYP(4)="M" : TISTYP(5)="MM"
# lecture de l'objet
Read [AOB]ABREV=[M:AOE1]OBJ   

# recherche des abréviations fichiers
For IJ1=0 To dim(TISFIC)-1
  If TISFIC(IJ1)="" : Break : Endif
  Read [ATB]CODFIC=TISFIC(IJ1)
  If !fstat : TISABF(IJ1)=[F:ATB]ABRFIC : Endif
Next IJ1

# recherche des abbréviations et AUTxxx des masques
# bascule des abbreviations action suivant ecrans web ou non (test sur 1er ecran)
# genere le traitement de creation et remplissage des variables AUTxxx
Wrseq " "
Wrseq "#------------------------------------------------------------------------" 
Wrseq "$FROM_W1"
For IJ1=0 To dim(TISMSK)-1
  If TISMSK(IJ1)="" : Break : Endif
  Read [AMK]CODMSK=TISMSK(IJ1)
  If !fstat 
    If TISABM(IJ1)="" : TISABM(IJ1)=[F:AMK]ABRMSK : Endif 
    TISW1(IJ1)="W1"+TISMSK(IJ1) 
    Wrseq "Local Char "+TISW1(IJ1)-"(15) : "+TISW1(IJ1)+"='"+TISW1(IJ1)+"'"
  Endif
Next IJ1
Wrseq "Return"

#----------
#  Creation des tables correspondance fichier-masque pour la generation des traitements
#----------
#   Chaque ligne contient (nbre de postes défini par variable NBT dans $DEFINE_IS)
#   - Shortint TRANG        : Rang dans table de stockage 
#   - Char     TABF   (5)   : Abreviation de la table
#   - Char     TATZ   (15)  : Zone de la table
#   - Char     TABF_Z (20)  : Concatenation abreviation table + zone (AAA+ZZZ) 
#   - Integer  TATZ_M       : Presence dans modele (0=non / 1=oui) 
#   - Shortint TABM_R       : Rang de saisie des masques          
#   - Char     TABM   (5)   : Abreviation du masque 
#   - Char     TAMZ   (15)  : Champ du masque 
#   - Char     TABM_Z (20)  : Concatenation abreviation masque + zone (AAA+ZZZ)
#   - Shortint TAMZ_T       : Type de champ du masque  
#   - Shortint TAMZ_R       : Rang du champ dans le masque (ordre de saisie)  
#   - Shortint TAMZ_S       : Champ masque saisissable (1=saisi /2=affiché/ 3=invisible) 
#   - Shortint TAMZ_D       : Champ masque dimension 
#   - Char     TAMZ_B (10)  : Variable bas de tableau   
#   - Char     TAMZ_A (10)  : Champ masque : actions à traiter dans l'import      
#   - Char     TABM_O (5)   : Abreviation du masque origine si masque complementaire 
#----------

#------ Phase 1 : pour chaque fichier defini dans la table TISFIC (les tables à importer) 
#                 creation 1 ligne par champ de la table (lecture du dictionnaire des tables) 
#                 1 tranche de 1000 postes par table (pour permettre les insertions dans no TRANG )
#                 chargement TRANG  TABF  TATZ  TABF_Z

Raz IJ2, IJ3
For IJ1=0 To dim(TISFIC)-1
  If TISFIC(IJ1)="" : Break : Endif
  Raz IJ3
  Filter [ATZ] Where CODFIC=TISFIC(IJ1)
  For [ATZ]NUMLIG 
    TRANG(IJ2)=(IJ1*1000)+IJ3+1 : TABF(IJ2)=TISABF(IJ1) : TATZ(IJ2)=[F:ATZ]CODZONE      
    TABF_Z(IJ2)=TABF(IJ2)+"/"+TATZ(IJ2)  : # concatenation
    IJ2 +=1 : IJ3 +=1 
  Next
Next IJ1
Filter [ATZ]

#------ Phase 2 : pour chaque exception (nom champ table <> nom dans masque) de TEABF
#                 recherche si ligne existe : TABF et TATZ
# si nelle ligne: chargement TRANG  TABF  TATZ  TABF_Z  TABM  TAMZ  TABM_Z  
# ancienne ligne: ajout                                 TABM  TAMZ  TABM_Z              

For IJ1=0 To dim(TEABF)-1
  If TEABF(IJ1)<>""
    Raz IJRG
    IJ2=find(TEABF(IJ1),TISABF)        : # recherche du rang du fichier pour cette exception 
    If IJ2 : IJRG=(IJ2-1)*1000 : Endif : # tranche de 1000 lignes possibles par fichier
    IJ2=find(TEABF(IJ1),TABF)
    If IJ2 : IJ2 -=1 : Endif
    For IJ3=IJ2 To dim(TABF)-1
      If TABF(IJ3)<>TEABF(IJ1)         : # pas de ligne deja definie (ajouter une ligne)
        IJ4 = find(0,TRANG)
        If IJ4
          TRANG(IJ4-1)=IJRG+999
          TABF(IJ4-1)=TEABF(IJ1) : TATZ(IJ4-1)=TEATZ(IJ1) : TABF_Z(IJ4-1)=TEABF(IJ1)+"/"+TEATZ(IJ1) 
          TABM(IJ4-1)=TEABM(IJ1) : TAMZ(IJ4-1)=TEAMZ(IJ1) : TABM_Z(IJ4-1)=TEABM(IJ1)+"/"+TEAMZ(IJ1)  
          Break 
        Endif  
      Endif
      If TATZ(IJ3)=TEATZ(IJ1)
        TABM(IJ3)=TEABM(IJ1) : TAMZ(IJ3)=TEAMZ(IJ1): TABM_Z(IJ3)=TEABM(IJ1)+"/"+TEAMZ(IJ1)   
        Break
      Endif
    Next IJ3
  Endif
Next IJ1

#------ Phase 3 : pour chaque masque defini dans la table TISMSK
#                 pour chaque champ du masque : ajouter les donnees ecran de la ligne 
#                 recherche si ligne existe : TABF et TATZ (pas de modif si traite par les exceptions)  
# si nelle ligne: chargement TRANG  TABM  TAMZ  TABM_Z  TAMZ_S  
# ancienne ligne: ajout             TABM  TAMZ  TABM_Z  TAMZ_S              

For IJ1=0 To dim(TISMSK)-1
  If TISMSK(IJ1)="" : Break : Endif
  Filter [AMZ] Where CODMSK=TISMSK(IJ1)
  For [AMZ]
    IJ2 = find([F:AMZ]CODZON,TATZ)
    If !IJ2 
      IJ2 = find([F:AMZ]CODZON+"(0)",TATZ)  : # recherche si presence indice
    Endif
#   si la zone masque a le meme nom que le champ de la table (compléter le tableau)
#      - si le nom du masque n'est pas garni
#      - si le nom du masque est deja garni le remplacer en fonction du cade saisie
#          (permet de remplacer une zone affichée par une zone saisissable)
    If (IJ2 & TABM(IJ2-1)="") | (IJ2 & [F:AMZ]SAIAFF < TAMZ_S(IJ2-1))
      TABM(IJ2-1)=TISABM(IJ1) : TAMZ(IJ2-1)=[F:AMZ]CODZON       
      TABM_Z(IJ2-1)=TISABM(IJ1)+"/"+[F:AMZ]CODZON
      TAMZ_S(IJ2-1)=[F:AMZ]SAIAFF      
    Else
#     cette zone masque n'a pas de correspondance dans la table   
      If [F:AMZ]SAIAFF=1 &  !find (TISABM(IJ1)+"/"+[F:AMZ]CODZON,TABM_Z)
        IJ4 = find(0,TRANG)   : # il faut ajouter un poste si zone saisissable
        If IJ4
          TRANG(IJ4-1)=9999
          TABM(IJ4-1)=TISABM(IJ1) : TAMZ(IJ4-1)=[F:AMZ]CODZON 
          TABM_Z(IJ4-1)=TISABM(IJ1)+"/"+[F:AMZ]CODZON
          TAMZ_S(IJ4-1)=[F:AMZ]SAIAFF      
        Endif  
      Endif
    Endif 
  Next
Next IJ1
Filter [AMZ]

#------ Phase 4 : pour chaque table mise a jour definie dans TISFIC
#                 il faut ouvrir les tables pour tester le dim des zones et rechercher la 
#                 présence dans le modèle ( exemple : presence à oui si dans modèle REP(1) ) 

For IJ1 =0 To dim(TISFIC)-1
If TISFIC(IJ1)<>""
  If evalue ("clalev (["+TISABF(IJ1)+"])") =0      
    Local File  =TISFIC(IJ1)                   : # la table est ouverte sur l'abreviation du dictionnaire 
  Endif
Endif
Next IJ1

#------ Phase 5 : pour chaque ligne du tableau TRANG
#                 chargement TATZ_M  TABM_R  TABM_O  TAMZ_S  TAMZ_R  TAMZ_B  TAMZ_A

Raz QUELABM, QUELMSK, QUELATZ

For IJ1=0 To dim(TRANG)-1
  If TRANG(IJ1)=0 : Break : Endif

#-          chargement TATZ_M  presence du champ table dans le modèle d'import
  If TABF(IJ1)<>""
    If instr(1,TATZ(IJ1),"GIMP(")                              : # si la donnee du tableau est une globale
      TATZ_M(IJ1)=1                                            : # ligne tableau creee par les exceptions 
    Else
      If evalue ("dim([F:"+TABF(IJ1)+"]"+TATZ(IJ1)+")") =1     : # zone non dimensionnée dans la table
        Call TST_CHAMP (TABF(IJ1),TATZ(IJ1),TATZ_M(IJ1)) From SUBIMPOBJ
      Elsif evalue ("dim([F:"+TABF(IJ1)+"]"+TATZ(IJ1)+")") >1  : # zone dimensionnée dans la table
        For IJ2=0 To evalue("dim([F:"+TABF(IJ1)+"]"+TATZ(IJ1)+")")-1
          If TATZ_M(IJ1)=1 : Break : Endif
          QUELATZ=TATZ(IJ1)+"("+num$(IJ2)+")"                  : # il faut rechercher sur tous les postes 
          Call TST_CHAMP (TABF(IJ1),QUELATZ,TATZ_M(IJ1)) From SUBIMPOBJ
        Next IJ2
      Endif
    Endif
  Endif

#-          chargement TABM_R  no ordre de saisie des masques (pour trier)
#-          chargement TABM_O  masque origine (uniquement si saisie dans un masque complementaire)
  If TAMZ(IJ1)<>""
    Raz TW1                       : # init tableau de recherche des actions
    
    IJ2=find(TABM(IJ1),TISABM)    
    If IJ2
      TABM_R(IJ1)=TISABMR(IJ2-1)  
      TABM_O(IJ1)=TISMSKO(IJ2-1)  
      QUELABM=TISABM(IJ2-1)        
      QUELMSK=TISMSK(IJ2-1)        
    Endif

#-          chargement TAMZ_S  code saisie du champ (1=saisi / 2=affiche / 3=invisible)
#-          chargement TAMZ_R  no ordre du champ dans le masque
    IJ2=instr(1,TAMZ(IJ1),"(")  
    If IJ2 : QUELAMZ=left$(TAMZ(IJ1),IJ2-1) : Else : QUELAMZ=TAMZ(IJ1) : Endif
    Read [AMZ]CODE=QUELMSK;QUELAMZ      : # lecture dans dictionnaire champs des champs du masque
    If !fstat
      If [F:AMZ]CODMSK<>[F:AMK]CODMSK
        Read [AMK]CODMSK=[F:AMZ]CODMSK  : # lecture dans dictionnaire des masques   
      Endif
      If TAMZ_S(IJ1)=0                  : # si deja garni (developpement ulterieur ?) 
        TAMZ_S(IJ1)=[F:AMZ]SAIAFF  
      Endif
      TAMZ_R(IJ1)=[F:AMZ]NUMLIG

#-          chargement TAMZ_B  variable bas tableau (si champ d'un bloc tableau)
      If [F:AMK]TYPBLOC([F:AMZ]NUMBLOC-1)=1 : TAMZ_B(IJ1)=[F:AMK]BASPAG([F:AMZ]NUMBLOC-1) : Endif 

#-          chargement TAMZ_A  actions du champ (uniquement les actions d'import)
      If find([F:AMZ]CODTYP,"M","MM") & [F:AMZ]SAIAFF=1
        TW1(5)=1                        : # toujours controle si menu local saisissable
      Endif
      If !find([F:AMZ]CODTYP,TISTYP)    : # ne pas traiter les types de données de ce tableau
        Read [ATY]CODTYP=[F:AMZ]CODTYP  : # recherche des actions liées au type de donnée
        If !fstat
          If [F:ATY]OBJLIEN<>""         :       # - action controle avec objet      
            TW1(5)=1 
          Endif
          For IJ2=0 To dim([F:ATY]IMPORT)-1 :   # - actions parametrees  
            If [F:ATY]IMPORT(IJ2)=2 : TW1(IJ2+1)=1 : Endif 
          Next IJ2
        Endif
      Endif  
      Filter [AMA] Where TYPAFF=1 & CODAFF=[F:AMZ]CODMSK & CODZON=[F:AMZ]CODZON & 
&                        find(EXEACT,2,3) & find(TYPACT,2,3,4,5,6,7,13,14) 
      For [AMA]TYPAFF
        TW1([F:AMA]TYPACT)=1
      Next 
      Filter [AMA] 
#     le tableau TW1 contient les actions spécifiques à l'import de cette donnée
      For IJ2=1 To dim(TW1)-1
        If TW1(IJ2)=1
          TAMZ_A(IJ1) += format$("N0:2",num$(IJ2))
        Endif
      Next IJ2
    Endif
  Endif
Next IJ1

#------ Phase 6 : tri du tableau TRANG dans l'ordre de saisie du masques

ITRI= find(0,TRANG) 
Sorta ITRI  TABM_R, TAMZ_R, TABM, TAMZ, TABM_Z, TAMZ_T, TAMZ_S, TAMZ_D, TAMZ_B, TAMZ_A,  
&           TABM_O, TABF, TATZ, TABF_Z, TATZ_M, TRANG

#------ Phase 7 : pour chaque ligne du tableau TRANG (trie dans l'ordre de saisie)
#                 chargement TAMZ_T  TAMZ_T  


# recherche du type de zone masque (uniquement si zone saisissable) 
#           dimension  zone masque (uniquement si zone saisissable)
Raz QUELMSK, QUELABM, QUELATZ
For IJ1=0 To dim(TRANG)-1
  If TAMZ_S(IJ1)=1 
    If TABM(IJ1)<>QUELABM
      If clalev([M:ZZZ])>0 : Close Mask [ZZZ] : Endif
      IJ2=find(TABM(IJ1),TISABM)
      If IJ2
        QUELABM=TISABM(IJ2-1)        
        QUELMSK=TISMSK(IJ2-1)        
        Local Mask =QUELMSK [ZZZ]
      Endif
    Endif      

#-          chargement TAMZ_T  type du champ (si saisissable) 
#-          chargement TAMZ_D  dimension du champ (si saisissable)
    If evalue("dim([M:ZZZ]"+TAMZ(IJ1)+")")>0
      TAMZ_T(IJ1)=evalue("type ([M:ZZZ]"+TAMZ(IJ1)+")")
      TAMZ_D(IJ1)=evalue("dim([M:ZZZ]"+TAMZ(IJ1)+")")
    Endif    

    IJ2=instr(1,TAMZ(IJ1),"(")        : # si bidouille ...
    If IJ2 : TAMZ_D(IJ1)=1 : Endif

    If TAMZ_T(IJ1)<0 | find(TAMZ_T(IJ1),8,10) : TAMZ_T(IJ1)=0 : Endif
  Endif 

Next IJ1 

#------ Phase 8 : pour chaque ligne du tableau TRANG (trie dans l'ordre de saisie)
#                 chargement TABF sur la variable bas tableau    
#                 (necessaire pour generer les actions sur variable bas tableau) 

For IJ1=0 To dim(TRANG)-1
#                 si on est sur une ligne bas tableau 
  If TAMZ_B(IJ1)<>"" & TAMZ(IJ1)=TAMZ_B(IJ1) & TABF(IJ1)=""
    IJ5=IJ1
    For IJ5=IJ1 To dim(TRANG)-1
#                 on recherche l'abreviation table sur un champ suivant du meme bloc tableau
      If TABF(IJ5)<>"" : TABF(IJ1)= TABF(IJ5) : Break : Endif
    Next IJ5
  Endif
Next IJ1

#------ Phase 9 : creation du fichier de contrôle (à supprimer apres mise au point)
#                 fichier ZJL.zjl : image du tableau TRANG genere dans repertoire des textes    
#                 (exemple: sur gaile610  /home1/adonix/GX3APP/TXT/ZJL.zjl 

Gosub VERIF_IS

#------

# fermetures
If clalev([M:ZZZ])>0 : Close Mask [ZZZ] : Endif

# generation des SAIMSK
Gosub SAIMSK_IS 

# generation de RAZCRE des menus locaux
Gosub RAZCRE_IS 

# generation du controle des menus locaux
Gosub CTL_MLOC_IS 

# generation du chargement des zones non saisissables des masques principaux 
Gosub ZON_NSAI_IS

# generation du transfert des donnees des masques complementaires 
Gosub MSK_CPLT_IS

# generation de la recherche du no de ligne détail 
Gosub TRLD_IS

# nettoyage après generation traitement
Gosub CLEAN_IS
Return

#########################################################################

$SAIMSK_IS
Local Integer IDSM        : # indicateur début generation $xxx_SAIMSK (xxx=abreviation table)
Local Integer IFSM        : # indicateur fin   generation $xxx_SAIMSK (xxx=abreviation table) 
Local Integer IBTAB       : # rang de la variable bas tableau  
Local Integer IDBTAB      : # indicateur generer actions debut de variable bas tableau (1=oui) 
Local Integer IFBTAB      : # indicateur generer actions fin   de variable bas tableau (1=oui) 
Local Integer IZTAB       : # indicateur type ligne du modèle (si =1 c'est un champ table)
Local Integer IGIMP       : # indicateur type ligne du modèle (si =1 c'est un GIMP)  

Local Char    JKW1    (20) : # nom du traitement W1xxxxxx du champ masque
Local Char    JKZMSK  (20) : # nom du champ masque ( sans l'indice ni masque exemple QTY )
Local Char    JKZMSK1 (30) : # nom du champ masque ( sans l'indice exemple [M:xxx]QTY )
Local Char    JKZMSK2 (30) : # nom du champ masque ( avec indice si <> 0 exemple [M:xxx]QTY(12) ) 
Local Char    JKZTAB  (30) : # nom du champ table  ( avec l'indice si il est différent de 0 )
Local Char    JKVMAN  (20) : # contient le nom de la zone intermediaire suivant type 
Local Integer JKIND        : # si donnée indicee 
Local Char    JKGLIG  (20) : # nom de variable bas tableau si table attachée a bloc tableau 
                             # (exemple : NBLIG pour les lignes de livraison SDELIVERYD) 
Local Char    JKBTAB  (20) : # nom de variable bas de tableau pour bloc tableau pour table entête
                           : # (exemple : NBFAC pour elements facturation SDELIVERY)
Local Char    JKBTAB1 (20) : # nom de varable bas tableau (avec masque [M:xxx]NBFAC)
Local Char    JKMCLG  (20) : # nom de l'ecran de base pour les champs d'un masque complémentaire 
                             # ( uniquement si l'ecran de base est pour la saisie des lignes )  
Local Char    ESPACE (10)  : # zone de mise en page des instructions
Local Char    JKM1   (20)  : # variable de travail
Local Char    JKM2   (20)  : # variable de travail
Local Char    JKM3   (20)  : # variable de travail
Local Char    JKM4   (20)  : # variable de travail
Local Char    JKM5   (20)  : # variable de travail

Local Integer OKCHAMP       : # flag de présence du champ dans le paramétrage

# Chargement du critère de traitement des données d'une table 
# (si plusieurs tables constituent la ligne détail, generation d'une seule section)
#  TISFIC(0)="SORDER"                   TISFIC(1)="SORDERQ"                        TISFIC(2)="SORDERP"
#  TISABF(0)="SOH"                      TISABF(1)="SOQ"                            TISABF(2)="SOP"
#  TISMSKLG(0)=
#  TISFCRIT(0)="find(TABF(IJ2),"SOH")"  TISFCRIT(1)="find(TABF(IJ2),"SOQ","SOP")"  TISFCRIT(2)="" 

If !TISFLG               : # il faut garnir TISFBTAB  TISMSKLG  TISFCRIT

  For IJ1=0 To dim(TISABF)-1
    If TISABF(IJ1)="" : Break : Endif
    For IJ2=0 To dim([F:AOB]IMPTBL)-1
      If TISFIC(IJ1)=[F:AOB]IMPTBL(IJ2) & [F:AOB]IMPTAB(IJ2)<>"" 
        TISFBTAB(IJ1)=[F:AOB]IMPTAB(IJ2)
        TISMSKLG(IJ1)=[F:AOB]IMPMSK(IJ2) 
      Endif
    Next IJ2 
  Next IJ1

#If GUSER="JL" : dbgmode(1)=1 : Endif

  For IJ1=0 To dim(TISABF)-1
    If TISABF(IJ1)="" : Break : Endif
    If TISFBTAB(IJ1)=""   : # c est une table qui ne gere pas les lignes
      TISFCRIT(IJ1)="find(TABF(IJ2),'"+TISABF(IJ1)+"')"
    Else                  : # c est une table qui gere les lignes
      If IJ1=0 | TISMSKLG(IJ1)<>TISMSKLG(IJ1-1) | TISFBTAB(IJ1)<>TISFBTAB(IJ1-1)
        IJ2=IJ1
        TISFCRIT(IJ2)="find(TABF(IJ2),'"+TISABF(IJ1)
      Endif  
      If IJ1>0 & TISMSKLG(IJ1)=TISMSKLG(IJ1-1) & TISFBTAB(IJ1)=TISFBTAB(IJ1-1)
        TISFCRIT(IJ2) +="','"+TISABF(IJ1)
      Endif
      If IJ1=dim(TISABF)-1 | TISMSKLG(IJ1)<>TISMSKLG(IJ1+1)| TISFBTAB(IJ1)<>TISFBTAB(IJ1+1)
        TISFCRIT(IJ2) +="')"
      Endif
    Endif
  Next IJ1 

Endif

#If GUSER="JL" : dbgmode(1)=1 : Endif

#If GUSER="JL" : # essai pour helene
#  TISABF(0)="PTH"  : TISABF(1)="PTD"  : TISABF(2)="STJ"  : TISABF(3)="STW"  
#  TISFBTAB(0)="" : TISFBTAB(1)="NBLIG" : TISFBTAB(2)="NBLIG" : TISFBTAB(3)="NBLIG" : 
#  TISFCRIT(0)="find(TABF(IJ2),'PTH')" : TISFCRIT(1)="find(TABF(IJ2),'PTD')" 
#  TISFCRIT(2)="find(TABF(IJ2),'STJ','STW')"
#Endif

For IJ1=0 To dim(TISABF)-1
  Raz JKGLIG, IBTAB, IDBTAB, IFBTAB
  If TISABF(IJ1)="" : Break : Endif

  If TISFCRIT(IJ1)<>"" 
    JKGLIG=TISFBTAB(IJ1)

  If JKGLIG=""

#         Gestion de la table en mode liste (entete)
    IDSM=1                  : # il faut generer le debut du gosub
    For IJ2=0 To dim(TRANG)-1 

      If evalue(TISFCRIT(IJ1)) & TATZ_M(IJ2)=1 & TAMZ_S(IJ2)=1 & TAMZ_T(IJ2)>0 & TAMZ_D(IJ2)>0
#      If TABF(IJ2)=TISABF(IJ1) & TATZ_M(IJ2)=1 & TAMZ_S(IJ2)=1 & TAMZ_T(IJ2)>0 & TAMZ_D(IJ2)>0
#       si la zone du masque est occursée 

        If TAMZ_D(IJ2)>1 
          For IJ4=0 To TAMZ_D(IJ2)-1
            Raz JKBTAB, JKBTAB1
            Call TST_CHAMP(TABF(IJ2),TAMZ(IJ2)+"("+num$(IJ4)+")",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP
              JKIND=IJ4
              JKBTAB=TAMZ_B(IJ2) : JKBTAB1="[M:"+vireblc(TABM(IJ2),2)+"]"+JKBTAB
              Gosub SMIS_LIG
            Endif
          Next IJ4
        Else
          Raz JKBTAB, JKBTAB1
          Gosub SMIS_LIG      : # traitement une zone de masque
        Endif 
      Endif
    Next IJ2
    Gosub SMIS_FIN  

  Else
#         Gestion de la table en mode tableau (lignes)
    IDSM=1                  : # il faut generer le debut du gosub
    IDBTAB=1                : # il faut generer les actions debut bas tableau
    Raz IBTAB 
    For IJ2=0 To dim(TRANG)-1 
      If evalue(TISFCRIT(IJ1)) & TATZ(IJ2)="" & TAMZ(IJ2)=JKGLIG & TAMZ_B(IJ2)=JKGLIG
#      If TABF(IJ2)=TISABF(IJ1) & TATZ(IJ2)="" & TAMZ(IJ2)=JKGLIG & TAMZ_B(IJ2)=JKGLIG
        IBTAB=IJ2
      Endif
      If evalue(TISFCRIT(IJ1)) & TATZ_M(IJ2)=1 & TAMZ_S(IJ2)=1 & TAMZ_T(IJ2)>0 & TAMZ_D(IJ2)>0 
#      If TABF(IJ2)=TISABF(IJ1) & TATZ_M(IJ2)=1 & TAMZ_S(IJ2)=1 & TAMZ_T(IJ2)>0 & TAMZ_D(IJ2)>0 
#       si le zone du masque est occursée  
        JKBTAB=JKGLIG 
        JKMCLG=TABM_O(IJ2)
        If JKMCLG=""
          JKBTAB1="[M:"+vireblc(TABM(IJ2),2)+"]"+JKBTAB
        Else
          JKBTAB1="[M:"+vireblc(TABM_O(IJ2),2)+"]"+JKBTAB
        Endif

        Gosub SMIS_LIG      : # traitement une zone de masque
      Endif
    Next IJ2

    Gosub SMIS_FIN  

  Endif
  
  Endif

Next IJ1

Return

#------------------------------------------------------------------------
#  Traitement une ligne du modele dans l'ordre du tableau
#------------------------------------------------------------------------
$SMIS_LIG

If IDSM=1 
  Gosub SMIS_DEB       : # generer le debut du gosub SAIMSK (sur la premiere ligne) 
Endif

Gosub SMIS_LIG1        : # garnir les zones de travail suivant la ligne   

If JKBTAB<>"" & TAMZ_B(IJ2)=JKBTAB & IDBTAB=1
  Gosub SMIS_DBTAB     : # generer les actions debut de variable bas tableau 
Endif 

Wrseq " "
Wrseq "# --- "+TAMZ(IJ2)
Wrseq "Raz TISJUMP : MSK_ABR='"+TABM(IJ2)+"' : MSK_ZONE='"+TAMZ(IJ2)+"'"

Wrseq "Gosub AV_ZONE From "+TRTIMPORT
Wrseq "If !TISJUMP"

Gosub SMIS_LIG2        : # generer les actions de la ligne

Wrseq "Endif"
Wrseq "Gosub AP_ZONE From "+TRTIMPORT

If IFBTAB=1            : # generer les actions fin de variable bas tableau 
  For IJ5=IJ2+1 To dim(TRANG)-1             : # recherche prochain champ du modele
    If TATZ_M(IJ5)=1 
      If TAMZ_B(IJ5)=JKBTAB  :                    Break : Endif  : # si dans tableau
      If TAMZ_B(IJ5)<>JKBTAB : Gosub SMIS_FBTAB : Break : Endif  : # si hors tableau
    Endif
  Next IJ5

Endif

Return

#------------------------------------------------------------------------
#  pour generer les noms de la zone masque, de la zone table, 
#  choix de la variable de manoeuvre suivant type de donnee 
#  determiner si on a un indice 
#  JKW1    contient nom du traitement W1xxxxxx du champ masque sous la forme =W1xxxxxx
#  JKZMSK  contient nom du champ masque ( sans l'indice ni masque exemple QTY ) 
#  JKZMSK1 contient nom du champ masque ( sans l'indice exemple [M:xxx]QTY ) 
#  JKZMSK2 contient nom du champ masque ( avec indice si <> 0 exemple [M:xxx]QTY(12) ) 
#          contient nom du champ masque ( avec indice si tableau exemple [M:xxx]QTY(nolign-1))
#  JKZTAB  contient nom du champ table  ( avec l'indice si il est différent de 0 )
#  JKIND   contient la valeur de l'indice du champ masque
#  JKMCLG  contient abreviation du masque origine si masque complementaire
#------------------------------------------------------------------------
$SMIS_LIG1
IJ3=find(vireblc(TABM(IJ2),2),TISABM)
If IJ3
  JKW1 ="="+TISW1(IJ3-1)
Endif

# -- classe [M] receptrice
JKZMSK2="[M:"+vireblc(TABM(IJ2),2)+"]"+vireblc(TAMZ(IJ2),2)
IJ3=instr(1,JKZMSK2,"(")
If IJ3 : JKZMSK1=left$(JKZMSK2,IJ3-1)  : Else : JKZMSK1=JKZMSK2  : Endif
IJ3=instr(1,JKZMSK1,"]")
If IJ3 : JKZMSK=right$(JKZMSK1,IJ3+1) : Else : JKZMSK=JKZMSK1 : Endif

If JKGLIG<>"" & JKBTAB<>"" & JKBTAB=TAMZ_B(IJ2) & JKMCLG=""
  JKZMSK2=JKZMSK1+"(nolign-1)" 
Endif

If JKIND & !find("(",JKZMSK2) : JKZMSK2 += "("+num$(JKIND)+")" : Endif

# -- classe [F] ou GIMP emettrice
Raz IGIMP, IZTAB
If instr(1, TATZ(IJ2),"GIMP(") : IGIMP=1 
  Else                           IZTAB=1
Endif
If IZTAB 
  JKZTAB="[F:"+vireblc(TABF(IJ2),2)+"]"+vireblc(TATZ(IJ2),2) 
  If TATZ(IJ2)=TAMZ(IJ2) & JKIND : JKZTAB += "("+num$(JKIND)+")" : Endif
Endif
If IGIMP
  If TAMZ_T(IJ2)>10 : JKZTAB="num$("+TATZ(IJ2)+")"
    Else              JKZTAB="val("+TATZ(IJ2)+")"
  Endif 
  # ajouter ulterieurement le chargement d'une date à partir d'un gimp
Endif

If    find (TAMZ_T(IJ2),2,4)       JKVMAN="[L]IMPZINT" 
Elsif TAMZ_T(IJ2)=3                JKVMAN="[L]IMPZDAT"
Elsif find (TAMZ_T(IJ2),5,6,7,9)   JKVMAN="[L]IMPZDEC"
Else                               JKVMAN="[L]IMPZCHA"
Endif

JKIND=0

Return

#------------------------------------------------------------------------
#  generation des actions de la donnee 
#------------------------------------------------------------------------
$SMIS_LIG2

# --- Garnir le tableau des actions
Raz TW1, JKM1
If TAMZ_A(IJ2)<>""
  JKM1=TAMZ_A(IJ2)
  While JKM1<>""
    TW1(val(left$(JKM1,2)))=val(left$(JKM1,2)) : JKM1=right$(JKM1,3) 
  Wend
Endif

# - L01
If TABM(IJ2)<>QUELABM
  QUELABM=TABM(IJ2)
  Wrseq "If clalev([M:"+QUELABM+"])>0 : Default Mask ["+QUELABM+"] : Endif"
Endif
Raz ESPACE

# - L02
If JKBTAB=""
  Wrseq "IMPMOD=0 : mkstat=0 : indice="+num$(JKIND)+" : "+JKVMAN+"="+JKZMSK2 
Else
  Wrseq "IMPMOD=0 : mkstat=0 : "+JKVMAN+"="+JKZMSK2,
  If JKIND>0
    Wrseq "("+num$(JKIND)+")", 
  Endif
  Wrseq ""
Endif
Raz ESPACE

# - L03
If TW1(2)<>0 | TW1(3)<>0 | TW1(4)<>0
  If JKBTAB="" | ( JKBTAB<>"" & JKBTAB<>TAMZ_B(IJ2) ) | JKIND>0
    Wrseq "If varmode("+JKZMSK1+","+num$(JKIND)+")=0"
  Endif
  If JKBTAB<>"" & JKBTAB=TAMZ_B(IJ2) & JKMCLG=""  
    Wrseq "If varmode("+JKBTAB1+",0)=0"
  Endif
  If JKBTAB<>"" & JKBTAB=TAMZ_B(IJ2) & JKMCLG<>""
    Wrseq "If varmode("+JKBTAB1+",0)=0 & varmode("+JKZMSK1+","+num$(JKIND)+")=0"
  Endif
  ESPACE += "  "
Endif

# - L05
If TW1(2)<>0
  If TISCOG(2)=0 : Wrseq ESPACE+"mkstat=0 : Call "+TISACT(2)+JKZMSK+"("+JKVMAN+") From "+JKW1 : Endif
  If TISCOG(2)=1 : Wrseq ESPACE+"mkstat=0 : Gosub "+TISACT(2)+JKZMSK+" From "+JKW1 : Endif
Endif 

# - L06
If TW1(2)<>0
  Wrseq ESPACE+"If mkstat=1 : Raz "+JKVMAN+" : Endif" 
Endif

# - L08
# If TW1(3)<>0 
#   Wrseq ESPACE+"If !mkstat"
#   ESPACE += "  "
# Endif

# - L09
If TW1(3)<>0
  If TISCOG(3)=0 : Wrseq ESPACE+"mkstat=0 : Call "+TISACT(3)+JKZMSK+"("+JKVMAN+") From "+JKW1 : Endif
  If TISCOG(3)=1 : Wrseq ESPACE+"mkstat=0 : Gosub "+TISACT(3)+JKZMSK+" From "+JKW1 : Endif
Endif

# - L11
# If TW1(4)<>0
#   Wrseq ESPACE+"If !mkstat"
#   ESPACE += "  "
# Endif

# - L12
If TW1(4)<>0
  If TISCOG(4)=0 : Wrseq ESPACE+"mkstat=0 : Call "+TISACT(4)+JKZMSK+"("+JKVMAN+") From "+JKW1 : Endif
  If TISCOG(4)=1 : Wrseq ESPACE+"mkstat=0 : Gosub "+TISACT(4)+JKZMSK+" From "+JKW1 : Endif
Endif

# - L13
If TW1(4)<>0
  Wrseq ESPACE+"If mkstat=1 : Raz "+JKVMAN+" : Endif" 
Endif

# - L15
# If TW1(4)<>0
#   If ESPACE<>"" : ESPACE=left$(ESPACE,(len(ESPACE)-2)) : Endif
#   Wrseq ESPACE+"Endif" 
# Endif

# - L16
# If TW1(3)<>0 
#   If ESPACE<>"" : ESPACE=left$(ESPACE,(len(ESPACE)-2)) : Endif
#   Wrseq ESPACE+"Endif" 
# Endif

# - L17
If TW1(2)<>0 | TW1(3)<>0 | TW1(4)<>0
  Wrseq "Endif" 
  Raz ESPACE
Endif

# - L20
If TW1(2)<>0 | TW1(3)<>0 | TW1(4)<>0
  Wrseq "If !mkstat" 
  ESPACE += "  "
Endif

# - L22
If JKBTAB="" | ( JKBTAB<>"" & JKBTAB<>TAMZ_B(IJ2) ) | JKIND>0
  Wrseq ESPACE+"If varmode("+JKZMSK1+","+num$(JKIND)+")=0"
Endif
If JKBTAB<>"" & JKBTAB=TAMZ_B(IJ2) & JKMCLG=""  
  Wrseq ESPACE+"If varmode("+JKBTAB1+",0)=0"
Endif
If JKBTAB<>"" & JKBTAB=TAMZ_B(IJ2) & JKMCLG<>""
  Wrseq ESPACE+"If varmode("+JKBTAB1+",0)=0 & varmode("+JKZMSK1+","+num$(JKIND)+")=0"
Endif
ESPACE += "  "

# - L24
If TW1(2)<>0 | TW1(3)<>0 | TW1(4)<>0
Wrseq ESPACE+JKZMSK2+"="+JKVMAN
Endif

# - L25
Wrseq ESPACE+"If "+JKVMAN+"<>"+JKZTAB+" : "+JKVMAN+"="+JKZTAB+" : IMPMOD=1 : Endif"

# - L28
If TW1(5)<>0
  If TISCOG(5)=0 
    Wrseq ESPACE+"mkstat=0 : Call "+TISACT(5)+JKZMSK+"("+JKVMAN+") From "+JKW1,
    Wrseq " : If mkstat : TISMKSTAT=mkstat : Return : Endif" 
  Endif
  If TISCOG(5)=1 
    Wrseq ESPACE+"mkstat=0 : Gosub "+TISACT(5)+JKZMSK+" From "+JKW1,
    Wrseq " : If mkstat : TISMKSTAT=mkstat : Return : Endif" 
  Endif
Endif

# - L30
If TW1(6)<>0
  If TISCOG(6)=0 
    Wrseq ESPACE+"mkstat=0 : Call "+TISACT(6)+JKZMSK+"("+JKVMAN+") From "+JKW1,
    Wrseq " : If mkstat : TISMKSTAT=mkstat : Return : Endif" 
  Endif
  If TISCOG(6)=1 
    Wrseq ESPACE+"mkstat=0 : Gosub "+TISACT(6)+JKZMSK+" From "+JKW1,
    Wrseq " : If mkstat : TISMKSTAT=mkstat : Return : Endif" 
  Endif
Endif

# - L32
If TW1(7)<>0
  Wrseq ESPACE+"If IMPMOD"
  ESPACE += "  "
Endif

# - L33
If TW1(7)<>0
  If TISCOG(7)=0 
    Wrseq ESPACE+"mkstat=0 : Call "+TISACT(7)+JKZMSK+"("+JKVMAN+") From "+JKW1,
    Wrseq " : If mkstat : TISMKSTAT=mkstat : Return : Endif" 
  Endif
  If TISCOG(7)=1 
    Wrseq ESPACE+"mkstat=0 : Gosub "+TISACT(7)+JKZMSK+" From "+JKW1,
    Wrseq " : If mkstat : TISMKSTAT=mkstat : Return : Endif" 
  Endif
Endif

# - L35
If TW1(7)<>0
  If ESPACE<>"" : ESPACE=left$(ESPACE,(len(ESPACE)-2)) : Endif
  Wrseq ESPACE+"Endif" 
Endif

# - L36
If ESPACE<>"" : ESPACE=left$(ESPACE,(len(ESPACE)-2)) : Endif
Wrseq ESPACE+"Endif" 

# - L37
Wrseq ESPACE+JKZMSK2+"="+JKVMAN

# - L39
If TW1(2)<>0 | TW1(3)<>0 | TW1(4)<>0
  Raz ESPACE
  Wrseq "Endif"
Endif

Return

#------------------------------------------------------------------------
#  pour generer le debut de la section SAIMSK ou SAI_NBLIG 
#------------------------------------------------------------------------
$SMIS_DEB
IDSM=0 : IFSM=1  
Wrseq " "
Wrseq "#------------------------------------------------------------------------" 
If JKBTAB<>""
  Wrseq "$"+vireblc(TABM(IJ2),2)+"_"+JKBTAB
Else
  Wrseq "$"+vireblc(TABF(IJ2),2)+"_SAIMSK"
Endif 
Wrseq "Local Char    IMPZCHA (250) : # type = 1 et >10 "
Wrseq "Local Integer IMPZINT       : # type = 2, 4 "
Wrseq "Local Date    IMPZDAT       : # type = 3 "
Wrseq "Local Decimal IMPZDEC       : # type = 5, 6, 7, 9 "
Wrseq "Local Char    MSK_ABR  (5)  : # abreviation du masque"
Wrseq "Local Char    MSK_ZONE (20) : # nom de la zone masque"
#--
Wrseq " "
Wrseq "Raz TISMKSTAT" 

Return

#------------------------------------------------------------------------
#  pour generer la fin de la section SAIMSK ou SAI_NBLIG 
#------------------------------------------------------------------------
$SMIS_FIN
If IFSM=1
  Raz IFSM

  If IFBTAB=1
    Gosub SMIS_FBTAB     : # generer les actions debut de variable bas tableau 
  Endif 

  Wrseq " "
  Wrseq "# --- chargement des zones non saisissables" 
  Wrseq "Gosub "+TISABF(IJ1)+"_ZON_NSAI"
  If TISFBTAB(IJ1)<>""
    For IJ3=IJ1+1 To dim(TISABF)-1
      If TISABF(IJ3)="" : Break : Endif
      If TISMSKLG(IJ3)=TISMSKLG(IJ1) & TISFBTAB(IJ3)=TISFBTAB(IJ1)
        Wrseq "Gosub "+TISABF(IJ3)+"_ZON_NSAI"
      Endif 
    Next IJ3
  Endif
  Wrseq " "

  Wrseq "# --- controle des menus locaux"
  Wrseq "Gosub "+TISABF(IJ1)+"_CTL_MLOC"
  If TISFBTAB(IJ1)<>""
    For IJ3=IJ1+1 To dim(TISABF)-1
      If TISABF(IJ3)="" : Break : Endif
      If TISMSKLG(IJ3)=TISMSKLG(IJ1) & TISFBTAB(IJ3)=TISFBTAB(IJ1)
        Wrseq "Gosub "+TISABF(IJ3)+"_CTL_MLOC"
      Endif 
    Next IJ3
  Endif
  Wrseq " "

  Wrseq "# --- transfert des masques complementaires"
  Wrseq "Gosub "+TISABF(IJ1)+"_MSK_CPLT"
  If TISFBTAB(IJ1)<>""
    For IJ3=IJ1+1 To dim(TISABF)-1
      If TISABF(IJ3)="" : Break : Endif
      If TISMSKLG(IJ3)=TISMSKLG(IJ1) & TISFBTAB(IJ3)=TISFBTAB(IJ1)
        Wrseq "Gosub "+TISABF(IJ3)+"_MSK_CPLT"
      Endif 
    Next IJ3
  Endif
  Wrseq " "

  Wrseq "mkstat=0"
  Wrseq " "
  Wrseq "Return"

Endif
Return

#------------------------------------------------------------------------
#  pour generer les actions debut variable bas tableau  
#------------------------------------------------------------------------
$SMIS_DBTAB
IDBTAB=0 : IFBTAB=1
Raz TW1, JKM1

If TAMZ_A (IBTAB)<>""
  JKM1=TAMZ_A(IBTAB)
  While JKM1<>""
    TW1(val(left$(JKM1,2)))=val(left$(JKM1,2)) : JKM1=right$(JKM1,3)
  Wend 
   Wrseq " "
   Wrseq "# --- "+TAMZ(IBTAB)    
  If TW1(5)<>0 | TW1(13)<>0
    IJ3=find(vireblc(TABM(IBTAB),2),TISABM)
    If IJ3
      JKW1="="+TISW1(IJ3-1)
    Endif
# - 
    Wrseq "If varmode("+JKBTAB1+",0)=0"
    ESPACE += "  "
# - 
    If TW1(5)<>0
      Wrseq ESPACE+"mkstat=0 : Call "+TISACT(5)+JKBTAB+" From "+JKW1,
      Wrseq " : If mkstat : Return : Endif" 
    Endif
# - 
    If TW1(13)<>0
      Wrseq ESPACE+"Call "+TISACT(13)+JKBTAB+" From "+JKW1
    Endif
# - 
    Wrseq "Endif"
      
  Endif
Endif

Return

#------------------------------------------------------------------------
#  pour generer les actions fin variable bas tableau  
#------------------------------------------------------------------------
$SMIS_FBTAB
IFBTAB=0
Raz TW1, JKM1

If TAMZ_A (IBTAB)<>""
  JKM1=TAMZ_A(IBTAB)
  While JKM1<>""
    TW1(val(left$(JKM1,2)))=val(left$(JKM1,2)) : JKM1=right$(JKM1,3)
  Wend 

  Wrseq " "
  Wrseq "# --- "+TAMZ(IBTAB)    
  If TW1(14)<>0
    IJ3=find(vireblc(TABM(IBTAB),2),TISABM)
    If IJ3
      JKW1="="+TISW1(IJ3-1)
    Endif
# - 
    Wrseq "If varmode("+JKBTAB1+",0)=0"
    ESPACE += "  "
# - 
    If TW1(14)<>0
      Wrseq ESPACE+"mkstat=0 : status=71 : Call "+TISACT(14)+JKBTAB+" From "+JKW1
    Endif
# - 
    Wrseq "Endif"
   
  Endif
Endif

Return

#########################################################################

$RAZCRE_IS
Local Integer II1, II2, II3
Local Integer    IFLIG (10)           : # Flag fichier ligne (1=fichier ligne)

For II1=0 To dim(TISFIC)-1
  If TISFIC(II1)="" : Break : Endif
  Wrseq " "
  Wrseq "#------------------------------------------------------------------------" 
  Wrseq "# Initialisation des menus locaux"
  Wrseq "$"+TISABF(II1)+"_RAZCRE"
  If TISFBTAB(II1)<>""
    Wrseq "indice=nolign-1" 
  Else
    Wrseq "Local Integer IS1" 
  Endif 
  For II2=0 To dim(TRANG)-1
    If TABF(II2)=TISABF(II1) 
      Read [AMZ]CODE=TABM(II2);TAMZ(II2)
      If !fstat & find([F:AMZ]CODTYP,"M","MM")       : # zone masque type menu local
        If TISFBTAB(II1)<>""                         : # si table de lignes
          Wrseq "If dim([M:"+TABM(II2)+"]"+[F:AMZ]CODZON+") >= nolign : ",
          Wrseq "[M:"+TABM(II2)+"]"+[F:AMZ]CODZON+"(nolign-1)=1 : Endif" 
        Else                                         : # si table entête (ou sans liens avec lignes)
          If [F:AMZ]DIME=1
            Wrseq "[M:"+TABM(II2)+"]"+[F:AMZ]CODZON+"=1" 
          Else
            Wrseq "For IS1=0 to dim([M:"+TABM(II2)+"]"+[F:AMZ]CODZON+")-1" 
            Wrseq "  [M:"+TABM(II2)+"]"+[F:AMZ]CODZON+"(IS1)=1" 
            Wrseq "Next IS1" 
          Endif 
        Endif
      Endif    
    Endif     
  Next II2
  Wrseq "Return"
Next II1

Return


#########################################################################

$MSK_CPLT_IS
Local Integer II1, II2, II3
#        JKM1 : Abreviation du masque origine
#        JKM2 : Champ       du masque origine
#        JKM3 : (nolign-1)  si masque origine est celui des lignes
#        JKM4 : Abreviation du masque complementaire
#        JKM5 : Champ       du masque compplementaire

For II1=0 To dim(TISFIC)-1
  If TISFIC(II1)="" : Break : Endif
  Wrseq " "
  Wrseq "#------------------------------------------------------------------------" 
  Wrseq "# Transfert des donnees saisies dans masques complementaires"
  Wrseq "$"+TISABF(II1)+"_MSK_CPLT"
  For II2=0 To dim(TRANG)-1
    If TABF(II2)=TISABF(II1) & TABM_O(II2)<>"" & TATZ_M(II2) 
      JKM1=TABM_O(II2) : JKM2=TAMZ(II2) : Raz JKM3 : JKM4=TABM(II2) : JKM5=TAMZ(II2)         
      If TISFBTAB(II1)<>"" : JKM3="(nolign-1)" : Endif   : # si table de lignes   
      For II3=0 To dim(TEABF)-1
        If TEABF(II3)<>"" 
          If TEABF(II3)=TABF(II2) & TEATZ(II3)=TATZ(II2) & TEABMO(II3)<>""
            JKM1=TEABMO(II3) : JKM2=TEAMZO(II3) : JKM4=TEABM(II3) : JKM5=TEAMZ(II3)
          Endif
        Endif
      Next II3 
      If TISFBTAB(II1)<>""
        Wrseq "If dim([M:"+JKM1+"]"+JKM2+")>= nolign : ",
      Else
        Wrseq "If dim([M:"+JKM1+"]"+JKM2+")>0 : ",
      Endif
      Wrseq "[M:"+JKM1+"]"+JKM2+JKM3+"=[M:"+JKM4+"]"+JKM5+" : ",
      Wrseq "Endif"
    Endif     
  Next II2
  Wrseq "Return"
Next II1

Return

#########################################################################

$ZON_NSAI_IS
Local Integer II1, II2, II3, II4
#        JKM1 : Abreviation du masque 
#        JKM2 : Champ       du masque 
#        JKM3 : Indice      (nolign-1)  si masque est celui des lignes
#                           (indice)    si autre masque 

For II1=0 To dim(TISFIC)-1
  If TISFIC(II1)="" : Break : Endif
  Wrseq " "
  Wrseq "#------------------------------------------------------------------------" 
  Wrseq "# Chargement des donnees du modele non saisissables" 
  Wrseq "$"+TISABF(II1)+"_ZON_NSAI"
  For II2=0 To dim(TRANG)-1
#                si donnee dans le modele et seulement affichée ou invisible
    If TABF(II2)=TISABF(II1) & TATZ_M(II2) & TAMZ_S(II2)>1
      JKM1=TABM(II2) : JKM2=TAMZ(II2) : Raz JKM3       

      If TISFBTAB(II1)<>""          : # si table de lignes geree en tableau 
        JKM3="(nolign-1)"
        Wrseq "If dim([M:"+JKM1+"]"+JKM2+")>= nolign : ",
        Wrseq "[M:"+JKM1+"]"+JKM2+JKM3+"=[F:"+TABF(II2)+"]"+TATZ(II2)+" : ",
        Wrseq "Endif"
      Else                          : # si autre table
        If evalue ("dim([F:"+TABF(II2)+"]"+TATZ(II2)+")") =1     : # zone non dimensionnée dans la table
          Wrseq "If dim([M:"+JKM1+"]"+JKM2+")>0 : ",
          Wrseq "[M:"+JKM1+"]"+JKM2+JKM3+"=[F:"+TABF(II2)+"]"+TATZ(II2)+" : ",
          Wrseq "Endif"
        Elsif evalue ("dim([F:"+TABF(II2)+"]"+TATZ(II2)+")") >1  : # zone dimensionnée dans la table
          For II3=0 To evalue("dim([F:"+TABF(II2)+"]"+TATZ(II2)+")")-1
            Call TST_CHAMP (TABF(II2),TATZ(II2)+"("+num$(II3)+")",II4) From SUBIMPOBJ
            If II4
              JKM3="("+num$(II3)+")"
              Wrseq "If dim([M:"+JKM1+"]"+JKM2+")>"+num$(II3)+" : ",
              Wrseq "[M:"+JKM1+"]"+JKM2+JKM3+"=[F:"+TABF(II2)+"]"+TATZ(II2)+JKM3+" : ",
              Wrseq "Endif"
            Endif 
          Next II3
        Endif
      Endif
  
    Endif     
  Next II2
  Wrseq "Return"
Next II1

Return

#########################################################################

$CTL_MLOC_IS
Local Integer II1, II2, II3
Local Integer    IFLIG (10)           : # Flag fichier ligne (1=fichier ligne)

For II1=0 To dim(TISFIC)-1
  If TISFIC(II1)="" : Break : Endif
  Wrseq " "
  Wrseq "#------------------------------------------------------------------------" 
  Wrseq "# Controle si menus locaux > 0"
  Wrseq "$"+TISABF(II1)+"_CTL_MLOC"
  If TISFBTAB(II1)<>"" 
    Wrseq "indice=nolign-1" 
  Else
    Wrseq "Local Integer IS1" 
  Endif 
  For II2=0 To dim(TRANG)-1
    If TABF(II2)=TISABF(II1) 
      Read [AMZ]CODE=TABM(II2);TAMZ(II2)
      If !fstat & find([F:AMZ]CODTYP,"M","MM")       : # zone masque type menu local
        If TISFBTAB(II1)<>""                         : # si table de lignes   
          Wrseq "If dim([M:"+TABM(II2)+"]"+[F:AMZ]CODZON+") >= nolign & ",
          Wrseq "[M:"+TABM(II2)+"]"+[F:AMZ]CODZON+"(nolign-1)<1 : ", 
          Wrseq "[M:"+TABM(II2)+"]"+[F:AMZ]CODZON+"(nolign-1)=1 : Endif" 
        Else                                         : # si table entête (ou sans liens avec lignes)
          If [F:AMZ]DIME=1
            Wrseq "If [M:"+TABM(II2)+"]"+[F:AMZ]CODZON+"<1 : ", 
            Wrseq "[M:"+TABM(II2)+"]"+[F:AMZ]CODZON+"=1 : Endif" 
          Else
            Wrseq "For IS1=0 to dim([M:"+TABM(II2)+"]"+[F:AMZ]CODZON+")-1" 
            Wrseq "  If [M:"+TABM(II2)+"]"+[F:AMZ]CODZON+"(IS1)<1 : ", 
            Wrseq "  [M:"+TABM(II2)+"]"+[F:AMZ]CODZON+"(IS1)=1 : Endif" 
            Wrseq "Next IS1" 
          Endif 
        Endif
      Endif    
    Endif     
  Next II2
  Wrseq "Return"
Next II1

Return

#########################################################################
# Génération du traitement de recherche du no de ligne
#########################################################################
$TRLD_IS
Local Integer II1, II2, II3
Local Integer IIBRK                  : # ind. d'arrêt du traitement des clés 
Local Integer IIABS                  : # ind. zone absente de la table interne ou du modèle
Local Char    RLDCLE  (100)
Local Char    RLDZON  (20) (0..5)
Local Integer RLDZONR      (0..5)

Local Char    TWBTAB  (15)              : # nom de la var. bas tableau  ex: [M:SOH4]NBLIG
Local Char    TWABF   (5)  (0..5)       : # abreviation table               ex: SOQ                 
Local Char    TWATZ   (15) (0..5)       : # champ de la table               ex: SHIDAT   
Local Char    TWABM   (5)  (0..5)       : # abreviation du masque           ex: SOH4 
Local Char    TWAMZ   (15) (0..5)       : # zone du masque                  ex: DSHIDAT  
Local Char    TWNUL   (10) (0..5)       : # constante de comparaison à valeur nulle

Local Char    ESPACE (20)               : # zone de mise en page des instructions

#--- recherche des clés à générer dans le traitement 
For II1=0 To dim(TRLDCLE)-1
  If TRLDCLE(II1)="" : Break : Endif
  If IIBRK=1                            : # une cle précédente du modèle contient                              
    Raz TRLDCLE(II1)                    : #   l'indicateur d'arrêt recherche
  Else
    RLDCLE=TRLDCLE(II1) : Gosub TRLD_IS1
    If IIABS                               : # cle absente du paramétrage 
      Raz TRLDCLE(II1)                   
    Else                                   : # cle presente dans le parametrage
      If TRLDBRK(II1)=1 : IIBRK=1 : Endif  : # si cle de recherche sans homonyme (no ligne, etc..) 
    Endif                                    
  Endif
Next II1

#--- génération
Wrseq " "
Wrseq "#------------------------------------------------------------------------" 
Wrseq "$RECHERCHE_LIG"
Wrseq "Local Integer NOL"

For II1=0 To dim(TRLDCLE)-1
  If TRLDCLE(II1)<>""
    Raz TWBTAB, TWABF, TWATZ, TWABM, TWAMZ, TWNUL, ESPACE        
    RLDCLE=TRLDCLE(II1) : Gosub TRLD_IS1

    For II2=0 To dim(RLDZON)-1
      If RLDZON(II2)="" | RLDZONR(II2)=0 : Break : Endif
      If II2=0 : TWBTAB="[M:"+TABM(RLDZONR(II2)-1)+"]"+TAMZ_B(RLDZONR(II2)-1) : Endif
      TWABF(II2)=TABF(RLDZONR(II2)-1)
      TWATZ(II2)=TATZ(RLDZONR(II2)-1)
      TWABM(II2)=TABM(RLDZONR(II2)-1)
      TWAMZ(II2)=TAMZ(RLDZONR(II2)-1)
      II3=evalue("Type(["+TWABF(II2)+"]"+TWATZ(II2)+")")
      Case II3
        When 1,2,4,5,6,7,9  : TWNUL(II2)="0"
        When 3              : TWNUL(II2)="[0/0/0]"
        When Default        : TWNUL(II2)="''" 
      Endcase
    Next II2
     
    For II2=0 To dim(TWABF)-1
      If II2=0         : Wrseq "If nolign=0 ", : Endif
      If TWABF(II2)="" : Wrseq "" : Break   : Endif
      Wrseq " & [F:"+TWABF(II2)+"]"+TWATZ(II2)+"<>"+TWNUL(II2),      
    Next II2   
    Wrseq "  For NOL=0 To "+TWBTAB+"-1"
    ESPACE="  "

    For II2=0 To dim(TWABF)-1
      If TWABF(II2)="" : Break : Endif
      ESPACE += "  "        
      Wrseq ESPACE+"If [F:"+TWABF(II2)+"]"+TWATZ(II2)+"=[M:"+TWABM(II2)+"]"+TWAMZ(II2)+"(NOL)"
    Next II2

    ESPACE += "  "
    Wrseq ESPACE+"nolign=NOL+1 : Break"
    If ESPACE<>"" : ESPACE=left$(ESPACE,(len(ESPACE)-2)) : Endif

    For II2=0 To dim(TWABF)-1
      If TWABF(II2)="" : Break : Endif
      Wrseq ESPACE+"Endif"
      If ESPACE<>"" : ESPACE=left$(ESPACE,(len(ESPACE)-2)) : Endif
    Next II2

    Wrseq "  Next NOL"
    Wrseq "Endif"
  Endif
Next II1

Wrseq "Return"

Return

#--- eclatement zones de la cle + recherche si presence dans modèle------
$TRLD_IS1
Raz II2, IIABS, RLDZON 

While RLDCLE<>""
  If !instr(1,RLDCLE,"/") : Break : Endif
  II3=instr(1,RLDCLE,"+")
  If II3
    RLDZON(II2)=left$(RLDCLE,II3-1) : RLDCLE=right$(RLDCLE,II3+1)
  Else 
    RLDZON(II2)=RLDCLE : Raz RLDCLE : Break
  Endif
  II2 +=1     
Wend

For II2=0 To dim(RLDZON)-1
  If RLDZON(II2)="" : Break : Endif
  II3=find(RLDZON(II2),TABF_Z)       : # recherche de la zone dans la table interne
  If II3 & TATZ_M(II3-1)=1            
    RLDZONR(II2)=II3                 : # zone dans le modèle, stockage du rang dans table interne 
  Else 
    IIABS=1                          : # la zone est inexistante ou absente du modèle
  Endif   
Next II2 

Return

#########################################################################
# Fermeture des tables utilisees pour la generation du traitement
#########################################################################
CLEAN_IS
# --- fermeture tables
If C_AMK : Close Local File [AMK] : Raz C_AMK : Endif
If C_AMZ : Close Local File [AMZ] : Raz C_AMZ : Endif
If C_AMA : Close Local File [AMA] : Raz C_AMA : Endif
If C_ATY : Close Local File [ATY] : Raz C_ATY : Endif
If C_ACV : Close Local File [ACV] : Raz C_ACV : Endif
If C_ATB : Close Local File [ATB] : Raz C_ATB : Endif
If C_ATZ : Close Local File [ATZ] : Raz C_ATZ : Endif
If C_AOB : Close Local File [AOB] : Raz C_AOB : Endif
#--- suppression tableaux
Kill TRANG, TABF, TATZ, TATZ_M, TABF_Z
Kill TABM_R, TABM, TAMZ, TABM_Z
Kill TAMZ_T, TAMZ_R, TAMZ_S, TAMZ_D, TAMZ_B, TAMZ_A, TABM_O
Kill TEABF, TEATZ, TEABM, TEAMZ
Kill TRLDCLE, TRLDBRK 
Return

#########################################################################
# Permet de generer un fichier de controle du garnissage des tableaux
# en activant le Gosub VERIF_IS
# a consulter sous /home1/adonix/GX3APP/TXT/ZJL.zjl
#########################################################################
VERIF_IS
Local Char LIGNE (80)
Local Char SEPARATEUR (1) : SEPARATEUR="|"
Openo filpath("TXT","ZJL","zjl",0),0 Using [FWRI]

Wrseq " " Using [FWRI]
Wrseq "            Les Actions a gerer dans l'Import" Using [FWRI]
Wrseq "   2 - Avant-zone    AVZ_        AV- " Using [FWRI]
Wrseq "   3 - Init          D_              " Using [FWRI]
Wrseq "   4 - Avant_saisie  AS_             " Using [FWRI]
Wrseq "   5 - Controle      C_              " Using [FWRI]
Wrseq "   6 - Apres-zone    AP_             " Using [FWRI]
Wrseq "   7 - Apres-modif   AMM_        AM_ " Using [FWRI]
Wrseq "  13 - Avant-ligne   AVANT_          " Using [FWRI]
Wrseq "  14 - Apres-ligne   APRES_          " Using [FWRI]  

Wrseq " " Using [FWRI]
Wrseq "          Legende Tableaux" Using [FWRI]         
Wrseq " TRANG  : Rang attribue à la constitution des tableaux"           Using [FWRI]    
Wrseq " TABF   : Abbreviation de la table (fichier)"                     Using [FWRI]
Wrseq " TATZ   : Zone de la table"                                       Using [FWRI] 
Wrseq " TATZ_M : Zone table presente dans modele (0=Non/1=Oui)"          Using [FWRI]
Wrseq " TABM_R : No ordre du masque en saisie"                           Using [FWRI]
Wrseq " TABM   : No ordre saisie + Abbreviation du masque"               Using [FWRI]  
Wrseq " TAMZ   : Zone masque"                                            Using [FWRI]
Wrseq " TAMZ_T : Type de zone masque champs saisissables (inst. type)"   Using [FWRI]   
Wrseq " TAMZ_S : Code saisissable (1=Saisi/2=Affiche/3=Invisible)"       Using [FWRI]
Wrseq " TAMZ_D : dimension du champ"                                     Using [FWRI]
Wrseq " TAMZ_R : No ordre du champ dans le masque"                       Using [FWRI]
Wrseq " TAMZ_B : Variable bas tableau"                                   Using [FWRI]              
Wrseq " TAMZ_A : Actions du champ (voir tableau ci-dessus)"              Using [FWRI]   
Wrseq " " Using [FWRI]

LIGNE="TRANG      TATZ              TABM                  TAMZ_S TAMZ_R         TAMZ_A"
Wrseq LIGNE Using [FWRI] 
LIGNE="     TABF               TATZ_M     TAMZ        TAMZ_T TAMZ_D   TAMZ_B"
Wrseq LIGNE Using [FWRI] 
For IJ3=0 To dim(TRANG)-1
 If TRANG(IJ3)<>0
  LIGNE = format$("K:4X",num$(TRANG(IJ3)))+SEPARATEUR+
&         format$("K:4X",TABF(IJ3))+SEPARATEUR+
&         format$("K:14X",TATZ(IJ3))+SEPARATEUR+
&         format$("K:1X",num$(TATZ_M(IJ3)))+SEPARATEUR+
&         format$("K:2X",num$(TABM_R(IJ3)))+
&         format$("K:4X",TABM(IJ3))+SEPARATEUR+
&         format$("K:14X",TAMZ(IJ3))+SEPARATEUR+
&         format$("K:3X",num$(TAMZ_T(IJ3)))+SEPARATEUR+ 
&         format$("K:1X",num$(TAMZ_S(IJ3)))+SEPARATEUR+
&         format$("K:3X",num$(TAMZ_D(IJ3)))+SEPARATEUR+
&         format$("K:3X",num$(TAMZ_R(IJ3)))+SEPARATEUR+
&         format$("K:8X",TAMZ_B(IJ3))+SEPARATEUR+
&         format$("K:12X",TAMZ_A(IJ3))
  Wrseq LIGNE Using [FWRI] 

 Endif
Next IJ3

Openo Using [FWRI]

Return

#########################################################################
