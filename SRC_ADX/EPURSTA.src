#<AdxTL>@(#)8.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE_EPURE"  : Gosub OUVRE
 When "VERF_EPURE"   : Gosub VERF
 When "FERME_EPURE"  : Gosub FERME
Endcase
Return

$OUVRE
If clalev([F:PS2])=0 : Local File PARSTA2 [PS2] : Endif
If clalev([F:SAP])=0 : Local File STATPRV [SAP] : Endif
Local Char    CODMAJ(10), ABFIC(4), LIBEL(80)
Local Integer RAZSTA
Local Date    DATRAZ
If [F:AEP]DAT=""
 Call ECR_TRACE("DAT"-mess(10,123,1),1) From GESECRAN : # Zone obligatoire
 OK = 0
Endif
If [F:AEP]CPY<>""
 Call ECR_TRACE("CPY"-mess(52,101,1),1) From GESECRAN : # Ce champ doit être vide
 OK = 0
Endif
If [F:AEP]FCY<>""    
 Call ECR_TRACE("FCY"-mess(52,101,1),1) From GESECRAN
 OK = 0
Endif
If !OK
 Call ECR_TRACE(OBJEPUR+":"-mess(86,105,1),1) From GESECRAN : # Paramétrage à revoir
 RAZSTA = 0
Else
 RAZSTA = 1
Endif
Return

$VERF
ABFIC = "WWW"
Gosub VERIF
Return

$VERIF
If evalue("[F:"+ABFIC+"]COD")<>CODMAJ
 Filter [PS2] Where UPDCOD=evalue("[F:"+ABFIC+"]COD")
 Read [PS2]PS20 First : # on prend le premier arbitrairement
 Filter [PS2]
 If !fstat
  CODMAJ = evalue("[F:"+ABFIC+"]COD")
  DATRAZ = eomonth(addmonth(datesyst,-[F:PS2]TIM-1))
  LIBEL = [F:PS2]DES    #CHECK IGNORE_LINE
  If ABFIC = "SAP" : LIBEL -= "("+mess(196,124,1)+")" : Endif
  Call ECR_TRACE(CODMAJ+":"-LIBEL-"DAT<"-format$(GFMD,DATRAZ),-1) From GESECRAN
 Else
  Return
 Endif
Endif
If evalue("[F:"+ABFIC+"]"+[F:AEP]DAT)>=DATRAZ
 OK = 0
Endif
If OK
 Case [F:PS2]UPDLEV  
  When 2 : # Société
   If [M]TOUSOC<>2 & evalue("[F:"+ABFIC+"]CPY")<>[M]SOCIETE
    OK = 0
   Endif
  When 3 : # Site
   If [M]TOUSOC<>2 & evalue("[F:"+ABFIC+"]CPY")<>[M]SOCIETE
    OK = 0
   Endif
   If OK & [M]TOUSIT<>2 & evalue("[F:"+ABFIC+"]FCY")<>[M]SITE
    OK = 0
   Endif
 Endcase
Endif
Return

$FERME
If RAZSTA
 FILTRE = [F:AEP]DAT+"<["+format$(GFMD,DATEPUR)+"]"
 If [F:AEP]FORMULE<>""
  FILTRE -= "&"-"("+[F:AEP]FORMULE+")"
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif
Close Local File [PS2], [SAP]
Return

$TR1
GOK = 1
Trbegin [SAP]
 For [SAP] Where evalue(FILTRE)
  OK = 1
  ABFIC = "SAP"
  Gosub VERIF
  If OK
   GCLE = [F:SAP]COD-[F:SAP]CPY-[F:SAP]FCY-[F:SAP]DAT-[F:SAP]CRI1-[F:SAP]CRI2-[F:SAP]CRI3
   GCLE = GCLE
   If !GTEST : Delete [SAP] : Endif
   If fstat=1
    Call ECR_TRACE(GCLE-":"-mess(10,100,1),1) From GESECRAN
   Else
    NBEPU += 1
    Call ECR_TRACE(GCLE,0) From GESECRAN
   Endif
  Endif
 Next
Commit
Return
