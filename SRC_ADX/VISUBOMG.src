#<AdxTL>@(#)4.0.0.0 $Revision$
# Issue 117643 - 2016-08-18 by JUSYN : formerly used special character % (as well as any other special character)
# Action de visualisation nomenclatures et gammes - Mode graphique
# Action VISUBOMG   : Visualisation nomenclature multiniveaux
############################################################
$ACTION
  Case GACTION
    When "VISUBOMG"
    Case ACTION
      When "OUVRE"        : Gosub OUVRE_BOMG
      When "DEBUT"        : Gosub DEBUT_BOMG
      When "FIN"          : Gosub FIN_BOMG
      When "AVANT_BOUTON" : Gosub AVANTBOUT_BOMG
      When "SETBOUT"      : Gosub SETBOUT_BOMG
      When "BOUTON"       : Gosub BOUTON_BOMG
      When "FIR"          : Gosub PREMIER_BOMG
      When "LAS"          : Gosub DERNIER_BOMG
      When "AVANT_PRE"    : Gosub AVANT_PREVIOUS_BOMG
      When "PRE"          : Gosub PREVIOUS_BOMG
      When "AVANT_SUI"    : Gosub AVANT_NEXT_BOMG
      When "SUI"          : Gosub NEXT_BOMG
      When "APRES_MODIF"  : Gosub APRES_MODIF_BOMG
    Endcase
  Endcase
Return

############################################################
# Visualisation nomenclatures
############################################################
$OUVRE_BOMG
Local Integer IITM, IITF,IITS, IBOH, IBOD, ITBO, ICBB, ITXC
If clalev([F:ITF])  = 0 : Local File ITMFACILIT    [ITF]   : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER     [ITM]   : Endif
If clalev([F:BOH3]) = 0 : Local File BOM           [BOH3]  : Endif
If clalev([F:ITM1]) = 0 : Local File ITMMASTER     [ITM1]  : IITM = 1 : Endif
If clalev([F:ITF1]) = 0 : Local File ITMFACILIT    [ITF1]  : IITF = 1 : Endif
If clalev([F:ITS1]) = 0 : Local File ITMSALES      [ITS1]  : IITS = 1 : Endif
If clalev([F:BOH1]) = 0 : Local File BOM           [BOH1]  : IBOH = 1 : Endif
If clalev([F:BOD1]) = 0 : Local File BOMD          [BOD1]  : IBOD = 1 : Endif
If clalev([F:TBO1]) = 0 : Local File TABBOMALT     [TBO1]  : ITBO = 1 : Endif
If clalev([F:CBB1]) = 0 : Local File CBLOB         [CBB1]  : ICBB = 1 : Endif
If clalev([F:TXC1]) = 0 : Local File TEXCLOB       [TXC1]  : ITXC = 1 : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY      [FCY]   : Endif : # FQ58840 - 15/10/09 MABON
# Issue 109708 - 2015-08-21 by JUSYN : versioning
If clalev([F:EVL])=0 : Local File ECCVAL [EVL] : Endif

Local Integer OK, L, WLEVEL, WLIGNE, WPLIGNE
Local Char     SAVFONCTION(GLONAFC)
Global Char    WICO_PROD(30),WICO_SSPROD(30),WICO_SCP(30),WICO_SCS(30),WICO_TXT(30)
Global Char    WICO_END(30),WICO_SCOWST(30),WICO_MAT(30),WICO_GHOST(30),WICO_VAL(30)

Gosub LISTE_ICONES

SAVFONCTION = GFONCTION
GFONCTION = "VISUBOMG"
Call AUTORIS From EXEFNC
If GNBAUZ=0
   GERR=1 : GMESSAGE = GFONCTION-":"-mess(1,123,1) : # Fonction non autorisée
   FIN=1 : Return
Endif
# appel en tunnel avec un site précis
If [L]PARAM(1)<>"" & [L]PARAM(4)<>"" & GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE & !find([L]PARAM(4),GUSRFCY(1..GNBAUZ))
   GERR=1 : GMESSAGE = mess(175,123,1)-[L]PARAM(4) : # Fonction non autorisée pour ce site
   FIN=1 : Return
Endif
Return

############################################################
$FIN_BOMG
If IITM = 1
  IITM = 0
  Close Local File [ITM1]
Endif
If IITF = 1
  IITF = 0
  Close Local File [ITF1]
Endif
If IITS = 1
  IITS = 0
  Close Local File [ITS1]
Endif
If IBOH = 1
  Filter [F:BOH1]
  IBOH = 0
  Close Local File [BOH1]
Endif
If IBOD = 1
  IBOD = 0
  Close Local File [BOD1]
Endif
If ITBO = 1
  ITBO = 0
  Close Local File [TBO1]
Endif
If ICBB = 1
  ICBB = 0
  Close Local File [CBB1]
Endif
If ITXC = 1
  ITXC = 0
  Close Local File [TXC1]
Endif

Call IMPSCR From ATRTX3
If dim([V]WICO_PROD) > 0    : Kill [V]WICO_PROD    : Endif
If dim([V]WICO_SSPROD) > 0  : Kill [V]WICO_SSPROD  : Endif
If dim([V]WICO_SCP) > 0     : Kill [V]WICO_SCP     : Endif
If dim([V]WICO_SCS) > 0     : Kill [V]WICO_SCS     : Endif
If dim([V]WICO_END) > 0     : Kill [V]WICO_END     : Endif
If dim([V]G_MEM_ITM) > 0    : Kill [V]G_MEM_ITM    : Endif
If dim([V]G_MEM_FCY) > 0    : Kill [V]G_MEM_FCY    : Endif
If dim([V]G_MEM_BOMALT) > 0 : Kill [V]G_MEM_BOMALT : Endif
If dim([V]WICO_SCOWST) > 0  : Kill [V]WICO_SCOWST  : Endif
If dim([V]WICO_MAT) > 0     : Kill [V]WICO_MAT     : Endif
If dim([V]WICO_GHOST) > 0   : Kill [V]WICO_GHOST   : Endif
If dim([V]WICO_VAL) > 0     : Kill [V]WICO_VAL     : Endif
If dim([V]WICO_TXT) > 0     : Kill [V]WICO_TXT     : Endif

If SAVFONCTION<>GFONCTION
   GFONCTION=SAVFONCTION
   Call AUTORIS From EXEFNC
Endif
Return

$SETBOUT_BOMG
############################################################
# GSPE1 = premier niveau      GSPE4 = Gamme                #
# GSPE2 = multi niveau        GSPE5 = Recette              #
# GSPE3 = impression                                       #
############################################################
If [M:VBOG]BOMFLG = 0
  ETABOU(GSPE1) = 0
  ETABOU(GSPE2) = 1
Else
  ETABOU(GSPE1) = 1
  ETABOU(GSPE2) = 0
Endif
If [M:VBOG]PARITMREF = "" | [M:VBOG]BOMALT = 0
  ETABOU(GSPE1) = 0
  ETABOU(GSPE2) = 0
  ETABOU(GSPE3) = 0
  ETABOU(GSPE4) = 0
  ETABOU(GSPE5) = 0
Else
  ETABOU(GSPE3) = 1
  ETABOU(GSPE4) = 1
  ETABOU(GSPE5) = 1
Endif

# le bouton gamme n'est valide que pour les nomclature de production et si on ne vient pas des gammes
If [M:VBOG]BOMALTTYP <> 2 | find("GESROU",GNAVIG(1..GPILNAV-1))
    ETABOU(GSPE4) = 0
Endif
# si l'écran des recettes est deja ouvert ou si on est en nomenclature de Sst on bloque le bouton.
If clalev([M:VBOR]) or [M]BOMALTTYP = 3
 ETABOU(GSPE5) = 0
Endif

If [M:VBOG]BOMALT = 0
  Call VIREBOUT(CHBOU,"<>") From GOBJET
Endif

Return

############################################################
$AVANTBOUT_BOMG
Local Char     ALTALP(3) : # alternative format alpha pour appel action objet
Local Integer  NBTRO
Local Char     WGAMME    : # utilisé en param de l'action objet sur fenetre
Case BOUT
  When "d" :

    If GMODU(8)=2 # Si et seulement si module GPAO actif ... FQ 75681 GA 09/2011
    #   SÉLECTIONNER LES ALT. DE GAMMES QUI ONT POUR ALT.NOMENCL ASSOCIÉE
    #   L'alternative passée en paramètre
    ## FQ 71292 GA 02/2011 revue du code MABON car Ko si on est venu en tunnel
    ### If clalev([TRO])> 0 Close File [TRO] Endif
    ### Local File TABROUALT [TRO] Where BOMALT1=[M:VBOG]BOMALT | BOMALT2=[M:VBOG]BOMALT | BOMALT3=[M:VBOG]BOMALT
        If clalev([F:TRO])=0 : Local File TABROUALT [TRO] : Endif
        For [TRO]TRO0 Where find([M:VBOG]BOMALT,BOMALT1,BOMALT2,BOMALT3)
            GROUALT (NBTRO) = [F:TRO]ROUALT
            NBTRO += 1
        Next
    Endif
    # si alternative liée à un site, recherche gamme mère
    WGAMME = [M:VBOG]PARITMREF
    #WGAMME = [M:VBOG]CPNITMREF(nolign-1)
    If clalev([F:TBO])=0 : Local File TABBOMALT [TBO] : Endif
    If [F:TBO]BOMALT <> [M:VBOG]BOMALT | [F:TBO]BOMALTTYP <> [M:VBOG]BOMALTTYP
        Read [TBO]TBO0=[M:VBOG]BOMALTTYP;[M:VBOG]BOMALT
        If fstat : Raz [F:TBO] : Endif
    Endif
    #
    If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
    If [F:ITF]ITMREF <> WGAMME
        If [F:TBO]FCY <> ""
            Read [ITF]ITF0=WGAMME;[F:TBO]FCY
            If fstat : Raz [F:ITF] : Endif
        Else
            Filter [ITF] Where ITMREF = WGAMME
            Read [ITF] First
            If fstat : Raz [F:ITF] : Endif
            Filter [ITF]
        Endif
    Endif
    If GMODU(8)=2 # Si et seulement si module GPAO actif ... FQ 75681 GA 09/2011
        ALTALP = num$([F:TRO]ROUALT)        # FQ 71292 GA 02/2011 avant ALTTAP=num$([M]BOMALT)???
        If [F:ITF]MFGROU <> ""
            WGAMME = [F:ITF]MFGROU
            ALTALP = num$([F:ITF]MFGROUALT) # FQ 71292 GA 02/2011 avant ALTTAP ???
        Endif

        # table réouverte systématiquement pour filtre !
        If [F:TBO]FCY <> ""
            Local File ROUTING [ROH] Where find(ROUALT, GROUALT)<> 0 & ITMREF=WGAMME & FCY = [F:TBO]FCY
        Else
            Local File ROUTING [ROH] Where find(ROUALT, GROUALT)<> 0 & ITMREF=WGAMME
        Endif
    Endif
  # GH 21/01/2014 bug 95091
  #When "e"  #recette
  #    GFONCTION = "VISUBOMROU"
Endcase
Return

############################################################
$DEBUT_BOMG
Raz [M:VBOG]
[M:VBOG]PARITMREF = PARAM(1)
[M:VBOG]BOMALT    = val(PARAM(2))
[M:VBOG]DATREF    = PARAM(3)    # !!! peut être 0/0/0 !!!
If PARAM(4) <> ""
   [M:VBOG]STOFCY = PARAM(4)
Endif
If val(PARAM(5))>0
   [M:VBOG]BOMALTTYP = val(PARAM(5)) : # GA 08/2007 ajout V6
   Grizo  [M:VBOG]BOMALTTYP
   # FQ 71292 ???
   #Filter[BOH3] Where BOMALTTYP = val(PARAM(5))
Else
   [M:VBOG]BOMALTTYP = 2             : # Nomenclature de production par défaut
Endif

# Issue 112780 - 2015-11-25 by CCC : add test on existence of VBOGECCMAJ
If dim([M:VBOG]VBOGECCMAJ)>0
    # Issue 109708 - 2015-08-21 by JUSYN : Versioning - Major and Minor version from Action VISUBOMG
    [M:VBOG]VBOGECCMAJ = PARAM(6)
    [M:VBOG]VBOGECCMIN = PARAM(7)
Endif

If [M:VBOG]STOFCY = ""
   Case [M:VBOG]BOMALTTYP
      When 1 :     Call FIND_GFCYDEF(5) From TRTX3 : # Site Ventes par défaut
      When 2 :     Call FIND_GFCYDEF(8) From TRTX3 : # Site GP     par défaut
      When 3 :     Call FIND_GFCYDEF(6) From TRTX3 : # Site Achats par défaut
   Endcase
   [M:VBOG]STOFCY = GFCY
Endif
If PARAM(1) <> ""
   Call AM_PARITMREF(PARAM(1)) From SUBVBOMG
Endif

## GH 20/03/2013 bug 86834
If dim([M:VBOG]LIKQTY2)>0 & dim([M:VBOG]FMTQTY2)>0
  # détermination de FMTQTY2 selon le type de donnée du champ LIKQTY de l'écran
  Local Decimal LNG

  If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
  If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif

  Read [AMZ]CODE = "VISUBOMG";"LIKQTY"
  If !fstat
    If [F:ATY]CODTYP<>[F:AMZ]CODTYP
      Read [ATY]CODTYP = [F:AMZ]CODTYP
    Endif
    LNG=[F:AMZ]LONG
  Endif
  If fstat
    Read [ATY]CODTYP = ""
    If fstat : Raz [F:ATY] : Endif
  Endif
  If [F:ATY]LNGTYP<>0 : LNG = [F:ATY]LNGTYP : Endif

  If LNG=0
    [M:VBOG]FMTQTY2 = "N:"+num$(type([M:VBOG]LIKQTY2)-10)+"F"
  Elsif int(LNG)=LNG
    [M:VBOG]FMTQTY2 = "N:"+num$(LNG)+"F"
  Else
    [M:VBOG]FMTQTY2 = "N:"+num$(LNG)+"#"
  Endif
Endif

If [M:VBOG]BOMALT <> 0 & [M:VBOG]BOMALTTYP <> 0 & [M:VBOG]PARITMREF <> "" & [M:VBOG]STOFCY<>""
  Grizo [VBOG]BOMALT,PARITMREF,STOFCY
# Issue 109708 - 2015-08-24 by JUSYN : Versioning
  If dim([M:VBOG]VBOGECCMAJ) > 0
      Grizo [M:VBOG]VBOGECCMAJ
      Grizo [M:VBOG]VBOGECCMIN
  Endif
  Gosub TRT_AFFBOM
Else
  Affzo [VBOG]
Endif
Return

############################################################
$APRES_MODIF_BOMG
#Case COUZON
#  When "STOFCY"    : [M:VBOG]STOFCY = CZ
#  When "DATREF"    : [M:VBOG]DATREF = CZ
#  When "BOMALT"    : [M:VBOG]BOMALT = val(CZ)
#  When "BOMALTTYP" : [M:VBOG]BOMALTTYP = val(CZ)
#Endcase

# Issue 109708 - 2015-07-22 by JUSYN : ECC versioning
#If COUZON="DATREF" & [M:VBOG]BOMALT <> 0 & [M:VBOG]BOMALTTYP <> 0 & [M:VBOG]PARITMREF <> "" & [M:VBOG]STOFCY<>""
#  [M:VBOG]DATREF = CZ
#  Gosub TRT_AFFBOM
#Endif

Local Integer I
Local Integer OK : OK = 0
If (COUZON="DATREF" | COUZON="VBOGECCMAJ" | COUZON="VBOGECCMIN") & [M:VBOG]BOMALT <> 0 & [M:VBOG]BOMALTTYP <> 0 & [M:VBOG]PARITMREF <> "" & [M:VBOG]STOFCY<>""
    Case COUZON
        When "DATREF"     : [M:VBOG]DATREF = CZ
        When "VBOGECCMAJ" : [M:VBOG]VBOGECCMAJ = CZ
        When "VBOGECCMIN" : [M:VBOG]VBOGECCMIN = CZ
    Endcase
    I = func ECCLIB.NBRCPN([M:VBOG]PARITMREF)
    If I = 2
        If [M:VBOG]VBOGECCMAJ <> "" & [M:VBOG]VBOGECCMIN <> ""
            OK = 1
        Endif
    Elsif I = 1
        If [M:VBOG]VBOGECCMAJ <> "" & [M:VBOG]VBOGECCMIN = ""
            OK = 1
        Endif
    Elsif I = 0
        OK = 1
    Endif

    If OK = 1 : Gosub TRT_AFFBOM
    Endif
Endif

Return

############################################################
$TRT_AFFBOM
# Lecture alternative
Read [TBO1]TBO0=[M:VBOG]BOMALTTYP;[M:VBOG]BOMALT
If fstat
  FIN = 1
  Return
Endif

Read [BOH1]BOH0=[M:VBOG]PARITMREF;[M:VBOG]BOMALT;[M:VBOG]BOMALTTYP
#lecture de l'entete pour la navigation
Read [BOH3]BOH0=[M:VBOG]PARITMREF;[M:VBOG]BOMALT;[M:VBOG]BOMALTTYP
If fstat
  GMESSAGE = mess(95,193,1)
  GERR     = 1
  FIN      = 1
  Return
Endif

[M:VBOG] = [F:BOH1]
Affzo [VBOG]5-20

# Contrôle validité entête
If [F:BOH1]BOHENDDAT = [0/0/0]
   [F:BOH1]BOHENDDAT = [31/12/2999]
Endif
If ([M:VBOG]DATREF >= [F:BOH1]BOHSTRDAT | [M:VBOG]DATREF=[0/0/0]) & [M:VBOG]DATREF <= [F:BOH1]BOHENDDAT
  Gosub DISPLAY_BOMG
Else
  Gosub DISPLAY_BOMG :  ## GH 06/03/2013 bug 87902
  If GERR=0
     GMESSAGE = mess(54,199,1)
     GERR     = 2
  Endif
Endif
[M:VBOG]BOMFLG = 0   : # Seul le 1er niveau est déplié
Return

############################################################
$DISPLAY_BOMG
## GH 06/03/2013 bug 87902
Read [ITM1]ITM0=[M:VBOG]PARITMREF
If fstat : Raz [F:ITM1] : Endif
[M:VBOG]BOMSTU  = [F:ITM1]STU : Affzo [VBOG]BOMSTU

Call LECTEXTRA([M:VBOG]BOMDES,"BOM", "BOMDESAXX", [M:VBOG]PARITMREF+"~"+num$([M:VBOG]BOMALT),num$([M:VBOG]BOMALTTYP)) From ATEXTRA
Affzo [VBOG]BOMDES

##

If ([M:VBOG]PARITMREF = "" | [M:VBOG]BOMALT = 0 | [M:VBOG]BOMALTTYP = 0 | [M:VBOG]STOFCY = "")
  Return
Endif

# Vider le XSL des composants
Effzo [VBOG]25

## GH 07/03/2013 bug 88522
If [F:TBO1]BOMALT <> [M:VBOG]BOMALT | [F:TBO1]BOMALTTYP <> [M:VBOG]BOMALTTYP
   Read [TBO1]TBO0=[M:VBOG]BOMALTTYP;[M:VBOG]BOMALT
   If fstat : Raz [F:TBO1] : Endif
Endif
If [F:TBO1]FCY<>""
   If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE & !find([F:TBO1]FCY,GUSRFCY(1..GNBAUZ))
     GERR=1 : GMESSAGE = mess(48,193,1) : # Alternative non valide sur ce site !
     Return
   Endif
   [M:VBOG]STOFCY = [F:TBO1]FCY : Affzo [VBOG]STOFCY :  Diszo [VBOG]STOFCY
Else
   Actzo [VBOG]STOFCY
Endif
##
# Issue 109708 - 2015-08-24 by JUSYN : Versioning
Gosub READECC From ECCVISUBOM

If dim(L) < 0
  Local Integer L,WLEVEL,WLIGNE,WPLIGNE
Endif
#
# génération de la liste
nolign  = 1
L       = nolign -1
WLEVEL  = 0
WLIGNE  = 0
WPLIGNE = 0
Gosub ADD_PROD
# génération de la liste
Call GEN_LISTE(L, WLEVEL, WLIGNE, WPLIGNE, [M:VBOG]STOFCY, [M:VBOG]PARITMREF, [M:VBOG]BOMALT, [M:VBOG]BOMALTTYP, [M:VBOG]DATREF)

nolign  = 1
Call AS_NBLIG From SUBVBOMG

Affzo [VBOG] # Issue 82418 GA 05/2012 Affzo déplacé
#SUIZON = "PARITMREF" : # GH 16/09/2014 bug 102435
Return

############################################################
# Gestion des boutons suivant précédent premier et dernier #
############################################################

$CHARGE_DATA
[M:VBOG] = [F:BOH3]
[M:VBOG]PARITMREF = [F:BOH3]ITMREF
Affzo [VBOG]5-20
# Contrôle validité entête
If [F:BOH3]BOHENDDAT = [0/0/0]
   [F:BOH3]BOHENDDAT = [31/12/2999]
Endif

Gosub DISPLAY_BOMG
[M:VBOG]BOMFLG = 0   : # Seul le 1er niveau est déplié
Return

$DROIT
If [F:TBO1]BOMALT <> [F:BOH3]BOMALT | [F:TBO1]BOMALTTYP <> [F:BOH3]BOMALTTYP
   Read [TBO1]TBO0=[F:BOH3]BOMALTTYP;[F:BOH3]BOMALT
   If fstat : Raz [F:TBO1] : Endif
Endif
OK = ([F:TBO1]FCY="" |  GUSRFCY(1)="\"  | GNBAUZ=GNBSITE | find([F:TBO1]FCY,GUSRFCY(1..GNBAUZ)))
Return

$PREMIER_BOMG
  Read [BOH3]BOH0 First
  If fstat > 2
    Call MESSAGE(mess(11,100,1)) From GESECRAN
    Return
  Endif
  Gosub DROIT
  If !OK : Goto NEXT_BOMG : Endif
  Gosub CHARGE_DATA
Return

$DERNIER_BOMG
  Read [BOH3]BOH0 Last
  If fstat > 2
    Call MESSAGE(mess(11,100,1)) From GESECRAN
    Return
  Endif
  Gosub DROIT
  If !OK : Goto PREVIOUS_BOMG : Endif
  Gosub CHARGE_DATA
Return

$AVANT_PREVIOUS_BOMG
  If ETABOU(GENRE) = 1
    GERR=3
    GMESSAGE=mess(60,191,1)
  Endif
Return

$PREVIOUS_BOMG
  Read [BOH3]BOH0 Prev
  If fstat > 2
    Call MESSAGE(mess(11,100,1)) From GESECRAN
    SUIZON = "PARITMREF"
    Return
  Endif
  Gosub DROIT
  If !OK : Goto PREVIOUS_BOMG : Endif
  Gosub CHARGE_DATA
Return

$AVANT_NEXT_BOMG
  If ETABOU(GENRE) = 1
    GERR=3
    GMESSAGE=mess(60,191,1)
  Endif
Return

$NEXT_BOMG
  Read [BOH3]BOH0 Next
  If fstat > 2
    Call MESSAGE(mess(11,100,1)) From GESECRAN
    SUIZON = "PARITMREF"
    Return
  Endif
  Gosub DROIT
  If !OK : Goto NEXT_BOMG : Endif
  Gosub CHARGE_DATA
Return

############################################################

#----------------------------------------------------------------------
# lecture récursive de la nomenclature ...
#----------------------------------------------------------------------
Subprog GEN_LISTE(L, LEVEL, LIGNE, PLIGNE, LFCY, LITM, LALT, LTYP, LDAT)
Variable Integer  L
Variable Integer  LEVEL
Variable Integer  LIGNE
Variable Integer  PLIGNE
Value    Char     LFCY
Value    Char     LITM
Value    Integer  LALT
Value    Integer  LTYP     : # ajout V6
Value    Date     LDAT

Local    Char     XMSG(120)
Local    Integer  WOK

Local    Date     WORIDAT
Local    Char     WORIFCY
Local    Date     WDSTDAT, REFDAT, WDATEREF
Local    Decimal  WBOMALT : WBOMALT = LALT
Local    Decimal  WALTTYP : WALTTYP = LTYP    : # ajout V6
Local    Decimal  WALTTYPR                    : # ajout V6
Local    Date     WMEMDAT
Local    Integer  WMEMPL
Local    Char     WPOHNUM
Local    Char     WBPSNUM

WMEMDAT = LDAT

# lecture
Gosub LEC_FILES

# FQ 49868 LLC 10/2008
# incrémentation niveau et changement de parent à ignorer si fantôme

#If [F:ITM]PHAFLG <> 2
    LEVEL  += 1
    PLIGNE = LIGNE
#Endif
# FQ 71292 GA 02/2011 Local File BOMD [BOD] ... devient [BODW]
# lecture liens
# FQ 63368 GA 03/2010 pb si LDAT=[0/0/0] on ne ramène pas les composants avec date de début validité
#&                   (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= LDAT)) &
#&                   (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= LDAT))
Local File BOMD [BODW] Where ITMREF = LITM & BOMALT = WBOMALT & BOMALTTYP=WALTTYP       &
&                                   (LDAT = [0/0/0] | BOMSTRDAT = [0/0/0] | BOMSTRDAT <= LDAT) &
&                                   (LDAT = [0/0/0] | BOMENDDAT = [0/0/0] | BOMENDDAT >= LDAT)

# lecture premier enregistrement
Read [BODW]BOD0 First                  # 10.02 Performances
While !fstat

    # pas de 5=texte, ni 6=valo,
    # If find([F:BODW]CPNTYP,5,6) : Goto NEXT_BOD : Endif

    # lecture article
    If [F:ITM]ITMREF <> [F:BODW]CPNITMREF
       Read [ITM]ITM0=[F:BODW]CPNITMREF
       If fstat : Raz [F:ITM] : Endif
    Endif

    If [F:ITF]ITMREF <> [F:BODW]CPNITMREF | [F:ITF]STOFCY <> LFCY
       Read [ITF]ITF0=[F:BODW]CPNITMREF;LFCY
       If fstat : Raz [F:ITF] : Endif
    Endif
    # si article fantôme descente par récursivité
    #If ([F:ITM]PHAFLG <> 2)
        Gosub ADD_LINE
    #Endif
    # FQ 49868 si on est sur un composé de type sous produit on ne déplie pas.
    If [F:BODW]CPNTYP=4 : Goto NEXT_BOD : Endif

    # V6 quel type de nomenclature production ou sous-traitance ?
    Case [F:ITF]REOCOD
      When 3  : WALTTYPR=2                  : # Production
      When 5  : WALTTYPR=3                  : # Sous-traitance
      When Default : WALTTYPR=[M:VBOG]BOMALTTYP  : # Pas de suggestion
    Endcase

    # si achat ou intersite, pas de traversée (20736)
    # FQ 49868 LLC 10/2008 pas de ligne [F:ITF] sur les fantômes, il faut inverser le test : find([F:ITF]REOCOD,2,4)
    # If [F:ITM]PHAFLG <> 2 & !find([F:ITF]REOCOD,1,3,5) : LDAT   = WMEMDAT : Goto NEXT_BOD : Endif
    GPE =  ([F:ITM]PHAFLG <> 2 & !find([F:ITF]REOCOD,1,3,5))
    # GPE can be changed to 0 for forcing BOM drill (in case suggestion = purchase per ex.)
    # GPE can be changed to 1 for cutting short BOM drill
    GPOINT = "BOMDRL" : Gosub ENTREE From EXEFNC : # Issue 121175 GH 24/04/2017 - Entry point added
    # Possibility to change WALTTYPR (according if production or subcontracting BOM exists per ex.)
    If GPE : LDAT   = WMEMDAT : Goto NEXT_BOD : Endif

    WMEMPL = PLIGNE

    Call GEN_LISTE(L, LEVEL, LIGNE, PLIGNE, LFCY, [F:BODW]CPNITMREF, WBOMALT, WALTTYPR, LDAT)

    WBOMALT = LALT
    LDAT   = WMEMDAT
    Gosub LEC_FILES
    # FQ 49868 GA 10/2008
    # décrémentation niveau et changement de parent à ignorer si fantôme
#    If [F:ITM]PHAFLG <> 2
       LEVEL -= 1
       PLIGNE = WMEMPL
#    Endif
$NEXT_BOD
    If GERR : Break : Endif
    Read [BODW]BOD0 Next                 # 10.02 Performances
    If !fstat & dim([M:VBOG]CPNITMREF) <= [M:VBOG]NBLIG
        GMESSAGE=mess(600,199,1) : GERR=1 : Break
    Endif
Wend
#Affzo [VBOG] # Issue 82418 GA 05/2012 Pb Performances
End

#----------------------------------------------------------------------
# alimentation du composé - nomenclature verticale
$ADD_PROD
[M:VBOG]LIGNE(L)     = WLIGNE
[M:VBOG]PARLIN(L)    = -1
[M:VBOG]LEV(L)       = WLEVEL
[M:VBOG]ITMREF(L)    = [M:VBOG]PARITMREF
[M:VBOG]CPNITMREF(L) = [M:VBOG]PARITMREF
[M:VBOG]GRPITMREF(L) = [M:VBOG]PARITMREF
[M:VBOG]ALTTYPR(L)   = [M:VBOG]BOMALTTYP
[M:VBOG]BOMSEQ(L)    = 0

Read [ITM]ITM0=[M:VBOG]ITMREF(L)
If fstat : Raz [F:ITM]  : Endif
Read [ITF1]ITF0=[M:VBOG]ITMREF(L);[M:VBOG]STOFCY
If fstat : Raz [F:ITF1]  : Endif
Read [BOH1]BOH0=[M:VBOG]ITMREF(L);[M:VBOG]BOMALT;[M:VBOG]BOMALTTYP
If fstat : Raz [F:BOH1]  : Endif

[M:VBOG]LIKQTY(L)    = [F:BOH1]BASQTY
[M:VBOG]STU(L)       = [F:ITM]STU
#[M:VBOG]ITMDES1(L)   = [F:ITM]ITMDES1
[M:VBOG]REOCOD(L)    = [F:ITF1]REOCOD
If dim([M:VBOG]LIBREOCOD(L))>0 & [F:ITF1]REOCOD>1
   [M:VBOG]LIBREOCOD(L)=mess([F:ITF1]REOCOD,250,1)
Endif

Gosub ADD_VNOM

L += 1
[M:VBOG]NBLIG = L

Return

#----------------------------------------------------------------------
# alimentation du tableau - nomenclature verticale
$ADD_LINE
Local Char    ITMNAME
Local Integer IND,IND1
Local Decimal LQTN, LQTNA, LQTB, LQTBA

ITMNAME =[F:BODW]CPNITMREF
# on regarde si le composée à ajouter n'existe pas deja dans le tableau
  If [F:BODW]CPNITMREF <> ""
    IND = find([F:BODW]CPNITMREF,[M]CPNITMREF(0..NBLIG))
    While IND > 0
      IND1 = find([F:BODW]CPNITMREF,[M]GRPITMREF(IND..NBLIG))
      If IND1 > 0
        IND += IND1
      Else
        # Issue 117643 - 2016-08-18 by JUSYN : formerly used special character % (as well as any other special character)
        # causes a termination of the application when you try to close lines with this special character.
        # So replaced with a neutral character.
        # ITMNAME += " %"-num$(IND)
        ITMNAME += " I"-num$(IND)
        Break
      Endif
    Wend
  Endif

LIGNE += 1
[M:VBOG]LIGNE(L)     = LIGNE
[M:VBOG]PARLIN(L)    = PLIGNE
[M:VBOG]LEV(L)       = LEVEL
[M:VBOG]ITMREF(L)    = [F:BODW]ITMREF

# gestion du type texte
If [F:BODW]CPNTYP = 5
  [M:VBOG]CPNITMREF(L) = "TEXTE"
  [M:VBOG]GRPITMREF(L) = "TEXTE"
  [M:VBOG]DES1AXX(L) = [F:BODW]BOMSHO
  #[M:VBOG]BOMSHO(L) = [F:BODW]BOMSHO : # GH 29/09/11 bug 76687
Else
  [M:VBOG]CPNITMREF(L) = ITMNAME
  [M:VBOG]GRPITMREF(L) = [F:BODW]CPNITMREF
  #[M:VBOG]ITMDES1(L)   = [F:ITM]DES1AXX
  [M:VBOG]BOMSHO(L) = [F:BODW]BOMSHO : # GH 29/09/11 bug 76687
# Issue 109708 - 2015-08-28 by JUSYN : Versioning
#Issue X3-58710 20/10/2017 by GEBIL : ECCVALMAJ no-existent variable
  #[M:VBOG]ECCVALMAJ(L) = [F:BODW]ECCVALMAJ
  #[M:VBOG]ECCVALMIN(L) = [F:BODW]ECCVALMIN
  If dim([M:VBOG]ECCVALMAJ(L)) > 0
    [M:VBOG]ECCVALMAJ(L) = [F:BODW]ECCVALMAJ
    [M:VBOG]ECCVALMIN(L) = [F:BODW]ECCVALMIN
  Endif
Endif
[M:VBOG]ALTTYPR(L)   = [F:BODW]BOMALTTYP
[M:VBOG]BOMSEQ(L)    = [F:BODW]BOMSEQ
[M:VBOG]CPNTYP(L)    = [F:BODW]CPNTYP

## GH 20/10/2011 bug 77219

# [M:VBOG]LIKQTY(L)    = [F:BODW]LIKQTY
# FQ 71292 GA 02/2011 [BOH] ... devient [BOHW]
# FQ 66497 - MABON 18/08/10 - Il faut tenir compte de la quantité de base
# If [F:BODW]LIKQTYCOD=1
#  If clalev([F:BOHW])=0 : Local File BOM [BOHW] : Endif
#  Read [BOHW]BOH0=[F:BODW]ITMREF;[F:BODW]BOMALT;[F:BODW]BOMALTTYP
#  If !fstat and [F:BOHW]BASQTY>0
#    [M:VBOG]LIKQTY(L)    = [F:BODW]LIKQTY*[M]BASQTY(0)/[F:BOHW]BASQTY
#  Endif
# Endif
# Fin MABON

If clalev([F:BOHW])=0 : Local File BOM [BOHW] : Endif
Read [BOHW]BOH0=[F:BODW]ITMREF;[F:BODW]BOMALT;[F:BODW]BOMALTTYP
If !fstat & [F:BODW]LIKQTY<>0 & [M:VBOG]LIKQTY(PLIGNE)<>0
  Call LIKQTY([M:VBOG]LIKQTY(PLIGNE),[F:ITM]STU,[F:BOHW]BASQTY,[F:BODW]LIKQTYCOD,
&             [F:BODW]LIKQTY,[F:BODW]QTYRND,[F:BODW]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
  If LQTNA=0 : # GH 19/12/12 Bug 85968 si la qté avec arrondi rend 0, on refait le calcul sans arrondi
     GCLE=""
     Call LIKQTY([M:VBOG]LIKQTY(PLIGNE),GCLE,[F:BOHW]BASQTY,[F:BODW]LIKQTYCOD,
&               [F:BODW]LIKQTY,[F:BODW]QTYRND,[F:BODW]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
 Endif
 [M:VBOG]LIKQTY(L)    = LQTNA
Else
 [M:VBOG]LIKQTY(L)    = 0
Endif

## Fin GH

[M:VBOG]STU(L)       = [F:ITM]STU
[M:VBOG]REOCOD(L)    = [F:ITF]REOCOD
If dim([M:VBOG]LIBREOCOD(L))>0 & [F:ITF]REOCOD>1
   [M:VBOG]LIBREOCOD(L)=mess([F:ITF]REOCOD,250,1)
Endif

Gosub ADD_VNOM

L += 1
[M:VBOG]NBLIG = L

Return

#----------------------------------------------------------------------
# GA 02/2008 nomenclature verticale
# NBLIG  : variable <Bas de tableau>
# PARKEY : clé père         (composé)
# KEYC   : clé              (composant)
# LIBL1  : libellé long
# LIBSH  : info-bulle       (facultatif)
# EXPFLG : ouvrir le niveau (facultatif)
# ICO    : icone associée   (facultatif)
#----------------------------------------------------------------------
$ADD_VNOM
If dim([M:VBOG]LIKQTY2)>0 & dim([M:VBOG]FMTQTY2)>0 & [M:VBOG]STU(L)<>""
   [M:VBOG]LIKQTY2(L) = format$([M:VBOG]FMTQTY2,[M:VBOG]LIKQTY(L))
Endif

[M:VBOG]KEYC(L)      = [M:VBOG]CPNITMREF(L) +"-"+ num$([M:VBOG]BOMSEQ(L))
If [M:VBOG]PARLIN(L)<>-1
   [M:VBOG]PARKEY(L) = [M:VBOG]KEYC([M:VBOG]PARLIN(L))
Else
   [M:VBOG]PARKEY(L) = ""
Endif
# info bulle
#If dim([M:VBOG]LIBSH)>0  & [M:VBOG]LIBREOCOD(L)<>""
If dim([M:VBOG]LIBSH)>0  & [M:VBOG]CPNTYP(L) > 1
  #[M:VBOG]LIBSH(L) = [M:VBOG]LIBREOCOD(L)
   [M:VBOG]LIBSH(L) = mess([M:VBOG]CPNTYP(L),438,1)
Else
  If func HAS_NOMP([M:VBOG]CPNITMREF(L),[M:VBOG]BOMALT)=1
    [M:VBOG]LIBSH(L)  = mess(222,184,1)
  Else
    [M:VBOG]LIBSH(L)  =  mess(35,197,1)
  Endif
Endif
# icône associée nomenclature verticale
If dim([M:VBOG]ICO)>0
    #[M:VBOG]ICO(L) = WICO_END
    If [M:VBOG]ALTTYPR(L)>1
       Case [M:VBOG]REOCOD(L)
         When 3           # Production
           [M:VBOG]ICO(L) = WICO_PROD
         When 5           # Sous-traité
           [M:VBOG]ICO(L) = WICO_SCP
       Endcase
       Case [M:VBOG]CPNTYP(L)
         When 4           # Sous-produit
           [M:VBOG]ICO(L) = WICO_SSPROD
         When 5            # texte
           [M:VBOG]ICO(L)  = WICO_TXT
         When 6            # valorisation
           [M:VBOG]ICO(L)  = WICO_VAL
         When 7           # Service
           [M:VBOG]ICO(L) = WICO_SCOWST
       Endcase
       If [M:VBOG]PARLIN(L)>-1 & [M:VBOG]CPNTYP([M:VBOG]PARLIN(L))<>4 & find([M:VBOG]ICO([M:VBOG]PARLIN(L)),"",WICO_END)
          [M:VBOG]ICO([M:VBOG]PARLIN(L)) = WICO_PROD
       Endif
    Endif
    If [M:VBOG]PARLIN(L)<>-1 & find([M:VBOG]ICO([M:VBOG]PARLIN(L)),"",WICO_END)
       [M:VBOG]ICO([M:VBOG]PARLIN(L))="Folder.gif"
    Endif
    If [F:ITM]PHAFLG = 2
      [M:VBOG]ICO(L) = WICO_GHOST
    Endif
    If [M:VBOG]ICO(L) =""
      [M:VBOG]ICO(L) = WICO_MAT
    Endif
Endif


# Niveau plié/déplié
If dim([M:VBOG]EXPFLG)>0
   If [M:VBOG]PARLIN(L) =-1
      [M:VBOG]EXPFLG(L) = 2
   Else
      # FQ65148 : le niveau sera présenté Plié avec la valeur 1, et non 0
#      [M:VBOG]EXPFLG(L) = 0
      [M:VBOG]EXPFLG(L) = 1
   Endif
   [M:VBOG]BOMFLG = 0   : # Seul le 1er niveau est déplié
Endif
Return



#----------------------------------------------------------------------
# lecture fichiers
$LEC_FILES
# lecture entete nomenclature
Read [BOH1]BOH0=LITM;LALT;LTYP
If fstat : Raz [F:BOH1] : Endif

# lecture article composé
If [F:ITM]ITMREF <> LITM
    Read [ITM]ITM0=LITM
    If fstat : Raz [F:ITM] : Endif
Endif
# lecture article/site composé
If [F:ITF]ITMREF <> LITM | [F:ITF]STOFCY <> LFCY
    Read [ITF]ITF0=LITM;LFCY
    If fstat : Raz [F:ITF] : Endif
Endif

Return

######################################################################################
# NOL doit être préalablement chargée - appelé par SUBVBOMG en AS_NBLIG
$CHARGE_BOD
If dim(WBOMALTTYP)<0 : Local Integer WBOMALTTYP : Endif

# Affichage du composant courant
[M:VBOG]XNUMLIG     = NOL
#[M:VBOG]XCPNITMREF  = [M:VBOG]CPNITMREF(NOL)
[M:VBOG]XCPNITMREF  = [M:VBOG]GRPITMREF(NOL)
[M:VBOG]XREOCOD     = [M:VBOG]REOCOD(NOL)
[M:VBOG]XBOMSHO     = [M:VBOG]BOMSHO(NOL)
[M:VBOG]XCPNTYP     = [M:VBOG]CPNTYP(NOL)

Read [BOD1]BOD0=[M:VBOG]ITMREF(NOL);[M:VBOG]BOMALT;[M:VBOG]BOMSEQ(NOL);[M:VBOG]XCPNITMREF;[M:VBOG]ALTTYPR(NOL)
If fstat : Raz [F:BOD1]  : Endif
Read [ITM1]ITM0=[M:VBOG]XCPNITMREF
If fstat : Raz [F:ITM1]  : Endif
Read [ITF1]ITF0=[M:VBOG]XCPNITMREF;[M:VBOG]STOFCY
If fstat : Raz [F:ITF1]  : Endif
#[M:VBOG]XCPNTYP    = [F:BOD1]CPNTYP
If dim([M]XBOMUOM)> 0 : #code activité UML actif
  [M:VBOG]XBOMUOM    = [F:BOD1]BOMUOM
  [M:VBOG]XBOMQTY    = [F:BOD1]BOMQTY
  [M:VBOG]XBOMSTUCOE = [F:BOD1]BOMSTUCOE
Endif
[M:VBOG]XLIKQTY    = [F:BOD1]LIKQTY
[M:VBOG]XLIKQTYCOD = [F:BOD1]LIKQTYCOD
[M:VBOG]XQTYRND    = [F:BOD1]QTYRND
#[M:VBOG]XBOMSHO    = [F:BOD1]BOMSHO
[M:VBOG]XSCA       = [F:BOD1]SCA
[M:VBOG]XBOMSTRDAT = [F:BOD1]BOMSTRDAT
[M:VBOG]XBOMENDDAT = [F:BOD1]BOMENDDAT
[M:VBOG]XBOMSTRLOT = [F:BOD1]BOMSTRLOT
[M:VBOG]XBOMENDLOT = [F:BOD1]BOMENDLOT
[M:VBOG]XCPNOPE    = [F:BOD1]CPNOPE
[M:VBOG]XBOMOFS    = [F:BOD1]BOMOFS
# Issue 109708 - 2015-08-28 by JUSYN : Versioning
#Issue X3-58710 20/10/2017 by GEBIL : ECCVALMAJ no-existent variable
#[M:VBOG]ECCMAJX = [F:BOD1]ECCVALMAJ
#[M:VBOG]ECCMINX = [F:BOD1]ECCVALMIN
If dim([M:VBOG]ECCMAJX) > 0
  [M:VBOG]ECCMAJX = [F:BOD1]ECCVALMAJ
  [M:VBOG]ECCMINX = [F:BOD1]ECCVALMIN
Endif

[M:VBOG]XITMDES1  = [M:VBOG]DES1AXX(NOL)
#[M:VBOG]XITMDES1   = [F:ITM1]ITMDES1
[M:VBOG]XCPNSTU     = [F:ITM1]STU

If [F:ITF1]STOMGTCOD>0
   [M:VBOG]STOMGTCOD = [F:ITF1]STOMGTCOD
Else
   [M:VBOG]STOMGTCOD = [F:ITM1]STOMGTCOD
Endif

If [M:VBOG]ALTTYPR(NOL)=1
   Read [ITS1]ITS0=[M:VBOG]XCPNITMREF
   If fstat : Raz [F:ITS1] : Endif
   [M:VBOG]BOMTEXNUM     = [F:ITS1]ITSTEX     : # Texte vente
Else
   [M:VBOG]BOMTEXNUM     = [F:ITM1]MFGTEX     : # Texte production
Endif
Gosub CHARGE_TEX    : # Texte
Gosub CHARGE_IMG    : # CLOB Image

Affzo [VBOG]30,35,40,45

Return

######################################################################################
# NOL doit être préalablement chargée - appelé par SUBVBOMG en AS_NBLIG
$CHARGE_BOH
# Affichage du composé
[M:VBOG]XNUMLIG     = NOL
#[M:VBOG]XCPNITMREF  = [M:VBOG]ITMREF(NOL)
[M:VBOG]XCPNITMREF  = [M:VBOG]GRPITMREF(NOL)
[M:VBOG]XREOCOD     = [M:VBOG]REOCOD(NOL)

Read [ITM1]ITM0=[M:VBOG]CPNITMREF(NOL)
If fstat : Raz [F:ITM1]  : Endif
Read [ITF1]ITF0=[M:VBOG]CPNITMREF(NOL);[M:VBOG]STOFCY
If fstat : Raz [F:ITF1]  : Endif
If !varinit([M:VBOG]DES1AXX,NOL) : Affzo [VBOG]DES1AXX(NOL) : Endif : # GH 20/03/2013 bug 86834
[M:VBOG]XITMDES1  = [M:VBOG]DES1AXX(NOL)
#[M:VBOG]XITMDES1  = [F:ITM1]ITMDES1
[M:VBOG]XCPNSTU   = [F:ITM1]STU
If [F:ITF1]STOMGTCOD>0
   [M:VBOG]STOMGTCOD = [F:ITF1]STOMGTCOD
Else
   [M:VBOG]STOMGTCOD = [F:ITM1]STOMGTCOD
Endif
#[M:VBOG]XBOMSHO = [F:BOD1]BOMSHO : # GH 29/09/11 bug 76687
#[M:VBOG]XBOMSHO = [M:VBOG]BOMTEXNUM

# GH 29/09/11 bug 76687
#[M:VBOG]BOMTEXNUM = [F:BOD1]BOMSHO
If [M:VBOG]BOMALTTYP=1
   Read [ITS1]ITS0=[M:VBOG]XCPNITMREF
   If fstat : Raz [F:ITS1] : Endif
   [M:VBOG]BOMTEXNUM     = [F:ITS1]ITSTEX     : # Texte vente
Else
   [M:VBOG]BOMTEXNUM     = [F:ITM1]MFGTEX     : # Texte production
Endif

[M:VBOG]XCPNTYP = 0
[M:VBOG]XLIKQTYCOD = 0
[M:VBOG]XQTYRND = 0

# Issue 112780 - 2015-11-25 by CCC : add test on existence of VBOGECCMAJ
If dim([M:VBOG]VBOGECCMAJ)>0
    # Issue 109708 - 2015-08-28 by JUSYN : Versioning - component detail versions
    [M:VBOG]ECCMAJX = [M:VBOG]VBOGECCMAJ
    [M:VBOG]ECCMINX = [M:VBOG]VBOGECCMIN
Endif

Gosub CHARGE_TEX    : # Texte
Gosub CHARGE_IMG    : # CLOB Image

Affzo [VBOG]30,35,40,45

Return

############################################################
$CHARGE_TEX
Raz [M:VBOG]TEXTE
If [M:VBOG]BOMTEXNUM<>""
   Read [TXC1]TXC0=[M:VBOG]BOMTEXNUM
   If !fstat   [M:VBOG]TEXTE = [F:TXC1]TEXTE Endif
Endif

Return
############################################################
$CHARGE_IMG
Read [CBB1]CBB0="ITM";[F:ITM1]ITMREF;""
If !fstat
   [M:VBOG]IMG=[F:CBB1]BLOB
Else
   Raz [M:VBOG]IMG
Endif

Return

############################################################
$BOUTON_BOMG

Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

Case BOUT
  When "a" :
    Gosub FIRST_LEV_BOMG
  When "b" :
    Gosub ALL_LEV_BOMG
  When "c" :
#    Call PRTSCR("VISUBOMG","VBOG","",0,0) From ATRTX3
    Read [BOH1]BOH0 = [M:VBOG]PARITMREF;[M:VBOG]BOMALT;[M:VBOG]BOMALTTYP
    If fstat : Raz [F:BOH1] : Endif
    # FQ61726 - MABON 21/01/09 - l'impression doit être multi-niveaux
    Local Mask BOP0 [BOP0]
    [M]TRT=2
    # FQ61726 - MABON 19/01/09 - la langue FRA ne doit pas être passée en dur
#    Call ETAT("BOMPRN","VISU","FRA",0,"test d'impression", TBPAR, TBVAL) From AIMP3
    Call ETAT("BOMPRN", GFONCTION, TBPAR, TBVAL) From ETAT
    # FQ61726 - MABON 21/01/09 - repositionnement du bon local mask
    Local Mask VISUBOMROU [VBOR]

  When "d" :
    If GMODU(8)=2 # Si et seulement si module GPAO actif ... FQ 75681 GA 09/2011
      If clalev([F:TRO])> 0 : Close File [TRO] : Endif
      If clalev([F:ROH])> 0 : Close File [ROH] : Endif
    Endif
Endcase
Return
############################################################
$FIRST_LEV_BOMG
# Replier tout, sauf 1er niveau
Local Integer K
If dim([M:VBOG]EXPFLG)>0
  For K=0 To [M:VBOG]NBLIG-1
    If [M:VBOG]PARLIN(K)=-1
     [M:VBOG]EXPFLG(K) = 2
    Else
      # FQ65148 : le niveau sera présenté Plié avec la valeur 1, et non 0
#     [M:VBOG]EXPFLG(K) = 0
     [M:VBOG]EXPFLG(K) = 1
    Endif
  Next
Endif

[M:VBOG]BOMFLG = 0   : # Seul le 1er niveau est déplié
Affzo [VBOG]25
Return

############################################################
$ALL_LEV_BOMG
# Deplier toute l'arborescence
Local Integer K
If dim([M:VBOG]EXPFLG)>0
  For K=0 To [M:VBOG]NBLIG-1
    [M:VBOG]EXPFLG(K) = 2
  Next
Endif
[M:VBOG]BOMFLG = 1   : # Toute l'arborescence est dépliée
Affzo [VBOG]
Return

############################################################
$LISTE_ICONES
# Production
If func CTL_FIC_ICONE("folder_gear.png")=2
   WICO_PROD = "folder_gear.png"
Else
   WICO_PROD = "produit.png"
Endif

# Sous-produit
If func CTL_FIC_ICONE("folder_add.png")=2
   WICO_SSPROD = "folder_add.png"
Else
   WICO_SSPROD = "sousproduit.png"
Endif

# Sous-traité
If func CTL_FIC_ICONE("folder_gear.png")=2
   WICO_SCP = "folder_gear.png"
Else
   WICO_SCP = "produitsoustraite.png"
Endif

# Sous-traitance
If func CTL_FIC_ICONE("folder_time.png")=2
   WICO_SCS = "folder_time.png"
Else
   WICO_SCS = "mvt2.png"
Endif

# feuilles de l'arborescence
If func CTL_FIC_ICONE("folder_into.png")=2
   WICO_END = "folder_into.png"
Else
   WICO_END = "box_closed.gif"
Endif
# Service
WICO_SCOWST = "soustraitance.png"
#matière
WICO_MAT = "matierepremiere.png"
#fantôme
WICO_GHOST = "fantome.png"
#valorisation
WICO_VAL = "valorisation.png"
#Texte
WICO_TXT = "texte.png"
Return


############################################################
Funprog CTL_FIC_ICONE (LNOMICON)
Value Char LNOMICON
Local Integer WOK : WOK=2

Local Char WREPERT(200),WDIRSEP
Case GOS(1)
 When "dos"  : WDIRSEP="\"
 When Default : WDIRSEP="/"
Endcase

WREPERT=filpath("X3_ROOT"+WDIRSEP+"RESSTD"+WDIRSEP+"IMG","","","X3_PUB")
If LNOMICON<>"" & filinfo(WREPERT+WDIRSEP+LNOMICON,0)<0
   WOK = 1
Endif


End WOK
############################################################

Funprog HAS_NOMP(ITEM,ALTERNATIVE)
Value Char ITEM
Value Integer ALTERNATIVE

Local Integer RES : RES = 0
Local File BOM [SBOH]

Look [F:SBOH]BOH0 = ITEM;ALTERNATIVE;2
If fstat = 0
  RES =1
Endif
Close Local File [SBOH]
End RES

