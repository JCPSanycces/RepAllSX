#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du fichier QUEUE
Call OBJET ("QUE", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "FERME"       : Gosub FERME
    When "SETBOUT"     : Gosub SETBOUT
    When "INICRE"      : Gosub INICRE
    When "RAZCRE"      : Gosub RAZCRE
    When "RAZDUP"      : Gosub RAZDUP
    When "LIENS"       : Gosub LIENS
    When "CREATION"    : Gosub CREATION
    When "MODIF"       : Gosub MODIF
    When "APRES_CRE"   : Gosub APRES_CRE
    When "APRES_MOD"   : Gosub APRES_MOD
    When "AV_ANNULE"   : Gosub AV_ANNULE
    When "ANNULE"      : Gosub ANNULE     # FGR 23/09/2009 : X3SUIVI58037
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char     GCQUECPT(GLONANM)   # Code compteur pour queue
Global Char SZTAB_PBLGRP (GLONVCR) (dim([M:QUE2]PBLGRP))
Global Integer INBTAB_PBLGRP

  Raz SZTAB_PBLGRP
  INBTAB_PBLGRP = 0
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(4)
  #  GCQUECPT = [F:TCA]CODNUM(4)
  GSOCIETE = ""
  GCURLEG = ""
  Call READ_COUNTER("", 12, 4, GSOCIETE, GCURLEG, GCQUECPT, GMANCOU) From CRM_UTIL
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
Return

##########################################################################################################
$FERME
  Kill GCQUECPT
  Kill SZTAB_PBLGRP
  Kill INBTAB_PBLGRP
Return

##########################################################################################################
$SETBOUT
  If REP = "" Then
    CHMEN += "I"
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

Local Integer STAT
Local Char SZSITE(GLONFCY)
SZSITE = ""

  # Récupération du compteur de contrat de service.
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK", "", GCQUECPT, date$, "", [M:QUE0]NUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:QUE]NUM = [M:QUE0]NUM
      Affzo [M:QUE0]NUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:QUE]TYPFULDES = "QUE"
  [F:QUE]NUMFULDES = [M:QUE0]NUM
  [M:QUE1]TYPFULDES = "QUE"
  [M:QUE1]NUMFULDES = [M:QUE0]NUM
Return

##########################################################################################################
$RAZCRE
  Gosub RAZ_SZTAB_PBLGRP From SUBQUEB
  Affzo [M:QUE1]1-99
  Affzo [M:QUE2]1-99
Return

##########################################################################################################
$RAZDUP
  Gosub RAZ_SZTAB_PBLGRP From SUBQUEB
Return

##########################################################################################################
$LIENS
  #---------------------------------------------------#
  #Lecture des clobs
  #---------------------------------------------------#
  Gosub LOADCLOB From SUBQUEB
  Gosub LOADFAMQUE From SUBQUEB
  Gosub LOAD_SZTAB_PBLGRP From SUBQUEB
  Affzo [M:QUE1]1-99
  Affzo [M:QUE2]1-99
Return

##########################################################################################################
$CREATION
  # FGR 23/09/2009 : X3SUIVI58037
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:QUE0]QUEDESAXX,"QUEUE","QUEDESAXX",[M:QUE0]NUM,"") From ATEXTRA
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBQUEB
  If GOK < 1 Then
    GERR = 1
    Return
  Endif
  Gosub SAVEFAMQUE From SUBQUEB
  If GOK < 1 Then
    GERR = 1
    Return
  Endif
Return

##########################################################################################################
$MODIF
  # FGR 23/09/2009 : X3SUIVI58037
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:QUE0]QUEDESAXX,"QUEUE","QUEDESAXX",[M:QUE0]NUM,"") From ATEXTRA
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBQUEB
  If GOK < 1 Then
    GERR = 1
    Return
  Endif
  Gosub SAVEFAMQUE From SUBQUEB
  If GOK < 1 Then
    GERR = 1
    Return
  Endif
Return

##########################################################################################################
$ANNULE
  # FGR 23/09/2009 : X3SUIVI58037
  #--- maj de la table des libéllés traduisibles
  Call SUPTEXTRA("QUEUE","QUEDESAXX",[M:QUE0]NUM,"") From ATEXTRA
Return

##########################################################################################################
$APRES_CRE
  Gosub LOAD_SZTAB_PBLGRP From SUBQUEB
Return

##########################################################################################################
$APRES_MOD
  Gosub LOAD_SZTAB_PBLGRP From SUBQUEB
Return

##########################################################################################################
$AV_ANNULE
  #Suppression des clobs
  Gosub DELCLOB From SUBQUEB
  If GOK < 1 Then
    Return
  Endif
  Gosub DEL_ALLPBQ From SUBQUEB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
Subprog C_NBLIG
End

##########################################################################################################
Subprog C_PBLGRP(VALEUR)
Variable Char    VALEUR()

Local Integer I

  Gosub CTLSHORTCUT From SUBPBLB
  If GERR > 0 Then
    End
  Endif
  #Vérifie si ce code compétence n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim([M:QUE2]PBLGRP)-1
    If I <> nolign-1 Then
      If [M:QUE2]PBLGRP(I) = VALEUR and [M:QUE2]PBLGRP(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        GMESSAGE = mess(431,196,1) #Cette famille de compétence a déjà été saisie.
        GERR = 2
      Endif
    Endif
  Next
End

##########################################################################################################
Subprog AM_PBLGRP(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:QUE2]PBLCLA(nolign-1) = ""
  Else
    Read [PBL]PBL0=VALEUR
    If fstat Then
      [M:QUE2]PBLCLA(nolign-1) = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:QUE2]PBLCLA(nolign-1) = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:QUE2]PBLCLA(nolign-1),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  Affzo [M:QUE2]PBLCLA(nolign-1)
End

##########################################################################################################
Subprog IB_PBLGRP
End
