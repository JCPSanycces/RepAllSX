#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du masque SELCONT

########################################
Subprog AM_SELIND(VALEUR)
Variable Integer VALEUR
Local Integer I

[M:SLCO]SELIND(nolign-1) = VALEUR 
For  I = 0 To [M:SLCO]NBLIG - 1
    If I <> nolign - 1 : [M:SLCO]SELIND(I) = 1 : Endif
Next I
Affzo [M:SLCO]
End

