#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : sections analytiques
#                             cf AML 2240 : 20
###################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables CCEWPIV devient WK
######################################################################
$OUVTAB_CCE
If !clalev([F:AXX]) Local File ATEXTRA [AXX] Endif
If !clalev([F:CCE]) Local File CACCE [CCE] Endif
If !clalev([F:FCY]) Local File FACILITY [FCY] Endif
If !clalev([F:FGR]) Local File FACGROUP [FGR] Endif
Return

######################################################################
Subprog TRT_CCE(ID,CLETRT,P_AXI,P_DIE,PITCCE,P_LISTFCY,P_CRITFCY,OK)
Value Char ID()
Value Char CLETRT () 
Value Integer P_AXI
Value Char P_DIE () 
Value Char PITCCE () 
Value Integer P_LISTFCY : # si liste pour les sites (value 0 ou 1)
Value Char P_CRITFCY () 
Variable Integer OK

If PITCCE ="" : Return : Endif

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GUTF8
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub OUVTAB_CCE
Gosub OUVREPIVOT From CONNECTFCT


Local Integer WPRECCE : Raz WPRECCE
Local Integer WNBCCE : Raz WNBCCE 
Local Char    OPTCCE(GDIMFIC)
OPTCCE = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitcce")
Local Integer WKNBZON : Raz WKNBZON
Local Char WKNORECMES (50): Raz WKNORECMES 
Local Integer WKHEATYP : Raz WKHEATYP 
Local Char WKHEADMES (250): Raz WKHEADMES 

Call READPIT(PITCCE,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
Local Char WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
Local Char WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
Local Char WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
Local Char WKFRM(150)(1..WKNBZON) : Raz WKFRM
Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
Local Char WKVAL(255)(1..WKNBZON) : Raz WKVAL
Local Char WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
Call LOADPIVZON(PITCCE,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
Call WRPIVOT_HEAD(PITCCE,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPRECCE,OPTCCE) From CONNECTFCT

If P_LISTFCY & find("FCY",WKTABABR)
For [FCY] Where evalue(P_CRITFCY)
    If pat(GVERSION,"1.5.*")
    # FQ 64773 GA 05/2010 and ENAFLG=2 -- Test en V5 champ inexistant
    Link [CCE] With [FGR]FGR1 = [F:FCY]FCY;[F:CCE]FCY As [LNK]
&   Where AXI=P_AXI 
&   and ([F:CCE]FCY="" | [F:CCE]FCY=[F:FCY]FCY | [F:FGR]CPY<>"")
    Else
    Link [CCE] With [FGR]FGR1 = [F:FCY]FCY;[F:CCE]FCY As [LNK]
&   Where DIE=P_DIE and ENAFLG=2
&   and ([F:CCE]FCY="" | [F:CCE]FCY=[F:FCY]FCY | [F:FGR]CPY<>"")
    Endif
    For [LNK]
        Gosub WR_CCE
    Next
Next
Else
#######
If pat(GVERSION,"1.5.*")
    For [CCE] Where AXI=P_AXI and ENAFLG=2
        Gosub WR_CCE
    Next
Else
    For [CCE] Where DIE=P_DIE and ENAFLG=2
        Gosub WR_CCE
    Next
Endif
Endif
#######

Call WRPIVOT_END(PITCCE ,WNBCCE ,WKNORECMES ,WPRECCE ,OPTCCE) From CONNECTFCT
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$WR_CCE
    ################################
    # fichiers CCE
    ################################
    #     Ouverture du fichier OPTCCE en écriture
    If WPRECCE = 0
      Openo OPTCCE,0 Using [FPIV]
      WPRECCE = 1
    Else
      Openo OPTCCE Using [FPIV]
    Endif
    
    WNBCCE += 1
    Call RAZVALPIVOT(PITCCE,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITCCE,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Return

######################################################################
#############################################################################
Funprog CCE_GETDES
Local Char LDES(GLONDES)
Raz LDES
If [F:CCE]CCE<>""
    If pat(GVERSION,"1.5.*")
        End [F:CCE]DES
    Else
        Call LECTEXTRA(LDES,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
        If LDES=""
            End [F:CCE]DES
        Endif
    Endif
Endif
End LDES

#############################################################################
# FQ 65034 Accès aux Sections #
# P_DIE    
# - contient le numéro d'axe en V5
# - contient le code de l'axe à partir de la V6
#############################################################################
Funprog CAL_GETCCE(P_ABRFIC,P_DIE,P_VCRTYP,P_VCRNUM,P_VCRLIN,P_VCRSEQ,P_CPLCLE)
Value    Char    P_ABRFIC() 
Value    Char    P_DIE () 
Value    Integer P_VCRTYP
Value    Char    P_VCRNUM() 
Value    Integer P_VCRLIN
Value    Integer P_VCRSEQ
Value    Char    P_CPLCLE() 

Local Char WCCE(GLONCCE) : Raz WCCE
If P_ABRFIC<>""
    If pat(GVERSION,"1.5.*")
      # La table contient le champ CCEi correspondant à l'axe i
        Local Char WCHAMP(30)
        WCHAMP="[F:"+P_ABRFIC+"]CCE"+P_DIE
        If evalue("dim("+WCHAMP+")")>0
           WCCE = evalue(WCHAMP)
           End WCCE
        Endif
    Else
      # Recherche de la valeur dans CPTANALIN pour la clé ID, la table P_ABRFIC, l'axe P_DIE
        If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
        Read [CAL] CAL0=P_ABRFIC;P_VCRTYP;P_VCRNUM;P_VCRLIN;P_VCRSEQ;P_CPLCLE;1
        If !fstat & P_DIE<>""
           J=find(P_DIE,[F:CAL]DIE(0..max(GNBDIE-1,8)))
           If J : WCCE=[F:CAL]CCE(J-1) : End WCCE : Endif
        Endif
    Endif
Endif
End WCCE

