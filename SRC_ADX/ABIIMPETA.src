#<AdxTL>@(#)4.0.0.0 $Revision$

GTEST = 0
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ABIIMPETA","ABIIMPETA",3,"") From GTRAITE
End

##############################################################################################################
$ACTION
Case ACTION
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When "INIT_DIA"     : Gosub INIT_DIA
Endcase
Return

##############################################################################################################
$EXEC
If [M:DIA]IMPORT<>2 & [M:DIA]MOV<>2
 Call AVERTIR(mess(123,148,1),GBIDI1) From GESECRAN
 Return
Endif
If GINFO
 Call FERME_VLC From GESECRAN
 Call OUVRE_VLC(mess(108,148,1),"","") From GESECRAN   : # Import ficher biar
Endif
Call IMPBIAR(nomap,[M:DIA]FICHIER,[M:DIA]IMPORT,[M:DIA]MOV,GBIDC2)
If GINFO
 Call FERME_VLC From GESECRAN
Endif
TRA=1
Return

$INIT_DIA
If !GSERVEUR & !GIMPORT
 GINFO =  1
Else
 GINFO = 0
Endif
Return

$TERMINE
TRA=1
Return

Subprog IMPBIAR(APPLI,BIAR,IMPORTS,MOV,TRACE)
Value    Char    APPLI,BIAR
Value    Integer IMPORTS,MOV
Variable Char    TRACE

Local Char PORT(250)
Local Integer ERR,STAINI

# 96797 : bug in menu, run with the infbox in INSTALL
Call INIGLOBVAR(STAINI) From GLOBVAR
Call CONNECTSIL From GESUSER

Call RECHPROP("busobj.adxadmin.port",PORT,ERR) From INTRUTILA
If PORT="" : End : Endif
If APPLI="" : APPLI = GDOSX3 : Endif
If APPLI="" : End : Endif

If filinfo(filpath("BI","","",APPLI),0) <0
 Call ECR_TRACE (mess(86,133,1)+"\|"+filpath("BI","","",APPLI)+"|",1) From GESECRAN
 End
Endif
If BIAR<>""
 Call EXE_IMPBIAR(APPLI,BIAR,IMPORTS,MOV,TRACE)
Else
 Local  Char   ORDRE(250)
 Local Char    FIC(150)(1..100)
 Local Integer NBFIC
 ORDRE = "lsadx -a"-APPLI-"BI biar"
 Call SYSTEME2(adxmac(0),ORDRE,"",NBFIC,FIC) From ORDSYS
 NBFIC = min(NBFIC,dim(FIC))
 For I=1 To NBFIC
  If find(seg$(FIC(I),len(FIC(I))-1,len(FIC(I))),"V5","V6","V7","V8","V9")>0 or instr(1,FIC(I),func APRODUCT.AGETRELEASEABR(nomap))>0 : # 119558
   Call EXE_IMPBIAR(APPLI,FIC(I),IMPORTS,MOV,TRACE)
  Endif
 Next I
 If NBFIC=0
  Call ECR_TRACE("No biar in folder BI  : BIAR File not imported",0) From GESECRAN
 Endif
Endif
End


Subprog EXE_IMPBIAR(APPLI,BIAR,IMPORTS,MOV,TRACE)
Value    Char    APPLI,BIAR
Value    Integer IMPORTS,MOV
Variable Char    TRACE
Local Char    LIGNE(250),PORT(250),SERVEUR(250),FICLOG(250),TESTADX(80)
Local Integer OK,ERR,DEBUT
Call RECHPROP("busobj.adxadmin.port",PORT,ERR) From INTRUTILA
If PORT="" or ERR : End : Endif
Call RECHPROP("component.busobj.servername",SERVEUR,ERR) From INTRUTILA
If SERVEUR="" or ERR : End : Endif
If GSERVEUR
 TRACE = func SERVSYS.GET_FILE_SERVEUR("tra")   # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
Elsif GTRACE=""
 Call OUVRE_TRACE(mess(108,148,1)) From LECFIC : # Import ficher biar
 TRACE = filpath("TRA",GTRACE,"tra")
Else
 TRACE = filpath("TRA",GTRACE,"tra")
Endif
Raz TESTADX
Call VARADX("ADXDIR",SERVEUR+":"+PORT,TESTADX) From ADXD
If TESTADX=""
 Call ECR_TRACE("("+SERVEUR+":"+PORT+") busobj.adxadmin not available",1) From GESECRAN
 End
Endif
If IMPORTS<>2 & MOV<>2
 Call ECR_TRACE(mess(123,148,1),0) From GESECRAN
 If !GSERVEUR
  Call FERME_TRACE From LECFIC
 Endif
 End
Endif
OK =1
Gosub OUVRE_TABLE From ABICREUNV                  : # Ouverture tables
Gosub INIT_PARAMETRE                              : # initialisation des parametres
If OK=0 : Goto ERREUR : Endif
If IMPORTS=2
 Gosub CREE_TOOL
 Gosub VERIF_REF_BIAR                            : # On verifie qu'il n'existe pas d'arborescence SAGE~IMPORT avant d'importer le BIAR
 If OK = 1
  If GINFO
   Call AFF_VLC(mess(108,148,1),"") From GESECRAN  : # Déplacement des états et univers dans le répertoire de livraison
  Endif
  Call MAJBIAR2(APPLI,BIAR,FICLOG) From PATCHABI   : # Import du fichier Biar
  Gosub VERIF_IMPORT_BIAR                          : # Verif si tout ces biens passés
 Endif
 If OK=0 : Goto ERREUR : Endif
Endif
If MOV<>2 : # On ne fait que l'impor du biar
 If !GSERVEUR
  Call FERME_TRACE From LECFIC
  End
 Endif
Endif
Gosub CREE_TOOL                                : # Création du fichier tool apres import du Biar
BALISE = 1 : OK =1
Gosub CRE_LIST_ETA From SUBATV2                : # Mise en variable des etats du refrentiel
Gosub LISTE_IMPORT                             : # Liste  des etats du repertoire biar ? : Etat  Nouveau
If GREPBI=IMPORT : Goto FIN : Endif
If [L]I_NBETATS =0
 Call ECR_TRACE(mess(92,148,1),0) From GESECRAN  : #  : Aucun états trouvés dans l'Infoview
Else
 Gosub LISTE_ALL                                : # Liste des etats du repertoire ALL : etats a supprimer
 Gosub LISTE_SPE                                : # Liste  des etats du repertoire SPE de la livraison :  etats a supprimer
 BALISE = 1 : OK =1
 Gosub FOLD_UNIV_ALL                            : # creation tableau des univers du repertoire ALL
 Gosub FIND_FOLD_MOVE                           : # recherche des cuid des repertoire mis en jeux
 Gosub RECH_FOLD
 Gosub MOV_BIAR                                 : # Deplacement des etats et repertoire, puis suppresion du dossier BIAR
 If OK=0 : Goto ERREUR : Endif
Endif
$FIN
## Suppresion des etats et univerrs du repertoire IMPORT_?
Gosub EFF_FICHIER From SUBATV2               : # Suppresion des fichier temporaire de travail
End

$VERIF_REF_BIAR
Local Clbfile READLOG(9)
Openi [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL Using [R1]
Iomode adxifs  ""  Using [R1]
Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
Iomode adxium  GUTF8  Using [R1]
Rdseq READLOG Using [R1]
Openi Using [R1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
If instr(0,READLOG,GIMPBI)
 Call ECR_TRACE(GIMPBI-mess(125,148,1)-": KO",0) From GESECRAN
Else
 Call ECR_TRACE(GIMPBI-mess(126,148,1)-": OK",0) From GESECRAN
 OK = 1
Endif
Return

$VERIF_IMPORT_BIAR
If filinfo(FICLOG,0) < 0
 OK=0
 Return
Endif

## Lecture fichier log de l'import du Biar
Local Clbfile READLOG(9)
Local Char MESSAGE(250)
Openi FICLOG   Using [R1]
Iomode adxifs  ""  Using [R1]
Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
Iomode adxium  GUTF8  Using [R1]

## Afectation du clob
Call ECR_TRACE(mess(157,148,1),0) From GESECRAN : # VéRIFICATION de  l'import du fichier biar
Rdseq MESSAGE Using [R1]
READLOG += MESSAGE
While !fstat
 Rdseq MESSAGE Using [R1]
 Call ECR_TRACE("|"+MESSAGE,0) From GESECRAN
 READLOG += MESSAGE
 # lecture pour avoir le dernier message
Wend
Openi Using [R1]

If BOVERSION>="R3"
 Call ECR_TRACE("BIAR File Imported successfully",-1) From GESECRAN
Else
 If !instr(0,READLOG,"BIAR File Imported successfully")
  OK =0
 Endif
Endif
Return

$ERREUR
Call ECR_TRACE("|"+mess(158,148,1)-":"
&                 -[M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ERR_LOG',1)
&                From GESECRAN
Gosub COP_FICHIER From SUBATV2
Gosub EFF_FICHIER From SUBATV2
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
ERR = 1
End

$MOV_BIAR
IMPPRO  = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'ImpBiar_'+num$(adxuid(1))+'.properties'

# Initialisations
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

## Ecriture fichier ImpBiar
Onerrgo ERREURS

Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+IMPPRO , 0  Using [D1]
Iomode adxifs  ""  Using [D1]
Iomode adxirs  chr$(13)+chr$(10)  Using [D1]
Iomode adxium  GUTF8  Using [D1]

If [L]EDOSALL<>""
 ## Delete des documents présents dans le repertoire ALL
 For I=0 To [L]A_NBETATS-1
  Wrseq "e;del;"+[L]A_ETATID(I)+';0;'+[L]A_ETATS(I) Using [D1]
 Next I

 ## Delete des documents présents dans le repertoire SPE
 For I=0 To [L]S_NBETATS-1
  Wrseq "e;del;"+[L]S_ETATID(I)+';0;'+[L]S_ETATS(I) Using [D1]
 Next I

  ##### Pour ALL
 J=0
 For I=0 To dim([L]I_ETATS)-1
  If !find([L]I_ETATUNV(I),UNVDEL(0..dim(UNVDEL)-1))
   [L]UNVDEL(J)   = [L]I_ETATUNV(I)
   J+=1
  Endif
 Next I

 I =0
 For K=0 To J-1
  For M=0 To dim([L]ETAT)-1
   If [L]UNVDEL(K)=[L]ETAT_UNV(M) & !find([L]ETAT_UNVID(M),UNVDELID(0..dim(UNVDELID)-1))
&   & find([L]ETAT_UNVID(M),TAB_ID(0..NBUNV-1))
    [L]UNVDEL(I)   = [L]ETAT_UNV(M)
    [L]UNVDELID(I) = [L]ETAT_UNVID(M)
    I+=1
   Endif
  Next
 Next

 ## delete des etats qui sont basé sur l'univers qui est present dans le repertoire d'import ALL
 If UDOSSPE="" : UDOSSPE=UDOSALL : Endif
 For K=0 To J-1
  M = 0
  For I=0 To dim([L]ETAT)-1
   If [L]ETAT_UNVID(I) = [L]UNVDELID(K) & !find([L]ETAT_ID(I),[L]A_ETATID(0..dim([L]A_ETATS)-1)) & [L]ETAT_F_CUID(I)=[L]UDOSSPE
    Wrseq "e;del;"+[L]ETAT_ID(I)+";0;"+[L]ETAT(I) Using [D1]
   Endif
  Next
 Next

 For K=0 To J-1
  If [L]UNVDELID(K)<>"" & [L]UNVDEL(K)<>""
   Wrseq "u;del;"+[L]UNVDELID(K)+";0;"+[L]UNVDEL(K) Using [D1]
  Endif
 Next K

 ##### Pour SPE
 J=0
 Raz UNVDEL,UNVDELID
 For I=0 To dim([L]SI_ETATS)-1
  If !find([L]SI_ETATUNV(I),UNVDEL(0..dim(UNVDEL)-1))
   [L]UNVDEL(J)   = [L]SI_ETATUNV(I)
   J+=1
  Endif
 Next I

 I =0
 For K=0 To J-1
  For M=0 To dim([L]ETAT)-1
   If [L]UNVDEL(K)=[L]ETAT_UNV(M) & !find([L]ETAT_UNVID(M),UNVDELID(0..dim(UNVDELID)-1))
&   & find([L]ETAT_UNVID(M),TAB_ID(0..NBUNV-1))
    [L]UNVDEL(I)   = [L]ETAT_UNV(M)
    [L]UNVDELID(I) = [L]ETAT_UNVID(M)
    I+=1
   Endif
  Next
 Next

 ## delete des etats qui sont basé sur l'univers qui est present dans le repertoire d'import SPE
 For K=0 To J-1
  M = 0
  For I=0 To dim([L]ETAT)-1
   If [L]ETAT_UNVID(I) = [L]UNVDELID(K) & !find([L]ETAT_ID(I),[L]S_ETATID(0..dim([L]S_ETATS)-1))  & [L]ETAT_F_CUID(I)=[L]EDOSALL
    Wrseq "e;del;"+[L]ETAT_ID(I)+";0;"+[L]ETAT(I) Using [D1]
    M = 1
   Endif
  Next
  If M
   Wrseq "u;del;"+[L]UNVDELID(K)+";0;"+[L]UNVDEL(K) Using [D1]
  Endif
 Next

 ## Copie des etats vers le repertoire ALL
 J=0
 For I=0 To [L]I_NBETATS-1
  Wrseq "e;mov"+';'+[L]I_ETATID(I)+';'+[L]EDOSALL+";"+[L]I_ETATS(I) Using [D1]
  If !find([L]I_ETAUNVID(I),UNVCOP(0..dim(UNVCOP)-1))
   Wrseq "u;mov;"+[L]I_ETAUNVID(I)+";"+UDOSALL+";"+[L]I_ETATUNV(I)  Using [D1]
   UNVCOP(J) = [L]I_ETAUNVID(I)
   J += 1
  Endif
 Next I

 ## Copie des etats vers le repertoire SPE
 For I=0 To [L]SI_NBETATS-1
  Wrseq "e;mov"+';'+[L]SI_ETATID(I)+';'+[L]SEDOSALL+";"+[L]SI_ETATS(I) Using [D1]
  If !find([L]SI_ETAUNVID(I),UNVCOP(0..dim(UNVCOP)-1))
   Wrseq "u;mov;"+[L]SI_ETAUNVID(I)+";"+UDOSSPE+";"+[L]SI_ETATUNV(I)  Using [D1]
   UNVCOP(J) =    [L]SI_ETAUNVID(I)
   J += 1
  Endif
 Next I

Else
 ### On a pas de repertoire d'indus pour la version actuelle, on la crée ! exemple passage V5->V6
 Call ECR_TRACE(GREPSOLIND-mess(127,148,1)-GREPBI,0) From GESECRAN   :# Le répertoire n'existe pas sous
 Wrseq "u;mov;"+UFOLD_1+";"+UDOS_0+";"+GREPSOLIND Using [D1]
 Wrseq "d;mov;"+EFOLD_1+";"+EDOS_0+";"+GREPSOLIND Using [D1]
Endif

## delete du dossier du BIAR(etat)
Wrseq "d;del"+';'+EFOLD_0+';0;'+GIMPBI Using [D1]

## delete du dossier du BIAR(univers)
Wrseq "u;del"+';'+UFOLD_0+';0;'+GIMPBI Using [D1]

Openo Using [D1]

#Goto TRACES : # CCL

ORDRE = ''+chr$(10)
& +'"'+[M:ATV2]BOTOOL+[M:ATV2]SREP+IMPCMD+'" '
& +'-t "'+[M:ATV2]BOTOOL+'" '
& +'-bo "'+[M:ATV2]BOFILE+'" '
& +'-u "'+[M:ATV2]BOTOOL+'\BO_BASE\shared\lib" '
& +'-param "'+[M:ATV2]FICPARAM +'" '
& +'-logdir "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'" '
& +'-logname "'+'ImpBiar_'+num$(adxuid(1))+'" '
& +'1> "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'ImpBiar_'+num$(adxuid(1))+'.out" '
& +'2> "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'ImpBiar_'+num$(adxuid(1))+'.err"'

ORDSYS(1) = [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\X3Imp_'+num$(adxuid(1))+'.cmd'
If !MAC64
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE) From SUBATV2
Else
 CMDTXT= [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\CMDX3Imp_'+num$(adxuid(1))+'.cmd'
 Call ECRITURE_COMMANDE(CMDTXT,ORDRE)  From SUBATV2
 ORDRE = CMD64+'"'+right$(CMDTXT,instr(1,CMDTXT,"@")+1)+'"'
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)  From SUBATV2
Endif
If GINFO
 Call AFF_VLC(mess(108,148,1),"") From GESECRAN  : # Import fichier Biar
Endif
Call SYSTEME([M:ATV2]MACHINE+':'+[M:ATV2]SERV,ORDSYS,"f",ERR) From ORDSYS

If GTRACE <> ""
 Call FICHIER_OUT([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ImpBiar_'+num$(adxuid(1))+'.out',OUT) From SUBATV2
 Call ECR_TRACE('',0) From GESECRAN
 Call ECR_TRACE (mess(4,139,1)-'ImpBiar_'+num$(adxuid(1))+'.out'-":",OUT) From GESECRAN
 Call AJOUT_TRACE([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ImpBiar_'+num$(adxuid(1))+'.out') From ABICREUNV
 If OUT : OK=0 : Endif
Endif

If filinfo([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ImpBiar_'+num$(adxuid(1))+'.err',7)>0
 If GTRACE <> ""
  Call ECR_TRACE('ImpBiar_'+num$(adxuid(1))-":"-mess(00505,00153,1),1) From GESECRAN
 Else
  Call ERREUR('ImpBiar_'+num$(adxuid(1))-":"-mess(00505,00153,1)) From GESECRAN
 Endif
 OK =0
 Return
Endif
Onerrgo
Return

$RECH_FOLD
Openi [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL Using [R1] #
Iomode adxifs  ""  Using [R1]
Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
Iomode adxium  GUTF8  Using [R1]
Rdseq CLOB  Using [R1]
DEB = instr(0,CLOB,"<Folders_And_Universes")
If !DEB
 If !fstat : Rdseq CLOB  Using [R1] : Endif
 DEB = instr(0,CLOB,"<Folders_And_Universes")
 If !DEB
  Call ECR_TRACE(mess(36,115,1),1) From GESECRAN : # Structure fichier incorrecte
  OK =0
  Return
 Endif
Endif
Openi Using [R1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

DEB = instr(0,CLOB,"<Folders_And_Universes")
CLOB = right$(CLOB,DEB)

DEB = instr(1,CLOB,'Universe Id="')
While DEB>0
 FIN = instr(DEB+13,CLOB,'"')
 UNIVID = seg$(CLOB,DEB+13,FIN-1)

 DEB = instr(DEB,CLOB,'ParentID="')
 FIN = instr(DEB+10,CLOB,'"')
 PARENTID = seg$(CLOB,DEB+10,FIN-1)

 If PARENTID = UDOSALL
  DEB = instr(DEB,CLOB,'Universe="')
  FIN = instr(DEB+10,CLOB,'"')
  CHAINE = seg$(CLOB,DEB+10,FIN-1)
  If CHAINE <> ""
   TAB_UNV(NBUNV) = CHAINE
   TAB_NIV(NBUNV) = val(right$(CHAINE,len(CHAINE)-3))
   TAB_ID(NBUNV)  = UNIVID
   NBUNV +=1
  Endif
 Endif
 DEB = instr(FIN,CLOB,'Universe Id="')
Wend
Return


$TRACES
If GTRACE<>""
 Local Char LIGNE(250)
 Call ECR_TRACE("File properties",0) From GESECRAN : # Création de l'univers
 Openi [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+IMPPRO
 Rdseq LIGNE
 While fstat=0
  If left$(LIGNE,6)="Erreur"
   ERREURS = 1
   Call ECR_TRACE("|"+right$(LIGNE,7),1) From GESECRAN
  Else
   Call ECR_TRACE("|"+LIGNE,0) From GESECRAN
  Endif
  Rdseq LIGNE
 Wend
 Openi
Endif
Return

$FOLD_UNIV_ALL
Gosub LIT_TOOL From ABIMAP

If filinfo([L]FICHIER,7)<0
 OK =0
Endif
OK = 1
DEB = instr(0,CLOB,"<Folders_And_Universes")
CLOB = right$(CLOB,DEB)

DEB = instr(0,CLOB,'Folder CUID="')
While DEB>0
 FIN = instr(DEB+13,CLOB,'"')
 U_DOS_CUID(U_NBDOS) = seg$(CLOB,DEB+13,FIN-1)

 DEB = instr(FIN,CLOB,'Id="')
 FIN = instr(DEB+4,CLOB,'"')
 U_DOS_ID(U_NBDOS) = seg$(CLOB,DEB+4,FIN-1)

 DEB = instr(FIN,CLOB,'Name="')
 FIN = instr(DEB+6,CLOB,'"')
 U_DOSSIER(U_NBDOS) = seg$(CLOB,DEB+6,FIN-1)

 DEB = instr(FIN,CLOB,'ParentID="')
 FIN = instr(DEB+10,CLOB,'"')
 U_DOS_P_ID(U_NBDOS) = seg$(CLOB,DEB+10,FIN-1)

 U_NBDOS +=1
 DEB = instr(FIN,CLOB,'Folder CUID="')
Wend
Return

$FIND_FOLD_MOVE
### Calcul du cuid du folder d'univers de destination
N=find(GREPBI,U_DOSSIER(0..U_NBDOS))
If N = 0 : Return : Endif
UDOS_0 = U_DOS_ID(N-1)
UDOS   = U_DOS_P_ID(N-1)
For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = GREPSOLIND & U_DOS_P_ID(J) =UDOS_0
  UDOS_1 = U_DOS_ID(J)
  Break
 Endif
Next J
For I=0 To U_NBDOS-1
 If U_DOSSIER(I) = GREPBOPROD & U_DOS_P_ID(I) =  UDOS_1
   UDOS_2 = U_DOS_ID(I)
  Break
 Endif
Next I
For K=0 To U_NBDOS-1
 If U_DOSSIER(K) = "ALL" & U_DOS_P_ID(K) = UDOS_2
  FOLDDES = U_DOS_CUID(K)
  UDOSALL = U_DOS_ID(K)
  Break
 Endif
Next K
For K=0 To U_NBDOS-1
 If U_DOSSIER(K) = "SPE" & U_DOS_P_ID(K) = UDOS_2
  FOLDDESSPE = U_DOS_CUID(K)
  UDOSSPE = U_DOS_ID(K)
  Break
 Endif
Next K

### Calcul du cuid du folder d'univers origine

Raz UFOLD_0,UFOLD_1,UFOLD_2,UFOLDALL
If GBOVERSION <"R4"
 For J=0 To U_NBDOS-1
  If U_DOSSIER(J) = "Universes"
   NIV1 = U_DOS_ID(J)
   Break
  Endif
 Next J
Endif
For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = GIMPBI  &  (U_DOS_P_ID(J) = NIV1 or GBOVERSION ="R4")
  UFOLD_0 = U_DOS_ID(J)
  Break
 Endif
Next J
For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = GREPSOLIND & U_DOS_P_ID(J) = UFOLD_0
  UFOLD_1= U_DOS_ID(J)
  Break
 Endif
Next J
For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = GREPBOPROD  & U_DOS_P_ID(J) = UFOLD_1
  UFOLD_2=U_DOS_ID(J)
  Break
 Endif
Next J
For I=0 To U_NBDOS-1
 If U_DOSSIER(I) = "ALL" & U_DOS_P_ID(I) = UFOLD_2
  FOLDORI   = U_DOS_CUID(I)
  UFOLDALL  = U_DOS_ID(I)
  Break
 Endif
Next I
If UFOLD_0=""
 Call ECR_TRACE(GIMPBI-mess(125,148,1)-": KO",0) From GESECRAN
 Goto ERREUR
Endif
Return

LISTE_ALL
N=find(GREPBI,[L]DOSSIER(0..NBDOSSIER))
If N = 0 : Return : Endif
EDOS_0 =  [L]DOS_ID(N-1)
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPSOLIND & [L]DOS_P_ID(I) = EDOS_0
  EDOS_1 = [L]DOS_ID(I)
  Break
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPBOPROD  & [L]DOS_P_ID(I) = EDOS_1
  EDOS_2 = [L]DOS_ID(I)
  Break
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = "ALL" & [L]DOS_P_ID(I) = EDOS_2
  EDOSALL = [L]DOS_ID(I)
  Break
 Endif
Next I
J=0
Call ECR_TRACE(mess(113,148,1)-":",0) From GESECRAN
For I=0 To NBETAT-1
 If [L]ETAT_F_CUID(I) = EDOSALL & [L]ETAT_UNVID(I) <> "" & J< dim([L]ETAT) & find([L]ETAT(I),[L]I_ETATS(0..[L]I_NBETATS))
  [L]A_ETATS(J)    = [L]ETAT(I)
  [L]A_ETATID(J)   = [L]ETAT_ID(I)
  [L]A_ETAIDFAT(J) = [L]ETAT_F_CUID(I)
  [L]A_ETATUNV(J)  = [L]ETAT_UNV(I)
  [L]A_ETAUNVID(J) = [L]ETAT_UNVID(I)
  Call ECR_TRACE(" -"-[L]A_ETATS(J),0) From GESECRAN
  J+=1
 Endif
Next I
[L]A_NBETATS = J
Return

$LISTE_SPE

N=find(GREPBI,[L]DOSSIER(0..NBDOSSIER))
If N = 0 : Return : Endif
SEDOS_0 =  [L]DOS_ID(N-1)
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPSOLIND & [L]DOS_P_ID(I) = SEDOS_0
  SEDOS_1 = [L]DOS_ID(I)
  Break
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPBOPROD  & [L]DOS_P_ID(I) = SEDOS_1
  SEDOS_2 = [L]DOS_ID(I)
  Break
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = "SPE" & [L]DOS_P_ID(I) = SEDOS_2
  SEDOSALL = [L]DOS_ID(I)
  Break
 Endif
Next I
J=0
Call ECR_TRACE(mess(141,148,1)-":",0) From GESECRAN : # Etats présents dans le repertoire SPE
For I=0 To NBETAT-1
 If [L]ETAT_F_CUID(I) = SEDOSALL & [L]ETAT_UNVID(I) <> "" & J< dim([L]ETAT) : # & find([L]ETAT(I),[L]I_ETATS(0..[L]I_NBETATS))
  [L]S_ETATS(J)    = [L]ETAT(I)
  [L]S_ETATID(J)   = [L]ETAT_ID(I)
  [L]S_ETAIDFAT(J) = [L]ETAT_F_CUID(I)
  [L]S_ETATUNV(J)  = [L]ETAT_UNV(I)
  [L]S_ETAUNVID(J) = [L]ETAT_UNVID(I)
  Call ECR_TRACE(" -"-[L]S_ETATS(J),0) From GESECRAN
  J+=1
 Endif
Next I
[L]S_NBETATS = J
Return


$LISTE_IMPORT
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GIMPBI
  EFOLD_0 = [L]DOS_ID(I)
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPSOLIND & [L]DOS_P_ID(I) = EFOLD_0
  EFOLD_1 = [L]DOS_ID(I)
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPBOPROD  & [L]DOS_P_ID(I) = EFOLD_1
  EFOLD_2 = [L]DOS_ID(I)
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = "ALL" & [L]DOS_P_ID(I) = EFOLD_2
  EFOLDALL = [L]DOS_ID(I)
 Endif
Next I
J=0
Call ECR_TRACE(mess(114,148,1)-":",0) From GESECRAN
Call ECR_TRACE("--- ALL :",0) From GESECRAN
For I=0 To NBETAT-1
 If [L]ETAT_F_CUID(I) = EFOLDALL & [L]ETAT_UNVID(I) <> "" & J< dim([L]ETAT)
  [L]I_ETATS(J)    = [L]ETAT(I)
  [L]I_ETATID(J)   = [L]ETAT_ID(I)
  [L]I_ETAIDFAT(J) = [L]ETAT_F_CUID(I)
  [L]I_ETATUNV(J)  = [L]ETAT_UNV(I)
  [L]I_ETAUNVID(J) = [L]ETAT_UNVID(I)
  Call ECR_TRACE(" ***"-[L]I_ETATS(J),0) From GESECRAN
  J+=1
 Endif
Next I
[L]I_NBETATS = J
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = "SPE" & [L]DOS_P_ID(I) = EFOLD_2
  SEFOLDALL = [L]DOS_ID(I)
 Endif
Next I
J=0
Call ECR_TRACE("--- SPE :",0) From GESECRAN
For I=0 To NBETAT-1
 If [L]ETAT_F_CUID(I) = SEFOLDALL & [L]ETAT_UNVID(I) <> "" & J< dim([L]ETAT)
  [L]SI_ETATS(J)    = [L]ETAT(I)
  [L]SI_ETATID(J)   = [L]ETAT_ID(I)
  [L]SI_ETAIDFAT(J) = [L]ETAT_F_CUID(I)
  [L]SI_ETATUNV(J)  = [L]ETAT_UNV(I)
  [L]SI_ETAUNVID(J) = [L]ETAT_UNVID(I)
  Call ECR_TRACE(" ***"-[L]SI_ETATS(J),0) From GESECRAN
  J+=1
 Endif
Next I
[L]SI_NBETATS = J
Return

$INIT_PARAMETRE

Local Clbfile ORDRE(2)
Local Integer STATS,OUT
Local Char    RESULT(GDIMFIC)(1..30)
Local Char    DOCPRO(GDIMFIC)
Local Char    IMPPRO(GDIMFIC)
Local Char    UNIPRO(GDIMFIC)
Local Char    SAVIFS(5),SAVIRS(5)
Local Integer SAVIUM,STAT
Local Char    RETOUR(250)
Local Integer I,J,K,L,M,N,ERR,BALISE
Local Char    WEBILIST(6),WEBIUNV(6),SOLCREA(6),UNIVLIST(6)
Local Char    REPBIS(80),REPBIS21(80),REPBIS22(80)
Local Char    ORDSYS(250)(1..2)
Local Char    FICIMP(250),FICALL(250),DOSBI(30),NIV1(80),NIV2(80),NIV3(80)
Local Char    TAB(20)(0..500),TAB_ID(20)(0..500),TAB_UNV(20)(0..500)
Local Integer DEB,FIN,NBUNV,TAB_NIV(0..500),REPSOL
Local Char    FOLDDESID(20),IMPORT(250)

### hierarchie folders de l'arboresence IMPORT
Local Char    EFOLD_0(80),EFOLD_1(80),EFOLD_2(80),EFOLDALL(80),SEFOLDALL(80)
Local Char    UFOLD_0(80),UFOLD_1(80),UFOLD_2(80),UFOLDALL(80)

### tableau etat Bo du repertoire IMPORT_ALL ???
Local Char    I_ETAIDFAT(20)(0..100)
Local Char    I_ETATID(20)(0..100)
Local Char    I_ETATS(80)(0..100)
Local Char    I_ETATUNV(10)(0..100)
Local Char    I_ETAUNVID(20)(0..100)
Local Integer I_NBETATS

### tableau etat Bo du repertoire IMPORT_SPE???
Local Char    SI_ETAIDFAT(20)(0..100)
Local Char    SI_ETATID(20)(0..100)
Local Char    SI_ETATS(80)(0..100)
Local Char    SI_ETATUNV(10)(0..100)
Local Char    SI_ETAUNVID(20)(0..100)
Local Integer SI_NBETATS

### tableau etat Bo du repertoire ALL
Local Char    A_ETAIDFAT(20)(0..100)
Local Char    A_ETATID(20)(0..100)
Local Char    A_ETATS(80)(0..100)
Local Char    A_ETATUNV(10)(0..100)
Local Char    A_ETAUNVID(20)(0..100)
Local Integer A_NBETATS
Local Char    EDOS_0(80),EDOS_1(80),EDOS_2(80),EDOSALL(80)
Local Char    UDOS(80),UDOS_0(80),UDOS_1(80),UDOS_2(80),UDOSALL(80)

### tableau etat Bo du repertoire SPE
Local Char    S_ETAIDFAT(20)(0..100)
Local Char    S_ETATID(20)(0..100)
Local Char    S_ETATS(80)(0..100)
Local Char    S_ETATUNV(10)(0..100)
Local Char    S_ETAUNVID(20)(0..100)
Local Integer S_NBETATS
Local Char    SEDOS_0(80),SEDOS_1(80),SEDOS_2(80),SEDOSALL(80),UDOSSPE(80)

### Varaible pour la creaation des fichier ini, et la trace lors du move
Local Char    FICBAT(250) , FICVAR(250) , FICREP(250) , FICTRA(250)
Local Char    EXE(50),REPTMP(250)
Local Char    EXTVAR(5) , EXTTXT(5) , EXTBAT(5) , EXTREP(5) , EXTTRA(5)
Local Char    FOLDDES(100), FOLDORI(100),FOLDDESSPE(100)
Local Integer NOLOGO
Local Char    USRBI(100),PWDBI(100),RETOUR(200),PWDBASE(100),USRBASE(100),MACHINEDATA(100)

### tableau des dossiers d'univers
Local Char    FOLDDES(80)
Local Char    U_DOSSIER(80)(0..100)
Local Char    U_DOS_ID(20)(0..100)
Local Char    U_DOS_CUID(50)(0..100)
Local Char    U_DOS_P_ID(20)(0..100)
Local Integer U_NBDOS

### tableau univers a supprimer car present dans le biar
Local Char UNVDEL(80)(0..60),UNVDELID(80)(0..60),UNVCOP(80)(0..60)

### tableau des univers a deplacer
Local Char    D_UNIVERS(50)(0..50),D_IDUNVORI(30)(0..50),D_IDUNVDES(30)(0..50)
Local Integer D_NBUNV

### variable pour le maapping
Local Char CHAINE(100)(0..100)
Local Integer NB

If clalev([M:ATV2])=0 : Local Mask ATV2                [ATV2] : Endif
Call RECHPROP("component.busobj.servername",[M:ATV2]MACHINE,GBIDI1) From INTRUTILA
Call RECHPROP("busobj.adxadmin.port",[M:ATV2]SERV,GBIDI1) From INTRUTILA
Call VARADX("ADXDIR",[M:ATV2]MACHINE+":"+[M:ATV2]SERV,[M:ATV2]REPADXDIR) From ADXD
Call RECHPROP("component.busobj.name",[M:ATV2]COMPBONAM,GBIDI1) From INTRUTILA
[M:ATV2]MACHINE += ":"+[M:ATV2]SERV

### Verif dossier
Local Char    CHEMIN(250)
Local Integer EXISTE
CHEMIN = [M:ATV2]MACHINE+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM
Call EXISTE(CHEMIN,EXISTE) From ORDSYS
If !EXISTE
 Call SYSTEME([M:ATV2]MACHINE,"ae_mkdir"-[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM,"",GBIDI1) From ORDSYS
 Call EXISTE(CHEMIN,EXISTE) From ORDSYS
 If EXISTE=0
  OK = 0 : Call ECR_TRACE(mess(221,133,1),1) From GESECRAN : # Le répertoire distant n'a pas pu être crée
  Return
 Endif
Endif
CHEMIN = [M:ATV2]MACHINE+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\BO_GEN'
Call EXISTE(CHEMIN,EXISTE) From ORDSYS
If !EXISTE
 Call SYSTEME([M:ATV2]MACHINE,"ae_mkdir"-[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\BO_GEN',"",GBIDI1) From ORDSYS
 Call EXISTE(CHEMIN,EXISTE) From ORDSYS
 If !EXISTE
  OK = 0 : Call ECR_TRACE(mess(221,133,1),1) From GESECRAN : # Le répertoire distant n'a pas pu être crée
  Return
 Endif
Endif
Local Char BOVERSION(80)
Call GETBOVERSION(BOVERSION) From INTRUTILA

Return

$CREE_TOOL
Raz [M:ATV2]
[M:ATV2]LANGORI  = "FRA"
[M:ATV2]LANGDES  = "FRA"
[M:ATV2]DATAMORI = ""
[M:ATV2]USRBI    ="Admin"
[M:ATV2]LANGDES  = GLANGUE
[M:ATV2]LANGORI  = GLANGUE
[M:ATV2]SREP     = '\TOOLS\BO\'

### init user et mdp BO
Call RECHPROP("busobj.login.adminusr",[M:ATV2]USRBI,GBIDI1) From INTRUTILA
Call INCRYPT([M:ATV2]USRBI,RETOUR) From INTRUTILA
[M:ATV2]USRBI="CRYPT:"+RETOUR
Call RECHPROP("busobj.login.adminpwd",[M:ATV2]PWDBI,GBIDI1) From INTRUTILA
OK=1
Gosub INIT_SOLUTION From SUBATV2
If !OK : Goto ERREUR : Endif
WEBILIST = "TRUE"
WEBIUNV  = "TRUE"
SOLCREA  = "FALSE"
UNIVLIST = "TRUE"
REPBIS   =  GIMPBI
REPBIS21 = GREPSOLIND
REPBIS22 = GREPBOPROD
IMPORT = GIMPBI
### Verification ! si il n'y a pas de biar a importer on sort de suite
If !DEBUT & IMPORTS=2
 Local Char  ORDRES(250), FIC(30)(1..100)
 Local Integer NBFIC
 If GBOVERSION<>"R4"
  ORDRES = "lsadx -a"-APPLI-"BI biar"
 Else
  ORDRES = "lsadx -a"-APPLI-"BI biar"
 Endif
 Call SYSTEME2(adxmac(0),ORDRES,"",NBFIC,FIC) From ORDSYS
 If NBFIC=0
  Call ECR_TRACE(mess(159,148,1),1) From GESECRAN : # Aucun fichier Biar trouvé
  Call ECR_TRACE("BIAR File Imported is not successfully",1) From GESECRAN
  ERR = 1
  End
 Endif
 DEBUT = 1
Endif

Gosub CRE_PARAM From SUBATV2
Gosub CRE_DOCLISTFILT From SUBATV2
If !OK
 Goto ERREUR
Endif
Gosub GENE_TOOL From SUBATV2
If !OK
 Goto ERREUR
Elsif filinfo([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL,7)<0
 Call ECR_TRACE("|"+[M:ATV2]FICTOOL-":"-mess(101,100,1),1) From GESECRAN
 Goto ERREUR
Endif
Return

$ERREURS
ER = errn
If GTRACE
 Call ECR_TRACE(errm-errmes$(errn),errn) From GESECRAN
Endif
Resume

######################################################################################
## Etiquette écran ABIIMPETA
######################################################################################
Subprog S_FICHIER(VALEUR)
Variable Char    VALEUR()
Local Char ORDRE(250),FIC(250)(1..25),BIAR(250)(0..25)
Local Integer NBFIC,I
If filinfo(filpath("BI","","",nomap),0) <0
 Call ERREUR (mess(86,133,1)+"\|"+filpath("BI","","",nomap)+"|") From GESECRAN
 End
Endif
ORDRE = "lsadx -a"-nomap-"BI biar"
Call SYSTEME2(adxmac(0),ORDRE,"",NBFIC,FIC) From ORDSYS
NBFIC = min(NBFIC,dim(FIC))
For I=1 To NBFIC
 BIAR(I) = FIC(I)
Next I
If NBFIC
 I =0
 Call SAITEX(NBFIC,BIAR,I,mess(108,148,1)) From GESECRAN : # import fichier Biar
 If I
  VALEUR = BIAR(I)
 Endif
Endif
End


Subprog C_FICHIER(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
 Local Char FIC(250)
 FIC = filpath("BI",VALEUR,"biar",nomap)
 If filinfo(FIC,0)<=0
  GMESSAGE = mess(101,100,1)+"\|"+FIC+"|" : # Fichier inexistant
  mkstat = 2 : End
 Else
 Endif
Endif
End
#####################################################################################

