#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
  Case ACTION
    When 'OUVRE' : Gosub OUVRE
    When 'BOUTON' : Gosub BOUTON
    When 'DEBUT'  : Gosub DEBUT
    When 'OK' : Gosub OK
  Endcase
Return

#-----------------------------------------------------------------------------#

$OUVRE

If clalev([F:GST]) = 0 Local File GST[GST] : Endif
If clalev([F:GDL]) = 0 Local File GSTDTL[GDL] : Endif
If clalev([F:GHR]) = 0 Local File GSTHDR[GHR] : Endif
If clalev([F:TCA]) = 0 Local File TABCOUAFF[TCA] : Endif



Return

#-----------------------------------------------------------------------------#

$DEBUT

Call LECMEMO("STD","[M:DIA]","gst") From GMEMO

 Diszo [M:GST0]CPY
 Diszo [M:GST0]FCY
 Affzo [M:GST0]

Return

#-----------------------------------------------------------------------------#

$BOUTON
  Case BOUT
    When 'R' : Gosub GENREPORT
    When 'S' : Gosub SYNCDATA
  Endcase
Return

#-----------------------------------------------------------------------------#

$OK
  Gosub SYNCDATA

  Gosub GENREPORT

Return
#-----------------------------------------------------------------------------#

$SYNCDATA

If clalev([F:TVT]) = 0 Local File TABVAT[TVT] : Endif

Local Integer VALID
VALID = 1

If rowcount([F:GST]) > 0
Raz [F:GDL]
Trbegin [F:GDL]
  For[F:GST]

#    Read[F:GDL]GDL1 = [F:GST]NUM;[F:GST]BPR;[F:GST]VAT;[F:GST]SNS #[F:GST]AMTATI;[F:GST]NETPRINOT;[F:GST]AMTVAT;
#    If fstat = 0
#      [F:GDL] = [F:GST]
#      [F:GDL]VAT = [F:GST]VAT
#      Rewrite[F:GDL]
#    Else
      [F:GDL] = [F:GST]
      [F:GDL]VAT = [F:GST]VAT
      Write[F:GDL]
#    Endif

    If fstat
      GOK = 0 : FIN = 0 :  Call FSTA("GDL") From GLOCK : Goto AB_TR1
      VALID = 0
      Break
    Endif
  Next

  If VALID = 0

  Else
    Commit
  Endif

Endif

#update bas label changes
Filter[F:GDL] Where RPTNUM = '' or RPTNUM = 'SIM'
For[F:GDL]
Read [F:TVT]TVT0 = [F:GDL]VAT;'AUS'
  If fstat = 0
     If [F:TVT]AUS1AGSTSAL = 2 : [F:GDL]AUS1AGSTSAL = '1A' Else [F:GDL]AUS1AGSTSAL = '' Endif
     If [F:TVT]AUS1BGSTPUR  = 2 : [F:GDL]AUS1BGSTPUR = '1B' Else [F:GDL]AUS1BGSTPUR = ''  Endif
     If [F:TVT]AUSG10CAPPUR = 2 : [F:GDL]AUSG10CAPPUR = 'G10' Else [F:GDL]AUSG10CAPPUR = '' Endif
     If [F:TVT]AUSG11NCAPPU = 2 : [F:GDL]AUSG11NCAPPU = 'G11' Else [F:GDL]AUSG11NCAPPU = '' Endif
     If [F:TVT]AUSG1TOTSA = 2 : [F:GDL]AUSG1TOTSA = 'G1' Else [F:GDL]AUSG1TOTSA = '' Endif
     If [F:TVT]AUSG2EXPSAL = 2 : [F:GDL]AUSG2EXPSAL = 'G2' Else [F:GDL]AUSG2EXPSAL = '' Endif
     If [F:TVT]AUSG3GSTFRES = 2 : [F:GDL]AUSG3GSTFRES = 'G3' Else [F:GDL]AUSG3GSTFRES = ''  Endif

      Rewrite [F:GDL]
  Endif
Next




Return

#-----------------------------------------------------------------------------#

$GENREPORT

#Local Libelle REP
Local Libelle QREP
#Local Char     SFCY(GLONFCY)(2)
#Local Char     SCPY(GLONCPY)(2)
Local Char RPTNUM

#validate that all the needed fields were filled out.
If func VALIDATEPARAM = 0
  FIN = 0
  Return
Endif

#Validate if the report is an actual or simmulation
If [M:GST0]RPTTYP = 1
  #if the report is actual confirm that the simmulation was for the same search criteria.
  Read[F:GHR]GHR1 = [M:GST0]STRDAT;[M:GST0]ENDDAT;[M:GST0]FCY;[M:GST0]CPY;[M:GST0]ALLFCY;[M:GST0]ALLCPY
  If fstat = 0
    #Qstbox "Are you sure you want to run the actual report. This action cannot be undone. "  - nomap Using [L]QREP
    #Qstbox mess(15,7704,1)  - nomap Using [L]QREP
    Variable Integer OK

    Call OUINON(mess(15,7704,1),OK)  From GESECRAN
      Case OK
         When 2: Goto ACTUAL #yes
         When 1: FIN = 0 : Return# no
      Endcase
  Else
    GMESSAGE = mess(2,7704,1)
    GERR = 1
    FIN = 0
    Return
  Endif

  #run the actual report and finilize entries
  $ACTUAL
  #assign the report number to the header
  [L]RPTNUM = func CREATERPTNUM
  If [L]RPTNUM <> ""
    Trbegin[F:GHR],[F:GDL]
    [F:GHR]RPTNUM =  [L]RPTNUM
    [F:GHR]RPTTYP = 1
    Rewrite[F:GHR]

     If fstat
      GOK = 0 : FIN = 0 :  Call FSTA("GHR") From GLOCK : Goto AB_TR1
     Else
       Update [F:GDL] Where RPTNUM = "SIM" With RPTNUM = [L]RPTNUM
       If fstat
         GOK = 0 : FIN = 0 :  Call FSTA("GDL") From GLOCK : Goto AB_TR1
       Else
         Commit
         Call GENRPT([L]RPTNUM)
      Endif
     Endif
  Else
    GMESSAGE = mess(4,7704,1)
    GERR = 1
    FIN = 0
    Return
  Endif
Else
  #Validate that there are no existing simmulations pending.
  #if there are, warm the user that the existing one will be over written.
  Filter[F:GHR] Where RPTTYP = 2
  If rowcount([F:GHR]) > 0
    Goto SIM
    #Qstbox "There is already a simmulation in progress. Running the report will overwrite the existing report simmulation. "  - nomap Using [L]QREP
    #Qstbox mess(16,7704,1)  - nomap Using [L]QREP
    #Case [L]QREP
    #   When 1: Goto SIM #yes
    #   When 2: Return# no
    #Endcase
  Else
    $SIM
      #clear previous simmulation
      Trbegin [F:GDL]
      Update [F:GDL] Where RPTNUM = 'SIM' With RPTNUM = ""

      If fstat
        GOK = 0 : FIN = 0 :  Call FSTA("GDL") From GLOCK : Goto AB_TR1
      Else
        Commit
      Endif

      Trbegin[F:GHR],[F:GDL]

      #save header information
      If rowcount([F:GHR]) > 0
        Read[F:GHR]First
        [F:GHR] = [M:GST0]
        [F:GHR]RPTNUM = 'SIM'
        [F:GHR]RUNDAT = date$
        Rewrite [F:GHR]
      Else
        [F:GHR] = [M:GST0]
        [F:GHR]RPTNUM = 'SIM'
        [F:GHR]RUNDAT = date$
        Write [F:GHR]
      Endif


      If !fstat

        #set the search criteria
        #if all sites and companies selected, only apply the date filter.
        If [M:GST0]ALLCPY = 2
          If [M:GST0]ALLFCY = 2
            #Trbegin [F:GDL]
            #update detail table's records to indicate a simmulation
            Update [F:GDL] Where (ACCDAT >= [M:GST0]STRDAT and ACCDAT <= [M:GST0]ENDDAT) and RPTNUM = "" With [F:GDL]RPTNUM = "SIM"

            If fstat
              GOK = 0 : FIN = 0 :  Call FSTA("GDL") From GLOCK : Goto AB_TR1
            Else
              Commit
            Endif
          Endif
        Endif

        #if all sites and spesific companies selected, only apply the date and company filter filter.
        If [M:GST0]ALLCPY = 1
          If [M:GST0]ALLFCY = 2

            #update detail table's records to indicate a simmulation
#           Update [F:GDL] Where (ACCDAT >= [M:GST0]STRDAT and ACCDAT <= [M:GST0]ENDDAT) and find([F:GDL]CPY, SCPY) and RPTNUM = "" With RPTNUM = 'SIM'
            Update [F:GDL] Where (ACCDAT >= [M:GST0]STRDAT and ACCDAT <= [M:GST0]ENDDAT) and [F:GDL]CPY = [M:GST0]CPY and RPTNUM = "" With RPTNUM = 'SIM'

            If fstat
              GOK = 0 : FIN = 0 :  Call FSTA("GDL") From GLOCK : Goto AB_TR1
            Else
              Commit
            Endif
          Endif
        Endif

        #if all Companies and spesific sites selected, only apply the date and sites filter filter.
        If [M:GST0]ALLCPY = 2
          If [M:GST0]ALLFCY = 1

            #Trbegin [F:GDL]
            #update detail table's records to indicate a simmulation
            #Update [F:GDL] Where (ACCDAT >= [M:GST0]STRDAT and ACCDAT <= [M:GST0]ENDDAT) and find([F:GDL]FCY, SFCY) and RPTNUM = "" With RPTNUM = 'SIM'
            Update [F:GDL] Where (ACCDAT >= [M:GST0]STRDAT and ACCDAT <= [M:GST0]ENDDAT) and [F:GDL]FCY = [M:GST0]FCY and RPTNUM = "" With RPTNUM = 'SIM'

            If fstat
              GOK = 0 : FIN = 0 :  Call FSTA("GDL") From GLOCK : Goto AB_TR1
            Else
              Commit
            Endif
          Endif
        Endif

        #if spesific Companies and spesific sites selected, apply the date and sites and company filter filter.
        If [M:GST0]ALLCPY = 1
          If [M:GST0]ALLFCY = 1

            #Trbegin [F:GDL]
            #update detail table's records to indicate a simmulation
            #Update [F:GDL] Where (ACCDAT >= [M:GST0]STRDAT and ACCDAT <= [M:GST0]ENDDAT) and (find([F:GDL]CPY, SCPY) or find([F:GDL]FCY, SFCY)) and RPTNUM = "" With RPTNUM = 'SIM'
            Update [F:GDL] Where (ACCDAT >= [M:GST0]STRDAT and ACCDAT <= [M:GST0]ENDDAT) and [F:GDL]FCY = [M:GST0]FCY  and [F:GDL]CPY = [M:GST0]CPY  and RPTNUM = "" With RPTNUM = 'SIM'

            If fstat
              GOK = 0 : FIN = 0 :  Call FSTA("GDL") From GLOCK : Goto AB_TR1
            Else
              Commit
            Endif
          Endif
        Endif

        #validate if all tax codes are linked to bas labels.
#        Filter[F:GDL] Where RPTNUM = 'SIM' and AUSBAS = ''
#        If rowcount([F:GDL]) > 0
#          GMESSAGE = mess(17,7704,1)
#          GERR = 1
#        Endif

        Call GENRPT('SIM')


      Else
        GOK = 0 : FIN = 0 :  Call FSTA("GHR") From GLOCK : Goto AB_TR1
      Endif

  Endif
  Filter[F:GHR]
Endif

Return


#-----------------------------------------------------------------------------#

Funprog VALIDATEPARAM

#If clalev([F:GST]) = 0 Local File GST[GST] : Endif
Local Integer VALID
VALID = 1

#Validate Company Selection
If [M:GST0]ALLCPY = 1
  If [M:GST0]CPY = ''
    GMESSAGE = mess(7,7704,1)
    GERR = 1
    VALID = 0
    Goto FAILED
  Endif
Endif

#Validate Site Selection
If [M:GST0]ALLFCY = 1
  If [M:GST0]FCY = ''
    GMESSAGE = mess(9,7704,1)
    GERR = 1
    VALID = 0
    Goto FAILED
  Endif
Endif


#Validate Date Selection

  If num$([M:GST0]STRDAT) <> '00/00/0000'
    If num$([M:GST0]ENDDAT) <> '00/00/0000'
      If [M:GST0]ENDDAT < [M:GST0]STRDAT
        GMESSAGE = mess(12,7704,1)
        GERR = 1
        VALID = 0
        Goto FAILED
      Endif
    Endif
  Endif


$FAILED

End VALID

#-----------------------------------------------------------------------------#

Subprog GENRPT(L_RPTNUM)
Value Char L_RPTNUM
#[M:GST0]STRDAT;[M:GST0]ENDDAT;[M:GST0]FFCY;[M:GST0]TFCY;[M:GST0]FCPY;[M:GST0]TCPY;[M:GST0]ALLFCY;[M:GST0]ALLCPY

  Local Integer NBPAR_MAX : NBPAR_MAX=10
  Local Char XTBPAR(20)(1..NBPAR_MAX)
  Local Char XTBVAL(250)(1..NBPAR_MAX)
  Local Char XREPNUM : XREPNUM = 'AUSGST'
  Local Char XDESTINATION : XDESTINATION = 'PREVIEW' #3 PREVISU / MESSPDF

  XTBPAR(1)="RPTNUM" : XTBVAL(1) = L_RPTNUM
  Call ETAT(XREPNUM,"",XTBPAR,XTBVAL) From ETAT
 #Call ETAT(XREPNUM, XDESTINATION,"",0,"",XTBPAR,XTBVAL) From AIMP3

  Call GENLOG(L_RPTNUM)

End

Funprog CREATERPTNUM

Value    Integer TYP
Variable Char    COUNTER
Variable Integer FIN

Local Char     NUMIMP    : # Request number
Local Integer  STAT      : #Status

If !clalev([F:TCA]) : Local File TABCOUAFF  [TCA] : Endif

    Read[F:TCA]TCA0 = 2;'';''
    If fstat = 0
      COUNTER = [F:TCA]CODNUM(18)

      Call NUMERO(COUNTER,"",[0/0/0],"",NUMIMP,STAT) From SUBANM

      #Call NUMERO ([F:TCA]CODNUM(18), L_FCY, L_DAT, L_PAYTYP, L_TASKID, OSTAT) From SUBANM
    Endif

    If STAT
     Gosub MESSAGE From SUBANM
     Call ERREUR(mess(60,199,1)-"("+COUNTER+") : "-MESSA) From GESECRAN
     FIN = 0 : End
    Endif

End NUMIMP

#-----------------------------------------------------------------------------#
Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2
     Diszo [M:GST0]CPY
     #Diszo [M:GST0]FCPY
     Affzo [M:GST0]
  Else
    Actzo [M:GST0]CPY
    #Actzo [M:GST0]FCPY
    Affzo [M:GST0]
  Endif

End

#-----------------------------------------------------------------------------#

Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2
     Diszo [M:GST0]FCY
     #Diszo [M:GST0]FFCY
     Affzo [M:GST0]
  Else
    Actzo [M:GST0]FCY
    #Actzo [M:GST0]FFCY
    Affzo [M:GST0]
  Endif


End

#-----------------------------------------------------------------------------#

$AB_TR1
Rollback
Return

#-----------------------------------------------------------------------------#


Subprog GENLOG(L_RPTNUM)
Value Char L_RPTNUM

Local Char     SFCY(GLONFCY)
Local Char     SCPY(GLONCPY)
Local Char     RPTTYP
Local Char     DETAIL(250)

#open log file
 If !GSERVEUR :
    Call OUVRE_TRACE (time$ + "GST Report Log file") From LECFIC
Else
     Call ECR_TRACE (time$ + "GST Report Log file",0) From GESECRAN
Endif

If [M:GST0]ALLCPY= 2
  SCPY = 'ALL'
Else
  SCPY = [M:GST0]CPY
Endif

If [M:GST0]ALLFCY = 2
  SFCY = 'ALL'
Else
  SFCY = [M:GST0]FCY
Endif

If [M:GST0]RPTTYP = 1
  RPTTYP = 'ACTUAL'
Else
  RPTTYP = 'SIMULATION'
Endif

Call ECR_TRACE('#########################################################################',0) From GESECRAN
Call ECR_TRACE('# Description       : GST Report Log file'+ space$(50-len('GST Report Log file'))+'#',0) From GESECRAN
Call ECR_TRACE('# Creation date     : ' + date$ + space$(52-len(num$(date$)))+'#',0) From GESECRAN
Call ECR_TRACE('# -----------------------------------------------------------------------#',0) From GESECRAN
Call ECR_TRACE('#                     ' + space$(50)+'#',0) From GESECRAN
Call ECR_TRACE('# Criteria          : '+ space$(50)+'#',0) From GESECRAN
Call ECR_TRACE('# Companies         : '+ SCPY + space$(50-len(SCPY))+'#',0) From GESECRAN
Call ECR_TRACE('# Sites             : '+ SFCY + space$(50-len(SFCY))+'#',0) From GESECRAN
Call ECR_TRACE('# Date From         : '+ [M:GST0]STRDAT + space$(52-len(num$([M:GST0]STRDAT)))+'#',0) From GESECRAN
Call ECR_TRACE('# Date To           : '+ [M:GST0]ENDDAT + space$(52-len(num$([M:GST0]ENDDAT)))+'#',0) From GESECRAN
Call ECR_TRACE('# Report Type       : '+ RPTTYP + space$(50-len(RPTTYP))+'#',0) From GESECRAN
Call ECR_TRACE('#                     ' + space$(50)+'#',0) From GESECRAN
Call ECR_TRACE('#                     ' + space$(50)+'#',0) From GESECRAN
Call ECR_TRACE('#------------------------------------------------------------------------# ',0) From GESECRAN
Call ECR_TRACE('##########################################################################',0) From GESECRAN
Call ECR_TRACE('',0) From GESECRAN
Call ECR_TRACE('',0) From GESECRAN
#Call ECR_TRACE('#Detail             : '+ space$(50)+'#',0) From GESECRAN
#Call ECR_TRACE('#                     '+ space$(50)+'#',0) From GESECRAN

Filter [F:GDL] Where RPTNUM = L_RPTNUM
For[F:GDL]

Raz DETAIL

DETAIL = + '# ' + [F:GDL]BPR
DETAIL += '   ' + [F:GDL]NUM
DETAIL += '   ' + num$([F:GDL]AMTATI)
DETAIL += '   ' + num$([F:GDL]NETPRINOT) #num$([F:GDL]NETPRINOT)
DETAIL += '   ' + num$([F:GDL]AMTVAT) #num$([F:GDL]AMTVAT)
DETAIL += '   ' + [F:GDL]VAT #[F:GDL]VAT

If [F:GDL]AUS1AGSTSAL = '' and [F:GDL]AUS1BGSTPUR = '' and [F:GDL]AUSG10CAPPUR = '' and [F:GDL]AUSG11NCAPPU = '' and [F:GDL]AUSG1TOTSA = '' and [F:GDL]AUSG2EXPSAL = '' and [F:GDL]AUSG3GSTFRES = ''
  DETAIL += ' : No BAS label assigned'

  Call ECR_TRACE(' '+ DETAIL + space$(100-len(DETAIL))+'#',1) From GESECRAN
Else

  If [F:GDL]AUS1AGSTSAL <> ''
    DETAIL +=  ' : ' + [F:GDL]AUS1AGSTSAL
  Endif

  If [F:GDL]AUS1BGSTPUR <> ''
    DETAIL +=  ' : ' + [F:GDL]AUS1BGSTPUR
  Endif

  If [F:GDL]AUSG10CAPPUR <> ''
    DETAIL +=  ' : ' + [F:GDL]AUSG10CAPPUR
  Endif

  If [F:GDL]AUSG11NCAPPU <> ''
    DETAIL +=  ' : ' + [F:GDL]AUSG11NCAPPU
  Endif

  If [F:GDL]AUSG1TOTSA <> ''
    DETAIL +=  ' : ' + [F:GDL]AUSG1TOTSA
  Endif

  If [F:GDL]AUSG2EXPSAL <> ''
    DETAIL +=  ' : ' + [F:GDL]AUSG2EXPSAL
  Endif

  If [F:GDL]AUSG3GSTFRES <> ''
    DETAIL +=  ' : ' + [F:GDL]AUSG3GSTFRES
  Endif

  Call ECR_TRACE(' '+ DETAIL + space$(100-len(DETAIL))+'#',0) From GESECRAN

Endif

Next

Call ECR_TRACE('###########################################################################',0) From GESECRAN


#close log file
If !GSERVEUR : Call FERME_TRACE From LECFIC : Endif

#display log file
Call LEC_TRACE() From LECFIC

End

