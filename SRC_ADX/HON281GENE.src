#<AdxTL>@(#)2.0.0.0 $Revision$
#*************************************************************************************
#* Requirement 82615  : Belgian declaration of fees 281.5
#* Process HON281GENE : Generation of the 281.5 file reporting fees
#*************************************************************************************

# Issue X3-107197 - 2018-09-11 by CBO : PARAMETER AND ACTIVITY CODE

#*!
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","HON281GENE","HON281GENE",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
 When "SEL_LISTE"   : Gosub SEL_LISTE From HON281DCL
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

#*************************************************************************************
$INIT_DIA
TMP = 1 : TRA = 1
Raz [M]
Return

$OUVRE
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([F:HHO])  : Local File HON281     [HHO]  : Endif
If !clalev([F:DHO])  : Local File HON281D    [DHO]  : Endif
If !clalev([F:TFT])  : Local File TABFILTDS  [TFT]  : Endif

If dim([V]GDIR281DEF)<0 : Global Char GDIR281DEF(GDIMFIC) : Endif  :#-- default storage directory
Return

$SORTIE
If dim([V]GDIR281DEF)>0 : Kill [V]GDIR281DEF : Endif
Return

$EXEC
Call HON281GENE
Return

#*************************************************************************************
Subprog HON281GENE
Local Integer OK
Local Char    TIT(50)
Local Char    SYMBOLE(30)

TIT = mess(97,122,1) :#--Génération fichier déclaration 281.5
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(104,"-"),0) From GESECRAN

#-- display launch parameters setting
Call ECR_TRACE(mess(2,45,1)+" : "+[M:DIA]CPY,0) From GESECRAN       :#--Société
Call ECR_TRACE(mess(2,47,1)+" : "+num$([M:DIA]YEA),0) From GESECRAN :#--Année
#--

SYMBOLE="HON281GENE"+"\"+[M]CPY+"\"+num$([M:DIA]YEA)
Lock =SYMBOLE
If fstat
 # Opération en cours sur autre poste
 Call ECR_TRACE(mess(30,100,1),1) From GESECRAN : End
Endif

Call GENEFIC

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

Unlock =SYMBOLE
End

#*************************************************************************************
Subprog GENEFIC

Local Char    NOMFIC(GDIMFIC), FICDON(GDIMFIC),URL(GDIMFIC)
Local Char    COD(10)     :#-- code of the 281.5 file setting
Local Char    CHAINE(200) :#-- for formulas treatment
Local Integer MAX_FLD     :#-- max fields for one 281.5 record output
Local Integer STAT, WI
Local Char    WSTEMP(12)

#-- evaluated fields (see file setting -
Local Decimal AMTINV      :#-- invoice amount
Local Decimal AMTPAY      :#-- payment amount
Local Integer LININV      :#-- line number of invoice
Local Char JOUTYP         :#-- journal type
#--

Gosub OUVRE

WSTEMP = space$(10)+"> " :#-- for error display during header controls

[L]COD = "FICHE281"
Filter [TFT] Where COD=[L]COD
[L]MAX_FLD=rowcount([TFT])

[L]NOMFIC = "HON281_"+[M:DIA]CPY+"_"+num$([M:DIA]YEA)+"_"+date$+"_"+format$("D:hhmm",date$)

#--
If [M:DIA]TYPEXP=1 : #--initialisation temporary file for client
 Call SET_FICNAM([L]NOMFIC,[L]FICDON,URL) From ORDSYS
Else
 If right$([M:DIA]FICHIER, len([M:DIA]FICHIER))<>"/" : [M:DIA]FICHIER += "/" : Endif
 If right$([M:DIA]VOLFIL, len([M:DIA]VOLFIL))<>"/" : [M:DIA]VOLFIL += "/" : Endif
 [L]FICDON = [M:DIA]FICHIER+[L]NOMFIC
 Call ECR_TRACE(mess(324,197,1)+" : |"+[M]VOLFIL+[L]NOMFIC, 0) From GESECRAN :#-- Nom du fichier en sortie
Endif
Call ECR_TRACE(string$(104,"-"),0) From GESECRAN
#--

Openo [L]FICDON,0                 Using [H281]
Iomode adxifs '"'                 Using [H281]  :#--field separator chr$(34)
Iomode adxirs chr$(13)+chr$(10)   Using [H281]  :#--record separator
Iomode adxium GASCII              Using [H281]  :#--codage mode --ASCII (GUTF8?)

Filter [F:HHO] Where CPY=[M:DIA]CPY & YEA=[M:DIA]YEA

For [F:HHO]HHO0
  Gosub CTRL_DATAS    :#-- control header datas
  Filter [F:DHO] Where CPY=[F:HHO]CPY & YEA=[F:HHO]YEA & PRVNUM=[F:HHO]PRVNUM
  For [F:DHO]DHO1(5)  :#--loop for CPY/YEA/PRVNUM/NUM/TYP281
    Raz [L]AMTINV,[L] AMTPAY, [L]LININV
    [L]JOUTYP = "PUR"
    For [F:DHO]DHO1
      Case [F:DHO]TYPLIN
        When 1
          #-- invoice amount
          [L]AMTINV = [F:DHO]AMTLEDINV  :#--*[F:DHO]SNSINV
          [L]LININV = [F:DHO]LIN
          If [F:DHO]SNSINV<0 : [L]JOUTYP="PUC" : Endif
        When 2
          #-- payment amounts
          [L]AMTPAY += [F:DHO]AMTLEDPAY :#--*[F:DHO]SNSPAY
          If  [L]LININV=0 : [L]LININV=[F:DHO]LIN : Endif
      Endcase
    Next
    Gosub WRITE_H281  :#-- write output record
  Next
  Filter [F:DHO]
Next
Filter [F:HHO]
Filter [TFT]

Openo Using [H281]  :#-- close output

#-- copy server temporary file to client
If [M]TYPEXP=1
 Call COPCLI([L]FICDON,[L]NOMFIC,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN=1 : End
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN=1 :End
 Endif
 Call EFFACE([L]FICDON,STAT) From ORDSYS
 Call ECR_TRACE(string$(104,"-"),0) From GESECRAN
 Call ECR_TRACE(mess(178,115,1),0) From GESECRAN
 Call ECR_TRACE(string$(104,"-"),0) From GESECRAN
Endif
End
#--

#--------
$WRITE_H281
#--------
Raz [L]WI
For [TFT]TFT0 Where COD=[L]COD
 [L]WI +=1
 If [F:TFT]FRM=""
  [L]CHAINE = ""
 Else
  Onerrgo ERR
  [L]CHAINE = num$(evalue([F:TFT]FRM))
  Onerrgo
 Endif
 If [L]WI < [L]MAX_FLD
  Wrseq [L]CHAINE , Using [H281]
 Else
  Wrseq [L]CHAINE   Using [H281]
 Endif
Next
Return

$ERR
# Erreur en évaluation de la formule
Call ECR_TRACE(mess(65,106,1)-[F:TFT]FRM,1) From GESECRAN
Resume

#----------
$CTRL_DATAS
#----------
#--Création fiche pour le prestataire #
Call ECR_TRACE(func AFNC.MES(mess(96,122,1),[F:HHO]PRVNUM),0) From GESECRAN
If [F:HHO]PHYPSL=1 & [F:HHO]PRVNAM=""
  # Raison sociale non renseignée
  Call ECR_TRACE(WSTEMP+mess(95,122,1),0) From GESECRAN
Endif
If [F:HHO]PHYPSL=2 & [F:HHO]SURNAM=""
  # Nom du prestataire non renseigné
  Call ECR_TRACE(WSTEMP+mess(90,122,1),0) From GESECRAN
Endif
If [F:HHO]STREETNUM+[F:HHO]STREET=""
  # Numéro et nom rue non renseignés
  Call ECR_TRACE(WSTEMP+mess(91,122,1),0) From GESECRAN
Endif
If [F:HHO]POSCTY =""
  # Ville non renseignée
  Call ECR_TRACE(WSTEMP+mess(92,122,1),0) From GESECRAN
Endif
If [F:HHO]LAN =""
  # Langue non renseignée
  Call ECR_TRACE(WSTEMP+mess(93,122,1),0) From GESECRAN
Endif
If [F:HHO]NATNUM+[F:HHO]EECNUM=""
  # Numéro national et numéro intracom non renseignés
  Call ECR_TRACE(WSTEMP+mess(94,122,1),0) From GESECRAN
Endif
Return

######################################################################################
# Gestion du masque HON281GENE
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("FEE") and func AFNC.PARAM("DCLFEES", VALEUR)<>"4" # Issue X3-107197
  # Société non définie pour traiter la 281.5
  GMESSAGE=mess(87,122,1)
  mkstat=2
  End
Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
#-- determination of the default directory for the output file storage
Local Char DIRDEF(GDIMFIC)
Raz [L]DIRDEF
Call PARAM(VALEUR, "DIR281DEF", [L]DIRDEF) From ADOVAL
If  [L]DIRDEF="" : [L]DIRDEF="[TMP]" : Endif
If [L]DIRDEF<>"" and right$([L]DIRDEF, len([L]DIRDEF))<>"/" : [L]DIRDEF += "/" : Endif
[V]GDIR281DEF=[L]DIRDEF
If [M]TYPEXP=2
 [M]VOLFIL=[V]GDIR281DEF
 Affzo [M]VOLFIL
Endif
End

#--
Subprog AS_YEA(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : End : Endif
Filter [F:HHO] Where CPY=[M:DIA]CPY

Read [F:HHO]HHO0 Last
If fstat
  VALEUR = year(date$)-1
Else
  VALEUR = [F:HHO]YEA :#--year of last extraction
Endif
Filter [F:HHO]
End

Subprog C_YEA(VALEUR)
Variable Decimal VALEUR
Read [F:HHO]HHO0=[M:DIA]CPY;VALEUR
If fstat
  # Il n'y a pas eu d'extraction des fiches 281.5 sur l'année #
  GMESSAGE= func AFNC.MES(mess(89,122,1),num$(VALEUR))
  mkstat=2
Endif
End

#--
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
  # Le poste client est inaccessible en batch
  GMESSAGE = mess(163,141,1)
  mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
Local Char NOMIMP(GDIMFIC)
If VALEUR=1
 Raz [M:DIA]VOLFIL
 Grizo [M:DIA]VOLFIL
Else
 [M:DIA]VOLFIL = [V]GDIR281DEF
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FICHIER,E_TYPE_FOLDER,GMESSAGE)
End

Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
Local Char TMP(250)
Gosub ENUM_VOLFIL_TYPE From ASYRSTO
If func ASYRSTO.CTL_VOLFIL(2,VALEUR,TMP,E_TYPE_FOLDER,GMESSAGE)<>0
 OK = 0 : End
Endif
End

