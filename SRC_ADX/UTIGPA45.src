#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIGPA45  Modification de la table SENTENCES afin que les intitulés
# soient stockés dans ATEXTRA                                            #
##########################################################################
# DM 101362 - 09.2014 by MM
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("storage labels SENTENCES table in ATEXTRA table") From LECFIC
    Call MAJ_UTIGPA45(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog MAJ_UTIGPA45(DOSSIER)
Value Char DOSSIER
Local Char WLAN(GLONLAN)
Local Char TEXDEF(250),TEXUNI(250)
Local Integer I,J
Local Char WCOD(15)

Call ECR_TRACE("UTIGPA45 : Start of process on : "+DOSSIER,0) From GESECRAN

If filinfo(filpath("FIL","SENTENCES","fde",DOSSIER),0) <= 0     End Endif

#----- Ouverture des fichiers -----#
Local File =DOSSIER+".ATEXTRA"   [AXX]
Local File =DOSSIER+".SENTENCES" [RSY]
Local File =DOSSIER+".AOBJLST"   [AOL]

WLAN = GLANGUE

# 102915 dans le cas où on repasse pls fois la moulinette
If dim([F:RSY]LAN)>0
  Call DEBTRANS From GLOCK
  Trbegin [AXX]
   For [RSY]RSY1(1)
    TEXDEF=""
    TEXUNI=""
    I=0 : J=0
    WCOD = [F:RSY]RSY

    For [RSY]RSY1
     I+=1

      GLANGUE= [F:RSY]LAN
      Call MAJTEXTRA([F:RSY]RSYDES,"SENTENCES","DESAXX",[F:RSY]RSY,"") From ATEXTRA
      Call MAJTEXTRA([F:RSY]RSYSHO,"SENTENCES","SHOAXX",[F:RSY]RSY,"") From ATEXTRA

    # Si texte existe dans la langue de référence, on le récupère en priorité,
    # sinon, si texte existe dans une ou pls autres langues, on récupère le premier trouvé
      If [F:RSY]RSYTEX<>""
          If GLANGUE=GLANDEF
             TEXDEF=[F:RSY]RSYTEX
          #Endif
          Else
              J+=1
              If J=1
                 TEXUNI= [F:RSY]RSYTEX
              Endif
          Endif
      Endif

      If I>1
         Delete [RSY]
      Endif
    Next

    Read [RSY]RSY1(1) = WCOD
    If !fstat
        If TEXDEF <>""
           [F:RSY]RSYTEX = TEXDEF
        Else
           [F:RSY]RSYTEX = TEXUNI
        Endif
        [F:RSY]LAN = ""
        Rewrite [RSY]
    Endif
  Next

  Read [AOL]AOL0="RSY"
  If !fstat
    Raz [F:AOL]SELFIC,[F:AOL]SELINT,[F:AOL]SELZON
    # nouveau paramétrage de l'objet RSY
    [F:AOL]SELFIC(0)="SENTENCES"
    [F:AOL]SELZON(0)="RSY"
    [F:AOL]SELFIC(1)="ATEXTRA"
    [F:AOL]SELZON(1)="TEXTE"
    [F:AOL]NBSEL= 2
    Rewrite [F:AOL]
    If fstat
       Call ECR_TRACE("AOL: can't update object RSY",1) From GESECRAN
    Endif
  Else
    Call ECR_TRACE("RSY: ABREV not find in AOBJLST",1) From GESECRAN
  Endif

  Commit

Endif
Close Local File [RSY],[AXX],[AOL]

GLANGUE = WLAN
Call ECR_TRACE("UTIGPA45 : End Process",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIGPA45(APPLI)

End


#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  Call MAJ_UTIGPA45(APPLI)
End
