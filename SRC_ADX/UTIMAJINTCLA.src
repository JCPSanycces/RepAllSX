#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Initialisation of short description
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("init short description") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#

#----------------------------------------------------------------------------------------#
$MAJTAB

If DOSSIER=nomap
 Local File ACLASSE [ACLA]
 Local File ACLAFLD [ACLAF]
 Local File ATABZON [ATZ]
 Local File ACLALNK [ACLAK]
 Local File ASHWEXPPRO [ASWR]
 Local File ASHWFLD [ASWF]
 Local File ACONTEXT [ACTX]
 Local File ASHW [ASW]
 Local File ACLACOL [ACLAC]
 Local File ASHWCOL [ASWC]
 Local File ACONTEXT [ACTX2]
Else
 Local File =DOSSIER+".ACLAFLD" [ACLAF]
 Local File =DOSSIER+".ATABZON" [ATZ]
 Local File =DOSSIER+".ACLASSE" [ACLA]
 Local File =DOSSIER+".ACLALNK" [ACLAK]
 Local File =DOSSIER+".ASHWEXPPRO" [ASWR]
 Local File =DOSSIER+".ASHWFLD" [ASWF]
 Local File =DOSSIER+".ACONTEXT" [ACTX]
 Local File =DOSSIER+".ASHW" [ASW]
 Local File =DOSSIER+".ACLACOL" [ACLAC]
 Local File =DOSSIER+".ASHWCOL" [ASWC]
 Local File =DOSSIER+".ACONTEXT" [ACTX2]
Endif


Local Char TBCLA(GLONACLA)(1..)
Local Char WCODCLA(GLONACLA),WTABREF(GLONATB)
Local Integer NBCLA

Trbegin [ACLAF]
 For [ACLA] Where TYPCLA=2
  Gosub TRT_ACLA
 Next
 For [ACLA] Where TYPCLA<>2
  Gosub TRT_ACLA
 Next
 For [ASWF]
  Gosub MAJ_ASWF
 Next
 For [ASW]
  For [ASWR]  Where CODREP=[ASW]CODREP
  Gosub TRT_ASWR
 Next
Next
Commit


Close Local File [ACLA],[ACLAF],[ATZ],[ACLAK],[ASWR],[ASWF],[ACTX],[ASW],[ACTX2]

Return

##----------------------------------------------------------------------------------------#
$TRT_ASWR
If [F:ASWR]INTSHTPRO = 0
 Local Char TABCLA(80)(1..50)
 Local Char TABPTR(80)(1..50),OBJ(50)
 Local Integer NBCLA,OKALIAS,ISACTX,MODIF

 Raz TABPTR,TABCLA,OBJ,ISACTX,NBCLA,MODIF
 Call DECODE_PRO([F:ASWR]CODPRO,0,"PRO",[L]DOSSIER,[ASWR]CODREP,[ASW]ABRCLA,[ASW]CODCLA,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
 If (NBCLA>1 & TABCLA(NBCLA)="") or NBCLA=0
   # rien
 Elsif NBCLA>=1
 If TABCLA(NBCLA)=""
   If !ISACTX
    Read [ASWF]ASWF0 = [F:ASWR]CODREP;OBJ
    If !fstat
     [F:ASWR]INTSHTPRO = [ASWF]INTSHTFLD
     MODIF = 1
    Endif
   Else
    Read [F:ACTX]ACTX0 = OBJ
    If !fstat &  len(func AFNC.LANTEXTE(GLANGUE,[ACTX]INTIT))<= 20
     [F:ASWR]INTSHTPRO = [ACTX]INTIT
     MODIF = 1
    Endif
   Endif
  Else
   Read [ACLAF]ACLAF0 = TABCLA(NBCLA);OBJ
   If !fstat
    [F:ASWR]INTSHTPRO = [ACLAF]INTSHTFLD
    MODIF = 1
   Endif
  Endif
 Endif
 If [F:ASWR]INTSHTPRO =0 &   [F:ASWR]INTPRO>0 &  len(func AFNC.LANTEXTE(GLANGUE, [F:ASWR]INTPRO))<= 20
  [F:ASWR]INTSHTPRO =  [F:ASWR]INTPRO
  MODIF=1
 Endif
 If MODIF=1
  Rewrite [ASWR]
  If fstat
   Call ERREUR("ASHWEXPPRO"-[ASWR]CODREP-"~"-[ASWR]CODPRO,2) From DOSDIC
  Endif
 Endif
Endif
Return

#----------------------------------------------------------------------------------------#
$TRT_ACLA
[L]WCODCLA = [F:ACLA]CODCLA
[L]WTABREF =  [F:ACLA]TABREF
Gosub MAJ_ACLAF
If [ACLA]TYPCLA = 2
 For [ACLAK] Where CODCLA= [ACLA]CODCLA
  [L]WCODCLA = [ACLAK]CLALNK
  [L]WTABREF  = [ACLAK]TABLNK
  Gosub MAJ_ACLAF
 Next
Endif
Return

#----------------------------------------------------------------------------------------#
$MAJ_ACLAF

If find([L]WCODCLA,TBCLA(1..NBCLA))>0 : Return : Endif

Local Integer MODIF
For [ACLAF] Where CODCLA=[L]WCODCLA
 MODIF = 0
 If [ACLAF]INTSHTFLD=0
  If [L]WTABREF<>""
   Read [ATZ]CODZONE =[L]WTABREF;[ACLAF]FLDCLA
   If !fstat
    If [F:ATZ]NOABREG>0
     [ACLAF]INTSHTFLD = [F:ATZ]NOABREG
     MODIF =1
    Elsif [F:ATZ]NOCOURT>0
     [ACLAF]INTSHTFLD = [F:ATZ]NOCOURT
     MODIF = 1
    Endif
   Endif
  Endif
  If [ACLAF]INTSHTFLD=0 &  [ACLAF]INTFLD>0 &  len(func AFNC.LANTEXTE(GLANGUE,[ACLAF]INTFLD))<= 20
   [ACLAF]INTSHTFLD = [ACLAF]INTFLD
   MODIF = 1
  Endif
  If MODIF = 1
   Rewrite [ACLAF]
   If fstat
    Call ERREUR("ACLAFLD"-[ACLAF]CODCLA-"~"-[ACLAF]FLDCLA,2) From DOSDIC
   Endif
  Endif
 Endif
Next

NBCLA += 1
TBCLA(NBCLA) = [L]WCODCLA
Return

#----------------------------------------------------------------------------------------#
$MAJ_ASWF
If [F:ASWF]INTSHTFLD=0
 If [F:ASWF]INTFLD>0 &  len(func AFNC.LANTEXTE(GLANGUE,[F:ASWF]INTFLD))<= 20
  [F:ASWF]INTSHTFLD = [F:ASWF]INTFLD
  Rewrite [F:ASWF]
  If fstat
   Call ERREUR("ASHWFLD"-[F:ASWF]CODREP-"~"-[F:ASWF]CODFLD,2) From DOSDIC
  Endif
 Endif
Endif
Return
