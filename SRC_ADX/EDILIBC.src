Funprog GET_PROTOPATH(WALIAS, WEXPRESSION, WREPCOD)
Value Char WALIAS
Value Char WEXPRESSION
Value Char WREPCOD

  Local Char WPROTOPATH(250) : WPROTOPATH = ""
  Local Char WTMPSTR(250)    : WTMPSTR = ""

  Local Integer I, J

  Local Char WEXPRESSION_TAB(60)(1..)
  Local Char WCARDINALITY_TAB(3)(1..)
  Local Char WLNKCLA_TAB(60)(1..)
  Local Char WCARDINALITY(3)
  Local Char WPATH_TAB(250)(1..)
  Local Integer WCASE_LEVEL_TAB(1..)

  Local Char WLNKCLA(20)
  Local Char WCODCLA(20)  #dataclass linked to the Representation
  Local Char WABRCLA(8)   #instance name of the dataclass linked to the Representation

  Local Integer WISALONE : WISALONE = [V]CST_AFALSE
  Local Integer WISALONE_FLG : WISALONE_FLG = [V]CST_AFALSE

  #1 - get main class info
  Local File ASHW [ASW]
  Read [ASW]ASW0 = WREPCOD
  If !fstat
    WCODCLA = [ASW]CODCLA
    WABRCLA = [ASW]ABRCLA
  Else
    #
  Endif
  LogicClose File [ASW]
  #/get main class info


  #2 - split path into an array
  Local Integer WFOUND   : WFOUND   = [V]CST_AFALSE
  Local Integer WFOUND_I : WFOUND_I = 0
  J = 0
  For I = 1 To len(WEXPRESSION)
    If mid$(WEXPRESSION, I, 1) = "." and WFOUND = [V]CST_AFALSE
      J = J + 1
      WEXPRESSION_TAB(J) = left$(WEXPRESSION, I-1)
      WFOUND = [V]CST_ATRUE
      WFOUND_I = I
    Elsif mid$(WEXPRESSION, I, 1) = "." and WFOUND = [V]CST_ATRUE
      J = J + 1
      WEXPRESSION_TAB(J) = mid$(WEXPRESSION, WFOUND_I+1, I-WFOUND_I-1)
#      WFOUND = [V]CST_ATRUE
      WFOUND_I = I
    Endif
  Next I
  If WFOUND = [V]CST_ATRUE
    J = J + 1
    WEXPRESSION_TAB(J) = right$(WEXPRESSION, WFOUND_I + 1)
  Else
    J = J + 1
    WEXPRESSION_TAB(J) = WEXPRESSION
  Endif
  #/split path into an array


  #3 - get cardinality  and type for each level
  For I = 1 To maxtab(WEXPRESSION_TAB())
    If I = 1
      If WEXPRESSION_TAB(I) = WABRCLA
        WCARDINALITY_TAB(I) = ""
        WLNKCLA_TAB(I)      = ""
        WCASE_LEVEL_TAB(I) = 1 #it's the dataclass instance name
      Elsif func PROTOPATH_FIND_COLL_IN_REP(WEXPRESSION_TAB(I), WREPCOD, WCARDINALITY, WISALONE) = [V]CST_ATRUE
        WISALONE_FLG = WISALONE
        WCARDINALITY_TAB(I) = WCARDINALITY
        WLNKCLA_TAB(I)      = ""
        WCASE_LEVEL_TAB(I) = 2 #it's a rep collection
      Else
        WCARDINALITY_TAB(I) = ""
        WLNKCLA_TAB(I)      = ""
        WCASE_LEVEL_TAB(I) = 3 #it's a rep property
      Endif
    Elsif I = 2
      If WCASE_LEVEL_TAB(I-1) = 3
#        #impossible
      Elsif WCASE_LEVEL_TAB(I-1) = 2
        ##it's a rep collection property
        WCARDINALITY_TAB(I) = ""
        WLNKCLA_TAB(I)      = ""
        WCASE_LEVEL_TAB(I)    = 21
      Else # WCASE_LEVEL_TAB(I-1) = 1
        #ouvrir la classe metier, chercher si c'est une collection,
        If func PROTOPATH_GET_CLASS_INFO(WCODCLA, WEXPRESSION_TAB(I), WCARDINALITY, WLNKCLA) = [V]CST_ATRUE
          #it's a dataclass collection linked to a childclass
          WCARDINALITY_TAB(I) = WCARDINALITY
          WLNKCLA_TAB(I)      = WLNKCLA
          WCASE_LEVEL_TAB(I) = 11
        Elsif func PROTOPATH_FIND_COLL_IN_CLASS(WCODCLA, WEXPRESSION_TAB(I), WCARDINALITY, WISALONE) = [V]CST_ATRUE
          WISALONE_FLG = WISALONE
          #it's a dataclass collection
          WCARDINALITY_TAB(I) = WCARDINALITY
          WLNKCLA_TAB(I)      = ""
          WCASE_LEVEL_TAB(I) = 11
        Else
          #it's a dataclass property
          WCARDINALITY_TAB(I) = ""
          WLNKCLA_TAB(I)      = ""
          WCASE_LEVEL_TAB(I) = 12
        Endif
      Endif
    Else
      #######
      If WCASE_LEVEL_TAB(I-1) = 11
        #it's a collection of the dataclass collection
        #loop
        WCODCLA = WLNKCLA_TAB(I-1)
        If func PROTOPATH_GET_CLASS_INFO(WCODCLA, WEXPRESSION_TAB(I), WCARDINALITY, WLNKCLA) = [V]CST_ATRUE
          #it's a dataclass collection linked to a dataclass
          WCARDINALITY_TAB(I) = WCARDINALITY
          WLNKCLA_TAB(I)      = WLNKCLA
          WCASE_LEVEL_TAB(I) = 11
          ##
        Elsif func PROTOPATH_FIND_COLL_IN_CLASS(WCODCLA, WEXPRESSION_TAB(I), WCARDINALITY, WISALONE) = [V]CST_ATRUE
          WISALONE_FLG = WISALONE
          #it's a dataclass collection
          WCARDINALITY_TAB(I) = WCARDINALITY
          WLNKCLA_TAB(I)      = ""
          WCASE_LEVEL_TAB(I) = 11
        Else
          #it's a dataclass property
          WCARDINALITY_TAB(I) = ""
          WLNKCLA_TAB(I)      = ""
          WCASE_LEVEL_TAB(I) = 12
        Endif
      Elsif WCASE_LEVEL_TAB(I-1) = 12
        #it's a property of the dataclass collection
        WCARDINALITY_TAB(I) = ""
        WLNKCLA_TAB(I)      = ""
        WCASE_LEVEL_TAB(I) = 12
      Else
        #err
      Endif
      #######
    Endif
  Next I
  #/#get cardinality  and type for each level

  #4 - generate prototype path
  WFOUND_I = 0
  J = 0
  For I = 1 To maxtab(WEXPRESSION_TAB())-1
    WTMPSTR = WTMPSTR + WEXPRESSION_TAB(I)
    If I > WFOUND_I and (WCARDINALITY_TAB(I) = "1-n" or WCARDINALITY_TAB(I) = "0-n" or WCARDINALITY_TAB(I) = "n-n")
      WFOUND_I = I
      J = J + 1
      WPATH_TAB(J) = WTMPSTR
    Endif
  Next I
  J = J + 1
#  WPATH_TAB(J) = WALIAS

  #special management if property is unique in a collection --> no alias in path !
  If J > 1
    Local Char WDOT_TAB(1)(1..maxtab(WPATH_TAB()))
    For K = 1 To maxtab(WPATH_TAB())
      WDOT_TAB(K) = "."
    Next K
    If WISALONE_FLG = [V]CST_ATRUE
      WPATH_TAB(J) = ""
      WDOT_TAB(J-1) = ""
    Else
      WPATH_TAB(J) = WALIAS
      WDOT_TAB(J-1) = "."
    Endif
  Else
    WPATH_TAB(J) = WALIAS
  Endif
  #generation path
  For J = 1 To maxtab(WPATH_TAB())-1
    WPROTOPATH = WPROTOPATH + WPATH_TAB(J) + WDOT_TAB(J) #+ "."
  Next J
  WPROTOPATH = WPROTOPATH + WPATH_TAB(J)
  #/generate prototype path
End WPROTOPATH


Funprog PROTOPATH_FIND_COLL_IN_REP(WCODCOL, WREPCOD, WCARDINALITY, WISALONE)
Value Char WCODCOL
Value Char WREPCOD
Variable Char WCARDINALITY
Variable Integer WISALONE

  Local Integer WOK : WOK = [V]CST_AFALSE
  Local Integer WMIN, WMAX

  Local File ASHWCOL [ASWC]
  Read [ASWC]ASWC0 = WREPCOD;WCODCOL
  If !fstat
    WOK = [V]CST_ATRUE
    If [ASWC]ACTCOL <> ""
      Local File ACTIV [ACV]
      Read [ACV]CODACT = [ASWC]ACTCOL
      If !fstat
        WMIN = [ASWC]MINCOL #[ACV]DIMFIL
        WMAX = [ACV]DIME #DIMMAX
      Endif
      LogicClose File [ACV]
    Else
      WMIN =  [ASWC]MINCOL
      WMAX =  [ASWC]MAXCOL
    Endif
    WCARDINALITY = func PROTOPATH_GET_CLASS_CARDINALITY(WMIN, WMAX)
  Else
    #err
    WOK = [V]CST_AFALSE
  Endif
  LogicClose File [ASWC]


  WISALONE = func PROTOPATH_PROPERTY_IS_ALONE_IN_COL_INTO_REP(WREPCOD)
End WOK

Funprog PROTOPATH_FIND_COLL_IN_CLASS(WCODCLA, WCODCOL, WCARDINALITY, WISALONE)
Value Char WCODCLA
Value Char WCODCOL
Variable Char WCARDINALITY
Variable Integer WISALONE

Local Integer WOK : WOK = [V]CST_AFALSE
Local Integer WMIN, WMAX

  Local File ACLACOL [ACLAC]
  Read [ACLAC]ACLAC0 = WCODCLA;WCODCOL
  If !fstat
    If [ACLAC]ACTCOL <> ""
      Local File ACTIV [ACV]
      Read [ACV]CODACT = [ACLAC]ACTCOL
      If !fstat
        WMIN = [ACLAC]MINCOL #[ACV]DIMFIL
        WMAX = [ACV]DIME #DIMMAX
        WOK  = [V]CST_ATRUE
#        Else
#          WOK = [V]CST_AFALSE
#          LogicClose File [ACV]
#          End WOK
      Endif
      LogicClose File [ACV]
    Else
      WMIN = [ACLAC]MINCOL
      WMAX = [ACLAC]MAXCOL
      WOK  = [V]CST_ATRUE
    Endif
    WCARDINALITY = func PROTOPATH_GET_CLASS_CARDINALITY(WMIN, WMAX)
  Else
    WOK = [V]CST_AFALSE
  Endif
  LogicClose File [ACLAC]

  WISALONE = func PROTOPATH_PROPERTY_IS_ALONE_IN_COL_INTO_CLASS(WCODCLA)

End WOK

Funprog PROTOPATH_PROPERTY_IS_ALONE_IN_COL_INTO_REP(WCODCLA)
Value Char WCODCLA

  Local Integer WISALONE : WISALONE = [V]CST_AFALSE
  Local Integer I : I = 0

  Local File ASHWFLD [ASWF]
  Filter [ASWF] Where CODREP = WCODCLA
  For [ASWF]
    I = I + 1
  Next
  LogicClose File [ASWF]
  If I > 1
    WISALONE = [V]CST_AFALSE
  Else
    WISALONE = [V]CST_ATRUE
  Endif
End WISALONE

Funprog PROTOPATH_PROPERTY_IS_ALONE_IN_COL_INTO_CLASS(WCODCLA)
Value Char WCODCLA

  Local Integer WISALONE : WISALONE = [V]CST_AFALSE
  Local Integer I : I = 0

  Local File ACLAFLD [ACLAF]
  Filter [ACLAF] Where CODCLA = WCODCLA
  For [ACLAF]
    I = I + 1
  Next
  LogicClose File [ACLAF]
  If I > 1
    WISALONE = [V]CST_AFALSE
  Else
    WISALONE = [V]CST_ATRUE
  Endif
End WISALONE

Funprog PROTOPATH_GET_CLASS_INFO(WCODCLA, WCODCOL, WCARDINALITY, WLNKCLA)
Value Char WCODCLA
Value Char WCODCOL
Variable Char WCARDINALITY
Variable Char WLNKCLA

Local Integer WOK : WOK = [V]CST_AFALSE
Local Integer WMIN, WMAX
#WCODCLA+WCODCOL -> cardinalité
#recherceh dans les lgines pour recuperer le code classse de la colection
  Local File ACLAFLD [ACLAF]
  Read [ACLAF]ACLAF0 = WCODCLA;WCODCOL
  If !fstat
    WLNKCLA = [ACLAF]LNKCLA
    Local File ACLACOL [ACLAC]
    Read [ACLAC]ACLAC0 = WCODCLA;WCODCOL
    If !fstat
      If [ACLAC]ACTCOL <> ""
        Local File ACTIV [ACV]
        Read [ACV]CODACT = [ACLAC]ACTCOL
        If !fstat
          WMIN = [ACLAC]MINCOL #[ACV]DIMFIL
          WMAX = [ACV]DIME #DIMMAX
          WOK  = [V]CST_ATRUE
#        Else
#          WOK = [V]CST_AFALSE
#          LogicClose File [ACV]
#          End WOK
        Endif
        LogicClose File [ACV]
      Else
        WMIN = [ACLAC]MINCOL
        WMAX = [ACLAC]MAXCOL
        WOK  = [V]CST_ATRUE
      Endif
      WCARDINALITY = func PROTOPATH_GET_CLASS_CARDINALITY(WMIN, WMAX)
    Else
      WOK = [V]CST_AFALSE
    Endif
    LogicClose File [ACLAC]
  Else
    WOK = [V]CST_AFALSE
  Endif
  LogicClose File [ACLAF]
End WOK


Funprog PROTOPATH_GET_CLASS_CARDINALITY(WMIN, WMAX)
Value Integer WMIN
Value Integer WMAX
Local Char WCARDINALITY(3)
#WMIN is a value in a local menu :
#WMIN = 1 means the value "0"
#WMIN = 2 means the value "1"
#WMIN = 3 means the value "Max"
#WMAX is a value :
#ex : WMAX = 5 means the value "5"
#exeption : value 0 means "Max"

   Case WMIN
     When 1 #1 means 0 in the local menu
       Case WMAX
         When 0       : WCARDINALITY = "0-n" #0-n
         When 1       : WCARDINALITY = "0-1" #0-1
         When Default : WCARDINALITY = "0-n" #> 1 #0-n fixé
       Endcase
     When 2 #2 means 1 in the local menu
       Case WMAX
         When 0       : WCARDINALITY = "1-n" #1-n
         When 1       : WCARDINALITY = "1-1" #1-1
         When Default : WCARDINALITY = "1-n" #> 1 #1-n fixé
       Endcase
     When 3 #3 means Max in the local menu
       Case WMAX
         When 0       : WCARDINALITY = "n-n" #
         When 1       : WCARDINALITY = "1-1" #n-1 so 1-1
         When Default : WCARDINALITY = "n-n" #> 1 #n-n
       Endcase
    Endcase


End WCARDINALITY

