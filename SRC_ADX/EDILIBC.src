#-----------------------------------------------------------------------------#
# Library for EDI module EDILIBC
# ---EDI/JSON files in MongoDB common calls---
#   JSON_CREATE
#   JSON_UPDATE
#   JSON_DELETE
#   DOC_LIST_DELETE
# ---EDI/Instance path protopath function---
#   GET_PROTOPATH
#-----------------------------------------------------------------------------#


$JSON_CREATE
#  Local Char WERR(250)          : WERR = ""

  Local Clbfile WENTITY_JSON(0) : WENTITY_JSON = ""
  Local Char WENTITY_ETAG(50)   : WENTITY_ETAG = "" #etag of entity when it's stored
  Local Char WJSON_UUID(36)     : WJSON_UUID = ""   #returned
  Local Char WMSG(250)          : WMSG = ""         #returned

#  WOK = func ASYREIP.EXPORT_DATA_DETAIL(this.APARENT, [V]CST_ANO, WENTITY_JSON, WMSG)
  WOK = func ASYREIP.EXPORT_DATA_DETAIL_FULL(this.APARENT, [V]CST_ANO, [V]CST_ATRUE, WENTITY_JSON, WMSG) #X3-74605 JUCON (14/06/2018)
  If WOK = [V]CST_AOK and WENTITY_JSON <> ""
    WOK = func ASYREIP.MDB_CREATE_EDI_ENTITY(WENTITY_JSON, WKEY, WENTITY_TYPE,WENTITY_ETAG,WJSON_UUID,WMSG)
    If WOK = [V]CST_AOK
      this.CACHEUUID = toUuid(WJSON_UUID)
      #"Copying entity in cache : Successful"
      WERR = mess(56,2007,1)-":"-mess(7,2007,1)
      WOK = [V]CST_AINFO
    Else
      #ERROR
      this.CACHEUUID = NullUuid()
      #"Copying entity in cache : Failed"
      WERR = mess(56,2007,1)-":"-mess(9,2007,1)-"("+WMSG+")"
      WOK = [V]CST_AWARNING
    Endif
  Else
    #ERROR
    this.CACHEUUID = NullUuid()
    #"Serializing entity using representation"-WREP: Failed"
    WERR = mess(39,2007,1)-WREP-":"-mess(9,2007,1)-"("+WMSG+")"
    WOK = [V]CST_AWARNING
  Endif
Return

$JSON_UPDATE
  Local Clbfile WENTITY_JSON(0) : WENTITY_JSON = ""
  Local Char WJSON_UUID(36)     : WJSON_UUID = ""   #returned
  Local Char WMSG(250)          : WMSG = ""         #returned

  WOK = func ASYREIP.EXPORT_DATA_DETAIL(this.APARENT, [V]CST_AYES, WENTITY_JSON, WMSG)
  If WOK = [V]CST_AOK and WENTITY_JSON <> ""
    WJSON_UUID = num$(this.CACHEUUID)
    WOK = func ASYREIP.MDB_UPDATE_EDI_ENTITY_UUID(WJSON_UUID, WENTITY_JSON, WMSG)
    If WOK = [V]CST_AOK
      #"Updating entity in cache : Successful"-WJSON_UUID
      WERR = mess(57,2007,1)-":"-mess(7,2007,1)-WJSON_UUID
      WOK = [V]CST_AINFO
    Else
      WOK = fmet this.MET_POST_JSON(WERR)
    Endif
  Else
    this.CACHEUUID = NullUuid()
    #"Serializing entity using representation"-WREP: Failed"
    WERR = mess(39,2007,1)-WREP-":"-mess(9,2007,1)-"("+WMSG+")"
#    WOK = [V]CST_AERROR
    WOK = [V]CST_AWARNING
  Endif
Return

$JSON_DELETE
  Local Char WMSG(250) : WMSG = ""
  Local Char WERR(250) : WERR = ""

  If this.CACHEUUID <> NullUuid()
    WOK = func ASYREIP.MDB_DELETE_EDI_ENTITY_UUID(num$(this.CACHEUUID),WMSG)
    If WOK = [V]CST_AOK
      #"Deleting entity in cache : Successful"-num$(this.CACHEUUID)
      WERR = mess(58,2007,1)-":"-mess(7,2007,1)-num$(this.CACHEUUID)
      this.CACHEUUID = NullUuid()
      WOK = [V]CST_AINFO
    Else
      WOK = func ASYREIP.MDB_DELETE_EDI_ENTITY_ID(WKEY,WENTITY_TYPE,WMSG)
      If WOK = [V]CST_AOK
        #"Deleting entity in cache : Successful"-WKEY
        WERR = mess(58,2007,1)-":"-mess(7,2007,1)-WKEY
        this.CACHEUUID = NullUuid()
        WOK = [V]CST_AINFO
      Else
        #"Deleting entity in cache : failed"-WKEY
        WERR = mess(58,2007,1)-":"-mess(9,2007,1)-WKEY-"("+WMSG+")"
        WOK = [V]CST_AWARNING
      Endif
    Endif
  Else
    WOK = func ASYREIP.MDB_DELETE_EDI_ENTITY_ID(WKEY,WENTITY_TYPE,WMSG)
    If WOK = [V]CST_AOK
      #"Deleting entity in cache : Successful"-WKEY
      WERR = mess(58,2007,1)-":"-mess(7,2007,1)-WKEY
      this.CACHEUUID = NullUuid()
      WOK = [V]CST_AINFO
    Else
       #X3-67156 - Delete EDI XMLfile and XSD
#      #"Deleting entity in cache : failed"-WKEY
#      WERR = mess(58,2007,1)-":"-mess(9,2007,1)-WKEY
#      WOK = [V]CST_AWARNING
      #entity not found ==> not created, it's not an error
      WERR = ""
      WOK = [V]CST_AINFO
      #/X3-67156 - Delete EDI XMLfile and XSD
    Endif
  Endif
Return


$DOC_LIST_DELETE
  Local Char WERR(250)                    : WERR = ""
  Local Integer WFOUND                    : WFOUND = [V]CST_AFALSE
  Local Integer WFUTURE                   : WFUTURE = 0
  Local Clbfile WRESHEAD
  Local Integer WSTATUSCODE
  Local Integer WRES

  Local Char    WVALUES(36)(1..100,1..1) #36 : length of an uuid, 1..10 we don't know how many, 1..1 only one prop to retrieve : uuid

  WSTATUSCODE = func ASYRSAREA.LIST(WFILTERS, WEXPECTED_PROPS, WFUTURE, WRESHEAD, WVALUES)
  #values are stored into WVALUES(1,1), WVALUES(2,1) etc
  If WSTATUSCODE = 200
    For I = 1 To maxtab(WVALUES())
      If WVALUES(I,1) <> ""
        WFOUND = [V]CST_ATRUE
        WRESHEAD = ""
        #supprimer le(s) fichier(s)
        WSTATUSCODE = func ASYRSAREA.REMOVE(WVALUES(I,1), WFUTURE, WRESHEAD, WRES)
        If WSTATUSCODE = 200
          #"Deleting entity in cache : Successful"-WVALUES(I,1)
          WERR = mess(58,2007,1)-":"-mess(7,2007,1)-WVALUES(I,1)
          WOK = [V]CST_AINFO
        Else
          #"Deleting entity in cache : failed"-WVALUES(I,1)
          WERR = mess(58,2007,1)-":"-mess(9,2007,1)-WVALUES(I,1)
          WOK = [V]CST_AWARNING
        Endif
      Endif
    Next I
    If WFOUND = [V]CST_AFALSE
      #error on retrive values
      #"Deleting entity in cache : failed"-WVALUES(I,1)
      WERR = mess(58,2007,1)-":"-mess(9,2007,1)
      WOK = [V]CST_AWARNING
    Endif
  Else
    #error on LIST func
    #"Deleting entity in cache : failed"-WVALUES(I,1)
    WERR = mess(58,2007,1)-":"-mess(9,2007,1)
    WOK = [V]CST_AWARNING
  Endif
Return


