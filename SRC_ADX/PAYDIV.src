#<AdxTL>@(#)154.0.0.0 $Revision$
# Issue 63495 - 2018-01-22 by MDJ : TABLE: unknown variable
###################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
###################################
# Contrôle en saisie des paramètres BPCORDTYP, BPSORDTYP
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
If VALEUR="" : End : Endif
Local File GTYPACCENT [GTE]
Read [GTE]GTE0(1) = VALEUR
If fstat=0 : # Fiche déjà existante
 GMESSAGE=mess(22,100,1) : mkstat=2
Endif
#JOJAC - 2018-08-02 - X3-101878 - START
If PARAM = 'BPCORDTYP' | PARAM = 'BPSORDTYP' | PARAM = 'BPSPROTYP'
  If len(VALEUR) > GLONGTE
    GMESSAGE=func AFNC.MES4(mess(00252,00100,1),PARAM,num$(GLONGTE),"GTE","Document types") : mkstat=2
  Endif
Endif
#JOJAC - 2018-08-02 - X3-101878 - END
End

################################################
Subprog SIGN2(CDASNS,SNS,DUDNUM,DUDLIG,CDE,SIGN)
################################################
Value Libelle    CDASNS, SNS
Value Integer    DUDNUM, DUDLIG, CDE
Variable Integer SIGN
# Local File [DUD]
SIGN=0
Case CDASNS
 When 2 : SIGN=-1 : # Dépense
 When 3 : SIGN=+1 : # Recette
 When Default : # Sens de règlement
  If DUDNUM<>0
   If [F:DUD]ACCNUM<>DUDNUM | [F:DUD]DUDLIG<>DUDLIG
    Read [DUD]DUD1 = DUDNUM;DUDLIG
   Else fstat=0
   Endif
   If fstat=0 : SIGN=[F:DUD]SNS : Endif
  Elsif CDE=1 : SIGN=1
  Elsif CDE=2 or CDE=4 : SIGN=-1
  Endif
  If SIGN=0
   If SNS=1 : SIGN=-1 : Else SIGN=1 : Endif
  Endif
Endcase
#83598 : ajout de la condition sur sens indéterminé (| SNS=3)
If SNS=1 | SNS=3 : SIGN*=-1 : Endif
End

##############################################
Subprog CLIFOU(BPR,PLAN,ACC,SNS,BPRTYP)
##############################################
Variable Libelle BPRTYP
Value Char BPR(), PLAN(), ACC()
Value Integer SNS
# Determine si on a à faire à un règlement client ou fournisseur
# Pour les comptes TVA et la mise à jour du portefeuille tiers

BPRTYP=0
If BPR<>""
 # Local File  [BPR]
 Call LECTURE("BPR",BPR,"") From CONTOBJ
 If fstat=0
  If [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG<>2    : BPRTYP=1 : # Client
  Elsif [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG=2 : BPRTYP=2 : # Fourn
  Endif
 Endif
Endif
If BPRTYP=0
 If [L]PLAN=""
  Call LECMAINPLAN(1,GSOCIETE,PLAN) From CPTDIV
 Endif
 Call LECTURE("GAC",ACC,PLAN) From CONTOBJ
 If fstat=0
  # GH 30/12/99
  # On privilégie les autorisations par type de tiers au champs "Maj solde"
  # Avant on faisait l'inverse ; Modif demandée par D.Camus
  If [F:GAC]AUZBPR(0)=2 & [F:GAC]AUZBPR(1)<>2    : BPRTYP=1 : # Client
  Elsif [F:GAC]AUZBPR(0)<>2 & [F:GAC]AUZBPR(1)=2 : BPRTYP=2 : # Fourn
  Elsif [F:GAC]UPDBLC=2                          : BPRTYP=1 : # Client
  Elsif [F:GAC]UPDBLC=3                          : BPRTYP=2 : # Fournisseur
  Endif
 Endif
Endif
If BPRTYP=0
 If SNS=1 : BPRTYP=2 : Else BPRTYP=1 : Endif
Endif
End

#################################
Subprog PAYCPT(STA,SIT,DAT1,DAT2)
#################################
Value    Char    SIT()
Variable Integer STA
Variable Date    DAT1, DAT2

# 1 -> Saisi et obligatoire
# 2 -> Saisi et facultatif
# 3 -> Non saisi
Local Integer OK
Local Char TIT(80)
DAT1=[0/0/0] : DAT2=[0/0/0] : OK=2
Onerrgo ERREUR From CONTROLE
Local Mask DATCPT [DIA]
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : End : Endif
Raz [M:DIA] : [M:DIA]FCY=SIT : [M:DIA]DACDAT2=2
Case STA
 When 3 : # Mise en portefeuille
  TIT = mess(55,117,1)
  [M:DIA]DACDAT1 = 3
 When 8 : # Remise sur compte intermédiaire
  TIT = mess(132,117,1)
  If [F:TPY]STA3=2
   [M:DIA]DACDAT1 = 1
  Else
   [M:DIA]DACDAT1 = 3
  Endif
 When 9 : # Remise en banque
  TIT = mess(133,117,1)
  If ([F:TPY]STA3=2 or [F:TPY]STA8=2) & [F:TPY]DUDFLG<>2
   [M:DIA]DACDAT1 = 1
  Else
   [M:DIA]DACDAT1 = 3
  Endif
Endcase
Call DIALWIN(OK,TIT,"DPAYCPT") From GESECRAN

If OK<>2 : STA=0 : Else DAT1=[M:DIA]DAT1 : DAT2=[M:DIA]DAT2 : Endif
End

######################################
Subprog INISEC(VALEUR,CODE,CAXE,BPRTYP)
######################################
Variable Char    VALEUR()
Value    Char    CODE
Value    Char    CAXE
Value    Integer BPRTYP

If CAXE = "" : End : Endif

If clalev([F:CDE])=0 : Local File CACCEDEF [CDE] : Endif

Local Integer I, TAB, D, IND, INDAXE, INDAXE2, XX
Local Char    AXE(GLONDIE), IDENT(30), IDENT2(30), SITE(GLONFCY), ZONE(10), ABREV(5), OLDID(30), OLDID2(30)

AXE  = CAXE
Call LECTURE("CDE",GSOCIETE,CODE) From CONTOBJ
If fstat
 Call LECTURE("CDE","",CODE) From CONTOBJ
Endif
If !fstat
 VALEUR = "" : D=len(mess(0,693,1))
 INDAXE = find(AXE,[F:CDE]DIE(0..dim([F:CDE]DIE)-1))
 If INDAXE
  For I=1 To [F:CDE]NBLIG

   TAB = evalue("[F:CDE]CCE"+num$(INDAXE)+"("+num$(I-1)+")")

   GPOINT="INISEC" : Gosub ENTREE From EXEFNC
   If VALEUR<>""  : Break : Endif

   Gosub IDENT

   If VALEUR<>"" : Break : Endif
  Next I
 Endif
Endif
End


$IDENT
If TAB=0 : End : Endif  #issue X3-63495
If TAB<>D & [F:CDE]FLD(TAB-1)<>""
 Onerrgo ERREUR From PAYDIV
 IDENT = evalue([F:CDE]FLD(TAB-1))
 Onerrgo
 If GERREUR : GERREUR=0 : IDENT="" : Endif
 If IDENT<>""
  ZONE = "CCE"
  IDENT2 = ""
  Case TAB
   When 2,3 : If [L]BPRTYP=1 : ABREV = "BPC" : TABLE = "BPCUSTOMER"
              Else           : ABREV = "BPS" : TABLE = "BPSUPPLIER"
              Endif
   When 5  :  ABREV = "AUS" : TABLE = "AUTILIS"
   When 7  :  ABREV = "CPY" : TABLE = "COMPANY"
   When 8  :  ABREV = "FCY" : TABLE = "FACILITY"
   When 9  :  ABREV = "TCU" : TABLE = "TABCUR"
   When 10 :  ABREV = "TVT" : TABLE = "TABVAT"
   When 13 :  ABREV = "BAN" : TABLE = "BANK"
   When 14 :  ABREV = "GAC" : TABLE = "GACCOUNT"  : ZONE = "CCEDEF" : IDENT2 = [F:GAC]COA
   When 21 :  ABREV = "CCE" : TABLE = "CACCE"     : Gosub IDENT From SUBCDEB  #issue X3-63495
   When Default : ABREV=""
  Endcase
  If ABREV<>""
   If evalue("clalev([F:"+ABREV+"])")=0
    Local File =TABLE
   Endif
   Call LECTURE(ABREV,IDENT,IDENT2) From CONTOBJ
   If fstat=0
    Raz INDAXE2
    Onerrgo ERREUR From PAYDIV
    For XX=1 To GOPTCANA
     If AXE=evalue("[F:"+ABREV+"]DIE("+num$(XX-1)+")") : INDAXE2=XX : Break : Endif
    Next
    Onerrgo
    If INDAXE2>0
     Onerrgo ERREUR From PAYDIV
     VALEUR = evalue("[F:"+ABREV+"]"+ZONE+"("+num$(INDAXE2-1)+")")
     Onerrgo
     If GERREUR : GERREUR=0 : VALEUR="" : Elsif VALEUR<>"" : Return : Endif
    Endif
   Endif
  Endif
 Endif
Endif
Return


$ERREUR
GERREUR=1
Resume

