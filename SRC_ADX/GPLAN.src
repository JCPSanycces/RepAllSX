############################################
## Plan de paye. Sous-programmes
############################################

############################################
### Exécution du plan de paye
############################################
Subprog PLAN(BULLETIN,PASAPAS,TYPPAS)
Value    Char    BULLETIN
Variable Integer PASAPAS
Value    Integer TYPPAS
Local Integer ILEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
ILEG=find(GCURLEG,GDOSLEG(1..GNBLEG))
If GPLANOK(ILEG)
  If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) : Endif
 Local File ADOVAL [ADW]
 Call GENPLAN(nomap,1,GCURLEG) From GENPLAN
Endif
If dim(GNBRCRB)<0 : Call DECL_PROFIL(0) : Endif

#JASMI - 2018-01-11 - X3-66753 - START
  Gosub SET_EXCHANGE_RATE
#JASMI - 2018-01-11 - X3-66753 - END

Call PLAN(BULLETIN,PASAPAS,TYPPAS) From ="WP"+GCURLEG+"PLAN"
End

############################################
### Gestion d'erreur
############################################
$ERRPLAN
Local Integer E , ERL, DOK
Local Char    PROGPLAN(10) , LIGNE(250) , LIGNE2(250) , MESSA(250) , ERRPG(250)
MESSA = errmes$(errn)+"\"+errm
ERL   = errl
ERRPG = errp
PROGPLAN  = ""
LIGNE = ""
#JASMI - 2017-01-10 - START
#For E=1 To 10
For E=1 To 50
#JASMI - 2017-01-10 - END
 If instr(1,ERRPG,"WP"+GCURLEG+"PLAN"+num$(E)) : PROGPLAN = "WP"+GCURLEG+"PLAN"+num$(E) : Break : Endif
Next E
If PROGPLAN<>"" & filinfo(filpath("TRT",PROGPLAN,"src",0),0)>=0
 Openi filpath("TRT",PROGPLAN,"src",0)
 For E=1 To ERL+1
  Rdseq LIGNE
 Next E
 Rdseq LIGNE2
 While left$(LIGNE2,1)="&"
  LIGNE += "\"+LIGNE2
  Rdseq LIGNE2
 Wend
 Openi
Endif
GFLGERR=1
If GTRACE<>""
 # Rubrique
 Call ECR_TRACE(mess(32,147,1)-RUB+"\"+MESSA+"\"+LIGNE,1) From GESECRAN
Else
 #DBA le 22/09/04 : Sugg 23107 : "Voulez-vous continuer ?"
 DOK=2
 # Rubrique xxxxxx Voulez-vous continuer ?
 Call OUINON(mess(32,147,1)-RUB+"\"+MESSA+"\"+mess(205,100,1),DOK) From GESECRAN
 If DOK=1 : GOK=0 : Endif
Endif
Resume

############################################
### Mise à jour en-tête
############################################
$MAJVEP
Readlock [VEP]VEP5 = BULLETIN
If fstat=1
 GOK = -1 : GLOCK = "$VALEMP"-MATRI-num$(DATVEP)-BULLETIN : Return
Elsif fstat
 GOK = 0 : Call RSTA("VEP",MATRI) From GLOCK : Return
Endif
If !GFLGERR : [F:VEP]STA=2 : Else : [F:VEP]STA=1 : Endif
# SEGAY  US 2331-88174 BULDEM
Gosub INIT_ISDEMAT From SUBVEP
If [L]WISDEMAT : [F:VEP]FLGDEMAT=1 : Endif # 88174

# Pour les liens crystal report
If dim([F:VEP]DATEXM)>0 & dim([F:HREXM]DATEXM)  : [F:VEP]DATEXM = [F:HREXM]DATEXM    : Endif
If dim([F:VEP]DATTRY)>0 & dim([F:TRY]STRDATTRY) : [F:VEP]DATTRY = [F:TRY]STRDATTRY : Endif

