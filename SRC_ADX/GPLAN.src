############################################
Subprog DECL_PROFIL (TYPPLAN)
Value Integer TYPPLAN

If clalev([F:CRB])=0  : Local File CALRUB     [CRB] : Endif
If clalev([F:VRA])=0  : Local File VARIA      [VRA] : Endif
Global Integer GNBRCRB, GIPRF
Global Integer  GTCRBSIZ
GTCRBSIZ=32700 #number of elements cant't be superior to 32767
If nbrecord([CRB])< GTCRBSIZ : GTCRBSIZ=nbrecord([CRB]) : Endif

Global Char GTCRBPRF(GLONPRF)(1..GTCRBSIZ)
Global Integer GTCRBROW(1..GTCRBSIZ)
Global Decimal GVARVAL1 (1..nbrecord([VRA]))
Global Decimal GVARVAL2 (1..nbrecord([VRA]))
Global Decimal GVARVAL3 (1..nbrecord([VRA]))
Global Date GVARDAT (1..3)
Global Char GVARSOC (GLONCPY)
Global Char GVARSIT (GLONFCY)
Global Char GVARCOD1 (GLONVRA) (1..nbrecord([VRA]))
Global Char GVARCOD2 (GLONVRA) (1..nbrecord([VRA]))
Global Char GVARCOD3 (GLONVRA) (1..nbrecord([VRA]))
Global Integer GNBRCOD1
Global Integer GNBRCOD2
Global Integer GNBRCOD3

# MS
If TYPPLAN
 If clalev([F:MSC])=0  : Local File MSCALR      [MSC]  : Endif
 Global Integer GNBRMSC, GIMSPRF
 Local Integer DIMMSC
 [L]DIMMSC=nbrecord([MSC])
 If ![L]DIMMSC : [L]DIMMSC=1  : GNBRMSC=1 : Endif
 Global Char GTMSCPRF(GLONPRF)(1..DIMMSC)
 Global Integer GTMSCROW(1..DIMMSC)
Endif
End

############################################
Subprog KILL_PROFIL (TYPPLAN)
Value Integer TYPPLAN
If dim(GNBRCRB)>=0  : Kill GNBRCRB  : Endif
If dim(GIPRF)>=0    : Kill GIPRF    : Endif
If dim(GTCRBPRF)>=0 : Kill GTCRBPRF : Endif
If dim(GTCRBROW)>=0 : Kill GTCRBROW : Endif
If dim(GTCRBSIZ)>=0 : Kill GTCRBSIZ : Endif
Kill GVARVAL1,GVARVAL2,GVARVAL3,GVARDAT,GVARSOC,GVARSIT,GVARCOD1,GVARCOD2,GVARCOD3,GNBRCOD1,GNBRCOD2,GNBRCOD3
#MS
If TYPPLAN
 Kill GNBRMSC,GIMSPRF,GTMSCPRF,GTMSCROW
Endif
End

############################################
### Chargement profil
############################################
$CHARGE_PROFIL
#JASMI - REMOVED TO SOLVE PAYSLIP CALCS FOR DIFF LEGS - START
#If GPRFRUB=PROFIL : Return : Endif
#JASMI - REMOVED TO SOLVE PAYSLIP CALCS FOR DIFF LEGS - END
If nbrecord([CRB])>GTCRBSIZ
  Raz GPRFTAB1,GPRFTAB2,GPRFTAB3,GPRFTAB4,GPRFTAB5,GPRFTAB6,GPRFTAB7
  For [CRB]CRB1 Where PRFCOD=PROFIL & LEG=GCURLEG
   If [F:CRB]ROW <= 15000
    GPRFTAB1([F:CRB]ROW) = 1
   Elsif[F:CRB]ROW <= 30000
    GPRFTAB2([F:CRB]ROW-15000) = 1
   Elsif[F:CRB]ROW <= 45000
    GPRFTAB3([F:CRB]ROW-30000) = 1
   Elsif[F:CRB]ROW <= 60000
    GPRFTAB4([F:CRB]ROW-45000) = 1
   Elsif[F:CRB]ROW <= 75000
    GPRFTAB5([F:CRB]ROW-60000) = 1
   Elsif[F:CRB]ROW <= 90000
    GPRFTAB6([F:CRB]ROW-75000) = 1
   Elsif[F:CRB]ROW <100000
    GPRFTAB7([F:CRB]ROW-90000) = 1
   Endif
  Next
Else
  If GNBRCRB<=0 : Gosub CHARGE_TABPRF : Endif
  Raz GPRFTAB1,GPRFTAB2,GPRFTAB3,GPRFTAB4,GPRFTAB5,GPRFTAB6,GPRFTAB7
  GIPRF=find(PROFIL,GTCRBPRF(1..GNBRCRB))
  If GIPRF
   Repeat
    If GTCRBROW(GIPRF) <= 15000
     GPRFTAB1(GTCRBROW(GIPRF)) = 1
    Elsif GTCRBROW(GIPRF) <= 30000
     GPRFTAB2(GTCRBROW(GIPRF)-15000) = 1
    Elsif GTCRBROW(GIPRF) <= 45000
    GPRFTAB3(GTCRBROW(GIPRF)-30000) = 1
    Elsif GTCRBROW(GIPRF) <= 60000
     GPRFTAB4(GTCRBROW(GIPRF)-45000) = 1
    Elsif GTCRBROW(GIPRF)<= 75000
     GPRFTAB5(GTCRBROW(GIPRF)-60000) = 1
    Elsif GTCRBROW(GIPRF) <= 90000
     GPRFTAB6(GTCRBROW(GIPRF)-75000) = 1
    Elsif GTCRBROW(GIPRF) <100000
     GPRFTAB7(GTCRBROW(GIPRF)-90000) = 1
    Endif
    GIPRF+=1
    If GIPRF>GNBRCRB : Break : Endif :#86202
   Until PROFIL<>GTCRBPRF(GIPRF)
  Endif
Endif
GPRFRUB = PROFIL
Return

######################
$CHARGE_TABPRF
GNBRCRB=0
For [CRB]CRB1 Where LEG=GCURLEG
 GNBRCRB+=1
 GTCRBROW(GNBRCRB)=[F:CRB]ROW
 GTCRBPRF(GNBRCRB)=[F:CRB]PRFCOD
Next
Return

############################################
### Ecriture historique
### Calcul pas à pas
############################################
$MEMRUB

If STDPLAN
 ACTION = "MEMRUB" : Gosub ACTION From ='STDPLAN'+GCURLEG
Endif

If SPEPLAN
 ACTION = "MEMRUB" : Gosub ACTION From ='SPEPLAN'+GCURLEG
Endif

If SIMUL
 Gosub RUBRIQUE From SIMULPAY
 Return
Endif

If PASAPAS<>0
 Read [RUB]RUB1=GCURLEG;RANG
 [M:PAS]NAM    = [F:ID]NAM
 [M:PAS]SRN    = [F:ID]SRN
 [M:PAS]COD    = RUB
 Call LECTEXTRA([M:PAS]DES,"RUBRIQUE","DES",[F:RUB]LEG,[F:RUB]COD) From ATEXTRA
 [M:PAS]ROW    = RANG
 [M:PAS]TYP    = [L]TYP
 [M:PAS]TYPRUB = [F:RUB]TYPRUB
 [M:PAS]BAS    = BASE
 [M:PAS]RAT    = TAUX
 # Affichage liseret rouge dans la zone Montant de l'écran TRTCALPAS
 If len(num$(MONT))>12
  [M:PAS]AMT   = arr(MONT,0.1^(11-len(num$(fix(MONT)))))
 Else
  [M:PAS]AMT    = MONT
 Endif
 [M:PAS]BAS0   = [F:RUB]BAS
 [M:PAS]RAT1   = [F:RUB]RAT1
 [M:PAS]RAT2   = [F:RUB]RAT2
 [M:PAS]LIBTX0 = mess(2,10702,1)
 [M:PAS]LIBTX1 = ""
 [M:PAS]LIBTX2 = ""
 MEM           = 0
 Case [M:PAS]TYPRUB
  When 1 : # Base
   Raz [M:PAS]RAT1,RAT2
  When 2,3 : # Base * taux & Base *taux/100
   If [L]TYP=1
    [M:PAS]LIBTX1 = mess(1,10326,1)                    #Part salariale
    Raz [M:PAS]RAT2
   Endif
   If [L]TYP=2
    [M:PAS]LIBTX2 = mess(2,10326,1)                    #Part patronale
    Raz [M:PAS]RAT1
   Endif
  When 4 : # Intervalle
   Raz [M:PAS]RAT1,RAT2
  When 5 : # Assiette
   Raz [M:PAS]RAT1,RAT2
   #Tax Band
   If [L]TYP<10
    [M:PAS]LIBTX1 = mess([L]TYP-2,10338,1)              # TA,TB,TC
    [M:PAS]RAT1   = [F:RUB]AMTMAX([L]TYP-3)
   Else
    [M:PAS]LIBTX1 = mess([L]TYP-6,10338,1)              # TD,TE,TF...
    [M:PAS]RAT1   = [F:RUB]AMTMAX([L]TYP-7)
   Endif
  When 6 : # Cotisation
   If [L]TYP=1 :                                     #% salarial
    [M:PAS]LIBTX1 = mess(6,10708,1)
    Raz [M:PAS]RAT2
   Endif
   If [L]TYP=2 :                                     #% patronal
    [M:PAS]LIBTX2 = mess(7,10708,1)
    Raz [M:PAS]RAT1
   Endif
  When 7
   Raz [M:PAS]LIBTX0,BAS0,LIBTX1,RAT1,LIBTX2,RAT2
  When 8 : # Historique
   [M:PAS]LIBTX1 = mess(4,10708,1)                     #date debut
   [M:PAS]LIBTX2 = mess(5,10708,1)                     #date fin
 Endcase
 Gosub FRMPAS
 Affzo [M:PAS]
Endif

If !ENVERS & !REGUL
 If RECAL
  Case RECAL
   When 1 : Gosub MEMRUB From TRTRECAL
   When 2 : Gosub MEMRUB From TRTRECCUM
   When 3 : Gosub MEMMSR
  Endcase
 Elsif MEM
  If find(TYP,7,8) : # On peut avoir plusieurs réguls...
   Read [HSP]HSP3 = BULLETIN;RUB;TYP
   If !fstat
    [F:HSP]AMT += MONT
### AWAITING MULTI CURRENCY
#MIPEA - 2017-05-12- US X3-11287- START
#MIPEA - 2017-10-24- US X3-59606- START
#JASMI - 2017-11-14 - X3-59363 - START
#    If !clalev([F:TCUC]) : Local File TABCUR [TCUC] : Endif
#    Read [TCUC]TCU0 = [F:VEP]CURCOD
#    [F:HSP]CONAMT += arr(MONT * [F:VEP]CUREXC,[TCUC]CURRND)
    If !clalev([F:TCUC]) : Local File TABCUR [TCUC] : Endif
    Raz [F:TCUC]
    If [F:VEP]CUREXC<>0
      Read [TCUC]TCU0 = [F:VEP]CURCOD
    Endif
    [F:HSP]CONAMT += arr(MONT * [F:VEP]CUREXC,[TCUC]CURRND)
#JASMI - 2017-11-14 - X3-59363 - END
#    [F:HSP]CONAMT += MONT * [F:VEP]CUREXC
#MIPEA - 2017-10-24- US X3-59606- END
#MIPEA - 2017-05-12- US X3-11287- END
    Rewrite [HSP]
    MEM = 0
   Endif
  Endif
  If MEM
   [F:HSP]BUL = BULLETIN
   [F:HSP]EMP = [L]MATRI
   [F:HSP]CTRNUM = [L]CTR
   [F:HSP]DAT = DATVEP
   [F:HSP]RUB = RUB
   [F:HSP]ROW = RANG
   [F:HSP]BAS = BASE
   [F:HSP]RAT = TAUX
   [F:HSP]AMT = MONT
### AWAITING MULTI CURRENCY
#MIPEA - 2017-05-12- US X3-11287- START
#MIPEA - 2017-10-24- US X3-59606- START
#JASMI - 2017-11-14 - X3-59363 - START
#    If !clalev([F:TCUC]) : Local File TABCUR [TCUC] : Endif
#    Read [TCUC]TCU0 = [F:VEP]CURCOD
#    [F:HSP]CONAMT = arr(MONT * [F:VEP]CUREXC,[TCUC]CURRND)
    If !clalev([F:TCUC]) : Local File TABCUR [TCUC] : Endif
    Raz [F:TCUC]
    If [F:VEP]CUREXC<>0
      Read [TCUC]TCU0 = [F:VEP]CURCOD
    Endif
    [F:HSP]CONAMT = arr(MONT * [F:VEP]CUREXC,[TCUC]CURRND)
#JASMI - 2017-11-14 - X3-59363 - END
#    [F:HSP]CONAMT += MONT * [F:VEP]CUREXC
#MIPEA - 2017-10-24- US X3-59606- END
#MIPEA - 2017-05-12- US X3-11287- END
   [F:HSP]TYP = TYP
   If [F:HSP]TYP=0 : [F:HSP]TYP = 1 : Endif
   [F:HSP]LEG = GCURLEG
   Write [HSP]
  Endif
  If fstat
   GOK = 0 : Call FSTA("HSP") From GLOCK : Return
  Endif
  Case RUB
   When PAYACPT1  : [F:HRSDP]BNCPOA  += MONT
   When PAYACPT2  : [F:HRSDP]BNCPOA2 += MONT
   When PAYACPT3  : [F:HRSDP]BNCPOA  -= MONT
   When PAYNET(1) : [F:HRSDP]BNC1    += MONT
   When PAYNET(2) : [F:HRSDP]BNC2    += MONT
   When PAYNET(3) : [F:HRSDP]BNC3    += MONT
   When PAYNET(4) : [F:HRSDP]BNC4    += MONT
   When PAYNET(5) : [F:HRSDP]BNC5    += MONT
  Endcase

  If CUMNUMADI<>""
   Case val(right$(CUMNUMADI,len(CUMNUMADI)))
    When 1 : [F:EPC]CUM1 += MONT
    When 2 : [F:EPC]CUM2 += MONT
    When 3 : [F:EPC]CUM3 += MONT
    When 4 : [F:EPC]CUM4 += MONT
    When 5 : [F:EPC]CUM5 += MONT
    When 6 : [F:EPC]CUM6 += MONT
    When 7 : [F:EPC]CUM7 += MONT
    When 8 : [F:EPC]CUM8 += MONT
    When 9 : [F:EPC]CUM9 += MONT
   Endcase
  Endif
  If LIBRUB<>""
   # DBA le 02/08/04 : Gestion commentaire variables par un clob
   Readlock [F:BCB]BCB0 = "VARTXT";"";BULLETIN;"";RUB
   If !fstat
    Setlob [F:BCB]CLOB With LIBRUB
    Rewrite [BCB]
    If fstat
     GOK = 0 : Call FSTA("BCB") From GLOCK : Return
    Endif
   Elsif fstat=1
    GOK = 0 : Call FSTA("BCB") From GLOCK : Return
   Else
    Raz [F:BCB]
    Setlob [F:BCB]CLOB With LIBRUB
    [F:BCB]CODBLB = "VARTXT"
    [F:BCB]IDENT1 = ""
    [F:BCB]IDENT2 = BULLETIN
    [F:BCB]IDENT3 = ""
    [F:BCB]IDENT4 = RUB
    If dim([F:BCB]CREUSR)>0 : [F:BCB]CREUSR = GUSER : Endif
    If dim([F:BCB]CREDAT)>0 : [F:BCB]CREDAT = date$ : Endif
    If dim([F:BCB]CRETIM)>0 : [F:BCB]CRETIM = time  : Endif
    Write [BCB]
    If fstat
     GOK = 0 : Call FSTA("BCB") From GLOCK : Return
    Endif
   Endif
  Endif
 Endif
Endif
CUMNUMADI = ""
LIBRUB = ""

If PASAPAS=0 or [M:PAS]TYPRUB<>5
 Raz MEM, BASE, TAUX, MONT, [L]TYP
Else
 Raz MEM, TAUX, MONT, [L]TYP
Endif
Raz TEXOS, PEXOS, TEXOP, PEXOP
Return

$FRMPAS
Local Char    WEXPR(250) , WFRM(250) , WVAL(250)
Local Integer WI , WJ , WK , WE
[M:PAS]NBFOR = 0
WEXPR = [M:PAS]BAS0 : Gosub WFRM
WEXPR = [M:PAS]RAT1 : Gosub WFRM
WEXPR = [M:PAS]RAT2 : Gosub WFRM
Return

$WFRM
WI = 1
WJ = 0
While WI<=len(WEXPR)
 WCAR = mid$(WEXPR,WI,1)
 If WJ=0
  If instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ[",WCAR)
   WJ = WI
   WK = WJ
  Endif
 Else
  If instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_[]",WCAR)
   WK = WI
  Else
   Gosub SETFRM
   WJ = 0
  Endif
 Endif
 WI += 1
Wend
If WJ
 Gosub SETFRM
Endif
Return

$SETFRM
WFRM = seg$(WEXPR,WJ,WK)
If !find(WFRM,[M:PAS]FRM(0..[M:PAS]NBFOR-1))
 WE = 0
 Onerrgo ERRFRM
 WVAL = num$(evalue(WFRM))
 Onerrgo
 If WE=0
  [M:PAS]FRM([M:PAS]NBFOR)    = WFRM
  [M:PAS]VALEUR([M:PAS]NBFOR) = WVAL
  [M:PAS]NBFOR += 1
 Endif
Endif
Return

$ERRFRM
WE = errn
Resume

############################################
### Mise à jour des soldes
############################################
$LECSOL
Readlock [HRSDP]SDP0 = MATRI;CTR
If fstat=1
 GOK = -1 : GLOCK = "$SOLDPAY"-MATRI-CTR : Return
Elsif fstat
 Raz [F:HRSDP]
 [F:HRSDP]EMP    = MATRI
 [F:HRSDP]CTRNUM = CTR
 Write [HRSDP]
 If fstat
  GOK = 0 : Call FSTA("FDP") From GLOCK : Return
 Endif
 Readlock [HRSDP]SDP0 = MATRI;CTR
Endif
If PAYACPT1<>""
 Read [HSP]HSP3 = BULLETIN;PAYACPT1;1
 If !fstat
  [F:HRSDP]BNCPOA -= [F:HSP]AMT
 Endif
Endif
If PAYACPT2<>""
 Read [HSP]HSP3 = BULLETIN;PAYACPT2;1
 If !fstat
  [F:HRSDP]BNCPOA2 -= [F:HSP]AMT
 Endif
Endif
#DBA le 01/07/02 Gestion des reports d'acomptes
If PAYACPT3<>""
 Read [HSP]HSP3 = BULLETIN;PAYACPT3;1
 If !fstat
  [F:HRSDP]BNCPOA += [F:HSP]AMT
 Endif
Endif
For I=1 To 5
 If PAYNET(I)<>""
  Read [HSP]HSP3 = BULLETIN;PAYNET(I);1
  If !fstat
   Case I
    When 1 : [F:HRSDP]BNC1 -= [F:HSP]AMT
    When 2 : [F:HRSDP]BNC2 -= [F:HSP]AMT
    When 3 : [F:HRSDP]BNC3 -= [F:HSP]AMT
    When 4 : [F:HRSDP]BNC4 -= [F:HSP]AMT
    When 5 : [F:HRSDP]BNC5 -= [F:HSP]AMT
   Endcase

  Endif
 Endif
Next I
## Calcul des acomptes à déduire
ACOMPTE1 = [F:HRSDP]BNCPOA
ACOMPTE2 = [F:HRSDP]BNCPOA2
# On exclut les acomptes payés après la date de paiement
For [HIP]HIP0 Where EMP=MATRI & CTRNUM=CTR & DAT>[F:VEP]PAYDAT
 If [F:HIP]TYPPOA=1
  ACOMPTE1 += [F:HIP]POA
 Else
  ACOMPTE2 += [F:HIP]POA
 Endif
Next
## Dévalorisation des cumuls salarié
For I=1 To NRUBCUM
 Read [HSP]HSP3 = BULLETIN;RUBCUM(I);1
 If !fstat
  Case RUBCUMN(I)
   When 1 : [F:EPC]CUM1 -= [F:HSP]AMT
   When 2 : [F:EPC]CUM2 -= [F:HSP]AMT
   When 3 : [F:EPC]CUM3 -= [F:HSP]AMT
   When 4 : [F:EPC]CUM4 -= [F:HSP]AMT
   When 5 : [F:EPC]CUM5 -= [F:HSP]AMT
   When 6 : [F:EPC]CUM6 -= [F:HSP]AMT
   When 7 : [F:EPC]CUM7 -= [F:HSP]AMT
   When 8 : [F:EPC]CUM8 -= [F:HSP]AMT
   When 9 : [F:EPC]CUM9 -= [F:HSP]AMT
  Endcase
 Endif
Next I
Return

$MAJSOL
If !PASAPAS
 Read [ECT]ECT0=MATRI;CTR
 If !fstat
  [F:HRSDP]FCY    = [F:ECT]FCY
  [F:HRSDP]SRV    = [F:ECT]SRV
 Endif
 [F:HRSDP]CODACS = [F:ID]CODACS
 Rewrite [HRSDP]
 If fstat
  GOK = 0 : Call FSTA("HRSDP") From GLOCK : Return
 Endif
Endif
Return

###DBA le 14/09/05
############################################
### Mise à jour des congés par employé
############################################
$LECCNG
#ADNGO - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**Local Integer MULTI
#**MULTI=-1
#**Gosub CNG
#**
Local Integer MULTI
MULTI=-1
Gosub CNG
#ADNGO - 2017-05-20 - END
Return

$MAJCNG
#ADNGO - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**Local Integer MULTI
#**MULTI=1
#**Gosub CNG
#**
Local Integer MULTI
MULTI=1
Gosub CNG
#ADNGO - 2017-05-20 - END
Return

$CNG
#ADNGO - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If !NBCODCP | PASAPAS : Return : Endif
#**If [F:ID]FLGTPS<>2 : Return : Endif
#**For I=1 To NBCODCP
#** Filter [F:CNG] Where CPY=SOCIETE & TIM=CODCP(I) & STRPER<=DATPAY & ENDPER>=DATPAY
#** Read[F:CNG]CNG0 First
#** Filter [F:CNG]
#** If !fstat
#**  Readlock [F:CNE]CNE0 = [F:CNG]YEA;MATRI;CTR;CODCP(I)
#**  If fstat=1
#**   GOK = -1 : GLOCK = "$CNGEMP"-num$([F:CNG]YEA)-MATRI-CODCP(I) : Return
#**  Elsif fstat
#**   Raz [F:CNE]
#**   [F:CNE]YEA    = [F:CNG]YEA
#**   [F:CNE]REFNUM = MATRI
#**   [F:CNE]CTRNUM = CTR
#**   [F:CNE]TIM    = CODCP(I)
#**   Gosub CHER_SLDNEG
#**   Write [F:CNE]
#**   If fstat
#**    GOK = 0 : Call FSTA("CNE") From GLOCK : Return
#**   Endif
#**   Readlock [F:CNE]CNE0 = [F:CNG]YEA;MATRI;CTR;CODCP(I)
#**  Endif
#**  If [F:CNG]CUM<>""
#**   Read [HSP]HSP3 = BULLETIN;[F:CNG]CUM;6
#**   If !fstat
#**    [F:CNE]NBRDAY += [F:HSP]AMT*MULTI
#**    Rewrite [F:CNE]
#**    If fstat
#**      GOK = 0 : Call FSTA("CNE") From GLOCK : Return
#**    Endif
#**   Endif
#**  Endif
#** Endif
#**Next
#**
If !NBCODCP | PASAPAS : Return : Endif
If [F:ID]FLGTPS<>2 : Return : Endif
For I=1 To NBCODCP
 Filter [F:CNG] Where CPY=SOCIETE & TIM=CODCP(I) & STRPER<=DATPAY & ENDPER>=DATPAY
#LIPET - 2018-08-14 - X3-102492 - START
 If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
  Filter [F:CNE] Where TIM=CODCP(I) & REFNUM=MATRI & CTRNUM=CTR & EMPLEASTR<=DATPAY & EMPLEAEND>=DATPAY
  Read [F:CNE]CNE0 Last
  Filter [F:CNE]
  If !fstat
   Filter [F:CNG] Where CPY=SOCIETE & TIM=CODCP(I) & YEA=[F:CNE]YEA
  Endif
 Endif
#LIPET - 2018-08-14 - X3-102492 - END
 Read[F:CNG]CNG0 First
 Filter [F:CNG]
 If !fstat
  Readlock [F:CNE]CNE0 = [F:CNG]YEA;MATRI;CTR;CODCP(I)
  If fstat=1
   GOK = -1 : GLOCK = "$CNGEMP"-num$([F:CNG]YEA)-MATRI-CODCP(I) : Return
  Elsif fstat
   Raz [F:CNE]
   [F:CNE]YEA    = [F:CNG]YEA
   [F:CNE]REFNUM = MATRI
   [F:CNE]CTRNUM = CTR
   [F:CNE]TIM    = CODCP(I)
#LIPET - 2018-08-14 - X3-102492 - START
   If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
      Local Integer NEWYEA : [L]NEWYEA = 0
      Call CALC_LVE_DATES_KSA(CODCP(I),SOCIETE,[F:CNE]YEA,MATRI,CTR,
&                             [F:CNE]EMPLEASTR,[F:CNE]EMPLEAEND,[F:CNE]EMPCYCSTR,[F:CNE]EMPCYCEND,
&                             DATPAY,NEWYEA) From SUBCNEKSA
      If [L]NEWYEA <> 0 Then
        [F:CNE]YEA = [L]NEWYEA
        [F:CNG]YEA = [L]NEWYEA
      Endif
   Endif
#LIPET - 2018-08-14 - X3-102492 - END
   Gosub CHER_SLDNEG
   Write [F:CNE]
   If fstat
    GOK = 0 : Call FSTA("CNE") From GLOCK : Return
   Endif
   Readlock [F:CNE]CNE0 = [F:CNG]YEA;MATRI;CTR;CODCP(I)
  Endif
  If [F:CNG]CUM<>""
   Read [HSP]HSP3 = BULLETIN;[F:CNG]CUM;6
   If !fstat
   #LIPET - 2018-08-14 - X3-102492 - START
   #case to take into account several payslips in the month for the same CTRNUM.
    #[F:CNE]NBRDAY += [F:HSP]AMT*MULTI
    [F:CNE]NBRDAY += ([F:HSP]AMT-[F:HSP]BAS)*MULTI
   #LIPET - 2018-08-14 - X3-102492 - END
    Rewrite [F:CNE]
    If fstat
      GOK = 0 : Call FSTA("CNE") From GLOCK : Return
    Endif
   Endif
  Endif
 Endif
Next
#ADNGO - 2017-05-20 - END
Return

#Lors d'une création d'enreg dans [CNE], on reporte le solde négatif de l'année précédente.
#Ce solde négatif est basculé dans le nb de congés pris sur nouvelle fiche.
#+ Maj de l'ancienne fiche & maj de timcng (historique des congès)
$CHER_SLDNEG
#ADNGO - 20117-05-20 - START
#** V7 : Waiting Time Mangement **#
#**Filter [F:CNE2] Where YEA<[F:CNE]YEA & REFNUM=[F:CNE]REFNUM & CTRNUM=[F:CNE]CTRNUM & TIM=[F:CNE]TIM
#**Readlock [F:CNE2]CNE0 Last
#**Filter [F:CNE2]
#**If !fstat & [F:CNE2]NBRDAY-[F:CNE2]NBRPRI<0
#** [F:CNE]NBRPRI +=abs([F:CNE2]NBRDAY- [F:CNE2]NBRPRI)
#** [F:CNE2]NBRPRI += abs([F:CNE2]NBRDAY- [F:CNE2]NBRPRI)
#** Rewrite [F:CNE2]
#** If fstat
#**   GOK = 0 : Call FSTA("CNE2") From GLOCK : Return
#** Endif
#** Gosub MAJ_TIC
#**Endif
#**
Filter [F:CNE2] Where YEA<[F:CNE]YEA & REFNUM=[F:CNE]REFNUM & CTRNUM=[F:CNE]CTRNUM & TIM=[F:CNE]TIM
Readlock [F:CNE2]CNE0 Last
Filter [F:CNE2]
If !fstat & [F:CNE2]NBRDAY-[F:CNE2]NBRPRI<0
 [F:CNE]NBRPRI +=abs([F:CNE2]NBRDAY- [F:CNE2]NBRPRI)
 [F:CNE2]NBRPRI += abs([F:CNE2]NBRDAY- [F:CNE2]NBRPRI)
 Rewrite [F:CNE2]
 If fstat
   GOK = 0 : Call FSTA("CNE2") From GLOCK : Return
 Endif
 Gosub MAJ_TIC
Endif
#ADNGO - 20117-05-20 - END
Return

#+ Maj de TIMCNG (historique des congès)
$MAJ_TIC
#ADNGO - 20117-05-20 - START
#** V7 : Waiting Time Mangement **#
#**Link [TIC] With [TIP]TIP0=LIG  As [LNK]
#**& Where [TIP]REFNUM=MATRI & [TIP]TIM=[F:CNE2]TIM & [TIC]YEA=[F:CNE2]YEA
#**& Order By Key CLE=LIG Desc

#**SLD=abs([F:CNE2]NBRDAY-[F:CNE2]NBRPRI)

#**For [LNK]CLE
#** If SLD=[F:TIC]NBRDAY
#**  [F:TIC]YEA=[F:CNE]YEA
#**  Rewrite [F:TIC]
#**  If fstat
#**   GOK = 0 : Call FSTA("TIC") From GLOCK : Break
#**  Endif
#**  Break
#** Elsif SLD<[F:TIC]NBRDAY
#**  Gosub CRE_TIC
#**  [F:TIC]NBRDAY-= SLD
#**  Rewrite [F:TIC]
#**  If fstat
#**   GOK = 0 : Call FSTA("TIC") From GLOCK : Break
#**  Endif
#**  Break
#** Else
#**  [F:TIC]YEA=[F:CNE]YEA
#**  Rewrite [F:TIC]
#**  If fstat
#**   GOK = 0 : Call FSTA("TIC") From GLOCK : Break
#**  Endif
#**  SLD-=[F:TIC]NBRDAY
#** Endif
#**Next
#**
Link [TIC] With [TIP]TIP0=LIG  As [LNK]
& Where [TIP]REFNUM=MATRI & [TIP]TIM=[F:CNE2]TIM & [TIC]YEA=[F:CNE2]YEA
& Order By Key CLE=LIG Desc

SLD=abs([F:CNE2]NBRDAY-[F:CNE2]NBRPRI)

For [LNK]CLE
 If SLD=[F:TIC]NBRDAY
  [F:TIC]YEA=[F:CNE]YEA
  Rewrite [F:TIC]
  If fstat
   GOK = 0 : Call FSTA("TIC") From GLOCK : Break
  Endif
  Break
 Elsif SLD<[F:TIC]NBRDAY
  Gosub CRE_TIC
  [F:TIC]NBRDAY-= SLD
  Rewrite [F:TIC]
  If fstat
   GOK = 0 : Call FSTA("TIC") From GLOCK : Break
  Endif
  Break
 Else
  [F:TIC]YEA=[F:CNE]YEA
  Rewrite [F:TIC]
  If fstat
   GOK = 0 : Call FSTA("TIC") From GLOCK : Break
  Endif
  SLD-=[F:TIC]NBRDAY
 Endif
Next
#ADNGO - 20117-05-20 - END
Return

$CRE_TIC
#ADNGO - 20117-05-20 - START
#** V7 : Waiting Time Mangement **#
#**Raz [F:TIC2]
#**[F:TIC2]LIG=[F:TIC]LIG
#**[F:TIC2]YEA=[F:CNE]YEA
#**[F:TIC2]NBRDAY=SLD
#**[F:TIC2]FLGREG=1
#**[F:TIC2]FLGBEF=[F:TIC]FLGBEF
#**Write [F:TIC2]
#**If fstat
#**  GOK = 0 : Call FSTA("TIC2") From GLOCK : Return
#**Endif
#**
Raz [F:TIC2]
[F:TIC2]LIG=[F:TIC]LIG
[F:TIC2]YEA=[F:CNE]YEA
[F:TIC2]NBRDAY=SLD
[F:TIC2]FLGREG=1
[F:TIC2]FLGBEF=[F:TIC]FLGBEF
Write [F:TIC2]
If fstat
  GOK = 0 : Call FSTA("TIC2") From GLOCK : Return
Endif
#ADNGO - 20117-05-20 - END
Return

############################################
####### Taux et plafonds d'exonération
############################################

$TSTEXO
Raz TEXOS, TEXOP, PEXOS, PEXOP
For I=1 To 4
 Case I
  When 1 : CODEXO = [F:HRCTR]EXOCOD1 : DEBEXO = [F:HRCTR]EXOSTR1 : FINEXO = [F:HRCTR]EXOEND1
  When 2 : CODEXO = [F:HRCTR]EXOCOD2 : DEBEXO = [F:HRCTR]EXOSTR2 : FINEXO = [F:HRCTR]EXOEND2
  When 3 : CODEXO = [F:HRCTR]EXOCOD3 : DEBEXO = [F:HRCTR]EXOSTR3 : FINEXO = [F:HRCTR]EXOEND3
  When 4 : CODEXO = [F:HRCTR]EXOCOD4 : DEBEXO = [F:HRCTR]EXOSTR4 : FINEXO = [F:HRCTR]EXOEND4
 Endcase
 If CODEXO<>"" & (DEBEXO=[0/0/0] | DATPAY>=DEBEXO) & (FINEXO=[0/0/0] | DATPAY<=FINEXO)
  K = find(CODEXO,CEXO(1..NEXO))
  If K
   If TEXO1(K)>TEXOS                        : # On privilégie le plus fort taux
    TEXOS = TEXO1(K)
    If TEXOS=100 : PEXOS = PEXO1(K) : Endif : # A 100% on prend le plafond
   Elsif TEXO1(K)=100 & TEXOS=100
    If PEXO1(K)<PEXOS                       : # Et a égalité celle de + petit plafond
     PEXOS = PEXO1(K)
    Endif
   Endif
   If TEXO2(K)>TEXOP
    TEXOP = TEXO2(K)
    If TEXOP=100 : PEXOP = PEXO2(K) : Endif
   Elsif TEXO2(K)=100 & TEXOP=100
    If PEXO2(K)<PEXOP
     PEXOP = PEXO2(K)
    Endif
   Endif
  Endif
 Endif
Next I
If TEXOS=100 & PEXOS>0 : TEXOS = 0 : Endif
If TEXOP=100 & PEXOP>0 : TEXOP = 0 : Endif
Return

############################################
######## Mise à jour des cumuls
############################################
$MAJCUM
If MONT<>0 or BASE<>0
 Raz [F:HSP]
 [F:HSP]BUL = BULLETIN
 [F:HSP]EMP = MATRI
 [F:HSP]CTRNUM = CTR
 [F:HSP]DAT = DATVEP
 [F:HSP]RUB = RUB
 [F:HSP]ROW = RANG
 [F:HSP]BAS = BASE
 [F:HSP]AMT = MONT
### AWAITING MULTI CURRENCY
#MIPEA - 2017-05-12- US X3-11287- START
#MIPEA - 2017-10-24- US X3-59606- START
#JASMI - 2017-11-14 - X3-59363 - START
#    If !clalev([F:TCUC]) : Local File TABCUR [TCUC] : Endif
#    Read [TCUC]TCU0 = [F:VEP]CURCOD
#    [F:HSP]CONAMT = arr(MONT * [F:VEP]CUREXC,[TCUC]CURRND)
    If !clalev([F:TCUC]) : Local File TABCUR [TCUC] : Endif
    Raz [F:TCUC]
    If [F:VEP]CUREXC<>0
      Read [TCUC]TCU0 = [F:VEP]CURCOD
    Endif
    [F:HSP]CONAMT = arr(MONT * [F:VEP]CUREXC,[TCUC]CURRND)
#JASMI - 2017-11-14 - X3-59363 - END
#    [F:HSP]CONAMT += MONT * [F:VEP]CUREXC
#MIPEA - 2017-10-24- US X3-59606- END
#MIPEA - 2017-05-12- US X3-11287- END
 [F:HSP]TYP = 6
 [F:HSP]LEG = GCURLEG
 Write [HSP]
 If fstat
  GOK = 0 : Call FSTA("HSP") From GLOCK
 Endif
Endif
Raz [F:HSP]
Return

############################################
######## Evaluation des rubriques grilles
############################################
$GRILLE
If [F:GRI]COD<>GRILLE
 Read [GRI]GRI0 = GRILLE
 If fstat : STAT = 1 : Return : Endif
Endif

# Recherche date

Filter [RIL] Where CODGRI=GRILLE & STRDAT<=DATPAY
Read [RIL]RIL0(2) Last
Filter [RIL]
If fstat>2
 STAT = 2 : Return
Else
 DATCUR = [F:RIL]STRDAT
Endif

# Formattage pour le numérique

For I=1 To [F:GRI]NBRCMP
 If [F:GRI]CMPTYP(I-1)=2
  Case I
   When 1 : GRICLE(0) =  func GPLAN.FMTNUM("N0:10.4#",val(GRICLE(0)))
   When 2 : GRICLE(1) =  func GPLAN.FMTNUM("N0:10.4#",val(GRICLE(1)))
   When 3 : GRICLE(2) =  func GPLAN.FMTNUM("N0:10.4#",val(GRICLE(2)))
  Endcase
 Endif
Next I

# Recherche valeur exacte

Read [RIL]RIL1 = GRILLE;DATCUR;GRICLE(0);GRICLE(1);GRICLE(2)
If !fstat
 STAT = 0
 Case GRICOL
  When 1 : MONT = val([F:RIL]VAL1)
  When 2 : MONT = val([F:RIL]VAL2)
 Endcase
 Return
Endif

# Recherche valeur sup ou inf

If [F:GRI]VALMAX=2 & [F:GRI]VALMIN=2
 Case [F:GRI]PIO
  When 1
   Gosub VALSUP
   If !OK : Gosub VALINF : Endif
  When 2
   Gosub VALINF
   If !OK : Gosub VALSUP : Endif
 Endcase
Elsif [F:GRI]VALMAX=2
 Gosub VALSUP
Elsif [F:GRI]VALMIN=2
 Gosub VALINF
Else
 OK = 0
Endif
If !OK
#  Rien à faire
 STAT = 3
Endif
Return

$VALSUP

# Recherche valeur supérieure

OK = 0
Case [F:GRI]NBRCMP
 When 1
  Filter [RIL] Where CODGRI=GRILLE & STRDAT=DATCUR
&                  & CMP1>=GRICLE(0)
 When 2
  Filter [RIL] Where CODGRI=GRILLE & STRDAT=DATCUR
&                  & CMP1=GRICLE(0) & CMP2>=GRICLE(1)
 When 3
  Filter [RIL] Where CODGRI=GRILLE & STRDAT=DATCUR
&                  & CMP1=GRICLE(0) & CMP2=GRICLE(1) & CMP3>=GRICLE(2)
Endcase
Read [RIL]RIL1 First
Filter [RIL]
If fstat<=2
 OK = 1 : STAT = 0
 Case GRICOL
  When 1 : MONT = val([F:RIL]VAL1)
  When 2 : MONT = val([F:RIL]VAL2)
 Endcase
 Return
Endif
Return

$VALINF

# Recherche valeur inférieure

OK = 0
Case [F:GRI]NBRCMP
 When 1
  Filter [RIL] Where CODGRI=GRILLE & STRDAT=DATCUR
&                  & CMP1<=GRICLE(0)
 When 2
  Filter [RIL] Where CODGRI=GRILLE & STRDAT=DATCUR
&                  & CMP1=GRICLE(0) & CMP2<=GRICLE(1)
 When 3
  Filter [RIL] Where CODGRI=GRILLE & STRDAT=DATCUR
&                  & CMP1=GRICLE(0) & CMP2=GRICLE(1) & CMP3<=GRICLE(2)
Endcase
Read [RIL]RIL1 Last
Filter [RIL]
If fstat<=2
 OK = 1 :  STAT = 0
 Case GRICOL
  When 1 : MONT = val([F:RIL]VAL1)
  When 2 : MONT = val([F:RIL]VAL2)
 Endcase
 Return
Endif
Return

############################################
##### Evaluation des rubriques historiques
############################################
$HISTORUB
If instr(1,RUBHIS,'(') <> 0
 CRITRUB = left$(RUBHIS,instr(1,RUBHIS,'(')-1)
Else
 CRITRUB = RUBHIS
Endif
If mid$ (RUBHIS,len(RUBHIS)-2,3)='(2)'
 Filter [HSP] Where EMP=MATRI & CTRNUM=CTR & DAT>=DATED & DAT<=DATEF & RUB=CRITRUB & (TYP=2 or TYP=8)
Else
 Filter [HSP] Where EMP=MATRI & CTRNUM=CTR & DAT>=DATED & DAT<=DATEF & RUB=CRITRUB & (TYP=1 or TYP=7)
Endif
Columns [HSP] (AMT)
MONT = 0
For [HSP] With Stability
 MONT += [F:HSP]AMT
Next
Columns [HSP]
Filter [HSP]
Return

$HISTOCUM
Filter [HSP] Where EMP=MATRI & CTRNUM=CTR & DAT>=DATED & DAT<=DATEF & RUB=RUBHIS & TYP=6
Columns [HSP] (AMT,BAS)
MONT = 0
For [HSP] With Stability
 MONT += [F:HSP]AMT-[F:HSP]BAS
Next
Columns [HSP]
Filter [HSP]
Return

$HISTOVAR
Filter [VEPW] Where EMP=MATRI & CTRNUM=CTR & PYRDAT>=DATED & PYRDAT<=DATEF
Columns [VEPW] (BUL)
MONT = 0
For [VEPW] With Stability
 Filter [VLA] Where TYP=4 & CPY="" & FCY="" & EMP=MATRI & DAT>=DATED & DAT<=DATEF & VARCOD=RUBHIS & BUL=[F:VEPW]BUL
 Columns [VLA] (VARVAL)
 For [VLA] With Stability
  MONT += [F:VLA]VARVAL
 Next
 Columns [VLA]
 Filter [VLA]
Next
Columns [VEPW]
Filter [VEPW]
Return

############################################
######## Traitement des règuls
############################################
$REGUL
SAVDATPAY = DATPAY
SAVDATVEP = DATVEP
SAVBUL    = BULLETIN
SAVPASR    = PASAPAS
SAVCTRDAT=[F:VEP]CTRDAT

Gosub RAZVAR  From ="WP"+GCURLEG+"PLANVRA1"
Gosub LECTURE From ="WP"+GCURLEG+"PLANVRA"
For I=1 To NBREGVAR
 If REGVARVAL(I)<>""
  REGVAL(I) = evalue("V_"+REGVARVAL(I))
 Elsif REGVAL(I)=0
  REGVAL(I) = evalue("V_"+REGVAR(I))
 Endif
Next I
Raz OLDRES1, OLDRES2, NEWRES1, NEWRES2

###**72216 (test GOK ?)
Gosub RAZ_HSR

For [VEP2]VEP0 Where EMP=MATRI & CTRNUM=CTR & STRDAT>=REGDEB & ENDDAT<=REGFIN & RVSDAT=[0/0/0] & RVS<>2
 DATPAY   = [F:VEP2]PYRDAT
 DATVEP   = [F:VEP2]PYRDAT
 BULLETIN = [F:VEP2]BUL
 PASAPAS = 0
 [F:VEP] = [F:VEP2]
 #Chargement des valeurs des anciennes paies
 Gosub LECTAB  From ="WP"+GCURLEG+"PLAN"
 Gosub INIVAR  From ="WP"+GCURLEG+"PLAN"
 Gosub RAZRUB  From ="WP"+GCURLEG+"PLAN"
 Gosub RAZVAR  From ="WP"+GCURLEG+"PLANVRA1"
 Gosub LECTURE From ="WP"+GCURLEG+"PLANVRA"
 Gosub RAZCUM  From ="WP"+GCURLEG+"PLANCUM1"
 Gosub LECTURE From ="WP"+GCURLEG+"PLANCUM"
 Gosub CHARGE_PROFIL From GPLAN
 For I=1 To NBREGVAR
  Assign "V_"+REGVAR(I) With REGVAL(I)
 Next I
 Gosub CALPAY From ="WP"+GCURLEG+"PLAN"
 NEWRES1 += evalue("R_"+REGRUB+"(1)")
 NEWRES2 += evalue("R_"+REGRUB+"(2)")
 Read [HSP]HSP3 = BULLETIN;REGRUB;1
 If !fstat : OLDRES1 += [F:HSP]AMT : Endif
 Read [HSP]HSP3 = BULLETIN;REGRUB;7
 If !fstat : OLDRES1 += [F:HSP]AMT : Endif
 Read [HSP]HSP3 = BULLETIN;REGRUB;2
 If !fstat : OLDRES2 += [F:HSP]AMT : Endif
 Read [HSP]HSP3 = BULLETIN;REGRUB;8
 If !fstat : OLDRES2 += [F:HSP]AMT : Endif

 ###**72216 (test GOK ?)
 Gosub MAJ_HSR
Next
NBREGUL += 1
REGRUB1(NBREGUL) = REGREG
REGVAL1(NBREGUL) = NEWRES1-OLDRES1
REGVAL2(NBREGUL) = NEWRES2-OLDRES2
DATPAY   = SAVDATPAY
DATVEP   = SAVDATVEP
BULLETIN = SAVBUL
PASAPAS = SAVPASR
Gosub RAZRUB  From ="WP"+GCURLEG+"PLAN"
Gosub RAZVAR  From ="WP"+GCURLEG+"PLANVRA1"
Gosub RAZCUM  From ="WP"+GCURLEG+"PLANCUM1"
Raz CUMSVG
Read [VEP]VEP5=BULLETIN
#Retour aux valeurs de la paie en cours
Gosub LECTAB From ="WP"+GCURLEG+"PLAN"
Return

###**72216
$RAZ_HSR
Delete [F:HRHSR] Where BUL=SAVBUL & RETNUM=""        :#Régul de paie (pas issue de la rétroactivité)
If fstat
 GOK = -1 : GLOCK = "$HISTOREGUL" : Return
Endif
Return

###**72216
$MAJ_HSR
GOK=1
Raz [F:HRHSR]
[F:HRHSR]=[HSP]
[F:HRHSR]BUL=SAVBUL
[F:HRHSR]ORIBUL=BULLETIN
[F:HRHSR]RETNUM=""
Case [F:HSP]TYP
 When 1, 7 : [F:HRHSR]AMT=evalue("R_"+REGRUB+"(1)")-[F:HSP]AMT : [F:HRHSR]TYP=7
 When 2, 8 : [F:HRHSR]AMT=evalue("R_"+REGRUB+"(2)")-[F:HSP]AMT : [F:HRHSR]TYP=8
Endcase
[F:HRHSR]TYPAMT=1 :#Auto
[F:HRHSR]CTRDAT=SAVCTRDAT
Write [F:HRHSR]
If fstat
  GOK = 0 : Call FSTA("HRHSR") From GLOCK : Return
Endif
Return

############################################
######## Détermination d'une caisse
############################################
$SET_CAISSE
Read [PCA]PCA0 = 6;"";"";"";"";"";CTR
If fstat | [F:PCA]ORG(CAISSE-1)=""
 Read [PCA]PCA0 = 5;"";"";"";"";MATRI;""
 If fstat | [F:PCA]ORG(CAISSE-1)=""
  Read [PCA]PCA0 = 4;"";"";"";SITE;"";""
  If fstat | [F:PCA]ORG(CAISSE-1)=""
   Read [PCA]PCA0 = 3;"";"";SOCIETE;"";"";""
   If fstat | [F:PCA]ORG(CAISSE-1)=""
    If !clalev([F:HRPOA]) : Local File POPULA [HRPOA] : Endif
    Link [HRPOA] With [PCA]PCA0~=2;GCURLEG;COD;"";"";"";""
&                As [CAK]
&             Where REFNUM=[L]MATRI & COD>"" & [F:PCA]ORG([L]CAISSE-1)>""
    Read [CAK]POA1 First
    If fstat | [F:PCA]ORG(CAISSE-1)=""
     Read [PCA]PCA0 = 1;GCURLEG;"";"";"";"";""
     If fstat | [F:PCA]ORG(CAISSE-1)=""
      Raz [F:ORG] : Return
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
If [F:PCA]ORG(CAISSE-1)<>[F:ORG]COD
 Read [ORG]ORG0 = GCURLEG;[F:PCA]ORG(CAISSE-1)
Endif
Return

##############################################################################################
# MASSE SALARIALE
##############################################################################################

############################################
### Exécution du plan de paye MS
############################################
Subprog PLANMS(FLGFIRST,TYPMCH,NBES,CHREMP,OKSIM)
Variable Integer FLGFIRST
Variable Integer OKSIM
Value    Integer TYPMCH
Value    Integer NBES
Value    Char    CHREMP ()(1..)
Local Integer ILEG

If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
ILEG=find(GCURLEG,GDOSLEG(1..GNBLEG))

If GPLANMSOK(ILEG)
 If dim(GNBRMSC)>=0 : Call KILL_PROFIL(1) : Endif
 Local File ADOVAL [ADW]
 Call GENPLANMS(nomap,1,GCURLEG) From GENPLANMS
Endif
If dim(GNBRMSC)<0 : Call DECL_PROFIL(1) : Endif
Call PLAN(FLGFIRST,TYPMCH,NBES,CHREMP,OKSIM) From ="WP"+GCURLEG+"MSPLAN"
End

############################################
### Chargement profil MS
############################################
$CHARGE_PROMSR
If GNBRMSC<=0 : Gosub CHARGE_TABMSPRF : Endif
Raz GPRFMSR
GIMSPRF=find(PROFIL,GTMSCPRF(1..GNBRMSC))
If GIMSPRF
  Repeat
    GPRFMSR(GTMSCROW(GIMSPRF)) = 1
    GIMSPRF+=1
    If GIMSPRF>GNBRMSC : Break : Endif
  Until PROFIL<>GTMSCPRF(GIMSPRF)
Endif
Return

##########################
$CHARGE_TABMSPRF
GNBRMSC=0
For [MSC]MSC1 #Where LEG=GCURLEG
 GNBRMSC+=1
 GTMSCROW(GNBRMSC)=[F:MSC]ROW
 GTMSCPRF(GNBRMSC)=[F:MSC]PRFCOD
Next
Return

###############################################################
### Chargement critère d'activation d'une hypothèse de rubrique
###############################################################
$CHARGE_ACTMHR
Raz GHYPMSR
#Boucle sur les hypothèses contenues dans le scénario courant, traitées progressivement
For I=2 To GIHYP
 # Parcours des hypothèses de rubriques précédentes actives
 If LISHYP(I)<>"" & TYPHYP(I)="2"
  #Boucle sur la liste des rubriques actives contenues l'hypo
  For [F:MHR]MHR0 Where COD=LISHYP(I)
   Read [F:MSR]MSR0=[F:MHR]CODMSR
   If !fstat
    GHYPMSR([F:MSR]ROW)=([F:MHR]ENAFLG1=2)
   Endif
  Next
 Endif
Next
Return

############################################
### Ecriture historique MS
############################################
$MEMMSR
#Alimentation des rubriques de la masse salariale
#tableau CHREMP:Chronos salariés,vide sinon valorisé pour les salariés fictifs(entrées ou remplaçants des sorties)
If MEM
 For MHI=1 To max(1,NBES)
  Raz [F:MHS]
  [F:MHS]COD    = SCENARIO
# mis en commentaire ci-dessous car on numérote les hypothèses hors ATM/AIA à partir de 2
#  If GIHYP>1
#   [F:MHS]LIGHYP = GIHYP-1
#  Else
   [F:MHS]LIGHYP = GIHYP :# 0=ATM ou 1=AIA pour les Scénarii initiaux
#  Endif
  [F:MHS]CODHYP = LISHYP(GIHYP)
  [F:MHS]TYPHYP = val(TYPHYP(GIHYP))
  [F:MHS]BUD    = GBUDHYP(GIHYP)
  [F:MHS]EMP    = MATRI
  [F:MHS]CTR    = CTR
  [F:MHS]MSEMP  = CHREMP(MHI)
  [F:MHS]DAT    = DATPAY
  [F:MHS]RUB    = RUB
  [F:MHS]TYP    = [L]TYP
  [F:MHS]BAS    = BASE
  [F:MHS]RAT    = TAUX
  [F:MHS]AMT    = MONT
  If [F:MHS]TYP=0 : [F:MHS]TYP = 1 : Endif
  [F:MHS]CPY    = SOCIETE
  [F:MHS]FCY    = SITE
  [F:MHS]PRF    = PROFIL
  [F:MHS]SRV    = SERVICE
#  [F:MHS]POT    = POSTE
#  [F:MHS]JOBPOT = EMPLOITYP
  [F:MHS]SIM    = 2
  If evalue("dim(GRP_"+RUB+")") > 0
   [F:MHS]GRP = evalue("GRP_"+RUB)
   If evalue("dim(CAT_"+evalue("GRP_"+RUB)+")") > 0 : [F:MHS]CAT = evalue("CAT_"+evalue("GRP_"+RUB)) : Endif
  Endif

  If evalue("dim(TMS_"+RUB+")") > 0
   [F:MHS]TOUTEE = evalue("TMS_"+RUB)
  Endif

  Write [MHS]
  If fstat
   GOK = 0 : Call FSTA("MHS") From GLOCK : Break
  Endif

  If [F:MHS]GRP <> "" : # Dans cette tables uniquement ce qui servira pour les consultations
   [F:MHH] = [F:MHS]
   [F:MHH]POT    = POSTE
   [F:MHH]JOBPOT = EMPLOITYP
   Write [MHH]
   If fstat
    GOK = 0 : Call FSTA("MHH") From GLOCK : Break
   Endif
  Endif

 Next
Endif
Return

$MSMAJCUM
#Alimentation des cumuls de la masse salariale
#tableau CHREMP:Chronos salariés,valorisé que pour les salariés fictifs(entrées ou remplaçants des sorties)
If MONT<>0 or BASE<>0
 For MHI = 1 To max(1,NBES)
  Raz [F:MHS]
  [F:MHS]COD    = SCENARIO
#  If GIHYP>1
#   [F:MHS]LIGHYP = GIHYP-1
#  Else
   [F:MHS]LIGHYP = GIHYP :# 0=ATM ou 1=AIA pour les Scénarii initiaux
#  Endif
  [F:MHS]CODHYP = LISHYP(GIHYP)
  [F:MHS]TYPHYP = val(TYPHYP(GIHYP))
  [F:MHS]BUD    = GBUDHYP(GIHYP)
  [F:MHS]EMP    = MATRI
  [F:MHS]MSEMP  = CHREMP(MHI)
  [F:MHS]CTR    = CTR
  [F:MHS]DAT    = DATPAY
  [F:MHS]RUB    = RUB
  [F:MHS]TYP    = 6
  [F:MHS]BAS    = BASE
  [F:MHS]AMT    = MONT
  [F:MHS]CPY    = SOCIETE
  [F:MHS]FCY    = SITE
  [F:MHS]PRF    = PROFIL
  [F:MHS]SRV    = SERVICE
#  [F:MHS]POT    = POSTE
#  [F:MHS]JOBPOT = EMPLOITYP
  [F:MHS]SIM    = 2
  If evalue("dim(GRP_"+RUB+")") > 0
   [F:MHS]GRP = evalue("GRP_"+RUB)
   If evalue("dim(CAT_"+evalue("GRP_"+RUB)+")") > 0 : [F:MHS]CAT = evalue("CAT_"+evalue("GRP_"+RUB)) : Endif
  Endif
  Write [MHS]
  If fstat
   GOK = 0 : Call FSTA("MHS") From GLOCK : Break
  Endif
 Next
Endif
Return

$MSMAJVRA
#Alimentation des variables de la masse salariale
#tableau CHREMP:Chronos salariés,valorisé que pour les salariés fictifs(entrées ou remplaçants des sorties)
If MONT<>0
 For MHI = 1 To max(1,NBES)
  Raz [F:MHA]
  [F:MHA]COD    = SCENARIO
#  If GIHYP>1
#   [F:MHA]LIGHYP = GIHYP-1
#  Else
   [F:MHA]LIGHYP = GIHYP :# 0=ATM ou 1=AIA pour les Scénarii initiaux
#  Endif
  [F:MHA]CODHYP = LISHYP(GIHYP)
  [F:MHA]TYPHYP = val(TYPHYP(GIHYP))
  [F:MHA]BUD    = GBUDHYP(GIHYP)
  [F:MHA]EMP    = MATRI
  [F:MHA]MSEMP  = CHREMP(MHI)
  [F:MHA]CTR    = CTR
  [F:MHA]DAT    = DATPAY
  [F:MHA]CODVRA = RUB
  [F:MHA]AMT    = MONT
  [F:MHA]CPY    = SOCIETE
  [F:MHA]FCY    = SITE
  [F:MHA]PRF    = PROFIL
  [F:MHA]SRV    = SERVICE
  Write [MHA]
  If fstat
   GOK = 0 : Call FSTA("MHA") From GLOCK : Break
  Endif
 Next
Endif
Return

#########################################################
######## Evaluation des rubriques grilles Masse salariale
#########################################################
$MSGRILLE
If [F:MGR]COD<>GRILLE
 Read [MGR]MGR0 = GRILLE
 If fstat : STAT = 1 : Return : Endif
Endif

# Recherche date

Filter [MRI] Where CODGRI=GRILLE & STRDAT<=DATPAY
Read [MRI]MRI0(2) Last
Filter [MRI]
If fstat>2
 STAT = 2 : Return
Else
 DATCUR = [F:MRI]STRDAT
Endif

# Formattage pour le numérique

For I=1 To [F:MGR]NBRCMP
 If [F:MGR]CMPTYP(I-1)=2
  Case I
   When 1 : GRICLE(0) =  func GPLAN.FMTNUM("N0:10.4#",val(GRICLE(0)))
   When 2 : GRICLE(1) =  func GPLAN.FMTNUM("N0:10.4#",val(GRICLE(1)))
   When 3 : GRICLE(2) =  func GPLAN.FMTNUM("N0:10.4#",val(GRICLE(2)))
  Endcase
 Endif
Next I

# Recherche valeur exacte

Read [MRI]MRI1 = GRILLE;DATCUR;GRICLE(0);GRICLE(1);GRICLE(2)
If !fstat
 STAT = 0
 Case GRICOL
  When 1 : MONT = val([F:MRI]VAL1)
  When 2 : MONT = val([F:MRI]VAL2)
 Endcase
 Return
Endif

# Recherche valeur sup ou inf

If [F:MGR]VALMAX=2 & [F:MGR]VALMIN=2
 Case [F:MGR]PIO
  When 1
   Gosub MSVALSUP
   If !OK : Gosub MSVALINF : Endif
  When 2
   Gosub MSVALINF
   If !OK : Gosub MSVALSUP : Endif
 Endcase
Elsif [F:MGR]VALMAX=2
 Gosub MSVALSUP
Elsif [F:MGR]VALMIN=2
 Gosub MSVALINF
Else
 OK = 0
Endif
If !OK
#  Rien à faire
 STAT = 3
Endif
Return

$MSVALSUP

# Recherche valeur supérieure

OK = 0
Case [F:MGR]NBRCMP
 When 1
  Filter [MRI] Where CODGRI=GRILLE & STRDAT=DATCUR
&                  & CMP1>=GRICLE(0)
 When 2
  Filter [MRI] Where CODGRI=GRILLE & STRDAT=DATCUR
&                  & CMP1=GRICLE(0) & CMP2>=GRICLE(1)
 When 3
  Filter [MRI] Where CODGRI=GRILLE & STRDAT=DATCUR
&                  & CMP1=GRICLE(0) & CMP2=GRICLE(1) & CMP3>=GRICLE(2)
Endcase
Read [MRI]MRI1 First
Filter [MRI]
If fstat<=2
 OK = 1 : STAT = 0
 Case GRICOL
  When 1 : MONT = val([F:MRI]VAL1)
  When 2 : MONT = val([F:MRI]VAL2)
 Endcase
 Return
Endif
Return

$MSVALINF

# Recherche valeur inférieure

OK = 0
Case [F:MGR]NBRCMP
 When 1
  Filter [MRI] Where CODGRI=GRILLE & STRDAT=DATCUR
&                  & CMP1<=GRICLE(0)
 When 2
  Filter [MRI] Where CODGRI=GRILLE & STRDAT=DATCUR
&                  & CMP1=GRICLE(0) & CMP2<=GRICLE(1)
 When 3
  Filter [MRI] Where CODGRI=GRILLE & STRDAT=DATCUR
&                  & CMP1=GRICLE(0) & CMP2=GRICLE(1) & CMP3<=GRICLE(2)
Endcase
Read [MRI]MRI1 Last
Filter [MRI]
If fstat<=2
 OK = 1 :  STAT = 0
 Case GRICOL
  When 1 : MONT = val([F:MRI]VAL1)
  When 2 : MONT = val([F:MRI]VAL2)
 Endcase
 Return
Endif
Return

# Formatage des valeurs décimal dans les grilles suite au changeemnt de comportemant sous convergence
Funprog FMTNUM(FMT,VALEUR)
Value Char FMT
Value Decimal VALEUR
Local Integer WI,ENT,DEC
Local Char RESULT(30)
If instr(0,FMT,".")
  Local Char B_FMT(5)
  WI=instr(0,FMT,":")
  B_FMT=left$(FMT,WI)
  FMT=right$(FMT,WI+1)
  WI=instr(0,FMT,".")
  DEC=val(right$(FMT,WI+1))
  RESULT=format$(B_FMT+left$(FMT,WI-1),fix(VALEUR)) # integer part of valeur
  RESULT+="."
  RESULT+=format$("N0:"+num$(DEC),(VALEUR-fix(VALEUR))*10^(DEC)) :# decimal part of valeur.N0 to forced to display n decimals
Else
  RESULT=format$(FMT,VALEUR)
Endif
End RESULT

#JASMI - 2018-01-11 - X3-66753 - START
$SET_EXCHANGE_RATE

Readlock [VEP]VEP5 = BULLETIN
If fstat=1
 GOK = -1 : GLOCK = "$VALEMP"-MATRI-num$(DATVEP)-BULLETIN : Return
Elsif fstat
 GOK = 0 : Call RSTA("VEP",MATRI) From GLOCK : Return
Endif

### AWAITING MULTI CURRENCY
#MIPEA - 2017-05-10- US X3-11287- START
#MIPEA - 2017-10-24- US X3-61061 - START
#MIPEA - 2017-11-07- US X3-59606- START
If !clalev([F:CPYMC]) : Local File COMPANY [CPYMC] : Endif
If !clalev([F:FCYMC]) : Local File FACILITY [FCYMC] : Endif
If !clalev([F:HRCTRMC]) : Local File EMPLOCTR [HRCTRMC] : Endif

Read [F:HRCTRMC]CTR0 = [F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
Read [F:FCYMC]FCY0 = [F:HRCTRMC]ETRFCY
Read [F:CPYMC]CPY0 = [F:FCYMC]LEGCPY

#Link [HRCTRMC] With [FCYMC]FCY0=[F:HRCTRMC]ETRFCY,
#&                   [CPYMC]CPY0=[F:FCYMC]LEGCPY
#&                   As [LNK]
#& Where [HRCTRMC]REFNUM=[F:VEP]EMP & [HRCTRMC]CTRNUM=[F:VEP]CTRNUM & [HRCTRMC]CTRDAT=[F:VEP]CTRDAT
#& Order By Key CLE=LIG Desc

#MIPEA - 2017-11-07- US X3-59606- END
If [F:CPYMC]ACCCUR <> [F:VEP]CURCOD & [F:VEP]CURCOD<>""
#MIPEA - 2017-11-07- US X3-59606- START
#  Read [F:CPY]CPY0 = [F:CPY]CPY
#MIPEA - 2017-11-07- US X3-59606- END
#Read [CPY]CPY0 = [M:VEP1]CPY
#If [F:CPY]ACCCUR <> [F:VEP]CURCOD
#MIPEA - 2017-10-24- US X3-61061 - END
#JASMI - 2018-01-11 - X3-66753 - START
#  If [F:VEP]STA=2
#JASMI - 2018-01-11 - X3-66753 - END
    Local Char    VALPAR(15)
    Local Decimal EXCHFIXRATE
    Local Decimal INVERSERATE
    Local Decimal VEPEXCHANGE

    If !clalev([F:TCUC]) : Local File TABCUR [TCUC] : Endif
    If !clalev([F:TCHC]) : Local File TABCHANGE [TCHC] : Endif

    Call PARAM("","TYPCOURS",VALPAR) From ADOVAL
    If VALPAR=""
      Call MESSAGE(func AFNC.MES1(mess(130,10701,1), "TYPCOURS")) From GESECRAN
    Endif

    Read [TCUC]TCU0 = [F:VEP]CURCOD
    If [F:TCUC]EURFLG=2 # Fixed EURO rate flagged
#MIPEA - 2017-11-06- US X3-59606- START
      EXCHFIXRATE = ([F:TCUC]EURRAT/1)
#      EXCHFIXRATE = (1/[F:TCUC]EURRAT)
#MIPEA - 2017-11-06- US X3-59606- END
#MIPEA - 2017-11-07- US X3-59606- START
       Filter [TCHC] Where CURDEN=[F:CPYMC]ACCCUR & CHGTYP=val(VALPAR) & CUR="EUR" & CHGSTRDAT<=[F:VEP]PYRDAT
#       Filter [TCHC] Where CURDEN=[F:CPY]ACCCUR & CHGTYP=val(VALPAR) & CUR="EUR" & CHGSTRDAT<=[M:VEP0]PYRDAT
#MIPEA - 2017-11-07- US X3-59606- END
       Read [TCHC]TCH0 Last
       Filter [TCHC]
#MIPEA - 2017-11-06- US X3-59606- START
      If !fstat
        INVERSERATE = [F:TCHC]REVCOURS/[F:TCHC]CHGDIV
      Else
        INVERSERATE = 0
      Endif
#      INVERSERATE = [F:TCHC]CHGRAT
#MIPEA - 2017-11-06- US X3-59606- END
      VEPEXCHANGE = EXCHFIXRATE * INVERSERATE
#      VEPEXCHANGE = arr(EXCHFIXRATE * INVERSERATE,[F:TCUC]CURRND)
    Else
#MIPEA - 2017-11-07- US X3-59606- START
      Filter [TCHC] Where CURDEN=[F:CPYMC]ACCCUR & CHGTYP=val(VALPAR) & CUR=[F:VEP]CURCOD & CHGSTRDAT<=[F:VEP]PYRDAT
#      Filter [TCHC] Where CURDEN=[F:CPY]ACCCUR & CHGTYP=val(VALPAR) & CUR=[F:VEP]CURCOD & CHGSTRDAT<=[M:VEP0]PYRDAT
#MIPEA - 2017-11-07- US X3-59606- END
      Read [TCHC]TCH0 Last
      Filter [TCHC]
#MIPEA - 2017-11-06- US X3-59606- START
      If !fstat
        VEPEXCHANGE = [F:TCHC]REVCOURS/[F:TCHC]CHGDIV
      Else
        VEPEXCHANGE = 0
      Endif
#      VEPEXCHANGE = [F:TCHC]CHGRAT
#MIPEA - 2017-11-06- US X3-59606- END
#      VEPEXCHANGE = arr([F:TCHC]CHGRAT,[F:TCUC]CURRND)
    Endif
#JASMI - 2018-01-11 - X3-66753 - START
#  Endif
#JASMI - 2018-01-11 - X3-66753 - END

[F:VEP]CUREXC = VEPEXCHANGE
[F:VEP]CURTYP = val(VALPAR)

Endif
#MIPEA - 2017-05-10- US X3-11287- END

Rewrite [VEP]
If fstat
 GOK = 0 : Call FSTA("VEP") From GLOCK : Return
Endif

Return
#JASMI - 2018-01-11 - X3-66753 - END

