#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management BOL3 (Bill of lading delivery selection)
######################################################################################
######################################################################################
#    Process Name:    SUBBOL3 - Bill of lading delivery selection entry  SAM #101090
#
#    Authors:         BeSpr   Oct, 2014
#
#    Modifications:
#                     BeSpr   Oct xx, 2014   xxxx
#
#
# Action = BOLSELDLV
# Screen = BOL3 (BOL3)
# Window = FBOLSELDLV
######################################################################################
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "BOUTON"        : Gosub EXEBOUT
 When "OK"            : Gosub SAVEIT
 When Default
Endcase
Return

######################################################################################
$OUVRE

If !clalev([F:CPY])  : Local File COMPANY       [CPY]  : Endif

Local Integer J,K,NOLD
Local Char    CRITERE(250)

# Initialization of the variables
BOLFCY = PARAM(1)
BOLCPY = PARAM(2)
BOLBPR = PARAM(3)
BOLTYPFLG = val(PARAM(4))

Return

######################################################################################
$SETBOUT

CHMEN +="D"
STADEF = GSTABOU2+1 # Search button default

Gosub SET_BOUT_SPE From GSAISIE

Return

######################################################################################
$EXEBOUT

Case BOUT
  When "D"  # Search
    NOLD = 0
    # Filter
    Case [M:BOL3]BOLTYP
      When 1 # Customer
        Gosub SET_SDH_DATA
      When 2 # Supplier
        Gosub SET_PNH_DATA
    Endcase
    Gosub SET_NBLIG
Endcase

Affzo [M:BOL3]

Return

######################################################################################
$DEBUT

Raz [M:BOL3]

# Set the hidden variables
[M:BOL3]FCY = BOLFCY
[M:BOL3]CPY = BOLCPY
[M:BOL3]BPR = BOLBPR
[M:BOL3]BOLTYP = BOLTYPFLG
# Set the dates to today's date
[M:BOL3]DATDEB = datesyst
[M:BOL3]DATFIN = datesyst
# Default to NOT validated
[M:BOL3]VALFLG = 1

# These should all be set, so i shouldnt need to do these
Call LEC_FCY([M:BOL3]FCY) From CPTLEC
Call LEC_CPY([M:BOL3]CPY) From CPTLEC
Call LEC_BPR([M:BOL3]BPR) From CPTLEC
GFCY = [M:BOL3]FCY
GCURLEG = [F:CPY]LEG
# Set Global parameters
Call GLOBVAR(GFCY,"VEN") From TRTX3

NOLD = 0
# Filter
Case [M:BOL3]BOLTYP
  When 1 # Customer
    Gosub SET_SDH_DATA
  When 2 # Supplier
    Gosub SET_PNH_DATA
Endcase

Gosub SET_NBLIG

Affzo [M:BOL3]

Return

######################################################################################
$SET_SDH_DATA

# If Include validated is Yes then do not check the CFMFLG checking
If [M:BOL3]VALFLG = 2
  CRITERE = 'CPY=[M:BOL3]CPY & STOFCY=[M:BOL3]FCY & BPCORD=[M:BOL3]BPR & SDHNUM<>[M:BOL0]DOCNUM & BOLNUM="" & (SHIDAT>=[M:BOL3]DATDEB & SHIDAT<=[M:BOL3]DATFIN)'
Else
  CRITERE = 'CPY=[M:BOL3]CPY & STOFCY=[M:BOL3]FCY & BPCORD=[M:BOL3]BPR & SDHNUM<>[M:BOL0]DOCNUM & CFMFLG<>2 & BOLNUM="" & (SHIDAT>=[M:BOL3]DATDEB & SHIDAT<=[M:BOL3]DATFIN)'
Endif

Filter [F:SDH]
For [F:SDH]SDH0 Where evalue (CRITERE)
  [M:BOL3]DOCNUM(NOLD)      = [F:SDH]SDHNUM
  [M:BOL3]SHIDAT(NOLD)      = [F:SDH]SHIDAT
  [M:BOL3]DLVDAT(NOLD)      = [F:SDH]DLVDAT
  [M:BOL3]CFMFLG(NOLD)      = [F:SDH]CFMFLG
  [M:BOL3]GROWEI(NOLD)      = [F:SDH]GROWEI
  [M:BOL3]NETWEI(NOLD)      = [F:SDH]NETWEI
  [M:BOL3]WEU(NOLD)         = [F:SDH]WEU
  [M:BOL3]VOL(NOLD)         = [F:SDH]VOL
  [M:BOL3]VOU(NOLD)         = [F:SDH]VOU
  [M:BOL3]PACNBR(NOLD)      = [F:SDH]PACNBR
  [M:BOL3]LICPLATE(NOLD)    = [F:SDH]LICPLATE
  [M:BOL3]ETD(NOLD)         = [F:SDH]ETD
  [M:BOL3]ETA(NOLD)         = [F:SDH]ETA
  [M:BOL3]DPEDAT(NOLD)      = [F:SDH]DPEDAT
  [M:BOL3]ARVDAT(NOLD)      = [F:SDH]ARVDAT
  [M:BOL3]TRLLICPLATE(NOLD) = [F:SDH]TRLLICPLATE
  NOLD += 1
Next

Filter [F:SDH]

Return

######################################################################################
$SET_PNH_DATA

# If Include validated is Yes then do not check the CFMFLG checking
If [M:BOL3]VALFLG = 2
  CRITERE = 'CPY=[M:BOL3]CPY & PNHFCY=[M:BOL3]FCY & BPSNUM=[M:BOL3]BPR & PNHNUM<>[M:BOL0]DOCNUM & BOLNUM="" & (RTNDAT>=[M:BOL3]DATDEB & RTNDAT<=[M:BOL3]DATFIN)'
Else
  CRITERE = 'CPY=[M:BOL3]CPY & PNHFCY=[M:BOL3]FCY & BPSNUM=[M:BOL3]BPR & PNHNUM<>[M:BOL0]DOCNUM & CFMFLG<>2 & BOLNUM="" & (RTNDAT>=[M:BOL3]DATDEB & RTNDAT<=[M:BOL3]DATFIN)'
Endif

For [F:PNH]PNH0 Where evalue (CRITERE)
  [M:BOL3]DOCNUM(NOLD)      = [F:PNH]PNHNUM
  [M:BOL3]SHIDAT(NOLD)      = [F:PNH]RTNDAT
  Raz [M:BOL3]DLVDAT(NOLD)
  [M:BOL3]CFMFLG(NOLD)      = [F:PNH]CFMFLG
  [M:BOL3]GROWEI(NOLD)      = [F:PNH]TOTGROWEI
  [M:BOL3]NETWEI(NOLD)      = [F:PNH]TOTNETWEI
  [M:BOL3]WEU(NOLD)         = [F:PNH]WEU
  [M:BOL3]VOL(NOLD)         = [F:PNH]TOTVOL
  [M:BOL3]VOU(NOLD)         = [F:PNH]VOU
  Raz [M:BOL3]PACNBR(NOLD)
  [M:BOL3]LICPLATE(NOLD)    = [F:PNH]LICPLATER
  [M:BOL3]ETD(NOLD)         = [F:PNH]ETDR
  [M:BOL3]ETA(NOLD)         = [F:PNH]ETAR
  [M:BOL3]DPEDAT(NOLD)      = [F:PNH]DPEDATR
  [M:BOL3]ARVDAT(NOLD)      = [F:PNH]ARVDATR
  [M:BOL3]TRLLICPLATE(NOLD) = [F:PNH]TRLLICPLATER
  NOLD += 1
Next

Filter [F:PNH]

Return

######################################################################################
$SET_NBLIG

nolign = NOLD-1
[M:BOL3]NBLIG = NOLD

Return

######################################################################################
$SAVEIT

NOLD = 0
Raz mkstat

If [M:BOL2]NBLIGC > 0
  NOLD = [M:BOL2]NBLIGC - 1
Else
  [M:BOL2]NBLIGC = 1
Endif

For NOLD = 0 To [M:BOL3]NBLIG-1
  If [M:BOL3]FLG(NOLD)=2 & !find([M:BOL3]DOCNUM(NOLD),[M:BOL2]DOCNUMCON(0..[M:BOL2]NBLIGC-1))
    [M:BOL2]NBLIGC += 1
    [M:BOL2]DOCNUMCON([M:BOL2]NBLIGC-1) = [M:BOL3]DOCNUM(NOLD)
    # Enable the SAVE button on the main screen
    mkstat = 4
  Endif
Next

Return

######################################################################################
## Screen Field Actions for BOL3
## Section automatically added (screen BOL3) 10/27/2014 21:24:31 (BESPR)
######################################################################################
Subprog C_FLG(VALEUR)
Variable Integer VALEUR()
If VALEUR=2 & VALEUR<>[M:BOL3]FLG(nolign-1)
  Case [M:BOL3]BOLTYP
    When 1 # Customer
      Read [F:SDH]SDH0 = [M:BOL3]DOCNUM(nolign-1)
      If fstat
        GMESSAGE = mess(1,2086,1)   # Nonexistent customer delivery
        VALEUR=1 : mkstat = 2 : End
      Elsif find ([M:BOL3]DOCNUM(nolign-1),[M:BOL2]DOCNUMCON(0..[M:BOL2]NBLIGC-1))
        GMESSAGE = mess(10,2086,1)   # Document already on Contents tab
        VALEUR=1 : mkstat = 2 : End
      Elsif [F:SDH]STOFCY <> [M:BOL0]FCY
        GMESSAGE = mess(47,102,1)   # Incompatible sites
        VALEUR=1 : mkstat = 2 : End
      Elsif [F:SDH]BOLNUM <> ""
        GMESSAGE=func AFNC.MES1(mess(11,2086,1),[F:SDH]BOLNUM)  # This document is tied to BOL xxx
        VALEUR=1 : mkstat = 2 : End
      Elsif [F:SDH]BPCORD<>[M:BOL3]BPR
        GMESSAGE = mess(187,192,1)  # Delivery incompatible with selections already made
        VALEUR=1 : mkstat = 2 : End
      Elsif [F:SDH]BPTNUM<>[M:BOL0]BPTNUM | [F:SDH]MDL<>[M:BOL0]MDL
        GMESSAGE = mess(135,191,1)  # Carrier or delivery terms do not match
        VALEUR=1 : mkstat = 2 : End
      Elsif [F:SDH]BPDADDLIG(0)<>[M:BOL0]BPAADDLIG(0) | [F:SDH]BPDADDLIG(1)<>[M:BOL0]BPAADDLIG(1) | [F:SDH]BPDADDLIG(2)<>[M:BOL0]BPAADDLIG(2)
        GMESSAGE = mess(14,2086,1)  # Delivery incompatible with selections already made
        VALEUR=1 : mkstat = 2 : End
      Elsif [F:SDH]BPDCTY<>[M:BOL0]CTY | [F:SDH]BPDSAT<>[M:BOL0]SAT | [F:SDH]BPDPOSCOD<>[M:BOL0]POSCOD
        GMESSAGE = mess(14,2086,1)  # Delivery incompatible with selections already made
        VALEUR=1 : mkstat = 2 : End
      Endif
    When 2 # Supplier
      Read [F:PNH]PNH0 = [M:BOL3]DOCNUM(nolign-1)
      If fstat
        GMESSAGE = mess(2,2086,1)   # Nonexistent supplier return
        VALEUR=1 : mkstat = 2 : End
      Elsif find ([M:BOL3]DOCNUM(nolign-1),[M:BOL2]DOCNUMCON(0..[M:BOL2]NBLIGC-1))
        GMESSAGE = mess(10,2086,1)   # Document already on Contents tab
        VALEUR=1 : mkstat = 2 : End
      Elsif [F:PNH]PNHFCY <> [M:BOL3]FCY
        GMESSAGE = mess(47,102,1)   # Incompatible sites
        VALEUR=1 : mkstat = 2 : End
      Elsif [F:PNH]BOLNUM <> ""
        GMESSAGE=func AFNC.MES1(mess(11,2086,1),[F:PNH]BOLNUM)  # This document is tied to BOL xxx
        VALEUR=1 : mkstat = 2 : End
      Elsif [F:PNH]BPSNUM<>[M:BOL3]BPR
        GMESSAGE = mess(202,192,1)  # Return incompatible with selections already made
        VALEUR=1 : mkstat = 2 : End
      Elsif [F:PNH]BPTNUM<>[M:BOL0]BPTNUM | [F:PNH]MDL<>[M:BOL0]MDL
        GMESSAGE = mess(135,191,1)   # Carrier or delivery terms do not match
        VALEUR=1 : mkstat = 2 : End
      Elsif [F:PNH]BPAADDLIG(0)<>[M:BOL0]BPAADDLIG(0) | [F:PNH]BPAADDLIG(1)<>[M:BOL0]BPAADDLIG(1) | [F:PNH]BPAADDLIG(2)<>[M:BOL0]BPAADDLIG(2)
        GMESSAGE = mess(14,2086,1)  # Return incompatible with selections already made
        VALEUR=1 : mkstat = 2 : End
      Elsif [F:PNH]CTY<>[M:BOL0]CTY | [F:PNH]SAT<>[M:BOL0]SAT | [F:PNH]POSCOD<>[M:BOL0]POSCOD
        GMESSAGE = mess(14,2086,1)  # Return incompatible with selections already made
        VALEUR=1 : mkstat = 2 : End
      Endif
  Endcase
Endif
End

####################################################################################
