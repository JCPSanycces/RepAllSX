#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HREXT3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone DFNNBR
mkstat = 0
zoncou = "DFNNBR"
indice = 0
status = 1
zoncou = "DFNNBR"
If varmode([M]DFNNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNNBR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]DFNNBR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]DFNNBR = nolign
   status = 75
   Call SAI_DFNNBR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone GRPNBR
mkstat = 0
zoncou = "GRPNBR"
indice = 0
status = 1
zoncou = "GRPNBR"
If varmode([M]GRPNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRPNBR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]GRPNBR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]GRPNBR = nolign
   status = 75
   Call SAI_GRPNBR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_DFNNBR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone DFNNBR
mkstat = 0
zoncou = "DFNNBR"

## Zone DFNDTALVL
mkstat = 0
zoncou = "DFNDTALVL"
IMPENT = [M]DFNDTALVL(indice)
If varinit([M]DFNDTALVL,indice)=0
 IMPENT = 1
Endif
If varmode([M]DFNDTALVL,indice)=0
 [M]DFNDTALVL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNDTALVL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DFNDTALVL(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DFNDTALVL" : GZNUM = 5230 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]DFNDTALVL(indice) = IMPENT

## Zone DFNCOD
mkstat = 0
zoncou = "DFNCOD"
If varmode([M]DFNCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNCOD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]DFNCOD(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DFNCOD" : GZNUM = 1261 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DFNNEWLIG
mkstat = 0
zoncou = "DFNNEWLIG"
IMPENT = [M]DFNNEWLIG(indice)
If varinit([M]DFNNEWLIG,indice)=0
 IMPENT = 1
Endif
If varmode([M]DFNNEWLIG,indice)=0
 [M]DFNNEWLIG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNNEWLIG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DFNNEWLIG(indice)
 Endif
Endif
[M]DFNNEWLIG(indice) = IMPENT

## Zone DFNFXDTXT
mkstat = 0
zoncou = "DFNFXDTXT"
If varmode([M]DFNFXDTXT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNFXDTXT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DFNTYP
mkstat = 0
zoncou = "DFNTYP"
WCHAR = [M]DFNTYP(indice)
If varmode([M]DFNTYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNTYP" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]DFNTYP(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DFNTYP" : GZNUM = 680 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]DFNTYP(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_DFNTYP([M]DFNTYP(indice)) From SUBHREXT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DFNTYP" : GZNUM = 680 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone DFNLNG
mkstat = 0
zoncou = "DFNLNG"
If varmode([M]DFNLNG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNLNG" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]DFNLNG(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DFNLNG" : GZNUM = 25 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DFNVALCLC
mkstat = 0
zoncou = "DFNVALCLC"
If varmode([M]DFNVALCLC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNVALCLC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DFNCDN
mkstat = 0
zoncou = "DFNCDN"
If varmode([M]DFNCDN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNCDN" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DFNTIT
mkstat = 0
zoncou = "DFNTIT"
If varmode([M]DFNTIT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNTIT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DFNMDT
mkstat = 0
zoncou = "DFNMDT"
IMPENT = [M]DFNMDT(indice)
If varinit([M]DFNMDT,indice)=0
 IMPENT = 2
Endif
If varmode([M]DFNMDT,indice)=0
 [M]DFNMDT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNMDT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DFNMDT(indice)
 Endif
Endif
[M]DFNMDT(indice) = IMPENT

## Zone DFNEXREMT
mkstat = 0
zoncou = "DFNEXREMT"
IMPENT = [M]DFNEXREMT(indice)
If varinit([M]DFNEXREMT,indice)=0
 IMPENT = 1
Endif
If varmode([M]DFNEXREMT,indice)=0
 [M]DFNEXREMT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNEXREMT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DFNEXREMT(indice)
 Endif
Endif
[M]DFNEXREMT(indice) = IMPENT

## Zone DFNEXUFLD
mkstat = 0
zoncou = "DFNEXUFLD"
If varmode([M]DFNEXUFLD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNEXUFLD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DFNTOTFLD1
mkstat = 0
zoncou = "DFNTOTFLD1"
If varmode([M]DFNTOTFLD1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNTOTFLD1" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DFNTOTCLC1
mkstat = 0
zoncou = "DFNTOTCLC1"
If varmode([M]DFNTOTCLC1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNTOTCLC1" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DFNTOTFLD2
mkstat = 0
zoncou = "DFNTOTFLD2"
If varmode([M]DFNTOTFLD2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNTOTFLD2" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DFNTOTCLC2
mkstat = 0
zoncou = "DFNTOTCLC2"
If varmode([M]DFNTOTCLC2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNTOTCLC2" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DFNTOTFLD3
mkstat = 0
zoncou = "DFNTOTFLD3"
If varmode([M]DFNTOTFLD3,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNTOTFLD3" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DFNTOTCLC3
mkstat = 0
zoncou = "DFNTOTCLC3"
If varmode([M]DFNTOTCLC3,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNTOTCLC3" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DFNNBR
mkstat = 0
zoncou = "DFNNBR"

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_GRPNBR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone GRPNBR
mkstat = 0
zoncou = "GRPNBR"

## Zone GRPDTALVL
mkstat = 0
zoncou = "GRPDTALVL"
IMPENT = [M]GRPDTALVL(indice)
If varinit([M]GRPDTALVL,indice)=0
 IMPENT = 1
Endif
If varmode([M]GRPDTALVL,indice)=0
 Call INICOMBO(11677) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_GRPDTALVL(IMPENT) From SUBHREXT
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,11677,1))))
 Endif
 [M]GRPDTALVL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRPDTALVL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]GRPDTALVL(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "GRPDTALVL" : GZNUM = 5230 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]GRPDTALVL(indice) = IMPENT

## Zone GRPDTACLC
mkstat = 0
zoncou = "GRPDTACLC"
If varmode([M]GRPDTACLC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRPDTACLC" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]GRPDTACLC(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "GRPDTACLC" : GZNUM = 5935 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone GRPORD
mkstat = 0
zoncou = "GRPORD"
If varmode([M]GRPORD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRPORD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]GRPORD(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "GRPORD" : GZNUM = 21329 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone GRPNBR
mkstat = 0
zoncou = "GRPNBR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HREXT3"
Return

