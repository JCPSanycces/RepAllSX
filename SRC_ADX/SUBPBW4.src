Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
# Issue 111207 - 2016-04-04 by BEEBE : Field is alway blocked for Subcontracting Orders
If [M:PBW4]WIPTYP=13
    mkstat=2
Else
    Call AS_ECCVALMAJ(VALEUR) From SUBPBWECC
Endif
End

Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Call C_ECCVALMAJ_P(VALEUR, "PBW4") From SUBPBWECC
If VALEUR<>[M:PBW4]ECCVALMAJ
    GMODIF=3
Endif
End

Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
# Issue 111207 - 2016-04-04 by BEEBE : Field is alway blocked for Subcontracting Orders
If [M:PBW4]WIPTYP=13
    mkstat=2
Else
    Call AS_ECCVALMIN(VALEUR) From SUBPBWECC
Endif
End

Subprog C_ECCVALMIN(VALEUR)
