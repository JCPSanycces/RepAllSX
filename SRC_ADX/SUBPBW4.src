#<AdxTL>@(#)0.0.0.0 $Revision$
########################################
$ACTION
Case ACTION
 When "AAM_STOFCY"   : Gosub AAM_STOFCY
 When "BAM_STOFCY"   : Gosub BAM_STOFCY
Endcase
Return

########################################
$AAM_STOFCY
#-------------------------------------------------------------#
# Avant exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     SITE(GLONFCY)   : SITE=VALEUR
Local Char     WOBJET(GLONAOB) : WOBJET="ITF"
#----- Restauration de l'ancienne valeur et blocage sur le champ -----#
If GBIDI1=1  VALEUR=[M:PBW4]STOFCY : mkstat=1 : Endif
If GBIDI1<>2 WOBJET="" : Endif : # Pas d'exécution du tunnel
GFLTITM=[M:PBW4]ITMREF
Return

########################################
$BAM_STOFCY
#-------------------------------------------------------------#
# Après exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
nolign=NOL+1: # Restitution du nolign
Raz GFLTITM
If GBIDI1=0  Return : Endif
VALEUR=SITE
Read [ITF] ITF0=[M:PBW4]ITMREF;VALEUR
If fstat Raz [F:ITF] : Endif
If [F:ITF]ITMREF="" mkstat=1 : Endif
Return

########################################
Subprog AM_EXTRCPDAT(VALEUR)
Variable Date    VALEUR
Local    Date    TODAY : TODAY = date$

# FQ 55989 GA 09/2009 sauvegarde du contrat avant rafraichissement de liste
Local    Char    WPOCNUM(GLONVCR) : WPOCNUM = [M:PBW4]POCNUM

If VALEUR < datesyst
          Call MESSAGE(mess(65,194,1)) From GESECRAN
Endif
[M:PBW4]EXTRCPDAT = VALEUR
Gosub CHARGE_WRCPDAT From BENCHLIBP

# rafraichissement liste contrats
If [M:PBW4]EXTRCPDAT <> [0/0/0]
    WDATEREF = [M:PBW4]EXTRCPDAT
Else
    WDATEREF = TODAY
Endif
# FQ 55989 GA 09/2009 les contrats ne sont pas listés si  WDATEREF < date$
#Filter [POC] Where ITMREF = [M:PBW4]ITMREF & ENDDAT >= WDATEREF & PRHFCY = [M:PBW4]STOFCY & WDATEREF >= date$
Filter [POC] Where ITMREF = [M:PBW4]ITMREF & ENDDAT >= WDATEREF & PRHFCY = [M:PBW4]STOFCY & STRDAT<= WDATEREF
nolign = 1
For [POC]POC2
    If nolign > dim([M:PBW4]SELIND) : Break : Endif
    Read [POH]POH0=[F:POC]POHNUM
    If fstat : Goto N_POC : Endif
    If !find([F:POH]APPFLG,3,4,5) : Goto N_POC : Endif
    If [F:POH]CLEFLG = 2          : Goto N_POC : Endif
    [M:PBW4]SELIND(nolign-1) = 1
    [M:PBW4]POHNUM(nolign-1) = [F:POC]POHNUM
    [M:PBW4]BPSNUM2(nolign-1)= [F:POC]BPSNUM
    [M:PBW4]STRDAT(nolign-1) = [F:POC]STRDAT
    [M:PBW4]ENDDAT(nolign-1) = [F:POC]ENDDAT
    [M:PBW4]PUU2(nolign-1)   = [F:POC]PUU
    [M:PBW4]USEPLC2(nolign-1)= [F:POC]USEPLC
    [M:PBW4]PURFCY(nolign-1) = [F:POC]POHFCY
  # FQ 55989 GA 09/2009 contrat courant
    If  WPOCNUM<>"" & WPOCNUM=[F:POC]POHNUM [M:PBW4]SELIND(nolign-1) = 2 Endif
    nolign += 1
$N_POC
Next
[M:PBW4]NBLIG = nolign - 1
Filter [POC]

# 14102 mm 04.06
# TRS : fournisseur non modifiable
If [M:PBW4]WIPTYP=7 & [M:PBW4]WIPSTA =3
    Grizo [M:PBW4]BPSNUM
# FQ 60084 GA 11/2009 ne pas réactiver si désactivé par ailleurs
#Else
#    Actzo [M:PBW4]BPSNUM
Endif

# -------------------------------------------------
# FQ 55989 & 52248: validité dates du contrat ?
# -------------------------------------------------
If WPOCNUM<>""
   Read [POC]POC1=WPOCNUM;[M:PBW4]ITMREF;[M:PBW4]PSHFCY
   If fstat Raz [F:POC] Endif
   If ([M:PBW4]EXTRCPDAT<[F:POC]STRDAT & [F:POC]STRDAT<>[0/0/0])
           # Cette date doit être supérieure à la date du contrat - FQ 59827 "DD2" devient "D:"+GFMDAT4
             GMESSAGE = mess(98,199,1)-[M:PBW4]POCNUM-format$("D:"+GFMDAT4,[F:POC]STRDAT)
             mkstat = 2 : End
   Endif
   If ([M:PBW4]EXTRCPDAT>[F:POC]ENDDAT & [F:POC]ENDDAT<>[0/0/0])
           # La date est supérieure à la date de validité du contrat - FQ 59827 "DD2" devient "D:"+GFMDAT4
             GMESSAGE = mess(128,192,1)-[M:PBW4]POCNUM-format$("D:"+GFMDAT4,[F:POC]ENDDAT)
             mkstat = 2 : End
   Endif
Endif
#
# Issue 115771 - 2016-04-25 by BEEBE : PJT may only be displayed on this screen
# Actzo [M:PBW4]PJT
Affzo [M:PBW4]25

End

########################################
Subprog AS_QTYPUU(VALEUR)
Variable Decimal VALEUR
GBOUT1 = ""
If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif


#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [M:PBW4]STOFCY | [F:ITF]ITMREF <> [F:ITM]ITMREF
   Read [ITF]ITF0 = [F:ITM]ITMREF;[M:PBW4]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

If [F:ITF]STOMGTCOD > 1 : GBOUT1=mess(102,198,1) : Endif
GBOUT2 = mess(332,198,1)
End

########################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Decimal    WQTY
Local Decimal    WCOEUOM, WCOEF1, WCOEF2
Local Char       WPUU(GLONUOM)

# Issue 97005 GA 02/2014 attention si OF sans code fournisseur !
# Issue 94215 & 88046 GA 12/2013 pas de changt de fournisseur/site/adresse rcp
#If find([M:PBW4]VCRTYP,10,36) & [M:PBW4]BPSNUM<>VALEUR
If [M:PBW4]VCRTYP=36 & [M:PBW4]BPSNUM<>VALEUR
   GMESSAGE = mess(461,194,1)
   Call ERREUR(GMESSAGE) From GESECRAN
   mkstat = 2
   VALEUR=[M:PBW4]BPSNUM
   End
Endif

# Epic: 55934 (STLIG)
If (VALEUR = "")
  End
Endif

# interx
If [F:BPR]BPRNUM <> VALEUR
    Read [F:BPR]BPR0=VALEUR
    If fstat : Raz [BPR] : Endif
Endif
If [F:BPR]FCY <> ""
    [M:PBW4]APPFCY = [F:BPR]FCY
Endif

If (clalev([F:ITP]) = 0) : Local File ITMBPS [ITP] : Endif

    # il faut vérifier que la qté saisie >= qte min achat
    # attention l'unité achat est peut etre differente

# Epic: 55934 (STLIG)
If ([F:ITP]BPSNUM <> VALEUR | [F:ITP]ITMREF <> [M:PBW4]ITMREF)
  Read [ITP]ITP0 = [M:PBW4]ITMREF;VALEUR
  If (fstat)
    Raz [F:ITP]
  Endif
Endif
If ([F:ITP]BPSNUM <> "")

  WQTY = [M:PBW4]QTYPUU
  WPUU = [F:ITP]PUU

  #----- Récupération des coefficients entre UA et US -----#
  # 05.05 30036
  Call PCAL_QTY (1, [M:PBW4]PUU, GBIDD3, [M:PBW4]STU,
&   [M:PBW4]ITMREF, [M:PBW4]BPSNUM, 1, WCOEF1) From TRTACHQTE1
  Call PCAL_QTY (1, [F:ITP]PUU, GBIDD3, [M:PBW4]STU,
&   [M:PBW4]ITMREF, VALEUR, 1, WCOEF2) From TRTACHQTE1
  If [M:PBW4]PUU <> [F:ITP]PUU | WCOEF1 <> WCOEF2
    GMESSAGE = mess(13,194,1)
    Call MESSAGE(GMESSAGE) From GESECRAN
    #--------- qté achat saisie ------#
    # 05.05 30036
    Call PCAL_QTY ([M:PBW4]QTYSTU, [M:PBW4]STU, WQTY, [F:ITP]PUU,
&     [M:PBW4]ITMREF, VALEUR, 1, WCOEUOM) From TRTACHQTE1
  Endif

  [M:PBW4]QTYPUU = WQTY
  [M:PBW4]PUU    = WPUU
  # qté stock saisie
  Call PCAL_QTY ([M:PBW4]QTYPUU, [M:PBW4]PUU, [M:PBW4]QTYSTU, [M:PBW4]STU,
&   [M:PBW4]ITMREF, VALEUR, 1, WCOEUOM) From TRTACHQTE1
  Affzo [M:PBW4]15

Else
  [M:PBW4]PUU    = [F:ITM]PUU
  # qté stock saisie
  Call PCAL_QTY ([M:PBW4]QTYSTU, [M:PBW4]STU, [M:PBW4]QTYPUU, [M:PBW4]PUU,
&   [M:PBW4]ITMREF, VALEUR, 1, WCOEUOM) From TRTACHQTE1
  Affzo [M:PBW4]15-25

Endif

End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer WRETOUR

Raz [M:PBW4]QTYPUU
Raz [M:PBW4]QTYSTU
Raz [M:PBW4]PUU
Raz [M:PBW4]STU
Filter [POC] Where ITMREF=VALEUR & STRDAT<=date$ & ENDDAT>=date$ Order By Key POC2
Look [POC] First
If fstat = 0
    GMESSAGE = mess(1,194,1)
    Call AVERTIR(GMESSAGE,WRETOUR) From GESECRAN
    If WRETOUR= 1
        VALEUR = ""
        mkstat = 1
    Endif
Endif
Filter [POC]

If WRETOUR = 1 : End :  Endif

[M:PBW4]STU    = [F:ITM]STU
[M:PBW4]PUU    = [F:ITM]PUU
Affzo [M:PBW4]PUU
Affzo [M:PBW4]STU
Affzo [M:PBW4]QTYPUU
Affzo [M:PBW4]QTYSTU
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Read [ITF]ITF0 = VALEUR;[M:PBW4]STOFCY
If fstat
    Raz [F:ITF]
    GMESSAGE = mess(25,192,1)
    mkstat = 2
Endif

# llc 11.01 11042
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat : Raz [ITM] : Endif
Endif
#----- Contrôle article en fin de vie ------#
If [F:ITM]LIFENDDAT <> [0/0/0] & [F:ITM]LIFENDDAT < date$
   mkstat = 1 : GMESSAGE = mess(12,318,1) : End
Endif

End


########################################
Subprog AM_SELIND(VALEUR)
Variable Integer VALEUR
Local Integer I
Local Integer    WRETOUR
Local Decimal    WQTY
Local Decimal    WCOEUOM

[M:PBW4]SELIND(nolign-1) = VALEUR
For  I = 0 To [M:PBW4]NBLIG - 1
    If I <> nolign - 1 : [M:PBW4]SELIND(I) = 1 : Endif
Next I
Case VALEUR
    When 2:             Call C_BPSNUM([M:PBW4]BPSNUM2(nolign-1))
                        If mkstat : End : Endif
                        WQTY = [M:PBW4]QTYPUU
                        If [M:PBW4]PUU <> [M:PBW4]PUU2(nolign-1)
                           GMESSAGE = mess(13,194,1)
                           Call MESSAGE(GMESSAGE) From GESECRAN
                           #--------- qté achat saisie ------#
                           Call PCAL_QTY ([M:PBW4]QTYPUU, [M:PBW4]PUU, WQTY, [M:PBW4]PUU2(nolign-1),
&                                         [M:PBW4]ITMREF, [M:PBW4]BPSNUM2(nolign-1), 1, WCOEUOM) From TRTACHQTE1
                        Endif

                        [M:PBW4]QTYPUU = WQTY
                        [M:PBW4]PUU    = [M:PBW4]PUU2(nolign-1)
                        # qté stock saisie
                        Call PCAL_QTY ([M:PBW4]QTYPUU, [M:PBW4]PUU, [M:PBW4]QTYSTU, [M:PBW4]STU,
&                                      [M:PBW4]ITMREF, [M:PBW4]BPSNUM2(nolign-1), 1, WCOEUOM) From TRTACHQTE1

                       [M:PBW4]POCNUM = [M:PBW4]POHNUM(nolign-1)
                       [M:PBW4]BPSNUM = [M:PBW4]BPSNUM2(nolign-1)
                       [M:PBW4]USEPLC = [M:PBW4]USEPLC2(nolign-1)
                       [M:PBW4]PSHFCY = [M:PBW4]PURFCY(nolign-1)
    When Default:   [M:PBW4]POCNUM = ""
                    Call AM_BPSNUM([M:PBW4]BPSNUM)
Endcase
Affzo [M:PBW4]15-25
End

########################################
Subprog AV_BPSNUM(VALEUR)
Variable Char    VALEUR()

# 14102 mm 04.06
# TRS : fournisseur non modifiable
If [M:PBW4]WIPTYP=7 & [M:PBW4]WIPSTA =3 :
# Issue 115771 - 2016-04-25 by BEEBE : PJT only display in this screen
#    Grizo [M:PBW4]BPSNUM : Actzo [M:PBW4]PJT: End
    Grizo [M:PBW4]BPSNUM : End
Endif
#
If find(2,[M:PBW4]SELIND(0..[M:PBW4]NBLIG-1))
    Diszo [M:PBW4]BPSNUM
#    Diszo [M:PBW4]PJT
# Issue 83198 GA 08/2012 Raz modif précédente: réactiver si aucune ligne sélectionnée
# FQ 60084 GA 11/2009 ne pas réactiver
Else
    Actzo [M:PBW4]BPSNUM
#    Actzo [M:PBW4]PJT
Endif
# End issue 115771
End

########################################
Subprog AS_BPSNUM(VALEUR)
Variable Char    VALEUR()

# Epic: 55934 (STLIG) enable/disable product selection on parameter: ITMBPSFCY
If (GITMBPSFCY = 1)
  GBOUT2 = ""
Else
  GBOUT2 = mess(1,3505,1)
Endif
GBOUT3 = mess(2,3505,1) # product-site suppliers
GBOUT4 = mess(24,198,1)
#GBOUT2 = mess(23,198,1)
#GBOUT3 = mess(24,198,1)


# Issue 94215 & 88046 GA 12/2013 pas de changt de fournisseur/site/adresse rcp
# Issue 113293 - 2016-01-15 by BEEBE : BPSNUM may be modified when SubconOrder will be generated
#                                      by GESMFG -> disenable access for field only when VCRTYP=36
#If find([M:PBW4]VCRTYP,10,36) & [M:PBW4]BPSNUM<>""
If find([M:PBW4]VCRTYP,36) & [M:PBW4]BPSNUM<>""
   mkstat=2
Endif

End

########################################
Subprog C_EXTRCPDAT(VALEUR)
Variable Date    VALEUR
# llc 11.01 11042
#----- Contrôle article en fin de vie ------#
If [F:ITM]LIFENDDAT <> [0/0/0] & [F:ITM]LIFENDDAT < date$
   mkstat = 1 : GMESSAGE = mess(12,318,1) : End
Endif

# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:PBW4]ECCVALMAJ)>0
    Call C_EXTRCPDAT(VALEUR, "PBW4") From SUBPBWECC
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 08/12/2003 15:52:10 (MM)
##########################################################################
# Saisie qté en US - 14649 12.03 MM
Subprog AM_QTYPUU(VALEUR)
Variable Decimal VALEUR

Affzo [M:PBW4]QTYSTU

If VALEUR=0 & [M]QTYSTU=0
    Raz [M]QTYPUU
    mkstat = 2 : GMESSAGE = mess(223,193,1)    #Il faut saisir une quantité soit en UA, soit en US
Endif

Call UPD_PPTOTALS([M:PBW4]QTYSTU)    # 106430.n
End


##########################################################################
# Saisie qté en US - 14649 12.03 MM
Subprog AM_QTYSTU(VALEUR)
Variable Decimal VALEUR
Affzo [M:PBW4]QTYPUU

If VALEUR=0 & [M]QTYPUU=0
    Raz [M]QTYSTU
    mkstat = 2 : GMESSAGE = mess(223,193,1)    #Il faut saisir une quantité soit en UA, soit en US
Endif

Call UPD_PPTOTALS(VALEUR)    # 106430.n
End


##########################################################################
Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer INDINTER : INDINTER = 0

# Epic: 55934 (STLIG) validate 1. blocking flag, and 2. product and product-site reference
Local Integer WITMBPS
Local Integer WRETOUR
If (VALEUR <> "")
  Call CTRL_DOUFLG(1,[M:PBW4]ITMREF,VALEUR,[M:PBW4]PSHFCY,WITMBPS,WRETOUR) From TRTACHCTL1
  If (WRETOUR <> 0)
    mkstat = 2 : End
  Endif
Endif

If VALEUR <> ""
    Read [BPR]BPR0=VALEUR
    If fstat : Raz [F:BPR] : Endif

    If [F:BPR]FCY <> ""
        If [F:FCY]FCY <> [F:BPR]FCY
            Read [FCY]FCY0=[F:BPR]FCY
            If fstat : Raz [FCY] : Endif
        Endif
    Endif
    If !find([M:PBW4]INTHAB,1,2,3,4,5,6,7) & [F:BPR]FCY <> "" & [F:FCY]LEGCPY = GSOCIETE     # 14102 mm 04.06
        GMESSAGE =mess(233,193,1) :  mkstat=2 : End
    Endif
    If !find([M:PBW4]APPHAB,1,2,3,4,5,6,7) & ([F:BPR]FCY = "" |([F:BPR]FCY <> "" & [F:FCY]LEGCPY <> GSOCIETE)) # 14102 mm 04.06
        GMESSAGE =mess(235,193,1) :  mkstat=2 : End
    Endif
    ## GH 28/07/2014 bug 101438
    If [F:BPR]FCY =  [M:PBW4]PSHFCY
        GMESSAGE =VALEUR-[M:PBW4]PSHFCY-mess(334,194,1) :  mkstat=2 : End
    Endif
    ##
    If [F:BPR]FCY <> "" & [F:FCY]LEGCPY = GSOCIETE  : INDINTER = 1 : Endif
Endif
End


##########################################################################

Subprog C_PSHFCY(VALEUR)
Variable Char    VALEUR()
Local Integer    I
I = find(VALEUR ,GSITE(1..GNBSITE))
If I
  GSOCIETE=GSOCSITE(I)
Endif
Call LECTURE ("FCY", [M:PBW4]STOFCY, "") From CONTOBJ
If [F:FCY]LEGCPY <> GSOCIETE
    GMESSAGE=VALEUR-mess(2,194,1) : mkstat=2 : End
Endif
End
######################################################################################
Subprog AM_TCTRNUM(VALEUR)
Variable Char    VALEUR()
  Call UPD_CONTAINER (VALEUR, [M:PBW4]TCTRQTY)   # 106430.n
End

Subprog AM_TCTRQTY(VALEUR)
Variable Decimal VALEUR
  Call UPD_CONTAINER ([M:PBW4]TCTRNUM, VALEUR)    # 106430.n
End

Subprog AM_WEICAP(VALEUR)
Variable Decimal VALEUR

Raz [M:PBW4]WEIAVL
If VALEUR > 0 : [M:PBW4]WEIAVL = VALEUR-[M:PBW4]WEITOT : Endif

If [M:PBW4]WEIAVL<0
  Chgstl [M:PBW4]WEIAVL With "NBNEGATIF"
Else
  Chgstl [M:PBW4]WEIAVL With ""
Endif

Affzo [M:PBW4]WEIAVL

End

Subprog AM_VOLCAP(VALEUR)
Variable Decimal VALEUR

Raz [M:PBW4]VOLAVL
If VALEUR > 0 : [M:PBW4]VOLAVL = VALEUR-[M:PBW4]VOLTOT : Endif

If [M:PBW4]VOLAVL<0
  Chgstl [M:PBW4]VOLAVL With "NBNEGATIF"
Else
  Chgstl [M:PBW4]VOLAVL With ""
Endif

Affzo [M:PBW4]VOLAVL

End

######################################################################################
# 106430 - Purhcase planning - Update header total fields
######################################################################################
Subprog UPD_PPTOTALS(QTY)
Variable Decimal QTY

Raz [M:PBW4]WEITOT, WEIAVL, VOLTOT, VOLAVL, TOTCOST

[M:PBW4]WEITOT    = [M:PBW4]ITMWEI * QTY
If [M:PBW4]WEU<>[M:PBW4]TCTRWEU
  Call CONVERT_QTY([M:PBW4]WEU,[M:PBW4]TCTRWEU,[M:PBW4]WEITOT)From TRTX3
Endif
If [M:PBW4]WEICAP > 0 : [M:PBW4]WEIAVL = [M:PBW4]WEICAP-[M:PBW4]WEITOT : Endif

#Volumes
[M:PBW4]VOLTOT    = [M:PBW4]ITMVOL * QTY
If [M:PBW4]VOU<>[M:PBW4]TCTRVOU
  Call CONVERT_QTY([M:PBW4]VOU,[M:PBW4]TCTRVOU,[M:PBW4]VOLTOT)From TRTX3
Endif
If [M:PBW4]VOLCAP > 0 : [M:PBW4]VOLAVL = [M:PBW4]VOLCAP-[M:PBW4]VOLTOT : Endif

#Costs
[M:PBW4]TOTCOST     = [M:PBW4]PURBASPRI * QTY

If [M:PBW4]WEIAVL<0
  Chgstl [M:PBW4]WEIAVL With "NBNEGATIF"
Else
  Chgstl [M:PBW4]WEIAVL With ""
Endif

If [M:PBW4]VOLAVL<0
  Chgstl [M:PBW4]VOLAVL With "NBNEGATIF"
Else
  Chgstl [M:PBW4]VOLAVL With ""
Endif

Affzo [M:PBW4]WEITOT, WEIAVL, VOLTOT, VOLAVL, TOTCOST

End

######################################################################################
# 106430 - Update container related fields
######################################################################################
Subprog UPD_CONTAINER (TCTRNUM,TCTRQTY)
Value Char    TCTRNUM
Value Integer TCTRQTY

Read [TCTR]TCTR0 = [L]TCTRNUM
If fstat : Raz [F:TCTR] : Endif

If [L]TCTRNUM = ""
  Raz [M:PBW4]TCTRQTY : Diszo [M:PBW4]TCTRQTY
  Actzo [M:PBW4]WEICAP, VOLCAP
Else
  Actzo [M:PBW4]TCTRQTY

  #Set the weight and volume capacity for the container
  If [L]TCTRQTY <= 0 : [L]TCTRQTY=1 : Endif
  [M:PBW4]WEICAP = [F:TCTR]MAXWEI  * [L]TCTRQTY
  [M:PBW4]VOLCAP = [F:TCTR]TCTRVOL * [L]TCTRQTY

  Affzo [M:PBW4]WEICAP, VOLCAP
  Diszo [M:PBW4]WEICAP, VOLCAP
Endif

#Set the UOM for both weight and volume
If [F:TCTR]WEU="" : [M:PBW4]TCTRWEU = GSALDSPWEU : Else : [M:PBW4]TCTRWEU = [F:TCTR]WEU : Endif
If [F:TCTR]VOU="" : [M:PBW4]TCTRVOU = GSALDSPVOU : Else : [M:PBW4]TCTRVOU = [F:TCTR]VOU : Endif

[M:PBW4]WEITOT = [M:PBW4]ITMWEI * [M:PBW4]QTYSTU
If [M:PBW4]WEU<>[M:PBW4]TCTRWEU #If we didn't change - no need to update
  Call CONVERT_QTY([M:PBW4]WEU,[M:PBW4]TCTRWEU,[M:PBW4]WEITOT)From TRTX3
Endif
If [M:PBW4]WEICAP > 0 : [M:PBW4]WEIAVL = [M:PBW4]WEICAP-[M:PBW4]WEITOT : Endif

[M:PBW4]VOLTOT = [M:PBW4]ITMVOL * [M:PBW4]QTYSTU
If [M:PBW4]VOU<>[M:PBW4]TCTRVOU #If we didn't change - no need to update
  Call CONVERT_QTY([M:PBW4]VOU,[M:PBW4]TCTRVOU,[M:PBW4]VOLTOT)From TRTX3
Endif
If [M:PBW4]VOLCAP > 0 : [M:PBW4]VOLAVL = [M:PBW4]VOLCAP-[M:PBW4]VOLTOT : Endif

If [M:PBW4]WEIAVL<0
  Chgstl [M:PBW4]WEIAVL With "NBNEGATIF"
Else
  Chgstl [M:PBW4]WEIAVL With ""
Endif

If [M:PBW4]VOLAVL<0
  Chgstl [M:PBW4]VOLAVL With "NBNEGATIF"
Else
  Chgstl [M:PBW4]VOLAVL With ""
Endif

Affzo [M:PBW4]TCTRWEU, TCTRVOU, WEITOT, WEIAVL, VOLTOT, VOLAVL
End

