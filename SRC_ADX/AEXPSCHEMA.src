Raz GNBMASKOUV
Local Char PARAM(30)(1..10) , VALEUR(10)
PARAM = "AHIX"
PARAM = "AMKXML"
Call TRAITE_CHAR(VALEUR,PARAM,"AWE","AEXPSCHEMA","",2,"") From GTRAITE
End

#-------------------------------------------#
$ACTION
Case ACTION
 When "DEBUT"     : Gosub DEBUT
 When "INIT"      : Gosub INIT
 When "AVANT_PAR" : Gosub AVANT_PAR
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
 When "TERMINE"   : Gosub TERMINE
Endcase
Return

#-------------------------------------------#
# Affichage de l'Ã©cran AWE2 pour dÃ©bugger
#-------------------------------------------#

$OUVRE
Onerrgo RIEN
Return

$DEBUT
Affzo
Return

$FIN
Onerrgo
Return

$RIEN
Resume

#-------------------------------------------#
# Export schÃ©ma modÃ¨le d'import XML
#-------------------------------------------#

$INIT
If clalev([F:AOE])=0 : Local File AOBJEXT    [AOE] : Endif
If clalev([F:AOD])=0 : Local File AOBJEXTD   [AOD] : Endif
If clalev([F:AOR])=0 : Local File AOBJEXTR   [AOR] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:ATB])=0 : Local File ATABLE     [ATB] : Endif
If clalev([F:ATI])=0 : Local File ATABIND    [ATI] : Endif
If clalev([F:AOB])=0 : Local File AOBJET     [AOB] : Endif
If clalev([F:AMP])=0 : Local File AMSKPAR    [AMP] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
If clalev([F:ATY])=0 : Local File ATYPE      [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE     [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
Return

#--------------------------------------------------------------------------------------------#
$AVANT_PAR
TIT = func AFNC.MES(mess(172,141,1),PARAM(1)) : # Export SchÃ©ma du modÃ¨le #
Return

#--------------------------------------------------------------------------------------------#
$TERMINE
If filinfo(NOMFIC,0)>0 
 Call OUVRE_TRACE(mess(104,121,1)-":"-NOMFIC) From LECFIC : # Fichier gÃ©nÃ©rÃ©
 Openi NOMFIC,0 Using [HTI_]
 Iomode adxifs "" Using [HTI_]
 Iomode adxirs chr$(10) Using [HTI_]
 Case ACODAGE
  When 1 : Iomode adxium GASCII Using [HTI_]
  When 2 : Iomode adxium GUTF8 Using [HTI_]
  When 3 : Iomode adxium GUCS2 Using [HTI_]
 Endcase
 Rdseq LIGNE Using [HTI_]
 While !fstat
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  Rdseq LIGNE Using [HTI_]
 Wend 
 Openi Using [HTI_]
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
Return

#--------------------------------------------------------------------------------------------#
$CONTROLE
Local Char    PUBLI(30) , CHAINE(250) , APPLI(GLONADS) , MODELE(GLONAOE)
Local Char    CLE(GLONAVA)(1..16) , NOMFIC(GLONATB) , LIGNE(250)
Local Integer I , J , K , IND , NBCLE , ATYPOBJ , ACODAGE , NUTEX
Local Char    FLD(30) , ZONE(50) , INTIT(50)
Local Char    TYP(GLONATY) , ENCODING(30)
Local Integer MNL , NBTAB , DIME , NUMTAB , FLOT , PLUS
Local Decimal LNG
Local Char    TAB(30)(1..50)

Local Mask AWE2 [AWE2]

MODELE = PARAM
Read [AOE]AOE0=MODELE
If fstat
 GERR = 1 : GMESSAGE = MODELE-":"-mess(30,141,1) : # ModÃ¨le inexistant
 FIN = 1 : Return
Elsif [F:AOE]TYPFIL<>5
 GERR = 1 : GMESSAGE = MODELE+"("+mess([F:AOE]TYPFIL,94,1)+")"-":"-mess(72,141,1) : # ModÃ¨le incorrect
 FIN = 1 : Return
Endif

APPLI    = nomap
ATYPOBJ  = 3
PUBLI    = func PUBLI(MODELE)
ACODAGE  = [F:AOE]CODDBA : # ascii/utf-8/ucs2
ENCODING = func ENCODING([F:AOE]CODDBA,[F:AOE]OPTCHA)

Raz [M:AWE2]
For IND=1 To dim([F:AOE]FLGREC)
 If [F:AOE]FLGREC(IND-1)<>""
  Gosub TABLE
 Endif
Next IND

Return

#----------------------------------------------------------#
Funprog ENCODING(TYP,JEU)
Value Integer TYP,JEU
Local Char ENCODE(20)
Case TYP
 When 1 : # ascii
  ENCODE = mess(JEU,9,1)
 When 2 : # utf-8
  ENCODE = tolower(mess(TYP,945,1))
 When 3 : # ucs2
  ENCODE = tolower(mess(TYP,945,1))
Endcase
End ENCODE

#--------------------------------------------------------------------------------------------#
Funprog PUBLI(MODELE)
Value Char MODELE
End "WWIMP"+MODELE

#--------------------------------------------------------------------------------------------#
$EXEC
Gosub GENXSD From AGENXSD
Return

#--------------------------------------------------------------------------------------------#
$TABLE
For [AOD]AOD0 Where EXT=[F:AOE]EXT & TYP=[F:AOE]FLGREC(IND-1)
 Raz TYP , LNG , MNL , INTIT , NUMTAB , NUTEX , FLOT , PLUS
 If find(left$([F:AOD]FLD,1),"/","*","=","'",'"',"")
  TYP = "A"
  LNG = 10
  If dim([F:AOD]BAL)>0 & [F:AOD]BAL<>""
   ZONE = [F:AOD]BAL
  Else
   ZONE = [F:AOD]TYP+"__"+num$([F:AOD]NUMLIG)
  Endif
  INTIT = func TEXTRA("ATABLE","INTFLD",[F:AOD]EXT,[F:AOD]FIL+[F:AOD]FLD)
 Else
  K = instr(1,[F:AOD]FLD,"(")
  If K
   DIME = val(right$([F:AOD]FLD,K+1))
   FLD  = left$([F:AOD]FLD,K-1)
   If dim([F:AOD]BAL)>0 & [F:AOD]BAL<>""
    ZONE = [F:AOD]BAL
   Else
    ZONE = FLD+"_"+num$(DIME)
   Endif
  Else
   FLD  = [F:AOD]FLD
   If dim([F:AOD]BAL)>0 & [F:AOD]BAL<>""
    ZONE = [F:AOD]BAL
   Else
    ZONE = [F:AOD]FLD
   Endif
  Endif
  Read [ATZ]CODZONE=[F:AOD]FIL;[L]FLD
  If !fstat and func ACTIV([F:ATZ]CODACT) 
   TYP   = [F:ATZ]CODTYP
   LNG   = [F:ATZ]LONG
   MNL   = [F:ATZ]NOLIB
   FLOT  = instr(1,[F:ATZ]OPTION,"F")
   PLUS  = instr(1,[F:ATZ]OPTION,"+")
   INTIT = func TEXTE([F:ATZ]NOCOURT)
   NUTEX = [F:ATZ]NOCOURT
   If MNL>1
    INTIT = mess(1,30,1)-num$(MNL)-string$(INTIT<>"","("+INTIT+")") : # Menu local
   Endif
  Else
   INTIT = ""
   TYP   = "A"
   LNG   = 10
  Endif
 Endif
 If dim([F:AOD]BAL)<=0 or [F:AOD]BAL=""
  Read [ATB]CODFIC=[F:AOD]FIL
  ZONE = [F:ATB]ABRFIC+"_"+ZONE
 Endif
 Gosub SETTYP
 If NUMTAB<>0
  INTIT = mess(63,139,1)-num$(NUMTAB)-string$(INTIT<>"","("+INTIT+")")  : # Table diverse
 Endif
 [M:AWE2]NBLIG += 1
 [M:AWE2]SELECT([M:AWE2]NBLIG-1)      = 2
 [M:AWE2]NIVEAU([M:AWE2]NBLIG-1)      = [F:AOE]FLGLEV(IND-1)
 [M:AWE2]GROUPE([M:AWE2]NBLIG-1)      = [F:AOE]FLGREC(IND-1)
 [M:AWE2]CHAMP([M:AWE2]NBLIG-1)       = ZONE
 [M:AWE2]GRPCHP([M:AWE2]NBLIG-1)      = ZONE
 [M:AWE2]INTIT([M:AWE2]NBLIG-1)       = INTIT
 [M:AWE2]NOTEX([M:AWE2]NBLIG-1)       = NUTEX
 K = instr(1,num$(LNG),".")
 If !K
  [M:AWE2]LONG([M:AWE2]NBLIG-1)       = LNG
 Else
  [M:AWE2]LONG([M:AWE2]NBLIG-1)       = val(left$(num$(LNG),K-1))+1+val(right$(num$(LNG),K+1))
 Endif   
 [M:AWE2]NOLIB([M:AWE2]NBLIG-1)       = MNL
 [M:AWE2]DIME([M:AWE2]NBLIG-1)        = 9999
 [M:AWE2]OBLIG([M:AWE2]NBLIG-1)       = max(1,[F:AOD]OBL)
 [M:AWE2]PATTERN([M:AWE2]NBLIG-1)     = [F:AOD]PATTERN
 [M:AWE2]TYPFCT([M:AWE2]NBLIG-1)      = 1
 [M:AWE2]MININCLU([M:AWE2]NBLIG-1)    = 1
 [M:AWE2]MAXINCLU([M:AWE2]NBLIG-1)    = 1
 [M:AWE2]FRACTIONDIG([M:AWE2]NBLIG-1) = 0
 [M:AWE2]TOTALDIGIT([M:AWE2]NBLIG-1)  = 0
 [M:AWE2]VALMIN([M:AWE2]NBLIG-1)      = 0
 [M:AWE2]VALMAX([M:AWE2]NBLIG-1)      = 0
 [M:AWE2]AUTMIN([M:AWE2]NBLIG-1)      = 1
 [M:AWE2]AUTMAX([M:AWE2]NBLIG-1)      = 1
 Case [F:ATY]TYPTYP
  When 1       : [M:AWE2]TYPPAR([M:AWE2]NBLIG-1) = 5  : # Menu local
  When 2       : [M:AWE2]TYPPAR([M:AWE2]NBLIG-1) = 2  : # NumÃ©rique
                 [M:AWE2]AUTMIN([M:AWE2]NBLIG-1) = 2
                 [M:AWE2]AUTMAX([M:AWE2]NBLIG-1) = 2
                 [M:AWE2]VALMIN([M:AWE2]NBLIG-1) = -32768
                 [M:AWE2]VALMAX([M:AWE2]NBLIG-1) = 32767
  When 3       : [M:AWE2]TYPPAR([M:AWE2]NBLIG-1) = 2  : # NumÃ©rique
  When 4,5,6   : [M:AWE2]TYPPAR([M:AWE2]NBLIG-1) = 3  : # DÃ©cimal
                 If LNG>0
                  K = instr(1,num$(LNG),".")
                  If !K
                   If FLOT
                    [M:AWE2]TOTALDIGIT([M:AWE2]NBLIG-1)  = LNG+1
                    [M:AWE2]FRACTIONDIG([M:AWE2]NBLIG-1) = LNG+1
                   Else
                    [M:AWE2]TOTALDIGIT([M:AWE2]NBLIG-1)  = LNG
                    [M:AWE2]FRACTIONDIG([M:AWE2]NBLIG-1) = 0
                   Endif 
                  Else
                   [M:AWE2]TOTALDIGIT([M:AWE2]NBLIG-1)   = val(left$(num$(LNG),K-1))+1+val(right$(num$(LNG),K+1))
                   [M:AWE2]FRACTIONDIG([M:AWE2]NBLIG-1)  = val(right$(num$(LNG),K+1))
                  Endif   
                 Endif
  When 8       : [M:AWE2]TYPPAR([M:AWE2]NBLIG-1) = 4  : # Date
  When 9       : [M:AWE2]TYPPAR([M:AWE2]NBLIG-1) = 7  : # Blob
  When 10      : [M:AWE2]TYPPAR([M:AWE2]NBLIG-1) = 6  : # Clob
  When Default : [M:AWE2]TYPPAR([M:AWE2]NBLIG-1) = 1  : # Char
 Endcase
Next AOD
Return

#-------------------------------------------#
$SETTYP
Read [ATY]CODTYP=TYP
If !fstat
 If [F:ATY]LNGTYP>0
  LNG = [F:ATY]LNGTYP
 Elsif TYP="ATX"
  LNG = GLONDES
 Elsif find(TYP,"AXX","AX1","AX2","AX3")
  Read [AMP]CODPAR = 2;[F:AOD]FIL;[L]FLD;[F:ATY]OBJLIEN
  CHAINE = [F:AMP]VALPAR
  If left$(CHAINE,1)="'" or left$(CHAINE,1)='"'
   CHAINE = seg$(PARTAB,2,len(CHAINE)-1)
  Endif
  NUMTAB = val(CHAINE)
 Endif
 Case [F:ATY]TYPTYP
  When 1 : # Menu
   LNG = 2
   If [F:ATY]NOLIB<>0
    MNL = [F:ATY]NOLIB
   Endif
  When 2 : # Entier court
   If LNG=0
    LNG = 5
   Endif
  When 3 : # Entier long
   If LNG=0
    LNG = 9
   Endif
  When 8 : # Date
   LNG = 10
 Endcase
 If !FLOT
  FLOT = instr(1,[F:ATY]OPTION,"F")
 Endif
 If !PLUS
  PLUS = instr(1,[F:ATY]OPTION,"+")
 Endif
Else
 TYP = "A"
 LNG = 10
Endif
Read [ATY]CODTYP=TYP
Return

#-------------------------------------------#
Funprog ACTIV(CODACT)
Value Char CODACT
If CODACT<>""
 Read [ACV]CODACT=[F:ATZ]CODACT
 If fstat or [F:ACV]FLACT<>2
  End 0
 Endif
Endif
End 1

#-------------------------------------------#
Funprog TEXTE(NUMERO)
Value Integer NUMERO
Local Char TEXTE(250)
Call TEXTE(NUMERO,TEXTE) From OBJDIV
End TEXTE

#-------------------------------------------#
Funprog TEXTRA(TABLE,CHAMP,CLE1,CLE2)
Value Char TABLE
Value Char CHAMP
Value Char CLE1
Value Char CLE2
Local Char TEXTE(250)
Call LECTEXTRA(TEXTE,TABLE,CHAMP,CLE1,CLE2) From ATEXTRA
End TEXTE

