#<AdxTL>@(#)9.0.0.0 $Revision$
Call MAJGRPSIT(nomap)
End

Subprog MAJGRPSIT(APPLI)
Value Char APPLI

Local File =APPLI+".COMPANY"  [CPY]
Local File =APPLI+".FACILITY" [FCY]
Local File =APPLI+".AGRPFCY"  [AGF]
Local File =APPLI+".AGRPCPY"  [AGC]
Local File =APPLI+".FACGROUP" [FGR]

Trbegin [AGF]
 Gosub MAJGRP
Commit
End

$MAJGRP
For [CPY]CPY0
 Read [AGF]AGF0 = [F:CPY]CPY
 If fstat
  Raz [F:AGF]
  [F:AGF]GRP    = [F:CPY]CPY
  [F:AGF]DES    = [F:CPY]CPYNAM
  [F:AGF]SHO    = [F:CPY]CPYSHO
  [F:AGF]FLGLEG = [F:CPY]CPYLEGFLG
  If [F:AGF]FLGLEG=2
   [F:AGF]FLGCPY = 2
  Else
   [F:AGF]FLGCPY = 1
  Endif
  [F:AGF]CREDAT = date$
  [F:AGF]CRETIM = time
  [F:AGF]CREUSR = GUSER
  Write [AGF]
  If fstat
   Call ERREUR("AGRPFCY"-[F:AGF]GRP,1) From DOSDIC
  Endif
 Endif
 If [F:CPY]CPYLEGFLG=2
  Read [AGC]AGC0 = [F:CPY]CPY;[F:CPY]CPY
  If fstat
   [F:AGC]GRP = [F:CPY]CPY
   [F:AGC]CPY = [F:CPY]CPY
   Write [AGC]
   If fstat
    Call ERREUR("AGRPCPY"-[F:AGC]GRP,1) From DOSDIC
   Endif
  Endif
 Endif
Next
Return

