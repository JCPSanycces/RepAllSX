End

#----------------------------------------------------------------#
# Receive from syracuse
#----------------------------------------------------------------#

Subprog SYRRCV(N,ARCV)
Value    Integer N
Variable Instance  ARCV Using C_ASYRRCV
Raz ARCV.ENTITIES , ARCV.SEGMENT , ARCV.HEADERVAL , ARCV.HEADERCOD , ARCV.PARAMCOD , ARCV.PARAMVAL
If GTEST
 Case N
  When 1 : # Prototype detail
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "$prototypes('TABCOUNTRY.$details')"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 2 : # Prototype query
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "$prototypes('TABCOUNTRY.$query')"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 3 : # Detail data
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "ATABLE('ATABLE')"
   ARCV.PARAMCOD(1)  = "representation"
   ARCV.PARAMVAL(1)  = "ATABLE.$details"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.folder1.ATABLE.$details"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 4 : # Query data
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "ATABLE"
   ARCV.PARAMCOD(1)  = "where"
   ARCV.PARAMVAL(1)  = "codfic gt 'A' and codfic lt 'Z'"
   ARCV.PARAMCOD(2)  = "tags"
   ARCV.PARAMVAL(2)  = ""
   ARCV.PARAMCOD(3)  = "orderby"
   ARCV.PARAMVAL(3)  = "abrfic asc"
   ARCV.PARAMCOD(4)  = "startindex"
   ARCV.PARAMVAL(4)  = "1"
   ARCV.PARAMCOD(4)  = "count"
   ARCV.PARAMVAL(4)  = "20"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.folder1.ATABLE.$query"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 5 : # Edit data
   ARCV.VERB         = "post"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "TABCOUNTRY('BIDON')"
   ARCV.ENTITIES(2)  = "$workingCopies"
   ARCV.PARAMCOD(1)  = "representation"
   ARCV.PARAMVAL(1)  = "TABCOUNTRY.$edit"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.folder1.TABCOUNTRY.$edit"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 6 : # Prototype child ATABAUD
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "$prototypes('ATABAUD.$child')"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 7 : # Prototype detail ACTIV
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "$PROTOTYPES('ACTIV.$details')"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.folder1.ACTIV.$details"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 8 : # Query data ACTIV
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "ACTIV"
   ARCV.PARAMCOD(1)  = "where"
   ARCV.PARAMVAL(1)  = "codact>'B' and codact<'C'"
   ARCV.PARAMCOD(2)  = "tags"
   ARCV.PARAMVAL(2)  = "A,B"
   ARCV.PARAMCOD(3)  = "select"
   ARCV.PARAMVAL(3)  = ""
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.folder1.ACTIV.$query"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 9 : # Prototype query
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "$prototypes('TABCOUNTRY.$query')"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.folder1.TABCOUNTRY.$query"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 10 : # Detail data
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "TABLAN('FRA')"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.folder1.TABLAN.$details"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 11 : # Query data
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "TABCOUNTRY"
  # ARCV.PARAMCOD(3)  = "where"
#   ARCV.PARAMVAL(3)  = "cry gt 'B' and lt<'Z'"
   ARCV.PARAMCOD(3)  = "key"
   ARCV.PARAMVAL(3)  = "gt.BH"
 #  ARCV.PARAMVAL(3)  = "lt.BI"
   ARCV.PARAMCOD(2)  = "tags"
   ARCV.PARAMVAL(2)  = ""
   ARCV.PARAMCOD(1)  = "orderby"
   ARCV.PARAMVAL(1)  = "crydes asc"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.folder1.TABCOUNTRY.$query"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 12 : # Prototype cube
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "$prototypes('STATS‾DOM.$cube')"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 13 : # Data cube
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "STATS('DOM')"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
   ARCV.PARAMCOD(1)  = "representation"
   ARCV.PARAMVAL(1)  = "STATS‾DOM.$cube"
   ARCV.PARAMCOD(2)  = "axes"
   ARCV.PARAMVAL(2)  = "‾(‾(!title‾'zzmModule‾!hierarchies‾(‾(‾'zzmModule‾1‾0)‾(‾'zzmClenum1_zzmUpdusr_zzmCpy‾0‾0)‾(‾'zzmCur‾0‾0)))‾(!title‾'Measures‾!hierarchies‾(‾(‾'!measures))))"
   ARCV.PARAMCOD(3)  = "slicer"
   ARCV.PARAMVAL(3)   = "‾(!title‾'zzmModule‾!hierarchies‾(‾(‾'zzmModule‾1‾0)))"
  When 14 : # Prototype query
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "$prototypes('AUTILIS.$query')"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 15 : # Query data
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "AUTILIS"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.folder1.AUTILIS.$query"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 16 : # Image
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "AIMAGE('ABLOB‾AUSPIC‾MB')"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.folder1.ABLOB"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 17 : # Query data
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "ATABLE"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.folder1.TABCOUNTRY.$query"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
  When 18 : # Query data
   ARCV.VERB         = "get"
   ARCV.PREFIX       = "http://syracuse"
   ARCV.ENTITIES(1)  = "TABCOUNTRY"
   ARCV.HEADERCOD(1) = "accept"
   ARCV.HEADERVAL(1) = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.folder1.TABCOUNTRY.$query"
   ARCV.HEADERCOD(2) = "accept-language"
   ARCV.HEADERVAL(2) = "fr"
 Endcase
Else
 SyrRecv ARCV
Endif
  Call TRACE_STR("ASYRRCV",ARCV) From ASYRCOM
End

#----------------------------------------------------------------#
# Send to syracuse
#----------------------------------------------------------------#

Subprog SYRSNDBLB(ASND)
Variable Instance  ASND Using C_ASYRSNDBLB
#Call TRACE_STR("ASYRSNDBLB",ASND) From ASYRCOM
Goto SND

Subprog SYRSND(ASND)
Variable Instance  ASND Using C_ASYRSND
#Call TRACE_STR("ASYRSND",ASND) From ASYRCOM
#Local Char DMPFILE(250)
#DMPFILE = heapdmp()

$SND
Local Integer J , K
If ASND.STAT <> 201
Raz ASND.URL
Endif

If !GTEST
 Case ASND.MODE
  When 0       :
   SyrSend ASND
   ASND.MODE = 0
   Raz ASND.DATA
  When 1       :
    SyrSend ASND First
    ASND.MODE = 2
    Raz ASND.DATA
  When 2       :
   SyrSend ASND Next
   Raz ASND.DATA
  When 3       :
    SyrSend ASND Last
    ASND.MODE = 0
    Raz ASND.DATA
 Endcase
Endif
Call TRACE("send complete"-"date$="+format$("D:YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$))
# Create file .json on my pc for tests
If GTEST & GUSER="MB"
 K = instr(1,ASND.CONTTYPE,".")
 While K
  J = K
  K = instr(K+1,ASND.CONTTYPE,".")
 Wend
 Openo "#@c:¥temp¥script_"+tolower(ctrans(right$(ASND.CONTTYPE,J+1),"¥/$",""))+".JSON",0 Using [JSON]
 Iomode adxirs "" Using [JSON]
 Iomode adxifs "" Using [JSON]
 Iomode adxium GASCII Using [JSON]
 If type(ASND.DATA)=523
  Wrseq ASND.DATA Using [JSON]
 Endif
 Openo Using [JSON]
Endif
End

#----------------------------------------------------------------#
# Trace
#----------------------------------------------------------------#

Subprog TRACE(MESSAGE)
Value Char MESSAGE

# AKA X3-103331.sn Check condition, open the trace file in append mode, write the message and close the file
If dim(GTRACEASYR)>0 and GTRACEASYR<>""
 Openo GTRACEASYR,-1
 Wrseq MESSAGE
 Openo
Endif
#AKA X3-103331.en

End

#----------------------------------------------------------------#
# Open log
#----------------------------------------------------------------#

Subprog TRACE_OPEN(MODE)
Value Char MODE
Case MODE
 When "F"
  Call OUVRE_TRACE("Syracuse("+adxusr+")") From LECFIC
 When "D"
  If find(adxusr,"erbou")
   End
  Elsif find(adxusr,"ccl","eboyard","dom","DOM","dadim","rbu","mbeinat","mb","jpga")
   GTRACEASYR = filpath("TRA","SYRA_" + toupper(adxusr), "tra", 0) : # AKA X3-103331.n Change GTRACE to GTRACEASYR
#  Elsif GADONIX=2
#   GTRACE = "/tmp/syracuse_"+tolower(adxusr)+".tra"
  Else
   GTRACEASYR = filpath("TRA","syracuse_"+adxusr,"tra")            : # AKA X3-103331.n Change GTRACE to GTRACEASYR
  Endif
  Openo GTRACEASYR,0                                               : # AKA X3-103331.n Change GTRACE to GTRACEASYR
  Wrseq "date$="+format$("D:YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$)
  Openo
Endcase
End

#----------------------------------------------------------------#
# Close log
#----------------------------------------------------------------#

Subprog TRACE_END
If left$(GTRACE,1)="F"
 #109897
 #GSERVEUR = 0
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

#----------------------------------------------------------------#
# Dump Instance
#----------------------------------------------------------------#

Subprog TRACE_STR(CODCLA,STRCOM)
Value Char CODCLA
Variable Instance STRCOM Using ="C_"+CODCLA
Local Clbfile CLBJSON
Local Integer I , COUNT
Local Char    NAM(10)
If GTRACEASYR = "" : End: Endif :#X3-103331
If filinfo(filpath("FIL","ACLASSE","fde"),0)<=0
 End
Endif
Local File ACLAFLD [ACLAF] , ACLASSE [ACLAS]
Read [ACLAS]ACLA0=CODCLA
Call TRACE("*** "+func ASYRFNC.TEXTE([F:ACLAS]INTCLA))
#DBG Call TRACE("DBG classe:"+"C_"+CODCLA)
For [ACLAF]ACLAF0 Where CODCLA=[L]CODCLA
 #DBG Call TRACE("DBG field:"+[F:ACLAF]FLDCLA)
 #DBG Call TRACE("DBG type:"+num$(evalue("type(STRCOM."+[F:ACLAF]FLDCLA+")")))
 If evalue("type(STRCOM."+[F:ACLAF]FLDCLA+")")=522 : # Blob
  Gosub TRACE_CLB
 Else
  If [F:ACLAF]FLDGRP=""
   If len(num$(evalue("STRCOM."+[F:ACLAF]FLDCLA)))>255
    Gosub TRACE_CLB
   Else
    Call TRACE("   "+[F:ACLAF]FLDCLA+"="+num$(evalue("STRCOM."+[F:ACLAF]FLDCLA)))
   Endif
  Else
   For I=1 To evalue("maxtab(STRCOM."+[F:ACLAF]FLDCLA+")")
    Call TRACE("   "+[F:ACLAF]FLDCLA+"("+num$(I)+")="+num$(evalue("STRCOM."+[F:ACLAF]FLDCLA+"("+num$(I)+")")))
   Next I
  Endif
 Endif
Next ACLAF
Call TRACE("*** End Instance"-CODCLA)
Close Local File
End

#-------------------------------------#
$TRACE_CLB
If left$(GTRACEASYR,1)="F" :#X3-103331: Don't use GTRACE
 Openo filpath("TRA",GTRACEASYR,"tra"), -1 Using [JSON]
Else
 Openo GTRACEASYR,-1 Using [JSON]
Endif
If evalue("type(STRCOM."+[F:ACLAF]FLDCLA+")")=522 : # Blob
 NAM = "blob"
 Onerrgo TRACE_CNV
 COUNT = strDecode(evalue("STRCOM."+[F:ACLAF]FLDCLA),CLBJSON,GUTF8)
 Onerrgo
Else
 NAM = "clob"
 CLBJSON = evalue("STRCOM."+[F:ACLAF]FLDCLA)
Endif
Wrseq chr$(10)+"*** Dﾃｩtails"-NAM-[F:ACLAF]FLDCLA-'('+num$(len(evalue("STRCOM."+[F:ACLAF]FLDCLA)))+')' Using [JSON]
Wrseq CLBJSON Using [JSON]
Wrseq "*** End"-NAM Using [JSON]
Openo Using [JSON]
Return

#-----------------#
$TRACE_CNV
CLBJSON = "Converting clob not possible"
Resume

#**
#* PARSE_TRACE_LINE
#*
#* @param LINE
#* @param TRACE
#*!
Funprog PARSE_TRACE_LINE(LINE,TRACE)
Variable Char LINE
Variable Clbfile TRACE

Local Char    CHR(1)
Local Integer I
Local Integer STOP_TRACE

_G_TRACE_NBLINES += 1

Local Char TYPTEX(5)
If left$(LINE,15)="#<AdxVL>@(#)%I%"
 LINE = right$(LINE,16)
 Append TRACE, '<p>'
Elsif left$(LINE,1)=">"
 Append TRACE, '<p class="t-p-G' + seg$(LINE,2,5) + '">'
 LINE = right$(LINE,6)
Elsif left$(LINE,1)="<"
 Append TRACE, '<p class="t-p-L' + seg$(LINE,2,5) + '">'
 LINE = right$(LINE,6)
Else
 Append TRACE, '<p>'
Endif

For I=1 To len(LINE)
 CHR = xgetchar( LINE, I )
 Case CHR
  When '<': Append TRACE,"&lt;"
  When '>': Append TRACE,"&gt;"
  When '"': Append TRACE,"&quot;"
  When '&': Append TRACE,"&amp;"
  When Default:Append TRACE,CHR
 Endcase
Next I

Append TRACE, '</p>' + chr$(10)
If _G_TRACE_NBLINES=1000: STOP_TRACE=1 : Endif
End STOP_TRACE

#**
#* READ_TRACE
#*
#* @param TRACE
#* @param CLOB
#*!
Funprog READ_TRACE(TRACE,FSEEK)
Value Char       TRACE
Value Integer    FSEEK

Local Clbfile CLOB

Global Integer  _G_TRACE_NBLINES
Local  Integer  ASTATUS: ASTATUS=0
Local  Char     FILENAM(50)
FILENAM = TRACE + ".tra"

Append CLOB,'<!DOCTYPE HTML>' + chr$(10)
Append CLOB,'<HTML>'+ chr$(10)
Append CLOB,'      <META HTTP-EQUIV="X-UA-Compatible" CONTENT="IE=9">'+ chr$(10)
Append CLOB,'    <HEAD>'+ chr$(10)
Append CLOB,'        <TITLE>' + TRACE + '</TITLE>'+ chr$(10)
Append CLOB,'            <META CHARSET="utf-8" />'+ chr$(10)
Append CLOB,'            <META HTTP-EQUIV="X-UA-Compatible" CONTENT="IE=9">'+ chr$(10)
Append CLOB,'            <Link REL="icon" HREF="/syracuse-ui/themes/desktop/sage/images/site/favicon.ico" />'+ chr$(10)
Append CLOB,'            <Link HREF="/syracuse-ui/themes/desktop/sage/trace.css" REL="stylesheet"/>'+ chr$(10)
Append CLOB,'      </HEAD>'+ chr$(10)
Append CLOB,'    <BODY>'+ chr$(10)
ASTATUS = func ASYRSTO.READCLOB_("TRA",FILENAM,"",chr$(10),GUTF8,FSEEK,"ASYRCOM.PARSE_TRACE_LINE",CLOB)
Append CLOB,'   </BODY>'+ chr$(10)
Append CLOB,'</HTML>'+ chr$(10)

Kill _G_TRACE_NBLINES
End CLOB




