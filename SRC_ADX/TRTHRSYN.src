## Initialisations
If dim(GTPSNBCOD) < 0
  For [TIM]TIM0
   NBCOD += 1
   TBCOD(NBCOD) = [F:TIM]COD
   TRAV(NBCOD)  = [F:TIM]WRKTIM
   If dim([F:TIM]REPFLG)>0
    REPOS(NBCOD) = [F:TIM]REPFLG
   Endif
   If dim([F:TIM]PRNCAL)>0
    TBPRNCAL(NBCOD) = [F:TIM]PRNCAL
   Endif
   TIMCAT(NBCOD) = [F:TIM]CATTIM
  Next
Else
  NBCOD = 0
  For I=1 To [V]GTPSNBCOD
   NBCOD +=1
   TBCOD(NBCOD)=[V]GTPSTBCOD(I)
   TRAV(NBCOD) = [V]GTPSTRAV(I)
   If dim([V]GTPSREPOS)>0
    REPOS(NBCOD) = [V]GTPSREPOS(I)
   Endif
   If dim([V]GTPSTBPRNCAL)>0
    TBPRNCAL(NBCOD) = [V]GTPSTBPRNCAL(I)
   Endif
   TIMCAT(NBCOD) =  [V]GTPSTIMCAT(I)
  Next
Endif
If dim(GTPSNBNAT) < 0
  For [F:NAT]NAT0
   NBNAT += 1
   TBNAT(NBNAT) = [F:NAT]COD
  Next
Else
  NBNAT = 0
  For I=1 To [V]GTPSNBNAT
   NBNAT +=1
   TBNAT(NBNAT)=[V]GTPSTBNAT(I)
  Next
Endif

#MIPEA - 2017-02-01- X3-12122- START
DATDEB = [F:HRPEOD]PERSTR(0)
DATFIN = [F:HRPEOD]PEREND(0)
DMOIS  = [F:HRPEOD]PERSTR(1)
FMOIS  = [F:HRPEOD]PEREND(1)
REGDEB = [F:HRPEOD]PERSTR(2)
REGFIN = [F:HRPEOD]PEREND(2)
DATDEBCAL= [F:HRPEOD]PERSTR(3)
If DATDEBCAL=[0/0/0] : DATDEBCAL= [F:HRPEOD]PERSTR(0) : Endif
DATFINCAL= [F:HRPEOD]PEREND(3)
If DATFINCAL=[0/0/0] : DATFINCAL= [F:HRPEOD]PEREND(0) : Endif
