# Calcul de période du mois courant, précédent & suivant
Gosub  CAL_PERIO From TRTFORVAR

Call MODULATION(DATPAY,DATDEB,DATFIN,MATRI,CTR) From TPSSTD

GPOINT = "DATPERSYN" : Gosub ENTREE From EXEFNC

Local Char FCYD(GLONFCY)
#MIPEA - 2017-02-01- X3-12122- START
Filter [F:HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & (CTRDAT<DATPAY | (FLGRET=2 & RETDATEFF<=DATPAY)) Order By CTRDAT Desc
Read [F:HRCTR] First
Filter [F:HRCTR]
#MIPEA - 2017-02-01- X3-12122- END
FCYD=""
#MIPEA - 2017-02-01- X3-12122- START
If !fstat Then FCYD=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATPAY,"ETRFCY","HRCTR") : Endif
DATFIN_P=DATFIN
# Ajout nouveaux paramètres dans CALC_DATEND
Call CALC_DATEND(FCYD, DATPAY, [F:HRCTR]XITDAT, [F:HRCTR]XITFNL, [F:HRCTR]CLEEVETIM, DATDEB, DATFIN, FMOIS, EXITSAL, [F:HRCTR]PERCOD) From TRTTPS
#If !fstat Then FCYD=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,DATPAY,"ETRFCY","CTR") : Endif
#DATFIN_P=DATFIN
## Ajout nouveaux paramètres dans CALC_DATEND
#Call CALC_DATEND(FCYD, DATPAY, [F:CTR]XITDAT, [F:CTR]XITFNL, [F:CTR]CLEEVETIM, DATDEB, DATFIN, FMOIS, EXITSAL) From TRTTPS
#MIPEA - 2017-02-01- X3-12122- END
If DATFIN_P<DATFIN Then DATFIN_P=DATFIN : Endif
Raz PRE

#MIPEA - 2017-02-01- X3-12122- START
For [HRCTR]CTR1 Where REFNUM=MATRI & CTRNUM=CTR
 If (CTRD<>[0/0/0] & [F:HRCTR]CTRDAT=CTRD) | ([L]TCTRD(0) <> [0/0/0] & find([F:HRCTR]CTRDAT,[L]TCTRD(0..8))>0) Then
   DATDEBCTR=[F:HRCTR]CTRDAT
   If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then
    DATDEBCTR=[F:HRCTR]RETDATEFF
   Endif
   If PASSE=1
    # On cherche si on a une fiche de rétroactivité relative au champ CTRGRD
    Read [ADI]CODE=10386;func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATPAY,"CTRGRD","HRCTR")
    # Gestion des champs spécifiques FRA
    If !fstat & (GDOSLEG<>"FRA" | [F:ADI]A1<>"") : Raz PRE : Endif
   Endif
   # Il faut faire le max avec DATEXTTPS+1, sinon on risque d'englober des temps qui ont été déjà comptabilisées sur une autre paie
   If [F:HRCTR]XITDAT=[0/0/0] & DATDEBCTR<=DATFIN
    For I=max(DATDEB,DATDEBCTR,DATEXTTPS+1)-DATDEB+1 To DATFIN-DATDEB+1
     PRE(I) = 1
    Next I
   Elsif [F:HRCTR]XITDAT>=DATDEB & DATDEBCTR<=DATFIN
    For I=max(DATDEB,DATDEBCTR,DATEXTTPS+1)-DATDEB+1 To min(DATFIN,[F:HRCTR]XITDAT)-DATDEB+1
     PRE(I) = 1
    Next I
   Endif
   PASSE = 1
 Endif
Next
#For [CTR]CTR1 Where REFNUM=MATRI & CTRNUM=CTR
# If (CTRD<>[0/0/0] & [F:CTR]CTRDAT=CTRD) | ([L]TCTRD(0) <> [0/0/0] & find([F:CTR]CTRDAT,[L]TCTRD(0..8))>0) Then
#   DATDEBCTR=[F:CTR]CTRDAT
#   If [F:CTR]FLGRET=2 & [F:CTR]RETDATEFF<>[0/0/0] Then
#    DATDEBCTR=[F:CTR]RETDATEFF
#   Endif
#   If PASSE=1
#    # On cherche si on a une fiche de rétroactivité relative au champ CTRGRD
#    Read [ADI]CODE=386;func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,DATPAY,"CTRGRD","CTR")
#    # Gestion des champs spécifiques FRA
#    If !fstat & (GDOSLEG<>"FRA" | [F:ADI]A1<>"") : Raz PRE : Endif
#   Endif
#   # Il faut faire le max avec DATEXTTPS+1, sinon on risque d'englober des temps qui ont été déjà comptabilisées sur une autre paie
#   If [F:CTR]XITDAT=[0/0/0] & DATDEBCTR<=DATFIN
#    For I=max(DATDEB,DATDEBCTR,DATEXTTPS+1)-DATDEB+1 To DATFIN-DATDEB+1
#     PRE(I) = 1
#    Next I
#   Elsif [F:CTR]XITDAT>=DATDEB & DATDEBCTR<=DATFIN
#    For I=max(DATDEB,DATDEBCTR,DATEXTTPS+1)-DATDEB+1 To min(DATFIN,[F:CTR]XITDAT)-DATDEB+1
#     PRE(I) = 1
#    Next I
#   Endif
#   PASSE = 1
# Endif
#Next
#MIPEA - 2017-02-01- X3-12122- END

Call PARAM("","REFPANIER",VRAPANIER) From ADOVAL
Call PARAM("","CUMSUP",CUMHRESUP) From ADOVAL
Call PARAM("","CPE",CPE) From ADOVAL
Call PARAM("","CPA",CPA) From ADOVAL

## Vérifs de routine

## Paramètres divers

Read [ID]ID0=MATRI

#MIPEA - 2017-02-01- X3-12122- START
Call LECTURE("FCY",func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATPAY,"ETRFCY","HRCTR"),"") From CONTOBJ
#Call LECTURE("FCY",func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,DATPAY,"ETRFCY","CTR"),"") From CONTOBJ
#MIPEA - 2017-02-01- X3-12122- END

LIMITE_HEBDO      = val(func AFNC.PARAM("HOUMAXLEG",[F:FCY]FCY))
LIMITE_BONIF      = val(func AFNC.PARAM("HOUBON",[F:FCY]FCY))
TAUX_BONIF        = val(func AFNC.PARAM("RATBON",[F:FCY]FCY))

#il faut utiliser ici l'horaire hebdo légale pas horaire hebdo société !!!
HRE_SEM_LEG       = val(func AFNC.PARAM("HOULEGWEK",[F:FCY]FCY))
HRE_SEM_MIN       = val(func AFNC.PARAM("HOUWEKMIN",[F:FCY]FCY))
HRE_SEM_MAX       = val(func AFNC.PARAM("HOUWEKMAX",[F:FCY]FCY))
LIMITE_HRESUP     = val(func AFNC.PARAM("HOUSUP",[F:FCY]FCY))
LIMITE_REPOS      = val(func AFNC.PARAM("HOUREP",[F:FCY]FCY))
LIMITE_CONTINGENT = val(func AFNC.PARAM("HOUCON",[F:FCY]FCY))
HRE_SUP_ANN       = val(func AFNC.PARAM("HOUSUPYEA",[F:FCY]FCY))
LIMITE_JOUR       = val(func AFNC.PARAM("HOUDAYLEG",[F:FCY]FCY))
TXHRE_COM         = val(func AFNC.PARAM("HOUCOM",[F:FCY]FCY))
TXHRE_COMSUP      = val(func AFNC.PARAM("HOUCOMSUP",[F:FCY]FCY))

# Neutralisation heures sup du dimanche
NEU_OVE_SUN       = val(func AFNC.PARAM("NEUOVESUN",[F:FCY]FCY))
# Neutralisation heures récup du dimanche
NEU_COM_SUN       = val(func AFNC.PARAM("NEUCOMSUN",[F:FCY]FCY))

EVTPGN(0) = func AFNC.PARAM("AT","")
EVTPGN(1) = func AFNC.PARAM("MALADIE","")
EVTPGN(2) = func AFNC.PARAM("MATERNITE","")
EVTPGN(3) = func AFNC.PARAM("ATTRAJET","")
EVTPGN(4) = func AFNC.PARAM("PATERNITE","")
EVTPGN(5) = func AFNC.PARAM("MALPROF","")
EVTPGN(6) = func AFNC.PARAM("PATHPREN","")
EVTPGN(7) = func AFNC.PARAM("PATHPOST","")

SITE              = [F:FCY]FCY
SOCIETE           = [F:FCY]LEGCPY

#MIPEA - 2017-02-01- X3-12122- START
MODULATION        = (val(func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATPAY,"MODTPS","HRCTR"))=2)
#MODULATION        = (val(func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,DATPAY,"MODTPS","CTR"))=2)
#MIPEA - 2017-02-01- X3-12122- END

If VRAPANIER<>""
 VARIA = VRAPANIER
 Gosub SET_VAR
 LIMITE_PANIER  = VALEUR
Endif

## Le planning

Call VALORDET(DATDEB,DATFIN_P,MATRI,"",PJOUR,PHEURE,SITE,CTR) From SUBPLN : # GTPSW ??
#Infbox "1 "-num$(DATDEB)-" "-num$(DATFIN_P)-" "-num$(PJOUR)
## Parcours des temps
#NBSEM = (DATFIN-DATDEB+1)/7
# Si le salarié est sorti, la date de fin est postérieure à la date de fin de mois
NBSEM = arr((DATFIN-DATDEB+1)/7,1)

If (MODULATION | EXITSAL) & NBSEM<(DATFIN-DATDEB+1)/7
 NBSEM += 1
Endif

# Déplacé avant le calcul de CRITERED, pour s'en servir dans le calcul
# On regarde si le salarié est sorti sur le mois en cours
XITMON=1
If clalev([F:CTRC])=0 : Local File EMPLOCTR [CTRC] : Endif
If CTRD<>[0/0/0] Then
  Filter [F:CTRC] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<>CTRD Order By CTRDAT
  Read [F:CTRC] Last
  If [F:CTRC]XITFNL<>2 & [F:CTRC]XITDAT<>[0/0/0] & [F:CTRC]XITDAT>=DATDEB & [F:CTRC]XITDAT<=FMOIS Then
    XITMON=2
  Endif
  Filter [F:CTRC]
Endif

DATFIRSTCTR=CTRD

If CTRD=[0/0/0] Then
  CRITERED="1=1"
Else
  # Attention, on peut être sur un bulletin mono-contrats, et avoir des sorties non définitives
  # Dans ce cas, il ne faut pas se limiter sur les dates de contrat
  # Doit-être aussi fait pour multi-contrat car on peut avoir
  # des contrats successifs dans une société ET avoir un contrat sur la même période dans une autre société
  # Donc suppression du test sur FLGMULCTR
  Local Integer RETCTR : RETCTR=1
  Read [F:CTRC]CTR0=MATRI;CTR;CTRD
  If !fstat & [F:CTRC]FLGRET=2 Then RETCTR=2 : Endif
  # Test remplacé par celui sur XITMON
  If CRITERED="" Then
    # Le critère n'est plus sur la date exacte, mais sur une fourchette de dates pour gérer
    # la consolidation des bulletins
    # Si le contrat est sans rupture de bulletin, il faut récupérer les temps pour tous les contrats consécutifs sans rupture
    Call CTRDAT_STR_END(MATRI,CTR,CTRD,STRCTR,ENDCTR) From DIVPAYE
    CRITERED=[L]CRIT_RUP_CTR
    DATFIRSTCTR=STRCTR

    CTRC=CTRD
    # Si CTRD n’est pas un lundi, et que la période précédente est travaillée (sans rupture définitive), alors le calcul doit
    # être identique à celui effectuée directement dans la fonction GESTIR
    # Le cumul des heures semaine pour le calcul des HS n’est pas possible si on travaille pour 2 sociétés différentes mais si on
    # travaille pour la même et qu’il n’y a pas de rupture de travail de contrat de travail on doit alors calculer les HS sur la semaine entière
    # Ajout test sur XITMON, pour prendre les temps sur le contrat précédent qui n'auraient pas  été pris dans le
    # bulletin précédent
    If dayn(CTRC)<>GFIRDAY | XITMON=2 Then
      If clalev([F:CTRT])=0 : Local File EMPLOCTR [CTRT] : Endif
      If clalev([F:CTRC])=0 : Local File EMPLOCTR [CTRC] : Endif
      Local Char CPYT(10),CPYC(10)
      # Dans le cas d'une mutation, il faut que les contrats soient consécutifs sans rupture, donc puisque
      # le 1er jour du contrat suivant n'est pas un lundi, le contrat précédent doit commencer à (Date début contrat en cours-1),
      # soit CTRC-1
      # Si sortie dans le même mois, il faut que la date du précédent contrat soit simplement inférieure à la date contrat en cours
      If dayn(CTRC)<>GFIRDAY Then
        Filter [F:CTRT] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<CTRC & XITDAT=CTRC-1 & XITFNL<>2
      Elsif XITMON=2 Then
        Filter [F:CTRT] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<CTRC & XITDAT<>[0/0/0] & XITFNL<>2 & [F:CTRC]XITDAT>=DATDEB & [F:CTRC]XITDAT<=FMOIS
      Endif
      Read [F:CTRT] Last
      Filter [F:CTRT]
      If !fstat Then
        Call LECTURE("FCY", func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTRT]CTRDAT,DATPAY,"ETRFCY","CTRT"), "") From CONTOBJ
        CPYT=[F:FCY]LEGCPY
        Read [F:CTRC]CTR0=MATRI;CTR;CTRC
        If !fstat Then
          Call LECTURE("FCY", func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTRC]CTRDAT,DATPAY,"ETRFCY","CTRC"), "") From CONTOBJ
          CPYC=[F:FCY]LEGCPY
          If CPYT=CPYC Then
            While dayn(CTRC)<>GFIRDAY
              CTRC=CTRC-1
            Wend
            CTRT=[F:CTRT]CTRDAT
            If [F:CTRT]CTRDAT<=CTRC Then
              # Si on récupère les temps non récupérés de la période d'activité précédente, il faut les récupérer à partir
              # du dernier temps comptabilisé pour cette période, et non pas à partir de la date de début de la période d'activité suivante
              If DATEXTTPS=[0/0/0] Then
                If clalev([F:VEP2])=0 : Local File VALEMP [VEP2] : Endif
                Filter [VEP2] Where EMP=MATRI & PYRDAT<=DATPAY & CTRNUM=CTR & CTRDAT=CTRT & RVS<>2 & RVSDAT=[0/0/0]
                Read [VEP2]VEP0 Last
                Filter [VEP2]
                If !fstat Then DATEXTTPS=[F:VEP2]DATTPS : Endif
                CRITERED-="| (CTRDAT=CTRT & STRDAT>=DATEXTTPS)"
              Else
                CRITERED-="| (CTRDAT=CTRT & STRDAT>=CTRC)"
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
    CRITERED+=")"
  Endif
Endif

[L]CRITERED_VEP=[L]CRITERED
If [L]STRCTR<>[0/0/0] & [L]STRCTR=[L]ENDCTR
  If instr(1,[L]CRITERED,[L]CRIT_RUP_CTR) > 0
     [L]CRITERED_VEP=[L]CRIT_RUP_VEP
     [L]CRITERED_VEP+=right$([L]CRITERED,[L]L_RUP_CTR+1)
  Endif
Endif
# Déplacé avant le calcul de CRITERED, pour s'en servir dans le calcul
## On regarde si le salarié est sorti sur le mois en cours
Filter [F:CTRC]
If GPAYE & clalev([F:VEP2])=0 : Local File VALEMP [VEP2] : Endif
# Si sortie du salarié, la date de fin de saisie des temps peut être sa date de sortie. Il faut donc comptabiliser les temps
# jusqu'à cette date, et non plus jusqu'à la fin du mois
# On teste sur STRDAT<=DATFIN au lieu de FMOIS uniquement si le salarié est sorti. Sinon, on continue sur FMOIS


#Infbox num$(MATRI) #MEL4
#Infbox num$(EXITSAL)  #0
#Infbox num$(DATFIN) #03/10/2017
#Infbox num$(FMOIS)  #05/10/2017
#Infbox num$(DATDEB) #06/09/2017
#Infbox num$(CTR)
#Infbox num$(evalue(CRITERED))
#Infbox num$(DATEXTTPS) #04/09/2017

#Filter [TIP] Where REFNUM=MATRI & ((EXITSAL=2 & STRDAT<=DATFIN) | (EXITSAL<>2 & STRDAT<=FMOIS))  & CTRNUM=CTR & evalue(CRITERED) & (DATEXTTPS=[0/0/0] | STRDAT>=DATEXTTPS)
#Infbox 'rowcount'-num$(rowcount([TIP]))
#Filter [TIP]

#JOJAC - 2017-09-19 - START
#For [TIP]TIP1 Where REFNUM=MATRI & ((EXITSAL=2 & STRDAT<=DATFIN) | (EXITSAL<>2 & STRDAT<=FMOIS)) & ENDDAT>=DATDEB & CTRNUM=CTR & evalue(CRITERED) & (DATEXTTPS=[0/0/0] | STRDAT>=DATEXTTPS)
For [TIP]TIP1 Where REFNUM=MATRI & ((EXITSAL=2 & STRDAT<=DATFIN) | (EXITSAL<>2 & STRDAT<=FMOIS))  & CTRNUM=CTR & evalue(CRITERED) & (DATEXTTPS=[0/0/0] | STRDAT>=DATEXTTPS)
#JOJAC - 2017-09-19 - END
DAT = max(DATDEB,[F:TIP]STRDAT)
#MIPEA - 2017-09-11- US X3-54558- START
COUNTTIP1=0
COUNTTIP2=0
#MIPEA - 2017-09-11- US X3-54558- END

 # Date du 1er temps pour ce matricule/contrat/date contrat/date paie
 If FIRSTENR Then
  DATFIRST=DAT
  FIRSTENR=0
 Endif
 T = find([F:TIP]TIM,TBCOD(1..NBCOD))
 OKENR=1
 # Si on ne se limite pas sur la date du contrat, il ne faut pas faire cette vérif, d'où l'ajout du test sur CRITERED
 # Ok pour le test sur CRITERED, mais à l'intérieur du 1er If
 # Test DATFIRSTCTR = soit à CTRD ou STRCTR(Date du 1er contrat du bulletin consolidé)
 If DATFIRSTCTR<>[0/0/0] & DAT<DATFIRSTCTR Then
  # Si le salarié est sorti dans le mois, et qu'on a des temps qui n'ont pas été comptabilisés sur le bulletin
  # précédent, il faut comptabiliser ses temps, d'où l'ajout du test sur XITMON
  If TRAV(T)<>2 & TIMCAT(T)<>2 & CRITERED<>"1=1" & XITMON=1 Then OKENR=0 : Endif
  # Dans le cas d'un dossier de rétro, on ne fait pas ce contrôle sur le mois de la rétro, sinon on écarte
  # à tort des temps qui sont à cheval. D'où l'ajout du test sur RETCTR
  If GPAYE & OKENR & RETCTR<>2 Then
    Filter [VEP2] Where EMP=MATRI & CTRNUM=CTR & CTRDAT<DATFIRSTCTR & RVS<>2 & RVSDAT=[0/0/0]
    Read [VEP2]VEP0 Last
    If !fstat Then
      If [F:VEP2]DATTPS>=DAT Then
        OKENR=0
      Endif
    Endif
    Filter [VEP2]
  Endif
 Endif
 # flag si sortie définitive et Temps sur paye précédente
 EXITSAL_VEP=0
#MIPEA - 2017-09-05- US X3-54558- START
 If OKENR & EXITSAL=2 & [F:TIP]DATPYR<[F:HRPEOD]PYRDAT
# If OKENR & EXITSAL=2 & [F:TIP]DATPYR<[F:PEO]PYRDAT
#MIPEA - 2017-09-05- US X3-54558- END
    Filter [VEP2] Where PYRDAT=[F:TIP]DATPYR & EMP=MATRI & CTRNUM=CTR & CTRDAT=CTRD & RVS<>2 & RVSDAT=[0/0/0]
    Read [VEP2]VEP0 Last
    If !fstat Then
      If [F:VEP2]DATTPS>=DAT Then
        EXITSAL_VEP=1
      Endif
    Endif
    Filter [VEP2]
 Endif
 If OKENR Then
   T2=0
   If [F:TIP]NATCOD<>"" :  T2= find([F:TIP]NATCOD,TBNAT(1..NBNAT)) : Endif
   FLVAR = 0
   FLAG_TRAITE = 1

   # Remonter le calcul de TOTNBRDAY ici car on le faisait X fois pour rien
   If [F:TIP]STRDAT <> [F:TIP]ENDDAT
     TOTC=([F:TIP]ENDDAT-[F:TIP]STRDAT+1)
     For ITYP=1 To 3
       TOTNBRDAY(ITYP)=0
       For IC=1 To TOTC
         DATC=[F:TIP]STRDAT+IC-1
         Call VALORTYP(DATC,DATC,MATRI,[F:TIP]TIM,JOURC,HEUREC,SITE,CTR,ITYP) From SUBPLN
         # TOTNBRDAY sert à proratiser les heures et jours quand on a un temps saisi sur plusieurs jours.
         # Donc on veut obtenir le nombre de jours où le salarié est présent, pas le décompte précis des jours de
         # travail (par exemple si temps partiel, on obtenait 4.5j au lieu de 5)
         If JOURC>0 Then JOURC=1 : Endif
         TOTNBRDAY(ITYP) += JOURC
       Next
     Next
   Endif

   # On a une 2nde boucle For K qui démarre à max(DATFIN+1,[F:TIP]STRDAT)-DATDEB+1 pour lire les temps si
   # même date de paie et temps au-delà de DATFIN. Du coup, on se retrouvait avec des temps comptés deux fois
   # Si sortie du salarié, la date de fin de saisie des temps peut être sa date de sortie. Il faut donc comptabiliser les
   # temps jusqu'à cette date, et non plus jusqu'à la fin du mois
   MAXD=min(DATFIN,[F:TIP]ENDDAT)-DATDEB+1
#MIPEA - 2017-02-09- X3-11284- START
   If [F:TIP]DATPYR=[F:HRPEOD]PYRDAT & [F:TIP]ENDDAT>DATFIN
#   If [F:TIP]DATPYR=[F:PEO]PYRDAT & [F:TIP]ENDDAT>DATFIN
#MIPEA - 2017-02-09- X3-11284- END
    MAXD=max(DATFIN+1,[F:TIP]STRDAT)-DATDEB
   Endif
   For K=max(DATDEB,[F:TIP]STRDAT)-DATDEB+1 To MAXD
    If [F:TIP]STRDAT=[F:TIP]ENDDAT
     # Avant de récupérer les heures/jours du temps, on vérifie que c'est cohérent avec le planning
     Raz [F:TIM]
#MIPEA - 2017-02-01- X3-12122- START
     Read [TIM]TIM0 = GCURLEG;[F:TIP]TIM
#     Read [TIM]TIM0 = [F:TIP]TIM
#MIPEA - 2017-02-01- X3-12122- END
     If !func SUBPLN.ISPLANNING(DAT,DAT,MATRI,[F:TIP]TIM,SITE,CTR)
        HEURES = [F:TIP]NBRHOU
        JOURS  = [F:TIP]NBRDAY
     Else
        # compter les jours fériés travaillés
        If dim(GFERIE)<1 : Global Integer GFERIE : VKILL=1 : Endif   :#0=non compté 1= compté
        SAV_GFERIE=GFERIE
        GFERIE=1
        Call VALORIS(DAT,DAT,MATRI,[F:TIP]TIM,JOUR,HEURE,SITE,CTR) From SUBPLN
#        Infbox "3 "-num$(DAT)-" "-num$(JOUR)
        GFERIE=SAV_GFERIE
        If dim(GFERIE)>=0 & VKILL : Kill GFERIE : Endif
        HEURES = 0 : JOURS  = 0
        If HEURE>0 Then HEURES = [F:TIP]NBRHOU : Endif
        If JOUR>0  Then JOURS  = [F:TIP]NBRDAY : Endif
     Endif
     # Tps importé ->[F:TIP]STRDAT=[F:TIP]ENDDAT donc verif type de jours sinon jouvré=jouvrable=jcalend !!!
     For ITYP=1 To 3
      # Si type événement temps = type demandé on prend le temps de TIMEMP
      # Si type événement temps "Ouvrés" et le type demandé = "Calendaire" on prend le temps de TIMEMP
      # Dans les autres cas on prend le temps valorisé du Planning
#MIPEA - 2017-02-01- X3-12122- START
      Read [TIM]TIM0 = GCURLEG;[F:TIP]TIM
#      Read [TIM]TIM0 = [F:TIP]TIM
#MIPEA - 2017-02-01- X3-12122- END
      If !fstat & (ITYP=[F:TIM]DAYTYP | ([F:TIM]DAYTYP=2 & ITYP=3))
        Case ITYP
         When 1 :
            JOUVRAS=JOURS : HOUVRAS=HEURES
         When 2 :
            JOUVRES=JOURS : HOUVRES=HEURES
         When 3 :
            JCALENS=JOURS : HCALENS=HEURES
        Endcase
      Else
        Call VALORTYP([F:TIP]STRDAT,[F:TIP]ENDDAT,MATRI,[F:TIP]TIM,JOUR,HEURE,SITE,CTR,ITYP) From SUBPLN
#              Infbox "4 "-num$([F:TIP]STRDAT)-" "-num$([F:TIP]ENDDAT)-" "-num$(JOUR)
        # On ne prend pas le min : on prend la valeur saisie si la valorisation est non nulle, on prend 0 sinon
        Case ITYP
         When 1 :
            If JOUR<>0  Then JOUVRAS=[F:TIP]NBRDAY Else JOUVRAS=0 : Endif
            If HEURE<>0 Then HOUVRAS=[F:TIP]NBRHOU Else HOUVRAS=0 : Endif
         When 2 :
            If JOUR<>0  Then JOUVRES=[F:TIP]NBRDAY Else JOUVRES=0 : Endif
            If HEURE<>0 Then HOUVRES=[F:TIP]NBRHOU Else HOUVRES=0 : Endif
         When 3 :
            If JOUR<>0  Then JCALENS=[F:TIP]NBRDAY Else JCALENS=0 : Endif
            If HEURE<>0 Then HCALENS=[F:TIP]NBRHOU Else HCALENS=0 : Endif
        Endcase
      Endif
     Next
    Else
     Call VALORIS(DAT,DAT,MATRI,[F:TIP]TIM,JOUR,HEURE,SITE,CTR) From SUBPLN
     HEURES = HEURE
     JOURS  = JOUR
     # Remonter le calcul de TOTNBRDAY en haut car on le faisait X fois pour rien
     For ITYP=1 To 3
      Call VALORTYP(DAT,DAT,MATRI,[F:TIP]TIM,JOUR,HEURE,SITE,CTR,ITYP) From SUBPLN
      # On prend la valeur saisie si la valorisation est non nulle, on prend 0 sinon
      # Calcul du nombre de jours selon le type
      # TOTNBRDAY test / par 0
      # Si type événement temps = type demandé on prend le temps de TIMEMP
      # Si type événement temps "Ouvrés" et le type demandé = "Calendaire" on prend le temps de TIMEMP
      # Dans les autres cas on prend le temps valorisé du Planning
#MIPEA - 2017-02-01- X3-12122- START
      Read [TIM]TIM0 = GCURLEG;[F:TIP]TIM
#      Read [TIM]TIM0 = [F:TIP]TIM
#MIPEA - 2017-02-01- X3-12122- END
      # Si le nbre de jours de la saisie est <> nbre de jours calculés pour le type on ne peut pas prendre le temps de TIMEMP
      If !fstat & (ITYP=[F:TIM]DAYTYP | ([F:TIM]DAYTYP=2 & ITYP=3)) & [F:TIP]NBRDAY=TOTNBRDAY(ITYP)
        Case ITYP
         When 1 :
            If JOUR<>0 & TOTNBRDAY(ITYP) <> 0  Then JOUVRAS=[F:TIP]NBRDAY/TOTNBRDAY(ITYP) Else JOUVRAS=0 : Endif
            If HEURE<>0 & TOTNBRDAY(ITYP) <> 0 Then HOUVRAS=[F:TIP]NBRHOU/TOTNBRDAY(ITYP) Else HOUVRAS=0 : Endif
         When 2 :
            If JOUR<>0 & TOTNBRDAY(ITYP) <> 0  Then JOUVRES=[F:TIP]NBRDAY/TOTNBRDAY(ITYP) Else JOUVRES=0 : Endif
            If HEURE<>0 & TOTNBRDAY(ITYP) <> 0 Then HOUVRES=[F:TIP]NBRHOU/TOTNBRDAY(ITYP) Else HOUVRES=0 : Endif
         When 3 :
            If JOUR<>0 & TOTNBRDAY(ITYP) <> 0  Then JCALENS=[F:TIP]NBRDAY/TOTNBRDAY(ITYP) Else JCALENS=0 : Endif
            If HEURE<>0 & TOTNBRDAY(ITYP) <> 0 Then HCALENS=[F:TIP]NBRHOU/TOTNBRDAY(ITYP) Else HCALENS=0 : Endif
        Endcase
      Else
        Case ITYP
         When 1 :
            JOUVRAS=JOUR : HOUVRAS=HEURE
         When 2 :
            JOUVRES=JOUR : HOUVRES=HEURE
         When 3 :
            JCALENS=JOUR : HCALENS=HEURE
        Endcase
      Endif
     Next
    Endif
    JNUIT  = [F:TIP]DAYNGT
    QTY1   = [F:TIP]QTY1
    QTY2   = [F:TIP]QTY2

    ISTIMEMP=1
    GPOINT = "HREJOUR" : Gosub ENTREE From EXEFNC

  ## Cumul par activité

    HRE_COD(T,K) += HEURES
    JRS_COD(T,K) += JOURS
    Q1_COD(K)+=QTY1
    Q2_COD(K)+=QTY2

    If T2
     HRE_NAT(T2,K) += HEURES
     JRS_NAT(T2,K) += JOURS
     Q1_NAT(K)+=QTY1
     Q2_NAT(K)+=QTY2
    Endif

    # Quand un temps est saisi ailleurs que dans TPSSTD (dans GESDCG par exemple), la date
    # de paie du temps est positionnée en fonction de la date de l'absence.
    # Or, dans le cas où le salarié est sorti et qu'on doit faire le solde événements temps, on doit prendre ses
    # événements temps, même si leur date de paie ne correspond pas, d'où l'ajout du test sur EXITSAL
    # Flag si sortie définitive et Temps n'est pas sur paye précédente !EXITSAL_VEP
#MIPEA - 2017-02-09- X3-11284- START
    If [F:TIP]DATPYR=[F:HRPEOD]PYRDAT | (EXITSAL=2 & !EXITSAL_VEP)
#    If [F:TIP]DATPYR=[F:PEO]PYRDAT | (EXITSAL=2 & !EXITSAL_VEP)
#MIPEA - 2017-02-09- X3-11284- END

     HRE_VAR(T,K) += HEURES
     JRS_VAR(T,K) += JOURS
     J_OUVRA(T,K) += JOUVRAS : H_OUVRA(T,K) += HOUVRAS
     J_OUVRE(T,K) += JOUVRES : H_OUVRE(T,K) += HOUVRES
     J_CALEN(T,K) += JCALENS : H_CALEN(T,K) += HCALENS

  #JASMI - 2017-09-05 - START
  If func AFNC.ACTIV("GLM")
     If (JOUVRAS<>0 | JOUVRES<>0 | JCALENS<>0) & COUNTTIP1=0
      Gosub ADD_TO_SUBTYPE_ARRAY_TIP
      COUNTTIP1+=1
     Endif
  Endif
  #JASMI - 2017-09-05 - END

     # On ne comptabilise que si, selon la nature d'événement définie en Ouvrable
     # Ouvré, ou Calendaire, le nombre de jour est différent de 0
     If [F:TIM]DAYDAC=2 # A ne faire que si on est en mode jour
       Case [F:TIM]DAYTYP
         When 1 : If J_OUVRA(T,K)>0 Then Q1_VAR(T,K)+= QTY1*J_OUVRA(T,K) : Q2_VAR(T,K)+= QTY2*J_OUVRA(T,K) : Endif
         When 2 : If J_OUVRE(T,K)>0 Then Q1_VAR(T,K)+= QTY1*J_OUVRE(T,K) : Q2_VAR(T,K)+= QTY2*J_OUVRE(T,K) : Endif
         When 3 : If J_CALEN(T,K)>0 Then Q1_VAR(T,K)+= QTY1*J_CALEN(T,K) : Q2_VAR(T,K)+= QTY2*J_CALEN(T,K) : Endif
       Endcase
     Else
       Q1_VAR(T,K)+= QTY1
       Q2_VAR(T,K)+= QTY2
     Endif
     FLVAR         = 1
     If T2
      HRE_VAR_NAT(T2,K) += HEURES
      JRS_VAR_NAT(T2,K) += JOURS
      Q1_VAR_NAT(T2,K)+= QTY1
      Q2_VAR_NAT(T2,K)+= QTY2
     Endif
    Endif

  ## Activités "temps de travail"

    If TRAV(T)=2
     TTR(K)      += HEURES
     If JNUIT=2 or JNUIT=5
      TTR_NUI(K) += HEURES
     Else
      TTR_JOU(K) += HEURES
     Endif
    Endif

  ## Activités "repos compensateur"

    If REPOS(T)=2
     TRP(K)      += HEURES
    Endif

  ## "Le" travail

    If TBCOD(T)=GTPSW
     TRA(K) += HEURES
     If JNUIT=2 or JNUIT=5
      TRA_NUI(K)  += HEURES
      If JNUIT=5
       TRA_NPO(K) += HEURES
      Endif
     Else
      TRA_JOU(K)  += HEURES
      If JNUIT=4
       TRA_JPO(K) += HEURES
      Endif
     Endif
    Endif

  ## Activités autres

    If TRAV(T)<>2
     AUT(K) += HEURES
    Endif

  ## Absences
    If TIMCAT(T)=2
#MIPEA - 2017-02-01- X3-12122- START
     ABSENCE(K) += val(func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATPAY,"HRSWEK","HRCTR"))/5
#     ABSENCE(K) += val(func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,DATPAY,"HRSWEK","CTR"))/5
#MIPEA - 2017-02-01- X3-12122- END
    Endif

    DAT += 1
    FLAG_TRAITE = 2

   Next K

   #
   # Le problème est lié à la date sauvegardée dans DATTPS.
   # DAT a commencé à la date de début des temps de la période d'extraction ou à la date de
   # début de TIMEMP.
   # Quand on sort de la boucle de K, DAT vaut 1 de plus que la dernière date traitée.
   #
   # Exemple : périodes d'extraction :
   #   début temps ! fin temps ! début mois ! fin mois
   #    (DATDEB)   !  (DATFIN) !  (DMOIS)   !  (FMOIS)
   #   ------------!-----------!------------!-----------
   #    28/08/10   !  24/09/10 !  01/09/10  !  30/09/10 : paie de septembre 2010
   #    25/09/10   !  22/10/10 !  01/10/10  !  31/10/10 : paie d'octobre 2010
   # Dans la gestion des temps : pour la paie de septembre 2010 : du 22/09/10 au 23/09/10.
   # Il n'y a pas encore eu d'arrêté des temps, donc DATEXTTPS = 0.
   # Enreg. temps  : DAT commence à 22/09/10, K varie de 26 à 27, DAT finit à 24/09/10 et
   # DATTPS = min(DAT,DATFIN) = min (24/09/10, 24/09/10) = 24/09/10.
   #
   # Puis d'autres temps sont saisis sur la paie de septembre 2010 : du 24/09/10 au 24/09/10.
   # Et on refait l'arrêté des temps de septembre 2010. Comme DATTPS est renseigné, on ne prend
   # que les enreg. dont la date de début > DATTPS, donc le nouvel enreg. n'est pas pris, A TORT.
   #
   # DAT devrait plutôt être égale à la dernière date réellement traitée, donc je le décrémente.
   DAT -=1

   If FLAG_TRAITE = 2 Then # Seulement si l'enreg. a été traité
     DATTPS = min(DAT,DATFIN)
   Endif

  ## Jours réels pour la mise à jour des variables.
  ## Parcours de la fin de la période d'extraction à la fin du mois
#MIPEA - 2017-02-01- X3-12122- START
   If [F:TIP]DATPYR=[F:HRPEOD]PYRDAT & [F:TIP]ENDDAT>DATFIN
#   If [F:TIP]DATPYR=[F:PEO]PYRDAT & [F:TIP]ENDDAT>DATFIN
#MIPEA - 2017-02-01- X3-12122- END
    DAT = max(DATFIN+1,[F:TIP]STRDAT)
    FLAG_TRAITE = 1
    # Si sortie du salarié, la date de fin de saisie des temps peut être sa date de sortie. Il faut donc comptabiliser les
    # temps jusqu'à cette date, et non plus jusqu'à la fin du mois
    # Faire ce changement uniquement si sortie dans le mois
    # Ajout test sur MONDAC : si l'événement est de type calendaire, il faut le prendre en compte sur la période totale
    If XITMON=2 & [F:TIM]MONDAC<>2 Then
      MAXD=min(DATFIN,[F:TIP]ENDDAT)-DATDEB+1
    Else
      MAXD=min(FMOIS,[F:TIP]ENDDAT)-DATDEB+1
    Endif
    For K=max(DATFIN+1,[F:TIP]STRDAT)-DATDEB+1 To MAXD
     # Les variables indicées J_OUVRA,J_OUVRE,J_CALEN doivent être maj après le GPOINT="HREJOUR"
     Raz JOUVRAS,HOUVRAS
     Raz JOUVRES,HOUVRES
     Raz JCALENS,HCALENS
     If [F:TIP]STRDAT=[F:TIP]ENDDAT
      HEURE = [F:TIP]NBRHOU
      JOUR  = [F:TIP]NBRDAY
     # Les variables indicées J_OUVRA,J_OUVRE,J_CALEN doivent être maj après le GPOINT="HREJOUR"
      JOUVRAS = JOUR
      HOUVRAS = HEURE
      JOUVRES = JOUR
      HOUVRES = HEURE
      JCALENS = JOUR
      HCALENS = HEURE
     Else
      Call VALORIS(DAT,DAT,MATRI,[F:TIP]TIM,JOUR,HEURE,SITE,CTR) From SUBPLN
      For ITYP=1 To 3
       Call VALORTYP(DAT,DAT,MATRI,[F:TIP]TIM,JOUR,HEURE,SITE,CTR,ITYP) From SUBPLN
     # Les variables indicées J_OUVRA,J_OUVRE,J_CALEN doivent être maj après le GPOINT="HREJOUR"
       Case ITYP
        When 1 : JOUVRAS = JOUR : HOUVRAS = HEURE
        When 2 : JOUVRES = JOUR : HOUVRES = HEURE
        When 3 : JCALENS = JOUR : HCALENS = HEURE
       Endcase
      Next
     Endif
     QTY1   = [F:TIP]QTY1
     QTY2   = [F:TIP]QTY2

     ISTIMEMP=1
     GPOINT = "HREJOUR" : Gosub ENTREE From EXEFNC

     # Les variables indicées J_OUVRA,J_OUVRE,J_CALEN doivent être maj après le GPOINT="HREJOUR"
     J_OUVRA(T,K) += JOUVRAS : H_OUVRA(T,K) += HOUVRAS
     J_OUVRE(T,K) += JOUVRES : H_OUVRE(T,K) += HOUVRES
     J_CALEN(T,K) += JCALENS : H_CALEN(T,K) += HCALENS

  #JASMI - 2017-09-05 - START
  If func AFNC.ACTIV("GLM")
     If (JOUVRAS<>0 | JOUVRES<>0 | JCALENS<>0) & COUNTTIP1=0#COUNTTIP2=0
      Gosub ADD_TO_SUBTYPE_ARRAY_TIP
      COUNTTIP1+=1
     Endif
  Endif
  #JASMI - 2017-09-05 - END

     HRE_VAR(T,K) += HEURE
     JRS_VAR(T,K) += JOUR
     # On ne comptabilise que si, selon la nature d'événement définie en Ouvrable
     # Ouvré, ou Calendaire, le nombre de jour est différent de 0
     If [F:TIM]DAYDAC=2 # A ne faire que si on est en mode jour
       Case [F:TIM]DAYTYP
         When 1 : If J_OUVRA(T,K)>0 Then Q1_VAR(T,K)+= QTY1*J_OUVRA(T,K) : Q2_VAR(T,K)+= QTY2*J_OUVRA(T,K) : Endif
         When 2 : If J_OUVRE(T,K)>0 Then Q1_VAR(T,K)+= QTY1*J_OUVRE(T,K) : Q2_VAR(T,K)+= QTY2*J_OUVRE(T,K) : Endif
         When 3 : If J_CALEN(T,K)>0 Then Q1_VAR(T,K)+= QTY1*J_CALEN(T,K) : Q2_VAR(T,K)+= QTY2*J_CALEN(T,K) : Endif
       Endcase
     Else
       Q1_VAR(T,K)+= QTY1
       Q2_VAR(T,K)+= QTY2
     Endif
     If T2
      HRE_VAR_NAT(T2,K) += HEURE
      JRS_VAR_NAT(T2,K) += JOUR
      Q1_VAR_NAT(T2,K)  += QTY1
      Q2_VAR_NAT(T2,K)  += QTY2
     Endif

     FLVAR = 1
     DAT += 1
     FLAG_TRAITE = 2
    Next K

    # DAT devrait plutôt être égale à la dernière date réellement traitée, donc je le décrémente.
    # Cf explications plus haut.
    DAT -=1

    If FLAG_TRAITE = 2 Then # Seulement si l'enreg. a été traité
      DATTPS = min(DAT,FMOIS)
    Endif
   Endif


  # Il faut initialiser TYPPGN dès qu'on a une maladie
   If find(TBCOD(T),EVTPGN) Then
     If ( [F:TIP]STRDAT >= DMOIS & [F:TIP]STRDAT <= FMOIS )
&    | ( [F:TIP]ENDDAT >= DMOIS & [F:TIP]ENDDAT <= FMOIS )
&    | ( [F:TIP]STRDAT <  DMOIS & [F:TIP]ENDDAT >  FMOIS ) Then
  # on prend les evenements qui touchent le mois *calendaire* en cours
  # suite d'événements TYPPGN = 1 "Initial"      >> VALEUR = 1
  # suite d'événements TYPPGN = 2 "Prolongation" >> VALEUR = 2
  # suite d'événements TYPPGN = 1 puis 2         >> VALEUR = 1
  # suite d'événements TYPPGN = 2 puis 1         >> VALEUR = 3
      If    TYPPGN(T) > [F:TIP]TYPPGN
       TYPPGN(T) = 3
      Elsif TYPPGN(T) < [F:TIP]TYPPGN
       TYPPGN(T) = [F:TIP]TYPPGN - TYPPGN(T)
      Else
       TYPPGN(T) = [F:TIP]TYPPGN
      Endif
     Else
      TYPPGN(T) = [F:TIP]TYPPGN
     Endif
   Endif

  ## Commentaires pour les variables
   If FLVAR
    If DAT_COD(T)<>"" : DAT_COD(T) += " , " : Endif
    If [F:TIP]STRDAT=[F:TIP]ENDDAT
     DAT_COD(T) -= format$("D:DD[/]MM",[F:TIP]STRDAT)
     If [F:TIP]ENDDAY=2
      DAT_COD(T) -= mess(2,422,1)
     Elsif [F:TIP]STRDAY=2
      DAT_COD(T) -= mess(1,422,1)
     Endif
    Else
     DAT_COD(T) -= format$("D:DD[/]MM",[F:TIP]STRDAT)+"-"+format$("D:DD[/]MM",[F:TIP]ENDDAT)
    Endif
    If [F:TIP]CMT<>"" & NBR_CMT(T)<5
     NBR_CMT(T) += 1
     CMT_COD(T,NBR_CMT(T)) = [F:TIP]CMT
    Endif
    If T2
     If DAT_NAT(T2)<>"" : DAT_NAT(T2) += " , " : Endif
     If [F:TIP]STRDAT=[F:TIP]ENDDAT
      DAT_NAT(T2) -= format$("D:DD[/]MM",[F:TIP]STRDAT)
     Else
      DAT_NAT(T2) -= format$("D:DD[/]MM",[F:TIP]STRDAT)+"-"+format$("D:DD[/]MM",[F:TIP]ENDDAT)
     Endif
     If [F:TIP]CMT<>"" & NBR_CMT_NAT(T2)<5
      NBR_CMT_NAT(T2) += 1
      CMT_NAT(T2,NBR_CMT_NAT(T2)) = [F:TIP]CMT
     Endif
    Endif
   Endif
  Endif
Next

#JASMI - 2017-02-01 - Issue 121325 - START
Local Char CRITPEO(80)
Local Integer ADJDAYCOUNT
If PREADJ
  If clalev([F:CTRPV])=0 : Local File EMPLOCTR [CTRPV] : Endif
  Filter [F:CTRPV] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=CTRD
  Read [F:CTRPV] Last
  Filter [F:CTRPV]
  If !fstat
    [L]ADJDAYCOUNT=val(func AFNC.PARAM("DCGJOUANT",[F:CTRPV]ETRFCY))
    [L]CRITPEO="(DATPYR<=[F:HRPEOD]PYRDAT & DATPYR>=([F:HRPEOD]PYRDAT-"+num$([L]ADJDAYCOUNT)+"))"
  Else
    [L]CRITPEO = "(DATPYR=[F:HRPEOD]PYRDAT)"
  Endif
Else
  [L]CRITPEO = "(DATPYR=[F:HRPEOD]PYRDAT)"
Endif
#JASMI - 2017-02-01 - Issue 121325 - END

Raz WFLG_DATBUL :# Test si REGUL déjà passé en paye
Raz WJ_DATBUL
If VRA
 Call DEBTRANS From GLOCK
 Gosub TR5
Endif

## Parcours des réguls
# Test si REGUL déjà passé en paye
# Ajout du test sur FLGBUL<>2 car sinon toutes les réguls peuvent potentiellement être sélectionnées

# Si le salarié sort le mois précédent, et qu'on saisit une régul sur son mois de sortie, TIG.CTRDAT=date du
# contrat précédent. Il faut donc ajouter une condition sur le CRITERED, sinon on ne récupère pas la régul
If CRITERED<>"1=1" Then
#MIPEA - 2017-02-01- X3-12122- START
  Filter [F:HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<CTRD & XITFNL<>2 & [F:HRCTR]XITDAT>=DATDEB & [F:HRCTR]XITDAT<=FMOIS
  If rowcount([F:HRCTR])>0 Then
    Read [F:HRCTR] Last
    CRITERED-="| (DATBUL=[0/0/0] & CTRDAT=[F:HRCTR]CTRDAT)"
#  Filter [F:CTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<CTRD & XITFNL<>2 & [F:CTR]XITDAT>=DATDEB & [F:CTR]XITDAT<=FMOIS
#  If rowcount([F:CTR])>0 Then
#    Read [F:CTR] Last
#    CRITERED-="| (DATBUL=[0/0/0] & CTRDAT=[F:CTR]CTRDAT)"
#MIPEA - 2017-02-01- X3-12122- END
  Endif

  # FQ110269 - 25/08/15 - Dans le cas d'un contrat de rétroactivité, on doit aussi faire la recherche sur les dates de contrats précédents
  Local Date CTRR
#MIPEA - 2017-02-01- X3-12122- START
  Read [F:HRCTR]CTR0=MATRI;CTR;CTRD
  If !fstat & [F:HRCTR]FLGRET=2 Then
#  Read [F:CTR]CTR0=MATRI;CTR;CTRD
#  If !fstat & [F:CTR]FLGRET=2 Then
#MIPEA - 2017-02-01- X3-12122- END
    CTRR=CTRD  #112588
    If dayn(CTRR)<>GFIRDAY Then
      Filter [F:CTRT] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<CTRR & XITDAT<=CTRR-1 & XITFNL<>2
    Elsif XITMON=2 Then
      Filter [F:CTRT] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<CTRR & XITDAT<>[0/0/0] & XITFNL<>2 & XITDAT>=DATDEB & XITDAT<=FMOIS
    Endif
    Read [F:CTRT] Last
    Filter [F:CTRT]
    If !fstat Then CTRR=[F:CTRT]CTRDAT : Endif
#112588
    If CTRR<>[0/0/0] & CTRR<>CTRD Then
      CRITERED-="| (CTRDAT=CTRR & STRDAT>=DATEXTTPS)"
    Endif
  Endif
Endif
# modif suite à Patch 24- livré dans Maintenance en avance phase.
# TRT du patch 24 + cette modif seule dans TRT du patch 24.
# FQ105844 -  Suppression du test sur FLGBUL qui ne sert plus car plus initialisé dans GESDCG
# Par ailleurs, une parenthèse était mal placée pour le dernier | pour le test sur FLGBUL
#JASMI - 2017-02-01 - Issue 121325 - START
#MIPEA - 2017-02-01- X3-12122- START
#For [F:TIG]TIG1 Where REFNUM=MATRI & CTRNUM=CTR & evalue(CRITERED)
#&    & (DATPYR=[F:HRPEOD]PYRDAT
#&       & (!VRA
#&         | (VRA & !find([F:TIG]LIG,WFLG_DATBUL(0..WJ_DATBUL)) & ([F:TIG]DATBUL=[0/0/0] | [F:TIG]DATBUL=[F:TIG]DATPYR))))
#For [F:TIG]TIG1 Where REFNUM=MATRI & CTRNUM=CTR & evalue(CRITERED)
#&    & (DATPYR=[F:PEO]PYRDAT
#&       & (!VRA
#&         | (VRA & !find([F:TIG]LIG,WFLG_DATBUL(0..WJ_DATBUL)) & ([F:TIG]DATBUL=[0/0/0] | [F:TIG]DATBUL=[F:TIG]DATPYR))))
For [TIG]TIG1 Where REFNUM=MATRI & CTRNUM=CTR & evalue(CRITERED)
&    & evalue([L]CRITPEO)
&       & (!VRA
&         | (VRA & !find([F:TIG]LIG,WFLG_DATBUL(0..WJ_DATBUL)) & (([F:TIG]DATBUL=[0/0/0] | [F:TIG]DATBUL=[F:VEP]PYRDAT) & ([F:TIG]BUL="" | [F:TIG]BUL=[F:VEP]BUL))))
#MIPEA - 2017-02-01- X3-12122- END
#JASMI - 2017-02-01 - Issue 121325 - END
#MIPEA - 2017-09-11- US X3-54558- START
COUNTTIG1=0
#MIPEA - 2017-09-11- US X3-54558- END
 #FQ105844 Le FLGBUL ne sert plus, le champ DATPYR est suffisant
 DAT  = max(REGDEB,[F:TIG]STRDAT)
 DEBK = max(REGDEB,[F:TIG]STRDAT)-REGDEB+1
 FINK = min(REGFIN,[F:TIG]ENDDAT)-REGDEB+1
#JASMI - 2017-02-02 - Issue 121325 - START
 If PREADJ & [F:TIG]STRDAT<REGDEB
  DAT  = [F:TIG]STRDAT
  DEBK = [F:TIG]STRDAT-[F:TIG]STRDAT+1
  FINK = [F:TIG]ENDDAT-[F:TIG]STRDAT+1
 Endif
#JASMI - 2017-02-02 - Issue 121325 - END
 T = find([F:TIG]TIM,TBCOD(1..NBCOD))
 T2=0
 If [F:TIG]NATCOD<>"" :  T2= find([F:TIG]NATCOD,TBNAT(1..NBNAT)) : Endif
# Remonter le calcul de TOTNBRDAY ici car on le faisait X fois pour rien
 If [F:TIG]STRDAT<>[F:TIG]ENDDAT
   TOTC=([F:TIG]ENDDAT-[F:TIG]STRDAT+1)
   For ITYP=1 To 3
    TOTNBRDAY(ITYP)=0
    For IC=1 To TOTC
     DATC=[F:TIG]STRDAT+IC-1
     Call VALORTYP(DATC,DATC,MATRI,[F:TIG]TIM,JOURC,HEUREC,SITE,CTR,ITYP) From SUBPLN
     # TOTNBRDAY sert à proratiser les heures et jours quand on a un temps saisi sur plusieurs jours.
     # Donc on veut obtenir le nombre de jours où le salarié est présent, pas le décompte précis des jours de
     # travail (par exemple si temps partiel, on obtenait 4.5j au lieu de 5)
     If JOURC>0 Then JOURC=1 : Endif
     TOTNBRDAY(ITYP) += JOURC
    Next
   Next
 Endif

 For K=DEBK To FINK
  If [F:TIG]STRDAT=[F:TIG]ENDDAT
   HEURES = [F:TIG]NBRHOU
   JOURS  = [F:TIG]NBRDAY
   # Tps importé ->[F:TIG]STRDAT=[F:TIG]ENDDAT donc verif type de jours sinon jouvré=jouvrable=jcalend !!!
   For ITYP=1 To 3
     # Si type événement temps = type demandé on prend le temps de TIMEMP
     # Si type événement temps "Ouvrés" et le type demandé = "Calendaire" on prend le temps de TIMEMP
     # Dans les autres cas on prend le temps valorisé du Planning
#MIPEA - 2017-02-01- X3-12122- START
     Read [TIM]TIM0 = GCURLEG;[F:TIG]TIM
#     Read [TIM]TIM0 = [F:TIG]TIM
#MIPEA - 2017-02-01- X3-12122- END
     If !fstat & (ITYP=[F:TIM]DAYTYP | ([F:TIM]DAYTYP=2 & ITYP=3))
       Case ITYP
        When 1 :
           JOUVRAS=JOURS : HOUVRAS=HEURES
        When 2 :
           JOUVRES=JOURS : HOUVRES=HEURES
        When 3 :
           JCALENS=JOURS : HCALENS=HEURES
       Endcase
     Else
      Call VALORTYP([F:TIG]STRDAT,[F:TIG]ENDDAT,MATRI,[F:TIG]TIM,JOUR,HEURE,SITE,CTR,ITYP) From SUBPLN
    # On ne prend pas le min : on prend la valeur saisie si la valorisation est non nulle, on prend 0 sinon
      Case ITYP
       When 1 :
          If JOUR<>0  Then JOUVRAS=[F:TIG]NBRDAY Else JOUVRAS=0 : Endif
          If HEURE<>0 Then HOUVRAS=[F:TIG]NBRHOU Else HOUVRAS=0 : Endif
       When 2 :
          If JOUR<>0  Then JOUVRES=[F:TIG]NBRDAY Else JOUVRES=0 : Endif
          If HEURE<>0 Then HOUVRES=[F:TIG]NBRHOU Else HOUVRES=0 : Endif
       When 3 :
          If JOUR<>0  Then JCALENS=[F:TIG]NBRDAY Else JCALENS=0 : Endif
          If HEURE<>0 Then HCALENS=[F:TIG]NBRHOU Else HCALENS=0 : Endif
      Endcase
     Endif
   Next
   ###
  Else
   ## Attention le cas d'une saisie de régul multi-dates avec des + et des - n'est pas gérées
   ## pour l'édition du bulletin calendrier.

   ## Exemple d'une bonne saisie
   ## ligne 1 :  du 15/09 au 15/09 -1 CP
   ## ligne 2 :  du 16/09 au 16/09 +1 CP
   ## ligne 3 :  du 17/09 au 17/09 -1 CP

   ## Exemple d'une mauvaise saisie
   ## ligne 1 :  du 15/09 au 17/09 -1 CP
   Call VALORIS(DAT,DAT,MATRI,[F:TIG]TIM,JOUR,HEURE,SITE,CTR) From SUBPLN
   If [F:TIG]NBRDAY<0
    HEURE=HEURE*-1
    JOUR=JOUR*-1
   Endif
   HEURES = HEURE
   JOURS  = JOUR
# Remonter le calcul de TOTNBRDAY en haut car on le faisait X fois pour rien
   # Calcul du nombre de jours selon le type
   # TOTNBRDAY à mettre en Decimal pour les 1/2 journées
   For ITYP=1 To 3
    Call VALORTYP(DAT,DAT,MATRI,[F:TIG]TIM,JOUR,HEURE,SITE,CTR,ITYP) From SUBPLN
    If [F:TIG]NBRDAY<0
     JOUR=JOUR*-1
    Endif
    If [F:TIG]NBRHOU<0
     HEURE=HEURE*-1
    Endif
   # TOTNBRDAY test / par 0
     # Si type événement temps = type demandé on prend le temps de TIMEMP
     # Si type événement temps "Ouvrés" et le type demandé = "Calendaire" on prend le temps de TIMEMP
     # Dans les autres cas on prend le temps valorisé du Planning
#MIPEA - 2017-02-01- X3-12122- START
    Read [TIM]TIM0 = GCURLEG;[F:TIG]TIM
#    Read [TIM]TIM0 = [F:TIG]TIM
#MIPEA - 2017-02-01- X3-12122- END
    # Si le nbre de jours de la saisie est <> nbre de jours calculés pour le type on ne peut pas prendre le temps de TIMEMP
    If !fstat & (ITYP=[F:TIM]DAYTYP | ([F:TIM]DAYTYP=2 & ITYP=3)) & [F:TIG]NBRDAY=TOTNBRDAY(ITYP)
      Case ITYP
       When 1 :
          If JOUR<>0 & TOTNBRDAY(ITYP) <> 0  Then JOUVRAS=[F:TIG]NBRDAY/TOTNBRDAY(ITYP) Else JOUVRAS=0 : Endif
          If HEURE<>0 & TOTNBRDAY(ITYP) <> 0 Then HOUVRAS=[F:TIG]NBRHOU/TOTNBRDAY(ITYP) Else HOUVRAS=0 : Endif
       When 2 :
          If JOUR<>0 & TOTNBRDAY(ITYP) <> 0  Then JOUVRES=[F:TIG]NBRDAY/TOTNBRDAY(ITYP) Else JOUVRES=0 : Endif
          If HEURE<>0 & TOTNBRDAY(ITYP) <> 0 Then HOUVRES=[F:TIG]NBRHOU/TOTNBRDAY(ITYP) Else HOUVRES=0 : Endif
       When 3 :
          If JOUR<>0 & TOTNBRDAY(ITYP) <> 0 Then JCALENS=[F:TIG]NBRDAY/TOTNBRDAY(ITYP) Else JCALENS=0 : Endif
          If HEURE<>0 & TOTNBRDAY(ITYP) <> 0 Then HCALENS=[F:TIG]NBRHOU/TOTNBRDAY(ITYP) Else HCALENS=0 : Endif
      Endcase
     Else
       Case ITYP
        When 1 :
           JOUVRAS=JOUR : HOUVRAS=HEURE
        When 2 :
           JOUVRES=JOUR : HOUVRES=HEURE
        When 3 :
           JCALENS=JOUR : HCALENS=HEURE
       Endcase
     Endif
   Next
   ###

  Endif


  JNUIT  = [F:TIG]DAYNGT
  QTY1   = [F:TIG]QTY1
  QTY2   = [F:TIG]QTY2
  ISTIMEMP=0
  GPOINT = "HREJOUR" : Gosub ENTREE From EXEFNC

## Cumul par activité pour le bulletin calendrier
  # Exemple : Régul du 01/01/2005 au 31/07/2005 pour le paye du 31/08/2005
  If DAT>=DATDEB & DAT<=DATFIN
   L = DAT - DATDEB +1
   REG_HRE_COD(T,L) += HEURES
   REG_JRS_COD(T,L) += JOURS
   REG_HRE_VAR2(T,L) += HEURES
   REG_JRS_VAR2(T,L) += JOURS
  Endif
# Fin extraction temps à fin calendrier
  If DAT>=DATDEB & DAT>DATFIN and DAT <= min(FMOIS,[F:TIG]ENDDAT)
   L = DAT - DATDEB +1
   REG_HRE_VAR2(T,L) += HEURES
   REG_JRS_VAR2(T,L) += JOURS
  Endif
  REG_Q1_COD+=QTY1
  REG_Q2_COD+=QTY2

  If T2
   If DAT>=DATDEB & DAT<=DATFIN
    L = DAT - DATDEB +1
    REG_HRE_NAT(T2,L) += HEURES
    REG_JRS_NAT(T2,L) += JOURS
   Endif
   REG_Q1_NAT+=QTY1
   REG_Q2_NAT+=QTY2
  Endif

## Activités "temps de travail"

  If TRAV(T)=2
   REG_TTR      += HEURES
   If JNUIT=2 or JNUIT=5
    REG_TTR_NUI += HEURES
   Else
    REG_TTR_JOU += HEURES
   Endif
  Endif

## Activités "repos compensateur"

  If REPOS(T)=2
   REG_TRP      += HEURES
  Endif

## "Le" travail

  If TBCOD(T)=GTPSW
   REG_TRA += HEURES
   If JNUIT=2 or JNUIT=5
    REG_TRA_NUI += HEURES
    If JNUIT=5
     REG_TRA_NPO += HEURES
    Endif
   Else
    REG_TRA_JOU += HEURES
    If JNUIT=4
     REG_TRA_JPO += HEURES
    Endif
   Endif
  Endif

## Activités autres

  If TRAV(T)<>2
   REG_AUT += HEURES
  Endif

## Absences
  If TIMCAT(T)=2
   REG_AUT += HEURES
  Endif

## Jours réels pour la mise à jour des variables

  REG_HRE_VAR(T) += HEURES
  REG_JRS_VAR(T) += JOURS

  REG_J_OUVRA(T) += JOUVRAS : REG_H_OUVRA(T) += HOUVRAS
  REG_J_OUVRE(T) += JOUVRES : REG_H_OUVRE(T) += HOUVRES
  REG_J_CALEN(T) += JCALENS : REG_H_CALEN(T) += HCALENS

#JASMI - 2017-09-05 - START
If func AFNC.ACTIV("GLM")
  If (JOUVRAS<>0 | JOUVRES<>0 | JCALENS<>0) & COUNTTIG1=0
    Gosub ADD_TO_SUBTYPE_ARRAY_TIG
    COUNTTIG1+=1
  Endif
Endif
#JASMI - 2017-09-05 - END

  REG_Q1_VAR(T)+= QTY1
  REG_Q2_VAR(T)+= QTY2
  If T2
   REG_HRE_VAR_NAT(T2) += HEURES
   REG_JRS_VAR_NAT(T2) += JOURS
   REG_Q1_VAR_NAT(T2)+= QTY1
   REG_Q2_VAR_NAT(T2)+= QTY2
  Endif

  DAT +=1
 Next K

## IJSS
# La prolongation a été enregistrée sur la paye précédente -> pas de modif à postériori
#
#110046
# on utilise W_TYPPGN
 If find(TBCOD(T),EVTPGN) Then
     If ( [F:TIG]STRDAT >= REGDEB& [F:TIG]STRDAT <= REGFIN)
&    | ( [F:TIG]ENDDAT >= REGDEB& [F:TIG]ENDDAT <= REGFIN)
&    | ( [F:TIG]STRDAT <  REGDEB& [F:TIG]ENDDAT >  REGFIN) Then
  # on prend les evenements qui touchent le mois *calendaire* en cours
  # suite d'événements TYPPGN = 1 "Initial"      >> VALEUR = 1
  # suite d'événements TYPPGN = 2 "Prolongation" >> VALEUR = 2
  # suite d'événements TYPPGN = 1 puis 2         >> VALEUR = 1
  # suite d'événements TYPPGN = 2 puis 1         >> VALEUR = 3
      If !W_TYPPGN(T) and TYPPGN(T)<>0
            If [F:TIG]TYPPGN=1
                TYPPGN(T) =1
            Elsif ([F:TIG]TYPPGN=2 and TYPPGN(T)<>2)
                TYPPGN(T) =3
            Else
                TYPPGN(T) =2
            Endif
            W_TYPPGN(T)=1
      Else
          W_TYPPGN(T)=1
          If TYPPGN(T) > [F:TIG]TYPPGN
              TYPPGN(T) = 3
          Elsif TYPPGN(T) < [F:TIG]TYPPGN
               TYPPGN(T) = [F:TIG]TYPPGN - TYPPGN(T)
          Else
               TYPPGN(T) = [F:TIG]TYPPGN
          Endif
      Endif
    Else
       TYPPGN(T) = [F:TIG]TYPPGN
    Endif
Endif
 ## Commentaires pour les variables

 If DAT_COD(T)<>"" : DAT_COD(T) += " , " : Endif
 If [F:TIG]STRDAT=[F:TIG]ENDDAT
  DAT_COD(T) -= format$("D:DD[/]MM",[F:TIG]STRDAT)
  # FQ109111 - 06/07/15 - Ajout Matin/après-midi dans le détail des réguls
  If [F:TIG]ENDDAY=2
    DAT_COD(T) -= mess(2,422,1)
  Elsif [F:TIG]STRDAY=2
    DAT_COD(T) -= mess(1,422,1)
  Endif
 Else
  DAT_COD(T) -= format$("D:DD[/]MM",[F:TIG]STRDAT)+"-"+format$("D:DD[/]MM",[F:TIG]ENDDAT)
 Endif
 If [F:TIG]CMT<>"" & NBR_CMT(T)<5
  NBR_CMT(T) += 1
  CMT_COD(T,NBR_CMT(T)) = [F:TIG]CMT
 Endif
 If T2
  If DAT_NAT(T2)<>"" : DAT_NAT(T2) += " , " : Endif
  If [F:TIG]STRDAT=[F:TIG]ENDDAT
   DAT_NAT(T2) -= format$("D:DD[/]MM",[F:TIG]STRDAT)
  Else
   DAT_NAT(T2) -= format$("D:DD[/]MM",[F:TIG]STRDAT)+"-"+format$("D:DD[/]MM",[F:TIG]ENDDAT)
  Endif
  If [F:TIG]CMT<>"" & NBR_CMT_NAT(T2)<5
   NBR_CMT_NAT(T2) += 1
   CMT_NAT(T2,NBR_CMT_NAT(T2)) = [F:TIG]CMT
  Endif
 Endif

Next

## Parcours des semaines
# Si plusieurs périodes d'activité sur le même mois de paie, on écrasait la synthèse de la 1ère période lors du calcul de
# la seconde. Maintenant, via cet indicateur FIRSTCTR et la date DATFIRST du 1er événement, on ne remet à 0 que sur le calcul de la 1ère
# période d'activité
Gosub CALC_SEMAINES
#MIPEA - 2017-02-01- X3-12122- START
Read [TIR]TIR0 = MATRI;CTR;[F:HRPEOD]PYRDAT
#Read [TIR]TIR0 = MATRI;CTR;[F:PEO]PYRDAT
#MIPEA - 2017-02-01- X3-12122- END
If fstat : Raz [F:TIR] : Endif
If DATFIRST<=DATMAX(0) | FIRSTCTR=0 Then
  Raz [F:TIR]
Endif
Call CTRDAT_STR_END(MATRI,CTR,CTRD,WSTRCTR,WENDCTR) From DIVPAYE : # FQ91472 US2912 SEGAY

DAT = DATDEB
Local Char    PLNCUR(10), SEMTYP(10)
Local Integer ANNEE, SEMAINE
Local Decimal HRE_SEM_TYP
#MIPEA - 2017-02-01- X3-12122- START
PLNCUR=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATPAY,"PLNTYP","HRCTR")
#PLNCUR=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,DATPAY,"PLNTYP","CTR")
#MIPEA - 2017-02-01- X3-12122- END
If PLNCUR="" : PLNCUR = GPLANNING : Endif
If clalev([F:WTY])=0 : Local File TYPWEEK [WTY] : Endif
If clalev([F:PLE])=0 : Local File PLANEMP [PLE] : Endif
Local Char CTRPLNTYP(GLONPLN)
For SEM=1 To NBSEM
 DATSEM = DAT
 Call DAT(DATSEM,ANNEE,SEMAINE) From SUBPLN
 #MIPEA - 2017-02-01- X3-12122- START
  CTRPLNTYP=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATPAY,"PLNTYP","HRCTR")
# CTRPLNTYP=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,DATPAY,"PLNTYP","CTR")
 #MIPEA - 2017-02-01- X3-12122- END
 Read [PLN]PLN0 = year(DATSEM);CTRPLNTYP
 HRE_SEM_TYP=0
 If !fstat
  SEMTYP = [F:PLN]WEKTYP(SEMAINE-1)
  If SEMTYP<>"" Then
  #ADNGO - 2017-02-03- X3-12122- START
    #Read [F:WTY]WTY0=SEMTYP
    Read [F:WTY]WTY0=GCURLEG;SEMTYP
  #ADNGO - 2017-02-03- X3-12122- END
    If !fstat Then
      # Planning opérationnel
      DATPLE=DATSEM
      For I=0 To 6
        Read [F:PLE]PLE0=[L]MATRI;DATPLE;[L]CTR
        If !fstat Then
          HRE_SEM_TYP += [F:PLE]NBRHOU
        Else
          HRE_SEM_TYP += [F:WTY]NBRHRS1(I)
        Endif
        DATPLE+=1
      Next
    Endif
  Endif
 Endif
 Raz TOT_HRE_COD, TOT_JRS_COD, TOT_HRE_NAT, TOT_JRS_NAT
 For K=1 To 7
  J = K+7*(SEM-1)
  SEM_TTR(K)         = TTR(J)
  SEM_TTR_JOU(K)     = TTR_JOU(J)
  SEM_TTR_NUI(K)     = TTR_NUI(J)
  SEM_TRP(K)         = TRP(J)
  SEM_TRA(K)         = TRA(J)
  SEM_TRA_JOU(K)     = TRA_JOU(J)
  SEM_TRA_NUI(K)     = TRA_NUI(J)
  SEM_TRA_JPO(K)     = TRA_JPO(J)
  SEM_TRA_NPO(K)     = TRA_NPO(J)
  SEM_AUT(K)         = AUT(J)
  SEM_ABS(K)         = ABSENCE(J)
  SEM_PRE(K)         = PRE(J)
  SEM_Q1_COD(K)    = Q1_COD(J)
  SEM_Q2_COD(K)    = Q2_COD(J)
  SEM_Q1_NAT(K)    = Q1_NAT(J)
  SEM_Q2_NAT(K)    = Q2_NAT(J)
  For T=1 To NBCOD
   SEM_HRE_COD(T,K)  = HRE_COD(T,J)
   SEM_JRS_COD(T,K)  = JRS_COD(T,J)
   TOT_HRE_COD(T)   += HRE_COD(T,J)
   TOT_JRS_COD(T)   += JRS_COD(T,J)
  Next T
  For T2=1 To NBNAT
   SEM_HRE_NAT(T2,K)  = HRE_NAT(T2,J)
   SEM_JRS_NAT(T2,K)  = JRS_NAT(T2,J)
   TOT_HRE_NAT(T2)   += HRE_NAT(T2,J)
   TOT_JRS_NAT(T2)   += JRS_NAT(T2,J)
  Next T2
  If year(DAT)<>[F:HLY]YEA
  #ADNGO - 2017-02-03- X3-12122- START
   #Read [HLY]HLY0 = year(DAT);SITE
   Read [HLY]HLY0 = year(DAT);SITE;GCURLEG
  #ADNGO - 2017-02-03- X3-12122- END
   If fstat
   #ADNGO - 2017-02-03- X3-12122- START
    #Read [HLY]HLY0 = year(DAT);""
    Read [HLY]HLY0 = year(DAT);"";GCURLEG
   #ADNGO - 2017-02-03- X3-12122- END
   Endif
  Endif

## AVANT : Les heures non travaillées d'1 jour férié sont assimilées à du travail effectif.
##  Si salarié travaille 1 jour férié (TTR(J)<>0) ces heures s'ajoutent au"temps de travail"=> Bug 43362
##
## Pour l'administration et le conseil d'état "les jours fériés chômés doivent être assimilés à du temps de W effectif lorsqu'il s'agit
## de déterminer les majorations pour heures supplémentaires ». Il faut ignorer les heures correspondant à un jour férié chômé lorsqu’il
## s’agit de déterminer les droits à bonification « repos » d’un salarié, mais en tenir compte pour des majorations octroyées sous forme de salaire.
##
## La cour de cassation dit que « les jours fériés et les congés payés ne peuvent être assimilés à du temps de travail effectif.
## Pour RF paye "A notre avis, en usant du terme de « majoration », la Cour de cassation s’est voulue plus stricte que le Conseil d’État
## et a entendu viser les majorations de salaire. Certains retiennent une autre interprétation : la solution préconisée par la Cour
## de cassation ne vaudrait que lorsque les majorations sont octroyées sous forme de repos compensateur de remplacement.
## Dans cette optique, le jour férié resterait assimilé à du temps de travail effectif lorsque les majorations pour heures
## supplémentaires sont octroyées en salaire. »

  If find(DAT,[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
   SEM_FER(K) = 1

   Call VALORIS(DAT,DAT,MATRI,"",JOUR,HEURE,SITE,CTR) From SUBPLN
#   Infbox "13 "-num$(DAT)-" "-num$(JOUR)
   # Cas particulier du 1er Mai considéré comme du temps de travail effectif et payé 100% s'il travaillait
   If day(DAT)=1 & month(DAT)=5
    SEM_TTR(K)     += HEURE-TTR(J)
    SEM_TTR_JOU(K) += HEURE-TTR(J)
    SEM_TRP(K)     += HEURE-TTR(J)
   Endif

   If TTR(J)<HEURE
    ## Heures non travaillées 1 jour férié sont exclues du repos comp et non imputées sur contingent
    SEM_TTR_FER(K) = HEURE-TTR(J)
   Else
    SEM_TTR_FER(K) = 0
   Endif
  Else
   SEM_FER(K) = 0
   SEM_TTR_FER(K) = 0
  Endif
  GPOINT = "HRESEMSYN" : Gosub ENTREE From EXEFNC

  DAT += 1
 Next K

 TOT_TTR       = sum(SEM_TTR(1..7))
 TOT_TTR_JOU   = sum(SEM_TTR_JOU(1..7))
 TOT_TTR_NUI   = sum(SEM_TTR_NUI(1..7))
 TOT_TRP       = sum(SEM_TRP(1..7))
 TOT_TRP_NOSUN = sum(SEM_TRP(1..6))
 TOT_TRA       = sum(SEM_TRA(1..7))
 TOT_TRA_JOU   = sum(SEM_TRA_JOU(1..7))
 TOT_TRA_NUI   = sum(SEM_TRA_NUI(1..7))
 TOT_TRA_JPO   = sum(SEM_TRA_JPO(1..7))
 TOT_TRA_NPO   = sum(SEM_TRA_NPO(1..7))
 TOT_AUT       = sum(SEM_AUT(1..7))
 TOT_ABS       = sum(SEM_ABS(1..7))
 TOT_PRE       = sum(SEM_PRE(1..7))
 TOT_Q1_COD    = sum(SEM_Q1_COD(1..7))
 TOT_Q2_COD    = sum(SEM_Q2_COD(1..7))
 TOT_Q1_NAT    = sum(SEM_Q1_NAT(1..7))
 TOT_Q2_NAT    = sum(SEM_Q2_NAT(1..7))

 # On ne calcule la synthèse des temps que pour les semaines contenues dans la période
 # D'où l'ajout du test SEM<=NBSEM1
 If SEM<=NBSEM1 & SYN
   For I=1 To NBVAR
    VARIA  = TBVAR(I)
    VALEUR = 0
    ACTION = "CALCUL" : Gosub ACTION
    # Si on est sur la 1ère période d'activité, on prend VALEUR. Sinon, on doit cumuler les valeurs entre chaque
    # période d'acivité
    If VALEUR = 0 & (WSTRCTR = [0/0/0] | [F:TIR]CTRDAT(SEM-1) < WSTRCTR | [F:TIR]CTRDAT(SEM-1) > WENDCTR)
      VALEUR += evalue("[F:TIR]"+TBVAR(I)+"("+num$(SEM-1)+")")
    Endif
    Assign "[F:TIR]"+TBVAR(I)+"("+num$(SEM-1)+")" With VALEUR
   Next I
 Endif
 ACTION = "CONTROLE" : Gosub ACTION

 If !ERR & DETAIL
#MIPEA - 2017-02-01- X3-12122- START
  MESSAGE = MATRI-":"-mess(21,10709,1)-format$("D:"+GFMDAT,DATSEM)-mess(22,10709,1)-format$("D:"+GFMDAT,DATSEM+6)
#  Semaine du ... au
  If MODULATION & DATSEM+6>DATFIN
   MESSAGE = MATRI-":"-mess(21,10709,1)-format$("D:"+GFMDAT,DATSEM)-mess(22,10709,1)-format$("D:"+GFMDAT,DATFIN)
  Endif
#  MESSAGE = MATRI-":"-mess(21,709,1)-format$("D:"+GFMDAT,DATSEM)-mess(22,709,1)-format$("D:"+GFMDAT,DATSEM+6)
##  Semaine du ... au
#  If MODULATION & DATSEM+6>DATFIN
#   MESSAGE = MATRI-":"-mess(21,709,1)-format$("D:"+GFMDAT,DATSEM)-mess(22,709,1)-format$("D:"+GFMDAT,DATFIN)
#  Endif
#MIPEA - 2017-02-01- X3-12122- END
  If GTRACE<>""
   Call ECR_TRACE(MESSAGE-"OK",0) From GESECRAN
  Endif
 Endif

Next SEM

# Pour un même salarié, avec plusieurs périodes d'activité, on peut avoir plusieurs bulletins avec la même date
# de paie. Dans ce cas, pour affecter les valeurs sur le bon bulletin, il faut ajouter la date du contrat dans le critère de filtre
Local Date CTRDAT_VEP : CTRDAT_VEP=CTRD

## Mise à jour synthèse
If SYN
  Local Date DATPAY2
  Local Integer WOK,WI
  If clalev([F:CTRP])=0 : Local File EMPLOCTR [CTRP] : Endif
  [L]DATPAY2=DATPAY
  [L]WBULLETIN=""
  WOK=1
  If [L]TCTRD(0) <> [0/0/0]
    For WI = 0 To dim([L]TCTRD)-1
      If [L]TCTRD(WI) <> [0/0/0]
        If GPAYE
          Read[F:CTRP]CTR0=MATRI;CTR;[L]TCTRD(WI)
          If !fstat
#MIPEA - 2017-02-01- X3-12122- START
            Call TPSDATPAY(MATRI,CTR,[L]TCTRD(WI),[F:CTRP]XITDAT,DATPAY,[F:CTRP]ETRFCY,[L]DATPAY2,[F:CTRP]PERCOD) From TRTTPS
#            Call TPSDATPAY(MATRI,CTR,[L]TCTRD(WI),[F:CTRP]XITDAT,DATPAY,[F:CTRP]ETRFCY,[L]DATPAY2) From TRTTPS
#MIPEA - 2017-02-01- X3-12122- END
          Endif
        Endif
        CTRDAT_VEP=[L]TCTRD(WI)
        ## Mise à jour synthèse
        Gosub SYN_BIS
      Endif
    Next
  Else
    ## Mise à jour synthèse
    Gosub SYN_BIS
  Endif
  If !WOK : End : Endif
Endif

## Mise à jour des dates

Call DEBTRANS From GLOCK
Gosub TR3

## MAJ variables de paye
If VRA

 Gosub FILTRE_VEP From TRTTPS
 # Il faut mettre à jour le bon bulletin
 Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY & CTRNUM=CTR & evalue([L]CRITERED_VEP) & evalue (CRITVEP)
 Read [VEP]VEP0 Last
 Filter [VEP]
 If fstat>2
  If GTRACE<>"" & TOT_PRE<>0
#MIPEA - 2017-02-01- X3-12122- START
   Call ECR_TRACE(MATRI-":"-mess(29,10709,1),1) From GESECRAN : # Paye non générée
#   Call ECR_TRACE(MATRI-":"-mess(29,709,1),1) From GESECRAN : # Paye non générée
#MIPEA - 2017-02-01- X3-12122- END
  Endif
  End
 Elsif [F:VEP]PST>1
& or  [F:VEP]FLGLOCK=2 : # Verrouillé

  If GTRACE<>""
   If clalev([F:CTRP])=0 : Local File EMPLOCTR [CTRP] : Endif
   Read [F:CTRP]CTR0=MATRI;CTR;[F:VEP]CTRDAT
   If [F:CTRP]XITDAT<>[0/0/0] Then
    If [F:VEP]PST>1
#MIPEA - 2017-02-01- X3-12122- START
       Call ECR_TRACE(MATRI-"("+mess(6,10506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:CTRP]CTRDAT)-mess(41,101,1)-format$(GFMD,[F:CTRP]XITDAT)+") :"-mess(30,10709,1),1) From GESECRAN : # Paye déjà
#       Call ECR_TRACE(MATRI-"("+mess(6,506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:CTRP]CTRDAT)-mess(41,101,1)-format$(GFMD,[F:CTRP]XITDAT)+") :"-mess(30,709,1),1) From GESECRAN : # Paye déjà
#MIPEA - 2017-02-01- X3-12122- END
# comptabilisée
    Else
       # Verrouillé
#MIPEA - 2017-02-01- X3-12122- START
       Call ECR_TRACE(MATRI-"("+mess(6,10506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:CTRP]CTRDAT)-mess(41,101,1)-format$(GFMD,[F:CTRP]XITDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(224,10703,
& 1),1
& ) From GESECRAN
#       Call ECR_TRACE(MATRI-"("+mess(6,506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:CTRP]CTRDAT)-mess(41,101,1)-format$(GFMD,[F:CTRP]XITDAT)+")
# :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(224,703,1),1
#& ) From GESECRAN : #
#MIPEA - 2017-02-01- X3-12122- END
# Opération impossible : ce bulletin est verrouillé.
    Endif
   Else
    If [F:VEP]PST>1
#MIPEA - 2017-02-01- X3-12122- START
       Call ECR_TRACE(MATRI-"("+mess(6,10506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:CTRP]CTRDAT)+") :"-mess(30,10709,1),1) From GESECRAN
#       Call ECR_TRACE(MATRI-"("+mess(6,506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:CTRP]CTRDAT)+") :"-mess(30,709,1),1) From GESECRAN : # Paye déjà comptabilisée
#MIPEA - 2017-02-01- X3-12122- END
    Else
       # Verrouillé
#MIPEA - 2017-02-01- X3-12122- START
       Call ECR_TRACE(MATRI-"("+mess(6,10506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:CTRP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(224,10703,1),1) From GESECRAN : #  Opération
# impossible :
#       Call ECR_TRACE(MATRI-"("+mess(6,506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:CTRP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(224,703,1),1) From GESECRAN : #  Opération impossible :
#MIPEA - 2017-02-01- X3-12122- END
# ce bulletin est verrouillé.
    Endif
   Endif
  Endif
  End # Opération impossible on sort
 Endif

#MIPEA - 2017-02-09- X3-11284- START
 Read [TIR]TIR0 = MATRI;CTR;[F:HRPEOD]PYRDAT
# Read [TIR]TIR0 = MATRI;CTR;[F:PEO]PYRDAT
#MIPEA - 2017-02-09- X3-11284- END
 If fstat : Raz [F:TIR] : Endif

 #Calcul de variables de type formules E_*
 Gosub TR_NBJOURS From TRTFORVAR
 ###

 Call DEBTRANS From GLOCK
 Gosub TR2A

 Call DEBTRANS From GLOCK
 Gosub TR2

 If GBULCAL=2
  Call DEBTRANS From GLOCK
  Gosub TR4
 Else
  # Le paramètre calendrier indique si c'est un état de type calendrier
  Read [ARD]ARD1="calendrier";[F:VEP]RPTBUL
  If !fstat & [F:ARD]PARDEF1=num$(2)
   Call DEBTRANS From GLOCK
   Gosub TR4
  Endif
 Endif
 If GPAYE & GOK
  Global Char GNUMBUL (GLONVCR)
  GNUMBUL=[F:VEP]BUL
  Call MAJFLGTPS (MATRI,DATPAY,CTR,3,2,DATTPS) From SUBVEP
  Kill GNUMBUL
 Endif
Endif

## Mail aux salariés

If MEL
 Raz GWRK
 K = 0
 For [TIM]TIM0 Where CATTIM=3
  T = find([F:TIM]COD,TBCOD(1..NBCOD))
  If T
   VALEUR = 0
   For J=1 To MAXJOURS
    VALEUR += JRS_VAR(T,J)
   Next J
   If VALEUR
    K += 1
    GWRK(K) = [F:TIM]COD-[F:TIM]DES-":"-num$(VALEUR)-"jours"-":"-DAT_COD(T)
   Endif
  Endif
 Next
 If K
  # 150 : Attention, [F:ID] doit être en ligne
  Call WORKFLOW(1,"TPS","","") From AWRK
 Endif
Endif

End

## Mise à jour synthèse
$SYN_BIS
If GPAYE
  Gosub FILTRE_VEP From TRTTPS
  # Il faut mettre à jour le bon bulletin
  Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY2 & CTRNUM=CTR & evalue([L]CRITERED_VEP) & evalue(CRITVEP)
  Read [VEP]VEP0 Last
  Filter [VEP]
  If !fstat
   If [F:VEP]FLGLOCK=2 : # Verrouillé
      # MESSAGE Opération impossible : ce bulletin est verrouillé.
      If clalev([F:CTRP])=0 : Local File EMPLOCTR [CTRP] : Endif
      Read [F:CTRP]CTR0=MATRI;CTR;[F:VEP]CTRDAT
      If [F:CTRP]XITDAT<>[0/0/0] Then
#MIPEA - 2017-02-01- X3-12122- START
       [L]WMESSAGE=MATRI-"("+mess(6,10506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:CTRP]CTRDAT)-mess(41,101,1)-format$(GFMD,[F:CTRP]XITDAT)+") :"-[F:VEP]BUL-mess(224,10703,1)-format$(GFMD,[F:VEP]PYRDAT)
& : #
#       [L]WMESSAGE=MATRI-"("+mess(6,506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:CTRP]CTRDAT)-mess(41,101,1)-format$(GFMD,[F:CTRP]XITDAT)+") :"-[F:VEP]BUL-mess(224,703,1)-format$(GFMD,[F:VEP]PYRDAT) : #
#MIPEA - 2017-02-01- X3-12122- END
# Opération impossible : ce bulletin est verrouillé.
      Else
#MIPEA - 2017-02-01- X3-12122- START
       [L]WMESSAGE=MATRI-"("+mess(6,10506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:CTRP]CTRDAT)+") :"-[F:VEP]BUL-mess(224,10703,1)-format$(GFMD,[F:VEP]PYRDAT): #  Opération impossible : ce bulletin est
#       [L]WMESSAGE=MATRI-"("+mess(6,506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:CTRP]CTRDAT)+") :"-[F:VEP]BUL-mess(224,703,1)-format$(GFMD,[F:VEP]PYRDAT): #  Opération impossible : ce bulletin est
#MIPEA - 2017-02-01- X3-12122- END
# verrouillé.
      Endif
      If GTRACE<>""
         Call ECR_TRACE([L]WMESSAGE,1) From GESECRAN
      Else
         Infbox [L]WMESSAGE
      Endif
      WOK=0
      Return
   Endif
   [L]WBULLETIN=[F:VEP]BUL
  Endif
Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GPAYE & GOK
# Verrouillé
  If [L]WBULLETIN <> ""
   Global Char GNUMBUL (GLONVCR)
   GNUMBUL=[L]WBULLETIN
   Call MAJFLGTPS (MATRI,DATPAY2,CTR,2,2,[0/0/0]) From SUBVEP
   Kill GNUMBUL
  Endif
Endif
Return

$FILTER_VEP
Raz WSTRCTR,WENDCTR
If GPAYE
 Gosub FILTRE_VEP From TRTTPS
 # Il faut mettre à jour le bon bulletin
 Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY & CTRNUM=CTR & evalue([L]CRITERED_VEP) & evalue (CRITVEP)
 Read [VEP]VEP0 Last
 Filter [VEP]
 If !fstat
  WSTRCTR=[F:VEP]STRCTRDAT
  WENDCTR=[F:VEP]CTRDAT
 Endif
Endif
Return

$ACTION
# SPE avant STD
[V]GPE=0
If PSPE : Gosub ACTION From SPECALTPS : Endif
If ![V]GPE
  If PSUB : Gosub ACTION From SUBCALTPS : Endif
Endif
Return

# Calcul du nombre de semaines, et des dates max par semaine
$CALC_SEMAINES
Local Integer NBSEM1,ANNEE,SEMAINE,EXITSAL
# 11 peut ne pas suffire dans le cas de sortie anticipée : donc on ouvre le tableau pour ne pas être limité
Local Date    DATCL,DATMAX(0..),DATFINCL,FMOISCL
Local Char    FCYD(GLONFCY)

  NBSEM1=0
#MIPEA - 2017-02-01- X3-12122- START
  DATCL    = [F:HRPEOD]PERSTR(0)
  DATFINCL = [F:HRPEOD]PEREND(0)
  FMOISCL  = [F:HRPEOD]PEREND(1)
#  DATCL    = [F:PEO]PERSTR(0)
#  DATFINCL = [F:PEO]PEREND(0)
#  FMOISCL  = [F:PEO]PEREND(1)
#MIPEA - 2017-02-01- X3-12122- END
  # Ajout nouveaux paramètres dans CALC_DATEND + Calcul du site
  FCYD=""
#MIPEA - 2017-02-01- X3-12122- START
  If !fstat Then FCYD=func SUBCTRRET.FIND_RETRO_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[F:HRPEOD]PYRDAT,"ETRFCY","HRCTR") : Endif
  Call CALC_DATEND(FCYD, [F:HRPEOD]PYRDAT, [F:HRCTR]XITDAT, [F:HRCTR]XITFNL, [F:HRCTR]CLEEVETIM, DATCL, DATFINCL, FMOISCL, EXITSAL, [F:HRCTR]PERCOD) From TRTTPS
#  If !fstat Then FCYD=func SUBCTRRET.FIND_RETRO_FLD([F:CTR]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,[F:PEO]PYRDAT,"ETRFCY","CTR") : Endif
#  Call CALC_DATEND(FCYD, [F:PEO]PYRDAT, [F:CTR]XITDAT, [F:CTR]XITFNL, [F:CTR]CLEEVETIM, DATCL, DATFINCL, FMOISCL, EXITSAL) From TRTTPS
#MIPEA - 2017-02-01- X3-12122- END
  Repeat
    Call DAT(DATCL,ANNEE,SEMAINE) From SUBPLN
    NBSEM1 += 1
    Case NBSEM1
      When 1 : DATMAX(NBSEM1-1)  = DATCL+6
      When 2 : DATMAX(NBSEM1-1)  = DATCL+6
      When 3 : DATMAX(NBSEM1-1)  = DATCL+6
      When 4 : DATMAX(NBSEM1-1)  = DATCL+6
      When 5 : DATMAX(NBSEM1-1)  = DATCL+6
      When 6 : DATMAX(NBSEM1-1)  = DATCL+6
      When 7 : DATMAX(NBSEM1-1)  = DATCL+6
      When 8 : DATMAX(NBSEM1-1)  = DATCL+6
      When 9 : DATMAX(NBSEM1-1)  = DATCL+6
    Endcase
    DATCL += 7
  Until DATCL>DATFINCL
  For I=0 To NBSEM1-1
    If [F:TIR2]CTRDAT(I)=[0/0/0] Then
      # Paramètre WEEKP à 3 car calcul par semaine
#MIPEA - 2017-02-01- X3-12122- START
      [F:TIR2]CTRDAT(I)=func TPSSTD.CALC_CTRDATDEF(MATRI,CTR,DATMAX(I),[F:HRPEOD]PYRDAT,DATMAX(I),3)
#      [F:TIR2]CTRDAT(I)=func TPSSTD.CALC_CTRDATDEF(MATRI,CTR,DATMAX(I),[F:PEO]PYRDAT,DATMAX(I),3)
#MIPEA - 2017-02-01- X3-12122- END
    Endif
  Next
Return

$TR1
# NBSEM est remplacé par NBSEM1 dans cette étiquette, sinon écrase le NBSEM utilisé dans TRTSYN.MAJ
#MIPEA - 2017-09-05- US X3-54558- START
Local Integer NBSEM1,ANNEE,SEMAINE
#Local Integer NBSEM1,ANNEE,SEMAINE,EXITSAL
#MIPEA - 2017-09-05- US X3-54558- END
Local Date    DATCL,DATMAX(0..11),CTRDAT_S(0..dim([F:TIR2]CTRDAT)-1),DATFINCL,FMOISCL
GOK = 1
Trbegin [TIR2]
 # Calcul du nombre de semaines, et des dates max par semaine
 Gosub CALC_SEMAINES
 #MIPEA - 2017-02-01- X3-12122- START
  Readlock [TIR2]TIR0 = MATRI;CTR;[F:HRPEOD]PYRDAT
# Readlock [TIR2]TIR0 = MATRI;CTR;[F:PEO]PYRDAT
 #MIPEA - 2017-02-01- X3-12122- END
 If fstat=1
  GOK = -1 : GLOCK = "$TIMRECAP"-MATRI : Goto ROLL_TR1
 Elsif fstat
  Raz [F:TIR2]
  [F:TIR2] = [F:TIR]
  [F:TIR2]REFNUM = MATRI
  [F:TIR2]CTRNUM = CTR
#MIPEA - 2017-02-01- X3-12122- START
  [F:TIR2]PYRDAT = [F:HRPEOD]PYRDAT
#  [F:TIR2]PYRDAT = [F:PEO]PYRDAT
#MIPEA - 2017-02-01- X3-12122- END
  For I=0 To NBSEM1-1
    If [F:TIR2]CTRDAT(I)=[0/0/0] Then
      # Paramètre WEEKP à 3 car calcul par semaine
#MIPEA - 2017-02-01- X3-12122- START
      [F:TIR2]CTRDAT(I)=func TPSSTD.CALC_CTRDATDEF(MATRI,CTR,DATMAX(I),[F:HRPEOD]PYRDAT,DATMAX(I),3)
#      [F:TIR2]CTRDAT(I)=func TPSSTD.CALC_CTRDATDEF(MATRI,CTR,DATMAX(I),[F:PEO]PYRDAT,DATMAX(I),3)
#MIPEA - 2017-02-01- X3-12122- END
    Endif
  Next
  If dim([F:TIR2]CREUSR)>0 : [F:TIR2]CREUSR = GUSER : Endif
  If dim([F:TIR2]CREDAT)>0 : [F:TIR2]CREDAT = date$ : Endif
  If dim([F:TIR2]CRETIM)>0 : [F:TIR2]CRETIM = time  : Endif
#MIPEA - 2017-02-01- X3-12122- START
  Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & (CTRDAT<=[F:HRPEOD]PYRDAT | (FLGRET=2 & RETDATEFF<=[F:HRPEOD]PYRDAT))
  Read [HRCTR]CTR0 Last
  Filter [HRCTR]
#  Filter [CTR] Where REFNUM=MATRI & CTRNUM=CTR & (CTRDAT<=[F:PEO]PYRDAT | (FLGRET=2 & RETDATEFF<=[F:PEO]PYRDAT))
#  Read [CTR]CTR0 Last
#  Filter [CTR]
#MIPEA - 2017-02-01- X3-12122- END
  If !fstat
#MIPEA - 2017-02-01- X3-12122- START
   [F:TIR2]FCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[F:HRPEOD]PYRDAT,"ETRFCY","HRCTR")
   [F:TIR2]SRV=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[F:HRPEOD]PYRDAT,"ETRSRV","HRCTR")
#   [F:TIR2]FCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,[F:PEO]PYRDAT,"ETRFCY","CTR")
#   [F:TIR2]SRV=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,[F:PEO]PYRDAT,"ETRSRV","CTR")
#MIPEA - 2017-02-01- X3-12122- END
  Else
   Raz [F:TIR2]FCY, [F:TIR2]SRV
  Endif
  Write [TIR2]
 Else
  [F:TIR]CREDAT  = [F:TIR2]CREDAT
  [F:TIR]CREUSR  = [F:TIR2]CREUSR
  [F:TIR]FCY     = [F:TIR2]FCY
  [F:TIR]SRV     = [F:TIR2]SRV
  For I=0 To dim([F:TIR2]CTRDAT)-1
    CTRDAT_S(I)  = [F:TIR2]CTRDAT(I)
  Next
  [F:TIR2]       = [F:TIR]
  For I=0 To dim([F:TIR2]CTRDAT)-1
    If [F:TIR2]CTRDAT(I)=[0/0/0] Then
      [F:TIR2]CTRDAT(I) = CTRDAT_S(I)
    Endif
  Next
  [F:TIR2]REFNUM = MATRI
  [F:TIR2]CTRNUM = CTR
#MIPEA - 2017-02-01- X3-12122- START
  [F:TIR2]PYRDAT = [F:HRPEOD]PYRDAT
#  [F:TIR2]PYRDAT = [F:PEO]PYRDAT
#MIPEA - 2017-02-01- X3-12122- END
  For I=0 To NBSEM1-1
    If [F:TIR2]CTRDAT(I)=[0/0/0] Then
      # Paramètre WEEKP à 3 car calcul par semaine
#MIPEA - 2017-02-01- X3-12122- START
      [F:TIR2]CTRDAT(I)=func TPSSTD.CALC_CTRDATDEF(MATRI,CTR,DATMAX(I),[F:HRPEOD]PYRDAT,DATMAX(I),3)
#      [F:TIR2]CTRDAT(I)=func TPSSTD.CALC_CTRDATDEF(MATRI,CTR,DATMAX(I),[F:PEO]PYRDAT,DATMAX(I),3)
#MIPEA - 2017-02-01- X3-12122- END
    Endif
  Next
  If dim([F:TIR2]UPDDAT)>0 : [F:TIR2]UPDDAT = date$ : Endif
  If dim([F:TIR2]UPDUSR)>0 : [F:TIR2]UPDUSR = GUSER : Endif
  If dim([F:TIR2]UPDTIM)>0 : [F:TIR2]UPDTIM = time  : Endif
  Rewrite [TIR2]
 Endif
 If fstat
  GOK = 0 : Call FSTA("TIR2") From GLOCK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#######################################################################
## Mise à jour des dates
#######################################################################
$TR3OLD
Raz FLGDAT
# On cherche d'abord les évènements TBDAT dans les réguls du mois précédent
# puis dans la saisie des temps du mois en cours
For I=1 To NBDAT
 # S'il y a une régul sur une date du fichier TIMEMPDAT on raz la date
 Read [TID]TID0=MATRI;CTR
 If !fstat & REGDEB<=evalue("[F:TID]DAT"+TBDAT(I)) & REGFIN>=evalue("[F:TID]DAT"+TBDAT(I))
  Filter [TIG] Where REFNUM=MATRI & STRDAT<=evalue("[F:TID]DAT"+TBDAT(I)) & TIM<>TBDAT(I) &
&                                   ENDDAT>=evalue("[F:TID]DAT"+TBDAT(I)) & CTRNUM=CTR
  Read [TIG]TIG2 First
  Filter [TIG]
  If !fstat
   FLGDAT(I) = 1
   DATDAT(I) = [00/00/00]
  Endif
 Endif

 # S'il y a une régul sur un code évènement TBDAT, on prend la date de régul
 Filter [TIG] Where REFNUM=MATRI & STRDAT>=REGDEB & ENDDAT<=REGFIN & TIM=TBDAT(I) & CTRNUM=CTR
 Read [TIG]TIG2 Last
 Filter [TIG]
 If !fstat
  FLGDAT(I) = 1
  DATDAT(I) = [F:TIG]ENDDAT
 Endif

 # S'il y a une saisie des temps sur le code évènement TBDAT, on prend la date de saisie
 Filter [TIP] Where REFNUM=MATRI & STRDAT>=DATDEB & TIM=TBDAT(I) & CTRNUM=CTR
 Read [TIP]TIP1 Last
 Filter [TIP]
 If !fstat
  FLGDAT(I) = 1
  DATDAT(I) = [F:TIP]ENDDAT
 Endif
Next I
If sum(FLGDAT(1..NBDAT))=0 : Return : Endif
GOK = 1
Trbegin [TID]
 Readlock [TID]TID0 = MATRI;CTR
 If fstat=1
  GOK = -1 : GLOCK = "$TIMEMPDAT"-MATRI-CTR : Goto ROLL_TR3
 Elsif fstat
  Raz [F:TID]
  [F:TID]REFNUM = MATRI
  [F:TID]CTRNUM = CTR
  Gosub SET_DATE
  Write [TID]
 Else
  Gosub SET_DATE
  Rewrite [TID]
 Endif
 If fstat
  GOK = 0 : Call FSTA("TID") From GLOCK : Goto AB_TR3
 Endif
Commit
Return

#######################################################################
## Mise à jour des dates
#######################################################################
$TR3
Raz FLGDAT
If clalev([F:TIP2])=0  : Local File TIMEMP    [TIP2]  : Endif
If clalev([F:TIG2])=0  : Local File TIMREGUL  [TIG2]  : Endif

# On cherche d'abord les évènements TBDAT dans les réguls du mois précédent
# puis dans la saisie des temps du mois en cours
For I=1 To NBDAT
 If !find (TBDAT(I),EVTDEBARR)
   # S'il y a une régul sur une date du fichier TIMEMPDAT on raz la date
   Read [TID]TID0=MATRI;CTR
   If !fstat & REGDEB<=evalue("[F:TID]DAT"+TBDAT(I)) & REGFIN>=evalue("[F:TID]DAT"+TBDAT(I))
    Filter [TIG] Where REFNUM=MATRI & STRDAT<=evalue("[F:TID]DAT"+TBDAT(I)) & TIM<>TBDAT(I) &
&                                     ENDDAT>=evalue("[F:TID]DAT"+TBDAT(I)) & CTRNUM=CTR
    Read [TIG]TIG2 First
    Filter [TIG]
    If !fstat
     FLGDAT(I) = 1
     DATDAT(I) = [00/00/00]
    Endif
   Endif

   # S'il y a une régul sur un code évènement TBDAT, on prend la date de régul
   Filter [TIG] Where REFNUM=MATRI & STRDAT>=REGDEB & ENDDAT<=REGFIN & TIM=TBDAT(I) & CTRNUM=CTR
   Read [TIG]TIG2 Last
   Filter [TIG]
   If !fstat
    FLGDAT(I) = 1
    DATDAT(I) = [F:TIG]ENDDAT
   Endif
   # S'il y a une saisie des temps sur le code évènement TBDAT, on prend la date de saisie
   Filter [TIP] Where REFNUM=MATRI & STRDAT>=DATDEB & TIM=TBDAT(I) & CTRNUM=CTR
   Read [TIP]TIP1 Last
   Filter [TIP]
   If !fstat
    FLGDAT(I) = 1
    DATDAT(I) = [F:TIP]ENDDAT
   Endif

   WINDDEBARR = find("DEB"+TBDAT(I),EVTDEBARR)
   If WINDDEBARR
      WINDDEBARR = find(EVTDEBARR(WINDDEBARR),TBDAT)
   Endif
   If WINDDEBARR
     # S'il y a une régul sur une date du fichier TIMEMPDAT on raz la date
     Read [TID]TID0=MATRI;CTR
     If !fstat & REGDEB<=evalue("[F:TID]DAT"+TBDAT(WINDDEBARR)) & REGFIN>=evalue("[F:TID]DAT"+TBDAT(WINDDEBARR))
      Filter [TIG] Where REFNUM=MATRI & STRDAT<=evalue("[F:TID]DAT"+TBDAT(WINDDEBARR)) & TIM<>TBDAT(WINDDEBARR) &
&                                       ENDDAT>=evalue("[F:TID]DAT"+TBDAT(WINDDEBARR)) & CTRNUM=CTR
      Read [TIG]TIG2 First
      Filter [TIG]
      If !fstat
       FLGDAT(WINDDEBARR) = 1
       DATDAT(WINDDEBARR) = [00/00/00]
      Endif
     Endif
     # S'il y a une régul sur un code évènement TBDAT, on prend la date de régul
     # La date doit être alimentée à chaque nouvel arrêt initial, à condition qu’elle ne soit pas successive à un autre arrêt
     Filter [TIG] Where REFNUM=MATRI & STRDAT>=REGDEB & ENDDAT<=REGFIN & TIM=TBDAT(I) & CTRNUM=CTR
     For [TIG]TIG2
      If [TIG]TYPPGN = 1 & FLGDAT(I) & (DATDAT(WINDDEBARR)= [00/00/00] | (DATDAT(WINDDEBARR)+1 <> [F:TIG]STRDAT)) Then
       WOKDEBARR=1
       # S'il y a une régul sur le code évènement TBDAT et date <= date de début de TIMEMP, on ne prend la date de début
       Filter [TIG2] Where REFNUM=MATRI & [F:TIG2]STRDAT<[F:TIG]STRDAT & TIM=TBDAT(I) & CTRNUM=CTR
       Read [TIG2]TIG2 Last
       Filter [TIG2]
       If !fstat
         If [F:TIG]STRDAT = ([F:TIG2]ENDDAT+1)
          WOKDEBARR=0
         Endif
       Endif
       # S'il y a une saisie des temps < DATDEB sur le code évènement TBDAT et date <= date de début de TIMEMP, on ne prend la date de début
       Filter [TIP2] Where REFNUM=MATRI & [F:TIP]STRDAT<[F:TIG]STRDAT & TIM=TBDAT(I) & CTRNUM=CTR
       Read [TIP2]TIP1 Last
       Filter [TIP2]
       If !fstat
         If [F:TIG]STRDAT = ([F:TIP2]ENDDAT+1)
            WOKDEBARR=0
         Endif
       Endif
       If WOKDEBARR
          FLGDAT(WINDDEBARR) = 1
          DATDAT(WINDDEBARR) = [F:TIG]STRDAT
        Endif
      Endif
     Next
     Filter [TIG]

     # S'il y a une saisie des temps sur le code évènement TBDAT DBARR, on prend la date de saisie
     # La date doit être alimentée à chaque nouvel arrêt initial, à condition qu’elle ne soit pas successive à un autre arrêt
     Filter [TIP] Where REFNUM=MATRI & STRDAT>=DATDEB & TIM=TBDAT(I) & CTRNUM=CTR
     For[TIP]TIP1
      If [TIP]TYPPGN = 1 & FLGDAT(I) & (DATDAT(WINDDEBARR)= [00/00/00] | (DATDAT(WINDDEBARR)+1 <> [F:TIP]STRDAT))Then
       WOKDEBARR=1
       # S'il y a une régul sur le code évènement TBDAT et date <= date de début de TIMEMP, on ne prend la date de début
       Filter [TIG] Where REFNUM=MATRI & [F:TIG]STRDAT<[F:TIP]STRDAT & TIM=TBDAT(I) & CTRNUM=CTR
       Read [TIG]TIG2 Last
       Filter [TIG]
       If !fstat
         If [F:TIP]STRDAT = ([F:TIG]ENDDAT+1)
          WOKDEBARR=0
         Endif
       Endif
       # S'il y a une saisie des temps < DATDEB sur le code évènement TBDAT et date <= date de début de TIMEMP, on ne prend la date de début
       Filter [TIP2] Where REFNUM=MATRI & [F:TIP2]STRDAT<[F:TIP]STRDAT & TIM=TBDAT(I) & CTRNUM=CTR & [F:TIP2]LIG <> [F:TIP]LIG
       Read [TIP2]TIP1 Last
       Filter [TIP2]
       If !fstat
         If [F:TIP]STRDAT = ([F:TIP2]ENDDAT+1)
            WOKDEBARR=0
         Endif
       Endif
       If WOKDEBARR
        FLGDAT(WINDDEBARR) = 1
        DATDAT(WINDDEBARR) = [F:TIP]STRDAT
       Endif
      Endif
     Next
     Filter [TIP]
   Endif
 Endif
Next I

If sum(FLGDAT(1..NBDAT))=0 : Return : Endif
GOK = 1
Trbegin [TID]
 Readlock [TID]TID0 = MATRI;CTR
 If fstat=1
  GOK = -1 : GLOCK = "$TIMEMPDAT"-MATRI-CTR : Goto ROLL_TR3
 Elsif fstat
  Raz [F:TID]
  [F:TID]REFNUM = MATRI
  [F:TID]CTRNUM = CTR
  Gosub SET_DATE
  Write [TID]
 Else
  Gosub SET_DATE
  Rewrite [TID]
 Endif
 If fstat
  GOK = 0 : Call FSTA("TID") From GLOCK : Goto AB_TR3
 Endif
Commit
Return

$SET_DATE
For I=1 To NBDAT
 If FLGDAT(I)
  Assign "[F:TID]DAT"+TBDAT(I) With DATDAT(I)
 Endif
Next I
Return

$AB_TR3
Rollback
Return

$ROLL_TR3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR3 : Endif

#######################################################################
## Mise à jour des variables
#######################################################################
$TR2A
GOK = 1
Trbegin [VRA]
  For [VRA]VRA0 Where TYPINI=4
#MIPEA - 2017-02-01- X3-12122- START
   Readlock [VLA]VLA0 = 4;GCURLEG;"";"";MATRI;DATPAY;[F:VRA]COD;[F:VEP]BUL
#   Readlock [VLA]VLA0 = 4;"";"";MATRI;DATPAY;[F:VRA]COD;[F:VEP]BUL
#MIPEA - 2017-02-01- X3-12122- END
   If fstat=1
    GOK = -1 : GLOCK="$VALEUR"-MATRI-num$(DATPAY)-[F:VRA]COD-[F:VEP]BUL : Break
   Elsif !fstat
    Raz [F:VLA]VARVAL
    Rewrite [VLA]
    If fstat
     GOK = 0 : Call FSTA("VLA") From GLOCK : Break
    Endif
    Delete [BCB] Where CODBLB="VARTXT" & IDENT1=[F:VRA]COD & IDENT2=[F:VEP]BUL
    If fstat=1 : GOK = -1 : GLOCK="$VARTXT"-[F:VRA]COD-[F:VEP]BUL : Break : Endif
   Endif
  Next
 If   GOK<0 : Goto ROLL_TR2A
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$ROLL_TR2A
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2A : Endif


$TR2
GOK = 1
 Trbegin [VRA]
 For [VRA]VRA0 Where [VRA]TYPINI=4
  VALEUR = 0
  TDAT   = ""
  Case [F:VRA]TYPMAJ
   When 1 : # Détail
    For T=1 To NBCOD
     If pat(TBCOD(T),[F:VRA]TIMCOD)
      Case [F:VRA]TYPVAL
       When 1 : # Jours
        Case [F:VRA]DAYTYP
         When 1 :
          For J=1 To MAXJOURS
           VALEUR += J_OUVRA(T,J)
          Next J
          VALEUR += REG_J_OUVRA(T)
         When 2 :
          For J=1 To MAXJOURS
           VALEUR += J_OUVRE(T,J)
          Next J
          VALEUR += REG_J_OUVRE(T)
         When 3 :
          For J=1 To MAXJOURS
           VALEUR += J_CALEN(T,J)
          Next J
          VALEUR += REG_J_CALEN(T)
         When Default :
          For J=1 To MAXJOURS
           VALEUR += JRS_VAR(T,J)
          Next J
          VALEUR += REG_JRS_VAR(T)
         Endcase
       When 2 : # Heures
        ##64941
        Case [F:VRA]DAYTYP
         When 1 :
          For J=1 To MAXJOURS
           VALEUR += H_OUVRA(T,J)
          Next J
          VALEUR += REG_H_OUVRA(T)
         When 2 :
          For J=1 To MAXJOURS
           VALEUR += H_OUVRE(T,J)
          Next J
          VALEUR += REG_H_OUVRE(T)
         When 3 :
          For J=1 To MAXJOURS
           VALEUR += H_CALEN(T,J)
          Next J
          VALEUR += REG_H_CALEN(T)
        ##
         When Default :
          For J=1 To MAXJOURS
           VALEUR += HRE_VAR(T,J)
          Next J
          VALEUR += REG_HRE_VAR(T)
        Endcase
       When 3 : # Qté1
        For J=1 To MAXJOURS
         VALEUR += Q1_VAR(T,J)
        Next J
        VALEUR += REG_Q1_VAR(T)
       When 4 : # Qté2
        For J=1 To MAXJOURS
         VALEUR += Q2_VAR(T,J)
        Next J
        VALEUR += REG_Q2_VAR(T)
        When 5 : #Prolongations
        VALEUR = TYPPGN(T)
      Endcase
      TDAT = DAT_COD(T)
     Endif
    Next T
    For T2=1 To NBNAT
     If pat(TBNAT(T2),[F:VRA]NATCOD)
      Case [F:VRA]TYPVAL
       When 1 : # Jours
        For J=1 To MAXJOURS
         VALEUR += JRS_VAR_NAT(T2,J)
        Next J
        VALEUR += REG_JRS_VAR_NAT(T2)
       When 2 : # Heures
        For J=1 To MAXJOURS
         VALEUR += HRE_VAR_NAT(T2,J)
        Next J
        VALEUR += REG_HRE_VAR_NAT(T2)
       When 3 : # Qté1
        For J=1 To MAXJOURS
         VALEUR += Q1_VAR_NAT(T2,J)
        Next J
        VALEUR += REG_Q1_VAR_NAT(T2)
       When 4 : # Qté2
        For J=1 To MAXJOURS
         VALEUR += Q2_VAR_NAT(T2,J)
        Next J
        VALEUR += REG_Q2_VAR_NAT(T2)
      Endcase
      TDAT = DAT_NAT(T2)
     Endif
    Next T2
   When 2 : # Récapitulatif
    # Pour chaque semaine du mois de paie, on a défini la période d'activité correspondante.
    # On ne doit donc cumuler que les valeurs de la bonne période d'activité
    [V]GPE = 0
    GPOINT = "UPDRECAP" : Gosub ENTREE From EXEFNC
    If ![V]GPE
     For I=0 To dim([F:TIR]CTRDAT)-1
      #Le critère n'est plus sur la date exacte, mais sur une fourchette de dates (STRCTRDAT et CTRDAT) pour gérer
      #la consolidation des bulletins
      If [F:TIR]CTRDAT(I)<>[0/0/0] & [F:TIR]CTRDAT(I)>=[F:VEP]STRCTRDAT & [F:TIR]CTRDAT(I)<=[F:VEP]CTRDAT Then
        VALEUR += evalue("[F:TIR]"+[F:VRA]TIMVAR+"("+num$(I)+")")
      Endif
     Next
     TDAT = format$("D:DD[/]MM",DATDEB)+"-"+format$("D:DD[/]MM",DATFIN)
   Endif
   When 3 : # formule
    Onerrgo RIEN
    ERR = 0
    VALEUR = evalue([F:VRA]FORVAR)
    Onerrgo
  Endcase
  VARIA = [F:VRA]COD
  ACTION = "VARIA" : Gosub ACTION
  If VALEUR<>0 or TDAT<>""
   If [F:ADI]CODE<>[F:VRA]PAGEMP
#MIPEA - 2017-02-01- X3-12122- START
    Read [ADI]CODE = 10337;[F:VRA]PAGEMP
#    Read [ADI]CODE = 337;[F:VRA]PAGEMP
#MIPEA - 2017-02-01- X3-12122- END
   Endif
   ARRONDI = 10^(-[F:ADI]N1)
   VALEUR = arr(VALEUR,ARRONDI)
#MIPEA - 2017-02-01- X3-12122- START
   Read [VLA]VLA0 = 4;"";"";"";MATRI;DATPAY;[F:VRA]COD;[F:VEP]BUL
#   Read [VLA]VLA0 = 4;"";"";MATRI;DATPAY;[F:VRA]COD;[F:VEP]BUL
#MIPEA - 2017-02-01- X3-12122- END
   If fstat=1
    GOK = -1 : GLOCK = "$VALEUR"-MATRI-[F:VRA]COD : Break
   Elsif fstat
    Raz [F:VLA]
    [F:VLA]TYP    = 4
    [F:VLA]VARCOD = [F:VRA]COD
    [F:VLA]BUL    = [F:VEP]BUL
    [F:VLA]EMP    = MATRI
    [F:VLA]DAT    = DATPAY
    [F:VLA]VARVAL = VALEUR
    Write [VLA]
   Else
    [F:VLA]VARVAL = VALEUR
    Rewrite [VLA]
   Endif
   If fstat
    GOK = 0 : Call FSTA("VLA") From GLOCK : Break
   Endif

#MIPEA - 2017-08-15- US X3-39538- START
    Local Integer INDLVESUB : INDLVESUB=0
    If func AFNC.ACTIV("GLM")
    Local Char RATEDES(100) : RATEDES=""

      If [F:VRA]LVESUBTYP<>""
        VALEUR=0

        For I=1 To 1000
          If SUBTYPESPLIT(I,1)=''
            Break
          Endif
          If SUBTYPESPLIT(I,1)=[F:VRA]TIMCOD
&          & SUBTYPESPLIT(I,2)=[VRA]LVESUBTYP
&          & num$(SUBTYPESPLIT(I,3))=num$([VRA]LVESUBRAT)
            VALEUR += val(SUBTYPESPLIT(I,4))
          Endif
        Next

#Writing VLA if the are values for the specific leave sub type as linked on the variable
        If VALEUR<>0 or TDAT<>""
          INDLVESUB=1
###          If [F:ADI]CODE<>[F:VRA]PAGEMP
###            Read [ADI]CODE = 10337;[F:VRA]PAGEMP
###          Endif
###          ARRONDI = 10^(-[F:ADI]N1)
          VALEUR = arr(VALEUR,ARRONDI)

          Read [VLA]VLA0 = 4;"";"";"";MATRI;DATPAY;[F:VRA]COD;[F:VEP]BUL
          If fstat=1
            GOK = -1 : GLOCK = "$VALEUR"-MATRI-[F:VRA]COD : Break
          Elsif fstat
            Raz [F:VLA]
            [F:VLA]TYP    = 4
            [F:VLA]VARCOD = [F:VRA]COD
            [F:VLA]BUL    = [F:VEP]BUL
            [F:VLA]EMP    = MATRI
            [F:VLA]DAT    = DATPAY
            [F:VLA]VARVAL = VALEUR
            Write [VLA]
          Else
            [F:VLA]VARVAL = VALEUR
            Rewrite [VLA]
          Endif
          If fstat
            GOK = 0 : Call FSTA("VLA") From GLOCK : Break
          Endif
        Endif
      Endif
    Endif
#MIPEA - 2017-08-15- US X3-39538- END
   TEXTE = ""
   If [F:VRA]TIMCMT<>"" or [F:VRA]CMTDET=2
    If [F:VRA]TIMCMT<>""
     Onerrgo RIEN
     ERR = 0
     TEXTE = evalue([F:VRA]TIMCMT)
     Onerrgo
    Endif
    Delete [BCB] Where CODBLB="VARTXT" & IDENT1=[F:VRA]COD & IDENT2=[F:VEP]BUL
    If fstat=1
     GOK = -1 : GLOCK = "$BCLOB VARTXT"-[F:VRA]COD-MATRI : Break
    Endif
    Filter [RUB] Where TEXVRI(0)=[F:VRA]COD or TEXVRI(1)=[F:VRA]COD
    For [RUB]RUB0
     Raz MESSAGE
     Raz [F:BCB]
     [F:BCB]CODBLB = "VARTXT"
     [F:BCB]IDENT1 = [F:VRA]COD
     [F:BCB]IDENT2 = [F:VEP]BUL
     [F:BCB]IDENT3 = ""
     [F:BCB]IDENT4 = [F:RUB]COD
     If dim([F:BCB]CREUSR)>0 : [F:BCB]CREUSR = GUSER : Endif
     If dim([F:BCB]CREDAT)>0 : [F:BCB]CREDAT = date$ : Endif
     If dim([F:BCB]CRETIM)>0 : [F:BCB]CRETIM = time  : Endif
     If !ERR & TEXTE<>"" : MESSAGE=TEXTE : Endif
     If [F:VRA]CMTDET=2
      For T=1 To NBCOD
       If pat(TBCOD(T),[F:VRA]TIMCOD)
        J = 1
        While J<=NBR_CMT(T)
         If J=1 | (J>1 & CMT_COD(T,J-1)<>CMT_COD(T,J))
          If MESSAGE=""
           MESSAGE=CMT_COD(T,J)
          Else
           MESSAGE-=CMT_COD(T,J)
          Endif
         Endif
         J += 1
        Wend
       Endif
      Next T
      For T2=1 To NBNAT
       If pat(TBNAT(T2),[F:VRA]NATCOD)
        J = 1
        While J<=NBR_CMT_NAT(T2)
         MESSAGE-=CMT_NAT(T2,J)
         J += 1
        Wend
       Endif
      Next T2
     Endif
     #107270 : Ajout PE pour gérer les jours de carence sur le bulletin de paie - MHE
     [V]GPE = 0
     GPOINT = "DATCAR" : Gosub ENTREE From EXEFNC
     If [V]GPE=1 : GOK=0 : Break 2 : Endif
     If MESSAGE<>""
      Setlob [F:BCB]CLOB With MESSAGE
      Write [BCB]
      If fstat
       GOK = 0 : Call FSTA("BCB") From GLOCK : Break 2
      Endif
     Endif
    Next
    Filter [RUB]
   Endif
   If DETAIL
    If GTRACE<>""
#MIPEA - 2017-02-01- X3-12122- START
#MIPEA - 2017-08-17- US X3-39538- START
      If INDLVESUB<>0
        If !clalev([HRLSTH]) : Local File HRLVESUBHEA [HRLSTH] : Endif
        Read [HRLSTH]HRLST0 = GCURLEG;[F:VRA]LVESUBTYP
        RATEDES = [F:HRLSTH]LVEPAYDES([F:VRA]LVESUBRAT-1)
        Call ECR_TRACE(MATRI-":"-mess(25,10709,1)-[F:VRA]COD-"-"-[F:VRA]LVESUBTYP-"-"-RATEDES-":"-num$([F:VLA]VARVAL)-TEXTE,0) From GESECRAN
      Else
        Call ECR_TRACE(MATRI-":"-mess(25,10709,1)-[F:VRA]COD-":"-num$([F:VLA]VARVAL)-TEXTE,0) From GESECRAN
      Endif
#     Call ECR_TRACE(MATRI-":"-mess(25,10709,1)-[F:VRA]COD-":"-num$([F:VLA]VARVAL)-TEXTE,0) From GESECRAN
#MIPEA - 2017-08-17- US X3-39538- END
#     Call ECR_TRACE(MATRI-":"-mess(25,709,1)-[F:VRA]COD-":"-num$([F:VLA]VARVAL)-TEXTE,0) From GESECRAN
#MIPEA - 2017-02-01- X3-12122- END
#    Mise à jour variable
    Endif
   Endif
  Endif
 Next

 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$RIEN
ERR = errn
Resume

#######################################################################
## Lecture d'une variable
#######################################################################
$SET_VAR
#MIPEA - 2017-02-01- X3-12122- START
Read [VLA]VLA0 = 4;"";"";"";MATRI;DATPAY;VARIA;[F:VEP]BUL
#Read [VLA]VLA0 = 4;"";"";MATRI;DATPAY;VARIA;[F:VEP]BUL
#MIPEA - 2017-02-01- X3-12122- END
If !fstat
 VALEUR = [F:VLA]VARVAL : Return
Endif
Filter [VFC] Where FCY=SITE & DAT<=DATPAY
Read [VFC]VFC0 Last
Filter [VFC]
If fstat<=2
#MIPEA - 2017-02-01- X3-12122- START
 Read [VLA]VLA0 = 3;"";"";SITE;"";[F:VFC]DAT;VARIA;""
# Read [VLA]VLA0 = 3;"";SITE;"";[F:VFC]DAT;VARIA;""
 #MIPEA - 2017-02-01- X3-12122- END
 If !fstat
  VALEUR = [F:VLA]VARVAL : Return
 Endif
Endif
Filter [VCP] Where CPY=SOCIETE & DAT<=DATPAY
Read [VCP]VCP0 Last
Filter [VCP]
If !fstat
#MIPEA - 2017-02-01- X3-12122- START
 Read [VLA]VLA0 = 2;"";SOCIETE;"";"";[F:VCP]DAT;VARIA;""
# Read [VLA]VLA0 = 2;SOCIETE;"";"";[F:VCP]DAT;VARIA;""
#MIPEA - 2017-02-01- X3-12122- END
 If !fstat
  VALEUR = [F:VLA]VARVAL : Return
 Endif
Endif
Filter [VFD] Where DAT<=DATPAY
Read [VFD]VFD0 Last
Filter [VFD]
If !fstat
#MIPEA - 2017-02-01- X3-12122- START
 Read [VLA]VLA0 = 1;GCURLEG;"";"";"";[F:VFD]DAT;VARIA;""
# Read [VLA]VLA0 = 1;"";"";"";[F:VFD]DAT;VARIA;""
 #MIPEA - 2017-02-01- X3-12122- END
 If !fstat
  VALEUR = [F:VLA]VARVAL : Return
 Endif
Endif
VALEUR = 0
Return

#######################################################################
## Mise à jour du bulletin calendrier
#######################################################################
$TR4
GOK = 1
Trbegin [BUL]

   #**
   #Readlock [BUL]BUL0 = MATRI;DATPAY;[F:VEP]BUL
   Readlock [BUL]BUL0 = MATRI;[F:VEP]PYRDAT;[F:VEP]BUL

   If fstat=1
    GOK = -1 : GLOCK = "$BULCAL"-MATRI : Goto ROLL_TR4
   Elsif fstat
    Raz [F:BUL]
    [F:BUL]BUL    = [F:VEP]BUL
    [F:BUL]REFNUM = MATRI
   #**
    #[F:BUL]PYRDAT = DATPAY
    [F:BUL]PYRDAT = [F:VEP]PYRDAT

    ACTION = "BULCAL" : Gosub ACTION
    Write [BUL]
   Else
    ACTION = "BULCAL" : Gosub ACTION
    Rewrite [BUL]
   Endif
 If fstat
  GOK = 0 : Call FSTA("BUL") From GLOCK : Goto AB_TR4
 Endif
Commit
Return

$AB_TR4
Rollback
Return

$ROLL_TR4
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR4 : Endif

#######################################################################
## Mise à jour dans TIMREGUL de la zone DATBUL
#######################################################################
$TR5
GOK = 1
Trbegin [TIG]
WJ_DATBUL=0 :# 88381
 Gosub FILTRE_VEP From TRTTPS
 # On peut avoir un bulletin par période d'activité ; il faut donc, pour chaque événement, trouver
 # le bulletin qui lui correspond
 #MIPEA - 2017-02-01- X3-12122- START
  Filter [VEP] Where EMP=MATRI & PYRDAT=[F:HRPEOD]PYRDAT & CTRNUM=CTR & evalue([L]CRITERED_VEP) & evalue(CRITVEP)
# Filter [VEP] Where EMP=MATRI & PYRDAT=[F:PEO]PYRDAT & CTRNUM=CTR & evalue([L]CRITERED_VEP) & evalue(CRITVEP)
 #MIPEA - 2017-02-01- X3-12122- END
 Read [VEP]VEP0 Last
 Filter [VEP]
 If !fstat & [F:VEP]PST<=1
& &  [F:VEP]FLGLOCK<=1 : # Verrouillé
  # FQ105844 - 24/02/15 - La sélection des réguls à mettre à jour doit être identique à celle qui est faite lors du parcours
  # des réguls dans le traitement principal (fait après l'appel du TR5, ce qui explique qu'on n'a pas ici le filtre sur les
  # WFLG_DATBUL)
#JASMI - 2017-02-01 - Issue 121325 - START
#MIPEA - 2017-02-09- X3-11284- START
#  For [TIG]TIG1 Where REFNUM=MATRI & CTRNUM=CTR & evalue(CRITERED)
#&                     & (DATPYR=[F:HRPEOD]PYRDAT
#&                     & (!VRA | (VRA & ([F:TIG]DATBUL=[0/0/0] | [F:TIG]DATBUL=[F:TIG]DATPYR))))
#  For [TIG]TIG1 Where REFNUM=MATRI & CTRNUM=CTR & evalue(CRITERED)
#&                     & (DATPYR=[F:PEO]PYRDAT
#&                     & (!VRA | (VRA & ([F:TIG]DATBUL=[0/0/0] | [F:TIG]DATBUL=[F:TIG]DATPYR))))
#MIPEA - 2017-02-09- X3-11284- END
  For [TIG]TIG1 Where REFNUM=MATRI & CTRNUM=CTR & evalue(CRITERED)
&                     & evalue([L]CRITPEO)
&                     & (!VRA | (VRA & (([F:TIG]DATBUL=[0/0/0] | [F:TIG]DATBUL=[F:VEP]PYRDAT) & ([F:TIG]BUL="" | [F:TIG]BUL=[F:VEP]BUL))))
#JASMI - 2017-02-01 - Issue 121325 - END
   Readlock [F:TIG]=
   If fstat=1
    GOK = -1 : GLOCK = "$TIMREGUL"-MATRI-CTR-num$([F:TIG]STRDAT) : Break
   Else
 #MIPEA - 2017-02-01- X3-12122- START
 #
 #LIPET - 2017-04-10 - X3-32083 - START
    #[F:TIG]DATBUL = [F:HRPEOD]PYRDAT
    If [F:TIG]DATBUL=[0/0/0]
      [F:TIG]BUL    = [F:VEP]BUL
      [F:TIG]DATBUL = [F:VEP]PYRDAT
    Endif
#LIPET - 2017-04-10 - X3-32083 - END
#    [F:TIG]DATBUL = [F:PEO]PYRDAT
 #MIPEA - 2017-02-01- X3-12122- END
#MIPEA - 2017-02-01- X3-12122- START
#LIPET - 2017-04-10 - X3-32083 - START
#    If [F:TIG]DATPYR <> [F:HRPEOD]PYRDAT & WJ_DATBUL < dim(WFLG_DATBUL)
#    If [F:TIG]DATPYR <> [F:PEO]PYRDAT & WJ_DATBUL < dim(WFLG_DATBUL)
#MIPEA - 2017-02-01- X3-12122- END
#       WFLG_DATBUL(WJ_DATBUL)=[F:TIG]LIG :# Test si REGUL déjà passé en paye
#       WJ_DATBUL+=1
#    Endif
    If !PREADJ
      If [F:TIG]DATPYR <> [F:HRPEOD]PYRDAT & WJ_DATBUL < dim(WFLG_DATBUL)
         WFLG_DATBUL(WJ_DATBUL)=[F:TIG]LIG :# Test si REGUL déjà passé en paye
         WJ_DATBUL+=1
      Endif
    Endif
#LIPET - 2017-04-10 - X3-32083 - END
    Rewrite [TIG]
    If fstat
     GOK = 0 : Call FSTA("TIG") From GLOCK : Break
    Endif
   Endif
  Next
 Endif
 If GOK=-1
  Goto ROLL_TR5
 Elsif GOK=0
  Goto AB_TR5
 Endif
Commit
Return

$AB_TR5
Rollback
Return

$ROLL_TR5
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR5 : Endif

#JASMI - 2017-09-05 - START
$ADD_TO_SUBTYPE_ARRAY_TIP
Local Integer SUBTYPECOUNT

  For SUBTYPECOUNT = 0 To dim([TIP]LVESUBTYP)-1
    If [TIP]LVESUBTYP(SUBTYPECOUNT)<>''
      For I = 1 To 1000
        If SUBTYPESPLIT(I,1)=''
          SUBTYPESPLIT(I,1)=[TIP]TIM
          SUBTYPESPLIT(I,2)=[TIP]LVESUBTYP(SUBTYPECOUNT)
          SUBTYPESPLIT(I,3)=num$([TIP]LVESUBRAT(SUBTYPECOUNT))
          SUBTYPESPLIT(I,4)=num$([TIP]LVESUBBAL(SUBTYPECOUNT))
          Break
        Else
          If SUBTYPESPLIT(I,1)=[TIP]TIM
&          & SUBTYPESPLIT(I,2)=[TIP]LVESUBTYP(SUBTYPECOUNT)
&          & num$(SUBTYPESPLIT(I,3))=num$([TIP]LVESUBRAT(SUBTYPECOUNT))
            SUBTYPESPLIT(I,4)=num$(val(SUBTYPESPLIT(I,4))+[TIP]LVESUBBAL(SUBTYPECOUNT))
            Break
          Endif
        Endif
      Next
    Endif
  Next

Return

$ADD_TO_SUBTYPE_ARRAY_TIG
Local Integer SUBTYPECOUNT
  For SUBTYPECOUNT = 0 To dim([TIG]LVESUBTYP)-1
    If [TIG]LVESUBTYP(SUBTYPECOUNT)<>''
      For I = 1 To 1000
        If SUBTYPESPLIT(I,1)=''
          SUBTYPESPLIT(I,1)=[TIG]TIM
          SUBTYPESPLIT(I,2)=[TIG]LVESUBTYP(SUBTYPECOUNT)
          SUBTYPESPLIT(I,3)=num$([TIG]LVESUBRAT(SUBTYPECOUNT))
          SUBTYPESPLIT(I,4)=num$([TIG]LVESUBBAL(SUBTYPECOUNT))
          Break
        Else
          If SUBTYPESPLIT(I,1)=[TIG]TIM
&          & SUBTYPESPLIT(I,2)=[TIG]LVESUBTYP(SUBTYPECOUNT)
&          & num$(SUBTYPESPLIT(I,3))=num$([TIG]LVESUBRAT(SUBTYPECOUNT))
            SUBTYPESPLIT(I,4)=num$(val(SUBTYPESPLIT(I,4))+[TIG]LVESUBBAL(SUBTYPECOUNT))
            Break
          Endif
        Endif
      Next
    Endif
  Next

Return
#JASMI - 2017-09-05 - END

