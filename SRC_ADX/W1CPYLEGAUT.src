#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGAUT 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:31"
A_USER  = "DOC"
A_STAMP = "20181109230331"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CPYLEGAUT [CLAUT]
Gosub HORODAT
Local Inpbox "CPYLEGAUT" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLAUT] As [SIM_]
Grizo [CLAUT]5
Grizo [CLAUT]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CLAUT]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=19 : X2(0)=93 : Y1(0)=8 : Y2(0)=9
X1(1)=19 : X2(1)=93 : Y1(1)=10 : Y2(1)=21
Return

$ON_NBLIG
Onevent CONTROL Call C_NBLIG From W1CPYLEGAUT
Return

Subprog C_NBLIG
Local Decimal BASPAG
## Action STD
Call C_NBLIG From TRTCPYLEGAUT
If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_GERDEFVAL
Onevent BEFORE_INPUT Call AS_GERDEFVAL(zc) From W1CPYLEGAUT
Onevent AFTER_CHANGE Gosub AMM_GERDEFVAL From W1CPYLEGAUT
Onevent INIT_AREA Call D_GERDEFVAL(zc) From W1CPYLEGAUT
Return

Subprog D_GERDEFVAL(VALEUR)
Variable Integer VALEUR
If varinit([M]GERDEFVAL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_GERDEFVAL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_GERDEFVAL(VALEUR) From TRTCPYLEGAUT
If mkstat=2
 [M]GERDEFVAL(INDIC) = VALEUR
 Affzo GERDEFVAL(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_GERDEFVAL
Call AM_GERDEFVAL(zc)
If !mkstat & GOBJET
 zoncou = "GERDEFVAL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_GERDEFVAL(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_GERDEFVAL(VALEUR) From TRTCPYLEGAUT
If mkstat : GERR = 1 : GZONE = "GERDEFVAL" : GZNUM = 88 : Endif
Gosub _AFF
End

$ON_GEREECNUM
Onevent BEFORE_AREA Gosub AV_GEREECNUM From W1CPYLEGAUT
Onevent CONTROL Call C_GEREECNUM(zc) From W1CPYLEGAUT
Return

$AV_GEREECNUM
## Action FMTEECPAY
Call FMTEECPAY([F:CPY]CRY) From TRTDIV
## Action ASAIEEC
If [F:TCY]EECFMTFLG<>2 : Grizo =zoncou : mkstat = 1 : Else : Actzo =zoncou : Endif
If GFMT<>""
 Chgfmt [M]GEREECNUM(indice) With "K:"+GFMT
Else
 Chgfmt [M]GEREECNUM(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog C_GEREECNUM(VALEUR)
Variable Char    VALEUR()
## Action CONTTVA
Call CONTTVA(VALEUR,[F:CPY]CRY) From CONTNUM
If mkstat : GERR = 1 : GZONE = "GEREECNUM" : GZNUM = 4145 : Endif
If !mkstat
 ## Action STD
 Call C_GEREECNUM(VALEUR) From TRTCPYLEGAUT
 If mkstat : GERR = 1 : GZONE = "GEREECNUM" : GZNUM = 4145 : Endif
Endif
Gosub _AFF
End

$ON_GERTAXCEN
Onevent CONTROL Call C_GERTAXCEN(zc) From W1CPYLEGAUT
Onevent BEFORE_INPUT Call AS_GERTAXCEN(zc) From W1CPYLEGAUT
Onevent AFTER_CHANGE Gosub AMM_GERTAXCEN From W1CPYLEGAUT
Return

Subprog AS_GERTAXCEN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1500,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_GERTAXCEN(zc) From W1CPYLEGAUT
Onkey   2 Titled GBOUTS Call S_GERTAXCEN(zc) From W1CPYLEGAUT
Onkey 144 Titled GBOUTP Call P_GERTAXCEN(zc) From W1CPYLEGAUT
Onkey 146 Titled GBOUTA Call SA_GERTAXCEN(zc) From W1CPYLEGAUT
Gosub _AFF
End

Subprog C_GERTAXCEN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BPRCHOICE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BPRCHOICE"
 Call S_TAB_CHAR(VALEUR,PARMSK,"BPRCHOICE","TRTSEL","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "GERTAXCEN" : GZNUM = 13507 : Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("BPR","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "GERTAXCEN" : GZNUM = 13507 : Endif
Endif
Gosub _AFF
End

$AMM_GERTAXCEN
Call AM_GERTAXCEN(zc)
If !mkstat & GOBJET
 zoncou = "GERTAXCEN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_GERTAXCEN(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZGERTAXCEN)")>indice
 [M]GERTAXCEN(indice) = VALEUR
 Affzo ZGERTAXCEN(indice)
Endif
Gosub _AFF
End

Subprog S_GERTAXCEN(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "BPR"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_GERTAXCEN(VALEUR)
Variable Char    VALEUR()
Call OBJET("BPR",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_GERTAXCEN(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "BPR"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_GERTAXCEN(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("BPR",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZGERTAXCEN
Onevent BEFORE_AREA Gosub AV_ZGERTAXCEN From W1CPYLEGAUT
Return

$AV_ZGERTAXCEN
If clalev([F:BPR])=0
 If dim(GTABCPT)>0 & GTABCPT<>"" & find("BPR",GABRCPT(1..GNBTABCPT))
  Local File =GTABCPT+"BPARTNER" [BPR]
 Else 
  Local File BPARTNER [BPR]
 Endif
Endif
Call LECTURE("BPR",num$([M]GERTAXCEN(indice)),"") From CONTOBJ
zc = [F:BPR]BPRNAM
Gosub _AFF
Return

$CHG_STY
Return


