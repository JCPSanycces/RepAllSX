Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZTYPFRM2)")>indice
 [M]TYPFRM2(indice) = VALEUR
 Affzo ZTYPFRM2(indice)
Endif
Gosub _AFF
End

Subprog S_TYPFRM2(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10376"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_TYPFRM2(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10376") From GOBJET
Gosub _AFF
End

Subprog SA_TYPFRM2(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10376"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TYPFRM2(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10376"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZTYPFRM2
Onevent BEFORE_AREA Gosub AV_ZTYPFRM2 From W1ORG3
Return

$AV_ZTYPFRM2
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10376",num$([M]TYPFRM2(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_NBRLIG
Onevent BEFORE_INPUT Call AS_NBRLIG From W1ORG3
Return

Subprog AS_NBRLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBRLIG From SUBORG
Gosub _AFF
End

$ON_GRPORG
Onevent CONTROL Call C_GRPORG(zc) From W1ORG3
Onevent BEFORE_INPUT Call AS_GRPORG(zc) From W1ORG3
Onevent AFTER_CHANGE Gosub AMM_GRPORG From W1ORG3
Return

Subprog AS_GRPORG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(46228,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_GRPORG(zc) From W1ORG3
Onkey   2 Titled GBOUTS Call S_GRPORG(zc) From W1ORG3
Onkey 144 Titled GBOUTP Call P_GRPORG(zc) From W1ORG3
Onkey 146 Titled GBOUTA Call SA_GRPORG(zc) From W1ORG3
Gosub _AFF
End

Subprog C_GRPORG(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "GRPORG" : GZNUM = 35085 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "GRPORG" : GZNUM = 35085 : Endif
 If !mkstat
  ## Action CONTORG
  Call CONTORG(VALEUR) From SUBORG
  If mkstat : GERR = 1 : GZONE = "GRPORG" : GZNUM = 35085 : Endif
  If !mkstat
   ## Action STD
   Call C_GRPORG(VALEUR) From SUBORG
   If mkstat : GERR = 1 : GZONE = "GRPORG" : GZNUM = 35085 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_GRPORG
Call AM_GRPORG(zc)
If !mkstat & GOBJET
 zoncou = "GRPORG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_GRPORG(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZGRPORG)")>indice
 [M]GRPORG(indice) = VALEUR
 Affzo ZGRPORG(indice)
Endif
Gosub _AFF
End

Subprog S_GRPORG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELORG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELORG"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELORG","SUBORG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_GRPORG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNORG
 Call TUNORG(VALEUR) From SUBORG
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_GRPORG(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ORG"
PARMSK(2) = num$(GCURLEG)
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_GRPORG(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("ORG",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZGRPORG
Onevent BEFORE_AREA Gosub AV_ZGRPORG From W1ORG3
Return

$AV_ZGRPORG
Call LECTEXTRA(zc,"ORGANISME","DES",num$(GCURLEG),num$([M]GRPORG(indice))) From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


