#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ORG3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:14:31"
A_USER  = "DOC"
A_STAMP = "20181109231431"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRLIG"
  If [M]NBRLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ORG3 [ORG3]
Gosub HORODAT
Local Inpbox "ORG3" From GFONCTION At A_STAMP With A_WINDPREV Mask [ORG3] As [SIM_]
Grizo [ORG3]5
Grizo [ORG3]15
Grizo [ORG3]20
Grizo [ORG3]25
Grizo [ORG3]30
Grizo [ORG3]35
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ORG3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=39 : Y1(0)=1 : Y2(0)=3
X1(1)=40 : X2(1)=74 : Y1(1)=1 : Y2(1)=3
X1(2)=1 : X2(2)=39 : Y1(2)=4 : Y2(2)=7
X1(3)=1 : X2(3)=39 : Y1(3)=8 : Y2(3)=11
X1(4)=40 : X2(4)=74 : Y1(4)=8 : Y2(4)=11
X1(5)=1 : X2(5)=74 : Y1(5)=12 : Y2(5)=25
Return

$ON_KEYORG
Onevent CONTROL Call C_KEYORG(zc) From W1ORG3
Onevent AFTER_CHANGE Gosub AMM_KEYORG From W1ORG3
Onevent INIT_AREA Call D_KEYORG(zc) From W1ORG3
Onevent BEFORE_INPUT Call AS_KEYORG(zc) From W1ORG3
Return

Subprog D_KEYORG(VALEUR)
Variable Integer VALEUR
If varinit([M]KEYORG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_KEYORG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_KEYORG(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "KEYORG" : GZNUM = 680 : Endif
If !mkstat
 ## Action STD
 Call C_KEYORG(VALEUR) From SUBORG
 If mkstat : GERR = 1 : GZONE = "KEYORG" : GZNUM = 680 : Endif
Endif
Gosub _AFF
End

$AMM_KEYORG
Call AM_KEYORG(zc)
If !mkstat & GOBJET
 zoncou = "KEYORG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_KEYORG(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_KEYORG(VALEUR) From SUBORG
If mkstat : GERR = 1 : GZONE = "KEYORG" : GZNUM = 680 : Endif
Gosub _AFF
End

$ON_LIBKEYORG
Onevent CONTROL Call C_LIBKEYORG(zc) From W1ORG3
Return

Subprog C_LIBKEYORG(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LIBKEYORG" : GZNUM = 11117 : Endif
Gosub _AFF
End

