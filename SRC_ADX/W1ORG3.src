Subprog D_TYPFRM0(VALEUR)
Variable Char    VALEUR()
If varinit([M]TYPFRM0,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10374","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_TYPFRM0(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10374") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_TYPFRM0(zc) From W1ORG3
Onkey   2 Titled GBOUTS Call S_TYPFRM0(zc) From W1ORG3
Onkey 144 Titled GBOUTP Call P_TYPFRM0(zc) From W1ORG3
Onkey 146 Titled GBOUTA Call SA_TYPFRM0(zc) From W1ORG3
Gosub _AFF
End

Subprog C_TYPFRM0(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10374","") From SUBADI
If mkstat : GERR = 1 : GZONE = "TYPFRM0" : GZNUM = 7469 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10374",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "TYPFRM0" : GZNUM = 7469 : Endif
Endif
Gosub _AFF
End

$AMM_TYPFRM0
Call AM_TYPFRM0(zc)
If !mkstat & GOBJET
 zoncou = "TYPFRM0" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TYPFRM0(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZTYPFRM0)")>indice
 [M]TYPFRM0(indice) = VALEUR
 Affzo ZTYPFRM0(indice)
Endif
Gosub _AFF
End

Subprog S_TYPFRM0(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10374"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_TYPFRM0(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10374") From GOBJET
Gosub _AFF
End

Subprog SA_TYPFRM0(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10374"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TYPFRM0(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10374"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZTYPFRM0
Onevent BEFORE_AREA Gosub AV_ZTYPFRM0 From W1ORG3
Return

$AV_ZTYPFRM0
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10374",num$([M]TYPFRM0(indice))) From ATEXTRA
Gosub _AFF
Return

