#--------------------------------------------------------------------------------------
#Read GACCDENCOD table for a given code and legislation
#Table GACCDENCOD should be declared previously
#--------------------------------------------------------------------------------------
Subprog LEC_CDA_LEG(LEG,CDA,GRET)
Value Char  LEG
