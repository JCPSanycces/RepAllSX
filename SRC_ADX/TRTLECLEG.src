#-----------------------------------------------------------------------------------------------#
#-- Lit la table TABSQHTYP en fonction de la législation (Avec héritage) passée en paramètre
#-- La table TABSQHTYP doit être ouverte par l'appelant

#-----------------------------------------------------------------------------------------------#
Subprog LEC_TSQ_LEG(LEG,TSQ,GRET)
Value Char  LEG
Value Char  TSQ
Variable Integer GRET

  # FGR 20/02/2015 : X3SUIVI104383
  fstat = 0
  GRET = 0
  If GNBLEG = 1 Then
    LEG = GDOSLEG(1)
  Endif
  If [F:TSQ]SQHTYP <> TSQ | [F:TSQ]LEG <> LEG Then
    Read [TSQ]TSQ0=TSQ;LEG
    If fstat Then
      Read [TSQ]TSQ0=TSQ;""
    Endif
  Endif
  GRET = fstat
End

