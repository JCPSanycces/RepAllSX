Variable Integer GRET
fstat = 0
GRET=0
If GNBLEG=1 : LEG = GDOSLEG(1) : Endif
If [F:CDA]COD<>CDA | [F:CDA]LEG<>LEG
  Read [F:CDA]CDA0=CDA;LEG
  If fstat
   Read [F:CDA]CDA0=CDA;""
 Endif
Endif
GRET=fstat
End

