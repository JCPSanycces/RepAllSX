#--------------------------------------------------------------------------------------
#lit la table TABPAYTERM en fonction de la législation passée en paramètre
#La table TABPAYTERM doit être ouverte par l'appelant
#--------------------------------------------------------------------------------------
Subprog LEC_TPT_LEG(LEG,PTE,LIN,GRET)
Value  Char    LEG
Value  Char    PTE
Value  Integer LIN
Variable Integer GRET
fstat = 0
GRET=0
If GNBLEG=1 : LEG = GDOSLEG(1) : Endif
If [F:TPT]PTE<>PTE | [F:TPT]PTELIN<>LIN | [F:TPT]LEG<>LEG
 Read [TPT]TPT0 = PTE;LEG;LIN
 If fstat
  Read [TPT]TPT0 = PTE;"";LIN
 Endif
Endif
GRET=fstat
End


