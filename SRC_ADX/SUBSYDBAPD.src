#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
# Description transfert information rendez-vous  synchronisation Adonix-Outlook Module CRM     Avril 2006
##########################################################################################################
# BAP_INISETDSC : Initialisation variables description Outlook Adonix
# BAP_LD_SETDESC : Définition description Outlook Adonix
#
# BAP_INIGETDSC  : Initialisation variables description Adonix Outlook
# BAP_LD_GETDESC : Définition description Adonix Outlook
##########################################################################################################
##########################################################################################################
# paramétrage description
# - - - - - - - - -
# Nota:
#  <Line  Multi="N" Id="IdentKey">'
#   <X3 Cat="S"  />'
#   <OL Name="OlName" Cat="S" />'
#  </Line>'
#
#  *  <X3 Cat="S"  />'
#         Cette info n'est pas exploitée
#         Cat: Standard - User (perso)
#  * <OL Name="Subject" Cat="S" />
#         Cat: Standard - User (perso)
#  * <Line  Multi="N" ... >
#        Multi: Yes - No  -> Ligne pouvant généré plusieurs clés sous la forme: IdentKey_1 à IdentKey_n
#        L'Add-In standard a une gestion propre basé sur OlName pour traiter un Multi (ex: Contacts des taches)
#        - Pour l'instant, il n'est pas utilisable avec une categorie U <OL Name="OlName" Cat="U" />
#        - <Line Multi="N" ... > est égal à <Line   ... >
#  * <OL Name="OlName" Cat="U" UserType="xxx" />'
#        UserType va de pair avec Cat='U'
#        Pour l'instant, il est utilisé avec TbInt
#            - MC_TU_NB (défaut):    nombre  ("olNumber")
#            - MC_TU_YESNO:          oui/non ("olYesNo")
# Cas non gérés:
#  - multi='Y'
##########################################################################################################
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
# SENS OUTLOOK ADONIX
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
##########################################################################################################
# Déclaration variables  Outlook Adonix
# ------------------------------------------------------------
$BAP_INISETDSC
Local Char VERSION(GLONDES)

  VERSION="V00002"
Return

##########################################################################################################
# Pgrm BAP_LD_SETDESC : Définition description Outlook Adonix
$BAP_LD_SETDESC
  WI += 1 : WDSC(WI) = '<Description Trt="SUBSYDBAP" Subprog="BAP_SET" Version="' +VERSION+ '" AdxIdLib='+ GLIBCHRONOBAP + '>'
  # - - - -tableau de Char
  WI += 1 : WDSC(WI) = ' <TbChr Size="200" Dim="50">'
  WI += 1 : WDSC(WI) = '  <Line Id="Location">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Location" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbChr>'
  # - - - -Tableau d'entiers
  WI += 1 : WDSC(WI) = ' <TbInt Dim="30">'
  WI += 1 : WDSC(WI) = '  <Line  Id="AllDayEvent">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="AllDayEvent" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="Duration">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Duration" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbInt >'
  # - - - -Tableau de décimal
  WI += 1 : WDSC(WI) = ' <TbDec Dim="0">'
  WI += 1 : WDSC(WI) = ' </TbDec>'
  # - - - -Tableau de date
  WI += 1 : WDSC(WI) = ' <TbDate Dim="3">'
  WI += 1 : WDSC(WI) = '  <Line  Id="Start">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Start" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="End">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="End" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="LastModificationTime">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="LastModificationTime" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbDate >'
  # - - - -Tableau de clob
  WI += 1 : WDSC(WI) = ' <TbCClob Dim="2" Size="3">'
  WI += 1 : WDSC(WI) = '  <Line Id="Subject">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Subject" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="Body">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Body" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbCClob>'
  # - - - -Tableau de spécial
  WI += 1 : WDSC(WI) = ' <Special>'
  If GIBSYNCBAPGERECOR = MC_TRUE Then
    WI += 1 : WDSC(WI) = '   <Link Id="Lk">'
    WI += 1 : WDSC(WI) = '     <TbChr>'
    WI += 1 : WDSC(WI) = '       <Line Id="Name">'
    WI += 1 : WDSC(WI) = '         <X3 Cat="S" />'
    WI += 1 : WDSC(WI) = '         <OL Name="FullName" Cat="S" />'
    WI += 1 : WDSC(WI) = '       </Line>'
    WI += 1 : WDSC(WI) = '       <Line Id="CtAdxId">'
    WI += 1 : WDSC(WI) = '         <X3 Cat="S" />'
    WI += 1 : WDSC(WI) = '         <OL Name="AdxId" Cat="S" />'
    WI += 1 : WDSC(WI) = '       </Line>'
    WI += 1 : WDSC(WI) = '     </TbChr>'
    WI += 1 : WDSC(WI) = '     <TbInt>'
    WI += 1 : WDSC(WI) = '       <Line Id="HasContact">'
    WI += 1 : WDSC(WI) = '         <X3 Cat="S" />'
    WI += 1 : WDSC(WI) = '         <OL Name="" Cat="S" />'
    WI += 1 : WDSC(WI) = '       </Line>'
    WI += 1 : WDSC(WI) = '     </TbInt>'
    WI += 1 : WDSC(WI) = '   </Link>'
  Endif
  WI += 1 : WDSC(WI) = ' </Special>'
  WI += 1 : WDSC(WI) = '</Description>'
Return

#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
# SENS ADONIX OUTLOOK
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
##########################################################################################################
# Déclaration variables  Adonix Outlook
# ------------------------------------------------------------
$BAP_INIGETDSC
Local Char VERSION(GLONDES)

  VERSION="V00005"
Return

##########################################################################################################
# Définition description Adonix Outlook
# Structure LD
# ------------------------------------------------------------
$BAP_LD_GETDESC
  WI += 1 : WDSC(WI) = '<Description Trt="SUBSYDBAP" Subprog="BAP_GET" Version="' +VERSION+ '" AdxIdLib='+ GLIBCHRONOBAP + '>'
  # - - - -Tableau de char
  WI += 1 : WDSC(WI) = ' <TbChr Size="200" Dim="50">'
  WI += 1 : WDSC(WI) = '  <Line Id="Location">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Location" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbChr>'
  # - - - -Tableau d'entiers
  WI += 1 : WDSC(WI) = ' <TbInt Dim="30">'
  WI += 1 : WDSC(WI) = '  <Line Id="AdxRef">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="AdxRef" Cat="U" UserType=' + MC_TU_YESNO + '/>'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="Duration">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Duration" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="AllDayEvent" >'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="AllDayEvent" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbInt >'
  # - - - -tableau de décimal
  WI += 1 : WDSC(WI) = ' <TbDec Dim="0">'
  WI += 1 : WDSC(WI) = ' </TbDec>'
  # - - - -Tableau de date
  WI += 1 : WDSC(WI) = ' <TbDate Dim="2">'
  WI += 1 : WDSC(WI) = '  <Line  Id="Start">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Start" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="End">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="End" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbDate >'
  # - - - -
  WI += 1 : WDSC(WI) = ' <TbCClob Dim="2" Size="6">'
  WI += 1 : WDSC(WI) = '  <Line  Id="Subject">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Subject" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="Body">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Body" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbCClob>'
  # - - - -
  WI += 1 : WDSC(WI) = ' <Special>'
  If GIBSYNCBAPGERECOR = MC_TRUE Then
    WI += 1 : WDSC(WI) = '   <Link Id="Lk">'
    WI += 1 : WDSC(WI) = '     <TbChr>'
    WI += 1 : WDSC(WI) = '       <Line Id="Name">'
    WI += 1 : WDSC(WI) = '         <X3 Cat="S" />'
    WI += 1 : WDSC(WI) = '         <OL Name="FullName" Cat="S" />'
    WI += 1 : WDSC(WI) = '       </Line>'
    WI += 1 : WDSC(WI) = '       <Line Id="CtAdxId">'
    WI += 1 : WDSC(WI) = '         <X3 Cat="S" />'
    WI += 1 : WDSC(WI) = '         <OL Name="AdxId" Cat="S" />'
    WI += 1 : WDSC(WI) = '       </Line>'
    WI += 1 : WDSC(WI) = '     </TbChr>'
    WI += 1 : WDSC(WI) = '   </Link>'
  Endif
  WI += 1 : WDSC(WI) = ' </Special>'
  WI += 1 : WDSC(WI) = '</Description>'
Return
