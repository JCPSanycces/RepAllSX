#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC02   Migration de la table ITMFACILIT      Module TC         #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   #--- Issue 108760 by TS
   #Call SAIDOS(DOSSIER,"") From SAIDOS
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
   #---
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 By TS
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #---
  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC02") From LECFIC
  Endif
  #Call RAZ_UUMGTRTTRC02(DOSSIER)
  Call MAJ_UUMGTRTTRC02(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

Subprog MAJ_UUMGTRTTRC02(DOSSIER)
Value Char DOSSIER

#--- Issue 108760 by TS
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
#---

If [F:ADS]MODULE(8)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

Local Integer ERR
Local Char WNAMITFM
Local Char WNAMITMM
Call MIGTABNAME (DOSSIER,"ITMFACILIT",WNAMITFM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"ITMMASTER",WNAMITMM,ERR) From TRTMIG

If ERR :
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC02",7,ERR) From TRTMIG : #7=Erreur
End : Endif


#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMITFM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC02",3,ERR) From TRTMIG : #3=Terminée
End
Endif

##2 - Traitements en cours
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC02",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC02",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Integer  ERR, NBCOMMIT,NBLUS
# Issue 112303 - 2015-11-09 by MAE : déplacement des variables
#Local Char WTAB_ITF (100) (adxwrb)
#Local Shortint WCPT_ITF   #WCPT_XXD

Call ECR_TIME("UUMGTRTTRC02 tables ITF Process : Update ITF") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC02 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"ITMFACILIT",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:ITF])  = 0 : Local File =DOSSIER+".ITMFACILIT"    [ITF]  : Endif   # Fichier X3 "Vide"
If clalev([F:ITFM]) = 0 : Local File =DOSSIER+"."+WNAMITFM   [ITFM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:ITMM]) = 0 : Local File =DOSSIER+"."+WNAMITMM   [ITMM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:OVE])  = 0 : Local File =DOSSIER+".OVERHEAD"    [OVE]  : Endif
If clalev([F:ITS])  = 0 : Local File =DOSSIER+".ITMSALES"    [ITS]  : Endif

#-----  Déclaration des variables -----#
# Issue 112303 - 2015-11-09 by MAE : déplacement des variables
Local Char WTAB_ITF (100) (adxwrb)
Local Shortint WCPT_ITF   #WCPT_XXD
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz STOP, CRITERE, NBCOMMIT,NBLUS

# Déclaration des variables communes de travail
Local Integer I, J

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRC02",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

#-----  Lien des tables entête & lignes -----#
Link [ITFM] With [ITMM]ITM0~=[F:ITFM]ITMREF, [ITS]ITS0=[F:ITFM]ITMREF
&    As [LNK]
&    Order By Key CLE = [F:ITFM]ITMREF;[F:ITFM]STOFCY

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC02" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_ITF00
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:ITFM]ITMREF=TABMIGKEY(1) & [F:ITFM]STOFCY>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:ITFM]ITMREF>TABMIGKEY(1) "
Else
 CRITERE = "1=1"
Endif

Trbegin [ITF]
GOK = 1

For [LNK] Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1
  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTTRC02" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_ITF
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_ITF
  Endif

#                                                         # hcb X3-38470 deb

 # version < V8, raz des champs v8
  If val(VERSION)<GMIGX3VER80
      Gosub RAZV8_ITF
  Endif
  #                                                         # hcb X3-38470 fin

  [F:ITF] = [F:ITFM]

  #Appel proc de migration sur entete
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_ITF
    If GOK<1 : Break : Endif
  Endif

  # Passage en V7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_ITF
    If GOK<1 : Break : Endif
  Endif
#                                                         # hcb X3-38470 deb
  # Passage en V8
  If val(VERSION)<GMIGX3VER80
    Gosub MAJV8_ITF
    If GOK<1 : Break : Endif
  Endif
  #                                                         # hcb X3-38470 fin

#                                                                    # hcb 110327-pck  deb
# Passage en V12
  If val(VERSION)<GMIGX3VER120
    Gosub MAJV12_ITF
    If GOK<1 : Break : Endif
  Endif
#                                                                    # hcb 110327-pck  fin

  ############################
  #-- Boucle sur les lignes
  ############################
  If GOK<1 : Break : Endif

  # --- alimentation des champs et écriture enreg
  #--- Issue 108760 by TS
  #If NEWMOTEUR
  #    Gosub ITF_STK : # pour stocker ref
  #    WriteB[F:ITF]
  #Else
  #    Write [F:ITF]
  #Endif
  #If fstat
  #  If NEWMOTEUR & adxwrb>1
  #    Call ECR_TRACE("File ITMFACILIT, Error ="-num$(fstat),1) From GESECRAN
  #    Gosub ITF_ERRTRA : # pour afficher les ref
  #  Else
  #    Call ECR_TRACE("File ITMFACILIT(STOFCY/NUM)"-[F:ITF]STOFCY-"/"-[F:ITF]ITMREF+", ERROR ="-num$(fstat),1) From GESECRAN
  #  Endif
  #  GOK=0 : Break
  #Endif
  Gosub ITF_STK : # pour stocker ref
  WriteB[F:ITF]
  If fstat
    Call ECR_TRACE("File ITMFACILIT, Error ="-num$(fstat),1) From GESECRAN
    Gosub ITF_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  #---

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:ITFM]ITMREF
    TABMIGKEY(2) = [F:ITFM]STOFCY
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC02",7,ERR) From TRTMIG : #7=Erreur
Else
  #--- Issue 108760 by TS
  #If NEWMOTEUR & adxwrb>1
    Flush [F:ITF]
    If fstat
        Call ECR_TRACE("File ITMFACILIT, Error ="-num$(fstat),1) From GESECRAN
        Gosub ITF_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  #--- Issue 108760 by TS
  #Endif
    If STOP
    TABMIGKEY(3)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTTRC02",NBMIGKEY,TABMIGKEY,NBLUS,NB+NBCOMMIT,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRC02",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_ITF00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [ITF]
Close Local File [ITFM]
Close Local File [ITMM]
Close Local File [OVE]
Close Local File [ITS]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"ITMFACILIT",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTTRC02") From TRTMIG
Call ECR_TIME("UUMGTRTTRC02 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End
################################################
$RAZV6_ITF
Raz [F:ITF]DLU
Raz [F:ITF]GENLEVINS
#Raz [F:ITF]ITMTOLNEG
#Raz [F:ITF]ITMTOLPOS
Raz [F:ITF]LTIQLYCRD
Raz [F:ITF]MATWRH
Raz [F:ITF]MFGWRH
Raz [F:ITF]NEWLTISTA
Raz [F:ITF]NQA
Raz [F:ITF]ORDWRH
Raz [F:ITF]OTRSTYP
Raz [F:ITF]OVECOD
Raz [F:ITF]OVECPNFLG
Raz [F:ITF]PCK
Raz [F:ITF]PCKCAP
Raz [F:ITF]PCKSTKFLG
Raz [F:ITF]PTOCOD
Raz [F:ITF]QLYCRD
Raz [F:ITF]QUAACS
Raz [F:ITF]QUAADXUID
Raz [F:ITF]QUAFLG
Raz [F:ITF]QUAFRY
Raz [F:ITF]QUANUM
Raz [F:ITF]QUANUMUID
Raz [F:ITF]SCCWRH
Raz [F:ITF]SCOWRH
Raz [F:ITF]SHIWRH
Raz [F:ITF]SHLLTI
Raz [F:ITF]SHLLTIUOM
Raz [F:ITF]SMPMOD
Raz [F:ITF]SMPTYP
Raz [F:ITF]STAFED
Raz [F:ITF]STOMGTCOD
Raz [F:ITF]TRFWRH
Return
################################################
$RAZV7_ITF
Return

################################################
$MAJV6_ITF

#
[F:ITF]DLU       = 1
[F:ITF]SHLLTIUOM = 1
#----                    REOCOD ----#
If [F:ITF]REOCOD = 5 : [F:ITF]REOCOD = 4 : Endif
[F:ITF]PCKSTKFLG = 1
#----                    QUAFRY ----#
[F:ITF]QUAFRY    = 1
#----                    QUANUM ----#
[F:ITF]QUANUM    = 0
#----                    SMPTYP ----#
[F:ITF]SMPTYP    = 1
#----                    GENLEVINS ----#
[F:ITF]GENLEVINS = 4
#----                    NQA ----#
[F:ITF]NQA       = 12
#----                    SMPMOD ----#
[F:ITF]SMPMOD    = 3
#----                    QUAFLG ----#
[F:ITF]QUAFLG    = [F:ITMM]QUAFLG
#----                    QLYCRD ----#
[F:ITF]QLYCRD    = [F:ITMM]QLYCRD
#----                    QUAACS ----#
[F:ITF]QUAACS    = [F:ITMM]QUAACS

If [F:ITFM]OVECOD<>""
  If [F:OVE]OVECOD <> [F:ITFM]OVECOD
    Read [OVE]OVE0=[F:ITFM]OVECOD
  Endif
  # Issue 83921 - 2012-12-03 by CCC : le transclasse ne fonctionne pas pour cette zone qui devient dimensionnée
  [F:ITF]OVECOD(0) = [F:ITFM]OVECOD
  If [F:OVE]CLCLEV=1  # Appliqué en entrée
     [F:ITF]OTRSTYP(0) = 5 # --> entrée OF
  Else                # Appliqué en sortie
     [F:ITF]OTRSTYP(0) = 6 # --> sortie OF
  Endif
  If [F:OVE]CLCMOD=1
     [F:ITF]OVECPNFLG=1
  Else
     [F:ITF]OVECPNFLG=2
  Endif
Endif

If [F:ITS]ITMREF<>[F:ITFM]ITMREF
    Read [ITS]ITS0=[F:ITFM]ITMREF
  Endif
 [F:ITF]PCK    = [F:ITS]PCK
 [F:ITF]PCKCAP = [F:ITS]PCKCAP

[F:ITF]STOMGTCOD = [F:ITMM]STOMGTCOD
Return
################################################
$MAJV7_ITF
Return
################################################
#                                                         # hcb X3-38470 deb
################################################
$RAZV8_ITF
Raz [F:ITF]PCKFLG
Return
################################################
$MAJV8_ITF
[F:ITF]PCKFLG = 2
If [F:ITMM]SALFLG <> 2 &  [F:ITMM]DLVFLG <> 2
   [F:ITF]PCKFLG    = 1
   [F:ITF]PCKSTKFLG = 1
Endif
Return
################################################
#                                                         # hcb X3-38470 fin

#                                                                # hcb 110327-pck deb
################################################
$MAJV12_ITF
[F:ITF]PCKSERFLG = 1     # détail série
Return
################################################
#                                                                # hcb 110327-pck fin
$ITF_STK
Call STK (WTAB_ITF,WCPT_ITF,[F:ITF]ITMREF-'/'-[F:ITF]STOFCY) From TRTMIG
Return
##############################################################################################
$ITF_ERRTRA
Call ERRTRA (WTAB_ITF,WCPT_ITF,"File ITMFACILIT(REFITF)=") From TRTMIG
Return
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
#---
Call MAJ_UUMGTRTTRC02(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC02(APPLI)
End
#######################################################################
# Suppression pour pouvoir relancer la moulinette
########################################################################
Subprog RAZ_UUMGTRTTRC02(DOSSIER)
Value Char DOSSIER

Local Integer ERR
##1 - verifications
####################
If [F:ADS]MODULE(8)<>2 : End : Endif          : # N= no module

Local Char WNAMITFM
Call MIGTABNAME (DOSSIER,"ITMFACILIT",WNAMITFM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMITFM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif

Call MIGTABRAZ (DOSSIER,"ITMFACILIT",ERR) From TRTMIG

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTTRC02",ERR) From TRTMIG

End

