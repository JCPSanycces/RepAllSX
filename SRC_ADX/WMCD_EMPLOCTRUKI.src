#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional fields
# Supervisor
## CRUD-CLASSE ## EMPLOCTRUKI
# 2018-11-06 07:05:29 173


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EMPLOCTRUKI,ASTATUS)
Variable Instance EMPLOCTRUKI Using C_EMPLOCTRUKI
Variable Integer ASTATUS

If EMPLOCTRUKI = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOCTRUKI

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EMPLOCTRUKI

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EMPLOCTRUKI,ASTATUS)
Variable Instance EMPLOCTRUKI Using C_EMPLOCTRUKI
Variable Integer ASTATUS

If EMPLOCTRUKI = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOCTRUKI
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EMPLOCTRUKI
Else
 Gosub ADELETE_EMPLOCTRUKI
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EMPLOCTRUKI,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EMPLOCTRUKI.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOCTRUKI.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOCTRUKI.UKADD)
 If EMPLOCTRUKI.UKADD([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.UKADD([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

For [L]A_I=1 To maxtab(EMPLOCTRUKI.UKADD)
 If EMPLOCTRUKI.UKADD([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.UKADD([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EMPLOCTRUKI
Trbegin [F:CTRUKI]
 Gosub ADELETE_EMPLOCTRUKI
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EMPLOCTRUKI
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EMPLOCTRUKI,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOCTRUKI._MAJSQL_EMPLOCTRUKI(EMPLOCTRUKI))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EMPLOCTRUKI.snapshotEnabled=1
 [L]A_RETIK = EMPLOCTRUKI.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOCTRUKI.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



