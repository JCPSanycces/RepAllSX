#<AdxTL>@(#)4.0.0.0 $Revision$
###################################################
## Intégration d'un paramètre
###################################################
$PARAM
FICHIER = "ADOPAR" : ABR = "ADP"
Read [ADP]ADP1 = NOMOBJ
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
 Else
  NEWOBJ = 0
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_ADP
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_ADP
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Return

$DEL_ADP
If clalev([F:ADW])=0 : Local File ADOVAL  [ADW] : Endif
Trbegin [ADP]
 Delete [ADW] Where PARAM=NOMOBJ
 Delete [ADP] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ADOPAR"-NOMOBJ : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ADP",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

$TR_ADP
Trbegin [ADP] , [ADW]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ADP"   : Gosub ADP1
     When "ADW"   : Gosub ADP2
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ADP",[F:ADP]PARAM,[F:ADP]CHAPITRE,string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Return

$ADP1
FICHIER = "ADOPAR" : ABR = "ADP"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ
   If VARIA="ACS" and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
    OK = 0
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
ACVOBJ = [F:ADP]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat | [F:ACV]FLACT<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ADP]CREDAT = date$
  [F:ADP]CREUSR = GUSER
  If dim([F:ADP]CRETIM)>0 : [F:ADP]CRETIM = time  : Endif
  [F:ADP]UPDDAT = date$
  [F:ADP]UPDUSR = GUSER
  If dim([F:ADP]UPDTIM)>0 : [F:ADP]UPDTIM = time  : Endif
 Endif
 Write [ADP]
Else
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ADP]UPDDAT = date$
  [F:ADP]UPDUSR = GUSER
  If dim([F:ADP]UPDTIM)>0 : [F:ADP]UPDTIM = time  : Endif
 Endif
 Rewrite [ADP]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ADOPAR"-NOMOBJ : Return
Endif
If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
 Read [ADW]ADW0 = "";"";NOMOBJ
 If fstat
  NEWZON = 1
 Else
  NEWZON = 0
 Endif
Endif
Return

$ADP2
FICHIER = "ADOVAL" : ABR = "ADW"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD=2) :#U11 patch SCM
 Read [ADW2]ADW0 = [F:ADW]CMP;[F:ADW]FCY;NOMOBJ
 If fstat
  NEWZON = 1
 Else
  NEWZON = 0
 Endif
 [F:ADW2]=[F:ADW]
 If NEWZON
  Write [ADW2]
 Else
  Rewrite [ADW2]
 Endif
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ADOVAL"-[F:ADW]CMP-[F:ADW]FCY-NOMOBJ : Return
 Endif
Else
 If NEWZON
  Write [ADW]
  If fstat
   GOK = 0 : ER = 99 : ERFIC = "ADOVAL"-NOMOBJ : Return
  Endif
 Endif
Endif
Return

$ABORT
Rollback
Return

