#<AdxTL>@(#)11.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
End

######################################
$ACTION
  Case ACTION
    When "MESSAGERIE"        : Gosub MESSAGERIE
    When "FICHIER"           : Gosub FICHIER
  Endcase
Return

######################################
$MESSAGERIE
  NBPAR += 1
  PARAMETRE(NBPAR) = "_EMailToList=" + chr$(1) + GSZMREWEB
  NBPAR += 1
  PARAMETRE(NBPAR) = "_EMailCCList=" + chr$(1) + ""
  NBPAR += 1
  PARAMETRE(NBPAR) = "_EMailSubject=" + chr$(1) + GSZEMAOBC
  NBPAR += 1
  PARAMETRE(NBPAR) = "_EMailMessage=" + chr$(1) + GSZEMATEX
Return

######################################
$FICHIER
  NBPAR += 1
  PARAMETRE(NBPAR) = "_FormatExport=" + chr$(1) + num$(3)
Return
