#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe TABCONTAINER
# Issue 113105 - 2016-01-13 by MAE : Refactoring code
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
   Endcase
   When "TCTR"
    Case [L]AEVENT
      When "AREAD_AFTER"  : Gosub TCTR_AREAD_AFTER
   Endcase
Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "TCTR.TCTRTYP"       :  Gosub TCTR_TCTRTYP
    When "TCTR.INTFLG"     :  Gosub TCTR_INTFLG
    When "TCTR.FREFLG"     :  Gosub TCTR_FREFLG
    When "TCTR.LPNREFCOU"    :  Gosub TCTR_LPNREFCOU
    When "TCTR.MONITMFLG"    :  Gosub TCTR_MONITMFLG
    When "TCTR.MONLOTFLG"    :  Gosub TCTR_MONLOTFLG

  Endcase
Return



#$METHODS
#Case [L]CURPTH
#   When ""
#      Case [L]ACTION
#      Endcase
#  When "TCTR"
#      Case [L]ACTION
#        When "AREAD_AFTER"  : Gosub TCTR_AREAD_AFTER
#      Endcase
#  Endcase
#Return


##############################################################################################
$TCTR_AREAD_AFTER
If this.TCTRTYP <> 1
#  #Disable of TEU field
  ASTATUS = fmet this.ASETATTRIBUTE("TEU","$isDisabled","true")
Else
  ASTATUS = fmet this.ASETATTRIBUTE("TEU","$isDisabled","false")
Endif
#management of fields in internal bloc
If this.INTFLG <> 2
    #Disable of LPNREFCOU field
    ASTATUS = fmet this.ASETATTRIBUTE("LPNREFCOU","$isDisabled","true")
    ASTATUS = fmet this.ASETATTRIBUTE("MONITMFLG","$isDisabled","true")
    ASTATUS = fmet this.ASETATTRIBUTE("MONLOTFLG","$isDisabled","true")
    ASTATUS = fmet this.ASETATTRIBUTE("LBEFMT","$isDisabled","true")
Else
    ASTATUS = fmet this.ASETATTRIBUTE("LPNREFCOU","$isDisabled","false")
    ASTATUS = fmet this.ASETATTRIBUTE("MONITMFLG","$isDisabled","false")
    ASTATUS = fmet this.ASETATTRIBUTE("MONLOTFLG","$isDisabled","false")
    ASTATUS = fmet this.ASETATTRIBUTE("LBEFMT","$isDisabled","false")
Endif
#management of fields in fret bloc
If this.FREFLG <> 2
    #Disable of LPNREFCOU field
    ASTATUS = fmet this.ASETATTRIBUTE("TEU","$isDisabled","true")
    ASTATUS = fmet this.ASETATTRIBUTE("RGT","$isDisabled","true")
Else
    ASTATUS = fmet this.ASETATTRIBUTE("TEU","$isDisabled","false")
    ASTATUS = fmet this.ASETATTRIBUTE("RGT","$isDisabled","false")
Endif
Return
##############################################################################################
$TCTR_TCTRTYP
Case [L]ARULE
 When "PROPAGATE"   : Gosub TCTR_TCTRTYP_PROPAGATE
Endcase
Return
##############################################################################################
$TCTR_TCTRTYP_PROPAGATE

If this.TCTRTYP <> 1
#  #Disable of TEU field
  this.TEU = AVOID.ADEC
  ASTATUS = fmet this.ASETATTRIBUTE("TEU","$isDisabled","true")
Else
  ASTATUS = fmet this.ASETATTRIBUTE("TEU","$isDisabled","false")
Endif
Return
##############################################################################################
$TCTR_INTFLG
Case [L]ARULE
 When "PROPAGATE"   : Gosub TCTR_INTFLG_PROPAGATE
Endcase
Return
##############################################################################################
$TCTR_INTFLG_PROPAGATE

If this.INTFLG <> 2
  #Disable of LPNREFCOU field
  this.LPNREFCOU = AVOID.ACHAR
  this.MONITMFLG = CST_ANO
  this.MONLOTFLG = CST_ANO
  this.LBEFMT    = AVOID.ACHAR
  ASTATUS = fmet this.ASETATTRIBUTE("LPNREFCOU","$isDisabled","true")
  ASTATUS = fmet this.ASETATTRIBUTE("MONITMFLG","$isDisabled","true")
  ASTATUS = fmet this.ASETATTRIBUTE("MONLOTFLG","$isDisabled","true")
  ASTATUS = fmet this.ASETATTRIBUTE("LBEFMT","$isDisabled","true")
Else
  ASTATUS = fmet this.ASETATTRIBUTE("LPNREFCOU","$isDisabled","false")
  ASTATUS = fmet this.ASETATTRIBUTE("MONITMFLG","$isDisabled","false")
  ASTATUS = fmet this.ASETATTRIBUTE("MONLOTFLG","$isDisabled","false")
  ASTATUS = fmet this.ASETATTRIBUTE("LBEFMT","$isDisabled","false")
Endif
Return
##############################################################################################
$TCTR_FREFLG
Case [L]ARULE
 When "PROPAGATE"   : Gosub TCTR_FREFLG_PROPAGATE
Endcase
Return
##############################################################################################
$TCTR_FREFLG_PROPAGATE

If this.FREFLG <> 2
   this.TEU = 0
   this.RGT = CST_ANO
   ASTATUS = fmet this.ASETATTRIBUTE("TEU","$isDisabled","true")
   ASTATUS = fmet this.ASETATTRIBUTE("RGT","$isDisabled","true")
Else
   ASTATUS = fmet this.ASETATTRIBUTE("TEU","$isDisabled","false")
   ASTATUS = fmet this.ASETATTRIBUTE("RGT","$isDisabled","false")
Endif
Return
##############################################################################################
$TCTR_LPNREFCOU
Case [L]ARULE
 When "CONTROL"   : Gosub TCTR_LPNREFCOU_CONTROL
Endcase
Return
##############################################################################################
$TCTR_LPNREFCOU_CONTROL
Local File ACODNUM [ANM]
Local File TABCONTAINER [TCTR]
Local Integer I
Local File LPN [LPN]

If this.LPNREFCOU <> AVOID.ACHAR
 #lecture de la table ANM : le compteur doit exister
 Read[ANM]ANM0 = this.LPNREFCOU
 If [F:ANM]CODNUM = AVOID.ACHAR
  [L]ASTATUS = fmet this.ASETERROR("LPNREFCOU", mess(152,187, 1), [V]CST_AERROR)
  this.LPNREFCOU = AVOID.ACHAR
  Return
 Endif
 #controle la longueur du compteur
 If [F:ANM]LNG > GLONLPN
  [L]ASTATUS = fmet this.ASETERROR("LPNREFCOU", mess(146,187, 1), [V]CST_AERROR)
  Return
 Endif
  #est ce que le compteur est déjà affecté sur un autre type de contenant
 Filter [TCTR] Where LPNREFCOU = this.LPNREFCOU
 For [TCTR]
    [L]ASTATUS = fmet this.ASETERROR("LPNREFCOU", mess(510,184, 1), [V]CST_AWARNING)
    Break
 Next
Endif
Return
##############################################################################################
$TCTR_MONITMFLG
Case [L]ARULE
 When "PROPAGATE"   : Gosub TCTR_MONITMFLG_PROPAGATE
Endcase
Return

##############################################################################################
$TCTR_MONITMFLG_PROPAGATE
If this.MONITMFLG<>CST_AYES and this.MONLOTFLG = CST_AYES
  this.MONLOTFLG = CST_ANO
Endif
Return
##############################################################################################
$TCTR_MONLOTFLG
Case [L]ARULE
 When "PROPAGATE"   : Gosub TCTR_MONLOTFLG_PROPAGATE
Endcase
Return

##############################################################################################
$TCTR_MONLOTFLG_PROPAGATE
If this.MONITMFLG<>CST_AYES and this.MONLOTFLG = CST_AYES
  this.MONITMFLG = CST_AYES
Endif
Return

