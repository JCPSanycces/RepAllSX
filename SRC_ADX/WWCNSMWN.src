#<AdxTL>@(#)%I%
# Supervisor
# Inquiry MWN

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:12"
A_USER  = "ADMIN"
A_STAMP = "20181109081112"
Return

$DEFAUT
Return

$OUVFIC
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(1004350,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSMWNSTD"
PROGSPE    = "CNSMWNSPE"
BOITE      = "FCNSMWN"
NOMMSK(0)  = "CONSMWN1"
ABMSK(0)   = "MWN1"
NOMMSK(1)  = "CONSMWN2"
ABMSK(1)   = "MWN2"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = ""
NBCMP = 0
CLECMP = "" : CLEMSK = ""
Return

$OUVRE
If clalev([F:ITM])=0 : Local File ITMMASTER    [ITM] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT   [ITF] : Endif
If clalev([F:FCY])=0 : Local File FACILITY     [FCY] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS      [AUS] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT      [TUN] : Endif
If clalev([F:MFG])=0 : Local File MFGHEAD      [MFG] : Endif
Return

$OUVRE_MSK
Case MA
 When  0 : Local Mask =NOMMSK(0) [MWN1]
 When  1 : Local Mask =NOMMSK(1) [MWN2]
Endcase
Return

$GRISE_MSK
Case MA
 When  0 : Grizo [MWN1]
 When  1 : Grizo [MWN2]
Endcase
Return

$GRISE_CLE
Return

$GRISE_CRIT
Return

$FERME_MSK
Case MA
 When  0 : If clalev([M:MWN1])>0 : Close Local Mask [MWN1] : Endif
 When  1 : If clalev([M:MWN2])>0 : Close Local Mask [MWN2] : Endif
Endcase
Return

$SETMASK
Case MA
 When  0 : Default Mask [MWN1]
 When  1 : Default Mask [MWN2]
Endcase
Return

$RAZMASK
Case MA
 When  0 : Raz [M:MWN1]
 When  1 : Raz [M:MWN2]
Endcase
Return

$CRITENT
Return

$ENTCRIT
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..3) , CRITAFF2(10)(1..3)
CRITAFF(1) = "" : CRITAFF2(1) = "CTNSTR"
CRITAFF(2) = "" : CRITAFF2(2) = "CTNEND"
CRITAFF(3) = "" : CRITAFF2(3) = "MFGNUMSTR"
NBCA = 3
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSMWN2"
NBBOUT = 0
If GBOUT1<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT1
 VALBOUT(NBBOUT) = "MWN"
 VALBOUT(NBBOUT) += "~B1"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M:MWN1]MFGFCY,"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("0","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([M]MFGNUM(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("0","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("1","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([M]CTN(nolign-1),"~","¨")
 Onerrgo
Endif
If GBOUT2<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT2
 VALBOUT(NBBOUT) = "MWN"
 VALBOUT(NBBOUT) += "~B2"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M:MWN1]MFGFCY,"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("0","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([M]MFGNUM(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("0","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("1","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("0","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([M]CTN(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("0","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
 When "B1"
  Onerrgo RIEN
  Assign "[M:MWN1]MFGFCY" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Assign "0" With val(ctrans(func AFNC.PART(INFO,5),"¨","~"))
  Assign "[M]MFGNUM(nolign-1)" With ctrans(func AFNC.PART(INFO,6),"¨","~")
  Assign "0" With val(ctrans(func AFNC.PART(INFO,7),"¨","~"))
  Assign "1" With val(ctrans(func AFNC.PART(INFO,8),"¨","~"))
  Assign "[M]CTN(nolign-1)" With ctrans(func AFNC.PART(INFO,9),"¨","~")
  Onerrgo
  Call B1_NBLIG From ="W1CONSMWN2"
 When "B2"
  Onerrgo RIEN
  Assign "[M:MWN1]MFGFCY" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Assign "0" With val(ctrans(func AFNC.PART(INFO,5),"¨","~"))
  Assign "[M]MFGNUM(nolign-1)" With ctrans(func AFNC.PART(INFO,6),"¨","~")
  Assign "0" With val(ctrans(func AFNC.PART(INFO,10),"¨","~"))
  Assign "1" With val(ctrans(func AFNC.PART(INFO,11),"¨","~"))
  Assign "0" With val(ctrans(func AFNC.PART(INFO,12),"¨","~"))
  Assign "[M]CTN(nolign-1)" With ctrans(func AFNC.PART(INFO,13),"¨","~")
  Assign "0" With val(ctrans(func AFNC.PART(INFO,14),"¨","~"))
  Onerrgo
  Call B2_NBLIG From ="W1CONSMWN2"
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


