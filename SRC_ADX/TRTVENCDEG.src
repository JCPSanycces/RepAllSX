#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# TRTVENCDEG
#########################################################################
#
# Composant de creation d'une commande :
# -> Call GENSOH(LCOD, LMAJ, LTEST, LTRT, LORINUM, LSIVNUM, LERR)
#   - LCOD     1= création complète de la facture
#              2= garnissage des classes [M] entête et lignes (ex : picking)
#   - LMAJ     C=Création / M=Modification / S=Suppression
#   - LTEST    Simulation et Ecriture ds fichier trace pour tests
#              (1=Non sans simul/2=Oui sans simul/3=Non avec simul/4=Oui avec simul)
#   - LTRT     Traitement appelé pour le chargement de [M]
#   - LORINUM  No document origine
#   - LSOHNUM  No du devis créé
#   - LERR     Code erreur
#              1=sur action OBJET / 2= dans chargement [M]entete
#              3=dans chargement [M]detail / 4=en lecture de table
#              8=dans point entrée / 9=autres
#              (complement info sur erreur dans GBIDC3)
#              90=en simulation, valeur affectee lors du rollback
#
#########################################################################

Local Integer LCOD   : LCOD=1
Local Char    LMAJ   : LMAJ="C"
Local Integer LTEST  : LTEST=2
Local Char    LTRT   : LTRT="ZTRTJLCDEG"
Local Char    LORINUM
Local Char    LSOHNUM
Local Integer LERR   : LERR=0

Raz GTRACE

Call GENSOH(LCOD, LMAJ, LTEST, LTRT, LORINUM, LSOHNUM, LERR)
End



#########################################################################
# Subprog GENSOH(LCOD, LMAJ, LTEST, LTRT, LORINUM, LSOHNUM, LERR)
#    S/P de creation automatique d'une commande de vente
#########################################################################

Subprog GENSOH(LCOD, LMAJ, LTEST, LTRT, LORINUM, LSOHNUM, LERR)
Value    Integer LCOD
Value    Char    LMAJ
Value    Integer LTEST
Value    Char    LTRT
Value    Char    LORINUM
Variable Char    LSOHNUM
Variable Integer LERR         : # test des erreurs par remplissage de GMESSAGE

#-- pour passage des valeurs
Global   Char    GWLTRT (15) : GWLTRT=LTRT
Global   Integer GWLTEST     : GWLTEST=LTEST
Global   Char    GWLIB_TD (50)            : # libelle de l'action pour trace test
Global   Integer GWCREINV : GWCREINV=2    : # pour effectuer traitements même si GIMPORT=1
Global   Char    GWIMPZON                 : # champ de classe [M] en cours chargement
Global   Char    GWACTION_GS (20)
Global   Integer GWIMPMOD

#--
Local    Integer SAVGIMPORT : SAVGIMPORT=GIMPORT
Raz LERR

#-- Pour Setmode

Local Integer  INBAFF                  : # Pile/Indice
Local Integer  IAFFCOD(0..1)           : # Code instruction
Local Char     IAFFMASK(GLONABR)(0..1) : # Abréviation écran
Local Char     IAFFCHP(50)(0..1)       : # Zone écran
Local Integer  IAFFIND(0..1)           : # Indice de la zone
Local Char     IAFFTXT(250)(0..1)      : # Texte
Local Integer  IAFFRANG(0..1)          : # Rang
Local Integer  IAFFOPT1(0..1)          : # Option1 Ex: Status, premier rang affzo 10-20
Local Integer  IAFFOPT2(0..1)          : # Option2 Ex: Raccourci clavier, dernier rang affzo 10-20

#---------

Case LCOD
     When 1   : Gosub GS_1
     When 2   : Gosub GS_2
Endcase

Setmode

If find(GWLTEST,2,4) : Call LEC_TRACE From LECFIC : Endif

Kill GWLTRT, GWLTEST, GWLIB_TD, GWCREINV, GWIMPZON, GWACTION_GS, GWIMPMOD
GIMPORT=SAVGIMPORT

End

#########################################################################
#########################################################################
$GS_1
Case LMAJ
     When "C"   : Gosub GS_1C
     When "M"   : Gosub GS_1M
     When "S"   : Gosub GS_1S
Endcase
Return

#------------------------------------------------------------------------
$GS_1C
#--- variables
Local  Integer OK
Local  Char    ACTION(20), ABREV(5)

#--- declaration et chargement des variables objet
ABREV="SOH" : GABREV="SOH"
Gosub DEFVAR From GOBJET
GIMPORT=1

Raz GMESSAGE
GOK=1 : OK=1

ACTION="AVANT_OUVRE" : GWLIB_TD=ACTION : Gosub TRACE_DETAILLEE : Gosub ACTION From GOBJSUB

#--- ouverture des maques de objet SOH
If clalev([M:SOH0])=0 : Local Mask SOH0 [SOH0] : Endif
If clalev([M:SOH1])=0 : Local Mask SOH1 [SOH1] : Endif
If clalev([M:SOH2])=0 : Local Mask SOH2 [SOH2] : Endif
If clalev([M:SOH3])=0 : Local Mask SOH3 [SOH3] : Endif
If clalev([M:SOH4])=0 : Local Mask SOH4 [SOH4] : Endif
If clalev([M:ACL])=0  : Local Mask ACLOB [ACL] : Endif
Raz [M:SOH0], [M:SOH1], [M:SOH2], [M:SOH3], [M:SOH4]

#--- ouverture des tables necessaires
If clalev([F:SOH])=0 : Local File SORDER   [SOH] : Endif

Gosub DEF_MSK_OBJ : Gosub OUVRE From WOSOH

ACTION="OUVRE" : GWLIB_TD=ACTION : Gosub TRACE_DETAILLEE : Gosub DEF_MSK_OBJ
Gosub AVANT_ACTION
Gosub ACTION From GOBJSUB
Gosub APRES_ACTION
If !OK : LERR=1 : Gosub TRT_ERR : Goto GS_1C_FIN : Endif
Call ISWINDOWOK (nomap,"OSOH") From INTRUTILB
WINPROG="WGOSOH"

Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2

GREP="C"
ACTION="RAZCRE" : GWLIB_TD=ACTION : Gosub TRACE_DETAILLEE : Gosub DEF_MSK_OBJ
Gosub AVANT_ACTION
Gosub ACTION From GOBJSUB
Gosub APRES_ACTION
If GERR=1 : LERR=1 : Gosub TRT_ERR : Goto GS_1C_FIN : Endif

#--- chargement des masques de objet
GWLIB_TD="MSK_ENTETE" : Gosub TRACE_DETAILLEE
Gosub AVANT_ACTION
Gosub MSK_ENTETE : # chargement masques enregistrement entête
Gosub APRES_ACTION
If mkstat : LERR=2 : Gosub TRT_ERR : Goto GS_1C_FIN : Endif

GWLIB_TD="MSK_DETAIL" : Gosub TRACE_DETAILLEE
Gosub AVANT_ACTION
Gosub MSK_DETAIL : # chargement des lignes
Gosub APRES_ACTION
If mkstat : LERR=3 : Gosub TRT_ERR : Goto GS_1C_FIN : Endif

#GPOINT="ALIMSKSOH" : Gosub ENTREE From EXEFNC
#If mkstat : LERR=8 : Gosub TRT_ERR : Goto GS_1C_FIN : Endif

#---
OK=1
ACTION="VERIF_CRE" : GWLIB_TD=ACTION : Gosub TRACE_DETAILLEE : Gosub DEF_MSK_OBJ
Gosub AVANT_ACTION
Gosub ACTION From GOBJSUB
Gosub APRES_ACTION
If !OK : LERR=1 : Gosub TRT_ERR : Goto GS_1C_FIN : Endif

GWACTION_GS="AP_VERIF_CRE" : Gosub ACTION_GS From=GWLTRT

Call DEBTRANS From GLOCK

#--- debut transaction creation
$GS_1C_TR
GOK=1

# ----------------------------------------------
# Issue X3-7938/120447 - 2016-12-16 by FGR : BEGIN
#Trbegin [SOH], [SOP], [SOQ]
Local Integer IBDEBTRANSFLG
Local  Char   GRPDEB(GLONVCR)     # Issue X3-16624/120499 - 2016-12-20 by FGR

  IBDEBTRANSFLG = (adxlog=1)
  If IBDEBTRANSFLG = [V]CST_AFALSE Then
    Trbegin [SOH], [SOP], [SOQ]
  Endif
# Issue X3-7938/120447 - 2016-12-16 by FGR : END
# ----------------------------------------------
  Raz [F:SOH], [F:SOP], [F:SOQ]
   nolign=1
  [F:SOH]=[M:SOH0] : [F:SOH]=[M:SOH1] :[F:SOH]=[M:SOH2] :[F:SOH]=[M:SOH3]
  Default File [F:SOH]

  GWLIB_TD="INICRE de GOBJSUB" : Gosub TRACE_DETAILLEE
  Gosub INICRE From GOBJSUB

  ACTION="INICRE" : GWLIB_TD=ACTION : Gosub TRACE_DETAILLEE
  Gosub AVANT_ACTION
  Gosub ACTION From GOBJSUB
  Gosub APRES_ACTION
  If GOK<0  Goto GS_1C_ROLL  Elsif  !GOK Goto GS_1C_AB  Endif

  GWACTION_GS="INICRE" : Gosub ACTION_GS From=GWLTRT

  GWLIB_TD="Write SORDER" : Gosub TRACE_DETAILLEE
  Write [F:SOH]
  If fstat : GOK=0 : Call FSTA("SOH") From GLOCK : LERR=9 : Goto GS_1C_AB : Endif

  ACTION="CREATION" : GWLIB_TD=ACTION : Gosub TRACE_DETAILLEE
  Gosub AVANT_ACTION
  Gosub ACTION From GOBJSUB
  Gosub APRES_ACTION
  If GOK<0  Goto GS_1C_ROLL  Elsif  !GOK Goto GS_1C_AB  Endif

  GWACTION_GS="CREATION" : Gosub ACTION_GS From=GWLTRT
  If GOK<0  Goto GS_1C_ROLL  Elsif  !GOK Goto GS_1C_AB  Endif

  # Issue X3-16624/120499 - 2016-12-20 by FGR : BEGIN
  If GOK=1
    # -- Déf des variables workflow
    Call WRKGLOB(170,[F:SOH]SOHNUM,"SORDER","") From GOBJACT
    #-------------------------------------------------------------------------------------#
    # Subprog WORKPLUS(TYPEVT,CODEVT,OPERAT,CLEOBJ,CODE,SIMUL,DIFFERE,TYPDEC,GRPDEB)      #
    # TYPEVT  : Type d'évènement Workflow (objet/import/etc.)                             #
    # CODEVT  : Code évènement                                                            #
    # OPERAT  : Opération (Modification/Bouton/etc.)                                      #
    # CLEOBJ  : Clé de l'objet si typevt=objet ou chrono origine/dest si typevt=signature #
    # CODE    : Code workflow (cas du bouton W et du workflow manuel)                     #
    # SIMUL   : Permet de simuler OU de générer un workflow manuel                        #
    # DIFFERE : Envoi message différé (transactions de création/modification d'un objet)  #
    # TYPDEC  : Déclenchement workflow avant/après mise à jour classe [F] (modif objet)   #
    # GRPDEB  : Premier chrono groupe (utilisé pour l'envoi différé)                      #
    #-------------------------------------------------------------------------------------#
    Call WORKPLUS(2,"SOH","C",[F:SOH]SOHNUM,"",0,1,0,GRPDEB) From AWRK
    If GOK <= 0 Then
      Return
    Endif
    #----- Envoi des messages groupe workflow signature -----#
    If GRPDEB <> "" Then
      Call ENVOI_GROUPE(GRPDEB) From AWRK
      GRPDEB = ""
    Endif
  Endif
  # Issue X3-16624/120499 - 2016-12-20 by FGR : END

If find(GWLTEST, 1,2)
    # ----------------------------------------------
    # Issue X3-7938/120447 - 2016-12-16 by FGR : BEGIN
    #Commit
    If IBDEBTRANSFLG = [V]CST_AFALSE Then
      Commit
    Endif
    # Issue X3-7938/120447 - 2016-12-16 by FGR : END
    # ----------------------------------------------
Else
    LERR=90 : Goto GS_1C_AB    : # simulation ne pas ecrire
Endif

ACTION="APRES_CRE" : GWLIB_TD=ACTION : Gosub TRACE_DETAILLEE
Gosub AVANT_ACTION
Gosub ACTION From GOBJSUB
Gosub APRES_ACTION

If GOK=1 : LSOHNUM=[M:SOH0]SOHNUM : Endif

Goto GS_1C_FIN

#---
$GS_1C_ROLL
# ----------------------------------------------
# Issue X3-7938/120447 - 2016-12-16 by FGR : BEGIN
#Rollback
#Call ROLL From GLOCK
#If GROLL
#   ACTION="AB_CREATION" : GWLIB_TD=ACTION : Gosub TRACE_DETAILLEE
#   Gosub AVANT_ACTION
#   Gosub ACTION From GOBJSUB
#   Gosub APRES_ACTION
#   LERR=1 : Goto GS_1C_FIN
#Else
#   Goto GS_1C_TR
#Endif
If IBDEBTRANSFLG = [V]CST_AFALSE Then
  Rollback
  Call ROLL From GLOCK
  If GROLL
     ACTION="AB_CREATION" : GWLIB_TD=ACTION : Gosub TRACE_DETAILLEE
     Gosub AVANT_ACTION
     Gosub ACTION From GOBJSUB
     Gosub APRES_ACTION
     LERR=1 : Goto GS_1C_FIN
  Else
     Goto GS_1C_TR
  Endif
Else
  # Impossible to manage "Call ROLL From GLOCK" in this case
   ACTION="AB_CREATION" : GWLIB_TD=ACTION : Gosub TRACE_DETAILLEE
   Gosub AVANT_ACTION
   Gosub ACTION From GOBJSUB
   Gosub APRES_ACTION
   LERR=1 : Goto GS_1C_FIN
Endif
# Issue X3-7938/120447 - 2016-12-16 by FGR : END
# ----------------------------------------------

#---
$GS_1C_AB
# ----------------------------------------------
# Issue X3-7938/120447 - 2016-12-16 by FGR : BEGIN
#Rollback
If IBDEBTRANSFLG = [V]CST_AFALSE Then
  Rollback
Endif
# Issue X3-7938/120447 - 2016-12-16 by FGR : END
# ----------------------------------------------
ACTION="AB_CREATION" : GWLIB_TD=ACTION : Gosub TRACE_DETAILLEE
Gosub AVANT_ACTION
Gosub ACTION From GOBJSUB
Gosub APRES_ACTION
If !LERR=90 : LERR=1 : Endif
Goto GS_1C_FIN

#---
$GS_1C_FIN

ACTION="FERME" : GWLIB_TD=ACTION : Gosub TRACE_DETAILLEE
Gosub AVANT_ACTION
Gosub ACTION From GOBJSUB
Gosub APRES_ACTION

If GTRACE<>""
   If LERR=0
      Call ECR_TRACE("**********"+mess(218,191,1)-LSOHNUM,0) From GESECRAN : # Création commande client
   Elsif LERR=90
      Call ECR_TRACE("**********"+mess(942,196,1),0) From GESECRAN   : # Simulation de creation OK
      LERR=0
   Else
      Call ECR_TRACE("**********"+mess(322,192,1),1) From GESECRAN         : # Commande non créé
   Endif
Endif

Return

#------------------------------------------------------------------------
$GS_1M
Return
#------------------------------------------------------------------------
$GS_1S
Return


#########################################################################
#########################################################################
$GS_2
#GIMPORT=1

#--- chargement des masques de objet

GWLIB_TD="MSK_ENTETE" : Gosub TRACE_DETAILLEE
Gosub AVANT_ACTION
Gosub MSK_ENTETE : # chargement masques enregistrement entête
Gosub APRES_ACTION
If mkstat : LERR=2 : Gosub TRT_ERR : Goto GS_2_FIN : Endif

GWLIB_TD="MSK_DETAIL" : Gosub TRACE_DETAILLEE
Gosub AVANT_ACTION
Gosub MSK_DETAIL : # chargement des lignes
Gosub APRES_ACTION
If mkstat : LERR=3 : Gosub TRT_ERR : Goto GS_2_FIN : Endif

GPOINT="ALIMSKSOH" : Gosub ENTREE From EXEFNC                                    : #CHECK IGNORE_LINE
If mkstat : LERR=8 : Gosub TRT_ERR : Goto GS_2_FIN : Endif

$GS_2_FIN
If LERR : Call ERREUR (GBIDC3) From GESECRAN : Endif
Return

#########################################################################
#########################################################################
$GS_3
Return

#########################################################################
#########################################################################
$GS_9
Return

#########################################################################
#########################################################################

#------------------------------------------------------------------------
$TRT_ERR
If LERR & GOK=1 : GOK=0 : Endif
Case LERR
     When 1        GBIDC3="ACTION="+GWLIB_TD
     When 2        Raz GBIDC3
     When 3        Raz GBIDC3
     When 4        Raz GBIDC3
     When 8        GBIDC3=GWLIB_TD-GBIDC3
     When 9        GBIDC3=GWLIB_TD-GBIDC3
     When Default  Raz GBIDC3
Endcase
GWACTION_GS="ERREUR" : Gosub ACTION_GS From=GWLTRT
If GBIDC3<>""
   Call ERREUR (GBIDC3) From GESECRAN
   Raz GBIDC3
Endif
Return

#------------------------------------------------------------------------
$TRACE_DETAILLEE
If !find(GWLTEST,2,4) : Return : Endif
If GTRACE=""
   Call OUVRE_TRACE (mess(1,13,1)+" TRTVENCDEG : "+mess(217,191,1)) From LECFIC
   #                 Traitement TRTVENCDEG : Creation commande client
Endif
Call ECR_TRACE(GWLIB_TD,0) From GESECRAN
Return

#------------------------------------------------------------------------
$ACTION
GWIMPZON=IMPZON
Raz GCLE
Case ACTION
     When "IMP_ZONE" : GWACTION_GS="MSK_ENTETE" : Gosub ACTION_GS From=GWLTRT
     When "IMP_TAB"  : GWACTION_GS="MSK_DETAIL" : Gosub ACTION_GS From=GWLTRT
Endcase
GWIMPMOD=IMPMOD
Return


#------------------------------------------------------------------------
# chargement masques enregistrement entête commande
$MSK_ENTETE

Default Mask [SOH0]
Call SAIMSK("SOH","IMP_ZONE","TRTVENCDEG") From W0SOH0
If mkstat : Return : Endif

Default Mask [SOH1]
Call SAIMSK("SOH","IMP_ZONE","TRTVENCDEG") From W0SOH1
If mkstat : Return : Endif

Default Mask [SOH2]
Call SAIMSK("SOH","IMP_ZONE","TRTVENCDEG") From W0SOH2
If mkstat : Return : Endif

Default Mask [SOH3]
Call SAIMSK("SOH","IMP_ZONE","TRTVENCDEG") From W0SOH3
Return

#------------------------------------------------------------------------
# chargement tableau des lignes commandes
$MSK_DETAIL
Local Integer LEC_DETAIL   : # 0=lire 1er enr. / 1= suivant / 2=fin / 3=erreur / 4=suivant
Local Char    LIG_DETAIL   : # (C)create / (U)pdate / (D)elete
Default Mask [SOH4]
[M]NBLIG=0 : nolign=0

# Boucle de lecture des lignes
While LEC_DETAIL <2
   If [M]NBLIG>=dim([M]ITMREF)
      OK=0 : GERR=1 : GMESSAGE=mess(26,100,1)-num$([M]NBLIG)
      Call ERREUR (GMESSAGE) From GESECRAN
      mkstat=1 : Break
   Endif
   # Lecture d'une ligne détail
   GWACTION_GS="READ_DETAIL" : Gosub ACTION_GS From=GWLTRT
   If LEC_DETAIL =1
      # Lecture ok et ligne à charger : Chargement du masque des lignes détail SOH4
      If nolign=0 & LIG_DETAIL="C"
         [M]NBLIG +=1 : nolign=[M]NBLIG : status=73
      Endif
      If nolign>0 & LIG_DETAIL="U"
         status=75
      Endif
      If nolign>0 & LIG_DETAIL="D"
         Dela nolign-1,1,[M]NBLIG-1 NBLIG
         [M]NBLIG -=1
      Endif
      indice=nolign-1 : mkstat=0
      Call SAI_NBLIG("SOP","IMP_TAB","TRTVENCDEG") From W0SOH4
      If mkstat : Break : Endif
      GWACTION_GS="AP_READ_DETAIL" : Gosub ACTION_GS From=GWLTRT
   Endif
   If LEC_DETAIL =3
      # Lecture ko : Sortie de la boucle de lecture des lignes
      OK=0 : GERR=1 : GMESSAGE=mess(1,13,1)-GWLTRT+" : "+mess(49,125,1)-GBIDC3
      Raz GBIDC3
      Call ERREUR (GMESSAGE) From GESECRAN
      mkstat=1 : LERR=4 : Break
   Endif
   If LEC_DETAIL =4
      # Lecture ok mais la ligne n'est pas à charger : Lecture ligne suivante
      If GBIDC3<>""
          Call MESSAGE (GBIDC3) From GESECRAN
          Raz GBIDC3
      Endif
      LEC_DETAIL=1 : # Pour lire la ligne suivante
   Endif
Wend
Return

#------------------------------------------------------------------------
# Masques commandes dans pile des masques par defaut
$DEF_MSK_OBJ
Default Mask [SOH0]
Default Mask [SOH1]
Default Mask [SOH2]
Default Mask [SOH3]
Default Mask [SOH4]
Return

#------------------------------------------------------------------------
$AVANT_ACTION
Case GWLIB_TD
  When "MSK_DETAIL"
       Local Integer SAUV_GPRIMOD, SAUV_GSPRIMOD
       SAUV_GPRIMOD=GPRIMOD : GPRIMOD=2 : SAUV_GSPRIMOD=GSPRIMOD : GSPRIMOD=2
       If SAUV_GPRIMOD=1
          Actzo [M:SOH4]GROPRI
          If dim([M:SOH4]DISCRGVAL1) > 0 Actzo [M:SOH4]DISCRGVAL1 Endif
          If dim([M:SOH4]DISCRGVAL2) > 0 Actzo [M:SOH4]DISCRGVAL2 Endif
          If dim([M:SOH4]DISCRGVAL3) > 0 Actzo [M:SOH4]DISCRGVAL3 Endif
          If dim([M:SOH4]DISCRGVAL4) > 0 Actzo [M:SOH4]DISCRGVAL4 Endif
          If dim([M:SOH4]DISCRGVAL5) > 0 Actzo [M:SOH4]DISCRGVAL5 Endif
          If dim([M:SOH4]DISCRGVAL6) > 0 Actzo [M:SOH4]DISCRGVAL6 Endif
          If dim([M:SOH4]DISCRGVAL7) > 0 Actzo [M:SOH4]DISCRGVAL7 Endif
          If dim([M:SOH4]DISCRGVAL8) > 0 Actzo [M:SOH4]DISCRGVAL8 Endif
          If dim([M:SOH4]DISCRGVAL9) > 0 Actzo [M:SOH4]DISCRGVAL9 Endif
       Endif
Endcase
Return

#------------------------------------------------------------------------
$APRES_ACTION
Case GWLIB_TD
  When "MSK_DETAIL"
       If dim(SAUV_GPRIMOD)>0  :
          If SAUV_GPRIMOD=1
             Diszo [M:SOH4]GROPRI
             If dim([M:SOH4]DISCRGVAL1) > 0 Diszo [M:SOH4]DISCRGVAL1 Endif
             If dim([M:SOH4]DISCRGVAL2) > 0 Diszo [M:SOH4]DISCRGVAL2 Endif
             If dim([M:SOH4]DISCRGVAL3) > 0 Diszo [M:SOH4]DISCRGVAL3 Endif
             If dim([M:SOH4]DISCRGVAL4) > 0 Diszo [M:SOH4]DISCRGVAL4 Endif
             If dim([M:SOH4]DISCRGVAL5) > 0 Diszo [M:SOH4]DISCRGVAL5 Endif
             If dim([M:SOH4]DISCRGVAL6) > 0 Diszo [M:SOH4]DISCRGVAL6 Endif
             If dim([M:SOH4]DISCRGVAL7) > 0 Diszo [M:SOH4]DISCRGVAL7 Endif
             If dim([M:SOH4]DISCRGVAL8) > 0 Diszo [M:SOH4]DISCRGVAL8 Endif
             If dim([M:SOH4]DISCRGVAL9) > 0 Diszo [M:SOH4]DISCRGVAL9 Endif
          Endif
          GPRIMOD=SAUV_GPRIMOD

       Endif

       If dim(SAUV_GSPRIMOD)>0 : GSPRIMOD=SAUV_GSPRIMOD : Endif
Endcase
Return




#------------------------------------------------------------------------
# Exemple de MSK_ENTETE a developper dans le traitement LTRT
#------------------------------------------------------------------------
#$MSK_ENTETE
#Case IMPZON
#     When "SOHNUM"     :  IMPMOD=1 : [M]SOHNUM=            #--- masque SOH0
#     When "SOHTYP"     :  IMPMOD=1 : [M]SOHTYP=
#     When "SALFCY"     :  IMPMOD=1 : [M]SALFCY=
#     When "CUSORDREF"  :  IMPMOD=1 : [M]CUSORDREF=
#     When "ORDDAT"     :  IMPMOD=1 : [M]ORDDAT=    defaut (datesys)
#     When "BPCORD"     :  IMPMOD=1 : [M]BPCORD=    OBLIGATOIRE
#                          --- gestion textes entete sur le 1er champ obligatoire
#                              attention - stockage du lien dans un champ de manoeuvre
#                                        - recuperation du lien dans la 1ere ligne detail
#                              - ouvrir masque ACLOB [ACL] et table TEXCLOB [TXC] en debut
#                              - garnir [M:ACL]CLOB avec le texte
#                              - mettre abréviation de la table dans le champ de manoeuvre
#                          Local Integer T_OK
#                          raz [M]I_SOHTEX1, [M]I_SOHTEX2
#                          If [M]I_SOHTEX1(nolign-1)="SOH"
#                             Call CRE_CLOB_ACL ("[M]I_SOHTEX1",T_OK) From TRTX3TEX
#                          Endif
#                          If [M]I_SOHTEX2(nolign-1)="SOH"
#                             Call CRE_CLOB_ACL ("[M]I_SOHTEX2",T_OK) From TRTX3TEX
#                          Endif
#
#     When "BPCINV"     :  IMPMOD=1 : [M]BPCINV=            #--- masque SOH1
#     When "BPCPYR"     :  IMPMOD=1 : [M]BPCPYR=
#     When "BPCGRU"     :  IMPMOD=1 : [M]BPCGRU=
#     When "BPAADD"     :  IMPMOD=1 : [M]BPAADD=
#     When "PJT"        :  IMPMOD=1 : [M]PJT=
#     When "REP"
#          Case indice
#               When 0  :  IMPMOD=1 : [M]REP(0)=
#               When 1  :  IMPMOD=1 : [M]REP(1)=
#          Endcase
