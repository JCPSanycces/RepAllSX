######################################################################################################
# Project       : Bank statement import (MT940/CAMT)
# File          : BSIBPRNUMDUP_CSTD
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 10.05.2017
######################################################################################################
# Module        : Finance
# Description   : Manages duplicate class for BP number definition (Class BSIBPRNUM)
######################################################################################################
# Updates       :
# Date          |Author |Version| Description
######################################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "CPYNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub NEW_CONTROL
      Endcase
    When "FCYNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub NEW_CONTROL
      Endcase
    When "FILFMTNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub NEW_CONTROL
      Endcase
    When Default
  Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_DUPLICATE"  : Gosub MET_DUPLICATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


####################################################################

$NEW_CONTROL
  If this.CPYNEW <> ""
    If func CTRL_EXIST_BPRNUM(this.CPYNEW,this.FCYNEW,this.FILFMTNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("BPRNUM",mess(45,7779,1)-":"-this.CPYNEW+"/"+this.FCYNEW+"/"+this.FILFMTNEW,[V]CST_AERROR)
    Endif
  Endif
Return


####################################################################

$MET_DUPLICATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)

  ASTATUS = fmet this.ADELETEERROR("")
  If this.CPYNEW <> ""
    ASTATUS = fmet this.ASETERROR("",mess(9,7983,1),[V]CST_AINFO)
    If func CTRL_EXIST_BPRNUM(this.CPYNEW,this.FCYNEW,this.FILFMTNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("BSIBPRNUMNEW",mess(45,7779,1)-":"-this.CPYNEW+"/"+this.FCYNEW+"/"+this.FILFMTNEW,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Else
      If func COPY_BPRNUM(this.CPY,this.FCY,this.FILFMT,this.CPYNEW,this.FCYNEW,this.FILFMTNEW,WERR) = [V]CST_AERROR
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(9,2007,1)-this.CPYNEW+"/"+this.FCYNEW+"/"+this.FILFMTNEW-WERR,[V]CST_AERROR)
        WRET_VALUE = [V]CST_AERROR
      Else
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(7,2007,1)-this.CPYNEW+"/"+this.FCYNEW+"/"+this.FILFMTNEW,[V]CST_AINFO)
        WRET_VALUE = [V]CST_AOK
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETERROR("",mess(141,105,1),[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return

Funprog CTRL_EXIST_BPRNUM(WCPY,WFCY,WFILFMT)
Value Char WCPY
Value Char WFCY
Value Char WFILFMT

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WCPY <> ""
    Local File BSIBPRNUM [BSIBPN]
    Read [BSIBPN]BSIBPN0 = WCPY;WFCY;WFILFMT
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [BSIBPN]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

Funprog COPY_BPRNUM(WCPY,WFCY,WFILFMT,WCPY_NEW,WFCY_NEW,WFILFMT_NEW, WERR)
Value Char WCPY
Value Char WFCY
Value Char WFILFMT
Value Char WCPY_NEW
Value Char WFCY_NEW
Value Char WFILFMT_NEW
Variable Char WERR

  Local Integer WOK : WOK = [V]CST_AOK
  Local File BSIBPRNUM [BSIBPN]
  Local File BSIBPRNUM [BSIBPN2]
  Local File BSIBPRNUMD [BSIBPND]
  Local File BSIBPRNUMD [BSIBPND2]
  WERR = ""

  Trbegin [BSIBPN2],[BSIBPND2]

  Read [BSIBPN]BSIBPN0 = WCPY;WFCY;WFILFMT
  If !fstat
    [BSIBPN2]       = [BSIBPN]
    [BSIBPN2]CPY    = WCPY_NEW
    [BSIBPN2]FCY    = WFCY_NEW
    [BSIBPN2]FILFMT = WFILFMT_NEW
    Write [BSIBPN2]
    If fstat
      WOK = [V]CST_AERROR
      WERR = "BSIBPRNUM ("+mess(1,7983,1)+")"
    Endif
  Else
    WOK = [V]CST_AERROR
    WERR = "BSIBPRNUM ("+mess(7,7983,1)+")"
  Endif

  If WOK = [V]CST_AOK
    Filter [BSIBPND] Where CPY = WCPY and FCY = WFCY and FILFMT = WFILFMT
    For [BSIBPND]
      [BSIBPND2]       = [BSIBPND]
      [BSIBPND2]CPY    = WCPY_NEW
      [BSIBPND2]FCY    = WFCY_NEW
      [BSIBPND2]FILFMT = WFILFMT_NEW
      Write [BSIBPND2]
      If fstat
          WOK = [V]CST_AERROR
          Break
      Endif
    Next
    Filter [BSIBPND]
  Endif

  If WOK = [V]CST_AERROR
    If WERR = "" : WERR = "BSIBPRNUMD ("+mess(3,40,1)-num$([BSIBPND2]LIN)+")" : Endif
    Rollback
  Else
    Commit
  Endif

  LogicClose File [BSIBPND2]
  LogicClose File [BSIBPND]
  LogicClose File [BSIBPN2]
  LogicClose File [BSIBPN]
End WOK

