#<AdxTL>@(#)0.0.0.0 $Revision$
# Mise à jour après calcul de coûts    SUBICU    (TB)
############################################# 
# Même ecran pour tous les types de coûts : ITCUPD0 [DIA]

$ACTION
Case ACTION
 When "INIT"        Gosub INIT
 When "OUVRE_BATCH" Gosub INIT  # depuis ARQTPAR (requête batch)
 When "CONTROLE"    TMP = 1
 When "EXEC"        Gosub EXEC
 When "TERMINE"     Gosub TERMINE
Endcase
Return

$INIT
Local Integer ITC_OK
Local Char    TIT_ECR  : TIT_ECR = mess(97,195,1) 

If !clalev([F:ITM])  : Local File ITMMASTER   [ITM]  : Endif
If !clalev([F:ITF])  : Local File ITMFACILIT  [ITF]  : Endif
If !clalev([F:ITG])  : Local File ITMCATEG    [ITG]  : Endif
If !clalev([F:TCM])  : Local File TABCOSTMET  [TCM]  : Endif
If !clalev([F:ITG])  : Local File ITMCATEG    [ITG]  : Endif
If !clalev ([F:ITC]) : Local File ITMCOST     [ITC]  : Endif
If !clalev([F:ITCW]) : Local File ITMCOST     [ITCW] : Endif
If !clalev([F:ICN])  : Local File ITCNAT      [ICN]  : Endif
If !clalev([F:ICNW]) : Local File ITCNAT      [ICNW] : Endif
If !clalev([F:ICC])  : Local File ITCMAT      [ICC]  : Endif
If !clalev([F:ICCW]) : Local File ITCMAT      [ICCW] : Endif
If !clalev([F:IWC])  : Local File ITCWST      [IWC]  : Endif
If !clalev([F:IWCW]) : Local File ITCWST      [IWCW] : Endif
If !clalev([F:ITV])  : Local File ITMMVT      [ITV]  : Endif
# CCC (13/08/07) Bug 42564
If GMODU(7)=2
    If !clalev([F:STJ])  : Local File STOJOU      [STJ]  : Endif # pour mvt variation valeur
    If !clalev([F:STJ1]) : Local File STOJOU      [STJ1] : Endif # pour mvt variation valeur
    If !clalev([F:ITH])  : Local File ITMMVTHIS   [ITH]  : Endif # pour mvt variation valeur
Endif
 
Return 

$EXEC
Local Char    CRIT_ICW(50)
Local Char    ERR_TRA(132)
Local Integer TYP_MAJ
Local Decimal OLD_CST
Local Date    OLD_DAT
Local Decimal PHY_STO      # pour l'interface des coûts std (29/03/01)

If !GSERVEUR
   Call OUVRE_TRACE(TIT_ECR) From LECFIC
Endif 

Call GETDEV([M]STOFCY) From DEVSUB : # pour récupérer GLOCALDEV pour arrondis

# Une transaction par type mis à jour 
# ----------------------------------- #

# Etablir le filtre selon les types choisis
If [M]STD = 2
    TYP_MAJ = 1
    Gosub MAJ_ITC
Endif
If [M]CUT = 2
    TYP_MAJ = 2
    Gosub MAJ_ITC
Endif
If [M]BUD = 2
    TYP_MAJ = 3
    Gosub MAJ_ITC
Endif
If [M]SIM = 2
    TYP_MAJ = 4
    Gosub MAJ_ITC
Endif
Return

$TERMINE
TRA = 1
If !GSERVEUR
   Call FERME_TRACE From LECFIC
Endif
Return


# ----------------------------------- #

$MAJ_ITC

Local Char TABCCE(GLONCCE)(GOPTCANA+1)

Trbegin [ITC]

# mise à jour des enreg qui ont Màj = différée
Filter [ITC] Where STOFCY=[M]STOFCY & CSTTYP=TYP_MAJ & CREUSR=GUSER & UID<>0 & UPDFLG=2
&            Order By Key ITC0 Desc
Raz ITC_OK
For [ITC]
    Call UPDITC(1,ITC_OK) From SUBICC
    If ITC_OK
        Break
    Endif
Next

If ITC_OK
    ERR_TRA = mess(13,100,1) - "ITMCOST:"-[F:ITC]ITMREF - num$([F:ITC]ITCSEQ)
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
Endif
If ITC_OK
    # retour erreur (bloquante) - transaction interrompue
    ERR_TRA = mess(14,100,1)
    # "T Y P E xxx : Le résultat est resté dans la table provisoire"
    ERR_TRA -= mess(TYP_MAJ,219,1)-":"- mess(134,197,1)
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    Rollback
Else
    Commit
Endif
Filter [ITC]
Return

###########################################################################################
#  Sous-prog d'actions sur zones d'écran
###########################################################################################
Subprog AP_STOFCY(VALEUR)
Variable Char VALEUR

# chercher quels types sont actuellement dans la table provisoire
Grizo STD,CUT,BUD,SIM

For [ITC] Where STOFCY = VALEUR & CSTTYP = 1 & CREUSR=GUSER & UID<>0 & UPDFLG=2
    Actzo STD
    Break
Next
For [ITC] Where STOFCY = VALEUR & CSTTYP = 2 & CREUSR=GUSER & UID<>0 & UPDFLG=2
    Actzo CUT
    Break
Next
For [ITC] Where STOFCY = VALEUR & CSTTYP = 3 & CREUSR=GUSER & UID<>0 & UPDFLG=2
    Actzo BUD
    Break
Next
For [ITC] Where STOFCY = VALEUR & CSTTYP = 4 & CREUSR=GUSER & UID<>0 & UPDFLG=2
    Actzo SIM
    Break
Next
End

Subprog D_STOFCY(VALEUR)
Variable Char VALEUR
VALEUR = GFCYDEF(0)
End

