#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion objet ALQ
Close Mask
Raz GPILOBJ,GNBMASKOUV
Call OBJET("ALQ",GBIDC1,GBIDC2) From GOBJET
End

#-----------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "FILTRE"    : Gosub FILTRE
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "LIENS"     : Gosub LIENS
 When "SETBOUT"   : Gosub SETBOUT
 When "EXEBOUT"   : Gosub EXEBOUT
 When "ANNULE"    : Gosub ANNULE
 When "AP_ANNULE" : Gosub AP_ANNULE
 When "VERIF_CRE" : Gosub VERIF
 When "VERIF_MOD" : Gosub VERIF
 When "CHANGE"    : Gosub CHANGE
Endcase
Return

#-----------------------------------------------------------#
$OUVRE
If clalev([F:ARV])=0  : Local File AREPORTV   [ARV]  : Endif
If clalev([F:ARX])=0  : Local File AREPORTX   [ARX]  : Endif
Local Integer VERIF_INTIT, VERIF_VALEUR,COLS , OKTRT
Gosub PFIX
Return

#-----------------------------------------------------------#
$SETBOUT
If !VERROU | !CLECUR | REP<>""
 Call VIREBOUT(CHAINE,"V2B") From GOBJET
Else
 Call EXISTE_ADX("","",PREFPRG+CLECUR1,OKTRT) From ORDSYS
 If !OKTRT
  Call VIREBOUT(CHAINE,"B") From GOBJET
 Endif
Endif
If [M]ENAFLG<>2
 Call VIREBOUT(CHAINE,"VB") From GOBJET
Endif
Return

#-----------------------------------------------------------#
$CHANGE
Gosub PFIX
Update [AXX] Where CODFIC="ALISTED" & ZONE = "INTITLIG" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ALISTED"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Update [AXX] Where CODFIC="ALISTEH" & ZONE = "INTIT"  & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ALISTEH"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Update [AXX] Where CODFIC="ALISTEH" & ZONE = "INTITSHO"  & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ALISTEH"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Update [ACB] Where CODBLB=IDCLOB &  IDENT1=[L]OCODE & IDENT2="" & IDENT3="" With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ACLOB ALISTEH"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("ACB",[L]OCODE) From GLOCK : Return
Endif
Return

#-----------------------------------------------------------#
$EXEBOUT
Case BOUT
 When "V"
  Gosub VERIF
  If VERIF_INTIT
   Call REQUETE(CLECUR1,nomap,OK)
   If GERR & dim([M:ALQ0]ENAFLG)>0
    Read [ALH]ALH0 = CLECUR1
    [M]ENAFLG = [F:ALH]ENAFLG
    Affzo [ALQ0]ENAFLG
    If dim([L]AUPDTICK)>0 & dim([F]updTick)>0
     [L]AUPDTICK = [F]updTick
    Endif
   Endif
  Endif
Endcase
Return

#-----------------------------------------------------------#
$FILTRE
FILTSUP = "TYP=2"
Return

#-----------------------------------------------------------#
$INICRE
$INIMOD
[F:ALH]TYP = 2
Return

#-----------------------------------------------------------#
$VERIF
VERIF_INTIT  = 0
VERIF_VALEUR = 0
COLS = 0
If [M]REPGRA >= 2
 For I=0 To [M]NBCOL-1
  If COLTIT <> "" : COLS +=1 : Endif
  If [M]GRA(I)= 3
   VERIF_INTIT += 1
  Endif
  If [M]GRA(I) = 1 | [M]GRA(I) = 2
   VERIF_VALEUR += 1
  Endif
 Next I
 If VERIF_VALEUR >= 1 & VERIF_INTIT = 1
  VERIF_INTIT = 1
 Else
  VERIF_INTIT = 0
 Endif
Else
 VERIF_INTIT = 1
Endif
If !COLS
 [M]REPGRA = 1
 Effzo [ALQ1]GRA : Effzo [ALQ1]REP
 Affzo [ALQ0]REPGRA
 Gosub GRISE_REPGRA
Endif
If [M]ENAFLG <> 2
 VERIF_INTIT = 1
Endif
If VERIF_INTIT = 0
 GMESSAGE = mess(128,139,1) : # Il faut au moins un champ de type libellé pour utiliser le graphisme
 OK = 0
Endif
Return

#-----------------------------------------------------------#
$CREATION
$MODIF
Readlock [ACB]ACB0 = IDCLOB;[M]COD;"";""
If fstat=1
 GOK =-1 : GLOCK = "$ACLOB"-IDCLOB-[M]COD : Return
Elsif fstat
 Raz [F:ACB]
 [F:ACB]CODBLB = IDCLOB
 [F:ACB]IDENT1 = [M]COD
 [F:ACB]CLOB   = [M]TEXTE
 [F:ACB]NAMBLB = [M]INTIT
 If dim([F:ACB]CREUSR)>0 : [F:ACB]CREUSR = GUSER : Endif
 If dim([F:ACB]CREDAT)>0 : [F:ACB]CREDAT = date$ : Endif
 If dim([F:ACB]CRETIM)>0 : [F:ACB]CRETIM = time  : Endif
 Write [ACB]
Else
 [F:ACB]CLOB = [M]TEXTE
 If dim([F:ACB]UPDUSR)>0 : [F:ACB]UPDUSR = GUSER : Endif
 If dim([F:ACB]UPDDAT)>0 : [F:ACB]UPDDAT = date$ : Endif
 If dim([F:ACB]UPDTIM)>0 : [F:ACB]UPDTIM = time  : Endif
 Rewrite [ACB]
Endif
If fstat
 GOK = 0 : Call FSTA("ACB") From GLOCK : Return
Endif
Delete [ALD] Where COD=[M]COD
If fstat=1
 GOK = -1 : GLOCK = "$ALISTED"-[M]COD : Return
Endif
For I=0 To [M]NBCOL-1
 Raz [F:ALD]
 [F:ALD]COD    = [M]COD
 [F:ALD]LIG    = I+1
 [F:ALD]NUMTEX = I+1
 [F:ALD]ORD    = I+1
 [F:ALD]CODTYP = [M]COLTYP(I)
 [F:ALD]NOLIB  = [M]COLNUM(I)
 [F:ALD]GRA    = [M]GRA(I)
 [F:ALD]REP    = [M]REP(I)
 Write [ALD]
 If fstat
  GOK = 0 : Call FSTA("ALD") From GLOCK : Break
 Endif
Next I
If GOK<>1 : Return : Endif
For I=0 To [M]NBPAR-1
 Raz [F:ALD]
 [F:ALD]COD    = [M]COD
 [F:ALD]LIG    = 100+I+1
 [F:ALD]NUMTEX = 100+I+1
 [F:ALD]ORD    = 100+I+1
 [F:ALD]CODTYP = [M]PARTYP(I)
 [F:ALD]NOLIB  = [M]PARNUM(I)
 [F:ALD]VALDEB = [M]VALDEB(I)
 Write [ALD]
 If fstat
  GOK = 0 : Call FSTA("ALD") From GLOCK : Break
 Endif
Next I
If GOK<>1 : Return : Endif
Call MAJTEXTRA([M]INTIT,"ALISTEH","INTIT",[M]COD,"") From ATEXTRA
Call MAJTEXTRA([M]INTITSHO,"ALISTEH","INTITSHO",[M]COD,"") From ATEXTRA

# Mise a jour valeur par defaut
For [ARV]ARV0 Where ETAT=[M]COD & TYPCOD=3
 Read [ALD]ALD0 = [ARV]ETAT;val([ARV]PARAM)
 If fstat
  Delete [ARV] Curr
  If fstat=1
   GOK=-1 : Call RSTA("ARV",[M]COD+"~"+[ARV]PARAM) From GLOCK : Break
  Endif
 Endif
Next
If GOK<>1 : Return : Endif

# Duplication
If GREP = "D"
 For I=0 To [M]NBCOL-1
  If [M]COLNUM2(I) <> 0
   Call DUPTEXTRA("ALISTED","INTITLIG",CLECUR1,num$([M]COLNUM2(I)),"ALISTED","INTITLIG",[M]COD,num$(I+1)) From ATEXTRA
  Endif
 Next I
 For I=0 To [M]NBPAR-1
  If [M]PARNUM2(I) <> 0
   Call DUPTEXTRA("ALISTED","INTITLIG",CLECUR1,num$([M]PARNUM2(I)+100),"ALISTED","INTITLIG",[M]COD,num$(I+100+1)) From ATEXTRA
  Endif
 Next I
 For I=0 To [M]NBPAR-1
  Call MAJTEXTRA([M]PARTIT(I),"ALISTED","INTITLIG",[M]COD,num$(I+1+100)) From ATEXTRA
  [M]PARNUM2(I) = I+1
 Next
 For I=0 To [M]NBCOL-1
  Call MAJTEXTRA([M]COLTIT(I),"ALISTED","INTITLIG",[M]COD,num$(I+1)) From ATEXTRA
  [M]COLNUM2(I) = I+1
 Next
 Return
Endif

# Mise a jour textes traduisibles des colonnes
For I=0 To [M]NBCOL-1
 If [M]COLNUM2(I) <> 0
  Call DUPTEXTRA("ALISTED","INTITLIG",[M]COD,num$([M]COLNUM2(I)),"ALISTED","INTITLIG",[M]COD,chr$(255)+num$(I+1)) From ATEXTRA
 Endif
Next I
For I=0 To [M]NBPAR-1
 If [M]PARNUM2(I) <> 0
  Call DUPTEXTRA("ALISTED","INTITLIG",[M]COD,num$([M]PARNUM2(I)+100),"ALISTED","INTITLIG",[M]COD,chr$(255)+num$(I+100+1)) From ATEXTRA
 Endif
Next I
Delete [AXX] Where CODFIC = "ALISTED" & ZONE = "INTITLIG" & IDENT1 = [M]COD & left$(IDENT2,1) <> chr$(255)
If fstat=1
 GOK=-1 : Call RSTA("AXX","ALISTED"-[M]COD) From GLOCK : Return
Endif
Update [AXX] Where CODFIC = "ALISTED" & ZONE = "INTITLIG" & IDENT1 = [M]COD & left$(IDENT2,1) = chr$(255)
&            With [AXX]IDENT2 = right$([AXX]IDENT2,2)
If fstat=1
 GOK=-1 : Call RSTA("AXX","ALISTED"-[M]COD) From GLOCK : Return
Endif
For I=0 To [M]NBPAR-1
 Call MAJTEXTRA([M]PARTIT(I),"ALISTED","INTITLIG",[M]COD,num$(I+1+100)) From ATEXTRA
 [M]PARNUM2(I) = I+1
Next
For I=0 To [M]NBCOL-1
 Call MAJTEXTRA([M]COLTIT(I),"ALISTED","INTITLIG",[M]COD,num$(I+1)) From ATEXTRA
 [M]COLNUM2(I) = I+1
Next
Return

#-----------------------------------------------------------#
$LIENS
[M]NBCOL = 0
[M]NBPAR = 0
For [ALD]ALD0 Where COD=[F:ALH]COD
 If [F:ALD]LIG<100
  Call LECTEXTRA([M]COLTIT([M]NBCOL),"ALISTED","INTITLIG",[F:ALH]COD,num$([F:ALD]LIG)) From ATEXTRA
  [M]COLTYP([M]NBCOL) = [F:ALD]CODTYP
  [M]COLNUM([M]NBCOL) = [F:ALD]NOLIB
  [M]GRA([M]NBCOL)    = [F:ALD]GRA
  [M]REP([M]NBCOL)    = [F:ALD]REP
  [M]COLNUM2([M]NBCOL) = [M]NBCOL + 1
  [M]NBCOL += 1
 Else
  Call LECTEXTRA([M]PARTIT([M]NBPAR),"ALISTED","INTITLIG",[F:ALH]COD,num$([F:ALD]LIG)) From ATEXTRA
  [M]PARTYP([M]NBPAR) = [F:ALD]CODTYP
  [M]PARNUM([M]NBPAR) = [F:ALD]NOLIB
  [M]VALDEB([M]NBPAR) = [F:ALD]VALDEB
  [M]PARNUM2([M]NBPAR) = [M]NBPAR+1
  [M]NBPAR += 1
 Endif
Next
Read [ACB]ACB0 = IDCLOB;[F:ALH]COD;"";""
If !fstat
 [M]TEXTE = [F:ACB]CLOB
Endif
Gosub GRISE_REPGRA
Gosub GRISE_TYPGRA
Return

#----------------------#
$GRISE_REPGRA
Case [M:ALQ0]REPGRA
 When 0,1 : # Caractère
  [M:ALQ0]OPTGRA = "" : [M:ALQ2]TYPGRA = 0 : [M:ALQ2]DEFGRA = 0
  Raz [M:ALQ2]IMAG
  Affzo [ALQ0]OPTGRA
  Affzo [ALQ2]TYPGRA, DEFGRA, IMAG
  Grizo [ALQ0]OPTGRA
  Grizo [ALQ2]TYPGRA, DEFGRA, IMAG
 When 2 : # Caractère ou graphique
  Actzo [ALQ0]OPTGRA
  Actzo [ALQ2]TYPGRA , DEFGRA, IMAG
 When 3 : # Caractère et graphique
  Actzo [ALQ0]OPTGRA
  Actzo [ALQ2]TYPGRA , DEFGRA, IMAG
 When 4 : # Graphique
  [M:ALQ0]OPTGRA = ""
  Affzo [ALQ0]OPTGRA
  Grizo [ALQ0]OPTGRA
  Actzo [ALQ2]TYPGRA , DEFGRA, IMAG
Endcase
Gosub AFF_OPTIONS
Return

#----------------------#
$AFF_OPTIONS
Case [M]REPGRA
 When 2
  [M:ALQ0]INTREPGRA = mess(164,139,1) : # Affichage par défaut
  [M:ALQ0]TYPREPGRA = "M"
  [M:ALQ0]LIBREPGRA = 2936
  [M:ALQ0]LNGREPGRA = 20
  [M:ALQ0]VALREPGRA = num$([M:ALQ0]AFFGRA)
  [M:ALQ0]OPTGRA = [M:ALQ0]VALREPGRA
  Call CHARGE([M:ALQ0]OPTGRA,[M:ALQ0]TYPREPGRA,[M:ALQ0]LIBREPGRA,[M:ALQ0]LNGREPGRA,[M:ALQ0]VALREPGRA)
& From FMTVAR
 When 3
  [M:ALQ0]INTREPGRA = mess(163,139,1) : # Position
  [M:ALQ0]TYPREPGRA = "M"
  [M:ALQ0]LIBREPGRA = 2931
  [M:ALQ0]LNGREPGRA = 20
  [M:ALQ0]VALREPGRA = num$([M:ALQ0]POSGRA)
  [M:ALQ0]OPTGRA = [M:ALQ0]VALREPGRA
  Call CHARGE([M:ALQ0]OPTGRA,[M:ALQ0]TYPREPGRA,[M:ALQ0]LIBREPGRA,[M:ALQ0]LNGREPGRA,[M:ALQ0]VALREPGRA)
& From FMTVAR
 When Default
  [M:ALQ0]INTREPGRA = ""
Endcase
Chgtzn [M:ALQ0]OPTGRA With [M:ALQ0]INTREPGRA
Return

#----------------------#
$GRISE_TYPGRA
Case [M:ALQ0]REPGRA
 When 0,1 : # Graphique
  [M:ALQ2]FSHGRA = 0
  Affzo [ALQ2]FSHGRA
  Grizo [ALQ2]FSHGRA
 When Default : # Caractère ou graphique/Caractère ou graphique/Graphique
  Case [M:ALQ2]TYPGRA
   When 1  : # Graphe Flash
    [M:ALQ2]FSHGRA = 0 : Affzo [ALQ2]FSHGRA : Grizo [ALQ2]FSHGRA
   When 2 : # Graphe multi Flash
    Actzo [ALQ2]FSHGRA
   When 4 : # XSL
    [M:ALQ2]FSHGRA = 0 : Affzo [ALQ2]FSHGRA : Grizo [ALQ2]FSHGRA
  Endcase
Endcase
Gosub AFF_IMAGE
Return

#----------------------#
$AFF_IMAGE
Local Char NOMIMAG(200) , IMAG1(20)
Case [M:ALQ2]TYPGRA
 When 1,2
  Case [M:ALQ2]DEFGRA
   When 1 : IMAG1="xbar"
   When 2 : IMAG1="xline"
   When 3 : IMAG1="xarea"
   When 4 : IMAG1="xpie"
   When 5 : IMAG1="xradar"
  Endcase
  If IMAG1<>""
   Case [M:ALQ2]FSHGRA
    When 1 : IMAG1+="m"
    When 2 : IMAG1+="cu"
    When 3 : IMAG1+="co"
   Endcase
  Endif
 When 3
  Case [M:ALQ2]FSHGRA
   When 4 : IMAG1="calmonth"
   When 5 : IMAG1="calweek"
   When 6 : IMAG1="calday"
  Endcase
 When 5
  IMAG1="gantt"
Endcase
Read [ASB]ASB0="SCR";toupper(IMAG1)
If !fstat
  [M:ALQ2]IMAG=[F:ASB]BLOB
Else
  Raz [M:ALQ2]IMAG
Endif
Return

#----------------------#
$PFIX
Local Char PREFPRG(5)
Local Char PREFMSK(5)
Local Char IDCLOB(10)
PREFPRG = "WMM"
PREFMSK = "WN"
IDCLOB  = "RQ_ALH"
Return

#----------------------#
Funprog PREF
Gosub PFIX
End IDCLOB

#--------------------------------------------------------------#
$ANNULE
Gosub PFIX
Delete [ACB] Where CODBLB=IDCLOB & IDENT1=CODE
If fstat=1
 GOK = -1 : GLOCK = "$ACLOB"-IDCLOB-CODE : Return
Endif
Return

#--------------------------------------------------------------#
$AP_ANNULE
If clalev([F:AXX])=0 : Local File =APPLI+".ATEXTRA" [AXX] : Endif
If clalev([F:ALR])=0 : Local File =APPLI+".ALISTER" [ALR] : Endif
Onerrgo RIEN
If dim([F:ALH]TYPENV)>0 & clalev([F:ALV])=0 : Local File =APPLI+".ALISTENV" [ALV] : Endif
Onerrgo

# Annulation des écrans, fenêtre, traitement
Gosub PFIX
Call DELMSK(PREFMSK+CODE,APPLI) From MSKDIV
Call DELWIN(PREFMSK+CODE,APPLI) From MSKDIV
Call EFFACE_ADX("",APPLI,PREFPRG+CODE,OK) From ORDSYS
Call EFFACE(filpath("TRT",PREFPRG+CODE,"src",APPLI),OK) From ORDSYS

# Suppresion texte traduisible
Trbegin [AXX]
 Delete [AXX] Where ((CODFIC="ALISTEH" | CODFIC="ALISTED")  & IDENT1=[L]CODE)
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK
 Endif
 Delete [ARV] Where TYPCOD=3 & ETAT = [L]CODE
 If fstat=1 | fstat>5
  GOK = -1 : Call RSTA("ARV",[L]CODE) From GLOCK
 Endif
 Delete [ARX] Where TYPCOD=3 & EXTCOD = [L]CODE
 If fstat=1 | fstat>5
  GOK = -1 : Call RSTA("ARX",[L]CODE) From GLOCK
 Endif
 Delete [ALR] Where COD=[L]CODE
 If fstat=1 | fstat>5
  GOK = -1 : Call RSTA("ALR",[L]CODE) From GLOCK
 Endif
 If dim([F:ALH]TYPENV)>0 & clalev([F:ALV])>0
  Delete [ALV] Where COD=[L]CODE
  If fstat=1 | fstat>5
   GOK = -1 : Call RSTA("ALV",[L]CODE) From GLOCK
  Endif
 Endif
Commit
Return

$RIEN
Resume

#------------------------------------------------------------------#
# Pg de mise à jour globale
#------------------------------------------------------------------#

Subprog GENDOS(APPLI)
Value Char APPLI
Local Integer OK
If APPLI<>nomap
 # Les requêtes SQL ne peuvent pas être validées à partir d'un autre dossier
 Call ECR_TRACE(mess(166,125,1),-1) From GESECRAN
 End
Endif
Onerrgo RIEN
Local File =APPLI+".ALISTER"  [ALR]
Local File =APPLI+".ALISTEH"  [ALH]
If dim([F:ALH]TYPENV)>0 : Local File =APPLI+".ALISTENV" [ALV] : Endif
Local File =APPLI+".ALISTED"  [ALD]
Local File =APPLI+".AMSK"     [AMK]
Local File =APPLI+".AMSKZON"  [AMZ]
Local File =APPLI+".AMSKACT"  [AMA]
Local File =APPLI+".AMSKPAR"  [AMP]
Local File =APPLI+".AWINDOW"  [AWI]
Local File =APPLI+".AWINBRO"  [AWB]
Local File =APPLI+".AWINBOUT" [AWT]
Local File =APPLI+".AWINPAR"  [AWP]
Local File =APPLI+".ATYPE"    [ATY]
Local File =APPLI+".AOBJET"   [AOB]
Local File =APPLI+".ACLOB"    [ACB]
Local File =APPLI+".ACTION"   [ACT] # Bug 81145
Local File =APPLI+".ACTPAR"   [ATR] # Bug 81145
Onerrgo
For [ALH]ALH0 Where TYP=2 & ENAFLG=2
 Call ECR_TRACE([F:ALH]COD,0) From GESECRAN
 Call REQUETE([F:ALH]COD,APPLI,OK)
Next
End

#-----------------------------------------------------------------------------#
Subprog REQUETE(REQUETE,APPLI,OK)
Value    Char    REQUETE
Value    Char    APPLI
Variable Integer OK

Local Integer MAXCOL , MAXLIG
MAXCOL = 250
MAXLIG = 1000 : # bug passage de  500 à 1000 : 85780
Local Integer I , J , K , L , ERR , MOK , BLCREF
Local Integer BASE
Local Integer NBLIG , TYP(250) , OKTYP , NBRCOL
Local Char    LIGNE(250)(1..MAXLIG) , TEXTE(250)(1..MAXLIG) , TEXANA(250)(1..MAXLIG)
Local Char    TIT(10)(0..MAXCOL) , CODTYP(GLONATY)(0..MAXCOL) , GENTYP(GLONATY) , VARGLB(GLONAGB)
Local Integer GRA(0..MAXCOL),REP(0..MAXCOL)
Local Char    PARTIT(10)(1..MAXCOL) , PARTYP(GLONATY)(1..MAXCOL) , PARDEF(120)(1..MAXCOL)
Local Integer NOLIB(0..MAXCOL) , PARLIB(1..MAXCOL)
Local Char    SAVIFS(5) , SAVIRS(5) , CHAINE(250)
Local Integer SAVIUM
Local Char    MASKREF(GLONAMK) , MASKDES(GLONAMK)
Local Char    FENREF(GLONFEN) , FENDES(GLONFEN)
Local Char    TRTDES(GLONADC) , TRAIT(250) , INTRQT(40)
Local Clbfile CLOB(12)

Onerrgo RIEN
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If clalev([F:ALR])=0 : Local File =APPLI+".ALISTER"  [ALR] : Endif
#CHECK UNUSED_BEGIN
If dim([F:ALH]TYPENV)>0 & clalev([F:ALV])=0 : Local File =APPLI+".ALISTENV" [ALV] : Endif
#CHECK UNUSED_END
If clalev([F:ALD])=0 : Local File =APPLI+".ALISTED"  [ALD] : Endif
If clalev([F:AMK])=0 : Local File =APPLI+".AMSK"     [AMK] : Endif
If clalev([F:AMZ])=0 : Local File =APPLI+".AMSKZON"  [AMZ] : Endif
If clalev([F:AMA])=0 : Local File =APPLI+".AMSKACT"  [AMA] : Endif
If clalev([F:AMP])=0 : Local File =APPLI+".AMSKPAR"  [AMP] : Endif
If clalev([F:AWI])=0 : Local File =APPLI+".AWINDOW"  [AWI] : Endif
If clalev([F:AWB])=0 : Local File =APPLI+".AWINBRO"  [AWB] : Endif
If clalev([F:AWT])=0 : Local File =APPLI+".AWINBOUT" [AWT] : Endif
If clalev([F:AWP])=0 : Local File =APPLI+".AWINPAR"  [AWP] : Endif
If clalev([F:ATY])=0 : Local File =APPLI+".ATYPE"    [ATY] : Endif
If clalev([F:AOB])=0 : Local File =APPLI+".AOBJET"   [AOB] : Endif
If clalev([F:ACB])=0 : Local File =APPLI+".ACLOB"    [ACB] : Endif
If clalev([F:AGB])=0 : Local File =APPLI+".AGLOBVAR" [AGB] : Endif
If clalev([F:ACT])=0 : Local File =APPLI+".ACTION"   [ACT] : Endif # Bug 81145
If clalev([F:ATR])=0 : Local File =APPLI+".ACTPAR"   [ATR] : Endif # Bug 81145
Onerrgo

OK = 1
Gosub PFIX
MASKREF = "VISUSQL"
MASKDES = PREFMSK+REQUETE
FENREF  = "VISUSQL"
FENDES  = PREFMSK+REQUETE
TRTDES  = PREFPRG+REQUETE
INTRQT  = mess(278,139,1)-REQUETE : # Requête SQL

Read [ADS]DOSSIER = APPLI
Case [F:ADS]TYPDBA
 When 1 : BASE = 3 : # Oracle
 When 2 : BASE = 5 : # Sql
 When 3 : BASE = 2 : # Cisam
 When 4 : BASE = 4 : # DB2
Endcase

Read [ACB]ACB0 = IDCLOB;REQUETE;"";""
If fstat
 OK = 0 : Call ECR_TRACE(INTRQT-":"-mess(81,139,1),1) From GESECRAN : # Requête vide
 Gosub DESACTIVE : Goto FIN
Endif

# Mise en forme du clob (commentaires en moins, tab et CR et espace)

Gosub SET_CLOB

# Remplacer les formules

NBRCOL = 0
For [ALD] Where COD=REQUETE
 If [F:ALD]LIG<100
  TIT([F:ALD]LIG)    = num$([F:ALD]LIG)
  CODTYP([F:ALD]LIG) = [F:ALD]CODTYP
  NOLIB([F:ALD]LIG)  = [F:ALD]NOLIB
  GRA([F:ALD]LIG)    = [F:ALD]GRA
  REP([F:ALD]LIG)    = [F:ALD]REP
  NBRCOL += 1
 Else
  PARTIT([F:ALD]LIG-100) = num$([F:ALD]LIG)
  PARTYP([F:ALD]LIG-100) = [F:ALD]CODTYP
  PARLIB([F:ALD]LIG-100) = [F:ALD]NOLIB
  PARDEF([F:ALD]LIG-100) = [F:ALD]VALDEB
 Endif
Next ALD

Repeat
 K = instr(K+1,CLOB,"%")
 If K
  L = instr(K+1,CLOB,"%")
  If L>K
   GENTYP = ""
   VARGLB = seg$(CLOB,K+1,L-1)
   If instr(1,VARGLB,"(")
    VARGLB = left$(VARGLB,instr(1,VARGLB,"(")-1)
   Endif
   Read [AGB]AGB0=VARGLB
   If !fstat
    GENTYP = [F:AGB]CODTYP
   Elsif L<K+4
    VARGLB = ""
    J = val(seg$(CLOB,K+1,L-1))
    If J>0 & J<=dim(PARTYP)
     If PARTYP(J)="" : # Ce n'est pas un paramètre
      GENTYP = ""
     Else
      GENTYP = PARTYP(J)
     Endif
    Endif
   Endif
   If GENTYP<>""
    Read [ATY]CODTYP=GENTYP
    If fstat
     # Type de données incorrect
     Call ECR_TRACE(INTRQT-":"-"%"+num$(J)+"%"-mess(14,133,1)-":"-GENTYP,1) From GESECRAN
     OK = 0 : Break
    Endif
    Case [F:ATY]TYPTYP
     When 1,2,3,4,5,6
      CLOB = left$(CLOB,K-1)+"0"+right$(CLOB,L+1)
     When 7
      If mid$(CLOB,K-1,1)="%" & mid$(CLOB,L+1,1)="%" : # Cas du 'like'
       CLOB = left$(CLOB,K-1)+"A"+right$(CLOB,L+1)
      Else
       CLOB = left$(CLOB,K-1)+"'A'"+right$(CLOB,L+1)
      Endif
     When 8
      If BASE=3 : # Oracle
       CLOB = left$(CLOB,K-1)+"to_date('20000101','YYYYMMDD')"+right$(CLOB,L+1)
      Else      : # Sql
       CLOB = left$(CLOB,K-1)+"convert(datetime,'20000101',112)"+right$(CLOB,L+1)
      Endif
    Endcase
    K = L
   Endif
  Endif
 Endif
Until K=0
If !OK : Gosub DESACTIVE : Goto FIN : Endif

Gosub TRF_CLOB_TO_TEXTE

If vireblc(CLOB,2)=""
 OK = 0 : Call ECR_TRACE(INTRQT-":"-mess(81,139,1),1) From GESECRAN : # Requête vide
 Gosub DESACTIVE : Goto FIN
Endif

If adxmac(-2)="pc018948.sagefr.adinternal.com" & 1=1
 Call OUVRE_TRACE("rqt sql") From LECFIC
 For I=1 To NBLIG
  Call ECR_TRACE(num$(I)-TEXTE(I),0) From GESECRAN
 Next I
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif

# On teste la requête

ERR = 0
If APPLI=nomap
 Onerrgo ERRSQL
 Anasql From num$(BASE) Sql TEXTE(1..NBLIG) Using TYP
 Onerrgo
 If ERR : OK = 0 : Gosub DESACTIVE : Goto FIN : Endif
 If [L]NBRCOL>0 & [L]NBRCOL<>TYP(0)
  Call ECR_TRACE(INTRQT-":"-mess(120,133,1),1) From GESECRAN
  # Le nombre de colonnes de la requête ($1$) ne correspond pas avec le nombre de colonnes avec un titre ($2$)
  Call ECR_TRACE(func AFNC.MES2(mess(121,143,1),num$(TYP(0)),num$([L]NBRCOL)),0) From GESECRAN
  OK = 0 : Gosub DESACTIVE : Goto FIN
 Endif
 If TYP(0)>150 : TYP(0) = 150 : Endif : # mb 8.6.12 bug 82517
Endif

# Chargement du clob

Gosub SET_CLOB
Gosub TRF_CLOB_TO_TEXTE

Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1 : OK = 0 : Goto FIN : Endif

# Validation écran
Call VALID(MASKDES,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,MOK) From VALMSK
If !MOK : OK = 0 : Goto FIN : Endif

# Validation fenêtre
Call VALID(FENDES,APPLI,1,MOK) From VALWIN
If !MOK : OK = 0 : Goto FIN : Endif

Call TEMPON(mess(159,133,1)-TRTDES) From GESECRAN : # Validation du traitement
If GTRACE<>""
 Call ECR_TRACE(INTRQT-"->"-mess(159,133,1)-TRTDES,0) From GESECRAN
Endif

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

TRAIT = filpath("TRT",TRTDES,"src",APPLI)
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Openo TRAIT,0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "$PARAM"
Wrseq "Local Char    PARTIT(30)(1.."+num$(dim(PARTIT))+") , PARTYP(GLONATY)(1.."+num$(dim(PARTIT))+")"
Wrseq "Local Char    PARDEF(120)(1.."+num$(dim(PARTIT))+")"
Wrseq "Local Integer PARLIB(1.."+num$(dim(PARTIT))+")"
Wrseq "Local Integer BASE"
For I=1 To dim(PARTIT)
 If PARTIT(I)<>""
  Wrseq 'PARTIT('+num$(I)+') = func AFNC.TEXTRA("ALISTED","INTITLIG","'+[F:ALH]COD+'","'+num$(I+100)+'")'
  Wrseq 'PARTIT('+num$(I)+') = ctrans(PARTIT('+num$(I)+'),'+"'"+'"'+"',"+'"'+"'"+'")'
  Wrseq 'PARTYP('+num$(I)+') = "'+PARTYP(I)+'"'
  Wrseq 'PARLIB('+num$(I)+') = '+num$(PARLIB(I))
  Wrseq 'PARDEF('+num$(I)+') = "'+ctrans(PARDEF(I),'"','¨')+'"'
 Endif
Next I
Wrseq "BASE = ";BASE
Wrseq "Return"
Wrseq
Wrseq "$LECTURE"
Wrseq "Local Integer I , J , K , L , ER , TIM , DEPLIG , DEPTIM"
Wrseq "Local Char    TEXTE(250)(1.."+num$(NBLIG)+") , GENTYP("+num$(GLONATY)+") , VARGLB("+num$(GLONAGB)+")"
Wrseq "Local Clbfile CLOB(12)"
For I=1 To NBLIG
 Wrseq 'TEXTE('+num$(I)+') = "';TEXTE(I);'"'
Next I
Wrseq 'Gosub PARAM'
Wrseq 'Gosub REMPLACE_CLOB From VISUSQL'
Wrseq 'Gosub ENVALR From VISUSQL'
Wrseq '[F:ALR]COD = "';REQUETE;'"'
Wrseq '[F:ALR]USR = UTIL'
Wrseq '[F:ALR]NIV = 1'
Wrseq '[F:ALR]CREDAT = date$'
Wrseq 'If dim([F:ALR]CRETIM)>0 : [F:ALR]CRETIM = left$(time$,2)+mid$(time$,4,2) : Endif'
Wrseq "K      = 0"
Wrseq "TIM    = time"
Wrseq "DEPLIG = 0"
Wrseq "DEPTIM = 0"
Wrseq "Onerrgo ERREUR"
Wrseq "ER = 0"
Wrseq "For ("
For I=1 To min(TYP(0),dim(CODTYP))
 Wrseq "& ";
 If I>1
  Wrseq ",";
 Else
  Wrseq " ";
 Endif
 Case TYP(I)
  When 1,2
   Wrseq "Integer  C"+num$(I);
  When 4,5,6,7,8,9
   Wrseq "Decimal  C"+num$(I);
  When 3
   Wrseq "Date     C"+num$(I);
  When 522
   Wrseq "Blbfile  C"+num$(I);
  When 523
   Wrseq "Clbfile  C"+num$(I);
  When Default
   Wrseq "Char     C"+num$(I)+"("+num$((TYP(I)<12)*29+min(TYP(I)-10,255))+")"; :#SAM122358
 Endcase
 Wrseq
Next I
Wrseq "& ) From '";num$(BASE);"' Sql TEXTE(1..";num$(NBLIG);") As [SQL0]"
Wrseq "If ER : Break : Endif"
Wrseq " K += 1"
If [F:ALH]MAXLIG<>0
 Wrseq " If K>";[F:ALH]MAXLIG
 Wrseq "  DEPLIG = 1 : Break"
 Wrseq " Endif"
Endif
If [F:ALH]MAXTIM<>0
 Wrseq " If time>TIM+";[F:ALH]MAXTIM
 Wrseq "  DEPTIM = 1 : Break"
 Wrseq " Endif"
Endif
Wrseq ' [F:ALR]LIG = K'
For I=1 To min(TYP(0),dim(CODTYP))
 Wrseq ' [F:ALR]COL = ';num$(I)
 Case TYP(I)
  When 1,2
   Wrseq ' [F:ALR]TYP = 2'
   Wrseq ' [F:ALR]NUM = [F:SQL0]C';num$(I)
  When 3
   Wrseq ' [F:ALR]TYP = 8'
   Wrseq ' [F:ALR]DAT = [F:SQL0]C';num$(I)
  When 4
   Wrseq ' [F:ALR]TYP = 3'
   Wrseq ' [F:ALR]NUM = [F:SQL0]C';num$(I)
  When 5,6,7,8,9
   Wrseq ' [F:ALR]TYP = 4'
   Wrseq ' [F:ALR]NUM = [F:SQL0]C';num$(I)
  When 522
   Wrseq ' [F:ALR]TYP = 9'
  When 523
   Wrseq ' [F:ALR]TYP = 10'
  When Default
   Wrseq ' [F:ALR]TYP = 7'
   Wrseq ' [F:ALR]VLR = [F:SQL0]C';num$(I)
 Endcase
 Wrseq ' Write [ALR]'
 Wrseq ' If fstat'
 Wrseq '  GOK = 0 : Call FSTA("ALR") From GLOCK : Break'
 Wrseq ' Endif'
Next I
If GPRODUIT=1 : ## GEODE
 I=find("FCY",CODTYP(1..99))
 If I>0
  Wrseq ' [F:ALR]COL = -1'
  Wrseq ' [F:ALR]TYP = 7'
  Wrseq ' [F:ALR]VLR = [F:SQL0]C';num$(I)
  Wrseq ' Write [ALR]'
  Wrseq ' If fstat'
  Wrseq '  GOK = 0 : Call FSTA("ALR") From GLOCK : Break'
  Wrseq ' Endif'
 Endif
 I=find("DEP",CODTYP(1..99))
 If I>0
  Wrseq ' [F:ALR]COL = -2'
  Wrseq ' [F:ALR]TYP = 7'
  Wrseq ' [F:ALR]VLR = [F:SQL0]C';num$(I)
  Wrseq ' Write [ALR]'
  Wrseq ' If fstat'
  Wrseq '  GOK = 0 : Call FSTA("ALR") From GLOCK : Break'
  Wrseq ' Endif'
 Endif
Endif
Wrseq "Next SQL0"
Wrseq "Onerrgo"
Wrseq "Return"
Wrseq
Wrseq "$ERREUR"
Wrseq "ER = errn"
Wrseq 'Call ERREUR(errmes$(errn)-errm+"\"+sum(TEXTE)) From GESECRAN'
Wrseq "Resume"
Wrseq
Wrseq "$TIT"
Wrseq "Local Char    TIT(30)"
Wrseq 'TIT(0) = Func AFNC.TEXTRA("ALISTEH","INTIT","'+[F:ALH]COD+'","")'
Wrseq "Return"
Wrseq
Wrseq "$DEFVAR"
Wrseq "Local Integer NBCOL"
Wrseq "Local Integer TYP(1..";TYP(0);")"
Wrseq "Local Decimal LONG(1..";TYP(0);")"
Wrseq "Local Integer NOLIB(1..";TYP(0);")"
Wrseq "NBCOL = ";TYP(0)
For I=1 To min(TYP(0),dim(CODTYP))
 TYPCOD = CODTYP(I)
 If CODTYP(I)<>""
  Read [ATY]CODTYP = CODTYP(I)
  Wrseq "TYP("+num$(I)+") = ";[F:ATY]TYPTYP
  Wrseq "NOLIB("+num$(I)+") = ";NOLIB(I)
  If [F:ATY]LNGTYP<>0
   Wrseq "LONG("+num$(I)+") = ";[F:ATY]LNGTYP
  Else
   Case [F:ATY]TYPTYP
    When 1 : # Menu local
     Case NOLIB(I)
      When 1       : Wrseq "LONG("+num$(I)+") = 4"
      When Default : Wrseq "LONG("+num$(I)+") = 15"
     Endcase
    When 2         : Wrseq "LONG("+num$(I)+") = 5"   : # Entier court
    When 3         : Wrseq "LONG("+num$(I)+") = 8"   : # Entier long
    When 4         : Wrseq "LONG("+num$(I)+") = 9.2" : # Décimal
    When 5,6       : Wrseq "LONG("+num$(I)+") = 0"   : # Flottant/double
    When 7         : Wrseq "LONG("+num$(I)+") = ";min(TYP(I)-10,255)+29*(TYP(I)<12) : # Alpha SAM 122358
    When 8         : Wrseq "LONG("+num$(I)+") = 2"   : # Date
    When 9,10      : Wrseq "LONG("+num$(I)+") = 9"   : # Blob/Clob
   Endcase
  Endif
 Else
  Case TYP(I)
   When 1         : Wrseq "TYP("+num$(I)+") = 1"
   When 2         : Wrseq "TYP("+num$(I)+") = 2"
   When 3         : Wrseq "TYP("+num$(I)+") = 8"
   When 4         : Wrseq "TYP("+num$(I)+") = 3"
   When 5,6,7,8,9 : Wrseq "TYP("+num$(I)+") = 4"
   When 522       : Wrseq "TYP("+num$(I)+") = 9"
   When 523       : Wrseq "TYP("+num$(I)+") = 10"
   When Default   : Wrseq "TYP("+num$(I)+") = 7"
  Endcase
  Case TYP(I)
   When 1         : Wrseq "LONG("+num$(I)+") = 2"
   When 2         : Wrseq "LONG("+num$(I)+") = 4"
   When 3         : Wrseq "LONG("+num$(I)+") = 2"
   When 4         : Wrseq "LONG("+num$(I)+") = 8"
   When 5,6,7,8,9 : Wrseq "LONG("+num$(I)+") = 9.2"
   When 522,523   : Wrseq "LONG("+num$(I)+") = 9"
   When Default   : Wrseq "LONG("+num$(I)+") = ";min(TYP(I)-10,255)
  Endcase
 Endif
Next I
Wrseq "Return"
Wrseq
Wrseq "$BOUTONS"
K = 0
Wrseq "Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8"
For I=1 To min(TYP(0),dim(CODTYP))
 If CODTYP(I)<>""
  Read [ATY]CODTYP = CODTYP(I)
  If [F:ATY]OBJLIEN<>""
   Read [AOB]ABREV = [F:ATY]OBJLIEN
   K += 1
   If find([F:ATY]TYPTYP,1,2,3,4,5,6)
    Wrseq "If [M:LST]C"+num$(I)+'(nolign-1) > 0 '
   Elsif find([F:ATY]TYPTYP,8)
    Wrseq "If [M:LST]C"+num$(I)+'(nolign-1) > [0/0/0] '
   Else
    Wrseq "If [M:LST]C"+num$(I)+'(nolign-1) <> "" '
   Endif
   Wrseq " Call TEXTE("+num$([F:AOB]LIBEL)+",GBOUT"+num$(K)+") From OBJDIV"
   Wrseq ' [M:LST]TUNNEL('+num$(K)+') = "'+[F:AOB]ABREV+'"'
   Wrseq ' [M:LST]TUNZON('+num$(K)+') = '+num$(I)
   Wrseq 'Endif'
   If K>=8 : Break : Endif
  Endif
 Endif
Next
Wrseq "Return"
Openo

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

Call TEMPOFF From GESECRAN

# Validation du traitement
Call VALID("TRT",TRTDES,APPLI,MOK) From VALMSKSUB
If !MOK : OK = 0 : Goto FIN : Endif

Trbegin [ALR]
 Delete [ALR] Where COD=REQUETE
 If clalev([F:ALV])>0 & dim([F:ALH]TYPENV)>0 : Delete [ALV] Where COD=REQUETE : Endif
Commit

$FIN
If !OK
 GERR = 1
Endif
End

#-----------------------------#
$ERRSQL
ERR = 1
CHAINE = errmes$(errn)+"\"+errm+"\"+sum(TEXANA)
# Requête incorrecte
Call ECR_TRACE(INTRQT-":"-mess(120,133,1),1) From GESECRAN
Call ECR_TRACE(CHAINE,0) From GESECRAN
Resume

#-----------------------------------------#
$SET_CLOB

CLOB = [F:ACB]CLOB

# Pour enlever les commentaires

If left$(CLOB,1)="#"
 J = 1
Else
 J = instr(1,CLOB,chr$(10)+"#")
Endif
While J
 K = instr(J+2,CLOB,chr$(10))
 If K
  CLOB = left$(CLOB,J-1)+right$(CLOB,K)
 Endif
 J = instr(1,CLOB,chr$(10)+"#")
Wend

# On enlève les CR

I = instr(1,CLOB,chr$(13))
While I
 CLOB = left$(CLOB,I-1)+right$(CLOB,I+1)
 I = instr(1,CLOB,chr$(13))
Wend

# On remplace les tab par un espace

CLOB = ctrans(CLOB,chr$(9)," ")

Return

#----------------------------------------#
$TRF_CLOB_TO_TEXTE

# On met dans TEXTE en remplaçant les chr$(10) par un " "

Setlob TEXANA With CLOB
NBLIG = 0
For I=1 To dim(TEXANA)
 While TEXANA(I)<>""
  K = instr(1,TEXANA(I),chr$(10))
  If K
   NBLIG += 1
   TEXTE(NBLIG) = left$(TEXANA(I),K-1)+" "
   TEXANA(I) = right$(TEXANA(I),K+1)
  Else
   NBLIG += 1
   TEXTE(NBLIG) = TEXANA(I)
   TEXANA(I) = ""
  Endif
 Wend
Next I

Return

#--------------------------------------------------------------#
## Désactivation d'une liste en erreur
#--------------------------------------------------------------#

$DESACTIVE
If !adxlog
 Gosub TR_LISTE
Else
 Gosub MAJ_LISTE
Endif
If GOK=1
 Call ECR_TRACE(INTRQT-":"-mess(62,139,1),-1) From GESECRAN : # Fiche désactivée
Endif
Return

$TR_LISTE
GOK=1
Trbegin [ALH]
 Gosub MAJ_LISTE
 If GOK<0 : Goto AB_TR_LISTE : Endif
Commit
Return

$AB_TR_LISTE
Rollback
Return

$MAJ_LISTE
Readlock [ALH]ALH0 = REQUETE
If fstat=1
 GOK = -1 : GLOCK = "$ALISTEH"
Else
 [F:ALH]ENAFLG = 1
 Rewrite [ALH]
 If fstat
  GOK = 0 : Call FSTA("ALH") From GLOCK
 Endif
Endif
Return

#-----------------------------#
$TR1
GOK = 1
Trbegin [AMK] , [AMZ]
 Delete [AMK] Where CODMSK=MASKDES
 If fstat=1
  GOK = -1 : GLOCK = "$AMSK"-MASKDES : Goto ROLL_TR1
 Endif
 Delete [AMZ] Where CODMSK=MASKDES
 If fstat=1
  GOK = -1 : GLOCK = "$AMSKZON"-MASKDES : Goto ROLL_TR1
 Endif
 Delete [AMA] Where TYPAFF=1 & CODAFF=MASKDES
 If fstat=1
  GOK = -1 : GLOCK = "$AMSKACT"-MASKDES : Goto ROLL_TR1
 Endif
 Delete [AMP] Where TYPAFF=1 & CODAFF=MASKDES
 If fstat=1
  GOK = -1 : GLOCK = "$AMSKPAR"-MASKDES : Goto ROLL_TR1
 Endif
 Read [AMK]CODMSK = MASKREF
 [F:AMK]CODMSK = MASKDES
 For [AMZ]CODE Where CODMSK=MASKREF
  [F:AMZ]CODMSK = MASKDES
  Write [AMZ]
  If fstat
   GOK = 0 : Call FSTA("AMZ") From GLOCK : Break
  Endif
  If [F:AMZ]CODZON="NBLIG"
   BLCREF = [F:AMZ]NUMBLOC
  Endif
 Next
 If GOK=0 : Goto AB_TR1 : Endif
 For I=1 To min(TYP(0),dim(CODTYP))
  Raz [F:AMZ]
  [F:AMZ]CODMSK = MASKDES
  [F:AMZ]CODZON = "C"+num$(I)
  OKTYP = 0
  TYPCOD = CODTYP(I)
  If TYPCOD<>""
   Read [ATY]CODTYP = TYPCOD
   If !fstat
    If ([F:ATY]TYPTYP=7 & TYP(I)>10)
&    | ([F:ATY]TYPTYP=8 & TYP(I)=3)
&    | ([F:ATY]TYPTYP=1 & TYP(I)=1)
&    | ([F:ATY]TYPTYP=2 & TYP(I)<=2)
&    | ([F:ATY]TYPTYP=3 & find(TYP(I),1,2,4))
&    | ([F:ATY]TYPTYP=4 & find(TYP(I),1,2,4,7))
     OKTYP=1
    Endif
    # Bug 81145
    For J=0 To [F:ATY]NBTYP-1
     If [F:ATY]ACTION(J)<>""
      Filter [ATR] Where ACTION = [F:ATY]ACTION(J)
      If rowcount([F:ATR]) = 1
       Read [ACT]ACTION = [F:ATY]ACTION(J)
       If !fstat
        If [ACT]TYPACT <> 2 : OKTYP=0 : Break : Endif
       Endif
      Elsif rowcount([F:ATR]) > 1
       OKTYP=0
      Endif
     Endif
    Next J
    # End Bug 81145
    Filter [ATR]
   Endif
  Endif
  If OKTYP
   [F:AMZ]CODTYP = TYPCOD
   If [F:ATY]LNGTYP=0
    Case TYP(I)
     When 1         : [F:AMZ]LONG = 2
     When 2         : [F:AMZ]LONG = 4
     When 3         : [F:AMZ]LONG = 0
     When 4         : [F:AMZ]LONG = 8
     When 5,6,7,8,9 : [F:AMZ]LONG = 9.2
     When 522,523   : [F:AMZ]LONG = 9
     When Default   : [F:AMZ]LONG = (TYP(I)<12)*29+min(TYP(I)-10,255) :#SAM 122358
    Endcase
   Else
    [F:AMZ]LONG = [F:ATY]LNGTYP
   Endif
   If left$([F:ATY]FORTYP,1)="="
    Case TYP(I)
     When 1         : [F:AMZ]CODTYP = "L"
     When 2         : [F:AMZ]CODTYP = "L"
     When 3         : [F:AMZ]CODTYP = "D"
     When 4         : [F:AMZ]CODTYP = "L"
     When 5,6,7,8,9 : [F:AMZ]CODTYP = "DCB" : [F:AMZ]LONG = 15 : [F:AMZ]OPTSAI += "3zF"
     When 522       : [F:AMZ]CODTYP = "ABB"
     When 523       : [F:AMZ]CODTYP = "ACB"
     When 525       : [F:AMZ]CODTYP = "AUUID"  : [F:AMZ]LONG = 0 # Bug 81145
     When 526       : [F:AMZ]CODTYP = "ADATIM" : [F:AMZ]LONG = 0 # Bug 81145
     When Default   : [F:AMZ]CODTYP = "A"
    Endcase
   Endif
   If TYPCOD="M"
    [F:AMZ]NOLIB = NOLIB(I)
    Case NOLIB(I)
     When 1         : [F:AMZ]LONG = 4
     When Default   : [F:AMZ]LONG = 15
    Endcase
   Endif
  Else
   Case TYP(I)
    When 1         : [F:AMZ]CODTYP = "L"   : [F:AMZ]LONG = 2
    When 2         : [F:AMZ]CODTYP = "L"   : [F:AMZ]LONG = 4
    When 3         : [F:AMZ]CODTYP = "D"   : [F:AMZ]LONG = 0
    When 4         : [F:AMZ]CODTYP = "L"   : [F:AMZ]LONG = 8
    When 5,6,7,8,9 : [F:AMZ]CODTYP = "DCB" : [F:AMZ]LONG = 9.2
    When 522       : [F:AMZ]CODTYP = "ABB" : [F:AMZ]LONG = 1
    When 523       : [F:AMZ]CODTYP = "ACB" : [F:AMZ]LONG = 1
    When 525       : [F:AMZ]CODTYP = "AUUID"  : [F:AMZ]LONG = 0 # Bug 81145
    When 526       : [F:AMZ]CODTYP = "ADATIM" : [F:AMZ]LONG = 0 # Bug 81145
    When Default   : [F:AMZ]CODTYP = "A"   : [F:AMZ]LONG = min(TYP(I)-10,255)
   Endcase
  Endif
  [F:AMZ]INTEVAL = 'func AFNC.TEXTRA("ALISTED","INTITLIG","'+REQUETE+'","'+num$(I)+'")'
  [F:AMZ]NUMBLOC = BLCREF
  [F:AMZ]NUMLIG = I+10
  [F:AMZ]NOZONE = I+10
  [F:AMZ]PDSZON = 1
  [F:AMZ]SAIAFF = 2
  [F:AMZ]TYPGRAPH = 1
  [F:AMZ]MODE = 1
  [F:AMZ]DIME = [F:AMK]NBLIGT(0)
  Case [L]GRA(I)
   When 1       : [F:AMZ]CHPARG = "G01:VALUE"
   When 2       : [F:AMZ]CHPARG = "G02:DEF"
   When 3       : [F:AMZ]CHPARG = "G03:LIB"
   When Default : [F:AMZ]CHPARG = ""
  Endcase
  [F:AMZ]CHREPR  = [L]REP(I)
  Write [AMZ]
  If fstat
   GOK = 0 : Call FSTA("AMZ") From GLOCK : Break
  Endif
 Next I
 If GOK=0 : Goto AB_TR1 : Endif
 If [F:ALH]NBRCOL<>0
  For I=1 To 9
   J = instr(1,[F:AMK]OPTION(BLCREF-1),num$(I))
   If J
    [F:AMK]OPTION(BLCREF-1) = left$([F:AMK]OPTION(BLCREF-1),J-1)+right$([F:AMK]OPTION(BLCREF-1),J+1)
   Endif
  Next I
  [F:AMK]OPTION(BLCREF-1) += num$([F:ALH]NBRCOL)
 Endif
 If [F:ALH]NBRLIG<>0
  [F:AMK]NBLIGT(BLCREF-1) = [F:ALH]NBRLIG
 Endif
 [F:AMK]MDL = 1
 [F:AMK]BLOCTYPT(BLCREF-1) = [F:ALH]REPGRA
 [F:AMK]BLOCTYPG(BLCREF-1) = [F:ALH]TYPGRA
 [F:AMK]BLOCPOSG(BLCREF-1) = [F:ALH]POSGRA
 [F:AMK]BLOCGDEF(BLCREF-1) = [F:ALH]DEFGRA
 [F:AMK]BLOCAFFD(BLCREF-1) = [F:ALH]AFFGRA
 [F:AMK]BLOCREPD(BLCREF-1) = [F:ALH]FSHGRA
 Write [AMK]
 If fstat
  GOK = 0 : Call FSTA("AMK") From GLOCK : Goto AB_TR1
 Endif
 For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=MASKREF
  [F:AMA]CODAFF = MASKDES
  Write [AMA]
  If fstat
   GOK = 0 : Call FSTA("AMA") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Goto AB_TR1 : Endif
 For [AMP]CODPAR Where TYPAFF=1 & CODAFF=MASKREF
  [F:AMP]CODAFF = MASKDES
  Write [AMP]
  If fstat
   GOK = 0 : Call FSTA("AMP") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Goto AB_TR1 : Endif
 Delete [AWI] Where WIN=FENDES
 If fstat=1
  GOK = -1 : GLOCK = "$AWINDOW"-FENDES : Goto ROLL_TR1
 Endif
 Delete [AWB] Where WIN=FENDES
 If fstat=1
  GOK = -1 : GLOCK = "$AWINBRO"-FENDES : Goto ROLL_TR1
 Endif
 Delete [AWT] Where WIN=FENDES
 If fstat=1
  GOK = -1 : GLOCK = "$AWINBOUT"-FENDES : Goto ROLL_TR1
 Endif
 Delete [AWP] Where WIN=FENDES
 If fstat=1
  GOK = -1 : GLOCK = "$AWINPAR"-FENDES : Goto ROLL_TR1
 Endif
 Read [AWI]AWI0 = FENREF
 [F:AWI]WIN = FENDES
 [F:AWI]NOMMSK(0) = MASKDES
 [F:AWI]MDL = 1
 Write [AWI]
 If fstat
  GOK = 0 : Call FSTA("AWI") From GLOCK : Goto AB_TR1
 Endif
 Read [AWB]AWB0 = FENREF
 [F:AWB]WIN = FENDES
 Write [AWB]
 If fstat
  GOK = 0 : Call FSTA("AWB") From GLOCK : Goto AB_TR1
 Endif
 For [AWT]AWT0 Where WIN=FENREF
  [F:AWT]WIN = FENDES
  Write [AWT]
  If fstat
   GOK = 0 : Call FSTA("AWT") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Goto AB_TR1 : Endif
 For [AWP]AWP0 Where WIN=FENREF
  [F:AWP]WIN = FENDES
  Write [AWP]
  If fstat
   GOK = 0 : Call FSTA("AWP") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#----------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ALISTEH  [ALH1]
 Local File ALISTED  [ALD1]
 Local File ACLOB    [ACB1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".ALISTEH" [ALH1]
 Local File =[M]DOSORG+".ALISTED" [ALD1]
 Local File =[M]DOSORG+".ACLOB"   [ACB1]
 Local File =[M]DOSORG+".ATEXTRA" [AXX1]
Endif
If [M]DOSDES=nomap
 Local File ALISTEH [ALH2]
 Local File ALISTED [ALD2]
 Local File ACLOB   [ACB2]
 Local File ATEXTRA [AXX2]
Else
 Local File =[M]DOSDES+".ALISTEH" [ALH2]
 Local File =[M]DOSDES+".ALISTED" [ALD2]
 Local File =[M]DOSDES+".ACLOB"   [ACB2]
 Local File =[M]DOSDES+".ATEXTRA" [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ALH1], [ALH2] , [ALD1] , [ALD2] , [ACB1] , [ACB2], [AXX1] , [AXX2]
Return

$TR_COP
Gosub PFIX
GOK = 1
Trbegin [ALH2]
 Delete [ALH2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ALISTEH" : Goto ROLL_TR_COP
 Endif
 Delete [ALD2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ALISTED" : Goto ROLL_TR_COP
 Endif
 Delete [ACB2] Where CODBLB=IDCLOB & IDENT1=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACLOB" : Goto ROLL_TR_COP
 Endif
 Delete [AXX2] Where (CODFIC="ALISTEH" | CODFIC="ALISTED")  & IDENT1=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATEXTRA" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AXX2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ALH1] Where COD=TABLE
  [F:ALH2] = [F:ALH1]
  Call COPTEXTRA("ALISTEH","INTIT",[F:ALH2]COD,"") From ATEXTRA
  Call COPTEXTRA("ALISTEH","INTITSHO",[F:ALH2]COD,"") From ATEXTRA
  If dim([F:ALH2]UPDUSR)>0 : [F:ALH2]UPDUSR = GUSER : Endif
  If dim([F:ALH2]UPDDAT)>0 : [F:ALH2]UPDDAT = date$ : Endif
  If dim([F:ALH2]UPDTIM)>0 : [F:ALH2]UPDTIM = time  : Endif
  Write [ALH2]
  If fstat
   GOK = 0 : Call FSTA("ALH2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ALD1] Where COD=TABLE
  [F:ALD2] = [F:ALD1]
  Call COPTEXTRA("ALISTED","INTITLIG",[F:ALD2]COD,num$([F:ALD2]LIG)) From ATEXTRA
  Write [ALD2]
  If fstat
   GOK = 0 : Call FSTA("ALD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ACB1] Where CODBLB=IDCLOB & IDENT1=TABLE
  [F:ACB2] = [F:ACB1]
  If dim([F:ACB2]UPDUSR)>0 : [F:ACB2]UPDUSR = GUSER : Endif
  If dim([F:ACB2]UPDDAT)>0 : [F:ACB2]UPDDAT = date$ : Endif
  If dim([F:ACB2]UPDTIM)>0 : [F:ACB2]UPDTIM = time  : Endif
  Write [ACB2]
  If fstat
   GOK = 0 : Call FSTA("ACB2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#----------------------------------------------------------------------------#
## Etiquette sur l'écran ALQ0
#----------------------------------------------------------------------------#

Subprog C_COD(VALEUR)
Variable Char    VALEUR()

End

Subprog AM_REPGRA(VALEUR)
Variable Integer VALEUR
If VALEUR<=1 or [M]REPGRA<=1
 Case VALEUR
  When 1
   [M]REP = 0
   [M]GRA = 0
   Effzo [ALQ1]GRA : Effzo [ALQ1]REP
  When 2,3,4
   For I=0 To [M]NBCOL-1
    If [M]COLTYP(I)<>""
     Read [ATY]CODTYP=[M]COLTYP(I)
     If !fstat & ([F:ATY]TYPTYP=7 or
&     ([F:ATY]TYPTYP>=1 and [F:ATY]TYPTYP<=4 and !find([M]COLTYP(I),"ATX","AXX","AX1","AX2","AX3")))
      [M:ALQ1]GRA(I) = 4
     Else
      [M:ALQ1]GRA(I) = 0
     Endif
    Endif
   Next I
   Affzo [M:ALQ1]GRA
 Endcase
Endif
[M]REPGRA = VALEUR
Gosub GRISE_REPGRA
Gosub GRISE_TYPGRA
End

Subprog AP_OPTGRA(VALEUR)
Variable Char    VALEUR()
Case [M]REPGRA
 When 2 : [M]AFFGRA = val([M]VALREPGRA)
 When 3 : [M]POSGRA = val([M]VALREPGRA)
Endcase
End

#----------------------------------------------------------------------------#
## Etiquette sur l'écran ALQ1
#----------------------------------------------------------------------------#

Subprog AS_COLNUM(VALEUR)
Variable Decimal VALEUR
If [M]COLTYP(nolign-1)=""
 mkstat = 1 : End
Else
 Call LECTURE("ATY",[M]COLTYP(nolign-1),"") From CONTOBJ
 If [F:ATY]TYPTYP<>1 & [M]COLTYP(nolign-1)<>"ADI"
  mkstat = 1 : End
 Elsif [F:ATY]NOLIB>0
  VALEUR = [F:ATY]NOLIB
  mkstat = 3 :  End
 Endif
Endif
End

Subprog C_COLNUM(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]COLTYP(nolign-1),"") From CONTOBJ
If [F:ATY]TYPTYP=1
 If VALEUR<1 | (VALEUR>99 & VALEUR<201)
  GMESSAGE = mess(5,176,1) : # No menu local incorrect
  mkstat = 2 : End
 Elsif mess(0,VALEUR,1)=""
  GMESSAGE = mess(98,123,1) : # Menu local non défini
  mkstat = 2 : End
 Endif
Elsif [F:ATY]TYPTYP<>1  & [M]COLTYP(nolign-1) = "ADI"
 Call CONTROLE("ADV","",num$(VALEUR),"",mkstat) From CONTOBJ
Endif
End

Subprog AS_PARNUM(VALEUR)
Variable Decimal VALEUR
If [M]PARTYP(nolign-1)=""
 mkstat = 1
Else
 Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
 If [F:ATY]TYPTYP<>1 & [M]PARTYP(nolign-1)<>"ADI"
  mkstat = 1 : End
 Elsif [F:ATY]NOLIB>0
  VALEUR = [F:ATY]NOLIB
  mkstat = 3 :  End
 Endif
Endif
End

Subprog C_PARNUM(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
If [F:ATY]TYPTYP=1
 If VALEUR<1 | (VALEUR>99 & VALEUR<201)
  GMESSAGE = mess(5,176,1) : # No menu local incorrect
  mkstat = 2 : End
 Elsif mess(0,VALEUR,1)=""
  GMESSAGE = mess(98,123,1) : # Menu local non défini
  mkstat = 2 : End
 Endif
Elsif [F:ATY]TYPTYP<>1  & [M]PARTYP(nolign-1) = "ADI"
 Call CONTROLE("ADV","",num$(VALEUR),"",mkstat) From CONTOBJ
Endif
End

Subprog IB_COLTIT
If [M]COLNUM2(nolign-1)= 0
 GBOUT1 = ""
Endif
End

Subprog IB_PARTIT
If [M]PARNUM2(nolign-1)= 0
 GBOUT1 = ""
Endif
End

#----------------------------------------------------------------------------#
## Etiquette écran ALQ2
#----------------------------------------------------------------------------#

Subprog AP_TYPGRA(VALEUR)
Variable Integer VALEUR
[M]TYPGRA = VALEUR
Gosub GRISE_TYPGRA
End

Subprog AP_DEFGRA(VALEUR)
Variable Integer VALEUR
[M]DEFGRA = VALEUR
Gosub AFF_IMAGE
End

Subprog AS_TYPGRA(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
GMENLOC(4) = 1
End

Subprog AS_DEFGRA(VALEUR)
Variable Integer VALEUR
If [M]TYPGRA<>1 and [M]TYPGRA<>2 : mkstat=1 : Endif
End

Subprog AS_FSHGRA(VALEUR)
Variable Integer VALEUR
Case [M]TYPGRA
 When 2
  GMENLOC(1)=0 : GMENLOC(2)=0 : GMENLOC(3)=0
  GMENLOC(4)=1 : GMENLOC(5)=1 : GMENLOC(6)=1
  If [M]DEFGRA=4 or  [M]DEFGRA=5
    GMENLOC(2)=1 : GMENLOC(3)=1
  Endif
 When 3
  GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1
  GMENLOC(4)=0 : GMENLOC(5)=0 : GMENLOC(6)=0
 When Default  : mkstat=1
Endcase
End

Subprog AP_FSHGRA(VALEUR)
Variable Integer VALEUR
[M]FSHGRA = VALEUR
Gosub AFF_IMAGE
End

Subprog C_GRA(VALEUR)
Variable Integer VALEUR
Read [ATY]CODTYP=[M]COLTYP(nolign-1)
If !fstat  & [F:ATY]TYPTYP=7
 For I=0 To [M]NBCOL-1
  If [M]GRA(I)= 3 & I<>nolign-1 & VALEUR =3
   GMESSAGE = mess(45,127,1) : # Il déja un champ de type libellé
   mkstat = 2 : Break
  Endif
 Next I
Endif
End

Subprog AS_GRA(VALEUR)
Variable Integer VALEUR
If [M:ALQ0]REPGRA <  2
 mkstat = 1 : End
Endif
If [M]COLTYP <> ""
 Read [ATY]CODTYP=[M]COLTYP(nolign-1)
 If !fstat  & [F:ATY]TYPTYP=7
  GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=0 : GMENLOC(4)=0
 Elsif !fstat & [F:ATY]TYPTYP>=1 and [F:ATY]TYPTYP<=4 and
& find([M]COLTYP(nolign-1),"ATX","AXX","AX1","AX2","AX3")=0
  GMENLOC(1)=0 : GMENLOC(2)=0 : GMENLOC(3)=1 : GMENLOC(4)=0
 Else
  mkstat =1
 Endif
Endif
End

Subprog AS_REP(VALEUR)
Variable Integer VALEUR
If [M]GRA(nolign-1)<>1 and [M]GRA(nolign-1)<>2
 mkstat = 1 : End
Endif
If [M:ALQ0]REPGRA <2
 mkstat = 1 : End
Endif
End

Subprog C_COLTYP(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ATY",VALEUR,"") From CONTOBJ
If [F:ATY]TYPTYP=12
 # 118565
 GMESSAGE = VALEUR-":"-mess(00113,00127,1) : #type DE DONNÉE INCOMPATIBLE
 mkstat = 2 : End
Endif
End


