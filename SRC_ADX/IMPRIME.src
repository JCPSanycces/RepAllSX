#<AdxTL>@(#)5.0.0.0 $Revision$

Local Char    IMPRIMANTE(GLONAIM)
Local Integer OBLIG
Call DEFIMP("ACTION","BY","",IMPRIMANTE,OBLIG)
Infbox IMPRIMANTE-num$(OBLIG)
End

#############################################################################
## Gestion des imprimantes
#############################################################################
## Subprog DEFIMP(ETAT,USER,COMPLEMENT,IMPRIMANTE,OBLIG)
#############################################################################
## Imprimante par défaut pour un couple (user,état)
#############################################################################
Subprog DEFIMP(ETAT,USER,COMPLEMENT,IMPRIMANTE,OBLIG)
Value    Char    ETAT
Value    Char    USER
Value    Char    COMPLEMENT
Variable Char    IMPRIMANTE
Variable Integer OBLIG
If clalev([F:AIA])=0 : Local File APRTAUS  [AIA] : Endif
If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif
If clalev([F:ARP])=0 : Local File AREPORT  [ARP] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif
If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif

Local Char    USRIMP(GLONAIM) , SITE(GLONFCY) , UTILIS(GLONAUS)
Local Integer OKIMP
Local Integer NBUSER
Local Char    TBUSER(GLONAUS)(1..100)

OKIMP = 0
IMPRIMANTE = ""
If ETAT = "" : End : Endif

Call LECTURE("ARP",ETAT,"") From CONTOBJ

## Quel utilisateur ?

UTILIS = USER
NBUSER = 0
Repeat
 NBUSER += 1
 TBUSER(NBUSER) = UTILIS
 Call LECTURE("AUS",UTILIS,"") From CONTOBJ
 If [F:AUS]USRPRT<>""
  UTILIS = [F:AUS]USRPRT
  If find(UTILIS,TBUSER(1..NBUSER)) or NBUSER>=dim(TBUSER) : # Sinon on peut boucler....
   UTILIS = USER : Break
  Endif
 Endif
Until [F:AUS]USRPRT=""

## D'abord le triplet user/état/complément

Read [AIA]AIA0 = UTILIS;ETAT;COMPLEMENT
If !fstat
 USRIMP = [F:AIA]PRT
 Gosub VERF_IMP : If OKIMP : OBLIG = ([F:AIA]OBL=2) : Goto FIN : Endif
Endif

## Ensuite le triplet user/état/vide

Read [AIA]AIA0 = UTILIS;ETAT;""
If !fstat
 USRIMP = [F:AIA]PRT
 Gosub VERF_IMP : If OKIMP : OBLIG = ([F:AIA]OBL=2) : Goto FIN : Endif
Endif

## Ensuite l'état

USRIMP = [F:ARP]PRTDEF
Gosub VERF_IMP : If OKIMP : OBLIG = ([F:ARP]PRTOBL=2) : Goto FIN : Endif

## Après ce ne sera plus obligatoire

OBLIG = 0

## Ensuite l'imprimante par défaut de l'utilisateur

USRIMP = [F:AUS]PRTDEF(max(0,[F:ARP]PRTNAT-1))
Gosub VERF_IMP : If OKIMP : Goto FIN : Endif

## Ensuite celle du site

Case GPRODUIT
 When 1 : # Géode
  SITE = GFCY
 When Default
  SITE = GFCYDEF(0)
Endcase
Call PARAM(SITE,"PRT"+num$([F:ARP]PRTNAT),USRIMP) From ADOVAL
Gosub VERF_IMP : If OKIMP : Goto FIN : Endif

## Si on est en batch, la prévisu n'est pas possible et il faut utiliser un serveur d'impression
## La prévisu n'est pas possible sur un écran VT
## Sinon la première prévisu

If GSERVEUR
 Filter [AIM] Where ENAFLG=2 & (PRTNAT=1 or PRTNAT=[F:ARP]PRTNAT) & PRT<>1 & PRTSRV<>""
Elsif GVTMOD
 Filter [AIM] Where ENAFLG=2 & (PRTNAT=1 or PRTNAT=[F:ARP]PRTNAT) & PRT<>1
Else
# Issue 85350 - 2012-10-29 by VPO : en V6 si PRT=1, PRTNAT=0 mais il reste cas migration
# Filter [AIM] Where ENAFLG=2 & (PRTNAT=1 or PRTNAT=[F:ARP]PRTNAT) & PRT=1
 Filter [AIM] Where ENAFLG=2 & (PRTNAT<=1 or PRTNAT=[F:ARP]PRTNAT) & PRT=1
Endif

Read [AIM]AIM0 First
Filter [AIM]
If fstat<=2
 OKIMP = 1
 IMPRIMANTE = [F:AIM]COD
 Goto FIN
Endif

# S'il n'y a pas de prévisu et qu'il n'y a qu'une seule destination, on prend la première disponible

If !GSERVEUR & nbrecord([F:AIM])=1
# Issue 85350 - 2012-10-29 by VPO : en V6 si PRT=1, PRTNAT=0 mais il reste cas migration
# Filter [AIM] Where ENAFLG=2 & (PRTNAT=1 or PRTNAT=[F:ARP]PRTNAT)
 Filter [AIM] Where ENAFLG=2 & (PRTNAT<=1 or PRTNAT=[F:ARP]PRTNAT)
 Read [AIM]AIM0 First
 Filter [AIM]
 If fstat<=2
  OKIMP = 1
  IMPRIMANTE = [F:AIM]COD
  Goto FIN
 Endif
Endif

## Sinon on s'en remettra au point d'entrée...

$FIN
## Point d'entrée indispensable
##
## ETAT          Code de l'état
## USER          Utilisateur
## OKIMP         1 si imprimante trouvée
## IMPRIMANTE    Code de l'imprimante trouvée
## OBLIG         1 si obligatoire
##
GPOINT = "DEFIMP" : Gosub ENTREE From EXEFNC
End

$VERF_IMP
If USRIMP<>""
 If USRIMP<>[F:AIM]COD
  Read [AIM]AIM0 = USRIMP
  If fstat : Raz [F:AIM] : Endif
 Endif
 OKIMP = ([F:AIM]ENAFLG=2)
 OKIMP *= ([F:AIM]PRT<>2 | [F:AIM]PRTNAT=1 | [F:AIM]PRTNAT=[F:ARP]PRTNAT)
 OKIMP *= (!GVTMOD or (GVTMOD & [F:AIM]PRT<>1)) : # Pas de prévisu sur un écran VT
 OKIMP *= (!GSERVEUR or (GSERVEUR & [F:AIM]PRT<>1)) : # Pas de prévisu en batch
 OKIMP *= (!GSERVEUR or (GSERVEUR & [F:AIM]PRTSRV<>"")) : # Il faut un serveur d'impression en batch
 If OKIMP
  If [F:AIM]ACS<>""
   Read [ACC]CODACC = USER;[F:AIM]ACS
   If fstat or [F:ACC]EXEC<>2
    OKIMP = 0 : Return
   Endif
  Endif
  IMPRIMANTE = USRIMP
 Endif
Endif
Return

Subprog SETIMP(ETAT,USER,COMPLEMENT,IMPRIMANTE)
Value    Char ETAT
Value    Char USER
Value    Char COMPLEMENT
Variable Char IMPRIMANTE()
If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif
If clalev([F:ARP])=0 : Local File AREPORT  [ARP] : Endif
If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif
Local Char    USRIMP(10)
Local Integer OKIMP , OBLIG
Call LECTURE("ARP",ETAT,"") From CONTOBJ
OKIMP = 0
USRIMP = IMPRIMANTE
Gosub VERF_IMP
If !OKIMP
 Call DEFIMP(ETAT,USER,COMPLEMENT,IMPRIMANTE,OBLIG)
Endif
End

##################################################################################
## Action ARPCONT   Contrôle d'un état
##################################################################################
Subprog ARPCONT(ETAT)
Variable Char ETET()
If clalev([F:ARP])=0 : Local File AREPORT [ARP] : Endif
Call CONTROLE("ARP","",ETAT,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Local Integer OK
Local Char    AUTSIT(250)
Call VERF_DROIT(ETAT,GUSER,OK,AUTSIT) From AIMP1
If !OK
 GMESSAGE = mess(3,135,1) : # Vous n'avez pas accès à cet état
 mkstat = 2 : End
Endif
End

##################################################################################
## Action AIMDEF   Valeur par défaut d'imprimante
##################################################################################
Subprog AIMDEF(IMPRIMANTE,ETAT,TBPAR,TBVAL)
Variable Char    IMPRIMANTE()
Value    Char    ETAT
Variable Char    TBPAR()(1..)
Variable Char    TBVAL()(1..)

If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif
If clalev([F:ARP])=0 : Local File AREPORT  [ARP] : Endif
If clalev([F:ARD])=0 : Local File AREPORTD [ARD] : Endif
If clalev([F:ATY])=0 : Local File ATYPE    [ATY] : Endif

Local Integer I , J , K , L
Local Integer OBLIG
Local Char    COMPLEMENT(250) , EXPRESSION(250)
Local Char    VALPAR(250) , PARAM(30) , PARFIC(30)

If ETAT="" : IMPRIMANTE = "" : End : Endif
Call LECTURE("ARP",ETAT,"") From CONTOBJ

## Evaluation du complément

COMPLEMENT = ""
If [F:ARP]PRTFRM<>""
 EXPRESSION = vireblc(format$("KT:250X",[F:ARP]PRTFRM),2)
 Repeat
  J = instr(1,EXPRESSION,"PARAM(")
  If J
   K = instr(J+1,EXPRESSION,")")
   If K
    PARAM = toupper(seg$(EXPRESSION,J+6,K-1))
    L = len(PARAM)
    If right$(PARAM,L-2)="FIN"
     PARFIC = left$(PARAM,L-3)+"DEB"
    Elsif right$(PARAM,L-2)="END"
     PARFIC = left$(PARAM,L-3)+"STR"
    Else
     PARFIC = PARAM
    Endif
    VALPAR = ""
    For [ARD]ARD0 Where RPTCOD=ETAT
     If toupper([F:ARD]PARCOD)=PARFIC
      For I=1 To dim(TBPAR)
       If toupper(TBPAR(I))=PARAM
        VALPAR = TBVAL(I)
        Read [ATY]CODTYP = [F:ARD]PARTYP
        Case [F:ATY]TYPTYP
         When 7       : VALPAR = '"'+VALPAR+'"'
         When 8       : VALPAR = '['+format$("D:"+GFMD,gdat$(VALPAR))+']'
         When Default : If VALPAR="" : VALPAR = "0" : Endif
        Endcase
        Break
       Endif
      Next I
      Break
     Endif
    Next
    If VALPAR<>""
     EXPRESSION = left$(EXPRESSION,J-1)+VALPAR+right$(EXPRESSION,K+1)
    Else
     EXPRESSION = left$(EXPRESSION,J-1)+right$(EXPRESSION,K+1)
    Endif
   Else
    J = 0
   Endif
  Endif
 Until J=0
 Onerrgo RIEN
 COMPLEMENT = evalue(EXPRESSION)
 Onerrgo
Endif
Call DEFIMP(ETAT,GUSER,COMPLEMENT,IMPRIMANTE,OBLIG)
If OBLIG
 mkstat = 2
Endif
End

$RIEN
Resume

##################################################################################
## Action AIMCONT   Contrôle d'imprimante
##################################################################################
Subprog AIMCONT(IMPRIMANTE,ETAT,BATCH)
Value    Char    IMPRIMANTE
Value    Char    ETAT
Value    Integer BATCH

If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif
If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif
If clalev([F:ARP])=0 : Local File AREPORT  [ARP] : Endif

## Existence

Call CONTROLE("ARP","",ETAT,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Call CONTROLE("AIM","",IMPRIMANTE,"",mkstat) From CONTOBJ
If mkstat : End : Endif

## Type d'imprimante

If [F:AIM]PRT=2 & [F:AIM]PRTNAT>1 & [F:AIM]PRTNAT<>[F:ARP]PRTNAT
 GMESSAGE = mess(5,133,1)-"("+mess([F:AIM]PRTNAT,22,1)+")" : # Imprimante de type incorrect
 mkstat = 2 : End
Endif
If [F:AIM]PRT=6 & ([F:ARP]GESZPL<>2 or [F:ARP]CODZPL="")
 GMESSAGE = mess(31,143,1) : # Paramétrage imprimante ZPL inexistant
 mkstat = 2 : End
Endif

## Pas de prévisu sur un écran VT

If GVTMOD & [F:AIM]PRT=1
 GMESSAGE = mess(231,133,1) : # Prévisu impossible sur un écran VT
 mkstat = 2 : End
Endif

## Code d'accès

If [F:AIM]ACS<>""
 Read [ACC]CODACC = GUSER;[F:AIM]ACS
 If fstat or [F:ACC]EXEC<>2
  GMESSAGE = mess(7,133,1) : # Imprimante non autorisée
  mkstat = 2 : End
 Endif
Endif

## Autorisation batch

If BATCH
 If find([F:AIM]PRT,1)
  GMESSAGE = mess(12,135,1) : # Pas de prévisu en batch
  mkstat = 2 : End
 Endif
 If [F:AIM]PRTSRV=""
  GMESSAGE = mess(13,135,1) : # Serveur d'impression non défini
  mkstat = 2 : End
 Endif
Endif

End
