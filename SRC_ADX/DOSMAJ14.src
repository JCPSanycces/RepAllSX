#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################################################
# DOSMAJ14 : Mises à jour à effectuer lors du passage à la version 140 (Release 14) 
# moulinette avant la version 140 
##################################################################################


Subprog AMAJ
#-------------------------------------#
#         Avant mise à jour           #
#-------------------------------------#
Onerrgo ERREUR

# Avant suppression des fenêtres/écrans WUXaaaaa  FQ 52854 GA 03/3009
Call ECR_TRACE("************** SAVCFGMAJ14  CFGMAJ14 ***************",-1) From GESECRAN
Call SAVCFGMAJ14   From CFGMAJ14 : # Moulinettes Configurateur

# Avant suppression des textes des tableaux de bord -F58563
Call ECR_TRACE("************** ADICMAJ30 CPTMAJ30 ***************",-1) From GESECRAN
If [F:ADS]MODULE(1)=2
 Call ADICMAJ30 From CPTMAJ30 : # Moulinettes Comptabilisation
Endif

#-----
# Rajout des types de données
# Rajout des codes activités
# Rajout des nouveaux champs 140
# Les index sont préservés
#-----

Call MAJDIC From SUPMAJ14

#----- Superviseur en premier

Call AMAJ   From SUPMAJ14      : # Moulinettes Superviseur

GVALIDE(2) = 1 : # Ecrans
GVALIDE(3) = 1 : # Objets
GVALIDE(4) = 1 : # Fenêtres et TRT générés superviseur
GVALIDE(5) = 1 : # Consultations

#----- Puis Tronc commun

Call ECR_TRACE("************** ATRCMAJ14 TRCMAJ14 ***************",-1) From GESECRAN
Call ATRCMAJ14   From TRCMAJ14 : # Moulinettes Tronc commun

#----- Ensuite les autres modules

Call ECR_TRACE("************** ACTMAJ14 CPTMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(1)=2
  Call ACPTMAJ14 From CPTMAJ14 : # Moulinettes Compta
  GVALTRANS(2)=2
Endif

Call ECR_TRACE("************** ATRSMAJ14 CPTMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(2)=2
  Call ATRSMAJ14 From CPTMAJ14 : # Moulinettes Tiers
  GVALTRANS(3)=2
Endif

Call ECR_TRACE("************** AIMMMAJ14 CPTMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(3)=2
  Call AIMMMAJ14 From CPTMAJ14 : # Moulinettes Immos
  GVALTRANS(4)=2
Endif

Call ECR_TRACE("************** AVENMAJ14 VENMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(4)=2
  Call AVENMAJ14 From VENMAJ14 : # Moulinettes Ventes
  GVALTRANS(5)=2               : # TRT générés Ventes (transactions, tarifs)
Endif

Call ECR_TRACE("************** AACHMAJ14 ACHMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(5)=2
  Call AACHMAJ14 From ACHMAJ14 : # Moulinettes Achats
  GVALTRANS(6)=2               : # TRT générés Achats (transactions, tarifs, signatures)
Endif

Call ECR_TRACE("************** ASTOMAJ14 STOMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(6)=2
  Call ASTOMAJ14 From STOMAJ14 : # Moulinettes Stock
  GVALTRANS(7)=2               : # TRT générés stocks (transactions)
Endif

Call ECR_TRACE("************** AGPAMAJ14 GPAMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(7)=2
  Call AGPAMAJ14 From GPAMAJ14 : # Moulinettes GPAO
  GVALTRANS(8)=2               : # TRT générés GPAO (transactions)
Endif

Call ECR_TRACE("************** ACR1MAJ14 CRMMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(11)=2
  Call ACR1MAJ14 From CRMMAJ14 : # Moulinettes CRM1
  GVALTRANS(12)=2              : # TRT générés Support clients
Endif

Call ECR_TRACE("************** ACR2MAJ14 CRMMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(12)=2
  Call ACR2MAJ14 From CRMMAJ14 : # Moulinettes CRM2
  GVALTRANS(13)=2              : # TRT générés Action commerciale
Endif

Call ECR_TRACE("************** UPDATE ATEXTRA ***************",-1) From GESECRAN
# Atextra est une table de type Superviseur en 140, il faut faire ici la mise à jour de sa structure
Call MAJTAB("ATEXTRA") From SUPMAJ14

Onerrgo
End


###################################################################################
###################################################################################
###################################################################################

Subprog MAJ
#-------------------------------------#
#          Après mise à jour          #
#-------------------------------------#
Onerrgo ERREUR

#----- Superviseur en premier

Call ECR_TRACE("************** MAJ SUPMAJ14 ***************",-1) From GESECRAN
Call MAJ      From SUPMAJ14     : # Moulinettes Superviseur

#----- Puis Tronc commun et CRM

Call ECR_TRACE("************** TRCMAJ14 TRCMAJ14 ***************",-1) From GESECRAN
Call TRCMAJ14 From TRCMAJ14     : # Moulinettes Tronc commun

#----- Puis Configurateur FQ 52854 GA 03/3009

Call ECR_TRACE("************** CFGMAJ14 CFGMAJ14 ***************",-1) From GESECRAN
Call CFGMAJ14   From CFGMAJ14 : # Moulinettes Configurateur

#----- Ensuite les autres modules

Call ECR_TRACE("************** CPTMAJ14 CPTMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(1)=2
  Call CPTMAJ14  From CPTMAJ14  : # Moulinettes Compta
Endif

Call ECR_TRACE("************** TRSMAJ14 CPTMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(2)=2
  Call TRSMAJ14  From CPTMAJ14  : # Moulinettes Tiers
Endif

Call ECR_TRACE("************** IMMMAJ14 CPTMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(3)=2
  Call IMMMAJ14  From CPTMAJ14  : # Moulinettes Immos
Endif

Call ECR_TRACE("************** VENMAJ14 VENMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(4)=2
  Call VENMAJ14  From VENMAJ14  : # Moulinettes Ventes
Endif

Call ECR_TRACE("************** ACHMAJ14 ACHMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(5)=2
  Call ACHMAJ14  From ACHMAJ14  : # Moulinettes Achats
Endif

Call ECR_TRACE("************** STOMAJ14 STOMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(6)=2
  Call STOMAJ14  From STOMAJ14  : # Moulinettes Stock
Endif

Call ECR_TRACE("************** GPAMAJ14 GPAMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(7)=2
  Call GPAMAJ14  From GPAMAJ14  : # Moulinettes GPAO
Endif

Call ECR_TRACE("************** CR1MAJ14 CRMMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(11)=2
  Call CR1MAJ14  From CRMMAJ14  : # Moulinettes CRM1
Endif

Call ECR_TRACE("************** CR2MAJ14 CRMMAJ14 ***************",-1) From GESECRAN
If [F:ADS]MODULE(12)=2
  Call CR2MAJ14  From CRMMAJ14  : # Moulinettes CRM2
Endif

Onerrgo
End


###################################################################################
###################################################################################
###################################################################################

$ERREUR
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Resume
