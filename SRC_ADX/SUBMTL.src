#<AdxTL>@(#)4.0.0.0 $Revision$
#######################################################################
# SUBMTL : Transactions de suivi lancements               SR 06/11/98 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:MTS]MFGTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                                                                     #
# Génération de 4 écrans de saisie à partir des écrans de base MTK0   #
#                                                              MTK1   #
#                                                              MTK2   #
#                                                              MTK3   #
#                                                                     #
# Nom des écrans générés : WRxyyyz                                    #
#                            x = 1 pour lancement                     #
#                                2 pour suivi                         #
#                                                                     #
#                          yyy = nom de la transaction (MTSNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#######################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="MTS"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=2
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M]MTSTYP = 2
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INICRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="MFGTRS" & IDENT1=num$([F:MTS]MTSTYP) & IDENT2=[F:MTS]MTSNUM
                      Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="MTS"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "SEL_TABLE"   : Gosub SEL_TABLE  From SUBETR : # Sélection sur code pièce auto
 When "AV_IMPRIME"  : Gosub COP_ECRAN
                      OK = 0
 When "FERME"       : Call IMPSCR        From ATRTX3
 When Default
Endcase
Return

#-------------------------------------------------------#
# Définir le dossier pour la génération des écrans      #
#-------------------------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto
# FQ 50870 ecrase la variable APPLI en validation des transactions sur dossier fille
If dim(APPLI)<0  Local  Char    APPLI Endif
If APPLI=""      APPLI=nomap          Endif

Local Char WMODU(3) : WMODU="R"
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WNUM
Local Shortint WENAFLG

Return


#-------------------------------------------------------#
# Ne traiter que les transactions de suivi              #
#-------------------------------------------------------#
$FILTRE
FILTSUP="MTSTYP=2"
Return

#------------------------------------------#
# Désactivation bouton validation et copie #
#------------------------------------------#
$SETBOUT
If GREP <>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case REP
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

$LIENS

If dim([M:MTL1]WRHCOD)>0
   If [M:MTL1]WRHCOD=0  [M:MTL1]WRHCOD=3  Endif
   If [M:MTL1]WRHOBY=2
      Grizo [M:MTL1]WRHCOD
   Else
      Actzo [M:MTL1]WRHCOD
   Endif
Endif

# Issue 107513/8 - 2015-07-13 by JUSYN : Material/component major and minor version
                           If dim([M:MTL2]ITMECCMAJ) > 0
                               If [M:MTL2]ITMECCMAJ=0  : [M:MTL2]ITMECCMAJ=2   : Endif
                               If [M:MTL2]ITMECCMIN=0  : [M:MTL2]ITMECCMIN=2   : Endif
                           Endif

If [M:MTL1]OPETRKFLG = 1 : Grizo [M:MTL2]5
Else                     : Actzo [M:MTL2]5
                           If [M:MTL2]OPEUOMMOD = 1 : Grizo [M:MTL2]OPEUOMTYP : Endif
Endif
#
If [M:MTL1]ITMTRKFLG = 1 : Grizo [M:MTL2]10
                           Gosub RAZCRE From SUBETR : # raz champs non saisissables
                           Grizo [M:ETR2]
                           Affzo [M:MTL2]
                           Affzo [M:ETR2]
Else                     : Actzo [M:MTL2]10
                           Actzo [M:ETR2]
                           [M:ETR2]BPSLOTCOD  = 3
                           [M:ETR2]BPSLOTCOD1 = 3
                           Grizo [M:ETR2]BPSLOTCOD
                           Grizo [M:ETR2]BPSLOTCOD1
                           [M:ETR2]MVTPRICOD  = 3
                           [M:ETR2]MVTPRICOD1 = 3
                           Grizo [M:ETR2]MVTPRICOD
                           Grizo [M:ETR2]MVTPRICOD1
Endif
#
If [M:MTL1]MATTRKFLG = 1 : Grizo [M:MTL3]
                           Grizo [M:MTL4]
Else                     : Actzo [M:MTL3]
                           Actzo [M:MTL4]
                           If [M:MTL3]STKFLG=0 : [M:MTL3]STKFLG=1  : Endif

                           If [M:MTL4]LOTCODS=0    : [M:MTL4]LOTCODS=1        : [MTL4]LOTSCRS    = 1 : Endif
                           If [M:MTL4]SLOCODS=0    : [M:MTL4]SLOCODS=1        : [MTL4]SLOSCRS    = 1 : Endif
# Issue 107513/8 - 2015-07-13 by JUSYN : Material/component major and minor version
                           If dim([M:MTL4]MATECCCOD) > 0
                               If [M:MTL4]MATECCCOD=0     : [M:MTL4]MATECCCOD=1      : [MTL4]MATECCSCR=1    : Endif
                               If [M:MTL4]MATECCCODMIN=0  : [M:MTL4]MATECCCODMIN=1   : [MTL4]MATECCSCRMIN=1 : Endif
                           Endif

                           If [M:MTL4]AQRCODS=0    : [M:MTL4]AQRCODS=1        : [MTL4]AQRSCRS    = 1 : Endif
                           If [M:MTL4]LOCCODS=0    : [M:MTL4]LOCCODS=1        : [MTL4]LOCSCRS    = 1 : Endif
                           If [M:MTL4]SERCODS=0    : [M:MTL4]SERCODS=1        : [MTL4]SERSCRS    = 1 : Endif
                           If [M:MTL4]SERECODS=0   : [M:MTL4]SERECODS=1       : [MTL4]SERESCRS   = 1 : Endif
                           If dim([M:MTL4]IDECODS1)>0 # FQ 51201 4 champs soumis au code activité PAL
                              If [M:MTL4]IDECODS1=0   : [M:MTL4]IDECODS1=1    : [MTL4]IDESCRS1   = 1 : Endif
                              If [M:MTL4]IDECODS2=0   : [M:MTL4]IDECODS2=1    : [MTL4]IDESCRS2   = 1 : Endif
                           Endif
                           If [M:MTL4]MVTDESCODS=0 : [M:MTL4]MVTDESCODS=1     : [MTL4]MVTDESSCRS = 1 : Endif
                           If [M:MTL4]LOTCODS=3       Grizo [MTL4]LOTSCRS    : Endif
                           If [M:MTL4]SLOCODS=3       Grizo [MTL4]SLOSCRS    : Endif
# Issue 107513/8 - 2015-07-13 by JUSYN : Material/component major and minor version
                           If dim([M:MTL4]MATECCCOD) > 0
                               If [M:MTL4]MATECCCOD=3     Grizo [MTL4]MATECCSCR     : Endif
                               If [M:MTL4]MATECCCODMIN=3  Grizo [MTL4]MATECCSCRMIN  : Endif
                           Endif

                           If [M:MTL4]AQRCODS=3       Grizo [MTL4]AQRSCRS    : Endif
                           If [M:MTL4]LOCCODS=3       Grizo [MTL4]LOCSCRS    : Endif
                           If [M:MTL4]SERCODS=3       Grizo [MTL4]SERSCRS    : Endif
                           If [M:MTL4]SERECODS=3      Grizo [MTL4]SERESCRS   : Endif
                           If dim([M:MTL4]IDECODS1)>0 # FQ 51201 4 champs soumis au code activité PAL
                              If [M:MTL4]IDECODS1=3   Grizo [MTL4]IDESCRS1   : Endif
                              If [M:MTL4]IDECODS2=3   Grizo [MTL4]IDESCRS2   : Endif
                           Endif
                           If [M:MTL4]MVTDESCODS=3    Grizo [MTL4]MVTDESSCRS : Endif
                           If dim([M:MTL4]WRHCOD2)>0
                              If [M:MTL4]WRHCOD2=0    [M:MTL4]WRHCOD2=3      : Endif
                              #--- Dem 60616
                              #If [M:MTL1]WRHOBY=2
                              #   Grizo [M:MTL4]WRHCOD2 : Grizo [M:MTL4]WRHSCR2
                              #Else
                              #   Actzo [M:MTL4]WRHCOD2
                                 If [M:MTL4]WRHCOD2=3  Grizo [MTL4]WRHSCR2  Else Actzo [MTL4]WRHSCR2  Endif
                              #Endif
                              #---
                           Endif
Endif
If clalev([M:DST])
  [M:DST]CCESCR  = 3
  [M:DST]CCESCR2 = 3
  [M:DST]CCESCR3 = 3
  Affzo [M:DST]
  Grizo [M:DST]10,20,30
Endif

If [M:MTL0]ENAFLG=0 [M:MTL0]ENAFLG=2         : Endif
If WMODU="R"  WMODU="R"+num$([M:MTL0]MTSTYP) : Endif # FQ 50600 ajout du test pour ne le faire que la 1ere fois :-((
If [M:MTL1]ITMTRKFLG = 2
    Gosub LIENS From SUBETR
Endif
Gosub PE_MFGTRS From SUBMFX
Return

###################################
$RAZCRE
If clalev([M:DST])
  [M:DST]CCESCR  = 3
  [M:DST]CCESCR2 = 3
  [M:DST]CCESCR3 = 3
  Affzo [M:DST]
  Grizo [M:DST]10,20,30
Endif

[M:MTL0]ENAFLG=2
[M:MTL0]MTSTYP = 2
Actzo [M:MTL1]
Actzo [M:MTL2]
Actzo [M:MTL3]
Actzo [M:MTL4]

[M:MTL3]STKFLG=1

[M:MTL4]LOTCODS=1        : [MTL4]LOTSCRS    = 1
[M:MTL4]SLOCODS=1        : [MTL4]SLOSCRS    = 1

# Issue 107513/8 - 2015-07-13 by JUSYN : Material/component major and minor version
If dim([M:MTL4]MATECCCOD) > 0
    [M:MTL4]MATECCCOD =1        : [MTL4]MATECCSCR = 1
    [M:MTL4]MATECCCODMIN =1     : [MTL4]MATECCSCRMIN = 1
Endif

[M:MTL4]AQRCODS=1        : [MTL4]AQRSCRS    = 1
[M:MTL4]LOCCODS=1        : [MTL4]LOCSCRS    = 1
[M:MTL4]SERCODS=1        : [MTL4]SERSCRS    = 1
[M:MTL4]SERECODS=1       : [MTL4]SERESCRS   = 1
If dim([M:MTL4]IDECODS1)>0 # FQ 51201 4 champs soumis au code activité PAL
   [M:MTL4]IDECODS1=1    : [MTL4]IDESCRS1   = 1
   [M:MTL4]IDECODS2=1    : [MTL4]IDESCRS2   = 1
Endif
[M:MTL4]MVTDESCODS=1     : [MTL4]MVTDESSCRS = 1

If dim([M:MTL1]WRHCOD) >0 [M:MTL1]WRHCOD =3 Endif
If dim([M:MTL4]WRHCOD2)>0 [M:MTL4]WRHCOD2=3 Endif

Actzo [M:ETR2]
If WMODU="R"  WMODU="R"+num$([M:MTL0]MTSTYP) : Endif # FQ 50600 ajout du test pour ne le faire que la 1ere fois :-((
Gosub RAZCRE From SUBETR
Gosub PE_MFGTRS From SUBMFX
Affzo [M:MTL0]
Affzo [M:MTL1]
Affzo [M:MTL2]
Affzo [M:MTL3]
Affzo [M:ETR2]

Return



#################################################
#Pour les zones n'ayant pas le même nom dans l'écran et dans le fichier
$INICRE
Gosub CHARGE_ATEXTRA From SUBMTL
[F:MTS]SRGWAIFLG = 1
If [F:MTS]STKFLG=0 : [F:MTS]STKFLG=1  : Endif
Gosub PE_MFGTRS From SUBMFX
Return

#----------------------------------------#
# Création ou modif du texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA
Call MAJTEXTRA([M:MTL0]DESAXX,"MFGTRS","DESAXX",num$([M:MTL0]MTSTYP),[M:MTL0]MTSNUM) From ATEXTRA
[F:MTS]MTSDES   =GLANGUE+"~"+[M:MTL0]DESAXX
[F:MTS]MTSTYPCAR=num$([F:MTS]MTSTYP)
Return

#################################################
$APRES_MODIF

Case COUZON
  When "OPETRKFLG"
       If val(CZ)=1
         [M:MTL2]MATRICULE = 1 : [M:MTL2]REBUT = 1 : [M:MTL2]REM = 1 : [M:MTL2]TYPTPS = 1
          Grizo [M:MTL2]5
       Else
          Actzo [M:MTL2]5
       Endif
       Affzo [M:MTL2]
  When "ITMTRKFLG"
       If val(CZ)=1
          [M:MTL2]TYPART    = 1
          # Issue 107513/8 - 2015-07-13 by JUSYN : Major and minor version
          # [M:MTL2]ITMECCMAJ = 1
          # [M:MTL2]ITMECCMIN = 1
          If dim([M:MTL2]ITMECCMAJ) > 0
              [M:MTL2]ITMECCMAJ = 2
              [M:MTL2]ITMECCMIN = 2
          Endif

          Grizo [M:MTL2]10
          # Grizo [M:MTL2]15 # Issue 107513/8
          Gosub RAZCRE From SUBETR : # raz champs non saisissables
          Grizo [M:ETR2]
       Else
          Actzo [M:MTL2]10
          # Issue 107513/8 - 2015-07-13 by JUSYN : Major and minor version
          If dim([M:MTL2]ITMECCMAJ) > 0
              [M:MTL2]ITMECCMAJ = 2
              [M:MTL2]ITMECCMIN = 2
              Actzo [M:MTL2]15 # Issue 107513/8
          Endif
          Actzo [M:ETR2]
          [M:ETR2]BPSLOTCOD  = 3
          [M:ETR2]BPSLOTCOD1 = 3
          Grizo [M:ETR2]BPSLOTCOD
          Grizo [M:ETR2]BPSLOTCOD1
          [M:ETR2]MVTPRICOD  = 3
          [M:ETR2]MVTPRICOD1 = 3
          Grizo [M:ETR2]MVTPRICOD
          Grizo [M:ETR2]MVTPRICOD1
       Endif
       Affzo [M:MTL2]
       Affzo [M:ETR2]

   When "MATTRKFLG"
       If val(CZ)=1
            [M:MTL3]CONSMAT = 1 : [M:MTL3]STOCODDEF = 1 : [M:MTL3]EMPFLG = 1
            [M:MTL3]TYPMAT = 1
            If dim([M:MTL4]WRHCOD2)>0
               [M:MTL4]WRHCOD2 = 2 : [M:MTL4]WRHSCR2 = 1
            Endif
            # Issue 107513/8 - 2015-07-13 by JUSYN : Major and minor version
            #If dim([M:MTL3]MATECCMAJ) > 0
            #[M:MTL3]MATECCMAJ = 1
            #[M:MTL3]MATECCMIN = 1
            #Endif

            Grizo [M:MTL3]
            Grizo [M:MTL4]
       Else
            Actzo [M:MTL3]
            Actzo [M:MTL4]
            If dim([M:MTL4]WRHCOD2)>0 & [M:MTL4]WRHCOD2=3
                Grizo [M:MTL4]WRHSCR2
            Endif
       Endif
       Affzo [M:MTL3]
       Affzo [M:MTL4]
    When "OPEUOMMOD"
       If val(CZ)=1
            [M:MTL2]OPEUOMTYP = 1
             Grizo [M:MTL2]OPEUOMTYP
       Else
            Actzo [M:MTL2]OPEUOMTYP
       Endif
    When "LOTCODS"
        If val(CZ)=3
         [M:MTL4]LOTSCRS=1
         If !GIMPORT Affzo [MTL4]LOTSCRS    : Grizo [M:MTL4]LOTSCRS    : Endif
       Elsif !GIMPORT
         Actzo [MTL4]LOTSCRS
       Endif
    When "SLOCODS"
        If val(CZ)=3
         [M:MTL4]SLOSCRS=1
         If !GIMPORT Affzo [MTL4]SLOSCRS    : Grizo [M:MTL4]SLOSCRS    : Endif
       Elsif !GIMPORT
         Actzo [MTL4]SLOSCRS
       Endif
    When "MATECCCOD" # Issue number - 2015-07-13 by JUSYN : Material/component major and minor version
        If val(CZ)=3
         [M:MTL4]MATECCSCR=1
         If !GIMPORT Affzo [MTL4]MATECCSCR    : Grizo [M:MTL4]MATECCSCR    : Endif
       Elsif !GIMPORT
         Actzo [MTL4]MATECCSCR
       Endif
    When "MATECCCODMIN" # Issue number - 2015-07-13 by JUSYN : Material/component major and minor version
        If val(CZ)=3
         [M:MTL4]MATECCSCRMIN=1
         If !GIMPORT Affzo [MTL4]MATECCSCRMIN : Grizo [M:MTL4]MATECCSCRMIN : Endif
       Elsif !GIMPORT
         Actzo [MTL4]MATECCSCRMIN
       Endif
    When "AQRCODS"
        If val(CZ)=3
         [M:MTL4]AQRSCRS=1
         If !GIMPORT Affzo [MTL4]AQRSCRS    : Grizo [M:MTL4]AQRSCRS    : Endif
       Elsif !GIMPORT
         Actzo [MTL4]AQRSCRS
       Endif
    When "LOCCODS"
        If val(CZ)=3
         [M:MTL4]LOCSCRS=1
         If !GIMPORT Affzo [MTL4]LOCSCRS    : Grizo [M:MTL4]LOCSCRS    : Endif
       Elsif !GIMPORT
         Actzo [MTL4]LOCSCRS
       Endif
    When "SERCODS"
        If val(CZ)=3
         [M:MTL4]SERSCRS=1
         If !GIMPORT Affzo [MTL4]SERSCRS    : Grizo [M:MTL4]SERSCRS    : Endif
       Elsif !GIMPORT
         Actzo [MTL4]SERSCRS
       Endif
    When "SERECODS"
        If val(CZ)=3
         [M:MTL4]SERESCRS=1
         If !GIMPORT Affzo [MTL4]SERESCRS    : Grizo [M:MTL4]SERESCRS    : Endif
       Elsif !GIMPORT
         Actzo [MTL4]SERESCRS
       Endif
    When "IDECODS1"
        If val(CZ)=3
         [M:MTL4]IDESCRS1=1
         If !GIMPORT Affzo [MTL4]IDESCRS1    : Grizo [M:MTL4]IDESCRS1    : Endif
       Elsif !GIMPORT
         Actzo [MTL4]IDESCRS1
       Endif
    When "IDECODS2"
        If val(CZ)=3
         [M:MTL4]IDESCRS2=1
         If !GIMPORT Affzo [MTL4]IDESCRS2    : Grizo [M:MTL4]IDESCRS2    : Endif
       Elsif !GIMPORT
         Actzo [MTL4]IDESCRS2
       Endif
    When "MVTDESCODS"
        If val(CZ)=3
         [M:MTL4]MVTDESSCRS=1
         If !GIMPORT Affzo [MTL4]MVTDESSCRS    : Grizo [M:MTL4]MVTDESSCRS    : Endif
       Elsif !GIMPORT
         Actzo [MTL4]MVTDESSCRS
       Endif

    When Default
       Gosub APRES_MODIF From SUBETR
       Gosub PE_MFGTRS From SUBMFX
Endcase


Return




#------------------------------------------------#
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(WMODU)<0 Local Char WMODU : WMODU="R" : Endif
If WMODU="R"    WMODU="R"+num$([M:MTL0]MTSTYP) : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO(GLONAMK), MTOB(GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG, OK
Local Char     BOUTONS(10)(4)
Local Char     TEXTE(40), LISTE(3), REPONS(1), WOPTION(15)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK
#------------------------- écran MTK3 -------------------------#
Local Char    ZT : # nom de zone dans table transaction
Local Char    ZM : # nom de zone dans le masque
Local Integer ZI : # pour les zones indicées

#---------------- Noms fenêtres et traitement ---------#
Local Char     WINREF1(GLONFEN) : WINREF1="OMTK"
Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WOMTK"+[M:MTL0]MTSNUM
Local Char     NOMTRT1(GLONADC) : NOMTRT1="WGOMTK"+[M:MTL0]MTSNUM
Local Char     NOMMSKENT(GLONAMK)    # Nom du masque d'entête de la fenêtre
#------------------------- Chargement -------------------------#
# FQ 50600 pb en validation de masse
If ACTION<>"ANNULE"   Gosub LIENS Endif
#------------------------- 1er écran --------------------------#
MFROM="MTK0"
MTO="WR"+num$([M:MTL0]MTSTYP)+[M:MTL0]MTSNUM+"0"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If [M:MTL1]MATTRKFLG = 1 & [M:MTL1]OPETRKFLG = 1 & [M:MTL1]ITMTRKFLG = 1
        Call ERREUR(mess(25,190,1)) From GESECRAN
        GOK = 0
        Return
   Endif
   If [M:MTL1]MATTRKFLG=1 TZONE(IZON)="MATTRKFLG"
                       TMOD(IZON) = 3
                       IZON+=1

   Endif
   If [M:MTL1]OPETRKFLG=1 TZONE(IZON)="OPETRKFLG"
                          TMOD(IZON) = 3
                          IZON += 1
   Endif
   If [M:MTL1]ITMTRKFLG=1 TZONE(IZON)="ITMTRKFLG"
                          TMOD(IZON) = 3
                          IZON += 1
   Endif
   If dim([M:MTL1]WRHCOD)>0
     If [M:MTL1]WRHCOD>1  TZONE(IZON)="WRHE"
                          TMOD(IZON) =[M:MTL1]WRHCOD
                          IZON+=1
     Endif
   Endif
   OPT1=0
   Gosub PE_MFGTRS From SUBMFX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Endif
#------------------------- 2ème écran -------------------------#
MFROM="MTK1"
MTO="WR"+num$([M:MTL0]MTSTYP)+[M:MTL0]MTSNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
#   If [M:MTL1]OPETRKFLG = 1 : MFROM = "MTKZ"
#   Else
       If [M:MTL1]FILTFLG>1 TZONE(IZON)="FILTOPE"
                            TMOD(IZON) =[M:MTL1]FILTFLG
                            IZON+=1
                            If [M:MTL1]FILTDEF = 3
                                TZONE(IZON) = "QTESUIVOPE"
                                TMOD(IZON) = 3
                                IZON += 1
                                TZONE(IZON) = "UOM"
                                TMOD(IZON) = 3
                                IZON += 1
                            Endif
       Endif
       If [M:MTL2]TYPTPS=2 TZONE(IZON)="TIMTYP"
                              TMOD(IZON) = 3
                              IZON += 1
                           TZONE(IZON)="MFGNUMOP"
                              TMOD(IZON) = 3
                              IZON += 1
                           TZONE(IZON)="ITMREF"
                              TMOD(IZON) = 3
                              IZON += 1
                           TZONE(IZON)="ROUALT"
                              TMOD(IZON) = 3
                              IZON += 1
       Endif
       # Issue 85671 GA 09/2014
       If [M:MTL2]MATRICULE=3
                           TZONE(IZON)="EMPNUM"
                              TMOD(IZON) = 3
                              IZON += 1
       Endif
#    Endif
     Gosub PE_MFGTRS From SUBMFX
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Endif
#------------------------- 3ème écran -------------------------#
MFROM="MTK2"
MTO="WR"+num$([M:MTL0]MTSTYP)+[M:MTL0]MTSNUM+"2"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
#     If [M:MTL1]ITMTRKFLG = 1 : MFROM = "MTKZ"
#     Else
        If [M:MTL2]TYPART=2 TZONE(IZON)="PRODTYP"
                              TMOD(IZON) = 3
                              IZON += 1
                            TZONE(IZON)="MFGNUMIT"
                              TMOD(IZON) = 3
                              IZON += 1
                            TZONE(IZON)="BOMALT"
                              TMOD(IZON) = 3
                              IZON += 1
        Endif
        # Issue 107513-8 - 2015-07-13 by JUSYN : Major and minor version hidden by default
        If dim([M:MTL2]ITMECCMAJ) > 0
            If [M:MTL2]ITMECCMAJ=2
                                TZONE(IZON)="ECCVALMAJ"
                                  TMOD(IZON) = 3
                                  IZON += 1
            Endif
            If [M:MTL2]ITMECCMIN=2
                                TZONE(IZON)="ECCVALMIN"
                                  TMOD(IZON) = 3
                                  IZON += 1
            Endif
        Endif

#     Endif
     Gosub TRT_CHAMP_DOC From SUBETR
     OPT1=2
     Gosub PE_MFGTRS From SUBMFX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Endif

#------------------------- 4ème écran -------------------------#
MFROM="MTK3"
MTO="WR"+num$([M:MTL0]MTSTYP)+[M:MTL0]MTSNUM+"3"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
#   If [M:MTL1]MATTRKFLG = 1 : MFROM = "MTKZ"
#   Else
       If [M:MTL1]FILTFLG>1 TZONE(IZON)="FILTMAT"
                            TMOD(IZON) =[M:MTL1]FILTFLG
                            IZON+=1
       Endif
       If [M:MTL3]TYPMAT=2 TZONE(IZON)="MATTYP"
                              TMOD(IZON) = 3
                              IZON += 1
                           TZONE(IZON)="MFGNUMMA"
                              TMOD(IZON) = 3
                              IZON += 1
                           TZONE(IZON)="BOMNUM"
                              TMOD(IZON) = 3
                              IZON += 1
                           TZONE(IZON)="BOMALT"
                              TMOD(IZON) = 3
                              IZON += 1
       Endif
       #---- Lot
       If   dim([M:MTL4]LOTCODS) > 0
          If  [M:MTL4]LOTCODS > 1 TZONE(IZON)="LOT"
                                     TMOD(IZON) =[M:MTL4]LOTCODS
                                     IZON+=1
          Endif
          If   [M:MTL4]LOTCODS = 1 | [M:MTL4]LOTCODS = 2
             ZT="LOTSCRS" : ZM="LOT" : Gosub TABLEAU_FICHE
          Endif
     Endif

     #---- Sous-Lot
     If   dim([M:MTL4]SLOCODS) > 0
          If  [M:MTL4]SLOCODS > 1 TZONE(IZON)="SLO"
                                     TMOD(IZON) =[M:MTL4]SLOCODS
                                     IZON+=1
          Endif
          If   [M:MTL4]SLOCODS = 1 | [M:MTL4]SLOCODS = 2
             ZT="SLOSCRS" : ZM="SLO" : Gosub TABLEAU_FICHE
          Endif
     Endif

     # Issue 107513/8 - 2015-07-13 by JUSYN : major version
     #---- Major version
     If   dim([M:MTL4]MATECCCOD) > 0
          If  [M:MTL4]MATECCCOD > 1
                                    TZONE(IZON)="ECCVALMAJ"
                                    TMOD(IZON) =[M:MTL4]MATECCCOD
                                    IZON+=1
          Endif
          If   [M:MTL4]MATECCCOD = 1 | [M:MTL4]MATECCCOD = 2
             ZT="MATECCSCR" : ZM="ECCVALMAJ" : Gosub TABLEAU_FICHE
          Endif
     Endif
     # Issue 107513/8 - 2015-07-13 by JUSYN : major version
     #---- Minor version
     If   dim([M:MTL4]MATECCCODMIN) > 0
          If  [M:MTL4]MATECCCODMIN > 1
                                    TZONE(IZON)="ECCVALMIN"
                                    TMOD(IZON) =[M:MTL4]MATECCCODMIN
                                    IZON+=1
          Endif
          If   [M:MTL4]MATECCCODMIN = 1 | [M:MTL4]MATECCCODMIN = 2
             ZT="MATECCSCRMIN" : ZM="ECCVALMIN" : Gosub TABLEAU_FICHE
          Endif
     Endif

     #---- Statut
     If   dim([M:MTL4]AQRCODS) > 0
          If  [M:MTL4]AQRCODS > 1 TZONE(IZON)="STA"
                                     TMOD(IZON) =[M:MTL4]AQRCODS
                                     IZON+=1
          Endif
          If   [M:MTL4]AQRCODS = 1 | [M:MTL4]AQRCODS = 2
             ZT="AQRSCRS" : ZM="STA" : Gosub TABLEAU_FICHE
          Endif
     Endif

     #---- Emplacement
     If   dim([M:MTL4]LOCCODS) > 0
          If  [M:MTL4]LOCCODS > 1 TZONE(IZON)="LOC"
                                     TMOD(IZON) =[M:MTL4]LOCCODS
                                     IZON+=1
          Endif
          If   [M:MTL4]LOCCODS = 1 | [M:MTL4]LOCCODS = 2
             ZT="LOCSCRS" : ZM="LOC" : Gosub TABLEAU_FICHE
          Endif
     Endif

     #---- Série début
     If   dim([M:MTL4]SERCODS) > 0
          If  [M:MTL4]SERCODS > 1 TZONE(IZON)="SERNUM"
                                     TMOD(IZON) =[M:MTL4]SERCODS
                                     IZON+=1
          Endif
          If   [M:MTL4]SERCODS = 1 | [M:MTL4]SERCODS = 2
             ZT="SERSCRS" : ZM="SERNUM" : Gosub TABLEAU_FICHE
          Endif
     Endif

     #---- Série fin
     If   dim([M:MTL4]SERECODS) > 0
          If  [M:MTL4]SERECODS > 1 TZONE(IZON)="SERNUMF"
                                     TMOD(IZON) =[M:MTL4]SERECODS
                                     IZON+=1
          Endif
          If   [M:MTL4]SERECODS = 1 | [M:MTL4]SERECODS = 2
             ZT="SERESCRS" : ZM="SERNUMF" : Gosub TABLEAU_FICHE
          Endif
     Endif

     #---- Identifiant 1
     If   dim([M:MTL4]IDECODS1) > 0
          If  [M:MTL4]IDECODS1 > 1 TZONE(IZON)="PALNUM"
                                     TMOD(IZON) =[M:MTL4]IDECODS1
                                     IZON+=1
          Endif
          If   [M:MTL4]IDECODS1 = 1 | [M:MTL4]IDECODS1 = 2
             ZT="IDESCRS1" : ZM="PALNUM" : Gosub TABLEAU_FICHE
          Endif
     Endif

     #---- Identifiant 2
     If   dim([M:MTL4]IDECODS2) > 0
          If  [M:MTL4]IDECODS2 > 1 TZONE(IZON)="CTRNUM"
                                     TMOD(IZON) =[M:MTL4]IDECODS2
                                     IZON+=1
          Endif
          If   [M:MTL4]IDECODS2 = 1 | [M:MTL4]IDECODS2 = 2
             ZT="IDESCRS1" : ZM="CTRNUM" : Gosub TABLEAU_FICHE
          Endif
     Endif

     #---- Désigation mouvement
     If   dim([M:MTL4]MVTDESCODS) > 0
          If  [M:MTL4]MVTDESCODS > 1 TZONE(IZON)="MVTDES"
                                     TMOD(IZON) =[M:MTL4]MVTDESCODS
                                     IZON+=1
          Endif
          If   [M:MTL4]MVTDESCODS = 1 | [M:MTL4]MVTDESCODS = 2
             ZT="MVTDESSCRS" : ZM="MVTDES" : Gosub TABLEAU_FICHE
          Endif
     Endif

     #---- Dépôt sortie
    If dim([M:MTL4]WRHCOD2)>0
       If [M:MTL4]WRHCOD2>1  TZONE(IZON)="WRH"
                             TMOD(IZON) =[M:MTL4]WRHCOD2
                             IZON+=1
       Endif
       If [M:MTL4]WRHSCR2>1  TZONE(IZON)="WRH"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:MTL4]WRHSCR2)
                             IZON+=1
       Endif
    Endif

#    Endif
     Gosub PE_MFGTRS From SUBMFX
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Endif

If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif
If [M:MTL1]ITMTRKFLG = 2
    #--- GéNéRATION des écrans et fenêtres de stock
    WNOMOBJ="MTK"
    WNOMTRS=[M:MTL0]MTSNUM
    WACSCOD=[M:MTL0]ACSCOD
    WLIBEL = [M:MTL0]DESAXX
    WENAFLG= [M:MTL0]ENAFLG
    WFLGMSK=2
    WNUM   =2
    Gosub TRT_ECRAN_STO From SUBETR
Endif


Return


#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW" [AWI] : Endif : # Si appel par le FUNMFGTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR" [AWP] : Endif : # Si appel par le FUNMFGTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS

#----- Suppression fenêtre si transaction non active -----#
Gosub TRT_SUP_FEN
If [M:MTL0]ENAFLG=1 : Return : Endif
#----- Génération fenêtre pour suivi si transaction active -----#
Delete [AWI] Where WIN=NOMWIN1
If fstat=1  GOK=-1 : GLOCK="$AWINDOW"-NOMWIN1
Elsif fstat GOK=0  : Call RSTA ("AWI",NOMWIN1) From GLOCK
Endif
Delete [AWP] Where WIN=NOMWIN1
If fstat=1  GOK=-1 : GLOCK="$AWINPAR"-NOMWIN1
Elsif fstat GOK=0  : Call RSTA ("AWP",NOMWIN1) From GLOCK
Endif
Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
  [F:AWI]MSKENT    = "WR"+num$([M:MTL0]MTSTYP)+[M:MTL0]MTSNUM+"0"
  WNOMMSK="WR"+num$([M:MTL0]MTSTYP)+[M:MTL0]MTSNUM+"1"
  I=find("MTK1",[F:AWI]NOMMSK)-1 : If I<0 I=1 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = [M:MTL1]OPETRKFLG
  WNOMMSK="WR"+num$([M:MTL0]MTSTYP)+[M:MTL0]MTSNUM+"2"
  I=find("MTK2",[F:AWI]NOMMSK)-1 : If I<0 I=2 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = [M:MTL1]ITMTRKFLG
  WNOMMSK="WR"+num$([M:MTL0]MTSTYP)+[M:MTL0]MTSNUM+"3"
  I=find("MTK3",[F:AWI]NOMMSK)-1 : If I<0 I=3 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = [M:MTL1]MATTRKFLG

  [F:AWI]ACS       = [M:MTL0]ACSCOD
  If dim([F:AWI]LIBEL)>0
    [F:AWI]LIBEL   = [M:MTL0]DESAXX
  Endif
  [F:AWI]ENAFLG    = 2
  [F:AWI]TRN       = [M:MTL0]MTSNUM
  [F:AWI]MDL       = 1            # !!

  # Issue 79269 - New entry Point to Hide/Show Specific Tab
  Gosub PE_MFGTRSWIN From SUBMFX

  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif

Endif
Call VALID(NOMWIN1,APPLI,1,OK) From VALWIN
Return


#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return


$COP_ECRAN
Local Char WINT(20)(2)
Local Char WTIT(100)
Local Char WMSK(GLONAMK)(5)
Local Char WABR(06)(5)
#
Raz WMSK, WABR
Call TEXTFIC("MFGTRS","MTSNUM",2,WINT(0)) From OBJDIV
Call TEXTFIC("MFGTRS","ACSCOD",2,WINT(1)) From OBJDIV
WTIT = WINT(0)+" : "+[M:MTL0]MTSNUM-[M:MTL0]DESAXX-WINT(1)+" : "+[M:MTL0]ACSCOD
WMSK(0) = "MTL0"
WMSK(1) = "MTL1"
WMSK(2) = "MTL2"
WMSK(3) = "MTL3"
WMSK(4) = "MTL4"
WMSK(5) = "STOETR2"
Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
Return


#######################################################################
# Présentation des zones en mode tableau ou mode fiche                #
#  - Ne concerne que les zones d'un tableau                           #
#  - Code traitement TMOD de GENECR = 9                               #
#  - Utilisation de TINT ( 1=fiche+tableau  2=tableau  3=fiche )      #
#######################################################################
$TABLEAU_FICHE
If evalue ("dim([M]"+ZT+"("+num$(ZI)+"))") > 0
  If evalue ("[M]"+ZT+"("+num$(ZI)+")") > 0
&  & evalue ("[M]"+ZT+"("+num$(ZI)+")") < 4
    TZONE(IZON)=ZM
    TMOD(IZON)=9
    TINT(IZON)= num$(evalue("[M]"+ZT+"("+num$(ZI)+")"))
    IZON+=1
  Endif
Endif
ZI=0
Return


#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(7)<>2 End Endif

# Validation transactions depuis génération des patchs
Call GENPATCH(2,APPLI) From FUNMFGTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

# Génération transactions à partir du dico des types de transaction
Call GENDOS(2,APPLI) From FUNMFGTRS

End

########################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE    : MODULE=8
Local Integer TYP       : TYP=2
Local Char    CODTAB(GLONTRS) : CODTAB=TABLE
#-----
Gosub OUVRE_COPTRS From SELTRS
Gosub EXEC_COPTRS  From SELTRS
Gosub FERME_COPTRS From SELTRS
Return

########################################
Subprog AS_MTSNUM(VALEUR)
Variable Char    VALEUR()
[M:MTL0]MTSTYP = 2
End
########################################
Subprog AM_WRHOBY(VALEUR)
Variable Integer VALEUR
#--- Dem 60616
#If VALEUR = 2
#   [M:MTL1]WRHCOD  = 1
#   [M:MTL4]WRHCOD2 = 2
#   [M:MTL4]WRHSCR2 = 1
#   Grizo [M:MTL1]WRHCOD
#   Grizo [M:MTL4]WRHCOD2
#   Grizo [M:MTL4]WRHSCR2
#Else
#   Actzo [M:MTL1]WRHCOD
#   Actzo [M:MTL4]WRHCOD2
#   If [M:MTL4]WRHCOD2=3
#       Grizo [M:MTL4]WRHSCR2
#   Else
#       Actzo [M:MTL4]WRHSCR2
#   Endif
#Endif
If VALEUR = 2
   [M:MTL1]WRHCOD  = 1
   Grizo [M:MTL1]WRHCOD
   If [M:MTL4]WRHCOD2=1
      [M:MTL4]WRHCOD2=3
      [M:MTL4]WRHSCR2=1
   Endif
   If [M:MTL4]WRHCOD2=3
       Grizo [M:MTL4]WRHSCR2
   Else
       Actzo [M:MTL4]WRHSCR2
   Endif
Else
   Actzo [M:MTL1]WRHCOD
Endif
#---
Affzo [M:MTL1]WRHCOD
Affzo [M:MTL4]WRHCOD2
Affzo [M:MTL4]WRHSCR2
End
########################################
#--- Dem 60616
Subprog AS_WRHCOD2(VALEUR)
Variable Integer VALEUR
If [M:MTL1]WRHOBY=2 GMENLOC(1)=1 Endif
End
#---

