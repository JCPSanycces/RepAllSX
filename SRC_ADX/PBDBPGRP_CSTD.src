#<AdxTL>@(#)3.0.0.0 $Revision$
# Class PBDBPGRP
# Update: ANGRE - SAM # 111399 2015-12-21



#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
    Case [L]CURPTH
        When "PBDBPGRPD" :    # Manage the handling of the detail collection: set COD + LEG
            Case [L]AEVENT
                When "ADDLINE_AFTER" : Gosub ADDLINE_AFTER_PBDBPGRPD   # A line is added
            Endcase
        Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


# SAM # 111399 $METHODS outcommented ADDLINE_AFTER is now implemented in $EVENT
$METHODS
#    Case [L]CURPTH
#        When "PBDBPGRPD" :    # Manage the handling of the detail collection: set COD + LEG
#            Case [L]ACTION
#                When "ADDLINE_AFTER" : Gosub ADDLINE_AFTER_PBDBPGRPD   # A line is added
#            Endcase
#        Endcase
Return

# SAM # 111399 changed ACTION to ARULE
$PROPERTIES
    Case [L]CURPRO
        When "COD"
              Case [L]ARULE
                  When "PROPAGATE" : Gosub PROPAGATE_COD
              Endcase
        When "LEG"
              Case [L]ARULE
                  When "CONTROL"   : Gosub CONTROL_LEG
                  When "PROPAGATE" : Gosub PROPAGATE_LEG
              Endcase
    Endcase
Return



############################################################################################
# Implementation of the METHODS
############################################################################################

$ADDLINE_AFTER_PBDBPGRPD
   this.COD = this.APARENT.COD
   this.LEG = this.APARENT.LEG
Return



############################################################################################
# Implementation of the PROPERTIES
############################################################################################

$PROPAGATE_COD
     Local Integer I

     # Loop on all the lines of "PBDBPGRPD" collection to assign CODE
     For I = 1 To maxtab( this.PBDBPGRPD )
         If this.PBDBPGRPD(I) <> null : this.PBDBPGRPD(I).COD = this.COD : Endif
     Next I
Return

$CONTROL_LEG
    Local File ATABDIV [ADI]
    Local Integer I

    # If the given legislation doesn't exist -> message
    Read [ADI]CODE = 909;this.LEG
    If fstat
        ASTATUS = fmet this.ASETERROR( "LEG", func AFNC.MES1( mess(345,107,1), this.LEG ), CST_AERROR ) # "$1$ is not a valid legislation."
    Endif
Return

$PROPAGATE_LEG
    Local Integer I

    # Loop on all the lines of "PBDBPGRPD" collection to assign LEG
    For I = 1 To maxtab(this.PBDBPGRPD )
        If this.PBDBPGRPD(I) <> null
            this.PBDBPGRPD(I).LEG = this.LEG
        Endif
    Next I
Return

