#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
#  Sous programmes pour la gestion des rendez-vous                           Module CRM 4 mai 2006
##########################################################################################################
#                                                                                                        #
# CREBAP    : Sous-programme de création d'un rendez-vous
#                                                                                                        #
##########################################################################################################
Subprog TEST
Local Char SZAPTNUM
Local Integer LERRCOD

  GSYNCOUTLOOK = 0
  Call FERME_TRACE From LECFIC
  Call CREBAP("SUBBAPCC", 2, 2, SZAPTNUM, LERRCOD) 
  GSYNCOUTLOOK = 0
End

##########################################################################################################
# Sous-programme de création d'un rendez-vous
#########################################
Subprog CREBAP(SZCREBAPTRT, ITRACE, ILEC_TRACE, SZAPTNUM, LERRCOD) 
Value Char SZCREBAPTRT
Value Integer ITRACE
Value Integer ILEC_TRACE
Variable Char SZAPTNUM
Variable Integer LERRCOD

Global Char GSZCREBAPTRT
Global Integer GICREBAPTRACE

Local Integer IBOPENTRACE
Local Integer IBDEBTRANSFLG
Local Integer SZTMP

  IBOPENTRACE = 0
  GSZCREBAPTRT = SZCREBAPTRT
  GICREBAPTRACE = ITRACE
  If GSZCREBAPTRT = "" Then
    GSZCREBAPTRT = "SUBBAPCC"
  Endif
  Raz LERRCOD, GMESSAGE
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If ITRACE Then
    If GTRACE = "" Then
      #Création du rendez-vous démarrée à partir du contexte : + GSZCREBAPTRT  
      Call OUVRE_TRACE (mess(320,177,1) - GSZCREBAPTRT) From LECFIC
      IBOPENTRACE = 1
    Endif
  Endif
#--- variables
Local  Integer OK, SAVGIMPORT 
Local  Char    ACTION(20), ABREV(5) 
Local Char SAVGABREV

  #--- declaration et chargement des variables objet 
  ABREV="BAP"
  SAVGABREV = GABREV
  GABREV = "BAP"
  Gosub DEFVAR From GOBJET    # FGR 07/06/2010 : X3SUIVI64666 A faire juste après GABREV
  #
  SAVFONC = GFONCTION         # FGR 16/09/2009 : X3SUIVI57846
  GFONCTION = "GES"+ABREV     # FGR 16/09/2009 : X3SUIVI57846
  #Gosub DEFVAR From GOBJET   # FGR 07/06/2010 : X3SUIVI64666 là on perd SAVFONC !
  SAVGIMPORT = GIMPORT
  GIMPORT = 1
  #Gestion des autorisations
  Call AUTORIS From EXEFNC
  GOK = 1
  OK = 1
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=AVANT_OUVRE",0) From GESECRAN
  Endif
  ACTION = "AVANT_OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR AVANT_OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #--- ouverture de la fenêtre contrat
  If !clalev([M:BAP0]) : Local Mask BAP0 [BAP0] : Endif
  If !clalev([M:BAP1]) : Local Mask BAP1 [BAP1] : Endif
  If !clalev([M:BAP2]) : Local Mask BAP2 [BAP2] : Endif
  If !clalev([M:BAP3]) : Local Mask BAP3 [BAP3] : Endif
  If !clalev([M:BAP4]) : Local Mask BAP4 [BAP4] : Endif
  If !clalev([M:BAP5]) : Local Mask BAP5 [BAP5] : Endif
  Raz [M:BAP0], [M:BAP1], [M:BAP2], [M:BAP3], [M:BAP4], [M:BAP5]
  #--- ouverture des tables necessaires
  If !clalev([F:BAP]) : Local File BAPPOINT [BAP] : Endif
  Gosub OUVRE From WOBAP 
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=OUVRE",0) From GESECRAN
  Endif
  ACTION = "OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  WINPROG = "WGOBAP"
  GREP = "C"
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=RAZCRE",0) From GESECRAN
  Endif
  ACTION = "RAZCRE" : Gosub ACTION From GOBJSUB
  If GERR = 1 Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR RAZCRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #--- chargement des masques de objet
  If ITRACE > 1 Then
    Call ECR_TRACE("MASK",0) From GESECRAN
  Endif
  #------------------------------------------------------------------------  
  # chargement masques enregistrement tache
  Default Mask [BAP0]
  Call SAIMSK("BAP","IMP_ZONE","SUBBAPCC") From W0BAP0
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK BAP0 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [BAP1]
  Call SAIMSK("BAP","IMP_ZONE","SUBBAPCC") From W0BAP1
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK BAP1(IMP_ZONE) mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [BAP1]
  Call SAIMSK("BAP","IMP_TAB","SUBBAPCC") From W0BAP1
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK BAP1(IMP_TAB) mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [BAP2]
  Call SAIMSK("BAP","IMP_ZONE","SUBBAPCC") From W0BAP2
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK BAP2(IMP_ZONE) mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [BAP2]
  Call SAIMSK("BAP","IMP_TAB","SUBBAPCC") From W0BAP2
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK BAP2(IMP_TAB) mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [BAP3]
  Call SAIMSK("BAP","IMP_ZONE","SUBBAPCC") From W0BAP3
  If mkstat Then
    If ITRACE > 3 Then
      Call ECR_TRACE("  ERROR  MARSK BAP3  mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [BAP4]
  Call SAIMSK("BAP","IMP_ZONE","SUBBAPCC") From W0BAP4
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK BAP4  mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [BAP5]
  Call SAIMSK("BAP","IMP_ZONE","SUBBAPCC") From W0BAP5
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK BAP5  mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  GPOINT = "MSKCREBAP" : Gosub ENTREE From EXEFNC  #CHECK IGNORE_LINE
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  GPOINT=MSKCREBAP mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 8
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=VERIF_CRE",0) From GESECRAN
  Endif
  ACTION = "VERIF_CRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR VERIF_CRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  GOK = 1
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [BAP]
  Endif
  Raz [F:BAP]
  Default File [F:BAP]
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=INICRE",0) From GESECRAN
  Endif
  ACTION = "INICRE" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR INICRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  [F:BAP] = [M:BAP0]
  [F:BAP] = [M:BAP1]
  [F:BAP] = [M:BAP2]
  [F:BAP] = [M:BAP3]
  [F:BAP] = [M:BAP4]
  [F:BAP] = [M:BAP5]
  [F:BAP]CREUSR = GUSER
  [F:BAP]CREDAT = date$
  [F:BAP]CREHOU= left$(time$, 2) + mid$(time$, 4, 2)
  If ITRACE > 1 Then
    #Ecriture [F:BAP] - APTNUM=+[F:BAP]APTNUM
    Call ECR_TRACE(mess(321,177,1) - [F:BAP]APTNUM,0) From GESECRAN
  Endif
  Write [F:BAP]
  If fstat Then
    #Erreur lors de l'écriture du rendez-vous+" APTNUM="+[F:BAP]APTNUM
    Call ECR_TRACE(mess(395,177,1) - "APTNUM=" - [F:BAP]APTNUM,1) From GESECRAN
    LERRCOD = 9
    GOK = 0
    Call FSTA("BAP") From GLOCK
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=CREATION",0) From GESECRAN
  Endif
  ACTION = "CREATION" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR CREATION",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If IBDEBTRANSFLG = 0 Then
    Commit
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=APRES_CRE",0) From GESECRAN
  Endif
  ACTION = "APRES_CRE" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR APRES_CRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If ITRACE Then
    Call ECR_TRACE("[M:BAP0]APTNUM="+[M:BAP0]APTNUM+"  GOK="+num$(GOK),0) From GESECRAN
  Endif
  If GOK <= 0 Then
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  SZAPTNUM = [M:BAP0]APTNUM
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=FERME",0) From GESECRAN
  Endif
  ACTION = "FERME" : Gosub ACTION From GOBJSUB
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC         # FGR 16/09/2009 : X3SUIVI57846
  Kill GSZCREBAPTRT 
  Kill GICREBAPTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC  
    Endif
  Endif
End

##########################################################################################################
$ACTION
Local Char SZVALBEFORE
Local Char SZVALAFTER
Local Integer IBTESTOK

  IBTESTOK = 0
  Raz SZVALBEFORE
  Raz SZVALAFTER
  If  evalue ("type([M]"+IMPZON+")") < 300 Then
    IBTESTOK = 1
  Endif
  If IBTESTOK = 1
    SZVALBEFORE =num$(evalue ("[M]"+IMPZON))
  Endif
  If GICREBAPTRACE > 1 Then
    Call ECR_TRACE("ACTION = "+ACTION-"IMPZON="+IMPZON-"XOK="+num$(XOK),0) From GESECRAN
    If  IBTESTOK = 1 Then
      #"    "+Valeur avant = +" : " +SZVALBEFORE)
      Call ECR_TRACE("    " - mess(369,177,1) - ":" - SZVALBEFORE,0) From GESECRAN
    Endif
  Endif
  Case ACTION 
     When "IMP_ZONE" : Gosub BAP_SET_HEA_INFO From=GSZCREBAPTRT
     When "IMP_TAB"  : Gosub BAP_SET_DET_INFO From=GSZCREBAPTRT
  Endcase
  If IBTESTOK = 1 Then
    SZVALAFTER =num$(evalue ("[M]"+IMPZON))
    If SZVALAFTER <> SZVALBEFORE Then
      IMPMOD = 1
    Endif
  Else
    IMPMOD = 1
  Endif
  If GICREBAPTRACE > 1 Then
    If IBTESTOK = 1 Then
      #"    "+Valeur après = +" : " +SZVALAFTER
      Call ECR_TRACE("    " - mess(370,177,1) - ":" - SZVALAFTER,0) From GESECRAN
    Endif
  Endif
Return

##########################################################################################################
$ONERROR
  If IBDEBTRANSFLG = 0 Then
    If adxlog Then
      Rollback
    Endif
  Endif
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GOK = 0
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC         # FGR 16/09/2009 : X3SUIVI57846
  Kill GSZCREBAPTRT 
  Kill GICREBAPTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC  
    Endif
  Endif
Return

##########################################################################################################
# Affectation des valeurs pour la création d'une tache. (exemple)
#############################################################################
$BAP_SET_HEA_INFO_EXEMPLE
  Case IMPZON
    When "APTNUM" 
      #Numéro de rendez-vous        
      [M:BAP0]APTNUM= ""
    When "NBLIGCCN"
      #Nombre de Correspondant/Personne à visiter
      [M:BAP1]NBLIGCCN=0
    When "ATPREPMNA"
      #Organisateur
      [M:BAP2]ATPREPMNA= ""      
    When "NBLIGREP"
      #Nombre de représentant 
      [M:BAP2]NBLIGREP(indice)= 0
    When "ATPADDCMT"
      #Description adresse
      [M:BAP3]ATPADDCMT=""
    When "FULDAY"
      #Journée entière
      [M:BAP1]FULDAY= 1     
    When "APTDUR"
      #Durée rendez-vous
      [M:BAP1]APTDUR= ""
    When "APTDAT"
      #Date rendez-vous
      [M:BAP1]APTDAT= ""      
    When "APTHOU"
      #Heure rendez-vous
      [M:BAP1]APTHOU= ""      
    When "APTDATEND"
      #Fin rendez-vous
      [M:BAP1]APTDATEND= ""      
    When "APTHOUEND"
      #Heure fin
      [M:BAP1]APTHOUEND= ""      
    When "FULOBJ"
      #sujet/Objectif
      #[M:BAP1]FULOBJ= 
    When "FULRPO"
      #Compte rendu
      #[M:BAP4]FULRPO= ""
  Endcase
Return

#############################################################################
#DETAIL
$BAP_SET_DET_INFO_EXEMPLE
  Case IMPZON
    When "APTCCNNUM"
      #Personne
      Case indice
        When 0
          IMPMOD=1 
          [M:BAP2]APTCCNNUM(indice)= ""      
        When 1
          IMPMOD=1 
          [M:BAP2]APTCCNNUM(indice)= ""      
      Endcase
    When "APTCOR"
      #Correspondant    Personne à visiter
      Case indice
        When 0
          IMPMOD=1 
          [M:BAP1]APTCOR(indice)=""
        When 1
          IMPMOD=1 
          [M:BAP1]APTCOR(indice)=""
      Endcase
    When "APTREPNUM"
      #Représentant
      Case indice
        When 0
          IMPMOD=1 
          [M:BAP2]APTREPNUM(indice)= ""      
        When 1
          IMPMOD=1 
          [M:BAP2]APTREPNUM(indice)= ""      
      Endcase
  Endcase
Return

##########################################################################################################
# Affectation des valeurs pour la création d'une tache. (exemple)
#############################################################################
$BAP_SET_HEA_INFO
  Case IMPZON
    When "APTNUM" 
      #Numéro de rendez-vous        
      # [M:BAP0]APTNUM= ""
    When "NBLIGCCN"
      #Nombre de Correspondant/Personne à visiter
      [M:BAP1]NBLIGCCN=2
    When "ATPREPMNA"
      #Organisateur
      [M:BAP2]ATPREPMNA= "LSE12"      
    When "NBLIGREP"
      #Nombre de représentant 
      [M:BAP2]NBLIGREP(indice)= 2
    When "ATPADDCMT"
      #Description adresse
      [M:BAP3]ATPADDCMT="Mon lieu de rendez vous"
    When "FULDAY"
      #Journée entière
      [M:BAP1]FULDAY= 1     
    When "APTDUR"
      #Durée rendez-vous
      [M:BAP1]APTDUR= "25"
    When "APTDAT"
      #Date rendez-vous
      [M:BAP1]APTDAT= "20060525"      
    When "APTHOU"
      #Heure rendez-vous
      [M:BAP1]APTHOU= "1010"      
    When "APTDATEND"
      #Fin rendez-vous
      [M:BAP1]APTDATEND= "20060525"      
    When "APTHOUEND"
      #Heure fin
      [M:BAP1]APTHOUEND= "1111"      
    When "FULOBJ"
      #sujet/Objectif
      #[M:BAP1]FULOBJ= 
    When "FULRPO"
      #Compte rendu
      #[M:BAP4]FULRPO= ""
  Endcase
Return

#############################################################################
#DETAIL
$BAP_SET_DET_INFO
  Case IMPZON
    When "APTCOR"
      #Correspondant    Personne à visiter
      Case indice
        When 0
          IMPMOD=1 
          [M:BAP1]APTCOR(0)="000000000000031"
        When 1
          IMPMOD=1 
          [M:BAP1]APTCOR(1)="000000000000030"
      Endcase
    When "APTREPNUM"
      #Représentant
      Case indice
        When 0
          IMPMOD=1 
          [M:BAP2]APTREPNUM(0)= "LSE12"    
        When 1
          IMPMOD=1 
          [M:BAP2]APTREPNUM(1)= "JPJ"      
      Endcase
  Endcase
Return
