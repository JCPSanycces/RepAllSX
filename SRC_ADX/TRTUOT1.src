#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
#   Paramétrage des unité de temps                                        Module CRM        20 mai 2003
##########################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When "OK"           : Gosub ONOK
 When Default
Endcase
Return


##########################################################################################################
$OUVRE
If !clalev([F:TUN]) : Local File TABUNIT [TUN] : Endif
If !clalev([F:UOT]) : Local File UNITOFTIME [UOT] : Endif

Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
If [M:UOT1]DIRTY
    ETABOU(GVALI) = 1
Else
    ETABOU(GVALI) = 0
Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT

#Définition du type des unités de temps.
[M:UOT1]TIT = mess(192, 182, 2)

Gosub LOADUOT1
Affzo [M:UOT1]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
#Nettoie l'écran avant de partir.
Raz [M:UOT1]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
[M:UOT1]DIRTY = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONOK

Local Integer ITER
ITER = 0

Call DEBTRANS From GLOCK
Trbegin [UOT]
Delete [UOT] Where [F:UOT]UOM <> ""
If fstat
    If fstat <> 4
        #Erreur lors de l'enregistrement des unités des temps.
        GMESSAGE = mess(188, 182, 2)
        GERR = 1
        Rollback
    Endif
Endif

If GERR
    Return
Else
    Commit
Endif

Call DEBTRANS From GLOCK
Trbegin [UOT]
For ITER = 0 To [M:UOT1]NBUOT - 1
    If [M:UOT1]UOM(ITER) <> ""
        [F:UOT]UOM = [M:UOT1]UOM(ITER)
        [F:UOT]TYPUOM = [M:UOT1]TYPUOM(ITER)
        [F:UOT]CREDAT = date$
        [F:UOT]CREUSR = GUSER
        [F:UOT]UPDDAT = date$
        [F:UOT]UPDUSR = GUSER
        Write [UOT]
        If fstat
            #Erreur lors de l'enregistrement des unités des temps.
            GMESSAGE = mess(188, 182, 2)
            GERR = 1
            Rollback
            Break
        Endif
    Endif
Next

If GERR
    Return
Else
    Commit
Endif

[M:UOT1]DIRTY = 0
FIN = 0
Return

##########################################################################################################
# Chargement des unités
#########################################################
$LOADUOT1

Local Integer ITER
ITER = 0

Raz [M:UOT1]NBUOT
Raz [M:UOT1]UOM
Raz [M:UOT1]TYPUOM

Filter [TUN] Where [F:TUN]UOMTYP = 5 Order By [F:TUN]UOM Asc

For [TUN]
    If ITER >= dim([M:UOT1]UOM) : Break : Endif

    [M:UOT1]UOM(ITER) = [F:TUN]UOM

    Read [UOT] UOT0 = [F:TUN]UOM
    If fstat
        [M:UOT1]TYPUOM(ITER) = 5
    Else
        [M:UOT1]TYPUOM(ITER) = [F:UOT]TYPUOM
    Endif

    ITER += 1
Next

Filter [TUN]

[M:UOT1]NBUOT = ITER

Return
