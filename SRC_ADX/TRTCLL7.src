##########################################################################################################
#   Gestion des tentatives d'appels                      Module CRM         18 juillet 2000
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If !clalev([F:CTT]) : Local File CALLATTEMP [CTT] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Integer I

  I = 0
  Filter [CTT] Where CLLNUM = PARAM(1)
  For [CTT]
    If I > 24 Then
      Break
    Endif
    [M:CLL7]DAT(I) = [F:CTT]CTTDAT
    [M:CLL7]HOU(I) = [F:CTT]HOUCRE
    I += 1
  Next
  [M:CLL7]NBATT = I
  Filter [CTT]
  Affzo [M:CLL7]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

