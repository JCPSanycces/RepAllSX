Subprog AS_CTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
VALEUR=func TPSSTD.CALC_CTRDATDEF([M]REFNUM,[M]CTRNUM,[M]REGFIN,[M]PYRDAT,[M]ENDDAT(nolign-1),1)
End

Subprog C_CTRDAT(VALEUR)
Variable Date    VALEUR
Local    Date    CTRDATREF(0..),XITDAT
Local    Integer I

  If VALEUR=[0/0/0] Then End : Endif
  # Contrôle existence
  #ADNGO - 2017-01-11 - X3-12021 - START
  #Read [F:CTR]CTR0=[M]REFNUM;[M]CTRNUM;VALEUR
  Read [F:HRCTR]CTR0=[M]REFNUM;[M]CTRNUM;VALEUR
  #ADNGO - 2017-01-11 - X3-12021 - END
  If fstat
  #ADNGO - 2017-01-11 - X3-12021 - START
    #GMESSAGE=mess(26,701,1) : # Contrat inexistant
    GMESSAGE=mess(26,10701,1) : # Contrat inexistant
  #ADNGO - 2017-01-11 - X3-12021 - END
    mkstat=2 : End
  Else
#ADNGO - 2017-01-11 - X3-12021 - START
#    [L]XITDAT=[F:CTR]XITDAT
#    Filter [CTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM Order By CTRDAT Desc
#    I=0
#    For [F:CTR]
#      [L]CTRDATREF(I)=[F:CTR]CTRDAT
#      If [F:CTR]CTRDAT<=[M]REGFIN | ([F:CTR]FLGRET=2 & [F:CTR]RETDATEFF<=[M]REGFIN) Then
#        Break
#      Endif
#      I+=1
#    Next
#    Filter [F:CTR]
    [L]XITDAT=[F:HRCTR]XITDAT
    Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM Order By CTRDAT Desc
    I=0
    For [F:HRCTR]
      [L]CTRDATREF(I)=[F:HRCTR]CTRDAT
      If [F:HRCTR]CTRDAT<=[M]REGFIN | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=[M]REGFIN) Then
        Break
      Endif
      I+=1
    Next
    Filter [F:HRCTR]
#ADNGO - 2017-01-11 - X3-12021 - END
    If !find(VALEUR,CTRDATREF) Then
    #ADNGO - 2017-01-11 - X3-12021 - START
      #GMESSAGE=mess(138,701,1) : # Contrat incompatible avec l'événement
      GMESSAGE=mess(138,10701,1) : # Contrat incompatible avec l'événement
    #ADNGO - 2017-01-11 - X3-12021 - END
      mkstat=2 : End
    Endif
  Endif
  If !mkstat Then
    If dim([M]SCTRDAT)>0 Then
      [M]SCTRDAT(nolign-1)=[L]XITDAT : Affzo [M]SCTRDAT(nolign-1)
    Endif
    If dim([M]FCYT)>0 Then
    #ADNGO - 2017-01-11 - X3-12021 - START
      #[M]FCYT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRFCY","CTR")
      [M]FCYT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRFCY","HRCTR")
    #ADNGO - 2017-01-11 - X3-12021 - END
      Affzo [M]FCYT(nolign-1)
    Endif
    If dim([M]SRVT)>0 Then
    #ADNGO - 2017-01-11 - X3-12021 - START
      #[M]SRVT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRSRV","CTR")
      [M]SRVT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRSRV","HRCTR")
    #ADNGO - 2017-01-11 - X3-12021 - END
      Affzo [M]SRVT(nolign-1)
    Endif
  Endif
End

