#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Modification :
#     SEGAY - 22/09/11 - bug 76457
#          Test du Kill sur Variable globale
#     SEGAY - 04/10/11 - bug 77201
#       dans le contrôle C_NBRHOU on appel celui de TPSSTD qui
#       peut remettre le nbr de jour [M]NBRDAY à 0 aprés le VALORIS
#       si le paramètre HEURE = 0
#       dans la régul dans ce cas on remet l'ancienne valeur de [M]NBRDAY.
#     SEGAY - 13/02/12 - FQ74044 -
#      Ajout vérification du nouveau champ FILTRE sur la nature d'évènement
#     SEGAY - 21/02/13 - FQ88136 -
#      Test sur ligne si temps déjà saisi dans TIMEMP
#      Tenir compte si temps en négatif ou pas
#     FQ85820 - 29/04/13 - prise en compte date d'effet + fiches de rétroactivité
######################################################################################

GUSRAUZ(1) = "123456"
GFONCTION = "TPSSTDR"
Local Char PARAM(30)(1..3) ,  VALEUR(10)
PARAM(1) = "ASN200500000215"
PARAM(2) = "20090228"
Call TRAITE_CHAR(VALEUR,PARAM,"TPSSTDR","TPSSTDR","",5,"XWTPSSTDR") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "FIN_LISTE"   : Gosub FIN_LISTE
 When "CONTROLE"    : Gosub CONTROLE
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "ENR"         : Gosub ENREGISTRE
 When "ABA"         : Gosub ABANDON
 When "END"         : Gosub FIN
 When "SETBOUT"     : Gosub SETBOUT
 When "BOUTON"      : Gosub BOUTON
 When "MEN"         : Gosub MENU
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SUI"         : Gosub SUI
 When "PRE"         : Gosub PRE
 When "FIR"         : Gosub FIR
 When "LAS"         : Gosub LAS
 When "TERMINE"     : Gosub KILLVARG
Endcase
Return

$KILLVARG
If !dim(FROM_NAVIG)>0 : # vient de TPSSTD
   If dim(GEVT)>0   : Kill GEVT   : Endif
Endif
Return

#####################################################################################
# Remplissage de la liste des transactions de saisie
#####################################################################################

$INIT
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
If clalev([F:STH])=0 : Local File SCRTPSH [STH] : Endif
# Issue 109533 - 2015-10-26 by BRBAN : No longer need in this function. Needed on GESDCG function.
# BRBAN 17/06/2014 SAM 96364 - PAIEV6
#If func AFNC.ACTIV("KPOAO")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KSA")=0)
#  Call MESSAGE(mess(16,11553,1)-mess(17,11553,1)) From GESECRAN
#Endif
Return

$SEL_LISTE
Local Integer OK
Raz GFLAG
# Paramètre utilisateur
If GDEFSCR2<>""
# FQ99390 - 17/04/14 - Si on veut entrer dans la fonction alors que le paramètre est renseigné, définir NBTEX et TEX(1) ; GFLAG pas nécessaire
# car réinitialisé ensuite par TEX(1)
 NBTEX = 1
 # FQ102658 - 16/09/14 - GDEFSCR2 et non pas GDEFSCR
 TEX(1) = GDEFSCR2
 #GFLAG = GDEFSCR2
 Return
Endif

Filter [STH] Where ENAFLG=2 and REGFLG=2
For [STH]
 OK = 1
 # Code activité
 If [F:STH]CODACT<>""
  Read [ACV]CODACT=[F:STH]CODACT
  If fstat or [F:ACV]FLACT<>2
   OK = 0
  Endif
 Endif
 # Code d'accès
 If [F:STH]CODACS<>"" & GUSRACS<>2
  Read [ACC]CODACC = GUSER;[F:STH]CODACS
  If fstat or [F:ACC]EXEC<>2
   OK = 0
  Endif
 Endif
 If OK
  NBTEX +=1
  TEXTE(NBTEX) = format$("Kb:"+num$(GLONSTH)+"X",[F:STH]COD)-':'-[F:STH]DES
  TEX(NBTEX)   = [F:STH]COD
 Endif
Next
Filter [STH]
If NBTEX=0 Then
  GMESSAGE=mess(4,126,1) : # Aucune transaction autorisée
  GERR=1
Endif
Return

$FIN_LISTE
GFLAG = VALEUR
Return

# Pas de transaction saisie
$CONTROLE
If GSTATUT = 7 | GFLAG=""
 FIN = 1
 Return
Endif
Call LECTURE("STH",GFLAG,"") From CONTOBJ
If fstat
 If GFLAG<>""
  Raz GMESSAGE
  Call TITOBJ("STH","!",GMESSAGE) From CONTOBJ
  GMESSAGE -= ":"-GFLAG-mess(86,105,1) : # Paramétrage à revoir
 Endif
 GERR = 1 : FIN = 1
 Return
Endif
Return


#####################################################################################
# Saisie des temps
#####################################################################################

####################################
$OUVRE
Local Mask TPSVENT [VTL] , VENTILE2 [VT2], TPSSTDR [TPS2]
Local Char    SAVFONC(GLONAFC)
SAVFONC = GFONCTION
Case GACTION
 When "TPSSTDR" : GFONCTION = "TPSSTDR"
Endcase
Call AUTORIS From EXEFNC
Gosub OUVFIC From TPSJOU
Raz [M:TPS2]
I=0 : J=0

I=0
##**92876 : We don't want to manage CCE* fields here
For [F:STD]STD0 Where COD=GFLAG & [F:STD]FRMFLD<>"" & !find(FLD,"TIM","STRDAT","ENDDAT") & left$(FLD,3)<>'CCE'
 [M]FRMFLD(I)=[F:STD]FRMFLD
 I+=1
Next
##**92876 : We want to manage them here
Gosub OUVRE_CCE From TPSSTD
Gosub OUVRE_IJSS From TPSSTD
Return

####################################
$DEBUT
Local Integer SEMAINE
Local Char    VALPAR(10)
Local Char    CRITSAL(250) , SYMBOLE(50)
Local Integer DEFILE, SAVCONS
Local Char    SOCIETE(80)
Local Char    LESITE(GLONFCY)
SAVCONS  = GCONSULT
GCONSULT = 0
GREP = "" : REP = ""
DEFILE = 1
Gosub INIPAR From TPSSTD
Actzo [M]

zoncou="NBRLIG" : Gosub CHG_FMT From W1TPSSTDR : # ça devrait être fait en AV_NBRLIG...

Affzo [TPS2]20
Return

####################################
$APRES_MODIF
 Gosub APRES_MODIF From TPSSTD
Return

####################################
$SETBOUT
CHMEN = ""
If GREP="M"
 CHBOU = "EA"
 STADEF = GSTAENR
Else
 CHBOU = "09"
 If [M]REFNUM<>"" & [M]PYRDAT<>[0/0/0]
  CHBOU += "<>"
  If instr(1,GUSRAUZ(1),"2") & GVISA=2 & left$([M]FRMFLD(15),1)<>"-": # Saisie visa
   CHMEN = "V"
  Endif
  If instr(1,GUSRAUZ(1),"1")
   Case DEFILE
    When 1
     CHMEN += "23"
    When 2
     CHMEN += "13"
    When 3
     CHMEN += "12"
   Endcase
  Endif
 Endif
Endif
Gosub SET_BOUT_STD From GSAISIE
Gosub SET_BOUT_SPE From GSAISIE
Return

####################################
$ENREGISTRE
Call DEBTRANS From GLOCK
Gosub TR1
GREP = "" : REP = ""
Gosub DEGRISE From TPSSTD
Gosub DEVERROU From TPSSTD
Gosub CHARGE
Return

####################################
$ABANDON
Gosub CHARGE
GREP = "" : REP = ""
Gosub DEGRISE From TPSSTD
Gosub DEVERROU From TPSSTD
Return

####################################
$FIN
Gosub DEVERROU From TPSSTD
GFONCTION = SAVFONC
Call AUTORIS From EXEFNC
GCONSULT = SAVCONS
GFLAG=""
Return

########################################
$CHARGE
Local Date OLDDAT
Local Integer NUMERO, I, J
Raz [M:VT2]
Effzo 20
nolign = 0

For [TIG]TIG3 Where REFNUM=[M]REFNUM & DATPYR=[M]PYRDAT
&                 & CTRNUM=[M]CTRNUM
 nolign += 1
 [M] = [F:TIG]
 Gosub AM_PM
 [M]OLIG(nolign-1)   = [F:TIG]LIG
 #ADNGO - 2017-01-26 - X3-12021 - START
 #Call LECTURE("TIM",[F:TIG]TIM,"") From CONTOBJ
 Call LECTURE("HRTIM",[F:TIG]TIM,GCURLEG) From CONTOBJ
 #ADNGO - 2017-01-26 - X3-12021 - END
 If [F:TIM]CATTIM=3
  [M]ONBRDAY(nolign-1) = [F:TIG]NBRDAY
 Else
  [M]ONBRDAY(nolign-1) = 0
 Endif
 [M]FLGMOD(nolign-1) = 0
 If [F:TIG]STRDAT=[F:TIG]ENDDAT
  If OLDDAT<>[F:TIG]STRDAT       :#n° de plages horaire si evt mono-date
   NUMERO=1
   OLDDAT=[F:TIG]STRDAT
  Else
   NUMERO+=1
  Endif
  [M]NUMPLG(nolign-1)=NUMERO
 Endif
 If dim([M]SCTRDAT)>0 Then
 #ADNGO - 2017-01-11 - X3-12021 - START
  #Read [F:CTR]CTR0=[M]REFNUM;[M]CTRNUM;[M]CTRDAT(nolign-1)
  Read [F:HRCTR]CTR0=[M]REFNUM;[M]CTRNUM;[M]CTRDAT(nolign-1)
 #ADNGO - 2017-01-11 - X3-12021 - END
  If !fstat Then
  #ADNGO - 2017-01-11 - X3-12021 - START
    #[M]SCTRDAT(nolign-1)=[F:CTR]XITDAT
    [M]SCTRDAT(nolign-1)=[F:HRCTR]XITDAT
  #ADNGO - 2017-01-11 - X3-12021 - END
  Endif
 Endif
 If dim([M]FCYT)>0 Then
   [M]FCYT(nolign-1)=[F:TIG]FCY
 Endif
 If dim([M]SRVT)>0 Then
   [M]SRVT(nolign-1)=[F:TIG]SRV
 Endif
 Gosub CHARGE_ANA
Next
[M]ONBLIG = nolign
[M]NBRLIG = nolign

Affzo 20
Gosub AUTORIS From TPSSTD
Return

$AM_PM
[M]LEADAY(nolign-1)=3 : # Journée
If [F:TIG]STRDAT=[F:TIG]ENDDAT & [F:TIG]STRDAY=2 & [F:TIG]ENDDAY=1
 [M]LEADAY(nolign-1)=1 : # Matin
Endif
If [F:TIG]STRDAT=[F:TIG]ENDDAT & [F:TIG]STRDAY=1 & [F:TIG]ENDDAY=2
 [M]LEADAY(nolign-1)=2 : # AM
Endif
Return

##**92876 :  New process (V7 process)
####################################
$CHARGE_ANA
For I=1 To [M]NBRDIE
 If I>GOPTCANA : Break : Endif
 # ici on affecte pas [M]WDIE par [F:TIG]DIE car on repart des DIE issue de la transaction (CDT)
 # Par contre on cherche le bon DIE pour charger le bon CCE dans la bonne colonne
 J=find([M]WDIE(I-1),[F:TIG]DIE(0..dim([F:TIG]DIE)-1))
 If J
  If I<=27
   Assign "[M]CCE"+num$(I)+"(nolign-1)" With [F:TIG]CCE(J-1)
  Endif
 Endif
Next I

#92876_US2757
If [F:TIG]ANAFLG=1
 K = [M:VT2]PTVENT+1
 [M]PTV(nolign-1) = K
 For [TIA]TIA0 Where LIG=[F:TIG]LIG
  For I=1 To [M]NBRDIE
   If I>GOPTCANA : Break : Endif
   # Par contre on cherche le bon DIE pour sauver le bon CCE dans le bon champ
   J=find([M]WDIE(I-1),[F:TIA]DIE(0..dim([F:TIA]DIE)-1))
   If J
    Assign "[M:VT2]TBCCE"+num$(I)+"(K)" With [F:TIA]CCE(J-1)
    If [M:VT2]TBDIE(J-1)="" : [M:VT2]TBDIE(J-1)=[F:TIA]DIE(J-1) : Endif
   Endif
  Next I
  [M:VT2]TBAMT(K) = [F:TIA]NBRHOU
  K += 1
  [M:VT2]PTVENT += 1
 Next
 [M]PTF(nolign-1) = K-1
 If dim([M]DSP)>0 :[M]DSP(nolign-1) = "$" : Endif
Endif
Return

####################################
$TR1
Local Decimal HEURE(1..42), JOUR(1..42)
Local Date CTRDAT_VEP : # FQ91472 US2857/58 - SEGAY 02/09/14
Raz CTRDAT_VEP
GOK = 1
Trbegin [TIG]
 # Parcours des lignes supprimées
 For I=0 To [M]ONBLIG-1
  If !find([M]OLIG(I),[M]LIG(0..[M]NBRLIG-1))
   Read [TIG]TIG0 = [M]OLIG(I)
   #ADNGO - 2017-01-26 - X3-12021 - START
   #Call LECTURE("TIM",[F:TIG]TIM,"") From CONTOBJ
   Call LECTURE("HRTIM",[F:TIG]TIM,GCURLEG) From CONTOBJ
   #ADNGO - 2017-01-26 - X3-12021 - END
   #Maj cp pris avant suppression
   Gosub MAJCP2
   If GOK<1 : Break : Endif
   Delete [TIG] Where LIG=[M]OLIG(I)
   If fstat=1
    GOK = -1 : GLOCK = "$TIMEMP"-num$([M]OLIG(I)) : Break
   Endif
   Delete [TIA] Where LIG=[M]OLIG(I)
   If fstat=1
    GOK = -1 : GLOCK = "$TIMANA"-num$([M]OLIG(I)) : Break
   Endif
   #ADNGO - 2017-01-11 - X3-12021 - START
   #Read[F:CTR]CTR0=[M]REFNUM;[M]CTRNUM;[F:TIG]CTRDAT
   Read[F:HRCTR]CTR0=[M]REFNUM;[M]CTRNUM;[F:TIG]CTRDAT
   #ADNGO - 2017-01-11 - X3-12021 - END
   If !fstat & GOK & CTRDAT_VEP <> [F:TIG]CTRDAT : Gosub FLGVEP : Endif : # FQ91472 US2857/58 - SEGAY 02/09/14
  Endif
 Next I
 If   GOK<1 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 For nolign=1 To [M]NBRLIG
  # Nouvelle ligne
  If [M]LIG(nolign-1)=0
  #ADNGO - 2017-01-11 - X3-12021 - START
   #Filter [F:CTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]STRDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M]STRDAT(nolign-1)))
   Filter [F:HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]STRDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M]STRDAT(nolign-1)))
  #ADNGO - 2017-01-11 - X3-12021 - END
  #ADNGO - 2017-01-11 - X3-12021 - START
   #Read[F:CTR]CTR0 Last
   #Filter [F:CTR]
   Read[F:HRCTR]CTR0 Last
   Filter [F:HRCTR]
  #ADNGO - 2017-01-11 - X3-12021 - END
   If !fstat
   #ADNGO - 2017-01-11 - X3-12021 - START
     #[M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRFCY","CTR")
     #[M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRSRV","CTR")
     [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRFCY","HRCTR")
     [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRSRV","HRCTR")
   #ADNGO - 2017-01-11 - X3-12021 - END
   Endif
   Raz [F:TIG]
   [F:TIG] = [M]
   Local Date MCTRDAT
   If dim([M]CTRDAT)<=0 | [M]CTRDAT(nolign-1)=[0/0/0] Then
    MCTRDAT=func TPSSTD.CALC_CTRDATDEF([M]REFNUM,[M]CTRNUM,[M]DATFIN,[M]PYRDAT,[M]ENDDAT(nolign-1),1)
   Else
    MCTRDAT=[M]CTRDAT(nolign-1)
   Endif
   [F:TIG]CTRDAT=MCTRDAT
   [F:TIG]LIG     = uniqid([TIP])
   [F:TIG]DATPYR = [M]PYRDAT
   #ADNGO - 2017-01-26 - X3-12021 - START
   #Call LECTURE("TIM",[F:TIG]TIM,"") From CONTOBJ
   Call LECTURE("HRTIM",[F:TIG]TIM,GCURLEG) From CONTOBJ
   #ADNGO - 2017-01-26 - X3-12021 - END
   Gosub MAJCP1
   If GOK<1 : Break : Endif
   Gosub ANA
   If GOK<1 : Break : Endif
   Write [TIG]
   If fstat
    GOK = 0 : Call FSTA("TIG") From GLOCK : Break
   Endif
   If  GOK & CTRDAT_VEP <> [F:TIG]CTRDAT : Gosub FLGVEP : Endif : # FQ91472 US2857/58 - SEGAY 02/09/14
  # Ligne modifiée
  Elsif [M]FLGMOD(nolign-1)
   Readlock [TIG]TIG0 = [M]LIG(nolign-1)
   If fstat=1
    GOK = -1 : GLOCK = "$TIMREGUL"-num$([M]LIG(nolign-1)) : Break
   Endif
   #On supprime l'ancienne pose de cp -> donc avant le transclass
   #ADNGO - 2017-01-26 - X3-12021 - START
   #Call LECTURE("TIM",[F:TIG]TIM,"") From CONTOBJ
   Call LECTURE("HRTIM",[F:TIG]TIM,GCURLEG) From CONTOBJ
   #ADNGO - 2017-01-26 - X3-12021 - END
   Gosub MAJCP2
   If GOK<1 : Break : Endif
   If [F:TIG]ANAFLG=1
    Delete [TIA] Where LIG=[F:TIG]LIG
    If fstat=1
     GOK = -1 : GLOCK = "$TIMANA"-num$([F:TIG]LIG) : Break
    Endif
   Endif
   #ADNGO - 2017-01-11 - X3-12021 - START
   #Filter [F:CTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]STRDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M]STRDAT(nolign-1)))
   #Read[F:CTR]CTR0 Last
   #Filter [F:CTR]
   #If !fstat
    #[M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRFCY","CTR")
    #[M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRSRV","CTR")
   #Endif
   Filter [F:HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]STRDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M]STRDAT(nolign-1)))
   Read[F:HRCTR]CTR0 Last
   Filter [F:HRCTR]
   If !fstat
    [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRFCY","HRCTR")
    [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRSRV","HRCTR")
   Endif
   #ADNGO - 2017-01-11 - X3-12021 - END
   [F:TIG] = [M]
   [F:TIG]DATPYR = [M]PYRDAT
   #ADNGO - 2017-01-26 - X3-12021 - START
   #Call LECTURE("TIM",[F:TIG]TIM,"") From CONTOBJ
   Call LECTURE("HRTIM",[F:TIG]TIM,GCURLEG) From CONTOBJ
   #ADNGO - 2017-01-26 - X3-12021 - END
   #On créé la nouvelle pose de cp -> donc après le transclass
   Gosub MAJCP1
   If GOK<1 : Break : Endif
   Gosub ANA
   If GOK<1 : Break : Endif
   Rewrite [TIG]
   If fstat
    GOK = 0 : Call FSTA("TIG") From GLOCK : Break
   Endif
   If  GOK & CTRDAT_VEP <> [F:TIG]CTRDAT : Gosub FLGVEP : Endif : # FQ91472 US2857/58 - SEGAY 02/09/14
  Endif
 Next nolign
 If   GOK<1 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

#En modif je décoche les flags de VEP sauf génération auto.
####################################
$FLGVEP
# FQ91472 US2857/58 - SEGAY 02/09/14
If GPAYE & GOK
 Local Date    DATPAY2
 [L]DATPAY2=[M]PYRDAT
 If clalev([F:TIG])>0 & dim(CTRDAT_VEP)>0  Then
    CTRDAT_VEP=[F:TIG]CTRDAT
    #ADNGO - 2017-02-02 - X3-12021 - START
    #Call TPSDATPAY([M]REFNUM,[M]CTRNUM,[F:TIG]CTRDAT,[F:CTR]XITDAT,[M]PYRDAT,[F:TIG]FCY,[L]DATPAY2) From TRTTPS
    Call TPSDATPAY([M]REFNUM,[M]CTRNUM,[F:TIG]CTRDAT,[F:HRCTR]XITDAT,[M]PYRDAT,[F:TIG]FCY,[L]DATPAY2,[F:HRCTR]PERCOD) From TRTTPS
    #ADNGO - 2017-02-02 - X3-12021 - END
 Endif
 Gosub FILTRE_VEP From TRTTPS
 Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=[L]DATPAY2 & CTRNUM=[M]CTRNUM & evalue(CRITVEP)
 Read [VEP]VEP0 Last
 Filter [VEP]
 If !fstat
   Global Char GNUMBUL (GLONVCR)
   GNUMBUL=[F:VEP]BUL
   Call MAJFLGTPS ([M]REFNUM,[L]DATPAY2,[M]CTRNUM,2,1,[0/0/0]) From SUBVEP :#Synthèse
   Call MAJFLGTPS ([M]REFNUM,[L]DATPAY2,[M]CTRNUM,3,1,[0/0/0]) From SUBVEP :#Maj variables
   Call MAJFLGTPS ([M]REFNUM,[L]DATPAY2,[M]CTRNUM,4,1,[0/0/0]) From SUBVEP :#Maj analytique
   Kill GNUMBUL
 Endif
Endif
Return

####################################
$MAJCP1
Raz HEURE,JOUR
# Ajout d'une régul temps de type congé
If [F:TIM]CATTIM=3 & [F:TIG]NBRDAY>=0
 # Saisie d'un nombre positif de congé
 If [F:TIG]STRDAT<>[F:TIG]ENDDAT
  Call VALORDET([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,JOUR,HEURE,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN
 Else
  JOUR=[F:TIG]NBRDAY
 Endif
 Raz [F:TIP]
 [F:TIP] = [F:TIG]
 Call ADD_CPPRIS(JOUR) From TPSSTD1
 If GOK<1 : Return : Endif
Elsif [F:TIM]CATTIM=3
 # Saisie d'un nombre négatif de congé
 If [F:TIG]STRDAT<>[F:TIG]ENDDAT
   Call VALORDET([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,JOUR,HEURE,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN
 Else
  JOUR=[F:TIG]NBRDAY
 Endif
 Call ADD_CPREG(JOUR) From TPSSTDR1
 If GOK<1 : Return : Endif
Endif
Return

$MAJCP2
Raz HEURE,JOUR
# Suppression d'une régul temps de type congé
If [F:TIM]CATTIM=3 & [F:TIG]NBRDAY>=0
 # Saisie d'un nombre positif de congé
 Raz [F:TIP]
 [F:TIP] = [F:TIG]
 Call SUPP_CPPRIS From TPSSTD1
 If GOK<1 : Return : Endif
Elsif [F:TIM]CATTIM=3
 # Saisie d'un nombre négatif de congé
 If [F:TIG]STRDAT<>[F:TIG]ENDDAT
  Call VALORDET([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,JOUR,HEURE,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN
 Else
  JOUR=[F:TIG]NBRDAY
 Endif
 Call SUPP_CPREG(JOUR) From TPSSTDR1
 If GOK<1 : Return : Endif
Endif
Return

##**92876 :  New process (V7 process)
####################################
$ANA
If [F:TIG]DSP="$"
 [F:TIG]DSP    = ""
 [F:TIG]ANAFLG = 1
 #92876_US2757
 For I=1 To [M]NBRDIE
   If I>GOPTCANA : Break : Endif
   If [F:TIG]CCE(I-1)<>"" : [F:TIG]CCE(I-1)="" : Endif
 Next
 For K=[M]PTV(nolign-1) To [M]PTF(nolign-1)
  Raz [F:TIA]
  [F:TIA]LIG    = [F:TIG]LIG
  [F:TIA]LIGANA = K+1-[M]PTV(nolign-1)
  For I=1 To [M]NBRDIE
   If I>GOPTCANA : Break : Endif
   # Par contre on cherche le bon DIE pour sauver le bon CCE dans le bon champ
   J=find([M]WDIE(I-1),[F:TIA]DIE(0..dim([F:TIA]DIE)-1))
   If !J
    J=1
    While [F:TIA]DIE(J-1)<>"" & J<dim([F:TIA]DIE)
     J+=1
    Wend
    If [F:TIA]DIE(J-1)="" : [F:TIA]DIE(J-1)=[M]WDIE(I-1) : Endif
   Endif
   If J
    [F:TIA]CCE(J-1) = evalue("[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")")
   Endif
  Next I
  [F:TIA]NBRHOU = [M:VT2]TBAMT(K)
  Write [TIA]
  If fstat
   GOK = 0 : Call FSTA("TIA") From GLOCK : Break
  Endif
 Next K
Else
 [F:TIG]ANAFLG = 0
 For I=1 To [M]NBRDIE
  If I>GOPTCANA : Break : Endif
  # Par contre on cherche le bon DIE pour sauver le bon CCE dans le bon champ
  J=find([M]WDIE(I-1),[F:TIG]DIE(0..dim([F:TIG]DIE)-1))
  If !J
   J=1
   While [F:TIG]DIE(J-1)<>"" & J<dim([F:TIG]DIE)
    J+=1
   Wend
   If [F:TIG]DIE(J-1)="" :   [F:TIG]DIE(J-1)=[M]WDIE(I-1) : Endif
  Endif
  If J
   If I<=27
    [F:TIG]CCE(J-1)= evalue("[M]CCE"+num$(I)+"(nolign-1)")
   Endif
 Endif
 Next
Endif
Return

####################################
$AB_TR1
Rollback
Return

####################################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

####################################
$SUI
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 > [M]REFNUM
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 > [M]FCY;[M]SRV;[M]REFNUM
 When 3
  LESITE = [M]FCY
#ADNGO - 2017-01-11 - X3-12021 - START
#  Call PERIO(LESITE,[M]REFNUM) From SUBPEO
#  Filter [PEO] Where FCY=LESITE & PYRDAT>[M]PYRDAT
#  Read [PEO]PEO0 First
#  Filter [PEO]
#  If fstat>2
#   Filter [PEO] Where FCY="" & PYRDAT>[M]PYRDAT
#   Read [PEO]PEO0 First
#   Filter [PEO]
#  Endif

  Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
  #JOJAC - 2017-02-23 - START
  #Filter [HRPEOD] Where FCY=LESITE & PYRDAT>[M]PYRDAT
  Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD & PYRDAT>[M]PYRDAT
  #JOJAC - 2017-02-23 - END
  Read [HRPEOD]HRPEOD0 First
  Filter [HRPEOD]
  If fstat>2
  #JOJAC - 2017-02-23 - START
   #Filter [HRPEOD] Where FCY="" & PYRDAT>[M]PYRDAT
   Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD  & PYRDAT>[M]PYRDAT
  #JOJAC - 2017-02-23 - END
   Read [HRPEOD]HRPEOD0 First
   Filter [HRPEOD]
  Endif
#ADNGO - 2017-01-11 - X3-12021 - END
Endcase
Goto SUIVPREC

####################################
$PRE
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 < [M]REFNUM;[M]CTRNUM
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 < [M]FCY;[M]SRV;[M]REFNUM;[M]CTRNUM
 When 3
  LESITE = [M]FCY
#ADNGO - 2017-01-11 - X3-12021 - START
#  Call PERIO(LESITE,[M]REFNUM) From SUBPEO
#  Filter [PEO] Where FCY=LESITE & PYRDAT<[M]PYRDAT
#  Read [PEO]PEO0 Last
#  Filter [PEO]
#  If fstat>2
#   Filter [PEO] Where FCY="" & PYRDAT<[M]PYRDAT
#   Read [PEO]PEO0 Last
#   Filter [PEO]
#  Endif

  Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
  #JOJAC - 2017-02-23 - START
  #Filter [HRPEOD] Where FCY=LESITE & PYRDAT<[M]PYRDAT
  Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT<[M]PYRDAT
  #JOJAC - 2017-02-23 - END
  Read [HRPEOD]HRPEOD0 Last
  Filter [HRPEOD]
  If fstat>2
   #JOJAC - 2017-02-23 - START
   #Filter [HRPEOD] Where FCY="" & PYRDAT<[M]PYRDAT
   Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD & PYRDAT<[M]PYRDAT
   #JOJAC - 2017-02-23 - END
   Read [HRPEOD]HRPEOD0 Last
   Filter [HRPEOD]
  Endif
#ADNGO - 2017-01-11 - X3-12021 - END
Endcase
Goto SUIVPREC

####################################
$FIR
Local Date DATREF
DATREF=GMOIPAY
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 First
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 First
 When 3
  LESITE = [M]FCY
#ADNGO - 2017-01-11 - X3-12021 - START
#  Call PERIO(LESITE,[M]REFNUM) From SUBPEO
#  Filter [PEO] Where FCY=LESITE & PYRDAT<DATREF
#  Read [PEO]PEO0 First
#  Filter [PEO]
#  If fstat
#   Filter [PEO] Where FCY="" & PYRDAT<DATREF
#   Read [PEO]PEO0 First
#   Filter [PEO]
#  Endif

  Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
  #JOJAC - 2017-02-23 - START
  #Filter [HRPEOD] Where FCY=LESITE & PYRDAT<DATREF
  Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD & PYRDAT<DATREF
  #JOJAC - 2017-02-23 - START
  Read [HRPEOD]HRPEOD0 First
  Filter [HRPEOD]
  If fstat
   #JOJAC - 2017-02-23 - START
   #Filter [HRPEOD] Where FCY="" & PYRDAT<DATREF
   Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT<DATREF
   #JOJAC - 2017-02-23 - END
   Read [HRPEOD]HRPEOD0 First
   Filter [HRPEOD]
  Endif
#ADNGO - 2017-01-11 - X3-12021 - END
Endcase
Goto SUIVPREC

####################################
$LAS
Local Date DATREF
DATREF=GMOIPAY
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 Last
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 Last
 When 3
  LESITE = [M]FCY
#ADNGO - 2017-01-11 - X3-12021 - START
#  Call PERIO(LESITE,[M]REFNUM) From SUBPEO
#  Filter [PEO] Where FCY=LESITE & PYRDAT>DATREF
#  Read [PEO]PEO0 Last
#  Filter [PEO]
#  If fstat
#   Filter [PEO] Where FCY="" & PYRDAT>=DATREF
#   Read [PEO]PEO0 Last
#   Filter [PEO]
#  Endif

  Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
  #JOJAC - 2017-02-23 - START
  #Filter [HRPEOD] Where FCY=LESITE & PYRDAT>DATREF
  Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT>DATREF
  #JOJAC - 2017-02-23 - END
  Read [HRPEOD]HRPEOD0 Last
  Filter [HRPEOD]
  If fstat
   #JOJAC - 2017-02-23 - START
   #Filter [HRPEOD] Where FCY="" & PYRDAT>=DATREF
   Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT>=DATREF
   #JOJAC - 2017-02-23 - END
   Read [HRPEOD]HRPEOD0 Last
   Filter [HRPEOD]
  Endif
#ADNGO - 2017-01-11 - X3-12021 - END
Endcase
Goto SUIVPREC

####################################
$SUIVPREC
If fstat<=2
 If DEFILE<3
  [M]REFNUM = [F:ID]REFNUM
  [M]CTRNUM = [F:ECT]CTRNUM
  [M]NAM    = [F:ID]NAM-[F:ID]SRN
  If [F:ID]FLGMULCTR<>2
   Diszo CTRNUM
  Else
   Actzo CTRNUM
  Endif
  Affzo REFNUM, CTRNUM, NAM
  Call AM_CTRNUM([M]CTRNUM) From =PROG
 Else
 #ADNGO - 2017-04-10 - X3-12021 - START
  #If [F:PEO]FCY<>"" & [F:PEO]FCY<>LESITE
  If [F:HRPEOH]FCY<>"" & [F:HRPEOH]FCY<>LESITE
 #ADNGO - 2017-04-10 - X3-12021 - END
   # Début/Fin de fichier
   GMESSAGE = mess(11,100,1)
   GERR = 1 : Return
  Endif
  #ADNGO - 2017-01-11 - X3-12021 - START
  #[M]PYRDAT = [F:PEO]PYRDAT
  [M]PYRDAT = [F:HRPEOD]PYRDAT
  #ADNGO - 2017-01-11 - X3-12021 - END
  Call C_PYRDAT([M]PYRDAT) From =PROG
  If mkstat=0 : Call AM_PYRDAT([M]PYRDAT) From =PROG : Endif
  Affzo PYRDAT
 Endif
Endif
Gosub AUTORIS From TPSSTD
Return

####################################
$BOUTON
Case BOUT
 When "V"
 #ADNGO - 2017-01-11 - X3-12021 - START
  #OK = 2 : Call OUINON(mess(27,709,1),OK) From GESECRAN : # Confirmation du visa
  OK = 2 : Call OUINON(mess(27,10709,1),OK) From GESECRAN : # Confirmation du visa
 #ADNGO - 2017-01-11 - X3-12021 - END
  If OK=2
   Call DEBTRANS From GLOCK
   Gosub TR2
   If GOK=1
    Gosub CHARGE
   Endif
  Endif
Endcase
Return

####################################
$MENU
Case BOUT
 When "1"
  DEFILE = 1
 When "2"
  DEFILE = 2
 When "3"
  DEFILE = 3
Endcase
Return

####################################
$TR2
GOK = 1
Trbegin [TIG]
 Update [TIG] Where REFNUM=[M]REFNUM & DATPYR=[M]PYRDAT & CTRNUM=[M]CTRNUM With STAFLG=GUSER
 If fstat
  GOK = 0 : Call RSTA("TIG",[M]REFNUM) From GLOCK : Goto AB_TR2
 Endif
Commit
Return

####################################
$AB_TR2
Rollback
Return

########################################################################
# Etiquettes ecran d'entête
########################################################################

########################################
Subprog C_PYRDAT(VALEUR)
Variable Date    VALEUR
Call C_PYRDAT(VALEUR) From TPSSTD
#JOJAC - 2017-03-10 - START
Call AM_PYRDAT(VALEUR)
#JOJAC - 2017-03-10 - END
End

########################################
Subprog AM_PYRDAT(VALEUR)
Variable Date    VALEUR
Local Integer SEMAINE , NOL
Local Date    DAT , DATDEB , DATFIN
#ADNGO - 2017-01-11 - X3-12021 - START
#If [F:PEO]STA<>2 & !instr(1,GUSRAUZ(1),"5") & !instr(1,GUSRAUZ(1),"6") : # Saisie sur période fermée
If [F:HRPEOD]STA<>2 & !instr(1,GUSRAUZ(1),"5") & !instr(1,GUSRAUZ(1),"6") : # Saisie sur période fermée
#ADNGO - 2017-01-11 - X3-12021 - END

#ADNGO - 2017-01-11 - X3-12021 - START
 #GMESSAGE = mess(58,709,1) : # Période non ouverte
 GMESSAGE = mess(58,10709,1) : # Période non ouverte
#ADNGO - 2017-01-11 - X3-12021 - END
 GERR = 2
Endif
If [F:ID]FLGMULCTR<>2
#ADNGO - 2017-01-11 - X3-12021 - START
 #Filter [CTR] Where REFNUM=[M]REFNUM & (CTRDAT<=[F:PEO]PEREND(2) | (FLGRET=2 & RETDATEFF<=[F:PEO]PEREND(2)))
 #Read [CTR]CTR1 Last
 #Filter [CTR]
 #If !fstat
  #[M]FCY=[F:CTR]ETRFCY
  #[M]CTRNUM = [F:CTR]CTRNUM
  Filter [HRCTR] Where REFNUM=[M]REFNUM & (CTRDAT<=[F:HRPEOD]PEREND(2) | (FLGRET=2 & RETDATEFF<=[F:HRPEOD]PEREND(2)))
  Read [HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat
  [M]FCY=[F:HRCTR]ETRFCY
  [M]CTRNUM = [F:HRCTR]CTRNUM
#ADNGO - 2017-01-11 - X3-12021 - END
  Affzo [M]FCY,CTRNUM
  #ADNGO - 2017-01-11 - X3-12021 - START
  #Call CADRE_PYRDAT(VALEUR,[M]FCY) From TPSSUB
  Call CADRE_PYRDAT(VALEUR,[HRCTR]PERCOD) From TPSSUB
  #ADNGO - 2017-01-11 - X3-12021 - END
 Endif
Endif
#ADNGO - 2017-01-11 - X3-12021 - START
#[M]DATDEB = [F:PEO]PERSTR(0)
#[M]DATFIN = [F:PEO]PEREND(0)
#[M]FMOIS  = [F:PEO]PEREND(1)
#[M]REGDEB = [F:PEO]PERSTR(2)
#[M]REGFIN = [F:PEO]PEREND(2)

[M]DATDEB = [F:HRPEOD]PERSTR(0)
[M]DATFIN = [F:HRPEOD]PEREND(0)
[M]FMOIS  = [F:HRPEOD]PEREND(1)
[M]REGDEB = [F:HRPEOD]PERSTR(2)
[M]REGFIN = [F:HRPEOD]PEREND(2)
#ADNGO - 2017-01-11 - X3-12021 - END
Affzo [TPS2]DATDEB,DATFIN,FMOIS,REGDEB,REGFIN
If [M]REFNUM<>""
 [M]PYRDAT = VALEUR
 Gosub PRESENCE
 Gosub CHARGE
Endif
End

########################################
Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Read [ID]ID0 = VALEUR
[M]NAM = [F:ID]NAM-[F:ID]SRN
Affzo NAM
Raz [M]CTRNUM
If [F:ID]FLGMULCTR<>2
 Effzo CTRNUM
 Diszo CTRNUM
 Affzo CTRNUM
Else
 Actzo CTRNUM
 Affzo CTRNUM
Endif

If [F:ID]FLGMULCTR<>2
 If [M]PYRDAT<>[0/0/0]
#ADNGO - 2017-01-11 - X3-12021 - START
  #Filter [CTR] Where REFNUM=VALEUR & (CTRDAT<=[M]REGFIN | (FLGRET=2 & RETDATEFF<=[M]REGFIN))
  #Read[CTR]CTR1 Last
  #Filter [CTR]
  #If !fstat
   #[M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRFCY","CTR")
   #[M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRSRV","CTR")
   #[M]CTRNUM = [F:CTR]CTRNUM
  #Endif
  Filter [HRCTR] Where REFNUM=VALEUR & (CTRDAT<=[M]REGFIN | (FLGRET=2 & RETDATEFF<=[M]REGFIN))
  Read[HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat
   [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRFCY","HRCTR")
   [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRSRV","HRCTR")
   [M]CTRNUM = [F:HRCTR]CTRNUM
  Endif
#LIPET - 2017-05-31 - X3-42400 - START
#ADNGO - 2017-01-12 - X3-12021 - START
#  If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
#    Read [FCY2]FCY0 = [F:HRCTR]ETRFCY
#    If !fstat
#    GCURLEG = [F:FCY2]LEG
#    [M:TPS2]LEG = GCURLEG
#    Affzo [M:TPS2]LEG
#    Endif
#ADNGO - 2017-01-12 - X3-12021 - END
#LIPET - 2017-05-31 - X3-42400 - END
#ADNGO - 2017-01-11 - X3-12021 - END
  Affzo FCY, SRV,CTRNUM
  #ADNGO - 2017-01-11 - X3-12021 - START
  #Call CADRE_PYRDAT([M]PYRDAT,[M]FCY) From TPSSUB
  Call CADRE_PYRDAT([M]PYRDAT,[HRCTR]PERCOD) From TPSSUB
  #ADNGO - 2017-01-11 - X3-12021 - END
  If mkstat=0
#ADNGO - 2017-01-11 - X3-12021 - START
#    [M]DATDEB = [F:PEO]PERSTR(0)
#    [M]DATFIN = [F:PEO]PEREND(0)
#    [M]FMOIS  = [F:PEO]PEREND(1)
#    [M]REGDEB = [F:PEO]PERSTR(2)
#    [M]REGFIN = [F:PEO]PEREND(2)

     [M]DATDEB = [F:HRPEOD]PERSTR(0)
     [M]DATFIN = [F:HRPEOD]PEREND(0)
     [M]FMOIS  = [F:HRPEOD]PEREND(1)
     [M]REGDEB = [F:HRPEOD]PERSTR(2)
     [M]REGFIN = [F:HRPEOD]PEREND(2)
#ADNGO - 2017-01-11 - X3-12021 - END
    Affzo [TPS2]DATDEB,DATFIN,FMOIS,REGDEB,REGFIN
  Endif
  [M]REFNUM = VALEUR
  Gosub PRESENCE
  Gosub CHARGE
 Else
 #ADNGO - 2017-01-11 - X3-12021 - START
  #Filter [CTR] Where REFNUM=VALEUR
  #Read [CTR]CTR1 Last
  #Filter [CTR]
  #If !fstat
   #[M]FCY    = [F:CTR]ETRFCY
   #[M]SRV    = [F:CTR]ETRSRV
   #[M]CTRNUM = [F:CTR]CTRNUM
  #Endif
  Filter [HRCTR] Where REFNUM=VALEUR
  Read [HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat
   [M]FCY    = [F:HRCTR]ETRFCY
   [M]SRV    = [F:HRCTR]ETRSRV
   [M]CTRNUM = [F:HRCTR]CTRNUM
  Endif
 #ADNGO - 2017-01-11 - X3-12021 - END
  Affzo FCY, SRV, CTRNUM
  Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  Call LECTURE("SRV",[M]SRV,"") From CONTOBJ
 Endif
#LIPET - 2017-05-31 - X3-42400 - START
  If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
    Read [FCY2]FCY0 = [F:HRCTR]ETRFCY
    If !fstat
    GCURLEG = [F:FCY2]LEG
    [M]LEG = GCURLEG
    Affzo [M]LEG
    Endif
#LIPET - 2017-05-31 - X3-42400 - END
Endif
End

####################################
Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
If [M]PYRDAT<>[0/0/0]
 #ADNGO - 2017-01-11 - X3-12021 - START
 #Filter [CTR] Where REFNUM=[M]REFNUM & CTRNUM=VALEUR & (CTRDAT<=[M]REGFIN | (FLGRET=2 & RETDATEFF<=[M]REGFIN))
 #Read [CTR]CTR0 Last
 #Filter [CTR]
 #If !fstat
  #[M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,VALEUR,[F:CTR]CTRDAT,[M]REGFIN,"ETRFCY","CTR")
  #[M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,VALEUR,[F:CTR]CTRDAT,[M]REGFIN,"ETRSRV","CTR")
 Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=VALEUR & (CTRDAT<=[M]REGFIN | (FLGRET=2 & RETDATEFF<=[M]REGFIN))
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If !fstat
  [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,VALEUR,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRFCY","HRCTR")
  [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,VALEUR,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRSRV","HRCTR")
 #ADNGO - 2017-01-11 - X3-12021 - END
  Affzo FCY, SRV
 Endif
 [M]CTRNUM = VALEUR
 Gosub PRESENCE
 Gosub CHARGE
Else
#ADNGO - 2017-01-11 - X3-12021 - START
# Filter [CTR] Where REFNUM=[M]REFNUM & CTRNUM=VALEUR
# Read [CTR]CTR0 Last
# Filter [CTR]
# If !fstat
#  [M]FCY    = [F:CTR]ETRFCY
#  [M]SRV    = [F:CTR]ETRSRV
 Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=VALEUR
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If !fstat
  [M]FCY    = [F:HRCTR]ETRFCY
  [M]SRV    = [F:HRCTR]ETRSRV
#ADNGO - 2017-01-11 - X3-12021 - END
  Affzo FCY, SRV
  #ADNGO - 2017-01-11 - X3-12021 - START
  #Call LECTURE("FCY",[F:CTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  #ADNGO - 2017-01-11 - X3-12021 - END
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 Endif
Endif
End

########################################
$PRESENCE
Local Date    DATDEBCTR

Raz [M]FCY, SRV
Raz [M]PRE
#ADNGO - 2017-01-11 - X3-12021 - START
#For [CTR]CTR0 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
# DATDEBCTR=[F:CTR]CTRDAT
# If [F:CTR]FLGRET=2 & [F:CTR]RETDATEFF<>[0/0/0] Then
#  DATDEBCTR=[F:CTR]RETDATEFF
# Endif
# If [F:CTR]XITDAT=[0/0/0] & DATDEBCTR<=[M]REGFIN
#  For I=max([M]REGDEB,DATDEBCTR)-[M]REGDEB+1 To [M]REGFIN-[M]REGDEB+1
#    [M]PRE(I-1) = 1
#  Next I
# Elsif [F:CTR]XITDAT>=[M]REGDEB & DATDEBCTR<=[M]REGFIN
#  For I=max([M]REGDEB,DATDEBCTR)-[M]REGDEB+1 To min([M]REGFIN,[F:CTR]XITDAT)-[M]REGDEB+1
#    [M]PRE(I-1) = 1
#  Next I
# Endif
# If DATDEBCTR<=[M]REGFIN
#  [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRFCY","CTR")
#  [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRSRV","CTR")
For [HRCTR]CTR0 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
 DATDEBCTR=[F:HRCTR]CTRDAT
 If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then
  DATDEBCTR=[F:HRCTR]RETDATEFF
 Endif
 If [F:HRCTR]XITDAT=[0/0/0] & DATDEBCTR<=[M]REGFIN
  For I=max([M]REGDEB,DATDEBCTR)-[M]REGDEB+1 To [M]REGFIN-[M]REGDEB+1
    [M]PRE(I-1) = 1
  Next I
 Elsif [F:HRCTR]XITDAT>=[M]REGDEB & DATDEBCTR<=[M]REGFIN
  For I=max([M]REGDEB,DATDEBCTR)-[M]REGDEB+1 To min([M]REGFIN,[F:HRCTR]XITDAT)-[M]REGDEB+1
    [M]PRE(I-1) = 1
  Next I
 Endif
 If DATDEBCTR<=[M]REGFIN
  [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRFCY","HRCTR")
  [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRSRV","HRCTR")
#ADNGO - 2017-01-11 - X3-12021 - END
  Endif
Next
If [M]FCY<>""
 Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 Call LECTURE("SRV",[M]SRV,"") From CONTOBJ
 Affzo FCY,SRV
Endif
Return

########################################################################
# Etiquettes ecran tableau
########################################################################

####################################
$SETNOL
Local Integer NOL
NOL = nolign-1
Return

########################################
Subprog C_NBRLIG
If GVISA=2 & find(status,65,68,83,75) & [M]STAFLG(nolign-1)<>"" & !instr(1,GUSRAUZ(1),"4")
 GMESSAGE = mess(9,123,1)
 mkstat = 2
Endif
If find(status,65,68,83,75,82)
 If GCONSULT : mkstat = 2 : End : Endif
Endif
If adxgtb
 Call AM_NBRLIG
 If mkstat=2 : End : Endif
Endif
End

########################################
Subprog AM_NBRLIGOLD
If !clalev([F:TIP]) : Local File TIMEMP [TIP] : Endif
If !clalev([F:TIM]) : Local File TIMCOD [TIM] : Endif
Local Decimal TOTDAY
Local Integer NOL
NOL = nolign-2
If NOL<0 | [M]NBRDAY(NOL)<0 | [M]NBRHOU(NOL)<0 : End : Endif
Raz TOTDAY
Filter [TIP] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & [M]STRDAT(nolign-2)<=ENDDAT & [M]ENDDAT(nolign-2)>=STRDAT
For [TIP]TIP1
 If [F:TIP]TIM=[M]TIM(nolign-2)
  If [F:TIM]DAYDAC=2 & ([F:TIP]NBRDAY<1 | [M]NBRDAY(nolign-2)<1)
   TOTDAY +=min([F:TIP]NBRDAY,1)
   If TOTDAY+min([M]NBRDAY(nolign-2),1)>1
    # Evènement déjà enregistré dans la saisie des temps. Régularisation inutile.
    #ADNGO - 2017-01-11 - X3-12021 - START
    #GMESSAGE = mess(166,709,1)
    GMESSAGE = mess(166,10709,1)
    #ADNGO - 2017-01-11 - X3-12021 - END
    mkstat = 2 : Break
   Endif
  Else
   # Evènement déjà enregistré dans la saisie des temps. Régularisation inutile.
   #ADNGO - 2017-01-11 - X3-12021 - START
   #GMESSAGE = mess(166,709,1)
   GMESSAGE = mess(166,10709,1)
   #ADNGO - 2017-01-11 - X3-12021 - END
   mkstat = 2 : Break
  Endif
 Endif
Next
Filter [TIP]
If mkstat=2 : End : Endif
End

########################################
Subprog AM_NBRLIG
If !clalev([F:TIP]) : Local File TIMEMP [TIP] : Endif
If !clalev([F:TIM]) : Local File TIMCOD [TIM] : Endif
Local Decimal TOTDAY
Local Integer NOL
Local Integer WI,WMAX
Local Decimal WJOUR,WHEURE
Raz WI
Raz WJOUR,WHEURE

NOL = nolign-2
If nolign =1
  NOL=0
Endif

WMAX=[M]NBRLIG-1
If NOL<0 | ([M]NBRDAY(NOL)=0 & [M]NBRHOU(NOL)=0) | find(status,65,68,83) : End : Endif
Raz TOTDAY
Raz WJOUR,WHEURE
Filter [TIP] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & [M]STRDAT(NOL)<=ENDDAT & [M]ENDDAT(NOL)>=STRDAT
For [TIP]TIP1
 If [F:TIP]TIM=[M]TIM(NOL)
 #ADNGO - 2017-01-26 - X3-12021 - START
  #Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
  Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
 #ADNGO - 2017-01-26 - X3-12021 - END
  For WI=0 To [M]NBRLIG-1
    If WI<>NOL & [M]TIM(WI)=[M]TIM(NOL)
    #ADNGO - 2017-01-26 - X3-12021 - START
      #Call LECTURE("TIM",[M]TIM(WI),"") From CONTOBJ
      Call LECTURE("HRTIM",[M]TIM(WI),GCURLEG) From CONTOBJ
    #ADNGO - 2017-01-26 - X3-12021 - END
      If WI<>NOL & [M]TIM(WI)=[M]TIM(NOL) & [M]STRDAT(WI)<=[F:TIP]ENDDAT & [M]ENDDAT(WI)>=[F:TIP]STRDAT
         If [F:TIM]DAYDAC=2
            WJOUR += [M]NBRDAY(WI)
         Else
            WHEURE+= [M]NBRHOU(WI)
         Endif
      Endif
    Endif
  Next
  If ([F:TIM]DAYDAC=2 & ([F:TIP]NBRDAY<0 & [M]NBRDAY(NOL)<0) | ([F:TIP]NBRDAY>=0 & [M]NBRDAY(NOL)>=0))
&  | ([F:TIM]DAYDAC<>2 & ([F:TIP]NBRHOU<0 & [M]NBRHOU(NOL)<0) | ([F:TIP]NBRHOU>=0 & [M]NBRHOU(NOL)>=0))
    If [F:TIM]DAYDAC=2
       WJOUR += [M]NBRDAY(NOL)
    Else
       WHEURE+= [M]NBRHOU(NOL)
    Endif
    If [F:TIM]DAYDAC=2 & ([F:TIP]NBRDAY<1 | WJOUR<1)
     TOTDAY +=min([F:TIP]NBRDAY,1)
     If TOTDAY+min(WJOUR,1)>1
      # Evènement déjà enregistré dans la saisie des temps. Régularisation inutile.
      #ADNGO - 2017-01-11 - X3-12021 - START
      #GMESSAGE = mess(166,709,1)
      GMESSAGE = mess(166,10709,1)
      #ADNGO - 2017-01-11 - X3-12021 - END
      mkstat = 2 : Break
     Endif
    Else
     If ([F:TIM]DAYDAC=2 &  ([F:TIP]NBRDAY<0 & WJOUR<0) | ([F:TIP]NBRDAY>=0 & WJOUR>0))
&      | ([F:TIM]DAYDAC<>2 & ([F:TIP]NBRHOU<0 & WHEURE<0) | ([F:TIP]NBRHOU>=0 & WHEURE>0))
     # Evènement déjà enregistré dans la saisie des temps. Régularisation inutile.
     #ADNGO - 2017-01-11 - X3-12021 - START
      #GMESSAGE = mess(166,709,1)
      GMESSAGE = mess(166,10709,1)
     #ADNGO - 2017-01-11 - X3-12021 - END
      mkstat = 2 : Break
     Endif
    Endif
  Endif
 Endif
Next
Filter [TIP]
If mkstat=2 : End : Endif
End

########################################
Subprog APRES_NBRLIG
Local Date XITDAT
[M]FLGMOD(nolign-1) = 1
If dim([M]CTRDAT)>0 & [M]CTRDAT(nolign-1)=[0/0/0] Then
  [M]CTRDAT(nolign-1)=func TPSSTD.CALC_CTRDATDEF([M]REFNUM,[M]CTRNUM,[M]DATFIN,[M]PYRDAT,[M]ENDDAT(nolign-1),1)
  Call CONTROL_CTRDAT([M]REFNUM,[M]CTRNUM,[M]CTRDAT(nolign-1),[M]ENDDAT(nolign-1),[M]PYRDAT,1,[L]XITDAT) From TPSSTD
  If !mkstat Then
    If dim([M]SCTRDAT)>0 Then
      [M]SCTRDAT(nolign-1)=[L]XITDAT : Affzo [M]SCTRDAT(nolign-1)
    Endif
    If dim([M]FCYT)>0 Then
    #ADNGO - 2017-01-11 - X3-12021 - START
      #[M]FCYT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRFCY","CTR")
      [M]FCYT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRFCY","HRCTR")
    #ADNGO - 2017-01-11 - X3-12021 - END
      Affzo [M]FCYT(nolign-1)
    Endif
    If dim([M]SRVT)>0 Then
    #ADNGO - 2017-01-11 - X3-12021 - START
      [M]SRVT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRSRV","HRCTR")
    #ADNGO - 2017-01-11 - X3-12021 - END
      Affzo [M]SRVT(nolign-1)
    Endif
  Endif
  Affzo [M]CTRDAT(nolign-1),SCTRDAT(nolign-1),FCYT(nolign-1),SRVT(nolign-1)
Endif
End

########################################
Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR
If nolign=1
 VALEUR = [M]REGDEB
Else
 VALEUR = min([M]REGFIN,[M]ENDDAT(nolign-2)+1)
Endif
End

########################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
#ADNGO - 2017-01-11 - X3-12021 - START
#If [F:PEO]PERSTR(2)<>[0/0/0] & VALEUR<[F:PEO]PERSTR(2)
If [F:HRPEOD]PERSTR(2)<>[0/0/0] & VALEUR<[F:HRPEOD]PERSTR(2)
#ADNGO - 2017-01-11 - X3-12021 - END

#ADNGO - 2017-01-11 - X3-12021 - START
 #GMESSAGE = mess(60,709,1) : # Date en dehors de la période de régul
 GMESSAGE = mess(60,10709,1) : # Date en dehors de la période de régul
#ADNGO - 2017-01-11 - X3-12021 - END
 mkstat = 2 : End
Endif
End

########################################
Subprog D_ENDDAT(VALEUR)
Variable Date    VALEUR
Call D_ENDDAT(VALEUR)From TPSSTD
End

####################################
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
Call AS_ENDDAT(VALEUR)From TPSSTD
End

########################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
#ADNGO - 2017-01-11 - X3-12021 - START
#If [F:PEO]PEREND(2)<>[0/0/0] & VALEUR>[F:PEO]PEREND(2)
If [F:HRPEOD]PEREND(2)<>[0/0/0] & VALEUR>[F:HRPEOD]PEREND(2)
#ADNGO - 2017-01-11 - X3-12021 - END

#ADNGO - 2017-01-11 - X3-12021 - START
 #GMESSAGE = mess(60,709,1) : # Date en dehors de la période de régul
 GMESSAGE = mess(60,10709,1) : # Date en dehors de la période de régul
#ADNGO - 2017-01-11 - X3-12021 - END
 mkstat = 2 : End
Endif
Gosub SETNOL
Local Integer I

# Présence de l'employé sur la période
For I=[M]STRDAT(nolign-1)-[M]REGDEB+1 To VALEUR-[M]REGDEB+1
 If [M]PRE(I-1)=0
 #ADNGO - 2017-01-11 - X3-12021 - START
  #GMESSAGE = mess(10,709,1)-format$("D:"+GFMDAT4,[M]REGDEB+I-1) : # Employé non présent au
  GMESSAGE = mess(10,10709,1)-format$("D:"+GFMDAT4,[M]REGDEB+I-1) : # Employé non présent au
 #ADNGO - 2017-01-11 - X3-12021 - END
  mkstat = 2 : Break
 Endif
Next I
If mkstat : End : Endif

#Mutation de site ou de service durant la période saisie
If VALEUR<>[M]STRDAT(NOL) :
#ADNGO - 2017-02-14 - X3-12021 - START
 #Local Char SITDEB (GLONSIT), SITFIN (GLONSIT)
 Local Char SITDEB (GLONFCY), SITFIN (GLONFCY)
#ADNGO - 2017-02-14 - X3-12021 - END
 Local Char SRVDEB (GLONSRV), SRVFIN (GLONSRV)
 If clalev([F:RCR])=0 : Local File RETROCTR [RCR] : Endif
#ADNGO - 2017-01-11 - X3-12021 - START
# Filter [F:CTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]STRDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M]STRDAT(nolign-1)))
# Read[F:CTR]CTR0 Last
# Filter [F:CTR]
  Filter [F:HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]STRDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M]STRDAT(nolign-1)))
  Read[F:HRCTR]CTR0 Last
  Filter [F:HRCTR]
#ADNGO - 2017-01-11 - X3-12021 - END
 If !fstat
#ADNGO - 2017-01-11 - X3-12021 - START
#  SITDEB=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRFCY","CTR")
#  SRVDEB=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRSRV","CTR")
  SITDEB=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRFCY","HRCTR")
  SRVDEB=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRSRV","HRCTR")
#ADNGO - 2017-01-11 - X3-12021 - END
 Endif
#ADNGO - 2017-01-11 - X3-12021 - START
# Filter [F:CTR] Where REFNUM=[M]REFNUM  & CTRNUM=[M]CTRNUM & (CTRDAT<=VALEUR | (FLGRET=2 & RETDATEFF<=VALEUR))
# Read[F:CTR]CTR0 Last
# Filter [F:CTR]
# If !fstat
#  SITFIN=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRFCY","CTR")
#  SRVFIN=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTR]CTRDAT,[M]REGFIN,"ETRSRV","CTR")
 Filter [F:HRCTR] Where REFNUM=[M]REFNUM  & CTRNUM=[M]CTRNUM & (CTRDAT<=VALEUR | (FLGRET=2 & RETDATEFF<=VALEUR))
 Read[F:HRCTR]CTR0 Last
 Filter [F:HRCTR]
 If !fstat
  SITFIN=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRFCY","HRCTR")
  SRVFIN=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]REGFIN,"ETRSRV","HRCTR")
#ADNGO - 2017-01-11 - X3-12021 - END
  Endif
 If SITDEB<>SITFIN | SRVDEB<>SRVFIN
   #Période à cheval sur une mutation
   #ADNGO - 2017-01-11 - X3-12021 - START
   #GMESSAGE = mess(125,709,1)
   GMESSAGE = mess(125,10709,1)
   #ADNGO - 2017-01-11 - X3-12021 - END
   mkstat = 2 : End
 Endif
Endif
End

########################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
Call AM_ENDDAT(VALEUR) From TPSSTD
End

########################################
Subprog D_TIM(VALEUR)
Variable Char    VALEUR()
Call D_TIM(VALEUR)From TPSSTD
End

########################################
Subprog C_TIM(VALEUR)
Variable Char    VALEUR()
Local Char    VALPAR(10)
Local Char    EVT(GLONTPS)(0..3)
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CNE])=0 : Local File CNGEMP   [CNE] : Endif
If clalev([F:CNG])=0 : Local File CNGCPY   [CNG] : Endif

#ADNGO - 2017-01-26 - X3-12021 - START
#Call LECTURE("TIM",VALEUR,"") From CONTOBJ
Call LECTURE("HRTIM",VALEUR,GCURLEG) From CONTOBJ
#ADNGO - 2017-01-26 - X3-12021 - END

Gosub SETNOL

#Interdire la saisie multi date sur les évènements cocher "Saisie plage horaire"
#et que la saisie de ces plages sont dans la transaction
If GNBHOR & [F:TIM]PLGHOR=2 & [M]STRDAT(NOL)<>[M]ENDDAT(NOL) & left$([M]FRMFLD(2),1)<>"-"
#ADNGO - 2017-01-11 - X3-12021 - START
 #GMESSAGE = mess(119,709,1) : #Saisie multi-date interdite pour ce code temps
 GMESSAGE = mess(119,10709,1) : #Saisie multi-date interdite pour ce code temps
#ADNGO - 2017-01-11 - X3-12021 - END
 mkstat = 2 : End
Endif

If [F:TIM]ACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:TIM]ACS
 If fstat or [F:ACC]EXEC<>2
 #ADNGO - 2017-01-11 - X3-12021 - START
  #GMESSAGE = VALEUR-":"-mess(61,709,1) : # Vous n'avez pas accès à ce code
  GMESSAGE = VALEUR-":"-mess(61,10709,1) : # Vous n'avez pas accès à ce code
 #ADNGO - 2017-01-11 - X3-12021 - END
  mkstat = 2 : End
 Endif
Endif

If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
  Local Integer RET
  Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[M]REFNUM,[M]CTRNUM,RET) From DIVPAYE
  If RET>0 Then
    GMESSAGE= VALEUR-":"-mess(320,199,1) : # Nature d'événement incompatible avec ce salarié
    mkstat=2 : End
  Endif
Endif

Gosub CTL_TYPPGN From TPSSTD
If mkstat=2 : End : Endif

If [F:TIM]CATTIM=3 & [F:TIM]FLGBLC=2
 Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
 Filter [CNG] Where CPY=[F:FCY]LEGCPY & TIM=VALEUR & ( (STRDAT<=[M]STRDAT(NOL) & ENDDAT>=[M]ENDDAT(NOL)) | (DEBDAT<=[M]STRDAT(NOL) & FINDAT>=[M]ENDDAT(NOL)) )
 #JASMI - 2014-09-04 - START
 #ADNGO - 2017-01-12 - X3-12021 - START
 #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
 If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
 #ADNGO - 2017-01-12 - X3-12021 - END
  Filter [F:CNE] Where TIM=VALEUR & REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & EMPLEASTR<=[M]STRDAT(NOL) & EMPLEAEND>=[M]ENDDAT(NOL)
  Read [F:CNE]CNE0 Last
  Filter [F:CNE]
  If !fstat
    Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=VALEUR & YEA=[F:CNE]YEA
  Endif
 Endif
 #JASMI - 2014-09-04 - END
 Read [CNG]CNG0 First
 Filter [CNG]
 If !fstat
  Read [CNE]CNE0=[F:CNG]YEA;[M]REFNUM;[M]CTRNUM:VALEUR
  If fstat
  #ADNGO - 2017-01-11 - X3-12021 - START
   #GMESSAGE = mess(165,709,1)-num$([F:CNG]YEA) : # Fiche congé par employé inexistante pour l'année
   GMESSAGE = mess(165,10709,1)-num$([F:CNG]YEA) : # Fiche congé par employé inexistante pour l'année
  #ADNGO - 2017-01-11 - X3-12021 - END
   mkstat = 2 : End
  Endif
 Else
  GMESSAGE = mess(319,199,1)-[F:TIM]COD : # Fiche période de congé inexistante pour l'évènement
  mkstat = 2 : End
 Endif
Endif

If [M]STRDAT(NOL)<>[M]ENDDAT(NOL)
 If VALEUR<>[M]TIM(NOL)
  Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,VALEUR,[M]NBRDAY(NOL),[M]NBRHOU(NOL),[M]FCY,[M]CTRNUM) From SUBPLN
 Endif

 #Ici on ne contrôle pas la disponibilité des congès comme en saisie des temps classique :
 #Si c'est une régul de congés (en +), c'est que les congès ont déjà été pris par le salarié.
 #Et c'est une régul de congés (en -), il est inutile de faire le contrôle (restitution)
Endif

End

####################################
Subprog D_NBRDAY(VALEUR)
Variable Decimal VALEUR
Call D_NBRDAY(VALEUR) From TPSSTD
End

####################################
Subprog AS_NBRDAY(VALEUR)
Variable Decimal VALEUR
If !VALEUR
 Gosub SETNOL
 Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),VALEUR,[M]NBRHOU(NOL),[M]FCY,[M]CTRNUM) From SUBPLN
Endif
End

####################################
Subprog C_NBRDAY(VALEUR)
Variable Decimal VALEUR
Local Decimal HEURE, JOUR
Gosub SETNOL
Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),JOUR,HEURE,[M]FCY,[M]CTRNUM) From SUBPLN
#On recalcule toujours le nb d'heures en fonction du nb de jours...
If JOUR :  [M]NBRHOU(NOL) = ar2(HEURE*VALEUR/JOUR) : Endif
#Nb jours saisi ne doit pas dépasser le nb de jours calendaire !
If abs(VALEUR)>([M]ENDDAT(NOL)-[M]STRDAT(NOL))+1
 #Pas plus de 1 jour par journée calendaire
 #ADNGO - 2017-01-11 - X3-12021 - START
 #GMESSAGE=mess(3,709,1)
 GMESSAGE=mess(3,10709,1)
 #ADNGO - 2017-01-11 - X3-12021 - END
 mkstat=2 : End
Endif
End

####################################
Subprog D_NBRHOU(VALEUR)
Variable Decimal VALEUR
Local Decimal JOUR
#On ne touche pas au nb de jours déjà initialisé...
Gosub SETNOL
Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),JOUR, VALEUR,[M]FCY,[M]CTRNUM) From SUBPLN
End

####################################
Subprog AS_NBRHOU(VALEUR)
Variable Decimal VALEUR
Local Decimal JOUR
Gosub SETNOL
If !VALEUR
 If [M]STRTIM(NOL)<>""
  Gosub SUMHRS From TPSSTD
  VALEUR=SUMHRS
 Else
  #On ne touche pas au nb de jours déjà initialisé...
  Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),JOUR,VALEUR,[M]FCY,[M]CTRNUM) From SUBPLN
 Endif
Endif
End

####################################
Subprog C_NBRHOU(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Local Decimal JOUR, HEURE
Local Decimal SVNBRDAY

If VALEUR
 SVNBRDAY=[M]NBRDAY(NOL)
 Call C_NBRHOU(VALEUR) From TPSSTD
 Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),JOUR, HEURE,[M]FCY,[M]CTRNUM) From SUBPLN
 # Si le NBRDAY est remis à 0 par le C_NBRHOU car HEURE calculé = 0
 # On remet l'ancienne valeur du nbre de jour car dans TPSSTDR on saisie Heure et Jour
 If (HEURE = 0 or VALEUR <> 0 ) and [M]NBRDAY(NOL) = 0 and SVNBRDAY<>[M]NBRDAY(NOL)
  [M]NBRDAY(NOL)=SVNBRDAY
  Affzo [M]NBRDAY(NOL)
 Endif
 # FQ109294 - 06/07/15 - Dans TPSSTD, on autorise la saisie de plus de 7h, donc on doit aussi l'utoriser dans TPSSTDR
 # Par ailleurs, on contrôle HOUDAYLEG dans TPSSTD.C_NBRHOU
# # Impossible de saisir 8h ou-8h si une journée de W pour ce salarié c'est 7h !!!
# If HEURE<abs(VALEUR) & HEURE>0
#  GMESSAGE = mess(240,199,1)-":"-num$(HEURE) : # Maximum autorisé :
#  mkstat = 2 : End
# Endif
Endif
#Si on saisie des heures en négatif, il faut recalculer le nb de jours en négatif
If VALEUR<0 & [M]NBRDAY(NOL)>0
 [M]NBRDAY(NOL)=[M]NBRDAY(NOL)*-1
 Affzo [M]NBRDAY(NOL)
Endif
End

