## Section automatically added (screen TPSSTDR) 01/12/2017 13:15:41 (ADNGO)
######################################################################################
Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
#ADNGO - 2017-01-12 - X3-12021 - START
  If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
  If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
    Filter  [HRCTR2] Where CTRNUM=VALEUR
    Read [HRCTR2] First
    Filter [HRCTR2]
    [M:TPS2]REFNUM = [F:HRCTR2]REFNUM
    Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
    If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:TPS2]LEG = GCURLEG
    Affzo [M:TPS2]LEG
    Endif
#ADNGO - 2017-01-12 - X3-12021 - END
End


######################################################################################

######################################################################################
## Section automatically added (screen TPSSTDR) 01/12/2017 13:28:13 (ADNGO)
######################################################################################
Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
#ADNGO - 2017-02-02 - X3-12021 - START
If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
Filter [HRCTR2] Where REFNUM = VALEUR
Read [HRCTR2] First
If fstat
  Raz GCURLEG
Endif
#ADNGO - 2017-02-02 - X3-12021 - END
End


######################################################################################

######################################################################################
## Section automatically added (screen TPSSTDR) 01/12/2017 14:08:45 (MIPEA)
######################################################################################
Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()

#ADNGO - 2017-01-12 - X3-12021 - START
  If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
  If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
    Filter  [HRCTR2] Where REFNUM=VALEUR
    If rowcount([HRCTR2]) = 1
      Read [HRCTR2] First
      Filter [HRCTR2]
      [M:TPS2]REFNUM = [F:HRCTR2]REFNUM
      Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
      If !fstat
        GCURLEG = [F:FCY2]LEG
        [M:TPS2]LEG = GCURLEG
        Affzo [M:TPS2]LEG
      Endif
    Endif
#ADNGO - 2017-01-12 - X3-12021 - END

End


