######################################################################################
## Etiquette ajoutée par le superviseur (écran TPSSTDR) 01/07/2014 18:35:22 (DBA)
######################################################################################
#92876_US2757
#Ne pas pouvoir saisir de répartition manuelle si aucun axe n'est compatible avec le site
Subprog IB_DSP
Local Integer AXE
Local Integer OK
For AXE=1 To [M]NBRDIE
 If AXE>GOPTCANA : Break : Endif
 Call CPY_AXE (AXE, [M]FCYT(nolign-1), OK) From TPSDIV
 If OK : Break : Endif :# A partir du moment où un axe correspond, on peut afficher la fenêtre de répartition
Next
If !OK
 Raz GBOUT2
 Raz GBOUT3
Endif
End

# FQ92876 - 26/09/14 - Réinitialisation des axes même si que affichés
Subprog AM_DSP(VALEUR)
Variable Char    VALEUR()
Local Integer    AXE,SAU_MKSTAT
Local Char       VALCCE(20)

  If VALEUR="" Then
    [M]DSP(nolign-1)=""
    SAU_MKSTAT=mkstat
    For AXE=1 To 27
      If evalue("dim([M]CCE"+num$(AXE)+")")>0 Then
        VALCCE=""
        Call ="AS_CCE"+num$(AXE) With VALCCE From TPSSTD
        If VALCCE<>"" Then
          Assign "[M]CCE"+num$(AXE)+"(nolign-1)" With VALCCE
        Endif
      Endif
    Next
    mkstat=SAU_MKSTAT
    [M]DSP(nolign-1)=""
  Endif
End


