#<AdxTL>@(#)6.0.0.0 $Revision$
########################################################
## $ERREUR
########################################################

$ERREUR
GERREUR=errn
Case GERREUR
 When 29
  Close Local File : # Pour pouvoir ouvrir le fichier message
  Call ERREUR(mess(127,100,1)+"\"+mess(128,100,1)) From GESECRAN
 When 42
  Call ERREUR(mess(127,100,1)+"\"+mess(146,100,1)) From GESECRAN
 When Default
  Call ERREUR(mess(127,100,1)+"\"+errmes$(GERREUR)+"\|"+errm+"|") From GESECRAN
Endcase
Resume

######################################################

$CHUT
GERREUR=errn
Resume
