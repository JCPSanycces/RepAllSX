####################################################################
# 1 : OS Type of machine (dos/unix) ( Field A 10)
####################################################################

$GET_OS
Gosub DECLARE_VAR From WMC0WMACONTEXTASOL
[L]CURPRO = "OS"
[L]ARULE = "GET" : [L]ACTION = "GET" : Gosub ACTION From ASYRSUB
Return


