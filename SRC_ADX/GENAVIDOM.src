#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du masque GENAVIDOM
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"GENAVIDOM"
 GFONCTION="GENAVIDOM" : Call AUTORIS From EXEFNC
Endif
GACTION = "GENAVIDOM"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","GENAVIDOM","DGENPAB",3,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

##########################################################################
$ACTION
##########################################################################
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "OUVRE_BATCH" : Gosub INIT
Endcase
Return

##########################################################################
$INIT
##########################################################################
Onerrgo CHUT From CONTROLE
If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
If !clalev([F:GCU])  : Local File GRPCUR     [GCU]  : Endif
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif
If !clalev([F:AUS])  : Local File AUTILIS    [AUS]  : Endif
If !clalev([F:BAN])  : Local File BANK       [BAN]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif
Return

##########################################################################
$CONTROLE
##########################################################################
TMP=1 : TIT="O"
Return

##########################################################################
$EXEC
##########################################################################
Local Char    PLAN(GLONCOA)
Local Libelle NIV, FLTRC
Local Decimal TOTLOC(3), TOTBAN(3), MONTANT, MT, MT2
Local Integer OK, I, J, K, STAT, NBLMAX, SIGN, NBBOR, NBPYH, LIGBOR, OKTCA , TESTLEG
Local Char    CRITERE(255), CRITERE2(255), CRITCUR(255), CRITTPY(255), EXPCLE(100), ZONE(20)
Local Char    NUMAVIS(GLONVCR), FCYTETE(GLONFCY), COMPTREG(GLONANM), DEVLOC(GLONCUR), DEVBAN(GLONCUR), SEP(3)
Local Char    TRA_TPY(5), TRA_BAN(5)
Local Date    DATJ

[L]SEP=", "

Onerrgo ERREUR From CONTROLE
Local Mask PAB1 [PAB1]
NBLMAX = dim([M:PAB1]NUM)
Close Local Mask [PAB1]
If !clalev([F:GCU])  : Local File GRPCUR     [GCU]  : Endif
If !clalev([F:TCA])  : Local File TABCOUAFF  [TCA]  : Endif
If !clalev([F:COA])  : Local File GCOA       [COA]  : Endif
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
If !clalev([F:TPY1]) : Local File TABPAYTYP  [TPY1] : Endif
If !clalev([F:FRM])  : Local File PAYFRM     [FRM]  : Endif
If !clalev([F:ANM])  : Local File ACODNUM    [ANM]  : Endif
If !clalev([F:BAN])  : Local File BANK       [BAN]  : Endif
If !clalev([F:ACC])  : Local File ACCES      [ACC]  : Endif
If !clalev([F:PYH])  : Local File PAYMENTH   [PYH]  : Endif
If !clalev([F:PYH2]) : Local File PAYMENTH   [PYH2] : Endif
If !clalev([F:PYH3]) : Local File PAYMENTH   [PYH3] : Endif
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif
If !clalev([F:TCH])  : Local File TABCHANGE  [TCH]  : Endif
If !clalev([F:PYT])  : Local File TMPPAYTOT  [PYT]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

If GNBLEG=1
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG=[M:DIA]LEG
Endif

Local Char    TSYMBOLE(50)(1..max(GNBSOC,nbrecord([F:CPY])))
Local Integer INDLOCK, NBLOCK
NBLOCK = 0
If [M:DIA]ALLCPY<>2
 NBLOCK=1
 TSYMBOLE(NBLOCK) = "GENAVIDOM\"+[M:DIA]CPY
 Lock =TSYMBOLE(NBLOCK) With lockwait=0
 If fstat
  # Opération en cours sur autre poste
  GERR=1 : GMESSAGE=mess(30,100,1)
  FIN=1 : Return
 Endif
Else
 For [CPY]CPY0 Where LEG=GCURLEG & CPYLEGFLG=2
  NBLOCK+=1
  TSYMBOLE(NBLOCK) = "GENAVIDOM\"+[F:CPY]CPY
  Lock =TSYMBOLE(NBLOCK) With lockwait=0
  If fstat
   # Opération en cours sur autre poste
   GERR=1 : GMESSAGE=mess(30,100,1)
   FIN=1 : Break
  Endif
 Next
 If FIN=1 : NBLOCK -=1 : Gosub DEVERROU : Return : Endif
Endif

If !GSERVEUR
 Call TITAWI(BCRIT,CRITERE) From OBJDIV
 Call OUVRE_TRACE(CRITERE) From LECFIC
Endif

CRITERE = "STA<7 & FRMNUM='' & BAN<>''"
If [M:DIA]ALLCPY<>2
 CRITERE -= "& CPY='"+[M:DIA]CPY+"'"
Endif
If [M:DIA]ALLFCY<>2
 CRITERE -= "& FCY='"+[M:DIA]FCY+"'"
Endif
If [M:DIA]ALLBAN<>2
 CRITERE -= "& BAN='"+[M:DIA]BAN+"'"
Endif
If [M:DIA]ALLUSR<>2
 CRITERE -= '& (UPDUSR="'+[M:DIA]USR+'"'
 CRITERE -= '| (UPDUSR="" & CREUSR="'+[M:DIA]USR+'"))'
Endif
If [M:DIA]ALLLOT<>2
 CRITERE -= '& PAYLOT="'+[M:DIA]LOT+'"'
Endif
If [M:DIA]DUDDAT<>[0/0/0]
 CRITERE -= "& DUDDAT<=["+format$(GFMD,[M:DIA]DUDDAT)+"]"
Endif
Gosub CRITCUR
If CRITCUR<>""
 CRITERE -= "&"-CRITCUR
Endif

If [M:DIA]ALLTPY=1
 If [F:TPY1]PAYTYP<>[M:DIA]TPY | [F:TPY1]LEG<>GCURLEG
  Read [TPY1]TPY0 = [M:DIA]TPY;GCURLEG
  If fstat
   Read [TPY1]TPY0 = [M:DIA]TPY;""
  Endif
 Endif
 Gosub TRT_TPY
Else
 Filter [TPY1] Where (LEG=GCURLEG | LEG="") Order By Key CLET=PAYTYP Asc;LEG Desc
 For [TPY1]CLET(1)
  If [F:TPY1]STA7=2 & [F:TPY1]ENAFLG=2
   Call CONTEXE([F:TPY1]ACS) From CPTSUB
   If !mkstat : OK=1 : Else mkstat=0 : OK=0 : GMESSAGE="" : Endif
  Else
   OK=0
  Endif
  If OK
   Gosub TRT_TPY
   If GOK<1 : Break : Endif
  Endif
 Next
 Filter [TPY1]
Endif

If NBPYH
 If [M:DIA]CPY<>""
  Call SETCUR(1,[M:DIA]CPY,DEVLOC) From CPTDIV
 Else
  Call SETCURFLD(DEVLOC) From CPTDIV
 Endif
 Call ECR_TRACE(" ",0) From GESECRAN

 # Total Transaction
 Filter [PYT] Where TRC=GTRACE Order By Key CLE=PAYTYP
 For [PYT]CLE(1)
  MT=0 : MT2=0
  For [PYT]CLE
   If [F:PYT]SNS=1
    If [M:DIA]CPY<>"" : MT+=[F:PYT]AMTLOC : Endif
   Else
    If [M:DIA]CPY<>"" : MT2+=[F:PYT]AMTLOC : Endif
   Endif
  Next
  If MT<>0  : GMESSAGE=mess(1,632,1)-"="-num$(MT)-DEVLOC : Else GMESSAGE="" : Endif
  If MT2<>0 : GMESSAGE=GMESSAGE+string$(MT<>0,SEP)-mess(2,632,2)-"="-num$(MT2)-DEVLOC : Endif
  Call ECR_TRACE(mess(69,116,1)-mess(3,871,1)-[F:PYT]PAYTYP-":"-GMESSAGE,0) From GESECRAN
 Next

 # Total Banque
 Filter [PYT] Where TRC=GTRACE Order By Key CLE=BAN
 For [PYT]CLE(1)
  MT=0 : MT2=0
  For [PYT]CLE
   If [F:PYT]SNS=1 : MT+=[F:PYT]AMTCUR : Else MT2+=[F:PYT]AMTCUR : Endif
  Next
  If MT<>0  : GMESSAGE=mess(1,632,1)-"="-num$(MT)-[F:PYT]CUR : Else GMESSAGE="" : Endif
  If MT2<>0 : GMESSAGE=GMESSAGE+string$(MT<>0,SEP)-mess(2,632,2)-"="-num$(MT2)-[F:PYT]CUR : Endif
  Call ECR_TRACE(mess(69,116,1)-mess(1,653,1)-[F:PYT]BAN-":"-GMESSAGE,0) From GESECRAN
 Next

 # Total général
 Filter [PYT] Where TRC=GTRACE
 MT=0 : MT2=0
 For [PYT]PYT0
  If [F:PYT]SNS=1
   If [M:DIA]CPY<>"" : MT+=[F:PYT]AMTLOC : Endif
  Else
   If [M:DIA]CPY<>"" : MT2+=[F:PYT]AMTLOC : Endif
  Endif
 Next
 If MT<>0  : GMESSAGE=mess(1,632,1)-"="-num$(MT)-DEVLOC : Else GMESSAGE="" : Endif
 If MT2<>0 : GMESSAGE=GMESSAGE+string$(MT<>0,SEP)-mess(2,632,2)-"="-num$(MT2)-DEVLOC : Endif
 Call ECR_TRACE(mess(86,117,1)-":"-GMESSAGE,0) From GESECRAN
 Filter [PYT]
 GMESSAGE=""
 Gosub TR_RAZ_PYT
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
 TRA=1
Endif

Gosub DEVERROU
Return

##########################################################################
$CRITCUR
##########################################################################
CRITCUR=""
If [M:DIA]CUR<>""
 CRITCUR = "CUR='"+[M:DIA]CUR+"'"
Elsif [M:DIA]GRPCUR<>""
 CRITCUR = "find(CUR"
 Call LECTURE("GCU",[M:DIA]GRPCUR,"") From CONTOBJ
 For I = 1 To [F:GCU]NBRCUR
  CRITCUR += ",'"+[F:GCU]CUR+"'"
 Next I
 If CRITCUR = "find(CUR"
  CRITCUR=""
 Else
  CRITCUR += ")"
 Endif
Endif
Return

##########################################################################
$TRT_TPY
##########################################################################
CRITTPY = "PAYTYP='"+[F:TPY1]PAYTYP+"'"
If [F:TPY1]STA6=2    : CRITTPY -= "& STA>=6"
Elsif [F:TPY1]STA5=2 : CRITTPY -= "& STA >=5"
Elsif [F:TPY1]STA3=2 : CRITTPY -= "& STA >=3"
Elsif [F:TPY1]STA2=2 : CRITTPY -= "& STA >=2"
Endif

Filter [PYH2] Where evalue(CRITERE) & evalue(CRITTPY)
&               Order By Key CLE=PAYTYP;BAN;CPY
If [M:DIA]ALLBAN=2
 For [PYH2]CLE(2)  :# Par banque
  # If all cpy then only take PYH where leg CPY = screen LEG
  OK = 1
  If [M:DIA]ALLCPY=2
   TESTLEG = 1
   Call LEC_CPY([F:PYH2]CPY) From CPTLEC
   If [F:CPY]LEG <> GCURLEG : OK = 0 : Endif
  Endif
  If OK
    Call LEC_BAN([F:PYH2]BAN) From CPTLEC
   Call CONTEXE([F:BAN]ACS) From CPTSUB
   If !mkstat
    Gosub TRT_BAN
    If GOK<1 : Break : Endif
   Else mkstat=0 : GOK=1
   Endif
  Endif
 Next
Else
 TESTLEG = 0
 Gosub TRT_BAN
Endif
Filter [PYH2]
Return

##########################################################################
$TRT_BAN
##########################################################################
For [PYH2]CLE(3)
 # If all cpy then only take PYH where leg CPY = screen LEG
 OK = 1
 If [M:DIA]ALLCPY=2 & TESTLEG <>1
  Call LEC_CPY([F:PYH2]CPY) From CPTLEC
  If [F:CPY]LEG <> GCURLEG : OK = 0 : Endif
 Endif

 If OK
  [L]FCYTETE = [F:PYH2]FCY
   Call LEC_BAN([F:PYH2]BAN) From CPTLEC
  DEVBAN = [F:BAN]CUR
  Call SETMAINREF([F:PYH2]CPY,GTYPGEN,GTYPANA) From CPTDIV
  Call LECPLAN([F:PYH2]CPY,GTYPGEN,PLAN) From CPTDIV
  COMPTREG = ""
  GSOCIETE = [F:PYH2]CPY
  Call LECTCA(3,OKTCA) From SUBTCA
  If OKTCA
   COMPTREG = [F:TCA]CODNUM(3)
  Endif
  If COMPTREG="" : COMPTREG = "PY7" : Endif
  Call LECTURE("ANM",COMPTREG,"") From CONTOBJ
  Case [F:ANM]NIVDEF
   When 1,2
    NIV=1
    EXPCLE = "PAYTYP;BAN;CPY"
   When 3
    NIV=2
    EXPCLE = "PAYTYP;BAN;FCY"
  Endcase

  If [M:DIA]CPY<>""
   Call SETCUR(1,[M:DIA]CPY,DEVLOC) From CPTDIV
  Else
   Call SETCURFLD(DEVLOC) From CPTDIV
  Endif

  Gosub CRITERE2
  Gosub TR
  If GOK<1 : Break : Endif
 Endif
Next
Return

##########################################################################
$CRITERE2
##########################################################################
CRITERE2="" : K=1
For I=1 To 3
 J=instr(K,EXPCLE,";")
 If !J : ZONE=right$(EXPCLE,K) : Else ZONE=seg$(EXPCLE,K,J-1) :  K=J+1 : Endif
 If I<>1 : CRITERE2-=" &" : Endif
 CRITERE2 -= ZONE+"=[F:PYH2]"+ZONE
Next I
Return

##########################################################################
$TR
##########################################################################
# Transaction = création d'un avis de domiciliation
GOK=1 : [L]NUMAVIS="" : [L]DATJ=date$
For [PYH] Where evalue(CRITERE2) & evalue(CRITERE) & evalue(CRITTPY) With Nohint
 Readlock [PYH]PYH0 Curr
 If fstat=1
  GOK=-1 : GLOCK="$PAYMENTH"-[F:PYH]NUM : Break
 Elsif fstat
  GOK=0 : Call RSTA("PYH",[F:PYH]NUM) From GLOCK : Break
 Endif

 Lock ="PYH"+[F:PYH]NUM
 If fstat
  GOK=-1 : GLOCK="%"+"PYH"+[F:PYH]NUM : Break
 Endif

 If [L]NUMAVIS<>"" & [L]LIGBOR+1>[L]NBLMAX
  Commit : # Fin de transaction
  Call DELOCK("PYH") From GLOCK
  Unlock [PYH]
  NBPYH+=LIGBOR : NBBOR+=1
  Gosub TRACE
  Gosub TOTAUX
  [L]NUMAVIS=""
 Endif
 If [L]NUMAVIS=""
  Call DEBTRANS From GLOCK
  Trbegin [PYH], [FRM] : # Début de transaction
  Gosub RECH_NUM
  If GOK<1 : Break : Endif
 Endif

 [F:PYH]FRMFLG    = 2
 [F:PYH]FRMNUM    = [L]NUMAVIS
 [F:PYH]FRMLIN    = [L]LIGBOR+1
 [F:PYH]STA       = 7
 [F:PYH]STAFLG(6) = 2
 [F:PYH]PABFLG    = 2
 If [F:PYH]FRMTYP<1 : [F:PYH]FRMTYP = 1  : Endif
 Raz [F:PYH]PABREN, [F:PYH]PABAMTPRT
 [F:PYH]FRMFCY    = [F:FRM]FRMFCY
 If dim([F:FRM]CREDAT)>0  : [F:PYH]FRMDAT=[F:FRM]CREDAT
 Else                     : [F:PYH]FRMDAT=[L]DATJ
 Endif
 If dim([F:FRM]CREUSR)>0  : [F:PYH]FRMUSR=[F:FRM]CREUSR
 Else                     : [F:PYH]FRMUSR=GUSER
 Endif
 Rewrite [PYH]
 If fstat
  GOK=0 : Call FSTA("PYH") From GLOCK : Break
 Endif
 [L]LIGBOR += 1

 If [F:PYH]SNS=1 : SIGN=1   : # Dépense
 Else            : SIGN=-1  : # Recette
 Endif
 # Montant en devise DEVLOC (dev. réf. principal ou GCURSHR)
 If [F:PYH]CUR=DEVLOC
  MONTANT=[F:PYH]AMTCUR
 Elsif DEVLOC=DEVBAN & [F:PYH]AMTBAN<>0
  MONTANT=[F:PYH]AMTBAN
 Else
  Call CONVERT([F:PYH]CUR,DEVLOC,DEVLOC,[F:TPY]RATTYP,[F:PYH]ACCDAT
&             ,[F:PYH]AMTCUR,MONTANT,STAT) From TRTDEV
  If STAT : MONTANT=0 : Endif
 Endif
 TOTLOC(0)+=SIGN*MONTANT : TOTLOC([F:PYH]SNS)+=MONTANT : MT=MONTANT
 # Montant en devise banque
 If [F:PYH]CUR=DEVBAN
  MONTANT=[F:PYH]AMTCUR
 Elsif [F:PYH]AMTBAN<>0
  MONTANT=[F:PYH]AMTBAN
 Elsif DEVBAN<>DEVLOC
  Call CONVERT([F:PYH]CUR,DEVBAN,DEVLOC,[F:TPY]RATTYP,[F:PYH]ACCDAT
&             ,[F:PYH]AMTCUR,MONTANT,STAT) From TRTDEV
  If STAT : MONTANT=0 : Endif
 Endif
 TOTBAN(0)+=SIGN*MONTANT : TOTBAN([F:PYH]SNS)+=MONTANT
Next
If GOK=0    : Goto AB_TR
Elsif GOK<0 : Goto ROLL_TR
Elsif !LIGBOR | [L]NUMAVIS="" : Goto AB_TR
Endif
Commit : # Fin de transaction
Call DELOCK("PYH") From GLOCK
Unlock [PYH]
NBPYH+=LIGBOR : NBBOR+=1
Gosub TRACE
Gosub TOTAUX
Return

##########################################################################
$TRACE
##########################################################################
If [L]NUMAVIS="" : Return : Endif
If FLTRC
 Call ECR_TRACE(" ",0) From GESECRAN
 FLTRC=0
Endif
For [PYH3]PYH1 Where FRMFLG=2 & FRMNUM=[L]NUMAVIS
 If !FLTRC
  GMESSAGE = [F:PYH3]BAN+SEP+[F:PYH3]PAYTYP
  If NIV=1 : GMESSAGE += SEP+[F:PYH3]CPY : Else GMESSAGE += SEP+[F:PYH3]FCY : Endif
  GMESSAGE += SEP+num$([L]TOTLOC(0))-DEVLOC
  # Avis de domiciliation NUM : BAN, PAYTYP, CPY/FCY, TOTLOC DEVLOC
  Call ECR_TRACE(mess(123,117,1)-[L]NUMAVIS-":"-GMESSAGE,0) From GESECRAN
  FLTRC=1
 Endif
 # Règlement NUM : nom du tiers/libellé du compte, AMTCUR CUR
 If [F:PYH3]BPR<>""
   Call LEC_BPR([F:PYH3]BPR) From CPTLEC
  GMESSAGE=[F:BPR]BPRNAM
 Elsif [F:PYH3]ACC<>""
  Call LEC_GAC([F:PYH3]ACC,PLAN) From CPTLEC
  Call LECTEXTRA(GMESSAGE,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 Endif
 GMESSAGE += SEP+num$([F:PYH3]AMTCUR)-[F:PYH3]CUR
 Call ECR_TRACE(mess(27,117,1)-[F:PYH3]NUM-":"-GMESSAGE,0) From GESECRAN
Next : # [PYH3]
GMESSAGE=""
Return

##########################################################################
$TOTAUX
##########################################################################
If [L]NUMAVIS="" : Return : Endif
GOK=1

Trbegin [PYT]
 For I=1 To 2
  If TOTBAN(I)<>0 | TOTLOC(I)<>0
   Read [PYT]PYT0 = GTRACE;TRA_TPY;"";DEVBAN;TRA_BAN;[0/0/0];I
   If fstat>2 : Raz [F:PYT] : Endif
   [F:PYT]AMTCUR += TOTBAN(I)
   [F:PYT]AMTLOC += TOTLOC(I)
   If [F:PYT]TRC=""
    [F:PYT]TRC    = GTRACE
    [F:PYT]CUR    = DEVBAN
    [F:PYT]PAYTYP = TRA_TPY
    [F:PYT]BAN    = TRA_BAN
    [F:PYT]SNS    = I
    Write [PYT]
   Else
    Rewrite [PYT]
   Endif
   If fstat
    GOK=2 : Call FSTA("PYT") From GLOCK
   Endif
  Endif
 Next I
Commit
Return

##########################################################################
$TR_RAZ_PYT
##########################################################################
GOK=1
Trbegin [PYT]
 Delete [PYT] Where TRC=GTRACE
 If fstat=1 | fstat>5
  GOK=2 : Call RSTA("PYT",GTRACE) From GLOCK
 Endif
Commit
Return

##########################################################################
$RECH_NUM
##########################################################################
[L]NUMAVIS="" : [L]LIGBOR = 0 : Raz [L]TOTLOC, [L]TOTBAN
Call NUMERO(COMPTREG,[L]FCYTETE,datesyst,[F:PYH]PAYTYP,[L]NUMAVIS,[L]STAT) From SUBANM
If STAT
 # Problème lors de la récupération du compteur
 Gosub MESSAGE From SUBANM
 GMESSAGE = mess(60,199,1)-"("+COMPTREG+") : "+MESSA
 GERR = 1 : GOK = 0
Endif
If GOK>0
 Raz [F:FRM]
 [F:FRM] = [F:PYH]
 If dim([F:FRM]UPDDAT)>0 : Raz [F:FRM]UPDDAT : Endif
 If dim([F:FRM]UPDUSR)>0 : Raz [F:FRM]UPDUSR : Endif
 If dim([F:FRM]CREDAT)>0 : [F:FRM]CREDAT=[L]DATJ : Endif
 If dim([F:FRM]CREUSR)>0 : [F:FRM]CREUSR=GUSER   : Endif
 [F:FRM]FRMFLG=2 : [F:FRM]FRMNUM=[L]NUMAVIS
 [F:FRM]FRMFCY=[L]FCYTETE : [F:FRM]STA=7
 Write [FRM]
 If fstat
  GOK=0 : Call FSTA("FRM") From GLOCK : Return
 Endif
 TRA_TPY=[F:PYH]PAYTYP
 TRA_BAN=[F:PYH]BAN
Endif
Return

$ROLL_TR
Rollback
Call DELOCK("PYH") From GLOCK
Unlock [PYH]
Call ROLL From GLOCK
If GROLL : Return : Else Goto TR : Endif

$AB_TR
Rollback
Call DELOCK("PYH") From GLOCK
Unlock [PYH]
Return


##########################################################################
$DEVERROU
##########################################################################
If dim(TSYMBOLE)>0
 For INDLOCK=1 To NBLOCK
  Unlock =TSYMBOLE(INDLOCK)
 Next
Endif
Return

##########################################################################
$TERMINE
##########################################################################
If GSERVEUR : Return : Endif
If !NBPYH : # Aucun règlement traité
 GERR=2 : GMESSAGE=mess(2,117,1)
Endif
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return


##########################################################################
$SEL_TABLE
##########################################################################
Case COUZON
 When "LOT" : # Lot de saisie
  OBJET="PYL"
  If [M]ALLCPY<>2
   CRITERE-="& CPY='"+[M]CPY+"'"
  Else
   CRITERE-="& [F:CPY]LEG='"+GCURLEG+"'"
  Endif
  If [M]ALLTPY<>2
   CRITERE-="& PAYTYP='"+[M]TPY+"'"
  Endif
  If CRITERE<>"" : CRITERE=right$(CRITERE,4) : Endif
 When "BAN" : Gosub SELBAN From CPTSEL
Endcase
Return


##########################################################################
## Mask GENAVIDOM ##
##########################################################################

Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From CPTTRT
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
 If dim([M]LEG)>0 : Actzo LEG : Endif
 GSOCIETE=""
 GCURFCY=""
Else
 Actzo CPY,ALLFCY
 If dim([M]LEG)>0 : Effzo LEG : Diszo LEG : Endif
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
Call AS_CPY(VALEUR) From CPTTRT
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR) From CPTTRT
End

Subprog AM_CPY(VALEUR)
Variable Char     VALEUR
Call AM_CPY (VALEUR) From CPTTRT
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG (VALEUR) From CPTTRT
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
Call AS_FCY(VALEUR) From CPTTRT
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog C_ALLTPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TPY : Grizo TPY
Else
 Actzo TPY
Endif
End

Subprog AS_TPY(VALEUR)
Variable Char     VALEUR
If [M:DIA]ALLTPY=2 : mkstat=1 : Endif
End

Subprog C_TPY(VALEUR)
Variable Char     VALEUR
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
Call LEC_TPY_LEG(GCURLEG,VALEUR) From CPTLEC
If [F:TPY]STA7<>2
 # Type de règlement non paramétré pour cette fonction
 GMESSAGE=mess(29,117,1) : mkstat=2
Else
 Call CONTEXE([F:TPY]ACS) From CPTSUB
Endif
End

Subprog C_ALLBAN(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo BAN : Grizo BAN
Else
 Actzo BAN
Endif
End

Subprog AS_BAN(VALEUR)
Variable Char     VALEUR
If [M:DIA]ALLBAN=2 : mkstat=1 : Endif
End

Subprog C_ALLUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo USR : Grizo USR
Else
 Actzo USR
Endif
End


Subprog AS_USR(VALEUR)
Variable Char     VALEUR
If [M:DIA]ALLUSR=2 : VALEUR="" : mkstat=2 : End
Elsif VALEUR="" : VALEUR=GUSER
Endif
End

Subprog C_ALLLOT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo LOT : Grizo LOT
Else
 Actzo LOT
Endif
End

Subprog AS_LOT(VALEUR)
Variable Char    VALEUR()
If [M]ALLLOT=2 : mkstat=1 : Endif
End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
If !clalev([F:PYL]) : Local File PAYLOT [PYL] : Endif
Call LECTURE("PYL",VALEUR,"") From CONTOBJ
If fstat : End
Elsif [M]ALLCPY<>2 & [F:PYL]CPY<>[M]CPY
 # Lot de saisie de société
 GMESSAGE=mess(110,121,1)-[F:PYL]CPY
 mkstat=2 : End
Elsif [M]ALLTPY<>2 & [F:PYL]PAYTYP<>[M]TPY
 # Lot de saisie de transaction
 GMESSAGE=mess(111,121,1)-[F:PYL]PAYTYP
 mkstat=2 : End
Endif
End

Subprog C_ALLCUR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CUR,GRPCUR : Grizo CUR,GRPCUR
Else
 Actzo CUR
 If [M]CUR<>"" : Effzo GRPCUR : Grizo GRPCUR : Else : Actzo GRPCUR : Endif
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char VALEUR
If [M]ALLCUR=2
 mkstat=1 : End
Endif
End

Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : Effzo GRPCUR :  Grizo GRPCUR : Else : Actzo GRPCUR : Endif
End

Subprog AS_GRPCUR(VALEUR)
Variable Char    VALEUR()
If [M]ALLCUR=2 | [M]CUR<>""
 mkstat=1 : End
Endif
End

Subprog AV_INI(VALEUR)
Variable Char VALEUR()
If [M]ALLCPY=2
 Effzo CPY, FCY : Grizo CPY, FCY
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
Else
 Actzo CPY, ALLFCY
 If [M]ALLCPY=2
  Effzo FCY : Grizo FCY
 Else
  Actzo FCY
 Endif
Endif
If [M]ALLLOT=2
 Effzo LOT : Grizo LOT
Else
 Actzo LOT
Endif
If [M]ALLBAN=2
 Effzo BAN : Grizo BAN
Else
 Actzo BAN
Endif
If [M]ALLUSR=2
 Effzo USR : Grizo USR
Else
 Actzo USR
Endif
If [M]ALLCUR=2
 Effzo CUR, GRPCUR : Grizo CUR, GRPCUR
Else
 Actzo CUR
 If [M]CUR<>"" : Effzo GRPCUR : Grizo GRPCUR : Else : Actzo GRPCUR : Endif
Endif
If GBIDC1<>""
 [M]ALLTPY = 1 : [M]TPY = GBIDC1
 Affzo [M]ALLTPY, TPY
 If dim(ZTPY)>0 : Affzo ZTPY : Endif
 Grizo ALLTPY, TPY
Else
 Actzo ALLTPY
 If [M]ALLTPY=2
  Effzo TPY : Grizo TPY
 Else
  Actzo TPY
 Endif
Endif
End

