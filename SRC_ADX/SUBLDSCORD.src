#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'une correspondant. 
#
# l'affectation se fait à partir des tables 
##########################################################################################################
$COR_SET_HEA_INFO
  Case IMPZON
    When "CNTNUM"
      #Code interlocuteur
      [M:COR0]CNTNUM = [M:LDS0]PSTNUM
      [M:COR0]UPDCNTNUM = 0
    When "CORTYPMEN"
      #Type (ici 2 = lead)
      [M:COR0]CORTYPMEN = 2
    When "HOMEML"
      #E-mail personnel
      [M:COR3]HOMEML = [M:LDS3]CNTEMA
    When "HOMZIP"
      [M:COR3]HOMZIP = [M:LDS3]ZIP
    When "HOMSAT"
      #Etat personnel
      [M:COR3]HOMSAT = [M:LDS3]SAT
    When "LNA"
      #Nom
      [M:COR0]LNA = [M:LDS0]CNTLNA
    When "HOMCRY"
      #Pays (personnel)
      [M:COR3]HOMCRY = [M:LDS3]CRY
    When "HOMCRYNAM"
      #Libellé Pays (personnel)
      [M:COR3]HOMCRYNAM = [M:LDS3]CRYNAM
    When "FNA"
      #Prénom
      [M:COR0]FNA = [M:LDS0]CNTFNA
    When "HOMADD"
      #Adresse rue (personnel)
      Case indice
        When 0
          [M:COR3]HOMADD(0) = [M:LDS3]ADD1
        When 1
          [M:COR3]HOMADD(1) = [M:LDS3]ADD2
        When 2
          [M:COR3]HOMADD(2) = [M:LDS3]ADD3
      Endcase
    When "HOMFAX"
      #Fax (personnel)
      # FGR 29/07/2010 : X3SUIVI66067
      If func SUBAINCRM.CTLTEL([M:LDS3]CNTFAX, [M:LDS3]CRY) = 1 Then
        [M:COR3]HOMFAX = ""
      Else
        [M:COR3]HOMFAX = [M:LDS3]CNTFAX
      Endif
    When "HOMTEL"
      #Téléphone (personnel)
      # FGR 29/07/2010 : X3SUIVI66067
      If func SUBAINCRM.CTLTEL([M:LDS3]CNTETS, [M:LDS3]CRY) = 1 Then
        [M:COR3]HOMTEL = ""
      Else
        [M:COR3]HOMTEL = [M:LDS3]CNTETS
      Endif
    When "HOMMOB"
      #telephone portable (personnel)
      [M:COR3]HOMMOB = [M:LDS3]CNTMOB
    When "TTL"
      #Civilité
      [M:COR0]TTL = [M:LDS0]CNTTTL
    When "HOMCTY"
      #Ville (personnel)
      [M:COR3]HOMCTY = [M:LDS3]CTY
    When "BPRLIB"
      #libelle tiers
      [M:COR2]BPRLIB = [M:LDS2]CPYNAM
    When "CPYBPANUM"
      If WI > 0 Then
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        [M:COR2]CPYBPADES = [M:BPAL]CODADR(WI-1)
      Endif
    When "CPYBPADES"
      If WI > 0 Then
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        [M:COR2]CPYBPADES = [M:BPAL]BPADES(WI-1)
      Endif
    When "CPYADD"
      If WI > 0 Then
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        Case indice
          When 0
            [M:COR2]CPYADD(0) = [M:BPAL]ADDLIG1(WI-1)
          When 1
            [M:COR2]CPYADD(1) = [M:BPAL]ADDLIG2(WI-1)
          When 2
            [M:COR2]CPYADD(2) = [M:BPAL]ADDLIG3(WI-1)
        Endcase
      Endif
    When "CPYZIP"
      If WI > 0 Then
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        [M:COR2]CPYZIP = [M:BPAL]POSCOD(WI-1)
      Endif
    When "CPYCTY"
      If WI > 0 Then
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        [M:COR2]CPYCTY = [M:BPAL]CTY(WI-1)
      Endif
    When "CPYSAT"
      If WI > 0 Then
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        [M:COR2]CPYSAT = [M:BPAL]SAT(WI-1)
      Endif
    When "CPYCRY"
      If WI > 0 Then
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        [M:COR2]CPYCRY = [M:BPAL]BPACRY(WI-1)
      Endif
    When "CPYCRYNAM"
      If WI > 0 Then
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        [M:COR2]CPYCRYNAM = [M:BPAL]CRYNAM(WI-1)
      Endif
    When "CPYEML"
      If WI > 0 Then
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        [M:COR2]CPYEML = [M:BPAL]WEB1(WI-1)  # FGR 20/07/2010 : X3SUIVI66067 : plus WEB
      Endif
    When "CPYTEL"
      If WI > 0 Then
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        [M:COR2]CPYTEL = [M:BPAL]TEL1(WI-1)  # FGR 20/07/2010 : X3SUIVI66067 : plus TEL
      Endif
    When "CPYFAX"
      If WI > 0 Then
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        [M:COR2]CPYFAX = [M:BPAL]TEL2(WI-1)  # FGR 20/07/2010 : X3SUIVI66067 : plus FAX
      Endif
    When "CPYMOB"
      If WI > 0 Then
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        [M:COR2]CPYMOB = [M:BPAL]TEL5(WI-1)  # FGR 20/07/2010 : X3SUIVI66067 : plus MOB
      Endif
    When "PSTREP"
      If GREP = "C" Then
        If [M:LDS0]PSTREP <> "" Then
          [M:COR4]NBLIGNCOP = 1
        Endif
      Endif
  Endcase
Return

#############################################################################
#DETAIL
$COR_SET_DET_INFO
  Case IMPZON
    When "COPREP"
      If GREP = "C" Then
        If indice =0
          If [M:LDS0]PSTREP <> "" Then
            IMPMOD=1
            [M:COR4]COPREP(indice) = [M:LDS0]PSTREP    
          Endif
        Endif
      Endif
  Endcase
Return

