#<AdxTL>@(#)3.0.0.0 $Revision$
############################################################################
# UUMGTRTSAL08   Sales invoice migration script               Sales module #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  #Call ORATRA From ORATRA
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTSAL08") From LECFIC
  Endif

  #Call RAZ_UUMGTRTSAL08(DOSSIER)
  Call MAJ_UUMGTRTSAL08(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ORATRA From ORATRA
  #Call ARRET From TIMING
Endif
End


###################################################################################
Subprog MAJ_UUMGTRTSAL08(DOSSIER)
Value Char DOSSIER

# Issue 106947 - 20150811 by LD : Migration of historic folder
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
# Issue 106947 - 20150811 by LD

Local Integer ERR
##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N = no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Récupération du n° de version
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL08",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

Local Char WNAMSIHM,WNAMSIDM,WNAMSIVM
Call MIGTABNAME (DOSSIER,"SINVOICE",WNAMSIHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SINVOICEV",WNAMSIVM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SINVOICED",WNAMSIDM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL08",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

If filinfo(filpath("FIL",WNAMSIHM,"fde",DOSSIER),0)<=0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSIDM,"fde",DOSSIER),0)<=0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSIVM,"fde",DOSSIER),0)<=0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL08",2,ERR) From TRTMIG : #2=En cours
Gosub MIG_OUVRE From TRTMIG #Gbn-108768

###################

Local Char WTAB_SIH (30) (adxwrb)
Local Char WTAB_SIV (30) (adxwrb)
Local Char WTAB_SID (90) (adxwrb)
Local Char WTAB_SVF (90) (adxwrb)
Local Char WTAB_CAL (120) (adxwrb)
Local Shortint WCPT_SIH,WCPT_SIV,WCPT_SID,WCPT_SVF,WCPT_CAL

Call ECR_TIME("UUMGTRTSAL08 Sales Invoice Process : Update SINVOICE-V-D") From DOSSUB
Call ECR_TRACE("UUMGTRTSAL08 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Call MIGTABINIT (DOSSIER,"SINVOICE",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"SINVOICEV",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"SINVOICED",ERR) From TRTMIG
# Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABINIT (DOSSIER,"CPTANALIN",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"SVCRFOOT",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"SVCRVAT",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:SIH])  = 0 : Local File =DOSSIER+".SINVOICE"     [SIH]  : Endif   # Fichier X3 "Vide"
If clalev([F:SIV])  = 0 : Local File =DOSSIER+".SINVOICEV"    [SIV]  : Endif   # Fichier X3 "Vide"
If clalev([F:SID])  = 0 : Local File =DOSSIER+".SINVOICED"    [SID]  : Endif   # Fichier X3 "Vide"

If clalev([F:SIHM]) = 0 : Local File =DOSSIER+"."+WNAMSIHM    [SIHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SIVM]) = 0 : Local File =DOSSIER+"."+WNAMSIVM    [SIVM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SIDM]) = 0 : Local File =DOSSIER+"."+WNAMSIDM    [SIDM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

#101380 SST Line Level Override .sn
Local Char WPARAM(GLONADP)
Local Integer I
#101380 SST Line Level Override .en

Gosub OUVRE_SAL From UUMGTRTSAL00
If GOK<>1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL08",7,ERR) From TRTMIG : #7=Erreur
  Goto FIN
Endif

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTSAL08",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

# Dde 81811 : Optimisation
#If NBCOMMIT=0
#  #----- Suppression des incohérences entre tables avant migration -----#
#  Gosub TRT_SQL
#  If GOK<1 : Goto FIN : Endif
#Endif
# Dde 81811 : Optimisation

#-----  Lien des tables entête & lignes -----#
#----- on ne met pas le numero de ligne dans le tri car inutile
Link [SIDM] With [SIHM]SIH0~=[F:SIDM]NUM , [SIVM]SIV0~=[F:SIDM]NUM, [ITM]ITM0=[F:SIDM]ITMREF
&    As [LNK]
&    Order By Key CLE = [F:SIVM]SALFCY;[F:SIVM]NUM

# PE pour ajout clause where
FLUX="UUMGTRTSAL08" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_SAL08
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:SIVM]SALFCY=TABMIGKEY(1) & [F:SIVM]NUM>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:SIVM]SALFCY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [SIH],[SIV],[SID]
GOK = 1

For [LNK]CLE(2) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  #rupture par site,facture
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTSAL08" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  #Raz [F:SIH]
  Gosub RAZ_SIH
  #Raz [F:SIV]
  Gosub RAZ_SIV
  [F:SIH] = [F:SIHM]
  [F:SIV] = [F:SIVM]

  If WSOCIETE<>[F:SIHM]CPY | WSITE<>[F:SIVM]SALFCY
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:SIV]SALFCY) From TRTX3CPT
      WSOCIETE=[F:SIHM]CPY
      WSITE=[F:SIVM]SALFCY

      #108649.so
      #If GACTKUS
      #    Call PARAM([F:SIVM]SALFCY,"USATAX",WPARAM) From ADOVAL
      #    GLOCUSATAX=val(WPARAM)
      #    If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif
      #Else
      #    Raz GLOCUSATAX
      #Endif
      #108649.eo
  Endif

  # Source folder version before V6.0
  If VERSION<GMIGX3VER60
    Gosub MAJ60_SIVSIH
    If GOK<1 : Break : Endif
  Endif

  #101380 SST Line Level Override .sn
  # Source folder version before V8 [AKIRA]
  If VERSION>=GMIGX3VER70 & VERSION<GMIGX3VER80
    Gosub MAJ80_SIVSIH
    If GOK<1 : Break : Endif
  Endif
  #101380 SST Line Level Override .en

  # Issue 106947 - 20150811 by LD : Migration of historic folder
#  If NEWMOTEUR
#      Gosub SIH_STK : # pour stocker ref
#      WriteB [F:SIH]
#  Else
#      Write [F:SIH]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File SINVOICE, Error ="-num$(fstat),1) From GESECRAN
#      Gosub SIH_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File SINVOICE(CPY/SALFCY/NUM)"-[F:SIH]CPY-[F:SIV]SALFCY-[F:SIH]NUM+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
  Gosub SIH_STK : # pour stocker ref
  WriteB [F:SIH]
  If fstat
    Call ECR_TRACE("File SINVOICE, Error ="-num$(fstat),1) From GESECRAN
    Gosub SIH_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  # Issue 106947 - 20150811 by LD
  ############################
  #-- Boucle sur les lignes
  ############################
  For [LNK]CLE
    #rupture par ligne de facture
    #Raz [F:SID]
    Gosub RAZ_SID
    [F:SID] = [F:SIDM]

    # Source folder version before V6.0
    If VERSION<GMIGX3VER60
      Gosub MAJ60_SID
      If GOK<1 : Break : Endif
    Endif

    #101380 SST Line Level Override .sn
    # Source folder version before V8 [AKIRA]
    If VERSION>=GMIGX3VER70 & VERSION<GMIGX3VER80
      Gosub MAJ80_SID
      If GOK<1 : Break : Endif
    Endif
    #101380 SST Line Level Override .en

    # 71065 : PJT
    # Source folder version before V11 (before CHALLENGER)
    If VERSION<GMIGX3VER110
        Gosub MAJ110_SIDSIV
        If GOK<1 : Break : Endif
    Endif
    # 71065 : PJT

    # Issue 106947 - 20150811 by LD : Migration of historic folder
#    If NEWMOTEUR
#        Gosub SID_STK : # pour stocker ref
#        WriteB [SID]
#    Else
#        Write [SID]
#    Endif
#    If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File SINVOICED, Error ="-num$(fstat),1) From GESECRAN
#          Gosub SID_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File SINVOICED(CPY/SALFCY/NUM)"-[F:SIH]CPY-[F:SIV]SALFCY-[F:SID]NUM-num$([F:SID]SIDLIN)+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
    Gosub SID_STK : # pour stocker ref
    WriteB [SID]
    If fstat
        Call ECR_TRACE("File SINVOICED, Error ="-num$(fstat),1) From GESECRAN
        Gosub SID_ERRTRA : # pour afficher les ref
        GOK=0 : Break
    Endif
    # Issue 106947 - 20150811 by LD
  Next

  If GOK<1 : Break : Endif

   # --- alimentation des champs et écriture enreg
  # Issue 106947 - 20150811 by LD : Migration of historic folder
#  If NEWMOTEUR
#      Gosub SIV_STK : # pour stocker ref
#      WriteB [F:SIV]
#  Else
#      Write [F:SIV]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File SINVOICEV, Error ="-num$(fstat),1) From GESECRAN
#      Gosub SIV_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File SINVOICEV(CPY/SALFCY/NUM)"-[F:SIH]CPY-[F:SIV]SALFCY-[F:SIV]NUM+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
  Gosub SIV_STK : # pour stocker ref
  WriteB [F:SIV]
  If fstat
    Call ECR_TRACE("File SINVOICEV, Error ="-num$(fstat),1) From GESECRAN
    Gosub SIV_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  # Issue 106947 - 20150811 by LD
  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:SIVM]SALFCY
    TABMIGKEY(2) = [F:SIVM]NUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL08",7,ERR) From TRTMIG : #7=Erreur
Else
  #If NEWMOTEUR & adxwrb>1  :  # Issue 106947 - 20150811 by LD : Migration of historic folder
    Flush [F:SIH]
    If fstat
        Call ECR_TRACE("File SINVOICE, Error ="-num$(fstat),1) From GESECRAN
        Gosub SIH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:SID]
    If fstat
        Call ECR_TRACE("File SINVOICED, Error ="-num$(fstat),1) From GESECRAN
        Gosub SID_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:SIV]
    If fstat
        Call ECR_TRACE("File SINVOICEV, Error ="-num$(fstat),1) From GESECRAN
        Gosub SIV_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:SVF]
    If fstat
        Call ECR_TRACE("File SVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
        Gosub SVF_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  #Endif                    :  # Issue 106947 - 20150811 by LD : Migration of historic folder
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
      TABMIGKEY(3)=num$(STOP)
  Else
      Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTSAL08",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTSAL08",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_SAL08
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

$FIN
Close Local File [SIV], [SID], [SIH]
Close Local File [SIVM], [SIDM], [SIHM]

Call ECR_TIME("UUMGTRTSAL08 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB

#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"SINVOICE",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"SINVOICEV",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"SINVOICED",ERR) From TRTMIG
# Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABEND (DOSSIER,"CPTANALIN",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"SVCRFOOT",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"SVCRVAT",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTSAL08") From TRTMIG
End

##########################################################################
Subprog RAZ_UUMGTRTSAL08(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : # N= no module
  End
Endif

#Gbn-101445
##1.1 - Récupération du n° de version
#####################################
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL08",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMSIHM,WNAMSIDM,WNAMSIVM
Call MIGTABNAME (DOSSIER,"SINVOICE",WNAMSIHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SINVOICEV",WNAMSIVM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SINVOICED",WNAMSIDM,ERR) From TRTMIG
If ERR : End : Endif

If filinfo(filpath("FIL",WNAMSIHM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSIDM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSIVM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table

##2 - On vide les fichiers selon le cas
#######################################

Local File =DOSSIER+".SINVOICE"  [SIH]
Trbegin [SIH]
Delete [SIH] Where ORIMOD<>3
Commit

Call MIGTABRAZ (DOSSIER,"SINVOICED",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"SINVOICEV",ERR) From TRTMIG

#Gbn-101445
If val(VERSION)<GMIGX3VER60
  Local File =DOSSIER+".CPTANALIN"  [CAL]
  Trbegin [CAL]
  Delete [CAL] Where ABRFIC="SVF" & VCRTYP=4
  Commit
  Trbegin [CAL]
  Delete [CAL] Where ABRFIC="SID"
  Commit

  Local File =DOSSIER+".SVCRVAT"    [SVV]
  Trbegin [SVV]
  Delete [SVV] Where VCRTYP=4
  Commit

  Local File =DOSSIER+".SVCRFOOT"   [SVF]
  Trbegin [SVF]
  Delete [SVF] Where VCRTYP=4
  Commit
Endif

Call MIGRAZKEY (DOSSIER,"UUMGTRTSAL08",ERR) From TRTMIG

End
################################################
$SIH_STK
Call STK (WTAB_SIH,WCPT_SIH,[F:SIH]NUM) From TRTMIG
Return
$SIV_STK
Call STK (WTAB_SIV,WCPT_SIV,[F:SIV]NUM) From TRTMIG
Return
$SID_STK
Call STK (WTAB_SID,WCPT_SID,[F:SID]NUM-'/'-num$([F:SID]SIDLIN)) From TRTMIG
Return
$SVF_STK
Call STK (WTAB_SVF,WCPT_SVF,[F:SVF]VCRNUM-'/'-num$([F:SVF]VCRTYP)-'/'-num$([F:SVF]DTA)) From TRTMIG
Return
$CAL_STK
Call STK (WTAB_CAL,WCPT_CAL,[F:CAL]ABRFIC-'/'-num$([F:CAL]VCRTYP)-'/'-[F:CAL]VCRNUM-'/'-num$([F:CAL]VCRLIN)-'/'-num$([F:CAL]VCRSEQ)-'/'-[F:CAL]CPLCLE-'/'-num$([F:CAL]ANALIG)) From TRTMIG
Return
##############################################################################################

#################################################
$SIH_ERRTRA
Call ERRTRA (WTAB_SIH,WCPT_SIH,"File SINVOICE(NUM)=") From TRTMIG
Return
$SIV_ERRTRA
Call ERRTRA (WTAB_SIV,WCPT_SIV,"File SINVOICEV(NUM)=") From TRTMIG
Return
$SID_ERRTRA
Call ERRTRA (WTAB_SID,WCPT_SID,"File SINVOICED(NUM/SIDLIN)=") From TRTMIG
Return
$SVF_ERRTRA
Call ERRTRA (WTAB_SVF,WCPT_SVF,"File SVCRFOOT(VCRNUM/VCRTYP/DTA)=") From TRTMIG
Return
$CAL_ERRTRA
Call ERRTRA (WTAB_CAL,WCPT_CAL,"File CPTANALIN(ABRFIC/VCRTYP/VCRNUM/VCRLIN/VCRSEQ/CPLCLE/ANALIG)=") From TRTMIG
Return

##############################
$RAZ_SIH
Raz [F:SIH]AMTATIL
Raz [F:SIH]AMTNOTL
Raz [F:SIH]BPAPAY
Raz [F:SIH]BPYADDLIG
Raz [F:SIH]BPYCRY
Raz [F:SIH]BPYCRYNAM
Raz [F:SIH]BPYCTY
Raz [F:SIH]BPYNAM
Raz [F:SIH]BPYPOSCOD
Raz [F:SIH]BPYSAT
Raz [F:SIH]CURLED
Raz [F:SIH]DIE
Raz [F:SIH]FIY
Raz [F:SIH]LED
Raz [F:SIH]PER
Raz [F:SIH]RATDIV
Raz [F:SIH]RATMLT
Raz [F:SIH]STARPT
Raz [F:SIH]WRHE
Return
$RAZ_SID
Raz [F:SID]AMTLIN
Raz [F:SID]CPY
Raz [F:SID]DDTANOT
Raz [F:SID]DDTANUM
Raz [F:SID]DSPLINFLG
Raz [F:SID]DSPLINVOL
Raz [F:SID]DSPLINWEI
Raz [F:SID]DSPVOU
Raz [F:SID]DSPWEU
Raz [F:SID]EECFLOPHY
Raz [F:SID]IMPNUMLIG
Raz [F:SID]WRH
Return
$RAZ_SIV
Raz [F:SIV]CPY
Raz [F:SIV]DSPTOTQTY
Raz [F:SIV]DSPTOTVOL
Raz [F:SIV]DSPTOTWEI
Raz [F:SIV]DSPVOU
Raz [F:SIV]DSPWEU
Raz [F:SIV]EECNATR
Raz [F:SIV]EECSCHR
Raz [F:SIV]FFWADD
Raz [F:SIV]FFWNUM
Raz [F:SIV]ICTCTY
Raz [F:SIV]INVDTADSP
Raz [F:SIV]INVDTATYP
Raz [F:SIV]SFISSTCOD #Gbn-101380
Raz [F:SIV]PLISTC
Raz [F:SIV]STARPT
Return

##############################
$EVAL_CAL
          For J=1 To max(GNBDIE,GOPTCANA)
              [F:CAL]DIE(J-1)=GDIE(J)
              Case J
              When 1 : [F:CAL]CCE(J-1)=[F:SIDM]CCE1
              When 2 : [F:CAL]CCE(J-1)=[F:SIDM]CCE2
              When 3 : [F:CAL]CCE(J-1)=[F:SIDM]CCE3
              When 4 : [F:CAL]CCE(J-1)=[F:SIDM]CCE4
              When 5 : [F:CAL]CCE(J-1)=[F:SIDM]CCE5
              When 6 : [F:CAL]CCE(J-1)=[F:SIDM]CCE6
              When 7 : [F:CAL]CCE(J-1)=[F:SIDM]CCE7
              When 8 : [F:CAL]CCE(J-1)=[F:SIDM]CCE8
              When 9 : [F:CAL]CCE(J-1)=[F:SIDM]CCE9
              When Default
              Endcase

#              If evalue("dim([F:SIDM]CCE"+num$(J)+")")>0
#                  [F:CAL]CCE(J-1)=evalue("[F:SIDM]CCE"+num$(J))
#              Endif
          Next J
Return



########################################################################
# Initialization of the new fields for V6.0
########################################################################
$MAJ60_SIVSIH
      ######################################
      #-- Mise à jour de la table SINVOICEV
      ######################################
      [F:SIV]CPY=GSOCIETE
      If len([F:SIV]EECNAT)>2 & left$([F:SIV]EECNAT,1)="0" : [F:SIV]EECNAT=right$([F:SIV]EECNAT,2) : Endif
      If [F:SIV]STOMVTFLG=1
          [F:SIV]EECNATR=[F:SIV]EECNAT : Raz [F:SIV]EECNAT
          [F:SIV]EECSCHR=[F:SIV]EECSCH : Raz [F:SIV]EECSCH
      Endif
      # Initialisation ds le tableau des éléments de facturation
      # INVDTATYP : Type de valeur : Si élément taux INVDTATYP=3 (%) Sinon INVDTATYP=1 (HT)
      For WI=0 To dim([F:SIV]INVDTA)-1
          If [F:SIV]INVDTA(WI)<>0
              [F:SIV]INVDTATYP(WI)=1
              WJ=find([F:SIV]INVDTA(WI),WSFINUM(0..WNBSFI))
              If WJ>0 & WSFIAMTCOD(WJ-1)=1 [F:SIV]INVDTATYP(WI)=3 Endif
          Endif
      Next
      # Renseignement des unités de répartition
      [F:SIV]DSPWEU=GSALDSPWEU
      [F:SIV]DSPVOU=GSALDSPVOU
      Raz [F:SIV]DSPTOTQTY, [F:SIV]DSPTOTWEI, [F:SIV]DSPTOTVOL
      # Initialisation flag impression
      If dim([F:SIV]STARPT)>0 & [F:SIV]STARPT=0
          If [F:SIV]INVSTA>1
              [F:SIV]STARPT = 2
          Else
              [F:SIV]STARPT = 1
          Endif
      Endif

      ####################################
      #-- Mise à jour de la table SINVOICE
      ####################################
      If [F:SIH]LED(0)=""
          For WI=1 To max(GNBCOA,2)
              [F:SIH]LED   (WI-1)=GLEDSOC(WI)
              [F:SIH]CURLED(WI-1)=GDEVLED(WI)
              [F:SIH]RATDIV(WI-1)=1
              If GDEVLED(WI)=GLOCALDEV
                  If dim([F:SIHM]RATCUR)>0 [F:SIH]RATMLT(WI-1)=[F:SIHM]RATCUR Else [F:SIH]RATMLT(WI-1)=0 Endif
              Elsif GDEVLED(WI)=GSYSCUR
                  If dim([F:SIHM]RATRPT)>0 [F:SIH]RATMLT(WI-1)=[F:SIHM]RATRPT Else [F:SIH]RATMLT(WI-1)=0 Endif
              Else
                  [F:SIH]RATMLT(WI-1)=0
              Endif
          Next WI
      Endif
      If dim([F:SIH]DIE)>0 & [F:SIH]DIE(0)=""
          For WI=1 To max(GNBDIE,GOPTCANA)
              [F:SIH]DIE(WI-1)=GDIE(WI)
          Next WI
      Endif
      #-- Chargement des montants HT et TTC facture en devise société
      WI=find(GLOCALDEV,[F:SIH]CURLED)
      If WI>0 & [F:SIH]RATDIV(WI-1)<>0
        WCOURS=[F:SIH]RATMLT(WI-1)/[F:SIH]RATDIV(WI-1)
      Else
        WCOURS=0
      Endif
      Call COURMNT([F:SIH]CUR,GLOCALDEV,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]RATDAT,1,
&                    [F:SIH]AMTNOT,[F:SIH]AMTNOTL,WCOURS,WRET) From TRTDEV
      If WRET <> 0 Then
        # FGR 12/01/2010 : X3SUIVI61184        Call ECR_TRACE("     1-File SINVOICE"-[F:SIV]NUM+", Error ="-num$(WRET),-1) From GESECRAN
        Call ECR_TRACE("     AMTNOT COURMNT(CUR="+[F:SIH]CUR-"GLOCALDEV="+GLOCALDEV+")",-1) From GESECRAN
      Endif
      Call COURMNT([F:SIH]CUR,GLOCALDEV,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]RATDAT,1,
&                    [F:SIH]AMTATI,[F:SIH]AMTATIL,WCOURS,WRET) From TRTDEV
      If WRET <> 0 Then
        # FGR 12/01/2010 : X3SUIVI61184
        Call ECR_TRACE("     2-File SINVOICE"-[F:SIV]NUM+", Error ="-num$(WRET),-1) From GESECRAN
        Call ECR_TRACE("     AMTATI COURMNT(CUR="+[F:SIH]CUR-"GLOCALDEV="+GLOCALDEV+")",-1) From GESECRAN
      Endif
      # ACA Gestion des adresses BPAPYR+BPY*
      Gosub RECUP_BPR

      # Initialisation flag impression (6.2 Certification)
      If dim([F:SIH]STARPT)>0 & [F:SIH]STARPT=0
          If [F:SIH]STA>1
              [F:SIH]STARPT = 2
          Else
              [F:SIH]STARPT = 1
          Endif
      Endif

      #-- création des enr dans les tables SVCRVAT et SVCRFOOT à partir de la table SINVOICEV
      If [F:SIV]INVSTA=3 | [F:SIV]INVTYP=5
        ##Delete [SVF] Where VCRTYP=4 & VCRNUM=[F:SIV]NUM
        ##Delete [SVV] Where VCRTYP=4 & VCRNUM=[F:SIV]NUM
        Gosub UPD_SVV_SIV : Gosub UPD_SVF_SIV
#         Call ECR_TRACE("SINVOICE : "-[F:SIV]NUM,1) From GESECRAN
      Endif
      #-- Si facture / avoir non validé : creation des enr de CPTANALIN
      If find([F:SIV]INVTYP,1,2) & [F:SIV]INVSTA<>3
          For J=0 To dim([F:SIVM]DTA)-1
              If [F:SIVM]DTA(J)=0 : Break : Endif

              WJ=find([F:SIVM]DTA(J),WSFINUM(0..WNBSFI))
              Gosub RECUP_SFI From UUMGTRTSAL00

##              Look [CAL] CAL0="SVF";0;[F:SIV]NUM;0;0;num$([F:SIVM]DTA(J));1
##              If fstat
                  Raz [F:CAL]
                  [F:CAL]ABRFIC="SVF"
                  [F:CAL]VCRTYP=4
                  [F:CAL]VCRNUM=[F:SIV]NUM
                  [F:CAL]VCRSEQ=[F:SIVM]DTA(J)
                  #[F:CAL]CPLCLE=num$([F:SIV]DTA(J))
                  [F:CAL]ANALIG=1
                  For I=1 To max(GNBCOA,2)
                      [F:CAL]LED(I-1)=GLEDSOC(I)
                      [F:CAL]COA(I-1)=GCOA(I)
                  Next I
                  [F:CAL]DSP=[F:SFI]DSP
                  For I=1 To max(GNBDIE,GOPTCANA)
                      [F:CAL]DIE(I-1)=GDIE(I)
                      [F:CAL]CCE(I-1)=[F:SFI]CCE(I-1)
                  Next I

                  # Issue 106947 - 20150811 by LD : Migration of historic folder
#                  If NEWMOTEUR
#                      Gosub CAL_STK : # pour stocker ref
#                      WriteB [F:CAL]
#                  Else
#                      Write [F:CAL]
#                  Endif
#                  If fstat
#                    If NEWMOTEUR & adxwrb>1
#                      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#                      Gosub CAL_ERRTRA : # pour afficher les ref
#                    Else
#                      Call ECR_TRACE("File CPTANALIN  SVF 0 "-[F:SIV]NUM-"0 0"-num$([F:SIVM]DTA(J))+", Error ="-num$(fstat),1) From GESECRAN
#                    Endif
#                    GOK=0 : Break
#                  Endif
                  Gosub CAL_STK : # pour stocker ref
                  WriteB [F:CAL]
                  If fstat
                    Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
                    Gosub CAL_ERRTRA : # pour afficher les ref
                    GOK=0 : Break
                  Endif
                  # Issue 106947 - 20150811 by LD
##              Endif
          Next J
          If GOK<1 : Return : Endif
      Endif

Return

########################################################################
# Initialization of the new fields (Invoice lines) for V6.0
########################################################################
$MAJ60_SID
##      Look [CAL] CAL0="SID";0;[F:SID]NUM;[F:SID]SIDLIN;0;"";1
##      If fstat
          Raz [F:CAL]
          [F:CAL]ABRFIC="SID"
          [F:CAL]VCRNUM=[F:SID]NUM
          [F:CAL]VCRLIN=[F:SID]SIDLIN
          [F:CAL]ANALIG=1
          For J=1 To max(GNBCOA,2)
              [F:CAL]LED(J-1)=GLEDSOC(J)
              [F:CAL]COA(J-1)=GCOA(J)
          Next J
          [F:CAL]ACC(0)=[F:SIDM]LINACC
          [F:CAL]ACC(1)=[F:SIDM]LINCNA
          Gosub EVAL_CAL

          # Issue 106947 - 20150811 by LD : Migration of historic folder
#          If NEWMOTEUR
#              Gosub CAL_STK : # pour stocker ref
#              WriteB [F:CAL]
#          Else
#              Write [F:CAL]
#          Endif
#          If fstat
#            If NEWMOTEUR & adxwrb>1
#              Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#              Gosub CAL_ERRTRA : # pour afficher les ref
#            Else
#              Call ECR_TRACE("File CPTANALIN SID 0"-[F:SID]NUM-num$([F:SID]SIDLIN)+", Error ="-num$(fstat),1) From GESECRAN
#            Endif
#            GOK=0 : Return
#          Endif
          Gosub CAL_STK : # pour stocker ref
          WriteB [F:CAL]
          If fstat
            Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
            Gosub CAL_ERRTRA : # pour afficher les ref
            GOK=0 : Return
          Endif
          # Issue 106947 - 20150811 by LD
##      Endif
      # Bug 72056 : Init. dates de prestation lignes à partir de l'entête (V6.1)
      If [F:SID]ENDDAT=[0/0/0] [F:SID]ENDDAT=[F:SIH]ENDDATSVC Endif
      If [F:SID]STRDAT=[0/0/0] [F:SID]STRDAT=[F:SIH]STRDATSVC Endif
      # Issue 90175 - 2013-07-01 by SR : Si pas de date fin--> pas de date début
      If [F:SID]ENDDAT=[0/0/0] : [F:SID]STRDAT=[F:SID]ENDDAT : Endif
      #----- Alimentation de la société sur les lignes de facture d'achat -----#
      WFICD="SID" : WFICD1="SID" : WFICE="SIV" : Gosub ALIM_FICD
      If [F:SID]EECFLOPHY=0  [F:SID]EECFLOPHY=1 : Endif
Return

# 71065 : PJT
########################################################################
# Initialization of the new fields for U11 (Invoice lines) [CHALLENGER]
########################################################################
$MAJ110_SIDSIV

[F:SID]PJT = [F:SIV]PJT

Return
# 71065 : PJT

##############################################################################################
$RECUP_BPR
  If [F:SIH]BPAPAY = ""
      If [F:BPC]BPCNUM<>[F:SIH]BPR
        Read [BPC]BPC0=[F:SIH]BPR
        If fstat Raz [F:BPC] Endif
      Endif
      If [F:SIH]BPRPAY=[F:BPC]BPCPYR
          [F:SIH]BPAPAY=[F:BPC]BPAPYR
      Else
          If [BPR]BPRNUM<>[F:SIH]BPRPAY
            Read [BPR]BPR0=[F:SIH]BPRPAY
            If fstat Raz [F:BPR] Endif
          Endif
          [F:SIH]BPAPAY=[F:BPR]BPAADD
      Endif
  Endif
  Gosub RECUP_BPR2
Return

$RECUP_BPR2
      If [F:BPC]BPCTYP=2
          # Si client divers, on récupère l'adresse facturation
          [F:SIH]BPYNAM(0)=[F:SIH]BPRNAM(0)
          [F:SIH]BPYNAM(1)=[F:SIH]BPRNAM(1)
          [F:SIH]BPYADDLIG(0)=[F:SIH]BPAADDLIG(0)
          [F:SIH]BPYADDLIG(1)=[F:SIH]BPAADDLIG(1)
          [F:SIH]BPYADDLIG(2)=[F:SIH]BPAADDLIG(2)
          [F:SIH]BPYPOSCOD=[F:SIH]POSCOD
          [F:SIH]BPYCTY=[F:SIH]CTY
          [F:SIH]BPYSAT=[F:SIH]SAT
          [F:SIH]BPYCRY=[F:SIH]CRY
          [F:SIH]BPYCRYNAM=[F:SIH]CRYNAM
      Else
          # Si client non divers, on prend le code adresse et on récupère le détail associé
          If [BPA]BPATYP<>1 or [BPA]BPANUM<>[F:SIH]BPRPAY or [BPA]BPAADD<>[F:SIH]BPAPAY
            Read [BPA]BPA0=1;[F:SIH]BPRPAY;[F:SIH]BPAPAY
            If fstat Raz [F:BPA] Endif
          Endif
          [F:SIH]BPYNAM(0)=""
          [F:SIH]BPYNAM(1)=""
          [F:SIH]BPYADDLIG(0)=[F:BPA]BPAADDLIG(0)
          [F:SIH]BPYADDLIG(1)=[F:BPA]BPAADDLIG(1)
          [F:SIH]BPYADDLIG(2)=[F:BPA]BPAADDLIG(2)
          [F:SIH]BPYPOSCOD=[F:BPA]POSCOD
          [F:SIH]BPYCTY=[F:BPA]CTY
          [F:SIH]BPYSAT=[F:BPA]SAT
          [F:SIH]BPYCRY=[F:BPA]CRY
          [F:SIH]BPYCRYNAM=[F:BPA]CRYNAM
      Endif
Return

########################################################################
# Initialization of the new fields for V8 [AKIRA]
########################################################################
MAJ80_SIVSIH
  #SST Line Level Override
  #If GACTLTA & GLOCUSATAX #108649.o
  If GSSTTAX(find([F:SIH]CPY,GSOC)) #108649.n
      For I=0 To dim([F:SIV]INVDTA)-1
          If [F:SIV]INVDTA(I)<>0
              Local Integer WJ
              WJ=find([F:SIV]INVDTA(I),WSFINUM(0..WNBSFI))
              If WJ>0 : [F:SIV]SFISSTCOD(I)=WSFISSTCOD(WJ-1) : Endif
          Endif
      Next
  Endif
Return

########################################################################
# Initialization of the new fields (invoice lines) for V8 [AKIRA]
########################################################################
$MAJ80_SID
  #SST Line Level Override
  #If GACTLTA & GLOCUSATAX #108649.o
  If GSSTTAX(find([F:SIH]CPY,GSOC)) #108649.n
      If [F:SID]ITMREF<>""
          Read [F:ITM]ITM0 = [F:SID]ITMREF
          If !fstat #Record exists
              If [F:ITM]SSTCOD<>""
                  [F:SID]SSTCOD = [F:ITM]SSTCOD
              Endif
          Endif
      Endif
  Endif
Return

# ------------------------------------------------------------------ #
# Alimentation des champs lignes détails communs à toutes les tables #
# Alimentation des champs entête communs à toutes les tables         #
# --> Concerne entre autre les totalisations poids et volume         #
# Entête :                                                           #
# - DSPTOTQTY  : Cumul quantité                                      #
# - DSPTOTWEI  : Cumul poids                                         #
# - DSPTOTVOL  : Cumul volume                                        #
# - DSPWEU     : Unité Poids                                         #
# - DSPVOU     : Unité Volume                                        #
# Détail :                                                           #
# - DSPLINFLG  : Flag répartition                                    #
# - DSPLINWEI  : Poids  ligne                                        #
# - DSPLINVOL  : Volume ligne                                        #
# - DSPWEU     : Unité Poids                                         #
# - DSPVOU     : Unité Volume                                        #
#                                                                    #
# - CPY        : Société                                             #
# - DSPLINFLG  : Flag répartition                                    #
# ------------------------------------------------------------------ #
###########################################################
$ALIM_FICD

[F:SID]CPY=[F:SIV]CPY

[F:SID]DSPLINFLG=2

WITMREF = [F:SID]ITMREF
Gosub READ_ITM From UUMGTRTSAL00

WMNTCALC = [F:ITM]ITMWEI * [F:SID]QTY * [F:SID]SAUSTUCOE
WUOM1=[F:ITM]WEU
WUOM2=GSALDSPWEU
WQTY=WMNTCALC
#Call CONVERT_QTY ([F:ITM]WEU,GSALDSPWEU,WMNTCALC)
Gosub CONVERT_QTY From UUMGTRTSAL00
WMNTCALC=WQTY
[F:SID]DSPLINWEI=WMNTCALC

WMNTCALC = [F:ITM]ITMVOU * [F:SID]QTY * [F:SID]SAUSTUCOE
WUOM1=[F:ITM]VOU
WUOM2=GSALDSPVOU
WQTY=WMNTCALC
#Call CONVERT_QTY ([F:ITM]VOU,GSALDSPVOU,WMNTCALC)
Gosub CONVERT_QTY From UUMGTRTSAL00
WMNTCALC=WQTY
[F:SID]DSPLINVOL=WMNTCALC

[F:SID]DSPWEU=[F:SIV]DSPWEU
[F:SID]DSPVOU=[F:SIV]DSPVOU

WMONT  = [F:SIV]DSPTOTQTY
If WFICD<>"SQD"
    WMONT += [F:SID]QTYSTU
Else
    WMONT += [F:SID]QTY
Endif
[F:SIV]DSPTOTQTY=WMONT

WMONT  = [F:SIV]DSPTOTWEI
WMONT += [F:SID]DSPLINWEI
[F:SIV]DSPTOTWEI=WMONT

WMONT  = [F:SIV]DSPTOTVOL
WMONT += [F:SID]DSPLINVOL
[F:SIV]DSPTOTVOL=WMONT

Return

# ------------------------------------------------- #
# Création des enregistrements de la table SVCRFOOT #
# ------------------------------------------------- #
$UPD_SVF_SIV
# Boucle sur la table des élements de pied
For I=0 To dim([F:SIVM]DTA)-1
  If [F:SIVM]DTA(I)<>0
      WJ=find([F:SIVM]DTA(I),WSFINUM(0..WNBSFI))
      Gosub RECUP_SFI From UUMGTRTSAL00
##      Look [SVF] SVF0=[F:SIV]NUM;4;[F:SIVM]DTA(I)
##      If fstat
          Raz [F:SVF]
          [F:SVF]VCRTYP=4 : [F:SVF]VCRNUM=[F:SIV]NUM : [F:SVF]NUM=[F:SIV]NUM

          [F:SVF]CPY=[F:SIV]CPY
          [F:SVF]CUR=[F:SIV]CUR

#          If evalue("dim([F:SVF]CREDAT)")>0
#              Assign "[F:SVF]CREDAT" With date$
#          Endif
#          If evalue("dim([F:SVF]CREUSR)")>0
#              Assign "[F:SVF]CREUSR" With GUSER
#          Endif
          [F:SVF]CREDAT=date$
          [F:SVF]CREUSR=GUSER
          [F:SVF]DTA          = [F:SIVM]DTA(I)
          [F:SVF]DTAAMT       = [F:SIVM]DTAAMT(I)
#          [F:SVF]DTATYP       = [F:SIVM]DTATYP(I)
          [F:SVF]DTATYP       = [F:SFI]CLCBAS
          [F:SVF]DTANOT       = [F:SIVM]DTANOT(I)
          [F:SVF]DTAVATNOT(0) = [F:SIVM]DTANOT(I)
          [F:SVF]DTANET(0)    = [F:SIVM]DTANET(I)
          [F:SVF]DTAVAT(0)    = [F:SIVM]DTAVAT(I)
          [F:SVF]DTAVATRAT(0) = [F:SIVM]DTAVATRAT(I)
          [F:SVF]DTAVATAMT(0) = [F:SIVM]DTAVATAMT(I)
          [F:SVF]CLCORD       = [F:SFI]CLCORD
          [F:SVF]AMTCOD       = [F:SFI]AMTCOD
          [F:SVF]DTADSP       = [F:SFI]DSP

          # Issue 106947 - 20150811 by LD : Migration of historic folder
#          If NEWMOTEUR
#              Gosub SVF_STK : # pour stocker ref
#              WriteB [F:SVF]
#          Else
#              Write [F:SVF]
#          Endif
#          If fstat
#            If NEWMOTEUR & adxwrb>1
#              Call ECR_TRACE("File SVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
#              Gosub SVF_ERRTRA : # pour afficher les ref
#            Else
#              Call ECR_TRACE("File SVCRFOOT"-[F:SIV]NUM-"4"-num$([F:SIV]INVDTA(I))+", Error ="-num$(fstat),1) From GESECRAN
#            Endif
#            GOK=0 : Break
#          Endif
          Gosub SVF_STK : # pour stocker ref
          WriteB [F:SVF]
          If fstat
            Call ECR_TRACE("File SVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
            Gosub SVF_ERRTRA : # pour afficher les ref
            GOK=0 : Break
          Endif
          # Issue 106947 - 20150811 by LD
##      Endif
  Endif
Next I
Return


# ------------------------------------------------- #
# Création des enregistrements de la table SVCRVAT  #
# ------------------------------------------------- #
$UPD_SVV_SIV
# Boucle sur la table des taxes liées aux produits
For I=0 To dim ([F:SIVM]VAT)-1
  If [F:SIVM]VAT(I)<>""
##      Look [SVV] SVV0=4;[F:SIV]NUM;[F:SIVM]VAT(I)
##      If fstat
          Raz [F:SVV]
          [F:SVV]VCRTYP=4 : [F:SVV]VCRNUM=[F:SIV]NUM : [F:SVV]NUM=[F:SIV]NUM

          [F:SVV]CPY=[F:SIV]CPY
          [F:SVV]CUR=[F:SIV]CUR

#          If evalue("dim([F:SVV]CREDAT)")>0
#              Assign "[F:SVV]CREDAT" With date$
#          Endif
#          If evalue("dim([F:SVV]CREUSR)")>0
#              Assign "[F:SVV]CREUSR" With GUSER
#          Endif
          [F:SVV]CREUSR=GUSER
          [F:SVV]CREDAT=date$

          [F:SVV]VAT       = [F:SIVM]VAT(I)
          [F:SVV]VATTYP    = [F:SIVM]VATTYP(I)
          [F:SVV]VATRAT    = [F:SIVM]VATRAT(I)

          [F:SVV]VATGRO    = [F:SIVM]VATGRO(I)
          [F:SVV]VATNET    = [F:SIVM]VATNET(I)
          [F:SVV]VATAMT    = [F:SIVM]VATAMT(I)
          [F:SVV]VATSUPAMT = [F:SIVM]VATSUPAMT(I)

          [F:SVV]BASTAX    = [F:SIVM]VATNET(I)
          [F:SVV]AMTTAX    = [F:SIVM]VATAMT(I)

          Write [F:SVV]
          If fstat
            Call ECR_TRACE("File SVCRVAT"-"4"-[F:SIVM]VAT(I)+", Error ="-num$(fstat),1) From GESECRAN
            GOK=0 : Break
          Endif
##      Endif
  Endif
Next I
If GOK<1 : Return : Endif
Gosub SVV2
Return

$SVV2
# Boucle sur la table des éléments de pied
For I=0 To dim([F:SIVM]DTAVAT)-1
  If [F:SIVM]DTAVAT(I)<>""
      Read [SVV]SVV0=4;[F:SIV]NUM;[F:SIVM]DTAVAT(I)
      If fstat
          Raz [F:SVV]
          [F:SVV]VCRTYP=4 : [F:SVV]VCRNUM=[F:SIV]NUM

          [F:SVV]CPY=[F:SIV]CPY
          [F:SVV]CUR=[F:SIV]CUR

#          If evalue("dim([F:SVV]CREDAT)")>0
#              Assign "[F:SVV]CREDAT" With date$
#          Endif
#          If evalue("dim([F:SVV]CREUSR)")>0
#              Assign "[F:SVV]CREUSR" With GUSER
#          Endif
          [F:SVV]CREUSR=GUSER
          [F:SVV]CREDAT=date$

          [F:SVV]VAT    = [F:SIVM]DTAVAT(I)
          [F:SVV]VATTYP = 1
          [F:SVV]VATRAT = [F:SIVM]DTAVATRAT(I)

          [F:SVV]BASTAX = [F:SIVM]DTANET(I)
          [F:SVV]AMTTAX = [F:SIVM]DTAVATAMT(I)

          Write [F:SVV]
          If fstat
            Call ECR_TRACE("File SVCRVAT"-"4"-[F:SIVM]VAT(I)+", Error ="-num$(fstat),1) From GESECRAN
            GOK=0 : Break
          Endif
      Else
          Gosub REW_SVV
          If GOK=0 : Break : Endif
      Endif
  Endif
Next I

Return


$REW_SVV
          [F:SVV]BASTAX += [F:SIVM]DTANET(I)
          [F:SVV]AMTTAX += [F:SIVM]DTAVATAMT(I)

          Rewrite [F:SVV]
          If fstat
            Call ECR_TRACE("File SVCRVAT"-"4"-[F:SIVM]VAT(I)+", Error ="-num$(fstat),1) From GESECRAN
            GOK=0
          Endif
Return

########################################################################
#----- Suppression des incohérences entre tables avant migration -----#
########################################################################
$TRT_SQL

 #-----  Déclaration des variables -----#

 Call DEBTRANS From GLOCK
 Gosub SET_FIRST From TRTFIRST

 Trbegin [SIDM]
 GOK = 1

 Gosub TRT_SQL1

 If GOK<1
  Rollback
 Else
  Commit
 Endif

Gosub UNSET_FIRST From TRTFIRST

Return

########################################################################
# Mise à jour SALFCY SINVOICED à partir de SALFCY SINVOICEV
########################################################################
$TRT_SQL1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL

REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMSIDM+" SET SALFCY_0="
REQSQL(1)="(SELECT SIV.SALFCY_0 FROM"-DOSSIER+"."+WNAMSIVM+" SIV Where SIV.NUM_0="+WNAMSIDM+".NUM_0)"
REQSQL(2)=" WHERE "+WNAMSIDM+".SALFCY_0<>(SELECT SIV.SALFCY_0 From"-DOSSIER+"."+WNAMSIVM+" SIV Where SIV.NUM_0="+WNAMSIDM+".NUM_0) "
Execsql From num$(GTYPDBA*2+1) Sql REQSQL

Onerrgo
Return
###################################################################################################
$ERR_SQL
 GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 GOK=0
Resume
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGTRTSAL08(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTSAL08(APPLI)
End

