#<AdxTL>@(#)0.0.0.0 $Revision$ Library about analytical dimen
##############################################################################################################
# ROUTINES ABOUT ANALYTICAL DIMENSIONS
##############################################################################################################
# INI_CCE         : Initializes the analytical dimension from a default dimension
# IS_DIETRK       : Is the dimension type managed by the given ledger code and/or the given account ?
# GET_DIEFMT      : Returns the dimension format for a given dimension type
# GET_DIECOLHEA   : Returns the Column Header for a given dimension type
# GET_CCEREDLST   : Returns, from a list of dimensions type & dimensions used as parameter, the dimensions types & dimensions managed by the ledger type used as parameter
# GET_CCELEDLST   : Returns, from a list of dimensions type & dimensions used as parameter, the dimensions types & dimensions managed by the ledger code used as parameter
# GET_DIELST      : Returns the number and value of the dimension types for a given company and a given ledger type
# CTL_CCE         : Controls the value of the dimension. The dimension cannot be empty
# CTL_CCEACC      : Controls the value of the dimension entered for an account and the value of the dimension. The dimension can be empty
# CTL_CCEACCSYRA  : Same routine as CTL_CCEACC but called from a Syracuse context
# CRE_CCE         : Automatic Creation/Update of analytical dimension

# Private routines :
# _CTL_CCE        : Controls the value of the dimension
##############################################################################################################

#####################################################################################################################
## INI_CCE
#####################################################################################################################
#**
#* Initializes the analytical dimension from a default dimension.<br>
#* If the default dimension doesn't retrieve an analytical dimension and if an account is used as
#* parameter, the analytical dimension is initialized by the one defined in the account [F:GAC]CCEDEF
#*
#* @param ACTX               Context
#* @param INST
#* @param COMPANY            Company
#* @param DEFAULT_DIMENSION  Default dimension
#* @param LEDCOD             Ledger Code
#* @param COA                Chart of account
#* @param ACC                Account
#* @param DIE                Dimension Type
#* @param CCE                Analytical dimension
#* @param ERRMES             Error message
#*!
Funprog INI_CCE(ACTX,INST,COMPANY,DEFAULT_DIMENSION,LEDCOD,COA,ACC,DIE,CCE,ERRMES)
Variable Instance ACTX    Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance INST   Using OBJECT
Value    Char    COMPANY()             : # Company
Value    Char    DEFAULT_DIMENSION()   : # Default dimension
Value    Char    LEDCOD()              : # Ledger Code
Value    Char    COA()                 : # Chart of account
Value    Char    ACC()                 : # Account
Value    Char    DIE()                 : # Dimension Type
Variable Char    CCE()                 : # Analytical dimension
Variable Char    ERRMES()              : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT  [GAC] : Endif

Local Integer IND

Raz CCE

If !func FINCCE_SYRA.IS_DIETRK(ACTX,LEDCOD,COA,ACC,DIE) : End [L]ASTATUS : Endif

[L]ASTATUS = func FINCDE_SYRA._INI_CCE(ACTX,INST,COMPANY,DEFAULT_DIMENSION,DIE,CCE,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

If CCE="" & COA<>"" & ACC<>""
 Call LEC_GAC(ACC,COA) From CPTLEC
 If !fstat
  Call LEC_GAC(ACC,COA) From CPTLEC
  IND = find(DIE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
  CCE = [F:GAC]CCEDEF(IND-1)
 Endif
Endif
End [L]ASTATUS

#####################################################################################################################
## IS_DIETRK
#####################################################################################################################
#**
#* Checks that:<ul>
#* <li>The Dimension Type is managed by the Ledger Code used as parameter (no control if the ledger code is not defined)
#* <li>The Dimension Type is managed by the Account used as parameter (no control if the account is not defined)
#* </ul>
#*
#* @param ACTX   Context
#* @param LEDCOD Ledger Code
#* @param COA    Chart of accounts
#* @param ACC    Account
#* @param DIE    Dimension Type
#*!
Funprog IS_DIETRK(ACTX,LEDCOD,COA,ACC,DIE)
Variable Instance ACTX    Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    LEDCOD()              : # Ledger Code
Value    Char    COA()                 : # Chart of accounts
Value    Char    ACC()                 : # Account
Value    Char    DIE()                 : # Dimension Type

Local Integer DIETRKFLG : DIETRKFLG = 1
Local Integer ILED

If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT  [GAC] : Endif

## If a ledger code is used as parameter, we verify that the dimension type is managed by this ledger code
If LEDCOD<>""
 DIETRKFLG = 0
 ILED = fmet ACTX.ACACHE.LED.AGETINDEX(LEDCOD)
 If ILED=[V]CST_ANOTDEFINED : End 0 : Endif
 For IDIE=1 To fmet ACTX.ACACHE.LED.AGETVALNUM(LEDCOD,"LEDDIENBR")
  If DIE = fmet ACTX.ACACHE.LED.AGETVALCHAR(LEDCOD,"DIE"+num$(IDIE))
   DIETRKFLG = 1 : Break
  Endif
 Next
Endif
If DIETRKFLG = 0 : End 0 : Endif

## If an account is used as parameter, we verify that the dimension type is managed by this account
If ACC<>""
 Call LEC_GAC(ACC,COA) From CPTLEC
 If fstat or !find(DIE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
  DIETRKFLG = 0 : End 0
 Endif
Endif
End 1


#####################################################################################################################
## GET_DIEFMT
#####################################################################################################################
#**
#* Returns the dimension format for a dimension type used as parameter (DIE)
#*
#* @param ACTX   Context
#* @param DIE    Dimension Type
#* @param DIEFMT Dimension Type Format
#* @param ERRMES Error message
#*!
Funprog GET_DIEFMT(ACTX,DIE,DIEFMT,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char        DIE()      : # Dimension Type
Variable Char     DIEFMT()   : # Dimension Type Format
Variable Char     ERRMES()   : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer IDIE

IDIE = fmet ACTX.ACACHE.DIE.AGETINDEX(DIE)
If IDIE=[V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = DIE-mess(80,103,1) : End [L]ASTATUS
Endif
DIEFMT = fmet ACTX.ACACHE.DIE.AGETVALCHAR(DIE,"DIEFMT")
If DIEFMT = AVOID.ACHAR : DIEFMT = "15c" : Endif
End [L]ASTATUS



#####################################################################################################################
## GET_DIECOLHEA
#####################################################################################################################
#**
#* Returns the Column Header for a dimension type used as parameter (DIE)
#*
#* @param ACTX      Context
#* @param DIE       Dimension Type
#* @param DIECOLHEA
#* @param ERRMES    Error message
#*!
Funprog GET_DIECOLHEA(ACTX,DIE,DIECOLHEA,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char        DIE()
Variable Char     DIECOLHEA()
Variable Char     ERRMES()   : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer IDIE

IDIE = fmet ACTX.ACACHE.DIE.AGETINDEX(DIE)
If IDIE=[V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = DIE-mess(80,103,1) : End [L]ASTATUS
Endif
DIECOLHEA = fmet ACTX.ACACHE.DIE.AGETVALCHAR(DIE,"COLHEA")
End [L]ASTATUS


#####################################################################################################################
## GET_CCEREDLST
#####################################################################################################################
#**
#* Returns, from a list of dimensions used as paramater (ALLDIE & DIE), the dimensions
#* managed by the ledtyp type used as parameter (LEDTYP)
#*
#* @param ACTX    Context
#* @param COMPANY Company
#* @param LEDTYP  Ledger type
#* @param ALLDIE  All Dimension Types
#* @param ALLCCE  All Analytical Dimensions
#* @param DIE     Dimension Types attached to the ledger type used as parameter (LEDTYP)
#* @param CCE     Analytical Dimensions attached to the ledger type used as parameter (LEDTYP)
#* @param ERRMES  Error message
#*!
Funprog GET_CCEREDLST(ACTX,COMPANY,LEDTYP,ALLDIE,ALLCCE,DIE,CCE,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY()     : # Company
Value    Integer  LEDTYP        : # Ledger type
Value    Char     ALLDIE()(1..) : # All Dimension Types
Value    Char     ALLCCE()(1..) : # All Analytical Dimensions
Variable Char     DIE()(1..)    : # Dimension Types attached to the ledger type used as parameter (LEDTYP)
Variable Char     CCE()(1..)    : # Analytical Dimensions attached to the ledger type used as parameter (LEDTYP)
Variable Char     ERRMES()      : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Char    DIEFMT(15)(1..len(mess(0,2644,1)))         : # Dimension Types Formats
Local Char    DIECOLHEA(GLONAX1)(1..len(mess(0,2644,1))) : # Dimension Types Column Header
Local Integer NBRDIE,NBRDIEMAX, ICPY, IDIE, I

ICPY = fmet ACTX.ACACHE.ACPY.AGETINDEX(COMPANY)
If ICPY = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = COMPANY-mess(16,104,1) : End [L]ASTATUS
Endif
NBRDIEMAX = fmet ACTX.ACACHE.ACPY.AGETVALNUM(COMPANY,"NBRDIE")

If NBRDIEMAX = 0 : Raz DIE, CCE : End [L]ASTATUS : Endif

Local Integer DIEOBYFLG(1..NBRDIEMAX)

[L]ASTATUS = func FINACM_SYRA.GET_ANAREDSTC(ACTX,COMPANY,1,1,LEDTYP,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

For I=1 To NBRDIE
 IDIE = find(DIE(I),ALLDIE(1..NBRDIEMAX))
 If IDIE
  CCE(I) = ALLCCE(IDIE)
 Else
  CCE(I) = ""
 Endif
Next
End [L]ASTATUS


#####################################################################################################################
## GET_CCELEDLST
#####################################################################################################################
#**
#* Returns, from a list of dimensions used as paramater (ALLDIE & ALLCCE), the dimensions
#* managed by the ledger code used as parameter (LEDCOD)
#*
#* @param ACTX   Context
#* @param ALLDIE All dimension types
#* @param ALLCCE All analytical dimensions
#* @param LEDCOD Ledger code
#* @param DIE    Dimension types managed
#* @param CCE    Analytical dimension managed
#*!
Funprog GET_CCELEDLST(ACTX,ALLDIE,ALLCCE,LEDCOD,DIE,CCE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char ALLDIE()(1..) : # All dimension types
Value    Char ALLCCE()(1..) : # All analytical dimensions
Value    Char LEDCOD        : # Ledger code
Variable Char DIE()(1..)    : # Dimension types managed
Variable Char CCE()(1..)    : # Analytical dimension managed

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK
Local Integer I,J : J = 0

If adxtyp=33 | !clalev([F:LED]) : Local File GLED : Endif

Raz DIE,CCE

Call LEC_LED(LEDCOD) From CPTLEC
If !fstat
 For I=1 To dim(ALLDIE)
  If ALLDIE(I)="" : Break  : Endif
  If find(ALLDIE(I),[F:LED]DIE(0..[F:LED]DIENBR-1))
   J +=1
   DIE(J) = ALLDIE(I)
   CCE(J) = ALLCCE(I)
  Endif
 Next
Endif
End [L]ASTATUS


#####################################################################################################################
## GET_DIELST
#####################################################################################################################
#**
#* Returns the number and values of the dimension types for a given compayny and a given ledger type
#*
#* @param ACTX    Context
#* @param COMPANY Company
#* @param LEDTYP  Ledger type
#* @param NBRDIE  Number of dimensions
#* @param DIE     Dimension Types
#* @param ERRMES  Error message
#*!
Funprog GET_DIELST(ACTX,COMPANY,LEDTYP,NBRDIE,DIE,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    COMPANY()      : # Company
Value    Integer LEDTYP         : # Ledger type
Variable Integer NBRDIE         : # Number of dimensions
Variable Char    DIE()(1..)     : # Dimension Types
Variable Char    ERRMES()       : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Char    LEDCOD(GLONLED), LEDCUR(GLONCUR)
Local Integer I, ILED

[L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX, COMPANY, LEDTYP, LEDCOD, LEDCUR, ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

ILED = fmet ACTX.ACACHE.LED.AGETINDEX(LEDCOD)
If ILED = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = LEDCOD-mess(177,107,1) : End [L]ASTATUS
Endif

NBRDIE = fmet ACTX.ACACHE.LED.AGETVALNUM(LEDCOD,"LEDDIENBR")

For I=1 To NBRDIE
 DIE(I) = fmet ACTX.ACACHE.LED.AGETVALCHAR(LEDCOD,"DIE"+num$(I))
Next
End [L]ASTATUS


#####################################################################################################################
## CTL_CCE
#####################################################################################################################
#**
#* Controls the value of the dimension. The dimension cannot be empty
#*
#* @param ACTX   Context
#* @param VALCCE Value of the dimension
#* @param DIE    Dimension type that matches the VALCCE dimension
#* @param FCY    Site
#* @param DAT    Date
#* @param ERRMES Error message
#*!
Funprog CTL_CCE(ACTX,VALCCE,DIE,FCY,DAT,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Char     VALCCE() : # Value of the dimension
Value    Char     DIE      : # Dimension type that matches the VALCCE dimension
Value    Char     FCY      : # Site
Value    Date     DAT      : # Date
Variable Char     ERRMES() : # Error message

Local Integer ASTATUS
Local Integer APPCASE : APPCASE = 3 # Application case : control the value of the dimenson without an account and ledger

[L]ASTATUS = func _CTL_CCE(ACTX,AVOID.AINS,APPCASE,VALCCE,AVOID.ACHAR,DIE,FCY,DAT,AVOID.ACHAR,AVOID.ACHAR,AVOID.ACHAR,AVOID.AINT,
&                          AVOID.ACHAR,AVOID.ACHAR,ERRMES)
End [L]ASTATUS


#####################################################################################################################
## CTL_CCEACC
#####################################################################################################################
#**
#* Checks that the value of the dimension is right for the account and controls the value
#* of the dimension. The dimension can be empty. The account cannot be empty.
#*
#* @param ACTX    Context
#* @param VALCCE  Value of the dimension
#* @param LEDCOD  Ledger code
#* @param DIE     Dimension type that matches the VALCCE dimension
#* @param FCY     Site
#* @param DAT     Date
#* @param ACC     Account of the entry
#* @param ALLDIE  All the dimension types
#* @param CCE     String to evaluate in order to have the values of the dimensions that matche the DIE in ALLDIE
#* @param NOL     Line number in the mask that matches the current line of input
#* @param TYP     Document type. Can be empty
#* @param COMPANY Company of the document type
#* @param ERRMES  Error message
#*!
Funprog CTL_CCEACC(ACTX,VALCCE,LEDCOD,DIE,FCY,DAT,ACC,ALLDIE,CCE,NOL,TYP,COMPANY,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Char     VALCCE()     : # Value of the dimension
Value    Char     LEDCOD()     : # Ledger code
Value    Char     DIE()        : # Dimension type that matches the VALCCE dimension
Value    Char     FCY()        : # Site
Value    Date     DAT          : # Date
Value    Char     ACC()        : # Account of the entry
Value    Char     ALLDIE()(0..): # All the dimension types
Value    Char     CCE          : # String to evaluate in order to have the values of the dimensions that matche the DIE in ALLDIE
Value    Integer  NOL          : # Line number in the mask that matches the current line of input
Value    Char     TYP          : # Document type. Can be empty
Value    Char     COMPANY      : # Company of the document type
Variable Char     ERRMES()     : # Error message

Local Integer ASTATUS
Local Integer APPCASE : APPCASE = 1 # Application case : control the dimension with the account in a classic environment

[L]ASTATUS = func _CTL_CCE(ACTX,AVOID.AINS,APPCASE,VALCCE,LEDCOD,DIE,FCY,DAT,ACC,ALLDIE,CCE,NOL,TYP,COMPANY,ERRMES)
End [L]ASTATUS


#####################################################################################################################
## CTL_CCEACCSYRA
#####################################################################################################################
#**
#* Same program as CTL_CCEACC but it is called from a syracuse environment.<br>
#* ALLDIE, CCE, NOL are no longer used and are replaced with the INST instance of a collection that
#* contains DIE and CCE<br>
#* Controls the value of the dimension entered for an account. Also controls the value
#* of the dimension. The dimension can be empty. The account cannot be empty.
#*
#* @param ACTX    Context
#* @param INST    The collection containing the other DIEs and CCEs
#* @param VALCCE  Value of the dimension
#* @param LEDCOD  Ledger code
#* @param DIE     Dimension type that matches the VALCCE dimension
#* @param FCY     Site
#* @param DAT     Date
#* @param ACC     Account of the entry
#* @param TYP     Document type. Can be empty
#* @param COMPANY Company of the document type
#* @param ERRMES  Error message
#*!
Funprog CTL_CCEACCSYRA(ACTX,INST,VALCCE,LEDCOD,DIE,FCY,DAT,ACC,TYP,COMPANY,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance INST Using OBJECT : # The collection containing the other DIEs and CCEs
Variable Char     VALCCE() : # Value of the dimension
Value    Char     LEDCOD() : # Ledger code
Value    Char     DIE()    : # Dimension type that matches the VALCCE dimension
Value    Char     FCY()    : # Site
Value    Date     DAT      : # Date
Value    Char     ACC()    : # Account of the entry
Value    Char     TYP      : # Document type. Can be empty
Value    Char     COMPANY  : # Company of the document type
Variable Char     ERRMES() : # Error message

Local Integer ASTATUS
Local Integer APPCASE : APPCASE = 2 # Application case : control the dimension with the account in a syracuse environment

[L]ASTATUS = func _CTL_CCE(ACTX,INST,APPCASE,VALCCE,LEDCOD,DIE,FCY,DAT,ACC,AVOID.ACHAR,AVOID.ACHAR,AVOID.AINT,TYP,COMPANY,ERRMES)
End [L]ASTATUS


#####################################################################################################################
## _CTL_CCE
#####################################################################################################################
#**
#* Controls the value of the dimension
#*
#* @private
#* @param ACTX    Context
#* @param COL_DIE The collection containing DIE and CCE
#* @param APPCASE Application case
#* @param VALCCE  Value of the dimension
#* @param LEDCOD  Ledger code
#* @param DIE     Dimension type that matches the VALCCE dimension
#* @param FCY     Site
#* @param DAT     Date
#* @param ACC     Account of the entry
#* @param ALLDIE  All the dimension type
#* @param CCE     String to evaluate in order to have the values of the dimensions that matche the DIE in ALLDIE
#* @param NOL     Line in the mask that matches the current line of input
#* @param TYP     Document type. Can be empty
#* @param COMPANY Company of the document type
#* @param ERRMES  Error message
#*!
Funprog _CTL_CCE(ACTX,COL_DIE,APPCASE,VALCCE,LEDCOD,DIE,FCY,DAT,ACC,ALLDIE,CCE,NOL,TYP,COMPANY,ERRMES)
Variable Instance ACTX    Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Instance COL_DIE Using OBJECT : # The collection containing DIE and CCE
Value    Integer  APPCASE      : # Application case
Variable Char     VALCCE()     : # Value of the dimension
Value    Char     LEDCOD()     : # Ledger code
Value    Char     DIE()        : # Dimension type that matches the VALCCE dimension
Value    Char     FCY()        : # Site
Value    Date     DAT          : # Date
Value    Char     ACC()        : # Account of the entry
Value    Char     ALLDIE()(0..): # All the dimension type
Value    Char     CCE          : # String to evaluate in order to have the values of the dimensions that matche the DIE in ALLDIE
Value    Integer  NOL          : # Line in the mask that matches the current line of input
Value    Char     TYP()        : # Document type. Can be empty
Value    Char     COMPANY()    : # Company of the document type
Variable Char     ERRMES()     : # Error message

Local Integer ASTATUS
Local Integer ILED               : # Index to search
Local Integer IDIE               : # Index of the dimension type [L]DIE in the ledger
Local Integer CPYDIE             : # Index of the dimension type [L]DIE in the company
Local Integer GACDIE             : # Index of the dimension type [L]DIE in the account. Indicates if the account is tracked on DIE
Local Char    LEDCOA(GLONCOA)    : # Chart of account of [L]ACC
Local Integer LEDDIENBR          : # Number of dimension in the ledger
Local Integer LEDDIEOBY          : # Indicates if a dimension is required on the ledger
Local Integer CARRYFRW           : # Indicates if the document type is a carry forward entry
Local Char    VALOTHCCE(GLONCCE) : # Value of the other dimension stored in CCE
Local Integer I, J, K, OK

[L]ASTATUS  = [V]CST_AOK
[L]CARRYFRW = [V]CST_AFALSE

If APPCASE<3 & ACC=""    : End [L]ASTATUS : Endif
If APPCASE=3 & VALCCE="" : End [L]ASTATUS : Endif

If adxtyp=33 | !clalev([F:CCE])   : Local File =ACTX.ACPT.TABCPT+"CACCE"    [CCE]  : Endif
If APPCASE<3
 If adxtyp=33 | !clalev([F:CPY])  : Local File COMPANY    [CPY] : Endif
 If adxtyp=33 | !clalev([F:GTE])  : Local File GTYPACCENT [GTE] : Endif
 If adxtyp=33 | !clalev([F:CAZ])  : Local File =ACTX.ACPT.TABCPT+"CAAUZ"    [CAZ]  : Endif
 If adxtyp=33 | !clalev([F:GAC])  : Local File =ACTX.ACPT.TABCPT+"GACCOUNT" [GAC]  : Endif
 If adxtyp=33 | !clalev([F:CCE2]) : Local File =ACTX.ACPT.TABCPT+"CACCE"    [CCE2] : Endif
Endif

If VALCCE<>""
 #--- Checks that the dimension exists
 Call LEC_CCE(VALCCE,DIE) From CPTLEC
 If fstat
  [L]ASTATUS = [V]CST_AERROR
  ERRMES = VALCCE-mess(35,106,1) : End [L]ASTATUS
 Endif
 #--- Checks that the dimension is chargeable
 If [F:CCE]IPT<>2
  [L]ASTATUS = [V]CST_AERROR
  ERRMES = VALCCE-mess(24,106,1) : End [L]ASTATUS
 Endif
 #--- Checks that the dimension is active
 If [F:CCE]ENAFLG<>2
  [L]ASTATUS = [V]CST_AERROR
  ERRMES = VALCCE-mess(7,103,1)  : End [L]ASTATUS
 Endif
Endif

If APPCASE<3
 Call LEC_CPY([L]COMPANY) From CPTLEC
 #--- Control exclusively for carry forward entries
 #--- Checks if the document type (GTE) is reserved to carry formard entries. In that case, some controls are not required
 If !fstat & [L]TYP<>""
  Call LEC_GTE_LEG([F:CPY]LEG,[L]TYP) From CPTLEC
  If !fstat & [F:GTE]PER=2 : [L]CARRYFRW = [V]CST_ATRUE : Endif
 Endif

 If [L]LEDCOD<>""
  #--- Checks that the dimension type is managed by the ledger
  ILED = fmet ACTX.ACACHE.LED.AGETINDEX([L]LEDCOD)
  If ILED=[V]CST_ANOTDEFINED | [L]DIE="" : End [L]ASTATUS : Endif
  LEDCOA    = fmet ACTX.ACACHE.LED.AGETVALCHAR([L]LEDCOD,"LEDCOA")
  LEDDIENBR = fmet ACTX.ACACHE.LED.AGETVALNUM([L]LEDCOD,"LEDDIENBR")
  LEDDIEOBY = fmet ACTX.ACACHE.LED.AGETVALNUM([L]LEDCOD,"LEDDIEOBY")
  For IDIE=1 To LEDDIENBR
   If [L]DIE = fmet ACTX.ACACHE.LED.AGETVALCHAR([L]LEDCOD,"DIE"+num$(IDIE))
    Break
   Endif
  Next
  If IDIE>LEDDIENBR : End [L]ASTATUS : Endif

  #--- Does the account is tracked on the dimension type [L]die ?
  Call LEC_GAC([L]ACC,LEDCOA) From CPTLEC
  If !fstat
   GACDIE = find([L]DIE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
  Endif

  #--- Checks if the dimension type is mandatory for the company
  CPYDIE = find([L]DIE,[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
  If VALCCE="" & GACDIE & CPYDIE & [F:CPY]OBYDIE(CPYDIE-1)=[V]CST_AYES & ![L]CARRYFRW
   [L]ASTATUS = [V]CST_AERROR
   ERRMES = [L]ACC-"("+LEDCOA+")"-mess(46,106,1)-[L]DIE : End [L]ASTATUS
  Endif

  #--- Checks that one dimension type at least is populated if a dimension is required in the ledger
  #--- and the account is has dimension type
  If VALCCE="" & LEDDIEOBY=[V]CST_AYES & [F:GAC]DACDIENBR>0 & ![L]CARRYFRW
   OK = 0
   For I=IDIE+1 To LEDDIENBR
    If find(fmet ACTX.ACACHE.LED.AGETVALCHAR([L]LEDCOD,"DIE"+num$(I)),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
     OK = 1 : Break
    Endif
   Next I
   If !OK : # It is the last dimension type
    OK = 0
    If APPCASE=2
     For I=1 To IDIE-1
      For J=1 To maxtab(COL_DIE)
       If COL_DIE(J)<>null & COL_DIE(J).DIE=fmet ACTX.ACACHE.LED.AGETVALCHAR([L]LEDCOD,"DIE"+num$(I))
&                          & COL_DIE(J).CCE<>AVOID.ACHAR
&                          & !find(COL_DIE(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
        OK = 1 : Break 2
       Endif
      Next
     Next
    Else
     For I=1 To IDIE-1
      J = find(fmet ACTX.ACACHE.LED.AGETVALCHAR([L]LEDCOD,"DIE"+num$(I)),[L]ALLDIE(0..dim([L]ALLDIE)-1))
      If J=0 : OK = 1 : Break : Endif
      K = instr(1,[L]CCE,"#")
      If K
       VALOTHCCE = evalue(left$([L]CCE,K-1)+num$(J)+"("+num$(NOL)+")")
      Else
       VALOTHCCE  = evalue([L]CCE+"("+num$(J-1)+")")
      Endif
      If VALOTHCCE <>"" : OK = 1 : Break : Endif
     Next
    Endif
    If !OK
     [L]ASTATUS = [V]CST_AERROR
     ERRMES = [L]ACC-"("+LEDCOA+")"-mess(98,106,1) : End [L]ASTATUS
    Endif
   Endif
  Endif

 Endif
Endif

If APPCASE<3 & VALCCE="" : End [L]ASTATUS : Endif

#--- Checks that the dimension is compatible with the site/company
If [L]FCY<>""
 [L]ASTATUS = func CDACFY_SYRA.CTL_SITE(ACTX,[F:CCE]FCY,[L]FCY,VALCCE,ERRMES)
 If [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS : Endif
Endif
#--- Checks the access code of the dimension
[L]ASTATUS = func FINMIS_SYRA.CTL_EXE(ACTX,[F:CCE]ACS,ERRMES)
If [L]ASTATUS = [V]CST_AERROR
 ERRMES = VALCCE-ERRMES : End [L]ASTATUS
Endif
#--- Checks the period during which the dimension can be used
[L]ASTATUS = func FINMIS_SYRA.CTL_VLYDAT(ACTX,[L]DAT,[F:CCE]VLYSTR,[F:CCE]VLYEND,ERRMES)
If [L]ASTATUS = [V]CST_AERROR
 ERRMES = VALCCE-ERRMES : End [L]ASTATUS
Endif

If APPCASE<3
 #--- Checks the Account/Dimension restriction code
 If [F:GAC]AUZ<>"" & [F:CCE]AUZ<>""
  Look [CAZ]CAZ0 = 2 ; [F:GAC]AUZ ; [F:CCE]AUZ
  If !fstat
   ERRMES = VALCCE-mess(27,106,1)-[L]ACC-"("+LEDCOA+")"
   [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
  Endif
 Endif

 #--- Checks the Dimension/Dimension restriction code
 If [F:CCE]AUZ<>""
  If APPCASE=2
   For J=1 To maxtab(COL_DIE)
    If COL_DIE(J)<>null & [L]DIE<>COL_DIE(J).DIE
&                       & COL_DIE(J).CCE<>AVOID.ACHAR
&                       & !find(COL_DIE(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
     Read [CCE2]CCE0 = COL_DIE(J).DIE ; COL_DIE(J).CCE
     If !fstat & [F:CCE2]AUZ<>""
      Look [CAZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
      If !fstat
       ERRMES = VALCCE-mess(26,106,1)-[F:CCE2]CCE
       [L]ASTATUS = [V]CST_AERROR : Break
      Endif
     Endif
    Endif
   Next
  Else
   For I=1 To dim([L]ALLDIE)
    If [L]DIE<>[L]ALLDIE(I-1)
     K = instr(1,[L]CCE,"#")
     If K
      VALOTHCCE  = evalue(left$([L]CCE,K-1)+num$(I)+"("+num$(NOL)+")")
     Else
      VALOTHCCE  = evalue([L]CCE+"("+num$(I-1)+")")
     Endif
     If VALOTHCCE <>"" : # dimension empty => no restriction
      Read [CCE2]CCE0 = [L]ALLDIE(I-1) ; VALOTHCCE
      If !fstat & [F:CCE2]AUZ<>""
       Look [CAZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
       If !fstat
        ERRMES = VALCCE-mess(26,106,1)-[F:CCE2]CCE
        [L]ASTATUS = [V]CST_AERROR : Break
       Endif
      Endif
     Endif
    Endif
   Next
  Endif
  If  [L]ASTATUS=[V]CST_AERROR : End [L]ASTATUS : Endif
 Endif
Endif
End [L]ASTATUS
#####################################################################################################################
## CRE_CCE
#####################################################################################################################
#**
#* Function that create Automaticly or modify analytical dimensions
#*
#* @param ACTX       Context
#* @param OPETYP     Operation type : C(reation) / U(pdate)
#* @param DIE        Dimension type that matches the CCE dimension
#* @param CCE        Dimension
#* @param CODFLD()   Table of dimension fields
#* @param VALFLD()   Table of fields values
#* @param ERRMES  Error message
#*!
Funprog CRE_CCE(ACTX,OPETYP,DIE,CCE,CODFLD,VALFLD,ERRMES)
Variable Instance ACTX    Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     OPETYP()      : # Operation type : C(reation) / U(pdate)
Value    Char     DIE()         : # Dimension type that matches the CCE dimension
Value    Char     CCE()         : # Value of the dimension
Value    Char     CODFLD()(1..) : # Fields
Value    Char     VALFLD()(1..) : # Values
Variable Char     ERRMES()      : # Error message

Local Integer     ASTATUS       : [L]ASTATUS = [V]CST_AOK
Local Char        DIEFMT(15)    : # Dimension Types Formats
Local Char        WCCE(GLONCCE)
Local Integer     I
Local Integer     NIV
Local Integer     SAVELIG

# Rq: In Syracuse mode (adxtyp=33)
If adxtyp=33 | !clalev([F:CCE])   :  Local File =ACTX.ACPT.TABCPT+"CACCE" [CCE]  : Endif
If adxtyp=33 | !clalev([F:CCE2])  :  Local File =ACTX.ACPT.TABCPT+"CACCE" [CCE2] : Endif
If adxtyp=33 | !clalev([F:CYP])   :  Local File =ACTX.ACPT.TABCPT+"GCCEPYMPRT" [CYP] : Endif

If DIE="" or CCE=""
  If OPETYP= "C"
    ERRMES = mess(7,123,1)+ "\"  # Création impossible
  Else
    ERRMES = mess(9,123,1)+ "\"  # Modification impossible
  Endif
  If CCE=  ""
   # Section : Valeur non définie
   ERRMES +=  "\"-mess(17,103,1)-" : "-mess(141,143,1)
  Endif  #Section : Valeur non définie
  If DIE= ""
   # Axe : Valeur non définie
   ERRMES += "\"-mess(2,103,1)-" : "-mess(141,143,1)
  Endif
  [L]ASTATUS = [V]CST_AERROR
  End [L]ASTATUS
Endif

If adxlog # transaction en cours
  Gosub CRE_UPD_CCE
Else
  Trbegin [CCE]
  Gosub CRE_UPD_CCE
  If [L]ASTATUS<>[V]CST_AOK
    Rollback
    End [L]ASTATUS
  Else
    Commit
    [L]ASTATUS = fmet ACTX.ASETERROR("","CCE created"-[F:CCE]CCE-[F:CCE]DES,[V]CST_AINFO)
  Endif
Endif

End [L]ASTATUS

#---
$CRE_UPD_CCE

If OPETYP="C"
  #--- Creation ==> Check that the dimension do not exists
  Call LEC_CCE(CCE,DIE) From CPTLEC
  If !fstat
    # Section déjà existante
     ERRMES = CCE-":"-mess(22,100,1)
     [L]ASTATUS = [V]CST_AERROR : Return
  Endif
  Raz [F:CCE]
Else
  #--- Update ==> Check that the dimension exists
  Call LEC_CCE(CCE,DIE) From CPTLEC
  If fstat
    # Section inexistante
    ERRMES = CCE-":"-mess(35,106,1)
    [L]ASTATUS = [V]CST_AERROR : Return
  Endif
Endif

If [L]ASTATUS = [V]CST_AERROR : Return : Endif

WCCE = CCE
[L]ASTATUS = func FINCCE_SYRA.GET_DIEFMT(ACTX,DIE,DIEFMT,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR
  Return
Endif
WCCE = vireblc(format$(DIEFMT,CCE),2)
If WCCE = AVOID.ACHAR or len(WCCE)<len(CCE)
  ERRMES = mess(120,103,1)-":"-mess(117,103,1)
  [L]ASTATUS = [V]CST_AWARNING
  Return
Endif

[F:CCE]DIE = DIE
[F:CCE]CCE = WCCE
SAVELIG = nolign

For I=1 To dim(CODFLD)
  If CODFLD(I)<>"" & VALFLD(I)<>""
    If evalue("dim([F:CCE]"+CODFLD(I)+")")>0
      Case evalue("type([F:CCE]"+CODFLD(I)+")")
        When 1         : Assign "[F:CCE]"+CODFLD(I) With max(1,val(VALFLD(I)))
        When 2,4,5,6,7 : Assign "[F:CCE]"+CODFLD(I) With val(VALFLD(I))
        When 3         : Assign "[F:CCE]"+CODFLD(I) With VALFLD(I)
        When Default   : Assign "[F:CCE]"+CODFLD(I) With VALFLD(I)
      Endcase
      # Control of the "Other dimension type"
      If instr(1,CODFLD(I),"OTHDIE")>0
        If VALFLD(I)=[F:CCE]DIE
          # Incorrect value
          ERRMES = "OTHDIE :"-[F:CCE]OTHDIE+" :"-mess(83,123,1)
          [L]ASTATUS = [V]CST_AERROR : Break
        Endif
        nolign = val(left$( right$(CODFLD(I),5) , len(right$(CODFLD(I),5))-1))+1
        Call UNICITE(VALFLD(I),[F:CCE]OTHDIE(0..[F:CCE]DIENBR-1)) From OBJDIV
        If mkstat
          ERRMES=GMESSAGE
          [L]ASTATUS = [V]CST_AERROR : Break
        Endif
      Endif
      # Control of the "Unit"
      If instr(1,CODFLD(I),"UOM")>0
        nolign = val(left$( right$(CODFLD(I),5) , len(right$(CODFLD(I),5))-1))+1
        Call UNICITE(VALFLD(I),[F:CCE]UOM (0..[F:CCE]UOMNBR-1)) From OBJDIV
        If mkstat
          ERRMES=GMESSAGE
          [L]ASTATUS = [V]CST_AERROR : Break
        Endif
      Endif
    Endif
  Endif
Next
nolign = SAVELIG
If [L]ASTATUS = [V]CST_AERROR : Return : Endif

# If a DIE is added control of the "Default Dimension"
For I=0 To dim([F:CCE]OTHDIE)-1
 If [F:CCE]OTHDIE(I)="" : Break : Endif
 Read [CCE2]CCE0 = [F:CCE]OTHDIE(I);[F:CCE]DEFCCE(I)
 If !fstat
  Call COMPAT([F:CCE]FCY,[F:CCE2]FCY,[F:CCE]DEFCCE(I)) From CFYSUB
  If mkstat
   ERRMES=GMESSAGE
   [L]ASTATUS = [V]CST_AERROR : Break
  Endif
 Else
  ERRMES=[F:CCE]DEFCCE(I)-":"-mess(35,106,1)
  [L]ASTATUS = [V]CST_AERROR : Break
 Endif
Next

If [L]ASTATUS = [V]CST_AERROR : Return : Endif

Call MAJTEXTRALAN(ACTX,[F:CCE]DES,"CACCE","DESTRA",ACTX.LAN,[F:CCE]DIE,[F:CCE]CCE,[L]ASTATUS) From ASYRSUB
Call MAJTEXTRALAN(ACTX,[F:CCE]DESSHO,"CACCE","SHOTRA",ACTX.LAN,[F:CCE]DIE,[F:CCE]CCE,[L]ASTATUS) From ASYRSUB
If [L]ASTATUS = [V]CST_AERROR : Return : Endif

If OPETYP="C"
  # Creation empty pyramid link
  [F:CYP]DIE = DIE
  [F:CYP]PYM = ""
  [F:CYP]CCE = CCE
  [F:CYP]LEV = 1
  [F:CYP]LIE = 1
  For NIV=1 To dim([F:CYP]GRU)
    [F:CYP]GRU(NIV-1) = "zzzzz"
  Next NIV
  Write [CYP]
  If fstat<>[V]CST_AOK
    Call FSTA("CYP",0,ERRMES) From GLOCK_SYRA
    [L]ASTATUS = [V]CST_AERROR : Return
  Endif
  # For Crystal Reports
  Call MAJTEXTRALAN(ACTX,"","GCCEGRUPYM","DESTRA",ACTX.LAN,"","zzzzz",[L]ASTATUS) From ASYRSUB
  If [L]ASTATUS = [V]CST_AERROR : Return : Endif
Endif

# Creation of a dimension
If OPETYP="C"
 [F:CCE]CREDAT = date$
 [F:CCE]CREUSR = GUSER
  Write [CCE]
  If fstat<>[V]CST_AOK
    Call FSTA("CCE",0,ERRMES) From GLOCK_SYRA
    [L]ASTATUS = [V]CST_AERROR : Return
  Endif
Else
  # Update of a dimension
  [F:CCE]UPDDAT = date$
  [F:CCE]UPDUSR = GUSER
  Rewrite [CCE]
  If fstat<>[V]CST_AOK
    Call FSTA("CCE",0,ERRMES) From GLOCK_SYRA
    [L]ASTATUS = [V]CST_AERROR : Return
  Endif
Endif

Return

