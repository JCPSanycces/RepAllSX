#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UTIACH2    Utilitaire de récupération du bug écart taxe   Module ACHAT #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#  Pour certaines factures les montants de taxe ne sont pas équilibrés ? #
#  ou plutôt le type d'achat est nul à cause du transclasse et ceci      #
#  empêche de valider les factures en comptabilité                       #
#                                                                        #
# Ce traitement corrige tous les types d'achats à 0 en les passant à 1   #
# Table PINVOICE  champs PURTYP(0-9)                                     #
# Table PINVOICED champ  LINPURTYP                                       #
##########################################################################

Call MAJ_UTIACH2
End


Subprog MAJ_UTIACH2
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>"" Call EXE_UTIACH2(DOSSIER) : Endif
End


Subprog EXE_UTIACH2(DOSSIER)
Value Char DOSSIER
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIACH2 : Utilitaire de rattrapage des types d'achat") From LECFIC
Call ECR_TRACE("UTIACH2 : Début traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:PIH]) =0  Local File =DOSSIER+".PINVOICE"    [PIH] : Endif 
If clalev([F:PID]) =0  Local File =DOSSIER+".PINVOICED"   [PID] : Endif 
#----- Variables locales -----#
Local Char     WNUM(GLONPIH), WMESSAGE(80)
Local Integer  WPIDLIN
Local Shortint WINDIC, I
#-----
For [PIH] Where ORIMOD=6 & STA<3
  If find(0,[F:PIH]PURTYP(0..[F:PIH]NBRTAX-1))
    Call DEBTRANS From GLOCK
$TR_UTIACH2
    GOK=1  
    Trbegin [PIH]
      WNUM=[F:PIH]NUM
      Readlock [PIH] PIH0=WNUM
      If fstat=1
        GOK=-1 : GLOCK="$PINVOICE"-WNUM
        Goto ROLL_UTIACH2
      Elsif fstat
        GOK=0  : Call RSTA("PIH",WNUM) From GLOCK
        Goto AB_UTIACH2
      Endif
      For I=0 To [F:PIH]NBRTAX-1
        If [F:PIH]PURTYP(I)=0 [F:PIH]PURTYP(I)=1 : Endif
      Next I
      Rewrite [PIH]
      If fstat
        GOK=0 : Call FSTA("PIH") From GLOCK
        Call ECR_TRACE("Erreur="+num$(fstat)+" sur facture "+[F:PIH]NUM,1) From GESECRAN
        Goto AB_UTIACH2
      Else
        Gosub TRAITEMENT_LIGNE
        If GOK=-1 Goto ROLL_UTIACH2 : Endif
        If GOK=0  Goto AB_UTIACH2   : Endif
        Call ECR_TRACE("Facture "+[F:PIH]NUM+" traitée",0) From GESECRAN
      Endif
    Commit
  Endif
$SUITE_UTIACH2
Next
#----- Fin du traitement -----#
$FIN_UTIACH2
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End

$ROLL_UTIACH2
Rollback : Call ROLL From GLOCK
If GROLL
  Call ECR_TRACE("Facture "+WNUM+" non traitée !",1) From GESECRAN
  Goto SUITE_UTIACH2
Else
  Goto TR_UTIACH2
Endif

$AB_UTIACH2
Rollback
Call ECR_TRACE("Facture "+WNUM+" non traitée !",1) From GESECRAN
Goto SUITE_UTIACH2


#----------------------------------#
# Traitement des lignes de facture #
#----------------------------------#
$TRAITEMENT_LIGNE
For [PID] PID0 Where NUM=WNUM
  If [F:PID]LINPURTYP=0
    WPIDLIN=[F:PID]PIDLIN
    Update [PID] Where NUM=WNUM & PIDLIN=WPIDLIN With LINPURTYP=1
    If fstat
      GOK=0 : Call FSTA("PID") From GLOCK
      WMESSAGE="Erreur="+num$(fstat)+" sur ligne facture "+WNUM-num$(WPIDLIN)
      Call ECR_TRACE(WMESSAGE,1) From GESECRAN
    Endif
  Endif
Next
Return
