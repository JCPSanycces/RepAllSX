#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################
# UTITC60                                                  Common data module                          #
# Wrong ATEXTRA migration for TABSIVTYP, TABPIVTYP and TABPAYTERM                                      #
########################################################################################################

Local Char APPLI(30) : APPLI = nomap
# Issue 108760 - 2015-08-07 by MAE :
#Call SAIDOS(DOSSIER,"") From SAIDOS
Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
If APPLI <> ""
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 # Issue 108760 - 2015-08-07 by MAE :
 #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
 If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTITC60: ATEXTRA correction for TPV/TSV/TPT - Fq 98885") From LECFIC
 Call MAJ_UTITC60(APPLI)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

########################################################################
Subprog MAJ_UTITC60(APPLI)
Value Char APPLI

Local Integer IFOUND

  If filinfo(filpath("FIL", "ATEXTRA", "fde", APPLI), 0) <= 0 Then
    # Si la table n'est pas là, on ne fait rien
    End
  Endif
  #
  Call ECR_TRACE("UUTITC60: Process Start on: "+APPLI,0) From GESECRAN
  Gosub CHECK_MISSING_RECORD
  Call ECR_TRACE("UUTITC60: Process End on: "+APPLI,0) From GESECRAN
End

$AB_UUTITC60
  Rollback
End

########################################################################
# For an automatic execution in patch integration                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ATEXTRA") : End : Endif
  # test de présence du module Tiers
  Call MAJ_UTITC60(APPLI)
End

########################################################################
# For an execution from DOSMAJ (folder validation)                     #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ATEXTRA") : End : Endif
  Call MAJ_UTITC60(APPLI)
End


#----------------------------------------------------------------------------------
# List of table and fields to check and fix.
#----------------------------------------------------------------------------------
$LIST_TAB_FIELD
  LATB(1)  = "TABPIVTYP"
  LATB(2)  = "TABSIVTYP"
  LATB(3)  = "TABPAYTERM"

  LZONE(1) = "DESAXX"
  LZONE(2) = "SHOAXX"
Return

#----------------------------------------------------------------------------------
# ATEXTRA Correction process
#----------------------------------------------------------------------------------
$CHECK_MISSING_RECORD
  Local Integer LSIMU
  Local Integer LDETTRA
  Local Char    LFOLDER
  Local Char    LATB(GLONATB)(1..)
  Local Char    LZONE(15)(1..)
  Local Integer I_ATB
  Local Integer I_FLD

  # Init variables
  # --------------

  LFOLDER  = APPLI
  Gosub LIST_TAB_FIELD

  # Exec process
  # ------------

  For I_ATB=1 To maxtab(LATB)
   For I_FLD=1 To maxtab(LZONE)
    Call UNIT_CHECK(LFOLDER,LATB(I_ATB),LZONE(I_FLD),G_NON, G_NON)
   Next I_FLD
  Next I_ATB

Return

#----------------------------------------------------------------------------------
# PFOLDER Folder processed
# PATB          Table processed
# PFIELD        Field processed
# PDETTRA       Detailed trace yes/no
# PSIMU         Simulation mode yes/no
#----------------------------------------------------------------------------------
Subprog UNIT_CHECK(PFOLDER,PATB,PFIELD,PDETTRA,PSIMU)
Value Char    PFOLDER
Value Char    PATB
Value Char    PFIELD
Value Integer PDETTRA
Value Integer PSIMU

  Local Integer LNBTRTREC
  Local Integer LNBDELREC
  Local Integer LNBUPDREC
  Local Integer LNBKEPREC
  Local Integer LNBNOREC

  If !clalev([F:AXX1]) : Local File =PFOLDER+".ATEXTRA" [AXX1] : Endif
  If !clalev([F:AXX2]) : Local File =PFOLDER+".ATEXTRA" [AXX2] : Endif
  If !clalev([F:XOBJ]) : Local File =PFOLDER+"."+PATB   [XOBJ] : Endif

  Call ECR_TRACE("\TABLE /"-PATB-"FIELD /"-PFIELD-" ==> CHECK ATEXTRA records",0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN

  Filter [F:AXX1] Where CODFIC=PATB & ZONE=PFIELD Order By IDENT1 Asc;LANGUE Asc
  For [F:AXX1]

   Case PATB
    When "TABPIVTYP" : Read [F:XOBJ]TPV0=[F:AXX1]IDENT1;[F:AXX1]IDENT2
    When "TABSIVTYP" : Read [F:XOBJ]TSV0=[F:AXX1]IDENT1;[F:AXX1]IDENT2
    When "TABPAYTERM": Read [F:XOBJ]TPT0=[F:AXX1]IDENT1;[F:AXX1]IDENT2
    When Default
   Endcase

   If fstat=5
    LNBTRTREC+=1
    If !adxlog
  Trbegin [F:AXX1], [F:AXX2]
  Local Integer LTRS
    Endif
    GOK=1
    If PDETTRA=G_OUI
     Call ECR_TRACE([F:AXX1]CODFIC-"/"-[F:AXX1]ZONE-"/"-[F:AXX1]LANGUE-"/"-[F:AXX1]IDENT1-"/"-[F:AXX1]IDENT2-"/"-[F:AXX1]TEXTE,1) From GESECRAN
    Endif
    # Looking for the "normal" record
    #--------------------------------
    Filter [F:AXX2] Where CODFIC=PATB & ZONE=PFIELD & IDENT1=[F:AXX1]IDENT1 & LANGUE=[F:AXX1]LANGUE & IDENT2<>[F:AXX1]IDENT2
    Local Integer LNBENR
    For [F:AXX2]
     LNBENR+=1
     If PDETTRA=G_OUI
      Call ECR_TRACE(space$(3)+"---> Corresponding record"-[F:AXX2]CODFIC-"/"-[F:AXX2]ZONE-"/"-[F:AXX2]LANGUE-"/"-[F:AXX2]IDENT1-"/"-[F:AXX2]IDENT2-"/"-[F:AXX2]TEXTE,0) From GESECRAN
     Endif
     If [F:AXX1]TEXTE<>"" & [F:AXX1]TEXTE<>[F:AXX2]TEXTE
      If [F:AXX2]TEXTE="" | [F:AXX2]TEXTE=func APLSTD.TEXMEN(PFOLDER,187,174,[F:AXX2]LANGUE)
       If PDETTRA=G_OUI
        Call ECR_TRACE(space$(6)+"o"-"Replacing text '"+[F:AXX2]TEXTE+"'"-"by"-"'"+[F:AXX1]TEXTE+"'",0) From GESECRAN
       Endif
       # Record update
       #--------------
       [F:AXX2]TEXTE=[F:AXX1]TEXTE
       Rewrite [F:AXX2]
       If fstat
        Call ECR_TRACE([F:AXX2]CODFIC-"/"-[F:AXX2]ZONE-"/"-[F:AXX2]IDENT1-"/"-[F:AXX2]IDENT2-"/"-[F:AXX2]LANGUE-"fstat="-num$(fstat),1) From GESECRAN
        GOK=0
       Else
        LNBUPDREC+=1
       Endif
      Else
       If PDETTRA=G_OUI
        Call ECR_TRACE(space$(6)+"o"-"Keeping text '"+[F:AXX2]TEXTE+"'",0) From GESECRAN
       Endif
       LNBKEPREC+=1
      Endif
     Else
      If PDETTRA=G_OUI
       Call ECR_TRACE(space$(6)+"o"-"Keeping text '"+[F:AXX2]TEXTE+"'",0) From GESECRAN
      Endif
      LNBKEPREC+=1
     Endif
    Next
    If !LNBENR
     LNBNOREC+=1
     If PDETTRA=G_OUI
      Call ECR_TRACE(space$(3)+"---> Corresponding enreg not found",0) From GESECRAN
     Endif
    Endif
    If PDETTRA=G_OUI
     Call ECR_TRACE(space$(6)+"o"-"Deleting the record"-[F:AXX1]CODFIC-"/"-[F:AXX1]ZONE-"/"-[F:AXX1]LANGUE-"/"-[F:AXX1]IDENT1-"/"-[F:AXX1]IDENT2-"/"-[F:AXX1]TEXTE,0) From GESECRAN
     Call ECR_TRACE("",0) From GESECRAN
    Endif
    # Record deletion
    #----------------
    Delete [F:AXX1] Curr
    If fstat
     Call ECR_TRACE([F:AXX1]CODFIC-"/"-[F:AXX1]ZONE-"/"-[F:AXX1]IDENT1-"/"-[F:AXX1]IDENT2-"/"-[F:AXX1]LANGUE-"fstat="-num$(fstat),1) From GESECRAN
     GOK=0
    Else
     LNBDELREC+=1
    Endif
    Filter [F:AXX2]
    # Fin transaction de mise à jour
    #-------------------------------
    If dim(LTRS)>0
     If GOK<>1 | (GOK=1 & PSIMU=G_OUI)
      Rollback
     Else
      Commit
     Endif
Kill LTRS
    Endif
   Endif
  Next
  Call ECR_TRACE("Nbr processed records    "+num$(LNBTRTREC),0) From GESECRAN
  Call ECR_TRACE("Nbr orphan records       "+num$(LNBNOREC),0)  From GESECRAN
  Call ECR_TRACE("Nbr modified records     "+num$(LNBUPDREC),0) From GESECRAN
  Call ECR_TRACE("Nbr unchanged records    "+num$(LNBKEPREC),0) From GESECRAN
  Call ECR_TRACE("Nbr deleted records      "+num$(LNBDELREC),0) From GESECRAN
End

