#<AdxTL>@(#)7.0.0.0 $Revision$
# ------------------------------------------------------------
# Sources htm utilisés par SUBAPSPAGE
#    Serveur de page du portail
#        Voir menu  2913
#
#   Version 0001
# ------------------------------------------------------------
$SET_HTML
PW_I=[F:APS]APSPRE    # menu 2913

If PW_I=1  # 1 cadre
    Local Integer P_SRCNB : P_SRCNB=11
    Local Char P_SRC(250)(0..P_SRCNB)
    Gosub $HTML_DEB     # Debut page
    
    P_SRC(07)='<!-- TEMPLATE PORTAIL X3  -->'
    P_SRC(08)=' <FRAMESET COLS="100%" , ROWS="100%" >'
    P_SRC(09)='  <FRAME $*FRAME1 >'
    P_SRC(10)=' </FRAMESET>'
    P_SRC(11)='</HTML>'
    Return
Endif

If PW_I=2  # 4 identiques
    Local Integer P_SRCNB : P_SRCNB=14
    Local Char P_SRC(250)(0..P_SRCNB)
    Gosub $HTML_DEB     # Debut page
    
    P_SRC(07)='<!-- TEMPLATE PORTAIL X3  -->'
    P_SRC(08)=' <FRAMESET COLS="50%,*" , ROWS="50%,*" >'
    P_SRC(09)='  <FRAME $*FRAME1 >'
    P_SRC(10)='  <FRAME $*FRAME2 >'
    P_SRC(11)='  <FRAME $*FRAME3 >'
    P_SRC(12)='  <FRAME $*FRAME4 >'
    P_SRC(13)=' </FRAMESET>'
    P_SRC(14)='</HTML>'
    Return
Endif

If PW_I=3  # 2 verticaux
    Local Integer P_SRCNB : P_SRCNB=12
    Local Char P_SRC(250)(0..P_SRCNB)
    Gosub $HTML_DEB     # Debut page
    
    P_SRC(07)='<!-- TEMPLATE PORTAIL X3  -->'
    P_SRC(08)=' <FRAMESET COLS="50%,*" >'
    P_SRC(09)='  <FRAME $*FRAME1 >'
    P_SRC(10)='  <FRAME $*FRAME2 >'
    P_SRC(11)=' </FRAMESET>'
    P_SRC(12)='</HTML>'
    Return
Endif

If PW_I=4  # 2 horizontaux
    Local Integer P_SRCNB : P_SRCNB=12
    Local Char P_SRC(250)(0..P_SRCNB)
    Gosub $HTML_DEB     # Debut page
    
    P_SRC(07)='<!-- TEMPLATE PORTAIL X3  -->'
    P_SRC(08)=' <FRAMESET ROWS="50%,*" >'
    P_SRC(09)='  <FRAME $*FRAME1 >'
    P_SRC(10)='  <FRAME $*FRAME2 >'
    P_SRC(11)=' </FRAMESET>'
    P_SRC(12)='</HTML>'
    Return
Endif

If PW_I=5  # 1+2 : horizontaux
    Local Integer P_SRCNB : P_SRCNB=15
    Local Char P_SRC(250)(0..P_SRCNB)
    Gosub $HTML_DEB     # Debut page
    
    P_SRC(07)='<!-- TEMPLATE PORTAIL X3  -->'
    P_SRC(08)=' <FRAMESET ROWS="50%,*" >'
    P_SRC(09)='  <FRAME $*FRAME1 >'
    P_SRC(10)='  <FRAMESET COLS="50%,*" >'
    P_SRC(11)='   <FRAME $*FRAME2 >'
    P_SRC(12)='   <FRAME $*FRAME3 >'
    P_SRC(13)='  </FRAMESET>'
    P_SRC(14)=' </FRAMESET>'
    P_SRC(15)='</HTML>'
    Return
Endif

If PW_I=6  # 2+1 : horizontaux
    Local Integer P_SRCNB : P_SRCNB=15
    Local Char P_SRC(250)(0..P_SRCNB)
    Gosub $HTML_DEB     # Debut page
    
    P_SRC(07)='<!-- TEMPLATE PORTAIL X3  -->'
    P_SRC(08)=' <FRAMESET ROWS="50%,*" >'
    P_SRC(09)='  <FRAMESET COLS="50%,*" >'
    P_SRC(10)='   <FRAME $*FRAME1 >'
    P_SRC(11)='   <FRAME $*FRAME2 >'
    P_SRC(12)='  </FRAMESET>'
    P_SRC(13)='  <FRAME $*FRAME3 >'
    P_SRC(14)=' </FRAMESET>'
    P_SRC(15)='</HTML>'
    Return
Endif

If PW_I=7  # 1+2: verticaux
    Local Integer P_SRCNB : P_SRCNB=15
    Local Char P_SRC(250)(0..P_SRCNB)
    Gosub $HTML_DEB     # Debut page
    
    P_SRC(07)='<!-- TEMPLATE PORTAIL X3  -->'
    P_SRC(08)=' <FRAMESET COLS="50%,*" >'
    P_SRC(09)='  <FRAME $*FRAME1 >'
    P_SRC(10)='  <FRAMESET ROWS="50%,*" >'
    P_SRC(11)='   <FRAME $*FRAME2 >'
    P_SRC(12)='   <FRAME $*FRAME3 >'
    P_SRC(13)='  </FRAMESET>'
    P_SRC(14)=' </FRAMESET>'
    P_SRC(15)='</HTML>'
    Return
Endif

If PW_I=8  # 2+1: verticaux
    Local Integer P_SRCNB : P_SRCNB=15
    Local Char P_SRC(250)(0..P_SRCNB)
    Gosub $HTML_DEB     # Debut page
    
    P_SRC(07)='<!-- TEMPLATE PORTAIL X3  -->'
    P_SRC(08)=' <FRAMESET COLS="50%,*" >'
    P_SRC(09)='  <FRAMESET ROWS="50%,*" >'
    P_SRC(10)='   <FRAME $*FRAME1 >'
    P_SRC(11)='   <FRAME $*FRAME2 >'
    P_SRC(12)='  </FRAMESET>'
    P_SRC(13)='  <FRAME $*FRAME3 >'
    P_SRC(14)=' </FRAMESET>'
    P_SRC(15)='</HTML>'
    Return
Endif

# Erreur
U_MESCODE="X3HTMLNOTFOUND" : U_MESP1=num$(PW_I) : U_MESP2=mess(PW_I,2913,1) : U_ERR=UC_ERRG : Gosub U_MESPUT  From SUBAPSUTI
Return



# - - - - - - - - - - - - - - - - - - - - - - - - -
$HTML_DEB
P_SRC(00)='<HTML>'
P_SRC(01)='<HEAD> <!-- $*HEADCMT -->'
P_SRC(02)='<base href=$*HREF_TAGBASE /><!-- Href est mis a jour par le composant HTC -->'
P_SRC(03)='<Link rel="stylesheet" type="text/css" href="./PortalPage/X3PortalPage.css" />'
P_SRC(04)='<TITLE></TITLE>'
P_SRC(05)='<SCRIPT src=".\Ressources\CommonFct.js" ></script>'
P_SRC(06)='</HEAD>'
Return
