#<AdxTL>@(#)0.0.0.0 $Revision$
#
#*********************************************************************
#
#                    GESTION DES MODES D'AMORTISSEMENT
#
#*********************************************************************
#    Création
#    MWA - 20.01.2003
#
#*********************************************************************
#    Modification
#    MWA - 26.10.2017   X3-54580 Wear & Tear Depreciation
#    MWA - 12.02.2015   FQ105809 Ajout modes turques - TL Linéaire turque  & HD Dégressif turque
#    MWA - 09.04.2013    FQ84281 Ajout modes suisses - HL Linéaire suisse  & HD Dégressif suisse
#    MWA - 13.03.2013    FQ84283 Ajout modes australiens - AL Prime cost  & AD Diminishing value
#    MWA - 21.08.2012    FQ84110 One period
#    CBO - 09.05.2012    FQ82075 Linéaire espagnol jour
#    MWA - 01.03.2012    FQ77877 Roumanie
#    MWA - 17.01.2012    FQ72372 Dégressif polonais
#    MWA - 03.12.2010    FQ67577 Gestion des modes polonais
#    MWA - 27.08.2010    FQ66197 Désignation du mode "standard" dans la langue de l'utilisateur
#    MWA - 22.07.2010    FQ61528 Adaptation pour tenir de la mono législation
#    GLE - 18.06.2010    FQ65551 Possibilité de créer/modifier les modes standards dans les solutions de dev et d'indus
#    MWA - 16.06.2010    FQ65483 Base/Duréé résiduelle option invalide pour Règle application taux
#    MWA - 15.06.2010    FQ59941 Gestion des modes russes
#    MWA - 25.02.2010    FQ62321 Filtre à tort sur liste gauche selon pays ou legislation
#    MWA - 07.07.2009    FQ60085 erreur dans construction d'un filtre
#    MWA - 07.07.2009    FQ55960 Degressif marocain
#
#*********************************************************************
#

  Raz GPILOBJ
  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM
  Call OBJET("DPM",GBIDC1,GBIDC2) From GOBJET
  End

  $ACTION
  # Infbox num$(ACTION)
  Case ACTION
    When "OUVRE"            : Gosub OUVRE       : # Début            - Avant toute chose

    When "APRES_MODIF"      : Gosub APRES_MODIF
    When "SETBOUT"          : Gosub SETBOUT

    When "RAZCRE"           : Gosub RAZCRE      : # Création         - Avant saisie
    When "RAZDUP"           : Gosub RAZDUP      : # Duplication      - Avant saisie
    When "LIENS"            : Gosub LIENS       : # Début            - Avant affichage des données

    When "VERIF_CRE"        : Gosub VERIF_CRE   : # Création         - Contrôles globaux
    When "INICRE"           : Gosub INICRE      : # Création         - Contrôles globaux
    When "CREATION"         : Gosub CREATION    : # Création         - Insertion dans autres tables

    When "AVANT_MOD"        : Gosub AVANT_MOD   : # Modification     - Avant modification
    When "VERIF_MOD"        : Gosub VERIF_MOD   : # Modification     - Contrôles globaux
    When "INIMOD"           : Gosub INIMOD      : # Modification     - Contrôles globaux
    When "MODIF"            : Gosub MODIF       : # Modification     - Mise à jour autres tables

    When "VERF_ANU"         : Gosub VERF_ANU    : # Suppression      - Contrôles globaux
    When "ANNULE"           : Gosub ANNULE      : # Suppression      - traitements complémentaires

    When "FERME"            : Gosub FERME       : # Fin              - Après toute chose FQ65551
    When Default
  Endcase

Return


#
#
#*********************************************************************
#
#
#
#=====================================================================
#
$OUVRE

  # Gestion des fichiers
  If clalev([F:DPMA]) =0     : Local File DPRMOD        [DPMA]    : Endif
  If clalev([F:DMR])  =0     : Local File DPRMODRAT     [DMR]     : Endif
  If clalev([F:DMO])  =0     : Local File DPRMODOPT     [DMO]     : Endif
  If clalev([F:DEP])  =0     : Local File DEPREC        [DEP]     : Endif
  If clalev([F:CNX])  =0     : Local File CONTEXT       [CNX]     : Endif

  Local Integer   STAT                   : # Code retour / call VERFALLCPY
  Local Char      L_CPY(GLONCPY)         : # Société pour contrôle habilitation

  Global Shortint ENV_DEV                : # environnement de développement FQ65551

  # FQ65551
  Local Char WPARAM
  Local File =GDOSX3+".ADOVAL" [ADW]
  Local File =GDOSX3+".ADOPAR" [ADP]
  Call PARAM("","ADONIX",WPARAM) From ADOVAL : # Chargement du paramètre identifiant un dossier de développement
  ENV_DEV = val(WPARAM)
  Close Local File [ADW], [ADP]
Return

#===================================================================== FQ65551
#
$FERME
  If dim(ENV_DEV)>0 : Kill ENV_DEV : Endif
Return
#
#=====================================================================
#
$APRES_MODIF
  # Habiliations : Contrôle habilitation / société
  If ( COUZON="CPY" ) Then
    L_CPY=CZ
    Gosub AUZ_CPY
  Endif

Return

#=====================================================================
#
$SETBOUT

  # Désactivation des actions   "Changer de clé"
  Call VIREBOUT(CHAINE,"H") From GOBJET


  # Pas de suppression du paramétrage par défaut en dehors des environnements de développement
  #If ( GADONIX <> 2 and [M:DPM0]CPY = "" and [M:DPM1]DPRMODTYP = GVML_TMSTAND) Then : # FQ65551
  If ( ENV_DEV <> 2 and [M:DPM0]CPY = "" and [M:DPM1]DPRMODTYP = GVML_TMSTAND) Then
    Call VIREBOUT(CHAINE,"A") From GOBJET
  Else
    # Pas de suppression du paramétrage par défaut si pas d'habilitation "tous sites du dossier"
    If ( [M]CPY="" and GNBAUZ <> GNBSITE ) Then
      Call VIREBOUT(CHAINE,"A") From GOBJET
    Else
      # Pas de suppression du paramétrage d'1 société si pas d'habilitation "tous sites de la société"
      Call VERFALLFCY([M:DPM0]CPY,[L]STAT) From SUPCPT
      If [L]STAT < 1 : Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
  Endif
Endif

Return


#=====================================================================
#
$RAZCRE

  # Affichage des valeurs par défaut
  Affzo [M:DPM1]

  # Conditionnement des champs selon mode libre ou standard
  Call CONDITIONNE_STD_LIB([M:DPM1]DPRMODTYP)

  # Chargement des plans sur lesquels le mode peut s'appliquer
  Call CHARGE_DPM3([M:DPM0]CPY)

Return

#=====================================================================
#
$VERIF_CRE
  Gosub VERIF_CRE_MOD
Return

#-----------------
$VERIF_CRE_MOD

Local Integer I
Local Integer RATCUM

  If ( [M:DPM1]RATCOETYP = GVML_COANNUI and
&    ( [M:DPM1]BASTYP = GVML_TBVALBI  or [M:DPM1]BASTYP = GVML_TBVLAMT ) ) Then
    # Si Type Taux/coef = Taux/annuité et Type base amort = valeur bilan ou valeur bilan - valeur résid
    If ( sum( [M:DPM1]RAT(0..([M:DPM1]NBLIG1-1)), [M:DPM1]EXCDPRRAT ) > 100 ) Then
      # La somme des taux y compris le taux d'amortissement exceptionnel ne doit pas dépasser 100%
      GERR= 1 : GMESSAGE= mess(17,7770, 1) : OK = 0
      zonsui = "[M:DPM1]RAT(0)"
      Return
    Endif
  Endif


  # si Type Valeur plancher  = Type de valeur plafond , le taux plancher
  # doit être inférieur au taux plafond

  If ( ( ( [M:DPM1]MAXDPRTYP = GVML_COPBASE and [M:DPM1]MINDPRTYP = GVML_COPBASE ) or
&        ( [M:DPM1]MAXDPRTYP = GVML_COPVNFE and [M:DPM1]MINDPRTYP = GVML_COPVNFE ) ) and
&          [M:DPM1]MINDPRRAT > [M:DPM1]MAXDPRRAT ) Then
    # Le Taux Plafond doit être >= au Taux Plancher
    GERR= 1 : GMESSAGE= mess(16,7770, 1) : OK = 0
    zonsui = "[M:DPM1]MAXDPRRAT"
    Return
  Endif

  # Détermination de STDDPM en fonction de STDDPRNUM
  Call DETERM_STDDPM()
  If ( [M:DPM0]STDDPM = "" ) Then
    # Le nombre maximum de méthodes libres a été dépassé. Opération impossible.
    GERR= 1 : GMESSAGE= mess(103,7770, 1) : OK = 0
    Return
  Endif

  # Le mode cible doit être résiduel
  If ([M:DPM1]DPRMODTYP = GVML_TMLIBRE ) Then
    If !( func SUBDPM.IS_MODE_LIBRE_CIBLE_VALIDE( [M:DPM0]DPM, [M:DPM1]RSDDPMTGR, [M:DPM1]BASTYP ) ) Then
      # Le mode résiduel equivalent n'est pas un mode résiduel
      GERR= 1 : GMESSAGE= mess(207,7770, 1) : OK = 0
      zonsui = "[M:DPM1]RSDDPMTGR"
      Return
    Endif
  Endif

Return

#=====================================================================
#
$INICRE

Gosub INI_CRE_MOD

Return

#-----------------
$INI_CRE_MOD
#-----------------

  # Affectation du champ APLPLNFLG
  Local Integer N_I

  For N_I = 1 To [M:DPM3]NBLIG3
    [F:DPM]APLPLNFLG([M:DPM3]DPRPLN(N_I-1)-1) = [M:DPM3]APLFLG(N_I-1)
  Next N_I

  [F:DPM]MINDPRRAT = [M:DPM1]MINDPRRAT / 100.
  [F:DPM]MAXDPRRAT = [M:DPM1]MAXDPRRAT / 100.
  [F:DPM]EXCDPRRAT = [M:DPM1]EXCDPRRAT / 100.

Return


#=====================================================================
#
$CREATION

  Gosub INSERT
Return

#=====================================================================
#
$RAZDUP

Return
#
#=====================================================================
#
$LIENS

Local Integer I, IS
Local Char LTBCPY(GLONCPY)(0..100)
Local Integer LNBCPY

  # Mode d'amortissement utilisé par un plan
  # le mode est utilisé par au moins un des biens de la société.
  If ( func DEP_UTILISE_DPM([M:DPM0]DPM, [M:DPM0]CPY ) ) Then
    [M:DPM0]UTILISE = G_OUI
  Else
    [M:DPM0]UTILISE = G_NON
  Endif

  # Coefficient en pourcentage
  [M:DPM1]MINDPRRAT = [F:DPM]MINDPRRAT * 100.
  [M:DPM1]MAXDPRRAT = [F:DPM]MAXDPRRAT * 100.
  [M:DPM1]EXCDPRRAT = [F:DPM]EXCDPRRAT * 100.

  # Conditionnement en fonction du type standard ou libre
  Call CONDITIONNE_STD_LIB([M:DPM1]DPRMODTYP)

  # Le type de mode Libre ou Standard n'est plus modifiable
  Diszo [M:DPM1]DPRMODTYP

  # Lecture des taux
  If ([M:DPM1]DPRMODTYP = GVML_TMLIBRE ) Then
    nolign = 1
    For [DMR]DMR0 Where DPM=[M:DPM0]DPM and CPY = [M:DPM0]CPY
      [M:DPM1] = [F:DMR]
      [M:DPM1]RAT(nolign-1) = [M:DPM1]RAT(nolign-1) * 100.
      # Si type application taux est égal à "Taux par annuité" ou "Base X taux mensuel"
      If ( [M:DPM1]RATCOETYP = GVML_COANNUI or [M:DPM1]RATCOETYP = GVML_COBSMTM ) Then
        [M:DPM1]RATCUM += [M:DPM1]RAT(nolign-1)
        nolign += 1
      Endif
    Next
    [M:DPM1]NBLIG1 = nolign-1
  Endif

  # Lecture des options (la gestion des options supérieures à 499 sont transparentes)
  nolign = 1
  For [DMO]DMO0 Where STDDPM=[M:DPM0]STDDPM and CPY= [M:DPM0]CPY and NUMDPM < 500
    [M:DPM2] = [F:DMO]
    [M:DPM2]OPTRAT(nolign-1) = [M:DPM2]OPTRAT(nolign-1) * 100.
    nolign += 1
  Next
  [M:DPM2]NBLIG2 = nolign-1

  # Lecture des plans sur lesquels le mode s'applique
  If ([M:DPM0]CPY = "") Then
    nolign = 1
    For I = 1 To G301MAX
      If ( (G_ACTIAS = G_OUI and I = G301IAS)  or (G_ACTGRT = G_OUI and I = G301SUB)  or
&          ( I <> G301AUC and I <> G301IAS and I <> G301SUB ) ) Then
      [M:DPM3]DPRPLN(nolign-1) = I
      [M:DPM3]APLFLG(nolign-1) = [F:DPM]APLPLNFLG(I-1)
      nolign += 1
      Endif
    Next I
  Else
    nolign = 1
    For [CNX]CNX0 Where CPY =[M:DPM0]CPY
      For I = 0 To [F:CNX]NBPLC-1
        [M:DPM3]DPRPLN(nolign-1) = [F:CNX]PLNCAA(I)
        [M:DPM3]APLFLG(nolign-1) = [F:DPM]APLPLNFLG([F:CNX]PLNCAA(I)-1)
        nolign += 1
      Next I
    Next
  Endif
  [M:DPM3]NBLIG3 = nolign-1

  # Affichage pour pouvoir conditionner les champs du tableau
  Call ACTION_BLOCK (ACB_AFFZO, "DPM3", "NBLIG3") From GLOBIENS

  # Libre
  If ([M:DPM1]DPRMODTYP = GVML_TMLIBRE ) Then
    # Par défaut répartition périodique X3-54480
    If ([F:DPM]DPRDISRUL <> GVML_REPFIRAV) Then
      [M:DPM1]DPRDISRUL = GVML_REPPERIO
    Endif

    # Si Type Taux/coef = "Base * Taux constant" ou = "Base / taux constant"
    # alors affectation de Taux constant à l'écran.
    If [M:DPM1]RATCOETYP = GVML_COBSMTC or [M:DPM1]RATCOETYP = GVML_COBSDTC
      [M:DPM1]CNSRAT = [M:DPM1]RAT(0)
    Endif
    # Si Type Taux/coef = "Taux par Annuité" ou = "Multiplier la base par un taux mensuel"
    # alors saisie  d'un nombre de taux sinon saisie d'un taux constant
    If [M:DPM1]RATCOETYP= GVML_COANNUI or [M:DPM1]RATCOETYP= GVML_COBSMTM
      [M:DPM1]CNSRAT = 0
    Else
      [M:DPM1]RATNBR= 0
    Endif
  Endif

  # Standard FQ66197
  # Affichage dans la langue de l'utilisateur.
  If ([M:DPM1]DPRMODTYP = GVML_TMSTAND ) Then
    [M:DPM0]DES = mess([M:DPM1]STDDPMNUM,3228,1)
  Endif

Return

#=====================================================================
#
$AVANT_MOD

  # Habilitations : Contrôle habilitation / société
  L_CPY=[M:DPM0]CPY
  Gosub AUZ_CPY
Return

#=====================================================================
#
$VERIF_MOD

  Gosub VERIF_CRE_MOD
Return

#=====================================================================
#
$INIMOD

  Gosub INI_CRE_MOD
Return


#=====================================================================
#
$MODIF
  # Suppression des taux et des options
  Gosub DELETE_ELEMENTS_DEPENDANTS

  # Insertion des taux et des options
  Gosub INSERT

  # Prise en compte des modifications par recalcul des biens porteur du mode modifié.

  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif

  # ---------------------------------------------
  # Passage des biens concernés à "A recalculer"
  # ---------------------------------------------
    If ( [M:DPM1]DPRMODTYP=GVML_TMSTAND ) Then
    # FILTER : S'il s'agit d'un mode standard, il est multi-société  => toutes les sociétés sont concernées
    # Sauf si le mode est limité à un pays donné         => uniquement les sociétés de même pays        sont concernées
    # Sauf si le mode est limité à une législation donné => uniquement les sociétés de même législation sont concernées
    # FQ60085 ( FILTRE  -> FILTRE(50)
    # FQ62321 ( FILTRE en LFILTRE car FILTRE est une variable utilisée par le superviseur )
    Local Char LFILTRE(50)
    LFILTRE = ""
    If ( [M:DPM1]CRY <> "" ) Then
      LFILTRE = "CRY = [M:DPM1]CRY"
    Endif
    # FQ61528
    # If ( [M:DPM1]LEG <> "" ) Then
    If ( dim([M:DPM1]LEG) > 0 and [M:DPM1]LEG <> "" ) Then
      If ( LFILTRE = "" ) Then
        LFILTRE = "LEG = [M:DPM1]LEG"
      Else
        # FQ60085 (=  -> +=
        LFILTRE += " & LEG = [M:DPM1]LEG"
      Endif
    Endif
    If ( LFILTRE = "") Then : LFILTRE = "1=1" : Endif
    Filter [CPY] Where evalue(LFILTRE)
  Elsif ( [M:DPM1]DPRMODTYP=GVML_TMLIBRE ) Then
    # FILTER : S'il s'agit d'un mode libre, s'il est multi-société  => toutes les sociétés sont concernées
    # si le mode est mono société => uniquement la société est concernée
    If ( [M:DPM0]CPY <> "" ) Then
      Filter [CPY] Where CPY=[M:DPM0]CPY
    Else
      Filter [CPY]
    Endif
  Endif
  # Exploitation du filter
  Local Integer I, I_PLN, LCNXUPD
  For [CPY]
    Filter [CNX] Where CPY=[F:CPY]CPY
    For [CNX]
      LCNXUPD=G_NON
      For I=1 To [F:CNX]NBPLC
        I_PLN=find([F:CNX]PLNCAA(I-1),[M:DPM3]DPRPLN)
        If I_PLN & [M:DPM3]APLFLG(I_PLN-1)=G_OUI
          LCNXUPD=G_OUI
          Break
        Endif
      Next I
      If LCNXUPD=G_OUI
        Local Integer RCOD
        Call ADD_UPD_WAI_CNX([F:CPY]CPY, [F:CNX]CNX, "DPM", [M:DPM0]DPM, "", "", RCOD) From UPDWAICNX
      Endif
    Next
  Next
  Filter [CPY]
  Filter [CNX]
  # ---------------------------------------------

Return


#=====================================================================
#
$VERF_ANU

Local Char LTBCPY(GLONCPY)(0..100)
Local Integer LNBCPY
Local Integer LUSED


  # La suppression d'un mode d'amortissement est interdite lorsque
  # le mode est utilisé par au moins un bien comptable.
  If ( [M:DPM0]UTILISE = G_OUI  ) Then
    GERR= 1 : GMESSAGE= mess(69,7770,1) :  OK = 0
    zonsui = "[M:DPM0]DPM"
    Return
  Endif

  # La suppression d'un mode d'amortissement est interdite
  # lorsque celui-ci est le mode résiduel équivalent d'un autre mode

  If ( [M:DPM1]DPRMODTYP = GVML_TMLIBRE  and
&      ( [M:DPM1]BASTYP = GVML_TBVLNET or
&        [M:DPM1]BASTYP = GVML_TBVNAMT     ) ) Then
    # Mode libre résiduel
    If clalev([F:WDPM])=0 : Local File DPRMOD   [WDPM] :  Endif
    Filter [WDPM] Where  RSDDPMTGR = [M:DPM0]DPM and DPM <> [M:DPM0]DPM
    Read[WDPM] First
    If ( fstat ) Then
      LUSED = 0
    Else
      LUSED = 1
    Endif
    Filter [WDPM]
    If ( LUSED ) Then
      # Suppression impossible : Le mode d'amortissement est utilisé comme mode résiduel équivalent
      GERR= 1 : mkstat = 2 : GMESSAGE= mess(209,7770, 1) : OK = 0
      zonsui = "[M:DPM0]DPM"
      Return
    Endif
  Endif

Return


#=====================================================================
#
$ANNULE

  # Suppression des taux et des options
  Gosub DELETE_ELEMENTS_DEPENDANTS
Return

#=====================================================================
#
$INSERT

  # Si Type Taux/coef = 2 (Base * Taux constant) ou = 3 ( Base / taux constant )
  # alors sauvegarde Taux constant dans DMR comme si nombre de taux était égal à 1.
  If ( [M:DPM1]RATCOETYP = GVML_COBSMTC or [M:DPM1]RATCOETYP = GVML_COBSDTC ) Then
    nolign = 1
    [M:DPM1]NUM = 1
    [M:DPM1]RAT = [M:DPM1]CNSRAT
    [M:DPM1]NBLIG1 = 1
  Endif

  # Création des taux
  For nolign = 1 To [M:DPM1]NBLIG1
    Raz  [F:DMR]
    [F:DMR] = [M:DPM1]
    [F:DMR] = [M:DPM0]
    [F:DMR]RAT = [M:DPM1]RAT (nolign-1) / 100.
    Write [F:DMR]
    If fstat
      GOK = 0
      Call FSTA("DMR") From GLOCK
      Break
    Endif
  Next nolign
  If GOK=0 : Return : Endif

  # Création des options
  For nolign = 1 To [M:DPM2]NBLIG2
    Raz  [F:DMO]
    [F:DMO]         = [M:DPM2]
    [F:DMO]         = [M:DPM0]
    [F:DMO]NUMDPM   = nolign
    [F:DMO]OPTCPY   = [F:DMO]CPY
    [F:DMO]OPTRAT   = [M:DPM2]OPTRAT (nolign-1) / 100.
    Write [F:DMO]
    If fstat
      GOK = 0
      Call FSTA("DMO") From GLOCK
      Break
    Endif
  Next nolign
  If GOK=0 : Return : Endif


Return

#=====================================================================
#
$DELETE_ELEMENTS_DEPENDANTS

  #  Suppression des taux
  Delete[F:DMR] Where DPM= [M:DPM0]DPM and CPY= [M:DPM0]CPY
  If fstat= 1
    GOK = 0
    Call RSTA("DMR",CLECUR1+"/"+num$(CLECUR2)) From GLOCK
    Return
  Endif

  # Suppression des options
  Delete[F:DMO] Where STDDPM= [M:DPM0]STDDPM and CPY= [M:DPM0]CPY
  If fstat= 1
    GOK = 0
    Call RSTA("DMO",CLECUR1+"/"+num$(CLECUR2)) From GLOCK
    Return
  Endif

Return


#=====================================================================
#
$AUZ_CPY

  # Habilitation : Contrôle de l'habilitation / société
  If ( GNBAUZ <> GNBSITE ) Then : # Pas d'habilitation tous sites
    If ( L_CPY <> "" ) Then
      mkstat = 0
      Call CONTALLFCY(L_CPY) From SUPCPT
      If mkstat : OK = 0 : mkstat = 0 : Endif
    Else
      # Vous n'êtes pas habilité pour la modification des paramètrages par défaut
      OK=0 : GMESSAGE=mess(113,7770,1)
    Endif
  Endif
Return

#=====================================================================
Subprog CTRL_NBR_MODE_LIBRE(PCPY, PMES, PRET)
Value    Char PCPY
Variable Char PMES()
Variable Integer PRET

 If !clalev([F:XDPM]) : Local File DPRMOD [XDPM] : Endif
 If !clalev([F:YDPM]) : Local File DPRMOD [YDPM] : Endif

 Local Integer NBMAXDPMLIB : NBMAXDPMLIB=GMXDPMLB
 Local Integer NB_DEF_DPM, NB_CPY_DPM
 Local Char CRIT_DPM(255)

 # Nombre de modes libres par défaut déjà définis

 Filter [F:XDPM] Where CPY="" & DPRMODTYP=GVML_TMLIBRE
 NB_DEF_DPM=rowcount([F:XDPM])
 If NB_DEF_DPM>=NBMAXDPMLIB
  PRET=1
  Goto FIN
 Endif

 # Nombres de modes libres par société déjà définis

 If PCPY=""
  Filter [F:XDPM] Where (CPY<>"" & DPRMODTYP=GVML_TMLIBRE)
 Else
  Filter [F:XDPM] Where (CPY=PCPY & DPRMODTYP=GVML_TMLIBRE)
 Endif
 For [XDPM]DPM0(1)
  Raz NB_CPY_DPM
  Filter [F:YDPM] Where (CPY=[F:XDPM]CPY)
  NB_CPY_DPM=rowcount ([F:YDPM])
  If NB_CPY_DPM+NB_DEF_DPM>=NBMAXDPMLIB
   PRET=1
   Break
  Endif
 Next

 $FIN

 # Résultat du contrôle
 If PRET=1
  PMES= mess(187,7770,1)-":"-num$(GMXDPMLB) #"nombre maximum de modes libres (par défaut ou société) atteint :"-num$(GMXDPMLB)
 Endif

 # Suppression des filtres
 Filter [F:YDPM]
 Filter [F:XDPM]

End

#
#*********************************************************************
#                     E C R A N      M D P 0
#*********************************************************************
#

########################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
 # Contrôle du nombre maximum de modes libres
 If [M:DPM1]DPRMODTYP=GVML_TMLIBRE
  Local Integer RETOUR
  Local Char    MES(255)
  Call CTRL_NBR_MODE_LIBRE(VALEUR, MES, RETOUR)
  If RETOUR=1
   GERR   = 1 : GMESSAGE = MES : mkstat = 2 : End
  Endif
 Endif
End

########################################
Subprog AM_CPY(VALEUR)
Variable Char VALEUR


  # Chargement des plans sur lesquels le mode peut s'appliquer
  Call  CHARGE_DPM3(VALEUR)

End

##########################################################################
Subprog AP_DPM(VALEUR)
Variable Char    VALEUR()

  # Un mode ne peut être à la fois défini "par défaut" et pour une société en particulier
  If ( [M:DPM0]CPY <> "" ) Then
    If ( func DPM_DEFINI(VALEUR) = 1 ) Then
      GERR= 1 : GMESSAGE= mess(70,7770,1)
      mkstat = 2 : End
    Endif
  Else
    If ( func DPM_DEFINI(VALEUR) = 2 ) Then
      GERR= 1 : GMESSAGE= mess(70,7770,1)
      mkstat = 2 : End
    Endif
  Endif
  # La duplication d'un mode standard est interdite
  If (func DPM_DEFINI([M:DPM0]DPM) and VALEUR <> [M:DPM0]DPM and [M:DPM1]DPRMODTYP = GVML_TMSTAND) Then
    GERR= 1 : GMESSAGE= mess(6,7770,1)
    mkstat = 2 : End
  Endif

  # Issue X3-67718 Conditionnement selon le type du mode Standard ou Libre
  If ( func DEP_UTILISE_DPM(VALEUR, [M:DPM0]CPY ) ) Then
    [M:DPM0]UTILISE = G_OUI
  Else
    [M:DPM0]UTILISE = G_NON
  Endif


  Call CONDITIONNE_STD_LIB([M:DPM1]DPRMODTYP)
  Affzo [M:DPM1]

End

##########################################################################
Subprog CL_MAJDES(VALEUR)
Variable Char    VALEUR()
  # Icone de mise à jour de la désignation avec le contenu du ML3228
  [M:DPM0]DES = mess([M:DPM1]STDDPMNUM,3228,1)
  Affzo [M:DPM0]DES
  mkstat = 4
End

#
#*********************************************************************
#                     E C R A N      M D P 1
#*********************************************************************
#

##########################################################################
Subprog AS_DPRMODTYP(VALEUR)
Variable Integer VALEUR
  #If (GADONIX <> 2 ) Then : # FQ65551
  If ( ENV_DEV <> 2 ) Then
    GMENLOC(GVML_TMSTAND) = 1
  Endif
End


########################################
Subprog AM_DPRMODTYP(VALEUR)
Variable Integer  VALEUR

  #  Standard
  If ( VALEUR  = GVML_TMSTAND ) Then : #  Standard
    [M:DPM0]CPY       = ""   : Affzo [M:DPM0]CPY
    [M:DPM1]RATCOETYP = 0    :
    [M:DPM1]CNSRAT    = 0    : Affzo [M:DPM1]CNSRAT
    [M:DPM1]RATNBR    = 0    : Affzo [M:DPM1]RATNBR
    [M:DPM1]RATCUM    = 0    : Affzo [M:DPM1]RATCUM
    [M:DPM1]NBLIG1    = 0    : Affzo [M:DPM1]NBLIG1
    [M:DPM1]FIRFIYFLG = 0    : Affzo [M:DPM1]FIRFIYFLG
    [M:DPM1]ANIDATFLG = 0    : Affzo [M:DPM1]ANIDATFLG
    [M:DPM1]PROTYP    = 0    : Affzo [M:DPM1]PROTYP
    [M:DPM1]BASTYP    = 0    : Affzo [M:DPM1]BASTYP
    [M:DPM1]ETRDATTYP = 0    : Affzo [M:DPM1]ETRDATTYP
    [M:DPM1]ENDDPRTYP = 0    : Affzo [M:DPM1]ENDDPRTYP
    [M:DPM1]ENDDATTYP = 0    : Affzo [M:DPM1]ENDDATTYP
    [M:DPM1]MINDPRLIF = 0    : Affzo [M:DPM1]MINDPRLIF
    [M:DPM1]MINDPRTYP = 0    : Affzo [M:DPM1]MINDPRTYP
    [M:DPM1]MINDPRRAT = 0    : Affzo [M:DPM1]MINDPRRAT
    [M:DPM1]MAXDPRTYP = 0    : Affzo [M:DPM1]MAXDPRTYP
    [M:DPM1]MAXDPRRAT = 0    : Affzo [M:DPM1]MAXDPRRAT
    [M:DPM1]EXCDPRTYP = 0    : Affzo [M:DPM1]EXCDPRTYP
    [M:DPM1]EXCDPRRAT = 0    : Affzo [M:DPM1]EXCDPRRAT
    [M:DPM1]DPRDISRUL = 0    : Affzo [M:DPM1]DPRDISRUL   : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
  Else
    [M:DPM1]RATCOETYP = GVML_COANNUI  : Affzo [M:DPM1]RATCOETYP
    [M:DPM1]FIRFIYFLG = G_NON         : Affzo [M:DPM1]FIRFIYFLG
    [M:DPM1]ANIDATFLG = G_NON         : Affzo [M:DPM1]ANIDATFLG
    [M:DPM1]PROTYP    = GVML_TPMOIS   : Affzo [M:DPM1]PROTYP
    [M:DPM1]ETRDATTYP = GVML_DAJOURP  : Affzo [M:DPM1]ETRDATTYP
    [M:DPM1]ENDDPRTYP = GVML_DSJOURP  : Affzo [M:DPM1]ENDDPRTYP
    [M:DPM1]ENDDATTYP = GVML_DSJOURP  : Affzo [M:DPM1]ENDDATTYP
    [M:DPM1]BASTYP    = GVML_TBVLAMT  : Affzo [M:DPM1]BASTYP
    [M:DPM1]MINDPRTYP = GVML_COSANS   : Affzo [M:DPM1]MINDPRTYP
    [M:DPM1]MAXDPRTYP = GVML_COSANS   : Affzo [M:DPM1]MAXDPRTYP
    [M:DPM1]EXCDPRTYP = GVML_COSANS   : Affzo [M:DPM1]EXCDPRTYP
    [M:DPM1]DPRDISRUL = GVML_REPPERIO : Affzo [M:DPM1]DPRDISRUL   : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
  Endif

  # Conditionnement selon le type du mode Standard ou Libre
  Call CONDITIONNE_STD_LIB(VALEUR)
  Affzo [M:DPM1]

  # Chargement des plans sur lesquels le mode peut s'appliquer
  Call  CHARGE_DPM3([M:DPM0]CPY)

End

########################################
Subprog C_STDDPMNUM(VALEUR)
Variable Integer  VALEUR

  # Un mode d'amortissement standard ne peut être utilisé qu'une seule fois
  If ( [M:DPM1]DPRMODTYP = GVML_TMSTAND ) Then
     Read [DPMA]DPM1= VALEUR
     If (fstat=0) and ([F:DPMA]DPM <> [M:DPM0]DPM) Then
       GERR= 1 : GMESSAGE= mess(35, 7770, 1)
       mkstat = 2 : End
     Endif
  Endif

End

########################################
Subprog AM_STDDPMNUM(VALEUR)
Variable Integer  VALEUR

  # Si le mode d'amortissement est standard la désignation hérite du libellé du mode (ml3228)
  If ( [M:DPM1]DPRMODTYP = GVML_TMSTAND ) Then
    [M:DPM0]DES = mess(VALEUR, 3228, 1)
    Affzo [M:DPM0]DES
  Endif
  # Affectation du mode résiduel
  # S'il s'agit d'un mode origine amorti sur valeur nette, le mode cible est équivalent à l'origine
  # S'il s'agit du mode CA Caducité / V.Brute,  le mode cible est RA Caducité / V.Nette
  # S'il s'agit d'un mode origine amorti sur valeur brute, le mode cible est RE Résiduel
  Case VALEUR
    When GVML_MASLINE : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Straight Line
    When GVML_MACADUC : [M:DPM1]RSDDPMTGR = G_DPMRA       : # Caducité
    When GVML_MADGALL : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Dégressif allemand
    When GVML_MADGBEL : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Dégressif belge
    When GVML_MADCLBA : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Declining balance
    When GVML_MADGESP : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Dégressif espagnol
    When GVML_MADGFRA : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Dégressif français
    When GVML_MADGMAL : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Dégressif allemand mixte
    When GVML_MADGPOR : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Dégressif portugais
    When GVML_MADGMES : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Dégressif espagnol mixte
    When GVML_MARESID : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Résiduelle
    When GVML_MAFRMML : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Formes & moules
    When GVML_MALIESP : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Linéaire espagnol
    When GVML_MALINGE : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Linge
    When GVML_MALIPUR : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Linéaire français
    When GVML_MAPROGR : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Progressif
    When GVML_MANOAMT : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Sans amortissement
    When GVML_MASOFTY : [M:DPM1]RSDDPMTGR = G_DPMRE       : # SOFTY
    When GVML_MAUNITO : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Unité d'oeuvre
    When GVML_MALADVR : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Linéaire au delà VN nulle
    When GVML_MADGPOM : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Dégressif portugais mixte
    When GVML_MAORDAN : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Ordinario / Anticipato
    When GVML_MAPORPC : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Portugais constantes
    When GVML_MAPORPD : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Portugais duodecimos
    When GVML_MACARSD : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Caducité résiduelle
    When GVML_MALIBEL : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Linéaire belge
    When GVML_MADGMAR : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Degressif marocain ( FQ55960 )
    When GVML_MALIRUS : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Linéaire russe       ( FQ59941 )
    When GVML_MADGRUS : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Dégressif russe      ( FQ59941 )
    When GVML_MACORUS : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Constant  russe      ( FQ59941 )
    When GVML_MASYRUS : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # SOFTY     russe      ( FQ59941 )
    When GVML_MAUORUS : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Unité d'oeuvre russe ( FQ59941 )
    When GVML_MALIPOL : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Linéaire polonais    ( FQ67577 )
    When GVML_MADGPOL : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Dégressif polonais   ( FQ72372 )
    When GVML_MALIROM : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Linéaire roumain     ( FQ77877 )
    When GVML_MAACROM : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Accéléré roumain     ( FQ77877 )
    When GVML_MADGROM : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Dégressif roumain    ( FQ77877 )
    When GVML_MALISPA : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Linéaire espagnol jour ( FQ82075)
    When GVML_MAONEP  : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # One period           ( FQ84110)
    When GVML_MAPRIMC : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Prime cost           ( FQ84283 )
    When GVML_MADVALU : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Diminishing value    ( FQ84283 )
    When GVML_MALISUI : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Linéaire suisse      ( FQ84281 )
    When GVML_MADGSUI : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Défressif suisse     ( FQ84281 )
    When GVML_MALITUR : [M:DPM1]RSDDPMTGR = G_DPMRE       : # Linéaire turque      ( FQ105809 )
    When GVML_MADGTUR : [M:DPM1]RSDDPMTGR = [M:DPM0]DPM   : # Défressif turque     ( FQ105809 )
    When Default
  Endcase
  Affzo [M:DPM1]RSDDPMTGR

  # FQ59941
  If ( [M:DPM1]RSDDPMTGR = G_DPMRE and [M:DPM1]PRATYPTGR = 0 and
&      ( VALEUR <> GVML_MARESID and VALEUR <> GVML_MASLINE and VALEUR <> GVML_MALIRUS ) ) Then
    [M:DPM1]PRATYPTGR = GVML_TPJOUR
    Actzo [M:DPM1]PRATYPTGR
    Affzo [M:DPM1]PRATYPTGR
  Endif

  # Conditionnement selon le type du mode Standard ou Libre
  Call CONDITIONNE_STD_LIB([M:DPM1]DPRMODTYP)
  Affzo [M:DPM1]

End

##########################################################################
Subprog AS_RATCOETYP(VALEUR)
Variable Integer VALEUR

 # Les valeurs valides pour ce champ sont "Taux par annuité",
 # "Base * taux constant", "Base / taux constant", "Base * taux mensuel"

 GMENLOC(GVML_COSANS)  = 1
 GMENLOC(GVML_COPBASE) = 1
 GMENLOC(GVML_COPVNFE) = 1
 GMENLOC(GVML_COBSDDU) = 1
 GMENLOC(GVML_COVNDDR) = 1
 GMENLOC(GVML_CO1EREX) = 1
 GMENLOC(GVML_CO1ERPE) = 1

 GMENLOC(GVML_COPRSIM) = 1
 GMENLOC(GVML_COPSANS) = 1
 GMENLOC(GVML_COPRINV) = 1
 GMENLOC(GVML_COPRDES) = 1
 GMENLOC(GVML_COPMOIS) = 1
 GMENLOC(GVML_COPJOUR) = 1
 GMENLOC(GVML_COVNADR) = 1
 GMENLOC(GVML_COPVNA)  = 1
 GMENLOC(GVML_COPPRTX) = 1
 GMENLOC(GVML_COBSADU) = 1   : # FQ65483

End

########################################
Subprog AM_RATCOETYP(VALEUR)
Variable Integer VALEUR

  # Si Type Taux/coef = 1 (Taux par Annuité) ou = 4 ( Multiplier la base par un taux mensuel )
  # alors saisie  d'un nombre de taux sinon saisie d'un taux constant

  If VALEUR = GVML_COANNUI or VALEUR = GVML_COBSMTM
    [M:DPM1]CNSRAT = 0 : Affzo [M:DPM1]CNSRAT
    Diszo [M:DPM1]CNSRAT
    Actzo [M:DPM1]RATNBR
  Else
    [M:DPM1]RATNBR= 0  : Affzo [M:DPM1]RATNBR
    [M:DPM1]RATCUM= 0  : Affzo [M:DPM1]RATCUM
    Actzo [M:DPM1]CNSRAT
    Diszo [M:DPM1]RATNBR
    Effzo [M:DPM1]NBLIG1
  Endif

  # Si  Type Taux/coef = "Multiplier Base par Tx Mensuel"
  # alors le type de prorata ne peut être que "Mois"
  # alors le type de date d'entrée/sortie ne peut être que 1 (Au jour précisé)

  If VALEUR = GVML_COBSMTM
    [M:DPM1]PROTYP = GVML_TPMOIS : Affzo [M:DPM1]PROTYP
    Diszo [M:DPM1]PROTYP
  Else
    Actzo [M:DPM1]PROTYP
  Endif

End


########################################
Subprog AM_RATNBR(VALEUR)
Variable Decimal VALEUR

  # si Type Taux/coef = 1 (Taux par annuité) ou 4 (Taux mensuel constant)
  # création de n lignes de taux dans le tableau ( n = nombre de taux ).

  If ( [M:DPM1]RATCOETYP = GVML_COANNUI or [M:DPM1]RATCOETYP = GVML_COBSMTM ) Then
    nolign = 1
    For nolign = 1 To VALEUR
      [M:DPM1]NUM(nolign-1) = nolign
      If ( nolign > [M:DPM1]RATNBR )  Then
        [M:DPM1]RAT(nolign-1) = 0
      Endif
    Next nolign
    [M:DPM1]NBLIG1 = nolign-1
  Endif

  [M:DPM1]RATCUM = sum( [M:DPM1]RAT(0..([M:DPM1]NBLIG1-1)) )
  Affzo [M:DPM1]RATCUM
  Call ACTION_BLOCK (ACB_AFFZO, "DPM1", "NBLIG1") From GLOBIENS # conditionne le bloc contenant NBLIG1

End

########################################
Subprog S_RSDDPMTGR(VALEUR)
Variable Char    VALEUR()

 If !clalev([F:XDPM]) : Local File DPRMOD [XDPM] : Endif

 Local Integer NBTEX , I , VALINT
 Local Char    TEX(50)(100)

 NBTEX = 0
 Filter [XDPM] Where DPM<>VALEUR & DPRMODTYP=GVML_TMSTAND
 For [XDPM]
  NBTEX += 1
  TEX(NBTEX) = [F:XDPM]DPM-[F:XDPM]DES
 Next I

 If NBTEX
  Call SAITEX(NBTEX,TEX,VALINT,mess(181,7770,1)) From GESECRAN
  If VALINT<>0 & status<>7
   VALEUR = left$(TEX(VALINT),2)
  Endif
 Endif

 mkstat = 2
End

########################################
Subprog C_RSDDPMTGR(VALEUR)
Variable Char    VALEUR()

 # Pas la peine de contrôler si le champ est vide
 If ( VALEUR <> "" and VALEUR <> [M:DPM0]DPM ) Then
  If !clalev([F:XDPM]) : Local File DPRMOD [XDPM] : Endif
  Read [XDPM]DPM0=VALEUR;""
  If fstat
   Call GSTA From GLOCK
   mkstat   = 2
   End
  Endif
 Else
  VALEUR = [M:DPM0]DPM
 Endif

End


###########################################
Subprog AM_RSDDPMTGR(VALEUR)
Variable Char    VALEUR()

  If (  VALEUR = G_DPMRE ) Then
    Actzo [M:DPM1]PRATYPTGR
  Else
    [M:DPM1]PRATYPTGR = 0
    Diszo [M:DPM1]PRATYPTGR
  Endif
  Affzo [M:DPM1]PRATYPTGR

  If ( [M:DPM1]STDDPMNUM = GVML_MAPORPC and VALEUR <> G_DPMRE and VALEUR <> G_DPMPC ) Then
    # Le mode équivalent ne peut être que Portugais Constantes ou Résiduel
    GERR= 1 : mkstat = 2 : GMESSAGE= mess(210,7770, 1) : OK = 0 : End
  Endif

  If ( [M:DPM1]STDDPMNUM = GVML_MAPORPD and VALEUR <> G_DPMRE and VALEUR <> G_DPMPD ) Then
    # Le mode équivalent ne peut être que Portugais Constantes Duodecimos ou Résiduel
    GERR= 1 : mkstat = 2 : GMESSAGE= mess(211,7770, 1) : OK = 0 : End
  Endif

End

########################################
Subprog B1_NBLIG1

Local Integer I
Local Decimal R

  # Reporter le taux de la ligne courante sur les lignes suivantes du tableaux
  [L]R = [M:DPM1]RAT(nolign-1)
  nolign += 1

  For [L]I = nolign To NBLIG1
    [M:DPM1]RATCUM -= [M:DPM1]RAT(nolign-1)
    [M:DPM1]RAT(nolign-1) = R
    [M:DPM1]RATCUM += [M:DPM1]RAT(nolign-1)
    nolign += 1
  Next [L]I

  Affzo [M:DPM1]RATCUM
  Call ACTION_BLOCK (ACB_AFFZO, "DPM1", "NBLIG1") From GLOBIENS # conditionne le bloc contenant NBLIG1

End

########################################
Subprog AS_NBLIG1

  # Empêcher l'activation du bouton lorsque la ligne courante est la dernière ligne du tableau
  If ( nolign = [M:DPM1]NBLIG1 ) Then
    GBOUT1 = ""
  Endif

End

########################################
Subprog AVANT_NBLIG1

  # Cumul des taux saisis
  If ( [M:DPM1]RATCOETYP = GVML_COANNUI or [M:DPM1]RATCOETYP = GVML_COBSMTM ) Then
    [M:DPM1]RATCUM -= [M:DPM1]RAT(nolign-1)
  Endif
End

########################################
Subprog APRES_NBLIG1

  # Cumul des taux saisis
  If ( [M:DPM1]RATCOETYP = GVML_COANNUI or [M:DPM1]RATCOETYP = GVML_COBSMTM ) Then
    [M:DPM1]RATCUM += [M:DPM1]RAT(nolign-1)
  Endif
  Affzo [M:DPM1]RATCUM

End

##########################################################################
Subprog AS_PROTYP(VALEUR)
Variable Integer VALEUR
End

##########################################################################
Subprog AS_MINDPRTYP(VALEUR)
Variable Integer VALEUR

 # Les valeurs valides pour ce champ sont "Aucun", "Pourcentage de la base d'amortissement",
 # "Pourcentage de la valeur nette fin d'exercice précédent",
 # "Valeur bilan / durée d'amortissement", "Valeur nette / durée résiduelle"
 # "V. bilan - V. résid. / durée d'amortissement", "V. nette - V. résid. / durée résiduelle"

 GMENLOC(GVML_COANNUI) = 1
 GMENLOC(GVML_COBSMTC) = 1
 GMENLOC(GVML_COBSDTC) = 1
 GMENLOC(GVML_COBSMTM) = 1
 GMENLOC(GVML_CO1EREX) = 1
 GMENLOC(GVML_CO1ERPE) = 1
 GMENLOC(GVML_COPRSIM) = 1
 GMENLOC(GVML_COPSANS) = 1
 GMENLOC(GVML_COPRINV) = 1
 GMENLOC(GVML_COPRDES) = 1
 GMENLOC(GVML_COPMOIS) = 1
 GMENLOC(GVML_COPJOUR) = 1
 GMENLOC(GVML_COPVNA)  = 1
 GMENLOC(GVML_COPPRTX) = 1
End

##########################################################################
Subprog AS_MAXDPRTYP(VALEUR)
Variable Integer VALEUR

 # Les valeurs valides pour ce champ sont "Aucun", "Pourcentage de la base d'amortissement",
 # "Pourcentage de la valeur nette fin d'exercice précédent"

 GMENLOC(GVML_COANNUI) = 1
 GMENLOC(GVML_COBSMTC) = 1
 GMENLOC(GVML_COBSDTC) = 1
 GMENLOC(GVML_COBSMTM) = 1
 GMENLOC(GVML_COBSDDU) = 1
 GMENLOC(GVML_COVNDDR) = 1
 GMENLOC(GVML_CO1EREX) = 1
 GMENLOC(GVML_CO1ERPE) = 1
 GMENLOC(GVML_COPRSIM) = 1
 GMENLOC(GVML_COPSANS) = 1
 GMENLOC(GVML_COPRINV) = 1
 GMENLOC(GVML_COPRDES) = 1
 GMENLOC(GVML_COPMOIS) = 1
 GMENLOC(GVML_COPJOUR) = 1
 GMENLOC(GVML_COVNADR) = 1
 GMENLOC(GVML_COPVNA)  = 1
 GMENLOC(GVML_COBSADU) = 1
 GMENLOC(GVML_COPPRTX) = 1
End


##########################################################################
Subprog AS_EXCDPRTYP(VALEUR)
Variable Integer VALEUR

 # Les valeurs valides pour ce champ sont "Aucun", "A reintégrer sur le 1er exercice",
 # "A reintégrer sur la 1ère période"

 GMENLOC(GVML_COANNUI) = 1
 GMENLOC(GVML_COBSMTC) = 1
 GMENLOC(GVML_COBSDTC) = 1
 GMENLOC(GVML_COBSMTM) = 1
 GMENLOC(GVML_COPBASE) = 1
 GMENLOC(GVML_COPVNFE) = 1
 GMENLOC(GVML_COBSDDU) = 1
 GMENLOC(GVML_COVNDDR) = 1
 GMENLOC(GVML_COPRSIM) = 1
 GMENLOC(GVML_COPSANS) = 1
 GMENLOC(GVML_COPRINV) = 1
 GMENLOC(GVML_COPRDES) = 1
 GMENLOC(GVML_COPMOIS) = 1
 GMENLOC(GVML_COPJOUR) = 1
 GMENLOC(GVML_COVNADR) = 1
 GMENLOC(GVML_COPVNA)  = 1
 GMENLOC(GVML_COBSADU) = 1
 GMENLOC(GVML_COPPRTX) = 1
End



##########################################################################
Subprog AS_ETRDATTYP(VALEUR)
Variable Integer VALEUR

  # Si "Règle application taux" est égal à "Base par taux mensuel"
  # seules les valeurs suivantes sont admises : "Au premier du mois", "Au premier jour du mois suivant"
  If ( [M:DPM1]RATCOETYP = GVML_COBSMTM ) Then
    GMENLOC(GVML_DAJOURP) = 1
    GMENLOC(GVML_DA1ERE)  = 1
    GMENLOC(GVML_DA1ERES) = 1
    GMENLOC(GVML_DA1ERS)  = 1
  Endif

  # Si "Type de prorata" est égal à "Mois"
  # les valeurs suivantes ne sont pas admises : "Au jour précisé"
  If ( [M:DPM1]PROTYP = GVML_TPMOIS ) Then
    GMENLOC(GVML_DAJOURP) = 1
  Endif

End

##########################################################################
Subprog AS_ENDDPRTYP(VALEUR)
Variable Integer VALEUR

  # Valeur exclue d'office :
  GMENLOC(GVML_DSDERMP) = 1 : # Au dernier jour du mois précédent
  GMENLOC(GVML_DSDEREP) = 1 : # Au dernier jour de l'exercice précédent
  GMENLOC(GVML_DSDERSP) = 1 : # Au dernier jour du semestre précédent
  GMENLOC(GVML_DSJPREC) = 1 : # Au jour précédent
  GMENLOC(GVML_DS1ERSC) = 1 : # Au premier jour du semestre courant


  # Si "Règle application taux" est égal à "Base par taux mensuel"
  # seules les valeurs suivantes sont admises : "Au dernier jour du mois courant"
  If ( [M:DPM1]RATCOETYP = GVML_COBSMTM ) Then
    GMENLOC(GVML_DSJOURP) = 1
    GMENLOC(GVML_DSDEREC) = 1
    GMENLOC(GVML_DSDERSC) = 1
  Endif

  # Si "Type de prorata" est égal à "Mois"
  # les valeurs suivantes ne sont pas admises : "Au jour précisé"
  If ( [M:DPM1]PROTYP = GVML_TPMOIS ) Then
    GMENLOC(GVML_DSJOURP) = 1
  Endif

End

##########################################################################
Subprog AS_ENDDATTYP(VALEUR)
Variable Integer VALEUR

  # Valeur exclue d'office :
  GMENLOC(GVML_DSDERSP) = 1 : # Au dernier jour du semestre précédent
  GMENLOC(GVML_DSDERSC) = 1 : # Au dernier jour du semestre courant

  # Si "Règle application taux" est égal à "Base par taux mensuel"
  # seules les valeurs suivantes sont admises : "Au dernier jour du mois précédent",
  # "Au dernier jour du mois courant"
  If ( [M:DPM1]RATCOETYP = GVML_COBSMTM ) Then
    GMENLOC(GVML_DSJOURP) = 1
    GMENLOC(GVML_DSDEREP) = 1
    GMENLOC(GVML_DSDEREC) = 1
    GMENLOC(GVML_DSJPREC) = 1
    GMENLOC(GVML_DS1ERSC) = 1
  Endif

  # Si "Type de prorata" est égal à "Mois"
  # les valeurs suivantes ne sont pas admises : "Au jour précisé", "Au jour précédent"
  If ( [M:DPM1]PROTYP = GVML_TPMOIS ) Then
    GMENLOC(GVML_DSJOURP) = 1
    GMENLOC(GVML_DSJPREC) = 1
  Endif

End


########################################
Subprog AM_BASTYP(VALEUR)
Variable Integer VALEUR

Local Integer LUSED
  If ( [M:DPM1]BASTYP = GVML_TBVLNET or
&      [M:DPM1]BASTYP = GVML_TBVNAMT     ) Then
    # A l'origine l'amortissement est basé sur la valeur nette
    If ( VALEUR  <> GVML_TBVLNET and
&        VALEUR  <> GVML_TBVNAMT     ) Then
      # Après modif, l'amortissement n'est plas basé sur valeur
      If ( [M:DPM0]DPM = [M:DPM1]RSDDPMTGR ) Then
        # Choix incorrect car ce mode est actuellement utilisé comme mode résiduel
        GERR= 1 : mkstat = 2 : GMESSAGE= mess(208,7770, 1) : OK = 0 : End
      Else
        If clalev([F:WDPM])=0 : Local File DPRMOD   [WDPM] :  Endif
        Filter [WDPM] Where  RSDDPMTGR = [M:DPM0]DPM
        Read[WDPM] First
        If ( fstat ) Then
          LUSED = 0
        Else
          LUSED = 1
        Endif
        Filter [WDPM]
        If ( LUSED ) Then
          # Choix incorrect car ce mode est actuellement utilisé comme mode résiduel
          GERR= 1 : mkstat = 2 : GMESSAGE= mess(208,7770, 1) : OK = 0 : End
        Endif
      Endif
    Endif
  Endif

End

########################################
Subprog C_MINDPRLIF(VALEUR)
Variable Decimal VALEUR

  # si Type Taux/coef = "Taux par annuité" et la durée minimum d'amortisement
  # est renseignée, elle ne peut pas être supérieure au nombre de taux saisi.

  If ( [M:DPM1]RATCOETYP = GVML_COANNUI and VALEUR > [M:DPM1]RATNBR ) Then
 # La durée d'amortissement minimum ne peut pas être supérieure au nombre de taux
    GERR= 1 : GMESSAGE= mess(5,7770, 1)
    mkstat = 2 : End
  Endif

End


########################################
Subprog AM_MINDPRTYP(VALEUR)
Variable Integer VALEUR

  # si Type Valeur plancher = "% base d'amt" ou "% valeur nette fin ex. précédent"
  # rendre le taux valeur plancher saisissable sinon rendre le champ insaisissable.

  If ( VALEUR = GVML_COPBASE or VALEUR = GVML_COPVNFE ) Then
    Actzo [M:DPM1]MINDPRRAT
  Else
    [M:DPM1]MINDPRRAT = 0
    Diszo [M:DPM1]MINDPRRAT
    Affzo [M:DPM1]MINDPRRAT
  Endif

End

########################################
Subprog C_MINDPRRAT(VALEUR)
Variable Decimal VALEUR

  # si Type Valeur plancher = "% base d'amt" ou "% valeur rés. fin exe. précédent"
  # le taux valeur plancher doit être renseigné et être compris entre 1 et 100 %

  If ( [M:DPM1]MINDPRTYP = GVML_COPBASE or [M:DPM1]MINDPRTYP = GVML_COPVNFE ) Then
    If ( VALEUR < 1  or VALEUR > 100 ) Then
      GERR= 1 : GMESSAGE= mess(15,7770, 1)
      mkstat = 2 : End
    Endif
  Endif

End

########################################
Subprog AM_MAXDPRTYP(VALEUR)
Variable Integer VALEUR

  # si Type Valeur plafond = "% base d'amt" ou "% valeur nette. fin ex. précédent"
  # rendre le taux valeur plafond  saisissable sinon rendre le champ insaisissable.

  If ( VALEUR = GVML_COPBASE or VALEUR = GVML_COPVNFE ) Then
    Actzo [M:DPM1]MAXDPRRAT
  Else
    [M:DPM1]MAXDPRRAT = 0
    Diszo [M:DPM1]MAXDPRRAT
    Affzo [M:DPM1]MAXDPRRAT
  Endif

End

########################################
Subprog C_MAXDPRRAT(VALEUR)
Variable Decimal VALEUR

  # si Type Valeur plafond = "% base d'amt" ou "% valeur nette. fin ex. précédent"
  # le taux valeur plafond doit être renseigné.

  If ( [M:DPM1]MAXDPRTYP = GVML_COPBASE or [M:DPM1]MAXDPRTYP = GVML_COPVNFE ) Then
    If ( VALEUR < 1  or VALEUR > 100 ) Then
      GERR= 1 : GMESSAGE= mess(15, 7770, 1)
      mkstat = 2 :  End
    Endif
  Endif

End

########################################
Subprog AM_EXCDPRTYP(VALEUR)
Variable Integer VALEUR

  # si Type Amt except. = "A réintégrer sur le 1er ex." ou "A réintégrer sur la 1ere per."
  # rendre le taux Amt except. saisissable sinon rendre le champ insaisissable.

  If  ( VALEUR = GVML_CO1EREX or VALEUR = GVML_CO1ERPE ) Then
    Actzo [M:DPM1]EXCDPRRAT
  Else
    [M:DPM1]EXCDPRRAT = 0
    Diszo [M:DPM1]EXCDPRRAT
    Affzo [M:DPM1]EXCDPRRAT
  Endif

End


#
#*********************************************************************
#                     E C R A N      D P M 2
#*********************************************************************
#

########################################
Subprog AVANT_NBLIG2

  #    Si le mode d'amortissement est défini pour une société spécifique
  #    Les options ne peuvent concerner que cette dernière.


  Actzo [M:DPM2]
  Affzo [M:DPM2]

  If ([M:DPM2]STRVLYDAT <> [0/0/0]) Then
    Actzo [M:DPM2]ENDVLYDAT(nolign-1)
    Actzo [M:DPM2]REFDATTYP(nolign-1)
  Else
    [M:DPM2]ENDVLYDAT(nolign-1) = [0/0/0]
    Affzo [M:DPM2]ENDVLYDAT(nolign-1)
    [M:DPM2]REFDATTYP(nolign-1)= GVML_DRSANS
    Affzo [M:DPM2]REFDATTYP(nolign-1)

    Diszo [M:DPM2]ENDVLYDAT(nolign-1)
    Diszo [M:DPM2]REFDATTYP(nolign-1)
  Endif
End

######################################################################################
Subprog C_NBLIG2

# FQ82075 : GVML_MALISPA
  #--------------
  If ( status = 82 or status = 73 ) Then
    If ( [M:DPM1]DPRMODTYP  = GVML_TMSTAND ) Then
      If ( ([M:DPM1]STDDPMNUM <> GVML_MAORDAN) and
&          ([M:DPM1]STDDPMNUM <> GVML_MADGALL) and
&          ([M:DPM1]STDDPMNUM <> GVML_MADGBEL) and
&          ([M:DPM1]STDDPMNUM <> GVML_MALIBEL) and
&          ([M:DPM1]STDDPMNUM <> GVML_MALIPUR) and
&          ([M:DPM1]STDDPMNUM <> GVML_MALISPA) ) Then
        # On peut saisir des options sur le mode IT, DA, DX, DB, LP, SL
        # Aucune option ne peut être saisie pour ce code
        GERR     = 1
        GMESSAGE = mess(216,7770,1)
        mkstat   = 2
        End
      Endif
    Else
      # On ne peut pas saisir d'option paramétrées sur un mode d'amortissement libre
      GERR     = 1
      GMESSAGE = mess(216,7770,1)
      mkstat   = 2
      End
    Endif
  Endif
  #--------------

End


##########################################################################
Subprog AS_OPTTYP(VALEUR)
Variable Integer VALEUR

  # Si type option est 0 alors les valeurs "Remplacement taux constant" "Augmentation taux constant"
  # "Diminution taux constant" ne sont pas admises.
  If ( [M:DPM1]CNSRAT = 0 and [M:DPM1]DPRMODTYP  = GVML_TMLIBRE  ) Then
    GMENLOC(GVML_OPRPLTX) = 1
    GMENLOC(GVML_OPAUGTX) = 1
    GMENLOC(GVML_OPDIMTX) = 1
  Endif

  # FQ59941 FQ82075
  If (find ([M:DPM1]STDDPMNUM, GVML_MADGBEL, GVML_MALIBEL, GVML_MAORDAN, GVML_MADGALL, GVML_MALIPUR, GVML_MALISPA)>0 ) Then
    GMENLOC(GVML_OPRPLTX) = 1
    GMENLOC(GVML_OPAUGTX) = 1
    GMENLOC(GVML_OPDIMTX) = 1
    GMENLOC(GVML_OPRPLPC) = 1
    GMENLOC(GVML_OPRPLPF) = 1
    GMENLOC(GVML_OPRPLAE) = 1
  Endif

  If ([M:DPM1]STDDPMNUM <> GVML_MAORDAN ) Then
  # Si mode différent de IT, l'option 8 "Option mode italien" n'est pas accessible
   GMENLOC(GVML_OPMODIT)  = 1
  Endif
  If ( [M:DPM1]STDDPMNUM <> GVML_MADGBEL and [M:DPM1]STDDPMNUM <> GVML_MALIBEL ) Then
  # Si mode différent de DB & LB, l'option 7  "Option mode belge" n'est pas accessible
   GMENLOC(GVML_OPMODBE)  = 1
  Endif
  If ( [M:DPM1]STDDPMNUM <> GVML_MADGALL ) Then
  # Si mode différent de DA  l'option 9  "Option mode allemand" n'est pas accessible
   GMENLOC(GVML_OPMODAL)  = 1
  Endif
   FQ82075
  If ( [M:DPM1]STDDPMNUM <> GVML_MALIPUR and [M:DPM1]STDDPMNUM <> GVML_MALISPA) Then
  # Si mode différent de LP, l'option 10  "Option mode linéaire " n'est pas accessible
   GMENLOC(GVML_OPMODLP)  = 1
  Endif


End

##########################################################################
Subprog AM_OPTTYP(VALEUR)
Variable Integer VALEUR

  If ( VALEUR = GVML_OPRPLPC or VALEUR = GVML_OPRPLPF ) Then
    [M:DPM2]OPTCOD(nolign-1) = GVML_COPBASE
  Elsif ( VALEUR = GVML_OPRPLAE ) Then
    [M:DPM2]OPTCOD(nolign-1) = GVML_CO1EREX
  Else
    [M:DPM2]OPTCOD(nolign-1) = GVML_COBSMTC
  Endif

  If ( VALEUR = GVML_OPMODIT ) Then
   # Option Mode : Italie  ( Option  par défaut : Prorata d'investissement )
   [M:DPM2]OPTCOD(nolign-1) = GVML_COPRINV
  Endif
  If ( VALEUR = GVML_OPMODBE ) Then
   # Option Mode : Belge  ( Option  par défaut : Sans Prorata)
   [M:DPM2]OPTCOD(nolign-1) = GVML_COPSANS
  Endif
  If ( VALEUR = GVML_OPMODAL ) Then
   # Option Mode : Allemand  ( Option  par défaut : Règle de simplification)
   [M:DPM2]OPTCOD(nolign-1) = GVML_COPRSIM
  Endif
  If ( VALEUR = GVML_OPMODLP ) Then
   # Option Mode : Linéaire  ( Option  par défaut : Priorité au taux)
   [M:DPM2]OPTCOD(nolign-1) = GVML_COPPRTX
  Endif
  If ( VALEUR= GVML_OPMODIT or VALEUR= GVML_OPMODBE or VALEUR= GVML_OPMODAL or VALEUR= GVML_OPMODLP ) Then
   # Option Mode : Italie, Belge, Allemagne, Linéaire
   # Blocage des autres champs de l'option
   Diszo [M:DPM2]OPTRAT(nolign-1)
   Diszo [M:DPM2]STRVLYDAT(nolign-1)
   Diszo [M:DPM2]ENDVLYDAT(nolign-1)
   Diszo [M:DPM2]REFDATTYP(nolign-1)
   [M:DPM2]DPRPLN(nolign-1) = G301AUC
  Endif

  Affzo [M:DPM2]

End

######################################################################################
Subprog AP_OPTTYP(VALEUR)
Variable Integer VALEUR

  If ( ([M:DPM1]STDDPMNUM= GVML_MADGBEL or [M:DPM1]STDDPMNUM= GVML_MALIBEL) and nolign > 1 ) Then
   # L'unique option pour ce mode a déjà été définie. Vous pouvez  éventuellement la modifier.
   GERR = 1
   GMESSAGE = mess(214,7770,1)
   mkstat = 2
   End
  Endif
End

##########################################################################
Subprog AS_OPTCOD(VALEUR)
Variable Integer  VALEUR

 # Ensemble des valeurs du ML316
 If (1 = 0 ) Then
    GMENLOC(GVML_COSANS)  = 1
    GMENLOC(GVML_COANNUI) = 1
    GMENLOC(GVML_COBSMTC) = 1
    GMENLOC(GVML_COBSDTC) = 1
    GMENLOC(GVML_COBSMTM) = 1
    GMENLOC(GVML_COPBASE) = 1
    GMENLOC(GVML_COPVNFE) = 1
    GMENLOC(GVML_COBSDDU) = 1
    GMENLOC(GVML_COVNDDR) = 1
    GMENLOC(GVML_CO1EREX) = 1
    GMENLOC(GVML_CO1ERPE) = 1
    GMENLOC(GVML_COPRSIM) = 1
    GMENLOC(GVML_COPSANS) = 1
    GMENLOC(GVML_COPRINV) = 1
    GMENLOC(GVML_COPRDES) = 1
    GMENLOC(GVML_COPMOIS) = 1
    GMENLOC(GVML_COPJOUR) = 1
    GMENLOC(GVML_COVNADR) = 1
    GMENLOC(GVML_COPVNA)  = 1
    GMENLOC(GVML_COBSADU) = 1
    GMENLOC(GVML_COPPRTX) = 1
  Endif


    GMENLOC(GVML_COANNUI) = 1
    GMENLOC(GVML_COBSMTM) = 1

  # Si le type option est "Remplacement taux" "Diminution taux" "Augmentation Taux"
  # la table ne doit présenter que les valeurs présentes dans la table "Type application du taux"
  If ( [M:DPM2]OPTTYP(nolign-1) = GVML_OPRPLTX or [M:DPM2]OPTTYP(nolign-1) = GVML_OPAUGTX or
&      [M:DPM2]OPTTYP(nolign-1) = GVML_OPDIMTX ) Then
    GMENLOC(GVML_COSANS)  = 1
    GMENLOC(GVML_COPBASE) = 1
    GMENLOC(GVML_COPVNFE) = 1
    GMENLOC(GVML_COBSDDU) = 1
    GMENLOC(GVML_COVNDDR) = 1
    GMENLOC(GVML_CO1EREX) = 1
    GMENLOC(GVML_CO1ERPE) = 1

    GMENLOC(GVML_COPRSIM) = 1
    GMENLOC(GVML_COPSANS) = 1
    GMENLOC(GVML_COPRINV) = 1
    GMENLOC(GVML_COPRDES) = 1
    GMENLOC(GVML_COPMOIS) = 1
    GMENLOC(GVML_COPJOUR) = 1
    GMENLOC(GVML_COVNADR) = 1
    GMENLOC(GVML_COPVNA)  = 1
    GMENLOC(GVML_COBSADU) = 1
    GMENLOC(GVML_COPPRTX) = 1
  # Si le type option est "Remplacement valeur plancher"
  # la table ne doit présenter que les valeurs présentes dans le champ "Type de valeur plancher"
  Elsif ( [M:DPM2]OPTTYP(nolign-1) = GVML_OPRPLPC ) Then
  # Si le type option est "Remplacement valeur plafond"
    GMENLOC(GVML_COBSMTC) = 1
    GMENLOC(GVML_COBSDTC) = 1
    GMENLOC(GVML_CO1EREX) = 1
    GMENLOC(GVML_CO1ERPE) = 1

    GMENLOC(GVML_COPRSIM) = 1
    GMENLOC(GVML_COPSANS) = 1
    GMENLOC(GVML_COPRINV) = 1
    GMENLOC(GVML_COPRDES) = 1
    GMENLOC(GVML_COPMOIS) = 1
    GMENLOC(GVML_COPJOUR) = 1
    GMENLOC(GVML_COVNADR) = 1
    GMENLOC(GVML_COPVNA)  = 1
    GMENLOC(GVML_COPPRTX) = 1
  # la table ne doit présenter que les valeurs présentes dans le champ "Type de valeur plafond"
  Elsif ( [M:DPM2]OPTTYP(nolign-1) = GVML_OPRPLPF ) Then
    GMENLOC(GVML_COBSMTC) = 1
    GMENLOC(GVML_COBSDTC) = 1
    GMENLOC(GVML_COBSDDU) = 1
    GMENLOC(GVML_COVNDDR) = 1
    GMENLOC(GVML_CO1EREX) = 1
    GMENLOC(GVML_CO1ERPE) = 1

    GMENLOC(GVML_COPRSIM) = 1
    GMENLOC(GVML_COPSANS) = 1
    GMENLOC(GVML_COPRINV) = 1
    GMENLOC(GVML_COPRDES) = 1
    GMENLOC(GVML_COPMOIS) = 1
    GMENLOC(GVML_COPJOUR) = 1
    GMENLOC(GVML_COVNADR) = 1
    GMENLOC(GVML_COPVNA)  = 1
    GMENLOC(GVML_COBSADU) = 1
    GMENLOC(GVML_COPPRTX) = 1
  # la table ne doit présenter que les valeurs présentes dans le champ "Type amt exceptionnel"
  Elsif ( [M:DPM2]OPTTYP(nolign-1) = GVML_OPRPLAE ) Then
    GMENLOC(GVML_COPBASE) = 1
    GMENLOC(GVML_COPVNFE) = 1
    GMENLOC(GVML_COBSMTC) = 1
    GMENLOC(GVML_COBSDTC) = 1
    GMENLOC(GVML_COBSDDU) = 1
    GMENLOC(GVML_COVNDDR) = 1

    GMENLOC(GVML_COPRSIM) = 1
    GMENLOC(GVML_COPSANS) = 1
    GMENLOC(GVML_COPRINV) = 1
    GMENLOC(GVML_COPRDES) = 1
    GMENLOC(GVML_COPMOIS) = 1
    GMENLOC(GVML_COPJOUR) = 1
    GMENLOC(GVML_COVNADR) = 1
    GMENLOC(GVML_COPVNA)  = 1
    GMENLOC(GVML_COBSADU) = 1
    GMENLOC(GVML_COPPRTX) = 1
  Endif

  # Si le mode est IT, seul les codes options 15 et 16 sont disponibles
  If ( [M:DPM1]STDDPMNUM = GVML_MAORDAN ) Then
    GMENLOC(GVML_COSANS)  = 1
    GMENLOC(GVML_COBSMTC) = 1
    GMENLOC(GVML_COBSDTC) = 1
    GMENLOC(GVML_COPBASE) = 1
    GMENLOC(GVML_COPVNFE) = 1
    GMENLOC(GVML_COBSDDU) = 1
    GMENLOC(GVML_COVNDDR) = 1
    GMENLOC(GVML_CO1EREX) = 1
    GMENLOC(GVML_CO1ERPE) = 1
    GMENLOC(GVML_COPRSIM) = 1
    GMENLOC(GVML_COPSANS) = 1
    GMENLOC(GVML_COPMOIS) = 1
    GMENLOC(GVML_COPJOUR) = 1
    GMENLOC(GVML_COVNADR) = 1
    GMENLOC(GVML_COPVNA)  = 1
    GMENLOC(GVML_COBSADU) = 1
    GMENLOC(GVML_COPPRTX) = 1
  Endif
  # Si le mode est DA seul le code option 12 est disponible
  If ( [M:DPM1]STDDPMNUM = GVML_MADGALL ) Then
    GMENLOC(GVML_COSANS)  = 1
    GMENLOC(GVML_COBSMTC) = 1
    GMENLOC(GVML_COBSDTC) = 1
    GMENLOC(GVML_COPBASE) = 1
    GMENLOC(GVML_COPVNFE) = 1
    GMENLOC(GVML_COBSDDU) = 1
    GMENLOC(GVML_COVNDDR) = 1
    GMENLOC(GVML_CO1EREX) = 1
    GMENLOC(GVML_CO1ERPE) = 1
    GMENLOC(GVML_COPSANS) = 1
    GMENLOC(GVML_COPRINV) = 1
    GMENLOC(GVML_COPRDES) = 1
    GMENLOC(GVML_COPMOIS) = 1
    GMENLOC(GVML_COPJOUR) = 1
    GMENLOC(GVML_COVNADR) = 1
    GMENLOC(GVML_COPVNA)  = 1
    GMENLOC(GVML_COBSADU) = 1
    GMENLOC(GVML_COPPRTX) = 1
  Endif
  # Si le mode est DB ou LB seul les codes options 13, 16, 17 sont disponibles
  If ( [M:DPM1]STDDPMNUM = GVML_MADGBEL or [M:DPM1]STDDPMNUM = GVML_MALIBEL ) Then
    GMENLOC(GVML_COSANS)  = 1
    GMENLOC(GVML_COBSMTC) = 1
    GMENLOC(GVML_COBSDTC) = 1
    GMENLOC(GVML_COPBASE) = 1
    GMENLOC(GVML_COPVNFE) = 1
    GMENLOC(GVML_COBSDDU) = 1
    GMENLOC(GVML_COVNDDR) = 1
    GMENLOC(GVML_CO1EREX) = 1
    GMENLOC(GVML_CO1ERPE) = 1
    GMENLOC(GVML_COPRSIM) = 1
    GMENLOC(GVML_COPRINV) = 1
    GMENLOC(GVML_COPRDES) = 1
    GMENLOC(GVML_COVNADR) = 1
    GMENLOC(GVML_COPVNA)  = 1
    GMENLOC(GVML_COBSADU) = 1
    GMENLOC(GVML_COPPRTX) = 1
  Endif
  # Si le mode est LP seul le code option 21 est disponible
  # FQ82045 GVML_MALISPA
  If ( [M:DPM1]STDDPMNUM = GVML_MALIPUR or [M:DPM1]STDDPMNUM = GVML_MALISPA) Then
    GMENLOC(GVML_COSANS)  = 1
    GMENLOC(GVML_COBSMTC) = 1
    GMENLOC(GVML_COBSDTC) = 1
    GMENLOC(GVML_COPBASE) = 1
    GMENLOC(GVML_COPVNFE) = 1
    GMENLOC(GVML_COBSDDU) = 1
    GMENLOC(GVML_COVNDDR) = 1
    GMENLOC(GVML_CO1EREX) = 1
    GMENLOC(GVML_CO1ERPE) = 1
    GMENLOC(GVML_COPRSIM) = 1
    GMENLOC(GVML_COPSANS) = 1
    GMENLOC(GVML_COPRINV) = 1
    GMENLOC(GVML_COPRDES) = 1
    GMENLOC(GVML_COPMOIS) = 1
    GMENLOC(GVML_COPJOUR) = 1
    GMENLOC(GVML_COVNADR) = 1
    GMENLOC(GVML_COPVNA)  = 1
    GMENLOC(GVML_COBSADU) = 1
  Endif

End

######################################################################################
Subprog AP_OPTCOD(VALEUR)
Variable Integer VALEUR

  If ( nolign > 1 ) Then
    Local Integer I_OPT
    Local Integer TOUS    : TOUS    = G_NON

    For I_OPT=1 To nolign-1
      If ( [M:DPM2]OPTTYP(nolign-1) = [M:DPM2]OPTTYP(I_OPT-1) and VALEUR = [M:DPM2]OPTCOD(I_OPT-1) ) Then
        If ( [M:DPM2]DPRPLN(I_OPT-1)= G301AUC ) Then
          TOUS = G_OUI
          Break
        Endif
      Endif
    Next I_OPT

    If ( TOUS = G_OUI ) Then
      # "Cette option est déjà appliquée pour tous les plans en ligne n"
      GERR     = 1
      GMESSAGE = mess(180,7770,1)-num$(I_OPT)
      mkstat   = 2
      End
    Endif
  Endif

End

########################################
Subprog AS_OPTRAT(VALEUR)
Variable Decimal VALEUR

  # Pas de saisie de taux si pas nécessaire

  If (   [M:DPM2]OPTCOD(nolign-1) = GVML_COSANS  )  Then
    mkstat = 2
    VALEUR = 0
  Endif

  If ( [M:DPM2]OPTTYP = GVML_OPMODIT or [M:DPM2]OPTTYP = GVML_OPMODBE or
&      [M:DPM2]OPTTYP = GVML_OPMODAL or [M:DPM2]OPTTYP = GVML_OPMODLP) Then
    mkstat = 2
    VALEUR = 0
  Endif

End

########################################
Subprog AS_STRVLYDAT(VALEUR)
Variable Date    VALEUR


  If ( [M:DPM2]OPTTYP = GVML_OPMODIT or [M:DPM2]OPTTYP = GVML_OPMODBE or
&      [M:DPM2]OPTTYP = GVML_OPMODAL or [M:DPM2]OPTTYP = GVML_OPMODLP) Then
    mkstat = 2
  Endif

End

########################################
Subprog AM_STRVLYDAT(VALEUR)
Variable Date    VALEUR

  If ( VALEUR <> [0/0/0] ) Then
    Actzo [M:DPM2]ENDVLYDAT(nolign-1)
    Actzo [M:DPM2]REFDATTYP(nolign-1)
  Else
    [M:DPM2]ENDVLYDAT = [0/0/0]
    Affzo [M:DPM2]ENDVLYDAT(nolign-1)
    [M:DPM2]REFDATTYP= GVML_DRSANS
    Affzo [M:DPM2]REFDATTYP(nolign-1)

    Diszo [M:DPM2]ENDVLYDAT(nolign-1)
    Diszo [M:DPM2]REFDATTYP(nolign-1)
  Endif

End

########################################
Subprog C_ENDVLYDAT(VALEUR)
Variable Date    VALEUR

  If ( VALEUR <> [0/0/0] and VALEUR < [M:DPM2]STRVLYDAT(nolign-1) ) Then
    GERR= 1 : GMESSAGE= mess(3,7770, 1)
    mkstat = 2 : End
  Endif

End

########################################
Subprog AS_REFDATTYP(VALEUR)
Variable Integer VALEUR

  If [M:DPM2]STRVLYDAT(nolign-1) <> [0/0/0]
    GMENLOC(4)=1
  Endif

End

##########################################################################
Subprog C_OPTRAT(VALEUR)
Variable Decimal VALEUR

Local Decimal TAUX

  # Si type option est égal à "Remplacement taux constant" le taux doit être compris entre 1 et 100
  If ( [M:DPM2]OPTTYP(nolign-1) = GVML_OPRPLTX ) Then
    If ( VALEUR < 1  or VALEUR > 100 ) Then
      GERR= 1 : GMESSAGE= mess(15,7770, 1)
      mkstat = 2 : End
    Endif
  Elsif ( [M:DPM2]OPTTYP(nolign-1) = GVML_OPAUGTX  and [M:DPM1]DPRMODTYP  = GVML_TMLIBRE  ) Then
  # Si type option est égal à "Augmentation taux constant" le taux constant augmenté de la valeur du champ
  # doit être compris entre 1 et 100
    [L]TAUX = [M:DPM1]CNSRAT + VALEUR
    If ( [L]TAUX < 1  or [L]TAUX > 100 ) Then
      GERR= 1 : GMESSAGE= mess(15,7770, 1)
      mkstat = 2 : End
    Endif
  Elsif ( [M:DPM2]OPTTYP(nolign-1) = GVML_OPDIMTX  and [M:DPM1]DPRMODTYP  = GVML_TMLIBRE   ) Then
  # Si type option est égal à "Diminution taux constant" le taux constant diminué de la valeur du champ
  # doit être compris entre 1 et 100
    [L]TAUX = [M:DPM1]CNSRAT - VALEUR
    If ( [L]TAUX < 1  or [L]TAUX > 100 ) Then
      GERR= 1 : GMESSAGE= mess(15,7770, 1)
      mkstat = 2 : End
    Endif
  Endif

  # Si type option est égal à "Remplacement valeur plancher" et que les champs code option et type valeur
  # plafond sont de même type, le taux option doit être <= au taux plafond
  If ( [M:DPM2]OPTTYP(nolign-1) = GVML_OPRPLPC ) and ( [M:DPM2]OPTCOD(nolign-1) = [M:DPM1]MAXDPRTYP ) Then
    If ( VALEUR > [M:DPM1]MAXDPRRAT)
      GERR= 1 : GMESSAGE= mess(15,7770, 1)
      mkstat = 2 : End
    Endif
  Endif

  # Si type option est égal à "Remplacement valeur plafond" et que les champs code option et type valeur
  # plancher sont de même type, le taux option doit être >= au taux plancher
  If ( [M:DPM2]OPTTYP(nolign-1) = GVML_OPRPLPF ) and ( [M:DPM2]OPTCOD(nolign-1) = [M:DPM1]MINDPRTYP ) Then
    If ( VALEUR < [M:DPM1]MINDPRRAT)
      GERR= 1 : GMESSAGE= mess(15,7770, 1)
      mkstat = 2 : End
    Endif
  Endif

  # Si type option est égal à "Remplacement amt exceptionnel" et que le champ règle application taux est
  # égal à taux par annuité, la somme des taux du tableau taux d'amortissement augmenté de la valeur de
  # taux option ne doit pas dépasser 100
  If ( [M:DPM2]OPTTYP(nolign-1) = GVML_OPRPLAE ) and ( [M:DPM1]RATCOETYP = GVML_COANNUI ) Then
    [L]TAUX = VALEUR
    For N_I = 0 To NBLIG1 - 1
        [L]TAUX += [M:DPM1]RAT(N_I)
    Next N_I

    If ( [L]TAUX > 100 )
      GERR= 1 : GMESSAGE= mess(15,7770, 1)
      mkstat = 2 : End
    Endif
  Endif

End

##########################################################################
Subprog AS_DPRPLN(VALEUR)
Variable Integer VALEUR

Local Integer I

  If ( [M:DPM0]CPY <> "" ) Then
    Call VIRE_PLN_CUR_DIFFERENTE ([M:DPM0]CPY, '', G301AUC) From GLOBIENS
  Endif
  If ( G_ACTIAS = G_NON ) Then :  GMENLOC(G301IAS) = 1 : Endif
  If ( G_ACTGRT = G_NON ) Then :  GMENLOC(G301SUB) = 1 : Endif
  If ( [M:DPM1]DPRMODTYP = GVML_TMSTAND ) Then
    # Si mode standard l'option s'aplique toujours pour tous les plans
    GMENLOC(G301CPT) = 1 : GMENLOC(G301FIS) = 1 : GMENLOC(G301MIN) = 1
    GMENLOC(G301ORI) = 1 : GMENLOC(G301R76) = 1 : GMENLOC(G301IAS) = 1
    GMENLOC(G301TEC) = 1 : GMENLOC(G301RET) = 1 : GMENLOC(G301SUB) = 1
    GMENLOC(G301LI1) = 1 : GMENLOC(G301LI2) = 1 : GMENLOC(G301LI3) = 1
    GMENLOC(G301LI4) = 1 : GMENLOC(G301LI5) = 1 : GMENLOC(G301LI6) = 1
  Endif

End

######################################################################################
Subprog AP_DPRPLN(VALEUR)
Variable Integer VALEUR

  #-1 --------------------------------
  If ( nolign > 1 ) Then
    Local Integer I_OPT
    Local Integer DOUBLON      : DOUBLON      = G_NON
    Local Integer INCOMPATIBLE : INCOMPATIBLE = G_NON
    #>>>>>>>>>>>>>>
    For I_OPT = 1 To nolign-1
      If ( [M:DPM2]OPTTYP(nolign-1)=[M:DPM2]OPTTYP(I_OPT-1) and
&          [M:DPM2]OPTCOD(nolign-1)=[M:DPM2]OPTCOD(I_OPT-1)   ) Then

        If ( VALEUR =[M:DPM2]DPRPLN(I_OPT-1) ) Then
          DOUBLON = G_OUI
          Break
        Endif
        If ( VALEUR=G301AUC and [M:DPM2]DPRPLN(I_OPT-1)<>G301AUC ) Then
          INCOMPATIBLE = G_OUI
          Break
        Endif
      Endif
    Next I_OPT
    #<<<<<<<<<<<<<<<

    If ( DOUBLON = G_OUI ) Then
      GERR     = 1
      GMESSAGE = mess(177,7770,1)-num$(I_OPT) #"Option déjà paramétrée en ligne n "
      mkstat   = 2
      End
    Endif
    If INCOMPATIBLE=G_OUI
      GERR     = 1
      GMESSAGE = mess(178,7770,1)+"\"+mess(179,7770,1)
      mkstat   = 2
    Endif
  Endif
  #-1 --------------------------------

End



##########################################################################
#  S/P liés à la gestion de l'écran
##########################################################################



#########################################################
#*! Syracused in class DPRMOD as method GET_STDDPM in DPRMOD_C_MPR
Subprog DETERM_STDDPM()

Local Shortint I

  # Détermination du mode d'amortissement standard
  # en fonction de STDDPMNUM via le menu local 428
  # Incrémentation dans le cas d'une méthode libre.

  If ([M:DPM1]DPRMODTYP = GVML_TMSTAND ) Then
    Case [M:DPM1]STDDPMNUM
      When GVML_MASLINE : [M:DPM0]STDDPM = "UL"   : # Straight Line
      When GVML_MACADUC : [M:DPM0]STDDPM = "CA"   : # Caducité
      When GVML_MADGALL : [M:DPM0]STDDPM = "DA"   : # Dégressif allemand
      When GVML_MADGBEL : [M:DPM0]STDDPM = "DB"   : # Dégressif belge
      When GVML_MADCLBA : [M:DPM0]STDDPM = "UD"   : # Declining balance
      When GVML_MADGESP : [M:DPM0]STDDPM = "DE"   : # Dégressif espagnol
      When GVML_MADGFRA : [M:DPM0]STDDPM = "DF"   : # Dégressif français
      When GVML_MADGMAL : [M:DPM0]STDDPM = "DX"   : # Dégressif allemand mixte
      When GVML_MADGPOR : [M:DPM0]STDDPM = "DP"   : # Dégressif portugais
      When GVML_MADGMES : [M:DPM0]STDDPM = "DI"   : # Dégressif espagnol mixte
      When GVML_MARESID : [M:DPM0]STDDPM = "RE"   : # Résiduelle
      When GVML_MAFRMML : [M:DPM0]STDDPM = "FM"   : # Formes & moules
      When GVML_MALIESP : [M:DPM0]STDDPM = "LE"   : # Linéaire espagnol
      When GVML_MALINGE : [M:DPM0]STDDPM = "LG"   : # Linge
      When GVML_MALIPUR : [M:DPM0]STDDPM = "LP"   : # Linéaire français
      When GVML_MAPROGR : [M:DPM0]STDDPM = "PR"   : # Progressif
      When GVML_MANOAMT : [M:DPM0]STDDPM = "SA"   : # Sans amortissement
      When GVML_MASOFTY : [M:DPM0]STDDPM = "SY"   : # SOFTY
      When GVML_MAUNITO : [M:DPM0]STDDPM = "UO"   : # Unité d'oeuvre
      When GVML_MALADVR : [M:DPM0]STDDPM = "LV"   : # Linéaire au delà VN nulle
      When GVML_MADGPOM : [M:DPM0]STDDPM = "DV"   : # Dégressif portugais mixte
      When GVML_MAORDAN : [M:DPM0]STDDPM = "IT"   : # Ordinario / Anticipato
      When GVML_MAPORPC : [M:DPM0]STDDPM = "PC"   : # Portugais constantes
      When GVML_MAPORPD : [M:DPM0]STDDPM = "PD"   : # Portugais duodecimos
      When GVML_MACARSD : [M:DPM0]STDDPM = "RA"   : # Caducité résiduelle
      When GVML_MALIBEL : [M:DPM0]STDDPM = "LB"   : # Linéaire belge
      When GVML_MADGMAR : [M:DPM0]STDDPM = "DM"   : # Degressif marocain   ( FQ55960 )
      When GVML_MALIRUS : [M:DPM0]STDDPM = "LR"   : # Linéaire russe       ( FQ59941 )
      When GVML_MADGRUS : [M:DPM0]STDDPM = "DR"   : # Linéaire russe       ( FQ59941 )
      When GVML_MACORUS : [M:DPM0]STDDPM = "CR"   : # Constant russe       ( FQ59941 )
      When GVML_MASYRUS : [M:DPM0]STDDPM = "SR"   : # SOFTY    russe       ( FQ59941 )
      When GVML_MAUORUS : [M:DPM0]STDDPM = "UR"   : # Unité d'oeuvre russe ( FQ59941 )
      When GVML_MALIPOL : [M:DPM0]STDDPM = "ML"   : # Linéaire polonais    ( FQ67577 )
      When GVML_MADGPOL : [M:DPM0]STDDPM = "MD"   : # Dégressif polonais   ( FQ72372 )
      When GVML_MALIROM : [M:DPM0]STDDPM = "RL"   : # Linéaire roumain     ( FQ77877 )
      When GVML_MAACROM : [M:DPM0]STDDPM = "RX"   : # Accéléré roumain     ( FQ77877 )
      When GVML_MADGROM : [M:DPM0]STDDPM = "RD"   : # Dégressif roumain    ( FQ77877 )
      When GVML_MALISPA : [M:DPM0]STDDPM = "SL"   : # Linéaire espagnol jour ( FQ82075)
      When GVML_MAONEP  : [M:DPM0]STDDPM = "1P"   : # One period           ( FQ84110)
      When GVML_MAPRIMC : [M:DPM0]STDDPM = "AL"   : # Prime cost           ( FQ84283)
      When GVML_MADVALU : [M:DPM0]STDDPM = "AD"   : # Diminishing value    ( FQ84283)
      When GVML_MALISUI : [M:DPM0]STDDPM = "HL"   : # Linéaire suisse      ( FQ84281)
      When GVML_MADGSUI : [M:DPM0]STDDPM = "HD"   : # Dégressif suisse     ( FQ84281)
      When GVML_MALITUR : [M:DPM0]STDDPM = "TL"   : # Linéaire turque      ( FQ105809)
      When GVML_MADGTUR : [M:DPM0]STDDPM = "TD"   : # Dégressif turque     ( FQ105809)
      When Default
   Endcase
 Else
   If (GREP <> "M") Then
     [M:DPM0]STDDPM = ""
     For I = 0 To 99
       Look [DPMA]DPM3=format$("N0:2",I)
       If (fstat) Then
         [M:DPM0]STDDPM = format$("N0:2",I)
         Break
       Endif
     Next I
   Endif
 Endif

End


##########################################################################
Subprog CHARGE_DPM3(PCPY)

Value Char PCPY

  # Chargement de l'onglet "Plans concernés"
  # Tous les plans de l'onglet sont par défaut concernés.

  If (PCPY = "") Then
    nolign = 0
    For I = 1 To G301MAX
      If ( (G_ACTIAS = G_OUI and I = G301IAS)  or (G_ACTGRT = G_OUI and I = G301SUB)  or
&          ( I <> G301AUC and I <> G301IAS and I <> G301SUB ) ) Then
        nolign += 1
        [M:DPM3]DPRPLN(nolign-1) = I
        [M:DPM3]APLFLG(nolign-1) = G_OUI
     Endif
    Next I
  Else
    nolign = 0
    For [CNX]CNX0 Where CPY =PCPY
      For I = 0 To [F:CNX]NBPLC-1
        nolign += 1
        [M:DPM3]DPRPLN(nolign-1) = [F:CNX]PLNCAA(I)
        [M:DPM3]APLFLG(nolign-1) = G_OUI
      Next I
    Next
  Endif
  [M:DPM3]NBLIG3 = nolign
  Affzo [M:DPM3]

End


########################################
Subprog CONDITIONNE_STD_LIB(PDPRMODTYP)
Value Shortint PDPRMODTYP


  If ( PDPRMODTYP  = GVML_TMSTAND ) Then : #  Standard
    # Standard
    Actzo [M:DPM1]CRY
    # FQ61528
    #Actzo [M:DPM1]LEG
    If (dim([M:DPM1]LEG)>0 ) Then : Actzo [M:DPM1]LEG : Endif
    Diszo [M:DPM0]DES

    # FQ59941
    If (  [M:DPM1]RSDDPMTGR = G_DPMRE       and
&         [M:DPM1]STDDPMNUM <> GVML_MALIRUS and
&         [M:DPM1]STDDPMNUM <> GVML_MARESID and
&         [M:DPM1]STDDPMNUM <> GVML_MASLINE  ) Then
      Actzo [M:DPM1]PRATYPTGR
    Else
      Diszo [M:DPM1]PRATYPTGR
    Endif

    If ( [M:DPM1]STDDPMNUM = GVML_MAPORPC or [M:DPM1]STDDPMNUM = GVML_MAPORPD ) Then
      Actzo [M:DPM1]RSDDPMTGR
    Else
      Diszo [M:DPM1]RSDDPMTGR
    Endif

    # Si les textes sont différents, l'icône de mise à jour de la désignation apparait
    If ( GREP <> "C" ) and ( [M:DPM0]DES <> mess([M:DPM1]STDDPMNUM,3228,1) ) Then
      Actzo [M:DPM0]MAJDES
    Else
      Diszo [M:DPM0]MAJDES
    Endif

    If ( [M:DPM0]UTILISE = G_OUI ) Then
      Diszo [M:DPM1]STDDPMNUM
    Else
      Actzo [M:DPM1]STDDPMNUM
    Endif

    # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
    Diszo [M:DPM1]RATCOETYP, CNSRAT, RATNBR, RATCUM, NBLIG1, FIRFIYFLG, ANIDATFLG, PROTYP,
&                 BASTYP, ETRDATTYP, ENDDPRTYP, ENDDATTYP, MINDPRLIF, MINDPRTYP,
&                 MINDPRRAT, MAXDPRTYP, MAXDPRRAT, EXCDPRTYP, EXCDPRRAT, DPRDISRUL

  Else

    # Libre
    Actzo [M:DPM0]DES
    Actzo [M:DPM1]RSDDPMTGR
    If (  [M:DPM1]RSDDPMTGR = G_DPMRE ) Then
      Actzo [M:DPM1]PRATYPTGR
    Else
      Diszo [M:DPM1]PRATYPTGR
    Endif

    [M:DPM1]STDDPMNUM = 0
    Diszo [M:DPM1]STDDPMNUM
    Diszo [M:DPM0]MAJDES

    [M:DPM1]CRY = ""
    Affzo [M:DPM1]CRY
    Diszo [M:DPM1]CRY

    # FQ61528
    #[M:DPM1]LEG = ""
    #Affzo [M:DPM1]LEG
    #Diszo [M:DPM1]LEG
    If (dim([M:DPM1]LEG) > 0) Then
      [M:DPM1]LEG = ""
      Affzo [M:DPM1]LEG
      Diszo [M:DPM1]LEG
    Endif

    If ([M:DPM0]UTILISE = G_OUI) Then
     Diszo [M:DPM1]RATCOETYP, CNSRAT, RATNBR, RATCUM, NBLIG1, FIRFIYFLG, ANIDATFLG, PROTYP,
&                 BASTYP, ETRDATTYP, ENDDPRTYP, ENDDATTYP, MINDPRLIF, MINDPRTYP,
&                 MINDPRRAT, MAXDPRTYP, MAXDPRRAT, EXCDPRTYP, EXCDPRRAT, DPRDISRUL  : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
    Else
     Actzo [M:DPM1]RATCOETYP, CNSRAT, RATNBR, RATCUM, NBLIG1, FIRFIYFLG, ANIDATFLG, PROTYP,
&                 BASTYP, ETRDATTYP, ENDDPRTYP, ENDDATTYP, MINDPRLIF, MINDPRTYP,
&                  MINDPRRAT, MAXDPRTYP, MAXDPRRAT, EXCDPRTYP, EXCDPRRAT, DPRDISRUL  : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
    Endif

    # Si Type Taux/coef = "Taux par Annuité" ou = "Multiplier la base par un taux mensuel"
    # alors saisie  d'un nombre de taux sinon saisie d'un taux constant
    If [M:DPM1]RATCOETYP= GVML_COANNUI or [M:DPM1]RATCOETYP= GVML_COBSMTM
      Diszo [M:DPM1]CNSRAT
    Else
      Diszo [M:DPM1]RATNBR
    Endif

    # Si  Type Taux/coef = "Multiplier Base par Tx Mensuel"
    # alors le type de prorata ne peut être que "Mois"
    # alors le type de date d'entrée/sortie ne peut être qu' "Au jour précisé"
    If [M:DPM1]RATCOETYP= GVML_COBSMTM
      Diszo [M:DPM1]PROTYP
    Else
      If ( [M:DPM0]UTILISE = G_NON ) Then
        Actzo [M:DPM1]PROTYP
      Endif
    Endif

    # si Type Valeur plancher = "% base d'amt" ou "% valeur nette fin ex précédent"
    # rendre le taux valeur plancher saisissable sinon rendre le champ insaisissable.
    If  not ( [M:DPM1]MINDPRTYP = GVML_COPBASE or [M:DPM1]MINDPRTYP = GVML_COPVNFE  ) Then
      Diszo [M:DPM1]MINDPRRAT
    Endif

    # si Type Valeur plafond = "% base d'amt" ou "% valeur nette fin ex. précédent"
    # rendre le taux valeur plafond  saisissable sinon rendre le champ insaisissable.

    If  not ( [M:DPM1]MAXDPRTYP = GVML_COPBASE or [M:DPM1]MAXDPRTYP = GVML_COPVNFE ) Then
      Diszo [M:DPM1]MAXDPRRAT
    Endif

    # si Type Amt except. = 2 (A réintégrer sur le 1er ex.) ou 3 (A réintégrer sur la 1ere per.)
    # rendre le taux Amt except. saisissable sinon rendre le champ insaisissable.

    If not ([M:DPM1]EXCDPRTYP = GVML_CO1EREX or [M:DPM1]EXCDPRTYP = GVML_CO1ERPE ) Then
      Diszo [M:DPM1]EXCDPRRAT
    Endif

  Endif



End


########################################
#*! Syracused in class DPRMOD as operation GET_DEFINITION_LEVEL in DPRMOD_C_MPR
Funprog DPM_DEFINI(PDPM)
# Reçoit un mode d'amortissement sous la forme ( Mode)
#    rend = 0 si le mode n'est pas défini
#    rend > 0 si le mode est défini
#    rend 1 si le mode est défini par défaut
#    rend 2 si le mode est défini pour au moins une société particulière
# ------------------------------------------------------------------------------

Value Char PDPM
Local Integer RRET

  Filter [DPMA] Where DPM = PDPM
  Read [DPMA]DPM0 First
  Filter [DPMA]
  If (fstat) Then
    RRET = 0
  Elsif ([F:DPMA]CPY="") Then
    RRET = 1
  Else
    RRET = 2
  Endif

End RRET


########################################
#*! Syracused in process FXLIB_DPRMOD as function IS_DPM_USED
Funprog DEP_UTILISE_DPM(PDPM,PCPY)
# Reçoit un mode d'amortissement
# et rend 1 si le mode est utilisé par un bien comptable
# ou rend 0 dans le cas contraire
# ------------------------------------------------------------------------------

Value Char  PDPM, PCPY

Local Integer RRET
Local Char CRITERE

  RRET = 0
  CRITERE = 'DPM=PDPM'
  If ( PCPY <> "" ) Then : CRITERE += ' & CPY=PCPY' : Endif

  For [DEP]DEP2 Where evalue(CRITERE)
    RRET=1
    Break
  Next

End RRET



#########################################################
#*! Syracused in class DPRMOD as operation IS_RSDDPMTGR_VALID in DPRMOD_C_MPR
Funprog  IS_MODE_LIBRE_CIBLE_VALIDE (PMOD, PMODTGR, PBASTYP)
#
# - Objet  : Retourne 1 si le mode d'amortissement en entrée peut être utilisé
#            comme mode cible pour un mode libre.
#
# - Entrée :
#
#
# - Sortie :
#   Boite noire
#
#

Value    Char    PMOD
Value    Char    PMODTGR
Value    Integer PBASTYP

Local Integer RTRN

  If clalev([F:WDPM])=0   : Local File DPRMOD     [WDPM]   :  Endif      : # Modes d'amortissement

  RTRN = 0
  If ( PMOD = PMODTGR ) Then
    # Le mode cible est équivalent au mode d'origine
    # Il doit être amorti sur valeur nette
    If ( PBASTYP = GVML_TBVLNET or
&        PBASTYP = GVML_TBVNAMT     ) Then
      # Mode cible est un mode libre amorti sur valeur nette
      RTRN = 1
    Endif
  Else
    Read [WDPM]DPM0 = PMODTGR
    If !(fstat) Then
    # Lecture OK
      If ([F:WDPM]STDDPMNUM = GVML_MARESID or
&         [F:WDPM]STDDPMNUM = GVML_MADCLBA or
&         [F:WDPM]STDDPMNUM = GVML_MADGALL or
&         [F:WDPM]STDDPMNUM = GVML_MADGBEL or
&         [F:WDPM]STDDPMNUM = GVML_MADGESP or
&         [F:WDPM]STDDPMNUM = GVML_MADGFRA or
&         [F:WDPM]STDDPMNUM = GVML_MADGMAL or
&         [F:WDPM]STDDPMNUM = GVML_MADGPOR or
&         [F:WDPM]STDDPMNUM = GVML_MADGMES or
&         [F:WDPM]STDDPMNUM = GVML_MADGPOM     ) Then
        # Mode cible est un mode standard résiduel
        RTRN = 1
      Elsif ( [F:WDPM]STDDPMNUM = 0 ) Then
        If ( [F:WDPM]BASTYP = GVML_TBVLNET or
&            [F:WDPM]BASTYP = GVML_TBVNAMT     ) Then
          # Mode cible est un mode libre amorti sur valeur nette
          RTRN = 1
        Endif
      Endif
    Endif
  Endif


End RTRN








