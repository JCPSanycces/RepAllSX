#<AdxTL>@(#)7.0.0.0 $Revision$
#######################################################################################################################
#  Affichage XML d'un historique Tiers                                        Module CRM          14 Septembre 2004   #
#######################################################################################################################
##########################################################
# Détail des paramètres 
#
# PARAM(1) : Code tiers
# PARAM(2) : Feuille XSLT.
# PARAM(3) : Contexte d'exécution.
# PARAM(4) : Ordre des colonnes.
#########################################################
#######################################################################################################################
$ACTION
  Case ACTION
    When "INIT"        : Gosub INITHBP1
    When "EXEC"        : Gosub EXECHBP1
    When Default
  Endcase
Return

#######################################################################################################################
$INITHBP1
Local Char SZXSLTSHEET

  SZXSLTSHEET = PARAM(2)
  If PARAM(1) = "" Then
    #Aucun tiers n'est précisé. Action abandonnée.
    GMESSAGE = mess(156,177,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  Read [BPR]BPR0=PARAM(1)
  If fstat Then
    #Le tiers indiqué est incorrect. Action abandonnée.
    GMESSAGE = mess(157,177,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  Gosub CHECKXSL From TRTMGGXSL1
  If FIN = 1 Then
    Return
 Endif
Return

#######################################################################################################################
$EXECHBP1
Local Char RETOUR
Local Char SZFULLFILENAME(250)
Local Char SZFILENAME(250)
Local Integer ICHAPTER
Local Integer IERRINF

  IERRINF = 0
  ICHAPTER = 0
  If PARAM(2) = "" Then
    Call HBP1INXML(PARAM(1), PARAM(4), 1, "STD", PARAM(3), SZFULLFILENAME, SZFILENAME, ICHAPTER, IERRINF) From SUBHBP1XML
  Else
    Call HBP1INXML(PARAM(1), PARAM(4), 1, PARAM(2), PARAM(3), SZFULLFILENAME, SZFILENAME, ICHAPTER, IERRINF) From SUBHBP1XML
  Endif
  If IERRINF = 0 Then
    Callui RETOUR = "" With "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) + "Report",
&                           "UILocalFile="+ chr$(1) + SZFILENAME
  Endif
Return
