#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC15          Moulinette de Migration              Module TRC  #
##########################################################################
# From TRCMAJ30  : UPDCFB   : new field LLCTYP                           #
##########################################################################
# Issues 80101 & 80102 & get VERSION number - GA 02/2012
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(WDOSSIER,"") From SAIDOS
Endif
If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 107271 - 2015-08-05 by CCC
  #Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif
  If !func DOSSUB.FILL_ADS(WDOSSIER): End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC15") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRC15(WDOSSIER)
  Call MAJ_UUMGTRTTRC15(WDOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
  If APPLI=GDOSX3 : End : Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 107271 - 2015-08-05 by CCC
  #Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If !func DOSSUB.FILL_ADS(APPLI): End : Endif
  Call MAJ_UUMGTRTTRC15(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC15(APPLI)
End

##########################################################################
Subprog MAJ_UUMGTRTTRC15(WDOSSIER)
Value Char WDOSSIER

adxftl=10
adxwrb=10
NEWMOTEUR=1

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 107271 - 2015-08-05 by CCC
#Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif
If !func DOSSUB.FILL_ADS(WDOSSIER): End : Endif

# Présence du Configurateur dans le dossier cible: code activité CFG
Local File =WDOSSIER+".ACTIV"    [ACV]
Local Integer WCFG
Call LECACT("CFG",WCFG) From TRTX3

# Présence du Configurateur
If WCFG=1
  GOK=1
  Gosub LOA_BOM From UUMGTRTTRC00

  Gosub UPDCFB
  If GOK<=0
      Call ECR_TRACE("UUMGTRTTRC15 table ITMBOMCFG Incorrectly Processed : Update CFB"-WDOSSIER,1) From GESECRAN
  Endif
Else
  Call ECR_TRACE("UUMGTRTTRC15: CFG not activated on folder"-WDOSSIER,0) From GESECRAN
  Local Integer ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC15",3,ERR) From TRTMIG : #3=Terminée
Endif

End
##########################################################################
Subprog RAZ_UUMGTRTTRC15(WDOSSIER)
Value Char WDOSSIER

Local Integer ERR

GOK=1

#1 - verifications
####################

If [F:ADS]MODULE(8)<>2 | [F:ADS]MODULE(7)<>2 : End : Endif          : # N= no module

Local Char WNAMFICM
Call MIGTABNAME (WDOSSIER,"ITMBOMCFG",WNAMFICM,ERR) From TRTMIG
If ERR : End : Endif

##2 - On vide les fichiers selon le cas
#######################################

If  filinfo(filpath("FIL","ITMBOMCFG","fde",WDOSSIER),0)>0
& & filinfo(filpath("FIL",WNAMFICM,"fde",WDOSSIER),0)>0
  #Call ECR_TRACE("RAZ_UUMGTRTTRC15 Raz table ITMBOMCFG"-WDOSSIER,0) From GESECRAN
  Call MIGTABRAZ (WDOSSIER,"ITMBOMCFG",ERR) From TRTMIG
  Call MIGRAZKEY (WDOSSIER,"UUMGTRTTRC15",ERR) From TRTMIG
Endif

End

####################################################################################
$UPDCFB
Local Integer ERR

GOK=1

##1 - verifications
####################

If [F:ADS]MODULE(8)<>2 | [F:ADS]MODULE(6)<>2  : # Modules 9=Tronc commun et 7=Stocks
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC15",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

If filinfo(filpath("FIL","ITMBOMCFG","fde",WDOSSIER),0) <=0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC15",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

Call ECR_TRACE("UUMGTRTTRC15 Start trace : ITMBOMCFG => BOMALTTYP" ,0) From GESECRAN

Local Char WNAMFICM
Call MIGTABNAME (WDOSSIER,"ITMBOMCFG",WNAMFICM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC15",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif

#----- Is old renamed file ok ?...  -----#
If filinfo(filpath("FIL",WNAMFICM,"fde",WDOSSIER),0) < 0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC15",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC15",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (WDOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC15",7,ERR) From TRTMIG : #7=Erreur
  Return : # End # 2015-11-09 by GH
Endif

###################

Call ECR_TIME("UUMGTRTTRC15 table ITMBOMCFG Process : Update CFB") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC15:Process Start on : "+WDOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (WDOSSIER,"ITMBOMCFG",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:CFB])  = 0 : Local File =WDOSSIER+".ITMBOMCFG"    [CFB]  : Endif   # Fichier X3 "Vide"
If clalev([F:CFBM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM [CFBM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
Local Char WTAB_CFB (100) (adxwrb) : # Issue 112303 - 2015-11-09 by GH - not to do before MIG_OUVRE
Local Shortint WCPT_CFB

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30) # Issue 80101 ajout HINTSPE
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE

# Déclaration des variables communes de travail
Local Integer I, J

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (WDOSSIER,"UUMGTRTTRC15",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC15" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CFB00
Raz NB
# Clé CFB0=ITMREF+BOMALT (ancienne table)
If STOP = 1
 STOP = 2
 CRITERE = "[F:CFBM]ITMREF=TABMIGKEY(1) & [F:CFBM]BOMALT>"+TABMIGKEY(2)
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:CFBM]ITMREF>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [CFB]
GOK = 1

# Issue 78741 don't create ITB when BOMALT=0
For [CFBM] Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE) & BOMALT>0

  NBLUS += 1

  # PE pour exclure ligne
  If FILTRELIN
      ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_CFB  : Endif
  Endif

  #Raz [F:CFB]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_CFB
  Endif

  [F:CFB] = [F:CFBM]

  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_CFB
    If GOK<1 : Break : Endif
  Endif

  # --- alimentation des champs et écriture enreg
  If NEWMOTEUR
      Gosub CFB_STK : # pour stocker ref
      WriteB [F:CFB]
  Else
      Write [F:CFB]
  Endif
  If fstat
    If NEWMOTEUR & adxwrb>1
      Call ECR_TRACE("File ITMBOMCFG, Error ="-num$(fstat),1) From GESECRAN
      Gosub CFB_ERRTRA : # pour afficher les ref
    Else
      Call ECR_TRACE("File ITMBOMCFG(ITMREF/BOMALT)"-[F:CFB]ITMREF+"/"+num$([F:CFB]BOMALT)+", ERROR ="-num$(fstat),1) From GESECRAN
    Endif
    GOK=0 : Break
  Endif

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:CFBM]ITMREF
    TABMIGKEY(2) = num$([F:CFBM]BOMALT)
    STOP=1
    Break
  Endif
$NEXT_CFB
Next

$END_CFB
If GOK<1
  Rollback
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC15",7,ERR) From TRTMIG : #7=Erreur
Else
  If NEWMOTEUR & adxwrb>1
    Flush [F:CFB]
    If fstat
        Call ECR_TRACE("File ITMBOMCFG, Error ="-num$(fstat),1) From GESECRAN
        Gosub CFB_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_CFB : #on part sur rollback
    Endif
  Endif
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  # Stocker les valeurs de ACLE1/ACLE2/STOP dans la table AMIGKEY.
  Call MIGSTKKEY (WDOSSIER,FLUX,NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto END_CFB
  Endif
  Commit
  Call MIGSTKPROGRESS (WDOSSIER,"UUMGTRTTRC15",STOP,ERR) From TRTMIG
  NBCOMMIT+=NB
  If STOP
    Goto LOOP_CFB00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [CFB]
Close Local File [CFBM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (WDOSSIER,"ITMBOMCFG",ERR) From TRTMIG
Call MIGTRTEND (WDOSSIER,"UUMGTRTTRC15") From TRTMIG
Call ECR_TIME("UUMGTRTTRC15:"+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
Return

#######################################################################
$CFB_STK
Call STK (WTAB_CFB,WCPT_CFB,[F:CFB]ITMREF+"/"+num$([F:CFB]BOMALT)) From TRTMIG
Return

#######################################################################
$CFB_ERRTRA
Call ERRTRA (WTAB_CFB,WCPT_CFB,"File ITMBOMCFG(ITMREF/BOMALT)=") From TRTMIG
Return

##########################################################################
$RAZV6_CFB
Raz [F:CFB]LLCTYP  # V6 new field
Return

#######################################################################
# Code extrait de TRCMAJ30 - table ITMBOMCFG
########################################################################
$MAJV6_CFB
### Issue 78741 cas impossible en principe
If [F:CFB]BOMALT<1
  [F:CFB]LLCTYP = 1
Else
  Case WBOMALTTYP([F:CFB]BOMALT)
        When 2,3:      [F:CFB]LLCTYP = 2
        When Default:  [F:CFB]LLCTYP = 1
  Endcase
Endif
#[F:CFB]UPDUSR=GUSER
#[F:CFB]UPDDAT=date$
Return
