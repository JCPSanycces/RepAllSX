#<AdxTL>@(#)11.0.0.0 $Revision$
######################################################################################
##  Xtend: Copie fiche Profil Xtend
##  Version 0001
######################################################################################
#    GACTION
#        AYSCOP        Copie d'une donnée Xtend
#        AYSFCYCOP     Copie globale d'un site
#    [L]
#        FCYORG, DOSORG
#        FCYDES, DOSDES
#        ELTCOD
#    [F:AYS1] Site origine       Ouvert et lu
#    [F:AYS2] Site destination   Ouvert et lu
######################################################################################
$TRTCOP
If [L]DOSORG=nomap
 Local File AYTPRF    [AYD1]
 Local File ATEXTE    [ATX1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[L]DOSORG+".AYTPRF"     [AYD1]
 Local File =[L]DOSORG+".ATEXTE"     [ATX1]
 Local File =[L]DOSORG+".ATEXTRA"    [AXX1]
Endif
If [L]DOSDES=nomap
 Local File AYTPRF     [AYD2]
 Local File ATEXTE     [ATX2]
 Local File ATEXTRA    [AXX2]
Else
 Local File =[L]DOSDES+".AYTPRF"     [AYD2]
 Local File =[L]DOSDES+".ATEXTE"     [ATX2]
 Local File =[L]DOSDES+".ATEXTRA"    [AXX2]
Endif

Read [AYD1]AYD0 = [L]FCYORG;[L]ELTCOD
If fstat
  OK=0
  Call RSTA("AYD",[L]FCYORG-[L]ELTCOD) From GLOCK
  Goto FINALLY
Endif

Read [AYD2]AYD0 = [L]FCYDES;[L]ELTCOD
DES_ELTCOD=[F:AYD2]PRFCOD : Gosub MSGDESOBJ From AYTCOP
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif


$FINALLY
Close Local File [AYD1], [ATX1] , [AXX1]
&              , [AYD2], [ATX2] , [AXX2]
Return

$TR_COP
 GOK = 1
 Trbegin [AYD2] , [ATX2]
 If DES_HASELT
     Delete [AYD2] Where  FCYCOD=[L]FCYDES and PRFCOD=[L]DES_ELTCOD
     If fstat=1
      GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTPRF" : Goto ROLL_TR_COP
     Elsif fstat>5
      GOK = 0 : Call RSTA("AYD2","") From GLOCK : Goto AB_TR_COP
     Endif
 Endif
 For [AYD1]AYD0 Where FCYCOD=[L]FCYORG & PRFCOD=[L]ELTCOD
  [F:AYD2] = [F:AYD1]
  [F:AYD2]FCYCOD = [L]FCYDES
  Call COPTEXTRA("AYTPRF","INTIT",[F:AYD1]FCYCOD,[F:AYD1]PRFCOD,[L]FCYDES) From SUBAYS
  If GOK<1 : Break : Endif
  [F:AYD2]UPDUSR = GUSER
  [F:AYD2]UPDDAT = date$
  # [F:AYD2]UPDTIM = time  - 93575
  Call SET_UPDTIM("AYD2") From AYTCOP # 93575
  [F:AYD2]BRWX3  = [F:AYD2]FCYCOD+"_"+[F:AYD2]PRFCOD
#*  [F:AYD2]CODACT = [L]ELTCODACT
  Write [AYD2]
  If fstat
   GOK=0 : Call FSTA("AYD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
