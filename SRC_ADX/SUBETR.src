#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
# SUBETR : Transactions de saisie des entrées en stock                #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWP]AWINBRO  Table des browser fenêtres    #
#                       [F:AWP]AWINBOUT Table des boutons fenêtres    #
#     Pour les achats : [F:PTR]PURTRS   Table des transactions        #
#                                                                     #
# Les étiquettes peuvent être appelées directement depuis l'objet     #
# de transaction                                                      #
# Pour la génération des écrans de stock les locales suivantes auront #
# été déclarées et alimentées dans le programmes appelant             #
# Local Char WMODU     : Contient la lettre correspondant à la famille#
#                        de l'écran à généré ainsi que le type de     #
#                        transaction                                  #
#                        E6   = Réceptions achat                       #
#                        T01  = Entrées diverses                      #
#                        K5  = Avoirs                                 #
#                        K6  = Retours client                         #
#                        K7  = Retours prêt                           #
#                        K8  = Retours matière ss trt                 #
#                        ..  = ..                                     #
#                                                                     #
# Local Char     WNOMOBJ(GLONAOB) : Nom de l'objet apellant           #
# Local Char     WNOMTRS(GLONTRS) : Nom de la transaction             #
# Local Char     WACSCOD(GLONACS) : Code accès                        #
# Local Char     WLIBEL(30)       : Désignation de la transaction     #
# Local Shortint WENAFLG          : Flag actif                        #
# Local Shortint WNUM             : numéro de l'écran à générer       #
#                                                                     #
# Génération des 2 écrans d'entrée en stock création et modif         #
#                                                                     #
# Nom des écrans générés : Waxyyyz                                    #
#                           ax = WMODU                                #
#                                E6 pour réceptions fournisseur       #
#                                T1 pour entrées diverses             #
#                                T5 pour plan de rangement            #
#                                R2 pour déclaration de production    #
#                                K5 pour avoirs                       #
#                                K6 pour retours clients              #
#                                K7 pour retours prêt                 #
#                                K8 pour retours matière ss trt
#                                T05 Plan de rangement
#                                .. ......                            #
#                          yyy = WNOMTRS                              #
#                                                                     #
#                            z = Numéro d'ordre de l'écran            #
#                                S      pour écran de création        #
#                                M      pour l'écran de modification  #
#                                                                     #
# Nom des fenêtres et traitements générés                             #
# Pour l'entrée          : Nom fenêtre    WQaaabbb+"S"                #
#                          Nom traitement WGWQaaabbb+"S"              #
#                          aaa = WNOMOBJ                              #
#                          bbb = WNOMTRS                              #
#                                                                     #
# Pour la modif          : Nom fenêtre    WQaaabbb+"M"                #
#                          Nom traitement WGWQaaabbb+"M"              #
#                          aaa = WNOMOBJ                              #
#                          bbb = WNOMTRS                              #
#                                                                     #
#######################################################################

$ACTION
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE : # Sélection sur code pièce auto
 When Default
Endcase
Return


$SEL_TABLE
#---------------------#
# Sélection sur champ #
#---------------------#
Case COUZON
  When "ENTCOD","ENTCODS"   : # Pièce auto d'entrée ou de sortie stock
    OBJET="GAU"
    CRITERE="TBL='STJTMP'"
Endcase
Return


$RAZCRE
#----------------------------------------------#
# Initialisation des valeurs                   #
# Appelé si nécessaire dans l'action           #
# RAZCRE de l'objet transaction                #
#----------------------------------------------#
#** Onglet stock
If dim([M:ETR1]NBLIG)>0
  [M:ETR1]NBLIG=GOPTCANA
  For nolign=1 To GOPTCANA
    [M:ETR1]CCEINTS(nolign-1)=nolign
    [M:ETR1]CCECODS(nolign-1)=1
    [M:ETR1]CCESCRS(nolign-1)=1
  Next nolign
Endif
If dim([M:ETR1]SRGWAIFLG)>0
    [M:ETR1]SRGWAIFLG=1       : # A quai (non)
Endif

#** Onglet stock rubriques
#- Bloc document
# Particularité retour prêt et retour matière pour sous traitance
If find(WMODU,"K7","K8")
    [M:ETR2]UOMSAIFLG=1      : # Pas de saisie en UC
    [M:ETR2]BPSLOTCOD=2      : # Numéro lot fournisseur (affiché)
    [M:ETR2]BPSLOTSCR=1
    If dim ([M:ETR2]LOTCOD)>0
      [M:ETR2]LOTCOD=2       : # Numéro lot (affiché)
      [M:ETR2]LOTSCR=1
    Endif
    [M:ETR2]MVTPRICOD=3      : # Prix du mouvement (invisible)
    [M:ETR2]MVTPRISCR=1
Else
    [M:ETR2]UOMSAIFLG=2      : # Saisie en UC
    [M:ETR2]BPSLOTCOD=1      : # Numéro lot fournisseur (saisie)
    [M:ETR2]BPSLOTSCR=1
    If dim ([M:ETR2]LOTCOD)>0
      [M:ETR2]LOTCOD=1       : # Numéro lot (saisie)
      [M:ETR2]LOTSCR=1
    Endif
Endif
If dim ([M:ETR2]SLOCOD)>0
  [M:ETR2]SLOCOD=3       : # Numéro sous-lot (invisible)
  [M:ETR2]SLOSCR=1
  [M:ETR2]NBSLOFLG=1     : # Nbr s-lot (invisible)
Endif
If dim([M:ETR2]LOCCOD)>0
  [M:ETR2]LOCCOD=3       : # Emplacement (invisible)
  [M:ETR2]LOCSCR=1
Endif
#                                                         # hcb X3FEAT-345 deb
If dim([M:ETR2]LPNCOD)>0
  [M:ETR2]LPNCOD=3       : # Contenant (invisible)
  [M:ETR2]LPNSCR=1
Endif
#                                                         # hcb X3FEAT-345 fin

#                                                          # hcb 71276 deb
If dim([M:ETR2]ECCCOD)>0
  [M:ETR2]ECCCOD=2      : # Version     (invisible)
  [M:ETR2]ECCSCR=1
Endif
If dim([M:ETR2]ECCCODMIN)>0
  [M:ETR2]ECCCODMIN=2      : # Version     (invisible)
  [M:ETR2]ECCSCRMIN=1
Endif
#                                                          # hcb 71276 fin

[M:ETR2]STACOD=3         : # Statut (invisible)
[M:ETR2]STASCR=1
If dim([M:ETR2]SERCOD)>0
  [M:ETR2]SERCOD=3       : # Numéro série (invisible)
  [M:ETR2]SERSCR=1
  [M:ETR2]SERECOD=2      : # Numéro série (invisible)
  [M:ETR2]SERESCR=1
Endif
[M:ETR2]MVTPRICOD=3      : # Prix (invisible)
[M:ETR2]MVTPRISCR=1
[M:ETR2]MVTDESCOD=3      : # Désignation mouvement (invisible)
[M:ETR2]MVTDESSCR=1
If dim([M:ETR2]WRHCOD1)>0
  #--- Dem 60616
  #If dim([M]WRHOBY)>0 & [M]WRHOBY = 2
  #   [M:ETR2]WRHCOD1=2       : # Dépôt (affiché)
  #Else
     [M:ETR2]WRHCOD1=3       : # Dépôt (invisible)
     [M:ETR2]WRHSCR1=1
  #Endif
  #---
Endif

#- Bloc détail
[M:ETR2]UOMSAIFLG1=1     : # Saisie UC (non)
[M:ETR2]BPSLOTCOD1=1     : # Lot fournisseur
[M:ETR2]BPSLOTSCR1=1
[M:ETR2]MVTPRICOD1=2     : # Prix
If dim([M:ETR2]IDECOD1)>0                         # hcb 27200
   [M:ETR2]IDECOD1=3        : # Identifiant 1
   [M:ETR2]IDESCR1=1
   [M:ETR2]IDECOD2=3        : # Identifiant 2
   [M:ETR2]IDESCR2=1
   [M:ETR2]IDECOD01=3        : # Identifiant 1    # hcb 27200
   [M:ETR2]IDESCR01=1                             # hcb 27200
   [M:ETR2]IDECOD02=3        : # Identifiant 2    # hcb 27200
   [M:ETR2]IDESCR02=1                             # hcb 27200
Endif                                             # hcb 27200
[M:ETR2]PRNCOD1=1        : # Impression
[M:ETR2]PRNSCR1=1
[M:ETR2]PRNNBFLG1=1      : # Nombre de document
[M:ETR2]PRNNBSCR1=1
[M:ETR2]SERECOD1=2       : # Numéro de série fin
[M:ETR2]SERESCR1=1
[M:ETR2]MVTDESCOD1=3     : # Désignation du mouvement
#[M:ETR2]MVTDESSCR1=1
[M:ETR2]AVSTOCOD1=2      : # Stock disponible
[M:ETR2]AVSTOSCR1=1
#- Bloc lot
If dim([M:ETR2]SPERFLG)>0
  [M:ETR2]SPERFLG=2      : # Péremption
Endif

#                                                 # hcb 71276 deb
If dim([M:ETR2]ECCFLG)>0
  [M:ETR2]ECCFLG=2      : # Version
Endif
#                                                 # hcb 71276 fin

If dim([M:ETR2]SPOTFLG)>0
  [M:ETR2]SPOTFLG=2      : # Titre
Endif
[M:ETR2]SRUB1FLG=1       : # Rubrique 1
[M:ETR2]SRUB2FLG=1       : # Rubrique 2
[M:ETR2]SRUB3FLG=1       : # Rubrique 3
[M:ETR2]SRUB4FLG=1       : # Rubrique 4
If clalev([M:ETR1])>0 Actzo [ETR1] : Endif
Actzo [ETR2]
#- Grisage des zones
If [M:ETR2]BPSLOTCOD=3  Grizo [ETR2]BPSLOTSCR  Else Actzo [ETR2]BPSLOTSCR : Endif
If dim([M:ETR2]LOTCOD)>0
  If [M:ETR2]LOTCOD=3
#                                    # hcb 71276 deb
     # Issue 109583 - 2015-07-16 by SR
     If dim ([M:ETR2]SLOCOD)>0
       [M:ETR2]SLOCOD=3
       Grizo [ETR2]NBSLOFLG
       Grizo [ETR2]SLOCOD
       Grizo [ETR2]SLOSCR
     Endif
     # End issue 109583
     Grizo [ETR2]LOTSCR
  Else
     Actzo [ETR2]LOTSCR
     # Issue 109583 - 2015-07-16 by SR
     If dim ([M:ETR2]SLOCOD)>0
       Actzo [ETR2]NBSLOFLG
       Actzo [ETR2]SLOCOD
       Actzo [ETR2]SLOSCR
     Endif
     # End issue 109583
  Endif
Endif

If dim([M:ETR2]ECCCOD)>0
  If [M:ETR2]ECCCOD=2
     [M:ETR2]ECCCODMIN =2
     Grizo [ETR2]ECCCODMIN
     Grizo [ETR2]ECCSCRMIN
     Grizo [ETR2]ECCSCR
  Else
     Actzo [ETR2]ECCCODMIN
     Actzo [ETR2]ECCSCRMIN
     Actzo [ETR2]ECCSCR
  Endif
Endif
#                                                      # hcb 71276 fin
If dim([M:ETR2]SLOCOD)>0
  If [M:ETR2]SLOCOD=3   Grizo [ETR2]SLOSCR   : Grizo [ETR2]NBSLOFLG
  Else
     Actzo [ETR2]SLOSCR : Actzo [ETR2]NBSLOFLG
  Endif
Endif
If dim([M:ETR2]LOCCOD)>0
  If [M:ETR2]LOCCOD=3   Grizo [ETR2]LOCSCR     Else Actzo [ETR2]LOCSCR    : Endif
Endif
#                                                        # hcb X3FEAT-345 deb
If dim([M:ETR2]LPNCOD)>0
  If [M:ETR2]LPNCOD=3   Grizo [ETR2]LPNSCR     Else Actzo [ETR2]LPNSCR    : Endif
Endif
#                                                         # hcb X3FEAT-345 fin

#                                                                        # hcb 71276 deb
If dim([M:ETR2]ECCCOD)>0
  If [M:ETR2]ECCCOD=2   Grizo [ETR2]ECCSCR     Else Actzo [ETR2]ECCSCR    : Endif
Endif
If dim([M:ETR2]ECCCODMIN)>0
  If [M:ETR2]ECCCODMIN=2   Grizo [ETR2]ECCSCRMIN     Else Actzo [ETR2]ECCSCRMIN    : Endif
Endif
#                                                                        # hcb 71276 fin

If [M:ETR2]STACOD=3     Grizo [ETR2]STASCR     Else Actzo [ETR2]STASCR    : Endif
If dim([M:ETR2]SERCOD)>0
  If [M:ETR2]SERCOD=3     Grizo [ETR2]SERSCR   Else Actzo [ETR2]SERSCR    : Endif
  If [M:ETR2]SERECOD=2    Grizo [ETR2]SERESCR  Else Actzo [ETR2]SERESCR   : Endif
Endif
If [M:ETR2]MVTPRICOD=3  Grizo [ETR2]MVTPRISCR  Else Actzo [ETR2]MVTPRISCR : Endif
If [M:ETR2]MVTDESCOD=3  Grizo [ETR2]MVTDESSCR  Else Actzo [ETR2]MVTDESSCR : Endif
If dim([M:ETR2]WRHCOD1)>0
   If dim([M]WRHOBY)>0
      #--- Dem 60616
      #If [M]WRHOBY = 2
      #  Grizo [ETR2]WRHSCR1  : Grizo [ETR2]WRHCOD1
      #Else
      #  Actzo [M:ETR2]WRHCOD1
        If [M:ETR2]WRHCOD1=3  Grizo [ETR2]WRHSCR1  Else Actzo [ETR2]WRHSCR1 : Endif
      #Endif
      #---
   Endif
Endif

#- Détail
If [M:ETR2]BPSLOTCOD1=3 Grizo [ETR2]BPSLOTSCR1 Else Actzo [ETR2]BPSLOTSCR1: Endif
#-- En réception la zone doit toujours être saisissable
#-- Cas des articles gérés en lot=lot fournisseur
If WMODU="E6" Grizo [ETR2]BPSLOTCOD1 : Grizo [ETR2]BPSLOTSCR1 : Endif
# En déclaration de production cette zone ne veut rien dire
If find(WMODU,"R2","T62","T63") Grizo [ETR2]BPSLOTCOD1 : Grizo [ETR2]BPSLOTSCR1 : Endif
If dim([M:ETR2]IDECOD1)>0
   If [M:ETR2]IDECOD1 =3    Grizo [ETR2]IDESCR1     Else Actzo [ETR2]IDESCR1    : Endif
   If [M:ETR2]IDECOD2 =3    Grizo [ETR2]IDESCR2     Else Actzo [ETR2]IDESCR2    : Endif
   If [M:ETR2]IDECOD01=3    Grizo [ETR2]IDESCR01    Else Actzo [ETR2]IDESCR01   : Endif
   If [M:ETR2]IDECOD02=3    Grizo [ETR2]IDESCR02    Else Actzo [ETR2]IDESCR02   : Endif
Endif
If [M:ETR2]PRNCOD1=1    Grizo [ETR2]PRNSCR1, PRNNBSCR1, PRNNBFLG1
  Else                  Actzo [ETR2]PRNSCR1, PRNNBSCR1, PRNNBFLG1
Endif
If [M:ETR2]PRNNBFLG1=1  Grizo [ETR2]PRNNBSCR1  Else Actzo [ETR2]PRNNBSCR1 : Endif
If [M:ETR2]SERECOD1=2   Grizo [ETR2]SERESCR1   Else Actzo [ETR2]SERESCR1  : Endif
If [M:ETR2]AVSTOCOD1=2  Grizo [ETR2]AVSTOSCR1  Else Actzo [ETR2]AVSTOSCR1 : Endif

If WMODU = "T05"
  Raz [ETR2]UOMSAIFLG
  Grizo [ETR2]UOMSAIFLG
Endif

# Particularité retour prêt
If find(WMODU,"K7","K8") Diszo [ETR2]UOMSAIFLG, MVTPRICOD, MVTPRICOD1 : Endif

If clalev([M:ETR1])>0 Affzo [ETR1]1-99 : Endif
Affzo [ETR2]1-99
Return


$APRES_MODIF
#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
Case COUZON
  When "BPSLOTCOD"                                : # Lot fournisseur doc
       If val(CZ)=3
         [M:ETR2]BPSLOTSCR=1
         If !GIMPORT Affzo [ETR2]BPSLOTSCR : Grizo [ETR2]BPSLOTSCR : Endif
       Elsif !GIMPORT
         Actzo [ETR2]BPSLOTSCR
       Endif
  When "LOTCOD"                                   : # Lot doc
       If val(CZ)=3
#                                                                  # hcb 71276 deb
         If !GIMPORT Affzo [ETR2]LOTSCR
            # Issue 109583 - 2015-07-16 by SR
            If dim([M:ETR2]SLOCOD) >0
              [M:ETR2]SLOSCR=1
              [M:ETR2]SLOCOD=3
              [ETR2]NBSLOFLG=1
              Affzo [ETR2]SLOSCR
              Grizo [ETR2]SLOSCR
              Affzo [ETR2]SLOCOD
              Grizo [ETR2]SLOCOD
              Affzo [ETR2]NBSLOFLG
              Grizo [ETR2]NBSLOFLG
            Endif
            # End issue 109583
            Grizo [ETR2]LOTSCR
         Endif
       Elsif !GIMPORT
             # Issue 109583 - 2015-07-16 by SR
             If dim([M:ETR2]SLOCOD) >0
               Actzo [ETR2]LOTSCR
               Actzo [ETR2]SLOCOD
               Actzo [ETR2]NBSLOFLG
             Endif
             # End issue 109583
#                                                                  # hcb 71276 fin
       Endif
  When "SLOCOD"                                   : # Sous-lot doc
       If val(CZ)=3
         [M:ETR2]SLOSCR=1
         If !GIMPORT
           Affzo [ETR2]SLOSCR : Grizo [ETR2]SLOSCR
           [ETR2]NBSLOFLG=1 : Affzo [ETR2]NBSLOFLG : Grizo [ETR2]NBSLOFLG : Endif
       Elsif !GIMPORT
         Actzo [ETR2]SLOSCR
         Actzo [ETR2]NBSLOFLG
       Endif
  When "STACOD"                                   : # Statut doc
       If val(CZ)=3
         [M:ETR2]STASCR=1
         If !GIMPORT Affzo [ETR2]STASCR : Grizo [ETR2]STASCR : Endif
       Elsif !GIMPORT
         Actzo [ETR2]STASCR
       Endif
  When "LOCCOD"                                   : # Emplacement doc
       If val(CZ)=3
         [M:ETR2]LOCSCR=1
         If !GIMPORT Affzo [ETR2]LOCSCR : Grizo [ETR2]LOCSCR : Endif
       Elsif !GIMPORT
         Actzo [ETR2]LOCSCR
       Endif
#                                                         # hcb X3FEAT-345 deb
 When "LPNCOD"                                   : # Contenant
       If val(CZ)=3
         [M:ETR2]LPNSCR=1
         If !GIMPORT Affzo [ETR2]LPNSCR : Grizo [ETR2]LPNSCR : Endif
       Elsif !GIMPORT
         Actzo [ETR2]LPNSCR
       Endif
#                                                         # hcb X3FEAT-345 fin


#                                                                  # hcb 71276 deb
  When "ECCCOD"                                     : # Version
       If val(CZ)=2
         [M:ETR2]ECCSCR=1
         If !GIMPORT Affzo [ETR2]ECCSCR
                     Grizo [ETR2]ECCSCR
                     [M:ETR2]ECCSCRMIN =1
                     [M:ETR2]ECCCODMIN =2
                     Affzo [M:ETR2]ECCSCRMIN
                     Affzo [M:ETR2]ECCCODMIN
                     Grizo [M:ETR2]ECCSCRMIN
                     Grizo [M:ETR2]ECCCODMIN

         Endif
       Elsif !GIMPORT
         Actzo [ETR2]ECCSCR
         Actzo [M:ETR2]ECCSCRMIN
         Actzo [M:ETR2]ECCCODMIN
       Endif
  When "ECCCODMIN"                                     : # Version
       If val(CZ)=2
         [M:ETR2]ECCSCRMIN=1
         If !GIMPORT Affzo [ETR2]ECCSCRMIN : Grizo [ETR2]ECCSCRMIN : Endif
       Elsif !GIMPORT
         Actzo [ETR2]ECCSCRMIN
       Endif
#                                                                  # hcb 71276 fin

  When "MVTPRICOD"                                : # Prix mouvement doc
       If val(CZ)=3
         [M:ETR2]MVTPRISCR=1
         If !GIMPORT Affzo [ETR2]MVTPRISCR : Grizo [ETR2]MVTPRISCR : Endif
       Elsif !GIMPORT
         Actzo [ETR2]MVTPRISCR
       Endif
  When "SERCOD"                                   : # Numéro série doc
       If val(CZ)=3
         [M:ETR2]SERSCR=1
         [M:ETR2]SERECOD=2
         [M:ETR2]SERESCR=1
         If !GIMPORT Affzo [ETR2]SERSCR, SERECOD, SERESCR
                     Grizo [ETR2]SERSCR, SERECOD, SERESCR
         Endif
       Elsif !GIMPORT
         Actzo [ETR2]SERSCR, SERECOD, SERESCR
       Endif
  When "SERECOD"                                  : # Numéro série fin doc
       If val(CZ)=2
         [M:ETR2]SERESCR=1
         If !GIMPORT Affzo [ETR2]SERESCR : Grizo [ETR2]SERESCR : Endif
       Elsif !GIMPORT
         Actzo [ETR2]SERESCR
       Endif
  When "MVTDESCOD"                                : # Des mouvement doc
       If val(CZ)=3
         [M:ETR2]MVTDESSCR=1
         If !GIMPORT Affzo [ETR2]MVTDESSCR : Grizo [ETR2]MVTDESSCR : Endif
       Elsif !GIMPORT
         Actzo [ETR2]MVTDESSCR
       Endif
 When "WRHOBY"                                : # dépôt obligatoire
       #--- Dem 60616
       #If val(CZ)=2
       #  [M:ETR2]WRHCOD1=2  : [M:ETR2]WRHSCR1=1
       #  If !GIMPORT
       #     Affzo [ETR2]WRHCOD1 : Grizo [ETR2]WRHCOD1
       #     Affzo [ETR2]WRHSCR1 : Grizo [ETR2]WRHSCR1
       #  Endif
       #Elsif !GIMPORT
       #  Affzo [M:ETR2]WRHCOD1 : Actzo [ETR2]WRHCOD1
       #  Affzo [M:ETR2]WRHSCR1 : If [M:ETR2]WRHCOD1 = 3 Diszo [ETR2]WRHSCR1 Else Actzo [ETR2]WRHSCR1 Endif
       #Endif
       If val(CZ)=2
         If [M:ETR2]WRHCOD1=1
           [M:ETR2]WRHCOD1=3
           [M:ETR2]WRHSCR1=1
         Endif
         If !GIMPORT
           If [M:ETR2]WRHCOD1=3
             Grizo [M:ETR2]WRHSCR1
           Else
             Actzo [M:ETR2]WRHSCR1
           Endif
           Affzo [ETR2]WRHCOD1 : Affzo [ETR2]WRHSCR1
         Endif
       Endif
       #---
  When "WRHCOD1"                                : # Des mouvement doc
       If val(CZ)=3
         [M:ETR2]WRHSCR1=1
         If !GIMPORT Affzo [ETR2]WRHSCR1 : Grizo [ETR2]WRHSCR1 : Endif
       Elsif !GIMPORT
         Actzo [ETR2]WRHSCR1
       Endif

  When "BPSLOTCOD1"                               : # Lot fournisseur
       If val(CZ)=3
         [M:ETR2]BPSLOTSCR1=1
         If !GIMPORT Affzo [ETR2]BPSLOTSCR1: Grizo [ETR2]BPSLOTSCR1 : Endif
       Elsif !GIMPORT
         Actzo [ETR2]BPSLOTSCR1
       Endif
  When "IDECOD1"                                  : # Identifiant 1
       If val(CZ)=3
         [M:ETR2]IDESCR1=1
         If !GIMPORT Affzo [ETR2]IDESCR1: Grizo [ETR2]IDESCR1 : Endif
       Elsif !GIMPORT
         Actzo [ETR2]IDESCR1
       Endif
  When "IDECOD2"                                  : # Identifiant 2
       If val(CZ)=3
         [M:ETR2]IDESCR2=1
         If !GIMPORT Affzo [ETR2]IDESCR2: Grizo [ETR2]IDESCR2 : Endif
       Elsif !GIMPORT
         Actzo [ETR2]IDESCR2
       Endif
  When "IDECOD01"                                  : # Identifiant 1
       If val(CZ)=3
         [M:ETR2]IDESCR01=1
         If !GIMPORT Affzo [ETR2]IDESCR01: Grizo [ETR2]IDESCR01 : Endif
       Elsif !GIMPORT
         Actzo [ETR2]IDESCR01
       Endif
  When "IDECOD02"                                  : # Identifiant 2
       If val(CZ)=3
         [M:ETR2]IDESCR02=1
         If !GIMPORT Affzo [ETR2]IDESCR02: Grizo [ETR2]IDESCR02 : Endif
       Elsif !GIMPORT
         Actzo [ETR2]IDESCR02
       Endif
  When "PRNCOD1"                                  : # Type Impression
       If val(CZ)=1
         [M:ETR2]PRNSCR1=1
         [M:ETR2]PRNNBFLG1=1
         [M:ETR2]PRNNBSCR1=1
         If !GIMPORT Affzo [ETR2]PRNSCR1    : Grizo [ETR2]PRNSCR1
                     Affzo [ETR2]PRNNBFLG1  : Grizo [ETR2]PRNNBFLG1
                     Affzo [ETR2]PRNNBSCR1  : Grizo [ETR2]PRNNBSCR1
         Endif
       Elsif !GIMPORT
         Actzo [ETR2]PRNSCR1
         Actzo [ETR2]PRNNBFLG1
         Actzo [ETR2]PRNNBSCR1
       Endif
  When "PRNNBFLG1"                                : # Nbre impression
       If val(CZ)=1
         [M:ETR2]PRNNBSCR1=1
         If !GIMPORT Affzo [ETR2]PRNNBSCR1: Grizo [ETR2]PRNNBSCR1 : Endif
       Elsif !GIMPORT
         Actzo [ETR2]PRNNBSCR1
       Endif
  When "SERECOD1"                                 : # Numéro série fin
       If val(CZ)=2
         [M:ETR2]SERESCR1=1
         If !GIMPORT Affzo [ETR2]SERESCR1 : Grizo [ETR2]SERESCR1 : Endif
       Elsif !GIMPORT
         Actzo [ETR2]SERESCR1
       Endif
  When "AVSTOCOD1"                                : # Stock dispo
       If val(CZ)=2
         [M:ETR2]AVSTOSCR1=1
         If !GIMPORT Affzo [ETR2]AVSTOSCR1: Grizo [ETR2]AVSTOSCR1 : Endif
       Elsif !GIMPORT
         Actzo [ETR2]AVSTOSCR1
       Endif
  When Default
Endcase
Return

$LIENS

#----------------------------------------------#
# Liens                                        #
# Appelé si nécessaire dans l'action           #
# LIENS  de l'objet transaction                #
#----------------------------------------------#
#** Onglet stock1
If dim([M:ETR1]NBLIG)>0
  If [M:ETR1]NBLIG=0  [M:ETR1]NBLIG=GOPTCANA : Endif
  For nolign=1 To GOPTCANA
    If [M:ETR1]CCESCRS(nolign-1)=0 [M:ETR1]CCESCRS(nolign-1)=1 : Endif
  Next nolign
Endif
If dim([M:ETR1]SRGWAIFLG)>0
    If [M:ETR1]SRGWAIFLG=0  [M:ETR1]SRGWAIFLG=1  : Endif   : # A quai  (non)
Endif
#** Onglet stock2
If find(WMODU,"K7", "K8")
    If [M:ETR2]UOMSAIFLG=0  [M:ETR2]UOMSAIFLG=1  : Endif   : # Saisie UC (affiché)
    If [M:ETR2]BPSLOTCOD=0  [M:ETR2]BPSLOTCOD=2  : Endif : # Numéro lot fournisseur (affiché)
    If dim([M:ETR2]LOTCOD)>0
      If [M:ETR2]LOTCOD=0   [M:ETR2]LOTCOD=2     : Endif : # Numéro lot (affiché)
    Endif
    If [M:ETR2]MVTPRICOD1=0 [M:ETR2]MVTPRICOD1=2 : Endif   : # Prix (invisible)
Else
    If [M:ETR2]UOMSAIFLG1=0 [M:ETR2]UOMSAIFLG1=2 : Endif   : # Saisie UC
    If [M:ETR2]BPSLOTCOD=0  [M:ETR2]BPSLOTCOD=1  : Endif   : # Numéro lot fournisseur (saisie)
    If dim([M:ETR2]LOTCOD)>0
      If [M:ETR2]LOTCOD=0     [M:ETR2]LOTCOD=1     : Endif : # Numéro lot (saisie)
    Endif
Endif
If dim([M:ETR2]SLOCCOD)>0
  If [M:ETR2]SLOCCOD=0    [M:ETR2]SLOCCOD=3    : Endif : # Numéro S-Lot
Endif

#                                                              # hcb 71276 deb
If dim([M:ETR2]ECCCOD)>0
  If [M:ETR2]ECCCOD=0    [M:ETR2]ECCCOD=2    : Endif : # version
  If [M:ETR2]ECCSCR=0    [M:ETR2]ECCSCR=1    : Endif : # version
Endif
If dim([M:ETR2]ECCCODMIN)>0
  If [M:ETR2]ECCCODMIN=0    [M:ETR2]ECCCODMIN=2    : Endif : # version
  If [M:ETR2]ECCSCRMIN=0    [M:ETR2]ECCSCRMIN=1    : Endif : # version
Endif
#                                                              # hcb 71276 fin

If dim([M:ETR2]LOCCOD)>0
  If [M:ETR2]LOCCOD=0     [M:ETR2]LOCCOD=3     : Endif : # Emplacement (invisible)
Endif
#                                                         # hcb X3FEAT-345 deb
If dim([M:ETR2]LPNCOD)>0
  If [M:ETR2]LPNCOD=0                                    : # Contenant
     [M:ETR2]LPNCOD=3
     [M:ETR2]LPNSCR=1
  Endif
Endif
#                                                         # hcb X3FEAT-345 fin
If [M:ETR2]STACOD=0     [M:ETR2]STACOD=3     : Endif : # Statut (invisible)
If dim([M:ETR2]SERCOD)>0
  If [M:ETR2]SERCOD=0     [M:ETR2]SERCOD=3     : Endif : # Numéro série (invisible)
  If [M:ETR2]SERECOD=0    [M:ETR2]SERECOD=2    : Endif : # Numéro série (invisible)
Endif
If [M:ETR2]MVTPRICOD=0  [M:ETR2]MVTPRICOD=3  : Endif   : # Prix (invisible)
If [M:ETR2]MVTDESCOD=0  [M:ETR2]MVTDESCOD=3  : Endif   : # Désignation mouvement (invisible)
If dim([M:ETR2]WRHCOD1)>0
  If [M:ETR2]WRHCOD1=0  [M:ETR2]WRHCOD1=3  : [M:ETR2]WRHSCR1 = 1 : Endif   : # Dépôt (invisible)
Endif

If dim([M:ETR2]SPERFLG)>0
  If [M:ETR2]SPERFLG=0  [M:ETR2]SPERFLG=2    : Endif   : # Péremption
Endif

#                                                                  # hcb 71276 deb
If dim([M:ETR2]ECCFLG)>0
  If [M:ETR2]ECCFLG=0  [M:ETR2]ECCFLG=2    : Endif   : # Version
Endif
#                                                                  # hcb 71276 fin

If dim([M:ETR2]SPOTFLG)>0
  If [M:ETR2]SPOTFLG=0  [M:ETR2]SPOTFLG=2    : Endif   : # Titre
Endif
If [M:ETR2]SRUB1FLG=0   [M:ETR2]SRUB1FLG=1   : Endif   : # Rubrique 1 (non)
If [M:ETR2]SRUB2FLG=0   [M:ETR2]SRUB2FLG=1   : Endif   : # Rubrique 2 (non)
If [M:ETR2]SRUB3FLG=0   [M:ETR2]SRUB3FLG=1   : Endif   : # Rubrique 3 (non)
If [M:ETR2]SRUB4FLG=0   [M:ETR2]SRUB4FLG=1   : Endif   : # Rubrique 4 (non)
#-- Grisage des zones document
If [M:ETR2]BPSLOTCOD=3    Grizo [ETR2]BPSLOTSCR  Else Actzo [ETR2]BPSLOTSCR  : Endif
If dim([M:ETR2]LOTCOD)>0
#                                                      # hcb 71276 deb

  If [M:ETR2]LOTCOD=3
     # Issue 109583 - 2015-07-16 by SR
     If dim([M:ETR2]SLOCOD)>0
       [M:ETR2]SLOCOD=3
       Grizo [ETR2]NBSLOFLG
       Grizo [ETR2]SLOCOD
       Grizo [ETR2]SLOSCR
     Endif
     # End issue 109583
     Grizo [ETR2]LOTSCR
  Else
     Actzo [ETR2]LOTSCR
     # Issue 109583 - 2015-07-16 by SR
     If dim([M:ETR2]SLOCOD)>0
       Actzo [ETR2]NBSLOFLG
       Actzo [ETR2]SLOCOD
       Actzo [ETR2]SLOSCR
     Endif
     # End issue 109583
  Endif
Endif

#                                                                           # hcb 71276 deb
If dim([M:ETR2]ECCCOD)>0
  If [M:ETR2]ECCCOD=2
     [M:ETR2]ECCCODMIN =2
     Grizo [ETR2]ECCCODMIN
     Grizo [ETR2]ECCSCRMIN
     Grizo [ETR2]ECCSCR
  Else
     Actzo [ETR2]ECCCODMIN
     Actzo [ETR2]ECCSCRMIN
     Actzo [ETR2]ECCSCR
  Endif
Endif
If dim([M:ETR2]ECCCODMIN)>0
  If [M:ETR2]ECCCODMIN=2     Grizo [ETR2]ECCSCRMIN     Else Actzo [ETR2]ECCSCRMIN    : Endif
Endif
#                                                                           # hcb 71276 fin
If dim([M:ETR2]SLOCOD)>0
  If [M:ETR2]SLOCOD=3     Grizo [ETR2]SLOSCR  : Grizo [ETR2]NBSLOFLG
  Else
    Actzo [ETR2]SLOSCR : Actzo [ETR2]NBSLOFLG
  Endif
Endif
If dim([M:ETR2]LOCCOD)>0
  If [M:ETR2]LOCCOD=3     Grizo [ETR2]LOCSCR     Else Actzo [ETR2]LOCSCR    : Endif
Endif
#                                                         # hcb X3FEAT-345 deb
If dim([M:ETR2]LPNCOD)>0
  If [M:ETR2]LPNCOD=3     Grizo [ETR2]LPNSCR     Else Actzo [ETR2]LPNSCR    : Endif
Endif
#                                                         # hcb X3FEAT-345 fin


If [M:ETR2]STACOD=3       Grizo [ETR2]STASCR     Else Actzo [ETR2]STASCR    : Endif
If dim([M:ETR2]SERCOD)>0
  If [M:ETR2]SERCOD=3     Grizo [ETR2]SERSCR     Else Actzo [ETR2]SERSCR    : Endif
  If [M:ETR2]SERECOD=2    Grizo [ETR2]SERESCR    Else Actzo [ETR2]SERESCR   : Endif
Endif
If [M:ETR2]MVTPRICOD=3  Grizo [ETR2]MVTPRISCR  Else Actzo [ETR2]MVTPRISCR   : Endif
If [M:ETR2]MVTDESCOD=3  Grizo [ETR2]MVTDESSCR  Else Actzo [ETR2]MVTDESSCR   : Endif
If dim([M:ETR2]WRHCOD1)>0
   If dim([M]WRHOBY)>0
      #--- Dem 60616
      #If [M]WRHOBY = 2
      #   Grizo [ETR2]WRHCOD1 : Grizo [ETR2]WRHSCR1
      #Else
      #   Actzo [M:ETR2]WRHCOD1
         If [M:ETR2]WRHCOD1=3  Grizo [ETR2]WRHSCR1  Else Actzo [ETR2]WRHSCR1   : Endif
      #Endif
      #---
   Endif
Endif

#-- Grisage des zones détail
If [M:ETR2]BPSLOTCOD1=3 Grizo [ETR2]BPSLOTSCR1 Else Actzo [ETR2]BPSLOTSCR1: Endif
#-- En réception la zone doit toujours être saisissable
#-- Cas des articles gérés en lot=lot fournisseur
If WMODU="E6" Grizo [ETR2]BPSLOTCOD1 : Grizo [ETR2]BPSLOTSCR1 : Endif
# En déclaration de production cette zone n'a aucun sens
If find(WMODU,"R2","T62","T63") Grizo [ETR2]BPSLOTCOD1 : Grizo [ETR2]BPSLOTSCR1 : Endif
#If [M:ETR2]MVTPRICOD1=2 Grizo [ETR2]MVTPRISCR1 Else Actzo [ETR2]MVTPRISCR1
If dim([M:ETR2]IDECOD1)>0
   If [M:ETR2]IDECOD01 = 0
      [M:ETR2]IDESCR01 = 1
      [M:ETR2]IDECOD01 = 3
   Endif   # identifiant 1 (invisible)  # hcb 27200
   If [M:ETR2]IDECOD02 = 0
      [M:ETR2]IDESCR02 = 1
      [M:ETR2]IDECOD02 = 3
   Endif  # identifiant 2 (invisible)  # hcb 27200
   If [M:ETR2]IDECOD1 =0  [M:ETR2]IDECOD1 =3   : Endif : # identifiant 1 (invisible)
   If [M:ETR2]IDECOD2 =0  [M:ETR2]IDECOD2 =3   : Endif : # identifiant 2 (invisible)
   If [M:ETR2]IDECOD1 =3  Grizo [ETR2]IDESCR1    Else Actzo [ETR2]IDESCR1    : Endif
   If [M:ETR2]IDECOD2 =3  Grizo [ETR2]IDESCR2    Else Actzo [ETR2]IDESCR2    : Endif
   If [M:ETR2]IDECOD01=3  Grizo [ETR2]IDESCR01   Else Actzo [ETR2]IDESCR01   : Endif
   If [M:ETR2]IDECOD02=3  Grizo [ETR2]IDESCR02   Else Actzo [ETR2]IDESCR02   : Endif
Endif
If [M:ETR2]PRNCOD1=1
    Grizo [ETR2]PRNSCR1, PRNNBSCR1, PRNNBFLG1
Else
    Actzo [ETR2]PRNSCR1, PRNNBSCR1, PRNNBFLG1
Endif
If [M:ETR2]PRNNBFLG1=1  Grizo [ETR2]PRNNBSCR1  Else Actzo [ETR2]PRNNBSCR1 : Endif
If [M:ETR2]SERECOD1=2   Grizo [ETR2]SERESCR1   Else Actzo [ETR2]SERESCR1  : Endif
If [M:ETR2]AVSTOCOD1=2  Grizo [ETR2]AVSTOSCR1  Else Actzo [ETR2]AVSTOSCR1 : Endif

If WMODU = "T05"
  Raz [ETR2]UOMSAIFLG
  Grizo [ETR2]UOMSAIFLG
Endif
# Particularité retour prêt
If find(WMODU,"K7","K8") Diszo [ETR2]UOMSAIFLG, MVTPRICOD, MVTPRICOD1 : Endif

If clalev([M:ETR1])>0 Affzo [ETR1]1-99 : Endif
Affzo [ETR2]1-99
Return

$TRT_CHAMP_HEADER
#--------------------------------------------#
# Traitement des champs en-tête document     #
# Appelé depuis TRT_ECRAN du document        #
#--------------------------------------------#
   If dim([M]SRGWAIFLG)>0
    # Réception à quai autorisée => champ emplacement quai par défaut
     If [M]SRGWAIFLG<>2   TZONE(IZON)="SRGLOCDEF"
                          TMOD(IZON) =3
                          IZON+=1
     Endif
   Endif
Return

$TRT_CHAMP_DOC
#------------------------------------#
# Traitement des champs document     #
# Appelé depuis TRT_ECRAN du document#
#------------------------------------#
   If WMODU <> "T05"
      If [M:ETR2]UOMSAIFLG=1
                           If find(WMODU,"E6","R2") : # dans l'écran réception et déclaration de prod
                                                      #la zone doit s'appeler UOM
                             TZONE(IZON)="UOMSTUCOE"          : # Coeff pcustu
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="UOM"                : # UOM
                             TMOD(IZON) =2
                             IZON+=1
                           Elsif !find(WMODU,"K5","K6","K7","K8")
                             TZONE(IZON)="PCUSTUCOE"          : # Coeff pcustu
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="PCU"                : # Coeff pcustu
                             TMOD(IZON) =2
                             IZON+=1
                           Endif
                           # Particularité écrans avoirs et retours client et prêt
                           If find(WMODU,"K7","K8")                : # Retour de prêt
                             TZONE(IZON)="SAUSTUCOE"          : # SAUSTUCOE : Coeff
                             TMOD(IZON) =2                    : # Affiché
                             IZON+=1
                             TZONE(IZON)="SAU"                : # SAU : Unite de vente
                             TMOD(IZON) =2                    : # Affiché
                             IZON+=1
                             TZONE(IZON)="STU"                : # STU : Unité de stock
                             TMOD(IZON) =2                    : # Affiché
                             IZON+=1
                           Elsif find(WMODU,"K5","K6")        : # Retour client et avoir
                             TZONE(IZON)="SAUSTUCOE"          : # Coeff saustu
                             TMOD(IZON) =3                    : # Invisible
                             IZON+=1
                             TZONE(IZON)="SAU"                : # SAU
                             TMOD(IZON) =2                    : # Affiché
                             IZON+=1
                             TZONE(IZON)="STU"                : # Unité de stock
                             TMOD(IZON) =3                    : # Affiché
                             IZON+=1
                           Else
                             TZONE(IZON)="STU"                : # Unité de stock
                             TMOD(IZON) =3
                             IZON+=1
                           Endif
                           TZONE(IZON)="QTYSTU"             : # Quantité en unité de stock
                           TMOD(IZON) =3
                           IZON+=1
     Endif
   Endif
   If [M:ETR2]BPSLOTCOD>1  TZONE(IZON)="BPSLOT"              : # Lot fournisseur
                           TMOD(IZON) =[M:ETR2]BPSLOTCOD
                           IZON+=1
   Endif
   If [M:ETR2]BPSLOTSCR>1  TZONE(IZON)="BPSLOT"              : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:ETR2]BPSLOTSCR)
                           IZON+=1
   Endif
   If dim([M:ETR2]LOTCOD)>0
     If [M:ETR2]LOTCOD>1     TZONE(IZON)="LOT"                : # Lot fournisseur
                             TMOD(IZON) =[M:ETR2]LOTCOD
                             IZON+=1
     Endif
     If [M:ETR2]LOTSCR>1     TZONE(IZON)="LOT"                : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]LOTSCR)
                             IZON+=1
     Endif
   Endif
   If dim([M:ETR2]SLOCOD)>0
     If [M:ETR2]SLOCOD>1     TZONE(IZON)="SLO"                : # Sous-Lot
                             TMOD(IZON) =[M:ETR2]SLOCOD
                             IZON+=1
     Endif
     If [M:ETR2]SLOSCR>1     TZONE(IZON)="SLO"                : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]SLOSCR)
                             IZON+=1
     Endif
     If [M:ETR2]NBSLOFLG=1   TZONE(IZON)="NBSLO"              : # Nombre de sous-lot
                             TMOD(IZON)=3
                             IZON+=1
                             TZONE(IZON)="SLOF"               : # Sous-lot fin
                             TMOD(IZON)=3
                             IZON+=1
     Else                    TZONE(IZON)="SLOF"               : # Sous-lot fin (affiché)
                             TMOD(IZON)=2
                             IZON+=1
                             TZONE(IZON)="SLOF"               : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]SLOSCR)
                             IZON+=1
     Endif
   Endif
   If [M:ETR2]STACOD>1     TZONE(IZON)="STA"                  : # Statut
                           TMOD(IZON) =[M:ETR2]STACOD
                           IZON+=1
   Endif
   If [M:ETR2]STASCR>1     TZONE(IZON)="STA"                  : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:ETR2]STASCR)
                           IZON+=1
   Endif
   If dim([M:ETR2]LOCCOD)>0
     If [M:ETR2]LOCCOD>1     TZONE(IZON)="LOCTYP"             : # Type Emplacement
                             TMOD(IZON) =[M:ETR2]LOCCOD
                             IZON+=1

                             TZONE(IZON)="LOC"                : # Emplacement
                             TMOD(IZON) =[M:ETR2]LOCCOD
                             IZON+=1
     Endif
     If [M:ETR2]LOCSCR>1     TZONE(IZON)="LOCTYP"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]LOCSCR)
                             IZON+=1

                             TZONE(IZON)="LOC"                : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]LOCSCR)
                             IZON+=1
     Endif
   Endif

#                                                         # hcb X3FEAT-345 deb
  If dim([M:ETR2]LPNCOD)>0
     If [M:ETR2]LPNCOD>1     TZONE(IZON)="LPNNUM"             : # Numéro de contenant
                             TMOD(IZON) =[M:ETR2]LPNCOD
                             IZON+=1

                             TZONE(IZON)="TCTRNUM"            : # Contenant
                             TMOD(IZON) =[M:ETR2]LPNCOD
                             IZON+=1
     Endif
     If [M:ETR2]LPNSCR>1     TZONE(IZON)="LPNNUM"             : # Numéro de contenant
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]LPNSCR)
                             IZON+=1

                             TZONE(IZON)="TCTRNUM"            : # Contenant
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]LPNSCR)
                             IZON+=1
     Endif
   Endif
#                                                         # hcb X3FEAT-345 fin
   If [M:ETR2]MVTPRICOD>1    If WMODU="E6"
                               TZONE(IZON)="CPR"              : # Prix d'origine
                             Else
                               TZONE(IZON)="PRI"              : # Prix saisi
                             Endif
                             TMOD(IZON) =[M:ETR2]MVTPRICOD
                             IZON+=1
                             TZONE(IZON)="PRIORD"             : # Prix d'ordre
                             If [M:ETR2]MVTPRICOD=3
                               TMOD(IZON) =3
                             Else
                               TMOD(IZON) =2
                             Endif
                             IZON+=1
                             If WMODU="E6"
                               TZONE(IZON)="CPRCUR"           : # Devise du prix ori si invisible
                               If [M:ETR2]MVTPRICOD=3
                                 TMOD(IZON) =3
                               Else
                                 TMOD(IZON) =2
                               Endif
                               IZON+=1
                             Endif
   Endif
   If [M:ETR2]MVTPRISCR>1    If WMODU="E6"
                               TZONE(IZON)="CPR"            : # Présentation tableau
                             Else
                               TZONE(IZON)="PRI"            : # Présentation tableau
                             Endif
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]MVTPRISCR)
                             IZON+=1
   Endif
   If dim([M:ETR2]SERCOD)>0
      If [M:ETR2]SERCOD>1     TZONE(IZON)="SERNUM"             : # Numéro de série
                              TMOD(IZON) =[M:ETR2]SERCOD
                             IZON+=1
      Endif
      If [M:ETR2]SERSCR>1     TZONE(IZON)="SERNUM"             : # Présentation tableau
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:ETR2]SERSCR)
                              IZON+=1
      Endif
      If [M:ETR2]SERECOD>1    TZONE(IZON)="SERNUMF"            : # Numéro série fin
                              TMOD(IZON) =3
                              IZON+=1
     Endif
     If [M:ETR2]SERESCR>1    TZONE(IZON)="SERNUMF"           : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]SERESCR)
                             IZON+=1
     Endif
   Endif
   If dim([M:ETR2]IDECOD01)>0
     If [M:ETR2]IDECOD01>1   TZONE(IZON)="PALNUM"             : # identifiant 1
                             TMOD(IZON) =[M:ETR2]IDECOD01
                             IZON+=1
     Endif
     If [M:ETR2]IDESCR01>1   TZONE(IZON)="PALNUM"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]IDESCR01)
                             IZON+=1
     Endif
     If [M:ETR2]IDECOD02>1   TZONE(IZON)="CTRNUM"             : # identifiant 3
                             TMOD(IZON) =[M:ETR2]IDECOD02
                             IZON+=1
     Endif
     If [M:ETR2]IDESCR02>1   TZONE(IZON)="CTRNUM"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]IDESCR02)
                             IZON+=1
     Endif
   Endif
     If [M:ETR2]MVTDESCOD>1  TZONE(IZON)="MVTDES"             : # Désignation mouvement
                             TMOD(IZON) =[M:ETR2]MVTDESCOD
                             IZON+=1
     Endif
     If [M:ETR2]MVTDESSCR>1  TZONE(IZON)="MVTDES"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]MVTDESSCR)
                             IZON+=1
     Endif
    If dim([M:ETR2]WRHCOD1)>0
        If [M:ETR2]WRHCOD1>1 TZONE(IZON)="WRH"                : # Dépôt
                             TMOD(IZON) =[M:ETR2]WRHCOD1
                             IZON+=1
     Endif
     If [M:ETR2]WRHSCR1>1 TZONE(IZON)="WRH"             : # Présentation tableau    # hcb 65404
                          TMOD(IZON) =9
                          TINT(IZON) =num$([M:ETR2]WRHSCR1)
                          IZON+=1
      Endif
    Endif

Return


$TRT_ECRAN_STO
Local Integer LPOSBPS,LPOSLOT,LPOSSLO, VS

If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
If !clalev([F:ADS1]) : Local File ADOSSIER [ADS1] : Endif
Read [ADS1]DOSSIER=APPLI

#---------------- Noms fenêtres et traitement détail stock création -------------#
Local Char     WINREF1(GLONFEN) : WINREF1="ISTOENT"
Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WQ"+WNOMOBJ+WNOMTRS+"S"
#-------------------------- 1er écran -------------------------------------------#
MFROM="STOENT"
MTO="W"+WMODU+WNOMTRS+"S"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If WMODU <> "T05"
      If [M:ETR2]UOMSAIFLG1=1 TZONE(IZON)="PCUSTUCOE"          : # Coeff pcustu
                           TMOD(IZON) =2
                           IZON+=1
                           TZONE(IZON)="PCU"             : # Quantité en unité de stock
                           TMOD(IZON) =2
                           IZON+=1
      Endif
   Endif

   If [M:ETR2]BPSLOTCOD1>1 TZONE(IZON)="BPSLOTAFF"             : # Lot fournisseur
                           TMOD(IZON) =[M:ETR2]BPSLOTCOD1
                           IZON+=1
   Endif
   If [M:ETR2]BPSLOTSCR1>1 TZONE(IZON)="BPSLOTAFF"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:ETR2]BPSLOTSCR1)
                           IZON+=1
   Endif


#                                                                        # hcb 71276 deb
   If dim([M:ETR2]ECCCOD)>0
      If [M:ETR2]ECCCOD>1    TZONE(IZON)="ECCVALMAJAFF"          : # Version majeure
                             TMOD(IZON) = 3
                             IZON+=1

                             TZONE(IZON)="ECCVALMINAFF"          : # Version mineure
                             TMOD(IZON) = 3
                             IZON+=1
      Endif
      If [M:ETR2]ECCSCR>1    TZONE(IZON)="ECCVALMAJAFF"           : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]ECCSCR)
                             IZON+=1
                             TZONE(IZON)="ECCVALMINAFF"           : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]ECCSCR)
                             IZON+=1

      Endif
   Endif
   If dim([M:ETR2]ECCCODMIN)>0
      If [M:ETR2]ECCCODMIN>1    TZONE(IZON)="ECCVALMINAFF"          : # Version mineure
                             TMOD(IZON) = 3
                             IZON+=1
      Endif
      If [M:ETR2]ECCSCRMIN>1    TZONE(IZON)="ECCVALMINAFF"           : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]ECCSCR)
                             IZON+=1
      Endif
   Endif

#                                                                      # hcb 71276 fin


   If dim([M:ETR2]IDECOD1)>0                  # hcb 27200
      If [M:ETR2]IDECOD1>1    TZONE(IZON)="PALNUM"             : # Identifiant 1
                              TMOD(IZON) =[M:ETR2]IDECOD1
                              IZON+=1
      Endif
      If [M:ETR2]IDESCR1>1    TZONE(IZON)="PALNUM"             : # Présentation tableau
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:ETR2]IDESCR1)
                              IZON+=1
      Endif
      If [M:ETR2]IDECOD2>1    TZONE(IZON)="CTRNUM"             : # Identifiant 2
                              TMOD(IZON) =[M:ETR2]IDECOD2
                              IZON+=1
      Endif
      If [M:ETR2]IDESCR2>1    TZONE(IZON)="CTRNUM"             : # Présentation tableau
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:ETR2]IDESCR2)
                              IZON+=1
      Endif
   Endif                                          # hcb 27200
   If [M:ETR2]PRNCOD1=1    TZONE(IZON)="LBEFMT"             : # Format étiquette
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:ETR2]PRNSCR1>1    TZONE(IZON)="LBEFMT"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:ETR2]PRNSCR1)
                           IZON+=1
   Endif
   If [M:ETR2]PRNNBFLG1=1  TZONE(IZON)="LBENBR"             : # Nombre d'étiquettes
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:ETR2]PRNNBSCR1>1  TZONE(IZON)="LBENBR"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:ETR2]PRNNBSCR1)
                           IZON+=1
   Endif
   If [M:ETR2]MVTPRICOD1>1 TZONE(IZON)="PRI"             : # Prix du mouvement
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If dim([M:ETR2]SERECOD1)>0
     If [M:ETR2]SERECOD1>1   TZONE(IZON)="SERNUMF"          : # Série fin
                             TMOD(IZON) =3
                             IZON+=1
     Endif
     If [M:ETR2]SERESCR1>1   TZONE(IZON)="SERNUMF"          : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]SERESCR1)
                             IZON+=1
     Endif
   Endif
   If [M:ETR2]MVTDESCOD1>1 TZONE(IZON)="MVTDES"             : # Désignation
                           TMOD(IZON) =[M:ETR2]MVTDESCOD1
                           IZON+=1
   Endif
   If [M:ETR2]AVSTOCOD1>1  TZONE(IZON)="STUDIS"             : # Stock disponible
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:ETR2]AVSTOSCR1>1  TZONE(IZON)="STUDIS"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:ETR2]AVSTOSCR1)
                           IZON+=1
   Endif
    If WMODU<>"T63"          TZONE(IZON)="SAIACTFLG"          : # Saisie des quantités en UA
                             TMOD(IZON) =3
                             IZON+=1
    Endif
   OPT1=2
   If WMODU="E6" Gosub PE_PURTRS From SUBPTX : Endif : # Voir ?? Report du point d'entrée transaction achat
   If find(WMODU,"K5","K6","K7","K8") Gosub PE_SALTRS From SUBSLX : Endif : # Voir ?? Report du point d'entrée transaction vente
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
# Inversion des champs BPSLOT/LOT/SLO
If find(WMODU,"K5","K6","K7","K8") & OPT1 <> 9  # hcb 106376
    Read [AMZ]CODE=MTO;"BPSLOTAFF"
    LPOSBPS = [AMZ]NOZONE
    Read [AMZ]CODE=MTO;"LOTAFF"
    LPOSLOT = [AMZ]NOZONE
    Read [AMZ]CODE=MTO;"SLOAFF"
    LPOSSLO = [AMZ]NOZONE

    Readlock [AMZ]CODE=MTO;"BPSLOTAFF"
    [AMZ]NOZONE = LPOSSLO
    Rewrite [AMZ]
    Read [AMZ]CODE=MTO;"LOTAFF"
    [AMZ]NOZONE = LPOSBPS
    Rewrite [AMZ]
    Read [AMZ]CODE=MTO;"SLOAFF"
    [AMZ]NOZONE = LPOSLOT
    Rewrite [AMZ]

    # Validation de l'écran
    #--- Issue X3-71020
    #Call VALID(MTO,APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,VS) From VALMSK
    Call VALIDFULL(MTO,APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,VS) From VALMSK
    #---
Endif
If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif

#---------------- Noms fenêtres et traitement détail stock modification----------#
Local Char     WINREF1(GLONFEN) : WINREF1="ISTOENTM"
Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WQ"+WNOMOBJ+WNOMTRS+"M"
#-------------------------- 1er écran -------------------------------------------#
MFROM="STOENTM"
MTO="W"+WMODU+WNOMTRS+"M"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If WMODU <> "T05"
      If [M:ETR2]UOMSAIFLG1=1 TZONE(IZON)="PCUSTUCOE"          : # Coeff pcustu
                           TMOD(IZON) =2
                           IZON+=1
                           TZONE(IZON)="PCU"                   : # Quantité en unité de stock
                           TMOD(IZON) =2
                           IZON+=1
      Endif
   Endif
   If [M:ETR2]BPSLOTCOD1>1 TZONE(IZON)="BPSLOTAFF"             : # Lot fournisseur
                           TMOD(IZON) =[M:ETR2]BPSLOTCOD1
                           IZON+=1
   Endif
   If [M:ETR2]BPSLOTSCR1>1 TZONE(IZON)="BPSLOTAFF"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:ETR2]BPSLOTSCR1)
                           IZON+=1
   Endif

#                                                                        # hcb 71276 deb
   If dim([M:ETR2]ECCCOD)>0
      If [M:ETR2]ECCCOD>1    TZONE(IZON)="ECCVALMAJAFF"          : # Version majeure
                             TMOD(IZON) = 3
                             IZON+=1

                             TZONE(IZON)="ECCVALMINAFF"          : # Version mineure
                             TMOD(IZON) = 3
                             IZON+=1
      Endif
      If [M:ETR2]ECCSCR>1    TZONE(IZON)="ECCVALMAJAFF"           : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]ECCSCR)
                             IZON+=1
                             TZONE(IZON)="ECCVALMINAFF"           : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]ECCSCR)
                             IZON+=1

      Endif
   Endif
   If dim([M:ETR2]ECCCODMIN)>0
      If [M:ETR2]ECCCODMIN>1    TZONE(IZON)="ECCVALMINAFF"          : # Version mineure
                             TMOD(IZON) = 3
                             IZON+=1
      Endif
      If [M:ETR2]ECCSCRMIN>1    TZONE(IZON)="ECCVALMINAFF"           : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]ECCSCR)
                             IZON+=1
      Endif
   Endif

#                                                                      # hcb 71276 fin


   If dim([M:ETR2]IDECOD1)>0
      If [M:ETR2]IDECOD1>1    TZONE(IZON)="PALNUM"             : # Identifiant 1
                              TMOD(IZON) =[M:ETR2]IDECOD1
                              IZON+=1
      Endif
      If [M:ETR2]IDESCR1>1    TZONE(IZON)="PALNUM"             : # Présentation tableau
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:ETR2]IDESCR1)
                              IZON+=1
      Endif
      If [M:ETR2]IDECOD2>1    TZONE(IZON)="CTRNUM"             : # Identifiant 2
                              TMOD(IZON) =[M:ETR2]IDECOD2
                              IZON+=1
      Endif
      If [M:ETR2]IDESCR2>1    TZONE(IZON)="CTRNUM"             : # Présentation tableau
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:ETR2]IDESCR2)
                              IZON+=1
      Endif
   Endif
   If [M:ETR2]PRNCOD1=1    TZONE(IZON)="LBEFMT"             : # Format étiquette
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:ETR2]PRNSCR1>1    TZONE(IZON)="LBEFMT"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:ETR2]PRNSCR1)
                           IZON+=1
   Endif
   If [M:ETR2]PRNNBFLG1=1  TZONE(IZON)="LBENBR"             : # Nombre d'étiquettes
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:ETR2]PRNNBSCR1>1  TZONE(IZON)="LBENBR"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:ETR2]PRNNBSCR1)
                           IZON+=1
   Endif
   If [M:ETR2]MVTPRICOD1>1 TZONE(IZON)="PRI"             : # Prix du mouvement
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If dim([M:ETR2]SERECOD1)>0
     If [M:ETR2]SERECOD1>1   TZONE(IZON)="SERNUMF"          : # Série fin
                             TMOD(IZON) =3
                             IZON+=1
     Endif
     If [M:ETR2]SERESCR1>1   TZONE(IZON)="SERNUMF"          : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]SERESCR1)
                             IZON+=1
     Endif
   Endif
   If [M:ETR2]MVTDESCOD1>1 TZONE(IZON)="MVTDES"             : # Désignation
                           TMOD(IZON) =[M:ETR2]MVTDESCOD1
                           IZON+=1
   Endif
   If [M:ETR2]AVSTOCOD1>1  TZONE(IZON)="STUDIS"             : # Stock disponible
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:ETR2]AVSTOSCR1>1  TZONE(IZON)="STUDIS"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:ETR2]AVSTOSCR1)
                           IZON+=1
   Endif

   OPT1=2
   If WMODU="E6" Gosub PE_PURTRS From SUBPTX : Endif : # Voir ?? Report du point d'entrée transaction achat
   If find(WMODU,"K5","K6","K7","K8") Gosub PE_SALTRS From SUBSLX : Endif : # Voir ?? Report du point d'entrée transaction vente
Else OPT1=9
Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif

# Inversion des champs BPSLOT/LOT/SLO
If find(WMODU,"K5","K6","K7","K8") & OPT1 <> 9  # hcb 106376
    Read [AMZ]CODE=MTO;"BPSLOTAFF"
    LPOSBPS = [AMZ]NOZONE
    Read [AMZ]CODE=MTO;"LOTAFF"
    LPOSLOT = [AMZ]NOZONE
    Read [AMZ]CODE=MTO;"SLOAFF"
    LPOSSLO = [AMZ]NOZONE

    Readlock [AMZ]CODE=MTO;"BPSLOTAFF"
    [AMZ]NOZONE = LPOSSLO
    Rewrite [AMZ]
    Readlock [AMZ]CODE=MTO;"LOTAFF"
    [AMZ]NOZONE = LPOSBPS
    Rewrite [AMZ]
    Readlock [AMZ]CODE=MTO;"SLOAFF"
    [AMZ]NOZONE = LPOSLOT
    Rewrite [AMZ]
    # Validation de l'écran
    #--- Issue X3-71020
    #Call VALID(MTO,APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,VS) From VALMSK
    Call VALIDFULL(MTO,APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,VS) From VALMSK
    #---
Endif
If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif
Return


#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW" [AWI] : Endif : # Si appel par le FUNxxxTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR" [AWP] : Endif : # Si appel par le FUNxxxTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS
#----- Suppression fenêtre -----#
Gosub TRT_SUP_FEN
If WENAFLG=1 : Return : Endif
#----- Génération fenêtre pour réception si transaction active -----#
Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
  [F:AWI]MSKENT    = ""
  WNOMMSK=MTO
  I=find("STOETR2",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = 2
  [F:AWI]ACS       = WACSCOD
  [F:AWI]ENAFLG    = WENAFLG
  [F:AWI]TRN       = WNOMTRS
  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
Endif
# Validation en V140 -> VALID From VALWIN
Call VALID(NOMWIN1,APPLI,1,OK) From VALWIN
Return


#----------------------------------------#
# Création ou modif du texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA
Call MAJTEXTRA(evalue("[M:"+WABR+"]DESAXX"),"STKTRS","DESAXX",num$(evalue("[M:"+WABR+"]SRTTYP")),
&              evalue("[M:"+WABR+"]SRTNUM")) From ATEXTRA
[F:SRT]SRTDES   =GLANGUE+"~"+evalue("[M:"+WABR+"]DESAXX")
[F:SRT]SRTTYPCAR=num$([F:SRT]SRTTYP)
Return

#######################################################################
#                   Actions sur champs écran [M:ETR1]                 #
#######################################################################
Subprog AS_NBLIG
#--------------------#
# Avant saisie NBLIG #
#--------------------#
If [M:ETR1]NBLIG=0 [M:ETR1]NBLIG=GOPTCANA : Affzo 10 : Endif
End


Subprog AS_CCESCRS(VALEUR)
#------------------------------------#
# Avant saisie du code tableau-fiche #
#------------------------------------#
Variable Integer VALEUR
If [M:ETR1]CCECODS(nolign-1)=3 VALEUR=1 : mkstat=2 : Endif
End


#########################################################################
#                   Actions sur champs écran [M:ETR2]                   #
#########################################################################
Subprog AS_PRNCOD1(VALEUR)
Variable Integer VALEUR
#                                                              # hcb X3-92339 deb
If clalev([F:ACV]) = 0 : Local File ACTIV [ACV] : Endif
If [F:ACV]CODACT     <> "LPN"
   Read [ACV] CODACT  = "LPN"
   If fstat
      Raz [F:ACV]
   Endif
Endif
If [F:ACV]FLACT <> 2
   GMENLOC(6) = 1
   GMENLOC(7) = 1
Endif
If GFONCTION = "GESSRG"   # ds le plan de rangement il ni a pas de création de LPN
   GMENLOC(6) = 1
   GMENLOC(7) = 1
Endif
#                                                              # hcb X3-92339 fin

    GMENLOC(3) = 1
    GMENLOC(4) = 1
    GMENLOC(5) = 1

End

#--- Dem 60616
Subprog AS_WRHCOD1(VALEUR)
Variable Integer VALEUR
If dim([M]WRHOBY)>0
   If [M]WRHOBY=2 GMENLOC(1)=1 Endif
Endif
End

#########################################################################

