#<AdxTL>@(#)9.0.0.0 $Revision$
#########################################################################
# SUBPOCA : Gestion des commandes ouvertes d'achat          CG 20/01/98 #
#           Modifié                                         HN Sep 2003 #
# --------------------------------------------------------------------- #
# Traitement des actions "Gosub" de l'objet "POC   modifié MBT 03/01/01 #
# Les traitements sur champ "Call" se trouvent dans le SUBPOC           #
# --------------------------------------------------------------------- #
# GCUR      contient la devise commande                                 #
# GLOCALDEV contient la devise société                                  #
# GSYSCUR   contient la devise dossier                                  #
# GFINRSP   contient le site financier ou responsable financier         #
#########################################################################


$DEFTRANS
#--------------------------------------------------------#
# Avant lecture des transactions de saisie disponibles : #
# Si GFLAG est renseigné la transaction est déja choisie #
# par le menu. Vérifier si elle est valide               #
#--------------------------------------------------------#
Local Shortint OUVFICFLG
If !clalev([F:PTR])  Local File PURTRS [PTR] : Endif
If GFLAG<>""
  Read [PTR] PTR0=5;GFLAG
  If fstat | [F:PTR]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:PTR]ACSCOD<>"" & GPROFIL<>GSUPER
    If !clalev([F:ACC])  Local File ACCES  [ACC] : OUVFICFLG=1 : Endif
    Read [ACC] CODACC=GUSER;[F:PTR]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1  Close Local File [ACC] : Raz OUVFICFLG : Endif
Return


$VARIANTE
#---------------------------------------#
# Après lecture de chaque transaction : #
# La transaction est-elle valide ?      #
# VARCOD contient le code transaction.  #
# Mettre OK à zéro si non valide.       #
#---------------------------------------#
Read [PTR] PTR0=5;VARCOD
If fstat | [F:PTR]ENAFLG=1 OK=0 : Endif
Return


$SETTRANS
#-------------------------------------#
# Après sélection de la transaction : #
# GFLAG = code transaction choisie    #
#-------------------------------------#
If clalev ([F:PTR])=0  Local File PURTRS [PTR] : Endif
Read [PTR] PTR0=5;GFLAG : If fstat Raz [F:PTR] : Endif

#MAE, le 30/01/08, GRP_SITE
GGRPFCY = [F:PTR]GFY
Return

# Issue 116835 - 2016-05-31 by SR : Ne pas contrôler enregistrement obsolète
$AVANT_OUVRE
ANOUPDTICK = 1
Return

$FILTRE
#--------------------------------------------------#
# Ne traiter que les commandes de type cde ouverte #
#--------------------------------------------------#
Default File [POH]
FILTSUP="POHTYP=2"
Return


$AV_IMPRIME
#-----------------------------------------------#
# Avant impression : Chargement nom du document #
#-----------------------------------------------#
If [F:PTR]PTRTYP<>5 | [F:PTR]PTRNUM<>GPTRNUM  : # Relecture transaction si nécessaire
   Read [PTR] PTR0=5;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
#----- Si document renseigné (écran ou transaction), prendre celui-la -----#
If [M:POC0]DOCNAM<>""
  [L]AREPORT=[M:POC0]DOCNAM
Elsif [F:PTR]DOCNAM<>""
  [L]AREPORT=[F:PTR]DOCNAM
Endif
Return


$AP_IMPRIME
#---------------------------------------------------------------#
# Après une impression il faut être sur d'être sur le bon enreg #
#---------------------------------------------------------------#
Raz [L]AREPORT
Gosub RELIT From GOBJSUB
Return


$OUVRE
Raz GSOC_ACTIVE
#---------------------------------------------------------------------#
# Dans EXEFNC si pas de site par défaut pour le module concerné       #
# GFCYDEF(0) = premier site de la table sites (modif Beinat 15/12/99) #
# FAUX, il faut toujours avoir GFCYDEF(0) = site par défaut du module #
# même si ce site par défaut est vide !                               #
#---------------------------------------------------------------------#
GFCYDEF(0)=GFCYDEF(6)
If !clalev([F:BPR2])   Local File BPARTNER    [BPR2] : Endif
If !clalev([F:POCB])   Local File PORDERC     [POCB] : Endif
If !clalev([F:TCY])    Local File TABCOUNTRY  [TCY]  : Endif
If !clalev([F:POS])    Local File POSCOD      [POS]  : Endif
If !clalev([F:TCA])    Local File TABCOUAFF   [TCA]  : Endif
If !clalev([F:STCH])   Local File COSTSTCH    [STCH] : Endif # Issue 84130 - 2012-09-18 by MUARN : landed cost SDC
If !clalev([F:STCF])   Local File COSTSTCF    [STCF] : Endif # Issue 90991 - 2013-10-23 by MUARN : sdc sites
#----- Ouverture fichiers pour inter-sites / inter-sociétés -----#
If GMODU(5)=2 : # Si module Ventes présent
  If !clalev([F:BPC])  Local File BPCUSTOMER  [BPC] : Endif
  If !clalev([F:ITS])  Local File ITMSALES    [ITS] : Endif
  If !clalev([F:MVC])  Local File BPCUSTMVT   [MVC] : Endif
  If !clalev([F:SOH])  Local File SORDER      [SOH] : Endif
  If !clalev([F:BPD])  Local File BPDLVCUST   [BPD] : Endif
  If !clalev([M:SORW]) Local Mask SORW       [SORW] : Endif : # Pour màj contrat ventes
Endif
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
GCONSDIA=0 : # Rend saisissable les écrans avec abréviation [DIA]
GPTRNUM=[F:PTR]PTRNUM
#-----------------------------------------------------#
# Contrôle existence de la structure tarif par défaut #
# et chargement des libellés colonnes par défaut      #
#-----------------------------------------------------#
Raz GRCPFCY, GPLISTC, GPUU, GREVFLG
Local Libelle  WMODULE : WMODULE=6
Local Char     CODE(3)
Local Integer  I, J, WRET, WCOD
Local Shortint OUVFICFLG, SAVNOLIGN, NOL
Local Integer  STAT
Local Decimal  WCOEUOM
Local Integer  WPOPLIN
Call CTLSTRUCT(2,WRET) From TRTPRICE
If WRET<>0 OK=0 : Return : Endif
GPLISTC="néant" : # Pour forcer l'affichage des entêtes de colonne si structure=""
Call COLREM("C",2,"") From TRTPRICE
Call TYPREM(2,"")     From TRTPRICE
Call TARIFCHGT(6)     From TRTPRICE
#----- chargement des formats évalués -----#
For I=0 To 8 [M:POC2]FMTREM(I)="NZ:9.2#" : Next I
#----- Ouverture masques des adresses et informations douanières ----#
If !clalev([M:AD63])  Local Mask ADRBPR   [AD63] : Endif
If !clalev([M:AD64])  Local Mask ADRBPR   [AD64] : Endif
If !clalev([M:PCEW])  Local Mask PCEE     [PCEW] : Endif
#-----
If !clalev([F:GCM])   Local File GACM     [GCM] : Endif
If !clalev([F:GAC])   Local File GACCOUNT [GAC] : Endif
#---------------------------------------------------#
# Récupération des paramètres achats                #
# Chargement GREVFLG : 1=Modif sans avenant  2=Avec #
#---------------------------------------------------#
GFCY=GFCYDEF(6)
Call GETFCYDEF(GFCY,"[F:FCY]PURFLG=2") From TRTX3
Gosub CHARG_PARAM : # Si GMESSAGE chargé pas de paramétrage signature
If GMESSAGE<>""
  GERR=1 : OK=0 : Return
Endif
GREVFLG=0 : GORITITCOL=1
#----- Effacement fichier de travail -----#
Gosub EFFAC_PWRKPO  From SUBPOCA : If OK=0 Return : Endif
#-----------------------------------------------#
# Déclaration des variables pour tableau lignes #
#-----------------------------------------------#
Gosub DECLARE From TABLEAUX
GAPPFLG=1
Return


$AFFMASK
#----------------------------------------------------#
# Premier affichage écran après appel de la fonction #
# -------------------------------------------------- #
#         Chargement des formats évalués             #
#----------------------------------------------------#
For I=0 To 8 [M:POC2]FMTREM(I)="NZ:9.2#" : Next I
Return


$SETBOUT
#-------------------------------------------------------------------------#
# Activation / désactivation des menus (ToolBar) et boutons (bas d'écran) #
#-------------------------------------------------------------------------#
#----- Menus "Texte entête" et "Texte pied" dans la ToolBar -----#
If GREP="C" | GREP="D" | [M:POC0]POHNUM<>""
  CHMEN+="FG"
Endif
#----- Menu "Texte article" dans la ToolBar -----#
If [M:POC0]POHNUM<>"" & [M:POC2]ITMREF<>""
  CHMEN+="H"
Endif
#----- Menus "Adresse commande"  et "Adresse expéditeur"  dans la ToolBar -----#
If GREP<>"" | CLECUR
  CHMEN+="IJ"
Endif
#----- Menu "Informations douanières" -----#
If CLECUR & [M:POC2]ITMREF<>""
  CHMEN+="K"
Endif
#----- Menu "Situation cde" dans la ToolBar -----#
If GREP="" & CLECUR  CHMEN+="L" : Endif
#----- Menu "Transaction" -----#
CHMEN+="M"
#----- Menu "Traçabilité" -----#
CHMEN+="T"
#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
#----- L'utilisateur a-t-il droit à la modification ? -----#
GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2
  Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
Call VIREBOUT (CHAINE,"DH")  From GOBJET
#-----
If CLECUR
  If [F:POH]RCPFLG>1 | [F:POH]CLEFLG>1
    Call VIREBOUT (CHAINE,"A")  From GOBJET : # Suppression bouton Supprimer
  Endif
  If [F:POH]CLEFLG>1
    Call VIREBOUT (CHAINE,"M")  From GOBJET : # Suppression Modification
  Endif
Endif
If GREP<>""  Call VIREBOUT (CHAINE,"3")  From GOBJET : Endif
If !CLECUR | [M:POC1]APPFLG>3  Call VIREBOUT (CHAINE,"3") From GOBJET : Endif
If [M:POC1]CLEFLG>1 | GHISTO
  Call VIREBOUT (CHAINE,"12")  From GOBJET
Endif
#----- Récupération du verrou objet pour test dans un S/P (Call) -----#
[M:POC0]XVERROU=VERROU
Return


$AVANTBOUT
#-----------------------------------#
# Avant exécution des boutons       #
# --------------------------------- #
# 1 = Ajout ligne                   #
# 2 = Supp. ligne                   #
# 3 = Signataires                   #
#                                   #
# F = Texte entête                  #
# G = Texte pied                    #
# H = Texte article                 #
# I = Adresse commande              #
# J = Adresse expédition            #
# K = Informations douanières       #
# L = Situation commande            #
# M = Visu transaction de saisie    #
#-----------------------------------#
Local  Libelle  WTYPADR
Local  Char     WABREV(5)
Local  Char     SAV_ZONCOU(GLONAVA)
Local  Integer  SAV_GCONSULT : SAV_GCONSULT=GCONSULT
If GREP<>"" SAV_ZONCOU=COUZON Else SAV_ZONCOU="" : Endif
#----- S'assurer que la classe [F:POH] corresponde bien au contrat affiché -----#
If [F:POH]POHNUM<>[M:POC0]POHNUM
  Read [POH] POH0=[M:POC0]POHNUM : If fstat  Raz [F:POH] : Endif
Endif
#-----
Case BOUT
  When "1" : If [M:POC0]BPSNUM=""
                GMESSAGE=mess(196,194,1) : GERR=1 : OK=0 : Return
             Endif
  When "F","G","H" : If GREP="" & dim(ACTMOD)>0 & !ACTMOD  GCONSDIA=2 : Endif
  When "I","J" : If GREP="" & (!ACTMOD | !VERROU)  GCONSDIA=2 : Endif
  When "K" : Local  Integer WEXEFLG : WEXEFLG=2
Endcase
Return


$EXEBOUT
#------------------------------------#
# Après exécution des boutons du bas #
# 1 = Ajout ligne                    #
# 2 = Supp. ligne                    #
# 3 = Signataires                    #
#------------------------------------#
Case BOUT
  When "1" : SUIZON="[M:POC2]ITMREF"
             If [M:POC2]XUPDFLG(0)<5 [M:POC2]XUPDFLG(0)+=5 : Endif
  When "2" : SUIZON="[M:POC2]ITMREF"
             If [M:POC2]XUPDFLG(0)<5 [M:POC2]XUPDFLG(0)+=5 : Endif
Endcase
Return


$FIN_ACTION
#------------------------------------------------------------#
# Après exécution boutons juste avant de revenir à la saisie #
# 1 = Ajout ligne                                            #
# 2 = Supp. ligne                                            #
#------------------------------------------------------------#
Case BOUT
  When "1" : Diszo [POC0]POHNUM
             If GREP="" & mkstat=4 GREP="M" : REP="M" : Endif
  When "2" : Diszo [POC0]POHNUM
             If GREP="" & mkstat=4 GREP="M" : REP="M" : Endif
Endcase
Return


$STATUT
#-------------------------------------------#
# Après exécution des boutons de la ToolBar #
# F = Texte entête                          #
# G = Texte pied                            #
# H = Texte article                         #
# I = Adresse commande                      #
# J = Adresse expédition                    #
# K = Informations douanières               #
# L = Situation de commande                 #
# M = Visu transaction de saisie            #
#-------------------------------------------#
Case BOUT
  When "F" : Gosub APRESBOUT_TEXTE
  When "G" : Gosub APRESBOUT_TEXTE
  When "H" : Gosub APRESBOUT_TEXTE
  When "I" : If !GCONSULT & GREP=""
               WTYPADR=1 : WABREV="AD63" : Gosub MAJ_ADRESSE From TRTACHCDE1
             Endif
  When "J" : If !GCONSULT & GREP=""
               WTYPADR=2 : WABREV="AD64" : Gosub MAJ_ADRESSE From TRTACHCDE1
             Endif
  When "K" : Gosub ACTIV_GSTAENR
Endcase
#VPO 14/03/11 72298 ajout test dim(SAV_ZONCOU)
If dim(SAV_ZONCOU)>0 & SAV_ZONCOU<>"" & !GIMPORT  SUIZON=SAV_ZONCOU : Endif
GCONSULT=SAV_GCONSULT
Return
#----- Activation du bouton enregistrer -----#
$ACTIV_GSTAENR
#--- WEXEFLG paramètre de l'action
If GREP="" & WEXEFLG=9
  Gosub ENTRE_MODIF From GOBJSUB
Endif
Return


$APRESBOUT_TEXTE
#-------------------------------------------------#
# Texte entête, pied et ligne article de commande #
#-------------------------------------------------#
If mkstat=4 & GREP="" : # Texte modifié
  Gosub ENTRE_MODIF From GOBJSUB
Endif
#----- Affichage icone texte -----#
If !GIMPORT
  If GREP="" & ([M:POC1]TEX1<>"" | [M:POC1]TEX2<>"")
    Call SET_IMAGE(4)   From GESECRAN
  Else
    Call RESET_IMAGE(4) From GESECRAN
  Endif
Endif
Return


$DEFLIG
#----------------------------------#
# Définition du fichier des lignes #
# -------------------------------- #
# Critère lecture     (CRIT)       #
# Nom du fichier      (FICLIG)     #
# Abréviation fichier (ABLIG)      #
# Zone numéro ligne   (ZONLIG)     #
#----------------------------------#
Default Mask [POC2]
Default File [POP]
CRIT   = 'POHNUM="'+[M:POC0]POHNUM+'" & POPLIN ='+num$([M:POC2]POPLIN)
FICLIG = "PORDERP"
ABLIG  = "POP"
ZONLIG = "POPSEQ"
Return


$LIENS_LIG
#-----------------------------------------------------------#
# Ici on se trouve dans la boucle de chargement des détails #
# en ligne à ligne, je renseigne une zone de l'écran qui    #
# contient la date début application (nom différent)        #
#-----------------------------------------------------------#
[M:POC2]POPSTRDAT(nolign-1) = [F:POP]STRDAT
[M:POC2]PRIFLG   (nolign-1) = 2
#----- Chargement sections analytiques -----#
Call CHARG_ACCCCE(nolign-1,"","","[M:POC2]CCE","POP",0,
&              [F:POP]POHNUM,[F:POP]POPLIN,[F:POP]POPSEQ,"") From TRTX3CPT

# Issue 90991 - 2013-11-05 by MUARN : supression données en commande ouverte
## Issue 84130 - 2012-09-28 by MUARN : coeff/cout modifiable si pas de SDC
#If [M:POC2]STCNUM<> ""
#  Diszo [POC2]CPRAMT, CPRCOE
#Else
#  Actzo [POC2]CPRAMT, CPRCOE
#Endif

Return


$INICRE_LIG
#----------------------------#
# Avant le Write de la ligne #
#----------------------------#
[F:POP]POHNUM=[M:POC0]POHNUM
[F:POP]STRDAT=[M:POC2]POPSTRDAT(nolign-1)
[F:POP]POHTYP=[F:POH]POHTYP
[F:POP]LINBUY=[F:POH]BUY
[F:POP]CPY   =GSOCIETE
#----- Chargement des désignations article -----#
[F:POP]ITMDES =[M:POC2]ITMDES
[F:POP]ITMDES1=[M:POC2]ITMDES1
#-----
If dim([F:POP]TSICOD)>0
  J=dim([F:POP]TSICOD)-1
  If dim([F:ITM]TSICOD)-1<J
    J=dim([F:ITM]TSICOD)-1
  Endif
  For I=0 To J
    [F:POP]TSICOD(I)=[F:ITM]TSICOD(I)
  Next I
Endif
#----- Initialisation des codes taxe -----#
Call ALIVATCOD(2,[M:POC0]BPSNUM,[M:POC2]ITMREF,"POC2",0) From TRTX3
[F:POP]VAT(0)  =[M:POC2]VAT(0)
[F:POP]VAT(1)  =[M:POC2]VAT(1)
[F:POP]VAT(2)  =[M:POC2]VAT(2)
If func AFNC.ACTIV("PTX")
  If dim([M:POC2]TAXRCP)>0  [F:POP]TAXRCP =[M:POC2]TAXRCP : Endif
  If dim([M:POC2]TAXISS)>0  [F:POP]TAXISS =[M:POC2]TAXISS : Endif
  If dim([M:POC2]TAXOTH1)>0 [F:POP]TAXOTH1=[M:POC2]TAXRCP : Endif
  If dim([M:POC2]TAXOTH2)>0 [F:POP]TAXOTH2=[M:POC2]TAXRCP : Endif
Endif
#-----
If GREVFLG=2
  [F:POP]LINREVNUM=[M:POC0]REVNUM
Endif
Return


$INIMOD_LIG
#------------------------------#
# Avant le Rewrite de la ligne #
#------------------------------#
[F:POP]STRDAT=[M:POC2]POPSTRDAT(nolign-1)
If GREVFLG=2
  [F:POP]LINREVNUM=[M:POC0]REVNUM
Endif
Return


$VALLIG
#----------------------------------------------------------------------#
# Traitements complémentaires ligne commande                           #
# SIGN vaut +1 en création ou modification                             #
#      vaut -1 en annulation (TRTLIG="A") ou avant modif. (TRTLIG="M") #
# -------------------------------------------------------------------- #
# La gestion des signatures se fait sur le contrat complet             #
# La mise à jour des bugdets se fait a la création des DL fermes       #
#----------------------------------------------------------------------#
If TRTLIG="A" & GREVFLG=2           : # Gestion de l'avenant sur PORDERP
  Call HISTO_CDE ("POP","","A") From TRTACHCDE1
  If GOK<1  Return : Endif
Endif
If TRTLIG="M" & GREVFLG=2 & SIGN=-1 : # Gestion de l'avenant sur PORDERP
  Call HISTO_CDE ("POP","","M") From TRTACHCDE1
  If GOK<1  Return : Endif
Endif
If TRTLIG="A"
  Call ENREG_ACCCCE(0,"","","","POP",
&                   0,[F:POP]POHNUM,[F:POP]POPLIN,[F:POP]POPSEQ,"","A")    From TRTX3CPT
Elsif SIGN=+1
  # Issue X3-71903 - 2018-02-22 by MUARN : ne pas enregistrer si des DL existent, sinon problème en désengagement
  Filter [POQ] Where POHNUM=[M:POC0]POHNUM
&                & POPLIN=[M:POC2]POPLIN
&                & WIPSTA=1
&                & DEMRCPDAT>=[M:POC2]POPSTRDAT(nolign-1)
&                & DEMRCPDAT<=[M:POC2]POPDAT(nolign-1)
  Look [POQ] POQ0 First
  If fstat <>0
    Call ENREG_ACCCCE(nolign-1,"[M:POC2]LINACC(","[M:POC2]LINDSP","[M:POC2]CCE","POP",
&                   0,[F:POP]POHNUM,[F:POP]POPLIN,[F:POP]POPSEQ,"",TRTLIG) From TRTX3CPT
  Endif
Endif
If GOK<1  Return : Endif
Return


$RAZCRE
#------------------------------------------------------#
# Valeurs par défaut et initialisations avant création #
#------------------------------------------------------#
If GFCY<>GFCYDEF(6)
  GFCY=GFCYDEF(6)
  Call GETFCYDEF(GFCY,"[F:FCY]PURFLG=2") From TRTX3
  Gosub CHARG_PARAM
Endif

# Issue 71069 - 2016-01-12 by MUARN : PJT
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY([M:POC0]POHFCY,"[M:POC2]PJT") From TRTPJT
Endif

#----- chargement des formats évalués -----#
For I=0 To 8 [M:POC2]FMTREM(I)="NZ:9.2#" : Next I
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL
#----- Ecran POC0 -----#
Actzo [POC0]1-99
[M:POC0]POHFCY=GFCY
If GUSRFCY(1)<>"\" & GNBAUZ=1 & [M:POC0]POHFCY<>""
  Diszo [POC0]POHFCY        : # Saisie inutile si un seul site permis
Else
  Actzo [POC0]POHFCY        : # Activation saisie si plusieurs sites possibles
Endif
[M:POC0]ORDDAT=date$
Grizo [POC0]SALFCY
#----- Ecran POC1 -----#
Actzo [POC1]1-99
Grizo [POC1]STOFCY
[M:POC1]STRDAT=[M:POC0]ORDDAT
[M:POC1]ENDDAT=[M:POC0]ORDDAT+365
[M:POC1]BUY   =GUSER
[M:POC1]RCPFCY=GRCPFCY
[M:POC1]INVFCY=GFINRSP
[M:POC1]APPFLG=1
[M:POC1]PRNFLG=1
[M:POC1]CLEFLG=1
[M:POC1]RCPFLG=1
[M:POC1]INVFLG=1
#----- Chargement nbre d'axes -----#
If dim([M:POC1]NBAXE)>0
  If [M:POC1]NBAXE=0
    [M:POC1]NBAXE=GOPTCANA
  Endif
Endif
#----- Ecran POC2 -----#
Actzo [POC2]1-99
Grizo [POC2]LINSTOFCY
# [M:POC2]XUPDFLG(0)=5 : # Pour éviter le grisage de l'onglet article la 1ère fois
[M:POC2]POPLIN    =1
[M:POC2]LINSTOFCY =[M:POC1]STOFCY
[M:POC2]PRHFCY    =[M:POC1]RCPFCY
[M:POC2]XPUUFLG   =2
[M:POC2]FIMHORUOM =1
[M:POC2]XSTRDAT   =[M:POC1]STRDAT
[M:POC2]XENDDAT   =[M:POC1]ENDDAT
#----- Ecran POC3 -----#
Actzo [POC3]5-10
Diszo [POC3]15 : # Désactivation du bloc ARC
#----- Gestion des textes -----#
Call RAZ_CLOB From ACLOB : GCONSDIA=0 : # Rend saisissable le texte
Raz [M:POC1]TEX1, [M:POC1]TEX2, [M:POC2]LINTEX
#-----
GREVFLG=1 : GPLIFLG=0
Gosub EFFAC_PWRKPO     : # Effacement fichiers de travail
Raz [M:AD63], [M:AD64] : # Effacement des masques adresses fournisseur
If !GIMPORT  Call RESET_IMAGE (4) From GESECRAN : Endif
GAPPFLG=1

# Issue 71069 - 2016-01-12 by MUARN : PJT
# A faire apres tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:POC0]POHFCY,"[M:POC2]PJT") From TRTPJT
Endif

Return


$RAZDUP
#------------------------------------------------------#
# Avant duplication                                    #
# ---------------------------------------------------- #
# Remise à zéro de certaines colonnes dans les détails #
# de toute la colonne dans le cas de la duplication    #
# qui pour l'instant n'existe pas                      #
#------------------------------------------------------#
Raz [M:POC0]POHNUM , [M:POC0]XPOHNUM, [M:POC0]REVNUM
[M:POC1]APPFLG   =1
[M:POC1]PRNFLG   =1
[M:POC1]CLEFLG   =1
[M:POC1]RCPFLG   =1
[M:POC1]INVFLG   =1
#----- Gestion des textes entête et pied -----#
Call RAZ_CLOB From ACLOB : GCONSDIA=0 : # Rend saisissable le texte
If left$([M:POC1]TEX1,3)="POH"
  Call DUP_CLOB("POH",[M:POC1]TEX1,WRET) From TRTX3TEX
  If WRET<1  Raz [M:POC1]TEX1 : Endif
Endif
If left$([M:POC1]TEX2,3)="POH"
  Call DUP_CLOB("POH",[M:POC1]TEX2,WRET) From TRTX3TEX
  If WRET<1  Raz [M:POC1]TEX2 : Endif
Endif
#----- Gestion des textes lignes article -----#
If left$([M:POC2]LINTEX,3)="POC" : # Il faudrait màj fichier travail pour autres lignes
  Call DUP_CLOB("POC",[M:POC2]LINTEX,WRET) From TRTX3TEX
  If WRET<1  Raz [M:POC2]LINTEX : Endif
Endif
#-----
Raz [M:POC3]OCNDAT, [M:POC3]OCNNUM, [M:POC3]OCNREM
Actzo [POC0]1-99
Actzo [POC1]1-99
Actzo [POC2]1-99
Actzo [POC3]5-10
#-----
GREVFLG=1 : GPLIFLG=0
If !GIMPORT
  Affzo [POC0]POHNUM, FILLER3, REVNUM : Affzo [POC1]35 : Affzo [POC3]15
Endif
Diszo [POC0]SALFCY
Diszo [POC3]15   : # Désactivation du bloc ARC
GAPPFLG=1
Return


$LIENS
#---------------------------------------#
# Chargement GFCY : Site de la commande #
#            GCUR : Devise commande     #
# Récupération des paramètres ACHATS    #
#---------------------------------------#
GAPPFLG=1
[M:POC0]XPOHNUM=[M:POC0]POHNUM
GREVFLG=0
If GFCY<>[F:POH]POHFCY GFCY=[F:POH]POHFCY : Gosub CHARG_PARAM : Endif
GRCPFCY=[F:POH]RCPFCY : # Site de réception par défaut
#----- Si commande inter-sites -----#
If [F:POH]BETFCY=2
  If [F:POH]SALFCY<>""
    #----- Avec correspondance dans les ventes ------#
    If [F:FCY]FCY<>[F:POH]SALFCY
      Read [FCY] FCY0=[F:POH]SALFCY : If fstat  Raz [F:FCY] : Endif
    Endif
    GCPY=[F:FCY]LEGCPY
    GSTOFCY=[F:POH]STOFCY : # Site d'expédition par défaut
    Call PARAM([F:POH]SALFCY,"LINBPD",GBIDC3) From ADOVAL
    GLINBPD=val(GBIDC3)
  Else
    #----- Sans correspondance dans les ventes ------#
    If [F:FCY]FCY<>[F:POH]STOFCY
      Read [FCY] FCY0=[F:POH]STOFCY : If fstat  Raz [F:FCY] : Endif
    Endif
    GCPY=[F:FCY]LEGCPY
    GSTOFCY=[F:POH]STOFCY : # Site d'expédition par défaut
  Endif
Endif
#-----
GCUR=[F:POH]CUR
GREVFLG=0
#--------------------------------------------------#
# Type de donnée MC1 = devise commande (GCUR)      #
#                MC2 = devise société  (GLOCALDEV) #
#                MC3 = devise dossier  (GSYSCUR)   #
#--------------------------------------------------#
GDEV1(1)=GCUR : GDEV1(2)=GLOCALDEV : GDEV1(3)=GSYSCUR
For I=1 To 3
  GDEVFM1(I)=GDEVFMT1(max(find(GDEV1(I),GDEVISE(1..GNBDEV)),1))
Next I
#---------------------------------------------------------------------#
# Chargement de la classe [M:AD63] zones adresse fournisseur commande #
#---------------------------------------------------------------------#
If [F:POH]CRY<>"" | [F:POH]CTY<>""
  [M:AD63] = [F:POH]
  [M:AD63]ADBBPR = [F:POH]BPSNUM
  [M:AD63]ADBFLG = 2
Else
  Raz [M:AD63]
  [M:AD63]BPAADD = [F:POH]BPAADD
  [M:AD63]ADBBPR = [F:POH]BPSNUM
Endif
#-----------------------------------------------------------------------#
# Chargement de la classe [M:AD64] zones adresse fournisseur expéditeur #
#-----------------------------------------------------------------------#
If [F:POH]BPOCRY<>"" | [F:POH]BPOCTY<>""
  [M:AD64]BPAADD      = [F:POH]BPOADD
  [M:AD64]BPRNAM(0)   = [F:POH]BPONAM(0)
  [M:AD64]BPRNAM(1)   = [F:POH]BPONAM(1)
  [M:AD64]BPAADDLIG(0)= [F:POH]BPOADDLIG(0)
  [M:AD64]BPAADDLIG(1)= [F:POH]BPOADDLIG(1)
  [M:AD64]BPAADDLIG(2)= [F:POH]BPOADDLIG(2)
  [M:AD64]CRY         = [F:POH]BPOCRY
  [M:AD64]CRYNAM      = [F:POH]BPOCRYNAM
  [M:AD64]SAT         = [F:POH]BPOSAT
  [M:AD64]POSCOD      = [F:POH]BPOPOSCOD
  [M:AD64]CTY         = [F:POH]BPOCTY
  [M:AD64]ADBBPR      = [F:POH]BPSNUM
  [M:AD64]ADBFLG      = 2
Else
  Raz [M:AD64]
  [M:AD64]BPAADD = [F:POH]BPOADD
  [M:AD64]ADBBPR = [F:POH]BPSNUM
Endif
#--------------------------------------------------------------------#
# Lecture BPSUPPLIER avec chargement libellés/formats colonnes tarif #
# Lecture BPARTNER                                                   #
#--------------------------------------------------------------------#
If [F:BPS]BPSNUM<>[M:POC0]BPSNUM
  Read [BPS] BPS0=[M:POC0]BPSNUM
  If fstat
    Raz [F:BPS] : GOK=0 : Call RSTA("BPS",[M:POC0]BPSNUM) From GLOCK : Return
  Endif
Endif
#----- Alimentation à partir du modèle d'édition du fournisseur commande -----#
Call ALI_PRTMOD("POC0",9) From TRTX3
#-----
If [M:AD63]ADBFLG=2
  [M:POC0]XBPRNAM=[M:AD63]BPRNAM(0)
Else
  [M:POC0]XBPRNAM=[F:BPS]BPSNAM
Endif
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call TARIFCHGT(6)                From TRTPRICE
  GSOC_UPDFLG=1 : # Pour forcer l'affichage des entêtes de colonne variables
  #----- Affichage entêtes de colonne variables -----#
  If !GIMPORT
    Local Char BASPAG(10) : BASPAG="NBLIG" : Gosub TIT_COL From ="W1WE5"+GPTRNUM+"2"
  Endif
Endif
#-----
If [F:BPR]BPRNUM<>[M:POC0]BPSNUM
  Read [BPR] BPR0=[M:POC0]BPSNUM
  If fstat
    Raz [F:BPR] : GOK=0 : Call RSTA("BPR",[M:POC0]BPSNUM) From GLOCK : Return
  Endif
Endif
#-----------------------------#
# Conversion Mt mini commande #
#-----------------------------#
If GSYSCUR<>[M:POC1]CUR
  STAT=0
  Call CONVERT (GSYSCUR,GCUR,GLOCALDEV,[M:POC1]CHGTYP,[M:POC0]ORDDAT,
&              [F:BPS]ORDMINAMT,[M:POC3]WORDMINAMT,STAT) From TRTDEV
Else
  [M:POC3]WORDMINAMT=[F:BPS]ORDMINAMT
Endif
[M:POC3]WCUR   =[M:POC1]CUR
[M:POC3]WCUR1  =[M:POC1]CUR
#----- Chargement des sections analytiques entête -----#
If dim([M:POC1]NBAXE)>0
  Call CHARG_CCEH("POC1","NBAXE","POH") From TRTX3CPT
Endif
#-----
Raz [M:POC2], [M:POC1]DATMIN, [M:POC1]DATMAX
Call FMTREM("POC2",GCUR) From TRTPRICE
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL
#----- Chargement des éléments facturation -----#
Call CHARG_ELEMENTS (5,[M:POC0]POHNUM,"POC3") From TRTACHELT1
#-------------------------------------#
# Lecture des lignes articles PORDERC #
#-------------------------------------#
Gosub EFFAC_PWRKPO : # Effacement fichiers de travail
Filter [POC] Where POHNUM=[M:POC0]POHNUM Order By Key POC0
For [POC]
  [M:POC2]          = [F:POH]
  [M:POC2]          = [F:POC]
  #----- Chargement des comptes -----#
  Call CHARG_ACCX("POC2","NBCOA","LINACC","POC") From TRTX3CPT
  #-----
  [M:POC2]XSTRDAT   = [F:POC]STRDAT
  [M:POC2]XENDDAT   = [F:POC]ENDDAT
  [M:POC2]LINTEX    = [F:POC]TEX
  [M:POC2]WCURVLT   = [M:POC1]CUR
  [M:POC2]FIMHORUOM = 1
  If [F:POH]APPFLG>2
    Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]POPLIN
    [G:POQ]currind=1 : [G:POQ]currlen=0 : # Réinitialisation clé par défaut
    If fstat [M:POC2]XPUUFLG=2 Else [M:POC2]XPUUFLG=1 : Endif
  Else
    [M:POC2]XPUUFLG=2
  Endif
  I=[M:POC2]NBART
  [M:POC2]XITMREF(I)=[F:POC]ITMREF
  [M:POC2]XPOPLIN(I)=[F:POC]POPLIN
  [M:POC2]XUPDFLG(I)=0
  [M:POC2]XCREFLG(I)=I+1
  [M:POC2]XLINSTOFCY(I)=[F:POC]STOFCY
  [M:POC2]XPRHFCY(I)=[F:POC]PRHFCY
  [M:POC1]LASTPOPLIN=[F:POC]POPLIN
  If [M:POC1]DATMIN=[0/0/0] | [F:POC]STRDAT<[M:POC1]DATMIN
    [M:POC1]DATMIN=[F:POC]STRDAT
  Endif
  If [M:POC1]DATMAX=[0/0/0] | [F:POC]ENDDAT>[M:POC1]DATMAX
    [M:POC1]DATMAX=[F:POC]ENDDAT
  Endif
  [M:POC2]LINCREFLG=1
  Gosub LIENS From TABLEAUX
  [M:POC2]LINSTOFCY=[F:POC]STOFCY
  [M:POC2]PRHFCY=[F:POC]PRHFCY
  [M:POC2]FCYADD=[F:POC]FCYADD
  [M:POC2]XMAXLIG(I)=[M:POC2]NBLIG
  If dim(ONUM)>0
    For J=0 To [M:POC2]NBLIG-1
      [M:POC2]XONUM(J)=ONUM(J)
    Next J
  Endif
  Gosub RAZ_LIGNES
  [M:POC2]NBART+=1
  Gosub CHARG_PWRKPO : If GOK<1  GERR=1 : OK=0 : Break : Endif
Next
Filter [POC]
If GOK<1  Return : Endif
If [M:POC2]NBART=0 & ([M:POC0]BETFCY<>2 | [M:POC0]BETCPY=2) : # Contrats inter-site sans ligne autorisés
  GMESSAGE=mess(45,194,1) : GERR=1 : OK=0 : Return
Endif
[M:POC2]XNOLIGN=[M:POC2]NBART
#----- Lecture de l'article si nécessaire -----#
If [F:ITM]ITMREF<>[M:POC2]ITMREF
  Read [ITM] ITM0=[M:POC2]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#----- Lecture article-fournisseur si nécessaire -----#
If [F:ITP]ITMREF<>[M:POC2]ITMREF | [F:ITP]BPSNUM<>[M:POC0]BPSNUM
  Read [ITP] ITP0=[M:POC2]ITMREF;[M:POC0]BPSNUM
  If fstat Raz [F:ITP] : Endif
Endif

# Issue 71069 - 2016-01-12 by MUARN : PJT
# A faire avant tout le reste
If GPJTSNGDOC = G_NON & [F:POH]CLEFLG=1 Then
 Call PJT_MODFCY([M:POC0]POHFCY,"[M:POC2]PJT") From TRTPJT
Endif

#----- Activation ou désactivation de certains champs -----#
If [F:POH]CLEFLG=2 : # Commande soldée
  Diszo  [POC0]POHFCY, BPSNUM, ORDREF, ORDDAT
  Diszo  [POC1]1-20
  If dim([M:POC1]CCE)>0  Diszo [POC1]CCE : Endif
  Diszo  [POC2]10-99
  Diszo  [POC3]5,15
Else
  Diszo [POC0]POHFCY, BPSNUM, ORDDAT
  #----- Commande réceptionnée ou facturée pas de modif du fournisseur facturant ou payé -----#
  If [F:POH]INVFLG>1 | [F:POH]INVNBR>0 | [F:POH]RCPFLG>1 | [F:POH]RCPNBR>0
     Diszo [POC1]BPSINV, BPAINV, BPRPAY, BPAPAY
  Else
     Actzo [POC1]BPSINV, BPAINV, BPRPAY, BPAPAY
  Endif
  #-----
  Actzo [POC1]STRDAT, ENDDAT, BUY, MDL, BPTNUM
  If [M:POC2]ITMREF<>"" & [M:POC2]POPLIN<>0
    Actzo [POC2]ITMDES,  ITMDES1, FCYADD, USEPLC, EXTQTYPUU, FIMHOR, FRTHOR, FRTHORUOM,
&               XSTRDAT, XENDDAT
    Diszo [POC2]ITMREF, ITMREFBPS
    # Issue 90991 - 2013-11-05 by MUARN : supression données en commande ouverte
    # Issue 84130 - 2012-09-28 by MUARN : coeff/cout modifiable si pas de SDC
#    If [M:POC2]STCNUM<> ""
#      Diszo [POC2]CPRAMT, CPRCOE
#    Else
#      Actzo [POC2]CPRAMT, CPRCOE
#    Endif
  Endif
  If [M:POC0]BETFCY=2
    Diszo  [POC0]SALFCY
    Diszo  [POC1]RCPFCY, STOFCY
    Actzo  [POC2]PRHFCY, LINSTOFCY
    Diszo  [POC3]OCNDAT, OCNNUM, OCNREM
    If [M:POC0]BETCPY<>2
      Grizo  [POC1]BPSINV, BPAINV, BPRPAY, BPAPAY, PTE, CUR, CHGTYP, INVFCY, VACBPR
      If dim([M:POC1]CCE)>0  Grizo [POC1]CCE : Endif
      Grizo  [POC2]PLI, PRIVLT, WCURVLT, 30
      Grizo  [POC3]5-10
      If [M:POC0]SALFCY<>""  Diszo [POC3]15 Else Actzo [POC3]15 : Endif
    Else
      Diszo  [POC1]PTE, CUR, CHGTYP, INVFCY, VACBPR
      If dim([M:POC1]CCE)>0  Diszo [POC1]CCE : Endif
      Actzo  [POC2]PLI, PRIVLT, WCURVLT, 30
      Actzo  [POC3]5-10
      If [M:POC0]SALFCY<>""  Diszo [POC3]15 Else Actzo [POC3]15 : Endif
    Endif
    #Affzo  [POC3]5
  Else
    Grizo  [POC0]SALFCY
    Actzo  [POC1]PTE, INVFCY
    Diszo  [POC1]RCPFCY
    Grizo  [POC1]STOFCY
    If dim([M:POC1]CCE)>0  Actzo [POC1]CCE : Endif
    Diszo  [POC1]CUR, CHGTYP, VACBPR
    Grizo  [POC2]LINSTOFCY
    If [M:POC2]ITMREF<>"" & [M:POC2]POPLIN<>0
      # Issue 90991 - 2013-11-06 by MUARN : supression données en commande ouverte
      #Actzo  [POC2]PRHFCY, PLI, PRIVLT, WCURVLT, CPRCUR, 30
      Actzo  [POC2]PRHFCY, PLI, PRIVLT, WCURVLT, 30
    Endif
    Actzo  [POC3]OCNDAT, OCNNUM, OCNREM
    #Affzo  [POC3]5
    Actzo  [POC3]5-15
  Endif
  If [M:POC2]ITMREF<>"" & [M:POC2]POPLIN<>0
    # Issue 71069 - 2016-03-30 by MUARN : PJT
    Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]POPLIN
    #----- Si pas d'existence de demandes de livraison alors modification PJT -----#
    If fstat <> 0
      Actzo [M:POC2]PJT
    Else
      Diszo [M:POC2]PJT
    Endif
    If [M:POC0]SALFCY<>""
      Diszo [POC2]PRHFCY, PUU
    Elsif [M:POC2]XPUUFLG<>2
      Diszo [POC2]PUU
    Else
      Actzo [POC2]PUU
    Endif
  Endif
Endif
If [M:POC2]ITMREF="" | [M:POC2]POPLIN=0 Grizo [POC2]10-30 : Endif
#-----
If GFONC1="GESPOC"  Call RAZ_CLOB From ACLOB   : Endif
If [F:POH]CLEFLG=2  GCONSDIA=2 Else GCONSDIA=0 : Endif
#----- Affichage icone texte -----#
If !GIMPORT
  If [M:POC1]TEX1<>"" | [M:POC1]TEX2<>""
    Call SET_IMAGE (4)   From GESECRAN
  Else
    Call RESET_IMAGE (4) From GESECRAN
  Endif
Endif

# Issue 71069 - 2016-01-12 by MUARN : PJT
# A faire après tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:POC0]POHFCY,"[M:POC2]PJT") From TRTPJT
Endif

Return


#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
If COUZON="CUR"        |
&  COUZON="CHGTYP"     |
&  COUZON="STRDAT"     |
&  COUZON="ENDDAT"     |
&  COUZON="PUU"        |
&  COUZON="EXTQTYPUU"  |
&  COUZON="PLI"        |
&  COUZON="XSTRDAT"    |
&  COUZON="XENDDAT"    |
&  COUZON="POPSTRDAT"  |
&  COUZON="GROPRI"     |
&  COUZON="DISCRGVAL1" |
&  COUZON="DISCRGVAL2" |
&  COUZON="DISCRGVAL3" |
&  COUZON="DISCRGVAL4" |
&  COUZON="DISCRGVAL5" |
&  COUZON="DISCRGVAL6" |
&  COUZON="DISCRGVAL7" |
&  COUZON="DISCRGVAL8" |
&  COUZON="DISCRGVAL9" |
&  COUZON="INVDTAAMT"
  GAPPFLG=2
Endif
Return


$INICRE
#-----------------------------------#
# Chargement avant le Write [F:POH] #
#-----------------------------------#
Raz [F:POH]TOTORD, [F:POH]TTVORD
[F:POH]CPY=GSOCIETE
[F:POH]POHTYP=2 : [F:POH]PURTYP=1 : [F:POH]PRNFLG=1
[F:POH]RCPFLG=1 : [F:POH]CLEFLG=1 : [F:POH]INVFLG=1
If GMANCOU<>2 | (GMANCOU=2 & vireblc([M:POC0]POHNUM,2)="")
  Call NUMERO(GCODNUM,[M:POC0]POHFCY,[M:POC0]ORDDAT,"",[M:POC0]POHNUM,STAT) From SUBANM
  If GOK<0
    Return
  Elsif GOK<1 | STAT<>0
    GOK=0 : GERR=1 : GMESSAGE=GCODNUM-mess(60,199,1)
    Return
  Endif
  [F:POH]POHNUM=[M:POC0]POHNUM
Endif
Gosub CHARGENTETE
#---------------------------------------------------#
# Création ou duplication des textes entête et pied #
#---------------------------------------------------#
Gosub CHARG_TEXT_ENTETE
#----- Création 1er signataire et màj indicateur de signature -----#
If GAPPPOC>1
  If [F:POH]BETCPY=2 | [F:POH]BETFCY<>2 : # Pas de signature pour contrats inter-site
    If [F:POH]CUR<>GLOCALDEV
      Call CONVERT([F:POH]CUR,GLOCALDEV,GLOCALDEV,[M:POC1]CHGTYP,GHIDATE,
&                  [F:POH]TOTVLT,GBIDD2,STAT) From TRTDEV
    Else
      GBIDD2=[F:POH]TOTVLT
    Endif
    [F:POH]APPFLG=0
  Else
    [F:POH]APPFLG=4   : # Pas de gestion de signature
  Endif
Else
  [F:POH]APPFLG=4     : # Pas de gestion de signature
Endif
#-------------------------------------------------------------------#
# Appel du S/P ventes pour création de l'entête contrat (SORDER) et #
# récupération du numéro de contrat vente pour maj dans le PORDER   #
#-------------------------------------------------------------------#
If [F:POH]BETFCY=2 & [F:POH]SALFCY<>"" & [F:POH]APPFLG>3
  Raz [M:SORW]
  [M:SORW]MAJCOD   = "C"
  [M:SORW]POHFCY   = [M:POC0]POHFCY
  [M:SORW]BPCINV   = [M:POC1]BPCINV
  [M:SORW]         = [M:POC3]
  [M:SORW]CUR      = [M:POC1]CUR
  [M:SORW]BETFCY   = [M:POC0]BETFCY
  [M:SORW]BETCPY   = [M:POC0]BETCPY
  [M:SORW]BPCORD   = [M:POC0]BPCORD
  [M:SORW]PRHFCY   = [M:POC2]PRHFCY
  [M:SORW]SALFCY   = [M:POC0]SALFCY
  [M:SORW]VLYDATCON= [M:POC1]ENDDAT
  [M:SORW]POHNUM   = [M:POC0]POHNUM
  # 95742 : PJT en inter société/inter site : (LD:21/04/16)
  # Le PJT transite uniquement en intersite
  If [F:POH]BETCPY=1
      [M:SORW]PJTH=[M:POC1]PJTH
  Endif
  # 95742 : PJT en inter société/inter site : (LD:21/04/16)
  Call MAJ_SOH From TRTVENMSIT
  If GMESSAGE<>"" GERR=1 : Endif
  If GOK<1 : Return : Endif : # ça c'est mal passé, abandon de la transaction
  [F:POH]OCNNUM =[M:SORW]SOHNUM
  [M:POC3]OCNNUM=[M:SORW]SOHNUM
  [M:POC3]OCNDAT=[M:POC0]ORDDAT
  [F:POH]OCNDAT=[M:POC0]ORDDAT
  If [M:POC3]OCNNUM<>""
    [M:POC3]OCNREM=mess(74,187,1)
    [F:POH]OCNREM=[M:POC3]OCNREM
  Endif
  If !GIMPORT  Affzo [POC3]OCNDAT, OCNNUM, OCNREM : Endif
Endif
Return


$CREATION
#-----------------------------#
# Création des lignes contrat #
#-----------------------------#
SAVNOLIGN=nolign
#----- Ecriture des éléments de facturation avec comptes et sections -----#
Call ENREG_ELEMENTS(5,[M:POC0]POHNUM,"POC3","C") From TRTACHELT1
If GOK<1  Return : Endif
#-----
If [M:POC2]NBART=0  Return : Endif : # Contrat inter-site sans ligne
For NOL=0 To [M:POC2]NBART-1
  Gosub CHARG_ONGLET_ART
  Gosub CREATION_POC : If GOK<1 Break : Endif
Next NOL
nolign=SAVNOLIGN
Return


$APRES_CRE
#----------------------------------------------------------------#
# Effacement fichiers de travail et affichage numéro de commande #
#----------------------------------------------------------------#
Gosub EFFAC_PWRKPO From SUBPOCA   : # Effacement fichiers de travail
Read [POH] POH0=[M:POC0]POHNUM    : # Il faut relire à cause des màj workflow
[M:POC1]=[F:POH]
[M:POC3]=[F:POH]
If !GIMPORT
  Affzo [POC0]POHNUM : Affzo [POC1]35 : Affzo [POC3]15
  If [M:POC1]TEX1<>"" | [M:POC1]TEX1<>""
    Call SET_IMAGE(4)   From GESECRAN
  Else
    Call RESET_IMAGE(4) From GESECRAN
  Endif
Endif
Raz [M:POC2]
Gosub LIENS From SUBPOCA
Affzo [POC2]
GREVFLG=0 : GPLIFLG=0             : # Effacement indicateurs
GAPPFLG=1
Return


$AB_CREATION
#-------------------------------------------#
# Abandon de la création suite à une erreur #
#-------------------------------------------#
Return


$AVANT_MOD
#-----------------------------------------------------------------#
# Appel du S/P ventes pour vérif modification du contrat (SORDER) #
#-----------------------------------------------------------------#
OK=1
If GREVFLG<>0 Return : Endif : # L'AVANT_MOD a déjà été executée !
GREVFLG=1
If [F:POH]BETFCY=2 & [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
  Raz [M:SORW]
  [M:SORW]MAJCOD = "M"
  [M:SORW]SOHNUM = [M:POC3]OCNNUM
  Call CTL_MAJ_SOH From TRTVENMSIT
  If GMESSAGE<>"" : # Modification contrat vente non autorisée
    GERR=1 : OK=0 : GREVFLG=0 : Return
  Endif
Endif
#---------------------------------------------#
# Après modification avec avenant ?           #
# Contrat signé : Modification ?              #
# Attention section appelée en ajout de ligne #
# OK=0 --> Pas de modification                #
#---------------------------------------------#
#----- Contrat soldé, modification interdite !
If [F:POH]CLEFLG=2
  GMESSAGE=mess(47,194,1) : GERR=1 : OK=0 : GREVFLG=0 : Return
Endif
If [F:POH]APPFLG=1 Return : Endif
#----- Contrat signé, modification ?
If [F:POH]APPFLG=2 | [F:POH]APPFLG=3
  OK=2 : Call AVERTIR(mess(48,194,1),OK) From GESECRAN
  If OK=1  OK=0 : GREVFLG=0 : Return  Else OK=1 : Endif
Endif
# Issue X3-71652 - 2018-01-26 by SDEM : begin
If GPURREV < 2 OK=1 : Return : Endif : # Pas de gestion d'avenant
#----- Contrat réceptionné ou facturé, modification avec avenant ? -----#
If [F:POH]RCPFLG>1 | [F:POH]INVFLG>1
  If GPURREV=2
    OK=2 : Call OUINON(mess(49,194,1),OK) From GESECRAN
    If OK=1  Return Else OK=1 : Goto AVEC_AVENANT : Endif
  Elsif GPURREV=3
    If OK=1  Return Else OK=1 : Goto AVEC_AVENANT : Endif
  Endif
Endif
#----- Contrat envoyé au fournisseur, modification avec avenant ?
If [F:POH]PRNFLG=2 & [F:POH]APPFLG>2
  OK=2 : Call OUINON(mess(50,194,1),OK) From GESECRAN
  If OK=1  Return Else OK=1 : Goto  AVEC_AVENANT : Endif
Endif
#----- Modification avec avenant ?
If [F:POH]APPFLG<>3 Return : Endif
# Issue X3-71652 - 2018-01-25 by SDEM : begin
If GPURREV=2 Then
  OK=2
  Call OUINON(mess(51,194,1),OK) From GESECRAN
Elsif GPURREV=3
  OK=2
Endif
# Issue X3-71652 - 2018-01-25 by SDEM : end
If OK=1 Return Else OK=1 : Endif
$AVEC_AVENANT
GREVFLG=2 : [M:POC0]REVNUM+=1
If !GIMPORT Affzo [POC0]FILLER3, REVNUM : Endif
Return

VERIF_MOD
#------------------------------#
# Vérification en modification #
#------------------------------#
Gosub VERIF
Return


$AVANT_MODFIC
#---------------------------------------------------------------#
# Avant chargement des nouvelles valeurs dans la classe [F:POH] #
# Historisation des changements entête si modif avec avenant    #
#---------------------------------------------------------------#
#----- Mise à jour fournisseur facturant des lignes si nécessaire -----#
If [M:POC1]BPSINV<>[F:POH]BPSINV | [M:POC1]BPAINV<>[F:POH]BPAINV
  Update [POQ] Where POHNUM=[F:POH]POHNUM
&              With  BPSINV=[M:POC1]BPSINV, BPAINV=[M:POC1]BPAINV
  If fstat  GOK=0 : Call FSTA("POQ") From GLOCK : Return : Endif
Endif
#----- Cas particulier où l'on modifie le texte en le supprimant -----#
If [M:POC1]TEX1="" & left$([F:POH]TEX1,3)="POH"
  Call SUP_CLOB([F:POH]TEX1,WRET) From TRTX3TEX
Endif
If [M:POC1]TEX2="" & left$([F:POH]TEX2,3)="POH"
  Call SUP_CLOB([F:POH]TEX2,WRET) From TRTX3TEX
Endif
#-----
If GREVFLG=2  Call HISTO_CDE("POH","","M") From TRTACHCDE1 : Endif
#----- Positionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
If GAPPPOC>1 & (find([F:POH]APPFLG,1,5) | (find([F:POH]APPFLG,2,3) & GAPPFLG=2))
  # Issue 120072 - 2016-12-02 by SR : Annulation systématique des signatures
  GPE = 1
  GPOINT = "POCRAZSIG" : Gosub ENTREE From EXEFNC
  #----- Si des DL existent, il ne faut pas toucher le circuit de signature -----#
  Look [POQ] POQ0(1)=[M:POC0]POHNUM
  [G:POQ]currind=1 : [G:POQ]currlen=0 : # Réinitialisation clé par défaut
  # Issue 120072 - 2016-12-02 by SR : Si pas de DL ou GPE positionné  à 0 par traitement spécifique
  If fstat | GPE = 0
    Call ANNULE_SUIVI("POC",mess(652,197,1),1,WRET) From TRTACHDIV1
    If GOK<1  Return : Endif
  Endif
Endif
Return


$INIMOD
#--------------------------------------------------#
# Chargement avant le Rewrite [POH] entête contrat #
#--------------------------------------------------#
If GREVFLG=2  [F:POH]PRNFLG=1 : [F:POH]REVNUM=[M:POC0]REVNUM : Endif
Gosub CHARGENTETE
#---------------------------------------------------#
# Création ou duplication des textes entête et pied #
#---------------------------------------------------#
Gosub CHARG_TEXT_ENTETE
#----- Mise à jour indicateurs réceptionné, facturé et soldé -----#
If [F:POH]RCPNBR=0    [F:POH]RCPFLG=1 Else [F:POH]RCPFLG=2 : Endif
If [F:POH]INVNBR=0    [F:POH]INVFLG=1 Else [F:POH]INVFLG=2 : Endif
If [F:POH]CLELINNBR=0 [F:POH]CLEFLG=1 : Endif
#----- Activation worflow signature -----#
If GAPPPOC>1 & (find([F:POH]APPFLG,1,5) | (find([F:POH]APPFLG,2,3) & GAPPFLG=2))
 # Issue 120072 - 2016-12-02 by SR : Positionnement systématique de APPFLG à la valeur 0
  GPE = 1
  GPOINT = "POCAPPFLG" : Gosub ENTREE From EXEFNC
  #----- Si des DL existent, il ne faut pas toucher le circuit de signature -----#
  Look [POQ] POQ0(1)=[M:POC0]POHNUM
  [G:POQ]currind=1 : [G:POQ]currlen=0 : # Réinitialisation clé par défaut
  # Issue 120072 - 2016-12-02 by SR : Si pas de DL ou GPE positionné à 0 par traitement spécifique
  If fstat | GPE = 0
    [F:POH]APPFLG=0
  Endif
Endif
#----- Appel du S/P ventes pour modif/suppression entête contrat (SORDER) -----#
If [F:POH]BETFCY=2 & [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
  #-----
  If [F:POH]APPFLG>2
    Raz [M:SORW]
    [M:SORW]MAJCOD   = "M"
    [M:SORW]SOHNUM   = [M:POC3]OCNNUM
    [M:SORW]BPCORD   = [M:POC0]BPCORD
    [M:SORW]PRHFCY   = [M:POC2]PRHFCY
    [M:SORW]VLYDATCON= [F:POH]ENDDAT
    # 95742 : PJT en inter société/inter site : (LD:21/04/16)
    # Le PJT transite uniquement en intersite
    If [F:POH]BETCPY=1
        [M:SORW]PJTH=[M:POC1]PJTH
    Endif
    # 95742 : PJT en inter société/inter site : (LD:21/04/16)
    Call MAJ_SOH From TRTVENMSIT
    If GMESSAGE<>""  GERR=1 : Endif
    If GOK<1  Return : Endif : # ça c'est mal passé, abandon de la transaction
  Else
    Raz [M:SORW]
    [M:SORW]MAJCOD   = "A"
    [M:SORW]SOHNUM   = [M:POC3]OCNNUM
    Call MAJ_SOH From TRTVENMSIT
    If GMESSAGE<>""  GERR=1 : Endif
    If GOK<1  Return : Endif : # ça c'est mal passé, abandon de la transaction
    Raz [F:POH]OCNDAT,  [F:POH]OCNNUM,  [F:POH]OCNREM
    Raz [M:POC3]OCNDAT, [M:POC3]OCNNUM, [M:POC3]OCNREM
    If !GIMPORT  Affzo [M:POC3]OCNDAT, OCNNUM, OCNREM : Endif
  Endif
  #-----
Endif
Return


$MODIF
#---------------------------------#
# Modification des lignes contrat #
#---------------------------------#
SAVNOLIGN=nolign
#----- Ecriture des éléments de facturation avec comptes et sections -----#
Call ENREG_ELEMENTS(5,[M:POC0]POHNUM,"POC3","M") From TRTACHELT1
If GOK<1  Return : Endif
#-----
For [POC] POC0 Where POHNUM=[M:POC0]POHNUM
  If !find([F:POC]POPLIN,[M:POC2]XPOPLIN(0..[M:POC2]NBART-1))
    Gosub SUPPRESS_POC : If GOK<1 Break : Endif
  Endif
Next
If GOK<1  nolign=SAVNOLIGN : Return : Endif
If [M:POC2]NBART=0  Return : Endif : # Contrat inter-site sans ligne
For NOL=0 To [M:POC2]NBART-1
  Gosub CHARG_ONGLET_ART
  If [M:POC2]XCREFLG(NOL)=0 : # Nouvelle ligne article contrat
    Gosub CREATION_POC : If GOK<1 Break : Endif
  Else
    Gosub MODIF_POC    : If GOK<1 Break : Endif
  Endif
Next NOL
nolign=SAVNOLIGN
Return


$APRES_MOD
#--------------------------------------------------------------------------#
# Après modification : affichage indicateurs entête et rechargement lignes #
#--------------------------------------------------------------------------#
Gosub EFFAC_PWRKPO From SUBPOCA   : # Effacement fichiers de travail
Read [POH] POH0=[M:POC0]POHNUM    : # Il faut relire à cause des màj workflow
[M:POC1]=[F:POH]
[M:POC3]=[F:POH]
If !GIMPORT  Affzo [POC1]35 : Affzo [POC3]15 : Endif
Raz [M:POC2]
Gosub LIENS From SUBPOCA          : # Rechargement des lignes
Affzo [POC2]
GREVFLG=0 : GPLIFLG=0             : # Effacement indicateurs
GAPPFLG=1
Return


$AB_MODIF
#-----------------------------------------------#
# Abandon de la modification suite à une erreur #
#-----------------------------------------------#
Return


$ABANDON
#----------------------------------------------------#
# Abandon création ou modification par l'utilisateur #
#----------------------------------------------------#
Local Shortint SAVGOK : SAVGOK=GOK  : # Sauvegarde de GOK
GREVFLG=0 : GPLIFLG=0               : # Effacement indicateurs
GAPPFLG=1
Gosub SUPPRESS_TEX From SUBPOCA     : # Suppression des textes entête, pied et lignes
Gosub EFFAC_PWRKPO From SUBPOCA     : # Effacement fichiers de travail
Raz [M:POC2]
GOK=SAVGOK                          : # Restitution de GOK
Return


$VERF_ANU
#-----------------------------------------#
# Contrôles de suppression                #
# --------------------------------------- #
# Supression interdite si :               #
#   - des DL existent (POQ)               #
#   - le contrat est réceptionné ou soldé #
# Avertissement et choix si contrat signé #
#-----------------------------------------#
#----- On regarde si des lignes POQ existent pour le contrat -----#
Look [POQ] POQ0(1)=[M:POC0]POHNUM
[G:POQ]currind=1 : [G:POQ]currlen=0 : # Réinitialisation clé par défaut
If !fstat : # Il existe des enregistrements, on ne peut pas supprimer
  GMESSAGE=mess(79,194,1) : GERR=1 : OK=0 : Return
Endif
#----- Appel du S/P ventes pour vérif suppression du contrat total (SORDER) -----#
If [F:POH]BETFCY=2 & [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
  Raz [M:SORW]
  [M:SORW]MAJCOD = "A"
  [M:SORW]SOHNUM = [M:POC3]OCNNUM
  Call CTL_MAJ_SOH From TRTVENMSIT
  If GMESSAGE<>"" : # Suppression contrat vente non autorisée
    GERR=1 : OK=0 : Return
  Endif
Endif
#----- Test contrat réceptionné ? -----#
If [F:POH]RCPFLG>1
  GMESSAGE=mess(15,194,1) : GERR=1 : OK=0 : Return
Endif
#----- Test contrat soldé ? -----#
If [F:POH]CLEFLG>1
  GMESSAGE=mess(16,194,1) : GERR=1 : OK=0 : Return
Endif
#----- Choix si contrat signé -----#
If [F:POH]APPFLG>1 & [F:POH]APPFLG<4
  OK=2 : Call AVERTIR(mess(17,194,1),OK) From GESECRAN
  If OK=1  OK=0 : Return : Endif
Endif
Return


$ANNULE
Local Integer  WRET
#--------------------------------------#
# Supression des textes entête et pied #
#--------------------------------------#
If left$([F:POH]TEX1,3)="POH"
  Call SUP_CLOB([F:POH]TEX1,GBIDI1) From TRTX3TEX
Endif
If left$([F:POH]TEX2,3)="POH"
  Call SUP_CLOB([F:POH]TEX2,GBIDI1) From TRTX3TEX
Endif
#---------------------------------------------------#
# Historisation entête contrat si no avenant <> 0   #
# Annulation des lignes article contrat             #
# Action VALLIG appelée à chaque ligne avec SIGN=-1 #
#---------------------------------------------------#
If [F:POH]REVNUM<>0
  GREVFLG=2
  Call HISTO_CDE("POH","","A") From TRTACHCDE1
  If GOK<1  Return : Endif
Endif
#----- Suppression éléments de facturation avec comptes et sections -----#
Call ENREG_ELEMENTS(5,[M:POC0]POHNUM,"POC3","A") From TRTACHELT1
If GOK<1  Return : Endif
#----- Suppression des lignes du contrat -----#
For [POC] POC0 Where POHNUM=[F:POH]POHNUM
  Gosub SUPPRESS_POC : If GOK<1 Break : Endif
Next
If GOK<1 Return : Endif
#----- Positionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
If GAPPPOC>1 & [F:POH]APPFLG<>4
  If dim(WRET)<1  Local Integer WRET : Endif
  Call ANNULE_SUIVI("POC",mess(653,197,1),1,WRET) From TRTACHDIV1
  If GOK<1  Return : Endif
Endif
#----- Appel du S/P ventes pour suppression de l'entête contrat (SORDER) -----#
If [M:POC0]BETFCY=2 & [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
  Raz [M:SORW]
  [M:SORW]MAJCOD = "A"
  [M:SORW]SOHNUM = [M:POC3]OCNNUM
  Call MAJ_SOH From TRTVENMSIT
  If GMESSAGE<>"" GERR=1 : Endif
  If GOK<1 : Return : Endif : # ça c'est mal passé, abandon de la transaction
Endif
Return


$AP_ANNULE
#------------------#
# Après annulation #
#------------------#
Local Shortint SAVGOK : SAVGOK=GOK  : # Sauvegarde de GOK
Gosub EFFAC_PWRKPO From SUBPOCA     : # Effacement fichiers de travail
Raz [M:POC2]
GREVFLG=0 : GPLIFLG=0               : # Effacement indicateurs
GOK=SAVGOK                          : # Restitution de GOK
Return


$FERME
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB
#-----
If clalev([M:AD63])  Close Local Mask [AD63] : Endif
If clalev([M:AD64])  Close Local Mask [AD64] : Endif
If clalev([M:PCEW])  Close Local Mask [PCEW] : Endif
#-----
If GFONC1="GESPOC"
  Raz GORITITCOL, GMENBOUT, GCONSDIA
Endif
Gosub EFFAC_PWRKPO : # Effacement fichiers de travail
#----- Effacement icone texte sauf en import -----#
If !GIMPORT  Call RESET_IMAGE(4) From GESECRAN : Endif
#----- Effacement des filtres -----#
Filter [POC] : Filter [POQ]
Return


$VERIF
Local Shortint RES
#--------------------------------------------------------------#
# Màj fichiers de travail à partir de l'onglet article courant #
# Vérifications : Code tarif renseigné ou ligne tarif          #
#                 Au moins une ligne si contrat non inter-site #
#                 Unicité article-site de réception            #
#--------------------------------------------------------------#
Raz mkstat
# VPO 07/12/10 69066 verifier valeur Condition de paiement, Code escompte, Regime de taxe
# VPO 01/03/11 71999 ameliorer message d'erreur
If [M:POC1]PTE<>""
    #Call CONTROLE("TPT","",[M:POC1]PTE,"",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POC1~PTE")+'"\'+GMESSAGE : Return : Endif
    #-- X3Suivi 71937 : Données par législation pour le Conditions de paiement
    #--CPO 71937 01/08/2013 Suite dev review
    Call CONTTPT ([M:POC1]PTE,GCURLEG,'','',[M:POC0]POHFCY,'','') From SUBTPT
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POC1~PTE")+'"\'+GMESSAGE : Return : Endif
Endif
If [M:POC1]DEP<>""
	  #--CPO 71937 TABDEPAGIO
		mkstat = 0
    #Call CONTROLE("TDA","!",[M:POC1]DEP,"",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POC1~DEP")+'"\'+GMESSAGE : Return : Endif
    Call CONTTDA([M:POC1]DEP,GCURLEG,"POC1","DEP",[M:POC0]POHFCY,"","") From SUBTDA
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POC1~DEP")+'"\'+GMESSAGE : Return : Endif
    #--/CPO
Endif
If [M:POC1]VACBPR<>""
    mkstat=0
    # 71937 : Multilégislation
    #Call CONTADI([M:POC1]VACBPR,"1","") From SUBADI
    #If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POC1~VACBPR")+'"\'+GMESSAGE : Return : Endif
    #Call CONTROLE("ADI","",[M:POC1]VACBPR,"1",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POC1~VACBPR")+'"\'+GMESSAGE : Return : Endif
    Call CONTTVB([M:POC1]VACBPR,GCURLEG,"POC1","VACBPR",[M:POC0]POHFCY,"","") From SUBTVB
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POC1~VACBPR")+'"\'+GMESSAGE : Return : Endif
    # 71937 : Multilégislation
Endif

Gosub MAJ_PWRKPO : If mkstat SUIZON="NBLIG" : OK=0 : Return : Endif
If [M:POC2]NBART=0 & ([M:POC0]BETFCY<>2 | [M:POC0]BETCPY=2)
  GMESSAGE=mess(61,199,1) : GERR=1 : SUIZON="ITMREF" : OK=0 : Return
Endif

If [M:POC2]NBART>1
  For I=0 To [M:POC2]NBART-2
    For J=I+1 To [M:POC2]NBART-1
      If [M:POC2]XITMREF(I)+[M:POC2]XPRHFCY(I)=[M:POC2]XITMREF(J)+[M:POC2]XPRHFCY(J)
        GMESSAGE=mess(90,194,1) : GERR=1 : SUIZON="ITMREF" : OK=0 : Break 2
      Endif
    Next
  Next I
  If OK=0  Return : Endif
Endif
#----- Si des DL existent, il ne faut pas toucher le circuit de signature -----#
# Issue 120072 - 2016-12-05 by SR : Permettre de ne pas contrôler la présence de DL
GPE = 1
GPOINT = "POCCTLPOQ" : Gosub ENTREE From EXEFNC
If GPE
  Look [POQ] POQ0(1)=[M:POC0]POHNUM : If !fstat  GAPPFLG=0 : Endif
  [G:POQ]currind=1 : [G:POQ]currlen=0 : # Réinitialisation clé par défaut
Endif
# End issue 120072
#----- Annulation des signatures existantes ! Poursuivre, Abandonner -----#
If GREP="M" & GAPPPOC>1 & find([M:POC1]APPFLG,2,3) & GAPPFLG=2
  OK=2 : Call AVERTIR(mess(64,194,1),OK) From GESECRAN
  If OK=1  OK=0 : Return Else OK=1 : Endif
Endif
#-----

# Issue 71069 - 2016-01-12 by MUARN : PJT
Call PJT_CONTROLE_HEAD_DETAIL("[M:POC1]PJTH", "[M:POC2]PJT") From TRTPJT
If GERR <> 0
  OK = 0
  Return
Endif

Return


$CHARGENTETE
#------------------------------------------------#
# Chargement entête avant le Write ou le Rewrite #
#------------------------------------------------#
#----- Relecture BPARTNER si nécessaire -----#
If [F:BPR]BPRNUM<>[M:POC0]BPSNUM
  Read [BPR] BPR0=[M:POC0]BPSNUM : If fstat  Raz [F:BPR] : Endif
Endif
#----- relecture BPSUPPLIER si nécesaire -----#
If [F:BPS]BPSNUM<>[M:POC0]BPSNUM
  Read [BPS] BPS0=[M:POC0]BPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
#----- Relecture transaction si nécessaire -----#
If [F:PTR]PTRTYP<>5 | [F:PTR]PTRNUM<>GPTRNUM
  Read [PTR] PTR0=5;GPTRNUM      : If fstat  Raz [F:PTR] : Endif
Endif
#-----
[F:POH]LAN    = [F:BPR]LAN
#----- Traitement du nom et de l'adresse du fournisseur -----#
If [M:AD63]ADBFLG<>2
  If [M:AD63]BPAADD<>""
    [F:POH]BPAADD = [M:AD63]BPAADD
  Else
    [F:POH]BPAADD = [F:BPS]BPAADD
  Endif
  If GACTSAD=2 : # Stockage systématique de l'adresse !
    #----- Lecture de l'adresse si nécessaire -----#
    If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPAADD
      Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPAADD
      If fstat  Raz [F:BPA] : Endif
    Endif
    #-----
    [F:POH]BPRNAM(0)    = [F:BPR]BPRNAM(0)
    [F:POH]BPRNAM(1)    = [F:BPR]BPRNAM(1)
    [F:POH]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
    [F:POH]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
    [F:POH]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
    [F:POH]CRY          = [F:BPA]CRY
    [F:POH]CRYNAM       = [F:BPA]CRYNAM
    [F:POH]SAT          = [F:BPA]SAT
    [F:POH]POSCOD       = [F:BPA]POSCOD
    [F:POH]CTY          = [F:BPA]CTY
  Else
    Raz [F:POH]BPRNAM,[F:POH]BPAADDLIG,[F:POH]CRY,[F:POH]CRYNAM,
&       [F:POH]SAT,[F:POH]POSCOD,[F:POH]CTY
  Endif
Else
  [F:POH]=[M:AD63]
Endif
#----- Traitement du nom et de l'adresse du fournisseur expéditeur -----#
If [M:AD64]ADBFLG<>2
  If [M:AD64]BPAADD<>""
    [F:POH]BPOADD = [M:AD64]BPAADD
  Else
    [F:POH]BPOADD = [F:BPS]BPAADD
  Endif
  If GACTSAD=2 : # Stockage systématique de l'adresse !
    #----- Lecture BPARTNER si nécessaire -----#
    If [F:BPR]BPRNUM<>[F:POH]BPSNUM
      Read [BPR] BPR0=[F:POH]BPSNUM
      If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
    Endif
    #----- Lecture de l'adresse si nécessaire -----#
    If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPOADD
      Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
      If fstat  Raz [F:BPA] : Endif
    Endif
    #-----
    [F:POH]BPONAM(0)    = [F:BPR]BPRNAM(0)
    [F:POH]BPONAM(1)    = [F:BPR]BPRNAM(1)
    [F:POH]BPOADDLIG(0) = [F:BPA]BPAADDLIG(0)
    [F:POH]BPOADDLIG(1) = [F:BPA]BPAADDLIG(1)
    [F:POH]BPOADDLIG(2) = [F:BPA]BPAADDLIG(2)
    [F:POH]BPOCRY       = [F:BPA]CRY
    [F:POH]BPOCRYNAM    = [F:BPA]CRYNAM
    [F:POH]BPOSAT       = [F:BPA]SAT
    [F:POH]BPOPOSCOD    = [F:BPA]POSCOD
    [F:POH]BPOCTY       = [F:BPA]CTY
  Else
    Raz [F:POH]BPONAM,[F:POH]BPOADDLIG,[F:POH]BPOCRY,[F:POH]BPOCRYNAM,
&       [F:POH]BPOSAT,[F:POH]BPOPOSCOD,[F:POH]BPOCTY
  Endif
Else
    [F:POH]BPOADD       = [M:AD64]BPAADD
    [F:POH]BPONAM(0)    = [M:AD64]BPRNAM(0)
    [F:POH]BPONAM(1)    = [M:AD64]BPRNAM(1)
    [F:POH]BPOADDLIG(0) = [M:AD64]BPAADDLIG(0)
    [F:POH]BPOADDLIG(1) = [M:AD64]BPAADDLIG(1)
    [F:POH]BPOADDLIG(2) = [M:AD64]BPAADDLIG(2)
    [F:POH]BPOCRY       = [M:AD64]CRY
    [F:POH]BPOCRYNAM    = [M:AD64]CRYNAM
    [F:POH]BPOSAT       = [M:AD64]SAT
    [F:POH]BPOPOSCOD    = [M:AD64]POSCOD
    [F:POH]BPOCTY       = [M:AD64]CTY
Endif
#----- Chargement des familles statistiques -----#
For I=0 To dim([F:POH]TSSCOD)-1
  [F:POH]TSSCOD(I)=[F:BPS]TSSCOD(I)
Next I
#-----  Chargement de la structure tarif -----#
For I=0 To dim([F:POH]DISCRGTYP)-1
  [F:POH]DISCRGTYP (I)=GDISCRGTYP(I)
  [F:POH]INVDTALIN1(I)=GINVDTALIN(I)
Next I
#----- Màj nombre de lignes -----#
[F:POH]LINNBR=[M:POC2]NBART
Return


$CHARG_PARAM
#----------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la commande            #
# -------------------------------------------------------------------- #
# Chargement GSOCIETE   : Société juridique                            #
#            GLOCALDEV  : Devise société juridique                     #
#            GFINRSP    : Site financier                               #
#            GRCPFCY    : Site réception par défaut                    #
# Récupération des paramètres ACHATS                                   #
# Contrôle existence paramétrage des règles de signature pour GSOCIETE #
#----------------------------------------------------------------------#
#----- Chargement des globales référentiels, comptes et sections de la société -----#
Call GETCPY(GFCY,"PTR",5,GPTRNUM) From TRTX3CPT
If GFINRSP="" GFINRSP=GFCY : Endif
#----- Lecture des affectations compteur si changement société -----#
If GSOC_UPDFLG
  If dim(OK)<1  Local Integer OK : Endif
  #----- Compteur des commandes -----#
  Call LECTCA(6,OK) From SUBTCA
  If fstat | !OK
    GERR=1 : GMESSAGE=mess(58,105,1)-mess(6,14,1)-mess(250,199,1) : Return
  Endif
  GMANCOU=[F:TCA]MANCOU(4) : GCODNUM=[F:TCA]CODNUM(4)
  # Issue 71069 - 2016-01-1 by MUARN : PJT
  GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)
Endif
#-----
Call DEFRCPFCY(GFCY)  From TRTACHDEF1
Call GLOBVAR(GFCY)    From WWGLOBACH
#-----
Raz GMESSAGE
Return


$EFFAC_PWRKPO
#--------------------------------------------------------------------#
# Effacement fichiers de travail onglet article de TOUS les articles #
#--------------------------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_EFFACPWC
GOK=1
Trbegin [PWC], [PWP]
  Delete [PWC] Where PRONUM=adxuid(1)
  If fstat=1  GOK=-1 : OK=0 : GLOCK="$PWRKPOC"-num$(adxuid(1))
              Goto ROLL_EFFACPWC
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PWC",num$(adxuid(1))) From GLOCK
              Goto AB_EFFACPWC
  Endif
  Delete [PWP] Where PRONUM=adxuid(1)
  If fstat=1  GOK=-1 : OK=0 : GLOCK="$PWRKPOP"-num$(adxuid(1))
              Goto ROLL_EFFACPWC
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PWP",num$(adxuid(1))) From GLOCK
              Goto AB_EFFACPWC
  Endif
Commit
Return
$AB_EFFACPWC
Rollback : Return
$ROLL_EFFACPWC
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_EFFACPWC : Endif : Return


$EFFAC_ART_PWRKPO
#------------------------------------------------------------#
# Effacement fichiers de travail onglet article d'UN article #
#------------------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_EFFACPWC1
GOK=1
Trbegin [PWC], [PWP]
  Delete [PWC] Where PRONUM=adxuid(1) & POHNUM=[M:POC0]POHNUM & POPLIN=[M:POC2]POPLIN
  If fstat=1  GOK=-1 : OK=0 : GLOCK="$PWRKPOC"-num$(adxuid(1))-[M:POC0]POHNUM
              Goto ROLL_EFFACPWC1
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PWC",num$(adxuid(1))+[M:POC0]POHNUM) From GLOCK
              Goto AB_EFFACPWC1
  Endif
  Delete [PWP] Where PRONUM=adxuid(1) & POHNUM=[M:POC0]POHNUM & POPLIN=[M:POC2]POPLIN
  If fstat=1  GOK=-1 : OK=0 : GLOCK="$PWRKPOP"-num$(adxuid(1))-[M:POC0]POHNUM
              Goto ROLL_EFFACPWC1
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PWP",num$(adxuid(1))-[M:POC0]POHNUM) From GLOCK
              Goto AB_EFFACPWC1
  Endif
Commit
Return
$AB_EFFACPWC1
Rollback : Return
$ROLL_EFFACPWC1
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_EFFACPWC1 : Endif : Return


$CHARG_PWRKPO
#-----------------------------------------------#
# Chargement fichiers de travail onglet article #
#-----------------------------------------------#
If dim([L]SAVNOLIGN)<=0 Local Shortint SAVNOLIGN : Endif
[L]SAVNOLIGN=nolign : # Sauvegarde de nolign
Call DEBTRANS From GLOCK
$TR_CHARGPWC
GOK=1
Trbegin [PWC], [PWP]
  [F:PWC]=[M:POC2] : [F:PWC]PRONUM=adxuid(1) : [F:PWC]POHNUM=[M:POC0]XPOHNUM
  Write [PWC]
  If fstat GOK=0 : Call FSTA("PWC") From GLOCK : Goto AB_CHARGPWC : Endif
  If [M:POC2]NBLIG>0
    For nolign=1 To [M:POC2]NBLIG
      [F:PWP]=[M:POC2] : [F:PWP]PRONUM=adxuid(1) : [F:PWP]POHNUM=[M:POC0]XPOHNUM
      Write [PWP]
      If fstat GOK=0 : Call FSTA("PWP") From GLOCK : Goto AB_CHARGPWC : Endif
    Next I
  Endif
Commit
$FIN_CHARGPWC
nolign=[L]SAVNOLIGN : # Restitution de nolign
Return
$AB_CHARGPWC
Rollback : Goto FIN_CHARGPWC
$ROLL_CHARGPWC
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_CHARGPWC : Endif : Goto FIN_CHARGPWC


$MAJ_PWRKPO
#--------------------------------------------------------------#
# Mise à jour fichiers de travail à partir de l'onglet article #
#--------------------------------------------------------------#
If [M:POC2]ITMREF="" | [M:POC2]POPLIN=0   Return : Endif : # Fin si onglet article vide
If dim([L]SAVNOLIGN)<=0 Local Shortint SAVNOLIGN : Endif
[L]SAVNOLIGN=nolign : # Sauvegarde de nolign
#----- Si pas de code tarif, il faut au moins une ligne tarif sauf inter-site intra-soc -----#
If [M:POC2]PLI="" & [M:POC2]NBLIG=0 & ([M:POC0]BETFCY<>2 | [M:POC0]BETCPY=2)
  GMESSAGE=mess(228,194,1) : GERR=1 : mkstat=1 : Goto FIN_MAJPWC
Endif
#----- Le site de réception est obligatoire -----#
If [M:POC2]PRHFCY=""
  GMESSAGE=mess(80,194,1)  : GERR=1 : mkstat=1 : Goto FIN_MAJPWC
Endif
#----- Màj date fin application dernière ligne conditions tarifaires -----#
If [M:POC2]NBLIG>0
  If [M:POC2]POPDAT([M:POC2]NBLIG-1)<>[M:POC2]XENDDAT
    [M:POC2]POPDAT([M:POC2]NBLIG-1)=[M:POC2]XENDDAT
    [M:POC2]UPDFLG([M:POC2]NBLIG-1)=1
  Endif
Endif
#-----
Call DEBTRANS From GLOCK
$TR_MAJPWC
GOK=1
Trbegin [PWC], [PWP]
  Readlock [PWC] PWC0=adxuid(1);[M:POC0]XPOHNUM;[M:POC2]POPLIN
  If fstat=1
    GOK=-1 : GLOCK="$PWRKPOC"-num$(adxuid(1)) : Goto ROLL_MAJPWC
  Elsif fstat
    Raz [F:PWC]
    [F:PWC]=[M:POC2] : [F:PWC]PRONUM=adxuid(1) : [F:PWC]POHNUM=[M:POC0]XPOHNUM
    Write [PWC]
    If fstat GOK=0 : Call FSTA("PWC") From GLOCK : Goto AB_MAJPWC : Endif
    #----- Màj Liste des références article et nombre de ligne -----#
    [M:POC2]XITMREF([M:POC2]NBART)=[M:POC2]ITMREF
    [M:POC2]XPOPLIN([M:POC2]NBART)=[M:POC2]POPLIN
    [M:POC2]XUPDFLG([M:POC2]NBART)=1
    [M:POC2]XLINSTOFCY([M:POC2]NBART)=[M:POC2]LINSTOFCY
    [M:POC2]XPRHFCY([M:POC2]NBART)=[M:POC2]PRHFCY
    [M:POC2]NBART+=1
    #----- Màj dernier no ligne utilisé, date mini et date maxi -----#
    [M:POC1]LASTPOPLIN=[M:POC2]POPLIN
    If [M:POC1]DATMIN=[0/0/0] | [M:POC2]XSTRDAT<[M:POC1]DATMIN
      [M:POC1]DATMIN=[M:POC2]XSTRDAT
    Endif
    If [M:POC1]DATMAX=[0/0/0] | [M:POC2]XENDDAT>[M:POC1]DATMAX
      [M:POC1]DATMAX=[M:POC2]XENDDAT
    Endif
    Affzo [POC2]5
    #-----
  Else
    [M:POC2]XPRHFCY(find([M:POC2]POPLIN,[M:POC2]XPOPLIN(0..[M:POC2]NBART-1))-1)=[M:POC2]PRHFCY
    [M:POC2]XLINSTOFCY(find([M:POC2]POPLIN,[M:POC2]XPOPLIN(0..[M:POC2]NBART-1))-1)=[M:POC2]LINSTOFCY
    [F:PWC]=[M:POC2] : [F:PWC]PRONUM=adxuid(1) : [F:PWC]POHNUM=[M:POC0]XPOHNUM
    Rewrite [PWC]
    If fstat GOK=0 : Call FSTA("PWC") From GLOCK : Goto AB_MAJPWC : Endif
  Endif
  #----- Effacement des lignes tarif de l'article -----#
  Delete [PWP] Where PRONUM=adxuid(1) & POHNUM=[M:POC0]XPOHNUM & POPLIN=[M:POC2]POPLIN
  If fstat=1
    GOK=-1 : GLOCK="$PWRKPOP"-num$(adxuid(1))-[M:POC0]XPOHNUM-num$([M:POC2]POPLIN)
    Goto ROLL_MAJPWC
  Elsif fstat
    GOK=0  : Call RSTA("PWP",num$(adxuid(1))+[M:POC0]XPOHNUM+num$([M:POC2]POPLIN)) From GLOCK
    Goto AB_MAJPWC
  Endif
  #----- Ecriture des lignes tarif de l'article -----#
  If [M:POC2]NBLIG>0
    For nolign=1 To [M:POC2]NBLIG
      Raz [F:PWP]
      [F:PWP]=[M:POC2] : [F:PWP]PRONUM=adxuid(1) : [F:PWP]POHNUM=[M:POC0]XPOHNUM
      Write [PWP]
      If fstat GOK=0 : Call FSTA("PWP") From GLOCK : Goto AB_MAJPWC : Endif
    Next I
  Endif
Commit
$FIN_MAJPWC
nolign=[L]SAVNOLIGN : # Restitution de nolign
Return
$AB_MAJPWC
Rollback : Goto FIN_MAJPWC
$ROLL_MAJPWC
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_MAJPWC : Endif : Goto FIN_MAJPWC


$CHARG_ONGLET_ART
#-------------------------------------------------------------------------------#
# Chargement onglet article : NOL contient l'indice de la réf.article à charger #
#-------------------------------------------------------------------------------#
If dim([L]SAVNOLIGN)<=0 Local Shortint SAVNOLIGN : Endif
[L]SAVNOLIGN=nolign : # Sauvegarde de nolign
Read [PWC] PWC0=adxuid(1);[M:POC0]XPOHNUM;[M:POC2]XPOPLIN(NOL)
If fstat
  Raz [F:PWC] : Effzo [POC2]10-99 : Grizo [POC2]10-99 : Goto FIN_CHARGONGLET
Endif
[M:POC2]=[F:PWC]
nolign=0
For [PWP] PWP0 Where PRONUM=adxuid(1) & POHNUM=[M:POC0]XPOHNUM & POPLIN=[M:POC2]XPOPLIN(NOL)
  nolign+=1
  [M:POC2]=[F:PWP]
Next
[M:POC2]NBLIG=nolign
Gosub RAZ_LIGNES    : # Effacement des lignes restantes
$FIN_CHARGONGLET
If [M:POC1]CLEFLG=2
  Diszo [POC2]10-99
Else
  Actzo [POC2]ITMDES, ITMDES1, FCYADD, USEPLC, 15-25
  # Issue 71069 - 2016-03-30 by MUARN : PJT
  Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]POPLIN
  #----- Si pas d'existence de demandes de livraison alors modification PJT -----#
  If fstat <> 0
    Affzo [M:POC2]PJT
  Else
    Diszo [M:POC2]PJT
  Endif
  Diszo [POC2]ITMREF, ITMREFBPS
  If [M:POC0]BETFCY=2
    Actzo  [POC2]PRHFCY, LINSTOFCY
    If [M:POC0]BETCPY<>2
      Grizo  [POC2]PLI, PRIVLT, WCURVLT, 30
    Else
     #Diszo  [POC2]PLI, PRIVLT, WCURVLT
      Actzo  [POC2]PLI, PRIVLT, WCURVLT
      Actzo  [POC2]30
    Endif
  Else
    Actzo [POC2]PRHFCY
    Grizo [POC2]LINSTOFCY
    Actzo [POC2]30
  Endif
  If [M:POC0]SALFCY<>"" & [M:POC2]XCREFLG(NOL)<>0
    Diszo [POC2]PRHFCY, PUU
  Elsif [M:POC2]XPUUFLG<>2
    Diszo [POC2]PUU
  Endif
Endif
#----- Lecture de l'article si nécessaire -----#
If [F:ITM]ITMREF<>[M:POC2]ITMREF
  Read [ITM] ITM0=[M:POC2]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#----- Lecture article-fournisseur si nécessaire -----#
If [F:ITP]ITMREF<>[M:POC2]ITMREF | [F:ITP]BPSNUM<>[M:POC0]BPSNUM
  Read [ITP] ITP0=[M:POC2]ITMREF;[M:POC0]BPSNUM
  If fstat Raz [F:ITP] : Endif
Endif
#-----
#[M:POC2]CPRCUR = GLOCALDEV # Issue 70985 - 2012-03-26 by MUARN : landed cost
nolign=[L]SAVNOLIGN : # Restitution de nolign
Return


$RAZ_LIGNES
#--------------------------------------------------------------#
# Effacement des lignes restantes non chargées dans le tableau #
# ------------------------------------------------------------ #
# [M:POC2]NBLIG = Nombre de lignes significatives              #
#--------------------------------------------------------------#
If dim([L]I)<=0 Local Integer I : Endif
# Issue 71069 - 2016-01-11 by MUARN : PJT (champ PJT remplacé par PJT1)
For I=[M:POC2]NBLIG To dim([M:POC2]POPSEQ)-1
  Raz [M:POC2]POPSEQ(I), [M:POC2]POPDAT(I), [M:POC2]POPSTRDAT(I), [M:POC2]PJT1(I),
&     [M:POC2]GROPRI(I), [M:POC2]NETPRI(I), [M:POC2]QUAFLG(I),    [M:POC2]ORICRY(I),
&     [M:POC2]UPDFLG(I), [M:POC2]CREFLG(I), [M:POC2]PRIREN(I),    [M:POC2]PRIFLG(I),
&     [M:POC2]POPCREFLG(I)
  If GACTDEB=2  Raz [M:POC2]EECINCRAT(I) : Endif
  If dim([M:POC2]DISCRGVAL1)>0 Raz [M:POC2]DISCRGVAL1(I) : Endif
  If dim([M:POC2]DISCRGVAL2)>0 Raz [M:POC2]DISCRGVAL2(I) : Endif
  If dim([M:POC2]DISCRGVAL3)>0 Raz [M:POC2]DISCRGVAL3(I) : Endif
  If dim([M:POC2]DISCRGVAL4)>0 Raz [M:POC2]DISCRGVAL4(I) : Endif
  If dim([M:POC2]DISCRGVAL5)>0 Raz [M:POC2]DISCRGVAL5(I) : Endif
  If dim([M:POC2]DISCRGVAL6)>0 Raz [M:POC2]DISCRGVAL6(I) : Endif
  If dim([M:POC2]DISCRGVAL7)>0 Raz [M:POC2]DISCRGVAL7(I) : Endif
  If dim([M:POC2]DISCRGVAL8)>0 Raz [M:POC2]DISCRGVAL8(I) : Endif
  If dim([M:POC2]DISCRGVAL9)>0 Raz [M:POC2]DISCRGVAL9(I) : Endif
  If dim([M:POC2]CCE1) >0      Raz [M:POC2]CCE1 (I)      : Endif
  If dim([M:POC2]CCE2) >0      Raz [M:POC2]CCE2 (I)      : Endif
  If dim([M:POC2]CCE3) >0      Raz [M:POC2]CCE3 (I)      : Endif
  If dim([M:POC2]CCE4) >0      Raz [M:POC2]CCE4 (I)      : Endif
  If dim([M:POC2]CCE5) >0      Raz [M:POC2]CCE5 (I)      : Endif
  If dim([M:POC2]CCE6) >0      Raz [M:POC2]CCE6 (I)      : Endif
  If dim([M:POC2]CCE7) >0      Raz [M:POC2]CCE7 (I)      : Endif
  If dim([M:POC2]CCE8) >0      Raz [M:POC2]CCE8 (I)      : Endif
  If dim([M:POC2]CCE9) >0      Raz [M:POC2]CCE9 (I)      : Endif
  If dim([M:POC2]CCE10)>0      Raz [M:POC2]CCE10(I)      : Endif
  If dim([M:POC2]CCE11)>0      Raz [M:POC2]CCE11(I)      : Endif
  If dim([M:POC2]CCE12)>0      Raz [M:POC2]CCE12(I)      : Endif
  If dim([M:POC2]CCE13)>0      Raz [M:POC2]CCE13(I)      : Endif
  If dim([M:POC2]CCE14)>0      Raz [M:POC2]CCE14(I)      : Endif
  If dim([M:POC2]CCE15)>0      Raz [M:POC2]CCE15(I)      : Endif
  If dim([M:POC2]CCE16)>0      Raz [M:POC2]CCE16(I)      : Endif
  If dim([M:POC2]CCE17)>0      Raz [M:POC2]CCE17(I)      : Endif
  If dim([M:POC2]CCE18)>0      Raz [M:POC2]CCE18(I)      : Endif
  If dim([M:POC2]CCE19)>0      Raz [M:POC2]CCE19(I)      : Endif
  If dim([M:POC2]CCE20)>0      Raz [M:POC2]CCE20(I)      : Endif
  If dim([M:POC2]DISCRGREN1)>0 Raz [M:POC2]DISCRGREN1(I) : Endif
  If dim([M:POC2]DISCRGREN2)>0 Raz [M:POC2]DISCRGREN2(I) : Endif
  If dim([M:POC2]DISCRGREN3)>0 Raz [M:POC2]DISCRGREN3(I) : Endif
  If dim([M:POC2]DISCRGREN4)>0 Raz [M:POC2]DISCRGREN4(I) : Endif
  If dim([M:POC2]DISCRGREN5)>0 Raz [M:POC2]DISCRGREN5(I) : Endif
  If dim([M:POC2]DISCRGREN6)>0 Raz [M:POC2]DISCRGREN6(I) : Endif
  If dim([M:POC2]DISCRGREN7)>0 Raz [M:POC2]DISCRGREN7(I) : Endif
  If dim([M:POC2]DISCRGREN8)>0 Raz [M:POC2]DISCRGREN8(I) : Endif
  If dim([M:POC2]DISCRGREN9)>0 Raz [M:POC2]DISCRGREN9(I) : Endif
Next I
Return


$SUPPRESS_TEX
#-----------------------------------------#
# Suppression des textes après un abandon #
#-----------------------------------------#
#----- Suppression texte entête et pied -----#
If GREP="D"
  If left$([M:POC1]TEX1,3)="POH"
    Call SUP_CLOB([M:POC1]TEX1,GBIDI1) From TRTX3TEX
  Endif
  If left$([M:POC1]TEX2,3)="POH"
    Call SUP_CLOB([M:POC1]TEX2,GBIDI1) From TRTX3TEX
  Endif
Endif
#----- Suppression des textes ligne -----#
For [PWC] PWC0 Where PRONUM=adxuid(1) & POHNUM=[M:POC0]XPOHNUM & POPLIN<>[M:POC2]POPLIN
  If left$([F:PWC]LINTEX,3)="POC" & [F:PWC]LINCREFLG=0
    Call SUP_CLOB([F:PWC]LINTEX,GBIDI1) From TRTX3TEX
  Endif
Next
#----- Suppression texte ligne de l'article en cours sur l'onglet POC2 -----#
If left$([M:POC2]LINTEX,3)="POC" & [M:POC2]LINCREFLG=0
  Call SUP_CLOB([M:POC2]LINTEX,GBIDI1) From TRTX3TEX
Endif
#-----
Call RAZ_CLOB From ACLOB
Return


$VERF_ANUART
#----------------------------------------------#
# Contrôles de suppression d'une ligne article #
# -------------------------------------------- #
# Supression interdite si :                    #
#   - des DL existent (POQ)                    #
#   - le contrat est réceptionné ou soldé      #
# Avertissement et choix si contrat signé      #
#----------------------------------------------#
#----- On regarde si des lignes POQ existent pour la ligne du contrat -----#
Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]POPLIN
[G:POQ]currind=1 : [G:POQ]currlen=0 : # Réinitialisation clé par défaut
If !fstat : # il existe des enregistrements, on ne peut pas supprimer
  GMESSAGE=mess(79,194,1) : GERR=1 : OK=0 : Return
Endif
#---- Appel du S/P ventes pour vérif suppression ligne article contrat (SORDERC) ----#
If [F:POH]BETFCY=2 & [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>"" & [M:POC2]XCREFLG(NOL)<>0
  Raz [M:SORW]
  [M:SORW]MAJCOD = "A"
  [M:SORW]SOHNUM = [M:POC3]OCNNUM
  [M:SORW]SOPLIN = [M:POC2]POPLIN
  [M:SORW]BPCORD = [M:POC0]BPCORD
  [M:SORW]PRHFCY = [M:POC2]PRHFCY
  Call CTL_MAJ_SOC From TRTVENMSIT
  If GMESSAGE<>"" : # Suppression ligne article contrat vente non autorisée
    GERR=1 : OK=0 : Return
  Endif
Endif
Filter [POQ]
#----- Test sur entête commande -----#
If [F:POH]CLEFLG>1
  GMESSAGE=mess(16,194,1) : GERR=1 : OK=0 : Return
Endif
#----- Choix si contrat signé -----#
If [F:POH]APPFLG>1 & [F:POH]APPFLG<4
  OK=2 : Call AVERTIR(mess(17,194,1),OK) From GESECRAN
  If OK=1  OK=0 : Return : Endif
Endif
Return


$CREATION_POC
#-----------------------------------#
# Création d'une ligne d'un contrat #
#-----------------------------------#
Raz [F:POC]
[F:POC] = [M:POC0]
[F:POC] = [M:POC1]
[F:POC] = [M:POC2]
[F:POC]CPY    = GSOCIETE
[F:POC]STOFCY = [M:POC2]LINSTOFCY
[F:POC]POPLIN = [M:POC2]POPLIN
[F:POC]STRDAT = [M:POC2]XSTRDAT
[F:POC]ENDDAT = [M:POC2]XENDDAT
[F:POC]TEX    = [M:POC2]LINTEX
#----- Lecture article si nécessaire -----#
If [F:ITM]ITMREF<>[F:POC]ITMREF
  Read [ITM] ITM0=[F:POC]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#----- Lecture de l'article-fournisseur si nécessaire -----#
If [F:ITP]ITMREF<>[F:POC]ITMREF | [F:ITP]BPSNUM<>[F:POH]BPSNUM
  Read [ITP] ITP0=[F:POC]ITMREF;[F:POH]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
#-----
[F:POC]STU=[F:ITM]STU
If GREVFLG=2 [F:POC]LINREVNUM=[M:POC0]REVNUM : Endif
#----- Calcul des qtés -----#
If [F:POC]EXTQTYPUU<>0
  Call PCAL_QTY([F:POC]EXTQTYPUU,[F:POC]PUU,[F:POC]EXTQTYSTU,[F:POC]STU,
&               [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
Endif
#----- Création ou duplication du texte ligne -----#
Gosub CHARG_TEXT_LIGNE
#-----
[F:POC]CREUSR=GUSER
[F:POC]CREDAT=date$
Write [POC]
If fstat GOK=0 : Call FSTA ("POC") From GLOCK : Return : Endif
#----- Appel du S/P ventes pour création de la ligne article contrat (SORDERC) -----#
If [M:POC0]BETFCY=2 & [M:POC0]SALFCY<>"" & [F:POH]APPFLG>=3
  Raz [M:SORW]
  [M:SORW]MAJCOD    = "C"
  [M:SORW]SOHNUM    = [M:POC3]OCNNUM
  [M:SORW]SOPLIN    = [F:POC]POPLIN
  [M:SORW]ITMREF    = [F:POC]ITMREF
  [M:SORW]STOFCY    = [M:POC2]LINSTOFCY
  [M:SORW]SAU       = [F:POC]PUU
  [M:SORW]EXTQTY    = [F:POC]EXTQTYPUU
  [M:SORW]USEPLC    = [F:POC]USEPLC
  [M:SORW]VLYDATITM = [F:POC]ENDDAT
  [M:SORW]BPCORD    = [M:POC0]BPCORD
  [M:SORW]PRHFCY    = [M:POC2]PRHFCY
  [M:SORW]EECICT    = [F:POC]EECICT2    : # Bug 72215
  [M:SORW]ICTCTY    = [F:POC]ICTCTY2    : # Bug 72215
  [M:SORW]FFWNUM    = [F:POC]FFWNUM2    : # Bug 72215
  [M:SORW]FFWADD    = [F:POC]FFWADD2    : # Bug 72215
  # 105605 : CCM - Revision index (LD:03/06/15)
  If dim([M:SORW]ECCVALMAJ) > 0         : # Issue 116162
      [M:SORW]ECCVALMAJ = [F:POC]ECCVALMAJ
      [M:SORW]ECCVALMIN = [F:POC]ECCVALMIN
  Endif                                 : # Issue 116162
  # 105605 : CCM - Revision index (LD:03/06/15)
  # 95742 : PJT en inter société/inter site : (LD:21/04/16)
  # Le PJT transite uniquement en intersite
  If [M:POC0]BETCPY=1
      [M:SORW]PJT=[F:POC]PJT
  Endif
  # 95742 : PJT en inter société/inter site : (LD:21/04/16)
  #----- Passage du code tarif si type inter-sociétés -----#
  If [F:PPC]PLI<>[F:POC]PLI
    Read [PPC] PPC0=[F:POC]PLI : If fstat  Raz [F:PPC] : Endif
  Endif
  If [M:POC0]BETCPY=2  [M:SORW]PLI=[F:POC]PLI : Endif
  #-----
  Call MAJ_SOC From TRTVENMSIT
  If GMESSAGE<>"" GERR=1 : Endif
  If GOK<1 : Return : Endif : # ça c'est mal passé, abandon de la transaction
Endif
Gosub CREATION From TABLEAUX
Return


$MODIF_POC
#---------------------------------------#
# Modification d'une ligne d'un contrat #
#---------------------------------------#
Readlock [POC] POC0=[F:POH]POHNUM;[M:POC2]POPLIN
If fstat=1
  GOK=-1 : GLOCK="$PORDERC"-[F:POH]POHNUM-num$([M:POC2]POPLIN) : Return
Elsif fstat
  GOK= 0 : Call RSTA("POC",[F:POH]POHNUM-num$([M:POC2]POPLIN)) From GLOCK : Return
Endif
#----- Cas particulier où l'on modifie le texte en le supprimant -----#
If [M:POC2]LINTEX="" & left$([F:POC]TEX,3)="POC"
  Call SUP_CLOB([F:POC]TEX,GBIDI1) From TRTX3TEX
Endif
#----- Si gestion avec avenant màj fichier historique -----#
If GREVFLG=2
  Call HISTO_CDE ("POC","","M") From TRTACHCDE1 : If GOK<1  Return : Endif
Endif
[F:POC]=[M:POC0] : [F:POC]=[M:POC1] : [F:POC]=[M:POC2]
[F:POC]STOFCY = [M:POC2]LINSTOFCY
[F:POC]STRDAT = [M:POC2]XSTRDAT
[F:POC]ENDDAT = [M:POC2]XENDDAT
[F:POC]TEX    = [M:POC2]LINTEX
If GREVFLG=2  [F:POC]LINREVNUM=[M:POC0]REVNUM : Endif
Call PCAL_QTY([F:POC]EXTQTYPUU,[F:POC]PUU,[F:POC]EXTQTYSTU,[F:POC]STU,
&             [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
#----- Création ou duplication du texte ligne -----#
Gosub CHARG_TEXT_LIGNE
#-----
[F:POC]UPDUSR = GUSER
[F:POC]UPDDAT = date$
Rewrite [POC]
If fstat  GOK=0 : Call FSTA("POC") From GLOCK : Return : Endif
#---- Appel du S/P ventes pour modification de la ligne article contrat (SORDERC) ----#
If [M:POC0]BETFCY=2 & [M:POC0]SALFCY<>"" & [F:POH]OCNNUM<>""
  Raz [M:SORW]
  [M:SORW]MAJCOD    = "M"
  [M:SORW]SOHNUM    = [M:POC3]OCNNUM
  [M:SORW]SOPLIN    = [F:POC]POPLIN
  [M:SORW]STOFCY    = [F:POC]STOFCY
  [M:SORW]EXTQTY    = [F:POC]EXTQTYPUU
  [M:SORW]USEPLC    = [F:POC]USEPLC
  [M:SORW]VLYDATITM = [F:POC]ENDDAT
  [M:SORW]BPCORD    = [M:POC0]BPCORD
  [M:SORW]PRHFCY    = [M:POC2]PRHFCY
  [M:SORW]EECICT    = [F:POC]EECICT2    : # Bug 72215
  [M:SORW]ICTCTY    = [F:POC]ICTCTY2    : # Bug 72215
  [M:SORW]FFWNUM    = [F:POC]FFWNUM2    : # Bug 72215
  [M:SORW]FFWADD    = [F:POC]FFWADD2    : # Bug 72215
  # 105605 : CCM - Revision index (LD:03/06/15)
  If dim([M:SORW]ECCVALMAJ) > 0         : # Issue 116162
      [M:SORW]ECCVALMAJ = [F:POC]ECCVALMAJ
      [M:SORW]ECCVALMIN = [F:POC]ECCVALMIN
  Endif                                 : # Issue 116162
  # 105605 : CCM - Revision index (LD:03/06/15)
  # 95742 : PJT en inter société/inter site : (LD:21/04/16)
  # Le PJT transite uniquement en intersite
  If [M:POC0]BETCPY=1
      [M:SORW]PJT=[F:POC]PJT
  Endif
  # 95742 : PJT en inter société/inter site : (LD:21/04/16)
  #----- Passage du code tarif si type inter-sociétés -----#
  If [F:PPC]PLI<>[F:POC]PLI
    Read [PPC] PPC0=[F:POC]PLI : If fstat  Raz [F:PPC] : Endif
  Endif
  If [M:POC0]BETCPY=2  [M:SORW]PLI=[F:POC]PLI : Endif
  #-----
  Call MAJ_SOC From TRTVENMSIT
  If GMESSAGE<>"" GERR=1 : Endif
  If GOK<1  Return : Endif : # ça c'est mal passé, abandon de la transaction
Endif
If dim(MAXLIG)>0
  MAXLIG=[M:POC2]XMAXLIG(NOL)
  If dim(ONUM)>0
    For J=0 To [M:POC2]XMAXLIG(NOL)-1
      ONUM(J)=[M:POC2]XONUM(J)
    Next J
  Endif
Endif
Gosub MODIF From TABLEAUX
Return


$SUPPRESS_POC
#--------------------------------------#
# Suppression d'une ligne d'un contrat #
#--------------------------------------#
If GREVFLG=2
  Call HISTO_CDE("POC","","A") From TRTACHCDE1
  If GOK<1  Return : Endif
Endif
#----- Suppression texte ligne et ligne vente si contrat inter-site -----#
If left$([F:POC]TEX,3)="POC"
  Call SUP_CLOB([F:POC]TEX,GBIDI1) From TRTX3TEX
Endif
#---- Appel du S/P ventes pour suppression de la ligne article contrat (SORDERC) ----#
If [M:POC0]BETFCY=2 & [M:POC0]SALFCY<>"" & [F:POH]OCNNUM<>""
  Raz [M:SORW]
  [M:SORW]MAJCOD = "A"
  [M:SORW]SOHNUM = [M:POC3]OCNNUM
  [M:SORW]SOPLIN = [F:POC]POPLIN
  [M:SORW]BPCORD = [M:POC0]BPCORD
  [M:SORW]PRHFCY = [M:POC2]PRHFCY
  Call MAJ_SOC From TRTVENMSIT
  If GMESSAGE<>"" GERR=1 : Endif
  If GOK<1 : Return : Endif : # ça c'est mal passé, abandon de la transaction
Endif
#----- Effacement de la ligne article contrat -----#
WPOPLIN=[F:POC]POPLIN
Delete [POC] Where POHNUM=[M:POC0]POHNUM & POPLIN=WPOPLIN
If fstat=1
  GOK=-1 : GLOCK="$PORDERC"-[M:POC0]POHNUM-num$(WPOPLIN) : Return
Elsif fstat
  GOK=0  : Call RSTA("POC",[M:POC0]POHNUM+num$(WPOPLIN)) From GLOCK : Return
Endif
#----- Suppression des lignes prix de la ligne article (PORDERP) -----#
For [POP] POP0 Where POHNUM=[M:POC0]POHNUM & POPLIN=WPOPLIN
  TRTLIG="A" : SIGN=-1 : Gosub VALLIG From SUBPOCA
  If GOK<1 Break : Endif
Next
If GOK<1 Return : Endif
Delete [POP] Where POHNUM=[M:POC0]POHNUM & POPLIN=WPOPLIN
If fstat=1
  GOK=-1 : GLOCK="$PORDERP"-[M:POC0]POHNUM-num$(WPOPLIN) : Return
Elsif fstat
  GOK=0  : Call RSTA("POP",[M:POC0]POHNUM+num$(WPOPLIN)) From GLOCK : Return
Endif
Return


$VERROU
#------------------------------------------------------------#
# Vérification du verrouillage de l'objet par un autre poste #
#------------------------------------------------------------#
If GREP="C" | GREP="D"  Return : Endif
If [M:POC0]XVERROU=0 : OK=0 : Endif
Return

#--------------------------------------#
# Chargement des textes entête et pied #
#--------------------------------------#
$CHARG_TEXT_ENTETE
If [M:POC1]TEX1<>""
  If left$([M:POC1]TEX1,3)="POH"
    Call CRE_CLOB([M:POC1]TEX1,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif left$([M:POC1]TEX1,3)<>"BPS"
    Call DUP_CLOB("POH",[M:POC1]TEX1,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:POH]TEX1=[M:POC1]TEX1
Endif
If [M:POC1]TEX2<>""
  If left$([M:POC1]TEX2,3)="POH"
    Call CRE_CLOB([M:POC1]TEX2,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif left$([M:POC1]TEX2,3)<>"BPS"
    Call DUP_CLOB("POH",[M:POC1]TEX2,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:POH]TEX2=[M:POC1]TEX2
Endif
Return

#---------------------------------#
# Chargement du texte de la ligne #
#---------------------------------#
$CHARG_TEXT_LIGNE
If [M:POC2]LINTEX<>""
  If left$([M:POC2]LINTEX,3)="POC"
    Call CRE_CLOB([M:POC2]LINTEX,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif !find(left$([M:POC2]LINTEX,3),"ITM","ITP")
    Call DUP_CLOB("POC",[M:POC2]LINTEX,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:POC]TEX=[M:POC2]LINTEX
Endif
Return

#---------------------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (frais/remises, comptes et sections analytiques) #
#---------------------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & (dim([M:POC2]DISCRGVAL1)>0 | dim([M:POC2]CCE1)>0)
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WE5"+GPTRNUM+"2"
  BASPAG="NBFAC" : Gosub TIT_COL From ="W1WE5"+GPTRNUM+"3"
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:POC2]NBLIG=0
    [M:POC2]NBLIG=1 : Affzo [POC2]30 : Effzo [POC2]30
  Endif
  If [M:POC3]NBFAC=0
    [M:POC3]NBFAC=1 : [M:POC3]FORMAT(0)="NZ:9.2#" : Affzo [POC3]5 : Effzo [POC3]5
  Endif
  #-----
Endif
Raz GSOC_UPDFLG
Return

# Issue 71069 - 2016-01-12 by MUARN : PJT
Funprog REPERCUTE_PJTH(PJTORI, PJTNEW)
Value Char PJTORI
Value Char PJTNEW

Local Integer NERROR
Local Char SACTION(1)
Local Shortint PWP_SEQ

NERROR = 0

If GPJTSNGDOC = G_OUI Then
  SACTION = "1"
Else
  Call ACTION_PJTQUESTIO(SACTION, 5) From TRTPJT
Endif
If SACTION <> "2" Then
    Case SACTION
      When "1"
        # Oui
        Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]POPLIN
        #----- Si pas d'existence de demandes de livraison alors modification PJT -----#
        If fstat <> 0
          # mise à jour des lignes
          For I=0 To [M:POC2]NBLIG-1
            [M:POC2]PJT1(I) = PJTNEW
            [M:POC2]UPDFLG(I)=1
            # Issue X3-3807 - 2017-10-24 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
            # Initialisation de la section analytique gérée à l'affaire sur les lignes de prix
            # Initialization of the dimension managed by project on the price lines
            NERROR = func PJT_INIT_CCE_CAL("POP", 0, [M:POC0]POHNUM, [M:POC2]XPOPLIN(I), 0, "", "1", PJTNEW, I)
            If NERROR <> 0 Then
              Break
            Endif
            # End issue X3-3807
          Next I
          [M:POC2]PJT = PJTNEW
          Affzo [M:POC2]PJT
          Affzo [POC2]30 # Issue X3-3807 - 2017-10-25 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
        Endif
        Call DEBTRANS From GLOCK
        GOK=1
        Trbegin [PWC], [PWP]
        # mise à jour du fichier de travail
        For I=0 To [M:POC2]NBART-1
          Readlock [PWC] PWC0=adxuid(1);[M:POC0]XPOHNUM;[M:POC2]XPOPLIN(I)
          If fstat=1
            NERROR = 2
            GOK=-1 : GLOCK="$PWRKPOC"-num$(adxuid(1))
            GMESSAGE = mess(13,100,1)-"PWRKPOC"
            Break
          Elsif fstat = 0
            Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]XPOPLIN(I)
            #----- Si pas d'existence de demandes de livraison alors modification PJT -----#
            If fstat <> 0
              [F:PWC]PJT = PJTNEW
              [F:PWC]PRONUM=adxuid(1)
              Rewrite [PWC]
              If fstat GOK=0
                Call FSTA("PWC") From GLOCK
                NERROR = 2
                Break
              Endif
            Endif
          Endif
          # mise à jour des conditions tarifaires
          For [PWP] PWP0 Where PRONUM=adxuid(1) & POHNUM=[M:POC0]XPOHNUM & POPLIN=[M:POC2]XPOPLIN(I)
            PWP_SEQ = [F:PWP]POPSEQ
            Readlock [PWP] PWP0=adxuid(1);[M:POC0]XPOHNUM;[M:POC2]XPOPLIN(I);PWP_SEQ
            If fstat=1
              NERROR = 2
              GOK=-1 : GLOCK="$PWRKPOP"-num$(adxuid(1))
              GMESSAGE = mess(13,100,1)-"PWRKPOP"
              Break 2
            Elsif fstat = 0
              Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]XPOPLIN(I)
              #----- Si pas d'existence de demandes de livraison alors modification PJT -----#
              If fstat <> 0
                [F:PWP]PJT = PJTNEW
                [F:PWP]UPDFLG=1
                [F:PWP]PRONUM=adxuid(1)
                # Issue X3-3807 - 2017-10-24 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
                # Initialisation de la section analytique gérée à l'affaire sur les lignes de prix
                # Initialization of the dimension managed by project on the price lines
                NERROR = func PJT_INIT_CCE_CAL_PWP("POP", 0, [F:PWP]POHNUM, [F:PWP]POPLIN, [F:PWP]POPSEQ, "", "1",PJTNEW)
                If NERROR <> 0 Then
                  Break
                Endif
                Rewrite [PWP]
                If fstat GOK=0
                  Call FSTA("PWP") From GLOCK
                  NERROR = 2
                  Break 2
                Endif
              Endif
            Endif
          Next
        Next I
        If GOK<>1 : Rollback : End NERROR : Endif
        Commit
      When "3"
        # Oui si même valeur
        If [M:POC2]PJT = PJTORI
          Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]POPLIN
          #----- Si pas d'existence de demandes de livraison alors modification PJT -----#
          If fstat <> 0
            # mise à jour des lignes
            For I=0 To [M:POC2]NBLIG-1
              [M:POC2]PJT1(I) = PJTNEW
              [M:POC2]UPDFLG(I)=1
              # Issue X3-3807 - 2017-10-24 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
              # Initialisation de la section analytique gérée à l'affaire sur les lignes de prix
              # Initialization of the dimension managed by project on the price lines
              NERROR = func PJT_INIT_CCE_CAL("POP", 0, [M:POC0]POHNUM, [M:POC2]XPOPLIN(I), 0, "", "1", PJTNEW, I)
              If NERROR <> 0 Then
                Break
              Endif
              # End issue X3-3807
            Next I
            If [M:POC2]PJT = PJTORI : [M:POC2]PJT = PJTNEW : Affzo [M:POC2]PJT : Endif
            Affzo [POC2]30 # Issue X3-3807 - 2017-10-25 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
          Endif
        Endif
        Call DEBTRANS From GLOCK
        GOK=1
        Trbegin [PWC], [PWP]

        # mise à jour du fichier de travail
        For I=0 To [M:POC2]NBART-1
          Readlock [PWC] PWC0=adxuid(1);[M:POC0]XPOHNUM;[M:POC2]XPOPLIN(I)
          If fstat=1
            NERROR = 2
            GOK=-1 : GLOCK="$PWRKPOC"-num$(adxuid(1))
            GMESSAGE = mess(13,100,1)-"PWRKPOC"
            Break
          Elsif fstat = 0
            If [F:PWC]PJT = PJTORI
              Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]XPOPLIN(I)
              #----- Si pas d'existence de demandes de livraison alors modification PJT -----#
              If fstat <> 0
                [F:PWC]PJT = PJTNEW #: Affzo [M:POC2]PJT
                [F:PWC]PRONUM=adxuid(1)
                Rewrite [PWC]
                If fstat GOK=0
                  Call FSTA("PWC") From GLOCK
                  NERROR = 2
                  Break
                Endif
              Endif
              # mise à jour des conditions tarifaires
              For [PWP] PWP0 Where PRONUM=adxuid(1) & POHNUM=[M:POC0]XPOHNUM & POPLIN=[M:POC2]XPOPLIN(I)
                PWP_SEQ = [F:PWP]POPSEQ
                Readlock [PWP] PWP0=adxuid(1);[M:POC0]XPOHNUM;[M:POC2]XPOPLIN(I);PWP_SEQ
                If fstat=1
                  NERROR = 2
                  GOK=-1 : GLOCK="$PWRKPOP"-num$(adxuid(1))
                  GMESSAGE = mess(13,100,1)-"PWRKPOP"
                  Break 2
                Elsif fstat = 0
                  Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]XPOPLIN(I)
                  #----- Si pas d'existence de demandes de livraison alors modification PJT -----#
                  If fstat <> 0
                    [F:PWP]PJT = PJTNEW
                    [F:PWP]UPDFLG=1
                    [F:PWP]PRONUM=adxuid(1)
                    # Issue X3-3807 - 2017-10-24 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
                    # Initialisation de la section analytique gérée à l'affaire sur les lignes de prix
                    # Initialization of the dimension managed by project on the price lines
                    NERROR = func PJT_INIT_CCE_CAL_PWP("POP", 0, [F:PWP]POHNUM, [F:PWP]POPLIN, [F:PWP]POPSEQ, "", "1",PJTNEW)
                    If NERROR <> 0 Then
                      Break
                    Endif
                    Rewrite [PWP]
                    If fstat GOK=0
                      Call FSTA("PWP") From GLOCK
                      NERROR = 2
                      Break 2
                    Endif
                  Endif
                Endif
              Next
            Endif
          Endif
        Next I
        If GOK=0  Rollback : End : Endif
        Commit
      When Default
    Endcase
Endif
End NERROR

Funprog REPERCUTE_PJT(PJTNEW)
Value Char PJTNEW

Local Integer NERROR
Local Shortint PWP_SEQ

NERROR = 0

# mise à jour du fichier de travail
Call DEBTRANS From GLOCK
GOK=1
Trbegin [PWC], [PWP]
Readlock [PWC] PWC0=adxuid(1);[M:POC0]XPOHNUM;[M:POC2]POPLIN
If fstat=1
  NERROR = 2
  GOK=-1 : GLOCK="$PWRKPOC"-num$(adxuid(1))
  GMESSAGE = mess(13,100,1)-"PWRKPOC"
Elsif fstat = 0
  Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]POPLIN
  #----- Si pas d'existence de demandes de livraison alors modification PJT -----#
  If fstat <> 0
    [F:PWC]PJT = PJTNEW
    [F:PWC]PRONUM=adxuid(1)
    Rewrite [PWC]
    If fstat GOK=0
      Call FSTA("PWC") From GLOCK
      NERROR = 2
    Endif
  Endif
Endif

For [PWP] PWP0 Where PRONUM=adxuid(1) & POHNUM=[M:POC0]XPOHNUM & POPLIN=[M:POC2]POPLIN
  PWP_SEQ = [F:PWP]POPSEQ
  Readlock [PWP] PWP0=adxuid(1);[M:POC0]XPOHNUM;[M:POC2]POPLIN;PWP_SEQ
  If fstat=1
    NERROR = 2
    GOK=-1 : GLOCK="$PWRKPOP"-num$(adxuid(1))
    GMESSAGE = mess(13,100,1)-"PWRKPOP"
    Break 2
  Elsif fstat = 0
    Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]POPLIN
    #----- Si pas d'existence de demandes de livraison alors modification PJT -----#
    If fstat <> 0
      [F:PWP]PJT = PJTNEW
      Rewrite [PWP]
      If fstat GOK=0
        Call FSTA("PWP") From GLOCK
        NERROR = 2
        Break
      Endif
    Endif
  Endif
Next
If GOK<>1 : Rollback : End NERROR : Endif
Commit
# mise à jour des lignes
For I=0 To [M:POC2]NBLIG-1
  [M:POC2]PJT1(I) = PJTNEW
  [M:POC2]UPDFLG(I)=1
  # Issue X3-3807 - 2017-10-24 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
  # Initialisation de la section analytique gérée à l'affaire sur les lignes de prix
  # Initialization of the dimension managed by project on the price lines
  NERROR = func PJT_INIT_CCE_CAL("POP", 0, [M:POC0]POHNUM, [M:POC2]XPOPLIN(I), 0, "", "1", PJTNEW, I)
  If NERROR <> 0 Then
    Break
  Endif
  # End issue X3-3807
Next I
Affzo [POC2]30 # Issue X3-3807 - 2017-10-25 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
End NERROR

# Issue 71069 - 2016-09-07 by MUARN : PJT
$AM_PJTH

If [M:POC2]NBLIG = 0 & [M:POC2]ITMREF = ""

  [M:POC1]PJTH=VALEUR

  If dim([M:POC1]NBAXE)>0
    If [M:POC1]NBAXE>0
        For I=1 To [M:POC1]NBAXE Raz [M:POC1]CCE(I-1) : Next
    Endif
    Call INIT_CCEH("POC1","NBAXE","POH") From TRTX3CPT
    If !GIMPORT : Affzo [M:POC1]30 : Endif
  Endif

  If dim([M:POC3]NBFAC) > 0
    For I=0 To [M:POC3]NBFAC-1
      If [M:POC3]DSP(I) = ""
        For J=1 To GNBDIE
          Case J
            When  1 :
              Raz [M:POC3]PFICCE1 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE1(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When  2 :
              Raz [M:POC3]PFICCE2 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE2(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When  3 :
              Raz [M:POC3]PFICCE3 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE3(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When  4 :
              Raz [M:POC3]PFICCE4 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE4(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When  5
              Raz [M:POC3]PFICCE5 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE5(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When  6 :
              Raz [M:POC3]PFICCE6 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE6(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When  7 :
              Raz [M:POC3]PFICCE7 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE7(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When  8 :
              Raz [M:POC3]PFICCE8 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE8(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When  9 :
              Raz [M:POC3]PFICCE9 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE9(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When 10 :
              Raz [M:POC3]PFICCE10(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE10(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When 11 :
              Raz [M:POC3]PFICCE11(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE11(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When 12 :
              Raz [M:POC3]PFICCE12(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE12(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When 13 :
              Raz [M:POC3]PFICCE13(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE13(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When 14 :
              Raz [M:POC3]PFICCE14(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE14(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When 15 :
              Raz [M:POC3]PFICCE16(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE15(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When 16 :
              Raz [M:POC3]PFICCE17(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE16(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When 17 :
              Raz [M:POC3]PFICCE17(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE17(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When 18 :
              Raz [M:POC3]PFICCE18(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE18(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When 19 :
              Raz [M:POC3]PFICCE19(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE19(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
            When 20 :
              Raz [M:POC3]PFICCE20(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:POC3]PFICCE20(I),J,"POCV","[M:POC3]ACC",I) From TRTX3CPT
          Endcase
        Next J
      Endif
    Next I
    If !GIMPORT : Affzo [M:POC3]5 : Endif
  Endif

Endif

Return

# Issue X3-3807 - 2017-10-24 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
#########################################################################
#**
#* Initialisation de la section analytique gérée à l'affaire sur les lignes de prix
#* Utilisé par REPERCUTE_PJTH
#* Boucle de lecture des lignes de prix PORDERP, pour chaque ligne lecture CPTANALIN pour init de la section et maj
#* Initialization of the dimension managed by project on the price lines
#* Used by REPERCUTE_PJTH
#* Used when the field PJT is not on the lines (if field PJT on the lines init is done with EXEC_PJTREPEAT_OUI or EXEC_PJTREPEAT_OUISI)
#* Lopp on the price lines PORDERP, for each line read CPTANALIN for init and dimension update
#*
#* @param WABRFIC  Abréviation table des lignes du document/Abbreviation table for document lines
#* @param WVCRTYP  Type de pièce/Entry type
#* @param WVCRNUM  N° de pièce/Entry Number
#* @param WVCRLIN  Numéro de ligne de la pièce/Entry line number
#* @param WVCRSEQ  Numéro de séquence de la pièce / /Entry sequence number
#*                 si 0 concerne toutes les lignes de prix d'une ligne article/if 0 concerns all the price lines for the product line
#* @param WCPLCLE  Complément clé/Complement key
#* @param SACTION  Valeur action repeat (1 Oui/2 Non/3 Oui si) Toujours à 1/Value for repeat action (1 Yes/2 No/3 Yes if) Always = 1
#* @param SPJTNEW  nouvelle valeur du PJT / New value of PJT
#* @param SNOL     ligne en cours / courrent Line
#*
#*!
Funprog PJT_INIT_CCE_CAL(WABRFIC, WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE, SACTION, SPJTNEW, SNOL)
Value Char    WABRFIC
Value Integer WVCRTYP
Value Char    WVCRNUM
Value Integer WVCRLIN
Value Integer WVCRSEQ
Value Char    WCPLCLE
Value Char    SACTION
Value Char    SPJTNEW
Value Integer SNOL

Local Integer NERROR
Local Integer NADXLOG
Local Integer WNOLIGN : WNOLIGN = SNOL + 1
Local Char    LVALPJT(GLONPJT)

# Utilisé par GET_PARAM_CCED de TRTPJTPUR pour connaître le contexte/ Used by GET_PARAM_CCED from TRTPJTPUR to know the context
Local Char    WCCEMSK : WCCEMSK = "POC2"

Local Char SBASTAB(GLONABR+GLONAVA+4)
Local Char STRTMODULE(GLONADC)
Local Integer ITRTMODULE
Local Char PJTACTION(GLONDCO)

Call TRAITEMENT_MODULE(6, STRTMODULE, ITRTMODULE) From TRTPJT


# Alimenter [M:POC2]PJT avec la nouvelle valeur zc car l'initialisation des sections INIT_CCE utilise [M:POC2]PJT
# [M:POC2]PJT is loaded with the new value zc because dimension initialization INIT_CCE uses [M:POC2]PJT
LVALPJT = [M:POC2]PJT
[M:POC2]PJT= SPJTNEW

# Initialisation de la section anaylitique
# Dimension initialization
Gosub PJT_INIT_CCED From TRTPJT

# Réalimenter M:POC2]PJT avec l'ancienne valeur
# M:POC2]PJT is reloaded with the old value
[M:POC2]PJT = LVALPJT

End NERROR


# Issue X3-3807 - 2017-10-24 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
#########################################################################
#**
#* Initialisation de la section analytique gérée à l'affaire sur les lignes de prix
#* Utilisé par REPERCUTE_PJTH et REPERCUTE_PJT
#* Boucle de lecture des lignes de prix PORDERP, pour chaque ligne lecture CPTANALIN pour init de la section et maj
#* Initialization of the dimension managed by project on the price lines
#* Used by REPERCUTE_PJTH et REPERCUTE_PJT
#* Used when the field PJT is not on the lines (if field PJT on the lines init is done with EXEC_PJTREPEAT_OUI or EXEC_PJTREPEAT_OUISI)
#* Lopp on the price lines PORDERP, for each line read CPTANALIN for init and dimension update
#*
#* @param WABRFIC  Abréviation table des lignes du document/Abbreviation table for document lines
#* @param WVCRTYP  Type de pièce/Entry type
#* @param WVCRNUM  N° de pièce/Entry Number
#* @param WVCRLIN  Numéro de ligne de la pièce/Entry line number
#* @param WVCRSEQ  Numéro de séquence de la pièce / /Entry sequence number
#*                 si 0 concerne toutes les lignes de prix d'une ligne article/if 0 concerns all the price lines for the product line
#* @param WCPLCLE  Complément clé/Complement key
#* @param SACTION  Valeur action repeat (1 Oui/2 Non/3 Oui si) Toujours à 1/Value for repeat action (1 Yes/2 No/3 Yes if) Always = 1
#* @param SPJTNEW  nouvelle valeur du PJT / New value of PJT
#* @param SNOL     ligne en cours / courrent Line
#*
#*!
Funprog PJT_INIT_CCE_CAL_PWP(WABRFIC, WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE, SACTION,SPJTNEW)
Value Char    WABRFIC
Value Integer WVCRTYP
Value Char    WVCRNUM
Value Integer WVCRLIN
Value Integer WVCRSEQ
Value Char    WCPLCLE
Value Char    SACTION
Value Char    SPJTNEW

Local Integer NERROR
Local Integer NADXLOG
Local Char    LVALPJT(GLONPJT)

# Utilisé par GET_PARAM_CCEH de TRTPJTPUR pour connaître le contexte/ Used by GET_PARAM_CCEH from TRTPJTPUR to know the context
Local Char    CODMSK : CODMSK ="POC2PWP"

Local Char SBASTAB(GLONABR+GLONAVA+4)
Local Char STRTMODULE(GLONADC)
Local Integer ITRTMODULE
Local Char PJTACTION(GLONDCO)

Call TRAITEMENT_MODULE(6, STRTMODULE, ITRTMODULE) From TRTPJT

# Alimenter [M:POC2]PJT avec la nouvelle valeur zc car l'initialisation des sections INIT_CCE utilise [M:POC2]PJT
# [M:POC2]PJT is loaded with the new value zc because dimension initialization INIT_CCE uses [M:POC2]PJT
LVALPJT = [M:POC2]PJT
[M:POC2]PJT= SPJTNEW

# Initialisation de la section anaylitique
# Dimension initialization
Gosub PJT_INIT_CCEH From TRTPJT

# Réalimenter M:POC2]PJT avec l'ancienne valeur
# M:POC2]PJT is reloaded with the old value
[M:POC2]PJT = LVALPJT

End NERROR

