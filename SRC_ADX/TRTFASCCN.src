#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP
#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP
#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP
##########################################################################
# Gestion du masque FASCCN [M:FASY] - Masque paramètres
##########################################################################
#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP
#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP
#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP


#------------------------------------
Subprog AM_UPDTYP(VALEUR)
Variable Integer VALEUR

  Actzo [M:FASY]REN

  If ( ACTTYPGES = GTAMUNI ) Then
    Case VALEUR
      When GVML_IRNWDAT    : # DATE RENOUVELLEMENT
        [M:FASY]RNWDAT    = [M:FAS6]RNWDAT                  : Actzo [M:FASY]RNWDAT
        [M:FASY]RNWDATFLG = [M:FAS6]RNWDATFLG
        [M:FASY]OBYRNWCON = 0                               : Affzo [M:FASY]OBYRNWCON : Diszo [M:FASY]OBYRNWCON
        [M:FASY]TPAFLG    = 0                               : Affzo [M:FASY]TPAFLG    : Diszo [M:FASY]TPAFLG
        [M:FASY]CCNACTCOD = ""                              : Affzo [M:FASY]CCNACTCOD : Diszo [M:FASY]CCNACTCOD : # FQ94077

      When GVML_IOCRFLG    : # OBLIGATION CONTRACTUELLE RENOUVELLEMENT
        [M:FASY]RNWDAT    = [0/0/0] : [M:FASY]RNWDATFLG = 0 : Diszo [M:FASY]RNWDAT
        [M:FASY]OBYRNWCON = [M:FAS6]OBYRNWCON               : Affzo [M:FASY]OBYRNWCON : Actzo [M:FASY]OBYRNWCON
        [M:FASY]TPAFLG    = 0                               : Affzo [M:FASY]TPAFLG    : Diszo [M:FASY]TPAFLG
        [M:FASY]CCNACTCOD = ""                              : Affzo [M:FASY]CCNACTCOD : Diszo [M:FASY]CCNACTCOD : # FQ94077

      When GVML_ITPAFLG    : # REMIS CONTRE INDEMNITE
        [M:FASY]RNWDAT    = [0/0/0] : [M:FASY]RNWDATFLG = 0 : Diszo [M:FASY]RNWDAT
        [M:FASY]OBYRNWCON = 0                               : Affzo [M:FASY]OBYRNWCON : Diszo [M:FASY]OBYRNWCON
        [M:FASY]TPAFLG    = [M:FAS6]TPAFLG                  : Affzo [M:FASY]TPAFLG    : Actzo [M:FASY]TPAFLG
        [M:FASY]CCNACTCOD = ""                              : Affzo [M:FASY]CCNACTCOD : Diszo [M:FASY]CCNACTCOD : # FQ94077

      When GVML_IACTCOD   : # CODE ACTUALISATION (FQ94077)
        [M:FASY]RNWDAT    = [0/0/0] : [M:FASY]RNWDATFLG = 0 : Diszo [M:FASY]RNWDAT
        [M:FASY]OBYRNWCON = 0                               : Affzo [M:FASY]OBYRNWCON : Diszo [M:FASY]OBYRNWCON
        [M:FASY]TPAFLG    = 0                               : Affzo [M:FASY]TPAFLG    : Diszo [M:FASY]TPAFLG
        [M:FASY]CCNACTCOD = [M:FAS6]CCNACTCOD               : Affzo [M:FASY]CCNACTCOD : Actzo [M:FASY]CCNACTCOD : # FQ94077
    Endcase
  Endif

  If ( ACTTYPGES = GTAMMAS ) Then
    Case VALEUR
      When GVML_IRNWDAT    : # DATE RENOUVELLEMENT
        [M:FASY]RNWDAT    = [0/0/0]                         : Actzo [M:FASY]RNWDAT
        [M:FASY]OBYRNWCON = 0                               : Affzo [M:FASY]OBYRNWCON : Diszo [M:FASY]OBYRNWCON
        [M:FASY]TPAFLG    = 0                               : Affzo [M:FASY]TPAFLG    : Diszo [M:FASY]TPAFLG
        [M:FASY]CCNACTCOD = ""                              : Affzo [M:FASY]CCNACTCOD : Diszo [M:FASY]CCNACTCOD : # FQ94077
      When GVML_IOCRFLG    : # OBLIGATION CONTRACTUELLE RENOUVELLEMENT
        [M:FASY]RNWDAT    = [0/0/0] : [M:FASY]RNWDATFLG = 0 : Diszo [M:FASY]RNWDAT
        [M:FASY]OBYRNWCON = G_NON                           : Affzo [M:FASY]OBYRNWCON : Actzo [M:FASY]OBYRNWCON
        [M:FASY]TPAFLG    = 0                               : Affzo [M:FASY]TPAFLG    : Diszo [M:FASY]TPAFLG
        [M:FASY]CCNACTCOD = ""                              : Affzo [M:FASY]CCNACTCOD : Diszo [M:FASY]CCNACTCOD : # FQ94077
      When GVML_ITPAFLG    : # REMIS CONTRE INDEMNITE
        [M:FASY]RNWDAT    = [0/0/0] : [M:FASY]RNWDATFLG = 0 : Diszo [M:FASY]RNWDAT
        [M:FASY]OBYRNWCON = 0                               : Affzo [M:FASY]OBYRNWCON : Diszo [M:FASY]OBYRNWCON
        [M:FASY]TPAFLG    = G_NON                           : Affzo [M:FASY]TPAFLG    : Actzo [M:FASY]TPAFLG
        [M:FASY]CCNACTCOD = ""                              : Affzo [M:FASY]CCNACTCOD : Diszo [M:FASY]CCNACTCOD : # FQ94077
      When GVML_IACTCOD   : # CODE ACTUALISATION (FQ94077)
        [M:FASY]RNWDAT    = [0/0/0] : [M:FASY]RNWDATFLG = 0 : Diszo [M:FASY]RNWDAT
        [M:FASY]OBYRNWCON = G_NON                           : Affzo [M:FASY]OBYRNWCON : Diszo [M:FASY]OBYRNWCON
        [M:FASY]TPAFLG    = 0                               : Affzo [M:FASY]TPAFLG    : Diszo [M:FASY]TPAFLG
        [M:FASY]CCNACTCOD = ""                              : Affzo [M:FASY]CCNACTCOD : Actzo [M:FASY]CCNACTCOD : # FQ94077
    Endcase
  Endif

  [M:FASY]UPDTYP = VALEUR

End

#------------------------------------
Subprog AV_RNWDAT(VALEUR)
Variable Date    VALEUR

  If ( ACTTYPGES = GTAMUNI ) Then
    If ([M:FASY]RNWDATFLG = G_OUI ) Then
      If ( GBROWS = 0 ) Then
        Chgstl [M:FASY]RNWDAT With "FORCAGE"
      Else
        Chgstl [M:FASY]RNWDAT With "TFORCAGE"
      Endif
    Else
      Chgstl [M:FASY]RNWDAT With ""
    Endif
  Endif
End

#------------------------------------
Subprog AS_RNWDAT(VALEUR)
Variable Date    VALEUR

  If ([M:FASY]RNWDATFLG <> G_OUI or func GLOBIENS.IS_CHAMP_ENABLE ("[M:FASY]RNWDAT", 0) = G_NON  ) Then
    GBOUT1 = ""
  Endif
End

#------------------------------------
Subprog AM_RNWDAT(VALEUR)
Variable Date    VALEUR


  # Contrôle
  Local Char CPYREF(GLONCPY)
  Case ACTTYPGES
    When GTAMMAS : CPYREF = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)
    When GTAMUNI : CPYREF = [M:FAS0]CPY
    When Default
  Endcase

  If ( ACTTYPGES = GTAMUNI and  VALEUR = [0/0/0] ) Then
    # Valeur obligatoire
    GERR= 1: GMESSAGE = mess(10,123,1)
    mkstat = 2
    End
  Endif

  If ( ACTTYPGES = GTAMUNI ) Then
    Read [DEP] DEP0=[M:FAS0]AASREF;G_CCNPLNIND;GFINEXECPF;GFINPERCPF
    If ( VALEUR < [F:DEP]STRDPRDAT ) Then
      # La date de renouvellement saisie ne peut pas être antérieure à la date de début d'amortissement gérant l'amort. industriel
      GERR= 1: GMESSAGE = mess(697,GML_MSGFAS,1)
      mkstat = 2
      End
    Endif
  Endif

  If ( VALEUR <> [0/0/0] and  VALEUR < GDEBEXECPF ) Then
    # La date de renouvellement saisie ne peut pas être antérieure à la date de début d'exercice du contexte gérant l'amort. industriel
    GERR= 1: GMESSAGE = mess(698,GML_MSGFAS,1)
    mkstat = 2
    End
  Endif

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR")) Then
    G_DEFORCE = 0
  Else
    [M:FASY]RNWDATFLG = G_OUI:  Affzo [M:FASY]RNWDATFLG
    Affzo [M:FASY]RNWDAT
    If ( GBROWS = 0 ) Then
      Chgstl [M:FASY]RNWDAT With "FORCAGE"
    Else
      Chgstl [M:FASY]RNWDAT With "TFORCAGE"
    Endif
  Endif
  [M:FASY]RNWDAT = VALEUR

  # Traitement associé
  # ....

End

#------------------------------------
Subprog B1_RNWDAT(VALEUR)
Variable Date    VALEUR

  # Gestion du code forçage
  [M:FASY]RNWDATFLG = G_NON : Affzo [M:FASY]RNWDATFLG

  # Traitement associé
  # ....

  If ( ACTTYPGES = GTAMUNI ) Then
    Local Integer I_PLNIND
    I_PLNIND = find(G_CCNPLNIND, [M:FAS3]DPRPLN)
    [M:FASY]RNWDAT = [M:FAS3]ENDDPRDAT(I_PLNIND-1)
  Else
    [M:FASY]RNWDAT = [0/0/0]
  Endif

  VALEUR =[M:FASY]RNWDAT
  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:FASY]RNWDAT  With ""
  Affzo [M:FASY]RNWDAT
  mkstat = 99

End


#------------------------------------
Subprog AM_TPAFLG(VALEUR)
Variable Integer VALEUR

  [M:FASY]TPAFLG = VALEUR

End


#------------------------------------
Subprog AM_OBYRNWCON(VALEUR)
Variable Integer VALEUR

  If ( ACTTYPGES = GTAMUNI ) Then
    If ( [M:FASY]OBYRNWCON = G_OUI and VALEUR <> G_OUI and func GLOCCN.RNW_ENCOURS([M:FAS0]CPY,[M:FAS0]FCY,[M:FAS0]AASREF) = 3 ) Then
      # Opération interdite : Le bien participe à une préparation de renouvellement en tant que bien à renouveler
      GERR= 1: GMESSAGE = mess(654,GML_MSGFAS,1)-":"-mess(749,GML_MSGFAS,1)
      mkstat = 2
      End
    Endif
  Endif

  [M:FASY]OBYRNWCON = VALEUR

End


########################################
Subprog AM_CCNACTCOD(VALEUR)
Variable Char    VALEUR()

  # FQ94077
  Local Char CPYREF(GLONCPY)
  Case ACTTYPGES
    When GTAMMAS : CPYREF = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)
    When GTAMUNI : CPYREF = [M:FAS0]CPY
    When Default
  Endcase

Local Char LLOCK (200)
Local Char LLOCK2(200)
  LLOCK  = func GLOBIENS.GET_KEY_CCNCOE (CPYREF, VALEUR)
  LLOCK2 = func GLOBIENS.GET_KEY_CCNCOE ("", VALEUR)
  If ( func GLOBIENS.IS_SYMBOLE_LOCKED ("COE", CPYREF, LLOCK)  = 0 or
&        func GLOBIENS.IS_SYMBOLE_LOCKED ("COE", CPYREF, LLOCK2) = 0      ) Then
    # Test si le nouveau code actualisation est verrouillée par la transaction "Gestion des Codes actualisations"
    GERR= 1: GMESSAGE = mess(690,7773,1)
    mkstat = 2 : End
  Endif

  [M:FASY]CCNACTCOD = VALEUR
End

###################################################################
Subprog C_CCNACTCOD(VALEUR)
Variable Char    VALEUR()


  # FQ94077
  Local Char CPYREF(GLONCPY)
  Case ACTTYPGES
    When GTAMMAS : CPYREF = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)
    When GTAMUNI : CPYREF = [M:FAS0]CPY
    When Default
  Endcase

  Look[COE]COE0= CPYREF;VALEUR
  If (fstat) Then
    Look[COE]COE0= "";VALEUR
    If (fstat) Then
      GERR= 1: GMESSAGE = mess(692,7773,1)
      mkstat = 2 : End
    Endif
  Endif
End

