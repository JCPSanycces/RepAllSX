#CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC
#CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC
#CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC
#########################################################################
# Gestion du masque FASCCNR [M:MFS0] - Objet de reprise
#########################################################################
#CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC
#CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC
#CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC



#-------------------------------------------
Subprog CCN_CHGRNWCON ( PSIMU, PRNWCON, PFINAMT, PDEBPER, RETOUR )
#
# - Objet  : Prise en compte du changement de l'indicateur OCR d'un bien
#
# - Prérequis :
#
#            [F:FASZ] Classe FXDASSETS alimentée avec les informations du bien à traiter
#
# - Entrée : Indicateur simulation Oui - Non
#            Indicateur OCR à appliquer
#            Fin d'amortissement du plan industriel
#            Début de période courante du contexte fiscal & comptable
#
# - Sortie : [F:FASZ]OBYRNWCON
#            [F:FASZ]RNWFLG
#            Retour
#            -1  Aucun changement
#             0  OK
#             1  Le bien participe à une préparation de renouvellement en tant que bien à renouveler
#           > 20 Erreur génération événement
#
Value    Integer  PSIMU
Value    Integer  PRNWCON
Value    Date     PFINAMT
Value    Date     PDEBPER
Variable Integer  RETOUR

  # Approche optimiste
  RETOUR  = 0
  # Par défaut :  Indicateur OER inchangé
  RRNWFLG = [F:FASZ]RNWFLG
  # Si indicateur OCR est inchangé alors arrêt du traitement : ceci n'est pas une erreur
  If ( [F:FASZ]OBYRNWCON = PRNWCON ) Then : RETOUR = -1 : Endif

  # Sauvegarde des globales ci-dessous si elle existe déjà
  If dim(G_RNWFLGO)>0 : If dim(SV_RNWFLGO)>0 : Kill SV_RNWFLGO: Endif : Local Integer SV_RNWFLGO: SV_RNWFLGO=G_RNWFLGO: Else : Global Integer G_RNWFLGO: Endif
  If dim(G_RNWDATO)>0 : If dim(SV_RNWDATO)>0 : Kill SV_RNWDATO: Endif : Local Date    SV_RNWDATO: SV_RNWDATO=G_RNWDATO: Else : Global Date    G_RNWDATO: Endif
  If dim(G_RNWDATN)>0 : If dim(SV_RNWDATN)>0 : Kill SV_RNWDATN: Endif : Local Date    SV_RNWDATN: SV_RNWDATN=G_RNWDATN: Else : Global Date    G_RNWDATN: Endif
  If dim(G_RNWCONO)>0 : If dim(SV_RNWCONO)>0 : Kill SV_RNWCONO: Endif : Local Integer SV_RNWCONO: SV_RNWCONO=G_RNWCONO: Else : Global Integer G_RNWCONO: Endif
  If dim(G_TPAFLGO)>0 : If dim(SV_TPAFLGO)>0 : Kill SV_TPAFLGO: Endif : Local Integer SV_TPAFLGO: SV_TPAFLGO=G_TPAFLGO: Else : Global Integer G_TPAFLGO: Endif
  # FQ94077
  If dim(G_CCNACTCODO)>0 : If dim(SV_CCNACTCODO)>0 : Kill SV_CCNACTCODO: Endif : Local Char SV_CCNACTCODO(GLONCCA) : SV_CCNACTCODO=G_CCNACTCODO: Else : Global Char G_CCNACTCODO(GLONCCA): Endif
  If dim(G_CCNACTCODN)>0 : If dim(SV_CCNACTCODN)>0 : Kill SV_CCNACTCODN: Endif : Local Char SV_CCNACTCODN(GLONCCA) : SV_CCNACTCODN=G_CCNACTCODN: Else : Global Char G_CCNACTCODN(GLONCCA): Endif

  If dim(G_RNWTRFCAD)>0
    If dim(SV_RNWTRFCAD)>0 : Kill SV_RNWTRFCAD: Endif
    Local Decimal SV_RNWTRFCAD: SV_RNWTRFCAD=G_RNWTRFCAD
  Else
    Global Decimal G_RNWTRFCAD
  Endif

  # Valeurs Avant pour événement
  G_RNWFLGO = [F:FASZ]RNWFLG
  G_RNWDATO = [F:FASZ]RNWDAT
  G_RNWDATN = [F:FASZ]RNWDAT
  G_RNWCONO = [F:FASZ]OBYRNWCON
  G_TPAFLGO = [F:FASZ]TPAFLG
  # FQ94077
  G_CCNACTCODO = [F:FASZ]CCNACTCOD
  G_CCNACTCODN = [F:FASZ]CCNACTCOD

  # Contrôle
  If ( PRNWCON = G_OUI and func GLOCCN.RNW_ENCOURS([F:FASZ]CPY,[F:FASZ]FCY,[F:FASZ]AASREF) = 3 ) Then
    # Erreur  mess(749,GML_MSGFAS,1) : Le bien participe à une préparation de renouvellement en tant que bien à renouveler
    RETOUR = 1
    End
  Endif

  # Indicateur obligation contractuelle de renouvellement
  [F:FASZ]OBYRNWCON = PRNWCON

  # Détermination de l'indicateur OER
  If !clalev([F:CCN])  : Local File CONCESSION [CCN]  : Endif
  Read [CCN]CCN0=[F:FASZ]CCNREF
  Local Integer LRNWFLG
  Call CAL_DETERM_FLAG_OER ( "CHGOCRFLG", GVML_TDCONCE, GVML_GCRNW, [F:FASZ]OBYRNWCON,
&                            [F:FASZ]TPAFLG, [F:CCN]ENDCCNDAT, PFINAMT, LRNWFLG ) From GLOBB7
  [F:FASZ]RNWFLG = LRNWFLG

  # Génération d'événement
  #-1 ------------------------------
  If ( PSIMU = G_NON ) Then
    G_RNWTRFCAD = 0
    #--------------------
    Local Integer LCDRET
    Call GENER_EVE(GVML_OMBIEN, [F:FASZ]CPY, [F:FASZ]FCY, [F:FASZ]AASREF, 0, "FASCCN",  PDEBPER, [0/0/0], LCDRET) From GENEVE
    If (LCDRET > 20) Then
      # Erreur entrée/sortie --> Fichier : EFASCCN (mess(104,GML_MSGFAS,1)-" EFASCCN ")
      RETOUR = LCDRET
      End
    Endif
  Endif
  #-1 ------------------------------

  # Restoration
  If dim(SV_RNWFLGO)>0 : G_RNWFLGO=SV_RNWFLGO : Kill SV_RNWFLGO : Endif
  If dim(SV_RNWDATO)>0 : G_RNWDATO=SV_RNWDATO : Kill SV_RNWDATO : Endif
  If dim(SV_RNWDATN)>0 : G_RNWDATN=SV_RNWDATN : Kill SV_RNWDATN : Endif
  If dim(SV_RNWCONO)>0 : G_RNWCONO=SV_RNWCONO : Kill SV_RNWCONO : Endif
  If dim(SV_TPAFLGO)>0 : G_TPAFLGO=SV_TPAFLGO : Kill SV_TPAFLGO : Endif
  # FQ94077
  If dim(SV_CCNACTCODO)>0 : G_CCNACTCODO=SV_CCNACTCODO : Kill SV_CCNACTCODO : Endif
  If dim(SV_CCNACTCODN)>0 : G_CCNACTCODN=SV_CCNACTCODN : Kill SV_CCNACTCODN : Endif


  If dim(SV_RNWTRFCAD)>0 : G_RNWTRFCAD=SV_RNWTRFCAD : Kill SV_RNWTRFCAD : Endif

End


######################################################################################
