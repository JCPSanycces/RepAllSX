#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################
# TRTFASCCN - MISE A JOUR DES INFORMATIONS DES BIENS EN CONCESSION          ##
##############################################################################
#
#  Remarque :
#
#  Gestion de la date de renouvellement
#     G_RNWDATO & G_RNWDATN contient les dates ( jamais à [0/0/0] ) pour trace et événement. Dans le cas où la date
#                           est déforcée, la date est alimentée avec la fin d'amortissement du plan gérant l'industriel
#     [M:FASY]RNWDAT  contient une date pouvant être à [0/0/0] dans le cas où la date est déforcée.
#
##############################################################################
#
#  Modifications :
#    USR - DD.MM.YYYY FQnnnnn : Comment
#    MWA - 15.01.2015 FQ94077 : Mise à jour du coefficient d'actualisation
#    GBO - 20.01.2011 FQ68447 : Contrôle des sources
#    GBO - 20.01.2011 FQ65873 : Utilisation des globales GML_MSGxxx
##############################################################################
 Local Char MASUNI : MASUNI="M"
 Call LAUNCH_ACT(MASUNI)
End
######################################################################
#
######################################################################
#
# RAF :
#
######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION

 # !!!!!!!!!!!!!!!!!!!!!!!!!!!
 #If GUSER <> "MWA" and ACTION = "INIT" : Infbox " !!!!!!!!!!!!!!! EN CHANTIER !!!!!!!!!!!!!!!!!!!" : FIN = 1 :  Return :  Endif
 #If GUSER <> "MWA" : FIN = 1 :  Return :  Endif
 # !!!!!!!!!!!!!!!!!!!!!!!!!!!


 #If GUSER ="MWA" : Infbox "TRTFASCCN ACTION /"-ACTION : Endif
 If dim(ORIACT)>0 & ORIACT<>""
  Case ORIACT
   When "TRTOBJ"
    Case ACTION
     When "LIENS0"        : Gosub MFS_LIENS0
     When "LIENS"         : Gosub MFS_LIENS
     When "LIENS2"        : Gosub MFS_LIENS2
     When "INICRE"        : Gosub MFS_INICRE
    #When "ABANDON"       : Infbox "ABANDON dans MFS"
    #When "FIN"           : Infbox "FIN dans MFS"
     When Default
    Endcase
   When Default
  Endcase
 Else
  Case ACTION
   When "INIT_DIA"     : Gosub INIT_DIA
   When "INIT"         : Gosub INIT
   When "AVANT_PAR"    : Gosub AVANT_PAR
   When "OUVRE"        : Gosub OUVRE
   When "DEBUT"        : Gosub DEBUT
   When "APRES_MODIF"  : Gosub APRES_MODIF
   When "SETBOUT"      : Gosub SETBOUT
   When "AP_CHOIX"     : Gosub AP_CHOIX
   When "BOUTON"       : Gosub BOUTON
   When "END"          : Gosub END_BOITE
   When "AVANT_OK"     : Gosub AVANT_OK
   When "OK"           : Gosub OK
   When "ABA"          : Gosub ABA
   When "CONTROLE"     : Gosub CONTROLE
   When "EXEC"         : Gosub EXEC
   When "FIN"          : Gosub FIN
   When "TERMINE"      : Gosub TERMINE
   When "SORTIE"       : Gosub SORTIE
   When Default
  Endcase
 Endif

Return

#                   GSERVEUR  GBATCH
# Interactif           0        0
# Saisie param.        0        1
# Lancement trt        1        0


#=====================================================================
$INIT_DIA                    # (Massif - Saisie des paramètres)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

    Global Integer    G_DEFORCE         : # Indicateur zone déforcée (G_NON ou G_OUI)
    Global Integer    G_DEBUG           : G_DEBUG     = 1
    Global Integer    G_CURCCN          : Raz G_CURCCN
    Global Date       G_CURENDCCN       : Raz G_CURENDCCN

    Global Date       G_RNWDATO
    Global Date       G_RNWDATN
    Global Integer    G_RNWCONO
    Global Integer    G_RNWCONN
    Global Integer    G_TPAFLGO
    Global Integer    G_TPAFLGN
    Global Integer    G_RNWFLGO
    Global Integer    G_RNWFLGN
    Global Char       G_REN(GLONDCO)
    Global Decimal    G_RNWTRFCAD
    Global Char       G_CCNACTCODO(GLONCCA)   : # FQ94077
    Global Char       G_CCNACTCODN(GLONCCA)   : # FQ94077

Return

#=====================================================================
$INIT                    # (Unitaire et Massif - interactif et exécution batch)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT


    Global Integer    G_DEFORCE         : # Indicateur zone déforcée (G_NON ou G_OUI)
    Global Integer    G_DEBUG           : G_DEBUG     = 1
    Global Integer    G_CURCCN          : Raz G_CURCCN
    Global Date       G_CURENDCCN       : Raz G_CURENDCCN

    Global Date       G_RNWDATO
    Global Date       G_RNWDATN
    Global Integer    G_RNWCONO
    Global Integer    G_RNWCONN
    Global Integer    G_TPAFLGO
    Global Integer    G_TPAFLGN
    Global Integer    G_RNWFLGO
    Global Integer    G_RNWFLGN
    Global Char       G_REN(GLONDCO)
    Global Decimal    G_RNWTRFCAD
    Global Char       G_CCNACTCODO(GLONCCA)   : # FQ94077
    Global Char       G_CCNACTCODN(GLONCCA)   : # FQ94077

Return

#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

  ##### Ouverture des masques de la fenêtre de l'action massive pour pouvoir les garder jusqu'à
  ##### EXEC - Ouverture manuelle des masques de la fenêtre.
  ##### Nécessaire jusqu'à ce qu'une modif permette de lancer une action massive avec plus
  ##### d'un écran de critère.
  Local Char WINACT : WINACT=ACTMETNAM+"M"
  Local Integer I_MSK
  If !clalev([F:AWI]) : Local File AWINDOW : Endif
  If !clalev([F:AMK]) : Local File AMSK    : Endif
  Read [AWI]AWI0=WINACT
  If !fstat
    Local Mask =[F:AWI]MSKENT
    For I_MSK=0 To [F:AWI]NBMSK
      Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
      Local Mask =[F:AMK]CODMSK
    Next I_MSK
  Endif

  #-> Initialisation des paramètres
  Raz [M:FASY]RNWDAT
  Raz [M:FASY]OBYRNWCON
  Raz [M:FASY]TPAFLG
  Raz [M:FASY]CCNACTCOD  : # FQ94077

  #--> Réaffichage du masque paramètre et positionnement à  non valide pour forcer tous les contrôles
  Affzo  [M:FASY]
  Setmok [M:FASY] With 0

  ##### Préparation et lancement de l'action en mode silencieux
  If ACTSILENCE=G_OUI & TRTFILMSK<>""
    TYPPRG=0
    Gosub INIT_WIN  From TRMPROACT
    Gosub ALIM_MASK From =TRTFILMSK

    Global Integer    G_DEFORCE         : # Indicateur zone déforcée (G_NON ou G_OUI)
    Global Integer    G_DEBUG           : G_DEBUG     = 1
    Global Integer    G_CURCCN          : Raz G_CURCCN
    Global Date       G_CURENDCCN       : Raz G_CURENDCCN

    Global Date       G_RNWDATO
    Global Date       G_RNWDATN
    Global Integer    G_RNWCONO
    Global Integer    G_RNWCONN
    Global Integer    G_TPAFLGO
    Global Integer    G_TPAFLGN
    Global Integer    G_RNWFLGO
    Global Integer    G_RNWFLGN
    Global Char       G_REN(GLONDCO)
    Global Decimal    G_RNWTRFCAD
    Global Char       G_CCNACTCODO(GLONCCA)   : # FQ94077
    Global Char       G_CCNACTCODN(GLONCCA)   : # FQ94077
 Endif

Return

#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

  Global Integer    G_DEFORCE         : # Indicateur zone déforcée (G_NON ou G_OUI)
  Global Integer    G_DEBUG           : G_DEBUG = 1
  Global Integer    G_CURCCN          : Raz G_CURCCN
  Global Date       G_CURENDCCN       : Raz G_CURENDCCN

  Global Date       G_RNWDATO
  Global Date       G_RNWDATN
  Global Integer    G_RNWCONO
  Global Integer    G_RNWCONN
  Global Integer    G_TPAFLGO
  Global Integer    G_TPAFLGN
  Global Integer    G_RNWFLGO
  Global Integer    G_RNWFLGN
  Global Char       G_REN(GLONDCO)
  Global Decimal    G_RNWTRFCAD
  Global Char       G_CCNACTCODO(GLONCCA)   : # FQ94077
  Global Char       G_CCNACTCODN(GLONCCA)   : # FQ94077

  If !clalev([F:WFAS]) : Local File FXDASSETS  [WFAS] : Endif
  If !clalev([F:CNX])  : Local File CONTEXT    [CNX]  : Endif
  If !clalev([F:DEP])  : Local File DEPREC     [DEP]  : Endif
  If !clalev([F:CCN])  : Local File CONCESSION [CCN]  : Endif
  If !clalev([F:FIS])  : Local File FISCYEAR   [FIS]  : Endif

  # FQ94077
  If !clalev([F:COE])  : Local File CCNCOE     [COE]  : Endif

  ######> UNITAIRE

  #-1 ----------------------------------------------
  If ( ACTTYPGES = GTAMUNI ) Then
    # "Action interdite : Le mode de gestion des concessions n'est pas"-GVML_GCRNW
    If ( G_CCNRPR <> G_OUI ) Then
    GMESSAGE = mess(654,GML_MSGFAS,1)-":"-mess(743,GML_MSGFAS,1)-mess(GVML_GCRNW,GML_GESCCN,1) :GERR=1 : FIN=1 : Return
    Endif

    # "Action interdite : Le bien est sorti."
    If ( [M:FAS4]ISSDAT <> [0/0/0] ) Then
      GMESSAGE = mess(654,GML_MSGFAS,1)-":"-mess(745,GML_MSGFAS,1) :GERR=1 : FIN=1 : Return
    Endif
  Endif
  #-1 ----------------------------------------------


Return

#=====================================================================
$DEBUT # (Massif interactif et Unitaire)

  Gosub ACTION From =TRTMODACT
  #-1 ---------------------------
  If (!GBATCH) Then
    #-> Effacement du masque paramètre
    Effzo [M:FASY]
    If ( ACTTYPGES = GTAMUNI ) Then
      [M:FASY]RNWDAT    = [M:FAS6]RNWDAT
      G_RNWDATN         = [M:FAS6]RNWDAT
      [M:FASY]RNWDATFLG = [M:FAS6]RNWDATFLG
      [M:FASY]OBYRNWCON = 0   : Diszo [M:FASY]OBYRNWCON
      [M:FASY]TPAFLG    = 0   : Diszo [M:FASY]TPAFLG
      [M:FASY]REN       = ""  : Diszo [M:FASY]REN
      [M:FASY]CCNACTCOD = ""  : Diszo [M:FASY]CCNACTCOD  : # FQ94077

      G_RNWFLGO         = [M:FAS6]RNWDATFLG
      G_RNWFLGN         = [M:FAS6]RNWDATFLG
      G_RNWDATO         = [M:FAS6]RNWDAT
      G_RNWCONO         = [M:FAS6]OBYRNWCON
      G_TPAFLGO         = [M:FAS6]TPAFLG
      G_CCNACTCODO      = [M:FAS6]CCNACTCOD  : # FQ94077
      G_CCNACTCODN      = [M:FAS6]CCNACTCOD  : # FQ94077
    Endif
    If ( ACTTYPGES = GTAMMAS ) Then
      [M:FASY]RNWDAT    = [0/0/0] : Diszo [M:FASY]RNWDAT
      [M:FASY]OBYRNWCON = 0       : Diszo [M:FASY]OBYRNWCON
      [M:FASY]TPAFLG    = 0       : Diszo [M:FASY]TPAFLG
      [M:FASY]REN       = ""      : Diszo [M:FASY]REN
      [M:FASY]CCNACTCOD = ""      : Diszo [M:FASY]CCNACTCOD  : # FQ94077
    Endif
  Endif
  #-1 ---------------------------

  #--> Réaffichage du masque paramètre
  Affzo  [M:FASY]
  #--> Positionnement à non valide pour forcer tous les contrôles
  Setmok [M:FASY] With 0

  #--> Si mode silencieux, alimentation du masque
  If ( ACTSILENCE = G_OUI and TRTFILMSK <> "" ) Then
    TYPPRG=0
    Gosub ALIM_MASK From =TRTFILMSK
  Endif

Return


#=====================================================================
$APRES_MODIF             # (Massif interactif et Unitaire)
 Case COUZON
  When Default
 Endcase
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$SETBOUT                 # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT

  If ( ACTTYPGES = GTAMUNI  ) Then
    Case [M:FASY]UPDTYP
     When GVML_IRNWDAT    : # DATE RENOUVELLEMENT
       If ( [M:FASY]RNWDAT = [M:FAS6]RNWDAT ) Then
         Call VIREBOUT (CHBOU,"O") From GOBJET
         Call VIREBOUT (CHMEN,"D") From GOBJET
       Endif
     When GVML_IOCRFLG    : # OBLIGATION CONTRACTUELLE RENOUVELLEMENT
       If ( [M:FASY]OBYRNWCON = [M:FAS6]OBYRNWCON ) Then
         Call VIREBOUT (CHBOU,"O") From GOBJET
         Call VIREBOUT (CHMEN,"D") From GOBJET
       Endif
     When GVML_ITPAFLG    : # REMIS CONTRE INDEMNITE
       If ( [M:FASY]TPAFLG = [M:FAS6]TPAFLG ) Then
         Call VIREBOUT (CHBOU,"O") From GOBJET
         Call VIREBOUT (CHMEN,"D") From GOBJET
       Endif
     When GVML_IACTCOD    : # CODE ACTUALISATION  (FQ94077)
       If ( [M:FASY]CCNACTCOD = [M:FAS6]CCNACTCOD ) Then
         Call VIREBOUT (CHBOU,"O") From GOBJET
         Call VIREBOUT (CHMEN,"D") From GOBJET
       Endif
     When Default
       Call VIREBOUT (CHBOU,"O") From GOBJET
       Call VIREBOUT (CHMEN,"D") From GOBJET
    Endcase
  Endif

Return

#=====================================================================
$AP_CHOIX                 # (Unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$BOUTON                  # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$END_BOITE               # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return


#=====================================================================
$AVANT_OK
  Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$OK                      # (Massif interactif et unitaire)
  Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$CONTROLE
  Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$ABA
 Effzo [M:FASY]
 Gosub DEBUT
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$EXEC                    # (Massif interactif et batch)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$FIN                     # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$TERMINE                  # (Massif interactif et batch)
 Gosub ACTION From =TRTMODACT

 If dim(G_DEFORCE)      >0   : Kill G_DEFORCE       : Endif
 If dim(G_DEBUG)        >0   : Kill G_DEBUG         : Endif
 If dim(G_CURCCN)       >0   : Kill G_CURCCN        : Endif
 If dim(G_CURENDCCN)    >0   : Kill G_CURENDCCN     : Endif

 If dim(G_RNWDATO)      >0   : Kill G_RNWDATO       : Endif
 If dim(G_RNWCONN)      >0   : Kill G_RNWCONN       : Endif
 If dim(G_RNWCONO)      >0   : Kill G_RNWCONO       : Endif
 If dim(G_TPAFLGO)      >0   : Kill G_TPAFLGO       : Endif
 If dim(G_TPAFLGN)      >0   : Kill G_TPAFLGN       : Endif
 If dim(G_RNWFLGO)      >0   : Kill G_RNWFLGO       : Endif
 If dim(G_RNWFLGN)      >0   : Kill G_RNWFLGN       : Endif
 If dim(G_REN)          >0   : Kill G_REN           : Endif
 If dim(G_RNWTRFCAD)    >0   : Kill G_RNWTRFCAD     : Endif
 If dim(G_CCNACTCODO)   >0   : Kill G_CCNACTCODO    : Endif  : # FQ94077
 If dim(G_CCNACTCODN)   >0   : Kill G_CCNACTCODN    : Endif  : # FQ94077

Return

#=====================================================================
$SORTIE                  # (Massif interactif et batch)
 Gosub ACTION From =TRTMODACT
Return

######################################################################
# Points d'entrée de l'action métier communs unitaire / massif
######################################################################
#
# Construction du nom des étiquettes :
#
# AAAA_BBBB_CCCCCC
#
# AAAA => Nom de la table origine (MAS1 / TMP1 / TPF1
# BBBB => Etape de l'action
# CCCC => Table destination ou Action ou Objet
#
######################################################################
#{ET_ACTMET}#
$ACTMET
Case ACTMET

  When  "SET_CRIT_FCY"      :   Gosub SET_CRIT_FCY         # M  - Filtre sur les sites non français


  When "CRITMEN"            :   Gosub CRITMEN              # U  - Activation menu ou bouton
  When "SET_PRECHARGE"      :   Gosub SET_PRECHARGE        # U  - A positionner à G_OUI s'il n'y a pas de bouton sélectionner
  When "SET_CALCPARM"       :   Gosub SET_CALCPARM         # UM - A positionner à G_OUI si l'action utilise le moteur de calcul
  When "FILL_HEA"           :   Gosub FILL_HEA             # U  - Alimentation partie spécifique en-tête

# Actions hors sous-programmes, communes au massif et à l'unitaire

  When "SET_CRITACT"        :   Gosub SET_CRITACT          # UM - CRITACT critère de sélection particulier à l'action métier

# s/p "LOCKER"

  When "OUVR_LOCK"          :   Gosub OUVR_LOCK            # UM - Ouverture de tables annexes pour les lock
  When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # M  - Exclusion élément de la population à sélectionner
  When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      # UM - Lock objet lié à l'enr en ligne de la population
  When "MAS1_LOCK_MONTANT"  :   Gosub MAS1_LOCK_MONTANT    # UM - Permet d'alimenter les zones montant de TMPMASLCK
  When "CLOS_LOCK"          :   Gosub CLOS_LOCK            # UM - Fermeture de tables annexes pour les lock

# s/p "CHARGER"

  When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       # UM - Ouverture de tables annexes pour l'alim des table tmp.
  When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de données -> tables tempo

# s/p "APPLIQUE_TEMP"

  When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       #
  When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramètres de l'action aux enr de la table temporaire principale
  When "TPF1_APPL_TPF1"     :   Gosub TPF1_APPL_TPF1       # UM - Application des paramètres de l'action aux enr de la table temporaire annexe
  When "END_APPL_TMP1"      :   Gosub END_APPL_TMP1        # UM - Traitement en fin de boucle avant fin de la transaction

# s/p "REPORT_MASK" Report objet principal dans les masques (unitaire uniquement)

  When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'écran
  When "TPF1_ALIM_MASK"     :   Gosub TPF1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'écran
  When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       # U  - Tansfert tables temporaires -> masques de l'écran (pour réaffichage)

# s/p "APPLIQUE_DIRT" Mise à jour directe (massif uniquement)

  When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
  When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise à jour directe des tables de données avec les paramètres de l'action
  When "END_APPL_DIRT"      :   Gosub END_APPL_DIRT        # M  - Traitement de fin de boucle avant fin de la transaction
  When "CLOS_APPL_DIRT"     :   Gosub CLOS_APPL_DIRT       # M  - Fermeture des tables annexes

# s/p "REPORTER"

  When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture de table annexes pour le report tmp -> données
  When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # UM - Report table temporaire principale -> FXDASSETS
  When "TPF1_ALIM_TABLE"    :   Gosub TPF1_ALIM_TABLE      # UM - Report table temporaire par plan -> DEPREC
  When "END_ALIM_TABLE"     :   Gosub END_ALIM_TABLE       # UM - Fin du report tmp -> données
  When "CLOS_ALIM_TABLE"    :   Gosub CLOS_ALIM_TABLE      # UM - Fermeture de table annexes pour le report tmp -> données

# Objet de visualisation / contrôle des modifications

  When "VISU_LOAD_PLAN"     :   Gosub VISU_LOAD_PLAN       # UM - Report table TPF dans Masque visu
  When "VISU_SAVE_PLAN"     :   Gosub VISU_SAVE_PLAN       # UM - Report masque visu dans table TPF

# Objet de visualisation / contrôle des modifications

  When "AM_FLGCPY"          :   Gosub AM_FLGCPY            # M  - Cochage/décochage d'une société
  When Default

 Endcase

Return

#=====================================================================
# Massif : Cochage/décochage d'une société
$AM_FLGCPY

 If ( VALEUR = G_OUI ) Then
   # Chargement de l'environnement global de la société
   GSOCIETE= [M:MHC]CPY(nolign-1)
   Call CHARGE_ENVIRONNEMENT () From GLOFCYCPY
 Endif


Return

#=====================================================================
# Unitaire : critère désactivation / activation menu CRITMEN
$SET_CRIT_FCY
  Local Char OLDCPY(GLONCPY)
  If ([F:FCY]LEGCPY <> OLDCPY) Then
    OLDCPY=[F:FCY]LEGCPY
    # Action réservée aux société gérant les concessions de type "Transmis par renouvellement
    If !clalev([F:CNX])  : Local File CONTEXT    [CNX]  : Endif
    Read [CNX]CNX0=[F:FCY]LEGCPY;G300CPFI
    If ( [F:CNX]CCNMOD <> GVML_GCRNW ) Then
      GOK= 0
    Endif
  Endif
Return


#=====================================================================
# Unitaire : critère désactivation / activation menu CRITMEN
$CRITMEN
 Local Integer ACCFCY
 Local Char AUZFCY (15)
 # Accès selon droit à l'option

 Call DROITSITE ( [M:FAS0]FCY, [L]AUZFCY, [L]ACCFCY ) From SUPCPT
 If ( not [L]ACCFCY or not instr(1, [L]AUZFCY, 'O') ) Then
   CRITMEN = "1=0"
 Else
   CRITMEN = "1=1"
 Endif

 If [F:FAS]OWNTYP <> GVML_TDCONCE
  CRITMEN = "1=0"
 Endif

Return

#=====================================================================
# Unitaire : Modif de la variable déclenchant le préchargement en unitaire PRECHARGE
$SET_PRECHARGE
 PRECHARGE=G_NON
Return

#=====================================================================
# Unitaire / massif : A activer uniquement si une action nécessite des appels au moteur de calcul
SET_CALCPARM
 CALC_MOTEUR = G_NON
Return

#=====================================================================
# Unitaire / massif : Modif de la variable fixant les critères de sélection propres à l'action
$SET_CRITACT
 If ACTTYPGES=GTAMMAS
  # CRITACT contient les critères de sélection suppplémentaires à appliquer à la population à sélectionner
  # Uniquement les biens en concession non sortis
  CRITACT=" OWNTYP = GVML_TDCONCE AND ISSDAT = [0/0/0] "
 Endif
Return

#=====================================================================
# Unitaire : Permet d'alimenter des zones spécifiques de l'en-tête de la fenêtre
$FILL_HEA
Return


###############################################################################################
# PHASE DE LOCK DE LA POPULATION DE BIENS COMPTABLES A TRAITER                                #
###############################################################################################

#=====================================================================
# Unitaire et massif : Sert à ouvrir des tables utilisées dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
$OUVR_LOCK
 If !clalev([F:MAS2]) : Local File FXDASSETS [MAS2] : Endif
Return

#=====================================================================
# Unitaire / massif : contrôle élément pour retrait de la population
$MAS1_CONTROLE
  Case [M:FASY]UPDTYP
    When GVML_IRNWDAT    : # DATE RENOUVELLEMENT
      If ( ACTTYPGES = GTAMMAS ) Then
        If ([M:FASY]RNWDAT <> [0/0/0] ) Then
          # Nouvelle date de renouvellement "forcée"
          If ([F:MAS1]RNWDATFLG = G_OUI and [F:MAS1]RNWDAT = [M:FASY]RNWDAT ) Then
            # Si le bien a déjà sa date forcée à la même valeur il est exclu de la population.
            GOK = 0
          Endif
        Else
          # Nouvelle date de renouvellement "déforcée"
          If ([F:MAS1]RNWDATFLG <> G_OUI ) Then
            # Si le bien a déjà sa date déforcée, il est exclu de la population.
            GOK = 0
          Endif
        Endif
      Endif
    When GVML_IOCRFLG    : # OBLIGATION CONTRACTUELLE RENOUVELLEMENT
      If ([M:FASY]OBYRNWCON = [F:MAS1]OBYRNWCON) Then
        GOK = 0
      Endif
    When GVML_ITPAFLG    : # REMIS CONTRE INDEMNITE
      If ([M:FASY]TPAFLG = [F:MAS1]TPAFLG) Then
        GOK = 0
      Endif
    When GVML_IACTCOD    : # CODE ACTUALISATION ( FQ94077 )
      If ([M:FASY]CCNACTCOD = [F:MAS1]CCNACTCOD) Then
        GOK = 0
      Endif
  Endcase
  If (!GOK) Then : Return : Endif

Return

#=====================================================================
# Unitaire / massif : Lock d'objet lié à l'enregistrement en ligne
#                     Alimenter RMES si un message doit apparaître
#=====================================================================
$MAS1_LOCK_AUTRE
Return

#=====================================================================
# Unitaire / massif : Sert à alimenter les zones montant de TMPMASLCK OBJAMT
#=====================================================================
$MAS1_LOCK_MONTANT
Return

#=====================================================================
# Unitaire et massif : Sert à fermer les tables utilisées dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
#=====================================================================
$CLOS_LOCK
Return

###############################################################################################
# CREATION DES ENREGISTREMENTS DANS LES TABLES TEMPORAIRES                                    #
###############################################################################################

#=====================================================================
# Unitaire / massif : Sert à ouvrir des tables utilisées dans MAS1_ALIM_TMP1
#=====================================================================
$OUVR_ALIM_TMP1
 If !clalev([F:MAS2]) : Local File FXDASSETS [MAS2] : Endif
 If !clalev([F:DEP])  : Local File DEPREC    [DEP]  : Endif
Return

#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
#=====================================================================
$MAS1_ALIM_TMP1

  #--> Alimentation table temporaire pour le bien comptable courant
  Raz [F:TMP1]
  [F:TMP1]FLGERR     = G_NON
  [F:TMP1]FLGMOD     = G_OUI

  # Chargement table temporaire TMPFASMAS [F:TMP1] avec infos du bien comptable [F:MAS1]
  [F:TMP1]TRTNUM     = NUMACT
  [F:TMP1]CPY        = [F:MAS1]CPY
  [F:TMP1]OBJREF     = [F:MAS1]AASREF
  [F:TMP1]AASDES1    = [F:MAS1]AASDES1
  [F:TMP1]CCNREF     = [F:MAS1]CCNREF
  [F:TMP1]RNWDATO    = [F:MAS1]RNWDAT
  [F:TMP1]RNWDAT     = [F:MAS1]RNWDAT
  [F:TMP1]RNWDATFLGO = [F:MAS1]RNWDATFLG
  [F:TMP1]RNWDATFLG  = [F:MAS1]RNWDATFLG
  [F:TMP1]OBYRNWCONO = [F:MAS1]OBYRNWCON
  [F:TMP1]OBYRNWCON  = [F:MAS1]OBYRNWCON
  [F:TMP1]TPAFLGO    = [F:MAS1]TPAFLG
  [F:TMP1]TPAFLG     = [F:MAS1]TPAFLG
  [F:TMP1]RNWFLGO    = [F:MAS1]RNWFLG
  [F:TMP1]RNWFLG     = [F:MAS1]RNWFLG
  [F:TMP1]TAXCOEFLG  = [F:MAS1]CCNETRNAT   : # (TAXCOEFLG en lieu et place de CCNETRNAT : débordement de TMPMASFAS)
  [F:TMP1]CCNACTCODO = [F:MAS1]CCNACTCOD : # FQ94077
  [F:TMP1]CCNACTCOD  = [F:MAS1]CCNACTCOD : # FQ94077


  Write [TMP1]
  If fstat
    Case fstat
      When 1
        RMES="TMPMASFAS"-mess(227,GML_MSGFAS,1)  # TMPMASFAS table verrouillée
        GOK=-1
      When 3
        RMES=mess(129,GML_MSGFAS,1)-[F:TMP1]TRTNUM+"/"+[F:TMP1]OBJREF
        GOK=0
      When Default
    Endcase
    Break 1
  Else
    NBTMP+=1
  Endif

Return

###############################################################################################
# APPLICATION DES PARAMETRES DANS LES TABLES TEMPORAIRES                                      #
###############################################################################################

#=====================================================================
$OUVR_APPL_TMP1
Return

#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1
 [F:TMP1]FLGMOD = G_NON
 [F:TMP1]FLGERR = G_NON
 Raz [F:TMP1]MSGERR

 # -------------------------------------------------------------------------------
 # - A reporter à l'identique dans MAS1_APPL_DIRT en utilisant la classe [F:MAS1]
 # -------------------------------------------------------------------------------
 Case [M:FASY]UPDTYP
   When GVML_IRNWDAT    : # DATE RENOUVELLEMENT
     # DEPREC période courante du plan gérant l'amortissement industriel
     Read [DEP] DEP0=[F:TMP1]OBJREF;G_CCNPLNIND;GFINEXECPF;GFINPERCPF
     # Flag forçage date de renouvellement
     [F:TMP1]RNWDATFLG = [M:FASY]RNWDATFLG
     # Date de renouvellement
     If ( [M:FASY]RNWDAT = [0/0/0] ) Then
       [F:TMP1]RNWDAT = [F:DEP]ENDDPRDAT
     Else
       [F:TMP1]RNWDAT = [M:FASY]RNWDAT
     Endif
     G_RNWDATN = [F:TMP1]RNWDAT

     # La date de renouvellement doit être  >= au début d'amortissement du plan gérant l'amortissement industriel.
     If ( [F:TMP1]RNWDAT < [F:DEP]STRDPRDAT ) Then
       [F:TMP1]FLGERR = G_OUI
       [F:TMP1]MSGERR = mess(697,GML_MSGFAS,1)
       RMES           = mess(697,GML_MSGFAS,1)
     Endif
   When GVML_IOCRFLG    : # OBLIGATION CONTRACTUELLE RENOUVELLEMENT
     # Le bien participe à une préparation de renouvellement en tant que bien à renouveler
     If ( [M:FASY]OBYRNWCON = G_OUI and [F:TMP1]OBYRNWCON <> G_OUI and func GLOCCN.RNW_ENCOURS([F:TMP1]CPY,[F:TMP1]FCY,[F:TMP1]OBJREF) = 3 ) Then
       [F:TMP1]FLGERR = G_OUI
       [F:TMP1]MSGERR = mess(749,GML_MSGFAS,1)
       RMES           = mess(749,GML_MSGFAS,1)
     Endif
     # Indicateur obligation contractuelle de renouvellement
     [F:TMP1]OBYRNWCON = [M:FASY]OBYRNWCON
   When GVML_ITPAFLG    : # REMIS CONTRE INDEMNITE
     # ????
     # Apport concédant, remise contre indemnité interdite (TAXCOEFLG en lieu et place de CCNETRNAT : débordement de TMPMASFAS)
     If ( [M:FASY]TPAFLG = G_OUI and [F:TMP1]TAXCOEFLG = GVML_NECONCD ) Then
       [F:TMP1]FLGERR = G_OUI
       [F:TMP1]MSGERR = mess(781,GML_MSGFAS,1)
       RMES           = mess(781,GML_MSGFAS,1)
     Endif
     # Indicateur remis contre indemnité
     [F:TMP1]TPAFLG = [M:FASY]TPAFLG
   When GVML_IACTCOD    : # CODE ACTUALISATION (FQ94077)
     # Pas de contrôle
     # Code actualisation
     [F:TMP1]CCNACTCOD = [M:FASY]CCNACTCOD
     G_CCNACTCODN      = [M:FASY]CCNACTCOD
 Endcase

 # Détermination de l'indicateur OER
 Read [DEP] DEP0=[F:TMP1]OBJREF;G_CCNPLNIND;GFINEXECPF;GFINPERCPF
 Read [CCN]CCN0=[F:TMP1]CCNREF
 Local Integer LRNWFLG
 Local Date    LRNWDAT
 If ( [F:TMP1]RNWDATFLG = G_OUI ) Then : LRNWDAT = [F:TMP1]RNWDAT : Else : LRNWDAT = [F:DEP]ENDDPRDAT : Endif
 Call CAL_DETERM_FLAG_OER ( "", GVML_TDCONCE, GVML_GCRNW, [F:TMP1]OBYRNWCON,
&                           [F:TMP1]TPAFLG, [F:CCN]ENDCCNDAT, LRNWDAT, LRNWFLG ) From GLOBB7
 [F:TMP1]RNWFLG = LRNWFLG

Return

#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire annexe (par plan)
$TPF1_APPL_TPF1
Return

#=====================================================================
# Unitaire / massif : Traitement de fin de boucle d'application des paramètres dans les tables temporaires
$END_APPL_TMP1
Return

###############################################################################################
# ALIMENTATION DES MASQUES DE LA TRANSACTION BIENS COMPTABLES AVEC LES INFOS DE SORTIE        #
###############################################################################################

#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TMP1_ALIM_MASK



  # Changement de méthode
  If ( [M:FASY]UPDTYP = GVML_ITPAFLG and [M:FAS6]TPAFLG <> [M:FASY]TPAFLG ) Then
    Local Char LDPM
    If ( [M:FASY]TPAFLG = G_OUI ) Then : LDPM = G_DPMSA : Else : LDPM = G_DPMRA : Endif
    If !clalev([F:FS2])  : Local File FXDASSETS  [FS2]  : Endif
    Read [FS2]FAS0= [M:FAS0]AASREF
    If !clalev([F:DP2])  : Local File DEPREC     [DP2]  : Endif
    Local Integer I_CAD : I_CAD = find(G_CCNPLNCAD,[M:FAS3]DPRPLN)
    Read [DP2]DEP0= [M:FAS0]AASREF;G_CCNPLNCAD;[M:FAS3]FIYENDDAT(I_CAD-1);[M:FAS3]PERENDDAT(I_CAD-1)
    Local Integer LCDRET
    #    ============
    Call FASMTC_SA_RA ("FS2", "DP2", LDPM, [0/0/0], G_NON, [F:DP2]PERSTRDAT, LCDRET) From TRTFAS
    #    ============
    If ( LCDRET > 0 ) Then : GOK= 0 : Return : Endif

    [M:FAS3]DPM       (I_CAD-1) = [F:DP2]DPM
    [M:FAS3]PRATYP    (I_CAD-1) = [F:DP2]PRATYP
    [M:FAS3]MTCDEVADJ (I_CAD-1) = [F:DP2]MTCDEVADJ
    [M:FAS3]MTCTIATYP (I_CAD-1) = [F:DP2]MTCTIATYP
    [M:FAS3]MTCTIADAT (I_CAD-1) = [F:DP2]MTCTIADAT
    [M:FAS3]MTCDEVADJ (I_CAD-1) = [F:DP2]MTCDEVADJ
  Endif

  Case [M:FASY]UPDTYP
    When GVML_IRNWDAT    : # DATE RENOUVELLEMENT
      # Flag forçage date de renouvellement
      [M:FAS6]RNWDATFLG = [M:FASY]RNWDATFLG
      # Date de renouvellement
      [M:FAS6]RNWDAT    = [M:FASY]RNWDAT
      G_RNWDATN         = [M:FASY]RNWDAT
    When GVML_IOCRFLG    : # OBLIGATION CONTRACTUELLE RENOUVELLEMENT
      # Indicateur obligation contractuelle de renouvellement
      [M:FAS6]OBYRNWCON = [M:FASY]OBYRNWCON
    When GVML_ITPAFLG    : # REMIS CONTRE INDEMNITE
      # Indicateur remis contre indemnité
      [M:FAS6]TPAFLG    = [M:FASY]TPAFLG
    When GVML_IACTCOD    : # CODE ACTUALISATION (FQ94077)
      # Code actualisation
      [M:FAS6]CCNACTCOD = [M:FASY]CCNACTCOD
  Endcase

  # Obligation effective de renouvellement
  [M:FAS6]RNWFLG = [F:TMP1]RNWFLG

  # Le bien est à recalculer
  [M:FAS0]FLGCLC                                     = G_OUI
  [M:FAS0]FLGCNXCLC(G300CPFI-1)                      = G_OUI
  [M:FAS0]FLGRPRCLC                                  = G_OUI
  [M:FAS3]DEPSTA(find(G_CCNPLNCAD,[M:FAS3]DPRPLN)-1) = GVML_SCNOCAL


  ACTMODIF=1
Return

#=====================================================================
# Unitaire : Permet de reporter les infos de TPF1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TPF1_ALIM_MASK
Return

#=====================================================================
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs
#            y ont été reportées.
REAF_ALIM_MASK
  Affzo [M:FAS3]
  Affzo [M:FAS6]
Return

###############################################################################################
# SORTIE OU ANNULATION DE SORTIE D UNE POPULATION DE BIENS COMPTABLES EN MISE A JOUR DIRECTE  #
###############################################################################################

#=====================================================================
# Massif : Sert à ouvrir des tables utilisées dans MAS1_APPL_MAS1
$OUVR_APPL_DIRT

Local Char    TRC_CPY   : Raz TRC_CPY  : # Société courante : rupture société pour émission en-tête trace
Local Date    LFIYENDDAT
Local Date    LPERSTRDAT
Local Date    LPERENDDAT
Local Integer LCCNPLNIND
Local Integer LCCNPLNCAD
Local Char    LCONTEXT

If !clalev([F:DEP])  : Local File DEPREC     [DEP]  : Endif
If !clalev([F:CCN])  : Local File CONCESSION [CCN]  : Endif
If !clalev([F:CNX])  : Local File CONTEXT    [CNX]  : Endif
If !clalev([F:FIS])  : Local File FISCYEAR   [FIS]  : Endif
If !clalev([F:FASZ]) : Local File FXDASSETS  [FASZ] : Endif

Return

#=====================================================================
# Massif : Application paramètres action aux tables de données : mise à jour directe
$MAS1_APPL_DIRT

#-----------------------------------------------
#         /!\ Attention /!\
# Si une modif est apportée dans ce traitement,
# il faut la reporter dans CCN_CHGRNWCON
#-----------------------------------------------


  # Approche optimiste
  GOK = 1

  #-> A rupture première société on émet un en-tête dans la trace
  If ( [F:MAS1]CPY <> TRC_CPY ) Then
    Call ECR_ENTETE([F:MAS1]CPY) From TRTFASCCN
    TRC_CPY = [F:MAS1]CPY

    # Récupération fin exercice et fin période de l'exercice courant du contexte fiscal & comptable
    Read [CNX]CNX0=[F:MAS1]CPY;G300CPFI
    If ( fstat ) Then : GOK= 0 : Return : Endif
    LCCNPLNIND = [F:CNX]CCNINDPLN
    LCCNPLNCAD = [F:CNX]CCNCADPLN
    Read [FIS]FIY1=[F:CNX]CPY;G300CPFI;GVML_TECOURA
    If ( fstat ) Then : GOK= 0 : Return : Endif
    LFIYENDDAT = [F:FIS]DATENDFIY
    LPERSTRDAT = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
    LPERENDDAT = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
  Endif


  # Valeurs Avant
  G_RNWFLGO    = [F:MAS1]RNWFLG
  G_RNWDATO    = [F:MAS1]RNWDAT
  G_RNWDATN    = [F:MAS1]RNWDAT
  G_RNWCONO    = [F:MAS1]OBYRNWCON
  G_TPAFLGO    = [F:MAS1]TPAFLG
  G_CCNACTCODO = [F:MAS1]CCNACTCOD : # FQ94077

  # Application des modifications sur le BCO en ligne dans [F:MAS1]
  Case [M:FASY]UPDTYP
    When GVML_IRNWDAT    : # DATE RENOUVELLEMENT
      # Flag forçage date de renouvellement
      [F:MAS1]RNWDATFLG = [M:FASY]RNWDATFLG

      # Date de renouvellement
      LCONTEXT = "CHGRNWDAT"
      # DEPREC de la période courante du plan gérant l'amortissement industriel
      Read [DEP]DEP0=[F:MAS1]AASREF;LCCNPLNIND;LFIYENDDAT;LPERENDDAT
      If ( [M:FASY]RNWDAT = [0/0/0] ) Then
        G_RNWDATN       = [F:DEP]ENDDPRDAT
        [F:MAS1]RNWDAT  = [F:DEP]ENDDPRDAT
      Else
        [F:MAS1]RNWDAT  = [M:FASY]RNWDAT
        G_RNWDATN       = [M:FASY]RNWDAT
      Endif

      # La date de renouvellement doit être  >= au début d'amortissement du plan gérant l'amortissment industriel.
      If ( G_RNWDATN < [F:DEP]STRDPRDAT ) Then
        NBCPYERR += 1
        RMES = mess(697,GML_MSGFAS,1)
        If ACTSILENCE=G_OUI
          G_MAJOK=G_NON
          GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
          GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
          GT_OBJ_DES(I_OBJ)="Error"-mess(697,GML_MSGFAS,1)
          I_OBJ+=1
        Else
          Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Erreur",RMES)  # Raf - mes
        Endif
        Raz RMES
        Return
      Endif

    When GVML_IOCRFLG    : # OBLIGATION CONTRACTUELLE RENOUVELLEMENT
      LCONTEXT = "CHGOCRFLG"
      # Le bien participe à une préparation de renouvellement en tant que bien à renouveler
      If ( [M:FASY]OBYRNWCON = G_OUI and [F:MAS1]OBYRNWCON <> G_OUI and func GLOCCN.RNW_ENCOURS([F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF) = 3 ) Then
        NBCPYERR += 1
        RMES = mess(749,GML_MSGFAS,1)
        If ACTSILENCE=G_OUI
          G_MAJOK=G_NON
          GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
          GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
          GT_OBJ_DES(I_OBJ)="Error"-mess(749,GML_MSGFAS,1)
          I_OBJ+=1
        Else
          Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Erreur",RMES)  # Raf - mes
        Endif
        Raz RMES
        Return
      Endif
      # Indicateur obligation contractuelle de renouvellement
      [F:MAS1]OBYRNWCON = [M:FASY]OBYRNWCON

    When GVML_ITPAFLG    : # REMIS CONTRE INDEMNITE
      LCONTEXT = "CHGTPAFLG"
      # Apport concédant, remise contre indemnité interdite
      If ( [M:FASY]TPAFLG = G_OUI and [F:MAS1]CCNETRNAT = GVML_NECONCD ) Then
        NBCPYERR += 1
        RMES = mess(781,GML_MSGFAS,1)
        If ACTSILENCE=G_OUI
          G_MAJOK=G_NON
          GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
          GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
          GT_OBJ_DES(I_OBJ)="Error"-mess(781,GML_MSGFAS,1)
          I_OBJ+=1
        Else
          Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Erreur",RMES)  # Raf - mes
        Endif
        Raz RMES
        Return
      Endif
      # Indicateur remis contre indemnité
      [F:MAS1]TPAFLG    = [M:FASY]TPAFLG

     When GVML_IACTCOD    : # CODE ACTUALISATION (FQ94077)
       LCONTEXT = ""
       # Code actualisation
       [F:MAS1]CCNACTCOD  = [M:FASY]CCNACTCOD
       G_CCNACTCODN       = [M:FASY]CCNACTCOD
      # Pas de contrôle.

  Endcase

  #-1 ------------------------------
  If ( FLGSIM <> G_OUI ) Then
    Read [DEP]DEP0=[F:MAS1]AASREF;LCCNPLNCAD;LFIYENDDAT;LPERENDDAT
    If ( fstat ) Then : GOK= 0 : Return : Endif

    If ( [M:FASY]UPDTYP = GVML_ITPAFLG and G_TPAFLGO <> [M:FASY]TPAFLG ) Then
      # Changement de méthode
      Local Char LDPM
      If ( [M:FASY]TPAFLG = G_OUI ) Then : LDPM = G_DPMSA : Else : LDPM = G_DPMRA : Endif
      Local Integer LCDRET
      #    ============
      Call FASMTC_SA_RA ("MAS1", "DEP", LDPM, [0/0/0], G_OUI, [F:DEP]PERSTRDAT, LCDRET) From TRTFAS
      #    ============
      If ( LCDRET > 0 ) Then : GOK= 0 : Return : Endif
    Endif

    # Mise à jour DEPREC  -> "DEPSTA"
    If ( [F:DEP]DEPSTA <> GVML_SCNOCAL ) Then : [F:DEP]DEPSTA = GVML_SCNOCAL : Endif

    Rewrite [F:DEP]
    If ( fstat ) Then : GOK= 0 : Return : Endif
  Endif
  #-1 ------------------------------
  # Détermination de l'indicateur OER
  Read [DEP] DEP0=[F:MAS1]AASREF;LCCNPLNIND;LFIYENDDAT;LPERENDDAT
  Read [CCN]CCN0=[F:MAS1]CCNREF
  Local Integer LRNWFLG

  Local Integer LOBYRNWCON
  Local Integer LTPAFLG
  Case [M:FASY]UPDTYP
    When GVML_IRNWDAT
      LOBYRNWCON = [F:MAS1]OBYRNWCON
      LTPAFLG    = [F:MAS1]TPAFLG
    When GVML_IOCRFLG
      LOBYRNWCON = [M:FASY]OBYRNWCON
      LTPAFLG    = [F:MAS1]TPAFLG
    When GVML_ITPAFLG
      LOBYRNWCON = [F:MAS1]OBYRNWCON
      LTPAFLG    = [M:FASY]TPAFLG
    When Default
      LOBYRNWCON = [F:MAS1]OBYRNWCON
      LTPAFLG    = [F:MAS1]TPAFLG
  Endcase

  Local Date    LRNWDAT
  If ( [F:MAS1]RNWDATFLG = G_OUI ) Then : LRNWDAT = [F:MAS1]RNWDAT : Else : LRNWDAT = [F:DEP]ENDDPRDAT : Endif
  Call CAL_DETERM_FLAG_OER ( LCONTEXT, GVML_TDCONCE, GVML_GCRNW, LOBYRNWCON,
&                            LTPAFLG, [F:CCN]ENDCCNDAT, LRNWDAT, LRNWFLG ) From GLOBB7
  [F:MAS1]RNWFLG = LRNWFLG


  # Mise à jour FXDASSETS
  #-1 ------------------------------
  If ( FLGSIM <> G_OUI ) Then
    # Le bien est à recalculer
    [F:MAS1]FLGCLC                = G_OUI
    [F:MAS1]FLGCNXCLC(G300CPFI-1) = G_OUI
    [F:MAS1]FLGRPRCLC             = G_OUI
    #-> Mise à jour du BCO en ligne dans [F:MAS1]
    #############
    Rewrite [MAS1]
    #############
    #-2 ------------------------------
    If fstat Then
      Case fstat
        When 1
          RMES=mess(226,GML_MSGFAS,1)-[F:MAS1]AASREF  : # "Enregistrement en cours d'utilisation"
          GOK=-1
        When 3
          RMES=mess(129,GML_MSGFAS,1)-[F:MAS1]AASREF  : # Tentative d'écriture en double de la clé :
          GOK=0
        When Default
      Endcase
      #> Emission erreur soit dans la trace soit dans des globales si action silencieuse
      If ACTSILENCE=G_OUI
        G_MAJOK=G_NON
        GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
        GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
        GT_OBJ_DES(I_OBJ)="Error"-RMES
        I_OBJ+=1
      Else
        Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Erreur",RMES)  # Raf - mes
      Endif

      # Remise à blanc de RMES
      Raz RMES
      Return
    Endif
    #-2 ------------------------------
  Endif
  #-1 ------------------------------

  # Génération d'événement
  #-1 ------------------------------
  If ( FLGSIM <> G_OUI ) Then
    # Classe utilisée dans l'alimentation des événements
    [F:FASZ]=[F:MAS1]
    #--------------------
    # Détermination G_RNWTRFCAD
    G_RNWTRFCAD = 0
    If ( [F:MAS1]RNWDONFLG = G_OUI ) Then
      # Bien renouvelé
      # Inidcateur "remis contre indemnité" modifié
      If (G_TPAFLGO <> [F:FASZ]TPAFLG) Then
        If !clalev([F:XDEP])  : Local File DEPREC     [XDEP]  : Endif
        Filter [XDEP] Where AASREF= [F:MAS1]AASREF and DPRPLN = G_CCNPLNCAD
        Read [XDEP]DEP0 First
        Filter [XDEP]
        G_RNWTRFCAD = [F:XDEP]TRFCADCUM
      Endif
    Endif
    #--------------------
    Local Integer LCDRET
    Call GENER_EVE(GVML_OMBIEN, [F:MAS1]CPY, [F:MAS1]FCY, [F:MAS1]AASREF, 0, "FASCCN",  LPERSTRDAT, [0/0/0], LCDRET) From GENEVE
    If (LCDRET > 20) Then
      GOK = 0
      If ( ACTSILENCE <> G_OUI ) Then
        Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1, mess(104,GML_MSGFAS,1)-" EFASCCN ", RMES)  # Raf - mes FQ64478
      Else
        ABANDON = G_OUI
        G_MAJOK = G_NON
        GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
        GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
        GT_OBJ_DES(I_OBJ)="Error"-mess(104,GML_MSGFAS,1)-"EFASCCN"
        I_OBJ += 1
      Endif
      # Remise à blanc de RMES
      Raz RMES
      Return
    Endif
  Endif
  #-1 ------------------------------

  # Ecriture d'une ligne dans la trace
  If ACTSILENCE=G_OUI
    G_MAJOK=G_OUI
    GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
    GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
    I_OBJ+=1
  Else
    Gosub ECR_LIGNE_DETAIL
  Endif

  # Incrément du compteur
  NBCPYMAJ+=1
  # Remise à blanc de RMES
  Raz RMES
Return

#=====================================================================
$END_APPL_DIRT

 Call SEP_COMPTE_RENDU([F:MAS1]CPY)
Return

#=====================================================================
$CLOS_APPL_DIRT
Return

###############################################################################################
# REPORT DU CONTENU DES TABLES TEMPORAIRES DANS LES TABLES METIERS                            #
###############################################################################################

#=====================================================================
$OUVR_ALIM_TABLE

Local Char    TRC_CPY   : Raz TRC_CPY  : # Société courante : rupture société pour émission en-tête trace
Local Date    LFIYENDDAT
Local Date    LPERSTRDAT
Local Date    LPERENDDAT
Local Integer LCCNPLNIND
Local Integer LCCNPLNCAD
Local Char    LCONTEXT

If !clalev([F:DEP])  : Local File DEPREC     [DEP]  : Endif
If !clalev([F:CCN])  : Local File CONCESSION [CCN]  : Endif
If !clalev([F:CNX])  : Local File CONTEXT    [CNX]  : Endif
If !clalev([F:FIS])  : Local File FISCYEAR   [FIS]  : Endif
If !clalev([F:FASZ]) : Local File FXDASSETS  [FASZ] : Endif


Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$TMP1_ALIM_TABLE

 # A ce niveau
 # Que l'on soit en massif ou en unitaire
 #   On dispose des globales ( une globale est définie au niveau de la cession et non pas du programme)
 #   On dispose toujours de la classe [F:TMP1] qui contient les informations modifiées et des informations cachées
 # En unitaire
 #   Le masque du bien a déjà été mis à jour avec les nouvelles valeurs
 #   On dispose de la classe [F:MAS1] avec les valeurs avant modification
 #   On y passe après le bouton enregistrer pour pouvoir générer éventuellement un événement.
 # En massif
 #   Le bien est à mettre à jour [F:MAS1]
 #   en utilisant [F:TMP1] alimentant la classe [F:MAS1]
 #   [F:MAS1] est mis à jour


  #-> A rupture première société on émet un en-tête dans la trace
  If ( [F:TMP1]CPY<>TRC_CPY ) Then
    If ( ACTTYPGES = GTAMMAS ) Then
      Call ECR_ENTETE([F:TMP1]CPY)
    Endif

    TRC_CPY=[F:TMP1]CPY
    # Récupération fin exercice et fin période de l'exercice courant du contexte fiscal & comptable
    Read [CNX]CNX0=[F:MAS1]CPY;G300CPFI
    If ( fstat ) Then : GOK= 0 : Return : Endif
    LCCNPLNIND = [F:CNX]CCNINDPLN
    LCCNPLNCAD = [F:CNX]CCNCADPLN
    Read [FIS]FIY1=[F:CNX]CPY;G300CPFI;GVML_TECOURA
    If ( fstat ) Then : GOK= 0 : Return : Endif
    LFIYENDDAT = [F:FIS]DATENDFIY
    LPERSTRDAT = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
    LPERENDDAT = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
  Endif


  # Avant
  G_RNWDATO = [F:TMP1]RNWDATO
  G_RNWDATN = [F:TMP1]RNWDATO
  G_RNWCONO = [F:MAS1]OBYRNWCON
  G_TPAFLGO = [F:MAS1]TPAFLG
  G_RNWFLGO = [F:MAS1]RNWFLG
  G_CCNACTCODO = [F:MAS1]CCNACTCOD : # FQ94077

  # Après
  # Application des modifications sur le BCO en ligne dans [F:MAS1]
  Case [M:FASY]UPDTYP
    When GVML_IRNWDAT    : # DATE RENOUVELLEMENT
      # Flag forçage date de renouvellement
      [F:MAS1]RNWDATFLG = [M:FASY]RNWDATFLG
      # Date de renouvellement
      LCONTEXT = "CHGRNWDAT"
      [F:MAS1]RNWDAT    = [F:TMP1]RNWDAT
      G_RNWDATN         = [F:TMP1]RNWDAT
    When GVML_IOCRFLG    : # OBLIGATION CONTRACTUELLE RENOUVELLEMENT
      # Indicateur obligation contractuelle de renouvellement
      LCONTEXT = "CHGRNWCON"
      [F:MAS1]OBYRNWCON = [M:FASY]OBYRNWCON
    When GVML_ITPAFLG    : # REMIS CONTRE INDEMNITE
      # Indicateur remis contre indemnité
      LCONTEXT = "CHTPAFLG"
      [F:MAS1]TPAFLG    = [M:FASY]TPAFLG
    When GVML_IACTCOD    : # CODE ACTUALISATION (FQ94077)
      # Code actualisation
      LCONTEXT = ""
      [F:MAS1]CCNACTCOD    = [M:FASY]CCNACTCOD
      G_CCNACTCODN         = [M:FASY]CCNACTCOD
  Endcase

  If ( ACTTYPGES = GTAMUNI or (ACTTYPGES = GTAMMAS and FLGSIM <> G_OUI)  ) Then
    Read [DEP]DEP0=[F:MAS1]AASREF;LCCNPLNCAD;LFIYENDDAT;LPERENDDAT
    If ( fstat ) Then : GOK= 0 : Return : Endif

    # Changement de méthode SA/RA
    If ( [M:FASY]UPDTYP = GVML_ITPAFLG and G_TPAFLGO <> [M:FASY]TPAFLG ) Then
      Local Char LDPM
      If ( [M:FASY]TPAFLG = G_OUI ) Then : LDPM = G_DPMSA : Else : LDPM = G_DPMRA : Endif
      Local Integer LCDRET
      Call FASMTC_SA_RA ("MAS1", "DEP", LDPM, [0/0/0], G_OUI, [F:DEP]PERSTRDAT, LCDRET) From TRTFAS
      If ( LCDRET > 0 ) Then :  GOK= 0 : Return : Endif
    Endif

    # Mise à jour DEPREC  -> "DEPSTA"
    If ( [F:DEP]DEPSTA <> GVML_SCNOCAL ) Then : [F:DEP]DEPSTA = GVML_SCNOCAL : Endif

    Rewrite [F:DEP]
    If ( fstat ) Then : GOK= 0 : Return : Endif
  Endif

  # Détermination de l'indicateur OER
  Read [DEP] DEP0=[F:MAS1]AASREF;LCCNPLNIND;LFIYENDDAT;LPERENDDAT
  Read [CCN]CCN0=[F:MAS1]CCNREF


  Local Integer LOBYRNWCON
  Local Integer LTPAFLG
  Case [M:FASY]UPDTYP
    When GVML_IRNWDAT
      LOBYRNWCON = [F:MAS1]OBYRNWCON
      LTPAFLG    = [F:MAS1]TPAFLG
    When GVML_IOCRFLG
      LOBYRNWCON = [M:FASY]OBYRNWCON
      LTPAFLG    = [F:MAS1]TPAFLG
    When GVML_ITPAFLG
      LOBYRNWCON = [F:MAS1]OBYRNWCON
      LTPAFLG    = [M:FASY]TPAFLG
    When Default
      LOBYRNWCON = [F:MAS1]OBYRNWCON
      LTPAFLG    = [F:MAS1]TPAFLG
  Endcase


  Local Integer LRNWFLG
  Local Date    LRNWDAT
  If ( [F:MAS1]RNWDATFLG = G_OUI ) Then : LRNWDAT = [F:MAS1]RNWDAT : Else : LRNWDAT = [F:DEP]ENDDPRDAT : Endif
  Call CAL_DETERM_FLAG_OER ( LCONTEXT, GVML_TDCONCE, GVML_GCRNW, LOBYRNWCON,
&                          LTPAFLG, [F:CCN]ENDCCNDAT, LRNWDAT, LRNWFLG ) From GLOBB7
  [F:MAS1]RNWFLG = LRNWFLG

  # Le bien est à recalculer
  [F:MAS1]FLGCLC                = G_OUI
  [F:MAS1]FLGCNXCLC(G300CPFI-1) = G_OUI
  [F:MAS1]FLGRPRCLC             = G_OUI

   # Génération de l'événement FASCCN
  #-1 ------------------------------
  If ( ACTTYPGES = GTAMUNI or (ACTTYPGES = GTAMMAS and FLGSIM <> G_OUI)  ) Then
    Local Integer LCDRET
    # Bien valeurs après :  Classe utilisée dans l'alimentation des événements
    [F:FASZ]=[F:MAS1]
    #--------------------
    # Détermination G_RNWTRFCAD
    G_RNWTRFCAD = 0
    If ( [F:MAS1]RNWDONFLG = G_OUI ) Then
      # Bien renouvelé
      # Inidcateur "remis contre indemnité" modifié
      If (G_TPAFLGO <> [F:FASZ]TPAFLG) Then
        If !clalev([F:XDEP])  : Local File DEPREC     [XDEP]  : Endif
        Filter [XDEP] Where AASREF= [F:MAS1]AASREF and DPRPLN = G_CCNPLNCAD
        Read [XDEP]DEP0 First
        Filter [XDEP]
        G_RNWTRFCAD = [F:XDEP]TRFCADCUM
      Endif
    Endif
    #--------------------
    Call GENER_EVE(GVML_OMBIEN, [F:FASZ]CPY, [F:FASZ]FCY, [F:FASZ]AASREF, 0, "FASCCN",  LPERSTRDAT, [0/0/0], LCDRET) From GENEVE
    If (LCDRET > 20) Then
      GOK = 0
      Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1, mess(104,GML_MSGFAS,1)-" EFASCCN ", RMES)  # Raf - mes FQ64478
      # Remise à blanc de RMES
      Raz RMES
      Return
    Endif
  Endif
  #-1 ------------------------------

  # Ecriture d'une ligne dans la trace
  If ( ACTTYPGES = GTAMMAS ) Then
    Gosub ECR_LIGNE_DETAIL
  Endif

  # Incrément du compteur
  NBCPYMAJ+=1
  # Remise à blanc de RMES
  Raz RMES


Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$TPF1_ALIM_TABLE
Return

#=====================================================================
# Unitaire / massif : Fin du report tmp -> données
$END_ALIM_TABLE
Return

#=====================================================================
# Unitaire / massif : Fermeture de table annexes pour le report tmp -> données
$CLOS_ALIM_TABLE
Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$VISU_LOAD_PLAN
Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$VISU_SAVE_PLAN
Return


######################################################################
# Points d'entrée objet de reprise
######################################################################
#{ET_REP}#
#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================

$MFS_LIENS0
Return

#=====================================================================
$MFS_LIENS
Return

#=====================================================================
MFS_LIENS2
Return

#=====================================================================
MFS_INICRE
Return

#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================

#==============================================================#
# Cette action est appelée pour chaque enregistrement lu dans  #
# la table temporaire par plan pour l'objet métier sur lequel  #
# on vient de cliquer.                                         #
# Alimenter ici les zones du tableau par plan spécifique à l'  #
# action                                                       #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#

$LOADPLN
Return

#==============================================================#
# Cette action est appelée pour chaque enregistrement de la    #
# table temporaire à mettre à jour.                            #
# Alimenter ici les zones spécifiques à l'action de la table   #
# temporaire par plan à partir des zones du tableau par plan   #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#

$SAVEPLN
Return

################################################################################
# Traitement de gestion de la trace - informations particulières à l'action    #
################################################################################
#{ET_GESTRACE}#
$GESTRACE

  Case TRTYP
    When 1         # Ouverture de la trace
      If ( ACTSILENCE <> G_OUI ) Then
        If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA] : Endif
        Call OUVRE_TRACE(toupper(mess(773,GML_MSGFAS,1)),1) From TRACEABX3
      Endif
    When 20        # Paramètres de l'action
      If ACTSILENCE<>G_OUI
        # Type de mise à jour
        Call  ECR_TRACE("",GTRC_PARAM,left$(mess(758,GML_MSGFAS,1)+space$(35),35)+":"-mess([M:FASY]UPDTYP,488,1),0,1) From TRACEABX3
        Case [M:FASY]UPDTYP
          When GVML_IRNWDAT    : # Date de renouvellement
            Call  ECR_TRACE("",GTRC_PARAM,left$(mess(759,GML_MSGFAS,1)+space$(35),35)+":"-num$([M:FASY]RNWDAT),0,1) From TRACEABX3
          When GVML_IOCRFLG    : # Obligation renouvellement
            Call  ECR_TRACE("",GTRC_PARAM,left$(mess(760,GML_MSGFAS,1)+space$(35),35)+":"-mess([M:FASY]OBYRNWCON,1,1),0,1) From TRACEABX3
          When GVML_ITPAFLG    : # Remis contre indemnité
            Call  ECR_TRACE("",GTRC_PARAM,left$(mess(761,GML_MSGFAS,1)+space$(35),35)+":"-mess([M:FASY]TPAFLG,1,1),0,1) From TRACEABX3
          When GVML_IACTCOD    : # Code actualisation (FQ94077)
            Call  ECR_TRACE("",GTRC_PARAM,left$(mess(935,GML_MSGFAS,1)+space$(35),35)+":"-[M:FASY]CCNACTCOD,0,1) From TRACEABX3
        Endcase
        # Motif
        Call  ECR_TRACE("",GTRC_PARAM,left$(mess(762,GML_MSGFAS,1)+space$(35),35)+":"-[M:FASY]REN,0,1) From TRACEABX3
        Call ECR_TRACE("",GTRC_PARAM,"",0,1) From TRACEABX3
      Endif
    When Default
  Endcase
Return

######################################################################
# Sous-programmes communs
######################################################################


#--------------------------------------------------------------#
# Emission de l'en-tête du tableau de compte-rendu dans la     #
# trace                                                        #
#--------------------------------------------------------------#
Subprog ECR_ENTETE(PCPY)    #
Value Char PCPY

  Local Char LINE(115)
  If ACTSILENCE=G_OUI : End : Endif

  If ( FLGDET = G_OUI ) Then
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,"",0,1) From TRACEABX3
    LINE =string$(115,"=") : Call ECR_TRACE(PCPY,GTRC_CRACTIO,LINE,0,1) From TRACEABX3
    LINE  = left$( mess(2,341,1)                  + string$(22,' '), 22)+"! "
    # Désignation
    LINE += left$( mess(763,GML_MSGFAS,1)                + string$(37,' '), 37)+"! "

    Case [M:FASY]UPDTYP
      When GVML_IRNWDAT    : # Date de renouvellement
        LINE += left$( mess(759,GML_MSGFAS,1)      + string$(24,' '), 24)+"!"
      When GVML_IOCRFLG    : # Obli. contract. renouv.
        LINE += left$( mess(760,GML_MSGFAS,1)      + string$(24,' '), 24)+"!"
      When GVML_ITPAFLG    : # Remis contre indemnité
        LINE += left$( mess(765,GML_MSGFAS,1)      + string$(24,' '), 24)+"!"
      When GVML_IACTCOD    : # Code actualisation (FQ94077)
        LINE += left$( mess(935,GML_MSGFAS,1)      + string$(24,' '), 24)+"!"
    Endcase
    # Obli. effect.  renouv.
        LINE += left$( mess(766,GML_MSGFAS,1)      + string$(24,' '), 24)+"!"

    Call ECR_TRACE(PCPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3

    LINE  = left$( " "                            + string$(61,' '), 61)+"! "
    Case [M:FASY]UPDTYP
      When GVML_IRNWDAT    : # DATE RENOUVELLEMENT
        LINE += left$( mess(767,GML_MSGFAS,1)                      + string$(10,' '), 10)+" ! "
        LINE += left$( mess(768,GML_MSGFAS,1)                      + string$(10,' '), 10)+" ! "
      When GVML_IOCRFLG    : # OBLIGATION CONTRACTUELLE RENOUVELLEMENT
        LINE += left$( mess(767,GML_MSGFAS,1)                       + string$(10,' '), 10)+" ! "
        LINE += left$( mess(768,GML_MSGFAS,1)                       + string$(10,' '), 10)+" ! "
      When GVML_ITPAFLG    : # REMIS CONTRE INDEMNITE
        LINE += left$( mess(767,GML_MSGFAS,1)                       + string$(10,' '), 10)+"!"
        LINE += left$( mess(768,GML_MSGFAS,1)                       + string$(10,' '), 10)+"   ! "
      When GVML_IACTCOD    : # CODE ACTUALISATION (FQ94077)
        LINE += left$( mess(767,GML_MSGFAS,1)                       + string$(10,' '), 10)+"!"
        LINE += left$( mess(768,GML_MSGFAS,1)                       + string$(10,' '), 10)+"   ! "
    Endcase
    LINE += left$( mess(767,GML_MSGFAS,1)                       + string$(10,' '), 10)+"! "
    LINE += left$( mess(768,GML_MSGFAS,1)                       + string$(10,' '), 10)+" !"

    Call ECR_TRACE(PCPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3



    LINE =string$(115,"=") : Call ECR_TRACE(PCPY,GTRC_CRACTIO,LINE,0,1) From TRACEABX3
  Endif
End

#--------------------------------------------------------------#
# Emission d'une ligne détail dans la trace                    #
#--------------------------------------------------------------#
$ECR_LIGNE_DETAIL

  If ACTSILENCE=G_OUI : End : Endif

  If ( FLGDET = G_OUI ) Then
    Local Char LINE(115)
    Case [M:FASY]UPDTYP
      When GVML_IRNWDAT    : # DATE RENOUVELLEMENT
        LINE += left$( num$(G_RNWDATO)             + string$(10,' '), 10) +" ! "
        LINE += left$( num$(G_RNWDATN)             + string$(10,' '), 10) +" ! "
      When GVML_IOCRFLG    : # OBLIGATION CONTRACTUELLE RENOUVELLEMENT
        LINE += left$( mess(G_RNWCONO,1,1)         + string$(10,' '), 10) +" ! "
        LINE += left$( mess([F:MAS1]OBYRNWCON,1,1) + string$(10,' '), 10) +" ! "
      When GVML_ITPAFLG    : # REMIS CONTRE INDEMNITE
        LINE += left$( mess(G_TPAFLGO,1,1)         + string$(10,' '), 10) +" ! "
        LINE += left$( mess([F:MAS1]TPAFLG,1,1)    + string$(10,' '), 10) +" ! "
      When GVML_IACTCOD    : # CODE ACTUALISATION (FQ94077)
        LINE += left$( G_CCNACTCODO                + string$(10,' '), 10) +" ! "
        LINE += left$( [F:MAS1]CCNACTCOD           + string$(10,' '), 10) +" ! "
    Endcase
    LINE += left$( mess(G_RNWFLGO,1,1)         + string$(10,' '), 10) +"! "
    LINE += left$( mess([F:MAS1]RNWFLG,1,1)    + string$(10,' '), 10) +" !"
    Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Ok",LINE)
  Endif

Return

#--------------------------------------------------------------#
# Emission de la ligne  référence BCO / désignation dans la    #
# trace                                                        #
#--------------------------------------------------------------#
Subprog BCO_COMPTE_RENDU(PCPY,PREF,PDES,PSTATUS,PMES)
Value Char PCPY
Value Char PREF
Value Char PDES
Value Char PSTATUS
Value Char PMES

  If ACTSILENCE=G_OUI : End : Endif

  Local Char LIGNE(115)
  LIGNE =" "
  LIGNE+=left$( PREF + string$(20,' '), 20) + " ! "
  If (PSTATUS = "Ok") Then
  LIGNE+=left$( PDES + string$(36,' '), 36)+ " ! "
  Endif
  LIGNE-=left$( PMES + string$(115,' '), 115)
  If ( PSTATUS="Ok" ) Then
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  Elsif PSTATUS="Erreur"
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,1,1) From TRACEABX3
  Endif
End

#--------------------------------------------------------------#
# Emission d'un séparateur dans la trace                       #
#--------------------------------------------------------------#
Subprog SEP_COMPTE_RENDU(PCPY)

Value Char PCPY

  If ACTSILENCE=G_OUI : End : Endif

  Local Char LIGNE(115)

  LIGNE="-------------------------------------------------------------------------------------------------------------------"
  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
End


#--------------------------------------------------------------#
# S/P de lancement de l'action (Développement)                 #
#--------------------------------------------------------------#
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

  Case PACTTYP
    When GTAMUNI
      Raz GPILOBJ
      Call DEFVAR From GLOBIMM
      Call INIVAR From GLOBIMM
      Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
    When GTAMMAS
      Local Char PARAM(30)(1..5)
      Local Char VALEUR
      PARAM(1)="M"               # Massif / unitaire
      PARAM(2)="FASCCN"          # Nom de l'action métier
      PARAM(3)=num$(GVML_OMBIEN) # Objet métier de référence
      PARAM(4)=num$(G_OUI)       # Mono société
      PARAM(5)=num$(G_NON)       # Plan d'amortissement
      Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASCCN","FASCCNM",4,"") From GTRAITE
    When Default
  Endcase
End

