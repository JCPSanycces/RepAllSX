#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet ORP
######################################################################################
######################################################################################
$ACTION
Case ACTION
 When "RAZCRE"        : Gosub RAZCRE
 When Default
Endcase
Return


######################################################################################
$RAZCRE
[M]GRUBOMFLG=2 : Affzo [M]GRUBOMFLG
Return
######################################################################################

# Issue 98932 - 2014-07-04 by RBA : Volumes managment evolution
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1)
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]VOLFILISS
 Raz [M]DRTISS
 Grizo [M]VOLFILISS
 Raz [M]VOLFILRCP
 Raz [M]DRTRCP
 Grizo [M]VOLFILRCP
 Raz [M]VOLFILSTO
 Raz [M]DRTSTO
 Grizo [M]VOLFILSTO
Else
 Actzo [M]VOLFILISS
 Actzo [M]VOLFILRCP
 Actzo [M]VOLFILSTO
Endif
Affzo [M]VOLFILISS
Affzo [M]VOLFILRCP
Affzo [M]VOLFILSTO
End

Subprog C_VOLFILRCP(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTRCP,E_TYPE_FOLDER,GMESSAGE)
End

Subprog C_VOLFILSTO(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTSTO,E_TYPE_FOLDER,GMESSAGE)
End

Subprog C_VOLFILISS(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTISS,E_TYPE_FOLDER,GMESSAGE)
End
#/ Issue 98932 - 2014-07-04 by RBA : Volumes managment evolution
