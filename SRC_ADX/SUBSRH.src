##########################################################################
# -------------------------------------- SAU ------------------------
########################################
Subprog AS_SAU(VALEUR)
Variable Char    VALEUR()
# L'unité est saisissable ssi ligne directe en cours de création
#If [M]DETSDHNUM(nolign-1) <> "" | [M]UPDFLG(nolign-1) <> 0 mkstat = 2 Endif
# L'unité est saisissable ssi ligne en cours de création
#If [M]CREFLG(nolign-1) <> 0 mkstat = 2 Endif

#LSE 05/12/2006 FQ38520
Local Integer NOL : NOL=nolign-1
If [F:ITM]ITMREF <> [M:SRH1]ITMREF(NOL)
    Read [ITM]ITM0=[M:SRH1]ITMREF(NOL)
    If fstat Raz [F:ITM] Endif
Endif
If [F:ITM]HDKITMTYP=5
    mkstat=2
Endif

End
#########################################################################
Subprog C_SAU(VALEUR)
Variable Char    VALEUR()

Local Integer NOL    :    NOL = nolign-1
Local Decimal WQTY, WCOEF
# CTLUOM : ctrle l'unité et ramène aussi le coef de conversion
# Ne pas le faire systématiquement pour ne pas écraser le coef s'il avait été modifié
If VALEUR <> [M:SRH1]SAU(NOL) | GIMPORT
    # Recherche du nouveau coefficient UV-US
    WCOEF=1
    If VALEUR<>[M:SRH1]STU(NOL)
        Call CTLUOM([M:SRH1]ITMREF(NOL),2,[M:SRH0]BPCORD,VALEUR,WCOEF,GBIDC1,GBIDC2,
&                   [M:SRH1]DACSAUCOE(NOL)) From STKACT
        If mkstat=2 End Endif
    Endif
    # Conversion de la qté retour saisie dans la nouvelle unité
    If [M:SRH1]QTY(NOL) <> 0
        If VALEUR=[M:SRH1]STU(NOL)
            [M:SRH1]QTY(NOL)=[M:SRH1]QTYSTU(NOL)
        Else
            # Pour faire la conversion on repart de la qté en US
            WQTY=[M:SRH1]QTYSTU(NOL)/WCOEF
            Call QTEARR(WQTY, VALEUR) From TRTDIV
            [M:SRH1]QTY(NOL)=WQTY
        Endif
    Endif
    # Conversion de la qté retour prévue saisie dans la nouvelle unité
    If [M:SRH1]EXTQTY(NOL) <> 0
        If VALEUR=[M:SRH1]STU(NOL)
            [M:SRH1]EXTQTY(NOL)=[M:SRH1]EXTQTYSTU(NOL)
        Else
            # Pour faire la conversion on repart de la qté en US
            WQTY=[M:SRH1]EXTQTYSTU(NOL)/WCOEF
            Call QTEARR(WQTY, VALEUR) From TRTDIV
            [M:SRH1]EXTQTY(NOL)=WQTY
        Endif
    Endif
    # Conversion de la qté livrée dans la nouvelle unité
    If [M:SRH1]DLVQTY(NOL) <> 0
        If VALEUR=[M:SRH1]STU(NOL)
            [M:SRH1]DLVQTY(NOL)=[M:SRH1]DLVQTYSTU(NOL)
        Else
            # Pour faire la conversion on repart de la qté en US
            WQTY=[M:SRH1]DLVQTYSTU(NOL)/WCOEF
            Call QTEARR(WQTY, VALEUR) From TRTDIV
            [M:SRH1]DLVQTY(NOL)=WQTY
        Endif
    Endif
    # Convertion des prix dans la nouvelle unité
    Gosub CONV_PRIX
    [M:SRH1]SAUSTUCOE(NOL) = WCOEF
    Affzo [M:SRH1]SAUSTUCOE(NOL), EXTQTY(NOL), QTY(NOL), DLVQTY(NOL)
    If [M:SRH1]DACSAUCOE(NOL) < 2
        Diszo [M:SRH1]SAUSTUCOE(NOL)
    Else
        Actzo [M:SRH1]SAUSTUCOE(NOL)
    Endif
Endif
End
# ----------------------------------------------------------------------------- *
# Conversion des prix lors d'un changement d'unité ou de coef. conversion UV-US
# ----------------------------------------------------------------------------- *
$CONV_PRIX
# Convertion des prix dans la nouvelle unité
If [M:SRH1]NETPRINOT(NOL)<>0
    Local Decimal WPRIX
    # --> Conversion des prix
    WPRIX=([M:SRH1]NETPRINOT(NOL)/[M:SRH1]SAUSTUCOE(NOL))*WCOEF
    WPRIX=arr(WPRIX,10^-GDECPRI)
    [M:SRH1]NETPRINOT(NOL)=WPRIX
    WPRIX=([M:SRH1]NETPRIATI(NOL)/[M:SRH1]SAUSTUCOE(NOL))*WCOEF
    WPRIX=arr(WPRIX,10^-GDECPRI)
    [M:SRH1]NETPRIATI(NOL)=WPRIX
    WPRIX=([M:SRH1]NETPRI(NOL)/[M:SRH1]SAUSTUCOE(NOL))*WCOEF
    WPRIX=arr(WPRIX,10^-GDECPRI)
    [M:SRH1]NETPRI(NOL)=WPRIX
    Affzo [M:SRH1]NETPRI(NOL)
Endif
Return
########################################
Subprog AM_SAU(VALEUR)
Variable Char    VALEUR()
#Affzo [M:SRH1]SAUSTUCOE(nolign-1)
#If [M]DACSAUCOE(nolign-1) < 2
#    Diszo [M]SAUSTUCOE(nolign-1)
#Else
#    Actzo [M]SAUSTUCOE(nolign-1)
#Endif
End
# -------------------------------------- EXTQTY ------------------------
########################################
Subprog C_EXTQTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL    : NOL = nolign-1
Local    Decimal WCOEF
Local    Decimal WEXTQTY, WDLV_EXTQTYSTU, WPND_EXTQTYSTU


# -- Quantité retour remise à zéro ?
If   [M]CREFLG(NOL)<>0 & [M]UPDFLG(NOL)<>0 & VALEUR = 0 & [M]QTY(NOL) = 0
    GMESSAGE = mess(83,123,1) : mkstat = 2 : End
Endif
# -- Si retour sur une ligne de livraison : Quantité retour prévue > quantité livrée ?
If [M]DETSDHNUM(NOL) <> ""
    # -- Calcul qté retour prévue en US pour la ligne de livraison
    WEXTQTY = VALEUR : WCOEF=[M]SAUSTUCOE(NOL) : Gosub CALC_DLV_EXTQTYSTU
# Bug 67067
#    If   [M]DLVQTYSTU(NOL) - WDLV_EXTQTYSTU < 0  GMESSAGE = mess(63,192,1) : mkstat = 2 : End : Endif
    If   [M]DLVQTYSTU(NOL) - WDLV_EXTQTYSTU < 0
        Local Integer OK : OK=1
        Call AVERTIR (mess(63,192,1), OK) From GESECRAN
        If OK=1 mkstat=2 : End : Endif
    Endif
#--CPO 81158 Le contrôle sur la qté réceptionnée se fait uniquement si on picke une livraison inter-sites
#--et dans ce cas [M]PNHNUM doit être vide (si renseigné => on est en pick de retour fss)
##    If [M]PNHNUM(NOL) = ""
#    If [M]PNHNUM(NOL) <> ""
## Bug 67067
    If [M]PNHNUM(NOL) = ""
#--/CPO
        #--CPO 107417 Seulement en inter-sites, et si la ligne de livraison contient une quantité déjà réceptionnées
        If find(2,[M]BETFCY,[M]BETCPY)>0 and [M]RCPQTYSTU(NOL)>0
        #--/
          # La qté retournée ne doit pas être réceptionnée (passer dans ce cas par le picking retour fsseur)
          If [M]DLVQTYSTU(NOL)-WDLV_EXTQTYSTU-[M]RCPQTYSTU(NOL)<0  GMESSAGE=mess(282,192,1)-"\"-mess(150,191,1) : mkstat = 2 : End : Endif
        Endif
    Endif
# -- Si retour issu retour fournisseur    : Quantité retour > quantité retournée ?
Elsif [M]PNHNUM(NOL) <> ""
    # -- Calcul qté retour prévue en US pour la ligne de retour fournisseur
    WEXTQTY = VALEUR : WCOEF=[M]SAUSTUCOE(NOL) : Gosub CALC_PND_EXTQTYSTU
    If [M]PNDQTYSTU(NOL) - WPND_EXTQTYSTU < 0 GMESSAGE = mess(283,192,1) : mkstat = 2 : End : Endif
Endif
# -- Quantité prévue inférieure à quantité retour ?
If  (VALEUR <> 0 & [M]QTY(NOL) <> 0) & VALEUR < [M]QTY(NOL)
      Local Integer OK : OK=1
      Call AVERTIR (mess(84,192,1), OK) From GESECRAN
      If OK=1 mkstat=2 : End : Endif
Endif
End

# --------------------------------------------------------- #
# Calcul qté retour prévue en US pour la ligne de livraison #
# --------------------------------------------------------- #
$CALC_DLV_EXTQTYSTU
Local Integer I
Local Decimal WEXTQTYSTU

Raz WDLV_EXTQTYSTU
# -- Calcul qté retour prévue en US pour la ligne de livraison
For  I = 0 To [M:SRH1]NBLIG -1
    If [M]DETSDHNUM(I) = [M]DETSDHNUM(NOL) & [M]SDDLIN(I) = [M]SDDLIN(NOL)
        WDLV_EXTQTYSTU += [M]EXTQTYSTU(I) - [M]XEXTQTYSTU(I)
    Endif
Next I
WDLV_EXTQTYSTU -= [M]EXTQTYSTU(NOL) - [M]XEXTQTYSTU(NOL)

If [M]SAU(NOL)<>[M]STU(NOL)
    Call CNVQTY(WEXTQTY,WCOEF,[M]STU(NOL), WEXTQTYSTU) From TRTVENQTE
Else
    WEXTQTYSTU=WEXTQTY
Endif
WDLV_EXTQTYSTU += WEXTQTYSTU - [M]XEXTQTYSTU(NOL)

Return
# ------------------------------------------------------------- #
# Calcul qté retour prévue en US pour la ligne de retour fsseur #
# ------------------------------------------------------------- #
$CALC_PND_EXTQTYSTU
Local Integer I
Local Decimal WEXTQTYSTU

# -- Calcul qté retour prévue en US pour la ligne de retour fsseur
Raz WPND_EXTQTYSTU
For  I = 0 To [M:SRH1]NBLIG -1
    If [M]PNHNUM(I) = [M]PNHNUM(NOL) & [M]PNDLIN(I) = [M]PNDLIN(NOL)
        WPND_EXTQTYSTU += [M]EXTQTYSTU(I) - [M]XEXTQTYSTU(I)
    Endif
Next I
WPND_EXTQTYSTU -= [M]EXTQTYSTU(NOL) - [M]XEXTQTYSTU(NOL)
If [M]SAU(NOL)<>[M]STU(NOL)
    Call CNVQTY(WEXTQTY,WCOEF,[M]STU(NOL),WEXTQTYSTU) From TRTVENQTE
Else
    WEXTQTYSTU=WEXTQTY
Endif
WPND_EXTQTYSTU += WEXTQTYSTU - [M]XEXTQTYSTU(NOL)
Return

#########################################
Subprog AM_EXTQTY(VALEUR)
Variable Decimal VALEUR
Local Integer NOL : NOL=nolign-1

# Si modif. de la qté retour prévue, on réinitialise la qté retour si elle n'a été raz
If [M]EXTQTY(NOL) = [M]QTY(NOL) & [M]QTY(NOL) <> 0 & VALEUR <> 0

    # X3-80406 - if non-conformance exist, check if user wishes to modify
    If func AFNC.ACTIV ("NCS")
        Local Integer LOK
        Local Integer EXISTS
        Local Char NCSMESS(255)
        [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (2, [M:SRH0]SRHNUM, [M:SRH1]SRDLIN(NOL), [L]NCSMESS,0)
        # check if user wishes to continue
        If (EXISTS > 0)
            Call OUINON([L]NCSMESS,LOK) From GESECRAN
            If LOK = 1
                GMESSAGE = ""
                GERR = 1
                mkstat = 2
                End
            Endif
        Endif
    Endif
    # X3-80406 - end

    [M]QTY(NOL) = VALEUR
    # -- calcul quantité en US
    Call CNVQTY([M]QTY(NOL),[M]SAUSTUCOE(NOL),[M]STU(NOL), [M]QTYSTU(NOL)) From TRTVENQTE
    # -- alimentation du déduit facture

    # X3-68815_Return_of_nonbillable_deliveries (LC- 18/01/18)
    If !clalev([SDH]): Local File SDELIVERY: Endif
    Raz [F:SDH]
    If [M]DETSDHNUM(NOL)<>""
      Read [F:SDH]SDH0=[M]DETSDHNUM(NOL)
    Endif
    If [F:SDH]SDHCAT<>4
    # End X3-68815_Return_of_nonbillable_deliveries (LC- 18/01/18)
      If [M]XQTY(NOL) = 0 & [M]QTY(NOL) <> 0
         [M]RTNINVUPD(NOL) = 1
         If [M]DETSDHNUM(NOL) <> "" & [M]SIHNUMFAC(NOL) = ""
#            [M]RTNINVUPD(NOL) = 2
            If GDLVRTNCNO=1
               # Pas d'avoir si la livraison n'est pas facturée, ce sera déduit de la facture
               [M]RTNCNOFLG(NOL) = 1
               [M]RTNINVUPD(NOL) = 2
            Else
               # Avoir si la livraison n'est pas facturée, ce ne sera pas déduit de la facture
               [M]RTNCNOFLG(NOL) = 2
               [M]RTNINVUPD(NOL) = 1
            Endif
         Endif
      Endif
    Endif # X3-68815_Return_of_nonbillable_deliveries (LC- 18/01/18)
    Affzo [M]RTNINVUPD(NOL), RTNCNOFLG(NOL)
    Affzo [M]QTY(nolign-1)

Endif
End
# -------------------------------------- QTY ------------------------
########################################
Subprog AS_QTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL    :    NOL = nolign-1
Local    Integer OK

# --> Si ligne gérée en stock, plus de modif. quantité une fois la ligne créé
#If [M]RTNSTOUPD(NOL)=2 & [M]CREFLG(NOL)<>0 mkstat = 2 : End : Endif
# --> Avertissement si ligne existait et maj cde déjà effectuée
If [M]CREFLG(NOL) <> 0 & [M]ORDUPD(NOL) = 2
   Call OUINON(mess(74,192,1)+"\"+mess(108,192,1)+"\"+mess(205,100,1), OK) From GESECRAN
   If   OK = 1 : mkstat = 2 : Endif
Endif
End

########################################
Subprog C_QTY(VALEUR)
Variable Decimal VALEUR

Local    Integer NOL    : NOL = nolign-1
Local    Decimal WCOEF
Local    Decimal WQTY, WDLV_QTYSTU, WPND_QTYSTU

# BRBAN 01/09/2014 #93745
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY,'')=1 & VALEUR = 0
  GMESSAGE = mess(83,123,1) : mkstat = 2 : End
Endif
#-

# -- Quantité retour remise à zéro : Valeur incorrecte
If VALEUR = 0 & [M]EXTQTY(NOL) = 0
    GMESSAGE = mess(83,123,1) : mkstat = 2 : End
Endif

#--- X3Suivi 82377 : Err mess sur retour client ---#
# -- Si retour issu retour fournisseur    : Quantité retour > quantité retournée ?
If [M]PNHNUM(NOL) <> ""
    #--- Calcul qté retour prévue en US pour la ligne de retour fournisseur --#
    WQTY = VALEUR : WCOEF=[M]SAUSTUCOE(NOL) : Gosub CALC_PND_QTYSTU
    If [M]PNDQTYSTU(NOL) - WPND_QTYSTU < 0
      GMESSAGE = mess(275,192,1) : mkstat = 2 : End : #-- Quantité retour > quantité du retour fournisseur
    Endif

#--- Si retour issu livraison  : Quantité retour > quantité livrée ?
Elsif [M]DETSDHNUM(NOL) <> ""
    # -- Calcul qté retour prévue en US pour la ligne de livraison --> WDLV_QTYSTU
    WQTY = VALEUR : WCOEF=[M]SAUSTUCOE(NOL) : Gosub CALC_DLV_QTYSTU

    If [M]DLVQTYSTU(NOL) - WDLV_QTYSTU < 0
        Local Integer OK : OK=1
        Call AVERTIR (mess(64,192,1), OK) From GESECRAN : #-- Quantité retour > Quantité livrée
        If OK=1 Raz GMESSAGE : mkstat=2 : End : Endif
    Endif

    #If [M]PNHNUM(NOL) = ""
    #    # La qté retournée ne doit pas être réceptionnée (passer dans ce cas par le picking retour fsseur)
    #    If [M]DLVQTYSTU(NOL)-WDLV_QTYSTU-[M]RCPQTYSTU(NOL)<0  GMESSAGE=mess(282,192,1)-"\"-mess(150,191,1) : mkstat = 2 : End : Endif
    #Endif

Endif

#--- Quantité retour > quantité prévue ?
If   [M]EXTQTY(NOL)<>0 & VALEUR > [M]EXTQTY(NOL)
    Local Integer OK : OK=1
    Call AVERTIR (mess(84,192,1), OK) From GESECRAN
    If OK=1 Raz GMESSAGE : mkstat=2 : End : Endif
Endif

End

# --------------------------------------------------------- #
# Calcul qté retour en US pour la ligne de livraison        #
# --------------------------------------------------------- #
$CALC_DLV_QTYSTU
Local Integer I
Local Decimal WQTYSTU

# -- Calcul qté retour en US pour la ligne de livraison
Raz WDLV_QTYSTU
For  I = 0 To [M:SRH1]NBLIG -1
    If [M]DETSDHNUM(I) = [M]DETSDHNUM(NOL) & [M]SDDLIN(I) = [M]SDDLIN(NOL)
        WDLV_QTYSTU += [M]QTYSTU(I) - [M]XQTYSTU(I)
    Endif
Next I
WDLV_QTYSTU -= [M]QTYSTU(NOL) - [M]XQTYSTU(NOL)
If [M]SAU(NOL)<>[M]STU(NOL)
    Call CNVQTY(WQTY,WCOEF,[M]STU(NOL),WQTYSTU) From TRTVENQTE
Else
    WQTYSTU=WQTY
Endif
WDLV_QTYSTU += WQTYSTU - [M]XQTYSTU(NOL)
Return
# --------------------------------------------------------- #
# Calcul qté retour en US pour la ligne de retour fsseur    #
# --------------------------------------------------------- #
$CALC_PND_QTYSTU
Local Integer I
Local Decimal WQTYSTU

# -- Calcul qté retour en US pour la ligne de retour fsseur
Raz WPND_QTYSTU
For  I = 0 To [M:SRH1]NBLIG -1
    If [M]PNHNUM(I) = [M]PNHNUM(NOL) & [M]PNDLIN(I) = [M]PNDLIN(NOL)
        WPND_QTYSTU += [M]QTYSTU(I) - [M]XQTYSTU(I)
    Endif
Next I
WPND_QTYSTU -= [M]QTYSTU(NOL) - [M]XQTYSTU(NOL)
If [M]SAU(NOL)<>[M]STU(NOL)
    Call CNVQTY(WQTY,[M]SAUSTUCOE(NOL),[M]STU(NOL),WQTYSTU) From TRTVENQTE
Else
    WQTYSTU=WQTY
Endif
WPND_QTYSTU += WQTYSTU - [M]XQTYSTU(NOL)
Return
########################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL : NOL = nolign-1

# X3-80406 - if non-conformance exist, check if user wishes to delete
If func AFNC.ACTIV ("NCS")
    Local Integer LOK
    Local Integer EXISTS
    Local Char NCSMESS(255)
    [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (2, [M:SRH0]SRHNUM, [M:SRH1]SRDLIN(NOL), [L]NCSMESS,0)
    # check if user wishes to continue
    If (EXISTS > 0)
        Call OUINON([L]NCSMESS,LOK) From GESECRAN
        If LOK = 1
            GMESSAGE = ""
            mkstat = 2
            End
        Endif
    Endif
Endif
# X3-80406 - end

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0 and GMODMSDGFORDEB<>2
  If [M]CREFLG(NOL) <> 0 and !find(GREP,"C","D") and [F:SRH]EECNUMDEB>0
    If (VALEUR <> 0 and [M]QTY(NOL)=0) or ([M]QTY(NOL)<=[M]EXTQTY(NOL) and [M]QTY(NOL)<>VALEUR)
      Filter [F:DEB] Where EECNUMDEB=[F:SRH]EECNUMDEB and VCRNUM=[F:SRH]SRHNUM and CPY=[F:SRH]CPY
      Read [F:DEB]First
      If fstat : Raz [F:DEB] : Endif
      Filter [F:DEB]
      If [F:DEB]DEBDAT<>[0/0/0]
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB)-mess(98,107,1)-format$("DD2",[F:DEB]DEBDAT),0) From GESECRAN
      Else
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB),0) From GESECRAN
      Endif
      GMODMSDGFORDEB = 2
    Endif
  Endif
Endif
#--/

If VALEUR <> 0
    If [M]QTY(NOL)=0
        # La qté retour devient > à 0 : On force le flag maj stock à oui
        #   Initialisation et grisage champs stock sur ligne document d'entrée
        #   si "U" Pas d'initialisation des unités et coefficients
        Call STKACTLIG(NOL) From STKECR
        Call INIZONENT([M]ITMREF(NOL),"SRH1",[M]STOFCY,[M]BPCORD,2,"U",NOL,12,[M]TRSCOD,[M]SRHNUM,3,1) From STKECR
        If mkstat End : Endif
        If [M]STOMGTCOD(NOL) > 1
            [M]RTNSTOUPD(NOL)=2 : Raz [M]WSTOFLG(NOL)
            If [M]CREFLG(NOL)<>0 & [M]YRTNSTOUPD(NOL)=1 [M]WSTOUPD(NOL)=1 Endif
            Affzo [M]RTNSTOUPD(NOL)
            Gosub CHARG_STOENTW : If mkstat=2 End Endif : # Bug 48874 : Charger STOENTW avec les mvts du document d'origine
        Endif
    Endif
Else
    # La qté retour est à 0 : Pas de mise à jour des stock
    Raz [M]RTNSTOUPD(NOL), [M]WSTOUPD(NOL)
    Raz [M]GESLOT(NOL), [M]WSTOSEQ(NOL), [M]WSTOFLG(NOL), [M]WSRUFLG(NOL)
    Call STKRAZGRILIG ("SRH1", NOL) From TRTVENSTK
    [M]WSTOFLG(NOL)=2 : # Article non géré en stock
    Affzo [M]RTNSTOUPD(NOL)
    # La qté retour est à 0 : Pas d'avoir possible
    [M]RTNCNOFLG(NOL) = 1 : Affzo [M]RTNCNOFLG(NOL)
Endif
# -- alimentation du déduit facture
If [M]XQTY(NOL) = 0 & VALEUR <> 0
   [M]RTNINVUPD(NOL) = 1
   # X3-68815_Return_of_nonbillable_deliveries (LC- 18/01/18)
   If !clalev([SDH]): Local File SDELIVERY: Endif
   Raz [F:SDH]
   If [M]DETSDHNUM(NOL)<>""
     Read [F:SDH]SDH0=[M]DETSDHNUM(NOL)
   Endif
   If [F:SDH]SDHCAT<>4
   # End X3-68815_Return_of_nonbillable_deliveries (LC- 18/01/18)
     If [M]DETSDHNUM(NOL) <> "" & [M]SIHNUMFAC(NOL) = ""
#        [M]RTNINVUPD(NOL) = 2
         If GDLVRTNCNO=1
             # Pas d'avoir si la livraison n'est pas facturée, ce sera déduit de la facture
             [M]RTNCNOFLG(NOL) = 1
             [M]RTNINVUPD(NOL) = 2
         Else
             # Avoir si la livraison n'est pas facturée, ce ne sera pas déduit de la facture
             [M]RTNCNOFLG(NOL) = 2
             [M]RTNINVUPD(NOL) = 1
         Endif
     Endif
   Endif # X3-68815_Return_of_nonbillable_deliveries (LC- 18/01/18)
   Affzo [M]RTNINVUPD(NOL), RTNCNOFLG(NOL)
Endif

End
# -------------------------------------- SAUSTUCOE ------------------------
########################################
Subprog AS_SAUSTUCOE(VALEUR)
Variable Decimal VALEUR
#If [M]DETSDHNUM(nolign-1) <> "" | [M]UPDFLG(nolign-1)<>0 | [M]SAU(nolign-1)=[M]STU(nolign-1)
If [M]SAU(nolign-1)=[M]STU(nolign-1)  mkstat=2 :  Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 08/07/2003 15:41:20 (LD)
##########################################################################
Subprog C_SAUSTUCOE(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL    : NOL = nolign-1
Local    Decimal WCOEF
Local    Decimal WQTY, WDLV_QTYSTU
Local    Decimal WEXTQTY, WDLV_EXTQTYSTU

# Bug 67067
#If VALEUR<>[M]SAUSTUCOE(NOL)
    If [M]DETSDHNUM(NOL) <> ""
        # -- Si retour sur une ligne de livraison : Quantité retour prévue > quantité livrée ?
        # -- Calcul qté retour prévue en US pour la ligne de livraison
        WEXTQTY = [M]EXTQTY(NOL) : WCOEF=VALEUR : Gosub CALC_DLV_EXTQTYSTU
        If   [M]DLVQTYSTU(NOL) - WDLV_EXTQTYSTU < 0  GMESSAGE = mess(63,192,1) : mkstat = 2 : End : Endif
        If [M]PNHNUM(NOL) = ""
            # La qté retournée ne doit pas être réceptionnée (passer dans ce cas par le picking retour fsseur)
            If [M]DLVQTYSTU(NOL)-WDLV_EXTQTYSTU-[M]RCPQTYSTU(NOL)<0  GMESSAGE=mess(282,192,1)-"\"-mess(150,191,1) : mkstat = 2 : End : Endif
        Endif
        # -- Si retour sur une ligne de livraison : Quantité retour > quantité livrée ?
        # -- Calcul qté retour prévue en US pour la ligne de livraison
        WQTY    = [M]QTY(NOL)    : WCOEF=VALEUR : Gosub CALC_DLV_QTYSTU
        If [M]DLVQTYSTU(NOL) - WDLV_QTYSTU < 0 GMESSAGE = mess(64,192,1) : mkstat = 2 : End : Endif
        If [M]PNHNUM(NOL) = ""
            # La qté retournée ne doit pas être réceptionnée (passer dans ce cas par le picking retour fsseur)
            If [M]DLVQTYSTU(NOL)-WDLV_QTYSTU-[M]RCPQTYSTU(NOL)<0  GMESSAGE=mess(282,192,1)-"\"-mess(150,191,1) : mkstat = 2 : End : Endif
        Endif
    Endif
#Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 08/07/2003 15:18:36 (LD)
##########################################################################
Subprog AM_SAUSTUCOE(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL : NOL=nolign-1
Local    Decimal WQTY, WCOEF

# Recalcul de la qté retour prévue en US
Call CNVQTY([M]EXTQTY(NOL),VALEUR,[M]STU(NOL), [M]EXTQTYSTU(NOL)) From TRTVENQTE
# Recalcul de la qté retour en US
Call CNVQTY([M]QTY(NOL),VALEUR,[M]STU(NOL), [M]QTYSTU(NOL)) From TRTVENQTE
# Recalcul de la qté livrée avec le nvx coefficient
WQTY=[M:SRH1]DLVQTYSTU(NOL) / VALEUR
Call QTEARR(WQTY, [M:SRH1]SAU(NOL)) From TRTDIV
[M:SRH1]DLVQTY(NOL)= WQTY
Affzo [M:SRH1]DLVQTY(NOL)
# Convertion des prix avec le nouveau coef
WCOEF=VALEUR : Gosub CONV_PRIX
End
# -------------------------------------- RTNREN ------------------------
########################################
Subprog AS_RTNREN(VALEUR)
Variable Char    VALEUR
Local    Integer NOL
NOL = nolign-1
# -- pas de saisie motif retour si qte nulle
If [M]QTY(NOL)=0 mkstat=2 : Endif
End
# -------------------------------------- DETRTNDAT ------------------------
########################################
Subprog AS_DETRTNDAT(VALEUR)
Variable Date    VALEUR
Local    Integer NOL : NOL = nolign-1
# -- pas de saisie date retour si qte nulle
If [M]QTY(NOL)=0 mkstat=2 : End : Endif
End
########################################
Subprog C_DETRTNDAT(VALEUR)
Variable Date    VALEUR
Local    Integer NOL : NOL = nolign-1
Local    Integer OK
If [M]EXYDAT <> [0/0/0]
   If  VALEUR > [M]EXYDAT
       Call OUINON(mess(67,192,1), OK) From GESECRAN
       If   OK = 1 : mkstat = 2 : End : Endif
   Endif
Endif
If VALEUR<>[M]DETRTNDAT(NOL)  & [M]DETSDHNUM(NOL)<>""
    # Si retour de livraison la date du retour ne doit pas être < date de livraison
    If [F:SDH]SDHNUM<>[M]DETSDHNUM(NOL)
        Read [SDH]SDH0=[F:SDD]SDHNUM
        If fstat Raz [F:SDH] Endif
    Endif
    If VALEUR < [F:SDH]DLVDAT GMESSAGE=mess(178,192,1) : mkstat=2 : End : Endif
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SRH1) 08/06/2007 14:59:12 (LD)
######################################################################################
Subprog AM_DETRTNDAT(VALEUR)
Variable Date    VALEUR

#--- Bug62980
#--- Contrôle date entrée par rapport aux dates mouvements en attente
If [M]STOMGTCOD(nolign-1)>1
  Local Date    LDATRUP
  Local Decimal LQTYRUP
  Call CTLRUP([M]STOFCY,[M]ITMREF(nolign-1),VALEUR,1,LDATRUP,LQTYRUP) From STKLIB
Endif
#---

# La date de retour n'est pas répercutée sur les mvts de stock
If [M]CREFLG(nolign-1) <> 0 Call MESSAGE(mess(221,191,1)) From GESECRAN Endif
End
##########################################################################
# -------------------------------------- ORDUPD ------------------------
########################################
Subprog AS_ORDUPD(VALEUR)
Variable Integer VALEUR
Local    Integer NOL : NOL = nolign-1
# -- maj cde impossible si déjà maj, si déjà facturé, si <>liv/cde, si ligne issue d'un retour fsseur
#                       si composant composé kit/sous-traité
If [M]XORDUPD(NOL)=2 | [M]SIHNUMFAC(NOL)<>"" | [M]SOHCAT(NOL)<> 1 | [M]PNHNUM(NOL)<>""
&  | find([M]LINTYP(NOL),2,3,4,5,10,11,12,13)
   mkstat = 2
Endif
# -- maj cde impossible si ligne directe ou si qte nulle
If [M]DETSDHNUM(NOL)="" | [M]QTY(NOL)=0
   mkstat=2
Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 22/07/2003 16:44:12 (LD)
##########################################################################
Subprog C_ORDUPD(VALEUR)
Variable Integer VALEUR
Local    Integer NOL : NOL = nolign-1
Local    Decimal WQTYSAU, WQTY

# Si maj de la commande
# Si l'UV du retour n'est pas l'UV de la commande
# --> Il faut vérifier que la qté retournée dans l'UV commande est cohérente
If VALEUR=2 & VALEUR<>[M]ORDUPD(NOL)
    If [M]DETSDHNUM(NOL)<>"" & [M]SOHSAU(NOL)<>"" & [M]SOHSAUCOE(NOL)<>0
        If [M]SOHSAU(NOL)<>[M]SAU(NOL) | [M]SOHSAUCOE(NOL)<>[M]SAUSTUCOE(NOL)
            WQTYSAU=[M:SRH1]QTYSTU(NOL) / [M:SRH1]SOHSAUCOE(NOL)
            WQTY=WQTYSAU
            Call QTEARR(WQTY,[M:SRH1]SOHSAU(NOL)) From TRTDIV
            If WQTYSAU<>WQTY
                # On ne tombe sur un chiffre rond : on refuse de maj la commande
                mkstat=2 : GMESSAGE=mess(266,192,1)+"\"+mess(267,192,1)
            Endif
        Endif
    Endif
Endif
End
# -------------------------------------- RTNSTOUPD ------------------------
########################################
Subprog AS_RTNSTOUPD(VALEUR)
Variable Integer VALEUR
Local    Integer NOL : NOL = nolign-1

# Pas de saisie du flag maj stock si l'article n'est pas géré en stock (flag forcé à non)
If [M]STOMGTCOD(NOL)=1 mkstat=2 Endif
# Pas de saisie du flag maj stock si la quantité est nulle (flag forcé à non)
If [M]QTY(NOL)=0 mkstat = 2 : Endif
# Pas de changement du flag maj stock si la ligne existait et qu'elle est déjà maj en stock,
If [M]CREFLG(NOL)<> 0 & [M]RTNSTOUPD(NOL)=2 &  [M]YRTNSTOUPD(NOL)=2 mkstat = 2 : Endif
End
########################################
Subprog C_RTNSTOUPD(VALEUR)
Variable Integer VALEUR
Local    Integer NOL : NOL = nolign-1
# Si pas de maj de stock ou la quantité est nulle ou
# la ligne existait et elle est déjà maj en stock, pas de contrôle
If VALEUR=1 |  [M]QTY(NOL)=0 | ([M]CREFLG(NOL)<>0 & [M]RTNSTOUPD(NOL)=2) End : Endif
# Contrôle existence article-site si géré en stock
Call CONTITF([M:SRH1]ITMREF(NOL), [M:SRH0]STOFCY, [M:SRH1]STOMGTCOD(NOL)) From TRTVENCTL
# Si article-site inexistant, GMESSAGE est déjà positionné
If mkstat=2 End Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 16/05/2003 15:17:41 (LD)
##########################################################################
Subprog AM_RTNSTOUPD(VALEUR)
Variable Integer VALEUR
Local    Integer NOL : NOL = nolign-1
Local    Integer WRET

If VALEUR=2
    Call STKACTLIG(NOL) From STKECR
    #   Initialisation et grisage champs stock sur ligne document d'entrée
    #   si "U" Pas d'initialisation des unités et coefficients
    Call INIZONENT([M]ITMREF(NOL),"SRH1",[M]STOFCY,[M]BPCORD,2,"U",NOL,12,[M]TRSCOD,[M]SRHNUM,3,1) From STKECR
    If mkstat End : Endif
    Raz [M]WSTOFLG(NOL) : [M]WSTOUPD(NOL)=1
    Gosub CHARG_STOENTW : If mkstat=2 End Endif : # Bug 48874 : Charger STOENTW avec les mvts du document d'origine
Else
    #   Pas de mise à jour des stock
    Call DELSTOENTW (NOL,NOL,"SRH1",1,1,[M:SRH0]STOFCY,1,"") From STKENT
    Raz [M]GESLOT(NOL), [M]WSTOSEQ(NOL), [M]WSTOFLG(NOL), [M]WSRUFLG(NOL), [M]WSTOUPD(NOL)
    Call STKRAZGRILIG("SRH1", NOL) From TRTVENSTK
    [M]WSTOFLG(NOL)=2 : # Article non géré en stock
Endif
End
# ------------------------------------------------------------------------
# Chargement de l'écran STOENTW avec les mvts du document d'origine
# ------------------------------------------------------------------------
$CHARG_STOENTW
Local Integer WRET

If dim([M]PRIORD)>0  Raz [M]PRIORD(NOL) : Actzo PRIORD(NOL) : Endif
If dim([M]MVTDES)>0  Raz [M]MVTDES(NOL) : Actzo MVTDES(NOL) : Endif
If [M:SRH1]DETSDHNUM(NOL)<>"" | [M:SRH1]PNHNUM(NOL)<>""
    If [F:SLT]STRNUM<>GFLAG
        Read [SLT]SLT0=6;GFLAG
        If fstat Raz [F:SLT] Endif
    Endif
    Local Integer WRET
    # Lecture des mouvements de stock d'une ligne de document pour stockage dans écran de travail STOENTW
    Call STJSTOENTW("SRH1",12,13,[M:SRH1]DETRTNDAT(NOL),NOL,[M:SRH1]NBLIG,"SLT",3,WRET) From STKENT
    # WRET=1 : Erreur pour stockage dans ENTW : La ligne ne peut pas être créée
    # WRET=2 : Aucune ligne ds ENTW : Tt a déjà été retourné : Pas de ligne à créer (avoirs de facture)
    # WRET=4 : Il y a des lignes ENTW mais il y a aussi des mvts en attente : La ligne peut être créée
    # WRET=6 : Aucune ligne ds ENTW : Ts les mvts st en attente : La ligne ne peut pas être créée
    If WRET=4
        Call MESSAGE([M:SRH1]DETSDHNUM(NOL)-":"-[M:SRH1]ITMREF(NOL)-mess(152,191,1)) From GESECRAN
    Elsif WRET<>0
        If WRET=6
            Call ERREUR([M:SRH1]DETSDHNUM(NOL)-":"-[M:SRH1]ITMREF(NOL)-":"-mess(284,192,1)-"\"-mess(153,191,1)) From GESECRAN
        Endif
        mkstat=2 : Return
    Endif
    Call RECPRISTJ([M:SRH0]STOFCY,4,[M:SRH1]DETSDHNUM(NOL),[M:SRH1]SDDLIN(NOL),[M:SRH1]PRIORD(NOL)) From STKENT
    #      Il faut désactiver les champs lot, n°série
    Call STKDISZONPIC("SRH1", NOL) From TRTVENSTK
Endif

Return
# -------------------------------------- RTNCNOFLG ------------------------
########################################
Subprog AS_RTNCNOFLG(VALEUR)
Variable Integer VALEUR
## Pas d'avoir si la facture n'a pas encore été créée ou si le retour est intra-société
#If [M:SRH1]RTNINVUPD(nolign-1)=2 | ([M:SRH1]BETFCY=2 & [M:SRH1]BETCPY<=1) mkstat=2 : Endif

# Pas de modification du flag si la facture n'a pas encore été créée ou si le retour est intra-société
If ([M:SRH1]SIHNUMFAC(nolign-1)="" & [M:SRH1]DETSDHNUM(nolign-1)<>"") | ([M:SRH1]BETFCY=2 & [M:SRH1]BETCPY<=1) mkstat=2 : Endif
If [M:SRH1]QTY(nolign-1)= 0 mkstat=2 : Endif

#CPO 69079
#Cas où on revient sur un retour après avoir créé la facture de la livraison
#Le SIHNUMFAC <>"" mais le RTNINVUPD = 2 (retour déjà déduit) => on ne doit pas pouvoir modifier le flag
If [M:SRH1]RTNINVUPD(nolign-1)=2 and [M:SRH1]SIHNUMFAC(nolign-1)<>"" : mkstat=2 : Endif

End
# -------------------------------------- LOT ------------------------
##########################################################################
## Etiquette ajoutée par le superviseur 12/02/2004 09:53:48 (LD)
##########################################################################
Subprog IB_LOT
If [M]PNHNUM(nolign-1)<>"" | [M]DETSDHNUM(nolign-1)<>"" Raz GBOUT2 Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 18/02/2004 11:00:02 (LD)
##########################################################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()

Local Shortint NOL : NOL=nolign-1
Local Char     WVCRNUMORI
Local Integer  LRET, WVCRTYPORI, WVCRLINORI

If [M:SRH1]PNHNUM(NOL) <> ""
    WVCRNUMORI = [M:SRH1]PNHNUM(NOL)
    WVCRTYPORI = 8
    WVCRLINORI = [M:SRH1]PNDLIN(NOL)
Elsif [M:SRH1]DETSDHNUM(NOL) <> ""
    WVCRNUMORI = [M:SRH1]DETSDHNUM(NOL)
    WVCRTYPORI = 4
    WVCRLINORI = [M:SRH1]SDDLIN(NOL)
Endif

LRET = func STKACT.FSTKCTRLOT(VALEUR,"SRH1",NOL,[M:SRH1]ITMREF(NOL),[M:SRH1]BPSLOT(NOL),
&                          13,[M:SRH0]SRHNUM,[M:SRH1]SRDLIN(NOL),
&                          WVCRNUMORI, WVCRTYPORI, WVCRLINORI, 0,
&                          [M:SRH0]STOFCY,"LOCTYP",[M:SRH1]GESLOT(NOL))
If mod(LRET,2)=1
    Diszo [M:SRH1]BPSLOT(NOL)
Else
    Actzo [M:SRH1]BPSLOT(NOL)
Endif
If mkstat=2 End Endif
Affzo [M:SRH1]BPSLOT(NOL)
#                                  # hcb 71276 deb
If VALEUR <> [M]LOT (nolign-1)
   If dim([M]ECCVALMAJ) > 0
      Raz [M]ECCVALMAJ(nolign-1)
      Raz [M]ECCVALMIN(nolign-1)
      Raz [M]ECCSAIFLG(nolign-1)
   Endif
Endif
#                                  # hcb 71276 fin




End
# -------------------------------------- NBSLO ------------------------
########################################
Subprog C_NBSLO(VALEUR)
Variable Decimal VALEUR
#-----------------------#
# Contrôle nbr sous-lot #
#-----------------------#
Local Shortint NOL : NOL=nolign-1
Call STKCTRNBSLO(VALEUR, [M:SRH1]SAU(NOL), [M:SRH1]QTY(NOL)) From STKACT
End

# -------------------------------------- SLO ------------------------
########################################
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
#-----------------------#
# Contrôle N° sous-lot  #
#-----------------------#
Local Shortint NOL : NOL=nolign-1
Local Char     WVCRNUMORI
Local Integer  WVCRTYPORI, WVCRLINORI

If VALEUR<>""
  If [M:SRH1]PNHNUM(NOL) <> ""
      WVCRNUMORI = [M:SRH1]PNHNUM(NOL)
      WVCRTYPORI = 8
      WVCRLINORI = [M:SRH1]PNDLIN(NOL)
  Elsif [M:SRH1]DETSDHNUM(NOL) <> ""
      WVCRNUMORI = [M:SRH1]DETSDHNUM(NOL)
      WVCRTYPORI = 4
      WVCRLINORI = [M:SRH1]SDDLIN(NOL)
  Endif
  Call STKCTRSLO(VALEUR, [M:SRH1]NBSLO(NOL), [M:SRH1]LOT(NOL),
&               [M:SRH1]ITMREF(NOL),[M:SRH1]BPSLOT(NOL),[M:SRH1]GESLOT(NOL), WVCRNUMORI, WVCRTYPORI, WVCRLINORI, 0,
&               [M:SRH0]STOFCY, [M:SRH1]SLOF(NOL)) From STKACT
  If mkstat=2 End : Endif
  Affzo [M:SRH1]SLOF(NOL)
Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 02/03/2004 18:14:54 (LD)
##########################################################################
Subprog B1_SLO(VALEUR)
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
Call RECLASTSLO([M:SRH1]ITMREF(NOL), [M:SRH1]LOT(NOL), "","", VALEUR) From STKLIB
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SRH1) 12/01/2009 08:31:36 (LD)
######################################################################################
Subprog C_BPSLOT(VALEUR)
Variable Char    VALEUR()
If dim([M:SRH1]SLO)>0
    Call STKCTRLOF(VALEUR, [M:SRH1]ITMREF(nolign-1), [M:SRH1]LOT(nolign-1), [M:SRH1]SLO(nolign-1), [M:SRH1]NBSLO(nolign-1), [M:SRH1]GESLOT(nolign-1) ) From STKACT
Else
    Call STKCTRLOF(VALEUR, [M:SRH1]ITMREF(nolign-1), [M:SRH1]LOT(nolign-1), "", 1, [M:SRH1]GESLOT(nolign-1) ) From STKACT
Endif
End

Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2
  VALEUR = [M:SRH1]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:SRH1]WRHE
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

#--- Bug 60553
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If [M:SRH1]WRH(nolign-1)<>""
   Raz [M:SRH1]LOC(nolign-1)
Endif
End

