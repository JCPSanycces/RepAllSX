End
#######################################################################
#                                                                     #
# SUBSRH : GESTION DES RETOURS                         EB - SEPT 1998 #
#                                                                     #
#######################################################################
# Issue X3-58977 - 20171220 by LD : PCU on stock transaction from credit memo incorrect
# Issue X3-94198 - 2018-07-02 by BAKHA : Remove button 13 for Non-conformance list
# Issue X3-80406 - 2018-07-13 by BAKHA : When customer return deleted, mark non-conformances
#                                        as document deleted.
# Issue X3-102712 - 2018-07-31 by BAKHA : Disable Non-conformance create button in Create/Amend/Delete/Duplicate mode

$ACTION
Case ACTION
 When "DEFTRANS"      : Gosub DEFTRANS        From SUBSRHA
 When "VARIANTE"      : Gosub VARIANTE        From SUBSRHA
 When "SETTRANS"      : Gosub SETTRANS        From SUBSRHA
 When "OUVRE"         : Gosub OUVRE           From SUBSRHA
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE     From SUBSRHA
 When "FERME"         : Gosub FERME           From SUBSRHA
 When "FILTRE"        : Gosub FILTRE          From SUBSRHA
 When "SETBOUT"       : Gosub SETBOUT         From SUBSRHA
 When "AVANTBOUT"     : Gosub AVANTBOUT       From SUBSRHA
 When "EXEBOUT"       : Gosub EXEBOUT         From SUBSRHA #85785
 When "STATUT"        : Gosub STATUT          From SUBSRHA
 When "APRES_MODIF"   : Gosub APRES_MODIF     From SUBSRHA
 When "GRISE"         : Gosub GRISE           From SUBSRHA
 When "VERIF_CRE"     : Gosub VERIF_CRE       From SUBSRHA
 When "RAZCRE"        : Gosub RAZCRE          From SUBSRHA
 When "INICRE"        : Gosub INICRE          From SUBSRHA
 When "CREATION"      : Gosub CREATION        From SUBSRHA
 When "ABANDON"       : Gosub ABANDON         From SUBSRHA
 When "APRES_CRE"     : Gosub APRES_CRE       From SUBSRHA
 When "AB_CREATION"   : Gosub AB_CRE_MOD      From SUBSRHA
 When "LIENS"         : Gosub LIENS           From SUBSRHA
 When "AVANT_MOD"     : Gosub AVANT_MOD       From SUBSRHA
 When "AVANT_MODFIC"  : Gosub AVANT_MODFIC    From SUBSRHA
 When "AVANT_CHOI"    : Gosub AVANT_CHOI      From SUBSRHA
 When "VERIF_MOD"     : Gosub VERIF_MOD       From SUBSRHA
 When "INIMOD"        : Gosub INIMOD          From SUBSRHA
 When "MODIF"         : Gosub MODIF           From SUBSRHA
 When "APRES_MOD"     : Gosub APRES_MOD       From SUBSRHA
 When "AB_MODIF"      : Gosub AB_CRE_MOD      From SUBSRHA
 When "VERF_ANU"      : Gosub VERF_ANU        From SUBSRHA
 When "ANNULE"        : Gosub ANNULE          From SUBSRHA
 When "DEFLIG"        : Gosub DEFLIG          From SUBSRHA
 When "LIENS_LIG"     : Gosub LIENS_LIG       From SUBSRHA
 When "INICRE_LIG"    : Gosub INI_LIG         From SUBSRHA
 When "INIMOD_LIG"    : Gosub INI_LIG         From SUBSRHA
 When "VALLIG"        : Gosub VALLIG          From SUBSRHA
 When "AVANT_SUITE"   : Gosub AVANT_SUITE     From SUBSRHA  : # 87368
 When "REMP_DERLU"    : Gosub REMP_DERLU      From SUBSRHC
 When "FILGAUCHE"     : Gosub FILGAUCHE       From SUBSRHC
 When "AP_FILGAUCHE"  : Gosub AP_FILGAUCHE    From SUBSRHC
 When "HINT"          : Gosub HINT_KEY        From SUBSRHC
 When "DEB_PICK"      : Gosub DEB_PICK        From SUBSRHC
 When "PICKE"         : Gosub PICKE           From SUBSRHC
 When "DEPICK"        : Gosub DEPICK          From SUBSRHC
 When "FIN_PICK"      : Gosub FIN_PICK        From SUBSRHC
 When Default
Endcase
#---------------- #
# Actions champs  #
#---------------- #
Case ACTION
 When "AAPRES_NBLIG" : Gosub AAPRES_NBLIG
 When "AB5_NBLIG"    : Gosub AB5_NBLIG
 When "BB5_NBLIG"    : Gosub BB5_NBLIG
 When "AB2_BPAADD"   : Gosub AB2_BPAADD     # FGR 10/11/2009 : X3SUIVI57700
 When "BB2_BPAADD"   : Gosub BB2_BPAADD     # FGR 10/11/2009 : X3SUIVI57700
 When Default
Endcase
Return

#########################################################################
# FGR 10/11/2009 : X3SUIVI57700 (début)
#######################################
$AB2_BPAADD
Local Integer IMODCHAMP

  IMODCHAMP = varmode([M:SRH0]BPAADD)
  If IMODCHAMP = 1 or IMODCHAMP = 2 Then
    Actzo [M:SRH0]BPAADD
  Endif

Return

#######################################
$BB2_BPAADD
  If IMODCHAMP = 1 Then
    Grizo [M:SRH0]BPAADD
  Elsif IMODCHAMP = 2 Then
    Diszo [M:SRH0]BPAADD
  Endif
Return
# FGR 10/11/2009 : X3SUIVI57700 (fin)
#########################################################################

#########################################################################
#                     ECRAN ENTETE : SRH0                               #
#########################################################################
# -------------------------------------- SRHNUM ------------------------
########################################
Subprog C_SRHNUM(VALEUR)
Variable Char    VALEUR()
# Pour ne pas essayer de dupliquer
If GREP="" & VALEUR = "" mkstat=2 : End : Endif
# On est pas passé par Fichier Nouveau
If GREP <> "C" & GREP <> "D"
   If [M]SRHNUM <> ""
      Look [F:SRH]SRH0=[M]SRHNUM
      If fstat
         Look [F:SRH]SRH0=VALEUR
         # Il y avait un enr en ligne et la clé saisie n'existe pas --> Création interdite
         If fstat : GMESSAGE=mess(178,199,1) : mkstat=2 : Endif
      Endif
   Else
      Look [F:SRH]SRH0=VALEUR
      # Il n'y avait pas d'enr en ligne et la clé saisie n'existe pas --> Création interdite
      If fstat : GMESSAGE=mess(178,199,1) : mkstat=2 : Endif
   Endif
Endif
End

# -------------------------------------- SITE RECEPTION ------------------------
##########################################################################
## Etiquette ajoutée par le superviseur 23/10/2003 13:47:20 (LD)
##########################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

Local Integer IRETOUR  # FGR 11/08/2014 : X3SUIVI102048

#Gbn-100166
# Chargement des globales référenciels, comptes et sections de la société
GFCY=VALEUR : Gosub CHARG_PARAM From SUBSRHA : If GERR=1 mkstat=2 : End Endif

If [M:SRH0]BPCORD<>"" & [M:SRH0]BPAADD<>""
#   Alimentation flag inter-site et inter-société
    Call ALIBETCPY(13,VALEUR,[M:SRH0]BPCORD,[M:SRH0]BPAADD,[M:SRH0]PNHFCY,[M:SRH0]BPSNUM,[M:SRH1]BETFCY,[M:SRH1]BETCPY) From TRTVENISOC
    If [M:SRH1]BETFCY=2
        # Retour inter-site
        # Le site de réception rattaché au clt livré est aussi le site de réception
        If VALEUR=[M:SRH0]PNHFCY
            Local Integer WOK : WOK=1
            Call AVERTIR (mess(184,191,1), WOK) From GESECRAN
            If WOK=1 mkstat=2 : End : Endif
        Endif
    Endif
    #--CPO 75115 Transféré après le "if"
    #Gosub REC_CPT_RET :     # Recherche du compteur retour
    Affzo [M:SRH1]BETFCY, BETCPY
Endif
#--CPO 75115 Init et recherche du compteur en fonction du SRHTYP
# ------------------------------------
# FGR 11/08/2014 : X3SUIVI102048 (début) : Si SRHTYP n'existe pas dans la nouvelle législation on l'efface pour en chercher un qui ira.
If [M:SRH0]SRHTYP<>""
  Call LEC_TRE_LEG(GCURLEG, [M:SRH0]SRHTYP, IRETOUR) From TRTLECLEG
  If IRETOUR <> 0 Then
    Raz [M:SRH0]SRHTYP
  Endif
Endif
# FGR 11/08/2014 : X3SUIVI102048 (fin)
# ------------------------------------
If [M:SRH0]SRHTYP=""
  Local Char WSRHTYP(GLONTRE) : Local Integer  WSRHCAT
  Gosub SRHTYP From SUBSRH
  [M:SRH0]SRHTYP=WSRHTYP : [M:SRH0]SRHCAT=WSRHCAT
  Affzo [M:SRH0]SRHTYP,SRHCAT
Endif
Gosub REC_CPT_RET :     # Recherche du compteur retour
#--
# Alimentation du code structure
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE
    If fstat Raz [F:CPY] Endif
Endif
[M:SRH0]PLISTC=[F:CPY]PLISTC

# Chargement des globales référenciels, comptes et sections de la société
#GFCY=VALEUR : Gosub CHARG_PARAM From SUBSRHA : If GERR=1 mkstat=2 : End Endif #gbn-100166-Déplacement en début de sous-pro.

# Affichage entêtes colonnes variables (sections analytiques) en cas de changement de société
Gosub AFF_TITCOL From SUBSRHA
# Effacement tableau des sections entête si changement société
If dim([M:SRH2]NBAXE)>0 & [M:SRH2]NBAXE>0
  [M:SRH0]STOFCY=VALEUR
  Effzo [SRH2]20 : Affzo [SRH2]20
Endif
#--- Bug 65478
If dim([M:SRH1]WRHE)>0
   Call WRHINIT([M:SRH1]WRHE,VALEUR,4) From STKWRH
Endif
#---
# Actzo ou Grizo des dépôts selon le site
[M]STOFCY=VALEUR
Gosub WRH_ETAT From SUBSRHA

#RMA * 85785
If func PORLEGLIB.DIGSIGN(VALEUR,"") = 1
  Chgfmt [M:SRH0]SRHCFMFLG   With "LA1:15X"
Else
  If dim([M:SRH0]SRHCFMFLG) > 0
    Chgfmt [M:SRH0]SRHCFMFLG   With "-LA1:15X"
  Endif
Endif

# BRBAN #93745 US2
If func AFNC.ACTIV('KPO')>0
  If func PORLEGLIB.DIGSIGN(VALEUR,'')=1
    Actzo  [M:SRH2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
    Call DIS_MANDOC(GFONCTION) From TRNDOC
  Else
    Diszo  [M:SRH2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
  Endif
Endif

End
######################################################################################
Subprog C_SRHTYP(VALEUR)
Variable Char    VALEUR()

If VALEUR="" : mkstat=2 : End : Endif
#--Contrôle que le type de retour pointe sur une catégorie acceptée par la transaction

# X3-1152 : Non invoiceable deliveries
#If GDLVTYP<4 & [F:TRE]SRHCAT<>GDLVTYP : mkstat = 2 : Endif
If GDLVTYP<>4 & [F:TRE]SRHCAT<>GDLVTYP : mkstat = 2 : Endif
# X3-1152 : Non invoiceable deliveries

#--CPO X3Suivi 75115 Libellé Catégorie --#
[M:SRH0]WSRHCAT = mess(8,105,1) - ':' - mess([F:TRE]SRHCAT,493,1)
Affzo [M:SRH0]WSRHCAT

# BRBAN 23-07-2014 SAM 93745 US2
If func AFNC.ACTIV('KPO')>0
  If func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY,'')=1
    Actzo  [M:SRH2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
    Call DIS_MANDOC(GFONCTION) From TRNDOC
  Else
    Diszo  [M:SRH2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
  Endif
Endif

If func AFNC.ACTIV("KPO")>0
  If func PORLEGLIB.CTLDOCTYP(VALEUR,"SRH",GMESSAGE) = 1
    mkstat = 2 : End
  Endif
Endif

End
######################################################################################
Subprog AM_SRHTYP(VALEUR)
Variable Char    VALEUR()

#--Init de la catégorie de retour
[M:SRH0]SRHCAT = [F:TRE]SRHCAT
Affzo [M:SRH0]SRHCAT

#--Init du compteur en fonction du type de retour
#--Afin d'avoir la bonne valeur dans le sous-pro REC_CPT_RET
[M:SRH0]SRHTYP=VALEUR
Gosub REC_CPT_RET : If GERR=1 : mkstat=2 : Endif

If GMANCOU=1 & [M:SRH0]SRHNUM <> ""
   Effzo [M:SRH0]SRHNUM
Endif

If GREP="C" & GMANCOU<>2
   Diszo [M:SRH0]SRHNUM
Else
   Actzo [M:SRH0]SRHNUM
Endif

End
######################################################################################
# -------------------------------------- BPCORD ------------------------
########################################
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()
GBPCNUM = VALEUR
# Recherche du client livré par défaut
Read [BPD]BPD0 = VALEUR;[F:BPC]BPDADD
If fstat = 0 & [F:BPD]ENAFLG=2 [M:SRH0]BPAADD = [F:BPD]BPAADD : Endif
If [M:SRH0]BPAADD = ""
   Filter [BPD] Where [BPD]BPCNUM = VALEUR & [BPD]ENAFLG=2
   Read [BPD]BPD0 First
   If fstat = 0 [M:SRH0]BPAADD = [F:BPD]BPAADD : Endif
   Filter [BPD]
Endif

Read [BPR]BPR0 = VALEUR
If fstat<>0 Raz [F:BPR] Endif
[M:SRH0]LAN = GLANGUE
If [F:BPR]LAN<>"" [M:SRH0]LAN=[F:BPR]LAN : Endif
# Utile pour l'init. des sections : La Section par défaut "SRH" utile [M:SRH0]BPCORD
[M:SRH0]BPCORD = VALEUR
# Alimentation client facture
[M:SRH1]BPCINV = [F:BPC]BPCINV

# GRNA 20/05/2011
Local Char CUSSEAORI : CUSSEAORI = "SRH0"
Gosub AM_BPRNUM From CUSSEALIB

If [M:SRH0]BPAADD<>""
    Local Char WBPCORD(GLONBPC), WBPAADD(GLONBPD)  : WBPCORD=VALEUR : WBPAADD=[M:SRH0]BPAADD
    Gosub CLILIV : If mkstat=2 End Endif
    If [M:SRH0]STOFCY <> "" Gosub REC_CPT_RET : Endif    # Recherche du compteur retour
Endif
If dim([M:SRH2]NBAXE)>0
    If [M:SRH2]NBAXE>0
        For I=1 To [M:SRH2]NBAXE Raz [M:SRH2]CCE(I-1) : Next
    Endif
    Call INIT_CCEH("SRH2","NBAXE","SRH") From TRTX3CPT
Endif

Affzo [M:SRH0]BPAADD, BPDNAM
Affzo [M:SRH1]BPCINV
Affzo [M:SRH2]20

End
# -------------------------------------- BPAADD ------------------------
######################################################################################
## Etiquette ajoutée par le superviseur (écran SRH1) 14/10/2005 10:31:12 (LD)
######################################################################################
Subprog AP_BPAADD(VALEUR)
Variable Char    VALEUR()

# Si saisie de l'adresse
If [M:ADB2]BPRNAM(0) <> ""
   [M]BPDNAM = [M:ADB2]BPRNAM(0)
   Affzo [M]BPDNAM
Endif
End
########################################
Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()

# --> Si utilisation du bouton adresse, il ne faut pas passer en AM_
If !GIMPORT & VALEUR = [M]BPAADD End : Endif

Local Char WBPCORD(GLONBPC), WBPAADD(GLONBPD)  : WBPCORD=[M:SRH0]BPCORD : WBPAADD=VALEUR
Gosub CLILIV : If mkstat=2 End Endif
Affzo [M]BPDNAM
End
#---------------------------------------------------#
$CLILIV
If [F:BPD]LAN<>"" [M:SRH0]LAN = [F:BPD]LAN : Endif
[M:SRH0]BPDNAM =[F:BPD]BPDNAM(0)
# Alimentation code adresse (client livré) dans [M:ADB2] pour saisie adresse libre
If dim([M:ADB2]BPAADD) > 0
   [M:ADB2]BPAADD = WBPAADD
   Call RECH_CNTNAM(WBPCORD, WBPAADD, [M:ADB2]CNTNAM) From TRTVENDIV
Endif
# Alimentation des champs relatifs au infos douanières
[M:SRH0]EECICT=[F:BPD]EECICT
[M:SRH0]ICTCTY=[F:BPD]ICTCTY
[M:SRH0]FFWNUM=[F:BPD]FFWNUM
[M:SRH0]FFWADD=[F:BPD]FFWADD
If dim([M:SRH0]BPIEECNUM)>0
    Call INIEECNUM (WBPCORD,WBPAADD,[M:SRH1]BPCINV,[M:SRH0]BPIEECNUM,[M:SRH0]EECNUMCRY) From TRTVENDIV
    [M:SRH0]EECLOC=[F:BPD]EECLOC
    # Lecture table modes de livraison
    If clalev ([F:TMD]) <= 0 Local File TABMODELIV [TMD] Endif
    If [F:BPD]MDL<>""
       Read [TMD]TMD0=[F:BPD]MDL
       If fstat=0 [M:SRH0]EECTRN=[F:TMD]EECTRN : Endif
    Endif
Endif
If [M:SRH0]STOFCY<>"" & WBPCORD<>"" & WBPAADD<>""
#   Alimentation flag inter-site et inter-société
    Call ALIBETCPY(13,[M:SRH0]STOFCY,WBPCORD,WBPAADD,[M:SRH0]PNHFCY,[M:SRH0]BPSNUM,[M:SRH1]BETFCY,[M:SRH1]BETCPY) From TRTVENISOC
    If [M:SRH1]BETFCY=2
        # Retour inter-site
        # Le site de réception rattaché au clt livré est aussi le site de réception
        If [M:SRH0]STOFCY=[M:SRH0]PNHFCY
            Local Integer WOK : WOK=1
            Call AVERTIR (mess(184,191,1), WOK)From GESECRAN
            If WOK=1 mkstat=2 : Return : Endif
        Endif
    Endif
    Affzo [M:SRH1]BETFCY, BETCPY
Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran SRH1) 25/10/2005 10:42:47 (LD)
######################################################################################
Subprog AM_BPCINV(VALEUR)
Variable Char    VALEUR()
If dim([M:SRH0]BPIEECNUM)>0
    Call INIEECNUM ([M:SRH0]BPCORD,[M:SRH0]BPAADD,VALEUR,[M:SRH0]BPIEECNUM,[M:SRH0]EECNUMCRY) From TRTVENDIV
Endif
End

Subprog AS_WRHE(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2 & VALEUR<>"" & [M]NBLIG<>0
   GMESSAGE=mess(342,184,1) : mkstat=2
Endif
End

