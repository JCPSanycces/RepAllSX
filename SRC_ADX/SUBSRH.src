Return
######################################################################################
##########################################################################
#     ETIQUETTES APPELEES PAR LES COMPOSANTS D'ENTREE EN STOCK
##########################################################################
#########################################################################
# Bouton Détail  en click droit sur NBLIG  Action SAISTOENT             #
# Fenêtre Détail en APRES_NBLIG            Action SAISTOENT             #
# STJSTOENTW appelé lors du picking et en AM_RTNSTOUPD                  #
#########################################################################
# ETIQUETTES APPELEES PAR TRTSTOENTA                                    #
#########################################################################
#-----------------------------------------------------------------------#
# Appelée dans CHARG_PARAM_STOENT                                       #
# Chargement Ecran STOENT (partie parametrage) creations des entrées    #
#-----------------------------------------------------------------------#
Subprog CHARG_PARAM_STOENT (LLIG)
Value Integer LLIG
[M:ENT]STOFCY    = [M:SRH0]STOFCY
[M:ENT]ITMREF    = [M:SRH1]ITMREF(LLIG)
[M:ENT]QTYTOENT  = [M:SRH1]QTY(LLIG)
[M:ENT]PCUTOENT  = [M:SRH1]SAU(LLIG)
[M:ENT]COETOENT  = [M:SRH1]SAUSTUCOE(LLIG)
[M:ENT]STU       = [M:SRH1]STU(LLIG)
[M:ENT]VCRNUM    = [M:SRH0]SRHNUM
[M:ENT]VCRLIN    = [M:SRH1]SRDLIN(LLIG)
[M:ENT]WSTOSEQ   = [M:SRH1]WSTOSEQ(LLIG)
[M:ENT]MVTDES    = [M:SRH1]MVTDES(LLIG)
[M:ENT]PRI       = [M:SRH1]PRIORD(LLIG)
[M:ENT]QUAFLG    = [M:SRH1]QUAFLG(LLIG)        # hcb V6CQ
[M:ENT]QUAFRE    = [M:SRH1]QUAFRE(LLIG)        # hcb V6CQ
If dim([M:SRH1]WRH)>0
  [M:ENT]XWRH    = [M:SRH1]WRH(LLIG)
Endif
[M:ENT]TRSTYP    = 12                          : # Type mouvement (M.704)
[M:ENT]TRSCOD    = [M:SRH0]TRSCOD              : # code mouvement
[M:ENT]TRSFAM    = [M:SRH2]TRSFAM
[M:ENT]IPTDAT    = [M:SRH1]DETRTNDAT(LLIG)     : # Date imputation
[M:ENT]BPRNUM    = [M:SRH0]BPCORD
[M:ENT]CUR       = [M:SRH1]CUR(LLIG)

[M:ENT]SRGWAIFLG = GSLTSRGWAIFLG
[M:ENT]PRNCOD1   = GSLTPRNCOD1
[M:ENT]PRNNBFLG1 = GSLTPRNNBFLG1
[M:ENT]CCECODS   = GSTODIE

If [M:SRH1]PNHNUM(LLIG) <> ""
    [M:ENT]VCRTYPORI = 8
    [M:ENT]VCRNUMORI = [M:SRH1]PNHNUM(LLIG)
    [M:ENT]VCRLINORI = [M:SRH1]PNDLIN(LLIG)
    [M:ENT]STOFCYORI = [M:SRH0]PNHFCY
    GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
Elsif [M:SRH1]DETSDHNUM(LLIG) <> ""
    [M:ENT]VCRTYPORI = 4
    [M:ENT]VCRNUMORI = [M:SRH1]DETSDHNUM(LLIG)
    [M:ENT]VCRLINORI = [M:SRH1]SDDLIN(LLIG)
    Read [SDH]SDH0=[M:SRH1]DETSDHNUM(LLIG)
    If fstat Raz [F:SDH] Endif
    [M:ENT]STOFCYORI = [F:SDH]STOFCY
    GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
Else
    GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
Endif
[M:ENT]BPRNUM = [M:SRH0]BPCORD
If dim([M:ENT]ECCBOMFLG)>0
   Raz [M:ENT]ECCBOMFLG                                     # hcb 71276
Endif

End

#-----------------------------------------------------------------------#
# Appelée dans MAJ_LIGNE_DOCUMENT                                       #
# Chargement Ecran STOENT (partie parametrage) creations des entrées    #
# Donne la main pour maj ligne du document, et grise les champs stock   #
# LPCU    : Unité utilisée dans le détail                               #
# LCOEF   : Coefficient utilisé dans  le détail                         #
# LQTYSTU : Qté en US à répercuter dans le doc                          #
#-----------------------------------------------------------------------#
$MAJ_LIG_SRH
Local Decimal WQTYSAU, WQTY

Local Integer NOL : NOL=LLIGDOC

# Bug 48874 : Ne pas faire de ctrl si on vient de la modif. QTY ou RTNSTOUPD (Appel STJSTOENTW)
If !find(GACTION, "SAISTOENT","SAISTOENTM") Return Endif

#--- Cas de la suppression : 24/11/03 (tests HN)
If LQTYSTU=0
  If [M:SRH1]CREFLG(NOL)<>0
    [M:SRH1]QTY(NOL)=0
    [M:SRH1]QTYSTU(NOL)=0
    Return
  Elsif [M:SRH1]CREFLG(NOL)=0
    Raz [M:SRH1]WSTOFLG(NOL) : Grizo [M:SRH1]QTY(NOL)
  Endif
Endif
# Dans la fenêtre détail : l'unité ou le coefficient UV-US ou la qté sont différents du document d'origine
# Si la qté en US est modifiée report sur la ligne document origine
If LQTYSTU<>[M:SRH1]QTYSTU(LLIGDOC)
    If LCOEF<>0
    # -- Coef. unique sur toutes les lignes
        If LPCU=[M:SRH1]SAU(LLIGDOC)
        # -- L'entrée a été saisie dans l'unité du document (UV) : On récalcule la qté retour en UV
            If LCOEF=[M:SRH1]SAUSTUCOE(LLIGDOC)
                [M:SRH1]QTY(LLIGDOC)=LQTYSTU / LCOEF
                [M:SRH1]QTYSTU(LLIGDOC)=LQTYSTU
            Else
                # Le coefficient a été modifié
                If [M:SRH1]DACSAUCOE(LLIGDOC)=2
                    # Il est modifiable       : Il est répercuté
                    [M:SRH1]QTY(LLIGDOC)=LQTYSTU / LCOEF
                    [M:SRH1]QTYSTU(LLIGDOC)=LQTYSTU
                    # Recalcul de la qté retour prévue en US
                    Call CNVQTY([M:SRH1]EXTQTY(LLIGDOC),LCOEF,[M:SRH1]STU(LLIGDOC),[M:SRH1]EXTQTYSTU(LLIGDOC)) From TRTVENQTE
                    # Recalcul de l'ancienne qté retour prévue avec le nvx coefficient
                    WQTY=[M:SRH1]XEXTQTYSTU(LLIGDOC) / LCOEF
                    Call QTEARR(WQTY, [M:SRH1]SAU(LLIGDOC)) From TRTDIV
                    [M:SRH1]XEXTQTY(LLIGDOC)= WQTY
                    # Recalcul de l'ancienne qté retour avec le nvx coefficient
                    WQTY=[M:SRH1]XQTYSTU(LLIGDOC) / LCOEF
                    Call QTEARR(WQTY, [M:SRH1]SAU(LLIGDOC)) From TRTDIV
                    [M:SRH1]XQTY(LLIGDOC)= WQTY
                    # Recalcul de la qté livrée avec le nvx coefficient
                    WQTY=[M:SRH1]DLVQTYSTU(LLIGDOC) / LCOEF
                    Call QTEARR(WQTY, [M:SRH1]SAU(LLIGDOC)) From TRTDIV
                    [M:SRH1]DLVQTY(LLIGDOC)= WQTY
                    Local Decimal WCOEF : WCOEF=LCOEF
                    Gosub CONV_PRIX : # Changement du coef : Convertion des prix
                    [M:SRH1]SAUSTUCOE(LLIGDOC)=LCOEF
                Else
                    # -- Il n'est pas modifiable : Il n'est pas répercuté
                    #    On recalcule la qté retour ds l'unité du document(UV)
                    #    Si on tombe sur un chiffre rond ok sinon on met tout en US
                    Gosub RECALC_QTYSAU
                Endif
            Endif
        Else
        # -- L'entrée a été saisie en US ou ds une autre unité
        #    On recalcule la qté retour ds l'unité du document(UV)
        #    Si on tombe sur un chiffre rond ok sinon on met tout en US
            Gosub RECALC_QTYSAU
        Endif
    Else
    # -- Coef. non unique sur toutes les lignes : on met tout en US
         # --> On ne fera pas de mise à jour de la commande
         If [M:SRH1]XORDUPD(LLIGDOC)=1 & [M:SRH1]ORDUPD(LLIGDOC)=2 [M:SRH1]ORDUPD(LLIGDOC)=1 : Endif
         Gosub CONV_LIG_SAUSTU
    Endif
    Affzo [M:SRH1]SAU(LLIGDOC), EXTQTY(LLIGDOC), QTY(LLIGDOC), DLVQTY(LLIGDOC), SAUSTUCOE(LLIGDOC), ORDUPD(LLIGDOC)
Endif

If [M:SRH1]SAU(LLIGDOC)=[M:SRH1]STU(LLIGDOC)
  Affzo [M:SRH1]SAUSTUCOE(LLIGDOC) : # pb diszo
  Diszo [M:SRH1]SAUSTUCOE(LLIGDOC)
  Affzo [M:SRH1]SAUSTUCOE(LLIGDOC) : # pb diszo
Endif

Return
# ------------------------------------------------------------- #
# Recalcul de la qté retour ds l'unité du document (UV)         #
#    Si on tombe sur un chiffre rond ok sinon on met tout en US #
# ------------------------------------------------------------- #
$RECALC_QTYSAU
# Calcul de la qté en UV
WQTYSAU=LQTYSTU / [M:SRH1]SAUSTUCOE(LLIGDOC)
WQTY=WQTYSAU
Call QTEARR(WQTY,[M:SRH1]SAU(LLIGDOC)) From TRTDIV
If WQTYSAU=WQTY
    # On tombe sur un chiffre rond : ok
    [M:SRH1]QTY(LLIGDOC)=WQTYSAU
    [M:SRH1]QTYSTU(LLIGDOC)= LQTYSTU
Else
    # On ne tombe pas sur un chiffre rond : on met tout en US
    # --> On ne fera pas de mise à jour de la commande
    If [M:SRH1]XORDUPD(LLIGDOC)=1 & [M:SRH1]ORDUPD(LLIGDOC)=2 [M:SRH1]ORDUPD(LLIGDOC)=1 : Endif
    Gosub CONV_LIG_SAUSTU
Endif
Return
# ------------------------------------------------------------- #
# Passage de la ligne retour en US                              #
# --> L'UV devient l'US                                         #
# --> La qté en UV devient la qté en US                         #
# --> Conversion en US toutes les quantités qui étaient en UV   #
# --> Le coef. UV-US est forcé à 1                              #
# ------------------------------------------------------------- #
$CONV_LIG_SAUSTU
[M:SRH1]QTYSTU(NOL)=LQTYSTU
[M:SRH1]SAU(NOL)=[M:SRH1]STU (NOL)
[M:SRH1]QTY(NOL)=LQTYSTU
# Il faut reconvertir en US toutes les quantités qui étaient en UV
[M:SRH1]EXTQTY(NOL) =[M:SRH1]EXTQTY(NOL)*[M:SRH1]SAUSTUCOE(NOL)

[M:SRH1]XEXTQTY(NOL)=[M:SRH1]XEXTQTY(NOL)*[M:SRH1]SAUSTUCOE(NOL)
[M:SRH1]XQTY(NOL)   =[M:SRH1]XQTY(NOL)*[M:SRH1]SAUSTUCOE(NOL)

[M:SRH1]DLVQTY(NOL) =[M:SRH1]DLVQTY(NOL)*[M:SRH1]SAUSTUCOE(NOL)

# Convertion des prix de l'UV vers l'US
Local Decimal WCOEF : WCOEF=1
Gosub CONV_PRIX
[M:SRH1]SAUSTUCOE(NOL)=1
Return

#########################################################################
# ETIQUETTES APPELEES PAR TRTSTOENTB                                    #
#########################################################################
#-----------------------------------------------------------------------#
# Appelée dans CTL_LIGNE_DOCUMENT                                       #
# Donne la main pour effectuer avant stockage dans STOENTW:             #
#  - contrôles de quantités                                             #
#  - affectation diverses                                               #
# En cas d'erreur, donner une valeur différente de 0 à mkstat           #
# Attention : Il est de la responsabilité de chaque document d'afficher #
#             les messages d'erreurs.                                   #
# Variables disponibles :                                               #
# LQTYSTU = Quantité totale en unité de stock des lignes de détail      #
# LPCU    = Unité utilisée dans le détail si unique sinon ""            #
# LCOEF   = Coefficient UC/US si unique sinon ""                        #
#-----------------------------------------------------------------------#
$CTL_LIG_SRH
#------------------------------------------#
# Contrôle au sortir de la saisie de stock #
# ou modif de stock                        #
#------------------------------------------#
If dim(NOL)<0       : Local Shortint NOL       : Endif
If dim(TRTLIG)<0    : Local Char     TRTLIG(1) : Endif
If dim(SVGNOL)<0    : Local Integer  SVGNOL    : Endif

# Bug 48874 : Ne pas faire de maj si on vient de la modif. QTY ou RTNSTOUPD (Appel STJSTOENTW)
If !find (GACTION,"SAISTOENT","SAISTOENTM") Return Endif

Local Integer OK
Local Decimal WRTNQTYSTU, WEXTQTYSTU
SVGNOL=nolign : # Sauvegarde du nolign ecran stock
NOL=LLIGDOC
nolign=NOL+1
NEWQTE =LQTYSTU

Local Shortint   WSUPP : Raz WSUPP

# Modification de la quantité
If LQTYSTU>0 & LQTYSTU<>[M:SRH1]QTYSTU(NOL)
    If [M:SRH1]DETSDHNUM(NOL) <> ""
        # -- Quantité retour > quantité livrée ?
        For  I = 0 To [M:SRH1]NBLIG -1
           If [M:SRH1]DETSDHNUM(I)=[M:SRH1]DETSDHNUM(NOL) & [M:SRH1]SDDLIN(I)=[M:SRH1]SDDLIN(NOL)
              WEXTQTYSTU += [M:SRH1]EXTQTYSTU(I) - [M:SRH1]XEXTQTYSTU(I)
           Endif
        Next I
        If [M:SRH1]DLVQTYSTU(NOL) - WEXTQTYSTU < 0 GMESSAGE = mess(63,192,1) : mkstat = 2 : Return : Endif


        # -- Quantité retour > quantité livrée ?
        For  I = 0 To [M:SRH1]NBLIG -1
           If [M:SRH1]DETSDHNUM(I)=[M:SRH1]DETSDHNUM(NOL) & [M:SRH1]SDDLIN(I)=[M:SRH1]SDDLIN(NOL)
              WRTNQTYSTU += [M:SRH1]QTYSTU(I) - [M:SRH1]XQTYSTU(I)
           Endif
        Next I
        WRTNQTYSTU -= ([M:SRH1]QTYSTU(NOL)-[M:SRH1]XQTYSTU(NOL))
        WRTNQTYSTU += LQTYSTU-[M:SRH1]XQTYSTU(NOL)
        If [M:SRH1]DLVQTYSTU(NOL) - WRTNQTYSTU < 0 GMESSAGE = mess(64,192,1) : mkstat = 2 : Return : Endif
        If [M:SRH1]PNHNUM(NOL) = ""
            # La qté retournée ne doit pas être réceptionnée (passer dans ce cas par le picking retour fsseur)
            If [M:SRH1]DLVQTYSTU(NOL)-WRTNQTYSTU-[M:SRH1]RCPQTYSTU(NOL)<0  GMESSAGE=mess(282,192,1)-"\"-mess(150,191,1) : mkstat = 2 : Return : Endif
        Endif
        # S'il y a un retour sur la commande
        # Si l'UV du retour n'est pas l'UV de la commande
        # --> Il faut vérifier que la qté retournée dans l'UV commande est cohérente
        If [M:SRH1]XORDUPD(NOL)=1 & [M:SRH1]ORDUPD(NOL)=2
#            If ([M:SRH1]SOHSAU(NOL)<>[M:SRH1]SAU(NOL) | [M:SRH1]SOHSAUCOE(NOL)<>[M:SRH1]SAUSTUCOE(NOL))
                WQTYSAU=LQTYSTU / [M:SRH1]SOHSAUCOE(NOL)
                WQTY=WQTYSAU
                Call QTEARR(WQTY,[M:SRH1]SOHSAU(NOL)) From TRTDIV
                If WQTYSAU<>WQTY
                    # On ne tombe sur un chiffre rond : on refuse de maj la commande
                    OK=1 : Call AVERTIR (mess(268,192,1)+"\"+mess(266,192,1)+"\"+mess(267,192,1), OK) From GESECRAN
                    If OK=1 Raz GERR : Raz GMESSAGE : mkstat=2 : Return : Endif
                Endif
#            Endif
        Endif
    Elsif [M:SRH1]PNHNUM(NOL) <> ""
        # -- Quantité retour > quantité livrée ?
        For  I = 0 To [M:SRH1]NBLIG -1
           If [M:SRH1]PNHNUM(I)=[M:SRH1]PNHNUM(NOL) & [M:SRH1]PNDLIN(I)=[M:SRH1]PNDLIN(NOL)
              WRTNQTYSTU += [M:SRH1]QTYSTU(I) - [M:SRH1]XQTYSTU(I)
           Endif
        Next I
        WRTNQTYSTU -= ([M:SRH1]QTYSTU(NOL)-[M:SRH1]XQTYSTU(NOL))
        WRTNQTYSTU += LQTYSTU-[M:SRH1]XQTYSTU(NOL)
        If [M:SRH1]PNDQTYSTU(NOL) - WRTNQTYSTU < 0 GMESSAGE = mess(275,192,1) : mkstat = 2 : Return : Endif
    Endif
    # -- Quantité retour > quantité prévue ?
#    pas de répercution du coef sur le retour
    If LPCU=[M:SRH1]SAU(NOL) & LCOEF<>[M:SRH1]SAUSTUCOE(NOL) & [M:SRH1]DACSAUCOE(NOL)=2
        # Entrée saisie ds l'unité du doc. (UV) mais chgmt du coef conversion UV-US : Recalcul qté prévue en US
        Call CNVQTY([M:SRH1]EXTQTY(NOL),LCOEF,[M:SRH1]STU(NOL), WEXTQTYSTU) From TRTVENQTE
    Else
        WEXTQTYSTU=[M:SRH1]EXTQTYSTU(NOL)
    Endif
    If  WEXTQTYSTU<>0 & LQTYSTU > WEXTQTYSTU
        OK=1 : Call AVERTIR (mess(84,192,1), OK) From GESECRAN
        If OK=1 : Raz GERR : Raz GMESSAGE : mkstat=2 : Return : Endif
    Endif
    # -- Quantité retour remise à zéro ?
    If LQTYSTU=0 & [M:SRH1]EXTQTY(NOL) = 0
        GMESSAGE = mess(83,123,1) : mkstat = 2 : Return
    Endif
Endif


# Contrôle du stock retourné
If [M:SRH1]DETSDHNUM(NOL)<>"" | [M:SRH1]PNHNUM(NOL)<>""
    Call CTR_STK_RETCLI(OK) From STKENT
    If OK mkstat = 2 : Return Endif
Endif

# Avertissement si la ligne existait et maj cde déjà effectuée
#If [M:SRH1]CREFLG(NOL) <> 0 & [M:SRH1]ORDUPD(NOL) = 2
#    Call OUINON(mess(74,192,1)+"\"+mess(108,192,1)+"\"+mess(205,100,1), OK) From GESECRAN
#    If   OK = 1 : mkstat = 2 : Return : Endif
#Endif
If [M:SRH1]CREFLG(NOL)<>0
  #-- Si la quantité est à 0 (suppression de ligne)
  If LQTYSTU = 0
    TRTLIG="A" : status=65
    Gosub TEST_MOD_ANU
    If mkstat=0
        # Si la ligne doit être supprimée, on regarde s'il y en a d'autres
        # pour déterminer si l'entête doit être supprimée
        Filter [SRD] Where SRHNUM=[M:SRH0]SRHNUM & SRDLIN<>[M:SRH1]SRDLIN(NOL)
&                Order By Key SRD0
        Read [SRD]SRD0 First
        If fstat WSUPP = 1 Endif
        Filter [SRD]
        If WSUPP=1
            # --> "Vous n'avez pas les droits pour ce retour"
            If [M:SRH2]AUZUSR <> GUSER & GAUZRET = 1
               GMESSAGE=mess(71,192,1) : mkstat=2
            Else
                # --> Ctrl autorisation suppression
                GBIDC2="S": Gosub AUTORIS_OPT From CONTX3
                If !GBIDI2  GMESSAGE=mess(2,104,1) : mkstat=2 Endif
            Endif
        Endif
    Endif
  Else
    TRTLIG="M" : status=75
    Gosub TEST_MOD_ANU
  Endif
  If mkstat Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE : nolign=SVGNOL : Return : Endif
Endif
nolign=SVGNOL
Return

#########################################################################
# ETIQUETTES APPELEES PAR TRTSTOENMA                                    #
#########################################################################
#-----------------------------------------------------------------------#
# Appelée dans CHARG_PARAM_STOENTM                                      #
# Chargement Ecran STOENTM (partie parametrage) modification des entrées#
#-----------------------------------------------------------------------#
Subprog CHARG_PARAM_STOENTM (LLIG)
Value Integer LLIG

If LLIG<>999999
  [M:ENM]STOFCY   = [M:SRH0]STOFCY
  [M:ENM]ITMREF   = [M:SRH1]ITMREF(LLIG)
  [M:ENM]QTYTOENT = [M:SRH1]QTY(LLIG)
  [M:ENM]PCUTOENT = [M:SRH1]SAU(LLIG)
  [M:ENM]COETOENT = [M:SRH1]SAUSTUCOE(LLIG)
  [M:ENM]STU      = [M:SRH1]STU(LLIG)
  [M:ENM]VCRNUM   = [M:SRH0]SRHNUM
  [M:ENM]VCRLIN   = [M:SRH1]SRDLIN(LLIG)
  [M:ENM]MVTDES   = [M:SRH1]MVTDES(LLIG)
  [M:ENM]QUAFLG   = [M:SRH1]QUAFLG(LLIG)        # hcb V6CQ
  [M:ENM]QUAFRE   = [M:SRH1]QUAFRE(LLIG)        # hcb V6CQ
  If dim([M:SRH1]WRH)>0
    [M:ENM]XWRH   = [M:SRH1]WRH(LLIG)
  Endif
  [M:ENM]PJT      = ""
  [M:ENM]TRSTYP   = 12                   : # Type mouvement (M.704)
  [M:ENM]TRSCOD   = [M:SRH0]TRSCOD       : # Code mouvement
  [M:ENM]TRSFAM   = [M:SRH2]TRSFAM
  [M:ENM]BPRNUM   = [M:SRH0]BPCORD       :
#  [M:ENM]ENTCOD   = WSLTENTCOD
  [M:ENM]ENTCOD   = [M:SRH0]ENTCOD
  If [M:SRH1]BETFCY=2 [M:ENM]TRFFCY = [M:SRH0]PNHFCY Endif
  [M:ENM]BETCPY   = [M:SRH1]BETCPY
  If [M:SRH1]DETSDHNUM (LLIG)<> "" | [M:SRH1]PNHNUM (LLIG)<> ""
      GSAIFLG="000000020000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Else
      GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Endif
Else : # Cas de la suppression
# ???
  [M:ENM]STOFCY   = [F:SRD]STOFCY
  [M:ENM]ITMREF   = [F:SRD]ITMREF
  [M:ENM]QTYTOENT = [F:SRD]QTY
  [M:ENM]PCUTOENT = [F:SRD]SAU
  [M:ENM]COETOENT = [F:SRD]SAUSTUCOE
  [M:ENM]STU      = [F:SRD]STU
  [M:ENM]VCRNUM   = [F:SRD]SRHNUM
  [M:ENM]VCRLIN   = [F:SRD]SRDLIN
  [M:ENM]MVTDES   = ""
  [M:ENM]PJT      = ""
  [M:ENM]TRSTYP   = 12                   : # Type mouvement (M.704)
  [M:ENM]TRSCOD   = [F:SRH]TRSCOD        : # Code mouvement
  [M:ENM]TRSFAM   = [F:SRH]TRSFAM
  [M:ENM]BPRNUM   = [F:SRH]BPCORD
#  [M:ENM]ENTCOD   = WSLTENTCOD
  [M:ENM]ENTCOD   = [F:SRH]ENTCOD
  If [M:SRH1]BETFCY=2 [M:ENM]TRFFCY = [M:SRH0]PNHFCY Endif
  [M:ENM]BETCPY   = [F:SRH]BETCPY
  If [F:SRD]SDHNUM <> "" | [F:SRD]PNHNUM <> ""
      GSAIFLG="000000020000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Else
      GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Endif
Endif
[M:ENM]SRGWAIFLG = GSLTSRGWAIFLG
[M:ENM]PRNCOD1   = GSLTPRNCOD1
[M:ENM]PRNNBFLG1 = GSLTPRNNBFLG1
If dim([M:ENM]ECCBOMFLG)>0
   Raz [M:ENM]ECCBOMFLG                                     # hcb 71276
Endif

End
#-----------------------------------------------------------------------#
# Appelée dans MAJ_MODIFICATION_LIGNE                                   #
# Mise à jour du document origine suite à modifications                 #
# le masque du document origine est chargé avec les nouvelles valeurs   #
#-----------------------------------------------------------------------#
########################################
$TRT_MAJ_DOCUMENT
Local Integer LOK

If dim(NOL)<0 :  Local Shortint NOL: Endif
If dim(TRTLIG)<0 Local Char    TRTLIG(1) : Endif

Local Char       SYMBOLE2(30), WSENS(1)
If dim(WSUPP)<0  Local Shortint   WSUPP : Raz WSUPP : Endif
Local Integer    SIGN, WSTAT, SAVNOLIGN, I, OK, WSRDLIN, WRET
Local Decimal    WLIVTTC, DELTAQTY, DELTAQTYSTU

#LSE 7/12/2005 sauvegarde valeur si suppression
Local Char       WSRDITEMLIN
Local Integer    WSRDQTYLIN


NOL=LLIGDOC
nolign=NOL+1
WSRDLIN=[M:SRH1]SRDLIN(NOL)
WSRDITEMLIN = [M:SRH1]ITMREF(NOL)


Raz WLIVTTC
# Mise à jour des quantités
Gosub MAJ_LIG_SRH
WSRDQTYLIN = [M:SRH1]QTYSTU(NOL)

If [M:SRH1]QTYSTU(NOL)=0
    TRTLIG="A"
    # Si la ligne doit être supprimée, on regarde s'il y en a d'autre sur le retour
    # pour déterminer si l'entête retour doit être supprimée
    Filter [SRD] Where SRHNUM=[M:SRH0]SRHNUM & SRDLIN<>[M:SRH1]SRDLIN(NOL)
&                Order By Key SRD0
    Read [SRD]SRD0 First
    If fstat WSUPP = 1 Endif
    Filter [SRD]
Else
    TRTLIG="M"
Endif

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0 and GMODMSDGFORDEB<>2
  If !find(GREP,"C","D") and [F:SRH]EECNUMDEB>0
      Filter [F:DEB] Where EECNUMDEB=[F:SRH]EECNUMDEB and VCRNUM=[F:SRH]SRHNUM and CPY=[F:SRH]CPY
      Read [F:DEB]First
      If fstat : Raz [F:DEB] : Endif
      Filter [F:DEB]
      If [F:DEB]DEBDAT<>[0/0/0]
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB)-mess(98,107,1)-format$("DD2",[F:DEB]DEBDAT),0) From GESECRAN
      Else
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB),0) From GESECRAN
      Endif
      GMODMSDGFORDEB = 2
  Endif
Endif
#--/

# --- Contrôles OK, suite de la mise à jour
#Gbn/Ts-93077-On ne fait le Dela qu'après le PE s'il n'y a qu'une seule ligne.
If [M:SRH1]QTYSTU(NOL)=0 & !WSUPP
  status=65 : nolign=NOL+1
  Dela NOL,1,[M:SRH1]NBLIG-1 [M:SRH1]NBLIG : [M:SRH1]NBLIG-=1
Endif

# --- Lecture de l'entête retour
If WSUPP = 1
   Readlock [SRH]SRH0=[M:SRH0]SRHNUM
Else
   Read [SRH]SRH0=[M:SRH0]SRHNUM
Endif
If fstat = 1 GOK = -1
   GLOCK = "$SRETURN"-[M:SRH0]SRHNUM : Return
Elsif fstat  GOK =  0
   Call RSTA ("SRH",[M:SRH0]SRHNUM) From GLOCK : Return
Endif

#If [F:SRD]SDHNUM<>""
#  SYMBOLE2="SDH"+[F:SRD]SDHNUM : Unlock=SYMBOLE2
#Endif

#-- Maj du détail retour
Readlock [SRD]SRD0=[M:SRH0]SRHNUM;WSRDLIN
If fstat = 1 GOK = -1
   GLOCK = "$SRETURND"-[M:SRH0]SRHNUM-num$(WSRDLIN)
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SRD",[M:SRH0]SRHNUM-num$(WSRDLIN)) From GLOCK
   Return
Endif
SIGN=-1
#----- Mise à jour statistiques ligne retour -----#
Call VALSTA ("SRD",SIGN) From SUBPS2
If GOK<1 : Return : Endif

If TRTLIG="A"
  DELTAQTY    = -1 * [F:SRD]QTY
  DELTAQTYSTU = -1 * [F:SRD]QTYSTU
  #-- Suppression texte ligne
  If left$([F:SRD]SRDTEX,3)="SRD"
        Call SUP_CLOB([F:SRD]SRDTEX,WRET) From TRTX3TEX
  Endif
  #----- Suppression comptes et sections de la ligne de facture -----#
  Call ENREG_ACCCCE(0,"","","","SRD",0,[F:SRD]SRHNUM,[F:SRD]SRDLIN,0,"","A") From TRTX3CPT
  If GOK<1  Return : Endif
  #-----
  #-- Suppression de la ligne de retour
  Delete [SRD] Where SRHNUM=[M:SRH0]SRHNUM & SRDLIN=WSRDLIN
  If fstat GOK=0 : Call FSTA("SRD") From GLOCK : Return : Endif

  # X3-80406 - Before we delete the customer return line check if this document is in any non-conformances
  If func AFNC.ACTIV ("NCS")
      Local Integer LOK
      Local Integer EXISTS
      Local Char NCSMESS(255)
      [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (2, [M:SRH0]SRHNUM, WSRDLIN, [L]NCSMESS, 1)
      If [L]EXISTS = 1
          # customer return line deleted then mark this document as deleted in any non-conformances
          LOK = func NCSDOCHDR_CSTD.DELETE_NON_CONFORMANCE_DOCUMENTS (2, [M:SRH0]SRHNUM, WSRDLIN)
          If LOK
              GMESSAGE = mess(47,3702,1)
              GOK = 0
              Return
          Endif
      Endif
  Endif
  # X3-80406 - endif
Else
#  DELTAQTY    = [M:SRH1]QTY(NOL) - [F:SRD]QTY
#  DELTAQTYSTU = [M:SRH1]QTYSTU(NOL) - [F:SRD]QTYSTU
  DELTAQTY    = [M]QTY(NOL)    - [M]XQTY(NOL)
  DELTAQTYSTU = [M]QTYSTU(NOL) - [M]XQTYSTU(NOL)

  [F:SRD]QTY=[M:SRH1]QTY(NOL)
  [F:SRD]QTYSTU=[M:SRH1]QTYSTU(NOL)
  [F:SRD]SAU=[M:SRH1]SAU(NOL)
  [F:SRD]SAUSTUCOE=[M:SRH1]SAUSTUCOE(NOL)
  [F:SRD]EXTQTY=[M:SRH1]EXTQTY(NOL)
  [F:SRD]EXTQTYSTU=[M:SRH1]EXTQTYSTU(NOL)
  [F:SRD]DLVQTY=[M:SRH1]DLVQTY(NOL)
  SIGN=1
  #-- Réécriture de la ligne de retour
  Rewrite [SRD]
  If fstat GOK=0 : Call FSTA("SRD") From GLOCK : Return : Endif
  #----- Mise à jour statistiques ligne retour -----#
  Call VALSTA ("SRD",SIGN) From SUBPS2
  If GOK<1 : Return : Endif
Endif

#----- Si tout s'est bien déroulé -----#
If GOK = 1
  GRELITSRH = 1
Endif

# Maj de la livraison correspondante
If [F:SRD]SDHNUM <> "" & DELTAQTYSTU <> 0
   Local Integer WMAJ_LIV : WMAJ_LIV=1
   Gosub LEC_LIV From SUBSRHA
   If GOK < 1 Return Endif #--CPO Lors du 94689 : If GOK < 1 End Endif
   If WMAJ_LIV = 1
       Local Decimal WCNVDELTAQTY
       Gosub CONV_LIV_DELTAQTY From SUBSRHA
       Gosub MAJLIV From SUBSRHA
       If GOK < 1 Return Endif #--CPO Lors du 94689 : If GOK < 1 End Endif
       # 106134 : Maj mvt client (livré non facturé) ssi facture non émise et pas de facturation qté retournée
       #If [F:SDH]SIHNUM = ""
       If ([M]SIHNUMFAC(NOL) = "" & DELTAQTYSTU <> 0) & GDLVRTNCNO=1
       # 106134
#          WLIVTTC += DELTAQTY * [F:SDD]NETPRIATI
          WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI
       Endif
    Endif
    Unlock [SDH] : Unlock [SDD]
Endif
# Maj du retour correspondant
If [F:SRD]PNHNUM <> "" & DELTAQTYSTU <> 0
   Local Integer WMAJ_PNH : WMAJ_PNH=1
   Gosub LEC_PNH From SUBSRHA
   If GOK < 1 Return Endif #--CPO Lors du 94689 : If GOK < 1 End Endif
   If WMAJ_PNH = 1
       Local Decimal WCNVDELTAQTY
       If TRTLIG="A"
           # Pour recherche dernier n°retour vente d'une ligne retour fsseur
           If clalev([F:SRD1])=0 Local File SRETURND [SRD1] Endif
       Endif
       Gosub MAJPND From SUBSRHA
       If GOK < 1 Return Endif #--CPO Lors du 94689 : If GOK < 1 End Endif
       If sum([M:SRH1]PNDLIN)<>0
           #--CPO 109068
           #Close Local File [SRD1]
           #Default File [SRH]
           If clalev([F:SRD1])>0
             Close Local File [SRD1]
             Default File [SRH]
           Endif
           #--
       Endif
       If [F:SDH]SIHNUM = ""
#          WLIVTTC += DELTAQTY * [F:SDD]NETPRIATI
          WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI
       Endif
    Endif
    Unlock [PNH] : Unlock [PND]
Endif

If WSUPP=1
# Suppression textes retour
# A SUPPRIMER
#  If [F:SRH]SRHTEX1 <> ""
#    Call TEX(5,"SRH1","","","",[F:SRH]SRHTEX1,"A",GBIDI1) From TRTX3TEX
#  Endif
#  If [F:SRH]SRHTEX2 <> ""
#    Call TEX(5,"SRH2","","","",[F:SRH]SRHTEX2,"A",GBIDI1) From TRTX3TEX
#  Endif
  If left$([F:SRH]SRHTEX1,3)="SRH"
      Call SUP_CLOB([F:SRH]SRHTEX1,WRET) From TRTX3TEX
  Endif
  If left$([F:SRH]SRHTEX2,3)="SRH"
      Call SUP_CLOB([F:SRH]SRHTEX2,WRET) From TRTX3TEX
  Endif
  Delete  [SRH]
  #--95965 Le test du fstat doit être fait après le Delete...
  If fstat GOK=0 : Call FSTA("SRH") From GLOCK : Return : Endif

  # X3-80406 - check if this document is in any non-conformances

  If func AFNC.ACTIV ("NCS")
    Local Integer LOK
    Local Integer EXISTS
    Local Char NCSMESS(255)
    [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (2, [F:SRH]SRHNUM, -1, [L]NCSMESS, 1)
    If [L]EXISTS > 0
        # If we have deleted the customer return then mark this document as deleted in any non-conformances

        LOK = func NCSDOCHDR_CSTD.DELETE_NON_CONFORMANCE_DOCUMENTS (2, [F:SRH]SRHNUM, -1)
        If LOK
            GMESSAGE = mess(47,3702,1)
            GOK = 0
            Return
        Endif
    Endif
  Endif
  # X3-80406 - endif

Endif
#--95965 Le test du fstat doit être fait après le Delete...
#If fstat GOK=0 : Call FSTA("SRH") From GLOCK : Return : Endif

WSENS = "-"
# Maj mouvement client (livré non facturé)
If WLIVTTC <> 0
   Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
&               0, WLIVTTC, WSENS, "D", "", [F:SDH]LND) From TRTBPMVT
   If GOK < 1 Return Endif
Endif


#------------------------------------------------------------------------#
# PE pour maj table spécifique suite à modification ligne détail retour  #
#------------------------------------------------------------------------#
GPOINT="UPDSTOSRD": Gosub ENTREE From EXEFNC
If GOK = 0 Return Endif

#Gbn-93077-Tout s'est bien passé, on supprime la dernière ligne dans le tableau
If [M:SRH1]QTYSTU(NOL)=0 & WSUPP=1
  status=65 : nolign=NOL+1
  Dela NOL,1,[M:SRH1]NBLIG-1 [M:SRH1]NBLIG : [M:SRH1]NBLIG-=1
Endif


# Si présence module Support Client, gestion du parc client
#If GMODU(12)=2 Gosub TRT_MACRULE_DOC From SUBSRH : Endif : # Bug 84870 : Pas de gestion du parc si inter-site
If GMODU(12)=2 & !([M:SRH1]BETFCY=2 & [M:SRH1]BETCPY<>2)  : # Bug 84870
    Gosub TRT_MACRULE_DOC From SUBSRH                     : # Bug 84870
Endif                                                     : # Bug 84870

Return
##########################################################################
#########################################################################
# SRHINIZONENT                                                          #
#        Appelé en AVANT-NBLIG en modification d'une ligne de retour    #
#                                                                       #
#        - Lecture des tables articles                                  #
#        - Lecture de la règle de gestion à appliquer                   #
#        - Si ligne non créée ou créée mais elle devient gérée en stock #
#             Si ligne gérée en stock     :                             #
#                Si retour direct                                       #
#                    Activation des champs stocks                       #
#                Si retour de livraison (picking)                       #
#                    Désactivation lot, n° série                        #
#        - Si ligne déjà créée :                                        #
#             Si ligne non gérée en stock :                             #
#                Grisage des champs stock                               #
#             Si ligne gérée en stock     :                             #
#                Désactivation des champs stock                         #
#                                                                       #
#########################################################################
Subprog SRHINIZONENT
Local Integer NOL : NOL=nolign-1

If [M:SRH1]STOMGTCOD(NOL)<>1 & [M:SRH1]RTNSTOUPD(NOL)=2
    # Si ligne gérée en stock
    # --> Lecture article et règle de gestion
    Call LECFICENT([M:SRH0]STOFCY,[M:SRH0]BPCORD,"",nolign-1,12,[M:SRH0]TRSCOD,0) From STKECR
Endif
If [M:SRH1]CREFLG(NOL)=0 | ([M:SRH1]CREFLG(NOL)<>0 & [M:SRH1]RTNSTOUPD(NOL)=2 & [M:SRH1]YRTNSTOUPD(NOL)=1)
    # ---------------------------------------------------------------------------------------------------- #
    # La ligne n'est pas encore créée ou elle est déjà créée mais le flag maj stock est passé de non à oui #
    # ---------------------------------------------------------------------------------------------------- #
    Actzo [M:SRH1]QTY(NOL)
    If [M:SRH1]STOMGTCOD(NOL)<>1 & [M:SRH1]RTNSTOUPD(NOL)=2
        # -------------------- #
        # Ligne gérée en stock #
        # -------------------- #
        If [M:SRH1]DETSDHNUM(NOL)="" & [M:SRH1]PNHNUM(NOL)="" & [M:SRH1]WSTOFLG(NOL)=0
            # Si retour direct
            # et les champs stocks ne sont pas renseignés : Il faut "réactiver la ligne"
            #
            # (cas particulier où on a passé le flg mvt de stock de non à oui)
            Call STKACTLIG(NOL) From STKECR
            #   Initialisation et grisage champs stock sur ligne document d'entrée
            #   si "U" Pas d'initialisation des unités et coefficients
            Call INIZONENT([M:SRH1]ITMREF(NOL),"SRH1",[M:SRH0]STOFCY,[M:SRH0]BPCORD,2,"U",NOL,12,[M]TRSCOD,"",3,1) From STKECR
            If mkstat End : Endif
            If dim([M:SRH1]PRIORD)>0  Raz [M:SRH1]PRIORD(NOL) : Actzo PRIORD(NOL) : Endif
            If dim([M:SRH1]MVTDES)>0  Raz [M:SRH1]MVTDES(NOL) : Actzo MVTDES(NOL) : Endif
        Elsif [M:SRH1]DETSDHNUM(NOL)<>"" | [M:SRH1]PNHNUM(NOL)<>""
           # Si retour de livraison (picking)             : Il faut Activer/Désactiver les chmps
           #
           #      Il faut désactiver les champs lot, n°série
           # (cas particulier où on a passé le flg mvt de stock de non à oui
           Call STKDISZONPIC("SRH1", NOL) From TRTVENSTK
           #MAE, le 30/09/2010, bg67156
           # Désactivation des zones stock si plus d'un détail stock
           If func STKENT.CAL_NBENTW([M:SRH1]WSTOSEQ(NOL)) > 1
              Call STKDISLIG(NOL) From STKECR
    # Bug 66195
              Diszo [M:SRH1]PRIORD(NOL)
              Actzo [M:SRH1]MVTDES(NOL)
           Else
              # Il faut désactiver les champs statut,type emplacement, emplacement en fonction du contexte de l'article
              If dim([M:SRH1]WSTOSAI)>0
                  If val(mid$([M:SRH1]WSTOSAI(NOL),4,1))=2 Diszo [M:SRH1]STA(NOL)    Else Actzo [M:SRH1]STA(NOL)    Endif
                  If dim([M:SRH1]LOCTYP(NOL))>0            : # Bug 74919
                    If val(mid$([M:SRH1]WSTOSAI(NOL),5,1))=2 Diszo [M:SRH1]LOCTYP(NOL) Else Actzo [M:SRH1]LOCTYP(NOL) Endif
                    If val(mid$([M:SRH1]WSTOSAI(NOL),6,1))=2 Diszo [M:SRH1]LOC(NOL)    Else Actzo [M:SRH1]LOC(NOL)    Endif
                  Endif                                    : # Bug 74919
              Endif
              Actzo [M:SRH1]MVTDES(NOL)
              If dim([M:SRH1]WRH)>0
                  If GWRHOBY=2 Diszo [M:SRH1]WRH(NOL) Else Actzo [M:SRH1]WRH(NOL) Endif
              Endif
              # Bug 66195
              #      Il faut désactiver les champs lot, n°série
              # (cas particulier où on a passé le flg mvt de stock de non à oui
              Call STKDISZONPIC("SRH1", NOL) From TRTVENSTK
           Endif
           #---
        Endif
    # Bug 66195
    Else
        # ------------------------ #
        # Ligne non gérée en stock #
        # ------------------------ #
        Call STKGRILIG ("SRH1", NOL) From TRTVENSTK
    # Bug 66195
    Endif
Else
    # ----------------------- #
    # La ligne est déjà créée #
    # ----------------------- #
    # Désactivation des champs
    If [M:SRH1]STOMGTCOD(NOL)=1 | [M:SRH1]RTNSTOUPD(NOL)=1
        # --> Si ligne non gérée en stock, grizage des champs stock
        Actzo [M:SRH1]QTY(NOL)
        Call STKGRILIG ("SRH1", NOL) From TRTVENSTK
    Else
        Diszo [M:SRH1]SAU(NOL), EXTQTY(NOL), QTY(NOL), SAUSTUCOE(NOL)
        Call STKDISLIG(NOL) From STKECR :  # Diszone les champs stocks ne pouvant plus être modifiés
        If dim([M]PRIORD)>0  Diszo [M]PRIORD(NOL) : Endif
        If dim([M]MVTDES)>0  Diszo [M]MVTDES(NOL) : Endif
    Endif
Endif

End
# --------------------------------------------------------------------------------
#                     Etiquettes
# --------------------------------------------------------------------------------
#########################################################################
#-------------------------------#
# Test de modification de ligne #
#-------------------------------#
$TEST_MOD_ANU
# --> Si la ligne a fait l'objet d'un avoir d'un suppression impossible
If [M:SRH1]SIHNUM(NOL) <> "" GMESSAGE = mess(203,192,1) : mkstat = 2 : Return : Endif
# --> avertissement si maj cde déjà effectuée
If [M:SRH1]ORDUPD(NOL) = 2 & [M:SRH1]XORDUPD(NOL) = 2
    Call OUINON(mess(145,191,1)+"\"+mess(205,100,1), OK) From GESECRAN
    If   OK = 1 : mkstat = 2 : Endif
Endif
Return
#########################################################################
# ---------------------------------- #
# Recherche du compteur livraison    #
# ---------------------------------- #
$REC_CPT_RET

If !clalev([F:TRE]) : Local File TABSRHTYP [TRE] : Endif

Local Integer WCPTSRHTYP : [L]WCPTSRHTYP = 0

If [M:SRH0]SRHTYP<>""
  # --- Récupération du code compteur
  #--CPO 75115 - 203
  #--On cherche avant tout sur le type de retour
  #--Lecture de TABSRHTYP si cette dernière n'est pas en ligne
  If (find([F:TRE]SRHTYP,"",[M:SRH0]SRHTYP)<1 | find([F:TRE]LEG,GCURLEG)<1)
      Local Integer WERR
      Call LEC_TRE_LEG(GCURLEG,[M:SRH0]SRHTYP,WERR) From TRTLECLEG
      If WERR Raz [F:TRE] : Call RSTA("TRE", [M:SRH0]SRHTYP) From GLOCK : Endif
  Endif
  #--Initialisation des compteurs en fonction du type de retour
  If [F:TRE]SRHTYP<>""
    If    [M:SRH1]BETFCY=2 & [M:SRH1]BETCPY=1       :#-- Retour Inter-sites
      GCPT=[F:TRE]CODNUMFCY
    Elsif [M:SRH1]BETCPY=2                          :#-- Retour Inter-sociétés
      GCPT=[F:TRE]CODNUMCPY
    Else                                            :#-- Retour normal
      GCPT=[F:TRE]CODNUM
    Endif
    GMANCOU=[F:TRE]MANCOU
    If func AFNC.ACTIV("KPO") #85785
      GCPTENDNBR =[F:TRE]CODNUMEND                         :#-- Compteur définitif
    Endif
    [L]WCPTSRHTYP = 1 :#--Il faut absolument ré-initialiser les compteurs si non passage ici
  Endif
Endif
#--On lit toujours car on utilise pour initialiser aussi d'autres compteurs
#--------(exp dans $OUVRE le GCPTENDNBR=[F:TCA]CODNUM(13))-------
Local Integer WOK
If clalev ([F:TCA]) <= 0 Local File TABCOUAFF [TCA] Endif
Call LECTCA(5,WOK) From SUBTCA
If fstat | !WOK
    GERR=1 : GMESSAGE=mess(58,105,1)-mess(5,14,1)-mess(250,199,1) : Return
Endif

#--Si pas de type de retour ou pas de compteur de paramétré
#--On initialise avec le paramétrage des affectations de compteurs
#--Pas d'entrée dans les "Affectations compteurs" pour le "Retour définitif"
#If [L]WCPTSRHTYP=0 | (func AFNC.ACTIV("DKS")=1 & GCPTENDNBR="") | GCPT="" | [F:TRE]SRHTYP=""
If [L]WCPTSRHTYP=0 | GCPT=""
  If GCPT="" | [F:TRE]SRHTYP=""
    If    GDLVTYP = 2                                       : # Retour de prêt
        GMANCOU=[F:TCA]MANCOU(7)  : GCPT=[F:TCA]CODNUM(7)
    Elsif GDLVTYP = 3                                       : # Retour de sous-traitance
        GMANCOU=[F:TCA]MANCOU(17) : GCPT=[F:TCA]CODNUM(17)
    Elsif [M:SRH1]BETFCY=2 | [M:SRH1]BETCPY=2               : # Retour Intra-société/Inter-société
        GMANCOU=[F:TCA]MANCOU(16) : GCPT=[F:TCA]CODNUM(16)
    Else                                                    : # Retour normal
        GMANCOU=[F:TCA]MANCOU(2)  : GCPT=[F:TCA]CODNUM(2)
    Endif
  Endif
#--Pas d'entrée dans les "Affectations compteurs" pour le "Retour définitif"
#  If func AFNC.ACTIV("DKS") & GCPTENDNBR=""
#    GCPTENDNBR=[F:TCA]CODNUM(xx)   :#-- Compteur définitif
#  Endif
Endif

#--CPO 75115 Le compteur et le compteur définitif doivent être différents
#--Uniquement si le code activité DKS est actif
If func AFNC.ACTIV("KPO")=1 and GCPT <>"" and GCPTENDNBR<>"" and GCPT=GCPTENDNBR #85785
  GERR=1 : GMESSAGE= mess(248,191,1)-GCPT+"/"+GCPTENDNBR : Return
Endif

#------------------------
## Bug 63578
#If dim(OK)<1  Local Integer OK : Endif
#Call LECTCA(5,OK) From SUBTCA
#If fstat | !OK
#    GERR=1 : GMESSAGE=mess(58,105,1)-mess(5,14,1)-mess(250,199,1) : Return
#Endif
## Bug 63578
#
#If [M:SRH1]BETFCY=2 & [M:SRH1]BETCPY=1     : # Retour Intra-société
#    GMANCOU=[F:TCA]MANCOU(16) : GCPT=[F:TCA]CODNUM(16)
#Else                                       : # Retour normal
#    GMANCOU=[F:TCA]MANCOU(2)  : GCPT=[F:TCA]CODNUM(2)
#Endif
#-------------------------
Return
#---------------------------------------------------------------------#
##########################################################################
#---------------------------------------#
#   Gestion du parc client              #
#---------------------------------------#
$TRT_MACRULE
Local Integer WRET, WTYP, WERR

  Raz WRET
  If !clalev ([F:STJ])  : Local File STOJOU [STJ] : Endif
  WTYP=3
  For [SRD]SRD0 Where SRHNUM=[F:SRH]SRHNUM
    If [F:ITM]ITMREF <> [F:SRD]ITMREF
      Read [ITM]ITM0 = [F:SRD]ITMREF
      If fstat Then
        Raz [F:ITM]
      Endif
    Endif
    If [F:SRD]SAUSTUCOE=0 Then
      [F:SRD]SAUSTUCOE=1
    Endif
    If [F:ITM]SERMGTCOD < 2
      # Pas de gestion des no série
      Gosub CHARGE_MACW
      # Appel au composant d'intégration
      Call MACRULE(WTYP,[F:SRH]BPCORD,WRET) From TRTMACRULE
      If WRET Then
        Gosub ERR_MACRULE
        Break                           # FGR 04/01/2011 : X3SUIVI70100
      Endif
    Else
      # Gestion des no séries
      For [STJ]STJ1 Where STOFCY=[F:SRH]STOFCY & VCRTYP=13 & VCRNUM=[F:SRD]SRHNUM
&                       & VCRLIN=[F:SRD]SRDLIN & REGFLG<>2 & ITMREF = [F:SRD]ITMREF
        Gosub CHARGE_MACW
        # Appel au composant d'intégration
        Call MACRULE(WTYP,[F:SRH]BPCORD,WRET) From TRTMACRULE
        If WRET Then
          Gosub ERR_MACRULE
          Break                         # FGR 04/01/2011 : X3SUIVI70100
        Endif
      Next
      If WRET Then                      # FGR 04/01/2011 : X3SUIVI70100
        Break
      Endif
    Endif
  Next
Return

# Traitement des erreurs
$ERR_MACRULE
  GOK = 0                               # FGR 04/01/2011 : X3SUIVI70100
  If WERR=0
    Call ECR_TRACE (mess(90,182,2),0)   From GESECRAN
    WERR=1
  Endif
  If [M:MACW]MACSERNUM=""
    Call ECR_TRACE ([F:SRD]ITMREF-":"-mess(WRET,182,2),0) From GESECRAN
  Else
    Call ECR_TRACE ([F:SRD]ITMREF-[M:MACW]MACSERNUM-":"-mess(WRET,182,2),0) From GESECRAN
  Endif
Return

# Chargement du masque [MACW]
$CHARGE_MACW
Raz [M:MACW]
[M:MACW]MACPDTCOD  = [F:SRD]ITMREF
[M:MACW]MACORIVCR  = [F:SRD]SRHNUM
[M:MACW]MACORIVCRL = [F:SRD]SRDLIN
[M:MACW]MACITNDAT  = [F:SRH]RTNDAT
If [F:ITM]SERMGTCOD < 2
   [M:MACW]MACQTY     = [F:SRD]QTYSTU
Else
   [M:MACW]MACQTY     = abs([F:STJ]QTYSTU)
   [M:MACW]MACSERNUM  = [F:STJ]SERNUM
Endif
#LSE 07/12/2005 FQ 33554
#[M:MACW]MACSTA  = [F:STJ]STA
[M:MACW]MACSTA  = left$([F:STJ]STA,1)
[M:MACW]MACMAITRT= "C"

  # FGR 12/11/2009 : X3SUIVI56282 (début)
  Local Char SZMACWCNT(GLONDES)
  Local Char SZMACWPRE(GLONDES)

  SZMACWCNT = "SUBSRH"
  SZMACWPRE = ""
  Gosub PE_MACWAUTO From TRTCRMPE
  # FGR 12/11/2009 : X3SUIVI56282 (fin)
Return

$TRT_MACRULE_MOD
Local Integer WRET, WTYP

  Raz WRET
  If !clalev ([F:STJ])  : Local File STOJOU     [STJ] : Endif
  WTYP=3
  For NOL=0 To [M:SRH1]NBLIG-1
    If [M:SRH1]UPDFLG(NOL)<>0 & [M:SRH1]RTNSTOUPD(NOL)=2 & [M:SRH1]YRTNSTOUPD(NOL)<>2
      If [F:ITM]ITMREF <> [M:SRH1]ITMREF(NOL)
        Read [ITM]ITM0 = [M:SRH1]ITMREF(NOL)
        If fstat Then
          Raz [F:ITM]
        Endif
      Endif
      If [F:ITM]SERMGTCOD > 1
        # Gestion des no séries
        For [STJ]STJ1 Where STOFCY=[M:SRH0]STOFCY & VCRTYP=13 & VCRNUM=[M:SRH0]SRHNUM
&                         & VCRLIN=[M:SRH1]SRDLIN(NOL) & REGFLG<>2 & ITMREF = [F:ITM]ITMREF
          Gosub CHARGE_MACW_MOD
          # Appel au composant d'intégration
          Call MACRULE(WTYP,[M:SRH0]BPCORD,WRET) From TRTMACRULE
          If WRET Then
            Break 2
          Endif
        Next
        If WRET Then                    # FGR 04/01/2011 : X3SUIVI70100
          Break
        Endif
      Endif
    Endif
  Next
  If WRET
    GOK = 0                             # FGR 04/01/2011 : X3SUIVI70100
    Call ECR_TRACE (mess(90,182,2),0)   From GESECRAN
    Call ECR_TRACE (mess(WRET,182,2),0) From GESECRAN
  Endif
Return

# Chargement du masque [MACW]
$CHARGE_MACW_MOD
Raz [M:MACW]
[M:MACW]MACPDTCOD  = [M:SRH1]ITMREF(NOL)
[M:MACW]MACORIVCR  = [M:SRH0]SRHNUM
[M:MACW]MACORIVCRL = [M:SRH1]SRDLIN(NOL)
[M:MACW]MACITNDAT  = [M:SRH0]ENTRTNDAT
[M:MACW]MACQTY     = abs([F:STJ]QTYSTU)
[M:MACW]MACSERNUM  = [F:STJ]SERNUM

#LSE 07/12/2005 FQ 33554
[M:MACW]MACSTA  = left$([F:STJ]STA,1)
[M:MACW]MACMAITRT= "C"

  # FGR 12/11/2009 : X3SUIVI56282 (début)
  Local Char SZMACWCNT(GLONDES)
  Local Char SZMACWPRE(GLONDES)

  SZMACWCNT = "SUBSRH"
  SZMACWPRE = "MOD"
  Gosub PE_MACWAUTO From TRTCRMPE
  # FGR 12/11/2009 : X3SUIVI56282 (fin)
Return
##########################################################################

$TRT_MACRULE_DOC
Local Integer WRET, WTYP
Local Integer IBFINDRECORD
Local Integer NOL
Local Char SZSERSTOK

  Raz WRET
  IBFINDRECORD=0
  NOL=LLIGDOC
  SZSERSTOK=""
  If !clalev ([F:STJ])  : Local File STOJOU     [STJ] : Endif
  If !clalev ([F:STJW])  : Local File STOJOU     [STJW] : Endif
  WTYP=3
  If [F:ITM]ITMREF <> WSRDITEMLIN
    Read [ITM]ITM0 = WSRDITEMLIN
    If fstat
      Raz [F:ITM]
    Endif
  Endif
  # Gestion des no séries
  If [F:ITM]SERMGTCOD > 1
    If WSRDQTYLIN <>0
      For [STJ]STJ1 Where STOFCY=[M:SRH0]STOFCY & VCRTYP=13 & VCRNUM=[M:SRH0]SRHNUM
&                       & VCRLIN=WSRDLIN & REGFLG<>2 & ITMREF = [F:ITM]ITMREF
        Gosub CHARGE_MACW_DOC
        # Appel au composant d'intégration
        Call MACRULE(WTYP,[M:SRH0]BPCORD,WRET) From TRTMACRULE
        If WRET
          Break
        Endif
      Next
    Else
      If !clalev([F:MACV]) : Local File MACHINES [MACV] : Endif
      Filter [STJ] Where [F:STJ]STOFCY=[M:SRH0]STOFCY & [F:STJ]VCRTYP=13 & [F:STJ]VCRNUM=[M:SRH0]SRHNUM
&                      & [F:STJ]VCRLIN=WSRDLIN & [F:STJ]REGFLG=2
&               Order By [F:STJ]SERNUM Asc; [F:STJ]MVTSEQ Asc
      For [STJ]
        If [F:STJ]SERNUM<>SZSERSTOK
          SZSERSTOK=[F:STJ]SERNUM
          Gosub CHARGE_MACW_DOC
          Filter [MACV] Where MACSERNUM=[M:MACW]MACSERNUM and MACPDTCOD=[M:MACW]MACPDTCOD
&                         and MACORIVCR=[M:MACW]MACORIVCR and MACORIVCRL = [M:MACW]MACORIVCRL
          For [MACV]
            IBFINDRECORD=0
            #ON vérifie qu'iln'y a pas de ligne de stock actif
            Filter [STJW] Where [F:STJW]VCRTYP=13 and [F:STJW]VCRNUM=[M:SRH0]SRHNUM
&                           and [F:STJW]VCRLIN=WSRDLIN and [F:STJW]REGFLG<>2
&                           and [F:STJW]SERNUM=[F:STJ]SERNUM
            For [STJW]
              IBFINDRECORD=1
              Break
            Next
            Filter [STJW]
            If IBFINDRECORD=0
              # Appel au composant d'intégration
              Call MACRULE(WTYP,[M:SRH0]BPCORD,WRET) From TRTMACRULE
              If WRET
                Break
              Endif
            Endif
          Next
          Filter [MACV]
          If WRET Then                  # FGR 04/01/2011 : X3SUIVI70100
            Break
          Endif
        Endif
      Next
      Filter [STJ]
    Endif
  Endif
  If WRET
    GOK = 0                             # FGR 04/01/2011 : X3SUIVI70100
    Call ECR_TRACE (mess(90,182,2),0)   From GESECRAN
    Call ECR_TRACE (mess(WRET,182,2),0) From GESECRAN
  Endif
Return

# Chargement du masque [MACW]
$CHARGE_MACW_DOC

Raz [M:MACW]
[M:MACW]MACPDTCOD  = WSRDITEMLIN
[M:MACW]MACORIVCR  = [M:SRH0]SRHNUM
[M:MACW]MACORIVCRL = WSRDLIN
[M:MACW]MACITNDAT  = [M:SRH0]ENTRTNDAT

[M:MACW]MACQTY     = abs([F:STJ]QTYSTU)
[M:MACW]MACSERNUM  = [F:STJ]SERNUM
[M:MACW]MACSTA  = left$([F:STJ]STA,1)

If WSRDQTYLIN <>0
    [M:MACW]MACMAITRT= "C"
Else
    [M:MACW]MACMAITRT= "A"
Endif
  # FGR 12/11/2009 : X3SUIVI56282 (début)
  Local Char SZMACWCNT(GLONDES)
  Local Char SZMACWPRE(GLONDES)

  SZMACWCNT = "SUBSRH"
  SZMACWPRE = "DOC"
  Gosub PE_MACWAUTO From TRTCRMPE
  # FGR 12/11/2009 : X3SUIVI56282 (fin)
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran SRH0) 02/03/2010 11:46:57 (TS)
######################################################################################
#--- Bug 62980
Subprog AM_ENTRTNDAT(VALEUR)
Variable Date    VALEUR

#--- Contrôle date entrée par rapport aux dates mouvements en attente
If GREP="C" & [M]NBLIG>0
  Local Integer I
  Local Date    LDATRUP, LDAT
  Local Decimal LQTYRUP
  For I=0 To [M]NBLIG-1
    Call CTLRUP([M]STOFCY,[M]ITMREF(I),VALEUR,0,LDATRUP,LQTYRUP) From STKLIB
    If LDAT<LDATRUP LDAT=LDATRUP Endif
  Next I
  If LDAT<>[0/0/0]
    Call MESSAGE(mess(354,184,1)-":\"+mess(355,184,1)-format$("DD2",LDAT)+
&                "\"+mess(357,184,1)-format$("DD2",LDAT)) From GESECRAN
  Endif
Endif
#---

End

