#--- Bug 72649
Subprog C_LOCTYP(VALEUR)
Variable Char    VALEUR()
If [M:SRH1]LOCTYP(nolign-1)<>VALEUR
   Call RAZLOC([M:SRH1]LOC(nolign-1),[M:SRH1]WLOCSEQ(nolign-1)) From STKACT
Endif
#                                                                            # hcb 110327 deb
If dim([M:SRH1]SERNUM) > 0 & [F:ITM]SERMGTCOD = 4 & [F:TLO]LOCCAT = 2 &  [M:SRH1]DETSDHNUM(nolign-1) = ""
   Raz   [M:SRH1]SERNUM (nolign-1)
   Raz   [M:SRH1]SERNUMF(nolign-1)
   Affzo [M:SRH1]SERNUM (nolign-1)
   Affzo [M:SRH1]SERNUMF(nolign-1)
Endif
#                                                                            # hcb 110327 deb
End
#---
######################################################################################
#--CPO 75115 - 275 Nouveau champ SRHTYP
$SRHTYP
Local Integer  CATEG

If !clalev([F:FGR]) : Local File FACGROUP  [FGR] : Endif
If !clalev([F:TRE]) : Local File TABSRHTYP [TRE] : Endif

#--Recherche en fonction de la catégorie paramétrée dans la transaction choisie
CATEG = GDLVTYP
#--Si catégorie = "Toutes"  -> on commence la recherche depuis les "Normales"
If CATEG=4 : CATEG=1 : Endif

Link [TRE] With [FGR]FGR0=[F:TRE]GFY;GCURFCY As [KTRE]

While CATEG <= GDLVTYP & CATEG < 5
    Filter [KTRE] Where SRHCAT=CATEG & ([TRE]GFY="" | [FGR]FCY=GCURFCY) & ([TRE]LEG=GCURLEG | [TRE]LEG="" )
    Read [KTRE]TRE0 First
    If fstat=0
        WSRHTYP = [F:TRE]SRHTYP
        WSRHCAT = [F:TRE]SRHCAT
#        Case [F:TRE]SRHCAT
#          When 1       : WSCORTN=1 : WLNDRTN=1 :# Retour normal
#          When 2       : WSCORTN=1 : WLNDRTN=2 :# Retour de prêt
#          When 3       : WSCORTN=2 : WLNDRTN=1 :# Retour pour sous-traitance
#          When Default : WSCORTN=1 : WLNDRTN=1 :# Au cas où...
#        Endcase
        #--A ce stade on ne peut faire des suppositions sur le caractère normal ou inter-site/soc
        #--On considère que c'est une Retour normal
        GCPT=[F:TRE]CODNUM
        CATEG=5
    Else CATEG+=1
    Endif
Wend
Filter [KTRE]

Return
#--/CPO

######################################################################################
Subprog C_DPEDATR(VALEUR)
Variable Date    VALEUR
# BRBAN 01/09/2014 #93745
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY,'')=1
  End
Endif

# FGR 07/07/2014 : X3SUIVI91606
If VALEUR <> [0/0/0] Then
  If VALEUR > [M:SRH0]ENTRTNDAT Then
    GMESSAGE = mess(400,192,1) - format$(GFMDAT, VALEUR) - ">" - format$(GFMDAT, [M:SRH0]ENTRTNDAT)
    mkstat = 2
    End
  Endif
  #    If [M:SRH2]ARVDATR <> [0/0/0] and VALEUR > [M:SRH2]ARVDATR Then
  #      GMESSAGE = mess(401,192,1) - format$(GFMDAT, VALEUR) - ">" - format$(GFMDAT, [M:SRH2]ARVDATR)
  #      mkstat = 2
  #      End
  #    Endif
Endif
End

######################################################################################
Subprog AM_DPEDATR(VALEUR)
Variable Date    VALEUR

  # FGR 07/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If [M:SRH2]ARVDATR = [0/0/0] or ([M:SRH2]ARVDATR <> [0/0/0] and (VALEUR > [M:SRH2]ARVDATR or [M:SRH2]DPEDATR = [M:SRH2]ARVDATR)) Then
      [M:SRH2]ARVDATR = VALEUR
      Affzo [M:SRH2]ARVDATR
    Endif
  Endif
End

######################################################################################
Subprog C_ARVDATR(VALEUR)
Variable Date    VALEUR

# BRBAN 01/09/2014 #93745
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY,'')=1
  End
Endif

# FGR 07/07/2014 : X3SUIVI91606
If VALEUR <> [0/0/0] Then
  If [M:SRH2]DPEDATR <> [0/0/0] and VALEUR < [M:SRH2]DPEDATR Then
    GMESSAGE = mess(401,192,1) - format$(GFMDAT, [M:SRH2]DPEDATR) - ">" - format$(GFMDAT, VALEUR)
    mkstat = 2
    End
  Endif
Endif

End
