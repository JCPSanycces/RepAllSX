######################################################################################
Subprog C_ETAR(VALEUR)
Variable Char    VALEUR()
If VALEUR="0000" : End : Endif
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY,'')=1
  If [M:SRH2]DPEDATR<>[0/0/0] & [M:SRH2]ARVDATR<>[0/0/0]
    If [M:SRH2]DPEDATR=[M:SRH2]ARVDATR & VALEUR<=[M:SRH2]ETDR
       # BRBAN 107887
       Call ERREUR(mess(98,7711,1)) From GESECRAN
       mkstat=2
    Endif
  Endif
Endif
End
######################################################################################
## Section automatically added (screen SRH1) 15-07-2015 18:23:23 (RMA)
######################################################################################
Subprog C_RTNCNOFLG(VALEUR)
Variable Integer VALEUR

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
If func AFNC.ACTIV("INVCA")

  Local Integer V_NOL : V_NOL = nolign-1

  If VALEUR = 2 & [M:SRH1]DETSDHNUM([L]V_NOL) <> ''

    Local Char V_LEG(30)

    If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
    If [F:CPY]CPY<>GSOCIETE
        Read [CPY] CPY0=GSOCIETE
        If fstat Raz [F:CPY] Endif
    Endif

    Call GETLEG([F:CPY]CPY,"",[L]V_LEG) From TRTLECLEG

    If func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"

      Local Integer RET

      Call INVCAN_NOCREM([M:SRH1]DETSDHNUM([L]V_NOL),[L]RET) From TRTINVCAN

      If [L]RET = 1
        Call ECR_TRACE(mess(194,7711,1),0) From GESECRAN
        mkstat = 2
      Endif

      #Affzo [M:SRH1]RTNCNOFLG
      #Affzo [M:SRH1]
    Endif
  Endif
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

End
######################################################################################
#                                                                            # hcb 110327 deb
Subprog AS_SERNUM(VALEUR)
Variable Char    VALEUR()
If dim([M:SRH1]LOCTYP) > 0
   If  [M:SRH1]LOCTYP(nolign-1) <> [F:TLO]LOCTYP
       Read [TLO]TLO0=[M:SRH0]STOFCY;[M:SRH1]LOCTYP(nolign-1)
       If fstat
          Raz [F:TLO]
       Endif
   Endif
   If [F:ITM]SERMGTCOD = 4 & [F:TLO]LOCCAT = 2 & [M:SRH1]DETSDHNUM(nolign-1) = ""
      mkstat = 2
   Endif
Endif
End
#                                                                            # hcb 110327 deb

