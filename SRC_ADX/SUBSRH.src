# 71065 : PJT
######################################################################################
## Etiquette ajoutée par le superviseur (écran SRH2) 13/07/2006 10:14:41 (LD)
######################################################################################
Subprog C_NBAXE

If !find(status,1,4,5,20,21,26,92,93) | GIMPORT End : Endif
#----- Contrôle Sections d'entête obligatoires si saisissables -----#
If [M:SRH2]NBAXE>0 & GHEADIE=1
  Local Integer I
  For I=1 To [M:SRH2]NBAXE
    If CCE(I-1)="" & GOBLDIE(I)=2
      mkstat=1 : GMESSAGE= mess(46,106,1)-GDIE(I) : Break
    Endif
  Next I
Endif
End
######################################################################################
#########################################################################
#                     ECRAN DES LIGNES : SRH1                           #
#########################################################################
Subprog IB_NBLIG
Local Integer NOL : NOL = nolign-1

# Bouton  1 : Saisie texte ligne
# Bouton  2 : Saisie des entrées
# Bouton  3 : Appel sous-pro INFOLOT
# Bouton  4 : Fenêtre complément lot
# Bouton  5 : Fenêtre détail en modification
# Bouton  6 : Tunnel livraison
# Bouton  7 : Tunnel avoir
# Bouton  8 : Tunnel retour fournisseur
# Bouton 10 : Traçabilité pièces ventes SYMEU 08/12/2008
# Bouton 11 : Situation ligne MABON 02/02/09
# Issue X3-77865 - 2018-05-07 by JUSYN : Non-conformance buttons
# Bouton 12 : Create non-conformance
# End issue X3-77865

# MHB 19/12/08 : ajout n° pièce sur intitulés clics droits
GBOUT6  = GBOUT6-[M]DETSDHNUM(nolign-1) : # Livraison
GBOUT7  = GBOUT7-[M]SIHNUM(nolign-1)    : # Avoir
GBOUT8  = GBOUT8-[M]PNHNUM(nolign-1)    : # Retour fournisseur
GBOUT11 = mess(164,198,1)               : # Situation ligne

If nolign <= [M]NBLIG
    If [M:SRH1]RTNSTOUPD(NOL) = 2
        If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=6;GFLAG
                                If fstat Raz [F:SLT] Endif
                                Endif
        # --> Particularité retour
        #     Ligne déjà créée  et flag maj stock était déjà à oui       bt B5 : Fenêtre détail en modification
        #     Ligne déjà créée  et flag maj stock est passé de non à oui bt B2 : Saisie des entrées
        #     Ligne en création et flag maj stock à oui                  bt B2 : Saisie des entrées
        #     [M]WSTOUPD est utilisé dans l'action SAISTOENT avec [M]CREFLG
        #              PARMSK(3) = "WQSRH"+GFLAG+mid$("SM",(!!([M:SRH1]CREFLG(nolign-1)))+1,1)
        #      devient PARMSK(3) = "WQSRH"+GFLAG+mid$("SM",((!!([M:SRH1]CREFLG(nolign-1)))&![M:SRH1]WSTOUPD(nolign-1))+1,1)
        Call STKINIBTN( 2, 5, 3, 4, "SRH1", "SLT", [M:SRH1]ITMREF(nolign-1), [M:SRH0]STOFCY ) From STKENT
    Else
        Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5
    Endif
    If [M]DETSDHNUM(NOL) = ""  Raz GBOUT6 : Endif
    If [M]SIHNUM(NOL) = ""     Raz GBOUT7 : Endif
    If [M]PNHNUM(NOL) = ""     Raz GBOUT8 : Endif
Else
    Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8, GBOUT11
Endif
# SYMEU 08/12/2008 : branchement traçabilité pièces
If find(GREP,"C","D") or find("CONSPIV",GNAVIG(1..GPILNAV)) Then Raz GBOUT10 Endif

#85785 * RMA * can't change the document values if validated
If func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY, "") & [M]SRHCFMFLG = 2
  Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5
Endif

# Issue X3-77865 - 2018-05-07 by JUSYN : Non-conformance buttons
# Issue X3-102712 - only display create button if not in create/amend/delete/duplicate mode
If func AFNC.ACTIV("NCS") and !find (GREP, "C","D","M","A")
     GBOUT12 = mess(508,198,1) # Create Non-conformance
Else
     Raz GBOUT12
Endif

# End issue X3-77865

End
##########################################################################
## Etiquette ajoutée par le superviseur 21/05/2003 15:54:48 (LD)
##########################################################################
Subprog AVANT_NBLIG
Local Integer NOL : NOL=nolign-1

If status=75
    Call SRHINIZONENT
Else
    If [M:SRH1]STOMGTCOD(NOL)<>1 & [M:SRH1]RTNSTOUPD(NOL)=2
        # Si ligne gérée en stock
        # --> Lecture article et règle de gestion
        Call LECFICENT([M:SRH0]STOFCY,[M:SRH0]BPCORD,"",nolign-1,12,[M:SRH0]TRSCOD,0) From STKECR
    Endif
    If find(status, 73, 82) :     # Insertion de ligne
        Actzo [M:SRH1]ITMREF(NOL)
    Endif
Endif

If GMODIF = 2
# --> Création d'une ligne : Initialisation des champs
    If [M]ENTRTNDAT = [0/0/0] | (date$ > [M]ENTRTNDAT & GREP="M")
        [M]DETRTNDAT(NOL) = date$
    Else
        [M]DETRTNDAT(NOL) = [M]ENTRTNDAT
    Endif
Endif

# ------------------------ #
# Suppression d'une ligne  #
# ------------------------ #
If find(status,65,68,83)
    If [M]DETSDHNUM(NOL)<>""
        # Ligne issue d'une livraison : Réincrémenter la qté à retourner (pr les ctrls)
        For  I = 0 To [M:SRH1]NBLIG -1
            If [M]DETSDHNUM(I) = [M]DETSDHNUM(NOL) & [M]SDDLIN(I) = [M]SDDLIN(NOL)
                [M]DLVQTYSTU(I) += [M]XQTYSTU(NOL)
            Endif
        Next I
    Elsif [M]PNHNUM(NOL)<>""
        # Ligne issue d'un retour fsseur : Réincrémenter la qté à retourner (pr les ctrls)
        For  I = 0 To [M:SRH1]NBLIG -1
            If [M]PNHNUM(I) = [M]PNHNUM(NOL) & [M]PNDLIN(I) = [M]PNDLIN(NOL)
                [M]PNDQTYSTU(I) += [M]XQTYSTU(NOL)
            Endif
        Next I
    Endif
Endif

End
########################################
Subprog C_NBLIG
Local Integer NOL

# Valeurs de GMODIF :
#    0 = Modification ligne (status=75)
#    1 = Suppression ligne  (status=65,68,83)
#    2 = Nouvelle ligne

GMODIF=2

If [M]NBLIG=0
   Actzo [M:SRH0]STOFCY, BPCORD, BPAADD
   Actzo [M:SRH0]SRHTYP                   :#--CPO 75115
Else
   Diszo [M:SRH0]STOFCY, BPCORD, BPAADD
   Diszo [M:SRH0]SRHTYP                   :#--CPO 75115
Endif

NOL=nolign-1
# --> Controle de suppression de lignes
If status = 65
   GMODIF=1
   # --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection livraison'
   If [M:SRH1]DETSDHNUM(NOL)<>"" & [M:SRH1]PNHNUM(NOL)="" & [M:SRH1]CREFLG(NOL)=0
      GMESSAGE=mess(223,192,1) : mkstat=2 : End
   Endif
   # --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection retours fournisseur'
   If [M:SRH1]PNHNUM(NOL)<>"" & [M:SRH1]CREFLG(NOL)=0
      GMESSAGE=mess(273,192,1) : mkstat=2 : End
   Endif
   # --> Ligne gérée en stock : Suppression ssi la ligne n'a pas encore été crée
   If [M:SRH1]RTNSTOUPD(NOL)=2
       If [M:SRH1]CREFLG(NOL)=0
           Call DELSTOENTW (NOL,NOL,"SRH1",1,1,[M:SRH0]STOFCY,1,"") From STKENT
       Else
           # La suppression d'une ligne validée doit se faire via la fenêtre de modification
           GMESSAGE = mess (6,184,1) : mkstat = 2
       Endif
   Endif
   Gosub TEST_MOD_ANU : If mkstat=2 End : Endif
Endif
If status = 68 | status = 83
   GMODIF=1
   For NOL=nolign-1 To nolign1-1
      # --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection livraison'
      If [M:SRH1]DETSDHNUM(NOL)<>"" & [M:SRH1]PNHNUM(NOL)="" & [M:SRH1]CREFLG(NOL)=0
         GMESSAGE=mess(223,192,1) : mkstat=2 : Break
      Endif
      # --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection retours fournisseur'
      If [M:SRH1]PNHNUM(NOL)<>"" & [M:SRH1]CREFLG(NOL)=0
         GMESSAGE=mess(273,192,1) : mkstat=2 : Break
      Endif
      # --> Ligne gérée en stock : Suppression ssi la ligne n'a pas encore été crée
      If [M:SRH1]CREFLG(NOL)<>0 & [M:SRH1]RTNSTOUPD(NOL)=2
          # La suppression d'une ligne validée doit se faire via la fenêtre de modification
          GMESSAGE = mess (6,184,1) : mkstat=2 : Break
      Endif
      Gosub TEST_MOD_ANU : If mkstat Break : Endif
   Next NOL
   If !mkstat Call DELSTOENTW (nolign-1,nolign1-1,"SRH1",1,1,[M:SRH0]STOFCY,1,"") From STKENT : Endif

Endif
# Controle en modification
If status = 75
   GMODIF=0 : NOL=nolign-1
   Gosub TEST_MOD_ANU : If mkstat End : Endif
Endif

#RMA * 85785
# Issue 112570 - 2015-11-17 by BRBAN
If func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY, "")
  If [M:SRH0]SRHCFMFLG = 2 & (find (status,65,68,83,73))# | GMODIF = 2)
    GMESSAGE = mess(51,7711,1) - mess(654,7773,1)
    mkstat = 2
    End
  Endif
Endif

# X3-80406 - if non-conformance exist, check if user wishes to delete
If func AFNC.ACTIV ("NCS") and (find (status,65,68,83))
    Local Integer LOK
    Local Integer EXISTS
    Local Char NCSMESS(255)
    [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (2, [M:SRH0]SRHNUM, [M:SRH1]SRDLIN(NOL), [L]NCSMESS, 1)
    # check if user wishes to continue
    If (EXISTS > 0)
        Call OUINON([L]NCSMESS,LOK) From GESECRAN
        If LOK = 1
            GMESSAGE = ""
            mkstat = 2
            End
        Endif
    Endif
Endif
# X3-80406 - end

End



Subprog APRES_NBLIG
#-----------------#
# Après ligne STD #
#-----------------#
If GIMPORT | GWEBSERV
  Gosub AAPRES_NBLIG : # Si import ou Web il faut appeler le début de l'action SAISTOENT !
Endif
End

########################################
$AAPRES_NBLIG
#---------------------------------------------------#
# Appel sous-pro OUVENT pour déterminer l'ouverture #
#       de la fenêtre détail SAISTOENT              #
#---------------------------------------------------#
Local Shortint WRET
Local Char     LSUP(1)
Local Shortint NOL : NOL=nolign-1

If [M:SRH1]STOMGTCOD(NOL)=1 | [M:SRH1]RTNSTOUPD(NOL)=1 | [M:SRH1]QTY(NOL)=0
  Raz GOUVENT :  Return
Endif
If [F:ITM]ITMREF<>[M:SRH1]ITMREF(NOL)
  Read [ITM]ITM0=[M:SRH1]ITMREF(NOL)
  If fstat Raz [F:ITM] : Endif
Endif
If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=6;GFLAG
                        If fstat Raz [F:SLT] : Endif
                        Endif
# Controle ouverture fenetre saisie des entrées
# Pour cela aliment les variables GOUVENT et GOUVLOT
# Grise les champs ne pouvant plus être modifiés (sous-pro STKDISLIG)
# LSUP = Option : "O"=Même si WSTOFLG=0, garder ce qui se trouve déjà dans STOENTW (lignes liées à la liv)
#If [M:SRH1]DETSDHNUM(NOL)<>"" LSUP="O" Endif

# Issue X3-58977
If [F:ITM]STOMGTCOD>1 & !find([M:SRH1]SAU(NOL),[F:ITM]STU,[F:ITM]PCU)
  [M:ENTW]WZONPCU = "STU"
  [M:ENTW]WZONQUC = "QTYSTU"
Else
  [M:ENTW]WZONPCU = "SAU"
  [M:ENTW]WZONQUC = "QTY"
Endif
# End issue X3-58977

Call OUVENT([M:SRH0]STOFCY,"SRH1",12,[M:SRH0]TRSCOD,[M:SRH0]BPCORD,13,
&           [M:SRH1]DETRTNDAT(NOL),NOL,[M:SRH1]NBLIG,"SLT",LSUP,WRET) From STKENT

Return
########################################
#-----------------------------------------------#
# fenêtre détail en modification                #
#-----------------------------------------------#
$AB5_NBLIG
Local Shortint NOL : NOL=nolign-1

#-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
# hcb 27842
Raz GBIDI2
GFCY=[M:SRH0]STOFCY
GBIDC2="K" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)
   GOUVENT=0
   Return
Endif

If [M:SRH0]SRHNUM<>""
  SYMBOLE2="SRH"+[M:SRH0]SRHNUM
  Lock=SYMBOLE2
  If fstat
    GMESSAGE=[M:SRH0]SRHNUM-mess(10,100,1)
    Call ERREUR(GMESSAGE) From GESECRAN
    GOUVENT=0
    Return
  Endif
Endif
GOUVENT=2
Return
########################################
$BB5_NBLIG
If [M:SRH0]SRHNUM<>""
  SYMBOLE2="SRH"+[M:SRH0]SRHNUM
  Unlock=SYMBOLE2
Endif
If GRELITSRH=1
  mkstat=4
Endif
Return
# -------------------------------------- ITMREF ------------------------
########################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
If [M]CREFLG(nolign-1)<>0 | [M]UPDFLG(nolign-1)<>0 mkstat=2 : Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SRH1) 23/03/2006 13:26:46 (LD)
######################################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

#--> Test présence article maitre
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat GMESSAGE=mess(8,192,1) : mkstat=2 : End : Endif
Endif
# On vérifie que la date de retour est bien >= la date de début de vie de l'article
If [F:ITM]LIFSTRDAT<>[0/0/0] & [M:SRH0]ENTRTNDAT<[F:ITM]LIFSTRDAT
   mkstat=2 : GMESSAGE=mess(331,199,1)-":"-format$(GFMDAT,[F:ITM]LIFSTRDAT) : End
Endif
# Pour les retours inter-site, on vérifie que l'article est toujours vendu ou livrable
If [M:SRH1]BETFCY=2
    If [F:ITM]SALFLG<>2 & [F:ITM]DLVFLG<>2 GMESSAGE = mess(515,199,1) : mkstat=2 : End  Endif
Else
# Sinon on vérifie que l'article est toujours vendu
    If [F:ITM]SALFLG<>2 GMESSAGE=mess(221,199,1) : mkstat=2 : End : Endif
Endif
#--- Issue 112531 by TS
If [F:ITM]DLVFLG<>2
  GMESSAGE=VALEUR-":"-mess(501,192,1) : mkstat=2 : End
Endif
#---
End
########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL

NOL = nolign-1
[M]SAU(NOL)       = [F:ITM]SAU
[M]SAUSTUCOE(NOL) = [F:ITM]SAUSTUCOE
[M]DACSAUCOE(NOL) = [F:ITM]DACSAUCOE

If clalev ([F:ITU])=0 Local File ITMBPC [ITU] Endif
If [F:ITU]ITMREF <> VALEUR | [F:ITU]BPCNUM <> [M:SRH0]BPCORD
   Read [ITU] ITU0=VALEUR;[M:SRH0]BPCORD
   If fstat Raz [F:ITU] Endif
Endif
If [F:ITU]SAU <> ""
    [M]SAU(NOL) = [F:ITU]SAU
    [M]SAUSTUCOE(NOL) = [F:ITU]SAUSTUCOE
    [M]DACSAUCOE(NOL) = 1
Endif
[M]STU(NOL)       = [F:ITM]STU
[M]STOMGTCOD(NOL) = [F:ITM]STOMGTCOD
If [F:ITM]STOMGTCOD>1
    If [F:ITF]ITMREF<>VALEUR | [F:ITF]STOFCY<>[M:SRH0]STOFCY
        Read [ITF] ITF0=VALEUR;[M:SRH0]STOFCY
        If fstat Raz [F:ITF] : Endif
    Endif
    If [F:ITF]STOMGTCOD>0 [M]STOMGTCOD(NOL) = [F:ITF]STOMGTCOD Endif
Endif

#--- Bug 62980
#--- Contrôle date entrée par rapport aux dates mouvements en attente
If [M]STOMGTCOD(NOL)>1
  Local Date    LDATRUP
  Local Decimal LQTYRUP
  Call CTLRUP([M]STOFCY,VALEUR,[M]DETRTNDAT(NOL),1,LDATRUP,LQTYRUP) From STKLIB
Endif
#---

# Désignation standard
#[M]ITMDES1(NOL)   = [F:ITS]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX", GLANGUE,[F:ITM]ITMREF,[M:SRH1]ITMDES1(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
# Désignation traduite
#Call CHARGE_ITMDES("DES1AXX", [M:SRH0]LAN,[F:ITM]ITMREF,[M:SRH1]ITMDES(NOL)) From TRTX3
#If [M:SRH1]ITMDES(NOL) = "" [M:SRH1]ITMDES(NOL) = [M:SRH1]ITMDES1(NOL) Endif
Call CHARGE_DEFITMDES("DES1AXX", [M:SRH0]LAN,[F:ITM]ITMREF,[M:SRH1]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129

# A cause de l'INISEC "SRD" qui peut être paramétré avec [F:PND]
If GMODU(6)=2 & GOPTCANA>0 Raz [F:PND] : Endif

# Au départ Pas de mise à jour des stock : il faut que la qté retour soit renseignée
Raz [M]RTNREN(NOL), [M]RTNSTOUPD(NOL),[M]RTNINVUPD(NOL),[M]ORDUPD(NOL), [M]WSTOUPD(NOL)
Raz [M]GESLOT(NOL), [M]WSTOSEQ(NOL), [M]WSTOFLG(NOL), [M]WSRUFLG(NOL)
Call STKRAZGRILIG("SRH1", NOL) From TRTVENSTK
[M]WSTOFLG(NOL)=2 : # Article non géré en stock

Affzo [M]ITMDES(NOL),ITMDES1(NOL),SAU(NOL), SAUSTUCOE(NOL), STU(NOL), RTNSTOUPD(NOL)

If [M]DACSAUCOE(NOL) < 2
    Diszo [M]SAUSTUCOE(NOL)
Else
    Actzo [M]SAUSTUCOE(NOL)
Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 12/05/2003 10:04:33 (LD)
