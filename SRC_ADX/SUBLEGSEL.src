#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(250)(1..) , VALEUR(20)
End

$ACTION
  Case ACTION
    When "DEBUT"        : Gosub DEBUT
    When "END"          : Gosub _END
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When Default
  Endcase
Return

$DEBUT
  Local Integer COUNTER
  For COUNTER = 1 To maxtab(PARAM)
    [M:LEGSEL]LEGISLATION(COUNTER - 1) = PARAM(COUNTER)
  Next
  [M:LEGSEL]NBLIG = (COUNTER - 1)
  [M:LEGSEL]SELECTED(0) = 2

  Affzo [M:LEGSEL]
Return

$_END
  If dim(GGESADSDOSLEG) > 0
    Kill GGESADSDOSLEG
  Endif
Return

$APRES_MODIF
#  Gosub TOGGLE_BOXES
Return

Subprog C_NBLIG
  If nolign > [M:LEGSEL]NBLIG : End : Endif

  If [M:LEGSEL]SELECTED(nolign-1) = 2
    [M:LEGSEL]SELECTED(nolign-1) = 1
  Else
    [M:LEGSEL]SELECTED(nolign-1) = 2
  Endif
  Gosub TOGGLE_BOXES
End

Subprog AM_NBLIG
#  If nolign > [M:LEGSEL]NBLIG : End : Endif
#  Gosub TOGGLE_BOXES
End

$TOGGLE_BOXES
  If [M:LEGSEL]SELECTED(nolign-1) = 2
    Local Integer CNT
    For CNT = 0 To nolign
      [M:LEGSEL]SELECTED(CNT) = 1
    Next
    [M:LEGSEL]SELECTED(nolign-1) = 2
  Endif

  If dim(GGESADSDOSLEG) < 1
    Global Integer GGESADSDOSLEG
  Endif
  GGESADSDOSLEG = nolign
  Affzo [M:LEGSEL]
Return

