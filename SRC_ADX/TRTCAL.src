######################################################################################
## Section automatically added (screen TRTCAL) 01/16/2017 09:25:00 (JOJAC)
######################################################################################
Subprog AM_ALLPERCOD(VALEUR)
Variable Integer VALEUR
Local Char VALBOUT : VALBOUT = ""
Local Char PARBOUT : PARBOUT = "HRPER0"
Global Char GFRQCOD
Local Date STR2, END2
Local Date STR2, END2
Local Integer TAXYEA, TAXMON
Local Integer NBPERNUM,NUMPERNUM
Local Char LIBHRPEO(130)(0..100)
Local Integer    TBPERNUM(GLONVCR)(0..100)
Local Char    TITBOITE(250)

Local Mask TRTCAL [TRTCAL]
GFRQCOD=[M:DIA]PERCOD

If VALEUR <> [M]ALLPERCOD
  If VALEUR = 1
    #GFRQCOD=[M:DIA]PERCOD
    If !clalev([F:HRPEOD]) : Local File HRPEODET [HRPEOD] : Endif
    If !clalev([F:HRPEOH]) : Local File HRPEOHEA [HRPEOH] : Endif

    [L]STR2 = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
    [L]END2 = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))


       Link [F:HRPEOD]
&      With [F:HRPEOH]HRPEOH0 = [F:HRPEOD]PERYEA;[F:HRPEOD]PERCOD
&      As [LNK]
&      Where [F:HRPEOD]PERCOD=GFRQCOD & [F:HRPEOH]FLGENA=2
&          & (month([F:HRPEOD]PERSTR(1))=month([L]STR2) or month([F:HRPEOD]PEREND(1))=month([L]END2))
&          & (year([F:HRPEOD]PERSTR(1))=year([L]STR2) or year([F:HRPEOD]PEREND(1))=year([L]END2))

If rowcount([LNK]) = 0
#MIPEA - 2017-02-14- X3-11346- START
  GERR = 2 : GMESSAGE = [M:DIA]PERCOD + " - " + mess(00164,00107,1)+ " " + format$(GFMD,[L]STR2) + " to " + format$(GFMD,[L]END2) + " " + mess(00002,00126,1)
#  Infbox [M:DIA]PERCOD + "- extraction period for paymonth " + format$(GFMD,[L]STR2) + " to " + format$(GFMD,[L]END2) + " is inactive or does not exist"
#MIPEA - 2017-02-14- X3-11346- END
  [M:DIA]ALLPERCOD = 2 : Affzo [M:DIA]ALLPERCOD
  Raz [M:DIA]PERCOD : Affzo [M:DIA]PERCOD
Endif

    [L]TAXMON = [F:HRPEOD]TAXMON
    [L]TAXYEA = [F:HRPEOD]PERYEA

    For [LNK]
      NBPERNUM+=1
      TBPERNUM(NBPERNUM) = [F:HRPEOD]PERNUM
      LIBHRPEO(NBPERNUM) = num$([F:HRPEOD]PERNUM)-num$([F:HRPEOD]PERSTR(1))-"-"-num$([F:HRPEOD]PEREND(1))
    Next

    Call SAITEX(NBPERNUM,LIBHRPEO,NUMPERNUM,TITBOITE) : # Choose period

     Link [F:HRPEOD]
&    With [F:HRPEOH]HRPEOH0 = [F:HRPEOD]PERYEA;[F:HRPEOD]PERCOD
&    As [LNK]
&    Where [F:HRPEOD]PERCOD=GFRQCOD & [F:HRPEOH]FLGENA=2
&        & [F:HRPEOD]PERNUM=TBPERNUM(NUMPERNUM)

    Read [LNK] First
    If !fstat
      [M:DIA]PERNUM     = [F:HRPEOD]PERNUM    : Affzo [M:DIA]PERNUM    : Grizo [M:DIA]PERNUM
      [M:DIA]DATPAYSTR  = [F:HRPEOD]PERSTR(1) : Affzo [M:DIA]DATPAYSTR : Grizo [M:DIA]DATPAYSTR
      [M:DIA]DATPAYEND  = [F:HRPEOD]PEREND(1) : Affzo [M:DIA]DATPAYEND : Grizo [M:DIA]DATPAYEND
    Endif
  Else
    Local Mask TRTCAL [DIA]
    #Raz [M:DIA]
    If clalev([M:VEP0])>0
     [M:DIA]DATPAYSTR = min([M:VEP0]PYRDAT,[M:VEP1]STRDAT)
     [M:DIA]DATPAYEND = max([M:VEP0]PYRDAT,[M:VEP1]ENDDAT)
    Else
     [M:DIA]DATPAYSTR = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","","")) : Affzo [M:DIA]DATPAYSTR
     [M:DIA]DATPAYEND = gdat$(func DIVPAYE.INIPARUSR("FINPAY","","")) : Affzo [M:DIA]DATPAYEND
     DATPAYE   = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
     Call LECMEMO("STD","[M:DIA]","cal") From GMEMO
     Call AFF_MEMO From DIVPAYE: #81085
    Endif

  Endif
Endif

#JOJAC - 2017-01-31 - START
If VALEUR = 2
  Raz [M:DIA]PERNUM     : Grizo [M:DIA]PERNUM
  Raz [M:DIA]DATPAYSTR  : Actzo [M:DIA]DATPAYSTR : [M:DIA]DATPAYSTR = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","","")) : Affzo [M:DIA]DATPAYSTR
  Raz [M:DIA]DATPAYEND  : Actzo [M:DIA]DATPAYEND : [M:DIA]DATPAYEND = gdat$(func DIVPAYE.INIPARUSR("FINPAY","","")) : Affzo [M:DIA]DATPAYEND
Endif
#JOJAC - 2017-01-31 - END
End
End

#########################################################
Subprog SAITEX(NBLIB,TBLIB,VALEUR,TIT)
Value    Integer NBLIB
Value    Char    TBLIB()
Variable Integer VALEUR
Value    Char    TIT()
Local Integer NBCOL
Onerrgo ERDIM
NBCOL = dim(TBLIB,2)
Onerrgo
NBCOL = min(dim(TIT)-1,NBCOL)
If NBCOL<=0
 Selbox TBLIB(1..NBLIB) Titled TIT  Using VALEUR
 If status=7 : VALEUR = 0 : Endif
Else
 Call SAITEX_COL(NBLIB,TBLIB,VALEUR,TIT)
Endif
End

Subprog SAITEX_COL(NLIB,VLIB,VALEUR,TIT)
Value Integer NLIB
Value Char    VLIB()(1..,1..)
Variable Integer VALEUR
Value Char    TIT()(0..)
Local Integer SIZCOL , SIZLIG
SIZCOL = 240
SIZLIG = 80
End

$ERDIM
NBCOL = 0
Resume

######################################################################################
## Section automatically added (screen TRTCAL) 02/07/2017 08:30:47 (JOJAC)
######################################################################################
Subprog AM_PERCOD(VALEUR)
Variable Char    VALEUR()

  [M]ALLPERCOD = 2 : Affzo [M]ALLPERCOD
  Raz [M]PERNUM : Affzo [M]PERNUM : Grizo [M]PERNUM

End


