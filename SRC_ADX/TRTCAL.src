Variable Char    VALEUR()

If VALEUR <> [M]LEG
  GCURLEG=VALEUR
#JASMI - 2017-02-13 - START
#  Gosub OUVFIC From ="WP"+GCURLEG+"PLAN"
#JASMI - 2017-02-13 - END
Endif

End
