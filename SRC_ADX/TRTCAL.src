#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du masque TRTCAL
####################################################################################################################
# HCM V8 :
# To manage the filter by GCURLEG on the main process    : Not yet
# To manage the filter on new concept of population      : Not yet
###################################################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTCAL","TRTCAL",4,"") From GTRAITE
End

#########################################
## Traitement des actions : TRTCAL
# GBIDI1 = 0 : Calcul du bulletin
# GBIDI1 = 1 : Calcul pas à pas
#########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : If GBIDI1=0 : Gosub EXEC : Endif
 When "SORTIE"      : Gosub SORTIE
 When "BOUTON"      : Gosub BOUTON
 When Default
  Case BOITE
   When "TRTCAL"    : Gosub BULLETIN
   When "TRTCALPAS" : Gosub PASAPAS
  Endcase
Endcase
Return

$BULLETIN
Case ACTION
 When "DEBUT"       : Gosub DEBUT_BULLETIN
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1
Endcase
Return

$PASAPAS
Case ACTION
 When "OUVRE"       : If GBIDI1=0 : FIN = 1 : Endif
 When "DEBUT"       : Gosub DEBUT
 When "SUI"         : Gosub RUB_SUIV
 When "FIR"         : Gosub PREMIER
 When "APRES_MODIF"
  If COUZON="AMT" | COUZON="RAT" | COUZON="BAS"
   Gosub CHANGE_MONT
  Elsif COUZON="EXPR"
   Gosub EVALE
  Endif
 When "BOUTON"      : If BOUT="A" : Gosub ALLER_SUR_RUB : Endif
 When "FIN"
  If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif
Endcase
Return


################################################
$DEBUT_BULLETIN
#Multi-legislation
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Affzo [DIA]: Setmok [DIA] With 0
Call AFF_MEMO From DIVPAYE: #81085
#JOJAC - 2017-01-31 - START
If [M:DIA]ALLEXTPER = 2
  Diszo [M:DIA]ALLPERCOD
Endif
#JOJAC - 2017-01-31 - END
Return

################################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#######################################################
## (Actions nécessaires à la saisie des paramètres)
#######################################################
$OUVRE
Local Char    VALPAR(10) , MATRI(GLONEML)
Local Integer NBPCE , OKC
Local Date    DATPAYE , DATMAT
Local Char    BULLETIN(GLONVCR)

Global Integer GFLGERR

Gosub OUVFIC
#MIPEA - 2017-02-14- X3-11346- START
#MIPEA - 2016-11-16 - X3PEOP-773- START
#If GCURLEG<>""
#  Gosub OUVFIC From ="WP"+GCURLEG+"PLAN"
#Endif
#MIPEA - 2017-02-13- X3-11346- END
#Gosub OUVFIC From ="WP"+GCURLEG+"PLAN"
#MIPEA - 2016-11-16 - X3PEOP-773- END

TIT = mess(9,10703,1)     : # Calcul des bulletins de paye

Local Mask TRTCAL [DIA]
Raz [M:DIA]
If clalev([M:VEP0])>0
 [M:DIA]ALLCPY    = 2
 [M:DIA]ALLFCY    = 2
 [M:DIA]ALLSRV    = 2
 [M:DIA]ALLPRF    = 2
 [M:DIA]MATDEB    = [M:VEP0]EMP
 [M:DIA]MATFIN    = [M:VEP0]EMP
 [M:DIA]DATPAYSTR = min([M:VEP0]PYRDAT,[M:VEP1]STRDAT)
 [M:DIA]DATPAYEND = max([M:VEP0]PYRDAT,[M:VEP1]ENDDAT)
 [M:DIA]ENAFLG    = 2
 GSTATUT  = GSTAOK
 GBIDI1   = 1
Else
 [M:DIA]DATPAYSTR = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
 [M:DIA]DATPAYEND = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
 DATPAYE   = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
 Call LECMEMO("STD","[M:DIA]","cal") From GMEMO
 Call AFF_MEMO From DIVPAYE: #81085
Endif
Return

######################################################
## Ouverture des tables
######################################################
$OUVFIC
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif
If clalev([F:VEP])=0 : Local File VALEMP     [VEP] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:HSP])=0 : Local File HISTOPAYE  [HSP] : Endif
If clalev([F:CRB])=0 : Local File CALRUB     [CRB] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE   [RUB] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA] : Endif
If clalev([F:ECT])=0 : Local File EMPCTR     [ECT] : Endif
#MIPEA - 2016-07-05 - REQ 114309 US134 - START
#Gosub OUVRE From DEFTABLE
Gosub OUVRE From WPDEFTABLE
#MIPEA - 2016-07-05 - REQ 114309 US134 - END
If ! clalev([F:RET]) : Local File RETRO    [RET] : Endif
If ! clalev([F:RES]) : Local File RETROSAL [RES] : Endif
If ! clalev([F:REC]) : Local File RETROCAL [REC] : Endif
If clalev([F:VEP2])=0 : Local File VALEMP     [VEP2] : Endif
#MIPEA - 2016-07-05 - REQ 114309 US134 - START
#BRBAN 27-05-2014  Table opening for KPO
If func AFNC.ACTIV("KPO")>0
  If clalev([F:VRA])=0 : Local File VARIA      [VRA] : Endif
  If clalev([F:RUB])=0 : Local File RUBRIQUE   [RUB] : Endif
  If clalev([F:TIP])=0 : Local File TIMEMP     [TIP] : Endif
  #If clalev([F:TIG])=0 : Local File TIMREGUL   [TIG] : Endif
  If clalev([F:HRLOD])=0 : Local File LEGOBGSETD [HRLOD] : Endif
  If clalev([F:PEO])=0 : Local File PERIOD     [PEO] : Endif

  # Issue 109533 - 2015-10-15 by BRBAN : Need to calculate SEG_AT & X_ND_SGRGT
  If clalev([F:WAR])=0 : Local File TRVACCRAT  [WAR]  : Endif
  #JOJAC - 2016-09-30 - X3PEOP-751 - START
  #If clalev([F:HRSIT])=0 : Local File SITEPAYE   [HRSIT]  : Endif
  If clalev([F:FCY])=0 : Local File FACILITY   [FCY]  : Endif
  #JOJAC - 2016-09-30 - X3PEOP-751 - END
  If clalev([F:VLA])=0 : Local File VALEUR     [VLA]  : Endif

  # Issue 111738 - 2016-02-02 by BRBAN : Need to calculate AUS_CONS
  #If !clalev([F:PLN])  : Local File PLANTYP    [PLN] : Endif
  #If !clalev([F:PLN2]) : Local File PLANTYP   [PLN2] : Endif
  #If !clalev([F:WTY])  : Local File TYPWEEK    [WTY] : Endif
  If !clalev([F:TIP2]) : Local File  TIMEMP  [TIP2]  : Endif
  #If !clalev([F:WHLY]) : Local File  HLYDAY  [WHLY]  : Endif
Endif
#-
# Issue 110164 - 2016-01-19 by BRBAN : Table opening for KOA leg
If func AFNC.ACTIV('KAO')>0
  If !clalev([F:HSAO]) : Local File HISTOPAYE [HSAO] : Endif
  #If !clalev([F:PLN])  : Local File PLANTYP    [PLN] : Endif
  #If !clalev([F:PLN2]) : Local File PLANTYP   [PLN2] : Endif
  #If !clalev([F:WTY])  : Local File TYPWEEK    [WTY] : Endif
  If !clalev([F:TIP])  : Local File TIMEMP     [TIP] : Endif
  #If !clalev([F:TIG])  : Local File TIMREGUL   [TIG] : Endif
  If !clalev([F:CHDA]) : Local File EMPLOCHD  [CHDA] : Endif
Endif
#MIPEA - 2016-07-05 - REQ 114309 US134 - END

#JASMI - 2017-05-16 - START
If clalev([F:HRPEOD])=0 : Local File HRPEODET   [HRPEOD] : Endif
If clalev([F:HRPEOH])=0 : Local File HRPEOHEA   [HRPEOH] : Endif
If func AFNC.ACTIV("KZA")>0
  If clalev([F:ETR])=0 : Local File EMPLOTAXREC [ETR] : Endif
Endif
If func AFNC.ACTIV("KAFR")
  If clalev([F:ETA])=0 : Local File EMPLOTAXAFR [ETA] : Endif
Endif
#JASMI - 2017-05-16 - END

Return

######################################################
$BOUTON
Case BOITE
 When "TRTCAL"
  Case BOUT
   When "R" :
    # Button "Rappel MEMO"
    Call AFF_MEMO From DIVPAYE
   Endcase
 When "TRTCALPAS"
  Case BOUT
   When "A"
    Gosub ALLER_SUR_RUB
   Endcase
 Endcase
Return

#######################################################
## Contrôle des paramètres
#######################################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
#86255
#Affectations indispensables pour avoir GCURLEG renseigné dans la 2ième fenêtre
#Sinon on le perd...
If dim([M:DIA]LEG)>0 : GCURLEG=[M:DIA]LEG : Endif
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If GLEGFIL<>"" & GCURLEG="" : GCURLEG = GLEGFIL : Endif
Return

#######################################################
## Prise en compte des critères
#######################################################
$EXEC
Gosub OUVFIC From ="WP"+GCURLEG+"PLAN"
Local Integer NOK, OKC , PASAPAS , T , INTE, CALNBR
# CALNBR pour ne pas éditer 2 fois le message de verrou sur le bulletin qui est dans TRTCONT

#Attention car en réalité limite superv à 50 caract !(Cf. table APLLCK)
Local Char   SYMBOLE(80)
Local Char CRITERE (250)

#MIPEA - 2017-02-13- X3-11346- START
Local Integer ILEG
ILEG=find(GCURLEG,GDOSLEG(1..GNBLEG))
If ILEG <>0
If GPLANOK(ILEG)
 If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif
 Local File ADOVAL [ADW]
 Call GENPLAN(nomap,1,GCURLEG) From GENPLAN
Endif
Endif
#MIPEA - 2017-02-13- X3-11346- END

# ouverture de la trace et écriture de l'en-tête
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

# mise en place du filtre sur la table des salariés
CRITERE = "[F:ID]FLGPAY=2"
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif

If [M:DIA]POP<>""
 Link [ECT] With
&   [ID]ID0   = [F:ECT]REFNUM,
&   [HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM
&   As [LNK]
&   Where evalue(CRITERE) & [F:HRPOA]REFNUM<>""
Else
 Link [ECT] With
&   [ID]ID0 = [F:ECT]REFNUM
&   As [LNK]
&   Where evalue(CRITERE)
Endif

T = 0 : CALNBR = 1
For [LNK]
 Gosub SALARIE
Next

Call OUVRE_BOITE(mess(174,10703,1),0) From GESECRAN : # Calcul du bulletin du salarié
Call SET_BOITE("",T) From GESECRAN

T = 0 : CALNBR = 0
For [LNK]
 Gosub SALARIE
Next

Call FERME_BOITE From GESECRAN

If !NBPCE
 Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
Else
 Call ECR_TRACE(num$(NBPCE)-mess(10,10703,1),0) From GESECRAN : # Bulletin calculé
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif

Return

###########################################################################
# Critères pour générer une nouvelle paye :
## - On doit pouvoir verrouiller le symbole VEP
## - Etre actif (Cf : CRITERE]
## - Avoir accès au code d'accès en exécution
## - Avoir droit à la fonction pour le site du salarié
## - L'entête du bulletin doit correspondre aux critères de sélection
## - Le bulletin ne doit pas être comptabilisé
## - L'état du bulletin doit valoir "saisi" ou éventuellement
##   "calculé" suivant la demande de recalcul
## - Le bulletin doit être dans la borne des dates de début et de fin
###########################################################################
$SALARIE
Local Integer OKC , OKPAY
Local Char    CRITVEP(250)

##**82073
Local Char TBUL(GLONVCR)(0..99)    :# Nb de bulletins à recalculer par couple Matricule\Contrat
Local Integer NBBUL, K

CRITVEP = 'EMP="'+[F:ID]REFNUM+'" & CTRNUM="'+[F:ECT]CTRNUM+'"'
If [M:DIA]ALLSRV<>2
 CRITVEP -= '& SRV="'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2
 CRITVEP -= '& PRF="'+[M:DIA]PRF+'"'
Endif
If [M:DIA]ALLFCY<>2
 CRITVEP -= '& FCY="'+[M:DIA]FCY+'"'
Endif
#JOJAC - 2017-01-11 - START
If [M:DIA]ALLPERCOD<>2
 CRITVEP -= '& PERCOD="'+[M:DIA]PERCOD+'"'
Endif
#JOJAC - 2017-01-11 - END
CRITVEP -= '& PST=1'  : # Comptabilisée
CRITVEP -= '& RVS<>2' : # Pas d'extourne
If [M:DIA]ENAFLG=1 :# Ne pas recalculer les bulletins déjà calculer
 CRITVEP -= '& STA=1'
Endif
CRITVEP -= '& PYRDAT>=['+format$(GFMD,[M:DIA]DATPAYSTR)+']'
CRITVEP -= '& FLGLOCK<>2' : # Verrouillé US 2022 65062
CRITVEP -= '& LEG="'+[M:DIA]LEG+'"'
#89370
#CRITVEP -= '& PYRDAT<=['+format$(GFMD,[M:DIA]DATPAYEND)+']'
#

Local Char CRIVEPSPE (250)
CRIVEPSPE="1=1"
GPOINT = "CRIVEPSPE" : Gosub ENTREE From EXEFNC

Raz [L]TBUL, [L]NBBUL
Filter [F:VEP] Where evalue(CRITVEP) & evalue(CRIVEPSPE)
&                    Order By Key CLE = [F:VEP]EMP ; [F:VEP]PYRDAT Desc ; [F:VEP]BUL Desc

#Du bulletin le plus récent au plus vieux
For [F:VEP]CLE
 #89370
 #If [L]MOICUR=0 : [L]MOICUR=month([F:VEP]PYRDAT) : Endif
 #If [L]MOICUR=month([F:VEP]PYRDAT)
 If [F:VEP]PYRDAT<=[M:DIA]DATPAYEND
 #
  [L]TBUL([L]NBBUL) = [F:VEP]BUL
  [L]NBBUL+= 1
 Else
  Break
 Endif
Next
Filter [F:VEP]

##**82073
#Dans l'ordre chrono
For K = [L]NBBUL-1 To 0 Step -1
 Read[F:VEP]VEP5=TBUL(K)
 If !fstat
 OKPAY = 1
 Call CONTROLE([F:VEP]EMP,[F:VEP]CTRDAT,[F:VEP]CTRNUM,[M:DIA]CRI,OKPAY,0) From DIVPAYE
 If OKPAY
  If [M:DIA]ALLCPY<>2   :# société
   Read [FCY]FCY0 = [F:VEP]FCY
   If fstat | [F:FCY]LEGCPY<>[M:DIA]CPY
    OKPAY = 0
   Endif
  Endif
 Endif
 If CALNBR=0
  If OKPAY
   # Verrou
   ##**82073
   Call VEPSYMBOLE (SYMBOLE, "VEP") From DIVPAYE
   Lock =SYMBOLE
   If fstat
    If GBIDI1=0 & CALNBR=0 : Call ECR_TRACE([F:ID]REFNUM-":"-mess(10,100,1),1) From GESECRAN : Endif
    OKPAY = 0
#MIPEA - 2016-07-05 - REQ 114309 US134 - START
  Else
    #113623
    Read[F:HRCTR]CTR0=[F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
    If !fstat
     Gosub VERF_RETRO
    Endif
#MIPEA - 2016-07-05 - REQ 114309 US134 - END
   Endif
  Endif
#MIPEA - 2016-07-05 - REQ 114309 US134 - START
#  Read[F:HRCTR]CTR0=[F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
#  If !fstat
#   Gosub VERF_RETRO
#  Endif
#MIPEA - 2016-07-05 - REQ 114309 US134 - END
  If OKPAY
   Call DEBTRANS From GLOCK
   Gosub ECRIT_LIGNES
#MIPEA - 2016-07-05 - REQ 114309 US134 - START
   # FQ114927
   GPOINT = "UPD_AFTER" : Gosub ENTREE From EXEFNC
#MIPEA - 2016-07-05 - REQ 114309 US134 - END
   If GOK=1
    Call AFF_BOITE([F:ID]REFNUM-[F:ID]NAM-[F:ID]SRN,T,INTE) From GESECRAN
    Call ECR_TRACE([F:ID]REFNUM-format$("D:"+GFMDAT,[F:VEP]PYRDAT)+":"-mess(9,10703,1)-[F:VEP]BUL,0) From GESECRAN
    #  Calcul des bulletins de paye
    If !GFLGERR : NBPCE += 1 : Endif
   Endif
  Endif
  Unlock =SYMBOLE
 Endif
 T += 1
 Endif
Next
Return

###########################
$VERF_RETRO
Filter [F:RES] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM
Read [F:RES]RES1 Last
Filter [F:RES]
If fstat<=2
 Read [F:RET]RET0 = [F:REC]RETNUM
 If !fstat & [F:RET]ENAFLG = 2
  Filter [F:REC] Where RETNUM=[F:RES]RETNUM & RECREFNUM=[F:RES]REFNUM & RECCTRNUM=[F:RES]CTRNUM
  Read [F:REC]REC1 First
  Filter [F:REC]
  If fstat>2
   #Rappels de la fiche de rétroactivité non calculés
   Call ECR_TRACE([F:RES]RETNUM-[F:RES]REFNUM-[F:RES]CTRNUM-":"-mess(210,10702,1),-1) From GESECRAN
  Endif
 Endif
Else
 # Avenant rétroactif
 If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETSTATUT<3
  # Avenant rétroactif non utilisé dans une fiche de rétroactivité
  Call ECR_TRACE([F:HRCTR]REFNUM-[F:HRCTR]CTRNUM-format$("D:"+GFMDAT,[F:HRCTR]CTRDAT)-":"-mess(209,10702,1),-1) From GESECRAN
 Endif
Endif
Return

###########################################################################
# Calcul des bulletins
###########################################################################
$ECRIT_LIGNES
GOK = 1
Trbegin [HSP]
 GFLGERR=0
 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 GCURLEG=[F:CPY]LEG

#JASMI - 2017-05-16 - START
Read [F:HRPEOD]HRPEOD0 = [F:VEP]PERCOD; [F:VEP]PERYEA; [F:VEP]PERNUM
If fstat : GOK = 0 : Call FSTA("HRPEOD") From GLOCK : Goto AB_TR : Endif
Read [F:HRPEOH]HRPEOH0 = [F:VEP]PERYEA; [F:VEP]PERCOD
If fstat : GOK = 0 : Call FSTA("HRPEOH") From GLOCK : Goto AB_TR : Endif
If func DIVPAYE.IS_KZA(GCURLEG)
  #ADNGO - 2017-06-07 - START
  #Read [F:ETR]ETR0 = [F:VEP]EMP; [F:VEP]CTRNUM; [F:VEP]CTRDAT; [F:VEP]PERYEA
  #If fstat : GOK = 0 : Call FSTA("ETR") From GLOCK : Goto AB_TR : Endif
   Filter [F:ETR] Where REFNUM=[VEP]EMP and CTRNUM=[VEP]CTRNUM and TAXYEA=[VEP]PERYEA
   If fstat
      GOK = 0
      Call FSTA("ETR") From GLOCK
      Goto AB_TR
   Else
      Read [F:ETR]ETR0 Last
   Endif
  #ADNGO - 2017-06-07 - END
Endif
If func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
  #ADNGO - 2017-06-07 - START
  #Read [F:ETA]ETA0 = [F:VEP]EMP; [F:VEP]CTRNUM; [F:VEP]CTRDAT; [F:VEP]PERYEA
  #If fstat : GOK = 0 : Call FSTA("ETA") From GLOCK : Goto AB_TR : Endif
  Filter [F:ETA] Where REFNUM=[VEP]EMP and CTRNUM=[VEP]CTRNUM and TAXYEA=[VEP]PERYEA
     If fstat
      GOK = 0
      Call FSTA("ETA") From GLOCK
      Goto AB_TR
   Else
      Read [F:ETA]ETA0 Last
   Endif
   #ADNGO - 2017-06-07 - END
Endif
#JASMI - 2017-05-16 - END

#MIPEA - 2016-07-05 - REQ 114309 US134 - START
#98246
 [V]GPE = 0
 GPOINT = "UPD_BEFORE" : Gosub ENTREE From EXEFNC
 If ![V]GPE
  Call PLAN([F:VEP]BUL,PASAPAS,0) From GPLAN
  # La mise à jour de l'en-tête est faite par GPLAN
 Endif
 #Call PLAN([F:VEP]BUL,PASAPAS,0) From GPLAN
#MIPEA - 2016-07-05 - REQ 114309 US134 - END
 If GOK<1 : Goto AB_TR : Endif
# La mise à jour de l'en-tête est faite par GPLAN
Commit
Return

$AB_TR
Rollback
GMESSAGE = mess (17,107,1) :#Rollback suite à une erreur dans la transaction
Return

######################################################################
## Calcul Pas à Pas : Actions de la fenêtre principale
######################################################################

$DEBUT
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif

Local Integer NOK, PASAPAS, TYPPAS, FINPAS, CALNBR
Local Integer DEVERROU
#Attention car en réalité limite superv à 50 caract !(Cf. table APLLCK)
Local Char    SYMBOLE(80)
Local Char    VALPAR(10)
Local Char    MATRI(GLONEML)
Local Date    DATPAY
Local Char    BULLETIN(GLONVCR)
Local Char CRITERE (250), CRITCTR(250)
Local Char P_BUL (GLONVCR)

#MIPEA - 2017-02-13- X3-11346- START
#Local Integer ILEG
##MIPEA - 2016-07-05 - REQ 114309 US134 - START
#SAV_GCURLEG=GCURLEG
#GCURLEG='FRA'
#ILEG=find(GCURLEG,GDOSLEG(1..GNBLEG))
#If ILEG <>0
#If GPLANOK(ILEG)
# If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif
# Local File ADOVAL [ADW]
# Call GENPLAN(nomap,1,GCURLEG) From GENPLAN
#Endif
#GCURLEG=SAV_GCURLEG
#Else
#GCURLEG=SAV_GCURLEG
#Endif
#MIPEA - 2017-02-13- X3-11346- END
#GCURLEG='FRA'
#ILEG=find(GCURLEG,GDOSLEG(1..GNBLEG))
#If GPLANOK(ILEG)
# If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif
# Local File ADOVAL [ADW]
# Call GENPLAN(nomap,1,GCURLEG) From GENPLAN
#Endif
#MIPEA - 2016-07-05 - REQ 114309 US134 - END
If dim(GNBRCRB)<0 : Call DECL_PROFIL(0) From GPLAN: Endif

Raz [M:PAS]
Affzo [PAS]: Setmok [PAS] With 0
Call AFF_MEMO From DIVPAYE: #81085

#JOJAC - 2017-01-31 - START
If [M:DIA]ALLEXTPER = 2
 Effzo [M:DIA]ALLPERCOD : Diszo [M:DIA]ALLPERCOD
Endif
#JOJAC - 2017-01-31 - END

If clalev([M:VEP0])>0
 DEVERROU = 0
 P_BUL=[M:VEP0]BUL
Else
 DEVERROU = 1
 Raz P_BUL
Endif

Diszo [M:PAS]BAS0,RAT1,RAT2
[M:PAS]DATPAYE   = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))

# mise en place du filtre sur la table des salariés
CRITERE = "[F:ID]ENAFLG=2 & [F:ID]FLGPAY=2"
If [M:DIA]ALLCPY<>2  #société
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif

# Filtre sur les contrats
#MIPEA - 2016-07-05 - REQ 114309 US134 - START
#93753
If clalev([M:VEP0])>0
  CRITCTR ='[F:HRCTR]CTRNUM=[M:VEP0]CTRNUM'
  CRITCTR -='& [F:HRCTR]CTRDAT=[M:VEP0]CTRDAT'
Else
  CRITCTR -= '[F:HRCTR]CTRDAT<=['+num$([M:DIA]DATPAYEND)+'] & [F:HRCTR]STACTR=2'
#end 93753
  If [M:DIA]ALLFCY<>2
   CRITCTR -= '& [F:HRCTR]ETRFCY="'+[M:DIA]FCY+'"' :# site
  Endif
  If [M:DIA]ALLSRV<>2
   CRITCTR -= '& [F:HRCTR]ETRSRV="'+[M:DIA]SRV+'"' :# service
  Endif
  If [M:DIA]ALLPRF<>2
   CRITCTR -= '& [F:HRCTR]PROPRF="'+[M:DIA]PRF+'"' :# profil
  Endif
Endif : #93753
#CRITCTR -= '[F:HRCTR]CTRDAT<=['+num$([M:DIA]DATPAYEND)+'] & [F:HRCTR]STACTR=2'
#CRITCTR -= '& ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>=['+num$([M:DIA]DATPAYSTR)+'])'
#If [M:DIA]ALLFCY<>2
# CRITCTR -= '& [F:HRCTR]ETRFCY="'+[M:DIA]FCY+'"' :# site
#Endif
#If [M:DIA]ALLSRV<>2
# CRITCTR -= '& [F:HRCTR]ETRSRV="'+[M:DIA]SRV+'"' :# service
#Endif
#If [M:DIA]ALLPRF<>2
# CRITCTR -= '& [F:HRCTR]PROPRF="'+[M:DIA]PRF+'"' :# profil
#Endif
#MIPEA - 2016-07-05 - REQ 114309 US134 - END

##**82073
If [M:DIA]POP<>""
 Link [HRCTR] With
&   [ID]ID0 = [F:HRCTR]REFNUM,
&   [FCY]FCY0=[F:HRCTR]ETRFCY,
&   [HRPOA]POA0 = [M:DIA]POP;[F:HRCTR]REFNUM
&   As [LNK]
&   Where evalue(CRITERE) & evalue(CRITCTR) & [F:HRPOA]REFNUM<>""
Else
 Link [HRCTR] With
&   [ID]ID0 = [F:HRCTR]REFNUM,
&   [FCY]FCY0=[F:HRCTR]ETRFCY
&   As [LNK]
&   Where evalue(CRITERE) & evalue(CRITCTR)
Endif
#MIPEA - 2016-11-16 - X3PEOP-773- START
#JASMI - 2016-11-08 - START
If GFONCTION <> "TRTCALPAS"
  GCURLEG = [FCY]LEG
Endif
#JASMI - 2016-11-08 - END
#MIPEA - 2016-11-16 - X3PEOP-773- END
TYPPAS  = 2 : # 1 pour afficher une rubrique; 2 pour afficher la rubrique suivante

# On cherche les matricules à afficher
For [LNK]
 Gosub MAT_SUIV
 If NOK=0 : Break : Endif
Next

If NOK
 Call MESSAGE(mess(20,10703,1)) From GESECRAN : # Pas de matricule à traiter
 FIN=1
Endif
FINPAS = 0
SUIZON = "BAS"
Return

$MAT_SUIV
Gosub TRTCONT
If NOK=0
 [M:PAS]REFNUM  = [F:ID]REFNUM
 [M:PAS]DAT     = [F:VEP]PYRDAT
 [M:PAS]CTRNUM  = [F:VEP]CTRNUM
 [M:PAS]FCY     = [F:VEP]FCY
 Call LECTURE("FCY",[M:PAS]FCY,"") From CONTOBJ
 [M:PAS]ZFCY    = [F:FCY]FCYNAM
 [M:PAS]CPY     = [F:FCY]LEGCPY
 [M:PAS]SRV     = [F:VEP]SRV
 [M:PAS]PRF     = [F:VEP]PRF
 MATRI          = [F:VEP]EMP
 DATPAY   = [F:VEP]PYRDAT
 BULLETIN = [F:VEP]BUL
 PASAPAS = 1 : # Identifie le point d'arrêt du calcul de la paye
 FINPAS  = 0 : # 1 pour passer au calcul du matricule suivant
 Gosub CPLAN From ="WP"+GCURLEG+"PLAN"
Endif
If DEVERROU
 Unlock =SYMBOLE
Endif
Return

$TRTCONT
Local Integer OKC
NOK = 1

#90788
If BULLETIN<>"" & BULLETIN=P_BUL
 Return
Endif

##**82073
If P_BUL<>""
 Read [VEP]VEP5=P_BUL
Else
 Filter [VEP] Where EMP=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT
 Read [VEP]VEP0 Last
 Filter[VEP]
Endif
If fstat>2 : Return : Endif

Call CONTROLE([F:VEP]EMP,[F:VEP]CTRDAT,[F:VEP]CTRNUM,[M:DIA]CRI,OKC,0) From DIVPAYE
If !OKC : Return : Endif

# Non comptabilisé
# Verrouillé US 2022 65062
If [F:VEP]PST>1 or [F:VEP]RVS=2 or [F:VEP]FLGLOCK=2: Return : Endif     :# Déjà comptabilisé ou extourne

# Etat = saisi sauf si recalcul demandé...
If[M:DIA]ENAFLG=1 :# Ne pas recalculer les bulletins déjà calculer
 If [F:VEP]STA<>1 :# etat <>saisi
  Return
 Endif
Endif

# Fiche VALEMP dans la borne des dates
If [M:DIA]DATPAYSTR>[F:VEP]PYRDAT :  Return : Endif
If [M:DIA]DATPAYEND<[F:VEP]PYRDAT :  Return : Endif

If P_BUL<>"" & P_BUL<>[F:VEP]BUL :  Return : Endif

# Verrou
##**82073
Call VEPSYMBOLE (SYMBOLE, "VEP") From DIVPAYE
Lock =SYMBOLE
If fstat
 Return
Endif

NOK=0
Return

$PREMIER
PASAPAS = 1 : # Identifie le point d'arrêt du calcul de la paye
FINPAS  = 0 : # 1 pour passer au calcul du matricule suivant
TYPPAS  = 2
Gosub CPLAN From ="WP"+GCURLEG+"PLAN"
FINPAS = 0
Return

$ALLER_SUR_RUB
TYPPAS = 1
[M:PAS]GOTORUB = [M:PAS]COD
Gosub CALPLAN From ="WP"+GCURLEG+"PLAN"
If GOK
 While FINPAS=1
  Read[LNK] Next
  If !fstat
   Gosub MAT_SUIV
  Else
   Call MESSAGE(mess(20,10703,1)) From GESECRAN : # Pas de matricule à traiter
   Break
  Endif
 Wend
 Gosub EVALE
 FINPAS = 0
 SUIZON = "BAS"
Else
 FIN=1
Endif
Return

$CHANGE_MONT
# OLDRUB contient la rubrique précédente. Rubrique Assiette. mkstat=2 s/[M]BAS
If COUZON="AMT"
 Case [M:PAS]TYPRUB
  When 5 : # Assiette
   TRANCHE = val(CZ)
   [M:PAS]OLDRUB = [M:PAS]COD
  When 2,3,6 : # Montant=Base*Taux , Cotisation, Montant=Base*Taux /100
   If [M:PAS]TYP=1 : Assign "R_"+[F:RUB]COD+"(1)" With val(CZ) : Endif : #Salarial
   If [M:PAS]TYP=2 : Assign "R_"+[F:RUB]COD+"(2)" With val(CZ) : Endif : #Patronal
  When Default
   Assign "R_"+[F:RUB]COD With val(CZ)
 Endcase
Elsif COUZON="RAT" & [M:PAS]TYPRUB=5
 PLAFOND = val(CZ)
 [M:PAS]OLDRUB = [M:PAS]COD
Elsif COUZON="BAS" & [M:PAS]TYPRUB=5
 If [M:PAS]TYP=1 : Assign "R_"+[F:RUB]COD+"(1)" With val(CZ) : Endif : #Salarial
 If [M:PAS]TYP=2 : Assign "R_"+[F:RUB]COD+"(2)" With val(CZ) : Endif : #Patronal
Endif
Gosub EVALE
Return

$RUB_SUIV
TYPPAS = 2
Gosub CALPLAN From ="WP"+GCURLEG+"PLAN"
While FINPAS=1
 Read [LNK] Next
 If !fstat
  Gosub MAT_SUIV
 Else
  Call MESSAGE(mess(20,10703,1)) From GESECRAN : # Pas de matricule à traiter
  Break
 Endif
Wend
Gosub EVALE
FINPAS = 0
SUIZON = "BAS"
Return

$EVALE
For I=0 To min(dim([M]EXPR)-1,[M]NBVAR)
 [M]RESULT(I) = ""
 If [M]EXPR(I)<>""
  Onerrgo RIEN
  [M]RESULT(I) = num$(evalue([M]EXPR(I)))
  Onerrgo
 Endif
Next I
Affzo RESULT
Return

$RIEN
Resume

################################################################################
## Etiquettes écran TRTCAL
################################################################################
#############################################################
## Contrôles sur la période de paye
#############################################################

## Sélection matricule
$SEL_TABLE
Case TABLE
 When "SELEMP"
  OBJET   = "EML"
  CRITERE = "ENAFLG=2"
Endcase
Return


#MIPEA - 2016-11-16 - X3PEOP-773- START
