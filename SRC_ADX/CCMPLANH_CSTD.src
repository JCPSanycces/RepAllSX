# --------------------------------------------------
# Custom Method
#
# Update the overall plan status.
#
$UPDATE_PLAN_STATUS

  Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
  CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null
  Local Integer EMAIL_TYPE
  Local Char SUBJECT(250)
  Local Clbfile BODY(0)
  Local Clbfile BODY_PLAN_STATUS(0)
  Local Integer STAT
  Local Integer ORIG_PLAN_STATUS

  this.HIGHLEVEL = fmet this.HIGH_LEVEL_PLAN_STATUS()

  # Notify (email) the Change Manager
  STAT = fmet CHANGE_REQUEST.AREAD(this.CRID)

  this.PLANSTATUS = fmet this.DETERMINE_PLAN_STATUS()

  If ((fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILCM") <> 1 and
&      this.PLANSTATUS = 3 or this.PLANSTATUS = 4) and
&      this.snapshot.PLANSTATUS <> this.PLANSTATUS and
&      this.ACTX.USER <> CHANGE_REQUEST.CCMUSRID)

      EMAIL_TYPE = 2063

      Append BODY_PLAN_STATUS, mess(this.PLANSTATUS,2045,1) +chr$(10)

      STAT = fmet CHANGE_REQUEST.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, BODY_PLAN_STATUS, "CCMCHGREQ")
    STAT = fmet CHANGE_REQUEST.SEND_EMAIL(this.ACTX.USER, CHANGE_REQUEST.CCMUSRID, "", SUBJECT, BODY)

    If (STAT = CST_AOK)
      ASTATUS = fmet this.ASETERROR("", mess(53,2038,1), CST_AINFO)
    Endif

  Endif

  FreeGroup CHANGE_REQUEST

Return

# --------------------------------------------------
# Initialise the overall plan status.
$INITIALISE

  this.PLANSTATUS = 1 # Pending
  this.HIGHLEVEL = 1  # Plan
Return

# --------------------------------------------------
# Actions on AUPDATE_CONTROL_AFTER, include:
# VALIDATE the high level plan, and
# Update the overall plan status.
$AUPDATE_CONTROL_AFTER

  Local Integer LOCAL_ASTATUS

  Gosub VALIDATE

  LOCAL_ASTATUS = fmet this.UPDATE_PLAN_STATUS()

Return

# --------------------------------------------------
# VALIDATE the high level plan i.e.
# Transaction type (TRANTYPE) and Action (ACTIONID).
$VALIDATE

  Local Integer LINE

  For LINE = 1 To maxtab(this.CCMPLAND)

    If ((this.CCMPLAND(LINE).ASTALIN <> CST_ADEL) and
&       (this.CCMPLAND(LINE).ASTALIN <> CST_ANEWDEL))

      If (this.CCMPLAND(LINE).TRANTYPE = 1)
        ASTATUS = fmet this.ASETERROR ("", mess(18,2038,1), [V]CST_AERROR)
        Break
      Endif
      If (this.CCMPLAND(LINE).TRANTYPE > 1 and this.CCMPLAND(LINE).ACTIONID = "")
        ASTATUS = fmet this.ASETERROR ("", mess(62,2038,1), [V]CST_AERROR)
        Break
      Endif

    Endif

  Next LINE

Return

# --------------------------------------------------
# VALIDATE_IMPLEMENT i.e.
# Check all lines for actioner / action / complete by date.
$VALIDATE_IMPLEMENT

  Local Integer I

  ASTATUS = CST_AOK

  If (this.IMPLEMENT = 2)

    For I = 1 To maxtab(this.CCMPLAND)

      If ((this.CCMPLAND(I).ASTALIN <> CST_ADEL) and
&         (this.CCMPLAND(I).ASTALIN <> CST_ANEWDEL))

        If (this.CCMPLAND(I).ACTIONID = "" or
&           this.CCMPLAND(I).ACTIONER = "" or
&           this.CCMPLAND(I).COMPLETEDATE = AVOID.ADATE)
          ASTATUS = fmet this.ASETERROR("IMPLEMENT", mess(27,2038,1), [V]CST_AERROR)
          this.IMPLEMENT = 1  # Reset
          Break
        Endif

      Endif

    Next

  Endif

  ARET_VALUE = ASTATUS

Return

# --------------------------------------------------
# Custom Method
#
# Set attributes on high level plan.
#
$SET_ATTRIBUTES

  Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
  CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null
  Local Integer IS_PLANNER, I

  ASTATUS = fmet CHANGE_REQUEST.AREAD(this.CRID)

  IS_PLANNER = CST_AFALSE
  # REQ109095/2 - start - for change request check planner
  If (this.ACTX.USER = CHANGE_REQUEST.PLANNER)
    IS_PLANNER = CST_ATRUE
  Endif
  FreeGroup CHANGE_REQUEST

  For I = 1 To maxtab(this.CCMPLAND)

    If ((this.CCMPLAND(I).ASTALIN <> CST_ADEL) and
&       (this.CCMPLAND(I).ASTALIN <> CST_ANEWDEL))

      # All disabled (default) ...
      ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("TRANTYPE",     "$isDisabled", "true")
      ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("ACTIONID",     "$isDisabled", "true")
      ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("COMPLETEDATE", "$isDisabled", "true")
      ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("ACTIONER",     "$isDisabled", "true")
      ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("LINESTATUS",   "$isDisabled", "true")
      ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("COMMENT",      "$isDisabled", "true")

      # Enable by exception ...
      If (IS_PLANNER and this.IMPLEMENT <> 2)
        ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("TRANTYPE",     "$isDisabled", "false")
        ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("ACTIONID",     "$isDisabled", "false")
        ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("COMPLETEDATE", "$isDisabled", "false")
        ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("COMMENT",      "$isDisabled", "false")
      Endif

      If ((IS_PLANNER and this.IMPLEMENT <> 2) or
&         (IS_PLANNER and this.IMPLEMENT = 2 and this.CCMPLAND(I).LINESTATUS <> 3))
        ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("ACTIONER",     "$isDisabled", "false")
      Endif

      If (this.IMPLEMENT = 2 and this.ACTX.USER = this.CCMPLAND(I).ACTIONER)
        # REQ110863/6/8 - comment editable for actioner
        ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("COMMENT",      "$isDisabled", "false")
        ASTATUS = fmet this.CCMPLAND(I).ASETATTRIBUTE("LINESTATUS",   "$isDisabled", "false")
      Endif

    Endif

  Next I

Return

# --------------------------------------------------
# Custom Method
#
# Set attributes on IMPLEMENT property.
#
$SET_ATTRIBUTES_IMPLEMENT

  Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
  CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null
  Local Integer IS_PLANNER, ALL_LINES_PENDING, I

  ASTATUS = fmet CHANGE_REQUEST.AREAD(this.CRID)

  IS_PLANNER = CST_AFALSE
  If (this.ACTX.USER = CHANGE_REQUEST.PLANNER)
    IS_PLANNER = CST_ATRUE
  Endif
  FreeGroup CHANGE_REQUEST

  ALL_LINES_PENDING = CST_ATRUE

  For I = 1 To maxtab(this.CCMPLAND)

    If ((this.CCMPLAND(I).ASTALIN <> CST_ADEL) and
&       (this.CCMPLAND(I).ASTALIN <> CST_ANEWDEL))

      If (this.CCMPLAND(I).LINESTATUS > 1)
        ALL_LINES_PENDING = CST_AFALSE
        Break
      Endif

    Endif

  Next I

  ASTATUS = fmet this.ASETATTRIBUTE("IMPLEMENT",   "$isDisabled", "true")
  If (IS_PLANNER and ALL_LINES_PENDING = CST_ATRUE)
    ASTATUS = fmet this.ASETATTRIBUTE("IMPLEMENT",   "$isDisabled", "false")
  Endif

Return

#
# --------------------------------------------------
# FUNCTION NAME:        NOTIFY_ACTIONER
# FUNCTION DESCRIPTION: Notify Actioner
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$NOTIFY_ACTIONER

  Local File CCMPLAND [PLAND]
  Local Char LAST_ACTIONER(5)
  Local Integer STAT
  Local Integer EMAIL_TYPE : EMAIL_TYPE = 2066  # Actioner
  Local Char SUBJECT(250)
  Local Clbfile BODY(0), OTHER_BODY(0)
  Local Integer AC_EMAIL : AC_EMAIL = CST_AFALSE

  If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILAC") <> 1 and
&     this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)

    BODY(0) = AVOID.ACLOB
    OTHER_BODY(0) = AVOID.ACLOB
    Append OTHER_BODY, mess(4,2033,1) +chr$(10)
    STAT = fmet CHANGE_REQUEST.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, OTHER_BODY, "CCMPLANH")

    Filter [PLAND] Where CRID = this.CRID and ACTIONER <> "" Order By ACTIONER
    For [PLAND]
      If ([F:PLAND]ACTIONER <> LAST_ACTIONER and
&         [F:PLAND]ACTIONER <> this.ACTX.USER)

        STAT = fmet CHANGE_REQUEST.SEND_EMAIL(this.ACTX.USER, [F:PLAND]ACTIONER, "", SUBJECT, BODY)

        If (STAT = CST_AOK)
          AC_EMAIL = CST_ATRUE
        Endif

        LAST_ACTIONER = [F:PLAND]ACTIONER

      Endif
    Next

    If (AC_EMAIL = CST_ATRUE)
      ASTATUS = fmet this.ASETERROR("", mess(60,2038,1), CST_AINFO)
    Endif

  Endif

  LogicClose File [PLAND]

Return

