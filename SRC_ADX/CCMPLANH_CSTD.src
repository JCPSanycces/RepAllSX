#<AdxTL>@(#)0.0.0.0 $Revision$
# Data Class script: CCMPLANH_CSTD, Change request plan header
###############################################################################
# Issue 109096/2 - 2015-11-23 by BAKHA : for non-conformance, send emails to actioners, and
#                                        if plan complete, email QA Manager
# Issue 110210/7 - 2015-12-16 by JUSYN : New labels for supervisor update
# Issue X3-67944 - 2018-01-19 by BAKHA : If Non-conformance, do not check detailed plans
# Issue X3-69118 - 2018-01-25 by BAKHA : message changed when Action ID is blank
# Issue X3-74449 - 2018-01-19 by BAKHA : For non-conformance, do not update plan status automatically
# Issue X3-76268 - 2018-02-13 by JUSYN : Remove/deactivate email notification NCS
# Issue X3-94420 - 2018-06-18 by BAKHA : Remove all code for NCS

$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_BEFORE"                 : Gosub CHECK_PLAN
        When "AINIT"                        : Gosub INITIALISE
        When "AUPDATE_CONTROL_AFTER"        : Gosub AUPDATE_CONTROL_AFTER
        When "AUPDATE_AFTER"                : Gosub AUPDATE_AFTER
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
    When "DETERMINE_PLAN_STATUS"            : Gosub DETERMINE_PLAN_STATUS
    When "HIGH_LEVEL_PLAN_STATUS"           : Gosub HIGH_LEVEL_PLAN_STATUS
    When "UPDATE_PLAN_STATUS"               : Gosub UPDATE_PLAN_STATUS
    When "SET_ATTRIBUTES"                   : Gosub SET_ATTRIBUTES
    When "SET_ATTRIBUTES_IMPLEMENT"         : Gosub SET_ATTRIBUTES_IMPLEMENT
    When "VALIDATE_IMPLEMENT"               : Gosub VALIDATE_IMPLEMENT
  Endcase
Return

$OPERATIONS
  Case [L]AOPERATION
    When "SALES_ORDER_PLAN_STATUS"          : Gosub SALES_ORDER_PLAN_STATUS
    When "SALES_QUOTES_PLAN_STATUS"         : Gosub SALES_QUOTES_PLAN_STATUS
    When "PURCHASE_ORDER_PLAN_STATUS"       : Gosub PURCHASE_ORDER_PLAN_STATUS
    When "PURCHASE_REQUEST_PLAN_STATUS"     : Gosub PURCHASE_REQUEST_PLAN_STATUS
    When "WORK_ORDER_PLAN_STATUS"           : Gosub WORK_ORDER_PLAN_STATUS
    When "SUB_CONTRACT_PLAN_STATUS"         : Gosub SUB_CONTRACT_PLAN_STATUS
    When "STOCK_PLAN_STATUS"                : Gosub STOCK_PLAN_STATUS
    When "FORECAST_PLAN_STATUS"             : Gosub FORECAST_PLAN_STATUS
    When "BOM_PLAN_STATUS"                  : Gosub BOM_PLAN_STATUS
    When "ROUTING_PLAN_STATUS"              : Gosub ROUTING_PLAN_STATUS
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
    When "IMPLEMENT"
      Case [L]ARULE
        When "CONTROL"
          ASTATUS = fmet this.VALIDATE_IMPLEMENT()
      Endcase
  Endcase
Return
###############################################################################

#
#
# --------------------------------------------------
# FUNCTION NAME:        CHECK_PLAN
# FUNCTION DESCRIPTION: Check Plan exists, if it does not then display an error message
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
$CHECK_PLAN

    Local File CCMPLANH [CCMPH]
    Read [CCMPH]CCMPH_0 = CRID
    If (fstat <> 0)
      ASTATUS = fmet this.ASETERROR ("", mess(78,2038,1), CST_AERROR)
    Endif
    Close Local File [CCMPH]
Return

# Update Change request status
#
$AUPDATE_AFTER

  # Update Change Request status: Plan / Implement ...
  Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
  CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null

  LOCAL_ASTATUS = fmet CHANGE_REQUEST.UPDATE_IMPLEMENT_STATUS(this.CRID, CST_AFALSE)
  Gosub NOTIFY_ACTIONER

  FreeGroup CHANGE_REQUEST

Return

# --------------------------------------------------
# Custom Method
#
# Determine and (return) the overall plan status from all the transaction detail plan and
# high level plan statuses.
#
$DETERMINE_PLAN_STATUS

  Local Integer PLANSTATUS(11)
  Local Integer PLAN, IMPLEMENT, COMPLETE, NOT_APPLICABLE

  PLAN = IMPLEMENT = COMPLETE = NOT_APPLICABLE = 0

  PLANSTATUS(0) = this.HIGHLEVEL
  PLANSTATUS(1) = fmet this.SALES_ORDER_PLAN_STATUS(this.CRID, CST_ATRUE)
  PLANSTATUS(2) = fmet this.SALES_QUOTES_PLAN_STATUS(this.CRID, CST_ATRUE)
  PLANSTATUS(3) = fmet this.PURCHASE_ORDER_PLAN_STATUS(this.CRID, CST_ATRUE)
  PLANSTATUS(4) = fmet this.WORK_ORDER_PLAN_STATUS(this.CRID, CST_ATRUE)
  PLANSTATUS(5) = fmet this.SUB_CONTRACT_PLAN_STATUS(this.CRID, CST_ATRUE)
  PLANSTATUS(6) = fmet this.PURCHASE_REQUEST_PLAN_STATUS(this.CRID, CST_ATRUE)
  PLANSTATUS(7) = fmet this.STOCK_PLAN_STATUS(this.CRID, CST_ATRUE)
  PLANSTATUS(8) = fmet this.FORECAST_PLAN_STATUS(this.CRID, CST_ATRUE)
  PLANSTATUS(9) = fmet this.BOM_PLAN_STATUS(this.CRID, CST_ATRUE)
  PLANSTATUS(10) = fmet this.ROUTING_PLAN_STATUS(this.CRID, CST_ATRUE)

  # Determine the overall plan status from all the transaction detail plan and
  # high level plan statuses ...

  For I = 0 To 10
    Case PLANSTATUS(I)
      When 1 : PLAN += 1
      When 2 : IMPLEMENT += 1
      When 3 : COMPLETE += 1
      When 4 : NOT_APPLICABLE += 1
    Endcase
  Next I

  If (NOT_APPLICABLE = 11)
    PLAN_STATUS = 4
  Elsif (COMPLETE + NOT_APPLICABLE = 11)
    PLAN_STATUS = 3
  Elsif (IMPLEMENT >= 1 or COMPLETE >= 1)
    PLAN_STATUS = 2
  Else
    PLAN_STATUS = 1
  Endif

  ARET_VALUE = PLAN_STATUS

Return

# --------------------------------------------------
# Custom Method
#
# Return the high level plan status.
#
$HIGH_LEVEL_PLAN_STATUS

  Local Integer TOTALPLANLINES
  Local Integer PLANLINES
  Local Integer COMPLETEDLINES
  Local Integer PLAN_STATUS

  # Count visible line (PLANLINES), In progress lines (INPROGRESSLINES) and Completed lines (COMPLETEDLINES) ...
  TOTALPLANLINES = maxtab(this.CCMPLAND)
  PLANLINES = 0
  COMPLETEDLINES = 0

  For I = 1 To TOTALPLANLINES

    If ((this.CCMPLAND(I).ASTALIN <> CST_ADEL) and
&       (this.CCMPLAND(I).ASTALIN <> CST_ANEWDEL))

      PLANLINES += 1

      If (this.CCMPLAND(I).LINESTATUS = 3)
        COMPLETEDLINES += 1
      Endif
    Endif
  Next I

  # Determine the high level plan status from the high level plan line statuses ...
  If (PLANLINES = 0 and this.IMPLEMENT = 2)
    PLAN_STATUS = 4
  Elsif (PLANLINES > 0 and PLANLINES = COMPLETEDLINES)
    PLAN_STATUS = 3
  Elsif (PLANLINES > 0 and this.IMPLEMENT = 2)
    PLAN_STATUS = 2
  Else
    PLAN_STATUS = 1
  Endif

  ARET_VALUE = PLAN_STATUS

Return

# --------------------------------------------------
# Custom Method
#
# Return the detail plan status (sales order). If status is 5 - No action,
# Implement is not ticked, and TRANSFORM_NOACTION = TRUE,
# then assume status is Pending
#
# Parameters : CRID - Change request id
#              TRANSFORM_NOACTION - change No action status to Pending
#

$SALES_ORDER_PLAN_STATUS

  Local Instance SALES_ORDER_PLAN Using C_CCMIMPSOH
  SALES_ORDER_PLAN = NewInstance C_CCMIMPSOH AllocGroup null
  Local Integer LOCAL_ASTATUS

  LOCAL_ASTATUS = fmet SALES_ORDER_PLAN.AREAD(CRID)

  If (LOCAL_ASTATUS = CST_AOK)
    ARET_VALUE = SALES_ORDER_PLAN.SOHPLASTA
  Endif

  FreeGroup SALES_ORDER_PLAN

Return

