#<AdxTL>@(#)0.0.0.0 $Revision$Class Process launch
# Supervisor
## ACLA-CLASSE ## EDIRUND
# 2018-10-17 07:54:25 281

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EDIRUND
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_NUM From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_NUMLIN From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_SORT From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_FLD From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_FLDNAM From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_MANDATORY From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_FLDVAL1 From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_REPFLDVAL1 From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_FLDVAL2 From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_REPFLDVAL2 From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_OPERATOR From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_FLDCODTYP From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_FLDTYPTYP From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_FLDNOLIB From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_UPDFLG From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub AINIT From WMC0EDIRUND : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EDIRUND
Gosub _ALOADATTRIBUTE_NUMLIN From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_SORT From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_FLD From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_FLDCODTYP From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_FLDTYPTYP From WMC1EDIRUND : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EDIRUND
Gosub LNKPRO_CREUSR From WMC1EDIRUND : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1EDIRUND : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



