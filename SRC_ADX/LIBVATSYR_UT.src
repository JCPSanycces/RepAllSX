Call UNIT_TEST_SALINV()
Call UNIT_TEST_PURINV()
Call UNIT_TEST_CALTAXE()


End

Subprog UNIT_TEST_SALINV()

Local Decimal WMONTANT(1..)     : # Montant des taxes
Local Decimal WMONTDED(1..)     : # Montant déductible
Local Integer WTYPREG           : # Type de régime
Local Integer WSTAT             : # Statut de retour
Local Char    WVAT(GLONVAT)(1..)
Local Decimal WOTHBASE(1..)      : # Pour appel CALTAXE2
Local Integer WNBTAXES
Local Decimal WMONTCALC
Local Date 		WDATE
Local Char  	WMESSA(250)

Call OUVRE_TRACE("--------------------------------UNIT_TEST_SALINV--------------------------------") From LECFIC
Call ECR_TRACE("Calcul de taxes : Test re-calcul par ligne de facture vente (pour comparer) ",0) From GESECRAN

Local File SINVOICE   [SIH]
Local File SINVOICEV  [SIV]
Local File SINVOICED  [SID]

Link [SIH] With [SID]SID0(1)~=[SIH]NUM,
&								[SIV]SIV0   ~=[SIH]NUM
& As [SIH_]

Filter [SIH_] Where CREDAT>=[01/04/2013]
& Order By Key MYKEY=NUM;SIDLIN Asc
For [SIH_]

  Call ECR_TRACE("--------------------------------//--------------------------------",0) From GESECRAN
  Call ECR_TRACE("Facture n°"+[F:SID]NUM-"Ligne"-num$([F:SID]SIDLIN),0) From GESECRAN
  Call ECR_TRACE("Société :"-[SIH_]CPY-"Règime :"-[SIH_]VAC-"Devise :"-[SIH_]CUR,0) From GESECRAN

  #--Calcul normal HT vers TTC
  Raz WMONTANT,WMONTDED,WTYPREG,WSTAT

	WNBTAXES=3
	WVAT(1)=[F:SID]VAT(0)
	WVAT(2)=[F:SID]VAT(1)
	WVAT(3)=[F:SID]VAT(2)

	WOTHBASE(1)=[F:SID]BASTAXLIN(0)
	WOTHBASE(2)=[F:SID]BASTAXLIN(1)
	WOTHBASE(3)=[F:SID]BASTAXLIN(2)

	If [F:SIV]PRITYP=1
		#-- HT vers TTC

  	WMONTCALC = [F:SID]AMTNOTLIN

    Call CALTAXE2(GACTX,[F:SIH_]CPY,[F:SIH_]ACCDAT,"",[F:SIH_]CUR
&            ,WNBTAXES,WVAT,[F:SIV]PRITYP,WMONTCALC,WOTHBASE,WMONTANT,WMONTDED,WTYPREG,WSTAT) From LIBVATSYR

		If WSTAT
			Call ERR_CALTAXE(WSTAT,WMESSA) From LIBVATSYR
			Call ECR_TRACE(WMESSA,1) From GESECRAN : Goto NEXT_SIH_
		Endif

    WMONTCALC += sigma(I=1,WNBTAXES,WMONTANT(I))

    If WMONTCALC<>[F:SID]AMTATILIN
    	Call ECR_TRACE("#####################Différence de résultat !#######################",1) From GESECRAN
    	WSTAT=1
    Endif

		Call ECR_TRACE("Montant HT de départ="+num$([F:SID]AMTNOTLIN)-"Taxes :"-num$(sigma(I=0,2,[F:SID]AMTTAXLIN(I))),WSTAT) From GESECRAN
    Call ECR_TRACE("---1) HT vers TTC :"-"TTC calculé="+num$(WMONTCALC)-"/ Avant="-num$([F:SID]AMTATILIN),WSTAT) From GESECRAN
    For I=1 To WNBTAXES
    	If WVAT(I)<>"" or WMONTANT(I)>0
    		Call ECR_TRACE("Taxes avant   :"-[F:SID]VAT(I-1)-num$([F:SID]AMTTAXLIN(I-1)),WSTAT) From GESECRAN
    		Call ECR_TRACE("Taxes calculées:"-WVAT(I)-num$(WMONTANT(I))-num$(WMONTDED(I)),WSTAT) From GESECRAN
    	Endif
    Next

	Elsif [F:SIV]PRITYP=2
		#-- TTC vers HT
  	WMONTCALC = [F:SID]AMTATILIN

    Call CALTAXE2(GACTX,[F:SIH_]CPY,[F:SIH_]ACCDAT,"",[F:SIH_]CUR
&            ,WNBTAXES,WVAT,[F:SIV]PRITYP,WMONTCALC,WOTHBASE,WMONTANT,WMONTDED,WTYPREG,WSTAT) From LIBVATSYR

		If WSTAT
			Call ERR_CALTAXE(WSTAT,WMESSA) From LIBVATSYR
			Call ECR_TRACE(WMESSA,1) From GESECRAN : Goto NEXT_SIH_
		Endif

    WMONTCALC = [F:SID]AMTATILIN-sigma(I=1,WNBTAXES,WMONTANT(I))

    If WMONTCALC<>[F:SID]AMTNOTLIN
    	Call ECR_TRACE("#####################Différence de résultat !#######################",1) From GESECRAN
    	WSTAT=1
    Endif

		Call ECR_TRACE("Montant TTC de départ="+num$([F:SID]AMTATILIN)-"Taxes :"-num$(sigma(I=0,2,[F:SID]AMTTAXLIN(I))),WSTAT) From GESECRAN
    Call ECR_TRACE("---2) TTC vers HT :"-"HT calculé="+num$(WMONTCALC)-"/ Avant="-num$([F:SID]AMTNOTLIN),WSTAT) From GESECRAN
    For I=1 To WNBTAXES
    	If WVAT(I)<>"" or WMONTANT(I)>0
    		Call ECR_TRACE("Taxes avant   :"-[F:SID]VAT(I-1)-num$([F:SID]AMTTAXLIN(I-1)),WSTAT) From GESECRAN
    		Call ECR_TRACE("Taxes calculées:"-WVAT(I)-num$(WMONTANT(I))-num$(WMONTDED(I)),WSTAT) From GESECRAN
    	Endif
    Next

	Endif
$NEXT_SIH_
Next

Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End

Subprog UNIT_TEST_PURINV()

Local Decimal WMONTANT(1..)     : # Montant des taxes
Local Decimal WMONTDED(1..)     : # Montant déductible
Local Integer WTYPREG           : # Type de régime
Local Integer WSTAT             : # Statut de retour
Local Char    WVAT(GLONVAT)(1..)
Local Integer WNBTAXES
Local Char    WCUR(GLONCUR)
Local Char    WCPY(GLONCPY)
Local Decimal WEXEAMTTAX(1..)   : # Montant exonération :#Pour appel CALTAXE3
Local Decimal WOTHBASE(1..)      : # Pour appel CALTAXE2
Local Decimal WMONTCALC
Local Date 		WDATE
Local Decimal WMTTTAXESDOC
Local Char  	WMESSA(250)

Call OUVRE_TRACE("--------------------------------UNIT_TEST_PURINV--------------------------------") From LECFIC
Call ECR_TRACE("Calcul de taxes : Test re-calcul par ligne de facture achat (pour comparer)",0) From GESECRAN

Local File PINVOICE   [PIH]
Local File PINVOICEV  [PIV]
Local File PINVOICED  [PID]

Link [PIH] With [PID]PID0(1)~=[PIH]NUM,
&								[PIV]PIV0   ~=[PIH]NUM
& As [PIH_]

Filter [PIH_] Where CREDAT>=[01/04/2013]
& Order By Key MYKEY=NUM;PIDLIN Asc
For [PIH_]MYKEY

  Call ECR_TRACE("--------------------------------//--------------------------------",0) From GESECRAN
  Call ECR_TRACE("Facture n°"+[F:PID]NUM-"Ligne"-num$([F:PID]PIDLIN),0) From GESECRAN
  Call ECR_TRACE("Société :"-[PIH_]CPY-"Règime :"-[PIH_]VAC-"Devise :"-[PIH_]CUR,0) From GESECRAN

  #--Calcul normal HT vers TTC
  Raz WMONTANT,WMONTDED,WTYPREG,WSTAT

	WNBTAXES=7
	WVAT(1) = [F:PID]VAT(0)
	WVAT(2) = [F:PID]VAT(1)
	WVAT(3) = [F:PID]VAT(2)
  WVAT(4) = [F:PID]TAXRCP
  WVAT(5) = [F:PID]TAXISS
  WVAT(6) = [F:PID]TAXOTH1
  WVAT(7) = [F:PID]TAXOTH2

	WOTHBASE(1)=[F:PID]CLCAMT1
  WOTHBASE(2)=[F:PID]CLCAMT2
  WOTHBASE(3)=[F:PID]CLCAMT3
  WOTHBASE(4)=[F:PID]CLCAMT4
  WOTHBASE(5)=[F:PID]CLCAMT5
  WOTHBASE(6)=[F:PID]CLCAMT6
  WOTHBASE(7)=[F:PID]CLCAMT7

If [F:PIH]VATDAT<>[0/0/0]
  WDATE=[F:PIH]VATDAT
Else
  WDATE=[F:PIH]ACCDAT
Endif

	#If [F:PIV]PRITYP=1 :#--A ajouter au moment voulu
		#-- HT vers TTC

  	WMONTCALC = [F:PID]AMTNOTLIN

    Call CALTAXE2(GACTX,[F:PIH_]CPY,WDATE,[F:PIH_]VAC,[F:PIH_]CUR
&            ,WNBTAXES,WVAT,1,[F:PID]AMTNOTLIN,WOTHBASE,WMONTANT,WMONTDED,WTYPREG,WSTAT) From LIBVATSYR

		If WSTAT
			Call ERR_CALTAXE(WSTAT,WMESSA) From LIBVATSYR
			Call ECR_TRACE(WMESSA,1) From GESECRAN : Goto NEXT_PIH_
		Endif

    WMONTCALC += sigma(I=1,WNBTAXES,WMONTANT(I))

		WMTTTAXESDOC = [F:PID]AMTTAXLIN1+[F:PID]AMTTAXLIN2+[F:PID]AMTTAXLIN3+[F:PID]AMTTAXRCP+[F:PID]AMTTAXISS+
& 								 [F:PID]AMTTAXOTH1+[F:PID]AMTTAXOTH2

    If WMONTCALC<>[F:PID]AMTATILIN
    	Call ECR_TRACE("#####################Différence de résultat !#######################",1) From GESECRAN
    	WSTAT=1
    Endif

		Call ECR_TRACE("Montant HT de départ="+num$([F:PID]AMTNOTLIN)-"Taxes :"-num$(WMTTTAXESDOC),WSTAT) From GESECRAN
    Call ECR_TRACE("---1) HT vers TTC :"-"TTC calculé="+num$(WMONTCALC)-"/ Avant="-num$([F:PID]AMTATILIN),WSTAT) From GESECRAN

    For I=1 To WNBTAXES
    	Case I
    		When 1,2,3 :
        	If WVAT(I)<>"" or WMONTANT(I)>0
        		Call ECR_TRACE("Taxes avant   :"-[F:PID]VAT(I-1)-num$(evalue("[F:PID]AMTTAXLIN"+num$(I))),WSTAT) From GESECRAN
        		Call ECR_TRACE("Taxes calculées:"-WVAT(I)-num$(WMONTANT(I))-num$(WMONTDED(I)),WSTAT) From GESECRAN
        	Endif
        When 4 :
        	If WVAT(I)<>"" or WMONTANT(I)>0
        		Call ECR_TRACE("Taxes avant   :"-[F:PID]TAXRCP-num$([F:PID]AMTTAXRCP),WSTAT) From GESECRAN
        		Call ECR_TRACE("Taxes calculées:"-WVAT(I)-num$(WMONTANT(I))-num$(WMONTDED(I)),WSTAT) From GESECRAN
        	Endif
        When 5 :
        	If WVAT(I)<>"" or WMONTANT(I)>0
        		Call ECR_TRACE("Taxes avant   :"-[F:PID]TAXISS-num$([F:PID]AMTTAXISS),WSTAT) From GESECRAN
        		Call ECR_TRACE("Taxes calculées:"-WVAT(I)-num$(WMONTANT(I))-num$(WMONTDED(I)),WSTAT) From GESECRAN
        	Endif
        When 6,7:
        	If WVAT(I)<>"" or WMONTANT(I)>0
        		Call ECR_TRACE("Taxes avant   :"-evalue("[F:PID]TAXOTH"+num$(I-5))-num$(evalue("[F:PID]AMTTAXOTH"+num$(I-5))),WSTAT) From GESECRAN
        		Call ECR_TRACE("Taxes calculées:"-WVAT(I)-num$(WMONTANT(I))-num$(WMONTDED(I)),WSTAT) From GESECRAN
        	Endif
			Endcase
    Next
$NEXT_PIH_
Next

Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End

