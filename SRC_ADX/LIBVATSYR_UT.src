###################################################################################
$INIT_WOTHBASE
For I=1 To WNBTAXES
	If WOTHBASE(I)=0
		WOTHBASE(I)=WMONTCALC
	Endif
Next

Return
$INIT_WOTHBASE_TTC
For I=1 To WNBTAXES
	If WOTHBASE(I)=0
		WOTHBASE(I)=WMONTCALC
	Endif
Next

Return
###################################################################################
$TEST

SAV_WMONTCALC = WMONTCALC

Call ECR_TRACE("CALTAXE--------------------------------",0) From GESECRAN
Call ECR_TRACE("Devise :"-WCUR,0) From GESECRAN
Call ECR_TRACE("Montant HT de départ="+num$(WMONTCALC)-"Taxes :"-sigma(I=1,WNBTAXES,WVAT(I)+"/"),0) From GESECRAN

#--Calcul normal HT vers TTC
Raz WMONTANT,WMONTDED,WTYPREG,WSTAT

Call CALTAXE(GACTX,WCPY,WDATE,"",WCUR
&            ,WNBTAXES,WVAT,1,WMONTCALC,WMONTANT,WMONTDED,WTYPREG,WSTAT) From LIBVATSYR

WMONTCALC += sigma(I=1,WNBTAXES,WMONTANT(I))

Call ECR_TRACE("---1) HT vers TTC :"-"TTC calculé="+num$(WMONTCALC)-"Taxes:",0) From GESECRAN
For I=1 To WNBTAXES
	If WVAT(I)<>"" or WMONTANT(I)>0
		Call ECR_TRACE(WVAT(I)-num$(WMONTANT(I))-num$(WMONTDED(I)),0) From GESECRAN
	Endif
Next

#--Calcul inverse TTC vers HT
Raz WMONTANT,WMONTDED,WTYPREG,WSTAT

Call CALTAXE(GACTX,WCPY,WDATE,"",WCUR
&            ,WNBTAXES,WVAT,2,WMONTCALC,WMONTANT,WMONTDED,WTYPREG,WSTAT) From LIBVATSYR

WMONTCALC += -sigma(I=1,WNBTAXES,WMONTANT(I))

Call ECR_TRACE("---2) TTC vers HT :"-"HT calculé="+num$(WMONTCALC)-"Taxes:",0) From GESECRAN
For I=1 To WNBTAXES
	If WVAT(I)<>"" or WMONTANT(I)>0
		Call ECR_TRACE(WVAT(I)-num$(WMONTANT(I))-num$(WMONTDED(I)),0) From GESECRAN
	Endif
Next

If WMONTCALC<>[L]SAV_WMONTCALC
	Call ECR_TRACE("#####################Différence de résultat !#######################",1) From GESECRAN
Endif

#--------------------------------
WMONTCALC = SAV_WMONTCALC

Call ECR_TRACE("CALTAXE2--------------------------------",0) From GESECRAN
Call ECR_TRACE("Devise :"-WCUR,0) From GESECRAN
Call ECR_TRACE("Montant HT de départ="+num$(WMONTCALC)-"Taxes :"-sigma(I=1,WNBTAXES,WVAT(I)+"/"),0) From GESECRAN

#--Calcul normal HT vers TTC
Raz WMONTANT,WMONTDED,WTYPREG,WSTAT

Gosub INIT_WOTHBASE

Call CALTAXE2(GACTX,WCPY,WDATE,"",WCUR
&            ,WNBTAXES,WVAT,1,WMONTCALC,WOTHBASE,WMONTANT,WMONTDED,WTYPREG,WSTAT) From LIBVATSYR

WMONTCALC += sigma(I=1,WNBTAXES,WMONTANT(I))

Call ECR_TRACE("---1) HT vers TTC :"-"TTC calculé="+num$(WMONTCALC)-"Taxes:",0) From GESECRAN
For I=1 To WNBTAXES
	If WVAT(I)<>"" or WMONTANT(I)>0
		Call ECR_TRACE(WVAT(I)-num$(WMONTANT(I))-num$(WMONTDED(I))-num$(WOTHBASE(I)),0) From GESECRAN
	Endif
Next

#--Calcul inverse TTC vers HT
Gosub INIT_WOTHBASE_TTC

Raz WMONTANT,WMONTDED,WTYPREG,WSTAT

Call CALTAXE2(GACTX,WCPY,WDATE,"",WCUR
&            ,WNBTAXES,WVAT,2,WMONTCALC,WOTHBASE,WMONTANT,WMONTDED,WTYPREG,WSTAT) From LIBVATSYR

WMONTCALC += -sigma(I=1,WNBTAXES,WMONTANT(I))

Call ECR_TRACE("---2) TTC vers HT :"-"HT calculé="+num$(WMONTCALC)-"Taxes:",0) From GESECRAN
For I=1 To WNBTAXES
	If WVAT(I)<>"" or WMONTANT(I)>0
		Call ECR_TRACE(WVAT(I)-num$(WMONTANT(I))-num$(WMONTDED(I))-num$(WOTHBASE(I)),0) From GESECRAN
	Endif
Next

If WMONTCALC<>[L]SAV_WMONTCALC
	Call ECR_TRACE("#####################Différence de résultat !#######################",1) From GESECRAN
Endif

#--------------------------------
WMONTCALC = SAV_WMONTCALC

Call ECR_TRACE("CALTAXE3--------------------------------",0) From GESECRAN
Call ECR_TRACE("Devise :"-WCUR,0) From GESECRAN
Call ECR_TRACE("Montant HT de départ="+num$(WMONTCALC)-"Taxes :"-sigma(I=1,WNBTAXES,WVAT(I)+"/"),0) From GESECRAN

#--Calcul normal HT vers TTC
Raz WMONTANT,WMONTDED,WTYPREG,WSTAT,WEXEAMTTAX

Call CALTAXE3(GACTX, WCPY,"CRPOP",WDATE,"",WCUR
&            ,WNBTAXES,WVAT,1,WMONTCALC,WMONTANT,WMONTDED,WEXEAMTTAX,WTYPREG,WSTAT) From LIBVATSYR

WMONTCALC += sigma(I=1,WNBTAXES,WMONTANT(I))

Call ECR_TRACE("---1) HT vers TTC :"-"TTC calculé="+num$(WMONTCALC)-"Taxes:",0) From GESECRAN
For I=1 To WNBTAXES
	If WVAT(I)<>"" or WMONTANT(I)>0
		Call ECR_TRACE(WVAT(I)-num$(WMONTANT(I))-num$(WMONTDED(I))-num$(WEXEAMTTAX(I)),0) From GESECRAN
	Endif
Next

#--Calcul inverse TTC vers HT
Raz WMONTANT,WMONTDED,WTYPREG,WSTAT,WEXEAMTTAX

Call CALTAXE3(GACTX,WCPY,"CRPOP",WDATE,"",WCUR
&            ,WNBTAXES,WVAT,2,WMONTCALC,WMONTANT,WMONTDED,WEXEAMTTAX,WTYPREG,WSTAT) From LIBVATSYR

WMONTCALC += -sigma(I=1,WNBTAXES,WMONTANT(I))

Call ECR_TRACE("---2) TTC vers HT :"-"HT calculé="+num$(WMONTCALC)-"Taxes:",0) From GESECRAN
For I=1 To WNBTAXES
	If WVAT(I)<>"" or WMONTANT(I)>0
		Call ECR_TRACE(WVAT(I)-num$(WMONTANT(I))-num$(WMONTDED(I))-num$(WEXEAMTTAX(I)),0) From GESECRAN
	Endif
Next

If WMONTCALC<>[L]SAV_WMONTCALC
	Call ECR_TRACE("#####################Différence de résultat !#######################",1) From GESECRAN
Endif

WMONTCALC = SAV_WMONTCALC
Raz WOTHBASE

Return
