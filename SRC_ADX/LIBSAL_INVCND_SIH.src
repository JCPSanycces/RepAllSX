  #--The bussines class handles the relation with the scheduling invoice class
  If dim(GSIDHYBHANDLE)>0 and GSIDHYBHANDLE<>null
    FreeGroup GSIDHYBHANDLE
    GSIDHYBHANDLE=null

    Kill GSIDHYBHANDLE
  Endif

  #  #--The gateway instance for new engine
  #  If dim(GSVIC_GATEWAY)>0 and GSVIC_GATEWAY<>null
  #    FreeGroup GSVIC_GATEWAY
  #    GSVIC_GATEWAY=null
