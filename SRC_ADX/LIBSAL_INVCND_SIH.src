    Else
      WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SET_FROM_CREDITNOTE([F:SID]VCRINVCNDLIN,-[F:SID]QTY,-[F:SID]AMTNOTLIN)
    Endif
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
