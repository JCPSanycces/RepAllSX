$OUVRE
Local Integer WRET

  If dim(GSIDHYBHANDLE)>0 and GSIDHYBHANDLE<>null
    FreeGroup GSIDHYBHANDLE
    GSIDHYBHANDLE=null

    Kill GSIDHYBHANDLE
  Endif

  #  If GUSER="CPOy"
  #    Global Integer GWFREEHEAP : GWFREEHEAP = int(freeheap/1024)
  #    Infbox "$OUVRE : GWFREEHEAP ="-num$(GWFREEHEAP)
  #  Endif

  #--Global instance handling the relation between SIH4 lines and SVCRINVCND instances
  #--The bussines class handles the relation with the scheduling invoice class
  Global Instance GSIDHYBHANDLE Using C_SIDHYBHANDLE
  GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null

  #--Mandatory to call in order to have the contoxt set before the first snapshot
  WRET = fmet GSIDHYBHANDLE.AINIT()
  If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
    # Error management
    WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If WRET>=[V]CST_AERROR
      GERR=1
    Else
      GERR=2
    Endif
  Endif
  If GERR=1 : OK=0 : Return : Endif

  #  #--The gateway instance for new engine
  #  Global Instance GSVIC_GATEWAY Using C_AGETEWAYADX
  #  GSVIC_GATEWAY = NewInstance C_AGETEWAYADX AllocGroup null
  If clalev([F:SID99])=0 : Local File SINVOICED [SID99] : Endif
  If clalev([F:SIV99])=0 : Local File SINVOICE  [SIV99] : Endif

Return
