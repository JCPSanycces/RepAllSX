#------------------------------------------------------------------------------------------------------
Funprog SIDHYBHANDLE_GET_INDEX(PCLASS_METHOD
&                              ,PVCRINVCNDTYP,PSOHNUM,PSOPLIN,PSOQSEQ,PVCRINVCNDLIN
&                              ,VAUUID,VSIDHYBHANDLE,VSIDHYBHANDLER_LINE,VMESSAGE)
Value Char        PCLASS_METHOD
Variable Instance VSIDHYBHANDLE Using C_SIDHYBHANDLE
Value Tinyint     PVCRINVCNDTYP
Value Char        PSOHNUM
Value Integer     PSOPLIN
Value Integer     PSOQSEQ
Value Integer     PVCRINVCNDLIN
Variable Char     VAUUID
Variable Integer  VSIDHYBHANDLER_LINE
Variable Char     VMESSAGE

Local Integer WRET : WRET=[V]CST_AOK

If PCLASS_METHOD=AVOID.ACHAR : End WRET : Endif

  #--The gateway instance for new engine
  If dim(SVIC_GATEWAY)>0 and SVIC_GATEWAY<>null
    FreeGroup SVIC_GATEWAY
  Endif
  SVIC_GATEWAY = NewInstance C_AGATEWAYADX AllocGroup null

  #--Sales order line origin
  WRET=[V]CST_AERROR
  If fmet SVIC_GATEWAY.ASETVALLONGINT("VCRINVCNDTYP",PVCRINVCNDTYP(NOL))=[V]CST_AOK
    If fmet SVIC_GATEWAY.ASETVALCHAR("SOHNUM",PSOHNUM(NOL))=[V]CST_AOK
      If fmet SVIC_GATEWAY.ASETVALDEC("SOPLIN",PSOPLIN(NOL))=[V]CST_AOK
        If fmet SVIC_GATEWAY.ASETVALDEC("SOQSEQ",PSOQSEQ(NOL))=[V]CST_AOK
          If fmet SVIC_GATEWAY.ASETVALDEC("VCRINVCNDLIN",PVCRINVCNDLIN(NOL))=[V]CST_AOK
            If fmet SVIC_GATEWAY.ASETVALCHAR("SVICUUID",VSVICUUID(NOL))=[V]CST_AOK
              If fmet SVIC_GATEWAY.ASETVALCHAR("MESSAGE",VMESSAGE)=[V]CST_AOK
                If fmet SVIC_GATEWAY.ASETVALLONGINT("SIDHYBHANDLER_LINE",VSIDHYBHANDLER_LINE)=[V]CST_AOK
                  WRET=fmet SVIC_GATEWAY.ASETVALINST("SIDHYBHANDLE",VSIDHYBHANDLE)
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  If WRET>=[V]CST_AERROR
    VMESSAGE="Error setting parameters for gateway call for '"+PCLASS_METHOD+"'"
    End WRET
  Endif

  #--Let's call the method
  Case PCLASS_METHOD
    When "GET_INDEX"                   : WRET = fmet SVIC_GATEWAY.ARPC("GET_INDEX"                  ,"LIBSAL_INVCND_SIH_GATEWAY")
    When "GET_INDEX_WITH_INSTANCE_ADD" : WRET = fmet SVIC_GATEWAY.ARPC("GET_INDEX_WITH_INSTANCE_ADD","LIBSAL_INVCND_SIH_GATEWAY")
    When Default : End WRET
  Endcase
  If WRET>[V]CST_AOK
    If fmet SVIC_GATEWAY.AGETVALCHAR("MESSAGE",VMESSAGE)>=[V]CST_AERROR
      VMESSAGE="Error durring gateway call for '"+PCLASS_METHOD+"'"
    Endif
    If WRET>=[V]CST_AERROR : End WRET : Endif
  Endif

  WRET=[V]CST_AERROR
  If fmet SVIC_GATEWAY.AGETVALCHAR("SVICUUID",VSVICUUID)=[V]CST_AOK
    If fmet SVIC_GATEWAY.AGETVALCHAR("MESSAGE",VMESSAGE)=[V]CST_AOK
      If fmet SVIC_GATEWAY.AGETVALLONGINT("SIDHYBHANDLER_LINE",VSIDHYBHANDLER_LINE)=[V]CST_AOK
        WRET=fmet SVIC_GATEWAY.AGETVALINST("SIDHYBHANDLE",VSIDHYBHANDLE)
      Endif
    Endif
  Endif
  If WRET>=[V]CST_AERROR
    VMESSAGE="Error getting parameters after gateway call for '"+PCLASS_METHOD+"'"
    End WRET
  Endif

End WRET
#------------------------------------------------------------------------------------------------------
$CREATION_UPDATE_SVIC
Local Integer WLINE,WSVIC,WRET,WTMP

  If [F:SIV]INVTYP=1 and [F:SIV]SIHORI=10
    #--First, the global working handler has to be instantiate if not done yet
    If GSIDHYBHANDLE=null
      #GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
      Return
    Endif

    WRET = fmet GSIDHYBHANDLE.UPDATE_ALL()
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GOK = 0 : GERR = 1
      Else
        GERR=2
      Endif
    Endif
    If GOK=0 or GERR=1 : GOK=0 : Return : Endif

    Local Decimal WINV_QTY_P, WINV_QTY_NP, WCN_QTY_P, WCN_QTY_NP
    Local Decimal WEXTINV_QTY_P, WEXTINV_QTY_NP, WEXTCN_QTY_P, WEXTCN_QTY_NP
    Local Decimal WINV_AMT_P, WINV_AMT_NP, WCN_AMT_P, WCN_AMT_NP
    Local Decimal WEXTINV_AMT_P, WEXTINV_AMT_NP, WEXTCN_AMT_P, WEXTCN_AMT_NP

    # 107888 : Scheduled invoices : X3-4564 (LD:24/11/16)
    # Update of invoiced amount field done when the sales order line is updated in $MAJLIGCDE_SVIC with the other fields to update
#    # Issue 107888 - 2016-08-05 by CPO : Schedule invoice US176 New field invoiced amount line on sales order line
#    #--For each invoice schedule related to the present invoice, update the original's order line invoice amount
#    #--IMPORTANT : I did not put the following order update in MAJLIGCDE because an invoice could have many invoice scheduling line comming from the same order line
#    For WLINE=1 To maxtab(GSIDHYBHANDLE.SIDTOSVIC)
#      If GSIDHYBHANDLE.SIDTOSVIC(WLINE)<>null and find(GSIDHYBHANDLE.SIDTOSVIC(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
#        WSVIC = GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVIC_INDEX
#        If WSVIC>0 and GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC)<>null and
#&          find(GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
#          #--Calling the update method
#
#          #--Reading original document line for updating
#          If GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).VCRTYP=10
#            Readlock [SOQ]SOQ0=GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).VCRNUMORI;
#&                              GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).VCRLINORI;
#&                              GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).VCRSEQORI
#            If fstat = 1 GOK = -1
#               GLOCK = "$SORDERQ"-GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).VCRNUMORI
#&                           -num$(GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).VCRLINORI)
#&                           -num$(GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).VCRSEQORI)
#               Break
#            Elsif fstat  GOK =  0
#               Call RSTA ("SOQ",GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).VCRNUMORI
#&                        -num$(GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).VCRLINORI)
#&                        -num$(GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).VCRSEQORI)) From GLOCK
#               Break
#            Endif
#            #--Getting the total invoiced amount of the schedule invoice
#            WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).GET_INVOICED_VALUES(
#&                                   0, WINV_QTY_P, WINV_QTY_NP, WCN_QTY_P,WCN_QTY_NP,
#&                                   WEXTINV_QTY_P, WEXTINV_QTY_NP, WEXTCN_QTY_P,WEXTCN_QTY_NP,
#&                                   WINV_AMT_P, WINV_AMT_NP, WCN_AMT_P,WCN_AMT_NP,
#&                                   WEXTINV_AMT_P, WEXTINV_AMT_NP, WEXTCN_AMT_P,WEXTCN_AMT_NP)
#            If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
#              # Error management
#              WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
#              If WRET>=[V]CST_AERROR
#                GERR=1
#                Break
#              Else
#                GERR=2
#              Endif
#            Endif
#
#           #[F:SOQ]INVAMT = GSIDHYBHANDLE.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).TOT_INV_AMT
#            [F:SOQ]INVAMT = WINV_AMT_P + WINV_AMT_NP
#
#            Rewrite [F:SOQ]
#            If fstat : GOK = 0 : Call FSTA("SOQ") From GLOCK : Break : Endif
#          Endif
#        Endif
#      Endif
#    Next
#    # End issue 107888 US176

    # 107888 : Scheduled invoices : X3-4564 (LD:24/11/16)
  Endif
  If GERR=1 : GOK=0 : Return : Endif
  If GOK<=0 : Return : Endif

Return
#------------------------------------------------------------------------------------------------------
$CREATION_CN_UPDATE_SVIC
Local Integer WLINE,WSVIC,WRET

  If [F:SIV]INVTYP=2 and [F:SIV]SIHORI=4
    #--First, the global working handler has to be instantiate if not done yet
    If GSIDHYBHANDLE=null
#      GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
      Return
    Endif

    WRET = fmet GSIDHYBHANDLE.UPDATE_ALL()
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GOK = 0 : GERR = 1
      Else
        GERR=2
      Endif
    Endif
    If GOK=0 or GERR=1 : GOK=0 : Return : Endif
  Endif
  If GOK=0 or GERR=1 : GOK=0 : Return : Endif

Return
#------------------------------------------------------------------------------------------------------
$MODIF_UPDATE_SVIC

  Gosub CREATION_UPDATE_SVIC

Return
#------------------------------------------------------------------------------------------------------
$MODIF_CN_UPDATE_SVIC

  Gosub CREATION_CN_UPDATE_SVIC

Return
#------------------------------------------------------------------------------------------------------
$ANNULE_UPDATE_SVIC

  Gosub CREATION_UPDATE_SVIC

Return
#------------------------------------------------------------------------------------------------------
$ANNULE_CN_UPDATE_SVIC

  Gosub CREATION_CN_UPDATE_SVIC

Return
#------------------------------------------------------------------------------------------------------
#** Called from SUBSIH.AVANT_NBLIG the before line modification action for a SIH4 line
#* @param NOL - is the current [M:SIH4] modified line's index
#* @param GMODIF - 0 (line updated)/1 (line deleted)/2 (line inserted)
#*!
$AVANT_NBLIG

  #--The user create/modify the invoice                 => the $CREATION/$MODIF will instantiate
  #--Or the user wants to modify the invoice schedule => it's the TRTSAISVIC that will instantiate
  Case GMODIF
    When 0 : #--0 = Modification ligne
             Gosub AVANT_NBLIG_SVIC_UPD From LIBSAL_INVCND_SIH
             If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif
    When 1 : #--1 = Suppression ligne
             Gosub AVANT_NBLIG_SVIC_DEL From LIBSAL_INVCND_SIH
             If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif
    When 2 : #--2 = Nouvelle ligne
             Gosub AVANT_NBLIG_SVIC_INS From LIBSAL_INVCND_SIH
             If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif

  Endcase

Return
#------------------------------------------------------------------------------------------------------
#** Called from SUBSIH.AVANT_NBLIG Here, we'll have to change the schedule invoice line's status to 'To be invoiced'
#* @param NOL - is the current [M:SIH4] modified line's index
#* @param GMODIF - 0 (line updated)/1 (line deleted)/2 (line inserted)
#*!
$AVANT_NBLIG_SVIC_UPD

Local Integer  WRET, WOK
Local Integer  SIDHYBHANDLER_LINE #--set by the $GSIDHYBHANDLE_GET_INDEX

  #--Here, we'll have to unmark the changes eventually marked after user modification of impacting schedule invoice fields
  #--(percent, quantity, price, amount etc.)
  #TODO
  If [M:SIH0]INVTYP=1 and [M:SIH4]SIDORI(NOL)=10 and [M:SIH4]VCRINVCNDLIN(NOL)>0
    #--First, the global working handler has to be instantiate if not done yet
    If GSIDHYBHANDLE=null
      GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
    Endif
    #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
    #--Set the SIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
    Gosub GSIDHYBHANDLE_GET_INDEX_USING_M_SIH  #--No instance add, because if the user modifications did not concerned the schedule invoice, there is no need to call unset_new
    If SIDHYBHANDLER_LINE<=0
      Return
    Endif

    If 1=1
      #--In order to handle abandonned modifications (on GESSIH, when a line is abandoned - exp : using Escape)
      If GSIDHYBHANDLE<>null
        If GSIDHYBHANDLE.snapshot<>null
          WRET = GSIDHYBHANDLE.freeSnapshot
          If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
            # Error management
            WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
            If WRET>=[V]CST_AERROR
              GERR=1
            Else
              GERR=2
            Endif
          Endif
          If GERR=1 : mkstat=2 : Return : Endif
        Endif
        If GSIDHYBHANDLE.snapshotEnabled = 0
          GSIDHYBHANDLE.snapshotEnabled = 1 #--snapshot enabeling if not done yet
        Endif
      Endif
    Else

      WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).BEFORE_CHANGES([M:SIH4]VCRINVCNDLIN(NOL))
      If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
        # Error management
        WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
        If WRET>=[V]CST_AERROR
          GERR=1
        Else
          GERR=2
        Endif
      Endif
      If GERR=1 : mkstat=2 : Return : Endif
    Endif
  Endif

Return
#------------------------------------------------------------------------------------------------------
#** Called from SUBSIH.AVANT_NBLIG Here, we'll have to change the schedule invoice line's status to 'To be invoiced'
#* @param NOL - is the current [M:SIH4] modified line's index
#* @param GMODIF - 0 (line updated)/1 (line deleted)/2 (line inserted)
#*!
$AVANT_NBLIG_SVIC_INS

  #--Nothing to do...schedule invoice line only inserted throught picking

Return
#------------------------------------------------------------------------------------------------------
#** Called from SUBSIH.AVANT_NBLIG Here, we'll have to change the schedule invoice line's status to 'To be invoiced'
#* @param NOL - is the current [M:SIH4] modified line's index
#* @param GMODIF - 0 (line updated)/1 (line deleted)/2 (line inserted)
#*!
$AVANT_NBLIG_SVIC_DEL

  #--Nothing to do if not deleted line
  If find(status,65,68,83)=0 : Return : Endif

Local Integer WRET
Local Integer SIDHYBHANDLER_LINE #--set by the $GSIDHYBHANDLE_GET_INDEX

  #--Here, we'll have to change the schedule invoice line's status to 'To be invoiced'
  #TODO
  If [M:SIH0]INVTYP=1 and [M:SIH4]SIDORI(NOL)=10 and [M:SIH4]VCRINVCNDLIN(NOL)>0
    #--First, the global working handler has to be instantiate if not done yet
    If GSIDHYBHANDLE=null
      GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
    Endif

    #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
    #--Set the SIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
    Gosub GSIDHYBHANDLE_GET_INDEX_WITH_INSTANCE_ADD_USING_M_SIH  #--Because of the different kind of schedule invoice origins
    If SIDHYBHANDLER_LINE<=0
      Return
    Endif
    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).INV_LINE_DELETED([M:SIH4]VCRINVCNDLIN(NOL))
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GERR=1
      Else
        GERR=2
      Endif
    Endif
    If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif
  Endif

Return
#------------------------------------------------------------------------------------------------------
#** Called from SUBSIH.APRES_NBLIG the after line modification action for a SIH4 line
#* @param NOL - is the current [M:SIH4] modified line's index
#* @param GMODIF - 0 (line updated)/1 (line deleted)/2 (line inserted)
#*!
$APRES_NBLIG

  #--The user create/modify the invoice                 => the $CREATION/$MODIF will instantiate
  #--Or the user wants to modify the invoice schedule => it's the TRTSAISVIC that will instantiate
  Case GMODIF
    When 0 : #--0 = Modification ligne
             Gosub APRES_NBLIG_SVIC_UPD From LIBSAL_INVCND_SIH
             If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif
    When 1 : #--1 = Suppression ligne
             #--Done in AV_NBLIG
    When 2 : #--2 = Nouvelle ligne
             Gosub APRES_NBLIG_SVIC_INS From LIBSAL_INVCND_SIH
             If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif

  Endcase

Return
#------------------------------------------------------------------------------------------------------
#** Called from SUBSIH.APRES_NBLIG Here, we'll have to unmark the changes eventually marked after user modification of impacting schedule invoice fields
#*  (percent, quantity, price, amount etc.)
#* @param NOL - is the current [M:SIH4] modified line's index
#* @param GMODIF - 0 (line updated)/1 (line deleted)/2 (line inserted)
#*!
$APRES_NBLIG_ABA

Local Integer  WRET
Local Shortint WIS_LASTLINE
Local Integer  SIDHYBHANDLER_LINE #--set by the $GSIDHYBHANDLE_GET_INDEX

Local Integer WOK
Local Tinyint WIS_EXTRABILL

  #--Here, we'll have to unmark the changes eventually marked after user modification of impacting schedule invoice fields
  #--(percent, quantity, price, amount etc.)
  #TODO
  If [M:SIH0]INVTYP=1 and [M:SIH4]SIDORI(NOL)=10 and [M:SIH4]VCRINVCNDLIN(NOL)>0
    #--First, the global working handler has to be instantiate if not done yet
    If GSIDHYBHANDLE=null
      GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
    Endif
    #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
    #--Set the SIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
    Gosub GSIDHYBHANDLE_GET_INDEX_USING_M_SIH  #--No instance add, because if the user modifications did not concerned the schedule invoice, there is no need to call unset_new
    If SIDHYBHANDLER_LINE<=0
      Return
    Endif

    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).UNSET_NEW([M:SIH4]VCRINVCNDLIN(NOL),[M:SIH0]NUM,WIS_LASTLINE)
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GERR=1
      Else
        GERR=2
      Endif
    Endif
    If GERR=1 : mkstat=2 : Return : Endif
#   If 1=1
    #--In order to handle abandonned modifications (on GESSIH, when a line is abandoned - exp : using Escape)
    If GSIDHYBHANDLE<>null and GSIDHYBHANDLE.snapshot<>null
      WRET = GSIDHYBHANDLE.revertToSnapshot
      If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
        # Error management
        WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
        If WRET>=[V]CST_AERROR
          GERR=1
        Else
          GERR=2
        Endif
      Endif
      If GERR=1 : mkstat=2 : Return : Endif
    Endif
#   Else
#    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).CANCEL_CHANGES([M:SIH4]VCRINVCNDLIN(NOL))
#    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
#      # Error management
#      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
#      If WRET>=[V]CST_AERROR
#        GERR=1
#      Else
#        GERR=2
#      Endif
#    Endif
#    If GERR=1 : mkstat=2 : Return : Endif
#   Endif
  Endif

Return
#------------------------------------------------------------------------------------------------------
$APRES_NBLIG_SVIC_UPD
Local Integer WRET,WSVIC_INDEX
Local Integer SIDHYBHANDLER_LINE #--set by the $GSIDHYBHANDLE_GET_INDEX
Local Decimal WNEWINVPERCENT, WNEWQTY

  #--Changing the quantity or doing a price search, the invoice schedule line has to be updated
  #--First, the invoice line has to come from an invoice schedule
  If [M:SIH0]INVTYP=1 and [M:SIH4]SIDORI(NOL)=10 and [M:SIH4]VCRINVCNDLIN(NOL)>0
    #--First, the global working handler has to be instantiate if not done yet
    If GSIDHYBHANDLE=null
      GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
    Endif
    #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
    #--Set the SIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
    Gosub GSIDHYBHANDLE_GET_INDEX_WITH_INSTANCE_ADD_USING_M_SIH #--Because of the different kind of schedule invoice origins
    If SIDHYBHANDLER_LINE<=0
      Return
    Endif

    #--No need to recall this
    #--Setting the INVCNDSTA and the SIHNUM/SIDLIN
    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SET_LIG_INVCNDSTA([M:SIH4]VCRINVCNDLIN(NOL),5)
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GERR=1
      Else
        GERR=2
      Endif
    Endif
    If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif

    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SET_LIG_SIHNUM([M:SIH4]VCRINVCNDLIN(NOL),[F:SIV]NUM,[M:SIH4]SIDLIN(NOL))
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GERR=1
      Else
        GERR=2
      Endif
    Endif
    If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif

    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).DO_CHANGES([M:SIH4]VCRINVCNDLIN(NOL))
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GERR=1
      Else
        GERR=2
      Endif
    Endif
    If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif

    #--Updating the m:sih4 mask with new values
    WSVIC_INDEX = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVIC_INDEX
    If WSVIC_INDEX>0 and  GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX)<>null and
&     find(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      #--Now, let's set the invoice line's new quantity
      For WLINE=1 To maxtab(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN)
        If GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE)<>null and
&     find(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
          If GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).VCRINVCNDLIN = [M:SIH4]VCRINVCNDLIN(NOL)
            WNEWQTY        = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).INVCNDQTY+
&                            GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).LIN_EXT_QTY
            WNEWINVPERCENT = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).INVPERCENT
            #--quantity changed ?
            If    [M:SIH4]QTY(NOL)<>WNEWQTY or [M:SIH4]INVPRC(NOL)<>WNEWINVPERCENT
              #--Not in case of extra-billing
              If [M:SIH4]QTY(NOL)<WNEWQTY or GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).IS_EXTRABILL<>[V]CST_AYES
                Call AM_QTY(WNEWQTY) From SUBSIH
                If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif
                [M:SIH4]QTY(NOL) = WNEWQTY
                Affzo [M:SIH4]QTY(NOL)
              Endif
#            #--percent changed ?
#            Elsif [M:SIH4]INVPRC(NOL)<>WNEWINVPERCENT
              #--Not in case of extra-billing
              If [M:SIH4]INVPRC(NOL)<WNEWINVPERCENT or GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).IS_EXTRABILL<>[V]CST_AYES
                [M:SIH4]INVPRC(NOL) = WNEWINVPERCENT
                Affzo [M:SIH4]INVPRC(NOL)
              Endif
            Else

            Endif
          Endif
        Endif
      Next
    Else
      mkstat=2
    Endif

    If 1=1
      #--In order to handle abandonned modifications (on GESSIH, when a line is abandoned - exp : using Escape)
      If GSIDHYBHANDLE<>null
        If GSIDHYBHANDLE.snapshot<>null
          WRET = GSIDHYBHANDLE.freeSnapshot
          If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
            # Error management
            WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
            If WRET>=[V]CST_AERROR
              GERR=1
            Else
              GERR=2
            Endif
          Endif
          If GERR=1 : mkstat=2 : Return : Endif
        Endif
        If GSIDHYBHANDLE.snapshotEnabled = 0
          GSIDHYBHANDLE.snapshotEnabled = 1 #--snapshot enabeling if not done yet
        Endif
      Endif
    Else
      WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).AFTER_CHANGES([M:SIH4]VCRINVCNDLIN(NOL))
      If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
        # Error management
        WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
        If WRET>=[V]CST_AERROR
          GERR=1
        Else
          GERR=2
        Endif
      Endif
      If GERR=1 : mkstat=2 : Return : Endif
    Endif

  Endif
  If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif

Return
#------------------------------------------------------------------------------------------------------
$APRES_NBLIG_SVIC_INS

Return
#------------------------------------------------------------------------------------------------------
$CALPFM_SVIC

  If dim(NLIG)<1 or clalev([M:SIH4])=0 or dim([M:SIH4]VCRINVCNDLIN(NLIG))<1 or dim([M:SIH4]SIDORI(NLIG))<1
    Return
  Endif

  If GFONCTION="GESSIH" and dim([M:SIH0]INVTYP)>0 and [M:SIH0]INVTYP=1 and dim([M:SIH1]SIHORI)>0 and [M:SIH1]SIHORI=10 and
&   dim([M:SIH4]VCRINVCNDLIN(NLIG))>0 & [M:SIH4]VCRINVCNDLIN(NLIG)>0 and dim([M:SIH4]SIDORI(NLIG))>0 and [M:SIH4]SIDORI(NLIG)=10

  Local Integer WRET,WNOL
  Local Integer SIDHYBHANDLER_LINE #--set by the $GSIDHYBHANDLE_GET_INDEX
  Local Decimal WNEWINVPERCENT

  #--Changing the quantity or doing a price search, the invoice schedule line has to be updated
  #--First, the invoice line has to come from an invoice schedule
  If [M:SIH0]INVTYP=1 and [M:SIH4]SIDORI(NLIG)=10 and [M:SIH4]VCRINVCNDLIN(NLIG)>0
    #--First, the global working handler has to be instantiate if not done yet
    If GSIDHYBHANDLE=null
      GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
    Endif

    #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
    #--Set the SIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
    NOL=NLIG
    Gosub GSIDHYBHANDLE_GET_INDEX_WITH_INSTANCE_ADD_USING_M_SIH  #--Because of the different kind of schedule invoice origins
    If SIDHYBHANDLER_LINE<=0
      Return
    Endif

    If [M:SIH1]PRITYP=2
      WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SET_NEW_PRICE([M:SIH4]VCRINVCNDLIN(NLIG),[M:SIH4]NETPRIATI(NLIG))
    Else
      WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SET_NEW_PRICE([M:SIH4]VCRINVCNDLIN(NLIG),[M:SIH4]NETPRINOT(NLIG))
    Endif
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        mkstat = 2
      Else
        GERR=2
      Endif
    Endif
    If mkstat>0 : Return : Endif
  Endif

  Endif
Return
#------------------------------------------------------------------------------------------------------
#**
#* Label GET_INVOICES_VALUES is used for a scheduled invoice,  to get all the values (invoice qty/amount, extra invoice qty/amount etc ...)
#* It is called by $MAJENTCDE at the creation/modification/delete of an invoice line tied to a order scheduled invoice
#*                 (necessary for the update of "on order" amount in the the customer balances)
#* It returns GOK = 0 and GERR = 1 in case an error occurs
#*!
$GET_INVOICED_VALUES
Local Integer WRET, WSVIC_INDEX
Local Integer SIDHYBHANDLER_LINE #--set by the $GSIDHYBHANDLE_GET_INDEX

Local Decimal WINV_QTY_P, WINV_QTY_NP, WCN_QTY_P, WCN_QTY_NP
Local Decimal WEXTINV_QTY_P, WEXTINV_QTY_NP, WEXTCN_QTY_P, WEXTCN_QTY_NP
Local Decimal WINV_AMT_P, WINV_AMT_NP, WCN_AMT_P, WCN_AMT_NP
Local Decimal WEXTINV_AMT_P, WEXTINV_AMT_NP, WEXTCN_AMT_P, WEXTCN_AMT_NP

#--First, the global working handler has to be instantiate if not done yet
If GSIDHYBHANDLE=null
  GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
Endif

#--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
#--Set the SIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
If TRTLIG="A"
    Gosub GSIDHYBHANDLE_GET_INDEX_WITH_INSTANCE_ADD_USING_F_SIV_SID  #--Because of the different kind of schedule invoice origins
Else
    Gosub GSIDHYBHANDLE_GET_INDEX_WITH_INSTANCE_ADD_USING_M_SIH #--Because of the different kind of schedule invoice origins
Endif
If SIDHYBHANDLER_LINE<=0
  Return
Endif

# 107888 : Scheduled invoices : (LD:03/06/16)
WSVIC_INDEX = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVIC_INDEX
If WSVIC_INDEX>0 and  GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX)<>null and
&  find(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).GET_INVOICED_VALUES(WVCRINVCNDLIN, WINV_QTY_P, WINV_QTY_NP, WCN_QTY_P,WCN_QTY_NP,
&                                   WEXTINV_QTY_P, WEXTINV_QTY_NP, WEXTCN_QTY_P,WEXTCN_QTY_NP,
&                                   WINV_AMT_P, WINV_AMT_NP, WCN_AMT_P,WCN_AMT_NP,
&                                   WEXTINV_AMT_P, WEXTINV_AMT_NP, WEXTCN_AMT_P,WEXTCN_AMT_NP)
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GERR=1
      Else
        GERR=2
      Endif
    Endif
Endif
If GOK=0 or GERR=1 : GOK=0 : Return : Endif

Return
# 107888 : Scheduled invoices : (LD:03/06/16)
#------------------------------------------------------------------------------------------------------
# Issue 107888 - 2016-08-04 by CPO : US210 Scheduling invoices - Invoice posting
#**
#* INVOICE_POSTING_SET_SVIC_INVCNDSTA is called from TRTVENFACV Suprog VALIDATION during invoice posting
#* It is used to update the schedule line status from 'On invoice' to 'Invoiced'
#* Called from within a For on [SID] loop and inside a transaction on progress. Set GOK=0 if an error occurs
#* @param [F:SIV]/[F:SIH] "online"
#* @param [F:SID] Current SINVOICED line (called from within a For on [SID] loop)
#* @param Transaction on progress
#* @param GOK Set to 0 if an error occurs
#*
#*!
$INVOICE_POSTING_SET_SVIC_INVCNDSTA

  #--After posting an invoice, the invoice schedule line has to be updated
  #--First, the invoice line has to come from an invoice schedule
  If [F:SIV]INVTYP=1 and [F:SID]SIDORI=10 and [F:SID]VCRINVCNDLIN>0
    Local Integer WRET,WSVIC_INDEX, WNEWGSIDHYBHANDLE
    Local Integer SIDHYBHANDLER_LINE #--set by the $GSIDHYBHANDLE_GET_INDEX
    Local Tinyint PNEWINVCNDSTA : PNEWINVCNDSTA = 2 #--'Invoiced'
    If dim(GSIDHYBHANDLE)<0
      Local Instance GSIDHYBHANDLE Using C_SIDHYBHANDLE
      WNEWGSIDHYBHANDLE = [V]CST_AYES
    Endif

    #--First, the global working handler has to be instantiate if not done yet
    If GSIDHYBHANDLE=null
      GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
    Endif
    #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
    #--Set the SIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
    Gosub GSIDHYBHANDLE_GET_INDEX_WITH_INSTANCE_ADD_USING_F_SIV_SID #--Because of the different kind of schedule invoice origins
    If SIDHYBHANDLER_LINE<=0
      Return
    Endif

    #--Setting scheduling invoice line's status to 'Invoiced'
    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SET_LIG_INVCNDSTA([F:SID]VCRINVCNDLIN,PNEWINVCNDSTA)
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GOK = 0 : GERR=1
      Else
        GERR=2
      Endif
    Endif
    If GOK=0 or GERR=1 : GOK=0 : Return : Endif

    Endif
    If GOK=0 or GERR=1 : GOK=0 : Return : Endif

Return
#------------------------------------------------------------------------------------------------------
$INVOICE_POSTING_UPD_SVIC

  #--After posting an invoice, the invoice schedule line has to be updated
  #--First, the invoice line has to come from an invoice schedule
  If [F:SIV]INVTYP=1 and [F:SID]SIDORI=10 and [F:SID]VCRINVCNDLIN>0
    Gosub CREATION_UPDATE_SVIC
    If GOK=0 or GERR=1 : GOK=0 : Return : Endif
  Endif

Return
# End issue 107888 US210
#------------------------------------------------------------------------------------------------------
# Issue 107888 - 2016-08-19 by CPO : Scheduling invoice - Invoice button from Orders
$GEN_FAC_SOH_SVIC
If dim(GCPO_NBREAD)<1 : Global Integer GCPO_NBREAD : Endif #--CPO A virer
REP="C"
Local Integer OK, NBINV, WFIN
Local Char    CRITERE(250), CRITDET(150)
Local Char    CRITSVCRINVCND(255),CRITSVCRINVCNDLIN(255)

#-- pour appel GENSIH
Local Integer LCOD      : LCOD = 2
Local Char    LMAJ(2)   : LMAJ ="C"
Local Integer LECH      : LECH = 2
Local Integer LTEST     : LTEST= 1 #2 commit avec trace #1 commit et pas de trace
Local Char    LTRT(30)  : LTRT ="TRTSIHSVICSOHBT"
Local Char    LORINUM(GLONVCR)
Local Char    LSIVNUM(GLONVCR)
Local Integer LERR      : LERR = 0

#If GUSER="LD" LTEST=2 Endif

  #--Schedule header
  CRITSVCRINVCND     = '1=1'
  #--Schedule line
  CRITSVCRINVCNDLIN  = '1=1'
  CRITSVCRINVCNDLIN += '&[F:SVICD]INVCNDSTA<=1'
  CRITSVCRINVCND    += '&[F:SVICD]NEXINVDAT<=['+format$(GFMD,date$)+']'
  CRITSVCRINVCND    += '&[F:SVICD]VCRTYP=10'

  #--Etape 1
  #--Set up des critères de filtre pour les lignes intermédiaires
  #--CRITERE : contient des filtres sur la table en-tête à l'origine de la ligne intermédiaire
  #--Objectif : sélectionner les lignes intermédiaires à traiter lors de la facturation courante
  #--> critères de saisie
  CRITERE  = '[SOH]SALFCY="' +[M:SOH0]SALFCY+'"'
  CRITERE -= '&[SOH]SOHNUM="'+[M:SOH0]SOHNUM+'"'
  CRITERE -= '&[SOH]BPCINV="'+[M:SOH1]BPCINV+'"'

  # V6.2 : Certification
  # Si ctrl date documents : La commande doit avoir une date <= à la date de la facture
  If GCTLDATORI=2  CRITERE -='& [SOH]ORDDAT<=['+format$(GFMD,date$)+']' Endif

  #--> Critères supplémentaires
  CRITERE -= "&[SOH]HLDSTA<2"                 :# order holds
  CRITERE -= "&[SOH]SOHCAT=1"                 :# cat  cde         =  normale
 #CRITERE -= "& ALLSTA <> 1"                  :# état alloc       allouée même partiellement
  CRITERE -= "&[SOH]INVSTA<>3"                :# état facture     non facturée
  # 107888 : Scheduled invoices : X3-21154 (LD:18/01/17)
  # The invoice mode should not be taken into account
  #CRITERE -= "&[SOH]IME<>6"                   :# mode facturation <> fact manuelle
  # 107888 : Scheduled invoices : X3-21154 (LD:18/01/17)
  CRITERE -= "&[SOH]APPFLG>2"                 :# état signature cde : signée

  #--Set up des critères de filtre pour les lignes intermédiaires
  #--CRITERE : contient des filtres sur la table en-tête à l'origine de la ligne intermédiaire
  #--Objectif : sélectionner les lignes intermédiaires à traiter lors de la facturation courante

  #--> Critères supplémentaires
  CRITDET  = "[SOQ]SOQSTA<>3"
  CRITDET -= "&[SOQ]DEMSTA=1"

  GSIVTYP  = [M:SIH0]SIVTYP

  #--Link de la table des lignes intermédiaires avec les tables en-tête/lignes à l'origine de ces dernières
  #--Les filtres utilisés :
  #--CRITSVCRINVCND   : porte directement sur la tables des échéanciers
  #--CRITSVCRINVCND   : porte directement sur les lignes de la table des échéanciers
  #--CRITERE          : porte sur les champs de la table en-tête d'origine (içi SORDER)
  #--FILSUPENT        : positionné par point d'entrée - contient les éventuels filtres sur champs en-tête table origine
  #--CRITDET          : porte sur les champs de la table lignes d'origine (içi SORDERQ uniquement)
  #--FILSUPDET        : positionné par point d'entrée - contient les éventuels filtres sur champs ligne table origine

  #--Définition du Link entre table intermédiaire et en-tête/lignes origine
  Link [SVICD] With [SVIC]SVIC0~=[SVICD]VCRTYP;
&                                [SVICD]VCRNUMORI;[SVICD]VCRLINORI;[SVICD]VCRSEQORI,
&                   [SOH]SOH0  ~=[SVICD]VCRNUMORI,
&                   [SOQ]SOQ0  ~=[SVICD]VCRNUMORI;[SVICD]VCRLINORI;[SVICD]VCRSEQORI,
&                   [SOP]SOP0  ~=[SVICD]VCRNUMORI;[SVICD]VCRLINORI;[SVICD]VCRSEQORI
&               As  [SVICLNK]
&           Where evalue(CRITSVCRINVCND) and
&                 evalue(CRITSVCRINVCNDLIN) and
&                (evalue(CRITERE)) and
&                (evalue(CRITDET))
  #--Boucle sur link et alimentation des masques SIHx au travers du READ_DETAIL du TRTSIHSVICSOHBT
  #--Comme on est censé être sur une seule commande, on ne teste pas de rupture et on fait des Read Next sur le link

  Read [SVICLNK] First
  If fstat : WFIN=1 : Endif
  While WFIN=0

    #----- Blocage logique de la demande
    SYMBOLE = "SOH"+[F:SOH]SOHNUM
    Lock = SYMBOLE
    If fstat
       # modification en cours sur un autre poste
       GERR=1 : GMESSAGE=[F:SOH]SOHNUM-":"-mess(10,100,1)
       Call ECR_TRACE(GMESSAGE,1) From GESECRAN
       OK=1   : WFIN=1 : Goto FIN_SOHSIH
    Endif
    #-----

    #----- Blocage logique de l'échéance à facturer
    #......
    #-----

    #Appel du composant de création facture.
    Call GENSIH(LCOD, LMAJ, LECH, LTEST, LTRT, LORINUM, LSIVNUM, LERR) From TRTVENFACG
    If LERR Then
      # 107888 : Scheduled invoices : X3-6337 (LD:28/10/16)
      #Call ECR_TRACE("Erreur création facture ! LERR="+num$(LERR)-"GERR="+num$(GERR),1) From GESECRAN
      Call ECR_TRACE(mess(888,197,1),1) From GESECRAN
      # 107888 : Scheduled invoices : X3-6337 (LD:28/10/16)
      If LERR>0 or GERR=1 : GERR=1 : WFIN=1 : Endif
      Goto FIN_SOHSIH
    Else
      NBINV += 1
    Endif

    $FIN_SOHSIH
    #----- Déblocage logique de la demande
    #-!!! ATTENTION il faut délocker les symboles posés ds GENSIH dans le LTRT en READ_DETAIL (A FAIRE aussi)
    #If OK=0 |LERR>0 Unlock = SYMBOLE : Endif
    Unlock =SYMBOLE
    #----- Déblocage logique de l'échéance à facturer
    #.....

    #--break with error
    If WFIN >0 and not([SVICD]VCRNUMORI="" and [SVICD]VCRLINORI=0 and [SVICD]VCRTYP=0)
      GOK=0 : GERR=1 : Break
    Endif
    #--fields empty means no more entry for Read [SWILNK_]CLE next, need to exit the loop
    If  ([SVICD]VCRNUMORI="" and [SVICD]VCRLINORI=0 and [SVICD]VCRTYP=0)
      Break
    Endif

  Wend

  If [M:SIH4]NBLIG = 0 Then
    GERR = 1
    GMESSAGE = mess(68,192,1)
    Raz GOK
  Endif
  #
  If GOK=0 or GERR=1
    Raz [M:SIH0],[M:SIH1],[M:SIH2],[M:SIH4] #--In order not to have partially filled masks after an error
  Endif

Kill GCPO_NBREAD #--A virer

Return
#------------------------------------------------------------------------------------------------------

#########################################################################
# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
#########################################################################
#**
#* Label MAJLIGCDE_SVIC is used to update the order linked to the schedule invoice line that is invoiced
#* Copy of MAJLIGCDE From SUBSIHA with particularities for schedule invoice
#* called from $VALLIGCRE, $VALLIGMOD, $VALLIGANN from GESSIH
#* It returns GOK = 0 and GERR = 1 in case an error occurs
#* #*!
$MAJLIGCDE_SVIC
#-------------------------#
# Maj lignes de commandes #
#-------------------------#
Local  Integer  STAT, WSOQSTA
Local  Decimal  WDIFF
Local  Decimal  WSTUSAUCOE
Local  Char     WSAU(GLONUOM)
Local  Integer  STAT, WRMN

# This concerns old extrafacturation qtys (before the update)
# Search extrafacturation for the update of customer balances : "on order" customer amount (ORDBPIATI,NOT in BPCUSTMVT) and line invoice update
#                         for the update of the order linked to the schedule invoice line that is invoiced
# This concerns new extrafacturation qtys (after the update)
Local Integer WVCRINVCNDLIN
# We need the additional invoiced quantity for the order line that is invoiced (all the scheduled invoice lines)
WVCRINVCNDLIN=0 : Gosub GET_INVOICED_VALUES From LIBSAL_INVCND_SIH
If GOK <= 0  Return  Endif
WNEWEXTQTY_NP = WEXTINV_QTY_NP
WNEWEXTQTY_P  = WEXTINV_QTY_P

Case TRTLIG
  When "C" :
      DELTAQTY    = DELTAQTY - (WNEWEXTQTY_NP+WNEWEXTQTY_P) + (WOLDEXTQTY_NP+WOLDEXTQTY_P)
  When "M" :
      DELTAQTY    = DELTAQTY - (WNEWEXTQTY_NP+WNEWEXTQTY_P) + (WOLDEXTQTY_NP+WOLDEXTQTY_P)
  When "A" :
      DELTAQTY    = DELTAQTY + (WNEWEXTQTY_NP+WNEWEXTQTY_P) + (WOLDEXTQTY_NP+WOLDEXTQTY_P)
  When Default :
Endcase

Readlock [SOQ] SOQ0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
If fstat = 1 GOK = -1
   GLOCK = "$SORDERQ"-[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SOQ",[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)) From GLOCK
   Return
Endif

Readlock [SOP] SOP0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
If fstat = 1 GOK = -1
   GLOCK = "$SORDERP"-[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SOP",[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)) From GLOCK
   Return
Endif
WSAU = [F:SOP]SAU
If [F:SOP]SAUSTUCOE=0 [F:SOP]SAUSTUCOE=1 Endif
WSTUSAUCOE = 1/[F:SOP]SAUSTUCOE

# Invoiced qty contains extra facturation, we remove it to update correctly order status
[F:SOQ]ODLQTY -= WOLDEXTQTY_NP
[F:SOQ]INVQTY -= WOLDEXTQTY_P

# Sauvegarde de la diff. entre qte cde et fac pour maj de l'en_cde client
Raz WDIFF
WDIFF = [F:SOQ]QTY - ([F:SOQ]ODLQTY + [F:SOQ]INVQTY)

# Sauvegarde état ligne commande
WSOQSTA    = [F:SOQ]SOQSTA

# Maj quantités allouées, ruptures, à livrer
If TRTLIG = "C"
   Raz [F:SOQ]ALLQTY, [F:SOQ]ALLQTYSTU, [F:SOQ]SHTQTY, [F:SOQ]SHTQTYSTU
   Raz [F:SOQ]TDLQTY
   Raz [F:SOQ]TDLQTYSTU
Endif

[F:SOQ]SOQSTA = 1
[F:SOQ]INVFLG = 1

# For schedules invoice, we work with qty is UV (not with qty in US)
# because extra facturation qty is only known in UV

# Positionnement état ligne avant maj entête
#If [F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU+DELTAQTYSTU >= [F:SOQ]QTYSTU
If [F:SOQ]ODLQTY+[F:SOQ]INVQTY+DELTAQTY >= [F:SOQ]QTY
   [F:SOQ]INVFLG = 2
Endif

# Bug 52442 : Si composant kit, le statut de solde doit être le même que celui du composé
If !find([F:SOP]LINTYP,3,4,5)
    #If [F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU+DELTAQTYSTU >= [F:SOQ]QTYSTU
    If [F:SOQ]ODLQTY+[F:SOQ]INVQTY+DELTAQTY >= [F:SOQ]QTY
       [F:SOQ]SOQSTA = 3
    Else
       #WQTY = [F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU+DELTAQTYSTU
       WQTY = [F:SOQ]ODLQTY+[F:SOQ]INVQTY+DELTAQTY
       If WQTY>0
           #Call SCAL_RMN ([F:SOQ]QTYSTU, WQTY, [F:SOQ]ITMREF, WRMN, STAT) From TRTVENQTE
           Call SCAL_RMN ([F:SOQ]QTY, WQTY, [F:SOQ]ITMREF, WRMN, STAT) From TRTVENQTE
           If WRMN=1 [F:SOQ]SOQSTA=3 Endif
       Endif
    Endif
    If [F:SOP]LINTYP=2 WCPE_SOQSTA=[F:SOQ]SOQSTA Endif
Else
    [F:SOQ]SOQSTA=WCPE_SOQSTA
Endif

# maj entête commande (avant maj détail cde)
Gosub MAJENTCDE From SUBSIHA
If GOK = 0  Return  Endif

# Si facture validée
If [F:SIV]INVSTA = 3
   [F:SOQ]INVQTY    += DELTAQTY
   [F:SOQ]INVQTYSTU += DELTAQTYSTU
Else
   [F:SOQ]ODLQTY    += DELTAQTY
   [F:SOQ]ODLQTYSTU += DELTAQTYSTU
Endif

# 107888 : Scheduled invoices : X3-4564 (LD:24/11/16)
[F:SOQ]INVAMT = WINV_AMT_P + WINV_AMT_NP + WEXTINV_AMT_P + WEXTINV_AMT_NP
# 107888 : Scheduled invoices : X3-4564 (LD:24/11/16)

# Invoiced qty contains extra facturation, we reput it
If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 10 & [F:SID]VCRINVCNDLIN>0
    [F:SOQ]ODLQTY += WNEWEXTQTY_NP
    [F:SOQ]INVQTY += WNEWEXTQTY_P
Endif

# Récriture du détail commande (SOP)
[F:SOP]SOQSTA = [F:SOQ]SOQSTA
Rewrite [SOP]
If fstat : GOK = 0 : Call FSTA("SOP") From GLOCK : Return : Endif

# Récriture du détail commande (SOQ)
Rewrite [SOQ]
If fstat : GOK = 0 : Call FSTA("SOQ") From GLOCK : Return : Endif

Return
# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)


#########################################################################
# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
#########################################################################
$MAJENTCDE_CRE_SVIC
#-------------------------------------------------#
# Maj entête de commande en création de ligne     #
#-------------------------------------------------#
# La ligne de commande qui est en ligne n'est pas encore maj
# (sauf [F:SOQ]SOQSTA,INVFLG,ALLQTY,ALLQTYSTU,SHTQTY,SHTQTYSTU,TDLQTY,TDLQTYSTU)

#-------------------------------------------------#
# Recalcul état solde                             #
#-------------------------------------------------#
# La ligne de commande n'était pas soldée, et elle le devient
If WSOQSTA <> 3 & [F:SOQ]SOQSTA = 3
   [F:SOH]CLELINNBR += 1
   If [F:SOH]CLELINNBR >= [F:SOH]LINNBR
      [F:SOH]ORDSTA = 2
   Endif
Endif

# Bug 49166 : Une commande soldée est considérée comme non allouée
If [F:SOH]ORDSTA = 2 [F:SOH]ALLSTA=1 : [F:SOH]ALLLINNBR=0 Endif

# For schedules invoice, we work with qty is UV (not with qty in US)
# because extra facturation qty is only known in UV

#-------------------------------------------------#
# Recalcul état facturation                       #
#-------------------------------------------------#
# Ancien cumul (en facturation + facturé)
#QTECALC = [F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU
QTECALC = [F:SOQ]ODLQTY+[F:SOQ]INVQTY

If [F:SOH]INVSTA<>3 [F:SOH]INVSTA=2 Endif
# La ligne de commande n'était pas facturée
#If QTECALC < [F:SOQ]QTYSTU
If QTECALC < [F:SOQ]QTY
   # La ligne de commande devient facturée
   #If QTECALC + DELTAQTYSTU >= [F:SOQ]QTYSTU
   If QTECALC + DELTAQTY >= [F:SOQ]QTY
      [F:SOH]INVLINNBR += 1
      # La cde devient facturée
      If [F:SOH]INVLINNBR >= [F:SOH]LINNBR
         [F:SOH]INVSTA = 3
      Endif
   Endif
Endif

#-------------------------------------------------#
# Maj des montants à facturer HT et TTC           #
#-------------------------------------------------#
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:19/12/16)
#If [F:SOH]ORDSTA = 2
#   [F:SOH]DLRNOT = 0
#   [F:SOH]DLRATI = 0
#Else
#   QTECALC = [F:SID]QTY
#   MNTCALC = QTECALC * [F:SOP]NETPRINOT
#   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
#   [F:SOH]DLRNOT -= MNTCALC
#   MNTCALC = QTECALC * [F:SOP]NETPRIATI
#   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
#   [F:SOH]DLRATI -= MNTCALC
#Endif
If [F:SOH]ORDSTA = 2
   [F:SOH]INRSCHNOT = 0
   [F:SOH]INRSCHATI = 0
Else
   # We should not consider the extra facturation, so we take DELTAQTY instead of [F:SID]QTY
   QTECALC = DELTAQTY
   MNTCALC = QTECALC * [F:SOP]NETPRINOT
   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
   [F:SOH]INRSCHNOT -= MNTCALC
   MNTCALC = QTECALC * [F:SOP]NETPRIATI
   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
   [F:SOH]INRSCHATI -= MNTCALC
Endif
[F:SOH]INRNOT = [F:SOH]DLRNOT + [F:SOH]INRSCHNOT
[F:SOH]INRATI = [F:SOH]DLRATI + [F:SOH]INRSCHATI
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:19/12/16)
#-------------------------------------------------#
# Maj de l'en commande client                     #
#-------------------------------------------------#
Raz WCDEHT, WCDETTC

# Si Qté facturé > Ce qu'il restait à facturé
# alors on décrémente l'en cde de ce qu'il restait à facturer
If DELTAQTY > WDIFF
   WCDETTC = (WDIFF*[F:SOP]NETPRIATI)*(-1)
   WCDEHT  = (WDIFF*[F:SOP]NETPRINOT)*(-1)
# Si Qté facturé <= Ce qu'il restait à facturer
# alors on décrémente l'en cde de la quantité facturer
Else
   WCDETTC = (DELTAQTY*[F:SOP]NETPRIATI)*(-1)
   WCDEHT  = (DELTAQTY*[F:SOP]NETPRINOT)*(-1)
Endif

# Maj dernier no facture
[F:SOH]LASINVNUM = [F:SIV]NUM
[F:SOH]LASINVDAT = [F:SIV]INVDAT

Return
# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)

#########################################################################
# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
#########################################################################
$MAJENTCDE_MOD_SVIC
#-------------------------------------------------#
# Maj entête de commande en modification de ligne #
#-------------------------------------------------#
# La ligne de commande qui est en ligne n'est pas encore maj
# (sauf [F:SOQ]SOQSTA,INVFLG,ALLQTY,ALLQTYSTU,SHTQTY,SHTQTYSTU,TDLQTY,TDLQTYSTU)

#-------------------------------------------------#
# Recalcul de l'état solde                        #
#-------------------------------------------------#
# La ligne de commande était soldée, et elle ne l'est plus
If WSOQSTA = 3 & [F:SOQ]SOQSTA <> 3
   [F:SOH]CLELINNBR -= 1
   [F:SOH]ORDSTA     = 1
Endif
# La ligne de commande n'était pas soldée, et elle le devient
If WSOQSTA <> 3 & [F:SOQ]SOQSTA = 3
   [F:SOH]CLELINNBR += 1
   If [F:SOH]CLELINNBR >= [F:SOH]LINNBR
      [F:SOH]ORDSTA = 2
   Endif
Endif

# Bug 49166 : Une commande soldée est considérée comme non allouée
If [F:SOH]ORDSTA = 2 [F:SOH]ALLSTA=1 : [F:SOH]ALLLINNBR=0 Endif

# For schedules invoice, we work with qty is UV (not with qty in US)
# because extra facturation qty is only known in UV

#-------------------------------------------------#
# Recalcul de l'état facture                      #
#-------------------------------------------------#
# Ancien cumul (en facturation + facturé)
#QTECALC = [F:SOQ]ODLQTYSTU + [F:SOQ]INVQTYSTU
QTECALC = [F:SOQ]ODLQTY + [F:SOQ]INVQTY

# La ligne de commande était facturée
#If QTECALC >= [F:SOQ]QTYSTU
If QTECALC >= [F:SOQ]QTY
   # La ligne de commande n'est plus facturée
   #If QTECALC + DELTAQTYSTU < [F:SOQ]QTYSTU
   If QTECALC + DELTAQTY < [F:SOQ]QTY
      [F:SOH]INVLINNBR -= 1
      If [F:SOH]INVLINNBR=0
         # La cde devient non facturée
         [F:SOH]INVSTA = 1
      Else
         # La cde devient partiellement facturée
         [F:SOH]INVSTA = 2
      Endif
   Endif
   # Si plus de lignes facturées en totalité, y en a t-il qui le sont partiellement?
   # Permet de recalculer l'état de la commande (partiellement facturée)
   If [F:SOH]INVLINNBR = 0
      For [SID1]SID1 Where BPCINV=[F:SOH]BPCINV & SALFCY=[F:SOH]SALFCY & SOHNUM=[F:SOQ]SOHNUM
         If [F:SID1]NUM<>[F:SID]NUM | [F:SID1]SIDLIN<>[F:SID]SIDLIN
            [F:SOH]INVSTA=2 : Break
         Endif
      Next
   Endif
# La ligne de commande n'était pas facturée
Else
   # La ligne de commande devient facturée
   #If QTECALC + DELTAQTYSTU >= [F:SOQ]QTYSTU
   If QTECALC + DELTAQTY >= [F:SOQ]QTY
      [F:SOH]INVLINNBR += 1
      If [F:SOH]INVLINNBR>=[F:SOH]LINNBR
         # La cde devient facturée
         [F:SOH]INVSTA = 3
      Else
         # La cde devient partiellement facturée
         [F:SOH]INVSTA = 2
      Endif
   Endif
Endif

#-------------------------------------------------#
# Maj des montants à livrer HT et TTC             #
#-------------------------------------------------#
# Ecart entre qte cde et qte facture de la ligne cde
ECARTQTY = [F:SOQ]QTY - ([F:SOQ]INVQTY + [F:SOQ]ODLQTY)
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:19/12/16)
#If [F:SOH]ORDSTA = 2
#   [F:SOH]DLRNOT = 0
#   [F:SOH]DLRATI = 0
#Else
#   If ECARTQTY > 0
#      If DELTAQTY < ECARTQTY
#         QTECALC = DELTAQTY
#      Else
#         QTECALC = ECARTQTY
#      Endif
#   Else
#      If DELTAQTY < ECARTQTY
#         QTECALC = DELTAQTY-ECARTQTY
#      Else
#         QTECALC = 0
#      Endif
#   Endif
#   MNTCALC = QTECALC * [F:SOP]NETPRINOT
#   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
#   [F:SOH]DLRNOT -= MNTCALC
#   MNTCALC = QTECALC * [F:SOP]NETPRIATI
#   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
#   [F:SOH]DLRATI -= MNTCALC
#Endif
If [F:SOH]ORDSTA = 2
   [F:SOH]INRSCHNOT = 0
   [F:SOH]INRSCHATI = 0
Else
   If ECARTQTY > 0
      If DELTAQTY < ECARTQTY
         QTECALC = DELTAQTY
      Else
         QTECALC = ECARTQTY
      Endif
   Else
      If DELTAQTY < ECARTQTY
         QTECALC = DELTAQTY-ECARTQTY
      Else
         QTECALC = 0
      Endif
   Endif
   MNTCALC = QTECALC * [F:SOP]NETPRINOT
   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
   [F:SOH]INRSCHNOT -= MNTCALC
   MNTCALC = QTECALC * [F:SOP]NETPRIATI
   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
   [F:SOH]INRSCHATI -= MNTCALC
Endif
[F:SOH]INRNOT = [F:SOH]DLRNOT + [F:SOH]INRSCHNOT
[F:SOH]INRATI = [F:SOH]DLRATI + [F:SOH]INRSCHATI
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:19/12/16)

#-------------------------------------------------#
# Maj de l'en commande client                     #
#-------------------------------------------------#
Raz WCDEHT, WCDETTC

# Diminution de la qte facturée
If DELTAQTY < 0
   # Si la ligne cde n'était pas soldée, on annule ce qu'il restait à facturer
   If WSOQSTA <> 3  WDIFF = 0  Endif
   # Si diminution qte facturée < (qte fac-qte cde) de la cde, pas de maj
   If WDIFF > 0 | (WDIFF <= 0 & [F:SID]QTY > WDIFF*(-1))
      # Augmentation de l'en cde
      If (WDIFF - DELTAQTY) > 0
         WCDETTC = (WDIFF-DELTAQTY) * [F:SOP]NETPRIATI
         WCDEHT  = (WDIFF-DELTAQTY) * [F:SOP]NETPRINOT
      Endif
   Endif
# Augmentation de la qte facturée
Else
   # La ligne cde n'était pas soldée (pas de maj si la ligne était soldée)
   If WSOQSTA <> 3
      # Si Qté facturée en plus > Ce qu'il restait à facturer
      # alors on décrémente l'en cde de ce qu'il restait à facturer
      If DELTAQTY > WDIFF
         WCDETTC = (WDIFF*[F:SOP]NETPRIATI)*(-1)
         WCDEHT  = (WDIFF*[F:SOP]NETPRINOT)*(-1)
      # Si Qté facturée en plus <= Ce qu'il restait à facturer
      # alors on décrémente l'en cde de la quantité facturée en plus
      Else
         WCDETTC = (DELTAQTY*[F:SOP]NETPRIATI)*(-1)
         WCDEHT  = (DELTAQTY*[F:SOP]NETPRINOT)*(-1)
      Endif
   Endif
Endif

Return
# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)

#########################################################################
# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
#########################################################################
$MAJENTCDE_ANN_SVIC
#-------------------------------------------------#
# Maj entête de commande en annulation de ligne   #
#-------------------------------------------------#
# La ligne de commande qui est en ligne n'est pas encore maj
# (sauf [F:SOQ]SOQSTA,INVFLG,ALLQTY,ALLQTYSTU,SHTQTY,SHTQTYSTU,TDLQTY,TDLQTYSTU)

#-------------------------------------------------#
# Recalcul de l'état solde                        #
#-------------------------------------------------#
# La ligne de commande était soldée, et elle ne l'est plus
If WSOQSTA = 3 & [F:SOQ]SOQSTA <> 3
   [F:SOH]CLELINNBR -= 1
   [F:SOH]ORDSTA     = 1
Endif

# For schedules invoice, we work with qty is UV (not with qty in US)
# because extra facturation qty is only known in UV

#-------------------------------------------------#
# Recalcul de l'état facture                      #
#-------------------------------------------------#
# Ancien cumul (en facturation + facturé)
#QTECALC = [F:SOQ]ODLQTYSTU + [F:SOQ]INVQTYSTU
QTECALC = [F:SOQ]ODLQTY + [F:SOQ]INVQTY
# La ligne de commande était facturée
#If QTECALC >= [F:SOQ]QTYSTU
If QTECALC >= [F:SOQ]QTY
   # La ligne de commande n'est plus facturée
   #If QTECALC + DELTAQTYSTU < [F:SOQ]QTYSTU
   If QTECALC + DELTAQTY < [F:SOQ]QTY
      [F:SOH]INVLINNBR -= 1
      If [F:SOH]INVLINNBR=0
         # La cde devient non facturée
         [F:SOH]INVSTA = 1
      Else
         # La cde devient partiellement facturée
         [F:SOH]INVSTA = 2
      Endif
   Endif
Endif

# Si plus de lignes facturées en totalité, y en a t-il qui le sont partiellement?
# Permet de recalculer l'état de la commande (partiellement facturées)
If [F:SOH]INVLINNBR = 0
   For [SID1]SID1 Where BPCINV=[F:SOH]BPCINV & SALFCY=[F:SOH]SALFCY &
&                       SOHNUM=[F:SOQ]SOHNUM
      If [F:SID1]NUM<>[F:SID]NUM | [F:SID1]SIDLIN<>[F:SID]SIDLIN
         [F:SOH]INVSTA=2 : Break
      Endif
   Next
Endif

#-------------------------------------------------#
# Maj des montants à livrer HT et TTC             #
#-------------------------------------------------#
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:19/12/16)
#If [F:SOH]ORDSTA = 2
#   [F:SOH]DLRNOT =0
#   [F:SOH]DLRATI =0
#Else
#   QTECALC = [F:SID]QTY
#   If ([F:SOQ]INVQTY + [F:SOQ]ODLQTY) > [F:SOQ]QTY
#      QTECALC = QTECALC - ([F:SOQ]INVQTY+[F:SOQ]ODLQTY-[F:SOQ]QTY)
#   Endif
#   MNTCALC = QTECALC * [F:SOP]NETPRINOT
#   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
#   [F:SOH]DLRNOT += MNTCALC
#   MNTCALC = QTECALC * [F:SOP]NETPRIATI
#   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
#   [F:SOH]DLRATI += MNTCALC
#Endif

If [F:SOH]ORDSTA = 2
   [F:SOH]INRSCHNOT =0
   [F:SOH]INRSCHATI =0
Else
   # We should not consider the extra facturation, so we take DELTAQTY instead of [F:SID]QTY
   QTECALC = -1 * DELTAQTY
   If ([F:SOQ]INVQTY + [F:SOQ]ODLQTY) > [F:SOQ]QTY
      QTECALC = QTECALC - ([F:SOQ]INVQTY+[F:SOQ]ODLQTY-[F:SOQ]QTY)
   Endif
   MNTCALC = QTECALC * [F:SOP]NETPRINOT
   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
   [F:SOH]INRSCHNOT += MNTCALC
   MNTCALC = QTECALC * [F:SOP]NETPRIATI
   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
   [F:SOH]INRSCHATI += MNTCALC
Endif
[F:SOH]INRNOT = [F:SOH]DLRNOT + [F:SOH]INRSCHNOT
[F:SOH]INRATI = [F:SOH]DLRATI + [F:SOH]INRSCHATI
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:19/12/16)

#-------------------------------------------------#
# Maj de l'en commande client                     #
#-------------------------------------------------#
Raz WCDEHT, WCDETTC

If WSOQSTA <> 3  WDIFF = 0  Endif

If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 10 & [F:SID]VCRINVCNDLIN>0
    # Si qte facturée supprimée < (qte fac-qte cde) de la cde, pas de maj
    If WDIFF > 0 | (WDIFF <= 0 & DELTAQTY*(-1) > WDIFF*(-1))
       WCDETTC = (DELTAQTY*(-1) + WDIFF) * [F:SOP]NETPRIATI
       WCDEHT  = (DELTAQTY*(-1) + WDIFF) * [F:SOP]NETPRINOT
    Endif
Else
    # Si qte facturée supprimée < (qte fac-qte cde) de la cde, pas de maj
    If WDIFF > 0 | (WDIFF <= 0 & [F:SID]QTY > WDIFF*(-1))
       WCDETTC = ([F:SID]QTY + WDIFF) * [F:SOP]NETPRIATI
       WCDEHT  = ([F:SID]QTY + WDIFF) * [F:SOP]NETPRINOT
    Endif
Endif

#-------------------------------------------------#
# Recherche dernière facture de la commande       #
#-------------------------------------------------#
If GREP<>"A" | (GREP="A" & [F:SOH]SOHNUM<>SVGSOHNUM)
   SVGSOHNUM=[F:SOH]SOHNUM
   Call RECH_DERFACSOH() From SUBSIHB
Endif

Return

#########################################################################
# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
#########################################################################
#** -----------------------------------------------------------------#
#*   Search for the extra invoice qtys of a scheduled invoice        #
#*  -----------------------------------------------------------------#
#* Entry   VVCRTYP       : Origin document type                      #
#*         VVCRNUMORI    : Origin document N°                        #
#*         VVCRLINORI    : Origin document line                      #
#*         VVCRSEQORI    : Origin document seq                       #
#*         VVCRINVCNDLIN : Scheduled invoice line                    #
#* Exit    VEXTQTY_NP    : Not posted extra invoice qty              #
#*         VEXTQTY_P     : Posted extra invoice qty                  #
#*         Vret          : Return status                             #
#** -----------------------------------------------------------------#
#**
#**
#* Used to update the order linked to a schedule invoice line
#* called from $VALLIGCRE, $VALLIGMOD, $VALLIGANN from GESSIH
#* #*!
Subprog RECEXTQTY (VVCRTYP, VVCRNUMORI, VVCRLINORI, VVCRSEQORI, VVCRINVCNDLIN, VEXTQTY_NP, VEXTQTY_P, VRET)
Value    Integer VVCRTYP
Value    Char    VVCRNUMORI
Value    Integer VVCRLINORI
Value    Integer VVCRSEQORI
Value    Integer VVCRINVCNDLIN
Variable Decimal VEXTQTY_NP
Variable Decimal VEXTQTY_P
Variable Integer VRET

VRET=0
Raz VEXTQTY_NP, VEXTQTY_P

If clalev([F:SVICD1]) = 0 Local File SVCRINVCNDD [SVICD1] : Endif

If VVCRINVCNDLIN<>0
  # Search the extra invoice qty for a scheduled invoice line
  Read [F:SVICD1]SVICD0=VVCRTYP;VVCRNUMORI;VVCRLINORI;VVCRSEQORI;VVCRINVCNDLIN
  If fstat : Raz [F:SVICD1] : Endif
  Case [F:SVICD1]INVCNDSTA
      When 2 : #--'Invoiced' (posted)
        VEXTQTY_P  = [F:SVICD1]LIN_EXT_QTY
      When 5 : #--'On invoice' (not posted)
        VEXTQTY_NP = [F:SVICD1]LIN_EXT_QTY
      When Default :
  Endcase
Else
#  # Search the extra qty for all the scheduled invoices line of an order line
  Filter [SVICD1] Where VCRTYP     = VVCRTYP     & VCRNUMORI = VVCRNUMORI &
&                       VCRLINORI  = VVCRLINORI  & VCRSEQORI = VVCRSEQORI
  For [SVICD1]
      Case [F:SVICD1]INVCNDSTA
          When 2 : #--'Invoiced' (posted)
            VEXTQTY_P  += [F:SVICD1]LIN_EXT_QTY
          When 5 : #--'On invoice' (not posted)
            VEXTQTY_NP += [F:SVICD1]LIN_EXT_QTY
          When Default :
      Endcase
  Next
  Filter [SVICD1]
Endif

End
# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)

