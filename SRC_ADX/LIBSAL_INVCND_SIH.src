#------------------------------------------------------------------------------------------------------
$B16_NBLIG
Local Integer NOL,WSVIC,SIDHYBHANDLER_LINE #--set by the $GSIDHYBHANDLE_GET_INDEX

NOL = nolign-1

  If [M:SIH1]SIHORI=10 and [M:SIH4]SIDORI(NOL)=10 and [M:SIH4]VCRINVCNDLIN(NOL)>0
    If !GWEBSERV #and GREP=""
      If GSIDHYBHANDLE=null
        GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
      Endif
      Local Integer WOK
      #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
      #--Set the SIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
      Gosub GSIDHYBHANDLE_GET_INDEX_WITH_INSTANCE_ADD_USING_M_SIH #--Because of the different kind of schedule invoice origins
      If SIDHYBHANDLER_LINE<=0
        Return
      Endif
      WSVIC = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVIC_INDEX
      If WSVIC<1 : Return : Endif
      Local Decimal BASPAG
      ## Action SAISVIC
      GCONSULT = 1
      Local Char    PARMSK(250)(1..20) , SAVACT(20)
      SAVACT = GACTION : GACTION = "SAISVIC"
      PARMSK(1) = "SIH4"
      PARMSK(2) = num$(nolign)
      PARMSK(3) = "10"
      PARMSK(4) = [M:SIH4]SOHNUM(NOL)
      PARMSK(5) = num$([M:SIH4]SOPLIN(NOL))
      PARMSK(6) = num$([M:SIH4]SOPLIN(NOL))
      PARMSK(7) = "C_SVCRINVCND"
      PARMSK(8) = "GSIDHYBHANDLE.SIDTOSVIC("+num$(SIDHYBHANDLER_LINE)+").SVCRINVCND("+num$(WSVIC)+")"
      Call TRAITE_NUM(BASPAG,PARMSK,"ISVIC","TRTSAISVIC","",1,"") From GTRAITE
      GACTION = SAVACT
    Endif
    GCONSULT = 0
    If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
  Endif

Return
#------------------------------------------------------------------------------------------------------
$FREEGROUP_GSIHVCRINVCND
Local Integer IJCPO

  If dim(GSIDHYBHANDLE)>0 and GSIDHYBHANDLE<>null
    FreeGroup GSIDHYBHANDLE
    GSIDHYBHANDLE=null

    Raz GSIDHYBHANDLE
  Endif

Return
#------------------------------------------------------------------------------------------------------
#** Called from SUBSIH.AM_QTY the after modification action for QTY field from a SIH4 line
#* @param NOL - the current [M:SIH4] modified line's index
#* @param VALEUR - the new qty value
#*!
$AM_QTY
Local Integer WRET,WOK
Local Tinyint WIS_EXTRABILL,WIS_LASTLINE_TOINVOICE
Local Integer SIDHYBHANDLER_LINE #--set by the $GSIDHYBHANDLE_GET_INDEX
Local Decimal WNEWINVPERCENT,WPRC_TOINVOICE, WQTY_TOINVOICE, WAMT_TOINVOICE

  #--Changing the quantity or doing a price search, the invoice schedule line has to be updated
  #--First, the invoice line has to come from an invoice schedule
  If [M:SIH0]INVTYP=1 and [M:SIH4]SIDORI(NOL)=10 and [M:SIH4]VCRINVCNDLIN(NOL)>0

    #--First, the global working handler has to be instantiate if not done yet
    If GSIDHYBHANDLE=null
      GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
    Endif
    #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
    #--Set the SIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
    Gosub GSIDHYBHANDLE_GET_INDEX_WITH_INSTANCE_ADD_USING_M_SIH  #--Because of the different kind of schedule invoice origins
    If SIDHYBHANDLER_LINE<=0
      Return
    Endif

    WIS_LASTLINE_TOINVOICE=[V]CST_AFALSE
    Raz WPRC_TOINVOICE, WQTY_TOINVOICE, WAMT_TOINVOICE
    #--Now, we need to have the max remaining percentage to invoice of the schedule invoice
    WSVIC_INDEX = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVIC_INDEX
    If WSVIC_INDEX>0 and  GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX)<>null and
&     find(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).GET_REMAINING_TO_INVOICE([M:SIH4]VCRINVCNDLIN(NOL),
&                 WPRC_TOINVOICE, WQTY_TOINVOICE, WAMT_TOINVOICE, WIS_LASTLINE_TOINVOICE)
      If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
        # Error management
        WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
        If WRET>=[V]CST_AERROR
          mkstat = 2
        Else
          GERR=2
        Endif
      Endif
      If mkstat>0 : Return : Endif
    Endif

    WOK = 2
    WIS_EXTRABILL=[V]CST_ANO
    If VALEUR>[M:SIH4]QTY(NOL)
      If WIS_LASTLINE_TOINVOICE<>[V]CST_ATRUE
        #"La valeur demandée est supérieure à celle de la ligne d'échéancier. Voulez-vous consommer les échéances suivantes?"+"\"+
        #"(uniquement celles dont la date de prochaine facture est ultérieure à celle de la ligne courante)?"
        #Call OUINON(mess(530,192,1)+". "+mess(531,192,1)+"?"+"\"+"("+mess(532,192,1)+")?",WOK) From GESECRAN
        Call OUINON(mess(530,192,1)+"."-mess(531,192,1),WOK) From GESECRAN
        If WOK<>2 : WIS_EXTRABILL=[V]CST_AYES : Endif
      Else
        #--There is no more lines with 'to be invoiced' status on the schedule invoice
        #--Here, we'll have a new VALEUR greater than the one from the invoice line, but less than the maximum percentage to invoice
        #--Impossible to be in this situation...
        Call AVERTIR(mess(530,192,1)+"."-mess(535,192,1),WOK) From GESECRAN
        If WOK<>2 : GERR=1 : mkstat=2 : Return : Endif
        WIS_EXTRABILL=[V]CST_AYES
      Endif
    Endif

    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SET_NEW_QTY([M:SIH4]VCRINVCNDLIN(NOL),VALEUR,WIS_EXTRABILL)
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        mkstat = 2
      Else
        GERR=2
      Endif
    Endif
    If mkstat>0 : Return : Endif

    #--We immediatly do the changes (in order to have the right percentage on the invoice line)
    #--Starts here
    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).DO_CHANGES([M:SIH4]VCRINVCNDLIN(NOL))
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GERR=1
      Else
        GERR=2
      Endif
    Endif
    If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif

    #--Updating the m:sih4 mask with new values
    WSVIC_INDEX = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVIC_INDEX
    If WSVIC_INDEX>0 and  GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX)<>null and
&     find(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      #--Now, let's set the invoice line's new quantity
      For WLINE=1 To maxtab(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN)
        If GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE)<>null and
&     find(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
          If GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).VCRINVCNDLIN = [M:SIH4]VCRINVCNDLIN(NOL)
            WNEWQTY        = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).INVCNDQTY+
&                            GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).LIN_EXT_QTY
            WNEWINVPERCENT = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).INVPERCENT
            #--quantity changed ?
            #--Not in case of extra-billing
            If VALEUR<>WNEWQTY #or GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).IS_EXTRABILL<>[V]CST_AYES
              VALEUR = WNEWQTY
            Endif
#            #--percent changed ?
#            Elsif [M:SIH4]INVPRC(NOL)<>WNEWINVPERCENT
            #--Not in case of extra-billing
            If [M:SIH4]INVPRC(NOL)<>WNEWINVPERCENT #or GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).IS_EXTRABILL<>[V]CST_AYES
              [M:SIH4]INVPRC(NOL) = WNEWINVPERCENT
              Affzo [M:SIH4]INVPRC(NOL)
            Endif
            Break
          Endif
        Endif
      Next
    Else
      mkstat=2
    Endif
    #--Ends here
  Endif

Return
#------------------------------------------------------------------------------------------------------
#** Called from SUBSIH.AM_INVPRC the after modification action for INVPRC field from a SIH4 line
#* @param NOL - the current [M:SIH4] modified line's index
#* @param VALEUR - the new percent value
#*!
$AM_INVPRC
Local Integer WRET,WSVIC_INDEX,WLINE,WOK
Local Tinyint WIS_EXTRABILL, WIS_LASTLINE_TOINVOICE
Local Integer SIDHYBHANDLER_LINE #--set by the $GSIDHYBHANDLE_GET_INDEX
Local Decimal WNEWQTY, WPRC_TOINVOICE, WQTY_TOINVOICE, WAMT_TOINVOICE

  #--Changing the quantity or doing a price search, the invoice schedule line has to be updated
  #--First, the invoice line has to come from an invoice schedule
  If [M:SIH0]INVTYP=1 and [M:SIH4]SIDORI(NOL)=10 and [M:SIH4]VCRINVCNDLIN(NOL)>0
    #--First, the global working handler has to be instantiate if not done yet
    If GSIDHYBHANDLE=null
      GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
    Endif
    #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
    #--Set the SIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
    Gosub GSIDHYBHANDLE_GET_INDEX_WITH_INSTANCE_ADD_USING_M_SIH  #--Because of the different kind of schedule invoice origins
    If SIDHYBHANDLER_LINE<=0
      Return
    Endif

    WIS_LASTLINE_TOINVOICE=[V]CST_AFALSE
    Raz WPRC_TOINVOICE, WQTY_TOINVOICE, WAMT_TOINVOICE
    #--Now, we need to have the max remaining percentage to invoice of the schedule invoice
    WSVIC_INDEX = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVIC_INDEX
    If WSVIC_INDEX>0 and  GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX)<>null and
&     find(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).GET_REMAINING_TO_INVOICE([M:SIH4]VCRINVCNDLIN(NOL),
&                 WPRC_TOINVOICE, WQTY_TOINVOICE, WAMT_TOINVOICE, WIS_LASTLINE_TOINVOICE)
#     If GUSER<>"CPOx"
      If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
        # Error management
        WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
        If WRET>=[V]CST_AERROR
          mkstat = 2
        Else
          GERR=2
        Endif
      Endif
      If mkstat>0 : Return : Endif
      #--Now, testing if the modified percentage is greater than the remaining to invoice
      #--If so, we throw an error message as the extra-billing throught percentage modification is not allowed
#      If (VALEUR>WPRC_TOINVOICE and WIS_LASTLINE_TOINVOICE<>[V]CST_ATRUE)
#&      | (VALEUR>(WPRC_TOINVOICE+[M:SIH4]INVPRC(NOL)) and WIS_LASTLINE_TOINVOICE=[V]CST_ATRUE)
      #--Adding the previous value to the total remaining percentage to invoice
      If VALEUR>(WPRC_TOINVOICE+[M:SIH4]INVPRC(NOL))
        GMESSAGE = mess(533,192,1)+"."+"\"+func AFNC.MES1(mess(534,192,1),num$(WPRC_TOINVOICE+[M:SIH4]INVPRC(NOL)))
        GERR=1 : mkstat=2
        Return
      Endif
    Endif

    WOK = 2
    WIS_EXTRABILL=[V]CST_ANO
    If VALEUR>[M:SIH4]INVPRC(NOL)
      If WIS_LASTLINE_TOINVOICE<>[V]CST_ATRUE
        #"La valeur demandée est supérieure à celle de la ligne d'échéancier. Voulez-vous consommer les échéances suivantes?"+"\"+
        #"(uniquement celles dont la date de prochaine facture est ultérieure à celle de la ligne courante)?"
        #Call OUINON(mess(530,192,1)+". "+mess(531,192,1)+"?"+"\"+"("+mess(532,192,1)+")?",WOK) From GESECRAN
        Call AVERTIR(mess(530,192,1)+"."-mess(531,192,1),WOK) From GESECRAN
        If WOK<>2 : mkstat=2 : Endif
      Else
        #--There is no more lines with 'to be invoiced' status on the schedule invoice
        #--Here, we'll have a new VALEUR greater than the one from the invoice line, but less than the maximum percentage to invoice
        #--Impossible to be in this situation...
      Endif
    Endif

    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SET_NEW_PERCENT([M:SIH4]VCRINVCNDLIN(NOL),VALEUR,WIS_EXTRABILL)
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        mkstat = 2
      Else
        GERR=2
      Endif
    Endif
    If mkstat>0 : Return : Endif

    #--We immediatly do the changes (in order to have the right quantity on the invoice line)
    #--Starts here
    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).DO_CHANGES([M:SIH4]VCRINVCNDLIN(NOL))
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GERR=1
      Else
        GERR=2
      Endif
    Endif
    If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif

    #--Updating the m:sih4 mask with new values
    WSVIC_INDEX = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVIC_INDEX
    If WSVIC_INDEX>0 and  GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX)<>null and
&     find(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      #--Now, let's set the invoice line's new quantity
      For WLINE=1 To maxtab(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN)
        If GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE)<>null and
&     find(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
          If GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).VCRINVCNDLIN = [M:SIH4]VCRINVCNDLIN(NOL)
            WNEWQTY        = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).INVCNDQTY+
&                            GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).LIN_EXT_QTY
            WNEWINVPERCENT = GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).INVPERCENT
            #--quantity changed ?
              #--Not in case of extra-billing
            If [M:SIH4]QTY(NOL)<>WNEWQTY #or GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).IS_EXTRABILL<>[V]CST_AYES
#              Call AM_QTY(WNEWQTY) From SUBSIH
#              If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif
              [M:SIH4]QTY(NOL) = WNEWQTY
              Affzo [M:SIH4]QTY(NOL)
            Endif
            #--percent changed ?
            #--Not in case of extra-billing
            If [M:SIH4]INVPRC(NOL)<>WNEWINVPERCENT #or GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WLINE).IS_EXTRABILL<>[V]CST_AYES
              VALEUR = WNEWINVPERCENT
            Endif
            Break
          Endif
        Endif
      Next
    Else
      mkstat=2
    Endif
    #--Ends here
  Endif
  If mkstat>0 or GERR=1 : mkstat=2 : Return : Endif

Return
