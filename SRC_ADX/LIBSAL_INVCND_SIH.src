$BB11_NBLIG

  If [M:SIH1]SIHORI=10 #and [M:SIH4]SIDORI(NOL)=10 and [M:SIH4]VCRINVCNDLIN(NOL)>0
    #If [M:SIH4]VCRINVCNDTYP(NOL)=10
