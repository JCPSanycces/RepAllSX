#------------------------------------------------------------------------------------------------------
#**
#* Label MAJLIGSVIC_C is used to perform an create on the current invoice line's index of the instance
#* called from $VALLIGCRE from GESSIH
#* It is called in case of a invoice condition on an [F:SID] new invoice line
#* It returns GOK = 0 and GERR = 1 in case an error occurs
#* #*!
$MAJLIGSVIC_C

  Case [F:SID]VCRINVCNDTYP
    When 10 : Gosub MAJLIGSVIC_C_SOQ
    When Default
  Endcase
  If GOK=0 or GERR=1 : GOK=0 : Return : Endif

Return
#------------------------------------------------------------------------------------------------------
#**
#* Label MAJLIGSVIC_C_SOQ is used to perform an create on the current invoice line's index of the SOHVCRINVCND_TOUPD instance
#* It is called in case of a invoice condition on an [F:SID] new invoice line
#* It returns GOK = 0 and GERR = 1 in case an error occurs
#*!
$MAJLIGSVIC_C_SOQ
Local Integer WRET,WSVIC_INDEX
Local Integer SIDHYBHANDLER_LINE #--set by the $GSIDHYBHANDLE_GET_INDEX

  #--Changing the quantity or doing a price search, the invoice schedule line has to be updated
  #--First, the invoice line has to come from an invoice schedule
  If [F:SIV]INVTYP=1 and [F:SID]SIDORI=10 and [F:SID]VCRINVCNDLIN>0
    #--First, the global working handler has to be instantiate if not done yet
    If GSIDHYBHANDLE=null
      GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
    Endif
    #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
    #--Set the SIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
    Gosub GSIDHYBHANDLE_GET_INDEX_WITH_INSTANCE_ADD_USING_F_SIV_SID #--Because of the different kind of schedule invoice origins
    If SIDHYBHANDLER_LINE<=0
      Return
    Endif

    #--Setting the INVCNDSTA and the SIHNUM/SIDLIN
    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SET_LIG_INVCNDSTA([F:SID]VCRINVCNDLIN,5)
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GOK = 0 : GERR=1
      Else
        GERR=2
      Endif
    Endif
    If GOK=0 or GERR=1 : GOK=0 : Return : Endif

    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SET_LIG_SIHNUM([F:SID]VCRINVCNDLIN,[F:SIV]NUM,[F:SID]SIDLIN)
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GOK = 0 : GERR=1
      Else
        GERR=2
      Endif
    Endif
    If GOK=0 or GERR=1 : GOK=0 : Return : Endif
  Endif
  If GOK=0 or GERR=1 : GOK=0 : Return : Endif

Return
#------------------------------------------------------------------------------------------------------
