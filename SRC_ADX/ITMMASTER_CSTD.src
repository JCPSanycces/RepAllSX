#$PROPERTIES
# Case CURPRO
#  When "ITMREF"         : Gosub ITMREF
#  When "CPY"            : Gosub CPY
#
# Endcase
#Return

$ITMREF
Case [L]ARULE
   When "INIT"
   When "CONTROL"
   When "PROPAGATE" : #-- envoyer par $SET_xxx lors de modif, comme apres_modif
   When "GET"
Endcase
Return

$CPY
Case [L]ARULE
   When "INIT"
   When "CONTROL"
   When "PROPAGATE" : #-- envoyer par $SET_xxx lors de modif, comme apres_modif
   When "GET"
Endcase
Return

########################## Methods implements #################################################
#====== C R U D encapsulation =================================================================
$READOBJECT
    #-- Encapsulation + Business rules
    #-- For Level: set: THIS.ACTX.LEVWML= MYLEVEL
    WRET = func TRTBOITM.READ_OBJECT(this)
Return
$CREATEOBJECT
    #-- Encapsulation + Business rules
    WRET = func TRTBOITM.CREATE_OBJECT(this)
Return
$UPDATEOBJECT
   #-- Encapsulation + Business rules
   WRET = func TRTBOITM.UPDATE_OBJECT(this)
Return
$DELETEOBJECT
   #-- Encapsulation + Business rules
   WRET = func TRTBOITM.DELETE_OBJECT(this)
Return
# =====END CRUD ===============================================================================

