#<AdxTL>@(#)0.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opûˋrationnels
#--------------------------------------------------------------------------
#   Action   : BUOSIG
#   Fenûˆtre  : BUOSIG
#   Ecran concernûˋ : BUOSIG
#   Description : Permet l'acces û  la liste des approbations ou des rûˋvisions
#                 en-cours ou û  l'historique des signatures, sur l'enveloppe
#
#--------------------------------------------------------------------------

$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub DEBUT
Endcase
Return

$OUVRE
If !clalev([BOA]) : Local File BUDAPP     [BOA] : Endif
If !clalev([BAD]) : Local File BUDAPPDET  [BAD] : Endif
If !clalev([BRV]) : Local File BUDREV     [BRV] : Endif
If !clalev([BVD]) : Local File BUDREVDET  [BVD] : Endif
If !clalev([AWS]) : Local File AWRKHISSUI [AWS] : Endif
If !clalev([ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([ENF]) : Local File ENVFIY     [ENF] : Endif
If !clalev([BUD]) : Local File BUD        [BUD] : Endif

#Variables utiles
Local Integer CND : # 1:En-cours / 2:Historique
Local Integer TYPEVT : # 1:Approbation / 2:Rûˋvision
Local Integer NIV : # Enveloppe/Budget ex./Ligne bud.
Local Char    ENVELOPPE(GLONENV)
Local Integer EXERCICE
Local Char    ACCNUM
Local Mask BUOSIG [BSG]
Local Integer I, NOK : I=0 : NOK=0
Return

$DEBUT
#-----------------------------
# Rûˋcupûˋration des paramû´tres
#-----------------------------
# Condition
CND = val(PARAM(1))
# Approbation/Rûˋvision
TYPEVT = val(PARAM(2))
# Enveloppe/Budget/Ligne
#Ce paramû´tre n'ûˋtant pas utilisûˋ
NIV = val(PARAM(3))
# Enveloppe
If PARAM(4)<>"" : ENVELOPPE = PARAM(4) : Endif
# Budget exercice
If PARAM(5)<>"0" : EXE = val(PARAM(5)) : Endif
# Ligne budgûˋtaire
If PARAM(6)<>"0" : ACCNUM = val(PARAM(6)) : Endif
Gosub SITUATION
Return

$SITUATION
Local Char CRITERE(50),CRITCND(10),CRITAWS(50)
Local Integer STATUT, TYPEBLM
Local Char NUMERO(12) :# Numûˋro app ou rev
Local Char MOTIF(100)
Local Integer K
CRITAWS="1=1"
Case CND
 When 1 : # En-cours
  CRITCND  = 'STA=2'
 When 2 : # historique
  CRITCND  = 'STA<>2'
  CRITAWS -= '& FLGSIG<>3 & FLGSIG<>2'
Endcase
Case TYPEVT
 When 1 :#app
  Link [AWS] With [BOA]BOA0~=[AWS]CLEDEC As [LNK] Where evalue(CRITCND) & [BOA]ENV=[L]ENVELOPPE & evalue(CRITAWS)
  For [LNK]
   If [M]NBLIG>=dim([M]NUM)
    Call ERREUR(mess(26,100,1)) From GESECRAN
    Break
   Endif
   NUMERO  = [F:BOA]NUM
   STATUT  = [F:BOA]STA
   MOTIF   = [F:BOA]RENTXT
   TYPEBLM = [F:BOA]TYP
   Gosub SITUATION2
   [M]NBLIG += 1
  Next
 When 2 :#rev
  Link [AWS] With [BRV]BRV0~=[AWS]CLEDEC As [LNK] Where evalue(CRITCND) & [BRV]ENV=[L]ENVELOPPE & evalue(CRITAWS)
  For [LNK]
   If [M]NBLIG>=dim([M]NUM)
    Call ERREUR(mess(26,100,1)) From GESECRAN
    Break
   Endif
   NUMERO  = [F:BRV]NUM
   STATUT  = [F:BRV]STA
   MOTIF   = [F:BRV]RENTXT
   TYPEBLM = [F:BRV]TYP
   Gosub SITUATION2
   [M]NBLIG += 1
  Next
Endcase
Affzo [M]
Gosub COLORIZE
Return

$SITUATION2
[M]TYPEVT([M]NBLIG)   = TYPEVT
[M]NUM([M]NBLIG)      = [L]NUMERO
[M]CHRONO([M]NBLIG)   = [F:AWS]CHRONO
[M]DATENV([M]NBLIG)   = [F:AWS]DATENV
[M]EMETTEUR([M]NBLIG) = [F:AWS]EMETTEUR
[M]DEST([M]NBLIG)     = [F:AWS]DEST
[M]TEXSUI([M]NBLIG)   = [F:AWS]TEXSUI
[M]USRSIG([M]NBLIG)   = [F:AWS]USRSIG
[M]FLGSIG([M]NBLIG)   = [F:AWS]FLGSIG
[M]ACTSIG([M]NBLIG)   = [F:AWS]ACTSIG
Case [F:AWS]ACTSIG
 When "VAL" : [M]REPONSE([M]NBLIG) = mess(164,154,1)
 When "REJ" :
  [M]REPONSE([M]NBLIG) = mess(165,154,1)
  [M]RENTXT([M]NBLIG)  = [L]MOTIF
Endcase
[M]TYP([M]NBLIG)      = [L]TYPEBLM
[M]STA([M]NBLIG)      = [L]STATUT
[M]LEVSIG([M]NBLIG)   = [F:AWS]LEVSIG
[M]NBRUSR([M]NBLIG)   = [F:AWS]NBRUSR
For K=1 To 9
 Assign "[M]USRSIG"+num$(K)+"("+num$([M]NBLIG)+")" With evalue("[F:AWS]USRSIG"+num$(K))
Next
Return

$COLORIZE
For I=0 To [M]NBLIG-1
 Case ACTSIG(I)
  When "REF" :  Chgstl [M]NBLIG(I) With "GDD1"
  When "VAL" :  Chgstl [M]NBLIG(I) With "GDD2"
 Endcase
Next
Affzo [M]
Return

#####################################################################################
## Etiquette ajoutûˋe par le superviseur (ûˋcran BUOSIG) 16/03/2009 17:13:02 (JHA)
######################################################################################
Subprog IB_NBLIG
 Case TYPEVT
  When 1
   Raz GBOUT2
   Call LECTURE("BOA",[M]NUM(nolign-1),"") From CONTOBJ
   If [F:BOA]TYP<>4
    Raz GBOUT1
   Endif
  When 2
   Raz GBOUT1
   Call LECTURE("BRV",[M]NUM(nolign-1),"") From CONTOBJ
   If [F:BRV]TYP<>4
    Raz GBOUT2
   Endif
 Endcase
End


######################################################################################
