#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion objet AYL
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AYL",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
## Xtend:  Gestion Elément lien dynamique 
#
#    Table AYTLINES (AYN)
#        LINCODTYP = 4 Lien dynamique  (géré en auto dans AYL_AYB2 à partir du code objet X3)
#        LINTYP
#                  = 30    liste sélection
#                  = 31    liste tri
#                  = 41    valeur paramètres action
#                  = 42    valeur paramètres lien accès sous-programme (e47139)
#
#  Version 0001
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "AVANT_OUVRE"    : Gosub AVANT_OUVRE
 When "AFFMASK"        : Gosub AFFMASK
 When "ANNULE"         : Gosub ANNULE
 When "CREATION"       : Gosub CREATION
 When "EXEACT"         : Gosub EXEACT
 When "FERME"          : Gosub FERME
 When "FILTRE"         : Gosub FILTRE
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "LIENS"          : Gosub LIENS
 When "MODIF"          : Gosub MODIF
 When "OUVRE"          : Gosub OUVRE
 When "RAZCRE"         : Gosub RAZCRE
 When "SETBOUT"        : Gosub SETBOUT
 When default
Endcase
Return

#---------------------------------------------------------------#
$AVANT_OUVRE
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Gosub INICTLFCY From SUBAYS
Return

#---------------------------------------------------------------#
$OUVRE
Local Char WSTR1 (250)
Local Integer WI
Gosub DSYFCY From SUBAYS     # Infos site
Return

#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY From SUBAYS # Clear affichage site
Return

$AFFMASK
#---------------------------------------------------------------#
# Nom visible sur lien dynamique
Chgfmt [M:AYB2]SELDYNALT With"-LA1:4X"
Chgfmt [M:AYB2]SRTDYNALT With"-LA1:4X"
Return

#---------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, copie
Endif
Return

#---------------------------------------------------------------#
$EXEACT
Case BOUT
When "S"
    Call USG_SUPP([M]FCYCOD, GABREV, [M:AYL0]DLKCOD, WI) From CNSAYUSTD
    If WI : OK=0 : Endif
Endcase
Return

#---------------------------------------------------------------#
$INICRE
$INIMOD
# Clé browser X3
[F]BRWX3=[F]FCYCOD+"_"+[F]DLKCOD 
Return

#---------------------------------------------------------------#
$CREATION
If GREP="D" : [M:AYB2]LINCOD = [M]DLKCOD : Endif

$MODIF
# 
# Sup. avant recréation par Sélection et Action
Gosub ANNULE2 : If GOK<>1 : Return : Endif
# Sélection
Call AYB2_AYL() From SUBAYB
# Param. Accès ss-prgrm
Call AYL1_AYL()
# Action
Call AYL3_AYL()

#  textes AXX
Call MAJTEXTRA([M]INTIT,"AYTELTDLK","INTIT",[M]FCYCOD,[M]DLKCOD) From  ATEXTRA

Return

#---------------------------------------------------------------#
$LIENS
Gosub DSYFCY From SUBAYS     # Infos site
Call SETPAGCOD([M:AYL1]PAGSAM)
Call SETBLCOPT([M:AYL1]ENTCOD)

# Gestion Sélection
[M:AYB2]SELTYPFILE=[F:AYL]SELTYP    # Gestion chgt par utilisateur
[M:AYB2]SRTTYPFILE=[F:AYL]SRTTYP    #
# Appel Gestion AYB2
Call SETAYB2([F:AYL]ENTCOD)
# Gestion tableau Paramètres Accès spg
Call SETTABTYP2(0, [M:AYB2]INTCODSEL, [M:AYB2]INTTYPSEL)

# Gestion Action
Call AM_ACTCOD([M:AYL1]ACTCOD)           
Return

#---------------------------------------------------------------#
$FILTRE
FILTSUP+=func SUBAYS.FILTFCY
Return

#---------------------------------------------------------------#
$RAZCRE
Gosub DSYFCY From SUBAYS     # Infos site
#[M]CODACT=WFCY_CODACT        # Code activité site
#
[M:AYB2]SELTYP = 1 # Défaut sélection: Aucune
# Gestion Sélection
WSTR1 = ""
Call AM_ENTCOD(WSTR1 )              
# Gestion Action
Call AM_ACTCOD(WSTR1 )           
Return

#---------------------------------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="AYTELTBLC" & ZONE = "INTIT"   & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
$ANNULE2
Delete [AYN]AYN0=[M]FCYCOD;4;toupper([M]DLKCOD)
If fstat=1 : GOK=-1 : GLOCK="$AYTLINES ("-[M]FCYCOD-"4"-[M]DLKCOD+")" : Return : Endif
Return


######################################################################################
## Utilitaires
######################################################################################

###    Mise à jour AYB2
Subprog SETAYB2(ENTCOD)
Value Char VALEUR
# Appel Gestion AYB2
[M:AYB2]OBJX3    ="AYL"      
[M:AYB2]LINCOD   =[M:AYL0]DLKCOD      
[M:AYB2]ENTCODSEL=ENTCOD
Call AYL_AYB2([M:AYB2]SELTYP) From SUBAYB
End

Subprog SETPAGCOD(PAGSAM)
Value Integer PAGSAM
If PAGSAM=2
    [M:AYL1]PAGCOD="" : Grizo [M:AYL1]PAGCOD
Else
    Actzo [M:AYL1]PAGCOD
Endif 
End

Subprog SETBLCOPT(ENTCOD)
If ENTCOD=""
    Effzo [M:AYL1]SELBLCOPT : Grizo [M:AYL1]SELBLCOPT
Else
    Actzo [M:AYL1]SELBLCOPT
Endif
End

### Chgt AytLines par le mask AYL1 (Para accès sous-prgrm
######################################################################################
Subprog AYL1_AYL()    
# Action (valeur des param)
For WI=0 To [M:AYL1]NUM42-1
 If find([M:AYL1]VALTYP42(WI),1,2,3)
     Raz [F:AYN]
     [F:AYN]FCYCOD    = [M]FCYCOD
     [F:AYN]LINCODTYP = 4
     [F:AYN]LINCODSTD = [M]DLKCOD
     [F:AYN]LINCOD    = toupper([M]DLKCOD)
     [F:AYN]LINTYP    = 42
     [F:AYN]LINNUM    = WI
    
     [F:AYN]PARCOD      = [M:AYL1]PARCOD42(WI)
     [F:AYN]VALTYP      = [M:AYL1]VALTYP42(WI)
     Case [F:AYN]VALTYP
     When 1,3    # cste; chp web
        [F:AYN]VALEUR = [M:AYL1]VALEUR42(WI)
     When 2    # chp xtend
        [F:AYN]VALBLCCOD   = [M:AYL1]VBLCCOD42(WI)
        [F:AYN]VALFIELNKE  = [M:AYL1]VFIELNKE42(WI)
        [F:AYN]VALFIECOD   = [M:AYL1]VFIECOD42(WI)
     Endcase
    
     Write [AYN]
     If fstat
      GOK=0 : Call FSTA("AYN") From GLOCK : Break
     Endif
  Endif
Next
If GOK<>1 : Goto AYL1_AYL_E : Endif

$AYL1_AYL_E
End



# Gestion Tableau Paramètres interface de type sous-programme 
######################################################################################
Subprog SETTABTYP2(AFFZO_FLG,INTCOD, INTTYP)
Value Integer AFFZO_FLG
Value Char INTCOD
Value Integer INTTYP
If INTTYP=2    # Accès sous-programme
    Actzo [M:AYL1]50
    # AYN: Principal- Table paramètres des actions (type 6 - interface)    - LINTYP = 40
    # AYN: Lié      - Table des valeurs portées par le DLK (type 4 - blocs)- LINTYP = 42
    
    WI=0
    # Liste des paramètres
    For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 6
&                     and LINCOD = toupper([L]INTCOD) and  LINTYP = 40
&                     and VALTYP<>1                # Pas une cste déclaré sur l'interface
          [M:AYL1]PARCOD42(WI)    = [F:AYN]PARCOD
          [M:AYL1]VALTYP42(WI)    = 7     # Défaut
          [M:AYL1]VALEUR42(WI)    = ""
          WI+=1
    Next
    [M:AYL1]NUM42=WI
    
    #  Valeurs: LINCODTYP = 4 et LINTYP = 42
    For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 4
&                     and LINCOD = [M]DLKCOD and  LINTYP = 42
          WI=find([F:AYN]PARCOD,[M:AYL1]PARCOD42(0..[M:AYL1]NUM42-1))
          If WI
              WI=WI-1
              [M:AYL1]VALTYP42(WI)    = [F:AYN]VALTYP
              [M:AYL1]VALEUR42(WI)    = [F:AYN]VALEUR
              [M:AYL1]VBLCCOD42(WI)   = [F:AYN]VALBLCCOD : Call SETZENTCODCOD42(AFFZO_FLG,[F:AYN]VALBLCCOD, WI)
              [M:AYL1]VFIELNKE42(WI)  = [F:AYN]VALFIELNKE
              [M:AYL1]VFIECOD42(WI)   = [F:AYN]VALFIECOD
              Call FIEKEY_COD([F:AYN]VALFIELNKE, [F:AYN]VALFIECOD, [M:AYL1]VFIEKEY42(WI)) From SUBAYF
          Endif
          #
    Next
    # Grisage
    For WI=0 To [M:AYL1]NUM42-1
      Call SETLIN42(AFFZO_FLG, [M:AYL1]VALTYP42(WI) , WI)
    Next
    
Else
  Effzo [M:AYL1]50 : Grizo [M:AYL1]50
Endif
Affzo [M:AYL1]50
End

### Gestion des chps d'une ligne de critère en fonction du type de valeur
Subprog SETLIN42(AFFZO_FLG,VALTYP, NOL)  
Value Integer AFFZO_FLG  
Value Integer VALTYP
Value Integer NOL
#
Case VALTYP
When 1     # cste
    Effzo [M:AYL1]VBLCCOD42(NOL),VFIEKEY42(NOL) : Grizo [M:AYL1]VBLCCOD42(NOL),VFIEKEY42(NOL)
    Actzo [M:AYL1]VALEUR42(NOL)
When 2    # chp xtend
    #Infbox "num "-num$(NOL)-"nb"-num$([M:AYL1]NUM42)
    Actzo [M:AYL1]VBLCCOD42(NOL),VFIEKEY42(NOL)
    Effzo [M:AYL1]VALEUR42(NOL) : Grizo [M:AYL1]VALEUR42(NOL)
When 3    # chp web
    Effzo [M:AYL1]VBLCCOD42(NOL),VFIEKEY42(NOL)
    Grizo [M:AYL1]VBLCCOD42(NOL),VFIEKEY42(NOL)
    Actzo [M:AYL1]VALEUR42(NOL)
    # Pour info
    #[M:AYL1]VALEUR42(NOL)=[M]DLKCOD+":act="+num$(NOL+1) : Diszo [M:AYL1]VALEUR42(NOL)  
When 4    # javascript
    Effzo [M:AYL1]VBLCCOD42(NOL),VFIEKEY42(NOL),VALEUR42(NOL)
    Grizo [M:AYL1]VBLCCOD42(NOL),VFIEKEY42(NOL),VALEUR42(NOL)
When 7    # bloc
    Effzo [M:AYL1]VBLCCOD42(NOL),VFIEKEY42(NOL),VALEUR42(NOL)
    Grizo [M:AYL1]VBLCCOD42(NOL),VFIEKEY42(NOL),VALEUR42(NOL)
Endcase 
End

### Gestion du code entité en fonction du bloc sur la ligne
Subprog SETZENTCODCOD42(AFFZO_FLG,BLCCOD, NOL)
Value Integer AFFZO_FLG
Value Char BLCCOD
Value Integer NOL
Local Char WENTCOD(GLONAYE)
If BLCCOD<>""    
    If !clalev([F:AYB1]) : Local File AYTELTBLC [AYB1] : Endif
    Read [AYB1]AYB0 = [M]FCYCOD;[L]BLCCOD
    If !fstat                
        WENTCOD=[F:AYB1]ENTCOD
    Endif
Endif
[M:AYL1]ZENTCOD42(NOL)=WENTCOD
If AFFZO_FLG : Affzo [M:AYL1]ZENTCOD42(NOL) : Endif
End


# Gestion Tableau Action 
######################################################################################
Subprog SETTABACT(ACTION)
Value Char ACTION

If ACTION<>""
   Actzo [M:AYL3]20,30  : Effzo [M:AYL3]20   # Activation tableau Action et cadre enchainement
#####   
Actzo [M:AYL1]ACTVERCHP
#####
   [M:AYL3]NUM41=dim([M:AYL3]PARCOD41)       # Pour eviter pb sur grizo des colonnes (AM_xx)
   Gosub AYL_AYL3
   Call AM_SUIPRG([M:AYL3]SUIPRG)
Else
   Effzo [M:AYL3]
   Grizo [M:AYL3]
   #####
Effzo [M:AYL1]ACTVERCHP
Grizo [M:AYL1]ACTVERCHP
#####
Endif

Affzo [M:AYL3]
End


### Chgt mask AYL3 (Action) par AytLines 
######################################################################################
$AYL_AYL3
# AYN: Principal- Table paramètres des actions (type 3 - interface)   - LINTYP = 40
# AYN: Lié      - Table des valeurs portées par le DL(type 4 - blocs) - LINTYP = 41

WI=0

# Liste des paramètres
For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 3
&                     and LINCOD = toupper([L]ACTION) and  LINTYP = 40
&                     and VALTYP<>1                # Pas une cste déclaré sur l'action
      [M:AYL3]PARCOD41(WI)    = [F:AYN]PARCOD
      [M:AYL3]VALTYP41(WI)    = 1     # Défaut
      [M:AYL3]VALEUR41(WI)    = "?"
      WI+=1
Next
[M:AYL3]NUM41=WI

#  Valeurs: LINCODTYP = 4 et LINTYP = 41
For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 4
&                     and LINCOD = toupper([M]DLKCOD) and  LINTYP = 41
      WI=find([F:AYN]PARCOD,[M:AYL3]PARCOD41(0..[M:AYL3]NUM41-1))
      If WI
          WI=WI-1
          [M:AYL3]VALTYP41(WI)    = [F:AYN]VALTYP
          [M:AYL3]VALEUR41(WI)    = [F:AYN]VALEUR
          [M:AYL3]VBLCCOD41(WI)   = [F:AYN]VALBLCCOD : Call SETZENTCODCOD41([F:AYN]VALBLCCOD, WI)
          [M:AYL3]VFIELNKE41(WI)  = [F:AYN]VALFIELNKE
          [M:AYL3]VFIECOD41(WI)   = [F:AYN]VALFIECOD
          Call FIEKEY_COD([F:AYN]VALFIELNKE, [F:AYN]VALFIECOD, [M:AYL3]VFIEKEY41(WI)) From SUBAYF
      Endif
      #
Next
# Grisage
For WI=0 To [M:AYL3]NUM41-1
  Call SETLIN41([M:AYL3]VALTYP41(WI) , WI)
Next
Return


### Chgt AytLines par le mask AYL3 (Action)
######################################################################################
Subprog AYL3_AYL()    
# Action (valeur des param)
For WI=0 To [M:AYL3]NUM41-1
 Raz [F:AYN]
 [F:AYN]FCYCOD    = [M]FCYCOD
 [F:AYN]LINCODTYP = 4
 [F:AYN]LINCODSTD = [M]DLKCOD
 [F:AYN]LINCOD    = toupper([M]DLKCOD)
 [F:AYN]LINTYP    = 41
 [F:AYN]LINNUM    = WI

 [F:AYN]PARCOD      = [M:AYL3]PARCOD41(WI)
 [F:AYN]VALTYP      = [M:AYL3]VALTYP41(WI)
 Case [F:AYN]VALTYP
 When 1,3,4    # cste; chp web
    [F:AYN]VALEUR = [M:AYL3]VALEUR41(WI)
 When 2    # chp xtend
    [F:AYN]VALBLCCOD   = [M:AYL3]VBLCCOD41(WI)
    [F:AYN]VALFIELNKE  = [M:AYL3]VFIELNKE41(WI)
    [F:AYN]VALFIECOD   = [M:AYL3]VFIECOD41(WI)
 Endcase

 Write [AYN]
 If fstat
  GOK=0 : Call FSTA("AYN") From GLOCK : Break
 Endif
Next
If GOK<>1 : Goto AYL3_AYL_E : Endif

$AYL3_AYL_E
End

### Gestion des chps d'une ligne de critère en fonction du type de valeur
Subprog SETLIN41(VALTYP, NOL)    
Value Integer VALTYP
Value Integer NOL
Case VALTYP
When 1     # cste
    Effzo [M:AYL3]VBLCCOD41(NOL),VFIEKEY41(NOL) : Grizo [M:AYL3]VBLCCOD41(NOL),VFIEKEY41(NOL)
    Actzo [M:AYL3]VALEUR41(NOL)
When 2    # chp xtend
    #Infbox "num "-num$(NOL)-"nb"-num$([M:AYL3]NUM41)
    Actzo [M:AYL3]VBLCCOD41(NOL),VFIEKEY41(NOL)
    Effzo [M:AYL3]VALEUR41(NOL) : Grizo [M:AYL3]VALEUR41(NOL)
When 3    # chp web
    Effzo [M:AYL3]VBLCCOD41(NOL),VFIEKEY41(NOL)
    Grizo [M:AYL3]VBLCCOD41(NOL),VFIEKEY41(NOL)
    Actzo [M:AYL3]VALEUR41(NOL)
    # Pour info
    #[M:AYL3]VALEUR41(NOL)=[M]DLKCOD+":act="+num$(NOL+1) : Diszo [M:AYL3]VALEUR41(NOL)  
When 4    # javascript
    # Effzo [M:AYL3]VBLCCOD41(NOL),VFIEKEY41(NOL),VALEUR41(NOL)
    # Grizo [M:AYL3]VBLCCOD41(NOL),VFIEKEY41(NOL),VALEUR41(NOL)

    Effzo [M:AYL3]VBLCCOD41(NOL),VFIEKEY41(NOL)
    Grizo [M:AYL3]VBLCCOD41(NOL),VFIEKEY41(NOL)
    Actzo [M:AYL3]VALEUR41(NOL)

Endcase 
End

### Gestion du code entité en fonction du bloc sur la ligne
Subprog SETZENTCODCOD41(BLCCOD, NOL)
Value Char BLCCOD
Value Integer NOL
Local Char WENTCOD(GLONAYE)
If BLCCOD<>""    
    If !clalev([F:AYB1]) : Local File AYTELTBLC [AYB1] : Endif
    Read [AYB1]AYB0 = [M]FCYCOD;[L]BLCCOD
    If !fstat                
        WENTCOD=[F:AYB1]ENTCOD
    Endif
Endif
[M:AYL3]ZENTCOD41(NOL)=WENTCOD: Affzo [M:AYL3]ZENTCOD41(NOL)
End


######################################################################################
## Ecran AYL0
######################################################################################


######################################################################################
## Ecran AYL1
######################################################################################
Subprog AM_ENTCOD(VALEUR)
Variable Char    VALEUR()
# Appel Gestion AYB2
[M:AYB2]SELTYP=1 : [M:AYB4]SRTTYP=1 
Call SETAYB2(VALEUR)
Affzo [AYB2]
#
Call SETBLCOPT(VALEUR)
# Gestion tableau Paramètres Accès spg
Call SETTABTYP2(1, [M:AYB2]INTCODSEL, [M:AYB2]INTTYPSEL)
End

Subprog AM_ACTCOD(VALEUR)
Variable Char    VALEUR()
Call SETTABACT(VALEUR)
#
#If VALEUR=""
#    Effzo [M:AYL1]ACTRUN : Grizo [M:AYL1]ACTRUN 
#Else
#    Actzo [M:AYL1]ACTRUN 
#Endif
End

Subprog AM_PAGSAM(VALEUR)
Variable Integer VALEUR
Call SETPAGCOD(VALEUR)
End

Subprog AS_VALTYP42(VALEUR)
Variable Integer VALEUR
Local Integer LST(len(mess(0,GCOMBO,1))),WI
LST(WI)=1 : WI+=1    # Cst
LST(WI)=2 : WI+=1    # Chp XTend
LST(WI)=3 : WI+=1    # Chp Web
# LST(WI)=4 : WI+=1    # Javascript
LST(WI)=7 : WI+=1    # Bloc
Call MNLCHX(GCOMBO,LST) From AYTUTIA
End

Subprog AM_VALTYP42(VALEUR)
Variable Integer VALEUR
NOL=nolign-1
Call SETLIN42(1, VALEUR, NOL)
End

Subprog AS_VALEUR42(VALEUR)
Variable Char    VALEUR()
If [M:AYL1]VALTYP42(nolign-1)=3 # Chps web
    If VALEUR="" or VALEUR="?"
        WVAL=[M:AYL1]PARCOD42(nolign-1)
        Call UNICITE(WVAL,[M:AYL1]VALEUR42) From OBJDIV
        If mkstat
            Local Integer WI
            While mkstat<>0
                mkstat=0 : GERR=0 : GMESSAGE=""
                WVAL=[M:AYL1]PARCOD42(nolign-1)+num$(WI)
                Call UNICITE(WVAL,[M:AYL1]VALEUR42) From OBJDIV
                WI+=1
            Wend
        Endif
        VALEUR = WVAL #: mkstat=3
    Endif
Endif
End

Subprog C_VALEUR42(VALEUR)
Variable Char    VALEUR()
If [M:AYL1]VALTYP42(nolign-1)=3 # Chps web
    Call UNICITE(VALEUR,[M:AYL1]VALEUR42) From OBJDIV
    If vireblc(VALEUR,2)=""
     mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
Endif
End

Subprog AM_VBLCCOD42(VALEUR)
Variable Char    VALEUR()
Call SETZENTCODCOD42(1, VALEUR, nolign-1)
End

Subprog AM_VFIEKEY42(VALEUR)
Variable Char    VALEUR()
Call FIEKEY_ANA(VALEUR, [M:AYL1]VFIELNKE42(nolign-1),[M:AYL1]VFIECOD42(nolign-1)) From SUBAYF
End

######################################################################################
## Ecran AYL3
######################################################################################
Subprog AS_VALTYP41(VALEUR)
Variable Integer VALEUR
Local Integer LST(len(mess(0,GCOMBO,1))),WI
LST(WI)=1 : WI+=1    # Cst
LST(WI)=2 : WI+=1    # Chp XTend
LST(WI)=3 : WI+=1    # Chp Web
LST(WI)=4 : WI+=1    # Javascript
Call MNLCHX(GCOMBO,LST) From AYTUTIA
End

Subprog AM_VALTYP41(VALEUR)
Variable Integer VALEUR
Local Integer NOL
NOL=nolign-1
Call SETLIN41(VALEUR, NOL)
End

Subprog AM_VBLCCOD41(VALEUR)
Variable Char    VALEUR()
Call SETZENTCODCOD41(VALEUR, nolign-1)
End

Subprog AM_VFIEKEY41(VALEUR)
Variable Char    VALEUR()
Call FIEKEY_ANA(VALEUR, [M:AYL3]VFIELNKE41(nolign-1),[M:AYL3]VFIECOD41(nolign-1)) From SUBAYF
End

Subprog AS_VALEUR41(VALEUR)
Variable Char    VALEUR()
Local Char WVAL(GLONAYV)
# If [M:AYL3]VALTYP41(nolign-1)=3 # Chps web

If find([M:AYL3]VALTYP41(nolign-1),3,4)
    If VALEUR="" or VALEUR="?"
        WVAL=[M:AYL3]PARCOD41(nolign-1)
        Call UNICITE(WVAL,[M:AYL3]VALEUR41) From OBJDIV
        If mkstat
            Local Integer WI
            While mkstat<>0
                mkstat=0 : GERR=0 : GMESSAGE=""
                WVAL=[M:AYL3]PARCOD41(nolign-1)+num$(WI)
                Call UNICITE(WVAL,[M:AYL3]VALEUR41) From OBJDIV
                WI+=1
            Wend
        Endif
        VALEUR = WVAL #: mkstat=3
    Endif
Endif
End

Subprog C_VALEUR41(VALEUR)
Variable Char    VALEUR()
If [M:AYL3]VALTYP41(nolign-1)<>1    # pas de ctl sur cste
 If vireblc(VALEUR,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1) : End
 Endif
Endif

# If [M:AYL3]VALTYP41(nolign-1)=3 # Chps web
If find([M:AYL3]VALTYP41(nolign-1),3,4)
    Call UNICITE(VALEUR,[M:AYL3]VALEUR41) From OBJDIV
Endif
End

Subprog AM_SUIPRG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M:AYL3]40 : Grizo [M:AYL3]40 : Actzo [M:AYL3]SUIPRGFLD,SUIPRGENT
Else
  Effzo [M:AYL3]SUIPRGFLD,SUIPRGENT : Grizo [M:AYL3]SUIPRGFLD,SUIPRGENT : Actzo [M:AYL3]40
Endif
End

