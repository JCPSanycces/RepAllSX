#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIGPA21   Mise à jour champs VCRTYP pour suivis sans OF               #
# ---------------------------------------------------------------------- #
##########################################################################

#################################
Call MAJ_UTIGPA21
End

#################################
Subprog MAJ_UTIGPA21
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
Call OUVRE_TRACE("UTIGPA21: Update VCRTYP in WIPCOST") From LECFIC
Call TEMPON("O") From GESECRAN
If DOSSIER<>"" Call EXE_UTIGPA21(DOSSIER) : Endif
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End


#################################
Subprog EXE_UTIGPA21(DOSSIER)
Value Char DOSSIER
Local Integer IUTI
Call ECR_TRACE("UTIGPA21: Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:MWI])=0  Local File =DOSSIER+".WIPCOST"  [MWI] : Endif
If clalev([F:MWH])=0  Local File =DOSSIER+".MFGWIP"   [MWH] : Endif

Call DEBTRANS From GLOCK

Trbegin [MWI]
Update [MWI] Where VCRTYP=0
&             With VCRTYP=37
Update [MWH] Where VCRTYP=0
&             With VCRTYP=37
If fstat
    Call ECR_TRACE("File WIPCOST, ERROR while update ="-num$(fstat),1) From GESECRAN
Endif
Commit

Call ECR_TRACE("UTIGPA21 : End Process",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call EXE_UTIGPA21(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
Call EXE_UTIGPA21(APPLI)       
End



