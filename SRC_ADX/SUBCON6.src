#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du masque CON6
###########################################################################################################
Subprog AM_INDCODE(VALEUR)
Variable Char    VALEUR()

  [M:CON6]INDCODE = VALEUR
  If VALEUR <> "" Then
    Gosub LOAD_VALEUR From TRTCON6
  Else
    Effzo [M:CON6]20
    [M:CON6]NBVAL=0
  Endif
  Affzo [M:CON6]1-99
  REP = ""
End

