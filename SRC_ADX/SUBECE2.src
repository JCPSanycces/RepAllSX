#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################
Subprog IB_ESCSTRDAT
  GBOUT1 = mess(1,3030,1)
  GBOUT2 = mess(2,3030,1)
  GBOUT3 = mess(3,3030,1)
  GBOUT4 = mess(4,3030,1)
End

##########################################################################
Subprog B1_ESCSTRDAT(VALEUR)
Variable Date    VALEUR

  Gosub SETYEARDATE From TRTECE2
  Affzo [M:ECE2]
End

##########################################################################
Subprog B2_ESCSTRDAT(VALEUR)
Variable Date    VALEUR

Local Integer ISREFOUND

  ISREFOUND = 0
  Filter [SRE] Where [F:SRE]SRENUM <> "" and [F:SRE]CREDAT <> [00/00/00]
  For [SRE]SRE1
    [M:ECE2]ESCSTRDAT = [F:SRE]CREDAT
    ISREFOUND = 1
    Break
  Next
  Filter [SRE]
  If ISREFOUND = 0 Then
    Gosub SETYEARDATE From TRTECE2
  Endif
  Affzo [M:ECE2]
End

##########################################################################
Subprog B3_ESCSTRDAT(VALEUR)
Variable Date    VALEUR

  If GESCSETDDA = [00/00/00] Then
    Gosub SETYEARDATE From TRTECE2
  Else
    [M:ECE2]ESCSTRDAT = GESCSETDDA
  Endif
  Affzo [M:ECE2]
End

##########################################################################
Subprog B4_ESCSTRDAT(VALEUR)
Variable Date    VALEUR

  If GESCSETNDA = 0 Then
    Gosub SETYEARDATE From TRTECE2
  Else
    [M:ECE2]ESCSTRDAT = date$ - GESCSETNDA
  Endif
  Affzo [M:ECE2]
End

##########################################################################
Subprog AS_NBSRE

  If nolign-1 >= 0 Then
    If nolign = [M:ECE3]NBSRE Then
      [M:ECE2]NVGCOD = "4"
    Else
      [M:ECE2]NVGCOD = "1"
      [M:ECE2]CURSRECAT = [M:ECE3]SRECAT(nolign-1)
    Endif
  Endif
End

##########################################################################
Subprog C_NBSRE

  If nolign-1 >= 0 Then
    If nolign = [M:ECE3]NBSRE Then
      [M:ECE2]NVGCOD = "4"
    Else
      [M:ECE2]NVGCOD = "1"
      [M:ECE2]CURSRECAT = [M:ECE3]SRECAT(nolign-1)
    Endif
  Endif
End

##########################################################################
Subprog AS_NBUSR

  If nolign-1 >= 0 Then
    Call LOADUSRCAT([M:ECE4]USR(nolign-1)) From TRTECE2
    [M:ECE2]NVGCOD = "2"
    [M:ECE2]CURUSR = [M:ECE4]USR(nolign-1)
  Endif
End

##########################################################################
Subprog C_NBUSR

  If nolign-1 >= 0 Then
    Call LOADUSRCAT([M:ECE4]USR(nolign-1)) From TRTECE2
    [M:ECE2]NVGCOD = "2"
    [M:ECE2]CURUSR = [M:ECE4]USR(nolign-1)
  Endif
End

##########################################################################
Subprog AS_NBCAT

  If nolign-1 >= 0 Then
    [M:ECE2]NVGCOD = "3"
    [M:ECE2]CURUSRCAT = [M:ECE4]USRCAT(nolign-1)
  Endif
End

##########################################################################
Subprog C_NBCAT

  If nolign-1 >= 0 Then
    [M:ECE2]NVGCOD = "3"
    [M:ECE2]CURUSRCAT = [M:ECE4]USRCAT(nolign-1)
  Endif
End

##########################################################################
Subprog IB_NBSRE

  Call TEXTE(14676, GBOUT1) From OBJDIV      #Escalades
End

##########################################################################
Subprog IB_NBUSR

  Call TEXTE(14676, GBOUT1) From OBJDIV      #Escalades
End

##########################################################################
Subprog IB_NBCAT

  Call TEXTE(14676, GBOUT1) From OBJDIV      #Escalades
End
