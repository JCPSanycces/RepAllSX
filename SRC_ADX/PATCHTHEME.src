#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","HRAPATCHP","HRAPATCHP",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "VERF_TABLE"   : Gosub VERF_TABLE
 When "EXEC"         : Gosub EXEC
Endcase
Return

$INIT
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
If clalev([F:VRA])=0 : Local File VARIA    [VRA] : Endif
If clalev([F:CUM])=0 : Local File CUMUL    [CUM] : Endif
Return

$SEL_TABLE
OBJET = "ADI"
CRITOBJ = "NUMTAB=10391"
Return

$VERF_TABLE
PARAM(1) = [F:ADI]CODE
PARAM(2) = GCURLEG
Return

$EXEC
Local Char ZONE (50)
For [VRA] Where VRATHM=PARAM(1) & LEG=PARAM(2)
 If [M:DIA]NBOBJ>=dim([M:DIA]NOMOBJ)
  Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
 [M:DIA]TYPOBJ([M]NBOBJ) = "VRA"
 [M:DIA]NOMOBJ([M]NBOBJ) = [F:VRA]COD
 #84947
 If dim([M:DIA]TYPNOMOBJ([M]NBOBJ))>0
  ZONE=[M:DIA]TYPOBJ([M]NBOBJ)+"|"+ [M:DIA]NOMOBJ([M]NBOBJ)
  nolign=[M]NBOBJ
  Call UNICITE(ZONE,[M]TYPNOMOBJ(0..[M]NBOBJ)) From OBJDIV
  If mkstat=2
   Break
  Else
   [M:DIA]TYPNOMOBJ([M]NBOBJ)=ZONE
  Endif
 Endif
 #
 [M]NBOBJ += 1
Next
For [CUM] Where CUMTHM=PARAM(1) & LEG=PARAM(2)
 If [M:DIA]NBOBJ>=dim([M:DIA]NOMOBJ)
  Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
 [M:DIA]TYPOBJ([M]NBOBJ) = "CUM"
 [M:DIA]NOMOBJ([M]NBOBJ) = [F:CUM]CUMCOD
 #84947
 If dim([M:DIA]TYPNOMOBJ([M]NBOBJ))>0
  ZONE=[M:DIA]TYPOBJ([M]NBOBJ)+"|"+ [M:DIA]NOMOBJ([M]NBOBJ)
  nolign=[M]NBOBJ
  Call UNICITE(ZONE,[M]TYPNOMOBJ(0..[M]NBOBJ)) From OBJDIV
  If mkstat=2
   Break
  Else
   [M:DIA]TYPNOMOBJ([M]NBOBJ)=ZONE
  Endif
 Endif
 #
 [M]NBOBJ += 1
Next
For [RUB] Where RUBTHM=PARAM(1) & LEG=PARAM(2)
 If [M:DIA]NBOBJ>=dim([M:DIA]NOMOBJ)
  Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
 [M:DIA]TYPOBJ([M]NBOBJ) = "RUB"
 [M:DIA]NOMOBJ([M]NBOBJ) = [F:RUB]COD
 #84947
 If dim([M:DIA]TYPNOMOBJ([M]NBOBJ))>0
  ZONE=[M:DIA]TYPOBJ([M]NBOBJ)+"|"+ [M:DIA]NOMOBJ([M]NBOBJ)
  nolign=[M]NBOBJ
  Call UNICITE(ZONE,[M]TYPNOMOBJ(0..[M]NBOBJ)) From OBJDIV
  If mkstat=2
   Break
  Else
   [M:DIA]TYPNOMOBJ([M]NBOBJ)=ZONE
  Endif
 Endif
 #
 [M]NBOBJ += 1
Next
Affzo [DIA]10
Return
