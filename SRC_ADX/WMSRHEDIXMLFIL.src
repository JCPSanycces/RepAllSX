#<AdxTL>@(#)0.0.0.0 $Revision$Class ## ?IDENTQRY? SEARCH ##
# Supervisor
#WMSRHEDIXMLFIL EDIXMLFIL
# 2018-11-06 07:05:18 481

Funprog IS_IMPLEMENTED()
End 1
#---------------------------------------------------------------------------------------------------#
# List of tables to open
#---------------------------------------------------------------------------------------------------#
$ASEARCH_OPEN
If filinfo(filpath("FIL","EDIXMLFIL","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EDIXMLFIL [EXF]
If filinfo(filpath("FIL","EDIXMLFILD","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EDIXMLFILD [EXFD]
If filinfo(filpath("FIL","EDIXMLFILXSD","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EDIXMLFILXSD [EXSD]
If filinfo(filpath("FIL","EDIXMLFILF","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EDIXMLFILF [EXFF]
Local File EDIXMLFIL [EXF_]
Local Char KEY_EXF(120)(1..3)
Local Char KEY_EXFD(120)(1..3)
Local Char KEY_EXSD(120)(1..3)
Local Char KEY_EXFF(120)(1..3)
#Empty keys :
KEY_EXF(3) = "++"
KEY_EXFD(3) = "+++0"
KEY_EXSD(3) = "+++0"
KEY_EXFF(3) = "+++0"
ACTION = "ASEARCH_OPEN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to close
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CLOSE
LogicClose File [EXF]
LogicClose File [EXFD]
LogicClose File [EXSD]
LogicClose File [EXFF]
LogicClose File [EXF_]
ACTION = "ASEARCH_CLOSE_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN
Link [EXF] With
& [EXFD]EXFD0=[F:EXF]MSGCOD;[F:EXF]MSGREL;[F:EXF]MSGFILNOR,
& [EXSD]EXSD0=[F:EXF]MSGCOD;[F:EXF]MSGREL;[F:EXF]MSGFILNOR,
& [EXFF]EXFF0=[F:EXF]MSGCOD;[F:EXF]MSGREL;[F:EXF]MSGFILNOR
& As [LNK_]
& Where (1=1
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN_INC
Link [EXF] With
& [EXFD]EXFD0=[F:EXF]MSGCOD;[F:EXF]MSGREL;[F:EXF]MSGFILNOR,
& [EXSD]EXSD0=[F:EXF]MSGCOD;[F:EXF]MSGREL;[F:EXF]MSGFILNOR,
& [EXFF]EXFF0=[F:EXF]MSGCOD;[F:EXF]MSGREL;[F:EXF]MSGFILNOR
& As [LNK_]
& Where (UPDDATTIM > gdatetime$(QUPDDATTIM)
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Create an instance of
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CREATEINSTANCE
Local Integer ASTATUS
Local Integer FINS
Return

#---------------------------------------------------------------------------------------------------#
# Set an instance
#---------------------------------------------------------------------------------------------------#
$ASEARCH_SETINSTANCE
KEY_EXF(2) = [F:EXF]MSGCOD+"+"+[F:EXF]MSGREL+"+"+[F:EXF]MSGFILNOR
KEY_EXFD(2) = [F:EXFD]MSGCOD+"+"+[F:EXFD]MSGREL+"+"+[F:EXFD]MSGFILNOR+"+"+num$([F:EXFD]NUMLIN)
KEY_EXSD(2) = [F:EXSD]MSGCOD+"+"+[F:EXSD]MSGREL+"+"+[F:EXSD]MSGFILNOR+"+"+num$([F:EXSD]NUMLIN)
KEY_EXFF(2) = [F:EXFF]MSGCOD+"+"+[F:EXFF]MSGREL+"+"+[F:EXFF]MSGFILNOR+"+"+num$([F:EXFF]NUMLIN)

If (KEY_EXF(2) <> KEY_EXF(3)) & (KEY_EXF(1) <> KEY_EXF(2))
 If INS <> null
  [L]ASTATUS = fmet INS.ACTION("ASEARCH_TRANS_AFTER")
  #serialize INS
  Gosub ASEARCH_TO_JSON
 Endif
#Create a new instance
INS = NewInstance C_EDIXMLFIL(GACTX,UIDINS,NUMLIN,null,"") AllocGroup null
INS.setaccessorEnabled = 0
SetInstance INS With [F:EXF]
FINS = 1
 KEY_EXF(1) = KEY_EXF(2)
Endif : # KEY_EXF(1) <> KEY_EXF(2)

Return

#---------------------------------------------------------------------------------------------------#
# Serialize the entity in a JSON format
#---------------------------------------------------------------------------------------------------#
$ASEARCH_TO_JSON
If FINS=0 : Return : Endif
QCOUNT += 1
Onerrgo ERROR_VALUE
Append ASND.DATA ,SEPINS1
SEPINS1 = ','+chr$(10)
Append ASND.DATA ,'{'
Append ASND.DATA ,'"MSGCOD":'          +'"'+escJson(INS.MSGCOD)+'"'
Append ASND.DATA ,',"MSGREL":'         +'"'+escJson(INS.MSGREL)+'"'
Append ASND.DATA ,',"MSGFILNOR":'      +'"'+escJson(INS.MSGFILNOR)+'"'
Append ASND.DATA ,',"CREUSR":'         +'"'+escJson(INS.CREUSR)+'"'
Append ASND.DATA ,',"UPDUSR":'         +'"'+escJson(INS.UPDUSR)+'"'
Append ASND.DATA ,'}'
Onerrgo
Freegroup INS
INS = null
Raz KEY_EXF(1),KEY_EXFD(1),KEY_EXSD(1),KEY_EXFF(1)
FINS = 0
Return

#---------------------------------------------------------------------------------------------------#
# Errors
#---------------------------------------------------------------------------------------------------#
$ERROR_VALUE
SVALUE ='"<error'-errmes$(errn)+'>"'
Resume
#---------------------------------------------------------------------------------------------------#
# Link standard key
#---------------------------------------------------------------------------------------------------#
$AQUERY_PRIMARYKEYS
Local Char ASTDKEY(250)
ASTDKEY = ""
ASTDKEY += "[F:EXF]MSGCOD"
ASTDKEY += ";[F:EXF]MSGREL"
ASTDKEY += ";[F:EXF]MSGFILNOR"
ACTION = "ASEARCH_PRIMARYKEYS_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Actions
#---------------------------------------------------------------------------------------------------#
$ASEARCH_ACTION
Local Char CURPRO(250),CURPTH(250),AMETHOD(50),AEVENT(50)
[L]AEVENT = [L]ACTION
Gosub METHODS From EDIXMLFIL_CSTD
Return

#---------------------------------------------------------------------------------------------------#
# APPEND_PROTOTYPE
#---------------------------------------------------------------------------------------------------#
Funprog APPEND_PROTOTYPE(ACTX,WCLOB,PSYR)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Clbfile   WCLOB
Variable Instance  PSYR     Using C_ASYR
Local Integer ERROR : ERROR = 0
Local Integer IND   : IND = 0
Local Char TRTNAME(80)
Local Char REPRESENTATION(80)
Local File ASHW    [ASW]
Filter [ASW] Where CODCLA="EDIXMLFIL" & DEFREP=2
Read [ASW]ASW0 First
If !fstat
 If  [ASW]ENAFAC(0) = 2
  REPRESENTATION = [ASW]CODREP
 Else
  WCLOB ="{}"
  End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"EDIXMLFIL")) 
 Endif
Endif
Close Local File [ASW]
If len(REPRESENTATION)=0
 WCLOB ="{}"
 End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"EDIXMLFIL")) 
Endif
Append WCLOB,'{'
Append WCLOB,'"$baseUrl":"'+PSYR.PREFIX+'"'
Append WCLOB,',"$baseType":"'+PSYR.CNTPRE+"."+nomap+'"'
Append WCLOB,',"$classTitle":"'+func GET_RES_STRING(ACTX.LAN,54616)+'"'
Append WCLOB,',"$url":"{$baseUrl}/EDIXMLFIL'+PSYR.URLREP+''+REPRESENTATION+'.$search"'
Append WCLOB,',"$prototype":"{$baseUrl}/$prototypes('+"'"+'{$representation}.$thumb'+"'"+')"'
Append WCLOB,',"$type":"{$baseType}.'+REPRESENTATION+'.$search"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"$resources":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$item":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,54616)+' {$key}"'
Append WCLOB,',"$key":"{MSGCOD}~{MSGREL}~{MSGFILNOR}"'
Append WCLOB,',"$url":"{$baseUrl}/EDIXMLFIL('+"'"+'{$key}'+"'"+')'+PSYR.URLREP+'EDIXMLFIL.searchItem"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"MSGCOD":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,50161)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":20'
Append WCLOB,"}"
Append WCLOB,',"MSGREL":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,1281)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":5'
Append WCLOB,"}"
Append WCLOB,',"MSGFILNOR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,50177)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":20'
Append WCLOB,"}"
Append WCLOB,',"CREUSR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,250)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,"}"
Append WCLOB,',"UPDUSR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,250)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,',"$links":{'
Append WCLOB,'"$search$details":{'
Append WCLOB,'"$title":"Detail"'
Append WCLOB,',"$default":true'
Append WCLOB,',"$url":"{$baseUrl}/EDIXMLFIL('+"'"+'{$key}'+"'"+')?representation=EDIXMLFIL.$details"'
Append WCLOB,',"$devices":"desktop"'
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
End ERROR
#---------------------------------------------------------------------------------------------------#
# GET_RES_STRING
#---------------------------------------------------------------------------------------------------#
Funprog GET_RES_STRING(_LAN,_ID)
Value Char _LAN
Value Integer _ID
Gosub  _GET_RES_STRING From WMSRHEDIXMLFILB
End RES

#---------------------------------------------------------------------------------------------------#
# GET_RES_MENU
#---------------------------------------------------------------------------------------------------#
Funprog GET_RES_MENU(_LAN,_ID)
Value Char _LAN
Value Char _ID
Gosub  _GET_RES_MENU From WMSRHEDIXMLFILB
End RES


