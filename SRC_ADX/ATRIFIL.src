#<AdxTL>@(#)10.0.0.0 $Revision$
#--------------------------------------------------------------------------------------------------------------#
# Process called by Write/Rewrite/Update on adonix
#--------------------------------------------------------------------------------------------------------------#
# The process ATRIFIL must be defined into variable [S]adxtrp
# The $ATRIOPE must be defined into variable [S]adxtrl
# The variable [S]adxtro = U (Update) or R (Rewrite) or W (Write) is initialised by adonix
# timestamp$ -> time to the thousandth of a second
#               func SUBADC.CNVMIL(TIMESTAMP$) with format AAAA-MM-JJ HH:MM:SS MMM
#           and func SUBADC.CNVMIL4(TIMESTAMP$) with format date in local
# uuid$ -> unique number of identification on 36 caracters
#--------------------------------------------------------------------------------------------------------------#
#ATTENTION il ne faut pas de onerrgo dans ce traitement qui utilise des Gosub !!!!!!!!!!!
#--------------------------------------------------------------------------------------------------------------#

$ATRIOPE
Local Char    ATIMSTP(50) , AUSRCUR(20)
Local Integer ER

#################################################################################################
# A REVOIR : PAS D'ACCORD QUE CE TRAITEMENT SERVE A L"APPLICATIF
#            CE TRAITEMENT NE SERA PAS UTILISE DANS SYRACUSE
#            L'INIT DES CHAMPS UPDDATTIM/CREDATTIM/AUUID EST GERE DANS LES METHODES DE CRUD
#################################################################################################
  # -------------------------------------
  # FGR 20/03/2012 : X3SUIVI71210 (début)
  If dim(GATRIFILB) < 0 Then
    Local Integer PSUBB

    Global Char GATRIFILB(GLONADC)

    Call EXISTE_ADX("", "", "ATRIFILB", PSUBB) From ORDSYS
    If PSUBB Then
      GATRIFILB = "ATRIFILB"
    Endif
  Endif
  If GATRIFILB <> "" Then
    Gosub ATRIOPE From =GATRIFILB
  Endif
  # FGR 20/03/2012 : X3SUIVI71210 (fin)
  # -------------------------------------
##############################################################################################

If (dim([F]UPDDATTIM)<=0 or dim([F]AUUID)<=0 or dim([F]UPDUSR)<=0) and dim([F]UPDSTP)<=0
 #-------------------------------------------------------------------#
 # - permet de ne prendre en compte que les tables CRM (v6)
 # - évite un conflit Oracle sur des "Update" lancés manuellement
 #   sur un des champs ci-dessous (Bug moteur résolu en v7)
 # - permet d'éviter un conflit avec les sous-programmes INICRE
 #   et INIMOD de GOBJSUB (v6)
 #-------------------------------------------------------------------#
 Return
Endif
If func AFNC.PARTSEP(ver$(0),2," ")>="17r.104"
 Local Datetime ADATTIM
 ADATTIM = datetime$
Endif
ATIMSTP = timestamp$
#
If dim(GUSRSD)>0 & GUSRSD<>""
     AUSRCUR = GUSRSD
Else
     AUSRCUR = GUSER
Endif
Case [S]adxtro
 When "U" : # Update
  Gosub VERIF_UT
  If dim([F]UPDDATTIM)>0 : Gosub INIT_UPDDATTIM   : Endif
  If dim([F]UPDUSR)>0 : [F]UPDUSR = AUSRCUR : Endif
  If dim([F]UPDSTP)>0 : [F]UPDSTP = ATIMSTP : Endif
 When "R" : # Rewrite
  Gosub VERIF_UT
  If dim([F]UPDDATTIM)>0 : Gosub INIT_UPDDATTIM   : Endif
  If dim([F]UPDUSR)>0 : [F]UPDUSR = AUSRCUR : Endif
  If dim([F]UPDSTP)>0 : [F]UPDSTP = ATIMSTP : Endif
  # Normalement, le uuid est déjà renseigné
  # Mais ce champ a pu être rajouté dans la table et il peut exister des enregistrements avec un uuid vide
  # si aucune moulinette d'init n'a été utilisée
  Gosub INIT_UUID
 When "W" : # write
  # jira 70340 init credattim always same for upddattim
  If dim([F]CREDATTIM)>0 : Gosub INIT_CREDATTIM : Endif
  If dim([F]UPDDATTIM)>0 : Gosub INIT_UPDDATTIM : Endif

  If dim([F]CREUSR)>0 & [F]CREUSR="" : [F]CREUSR = AUSRCUR : Endif
  If dim([F]UPDUSR)>0 & [F]UPDUSR="" : [F]UPDUSR = AUSRCUR : Endif
  If dim([F]UPDSTP)>0 & [F]UPDSTP="" : [F]UPDSTP = ATIMSTP : Endif
  Gosub FORCE_UUID
Endcase
Return

#----------------------------#
$VERIF_UT
Gosub CTL_APPLI
If UT_APPLI
 Gosub SET_USER
 If dim([F]CREUSR)>0 & find([F]CREUSR,TB_AUZ(1..NB_AUZ)) & [F]CREUSR<>AUSRCUR
  Gosub SET_TABLE
  Gosub GET_NAMTAB
  If !find(NAM_TAB,TB_VIR(1..NB_VIR))
   GOK = 0
   Infbox "You ("+AUSRCUR+") are not allowed to modify"-NAM_TAB-"created by"-[F]CREUSR
  Endif
 Endif
Endif
Return

#------------------------------------------#
# Application
#------------------------------------------#
$CTL_APPLI
Local Integer UT_APPLI
If dim(GDOSX3)>0
 UT_APPLI = (find(nomap(0),GDOSX3))
Endif
Return

#-----------------------------------------------------#
# Utilisateurs pouvant modifier des données stables
#-----------------------------------------------------#

$SET_USER
Local Integer NB_AUZ
Local Char    TB_AUZ(GLONAUS)(1..10)
NB_AUZ  = 1 : TB_AUZ(NB_AUZ) = string$(GLONAUS,"A") : # User test Supervisor
NB_AUZ += 1 : TB_AUZ(NB_AUZ) = "QFIN"               : # User test Finance
NB_AUZ += 1 : TB_AUZ(NB_AUZ) = "QFXD"               : # User test Fixed Assets
Return

#-----------------------------------------------#
# Nom de la table courante
#-----------------------------------------------#

$GET_NAMTAB
Local Integer IND_TAB
Local Char    NAM_TAB(250)
IND_TAB = find(right$(ctrans(clanam([F]),"]",""),4),[S]fileabre(1..[S]dbglong(11)-1))
If IND_TAB
 NAM_TAB = [S]filename(IND_TAB)
 IND_TAB = instr(1,NAM_TAB,".FIL")
 If IND_TAB
  NAM_TAB = right$(NAM_TAB,IND_TAB+5)
 Endif
Endif
Return

#--------------------------------------------#
# Tables non gérées dans les données stables
#--------------------------------------------#

$SET_TABLE
Local Char    TB_VIR(GLONATB)(1..30)
Local Integer NB_VIR
NB_VIR = 1  : TB_VIR(NB_VIR) = "APLLCK"
NB_VIR += 1 : TB_VIR(NB_VIR) = "ALOGIN"
NB_VIR += 1 : TB_VIR(NB_VIR) = "ATEXTE"
NB_VIR += 1 : TB_VIR(NB_VIR) = "ATEXTRA"
NB_VIR += 1 : TB_VIR(NB_VIR) = "AFCTEXE"
NB_VIR += 1 : TB_VIR(NB_VIR) = "XXCORT"
NB_VIR += 1 : TB_VIR(NB_VIR) = "XXCORH"
NB_VIR += 1 : TB_VIR(NB_VIR) = "AOBJGRPDEV"
NB_VIR += 1 : TB_VIR(NB_VIR) = "ADICTRT"
NB_VIR += 1 : TB_VIR(NB_VIR) = "APATCH"
NB_VIR += 1 : TB_VIR(NB_VIR) = "AELT"
NB_VIR += 1 : TB_VIR(NB_VIR) = "AELTLINK"
NB_VIR += 1 : TB_VIR(NB_VIR) = "AESPION"
NB_VIR += 1 : TB_VIR(NB_VIR) = "ALSTRD"
NB_VIR += 1 : TB_VIR(NB_VIR) = "APORTMOD"
NB_VIR += 1 : TB_VIR(NB_VIR) = "APORTTAB"
NB_VIR += 1 : TB_VIR(NB_VIR) = "APORTUSER"
NB_VIR += 1 : TB_VIR(NB_VIR) = "AFCTFCY"
NB_VIR += 1 : TB_VIR(NB_VIR) = "ABATABT" : #117396
NB_VIR += 1 : TB_VIR(NB_VIR) = "ABATRQT" : #117396
NB_VIR += 1 : TB_VIR(NB_VIR) = "ABATRQTL" : #117396
Return

#----------------------------#
$FORCE_UUID
If dim([F]AUUID)>0
 If type([F]AUUID)=525
  [F]AUUID = getUuid
 Else
  [F]AUUID = uuid$
 Endif
Endif
Return

#----------------------------#
$INIT_UUID
If dim([F]AUUID)>0
 If type([F]AUUID)=525
  If [F]AUUID=NullUuid : # Uuident
   [F]AUUID = getUuid
  Endif
 Elsif [F]AUUID=""
  [F]AUUID = uuid$
 Endif
Endif
Return

#----------------------------#
$INIT_UPDDATTIM
If type([F]UPDDATTIM)=526
 If dim(ADATTIM)>0
  [F]UPDDATTIM = ADATTIM
 Endif
Else
 [F]UPDDATTIM = ATIMSTP
Endif
Return

#----------------------------#
$INIT_CREDATTIM
If type([F]CREDATTIM)=526
 If dim(ADATTIM)>0
  [F]CREDATTIM = ADATTIM
 Endif
Else
 [F]CREDATTIM = ATIMSTP
Endif
Return

#----------------------------#
$MAJ_UPDDATTIM
If type([F]UPDDATTIM)=526
 If dim(ADATTIM)>0 & num$([F]UPDDATTIM)=num$(gdatetime$(""))
  [F]UPDDATTIM = ADATTIM
 Endif
Elsif [F]UPDDATTIM=""
 [F]UPDDATTIM = ATIMSTP
Endif
Return

#----------------------------#
$MAJ_CREDATTIM
If type([F]CREDATTIM)=526
 If dim(ADATTIM)>0 & num$([F]CREDATTIM)=num$(gdatetime$(""))
  [F]CREDATTIM = ADATTIM
 Endif
Elsif [F]CREDATTIM=""
 [F]CREDATTIM = ATIMSTP
Endif
Return

#---------------#
$ER
ER = errn
Resume

