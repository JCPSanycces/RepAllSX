#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
Case ACTION
  When "ANNULE"      : Gosub ANNULE
  When "CREATION"    : Gosub CREATION
  When "MODIF"       : Gosub MODIF
  When "CHANGE"      : Gosub CHANGE
  When Default
Endcase

Return
#############################################################
$ANNULE
  # FGR 18/09/2009 : X3SUIVI57920
  #--- maj de la table des libéllés traduisibles
  Call SUPTEXTRA("TABSCA","SCADESAXX",[L]CODE,"") From ATEXTRA
  Call SUPTEXTRA("TABSCA","SCASHOAXX",[L]CODE,"") From ATEXTRA
Return
#############################################################
$CREATION
Local Integer WKNOL

  # FGR 18/09/2009 : X3SUIVI57920
  # FGR 01/10/2009 : X3SUIVI58279 : MSGNUM au lieu de SCANUM
  For WKNOL=0 To [M]NBSCA-1
    Call MAJTEXTRA([M]SCADESAXX(WKNOL),"TABSCA","SCADESAXX",num$([M]SCANUM(WKNOL)),"") From ATEXTRA
    Call MAJTEXTRA([M]SCASHOAXX(WKNOL),"TABSCA","SCASHOAXX",num$([M]SCANUM(WKNOL)),"") From ATEXTRA
  Next WKNOL
Return

#############################################################
$MODIF
Local Integer WKNOL

  # FGR 18/09/2009 : X3SUIVI57920
  # FGR 01/10/2009 : X3SUIVI58279 : MSGNUM au lieu de SCANUM
  For WKNOL=0 To [M]NBSCA-1
    Call MAJTEXTRA([M]SCADESAXX(WKNOL),"TABSCA","SCADESAXX",num$([M]SCANUM(WKNOL)),"") From ATEXTRA
    Call MAJTEXTRA([M]SCASHOAXX(WKNOL),"TABSCA","SCASHOAXX",num$([M]SCANUM(WKNOL)),"") From ATEXTRA
  Next WKNOL
Return

#############################################################
$CHANGE
  # FGR 18/09/2009 : X3SUIVI57920
  Call CHANGE_AXX("TABSCA", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
Return

########################################
Subprog AS_SCANUM(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : mkstat = 2 : Endif
End

########################################
Subprog C_SCANUM(VALEUR)
Variable Decimal VALEUR
Call UNICITE(VALEUR, [M:TSR1]SCANUM(0..NBSCA-1)) From OBJDIV
End

