#<AdxTL>@(#)10.0.0.0 $Revision$
##############################################################################
## Mise à jour nouveau champ ISONUM de la table TABCOUNTRY
##############################################################################
Call OUVRE_TRACE("Mise à jour nouveau champ ISONUM de la table TABCOUNTRY") From LECFIC
Call PATCH_X3(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTCY
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJTCY
End

$MAJTCY

Local File =DOSSIER+".TABCOUNTRY" [TCY] 

If dim([F:TCY]ISONUM)<0
 Close Local File [TCY]
 Return 
Endif

# Mise à jour de la table TABCOUNTRY
Call ECR_TRACE(mess(81,125,1)-"TABCOUNTRY:"-time$,0) From GESECRAN
Trbegin [TCY]
 For [TCY]TCY0
  If [F:TCY]CINSEE<>"" & [F:TCY]ISONUM=""
   [F:TCY]ISONUM = [F:TCY]CINSEE
   Rewrite [TCY]
  Endif
 Next
Commit

Close Local File [TCY]

Return
