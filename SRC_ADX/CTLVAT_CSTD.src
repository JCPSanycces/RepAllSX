Endcase
Return

#######################################################################################
# ------------------------------- #
# Method that Controle the VAT    #
# ------------------------------- #
$CTLVAT
Local Integer WRET
Local Integer WI

Local File TABVAT    [TVT]
Local File TABRATVAT [TRA]

Local Char WMESSA(255)

# Contrôle du régime de taxe
If this.VACBPR<>""
    WRET = func FINDVAT_SYRA.CONTTVB(this.ACTX,this.VACBPR,this.LEG,this.FCY,"","",WMESSA)
    If WRET>[V]CST_AWARNING
        this.VACBPRFLG = 1
        this.VACBPRMSG = mess(620,197,1)-WMESSA
        #Callmet this.ASETERROR("",this.VACBPRMSG,WRET)
    Endif
Endif

# Contrôle des niveaux de taxe
For WI=1 To maxtab(this.C_VACITM)
    If this.C_VACITM(WI)=null Break Endif
    WRET = func FINDVAT_SYRA.CONTTVI(this.ACTX,this.C_VACITM(WI).VACITM,this.LEG,this.FCY,"","",WMESSA)
    If WRET>[V]CST_AWARNING
        this.C_VACITM(WI).VACITMFLG = 1
        this.C_VACITM(WI).VACITMMSG = mess(839,197,1)-WMESSA
        #Callmet this.ASETERROR("",this.C_VACITM(WI).VACITMMSG,WRET)
    Endif
Next WI

# Contrôle des codes taxe
For WI=1 To maxtab(this.C_VAT)
    If this.C_VAT(WI)=null Break Endif

    WRET = func FINDVAT_SYRA.CONTTVT(this.ACTX,this.C_VAT(WI).VAT,this.LEG,this.FCY,"","",WMESSA)
    If WRET>[V]CST_AWARNING
        this.C_VAT(WI).VATFLG = 1
        this.C_VAT(WI).VATMSG = mess(840,197,1)-WMESSA
        #Callmet this.ASETERROR("",this.C_VAT(WI).VATMSG,WRET)
    Endif
    Call LEC_TVT_LEG(this.ACTX,this.LEG,this.C_VAT(WI).VAT,WRET) From TRTLECLEG_SYRA
    # A VOIR
    If WRET<[V]CST_AERROR
        # Contrôle du type de taxe
        If [F:TVT]VATTYP=1 & find(this.C_VAT(WI).VATTYP,0,2)
            # Type de taxe TVA
            # Sur doc d'origine : Code taxe présent sur Taxe 2 ou/et 3 (taxe para/spé)
            # --> C'est une erreur
            this.C_VAT(WI).VATFLG = 2
        Elsif find([F:TVT]VATTYP,2,3) & find(this.C_VAT(WI).VATTYP,0,1)
            # Type de taxe para/spé
            # Sur doc d'origine : Code taxe présent sur Taxe 1 (TVA)
            # --> C'est une erreur
            this.C_VAT(WI).VATFLG = 2
        Endif
        this.C_VAT(WI).VATTYP=[F:TVT]VATTYP
        # Contrôle des lignes de taux
        Filter [TRA] Where CPY=this.CPY & VAT=this.C_VAT(WI).VAT & STRDAT<=this.DAT & (LEG=[F:TVT]LEG)
        Read [TRA]TRA0 Last
        If fstat>2
          Filter [TRA] Where CPY="" & VAT=this.C_VAT(WI).VAT & STRDAT<=this.DAT & (LEG=[F:TVT]LEG)
          Read [TRA]TRA0 Last
        # Aucun taxe n'est applicable
          If fstat>2
              this.C_VAT(WI).VATFLG = 1
              this.C_VAT(WI).VATMSG = mess(840,197,1)-":"-this.C_VAT(WI).VAT-":"-mess(848,197,1)
              Filter [TRA]
          Endif
        Endif
        Filter [TRA]
    Endif
Next WI

[L]ARET_VALUE = fmet this.AGETMAXERROR("")

Return

