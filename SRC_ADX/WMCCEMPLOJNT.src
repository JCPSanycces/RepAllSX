####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0EMPLOJNT
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_REFNUM From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_REFNUM From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_NUMLIG From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_NUMLIG From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SSITFAM From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SSITFAM From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SJNTREFNUM From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SJNTREFNUM From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SJNTNAM From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SJNTNAM From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SJNTSRN From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SJNTSRN From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SJNTDATBRN From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SJNTDATBRN From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SJNTTEL From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SJNTTEL From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREDATTIM From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREDATTIM From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDDATTIM From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDDATTIM From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_AUUID From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_AUUID From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREUSR From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREUSR From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDUSR From WMC1EMPLOJNT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDUSR From WMC1EMPLOJNT : Gosub TESTALLSTAT :  Endif
[L]ASTATUS = fmet this.ACONTROL
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



