#[26]
$I_STATS
 # FQ83184 "-> Statistiques sur la population :"
 Call ECR_TRACE("",GTRC_STAT,mess(70,GML_MSGTRC,1),0,1) From TRACEABX3 # A reporter dans TRMOBJACT2
 If NBOBJ
  # FQ83184 "Nombre d'enregistrements sÃĐlectionnÃĐs :"
  Call ECR_TRACE("",GTRC_STAT,mess(71,GML_MSGTRC,1)-num$(NBOBJ),0,1) From TRACEABX3
 Else
  # FQ83184 "Aucun enregistrements sÃĐlectionnÃĐs"
  Call ECR_TRACE("",GTRC_STAT,mess(72,GML_MSGTRC,1),0,1) From TRACEABX3
 Endif
 If NBTMP
   # FQ83184 "Nombre d'enregistrements ÃĐcrits sur TMP :"
  Call ECR_TRACE("",GTRC_STAT,mess(73,GML_MSGTRC,1)-num$(NBTMP),0,1) From TRACEABX3
 Else
   # FQ83184 "Aucun enregistrements ÃĐcrits sur TMP"
  Call ECR_TRACE("",GTRC_STAT,mess(74,GML_MSGTRC,1),0,1) From TRACEABX3
 Endif
 If ACTGESPLN=2
  If NBTMPPLN
    # FQ83184 "Nombre d'enregistrements ÃĐcrits sur TMPPLN :"
   Call ECR_TRACE("",GTRC_STAT,mess(75,GML_MSGTRC,1)-num$(NBTMPPLN),0,1) From TRACEABX3
  Else
    # FQ83184 "Aucun enregistrements ÃĐcrits sur TMPPLN"
   Call ECR_TRACE("",GTRC_STAT,mess(76,GML_MSGTRC,1),0,1) From TRACEABX3
  Endif
 Endif
 Call ECR_TRACE("",GTRC_STAT,"",0,1) From TRACEABX3
Return

#[27]
$I_OBJ_MAJ
 Local Char I_MESSAGE(255)
 If TRPARM=9
  I_MESSAGE="-> "
  Case REFOBJ
   When "FAS" : I_MESSAGE+=mess(77,GML_MSGTRC,1) : # FQ83184 "Liste des biens comptables modifiÃĐs"
   When "LOF" : I_MESSAGE+=mess(78,GML_MSGTRC,1) : # FQ83184 "Liste des dÃĐpenses modifiÃĐes"
   When "LEA" : I_MESSAGE+=mess(79,GML_MSGTRC,1) : # FQ83184 "Liste des contrats de location financement modifiÃĐs"
   When Default
  Endcase
   # FQ83184 " (Simulation)"
  If FLGSIM=G_OUI : I_MESSAGE+=mess(80,GML_MSGTRC,1) : Endif
 Else
  Case REFOBJ
   When "FAS" : I_MESSAGE=[F:TMP1]OBJREF-"-"-[F:TMP1]AASDES1
   When "LOF" : I_MESSAGE=[F:TMP1]OBJREF+"/"+[F:TMP1]LINLOF-"-"-[F:TMP1]DES
   When "LEA" : I_MESSAGE=[F:TMP1]OBJREF-"-"-[F:TMP1]LEADES
   When Default
  Endcase
 Endif
 Call ECR_TRACE("",0,I_MESSAGE,0,1) From TRACEABX3
Return

#### Erreurs

#[60]#
$E_SPECACT
 Gosub GESTRACE From =TRTACTMAS
Return

#[79]#
$E_ONERRGO
 Local Char E_MESSAGE(255)
 # FQ83184 errmes$(errn)-"/"-num$(errn)-"s'est produite Ã  la ligne"-num$(errl)-"du traitement"-errp
 E_MESSAGE=errmes$(errn)-"/"-num$(errn)-mess(85,GML_MSGTRC,1)-num$(errl)-mess(86,GML_MSGTRC,1)-errp
 If GTRACE<>""
  Call ECR_TRACE("",0,"",0,1) From TRACEABX3
  Call ECR_TRACE("",0,E_MESSAGE,1,1) From TRACEABX3
  Call ECR_TRACE("",0,"",0,1) From TRACEABX3
 Else
  If !GSERVEUR
   Infbox (E_MESSAGE)
  Endif
 Endif
Return

