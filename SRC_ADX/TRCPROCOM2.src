#[99]#
$FERMETRACE

# Pour faire coÃĐxister les deux modÃĻles de trace standard (X3 et TRACEABX3), on teste la prÃĐsence de GSEQTRACE

# If dim(GSEQTRACE)>0
#  Call FERME_TRACE(1) From TRACEABX3 : TRA=1
# Else
#  If !GSERVEUR : Call FERME_TRACE From LECFIC : TRA=1 : Endif
# Endif

 If dim(GSEQTRACE)>0
  If !GSERVEUR
   Call FERME_TRACE(1) From TRACEABX3 : TRA=1
  Else
   Call VIDE_TRACE(1) From TRACEABX3
  Endif
 Else
  If !GSERVEUR : Call FERME_TRACE From LECFIC : TRA=1 : Endif
 Endif

Return


#################################### Traitements appelÃĐs par Gosub ou Call

$INIT_SELPARM
 Local Char    ZONDEB
 Local Char    ZONFIN
 Local Integer ZONTYP
 Local Char    ZONNAM(40)
 Local Char    MESTRACE(100)
 ZONNAM=evalue('TN_SELO'+SEL_LVL+'(TRPARM)')
 ZONDEB='[M:MHC]'+evalue('TZ_SELO'+SEL_LVL+'(TRPARM)')+'DEB'
 ZONFIN='[M:MHC]'+evalue('TZ_SELO'+SEL_LVL+'(TRPARM)')+'FIN'
 ZONTYP=evalue('TT_SELO'+SEL_LVL+'(TRPARM)')
Return

$ECR_SELPARM
 If evalue(ZONDEB+'="" & '+ZONFIN+'=""') # Les deux zones sont vides
  # FQ83184  "-> Pas de sÃĐlection sur ce critÃĻre"
  MESTRA=ZONNAM-mess(81,GML_MSGTRC,1)
 Elsif (evalue(ZONDEB+'='+ZONFIN) | (evalue(ZONFIN+'=""'))) # Les deux zones sont ÃĐgales
  Case ZONTYP
   When 1 : MESTRA=ZONNAM-"->"-evalue(ZONDEB)
   When 2 : MESTRA=ZONNAM-"->"-evalue('num$('+ZONDEB+')')
  Endcase
 Elsif evalue(ZONDEB+'<>'+ZONFIN) # Les deux zones sont diffÃĐrentes
  Case ZONTYP
   When 1 : MESTRA=ZONNAM-"->"-mess(82,GML_MSGTRC,1)-evalue(ZONDEB)-mess(83,GML_MSGTRC,1)-evalue(ZONFIN) : # FQ83184 "de" "Ã "
   When 2 : MESTRA=ZONNAM-"->"-mess(82,GML_MSGTRC,1)-evalue('num$('+ZONDEB+')')-mess(83,GML_MSGTRC,1)-evalue('num$('+ZONFIN+')') : # FQ83184 "de" "Ã "
  Endcase
 Endif
 Call ECR_TRACE("",GTRC_PARAM,MESTRA,0,1) From TRACEABX3
Return

