#[21]#
$I_SELTOU
 Case TRPARM
  When 0
   Call ECR_TRACE("",GTRC_CRITERE,"",0,1) From TRACEABX3
   #> Tableau des sociÃĐtÃĐs et des sites sÃĐlectionnÃĐs :
   Local Integer I_FCY      : Raz I_FCY
   Local Char    SAV_CPY(3) : Raz SAV_CPY
   Local Char    LIGNE(100) : Raz LIGNE
   Local Char    SEPARATEUR :     SEPARATEUR="-"
   LIGNE=string$(94,SEPARATEUR) : Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
   # FQ83184 SociÃĐtÃĐ / Raison sociale / Site / Nom
   LIGNE=" "+mess(59,GML_MSGTRC,1)+space$(3)+mess(60,GML_MSGTRC,1)+space$(24)+mess(61,GML_MSGTRC,1)+space$(5)+mess(62,GML_MSGTRC,1)
   Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
   LIGNE=string$(94,SEPARATEUR) : Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3

   #Gbn-280405-Bug nÂ°29958-Contenu du tableau en fonction de G_NOCHOI_SELALL
   If G_NOCHOI_SELALL=G_NON
    For I_FCY=1 To [M:MHC]NBFCY
     If [M:MHC]FLGFCY(I_FCY-1) = G_OUI
      If SAV_CPY<>[M:MHC]FCYCPY(I_FCY-1)
       LIGNE = space$(2)+[M:MHC]FCYCPY(I_FCY-1)+space$(max(0, 10-len([M:MHC]FCYCPY(I_FCY-1))))
&             +[M:MHC]ZCPY(find([M:MHC]FCYCPY(I_FCY-1),[M:MHC]CPY)-1)+space$(max(0, 38-len([M:MHC]ZCPY(find([M:MHC]FCYCPY(I_FCY-1),[M:MHC]CPY)-1))))
&             +[M:MHC]FCY(I_FCY-1) +space$(max(0, 9-len([M:MHC]FCY(I_FCY-1))))+[M:MHC]ZFCY(I_FCY-1)
       SAV_CPY=[M:MHC]FCYCPY(I_FCY-1)
       Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
      Else
       LIGNE = space$(50)+[M:MHC]FCY(I_FCY-1) +space$(max(0, 9-len([M:MHC]FCY(I_FCY-1))))+[M:MHC]ZFCY(I_FCY-1)
       Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
      Endif
     Endif
    Next I_FCY
   Else
    LIGNE = space$(1)+mess(444,7773,1)+space$(max(0, 48-len(mess(444,7773,1))))+mess(449,7773,1)
    Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
   Endif

   LIGNE=string$(94,SEPARATEUR) : Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3

   #> SÃĐlection ÃĐtendue :
   If [M:ASL]FLD1<>""
    Local Integer SEP_DEB
    Call ECR_TRACE("",GTRC_CRITERE,"",0,1) From TRACEABX3
    LIGNE=string$(94,SEPARATEUR) : Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
    # FQ83184 Cond. / Table / Zone / OpÃĐrateur / Valeur
    LIGNE=" "+mess(63,GML_MSGTRC,1)+space$(1)+mess(64,GML_MSGTRC,1)+space$(6)+mess(65,GML_MSGTRC,1)+space$(7)+mess(66,GML_MSGTRC,1)+space$(10)+mess(67,GML_MSGTRC,1)
    Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
    LIGNE=string$(94,SEPARATEUR) : Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
    # FQ95148
    LIGNE=space$(7)+[M:ASL]TBL1+space$(max(0, 12-len([M:ASL]TBL1)))
&                  +[M:ASL]FLD1+space$(max(0, 12-len([M:ASL]FLD1)))
&                  +mess([M:ASL]OPE1,55,1)+space$(max(0, 19-len(mess([M:ASL]OPE1,55,1))))
&                  +[M:ASL]VAL1
    Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
   Endif
   If [M:ASL]FLD2<>""
    # FQ95148
    LIGNE=space$(1)+mess([M:ASL]ANDOR2,56,1)+space$(max(0, 6-len(mess([M:ASL]ANDOR2,56,1))))
&                  +[M:ASL]TBL2+space$(max(0, 12-len([M:ASL]TBL2)))
&                  +[M:ASL]FLD2+space$(max(0, 12-len([M:ASL]FLD2)))
&                  +mess([M:ASL]OPE2,55,1)+space$(max(0, 19-len(mess([M:ASL]OPE2,55,1))))
&                  +[M:ASL]VAL2
    Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
   Endif
   If [M:ASL]FLD3<>""
    # FQ95148
    LIGNE=space$(1)+mess([M:ASL]ANDOR3,56,1)+space$(max(0, 6-len(mess([M:ASL]ANDOR3,56,1))))
&                  +[M:ASL]TBL3+space$(max(0, 12-len([M:ASL]TBL3)))
&                  +[M:ASL]FLD3+space$(max(0, 12-len([M:ASL]FLD3)))
&                  +mess([M:ASL]OPE3,55,1)+space$(max(0, 19-len(mess([M:ASL]OPE3,55,1))))
&                  +[M:ASL]VAL3
    Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
   Endif
   If [M:ASL]FLD4<>""
    # FQ95148
    LIGNE=space$(1)+mess([M:ASL]ANDOR4,56,1)+space$(max(0, 6-len(mess([M:ASL]ANDOR4,56,1))))
&                  +[M:ASL]TBL4+space$(max(0, 12-len([M:ASL]TBL4)))
&                  +[M:ASL]FLD4+space$(max(0, 12-len([M:ASL]FLD4)))
&                  +mess([M:ASL]OPE4,55,1)+space$(max(0, 19-len(mess([M:ASL]OPE4,55,1))))
&                  +[M:ASL]VAL4
    Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
   Endif
   If [M:ASL]FLD5<>""
    # FQ95148
    LIGNE=space$(1)+mess([M:ASL]ANDOR5,56,1)+space$(max(0, 6-len(mess([M:ASL]ANDOR5,56,1))))
&                  +[M:ASL]TBL5+space$(max(0, 12-len([M:ASL]TBL5)))
&                  +[M:ASL]FLD5+space$(max(0, 12-len([M:ASL]FLD5)))
&                  +mess([M:ASL]OPE5,55,1)+space$(max(0, 19-len(mess([M:ASL]OPE5,55,1))))
&                  +[M:ASL]VAL5
    Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
   Endif
   If [M:ASL]EXP1<>""
    If dim(SEP_DEB)<0 : Local Integer SEP_DEB : Endif
    LIGNE=string$(94,SEPARATEUR) : Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
    # FQ83184 Expression
    LIGNE=space$(1)+mess(84,GML_MSGTRC,1) : Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
    LIGNE=string$(94,SEPARATEUR) : Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
    LIGNE=space$(1)+[M:ASL]EXP1
    Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
   Endif
   If dim(SEP_DEB)>0
    LIGNE=string$(94,SEPARATEUR) : Call ECR_TRACE("",GTRC_CRITERE,LIGNE,0,1) From TRACEABX3
   Endif
  When Default
   Local Char SEL_LVL : SEL_LVL="TOU"
   Gosub INIT_SELPARM
   Gosub ECR_SELPARM
 Endcase
Return

