 # FQ83184 "Devise  :"
 Call ECR_TRACE(RUPTURE_CPY,GTRC_CRACTIO,mess(58,GML_MSGTRC,1)-RUPTURE_CUR-"-"-RUPTURE_CURLIB,0,1) From TRACEABX3
#Call ECR_TRACE(RUPTURE_CPY,GTRC_CRACTIO,"",0,1) From TRACEABX3
