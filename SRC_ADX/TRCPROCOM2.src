$GESTRACE

#If FLGTRC=1 : Return : Endif          # Si trace non demandÃĐe on sort # La trace est toujours demandÃĐe !!!!!
If dim(ACTSILENCE)>0
 If ACTSILENCE=G_OUI : Return : Endif  # Si l'action est lancÃĐe en mode silencieux, on ne gÃĻre pas la trace
Endif

Local Char SEPARATEUR(1)

Case TRTYP                                         #                                       TRT dans TRMaction
 When 1  : Gosub OUVRETRACE                        # Message de dÃĐbut de trace                     O

 When 2  : Gosub R_TRACE                           # Rupture Sous-partie de trace
 When 3  : Gosub R_CPY                             # Rupture sociÃĐtÃĐ
 When 4  : Gosub R_FCY                             # Rupture site
 When 5  : Gosub R_OBJET                           # Rupture objet mÃĐtier

 When 20 : Gosub I_PARAM                           # ParamÃĻtres de l'action massive                O
 When 21 : Gosub I_SELTOU                          # SÃĐlection (Zones tous objets)
 When 22 : Gosub I_SELFAS                          # SÃĐlection (Zones liÃĐes Ã  l'objet FAS)
 When 23 : Gosub I_SELLOF                          # SÃĐlection (Zones liÃĐes Ã  l'objet LOF)
 When 24 : Gosub I_SELLEA                          # SÃĐlection (Zones liÃĐes Ã  l'objet LEA)
 When 25 : Gosub I_OPTION                          # Options du traitement massif
 When 26 : Gosub I_STATS                           # Statistiques sur la population
 When 27 : Gosub I_OBJ_MAJ                         # Info sur un objet mis Ã  jour

 When 40 :
 When 41 :
 When 42 :
 When 43 :

 When 60 : Gosub E_SPECACT                         # Erreur spÃĐcifiques Ã  l'action massive
 When 61 :
 When 79 : Gosub E_ONERRGO                         # Erreur technique interceptÃĐe par onerrgo

 When 80 : SEPARATEUR="=" : Gosub SEPAR_LIGNE
 When 81 : SEPARATEUR="-" : Gosub SEPAR_LIGNE
 When 82 : SEPARATEUR="#" : Gosub SEPAR_LIGNE

 When 99 : Gosub FERMETRACE

 When Default
Endcase

Return

#### Niveau de rupture

#[2]#
$R_TRACE
 Local Char TIT_PART(100)
 Local Integer CHAPITRE
#FQ 35738 Case TRPARM
#FQ 35738  When 1 : TIT_PART="Options de l'action massive"              : CHAPITRE = GTRC_OPTION
#FQ 35738  When 2 : TIT_PART="CritÃĻres de sÃĐlection de la population"   : CHAPITRE = GTRC_CRITERE
#FQ 35738  When 3 : TIT_PART="ParamÃĻtres de l'action massive"           : CHAPITRE = GTRC_PARAM
#FQ 35738  When 4 : TIT_PART="Compte-rendu des modifications"           : CHAPITRE = GTRC_CRACTIO
#FQ 35738  When Default
#FQ 35738 Endcase
 Case TRPARM
  When 1  : TIT_PART=mess(532,7773,1)             : CHAPITRE = GTRC_OPTION
  When 2  : TIT_PART=mess(533,7773,1)             : CHAPITRE = GTRC_CRITERE
  When 3  : TIT_PART=mess(534,7773,1)             : CHAPITRE = GTRC_PARAM
  When 4  : TIT_PART=mess(535,7773,1)             : CHAPITRE = GTRC_CRACTIO
  When Default
 Endcase
 If TRPARM>1
  Call ECR_TRACE("",CHAPITRE,"",0,1) From TRACEABX3
  Call ECR_TRACE("",CHAPITRE,"######",0,1) From TRACEABX3
 Endif
 Call ECR_TRACE("",CHAPITRE,TIT_PART,0,1) From TRACEABX3
 Call ECR_TRACE("",CHAPITRE,"========================",0,1) From TRACEABX3
Return

