######################################################################################
Subprog C_NXTSEQ(VALEUR)  # 88598.sn
Variable Char    VALEUR()
Local Integer I, WCHECK
Local Char FIN

If find(GREP,"C","D") : End : Endif

If VALEUR='' : End : Endif #  allow blank next check

# 91932.sn
#If filinfo(filpath("FIL","CHQBOK","fde",""),0)>0   # 96304.o
#Issue 106660 – 2018-09-06  by VAVIL - impossible to acces the function GESBAN (add func AFNC.ACTIV("CHQ"))
If func AFNC.ACTIV("CHQ") & filinfo(filpath("FIL","CHQBOK","fde",nomap),0)>0 # 96304.n
  If clalev([F:CHB])=0  : Local File CHQBOK     [CHB]  : Endif
# 91932.en

Filter [CHB] Where [CHB]BAN=[M]BAN

For [CHB]
  FIN = func CHKLIB.CHQEND([F:CHB]CHQFIRNUM,[F:CHB]NBRCHQ)
  If instr(1,"0123456789",left$(VALEUR,1)) # Numeric check range
    If val(VALEUR) >= val([F:CHB]CHQFIRNUM) and val(VALEUR) <= val([CHB]CHQFIRNUM) + [CHB]NBRCHQ
      WCHECK=1
      Break
    Endif
  Else  # Alpha check range
  If VALEUR >= [F:CHB]CHQFIRNUM and VALEUR <= FIN  and left$([F:CHB]CHQFIRNUM,1) >= 'A'
    WCHECK=1
    Break
  Endif
  Endif
Next

If !WCHECK  # No checkbook range
  GMESSAGE = mess(161,121,1) - VALEUR : mkstat=2
Endif
F
Endif # 91932.n
End  # 88598.en



######################################################################################
# ROSCH : 80148 - Positive Pay
$S_TFB

Local Integer NBTEX
Local Char TEXTRA(250)
Raz NBTEX

TIT(0) = mess(122,124,1) : # Sélection Fichier
If clalev([F:TFB])=0 : Local File TABFILBAN [TFB] : Endif

CRITERE  = "RECTYP=2 & ORDNUM=1 & NUM=1"
For [TFB]TFB0 Where evalue (CRITERE)
 If NBTEX+1>dim(TEX)-1 : Break : Endif
 Call LECTEXTRA(TEXTRA, "TABFILBAN", "DESTRA", [F:TFB]COD, [F:TFB]BAN+"~"+[F:TFB]LEG) From ATEXTRA
 If !find(format$("K:10X",[F:TFB]COD)-TEXTRA,TEXTE(1..NBTEX))
  NBTEX +=1
  TEX(NBTEX) = [F:TFB]COD
  TEXTE(NBTEX) = format$("K:10X",[F:TFB]COD)-TEXTRA
 Endif
Next

Return

######################################################################################
# RBU : 80148 - Positive Pay
$V_TFB

If COUZON = "POSPAYFIL"
  [M:BAN3]POSPAYFIL = [F:TFB]COD
    mkstat = 4
Endif

Return
