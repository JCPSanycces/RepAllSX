######################################################################################
Funprog SET_FMT(CPY)
Value Char CPY
#Issue X3-67318 – 2018-01-08  by MADOR - mistakes on INPAYTRA/OUTPAYTRA fields in BANK table
Local Char FMT(6)

If func AFNC.PARAM("BCREG",CPY) = "2"
  FMT = "K"
Else
  FMT = "-K"
Endif

FMT += ":10X"
#Issue end
End FMT
######################################################################################
Funprog CODE_USED(BAN)
Value Char BAN

Local Integer RETVAL

If !clalev([F:BCREG]) : Local File BANKCASHREG [BCREG] : Endif

Filter [F:BCREG] Where [F:BCREG]REGCOD = BAN
Look [F:BCREG]BCREG1 First
If fstat = 0 RETVAL = 1 : Endif
Filter [F:BCREG]

End RETVAL
######################################################################################
#ISSUE END
Subprog CHANGE_FIFOCONPRO_STATE(COMPANY, BCCUR)
Variable Char COMPANY()
Variable Char BCCUR()

#Issue 47122 – 2017-09-21  by MADOR - 3.1 - Function GESBAN and GESCAI
If func AFNC.PARAM("FIFRC", [L]COMPANY) <> "2"
  Gosub HIDE_FLFFIFCP: End
Endif

If !clalev([F:CPY1])    : Local File COMPANY      [CPY1]    : Endif
If !clalev([F:GCM1])    : Local File GACM         [GCM1]    : Endif

Link [CPY1] With [GCM1]GCM0 = [F:CPY1]ACM As [GCMA]
&           Where [F:CPY1]CPY = [L]COMPANY

Read [GCMA]CPY0 First

If !fstat and [L]BCCUR <> [F:GCM1]CUR(0) and [L]BCCUR <> ""
    Chgfmt [M:BAN2]FLDSDA  With "D:" + GFMDAT
    Chgfmt [M:BAN2]FLDFIFCP  With "K:10X"
    If [M:BAN2]FLDFIFCP = 1 or [M:BAN2]FLDFIFCP = 0
        Raz [M:BAN2]FLDSDA
        Grizo [M:BAN2]FLDSDA
    Else
        Actzo [M:BAN2]FLDSDA
        Affzo [M:BAN2]FLDFIFCP
    Endif
Else
    Gosub HIDE_FLFFIFCP
Endif

LogicClose File  [CPY1]
LogicClose File  [GCM1]
#Issue end
End
