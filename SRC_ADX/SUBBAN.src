#<AdxTL>@(#)0.0.0.0 $Revision$ Compte en banque
# Issue 74384 - 2018-04-19 by MDJ : Changes to Checkbook not saved when tunneling from bank account
# CBO   25.10.2017 X3-53346 : Error authorization of FCY
#
Call OBJET("BAN",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "FILTRE"                : FILTSUP = "[F:BAN]BANCSH=1"
 When "OUVRE"                 : Gosub OUVRE
 When "LIENS"                 : Gosub LIENS
 When "VERIF_CRE","VERIF_MOD" : Gosub VERIF : Call VERIFPAYTRASEL From SUBBAN
 When "STYLE"                 : Gosub SETSTYLE
 When "FIN"                   : Gosub FIN
 When "SEL_LISTE"             : Gosub S_TFB               # ROSCH : 80148 - Positive Pay
 When "VERF_TABLE"            : Gosub V_TFB               # RBU : 80148 - Positive Pay
 When "RAZDUP"                : Gosub RAZDUP              # 94080.n
 When "RAZCRE"                : Gosub RAZCRE              # 88426 - Factoring Management
 When "AVANT_MOD"             : Gosub AVANT_MOD           # X3-53346
 When "VERF_ANU"              : Gosub VERF_ANU            # X3-53346

 Endcase
Return

### SAM 88426 Factoring Management -
$RAZCRE
#---------------------------------#
# Initialization table axes      E #
#---------------------------------#
If dim([M:BAN2]NBSEC)>0
  Call CHARG_DIE(12,"","BAN2","NBSEC") From TRTX3CPT
  Affzo [M:BAN2]
Endif

#Issue 47122 – 2017-09-21  by MADOR - 3.1 - Function GESBAN and GESCAI
If func AFNC.ACTIV("FIFRC")
    Call CHANGE_FIFOCONPRO_STATE([M:BAN2]CPY, [M:BAN2]CUR)
Endif
#Issue end
Return
### End SAM 88426

$OUVRE
If clalev([F:BAN2])=0 : Local File BANK       [BAN2] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif
If clalev([F:JOU])=0  : Local File GJOURNAL   [JOU]  : Endif
If clalev([F:JCO])=0  : Local File GJOUCOA    [JCO]  : Endif
If clalev([F:CAC])=0  : Local File GACCCODE   [CAC]  : Endif
#Issue 106660 – 2018-09-06  by VAVIL - impossible to acces the function GESBAN
If func AFNC.ACTIV("CHQ")
  If clalev([F:CHB])=0  : Local File CHQBOK     [CHB]  : Endif
Endif
#Issue end
#If clalev([F:CHB])=0  : Local File CHQBOK     [CHB]  : Endif  # 88598.n # 91932.o
If clalev([F:TFB])=0  : Local File TABFILBAN  [TFB]  : Endif  # ROSCH : 80148 - Positive Pay

If dim(GCURLEG)>0  : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If dim(GCURFCY)>0  : Local Char SAV_GCURFCY(GLONFCY) : SAV_GCURFCY = GCURFCY   : Endif
If dim(GSOCIETE)>0 : Local Char SAV_GCURCPY(GLONCPY) : SAV_GCURCPY = GSOCIETE  : Endif
If dim(GGRPFCY)>0  : Local Char SAV_GGRPFCY(GLONAGF) : SAV_GGRPFCY = GGRPFCY   : Endif

### SAM 88426 Factoring Management -
If clalev([F:CDI])=0 : Local File CADIEDEF   [CDI] : Endif
Local Integer NUMDIE
NUMDIE = 12 : # Rank in the menu 2230 (Bank)
Read [CDI]CDI0 = NUMDIE
### End SAM 88426

Return

$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG  = SAV_GCURLEG : Endif
If dim(SAV_GCURFCY)>0 : GCURFCY  = SAV_GCURFCY : Endif
If dim(SAV_GCURCPY)>0 : GSOCIETE = SAV_GCURCPY : Endif
If dim(SAV_GGRPFCY)>0 : GGRPFCY  = SAV_GGRPFCY : Endif
Return

$LIENS
Call LECMAINPLAN(1,[M]CPY,[M]COA) From CPTDIV
If [M]FCY<>""
 Call GETSOC([M]FCY) From DEVSUB
Else
 GSOCIETE = [M]CPY
 If GCURFCY=""
  I = find(GSOCIETE,GSOCSITE(1..GNBSITE))
  GCURFCY = GSITE(I)
 Endif
Endif

If [M:BAN2]BIDEXS<>"" Then
 Local Char IBACOD
 Call CRE_IBAN(IBACOD,[M:BAN1]CRY,"",[M:BAN2]BIDEXS) From SUBBID
 [M:BAN2]IBAEXS=IBACOD
Endif

If dim([M:BAN2]SCTPROLOT)>0 Then
 Actzo [M:BAN2]SCTPROLOT
 If [M:BAN2]CUR<>GCURSHR Then
  Grizo [M:BAN2]SCTPROLOT
 Endif
Endif

Gosub LIENS_BAN From CHKLIB
Read [CPY]CPY0=[M:BAN2]CPY
If !fstat
 GCURLEG = [F:CPY]LEG
Endif

# SAM 81743: visibility of BNKPROBALCTL depends on parameter PROBALCTL
Local Char P_PROBALCTL(1) : P_PROBALCTL = ""
Call PARAM(GCURLEG,"PROBALCTL",P_PROBALCTL) From ADOVAL
If P_PROBALCTL <> "2"
  Chgfmt [M:BAN2]BNKPROBALCTL With "-K:1X"
Else
  Chgfmt [M:BAN2]BNKPROBALCTL With "NA:1X"
Endif
Affzo [M:BAN2]BNKPROBALCTL

# SAM 111165 visibility of BANFIL depends on parameter PORRBK
If func AFNC.ACTIV("KPO")>0
  Call HANDLE_BANFIL([M:BAN2]CPY)
Endif


# SAM 110033: visibility of BVRNUM and BVRCUSTID depends on parameter SWICUSBVR (Swiss localization)
If func AFNC.ACTIV("KSW")>0
  Call HANDLE_BVR([M:BAN2]CPY)
Endif

###  - SAM 88426 - Factoring management
## Loading analytical sections

If dim([M:BAN2]DIE)<1 : Return : Endif

Raz [M:BAN2]DIE
Raz [M:BAN2]CCE
[M:BAN2]NBSEC = [F:CDI]NBRDIE
For I=0 To [F:CDI]NBRDIE-1
 [M:BAN2]DIE(I) = [F:CDI]DIE(I)
 For J=0 To dim([F:BAN]DIE)-1
  If [F:BAN]DIE(J)=[F:CDI]DIE(I)
   [M:BAN2]CCE(I) = [F:BAN]CCE(J)
   Break
  Endif
 Next J
Next I
### End SAM 88426

####### SAM # 85794-4 Implement field PORBANCOD angre 13.07.2015 ###########
Call SETPORBANCOD([M:BAN1]BIDNUM, [M:BAN1]CRY)

#ISSUE 33455 – 2017-05-18  By MANOW/MRDAB
If func AFNC.ACTIV("REGBC")
  Call REFBANKPAYTRA([M:BAN2]CPY, [M:BAN0]BAN) From SUBBAN
Endif
#ISSUE END
#Issue 47122 – 2017-09-21  by MADOR - 3.1 - Function GESBAN and GESCAI
If func AFNC.ACTIV("FIFRC")
    Call CHANGE_FIFOCONPRO_STATE([M:BAN2]CPY, [M:BAN2]CUR)
Endif
#Issue End
Return

$AVANT_MOD
# X3-53346
# Contrôle accés à la fonction
Call ACCES_POINTAGE(GOK,[M:BAN0]BAN) From SUBCHK
If !GOK
 # Vous n'avez pas accés à la banque
 GMESSAGE = mess(25,120,1) - [M:BAN0]BAN
 GERR = 1 : OK=0 : Return
Endif
Return

$VERF_ANU
# X3-53346
# Contrôle accés à la fonction
Call ACCES_POINTAGE(GOK,[M:BAN0]BAN) From SUBCHK
If !GOK
 # Vous n'avez pas accés à la banque
 GMESSAGE = mess(25,120,1) - [M:BAN0]BAN
 GERR = 1 : OK=0 : Return
Endif
Return


$VERIF
If !find(1,[M]JOUTYP(0..[M]NBRJOU-1))
 # Le journal de banque doit être saisi
 GMESSAGE=mess(8,117,1)
 OK=0
Endif
# 94080.sn
#If filinfo(filpath("FIL","CHQBOK","fde",""),0)>0   # 96304.o
#Issue 106660 – 2018-09-06  by VAVIL - impossible to acces the function GESBAN (add func AFNC.ACTIV("CHQ"))
If func AFNC.ACTIV("CHQ") & filinfo(filpath("FIL","CHQBOK","fde",nomap),0)>0 # 96304.n
If clalev([F:CHB])=0  : Local File CHQBOK     [CHB]  : Endif
  Look [F:CHB]CHB0=[M:BAN0]BAN
  If fstat and dim([M:BAN3]NXTSEQ) > 0 and [M:BAN3]NXTSEQ<> ''
    GMESSAGE = mess(161,121,1) - [M:BAN3]NXTSEQ
    OK=0
  Endif
Endif
# 94080.en
Return

$SETSTYLE
# DFY - error on Chgstl [M]NBRJOU(I)
For I=0 To [M:BAN2]NBRJOU-1
 If mess([M:BAN2]JOUTYP(I),660,1)="Banque"
  Chgstl [M:BAN2]NBRJOU(I) With "BANLIN"
 Else
  Chgstl [M:BAN2]NBRJOU(I) With "NORMAL"
 Endif
Next
Return

# 94080.sn
$RAZDUP
 If func AFNC.ACTIV("CHQMG")>0
    Raz [M:BAN3]NXTSEQ
    Affzo [M:BAN3]NXTSEQ
  Endif
Return
# 94080.en
###########################################
## Etiquette des écrans BAN0, BAN1, BAN2 ##
###########################################


Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If VALEUR="" & [M]CPY<>""
 Call CONTALLFCY([M]CPY) From CPTSUB
Endif
End

Subprog AP_FCY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
Call LECMAINPLAN(1,[F:FCY]LEGCPY,[M]COA) From CPTDIV
If VALEUR<>"" : Call GETSOC(VALEUR) From DEVSUB : Endif
End

Subprog AM_FCY(VALEUR)
Variable Char     VALEUR
#Issue X3-67318 – 2018-01-08  by MADOR - mistakes on INPAYTRA/OUTPAYTRA fields in BANK table
If GFONCTION<>"GESCAI"
    [M]CPY = ""
Endif
If func AFNC.ACTIV("REGBC")
    Gosub EFFZO_PAY_TRA
Endif
#Issue end
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]FCY<>""
 VALEUR = [F:FCY]LEGCPY
 mkstat = 2
 If GFONCTION<>"GESCAI"
  Call BAN_AM_CPY(VALEUR) From CHKLIB
 Endif
Else
 Call CONTACCCFY(VALEUR,"") From CFYSUB : # Accès refusé si pas accès à tous les sites de la société
Endif
End

Subprog AP_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer I
Call LECMAINPLAN(1,VALEUR,[M]COA) From CPTDIV
GCURLEG = [F:CPY]LEG
GSOCIETE = VALEUR
I = find(GSOCIETE,GSOCSITE(1..GNBSITE))
GCURFCY = GSITE(I)
End

Subprog C_CPY(VALEUR)
Variable Char     VALEUR

#ISSUE 33455 – 2017-06-09  By MANOW/MRDAB
If (GFONCTION = "GESBAN")
  If [M]FCY = "" # X3-53346
    Call CONTALLFCY(VALEUR) From CPTSUB
  Endif
Endif

If func AFNC.ACTIV("REGBC")
  If(GFONCTION = "GESCAI")
    Call REFCASHPAYTRA(VALEUR, [M:CAI1]BAN) From SUBBAN
  Elsif(GFONCTION = "GESBAN")
    Call REFBANKPAYTRA(VALEUR, [M:BAN0]BAN) From SUBBAN
  Endif
Endif
#ISSUE END
End

Subprog AM_CPY(VALEUR)
Variable Char     VALEUR

If GFONCTION<>"GESCAI"
  Call BAN_AM_CPY(VALEUR) From CHKLIB
  # SAM 81743: visibility of BNKPROBALCTL depends on parameter PROBALCTL
  Read [CPY]CPY0 = VALEUR
  Local Char P_PROBALCTL(1) : P_PROBALCTL = ""
  Call PARAM([CPY]LEG,"PROBALCTL",P_PROBALCTL) From ADOVAL
  If P_PROBALCTL <> "2"
    Chgfmt [M:BAN2]BNKPROBALCTL With "-K:1X"
  Else
    Chgfmt [M:BAN2]BNKPROBALCTL With "NA:1X"
  Endif
  Affzo [M:BAN2]BNKPROBALCTL

  # SAM 111165 visibility of BANFIL depends on parameter PORRBK
  If func AFNC.ACTIV("KPO")>0
    Call HANDLE_BANFIL(VALEUR)
  Endif

  # SAM 110033: visibility of BVRNUM and BVRCUSTID depends on parameter SWICUSBVR (Swiss localization)
  If func AFNC.ACTIV("KSW")>0
    Call HANDLE_BVR(VALEUR)
  Endif
Endif
#Issue 47122 – 2017-09-21  by MADOR - 3.1 - Function GESBAN and GESCAI
If func AFNC.ACTIV("FIFRC")
  If GFONCTION = "GESBAN"
    Call CHANGE_FIFOCONPRO_STATE(VALEUR, [M:BAN2]CUR)
  Elsif GFONCTION = "GESCAI"
    Call CHANGE_FIFOCONPRO_STATE(VALEUR, [M:CAI1]CUR) From SUBCAI
  Endif
Endif
#Issue End
#Issue X3-67318 – 2018-01-08  by MADOR - mistakes on INPAYTRA/OUTPAYTRA fields in BANK table
If func AFNC.ACTIV("REGBC")
  Gosub EFFZO_PAY_TRA
Endif
#Issue end
End

Subprog HANDLE_BVR(CPY)
Value Char CPY
# SAM 110033: visibility of BVRNUM and BVRCUSTID depends on parameter SWICUSBVR (Swiss localization)
Local Char P_SWICUSBVR(1) : P_SWICUSBVR = ""
Call PARAM(CPY,"SWICUSBVR",P_SWICUSBVR) From ADOVAL
If P_SWICUSBVR <> "2"
  Chgfmt [M:BAN2]BVRNUM With "-K:11X"
  Chgfmt [M:BAN2]BVRCUSTID With "-K:12X"
Else
  Chgfmt [M:BAN2]BVRNUM With "K:11X"
  Chgfmt [M:BAN2]BVRCUSTID With "K:12X"
Endif
Affzo [M:BAN2]BVRNUM
Affzo [M:BAN2]BVRCUSTID
End

Subprog C_NBRJOU
Gosub SETSTYLE
End

Subprog C_JOUTYP(VALEUR)
Variable Integer  VALEUR
Call UNICITE(VALEUR,[M]JOUTYP(0..[M]NBRJOU-1)) From OBJDIV
End

Subprog C_JOU(VALEUR)
Variable Char     VALEUR
Call LEC_JOU_LEG(GCURLEG,VALEUR) From CPTLEC
If !find([F:JOU]TYP,3,4,5,6)
 # Saisir un journal de trésorerie ou d'opérations diverses
 GMESSAGE = mess(7,117,1)
 mkstat = 1 : End
Endif
If [F:JOU]TYP=3
 Call LECMAINPLAN(1,[M]CPY,[M]COA) From CPTDIV
 If clalev([F:JCO])=0 : Local File GJOUCOA  [JCO]  : Endif
 Call LEC_JCO_LEG(GCURLEG,[M]COA,VALEUR) From CPTLEC
 If fstat | [F:JCO]ACC=""
  # Journal non défini pour le plan
  GMESSAGE = mess(151,121,1)-[M]COA
  mkstat = 2 : End
 Endif
Endif
Call VERIF([F:JOU]FCY,GCURFCY,[F:JOU]JOU) From CFYSUB
If mkstat : End : Endif
End

Subprog C_GTE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LEC_JOU_LEG(GCURLEG,[M:BAN2]JOU(nolign-1)) From CPTLEC
 If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
  # Journal non autorisé sur ce type de pièce
  GMESSAGE = [F:JOU]JOU-":"-mess(8,106,1)-VALEUR
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_TREACC(VALEUR)
Variable Char    VALEUR()
If clalev([F:JOU])=0 : Local File GJOURNAL   [JOU] : Endif
If clalev([F:JCO])=0 : Local File GJOUCOA  [JCO]  : Endif
Call LEC_JOU_LEG(GCURLEG,[M:BAN2]JOU(nolign-1)) From CPTLEC
If [F:JOU]TYP=3
 Call LEC_JCO_LEG(GCURLEG,[M]COA,[M:BAN2]JOU(nolign-1)) From CPTLEC
 If !fstat & [F:JCO]ACC<>""
  VALEUR = [F:JCO]ACC
 Endif
 If [M]JOUTYP(nolign-1)=1 : # Journal de banque=>Affectation de BANACC
  [M]BANACC=VALEUR
 Endif
 mkstat = 2 : End
Endif
End

Subprog C_TREACC(VALEUR)
Variable Char    VALEUR()
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Read [GAC]GAC0 = [M:BAN2]COA ; VALEUR
If fstat
 # Compte inexistant
 GMESSAGE = mess(38,106,1)
 mkstat = 2 : End
Endif
If [M]JOUTYP(nolign-1)=1 : # Journal de banque=>Affectation de BANACC
 [M]BANACC=VALEUR
Endif
End

Subprog AS_BANACC(VALEUR)
Variable Char    VALEUR()
Local Integer K
K = find(1,[M]JOUTYP(0..[M]NBRJOU-1))
If K=0 : End : Endif
If [F:JOU]TYP = 3
 Call LEC_JCO_LEG(GCURLEG,[M]COA,[M]JOU(K-1)) From CPTLEC
 If !fstat & [F:JCO]ACC<>""
  VALEUR = [F:JCO]ACC
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_BANBPR(VALEUR)
Variable Char     VALEUR
# Bug 14281 (CP : 22/05/02) : Code Tiers obligatoire si compte collectif
If [M]BANACC<>""
 Call LECTURE("GAC",[M]BANACC,[M]COA) From CONTOBJ
 If [F:GAC]SAC = 2 & VALEUR=""
  # Zone obligatoire
  GMESSAGE = mess(10,123,1)
  mkstat = 1 : End
 Endif
 If VALEUR<>[M]BANBPR
  If clalev([F:DAE])=0 : Local File GACCENTRYD   [DAE] : Endif
  Call SETMAINREF([M]CPY,GTYPGEN,GTYPANA) From CPTDIV
  Filter [F:DAE] Where LEDTYP=GTYPGEN & CPY=[M]CPY & ACC=[M]BANACC & BPR=[M]BANBPR
  Read [DAE]DAE3 First
  Filter [DAE]
  If !fstat
   # Modification impossible
   GMESSAGE = mess(9,123,1)
   mkstat = 1 : End
  Endif
 Endif
Endif
If VALEUR<>"" & [F:BPR]BPRACC<>2
 # Ce n'est pas un tiers compte
 GMESSAGE = mess(3,117,1)
 mkstat = 1 : End
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char     VALEUR
If [M]BANACC<>""
 Call LECTURE("GAC",[M]BANACC,[M]COA) From CONTOBJ
 If [F:GAC]CUR<>""
  VALEUR = [F:GAC]CUR
 Else
  Local Char CODLED(GLONLED), DEVLED(GLONCUR)
  Call SETMAINREF([M]CPY,GTYPGEN,GTYPANA) From CPTDIV
  Call LECLED([M]CPY,GTYPGEN,CODLED,DEVLED) From CPTDIV
  VALEUR = DEVLED
 Endif

 #Issue 47122 – 2017-09-21  by MADOR - 3.1 - Function GESBAN and GESCAI
 If func AFNC.ACTIV("FIFRC")
   If GFONCTION = "GESCAI"
      Call CHANGE_FIFOCONPRO_STATE([M:CAI1]CPY, VALEUR) From SUBCAI
   Elsif GFONCTION = "GESBAN"
      Call CHANGE_FIFOCONPRO_STATE([M:BAN2]CPY, VALEUR)
   Endif
 Endif
 #Issue end
 mkstat = 2
Endif

  # MABON - FQ56469 - 15/09/09
  If dim([M:BAN2]SCTPROLOT)>0 Then
    If VALEUR=GCURSHR Then
      Actzo [M:BAN2]SCTPROLOT
    Else
      Grizo [M:BAN2]SCTPROLOT
    Endif
  Endif
End

Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()

#Issue 47122 – 2017-09-21  by MADOR - 3.1 - Function GESBAN and GESCAI
If func AFNC.ACTIV("FIFRC")
    If GFONCTION = "GESBAN"
        Call CHANGE_FIFOCONPRO_STATE([M:BAN2]CPY, VALEUR)
    Elsif GFONCTION = "GESCAI"
        Call CHANGE_FIFOCONPRO_STATE([M:CAI1], VALEUR) From SUBCAI
    Endif
Endif
#Issue End
End

Subprog AS_CHGTYP(VALEUR)
Variable Integer  VALEUR
Local Char CODLED(GLONLED), DEVLED(GLONCUR)
Call SETMAINREF([M]CPY,GTYPGEN,GTYPANA) From CPTDIV
Call LECLED([M]CPY,GTYPGEN,CODLED,DEVLED) From CPTDIV
If [M]CUR = DEVLED
 mkstat = 1 : End
Endif
End

Subprog AM_BAN(VALEUR)
Variable Char    VALEUR()
Read [BAN2]BAN0=VALEUR
If fstat=0 & [F:BAN2]BANCSH=2
 # Caisse
 GMESSAGE = mess(2,653,1)
 mkstat = 2 : End
Endif
If GREP='D' : Gosub RAZDUP : Endif  # 94080.n
End

Subprog AS_CHGDAT(VALEUR)
Variable Date    VALEUR
If [F:BAN]OLDCUR=""
 mkstat = 1 : End
Endif
End

Subprog C_CHGDAT(VALEUR)
Variable Date    VALEUR
Local Integer K
If VALEUR=[0/0/0] : End : Endif
If [M]OLDCUR<>""
 If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
 Call SETMAINREF([M]CPY,GTYPGEN,GTYPANA) From CPTDIV
 Filter [DAE] Where LEDTYP=GTYPGEN & ACC=[M]BANACC & CUR=[M]OLDCUR & ACCDAT>=VALEUR
 Look [DAE]DAE3 First
 If !fstat
  K = instr(1,mess(105,105,1),"*")
  If K
   #--- Il existe des opérations en [M]OLDCUR postérieures à cette date
   GMESSAGE = left$(mess(105,105,1),K-1) + [M]OLDCUR + right$(mess(105,105,1),K+1)
  Endif
  mkstat=2
 Endif
 Filter [DAE]
Endif
End

Subprog AS_IBACOD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]BIDNUM<>"" & [M]CRY<>""
 Call CRE_IBAN(VALEUR,[M]CRY,"",[M]BIDNUM) From SUBBID
Endif
End

Subprog C_IBACOD(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
If VALEUR<>""
# Call C_IBACOD(VALEUR) From SUBBID  #DdM30596
Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran BAN1) 20/03/2007 10:49:17 (CP)
######################################################################################
Subprog C_TRECOD(VALEUR)
Variable Char    VALEUR()
If !GIMPORT & func AFNC.ACTIV("CASIN")
 Local Integer OK
 If VALEUR=""
  # Pas de code interface : XXX Banque san suivi de trésorerie.
  Call AVERTIR(mess(1,173,1)-":"-[M:BAN0]BAN-mess(2,173,1),OK) From GESECRAN
  If OK<>2 : mkstat=2 : Endif
 Else
  If !clalev([BA1]) : Local File BANK [BA1] : Endif
  Filter [BA1] Where BAN<>[M:BAN0]BAN & TRECOD=VALEUR
  Read First
  If !fstat
   # Code interface tréso déjà utilisé
   Call AVERTIR(mess(12,173,1)-":"-[F:BA1]BAN,OK) From GESECRAN
   If OK<>2 : mkstat=2 : Endif
  Endif
 Endif
Endif
End

# MABON - FQ57657 - 11/09/09
Subprog AM_BIDEXS(VALEUR)
Variable Char    VALEUR()
Local    Char IBACOD

  Call CRE_IBAN(IBACOD,[M:BAN1]CRY,"",VALEUR) From SUBBID
  [M:BAN2]IBAEXS=IBACOD
  Affzo [M:BAN2]IBAEXS

  If [M:BAN2]CUREXS="" Then
    [M:BAN2]CUREXS=[M:BAN2]CUR
    Affzo [M:BAN2]CUREXS
  Endif
End

