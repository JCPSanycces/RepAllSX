Subprog AS_CHK_BTN(VALEUR)
Variable Char    VALEUR()

  # No access to checkbook if the bank is not yet created
  If GREP="C" or GREP="D"
    mkstat = 2
    End
  Endif

End
######################################################################################
# ROSCH : 80148 - Positive Pay
Subprog C_POSPAYFIL(VALEUR)
Variable Char VALEUR()

While VALEUR <> ""
  If GCURLEG<>""
    Filter [TFB] Where COD=VALEUR and (LEG=GCURLEG | LEG="")
    Read [TFB]TFB0 First
    Filter [TFB]
    If fstat
      Filter [TFB] Where COD=VALEUR
      Read [TFB]TFB0 First
      Filter [TFB]
      If !fstat
        # Fiche inexistante pour la législation courante
        GMESSAGE = VALEUR-":"-mess(232,107,1)-"["+GCURLEG+"]"
        mkstat = 2 : Break
      Else
       # Fiche inexistante
        GMESSAGE = VALEUR-":"-mess(23,100,1)
        mkstat = 2 : Break
      Endif
    Endif
  Else
    Filter [TFB] Where COD=VALEUR
    Read [TFB]TFB0 First
    Filter [TFB]
    If fstat
      # Fiche inexistante
      GMESSAGE = VALEUR-":"-mess(23,100,1)
      mkstat = 2 : Break
    Endif
  Endif
  Break
Wend

End
