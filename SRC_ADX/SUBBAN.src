## Section automatically added (screen BAN2) 10/26/2017 15:14:50 (VAVIL)
######################################################################################
Subprog C_FLDSDA(VALEUR)
Variable Date    VALEUR

Local Decimal EXERCICE , PERIODE
Local Libelle MAINGENLED, MAINANALED

If clalev([F:PER])=0 : Local File PERIOD  [PER] : Endif

Call SETMAINREF([M]CPY,[L]MAINGENLED,[L]MAINANALED) From CPTDIV

Call GETPERSOC([M]CPY,[L]MAINGENLED,VALEUR,EXERCICE,PERIODE) From CPTSUB

If VALEUR <> [00/00/00]
  Read [F:PER]PER0 = [M]CPY;[L]MAINGENLED;EXERCICE;PERIODE
  If !fstat
    If VALEUR <> [F:PER]PERSTR
      Call ECR_TRACE(mess(8,7708,1),1)  From GESECRAN
      mkstat = 2
    Endif
  Else
    Call ECR_TRACE(mess(11,47,1)-mess(40,9016,1)+".",1)  From GESECRAN
    mkstat = 2
  Endif
Endif

End
######################################################################################
$EFFZO_PAY_TRA
#Issue X3-67318 – 2018-01-08  by MADOR - mistakes on INPAYTRA/OUTPAYTRA fields in BANK table
If(GFONCTION = "GESCAI")
    Effzo [M:CAI1]INPAYTRA
    Effzo [M:CAI1]OUTPAYTRA
Elsif(GFONCTION = "GESBAN")
    Effzo [M:BAN2]INPAYTRA
    Effzo [M:BAN2]OUTPAYTRA
Endif
#Issue end
Return
