####### SAM # 85794-4 Implement field PORBANCOD angre 13.07.2015 ###########
Subprog SETPORBANCOD(BIDNUM,COUNTRY)
Variable Char BIDNUM
Variable Char COUNTRY
  If clalev([F:ABN])=0 : Local File ABANK       [ABN] : Endif
  If dim( [F:ABN]PORBANCOD ) > 0 and dim([M:BAN1]PORBANCOD) > 0
    Read [ABN]ABN0 = COUNTRY; left$( BIDNUM, 4 )
    If !fstat
      [M:BAN1]PORBANCOD = [F:ABN]PORBANCOD
    Else
      [M:BAN1]PORBANCOD = ""
    Endif
     Affzo [M:BAN1]PORBANCOD
  Endif
End



######################################################################################

####### SAM # 110033 Swiss localization: init field BVRNUM with post account for post bank, 05.11.2015 Bader ###########
Subprog AS_BVRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]BIDNUM<>""
   Call SETBVRNUM([M]BIDNUM,VALEUR)
Endif
End


####### SAM # 110033 Swiss localization: init field BVRNUM with post account for post bank, 05.11.2015 Bader ###########
Subprog SETBVRNUM(BIDNUM, ACCOUNT)
Variable Char BIDNUM
Variable Char ACCOUNT
If dim([M:BAN2]BVRNUM) > 0 & BIDNUM<>""
   Local Char NUMCLEAR(GLONBID)
   NUMCLEAR = func SWILIB0.STRIP_ZEROS(left$(BIDNUM,5))    # delete leading zeros from clearing number
   If (NUMCLEAR = "9000") and len(BIDNUM) >= 14  Then      # post finance account
      ACCOUNT = func SWILIB0.STRIP_ZEROS(right$(BIDNUM,6)) # get account from BIDNUM and strip leading zeros
      ACCOUNT = "0" + ACCOUNT                              # add one leading zero
      ACCOUNT = left$(ACCOUNT,2) + "-" + mid$(ACCOUNT,3,6) + "-" + right$(ACCOUNT,9)
   Endif
Endif
End

#** #####################################################################################
#*
#* Issue 41678
#* Function:  ISNUMERIC
#* Purpose:   Check if NUMBER consists only of numerical characters ( "0", "1", ... "9" )
#*            ISNUMERIC returns 1 for success and 0 for failure.
#*
#*! #####################################################################################
Funprog ISNUMERIC(NUMFLD, PSIZE)
Value Char NUMFLD()
Value Integer PSIZE

    Local Integer I
    # Check if NUMBER consists only of numerical characters.
    For I = 1 To PSIZE
        If ( mid$( NUMFLD, I, 1) < "0" ) or ( mid$( NUMFLD, I, 1) > "9" )
            # Nonnumerical character found.
            End 0
        Endif
    Next
End 1


######################################################################################
Subprog C_ABANUM(VALEUR)
Variable Char    VALEUR()
  # Issue 41678
  If (VALEUR <> "") Then
    Local Integer LSIZE : LSIZE = 9
    If func ISNUMERIC(VALEUR, LSIZE) = [V]CST_AFALSE
      GMESSAGE = mess(209,121,1)
      mkstat = 1 : End
    Endif
  Endif
End


Subprog HANDLE_BANFIL(CPY)
# Init SAM 111165  To check the PORRBK Company value and hide or display the "bank file" field
Local Char WRBK(3), FMT (5)
Call PARAM(CPY,"PORRBK",WRBK) From ADOVAL
If val(WRBK)=2 :FMT= "K:10": Else:  FMT= "-K:10":  Endif
Chgfmt [M:BAN2]BANFIL With FMT
Actzo [M:BAN2]BANFIL
# End SAM 111165
End

#ISSUE 33455 – 2017-05-17  By MANOW
Subprog C_INPAYTRA(VALEUR)
Variable Char    VALEUR()
Call AMPAYTRA(VALEUR, 2) From SUBBAN
End

Subprog C_OUTPAYTRA(VALEUR)
Variable Char    VALEUR()
Call AMPAYTRA(VALEUR, 1) From SUBBAN
End


Subprog AMPAYTRA(VALEUR, INOUT)
Value Char VALEUR()
Value Char MESSAGE
Value Tinyint INOUT
Variable Integer CASHORBANK : CASHORBANK=0

If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif

Case GFONCTION
  When "GESCAI"
    CASHORBANK=2
  When "GESBAN"
    CASHORBANK=1
Endcase

If (INOUT = 2)
  If (VALEUR <> "")
    For [TPY] Where [TPY]PAYTYP=VALEUR and [TPY]LEG=GCURLEG and [TPY]BANCSH=CASHORBANK and [TPY]SNS=INOUT and [TPY]ENAFLG = 2 and [TPY]DACREGNUM = 2
      mkstat=0
      End
    Next
    Call ERRTIT(mess(32,126,1)+' "'+mess(7,7702,1)+'"', mess(7,7702,1)+" "+ mess(368,177,1)) From GESECRAN
    mkstat=2
  Endif
Elsif (INOUT = 1)
  If (VALEUR <> "")
    For [TPY] Where [TPY]PAYTYP=VALEUR and [TPY]LEG=GCURLEG and [TPY]BANCSH=CASHORBANK and [TPY]SNS=INOUT and [TPY]ENAFLG = 2 and [TPY]DACREGNUM = 2
      mkstat=0
      End
    Next
    Call ERRTIT(mess(32,126,1)+' "'+mess(8,7702,1)+'"', mess(8,7702,1)+" "+ mess(368,177,1)) From GESECRAN
    mkstat=2
  Endif
Endif
End

Subprog VERIFPAYTRASEL
  If dim([M:BAN2]FLDSDA) > 0 and varmode([M:BAN2]FLDSDA) <> 3 and
&    [M:BAN2]FLDSDA = [00/00/0000] and  [M:BAN2]FLDFIFCP = 2
    GMESSAGE = mess(197,193,1)
    mkstat = 1 : End
  Endif
  If dim([M:CAI1]FLDSDA) > 0 and varmode([M:CAI1]FLDSDA) <> 3 and
&    [M:CAI1]FLDSDA = [00/00/0000] and  [M:CAI1]FLDFIFCP = 2
    GMESSAGE = mess(197,193,1)
    mkstat = 1 : End
  Endif
  If dim([M]INPAYTRA) > 0 and !(([M]INPAYTRA <> "" and [M]OUTPAYTRA <> "") or
&                               ([M]INPAYTRA = "" and [M]OUTPAYTRA = ""))
    If ([M]INPAYTRA = "")
      GMESSAGE=mess(18,7702,1)
    Elsif ([M]OUTPAYTRA = "")
      GMESSAGE=mess(19,7702,1)
    Endif
    GERROR=1
  Endif
End
#ISSUE END

#ISSUE 33455 – 2017-06-09  By MANOW
Subprog REFBANKPAYTRA(CPY, BAN)
Value Char CPY
Value Char BAN

Local Char FMT(6)
#Issue X3-67318 – 2018-01-08  by MADOR - mistakes on INPAYTRA/OUTPAYTRA fields in BANK table
FMT = func SUBBAN.SET_FMT(CPY)
#Issue end

Chgfmt [M:BAN2]INPAYTRA  With FMT
Chgfmt [M:BAN2]OUTPAYTRA With FMT
Chgfmt [M:BAN2]BAK11     With FMT
Chgfmt [M:BAN2]BAK12     With FMT
Chgfmt [M:BAN2]BAK13     With FMT
Chgfmt [M:BAN2]BAK14     With FMT

#Issue X3-67318 – 2018-01-08  by MADOR - mistakes on INPAYTRA/OUTPAYTRA fields in BANK table
If func SUBBAN.CODE_USED(BAN)
    Grizo [M:BAN2]FCY
    Grizo [M:BAN2]CPY
    Grizo [M:BAN2]INPAYTRA
    Grizo [M:BAN2]OUTPAYTRA
    Grizo [M:BAN2]BAK11
    Grizo [M:BAN2]BAK12
    Grizo [M:BAN2]BAK13
    Grizo [M:BAN2]BAK14
Else
    Actzo [M:BAN2]FCY
    Actzo [M:BAN2]CPY
    Actzo [M:BAN2]INPAYTRA
    Actzo [M:BAN2]OUTPAYTRA
    Actzo [M:BAN2]BAK11
    Actzo [M:BAN2]BAK12
    Actzo [M:BAN2]BAK13
    Actzo [M:BAN2]BAK14
Endif
#Issue end
End

