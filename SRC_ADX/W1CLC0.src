Subprog D_DESCLA(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESCLA,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"CLACTR","DESCLA",[M]CODCLA,[M]LEG) From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_DESCLA(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_DESCLA(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DESCLA(zc) From W1CLC0
Gosub _AFF
End

Subprog C_DESCLA(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DESCLA" : GZNUM = 8 : Endif
Gosub _AFF
End

Subprog B1_DESCLA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DESCLA" : PROGSUB = "SUBHRCLC" : PROGSPE = "SPECLC0" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "CLACTR"
 PARMSK(2) = "DESCLA"
 PARMSK(3) = [M]CODCLA
 PARMSK(4) = [M]LEG
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_DESCLA" : PROGSUB = "SUBHRCLC" : PROGSPE = "SPECLC0" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_NOLIB
Return

