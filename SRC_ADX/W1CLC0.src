Subprog AS_CDNCLA(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1484,GBOUT1) From OBJDIV
Call TEXTE(27108,GBOUT2) From OBJDIV
Call TEXTE(29795,GBOUT3) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
If !GWEBSERV
 ## Action AFRIB
 Call IB_FORMULE From AFORMULE
 If mkstat=2
  [M]CDNCLA(INDIC) = VALEUR
  Affzo CDNCLA(INDIC) : mkstat = 2
 Endif
Endif
Onkey 129 Titled GBOUT1 Call B1_CDNCLA(zc) From W1CLC0
Onkey 130 Titled GBOUT2 Call B2_CDNCLA(zc) From W1CLC0
Onkey 131 Titled GBOUT3 Call B3_CDNCLA(zc) From W1CLC0
Onkey   2 Titled GBOUTS Call S_CDNCLA(zc) From W1CLC0
Gosub _AFF
End

Subprog C_CDNCLA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRCONT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFRCONT"
 PARMSK(1) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFRCONT","AFORMULE","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CDNCLA" : GZNUM = 1028 : Endif
Endif
Gosub _AFF
End

Subprog S_CDNCLA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMPLO
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMPLO"
 Call SAISIE_CHAR(VALEUR,PARMSK,"SELEMP","SELEMP","XWSELEMP") From GSAISIE
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CDNCLA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRB1
 Call B1_FORMULE(VALEUR,GEMPTAB(1),GEMPTAB(2),GEMPTAB(3),GEMPTAB(4),GEMPTAB(5)) From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
