Subprog S_DOCCLAA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]NOLIB)
 PARMSK(3) = "20"
 PARMSK(4) = [M]VALINT(nolign-1)
 PARMSK(5) = [M]VALPAR(nolign-1)
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINT(nolign-1) = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]NOLIB)
 PARMSK(3) = "20"
 PARMSK(4) = [M]VALINT(nolign-1)
 PARMSK(5) = [M]VALPAR(nolign-1)
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINT(nolign-1) = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_DOCCLAA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call B1_DOCCLAA(VALEUR) From SUBHRCLC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
