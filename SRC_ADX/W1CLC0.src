#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CLC0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:08"
A_USER  = "DOC"
A_STAMP = "20181109230308"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRDOC"
  If [M]NBRDOC=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CLC0 [CLC0]
Gosub HORODAT
Local Inpbox "CLC0" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLC0] As [SIM_]
Grizo [CLC0]5
Grizo [CLC0]15
Grizo [CLC0]10
Grizo [CLC0]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CLC0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=92 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=92 : Y1(1)=11 : Y2(1)=15
X1(2)=1 : X2(2)=92 : Y1(2)=4 : Y2(2)=10
X1(3)=1 : X2(3)=92 : Y1(3)=16 : Y2(3)=28
Return

$ON_CODCLA
Onevent CONTROL Call C_CODCLA(zc) From W1CLC0
Onevent BEFORE_INPUT Call AS_CODCLA(zc) From W1CLC0
Onevent AFTER_CHANGE Gosub AMM_CODCLA From W1CLC0
Return

Subprog AS_CODCLA(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45815,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CODCLA(zc) From W1CLC0
Onkey   2 Titled GBOUTS Call S_CODCLA(zc) From W1CLC0
Onkey 144 Titled GBOUTP Call P_CODCLA(zc) From W1CLC0
Onkey 146 Titled GBOUTA Call SA_CODCLA(zc) From W1CLC0
Gosub _AFF
End

Subprog C_CODCLA(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CODCLA" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTHRCLC
 Call CONTHRCLC(VALEUR,GCURLEG,GSOCIETE) From SUBHRCLC
 If mkstat : GERR = 1 : GZONE = "CODCLA" : GZNUM = 5296 : Endif
 If !mkstat
  ## Action CONTOBJW
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARMSK(1) = "HRCLC"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODCLA" : GZNUM = 5296 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CODCLA
Call AM_CODCLA(zc)
If !mkstat & GOBJET
 zoncou = "CODCLA" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CODCLA(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCODCLA)")>indice
 [M]CODCLA(indice) = VALEUR
 Affzo ZCODCLA(indice)
Endif
Gosub _AFF
End

Subprog S_CODCLA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRCLC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRCLC"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRCLC","SUBHRCLC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CODCLA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRCLC
 Call TUNHRCLC(VALEUR,GCURLEG,GSOCIETE) From SUBHRCLC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_CODCLA(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRCLC"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CODCLA(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRCLC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCODCLA
Onevent BEFORE_AREA Gosub AV_ZCODCLA From W1CLC0
Return

$AV_ZCODCLA
Call LECTEXTRA(zc,"CLACTR","DESCLA",num$([M]CODCLA(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1CLC0
Onevent CONTROL Call C_LEG(zc) From W1CLC0
Onevent AFTER_CHANGE Gosub AMM_LEG From W1CLC0
Onevent BEFORE_INPUT Call AS_LEG(zc) From W1CLC0
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"909") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LEG(zc) From W1CLC0
Onkey   2 Titled GBOUTS Call S_LEG(zc) From W1CLC0
Onkey 144 Titled GBOUTP Call P_LEG(zc) From W1CLC0
Onkey 146 Titled GBOUTA Call SA_LEG(zc) From W1CLC0
If VALEUR="" : Call INIADI(VALEUR,"909") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"909","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"909",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  If !mkstat
   ## Action STD
   Call C_LEG(VALEUR) From SUBHRCLC
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_LEG
Call AM_LEG(zc)
If !mkstat & GOBJET
 zoncou = "LEG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_LEG(VALEUR) From SUBHRCLC
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZLEG)")>indice
 [M]LEG(indice) = VALEUR
 Affzo ZLEG(indice)
Endif
Gosub _AFF
End

Subprog S_LEG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "909"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

