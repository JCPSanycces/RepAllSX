Onevent CONTROL Call C_DOCCLAA(zc) From W1CLC0
Onevent AFTER_CHANGE Gosub AMM_DOCCLAA From W1CLC0
Return

Subprog IB_DOCCLAA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTBOUT
 Call BOUTSEL(VALEUR,"M",[M]NOLIB,"") From FMTVAR
Endif
## Action STD
Call IB_DOCCLAA From SUBHRCLC
Gosub _AFF
End

Subprog AS_DOCCLAA(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_DOCCLAA(VALEUR)
## Action AFMTSAI
Call ASAISIE(VALEUR,"M") From FMTVAR
If mkstat=2
 [M]DOCCLAA(INDIC) = VALEUR
 Affzo DOCCLAA(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_DOCCLAA(zc) From W1CLC0
Onkey   2 Titled GBOUTS Call S_DOCCLAA(zc) From W1CLC0
Gosub _AFF
End

Subprog C_DOCCLAA(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DOCCLAA" : GZNUM = 5169 : Endif
If !mkstat
 ## Action AFMTCONT
 Call CONTROLE(VALEUR,"M",[M]NOLIB,20,[M]VALINT(nolign-1)) From FMTVAR
 If mkstat : GERR = 1 : GZONE = "DOCCLAA" : GZNUM = 5169 : Endif
 If !mkstat
  ## Action ACONTACL
  Call CONTACL([M]VALINT(nolign-1),"M","","") From SUBACL
  If mkstat : GERR = 1 : GZONE = "DOCCLAA" : GZNUM = 5169 : Endif
  If !mkstat
   ## Action CONTUNI
   Call UNICITE2(VALEUR,[M]NBRDOC,[M]DOCCLAA) From OBJDIV
   If mkstat : GERR = 1 : GZONE = "DOCCLAA" : GZNUM = 5169 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_DOCCLAA
Call AM_DOCCLAA(zc)
If !mkstat & GOBJET
 zoncou = "DOCCLAA" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

