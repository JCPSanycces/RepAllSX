#<AdxTL>@(#)1.0.0.0 $Revision$
Call AYT_DEBUG From AYTUTIA   # Activation debug java
DOSORG = "XTEND"
FCYORG = "ZSITE2"
Integer RET
Local Char TIM(14)
TIM = func AYTGEN.TIMESTAMP
Call XMLGEN(DOSORG, FCYORG, TIM,"","", RET)
End


######################################################################################
## Xtend: Génération fiche Alias de page
#  Version 0001
######################################################################################
#    XMLGEN 
######################################################################################
Subprog XMLGEN(DOSORG, FCYORG, TIMSTP, OPTION, ELTCOD,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char FCYORG        #     Code site Xtend
Value Char TIMSTP        #     Référence time stamp 20061012093014
Value Char OPTION()(1..) #     Option 
                         #       'TRADET'=Trace détaillée
                         #       'CHK'   =Vérification des pages design
Value Char ELTCOD        #     Code élément
Variable Integer RET     #     1 Ok; 0: Ko ; 2: avertissement
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer WI, WNBREC
Local Integer TRADETFLG   : TRADETFLG   = find("TRADET",OPTION)
Local Integer CHKFLG      : CHKFLG      = find("PAGCHK",OPTION) 
Local Char WSTR1(250)

RET=1

Call TITOBJ("AYG","", WSTR1) From CONTOBJ
Call ECR_TRACE(mess(38,7900,1)-WSTR1,0) From GESECRAN : # Validation de l'écran
If CHKFLG  : Call ECR_TRACE(mess(175,7900,1),0) From GESECRAN : Endif

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS

# Préparation vérification fichier Html
Gosub WF_FICINI
If WF_RET=0 : RET=0 : End : Endif

If DOSORG=nomap 
 Local File AYTPAG   [AYG1] 
 Local File ATEXTE   [ATX1] 
 Local File ATEXTRA  [AXX1]
Else 
 Local File =[L]DOSORG+".AYTPAG"  [AYG1] 
 Local File =[L]DOSORG+".ATEXTE"  [ATX1] 
 Local File = [L]DOSORG+".ATEXTRA"    [AXX1]
Endif 
Default File "[AYG1],[ATX1]"

#$$$$ Test site Z1005 par clob
#If FCYORG<>"Z1005" : Goto BYFILE : Endif   

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# By File
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$BYFILE
Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=TIMSTP
XT_XMLID="PAG"
Gosub XMLF_INI2 From AYTGEN : If XT_RET=0 : RET=0 : Goto FFINALLY : Endif 
#
XT_TY="ELMTS"  : XT_ID=XT_XMLID                                            : Gosub XMLF_ADD From AYTGEN
#
For [AYG1]AYG0 Where FCYCOD=FCYORG
 WNBREC+=1
 If TRADETFLG : Call ECR_TRACE(mess(3,7910,1)-":"-[F]PAGCOD,0) From GESECRAN : Endif
 #
 XT_TY="ELMT"  : XT_ID=[F]PAGCOD    
 Call LECTEXTRA(XT_VAL,"AYTPAG","INTIT",[F]FCYCOD,[F]PAGCOD) From AYTUTIA  : Gosub XMLF_ADD From AYTGEN

 XT_TY="FLD"   : XT_ID="WEBPRO"     : XT_VAL=num$([F]WEBPRO)
                                      XT_LAB=mess([F]WEBPRO,7911,1)        : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="LOGMOD"     : XT_VAL=num$([F]LOGMOD)
                                      XT_LAB=mess([F]LOGMOD,1,1)           : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="ACSMOD"     : XT_VAL=num$([F]ACSMOD)
                                      XT_LAB=mess([F]ACSMOD,1,1)           : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"  : XT_ID="BLCBCK"      : XT_VAL=[F]BLCBCK                     : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"  : XT_ID="BLCMAI"      : XT_VAL=[F]BLCMAI                     : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"  : XT_ID="FICDEF"      : XT_VAL=[F]FICDEF                     : Gosub XMLF_ADD From AYTGEN
  If CHKFLG
   WF_LANXT=WF_LANDEF : WF_FICNAM=[F]FICDEF : Gosub WF_FICVER
   If WF_RET = 0 : RET=2 : Endif   # Remonter un warning
  Endif
 #
 XT_TY="TAB"   : XT_ID="FICLANNBR"                                            : Gosub XMLF_ADD From AYTGEN
 For WI=0 To [F]FICLANNBR-1
  XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
  XT_TY="COL"  : XT_ID="FICLAN"     : XT_VAL=[F]FICLAN(WI)                  : Gosub XMLF_ADD From AYTGEN
  XT_TY="COL"  : XT_ID="FICLANCOD"  : XT_VAL=[F]FICLANCOD(WI)               : Gosub XMLF_ADD From AYTGEN
    WF_LANXT=[F]FICLANCOD(WI) : WF_FICNAM=[F]FICLAN(WI) : Gosub WF_FICVER
    If WF_RET = 0 : RET=2 : Endif   # Remonter un warning
 Next
Next
#

$FFINALLY
Gosub XMLF_CL  From AYTGEN
Close Local File [AYG1],[ATX1],[AXX1]
Call ECR_TRACE(mess(146,7900,1)-num$(WNBREC),0) From GESECRAN
#WI = val(func AYTGEN.TIMESTAMP()) - val(TIMSTP)
#Infbox "Tps en sec:" + num$(WI)
End

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# By Clob
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
Gosub XML_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=TIMSTP
#
XT_TY="ELMTS" : XT_ID="PAG"                                               : Gosub XML_ADD From AYTGEN
#
For [AYG1]AYG0 Where FCYCOD=FCYORG
 XT_TY="ELMT"  : XT_ID=[F]PAGCOD    
 Call LECTEXTRA(XT_VAL,"AYTACT","INTIT",[F]FCYCOD,[F]PAGCOD) From AYTUTIA  : Gosub XML_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="WEBPRO"     : XT_VAL=num$([F]WEBPRO)
                                      XT_LAB=mess([F]WEBPRO,7911,1)        : Gosub XML_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="BLCBCK"     : XT_VAL=[F]BLCBCK                     : Gosub XML_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="BLCMAI"     : XT_VAL=[F]BLCMAI                     : Gosub XML_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="FICDEF"     : XT_VAL=[F]FICDEF                     : Gosub XML_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="LOGMOD"     : XT_VAL=num$([F]LOGMOD)
                                      XT_LAB=mess([F]LOGMOD,1,1)           : Gosub XML_ADD From AYTGEN
 XT_TY="TAB"   : XT_ID="FICLANNBR"                                            : Gosub XML_ADD From AYTGEN
 For WI=0 To [F]FICLANNBR-1
  XT_TY="LIN"                                                               : Gosub XML_ADD From AYTGEN
  XT_TY="COL"  : XT_ID="FICLAN"     : XT_VAL=[F]FICLAN(WI)                  : Gosub XML_ADD From AYTGEN
  XT_TY="COL"  : XT_ID="FICLANCOD"  : XT_VAL=[F]FICLANCOD(WI)               : Gosub XML_ADD From AYTGEN
 Next


Next
#

$FINALLY
Gosub XML_CL  From AYTGEN
Close Local File [AYG1],[ATX1]
End



# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Vérifications fichiers 
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$WF_FICINI         # Initialisation
# - - - - - - - - - - - - - - - - -
Local Integer WF_RET    # Code retour vérif. fichier  0:Ok 1:Ko
WF_RET=1
Local Char WF_FILEPATH(250), WF_LANXT(GLONLAN), WF_LANDEF(GLONLAN), WF_FICNAM(100)
Local Integer WF_I

# Accès site - Infos langues
If DOSORG=nomap 
 Local File AYTFCY  [AYS1] 
Else 
 Local File =[L]DOSORG+".AYTFCY"  [AYS1] 
Endif
Read [AYS1]AYS0 = FCYORG
If fstat
    Call ECR_TRACE(mess(19,7900,1)-FCYORG,1) From GESECRAN
    WF_RET=0
    Return
Endif
# Langues xtend
Local Char WF_TABLANXT (GLONLAN)(1..1)
Local Char WF_TABLANRAC(200)(1..1)
If [F]LANNBR > 0  # protection
    Local Char WF_TABLANXT (GLONLAN)(1..[F]LANNBR)
    Local Char WF_TABLANRAC(200)(1..[F]LANNBR)
    For WF_I=0 To [F]LANNBR-1
        If [F]LANDEF(WF_I)=2 : WF_LANDEF=LANCOD(WF_I) : Endif
        WF_TABLANXT (WF_I+1)= LANCOD(WF_I)
        WF_TABLANRAC(WF_I+1)= func AYTGESFILE.GETPATH("",DOSORG,"DIRPAG",LANADS(WF_I),FCYORG,"")+
&                func AYTGESFILE.GETPATH("",DOSORG,"DIRSEP","","","")
    Next
Endif
Close Local File [AYS1]
Return

$WF_FICVER         # Vérifications
# - - - - - - - - - - - - - - - - -
#  Input:     WF_LANXT langue à vérifier,  WF_FICNAM nom du fichier
WF_RET=1
WF_I=find(WF_LANXT, WF_TABLANXT)
If WF_I
    WF_FILEPATH=WF_TABLANRAC(WF_I)+WF_FICNAM
    Call EXISTE(WF_FILEPATH, WF_I) From ORDSYS
    If WF_I<>1     # pas un fichier
        If !TRADETFLG : Call ECR_TRACE(mess(3,7910,1)-[F]PAGCOD,0) From GESECRAN : Endif
        Call ECR_TRACE("  "-mess(17,7900,1)-WF_FICNAM-"-"-mess(134,7900,1)-WF_LANXT,1) From GESECRAN
        WF_RET=0
    Endif
Else     # Incohérence site - page
    If !TRADETFLG : Call ECR_TRACE(mess(3,7910,1)-[F]PAGCOD,0) From GESECRAN : Endif
    Call ECR_TRACE("  "-mess(18,7900,1)-WF_LANXT,1) From GESECRAN
    WF_RET=0
    Return
Endif

Return
