####################################################################################
Subprog AV_WCENTER(VALEUR)
Variable Char    VALEUR()

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]WCENTER(nolign-1)
    End
  Endif

  If [M:SFTEA]SFTTYP(nolign-1)>3 & [M:SFTEA]FCY(nolign-1)<>"" & [M:SFTEA]BRKTXN(nolign-1)=""
    Actzo [M:SFTEA]WCENTER(nolign-1)
  Else
    Grizo [M:SFTEA]WCENTER(nolign-1)
  Endif

End

####################################################################################
Subprog C_WCENTER(VALEUR)
Variable Char    VALEUR()

  If VALEUR=""
    #Mandatory field
    Call ERREUR(mess(10,123,1)) From GESECRAN
    mkstat = 2
    End
  Endif

  Read [MWS]WST0=VALEUR;[M:SFTEA]FCY(nolign-1)
  If fstat
    #Work center does not exist at the site
    Call ERREUR(mess(196,193,1)) From GESECRAN
    mkstat = 2
    End
  Else
    If [F:MWS]WSTTYP = 3
      #Work center type cannot be subcontract
      Call ERREUR(mess(52,2422,1)) From GESECRAN
      mkstat = 2
      End
    Endif

    If [M:SFTEA]WCENTER(nolign-1)<>""
      Read [MWS2]WST0=[M:SFTEA]WCENTER(nolign-1);[M:SFTEA]FCY(nolign-1)
      If !fstat
        If [F:MWS]WSTTYP<>[MWS2]WSTTYP
          #is not the same type as the original work center
          #Call ERREUR(VALEUR - mess(47,2422,1)) From GESECRAN
          Call ERREUR(func AFNC.MES1(mess(47,2422,1), VALEUR)) From GESECRAN #CT-1797
          mkstat = 2
          End
        Endif
      Endif
    Endif
  Endif

End

####################################################################################
Subprog AV_LCENTER(VALEUR)
Variable Char    VALEUR()

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]LCENTER(nolign-1)
    End
  Endif

  If [M:SFTEA]SFTTYP(nolign-1)>3 & [M:SFTEA]FCY(nolign-1)<>"" & [M:SFTEA]BRKTXN(nolign-1)=""
    Actzo [M:SFTEA]LCENTER(nolign-1)
  Else
    Grizo [M:SFTEA]LCENTER(nolign-1)
  Endif

End

####################################################################################
Subprog C_LCENTER(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" & [M:SFTEA]LCENTER(nolign-1)<>""
    #Labor center is required
    Call ERREUR(mess(48,2422,1)) From GESECRAN
    mkstat = 2
    End
  Endif

  If VALEUR<>"" & [M:SFTEA]LCENTER(nolign-1)=""
    #Labor center cannot be entered if the previous value is blank
    Call ERREUR(mess(49,2422,1)) From GESECRAN
    mkstat = 2
    End
  Endif

  If VALEUR<>"" & [M:SFTEA]LCENTER(nolign-1)<>""
    If VALEUR = [M:SFTEA]WCENTER(nolign-1)
      #The labor center must not be identical to main work center
      Call ERREUR(mess(26,193,1)) From GESECRAN
      mkstat = 2
      End
    Endif
    Read [MWS]WST0=VALEUR;[M:SFTEA]FCY(nolign-1)
    If fstat
      #Labor center does not exist at the site
      Call ERREUR(mess(44,2422,1)) From GESECRAN
      mkstat = 2
      End
    Else
      If [F:MWS]WSTTYP<>2
        #is not a labor workcenter
        Call ERREUR(VALEUR - mess(4,193,1)) From GESECRAN
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

####################################################################################
Subprog AV_CLEFLG(VALEUR)
Variable Integer VALEUR

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]CLEFLG(nolign-1)
    End
  Endif

  If [M:SFTEA]SFTTYP(nolign-1)=5 & [M:SFTEA]BRKTXN(nolign-1)=""
    Actzo [M:SFTEA]CLEFLG(nolign-1)
  Else
    Grizo [M:SFTEA]CLEFLG(nolign-1)
  Endif

End

######################################################################################
Subprog C_FLTTEAMNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : End : Endif

  Read [TMA]TMA0=VALEUR
  If [F:TMA]EMPTYP = 1
    GMESSAGE= func AFNC.MES1(mess(119,2422,1), num$(VALEUR))
    mkstat=2
  Endif
End

