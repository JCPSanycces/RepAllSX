#<AdxTL>@(#)0.0.0.0 $Revision$
# Shop floor tracking employee activity
######################################################################################
$ACTION

Case [L]ACTION
  When "OUVRE"        : Gosub OUVRE
  When "DEBUT"        : Gosub DEBUT
  When "SETBOUT"      : Gosub SETBOUT
  When "BOUTON"       : Gosub BOUTON
  When "APRES_MODIF"  : Gosub APRES_MODIF
Endcase
Return

####################################################################################
$OUVRE

  If !clalev([F:SFTX])  : Local File SFTTXN     [SFTX]  : Endif
  If !clalev([F:SFTXN]) : Local File SFTTXN     [SFTXN] : Endif
  If !clalev([F:SFTXN2]): Local File SFTTXN     [SFTXN2]: Endif
  If !clalev([F:MFO])   : Local File MFGOPE     [MFO]   : Endif
  If !clalev([F:TMA])   : Local File TABMAT     [TMA]   : Endif
  If !clalev([F:MWS])   : Local File WORKSTATIO [MWS]   : Endif
  If !clalev([F:MWS2])  : Local File WORKSTATIO [MWS2]  : Endif
  If !clalev([F:MFG])   : Local File MFGHEAD    [MFG]   : Endif
  If !clalev([F:SCH])   : Local File SCHEDULING [SCH]   : Endif
  If !clalev([F:SFTIR]) : Local File SFTINDREF  [SFTIR] : Endif
  If !clalev([F:SFTTM]) : Local File SFTTEM     [SFTTM] : Endif

  Global Integer DELFLG
  Global Integer DELNOLIGN

Return

####################################################################################
$DEBUT

  #Clears all the fields including all the create and update flags
  Raz [M:SFTEA]

  # set initial filter checks on
  [M:SFTEA]TYPCIO = [V]CST_AYES
  [M:SFTEA]TYPIND = [V]CST_AYES
  [M:SFTEA]TYPBRK = [V]CST_AYES
  [M:SFTEA]TYPSET = [V]CST_AYES
  [M:SFTEA]TYPRUN = [V]CST_AYES

  [M:SFTEA]OPTOPN = [V]CST_AYES
  [M:SFTEA]OPTCLS = [V]CST_AYES

  Actzo [M:SFTEA]OPTOPN
  Actzo [M:SFTEA]OPTCLS
  Actzo [M:SFTEA]OPTERR
  Actzo [M:SFTEA]OPTHST

  Affzo [M:SFTEA]

Return

####################################################################################
$SETBOUT

  Raz CHMEN

  CHMEN+="H"
  CHMEN+="C"

  If [M:SFTEA]OPTHST=[V]CST_ANO
    If find([V]CST_AYES, [M:SFTEA]UPDFLG) | find([V]CST_AYES, [M:SFTEA]CREFLG)
      CHMEN+="S"
    Endif
  Endif

Return

####################################################################################
$APRES_MODIF

  Case zoncou
    When "SHIFTDAT","STRDAT","STRTIM","ENDDAT","ENDTIM","INDREF","OPENUM","CPLQTY","REJCPLQTY","SCANUM","NUMJOBS","NUMMAC","SUMEMP","ELADUR","WCENTER","LCENTER","CLEFLG"
      # set the update flag so that the save action knows to rewrite the record
      # disable the key fields since they cannot be changed
      If [M:SFTEA]CREFLG(nolign-1)<>[V]CST_AYES
        [M:SFTEA]UPDFLG(nolign-1)=[V]CST_AYES
      Endif
      #Affzo [M:SFTEA]CREFLG(nolign-1)
      #Affzo [M:SFTEA]UPDFLG(nolign-1)
    When "NBLIG"
      # a new line was added
      If status=82 | status=73
        If [M:SFTEA]OPTHST=[V]CST_ANO
          Actzo [M:SFTEA]EMPNUM(nolign-1)
          Actzo [M:SFTEA]SFTTYP(nolign-1)
          Actzo [M:SFTEA]VCRNUM(nolign-1)
        Endif
      Elsif status=65
        Gosub DEL
      Endif
  Endcase

Return

####################################################################################
$BOUTON

  Case BOUT
    When "H" : Gosub SEARCH
    When "S" : Gosub SAVE
    When "C" : Gosub CLEAR
  Endcase

Return

####################################################################################
$CLEAR
  Gosub DEBUT
Return

####################################################################################
$SEARCH
  Local Char CRIT1(250),CRIT2(250),CRIT3(250)
  Local Char UOR(2)
  Local Integer WMAX, JOB, MACH, MACHTMP, I, IRELOAD, TMPNUMJOBS, TMPSUMEMP
  Local Char STRYR(4), STRMO(2), STRDY(2), STRHR(2), STRMN(2)
  Local Date PARSEDATE
  Local Decimal DECDUR

  If find([V]CST_AYES, [M:SFTEA]UPDFLG) | find([V]CST_AYES, [M:SFTEA]CREFLG)
    #Reload the table and cancel the modifications?
    Call OUINON(mess(68,2422,1),IRELOAD) From GESECRAN
    If IRELOAD = [V]CST_ANO : Return : Endif
  Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    LogicClose File [SFTX]
    #Local File SFTTXNH [SFTX]
    If !clalev([F:SFTX])  : Local File SFTTXNH [SFTX] : Endif
  Else
    If !clalev([F:SFTX])  : Local File SFTTXN [SFTX]  : Endif
  Endif

  # Option filters
  If [M:SFTEA]OPTOPN=[V]CST_ANO & [M:SFTEA]OPTCLS=[V]CST_ANO & [M:SFTEA]OPTERR=[V]CST_ANO & [M:SFTEA]OPTHST=[V]CST_ANO
    Call ERREUR(mess(99,100,1)) From GESECRAN
    Return
  Endif

  # build search criteria
  CRIT1 = "1=1"
  CRIT2 = "1=1"

  #114791
  # Employee & Team
  If [M:SFTEA]FLTEMPNUM>0
    If [M:SFTEA]FLTTEAMNUM=0
      Filter [SFTTM] Where EMPNUM = [M:SFTEA]FLTEMPNUM
      Read [SFTTM]SFTTM1 First
      Filter [SFTTM]
      If !fstat
        CRIT1 -= '& (EMPNUM=' + num$([M:SFTEA]FLTEMPNUM) + ' OR (TEAMNUM=' + num$([SFTTM]TEAMNUM) + ' & EMPNUM=' + num$([SFTTM]TEAMNUM) + '))'
      Else
        CRIT1 -= '& EMPNUM=' + num$([M:SFTEA]FLTEMPNUM)
      Endif
    Else
      CRIT1 -= '& EMPNUM=' + num$([M:SFTEA]FLTEMPNUM)
    Endif
  Endif

  If [M:SFTEA]FLTTEAMNUM>0
    CRIT1 -= '& TEAMNUM=' + num$([M:SFTEA]FLTTEAMNUM)
  Endif

  # Site
  If [M:SFTEA]FLTFCY<>""
    If [M:SFTEA]OPTHST=[V]CST_AYES
      CRIT1 -= '& MFGFCY="' + [M:SFTEA]FLTFCY + '"'
    Else
      CRIT1 -= '& FCY="' + [M:SFTEA]FLTFCY + '"'
    Endif
  Endif

  # errors
  If [M:SFTEA]OPTERR=2
    CRIT1 -= '& ERRFLG=2'
  Endif

  # open (without end date) and close (with end date including elapsed)
  If [M:SFTEA]OPTOPN=[V]CST_AYES & [M:SFTEA]OPTCLS=[V]CST_ANO
    CRIT1 -= "& UTCENDDATTIM=AVOID.ADATTIM"
  Elsif [M:SFTEA]OPTOPN=[V]CST_ANO & [M:SFTEA]OPTCLS=[V]CST_AYES
    CRIT1 -= "& UTCENDDATTIM<>AVOID.ADATTIM"
  Endif

  # Workorder
  If [M:SFTEA]VCRNUMSTR<>""
    CRIT1 -= '& VCRNUM>="' + [M:SFTEA]VCRNUMSTR + '"'
  Endif
  If [M:SFTEA]VCRNUMEND<>""
    CRIT1 -= '& VCRNUM<="' + [M:SFTEA]VCRNUMEND + '"'
  Endif

  # Operation
  If [M:SFTEA]OPENUMSTR>0
    CRIT2 -= "& OPENUM>=" + num$([M:SFTEA]OPENUMSTR)
  Endif
  If [M:SFTEA]OPENUMEND>0
    CRIT2 -= "& OPENUM<=" + num$([M:SFTEA]OPENUMEND)
  Endif

  # Workcenter
  If [M:SFTEA]WSTSTR<>""
    CRIT2 -= '& WCENTER>="' + [M:SFTEA]WSTSTR + '"'
  Endif
  If [M:SFTEA]WSTEND<>""
    CRIT2 -= '& WCENTER<="' + [M:SFTEA]WSTEND + '"'
  Endif

  # Shift date
  If [M:SFTEA]SHIDATSTR<>[0/0/0]
    CRIT2 -= "& SHIFTDAT>=[" +format$(GFMD,[M:SFTEA]SHIDATSTR)+ "]"
  Endif
  If [M:SFTEA]SHIDATEND<>[0/0/0]
    CRIT2 -= "& SHIFTDAT<=[" +format$(GFMD,[M:SFTEA]SHIDATEND)+ "]"
  Endif

  # SFT type filters
  If [M:SFTEA]TYPCIO=[V]CST_ANO & [M:SFTEA]TYPIND=[V]CST_ANO & [M:SFTEA]TYPBRK=[V]CST_ANO & [M:SFTEA]TYPSET=[V]CST_ANO & [M:SFTEA]TYPRUN=[V]CST_ANO
    Call ERREUR(mess(99,100,1)) From GESECRAN
    Return
  Endif

  Raz CRIT3
  Raz UOR

  # SFT type filters
  If [M:SFTEA]TYPCIO=[V]CST_AYES
    CRIT3 -= "SFTTYP=1"
    UOR = "Or"
  Endif

  If [M:SFTEA]TYPIND=[V]CST_AYES
    CRIT3-= UOR - "SFTTYP=2"
    UOR = "Or"
  Endif

  If [M:SFTEA]TYPBRK=[V]CST_AYES
    CRIT3-= UOR - "SFTTYP=3"
    UOR = "Or"
  Endif

  If [M:SFTEA]TYPSET=[V]CST_AYES
    CRIT3-= UOR - "SFTTYP=4"
    UOR = "Or"
  Endif

  If [M:SFTEA]TYPRUN=[V]CST_AYES
    CRIT3-= UOR - "SFTTYP=5"
  Endif

  Effzo [M:SFTEA]25

  I = 0

  WMAX = dim([M:SFTEA]EMPNUM)  # Max lines to be displayed

  For [SFTX] Where evalue(CRIT1) & evalue(CRIT2) & evalue(CRIT3)
    If I >= WMAX
        Call ERREUR(func AFNC.MES1(mess(37,2422,1),num$(WMAX))) From GESECRAN
        Break
    Endif

    If DELFLG = [V]CST_AYES & I = (DELNOLIGN-1)
      I += 1
    Endif

    [M:SFTEA]VCRNUM(I)    = [F:SFTX]VCRNUM
    [M:SFTEA]EMPNUM(I)    = [F:SFTX]EMPNUM
    [M:SFTEA]TEAMNUM(I)   = [F:SFTX]TEAMNUM  #114791
    [M:SFTEA]EMPDES(I)    = func GETEMPDES([F:SFTX]EMPNUM)
    [M:SFTEA]SFTTYP(I)    = [F:SFTX]SFTTYP
    [M:SFTEA]SFTSEQ(I)    = [F:SFTX]SFTSEQ
    [M:SFTEA]SHIFTDAT(I)  = [F:SFTX]SHIFTDAT
    [M:SFTEA]INDREF(I)    = [F:SFTX]INDREF
    [M:SFTEA]INDTYP(I)    = [F:SFTX]INDTYP
    [M:SFTEA]OPENUM(I)    = [F:SFTX]OPENUM
    [M:SFTEA]CPLQTY(I)    = [F:SFTX]CPLQTY
    [M:SFTEA]REJCPLQTY(I) = [F:SFTX]REJCPLQTY
    [M:SFTEA]SCANUM(I)    = [F:SFTX]SCANUM
    [M:SFTEA]NUMJOBS(I)   = [F:SFTX]NUMJOBS
    [M:SFTEA]NUMMAC(I)    = [F:SFTX]NUMMAC
    [M:SFTEA]SUMEMP(I)    = [F:SFTX]SUMEMP  #114791
    [M:SFTEA]DURATION(I)  = [F:SFTX]DURATION
    [M:SFTEA]WCENTER(I)   = [F:SFTX]WCENTER
    [M:SFTEA]LCENTER(I)   = [F:SFTX]LCENTER
    [M:SFTEA]OPEUOM(I)    = [F:SFTX]OPEUOM
    [M:SFTEA]CLEFLG(I)    = [F:SFTX]CLEFLG
    [M:SFTEA]MACFLG(I)    = [F:SFTX]MACFLG  #114791

    If [M:SFTEA]OPTHST=[V]CST_AYES
      [M:SFTEA]FCY(I)     = [F:SFTX]MFGFCY
    Else
      [M:SFTEA]FCY(I)     = [F:SFTX]FCY
      [M:SFTEA]ERRFLG(I)  = [F:SFTX]ERRFLG
      [M:SFTEA]ERRMSG(I)  = [F:SFTX]ERRMSG

      #Transactions only exist in SFTTXN
      If [F:SFTX]BRKTXN <> AVOID.AUUIDENT
        [M:SFTEA]BRKTXN(I) = num$([F:SFTX]BRKTXN)
      Endif

      If [F:SFTX]TXNUUID <> AVOID.AUUIDENT  #114791
        [M:SFTEA]TXNUUID(I) = num$([F:SFTX]TXNUUID)
      Endif
    Endif

    If [F:SFTX]UTCSTRDATTIM <> AVOID.ADATTIM
      Raz STRYR, STRMO, STRDY, STRHR, STRMN, PARSEDATE
      Call PARSEDATETIME ([F:SFTX]UTCSTRDATTIM, [F:SFTX]UTCOFFSET, STRYR, STRMO, STRDY, STRHR, STRMN) From SFTLIB

      PARSEDATE = evalue("["+STRDY+"/"+STRMO+"/"+STRYR+"]")
      [M:SFTEA]STRDAT(I) = PARSEDATE
      [M:SFTEA]STRTIM(I) = format$("N0:2#",val(STRHR))+format$("N0:2#",val(STRMN))
    Else
      [M:SFTEA]STRDAT(I)=[0/0/0]
      [M:SFTEA]STRTIM(I)=""
    Endif

    If [F:SFTX]UTCENDDATTIM <> AVOID.ADATTIM & [F:SFTX]UTCSTRDATTIM <> AVOID.ADATTIM
      Raz STRYR, STRMO, STRDY, STRHR, STRMN, PARSEDATE
      Call PARSEDATETIME ([F:SFTX]UTCENDDATTIM, [F:SFTX]UTCOFFSET, STRYR, STRMO, STRDY, STRHR, STRMN) From SFTLIB

      PARSEDATE = evalue("["+STRDY+"/"+STRMO+"/"+STRYR+"]")
      [M:SFTEA]ENDDAT(I) = PARSEDATE
      [M:SFTEA]ENDTIM(I) = format$("N0:2#",val(STRHR))+format$("N0:2#",val(STRMN))
    Else
      [M:SFTEA]ENDDAT(I)=[0/0/0]
      [M:SFTEA]ENDTIM(I)=""
    Endif

    #114791
    #Calculate elapsed duration
    [M:SFTEA]TIMUOMCOD(I) = func GET_TIMUOMCOD([F:SFTX]SFTTYP, [F:SFTX]INDTYP, [F:SFTX]VCRNUM, [F:SFTX]OPENUM)

    If [F:SFTX]UTCENDDATTIM <> AVOID.ADATTIM & [F:SFTX]UTCSTRDATTIM = AVOID.ADATTIM
      TMPNUMJOBS = [F:SFTX]NUMJOBS
      TMPSUMEMP = [F:SFTX]SUMEMP

      If TMPNUMJOBS=0 : TMPNUMJOBS=1 : Endif
      If TMPSUMEMP=0 : TMPSUMEMP=1 : Endif

      If [M:SFTEA]TIMUOMCOD(I) = 1
        [M:SFTEA]ELADUR(I) = (([F:SFTX]DURATION * TMPNUMJOBS) / TMPSUMEMP) / 60
      Else
         [M:SFTEA]ELADUR(I) = (([F:SFTX]DURATION * TMPNUMJOBS) / TMPSUMEMP)
      Endif
    Endif

    #Calculate activity duration
    If [M:SFTEA]TIMUOMCOD(I) = 1
      [M:SFTEA]LABDUR(I) = [F:SFTX]DURATION / 60
    Else
      [M:SFTEA]LABDUR(I) = [F:SFTX]DURATION
    Endif

#119090.so
#Changed NUMMAC field to boolean
#Removed machine duration display [M]MACHDUR from the grid
#    If [F:SFTX]SFTTYP>3
#      MACHTMP=1
#
#      #114791 Machine duration display
#      If func SFTLIB.ISMACHINE([M:SFTEA]WCENTER(I),[M:SFTEA]FCY(I)) = [V]CST_AYES
#        If [F:SFTX]SFTTYP=5
#          MACHTMP = [F:SFTX]NUMMAC
#        Endif
#      Else
#        MACHTMP = 0
#      Endif
#
#      If [M:SFTEA]OPTHST=[V]CST_AYES
#        DECDUR = [F:SFTX]TIMMAC
#      Else
#        DECDUR = [F:SFTX]DURATION * MACHTMP
#      Endif
#
#      If [M:SFTEA]TIMUOMCOD(I) = 1
#        [M:SFTEA]MACHDUR(I) = DECDUR / 60
#      Else
#        [M:SFTEA]MACHDUR(I) = DECDUR
#      Endif
#    Endif
#119090.eo

    I += 1

NEXT_SFTX:
  Next
  [M:SFTEA]NBLIG = I
  Affzo [M:SFTEA]25

  If [M:SFTEA]OPTHST=[V]CST_AYES
    # switch channel back to SFTTXN
    If clalev([F:SFTX])<>0 : Close File [SFTX] : Endif
    Local File SFTTXN [SFTX]
  Endif

Return
####################################################################################
$SAVE

Local Integer STRFLG, ENDFLG, I
Local Integer LOCAL_STATUS
Local Decimal TMPDUR
Local Uuident TXNUUID

Local Instance SFTTXN_INS Using C_SFTTXN
Local Instance SFTTXN_UPD Using C_SFTTXN

For I=0 To [M:SFTEA]NBLIG-1

    If [M:SFTEA]CREFLG(I)=[V]CST_AYES
        Raz STRFLG, ENDFLG

        If ([M:SFTEA]STRDAT(I)<>[0/0/0] & [M:SFTEA]STRTIM(I)<>"") : STRFLG=1 : Endif
        If ([M:SFTEA]ENDDAT(I)<>[0/0/0] & [M:SFTEA]ENDTIM(I)<>"") : ENDFLG=1 : Endif

        SFTTXN_INS = NewInstance C_SFTTXN AllocGroup null

        SFTTXN_INS.EMPNUM      = [M:SFTEA]EMPNUM(I)
        SFTTXN_INS.TEAMNUM     = [M:SFTEA]TEAMNUM(I) #114791
        SFTTXN_INS.SFTTYP      = [M:SFTEA]SFTTYP(I)
        SFTTXN_INS.VCRNUM      = [M:SFTEA]VCRNUM(I)
        #SFTTXN_INS.SFTSEQ      = func SFTTXN_CSTD.NEXT_SEQ([M:SFTEA]EMPNUM(I), [M:SFTEA]SFTTYP(I), [M:SFTEA]VCRNUM(I))
        SFTTXN_INS.UTCOFFSET   = fmet SFTTXN_INS.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, [M:SFTEA]FCY(I), "SFTOFFSET")

        #Convert Start/End date back to UTC
        If STRFLG=1
            SFTTXN_INS.UTCSTRDATTIM = func SFTLIB.CALCBREAKTIME([M:SFTEA]STRDAT(I), SFTTXN_INS.UTCOFFSET, [M:SFTEA]STRTIM(I))
        Endif

        If ENDFLG=1
          SFTTXN_INS.UTCENDDATTIM = func SFTLIB.CALCBREAKTIME([M:SFTEA]ENDDAT(I), SFTTXN_INS.UTCOFFSET, [M:SFTEA]ENDTIM(I))
        Elsif STRFLG=0
          SFTTXN_INS.UTCENDDATTIM = datetime$
          ENDFLG=1
        Endif

        #Get the employee's shift
        Read [TMA]TMA0=[M:SFTEA]EMPNUM(I)
        #Set the employee's shift to the transaction record
        If !fstat : SFTTXN_INS.SHIFT = [F:TMA]SHIFT : Endif

        SFTTXN_INS.FCY        = [M:SFTEA]FCY(I)
        SFTTXN_INS.SHIFTDAT   = [M:SFTEA]SHIFTDAT(I)
        SFTTXN_INS.INDREF     = [M:SFTEA]INDREF(I)

        If [M:SFTEA]INDREF(I) <> ""
            Read [F:SFTIR]SFTAG0=[M:SFTEA]INDREF(I)
            If !fstat : SFTTXN_INS.INDTYP = [F:SFTIR]INDTYP : Endif
        Endif

        SFTTXN_INS.OPENUM     = [M:SFTEA]OPENUM(I)
        SFTTXN_INS.CPLQTY     = [M:SFTEA]CPLQTY(I)
        SFTTXN_INS.REJCPLQTY  = [M:SFTEA]REJCPLQTY(I)
        SFTTXN_INS.SCANUM     = [M:SFTEA]SCANUM(I)
        SFTTXN_INS.NUMJOBS    = [M:SFTEA]NUMJOBS(I)
        SFTTXN_INS.NUMMAC     = [M:SFTEA]NUMMAC(I)
        SFTTXN_INS.SUMEMP     = [M:SFTEA]SUMEMP(I)  #114791
        SFTTXN_INS.WCENTER    = [M:SFTEA]WCENTER(I)
        SFTTXN_INS.LCENTER    = [M:SFTEA]LCENTER(I)
        SFTTXN_INS.OPEUOM     = [M:SFTEA]OPEUOM(I)
        SFTTXN_INS.CLEFLG     = [M:SFTEA]CLEFLG(I)
        SFTTXN_INS.MACFLG     = [M:SFTEA]MACFLG(I)  #114791

        #Save duration directly from the field for elapsed time entries
        If STRFLG=0 & ENDFLG=1
            #114791
            SFTTXN_INS.DURATION = [M:SFTEA]DURATION(I)

            If [M:SFTEA]TIMUOMCOD(I) = 1
              [L]TMPDUR = [M:SFTEA]ELADUR(I) * 60
            Else
              [L]TMPDUR = [M:SFTEA]ELADUR(I)
            Endif

        #Save duration from calculation for other entries
        Elsif STRFLG=1 & ENDFLG=1
            #114791
            If func SFTLIB.EMPTYP(SFTTXN_INS.EMPNUM)=3 #Summary Team
              SFTTXN_INS.DURATION = func SFTLIB.CALC_DURATION(SFTTXN_INS.UTCSTRDATTIM, SFTTXN_INS.UTCENDDATTIM, SFTTXN_INS.NUMJOBS, SFTTXN_INS.SUMEMP)
            Else
              SFTTXN_INS.DURATION = func SFTLIB.CALC_DURATION(SFTTXN_INS.UTCSTRDATTIM, SFTTXN_INS.UTCENDDATTIM, SFTTXN_INS.NUMJOBS, 1)
            Endif
            [L]TMPDUR = func SFTLIB.CALC_DURATION(SFTTXN_INS.UTCSTRDATTIM, SFTTXN_INS.UTCENDDATTIM, 1, 1)   #114791
        Else
            SFTTXN_INS.DURATION = 0
            [L]TMPDUR = 0   #114791
        Endif

        #114791
        #Split into two records
        [L]TXNUUID = AVOID.AUUID

        If SFTTXN_INS.SFTTYP>3
          If func SFTLIB.ISMACHINE(SFTTXN_INS.WCENTER,SFTTXN_INS.FCY)=[V]CST_AYES
            If SFTTXN_INS.LCENTER = AVOID.ACHAR #Machine only (M-X)
              SFTTXN_INS.MACFLG = [V]CST_AYES
            Else #Machine and labor (M-L)
              If !([M:SFTEA]ELADUR(I)=0 & [M:SFTEA]STRDAT(I)=[0/0/0] & [M:SFTEA]CPLQTY(I)>0)
                #If SFTTXN_INS.NUMMAC>0 #119090.o
                If SFTTXN_INS.NUMMAC = [V]CST_AYES #119090.n
                  [L]LOCAL_STATUS = func SFTTXN_CSTD.MACHINE_START(SFTTXN_INS.EMPNUM, SFTTXN_INS.TEAMNUM, SFTTXN_INS.FCY, SFTTXN_INS.SFTTYP, SFTTXN_INS.SHIFTDAT, SFTTXN_INS.UTCSTRDATTIM,
&                                 SFTTXN_INS.UTCENDDATTIM, SFTTXN_INS.UTCOFFSET, SFTTXN_INS.VCRNUM, SFTTXN_INS.OPENUM, SFTTXN_INS.OPEUOM, SFTTXN_INS.NUMMAC, [L]TMPDUR,
&                                 SFTTXN_INS.WCENTER, SFTTXN_INS.LCENTER, [L]TXNUUID)

                  If [L]LOCAL_STATUS >= [V]CST_AERROR
                    #Error writing record
                    Call ERREUR(mess(23,2422,1)) From GESECRAN
                    FreeGroup SFTTXN_INS
                    Break
                  Endif

                  #SFTTXN_INS.NUMMAC = 0 #119090.o
                  SFTTXN_INS.NUMMAC = [V]CST_ANO  #119090.n
                  SFTTXN_INS.MACFLG = [V]CST_ANO
                Else
                  SFTTXN_INS.WCENTER = SFTTXN_INS.LCENTER
                  SFTTXN_INS.LCENTER = AVOID.ACHAR
                Endif
              Endif
            Endif
          Endif
        Endif

        SFTTXN_INS.TXNUUID = [L]TXNUUID
        SFTTXN_INS.SFTSEQ = func SFTTXN_CSTD.NEXT_SEQ([M:SFTEA]EMPNUM(I), [M:SFTEA]SFTTYP(I), [M:SFTEA]VCRNUM(I))

        If fmet SFTTXN_INS.AINSERT <> [V]CST_AOK
            #Error writing record
            Call ERREUR(mess(23,2422,1)) From GESECRAN
            FreeGroup SFTTXN_INS
            Break
        Endif

        [M:SFTEA]CREFLG(I)    = [V]CST_ANO

        FreeGroup SFTTXN_INS
    Else

        If [M:SFTEA]UPDFLG(I)=[V]CST_AYES
            SFTTXN_UPD = NewInstance C_SFTTXN AllocGroup null
            Raz STRFLG, ENDFLG

            If ([M:SFTEA]STRDAT(I)<>[0/0/0] & [M:SFTEA]STRTIM(I)<>"") : STRFLG=1 : Endif
            If ([M:SFTEA]ENDDAT(I)<>[0/0/0] & [M:SFTEA]ENDTIM(I)<>"") : ENDFLG=1 : Endif

            If fmet SFTTXN_UPD.AREAD([M:SFTEA]EMPNUM(I), [M:SFTEA]SFTTYP(I), [M:SFTEA]VCRNUM(I), [M:SFTEA]SFTSEQ(I)) <> [V]CST_AOK
                #Error reading record
                Call ERREUR(mess(21,2422,1)) From GESECRAN
                FreeGroup SFTTXN_UPD
                Break
            Endif

            #Convert Start/End date back to UTC
            If STRFLG=1
                SFTTXN_UPD.UTCSTRDATTIM = func SFTLIB.CALCBREAKTIME([M:SFTEA]STRDAT(I), SFTTXN_UPD.UTCOFFSET, [M:SFTEA]STRTIM(I))
            Else
                SFTTXN_UPD.UTCSTRDATTIM = AVOID.ADATTIM
            Endif

            If ENDFLG=1
                SFTTXN_UPD.UTCENDDATTIM = func SFTLIB.CALCBREAKTIME([M:SFTEA]ENDDAT(I), SFTTXN_UPD.UTCOFFSET, [M:SFTEA]ENDTIM(I))
            Elsif STRFLG=0
                SFTTXN_UPD.UTCENDDATTIM = datetime$
                ENDFLG=1
            Else
                SFTTXN_UPD.UTCENDDATTIM = AVOID.ADATTIM
            Endif

            SFTTXN_UPD.SHIFTDAT   = [M:SFTEA]SHIFTDAT(I)
            SFTTXN_UPD.INDREF     = [M:SFTEA]INDREF(I)

            If [M:SFTEA]INDREF(I) <> ""
                Read [F:SFTIR]SFTAG0=[M:SFTEA]INDREF(I)
                If !fstat : SFTTXN_UPD.INDTYP = [F:SFTIR]INDTYP : Endif
            Else
                SFTTXN_UPD.INDTYP = 0
            Endif

            SFTTXN_UPD.OPENUM     = [M:SFTEA]OPENUM(I)
            SFTTXN_UPD.CPLQTY     = [M:SFTEA]CPLQTY(I)
            SFTTXN_UPD.REJCPLQTY  = [M:SFTEA]REJCPLQTY(I)
            SFTTXN_UPD.SCANUM     = [M:SFTEA]SCANUM(I)
            SFTTXN_UPD.NUMJOBS    = [M:SFTEA]NUMJOBS(I)
            SFTTXN_UPD.NUMMAC     = [M:SFTEA]NUMMAC(I)
            SFTTXN_UPD.SUMEMP     = [M:SFTEA]SUMEMP(I)  #114791
            SFTTXN_UPD.WCENTER    = [M:SFTEA]WCENTER(I)
            SFTTXN_UPD.LCENTER    = [M:SFTEA]LCENTER(I)
            SFTTXN_UPD.CLEFLG     = [M:SFTEA]CLEFLG(I)
            SFTTXN_UPD.MACFLG     = [M:SFTEA]MACFLG(I)  #114791

            #Save duration directly from the field for elapsed time entries
            If STRFLG=0 & ENDFLG=1
                SFTTXN_UPD.DURATION = [M:SFTEA]DURATION(I)
            #Save duration from calculation for other entries
            Elsif STRFLG=1 & ENDFLG=1
                #114791
                If func SFTLIB.EMPTYP(SFTTXN_UPD.EMPNUM)=3 #Summary Team
                  SFTTXN_UPD.DURATION = func SFTLIB.CALC_DURATION(SFTTXN_UPD.UTCSTRDATTIM, SFTTXN_UPD.UTCENDDATTIM, SFTTXN_UPD.NUMJOBS, SFTTXN_UPD.SUMEMP)
                Else
                  SFTTXN_UPD.DURATION = func SFTLIB.CALC_DURATION(SFTTXN_UPD.UTCSTRDATTIM, SFTTXN_UPD.UTCENDDATTIM, SFTTXN_UPD.NUMJOBS, 1)
                Endif
            Else
                SFTTXN_UPD.DURATION = 0
            Endif

            # Special handling for Breaks and Exclusive Indrects that went from open to closed
            If ([M:SFTEA]SFTTYP(I)=3 | ([M:SFTEA]SFTTYP(I)=2 & [M:SFTEA]INDTYP(I)=4)) & [M:SFTEA]BRKTXN(I)<>""
              # Re-open the transactions closed by the break open
              For [SFTXN] Where EMPNUM=[M:SFTEA]EMPNUM(I) & BRKTXN=toUuid([M:SFTEA]BRKTXN(I))
                # Don't try to reopen the record we are closing.
                If !([F:SFTXN]SFTTYP=[M:SFTEA]SFTTYP(I) & [F:SFTXN]SFTSEQ=[M:SFTEA]SFTSEQ(I))
                  If [M:SFTEA]BRKOPEN(I) = [V]CST_AYES
                    SFTTXN_INS = NewInstance C_SFTTXN AllocGroup null

                    SFTTXN_INS.EMPNUM       = [F:SFTXN]EMPNUM
                    SFTTXN_INS.TEAMNUM      = [F:SFTXN]TEAMNUM #114791
                    SFTTXN_INS.SFTTYP       = [F:SFTXN]SFTTYP
                    SFTTXN_INS.VCRNUM       = [F:SFTXN]VCRNUM
                    SFTTXN_INS.SFTSEQ       = func SFTTXN_CSTD.NEXT_SEQ([F:SFTXN]EMPNUM, [F:SFTXN]SFTTYP, [F:SFTXN]VCRNUM)
                    SFTTXN_INS.UTCSTRDATTIM = SFTTXN_UPD.UTCENDDATTIM
                    SFTTXN_INS.UTCOFFSET    = [F:SFTXN]UTCOFFSET
                    SFTTXN_INS.INDREF       = [F:SFTXN]INDREF
                    SFTTXN_INS.NUMJOBS      = [F:SFTXN]NUMJOBS
                    SFTTXN_INS.OPENUM       = [F:SFTXN]OPENUM
                    SFTTXN_INS.NUMMAC       = [F:SFTXN]NUMMAC
                    SFTTXN_INS.SUMEMP       = [F:SFTXN]SUMEMP  #114791
                    SFTTXN_INS.WCENTER      = [F:SFTXN]WCENTER
                    SFTTXN_INS.LCENTER      = [F:SFTXN]LCENTER
                    SFTTXN_INS.OPEUOM       = [F:SFTXN]OPEUOM
                    SFTTXN_INS.INDTYP       = [F:SFTXN]INDTYP
                    SFTTXN_INS.FCY          = [F:SFTXN]FCY
                    SFTTXN_INS.SHIFT        = [F:SFTXN]SHIFT
                    SFTTXN_INS.SHIFTDAT     = [F:SFTXN]SHIFTDAT

                    If fmet SFTTXN_INS.AINSERT <> [V]CST_AOK
                      Call ERREUR(mess(24,2422,1)) From GESECRAN
                      FreeGroup SFTTXN_INS
                      Break
                    Endif
                    FreeGroup SFTTXN_INS
                  Endif

                  # For both cases - clear the BRKTXN from the transaction
                  [F:SFTXN]BRKTXN = AVOID.AUUIDENT
                  Rewrite [SFTXN]

                Endif
              Next
              # Clear the BRKTXN from the break
              SFTTXN_UPD.BRKTXN = AVOID.AUUIDENT
            Endif

            If fmet SFTTXN_UPD.AUPDATE <> [V]CST_AOK
                #Error updating record
                Call ERREUR(mess(24,2422,1)) From GESECRAN
                FreeGroup SFTTXN_UPD
                Break
            Endif

            #114791
            #Cascade update of UTCENDDATTIM
            #Jira 50317.n 08/03/17 by CATUA Commented out auto update issue using TXNUUID for auto break or Run during break = on scenarios
            #Update of one line will update the rest
#            If (SFTTXN_UPD.SFTTYP > 3 & SFTTXN_UPD.UTCSTRDATTIM <> AVOID.ADATTIM & SFTTXN_UPD.UTCENDDATTIM <> AVOID.ADATTIM & SFTTXN_UPD.TXNUUID <> AVOID.AUUIDENT) &
#&           !(SFTTXN_UPD.MACFLG = [V]CST_AYES & SFTTXN_UPD.TEAMNUM <> 0 & SFTTXN_UPD.EMPNUM <> SFTTXN_UPD.TEAMNUM)
#              For [SFTXN] Where SFTTYP = SFTTXN_UPD.SFTTYP & UTCSTRDATTIM <> AVOID.ADATTIM & UTCSTRDATTIM = SFTTXN_UPD.UTCSTRDATTIM & UTCENDDATTIM <> SFTTXN_UPD.UTCENDDATTIM &
#&             TXNUUID = SFTTXN_UPD.TXNUUID
#                If !([F:SFTXN]EMPNUM = SFTTXN_UPD.EMPNUM & [F:SFTXN]SFTTYP = SFTTXN_UPD.SFTTYP & [F:SFTXN]VCRNUM = SFTTXN_UPD.VCRNUM & [F:SFTXN]SFTSEQ = SFTTXN_UPD.SFTSEQ) &
#&               !([F:SFTXN]MACFLG = [V]CST_AYES & [F:SFTXN]TEAMNUM <> 0 & [F:SFTXN]EMPNUM <> [F:SFTXN]TEAMNUM)
#                  [F:SFTXN]UTCENDDATTIM = SFTTXN_UPD.UTCENDDATTIM
#                  [F:SFTXN]ACTENDDATTIM = SFTTXN_UPD.ACTENDDATTIM
#
#                  If [F:SFTXN]UTCSTRDATTIM = SFTTXN_UPD.UTCSTRDATTIM & [F:SFTXN]NUMJOBS = SFTTXN_UPD.NUMJOBS & [F:SFTXN]SUMEMP = SFTTXN_UPD.SUMEMP
#                    [F:SFTXN]DURATION = SFTTXN_UPD.DURATION
#                  Else
#                    If [F:SFTXN]UTCSTRDATTIM < [F:SFTXN]UTCENDDATTIM
#                      If func SFTLIB.EMPTYP([F:SFTXN]EMPNUM)=3 #Summary Team
#                        [F:SFTXN]DURATION = func SFTLIB.CALC_DURATION([F:SFTXN]UTCSTRDATTIM, [F:SFTXN]UTCENDDATTIM, [F:SFTXN]NUMJOBS, [F:SFTXN]SUMEMP)
#                      Else
#                        [F:SFTXN]DURATION = func SFTLIB.CALC_DURATION([F:SFTXN]UTCSTRDATTIM, [F:SFTXN]UTCENDDATTIM, [F:SFTXN]NUMJOBS, 1)
#                      Endif
#                    Endif
#                  Endif
#                  Rewrite [SFTXN]
#                Endif
#              Next
#            Endif

            [M:SFTEA]UPDFLG(I) = [V]CST_ANO

            FreeGroup SFTTXN_UPD
        Endif
    Endif

NEXT_REC:
Next

Kill SFTTXN_INS
Kill SFTTXN_UPD

Gosub SEARCH

Return

####################################################################################
$DEL
  Local Integer I, ICOUNT, IRET
  Local Instance SFTTXN_DEL Using C_SFTTXN
  Local Instance SFTTXN_UUIDDEL Using C_SFTTXN

  # No deleting history records
  If [M:SFTEA]OPTHST=[V]CST_AYES : mkstat=1 : Return : Endif

  SFTTXN_DEL = NewInstance C_SFTTXN AllocGroup null
  If fmet SFTTXN_DEL.AREAD([M:SFTEA]EMPNUM(nolign-1), [M:SFTEA]SFTTYP(nolign-1), [M:SFTEA]VCRNUM(nolign-1), [M:SFTEA]SFTSEQ(nolign-1)) <> [V]CST_AOK
    #Record still does not exists, continue to delete line from the grid without prompting an error.
    Goto DELETE_ERROR
  Endif

  If SFTTXN_DEL.EMPNUM<>[M:SFTEA]EMPNUM(nolign-1)
    #Error reading record
    Call ERREUR(mess(21,2422,1)) From GESECRAN
    mkstat=1
    Goto DELETE_ERROR
  Endif

  # Check if this is a break or exclusive indirect record that is open
  # If so - re-open the transactions that were closed when the break was started
  If (SFTTXN_DEL.SFTTYP=3 | (SFTTXN_DEL.SFTTYP=2 & SFTTXN_DEL.INDTYP=4)) & SFTTXN_DEL.BRKTXN<>AVOID.AUUIDENT
    For [SFTXN] Where BRKTXN=SFTTXN_DEL.BRKTXN
      If !([F:SFTXN]SFTTYP=[M:SFTEA]SFTTYP(nolign-1) & [F:SFTXN]SFTSEQ=[M:SFTEA]SFTSEQ(nolign-1))
        [F:SFTXN]BRKTXN       = AVOID.AUUIDENT
        [F:SFTXN]DURATION     = AVOID.ADEC
        [F:SFTXN]UTCENDDATTIM = AVOID.ADATTIM
        [F:SFTXN]ACTENDDATTIM = AVOID.ADATTIM
        Rewrite [F:SFTXN]
        If fstat
          #Error deleting record
          Call ERREUR(mess(67,2422,1)) From GESECRAN
          mkstat=1
          Goto DELETE_ERROR
        Endif
        For I=0 To [M:SFTEA]NBLIG-1
          If [M:SFTEA]EMPNUM(I)=[F:SFTXN]EMPNUM & [M:SFTEA]SFTTYP(I)=[F:SFTXN]SFTTYP &
&            [M:SFTEA]VCRNUM(I)=[F:SFTXN]VCRNUM &  [M:SFTEA]SFTSEQ(I)=[F:SFTXN]SFTSEQ
            [M:SFTEA]DURATION(I) = AVOID.ADEC
            [M:SFTEA]ENDDAT(I) = [0/0/0]
            [M:SFTEA]ENDTIM(I) = "0000"
            [M:SFTEA]BRKTXN(I) = ""
            Affzo [M:SFTEA]DURATION(I),ENDDAT(I),ENDTIM(I),BRKTXN(I)
            Break
          Endif
        Next
      Endif
    Next
  Endif

  #114791
  #Cascade delete
  Raz DELFLG
  Raz ICOUNT
  If SFTTXN_DEL.SFTTYP>3 & SFTTXN_DEL.TXNUUID<>AVOID.AUUIDENT
    SFTTXN_UUIDDEL = NewInstance C_SFTTXN AllocGroup null
    If SFTTXN_DEL.MACFLG=[V]CST_AYES
      For [F:SFTXN] Where SFTTYP = SFTTXN_DEL.SFTTYP & TXNUUID = SFTTXN_DEL.TXNUUID
        ICOUNT += 1
      If ICOUNT=2 : Break : Endif
      Next

      #Prompt user then delete machine/labor records with the same TXNUUID
      If ICOUNT = 2
        Call AVERTIR(mess(117,2422,1),IRET) From GESECRAN
        If IRET <> [V]CST_AYES
          mkstat = 2
          Goto DELETE_ERROR
        Endif

        For [F:SFTXN2] Where SFTTYP = SFTTXN_DEL.SFTTYP & TXNUUID = SFTTXN_DEL.TXNUUID
          If !([F:SFTXN2]EMPNUM = SFTTXN_DEL.EMPNUM & [F:SFTXN2]SFTTYP = SFTTXN_DEL.SFTTYP & [F:SFTXN2]VCRNUM = SFTTXN_DEL.VCRNUM & [F:SFTXN2]SFTSEQ = SFTTXN_DEL.SFTSEQ)
            If fmet SFTTXN_UUIDDEL.AREAD([F:SFTXN2]EMPNUM, [F:SFTXN2]SFTTYP, [F:SFTXN2]VCRNUM, [F:SFTXN2]SFTSEQ) = [V]CST_AOK
              If fmet SFTTXN_UUIDDEL.ADELETE <> [V]CST_AOK
                #Error deleting record
                Call ERREUR(mess(67,2422,1)) From GESECRAN
                mkstat=1
                Goto DELETE_ERROR
              Endif
            Endif
          Endif
        Next
        DELFLG = [V]CST_AYES
      Endif
    Else
      For [F:SFTXN] Where SFTTYP = SFTTXN_DEL.SFTTYP & TXNUUID = SFTTXN_DEL.TXNUUID & MACFLG<>[V]CST_AYES
        ICOUNT += 1
      If ICOUNT = 2 : Break : Endif
      Next

      If ICOUNT = 1
        #Delete all machine records with the same TXNUUID if the LAST labor is deleted
        For [F:SFTXN2] Where SFTTYP = SFTTXN_DEL.SFTTYP & TXNUUID = SFTTXN_DEL.TXNUUID & MACFLG = [V]CST_AYES
          If fmet SFTTXN_UUIDDEL.AREAD([F:SFTXN2]EMPNUM, [F:SFTXN2]SFTTYP, [F:SFTXN2]VCRNUM, [F:SFTXN2]SFTSEQ) = [V]CST_AOK
            If fmet SFTTXN_UUIDDEL.ADELETE <> [V]CST_AOK
              #Error deleting record
              Call ERREUR(mess(67,2422,1)) From GESECRAN
              mkstat=1
              Goto DELETE_ERROR
            Else
              DELFLG = [V]CST_AYES
            Endif
          Endif
        Next
      Endif
    Endif
  Endif

  If fmet SFTTXN_DEL.ADELETE <> [V]CST_AOK
      #Error deleting record
      Call ERREUR(mess(67,2422,1)) From GESECRAN
      mkstat=1
      Goto DELETE_ERROR
  Endif

  If DELFLG = [V]CST_AYES
    DELNOLIGN = nolign
#    nolign=[M:SFTEA]NBLIG
#    I=0
#    While I<[M:SFTEA]NBLIG
#      If [M:SFTEA]TXNUUID(I) <> AVOID.ACHAR & [M:SFTEA]TXNUUID(I) = num$(SFTTXN_DEL.TXNUUID)
#        Dela I, 1 [M:SFTEA]NBLIG
#        [M:SFTEA]NBLIG-=1
#        I-=1
#      Endif
#      I+=1
#    Wend
#    [M:SFTEA]NBLIG-=1
#    Affzo [M:SFTEA]25
    Gosub SEARCH
    nolign=[M:SFTEA]NBLIG
    Raz DELFLG
  Endif


DELETE_ERROR:
  If SFTTXN_DEL.SFTTYP>3 & SFTTXN_DEL.TXNUUID<>AVOID.AUUIDENT > 0
    FreeGroup SFTTXN_UUIDDEL
    Kill SFTTXN_UUIDDEL
  Endif

  FreeGroup SFTTXN_DEL
  Kill SFTTXN_DEL
Return

#114791
####################################################################################
Subprog CALC_ENTERED_DURATION (IDUR,INUM,ISUMEMP)
Value Decimal IDUR
Value Integer INUM    #Number of Jobs
Value Integer ISUMEMP #Number of Employees


  If INUM=0 : INUM = 1 : Endif
  If ISUMEMP=0 : ISUMEMP = 1 : Endif
  #Hidden duration field must be in minutes
  If [M:SFTEA]TIMUOMCOD(nolign-1) = 1
    [M:SFTEA]DURATION(nolign-1) = ((IDUR * ISUMEMP) / INUM) * 60
    [M:SFTEA]ELADUR(nolign-1) = (([M:SFTEA]DURATION(nolign-1) * INUM) / ISUMEMP) / 60
  Else
    [M:SFTEA]DURATION(nolign-1) = (IDUR * ISUMEMP) / INUM
    [M:SFTEA]ELADUR(nolign-1) = ([M:SFTEA]DURATION(nolign-1) * INUM) / ISUMEMP
  Endif

  Affzo [M:SFTEA]ELADUR(nolign-1)

  Call DISPLAY_DURATIONS

End


####################################################################################
Subprog CALC_DATTIM_DURATION (ISTARTDATE,ISTARTTIME,IENDDATE,IENDTIME,INUM,ISUMEMP)
Value Date ISTARTDATE
Value Char ISTARTTIME
Value Date IENDDATE
Value Char IENDTIME
Value Integer INUM    #Number of Jobs
Value Integer ISUMEMP #Number of Employees

  Local Integer   STARTHR, STARTMIN, ENDHR, ENDMIN
  Local Integer   DAYS, HOURS, MINS, ICALC
  Local Decimal   DURMINS
  Local Char      STRHOURS(2), STRMINS(2)

  If IENDDATE<>[0/0/0] & IENDTIME<>"" & ISTARTDATE<>[0/0/0] & ISTARTTIME<>""
    # Get the hours and minutes
    STARTHR   = val(mid$(ISTARTTIME,1,2))
    STARTMIN  = val(mid$(ISTARTTIME,3,2))
    ENDHR     = val(mid$(IENDTIME,1,2))
    ENDMIN    = val(mid$(IENDTIME,3,2))

    DAYS  = IENDDATE - ISTARTDATE
    HOURS = ENDHR - STARTHR
    MINS  = ENDMIN - STARTMIN

    If MINS < 0
      HOURS -= 1
      MINS += 60
    Elsif MINS >= 60
      HOURS += 1
      MINS -= 60
    Endif

    If HOURS < 0
      DAYS -= 1
      HOURS += 24
    Elsif HOURS >= 24
      DAYS += 1
      HOURS -= 24
    Endif

    # Convert the duration into minutes
    DURMINS = (DAYS * 24 * 60) + (HOURS * 60) + (MINS)

    #114791
    # Make sure we don't multiply or divide by zero
    If INUM=0 : INUM=1 : Endif
    If ISUMEMP=0 : ISUMEMP=1 : Endif
    [M:SFTEA]DURATION(nolign-1) = (DURMINS * ISUMEMP) / INUM
  Endif

  Call DISPLAY_DURATIONS
End

####################################################################################
Subprog DISPLAY_DURATIONS

  Local Char STRHOURS(2), STRMINS(2)
  Local Decimal TMPDUR
  Local Integer TMPNUMJOBS, TMPSUMEMP

  # Take the saved duration and convert properly to Visible duration fields

  # If zero - clear out and exit
  If [M:SFTEA]DURATION(nolign-1)<=0
    [M:SFTEA]LABDUR(nolign-1)   = 0
    #[M:SFTEA]MACHDUR(nolign-1)  = 0 #119090.o
    Affzo [M:SFTEA]LABDUR(nolign-1)
    #Affzo [M:SFTEA]MACHDUR(nolign-1) #119090.o
    End
  Endif

  #Calculate activity duration
  If [M:SFTEA]TIMUOMCOD(nolign-1) = 1
    [M:SFTEA]LABDUR(nolign-1) = [M:SFTEA]DURATION(nolign-1) / 60
  Else
    [M:SFTEA]LABDUR(nolign-1) = [M:SFTEA]DURATION(nolign-1)
  Endif

  Affzo [M:SFTEA]LABDUR(nolign-1)

#119090.so
#Changed NUMMAC field to boolean
#Removed machine duration display [M]MACHDUR from the grid
#  If [M:SFTEA]SFTTYP(nolign-1)>3
#    TMPDUR = [M:SFTEA]DURATION(nolign-1)
#
#    #114791 Machine duration display
#    If func SFTLIB.ISMACHINE([M:SFTEA]WCENTER(nolign-1),[M:SFTEA]FCY(nolign-1)) = [V]CST_AYES
#      If [M:SFTEA]SFTTYP(nolign-1)=5
#        TMPDUR = TMPDUR * [M:SFTEA]NUMMAC(nolign-1)
#      Endif
#    Else
#      TMPDUR = 0
#    Endif
#
#    If [M:SFTEA]TIMUOMCOD(nolign-1) = 1
#      [M:SFTEA]MACHDUR(nolign-1) = TMPDUR / 60
#    Else
#      [M:SFTEA]MACHDUR(nolign-1) = TMPDUR
#    Endif
#
#    Affzo [M:SFTEA]MACHDUR(nolign-1)
#  Endif
#119090.eo

End

####################################################################################
Funprog GETEMPDES(EMPNUM)
Value Integer EMPNUM
  Local Char EMPDESC(30)

  Read [F:TMA]TMA0=EMPNUM
  [L]EMPDESC = [F:TMA]EMPDES

End EMPDESC

####################################################################################
Funprog GET_TIMUOMCOD(SFTTYP, INDTYP, UOMMFGNUM, UOMOPENUM)
Value Integer SFTTYP
Value Integer INDTYP
Value Char    UOMMFGNUM
Value Integer UOMOPENUM

  Local Integer UOMCOD

  # Default the time unit to minutes
  UOMCOD = 2

  # If PTO or Clock in out - change to hours
  If (SFTTYP = 2 & INDTYP = 1) | SFTTYP = 1
    UOMCOD = 1
  Endif

  # If Run or Setup - get from operation
  If SFTTYP > 3 & UOMMFGNUM <> "" & UOMOPENUM > 0
    Filter [MFO] Where MFGNUM = UOMMFGNUM & OPENUM = UOMOPENUM
    Read [MFO]MFO0 First
    Filter [MFO]
    UOMCOD = [F:MFO]TIMUOMCOD
  Endif

End UOMCOD

####################################################################################
Subprog VALIDATE_BREAK(BRKEND)
Value Date BRKEND
  Local Integer OPEN

  If [M:SFTEA]SFTTYP(nolign-1)=3 | ([M:SFTEA]SFTTYP(nolign-1)=2 & [M:SFTEA]INDTYP(nolign-1)=4)
    If BRKEND<>[0/0/0] & [M:SFTEA]BRKTXN(nolign-1)<>""
      Call OUINON(mess(45,2422,1), OPEN) From GESECRAN
      [M:SFTEA]BRKOPEN(nolign-1) = OPEN
    Endif
  Endif

End

####################################################################################
# Screen Field Actions
####################################################################################

####################################################################################
Subprog AV_EMPNUM(VALEUR)
Variable Decimal VALEUR


  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

#  If DELFLG = [V]CST_AYES
#   If nolign >= [M]NBLIG+2 | nolign = DELNOLIGN
#      End
#   Endif
#  Endif

  If VALEUR=0 #| [M:SFTEA]CREFLG(nolign-1)=2
    Actzo [M:SFTEA]EMPNUM(nolign-1)
  Else
    #Grizo [M:SFTEA]EMPNUM(nolign-1)
    Diszo [M:SFTEA]EMPNUM(nolign-1)
  Endif

End

####################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal VALEUR

  Local Integer IACTIVE
  Local Char    EMPID(100)

  Call TEXTE(10793,EMPID) From OBJDIV
  IACTIVE =  func SFTLIB.EMPLOYEEACTIVE(VALEUR)

  If IACTIVE = [V]CST_ANO
    #Inactive record
    Call ERREUR(EMPID - ":" - num$(VALEUR) - " \" + mess(2,126,1)) From GESECRAN
    mkstat = 2
    End
  Endif

  #114791
  If func SFTLIB.EMPTYP(VALEUR)=2 #Detailed Team
    #Only Employee and Summary team records can be entered
    Call ERREUR(mess(115,2422,1)) From GESECRAN
    mkstat = 2
  Endif

End

####################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR

  # set the create flag so that the save action knows to write a new record
  [M:SFTEA]CREFLG(nolign-1) = [V]CST_AYES

  #114791
  #Default team number and number of employees
  Read [TMA]TMA0=VALEUR
  If !fstat
    If [TMA]EMPTYP=3 #Summary team
      [M:SFTEA]TEAMNUM(nolign-1) = VALEUR
      [M:SFTEA]SUMEMP(nolign-1)  = [TMA]SUMEMP
      Affzo [M:SFTEA]TEAMNUM(nolign-1)
      Affzo [M:SFTEA]SUMEMP(nolign-1)
    Endif
  Endif

End

####################################################################################
Subprog AV_EMPDES(VALEUR)
Variable Char    VALEUR()

  If DELFLG = [V]CST_AYES
    If nolign >= [M]NBLIG+2 : End : Endif
  Else
    VALEUR = func GETEMPDES([M:SFTEA]EMPNUM(nolign-1))
  Endif

End

####################################################################################
Subprog AV_FCY(VALEUR)
Variable Char VALEUR()

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]FCY(nolign-1)
    End
  Endif

  If [M:SFTEA]SFTSEQ(nolign-1)=0
    Affzo [M:SFTEA]SFTTYP(nolign-1)
  Endif

  If VALEUR="" #| [M:SFTEA]CREFLG(nolign-1)=2
    Actzo [M:SFTEA]FCY(nolign-1)
  Else
    Grizo [M:SFTEA]FCY(nolign-1)
  Endif

End

####################################################################################
Subprog AM_FCY(VALEUR)
Variable Char VALEUR()

  Local Date SHIDAT
  Local Char SHITIM(4)

  #Default shift date by calling timestamp
  If [M:SFTEA]SHIFTDAT(nolign-1)=[0/0/0]
    Call TIMESTAMP(VALEUR,SHIDAT,SHITIM) From SFTLIB

    If SHIDAT<>[0/0/0]
      [M:SFTEA]SHIFTDAT(nolign-1) = SHIDAT
      Affzo SHIFTDAT(nolign-1)
    Endif
  Endif

End

####################################################################################
Subprog AV_SFTTYP(VALEUR)
Variable Integer VALEUR

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If VALEUR=0 #| [M:SFTEA]CREFLG(nolign-1)=2
    Actzo [M:SFTEA]SFTTYP(nolign-1)
  Else
    Grizo [M:SFTEA]SFTTYP(nolign-1)
  Endif

End

####################################################################################
Subprog AM_SFTTYP(VALEUR)
Variable Integer VALEUR

  Local Integer I : I = (nolign-1)
  [M:SFTEA]TIMUOMCOD(I) = func GET_TIMUOMCOD(VALEUR, [M:SFTEA]INDTYP(I), [M:SFTEA]VCRNUM(I), [M:SFTEA]OPENUM(I))
  Affzo [M:SFTEA]TIMUOMCOD(I)

End

####################################################################################
Subprog AV_SHIFTDAT(VALEUR)
Variable Date    VALEUR

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]SHIFTDAT(nolign-1)
    End
  Endif

  If ([M:SFTEA]SFTSEQ(nolign-1)>0 & (
&    ([M:SFTEA]SFTTYP(nolign-1)>1 & [M:SFTEA]STRDAT(nolign-1)=[0/0/0] & [M:SFTEA]ENDDAT(nolign-1)=[0/0/0]) | (
&    ([M:SFTEA]SFTTYP(nolign-1)>3 | ([M:SFTEA]SFTTYP(nolign-1)=2 & [M:SFTEA]INDTYP(nolign-1)<>4)) & [M:SFTEA]BRKTXN(nolign-1)<>"") ) ) |
&    ([M:SFTEA]SFTSEQ(nolign-1)=0 & [M:SFTEA]DURATION(nolign-1)>0 & [M:SFTEA]STRDAT(nolign-1)=[0/0/0])
    Grizo [M:SFTEA]SHIFTDAT(nolign-1)
  Else
    Actzo [M:SFTEA]SHIFTDAT(nolign-1)
  Endif

End

####################################################################################
Subprog C_SHIFTDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR<>[0/0/0]
    If [M:SFTEA]STRDAT(nolign-1)<>[0/0/0]
      If VALEUR>[M:SFTEA]STRDAT(nolign-1)
        #Shift date is greater than start date
        Call ERREUR(mess(35,2422,1)) From GESECRAN
        mkstat = 2
        End
      Endif
    Endif

    If [M:SFTEA]ENDDAT(nolign-1)<>[0/0/0]
      If VALEUR>[M:SFTEA]ENDDAT(nolign-1)
        #Shift date is greater than end date
        Call ERREUR(mess(38,2422,1)) From GESECRAN
        mkstat = 2
        End
      Endif
    Endif
  Endif

End

####################################################################################
Subprog AV_STRDAT(VALEUR)
Variable Date    VALEUR

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]STRDAT(nolign-1)
    End
  Endif

  If ([M:SFTEA]SFTSEQ(nolign-1)>0 & (
&    ([M:SFTEA]SFTTYP(nolign-1)>1 & [M:SFTEA]STRDAT(nolign-1)=[0/0/0] & [M:SFTEA]ENDDAT(nolign-1)=[0/0/0]) | (
&    ([M:SFTEA]SFTTYP(nolign-1)>3 | ([M:SFTEA]SFTTYP(nolign-1)=2 & [M:SFTEA]INDTYP(nolign-1)<>4)) & [M:SFTEA]BRKTXN(nolign-1)<>"") ) ) |
&    ([M:SFTEA]SFTSEQ(nolign-1)=0 & [M:SFTEA]DURATION(nolign-1)>0 & [M:SFTEA]STRDAT(nolign-1)=[0/0/0])
    Grizo [M:SFTEA]STRDAT(nolign-1)
  Else
    Actzo [M:SFTEA]STRDAT(nolign-1)
  Endif

End

####################################################################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR<>[0/0/0]
    If [M:SFTEA]ENDDAT(nolign-1)<>[0/0/0]
      If VALEUR>[M:SFTEA]ENDDAT(nolign-1)
        #The start date is greater than the end date
        Call ERREUR(mess(81,7711,1)) From GESECRAN
        mkstat = 2
        End
      Endif
    Endif

    If VALEUR<[M:SFTEA]SHIFTDAT(nolign-1)
      #Shift date is greater than start date
      Call ERREUR(mess(35,2422,1)) From GESECRAN
      mkstat = 2
      End
    Endif
  Else
    If [M:SFTEA]SFTTYP(nolign-1)=1
      #Mandatory field
      Call ERREUR(mess(10,123,1)) From GESECRAN
      mkstat = 2
      End
    Endif
  Endif
End

####################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR=[0/0/0]
    # If no start date - start time must also be blank
    [M:SFTEA]STRTIM(nolign-1)=""
    # If we changed the start date from something to blank - we need to set duration to 0
    If [M:SFTEA]STRDAT(nolign-1)<>[0/0/0]
      [M:SFTEA]DURATION(nolign-1)=0
    Endif
  Endif

  Call CALC_DATTIM_DURATION(VALEUR,[M:SFTEA]STRTIM(nolign-1),[M:SFTEA]ENDDAT(nolign-1),[M:SFTEA]ENDTIM(nolign-1),[M:SFTEA]NUMJOBS(nolign-1),[M:SFTEA]SUMEMP(nolign-1))

End

####################################################################################
Subprog AV_STRTIM(VALEUR)
Variable Char    VALEUR()

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]STRTIM(nolign-1)
    End
  Endif

  If ([M:SFTEA]SFTSEQ(nolign-1)>0 & (
&    ([M:SFTEA]SFTTYP(nolign-1)>1 & [M:SFTEA]STRDAT(nolign-1)=[0/0/0] & [M:SFTEA]ENDDAT(nolign-1)=[0/0/0]) | (
&    ([M:SFTEA]SFTTYP(nolign-1)>3 | ([M:SFTEA]SFTTYP(nolign-1)=2 & [M:SFTEA]INDTYP(nolign-1)<>4)) & [M:SFTEA]BRKTXN(nolign-1)<>"") ) ) |
&    ([M:SFTEA]SFTSEQ(nolign-1)=0 & [M:SFTEA]DURATION(nolign-1)>0 & [M:SFTEA]STRDAT(nolign-1)=[0/0/0])
    Grizo [M:SFTEA]STRTIM(nolign-1)
  Else
    Actzo [M:SFTEA]STRTIM(nolign-1)
  Endif

End

####################################################################################
Subprog C_STRTIM(VALEUR)
Variable Char    VALEUR()

  # no need to check time if end date is greater than start date
  If [M:SFTEA]STRDAT(nolign-1)=[M:SFTEA]ENDDAT(nolign-1)
    If [M:SFTEA]ENDTIM(nolign-1)<>"" & VALEUR>[M:SFTEA]ENDTIM(nolign-1)
      #Start time is greater than end time
      Call ERREUR(mess(29,9951,1)) From GESECRAN
      mkstat = 2
      End
    Endif
  Endif

End

####################################################################################
Subprog AM_STRTIM(VALEUR)
Variable Char    VALEUR()

  Call CALC_DATTIM_DURATION([M:SFTEA]STRDAT(nolign-1),VALEUR,[M:SFTEA]ENDDAT(nolign-1),VALEUR,[M:SFTEA]NUMJOBS(nolign-1),[M:SFTEA]SUMEMP(nolign-1))

End

####################################################################################
Subprog AV_ENDDAT(VALEUR)
Variable Date    VALEUR

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]ENDDAT(nolign-1)
    End
  Endif

  If ([M:SFTEA]SFTSEQ(nolign-1)>0 & (
&    ([M:SFTEA]SFTTYP(nolign-1)>1 & [M:SFTEA]STRDAT(nolign-1)=[0/0/0] & [M:SFTEA]ENDDAT(nolign-1)=[0/0/0]) | (
&    ([M:SFTEA]SFTTYP(nolign-1)>3 | ([M:SFTEA]SFTTYP(nolign-1)=2 & [M:SFTEA]INDTYP(nolign-1)<>4)) & [M:SFTEA]BRKTXN(nolign-1)<>"") ) ) |
&    ([M:SFTEA]SFTSEQ(nolign-1)=0 & [M:SFTEA]DURATION(nolign-1)>0 & [M:SFTEA]STRDAT(nolign-1)=[0/0/0])
    Grizo [M:SFTEA]ENDDAT(nolign-1)
  Else
    Actzo [M:SFTEA]ENDDAT(nolign-1)
  Endif

End

####################################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR<>[0/0/0]
    If [M:SFTEA]STRDAT(nolign-1)<>[0/0/0]
      If VALEUR<[M:SFTEA]STRDAT(nolign-1)
        #The start date is greater than the end date
        Call ERREUR(mess(81,7711,1)) From GESECRAN
        mkstat = 2
        End
      Endif
    Endif

    If VALEUR<[M:SFTEA]SHIFTDAT(nolign-1)
      #Shift date is greater than end date
      Call ERREUR(mess(38,2422,1)) From GESECRAN
      mkstat = 2
      End
    Endif
  Endif

End

####################################################################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR

  Call VALIDATE_BREAK(VALEUR)

  If VALEUR=[0/0/0]
    # If no end date - end time must also be blank
    [M:SFTEA]ENDTIM(nolign-1)=""
    # If we changed the end date from something to blank - we need to set duration to 0
    If [M:SFTEA]ENDDAT(nolign-1)<>[0/0/0]
      [M:SFTEA]DURATION(nolign-1)=0
    Endif
  Endif

  Call CALC_DATTIM_DURATION([M:SFTEA]STRDAT(nolign-1),[M:SFTEA]STRTIM(nolign-1),VALEUR,[M:SFTEA]ENDTIM(nolign-1),[M:SFTEA]NUMJOBS(nolign-1),[M:SFTEA]SUMEMP(nolign-1))

End

####################################################################################
Subprog AV_ENDTIM(VALEUR)
Variable Char    VALEUR()

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]ENDTIM(nolign-1)
    End
  Endif

  If ([M:SFTEA]SFTSEQ(nolign-1)>0 & (
&    ([M:SFTEA]SFTTYP(nolign-1)>1 & [M:SFTEA]STRDAT(nolign-1)=[0/0/0] & [M:SFTEA]ENDDAT(nolign-1)=[0/0/0]) | (
&    ([M:SFTEA]SFTTYP(nolign-1)>3 | ([M:SFTEA]SFTTYP(nolign-1)=2 & [M:SFTEA]INDTYP(nolign-1)<>4)) & [M:SFTEA]BRKTXN(nolign-1)<>"") ) ) |
&    ([M:SFTEA]SFTSEQ(nolign-1)=0 & [M:SFTEA]DURATION(nolign-1)>0 & [M:SFTEA]STRDAT(nolign-1)=[0/0/0])
    Grizo [M:SFTEA]ENDTIM(nolign-1)
  Else
    Actzo [M:SFTEA]ENDTIM(nolign-1)
  Endif

End

####################################################################################
Subprog C_ENDTIM(VALEUR)
Variable Char    VALEUR()

  # no need to check time if end date is greater than start date
  If [M:SFTEA]STRDAT(nolign-1)=[M:SFTEA]ENDDAT(nolign-1)
    If [M:SFTEA]STRTIM(nolign-1)<>"" & VALEUR<[M:SFTEA]STRTIM(nolign-1)
      #Start time is greater than end time
      Call ERREUR(mess(29,9951,1)) From GESECRAN
      mkstat = 2
      End
    Endif
  Endif

End

####################################################################################
Subprog AM_ENDTIM(VALEUR)
Variable Char    VALEUR()

  Call CALC_DATTIM_DURATION([M:SFTEA]STRDAT(nolign-1),[M:SFTEA]STRTIM(nolign-1),[M:SFTEA]ENDDAT(nolign-1),VALEUR,[M:SFTEA]NUMJOBS(nolign-1),[M:SFTEA]SUMEMP(nolign-1))

End

####################################################################################
Subprog AV_INDREF(VALEUR)
Variable Char    VALEUR()

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]INDREF(nolign-1)
    End
  Endif

  Case [M:SFTEA]SFTTYP(nolign-1)
    When 3   # Break
      Actzo [M:SFTEA]INDREF(nolign-1)
    When 2  # Indirect - only enable if exclusive or break txn is blank
      If [M:SFTEA]BRKTXN(nolign-1)="" | [M:SFTEA]INDTYP(nolign-1)=4
        Actzo [M:SFTEA]INDREF(nolign-1)
      Else
        Grizo [M:SFTEA]INDREF(nolign-1)
      Endif
    When Default
      Grizo [M:SFTEA]INDREF(nolign-1)
  Endcase

End

####################################################################################
Subprog C_INDREF(VALEUR)
Variable Char    VALEUR()

  If VALEUR=""
    #Mandatory field
    Call ERREUR(mess(10,123,1)) From GESECRAN
    mkstat = 2
    End
  Endif

  Read [F:SFTIR]SFTAG0=VALEUR
  If !fstat
    If [M:SFTEA]SFTTYP(nolign-1)=2 #Indirect
      If find([F:SFTIR]INDTYP,2,5)
        #Invalid indirect references
        Call ERREUR(mess(41,2422,1)) From GESECRAN
        mkstat = 2
        End
      Endif
    Endif

    If [M:SFTEA]SFTTYP(nolign-1)=3 #Break
      If find([F:SFTIR]INDTYP,1,3,4,5)
        #Invalid break
        Call ERREUR(mess(69,2422,1)) From GESECRAN
        mkstat = 2
        End
      Endif
    Endif
  Endif

End

####################################################################################
Subprog AM_INDREF(VALEUR)
Variable Char    VALEUR()

  Local Integer I : I = (nolign-1)

  #Reset number of jobs value back to 1 if original value is nonexclusive indirect
  If VALEUR<>"" & [M:SFTEA]INDREF(I)<>""
    If [M:SFTEA]INDTYP(I)=3
      [M:SFTEA]NUMJOBS(I)=1
    Endif
  Endif

  If [M:SFTEA]SFTTYP(I)=2 | [M:SFTEA]SFTTYP(I)=3
    Read [F:SFTIR]SFTAG0=VALEUR
    If !fstat : [M:SFTEA]INDTYP(I) = [F:SFTIR]INDTYP : Endif
  Endif

  [M:SFTEA]TIMUOMCOD(I) = func GET_TIMUOMCOD([M:SFTEA]SFTTYP(I), [M:SFTEA]INDTYP(I), [M:SFTEA]VCRNUM(I), [M:SFTEA]OPENUM(I))
  Affzo [M:SFTEA]TIMUOMCOD(I)

End

####################################################################################
Subprog AV_VCRNUM(VALEUR)
Variable Char    VALEUR()

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]VCRNUM(nolign-1)
    End
  Endif

  If [M:SFTEA]SFTSEQ(nolign-1)=0 & [M:SFTEA]SFTTYP(nolign-1)>3 & [M:SFTEA]BRKTXN(nolign-1)=""
    Actzo [M:SFTEA]VCRNUM(nolign-1)
  Else
    Grizo [M:SFTEA]VCRNUM(nolign-1)
  Endif

End

####################################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()

  Local Char PARAMRET(4)
  Local Integer MTKALLMGT, DOSFAB

  If VALEUR=""
    #Mandatory field
    Call ERREUR(mess(10,123,1)) From GESECRAN
    mkstat = 2
    End
  Endif

  #Copied from SUBMTK
  If [M:SFTEA]SFTTYP(nolign-1)>3
    Read [F:MFG]MFG0=VALEUR
    If !fstat
        #Work order does not exist at the site
        If [F:MFG]MFGFCY<>[M:SFTEA]FCY(nolign-1) : Call ERREUR(mess(51,2422,1)) From GESECRAN  :  mkstat = 2 : End : Endif

        #This WO Status cannot be tracked
        If [F:MFG]MFGSTA<>1 : Call ERREUR(mess(19,190,1)) From GESECRAN  :  mkstat = 2 : End : Endif

        #This WO is suspended: tracking is not possible
        If [F:MFG]SUSFLG=2  : Call ERREUR(mess(180,190,1)) From GESECRAN :  mkstat = 2 : End : Endif

        Call PARAM([M:SFTEA]FCY(nolign-1),"MTKALLMGT",PARAMRET) From ADOVAL
        MTKALLMGT = val(PARAMRET)
        #Allocation incomplete. Tracking not possible
        If MTKALLMGT = [V]CST_AYES & !find([F:MFG]ALLSTA,3,5)  # Alloc status: 3-Complete; 5-Complete/Shortage
            Call ERREUR(mess(18,190,1)) From GESECRAN
            mkstat = 2
            End
        Endif

        Raz PARAMRET
        Call PARAM([M:SFTEA]FCY(nolign-1),"DOSFAB",PARAMRET) From ADOVAL
        DOSFAB = val(PARAMRET)
        #The WO is not printed: tracking not possible
        If [F:MFG]MFGTRKFLG<3 & DOSFAB=2 : Call ERREUR(mess(20,190,1)) From GESECRAN : mkstat = 2 : End : Endif

    Else
        #Record does not exist
        Call ERREUR(mess(23,100,1)) From GESECRAN
        mkstat = 2
        End
    Endif
  Endif

End

######################################################################################
Subprog AM_VCRNUM(VALEUR)
Variable Char    VALEUR()

  Local Integer I : I = (nolign-1)
  [M:SFTEA]TIMUOMCOD(I) = func GET_TIMUOMCOD([M:SFTEA]SFTTYP(I), [M:SFTEA]INDTYP(I), VALEUR, [M:SFTEA]OPENUM(I))
  Affzo [M:SFTEA]TIMUOMCOD(I)

End

####################################################################################
Subprog AV_OPENUM(VALEUR)
Variable Decimal  VALEUR

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]OPENUM(nolign-1)
    End
  Endif

  If [M:SFTEA]SFTSEQ(nolign-1)=0 & [M:SFTEA]SFTTYP(nolign-1)>3 & [M:SFTEA]VCRNUM(nolign-1)<>"" & [M:SFTEA]BRKTXN(nolign-1)=""
    Actzo [M:SFTEA]OPENUM(nolign-1)
  Else
    Grizo [M:SFTEA]OPENUM(nolign-1)
  Endif

End

####################################################################################
Subprog C_OPENUM(VALEUR)
Variable Decimal VALEUR

  Local Char PARAMRET(4)
  Local Integer CTLOPEPRE, OPERPREC, ALLOW_IT

  If [M:SFTEA]VCRNUM(nolign-1)<>""
    Filter [MFO] Where MFGNUM = [M:SFTEA]VCRNUM(nolign-1) & OPENUM = VALEUR
    Read [MFO]MFO0 First
    Filter [MFO]
    If !fstat
      #Operation status cannot be closed, excluded, or ordered
      If [F:MFO]OPESTA >= 5 : Call ERREUR(mess(50,2422,1)) From GESECRAN  :  mkstat = 2 : End : Endif

      If [F:MFO]EXTWST<>""
        Read [MWS]WST0=[F:MFO]EXTWST;[M:SFTEA]FCY(nolign-1)
        If !fstat
          If [F:MWS]WSTTYP=3
            #Work center type cannot be subcontract
            Call ERREUR(mess(52,2422,1)) From GESECRAN
            mkstat = 2
            End
          Endif
        Endif
      Endif

      If [F:MFO]EXTLAB<>""
        Read [MWS]WST0=[F:MFO]EXTLAB;[M:SFTEA]FCY(nolign-1)
        If !fstat
          If [F:MWS]WSTTYP=3
            #Labor center type cannot be subcontract
            Call ERREUR(mess(55,2422,1)) From GESECRAN
            mkstat = 2
            End
          Endif
        Endif
      Endif

      Call PARAM([M:SFTEA]FCY(nolign-1),"CTLOPEPRE",PARAMRET) From ADOVAL
      CTLOPEPRE = val(PARAMRET)

      #Invalid if GCTLOPEPRE = 3 and prior operation has not been run.
      If CTLOPEPRE > 1
        OPERPREC = 0
        # Find the prior operation number
        Filter [SCH] Where MFGNUM = [M:SFTEA]VCRNUM(nolign-1) & NEXOPENUM = VALEUR
        Read [SCH]SCH0 First
        Filter [SCH]
        If !fstat : OPERPREC = [F:SCH]OPENUM : Endif
        If OPERPREC<>0
          # Check if prior marked complete in MFG Operations table
           Filter [MFO] Where MFGNUM = [M:SFTEA]VCRNUM(nolign-1) & OPENUM = OPERPREC
           Read [MFO]MFO0 First
           Filter [MFO]
           If !fstat & [F:MFO]OPESTA < 5
             # This operation is not closed in the MFG tables - see if closed in SFTTXN tables
             Filter [F:SFTXN] Where [F:SFTXN]VCRNUM = [M:SFTEA]VCRNUM(nolign-1) &
&                                      [F:SFTXN]OPENUM = OPERPREC &
&                                      [F:SFTXN]CLEFLG = [V]CST_AYES
             Read [F:SFTXN]SFT0 First
             Filter [F:SFTXN]
             If fstat <> 0
               ALLOW_IT = [V]CST_ANO
               If CTLOPEPRE=2
                 Call AVERTIR(mess(22,190,1)-num$([L]OPERPREC),ALLOW_IT) From GESECRAN
               Else
                 Call ERREUR(mess(22,190,1)-num$([L]OPERPREC)) From GESECRAN
               Endif
               If ALLOW_IT=[V]CST_ANO : mkstat = 2 : End : Endif
             Endif
           Endif
         Endif
      Endif
    Else
       #Invalid Operation
      Call ERREUR(mess(58,123,1)) From GESECRAN
      mkstat = 2
      End
    Endif
  Endif

End

####################################################################################
Subprog AM_OPENUM(VALEUR)
Variable Decimal VALEUR

  Local Integer I : I = (nolign-1)
  Local Integer TMPMCH #119090.n


  #114791
  [M:SFTEA]TIMUOMCOD(I) = func GET_TIMUOMCOD([M:SFTEA]SFTTYP(I), [M:SFTEA]INDTYP(I), [M:SFTEA]VCRNUM(I), VALEUR)
  Affzo [M:SFTEA]TIMUOMCOD(I)

  #Default work center and labor center from the work order
  If [M:SFTEA]VCRNUM(I)<>"" & VALEUR<>0
    Filter [MFO] Where MFGNUM = [M:SFTEA]VCRNUM(I) & OPENUM = VALEUR
    Read [MFO]MFO0 First
    Filter [MFO]
    If !fstat
      [M:SFTEA]WCENTER(I)   = [F:MFO]EXTWST
      [M:SFTEA]LCENTER(I)   = [F:MFO]EXTLAB
      #[M:SFTEA]NUMMAC(I)   = [F:MFO]EXTWSTNBR #119090.o
      [M:SFTEA]OPEUOM(I)    = [F:MFO]OPEUOM
      [M:SFTEA]TIMUOMCOD(I) = [F:MFO]TIMUOMCOD

      TMPMCH = [V]CST_ANO #119090.n

      #114791
      Read [MWS]WST0=[M:SFTEA]WCENTER(I);[M:SFTEA]FCY(I)
      If !fstat
        If [F:MWS]WSTTYP=1 #Machine
          #119090.sn
          #If [M:SFTEA]SFTTYP(I)=4:[M:SFTEA]NUMMAC(I)=1:Endif
          TMPMCH = [V]CST_AYES #Default to checked if primary workcenter is machine
          #119090.en
          If func SFTLIB.EMPTYP([M:SFTEA]EMPNUM(I))=3 & [M:SFTEA]LCENTER(I) = ""
            [M:SFTEA]SUMEMP(I)= 0 #Default number of employees to 0 for summary teams and work center is machine only
          Endif
        Endif
        #119090.so
        #If [F:MWS]WSTTYP=2 #Labor
        #  If [M:SFTEA]NUMMAC(I)>0:[M:SFTEA]NUMMAC(I)=0:Endif
        #Endif
        #119090.eo
      Endif

      [M:SFTEA]NUMMAC(I) = TMPMCH #119090.n

      Affzo [M:SFTEA]LCENTER(I), WCENTER(I), NUMMAC(I), OPEUOM(I), TIMUOMCOD(I), SUMEMP(I)
    Endif
  Endif

End

####################################################################################
Subprog AV_CPLQTY(VALEUR)
Variable Decimal VALEUR

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]CPLQTY(nolign-1)
    End
  Endif

  If [M:SFTEA]SFTTYP(nolign-1)=5 & [M:SFTEA]BRKTXN(nolign-1)=""
    Actzo [M:SFTEA]CPLQTY(nolign-1)
  Else
    Grizo [M:SFTEA]CPLQTY(nolign-1)
  Endif

End

####################################################################################
Subprog C_CPLQTY(VALEUR)
Variable Decimal VALEUR

  If VALEUR < [M:SFTEA]REJCPLQTY(nolign-1)
    #Rejected qty cannot be more than completed qty
    Call ERREUR(mess(25,2422,1)) From GESECRAN
    VALEUR = 0
    OK = 1
    mkstat = 1
  Endif

End

####################################################################################
Subprog AV_REJCPLQTY(VALEUR)
Variable Decimal VALEUR

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]REJCPLQTY(nolign-1)
    End
  Endif

  If [M:SFTEA]SFTTYP(nolign-1)=5 & [M:SFTEA]CPLQTY(nolign-1)>0 & [M:SFTEA]BRKTXN(nolign-1)=""
    Actzo [M:SFTEA]REJCPLQTY(nolign-1)
  Else
    Grizo [M:SFTEA]REJCPLQTY(nolign-1)
  Endif

End

####################################################################################
Subprog C_REJCPLQTY(VALEUR)
Variable Decimal VALEUR

  If VALEUR > [M:SFTEA]CPLQTY(nolign-1)
    #Rejected qty cannot be more than completed qty
    Call ERREUR(mess(25,2422,1)) From GESECRAN
    VALEUR = 0
    OK = 1
    mkstat = 1
  Endif

End

####################################################################################
Subprog AM_REJCPLQTY(VALEUR)
Variable Decimal VALEUR

  #Reset rejection code field
  If VALEUR=0 : [M:SFTEA]SCANUM(nolign-1) = 0 : Endif

End

####################################################################################
Subprog AV_SCANUM(VALEUR)
Variable Decimal VALEUR

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]SCANUM(nolign-1)
    End
  Endif

  If [M:SFTEA]SFTTYP(nolign-1)=5 & [M:SFTEA]REJCPLQTY(nolign-1)>0 & [M:SFTEA]BRKTXN(nolign-1)=""
    Actzo [M:SFTEA]SCANUM(nolign-1)
  Else
    Grizo [M:SFTEA]SCANUM(nolign-1)
  Endif

End

####################################################################################
Subprog C_SCANUM(VALEUR)
Variable Decimal VALEUR

  Local Char WSCANUM(12) : WSCANUM = num$(VALEUR)
  If VALEUR <> 0
    Call CONTROLE("TSR","",WSCANUM,"",mkstat) From CONTOBJ
  Endif

End

####################################################################################
Subprog AV_NUMJOBS(VALEUR)
Variable Decimal  VALEUR

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]NUMJOBS(nolign-1)
    End
  Endif

  If (([M:SFTEA]SFTTYP(nolign-1)=2 & [M:SFTEA]INDTYP(nolign-1)=3) | [M:SFTEA]SFTTYP(nolign-1)>3) & [M:SFTEA]BRKTXN(nolign-1)=""
    Actzo [M:SFTEA]NUMJOBS(nolign-1)
  Else
    Grizo [M:SFTEA]NUMJOBS(nolign-1)
  Endif

End

####################################################################################
Subprog AM_NUMJOBS(VALEUR)
Variable Decimal  VALEUR

  #114791
  If [M:SFTEA]STRDAT(nolign-1)=[0/0/0]
    Call CALC_ENTERED_DURATION([M:SFTEA]ELADUR(nolign-1),VALEUR,[M:SFTEA]SUMEMP(nolign-1))
  Else
    Call CALC_DATTIM_DURATION([M:SFTEA]STRDAT(nolign-1),[M:SFTEA]STRTIM(nolign-1),[M:SFTEA]ENDDAT(nolign-1),[M:SFTEA]ENDTIM(nolign-1),VALEUR,[M:SFTEA]SUMEMP(nolign-1))
  Endif

End

####################################################################################
Subprog AV_NUMMAC(VALEUR)
Variable Integer VALEUR

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]NUMMAC(nolign-1)
    End
  Endif

  Local Integer ENABLEFLG

  Raz ENABLEFLG

  #114791
  If [M:SFTEA]SFTTYP(nolign-1)>3 & [M:SFTEA]BRKTXN(nolign-1)=""
    If func SFTLIB.ISMACHINE([M:SFTEA]WCENTER(nolign-1),[M:SFTEA]FCY(nolign-1)) = [V]CST_AYES
      If [M:SFTEA]LCENTER(nolign-1)<>"" #119090.n Only enable if its Machine-Labor
        ENABLEFLG = 1
      Endif
    Endif
  Endif

  If ENABLEFLG = 1
    Actzo [M:SFTEA]NUMMAC(nolign-1)
  Else
    Grizo [M:SFTEA]NUMMAC(nolign-1)
  Endif
End

