####################################################################################
Subprog AV_SUMEMP(VALEUR)
Variable Decimal  VALEUR

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]SUMEMP(nolign-1)
    End
  Endif

  Local Integer ENABLEFLG

  Raz ENABLEFLG

  If [M:SFTEA]SFTTYP(nolign-1)>3 & [M:SFTEA]BRKTXN(nolign-1)=""
    If func SFTLIB.EMPTYP([M:SFTEA]EMPNUM(nolign-1))=3 #Summary Team
      If !(func SFTLIB.ISMACHINE([M:SFTEA]WCENTER(nolign-1),[M:SFTEA]FCY(nolign-1))=[V]CST_AYES & [M:SFTEA]WCENTER(nolign-1)<>"" & [M:SFTEA]LCENTER(nolign-1)="")
        ENABLEFLG = 1
      Endif
    Endif
  Endif

  If ENABLEFLG = 1
    Actzo [M:SFTEA]SUMEMP(nolign-1)
  Else
    Grizo [M:SFTEA]SUMEMP(nolign-1)
  Endif

End

####################################################################################
Subprog C_SUMEMP(VALEUR)
Variable Decimal  VALEUR

  If VALEUR=0 & func SFTLIB.EMPTYP([M:SFTEA]EMPNUM(nolign-1))=3 #Summary Team
    Read [MWS]WST0=[M:SFTEA]WCENTER(nolign-1);[M:SFTEA]FCY(nolign-1)
    If !fstat & [F:MWS]WSTTYP=2 #Labor
      #Mandatory field
      Call ERREUR(mess(10,123,1)) From GESECRAN
      mkstat = 2
      End
    Endif
  Endif

End

####################################################################################
Subprog AM_SUMEMP(VALEUR)
Variable Decimal  VALEUR

  If [M:SFTEA]STRDAT(nolign-1)=[0/0/0]
    Call CALC_ENTERED_DURATION([M:SFTEA]ELADUR(nolign-1),[M:SFTEA]NUMJOBS(nolign-1),VALEUR)
  Else
    Call CALC_DATTIM_DURATION([M:SFTEA]STRDAT(nolign-1),[M:SFTEA]STRTIM(nolign-1),[M:SFTEA]ENDDAT(nolign-1),[M:SFTEA]ENDTIM(nolign-1),[M:SFTEA]NUMJOBS(nolign-1),VALEUR)
  Endif

End

####################################################################################
Subprog AV_ELADUR(VALEUR)
Variable Decimal    VALEUR()

  If DELFLG = [V]CST_AYES & nolign >= [M]NBLIG+2 : End : Endif

  If [M:SFTEA]OPTHST=[V]CST_AYES
    Grizo [M:SFTEA]ELADUR(nolign-1)
    End
  Endif

  If [M:SFTEA]STRDAT(nolign-1)=[0/0/0] & (
&  ([M:SFTEA]SFTTYP(nolign-1)=3 | ([M:SFTEA]SFTTYP(nolign-1)=2 & [M:SFTEA]INDTYP(nolign-1)<>4)) |
&  (([M:SFTEA]SFTTYP(nolign-1)>3 | ([M:SFTEA]SFTTYP(nolign-1)=2 & [M:SFTEA]INDTYP(nolign-1)=4)) & [M:SFTEA]BRKTXN(nolign-1)="")  )
    Actzo [M:SFTEA]ELADUR(nolign-1)
  Else
    Grizo [M:SFTEA]ELADUR(nolign-1)
  Endif

End

####################################################################################
Subprog C_ELADUR(VALEUR)
Variable Decimal    VALEUR()

  If VALEUR=0 & [M:SFTEA]STRDAT(nolign-1)=[0/0/0] & [M:SFTEA]CPLQTY(nolign-1)=0
    Call ERREUR(mess(91,2422,1)) From GESECRAN
    mkstat = 2
  Endif

End

####################################################################################
Subprog AM_ELADUR(VALEUR)
Variable Decimal    VALEUR()

  Call CALC_ENTERED_DURATION(VALEUR,[M:SFTEA]NUMJOBS(nolign-1),[M:SFTEA]SUMEMP(nolign-1))

End

