  If VALEUR="" : End : Endif

  Read [MWS]WST0=VALEUR
  If fstat
    #Record does not exist
    Call ERREUR(mess(23,100,1)) From GESECRAN
    mkstat = 2
    End
  Endif

End

####################################################################################
Subprog C_WSTEND(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" : End : Endif

  Read [MWS]WST0=VALEUR
  If fstat
    #Record does not exist
    Call ERREUR(mess(23,100,1)) From GESECRAN
    mkstat = 2
    End
  Endif

End

####################################################################################
Subprog AM_OPTERR(VALEUR)
Variable Integer VALEUR

  If VALEUR=[V]CST_AYES
    [M:SFTEA]OPTOPN = [V]CST_ANO
    [M:SFTEA]OPTCLS = [V]CST_AYES
    [M:SFTEA]OPTHST = [V]CST_ANO
    Grizo [M:SFTEA]OPTOPN
    Grizo [M:SFTEA]OPTCLS
    Grizo [M:SFTEA]OPTHST
  Else
    [M:SFTEA]OPTOPN = [V]CST_AYES
    [M:SFTEA]OPTCLS = [V]CST_AYES
    Actzo [M:SFTEA]OPTOPN
    Actzo [M:SFTEA]OPTCLS
    Actzo [M:SFTEA]OPTHST
  Endif

  Affzo [M:SFTEA]OPTOPN
  Affzo [M:SFTEA]OPTCLS
  Affzo [M:SFTEA]OPTHST

End

####################################################################################
Subprog AM_OPTHST(VALEUR)
Variable Integer VALEUR

  If VALEUR=[V]CST_AYES
    [M:SFTEA]OPTOPN = [V]CST_ANO
    [M:SFTEA]OPTCLS = [V]CST_ANO
    [M:SFTEA]OPTERR = [V]CST_ANO
    Grizo [M:SFTEA]OPTOPN
    Grizo [M:SFTEA]OPTCLS
    Grizo [M:SFTEA]OPTERR
    Diszo [M:SFTEA]25
  Else
    [M:SFTEA]OPTOPN = [V]CST_AYES
    [M:SFTEA]OPTCLS = [V]CST_AYES
    Actzo [M:SFTEA]OPTOPN
    Actzo [M:SFTEA]OPTCLS
    Actzo [M:SFTEA]OPTERR
    Actzo [M:SFTEA]25
  Endif

  Affzo [M:SFTEA]OPTOPN
  Affzo [M:SFTEA]OPTCLS
  Affzo [M:SFTEA]OPTERR

End

