     Chgtbk [M:EMP5]15             With ""
     If dim([M:EMP5]NBRCTRAFR)>0      : Chgfmt [M:EMP5]NBRCTRAFR With "-Nz:4"       : Raz [M:EMP5]NBRCTRAFR : Endif
     If dim([M:EMP5]CTRNUMAFR)>0      : Chgfmt [M:EMP5]CTRNUMAFR With "-K:20X"      : Raz [M:EMP5]CTRNUMAFR : Endif
     If dim([M:EMP5]CTRDATAFR)>0      : Chgfmt [M:EMP5]CTRDATAFR With "-D:"+GFMDAT4 : Raz [M:EMP5]CTRDATAFR : Endif
     If dim([M:EMP5]XITDATAFR)>0      : Chgfmt [M:EMP5]XITDATAFR With "-D:"+GFMDAT4 : Raz [M:EMP5]XITDATAFR : Endif
     If dim([M:EMP5]TAXSTRDAT)>0      : Chgfmt [M:EMP5]TAXSTRDAT With "-D:"+GFMDAT4 : Raz [M:EMP5]TAXSTRDAT : Endif
     If dim([M:EMP5]TAXENDDAT)>0      : Chgfmt [M:EMP5]TAXENDDAT With "-D:"+GFMDAT4 : Raz [M:EMP5]TAXENDDAT : Endif
     If dim([M:EMP5]TAXSTAAFR)>0      : Chgfmt [M:EMP5]TAXSTAAFR With "-LA:11658"   : Raz [M:EMP5]TAXSTAAFR : Endif
     If dim([M:EMP5]DIRNUM)>0         : Chgfmt [M:EMP5]DIRNUM    With "-K:15X"      : Raz [M:EMP5]DIRNUM    : Endif
     If dim([M:EMP5]DIRPRC)>0         : Chgfmt [M:EMP5]DIRPRC    With "-Nz:0.4"     : Raz [M:EMP5]DIRPRC    : Endif
     If dim([M:EMP5]DIRAMT)>0         : Chgfmt [M:EMP5]DIRAMT    With "-Nz:11.2"    : Raz [M:EMP5]DIRAMT    : Endif
     If dim([M:EMP5]RETFDSNUM )>0     : Chgfmt [M:EMP5]RETFDSNUM With "-K:20X"      : Raz [M:EMP5]RETFDSNUM : Endif
Endif
#ADNGO - 2018-01-18 - X3-59214 - END
Return

