$SPECIFIC_AFRICA
###########
## AFRICA
###########
#JASMI - 2016-10-25 - JIRA X3PEOP-3179 - START
  If !func DIVPAYE.IS_KAO_LEG(GCURLEG) & !func DIVPAYE.IS_KPO_LEG(GCURLEG)
    Chgfmt [M:EMP2]PLCBRN With WSIGN+"K:13X"
  Endif
#JASMI - 2016-10-25 - JIRA X3PEOP-3179 - END

#JASMI - 2016-10-31 - JIRA X3PEOP-3179 - START
  If func DIVPAYE.IS_KZM_LEG(GCURLEG)
    If dim([M:EMP5]BRNCERNUM)>0 : Chgfmt [M:EMP5]BRNCERNUM With WSIGN+"K:20X" :Endif
    If dim([M:EMP5]GRATAXNUM)>0 : Chgfmt [M:EMP5]GRATAXNUM With WSIGN+"K:15X"  :Endif
    If dim([M:EMP5]PINNUM)>0    : Chgfmt [M:EMP5]PINNUM    With WSIGN+"K:15X" :Endif
  Endif
#JASMI - 2016-10-31 - JIRA X3PEOP-3179 - END
#LIMAS 2017-07-27 X3-35355 START
  If func DIVPAYE.IS_KGH_LEG(GCURLEG) Then
    If dim([M:EMP2]CTYBRN)>0 : Chgfmt [M:EMP2]CTYBRN With WSIGN+"K:20X"      :Endif
    If dim([M:EMP5]DIRNUM)>0 : Chgfmt [M:EMP5]DIRNUM With WSIGN+"K:15X"      :Endif
    If dim([M:EMP5]DIRAMT)>0 : Chgfmt [M:EMP5]DIRAMT With WSIGN+"Nz:11.2"    :Endif
    If dim([M:EMP5]DIRPRC)>0 : Chgfmt [M:EMP5]DIRPRC With WSIGN+"Nz:0.4"     :Endif

    If dim([M:EMP5]BRNCERNUM)>0 : Chgfmt [M:EMP5]BRNCERNUM    With WSIGN+"K:20X"      :Endif
    If dim([M:EMP5]GRATAXNUM)>0 : Chgfmt [M:EMP5]GRATAXNUM    With WSIGN+"K:150X"     :Endif
    If dim([M:EMP5]PINNUM)>0    : Chgfmt [M:EMP5]PINNUM       With WSIGN+"K:20X"      :Endif

  #  If dim([M:EMP5]EMPPOS)>0 : Chgfmt [M:EMP5]EMPPOS With WSIGN+"LA:11721"   :Endif
  Endif
#LIMAS 2017-07-27 X3-35355 END
#ADNGO - 2017-08-22 - X3-53120 - START
  If func DIVPAYE.IS_KNA_LEG(GCURLEG)
    If dim([M:EMP5]BRNCERNUM)>0 : Chgfmt [M:EMP5]BRNCERNUM With WSIGN+"K:20X" :Endif
    If dim([M:EMP5]GRATAXNUM)>0 : Chgfmt [M:EMP5]GRATAXNUM With WSIGN+"K:15X"  :Endif
    If dim([M:EMP5]PINNUM)>0    : Chgfmt [M:EMP5]PINNUM    With WSIGN+"K:15X" :Endif
  Endif
#ADNGO - 2017-08-22 - X3-53120 - END

#ADNGO - 2017-08-25 - X3-53120 - START
  If func DIVPAYE.IS_KKE_LEG(GCURLEG) Then

    If dim([M:EMP5]BRNCERNUM)>0 : Chgfmt [M:EMP5]BRNCERNUM    With WSIGN+"K:20X"  :   Endif
    If dim([M:EMP5]GRATAXNUM)>0 : Chgfmt [M:EMP5]GRATAXNUM    With WSIGN+"K:150X" :   Endif
    If dim([M:EMP5]PINNUM)>0    : Chgfmt [M:EMP5]PINNUM       With WSIGN+"K:20X"  :   Endif

    If dim([M:EMP5]DIRNUM)>0 : Chgfmt [M:EMP5]DIRNUM With WSIGN+"K:15X"      :  Endif
    If dim([M:EMP5]DIRAMT)>0 : Chgfmt [M:EMP5]DIRAMT With WSIGN+"Nz:11.2"    :  Endif
    If dim([M:EMP5]DIRPRC)>0 : Chgfmt [M:EMP5]DIRPRC With WSIGN+"Nz:0.4"     :  Endif
  Endif
#ADNGO - 2017-08-25 - X3-53120 - END
#ADNGO - 2017-08-31 - X3-53129 - START
If func DIVPAYE.IS_KLS_LEG(GCURLEG) Then
  If dim([M:EMP5]BRNCERNUM)>0 : Chgfmt [M:EMP5]BRNCERNUM    With WSIGN+"K:20X"    :   Endif
  If dim([M:EMP5]GRATAXNUM)>0 : Chgfmt [M:EMP5]GRATAXNUM    With WSIGN+"K:150X"   :   Endif
  If dim([M:EMP5]PINNUM)>0    : Chgfmt [M:EMP5]PINNUM       With WSIGN+"K:20X"    :   Endif
  If dim([M:EMP5]EMPTAXNUM)>0 : Chgfmt [M:EMP5]EMPTAXNUM    With WSIGN+"K:15X"    :   Endif
  If dim([M:EMP5]DIRAMT)>0    : Chgfmt [M:EMP5]DIRAMT With WSIGN+"Nz:11.2"        :   Endif
