#<AdxTL>@(#)0.0.0.0 $Revision$
$RESET_SCREEN
  Call HIDE_ACTIVITYFIELDS From WOEMLHIDE

Return

$SHOW_LEG
  Call SHOW_LEGACTCALLS From WOEMLSHOW

#reshow all fields not protected by localization activity codes
  Local Char WSIGN(1)
  WSIGN=""
  Gosub RESHOW_UNPROTECTED_FIELDS

#reset all block titles that are set below
  Gosub RESET_BLOCK_TITLES

#hide fields specifically for certain localizations
  WSIGN="-"
  Gosub SPECIFIC_SOUTH_AFRICA
  Gosub SPECIFIC_AFRICA
  Gosub SPECIFIC_ZAMBIA
  Gosub SPECIFIC_FRANCE
  #ADNGO - 2017-12-05 - X3-60299 - START
  Gosub SPECIFIC_MIDDLEEAST
  #ADNGO - 2017-12-05 - X3-60299 - END
#DIRAS - 2016-10-25 - JIRA X3PEOP-3179 - START
  Gosub SPECIFIC_UK
#DIRAS - 2016-10-25 - JIRA X3PEOP-3179 - END

#DEKEE - 2016-11-08 - JIRA X3PEOP-3802 - START
Affzo [M:EMP1]
Affzo [M:EMP2]
Affzo [M:EMP3]
#DEKEE - 2016-11-08 - JIRA X3PEOP-3802 - END

Return

#DIRAS - 2016-10-26 - JIRA X3PEOP-3179 - START
$RESET_BLOCK_TITLES
  If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
  Local Integer WNUMLIBEL

  Local Char DESCRIPTION(250)
  If clalev([ATZ])=0 : Local File ATABZON [ATZ] : Endif

##HRMAT0
  Read [F:AMKW]CODMSK = "HRMAT0"
  WNUMLIBEL=[F:AMKW]TITBLOC(0)
  Chgtbk [M:EMP0]6  With func AFNC.TEXTE(WNUMLIBEL)
  WNUMLIBEL=[F:AMKW]TITBLOC(1)
  Chgtbk [M:EMP0]11 With func AFNC.TEXTE(WNUMLIBEL)

#DEKEE - 2016-12-01 - JIRA X3PEOP-4427 - START
  Read [ATZ]CODZONE="EMPLOID";"NAM"
  If(!fstat)
    Call TEXTE([ATZ]NOCOURT,DESCRIPTION) From OBJDIV
    Chgtzn[M:EMP0]NAM      With (DESCRIPTION)
  Endif
  Read [ATZ]CODZONE="EMPLOID";"PSD"
  If(!fstat)
    Call TEXTE([ATZ]NOCOURT,DESCRIPTION) From OBJDIV
    Chgtzn[M:EMP0]PSD      With (DESCRIPTION)
  Endif
  Read [ATZ]CODZONE="EMPLOID";"SRN"
  If(!fstat)
    Call TEXTE([ATZ]NOABREG,DESCRIPTION) From OBJDIV
    Chgtzn[M:EMP0]SRN      With (DESCRIPTION)
  Endif
#DEKEE - 2016-12-01 - JIRA X3PEOP-4427 - END
#DIRAS - 2016-10-26 - JIRA X3PEOP-3179 - END

#DIRAS - 2016-10-26 - JIRA X3PEOP-3183 - START
#HRMAT2
  Read [F:AMKW]CODMSK = "HRMAT2"
  WNUMLIBEL=[F:AMKW]TITBLOC(0)
  Chgtbk [M:EMP2]10 With func AFNC.TEXTE(WNUMLIBEL)
  #ADNGO - 2017-05-04 - JIRA X3-33781 - START
  #WNUMLIBEL=[F:AMKW]TITBLOC(4)
 # Chgtbk [M:EMP2]50 With func AFNC.TEXTE(WNUMLIBEL)
  Chgtbk [M:EMP2]50 With mess(249,10702,1)
  #ADNGO - 2017-05-04 - JIRA X3-33781 - END


  Read [ATZ]CODZONE="EMPLOID";"DATBRN"
  If(!fstat)
    Call TEXTE([ATZ]NOCOURT,DESCRIPTION) From OBJDIV
    Chgtzn[M:EMP2]DATBRN      With (DESCRIPTION)
  Endif

  Read [F:AMKW]CODMSK = "HRMAT3"
  WNUMLIBEL=[F:AMKW]INTMSK
  Chgtfd [M:EMP3] With "Admin"
#DIRAS - 2016-10-26 - JIRA X3PEOP-3183 - END


Return

$RESHOW_UNPROTECTED_FIELDS

#EMP1 Reshows unprotected fields hidden by SPECIFIC_UK
  #LIPET - 2017-05-09 - X3-36382 - START
#  If dim([M:EMP1]CRY)>0      : Chgfmt [M:EMP1]CRY        With WSIGN+"K:3"        : Raz [M:EMP1]CRY         :Endif
#  If dim([M:EMP1]CRYNAM)>0   : Chgfmt [M:EMP1]CRYNAM     With WSIGN+"K:40X"      : Raz [M:EMP1]CRYNAM      :Endif
#  If dim([M:EMP1]CODPOS)>0   : Chgfmt [M:EMP1]CODPOS     With WSIGN+"K:"+GFMT    : Raz [M:EMP1]CODPOS      :Endif
#  If dim([M:EMP1]CTY)>0      : Chgfmt [M:EMP1]CTY        With WSIGN+"K:"+GFMT    : Raz [M:EMP1]CTY         :Endif
#  If dim([M:EMP1]TEL)>0      : Chgfmt [M:EMP1]TEL        With WSIGN+"K:"+GFMT    : Raz [M:EMP1]TEL         :Endif
#  If dim([M:EMP1]MOB)>0      : Chgfmt [M:EMP1]MOB        With WSIGN+"K:"+GFMT    : Raz [M:EMP1]MOB         :Endif
#  If dim([M:EMP1]FAX)>0      : Chgfmt [M:EMP1]FAX        With WSIGN+"K:"+GFMT    : Raz [M:EMP1]FAX         :Endif
#  If dim([M:EMP1]EML)>0      : Chgfmt [M:EMP1]EML        With WSIGN+"K:50X"      : Raz [M:EMP1]EML         :Endif
#  If dim([M:EMP1]FLGTEL)>0   : Chgfmt [M:EMP1]FLGTEL     With WSIGN+"K:10X"      : Raz [M:EMP1]FLGTEL      :Endif
#  If dim([M:EMP1]FLGEML)>0   : Chgfmt [M:EMP1]FLGEML     With WSIGN+"K:20X"      : Raz [M:EMP1]FLGEML      :Endif
  If dim([M:EMP1]CRY)>0      : Chgfmt [M:EMP1]CRY        With WSIGN+"K:3"        :Endif
  If dim([M:EMP1]CRYNAM)>0   : Chgfmt [M:EMP1]CRYNAM     With WSIGN+"K:40X"      :Endif
#JASMI - 2017-05-12 - START
#  If dim([M:EMP1]CODPOS)>0   : Chgfmt [M:EMP1]CODPOS     With WSIGN+"K:"+GFMT    :Endif
#  If dim([M:EMP1]CTY)>0      : Chgfmt [M:EMP1]CTY        With WSIGN+"K:"+GFMT    :Endif
#  If dim([M:EMP1]TEL)>0      : Chgfmt [M:EMP1]TEL        With WSIGN+"K:"+GFMT    :Endif
#  If dim([M:EMP1]MOB)>0      : Chgfmt [M:EMP1]MOB        With WSIGN+"K:"+GFMT    :Endif
#  If dim([M:EMP1]FAX)>0      : Chgfmt [M:EMP1]FAX        With WSIGN+"K:"+GFMT    :Endif
  If dim([M:EMP1]CODPOS)>0   : Chgfmt [M:EMP1]CODPOS     With WSIGN+"K:10X"      :Endif
  If dim([M:EMP1]CTY)>0      : Chgfmt [M:EMP1]CTY        With WSIGN+"K:40X"      :Endif
  If dim([M:EMP1]TEL)>0      : Chgfmt [M:EMP1]TEL        With WSIGN+"K:20X"      :Endif
  If dim([M:EMP1]MOB)>0      : Chgfmt [M:EMP1]MOB        With WSIGN+"K:20X"      :Endif
  If dim([M:EMP1]FAX)>0      : Chgfmt [M:EMP1]FAX        With WSIGN+"K:20X"      :Endif
#JASMI - 2017-05-12 - END
  If dim([M:EMP1]EML)>0      : Chgfmt [M:EMP1]EML        With WSIGN+"K:50X"      :Endif
  If dim([M:EMP1]FLGTEL)>0   : Chgfmt [M:EMP1]FLGTEL     With WSIGN+"K:10X"      :Endif
  If dim([M:EMP1]FLGEML)>0   : Chgfmt [M:EMP1]FLGEML     With WSIGN+"K:20X"      :Endif
  #LIPET - 2017-05-09 - X3-36382 - END

  #LIPET - 2017-05-09 - X3-36382 - START
#  #Chgfmt [M:EMP1]FLGPAY     With WSIGN+"K:20X"      : Raz [M:EMP1]FLGPAY
#  If dim([M:EMP1]FLGTPS)>0    : Chgfmt [M:EMP1]FLGTPS     With WSIGN+"K:20X"      : Raz [M:EMP1]FLGTPS       :Endif
#  If dim([M:EMP1]FLGMULCTR)>0 : Chgfmt [M:EMP1]FLGMULCTR  With WSIGN+"K:20X"      : Raz [M:EMP1]FLGMULCTR     :Endif
#  #Chgfmt [M:EMP1]FLGINT     With WSIGN+"K:20X"      : Raz [M:EMP1]FLGINT
#  #Chgfmt [M:EMP1]FLGBULDEM  With WSIGN+"K:20X"      : Raz [M:EMP1]FLGBULDEM
#  If dim([M:EMP1]CODACS)>0    : Chgfmt [M:EMP1]CODACS     With WSIGN+"K:10X"      : Raz [M:EMP1]CODACS     :Endif
#  #Chgfmt [M:EMP1]NUMCCS     With WSIGN+"K:10X"      : Raz [M:EMP1]NUMCCS
#  #Chgfmt [M:EMP5]DMYFLD     With WSIGN+"K:10X"        : Raz [M:EMP5]DMYFLD
#  If dim([M:EMP3]NBHDC)>0    : Chgfmt [M:EMP3]NBHDC      With WSIGN+"N:4"        : Raz [M:EMP3]NBHDC      :Endif
  If dim([M:EMP1]FLGTPS)>0    : Chgfmt [M:EMP1]FLGTPS     With WSIGN+"K:20X"      :Endif
  If dim([M:EMP1]FLGMULCTR)>0 : Chgfmt [M:EMP1]FLGMULCTR  With WSIGN+"K:20X"      :Endif
  If dim([M:EMP1]CODACS)>0    : Chgfmt [M:EMP1]CODACS     With WSIGN+"K:10X"      :Endif
  If dim([M:EMP3]NBHDC)>0    : Chgfmt [M:EMP3]NBHDC      With WSIGN+"N:4"         :Endif
  #LIPET - 2017-05-09 - X3-36382 - END
#EMP2 Reshows unprotected fields hidden by SPECIFIC_UK
  If dim([M:EMP2]OLDNAM)>0    : Chgfmt [M:EMP2]OLDNAM     With WSIGN+"K:20X"    :Endif
  If dim([M:EMP2]CRYBRN)>0    : Chgfmt [M:EMP2]CRYBRN     With WSIGN+"K:3"      :Endif
  If dim([M:EMP2]CRYNAMBRN)>0 : Chgfmt [M:EMP2]CRYNAMBRN  With WSIGN+"K:40"     :Endif
  If dim([M:EMP2]CTYBRN)>0    : Chgfmt [M:EMP2]CTYBRN     With WSIGN+"K:20X"    :Endif
  #Chgfmt [M:EMP2]NUMSSC     With WSIGN+"SSE"     : Raz [M:EMP2]NUMSSC
  #Chgfmt [M:EMP2]NUMSSC2    With WSIGN+"SSE2"    : Raz [M:EMP2]NUMSSC2
  If dim([M:EMP2]ADT)>0       : Chgfmt [M:EMP2]ADT        With WSIGN+"N:2"        :Endif
  If dim([M:EMP2]CHD)>0       : Chgfmt [M:EMP2]CHD        With WSIGN+"N:2"        :Endif
  If dim([M:EMP2]SITFAMA)>0   : Chgfmt [M:EMP2]SITFAMA    With WSIGN+"K:20"       :Endif
  If dim([M:EMP2]JNTREFNUM)>0 : Chgfmt [M:EMP2]JNTREFNUM  With WSIGN+"K:15"       :Endif
  If dim([M:EMP2]JNTNAM)>0    : Chgfmt [M:EMP2]JNTNAM     With WSIGN+"K:40X"      :Endif
  If dim([M:EMP2]JNTSRN)>0    : Chgfmt [M:EMP2]JNTSRN     With WSIGN+"K:20X"      :Endif
  If dim([M:EMP2]JNTREFNUM)>0 : Chgfmt [M:EMP2]JNTREFNUM  With WSIGN+"K:15"       :Endif
  If dim([M:EMP2]JNTDATBRN)>0 : Chgfmt [M:EMP2]JNTDATBRN  With WSIGN+"D:"+GFMDAT4 :Endif
  If dim([M:EMP2]JNTCRY)>0    : Chgfmt [M:EMP2]JNTCRY     With WSIGN+"K:3"        :Endif
  If dim([M:EMP2]JNTCRYNAM)>0 : Chgfmt [M:EMP2]JNTCRYNAM  With WSIGN+"K:40"       :Endif
  If dim([M:EMP2]JNTTEL)>0    : Chgfmt [M:EMP2]JNTTEL     With WSIGN+"K:20"       :Endif

  #Hides added discription under block title
  #Chgtbk [M:EMP2]50         With WSIGN-""

#DIRAS - 2016-10-31 - JIRA X3PEOP-3187 - START
#EMP3 Reshows unprotected blocks hidden by SPECIFIC_UK
  If dim([M:EMP3]NBHDC)>0    : Chgfmt [M:EMP3]NBHDC        With WSIGN+"N:4"   :Endif
  If dim([M:EMP3]NBRCHEF)>0  : Chgfmt [M:EMP3]NBRCHEF      With WSIGN+"N:4"   :Endif
  If dim([M:EMP3]NBRPAS)>0   : Chgfmt [M:EMP3]NBRPAS       With WSIGN+"N:2"   :Endif

#EMP3 Reshows unprotected fields hidden by SPECIFIC_UK
  #JOJAC - 2017-03-24 - START
  #Chgfmt [M:EMP3]PFLTEL       With WSIGN+"K:20"   #: Raz [M:EMP3]PFLTEL
  If GFMT <> ""
#JASMI - 2017-05-12 - START
#    If dim([M:EMP3]PFLTEL)>0    : Chgfmt [M:EMP3]PFLTEL       With WSIGN+"K:"+GFMT    :Endif
    If dim([M:EMP3]PFLTEL)>0    : Chgfmt [M:EMP3]PFLTEL       With WSIGN+"K:20X"      :Endif
#JASMI - 2017-05-12 - END
    Else
    If dim([M:EMP3]PFLTEL)>0    : Chgfmt [M:EMP3]PFLTEL       With WSIGN+"K:35X"      :Endif
  Endif
  #JOJAC - 2017-03-24 - END
  #ADNGO - 2017-05-05 - JIRA X3-35980 - START
  #If dim([M:EMP3]PFLMOB)>0        : Chgfmt [M:EMP3]PFLMOB       With WSIGN+"K:20"       :Endif
#JASMI - 2017-05-12 - START
#  If dim([M:EMP3]PFLMOB)>0        : Chgfmt [M:EMP3]PFLMOB       With WSIGN+"K:"+GFMT       :Endif
  If dim([M:EMP3]PFLMOB)>0        : Chgfmt [M:EMP3]PFLMOB       With WSIGN+"K:20X"      :Endif
#JASMI - 2017-05-12 - END
  #ADNGO - 2017-05-05 - JIRA X3-35980 - END
  If dim([M:EMP3]PFLEML)>0        : Chgfmt [M:EMP3]PFLEML       With WSIGN+"K:50X"      :Endif
  If dim([M:EMP3]STG)>0           : Chgfmt [M:EMP3]STG          With WSIGN+"LA:1"       :Endif
  If dim([M:EMP3]STYCRD)>0        : Chgfmt [M:EMP3]STYCRD       With WSIGN+"K:15X"      :Endif
  If dim([M:EMP3]DATSTY)>0        : Chgfmt [M:EMP3]DATSTY       With WSIGN+"D:"+GFMDAT4 :Endif
  If dim([M:EMP3]WRKCRD)>0        : Chgfmt [M:EMP3]WRKCRD       With WSIGN+"K:15X"      :Endif
  If dim([M:EMP3]HDC)>0           : Chgfmt [M:EMP3]HDC          With WSIGN+"N:3"        :Endif
  If dim([M:EMP3]DATSTRHDC)>0     : Chgfmt [M:EMP3]DATSTRHDC    With WSIGN+"D:"+GFMDAT4 :Endif
  If dim([M:EMP3]DATENDHDC)>0     : Chgfmt [M:EMP3]DATENDHDC    With WSIGN+"D:"+GFMDAT4 :Endif
  If dim([M:EMP3]RESPO)>0         : Chgfmt [M:EMP3]RESPO        With WSIGN+"LA:50"      :Endif
  If dim([M:EMP3]CHEF)>0          : Chgfmt [M:EMP3]CHEF         With WSIGN+"K:20X"      :Endif
  If dim([M:EMP3]CHEFNAM)>0       : Chgfmt [M:EMP3]CHEFNAM      With WSIGN+"K:40X"      :Endif
  #ANCOA - 2017-05-24 - JIRA X3-39378 - START - format increased from 20 to 35
  If dim([M:EMP3]PASNUM)>0        : Chgfmt [M:EMP3]PASNUM       With WSIGN+"K:35X"      :Endif
  #ANCOA - 2017-05-24 - JIRA X3-39378 - END
  If dim([M:EMP3]PASCRY)>0        : Chgfmt [M:EMP3]PASCRY       With WSIGN+"K:3"        :Endif
  If dim([M:EMP3]DATWRK)>0        : Chgfmt [M:EMP3]DATWRK       With WSIGN+"D:"+GFMDAT4 :Endif
  If dim([M:EMP3]PLCISS)>0        : Chgfmt [M:EMP3]PLCISS       With WSIGN+"K:30X"      :Endif
  If dim([M:EMP3]PASCRY)>0        : Chgfmt [M:EMP3]PASCRY       With WSIGN+"K:3"        :Endif
  If dim([M:EMP3]ISSAUZ)>0        : Chgfmt [M:EMP3]ISSAUZ       With WSIGN+"K:40X"      :Endif
  If dim([M:EMP3]EXPDAT)>0        : Chgfmt [M:EMP3]EXPDAT       With WSIGN+"D:"+GFMDAT4 :Endif
  If dim([M:EMP3]ETRPITTYP)>0     : Chgfmt [M:EMP3]ETRPITTYP    With WSIGN+"K:30X"      :Endif
  If dim([M:EMP3]ETRPITDAT)>0     : Chgfmt [M:EMP3]ETRPITDAT    With WSIGN+"D:"+GFMDAT4 :Endif
  If dim([M:EMP3]ETRPITEXPDAT)>0  : Chgfmt [M:EMP3]ETRPITEXPDAT With WSIGN+"K:30X"      :Endif

#DIRAS - 2016-10-31 - JIRA X3PEOP-3187 - END

