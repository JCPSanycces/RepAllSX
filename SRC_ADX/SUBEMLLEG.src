    If dim([M:EMP1]MIDPOSINM)>0  : Chgfmt [M:EMP1]MIDPOSINM   With  WSIGN+"A:21X"  : Raz [M:EMP1]MIDPOSINM  : Endif
    Chgtzn [M:EMP1]ADD1            With mess(00075,10702,1)
    Chgtzn [M:EMP1]ADD2            With mess(00076,10702,1)
    Chgtzn [M:EMP1]ADD3            With mess(00019,11738,1)
    Chgtbk [M:EMP1]45              With mess(00020,11738,1)
    Chgtzn [M:EMP1]MIDTYP          With mess(00023,11738,1)
    #MAT2 / EMP2
    If dim([M:EMP2]CTYBRN)>0     : Chgfmt [M:EMP2]CTYBRN      With WSIGN+"K:18X"   : Raz [M:EMP2]CTYBRN    : Endif
    If dim([M:EMP2]NUMSSC )>0    : Chgfmt [M:EMP2]NUMSSC      With WSIGN+"K:30X"   : Raz [M:EMP2]NUMSSC    : Endif
    If dim([M:EMP2]ICOS)>0       : Chgfmt [M:EMP2]ICOS        With WSIGN+"K:3X"    : Raz [M:EMP2]ICOS      : Endif
    If dim([M:EMP2]LNKPAR )>0    : Chgfmt [M:EMP2]LNKPAR      With WSIGN+"K:81X"   : Raz [M:EMP2]LNKPAR    : Endif
    If dim([M:EMP2]ARANAM )>0    : Chgfmt [M:EMP2]ARANAM      With WSIGN+"K:81X"   : Raz [M:EMP2]ARANAM    : Endif
    Chgtzn [M:EMP2]CRYBRN          With mess(00005,11738,1)
    Chgtzn [M:EMP2]CRYNAMBRN       With mess(00006,11738,1)
    Chgtbk [M:EMP2]50              With mess(00005,11706, 1)
    Chgtzn[M:EMP2]OLDNAM           With mess(00004,11738,1)
    Diszo [M:EMP2]ADT
    Diszo [M:EMP2]CHD
    #MAT3 / EMP3
    #Chgtbk [M:EMP3]30              With ""
    If dim([M:EMP3]ETRPITTYP)>0     : Chgfmt [M:EMP3]ETRPITTYP       With WSIGN+"K:20X"               : Raz [M:EMP3]ETRPITTYP    : Endif
    If dim([M:EMP3]ETRPITDAT)>0     : Chgfmt [M:EMP3]ETRPITDAT       With WSIGN+"D:"+GFMDAT4          : Raz [M:EMP3]ETRPITDAT    : Endif
    If dim([M:EMP3]ETRPITEXPDAT)>0  : Chgfmt [M:EMP3]ETRPITEXPDAT    With WSIGN+"D:"+GFMDAT4          : Raz [M:EMP3]ETRPITEXPDAT : Endif
    #MAT5 / EMP5
    If dim([M:EMP5]ETHGRP)>0     : Chgfmt [M:EMP5]ETHGRP          With WSIGN+"LA:11657"            : Raz [M:EMP5]ETHGRP    : Endif
    If dim([M:EMP5]RCEGRP)>0     : Chgfmt [M:EMP5]RCEGRP          With WSIGN+"LA:11658"            : Raz [M:EMP5]RCEGRP    : Endif
    If dim([M:EMP5]LNRSKL)>0     : Chgfmt [M:EMP5]LNRSKL          With WSIGN+"LA:1"                : Raz [M:EMP5]LNRSKL    : Endif
    If dim([M:EMP5]GRATAXNUM)>0  : Chgfmt [M:EMP5]GRATAXNUM       With WSIGN+"K:15"                : Raz [M:EMP5]GRATAXNUM : Endif
    If dim([M:EMP5]PINNUM)>0     : Chgfmt [M:EMP5]PINNUM          With WSIGN+"K:15"                : Raz [M:EMP5]PINNUM    : Endif
    #MAT6 / EMP6
    Chgtzn[M:EMP6]DATANC           With mess(00026,11738,1)
    #MAT7 / EMP7
    If dim([M:EMP7]CPYBAN )>0    : Chgfmt [M:EMP7]CPYBAN      With WSIGN+"A:5X"   : Raz [M:EMP7]CPYBAN    : Endif
    Chgtzn[M:EMP7]AGNID            With mess(00024,11738,1)
    #THRAM - 2016-09-15 - Requirement X3PEOP-1760 - START
    If dim([M:EMP7]IBAN)>0       : Chgfmt [M:EMP7]IBAN        With WSIGN+"K:4X"   : Raz [M:EMP7]IBAN      : Endif
    #THRAM - 2016-09-15 - Requirement X3PEOP-1760 - END
    #MAT14 / EMP14
    If dim([M:EMPE]WCAT)>0       : Chgfmt [M:EMPE]WCAT        With WSIGN+"LA:10554"  : Raz [M:EMPE]WCAT      : Endif
    If dim([M:EMPE]WBKT)>0       : Chgfmt [M:EMPE]WBKT        With WSIGN+"LA:10553"  : Raz [M:EMPE]WBKT      : Endif
    Endif
  Endif
Return
#ADNGO - 2017-12-05 - X3-60299 - END

