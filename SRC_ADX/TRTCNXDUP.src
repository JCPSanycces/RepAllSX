#<AdxTL>@(#)2.0.0.0 $Revision$
################################################################################
#    TRAITEMENT DE DUPLICATION D'UN CONTEXTE
#    GLE
#    Création le : 11/04/2011
#    Modification le : --/--/----
#-------------------------------------------------------------------------------
#    Modification
#    GLE - 09.05.2011 FQ73718 : Contrôle que les sociétés ont le même modèle comptable et prise en compte synchro avec compta
################################################################################

######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION
  #Infbox "TRTCNXDUP /"-ACTION
  Case ACTION
    When "OUVRE" : Gosub OUVRE
    When "DEBUT" : Gosub DEBUT
    When "OK"    : Gosub OK
    When "FIN"   : Gosub FIN
  Endcase
Return

$OUVRE
  Gosub OUVERTURE_TABLES
Return

$DEBUT
  [M:CNXD]CPYSRC = PARAM(1)
  [M:CNXD]DESCNX = mess(val(PARAM(2)),3100,1)
Return

$OK
  Gosub DUPLICATE_CNX
Return

$FIN
  Gosub FERMETURE_TABLES
Return

$OUVERTURE_TABLES
  If !clalev([F:WCPY]) : Local File COMPANY   [WCPY] : Endif
  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif
  If !clalev([F:CNX1]) : Local File CONTEXT   [CNX1] : Endif
  If !clalev([F:CNX2]) : Local File CONTEXT   [CNX2] : Endif
  If !clalev([F:FIS1]) : Local File FISCYEAR  [FIS1] : Endif
  If !clalev([F:FIS2]) : Local File FISCYEAR  [FIS2] : Endif
Return

$FERMETURE_TABLES
  If clalev([F:WCPY]) : Close File [F:WCPY] : Endif
  If clalev([F:WFAS]) : Close File [F:WFAS] : Endif
  If clalev([F:CNX1]) : Close File [F:CNX1] : Endif
  If clalev([F:CNX2]) : Close File [F:CNX2] : Endif
  If clalev([F:FIS1]) : Close File [F:FIS1] : Endif
  If clalev([F:FIS2]) : Close File [F:FIS2] : Endif
Return

################################################################################
# TRAITEMENT METIER
################################################################################
$DUPLICATE_CNX
  Local Shortint N_PLN, ERR
  Local Char     MESSAGE(255)

  Call TEXTE(43503,MESSAGE) From OBJDIV
  Call OUVRE_TRACE(MESSAGE) From LECFIC

  Call ECR_TRACE(left$(mess(17,GML_MSGCIG,1)+space$(30),30)+":"-PARAM(1),0) From GESECRAN
  Call ECR_TRACE(left$(mess(521,GML_MSGFAS,1)+space$(30),30)+":"-mess(val(PARAM(2)),3100,1),0) From GESECRAN
  Call ECR_TRACE(left$(mess(18,GML_MSGCIG,1)+space$(30),30)+":"-[M:CNXD]CPYDEST,0) From GESECRAN

  # Lecture du contexte à dupliquer
  Read [F:CNX1]CNX0=PARAM(1);val(PARAM(2))

  # Contrôles préalables
  Gosub CONTROLES

  If !ERR
    Trbegin [F:CNX2], [F:FIS2]

    # Copie du contexte
    [F:CNX2]    = [F:CNX1]
    [F:CNX2]CPY = [M:CNXD]CPYDEST

    If [F:CNX1]CNX = G300CPFI
      # Le contexte Comptable et Fiscal doit avoir la même devise que la société
      Read [F:WCPY]CPY0 = [F:CNX2]CPY
      [F:CNX2]CUR    = [F:WCPY]ACCCUR
      [F:CNX2]CURTYP = 1
    Endif

    Write [F:CNX2]
    If fstat
      Call ECR_TRACE("\"+mess(26,125,1)-"[F:CNX2]"-[F:CNX2]CPY-num$([F:CNX2]CNX)-num$(fstat),1) From GESECRAN
      ERR = 1
    Endif

    # Copie des exercices
    For [F:FIS1]FIY0 Where CPY = [F:CNX1]CPY and CNX = [F:CNX1]CNX
      [F:FIS2]    = [F:FIS1]
      [F:FIS2]CPY = [M:CNXD]CPYDEST

      Write [F:FIS2]
      If fstat
        Call ECR_TRACE("\"+mess(26,125,1)-"[F:FIS2]"-[F:FIS2]CPY-num$([F:FIS2]CNX)-[F:FIS2]DATSTRFIY-num$(fstat),1) From GESECRAN
        ERR = 1
      Endif
    Next

    If ERR
      Rollback
      Call ECR_TRACE("\"+mess(275,GML_MSGFASPR,1),1) From GESECRAN
    Else
      Commit
      Call ECR_TRACE("\"+mess(276,GML_MSGFASPR,1),0) From GESECRAN
    Endif
  Endif

  Call LEC_TRACE() From LECFIC
Return

$CONTROLES
  ERR = 0

  Local Char ACMSRC(GLONGCM), ACMDEST(GLONGCM)

  # FQ73718
  # Les sociétés doivent avoir le même modèle comptable
  Read [F:WCPY]CPY0=[M:CNXD]CPYSRC
  [L]ACMSRC = [F:WCPY]ACM
  Read [F:WCPY]CPY0=[M:CNXD]CPYDEST
  [L]ACMDEST = [F:WCPY]ACM
  If [L]ACMSRC <> [L]ACMDEST
    Call ECR_TRACE("\"+func GLOFUNC.SUBSTIT2(mess(280,GML_MSGFASPR,1),[M:CNXD]CPYSRC,[M:CNXD]CPYDEST),1) From GESECRAN
    ERR = 1
    Return
  Endif

  # FQ73718
  # Si la société cible doit être synchronisée avec la compta la société source doit l'être aussi
  If func AFNC.PARAM("ACCPERCTL",[M:CNXD]CPYDEST)="2" and func AFNC.PARAM("ACCPERCTL",[M:CNXD]CPYSRC)<>"2"
    Call ECR_TRACE("\"+func GLOFUNC.SUBSTIT2(mess(281,GML_MSGFASPR,1),[M:CNXD]CPYSRC,[M:CNXD]CPYDEST),1) From GESECRAN
    ERR = 1
    Return
  Endif

  # Le contexte ne doit pas déjà exister dans la société cible
  Look [F:CNX2]CNX0=[M:CNXD]CPYDEST;val(PARAM(2))
  If !fstat
    Call ECR_TRACE("\"+func GLOFUNC.SUBSTIT2(mess(277,GML_MSGFASPR,1),mess(val(PARAM(2)),3100,1),[M:CNXD]CPYDEST),1) From GESECRAN
    ERR = 1
    Return
  Endif

  # Si on ne duplique pas le contexte Comptable et Fiscal il faut verifier qu'il existe dans la société cible
  If val(PARAM(2)) <> G300CPFI
    Look [F:CNX2]CNX0=[M:CNXD]CPYDEST;G300CPFI
    If fstat
      Call ECR_TRACE("\"+mess(18,GML_MSGCIG,1)-":"-mess(121,GML_MSGFASPR,1)-mess(G300CPFI,3100,1),1) From GESECRAN
      ERR = 1
      Return
    Endif
  Endif

  # Les plans du contexte à dupliquer ne doivent pas exister dans un autre contexte de la société cible
  For [CNX2]CNX0 Where CPY=[M:CNXD]CPYDEST
    For N_PLN = 0 To [F:CNX1]NBPLC-1
      If find([F:CNX1]PLNCAA(N_PLN),[F:CNX2]PLNCAA)
        Call ECR_TRACE("\"+mess([F:CNX1]PLNCAA(N_PLN),3101,1)-":"-mess(213,GML_MSGFASPR,1)-mess([F:CNX2]CNX,3100,1),1) From GESECRAN
        ERR = 1
        Return #CHECK IGNORE_LINE
      Endif
    Next
  Next

  # La société cible ne doit pas avoir de biens
  Filter [WFAS] Where CPY=[M:CNXD]CPYDEST
  If rowcount([WFAS])
    Call ECR_TRACE("\"+func GLOFUNC.SUBSTIT1(mess(278,GML_MSGFASPR,1), [M:CNXD]CPYDEST),1) From GESECRAN
    ERR = 1
    Return
  Endif
  Filter [WFAS]
Return

################################################################################
# INTERFACE
################################################################################
Subprog C_CPYDEST(VALEUR)
Variable Char    VALEUR()
  # Pas de copie sur une même société
  If VALEUR = [M:CNXD]CPYSRC
    mkstat = -2
  Endif
End
