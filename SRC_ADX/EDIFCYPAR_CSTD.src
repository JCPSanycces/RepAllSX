#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDIFCYPAR                                                        #
# Manages main class EDIFCYPAR (this) and no child class                      #
# Author : RBA + JUCON                                                        #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"              : Gosub AREAD_AFTER  #SAM 110811
        When "AINSERT_CONTROL_AFTER"    : Gosub AINSERT_CONTROL_AFTER
        When "AUPDATE_CONTROL_AFTER"    : Gosub AUPDATE_CONTROL_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_VALIDATE"             : Gosub MET_VALIDATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "FCY"
      Case [L]ARULE
        When "CONTROL"   : Gosub FCY_CONTROL
        When "PROPAGATE" : Gosub FCY_PROPAGATE
      Endcase
    When "PARCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PARCOD_PROPAGATE
      Endcase
    When "PARTYP"
      Case [L]ARULE
        When "INIT"      : Gosub PARTYP_INIT
        When "CONTROL"   : Gosub PARTYP_CONTROL  #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
        When "PROPAGATE" : Gosub PARTYP_PROPAGATE
      Endcase
    When "GLN" #SAM 110811
      Case [L]ARULE
        When "PROPAGATE" : Gosub GLN_PROPAGATE
      Endcase
    When "IDTYPE" #SAM 110811
      Case [L]ARULE
        When "INIT"      : Gosub IDTYPE_INIT
        When "CONTROL"   : Gosub IDTYPE_CONTROL
        When "PROPAGATE" : Gosub IDTYPE_PROPAGATE
      Endcase
    When "EXCEDICOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EXCEDICOD_PROPAGATE
      Endcase
    When "STA"
      Case [L]ARULE
        When "INIT"      : Gosub STA_INIT
      Endcase
  Endcase
Return

###################################################################

$STA_INIT
  this.STA = 1
Return

###################################################################

$FCY_CONTROL
  If this.FCY <> ""
    this.FCY = func EDILIBA.FORMATVAL("FCY", this.FCY)
  Endif
Return

$FCY_PROPAGATE
  Local Integer WOK
  Local Char WERR (250)

  this.VALID  = [V]CST_ANO
  this.FCYNAM = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"FCYNAM")
  this.EXCEDICOD=""

  ASTATUS = fmet this.ADELETEERROR("PARCOD")
  WOK = func CONTROL_EXIST(this)
  If WOK = [V]CST_ATRUE
    WERR = mess(7,123,1)+"."-mess(22,100,1)  ## Creation not possible. Record already exists
    ASTATUS = fmet this.ASETERROR("FCY",WERR,[V]CST_AERROR)
  Endif
Return

####################################################################

$PARCOD_PROPAGATE
  Local Integer WOK
  Local Char WERR (250)

  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")
  this.PARTYP = fmet this.ACTX.ACACHE.EPR.AGETVALNUM(this.PARCOD,"PARTYP")
  this.VALID = [V]CST_ANO
  this.EXCEDICOD = ""

  ASTATUS = fmet this.ADELETEERROR("FCY")
  WOK = func CONTROL_EXIST(this)
  If WOK = [V]CST_ATRUE
    WERR = mess(7,123,1)+"."-mess(22,100,1)  ## Creation not possible. Record already exists
    ASTATUS = fmet this.ASETERROR("PARCOD",WERR,[V]CST_AERROR)
  Endif
Return

####################################################################

$PARTYP_INIT
  this.PARTYP = 2
Return

$PARTYP_CONTROL #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
  Local Char WERR (250)
#  WERR = "Type de partenaire interdit"
  WERR = mess(216,2006,1)
  If this.PARTYP <> 2 #controle tiers-société
    ASTATUS = fmet this.ASETERROR("PARCOD",WERR,[V]CST_AERROR)
  Endif
Return

$PARTYP_PROPAGATE
#  this.PARTYP = 2
Return

####################################################################

#Init SAM 110811 - Control for idenfification ID type
$GLN_PROPAGATE
  If this.GLN<>"" and this.IDTYPE=3 # and this.EXCEDICOD="" #110811 US6
    this.EXCEDICOD = this.GLN
  Endif
Return

####################################################################

$IDTYPE_INIT
  this.IDTYPE=6

Return

$IDTYPE_CONTROL
  Local Char WERR(250)
  Case this.IDTYPE
    When 1,4,5: WERR=mess(25,188,1)  # "Type not allowed"
  Endcase

  If WERR<>""
    ASTATUS = fmet this.ASETERROR("IDTYPE",WERR,[V]CST_AERROR)
  Endif
Return

$IDTYPE_PROPAGATE
  Local Char WERR(250)
  Local File FACILITY [FCY]
  this.EXCEDICOD=""
  ASTATUS = fmet this.ASETERROR("EXCEDICOD",WERR,[V]CST_AYES)
  Read[FCY]FCY0=this.FCY
  If !fstat
    Case this.IDTYPE
      When 2: #Local code is the CRN of the Site
              this.EXCEDICOD=[F:FCY]CRN
              If [F:FCY]CRN=""
                WERR=mess(154,2006,1) #Company tax ID number is empty
              Endif
      When 3: #GLN
              If this.GLN<>""
                this.EXCEDICOD=this.GLN
              Else
                WERR=mess(72,108,1) : # null value
              Endif
    Endcase
    LogicClose File [FCY]
  Endif
  If WERR<>""
    ASTATUS = fmet this.ASETERROR("EXCEDICOD",WERR,[V]CST_AWARNING)
  Endif
Return
#/ SAM 110811

####################################################################

$EXCEDICOD_PROPAGATE
  this.VALID = [V]CST_ANO
Return

####################################################################

#init SAM 110811
#********************************************************************
# Method AINSERT_CONTROL_AFTER
#********************************************************************
#*
#*!
$AREAD_AFTER
  Local File FACILITY [FCY]

  Read[FCY]FCY0=this.FCY
  If !fstat
    Case this.IDTYPE
      When 2: this.EXCEDICOD=[F:FCY]CRN
      When 3: this.EXCEDICOD=this.GLN
    Endcase
  Endif
  LogicClose File [FCY]
Return
#End 110811


#********************************************************************
# Method AINSERT_CONTROL_AFTER
#********************************************************************
#*
#*!
$AINSERT_CONTROL_AFTER
  Local Integer WOK
  WOK = fmet this.MET_VALIDATE()
  ASTATUS = WOK
Return

#********************************************************************
# Method AUPDATE_CONTROL_AFTER
#********************************************************************
#*
#*!
$AUPDATE_CONTROL_AFTER
  Local Integer WOK
  WOK = fmet this.MET_VALIDATE()
  ASTATUS = WOK
Return

#********************************************************************
# Method MET_VALIDATE
#********************************************************************
#*
#*!
$MET_VALIDATE
  Local Integer WOK
  Local Char WERR(250)
  If this.EXCEDICOD = ""
    this.VALID = [V]CST_ANO
    #WERR = "Setup is not complete"
    WERR = mess(81,2006,1)
    ASTATUS = fmet this.ASETERROR("EXCEDICOD",WERR,[V]CST_AWARNING)
  Else
    WOK = func CONTROL_EXIST(this)
    If WOK = [V]CST_ATRUE and [L]ARULE = "AINSERT_CONTROL_AFTER"
      this.VALID = [V]CST_ANO
      WERR = mess(7,123,1)+"."-mess(22,100,1)  ## Creation not possible. Record already exists
      ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
    Else
      this.VALID = [V]CST_AYES
    Endif
  Endif

  If this.VALID = [V]CST_AYES
    ARET_VALUE = [V]CST_AOK
  Else
    ARET_VALUE = [V]CST_AERROR
  Endif

Return

#********************************************************************
# Funprog CONTROL_EXIST
#********************************************************************
#
#* Set default values
#* @param WOBJECT
#* @return [V]CST_ATRUE/[V]CST_AFALSE
#*!
Funprog CONTROL_EXIST(WOBJECT)
Variable Instance WOBJECT Using OBJECT

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WOBJECT.FCY <> "" and WOBJECT.PARCOD <> ""
    Local File EDIFCYPAR [EFP]
    Read [EFP]EFP0=WOBJECT.FCY;WOBJECT.PARCOD
    If fstat = [V]CST_AOK
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [EFP]
  Endif
End WOK

