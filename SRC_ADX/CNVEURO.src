 Call COURSITE([F:POH]CUR,[F:POH]POHFCY,[F:POH]CHGTYP,[F:POH]ORDDAT,[F:POH]CHGCOE,SPSTAT) From TRTDEV
 Rewrite [POH]
 If fstat
  GOK=0 : Call FSTA("POH") From GLOCK : Goto AB_TRA1
 Endif
