 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MCS]OVEMACCPN,[F:MCS]OVEMACCPN,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MCS]OVELABCPN,[F:MCS]OVELABCPN,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MCS]OVESCOCPN,[F:MCS]OVESCOCPN,SPSTAT) From TRTDEV
 Rewrite [MCS]
 If fstat
  GOK=0 : Call FSTA("MCS") From GLOCK : Goto AB_TR25
 Endif
Commit
Return

$AB_TR25
Rollback
Return

$ROLL_TR25
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR25 : Endif

