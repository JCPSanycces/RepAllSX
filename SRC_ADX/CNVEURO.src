$MAJ_DEVSOC
Call MESSAGE(mess(84,115,1)-DEVDES-"->"-[F:CPY2]CPY,0) : # Mise à jour devise société
GOK = 1
Trbegin [CPY]
 Readlock [CPY]CPY0 = [F:CPY2]CPY
 If fstat
  GOK=0 : Call RSTA("CPY",[F:CPY2]CPY) From GLOCK : Rollback : Return
 Endif
 [F:CPY]ACCCUR = DEVDES
 Rewrite [CPY]
 If fstat
  GOK=0 : Call FSTA("CPY") From GLOCK : Rollback : Return
 Endif
Commit
Return

###############################################################################
$CNV_DIVVEN
Call MESSAGE(mess(89,115,1),-1) : # Conversion ventes

# Entête livraison
Local File SDELIVERY [SDH], SDELIVERY [SDH2]
Filter [SDH2] Order By Key CLE=CREDAT
For [SDH2]
 ISITE = find([F:SDH2]STOFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TRB1
  If GOK<1 : Break : Endif
 Endif
Next
Close Local File [SDH], [SDH2]
If GOK<1 Return Endif

# Entête commande vente
Local File SORDER [SOH], SORDER [SOH2]
Filter [SOH2] Order By Key CLE=CREDAT
For [SOH2]
 ISITE = find([F:SOH2]SALFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TRB2
  If GOK<1 : Break : Endif
 Endif
Next
Close Local File [SOH], [SOH2]
If GOK<1 Return Endif

# Entête devis vente
Local File SQUOTE [SQH], SQUOTE [SQH2]
Filter [SQH2] Order By Key CLE=CREDAT
For [SQH2]
 ISITE = find([F:SQH2]SALFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TRB3
  If GOK<1 : Break : Endif
 Endif
Next
Close Local File [SQH], [SQH2]
If GOK<1 Return Endif

# Historique entête commande vente
Local File VSORDER [VOH], VSORDER [VOH2]
Filter [VOH2] Order By Key CLE=CREDAT
For [VOH2]
 ISITE = find([F:VOH2]SALFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TRB4
  If GOK<1 : Break : Endif
 Endif
Next
Close Local File [VOH], [VOH2]
Return

$TRB1
GOK = 1
Trbegin [SDH]
 Readlock [SDH]SDH0 = [F:SDH2]SDHNUM
 If fstat=1
  GOK=-1 : GLOCK="$SDELIVERY"-[F:SDH2]SDHNUM : Goto ROLL_TRB1
 Elsif fstat
  GOK=0 : Call RSTA("SDH",[F:SDH2]SDHNUM) From GLOCK : Goto AB_TRB1
 Endif
 Call COURSITE([F:SDH]CUR,[F:SDH]STOFCY,[F:SDH]CHGTYP,[F:SDH]DLVDAT,[F:SDH]CHGRAT,SPSTAT) From TRTDEV
 Rewrite [SDH]
 If fstat
  GOK=0 : Call FSTA("SDH") From GLOCK : Goto AB_TRB1
 Endif
Commit
Return

$AB_TRB1
Rollback
Return

$ROLL_TRB1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRB1 : Endif

$TRB2
