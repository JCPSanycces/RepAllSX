$CNV_ABON
Call MESSAGE(mess(111,116,1),-1)              : # Abonnements
Call MESSAGE(mess(63,115,1)-mess(64,115,1),0) : # Baratin ...
Return

###############################################################################
$CNV_BUDGET
If [L]BUDGET<>2 : Return : Endif
Local File BUDPAR [BUP], BUD [BUD], BUDPAR [BUP2]


Call MESSAGE(mess(67,115,1),-1) : # Budgets

For [BUP2]BUP0
 Call CNVBUD2([F:BUP2]BUD,DATPAS,DEVCUR,DEVDES) From CNVBUD
 If GOK<1 : Break : Endif
Next

$FIN_CNVBUD
Close Local File [BUP2], [BUP], [BUD]
Return

###############################################################################
$CNV_BANQUE
Local File BANK [BAN], GACCOUNT [GAC]

Call MESSAGE(mess(45,120,1),-1) : # Banques

Call DEBTRANS From GLOCK
Gosub TR4

Close Local File [BAN], [GAC]
Return

$TR4
GOK = 1
Trbegin [GAC]
 For [BAN] Where CUR=DEVCUR & BANACC<>""
  Readlock [GAC]GAC0 = [F:BAN]BANACC
  If fstat=1
   GOK=-1 : GLOCK="$GACCOUNT"-[F:BAN]BANACC : Goto ROLL_TR4
  Elsif fstat
   GOK=0 : Call RSTA("GAC",[F:BAN]BANACC) From GLOCK : Goto AB_TR4
  Endif
  If [F:GAC]CUR=""
   [F:GAC]CUR = DEVCUR
   Rewrite [GAC]
   If fstat
    GOK=0 : Call FSTA("GAC") From GLOCK : Goto AB_TR4
   Endif
   If GTRACE<>""
    Call ECR_TRACE(mess(8,104,1)-[F:BAN]BANACC,0) From GESECRAN : # Compte
   Endif
  Elsif [F:GAC]CUR<>DEVCUR
   Call ECR_TRACE(mess(71,111,1)+":"-[F:BAN]BAN+":"-DEVCUR-[F:GAC]ACC+":"-[F:GAC]CUR,1) From GESECRAN
   # Incohérence devises
  Endif
 Next
Commit
Return

$AB_TR4
Rollback
Return

$ROLL_TR4
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR4 : Endif

################################################################################################
$CNV_DIVDOS
If [L]PERMUT<>2 : Return : Endif

Call MESSAGE(mess(70,115,1),-1) : # Conversion autres zones dossier

Call CNVPARAM(  DEVDES,DEVCUR,"AMTDCLDAS" , DATPAS)
Call CNVPARAM(  DEVDES,DEVCUR,"FUPAMT"    , DATPAS)
If [F:ADS]MODULE(8)=2 : # TC
 WCHP(1) = "DEFVAL" : WARR(1) = 0
 Call CNVDIV2("",DEVDES,DEVCUR,"PFOOTINV"  ,WCHP,1,"","","","",DATPAS,"AMTCOD=2",WARR) From CNVDIV
 WCHP(1) = "DEFVAL" : WARR(1) = 0
 Call CNVDIV2("",DEVDES,DEVCUR,"SFOOTINV"  ,WCHP,1,"","","","",DATPAS,"AMTCOD=2",WARR) From CNVDIV
 WCHP(1) = "TDSMIN" : WARR(1) = 0
 WCHP(2) = "TDSMAX" : WARR(2) = 0
 Call CNVDIV2("",DEVDES,DEVCUR,"SFOOTINV"  ,WCHP,2,"","","","",DATPAS,"",WARR) From CNVDIV
 WCHP(1) = "VALUOM" : WARR(1) = 0
 Call CNVDIV2("",DEVDES,DEVCUR,"CACNA"     ,WCHP,1,"","","","",DATPAS,"",WARR) From CNVDIV
 WCHP(1) = "PTEMINAMT" : WARR(1) = 0
 WCHP(2) = "DUDMINAMT" : WARR(2) = 0
 Call CNVDIV2("",DEVDES,DEVCUR,"TABPAYTERM",WCHP,2,"","","","",DATPAS,"",WARR) From CNVDIV
 WCHP(1) = "PCKPRI" : WARR(1) = 12
 Call CNVDIV2("",DEVDES,DEVCUR,"TABPACKAGE",WCHP,1,"","","","",DATPAS,"",WARR) From CNVDIV
 WCHP(1) = "BASPRI" : WARR(1) = 12
 WCHP(2) = "THEPRI" : WARR(2) = 12
 WCHP(3) = "MINPRI" : WARR(3) = 12
 Call CNVDIV2("",DEVDES,DEVCUR,"ITMSALES"  ,WCHP,3,"","","","",DATPAS,"",WARR) From CNVDIV
 # ARODEC est à 12 dans ces cas pour garder la précision maxi d'origine (TB)
 WCHP(1) = "ADL"    : WARR(1) = 0
 WCHP(2) = "FXDAMT" : WARR(2) = 0
 WCHP(3) = "TSDFRE" : WARR(3) = 0
 #WCHP(4) = "BKT"    : WARR(4) = 0
 Call CNVDIV2("",DEVDES,DEVCUR,"BPCARRIER" ,WCHP,3,"","","","",DATPAS,"",WARR) From CNVDIV
 WCHP(1) = "ADL"    : WARR(1) = 0
 WCHP(2) = "PRI"    : WARR(2) = 0
 #WCHP(3) = "BKT"    : WARR(3) = 0
 Call CNVDIV2("",DEVDES,DEVCUR,"CARPRICE"  ,WCHP,2,"","","","",DATPAS,"",WARR) From CNVDIV
 WCHP(1) = "CDTISR"    : WARR(1) = 0
 WCHP(2) = "FUPMINAMT" : WARR(2) = 0
 WCHP(3) = "ORDMINAMT" : WARR(3) = 0
 WCHP(4) = "OSTAUZ"    : WARR(4) = 0
 Call CNVDIV2("",DEVDES,DEVCUR,"BPCUSTOMER",WCHP,4,"","","","",DATPAS,"",WARR) From CNVDIV
 WCHP(1) = "ORDMINAMT" : WARR(1) = 0
 WCHP(2) = "OSTAUZAMT" : WARR(2) = 0
 Call CNVDIV2("",DEVDES,DEVCUR,"BPSUPPLIER",WCHP,2,"","","","",DATPAS,"",WARR) From CNVDIV
Endif
If [F:ADS]MODULE(1)=2 : # Compta
 WCHP(1) = "VALUOM" : WARR(1) = 0
 Call CNVDIV2("",DEVDES,DEVCUR,"CPYRAMIDG" ,WCHP,1,"","","","",DATPAS,"",WARR) From CNVDIV
Endif
Return

###############################################################################################
Subprog CNVPARAM(DEVCUR,DEVDES,PARAM,DATPAS)
Value Char DEVCUR, DEVDES
Value Char PARAM
Value Date DATPAS

Local Decimal WMONT
Local Integer TYPCUR, SPSTAT
Local Char    VALPAR(20)

If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
Local File ADOVAL [ADW2]

Call PARAM("","CHGTYP",VALPAR) From ADOVAL
TYPCUR = val(VALPAR)
If TYPCUR=0 : TYPCUR = 1 : Endif

Call DEBTRANS From GLOCK
Gosub TR30
If GOK<1 : End : Endif
Call MESSAGE(mess(9,115,1)-PARAM,0) : # Conversion paramètre
End

$TR30
GOK = 1
Trbegin [ADW]
 For [ADW2] Where PARAM=[L]PARAM
  Readlock [ADW]ADW0 = [F:ADW2]CMP ; [F:ADW2]FCY ; [F:ADW2]PARAM
  If fstat=1
   GOK=-1 : GLOCK="$ADOVAL"-[F:ADW2]PARAM : Break
  Elsif fstat
   GOK=0 : Call RSTA("ADW",[F:ADW2]PARAM) From GLOCK : Break
  Endif
  WMONT  = val([F:ADW]VALEUR)
  Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,WMONT,WMONT,SPSTAT) From TRTDEV
  [F:ADW]VALEUR = num$(WMONT)
  Rewrite [ADW]
  If fstat
   GOK=0 : Call FSTA("ADW") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR30
 Elsif !GOK : Goto AB_TR30
 Endif
Commit
Return

$AB_TR30
Rollback
Return

$ROLL_TR30
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR30 : Endif

###############################################################################
$MAJ_DEVSYS
If [L]PERMUT=2
 Call MESSAGE(mess(80,115,1)-DEVCUR-"<->"-DEVDES,0) : # Permutation devises
 GOK = 1
 Trbegin [ADW]
  Readlock [ADW]ADW0 = "";"";"SYSCUR"
  If fstat
   GOK=0 : Call RSTA("ADW","SYSCUR") From GLOCK : Rollback : Return
  Else
   [F:ADW]VALEUR = [L]DEVCUR : # Devise reporting
   Rewrite [ADW]
   If fstat
    GOK=0 : Call FSTA("ADW") From GLOCK : Rollback : Return
   Endif
  Endif
 Commit
 GSYSCUR = DEVCUR
 Trbegin [ADS]
  Readlock [ADS]DOSSIER = [L]DOSMAJ
  If fstat
   GOK=0 : Call RSTA("ADS",[L]DOSMAJ) From GLOCK : Rollback : Return
  Else
   [F:ADS]RPTCUR = [L]DEVCUR : # Devise reporting
   Rewrite [ADS]
   If fstat
    GOK=0 : Call FSTA("ADS") From GLOCK : Rollback : Return
   Endif
  Endif
 Commit
Endif
Return

###############################################################################
$MAJ_DEVPAYS
If [L]TOUSOC=2
 Call MESSAGE(mess(83,115,1)-DEVDES-"->"-GPAYS,0) : # Mise à jour devise pays
 GOK = 1
 Trbegin [TCY]
  Readlock [TCY]TCY0 = GPAYS
  If fstat
   GOK=0 : Call RSTA("TCY",GPAYS) From GLOCK : Rollback : Return
  Elsif [F:TCY]CUR=DEVCUR
   [F:TCY]CUR = DEVDES : # Devise pays
   Rewrite [TCY]
   If fstat
    GOK=0 : Call FSTA("TCY") From GLOCK : Rollback : Return
   Endif
  Endif
 Commit
 GLOCALDEV = DEVDES
Endif
Return

###############################################################################
Subprog AS_TOUSOC(VALEUR)
Variable Integer  VALEUR
#Call AS_ALLCPY(VALEUR) From CPTTRT
# bug 12539 (CP:22/01/02)
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    mkstat = 1 : End 
Endif
End

Subprog AS_SOCIETE(VALEUR)
Variable Char     VALEUR
If [M]TOUSOC=2 : mkstat = 1 : End : Endif
End

Subprog AS_PERMUT(VALEUR)
Variable Integer VALEUR
Local Char    DEVCUR(GLONCUR)
Raz DEVCUR
If [M]TOUSOC<>2
 mkstat = 1 : End
Endif
For [CPY]CPY0 Where CPYLEGFLG=2
 If DEVCUR=""
  DEVCUR = [F:CPY]ACCCUR
 Else
  If [F:CPY]ACCCUR<>DEVCUR
   # Permutation impossible, toutes les sociétés n'ont pas la même devise
   mkstat = 1 : Break
  Endif
 Endif
Next
End

Subprog AS_DEVCUR(VALEUR)
Variable Char VALEUR
If [M]TOUSOC<>2
 Read [CPY]CPY0 = [M]SOCIETE
 VALEUR = [F:CPY]ACCCUR
 mkstat = 2
Else
 VALEUR = GLOCALDEV
Endif
End

Subprog AS_DEVDES(VALEUR)
Variable Char VALEUR
VALEUR = GSYSCUR
mkstat = 2
End

Subprog C_DEVDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]DEVCUR
 mkstat = 2
Endif
End

Subprog AS_TABLO(VALEUR)
Variable Integer VALEUR
If [M]TOUSOC<>2 : mkstat=1 : Endif
End

Subprog AS_BUDGET(VALEUR)
Variable Integer VALEUR
If [M]TOUSOC<>2 : mkstat=1 : Endif
End

Subprog AS_FRAIS(VALEUR)
Variable Integer  VALEUR
If [M]TOUSOC<>2 : mkstat=1 : Endif
End

Subprog AS_STOLOT(VALEUR)
Variable Integer VALEUR
If [M]TOUSOC<>2 : mkstat=1 : Endif
End
