  GOK=0 : Call RSTA("PIH",[F:PIH2]NUM) From GLOCK : Goto AB_TR10
 Endif
 WRAT = [F:PIH]RATCUR
 If [F:PIH]RATRPT=0 & WRAT<>0 : # mb 9.5.1 Cours devise reporting société pas toujours renseigné
  Call CONVERT(DEVCUR,DEVDES,DEVDES,[F:PIH]CURTYP,[F:PIH]ACCDAT,1000000*WRAT,[F:PIH]RATRPT,SPSTAT) From TRTDEV
  [F:PIH]RATRPT = arr([F:PIH]RATRPT/1000000,0.000001)
 Endif
 [F:PIH]RATCUR = [F:PIH]RATRPT
 If [L]PERMUT=2
  [F:PIH]RATRPT = WRAT
 Endif
 Rewrite [PIH]
 If fstat
  GOK=0 : Call FSTA("PIH") From GLOCK : Goto AB_TR10
 Endif
