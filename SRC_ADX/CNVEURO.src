Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR10 : Endif

###############################################################################
$CNV_REGLE
Local File PAYMENTH  [PYH], PAYMENTH  [PYH2]
&        , PAYMENTD  [PYD], PAYMENTA  [PYA]

Call MESSAGE(mess(2,665,1),-1) : # Règlements

Filter [PYH2] Where CPY=[F:CPY2]CPY Order By Key CLE=CPY
For [PYH2]
 Call DEBTRANS From GLOCK
 Gosub TR13
 If GOK<1 : Break : Endif
Next
Close Local File [PYH], [PYH2], [PYD], [PYA]
Return

$TR13
GOK = 1
Trbegin [PYH], [PYD]
 Readlock [PYH]PYH0 = [F:PYH2]NUM
 If fstat=1
  GOK=-1 : GLOCK="$PAYMENTH"-[F:PYH2]NUM : Goto ROLL_TR13
 Elsif fstat
  GOK=0 : Call RSTA("PYH",[F:PYH2]NUM) From GLOCK : Goto AB_TR13
 Endif
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCUR,[F:PYH]ACCDAT,[F:PYH]AMTNYTBIL,[F:PYH]AMTNYTBIL,SPSTAT) From TRTDEV
 Rewrite [PYH]
 If fstat
  GOK=0 : Call FSTA("PYH") From GLOCK : Goto AB_TR13
 Endif

 For [PYD]PYD0 Where NUM=[F:PYH2]NUM
  WMONT  = [F:PYD]PAYLOCLIN
  [F:PYD]PAYLOCLIN  = [F:PYD]PAYRPTLIN
  If [L]PERMUT=2
   [F:PYD]PAYRPTLIN  = WMONT
  Endif
  Rewrite [PYD]
  If fstat=1
   GOK=-1 : GLOCK = "$PAYMENTD" : Break
  Elsif fstat
   GOK=0 : Call FSTA("PYD") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR13
 Elsif !GOK : Goto AB_TR13
 Endif
Commit
Return

$AB_TR13
Rollback
Return

$ROLL_TR13
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR13 : Endif

###############################################################################
$CNV_PROROG
Local File PROROGPCE  [PRP], PROROGPCE  [PRP2]

Call MESSAGE(mess(143,117,1),-1) : # Prorogation

Filter [PRP2] Order By Key CLE=FCYLIN
For [PRP2]
 ISITE = find([F:PRP2]FCYLIN,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR14
  If GOK<1 : Break : Endif
 Endif
Next
Close Local File [PRP], [PRP2]
Return

$TR14
GOK = 1
Trbegin [PRP]
 Readlock [PRP]PRP0 = [F:PRP2]ACCNUM
 If fstat=1
  GOK=-1 : GLOCK="$PROROGPCE"-[F:PRP2]ACCNUM : Goto ROLL_TR14
 Elsif fstat
  GOK=0 : Call RSTA("PYH",[F:PRP2]ACCNUM) From GLOCK : Goto AB_TR14
 Endif
 WMONT  = [F:PRP]AMTLOC
 [F:PRP]AMTLOC = [F:PRP]AMTRPT
 If [L]PERMUT=2
  [F:PRP]AMTRPT = WMONT
 Endif
 Rewrite [PRP]
 If fstat
  GOK=0 : Call FSTA("PRP") From GLOCK : Goto AB_TR14
 Endif
Commit
Return

$AB_TR14
Rollback
Return

$ROLL_TR14
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR14 : Endif

################################################################################################
$CNV_STOCK
Call MESSAGE(mess(69,115,1),-1) : # Conversion des stocks (modifiée le 24/09/01)
##WCHP(1) = "LOTAVC" : WARR(1) = 6  ## STOFCY n'est pas dans STOLOT Quelle est la devise ??
##Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"STOLOTFCY"   ,WCHP,1,"","STOFCY","","",DATPAS,"",WARR) From CNVDIV
WCHP(1) = "CST"    : WARR(1) = 0
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"STOCOST"  ,WCHP,1,"","STOFCY","","",DATPAS,"",WARR) From CNVDIV
WCHP(1) = "ORDCST" : WARR(1) = 0
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"STOPAR"   ,WCHP,1,"","STOFCY","","",DATPAS,"",WARR) From CNVDIV
WCHP(1) = "PRI"    : WARR(1) = GDECPRI
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"STOCK"    ,WCHP,1,"","STOFCY","","",DATPAS,"",WARR) From CNVDIV
WCHP(1) = "PRI"    : WARR(1) = GDECPRI
WCHP(2) = "PRINEW" : WARR(2) = GDECPRI
WCHP(3) = "PRIREG" : WARR(3) = GDECPRI
WCHP(4) = "AMTDEV" : WARR(4) = 0
WCHP(5) = "WIPCLE" : WARR(5) = 0
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"STOCSTREG",WCHP,5,"","STOFCY","","",DATPAS,"",WARR) From CNVDIV
WCHP(1) = "PRI"    : WARR(1) = GDECPRI
WCHP(2) = "PRIREG" : WARR(2) = GDECPRI
WCHP(3) = "AMTDEV" : WARR(3) = 0
WCHP(4) = "WIPCLE" : WARR(4) = 0
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"STOJOU"   ,WCHP,4,"","STOFCY","","",DATPAS,"",WARR) From CNVDIV
WCHP(1) = "AVC"       : WARR(1) = 6
WCHP(2) = "AVCBASAMT" : WARR(2) = 0
WCHP(3) = "LASRCPPRI" : WARR(3) = GDECPRI
WCHP(4) = "MONRCPAMT" : WARR(4) = 0
WCHP(5) = "YEARCPAMT" : WARR(5) = 0
WCHP(6) = "MONISSAMT" : WARR(6) = 0
WCHP(7) = "YEAISSAMT" : WARR(7) = 0
WCHP(8) = "AMTDEV"    : WARR(8) = 0
WCHP(9) = "WIPCLE"    : WARR(9) = 0
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"ITMMVT"   ,WCHP,9,"","STOFCY","","",DATPAS,"",WARR) From CNVDIV
WCHP(1) = "AVC"       : WARR(1) = 6
WCHP(2) = "AVCBASAMT" : WARR(2) = 0
WCHP(3) = "LASRCPPRI" : WARR(3) = GDECPRI
WCHP(4) = "MONRCPAMT" : WARR(4) = 0
WCHP(5) = "YEARCPAMT" : WARR(5) = 0
WCHP(6) = "MONISSAMT" : WARR(6) = 0
WCHP(7) = "YEAISSAMT" : WARR(7) = 0
WCHP(8) = "AMTDEV"    : WARR(8) = 0
WCHP(9) = "WIPCLE"    : WARR(9) = 0 
WCHP(10)= "LASPURPRI" : WARR(10)= GDECPRI
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"ITMMVTHIS",WCHP,10,"","STOFCY","","",DATPAS,"",WARR) From CNVDIV
WCHP(1) = "CUNCST"    : WARR(1) = GDECPRI
WCHP(2) = "NETCUNCST" : WARR(2) = GDECPRI
WCHP(3) = "PRIORD"    : WARR(3) = GDECPRI
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"CUNLISDET",WCHP,3,"","STOFCY","","CUR",DATPAS,"",WARR) From CNVDIV

# conversion des 2 tables temporaires servant à l'interface des stocks (24/9/01)
WCHP(1) = "PRI"       : WARR(1) = GDECPRI
WCHP(2) = "PRIREG"    : WARR(2) = GDECPRI
WCHP(3) = "PRIORI"    : WARR(3) = GDECPRI
WCHP(4) = "AGGAMT"    : WARR(4) = 0
WCHP(5) = "AGGAMTORI" : WARR(5) = 0
WCHP(6) = "AGGDEV"    : WARR(6) = 0
WCHP(7) = "WIPCLE"    : WARR(7) = 0
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"STOJOUAGG",WCHP,7,"","FINRSPFCY","","CUR",DATPAS,"",WARR) From CNVDIV
WCHP(1) = "PRI"       : WARR(1) = GDECPRI
WCHP(2) = "PRIREG"    : WARR(2) = GDECPRI
WCHP(3) = "PRIORI"    : WARR(3) = GDECPRI
WCHP(4) = "AGGAMT"    : WARR(4) = 0
WCHP(5) = "AGGDEV"    : WARR(5) = 0
WCHP(6) = "WIPCLE"    : WARR(6) = 0
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"STOREGAGG",WCHP,6,"","FINRSPFCY","","",DATPAS,"",WARR) From CNVDIV

Return

################################################################################################
$CNV_STOLOTFCY
# traité à part (27/09/01 - TB)
If [L]STOLOTFCY <> 2 Return Endif

Raz ERR
Onerrgo NERR
Local File STOLOTFCY [SLF], STOLOTFCY [SLF2]
Onerrgo ERR
If ERR : Return : Endif

Call MESSAGE(mess(104,115,1),-1) : # Conversion des lots de stock

Filter [SLF2] Order By Key CLE=CUR
For [SLF2]
 If [F:SLF2]CUR=DEVCUR
  Call DEBTRANS From GLOCK
  Gosub TR_SLF
  If GOK<1 : Break : Endif
 Endif
Next
Close Local File [SLF], [SLF2]
Return

$TR_SLF
GOK = 1
Trbegin [SLF]
 [F:SLF] = [F:SLF2]
 Readlock [SLF]SLF0 = 
 If fstat=1
  GOK=-1 : GLOCK="$STOLOTFCY" : Goto ROLL_TR_SLF
 Elsif fstat
  GOK=0 : Call RSTA("SLF","") From GLOCK : Goto AB_TR_SLF
 Endif
 Call CONVERT3(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,0,[F:SLF]AVCBASAMT,[F:SLF]AVCBASAMT,SPSTAT) From TRTDEV
 Call CONVERT3(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:SLF]AVC,[F:SLF]AVC,SPSTAT) From TRTDEV
 [F:SLF]CUR = DEVDES
 Rewrite [SLF]
 If fstat
  GOK=0 : Call FSTA("SLF") From GLOCK : Goto AB_TR_SLF
 Endif
Commit
Return

$AB_TR_SLF
Rollback
Return

$ROLL_TR_SLF
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_SLF : Endif

################################################################################################
$CNV_FRAIS
If [L]FRAIS<>2 : Return : Endif

Raz ERR
Onerrgo NERR
Local File OVERHEAD [OVE], OVERHEAD [OVE2]
Onerrgo ERR
If ERR : Return : Endif

Call MESSAGE(mess(103,115,1),-1) : # Conversion des frais généraux

Filter [OVE2] Order By Key CLE=CUR
For [OVE2]
 If [F:OVE2]CUR=DEVCUR
  Call DEBTRANS From GLOCK
  Gosub TR_FRAIS
  If GOK<1 : Break : Endif
 Endif
Next
Close Local File [OVE], [OVE2]
Return

$TR_FRAIS
GOK = 1
Trbegin [OVE]
 [F:OVE] = [F:OVE2]
 Readlock [OVE]OVE0 = 
 If fstat=1
  GOK=-1 : GLOCK="$OVERHEAD" : Goto ROLL_TR_FRAIS
 Elsif fstat
  GOK=0 : Call RSTA("OVE","") From GLOCK : Goto AB_TR_FRAIS
 Endif
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:OVE]FXDOVEA  ,[F:OVE]FXDOVEA  ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:OVE]FXDOVEB  ,[F:OVE]FXDOVEB  ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:OVE]FXDOVEC  ,[F:OVE]FXDOVEC  ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:OVE]FXDOVED  ,[F:OVE]FXDOVED  ,SPSTAT) From TRTDEV
 [F:OVE]CUR = DEVDES
 Rewrite [OVE]
 If fstat
  GOK=0 : Call FSTA("OVE") From GLOCK : Goto AB_TR_FRAIS
 Endif
Commit
Return

$AB_TR_FRAIS
Rollback
Return

$ROLL_TR_FRAIS
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_FRAIS : Endif

################################################################################################
$CNV_COST
