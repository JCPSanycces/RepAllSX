###############################################################################
$CNV_TABLO
If [L]TABLO<>2 : Return : Endif
Raz ERR
Onerrgo NERR
Local File GACTXSVAL  [TXV],  GACTXSVALP [TVP]
&        , GACTXSVALP [TVP2], GACTXSFIE  [TXF]
&        , GACTXSARR  [TXA],  GACTXSARRD [TAD]
&        , GRUCPYD    [CYD],  GACTXSARR  [TXA2]

Onerrgo ERR
If ERR : Return : Endif


Call MESSAGE(mess(66,115,1),-1) : # Conversion des tableaux de bord

For [TXA2]TXA0
 Call CNVTAB2([F:TXA2]GRUCPY,[F:TXA2]YEAPAR,[F:TXA2]TXSARRCOD,2,DATPAS,DEVCUR,DEVDES) From CNVTAB
 If GOK<1 : Break : Endif
Next

$FIN_CNVTAB
Close Local File [TXV], [TVP], [TVP2], [TXF], [TXA], [TAD], [CYD], [TXA2]
Return

