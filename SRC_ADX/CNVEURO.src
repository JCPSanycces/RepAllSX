&        , ITCNAT    [ICN], ITCNAT    [ICN2]
&        , ITCMAT    [ICC], ITCMAT    [ICC2]
&        , ITCWST    [IWC], ITCWST    [IWC2]

Call MESSAGE(mess(105,115,1),-1) : # Conversion des coûts

Filter [ITC2] Order By Key CLE=CREDAT
For [ITC2]
 ISITE = find([F:ITC2]STOFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR17
  If GOK<1 : Break : Endif
 Endif
Next
If GOK<1 Return Endif

Filter [ICC2] Order By Key CLE=CREDAT
For [ICC2]
 ISITE = find([F:ICC2]STOFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR19
  If GOK<1 : Break : Endif
 Endif
Next
If GOK<1 Return Endif

Filter [IWC2] Order By Key CLE=CREDAT
For [IWC2]
 ISITE = find([F:IWC2]STOFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR20
  If GOK<1 : Break : Endif
 Endif
Next
If GOK<1 Return Endif

# nouvelles tables des détails de frais généraux v 130 (TB - 27/02/01)
Filter [ICN2] Order By Key CLE=CREDAT
For [ICN2]
 ISITE = find([F:ICN2]STOFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR21
  If GOK<1 : Break : Endif
 Endif
Next
Close Local File [ITC], [ITC2], [ICC], [ICC2], [IWC], [IWC2], [ICN], [ICN2]
Return

################################################################################################
$CNV_GPAO
Local File MFGCOST   [MFC], MFGCOST   [MFC2]
&        , WORKCOST  [MWC], WORKCOST  [MWC2]
&        , OVERHEAD [OVE]
Local File MFCNAT    [MCN], MFCNAT    [MCN2],
&          MFCMAT    [MCC], MFCMAT    [MCC2],
&          MFCWST    [MCW], MFCWST    [MCW2],
&          MFCSCRAP  [MCS], MFCSCRAP  [MCS2]

Call MESSAGE(mess(72,115,1),-1) : # Conversion GPAO

WCHP(1) = "CPLCRG" : WARR(1) = GDECPRI
WCHP(2) = "CPLPRI" : WARR(2) = GDECPRI
WCHP(3) = "EXTPRI" : WARR(3) = GDECPRI
# Rajout de zones 130 24/09/01  (TB)
WCHP(4) = "REFPRI" : WARR(4) = GDECPRI
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"MFGOPE"   ,WCHP,4,"","PLNFCY","","",DATPAS,"",WARR) From CNVDIV
WCHP(1) = "CPLCRG" : WARR(1) = GDECPRI
WCHP(2) = "CPLPRI" : WARR(2) = GDECPRI
WCHP(3) = "EXTPRI" : WARR(3) = GDECPRI
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"MFGOPETRK",WCHP,3,"","MFGFCY","","",DATPAS,"",WARR) From CNVDIV
#WCHP(1) = "CPLCRG" : WARR(1) = GDECPRI
#WCHP(2) = "CPLPRI" : WARR(2) = GDECPRI
#WCHP(3) = "EXTPRI" : WARR(3) = GDECPRI
#Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"MFGRCCP" ,WCHP,3,"","PLNFCY","","",DATPAS,"",WARR) From CNVDIV

# Rajout de zones 130 24/09/01  (TB)
WCHP(1) = "REFPRI" : WARR(1) = GDECPRI
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"ROUOPE"   ,WCHP,1,"","FCY"   ,"","",DATPAS,"",WARR) From CNVDIV
# conversion des 2 tables temporaires servant à l'interface des temps (24/09/01)
WCHP(1) = "SETAMT" : WARR(1) = 0
WCHP(2) = "OPEAMT" : WARR(2) = 0
WCHP(3) = "SCOAMT" : WARR(3) = 0
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"OPETRKAGG",WCHP,3,"","FINRSPFCY","","CUR",DATPAS,"",WARR) From CNVDIV
WCHP(1) = "NATAMT" : WARR(1) = 0
Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"OPEOVEAGG",WCHP,1,"","FINRSPFCY","","CUR",DATPAS,"",WARR) From CNVDIV

Filter [MFC2] Order By Key CLE=CREDAT
For [MFC2]
 ISITE = find([F:MFC2]STOFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR15
  If GOK<1 : Break : Endif
 Endif
Next
If GOK<1 Return Endif

Filter [MWC2] Order By Key CLE=CREDAT
For [MWC2]
 ISITE = find([F:MWC2]VLTFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR16
  If GOK<1 : Break : Endif
 Endif
Next
If GOK<1 Return Endif

# nouvelles tables des détails de frais généraux v 130 (TB - 27/02/01)

Filter [MCN2] Order By Key CLE=CREDAT
For [MCN2]
 ISITE = find([F:MCN2]STOFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR22
  If GOK<1 : Break : Endif
 Endif
Next

# Liste des Frais généraux dont la devise est différente de celle de la section valorisation
# dans GP plutôt que stock ! (02/10/01- Bug 10727)

Filter [MWC] Order By Key CLE=CREDAT
For [MWC]
 ISITE = find([F:MWC]VLTFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  If [F:MWC]OVECOD<> ""
   Read [OVE]OVE0 = [F:MWC]OVECOD
   If !fstat & [F:OVE]CUR<>DEVDES
    Call ECR_TRACE(mess(69,193,1)-[F:OVE]CUR-[F:MWC]OVECOD-"<>"-DEVDES-[F:MWC]VLTCCE,1) From GESECRAN
    # La devise des frais généraux est différente de celle du site de la section
   Endif
  Endif
 Endif
Next

Filter [MCC2] Order By Key CLE=CREDAT
For [MCC2]
 ISITE = find([F:MCC2]STOFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR23
  If GOK<1 : Break : Endif
 Endif
Next
If GOK<1 Return Endif

Filter [MCW2] Order By Key CLE=CREDAT
For [MCW2]
 ISITE = find([F:MCW2]STOFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR24
  If GOK<1 : Break : Endif
 Endif
Next
If GOK<1 Return Endif

Filter [MCS2] Order By Key CLE=CREDAT
For [MCS2]
 ISITE = find([F:MCS2]STOFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR25
  If GOK<1 : Break : Endif
 Endif
Next
If GOK<1 Return Endif



Close Local File [MFC], [MFC2], [MWC], [MWC2]
&              , [MCC], [MCC2], [MCW], [MCW2], [MCS], [MCS2], [OVE], [MCN], [MCN2]
Return

$TR15
GOK = 1
Trbegin [MFC]
 [F:MFC] = [F:MFC2]
 Readlock [MFC]MFC0 = 
 If fstat=1
  GOK=-1 : GLOCK="$MFGCOST" : Goto ROLL_TR15
 Elsif fstat
  GOK=0 : Call RSTA("MFC","") From GLOCK : Goto AB_TR15
 Endif
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]MATTOT   ,[F:MFC]MATTOT   ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]MACTOT   ,[F:MFC]MACTOT   ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]LABTOT   ,[F:MFC]LABTOT   ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]SCOTOT   ,[F:MFC]SCOTOT   ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]INVDTATOT,[F:MFC]INVDTATOT,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]OVETOT   ,[F:MFC]OVETOT   ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]CSTTOT   ,[F:MFC]CSTTOT   ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]MATCST   ,[F:MFC]MATCST   ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]MACCST   ,[F:MFC]MACCST   ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]LABCST   ,[F:MFC]LABCST   ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]SCOCST   ,[F:MFC]SCOCST   ,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]INVDTACST,[F:MFC]INVDTACST,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]OVEMATCST,[F:MFC]OVEMATCST,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]OVEMACCST,[F:MFC]OVEMACCST,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]OVELABCST,[F:MFC]OVELABCST,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]OVESCOCST,[F:MFC]OVESCOCST,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]MACCPNCST,[F:MFC]MACCPNCST,SPSTAT) From TRTDEV
 Call CONVERT3_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,GDECPRI,[F:MFC]LABCPNCST,[F:MFC]LABCPNCST,SPSTAT) From TRTDEV
