 Readlock [POH]POH0 = [F:POH2]POHNUM
 If fstat=1
  GOK=-1 : GLOCK="$PORDER"-[F:POH2]POHNUM : Goto ROLL_TRA1
 Elsif fstat
  GOK=0 : Call RSTA("POH",[F:POH2]POHNUM) From GLOCK : Goto AB_TRA1
