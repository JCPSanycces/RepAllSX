#<AdxTL>@(#)5.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
# Adaption V140 =>  Passage par GTRAITE
#Call CNVEURO
End
#---------------------------------------------------------------------
# Teste de la présence des champs monétaire dans le traitement CNVEURO
Local File ATABZON [ATZ], ATABLE [ATB]
Local Char WSRC(250), WBUF(250)
Local Integer LOK, I
Local Char LTABEXC(20)(100)
Raz I
#----- Liste des tables à exclure du test -------#
I+=1 : LTABEXC(I)="ITMCOSTW"
I+=1 : LTABEXC(I)="ITCMATW"
I+=1 : LTABEXC(I)="MATCSTW"
WSRC = filpath("TRT","CNVEURO","src")
Call OUVRE_TRACE("CNV_EURO") From LECFIC
Openi WSRC Using [TRT]
For [ATB] Where CODFIC<"W" & !find(CODFIC,LTABEXC)
#    Call ECR_TRACE([F:ATB]CODFIC,0) From GESECRAN
    For [ATZ] Where (pat(CODTYP,"MD*")=1 |pat(CODTYP,"MS*")=1)
&                 & CODFIC=[F:ATB]CODFIC
        Raz LOK
        Seek First+1 Using [TRT] 
        Gosub TRT
        If !LOK
            Call ECR_TRACE([F:ATZ]CODFIC-[F:ATZ]CODZONE,1) From GESECRAN
        Endif
    Next
Next
Openi Using [TRT]
Call SUPP_TRACE From LECFIC
End

$TRT
Rdseq WBUF Using [TRT]
If fstat=0
    If pat(WBUF,'*"'+[F:ATZ]CODZONE+'"*')=1 | pat(WBUF,"*[F:"+[ATB]ABRFIC+"*]"+[F:ATZ]CODZONE+"*")=1
        LOK=1
        Return
    Endif
    Goto TRT
Endif
Return

#########################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
Endcase
Return

#######################################################
# Moulinette Passage Euro                             #
#######################################################
$INIT
Local Integer I, J, K, OK, SPSTAT, ERR, FLG
Local Char    DEVCUR(GLONCUR), DEVDES(GLONCUR), VALPAR(20)
Local Decimal WMONT, WMONT1, WMONT2, WRAT
Local Integer TYPCUR, ANOM
Local Integer PERMUT, BUDGET, TABLO, TOUSOC, TRACE, FRAIS, STOLOTFCY
Local Date    DATDEB, DATFIN, DATPAS
Local Integer ISITE
Local Char    SOCIETE(GLONCPY), DOSMAJ(10)
Local Integer BATCH
Local Char    CRITERE(250)
Local Char    WCHP(12)(1..20)
Local Integer WARR(1..20)

Onerrgo ERR

If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE  [TCH] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:CPY2])=0 : Local File COMPANY   [CPY2] : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER   [ADS] : Endif

Local Mask CNVEURO [CNV] : Raz [CNV]

Local Char TIT(30) 
TIT = mess(82,107,1) : # Conversion EURO
Return
 

$CONTROLE
If [M]DEVCUR=[M]DEVDES : FIN=1 : Return : Endif
If !GSERVEUR
 OK = 2 : Call AVERTIR(mess(79,115,1),OK) From GESECRAN
 If OK<>2 : FIN=1 : Return :  Endif
Endif
Call MONO(OK) From AX3MONO
If !OK : FIN=1 : Return : Endif 
If !GSERVEUR & [M:CNV]TRACE=2
 Call OUVRE_TRACE(TIT) From LECFIC
 TRA =1 
Endif
Return

$EXEC
Read [TCY]TCY0 = GPAYS
If fstat
 Read [TCY]TCY0 = ""
Endif
If fstat=0
 GLOCALDEV = [F:TCY]CUR
Else
 GLOCALDEV = "FRF"
Endif
[L] = [M:CNV]
DOSMAJ = nomap
Call OUVRE_VLC(TIT,"","") From GESECRAN 
If GSERVEUR : BATCH = 1 : Else : BATCH = 0 : Endif
Gosub CNV
Call MULTI(OK) From AX3MONO
Call FERME_VLC From GESECRAN
Return

###############################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK)  
Value    Char    DOSSIER  
Value    Char    USER  
Variable Char    P1()(1..)  
Variable Char    P2()(1..)  
Variable Integer OK 
#Gosub OUVRE 
#Raz [M:DIA] 
#Local Char WIN (GLONFEN)
#WIN="DCNVEURO"
#Call PARAM(DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT  
###
End  

###############################################################################
Subprog MESSAGE(MESSA,FLG)
Value Char    MESSA
Value Integer FLG
Local Char    FICTRA(GDIMFIC)
If GTRACE<>""
 Case FLG
  When -2
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
   Call ECR_TRACE(MESSA-format$("D:"+GFMDAT,date$)-time$,FLG) From GESECRAN
  When -1
   Call ECR_TRACE(MESSA-format$("D:"+GFMDAT,date$)-time$,FLG) From GESECRAN
  When Default
   Call ECR_TRACE(MESSA,FLG) From GESECRAN
 Endcase
 Openo : # Pour forcer l'écriture dans la trace
 FICTRA = filpath("TRA",GTRACE,"tra",0)
 Openo FICTRA
Endif
If !GSERVEUR
 If FLG=-2
  Call AFF_VLC(MESSA,"") From GESECRAN
 Elsif FLG<0 
  Call AFF_VLC([M:VLC]TEX,MESSA) From GESECRAN
 Endif
Endif
End

###############################################################################
$CNV
Call PARAM("","CHGTYP",VALPAR) From ADOVAL
TYPCUR = val(VALPAR)
If TYPCUR=0 : TYPCUR = 1 : Endif
Read [ADS]DOSSIER = [L]DOSMAJ
If fstat : Return : Endif

GOK = 1
If [L]TOUSOC=2
 Filter [CPY2] Where CPYLEGFLG=2 & ACCCUR=[L]DEVCUR
 Read [CPY2]CPY0 First
 While fstat<=2  : # Pour contrer les 'snapshot too old'
  Gosub CNV_SOC
  If GOK<1 : Break : Endif 
  Read [CPY2]CPY0 Next
 Wend
Else
 Read [CPY2]CPY0 = [L]SOCIETE
 Gosub CNV_SOC
Endif
If GOK<1 : Return : Endif

Gosub CNV_DOS
If GOK<1 : Return : Endif
Call INIVAR From GLOBX3

If [L]TOUSOC=2
 Filter [CPY2] Where CPYLEGFLG=2 & ACCCUR=[L]DEVDES : # On vient de faire ACCCUR=[L]DEVDES
 Read [CPY2]CPY0 First
 While fstat<=2
  Gosub RECUP_SOC
  If GOK<1 : Break : Endif 
  Read [CPY2]CPY0 Next
 Wend
Else
 Read [CPY2]CPY0 = [L]SOCIETE
 Gosub RECUP_SOC
Endif
If GOK<1 : Return : Endif

Call MESSAGE(mess(81,115,1),-2) : # Fin de conversion
Return

###############################################################################
$CNV_SOC
Call MESSAGE(mess(74,115,1)-[F:CPY2]CPY,-2) : # Conversion société
If [F:ADS]MODULE(1)=2 : # Compta
 Gosub CNV_PIECE   : If GOK<1 : Return : Endif
 Gosub CNV_ECHE    : If GOK<1 : Return : Endif
 Gosub CNV_PCETMP  : If GOK<1 : Return : Endif
 Gosub CNV_LOT     : If GOK<1 : Return : Endif
 Gosub CNV_ENGAGE  : If GOK<1 : Return : Endif
 Gosub CNV_HONO    : If GOK<1 : Return : Endif
Endif
If [F:ADS]MODULE(3)=2 : # Immos
 Gosub CNV_IMMO    : If GOK<1 : Return : Endif
Endif
If [F:ADS]MODULE(8)=2 : # Tronc commun
 Gosub CNV_CUMCLI  : If GOK<1 : Return : Endif
 Gosub CNV_CUMFOU  : If GOK<1 : Return : Endif
 Gosub CNV_FACCLI  : If GOK<1 : Return : Endif
 Gosub CNV_FACFOU  : If GOK<1 : Return : Endif
 Gosub CNV_COST    : If GOK<1 : Return : Endif # sorti de la partie GP (02/10/01)
Endif
If [F:ADS]MODULE(2)=2 : # Tiers
 Gosub CNV_REGLE   : If GOK<1 : Return : Endif
 Gosub CNV_PROROG  : If GOK<1 : Return : Endif
Endif
If [F:ADS]MODULE(6)=2 : # Stock
 Gosub CNV_STOCK   : If GOK<1 : Return : Endif
Endif
If [F:ADS]MODULE(7)=2 : # GPAO
 Gosub CNV_GPAO    : If GOK<1 : Return : Endif
Endif
Gosub CNV_DIVSOC   : If GOK<1 : Return : Endif
Gosub MAJ_DEVSOC   : If GOK<1 : Return : Endif
If [F:ADS]MODULE(4)=2 : # Ventes
 Gosub CNV_DIVVEN  : If GOK<1 : Return : Endif
Endif
If [F:ADS]MODULE(5)=2 : # Achat
 Gosub CNV_DIVACH  : If GOK<1 : Return : Endif
Endif
Return

###############################################################################
$CNV_DOS
Call MESSAGE(mess(85,115,1),-2) : # Dossier

If [F:ADS]MODULE(1)=2 : # Compta
 Gosub CNV_TABLO   : If GOK<1 : Return : Endif
 Gosub CNV_ABON
 Gosub CNV_BUDGET  : If GOK<1 : Return : Endif
Endif
If [F:ADS]MODULE(2)=2 : # Tiers
 Gosub CNV_BANQUE  : If GOK<1 : Return : Endif
Endif
If [F:ADS]MODULE(6)=2 : # Stock lot                         (27/09/01)
 Gosub CNV_STOLOTFCY : If GOK<1 : Return : Endif
Endif
##If [F:ADS]MODULE(7)=2 : # GPAO  >> les FG sont en T.Commun (27/09/01) TB
 Gosub CNV_FRAIS   : If GOK<1 : Return : Endif
##Endif
Gosub CNV_DIVDOS   : If GOK<1 : Return : Endif
Gosub MAJ_DEVSYS   : If GOK<1 : Return : Endif
Gosub MAJ_DEVPAYS  : If GOK<1 : Return : Endif
Return

###############################################################################
$RECUP_SOC
Call MESSAGE(mess(65,115,1)-[F:CPY2]CPY,-2) : # Contrôles de conversion
If [F:ADS]MODULE(1)=2 : # Compta
 Gosub VERIF_ECH
 Gosub VERIF_LET
 Gosub RECUP_BAL
 Gosub RECUP_BLA
 If [F:ADS]MODULE(8)=2 : # Tronc commun
  Gosub RECUP_SOL
 Endif
Endif
Return

###############################################################################
$VERIF_ECH
Local Mask LETTRAGE  [LTR],  LETTRECH   [LTE], LETTCRIT   [LTC]
Local File GACCOUNT  [GAC],  GACCDUDATE [DUD], BALANCE    [BAL], MATCHCODE [MTC]
&        , GACCENTRY [HAE],  GACCENTRYD [DAE], GACCENTRYD [DAE3]
&        , GACCENTRY [HAE9], GACCENTRYD [DAE9] 
Link [DAE9] With [HAE9]HAE0=[DAE9]TYP;[DAE9]NUM      
& As [LDAE]       
& Where [HAE9]CPY=[F:CPY2]CPY   
&     & [DAE9]BPR<>""      
&     & ([HAE9]CAT=1 | [HAE9]CAT=4) 
&     & [HAE9]ANA<>2 
& Order By Key CLE=[DAE9]CPY;[DAE9]FCYLIN;[DAE9]ACC;[DAE9]BPR;[DAE9]ACCDAT;[DAE9]ACCNUM       
 
Local Decimal MT_ECHE 
       
Call MESSAGE(mess(109,116,1),-1) : # Vérification échéances

For [LDAE]CLE(4)
 For [LDAE]CLE  
  MT_ECHE = 0 
  For [DUD]DUD0 Where TYP=[F:DAE9]TYP & NUM=[F:DAE9]NUM & LIG=[F:DAE9]LIG 
   MT_ECHE += [F:DUD]AMTLOC
  Next 
  If MT_ECHE<>[F:DAE9]AMTLOC 
   Call MESSAGE([F:DAE9]CPY-[F:DAE9]TYP-[F:DAE9]NUM+" "+format$("K>:5X",[F:DAE9]LIG)-mess(24,119,1)  
&               -num$(MT_ECHE)-num$([F:DAE9]AMTLOC),1)
   #### Total des échéances incorrect
  Endif 
 Next
Next 

Close Local File [GAC],  [DUD], [BAL], [MTC], [HAE], [DAE], [DAE3], [HAE9], [DAE9]
Close Local Mask [LTR],  [LTE], [LTC]
Return

###############################################################################
$VERIF_LET
Local Mask LETTRAGE   [LTR],  LETTRECH   [LTE], LETTCRIT   [LTC]
Local File GACCOUNT   [GAC],  GACCDUDATE [DUD], BALANCE    [BAL],  MATCHCODE  [MTC]
&        , GACCENTRY  [HAE],  GACCENTRYD [DAE], GACCENTRYD [DAE3], GACCENTRYD [DAE0]

Local Decimal DEB_LET, CRE_LET 
Local Decimal SUMDEB, SUMCRE, NUMDEB, LIGDEB, NUMCRE, LIGCRE, ECHDEB, ECHCRE
 
Call MESSAGE(mess(110,116,1),-1) : # Vérification lettrage

For [DAE0]DAE1(4) Where CPY=[F:CPY2]CPY
 Read [GAC]GAC0=[F:DAE0]ACC
 If fstat=0 & [F:GAC]MTC=2

  Local File GACCENTRYD [DAE9]
  Filter [DAE9]
& Where CPY=[F:DAE0]CPY & FCYLIN=[F:DAE0]FCYLIN & ACC=[F:DAE0]ACC & BPR=[F:DAE0]BPR
&     & MTC>="A" & MTC<="ZZZZZ"
& Order By Key CLE=CPY;FCYLIN;ACC;BPR;MTC;ACCDAT;ACCNUM
  For [DAE9]CLE(5) 
   Raz DEB_LET,CRE_LET 
   For [DAE9]CLE
    If [F:DAE9]SNS=1
     DEB_LET += [F:DAE9]AMTLOC 
    Else 
     CRE_LET += [F:DAE9]AMTLOC
    Endif 
   Next 
   If DEB_LET<>CRE_LET
    Call MESSAGE([F:DAE9]CPY-[F:DAE9]FCYLIN-[F:DAE9]TYP-[F:DAE9]NUM+" "+format$("K>:5X",[F:DAE9]LIG)
&   -mess(119,116,1)-num$(DEB_LET)-num$(CRE_LET),1)
    # Erreur lettrage
   Endif 
  Next
  Close Local File [DAE9]
 
 Endif 
Next
     
Close Local File [GAC], [DUD], [BAL], [MTC], [HAE], [DAE], [DAE3], [DAE0]
Close Local Mask [LTR], [LTE], [LTC]
Return

###############################################################################
$RECUP_BAL
Local File FISCALYEAR [FIY2]
Call MESSAGE(mess(54,116,1),-1) : # Récupération balance
Filter [FIY2] Where CPY=[F:CPY2]CPY & FIYSTR<>[0/0/0] & FIYEND<>[0/0/0] & FIYSTA<>1
Read [FIY2]FIY0 First
While fstat<=2
 Call RECUPBAL([F:CPY2]CPY,2,"",[F:FIY2]FIYNUM,"",3,"",BATCH,1,ANOM) From RECUPBAL
 Read [FIY2]FIY0 Next
Wend
Close Local File [FIY2]
Return

###############################################################################
$RECUP_BLA
Local File FISCALYEAR [FIY2]
Call MESSAGE(mess(73,116,1),-1) : # Récupération balance analytique
Filter [FIY2] Where CPY=[F:CPY2]CPY & FIYSTR<>[0/0/0] & FIYEND<>[0/0/0] & FIYSTA<>1
Read [FIY2]FIY0 First
While fstat<=2
 Call RECUPBLA([F:CPY2]CPY,2,"",[F:FIY2]FIYNUM,"","",3,"",1,BATCH,1) From RECUPBLA
 Read [FIY2]FIY0 Next
Wend
Close Local File [FIY2]
Return

###############################################################################
$RECUP_SOL
Call MESSAGE(mess(112,116,1),-1) : # Récupération des soldes
Call RECUPSOL([F:CPY2]CPY,2,2,2,2,BATCH,1,1) From RECUPSOL
Return

###############################################################################
$CNV_PIECE
Local File GACCENTRY  [HAE] , GACCENTRY  [HAE2] 
&        , GACCENTRYD [DAE] , GACCENTRYA [DAA]
Local Char CLE1(20), CLE2(20)

Call MESSAGE(mess(10,115,1),-1) : # Conversion des pièces comptables

Raz CRITERE, CLE1, CLE2, FLG, K
Call DEBTRANS From GLOCK

$CNV_PIECE2
CRITERE = 'CPY = "'+[F:CPY2]CPY+'"'
If FLG=1
 CRITERE -= '& TYP = "'+CLE1+'" & NUM > "'+CLE2+'"'
 FLG = 2
Elsif FLG=2
 CRITERE -= '& TYP > "'+CLE1+'"'
 FLG = 0
Endif
For [HAE2] Where evalue(CRITERE)
 Gosub TR1
 K += 1
 If K>1000
  K = 0
  CLE1 = [F:HAE2]TYP
  CLE2 = [F:HAE2]NUM
  FLG = 1
  Break : # Pour contrer les 'snapshot too old'
 Endif
Next
If FLG : Goto CNV_PIECE2 : Endif

Close Local File [HAE], [HAE2], [DAE] , [DAA]
Return

$TR1
GOK = 1
Trbegin [HAE] , [DAE] , [DAA]
 Readlock [HAE]HAE0 = [F:HAE2]TYP ; [F:HAE2]NUM
 If fstat=1
  GOK=-1 : GLOCK="$GACCENTRY"-[F:HAE2]TYP-[F:HAE2]NUM : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("HAE",[F:HAE2]TYP-[F:HAE2]NUM) From GLOCK : Goto AB_TR1
 Endif
 WRAT = [F:HAE]RATCUR
 [F:HAE]RATCUR = [F:HAE]RATRPT
 If [L]PERMUT=2
  [F:HAE]RATRPT = WRAT
 Endif
 Rewrite [HAE]
 If fstat
  GOK=0 : Call FSTA("HAE") From GLOCK : Goto AB_TR1
 Endif

 For [DAE]DAE0 Where TYP=[F:HAE2]TYP & NUM=[F:HAE2]NUM
  WMONT  = [F:DAE]AMTLOC
  WMONT1 = [F:DAE]AMTLOC1
  [F:DAE]AMTLOC  = [F:DAE]AMTRPT
  [F:DAE]AMTLOC1 = [F:DAE]AMTRPT1
  If [L]PERMUT=2
   [F:DAE]AMTRPT  = WMONT
   [F:DAE]AMTRPT1 = WMONT1
  Endif
  Call CONVERT([F:HAE]CUR,DEVDES,DEVDES,[F:HAE]TYPRAT,[F:HAE]ACCDAT
&     ,[F:DAE]AMTVAT,[F:DAE]AMTVAT,SPSTAT) From TRTDEV
  If sum([F:DAE]AMTLOC,[F:DAE]AMTRPT,[F:DAE]AMTCUR)=0
   Delete [DAE]DAE0 Curr
   If fstat=1
    GOK=-1 : GLOCK = "$GACCENTRYD" : Break
   Elsif fstat>5
    GOK = 0 : Call RSTA("DAE","") From GLOCK : Break
   Endif
  Else
   Rewrite [DAE]
   If fstat=1
    GOK=-1 : GLOCK = "$GACCENTRYD" : Break
   Elsif fstat
    GOK=0 : Call FSTA("DAE") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 For [DAA]DAA0 Where TYP=[F:HAE2]TYP & NUM=[F:HAE2]NUM
  WMONT  = [F:DAA]AMTLOC
  [F:DAA]AMTLOC  = [F:DAA]AMTRPT
  If [L]PERMUT=2
   [F:DAA]AMTRPT  = WMONT
  Endif
  If sum([F:DAA]AMTLOC,[F:DAA]AMTRPT,[F:DAA]AMTCUR)=0
   Delete [DAA]DAA0 Curr
   If fstat=1
    GOK=-1 : GLOCK = "$GACCENTRYA" : Break
   Elsif fstat>5
    GOK = 0 : Call RSTA("DAA","") From GLOCK : Break
   Endif
  Else
   Rewrite [DAA]
   If fstat=1
    GOK=-1 : GLOCK = "$GACCENTRYA" : Break
   Elsif fstat
    GOK=0 : Call FSTA("DAA") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif


###############################################################################
$CNV_ECHE
Local File GACCDUDATE [DUD] , GACCDUDATE [DUD2]
If func AFNC.ACTIV("HDU") : Local File HISTODUD  [HDU]  : Endif

Local Decimal CLE1(20), CLE2(20)

Call MESSAGE(mess(102,115,1),-1) : # Conversion des échéances

Raz CRITERE, CLE1, CLE2, FLG, K
Call DEBTRANS From GLOCK

$CNV_ECHE2
CRITERE = 'CPY = "'+[F:CPY2]CPY+'"'
If FLG=1
 CRITERE -= '& ACCNUM = '+num$(CLE1)+' & DUDLIG > '+num$(CLE2)
 FLG = 2
Elsif FLG=2
 CRITERE -= '& ACCNUM > '+num$(CLE1)
 FLG = 0
Endif
For [DUD2]DUD1 Where evalue(CRITERE)
 Gosub TR1_DUD
 K += 1
 If K>1000
  K = 0
  CLE1 = [F:DUD2]ACCNUM
  CLE2 = [F:DUD2]DUDLIG
  FLG = 1
  Break : # Pour contrer les 'snapshot too old'
 Endif
Next
If FLG : Goto CNV_ECHE2 : Endif

Close Local File [DUD], [DUD2]
Return

$TR1_DUD
GOK = 1
Trbegin [DUD]
 Readlock [DUD]DUD1 = [F:DUD2]ACCNUM ; [F:DUD2]DUDLIG
 If fstat=1
  GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:DUD2]ACCNUM)-num$([F:DUD2]DUDLIG) : Goto ROLL_TR1_DUD
 Elsif fstat
  GOK=0 : Call RSTA("DUD",num$([F:DUD2]ACCNUM)-num$([F:DUD2]DUDLIG)) From GLOCK : Goto AB_TR1_DUD
 Endif
 WMONT  = [F:DUD]AMTLOC
 WMONT1 = [F:DUD]PAYLOC
 WMONT2 = [F:DUD]TMPLOC
 [F:DUD]AMTLOC  = [F:DUD]AMTRPT
 [F:DUD]PAYLOC  = [F:DUD]PAYRPT
 [F:DUD]TMPLOC  = [F:DUD]TMPRPT
 If [L]PERMUT=2
  [F:DUD]AMTRPT  = WMONT
  [F:DUD]PAYRPT  = WMONT1
  [F:DUD]TMPRPT  = WMONT2
 Endif
 If sum([F:DUD]AMTLOC,[F:DUD]AMTRPT,[F:DUD]AMTCUR)=0
& & sum([F:DUD]PAYLOC,[F:DUD]PAYRPT,[F:DUD]PAYCUR)=0
& & sum([F:DUD]TMPLOC,[F:DUD]TMPRPT,[F:DUD]TMPCUR)=0
  Call HISTOECH("DUD",2,date$)From MODECHE
  Delete [DUD]DUD1 Curr
  If fstat=1
   GOK=-1 : GLOCK = "$GACCDUDATE" : Goto ROLL_TR1_DUD
  Elsif fstat>5
   GOK = 0 : Call RSTA("DUD","") From GLOCK : Goto AB_TR1_DUD
  Endif
 Else 
  Call SLDECH("DUD")From MODECHE
  Rewrite [DUD]
  If fstat=1
   GOK=-1 : GLOCK = "$GACCDUDATE" : Goto ROLL_TR1_DUD
  Elsif fstat
   GOK=0 : Call FSTA("DUD") From GLOCK : Goto AB_TR1_DUD
  Endif
 Endif
Commit
## Historisation des échéances
If func AFNC.ACTIV("HDU") 
 Trbegin [HDU]
  For [HDU] Where ACCNUM=[F:DUD2]ACCNUM & DUDLIG=[F:DUD2]DUDLIG
   WMONT  = [F:HDU]AMTLOC
   WMONT1 = [F:HDU]PAYLOC
   WMONT2 = [F:HDU]TMPLOC
   [F:HDU]AMTLOC  = [F:HDU]AMTRPT
   [F:HDU]PAYLOC  = [F:HDU]PAYRPT
   [F:HDU]TMPLOC  = [F:HDU]TMPRPT
   If [L]PERMUT=2
    [F:HDU]AMTRPT  = WMONT
    [F:HDU]PAYRPT  = WMONT1
    [F:HDU]TMPRPT  = WMONT2
   Endif
   Rewrite [HDU]
   If fstat :GOK=0 : Endif
  Next
  If !GOK
   Call FSTA("HDU") From GLOCK : Goto AB_TR1_DUD
  Endif
 Commit
Endif
Return

$AB_TR1_DUD
Rollback
Return

$ROLL_TR1_DUD
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1_DUD : Endif

###############################################################################
$CNV_PCETMP
Local File GACCTMP  [HAT] , GACCTMP  [HAT2] 
&        , GACCTMPD [DAT] , GACCTMPA [AAT]

Call MESSAGE(mess(73,115,1),-1) : # Conversion des pièces temporaires

For [HAT2] Where CPY=[F:CPY2]CPY
 Call DEBTRANS From GLOCK
 Gosub TR01
 If GOK<1 : Break : Endif
Next
Close Local File [HAT], [HAT2], [DAT] , [AAT]
Return

$TR01
GOK = 1
Trbegin [HAT] , [DAT] , [AAT]
 Readlock [HAT]HAT0 = [F:HAT2]TYP ; [F:HAT2]NUM
 If fstat=1
  GOK=-1 : GLOCK="$GACCTMP"-[F:HAT2]TYP-[F:HAT2]NUM : Goto ROLL_TR01
 Elsif fstat
  GOK=0 : Call RSTA("HAT",[F:HAT2]TYP-[F:HAT2]NUM) From GLOCK : Goto AB_TR01
 Endif
 WRAT = [F:HAT]RATCUR
 [F:HAT]RATCUR = [F:HAT]RATRPT
 If [L]PERMUT=2
  [F:HAT]RATRPT = WRAT
 Endif
 Rewrite [HAT]
 If fstat
  GOK=0 : Call FSTA("HAT") From GLOCK : Goto AB_TR01
 Endif

 For [DAT]DAT0 Where TYP=[F:HAT2]TYP & NUM=[F:HAT2]NUM
  WMONT  = [F:DAT]AMTLOC
  WMONT1 = [F:DAT]AMTLOC1
  [F:DAT]AMTLOC  = [F:DAT]AMTRPT
  [F:DAT]AMTLOC1 = [F:DAT]AMTRPT1
  If [L]PERMUT=2
   [F:DAT]AMTRPT  = WMONT
   [F:DAT]AMTRPT1 = WMONT1
  Endif
  Call CONVERT([F:HAT]CUR,DEVDES,DEVDES,[F:HAT]TYPRAT,[F:HAT]ACCDAT,[F:DAT]AMTVAT,[F:DAT]AMTVAT,SPSTAT)
& From TRTDEV
  If sum([F:DAT]AMTLOC,[F:DAT]AMTRPT,[F:DAT]AMTCUR)=0
   Delete [DAT]DAT0 Curr
   If fstat=1
    GOK=-1 : GLOCK = "$GACCTMPD" : Break
   Elsif fstat>5
    GOK = 0 : Call RSTA("DAT","") From GLOCK : Break
   Endif
  Else
   Rewrite [DAT]
   If fstat=1
    GOK=-1 : GLOCK = "$GACCTMPD" : Break
   Elsif fstat
    GOK=0 : Call FSTA("DAT") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR01
 Elsif !GOK : Goto AB_TR01
 Endif

 For [AAT]AAT0 Where TYP=[F:HAT2]TYP & NUM=[F:HAT2]NUM
  WMONT  = [F:AAT]AMTLOC
  [F:AAT]AMTLOC  = [F:AAT]AMTRPT
  If [L]PERMUT=2
   [F:AAT]AMTRPT  = WMONT
  Endif
  If sum([F:AAT]AMTLOC,[F:AAT]AMTRPT,[F:AAT]AMTCUR)=0
   Delete [AAT]AAT0 Curr
   If fstat=1
    GOK=-1 : GLOCK = "$GACCTMPA" : Break
   Elsif fstat>5
    GOK = 0 : Call RSTA("AAT","") From GLOCK : Break
   Endif
  Else
   Rewrite [AAT]
   If fstat=1
    GOK=-1 : GLOCK = "$GACCTMPA" : Break
   Elsif fstat
    GOK=0 : Call FSTA("AAT") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR01
 Elsif !GOK : Goto AB_TR01
 Endif

Commit
Return

$AB_TR01
Rollback
Return

$ROLL_TR01
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR01 : Endif

###############################################################################
$CNV_LOT
Local File GENTLOT [LOT], GENTLOT [LOT2], GENTLOTH [LOH]

Call MESSAGE(mess(11,115,1),-1) : # Conversion des lots

Filter [LOT2] Where CPY=[F:CPY2]CPY
For [LOT2]LOT0
 Call DEBTRANS From GLOCK
 Gosub TR2
 If GOK<1 : Break : Endif
Next
Close Local File [LOT], [LOT2], [LOH]
Return

$TR2
GOK = 1
Trbegin [LOH]
 For [LOH]LOH0 Where LOT=[F:LOT2]LOT
  WRAT = [F:LOH]RATCUR
  [F:LOH]RATCUR = [F:LOH]RATRPT
  If [L]PERMUT=2
   [F:LOH]RATRPT = WRAT
  Endif
  Rewrite [LOH]
  If fstat=1
   GOK=-1 : GLOCK = "$GENTLOTH" : Break
  Elsif fstat
   GOK=0 : Call FSTA("LOH") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

###############################################################################
$CNV_ENGAGE
Local File GCOMMIT [CMM], GCOMMIT [CMM2], GCOMMITD [CMD]

Call MESSAGE(mess(68,116,1),-1) : # Engagements

Filter [CMM2] Where CPY=[F:CPY2]CPY Order By Key CLE=CPY
For [CMM2]
 Call DEBTRANS From GLOCK
 Gosub TR3
 If GOK<1 : Break : Endif
Next
Close Local File [CMM], [CMM2], [CMD]
Return

$TR3
GOK = 1
Trbegin [CMM] , [CMD]
 Readlock [CMM]CMM0 = [F:CMM2]NUM
 If fstat=1
  GOK=-1 : GLOCK="$GCOMMIT"-[F:CMM2]NUM : Goto ROLL_TR3
 Elsif fstat
  GOK=0 : Call RSTA("CMM",[F:CMM2]NUM) From GLOCK : Goto AB_TR3
 Endif
 WRAT  = [F:CMM]RATCUR
 [F:CMM]RATCUR = [F:CMM]RATRPT
 If [L]PERMUT=2
  [F:CMM]RATRPT = WRAT
 Endif
 Rewrite [CMM]
 If fstat
  GOK=0 : Call FSTA("CMM") From GLOCK : Goto AB_TR3
 Endif

 For [CMD]CMD0 Where NUM=[F:CMM2]NUM
  WMONT = [F:CMD]AMTLOC
  [F:CMD]AMTLOC = [F:CMD]AMTRPT
  If [L]PERMUT=2
   [F:CMD]AMTRPT = WMONT
  Endif
  Rewrite [CMD]
  If fstat=1
   GOK=-1 : GLOCK = "$GCOMMITD" : Break
  Elsif fstat
   GOK=0 : Call FSTA("CMD") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR3
 Elsif !GOK : Goto AB_TR3
 Endif
Commit
Return

$AB_TR3
Rollback
Return

$ROLL_TR3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR3 : Endif

###############################################################################
$CNV_IMMO
Local File FIXASSET [FAS2], FIXASSET [FAS]
&        , FIXDEP   [FDP],  FIXWRO   [FWR], FIXWRO [FWR2]

Call MESSAGE(mess(68,115,1),-1) : # Conversion des immos

Filter [FAS2] Where CPY=[F:CPY2]CPY Order By Key CLE=CPY
For [FAS2]
 Call CNVFAS([F:FAS2]FASCOD,[F:FAS2]FASNUM,DATPAS,DEVCUR,DEVDES,TYPCUR) From CNVFAS
 If GOK<1 : Break : Endif
Next
Close Local File [FAS2], [FAS], [FDP], [FWR], [FWR2]
Return

###############################################################################
$CNV_CUMCLI
Local File BPCUSTMVT [MVC], BPCUSTMVT [MVC2]

Call MESSAGE(mess(76,115,1),-1) : # Cumuls clients

Filter [MVC2] Order By Key CLE=FINRSPFCY
For [MVC2]
 ISITE = find([F:MVC2]FINRSPFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR6
  If GOK<1 : Break : Endif
#  Call ECR_TRACE([F:MVC2]BPCNUM-[F:MVC2]FINRSPFCY,0) From GESECRAN
 Endif
Next
Close Local File [MVC], [MVC2]
Return

$TR6
GOK = 1
Trbegin [MVC]
 For [MVC]MVC0 Where BPCNUM=[F:MVC2]BPCNUM & FINRSPFCY=[F:MVC2]FINRSPFCY
  If [F:MVC]ACCCUR=DEVCUR
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]BLCC      ,[F:MVC]BLCC      ,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]DLVOSTC   ,[F:MVC]DLVOSTC   ,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]LNDBPCATIC,[F:MVC]LNDBPCATIC,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]LNDBPCNOTC,[F:MVC]LNDBPCNOTC,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]LNDBPIATIC,[F:MVC]LNDBPIATIC,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]LNDBPINOTC,[F:MVC]LNDBPINOTC,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]LNDDLVC   ,[F:MVC]LNDDLVC   ,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]NIVDLVC   ,[F:MVC]NIVDLVC   ,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]NPTINVC   ,[F:MVC]NPTINVC   ,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]NYTBILC   ,[F:MVC]NYTBILC   ,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]ORDBPCATIC,[F:MVC]ORDBPCATIC,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]ORDBPCNOTC,[F:MVC]ORDBPCNOTC,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]ORDBPIATIC,[F:MVC]ORDBPIATIC,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]ORDBPINOTC,[F:MVC]ORDBPINOTC,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]QUONOTC,   [F:MVC]QUONOTC   ,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]QUOATIC,   [F:MVC]QUOATIC   ,SPSTAT)  From TRTDEV
#   Call CONVERT_TAB([F:MVC]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVC]LASDOCAMT,[F:MVC]LASDOCAMT,SPSTAT)  From TRTDEV
   [F:MVC]ACCCUR = DEVDES
   Rewrite [MVC]
   If fstat=1
    GOK=-1 : GLOCK = "$BPCUSTMVT" : Break
   Elsif fstat
    GOK=0 : Call FSTA("MVC") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR6
 Elsif !GOK : Goto AB_TR6
 Endif
Commit
Return

$AB_TR6
Rollback
Return

$ROLL_TR6
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR6 : Endif

###############################################################################
$CNV_CUMFOU
Local File BPSUPPMVT [MVS], BPSUPPMVT [MVS2]

Call MESSAGE(mess(77,115,1),-1) : # Cumuls fournisseurs

Filter [MVS2] Order By Key CLE=FINRSPFCY
For [MVS2]
 ISITE = find([F:MVS2]FINRSPFCY,GSITE(1..GNBSITE))
 If ISITE & GSOCSITE(ISITE)=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TR7
  If GOK<1 : Break : Endif
#  Call ECR_TRACE([F:MVS2]BPSNUM-[F:MVS2]FINRSPFCY,0) From GESECRAN
 Endif
Next
Close Local File [MVS], [MVS2]
Return

$TR7
GOK = 1
Trbegin [MVS]
 For [MVS]MVS0 Where BPSNUM=[F:MVS2]BPSNUM & FINRSPFCY=[F:MVS2]FINRSPFCY
  If [F:MVS]ACCCUR=DEVCUR
   Call CONVERT_TAB([F:MVS]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVS]ORDAMT,[F:MVS]ORDAMT,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVS]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVS]RCPAMT,[F:MVS]RCPAMT,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVS]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVS]BILAMT,[F:MVS]BILAMT,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVS]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVS]BLCAMT,[F:MVS]BLCAMT,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVS]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVS]INVAMT,[F:MVS]INVAMT,SPSTAT)  From TRTDEV
   Call CONVERT_TAB([F:MVS]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVS]LASINVAMT,[F:MVS]LASINVAMT,SPSTAT) From TRTDEV
   Call CONVERT_TAB([F:MVS]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVS]LASPAYAMT,[F:MVS]LASPAYAMT,SPSTAT) From TRTDEV
   Call CONVERT_TAB([F:MVS]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVS]LASPOHAMT,[F:MVS]LASPOHAMT,SPSTAT) From TRTDEV
   Call CONVERT_TAB([F:MVS]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVS]LASPQHAMT,[F:MVS]LASPQHAMT,SPSTAT) From TRTDEV
   Call CONVERT_TAB([F:MVS]ACCCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:MVS]LASPTHAMT,[F:MVS]LASPTHAMT,SPSTAT) From TRTDEV
   [F:MVS]ACCCUR = DEVDES
   Rewrite [MVS]
   If fstat=1
    GOK=-1 : GLOCK = "$BPSUPPMVT" : Break
   Elsif fstat
    GOK=0 : Call FSTA("MVS") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR7
 Elsif !GOK : Goto AB_TR7
 Endif
Commit
Return

$AB_TR7
Rollback
Return

$ROLL_TR7
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR7 : Endif

###############################################################################
$CNV_HONO
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
Read [ACV]CODACT = "DAS"
If fstat | [F:ACV]FLACT<>2
 Close Local File [ACV]
 Return
Endif

Raz ERR
Onerrgo NERR
Local File HONLIN [HLN], HONLIN [HLN2], TDSPRV [TPR], TDSPRV [TPR2]
Onerrgo ERR
If ERR : Return : Endif

Call MESSAGE(mess(4,696,1),-1) : # Lignes honoraires

Filter [HLN2] Order By Key CLE=CPY
For [HLN2]
 If [F:HLN2]CPY=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TRH1
  If GOK<1 : Break : Endif
 Endif
Next
If GOK<1 Return Endif

Filter [TPR2] Order By Key CLE=CPY
For [TPR2]
 If [F:TPR2]CPY=[F:CPY2]CPY
  Call DEBTRANS From GLOCK
  Gosub TRH2
  If GOK<1 : Break : Endif
 Endif
Next

Close Local File [HLN], [TPR], [HLN2], [TPR2], [ACV]
Return

$TRH1
GOK = 1
Trbegin [HLN]
 Readlock [HLN]HLN0 = [F:HLN2]FCY ; [F:HLN2]PRVNUM ; [F:HLN2]DAT ; [F:HLN2]HON ; [F:HLN2]LINNUM
 If fstat=1
  GOK=-1
  GLOCK="$HONLIN"-[F:HLN2]FCY-[F:HLN2]PRVNUM-format$(GFMD,[F:HLN2]DAT)-num$([F:HLN2]HON)-num$([F:HLN2]LINNUM)
  Goto ROLL_TRH1
 Elsif fstat
  GOK=0
  Call RSTA("HLN",[F:HLN2]FCY-[F:HLN2]PRVNUM-format$(GFMD,[F:HLN2]DAT)-num$([F:HLN2]HON)-num$([F:HLN2]LINNUM))
& From GLOCK
  Goto AB_TRH1
 Endif
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCUR,[F:HLN]DAT,[F:HLN]AMTLOC,[F:HLN]AMTLOC,SPSTAT) From TRTDEV
 Rewrite [HLN]
 If fstat
  GOK=0 : Call FSTA("HLN") From GLOCK : Goto AB_TRH1
 Endif
Commit
Return

$AB_TRH1
Rollback
Return

$ROLL_TRH1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRH1 : Endif

$TRH2
GOK = 1
Trbegin [TPR]
 Readlock [TPR]TPR0 = [F:TPR2]PRVNUM ; [F:TPR2]CPY
 If fstat=1
  GOK=-1 : GLOCK="$TDSPRV"-[F:TPR2]PRVNUM-[F:TPR2]CPY : Goto ROLL_TRH2
 Elsif fstat
  GOK=0 : Call RSTA("TPR",[F:TPR2]PRVNUM-[F:TPR2]CPY) From GLOCK : Goto AB_TRH2
 Endif
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:TPR]AMTLOC,[F:TPR]AMTLOC,SPSTAT) From TRTDEV
 Rewrite [TPR]
 If fstat
  GOK=0 : Call FSTA("TPR") From GLOCK : Goto AB_TRH2
 Endif
Commit
Return

$AB_TRH2
Rollback
Return

$ROLL_TRH2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRH2 : Endif

$ERR
ERR = errn
Call ECR_TRACE("err="+num$(ERR)-errp+"("+num$(errl)+")"-errm,1) From GESECRAN
Resume

$NERR
ERR = errn
Resume

###############################################################################
$CNV_FACCLI
Local File SINVOICE [SIH], SINVOICE [SIH2], SINVOICEV [SIV]

Call MESSAGE(mess(6,41,1),-1) : # Factures clients

Filter [SIH2] Where CPY=[F:CPY2]CPY Order By Key CLE=CPY
For [SIH2]
 Call DEBTRANS From GLOCK
 Gosub TR9
 If GOK<1 : Break : Endif
Next
Close Local File [SIH], [SIH2], [SIV]
Return

$TR9
GOK = 1
Trbegin [SIH]
 Readlock [SIH]SIH0 = [F:SIH2]NUM
 If fstat=1
  GOK=-1 : GLOCK="$SINVOICE"-[F:SIH2]NUM : Goto ROLL_TR9
 Elsif fstat
  GOK=0 : Call RSTA("SIH",[F:SIH2]NUM) From GLOCK : Goto AB_TR9
 Endif
 WRAT = [F:SIH]RATCUR
 If [F:SIH]RATRPT=0 & WRAT<>0 : # mb 9.5.1 Cours devise reporting société jamais renseigné
  Read [SIV]SIV0 = [F:SIH]NUM
  If !fstat
   Call CONVERT(DEVCUR,DEVDES,DEVDES,[F:SIH]CURTYP,[F:SIV]INVDAT,1000000*WRAT,[F:SIH]RATRPT,SPSTAT) From TRTDEV
  Else
   Call CONVERT(DEVCUR,DEVDES,DEVDES,[F:SIH]CURTYP,[F:SIH]ACCDAT,1000000*WRAT,[F:SIH]RATRPT,SPSTAT) From TRTDEV
  Endif
  [F:SIH]RATRPT = arr([F:SIH]RATRPT/1000000,0.000001)
 Endif
 [F:SIH]RATCUR = [F:SIH]RATRPT
 If [L]PERMUT=2
  [F:SIH]RATRPT = WRAT
 Endif
 Rewrite [SIH]
 If fstat
  GOK=0 : Call FSTA("SIH") From GLOCK : Goto AB_TR9
 Endif
Commit
Return

$AB_TR9
Rollback
Return

$ROLL_TR9
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR9 : Endif

###############################################################################
