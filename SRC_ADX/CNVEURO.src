 Elsif fstat
  GOK=0 : Call RSTA("UOH",[F:UOH2]POHNUM-num$([F:UOH2]REVNUM)) From GLOCK : Goto AB_TRA6
 Endif
 Call COURSITE([F:UOH]CUR,[F:UOH]POHFCY,[F:UOH]CHGTYP,[F:UOH]ORDDAT,[F:UOH]CHGCOE,SPSTAT) From TRTDEV
