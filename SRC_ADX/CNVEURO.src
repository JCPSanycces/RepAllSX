$CNV_DIVSOC
Call MESSAGE(mess(75,115,1),-1) : # Conversion autres zones société

If [F:ADS]MODULE(5)=2 : # Achats
 WCHP(1) = "CPR" : WARR(1) = GDECPRI
 Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"PINVOICED" ,WCHP,1,""   ,"FCYLIN","","CPRCUR",DATPAS,"",WARR) From CNVDIV
 WCHP(1) = "CPR"    : WARR(1) = GDECPRI
 Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"PRECEIPTD" ,WCHP,1,""   ,"PRHFCY","","CPRCUR",DATPAS,"",WARR) From CNVDIV
 WCHP(1) = "TOTPRQ" : WARR(1) = 0
 Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"PREQUIS"   ,WCHP,1,""   ,"PSHFCY","",""      ,DATPAS,"",WARR) From CNVDIV
 WCHP(1) = "CPR"    : WARR(1) = GDECPRI
 Call CNVDIV2([F:CPY2]CPY,DEVCUR,DEVDES,"PRETURND"  ,WCHP,1,""   ,"PNHFCY","","CPRCUR",DATPAS,"",WARR) From CNVDIV
Endif
Return

