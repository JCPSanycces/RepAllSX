#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
Case ACTION
    When "IMP_COMPILE" :   Gosub COMPILE
    When "IMP_DEFTRT"  :   Gosub DEFTRT
    When "IMP_OUVRE"   :   Gosub OUVRE
    When "EXPORT"      :   Gosub EXPORT
    When "IMPORT"      :   Gosub IMPORT
    When "AP_IMPORT"   :   Gosub AP_IMPORT
Endcase
Return

$COMPILE
GFONBOD = "BOMC"
Return

$DEFTRT
If [L]TRTMSK="W0BOD1"
    [L]TRTMSK="W0BOD2"
Endif
Return

$OUVRE
Local Integer  OKCHAMP, SUPBOD
If clalev ([F:TBO]) <= 0  : Local File TABBOMALT [TBO] : Endif
# interchanger les écrans car l'import se base sur l'objet et non sur la fonction

#Close Local Mask [BOD1]  # ferme aussi la boîte !!?? voir bug 9070 !
If clalev([M:BOD1])>0 : Close Mask [BOD1] : Endif # bug 65549
Local Mask BOD2 [BOD1]   # bug 11230  23/10/01
Return

$EXPORT
If [F:BOH]BOMALTTYP <> 1 : OK = 0 : Endif
Return

#---------------------------------------------------------------------
$AP_IMPORT
If IMPFIC="BOH"
   ## GH 13/10/2011 bug 76972
   Call TST_CHAMP(IMPFIC,"BOMALTTYP",OKCHAMP) From SUBIMPOBJ
   If !OKCHAMP : [F:BOH]BOMALTTYP=1 : Endif

   ## GH 25/10/2012 bug 79196
   If [F:BOH]BOMALTTYP<>0
      If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
      Trbegin [AXX]
         Read [AXX]AXX0 = "BOM";"BOMDESAXX";"imp";[F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT);'0'
         If !fstat
            [F:AXX]IDENT2=num$([F:BOH]BOMALTTYP)
            Rewrite [AXX]
         Endif
      Commit
   Endif
Endif
Return

$IMPORT
Case IMPFIC
    When "BOH": 
# ---------------------------------------------------#
#     Entête de nomenclature                         #
# ---------------------------------------------------#
        # If [F:BOH]BOMALTTYP=0 :[F:BOH]BOMALTTYP=1 : Endif : ## GH 13/10/2011 bug 76972
        If [F:TBO]BOMALT <> [F:BOH]BOMALT | [F:TBO]BOMALTTYP <> [F:BOH]BOMALTTYP
            Read [TBO]TBO0=[F:BOH]BOMALTTYP;[F:BOH]BOMALT
            If fstat : Raz [F:TBO] : Endif
        Endif
        If [F:TBO]BOMALTTYP <> 1     
            Call ECR_TRACE(mess(225,199,1),1) From GESECRAN
            OK = 0 
        Endif

    When "BOD": 
# ---------------------------------------------------#
#     Lien de nomenclature                           #
# ---------------------------------------------------#
       Gosub IMP_DECLARE From TRTX3IMP
# Il faut déterminer s'il s'agit d'une nouvelle ligne ou pas
       SUPBOD = ([F:BOD]BOMSEQ<0)
       If SUPBOD : [F:BOD]BOMSEQ*=-1 : Endif
        ICLEPRIM (0) = "BOMSEQ" : ICLESEC (0) = "CPNITMREF"
        NBASTAB = "NBLIG"
        Gosub RECHERCHE_LIGNE From TRTX3IMP   
#      #-----------------------------------------------#
#      # Cas de la suppression de ligne (Séquence < 0) #
#      #-----------------------------------------------#
       If    SUPBOD & nolign=0
         Call ECR_TRACE([F:BOD]CPNITMREF-num$(-[F:BOD]BOMSEQ)-":"-mess(77,9005,1),1) From GESECRAN
         OK = 0
       Elsif SUPBOD & nolign<>0
         status=65
         ### Call C_NBLIG     From SUBBOD : If mkstat Return : Endif
         Call AVANT_NBLIG From SUBBOD
         Call APRES_NBLIG From SUBBOD
       Endif
Endcase

Return





