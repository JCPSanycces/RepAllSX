Subprog GEN_LIBCLI1(LANG,DOSR)
Value Char    LANG
Value Char    DOSR

Local Char    REP(200),LANLIB(50)
Local Char    WPREF_FILE (12), DIRSEP
Local Integer WCHAP
Local Char    FNOMFIC (255)
Local Char    WTEXTE (255)

Local Char    WVERSION : WVERSION = 'Version="V1.0"'


Local File =GDOSX3+".APLSTD" [ZZA] :# On lit les XXX  toujours sur le dossier mère  CC 06/02/2009
Local File =DOSR+".APLSTD" [ZZB]
Local File =DOSR+".ATEXTRA" [AXX1]      

Read [AXX1]AXX0 = "TABLAN";"INTDES";LANG;LANG;""
If fstat=0
  LANLIB=[F:AXX1]TEXTE
Else
  LANLIB=LANG
Endif

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

REP= "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"LIB"

# Dll tools
WPREF_FILE = "Tools_"
WCHAP=9911
Gosub LAN_OPT

# Dll Impression
WPREF_FILE = "Imp_CR_"
WCHAP=9910
Gosub LAN_OPT

# Dll Impression
WPREF_FILE = "Trad_"
WCHAP=9912
Gosub LAN_OPT

# Dll OutLook
WPREF_FILE = "AddIn_Ol_"
WCHAP=9913
Gosub LAN_OPT

Close Local File

End


#-------------------------------------------------------------------------------------------
$LAN_OPT

#--------------------------------------------------------------------------#
# creation fichier WPREF_FILE+"Lang".xml sous X3_PUB/X3_ROOT/GEN/"Lang"/LIB
#--------------------------------------------------------------------------#

FNOMFIC =filpath(REP,WPREF_FILE+LANG,"xml","X3_PUB")

Openo FNOMFIC,0 Using [I_LO]
Iomode adxifs '' Using [I_LO]
Iomode adxirs chr$(10) Using [I_LO]
Iomode adxium GUTF8 Using [I_LO]

WTEXTE ='<?xml version="1.0" encoding="utf-8" standalone="yes" ?>'
Wrseq WTEXTE Using [I_LO]
WTEXTE = '    <Messages language="'+LANLIB+'" Menu="'+num$(WCHAP)+'"'-WVERSION-'Extract="'+date$+'">'
Wrseq WTEXTE Using [I_LO]

Filter [ZZA] Where LANCHP = WCHAP and LAN = "XXX" and LANNUM <> 0
For [ZZA]
  Raz WTEXTE
  Read [ZZB]CLE = [F:ZZA]LANCHP;[F:ZZA]LANNUM;LANG
  If (fstat = 0 & vireblc([F:ZZB]LANMES,2) <> "")
    WTEXTE = '     <data id="'+[F:ZZA]LANMES+'" AdxLine="'+ num$([F:ZZA]LANNUM) +'">'+[F:ZZB]LANMES+'</data>'
    Wrseq WTEXTE Using [I_LO] 
  Endif
Next
WTEXTE = "</Messages>"
Wrseq WTEXTE Using [I_LO]

Filter [ZZA]

Openo Using [I_LO] 

Return



