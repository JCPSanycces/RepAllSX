Local Integer WRANG1, WRANG2, WNUM
Local Integer WNBRE
Local Integer WLANCHP
Local Char WLAN(3)

Local Char WCHAR(1)
Local Char WLIBLAN (250)


#---------------------------------------------#
# creation fichier start.txt sous x3_pub #
#---------------------------------------------#
FNOMFIC =filpath(REP,WPREF_FILE,"txt","X3_PUB")
FNOMMODEL =filpath(REP_MOD,WPREF_FILE_MOD,"txt","X3_PUB")



Openo FNOMFIC,0 Using [O_FC]
Iomode adxifs '' Using [O_FC]
