#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"ALANG","VALLANG","") From GSAISIE
End
     

#   VALLANG           Création des répertoires de ressources pour une solution
#                     ou globalement pour l'industrialisation                     
#                     
#
#  CRELIBALL   :  Génération globale (répertoires, client, moteur) pour toutes les langues de la solution
#  CRELIBINDUS :  Idem mais pour une liste de langue et de dossiers de référence passée en paramètre
#                 On peut être ainsi amenés à créer des répertoires "langues" non utilisés par la solution
#                 sous X3_PUB/X3_ROOT/GEN/...
#
#  GENLIBWEB   :  Crée la liste des langues de la solution avec les libellés dans toutes les langues
#                 Crée les fichiers de libellés de connexion du serveur Web
#  GENLIBMOT   :  Génération libellés du moteur
#                 Crée les répertoires X3_PUB si nécessaire
#  GENLIBCLI   :  Génération libellés du client et du client Web (éditeur de formule)
#                 Crée les répertoires X3_PUB si nécessaire
#  GEN_ILOG    :  Génération libellés pour composants ILOG balances et planning
#                 Crée les répertoires X3_PUB si nécessaire
#  GEN_LIBCLI1 :  Génération libellés pour serveur edition et addin outlook
#                 Crée les répertoires X3_PUB si nécessaire
#  GEN_LIBFLASH:  Génération libellés pour les composants flash
#                 Crée les répertoires X3_PUB si nécessaire
#  GEN_LIBPORTAL:  Génération libellés pour le portailhr
#                 Crée les répertoires X3_PUB si nécessaire
#
#  COPYLOC     :  Copie sur un répertoire client et renomme tous les fichiers du client
#                 produits sur le serveur selon les normes définies
#
#  LIBCLIJSON  :  Génération des libellés en json pour le client

$ACTION
Case ACTION
 When "DEBUT"      : Gosub DEBUT
 When "OK"         : Gosub BOUTOK
 When "BOUTON"     : Gosub BOUTON
Endcase
Return

$DEBUT
Local Char TDOS(GLONADS)(1..50)
Local Char TLAN(GLONLAN)(1..50)
Local Integer NBLAN,I
Call GLOBLANGREF(TDOS,TLAN,NBLAN) From INTRUTILA
For I=1 To NBLAN
  [M]LAN(I-1)=TLAN(I)
  [M]DOSREF(I-1)=TDOS(I)
  [M]AGEN(I-1)=2
  Call LECTEXTRA([M]INTLAN(I-1),"TABLAN","INTDES",TLAN(I),"") From ATEXTRA
Next I
[M]NBLIG=NBLAN
Affzo [M]
Return


$BOUTON
  If BOUT="A"
    Gosub CRETLAN
    Local Integer OKT
#  Voulez vous regénérer les libellés avant le transfert
    Call OUINON(mess(232,133,1),OKT) From GESECRAN
    If OKT=2
      Call CRELIBINDUS(TDOS,TLAN,NBLAN)
    Endif
    Call COPYLOC(TLAN,NBLAN)
  Endif
Return

$BOUTOK
  Local Integer OKT
  Call OUINON(mess(179,133,1),OKT) From GESECRAN
  If OKT=2
    Gosub CRETLAN
    Call CRELIBINDUS(TDOS,TLAN,NBLAN)
  Endif
Return

$CRETLAN
    Local Char TDOS(10)(1..50)
    Local Char TLAN(10)(1..50)
    Local Integer NBLAN,I
    For I=1 To [M]NBLIG
      If [M]AGEN(I-1)=2
        NBLAN+=1
        TLAN(NBLAN)=[M]LAN(I-1)
        TDOS(NBLAN)=[M]DOSREF(I-1)
      Endif
    Next I
Return


# ----------------------------------------------------------------------------

Subprog CRELIBINDUS(TDOS,TLAN,NBLAN)

#        ---- Crée les répertoires X3_PUB pour les langues fournies en paramètres
#             Elles doivent exister dans TABLAN et être différentes de ALL

Value Char TDOS()(1..)
Value Char TLAN()(1..)
Value Integer NBLAN

# Crée les répertoires qui peuvent manquer sur X3_ROOT
Local Integer RETCREREP,I
Gosub CREX3RLIBRE From INTRUTILC
Kill RETCREREP

# Crée les fichiers connectx3langs par dossier
Local File ADOSSIER [ADS]
For [ADS]
  If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
    Call CRELIBWEBD([F:ADS]DOSSIER) From INTRUTILC
  Endif
Next

Call GENLIBWEB

Gosub ENGREF

For I=1 To NBLAN
  If TLAN(I)<>"ALL"
    Call GENLIBCLI(TLAN(I),TDOS(I),ENGREF) 
    Call GENLIBMOT(TLAN(I),TDOS(I)) 
    Call GEN_ILOG(TLAN(I),TDOS(I))  
    Call GEN_LIBCLI1(TLAN(I),TDOS(I))
    Call INIONEMEN(TDOS(I),TLAN(I)) From VALCSTWEB
  Endif
Next I
# 1 fev 2010 ajout des composants flash
Call GEN_LIBFLASH (TDOS,TLAN,NBLAN)

# 20 juin 2011 ajout des fichiers pour portal hr
Call GEN_LIBPORTAL (TDOS,TLAN,NBLAN)

# 21 Novembre 2012 : génération des libellés json pour le client
Call LIBCLIJSON

End

# ----------------------------------------------------------------------------

Subprog CRELIBALL

#       Génère les libellés pour toutes les langues de la solution

Local Integer NBLAN,I
Local Char TLAN(10)(1..50),TDOS(10)(1..50)

Call GLOBLANGREF(TDOS,TLAN,NBLAN) From INTRUTILA

# Crée les répertoires qui peuvent manquer sur X3_ROOT
Call CREX3ROOT From INTRUTILC

# Crée les fichiers connectx3langs par dossier
Local File ADOSSIER [ADS]
For [ADS]
  If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
    Call CRELIBWEBD([F:ADS]DOSSIER) From INTRUTILC
  Endif
Next

Call GENLIBWEB

Gosub ENGREF

For I=1 To NBLAN
  If TLAN(I)<>"ALL"
    Call GENLIBCLI(TLAN(I),TDOS(I),ENGREF) 
    Call GENLIBMOT(TLAN(I),TDOS(I)) 
    Call GEN_ILOG(TLAN(I),TDOS(I))  
    Call GEN_LIBCLI1(TLAN(I),TDOS(I))
    Call INIONEMEN(TDOS(I),TLAN(I)) From VALCSTWEB
  Endif
Next I

# 1 fev 2010 ajout des composants flash
Call GEN_LIBFLASH (TDOS,TLAN,NBLAN)

# 20 juin 2011 ajout des fichiers pour portal hr
Call GEN_LIBPORTAL (TDOS,TLAN,NBLAN)

# 21 Novembre 2012 : génération des libellés json pour le client
Call LIBCLIJSON

End
#
$ENGREF
#  Recherche le dossier de référence pour ENG 
Local Char ENGREF
For I=1 To NBLAN
  If TLAN(I)="ENG" 
    ENGREF=TDOS(I)
    Break 1
  Endif
Next I
If ENGREF=""
 For I=7 To 0 Step -1
   If adxmother(I)<>""
     ENGREF=adxmother(I)
     Break 1
   Endif
 Next I
Endif
Return

# ---------------------------------------------------------------------------------------

Subprog GENLIBWEB

#              Initialisation des libellés serveur Web


Local Char TEXT(250),VALL1(250)
Local Char NOMFIC(GDIMFIC)
Local Integer NBVAL,I,J,K,L,H
Local Integer NOMEN,NOMES
Local Char TLAN(GLONLAN)(1..50),TDOS(GLONADS)(1..50)
Local Integer NBLAN
Local Char    REPERT(GDIMFIC) , ORDSYS(250), DIRSEP, RESULT(200)(1..10)
Local Char    MACHINE(GDIMFIC) , REP(GDIMFIC)
Local Char    LANDES(GLONDES)
Local Integer STAT
MACHINE = adxmac(0)

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase


Call GLOBLANGREF(TDOS,TLAN,NBLAN) From INTRUTILA

Local File TABLAN [TLAG]        

Local Char LANISO(10)(1..50)
For I=1 To NBLAN
  If clalev([F:TLAG])<>0  : Close Local File [TLAG]  : Endif  
  Local File =TDOS(I)+".TABLAN" [TLAG]      
  Read [TLAG]TLA0=TLAN(I)
  LANISO(I)=[F:TLAG]LANISO
Next I
If clalev([F:TLAG])<>0  : Close Local File [TLAG]  : Endif  
Local Char TLIBLAN(30)(1..50,1..50)
For I=1 To NBLAN
  If clalev([F:AXX1])<>0  : Close Local File [AXX1]  : Endif  
  Local File =TDOS(I)+".ATEXTRA" [AXX1]      
  For J=1 To NBLAN
    Read [AXX1]AXX0 = "TABLAN";"INTDES";TLAN(J);TLAN(I);""
    If fstat=0
      TLIBLAN(I,J)= [F:AXX1]TEXTE
    Else 
      Read [AXX1]AXX0 = "TABLAN";"INTDES";GLANDEF;TLAN(I);""
      If fstat=0 
        TLIBLAN(I,J) = [F:AXX1]TEXTE 
      Else
        TLIBLAN(I,J) = LANISO(J) 
      Endif
    Endif
  Next J
Next I
If clalev([F:AXX1])<>0  : Close Local File [AXX1]  : Endif  



#     connectx3libslangs.xml  : table globale des langues de connexion de la solution

REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"LIB"
Gosub CREREP From INTRUTILC
NOMFIC=filpath(REP,"connectx3libslangs","xml","X3_PUB")
Openo NOMFIC,0 Using [CST_]
Iomode adxifs "" Using [CST_]
Iomode adxirs chr$(10) Using [CST_]
Iomode adxium GUTF8 Using [CST_]
VALL1='<?xml version="1.0" encoding="utf-8" ?>'
Wrseq VALL1 Using [CST_]
VALL1='<libs>'
Wrseq VALL1 Using [CST_]

For I=1 To NBLAN
  VALL1='<lib id="'+TLAN(I)+'" locale="'+LANISO(I)+'">'
  Wrseq VALL1 Using [CST_]
  For J=1 To NBLAN
    VALL1='<'+TLAN(J)+'>'+TLIBLAN(I,J)+'</'+TLAN(J)+'>'
    Wrseq VALL1 Using [CST_]
  Next J
  VALL1='</lib>'
  Wrseq VALL1 Using [CST_]
Next I

VALL1='</libs>'
Wrseq VALL1 Using [CST_]
Openo Using [CST_]


#     connectx3libs.xml  : libellés de connexion du serveur Web

REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"LIB"
Local File =GDOSX3+".APLSTD"  [A_SX]  :# On lit les XXX  toujours sur le dossier mère  CC 06/02/2009
If NBLAN>=1  :  Local File =TDOS(1)+".APLSTD"   [A_01] : Endif
If NBLAN>=2  :  Local File =TDOS(2)+".APLSTD"   [A_02] : Endif
If NBLAN>=3  :  Local File =TDOS(3)+".APLSTD"   [A_03] : Endif
If NBLAN>=4  :  Local File =TDOS(4)+".APLSTD"   [A_04] : Endif
If NBLAN>=5  :  Local File =TDOS(5)+".APLSTD"   [A_05] : Endif
If NBLAN>=6  :  Local File =TDOS(6)+".APLSTD"   [A_06] : Endif
If NBLAN>=7  :  Local File =TDOS(7)+".APLSTD"   [A_07] : Endif
If NBLAN>=8  :  Local File =TDOS(8)+".APLSTD"   [A_08] : Endif
If NBLAN>=9  :  Local File =TDOS(9)+".APLSTD"   [A_09] : Endif
If NBLAN>=10 :  Local File =TDOS(10)+".APLSTD"  [A_10] : Endif
If NBLAN>=11 :  Local File =TDOS(11)+".APLSTD"  [A_11] : Endif
If NBLAN>=12 :  Local File =TDOS(12)+".APLSTD"  [A_12] : Endif
If NBLAN>=13 :  Local File =TDOS(13)+".APLSTD"  [A_13] : Endif
If NBLAN>=14 :  Local File =TDOS(14)+".APLSTD"  [A_14] : Endif
If NBLAN>=15 :  Local File =TDOS(15)+".APLSTD"  [A_15] : Endif
If NBLAN>=16 :  Local File =TDOS(16)+".APLSTD"  [A_16] : Endif
If NBLAN>=17 :  Local File =TDOS(17)+".APLSTD"  [A_17] : Endif
If NBLAN>=18 :  Local File =TDOS(18)+".APLSTD"  [A_18] : Endif
If NBLAN>=19 :  Local File =TDOS(19)+".APLSTD"  [A_19] : Endif
If NBLAN>=20 :  Local File =TDOS(20)+".APLSTD"  [A_20] : Endif

 NOMEN=9710
 Local Char NAMLIB(120)(1..500)
 Local Integer NBLIB,NLIG,DEFTRAD,ADD

 Read [A_SX]CLE=9710;1;"XXX"
 If fstat<>0 : End : Endif
 NOMFIC=filpath(REP,"connectx3libs","xml","X3_PUB")
 Openo NOMFIC,0 Using [CST_]
 Iomode adxifs "" Using [CST_]
 Iomode adxirs chr$(10) Using [CST_]
 Iomode adxium GUTF8 Using [CST_]
 VALL1='<?xml version="1.0" encoding="utf-8" ?>'
 Wrseq VALL1 Using [CST_]
 VALL1='<libs  num="'+num$(NOMEN)+'" name="connectx3libs" langs="'
 For J=1 To NBLAN
   If J>1 : VALL1+="," : Endif
   VALL1+=TLAN(J)
 Next J
 VALL1+='">'
 Wrseq VALL1 Using [CST_]

#   Recherche les codes des libellés
 Filter [A_SX] Where LANCHP=NOMEN and LANNUM>1 and LAN="XXX" 
 NBLIB=1
 For [A_SX]
   NBLIB+=1
   NAMLIB(NBLIB)=[F:A_SX]LANMES
 Next
 Filter [A_SX]

 For J=2 To NBLIB
   If ADD>0 : ADD-=1 : Goto EXPORTSUI : Endif
   NOMES=J
   NLIG=0
   For L=J To J+10
     If NAMLIB(L)<>NAMLIB(J) : Break 1 : Endif
     NLIG+=1
   Next L
   VALL1='  <lib id="'+NAMLIB(J)+'" num="'
   For H=1 To NLIG
     If H>1 : ADD+=1 : VALL1+="/" : Endif
     VALL1+=num$(NOMES+H-1)
   Next H
   VALL1+='">'
   Wrseq VALL1 Using [CST_]

   For I=1 To NBLAN
     DEFTRAD=0
     VALL1='    <'+TLAN(I)+'>'
     For K=1 To NLIG
       Gosub RECHLIB
       VALL1+=TEXT
       If K<>NLIG : Wrseq VALL1 Using [CST_] : Raz VALL1 : Endif
     Next K
     VALL1+='</'+TLAN(I)+'>'
     Wrseq VALL1 Using [CST_]
   Next I

   VALL1='  </lib>'
   Wrseq VALL1 Using [CST_]
$EXPORTSUI
 Next J

 VALL1="</libs>"
 Wrseq VALL1 Using [CST_]
 Openo Using [CST_]

Close Local File
End


$RECHLIB
Raz TEXT
Case I
  When  1 : Read [A_01]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_01]LANMES : Endif
  When  2 : Read [A_02]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_02]LANMES : Endif
  When  3 : Read [A_03]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_03]LANMES : Endif
  When  4 : Read [A_04]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_04]LANMES : Endif
  When  5 : Read [A_05]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_05]LANMES : Endif
  When  6 : Read [A_06]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_06]LANMES : Endif
  When  7 : Read [A_07]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_07]LANMES : Endif
  When  8 : Read [A_08]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_08]LANMES : Endif
  When  9 : Read [A_09]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_09]LANMES : Endif
  When 10 : Read [A_10]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_10]LANMES : Endif
  When 11 : Read [A_11]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_11]LANMES : Endif
  When 12 : Read [A_12]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_12]LANMES : Endif
  When 13 : Read [A_13]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_13]LANMES : Endif
  When 14 : Read [A_14]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_14]LANMES : Endif
  When 15 : Read [A_15]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_15]LANMES : Endif
  When 16 : Read [A_16]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_16]LANMES : Endif
  When 17 : Read [A_17]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_17]LANMES : Endif
  When 18 : Read [A_18]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_18]LANMES : Endif
  When 19 : Read [A_19]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_19]LANMES : Endif
  When 20 : Read [A_20]CLE=NOMEN;NOMES+K-1;TLAN(I)
            If fstat=0 : TEXT=[F:A_20]LANMES : Endif
  When Default : If clalev([A_DF])<>0 : Close Local File [A_DF] : ENDIF
                 Local File =TDOS(I)+".APLSTD"  [A_DF]
                 Read [A_DF]CLE=NOMEN;NOMES+K-1;TLAN(I)
                 If fstat=0 : TEXT=[F:A_DF]LANMES : Endif
Endcase

If TLAN(I)<>"FRA" and (fstat<>0 or vireblc(TEXT,2)="") and (DEFTRAD=1 or K=1)
  Read [A_SX]CLE=NOMEN;NOMES+K-1;"FRA"
  TEXT=[F:A_SX]LANMES
  DEFTRAD=1
Endif
If fstat<>0 : TEXT="" : Endif  : # On pourrait mettre NAMLIB(J)
Call MODVAL(TEXT) From INTRUTILA
Return



# ------------------------------------------------------------------------------------

Subprog GENLIBMOT(LANG,DOSR)  

#    Génération libellés moteur pour la langue LANG

Value Char    LANG    : # Langue d'extraction  
Value Char    DOSR    : # Dossier de référence pour la langue  

Local Char ASTEXT (200)
Local Char LANTXT (123)
Local Char WCHEMIN (200)
Local Integer NUMDEB : NUMDEB=9001  : # Menu de départ d'extraction   
Local Integer NUMFIN : NUMFIN=11000 : # Menu Fin d'extraction 
NUMFIN=9149   : # Mail Cathy
Local Char DIRSEP,REP(200)


Local Integer NBLAN : NBLAN=1
Local Char TLAN(10)(1..1) : TLAN(1)=LANG
Local Integer RETCREREP
Gosub CREX3RLIBRE From INTRUTILC
Kill RETCREREP

Call GLOBWEB(nomap) From INTRUTILA

If clalev([F:TLA])=0  : Local File =DOSR+".TABLAN" [TLA]  : Endif        
If clalev([F:AST])=0  : Local File =DOSR+".APLSTD" [AST]  : Endif        

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"LIB"
ASTEXT =filpath(REP,LANG,"","X3_PUB")

Gosub ECRLIBCLI

Close Local File [TLA] , [AST]
End

# -----------------------------------------------------------------------

Subprog GENLIBCLI(LANG,DOSR,ENGREF)  

#    Génération libellés Client pour la langue LANG

Value Char    LANG    : # Langue d'extraction  
Value Char    DOSR    : # Dossier de référence pour la langue traitée 
Value Char    ENGREF  : # Dossier de référence pour la langue ENG 

Local Char ASTEXT (200)
Local Char LANTXT (123)
Local Char WCHEMIN (200)
Local Integer NUMDEB : NUMDEB=9137 : # Menu de départ d'extraction   
Local Integer NUMFIN : NUMFIN=9139 : # Menu Fin d'extraction 
Local Char DIRSEP,REP(200),LANG1


Local Integer NBLAN : NBLAN=1
Local Char TLAN(10)(1..1) : TLAN(1)=LANG
Local Integer RETCREREP
Gosub CREX3RLIBRE From INTRUTILC
Kill RETCREREP

Call GLOBWEB(nomap) From INTRUTILA


Local File =DOSR+".TABLAN" [TLA]        
Local File =DOSR+".APLSTD" [AST]        

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+LANG+DIRSEP+"LIB"
ASTEXT =filpath(REP,"wmainlibs","","X3_PUB")

Gosub ECRLIBCLI

#
#    Initialisation des libellés Editeur de formule (menus 9839 et 9840)
#    Pour la langue LANG


Local Char VALL1(200),TEXT(200)
Local Char FILEIN(200),FILEOUT(200)
Local Integer I,J,IPOS,IP0,IP1,IP2
Local Integer NOMEN,NOMES
Local Char NAMEREP(200),NAMEREP1(200)
Local Integer NBMOD
Local Char ARCHMOD(100)(1..10)
Local Integer ARCHTYP(1..10)


#  On ne génère pas si la langue est inconnue 
#  Si la langue est déclarée unicode on génère en ENG
#  [F:TLA]LANUNI=2
Read [TLA]TLA0=LANG
If fstat<>0  or [F:TLA]LAN="ALL"
  Goto FIN
Endif

#  Recherche les fichiers modèles

If clalev([F:HLP_])>0 : Close Local File [HLP_] : Endif
REP = "X3_ROOT"+DIRSEP+"RESSTD"+DIRSEP+"DIV"
NAMEREP=filpath(REP,"","","X3_PUB")
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
Local File (HLP(30)) From System adxmac(0)+'@lsadx -a'-toupper(nomap(0))-NAMEREP As [HLP_]
For [HLP_] Where HLP<>""
 IPOS=instr(1,toupper([F:HLP_]HLP),"_MOD")
 If IPOS<>0 
   NBMOD+=1
   ARCHMOD(NBMOD)=[F:HLP_]HLP
   ARCHTYP(NBMOD)=1
   If right$(toupper(ARCHMOD(NBMOD)),len(ARCHMOD(NBMOD))-3)=".XML" : ARCHTYP(NBMOD)=2 : Endif
 Endif
Next HLP_
If NBMOD=0 : Goto FIN : Endif

# Transformation des fichiers modèles

If [F:TLA]LANUNI=2 and ENGREF<>""
  Close Local File [AST]
  Local File =ENGREF+".APLSTD" [AST]        
Endif

For I=1 To NBMOD
 FILEIN=NAMEREP+DIRSEP+ARCHMOD(I)
 IPOS=instr(1,toupper(ARCHMOD(I)),"_MOD")
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+LANG+DIRSEP+"LIB"
  NAMEREP1=filpath(REP,"","","X3_PUB")
  fstat=0
  FILEOUT=NAMEREP1+DIRSEP+left$(ARCHMOD(I),IPOS-1)+right$(ARCHMOD(I),IPOS+4)
  Openi FILEIN Using [I_ED]
  If fstat<>0 
    Call ERREUR(mess(10,137,1)-FILEIN) From GESECRAN : # Erreur d'ouverture fichier  
    Goto FIN 
  Endif
  Iomode adxifs "" Using [I_ED]
  Iomode adxirs chr$(10) Using [I_ED]
  Case ARCHTYP(I)
    When 1 : Iomode adxium GASCII Using [I_ED]
    When 2 : Iomode adxium GUTF8 Using [I_ED]
  Endcase
  Openo FILEOUT,0 Using [O_ED]
  If fstat<>0 
    Call ERREUR(mess(10,137,1)-FILEOUT) From GESECRAN : # Erreur d'ouverture fichier  
    Goto FIN
  Endif
  Iomode adxifs "" Using [O_ED]
   Case ARCHTYP(I)
    When 1 : Iomode adxirs chr$(13)+chr$(10) Using [O_ED]
    When 2 : Iomode adxirs chr$(10) Using [O_ED]
  Endcase
  Case ARCHTYP(I)
    When 1 : Iomode adxium GASCII Using [O_ED]
    When 2 : Iomode adxium GUTF8 Using [O_ED]
  Endcase
  LANG1=LANG
  If [F:TLA]LANUNI=2 and ENGREF<>"" : LANG1="ENG" : Endif
  While fstat=0
    Rdseq VALL1 Using [I_ED]
    If fstat=0
      Gosub ANALED
      Wrseq VALL1 Using [O_ED]
    Endif
  Wend
  Openo Using [O_ED]
  Openi Using [I_ED]
Next I


# Transformation des fichiers modèles nouvelle mouture (éditeur de formule Unicode)
Local Integer ILIN
Close Local File [AST]
Local File =DOSR+".APLSTD" [AST] 
For I=1 To 2
  FILEIN=NAMEREP+DIRSEP
  Case I
    When 1 : FILEIN+="x3functions_mod.xml"
    When 2 : FILEIN+="x3operators_mod.xml"
  Endcase

  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+LANG+DIRSEP+"LIB"
  NAMEREP1=filpath(REP,"","","X3_PUB")
  fstat=0
  FILEOUT=NAMEREP1+DIRSEP
  Case I
    When 1 : FILEOUT+="x3Ufunctions.xml"
    When 2 : FILEOUT+="x3Uoperators.xml"
  Endcase
  Openi FILEIN Using [I_ED]
  If fstat<>0 
    Call ERREUR(mess(10,137,1)-FILEIN) From GESECRAN : # Erreur d'ouverture fichier  
    Goto FIN 
  Endif
  Iomode adxifs "" Using [I_ED]
  Iomode adxirs chr$(10) Using [I_ED]
  Iomode adxium GUTF8 Using [I_ED]
  Openo FILEOUT,0 Using [O_ED]
  If fstat<>0 
    Call ERREUR(mess(10,137,1)-FILEOUT) From GESECRAN : # Erreur d'ouverture fichier  
    Goto FIN
  Endif
  Iomode adxifs "" Using [O_ED]
  Iomode adxirs chr$(10) Using [O_ED]
  Iomode adxium GUTF8 Using [O_ED]
  LANG1=LANG
  While fstat=0
    Rdseq VALL1 Using [I_ED]
    If ILIN=0
      ILIN=1
      VALL1='<?xml version="1.0" encoding="utf-8" ?>'
    Endif
    If fstat=0
      Gosub ANALED
      Wrseq VALL1 Using [O_ED]
    Endif
  Wend
  Openo Using [O_ED]
  Openi Using [I_ED]
Next I



$FIN
If clalev([F:TLA])>0 : Close Local File [TLA] : Endif
If clalev([F:AST])>0 : Close Local File [AST] : Endif
End

$ANALED
  IP0=instr(1,VALL1,"mess(")
  If IP0=0 : Return : Endif
  IP2=instr(IP0,VALL1,",")
  NOMEN=val(mid$(VALL1,IP0+5,IP2-IP0-5))
  IP1=instr(IP2,VALL1,")")
  NOMES=val(mid$(VALL1,IP2+1,IP1-IP2-1))
  Read [AST]CLE=NOMEN;NOMES;LANG1
  If fstat=0 Then
    TEXT=[F:AST]LANMES
  Else
    If LANG1<>GLANGUE
      Read [AST]CLE=NOMEN;NOMES;GLANGUE
    Else
      Read [AST]CLE=NOMEN;NOMES;GLANDEF
    Endif
    If fstat=0 : TEXT=[F:AST]LANMES : Else : TEXT="("+num$(NOMEN)+","+num$(NOMES)+")": Endif
  Endif
# TEXT=mess(NOMES,NOMEN,1)
  VALL1=left$(VALL1,IP0-1)+TEXT+right$(VALL1,IP1+1)
#  CC   07/08/2006   - On ne met pas 2 chr$(10) à la fin   - Bug 37282
  If right$(VALL1,len(VALL1))=chr$(13) : VALL1=left$(VALL1,len(VALL1)-1) : Endif
  If right$(VALL1,len(VALL1))=chr$(10) : VALL1=left$(VALL1,len(VALL1)-1) : Endif
  fstat=0
Return


$ECRLIBCLI
# ouverture du fichier de sortie pour Aplstd en output  

Openo ASTEXT,0 Using [O_ED]
Iomode adxifs "" Using [O_ED]
Iomode adxirs "" Using [O_ED]
Iomode adxium GUTF8 Using [O_ED]


Local Integer  CHP, NUM , NUM2, I, CHAPNUM
Local Char     MES (123)
Local Char     RCHP : RCHP = chr$(12)
Local Char     RMES : RMES = chr$(10)
#

CHAPNUM = 0
CHP = 0
Filter [AST] Where LAN = LANG and [F:AST]LANCHP >= NUMDEB  and [F:AST]LANCHP <= NUMFIN  Order By Key CLE   
For [AST]CLE 
     If [F:AST]LANCHP <> CHP
        If CHAPNUM <> 0 
                #----------------------------------------#
                # Ecriture caractère rupture chapitre
                #----------------------------------------#
                Wrseq RCHP Using [O_ED]
                Wrseq RMES Using [O_ED]
        Endif
        CHAPNUM += 1
        CHP = [F:AST]LANCHP
        NUM = 0
     Endif

     NUM2 = [F:AST]LANNUM - NUM
     If NUM2 > 1
         For I = NUM + 1  To [F:AST]LANNUM - 1
            #-----------------------------------#
            # Ecriture caractère rupture numero
            #-----------------------------------#
            Wrseq RMES Using [O_ED]
         Next I
     Endif 
    #---------------------------------------------------------------#
    # Ecriture d un engt dans le fichier sequentiel de sortie  
    #---------------------------------------------------------------#

    NUM = [F:AST]LANNUM
    MES = [F:AST]LANMES   
    Wrseq MES,RMES Using [O_ED]

Next 

Filter [AST] : # Fin du filtre 

#-------------------------------------------#
# Ecriture caractère rupture chapitre
#-------------------------------------------#
 
Wrseq RCHP Using [O_ED]
Wrseq RMES Using [O_ED]

Openo  Using [O_ED]

Return

# -----------------------------------------------------------------------------------------------

Subprog GEN_ILOG(LANG,DOSR)  
Value Char LANG
Value Char DOSR

Local Char LANISO, DIRSEP
Local Char FNOMFIC (255), REP(250)
Local Char WTEXTE (255)

Local Char LEMOIS(3)
Local Char LEJOUR(3)
# jour de la semaine 742
# Mois de L'année 9001
LEMOIS=func MST(month( date$ ),9001)
LEJOUR=func MST(dayn(date$),742)

Local File =DOSR+".TABLAN" [TLA]
Local File =GDOSX3+".APLSTD" [ZZA] :# On lit les XXX  toujours sur le dossier mère  CC 06/02/2009

Local File =DOSR+".APLSTD" [ZZB]

# cg mars 2014
# il faut imperativement le code iso sous format xx_XX pour illog
# sinon les libelles ne s affichent pas
# en v7 les codes iso ont changé de format 
Read [TLA]TLA0=LANG
If fstat=0 
    LANISO=ctrans([F:TLA]LANISO,"-","_")
Endif
If LANISO="" : LANISO="xx_XX" : Endif

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+LANG+DIRSEP+"LIB"

#-----------------------------------------------------------#
# creation fichier x3optxxx.dbm sous X3_ROOT/GEN/"Lang"/LIB
#-----------------------------------------------------------#

FNOMFIC =filpath(REP,"x3opt"+LANG,"dbm","X3_PUB")

Openo FNOMFIC,0 Using [I_LO]
Iomode adxifs '' Using [I_LO]
Iomode adxirs chr$(10) Using [I_LO]

If LANG= "POL" or LANG = "RUS" or LANG = "CHI"
    Iomode adxium GUTF8 Using [I_LO]
Else
    Iomode adxium GASCII Using [I_LO]
Endif

#WTEXTE = "// IlvMessageDatabase 3.1 Thu Oct 14 09:48:29 1999"
WTEXTE = "// IlvMessageDatabase 4"-LEJOUR-LEMOIS-format$("D:DD",date$)-time$-format$("D:YYYY",date$)
Wrseq WTEXTE Using [I_LO]

WTEXTE = "// Language: "+LANISO
Wrseq WTEXTE Using [I_LO]

# ajout du russe et du polonais
# codif = windows-1250
If LANG = "CHI" 
    WTEXTE = "// Encoding: GB2312" 
Elsif LANG= "POL" or LANG = "RUS"
    WTEXTE = "// Encoding: windows-1250" 
Else
    WTEXTE = "// Encoding: windows-1252" 
Endif
#
Wrseq WTEXTE Using [I_LO]

Filter [ZZA] Where LANCHP = 9150 and LAN = "XXX" and LANNUM <> 0

For [ZZA]
    Raz WTEXTE
    Read [ZZB]CLE = [F:ZZA]LANCHP;[F:ZZA]LANNUM;LANG
    If fstat = 0
        WTEXTE = '"'+[F:ZZA]LANMES+'" "'+[F:ZZB]LANMES+'"'
    Else
        WTEXTE = '"'+[F:ZZA]LANMES+'"'
    Endif
    Wrseq WTEXTE Using [I_LO]
Next

Filter [ZZA]

Openo Using [I_LO] 


#-----------------------------------------------------------#
# creation fichier x3scaxxx.dbm sous X3_ROOT/GEN/"Lang"/LIB
#-----------------------------------------------------------#

FNOMFIC =filpath(REP,"x3sca"+LANG,"dbm","X3_PUB")

Openo FNOMFIC,0 Using [I_LO] 
Iomode adxifs '' Using [I_LO]
Iomode adxirs chr$(13)+chr$(10) Using [I_LO]
If LANG= "POL" or LANG = "RUS" or LANG = "CHI"
    Iomode adxium GUTF8 Using [I_LO]
Else
    Iomode adxium GASCII Using [I_LO]
Endif

#WTEXTE = "// IlvMessageDatabase 3.1 Thu Oct 14 09:48:29 1999"
WTEXTE = "// IlvMessageDatabase 4"-LEJOUR-LEMOIS-format$("D:DD",date$)-time$-format$("D:YYYY",date$)
Wrseq WTEXTE Using [I_LO]

WTEXTE = "// Language: "+LANISO
Wrseq WTEXTE Using [I_LO]

# ajout du russe et du polonais
# codif = windows-1250
If LANG = "CHI" 
    WTEXTE = "// Encoding: GB2312" 
Elsif LANG= "POL" or LANG = "RUS"
    WTEXTE = "// Encoding: windows-1250" 
Else
    WTEXTE = "// Encoding: windows-1252" 
Endif
#
Wrseq WTEXTE Using [I_LO]


Filter [ZZA] Where LANCHP = 9153 and LAN = "XXX" and LANNUM <> 0

For [ZZA]
    Raz WTEXTE
    Read [ZZB]CLE = [F:ZZA]LANCHP;[F:ZZA]LANNUM;LANG
    If fstat = 0
        WTEXTE = '"'+[F:ZZA]LANMES+'" "'+[F:ZZB]LANMES+'"'
    Else
        WTEXTE = '"'+[F:ZZA]LANMES+'"'
    Endif
    Wrseq WTEXTE Using [I_LO]
Next

Filter [ZZA]

Filter [ZZA] Where LANCHP = 9151 and LAN = "XXX" and LANNUM <> 0

For [ZZA]
    Raz WTEXTE
    Read [ZZB]CLE = [F:ZZA]LANCHP;[F:ZZA]LANNUM;LANG
    If fstat = 0
        WTEXTE = '"'+[F:ZZA]LANMES+'" "'+[F:ZZB]LANMES+'"'
    Else
        WTEXTE = '"'+[F:ZZA]LANMES+'"'
    Endif
    Wrseq WTEXTE Using [I_LO]
Next

Filter [ZZA]

Openo Using [I_LO]


#-----------------------------------------------------------#
# creation fichier x3secxxx.dbm sous X3_ROOT/GEN/"Lang"/LIB
#-----------------------------------------------------------#

FNOMFIC =filpath(REP,"x3sec"+LANG,"dbm","X3_PUB")

Openo FNOMFIC,0 Using [I_LO] 
Iomode adxifs '' Using [I_LO]
Iomode adxirs chr$(13)+chr$(10) Using [I_LO]
If LANG= "POL" or LANG = "RUS" or LANG = "CHI"
    Iomode adxium GUTF8 Using [I_LO]
Else
    Iomode adxium GASCII Using [I_LO]
Endif

#WTEXTE = "// IlvMessageDatabase 3.1 Thu Oct 14 09:48:29 1999"
WTEXTE = "// IlvMessageDatabase 4"-LEJOUR-LEMOIS-format$("D:DD",date$)-time$-format$("D:YYYY",date$)
Wrseq WTEXTE Using [I_LO]

WTEXTE = "// Language: "+LANISO
Wrseq WTEXTE Using [I_LO]

# ajout du russe et du polonais
# codif = windows-1250
If LANG = "CHI" 
    WTEXTE = "// Encoding: GB2312" 
Elsif LANG= "POL" or LANG = "RUS"
    WTEXTE = "// Encoding: windows-1250" 
Else
    WTEXTE = "// Encoding: windows-1252" 
Endif
#
Wrseq WTEXTE Using [I_LO]


Filter [ZZA] Where LANCHP = 9152 and LAN = "XXX" and LANNUM <> 0

For [ZZA]
    Raz WTEXTE
    Read [ZZB]CLE = [F:ZZA]LANCHP;[F:ZZA]LANNUM;LANG
    If fstat = 0
        WTEXTE = '"'+[F:ZZA]LANMES+'" "'+[F:ZZB]LANMES+'"'
    Else
        WTEXTE = '"'+[F:ZZA]LANMES+'"'
    Endif
    Wrseq WTEXTE Using [I_LO] 
Next

Filter [ZZA]

Openo Using [I_LO] 


Close Local File
End

