Subprog GEN_LIBFLASH(TDOS,TLAN,NBLAN)
Value Char TDOS()(1..)
Value Char TLAN()(1..)
Value Integer NBLAN



Local Char    REP(250),LANLIB(50)
Local Char    REP_MOD (250)
Local Char    REP_COP (250)

Local Char    WPREF_FILE (25), WPREF_FILE_MOD (25), DIRSEP(1)
Local Char    WPREF_FILE_COP (25)
Local Integer WCHAP
Local Char    FNOMFIC (255)
Local Char    WTEXTE (255)


Local Char    WFICORI (255)
Local Char    WFICCOP (255)


Local Integer WNBRE_RECORD

Local Integer WSTAT



Local Char    WVERSION : WVERSION = 'Version="V1.0"'


Local File =GDOSX3+".APLSTD" [ZZA] :# On lit les XXX  toujours sur le dossier mère  idem pour les autres
Local File =GDOSX3+".APLSTD" [ZZB]
Local File =GDOSX3+".APLSTD" [ZZC]


Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

REP= "X3_ROOT"+DIRSEP+"X3CLI"+DIRSEP+"XBLOCK"+DIRSEP+"FLASH"+DIRSEP+"_Core"+DIRSEP+"_xmlparams"
# rep de copie des generes
REP_COP= "X3_ROOT"+DIRSEP+"FLASH_TRANS"+DIRSEP+"_GENERATED"


# verification que les records xxx existent
# si ce n'est pas le cas : on ne fait rien on ecrase surtout pas les fichiers
WNBRE_RECORD = 0
Filter [ZZA] Where LANCHP > 9949 and LANCHP < 9953 and LAN = "XXX" and LANNUM <> 0
WNBRE_RECORD = rowcount ([F:ZZA])
Filter [ZZA]

If WNBRE_RECORD <> 0
    WPREF_FILE = "msgs"
    Gosub BOUCLE_MSGS
    WFICORI =filpath(REP,WPREF_FILE,"xml","X3_PUB")
    WFICCOP =filpath(REP_COP,WPREF_FILE,"xml","X3_PUB")
    Call COPIE(WFICORI,WFICCOP,WSTAT) From ORDSYS
Endif
 
# verification que les records xxx existent
# si ce n'est pas le cas : on ne fait rien on ecrase surtout pas ls fichiers

WNBRE_RECORD = 0
Filter [ZZA] Where LANCHP > 9952 and LANCHP < 9961 and LAN = "XXX" and LANNUM <> 0
WNBRE_RECORD = rowcount ([F:ZZA])
Filter [ZZA]

If WNBRE_RECORD <> 0
    WPREF_FILE = "trans_all"
    Gosub BOUCLE_TRANS_ALL
    WFICORI =filpath(REP,WPREF_FILE,"xml","X3_PUB")
    WFICCOP =filpath(REP_COP,WPREF_FILE,"xml","X3_PUB")
    Call COPIE(WFICORI,WFICCOP,WSTAT) From ORDSYS
Endif


WPREF_FILE = "sgx_libsinfo"
WPREF_FILE_MOD = "sgx_libsinfo_mod"
REP_MOD= "X3_ROOT"+DIRSEP+"FLASH_TRANS"+DIRSEP+"MODELS"
# rep de copie des generes
REP_COP= "X3_ROOT"+DIRSEP+"FLASH_TRANS"+DIRSEP+"_GENERATED"
#
REP= "X3_ROOT"+DIRSEP+"X3CLI"+DIRSEP+"XBLOCK"+DIRSEP+"FLASH"+DIRSEP+"FlowCharting"+DIRSEP+"ELibs"
# sous /dossiers/X3_PUB/X3_ROOT/X3CLI/XBLOCK/FLASH/FlowCharting/ELibs/

# REP_MOD = dossiers/X3_PUB/X3_ROOT/FLASH_TRANS/MODELS/
# verification que le fichier modele existe 
# si n'existe pas on ne fait rien

If filinfo(filpath(REP_MOD,WPREF_FILE_MOD,"txt","X3_PUB"),0)>0
    Gosub BOUCLE_SGX_LIBSINFO
    # copie le fichier genere sous /_GENERATED/
     WFICORI =filpath(REP,WPREF_FILE,"txt","X3_PUB")
     WFICCOP =filpath(REP_COP,WPREF_FILE,"txt","X3_PUB")
     Call COPIE(WFICORI,WFICCOP,WSTAT) From ORDSYS
Endif

WPREF_FILE = "sgx_libsinfo"
WPREF_FILE_MOD = "NEW_sgx_libsinfo_mod"
REP= "X3_ROOT"+DIRSEP+"X3CLI"+DIRSEP+"XBLOCK"+DIRSEP+"FLASH"+DIRSEP+"FlowCharting"+DIRSEP+"xtec"+DIRSEP+"sage_libraries"+DIRSEP+"sage_basic"
# sous /dossiers/X3_PUB/X3_ROOT/X3CLI/XBLOCK/FLASH/FlowCharting/xtec/sage_libraries/sage_basic/

# verification que le fichier modele existe 
# si n'existe pas on ne fait rien
If filinfo(filpath(REP_MOD,WPREF_FILE_MOD,"txt","X3_PUB"),0)>0
    Gosub BOUCLE_NEW_SGX_LIBSINFO
    # copie le fichier genere sous /_GENERATED/
     WFICORI =filpath(REP,WPREF_FILE,"txt","X3_PUB")
     WPREF_FILE_COP= "NEW_"+WPREF_FILE
     WFICCOP =filpath(REP_COP,WPREF_FILE_COP,"txt","X3_PUB")
     Call COPIE(WFICORI,WFICCOP,WSTAT) From ORDSYS
Endif


WPREF_FILE = "start"
WPREF_FILE_MOD = "start_PADDEV_mod"
REP= "X3_ROOT"+DIRSEP+"X3CLI"+DIRSEP+"XBLOCK"+DIRSEP+"FLASH"+DIRSEP+"FlowCharting"+DIRSEP+"xtec"+DIRSEP+"xstartdata"+DIRSEP+"PadDev"
# sous dossiers/X3_PUB/X3_ROOT/X3CLI/XBLOCK/FLASH/FlowCharting/xtec/xstartdata/PadDev/

# verification que le fichier modele existe 
# si n'existe pas on ne fait rien
If filinfo(filpath(REP_MOD,WPREF_FILE_MOD,"txt","X3_PUB"),0)>0
    Gosub BOUCLE_START_PADDEV
    # copie le fichier genere sous /_GENERATED/
     WFICORI =filpath(REP,WPREF_FILE,"txt","X3_PUB")
     WPREF_FILE_COP= WPREF_FILE+"_PADDEV"
     WFICCOP =filpath(REP_COP,WPREF_FILE_COP,"txt","X3_PUB")
     Call COPIE(WFICORI,WFICCOP,WSTAT) From ORDSYS
Endif

WPREF_FILE = "start"
WPREF_FILE_MOD = "start_PADPLAYER_mod"
REP= "X3_ROOT"+DIRSEP+"X3CLI"+DIRSEP+"XBLOCK"+DIRSEP+"FLASH"+DIRSEP+"FlowCharting"+DIRSEP+"xtec"+DIRSEP+"xstartdata"+DIRSEP+"PadPlayer"
# sous dossiers/X3_PUB/X3_ROOT/X3CLI/XBLOCK/FLASH/FlowCharting/xtec/xstartdata/PadPlayer/

# verification que le fichier modele existe 
# si n'existe pas on ne fait rien
If filinfo(filpath(REP_MOD,WPREF_FILE_MOD,"txt","X3_PUB"),0)>0
    Gosub BOUCLE_START_PADPLAYER
    # copie le fichier genere sous /_GENERATED/
     WFICORI =filpath(REP,WPREF_FILE,"txt","X3_PUB")
     WPREF_FILE_COP= WPREF_FILE+"_PADPLAYER"
     WFICCOP =filpath(REP_COP,WPREF_FILE_COP,"txt","X3_PUB")
     Call COPIE(WFICORI,WFICCOP,WSTAT) From ORDSYS
Endif


Close Local File
End
###########################################################################################################
$BOUCLE_MSGS
Local Char FNOMFIC (255)
Local Char WTEXTE (255)
Local Char WLAN(3)

Local Integer WINDICE

#---------------------------------------------#
# creation fichier msgs.xml sous x3_pb        #
#---------------------------------------------#
FNOMFIC =filpath(REP,WPREF_FILE,"xml","X3_PUB")

Openo FNOMFIC,0 Using [I_LO]
Iomode adxifs '' Using [I_LO]
Iomode adxirs chr$(10) Using [I_LO]
Iomode adxium GUTF8 Using [I_LO]

WTEXTE ='<?xml version="1.0" encoding="UTF-8" ?>'
Wrseq WTEXTE Using [I_LO]

WTEXTE = '<xmessages xkey="556422" xid="msgs_all">'
Wrseq WTEXTE Using [I_LO]
WTEXTE = '<xstds>'
Wrseq WTEXTE Using [I_LO]

Filter [ZZA] Where LANCHP = 9950 and LAN = "XXX" and LANNUM <> 0

For [ZZA]
    Raz WTEXTE
    WTEXTE = ' <xstd xid="'+[F:ZZA]LANMES+'">'
    Wrseq WTEXTE Using [I_LO]
    Raz WTEXTE
    For WINDICE = 1 To NBLAN
        WLAN =TLAN (WINDICE)
        WLAN = tolower (WLAN)
        Read [ZZB]CLE = [F:ZZA]LANCHP;[F:ZZA]LANNUM;TLAN (WINDICE)
        If fstat = 0
