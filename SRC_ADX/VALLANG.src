Openi Using [I_MD]

Return

#######################################################
$ANA_TEXTE
# on recherche le texte {mess(9961, ---> pour sgx_libsinfo
# on recherche le texte {mess(9962, ---> pour start_paddev
# on recherche le texte {mess(9963, ---> pour start_padplayer

# et on va remplacer par ex {"lang":"eng","label":"Basic shapes"},
# attention la derniere trad ne doit pas avoir la virgule finir par }
WCHAR = ""

WRANG1 = 0
WRANG2 = 0
WNUM   = 0
WNBRE  = 0
#
WTEXTWRIT =""
WTEXTGAUCH =""
WTEXTDROIT =""

#
WRANG1 = instr (0,WTEXTE,WCHAINE)
If WRANG1 <> 0
    # texte à gauche ex  sur la chaine TEST{(mess,9961,1)}TATA
    # on recupere à gauche TEST{
    # on recupere à droite TATA

    WTEXTGAUCH = left$(WTEXTE,WRANG1-1)
    # recuperation du numero dernier pour lire le record de aplstd
    WCHAINE =")}"
    WRANG2 = instr (0,WTEXTE,WCHAINE)
    WTEXTDROIT =right$(WTEXTE,WRANG2+2)
    If WRANG2 > WRANG1
        # si code = X il faudra remplacer par la liste des langues
        WCHAR = mid$(WTEXTE,WRANG1+11,WRANG2-WRANG1-11)
        If WCHAR = "X"
            WTEXTWRIT = WLIBLAN
        Else
            WNUM = val(mid$(WTEXTE,WRANG1+11,WRANG2-WRANG1-11))
            # lecture aplstd de toutes les langues dispo
            If WNUM = 0
                # erreur dans le fichier modele
                WTEXTWRIT = '"lang":"'+WLAN+'","label":"'+[F:ZZA]LANMES+'"}'      
            Else
                Filter [ZZA] Where LANCHP = WLANCHP and LANNUM = WNUM and LAN <> "XXX"
                WNBRE= rowcount ([F:ZZA])
                If WNBRE = 0
                    # erreur dans le fichier modele
                    WTEXTWRIT = '"lang":"fra","label":"error !!!!!!"}'    
                Else
                    For [ZZA]
                        WLAN = tolower([F:ZZA]LAN)
                        If WTEXTGAUCH <> ""
                            WTEXTWRIT =WTEXTGAUCH
                            WTEXTGAUCH = ""
                        Endif
                        WNBRE -=1
                        WTEXTWRIT += '{"lang":"'+WLAN+'","label":"'+[F:ZZA]LANMES+'"}'  
                        If WNBRE <>0
                            WTEXTWRIT =WTEXTWRIT+','
                            Wrseq WTEXTWRIT Using [O_FC]
                            WTEXTWRIT = ""
                        Endif
                    Next
                Endif
                Filter [ZZA]
            Endif
        Endif
    Else
        # erreur dans le fichier modele
        WTEXTWRIT = '"lang":"fra","label":"error !!!!!!"}'    
        Return
    Endif
    If WTEXTGAUCH <> ""
            WTEXTWRIT =WTEXTGAUCH+WTEXTWRIT
    Endif
    If WTEXTDROIT <> ""
            WTEXTWRIT =WTEXTWRIT+WTEXTDROIT
    Endif
Else
    WTEXTWRIT =WTEXTE
Endif
Wrseq WTEXTWRIT Using [O_FC]

Return


$ANA_LIBLAN
Filter [ZZA] Where LANCHP = WLANCHP and LANNUM = 1 and LAN <> "XXX"
WLIBLAN =""
WNBRE= rowcount ([F:ZZA])
If WNBRE <> 0
    For [ZZA]
        WLIBLAN += '"'+tolower([F:ZZA]LAN)+'"'
        WNBRE -=1
        If WNBRE <>0
             WLIBLAN +=','
        Endif
    Next
Endif
Filter [ZZA]

# pour l'instant on force wliblan avec fra et eng seuelemnt
# correspond a l'aide en ligne sur ce produit ..
WLIBLAN = '"fra","eng"'


Return


###########################################################################################################
# -----------------------------------------------------------------------------------------------

Subprog GEN_LIBPORTAL(TDOS,TLAN,NBLAN)
