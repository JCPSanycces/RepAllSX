Iomode adxifs '' Using [I_MD]
Iomode adxirs chr$(10) Using [I_MD]
Iomode adxium GUTF8 Using [I_MD]

# init wliblan
WLANCHP = 9963
Gosub ANA_LIBLAN

# Transformation du fichier modèle
Repeat
    WCHAINE ="{mess(9963,"
    Rdseq WTEXTE Using [I_MD]
    If WTEXTE <> ""
          Gosub ANA_TEXTE
    Endif
Until fstat <> 0


