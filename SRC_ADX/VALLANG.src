$BOUCLE_RSRC

# verification que le fichier modele existe 
# si n'existe pas on ne fait rien on continue
If filinfo(filpath(REP_MOD,WPREF_FILE_MOD,"txt","X3_PUB"),0)<=0
    Return
Endif

Local Char FNOMFIC (255)
Local Char FNOMMODEL (255)
FNOMFIC =filpath(REP,WPREF_FILE,"txt","X3_PUB")
FNOMMODEL =filpath(REP_MOD,WPREF_FILE_MOD,"txt","X3_PUB")



WTEXTE =""
WTEXTGAUCH =""
WTEXTDROIT = ""
WTEXWRIT =""


WRANG1=0
WRANG2=0
WNUM=0
WNBRE=0

WLAN=""
WCHAR= ""
WLIBLAN =""

WCHAINE = ""

Openo FNOMFIC,0 Using [OFIC]
Iomode adxifs '' Using [OFIC]
Iomode adxirs chr$(10) Using [OFIC]
Iomode adxium GUTF8 Using [OFIC]

# recherche du fichier modele
Openi FNOMMODEL,0 Using [IMOD]
Iomode adxifs '' Using [IMOD]
Iomode adxirs chr$(10) Using [IMOD]
Iomode adxium GUTF8 Using [IMOD]

# TRANSFORMATION du fichier modèle
Repeat
    Rdseq WTEXTE Using [IMOD]
    If WTEXTE <> ""
          Gosub ANA_TEXTE_RSRC
    Endif
Until fstat <> 0


Openo Using [OFIC]
Openi Using [IMOD]

Return


#######################################################
$ANA_TEXTE_RSRC
# on recherche le texte {mess(9300, ---> pour 
# on recherche le texte {mess(9301, ---> pour xxx
# on recherche le texte {mess(9302, ---> pour xxxx

# et on va remplacer par ex "ENG": "February",
# attention la derniere trad ne doit pas avoir la virgule finir par }
WCHAR = ""

WRANG1 = 0
WRANG2 = 0
WNUM   = 0
WNBRE  = 0
#
WTEXTWRIT =""
WTEXTGAUCH =""
WTEXTDROIT =""
#
WRANG1 = instr (0,WTEXTE,WCHAIPREM)
If WRANG1 <> 0
    # texte à gauche ex  sur la chaine TEST{(mess,9300,1)}TATA
    # on recupere à gauche TEST{
    # on recupere à droite TATA

    WTEXTGAUCH = left$(WTEXTE,WRANG1-1)
    # recuperation du numero dernier pour lire le record de aplstd
    WCHAINE =")}"
    WRANG2 = instr (0,WTEXTE,WCHAINE)
    WTEXTDROIT =right$(WTEXTE,WRANG2+2)
    If WRANG2 > WRANG1
        # si code = X il faudra remplacer par la liste des langues
        WCHAR = mid$(WTEXTE,WRANG1+11,WRANG2-WRANG1-11)
        If WCHAR = "X"
            WTEXTWRIT = WLIBLAN
        Else
            WNUM = val(mid$(WTEXTE,WRANG1+11,WRANG2-WRANG1-11))
            # lecture aplstd de toutes les langues dispo
            If WNUM = 0
                # erreur dans le fichier modele
                WTEXTWRIT = '"lang":"'+WLAN+'","label":"'+[F:ZZA]LANMES+'"'      
            Else
                Filter [ZZA] Where LANCHP = WLANCHP and LANNUM = WNUM and LAN <> "XXX"
                WNBRE= rowcount ([F:ZZA])
                If WNBRE = 0
                    # erreur dans le fichier modele
                    WTEXTWRIT = '"FRA": "error not exist!!!!!!"'    
                Else
                    For [ZZA]
                        WLAN = toupper([F:ZZA]LAN)
                        If WTEXTGAUCH <> ""
                            WTEXTWRIT =WTEXTGAUCH
                            WTEXTGAUCH = ""
                        Endif
                        WNBRE -=1
                        # attention le lanmes doit etre reecrit en fct a cause des " et des '
                        # a cause de json
                        # 1. on remplace le \" par "
                        # 2. on remplace le ' par "
                        # 3. on remplace le " par \" en dernier
                        WLAN_MES =[F:ZZA]LANMES
                        WLAN_MES= func AFNC.TRANSF(WLAN_MES,'\"','"')
                        WLAN_MES =func AFNC.TRANSF(WLAN_MES,"'",'"')
                        WLAN_MES=func AFNC.TRANSF(WLAN_MES,'"','\"')

                        WTEXTWRIT += '"'+WLAN+'": "'+WLAN_MES+'"'  
                        If WNBRE <>0
                            WTEXTWRIT =WTEXTWRIT+','
                            Wrseq WTEXTWRIT Using [OFIC]
                            WTEXTWRIT = ""
                        Endif
                    Next
                Endif
                Filter [ZZA]
            Endif
        Endif
    Else
        # erreur dans le fichier modele
        WTEXTWRIT = '"FRA": "error template!!!!!!"'    
        Return
    Endif
    If WTEXTGAUCH <> ""
            WTEXTWRIT =WTEXTGAUCH+WTEXTWRIT
    Endif
    If WTEXTDROIT <> ""
            WTEXTWRIT =WTEXTWRIT+WTEXTDROIT
    Endif
Else
    WTEXTWRIT =WTEXTE
Endif
Wrseq WTEXTWRIT Using [OFIC]

Return

