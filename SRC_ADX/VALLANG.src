Subprog COPYLOC(TLAN,NBLAN)     
Value Char TLAN()(1..)
Value Integer NBLAN

#  Copie sur un répertoire client et renomme tous les fichiers du client
#  produits sur le serveur selon les normes définies

Local Char REPLOC(200)
Local Integer OK
REPLOC="#@C:\tmp"
Call SAICAR(REPLOC,mess(37,139,1),mess(37,139,1),"A",0,200,"", OK) From GESECRAN
If OK<>2 : End : Endif
REPLOC=ctrans(REPLOC,"/","\")

If filinfo(REPLOC,7)<0
#   Répertoire inexistant  
  Call ERREUR(REPLOC-":"-mess(86,133,1)) From GESECRAN
  End
Endif

If right$(REPLOC,len(REPLOC))<>"\" : REPLOC+="\" : Endif

Local Integer I
Local Char REP(250),FIC1(250),FIC2(250),DIRSEP

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

Call OUVRE_TRACE(" ") From LECFIC

#  Copie de Connectx3libslangs.xml
REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"LIB"
FIC1=filpath(REP,"connectx3libslangs","xml","X3_PUB")
FIC2=REPLOC+"connectx3libslangs.xml"
Gosub COP_FIC



For I=1 To NBLAN
  #  Copie de wmainlibs
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)+DIRSEP+"LIB"
  FIC1=filpath(REP,"wmainlibs","","X3_PUB")
  FIC2=REPLOC+"U"+TLAN(I)
  Gosub COP_FIC

  #  Copie de x3functions.xml
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)+DIRSEP+"LIB"
  FIC1=filpath(REP,"x3functions","xml","X3_PUB")
  FIC2=REPLOC+"x3functions"+TLAN(I)+".xml"
  Gosub COP_FIC

  #  Copie de x3Ufunctions.xml
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)+DIRSEP+"LIB"
  FIC1=filpath(REP,"x3Ufunctions","xml","X3_PUB")
  FIC2=REPLOC+"x3Ufunctions"+TLAN(I)+".xml"
  Gosub COP_FIC

  #  Copie de x3functions.txt
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)+DIRSEP+"LIB"
  FIC1=filpath(REP,"x3functions","txt","X3_PUB")
  FIC2=REPLOC+"x3functions"+TLAN(I)+".txt"
  Gosub COP_FIC

  #  Copie de x3operators.txt
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)+DIRSEP+"LIB"
  FIC1=filpath(REP,"x3operators","txt","X3_PUB")
  FIC2=REPLOC+"x3operators"+TLAN(I)+".txt"
  Gosub COP_FIC

  #  Copie de x3operators.xml
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)+DIRSEP+"LIB"
  FIC1=filpath(REP,"x3operators","xml","X3_PUB")
  FIC2=REPLOC+"x3operators"+TLAN(I)+".xml"
  Gosub COP_FIC

  #  Copie de x3Uoperators.xml
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)+DIRSEP+"LIB"
  FIC1=filpath(REP,"x3Uoperators","xml","X3_PUB")
  FIC2=REPLOC+"x3Uoperators"+TLAN(I)+".xml"
  Gosub COP_FIC

  #  Copie de Imp_CR_"codlang".xml.txt
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"LIB"
  FIC1=filpath(REP,"Imp_CR_"+TLAN(I),"xml","X3_PUB")
  FIC2=REPLOC+"Imp_CR_"+TLAN(I)+".xml"
  Gosub COP_FIC

  #  Copie de Tools_"codlang".xml
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"LIB"
  FIC1=filpath(REP,"Tools_"+TLAN(I),"xml","X3_PUB")
  FIC2=REPLOC+"Tools_"+TLAN(I)+".xml"
  Gosub COP_FIC

  #  Copie de Trad_"codlang".xml
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"LIB"
  FIC1=filpath(REP,"Trad_"+TLAN(I),"xml","X3_PUB")
  FIC2=REPLOC+"Trad_"+TLAN(I)+".xml"
  Gosub COP_FIC

  #  Copie de AddIn_Ol_"codlang".xml
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"LIB"
  FIC1=filpath(REP,"AddIn_Ol_"+TLAN(I),"xml","X3_PUB")
  FIC2=REPLOC+"AddIn_Ol_"+TLAN(I)+".xml"
  Gosub COP_FIC

  #  Copie de x3opt"codlang".dbm
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)+DIRSEP+"LIB"
  FIC1=filpath(REP,"x3opt"+TLAN(I),"dbm","X3_PUB")
  FIC2=REPLOC+"X3Opt"+TLAN(I)+".dbm"
  Gosub COP_FIC

  #  Copie de x3sca"codlang".dbm
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)+DIRSEP+"LIB"
  FIC1=filpath(REP,"x3sca"+TLAN(I),"dbm","X3_PUB")
  FIC2=REPLOC+"X3Sca"+TLAN(I)+".dbm"
  Gosub COP_FIC

  #  Copie de x3sec"codlang".dbm
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)+DIRSEP+"LIB"
  FIC1=filpath(REP,"x3sec"+TLAN(I),"dbm","X3_PUB")
  FIC2=REPLOC+"X3Sec"+TLAN(I)+".dbm"
  Gosub COP_FIC
Next I

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End


$COP_FIC
  If filinfo(FIC1,7)>0
    Call COPIE(FIC1,FIC2,OK) From ORDSYS
    Call ECR_TRACE(mess(91,123,1)-":"-FIC1,0) From GESECRAN 
  Else
    Call ECR_TRACE(mess(101,100,1)-":"-FIC1,1) From GESECRAN 
  Endif
Return

# -----------------------------------------------------------------------------------------------

# Textes du dictionnaire (APLSTD)
Funprog MST(I,CHAP)
 If clalev([F:ZSTD])=0 : Local File APLSTD [ZSTD] : Endif
 Read [ZSTD]CLE=CHAP;I;"ENG"
 If fstat=0
    End [ZSTD]LANMES
 Else
    Read [ZSTD]CLE=CHAP;I;GLANGUE
    If fstat=0
    End [ZSTD]LANMES
    Endif
 Endif
End ""

# -----------------------------------------------------------------------------------------------

Subprog LIBCLIJSON

Local Char REP(GDIMFIC),DIRSEP,VALLM(200),VALLM1(200) 
Local Char TLAN(GLONLAN)(1..50),TDOS(GLONADS)(1..50)
Local Integer NBLAN

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

Call GLOBLANGREF(TDOS,TLAN,NBLAN) From INTRUTILA
For I=1 To NBLAN
  If clalev([F:AS_T])<>0  : Close Local File [AS_T]  : Endif  
  Local File =TDOS(I)+".APLSTD" [AS_T]   
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)+DIRSEP+"LIB" 
  NAMEFIC=filpath(REP,"localize","json","X3_PUB")
  Openo NAMEFIC,0 Using [O_ED]
  Iomode adxifs "" Using [O_ED]
  Iomode adxirs chr$(10) Using [O_ED]
  Iomode adxium GUTF8 Using [O_ED]
  Gosub LIBCLIINJSON
  Openo Using [O_ED]
Next I
If clalev([F:AS_T])<>0  : Close Local File [AS_T]  : Endif  

End


$LIBCLIINJSON
Wrseq '{' Using [O_ED]

Filter [AS_T] Where LANCHP=7980 and LANNUM>0 and LAN=TLAN(I)
Wrseq '"error": {' Using [O_ED]
VALLM1=""
For [AS_T]
  VALLM=[F:AS_T]LANMES
  Gosub MVALC1 From INTRUTILA 
  If VALLM1<>"" : Wrseq VALLM1+',' Using [O_ED] : Endif
  VALLM1='"'+num$([F:AS_T]LANNUM)+'":"'+VALLM+'"' 
Next
Filter [AS_T]
If VALLM1<>"" : Wrseq VALLM1 Using [O_ED] : Endif
Wrseq '},' Using [O_ED]

Filter [AS_T] Where LANCHP=7981 and LANNUM>0 and LAN=TLAN(I)
Wrseq '"text": {' Using [O_ED]
VALLM1=""
For [AS_T]
  VALLM=[F:AS_T]LANMES
  Gosub MVALC1 From INTRUTILA 
  If VALLM1<>"" : Wrseq VALLM1+',' Using [O_ED] : Endif
  VALLM1='"'+num$([F:AS_T]LANNUM)+'":"'+VALLM+'"' 
Next
Filter [AS_T]
If VALLM1<>"" : Wrseq VALLM1 Using [O_ED] : Endif
Wrseq '},' Using [O_ED]

Filter [AS_T] Where LANCHP=7982 and LANNUM>0 and LAN=TLAN(I)
Wrseq '"misc": {' Using [O_ED]
VALLM1=""
For [AS_T]
  VALLM=[F:AS_T]LANMES
  Gosub MVALC1 From INTRUTILA 
  If VALLM1<>"" : Wrseq VALLM1+',' Using [O_ED] : Endif
  VALLM1='"'+num$([F:AS_T]LANNUM)+'":"'+VALLM+'"' 
Next
Filter [AS_T]
If VALLM1<>"" : Wrseq VALLM1 Using [O_ED] : Endif
Wrseq '}' Using [O_ED]

Wrseq '}' Using [O_ED]
Return




