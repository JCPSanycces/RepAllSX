#Subprog XGEMPLACAM(VALEUR)
Subprog GENHRLOCAM(VALEUR)
Variable Integer    VALEUR()

  Raz  [M]DATFIL
  If VALEUR=1
   Call SET_NAMCLI([M]DATFIL) From ORDSYS
   Grizo [M]DATFIL
  Else
   [M]DATFIL = filpath("tmp","","",nomap,"","")
   Actzo [M]DATFIL
  Endif
  Affzo [M]DATFIL

End

