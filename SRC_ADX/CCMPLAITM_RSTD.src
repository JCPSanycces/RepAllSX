#<AdxTL>@(#)0.0.0.0 $Revision$
# Class CCMPLAITM_CCMIMPITMDET

$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
        When "AREAD_AFTER"
          Gosub GET_CHANGE_REQUEST_DETAILS # Change request details
          Gosub ACTIVATE_FIELDS
        When "AUPDATE_CONTROL_AFTER"
          Gosub ASSIGN_TO_ALL_LINES
      Endcase
Endcase

Return

# Using CRID, get change request details
$GET_CHANGE_REQUEST_DETAILS
  Local Instance SELCHGREQ Using C_CCMCHGREQ
  SELCHGREQ = NewInstance C_CCMCHGREQ AllocGroup null
  ASTATUS = fmet SELCHGREQ.AREAD(this.CCMIITM.CRID)
  If  ASTATUS<>[V]CST_AOK
    ASTATUS = fmet  this.ASETERROR ("", "", [V]CST_AERROR)
  Else
    this.PRODUCT = SELCHGREQ.PRODUCT
    this.ECCVALMAJ   = SELCHGREQ.ECCVALMAJ
    this.ECCVALMIN   = SELCHGREQ.ECCVALMIN
    this.CRSTATUS = SELCHGREQ.CRSTATUS
    this.CCMUSRID = SELCHGREQ.CCMUSRID
    this.PLANNER = SELCHGREQ.PLANNER
  Endif
  FreeGroup SELCHGREQ
Return

# --------------------------------------------------
# Enable / disable fields at a class level.
$ACTIVATE_FIELDS

  Local Integer LOCAL_ASTATUS

  If (this.CCMIITM.ITMPLASTA = 3) or
&    (this.CCMIITM.ITMPLASTA = 4 and this.CCMIITM.TOTALLINES = 0)
    LOCAL_ASTATUS = fmet this.CCMIITM.ASETATTRIBUTE("IMPLEMENT", "$isHidden", "true")
  Elsif (this.ACTX.USER = this.PLANNER)
    LOCAL_ASTATUS = fmet this.CCMIITM.ASETATTRIBUTE("IMPLEMENT", "$isHidden", "false")
    LOCAL_ASTATUS = fmet this.CCMIITM.ASETATTRIBUTE("IMPLEMENT", "$isDisabled", "false")
  Else
    LOCAL_ASTATUS = fmet this.CCMIITM.ASETATTRIBUTE("IMPLEMENT",   "$isHidden", "true")
  Endif

  If (this.ACTX.USER = this.PLANNER and this.CCMIITM.IMPLEMENT = 1)
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("DEFACTIONID", "$isHidden",   "false")
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("DEFCOMPDATE", "$isHidden",   "false")
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("DEFACTIONER", "$isHidden",   "false")
  Else

    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("DEFACTIONID", "$isHidden",   "true")
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("DEFCOMPDATE", "$isHidden",   "true")
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("DEFACTIONER", "$isHidden",   "true")
  Endif

  # Disable all other read-only properties ...
  LOCAL_ASTATUS = fmet this.CCMIITM.ASETATTRIBUTE("CRID",      "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.CCMIITM.ASETATTRIBUTE("ITMPLASTA", "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.CCMIITM.ASETATTRIBUTE("UPDDATTIM", "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.CCMIITM.ASETATTRIBUTE("UPDUSR",    "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("CRSTATUS",          "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("PRODUCT",           "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("ECCVALMAJ",         "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("ECCVALMIN",         "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("CCMUSRID",          "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("PLANNER",           "$isDisabled", "true")

  # if Change request Closed or not allowed to amend, then disable edit link
  If (this.PLANNER <> this.ACTX.USER or (this.CRSTATUS <> 4 and this.CRSTATUS <> 5))
    LOCAL_ASTATUS = fmet this.ASETLINKDISABLE("AEDIT",[V]CST_AFFLNKREC)
  Endif

Return


# --------------------------------------------------
# Assign default ACTIONID, ACTIONER and COMPleteByDATE to all detail records ...
$ASSIGN_TO_ALL_LINES

  Local File CCMIMPITMDET [CCMITMD]

  If (this.DEFACTIONID <> "")

    If (this.DEFACTIONER = "" or
&       this.DEFCOMPDATE = AVOID.ADATE)
      ASTATUS = fmet this.ASETERROR("", mess(64,2038,1), CST_AERROR)
    Else

      Update [CCMITMD] Where CRID = this.CCMIITM.CRID With
&       ACTIONID = this.DEFACTIONID,
&       ACTIONER = this.DEFACTIONER,
&       COMPLETEDATE = this.DEFCOMPDATE

      # Set action lines to total lines and update status
      LOCAL_ASTATUS = fmet this.CCMIITM.UPDATE_STATUS()

    Endif

  Endif

  LogicClose File [CCMITMD]

Return

$PROPERTIES
  Case CURPRO
  Endcase
Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

