#<AdxTL>@(#)5.0.0.0 $Revision$
########################################################################
# Traitement TRTSTOSERE - Saisie des numéros de série à sortir    V140 #
#                         Dans le cas où ceux-ci sont gérés en E/S     #
########################################################################
# Action SAISTOSERE
#    Paramètres     - LABR    Abréviation masque : "SOR" ou "SOM"
#                   - LNOL    No ligne écran (nolign-1)
#
########################################################################
$ACTION

Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "AVANT_ENR"     : Gosub AVANT_ENR
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "FINSAI"        : Gosub FINSAI
Endcase

Return

#########################################################################
$OUVRE
Local Char    LABR            : # Abréviation masque origine
Local Integer LNOL            : # No ligne courante (nolign-1) masque origine
Local Integer I, OK
Local Decimal WDISPO

If clalev([F:STS])=0  Local File STOSER [STS]  Endif
If clalev([M:SSE1])=0  Local Mask STOSERE [SSE1]  Endif            # hcb 117083

# Récupération des paramètres
LABR    = PARAM(1)
LNOL    = val(PARAM(2))

Return

#########################################################################
$DEBUT

Effzo [M:SSE]10

[M:SSE]LABR   = LABR
[M:SSE]STOFCY = evalue("[M:"+LABR+"]STOFCY")
[M:SSE]ITMREF = evalue("[M:"+LABR+"]ITMREF")
[M:SSE]STU    = evalue("[M:"+LABR+"]STU")
[M:SSE]QTY    = evalue("[M:"+LABR+"]SORQTYACT")-evalue("[M:"+LABR+"]PECQTYACT")
&                                              -evalue("[M:"+LABR+"]SHTQTY")
[M:SSE]NBLIG  = 0

Affzo [M:SSE]1-99

Return

#########################################################################
$SETBOUT

If !find("A",CHBOU) CHBOU+="A" Endif
If !find("E",CHBOU) CHBOU+="E" Endif

Return

#########################################################################
$AVANT_ENR

If [M:SSE]NBLIG=0 |
& ([M:SSE]NBLIG<>0 & sigma(I=0,[M:SSE]NBLIG-1,[M:SSE]QTYSTU(I))>[M:SSE]QTY)
   # Le nb de no série ne correspond pas à la qté à traiter
   GMESSAGE = mess(246,199,1)
   GERR=1 : FOK=0 : Return
Endif

If [M:SSE]NBLIG>1
      Raz [M:SSE1]                    # hcb 117083
      Transmask [M:SSE] To [M:SSE1]# Issue 25606 [M:SSE1] = [M:SSE]              # hcb 117083
   # Vérification que les plages de no série sont bien croissantes
   Sorta [M:SSE1]NBLIG [M:SSE1]NBLIG Order By [M:SSE1]SERNUM([S]indice)    # hcb 117083
   For I=1 To [M:SSE1]NBLIG-1                                              # hcb 117083
      If [M:SSE1]SERNUM(I) <= [M:SSE1]SERNUMF(I-1)                         # hcb 117083
         GMESSAGE = mess(464,199,1)
         GERR=1 : FOK=0 : Break
      Endif
   Next I
Endif

Return

#########################################################################
$ENR
Local Integer WNBLIG, WRET
Local Char    WSERNUM(GLONSER), WNUMERO(GLONSER)
Local Decimal WPECQTY, WPECQTYACT

WPECQTY    = [M:SOR]PECQTY
WPECQTYACT = [M:SOR]PECQTYACT

# Contrôle de l'insertion
#--- Issue 110327
#WNBLIG = sum([M:SSE]QTYSTU(0..[M:SSE]NBLIG-1))
If [M:SOR]SERMGTCOD=4
  WNBLIG = [M:SSE]NBLIG
Else
  WNBLIG = sum([M:SSE]QTYSTU(0..[M:SSE]NBLIG-1))
Endif
#---
If [M:SOR]NBLIG+WNBLIG >= dim([M:SOR]STA)-1
   FOK=0 : GERR=1
   GMESSAGE=mess(122,199,1)
   Return
Endif

# Ouverture des n lignes
nolign = [M:SOR]NBLIG
Insa nolign,WNBLIG,[M:SOR]NBLIG [M:SOR]NBLIG
nolign = [M:SOR]NBLIG
status = 0

[M:SOR]NBLIG += WNBLIG

# Boucle sur les séquences de no série saisies
For I=0 To [M:SSE]NBLIG-1
   WSERNUM  = ""
   WNUMERO  = [M:SSE]SERNUM(I)
   #--- Issue 110327
   If [F:ITM]SERMGTCOD=4
      WSERNUM = WNUMERO
      Read [F:STO]STO0=[M:SSE]STOFCY;[M:SSE]STOCOU(I)
      If fstat
         FOK=0 : GERR=1
         GMESSAGE=WSERNUM-":"-mess(305,199,1)
         Break
      Endif
      # Alimentation de la ligne de sortie (dans STOSOR)
      Gosub ALI_STOSOR
   Elsif [F:ITM]SERMGTCOD=3
   #--- End issue 110327
      # Traitement d'une séquence de numéro
      While WSERNUM<>[M:SSE]SERNUMF(I)
         WSERNUM = WNUMERO
         Read [STO]STO5=[M:SSE]ITMREF;WSERNUM
         If fstat
            FOK=0 : GERR=1
            GMESSAGE=WSERNUM-":"-mess(305,199,1)
            Break 2
         Endif
         # Alimentation de la ligne de sortie (dans STOSOR)
         Gosub ALI_STOSOR
         # Numéro suivant
         Call PLUS_UN(WSERNUM,WNUMERO,WRET) From STKLIB
         If WRET<>0
            FOK=0 : GERR=1
            GMESSAGE=WSERNUM-":"-mess(476,197,1)
            Break 2
         Endif
      Wend
      #--- Issue 110327
   Endif
   #---
Next I

If FOK=0
   Dela [M:SOR]NBLIG-WNBLIG,WNBLIG [M:SOR]NBLIG
   [M:SOR]NBLIG     -= WNBLIG
   [M:SOR]PECQTY     = WPECQTY
   [M:SOR]PECQTYACT  = WPECQTYACT
   Return
Endif

Affzo [M:SOR]1-99

# Pour forcer le raffraichissement du picking
GSAISERIE=1
mkstat=4
FIN=1

Return

#########################################################################
$ABA

Gosub DEBUT

Return

#########################################################################
$FINSAI

Return

###########################################################################
$ALI_STOSOR

nolign += 1
NOL = nolign-1

[M:SOR]ICOMVTATT(NOL)  = ""

#--- Issue 110327
If [F:ITM]SERMGTCOD=4
   [M:SOR]QTYSTU(NOL)     = [M:SSE]QTYSTU(I)
   [M:SOR]QTYSTUACT(NOL)  = [M:SSE]QTYSTU(I)
Else
#---
   [M:SOR]QTYSTU(NOL)     = 1
   [M:SOR]QTYSTUACT(NOL)  = 1
#--- Issue 110327
Endif
#---

[M:SOR]XPCU(NOL)       = [F:STO]PCU
[M:SOR]XPCUSTUCOE(NOL) = [F:STO]PCUSTUCOE

If [M:SOR]XPCUSTUCOE(NOL)=0 [M:SOR]XPCUSTUCOE(NOL)=1 Endif
[M:SOR]QTYPCU(NOL) = [M:SOR]QTYSTU(NOL)/[M:SOR]XPCUSTUCOE(NOL)
Call QTEARR([M:SOR]QTYPCU(NOL),[M:SOR]XPCU(NOL)) From TRTDIV

#--- Issue 110327
If [F:ITM]SERMGTCOD=4
   # Contrôle du disponible pour sortie sur la ligne de stock
   Call STODISSOR("[F:STO]","[F:ITM]","",[M:SOR]AVAQTYPCU(NOL),[M:SOR]AVAQTYSTU(NOL),[M:SOR]AVAQTYSTU(NOL)) From STKLIB
Else
#---
   [M:SOR]AVAQTYPCU(NOL)  = 1
   [M:SOR]AVAQTYSTU(NOL)  = 1
#--- Issue 110327
Endif
#---

[M:SOR]TOTQTYSTU(NOL)  = [F:STO]QTYSTU

If dim([M:SOR]LOT)>0     [M:SOR]LOT(NOL)    = [F:STO]LOT    Endif
If dim([M:SOR]SLO)>0     [M:SOR]SLO(NOL)    = [F:STO]SLO    Endif
If dim([M:SOR]LOC)>0     [M:SOR]LOC(NOL)    = [F:STO]LOC    Endif
#--- Issue 110327
If [F:ITM]SERMGTCOD=4
   If dim([M:SOR]SERNUM) >0 [M:SOR]SERNUM(NOL) = [M:SSE]SERNUM(I)  Endif
   If dim([M:SOR]SERNUMF)>0 [M:SOR]SERNUMF(NOL)= [M:SSE]SERNUMF(I) Endif
Else
#---
   If dim([M:SOR]SERNUM) >0 [M:SOR]SERNUM(NOL) = [F:STO]SERNUM Endif
   If dim([M:SOR]SERNUMF)>0 [M:SOR]SERNUMF(NOL)= [F:STO]SERNUM Endif
#--- Issue 110327
Endif
#---

[M:SOR]SERNUMFLG(NOL)  = 1
[M:SOR]STA(NOL)        = [F:STO]STA
If dim([M:SOR]SHLDAT) >0 [M:SOR]SHLDAT(NOL) = [F:STL]SHLDAT Endif

[M:SOR]STOCOU(NOL)     = [F:STO]STOCOU

[M:SOR]PECQTY         += [M:SOR]QTYSTU(NOL)
[M:SOR]PECQTYACT      += [M:SOR]QTYSTUACT(NOL)

If dim([M:SOR]LOT)>0    Diszo [M:SOR]LOT(NOL)    Endif
If dim([M:SOR]SLO)>0    Diszo [M:SOR]SLO(NOL)    Endif
If dim([M:SOR]LOC)>0    Diszo [M:SOR]LOC(NOL)    Endif

Diszo [M:SOR]QTYSTU(NOL)
Diszo [M:SOR]QTYPCU(NOL)
If dim([M:SOR]SERNUM)>0 Diszo [M:SOR]SERNUM(NOL) Endif
Diszo [M:SOR]STA(NOL)
Affzo [M:SOR]STA(NOL)

Return

###########################################################################
Subprog C_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL

NOL=nolign-1

# Le nb de no série ne correspond pas à la qté à traiter
If sum([M:SSE]QTYSTU(0..[M:SSE]NBLIG-1))-[M:SSE]QTYSTU(NOL)+VALEUR > [M:SSE]QTY
   GMESSAGE = mess(246,199,1)
   mkstat=2 : End
Endif

End

##########################################################################
Subprog AM_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL, WRET, WNBSER
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer LTYPLOC, LSTA
Local    Decimal WPCUDIS, WSTUDIS, WSTUACTDIS, WTOTACTDIS, WDISPO

NOL=nolign-1

# Si la quantité était nulle
#If [M:SSE]QTYSTU(NOL)=0 End Endif
# Il n'y a pas encore de no série saisi
If [M:SSE]SERNUM(NOL)="" End Endif

# La quantité a diminué
If VALEUR < [M:SSE]QTYSTU(NOL)
   If [M:SSE]SERNUM(NOL)<>""             : #--- Issue 110327   WNBSER  = VALEUR
      WNUMDEB = [M:SSE]SERNUM(NOL)
      If WNBSER=1
         [M:SSE]SERNUMF(NOL) = WNUMDEB
      Else
         Call PLUS_NB(WNUMDEB,WNBSER,WNUMFIN,WRET) From STKLIB
         If WRET=0
            [M:SSE]SERNUMF(NOL) = WNUMFIN
         Else
            mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : End
         Endif
      Endif
      Affzo [M:SSE]SERNUM(NOL), SERNUMF(NOL)
   Endif                                 : #--- Issue 110327
   End
Endif

If [M:SSE]LABR="SOR"
   # La quantité a augmenté
   If VALEUR > [M:SSE]QTYSTU(NOL)
      # Vérification que les no série existent et sont disponibles
      # pour le surplus et alimentation du no série fin
      WNBSER  = VALEUR-[M:SSE]QTYSTU(NOL)
      WNUMDEB = [M:SSE]SERNUMF(NOL)
      For J=1 To WNBSER
         Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
         If WRET=0
            Read [STS]STS0=[M:SSE]ITMREF;WNUMFIN
            If !fstat
               #--- Issue 110327
               If [F:ITM]SERMGTCOD=4
                 If [F:STS]STOCOU<>[M:SSE]STOCOU(NOL)
                   mkstat=2 : GMESSAGE=mess(444,184,1) : Break
                 Elsif [F:STS]ISSDAT<>[0/0/0]
                   mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(37,184,1) : Break
                 Elsif [F:STS]SDHNUM<>"" & !find([F:STS]SDHNUM,[M:SOR]VCRNUM,[M:SOR]VCRNUMORI)
                   mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(443,184,1) : Break
                 Endif
                 #--- No série en cours de traitement?
                 If func STKLIB.REC_STOSERW([M:SSE]ITMREF,WNUMFIN)<>0
                   mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(449,184,1) : Break
                 Endif
               Else
                 Gosub VERIF_STOCK
               Endif
               #Gosub VERIF_STOCK
               #--- End issue 110327
               If mkstat=2 Break Endif
               WNUMDEB = WNUMFIN
            Else
               GMESSAGE=WNUMFIN-":"-mess(43,196,1)
               mkstat=2 : Break
            Endif
         Else
            GMESSAGE=WNUMDEB-":"-mess(476,197,1)
            mkstat=2 : Break
         Endif
      Next J
      If mkstat=2 End Endif
      #--- Issue 110327
      If [F:ITM]SERMGTCOD=4
         Gosub VERIF_STOCK
         If mkstat=2 End Endif
      Endif
      #---
      [M:SSE]SERNUMF(NOL) = WNUMFIN
      Affzo [M:SSE]SERNUM(NOL), SERNUMF(NOL)
      End
   Endif
Endif

End

##########################################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL, J, WRET, WNBSERIE
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer LTYPLOC, LSTA
Local    Decimal WPCUDIS, WSTUDIS, WSTUACTDIS, WTOTACTDIS, WDISPO

NOL = nolign-1

If [M:SSE]LABR="SOR"
   Read [STS]STS0=[M:SSE]ITMREF;VALEUR
   If !fstat
      WNUMDEB = VALEUR
      WNUMFIN = VALEUR
      #--- Issue 110327
      If [F:ITM]SERMGTCOD=4
        If [F:STS]ISSDAT<>[0/0/0]
           mkstat=2 : GMESSAGE=VALEUR-":"-mess(37,184,1) : End
        Elsif [F:STS]SDHNUM<>"" & !find([F:STS]SDHNUM,[M:SOR]VCRNUM,[M:SOR]VCRNUMORI)
           mkstat=2 : GMESSAGE=VALEUR-":"-mess(443,184,1) : End
        Endif
        #--- No série en cours de traitement?
        If func STKLIB.REC_STOSERW([M:SSE]ITMREF,VALEUR)<>0
           mkstat=2 : GMESSAGE=VALEUR-":"-mess(449,184,1) : End
        Endif
        [M:SSE]STOCOU(NOL)=[F:STS]STOCOU
        If [M:SSE]QTYSTU(NOL)=1 Gosub VERIF_STOCK Endif
      Else
        Gosub VERIF_STOCK
      Endif
      #Gosub VERIF_STOCK
      #--- End issue 110327
      If mkstat=2 End Endif
   Else
      GMESSAGE=WNUMFIN-":"-mess(43,196,1)
      mkstat=2 : End
   Endif

   If [M:SSE]QTYSTU(NOL)=0
      If NOL=0
         [M:SSE]QTYSTU(NOL) = [M:SSE]QTY
      Else
         [M:SSE]QTYSTU(NOL) = [M:SSE]QTY-sigma(I=0,NOL-1,[M:SSE]QTYSTU(I))
      Endif
   Endif

   If [M:SSE]QTYSTU(NOL)=1
      [M:SSE]SERNUMF(NOL) = VALEUR
   Else
      # Vérification que les no série existent et sont disponibles
      # et alimentation du no série fin
      WNBSERIE = [M:SSE]QTYSTU(NOL)
      WNUMDEB  = VALEUR
      For J=2 To WNBSERIE
         Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
         If WRET=0
            Read [STS]STS0=[M:SSE]ITMREF;WNUMFIN
            If !fstat
               #--- Issue 110327
               If [F:ITM]SERMGTCOD=4
                 If [F:STS]STOCOU<>[M:SSE]STOCOU(NOL)
                   mkstat=2 : GMESSAGE=mess(444,184,1) : Break
                 Elsif [F:STS]ISSDAT<>[0/0/0]
                   mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(37,184,1) : Break
                 Elsif [F:STS]SDHNUM<>"" & !find([F:STS]SDHNUM,[M:SOR]VCRNUM,[M:SOR]VCRNUMORI)
                   mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(443,184,1) : Break
                 Endif
                 #--- No série en cours de traitement?
                 If func STKLIB.REC_STOSERW([M:SSE]ITMREF,WNUMFIN)<>0
                   mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(449,184,1) : Break
                 Endif
               Else
                 Gosub VERIF_STOCK
               Endif
               #Gosub VERIF_STOCK
               #--- End issue 110327
               If mkstat=2 Break Endif
               WNUMDEB = WNUMFIN
            Else
               GMESSAGE=WNUMFIN-":"-mess(43,196,1)
               mkstat=2 : Break
            Endif
         Else
            GMESSAGE=WNUMDEB-":"-mess(476,197,1)
            mkstat=2 : Break
         Endif
      Next J
      If mkstat=2 End Endif
      #--- Issue 110327
      If [F:ITM]SERMGTCOD=4
         Gosub VERIF_STOCK
         If mkstat=2 End Endif
      Endif
      #---
      [M:SSE]SERNUMF(NOL) = WNUMFIN
   Endif
   Affzo [M:SSE]SERNUMF(NOL)
   End
Endif

End

##########################################################################
# La ligne de stock est-elle sortable ?                                  #
##########################################################################
$VERIF_STOCK

#--- Issue 110327
Local Integer K, L
Local Decimal WQTY, WSTOCOU
#---

If [M:SOR]NBLIG>0
   # No série déjà sélectionné
   If find(WNUMFIN,[M:SOR]SERNUM(0..[M:SOR]NBLIG-1))
      GMESSAGE=WNUMFIN-":"-mess(194,184,1)
      mkstat=2 : Return
   Endif
Endif

#--- Issue 110327
If [F:ITM]SERMGTCOD=4
   Read [STO]STO0=[M:SSE]STOFCY;[M:SSE]STOCOU(NOL)
Else
   Read [STO]STO5=[M:SSE]ITMREF;WNUMFIN
Endif
#Read [STO]STO5=[M:SSE]ITMREF;WNUMFIN
#---
If fstat
   GMESSAGE=WNUMFIN-":"-mess(305,199,1)
   mkstat=2 : Return
Endif
Read [STL]STL0=[M:SOR]ITMREF;[F:STO]LOT;[F:STO]SLO
If fstat
   Call RSTA ("STL",[M:SOR]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
   mkstat=2 : Return
Endif

#--- Issue 110327
Raz K, L
If [F:ITM]SERMGTCOD=4
   # La ligne de stock est-elle déjà dans le tableau [M:SOR]
   If [M:SOR]NBLIG <> 0
      K = find([F:STO]STOCOU,[M:SOR]STOCOU(L..[M:SOR]NBLIG-1))
   Endif
Endif
# Les contrôles sur la ligne de stock ne sont à faire que celle-ci
# n'est pas déjà dans le tableau [M:SOR]
If K<=0
#--- End issue 110327
   If [F:STO]LOCCAT=2
      Raz WRET
      # Contrôle que la ligne de stock en attente de rangement est complète
      Call CTLPLFLOC([M:SOR]ITMREF,"",WRET) From STKSOR
      If WRET<>0
         GMESSAGE =WNUMFIN-":"-mess(378,199,1)+"\"+mess(377,199,1)-": "
         Case WRET
          When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
          When 2 : GMESSAGE+=mess(453,197,1)
          When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
         Endcase
         mkstat=2 : Return
      Endif
   Endif

   # Ligne de stock faisant l'objet d'une demande d'analyse
   If [M:SOR]PECQLYCTL<>2 & [F:STO]QLYCTLDEM<>""
      GMESSAGE=WNUMFIN-":"-mess(460,199,1)
      mkstat=2 : Return
   Endif

   # Si non administrateur stock, contrôle ligne pickée par rapport
   # à la péremption et à la règle de gestion
   If GSTOADMIN<>2
      If string$(evalue(GCRITPIC),"OK")<>"OK"
         GMESSAGE=WNUMFIN-":"-mess(366,199,1)
         mkstat=2 : Return
      Endif
   Endif

   # Calcul du stock disponible sur l'article
   Raz LTYPLOC, LSTA
   If [M:SOR]PECPLFLOC=2 LTYPLOC+=1 Endif
   If [M:SOR]PECSCOLOC=2 LTYPLOC+=4 Endif
   # Si pas d'emplacements internes
   If [M:SOR]PECINTLOC=1 LTYPLOC=LTYPLOC*(-1) Endif
   If [M:SOR]AAASTA=2    LSTA   +=1 Endif
   If [M:SOR]QQQSTA=2    LSTA   +=2 Endif
   If [M:SOR]RRRSTA=2    LSTA   +=4 Endif
   Call STODISTOT("[F:ITV]",LTYPLOC,LSTA,[M:SOR]PECOWNER,WTOTACTDIS) From STKLIB

   #--- Issue 116826
   # On retire la somme des quantités saisies
   WTOTACTDIS -= sum([M:SOR]QTYSTUACT)
   # On rajoute l'allouée global
   WTOTACTDIS += [M:SOR]GLOALLQTY

   If [M:SOR]VCRTYPORI<>0 & [M:SOR]VCRNUMORI<>"" & [M:SOR]VCRLINORI<>0
      # Ajout stock alloué sur la pièce origine si création
      For [STA]STA1 Where VCRTYP=[M:SOR]VCRTYPORI & VCRNUM=[M:SOR]VCRNUMORI &
&                         VCRLIN=[M:SOR]VCRLINORI & VCRSEQ=[M:SOR]VCRSEQORI
         WTOTACTDIS += [F:STA]QTYSTUACT
      Next
   Else
      # Ajout stock alloué sur la pièce
      For [STA]STA1 Where VCRTYP=[M:SOR]VCRTYP & VCRNUM=[M:SOR]VCRNUM &
&                         VCRLIN=[M:SOR]VCRLIN & VCRSEQ=0 & ALLTYP=2
         WTOTACTDIS += [F:STA]QTYSTUACT
      Next
   Endif
   #---

   # Contrôle du disponible pour sortie sur la ligne de stock
   Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB

   # Disponible = min(dispo ligne stock, dispo article)
   WDISPO = min(WSTUACTDIS,WTOTACTDIS)

   # Pas de stock disponible
   If WDISPO<=0
      GMESSAGE =mess(367,199,1)
      If GWIPSTOLCK=2 & [F:STO]LOCCAT=2
         # La qté en attente de rangement est peut être dans une liste à ranger
         GMESSAGE += "\"+mess(150,184,1)
      Endif
      mkstat=2 : Return
   Endif
#--- Issue 110327
Else
   # Contrôle du disponible de la ligne de stock
   # cette ligne de stock peut être présente plusieurs fois dans le tableau
   WSTOCOU=[M:SOR]STOCOU(K-1)
   WQTY=sigma(L=0,[M:SOR]NBLIG-1,([M:SOR]QTYSTU(L)-[M:SOR]QTYSTUORI(L))*([M:SOR]STOCOU(L)=WSTOCOU))
   WQTY+=[M:SSE]QTYSTU(NOL)
   If WQTY>[M:SOR]AVAQTYSTU(K-1)
      GMESSAGE=mess(446,196,1)
      mkstat=2 : Return
   Endif
Endif
#--- End issue 110327

Return

