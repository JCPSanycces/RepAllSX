#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
 When "AP_IMPORT" : Gosub INICOURS
Endcase
Return

$INICOURS
If [F:TCH]CHGDIV=0
 [F:TCH]CHGDIV = 1
Endif
If [F:TCH]CHGTYP<1
 [F:TCH]CHGTYP = 1
Elsif [F:TCH]CHGTYP>len(mess(0,202,1))
 [F:TCH]CHGTYP = len(mess(0,202,1))
Endif
If [F:TCH]REVCOURS=0 & [F:TCH]CHGRAT<>0
 [F:TCH]REVCOURS = arr([F:TCH]CHGDIV/[F:TCH]CHGRAT,10^-GDECRCU)
Elsif [F:TCH]CHGRAT=0 & [F:TCH]REVCOURS<>0
 [F:TCH]CHGRAT = arr([F:TCH]CHGDIV/[F:TCH]REVCOURS,10^-GDECRCU)
Endif
Return
