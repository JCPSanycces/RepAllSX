#<AdxTL>@(#)0.0.0.0 $Revision$
#------------------------------------------------------------------------------------------
#                Clôture Budgétaire des budgets analytiques
#------------------------------------------------------------------------------------------
#  Fonction : CMMREP - Report de pré-engagements et engagements non soldés
#  Action   : CMMREP
#  Fenêtre/Window  : CMMREP
#  Ecran concerné/Mask : CMMREP [M:CMMR]
#  Description :
#  *1-Report -> Aprés cloture des DA et Commande, report des pré-engagement et engagements
#------------------------------------------------------------------------------------------

Call TRAITE_CHAR(VALEUR,PARAM,"","CMMREP","TRTCMMREP",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "AVANT_PAR"   : Gosub AVANT_PAR
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
Endcase
Return

$AVANT_PAR
Raz [M:CMMR]
Return

$INIT
# Tables utiles
If !clalev([BUA])  : Local File BUDPURAUD  [BUA]  : Endif
If !clalev([BUP])  : Local File BUDPAR     [BUP]  : Endif
If !clalev([BUD])  : Local File BUD        [BUD]  : Endif
If !clalev([CCE])  : Local File CACCE      [CCE]  : Endif
If !clalev([GCM])  : Local File GACM       [GCM]  : Endif
If !clalev([LED])  : Local File GLED       [LED]  : Endif
If !clalev([CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([FIY])  : Local File FISCALYEAR [FIY]  : Endif
If !clalev([FIY2]) : Local File FISCALYEAR [FIY2] : Endif

If !clalev([F:CMM]) : Local File GCOMMIT  [CMM] : Endif
If !clalev([F:CMD]) : Local File GCOMMITD [CMD] : Endif

# Achats
If !clalev([PIH]) : Local File PINVOICE   [PIH] : Endif
If !clalev([PID]) : Local File PINVOICED  [PID] : Endif
If !clalev([PSH]) : Local File PREQUIS    [PSH] : Endif
If !clalev([PSD]) : Local File PREQUISD   [PSD] : Endif
If !clalev([POH]) : Local File PORDER     [POH] : Endif
If !clalev([POP]) : Local File PORDERP    [POP] : Endif
If !clalev([POQ]) : Local File PORDERQ    [POQ] : Endif
If !clalev([CAL]) : Local File CPTANALIN  [CAL] : Endif

# Masque
Local Mask CMMREP [CMMR]

# Variables Locales
Local Char CRITBUA(250), CRITLIG(250), MESSA(250)
Local Char SITE(GLONFCY), TABLE(GLONABR)
Local Decimal EXERCICE,PERIODE
Local Integer I, J, E, STAT, OK
I=0 : OK=1
Local Integer NCCE1,NCCE2,NCCE3,NCCE4,NCCE5,NCCE6,NCCE7,NCCE8,NCCE9

# Pour le Call MAJENG()
Local Char CODLED, DEVLED
Local Char DOCUMENT(GLONVCR)(1..3)  #18 (1)n° de la pièce d'origine (2)n° de ligne de la pièce d'origine (3)n° de séquence pour les commandes
Local Libelle MOTIF(1..2)       #19 (1)Motif Action AML-2683  (2) Motif Pièce AML-2684
Local Char PIECE
Local Char IDENT(GLONVCR)(1..3)
Local Integer SENS, SIGN
Local Char    COMPTE
Local Char    TIERS
Local Char    TYPPCE
Local Integer TYPORG
Local Char    NUMPCE
Local Integer TYPCUR
Local Char TBACC(GLONGAC)(1..10)
Local Char TBLED(GLONLED)(1..10)
Local Decimal RATDIV(1..10) : RATDIV(1)=0
Local Decimal RATMLT(1..10) : RATMLT(1)=0
Local Char TBDIE(GLONDIE)(1..func AFNC.ACTIV("ANA"))
Local Char TBCCE(GLONCCE)(1..func AFNC.ACTIV("ANA"))
Local Integer NBTB : NBTB=0
Local Integer CONTBUD : CONTBUD=0

Local Integer DEBUGTRACE
[L]DEBUGTRACE=[V]CST_AFALSE

Return

$CONTROLE
TMP=1
Return

$EXEC
# Trace/Tracking
If [M]TRC=2
 Local Integer TRCREP
 TRCREP=0
 # Report des pré-engagements et engagements non soldés
 Call OUVRE_TRACE(mess(210,107,1)) From LECFIC
Endif

Gosub LOAD_FILTRE
Gosub DECLARE_GLOBAL From SUBCMM


# Report des budgets
For I=0 To [M]NBLIG-1
 If [M]REPOR(I)=2
  Call DEBTRANS From GLOCK
  Gosub REPORTCMM
 Endif
Next

#If [M]TRC=2
# If !TRCREP
#  # Rien n'a été reporté
#  Call ECR_TRACE(mess(205,108,1),0) From GESECRAN
# Endif
# Call ECR_TRACE("---------------------------------------------",0) From GESECRAN
#Endif
Return

$LOAD_FILTRE
#--------- Critère sur table d'audit ---------#
CRITBUA ='CPY="'+[M]CPY+'" & FIY='+num$([M]EFIY)
CRITBUA -='& (CMMPRP>0 | CMM>0) & BUD=""'
CRITBUA -='& POSTPONED<>2'
#
If [M]FCYSTR<>""
CRITBUA -='& FCY>="'+[M]FCYSTR+'" & FCY<="'+[M]FCYEND+'"'
Endif
#
Case [M]TYPDOC
 When 2 : CRITBUA -= '& TYP=1'
 When 3 : CRITBUA -= '& TYP=2'
Endcase
Return

$REPORTCMM
OK=1

If [M]TRC=2
 Call ECR_TRACE(string$(40,"#"),0) From  GESECRAN
 Call ECR_TRACE(mess([M]TYP(I),2684,1)-":"-[M]NUM(I),0) From GESECRAN
 Call ECR_TRACE(mess(50,104,1)-"=>"-num$([M]AMTREP(I)),0) From GESECRAN
 Call ECR_TRACE(string$(40,"-"),0) From  GESECRAN
Endif

# --- Affectation des variable pour les Call MAJENG(...) From CPTENG --- #
Call LECLED([M]CPY,[M]LEDTYP(I),CODLED,DEVLED) From CPTDIV
DOCUMENT(1)=[M]NUM(I)
DOCUMENT(2)=num$([M]LIN(I))
DOCUMENT(3)=num$([M]SEQ(I))
If [L]DEBUGTRACE : Call ECR_TRACE("Document"-DOCUMENT,0) From  GESECRAN : Endif
COMPTE = [M]ACC(I)
#PIECE = [M]CODGAU(I)
For J=1 To 3
 IDENT(J) = DOCUMENT(J)
Next
Call LECTURE("CMM",[M]CMM(I),"") From CONTOBJ
SENS   = [F:CMM]SNS
TIERS  = [F:CMM]BPR
TYPPCE = [F:CMM]TYPREF
TYPORG = [F:CMM]TYPORG
NUMPCE = [F:CMM]NUMREF
TYPCUR = [F:CMM]TYPCUR
# ---------------------------------------------------------------------- #
#Pour la mise à jour des engagements (multi-ref), je suis obligé de repartir des
#infos de la ligne d'achat. J'utilise  CPTANALIN
Case [M]TYP(I)
 When 1 :#Demande d'achat
  TABLE = "PSD"
 When 2 :#Commande
  TABLE = "POP"
Endcase
#ABRFIC+VCRTYP+VCRNUM+VCRLIN+VCRSEQ+CPLCLE+ANALIG
Read [CAL]CAL0=TABLE;0;NUM(I);LIN(I);SEQ(I);""
If !fstat
 For J=1 To dim([F:CAL]ACC)
  [L]TBLED(J)=[F:CAL]LED(J-1)
  [L]TBACC(J)=[F:CAL]ACC(J-1)
 Next
 For J=1 To dim([F:CAL]DIE)
  [L]TBDIE(J)=[F:CAL]DIE(J-1)
  [L]TBCCE(J)=[F:CAL]CCE(J-1)
  NBTB=J
 Next

 #Contrôle que Sections Actives
 For E=1 To NBTB
  Read [CCE]CCE0 = [L]TBDIE(E);[L]TBCCE(E)
  If !fstat
   If !([M]DRFIY>=[F:CCE]VLYSTR & ([F:CCE]VLYEND=[0/0/0] | [M]DRFIY<=[F:CCE]VLYEND))
    # Section CCE (DIE) Hors limite des dates de validité, modifier la date de fin de section pour permettre le report
    Call ECR_TRACE(mess(17,103,1)-[L]TBCCE(E)-"("+[L]TBDIE(E)+")"-mess(13,104,1)+","-mess(268,108,1),1) From GESECRAN
    OK=0 : Break
   Endif
  Endif
 Next E
 If !OK
  Return
 Endif
#
Else
 If [M]TRC=2
  # Problème de lecture de la pièce d'achat
  Call ECR_TRACE(mess(255,108,1)-"=>"-mess([M]TYP(I),2684,1)-[M]NUM(I),0) From GESECRAN
 Else
  Call MESSAGE(mess(255,108,1)-"=>"-mess([M]TYP(I),2684,1)-[M]NUM(I)) From GESECRAN
 Endif
 Return
Endif

#Contrôles et vérifications ok the show must go on...
GOK=1
Trbegin [CMM],[CMD]
If [L]DEBUGTRACE : Call ECR_TRACE("BEGIN",0) From  GESECRAN :Endif
###-----------------------------------------------------------
###---DANS L’EXERCICE ÉMETTEUR :
###-----------------------------------------------------------

##--DANS L’ENGAGEMENT OU LE PRÉ-ENGAGEMENT :
#-* CRÉATION D’UNE LIGNE DE SOLDE SUR L’EXERCICE EN COURS DE CLÔTURE
#-* JHA : MAJ DE LA TABLE D'AUDIT
## ! NB:  Tout cela est fait par le Call MAJENG() From CPTENG !

MOTIF(2)=6 : # Report
MOTIF(1)=4  : #Solde (/Report)
SIGN=-1
If [M]TRC=2
 If [L]DEBUGTRACE :Call ECR_TRACE("Call MAJENG pour"-mess(4,2683,1)-mess(6,2684,1)-"sur"-[M]CMM(I)-"au"-format$("D:DD[/]MM[/]YYYY",[M]DAT(I))-"Montant : "-num$([M]AMTREP(I)),0) From GESECRAN :Endif
Endif
Call MAJENG([M]DAT(I),[M]FCY(I),[M]CUR(I),[M]AMTREP(I),RATDIV,RATMLT,[M]QTY(I),TBACC,TBLED,TIERS
&                 ,TBDIE,TBCCE,SENS,SIGN,[M]CMMTYP(I),CONTBUD,[M]CMM(I),DOCUMENT,MOTIF,OK,MESSA
&                 ,PIECE,IDENT,TYPPCE,NUMPCE,TYPORG,TYPCUR) From CPTENG
If !OK
 Call MESSAGE(MESSA) From GESECRAN
 GOK=0
Endif

###-----------------------------------------------------------
###---DANS L’EXERCICE RÉCEPTEUR :
###-----------------------------------------------------------

##--DANS L’ENGAGEMENT OU LE PRÉ-ENGAGEMENT :
#-* CRÉATION D’UNE LIGNE DE PRÉ-ENGAGEMENT OU D’ENGAGEMENT SUR LE NOUVEL EXERCICE

MOTIF(1)=1 : #Création (/Report)
SIGN=1
If [M]TRC=2
 If [L]DEBUGTRACE :Call ECR_TRACE("Call MAJENG pour"-mess(1,2683,1)-mess(6,2684,1)-"sur"-[M]CMM(I)-"au"-format$("D:DD[/]MM[/]YYYY",[M]DRFIY),0) From GESECRAN :Endif
Endif
Call MAJENG([M]DRFIY,[M]FCY(I),[M]CUR(I),[M]AMTREP(I),RATDIV,RATMLT,[M]QTY(I),TBACC,TBLED,TIERS
&                 ,TBDIE,TBCCE,SENS,SIGN,[M]CMMTYP(I),CONTBUD,[M]CMM(I),DOCUMENT,MOTIF,OK,MESSA
&                 ,PIECE,IDENT,TYPPCE,NUMPCE,TYPORG,TYPCUR) From CPTENG
If !OK
 Call MESSAGE(MESSA) From GESECRAN
 GOK=0
Endif

If [M]TRC=2
 Call ECR_TRACE(string$(40,"#"),0) From GESECRAN
 If [L]DEBUGTRACE : Call ECR_TRACE("The end ",0) From GESECRAN : Endif
Endif

If GOK<0   : Goto ROLL_TR
Elsif !GOK : Goto AB_TR
Endif
Commit
Return

$AB_TR
Rollback
Return

$ROLL_TR
Rollback
Call ROLL From GLOCK
If GROLL
 Return
Else
 Goto REPORTCMM
Endif


$TERMINE
Local Integer INDREP : INDREP=0
For I=0 To [M]NBLIG-1
 If [M]REPOR(I)=2 : INDREP=1 : Break : Endif
Next
If !INDREP
 # Vous n'avez rien coché. Souhaitez vous quitter sans rien faire?
 Call OUINON(mess(105,108,1),OK) From GESECRAN
 If OK=1
  FOK=0
  FIN=0
 Endif
Else
 # Trace
 If [M]TRC=2
  Call ECR_TRACE(string$(40,"#"),0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
Endif
Return

$COLORIZE
Local Integer J,K : K=1
Local Char SRTCUR
Case [M]SRT
  When 0
   SRTCUR = ""
  When 1 :#Pièce
   SRTCUR =[M]NUM(0)
  When 2 :#Compte
   SRTCUR =[M]ACC(0)
 Endcase
For J=0 To [M]NBLIG-1
 Case [M]SRT
  When 0
   If K<>3 : K+=1 : Else : K=1 : Endif
   Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
  When 1 :#Pièce
   If SRTCUR<>[M]NUM(J)
    If K<>3 : K+=1 : Else : K=1 : Endif
    Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
   Else
    Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
   Endif
   SRTCUR =[M]NUM(J)
  When 2 :#Compte
   If SRTCUR<>[M]ACC(J)
    If K<>3 : K+=1 : Else : K=1 : Endif
    Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
   Else
    Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
   Endif
   SRTCUR =[M]ACC(J)
 Endcase
Next
Affzo [M]
Return



#################################
## Etiquette de l'écran CMMREP ##
#################################


Subprog CL_SEARCH(VALEUR)
Variable Char    VALEUR()
If [M]CPY=""
 End
Endif
Gosub INIT
Gosub LOAD_FILTRE
Filter [BUA] Where evalue(CRITBUA)
For [BUA]BUA0
  Call LECTURE("CMM",[F:BUA]CMMNUM,"") From CONTOBJ
   [M]BUANUM(I) = [F:BUA]BUANUM # Num ID
   [M]TYPPCE(I) = [F:BUA]TYPPCE #
   [M]TYP(I)    = [F:BUA]TYP # Type Pièce Demande achat commande factur ...
   [M]NUM(I)    = [F:BUA]NUM # Num Pièce
   [M]LIN(I)    = [F:BUA]LIN
   [M]SEQ(I)    = [F:BUA]SEQ
   [M]LEDTYP(I) = [F:BUA]LEDTYP
   [M]DAT(I)    = [F:BUA]DAT
   [M]FCY(I)    = [F:BUA]FCY
   [M]FIY(I)    = [F:BUA]FIY   #Exercice
   [M]CODGAU(I) = [F:BUA]CODGAU #Pièce automatique
   [M]CMM(I)    = [F:BUA]CMMNUM
   [M]CMMTYP(I) = [F:CMM]TYP
   Case [F:BUA]TYP
    When 1 : [M]OBJ(I)="PSH"
    When 2 : [M]OBJ(I)="POH"
    When 3 :#Facture
     Read [PIH]PIH0=[F:BUA]NUM
     If !fstat
      Case [F:PIH]ORIMOD
       When 2,3 : #Comptabilité/tiers
        [M]OBJ(I)="BIS"
       When 6 : #Achats
        [M]OBJ(I)="PIH"
      Endcase
     Else
      [M]OBJ(I)="GAS"
     Endif
   Endcase
#   [M]ACC(I)    = [F:BUA]ACC
  For J=1 To min(dim([F:BUA]DIE), 9)
   Assign "[M]DIE"+num$(J)+"("+num$(I)+")" With [F:BUA]DIE(J-1)
   Assign "[M]CCE"+num$(J)+"("+num$(I)+")" With [F:BUA]CCE(J-1)
  Next

   [M]CUR(I)    = [F:BUA]CUR # Devise
#   [M]CURLED(I) = [F:BUA]CURLED
   Case [F:CMM]TYP
    When 1
     [M]AMTREP(I) = [F:BUA]CMMPRP # Pré-engagements
#     [M]AMTREPLED(I) = [F:BUA]CMMPRPLED
    When 2
     [M]AMTREP(I) = [F:BUA]CMM # Engagement = MONTANT
#     [M]AMTREPLED(I) = [F:BUA]CMMLED
   Endcase
   [M]QTY(I)    = [F:BUA]QTY
   [M]REPOR(I)  = 1
   I+=1
   #----TB protection----
   If I>dim([M]REPOR)-1
    #Tableau Plein
    Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break
   Endif
   #--------------------
Next
Filter [BUA]
[M]NBLIG=I
If [M]NBLIG=0
 # Aucun enregistrement pour ces sélections
 Call MESSAGE(mess(104,199,1)) From GESECRAN
Else
 Affzo [M]
 Raz [M]SRT
 Gosub COLORIZE
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Char SOCIETE(GLONCPY)
 SOCIETE=VALEUR
 Local Integer SOC
 SOC = find(SOCIETE,GSOC(1..GNBSOC))
 If !SOC
  # Société inexistante
  GMESSAGE=mess(16,104,1)
  mkstat=2 : End
 Endif
 #06/10/09-Dmd54223:Autorisation site
 Call CONTCPY(VALEUR) From CPTSUB
 # Variables locales
 Local Libelle LEDTYPGEN, LEDTYPANA
 Local Char    CODLED(GLONLED), DEVLED(GLONCUR)
 Local Decimal EXERCICE
 # Plan de compte
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 Call SETMAINREF(SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Call LECLED(SOCIETE,LEDTYPANA,CODLED,DEVLED) From CPTDIV
 Call LECTURE("LED",CODLED,"") From CONTOBJ
 [M]COA=[F:LED]COA
 # Exercice
 Call GETEXE(VALEUR,LEDTYPANA,date$,EXERCICE) From CPTSUB
 Read [FIY]FIY0 = SOCIETE;LEDTYPANA;EXERCICE
 If !fstat & [F:FIY]FIYSTA=2
  [M]EFIY=EXERCICE
  [M]INTEFIY=[F:FIY]DES
  [M]DFIY=[F:FIY]FIYSTR
  [M]FFIY=[F:FIY]FIYEND
  Read [FIY2]FIY0 = SOCIETE;LEDTYPANA;EXERCICE+1
  If !fstat & [F:FIY2]FIYSTA<>3
   [M]RFIY=EXERCICE+1
   [M]INTRFIY=[F:FIY2]DES
   [M]DRFIY=[F:FIY2]FIYSTR
   [M]FRFIY=[F:FIY2]FIYEND
  Endif
 Endif
Endif
Affzo [M]
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Raz [M]NBLIG
Affzo [M]
End

Subprog C_EFIY(VALEUR)
Variable Decimal VALEUR
If [M]CPY<>""
 # Variables locales
 Local Libelle LEDTYPGEN, LEDTYPANA
 # Plan de compte
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 Call SETMAINREF([M]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Read [FIY]FIY0 = [M]CPY;LEDTYPANA;VALEUR
 If !fstat
  If [F:FIY]FIYSTA=2
   [M]INTEFIY=[F:FIY]DES
   [M]DFIY=[F:FIY]FIYSTR
   [M]FFIY=[F:FIY]FIYEND
   Read [FIY2]FIY0 = [M]CPY;LEDTYPANA;VALEUR+1
   If !fstat
    If [F:FIY2]FIYSTA=3
     # Exercice budgétaire récepteur fermé
     GMESSAGE=mess(204,108,1)
     mkstat=2
    Else
     [M]RFIY=VALEUR+1
     [M]INTRFIY=[F:FIY2]DES
     [M]DRFIY=[F:FIY2]FIYSTR
     [M]FRFIY=[F:FIY2]FIYEND
    Endif
   Else
    # Il n'existe pas d'exercice recepteur pour cet exercice sur cette société et son référentiel analytique principal
    GMESSAGE=mess(202,108,1)
    mkstat=2 : End
   Endif
  Else
  # Exercice non ouvert
   GMESSAGE=mess(20,101,1)
   mkstat=2 : End
  Endif
 Else
  # Exercice inexistant pour cette société sur le référentiel analytique principal
  GMESSAGE=mess(203,108,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AM_EFIY(VALEUR)
Variable Decimal VALEUR
Raz [M]NBLIG
Affzo [M]
End

Subprog AS_DET(VALEUR)
Variable Char    VALEUR()
#GNAVEXEFNC=1 :#Necessaire pour eviter le choix de transaction cf $DEBUT dans GOBJET.src
#Local Char BUOPURTRS
##Transaction de saisie des achats.
#Call PARAM([M]CPY,"GDDPURTRS",BUOPURTRS) From ADOVAL
#If BUOPURTRS<>""
# GFLAG=BUOPURTRS
#Endif
End

Subprog IB_NBLIG
If [M]CMM(nolign-1)=""
 Raz GBOUT1
Endif
GBOUT2 = mess([M]TYP(nolign-1),2684,1)-[M]NUM(nolign-1)
End

Subprog B3_NBLIG
#Tri par numéro de pièce
Sorta [M:CMMR]NBLIG [M:CMMR]NBLIG Order By [M:CMMR]NUM(indice)
[M]SRT=1
Gosub COLORIZE
Affzo [CMMR]1-99
End

Subprog B4_NBLIG
#Tri par compte budgétaire
Sorta [M:CMMR]NBLIG [M:CMMR]NBLIG Order By [M:CMMR]ACC(indice),
&                                          [M:CMMR]NUM(indice),
&                                          [M:CMMR]FIY(indice),
&                                          [M:CMMR]TYP(indice)
[M]SRT=2
Gosub COLORIZE
Affzo [CMMR]1-99
End

Subprog CL_COCHER(VALEUR)
Variable Char    VALEUR()
If [M]NBLIG>0
 Local Integer COCHE
 If [M]REPOR(0)=1
  COCHE=2
 Else
  COCHE=1
 Endif
 For I=0 To [M]NBLIG-1
  [M]REPOR(I)=COCHE
 Next
 Affzo [M]
Endif
End

Subprog C_FCYSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 If [F:FCY]LEGCPY<>[M]CPY
  # Ce site est dans la société
  GMESSAGE = mess(43,133,1)-[F:FCY]LEGCPY
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_FCYEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]FCYSTR<>""
 VALEUR = [M]FCYSTR
 Affzo [M]FCYEND
Endif
End

Subprog C_FCYEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]FCYSTR<>""
  # Zone Obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
Endif
If VALEUR<>""
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 If [F:FCY]LEGCPY<>[M]CPY
  # Ce site est dans la société
  GMESSAGE = mess(43,133,1)-[F:FCY]LEGCPY
  mkstat = 2 : End
 Endif
 If VALEUR<[M]FCYSTR
  #La borne fin est inférieure à la borne début
  GMESSAGE = mess(257,139,1)
  mkstat = 2 : End
 Endif
Endif
End

######################################################################################

