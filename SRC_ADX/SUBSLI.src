# Init SAM 112148
Subprog AS_METCORCOD(VALEUR)
Variable Integer VALEUR
If GFONCTION='GESSLA'
  Gosub HIDE_ENTER From TRTINVCAN
  Actzo [M]METCORCOD
Else
  VALEUR=3
Endif
End

Subprog C_METCORCOD(VALEUR)
Variable Integer VALEUR
  Local Char WMET(3)
  Local Integer I, WOK
  For I=1 To GNBLEG
    Call PARAML(GDOSLEG(I),"FACTURAE",WMET) From ADOVAL  #To find legislations allowed
    If val(WMET)=2: WOK=1: Break: Endif
  Next
  If GFONCTION<>'GESSLA' and VALEUR<>3: WOK=0:Endif
  If WOK=0
    GMESSAGE =  mess(357,199,1) : : mkstat=2  # Value not allowed
  Endif
End
# End SAM 112148

