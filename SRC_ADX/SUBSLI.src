#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

# Validation transactions factures depuis génération des patchs
Call GENPATCH(5,APPLI) From FUNSALTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

# Génération transactions vente à partir du dico des types de transaction
Call GENDOS(5,APPLI) From FUNSALTRS

End

##########################################################################
# Vérification des paramètres transactions facture (TRSFAC)              #
##########################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value    Char    PARAM
Value    Char    VALEUR
Variable Integer OK
If VALEUR = ""
  End
Else
  VALEUR = toupper(VALEUR)
Endif

If clalev ([F:SLT]) = 0 : Local File SALTRS [SLT] : Endif
Read [SLT]SLT0 = 5;VALEUR
If fstat | !find([F:SLT]INVTYP ,1,4)
  OK = 0
  GMESSAGE = mess(83,123,1) :  # ---  valeur incorrecte
Endif
End

########################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE    : MODULE=5
Local Integer TYP       : TYP=5
Local Char    CODTAB(GLONTRS) : CODTAB=TABLE
#-----
Gosub OUVRE_COPTRS From SELTRS
Gosub EXEC_COPTRS  From SELTRS
Gosub FERME_COPTRS From SELTRS
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran SLI1) 23/09/2009 10:42:44 (TS)
######################################################################################
Subprog AM_WRHOBY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    [M:SLI1]WRHCOD = 1
    Grizo [M:SLI1]WRHCOD
    If [M:SLS1]WRHCOD1=1
       [M:SLS1]WRHCOD1=3
       [M:SLS1]WRHSCR1=1
    Endif
    If [M:SLS1]WRHCOD1=3
       Grizo [M:SLS1]WRHSCR1
    Else
       Actzo [M:SLS1]WRHSCR1
    Endif
Else
    Actzo [M:SLI1]WRHCOD
Endif
Affzo [M:SLI1]WRHCOD
Affzo [M:SLS1]WRHCOD1
Affzo [M:SLS1]WRHSCR1
End

