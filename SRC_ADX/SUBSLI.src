#<AdxTL>@(#)0.0.0.0 $Revision$ Transaction facture
Call OBJET ("SLI",GBIDC1,GBIDC2) From GOBJET
End
#######################################################################
# SUBSLI : Transactions de saisie des factures           JL  23/04/98 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SLQ]SALTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                                                                     #
# Génération des  écrans de saisie à partir des écrans de base SIH1   #
#                                                              SIH2   #
#                                                              SIH4   #
# Nom des écrans générés : WKxyyyz                                    #
#                            x = type de la transaction (STRTYP)      #
#                                1 -    devis                         #
#                                2 -    commandes                     #
#                                3 -    commandes ouvertes            #
#                                4 -    livraisons                    #
#                                5 -    factures / avoirs             #
#                                6 -    retours client                #
#                                7 -    retours prêt                  #
#                                                                     #
#                          yyy = no de la transaction   (STRNUM)      #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                1 et 2 devis                         #
#                                1 et 2 cde ouverte                   #
#                                1 2 3 et 4 commande                  #
#                                1 2 et 4 facture                     #
#######################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Gosub OUVRE From SUBSLX
                      Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="SLT"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=5
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "EFFMASK"     : [M]STRTYP = 5
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "LIENS"       : Gosub LIENS : Gosub LIENS From SUBSLX : Gosub TRT_DIETRS From SUBDST
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST         # FGR 02/04/2015 X3SUIVI105605 : Gosub TRT_ECRAN
 When "APRES_CRE"   : Gosub APRES_CRE                      # FGR 02/04/2015 X3SUIVI105605
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST         # FGR 02/04/2015 X3SUIVI105605 : Gosub TRT_ECRAN
 When "APRES_MOD"   : Gosub APRES_MOD                      # FGR 02/04/2015 X3SUIVI105605
 When "ANNULE"      : Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="SLT"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
                      Gosub ANNULE From SUBSLX
 When "APRES_MODIF" : Gosub APRES_MODIF From SUBSLX
 When "INICRE"      : Gosub INICRE
                      Gosub INICRE From SUBSLX
 When "INIMOD"      : Gosub INICRE
                      Gosub INICRE From SUBSLX
 When "SEL_TABLE"   : Gosub SEL_TABLE  : # Sélection sur code pièce auto stock
 When Default
Endcase
Return

$APRES_CRE
$APRES_MOD
  # FGR 02/04/2015 X3SUIVI105605 : INVTYP peut ne pas être à jour autrement
  Gosub RELIT From GOBJSUB
  Gosub TRT_ECRAN
Return

#-------------------------------------------------------#
#                                                       #
#-------------------------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto stock
Local Char APPLI
APPLI=nomap
# Pour génération des écrans et fenêtres de stock
Local Char WMODU(3) : WMODU="K"
Local Char WNOMOBJ(GLONAOB)
Local Char WNOMTRS(GLONTRS)
Local Char WACSCOD(GLONACS)
Local Char WLIBEL(30)
Local Shortint WNUM
Local Shortint WENAFLG
Return

#-------------------------------------------------------#
# Ne traiter que les transactions de type facture       #
# et facture/proforma ou avoir selon la fonction        #
#-------------------------------------------------------#
$FILTRE
FILTSUP="STRTYP=5"
If GFONCTION="GESSLI"
   FILTSUP+="&find(INVTYP,1,3,4)"
Elsif GFONCTION="GESSLA"
   FILTSUP+="&INVTYP=2"
Endif

Return

#---------------------------------#
# Désactivation des boutons       #
#---------------------------------#
$SETBOUT
If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur les boutons         #
#-------------------------------------#
$EXEBOUT
Case BOUT
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

#--------------------------------------------------------------#
# Initialisation des codes de saisie des sections analytiques  #
#--------------------------------------------------------------#
$LIENS
  #If GFONCTION="GESSLA"  # Depuis FUNSALTRS, on ne peut utiliser GFONCTION
  If [F:SLT]INVTYP=2
    #   If dim([M]NBAXE)>0
    #      If [M:SLA1]NBAXE=0 : [M:SLA1]NBAXE=GOPTCANA : Endif
    #   Endif
    If [M:ETR2]UOMSAIFLG=1
      [M:SLI4]STUCOD=1
      [M:SLI3]SAUCOECOD=3
      [M:SLI3]SAUCOD=2
    Else
      [M:SLI4]STUCOD=2
      [M:SLI3]SAUCOECOD=1
      [M:SLI3]SAUCOD=1
    Endif
    [M:SLI4]STUSCR=1 : [M:SLI3]SAUCOESCR=1 : [M:SLI3]SAUSCR=1
    If dim([M:SLA1]WRHCOD) >0    : # Dépôt
      If [M:SLA1]WRHCOD=0  [M:SLA1]WRHCOD=3  Endif
      If [M:SLA1]WRHOBY = 2
        Grizo [M:SLA1]WRHCOD
      Else
        Actzo [M:SLA1]WRHCOD
      Endif
    Endif
  Else
    Case [F:SLT]INVTYP
      When 1 : [M:SLI1]INVTYPFAC=1
      When 3 : [M:SLI1]INVTYPFAC=2
      When 4 : [M:SLI1]INVTYPFAC=3
    Endcase
    Call EDD_FIELDS([M:SLI1]INVTYPFAC)      # FGR 10/04/2015 : X3SUIVI105605
    #   If dim([M]NBAXE)>0
    #      If [M:SLI1]NBAXE=0 : [M:SLI1]NBAXE=GOPTCANA : Endif
    #   Endif
    [M:SLI2]CNORENCOD=3 : Grizo [M:SLI2]CNORENCOD
    [M:SLI3]AMTLINCOD=3 : [M:SLI3]AMTLINSCR=1
    Grizo [M:SLI3]AMTLINCOD : Grizo [M:SLI3]AMTLINSCR
    If dim([M:SLI1]WRHCOD)>0
      If [M:SLI1]WRHCOD=0   [M:SLI1]WRHCOD=3  Endif
      If [M:SLI1]WRHOBY = 2
        Grizo [M:SLI1]WRHCOD
      Else
        Actzo [M:SLI1]WRHCOD
      Endif
    Endif
    If dim([M:SLS1]WRHCOD1)>0
      If [M:SLS1]WRHCOD1=0  [M:SLS1]WRHCOD1=3  : Endif
      Actzo [M:SLS1]WRHCOD1
      If [M:SLS1]WRHCOD1=3  Grizo [SLS1]WRHSCR1  Else Actzo [SLS1]WRHSCR1  : Endif
    Endif
  Endif
  # -------------------------------------
  # FGR 12/08/2014 : X3SUIVI86249 (début)
  If func AFNC.ACTIV("KBE") = 1 Then
    Actzo [M:SLI2]BELVCSCOD
  Else
    Grizo [M:SLI2]BELVCSCOD
  Endif
  # FGR 12/08/2014 : X3SUIVI86249 (fin)
  # -------------------------------------

  #--------------------------------------
  # 107888 Percent column in sales credit notes
  If GFONCTION='GESSLA'
     [M:SLI3]INVPRCCOD=3
     Grizo [M:SLI3]INVPRCCOD
  Endif
  # End 107888 Percent column in sales credit notes
  #--------------------------------------
Return

#-------------------------------------------------------------#
# Initialisation des codes de saisie des sections analytiques #
#-------------------------------------------------------------#
$RAZCRE
  [M:SLI0]ENAFLG = 2
  #For indice=0 To GOPTCANA-1
  #  If CCECODD(indice) = 0 : CCECODD(indice) = 1 : Endif
  #Next indice
  If GFONCTION="GESSLA"
    #   If dim([M]NBAXE)>0
    #      If [M:SLA1]NBAXE=0 : [M:SLA1]NBAXE=GOPTCANA : Endif
    #   Endif
    #   Affzo [M:SLA1] 25
    #--- Dépôt
    If dim([M:SLA1]WRHCOD)>0
      If [M:SLA1]WRHOBY=2
        [M:SLA1]WRHCOD=1
        Diszo [M:SLA1]WRHCOD
      Else
        [M:SLA1]WRHCOD=3
        Actzo [M:SLA1]WRHCOD
      Endif
    Endif
    # Pour génération des écrans et fenêtres de stock
    WMODU+=num$([M:SLI0]STRTYP)
    Gosub RAZCRE From SUBETR
    [M:SLI4]STUCOD=2    : [M:SLI4]STUSCR=1
    [M:SLI3]SAUCOECOD=1 : [M:SLI3]SAUCOESCR=1
    [M:SLI3]SAUCOD=1    : [M:SLI3]SAUSCR=1
    Diszo [M:SLI4]STUCOD, STUSCR
    Diszo [M:SLI3]SAUCOECOD, SAUCOESCR
    Diszo [M:SLI3]SAUCOD, SAUSCR
  Else
    #   If dim([M]NBAXE)>0
    #      If [M:SLI1]NBAXE=0 : [M:SLI1]NBAXE=GOPTCANA : Endif
    #   Endif
    #   Affzo [M:SLI1] 25
    [M:SLI2]CNORENCOD=3 : Grizo [M:SLI2]CNORENCOD
    [M:SLI3]AMTLINCOD=3 : [M:SLI3]AMTLINSCR=1
    Grizo [M:SLI3]AMTLINCOD, AMTLINSCR
    #--- Dépôt
    If dim([M:SLI1]WRHCOD)>0
      If [M:SLI1]WRHOBY=2
        [M:SLI1]WRHCOD=1
        Diszo [M:SLI1]WRHCOD
      Else
        [M:SLI1]WRHCOD=3
        Actzo [M:SLI1]WRHCOD
      Endif
    Endif
    If dim([M:SLS1]WRHCOD1)>0
      [M:SLS1]WRHCOD1=3
      [M:SLS1]WRHSCR1=1
    Endif
  Endif
  # -------------------------------------
  # FGR 12/08/2014 : X3SUIVI86249 (début)
  If func AFNC.ACTIV("KBE") = 1 Then
    [M:SLI2]BELVCSCOD = 1 # Saisi
    Actzo [M:SLI2]BELVCSCOD
  Else
    [M:SLI2]BELVCSCOD = 3 # Invisible
    Grizo [M:SLI2]BELVCSCOD
  Endif
  Affzo [M:SLI2]BELVCSCOD
  # FGR 12/08/2014 : X3SUIVI86249 (fin)
  # -------------------------------------
  #--------------------------------------
  # 107888 Percent column in sales credit notes
  If GFONCTION='GESSLA'
     [M:SLI3]INVPRCCOD=3
     Grizo [M:SLI3]INVPRCCOD
     [M:SLI3]INVPRCCOD=1
     Grizo [M:SLI3]INVPRCSCR
  Endif
  # End 107888 Percent column in sales credit notes
  #--------------------------------------
Return

$SEL_TABLE
#---------------------#
# Sélection sur champ #
#---------------------#
Case COUZON
  When "ENTCOD"   : # Pièce auto de sortie stock
    OBJET="GAU"
    CRITERE="TBL='STJTMP'"
Endcase
Return

#-------------------------------------------------------------#
# Initialisation du type de facture                           #
#-------------------------------------------------------------#
$INICRE
If GFONCTION="GESSLA"
   [F:SLT]INVTYP=2
Else
   Case [M:SLI1]INVTYPFAC
    When 1 : [F:SLT]INVTYP=1
    When 2 : [F:SLT]INVTYP=3
    When 3 : [F:SLT]INVTYP=4
   Endcase
Endif

Return

#------------------------------------------------#
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(WMODU)<0 Local Char    WMODU(2) : Endif
If dim(APPLI)<0 Local Char APPLI : Endif
If dim(OK)<0    Local Integer OK       : Endif
If APPLI=""     APPLI=nomap      : Endif
If WMODU=""     WMODU="K"        : Endif
Local Char    MFROM(GLONAMK)
Local Char    MTO(GLONAMK)
Local Integer TBLOC(15)
Local Char    TZONE(GLONAVA)(200)
Local Integer TMOD(200)
Local Char    TINT(1)(200)
Local Char    TTAB(1)(1)
Local Char    TFLD(1)(1)
Local Integer OPT1, OPT2, OPT3, RETOUR
Local Integer IZON, I, FLAG
# Local Char BOUTONS(10)(4), TEXTE(40), LISTE(3), REPONS(1)

#------------------------- écran SIH1 -------------------------#
#If GFONCTION="GESSLA"
#If [M]INVTYP=2
#   If (dim([M:SLA1]CCECOD)>0 & [M:SLA1]CCECOD=3) | dim([M:SLA1]CCECOD)<1
#      Gosub MODIF_SIH2CCE : If GOK<1 Return : Endif
#   Endif
#   If [M:SLA1]INVDTACOD=3
#      Gosub MODIF_SIH2FAC : If GOK<1 Return : Endif
#   Endif
#Else
#   If (dim([M:SLI1]CCECOD)>0 & [M:SLI1]CCECOD=3) | dim([M:SLI1]CCECOD)<1
#      Gosub MODIF_SIH2CCE : If GOK<1 Return : Endif
#   Endif
#   If dim([M:SLI1]INVDTACOD)>0 & [M:SLI1]INVDTACOD=3
#      Gosub MODIF_SIH2FAC : If GOK<1 Return : Endif
#   Endif
#Endif

MFROM="SIH1"
MTO="WK"+num$([M:SLI0]STRTYP)+[M:SLI0]STRNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If   ACTION <> "ANNULE"
     #---- client commande & nom
#     If   [M:SLI4]BPCORDCOD= 1  TZONE(IZON)="BPCORD"
#                                TMOD(IZON) =3
#                                IZON+=1
#                                TZONE(IZON)="BPCNAM"
#                                TMOD(IZON) =3
#                                IZON+=1
#     Endif
     #---- client commande & nom
     If   [M:SLI2]BPCORDCOD > 1 TZONE(IZON)="BPCORD"
                                TMOD(IZON) =[M:SLI2]BPCORDCOD
                                IZON+=1
                                TZONE(IZON)="BPCNAM"
                                TMOD(IZON) =[M:SLI2]BPCORDCOD
                                IZON+=1     Endif
     #---- tiers payeur
     If   [M:SLI2]BPCPYRCOD > 1 TZONE(IZON)="BPRPAY"
                                TMOD(IZON) =[M:SLI2]BPCPYRCOD
                                IZON+=1
     Endif
     #---- client groupe
     If   [M:SLI2]BPCGRUCOD > 1 TZONE(IZON)="BPCGRU"
                                TMOD(IZON) =[M:SLI2]BPCGRUCOD
                                IZON+=1
     Endif
     #---- adresse livraison
     If   [M:SLI2]BPAADDCOD > 1 TZONE(IZON)="BPAADD"
                                TMOD(IZON) =[M:SLI2]BPAADDCOD
                                IZON+=1
                                TZONE(IZON)="BPDNAM"
                                TMOD(IZON) =[M:SLI2]BPAADDCOD
                                IZON+=1
     Endif
     #---- affaire
     If   [M:SLI2]PJTCOD > 1    TZONE(IZON)="PJT"
                                TMOD(IZON) =[M:SLI2]PJTCOD
                                IZON+=1
     Endif
     #---- représentant
     If   [M:SLI2]REPCOD > 1    TZONE(IZON)="REP"
                                TMOD(IZON) =[M:SLI2]REPCOD
                                IZON+=1
     Endif
     #---- Origine de la facture
     If   [M:SLI4]SIHORICOD = 1 TZONE(IZON)="SIHORI"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="SIHORINUM"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="SIHORIDAT"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- N° facture achat
     If   [M:SLI4]PIHNUMCOD = 1 TZONE(IZON)="PIHNUM"
                                TMOD(IZON) =3
                                IZON+=1
     Endif

     #---- inter-sociétés
     If   [M:SLI4]BETCPYCOD = 1 TZONE(IZON)="BETCPY"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- A VOIR : TRAITER de le numero de facture : Pb des avoirs
     #---- motif avoir
     If   [M:SLI2]CNORENCOD > 1 TZONE(IZON)="CNOREN"
                                TMOD(IZON) =[M:SLI2]CNORENCOD
                                IZON+=1
     Endif
     #---- régime de taxe
     If   [M:SLI2]VACBPRCOD > 1 TZONE(IZON)="VACBPR"
                                TMOD(IZON) =[M:SLI2]VACBPRCOD
                                IZON+=1
     Endif
     #LTA.sn entity/use code for local taxing
     If func AFNC.ACTIV("LTA") and [M:SLI2]SSTENTCOD > 1
                                TZONE(IZON)="SSTENTCOD"
                                TMOD(IZON) =[M:SLI2]SSTENTCOD
                                IZON+=1
     Endif
     #LTA.en
     #---- prix HT/TTC
     If   [M:SLI2]PRITYPCOD > 1 TZONE(IZON)="PRITYP"
                                TMOD(IZON) =[M:SLI2]PRITYPCOD
                                IZON+=1
     Endif
     If dim([M:SLI2]FLD40RENCOD)>0
         If   [M:SLI2]FLD40RENCOD > 1 TZONE(IZON)="FLD40REN"
                                    TMOD(IZON) =[M:SLI2]FLD40RENCOD
                                    IZON+=1
         Endif
     Endif
     If dim([M:SLI2]FLD41RENCOD)>0
         If   [M:SLI2]FLD41RENCOD > 1 TZONE(IZON)="FLD41REN"
                                    TMOD(IZON) =[M:SLI2]FLD41RENCOD
                                    IZON+=1
         Endif
     Endif
     #---- flag mouvement de stock
     If   [M:SLI2]STOMVTCOD > 1 TZONE(IZON)="STOMVTFLG"
                                TMOD(IZON) =[M:SLI2]STOMVTCOD
                                IZON+=1
     Endif
     #---- site expédition
     If   [M:SLI2]STOFCYCOD > 1 TZONE(IZON)="STOFCY"
                                TMOD(IZON) =[M:SLI2]STOFCYCOD
                                IZON+=1
     Endif
     #---- famille mouvement
     If   [M:SLI2]TRSFAMCOD > 1 TZONE(IZON)="TRSFAM"
                                TMOD(IZON) =[M:SLI2]TRSFAMCOD
                                IZON+=1
     Endif
     #---- CPO 65018
     #---- Incoterm et ville Incoterm
     If   [M:SLI2]EECICTCOD > 1 TZONE(IZON)="EECICT"
                                TMOD(IZON) =[M:SLI2]EECICTCOD
                                IZON+=1
                                TZONE(IZON)="ICTCTY"
                                TMOD(IZON) =[M:SLI2]EECICTCOD
                                IZON+=1
     Endif
#     If GFONCTION="GESSLA"
     If [M]INVTYP=2
         #---- Réception à quai
         If   [M:SLA1]SRGWAIFLG<>2  TZONE(IZON)="SRGLOCDEF" : # Si autorisée => champ emplacement quai par défaut
                                    TMOD(IZON) =3
                                    IZON+=1
         Endif
        #---- Dépôt entête
         If dim([M:SLA1]WRHCOD) >0
            If  [M:SLA1]WRHCOD > 1   TZONE(IZON)="WRHE"
                                     TMOD(IZON) =[M:SLA1]WRHCOD
                                     IZON+=1
            Endif
         Else
            # Bug 63618
            # Gestion des dépots désactivée (Code activité WRH inactif) : Forcer le champ WRHE invisible
            TZONE(IZON)="WRHE"
            TMOD(IZON) =3
            IZON+=1
            # Bug 63618
        Endif
     Else
         #---- Réception à quai : non gérée dans les factures
         TZONE(IZON)="SRGLOCDEF" : # Si autorisée => champ emplacement quai par défaut
         TMOD(IZON) =3
         IZON+=1
         #---- Dépôt
         If dim([M:SLI1]WRHCOD)>0
            If [M:SLI1]WRHCOD>1 TZONE(IZON)="WRHE"
                                TMOD(IZON) =[M:SLI1]WRHCOD
                                IZON+=1
            Endif
         Else
            # Bug 63618
            # Gestion des dépots désactivée (Code activité WRH inactif) : Forcer le champ WRHE invisible
            TZONE(IZON)="WRHE"
            TMOD(IZON) =3
            IZON+=1
            # Bug 63618
         Endif
     Endif
     #---- état facture
     If   [M:SLI4]STACOD = 1 TZONE(IZON)="INVSTA"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="STARPT"
                             TMOD(IZON) =3
                             IZON+=1
     Endif
     ## RMA (VAT)
     #---- EECNUM for VAT declaration (Portugal, Germany and Austria)
     If dim([M:SLI2]DCLEECNUMCOD)>0
       If [M:SLI2]DCLEECNUMCOD > 1 TZONE(IZON)="DCLEECNUM"
                             TMOD(IZON) =[M:SLI2]DCLEECNUMCOD
                             IZON+=1
       Endif
     Endif
     ## RMA (VAT) End
     # --------------------------------------
     # FGR 07/07/2014 : X3SUIVI91606 (début)
     #---- matricule
     If   [M:SLI2]LICPLATCOD > 1 TZONE(IZON)="LICPLATE"
                                TMOD(IZON) =[M:SLI2]LICPLATCOD
                                IZON+=1
     Endif
     #---- matricule remorque
     If   [M:SLI2]TRAPLTCOD > 1 TZONE(IZON)="TRLLICPLATE"
                                TMOD(IZON) =[M:SLI2]TRAPLTCOD
                                IZON+=1
     Endif
     #---- date départ
     If   [M:SLI2]DPEDATCOD > 1 TZONE(IZON)="DPEDAT"
                                TMOD(IZON) =[M:SLI2]DPEDATCOD
                                IZON+=1
     Endif
     #---- date arrivée
     If   [M:SLI2]ARVDATCOD > 1 TZONE(IZON)="ARVDAT"
                                TMOD(IZON) =[M:SLI2]ARVDATCOD
                                IZON+=1
     Endif
     #---- heure départ
     If   [M:SLI2]ETDCOD     > 1 TZONE(IZON)="ETD"
                                TMOD(IZON) =[M:SLI2]ETDCOD
                                IZON+=1
     Endif
     #---- heure arrivée
     If   [M:SLI2]ETACOD     > 1 TZONE(IZON)="ETA"
                                TMOD(IZON) =[M:SLI2]ETACOD
                                IZON+=1
     Endif
     # FGR 07/07/2014 : X3SUIVI91606 (fin)
     # --------------------------------------
     # FGR 12/08/2014 : X3SUIVI86249 (début)
     #---- Numéro VCS
     If   [M:SLI2]BELVCSCOD  > 1 TZONE(IZON)="BELVCS"
                                TMOD(IZON) =[M:SLI2]BELVCSCOD
                                IZON+=1
     Endif
     # FGR 12/08/2014 : X3SUIVI86249 (fin)
     # --------------------------------------
#---- # SAM 112148 XML signature (Spanish Facturae and EDI)
     If dim([M:SLI2]METCORCOD)>0
       If [M:SLI2]METCORCOD > 1 TZONE(IZON)="METCOR"
                               TMOD(IZON) =[M:SLI2]METCORCOD
                               IZON+=1
       Endif
     Endif
     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

     #---- visualisation du masque généré
     OPT1 = 2
#     If ACTION<>"MASSE"
#        BOUTONS(1)=mess(2,1,1)    : # Oui
#        BOUTONS(2)=mess(1,1,1)    : # Non
#        BOUTONS(3)=mess(71,198,1) : # Abandon
#        TEXTE= " "+mess(1,196,1)  : LISTE="ONA" : REPONS="N"
#        Call CHOIXM(BOUTONS,TEXTE,LISTE,REPONS) From TRTX3
#        If REPONS="A" GOK=0  : Return : Endif
#        If REPONS="O" OPT2=1 : Endif
#     Endif
     #---- suppression du masque
Else OPT1=9
Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
#---- erreur
If RETOUR<>0 GOK=0 : Return : Endif

#------------------------- écran SIH2 -------------------------#

MFROM="SIH2"
MTO="WK"+num$([M:SLI0]STRTYP)+[M:SLI0]STRNUM+"2"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
     #---- devise
     If   [M:SLI2]CURCOD    > 1 TZONE(IZON)="CUR"
                                TMOD(IZON) =[M:SLI2]CURCOD
                                IZON+=1
                                TZONE(IZON)="CURTYP"
                                TMOD(IZON) =[M:SLI2]CURCOD
                                IZON+=1
     Endif
     #---- court devise
     If   [M:SLI2]RATCURCOD > 1 TZONE(IZON)="RAT1"
                                TMOD(IZON) =[M:SLI2]RATCURCOD
                                IZON+=1
                                TZONE(IZON)="LABEL"
                                TMOD(IZON) =[M:SLI2]RATCURCOD
                                IZON+=1
                                TZONE(IZON)="RAT2"
                                TMOD(IZON) =[M:SLI2]RATCURCOD
                                IZON+=1
                                TZONE(IZON)="CURMLT"
                                TMOD(IZON) =[M:SLI2]RATCURCOD
                                IZON+=1
     Endif
     #---- commentaires
     If   [M:SLI2]DESCOD    > 1 TZONE(IZON)="DES"
                                TMOD(IZON) =[M:SLI2]DESCOD
                                IZON+=1
     Endif
     #---- factor
     If   [M:SLI2]BPRFCTCOD > 1 TZONE(IZON)="BPRFCT"
                                TMOD(IZON) =[M:SLI2]BPRFCTCOD
                                IZON+=1
     Endif
     #---- collectif
     If   [M:SLI2]BPRSACCOD > 1 TZONE(IZON)="BPRSAC"
                                TMOD(IZON) =[M:SLI2]BPRSACCOD
                                IZON+=1
     Endif
     #---- date début échéance
     If   [M:SLI2]DUDDATCOD > 1 TZONE(IZON)="STRDUDDAT"
                                TMOD(IZON) =[M:SLI2]DUDDATCOD
                                IZON+=1
     Endif
     ## <PP 07/04/03> Rajout des champs date début et fin prestation (période de prestation)
     If dim([M:SLI2]SVCDATCOD)>0    : # Bug 64820
         If [M:SLI2]SVCDATCOD>1     : # Bug 64820
             TZONE(IZON)="STRDATSVC"
             TMOD(IZON) =[M:SLI2]SVCDATCOD
             IZON+=1
             TZONE(IZON)="ENDDATSVC"
             TMOD(IZON) =[M:SLI2]SVCDATCOD
             IZON+=1
         Endif
     Else
         # Bug 63618
         # Charg/prod const.d'avance désactivé (Code activité SVC inactif) : Forcer les champs STRDATSVC ENDDATSVC invisibles
         TZONE(IZON)="STRDATSVC"
         TMOD(IZON) =3
         IZON+=1
         TZONE(IZON)="ENDDATSVC"
         TMOD(IZON) =3
         IZON+=1
         # Bug 63618
     Endif
     ## <Fin PP>
     #---- condition de paiement
     If   [M:SLI2]PTECOD    > 1 TZONE(IZON)="PTE"
                                TMOD(IZON) =[M:SLI2]PTECOD
                                IZON+=1
     Endif

     # 87923 : Gestion des prélèvements SDD
     If dim([M:SLI2]UMRNUMCOD)>0
         If [M:SLI2]UMRNUMCOD>1
             TZONE(IZON)="UMRNUM"
             TMOD(IZON) =[M:SLI2]UMRNUMCOD
             IZON+=1
         Endif
     Else
         # Gestion des prélèvements SDD désactivé (Code activité SDD inactif) : Forcer le champ UMRNUM invisible
         TZONE(IZON)="UMRNUM"
         TMOD(IZON) =3
         IZON+=1
         TZONE(IZON)="UMRNUM"
         TMOD(IZON) =3
         IZON+=1
     Endif
     # 87923 : Gestion des prélèvements SDD
     #---- escompte
     If   [M:SLI2]DEPCOD    > 1 TZONE(IZON)="DEP"
                                TMOD(IZON) =[M:SLI2]DEPCOD
                                IZON+=1
     Endif
     #---- sections analytiques
#     If [M]INVTYP=2
#        #------- Test si toutes les sections sont affichées --------#
#        If dim([M:SLA1]CCECOD)>0
#           If [M:SLA1]CCECOD=2  TZONE(IZON)="CCE"
#                                TMOD(IZON)=2
#                                TBLOC(3)=2
#                                IZON+=1
#           Endif
#        Endif
#        #------- Test si toutes les sections sont invisibles --------#
#        If (dim([M:SLA1]CCECOD)>0 & [M:SLA1]CCECOD=3) | dim([M:SLA1]CCECOD)<1
#            TBLOC(3)=1
#        Endif
#     Else
#        #------- Test si toutes les sections sont affichées --------#
#        If dim([M:SLI1]CCECOD)>0
#           If [M:SLI1]CCECOD=2  TZONE(IZON)="CCE"
#                                TMOD(IZON)=2
#                                TBLOC(3)=2
#                                IZON+=1
#           Endif
#        Endif
#        #------- Test si toutes les sections sont invisibles --------#
#        If (dim([M:SLI1]CCECOD)>0 & [M:SLI1]CCECOD=3) | dim([M:SLI1]CCECOD)<1
#            TBLOC(3)=1
#        Endif
#     Endif
     #----- Test si les sections d'entête sont affichées -----#
     If dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=2
        TZONE(IZON)="CCE"
        TMOD(IZON)=2
        # TBLOC(3)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
        IZON+=1
     Endif
     #----- Test si les sections d'entête sont invisibles -----#
     If (dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=3) | dim([M:DST]HEACCECOD)<1
        TBLOC(3)=1
     Endif

     # SAM 110033: Swiss localization
     #---- Paying bank for ISR payment for Switzerland
     If dim([M:SLI2]PAYBANCOD) > 0
       If func AFNC.ACTIV("KSW")
          If ( [M]INVTYP = 2 )  or ( [M]INVTYP = 3 )
                                TZONE(IZON) = "PAYBAN"
                                TMOD(IZON)  = 3
                                IZON += 1
          Elsif [M:SLI2]PAYBANCOD > 1
                                TZONE(IZON) ="PAYBAN"
                                TMOD(IZON)  =[M:SLI2]PAYBANCOD
                                IZON += 1
          Endif
       Endif
     Endif

     #---- ISR reference number for Switzerland
     If dim([M:SLI4]BVRREFNUMCOD) > 0
       If func AFNC.ACTIV("KSW") and ( ( [M:SLI4]BVRREFNUMCOD = 1 ) or ( [M]INVTYP = 2 )  or ( [M]INVTYP = 3 ) )
                                TZONE(IZON) = "BVRREFNUM"
                                TMOD(IZON)  = 3
                                IZON += 1
       Endif
     Endif
     # SAM 110033 END

     #---- éléments de facturation
     If [M]INVTYP=2
#     If GFONCTION="GESSLA"
        #------- Test si tous les éléments de facturation sont affichées --------#
        If [M:SLA1]INVDTACOD=2  TZONE(IZON)="INVDTAAMT"
                                TMOD(IZON)=2
                                # TBLOC(4)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                                IZON+=1
                                TZONE(IZON)="INVDTATYP"
                                TMOD(IZON) =2
                                # TBLOC(4)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                                IZON+=1
                                TZONE(IZON)="SFISSTCOD" # 101380.n
                                TMOD(IZON) =2           # 101380.n
                                # TBLOC(4)=2              # 101380.n ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                                IZON+=1                 # 101380.n
        Endif
        #------- Test si tous les éléments de facturation sont invisibles --------#
        If [M:SLA1]INVDTACOD=3  TBLOC(4)=1 Endif
     Else
        #------- Test si tous les éléments de facturation sont affichées --------#
        If dim([M:SLI1]INVDTACOD)>0
           If [M:SLI1]INVDTACOD=2  TZONE(IZON)="INVDTAAMT"
                                   TMOD(IZON)=2
                                  # TBLOC(4)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                                   IZON+=1
           Endif
           #------- Test si tous les éléments de facturation sont invisibles --------#
           If [M:SLI1]INVDTACOD=3     TBLOC(4)=1 Endif

        Endif
     Endif
     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX
Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
#---- erreur
If RETOUR<>0 GOK=0 : Return : Endif

#------------------------- écran SIH4 -------------------------#
Local Char    ZT : # nom de zone dans table transaction
Local Char    ZM : # nom de zone dans le masque
Local Integer ZI : # pour les zones indicées
MFROM="SIH4"
MTO="WK"+num$([M:SLI0]STRTYP)+[M:SLI0]STRNUM+"4"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
     #---- désignation traduite de l'article
     If   [M:SLI3]ITMDESCOD > 1 TZONE(IZON)="ITMDES"
                                TMOD(IZON) =[M:SLI3]ITMDESCOD
                                IZON+=1
     Endif
     If   [M:SLI3]ITMDESCOD = 1 | [M:SLI3]ITMDESCOD = 2
        ZT="ITMDESSCR" : ZM="ITMDES" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- désignation standard de l'article
     If   [M:SLI3]ITMDES1COD > 1 TZONE(IZON)="ITMDES1"
                                TMOD(IZON) =[M:SLI3]ITMDES1COD
                                IZON+=1
     Endif
     If   [M:SLI3]ITMDES1COD = 1 | [M:SLI3]ITMDES1COD = 2
        ZT="ITMDES1SCR" : ZM="ITMDES1" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     # FGR 04/02/2015 : X3SUIVI105605 (début)
     If func AFNC.ACTIV("ECC") Then
       If [M]INVTYP <> 2  and [M]INVTYP <> 3 Then
         #---- Version majeure
         If   [M:SLI3]ECCCOD> 1     TZONE(IZON)="ECCVALMAJ"
                                    TMOD(IZON) =[M:SLI3]ECCCOD
                                    IZON+=1
         Endif
         If   [M:SLI3]ECCCOD = 1 | [M:SLI3]ECCCOD = 2
            ZT="ECCSCR" : ZM="ECCVALMAJ" : Gosub TABLEAU_FICHE From SUBSLX
         Endif
         #---- Version mineure
         If   [M:SLI3]ECCCODMIN> 1  TZONE(IZON)="ECCVALMIN"
                                    TMOD(IZON) =[M:SLI3]ECCCODMIN
                                    IZON+=1
         Endif
         If   [M:SLI3]ECCCODMIN = 1 | [M:SLI3]ECCCODMIN = 2
            ZT="ECCSCRMIN" : ZM="ECCVALMIN" : Gosub TABLEAU_FICHE From SUBSLX
         Endif
       Else
        # Avoir et proforma : toujours invisible
        #---- Version majeure
        TZONE(IZON)="ECCVALMAJ"
        TMOD(IZON) =3
        IZON+=1
        #---- Version mineure
        TZONE(IZON)="ECCVALMIN"
        TMOD(IZON) =3
        IZON+=1
       Endif
     Endif
     # FGR 04/02/2015 : X3SUIVI105605 (fin)

     # 107888 : Scheduled invoices : (LD:04/03/16)
     #---- percentage
     If   [M:SLI3]INVPRCCOD >1 TZONE(IZON)="INVPRC"
                               TMOD(IZON) =[M:SLI3]INVPRCCOD
                               IZON+=1
     Endif
     If   [M:SLI3]INVPRCCOD = 1 | [M:SLI3]INVPRCCOD = 2
        ZT="INVPRCSCR" : ZM="INVPRC" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     # 107888 : Scheduled invoices : (LD:04/03/16)

#     If GFONCTION="GESSLI"
     If [M]INVTYP<>2
         #---- unité de vente
         If   [M:SLI3]SAUCOD    > 1 TZONE(IZON)="SAU"
                                    TMOD(IZON) =[M:SLI3]SAUCOD
                                    IZON+=1
         Endif
         If   [M:SLI3]SAUCOD = 1 | [M:SLI3]SAUCOD = 2
            ZT="SAUSCR" : ZM="SAU" : Gosub TABLEAU_FICHE From SUBSLX
         Endif
         #---- coef UV-US
         If   [M:SLI3]SAUCOECOD > 1 TZONE(IZON)="SAUSTUCOE"
                                    TMOD(IZON) =[M:SLI3]SAUCOECOD
                                    IZON+=1
         Endif
         If   [M:SLI3]SAUCOECOD = 1 | [M:SLI3]SAUCOECOD = 2
            ZT="SAUCOESCR" : ZM="SAUSTUCOE" : Gosub TABLEAU_FICHE From SUBSLX
         Endif
         #---- unité de stock
         If   [M:SLI4]STUCOD = 1    TZONE(IZON)="STU"
                                    TMOD(IZON) =3
                                    IZON+=1
         Else
            ZT="STUSCR" : ZM="STU" : Gosub TABLEAU_FICHE From SUBSLX
         Endif
     Endif
     #---- prix brut
     If   [M:SLI3]GROPRICOD > 1 TZONE(IZON)="GROPRI"
                                TMOD(IZON) =[M:SLI3]GROPRICOD
                                IZON+=1
     Endif
     If   [M:SLI3]GROPRICOD = 1 | [M:SLI3]GROPRICOD = 2
        ZT="GROPRISCR" : ZM="GROPRI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- valeur1 remise/frais
     If   dim([M:SLX1]DISCRGCOD1) > 0
          If  [M:SLX1]DISCRGCOD1 > 1 TZONE(IZON)="DISCRGVAL1"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD1
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD1 = 1 | [M:SLX1]DISCRGCOD1 = 2
             ZT="DISCRGSCR1" : ZM="DISCRGVAL1" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur2 remise/frais
     If   dim([M:SLX1]DISCRGCOD2) > 0
          If  [M:SLX1]DISCRGCOD2 > 1 TZONE(IZON)="DISCRGVAL2"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD2
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD2 = 1 | [M:SLX1]DISCRGCOD2 = 2
             ZT="DISCRGSCR2" : ZM="DISCRGVAL2" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur3 remise/frais
     If   dim([M:SLX1]DISCRGCOD3) > 0
          If  [M:SLX1]DISCRGCOD3 > 1 TZONE(IZON)="DISCRGVAL3"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD3
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD3 = 1 | [M:SLX1]DISCRGCOD3 = 2
             ZT="DISCRGSCR3" : ZM="DISCRGVAL3" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur4 remise/frais
     If   dim([M:SLX1]DISCRGCOD4) > 0
          If  [M:SLX1]DISCRGCOD4 > 1 TZONE(IZON)="DISCRGVAL4"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD4
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD4 = 1 | [M:SLX1]DISCRGCOD4 = 2
             ZT="DISCRGSCR4" : ZM="DISCRGVAL4" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur5 remise/frais
     If   dim([M:SLX1]DISCRGCOD5) > 0
          If  [M:SLX1]DISCRGCOD5 > 1 TZONE(IZON)="DISCRGVAL5"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD5
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD5 = 1 | [M:SLX1]DISCRGCOD5 = 2
             ZT="DISCRGSCR5" : ZM="DISCRGVAL5" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur6 remise/frais
     If   dim([M:SLX1]DISCRGCOD6) > 0
          If  [M:SLX1]DISCRGCOD6 > 1 TZONE(IZON)="DISCRGVAL6"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD6
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD6 = 1 | [M:SLX1]DISCRGCOD6 = 2
             ZT="DISCRGSCR6" : ZM="DISCRGVAL6" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur7 remise/frais
     If   dim([M:SLX1]DISCRGCOD7) > 0
          If  [M:SLX1]DISCRGCOD7 > 1 TZONE(IZON)="DISCRGVAL7"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD7
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD7 = 1 | [M:SLX1]DISCRGCOD7 = 2
             ZT="DISCRGSCR7" : ZM="DISCRGVAL7" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur8 remise/frais
     If   dim([M:SLX1]DISCRGCOD8) > 0
          If  [M:SLX1]DISCRGCOD8 > 1 TZONE(IZON)="DISCRGVAL8"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD8
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD8 = 1 | [M:SLX1]DISCRGCOD8 = 2
             ZT="DISCRGSCR8" : ZM="DISCRGVAL8" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur9 remise/frais
     If   dim([M:SLX1]DISCRGCOD9) > 0
          If  [M:SLX1]DISCRGCOD9 > 1 TZONE(IZON)="DISCRGVAL9"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD9
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD9 = 1 | [M:SLX1]DISCRGCOD9 = 2
             ZT="DISCRGSCR9" : ZM="DISCRGVAL9" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- prix net
     If   [M:SLI4]NETPRICOD = 1 TZONE(IZON)="NETPRI"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="NETPRISCR" : ZM="NETPRI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif

     If [M]INVTYP=2
         #---- montant ligne
         #---- montant ligne uniquement saisissable pour les avoirs
         #                   invisible pour les factures (traité dans SIH4_INV)
         If   [M:SLI3]AMTLINCOD > 1 TZONE(IZON)="AMTLIN"
                                    TMOD(IZON) =[M:SLI3]AMTLINCOD
                                    IZON+=1
         Endif
         If   [M:SLI3]AMTLINCOD = 1 | [M:SLI3]AMTLINCOD = 2
            ZT="AMTLINSCR" : ZM="AMTLIN" : Gosub TABLEAU_FICHE From SUBSLX
         Endif
     Endif
     #---- prix revient
     If   [M:SLI3]CPRPRICOD > 1 TZONE(IZON)="CPRPRI"
                                TMOD(IZON) =[M:SLI3]CPRPRICOD
                                IZON+=1
     Endif
     If   [M:SLI3]CPRPRICOD = 1 | [M:SLI3]CPRPRICOD = 2
        ZT="CPRPRISCR" : ZM="CPRPRI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- marge
     If   [M:SLI4]PFMCOD    = 1 TZONE(IZON)="PFM"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="PFMTOT"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="PFMSCR" : ZM="PFM" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- niveau de taxe
     If   [M:SLI3]VACITMCOD > 1 TZONE(IZON)="VACITM1"
                                TMOD(IZON) =[M:SLI3]VACITMCOD
                                IZON+=1
                                TZONE(IZON)="VACITM2"
                                TMOD(IZON) =[M:SLI3]VACITMCOD
                                IZON+=1
                                TZONE(IZON)="VACITM3"
                                TMOD(IZON) =[M:SLI3]VACITMCOD
                                IZON+=1
                                TZONE(IZON)="SSTCOD"            # 101380.n
                                TMOD(IZON) =[M:SLI3]VACITMCOD   # 101380.n
                                IZON+=1                         # 101380.n
     Endif
     If   [M:SLI3]VACITMCOD = 1 | [M:SLI3]VACITMCOD = 2
        ZT="VACITMSCR" : ZM="VACITM1" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="VACITMSCR" : ZM="VACITM2" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="VACITMSCR" : ZM="VACITM3" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="VACITMSCR" : ZM="SSTCOD"  : Gosub TABLEAU_FICHE From SUBSLX # 101380.n
     Endif
     #---- représentants / tx comm
     If   [M:SLI3]REPCODD   > 1 TZONE(IZON)="REP1"
                                TMOD(IZON) =[M:SLI3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REP2"
                                TMOD(IZON) =[M:SLI3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REPRAT1"
                                TMOD(IZON) =[M:SLI3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REPRAT2"
                                TMOD(IZON) =[M:SLI3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REPCOE"
                                TMOD(IZON) =[M:SLI3]REPCODD
                                IZON+=1
     Endif
     If   [M:SLI3]REPCODD = 1 | [M:SLI3]REPCODD = 2
        ZT="REPSCRD" : ZM="REP1"    : Gosub TABLEAU_FICHE From SUBSLX
        ZT="REPSCRD" : ZM="REP2"    : Gosub TABLEAU_FICHE From SUBSLX
        ZT="REPSCRD" : ZM="REPRAT1" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="REPSCRD" : ZM="REPRAT2" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="REPSCRD" : ZM="REPCOE"  : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- Début prestation, Fin prestation, Nbre périodes, Type période
     If   [M:SLI3]SVCDATCODD > 1 TZONE(IZON)="STRDAT"
                                 TMOD(IZON) =[M:SLI3]SVCDATCODD
                                 IZON+=1
                                 TZONE(IZON)="ENDDAT"
                                 TMOD(IZON) =[M:SLI3]SVCDATCODD
                                 IZON+=1
                                 TZONE(IZON)="PERNBR"
                                 TMOD(IZON) =[M:SLI3]SVCDATCODD
                                 IZON+=1
                                 TZONE(IZON)="PERTYP"
                                 TMOD(IZON) =[M:SLI3]SVCDATCODD
                                 IZON+=1
     Endif
     If   [M:SLI3]SVCDATCODD = 1 | [M:SLI3]SVCDATCODD = 2
        ZT="SVCDATSCRD" : ZM="STRDAT" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="SVCDATSCRD" : ZM="ENDDAT" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="SVCDATSCRD" : ZM="PERNBR" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="SVCDATSCRD" : ZM="PERTYP" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- type de ligne
     If   [M:SLI4]LINTYPCOD = 1 TZONE(IZON)="LINTYP"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="LINTYPSCR" : ZM="LINTYP" : Gosub TABLEAU_FICHE From SUBSLX
     Endif

     #---- gratuit
     If   [M:SLI4]FOCFLGCOD = 1 TZONE(IZON)="FOCFLG"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="FOCFLGSCR" : ZM="FOCFLG" : Gosub TABLEAU_FICHE From SUBSLX
     Endif

     #---- Flux physique
     If dim([M:SLI3]FLOPHYCODD)>0
         If   [M:SLI3]FLOPHYCODD>1  TZONE(IZON)="EECFLOPHY"
                                    TMOD(IZON) =[M:SLI3]FLOPHYCODD
                                    IZON+=1
         Endif
         If   [M:SLI3]FLOPHYCODD=1 | [M:SLI3]FLOPHYCODD=2
            ZT="FLOPHYSCRD" : ZM="EECFLOPHY" : Gosub TABLEAU_FICHE From SUBSLX
         Endif
     Endif

     # 71065 : PJT
     #---- Affaire
     If dim([M:SLI3]PJTCODD)>0
         If   [M:SLI3]PJTCODD>1  TZONE(IZON)="DPJT"
                                    TMOD(IZON) =[M:SLI3]PJTCODD
                                    IZON+=1
         Endif
         If   [M:SLI3]PJTCODD=1 | [M:SLI3]PJTCODD=2
            ZT="PJTSCRD" : ZM="DPJT" : Gosub TABLEAU_FICHE From SUBSLX
         Endif
     Endif
     # 71065 : PJT

     #---- sections analytiques
#     If [M]INVTYP=2
#        For I=0 To dim([M:SLA1]CCECODD)-1
#           If [M:SLA1]CCECODD(I) > 1 TZONE(IZON)="CCE"+num$(I+1)
#                                     TMOD(IZON) =[M:SLA1]CCECODD(I)
#                                     IZON+=1
#           Endif
#           If [M:SLA1]CCECODD(I) = 1 | [M:SLA1]CCECODD(I) = 2
#              ZT="CCESCRD" : ZM="CCE"+num$(I+1) : ZI=I
#              Gosub TABLEAU_FICHE From SUBSLX
#           Endif
#        Next I
#     Else
#        For I=0 To dim([M:SLI1]CCECODD)-1
#           If [M:SLI1]CCECODD(I) > 1 TZONE(IZON)="CCE"+num$(I+1)
#                                     TMOD(IZON) =[M:SLI1]CCECODD(I)
#                                     IZON+=1
#           Endif
#           If [M:SLI1]CCECODD(I) = 1 | [M:SLI1]CCECODD(I) = 2
#              ZT="CCESCRD" : ZM="CCE"+num$(I+1) : ZI=I
#              Gosub TABLEAU_FICHE From SUBSLX
#           Endif
#        Next I
#     Endif
     If [M:DST]CCESCR>1
       For I=0 To 19
         TZONE(IZON)="CCE"+num$(I+1)
         TMOD(IZON) =9
         TINT(IZON) =num$([M:DST]CCESCR)
         IZON+=1
       Next I
     Endif

     If   [M:SLI4]AMTCOD    = 1 TZONE(IZON)="INVNOT"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="INVATI"
                                TMOD(IZON) =3
                                IZON+=1
     Endif

#     If GFONCTION="GESSLI"
     If [M]INVTYP<>2
        # Si facture, traitement des zones stock sorties
        #---- Lot
        If   dim([M:SLS1]LOTCOD) > 0
          If  [M:SLS1]LOTCOD > 1 TZONE(IZON)="LOT"
                                     TMOD(IZON) =[M:SLS1]LOTCOD
                                     IZON+=1
          Endif
          If   [M:SLS1]LOTCOD = 1 | [M:SLS1]LOTCOD = 2
             ZT="LOTSCR" : ZM="LOT" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
        Endif

        #---- Sous-Lot
        If   dim([M:SLS1]SLOCOD) > 0
          If  [M:SLS1]SLOCOD > 1 TZONE(IZON)="SLO"
                                     TMOD(IZON) =[M:SLS1]SLOCOD
                                     IZON+=1
          Endif
          If   [M:SLS1]SLOCOD = 1 | [M:SLS1]SLOCOD = 2
             ZT="SLOSCR" : ZM="SLO" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
        Endif

        #---- Statut
        If   dim([M:SLS1]AQRCOD) > 0
          If  [M:SLS1]AQRCOD > 1 TZONE(IZON)="STA"
                                     TMOD(IZON) =[M:SLS1]AQRCOD
                                     IZON+=1
          Endif
          If   [M:SLS1]AQRCOD = 1 | [M:SLS1]AQRCOD = 2
             ZT="AQRSCR" : ZM="STA" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
        Endif

        #---- Emplacement
        If   dim([M:SLS1]LOCCOD) > 0
          If  [M:SLS1]LOCCOD > 1 TZONE(IZON)="LOC"
                                     TMOD(IZON) =[M:SLS1]LOCCOD
                                     IZON+=1
          Endif
          If   [M:SLS1]LOCCOD = 1 | [M:SLS1]LOCCOD = 2
             ZT="LOCSCR" : ZM="LOC" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
        Endif

        #---- Série début
        If   dim([M:SLS1]SERCOD) > 0
          If  [M:SLS1]SERCOD > 1 TZONE(IZON)="SERNUM"
                                     TMOD(IZON) =[M:SLS1]SERCOD
                                     IZON+=1
          Endif
          If   [M:SLS1]SERCOD = 1 | [M:SLS1]SERCOD = 2
             ZT="SERSCR" : ZM="SERNUM" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
        Endif

        #---- Série fin
        If   dim([M:SLS1]SERECOD) > 0
          If  [M:SLS1]SERECOD > 1 TZONE(IZON)="SERNUMF"
                                     TMOD(IZON) =[M:SLS1]SERECOD
                                     IZON+=1
          Endif
          If   [M:SLS1]SERECOD = 1 | [M:SLS1]SERECOD = 2
             ZT="SERESCR" : ZM="SERNUMF" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
        Endif

        #---- Dépôt
        If dim([M:SLS1]WRHCOD1)>0
           If [M:SLS1]WRHCOD1>1  TZONE(IZON)="WRH"
                                 TMOD(IZON) =[M:SLS1]WRHCOD1
                                 IZON+=1
           Endif
           If [M:SLS1]WRHSCR1>1  TZONE(IZON)="WRH"
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SLS1]WRHSCR1)
                                 IZON+=1
           Endif
        Endif

        #---- Identifiant 1
        If   dim([M:SLS1]IDECOD01) > 0
          If  [M:SLS1]IDECOD01 > 1 TZONE(IZON)="PALNUM"
                                     TMOD(IZON) =[M:SLS1]IDECOD01
                                     IZON+=1
          Endif
          If   [M:SLS1]IDECOD01 = 1 | [M:SLS1]IDECOD01 = 2
             ZT="IDESCR01" : ZM="PALNUM" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
        Endif

        #---- Identifiant 2
        If   dim([M:SLS1]IDECOD02) > 0
          If  [M:SLS1]IDECOD02 > 1 TZONE(IZON)="CTRNUM"
                                     TMOD(IZON) =[M:SLS1]IDECOD02
                                     IZON+=1
          Endif
          If   [M:SLS1]IDECOD02 = 1 | [M:SLS1]IDECOD02 = 2
             ZT="IDESCR02" : ZM="CTRNUM" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
        Endif

        #---- Désigation mouvement
        If   dim([M:SLS1]MVTDESCOD) > 0
          If  [M:SLS1]MVTDESCOD > 1 TZONE(IZON)="MVTDES"
                                     TMOD(IZON) =[M:SLS1]MVTDESCOD
                                     IZON+=1
          Endif
          If   [M:SLS1]MVTDESCOD = 1 | [M:SLS1]MVTDESCOD = 2
             ZT="MVTDESSCR" : ZM="MVTDES" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
        Endif

        #---- Désactivation des zones stock entrées pour les factures
        Gosub SIH4_INV
     Else
         # Gestion des avoirs : génération des écrans et fenêtres de stock
         Gosub TRT_CHAMP_DOC From SUBETR
     Endif
     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

Endif

## 8 dans param WCTLFCY de l'écran de base SIH4
## si section ana en mode fiche uniquement (contrôle non bloquant)
#Gosub PARAM_CTRL_CCE_AV
#If GOK<1 : Return : Endif
Local Char NBRC_MSK   (12) : NBRC_MSK=MFROM
Local Char NBRC_NBLIG (12) : NBRC_NBLIG="NBLIG"
Gosub NBR_COL_AV From SUBSLX   : If GOK<1 Return Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR


If RETOUR<>0 GOK=0 : Return : Endif

Gosub NBR_COL_AP From SUBSLX   : If GOK<1 Return Endif

#---- suppression ou génération fenêtre AWINDOW
If ACTION="ANNULE"
  Gosub TRT_SUP_FEN From SUBSLX
Else
  Gosub TRT_GEN_FEN From SUBSLX
Endif
If GOK<1 : Return : Endif
#----

#If GFONCTION="GESSLA"
If [M]INVTYP=2
    #--- Génération des écrans et fenêtres de stock
    WNOMOBJ="SIH"
    WNOMTRS=[M:SLI0]STRNUM
    WACSCOD=[M:SLI0]ACSCOD
#    WLIBEL =[M:SLI0]STRDES
    Local Char WLIBEL (40)
    Call LECTEXTRA (WLIBEL,"SALTRS","DESAXX",num$([M:SLI0]STRTYP),[M:SLI0]STRNUM) From ATEXTRA
    WENAFLG=[M:SLI0]ENAFLG
    WNUM   =2
    Gosub TRT_ECRAN_STO From SUBETR
Endif

#------------------- écran SIH4INV ou SIH4CNO --------------------#
# Creation des ecrans SIH4 specifique aux factures et avoirs      #
# nécessaire pour le traitements de génération factures GENSIH    #
#            pour les imports                                     #
#-----------------------------------------------------------------#
Local Char    ZT : # nom de zone dans table transaction
Local Char    ZM : # nom de zone dans le masque
Local Integer ZI : # pour les zones indicées

If ACTION<>"ANNULE"
   MFROM="SIH4"
#   If GFONCTION="GESSLA"
   If [M]INVTYP=2
      MTO="WSIH4CNO"
    Else
      MTO="WSIH4INV"
   Endif

   Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON

   If [M]INVTYP<>2 : Gosub SIH4_INV : Endif
#   If GFONCTION="GESSLI" : Gosub SIH4_INV : Endif

   Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR

   If RETOUR<>0 GOK=0 : Return : Endif
Endif

Return

######################################################################################
Subprog EDD_FIELDS(IINVTYPFAC)
Value Integer IINVTYPFAC

  # FGR 10/04/2015 : X3SUIVI105605
  If IINVTYPFAC = 2 Then
    Chgfmt [M:SLI3]ECCCOD  With "-LA35:15X"
    Chgfmt [M:SLI3]ECCSCR  With "-LA99:15X"
    Chgfmt [M:SLI3]ECCCODMIN  With "-LA35:15X"
    Chgfmt [M:SLI3]ECCSCRMIN  With "-LA99:15X"
  Else
    Chgfmt [M:SLI3]ECCCOD  With "LA35:15X"
    Chgfmt [M:SLI3]ECCSCR  With "LA99:15X"
    Chgfmt [M:SLI3]ECCCODMIN  With "LA35:15X"
    Chgfmt [M:SLI3]ECCSCRMIN  With "LA99:15X"
  Endif
End

#----------------------------------------------------------------------------#
# desactivation des zones stocks entrées pour les factures
# desactivation du champs AMTLIN pour les facture
#----------------------------------------------------------------------------#
$SIH4_INV
        TZONE(IZON)="BPSLOT"
        TMOD(IZON) =3
        IZON+=1
        TZONE(IZON)="NBSLO"
        TMOD(IZON) =3
        IZON+=1
        TZONE(IZON)="SLOF"
        TMOD(IZON) =3
        IZON+=1
        TZONE(IZON)="LOCTYP"
        TMOD(IZON) =3
        IZON+=1
        TZONE(IZON)="PRIORD"
        TMOD(IZON) =3
        IZON+=1
        TZONE(IZON)="AMTLIN"
        TMOD(IZON) =3
        IZON+=1
        # X3-69438 : LPN - Customer return & credit note / X3-75881 (LCC 02/03718)
        TZONE(IZON)="TCTRNUM"
        TMOD(IZON) =3
        IZON+=1
#        TZONE(IZON)="LPNNUM"
#        TMOD(IZON) =3
#        IZON+=1
        # End X3-69438/X3-75881 (LCC 01/03/18)
        #### X3-81835  : LPN - sales Issues documents / X3-81999 (LCC 20/03/18)
        If dim([M:SLS1]LPNCOD)>0
          If [M:SLS1]LPNCOD>1    TZONE(IZON)="LPNNUM"             : # Numéro de contenant
                                 TMOD(IZON) =[M:SLS1]LPNCOD
                                 IZON+=1
          Endif
          If [M:SLS1]LPNSCR>1    TZONE(IZON)="LPNNUM"             : # Numéro de contenant
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SLS1]LPNSCR)
                                 IZON+=1
          Endif
        Endif
        #### End X3-81835  : LPN - sales Issues documents / X3-81999 (LCC 20/03/18)
Return

