#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGPRESAL07   Pre-migration retour                        Module Ventes #
#                                                                          #
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête retour   : SRETURN                                                #
# ------------------------                                                 #
# Gestion des infos douanières                                             #
#                                                                          #
# Migration en V11 :            : # Issue X3-90233                         #
# ---------------                                                          #
# Entête retour   : SRETURN                                                #
# -------------------------                                                #
# Alim. PJT à partir du champ PJT de la 1ère livraison                     #
# Détail retour   : SRETURND                                               #
# -------------------------                                                #
# Alim. PJT à partir du champ PJT de la livraison                          #
#                                                                          #
# Pour toutes les versions                                                 #
# ------------------------                                                 #
# Détail retour   : SRETURND                                               #
# --------------------------                                               #
# Alim. STOFCY à partir de l'entête si différence                          #
#                                                                          #
############################################################################
# Issue X3-90233 - 20180807 by LD : Error in processes UUMGPRESALxx

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPRESAL07") From LECFIC
  Endif

  Call MAJ_UUMGPRESAL07(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGPRESAL07(DOSSIER)
Value Char DOSSIER

Local Integer ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif
# Issue 106947 - 20150811 by LD

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N= no module
  End
Endif

#----- Récupération du n° de version
# Issue X3-90233
#Local Char VERSION
#Call VERSION (DOSSIER,VERSION) From DOSSUB
#If val(VERSION)=0
#  # N° de version incorrecte
#  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL07",7,ERR) From TRTMIG : #7=Erreur
#  End
#Endif
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL07",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif
# End issue X3-90233

Call ECR_TIME("UUMGPRESAL07 Sales Return Process : Update SRETURN") From DOSSUB
Call ECR_TRACE("UUMGPRESAL07 : Process Start on : "+DOSSIER,0) From GESECRAN

Gosub MIG_OUVRE From TRTMIG

Local Integer EXE_SQL
#EXE_SQL = 1

If EXE_SQL
  # Mise à jour des champs directement par requête SQL

  # Passage en V6
  If VERSION<GMIGX3VER60
    #1- ajouter la colonne dans la table SRETURN
    #--------------- Field ADDITION  ----------#
    Call MIGINDCRE (DOSSIER,"SRETURN","","BPIEECNUM","A",20,ERR) From TRTMIG
    If ERR : Goto FIN : Endif

    Gosub TRT_SQL1
  Endif

Else
  # Mise à jour des champs par boucle de lecture de la table et maj

  # Passage en V6
  If VERSION<GMIGX3VER60
    #1- ajouter la colonne dans la table SRETURN
    #2- ajouter un index unique
    # Ajout du champ BPIEECNUM : Identification CEE et de la clé de parcours qui va bien
    Call MIGINDCRE (DOSSIER,"SRETURN","BPCORD+BPAADD+SRHNUM","BPIEECNUM","A",20,ERR) From TRTMIG
    If ERR : Goto FIN : Endif

    Gosub TRT_X3_60

    #--------------- Suppression index ----------#
    Call MIGINDDEL (DOSSIER,"SRETURN",ERR) From TRTMIG
    If ERR : Goto FIN : Endif
  Endif


  # Issue X3-90233
  # Passage en V11
  If VERSION<GMIGX3VER110
    # 1- ajouter les colonnes dans la table SRETURND
    # Ajout du champ PJT : Code affaire
    Call MIGADDCOL (DOSSIER,"SRETURND","PJT","A",40,1,ERR) From TRTMIG
    If ERR : Goto FIN : Endif

    Gosub TRT_X3_110
  Endif
  # Issue X3-90233

Endif

# Mise à jour des champs directement par une requête SQL
Gosub TRT_SQL2

$FIN
Call ECR_TIME("UUMGPRESAL07 : Sales Return Process END.")  From DOSSUB
End

############################################################################
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête retour   : SRETURN                                                #
# ---------------------                                                    #
# Gestion des infos douanières                                             #
############################################################################
$TRT_X3_60

# 2- alimenter les nouvelles colonnes si vide
# -------------------------------------------
#----- Ouverture des fichiers -----#
If clalev([F:SRH]) : Close File [SRH] : Endif
If clalev([F:SRH])  = 0 : Local File =DOSSIER+".SRETURN"     [SRH]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPD])  = 0 : Local File =DOSSIER+".BPDLVCUST"   [BPD]  : Endif
If clalev([F:TMD])  = 0 : Local File =DOSSIER+".TABMODELIV"  [TMD]  : Endif

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer COMPTEUR
Local Integer STOP, NB
Local Char    CRITERE(250)
Local Char    ACLE1, ACLE2, ACLE3
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST
Filter [SRH] Order By Key CLE=[F:SRH]BPCORD;[F:SRH]BPAADD;[F:SRH]SRHNUM

$LOOP60_SAL07
Raz NB
If STOP=1
 STOP = 2
 CRITERE  = "[F:SRH]BPCORD=ACLE1 & [F:SRH]BPAADD=ACLE2 & [F:SRH]SRHNUM>ACLE3"
Elsif STOP=2
 STOP = 3
 CRITERE  = "[F:SRH]BPCORD=ACLE1 & [F:SRH]BPAADD>ACLE2"
Elsif STOP=3
 STOP = 0
 CRITERE  = "[F:SRH]BPCORD>ACLE1"
Else
 CRITERE  = "1=1"
Endif

Trbegin [SRH]
GOK = 1

For [SRH]CLE Where evalue(CRITERE)

  If  [F:SRH]EECICT<>'' & [F:SRH]EECTRN<>0 & (dim([F:SRH]EECLOC)<0 | [F:SRH]EECLOC<>0) & (dim([F:SRH]BPIEECNUM)<0 | [F:SRH]BPIEECNUM<>'')
      Goto SUITE_LOOP60_SAL07
  Endif

  # --- alimentation des champs
  Gosub RECUP_BPR
  # --- alimentation des champs
  Gosub RECUP_BPD

  Rewrite [F:SRH]
  If fstat
    Call ECR_TRACE("File SRETURN(SRHNUM)"-[F:SRH]SRHNUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:SRH]BPCORD
    ACLE2 = [F:SRH]BPAADD
    ACLE3 = [F:SRH]SRHNUM
    STOP=1
    Break
  Endif

$SUITE_LOOP60_SAL07
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP60_SAL07
  Endif
Endif

$FIN60_SAL07
Gosub UNSET_FIRST From TRTFIRST
Filter [SRH]
Close Local File [SRH], [BPR], [BPD], [TMD]

Call ECR_TIME("UUMGPRESAL07 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB

Return

########################################################################
$RECUP_BPR

    If GACTDEB=2 & [F:SRH]BPIEECNUM=""
        # --- Alimentation n° d'identification CEE
        If [F:BPR]BPRNUM<>[F:SRH]BPCINV & [F:SRH]BPCINV<>""
           Read [F:BPR]BPR0 = [F:SRH]BPCINV : If fstat Raz [BPR] Endif
        Endif
        [F:SRH]BPIEECNUM=[F:BPR]EECNUM
    Endif

Return

#########################################################################
$RECUP_BPD

      If [F:SRH]EECICT="" | (GACTDEB=2 & ([F:SRH]EECLOC=0 | [F:SRH]EECTRN=0))
          # --- Alimentation incoterm, lieu de transport CEE et mode de transport CEE
          If [F:BPD]BPCNUM<>[F:SRH]BPCORD | [F:BPD]BPAADD<>[F:SRH]BPAADD
             Read [F:BPD]BPD0 = [F:SRH]BPCORD;[F:SRH]BPAADD : If fstat Raz [BPD] Endif
          Endif
          If [F:SRH]EECICT="" [F:SRH]EECICT=[F:BPD]EECICT Endif
          If GACTDEB=2
             If [F:SRH]EECLOC=0 [F:SRH]EECLOC=[F:BPD]EECLOC Endif
             If [F:SRH]EECTRN=0 & [F:BPD]MDL<>""
                If [F:TMD]MDL<>[F:BPD]MDL
                   Read [TMD]TMD0=[F:BPD]MDL
                   If fstat Raz [TMD] : Endif
                Endif
                [F:SRH]EECTRN=[F:TMD]EECTRN
             Endif
          Endif
      Endif

Return

############################################################################
# Migration en V11 :              : # Issue X3-90233                       #
# ---------------                                                          #
# Entête retour   : SRETURN                                                #
# ---------------------                                                    #
# Alim. PJT à partir du champ PJT de la 1ère livraison                     #
# Détail retour   : SRETURND                                               #
# -------------------------                                                #
# Alim. PJT à partir du champ PJT de la livraison                          #
############################################################################
$TRT_X3_110                       : # Issue X3-90233

# 2- alimenter les nouvelles colonnes si vide
# -------------------------------------------
#----- Ouverture des fichiers -----#
If clalev([F:SRH]) : Close File [SRH] : Endif
If clalev([F:SRD]) : Close File [SRD] : Endif
If clalev([F:SRH])  = 0 : Local File =DOSSIER+".SRETURN"     [SRH]  : Endif
If clalev([F:SRD])  = 0 : Local File =DOSSIER+".SRETURND"    [SRD]  : Endif
If clalev([F:SDH])  = 0 : Local File =DOSSIER+".SDELIVERY"   [SDH]  : Endif

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer COMPTEUR
Local Integer STOP, NB
Local Char    CRITERE(250)
Local Char    ACLE1
Raz COMPTEUR, STOP, CRITERE

Local Integer WLIG

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP110_SAL07                    : # Issue X3-90233

Raz NB
If STOP=1
 STOP = 0
 CRITERE = "[F:SRH]SRHNUM>ACLE1"
Else
 CRITERE = "1=1"
Endif

Trbegin [SRH]
GOK = 1

For [SRH]SRH0 Where evalue(CRITERE)

  WLIG=0
  For [SRD] Where SRHNUM=[F:SRH]SRHNUM & SDHNUM<>""
    Gosub MAJ110_SRHSRDSDH        : # Issue X3-90233
    If GOK<1 : Break : Endif
    Rewrite [F:SRD]
    If fstat
      Call ECR_TRACE("File SRETURND(SRHNUM/SRDLIN)"-[F:SRD]SRHNUM-num$([F:SRD]SRDLIN)+", Error ="-num$(fstat),1) From GESECRAN
      GOK=0 : Break
    Endif
  Next
  If GOK<1 : Break : Endif

  If WLIG=1
    Rewrite [F:SRH]
    If fstat
      Call ECR_TRACE("File SRETURN(SRHNUM)"-[F:SRH]SRHNUM+", Error ="-num$(fstat),1) From GESECRAN
      GOK=0 : Break
    Endif
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:SRH]SRHNUM
    STOP=1
    Break
  Endif

$SUITE_LOOP110_SAL07              : # Issue X3-90233
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP110_SAL07            : # Issue X3-90233
  Endif
Endif

$FIN110_SAL07                     : # Issue X3-90233
Gosub UNSET_FIRST From TRTFIRST
Close Local File [SRH], [SRD], [SDH]

Call ECR_TIME("UUMGPRESAL07 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB

Return

########################################################################
# Nouveaux Champs entête et détail à alimenter à partir de la V11         : # Issue X3-90233
########################################################################
$MAJ110_SRHSRDSDH                 : # Issue X3-90233
  If [F:SDH]SDHNUM<>[F:SRD]SDHNUM
    Read [F:SDH]SDH0 = [F:SRD]SDHNUM : If fstat Raz [SDH] Endif
  Endif
  # Code affaire entête retour = Code affaire de la 1ère livraison liée à une ligne retour
  If WLIG=0 [F:SRH]PJT=[F:SDH]PJT : WLIG=1 Endif

  # Code affaire ligne retour = Code affaire de la livraison liée
  [F:SRD]PJT = [F:SDH]PJT
Return

########################################################################
$TRT_SQL1

#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:SRH]) : Close File [SRH] : Endif
If clalev([F:SRH])  = 0 : Local File =DOSSIER+".SRETURN"     [SRH]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPD])  = 0 : Local File =DOSSIER+".BPDLVCUST"   [BPD]  : Endif
If clalev([F:TMD])  = 0 : Local File =DOSSIER+".TABMODELIV"  [TMD]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [SRH]
GOK = 1

# Passage en V6
If VERSION<GMIGX3VER60
  Gosub TRT_SQL11_60
Endif

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SRH]
Return
########################################################################
$TRT_SQL11_60
Return
########################################################################
$TRT_SQL2

#----- Ouverture des fichiers -----#
If clalev([F:SRH]) : Close File [SRH] : Endif
If clalev([F:SRD]) : Close File [SRD] : Endif
If clalev([F:SRH])  = 0 : Local File =DOSSIER+".SRETURN"      [SRH]  : Endif
If clalev([F:SRD])  = 0 : Local File =DOSSIER+".SRETURND"     [SRD]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [SRD]
GOK = 1

# Suppression des incohérences entre tables avant migration
# A faire pour toutes les versions
Gosub TRT_SQL21 : # Mise à jour STOFCY SRETURND à partir de STOFCY SRETURN

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SRH],[SRD]
Return
########################################################################
# Mise à jour STOFCY SRETURND à partir de STOFCY SRETURN
########################################################################
$TRT_SQL21
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SRETURND SET STOFCY_0="
REQSQL(1)="(SELECT SRH.STOFCY_0 FROM"-DOSSIER+".SRETURN SRH WHERE SRH.SRHNUM_0=SRETURND.SRHNUM_0)"
REQSQL(2)=" WHERE SRETURND.STOFCY_0<>(SELECT SRH.STOFCY_0 FROM"-DOSSIER+".SRETURN SRH WHERE SRH.SRHNUM_0=SRETURND.SRHNUM_0) "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return
###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK=0
Resume

