#########################################################################
# STKLOTBLAN  : Affecte le lot blanc à la ligne en cours
#
# Attention: Cette action ne peut-être appelée que sur le champ LOT ou LOTAFF
#########################################################################
Subprog STKLOTBLAN( VALEUR )
Variable Char VALEUR

Local Char LABR1 : LABR1 = func STKLIB.MSKDEF
Local Integer WI
Local Char LABR
WI = len(LABR1)
LABR = mid$(LABR1,2,WI-2)



    If evalue("dim([M:"+LABR+"]GESLOTAFF)")>0
        [M]GESLOTAFF(nolign-1) = "B"
        Raz [M]LOTAFF(nolign-1)
        Affzo LOTAFF(nolign-1)
        Raz VALEUR
        If evalue("dim([M:"+LABR+"]SLOAFF)")>0
            Raz [M]SLOAFF(nolign-1)
            Affzo SLOAFF(nolign-1)
        Endif
        If evalue("dim([M:"+LABR+"]BPSLOTAFF)")>0
            Raz [M]BPSLOTAFF(nolign-1)
            Affzo BPSLOTAFF(nolign-1)
        Endif
        mkstat = 99
    Elsif evalue("dim([M:"+LABR+"]GESLOT)")>0
        [M]GESLOT(nolign-1) = "B"
        Raz [M]LOT(nolign-1)
        Affzo LOT(nolign-1)
        Raz VALEUR
        If evalue("dim([M:"+LABR+"]BPSLOT)")>0
            Raz [M]BPSLOT(nolign-1)
            Affzo BPSLOT(nolign-1)
        Endif
        If evalue("dim([M:"+LABR+"]SLO)")>0
            Raz [M]SLO(nolign-1)
            Affzo SLO(nolign-1)
        Endif
        mkstat=99
    Endif
End
############################################################
# Sous programme d'affichage des unités d'un article en tableau
# LITM   = Article
# LMSK   = Classe écran (ex "[M:VUNI]")
# LTAB   = Variable bas tableau (Ex NBLIG)
# LFLD   = Tableau du nom des champs (champ vide si valeurs par défaut)
#
# Les noms des champs par défaut sont les suivant
# D'autres noms peuvent être définis par le paramètre LFLD dans le même ordre
#
# UOMTXT    = Type d'unité
# UOM       = Unité
# UOMDES    = Intitulé unité
# UOMSTUCOE = Coefficient en US
# DACUOMCOE = Code modifable (menu local 1)
# UOMLBEFMT = Format étiquette
# UOMRUL    = Code déstockage menu local 2706
#
Subprog STKVISUNI(LITM,LMSK,LTAB,LFLD)
Value Char    LITM
Value Char    LMSK
Value Char    LTAB
Value Char    LFLD()
#
Local Char     W_FLD(10)(07)
Local Char     W_TXT
Local Char     W_UOM(GLONUOM)
Local Decimal  W_COE
Local Shortint W_DAC
Local Char     W_LBE
Local Shortint W_RUL
#
Local Integer  W_I, W_J, W_K
Local Char     W_INT(23)(07)
#
If clalev([F:TUN]) = 0 : Local File TABUNIT    [TUN] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA    [AXX] : Endif
#
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If [F:ITM]ITMREF <> LITM
  Read [ITM]ITM0=LITM
  If fstat Raz [F:ITM] Endif
Endif
# Nom des champs par défaut
W_FLD(0) = "UOMTXT"
W_FLD(1) = "UOM"
W_FLD(2) = "UOMDES"
W_FLD(3) = "UOMSTUCOE"
W_FLD(4) = "DACUOMCOE"
W_FLD(5) = "UOMLBEFMT"
W_FLD(6) = "UOMRUL"
# Surcharge par d'éventuels autres noms de champs
If LFLD(0) <> ""
  For W_I = 0 To dim(LFLD)-1
    W_FLD(W_I) = LFLD(W_I)
  Next W_I
Endif
#
Call TEXTE(2076, W_INT(0)) From OBJDIV
Call TEXTE(2084, W_INT(1)) From OBJDIV
Call TEXTE(1858, W_INT(2)) From OBJDIV
Call TEXTE(2994, W_INT(3)) From OBJDIV
Call TEXTE(2080, W_INT(4)) From OBJDIV
Call TEXTE(13671,W_INT(5)) From OBJDIV
Call TEXTE(5202, W_INT(6)) From OBJDIV
W_K = 0
#
W_TXT = W_INT(0)
W_UOM = [F:ITM]STU
W_COE = 1
W_DAC = 0
W_LBE = [F:ITM]STULBEFMT
W_RUL = 0
Gosub LOA_LIGUOM
W_K += 1
#
If [F:ITM]WEU <> ""
  W_TXT = W_INT(1)
  W_UOM = [F:ITM]WEU
  W_COE = [F:ITM]ITMWEI
  W_DAC = 0
  W_LBE = ""
  W_RUL = 0
  Gosub LOA_LIGUOM
  W_K += 1
Endif
#
If [F:ITM]PUU <> ""
  W_TXT = W_INT(2)
  W_UOM = [F:ITM]PUU
  W_COE = [F:ITM]PUUSTUCOE
  W_DAC = [F:ITM]DACPUUCOE
  W_LBE = ""
  W_RUL = 0
  Gosub LOA_LIGUOM
  W_K += 1
Endif
If [F:ITM]SAU <> ""
  W_TXT = W_INT(3)
  W_UOM = [F:ITM]SAU
  W_COE = [F:ITM]SAUSTUCOE
  W_DAC = [F:ITM]DACSAUCOE
  W_LBE = ""
  W_RUL = 0
  Gosub LOA_LIGUOM
  W_K += 1
Endif
If [F:ITM]SSU <> ""
  W_TXT = W_INT(4)
  W_UOM = [F:ITM]SSU
  W_COE = [F:ITM]SSUSTUCOE
  W_DAC = 0
  W_LBE = ""
  W_RUL = 0
  Gosub LOA_LIGUOM
  W_K += 1
Endif
If [F:ITM]EEU <> ""
  W_TXT = W_INT(5)
  W_UOM = [F:ITM]EEU
  W_COE = [F:ITM]EEUSTUCOE
  W_DAC = 0
  W_LBE = ""
  W_RUL = 0
  Gosub LOA_LIGUOM
  W_K += 1
Endif
W_J = 1
For W_I = 0 To dim([F:ITM]PCU)-1
  If [F:ITM]PCU(W_I) <> ""
    W_TXT = W_INT(6)-num$(W_J)
    W_UOM = [F:ITM]PCU      (W_I)
    W_COE = [F:ITM]PCUSTUCOE(W_I)
    W_DAC = [F:ITM]DACPCUCOE(W_I)
    W_LBE = [F:ITM]LBEFMT   (W_I)
    W_RUL = [F:ITM]PCURUL   (W_I)
    Gosub LOA_LIGUOM
    W_K += 1
    W_J += 1
  Endif
Next W_I
If evalue("dim("+LMSK+W_FLD(2)+") > 0")
  For W_I = 0 To W_K-1
    Read [TUN]TUN0=evalue(LMSK+W_FLD(1)+"(W_I)")
    If fstat = 0
      Read [AXX] AXX0="TABUNIT";"DESSHO";GLANGUE;[F:TUN]UOM;""
      If fstat  Raz [F:AXX] : Endif
      Assign LMSK+W_FLD(2)+"(W_I)" With [F:AXX]TEXTE
    Else
      Assign LMSK+W_FLD(2)+"(W_I)" With "?"
    Endif
  Next W_I
Endif
#
Assign LMSK+LTAB With W_K
End
############################################################
$LOA_LIGUOM
If evalue("dim("+LMSK+W_FLD(0)+")>0")
  Assign LMSK+"UOMTXT   (W_K)" With W_TXT
Endif
If evalue("dim("+LMSK+W_FLD(1)+")>0")
  Assign LMSK+"UOM      (W_K)" With W_UOM
Endif
If evalue("dim("+LMSK+W_FLD(3)+")>0")
  Assign LMSK+"UOMSTUCOE(W_K)" With W_COE
Endif
If evalue("dim("+LMSK+W_FLD(4)+")>0")
  Assign LMSK+"DACUOMCOE(W_K)" With W_DAC
Endif
If evalue("dim("+LMSK+W_FLD(5)+")>0")
  Assign LMSK+"UOMLBEFMT(W_K)" With W_LBE
Endif
If evalue("dim("+LMSK+W_FLD(6)+")>0")
  Assign LMSK+"UOMRUL   (W_K)" With W_RUL
Endif
Return
############################################################
# Sous programme d'affichage du détail des cumuls stocks
# La classe donnée par LITV doit être chargée
# LITV = Classe ITV            ex "[F:ITV]"
# LITT = Classe ITV pour cumul ex "[F:ITV1]"
# LMSK = Classe écran          ex "[M:VITF]"
# LTAB = Variable bas tableau  ex "NBLIG"
# LINT = Tableau des intitulés
#
# LOPT = Option 0 = Calcul des intitulés et affichage
#               1 = Calcul des intitulés seuls
#               2 = Affichage seul
#               3 = Cumul classe LITV sur LITT
# LCUM = Affichage cumuls 0 = oui
#                         1 = non
# Le chargement est fait dans les champs écrans de nom fixe suivant :
# INTFLD pour l'intitulé (Char)
# VALFLD pour la valeur  (Type de donnée QTY)
#
Subprog STKDETSTO(LITV,LITT,LMSK,LTAB,LINT,LOPT,LCUM)
Value    Char     LITV
Value    Char     LITT
Value    Char     LMSK
Value    Char     LTAB
Variable Char     LINT()
Value    Integer  LOPT
Value    Integer  LCUM
#
Local Char    W_FLD(10)(37)
Local Char    W_CUM(32)(09)
Local Char    W_RUB(30)
Local Decimal W_CUM1, W_CUM2, W_CUM3
Local Integer W_I, W_J, W_K, W_L, W_M
#
W_FLD(00) = "PHYSTO"
W_FLD(01) = "CTLSTO"
W_FLD(02) = "REJSTO"
W_FLD(03) = "PLFPHYSTO"
W_FLD(04) = "PLFCTLSTO"
W_FLD(05) = "PLFREJSTO"
W_FLD(06) = "*  20465"
W_FLD(07) = "BPRPHYSTO"
W_FLD(08) = "BPRCTLSTO"
W_FLD(09) = "BPRREJSTO"
W_FLD(10) = "SCOPHYSTO"
W_FLD(11) = "SCOCTLSTO"
W_FLD(12) = "SCOREJSTO"
W_FLD(13) = "*  20638"
W_FLD(14) = "** 20490"
W_FLD(15) = "** 20491"
W_FLD(16) = "** 20492"
W_FLD(17) = "SCCLNDSTO"
W_FLD(18) = "***06313"
W_FLD(19) = "PHYALL"
W_FLD(20) = "CTLALL"
W_FLD(21) = "REJALL"
W_FLD(22) = "*  20493"
W_FLD(23) = "SCOPHYALL"
W_FLD(24) = "SCOCTLALL"
W_FLD(25) = "SCOREJALL"
W_FLD(26) = "*  20494"
W_FLD(27) = "** 20469"
W_FLD(28) = "DETSHT"
W_FLD(29) = "GLOALL"
W_FLD(30) = "GLOSHT"
W_FLD(31) = "TRFSTO"
W_FLD(32) = "TRASTO"
W_FLD(33) = "ORDSTO"
W_FLD(34) = "SCCALL"
W_FLD(35) = "SALSTO"
W_FLD(36) = "WAISTO"
# Tableau pour cumuls
W_CUM(00) = "20465 000102030405"
W_CUM(01) = "20638 070809101112"
W_CUM(02) = "20490 00030710"
W_CUM(03) = "20491 01040811"
W_CUM(04) = "20492 02050912"
W_CUM(05) = "06313 00010203040507080910111217"
W_CUM(06) = "20493 192021"
W_CUM(07) = "20494 232425"
W_CUM(08) = "20469 192021232425"
#
If LOPT = 0 | LOPT = 1
  For W_I = 0 To dim(W_FLD)-1
    If W_I < dim(LINT)
      If left$(W_FLD(W_I),1) <> "*"
        Call TEXTFIC("ITMMVT",W_FLD(W_I),2,LINT(W_I)) From OBJDIV
      Else
        W_J = val(right$(W_FLD(W_I),4))
        Call TEXTE(W_J,LINT(W_I)) From OBJDIV
      Endif
    Else
      Break
    Endif
  Next W_I
Endif
#
If LOPT = 0 | LOPT = 2
  W_J = 0
  For W_I = 0 To dim(W_FLD)-1
    If left$(W_FLD(W_I),1) = "*" & LCUM = 0
      Assign LMSK+"INTFLD("+num$(W_J)+")" With left$(W_FLD(W_I),3)+LINT(W_I)
      W_CUM1 = 0
      W_CUM3 = 0
      W_M    = 0
      For W_K = 0 To dim(W_CUM)-1
        If left$(W_CUM(W_K),5) = right$(W_FLD(W_I),4)
          W_RUB = right$(W_CUM(W_K),7)
          While W_RUB <> ""
            W_L = val(left$(W_RUB,2))
            W_CUM2  = evalue(LITV+W_FLD(W_L))
            W_CUM1 += W_CUM2
            If W_M = 0 & W_CUM2 <> 0
              W_M = 1
              W_CUM3 = W_CUM2
            Endif
            W_RUB = right$(W_RUB,3)
          Wend
        Endif
      Next W_K
      If W_CUM1 <> 0 & W_CUM1 <> W_CUM3
        Assign LMSK+"VALFLD("+num$(W_J)+")" With W_CUM1
        W_J += 1
      Endif
    Else
      If evalue(LITV+W_FLD(W_I)+"<>0")
        Assign LMSK+"INTFLD("+num$(W_J)+")" With LINT(W_I)
        Assign LMSK+"VALFLD("+num$(W_J)+")" With evalue(LITV+W_FLD(W_I))
        W_J += 1
      Endif
    Endif
  Next W_I
  Assign LMSK+LTAB With W_J
Endif
#
If LOPT = 3
  For W_I = 0 To dim(W_FLD)-1
    If left$(W_FLD(W_I),1) <> "*"
      W_CUM1 = evalue(LITV+W_FLD(W_I))
      W_CUM2 = evalue(LITT+W_FLD(W_I))
      Assign LITT+W_FLD(W_I) With (W_CUM1+W_CUM2)
    Endif
  Next W_I
Endif
End


###############################################################################
# RAZLOC : Efface la zone LOC, et déréserve le n° de séquence LOCSEQ
###############################################################################
# Paramètres E+S : LOC    = zone LOC à effacer
#            E   : LOCSEQ = N° de séquence de réservation de l'emplacement
###############################################################################
Subprog RAZLOC(LOC, LOCSEQ)
Variable Char     LOC
Value    Integer  LOCSEQ

Local Integer LRET
    Raz LOC
    Call STKDELRES(LOCSEQ, "", "", LRET) From STKLOC

End

##################################################
# Affecte à un champ lot le prochain numéro de compteur
##################################################
# Paramètres S : AZC    = Zone courante (champ lot)
#
#            E : SITE   = Nom du site
#                DAT    = Date d'imputation
#                ITMREF = Référence article
##################################################
Subprog LOTNUMCPT(AZC,SITE,DAT,PITM)
Variable Char     AZC
Value    Char     SITE
Value    Date     DAT
Value    Char     PITM

Local Char    WLOT(GLONLOT) : WLOT = ""
Local Integer WRET          : WRET = 0
Local Integer LFOUND : Raz LFOUND        # Indique si la valeur en cours du compteur se trouve sur une autre ligne de détail
If AZC<>""
    End
Endif

If !clalev([F:STL])  Local File STOLOT    [STL]  Endif

If [F:ITM]ITMREF<>PITM  Read [ITM]ITM0=PITM      Endif

I = find (PITM,[M:ENTW]WITMREF)-1
If I>=0 & [M:ENTW]WLOTCOU(I)<>""
    Local Integer LWSTOSEQEX : LWSTOSEQEX=0
    If clalev([M:ENT]) | clalev([M:ENM])
        If sigma(0,[M]NBLIG-1,([M]LOTAFF(indcum)=[M:ENTW]WLOTCOU(I)) & (indcum<>nolign-1))
            LFOUND = 1
        Endif
        If clalev([M:ENT])
            LWSTOSEQEX = [M:ENT]WSTOSEQ
        Endif
    Endif
    # Pour calculer un nouveau n° de lot, il faut que le n° en cours soit utilisé sur une autre ligne de détail
    # ou sur une autre ligne de document, sinon, on récupère celui en cours
    If !LFOUND & !sigma(0,[M:ENTW]NBLIG-1,([M:ENTW]WSTOSEQ(indcum)<>0)&
&      ([M:ENTW]WSTOSEQ(indcum)<>LWSTOSEQEX)& ([M:ENTW]LOT([M:ENTW]NUMLIGLOT(indcum))=[M:ENTW]WLOTCOU(I)))
        AZC=[M:ENTW]WLOTCOU(I)
        End
    Endif
Endif

Call DEBTRANS From GLOCK
Trbegin ADOVAL

$NEW_LOT
# Calcul d'un nouveau n° de lot
Call NUMERO([F:ITM]LOTCOU,SITE,DAT,PITM,AZC,WRET) From SUBANM

If WRET = 1
    mkstat = 2
    GMESSAGE= [F:ITM]LOTCOU-":"-mess(29,196,1)
Elsif WRET = 2
    mkstat = 2
    GMESSAGE= [F:ITM]LOTCOU-":"-mess(30,196,1)
Else
    Read [STL]STL0(2)=PITM;AZC
    [G:STL]currlen = 0
    # Le lot existe déjà
    If !fstat Goto NEW_LOT Endif
Endif

If I<0
    I = find("", [M:ENTW]WITMREF)-1
    [M:ENTW]WITMREF(I) = PITM
Endif
[M:ENTW]WLOTCOU(I) = AZC
Commit

If !mkstat
    mkstat = 99    # Changer de champ à la suite de cette action
Endif

End

##################################################
# récupération compteur sur champ lot dest.
##################################################
# Paramètres S : AZC    = Zone courante (champ lot)
#
#            E : SITE   = Nom du site
#                DAT    = Date d'imputation
#                ITMREF = Référence article
##################################################
Subprog LOTNUMCPTD(AZC,SITE,DAT,PITM)
Variable Char     AZC
Value    Char     SITE
Value    Date     DAT
Value    Char     PITM

Local Char    WLOT(GLONLOT) : WLOT = ""
Local Integer WRET          : WRET = 0

If AZC <> "" : End : Endif

If [F:ITM]ITMREF<>PITM  Read [ITM]ITM0=PITM  Endif

Call DEBTRANS From GLOCK
Trbegin ADOVAL
# calcul d'un nouveau n° de lot
Call NUMERO([F:ITM]LOTCOU, SITE, DAT, PITM, AZC, WRET) From SUBANM

Case WRET
    When 1:    mkstat = 2
               GMESSAGE = [F:ITM]LOTCOU-":"-mess(29,196,1)
    When 2:    mkstat = 2
               GMESSAGE= [F:ITM]LOTCOU-":"-mess(30,196,1)
Endcase
Commit
End


###############################################################################
# STKLASSER: Renvoie le dernier numéro de série +1 de l'article passé en paramètre
###############################################################################
# Paramètres S : PSER = Résultat (vide si erreur ou acun n° existant)
#
#            E : PITM = Article
###############################################################################
Subprog STKLASSER(PSER,PITM)
Variable Char    PSER
Value    Char    PITM

Local Integer F, I, LRET
Local Char    LSERTMP(GLONSER)
Local Integer LWSTOSEQEX    # Numéro de séquence à exclure des recherches
If clalev([ENT])
    LWSTOSEQEX = [M:ENT]WSTOSEQ
Elsif !clalev([ENM])
    LWSTOSEQEX = [M]WSTOSEQ(nolign-1)
Endif

    Filter [STS] Where ITMREF=PITM
    Read [STS]STS0 Last
    PSER = [F:STS]SERNUM
    Filter [STS]
    If LRET
        Raz PSER
    Endif
    LSER = PSER
    If clalev([ENTW])
        F = find(PITM,[M:ENTW]ITMREF(0..[M:ENTW]NBLIG-1))
        Raz I
        While F>0
            I += F-1
            If [M:ENTW]WSTOSEQ(I)>0 & [M:ENTW]WSTOSEQ(I)<>LWSTOSEQEX & [M:ENTW]SERNUMF(I)>PSER
                PSER = [M:ENTW]SERNUMF(I)
            Endif
            I+=1
            F = find(PITM,[M:ENTW]ITMREF(I..[M:ENTW]NBLIG-1))
            I += F-1
        Wend
    Endif
    If clalev([ENT])
        PSER = max(PSER,max([M:ENT]SERNUMF(0..nolign-2)))
        PSER = max(PSER,max([M:ENT]SERNUMF(nolign..[M:ENT]NBLIG-1)))
    Endif
    If clalev([ENM])
        PSER = max(PSER,max([M:ENM]SERNUMF(0..nolign-2)))
        PSER = max(PSER,max([M:ENM]SERNUMF(nolign..[M:ENM]NBLIG-1)))
    Endif
    If PSER<>""
        Call PLUS_UN (PSER,PSER,LRET) From STKLIB
        If LRET
            Raz PSER
        Endif
    Endif
End


##################################################
Subprog STKCTRGAU(VALEUR)
Value    Char    VALEUR
# prévoir aussi l'option A du type de donnée GAU
If !clalev([GAU]) Local File GAUTACE [GAU] Endif

If VALEUR <> ""
 Read [GAU]GAU0 = VALEUR
 If !fstat & [F:GAU]TBL<>"STJTMP"
  GMESSAGE=mess(61,119,1)-"STJTMP"   : # La table déclenchante n'est pas STJTMP
  mkstat=2
 Endif
Endif

End

##################################################
Subprog STKASGAU(VALEUR,PGFY)
Variable Char    VALEUR
Value    Char    PGFY

Local Char LOPEIFA, LACCIFA

If clalev([F:ADW])=0 : Local File ADOVAL   [ADW] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif

mkstat=2
For [FCY]
    Look [FGR]FGR0 = PGFY;[F:FCY]FCY
    If !fstat | PGFY=""
        Call PARAM([F:FCY]FCY,"OPEIFA",LOPEIFA) From ADOVAL
        If val(LOPEIFA)<2
            Call PARAM([F:FCY]FCY,"ACCIFA",LACCIFA) From ADOVAL
            If val(LACCIFA)>=2
                mkstat=0
                Break
            Endif
        Endif
    Endif
Next
If mkstat=2
    Raz VALEUR
Endif
End

##################################################
Subprog STKASGAUS(VALEUR,PGFY)
Variable Char    VALEUR
Value    Char    PGFY

Local Char LOPEIFA, LACCIFA

If clalev([F:ADW])=0 : Local File ADOVAL   [ADW] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif

mkstat=2
For [FCY]
    Look [FGR]FGR0 = PGFY;[F:FCY]FCY
    If !fstat | PGFY=""
        Call PARAM([F:FCY]FCY,"SCOIFA",LOPEIFA) From ADOVAL
        If val(LOPEIFA)<2
            Call PARAM([F:FCY]FCY,"ACCIFA",LACCIFA) From ADOVAL
            If val(LACCIFA)>=2
                mkstat=0
                Break
            Endif
        Endif
    Endif
Next
If mkstat=2
    Raz VALEUR
Endif

End


##################################################
# Transforme AZC pour qu'il soit au format majuscule
# et contrôle que les caractères spéciaux sont autorisés
##################################################
# AZC = zone emplacement
# AUZ = caractères spéciaux autorisés
##################################################
Subprog CTLEMPFMT(AZC, AUZ)
Variable Char    AZC()
Value    Char    AUZ()

AZC = vireblc(toupper(AZC),4)
If AZC=""
    End
Endif

Local Char LFMT
LFMT = "Kv4:"+num$(GLONEMP)+"c"

Raz mkstat
AZC = vireblc(toupper(AZC),4)
If format$(LFMT,AZC) <> AZC
    If AUZ="" | ctrans(AZC,AUZ,"")<>"" & format$(LFMT,ctrans(AZC,AUZ,""))=""
        mkstat=2
    Endif
Endif

End

##################################################
# Transforme AZC pour qu'il soit au format majuscule
# et contrôle que les caractères spéciaux sont autorisés
##################################################
# AZC = zone emplacement
# AUZ = caractères spéciaux autorisés
##################################################
Subprog CTLTEMFMT(AZC, AUZ)
Variable Char    AZC()
Value    Char    AUZ()

AZC = vireblc(toupper(AZC),4)
If AZC=""
    End
Endif

Local Char LFMT
LFMT = "Kv4:"+num$(GLONTEM)+"c"

Raz mkstat
AZC = vireblc(toupper(AZC),4)
If format$(LFMT,AZC) <> AZC
    If AUZ="" | ctrans(AZC,AUZ,"")<>"" & format$(LFMT,ctrans(AZC,AUZ,""))=""
        mkstat=2
    Endif
Endif

End


####################################################################
# Gestion de la frequence controle qualité
####################################################################
# uniquement pour les article fournisseurs ou site avec QUAFLG = 4 #
####################################################################
# LABR = Masque
# LFCY = Site de stock
# LlIN = Ligne document
# LITM = Article
# LBPS = Fournisseur
# LACT = Situation
#          "S" : Saisie article
#          "F" : Flagage article
#          "V" : Validation
#          "A" : Abandon
####################################################################
Subprog STKFREQCQ(LABR,LFCY,LLIN,LITM,LBPS,LACT,LQUA,LITP)
Value    Char    LABR
Value    Char    LFCY
Value    Integer LLIN
Value    Char    LITM
Value    Char    LBPS
Value    Char    LACT
Variable Integer LQUA
Value    Integer LITP
If LITM = ""
   End
Endif

# Init des variables locales
Local Char    LMABR(10)
LMABR  = "[M:"+LABR+"]"
Local Integer LOUVTRS : Raz LOUVTRS
If LACT = "S"
   If evalue("dim("+LMABR+"QUAFLG)")>0
      Assign LMABR+"QUAFLG(LLIN)" With LQUA
   Endif
   If evalue("dim("+LMABR+"QUAFRE)")>0
      Assign LMABR+"QUAFRE(LLIN)" With LITP
   Endif
Endif


If LITM <> [F:ITF]ITMREF | LFCY <> [F:ITF]STOFCY
   Read [F:ITF]ITF0=LITM;LFCY
   If fstat
      End
   Endif
Endif
If LBPS<>""
   If !clalev([F:ITP]) : Local File ITMBPS [ITP] : Endif
   If [F:ITP]ITMREF<>LITM | [F:ITP]BPSNUM<>LBPS
      Read [ITP]ITP0=LITM;LBPS
      If fstat
         Raz [F:ITP]
      Endif
   Endif
Endif


If [F:ITF]QUAFLG <> 4 & (LBPS <> "" & [F:ITP]QUAFLG <> 4)
   End
Endif

Raz GPE
GPOINT = "STKFREQCQ"
Gosub ENTREE From EXEFNC
If GPE <> 0
   End
Endif


Case LACT
     When "S" : Gosub STKFREQCQ_S
     When "F" : Gosub STKFREQCQ_F
     When "V" : Gosub STKFREQCQ_V
     When "A" : Gosub STKFREQCQ_A
Endcase

If LOUVTRS=1
   If GOK
      Commit
   Else
      Rollback
   Endif
Endif

End

$STKFREQCQ_S
# si = 0  pas de frequence active
# si = 1  frequence active ITF seul
# si = 2  frequence active ITP et ITF

Raz LITP
If LBPS <> "" &  [F:ITP]QUAFLG = 4
   LQUA = 1
   If [F:SRU]QLYCTLFLG = 2
      If [F:ITP]QUANUMUID = 0
         If [F:ITP]QUANUM +1 >= [F:ITP]QUAFRY
            LQUA = 2
            LITP = 2
         Endif
      Elsif [F:ITP]QUAADXUID = adxuid(1)
            LQUA = 2
            LITP = 2
      Endif
   Endif
Endif
If LQUA <> 2
   If [F:ITF]QUAFLG = 4
      LQUA = 1
      If [F:SRU]QLYCTLFLG = 2
         If [F:ITF]QUANUMUID <= 0
            If [F:ITF]QUANUM +1 >= [F:ITF]QUAFRY
               LQUA = 2
               LITP = 1
            Endif

         Elsif [F:ITF]QUAADXUID = adxuid(1)
               LQUA = 2
               LITP = 1
         Endif
      Endif
   Endif
Endif
If evalue("dim("+LMABR+"QUAFLG)")>0
   Assign LMABR+"QUAFLG(LLIN)" With LQUA
Endif
If evalue("dim("+LMABR+"QUAFRE)")>0
   Assign LMABR+"QUAFRE(LLIN)" With LITP
Endif

Return

$STKFREQCQ_F

If LITP = 2 & ([F:ITP]QUAADXUID <> adxuid(1) | [F:ITP]QUANUMUID = 0)
   If !adxlog
      LOUVTRS = 1
      Trbegin [ITF]
   Endif
   Readlock [ITP]Curr
   Case fstat
       When 1 :
           GOK = -1
           Return
       When 0 :
           [F:ITP]QUAADXUID = adxuid(1)
           [F:ITP]QUANUMUID = [F:ITP]QUANUM +1
           Rewrite [ITP]
           If fstat
              GOK = 0
              Call FSTA("ITP") From GLOCK
              Return
           Endif
       When Default :
           GOK = 0
           Call FSTA("ITP") From GLOCK
           Return
       Endcase
   If [F:ITF]QUAFLG = 4
      Readlock [ITF]Curr
      Case fstat
          When 1 :
              GOK = -1
              Return
          When 0 :
              [F:ITF]QUAADXUID = adxuid(1)
              [F:ITF]QUANUMUID = [F:ITF]QUANUM + 1
              Rewrite [ITF]
              If fstat
                 GOK = 0
                 Call FSTA("ITF") From GLOCK
                 Return
              Endif
          When Default :
              GOK = 0
              Call FSTA("ITF") From GLOCK
              Return
      Endcase
   Endif
Else
   If [F:ITF]QUAFLG = 4 & ([F:ITF]QUAADXUID <> adxuid(1) | [F:ITF]QUANUMUID = 0)
      If !adxlog
         LOUVTRS = 1
         Trbegin [ITF]
      Endif
      Readlock [ITF]Curr
      Case fstat
      When 1 :
          GOK = -1
      When 0 :
          [F:ITF]QUAADXUID = adxuid(1)
          [F:ITF]QUANUMUID = [F:ITF]QUANUM + 1
          Rewrite [ITF ]
          If fstat
             GOK = 0
             Call FSTA("ITF") From GLOCK
          Endif
      When Default :
          GOK = 0
          Call FSTA("ITF") From GLOCK
      Endcase
   Endif
Endif

Return

$STKFREQCQ_V

If LBPS <> "" &  [F:ITP]QUAFLG = 4
# cas de plusieurs lignes de meme articles
#     meme adxuid
#     quaflg = 2 (obligatoire)
#     mais quanumuid deja remise à 0
   If [F:ITP]QUAADXUID =  adxuid(1) & [F:ITP]QUANUMUID = 0 & LQUA = 2
      Return
   Else
      If !adxlog
         LOUVTRS = 1
         Trbegin [ITF]
      Endif
      Readlock [ITP]Curr
      Case fstat
           When 1 :
              GOK = -1
              Return
           When 0 :
              # cas validation article en CQ avec frequence declanchée
              # meme adxuid
              # quanumuid renseignée
              If [F:ITP]QUAADXUID =  adxuid(1) & [F:ITP]QUANUMUID > 0
                 [F:ITP]QUANUM    -= ([F:ITP]QUANUMUID -1)
                 Raz [F:ITP]QUANUMUID
              Else
                 # cas validation article avec frequence non declanchée
                 [F:ITP]QUANUM += 1
              Endif
              Rewrite [ITP]
              If fstat
                 GOK = 0
                 Call FSTA("ITP") From GLOCK
                 Return
              Endif
              If [F:ITF]QUAFLG = 4
                 Readlock [ITF]Curr
                 Case fstat
                      When 1 :
                         GOK = -1
                         Return
                      When 0 :
                         # cas validation article en CQ avec frequence declanchée
                         # meme adxuid
                         # quanumuid renseignée
                         If [F:ITF]QUAADXUID =  adxuid(1) & [F:ITF]QUANUMUID > 0
                            [F:ITF]QUANUM    -= ([F:ITF]QUANUMUID -1)
                            Raz [F:ITF]QUANUMUID
                         Else
                            # cas validation article avec frequence non declanchée
                            [F:ITF]QUANUM += 1
                         Endif
                         Rewrite [ITF]
                         If fstat
                            GOK = 0
                            Call FSTA("ITF") From GLOCK
                            Return
                         Endif
                      When Default :
                         GOK = 0
                         Call FSTA("ITF") From GLOCK
                         Return
                 Endcase
                 Return
              Endif
           When Default :
              GOK = 0
              Call FSTA("ITP") From GLOCK
              Return
      Endcase
   Endif
Endif
If [F:ITF]QUAFLG = 4
# cas de plusieurs lignes de meme articles
#     meme adxuid
#     quaflg = 2 (obligatoire)
#     mais quanumuid deja remise à 0
   If [F:ITF]QUAADXUID =  adxuid(1) & [F:ITF]QUANUMUID = 0 & LQUA = 2
      Return
   Else
      If !adxlog
         LOUVTRS = 1
         Trbegin [ITF]
      Endif
      Readlock [ITF]Curr
      Case fstat
          When 1 :
              GOK = -1
              Return
          When 0 :
              # cas validation article en CQ avec frequence declanchée
              # meme adxuid
              # quanumuid renseignée
              If [F:ITF]QUAADXUID =  adxuid(1) & [F:ITF]QUANUMUID > 0
                 [F:ITF]QUANUM    -= ([F:ITF]QUANUMUID -1)
                 Raz [F:ITF]QUANUMUID
              Else
                 # cas validation article avec frequence non declanchée
                 [F:ITF]QUANUM += 1
              Endif
              Rewrite [ITF]
              If fstat
                 GOK = 0
                 Call FSTA("ITF") From GLOCK
                 Return
              Endif
          When Default :
              GOK = 0
              Call FSTA("ITF") From GLOCK
              Return
      Endcase
   Endif
Endif
Return

$STKFREQCQ_A

If LBPS <> "" & [F:ITP]QUAFLG = 4 & [F:ITP]QUAADXUID = adxuid(1) & [F:ITP]QUANUMUID > 0
   If !adxlog
      LOUVTRS = 1
      Trbegin [ITF]
   Endif
   Readlock [ITP]Curr
   Case fstat
        When 1 :
            GOK = -1
            Return
        When 0 :
            Raz [F:ITP]QUANUMUID
            Rewrite [ITP]
            If fstat
               GOK = 0
               Call FSTA("ITP") From GLOCK
               Return
            Endif
            If [F:ITF]QUAFLG = 4
               Readlock [ITF]Curr
               Case fstat
                    When 1 :
                        GOK = -1
                        Return
                    When 0 :
                        Raz [F:ITF]QUANUMUID
                        Rewrite [ITF]
                        If fstat
                           GOK = 0
                           Call FSTA("ITF") From GLOCK
                           Return
                        Endif
                    When Default :
                        GOK = 0
                        Call FSTA("ITF") From GLOCK
                        Return
               Endcase
               Return
            Endif
        When Default :
            GOK = 0
            Call FSTA("ITP") From GLOCK
            Return
   Endcase
Endif
If [F:ITF]QUAFLG = 4 & [F:ITF]QUAADXUID =  adxuid(1) & [F:ITF]QUANUMUID > 0
   If !adxlog
      LOUVTRS = 1
      Trbegin [ITF]
   Endif
   Readlock [ITF]Curr
   Case fstat
       When 1 :
           GOK = -1
           Return
       When 0 :
           Raz [F:ITF]QUANUMUID
           Rewrite [ITF]
           If fstat
              GOK = 0
              Call FSTA("ITF") From GLOCK
              Return
           Endif
       When Default :
           GOK = 0
           Call FSTA("ITF") From GLOCK
           Return
   Endcase
Endif
Return

