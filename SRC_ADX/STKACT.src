#<AdxTL>@(#)3.0.0.0 $Revision$
Infbox ctrans("$","*","")
End
#########################################################################
# Traitement STKACT - Librairie d'actions stock                    V140 #
#                     Librairie de sous-programmes de zones écran       #
#########################################################################

#########################################################################
# Actions de type saisie fenêtre
#------------------------------------------------------------------------
# SAISTOSTA   : Saisie statuts de stocks
#########################################################################

#########################################################################
# Actions de type traitement divers (S/P)
#------------------------------------------------------------------------
# STKASFCY    : Avant saisie site
# STKASGAU    : Avant saisie pièce auto (pour la GP)
# STKCTRFCY   : Contrôle site
# STKCTRGAU   : Controle pièce auto
# STKCTRLOTS  : Contrôle lot en sortie
# STKCTRSLOS  : Contrôle sous-lot en sortie
# STKCTRLOTC  : Contrôle lot en changement de stock
# STKCTRSLOC  : Contrôle sous-lot en changement de stock
# STKCTRSTA   : Contrôle statut (à partir d'une liste de sous-statuts)
# STKCTRCHS   : Contrôle liste de statuts
# STKCTRSER   : Contrôle numero de serie
# STKCTRSERN  : Contrôle numero de serie
# CTLUOM      : Contrôle unité
# STKLASSER   : Dernier n° de série+1 d'un article
#########################################################################

#########################################################################
# Sous-programmes divers
#------------------------------------------------------------------------
# STKOWNER    : Contrôle du propriétaire (et tunnel)
# STKCTRLOT   : Contrôle lot en entrée
# STKCTRNBSLO : Contrôle la validité du nombre de sous lots
#               avec la décimalisation de l'unité
# STKCTRSLO   : Contrôle sous lot
# STKINISTA   : Renvoie le statut par defaut
# STKDEFSTAQ  : Renvoie un statut par defaut en Q*
# STKAUZSTA   : Restriction des statuts autorisés en fonction de GQUAFLG
# STKVISUNI   : Chargement des unités dans un bloc tableau d'écran
# STKDETSTO   : Affichage du détail stock dans un tableau d'écran
# RECSER_M    : Recherche l'existence de numéros de séries
# RECSER_F    : Contrôle no série
# STKCTRCOE   : Contrôle si le coef UC/US génére une qté US arrondi
#########################################################################

#########################################################################
# Traitements devant être appelés par les documents                     #
#-----------------------------------------------------------------------#
# STK_IBNBLIG : Initialise les libellés de bouton selon le contexte
# STK_LIENSLIG: Affecte les valeurs des champs communs
#               (Valeurs prisent dans STOJOU)
# STK_BAPRESNBLIG: Grise les champs stock ne pouvant plus être modifiés
# STK_VALLIG  : Enregistrement d'une ligne de document
#########################################################################

$ACTION
Case ACTION
  When "OUVRE"
    Case GACTION
      When "SAISTOSTA"  : Gosub OUVRE_SAISTOSTA
    Endcase
  When "DEBUT" :
    Case GACTION
      When "SAISTOSTA"  : Gosub DEBUT_SAISTOSTA
    Endcase
  When "OK" :
    Case GACTION
      When "SAISTOSTA"  : Gosub OK_SAISTOSTA
    Endcase
Endcase
Return

#########################################################################
# Actions de type saisie fenêtre
#########################################################################

#########################################################################
# Action SAISTOSTA de saisie de statut de stocks
# Valeur   = Zone courante
# Param(1) = Statuts majeurs autorisés (1='A' 2='Q' 3='A'+'Q' 4='R'....)
# Param(2) = Saisie obligatoire (0 = non obligatoire)
#########################################################################
$OUVRE_SAISTOSTA
Return
#########################################################################
$DEBUT_SAISTOSTA
Local Char    W_VAL(len(VALEUR))
Local Integer W_AUT : W_AUT = val(PARAM(1))
Local Integer W_OBL : W_OBL = val(PARAM(2))
Local Integer W_I, W_J, W_K
#
Raz [M:SSTA]
#
W_VAL = toupper(vireblc(VALEUR,4))
W_I   = 0
W_K   = 1
W_J   = instr(W_K,W_VAL,",")
While W_J <> 0
  [M:SSTA]STA(W_I) = seg$(W_VAL,W_K,W_J-1)
  [M:SSTA]NBLIG    += 1
  W_I += 1
  W_K  = W_J + 1
  W_J = instr(W_K,VALEUR,",")
Wend
If seg$(W_VAL,W_K,len(W_VAL)) <> ""
  [M:SSTA]STA(W_I) = seg$(W_VAL,W_K,len(W_VAL))
  [M:SSTA]NBLIG   +=  1
Endif
# Recherche des intitulés
For W_I = 0 To [M:SSTA]NBLIG-1
  Read [TST]TST0=[M:SSTA]STA(W_I)
  If fstat = 0
    Call GET_ATEXTRA("TABSTASTO","STAAXX",GLANGUE,[M:SSTA]STAAXX(W_I)) From TRTX3TEX
  Else
    [M:SSTA]STAAXX(W_I) = ""
  Endif
Next W_I
Affzo [M:SSTA]
Return
#########################################################################
$OK_SAISTOSTA
VALEUR = ""
For W_I = 0 To [M:SSTA]NBLIG-1
  If VALEUR = ""
    VALEUR = [M:SSTA]STA(W_I)
  Else
    VALEUR += ","+[M:SSTA]STA(W_I)
  Endif
Next W_I
Call STKCTRCHS(VALEUR,W_AUT,W_OBL,mkstat)
FIN = 1
Return

#########################################################################
# Actions de type traitement divers
#########################################################################

#########################################################################
# STKASFCY : S/P avant saisie site
#########################################################################
Subprog STKASFCY(LFCY)
Variable Char    LFCY
Local    Integer WFIND
#bg 54216, INIT_FCY
WFIND = 0
If LFCY = "" & GFCYDEF(0)<>""
  LFCY = GFCYDEF(0)
Elsif LFCY=""
  #Filter [FCY] Where WRHFLG=2
  #Read [FCY] first
  For [FCY] Where WRHFLG=2
      If GUSRFCY(1)<>"\" & find([F:FCY]FCY,GUSRFCY(1..GNBAUZ))
         LFCY=[F:FCY]FCY
         WFIND=1
         Break
      Endif
  Next
  #on a pas trouvé de site de dépot autorisé pour l'utilisateur
  If WFIND=0
      Raz [F:FCY]
      LFCY=[F:FCY]FCY
  Endif
Endif
End


########################################################################
# STKOWNER          Controle Propriétaire :
#                   Site  puis fournisseur
########################################################################
# Paramètres E : LTRT = C = controle  V = Visu
#                LOWN = Site
#                LSUP = Inutilisé (paramètre supplémentaire au cas où)
#            S : mkstat est positionné à 2 si erreur
#                LRET = 1 = Site  2 = Fournisseur
########################################################################
Subprog STKOWNER(LTRT,LOWN,LSUP,LRET)
Value    Char     LTRT
Value    Char     LOWN
Value    Char     LSUP
Variable Integer  LRET

Raz mkstat

If LOWN = ""
   End
Endif


If clalev([F:FCY1]) = 0 : Local File FACILITY   [FCY1] : Endif
If clalev([F:BPS])  = 0 : Local File BPSUPPLIER [BPS]  : Endif
LRET = 0
Raz GERR
#--- Lecture FACILITY
If [F:FCY1]FCY<>LOWN
   Read [FCY1]FCY0=LOWN
   If fstat
      LRET = 9
   Else
      LRET = 1
   Endif
Else
   LRET = 1
Endif
If LRET = 9
#--- Lecture BPSUPPLIER
   If [F:BPS]BPSNUM<>LOWN
      Read [BPS]BPS0=LOWN
      If fstat
         LRET = 9
      Else
         LRET = 2
      Endif
   Else
      LRET = 2
   Endif
Endif


# Propriétaire inexistant !
If LTRT = "C"
   If LRET = 9
      GMESSAGE = LOWN-":"-mess(517,199,1)
      GERR = 1
      mkstat = 2
   Endif
Elsif LTRT = "V"
   GCONSULT  = 2
   Case LRET
        When 1 :
          Call OBJET("FCY",LOWN,"") From GOBJET
        When 2 :
          Call OBJET("BPS",LOWN,"") From GOBJET
        When Default:
   Endcase
   GCON
SULT = 0
Endif

End


#########################################################################
# STKCTRFCY : S/P de contrôle site
#########################################################################
Subprog STKCTRFCY(LFCY)
Variable  Char    LFCY
If LFCY <> ""
  If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
  If GUSRFCY(1)<>"\" & !find(LFCY,GUSRFCY(1..GNBAUZ))
    GMESSAGE = LFCY-":"-mess(2,104,1) : # Vous n'avez pas les droits pour ce site
    mkstat = 2
  Else
    Read [FCY]FCY0=LFCY
    If fstat | fstat = 0 & [F:FCY]WRHFLG <> 2
      mkstat = 2
      GMESSAGE = mess(61,187,1)
    Else
      Call GLOBVAR(LFCY) From WWGLOBSTO
      Call GETDEV(LFCY)  From DEVSUB
    Endif
  Endif
Endif
End

########################################################################
# STKCTRLOTS : S/P de contrôle lot en sortie
########################################################################
# Paramètres E : LLOT  = Lot à contrôler
#                LITM  = Article
#                LDAT  = Date besoin pour contrôle péremption
#                LBPRNUM = Client
#                LSTOFCY = Site
#
#            S : mkstat est positionné à 2 si erreur
#
# Prérequis    : Ce buffer doit être en ligne TABSTORUL [SRU]
#
########################################################################
Subprog STKCTRLOTS(LLOT, LITM, LDAT, LBPRNUM,LSTOFCY)
Value    Char    LLOT
Value    Char    LITM
Value    Date    LDAT
Value    Char    LBPRNUM
Value    Char    LSTOFCY

Local    Integer WLOT, WPER
Local    Char NBDAY(10)

Raz      NBDAY       # hcb dlu

Raz WLOT
WPER = 1

If LLOT="" | LITM="" End Endif

#If LDAT=[0/0/0] LDAT=date$ Endif

If clalev([F:STL])=0  Local File STOLOT    [STL]  Endif
#                                                      hcb v6per deb
If clalev([F:ITM])=0  Local File ITMMASTER [ITM]  Endif
If [F:ITM]ITMREF <> LITM
   Read [ITM]ITM0=  LITM
   If fstat
      Raz [F:ITM]
   Endif
Endif
If LSTOFCY <>""
  Read [ITF]ITF0=LITM;LSTOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif
#                                                      hcb v6per fin

#lecture de la DLU client
If clalev([F:ITU])=0  Local File ITMBPC [ITU]  Endif
If LBPRNUM <> ""
   Read [ITU]ITU0 = [F:ITM]ITMREF;LBPRNUM
   If fstat
      Raz [F:ITU]
   Endif
Endif
If [F:ITU]DLUBPC <> 0
  Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
Endif

For [STL] Where ITMREF=LITM & LOT=LLOT
   WLOT+=1
   #DLUBPC
   #si le client a un coeff de dlu, on retranche le nb de jours équivalent à la dlu du lot
   If [F:STL]DLUDAT=[0/0/0] | [F:STL]DLUDAT+val(NBDAY)>=LDAT
      WPER=0
   Endif
   If [F:STL]SHLDAT=[0/0/0] | [F:STL]SHLDAT>=LDAT  #  hcb v6dlu
      WPER=0
   Endif
Next

# Lot inexistant
If WLOT=0
   GERR=2 : GMESSAGE=mess(123,199,1)
   End
Endif
# Lots périmés interdits et le lot est périmé
If [F:SRU]SHLLOT<>3 & WPER=1                       #  hcb v6dlu
   GERR=1 : GMESSAGE=mess(398,199,2)
   mkstat=2 : End
Endif

End

########################################################################
# STKCTRSLOS : S/P de contrôle sous-lot en sortie
########################################################################
# Paramètres E : LSLO  = Sous-lot à contrôler
#                LLOT  = Lot
#                LITM  = Article
#                LDAT  = Date besoin pour contrôle péremption
#                LBPRNUM = Client
#                LSTOFCY = Site
#
#            S : mkstat est positionné à 2 si erreur
#
# Prérequis    : Ce buffer doit être en ligne TABSTORUL [SRU]
#
########################################################################
Subprog STKCTRSLOS(LSLO, LLOT, LITM, LDAT, LBPRNUM,LSTOFCY)
Value    Char    LSLO
Value    Char    LLOT
Value    Char    LITM
Value    Date    LDAT
Value    Char    LBPRNUM
Value    Char    LSTOFCY

Local Char    NBDAY(10)

NBDAY=""
If LLOT="" | LITM="" End Endif

If clalev([F:STL])=0  Local File STOLOT   [STL]  Endif
#                                                      hcb v6per deb
If clalev([F:ITM])=0  Local File ITMMASTER [ITM]  Endif
If [F:ITM]ITMREF <> LITM
   Read [ITM]ITM0=  LITM
   If fstat
      Raz [F:ITM]
   Endif
Endif
#                                                      hcb v6per fin
If LSTOFCY <>""
  Read [ITF]ITF0=LITM;LSTOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

#lecture de la DLU client
If clalev([F:ITU])=0  Local File ITMBPC [ITU]  Endif
If LBPRNUM <> ""
   Read [ITU]ITU0 = [F:ITM]ITMREF;LBPRNUM
   If fstat
      Raz [F:ITU]
   Endif
Endif

If [F:ITU]DLUBPC <> 0
  Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
Endif



Read[STL]STL0=LITM;LLOT;LSLO
If fstat
   # Lot inexistant
   GERR=2 : GMESSAGE=mess(123,199,1)
Else
  If [F:SRU]SHLLOT<>3 & (([F:STL]DLUDAT<>[0/0/0] & ([F:STL]DLUDAT+val(NBDAY))<LDAT) | ([F:STL]SHLDAT<>[0/0/0] & [F:STL]SHLDAT<LDAT))  # hcb v6dlu
   # Lots périmés interdits et le lot est périmé
   GERR=1 : GMESSAGE=mess(398,199,2)
   mkstat=2
  Endif
Endif

End

########################################################################
# STKCTRLOTC : S/P de contrôle lot en changement de stock
########################################################################
# Paramètres E : LLOT  = Lot à contrôler
#                LITM  = Article
#                LDAT  = Date besoin pour contrôle péremption
#
#            S : mkstat est positionné à 2 si erreur
#
# Prérequis    : Ce buffer doit être en ligne TABSTORUL [SRU1]
#
########################################################################
Subprog STKCTRLOTC(LLOT, LITM, LDAT)
Value    Char    LLOT
Value    Char    LITM
Value    Date    LDAT

Local    Integer WLOT, WPER
Raz WLOT
WPER = 1

If LLOT="" | LITM="" End Endif

If clalev([F:STL])=0  Local File STOLOT   [STL]  Endif

For [STL] Where ITMREF=LITM & LOT=LLOT
   WLOT+=1
   If [F:STL]DLUDAT=[0/0/0] | [F:STL]DLUDAT>=LDAT     # hcb v6dlu
      WPER=0
   Endif
   If [F:STL]SHLDAT=[0/0/0] | [F:STL]SHLDAT>=LDAT     # hcb v6dlu
      WPER=0
   Endif
Next

# Lot inexistant
If WLOT=0
   GERR=2 : GMESSAGE=mess(123,199,1)
   End
Endif
# Lots périmés interdits et le lot est périmé
If [F:SRU1]SHLLOT<>3 & WPER=1
   GERR=1 : GMESSAGE=mess(398,199,2)                  # hcb v6dlu
   mkstat=2 : End
Endif

End

########################################################################
# STKCTRSLOC : S/P de contrôle sous-lot en changement de stock
########################################################################
# Paramètres E : LSLO  = Sous-lot à contrôler
#                LLOT  = Lot
#                LITM  = Article
#                LDAT  = Date besoin pour contrôle péremption
#
#            S : mkstat est positionné à 2 si erreur
#
# Prérequis    : Ce buffer doit être en ligne TABSTORUL [SRU1]
#
########################################################################
Subprog STKCTRSLOC(LSLO, LLOT, LITM, LDAT)
Value    Char    LSLO
Value    Char    LLOT
Value    Char    LITM
Value    Date    LDAT

If LLOT="" | LITM="" End Endif

If clalev([F:STL])=0  Local File STOLOT   [STL]  Endif
#                                                      hcb v6per deb
If clalev([F:ITM])=0  Local File ITMMASTER [ITM]  Endif
If [F:ITM]ITMREF <> LITM
   Read [ITM]ITM0=  LITM
   If fstat
      Raz [F:ITM]
   Endif
Endif
#                                                      hcb v6per fin

Read[STL]STL0=LITM;LLOT;LSLO
If fstat
   # Lot inexistant
   GERR=2 : GMESSAGE=mess(123,199,1)
Elsif [F:SRU1]SHLLOT<>3 & (([F:STL]DLUDAT<>[0/0/0] & [F:STL]DLUDAT<LDAT) | ([F:STL]SHLDAT<>[0/0/0] & [F:STL]SHLDAT<LDAT))   # hcb v6dlu
   # Lots périmés interdits et le lot est périmé
   GERR=1 : GMESSAGE=mess(398,199,2)
   mkstat=2
Endif

End

#########################################################################
# STKCTRSTA : S/P de contrôle qu'un statut est valide selon une liste
#             de statuts autorisés
#########################################################################
# Paramètres E : LSTA = Statut à contrôler
#                LLIS = Liste des valeurs / pattern autorisées
#                LOPT = Option contrôle qualité
#                       0                         --> Ne change rien
#                       1 Pas de ctl qualité      --> Ne change rien
#                       2 Ctl qualité obligatoire --> Enlève les s-statuts A & R
#                       3 Ctl qualité modifiable  --> Ne change rien
#                       4 Blocage statut (C.QUAL) --> Enlève les s-statuts A & Q
#                LOBL = 0 Facultatif
#                       1 Obligatoire
#                       2 Facultatif contrôlé (sans erreur) si admin stock
#                       3 Obligatoire contrôlé(sans erreur) si admin stock
#                LFRE = 0 pas de frequence déclenchée
#                       1 Frequence article site
#                       2 Fréquence article fournisseur
#
#            S : LRET = 2 si erreur
#########################################################################
Subprog STKCTRSTA(LSTA,LLIS,LOPT,LOBL,LFRE,LRET)
Variable Char     LSTA
Value    Char     LLIS
Value    Integer  LOPT
Value    Integer  LOBL
Value    Integer  LFRE
Variable Shortint LRET
#
Local    Char     W_STA(GLONSTA)
Local    Integer  W_I, W_J
#

Call STKAUZSTA(LLIS,LOPT)
#

LRET = 2
LSTA = toupper(vireblc(LSTA,1))
If LSTA = ""
  If find(LOBL,1,3)
    GMESSAGE = mess(10,123,1)
  Else
    LRET = 0
  Endif
  Goto STKCTRSTA_END
Endif

# Contrôle avec table des statuts
If clalev([F:TST]) = 0 : Local File TABSTASTO [TST] : Endif
#
If LSTA <> [F:TST]STASTO
  Read [TST]TST0=LSTA
  If fstat
    Goto STKCTRSTA_END
  Endif
Endif

# Contrôle avec liste de valeurs
If len(LLIS) > 0
  W_I = 1
  W_J = instr(W_I,LLIS,",")
  While W_J <> 0
    W_STA = seg$(LLIS,W_I,W_J-1)
    If pat(LSTA,W_STA)
      LRET = 0
      Break
    Endif
    W_I = W_J +1
    W_J = instr(W_I,LLIS,",")
  Wend
  If W_J = 0 & LRET <> 0
    W_STA = seg$(LLIS,W_I,len(LLIS))
    If pat(LSTA,W_STA)
      LRET = 0
    Endif
  Endif
Endif

If LRET
   If LFRE <> 0
      If LFRE = 1                            # hcb V6CQ
         GMESSAGE = mess(302,184,1)          # hcb V6CQ
      Else                                   # hcb V6CQ
         GMESSAGE = mess(307,184,1)          # hcb V6CQ
      Endif                                  # hcb V6CQ
   Else                                      # hcb V6CQ
      GMESSAGE = LSTA-":"-mess(24,184,1)
   Endif                                     # hcb V6CQ
   If GSTOADMIN=2 & find(LOBL,2,3)
      Call MESSAGE(GMESSAGE) From GESECRAN
      LRET=0
   Endif
Endif

$STKCTRSTA_END
End

#########################################################################
# STKCTRCHS : S/P de contrôle d'une chaîne de statuts
#########################################################################
# Paramètres E : LVAL = Chaîne à contrôler
#                LAUT = Code statuts majeurs autorisés ( de 1 à 7)
#                LOBL = Code saisie obligatoire (1 si obligatoire)
#            S : LVAL = Chaîne contrôlé
#                LRET = Code retour = 2 si erreur
#########################################################################
Subprog STKCTRCHS(LVAL,LAUT,LOBL,LRET)
Variable Char     LVAL
Value    Integer  LAUT
Value    Integer  LOBL
Variable Shortint LRET

If LOBL = 0 & LVAL = ""
    End
Endif

If LOBL <> 0 & LVAL = ""
  GMESSAGE = mess(10,123,1)
  LRET = 2
Else
  LRET = 0
  Local Char    W_VAL    (len(LVAL))
  Local Char    W_STA(05)(len(LVAL))
  Local Integer W_I, W_J, W_K
  W_I   = 0
  W_K   = 1
  W_VAL = toupper(LVAL)
  W_J   = instr(W_K,W_VAL,",")
  While W_J <> 0
    W_STA(W_I) = seg$(W_VAL,W_K,W_J-1)
    W_I += 1
    W_K  = W_J + 1
    W_J = instr(W_K,W_VAL,",")
  Wend
  W_STA(W_I) = seg$(W_VAL,W_K,len(W_VAL))
# Contrôle
  For W_J = 0 To W_I
    If len(W_STA(W_J)) > 3 | !find(left$(W_STA(W_J),1),"A","Q","R")
      LRET = 2
      Break
    Endif
    If (left$(W_STA(W_J),1) = "A" & !find(LAUT,1,3,5,7)) |
&      (left$(W_STA(W_J),1) = "Q" & !find(LAUT,2,3,6,7)) |
&      (left$(W_STA(W_J),1) = "R" & !find(LAUT,4,5,6,7))
      LRET = 2
      Break
    Endif
    If !(instr(1,W_STA(W_J),"*") | instr(1,W_STA(W_J),"?"))
      Look [TST]TST0=W_STA(W_J)
      If fstat
        LRET = 2
        Break
      Endif
    Else
      If instr(1,W_STA(W_J),"*") & mid$(W_STA(W_J),len(W_STA(W_J)),1) <> "*"
        LRET = 2
        Break
      Endif
    Endif
  Next W_J
# Elimination statuts inutiles
  If LRET = 0
    Sorta W_I+1 W_STA
    For W_J = 0 To W_I
      If instr(1,W_STA(W_J),"*")
        For W_K = 0 To W_I
          If W_K <> W_J
            If pat(W_STA(W_K),W_STA(W_J))
              W_STA(W_K) = ""
            Endif
          Endif
        Next W_K
      Endif
    Next W_J
# Rechargement valeurs
    LVAL    = ""
    For W_J = 0 To W_I
      If W_STA(W_J) <> ""
        If LVAL <> ""
          LVAL += ","
        Endif
        LVAL += W_STA(W_J)
      Endif
    Next W_J
  Endif
  If LRET = 2
    GMESSAGE = mess(37,124,1)
  Endif
Endif
End

#########################################################################
# STKCTRSER      Contrôle des n° de séries
#                Effectue tout d'abord une recherche dans le fichier STOSER,
#                puis dans les masques STOENTW et celui passé en paramètre
#########################################################################
# Paramètres E : PSER   = N° de série saisi
#                PITM   = Référence article
#                PNOL   = Indice de la ligne
#                PNBLIG = Nombre de ligne dans le tableau
#                PLIGEX = Ligne du tableau du masque à exclure (1 <= PLIGEX <= NBLIG)
#                         Si le masque contient un tableau contenant le champ WSTOSEQ
#                         ce sont toutes les lignes dont le champ WSTOSEQ=PLIGEX
#                         qui sont exclues
#                PTRS   = Type de transaction (m704)
#                POBL   = Saisie obligatoire (0=non/1=oui)
#                PVCRORI= Numéro de pièce d'origine
#                PLINORI= Numéro de ligne de la pièce d'origine
#                PSEQORI = N° de séquence d'origine (utilisé uniquement pour la réintégration)
#                POBL   = Obligatoire (0=Non 1=Oui)
#                LSUP   = Option (au cas où...)
#
# Prérequis    : Le masque PABR doit contenir les champs
#                    - ITMREF
#                    - SERNUM
#                    - SERNUMF
#                Les champs [M:ENTW]WZONxxx doivent être renseignés
#                La table ITMCATEG [ITG] doit être positionnée
#
#########################################################################
Subprog STKCTRSER(PSER, PITM, PNOL, PNBLIG, PLIGEX, PTRS, PVCRTYP, PVCRNUM, PVCRLIN, PTYPORI, PVCRORI, PLINORI, PSEQORI, POBL, LSUP )
Value    Char     PSER
Value    Char     PITM
Value    Integer  PNOL
Value    Integer  PNBLIG
Value    Integer  PLIGEX
Value    Integer  PTRS
Value    Integer  PVCRTYP
Value    Char     PVCRNUM
Value    Integer  PVCRLIN
Value    Integer  PTYPORI
Value    Char     PVCRORI
Value    Integer  PLINORI
Value    Integer  PSEQORI
Value    Integer  POBL
Value    Char     LSUP

    #--- Issue 110327
    Local    Char    LSERORI(GLONSER)
    Local    Char    LSERFORI(GLONSER)
    Raz LSERORI, LSERFORI
    #---
    Local    Char    LMSKCOU(10)
    Local    Char    LSERF(GLONSER)
    Local    Integer LWSTOSEQ
    Local    Char    LZONQUS(20)
    If !(PSER="" & POBL=0)
        If clalev([ENTW])
            If dim([M]WSTOSEQ)>1
                LWSTOSEQ = [M]WSTOSEQ(PNOL)
            Elsif dim([M]WSTOSEQ)=1    # Ecran STOENT
                LWSTOSEQ = [M]WSTOSEQ
            Else
                LWSTOSEQ = -1    # Dans le cas de STOENTM par exemple. On n'a alors pas besoin de controler dans des masques
            Endif

            LMSKCOU = func STKLIB.MSKDEF
            #--- Issue 110327
            If LMSKCOU="[ENM]"
               LSERORI  = [M:ENM]SERNUMO(PNOL)
               LSERFORI = [M:ENM]SERNUMFO(PNOL)
            Endif
            #---
            If find(LMSKCOU,"[ENT]","[ENM]")
               LZONQUS = "[M]QTYSTU"
            Else
               LZONQUS = "[M]"+[M:ENTW]WZONQUS
            Endif
        Elsif clalev ([M:SGW])
            LZONQUS  = "[M]QTYSTUDES"
            If dim([M]WSTOSEQ)=1    # Ecran STOCHG ou STOQUA
                LWSTOSEQ = [M]WSTOSEQ
            Else
                LWSTOSEQ = [M]WSTOSEQ(PNOL)
            Endif
        Endif

        If evalue(LZONQUS+"(PNOL)")<=0
            GMESSAGE = mess(83,182,1)    # Qté >0 !!
            mkstat=2
            End
        Endif

# CCC: 25/09/03 Il a été décidé de ne pas avoir de format
#        If [F:ITG]SERNUMFMT<>""
#            If format$([F:ITG]SERNUMFMT, PSER)=""
#                mkstat = 2
#                GMESSAGE = mess(358,183,1)
#            Endif
#        Endif
        #--- Issue 110327
        #Call RECSER_F( PSER, evalue(LZONQUS+"(PNOL)"), PITM, PTRS, PVCRTYP, PVCRNUM, PVCRLIN, PTYPORI, PVCRORI, PLINORI, PSEQORI, LSERF)
        Call RECSER_F( PSER, evalue(LZONQUS+"(PNOL)"), PITM, PTRS, PVCRTYP, PVCRNUM, PVCRLIN,
&                      PTYPORI, PVCRORI, PLINORI, PSEQORI, LSERORI, LSERFORI, LSERF)
        #---
        If !mkstat #& LWSTOSEQ>=0
            Call RECSER_M( PSER, PLIGEX, LWSTOSEQ, evalue(LZONQUS+"(PNOL)"), LZONQUS, PITM, PNBLIG, LSERF)
        Endif
        If !mkstat
            [M]SERNUMF(PNOL) = LSERF
            Affzo [M]SERNUMF(PNOL)
        Endif
    Else
        [M]SERNUMF(PNOL) = ""
        Affzo [M]SERNUMF(PNOL)
    Endif
End

#########################################################################
# STKCTRSERN     Contrôle d'un n° de série
#########################################################################
# Paramètres E : WSER       = No série
#                WITM       = Article
#                WFCY       = Site
#                WSERSOR    = No série sortie (0/1)
#                WCTLORI    = Ctrl pièce origine avec :
#                                E = Pièce entrée série
#                                S = Pièce sortie série
#                WVCRTYPORI = Type pièce origine
#                WVCRNUMORI = Numéro pièce origine
#                WVCRLINORI = Ligne pièce origine
#                WFILTRE    = Filtre
# Paramètres S : LRET       = Code retour :
#                               0=OK
#                               1=No série inexistant
#                               2=No série sur un autre site
#                               3=No série non sorti
#                               4=No série déjà sorti
#                               5=Pièce entrée du no série incorrecte
#                               6=Pièce sortie du no série incorrecte
#                               7=No série ne respectant pas le filtre
#
#########################################################################
Subprog STKCTRSERN(WSER,WITM,WFCY,WSERSOR,WCTLORI,WVCRTYPORI,WVCRNUMORI,WVCRLINORI,WFILTRE,LRET)
Value    Char    WSER
Value    Char    WITM
Value    Char    WFCY
Value    Integer WSERSOR
Value    Char    WCTLORI
Value    Integer WVCRTYPORI
Value    Char    WVCRNUMORI
Value    Integer WVCRLINORI
Value    Char    WFILTRE
Variable Integer LRET

Raz LRET

If clalev([F:STS]) = 0 : Local File STOSER    [STS] : Endif

Read [STS]STS0=WITM;WSER
If fstat LRET=1 : End Endif

If WFCY<>"" & [F:STS]STOFCY<>WFCY
   LRET=2 : End
Endif

If WSERSOR=1 & [F:STS]ISSDAT= [0/0/0]
   LRET=3 : End
Endif
If WSERSOR=0 & [F:STS]ISSDAT<>[0/0/0]
   LRET=4 : End
Endif

If WVCRNUMORI<>""
   If WCTRSER="E"
      If [F:STS]RCPVCRTYP<>WVCRTYPORI | [F:STS]RCPVCRNUM<>WVCRNUMORI |
&        [F:STS]RCPVCRLIN<>WVCRLINORI
         LRET=5 : End
      Endif
   Else
      If [F:STS]SDHTYP<>WVCRTYPORI | [F:STS]SDHNUM<>WVCRNUMORI |
&        [F:STS]SDDLIN<>WVCRLINORI
         LRET=6 : End
      Endif
   Endif
Endif

# Prise ne compte du filtre renseigné
If WFILTRE<>"" & !evalue(WFILTRE)
   LRET=7
Endif

End

########################################################################
# RECSER_M      Recherche l'existance de numéros de séries
#               dans un masque passé en paramètre puis dans STOENTW
#               Si un n° est trouvé, un message d'avertissement est affiché
#               Toutes les lignes de STOENTW qui ont WSTOSEQ=PLIGEX
#               sont exclues du test
########################################################################
# Paramètres E : PABR   = Abréviation du masque à scruter
#                PLIGEX = Ligne du tableau du masque à exclure (1 <= PLIGEX <= NBLIG)
#                         Si le masque contient un tableau contenant le champ WSTOSEQ
#                         ce sont toutes les lignes dont le champ WSTOSEQ=PLIGEX
#                         qui sont exclues
#                PLIGEXW= Ligne du tableau STOENTW à exclure (1 <= PLIGEXW <= NBLIG)
#                         Ce sont toutes les lignes dont le champ WSTOSEQ=PLIGEXW
#                         qui sont exclues
#                PSER   = N° de série saisi
#                PQTY   = Quantité
#                PITM   = Ref Article
#
# Paramètres S : PSERF  = N° de série fin calculé
#
# Prérequis    : Le masque PABR doit contenir les champs:
#                    - ITMREF
#                    - SERNUM
#                Les champs [M:ENTW]WZONxxx doivent être renseignés
#
########################################################################
Subprog RECSER_M( PSER, PLIGEX, PLIGEXW, PQTY, PZONQUS, PITM, PNBLIG, PSERF )
Value    Char     PSER
Value    Integer  PLIGEX
Value    Integer  PLIGEXW
Value    Decimal  PQTY
Value    Char     PZONQUS
Value    Char     PITM
Value    Integer  PNBLIG
Variable Char     PSERF

    Local Integer  PRET
    Local Char     LTABSER(GLONSER)(PQTY)
    Local Integer  NBL(2), NBS
    Local Integer  I, J, ABR
    Local Integer  LSUITE
    Local Integer  LRET
    Local Integer  LNBERR
    Local Char     LMABR(10)(2)
    Local Char     LZONQTY(20)(2)
    Local Char     LZONSER(20)(2)
    Local Integer  LSTOP
    Local Integer  CURRLIG # N° de ligne en cours dans le masque de recherche

    LSUITE = 1
    PSERF  = ""
    PRET   = -1
    LNBERR = 0
    LSTOP  = 0

    LMABR(0)= "[M]"
    LZONQTY(0) = PZONQUS
    LZONSER(0) = "[M]SERNUM"
    NBL(0) = PNBLIG

    If clalev([ENTW])
        LMABR(1)= "[M:ENTW]"
        LZONQTY(1) = "[M:ENTW]QTYSTU"
        LZONSER(1) = "[M:ENTW]SERNUM"
        NBL(1) = [M:ENTW]NBLIG
    Elsif clalev([SGW])
        LMABR(1)= "[M:SGW]"
        LZONQTY(1) = "[M:SGW]WQTYSTUDES"
        LZONSER(1) = "[M:SGW]WSERNUM"
        NBL(1) = [M:SGW]NBLIG
    Endif

    LTABSER(0) = PSER
    For I=1 To PQTY-1
        Call PLUS_UN(LTABSER(I-1),LTABSER(I),LRET) From STKLIB
        If LRET
            Break
        Endif
    Next

    If !LRET
        For ABR=0 To 1
            For I=0 To NBL(ABR)-1
                # Attention: PLIGEX correspond au numéro de ligne, pas à l'indice dans le tableau
                If evalue("dim("+LMABR(ABR)+"WSTOSEQ)")>1
                    CURRLIG = evalue(LMABR(ABR)+"WSTOSEQ(I)")
                    If CURRLIG=0 : CURRLIG=-1 : Endif
                Else
                    CURRLIG = I+1
                Endif
                If (ABR=0 & CURRLIG<>PLIGEX & CURRLIG<>-1) |
&                  (ABR=1 & CURRLIG<>PLIGEXW & CURRLIG<>-1)
                    If evalue("dim("+LMABR(ABR)+"ITMREF)")>1
                        If evalue(LMABR(ABR)+"ITMREF(I)")=PITM
                            LSUITE=1
                        Else
                            LSUITE=0
                        Endif
                    Endif
                    If LSUITE
                        NBS  = evalue(LZONQTY(ABR)+"(I)")
                        LSER = evalue(LZONSER(ABR)+"(I)")
                        If LSER <> "$" & LSER<>""
                            For J=1 To NBS
                                If find(LSER,LTABSER)
                                    If LNBERR<5
                                        If LNBERR=0
                                            PRET = 2
                                            GMESSAGE=mess(69,187,1)+":"    # Numéro de série en cours de création
                                            GERR=1
                                            mkstat=2
                                        Endif
                                        GMESSAGE += "\"+LSER
                                        LNBERR +=1
                                    Else
                                        If LNBERR=5
                                            GMESSAGE += "\..."
                                            LSTOP = 1
                                            Break
                                        Endif
                                    Endif
                                Endif
                                If J<NBS
                                    Call PLUS_UN(LSER,LSER,LRET) From STKLIB
                                Endif
                            Next J
                        Endif
                    Endif
                Endif
                If LSTOP : Break : Endif
            Next I
            If GERR  : Break : Endif
            If LSTOP : Break : Endif
        Next ABR
    Endif
    If LRET>0
        GMESSAGE=mess(40,196,1)    # Saisie numéro de série incorrecte
        GERR = 1
        mkstat = 2
        PRET = 6
    Else
        PSERF = LTABSER(PQTY-1)
    Endif
End

########################################################################
# RECSER_F        Controle  numero de serie
########################################################################
# Paramètres E :
#                PSER = N° de série saisi
#                PQTY = Quantité
#                PITM = Ref Article
#                PTRS = Type de transaction (m704)
#                PVCRTYP = type de pièce
#                PVCRNUM = n° de pièce
#                PVCRLIN = n° de ligne de la pièce
#                PTYPORI = type de la pièce d'origine
#                PVCRORI = n° de la pièce d'origine
#                PLINORI = N° de la ligne d'origine
#                PSEQORI = N° de séquence d'origine (utilisé uniquement pour la réintégration)
#                PSERO  = N° série origine si appel depuis STOENTM           : # Issue 110327
#                PSERFO = N° série origine fin si appel depuis STOENTM       : # Issue 110327
# Paramètres S :
#                PSERF= N° de série fin
#
# Prérequis    : Ces tables doivent être ouvertes   ITMMASTER
#                                                   STOSER
#
########################################################################
#--- Issue 110327 ajout paramètres PSERO et PSERFO
Subprog RECSER_F(PSER,PQTY,PITM,PTRS,PVCRTYP,PVCRNUM,PVCRLIN,PTYPORI,PVCRORI,PLINORI,PSEQORI,PSERO,PSERFO,PSERF)
Value    Char     PSER
Value    Decimal  PQTY
Value    Char     PITM
Value    Integer  PTRS
Value    Integer  PVCRTYP
Value    Char     PVCRNUM
Value    Integer  PVCRLIN
Value    Integer  PTYPORI
Value    Char     PVCRORI
Value    Integer  PLINORI
Value    Integer  PSEQORI
Value    Char     PSERO
Value    Char     PSERFO
Variable Char     PSERF

    Local Integer  PRET    # -1=pas d'erreur
    Local Integer  LRCPCUR # =1 ssi N° de série trouvé dans le fichier et entré par le document en cours
    Local Integer  LISSORI # =1 ssi N° de série sorti par doc d'origine PVCRORI et PLINORI
    Local Integer  LMODIF  # =1 ssi clalev([m:enm]) ou clalev([m:ssl])
    Local Decimal  I
    Local Char     LSERD(GLONSER) : LSERD = PSER
    Local Char     LSERF(GLONSER) : LSERF = PSER
    Local Integer  LRET, LERR
#                LRET = -1 = Pas d'erreur
#                        0 = Numero de Série inexistant
#                        1 = Numero de Série existant
#                        2 = Numero de Série en cours de création
#                        3 = Date de sortie non renseignée
#                        4 = Document de sortie renseigné
#                        5 = Date de sortie renseignée
#                        6 = Saisie des numéros de série incorrecte
#                        7 = Nombre de no de série sélectionnés incorrect

    PRET = -1
    Raz LERR
#    LMODIF = clalev([SSL1]) | clalev([ENM])      # hcb 116671
     LMODIF = clalev([ENM])                       # hcb 116671

    #--- Issue 110327
    If !clalev([STO]) Local File STOCK     [STO] Endif
    If !clalev([STS]) Local File STOSER    [STS] Endif
    If !clalev([ITM]) Local File ITMMASTER [ITM] Endif
    If [F:ITM]ITMREF<>PITM
        Read [F:ITM]ITM0=PITM
    Endif
    #################
    # Cas ou la saisie est vide
    If PSER = ""
        Case PTRS
            When 1, 3, 5, 7, 16 : # entree diverse - reception founisseur - declaration production HCB - reception sous traitance
                If [F:ITM]SERCOU = ""    # Vérifie qu'il existe un compteur
                    PRET = 6
                Endif

            When 12, 14, 18, 19, 33 : # retour client - transfert inter-sites - retour pret - réintégration - retour matière sous traitance
                PRET = 6

            When Default : Wrnbox "Cas non traité"+chr$(13)+"TRSTYP="+num$(PTRS)

        Endcase
    #################
    # Cas ou la saisie est non vide
    Else
        Local Integer WRCPISSSER
        Raz WRCPISSSER
        GPOINT="RCPISSSER" : Gosub ENTREE From EXEFNC

        I = PQTY
        While I > 0 & PRET=-1
          #--- Issue 110327
          If PSERO="" | (LSERF<PSERO | LSERF>PSERFO)
            #lecture STOSER
            Call LECSER (PITM,LSERF,"",PRET) From STKLIB
            # Dans le cas du plan de rangement, si le numéro de série
            # a été trouvé, il faut vérifier que celui-ci a été créé
            # avec le pièce qui a généré l'entrée à quai (-> LSSL=1).
            Raz LRCPCUR
            Raz LISSORI
            If PRET=1
                If [F:STS]RCPVCRNUM = PVCRNUM &
&                  [F:STS]RCPVCRTYP = PVCRTYP &
&                  [F:STS]RCPVCRLIN = PVCRLIN
                    LRCPCUR = 1
                    #--- Issue 110327
                    If [F:STS]SDHNUM<>"" & [F:STS]SDHNUM<>PVCRORI
                        LISSORI = 4
                    Endif
                    #---
                Elsif [F:STS]SDHNUM<>""       &
&                     [F:STS]SDHNUM = PVCRORI &
&                     [F:STS]SDHTYP = PTYPORI &
&                     [F:STS]SDDLIN = PLINORI
                    LISSORI = 2
                Elsif [F:STS]SDHNUM<>""       &
&                     [F:STS]SDHNUM = PVCRORI &
&                     [F:STS]SDHTYP = PTYPORI
                    LISSORI = 1
                Endif
            Endif
            # Regarde pour chaque type de transaction stock,
            # Si le retour de LECSER correspond à une erreur ou non
            Case PTRS
                When 1  : # Entrée diverse : le numéro de série ne doit pas exister
                          If PRET=0
                              PRET = -1
                          # S'il existe
                          Elsif PRET=1
                              # On est dans le plan de rangement où le moteur de modif
                              If LRCPCUR & LMODIF
                                  PRET = -1
                              Elsif WRCPISSSER=1 & [F:STS]ISSDAT<>[0/0/0]
                                  PRET = -1
                              # Il a été sorti par une sortie diverse
                              Elsif [F:STS]ISSDAT<>[0/0/0] & ([F:STS]SDHTYP=20 | [F:STS]SDHTYP=31 |[F:STS]SDHTYP=32 | [F:STS]SDHTYP=12)   # hcb 100155
                                  PRET = -1
                              Else
                                  PRET = 3
                              Endif
                          Endif
                # Reception fournisseur (sous-traitance)
                When 3,16 : # le no série ne doit pas exister si pas de pièce origine
                            If PRET=0 & (PVCRORI="" | PTYPORI=14)
                                PRET=-1
                            # s'il existe, il doit avoir été entré par la pièce courante
                            # ou sorti par la pièce origine
                            Elsif PRET=1
                                #--- Issue 110327
                                #If LRCPCUR & LMODIF | LISSORI=2
                                If LRCPCUR & LMODIF & LISSORI<>4 | LISSORI=2
                                #---
                                    PRET=-1
                                Elsif WRCPISSSER=1 & [F:STS]ISSDAT<>[0/0/0]
                                    PRET = -1
                                #--- Issue 110327
                                Elsif LISSORI=4
                                    PRET=8
                                #---
                                Elsif LISSORI=1
                                    PRET=9
                                #--- Issue 112493
                                Elsif [F:STS]RCPVCRTYP=13 & PTYPORI=4
                                    PRET=-1
                                #---
                                Endif
                            Endif
                # Declaration production
                When 5  : # le numéro de série ne doit pas exister ou
                          # s'il existe, il doit avoir été entré par la pièce courante
                          If PRET=0 | (PRET=1 & LRCPCUR & LMODIF)
                              PRET = -1
                          Elsif WRCPISSSER=1 & [F:STS]ISSDAT<>[0/0/0]
                              PRET = -1
                          Endif
                # Changement emplacement
                When 7  : If PRET = 1
                              PRET = -1
                          Endif
                # Retour client
                When 12 : # le numéro de série doit exister et la date de sortie être renseignée
                          If PRET=1
                              If [F:STS]ISSDAT = [0/0/0]
                                  PRET = 3
                              Elsif PVCRORI<>""
                                If [F:STS]SDHTYP = PTYPORI
                                  If [F:STS]SDHNUM<>PVCRORI
                                      PRET = 8 # N° de série sorti par une autre pièce
                                  Elsif [F:STS]SDDLIN<>PLINORI
                                      PRET = 9 # N° de série sorti sur une autre ligne de la pièce
                                  Else
                                      PRET = -1
                                  Endif
                                Endif
                              Else
                                  PRET = -1
                              Endif
                          Elsif PVCRORI=""
                              LERR = 2    # Msg d'avertissement
                              PRET=0
                          Endif
                # Transfert intersite
                When 14 : #--- Bug 66077
                          # le numéro de série doit exister
                          #If PRET = 1
                          #    PRET = -1
                          #Endif
                          # Si série géré en sortie, il peut ne pas exister
                          If PRET=0 & [F:ITM]SERMGTCOD=2
                             PRET=-1
                          # Sinon, il peut exister
                          Elsif PRET=1
                             PRET=-1
                          Endif
                          #---
                #--- Issue 110327 : supression du 'when 33'
                # Retour pret
                When 18 : # le no série doit exister
                          If PRET=1
                              If [F:STS]SDHNUM = ""
                                  PRET = 3
                              Elsif [F:STS]ISSDAT  <> [0/0/0]
                                  If [F:STS]SDHNUM<>PVCRORI
                                      PRET = 8 # N° de série sorti par une autre pièce
                                  Elsif [F:STS]SDDLIN<>PLINORI
                                      PRET = 9 # N° de série sorti sur une autre ligne de la pièce
                                  Endif
                              Else
                                  PRET=-1
                              Endif
                          Else
                              If PVCRORI=""
                                  LERR = 2    # Msg d'avertissement
                                  PRET=0
                              Endif
                          Endif
                #--- Issue 110327
                # Retour matière sous traitance
                When 33 : # le no série doit exister
                          If PRET=1
                              If [F:ITM]SERMGTCOD=4
                                  Read [STO]STO0=[F:STS]STOFCY;[F:STS]STOCOU
                                  If fstat | [F:STO]LOCCAT<>4
                                      PRET=10
                                  Endif
                              Endif
                              If PRET = 1
                                  If [F:STS]SDHNUM<>'' & [F:STS]SDHNUM<>PVCRORI
                                      PRET = 8 # N° de série sorti par une autre pièce
                                  Else
                                      PRET=-1
                                  Endif
                              Else
                                  If PVCRORI=""
                                      LERR = 2    # Msg d'avertissement
                                      PRET=0
                                  Endif
                              Endif
                          Endif
                #--- End issue 110327
                # Reintegration stock
                # Dans la table STS, c'est le n° de suivi qui est renseigné pas le n° d'OF
                # => on cherche dans stojou
                When 19 : # le no série doit exister
                          If PRET = 1
                              #--- Issue 110327
                              If [F:ITM]SERMGTCOD=4
                                  Filter [F:STJ] Where UPDCOD=2          & ITMREF=PITM
&                                                    & VCRTYPORI=PTYPORI & VCRNUMORI=PVCRORI
&                                                    & VCRLINORI=PLINORI & VCRSEQORI=PSEQORI
&                                                    & SERDEB<=PSER & SERFIN>=PSER & REGFLG<>2
                              Else
                                  Filter [F:STJ] Where UPDCOD=2          & ITMREF=PITM
&                                                    & VCRTYPORI=PTYPORI & VCRNUMORI=PVCRORI
&                                                    & VCRLINORI=PLINORI & VCRSEQORI=PSEQORI
&                                                    & SERNUM=PSER       & REGFLG<>2
                              Endif
#                              Filter [F:STJ] Where UPDCOD=2          & ITMREF=PITM
#&                                                & VCRTYPORI=PTYPORI & VCRNUMORI=PVCRORI
#&                                                & VCRLINORI=PLINORI & VCRSEQORI=PSEQORI
#&                                                & SERNUM=PSER       & REGFLG<>2
                              #--- End issue 110327
                              Look [STJ]STJ2 First
                              If fstat
                                PRET = 8
                              Else
                                PRET = -1
                              Endif
                              Filter [STJ]
                          Endif
                When Default : PRET=-1
                            Wrnbox "Cas non traité"+chr$(13)+"TRSTYP="+num$(PTRS)

            Endcase
          #--- Issue 110327
          Endif

          I -= 1
          If I>0 & PRET=-1
              Call PLUS_UN(LSERD,LSERF,LRET) From STKLIB
              If LRET <> 0
                  PRET = 7
              Else
                  LSERD = LSERF
              Endif
          Endif
        Wend

    Endif
    If PRET=-1
        PSERF = LSERF
    Else
        PSERF = ""

        Case PRET
             When 0 : GERR=max(LERR,1) : mkstat = 2*(GERR=1) : GMESSAGE = LSERF-":"-mess(43,196,1)  # Numero de Série inexistant
             When 1 : GERR=max(LERR,1) : mkstat = 2*(GERR=1) : GMESSAGE = LSERF-":"-mess(3,187,1)   # Numero de Série existant
             When 2 : GERR=max(LERR,1) : mkstat = 2*(GERR=1) : GMESSAGE = LSERF-":"-mess(69,187,1)  # Numero de Série en cours de création
             When 3 : GERR=max(LERR,1) : mkstat = 2*(GERR=1) : GMESSAGE = LSERF-":"-mess(93,184,1)  # Numéro de série présent en stock
             When 4 : GERR=max(LERR,1) : mkstat = 2*(GERR=1) : GMESSAGE = LSERF-":"-mess(72,187,1)  # Document de sortie renseigné
             When 5 : GERR=max(LERR,1) : mkstat = 2*(GERR=1) : GMESSAGE = LSERF-":"-mess(73,187,1)  # Date de sortie renseignée
             When 6 : GERR=max(LERR,1) : mkstat = 2*(GERR=1) : GMESSAGE = LSERF-":"-mess(40,196,1)  # Saisie des numéros de série incorrecte
             When 7 : GERR=max(LERR,1) : mkstat = 2*(GERR=1) : GMESSAGE = num$(PQTY)-":"-mess(130,194,1) # Nombre de no de série sélectionnés incorrect
             When 8 : GERR=max(LERR,1) : mkstat = 2*(GERR=1) : GMESSAGE = LSERF-":"-mess(37,184,1)  # N° de série sorti par une autre pièce
             When 9 : GERR=max(LERR,1) : mkstat = 2*(GERR=1) : GMESSAGE = LSERF-":"-mess(38,184,1)  # N° de série sorti sur une autre ligne de la pièce
        Endcase
    Endif
End

#########################################################################
# CTLUOM : Contrôle d'une unité avec récupération du coefficient
#          et du flag coef saisissable
#########################################################################
# Paramètres E : LITM    = Article
#                LTYP    = Type unité (1=Achat,2=Vente,3=Stock)
#                LBPR    = Tiers
# Paramètres S : LUOM    = Unite à contrôler
#                LCOE    = Coefficient xx-US
#                LUSCAV  = Unite Stock, Conditionnement, Achat ou Vente (="S","C","A","V","AF","CF")
#                          (F=unité spécifique au fournisseur)
#                          (O=unité main d'oeuvre)
#                LLBEFMT = Format etiquette
#                LDACCOE = Flag Saisie coefficient autorisé (0,1=non,2=oui)
#
# Les tables suivantes peuvent être utilisées ITMMASTER
#                                             ITMBPS - ITMBPC
#                                             TABUNIT
#                                             Elles sont ouvertes si nécessaire
#########################################################################
Subprog CTLUOM(LITM, LTYP, LBPR, LUOM, LCOE, LUSCAV, LLBEFMT, LDACCOE)
Value    Char    LITM
Value    Integer LTYP
Value    Char    LBPR
Variable Char    LUOM
Variable Decimal LCOE
Variable Char    LUSCAV
Variable Char    LLBEFMT
Variable Integer LDACCOE

Local    Integer  I, K
Local    Char     WUOM, TUOM(GLONUOM)(4)
Local    Shortint LOK   : LOK=0    : # Flag indiquant si le coef a été trouvé
# Init des paramètres de sortie
LCOE=0
Raz LUSCAV
Raz LLBEFMT
LDACCOE = 1
#
WUOM=LUOM
WUOM = vireblc(WUOM,1)
If WUOM = "" End : Endif
#
TUOM(0) = WUOM
TUOM(1) = toupper(WUOM)
TUOM(2) = tolower(WUOM)
TUOM(3) = toupper(left$(WUOM,1))+tolower(mid$(WUOM,2,2))
Raz WUOM
If clalev([F:ITM]) = 0 Local File ITMMASTER [ITM]:Endif
If [F:ITM]ITMREF <> LITM Read [ITM]ITM0=LITM Endif

If find([F:ITM]STU,TUOM)
#   --------------------------------------------------------#
#   L'unité est l'unité de stock                            #
#   --------------------------------------------------------#
    WUOM=[F:ITM]STU : LCOE=1 : LDACCOE=1
    LLBEFMT = [F:ITM]STULBEFMT
    LUSCAV = "S"
Else
#   --------------------------------------------------------#
#   L'unité est une unité de conditionnement                #
#   -->  Récup. coef.conversion UC-US                       #
#   --------------------------------------------------------#
    For I=0 To dim([F:ITM]PCU)-1
       If find([F:ITM]PCU(I),TUOM)
          WUOM=[F:ITM]PCU(I)
          LCOE=[F:ITM]PCUSTUCOE(I)
          LDACCOE=[F:ITM]DACPCUCOE(I)
          LLBEFMT = [F:ITM]LBEFMT(I)
          LUSCAV = "C"
          Break
       Endif
    Next I
Endif
#   --------------------------------------------------------#
#   Particularité pour les stocks                           #
#   --------------------------------------------------------#
If LTYP=3
   If LUSCAV <> ""
      End
   Endif


#  Si un fournisseur est spécifié, les unités dans la table Article-Fournisseur (ITMBPS)
#  sont prioritaires sur les unités spécifiées dans l'article
    If LBPR <>""
        # Positionnement dans la table ITMBPS
        If clalev([F:ITP]) = 0 Local File ITMBPS [ITP]: Endif
        If [F:ITP]ITMREF<>LITM & [F:ITP]BPSNUM<>LBPR
            Read [ITP]ITP0=LITM;LBPR
            If fstat  Raz [F:ITP] Endif
        Endif
        If find([F:ITP]PUU,TUOM)        : # UA de l'article-fournisseur
            WUOM    = [F:ITP]PUU
            LCOE    = [F:ITP]PUUSTUCOE
            LUSCAV  = "AF"
            LLBEFMT = ""
            LOK = 1
        Endif
        If find([F:ITP]PCU,TUOM)        : # UC de l'article-fournisseur
            WUOM    = [F:ITP]PCU
            LCOE    = [F:ITP]PCUPUUCOE*[F:ITP]PUUSTUCOE
            LUSCAV  = "CF"
            LLBEFMT = ""
            LOK = 1
        Endif
    Endif
    # Si l'unité à chercher ne correspond pas à une unité article-fournisseur
    # on cherche dans les unités de l'article
    If !LOK
            If find([F:ITM]PUU,TUOM)    : # UA article
                WUOM    = [F:ITM]PUU
                LCOE    = [F:ITM]PUUSTUCOE
                LDACCOE = [F:ITM]DACPUUCOE-1
                LUSCAV  = "A"
                LLBEFMT = ""
                LOK = 1
            Else
                If find([F:ITM]SAU,TUOM) : # UV article
                    WUOM    = [F:ITM]SAU
                    LCOE    = [F:ITM]SAUSTUCOE
                    LDACCOE = [F:ITM]DACSAUCOE-1
                    LUSCAV  = "V"
                    LLBEFMT = ""
                    LOK = 1
                Endif    # UV
            Endif    # UA
    Endif


        # Si aucun format d'étiquette n'a été trouvé, on prend celui de l'unité de stock
    If LLBEFMT=""
       LLBEFMT = [F:ITM]STULBEFMT
    Endif

    If LCOE=0
        LUSCAV = ""
        LLBEFMT=""
    Endif

    #pas de saisie si unité de numération
    If clalev([F:TUN]) = 0 Local File TABUNIT [TUN] : Endif
    Read [TUN]TUN0=WUOM
    If fstat = 0 & [F:TUN]UOMTYP = 6 LDACCOE = 1 Endif
Elsif LTYP=2
#   --------------------------------------------------------#
#   Particularité pour le module vente                      #
#   --------------------------------------------------------#
    If WUOM = [F:ITM]STU LUOM=WUOM : End : Endif
    Gosub INI_ITMCOE         : # Init. coef ITM utilisées comme diviseurs
#   --------------------------------------------------------#
#   Lecture ITU  : Si l'unité est l'unité de vente          #
#                  -->  Récup coef.conversion UV-US         #
#                  Si l'unité est une unité de cond.        #
#                  -->  Calcul coef.conversion UC-US        #
#                         UC-US = UC-UV (ITU) * UV-US (ITM) #
#   --------------------------------------------------------#
    If clalev([F:ITU]) = 0 Local File ITMBPC [ITU] : Endif
    If [F:ITU]ITMREF <> LITM | [F:ITU]BPCNUM <> LBPR
        Read [ITU] ITU0=LITM;LBPR
        If fstat Raz [F:ITU] : Endif
    Endif
    Gosub INI_ITUCOE     : # Init. coef ITU utilisées comme diviseurs
    If find([F:ITU]SAU,TUOM)
        LUOM=[F:ITU]SAU  : LDACCOE=1 : LCOE  = [F:ITU]SAUSTUCOE : End
    Endif
    If find([F:ITU]PCU1,TUOM)
        LUOM=[F:ITU]PCU1 : LDACCOE=1 : LCOE  = [F:ITU]PCUSAUCOE1*[F:ITU]SAUSTUCOE : End
    Endif
    If find([F:ITU]PCU2,TUOM)
        LUOM=[F:ITU]PCU2 : LDACCOE=1 : LCOE  = [F:ITU]PCUSAUCOE2*[F:ITU]SAUSTUCOE : End
    Endif

    If find([F:ITM]SAU,TUOM) : # UV article
        LUOM = [F:ITM]SAU : LCOE=[F:ITM]SAUSTUCOE : LDACCOE=[F:ITM]DACSAUCOE : End
    Endif

#   --------------------------------------------------------#
#   Particularité si l'article est de type main d'oeuvre    #
#   --------------------------------------------------------#
    If [F:ITM]HDKITMTYP=3
       If find([F:ITM]DAYUOM,TUOM)
          LUOM=[F:ITM]DAYUOM : Gosub REC_LCOE : LDACCOE=1 : LUSCAV="O" : End
       Elsif find([F:ITM]HOUUOM,TUOM)
          LUOM=[F:ITM]HOUUOM : Gosub REC_LCOE : LDACCOE=1 : LUSCAV="O" : End
       Elsif find([F:ITM]MNTUOM,TUOM)
          LUOM=[F:ITM]MNTUOM : Gosub REC_LCOE : LDACCOE=1 : LUSCAV="O" : End
       Endif
    Endif
Elsif LTYP=1
#   --------------------------------------------------------#
#   Particularité pour le module achat                      #
#   --------------------------------------------------------#
    Raz LCOE
    LDACCOE=1
    If [F:ITM]PUUSTUCOE=0 : [F:ITM]PUUSTUCOE=1 : Endif
    If find([F:ITM]STU,TUOM) WUOM=[F:ITM]STU : LUSCAV="S" : LDACCOE=1 : LCOE=1
      If WUOM=""
        Gosub ERR_UOM
      Else
        LUOM=WUOM
      Endif
      End
    Endif
    If clalev([F:ITP])=0 : Local File ITMBPS     [ITP] : Endif
    If [F:ITP]ITMREF <> LITM | [F:ITP]BPSNUM <> LBPR
      Read [ITP]ITP0 = LITM;LBPR
      If fstat : Raz [F:ITP] : Endif
    Endif
    If [F:ITP]PUUSTUCOE=0 : [F:ITP]PUUSTUCOE=1 : Endif
    If [F:ITP]PCUPUUCOE=0 : [F:ITP]PCUPUUCOE=1 : Endif
    #-- Si l'unité saisie=unité d'achat du fournisseur ou unité de cdt fournisseur
    If find([F:ITP]PUU,TUOM)  | find([F:ITP]PCU,TUOM)
      #-- Et que cette unité est aussi l'unité d'achat de l'article
      If find([F:ITM]PUU,TUOM)
        WUOM=[F:ITM]PUU
        # Si coeff UA-US modifiable on prend coeff du fournisseur
        # sinon on prend le coeff de l'article
        If [F:ITM]DACPUUCOE=2
          If find([F:ITP]PUU,TUOM)
            LUSCAV="AF" : LCOE=[F:ITP]PUUSTUCOE
          Elsif find([F:ITP]PCU,TUOM)
            LUSCAV="CF" : LCOE=[F:ITP]PCUPUUCOE*[F:ITP]PUUSTUCOE
          Endif
          LDACCOE=2
        Else
          LUSCAV="A" : LCOE=[F:ITM]PUUSTUCOE : LDACCOE=1
        Endif
      Else
      #-- Cette unité fait-elle partie de la table de conditionnement ?
        For I=0 To dim([F:ITM]PCU)-1
         If find([F:ITM]PCU(I),TUOM)
            WUOM=[F:ITM]PCU(I)
            LCOE=[F:ITM]PCUSTUCOE(I)
            LDACCOE=[F:ITM]DACPCUCOE(I)
            Break
         Endif
        Next I
        #-- Elle n'en fait pas partie, le coeff n'est pas modifiable
        If WUOM=""
          If find([F:ITP]PUU,TUOM)
            WUOM=[F:ITP]PUU : LDACCOE=1 : LUSCAV="AF" : LCOE=[F:ITP]PUUSTUCOE
          Elsif find([F:ITP]PCU,TUOM)
            WUOM=[F:ITP]PCU : LDACCOE=1 : LUSCAV="CF" : LCOE=[F:ITP]PCUPUUCOE*[F:ITP]PUUSTUCOE
          Endif
        Else
        #-- Elle fait partie des unités de conditionnnement
        #-- Si le coeff est modifiable on prend celui du fournisseur
          If  LDACCOE=2
            If WUOM=[F:ITP]PUU
              LUSCAV="AF" : LCOE=[F:ITP]PUUSTUCOE
            Elsif WUOM=[F:ITP]PCU
              LUSCAV="CF" : LCOE=[F:ITP]PCUPUUCOE*[F:ITP]PUUSTUCOE
            Endif
          Endif
        Endif
      Endif
    Else
      #-- Et que cette unité est l'unité d'achat de l'article
      If find([F:ITM]PUU,TUOM)
        # Si coeff UA-US modifiable on prend coeff article
        # sinon on prend le coeff de l'article
        WUOM=[F:ITM]PUU : LUSCAV="A" : LCOE=[F:ITM]PUUSTUCOE
        LDACCOE=[F:ITM]DACPUUCOE
      Else
      #-- Cette unité fait-elle partie de la table de conditionnement
        For I=0 To dim([F:ITM]PCU)-1
         If find([F:ITM]PCU(I),TUOM)
            WUOM=[F:ITM]PCU(I)
            LCOE=[F:ITM]PCUSTUCOE(I)
            LDACCOE=[F:ITM]DACPCUCOE(I)
            Break
         Endif
        Next I
      Endif
    Endif
Endif
If WUOM=""
    Gosub ERR_UOM
Else
    LUOM=WUOM
Endif
End

$INI_ITMCOE
Local Integer K
If [F:ITM]SAUSTUCOE=0 : [F:ITM]SAUSTUCOE=1 : Endif
For K=0 To dim([F:ITM]PCU)-1
   If vireblc([F:ITM]PCU(K),2)<>"" & [F:ITM]PCUSTUCOE(K)=0 [F:ITM]PCUSTUCOE(K)=1 : Endif
Next K
Return

$INI_ITUCOE
If [F:ITU]SAUSTUCOE=0  : [F:ITU]SAUSTUCOE=1  : Endif
If [F:ITU]PCUSAUCOE1=0 : [F:ITU]PCUSAUCOE1=1 : Endif
If [F:ITU]PCUSAUCOE2=0 : [F:ITU]PCUSAUCOE2=1 : Endif
Return

# ---------------------------------------------------------------------------------------- #
# Particularité si l'unité est une unité main d'oeuvre : Pas de coef dans la table article #
# Recherche du coef de conversion directement dans la table des coefs                      #
# ---------------------------------------------------------------------------------------- #
$REC_LCOE
If LUOM = [F:ITM]STU : LCOE = 1 : Return : Endif
If clalev([F:TCO])=0 : Local File TABCOEFF [TCO] : Endif
Read [TCO]TCO0=LUOM;[F:ITM]STU
If fstat = 0
    LCOE = [F:TCO]COEUOM
Else
    Read [TCO]TCO0=[F:ITM]STU;LUOM
    If [F:TCO]COEUOM=0 : [F:TCO]COEUOM=1 : Endif
    If fstat = 0 LCOE = 1/[F:TCO]COEUOM : Endif
Endif
If LCOE=0 LCOE=1 Endif
Return


$ERR_UOM
mkstat=2 :
If LTYP=1
 GMESSAGE=mess(221,197,1) : # Unité d'achat incorrecte !
Elsif LTYP=2
 GMESSAGE=mess(9,192,1)   : # Unité de vente inconnue pour cet article
Elsif LTYP=3
 GMESSAGE=mess(228,197,1) : # Unité de stock incorrecte !
Else
 GMESSAGE=mess(238,192,1) : # Unité inconnue pour cet article !
Endif
If TUOM(0)<>"" GMESSAGE+=" : "+TUOM(0) : Endif
Return

########################################################################
# STKCTRCOE : Contrôle si le coef UC/US génère une qté US arrondie
########################################################################
# Paramètres E : LQTYPCU     = Quantité UC
#                LPCUSTUCOE  = Coefficient UC/US
#                LSTU        = Unité de stock
# Paramètres S : LRET        = Code retour (0=refusé, 1=ok)
########################################################################
Subprog STKCTRCOE(LQTYPCU,LPCUSTUCOE,LSTU,LRET)
Value    Decimal  LQTYPCU
Value    Decimal  LPCUSTUCOE
Value    Char     LSTU
Variable Integer  LRET

Local    Decimal  WQTYSTU, WQTYSTUARR
Local    Integer  VS
LRET=1
#--- Point d'entrée pour ne pas faire le contrôle
GPOINT = "NO_CTRCOE" : Gosub ENTREE From EXEFNC
If GOK=0 : GOK=1 : End : Endif

#--- Alimentation de la quantité en US
WQTYSTU    = LQTYPCU * LPCUSTUCOE
WQTYSTUARR = WQTYSTU
#--- Calcul qté US arrondi
Call QTEARR(WQTYSTUARR,LSTU) From TRTDIV
If WQTYSTU<>WQTYSTUARR
   VS = 2
   Call AVERTIR(mess(350,184,1),VS) From GESECRAN
   If VS=1 LRET=0 Endif
Endif

End

#########################################################################
# Sous-programmes divers
#########################################################################

########################################################################
# STKAMLOF : Après modification du lot fournisseur -> init du lot
########################################################################
# Paramètres E : PNEWBPS    = Nouvelle valeur lot fournisseur
#                PABR       = Abréviation du masque
#                PNOL       = Indice ligne
#                PITM       = Article
#                POLDBPS    = Ancienne valeur lot fournisseur
#                PZONLOT    = Nom de la zone lot
#                PZONSLO    = Nom de la zon sous-lot
#
# Paramètres S : PGESLOT    = "B" si lot blanc, "C" si compteur,
#                             "V" si reprise n° de pièce
#
# Prérequis      : Ces tables doivent être ouvertes et positionnées:
#                     TABSTORUL
#                     ITMMASTER
########################################################################
Subprog STKAMLOF(PNEWBPS, PABR, PNOL, PITM, PSTOFCY, POLDBPS, PZONLOT, PZONSLO, PZONTLO, PGESLOT)
Value    Char    PNEWBPS
Value    Char    PABR
Value    Integer PNOL
Value    Char    PITM
Value    Char    PSTOFCY
Value    Char    POLDBPS
Value    Char    PZONLOT
Value    Char    PZONSLO
Value    Char    PZONTLO
Variable Char    PGESLOT
#--- Issue 122875 remplacement LMSKCOU(7) par LMSKCOU(10)
Local Char LMSKCOU(10) : LMSKCOU = func STKLIB.MSKDEF
Local Char LMABR(10) : LMABR = "[M:"+PABR+"]"
Local Integer LNBSLO
Local Char LSLO(GLONSLO)

If !clalev([STL]) : Local File STOLOT [STL] : Endif

#---- Un lot fournisseur ne peut pas être rattaché à un lot blanc ---#
If PNEWBPS<>"" & PGESLOT="B"
    PGESLOT = ""
Endif

If [F:SRU]LOTSUPINH=2 & ( evalue(LMABR+PZONLOT+"(PNOL)") = ""
&                       | evalue(LMABR+PZONLOT+"(PNOL)") = POLDBPS
&                       | [F:SRU]DACLOT=1 )

    # Bug 24573 : TS le 02.09.04
    # Vérification qu'il n'existe pas un lot = lot fournisseur saisi,
    # mais ayant comme lot fournisseur une autre valeur
    Read [STL]STL0(2)=PITM;PNEWBPS
    [G:STL]currlen = 0
    If !fstat & [F:STL]BPSLOT<>PNEWBPS
        End
    Endif

    Default Mask "["+PABR+"]"
    Assign LMABR+PZONLOT+"(PNOL)" With PNEWBPS
    Affzo =PZONLOT+"(PNOL)"
    If PNEWBPS=""
        If [F:ITM]LOTCOU<>""
           PGESLOT = "C"    # Compteur article
        Else
           PGESLOT=""
        Endif
        If [F:ITF]LOCMGTCOD=2 & evalue("dim("+LMABR+PZONTLO+"(PNOL))")>0
            If [F:TLO]STOFCY<>PSTOFCY | [F:TLO]LOCTYP<>evalue(LMABR+PZONTLO+"(PNOL)")
                Read [TLO]TLO0=[M:ENT]STOFCY;evalue(LMABR+PZONTLO+"(PNOL)")
                If fstat    # Ne doit jamais arriver, car controlé avant.
                    mkstat = 2
                    End
                Endif
            Endif
            # test si type quai
            If [F:TLO]LOCCAT = 2
                PGESLOT = ""
            Endif
        Endif
    Else
        PGESLOT = ""
    Endif
    Default Mask LMSKCOU
    Call STKAMLOT( evalue(LMABR+PZONLOT+"(PNOL)"), PABR, PNOL, PITM, PZONSLO )
Elsif [F:SRU]DACLOT=1
    If evalue("dim("+LMABR+PZONSLO+")")>0
        LSLO = evalue(LMABR+PZONSLO+"(PNOL)")
    Else
        LSLO = ""
    Endif
    If evalue("dim("+LMABR+"NBSLO)")>0
        LNBSLO = evalue(LMABR+"NBSLO(PNOL)")
    Else
        LNBSLO = 1
    Endif
    Call STKCTRLOF( PNEWBPS, PITM, evalue(LMABR+PZONLOT+"(PNOL)"), LSLO, LNBSLO, PGESLOT )
Endif
End


########################################################################
# STKCTRLOF : Contrôle que le lot fournisseur saisi est associable avec le lot/slo
########################################################################
# Paramètres E : PBPSLOT    = Nouvelle valeur lot fournisseur
#                PITM       = Article
#                PLOT       = Lot
#                PSLO       = Sous-lot
#                PNBSLO     = Nombre de sous-lots
#
# Prérequis      : Ces tables doivent être ouvertes et positionnées:
#                     ITMMASTER
########################################################################
Subprog STKCTRLOF( PBPSLOT, PITM, PLOT, PSLO, PNBSLO, PGESLOT )
Value Char    PBPSLOT
Value Char    PITM
Value Char    PLOT
Value Char    PSLO
Value Integer PNBSLO
Value Char    PGESLOT

If  PLOT="" & PGESLOT<>"V"
& | (PSLO="" & [F:ITM]LOTMGTCOD=4 & GFEALOTLEV<>2)
    End
Endif

Local Integer I, LRET
Local Integer LLIGLOT
Local Char    LSLO

If [F:ITM]ITMREF<>PITM  Read [ITM]ITM0=PITM  Endif
#--- Gestion des sous-lots sans gestion d'unicité des lots
If [F:ITM]LOTMGTCOD=4 & GFEALOTLEV<>2
    LSLO = PSLO
    For I=1 To PNBSLO
        Read [STL]STL0=PITM;PLOT;LSLO
        If !fstat
            If PBPSLOT<>[F:STL]BPSLOT
                mkstat=2
                GMESSAGE=mess(19,184,1)-[F:STL]BPSLOT
                Break
            Endif
        Else    # recherche dans les masques
            # On regarde si le lot a déjà été utilisé pour un autre lot fournisseur
            If dim([M]WSTOSEQ)=1
                Call SEARCHLOTENTW( PITM, PLOT, LSLO, [M]WSTOSEQ, LLIGLOT ) From STKENTA
            Elsif dim([M]WSTOSEQ)>1
                Call SEARCHLOTENTW( PITM, PLOT, LSLO, [M]WSTOSEQ(nolign-1), LLIGLOT ) From STKENTA
            Endif
            If LLIGLOT<0 | clalev([M:ENM])
                If clalev([M:ENT])
                    Call SEARCHLOTENT( PLOT, LSLO, nolign-1, LLIGLOT ) From STKENTA
                    If LLIGLOT>=0 & PBPSLOT <> [M:ENT]BPSLOT(LLIGLOT)
                        mkstat = 2
                        GMESSAGE=mess(19,184,1)-[M:ENT]BPSLOT(LLIGLOT)
                    Endif
                Elsif clalev([M:ENM])
                    Call SEARCHLOTENM( PLOT, LSLO, nolign-1, LLIGLOT ) From STKENTA
                    If LLIGLOT>=0 & PBPSLOT <> [M:ENM]BPSLOT(LLIGLOT)
                        mkstat = 2
                        GMESSAGE=mess(19,184,1)-[M:ENM]BPSLOT(LLIGLOT)
                    Endif
                Endif
            Else
                If PBPSLOT <> [M:ENTW]BPSLOT(LLIGLOT)
                    mkstat = 2
                    GMESSAGE=mess(19,184,1)-[M:ENTW]BPSLOT(LLIGLOT)
                Endif
            Endif
        Endif
        If I<PNBSLO
            Call PLUS_UN(LSLO,LSLO,LRET) From STKLIB
            If LRET
                mkstat=2
                Break
            Endif
        Endif
    Next
Else
    Read [STL]STL0(2)=PITM;PLOT
    [G:STL]currlen = 0
    If !fstat
        If PBPSLOT<>[F:STL]BPSLOT
            mkstat=2
            GMESSAGE=mess(19,184,1)-[F:STL]BPSLOT
        Endif
    Endif
    If !mkstat    # recherche dans les masques
        #--- Puis dans STOENTW
        If dim([M]WSTOSEQ)=1    # Cas du ctrl lot dans STOENT
            Call SEARCHLOTENTW( PITM, PLOT, "", [M]WSTOSEQ, LLIGLOT ) From STKENTA
        Elsif dim([M]WSTOSEQ)>1
            Call SEARCHLOTENTW( PITM, PLOT, "", [M]WSTOSEQ(nolign-1), LLIGLOT ) From STKENTA
        Endif
        If LLIGLOT<0 | clalev([M:ENM])
            If clalev([M:ENT])
                Call SEARCHLOTENT( PLOT, "", nolign-1, LLIGLOT ) From STKENTA
                If LLIGLOT>=0 & PBPSLOT <> [M:ENT]BPSLOT(LLIGLOT)
                    mkstat = 2
                    GMESSAGE=mess(19,184,1)-[M:ENT]BPSLOT(LLIGLOT)
                    End
                Endif
            Elsif clalev([M:ENM])
                Call SEARCHLOTENM( PLOT, "", nolign-1, LLIGLOT ) From STKENTA
                If LLIGLOT>=0 & PBPSLOT <> [M:ENM]BPSLOT(LLIGLOT)
                    mkstat = 2
                    GMESSAGE=mess(19,184,1)-[M:ENM]BPSLOT(LLIGLOT)
                    End
                Endif
            Endif
        Else
            If PBPSLOT <> [M:ENTW]BPSLOT(LLIGLOT)
                mkstat = 2
                GMESSAGE=mess(19,184,1)-[M:ENTW]BPSLOT(LLIGLOT)
                End
            Endif
        Endif
    Endif
Endif

End


########################################################################
# STKAMLOT : Calcule le n° de sous lot en fonction du nouveau lot saisi
########################################################################
# Paramètres E : PLOT       = Lot
#                PABR       = Abréviation écran
#                PNOL       = Indice de ligne en cours
#                PITM       = Article
#                PZONSLO    = Nom de la szone sous-lot
########################################################################
Subprog STKAMLOT( PLOT, PABR, PNOL, PITM, PZONSLO)
Value Char    PLOT
Value Char    PABR
Value Integer PNOL
Value Char    PITM
Value Char    PZONSLO
#--- Issue 122875 remplacement LMSKCOU(7) par LMSKCOU(10)
Local Char LMSKCOU(10) : LMSKCOU = func STKLIB.MSKDEF
Local Char LMABR(10) : LMABR = "[M:"+PABR+"]"
Local Char LSLO(GLONSLO)
If !clalev([STL]) : Local File STOLOT [STL] : Endif
If [F:ITM]LOTMGTCOD=4 & PZONSLO<>"" & evalue("dim("+LMABR+PZONSLO+")")>0
    Look [STL]STL0=PITM;PLOT;evalue(LMABR+PZONSLO+"(PNOL)")
    If fstat
        Default Mask "["+PABR+"]"
        If PABR = "ENT" | PABR = "ENM"                                # hcb 50325
           Call RECLASTSLO(PITM, PLOT, PABR, "", LSLO) From STKLIB    # hcb 50325
        Else
           Call RECLASTSLO(PITM, PLOT, "", "", LSLO) From STKLIB
        Endif
        Assign LMABR+PZONSLO+"(PNOL)" With LSLO
        Affzo =PZONSLO+"(PNOL)"
        Default Mask LMSKCOU
    Endif
Endif

End

#                                                                                # hcb 71276 deb
########################################################################
# STKINIECC Recherche  versions majeure et mineure d'un article
########################################################################
#   Prérequis :  ITMMASTER doit etre chargé avec l'article PITM
########################################################################
#                PITM       = Article
#                PLOT       = Lot
#                PABR       = Abréviation écran
#                PSAI       = Mode initialisation  1 = Article ou Article fournisseur  2 = Article + Lot
#                                  ex : apres saisie article  + lot : PSAI = 2 (Réception , entree diverse ...)
#                                       apres saisie article          PSAI = 1 (Article , commande fournisseur , demande achat  ....)
#                PTAB       = Mode tableau 1 = non 2 = oui
#                                  ex : appel depuis un document PTAB = 2 depuis les VT PTAB = 1
#                PNOL       = Indice ligne si PTAB = 2
#                PAFF       = Mode affichage 1 = non 2 = oui
#                                  ex : appel depuis une menu transactionnel PAFF = 2 depuis un import PAFF = 1
#                PMAJ       = Version majeur si deja connu
#                PZONMAJ    = Nom de la rubrique version majeure à renseigner
#                PZONMIN    = Nom de la rubrique version mineure à renseigner
#                PZONMAJORI = Nom de la rubrique version majeure contenant la version majeure du document origine
#                PZONMINORI = Nom de la rubrique version mineure contenant la version mineure du document origine
#                PTYPTIERS  = 0 = toujours préchargement > 0 préchargement
#                             1 = fournisseur 2 = client 3 client et fournisseur = client
#                PBPRNUM     = Numéro de tiers
#
########################################################################
Subprog STKINIECC(PITM,PLOT,PABR,PSAI,PTAB,PNOL,PAFF,PMAJ,PZONMAJ,PZONMIN,PZONMAJORI,PZONMINORI,PTYPTIERS,PBPRNUM)
Value Char    PITM
Value Char    PLOT
Value Char    PABR
Value Integer PSAI
Value Integer PTAB
Value Integer PNOL
Value Integer PAFF
Value Char    PMAJ
Value Char    PZONMAJ
Value Char    PZONMIN
Value Char    PZONMAJORI
Value Char    PZONMINORI
Value Integer PTYPTIERS
Value Char    PBPRNUM

If [F:ITM]ITMREF<>PITM
   Read [ITM]ITM0=PITM
Endif

# l'article ne gére pas les versions : end
If [F:ITM]ECCSTO < 2
   End
Endif
# la rubrique version majeure n'est pas renseignée : end
If PZONMAJ = ""
   End
Endif
# si la rubrique version majeure est inexistente : end
Local Char    LMABR(10)  : LMABR = "[M:"+PABR+"]"
# Issue 119057 - 2016-10-12 by MAE
#If evalue("dim("+LMABR+PZONMAJ+")")= 0
If evalue("dim("+LMABR+PZONMAJ+")")<1
   End
Endif

# la version majeure est deja renseignée : end
If PMAJ <> ""
   End
Endif
# si l initialisation a ete deja faite  : end
If evalue("dim([M:"+PABR+"]ECCSAIFLG)") >= 0  PTAB = 2
   If evalue(LMABR+"ECCSAIFLG(PNOL)") > 0
      End
   Endif
Endif
#--- Issue 122875 remplacement LMSKCOU(7) par LMSKCOU(10)
Local Char    LMSKCOU(10) : LMSKCOU = func STKLIB.MSKDEF
Local Integer NUMLIGLOT
Local Integer NBL
Local Integer LSUITE
Local Integer LRET
Local Char    WECCVALMAJ(GLONECS)
Local Char    WECCVALMIN(GLONICVVAL)
Local Integer WECCSTA
Local Integer WECCSAIFLG
Local Integer WLOAECCFLG
Raz LRET
Raz WECCVALMAJ
Raz WECCVALMIN
Raz WECCSTA
Raz WECCSAIFLG
Raz WLOAECCFLG
# ECCSAIFLG = 0 Pour un article suivi en version l'initialisation n'a pas ete faite
# ECCSAIFLG = 1 rubriques ECCVALMAJ/MIN non saisissables ou initialisation faite  pour demande achat
# ECCSAIFLG = 3 rubriques ECCVALMAJ/MIN non saisissables sur ligne document mais possible par le complement lot
# ECCSAIFLG = 2 rubriques ECCVALMAJ/MIN     saisissables
# la rubrique ECCSAIFLG est technique elle permet la modification ou non dans le complément lot
Local File STOLOT [STL]
Local File ECCSTA [ECS]
Local File ECCVAL [EVL]


# si mode saisie egale 1 on recherche uniquement dans la table ECCSTA
If PSAI = 1
   Gosub READECCSTA
   Goto  AFFICH_ECC
Endif

# si le lot est un lot blanc pas d affectation des versions
If PAFF = 2 & evalue("dim([M:"+PABR+"]GESLOT)") >= 0 & evalue(LMABR+"GESLOT(PNOL)") = "B" & PLOT = ""
    Raz WECCVALMAJ
    Raz WECCVALMIN
    Raz WECCSTA
    WECCSAIFLG = 1
    Goto AFFICH_ECC
Endif
# si lot saisi
If PLOT <> ""
   Filter [STL] Where ITMREF = PITM   &  LOT = PLOT
   For [STL]
# si lot existe récuperation ECCVAMAJ/MIN de STOLOT
       LRET = 1
       WECCVALMAJ = [F:STL]ECCVALMAJ
       WECCVALMIN = [F:STL]ECCVALMIN
       WECCSAIFLG = 1
       Break
   Next
   Filter [STL]
   If LRET = 1
      Goto AFFICH_ECC
   Else
# En mode tableau le lot est peu etre deja saisie -> recherche
      If PTAB = 2
         If PABR <> "SNL1"
            If PABR = "ENT" | PABR = "ENM"
               NBL     =  evalue(LMABR+"NBLIG")
               NUMLIGLOT = -1
               Case PABR
                    When "ENT" : Call SEARCHLOTENT ( PLOT, "", -1, NUMLIGLOT) From STKENTA
                    When "ENM" : Call SEARCHLOTENM ( PLOT, "", -1, NUMLIGLOT) From STKENTA
               Endcase
               If NUMLIGLOT >= 0 LRET = 3
                  WECCVALMAJ = evalue("[M:"+PABR+"]ECCVALMAJ(NUMLIGLOT)")
                  WECCVALMIN = evalue("[M:"+PABR+"]ECCVALMIN(NUMLIGLOT)")
                  WECCSAIFLG = 3
                  LRET = 3
               Endif
            Else
               LSUITE = 1
               NBL = [M:ENTW]NBLIG
               For I=0 To NBL-1
                   If dim([M:ENTW]ITMREF)>1
                      If [M:ENTW]ITMREF(I) <> PITM
                         LSUITE = 0
                      Endif
                   Endif
                   If LSUITE
                      NUMLIGLOT = [M:ENTW]NUMLIGLOT(I)
                      If NUMLIGLOT>=0 & [M:ENTW]LOT(NUMLIGLOT) = PLOT
                         WECCVALMAJ = [M:ENTW]ECCVALMAJ(NUMLIGLOT)
                         WECCVALMIN = [M:ENTW]ECCVALMIN(NUMLIGLOT)
                         WECCSAIFLG = 3
                         LRET = 3
                         Break
                      Endif
                   Else
                      LSUITE = 1
                   Endif
               Next I
            Endif
         Endif
      Endif
   Endif
# si lot n'existe pas : recuperation ECCVAMAJ/MIN de ECCSTA
   If LRET = 0
      Gosub READECCSTA
   Endif
   Goto  AFFICH_ECC
Else
#                                                                                         # hcb 112239 deb
# si lot pas saisi RECUPERATION ECCVAMAJ/MIN de ECCSTA
# en effet le lot peut etre déterminé par compteur , par  le lot fournisseur, par le numéro de document
#   If [F:ITM]LOTCOU <> ""
#      Gosub READECCSTA
#   Else
# si lot pas saisi et pas compteur pas d affectation des versions
    Raz WECCVALMAJ
    Raz WECCVALMIN
#      WECCSAIFLG = 1
    Gosub READECCSTA
#      Goto AFFICH_ECC
#   Endif
#                                                                                         # hcb 112239 fin
Endif

# affectation et affichage des valeurs versions trouvées
$AFFICH_ECC
Default Mask "["+PABR+"]"

If PTAB = 1
   Assign LMABR+PZONMAJ With WECCVALMAJ
   Assign LMABR+PZONMIN With WECCVALMIN
   If evalue("dim([M:"+PABR+"]ECCSAIFLG)") >= 0
      Assign LMABR+"ECCSAIFLG" With WECCSAIFLG
   Endif

   If PAFF = 2
      Affzo =PZONMAJ
      Affzo =PZONMIN
      Default Mask LMSKCOU
   Endif
Else
   Assign LMABR+PZONMAJ+"  (PNOL)" With WECCVALMAJ
   Assign LMABR+PZONMIN+"  (PNOL)" With WECCVALMIN
   If evalue("dim([M:"+PABR+"]ECCSAIFLG)") >= 0
      Assign LMABR+"ECCSAIFLG(PNOL)" With WECCSAIFLG
   Endif
   If PAFF = 2
      Affzo =PZONMAJ+"(PNOL)"
      Affzo =PZONMIN+"(PNOL)"
      Default Mask LMSKCOU
   Endif
Endif

End

########################################################################
# Recherche versions majeure et mineure d'un article
########################################################################
#   Prérequis :  ITMMASTER doit etre chargé avec l'article PITM
########################################################################
#                PITM       = Article doit etre chargé
########################################################################
$READECCSTA

Raz GPE
If PTYPTIERS = 0
   WLOAECCFLG = 2
Else
   WECCSAIFLG = 1
   WLOAECCFLG = [F:ITM]LOAECCFLG
# lecture article fournisseur
   If PTYPTIERS = 1 & PBPRNUM  <>""
    # Positionnement dans la table ITMBPS
      Local File ITMBPS [ITP1]
      Read [ITP1]ITP0=PITM;PBPRNUM
      If !fstat
          WLOAECCFLG = [F:ITP1]LOAECCFLG
      Endif
   Endif
# lecture article client
   If PTYPTIERS > 1
      WLOAECCFLG = [F:ITS]LOAECCFLG
      If  PBPRNUM  <>""
   # Positionnement dans la table ITMBPC
          Local File ITMBPC [ITU1]
          Read [ITU1]ITU0=PITM;PBPRNUM
          If !fstat
             If dim([F:ITU1]LOAECCFLG) > 0
                WLOAECCFLG = [F:ITU1]LOAECCFLG
             Endif
          Endif
      Endif
   Endif
   GPOINT = "READTIERS"
   Gosub  ENTREE From EXEFNC
Endif
If PZONMAJORI <> "" & GPE = 0
   If find(PABR,"ENT","ENM","POD1")
      If evalue("dim("+LMABR+PZONMAJORI+")") > 0
         WECCVALMAJ =  evalue("[M:"+PABR+"]"+PZONMAJORI)
         If evalue("dim([M:"+PABR+"]ECCBOMFLG)") >= 0
            WECCSAIFLG =  evalue(LMABR+"ECCBOMFLG")
         Endif
      Endif
      If evalue("dim("+LMABR+PZONMINORI+")") > 0
         WECCVALMIN =  evalue("[M:"+PABR+"]"+PZONMINORI)
      Endif
   Else
      If evalue("dim("+LMABR+PZONMAJORI+")") > 0
         WECCVALMAJ =  evalue("[M:"+PABR+"]"+PZONMAJORI+"(PNOL)")
      Endif
      If evalue("dim("+LMABR+PZONMINORI+")") > 0
         WECCVALMIN =  evalue("[M:"+PABR+"]"+PZONMINORI+"(PNOL)")
      Endif
   Endif
Endif
# si les versions sont issues d une nomenclature le prechargement est à oui on sort
If WECCSAIFLG = 9
   WLOAECCFLG = 2
   Return
Endif
# si le prechargement version(s) n est pas à oui on sort
If WLOAECCFLG <> 2
   WECCSAIFLG = 2
   Return
Endif


WECCSAIFLG = 2
If WECCVALMAJ = ""
   Local Char FILTRECS2
   Local Char FILTRECS3
   Raz GPE
   GPOINT = "READECCSTA"
   Gosub  ENTREE From EXEFNC
   If FILTRECS2 = ""
      FILTRECS2 = "1=1"
   Endif
   If FILTRECS3 = ""
      FILTRECS3 = "1=1"
   Endif
   If GPE = 0
# premiere passe recherche derniere version "Active" STA = 2
      Filter [ECS] Where ITMREF = PITM & ECCSTA = 2 & evalue(FILTRECS2)
         Look [ECS]ECS1 First
         If !fstat
            Read [ECS] Curr
            WECCVALMAJ = [F:ECS]ECCVALMAJ
            WECCSAIFLG = 2
         Endif
      Filter [ECS]
# si pas trouvée deuxieme passe recherche derniere version "Arretée" STA = 3
      If WECCVALMAJ = ""
         Filter [ECS] Where ITMREF = PITM & ECCSTA = 3 & evalue(FILTRECS3)
         Look [ECS]ECS1 First
         If !fstat
            Read [ECS] Curr
            WECCVALMAJ = [F:ECS]ECCVALMAJ
            WECCSAIFLG = 2
         Endif
         Filter [ECS]
      Endif
   Endif
# si version majeure trouvée et si article gere la version mineure : recherche derniere version mineure
   If WECCVALMAJ  <> "" & [F:ITM]ECCSTO = 3
      Gosub READECCMIN
   Endif
Else
   WECCSAIFLG = 2
Endif
Return

########################################################################
# Recherche dernière version mineure d'un article dans ECCVAL
########################################################################
#   Prérequis :
########################################################################
#                PITM       = Article doit etre chargé
#                WECCVALMAJ = Version majeure doit etre chargée
########################################################################
$READECCMIN
If !clalev([EVL]) : Local File ECCVAL [EVL] : Endif

Local Char FILTREVL4
Local Char FILTREVL4
Raz GPE
GPOINT = "READECCVAL"
Gosub  ENTREE From EXEFNC
If FILTREVL4 = ""
   FILTREVL4 = "1=1"
Endif
If GPE = 0
   Filter [EVL] Where ITMREF = PITM & ECCVALMAJ = WECCVALMAJ & ECCTYP = 4 & evalue(FILTREVL4)
&  Order By Key CLE = ITMREF;ECCVALMAJ;ECCVALMIN Desc
   Look [EVL]CLE First
   If !fstat
      Read [EVL] Curr
      WECCVALMIN = [F:EVL]ECCVALMIN
   Endif
   Filter [EVL]
Endif
Return


########################################################################
# PAR_AMSKZON_LOT Recherche parametres : TYPTIERS et TIERS de la zone LOT dans AMSKZON
########################################################################
########################################################################
#                PABR       = Abréviation écran
#                LTYPTIERS  = 0 = pas de tiers 1 = fournisseur 2 = client 3 client et fournisseur = client
#                LBPRNUM     = Numéro de tiers
#
########################################################################
Subprog PAR_AMSKZON_LOT(PABR,LTYPTIERS,LBPRNUM,LZONMAJORI,LZONMINORI)
Value Char       PABR
Variable Integer LTYPTIERS
Variable Char    LBPRNUM
Variable Char    LZONMAJORI
Variable Char    LZONMINORI

LTYPTIERS = 0
Raz LBPRNUM

If !clalev([AMP]) : Local File AMSKPAR [AMP] : Endif

Read [AMP]CODPAR=1;PABR;"LOT";"TYPTIERS"
If fstat
   Raz [F:AMP]
Endif
LTYPTIERS = val([F:AMP]VALPAR)
Read [AMP]CODPAR=1;PABR;"LOT";"BPRNUM"
If fstat
   Raz [F:AMP]
Endif
LBPRNUM = [F:AMP]VALPAR
If LZONMAJORI = ""
   Read [AMP]CODPAR=1;PABR;"LOT";"ZONECCMAJO"
   If fstat
      Raz [F:AMP]
   Endif
   If [F:AMP]VALPAR <> ""
       LZONMAJORI = evalue([F:AMP]VALPAR)
   Endif
Endif
If LZONMINORI = ""
   Read [AMP]CODPAR=1;PABR;"LOT";"ZONECCMINO"
   If fstat
      Raz [F:AMP]
   Endif
   If [F:AMP]VALPAR <> ""
      LZONMINORI = evalue([F:AMP]VALPAR)
   Endif
Endif
If LZONMAJORI = ""
   LZONMAJORI = '""'
Endif
If LZONMINORI = ""
   LZONMINORI = '""'
Endif
If LBPRNUM = ""
   LBPRNUM = '""'
Endif

End
#                                                                                # hcb 71276 fin

########################################################################
# STKCTRLOT : Contrôle lot en entrée
#                 - Si n° de pièce origine, vérifie que le lot existe
#                 - Autorisation de reprise de lot existant selon règle de gestion
#                 - 1 Lot => 1 seul lot fournisseur
########################################################################
# Paramètres E : PLOT       = Lot à controler
#                PABR       = Abréviation de l'écran
#                PNOL       = Indice de la ligne
#                PITM       = Article
#                PBPSLOT    = Lot fournisseur
#                PVCRTYP    = Type de pièce
#                PVCRNUM    = Numéro de pièce
#                PVCRLIN    = Ligne de pièce
#                PVCRNUMORI = Numéro de pièce d'origine
#                PVCRTYPORI = Type de pièce d'origine
#                PVCRLINORI = Numéro de ligne d'origine
#                PVCRSEQORI = Numéro de séquence d'origine (utilisé uniquement pour la réintégration)
#                PSTOFCY    = Site
#                PZONTLO    = Nom du champ type emplacement
#
# Paramètres S : PGESLOT    = "C" si compteur,
#                             "V" si reprise n° de pièce
#                             "" sinon
#                             "B" ne peut être affecté que par bouton
#
# Prérequis      : Ces tables doivent être ouvertes   STOLOT
#                                                     TABSTORUL (et positionnée)
#                                                     ITMMASTER (et positionnée)
#                  Le champ WSTOSEQ doit exister dans le masque courant
########################################################################
Subprog STKCTRLOT(PLOT, PABR, PNOL, PITM, PBPSLOT, PVCRTYP, PVCRNUM, PVCRLIN, PVCRNUMORI, PVCRTYPORI, PVCRLINORI, PVCRSEQORI, PSTOFCY, PZONTLO, PGESLOT)
Value    Char    PLOT
Value    Char    PABR
Value    Integer PNOL
Value    Char    PITM
Value    Char    PBPSLOT
Value    Integer PVCRTYP
Value    Char    PVCRNUM
Value    Integer PVCRLIN
Value    Char    PVCRNUMORI
Value    Integer PVCRTYPORI
Value    Integer PVCRLINORI
Value    Integer PVCRSEQORI
Value    Char    PSTOFCY
Value    Char    PZONTLO
Variable Char    PGESLOT

Local Integer LRET
Local Char LBPSLOT(type(PBPSLOT)-10)

LBPSLOT = PBPSLOT

GPOINT="PAR_CTRLOT"
Gosub ENTREE From EXEFNC

LRET = func FSTKCTRLOT(PLOT, PABR, PNOL, PITM, LBPSLOT, PVCRTYP, PVCRNUM, PVCRLIN,
&                      PVCRNUMORI, PVCRTYPORI, PVCRLINORI, PVCRSEQORI, PSTOFCY, PZONTLO, PGESLOT)
End


########################################################################
# Paramètres E : PLOT       = Lot à controler
#                PABR       = Abréviation de l'écran
#                PNOL       = Indice de la ligne
#                PITM       = Article
#                PVCRTYP    = Type de pièce
#                PVCRNUM    = Numéro de pièce
#                PVCRLIN    = Ligne de pièce
#                PVCRNUMORI = Numéro de pièce d'origine
#                PVCRTYPORI = Type de pièce d'origine
#                PVCRLINORI = Numéro de ligne d'origine
#                PVCRSEQORI = Numéro de séquence d'origine (utilisé uniquement pour la réintégration)
#                PSTOFCY    = Site
#                PZONTLO    = Nom du champ type emplacement
#
# Paramètres S : PBPSLOT    = Lot fournisseur
#                PGESLOT    = "C" si compteur,
#                             "V" si reprise n° de pièce
#                             "" sinon
#                             "B" ne peut être affecté que par bouton
#                Code retour = 0 : lot inexistant
#                              1 : lot présent dans STOLOT
#                              2 : lot présent dans ENTW ou ENT ou ENM
#                              4 : Existance de mvt de la pièce d'origine avec ce lot
#                              8 : Existance de mvt de la pièce en cours avec ce lot
# Prérequis      : Ces tables doivent être ouvertes   STOLOT
#                                                     TABSTORUL (et positionnée)
#                                                     ITMMASTER (et positionnée)
#                  Le champ WSTOSEQ doit exister dans le masque courant
########################################################################
Funprog FSTKCTRLOT(PLOT, PABR, PNOL, PITM, PBPSLOT, PVCRTYP, PVCRNUM, PVCRLIN, PVCRNUMORI, PVCRTYPORI, PVCRLINORI, PVCRSEQORI, PSTOFCY, PZONTLO, PGESLOT)
Value    Char    PLOT
Value    Char    PABR
Value    Integer PNOL
Value    Char    PITM
Variable Char    PBPSLOT
Value    Integer PVCRTYP
Value    Char    PVCRNUM
Value    Integer PVCRLIN
Value    Char    PVCRNUMORI
Value    Integer PVCRTYPORI
Value    Integer PVCRLINORI
Value    Integer PVCRSEQORI
Value    Char    PSTOFCY
Value    Char    PZONTLO
Variable Char    PGESLOT

Local Integer LLIGLOT
Local Char    LMABR(10) : LMABR = "[M:"+PABR+"]"
Local Integer LFILSTJ
Local Integer LEXI : Raz LEXI
If !clalev([STL]) : Local File STOLOT [STL] : Endif

Look [STL]STL0(2)=PITM;PLOT
[G:STL]currlen = 0
LEXI += (!fstat)

#------- Si document d'origine, on vérifie uniquement qu'il existe un mouvement avec le lot ----#
# Le document origine n'est pas significatif si c'est une cde d'achat(14), un OF(10) ou un EO(36)
# L'OF n'est intéressant que si on est en réintégration
    If PVCRNUMORI<>""
        Raz LFILSTJ
        If !find(PVCRTYPORI,10,14,36)
            Filter [F:STJ] Where UPDCOD=2          & ITMREF=PITM
&                              & VCRTYP=PVCRTYPORI & VCRNUM=PVCRNUMORI
&                              & VCRLIN=PVCRLINORI & LOT=PLOT & REGFLG<>2
            LFILSTJ = 1
            #--- Issue 115182
            Look [STJ]STJ1 First
            #---
        Elsif (PVCRTYPORI=10 & PVCRTYP=12)
            Filter [F:STJ] Where UPDCOD=2             & ITMREF=PITM
&                              & VCRTYPORI=PVCRTYPORI & VCRNUMORI=PVCRNUMORI
&                              & VCRLINORI=PVCRLINORI & VCRSEQORI=PVCRSEQORI
&                              & LOT=PLOT             & REGFLG<>2
            LFILSTJ = 1
            #--- Issue 115182
            Look [STJ] First
            #---
        Endif
        If LFILSTJ
            #--- Issue 115182
            #Look [STJ]STJ2 First
            #---
            If fstat
                mkstat=2
                GERR=1
                GMESSAGE = mess(360, 199, 1)    # Lot inexistant dans la ligne du document origine
            Else
                LEXI += 4
                #--- Issue 115182
                If !find(PVCRTYPORI,10,14,36)
                   Read [STJ]STJ1 First
                Else
                   Read [STJ] First
                Endif
                #Read [STJ]STJ2 First
                #---
                PBPSLOT = [STJ]BPSLOT
                Raz PGESLOT
            Endif
            Filter [F:STJ]
            End LEXI
        Endif
    Endif
#------- Si Lot blanc => pas de contrôle --------#
If PLOT="" & PGESLOT="B"
    End LEXI
Endif

If PLOT<>""
    PGESLOT=""
    #--- Pas de sous-lot ou sous-lot avec gestion d'unicité des lots
    If ([F:ITM]LOTMGTCOD<>4 | [F:ITM]LOTMGTCOD=4 & GFEALOTLEV=2) &
&      [F:SRU]DACLOT=3 & (PLOT<>PBPSLOT | PLOT<>PVCRNUM) & mod(LEXI,2)=1
        # Ce test d'existence n'est à faire que si l'article n'est pas géré en sous-lot
        # et qu'il est interdit d'avoir les mêmes n° de lot pour l'article (ce qui ne doit pas arriver dans les retours!!)
        Filter [STJ] Where STOFCY=PSTOFCY & VCRTYP=PVCRTYP & VCRNUM=PVCRNUM
&                        & VCRLIN=PVCRLIN & ITMREF=PITM    & UPDCOD=2
&                        & LOT=PLOT       & REGFLG<>2
        Look [STJ]STJ1 First
        Filter [STJ]
        If fstat
            GERR=1
            mkstat=2
            GMESSAGE=mess(19,196,1)
            End LEXI
        Else
            LEXI += 8
        Endif
    Endif
#                                                              # hcb 71276 deb
# en Assemblage et désassemblage pour une nomenclature de production il faut controler la version
   If find(PVCRTYP,31,32)
      Gosub CTR_LOT_VERSION
      If GERR = 2
         mkstat = 2
         GMESSAGE=mess(431,184,1)   # CE lot a  une version différente  !
         End LEXI
      Endif
   Endif
#                                                              # hcb 71276 fin

Else
    #-- Si rien n'est saisi, soit on reprend le n° de pièce soit c'est un compteur soit c'est une réception à quai
    #-- Si dans la fiche article il n'y a pas de compteur lot défini, c'est le compteur général qui sera utilisé (03/10/03)
    If [F:SRU]LOTSUPINH=3
        PGESLOT="V"
        If PVCRNUM<>""
            PNEWLOT = PVCRNUM
        Endif
    Elsif [F:ITM]LOTCOU=""
        PGESLOT=""
    Else
        PGESLOT="C"
    Endif
    If PBPSLOT="" & [F:ITF]LOCMGTCOD=2 & evalue("dim("+LMABR+PZONTLO+"(PNOL))")>0 & evalue(LMABR+PZONTLO+"(PNOL)")<>""
        If [F:TLO]STOFCY<>PSTOFCY | [F:TLO]LOCTYP<>evalue(LMABR+PZONTLO+"(PNOL)")
            Read [TLO]TLO0=PSTOFCY;evalue(LMABR+PZONTLO+"(PNOL)")
            If fstat    # Ne doit jamais arriver, car controlé avant.
                mkstat = 2
                End LEXI
            Endif
        Endif
        # test si type quai
        If [F:TLO]LOCCAT = 2
          #--- Issue X3-53322
          # On efface GESLOT si pas de gestion de LPN ou pas de LPN renseigné et LPN facultatif
          If evalue("dim("+LMABR+"LPNNUM)")<0 | [F:ITF]LPNMGTCOD<>2 |
&           (evalue("dim("+LMABR+"LPNNUM)")>=0 & evalue(LMABR+"LPNNUM(PNOL)")="" & [F:SRU]DACCTR<>2)
            PGESLOT = ""
          Endif
          #PGESLOT = ""
          #---
        Endif
    Endif
Endif


#---------- Tests sur le lot fournisseur --------------------------------#
#-- On ne peut pas affecter différents lots fournisseurs à un seul lot --#
#-- Si gestion de sous-lot => le contrôle s'effectue sur le sous-lot   --#
#-- sauf si on est paramétré avec gestion d'unicité des lots           --#
If ([F:ITM]LOTMGTCOD<>4 | [F:ITM]LOTMGTCOD=4 & GFEALOTLEV=2) & PGESLOT<>"C"
    #--- Vérification d'abord dans le fichier STOLOT
    Read [STL]STL0(2)=PITM;PLOT
    [G:STL]currlen=0
    If find(PVCRTYP,13,18)    # Retours prêts ou client et avoirs
        If !fstat
            PBPSLOT = [F:STL]BPSLOT
        Else
            If dim([M]WSTOSEQ)=1    # Cas du ctrl lot dans STOENT
                Call SEARCHLOTENTW( PITM, PLOT, "", [M]WSTOSEQ, LLIGLOT ) From STKENTA
            Elsif dim([M]WSTOSEQ)>1
                Call SEARCHLOTENTW( PITM, PLOT, "", [M]WSTOSEQ(nolign-1), LLIGLOT ) From STKENTA
            Endif
            If LLIGLOT<0 | clalev([M:ENM])
                If clalev([M:ENT])
                    Call SEARCHLOTENT( PLOT, "", nolign-1, LLIGLOT ) From STKENTA
                    If LLIGLOT>=0
                        LEXI += 2
                        PBPSLOT = [M:ENT]BPSLOT(LLIGLOT)
                    Endif
                Elsif clalev([M:ENM])
                    Call SEARCHLOTENM( PLOT, "", nolign-1, LLIGLOT ) From STKENTA
                    If LLIGLOT>=0
                        LEXI += 2
                        PBPSLOT = [M:ENM]BPSLOT(LLIGLOT)
                    Endif
                Endif
            Else
                LEXI += 2
                PBPSLOT = [M:ENTW]BPSLOT(LLIGLOT)
            Endif
        Endif
    Else

        If !fstat
           #--- Issue X3-78672
           #If  !([F:STL]VCRTYP = PVCRTYP & [F:STL]VCRNUM = PVCRNUM & [F:STL]VCRLIN  = PVCRLIN)  # hcb 40777
              If PBPSLOT = ""
                 PBPSLOT = [F:STL]BPSLOT
              Elsif PBPSLOT <> [F:STL]BPSLOT
                    mkstat = 2
                    GMESSAGE=mess(19,184,1)-[F:STL]BPSLOT
                    End LEXI
              Endif
           #--- Issue X3-78672
           #Endif                                                                                # hcb 40777
        Endif
        #--- Puis dans STOENTW
        If dim([M]WSTOSEQ)=1    # Cas du ctrl lot dans STOENT
            Call SEARCHLOTENTW( PITM, PLOT, "", [M]WSTOSEQ, LLIGLOT ) From STKENTA
        Elsif dim([M]WSTOSEQ)>1
            Call SEARCHLOTENTW( PITM, PLOT, "", [M]WSTOSEQ(nolign-1), LLIGLOT ) From STKENTA
        Endif
        If LLIGLOT<0 | clalev([M:ENM])
            If clalev([M:ENT])
                Call SEARCHLOTENT( PLOT, "", nolign-1, LLIGLOT ) From STKENTA
                If LLIGLOT>=0 & PBPSLOT <> [M:ENT]BPSLOT(LLIGLOT)
                    mkstat = 2
                    LEXI += 2
                    GMESSAGE=mess(19,184,1)-[M:ENT]BPSLOT(LLIGLOT)
                    End LEXI
                Endif
            Elsif clalev([M:ENM])
                Call SEARCHLOTENM( PLOT, "", nolign-1, LLIGLOT ) From STKENTA
                If LLIGLOT>=0 & PBPSLOT <> [M:ENM]BPSLOT(LLIGLOT)
                    mkstat = 2
                    LEXI += 2
                    GMESSAGE=mess(19,184,1)-[M:ENM]BPSLOT(LLIGLOT)
                    End LEXI
                Endif
            Endif
        Else
            If PBPSLOT <> [M:ENTW]BPSLOT(LLIGLOT)
                mkstat = 2
                LEXI += 2
                GMESSAGE=mess(19,184,1)-[M:ENTW]BPSLOT(LLIGLOT)
                End LEXI
            Endif
        Endif
    Endif
Endif

If !mkstat
    If find(PVCRTYP,13,18) & [F:ITM]LOTMGTCOD<>4
        If mod(LEXI,2)<>1
            GERR=2
            GMESSAGE=mess(123,199,1)
        Endif
    Endif
Endif

End LEXI

#                                                              # hcb 71276 deb
$CTR_LOT_VERSION
If evalue("dim([M:"+PABR+"]ECCVALMAJ)")>0
   Local Char PMASK
   Local Char PMASK1
   PMASK = PABR
   If find(PABR,"ENT","ENM")
      If evalue(LMABR+"ECCBOMFLG") <> 9
         Return
      Elsif PVCRTYP = 31
            If [BBY0]BOMALTTYP(0) <> 2
               Return
            Endif
      Elsif [DBY0]BOMALTTYP(0) <> 2
            Return
      Endif
   Endif
   PMASK1 = "[M:"+PMASK+"]"
   Filter [STL] Where ITMREF = PITM   &  LOT = PLOT
   For [STL]
# si lot existe les versions doivent etre identiques
       If find(PABR,"ENT","ENM")
           If evalue(PMASK1+"ECCVALMAJAFF(PNOL)") <> "" & evalue(PMASK1+"ECCVALMAJAFF(PNOL)") <> [F:STL]ECCVALMAJ
             GERR = 2
             Break
          Endif
          If  evalue(PMASK1+"ECCVALMINAFF(PNOL)") <> "" & evalue(PMASK1+"ECCVALMINAFF(PNOL)") <> [F:STL]ECCVALMIN
              GERR = 2
              Break
          Endif
       Else
          If evalue(PMASK1+"ECCVALMAJ(PNOL)") <> "" & evalue(PMASK1+"ECCVALMAJ(PNOL)") <> [F:STL]ECCVALMAJ
             GERR = 2
             Break
          Endif
          If  evalue(PMASK1+"ECCVALMIN(PNOL)") <> "" & evalue(PMASK1+"ECCVALMIN(PNOL)") <> [F:STL]ECCVALMIN
              GERR = 2
              Break
          Endif
       Endif
       Break
   Next
   Filter [STL]
Endif
Return
#                                                              # hcb 71276 fin
########################################################################
# STKIBLOT: Initialisation des boutons sur le champ NBLIG ou LOT
#                 - Si n° de pièce origine, vérifie que le lot existe
#                 - Autorisation de reprise de lot existant selon règle de gestion
#                 - 1 Lot => 1 seul lot fournisseur
########################################################################
# Paramètres E : PLOT       = Lot
#                PNBSLO     = Nombre de sous-lots
#                PBTNCPT    = Numéro du bouton "Compteur"  (pas de btn =0)
#                PBTNBLC    = Numéro du bouton "Lot blanc" (pas de btn =0)
#                PBTNINF    = Numéro du bouton "Info lot"  (pas de btn =0)
#
# Prérequis      : ITMMASTER [ITM] doit être positionnée
#                  La sélection est doit être sur le bouton sélection
########################################################################
Subprog STKIBLOT(PLOT,PNBSLO,PBTNCPT,PBTNBLC,PBTNINF)
Value    Char    PLOT
Value    Integer PNBSLO
Value    Integer PBTNCPT
Value    Integer PBTNBLC
Value    Integer PBTNINF

If clalev([SRU])
    If [F:SRU]DACLOT=3
        Raz GBOUTS     : # Efface le bouton "Sélection"
    Endif
Endif

If PBTNCPT>0
    # Compteur lot (intéressant en particulier pour les réceptions à quai)
    If [F:ITM]LOTCOU = ""
        Assign "GBOUT"+num$(PBTNCPT) With ""
    Else
#        Assign "GBOUT"+num$(PBTNCPT) With mess(439,198,1)
    Endif
Endif

If PBTNBLC
    # Lot blanc
    If   [F:ITM]LOTMGTCOD = 2
#        Assign "GBOUT"+num$(PBTNBLC) With mess(440,198,1)
    Else
        Assign "GBOUT"+num$(PBTNBLC) With ""
    Endif
Endif

If PBTNINF
    # Info lot
    If [F:ITM]LOTMGTCOD = 1 | PLOT <> "" & PNBSLO<=1
        Assign "GBOUT"+num$(PBTNINF) With ""
    Else
#        Assign "GBOUT"+num$(PBTNINF) With mess(441,198,1)
    Endif
Endif

End

#########################################################################
# STKCTRNBSLO : Controle la validite du nombre de sous lots
#               avec la décimalisation de l'unité
#
# Parametres E: PNBSLO   = Nombre de sous lots
#               PPCU     = Unité de conditionnement de la quantité
#                          qui doit être divisée en sous lots
#               PQTYPCU  = Quantité en UC
#
# Prérequis : Les champs [M:ENTW]WZONxxx doivent être renseignés
#
# Remarque: Ce contrôle n'est pas utile pour les unités
#           qui ne sont pas des UC
#########################################################################
Subprog STKCTRNBSLO( PNBSLO, PPCU, PQTYPCU )
Value Decimal PNBSLO
Value Char    PPCU
Value Decimal PQTYPCU

Local Char PUNT(5)(2)
Local Char LLBEFMT(10)
Local Char LDECFMT(10),LDEC(3)
Local Integer I,J

# hcb 34084
If PNBSLO = 1
   End
Endif

If PNBSLO< 1
    GMESSAGE= mess(2,184,1)
    mkstat=2
Else
    Local Char    LUSCAV(2)
    Local Integer LMODIF
    Local Decimal LPCUSTUCOE
    # Vérifie que l'unité passée en paramètre correspond à une unité de stock ou de conditionnement
    # car elles seules peuvent déclencher une erreur.
    # En effet, les autres unités ne sont pas divisées en sous lots.
    Call CTLUOM ([M]ITMREF(nolign-1),3,"", PPCU, LPCUSTUCOE, LUSCAV, LLBEFMT, LMODIF) From STKACT
    If LUSCAV="S" | LUSCAV="C"
        PUNT(0) = PPCU
    Else
        PUNT(0) = ""
    Endif
    PUNT(1) = [M]STU(nolign-1)

    If PNBSLO>PQTYPCU | PNBSLO>evalue("[M]"+[M:ENTW]WZONQUS+"(nolign-1)")
        For I=0 To 1
            If PUNT(I)<>""
                # Récupère le format de l'unité...
                LDECFMT = GUNTFMT1(max(find(PUNT(I),GUNITE(1..GNBUNT)),1))
                J = instr(1,LDECFMT , ".")
                If J>0 & J<len(LDECFMT )
                    #... et en déduit le nombre de décimales
                    LFMT = right$(LDECFMT ,J+1)
                    While (ascii(LDECFMT )>=ascii("0") & ascii(LDECFMT )<=ascii("9"))
                        LDEC+=left$(LDECFMT ,1)
                        LDECFMT =right$(LDECFMT ,2)
                    Wend
                Else
                    mkstat=2
                    Break
                Endif
                # Comparaison du nombre de décimales données par le format de l'unité avec
                # le nombre de décimales nécessaires pour le nombre de sous lots
                If fix(log(PNBSLO))>val(LDEC)
                    mkstat=2
                    Break
                Endif
            Endif
        Next

        If mkstat=2
            GMESSAGE= mess(1,184,1)
        Endif
    Endif
Endif
End

########################################################################
# STKCTRSLO : Contrôle  sous lot + calcul sous lot fin
########################################################################
# Paramètres E : PSLO       = Sous lot à controler
#                PNBSLO     = Nombre de sous lots
#                PLOT       = Lot
#                PITM       = Article
#                PBPSLOT    = Lot fournisseur
#                PGESLOT    = Indicateur type de lot
#                PVCRNUMORI = Numéro de pièce d'origine
#                PVCRTYPORI = Type de pièce d'origine
#                PVCRLINORI = Numéro de ligne d'origine
#                PVCRSEQORI = Numéro de séquence d'origine (utilisé uniquement pour la réintégration)
#                PSTOFCY    = Site
#
# Paramètres S : PSLOF      = N° de sous lot fin
#
# Prérequis    : Ces tables doivent être ouvertes   STOLOT
#                                                   TABSTORUL (et positionné)
#                                                   ITMMASTER (et positionné)
#
########################################################################
Subprog STKCTRSLO(PSLO, PNBSLO, PLOT, PITM, PBPSLOT, PGESLOT, PVCRNUMORI, PVCRTYPORI, PVCRLINORI, PVCRSEQORI, PSTOFCY, PSLOF)
Value    Char    PSLO
Value    Integer PNBSLO
Value    Char    PLOT
Value    Char    PITM
Variable Char    PBPSLOT
Value    Char    PGESLOT
Value    Char    PVCRNUMORI
Value    Integer PVCRTYPORI
Value    Integer PVCRLINORI
Value    Integer PVCRSEQORI
Value    Char    PSTOFCY
Variable Char    PSLOF

Local Char    WSLOD(GLONSLO)
Local Char    WSLOF(GLONSLO)
Local Integer WRET
Local Integer I
Local Integer NCAR
Local Integer LLIGLOT
Local Integer LBPSLOTOK : Raz LBPSLOTOK
PSLOF = ""
Local Integer  LSSL

If !clalev([STL]) : Local File STOLOT [STL] : Endif

    If PNBSLO<=0
        GMESSAGE = mess(4,184,1)    # Nombre de sous lots incorrect
        GERR = 1
        mkstat=2
        End
    Endif

    If [F:ITM]LOTMGTCOD = 4
       If PSLO <> ""
            Local Integer  I
            I     = PNBSLO
            WSLOF = PSLO
            If PVCRNUMORI=""
                While I > 0
                    If PGESLOT<>"C"
                        If !mkstat
                            If clalev([SRH1]) | clalev([SRL1]) | clalev([SIH4])
                                Look [STL]STL0(2)=PITM;PLOT
                                [G:STL]currlen = 0
                                If fstat
                                    GERR=2
                                    GMESSAGE=mess(123,199,1)
                                Endif
                            Endif
                        Endif
                        # S'il est interdit d'utiliser un couple lot/sous lot existant...
                        # ... on regarde s'il existe...
                        Read [STL]STL0=PITM;PLOT; WSLOF
                        If !fstat
                            If [F:SRU]DACLOT = 3
                                Raz LSSL
                                If  clalev([M:SSL1])
                                    If clalev([M:ENT])
                                       If [F:STL]VCRNUM = [M:ENT]VCRNUM &
&                                         [F:STL]VCRTYP = [M:ENT]VCRTYP &
&                                         [F:STL]VCRLIN = [M:ENT]VCRLIN
                                          LSSL = 1
                                       Endif
                                    Elsif clalev([M:ENM])
                                       If [F:STL]VCRNUM = [M:ENM]VCRNUM &
&                                         [F:STL]VCRTYP = [M:ENM]VCRTYP &
&                                         [F:STL]VCRLIN = [M:ENM]VCRLIN
                                          LSSL = 1
                                       Endif
                                    Else
                                       If [F:STL]VCRNUM = [M:SSL1]VCRNUM(nolign-1) &
&                                         [F:STL]VCRTYP = [M:SSL1]VCRTYP(nolign-1) &
&                                         [F:STL]VCRLIN = [M:SSL1]VCRLIN(nolign-1)
                                          LSSL = 1
                                       Endif
                                    Endif
                                 Endif
                               If LSSL <> 1
                            # ... si oui, on génère une erreur
                                  mkstat= 2
                                  GMESSAGE=mess(19,196,1)    # Sous lot existant
                                  GERR = 1
                                  End
                               Endif
                            Endif
                            If clalev([SRH1]) | clalev([SRL1]) | clalev([SIH4])
                                PBPSLOT = [F:STL]BPSLOT
                                If !LBPSLOTOK
                                    LBPSLOTOK = 1
                                Elsif PBPSLOT <> [F:STL]BPSLOT
                                    mkstat = 2
                                    GMESSAGE=mess(19,184,1)-[F:STL]BPSLOT
                                Endif
                            Elsif PBPSLOT <> [F:STL]BPSLOT
                                mkstat = 2
                                GMESSAGE=mess(19,184,1)-[F:STL]BPSLOT
                            Endif
                        Endif
                        If !mkstat
                            If ( clalev([SRH1]) | clalev([SRL1]) | clalev([SIH4]) ) & !LBPSLOTOK
                                # On regarde si le lot a déjà été utilisé pour un autre lot fournisseur
                                If dim([M]WSTOSEQ)=1
                                    Call SEARCHLOTENTW( PITM, PLOT, WSLOF, [M]WSTOSEQ, LLIGLOT ) From STKENTA
                                Elsif dim([M]WSTOSEQ)>1
                                    Call SEARCHLOTENTW( PITM, PLOT, WSLOF, [M]WSTOSEQ(nolign-1), LLIGLOT ) From STKENTA
                                Endif
                                If LLIGLOT<0 | clalev([M:ENM])
                                    If clalev([M:ENT])
                                        Call SEARCHLOTENT( PLOT, WSLOF, nolign-1, LLIGLOT ) From STKENTA
                                        If LLIGLOT>=0
                                            PBPSLOT = [M:ENT]BPSLOT(LLIGLOT)
                                        Endif
                                    Elsif clalev([M:ENM])
                                        Call SEARCHLOTENM( PLOT, WSLOF, nolign-1, LLIGLOT ) From STKENTA
                                        If LLIGLOT>=0
                                            PBPSLOT = [M:ENT]BPSLOT(LLIGLOT)
                                        Endif
                                    Endif
                                Else
                                    PBPSLOT = [M:ENTW]BPSLOT(LLIGLOT)
                                Endif
                            Else
                                # On regarde si le lot a déjà été utilisé pour un autre lot fournisseur
                                If dim([M]WSTOSEQ)=1
                                    Call SEARCHLOTENTW( PITM, PLOT, WSLOF, [M]WSTOSEQ, LLIGLOT ) From STKENTA
                                Elsif dim([M]WSTOSEQ)>1
                                    Call SEARCHLOTENTW( PITM, PLOT, WSLOF, [M]WSTOSEQ(nolign-1), LLIGLOT ) From STKENTA
                                Endif
                                If LLIGLOT<0 | clalev([M:ENM])
                                    If clalev([M:ENT])
                                        Call SEARCHLOTENT( PLOT, WSLOF, nolign-1, LLIGLOT ) From STKENTA
                                        If LLIGLOT>=0 & PBPSLOT <> [M:ENT]BPSLOT(LLIGLOT)
                                            mkstat = 2
                                            GMESSAGE=mess(19,184,1)-[M:ENT]BPSLOT(LLIGLOT)
                                        Endif
                                    Elsif clalev([M:ENM])
                                        Call SEARCHLOTENM( PLOT, WSLOF, nolign-1, LLIGLOT ) From STKENTA
                                        If LLIGLOT>=0 & PBPSLOT <> [M:ENM]BPSLOT(LLIGLOT)
                                            mkstat = 2
                                            GMESSAGE=mess(19,184,1)-[M:ENM]BPSLOT(LLIGLOT)
                                        Endif
                                    Endif
                                Else
                                    If PBPSLOT <> [M:ENTW]BPSLOT(LLIGLOT)
                                        mkstat = 2
                                        GMESSAGE=mess(19,184,1)-[M:ENTW]BPSLOT(LLIGLOT)
                                    Endif
                                Endif
                            Endif
                        Endif
                    Endif # PGESLOT<>"C"
                    WSLOD = WSLOF
                    I -= 1
                    If I>0
                        # Incrémentation du n° de sous-lot
                        Call PLUS_UN(WSLOD,WSLOF,WRET) From STKLIB
                        If WRET <> 0
                            mkstat = 2
                            GMESSAGE = WSLOD-":"-mess(724,196,1)  # Saisie des sous-lots incorrecte
                            GERR = 1
                            End
                        Endif
                    Endif
                Wend
                PSLOF = WSLOF
            Else
                Local Char TABSLO(GLONSLO)(0..PNBSLO-1)
                If PNBSLO = 1
                     WSLOD = WSLOF
                     TABSLO(0) = WSLOF
                Else
                    For I=0 To PNBSLO-1
                        TABSLO(I) = WSLOF
                        WSLOD = WSLOF
                        Call PLUS_UN(WSLOD,WSLOF,WRET) From STKLIB
                        If WRET <> 0
                            mkstat = 2
                            GMESSAGE = WSLOD-":"-mess(724,196,1)  # Saisie des sous-lots incorrecte
                            GERR = 1
                            End
                        Endif
                    Next
                Endif
                #WSLOF contient dernier sous-lot + 1 !!!
                PSLOF = WSLOD
                # L'utilisation de NCAR est justifié par l'exemple suivant:
                # SLODEB="SL01" et SLOFIN="SL05"
                # Il ne faut pas récupérer les SLO="SL01A" par exemple, or ceux-ci
                # seraient pris en n'utilisant que les bornes.
                NCAR = len(WSLOF)
                If !find(PVCRTYPORI,10,14,36) | (PVCRTYPORI=10 & PVCRSEQORI>0)
                    For I=0 To PNBSLO-1
                        If !find(PVCRTYPORI,10,14,36)
                            Filter [F:STJ] Where UPDCOD=2 & ITMREF=PITM
&                                              & VCRTYP=PVCRTYPORI & VCRNUM=PVCRNUMORI
&                                              & VCRLIN=PVCRLINORI & LOT=PLOT
&                                              & REGFLG<>2 & SLO=TABSLO(I)
                        Elsif (PVCRTYPORI=10 & PVCRSEQORI>0)
                            Filter [F:STJ] Where UPDCOD=2 & ITMREF=PITM
&                                              & VCRTYPORI=PVCRTYPORI & VCRNUMORI=PVCRNUMORI
&                                              & VCRLINORI=PVCRLINORI & VCRSEQORI=PVCRSEQORI
&                                              & LOT=PLOT & REGFLG<>2 & SLO=TABSLO(I)
                        Endif
                    Look [F:STJ]STJ2 First
                    Filter [F:STJ]
                    If fstat
                        PSLOF = ""
                        mkstat = 2
                        GMESSAGE = mess(360, 199, 1)    # Lot inexistant dans la ligne du document origine
                        GERR = 1
                        Break
                    Endif
                    Next
                Endif
            Endif
       Endif
    Endif
End

#                                                                           # hcb 71276 deb
########################################################################
# STKCTRECC : Contrôle versions
########################################################################
# Paramètres E : PITM       = Article
#                PMAJ       = version majeure
#                PMIN       = version mineure
#                PLOT       = lot
#                PORI       = origine du controle :
#                 1 = rubrique ECCVALMAJ : Zone obligatoire
#                 2 = rubrique ECCVALMIN : Zone obligatoire
#                 3 = rubrique ECCVALMAJ : Zone non obligatoire
#                 4 = rubrique ECCVALMIN : Zone non obligatoire
#                 5 = rubrique ECCVALMAJ : Zone obligatoire sans controle lot
#                 6 = rubrique ECCVALMIN : Zone obligatoire sans controle lot
#                 7 = rubrique ECCVALMAJ : doit exister si renseignée sans controle lot
#                 8 = rubrique ECCVALMIN : doit exister si renseignée sans controle lot

#
# Prérequis      : Ces tables doivent être ouvertes et positionnées:
#                     ITMMASTER
########################################################################
Subprog STKCTRECC(PITM,PMAJ,PMIN,PLOT,PORI)
Value Char    PITM
Value Char    PMAJ
Value Char    PMIN
Value Char    PLOT
Value Integer PORI
Local Integer WCTRLOT

If GUSER = "HCB"
# Dbgaff
Endif

WCTRLOT = 2
If find(PORI,5,6,7,8)
   Raz WCTRLOT
Endif

If GIMPORT
   Global Integer GIMPORT_ERR
   Raz GIMPORT_ERR
Endif


If GUSER = "HCB"
#   Dbgaff
Endif

If PORI = 3 & PMAJ = "" : End : Endif
If PORI = 4 & PMIN = "" : End : Endif

If [F:ITM]ECCSTO = 2 & PMIN <> ""
   mkstat = 2
   GMESSAGE = mess(420,184,1) #  # Version majeure ou mineure incorrecte !
   GIMPORT_ERR = 56
   End
Endif

# si le lot renseigné controle de la cohérence des versions
If PLOT <> "" & WCTRLOT = 2
   If !clalev([F:STL1]) : Local File STOLOT [STL1] : Endif
   Filter [F:STL1] Where ITMREF = PITM & LOT = PLOT
&         Order By Key STL0
          Read [STL1] First
   Filter [F:STL1]
   If !fstat
      If PMAJ <> [F:STL1]ECCVALMAJ
         mkstat = 2
         GMESSAGE = mess(395,184,1) # La version saisie est differentre de celle du lot
         GIMPORT_ERR = 51
         End
      Endif
      If PMIN <> "" & PMIN <> [F:STL1]ECCVALMIN
         mkstat = 2
         GMESSAGE = mess(395,184,1) # La version saisie est differentre de celle du lot
         GIMPORT_ERR = 52
         End
      Endif
      End
   Endif
Endif
# controle existence version majeure
If PMAJ = "" & PORI = 7
   End
Endif

If !clalev([F:ECS]) : Local File ECCSTA [ECS] : Endif
Read [ECS]ECS0=PITM;PMAJ
If fstat
   mkstat = 2
   GMESSAGE = mess(406,184,1) # Version inexistante  !
   GIMPORT_ERR = 50
   End
Endif

# si version active
If [F:ECS]ECCSTA = 4
    mkstat = 2
    GMESSAGE = mess(397,184,1) # la version n est pas active  !
    GIMPORT_ERR = 57
    End
Endif
# si l article ne gere pas la version mineure : end
If [F:ITM]ECCSTO < 3
   End
Endif
# si l origine du controle est la rubrique ECCVALMAJ : end
If find(PORI,1,3,5,7)
   End
Endif

# controle existence version mineure
If PMIN = "" & PORI = 8
   End
Endif
If !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif
Read [EVL]EVL1=PITM;PMAJ;PMIN;4
If fstat
   mkstat = 2
   GMESSAGE = mess(434,184,1) # Version mineure inexistante !
   GIMPORT_ERR = 55
Endif

End

########################################################################
# STKASMIN : avant saisie version mineures
########################################################################
# Paramètres E : PMAJ       = version majeure
########################################################################
Subprog STKASMIN(PMAJ)
Value Char    PMAJ
If PMAJ = ""
   mkstat = 2
Endif
End

