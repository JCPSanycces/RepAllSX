###############################################################################
# STKINISTA : Renvoie le statut par defaut
###############################################################################
# Paramètres E+S : LSTA = Statut à controler.
#                         Si un contrôle qualité est obligatoire, et LSTA <> Q*,
#                         LSTA = statut par défaut s'il est égal à Q*
#                              = le premier statut Q* correspondant à
#                                un sous statut autorisé dans la règle de gestion
#                              = Q sinon
#
#            E   : LBPS = Numéro de fournisseur (peut être vide)
#                  LQUA = 1 : pas de contrôle qualité
#                         2 : contrôle qualité obligatoire
#                         3 : contrôle qualité modifiable
#                         4 : contrôle périodique
# à partir de la V6 LQUA est determine en amont pour pouvoir tenir compte du
#                         contrôle périodique
# Prérequis : Les tables [ITM] et [SRU] doivent être positionnées
#
###############################################################################
Subprog STKINISTA(LSTA,LBPS,LQUA)
Variable Char     LSTA
Value    Char     LBPS
Value    Integer  LQUA
If LQUA = 0
    If LBPS<>""
       If !clalev([F:ITP]) : Local File ITMBPS [ITP] : Endif
       Read [ITP]ITP0=[F:ITM]ITMREF;LBPS
       If !fstat
          If LQUA=0 | [F:ITP]QUAFLG=2
             LQUA=[F:ITP]QUAFLG
          Endif
       Elsif LQUA=0 | [F:ITF]QUAFLG=2
          LQUA=[F:ITF]QUAFLG
       Endif
    Elsif LQUA=0 | [F:ITF]QUAFLG=2
       LQUA=[F:ITF]QUAFLG
    Endif
#   LQUA = 4 ne veux rien dire ici ....
    If LQUA = 4                                               # hcb V6CQ
       LQUA = 3                                               # hcb V6CQ
    Endif                                                     # hcb V6CQ
Endif
    # Quand il y a un controle qualité...
If LQUA = 2 | LQUA = 3
   # ... on définit le statut en Q*
   Call STKDEFSTAQ(LSTA, LBPS)
   If LSTA=""
   # Ctrl qualité modifiable et statut Q interdit --> statut par défaut
      If LQUA=3
         LSTA = [F:SRU]DEFSTA
         LQUA = 1
      # Sinon on force le statut Q
      Else
         LSTA = "Q"
      Endif
   Endif
   Raz GMESSAGE
   Raz GERR
Else
# sinon on prend uniquement le statut par défaut
   LSTA = [F:SRU]DEFSTA
Endif
End

###############################################################################
# STKDEFSTAQ : Renvoie un statut par defaut en Q*
###############################################################################
# Paramètres E+S : LSTA = Statut à controler.
#                         si LSTA <> Q* alors GMESSAGE="Statut Q obligatoire" et
#                         LSTA = statut par défaut s'il est égal à Q*
#                              = le premier statut Q* correspondant à
#                                un sous statut autorisé dans la règle de gestion
#                              = Q sinon
#
#            E   : LBPS = Numéro de fournisseur (peut être vide)
#
# Prérequis : Les tables [ITM] et [SRU] doivent être positionnées
#
###############################################################################
Subprog STKDEFSTAQ(LSTA,LBPS)
Variable Char     LSTA
Value    Char     LBPS

    Local Integer  I, J
    Local Char     LLIS    # LLIS = Liste des valeurs / pattern autorisées
    LLIS = [F:SRU]AUZSST

    # ... on vérifie que le statut correspond à Q*...
    If !pat(LSTA,"Q*")
        GMESSAGE = mess(830,196,1) # Statut Q obligatoire
        # ... si ce n'est pas le cas on le modifie avec le statut par défaut...
        If pat([F:SRU]DEFSTA,"Q*")
            LSTA = [F:SRU]DEFSTA
        # ... si le statut par defaut est différent de Q*,
        # on cherche le premier correspondant à la liste des statuts autorisés...
        Else
            I=1                 # hcb tst
            J=0
            Repeat
                J = instr(J+1,LLIS,",")
                If mid$(LLIS,I,1)="Q"
                    LSTA = seg$(LLIS,I,J+(!J)*len(LLIS)-(!!J))
                    Break
                Endif
                I = J+1
            Until J=0
            If left$(LSTA,1)="Q"
                # Recherche le premier statut correspondant au premier statut Q*
                # qui a été trouvé dans la liste des sous-statuts autorisés
                If clalev([F:TST]) = 0 : Local File TABSTASTO [TST] : Endif
                If LSTA <> [F:TST]STASTO
                    Read [TST]TST0=LSTA
                    If fstat
                        For [TST] Where STASTO>="Q" and STASTO<"R"
                            If pat([F:TST]STASTO,LSTA)
                                LSTA = [F:TST]STASTO
                                Break
                            Endif
                        Next
                    Endif
                Endif
            Else
                # ... si cela ne va toujours pas, pas de statut
                LSTA = ""
            Endif
        Endif
    Endif
End

###############################################################################
# STKAUZSTA: Restriction des statuts autorisés en fonction de GQUAFLG
###############################################################################
# Paramètres E+S :
#   PLISAUZSTA = liste des sous-statuts autorisés
#                Modifiée en fonction de QUAFLG
# Paramètres E
#   QUAFLG     = Option contrôle qualité
#                0                              --> Ne change rien
#                1 Pas de contrôle qualité      --> Ne change rien
#                2 Contrôle qualité obligatoire --> Enlève les sous statuts A et R
#                3 Contrôle qualité modifiable  --> Ne change rien
#                4 Blocage statut (Ds C.qualité)--> Enlève les sous statuts A et Q
###############################################################################
Subprog STKAUZSTA(PLISAUZSTA,QUAFLG)
Variable Char    PLISAUZSTA
Value    Integer QUAFLG
If QUAFLG=2 & PLISAUZSTA<>""
  Local Char WLIST(30)
  Raz WLIST : I=1 : J=1
  While J<>0
    J=instr(I,PLISAUZSTA,",")
    K=J-I+1
    If J<>0
      If instr(1,mid$(PLISAUZSTA,I,K),"Q")  WLIST+=mid$(PLISAUZSTA,I,K) : Endif
      I=J+1
    Else
      If instr(1,right$(PLISAUZSTA,I),"Q")  WLIST+=right$(PLISAUZSTA,I) : Endif
    Endif
  Wend
  If WLIST<>""
    If right$(WLIST,len(WLIST))=","   WLIST=left$(WLIST,len(WLIST)-1)   : Endif
  Else
    WLIST="Q*"
  Endif
  PLISAUZSTA=WLIST
Endif
If QUAFLG=4 & PLISAUZSTA<>""
  Local Char WLIST(30)
  Raz WLIST : I=1 : J=1
  While J<>0
    J=instr(I,PLISAUZSTA,",")
    K=J-I+1
    If J<>0
      If instr(1,mid$(PLISAUZSTA,I,K),"R")  WLIST+=mid$(PLISAUZSTA,I,K) : Endif
      I=J+1
    Else
      If instr(1,right$(PLISAUZSTA,I),"R")  WLIST+=right$(PLISAUZSTA,I) : Endif
    Endif
  Wend
  If WLIST<>""
    If right$(WLIST,len(WLIST))=","   WLIST=left$(WLIST,len(WLIST)-1)   : Endif
  Else
    WLIST="R*"
  Endif
  PLISAUZSTA=WLIST
Endif
End

