#<AdxTL>@(#)0.0.0.0 $Revision$Classe Initiateurs internes
# Superviseur
## CRUD-CLASSE ## CCMCRORIGI
# 2018-10-19 07:50:16 364

Gosub TEST From WMCR_CCMCRORIGI : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,CRID,ORIGILN)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# CCMCRORIGI : CCMCRORIGI
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet CCMCRORIGI._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = CCMCRORIGI.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(CCMCRORIGI.ACTX.AFOLDER,nomap,"")>0
 Local File CCMCRORIGI [CCMCROI]
 Local File CCMCRORIGI [AAA_]
Else
 Local File =CCMCRORIGI.ACTX.AFOLDER+".CCMCRORIGI" [CCMCROI]
 Local File =CCMCRORIGI.ACTX.AFOLDER+".CCMCRORIGI" [AAA_]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [CCMCROI] With
& [AAA_]CCMCROI0 = CRID+ORIGILN
& As [LNK_]
Return

############################################################################################
### CCMCRORIGI(WCCMCROI)
############################################################################################
Funprog  _MAJSQL_CCMCRORIGI(WCCMCROI)
Variable Instance WCCMCROI Using C_CCMCRORIGI
Local Integer ASTATUS,A_I,A_J
Default File [F:CCMCROI]
If WCCMCROI.ASTALIN=[V]CST_ANEW
 Call INICRE(WCCMCROI) From ASYRSUB
 SetInstance [F:CCMCROI] With WCCMCROI
 Write [F:CCMCROI]
 If fstat
  Call FSTA("CCMCROI",WCCMCROI,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WCCMCROI.updTick = [F:CCMCROI]updTick
Elsif WCCMCROI.ASTALIN=[V]CST_ALL or WCCMCROI.ASTALIN=[V]CST_AUPD
 Call INIUPD(WCCMCROI) From ASYRSUB
 SetInstance [F:CCMCROI] With WCCMCROI
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WCCMCROI,"CCMCRORIGI")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:CCMCROI]CCMCROI0 = [F:CCMCROI]CRID;[F:CCMCROI]ORIGILN
 If fstat
  Call FSTA("CCMCROI",WCCMCROI,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WCCMCROI.updTick = [F:CCMCROI]updTick
Elsif WCCMCROI.ASTALIN=[V]CST_ADEL
 SetInstance [F:CCMCROI] With WCCMCROI
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WCCMCROI,"CCMCRORIGI")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:CCMCROI]CCMCROI0 = [F:CCMCROI]CRID;[F:CCMCROI]ORIGILN
 If fstat
  Call FSTA("CCMCROI",WCCMCROI,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



