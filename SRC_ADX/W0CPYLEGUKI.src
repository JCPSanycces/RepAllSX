#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGUKI 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone TAXOFCNAM
mkstat = 0
zoncou = "TAXOFCNAM"
indice = 0
If varmode([M]TAXOFCNAM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TAXOFCNAM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TAXDTT
mkstat = 0
zoncou = "TAXDTT"
indice = 0
WCHAR = [M]TAXDTT
If varmode([M]TAXDTT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TAXDTT" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]TAXDTT,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TAXDTT" : GZNUM = 1001654 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]TAXDTT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_TAXDTT([M]TAXDTT) From TRTCPYLEGUKI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TAXDTT" : GZNUM = 1001654 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PAYREFNUM
mkstat = 0
zoncou = "PAYREFNUM"
indice = 0
If varmode([M]PAYREFNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PAYREFNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]PAYREFNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PAYREFNUM" : GZNUM = 1001498 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone ECON
mkstat = 0
zoncou = "ECON"
indice = 0
If varmode([M]ECON,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ECON" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone EMPREF
mkstat = 0
zoncou = "EMPREF"
indice = 0
If varmode([M]EMPREF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EMPREF" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone CLMEMPALL
mkstat = 0
zoncou = "CLMEMPALL"
indice = 0
IMPENT = [M]CLMEMPALL
If varinit([M]CLMEMPALL,indice)=0
 IMPENT = 1
Endif
If varmode([M]CLMEMPALL,indice)=0
 [M]CLMEMPALL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CLMEMPALL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CLMEMPALL(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_CLMEMPALL(IMPENT) From TRTCPYLEGUKI
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CLMEMPALL" : GZNUM = 1001684 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]CLMEMPALL = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone ACCOFFNAM
mkstat = 0
zoncou = "ACCOFFNAM"
indice = 0
If varmode([M]ACCOFFNAM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACCOFFNAM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone AOR3
mkstat = 0
zoncou = "AOR3"
indice = 0
If varmode([M]AOR3,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AOR3" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SAUREF
mkstat = 0
zoncou = "SAUREF"
indice = 0
If varmode([M]SAUREF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SAUREF" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone CRPTAXREF
mkstat = 0
zoncou = "CRPTAXREF"
indice = 0
If varmode([M]CRPTAXREF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRPTAXREF" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone PAYTHR
mkstat = 0
zoncou = "PAYTHR"
indice = 0
IMPENT = [M]PAYTHR
If varinit([M]PAYTHR,indice)=0
 IMPENT = 1
Endif
If varmode([M]PAYTHR,indice)=0
 [M]PAYTHR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PAYTHR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PAYTHR(indice)
 Endif
Endif
[M]PAYTHR = IMPENT

## Zone APPLEVALL
mkstat = 0
zoncou = "APPLEVALL"
indice = 0
IMPENT = [M]APPLEVALL
WNUM = IMPENT
If varinit([M]APPLEVALL,indice)=0
 IMPENT = 1
Endif
If varmode([M]APPLEVALL,indice)=0
 [M]APPLEVALL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "APPLEVALL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]APPLEVALL(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_APPLEVALL(IMPENT) From TRTCPYLEGUKI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "APPLEVALL" : GZNUM = 1001692 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]APPLEVALL = IMPENT

## Zone APPLEVAMT
mkstat = 0
zoncou = "APPLEVAMT"
indice = 0
If varmode([M]APPLEVAMT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "APPLEVAMT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_APPLEVAMT([M]APPLEVAMT) From TRTCPYLEGUKI
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "APPLEVAMT" : GZNUM = 1001693 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

indice = 0
status = 1
zoncou = "NBBAN"
If !mkstat
 NBLIG = [M]NBBAN
 For nolign=1 To NBLIG
  indice = nolign-1
  [M]NBBAN = nolign
  status = 75
  Call SAI_NBBAN(IMPFIC,ACTION,IMPTRT)
  If mkstat : Break : Endif
 Next nolign
 If mkstat : End : Endif
 indice = 0
Endif

####################################
## Bloc tableau 5
####################################
IMPTBL = 1

## Zone NBCAR
mkstat = 0
zoncou = "NBCAR"
indice = 0
status = 1
zoncou = "NBCAR"
If varmode([M]NBCAR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBCAR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBCAR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBCAR = nolign
   status = 75
   Call SAI_NBCAR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 6
####################################
IMPTBL = 0

## Zone CMPSTGDAT
mkstat = 0
zoncou = "CMPSTGDAT"
indice = 0
If varmode([M]CMPSTGDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CMPSTGDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone AUTRENDAT
mkstat = 0
zoncou = "AUTRENDAT"
indice = 0
If varmode([M]AUTRENDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AUTRENDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 4
####################################
Subprog SAI_NBBAN(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1


## Zone ACCTYP
mkstat = 0
zoncou = "ACCTYP"
IMPENT = [M]ACCTYP(indice)
If varinit([M]ACCTYP,indice)=0
 IMPENT = 1
Endif
[M]ACCTYP(indice) = IMPENT

## Zone DEFFLG
mkstat = 0
zoncou = "DEFFLG"
IMPENT = [M]DEFFLG(indice)
If varinit([M]DEFFLG,indice)=0
 IMPENT = 1
Endif
[M]DEFFLG(indice) = IMPENT

## Zone HMRC
mkstat = 0
zoncou = "HMRC"
IMPENT = [M]HMRC(indice)
If varinit([M]HMRC,indice)=0
 IMPENT = 1
Endif
[M]HMRC(indice) = IMPENT


End

####################################
## Bloc tableau 5
####################################
Subprog SAI_NBCAR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBCAR
mkstat = 0
zoncou = "NBCAR"

## Zone CARREG
mkstat = 0
zoncou = "CARREG"
If varmode([M]CARREG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CARREG" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CARREG(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CARREG" : GZNUM = 55180 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_CARREG([M]CARREG(indice)) From TRTCPYLEGUKI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CARREG" : GZNUM = 55180 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CARMAK
mkstat = 0
zoncou = "CARMAK"
If varmode([M]CARMAK,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CARMAK" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CARMAK(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CARMAK" : GZNUM = 55181 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone CARMOD
mkstat = 0
zoncou = "CARMOD"
If varmode([M]CARMOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CARMOD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CARMOD(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CARMOD" : GZNUM = 1001869 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone FUETYP
mkstat = 0
zoncou = "FUETYP"
IMPENT = [M]FUETYP(indice)
If varinit([M]FUETYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]FUETYP,indice)=0
 [M]FUETYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FUETYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FUETYP(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "FUETYP" : GZNUM = 52434 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]FUETYP(indice) = IMPENT

## Zone EMISSI
mkstat = 0
zoncou = "EMISSI"
If varmode([M]EMISSI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EMISSI" : Gosub ACTION From =IMPTRT
 Endif
 If [M]EMISSI(indice)<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "EMISSI" : GZNUM = 1001870 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone LISPRI
mkstat = 0
zoncou = "LISPRI"
If varmode([M]LISPRI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LISPRI" : Gosub ACTION From =IMPTRT
 Endif
 If [M]LISPRI(indice)=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "LISPRI" : GZNUM = 1820 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If [M]LISPRI(indice)<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "LISPRI" : GZNUM = 1820 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone DATREG
mkstat = 0
zoncou = "DATREG"
If varmode([M]DATREG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATREG" : Gosub ACTION From =IMPTRT
 Endif
 If [M]DATREG(indice)=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DATREG" : GZNUM = 1001873 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NBCAR
mkstat = 0
zoncou = "NBCAR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CPYLEGUKI"
Return

