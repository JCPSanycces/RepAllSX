If !clalev([F:BPC])  Local File BPCUSTOMER [BPC] : Endif
#-----
Local Char    WMSG(250)
Local Char    COD_OBJ(GLONAOB)
Local Char    WWKEYS(GLONBPS)
Local Char    CHAMPS_LUS(50)(1..10)
Local Blbfile BLOB_LUS(1)
Local Date DATMIN : DATMIN=gdat$( 1, 1,year(date$))
Local Date DATMAX : DATMAX=gdat$(31,12,year(date$))
#-----
COD_OBJ="BPC"
WWKEYS="A-TS"
WWKEYS="CROCAN"
Call LECTURE(COD_OBJ,WWKEYS,CHAMPS_LUS,BLOB_LUS) From WMNETBPC
#-----
WMSG ="Client ="-WWKEYS-"-"-CHAMPS_LUS(1)+"\"
WMSG+="Nb cdes mois ="-CHAMPS_LUS(6)+"\"
WMSG+="Nb cdes an ="-CHAMPS_LUS(7)+"\"
WMSG+="CA mois ="-CHAMPS_LUS(8)-GLOCALDEV+"\"
WMSG+="CA an ="-CHAMPS_LUS(9)-GLOCALDEV+"\"
WMSG+="En cours ="-CHAMPS_LUS(10)-GLOCALDEV
Call MESSAGE(WMSG) From GESECRAN
#-----
End



#############################################
$ACTION

Case ACTION
 When "DESC_LISTE" : Gosub DESC_LISTE
 When "DESC_LEC"   : Gosub DESC_LEC
 When "LISTE"      : Gosub LISTE
 When "LECTURE"    : Gosub LECTURE
 When "RAFRAICHIR" : Gosub RAFRAICHIR
Endcase
Return
#############################################

#**
#* Sous-programme de description du web service de liste
#* @public
#*!
$DESC_LISTE
Return



#**
#* Sous-programme de description du web service de lecture
#* @public 
#*!
$DESC_LEC
#-----
CODE_CHAMPS(6) ="NBMSOH"
CODE_CHAMPS(7) ="NBASOH"
CODE_CHAMPS(8) ="CAMBPC"
CODE_CHAMPS(9) ="CAABPC"
CODE_CHAMPS(10)="OSTBPC"

INTIT_CHAMPS(6) =mess(236,191,1)
INTIT_CHAMPS(7) =mess(237,191,1)
INTIT_CHAMPS(8) =mess(238,191,1)
INTIT_CHAMPS(9) =mess(239,191,1)
INTIT_CHAMPS(10)=mess(240,191,1)

TYPE_CHAMPS(6) =3 
TYPE_CHAMPS(7) =3
TYPE_CHAMPS(8) =4
TYPE_CHAMPS(9) =4
TYPE_CHAMPS(10)=4

LEN_CHAMPS(6)  =8 
LEN_CHAMPS(7)  =8
LEN_CHAMPS(8)  =9.2
LEN_CHAMPS(9)  =9.2
LEN_CHAMPS(10) =9.2
#-----
Return

#**
#* Sous-programme de liste
#* @public
#*!

# hcb 
#-------------------------- #
# Sous-programme de liste   #
# ------------------------- #
# CHP1 () (1..)   BPCNUM    #
# CHP2 () (1..)   BPCNAM    #
# CHP3 () (1..)   OSTAUZ    #
# CHP4 () (1..)   ENAFLG    #
# CHP5 () (1..)   SOLDE     #
# CHP6 () (1..)   TELEPHONE #
# CHP7 () (1..)   FAX       #
# CHP8 () (1..)             #
# CHP9 () (1..)             #
#---------------------------#
$LISTE

#----- Table BPCUSTOMER
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:MVC])=0 : Local File BPCUSTMVT  [MVC] : Endif
#-----
Local Integer I_E
Local Decimal P

#-----
For I_E=1 To NB_LIG

    If [F:BPC]BPCNUM <> CHP1(I_E)    
       Read [BPC]BPC0=CHP1(I_E)
    Endif
    Raz P
    P = func TRTBPMVT.CALOST([BPC]BPCRSK,[BPC]CHGTYP,date$)

CHP6(I_E)=string$((CHP3(I_E) >=P & [BPC]OSTCTL = 1),"green")+string$((CHP3(I_E) <P  & [BPC]OSTCTL = 1),"red")+string$([BPC]OSTCTL = 3,"red")+string$([BPC]OSTCTL = 2,"green")
Next I_E
#-----
Return


#**
#* Sous-programme de lecture dĂ©tail
#* @public
#*!
$LECTURE
#-----
Local Date DATMIN, DATMAX
#-----
If month(date$)=1
  DATMIN=gdat$( 1,12,year(date$)-1)
  DATMAX=gdat$(31,12,year(date$)-1)
Elsif month(date$)-1=2
  DATMIN=gdat$( 1,month(date$)-1,year(date$))
  DATMAX=gdat$(28,month(date$)-1,year(date$))
Elsif find(month(date$)-1,4,6,9,11)
  DATMIN=gdat$( 1,month(date$)-1,year(date$))
  DATMAX=gdat$(30,month(date$)-1,year(date$))
Else
  DATMIN=gdat$( 1,month(date$)-1,year(date$))
  DATMAX=gdat$(31,month(date$)-1,year(date$))
Endif
CHAMPS_LUS(6) = num$(func TRTX3FNC.GETNBRSOH(WWKEYS,DATMIN,DATMAX)) 
CHAMPS_LUS(8) =num$(func TRTX3FNC.GETCABPC(WWKEYS,DATMIN,DATMAX))
DATMIN=gdat$( 1, 1,year(date$)-1)
DATMAX=gdat$(31,12,year(date$)-1)
CHAMPS_LUS(7) =num$(func TRTX3FNC.GETNBRSOH(WWKEYS,DATMIN,DATMAX))
CHAMPS_LUS(9) =num$(func TRTX3FNC.GETCABPC(WWKEYS,DATMIN,DATMAX))
CHAMPS_LUS(10)=num$(func TRTBPMVT.CALOST(WWKEYS,[BPC]CHGTYP,date$))
#-----
Return

#**
#* Sous-programme de rafraichissement favoris
#* @public
#*!
$RAFRAICHIR
Return



