#######################################################
## Fonctions super-utilisateur et fichier entreprise###
#######################################################
Local Integer OK
Case GBIDC1
 When "m"     : Call MONO(OK)
                If OK
                 Call MESSAGE(mess(151,124,1)) From GESECRAN
                Endif
 When "M"     : Call MULTI(OK)
                If OK
                 Call MESSAGE(mess(152,124,1)) From GESECRAN
                Endif
Endcase
End


###############################################
## Passage en Mono / Multi                  ###
## Tous les programmes sont dans ENTREPMONO ###
###############################################
Subprog MONO(OK)
Variable Integer OK
Call MONO(OK) From ENTREPMONO
End

Subprog MONODOS(DOSSIER,VALEUR,OK)
Value    Char    DOSSIER()
Variable Integer OK
Value    Char    VALEUR()
Call MONODOS(DOSSIER,VALEUR,OK) From ENTREPMONO
End

Subprog MULTI(OK)
Variable Integer OK
Call MULTI(OK) From ENTREPMONO
End

Subprog MULTIDOS(DOSSIER,OK)
Value    Char    DOSSIER()
Variable Integer OK
Call MULTIDOS(DOSSIER,OK) From ENTREPMONO
End

Subprog TSTMONO(OK)
Variable Integer OK
Call TSTMONO(OK) From ENTREPMONO
End

Subprog TSTMONODOS(DOSSIER,VALEUR,OK)
Value    Char    DOSSIER()
Value    Char    VALEUR()
Variable Integer OK
Call TSTMONODOS(DOSSIER,VALEUR,OK) From ENTREPMONO
End

####################################################
## Lecture du no de série pour modules/options    ##
####################################################
Subprog AUTORIS
Local Libelle  BIT(1..96)
Local Integer  I , J
If GMENDEP="" : End : Endif

Call SERIAL(BIT)
GAUTORIS=1
End

Subprog AUTORISA(AUTMOD,AUTOPT)
Variable Integer  AUTMOD() , AUTOPT()
Local    Libelle  BIT(1..96)
GAUTORIS=0
Call SERIAL(BIT)
End

Subprog SERIALFIC(BIT,FICHIER)
Variable Libelle BIT(1..)
Value    Char    FICHIER
End

Subprog SERIAL(BIT)
Variable Libelle BIT(1..)
End
