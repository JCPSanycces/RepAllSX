#<AdxTL>@(#)9.0.0.0 $Revision$
# Trt MWIPLIB : Reprise de XWIPLIB du patch des US    (TB - 2003)
# Sous-programmes générant des WIPCOST au fur et à mesure des suivis

###########################################################################
# Sous-programmes avec les n° de types de Wipcost générés
# 1.  Consommation matière
# 14. Déclaration de Production
#    MAJ_WIPCOST - appelé depuis le traitement STKMAJ (entrées et sorties)
#                  Traite création, modification, suppression et régul
# 5.  Frais généraux de matières ou de produit
#    MAT_OH - Procédure pour calcul des frais après sortie matière ou après
#             une entrée de produit (Appelé depuis MAJ_WIPCOST)
###########################################################################
# 2, 3, 6, 7, 16 Operations Expenses and Overhead and Scrap
#    OPETRK_NEW - Procedure used to decide which type of WIPCOST records
#                to create - Machine and/or Labor - when entering a new line
#                on a production tracking record for an Operation's Expense,
#                Overhead, or scrap. Then call the corresponding procedure.
#                This will be called from SUBMTKC - MAJOPE right before the
#                end of the loop.
#        MLEOPETRK_NEW - Procedure used to create a new WIPCOST record when
#                    creating a new line on a production tracking record
#                    for the expense of an Operation that has a Machine or
#                    Labor Work Center.
#                    This will be called from OPETRK_NEW.
#        MLOOPETRK_NEW - Procedure used to create a new WIPCOST record when
#                    creating a new line on a production tracking record
#                    for the overhead of an Operation that has a Machine or
#                    Labor Work Center.
#                    This will be called from OPETRK_NEW.
#    OPETRK_MOD - Procedure used to decide which type of WIPCOST records
#                to create - Machine and/or Labor - when modifying a line
#                on a production tracking record for an Operation's Expense,
#                Overhead, or scrap. Then call the corresponding procedure.
#                This will be called from MTKWIN - MAJ_MODIF right after
#                the call to MAJFIC, both before loop and in loop(if range).
#        MLOOPETRK_MOD - Procedure used to create a new WIPCOST record when
#                    modifying a line on a production tracking record
#                    for the overhead of an Operation that has a Machine or
#                    Labor Work Center.
#                    This will be called from OPETRK_MOD.
#    OPETRK_DEL - Procedure used to decide which type of wipcost records
#                to create - Machine and/or Labor - when deleting a line
#                on a production tracking record for an Operation's Expense,
#                Overhead, or scrap.  Then call the corresponding procedure.
#                This will be called from SUBMTKC - ANNULE_SUIV right after
#                the call to ANNULE_SUIVOPE which is in a loop.
#                This will also be called from MTKWIN - MAJ_MODIF right after
#                the call to ANNULE_SUIVOPE, both before loop and in loop(if range).
#        MLEOPETRK_DEL - Procedure used to create a new wipcost record when
#                    deleting a line on a production tracking record
#                    for the expense of an Operation that has a Machine or
#                    Labor Work Center.
#                    This will be called from OPETRK_DEL.
#        MLOOPETRK_DEL - Procedure used to create a new wipcost record when
#                    deleting a line on a production tracking record
#                    for the overhead of an Operation that has a Machine or
#                    Labor Work Center.
#                    This will be called from OPETRK_DEL.
###########################################################################
# 4, 8 Subcontracting Expense and Overhead
#    SCEOPETRK_NEW - Procedure used to create a new wipcost record when
#                    creating a new line on a purchase receipt record
#                    for the expense of a Subcontracting Operation.
#                    This will be called from MTKLIB - MAJ_MTK.
#    SCEOPETRK_DEL - Procedure used to create a new wipcost record when
#                    deleting a line on a purchase receipt record
#                    for the expense of a SubContracting Operation.
#                    This will be called from OPETRK_DEL.
#    SCOOPETRK_DEL - Procedure used to create a new wipcost record when
#                    deleting a line on a purchase receipt record
#                    for the overhead of a SubContracting Operation.
#                    This will be called from OPETRK_DEL.
#    SCEOPEPRI_MOD - appelé depuis SBCLIB :
#                    mise à jour des wipcost avec le prix de facture
###########################################################################


###########################################################################
# CREWIPMATSCO: Fill mask [M:STW] for items not managed in stock
#          For example : material supplied by sub-contractor
#          It allows to manage WIP records
# [F:SCM], [F:PTD] (and maybe [F:PID]) have to be filled
###########################################################################
# Issue 99332 GA 05/2014 + 2 parameters [F:PTD]PTHNUM,[F:PTD]PTDLIN
Subprog CREWIPMATSCO(LCOD,PVCRNUM,PVCRLIN,PRET)
Value    Char    LCOD
Value Char       PVCRNUM # Issue 99332 GA 05/2014
Value Integer    PVCRLIN # Issue 99332 GA 05/2014
Variable Integer PRET

If !clalev([F:MWI]) : Local File WIPCOST   [MWI] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
If !clalev([F:PID]) : Local File PINVOICED [PID] : Endif
If !clalev([F:SCI]) : Local File SCOITM    [SCI] : Endif
If [F:SCI]SCONUM<>[F:SCM]SCONUM | [F:SCI]SCILIN<>[F:SCM]SCILIN
    Read [SCI]SCI0=[F:SCM]SCONUM;[F:SCM]SCILIN
Endif
Raz [M:STW]
Raz [M:SVW]

[M:STW]STOFCY = [F:SCI]PRHFCY
# Issue 66659 - 2010-09-01 by CCC : Il n'y a pas de date de livraison pour une matière fournie
#                                => on prend la date de réception
#[M:STW]IPTDAT = [F:SCM]DLVDAT
[M:STW]IPTDAT = [F:PTD]RCPDAT
[M:STW]ITMREF = [F:SCM]CPNITMREF
If [F:ITM]ITMREF <> [M:STW]ITMREF
    Read [F:ITM]ITM0=[M:STW]ITMREF
    If fstat
        Call FSTA("ITM") From GLOCK
        PRET = 1
        End
    Endif
Endif

# Issue 99332 GA 05/2014 Line receipt for subcontracted product
If !clalev([F:PTDW]): Local File PRECEIPTD [PTDW]: Endif
Filter [PTDW] Where PTHNUM =PVCRNUM
&                 & PTDLIN<=PVCRLIN
&                 & LINTYP=2
&            Order By Key PKX=PTHNUM;PTDLIN Desc
Read [PTDW]PKX First
Filter [PTDW]
If fstat
    Call ECR_DEBUG("CREWIPMATSCO(MWIPLIB):"-[F:SCI]SCONUM-"No receipt"-PVCRNUM-num$(PVCRLIN)) From SCOSTKAUTLIB
    LRET=1
    GOK=0
    End
Endif

[M:STW]STU    = [F:SCM]STU
[M:STW]TRSTYP = 29                : # 29=Conso matière
# Issue 71362 - 2011-04-18 by CCC : Le document doit correspondre à celui qui a créé les wipcost donc c'est la réception
#If [F:PID]NUM <>"" & [F:SCM]SCOFLG=3 : # Matières fournies par le sous-traitant et facturées
## on se rattache à la facture d'achat
#  [M:STW]VCRTYP = 17
#  [M:STW]VCRNUM = [F:PID]NUM
#  [M:STW]VCRLIN = [F:PID]PIDLIN
#Else
## sinon, comme pour les matières sorties,
## on se rattache à la réception de l'article lancé
  [M:STW]VCRTYP = 6
  [M:STW]VCRNUM = [F:PTDW]PTHNUM # Issue 99332 GA 05/2014 [F:PTD]PTHNUM
  [M:STW]VCRLIN = [F:PTDW]PTDLIN # Issue 99332 GA 05/2014 [F:PTD]PTDLIN
#Endif
[M:STW]VCRTYPORI = 36
[M:STW]VCRNUMORI = [F:SCM]SCONUM
[M:STW]VCRLINORI = [F:SCM]SCILIN
[M:STW]VCRSEQORI = [F:SCM]SCMLIN
# Issue 106102 - 2016-05-26 by CCC : Value of deletion has to be calculated
#If LCOD = "M"
#  [M:STW]NBLIG        = 2     : # 2 lignes: si modification 'A' et 'C'
#
#  # suppression: elle ne peut-être que complète pour une ligne, elle ne peut pas être partielle comme pour les mouvements de stock
#  [M:STW]MAJCOD(0)    = "A"
#  For [MWI] Where VCRTYP    = 36
#&               & VCRNUM    = [M:STW]VCRNUMORI
#&               & MFGTRKNUM = [M:STW]VCRNUM
#&               & MFGTRKLIN = [M:STW]VCRLIN
#&               & ITMREF    = [M:STW]ITMREF
#      [M:STW]QTYSTU(0)    += [F:MWI]QTY
#      [M:STW]QTYSTUACT(0) += [F:MWI]QTYACT
#      [M:SVW]AMTVAL(0)    += [F:MWI]AMOUNT
#      [M:SVW]PRINAT(0)    = 0
#  Next
#  [M:SVW]VMATCST([F:ITM]BRDCOD-1) = [M:SVW]AMTVAL(0)
#
#  [M:STW]MAJCOD(1)    = "C"  : # on recrée la ligne suite à maj
#  [M:STW]QTYSTU(1)    = [M:SDP]QTY
#  [M:STW]QTYSTUACT(1) = [M:SDP]QTY
#  [M:SVW]AMTVAL(1)    = [M:SDP]AMTTOT
#  [M:SVW]PRINAT(1)    = 8
#  Call COPSDP2SVWVAL (1,1) From STKVALECR
#Else
#  [M:STW]NBLIG        = 1     : # 1 ligne :si création ou annulation
#  [M:STW]MAJCOD(0)    = LCOD  : # 'A' ou 'C'
#  [M:STW]QTYSTU(0)    = [M:SDP]QTY
#  [M:STW]QTYSTUACT(0) = [M:SDP]QTY
#  [M:SVW]AMTVAL(0)    = [M:SDP]AMTTOT
#  [M:SVW]PRINAT(0)    = 8
#  Call COPSDP2SVWVAL (1,1) From STKVALECR
#Endif
If LCOD = "C"
  [M:STW]NBLIG        = 1     : # 1 ligne :si création ou annulation
  [M:STW]MAJCOD(0)    = LCOD  : # 'A' ou 'C'
  [M:STW]QTYSTU(0)    = [M:SDP]QTY
  [M:STW]QTYSTUACT(0) = [M:SDP]QTY
  [M:SVW]AMTVAL(0)    = [M:SDP]AMTTOT
  [M:SVW]PRINAT(0)    = 8
  Call COPSDP2SVWVAL (1,1) From STKVALECR
Else

  # suppression: elle ne peut-être que complète pour une ligne, elle ne peut pas être partielle comme pour les mouvements de stock
  [M:STW]MAJCOD(0)    = "A"
  For [MWI] Where VCRTYP    = 36
&               & VCRNUM    = [M:STW]VCRNUMORI
&               & MFGTRKNUM = [M:STW]VCRNUM
&               & MFGTRKLIN = [M:STW]VCRLIN
&               & ITMREF    = [M:STW]ITMREF
      [M:STW]QTYSTU(0)    += [F:MWI]QTY
      [M:STW]QTYSTUACT(0) += [F:MWI]QTYACT
      [M:SVW]AMTVAL(0)    += [F:MWI]AMOUNT
      [M:SVW]PRINAT(0)    = 0
  Next
  [M:SVW]VMATCST([F:ITM]BRDCOD-1) = [M:SVW]AMTVAL(0)
  If LCOD="A"
    [M:STW]NBLIG        = 1
  Else
    [M:STW]NBLIG        = 2     : # 2 lignes: si modification 'A' et 'C'
    [M:STW]MAJCOD(1)    = "C"  : # on recrée la ligne suite à maj
    [M:STW]QTYSTU(1)    = [M:SDP]QTY
    [M:STW]QTYSTUACT(1) = [M:SDP]QTY
    [M:SVW]AMTVAL(1)    = [M:SDP]AMTTOT
    [M:SVW]PRINAT(1)    = 8
    Call COPSDP2SVWVAL (1,1) From STKVALECR
  Endif
Endif

Call MAJ_WIPCOST(PRET)
End

#**
#* SCMPRI_MOD : Met à jour les Wipcost d'une matière fournie par le sous-traitant
#*              au moment de la facture
#* @param PVCRTYP  : type de document (réception)
#* @param PVCRNUM  : n° de document
#* @param PVCRLIN  : n° ligne de document
#* @param PVCRTYPORI : Type de document d'origine (EO)
#* @param PVCRNUMORI : N° document origine
#* @param PVCRLINORI : N° ligne document d'origine
#* @param PITM       : Code article
#* @param PFCY     : Site
#* @param [M:SDP]    : Cet écran doit être chargé avec le détail du delta de montant
#*!
Subprog SCMPRI_MOD(PVCRTYP,PVCRNUM,PVCRLIN,PVCRTYPORI,PVCRNUMORI,PVCRLINORI,PITM,LRET)
Value Integer PVCRTYP
Value Char    PVCRNUM
Value Integer PVCRLIN
Value Integer PVCRTYPORI
Value Char    PVCRNUMORI
Value Integer PVCRLINORI
Value Char    PITM
Variable Integer LRET

If !clalev([M:STW]) : Local Mask STOWORK : Endif
If !clalev([M:SVW]) : Local Mask STOVALWORK : Endif
If !clalev([F:MWI]) : Local File WIPCOST : Endif

Local Integer LFIND
Local Decimal LAMTORI : Raz LAMTORI
Local Decimal LDELTA(1+GACTMAT+GACTMAC+GACTLAB+2+4)     # = dim mat + dim mac + dim lab + sco + invdta + fg mat + fg mac + fg lab + fg sco

Raz LRET

# Issue 86964 - 2013-01-31 by CCC
# Si pas de différence => on sort
If [M:SDP]AMTTOT=0
    End
Endif

# Issue 99332 GA 05/2014 see SCOSBCLIB: [F:PTDW] already reloaded ...
# On se positionne sur la ligne de réception de l'article lancé
#Local File PRECEIPTD [PTD]
#Filter [PTD] Where PTHNUM=PVCRNUM
#&                & PTDLIN<PVCRLIN
#&                & LINTYP=2
#&            Order By Key PKX=PTDLIN Desc
#Read [PTD]PKX First
#Filter [PTD]
#If fstat
#    LRET=1
#    End
#Endif
# Issue 86964 - 2013-01-31 by CCC
# 1- Calcul du montant déjà enregistré pour cette matière
#Filter [MWI] Where VCRTYP = PVCRTYPORI
#&                & VCRNUM = PVCRNUMORI
#&                & VCRLIN = [F:PTD]VCRLINORI => ????
#&                & TXNTYP = 1
#&                & ITMREF = PITM
#&                & MFGTRKNUM = PVCRNUM
#&                & MFGTRKLIN = [F:PTD]PTDLIN => [F:PTDW]PTDLIN is in parameter PVCRLIN
Filter [MWI] Where VCRTYP = PVCRTYPORI
&                & VCRNUM = PVCRNUMORI
&                & VCRLIN = PVCRLINORI
&                & TXNTYP = 1
&                & ITMREF = PITM
&                & MFGTRKNUM = PVCRNUM
&                & MFGTRKLIN = PVCRLIN

LFIND=0
For [MWI]
    [M:SDP]AMTTOT += [F:MWI]AMOUNT
    Call LOADSDP("[F:MWI]", "", 1) From STKVAL
    LFIND=1
Next
Filter [MWI]

# Issue 99332 GA 05/2014 + 2 parameters PVCRNUM,PVCRLIN
# 2- Régul des wipcost
If !LFIND
    Call CREWIPMATSCO("C",PVCRNUM,PVCRLIN,LRET)
Else
    Call CREWIPMATSCO("M",PVCRNUM,PVCRLIN,LRET)
Endif

End

###########################################################################
# Vérifie ou crée la table d'entête (appelé par les sous-pro générant des Wipcost)
# au retour de ce sous-pro, il faut affecter [F:MWI]VCRNUM
###########################################################################
Subprog CRE_MFGWIP(W_VCRNUM,W_VCRTYP,W_TYP,W_FCY,W_DAT,W_PDT,W_ALTB,W_ROU,W_ALTR,W_WST,ERR)
Value     Char     W_VCRNUM
Value     Integer  W_VCRTYP     # 10:suivi sur OF, 36:suivi sur EO , sinon suivi sans OF --> 37
Value     Integer  W_TYP
Value     Char     W_FCY
Value     Date     W_DAT   # date d'imputation du suivi
Value     Char     W_PDT   # article parent
Value     Integer  W_ALTB  # alt de nomenclature
Value     Char     W_ROU   # gamme
Value     Integer  W_ALTR
Value     Char     W_WST   # poste de charge (suivi divers)
Variable  Integer  ERR

Local    Decimal NO_EXE,NO_PER    # pour que le sous-pro marche (décimal !)
Local    Char    MWH_NUM(GLONVCR) # numéro servant de regroupement de WIP = clé de MWH
Local    Char    CRIT_ENT(80)     # critere entête pour éléments exclusifs
Local    Integer LVCRTYP, LOK

LVCRTYP=W_VCRTYP
If LVCRTYP=0
    LVCRTYP=37
Endif

If GMODU(8)=2
    If !clalev([F:MFG])  : Local File MFGHEAD   [MFG]  : Endif
Endif
If GMODU(6)=2
    If !clalev([F:SCO])  : Local File SCOHEAD   [SCO]  : Endif
    If !clalev([F:SCI])  : Local File SCOITM    [SCI]  : Endif
Endif
If !clalev([F:MWH])  : Local File MFGWIP    [MWH]  : Endif
If !clalev([F:TCA])  : Local File TABCOUAFF [TCA]  : Endif
If !clalev([F:PER])  : Local File PERIOD    [PER]  : Endif

$RD_MWH
Read [MWH]MWH0 = LVCRTYP;W_VCRNUM
If fstat
    # selon le type de suivi créer MWH vide ou à partir de MFG
    If find(LVCRTYP,10,36)
        Raz LOK
        Case LVCRTYP
            When 10 :
                Raz [F:MWH]
                Read [MFG]MFG0=W_VCRNUM
                If !fstat
                  [F:MWH] = [F:MFG] # attention MFG n'a pas encore toutes ses zones renseignées (dates, CPLQTY...)
                  [F:MWH]VCRTYP = 10
                  [F:MWH]VCRNUM = [F:MFG]MFGNUM
                  LOK = 1
                Endif
            When 36 :
                Raz [F:SCO]
                Read [SCO]SCO0=W_VCRNUM
                If !fstat
                  [F:MWH] = [F:SCO]
                  [F:MWH]STRDAT = [F:SCO]ORDDAT
                  [F:MWH]ENDDAT = [F:SCO]RETDAT
                  If [F:SCI]SCONUM<>[F:SCO]SCONUM
                      Filter [SCI] Where SCONUM=[F:SCO]SCONUM
                      Read [SCI]SCI0 First  # V6 : mono-article
                      Filter [SCI]
                  Endif
                  [F:MWH] = [F:SCI]
                  [F:MWH]MFGFCY = [F:SCI]PRHFCY
                  [F:MWH]VCRTYP = 36
                  [F:MWH]VCRNUM = [F:SCO]SCONUM
                  LOK = 1
                Endif
        Endcase
        If LOK
            [F:MWH]MATLEVFLG = 2
            [F:MWH]MFGTRKFLG = 4 # pour un 1er suivi, MFG n'est pas encore flagué
            [F:MWH]TRKTYP    = 1       # suivi sur OF
            [F:MWH]TRKFIRST  = W_DAT   # 1er suivi puisqu'on crée MWH
            [F:MWH]CREUSR    = GUSER
            [F:MWH]CREDAT    = date$
            [F:MWH]UPDUSR    = ""
            [F:MWH]UPDDAT    = [0/0/0]
            [F:MWH]EXPNUM    = [C]EXPORT
            Write [MWH]
            If fstat=3 : # GH 02/2016 bug 108954 creation done by another simultaneous transaction is not detectable
               Goto RD_MWH
            Endif
            If fstat
                Call FSTA("MWH") From GLOCK
                GOK = 0
            Endif
        Endif
    Else
        # chercher une entité sur cette période

        Call GETSOC(W_FCY) From DEVSUB    # --> renseigne GTYPGEN
        Call GETPER(W_FCY,GTYPGEN,W_DAT,NO_EXE,NO_PER) From CPTSUB
        # test selon dates et ITMREF ou ROUNUM
        # un seul filtre puisque toutes les combinaisons sont exclusives entre elles
        # (pour autant qu'on ne mette pas à la fois ROUNUM et WST)
        If W_ROU <> ""
          CRIT_ENT = "ITMREF=W_PDT & BOMALT=W_ALTB & ROUNUM=W_ROU & ROUALT=W_ALTR"
        Else
          CRIT_ENT = "ITMREF=W_PDT & BOMALT=W_ALTB & WST=W_WST"
        Endif

        Filter [MWH] Where TRKTYP=W_TYP & STRDAT=[F:PER]PERSTR & ENDDAT=[F:PER]PEREND & MFGFCY=W_FCY
&                & evalue(CRIT_ENT)
        Read [MWH]MWH1 First
        If fstat
          # nouveau chrono (compteur 'MWH')   # Récupération du compteur :
          Local Integer WOK
          Call LECTCA(8,WOK) From SUBTCA
          If WOK=0
             ERR = 5
             Raz [F:TCA]
          Else
            Call NUMERO([F:TCA]CODNUM(6),W_FCY,W_DAT,"",MWH_NUM,ERR) From SUBANM
          Endif
          If ERR=0
            Raz [F:MWH]
            [F:MWH]VCRTYP    = LVCRTYP
            [F:MWH]VCRNUM    = MWH_NUM  # nouveau compteur
            [F:MWH]MFGFCY    = W_FCY
            [F:MWH]STRDAT    = [F:PER]PERSTR
            [F:MWH]ENDDAT    = [F:PER]PEREND
            [F:MWH]TRKTYP    = W_TYP
            [F:MWH]TRKFIRST  = W_DAT    # 1er suivi puisqu'on crée MWH
            [F:MWH]ITMREF    = W_PDT
            [F:MWH]ROUNUM    = W_ROU
            [F:MWH]ROUALT    = W_ALTR    # que pour MKO !
            If W_PDT <> ""
              [F:MWH]BOMALT    = W_ALTB  # que pour MKI et MKM !
            Endif
            If [F:MWH]ROUNUM = ""
              [F:MWH]WST     = W_WST     # que pour suivi des temps divers
            Endif
            [F:MWH]MFGTRKFLG = 4         # pour être considéré en cours
            [F:MWH]CREUSR    = GUSER
            [F:MWH]CREDAT    = date$
            [F:MWH]UPDUSR    = ""
            [F:MWH]UPDDAT    = [0/0/0]
            [F:MWH]EXPNUM    = [C]EXPORT
            Write [MWH]
            If fstat
              Call FSTA("MWH") From GLOCK
              GOK = 0
            Endif
          Else
            Gosub ERR_MFGWIP
          Endif
        Endif
        Filter [MWH]
    Endif
Else
    # CCC (10/01/08) DM 44021
    If [F:MWH]TRKLAST<W_DAT
        [F:MWH]TRKLAST   = W_DAT
    Endif
    If [F:MWH]TRKFIRST>W_DAT | [F:MWH]TRKFIRST = "00/00/00"
        [F:MWH]TRKFIRST = W_DAT
    Endif
Endif
If [F:MWH]BOMALTTYP=0 & [F:MWH]BOMALT<>0 # FQ 58577
   Case LVCRTYP
     When 10 : [F:MWH]BOMALTTYP=2
     When 36 : [F:MWH]BOMALTTYP=3
   Endcase
Endif
End

# Message d'erreurs gestion des compteurs (GMESSAGE est exploité au retour)
$ERR_MFGWIP
Case ERR
 When 1  : GMESSAGE = mess(12,114,1)  : # Compteur inexistant
 When 2  : GMESSAGE = mess(13,114,1)  : # Dépassement de compteur
 When 3  : GMESSAGE = mess(20,101,1)  : # Exercice non ouvert
 When 4  : GMESSAGE = mess(111,123,1) : # Longueur incorrecte
 When 5  : GMESSAGE = mess(64,199,1)  : # aucun compteur n'est affecté à ce document
 When 99 : GMESSAGE = mess(135,133,1) : # Compteur verrouillé
Endcase
GMESSAGE += " ("+[F:TCA]CODNUM(6)+")"
Return

# Générer les WIPCOST d'entrée et de sortie à partir du masque STW
###########################################################################
Subprog MAJ_WIPCOST(ERR)
Variable Integer ERR

Local Integer    LAST_SEQ, I, J
Local Decimal    L_CURRND
Local Integer    X_PRINAT, X_MS, X_UC, X_TXNACT
Local Char       X_MFGFCY(GLONFCY), X_ITMREF(GLONITM), X_STU(GLONUOM)
Local Decimal    X_QTY, X_QTYACT, X_AMOUNT, X_REJQTY # CCC (04/11/04) Bug 26297 Ajouts du calcul de la qté active
Local Decimal    X_INVDTA
Local Date       X_TXNDAT
Local Integer    ITM_TYP, CST_FLG
Local Decimal    LBASAMT    # Base de calcul des FG
Local Char       LMAJCOD(2)
Local Integer    LMATFLG

If !clalev([F:MWH])  : Local File MFGWIP     [MWH]  : Endif
If !clalev([F:MWI])  : Local File WIPCOST    [MWI]  : Endif
If !clalev([F:MWIS]) : Local File WIPCOST    [MWIS] : Endif     # Issue 79062 - 2012-02-06 by CCC

If !clalev([F:ITM])  : Local File ITMMASTER  [ITM]  : Endif
If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([F:ITF])  : Local File ITMFACILIT [ITF]  : Endif
If !clalev([F:ITC])  : Local File ITMCOST    [ITC]  : Endif
If !clalev([F:ICN])  : Local File ITCNAT     [ICN]  : Endif
If !clalev([F:OVE])  : Local File OVERHEAD   [OVE]  : Endif
If !clalev([F:BOH])  : Local File BOM        [BOH]  : Endif
If !clalev([F:BOD])  : Local File BOMD       [BOD]  : Endif
If GMODU(8)=2
    If !clalev([F:MTS])  : Local File MFGTRS     [MTS]  : Endif
    If !clalev([F:MFG])  : Local File MFGHEAD    [MFG]  : Endif
    If !clalev([F:MKM])  : Local File MFGMATTRK  [MKM]  : Endif
    If !clalev([F:MKI])  : Local File MFGITMTRK  [MKI]  : Endif
Endif
If GMODU(6)=2
    If !clalev([F:PTR])  : Local File PURTRS     [PTR]  : Endif
    If !clalev([F:SCO])  : Local File SCOHEAD    [SCO]  : Endif
    If !clalev([F:SCI])  : Local File SCOITM     [SCI]  : Endif
Endif

Read [FCY]FCY0=[M:STW]STOFCY
Call GET_CUR_RND([F:FCY]LEGCPY, L_CURRND, ERR)
# "erreur de lecture sur devise ; société juridique"
If ERR = 1
  GMESSAGE = mess(10,2363,1)-[F:FCY]LEGCPY
  End
Endif

# Selon les cumuls X_QTY, créer un enreg 'Supp' ou un enreg 'Nouveau'
# positionner X_TXNACT et inverser la qté et le montant si besoin
# Traite aussi les régularisations de mvt en attente
X_TXNDAT = [M:STW]IPTDAT
X_MFGFCY = [M:STW]STOFCY
X_ITMREF = [M:STW]ITMREF
X_STU    = [M:STW]STU

# Get a group list
# For now, only version number is the differenciator
Local Char LTABGRP(GLONICVVAL*2+1)([M:STW]NBLIG)
Local Char X_ECCMAJ(GLONICVVAL), X_ECCMIN(GLONICVVAL)
Local Integer LNBGRP, LGRP
For I=0 To [M:STW]NBLIG-1
    # If "vmaj vmin" is not already in LTABGRP -> add it
    If !sigma(0,LNBGRP-1,LTABGRP(indcum)=([M:STW]ECCVALMAJ(I)+" "+[M:STW]ECCVALMIN(I)))
        LTABGRP(LNBGRP) = [M:STW]ECCVALMAJ(I)+" "+[M:STW]ECCVALMIN(I)
        LNBGRP += 1
    Endif
Next

# numéro de l'année pour les valorisations au coût standard
Case [M:STW]TRSTYP
    When 5
        # CCC (2009-07-31) Bug 56895 : La classe MKI peut ne pas être positionnée correctement
        If [F:MKI]MFGTRKNUM<>[M:STW]VCRNUM | [F:MKI]ITMTRKLIN<>[M:STW]VCRLIN
            Read [MKI]MKI0=[M:STW]VCRNUM;[M:STW]VCRLIN
        Endif
        # entrée OF
        Call CRE_MFGWIP([F:MKI]MFGNUM,10*([F:MKI]PRODTYP=1),[F:MKI]PRODTYP,X_MFGFCY,X_TXNDAT,X_ITMREF,[F:MKI]BOMALT,"",0,"",ERR)
        # >>> à appeler avec [F:MKI]BOMNUM au lieu de X_ITMREF qd il sera créé (eviter d'avoir prod=sous-prod)
        # erreur de création entête valorisation encours d'OF (MFGWIP)
        If ERR | GOK<1 : GMESSAGE -= "\"+mess(17,2363,1) : End : Endif

        If [F:MKI]PRODTYP=1 & [F:MKI]MFGLIN>0 ## >> utiliser directement les zones de MKI
            # Cas de sous-produit (le mnt devra être déduit au calcul final de PRF)
            Read [MFI]MFI0=[F:MKI]MFGNUM;[F:MKI]MFGLIN
            ITM_TYP = [F:MFI]ITMTYP
            CST_FLG = [F:MFI]CSTFLG
        Endif

        If ITM_TYP=0 : ITM_TYP = [F:MKI]ITMTYP : Endif
        If CST_FLG=0 : CST_FLG = [F:MKI]CSTFLG : Endif # valorisé en attendant (au cas où)
        If ITM_TYP=0 : ITM_TYP = 1 : Endif
        If CST_FLG=0 : CST_FLG = 2 : Endif # valorisé en attendant (au cas où)

        If [F:MWH]MATLEVFLG = 2
            LMATFLG = func SUBCSTB.ISMAT([M:STW]ITMREF, 2, [F:MKI]BOMALT, [M:STW]IPTDAT)
        Endif

        For LGRP=0 To LNBGRP-1  # 104939 : version management -> 1 WIP per version number

            Raz X_QTY, X_QTYACT, X_REJQTY, X_AMOUNT
            For I=0 To [M:STW]NBLIG-1
              If LTABGRP(LGRP) = ([M:STW]ECCVALMAJ(I)+" "+[M:STW]ECCVALMIN(I))
                If [M:STW]WAIFLG(I) = 0 & [M:STW]MAJCOD(I) = "A"
                  X_QTY     -= [M:STW]QTYSTU(I)
                  X_QTYACT  -= [M:STW]QTYSTUACT(I)
                  X_AMOUNT  += [M:SVW]AMTVAL(I)
                  X_PRINAT   = [M:SVW]PRINAT(I)   # est à la ligne !!
                  If left$([M:STW]STA(I),1) = "R"
                    X_REJQTY     -= [M:STW]QTYSTU(I)
                  Endif
                  X_ECCMAJ = [M:STW]ECCVALMAJ(I)
                  X_ECCMIN = [M:STW]ECCVALMIN(I)
                Endif
              Endif
            Next

            If X_QTY <> 0
              # créer un enreg de type "Supprimé"
              Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ) # par / à MWH précédemment lu ou créé
              X_TXNACT = 3
              Gosub MWI_PROD
              # erreur en retour "erreur à la mise à jour des encours d'OF (WIPCOST)
              If ERR
                GMESSAGE = mess(20,2363,1)
                Break
              Endif
            Endif

            Raz X_QTY, X_QTYACT, X_REJQTY, X_AMOUNT
            For I=0 To [M:STW]NBLIG-1
              If LTABGRP(LGRP) = ([M:STW]ECCVALMAJ(I)+" "+[M:STW]ECCVALMIN(I))
                If [M:STW]WAIFLG(I) = 0 & [M:STW]MAJCOD(I) = "C"
                  X_QTY     += [M:STW]QTYSTU(I) # dans STW la qté n'est pas signée !!
                  X_QTYACT  += [M:STW]QTYSTUACT(I)
                  X_AMOUNT  += [M:SVW]AMTVAL(I) * -1    # NEGATIF par rapport au suivi de l'encours !
                  X_PRINAT   = [M:SVW]PRINAT(I)
                  If left$([M:STW]STA(I),1) = "R"
                    X_REJQTY     += [M:STW]QTYSTU(I)
                  Endif
                  X_ECCMAJ = [M:STW]ECCVALMAJ(I)
                  X_ECCMIN = [M:STW]ECCVALMIN(I)
                Endif
              Endif
            Next
            If X_QTY <> 0
              # créer un enreg de type "Nouveau"
              Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)
              X_TXNACT = 1  # on ne distinguera pas le 'modifié' du 'Nouveau'(à moins que du 'A'+ du 'C' signifie 'Modifié'???)
              Gosub MWI_PROD
              # erreur en retour "erreur à la mise à jour des encours d'OF (WIPCOST)
              If ERR
                GMESSAGE = mess(20,2363,1)
                Break
              Endif
            Endif
        Next
        If ERR : End : Endif
    When 6, 19
        # sortie OF ou réintégration matière (sortie négative)
        # à la régul des manquants MKM n'est pas en ligne, il faut faire la lecture :
        If [F:MKM]MFGTRKNUM<>[M:STW]VCRNUM | [F:MKM]MATTRKLIN<>[M:STW]VCRLIN
          Read [MKM]MKM0=[M:STW]VCRNUM;[M:STW]VCRLIN
          If fstat
            Call FSTA("MKM") From GLOCK
            ERR = 1
            End
          Endif
        Endif
# Inutiles et provoquent un bug en régul des mvts en attente
#        If [F:MFI]MFGNUM<>[F:MKM]MFGNUM | [F:MFI]MFGLIN<>[F:MKM]MFGLIN
#            Read [MFI]MFI0=[F:MKM]MFGNUM;[F:MKM]MFGLIN
#            If fstat
#                Raz [F:MFI]
#            Endif
#        Endif

        # CCC (2010-01-08) Bug 61426 : Type 10 pour les réintégration OF (MATTYP=3)
        Call CRE_MFGWIP([F:MKM]MFGNUM,10*([F:MKM]MATTYP=1|[F:MKM]MATTYP=3),[F:MKM]MATTYP,X_MFGFCY,X_TXNDAT,[F:MKM]BOMNUM,[F:MKM]BOMALT,"",0,"",ERR)
        # erreur de création entête valorisation encours d'OF (MFGWIP)
        If ERR | GOK<1 : GMESSAGE -= "\"+mess(17,2363,1) : End : Endif

        If [F:MWH]MATLEVFLG = 2
            LMATFLG = func SUBCSTB.ISMAT([M:STW]ITMREF, 2, [F:MKM]BOMALT, [M:STW]IPTDAT)
        Endif

        For LGRP=0 To LNBGRP-1

            Raz X_QTY, X_QTYACT, X_AMOUNT
            # 1ère boucle sur l'écran pour mvt annulés
            For I=0 To [M:STW]NBLIG-1
              If LTABGRP(LGRP) = ([M:STW]ECCVALMAJ(I)+" "+[M:STW]ECCVALMIN(I))
                If [M:STW]WAIFLG(I) = 0 & [M:STW]MAJCOD(I) = "A"
                  X_QTY     -= [M:STW]QTYSTU(I)
                  X_QTYACT  -= [M:STW]QTYSTUACT(I)
                  X_AMOUNT  += [M:SVW]AMTVAL(I) * -1
                  X_PRINAT   = [M:SVW]PRINAT(I)
                  X_ECCMAJ = [M:STW]ECCVALMAJ(I)
                  X_ECCMIN = [M:STW]ECCVALMIN(I)
                Endif
              Endif
            Next

            If X_QTY <> 0
              # créer un enreg de type "Supprimé"
              Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)
              X_TXNACT = 3
              Gosub MWI_MAT
              # erreur en retour "erreur à la mise à jour des encours d'OF (WIPCOST)
              If ERR
                GMESSAGE = mess(20,2363,1)
                Break
              Endif
            Endif

            Raz X_QTY, X_QTYACT, X_AMOUNT
            # 2ème boucle sur l'écran pour mvt créés
            For I=0 To [M:STW]NBLIG-1
              If LTABGRP(LGRP) = ([M:STW]ECCVALMAJ(I)+" "+[M:STW]ECCVALMIN(I))
                If [M:STW]WAIFLG(I) = 0 & [M:STW]MAJCOD(I) = "C"
                  X_QTY     += [M:STW]QTYSTU(I) # dans STW la qté n'est pas signée !!
                  X_QTYACT  += [M:STW]QTYSTUACT(I)
                  X_AMOUNT  += [M:SVW]AMTVAL(I)
                  X_PRINAT   = [M:SVW]PRINAT(I)
                  X_ECCMAJ = [M:STW]ECCVALMAJ(I)
                  X_ECCMIN = [M:STW]ECCVALMIN(I)
                Endif
              Endif
            Next
            # faire ici les autres choix de valorisation matière (?): cela désynchroniserait WIP et stock !
            If X_QTY <> 0
              # créer un enreg de type "Nouveau"
              Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)
              X_TXNACT = 1  # on ne distinguera pas le 'modifié' du 'Nouveau' !
              Gosub MWI_MAT
              # erreur en retour "erreur à la mise à jour des encours d'OF (WIPCOST)
              If ERR
                GMESSAGE = mess(20,2363,1)
                Break
              Endif
            Endif
        Next
        If ERR : End : Endif
    When 3
        If !clalev([F:SCI]) : End : Endif
        Raz [F:SCI]
        If [M:STW]VCRTYPORI=14 & [M:STW]VCRNUMORI<>"" & [M:STW]VCRNUMORI<>[F:POQ]POHNUM
           Read [POQ] POQ0=[M:STW]VCRNUMORI;[M:STW]VCRLINORI;[M:STW]VCRSEQORI
           If fstat  Raz [F:POQ] : Endif
           If [F:POQ]VCRTYPORI=36 & [F:POQ]VCRNUMORI<>""
              Read [F:SCI]SCI0=[F:POQ]VCRNUMORI;[F:POQ]VCRLINORI
           Endif
        Elsif [M:STW]VCRTYPORI=36 & [M:STW]VCRNUMORI<>"" & [M:STW]VCRNUMORI<>[F:SCI]SCONUM
           Read [F:SCI]SCI0=[M:STW]VCRNUMORI;[M:STW]VCRLINORI
        Endif
        If [F:SCI]SCONUM="" : End : Endif # Si ce n'est pas une réception de sous-traitance: on sort
        # Réception EO
        Call CRE_MFGWIP([F:SCI]SCONUM,36,0,X_MFGFCY,X_TXNDAT,X_ITMREF,[F:SCI]BOMALT,"",0,"",ERR)
        If ERR | GOK<1 : GMESSAGE -= "\"+mess(23,2363,1) : End : Endif

        ITM_TYP = 1
        CST_FLG = 2

        For LGRP=0 To LNBGRP-1

            Raz X_QTY, X_QTYACT, X_REJQTY, X_AMOUNT
            For I=0 To [M:STW]NBLIG-1
              If LTABGRP(LGRP) = ([M:STW]ECCVALMAJ(I)+" "+[M:STW]ECCVALMIN(I))
                If [M:STW]WAIFLG(I) = 0 & [M:STW]MAJCOD(I) = "A"
                  X_QTY     -= [M:STW]QTYSTU(I)
                  X_QTYACT  -= [M:STW]QTYSTUACT(I)
                  X_INVDTA  += [M:SVW]VINVDTA(I)            # Dans le cas du coût standard c'est égal à 0
                  X_AMOUNT  += [M:SVW]AMTVAL(I)-X_INVDTA
                  X_PRINAT   = [M:SVW]PRINAT(I)   # est à la ligne !!
                  If left$([M:STW]STA(I),1) = "R"
                    X_REJQTY     -= [M:STW]QTYSTU(I)
                  Endif
                  X_ECCMAJ = [M:STW]ECCVALMAJ(I)
                  X_ECCMIN = [M:STW]ECCVALMIN(I)
                Endif
              Endif
            Next

            If X_QTY <> 0
              Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ) # par / à MWH précédemment lu ou créé
              # créer un enreg de type "Supprimé"
              X_TXNACT = 3
              Gosub MWI_PROD
              # erreur en retour "erreur à la mise à jour des encours d'OF (WIPCOST)
              If ERR
                GMESSAGE = mess(24,2363,1)
                Break
              Endif
            Endif

            Raz X_QTY, X_QTYACT, X_REJQTY, X_AMOUNT
            For I=0 To [M:STW]NBLIG-1
              If LTABGRP(LGRP) = ([M:STW]ECCVALMAJ(I)+" "+[M:STW]ECCVALMIN(I))
                If [M:STW]WAIFLG(I) = 0 & [M:STW]MAJCOD(I) = "C"
                  X_QTY     += [M:STW]QTYSTU(I) # dans STW la qté n'est pas signée !!
                  X_QTYACT  += [M:STW]QTYSTUACT(I)
                  X_INVDTA  += [M:SVW]OINVDTA(I) * -1   # Issue 85549 - 2012-11-07 by CCC : ajout *(-1)
                  X_AMOUNT  += ([M:SVW]AMTVAL(I)* (-1)) -X_INVDTA    # NEGATIF par rapport au suivi de l'encours !
                  X_PRINAT   = [M:SVW]PRINAT(I)
                  If left$([M:STW]STA(I),1) = "R"
                    X_REJQTY     += [M:STW]QTYSTU(I)
                  Endif
                  X_ECCMAJ = [M:STW]ECCVALMAJ(I)
                  X_ECCMIN = [M:STW]ECCVALMIN(I)
                Endif
              Endif
            Next
            If X_QTY <> 0
              # créer un enreg de type "Nouveau"
              Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)
              X_TXNACT = 1  # on ne distinguera pas le 'modifié' du 'Nouveau'(à moins que du 'A'+ du 'C' signifie 'Modifié'???)
              Gosub MWI_PROD
              # erreur en retour "erreur à la mise à jour des encours d'EO (WIPCOST)
              If ERR
                GMESSAGE = mess(24,2363,1)
                Break
              Endif
            Endif
        Next
        If ERR : End : Endif
    When 29
        # sortie matière EO
        If [F:SCI]SCONUM<>[M:STW]VCRNUMORI | [F:SCI]SCILIN<>[M:STW]VCRLINORI
          Read [SCI]SCI0=[M:STW]VCRNUMORI;[M:STW]VCRLINORI
          If fstat
            Call FSTA("SCI") From GLOCK
            ERR = 1
            End
          Endif
        Endif

        Call CRE_MFGWIP([F:SCI]SCONUM,36,0,X_MFGFCY,X_TXNDAT,"",[F:SCI]BOMALT,"",0,"",ERR)
        # erreur de création entête valorisation encours d'EO (MFGWIP)
        If ERR | GOK<1 : GMESSAGE -= "\"+mess(17,2363,1) : End : Endif

        If [F:MWH]MATLEVFLG = 2
            LMATFLG = func SUBCSTB.ISMAT([M:STW]ITMREF, 3, [F:SCI]BOMALT, [M:STW]IPTDAT)
        Endif

        For LGRP=0 To LNBGRP-1

            Raz X_QTY, X_QTYACT, X_AMOUNT
            # 1ère boucle sur l'écran pour mvt annulés
            For I=0 To [M:STW]NBLIG-1
              If LTABGRP(LGRP) = ([M:STW]ECCVALMAJ(I)+" "+[M:STW]ECCVALMIN(I))
                If [M:STW]WAIFLG(I) = 0 & [M:STW]MAJCOD(I) = "A"
                  X_QTY     -= [M:STW]QTYSTU(I)
                  X_QTYACT  -= [M:STW]QTYSTUACT(I)
                  X_AMOUNT  += [M:SVW]AMTVAL(I) * -1
                  X_PRINAT   = [M:SVW]PRINAT(I)
                  X_ECCMAJ = [M:STW]ECCVALMAJ(I)
                  X_ECCMIN = [M:STW]ECCVALMIN(I)
                Endif
              Endif
            Next

            If X_QTY <> 0
              # créer un enreg de type "Supprimé"
              Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)
              X_TXNACT = 3
              Gosub MWI_MAT
              # erreur en retour "erreur à la mise à jour des encours d'EO (WIPCOST)
              If ERR
                GMESSAGE = mess(24,2363,1)
                Break
              Endif
            Endif

            Raz X_QTY, X_QTYACT, X_AMOUNT
            # 2ème boucle sur l'écran pour mvt créés
            For I=0 To [M:STW]NBLIG-1
              If LTABGRP(LGRP) = ([M:STW]ECCVALMAJ(I)+" "+[M:STW]ECCVALMIN(I))
                If [M:STW]WAIFLG(I) = 0 & [M:STW]MAJCOD(I) = "C"
                  X_QTY     += [M:STW]QTYSTU(I) # dans STW la qté n'est pas signée !!
                  X_QTYACT  += [M:STW]QTYSTUACT(I)
                  X_AMOUNT  += [M:SVW]AMTVAL(I)
                  X_PRINAT   = [M:SVW]PRINAT(I)
                  X_ECCMAJ = [M:STW]ECCVALMAJ(I)
                  X_ECCMIN = [M:STW]ECCVALMIN(I)
                Endif
              Endif
            Next
            # faire ici les autres choix de valorisation matière (?): cela désynchroniserait WIP et stock !
            If X_QTY <> 0
              # créer un enreg de type "Nouveau"
              Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)
              X_TXNACT = 1  # on ne distinguera pas le 'modifié' du 'Nouveau' !
              Gosub MWI_MAT
              # erreur en retour "erreur à la mise à jour des encours d'EO (WIPCOST)
              If ERR
                GMESSAGE = mess(24,2363,1)
                Break
              Endif
            Endif
        Next
        If ERR : End : Endif
Endcase

End

$MWI_PROD
# Perform mapping
Raz [F:MWI]

Case [M:STW]TRSTYP
    When 5,6,19 :
        [F:MWI]          = [F:MKI]
        [F:MWI]VCRLIN    = [F:MKI]MFGLIN
        [F:MWI]MFGTRKLIN = [F:MKI]ITMTRKLIN
        [F:MWI]MTSNUM    = [F:MTS]MTSNUM
        [F:MWI]ENTCOD    = GACCWIPENT    # param général ACCWIPENT = code pièce auto

    When 3,29 :
        [F:MWI]          = [F:SCI]
        [F:MWI]VCRLIN    = [F:SCI]SCILIN
        [F:MWI]MFGTRKNUM = [M:STW]VCRNUM
        [F:MWI]MFGTRKLIN = [M:STW]VCRLIN
        [F:MWI]MTSNUM    = [F:PTR]PTRNUM
        [F:MWI]ENTCOD    = GACCWIPEOA    # param général ACCWIPEOA = code pièce auto

Endcase

[F:MWI]VCRTYP    = [F:MWH]VCRTYP
[F:MWI]VCRNUM    = [F:MWH]VCRNUM

[F:MWI]ITMTYP    = ITM_TYP
[F:MWI]MATGRP    = [F:ITM]BRDCOD


[F:MWI]TXNDAT    = [M:STW]IPTDAT
[F:MWI]MFGFCY    = [M:STW]STOFCY
[F:MWI]ITMREF    = [M:STW]ITMREF
[F:MWI]ECCVALMAJ = X_ECCMAJ
[F:MWI]ECCVALMIN = X_ECCMIN
[F:MWI]STU       = [M:STW]STU

[F:MWI]PRINAT    = X_PRINAT
[F:MWI]QTY       = X_QTY
[F:MWI]QTYACT    = X_QTYACT
[F:MWI]REJQTY    = X_REJQTY

[F:MWI]WIPSEQ    = LAST_SEQ + 1
[F:MWI]TXNTYP    = 14
[F:MWI]TXNACT    = X_TXNACT
[F:MWI]OPENUM    = 0

If ITM_TYP = 1 | CST_FLG = 2   # on valorise le (sous-)produit (!! sinon même l'interface ne passera rien!)
    If [F:MWI]PRINAT <> 8
      Gosub COST_ELEMENTS
    Else
      Gosub CPP_ELEMENTS  # cas de valorisation au prix de l'ordre
    Endif

    X_AMOUNT += X_INVDTA

    [F:MWI]AMOUNT      = arr(X_AMOUNT,L_CURRND)
    If [F:MWI]QTY <> 0
      [F:MWI]UNTCST    = arr(abs([F:MWI]AMOUNT/[F:MWI]QTY),L_CURRND)
    Else
      [F:MWI]UNTCST    = abs([F:MWI]AMOUNT)
    Endif

    #il faut les FG dans le mnt tot du 14 [F:MWI]AMOUNT = abs(sum( [F:MWI]CSTELM(0..3) ))*sgn(X_AMOUNT)    # Montant hors FG mono-niveau
    LBASAMT       = abs(sum( [F:MWI]CSTELM(8..11) ))*sgn(X_AMOUNT)    # Montant hors FG multi-niveaux pour calcul des FG

    If LBASAMT=0 : LBASAMT=[F:MWI]AMOUNT-X_INVDTA : Endif

    If ITM_TYP=2 & CST_FLG=2
      Raz [F:MWI]CSTELM
      [F:MWI]CSTELM(0) = [F:MWI]AMOUNT
      # Issue 79932 - 2012-02-07 by CCC : Alimentation des détails de coûts
      #[F:MWI]CSTELM(8) = [F:MWI]AMOUNT
# Issue 80925 - 2012-03-21 by CCC
#      [F:MWI]CSTELM(8)  = abs(arr(sum([M:SVW]VMATCST),L_CURRND))*sgn([F:MWI]AMOUNT)
#      [F:MWI]CSTELM(9)  = abs(arr(sum([M:SVW]VLABCST),L_CURRND))*sgn([F:MWI]AMOUNT)
#      [F:MWI]CSTELM(10) = abs(arr(sum([M:SVW]VMACCST),L_CURRND))*sgn([F:MWI]AMOUNT)
#      [F:MWI]CSTELM(11) = abs(arr(sum([M:SVW]VSCOTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
#      [F:MWI]CSTELM(12) = abs(arr(sum([M:SVW]VOVEMATTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
#      [F:MWI]CSTELM(13) = abs(arr(sum([M:SVW]VOVELABTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
#      [F:MWI]CSTELM(14) = abs(arr(sum([M:SVW]VOVEMACTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
#      [F:MWI]CSTELM(15) = abs(arr(sum([M:SVW]VOVESCOTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
#      [F:MWI]CSTELM(16) = abs(arr(sum([M:SVW]VINVDTA),L_CURRND))*sgn([F:MWI]AMOUNT)
#      [F:MWI]CSTELM(8) += [F:MWI]AMOUNT-sum([F:MWI]CSTELM(8..16))

      Case X_TXNACT
          When 1: LMAJCOD="C"
          When 3: LMAJCOD="A"
      Endcase

      Local Decimal LTOT, LMAX, LTMP
      Local Char LZON(100)
      LTOT = 0
      LMAX = 0
      LZON = "[F:MWI]MATCST(max(1,[F:ITM]BRDCOD)-1)"
      For I=0 To GACTMAT-1
          # Issue 80925 - 2012-03-21 by CCC
          #LTMP = abs(arr(sigma(0,[M:SVW]NBLIG-1,[M:SVW]VMATCST(indcum*GACTMAT+I)),L_CURRND))*sgn([F:MWI]AMOUNT)
          LTMP = abs(arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                              *([M:SVW]VMATCST(indcum*GACTMAT+I))
&                                       ),L_CURRND))*sgn([F:MWI]AMOUNT)
          [F:MWI]MATCST(I) = LTMP
          LTOT += LTMP
          If abs(LTMP)>LMAX
                LZON = "[F:MWI]MATCST("+num$(I)+")"
                LMAX = abs(LTMP)
          Endif
      Next

      For I=0 To GACTMAC-1
          # Issue 80925 - 2012-03-21 by CCC
          #LTMP = abs(arr(sigma(0,[M:SVW]NBLIG-1,[M:SVW]VMACCST(indcum*GACTMAC+I)),L_CURRND))*sgn([F:MWI]AMOUNT)
          LTMP = abs(arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                              *([M:SVW]VMACCST(indcum*GACTMAC+I))
&                                       ),L_CURRND))*sgn([F:MWI]AMOUNT)
          [F:MWI]MACCST(I) = LTMP
          LTOT += LTMP
          If abs(LTMP)>LMAX
                LZON = "[F:MWI]MACCST("+num$(I)+")"
                LMAX = abs(LTMP)
          Endif
      Next

      For I=0 To GACTLAB-1
          # Issue 80925 - 2012-03-21 by CCC
          #LTMP = abs(arr(sigma(0,[M:SVW]NBLIG-1,[M:SVW]VLABCST(indcum*GACTLAB+I)),L_CURRND))*sgn([F:MWI]AMOUNT)
          LTMP = abs(arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                              *([M:SVW]VLABCST(indcum*GACTLAB+I))
&                                       ),L_CURRND))*sgn([F:MWI]AMOUNT)
          [F:MWI]LABCST(I) = LTMP
          LTOT += LTMP
          If abs(LTMP)>LMAX
                LZON = "[F:MWI]LABCST("+num$(I)+")"
                LMAX = abs(LTMP)
          Endif
      Next

      # Issue 80925 - 2012-03-21 by CCC
      #LTMP = abs(arr(sum([M:SVW]VSCOTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
      LTMP    = abs(arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                             *([M:SVW]VSCOTOT(indcum))),L_CURRND))*sgn([F:MWI]AMOUNT)
      [F:MWI]SCOCST    = LTMP
      LTOT += LTMP
      If abs(LTMP)>LMAX
            LZON = "[F:MWI]SCOCST"
            LMAX = abs(LTMP)
      Endif

      # Issue 80925 - 2012-03-21 by CCC
      #LTMP = abs(arr(sum([M:SVW]VINVDTA),L_CURRND))*sgn([F:MWI]AMOUNT)
      LTMP = abs(arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                          *([M:SVW]VINVDTA(indcum))),L_CURRND))*sgn([F:MWI]AMOUNT)
      [F:MWI]INVDTACST = LTMP
      LTOT += LTMP
      If abs(LTMP)>LMAX
            LZON = "[F:MWI]INVDTACST"
            LMAX = abs(LTMP)
      Endif

      # Issue 85669 - 2012-11-16 by CCC : Annulation FG pour les sous-produits
      If ITM_TYP<>2
          # Issue 80925 - 2012-03-21 by CCC
          #LTMP = abs(arr(sum([M:SVW]VOVEMATTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
          LTMP = abs(arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                          *([M:SVW]VOVEMATTOT(indcum))),L_CURRND))*sgn([F:MWI]AMOUNT)
          [F:MWI]OVEMATCST = LTMP
          LTOT += LTMP
          If abs(LTMP)>LMAX
                LZON = "[F:MWI]OVEMATCST"
                LMAX = abs(LTMP)
          Endif

          # Issue 80925 - 2012-03-21 by CCC
          #LTMP = abs(arr(sum([M:SVW]VOVEMACTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
          LTMP = abs(arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                          *([M:SVW]VOVEMACTOT(indcum))),L_CURRND))*sgn([F:MWI]AMOUNT)
          [F:MWI]OVEMACCST = LTMP
          LTOT += LTMP
          If abs(LTMP)>LMAX
                LZON = "[F:MWI]OVEMACCST"
                LMAX = abs(LTMP)
          Endif

          # Issue 80925 - 2012-03-21 by CCC
          #LTMP = abs(arr(sum([M:SVW]VOVELABTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
          LTMP = abs(arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                          *([M:SVW]VOVELABTOT(indcum))),L_CURRND))*sgn([F:MWI]AMOUNT)
          [F:MWI]OVELABCST = LTMP
          LTOT += LTMP
          If abs(LTMP)>LMAX
                LZON = "[F:MWI]OVELABCST"
                LMAX = abs(LTMP)
          Endif

          # Issue 80925 - 2012-03-21 by CCC
          #LTMP = abs(arr(sum([M:SVW]VOVESCOTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
          LTMP = abs(arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                          *([M:SVW]VOVESCOTOT(indcum))),L_CURRND))*sgn([F:MWI]AMOUNT)
          [F:MWI]OVESCOCST = LTMP
          LTOT += LTMP
          If abs(LTMP)>LMAX
                LZON = "[F:MWI]OVESCOCST"
                LMAX = abs(LTMP)
          Endif
      Endif
      Assign LZON With evalue(LZON) + [F:MWI]AMOUNT-LTOT

      [F:MWI]CSTELM(8)  = sum([F:MWI]MATCST)
      [F:MWI]CSTELM(9)  = sum([F:MWI]LABCST)
      [F:MWI]CSTELM(10) = sum([F:MWI]MACCST)
      [F:MWI]CSTELM(11) = [F:MWI]SCOCST
      [F:MWI]CSTELM(16) = [F:MWI]INVDTACST
      [F:MWI]CSTELM(12) = [F:MWI]OVEMATCST
      [F:MWI]CSTELM(13) = [F:MWI]OVELABCST
      [F:MWI]CSTELM(14) = [F:MWI]OVEMACCST
      [F:MWI]CSTELM(15) = [F:MWI]OVESCOCST
    Endif
Endif

[F:MWI]GLPSTA    = 1

# Write record only if there is a qty or amount value
If [F:MWI]QTY = 0 & [F:MWI]AMOUNT = 0
    Raz [F:MWI]
Else
    Call ECR_MWI
    If fstat  | GOK=0
        If fstat
            Call FSTA("MWI") From GLOCK
        Endif
        ERR = 1
        Return
    Endif

    Read [ITF]ITF0 = [F:MWI]ITMREF;[F:MWI]MFGFCY
    If fstat
        Call FSTA("ITF") From GLOCK
        ERR = 1
    Else
        # Issue 114047 - 2016-03-07 by CCC : Distinguish WO & EO entries
        If [F:MWI]VCRTYP=36
            Call LECOVE([F:MWI]ITMREF,[F:MWI]MFGFCY,3,ERR) From STKVAL
        Else
            Call LECOVE([F:MWI]ITMREF,[F:MWI]MFGFCY,5,ERR) From STKVAL
        Endif
        If !ERR
            If [F:OVE]CLCLEV = 1 | ITM_TYP=2 & CST_FLG=2
               # dans le cas de suppression faut-il annuler les enreg de frais plutôt que les recalculer?
               # mais quoi annuler car la qté à annuler <> Qt du wipcost d'origine (modif partielle !)
               Call MAT_OH([F:OVE]OVECOD,1,LBASAMT,ERR)
            Endif
        Elsif ERR=1
            Raz ERR    # Le fait qu'il n'y ai pas de FG n'est pas une erreur
        Endif
    Endif
Endif

Return


$MWI_MAT
# Perform mapping
Raz [F:MWI]
Local Decimal LVALREP(max(8,GACTMAT+GACTMAC+GACTLAB+1+1+4))
Raz LVALREP

Case [M:STW]TRSTYP
    When 5,6,19 :
        [F:MWI] = [F:MKM]
        # Issue 88707 - 2013-03-25 by CCC : Si cumul au suivi,
        #[F:MWI]VCRLIN    = [F:MKM]MFGLIN
        [F:MWI]VCRLIN    = [M:STW]VCRLINORI
        [F:MWI]MFGTRKLIN = [F:MKM]MATTRKLIN
        [F:MWI]MTSNUM    = [F:MTS]MTSNUM     # pas en ligne depuis les réguls de mvt attente !!
        [F:MWI]ENTCOD    = GACCWIPENT

    When 3,29 :
        [F:MWI]          = [F:PTD]           # Ligne rcp article sous-traité
        [F:MWI]VCRLIN    = [M:STW]VCRLINORI
        [F:MWI]BOMSEQ    = [F:SCM]SCMLIN     # ou [F:SCM]BOMSEQ ?
        [F:MWI]MFGTRKNUM = [M:STW]VCRNUM
        [F:MWI]MFGTRKLIN = [M:STW]VCRLIN
        [F:MWI]SCOFLG    = [F:SCM]SCOFLG
        [F:MWI]MTSNUM    = [F:PTR]PTRNUM
        [F:MWI]ENTCOD    = GACCWIPEOA    # param général ACCWIPEOA = code pièce auto
Endcase

[F:MWI]VCRTYP    = [F:MWH]VCRTYP
[F:MWI]VCRNUM    = [F:MWH]VCRNUM
[F:MWI]MATGRP    = [F:ITM]BRDCOD

[F:MWI]TXNDAT    = X_TXNDAT
[F:MWI]MFGFCY    = X_MFGFCY
[F:MWI]ITMREF    = X_ITMREF
[F:MWI]ECCVALMAJ = X_ECCMAJ
[F:MWI]ECCVALMIN = X_ECCMIN
[F:MWI]STU       = X_STU
[F:MWI]PRINAT    = X_PRINAT
[F:MWI]QTY       = X_QTY
[F:MWI]QTYACT    = X_QTYACT
[F:MWI]AMOUNT    = arr(X_AMOUNT,L_CURRND)
[F:MWI]UNTCST    = arr([F:MWI]AMOUNT/[F:MWI]QTY,L_CURRND) : # Qty will never be 0 at this point

[F:MWI]CSTELM(0) = [F:MWI]AMOUNT
[F:MWI]CSTELM(8) = [F:MWI]AMOUNT
LBASAMT = [F:MWI]AMOUNT

#---- Si la valo est le coût standard, on peut détailler le coût mono-niveau ----#
If find([F:MWI]PRINAT,2,3)
    Filter [ITC] Where STOFCY = [F:MWI]MFGFCY
&                    & ITMREF = [F:MWI]ITMREF
&                    & CSTTYP = [F:MWI]PRINAT-1
&                    & ITCSTRDAT<=[M:STW]IPTDAT
&                    & ITCENDDAT>=[M:STW]IPTDAT
&                    & UID = 0
    Read [ITC]ITC0 First
    Filter [ITC]
    If !fstat
        Gosub ITEM_COSTS # décompose en coûts du niveau >>!!ATTENTION pas comme dans SUBMCC (cout prévisionnel)!!

        # Issue 81304 - 2012-06-07 by CCC : suppression du forçage de signe
        ## Issue 80252 - 2012-02-22 by CCC : ajout de "abs"
        Raz LVALREP
        LVALREP(0) = MATTOT
        LVALREP(1) = LABTOT
        LVALREP(2) = MACTOT
        LVALREP(3) = SCOTOT
        LVALREP(4) = OVEMATTOT
        LVALREP(5) = OVELABTOT
        LVALREP(6) = OVEMACTOT
        LVALREP(7) = OVESCOTOT
        Call REPVAL([F:MWI]AMOUNT, LVALREP(0..7), L_CURRND, [F:MWI]CSTELM(0..7)) From STKVALECR

        # Si décomposition multi-niveaux est gérée,
        # on se base sur le masque STOVALWORK (quelque soit la méthode de valo)
        # sinon on prend les valeur de ITMCOST pour les valo au standard
#        If [F:ITC]VLTTOT<>0    # CCC (25/07/05) Bug 31349: division par 0
#            [F:MWI]CSTELM(8)  = arr(([F:MWI]AMOUNT * [F:ITC]MATTOT) / [F:ITC]VLTTOT,L_CURRND)
#            [F:MWI]CSTELM(9)  = arr(([F:MWI]AMOUNT * [F:ITC]LABTOT) / [F:ITC]VLTTOT,L_CURRND)
#            [F:MWI]CSTELM(10) = arr(([F:MWI]AMOUNT * [F:ITC]MACTOT) / [F:ITC]VLTTOT,L_CURRND)
#            [F:MWI]CSTELM(11) = arr(([F:MWI]AMOUNT * [F:ITC]SCOTOT) / [F:ITC]VLTTOT,L_CURRND)
#            [F:MWI]CSTELM(12) = arr(([F:MWI]AMOUNT * [F:ITC]OVEMATCST) / [F:ITC]VLTTOT,L_CURRND)
#            [F:MWI]CSTELM(13) = arr(([F:MWI]AMOUNT * [F:ITC]OVELABCST) / [F:ITC]VLTTOT,L_CURRND)
#            [F:MWI]CSTELM(14) = arr(([F:MWI]AMOUNT * [F:ITC]OVEMACCST) / [F:ITC]VLTTOT,L_CURRND)
#            [F:MWI]CSTELM(15) = arr(([F:MWI]AMOUNT * [F:ITC]OVESCOCST) / [F:ITC]VLTTOT,L_CURRND)
        Raz LVALREP
        LVALREP(0) = [F:ITC]MATTOT
        LVALREP(1) = [F:ITC]LABTOT
        LVALREP(2) = [F:ITC]MACTOT
        LVALREP(3) = [F:ITC]SCOTOT
        LVALREP(4) = [F:ITC]OVEMATCST
        LVALREP(5) = [F:ITC]OVELABCST
        LVALREP(6) = [F:ITC]OVEMACCST
        LVALREP(7) = [F:ITC]OVESCOCST
        Call REPVAL([F:MWI]AMOUNT, LVALREP(0..7), L_CURRND, [F:MWI]CSTELM(8..15)) From STKVALECR
        LBASAMT = sum([F:MWI]CSTELM(8..11))
    Endif
Endif
If GACTDECCST & !([F:MWI]VCRTYP=36 & [F:SCM]SCOFLG=3)   # Détail coût multi-niveaux

# Issue 80925 - 2012-03-21 by CCC
#    [F:MWI]CSTELM(8)  = abs(arr(sum([M:SVW]VMATCST),L_CURRND))*sgn([F:MWI]AMOUNT)
#    [F:MWI]CSTELM(9)  = abs(arr(sum([M:SVW]VLABCST),L_CURRND))*sgn([F:MWI]AMOUNT)
#    [F:MWI]CSTELM(10) = abs(arr(sum([M:SVW]VMACCST),L_CURRND))*sgn([F:MWI]AMOUNT)
#    [F:MWI]CSTELM(11) = abs(arr(sum([M:SVW]VSCOTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
#    [F:MWI]CSTELM(12) = abs(arr(sum([M:SVW]VOVEMATTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
#    [F:MWI]CSTELM(13) = abs(arr(sum([M:SVW]VOVELABTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
#    [F:MWI]CSTELM(14) = abs(arr(sum([M:SVW]VOVEMACTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
#    [F:MWI]CSTELM(15) = abs(arr(sum([M:SVW]VOVESCOTOT),L_CURRND))*sgn([F:MWI]AMOUNT)
#    [F:MWI]CSTELM(16) = abs(arr(sum([M:SVW]VINVDTA),L_CURRND))*sgn([F:MWI]AMOUNT)

    Case X_TXNACT
        When 1: LMAJCOD="C"
        When 3: LMAJCOD="A"
    Endcase

    # Issue 80925 - 2012-03-21 by CCC : prise en compte de MAJCOD
    J=0
    For I=0 To GACTMAT-1
        LVALREP(J) = arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                              *([M:SVW]VMATCST(indcum*GACTMAT+I))
&                       ),L_CURRND)
        J+=1
    Next

    For I=0 To GACTMAC-1
        LVALREP(J) = arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                              *([M:SVW]VMACCST(indcum*GACTMAC+I))
&                       ),L_CURRND)
        J+=1
    Next

    For I=0 To GACTLAB-1
        LVALREP(J) = arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                              *([M:SVW]VLABCST(indcum*GACTLAB+I))
&                       ),L_CURRND)
        J+=1
    Next

    LVALREP(J)    = arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                             *([M:SVW]VSCOTOT(indcum))),L_CURRND)
    J+=1

    LVALREP(J) = arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                          *([M:SVW]VINVDTA(indcum))),L_CURRND)
    J+=1

    LVALREP(J) = arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                                    *([M:SVW]VOVEMATTOT(indcum))),L_CURRND)
    J+=1
    LVALREP(J) = arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                                    *([M:SVW]VOVEMACTOT(indcum))),L_CURRND)
    J+=1
    LVALREP(J) = arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                                    *([M:SVW]VOVELABTOT(indcum))),L_CURRND)
    J+=1
    LVALREP(J) = arr(sigma(0,[M:SVW]NBLIG-1,([M:STW]MAJCOD(indcum)=LMAJCOD)
&                                                    *([M:SVW]VOVESCOTOT(indcum))),L_CURRND)
    J+=1

    Call REPVAL([F:MWI]AMOUNT, LVALREP, L_CURRND, LVALREP) From STKVALECR
    J=0
    For I=0 To GACTMAT-1
        [F:MWI]MATCST(I) = LVALREP(J)
        J+=1
    Next
    # Issue 90406 - 2013-06-12 by CCC : Inversion de l'ordre MAC et LAB pour correspondre à celui au-dessus
    For I=0 To GACTMAC-1
        [F:MWI]MACCST(I) = LVALREP(J)
        J+=1
    Next
    For I=0 To GACTLAB-1
        [F:MWI]LABCST(I) = LVALREP(J)
        J+=1
    Next
    [F:MWI]SCOCST     = LVALREP(J)
    J+=1
    [F:MWI]INVDTACST  = LVALREP(J)
    J+=1
    [F:MWI]OVEMATCST  = LVALREP(J)
    # Issue 90406 - 2013-06-12 by CCC : Inversion de l'ordre MAC et LAB pour correspondre à celui au-dessus
    J+=1
    [F:MWI]OVEMACCST  = LVALREP(J)
    J+=1
    [F:MWI]OVELABCST  = LVALREP(J)
    J+=1
    [F:MWI]OVESCOCST  = LVALREP(J)
    J+=1

    [F:MWI]CSTELM(8)  = sum([F:MWI]MATCST)
    [F:MWI]CSTELM(9)  = sum([F:MWI]LABCST)
    [F:MWI]CSTELM(10) = sum([F:MWI]MACCST)
    [F:MWI]CSTELM(11) = [F:MWI]SCOCST
    [F:MWI]CSTELM(12) = [F:MWI]OVEMATCST
    [F:MWI]CSTELM(13) = [F:MWI]OVELABCST
    [F:MWI]CSTELM(14) = [F:MWI]OVEMACCST
    [F:MWI]CSTELM(15) = [F:MWI]OVESCOCST
    [F:MWI]CSTELM(16) = [F:MWI]INVDTACST

    LBASAMT = sum([F:MWI]CSTELM(8..11))
Else
    If [F:ITM]ITMREF <> [F:MWI]ITMREF
        Read [F:ITM]ITM0=[F:MWI]ITMREF
    Endif
    [F:MWI]MATCST(max(0,[F:ITM]BRDCOD-1)) = [F:MWI]AMOUNT
Endif

If LMATFLG
    [F:MWI]MATLEV0 = sum([F:MWI]MATCST)
Endif

[F:MWI]WIPSEQ    = LAST_SEQ + 1
[F:MWI]TXNTYP    = 1
[F:MWI]TXNACT    = X_TXNACT     # depuis MAJ_WIPCOST ; 1 'nouveau' 3 : 'Suppr'

[F:MWI]GLPSTA    = 1


# Write record only if there is a qty or amount value
If [F:MWI]QTY = 0 & [F:MWI]AMOUNT = 0
    Raz [F:MWI]
Else
    Call ECR_MWI
    If fstat | GOK=0
        If fstat
            Call FSTA("MWI") From GLOCK
        Endif
        ERR = 1
        Return
    Endif

    If [F:MWI]SCOFLG<>3    # Si c'est une matière fournie par le sous-traitant on n'a pas de FG à calculer
        Read [ITF]ITF0 = [F:MWI]ITMREF;[F:MWI]MFGFCY # oter car déplacé plus haut
        If fstat
            Call FSTA("ITF") From GLOCK
            ERR = 1
            Return
        Else
            # Issue 114047 - 2016-03-07 by CCC : Distinguish WO & EO issues
            If [F:MWI]VCRTYP=36
                Call LECOVE([F:MWI]ITMREF,[F:MWI]MFGFCY,29,ERR) From STKVAL
            Else
                Call LECOVE([F:MWI]ITMREF,[F:MWI]MFGFCY,6,ERR) From STKVAL
            Endif
            If !ERR
                If [F:OVE]CLCLEV = 2             # frais en sortie (répond à la dem 19034)
                   Call MAT_OH([F:OVE]OVECOD,2,LBASAMT,ERR)
                   If ERR = 1 : Return : Endif
                Endif
            Elsif ERR=1
                Raz ERR    # Le fait qu'il n'y ai pas de FG n'est pas une erreur
            Endif
        Endif
    Endif
Endif
Return

# Sous-pro des frais généraux matière ou produit
###########################################################################
Subprog MAT_OH(L_OVECOD,L_TYP,BASAMT,ERR)
Value    Char       L_OVECOD
Value    Integer    L_TYP    # Frais de Matière (2) ou de produit(1)
Value    Decimal    BASAMT
Variable Integer    ERR

Local Integer    LAST_SEQ
Local Decimal    L_CURRND
Local Char       SAV_VCRNUM(GLONVCR)
Local Integer    SAV_VCRTYP,SAV_WIPSEQ, SAV_TXNTYP
Local Decimal    BAS_AMT
Local Integer    LTIAFXD

# Initialize values and open needed tables
ERR = 0

If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif

# (ce sous-pro est appelé après écriture de la dépense matière ou de l'entrée produit)
# Store current record's key values for lookup again after verify sequence number
SAV_VCRNUM = [F:MWI]VCRNUM
SAV_VCRTYP = [F:MWI]VCRTYP
SAV_WIPSEQ = [F:MWI]WIPSEQ
SAV_TXNTYP = [F:MWI]TXNTYP

Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)

Call GET_CUR_RND([F:FCY]LEGCPY, L_CURRND, ERR)
# "erreur de lecture sur devise ; société juridique"
If ERR = 1
  GMESSAGE = mess(10,2363,1)-[F:FCY]LEGCPY
  End
Endif

# Perform mapping - Everything is the same as the material/production expense record
# except amount, 2 overhead fields, trans. type, and WIP seq # >> vider les CSTELM ???
Read [MWI]MWI5 = SAV_VCRTYP;SAV_VCRNUM;SAV_WIPSEQ;SAV_TXNTYP
If fstat : ERR = 1 : End : Endif

# inverser ici la base de calcul dans le cas des entrées

If [F:MWI]TXNTYP=14
## CCC (12/10/04) Bug 24941 : AMOUNT contient déjà le montant des FG
##  BAS_AMT = [F:MWI]AMOUNT * -1 # les frais s'ajoutent pour l'entrée en stock
##                               # ils sont <0 en cas de suppression de mouvement
#    BAS_AMT = func CALBAS(L_CURRND, L_OVECOD, [F:MWI]AMOUNT * -1)
#  BAS_AMT = [F:MWI]AMOUNT * -1 # les frais s'ajoutent pour l'entrée en stock
    BAS_AMT = -BASAMT
Else
#  BAS_AMT = [F:MWI]AMOUNT
    BAS_AMT = BASAMT
Endif

# changer les zones du buffer pour en faire un enreg de frais généraux
[F:MWI]TXNTYP    = 5
[F:MWI]MATOVETYP = L_TYP
[F:MWI]WIPSEQ    = LAST_SEQ  # > incrémenter dans le sous-pro

Raz LTIAFXD
Raz GPE
GPOINT = "MATOH"
Gosub ENTREE From EXEFNC
If GPE=0
    Call CAL_OH(L_CURRND,L_OVECOD,[F:MWI]QTY,BAS_AMT,0,ERR)
    # l'écriture se fait dans le sous-pro pour chaque nature
Endif

End
###########################################################################

Subprog OPETRK_NEW(ERR)
Variable Integer    ERR
# Initialize values and open needed tables
Local Integer TIA_FXD # indicateur pour éviter de passer x fois les fixes
                      # déclaré ici pour passer du sous-pro OPE au sous-pro des FG
ERR = 0

If !clalev([F:MWH]) : Local File MFGWIP     [MWH] : Endif
If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif
If !clalev([F:MWIS]): Local File WIPCOST    [MWIS]: Endif     # Issue 79062 - 2012-02-06 by CCC
If !clalev([F:MWS]) : Local File WORKSTATIO [MWS] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([F:MTS]) : Local File MFGTRS     [MTS] : Endif

If [F:FCY]FCY <> [F:MKO]MFGFCY
  Read [FCY]FCY0=[F:MKO]MFGFCY # lu qu'une fois éventuellement
Endif

Call CRE_MFGWIP([F:MKO]MFGNUM,10*([F:MKO]TIMTYP=1),[F:MKO]TIMTYP,[F:MKO]MFGFCY,[F:MKO]IPTDAT,"",0,[F:MKO]ITMREF,[F:MKO]ROUALT,[F:MKO]CPLWST,ERR)
# attention ici [MKO]ITMREF servira à [MWH]ROUNUM c'est la gamme !
# erreur de création entête valorisation encours d'OF (MFGWIP)
If ERR | GOK<1 : GMESSAGE -= "\"+mess(17,2363,1) : End : Endif

# Determine what type of records needs created - Machine or Labor - based
# off of the work center type
Read [MWS]WST0 = [F:MKO]CPLWST;[F:MKO]MFGFCY
If fstat
  ERR = 1  # "xxxxx poste inexistant sur ce site..."
  GMESSAGE = [F:MKO]CPLWST-":"-mess(133,193,1)-[F:MKO]MFGFCY
  End
Endif

If [F:MWS]WSTTYP = 1    # Machine
    Call MLEOPETRK_NEW(1,1,"C",TIA_FXD,ERR)     # Machine Expense
    If ERR = 1 : End : Endif

    Call MLOOPETRK_NEW(1,TIA_FXD,ERR)           # Machine Overhead
    If ERR = 1 : End : Endif


Elsif [F:MWS]WSTTYP = 2    # Main d'oeuvre
    Call MLEOPETRK_NEW(2,1,"C",TIA_FXD,ERR)     # Labor Expense - Primary
    If ERR = 1 : End : Endif

    Call MLOOPETRK_NEW(2,TIA_FXD,ERR)           # Labor Overhead - Primary
    If ERR = 1 : End : Endif

Endif

# CCC (09/09/05) Bug 32038 : Ce qui suit n'était effectué que dans le cas où le 1er poste était de type machine
    If [F:MKO]CPLLAB <> ""
        Read [MWS]WST0 = [F:MKO]CPLLAB;[F:MKO]MFGFCY
        If fstat
          ERR = 1   # "xxxxx poste inexistant sur ce site..."
          GMESSAGE = [F:MKO]CPLLAB-":"-mess(133,193,1)-[F:MKO]MFGFCY
          End
        Endif
        Raz TIA_FXD
        Call MLEOPETRK_NEW(2,2,"C",TIA_FXD,ERR) # Labor Expense - Secondary
        If ERR = 1 : End : Endif

        Call MLOOPETRK_NEW(2,TIA_FXD,ERR)       # Labor Overhead - Secondary
        If ERR = 1 : End : Endif
    Endif

End

###########################################################################
Subprog MLEOPETRK_NEW(IWSTTYP,IPRIM,CRE_MOD,TIA_FXD,ERR)
Value    Integer    IWSTTYP, IPRIM  # typ 1=machine ; 2=main d'oeuvre
Value    Char       CRE_MOD         # appel en création "C", en modif : "M"
Variable Integer    TIA_FXD         # 1= fixes déjà pris en compte
Variable Integer    ERR

Local Integer    LAST_SEQ, J
Local Decimal    L_CURRND

# Initialize values and open needed tables
ERR = 0

If !clalev([F:MWI2]) : Local File WIPCOST    [MWI2] : Endif # pour recherche

If !clalev([F:MWS]) : Local File WORKSTATIO [MWS] : Endif
If !clalev([F:MWC]) : Local File WORKCOST   [MWC] : Endif
If !clalev([F:TMA]) : Local File TABMAT     [TMA] : Endif

Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)

Call GET_CUR_RND([F:FCY]LEGCPY, L_CURRND, ERR)
# "erreur de lecture sur devise ; société juridique"
If ERR = 1
  GMESSAGE = mess(10,2363,1)-[F:FCY]LEGCPY
  End
Endif

# Perform mapping
Raz [F:MWI]

[F:MWI] = [F:MKO]
[F:MWI]VCRTYP    = [F:MWH]VCRTYP
[F:MWI]VCRNUM    = [F:MWH]VCRNUM
[F:MWI]MFGTRKLIN = [F:MKO]OPETRKLIN
[F:MWI]TXNDAT    = [F:MKO]IPTDAT
[F:MWI]QTY       = [F:MKO]CPLQTY    # en unité d'opération !
[F:MWI]STU       = [F:MKO]OPEUOM
[F:MWI]REJQTY    = [F:MKO]REJCPLQTY

If IPRIM = 1
    [F:MWI]WST   = [F:MKO]CPLWST    # poste de charge principal
Else
    [F:MWI]WST   = [F:MKO]CPLLAB
Endif

[F:MWI]MTSNUM    = [F:MTS]MTSNUM

[F:MWI]ENTCOD    = GACCWIPENT

Read [MWS]WST0 = [F:MWI]WST;[F:MWI]MFGFCY
If fstat
  ERR = 1  # "xxxxx poste inexistant sur ce site..."
  GMESSAGE = [F:MWI]WST-":"-mess(133,193,1)-[F:MWI]MFGFCY
  End
Endif
[F:MWI]VLTCCE    = [F:MWS]VLTCCE

Read [MWC]WCT0 = [F:MWI]VLTCCE;[F:MWI]MFGFCY  # le site avait été oublié dans XWIPLIB (TB)
If fstat
  # pas de section de valorisation pour ce poste !
  # GMESSAGE = mess(153,197,1) - [F:MWS]WST
  ## ERR = 1 : End  # non bloquant ! mettre 0 dans RAT ; quoi dans BRDCOD ??
  Raz [F:MWC]
Endif
[F:MWI]CSTTYP    = [F:MWC]CSTTYP
[F:MWI]OPEGRP    = max(1,[F:MWC]BRDCOD) # au cas où il soit à 0 par le Raz !

# CCC (28/10/04) Bug 26120 : Il manquait les cas 3 et 4
Case GMFCRATCPL
    When 1 :
        [F:MWI]SETRAT    = [F:MWC]STDSETCST
        [F:MWI]OPERAT    = [F:MWC]STDOPECST
    When 2 :
        [F:MWI]SETRAT    = [F:MWC]CUTSETCST
        [F:MWI]OPERAT    = [F:MWC]CUTOPECST
    When 3 :
        [F:MWI]SETRAT    = [F:MWC]BUDSETCST
        [F:MWI]OPERAT    = [F:MWC]BUDOPECST
    When 4 :
        [F:MWI]SETRAT    = [F:MWC]SIMSETCST
        [F:MWI]OPERAT    = [F:MWC]SIMOPECST
Endcase

If IWSTTYP = 2 & GOPRRATE <> 1
    Read [TMA]TMA0 = [F:MKO]EMPNUM
    # CCC (28/10/04) Bug 26120 : EMPNUM est un entier pas une chaine de caract.
    If GOPRRATE = 2 & ([F:MKO]EMPNUM = 0 | fstat)
        [F:MWI]SETRAT = 0
        [F:MWI]OPERAT = 0
        [F:MWI]CSTTYP = 1      # taux par employé: forcément horaire !
    Elsif GOPRRATE = 2 & !fstat
        [F:MWI]SETRAT = [F:TMA]CHGRAT
        [F:MWI]OPERAT = [F:TMA]CHGRAT
        [F:MWI]CSTTYP = 1
    Elsif GOPRRATE = 3 & !fstat & [F:TMA]CHGRAT > 0
        [F:MWI]SETRAT = [F:TMA]CHGRAT
        [F:MWI]OPERAT = [F:TMA]CHGRAT
        [F:MWI]CSTTYP = 1
    Endif
Endif

If IWSTTYP = 1
    [F:MWI]TXNTYP    = 3
Elsif IWSTTYP = 2
    [F:MWI]TXNTYP    = 2
#    # main d'oeuvre secondaire: charger les CCEx avec LABCCEx (sinon c'est par le transclasse)
#    If IPRIM = 2
#      For J = 1 To GOPTCANA
#        Assign "[F:MWI]CCE"+num$(J) With evalue("[F:MKO]LABCCE"+num$(J))
#      Next
#    Endif
Endif

If IPRIM = 2
    [F:MWI]CPLSETTIM = [F:MWI]CPLSETTIM * [F:MKO]SETLABCOE
    [F:MWI]CPLOPETIM = [F:MWI]CPLOPETIM * [F:MKO]OPELABCOE
Endif

If [F:MKO]TIMUOMCOD = 2
    [F:MWI]CPLSETTIM = func TRTX3.ARRTYP("", "", "TIH", [F:MWI]CPLSETTIM / 60)
    [F:MWI]CPLOPETIM = func TRTX3.ARRTYP("", "", "TIH", [F:MWI]CPLOPETIM / 60)
Endif

If [F:MWI]CSTTYP = 1
    [F:MWI]CSTELM(0)    = arr([F:MWI]CPLSETTIM * [F:MWI]SETRAT, L_CURRND)
    [F:MWI]CSTELM(1)    = arr([F:MWI]CPLOPETIM * [F:MWI]OPERAT, L_CURRND)
Elsif [F:MWI]CSTTYP = 2
  If [F:MWH]TRKTYP = 1 # pour les suivis sur OF
    # Si le taux est fixe, vérifier qu'il n'est pas déjà compté dans un autre WIP  (TB)
    # si c'est le cas mettre les éléments à 0 !
    For [MWI2]MWI3 Where VCRTYP=[F:MWI]VCRTYP & VCRNUM=[F:MWI]VCRNUM & OPENUM=[F:MWI]OPENUM &
&             OPESPLNUM=[F:MWI]OPESPLNUM & TXNTYP=[F:MWI]TXNTYP & VLTCCE=[F:MWI]VLTCCE
      # positionner un indicateur pour éviter de passer x fois les fixes.
      # le test de la section est suffisant (>> attention si poste réalisé a un tx fixe alors que p prévu non ??!)
      If [F:MWI2]TXNACT<3 & [F:MWI2]AMOUNT<>0
       TIA_FXD = 1  # transmettre cela au calcul de FG et courcircuiter les fixes
       Break
      Endif
    Next
  Endif
  If TIA_FXD = 0
      [F:MWI]CSTELM(0)    = [F:MWI]SETRAT
      [F:MWI]CSTELM(1)    = [F:MWI]OPERAT
  Else
      [F:MWI]CSTELM(0)    = 0
      [F:MWI]CSTELM(1)    = 0
  Endif
Endif
[F:MWI]AMOUNT    = [F:MWI]CSTELM(0) + [F:MWI]CSTELM(1)
If GACTDECCST
    If [F:MWI]TXNTYP=2
        [F:MWI]LABCST([F:MWI]OPEGRP-1) = [F:MWI]AMOUNT
    Else
        [F:MWI]MACCST([F:MWI]OPEGRP-1) = [F:MWI]AMOUNT
    Endif
Endif
[F:MWI]WIPSEQ    = LAST_SEQ + 1

If CRE_MOD = "C"
  [F:MWI]TXNACT  = 1
Elsif CRE_MOD = "M"
  [F:MWI]TXNACT  = 2
Endif
[F:MWI]GLPSTA    = 1
[F:MWI]GLPDAT    = [00/00/0000]

# Cas particulier : qté et montant à 0 :
# l'enreg dépense machine ou main d'oeuvre est créé à zéro et considéré comme comptabilisé
# pour attacher un éventuel enreg de frais généraux  (TB)
## (seul un MKO divers (plan de suivi) peut avoir une CPLQTY=0)

If [F:MWI]QTY = 0 & [F:MWI]AMOUNT = 0
    [F:MWI]GLPSTA = 2
    [F:MWI]GLPDAT = date$ # pas de n° de pièce, pas de tunnel possible !
Endif
Call ECR_MWI
If fstat | GOK=0
    If fstat
        Call FSTA("MWI") From GLOCK
    Endif
    ERR = 1
    End
Endif

End

###############################################################################
# création des frais opératoires pour machine main d'oeuvre et sous-traitance
###############################################################################
Subprog MLOOPETRK_NEW(IWSTTYP,TIA_FXD,ERR)
Value    Integer    IWSTTYP
Value    Integer    TIA_FXD  # 1= fixes déjà pris en compte
Variable Integer    ERR

Local Integer    LAST_SEQ
Local Decimal    L_CURRND
Local Char       SAV_VCRNUM(GLONVCR)
Local Integer    SAV_VCRTYP, SAV_WIPSEQ, SAV_TXNTYP

# Initialize values and open needed tables
ERR = 0

If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif
If !clalev([F:MWC]) : Local File WORKCOST   [MWC] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif

# Store current record's key values for lookup again after verify sequence number
SAV_VCRNUM = [F:MWI]VCRNUM
SAV_VCRTYP = [F:MWI]VCRTYP
SAV_WIPSEQ = [F:MWI]WIPSEQ
SAV_TXNTYP = [F:MWI]TXNTYP

Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)

Call GET_CUR_RND([F:FCY]LEGCPY, L_CURRND, ERR)
# "erreur de lecture sur devise ; société juridique"
If ERR = 1
  GMESSAGE = mess(10,2363,1)-[F:FCY]LEGCPY
  End
Endif

# Perform mapping - Everything is the same as the machine expense record
# except amount, 2 overhead fields, trans. type, and WIP seq # > vider les CSTELM ???
Read [MWI]MWI5 = SAV_VCRTYP;SAV_VCRNUM;SAV_WIPSEQ;SAV_TXNTYP
If fstat : ERR = 1 : End : Endif

# In case where machine amount and qty were both 0 these
# 2 field must again be initialized.
[F:MWI]GLPSTA    = 1            : # new Clear posted flag
[F:MWI]GLPDAT    = [00/00/0000] : # new Clear posted date

Read [MWC]WCT0 = [F:MWI]VLTCCE;[F:MWI]MFGFCY
If fstat :
  #ERR = 1 : End  # > tracer le msg
  Raz [F:MWC]
Endif
If [F:MWC]OVECOD = "" : End : Endif    # if there is no overhead code then a WIPCOST
                                       # Overhead record does not need to be created

Case IWSTTYP
 When 1 :    [F:MWI]TXNTYP    = 7
 When 2 :    [F:MWI]TXNTYP    = 6
 When 3 :    [F:MWI]TXNTYP    = 8   # utilisé aussi pour sous-traitance
Endcase

[F:MWI]WIPSEQ    = LAST_SEQ  # sera incrémenté dans le sous-pro

Call CAL_OH(L_CURRND,[F:MWC]OVECOD,[F:MWI]CPLSETTIM+[F:MWI]CPLOPETIM,
&            [F:MWI]AMOUNT,TIA_FXD,ERR)
If ERR = 1 : End : Endif

End

###########################################################################
Subprog OPETRK_MOD(ERR)
Variable Integer    ERR

Local Char    SAV_VCRNUM(GLONVCR)
Local Integer SAV_VCRTYP,SAV_WIPSEQ, SAV_TXNTYP
Local Integer TIA_FXD  # déclaré ici pour passer du sous-pro OPE au sous-pro des FG

ERR = 0

If !clalev([F:MWH]) : Local File MFGWIP     [MWH]  : Endif
If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif
If !clalev([F:MKO]) : Local File MFGOPETRK  [MKO] : Endif
If !clalev([F:MWS]) : Local File WORKSTATIO [MWS] : Endif
If !clalev([F:MTS]) : Local File MFGTRS     [MTS] : Endif

If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If [F:FCY]FCY <> [F:MKO]MFGFCY
  Read [FCY]FCY0=[F:MKO]MFGFCY
Endif

Call CRE_MFGWIP([F:MKO]MFGNUM,10*([F:MKO]TIMTYP=1),[F:MKO]TIMTYP,[F:MKO]MFGFCY,[F:MKO]IPTDAT,"",0,[F:MKO]ITMREF,[F:MKO]ROUALT,[F:MKO]CPLWST,ERR)
# erreur de création entête valorisation encours d'OF (MFGWIP)
If ERR | GOK<1 : GMESSAGE -= "\"+mess(17,2363,1) : End : Endif

# Determine what type of records needs created - Machine or Labor - based
# off of the work center type  ## Sous-traitance : la modif n'est pas possible
Read [MWS]WST0 = [F:MKO]CPLWST;[F:MKO]MFGFCY
If fstat
  ERR = 1  # "xxxxx poste inexistant sur ce site..."
  GMESSAGE = [F:MKO]CPLWST-":"-mess(133,193,1)-[F:MKO]MFGFCY
  End
Endif

If [F:MWS]WSTTYP = 1
    Call MLEOPETRK_DEL(1,1,ERR)                    # Annule l'ancien
    If ERR = 1 : End : Endif
    Call MLEOPETRK_NEW(1,1,"M",TIA_FXD,ERR)        # Machine Expense
    If ERR = 1 : End : Endif

    # Store current record's key values for lookup again after verify sequence number
    SAV_VCRNUM = [F:MWI]VCRNUM  ## implique de ne pas lire d'autre MWI entre les 2 sous-pro !!
    SAV_VCRTYP = [F:MWI]VCRTYP
    SAV_WIPSEQ = [F:MWI]WIPSEQ
    SAV_TXNTYP = [F:MWI]TXNTYP

    Call MLOOPETRK_DEL(1,1,ERR)                    # Annule l'ancien Machine Overhead
    If ERR = 1 : End : Endif

    Call MLOOPETRK_MOD(1,1,SAV_VCRTYP,SAV_VCRNUM,SAV_WIPSEQ,SAV_TXNTYP,TIA_FXD,ERR) # Machine Overhead
    If ERR = 1 : End : Endif

Elsif [F:MWS]WSTTYP = 2
    Call MLEOPETRK_DEL(2,1,ERR)        # Annule l'ancien
    If ERR = 1 : End : Endif
    Call MLEOPETRK_NEW(2,1,"M",TIA_FXD,ERR)        # Labor Expense - Primary
    If ERR = 1 : End : Endif

    SAV_VCRNUM = [F:MWI]VCRNUM
    SAV_VCRTYP = [F:MWI]VCRTYP
    SAV_WIPSEQ = [F:MWI]WIPSEQ
    SAV_TXNTYP = [F:MWI]TXNTYP
    Call MLOOPETRK_DEL(2,1,ERR)        # Annule l'ancien Labor Overhead - Primary
    If ERR = 1 : End : Endif
    Call MLOOPETRK_MOD(2,1,SAV_VCRTYP,SAV_VCRNUM,SAV_WIPSEQ,SAV_TXNTYP,TIA_FXD,ERR)  # Labor Overhead - Primary
    If ERR = 1 : End : Endif

    If ERR = 1 : End : Endif
Endif
    # CCC (09/09/05) Bug 32038 : Ce qui suit n'était effectué que dans le cas où le 1er poste était de type machine
    If [F:MKO]CPLLAB <> ""
        Read [MWS]WST0 = [F:MKO]CPLLAB;[F:MKO]MFGFCY
        If fstat
          ERR = 1  # "xxxxx poste inexistant sur ce site..."
          GMESSAGE = [F:MKO]CPLLAB-":"-mess(133,193,1)-[F:MKO]MFGFCY
          End
        Endif
        Call MLEOPETRK_DEL(2,2,ERR)                # Annule l'ancien
        If ERR = 1 : End : Endif
        Raz TIA_FXD
        Call MLEOPETRK_NEW(2,2,"M",TIA_FXD,ERR)    # Labor Expense - Secondary
        If ERR = 1 : End : Endif

        SAV_VCRNUM = [F:MWI]VCRNUM
        SAV_VCRTYP = [F:MWI]VCRTYP
        SAV_WIPSEQ = [F:MWI]WIPSEQ
        SAV_TXNTYP = [F:MWI]TXNTYP
        Call MLOOPETRK_DEL(2,2,ERR)    # Annule l'ancien Labor Overhead - Secondary
        If ERR = 1 : End : Endif
        Call MLOOPETRK_MOD(2,2,SAV_VCRTYP,SAV_VCRNUM,SAV_WIPSEQ,SAV_TXNTYP,TIA_FXD,ERR)    # Labor Overhead - Secondary
        If ERR = 1 : End : Endif
    Endif

End

###########################################################################
Subprog MLEOPETRK_DEL(IWSTTYP,IPRIM,ERR)
Value Integer        IWSTTYP, IPRIM
Variable Integer     ERR

Local Integer    LAST_SEQ

# Initialize values and open needed tables
ERR = 0

Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)

# If the line to be modified has been posted then need to create a WIPCOST record
# to get rid of it, else just delete the WIPCOST record
## lecture du dernier suffit (séq supérieure) un seul enreg est concerné
If IWSTTYP = 1 & IPRIM = 1
    Filter [MWI]Where MFGTRKNUM = [F:MKO]MFGTRKNUM & MFGTRKLIN = [F:MKO]OPETRKLIN &
&            VCRNUM = [F:MWH]VCRNUM & TXNTYP = 3 & WST = [F:MKO]CPLWST
Elsif IWSTTYP = 2 & IPRIM = 2
    Filter [MWI]Where MFGTRKNUM = [F:MKO]MFGTRKNUM & MFGTRKLIN = [F:MKO]OPETRKLIN &
&            VCRNUM = [F:MWH]VCRNUM & TXNTYP = 2 & WST = [F:MKO]CPLLAB
Elsif IWSTTYP = 2 & IPRIM = 1
    Filter [MWI]Where MFGTRKNUM = [F:MKO]MFGTRKNUM & MFGTRKLIN = [F:MKO]OPETRKLIN &
&            VCRNUM = [F:MWH]VCRNUM & TXNTYP = 2 & WST = [F:MKO]CPLWST
Endif
Read [MWI]MWI1 Last
If !fstat
  If [F:MWI]GLPSTA = 1
# Issue 74988 - 2011-09-01 by CCC : La suppression des sections ana de la ligne ne doit pas se faire à ce niveau car ici on peut être en simple modif
#    # Suppression des sections analytiques liées au suivi
#    Delete [F:CAL] Where ABRFIC="MKO"
#&                      & VCRNUM=[F:MWI]MFGTRKNUM
#&                      & VCRLIN=[F:MWI]MFGTRKLIN
#&                      & CPLCLE=[F:MWI]WST
    Delete [F:MWI]
    If fstat
        Call FSTA("MWI") From GLOCK
        Filter [MWI]
        ERR = 1
        GMESSAGE = mess(19,2363,1) #"Erreur à la suppression de WIPCOST"
        End
    Endif
  Else
    # Perform mapping
    [F:MWI]WIPSEQ    = LAST_SEQ + 1
    [F:MWI]TXNACT    = 3       # "supprimé" pour pouvoir annuler l'incidence en compta
    [F:MWI]GLPSTA    = 1
    [F:MWI]GLPDAT    = [00/00/0000]

    [F:MWI]QTY       = [F:MWI]QTY * (-1)
    [F:MWI]REJQTY    = [F:MWI]REJQTY * (-1)
    [F:MWI]AMOUNT    = [F:MWI]AMOUNT * (-1)
    [F:MWI]CSTELM(0) = [F:MWI]CSTELM(0) * (-1)
    [F:MWI]CSTELM(1) = [F:MWI]CSTELM(1) * (-1)
    [F:MWI]CPLSETTIM = [F:MWI]CPLSETTIM * (-1)
    [F:MWI]CPLOPETIM = [F:MWI]CPLOPETIM * (-1)

# CCC (2009-05-15) Bug 55211 : Les temps peuvent être comptabilisés => il faut créer l'extourne
#    # Write record only if there is a qty or amount value
#    If [F:MWI]QTY = 0 & [F:MWI]AMOUNT = 0
#        Raz [F:MWI]
#    Else
        Call ECR_MWI
        If fstat | GOK=0
            If fstat
                Call FSTA("MWI") From GLOCK
            Endif
            Filter [MWI]
            ERR = 1
            End
        Endif
#    Endif
  Endif
Endif

Filter [MWI]
End

###########################################################################
Subprog MLOOPETRK_DEL(IWSTTYP,IPRIM,ERR)
Value Integer        IWSTTYP, IPRIM
Variable Integer     ERR

Local Integer    LAST_SEQ
Local Integer    NB_MOD     # nb d'enreg trouvés avec action "modifié"

ERR = 0

Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)

## >> AUTRE SOLUTION : mettre les nouveaux enregistrements avec TXNACT à 1
##    et filtrer à la prochaine modif les MWI dont TXNACT=1 & GLPSTA=1

# If the line to be modified has been posted then need to create a WIPCOST record
# to get rid of it, else just delete the WIPCOST record
## et si on modifie x fois > tester aussi TXNACT prendre les 1 OU les 2 !!
# parcourir en premier les MWI avec TXNACT=2 (modifié antérieurement)
# si rien trouvé parcourir les MWI avec TXNACT=1 ("Nouveau")
If IWSTTYP = 1 & IPRIM = 1
    Filter [MWI]Where MFGTRKNUM = [F:MKO]MFGTRKNUM & MFGTRKLIN = [F:MKO]OPETRKLIN &
&            VCRNUM = [F:MWH]VCRNUM & TXNTYP = 7 & WST = [F:MKO]CPLWST & TXNACT = 2
Elsif IWSTTYP = 2 & IPRIM = 2
    Filter [MWI]Where MFGTRKNUM = [F:MKO]MFGTRKNUM & MFGTRKLIN = [F:MKO]OPETRKLIN &
&            VCRNUM = [F:MWH]VCRNUM & TXNTYP = 6 & WST = [F:MKO]CPLLAB & TXNACT = 2
Elsif IWSTTYP = 2 & IPRIM = 1
    Filter [MWI]Where MFGTRKNUM = [F:MKO]MFGTRKNUM & MFGTRKLIN = [F:MKO]OPETRKLIN &
&            VCRNUM = [F:MWH]VCRNUM & TXNTYP = 6 & WST = [F:MKO]CPLWST & TXNACT = 2
Endif
       ### attention ne pas prendre des "modifiés" comptabilisés déjà annulés par d'autres !! > +flg ?
###Read [MWI]MWI1 Last ### <<< il n'y avait qu'un enreg OH par ligne de suivi ! v140 : n enreg /nature

#For [MWI] #Issue X3-38386 15/02/2018 by GEBIL
For [MWI]MWI1
  NB_MOD += 1
  Gosub MWI_MLO  # (ceux qui sont créés ne risquent pas d'etre relus car TXNACT = 3)
  If ERR  Break   Endif
Next

If ERR = 0 & NB_MOD = 0
  If IWSTTYP = 1 & IPRIM = 1
    Filter [MWI]Where MFGTRKNUM = [F:MKO]MFGTRKNUM & MFGTRKLIN = [F:MKO]OPETRKLIN &
&            VCRNUM = [F:MWH]VCRNUM & TXNTYP = 7 & WST = [F:MKO]CPLWST & TXNACT = 1
  Elsif IWSTTYP = 2 & IPRIM = 2
    Filter [MWI]Where MFGTRKNUM = [F:MKO]MFGTRKNUM & MFGTRKLIN = [F:MKO]OPETRKLIN &
&            VCRNUM = [F:MWH]VCRNUM & TXNTYP = 6 & WST = [F:MKO]CPLLAB & TXNACT = 1
  Elsif IWSTTYP = 2 & IPRIM = 1
    Filter [MWI]Where MFGTRKNUM = [F:MKO]MFGTRKNUM & MFGTRKLIN = [F:MKO]OPETRKLIN &
&            VCRNUM = [F:MWH]VCRNUM & TXNTYP = 6 & WST = [F:MKO]CPLWST & TXNACT = 1
  Endif

  #For [MWI] #Issue X3-38386 15/02/2018 by GEBIL
  For [MWI]MWI1
    Gosub MWI_MLO  # (ceux qui sont créés ne risquent pas d'etre relus car TXNACT = 3)
    If ERR  Break  Endif
  Next
Endif

Filter [MWI]
End

$MWI_MLO
#Issue X3-38386 15/02/2018 by GEBIL : Slowness in operation tracking
#    Filter [F:MWI] Where MFGTRKNUM=[F:MWI]MFGTRKNUM
#&                      & MFGTRKLIN=[F:MWI]MFGTRKLIN
#&                      & WST=[F:MWI]WST
#&                      & GLPSTA=2
    If dim([L]WMFGTRKNUM)<0
       Local Char       WMFGTRKNUM(GLONVCR)
       Local Integer    WMFGTRKLIN
       Local Char       WWST(GLONWST)
    Endif

    WMFGTRKNUM = [F:MWI]MFGTRKNUM
    WMFGTRKLIN = [F:MWI]MFGTRKLIN
    WWST       = [F:MWI]WST

    Filter [F:MWI] Where MFGTRKNUM=WMFGTRKNUM
&                      & MFGTRKLIN=WMFGTRKLIN
&                      & WST=WWST
&                      & GLPSTA=2
    #Look [MWI] First #Issue X3-38386 15/02/2018 by GEBIL
    Look [MWI]MWI1 First
    Filter [MWI]
    If fstat
        # Suppression des sections analytiques liées aux Fg
        Case [F:MWI]VCRTYP
            When 10 :
                Delete [F:CAL] Where ABRFIC="MKO"
&                                  & VCRNUM=[F:MWI]MFGTRKNUM
&                                  & VCRLIN=[F:MWI]MFGTRKLIN
&                                  & CPLCLE=[F:MWI]OVENAT+"~"+[F:MWI]WST
            When 36 :
                Delete [F:CAL] Where ABRFIC="MWI"
&                                  & VCRNUM=[F:MWI]MFGTRKNUM
&                                  & VCRLIN=[F:MWI]MFGTRKLIN
&                                  & CPLCLE=[F:MWI]OVENAT+"~"+[F:MWI]ITMREF
        Endcase
        Delete [F:MWI]
        If fstat
            Call FSTA("MWI") From GLOCK
            ERR = 1
            GMESSAGE = mess(19,2363,1) #"Erreur à la suppression de WIPCOST"
            Return
        Endif
    Else
        ## [rewrite l'enreg avec un nouveau flag s'il faut pouvoir le distinguer à la prochaine modif] ?
        # Perform mapping
        [F:MWI]WIPSEQ    = LAST_SEQ + 1
        [F:MWI]TXNACT    = 3
        [F:MWI]GLPSTA    = 1
        [F:MWI]GLPDAT    = [00/00/0000]

        [F:MWI]AMOUNT    = [F:MWI]AMOUNT * (-1)
        [F:MWI]OVENATAMT = [F:MWI]OVENATAMT * (-1)

        # Write record only if there is a qty or amount value
        If [F:MWI]QTY = 0 & [F:MWI]AMOUNT = 0
            Raz [F:MWI]
        Else
            Call ECR_MWI
            If fstat  | GOK=0
                If fstat
                    Call FSTA("MWI") From GLOCK
                Endif
                ERR = 1
                Return
            Endif
            LAST_SEQ=[F:MWI]WIPSEQ+1 : # LAST_SEQ+=1 # GH 02/2016 bug 108954 incrementation for WIPCOST
        Endif
    Endif
Return


###########################################################################
Subprog MLOOPETRK_MOD(IWSTTYP,IPRIM,SAV_VCRTYP,SAV_VCRNUM,SAV_WIPSEQ,SAV_TXNTYP,TIA_FXD,ERR)
Value Integer        IWSTTYP, IPRIM, SAV_VCRTYP
Value Char           SAV_VCRNUM
Value Integer        SAV_WIPSEQ, SAV_TXNTYP
Value    Integer     TIA_FXD  # 1= fixes déjà pris en compte
Variable Integer     ERR

Local Integer    LAST_SEQ
Local Decimal    L_CURRND

# Start adding record for new value, but first need to get the last seq number
Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)

Call GET_CUR_RND([F:FCY]LEGCPY, L_CURRND, ERR)
# "erreur de lecture sur devise ; société juridique"
If ERR = 1
  GMESSAGE = mess(10,2363,1)-[F:FCY]LEGCPY
  End
Endif

# Perform mapping - Everything is the same as the machine/labor expense record
# except amount, 2 overhead fields, trans. type, and WIP seq #
Read [MWI]MWI5 = SAV_VCRTYP;SAV_VCRNUM;SAV_WIPSEQ;SAV_TXNTYP
If fstat
  Call FSTA("MWI") From GLOCK
  ERR = 1
  End
Endif
[F:MWI]GLPSTA    = 1            : # Réinitialisé (au cas où mnt=0)
[F:MWI]GLPDAT    = [00/00/0000] : #


Read [MWC]WCT0 = [F:MWI]VLTCCE;[F:MWI]MFGFCY
If fstat
  ## ERR = 1 : End  # non bloquant ! mettre 0 dans RAT ; quoi dans BRDCOD ??
  Raz [F:MWC]
Endif
If [F:MWC]OVECOD = "" : End : Endif    # if there is no overhead code then a WIPCOST
                                       # Overhead record does not need to be created

If IWSTTYP = 1
    [F:MWI]TXNTYP    = 7
Elsif IWSTTYP = 2
    [F:MWI]TXNTYP    = 6
Endif

[F:MWI]WIPSEQ    = LAST_SEQ # sera incrémenté dans le sous-pro

# recrée les n enreg par nature à partir du nouvel enreg MWI
Call CAL_OH(L_CURRND,[F:MWC]OVECOD,[F:MWI]CPLSETTIM+[F:MWI]CPLOPETIM,
&            [F:MWI]AMOUNT,TIA_FXD,ERR)

End


###########################################################################
Subprog OPETRK_DEL(ERR)
Variable Integer    ERR

ERR = 0

If !clalev([F:MWH]) : Local File MFGWIP     [MWH]  : Endif
If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif
If !clalev([F:MKO]) : Local File MFGOPETRK  [MKO] : Endif
If !clalev([F:MWS]) : Local File WORKSTATIO [MWS] : Endif

Call CRE_MFGWIP([F:MKO]MFGNUM,10*([F:MKO]TIMTYP=1),[F:MKO]TIMTYP,[F:MKO]MFGFCY,[F:MKO]IPTDAT,"",0,[F:MKO]ITMREF,[F:MKO]ROUALT,[F:MKO]CPLWST,ERR)
# erreur (de lecture) en retour
If ERR | GOK<1 : GMESSAGE -= "\"+mess(17,2363,1) : End Endif

Read [MWS]WST0 = [F:MKO]CPLWST;[F:MKO]MFGFCY
If fstat
  ERR = 1  # "xxxxx poste inexistant sur ce site..."
  GMESSAGE = [F:MKO]CPLWST-":"-mess(133,193,1)-[F:MKO]MFGFCY
  End
Endif

If [F:MWS]WSTTYP = 1
    Call MLEOPETRK_DEL(1,1,ERR)        # Machine Expense
    If ERR = 1 : End : Endif

    Call MLOOPETRK_DEL(1,1,ERR)        # Machine Overhead
    If ERR = 1 : End : Endif

    If [F:MKO]CPLLAB <> ""
        Read [MWS]WST0 = [F:MKO]CPLLAB;[F:MKO]MFGFCY
        If fstat
          ERR = 1  # "xxxxx poste inexistant sur ce site..."
          GMESSAGE = [F:MKO]CPLLAB-":"-mess(133,193,1)-[F:MKO]MFGFCY
          End
        Endif

        Call MLEOPETRK_DEL(2,2,ERR)    # Labor Expense - Secondary
        If ERR = 1 : End : Endif

        Call MLOOPETRK_DEL(2,2,ERR)    # Labor Overhead - Secondary
        If ERR = 1 : End : Endif
    Endif

Elsif [F:MWS]WSTTYP = 2
    Call MLEOPETRK_DEL(2,1,ERR)        # Labor Expense - Primary
    If ERR = 1 : End : Endif

    Call MLOOPETRK_DEL(2,1,ERR)        # Labor Overhead - Primary
    If ERR = 1 : End : Endif

Elsif [F:MWS]WSTTYP = 3
    Call SCEOPETRK_DEL(10,[F:MKO]MFGTRKNUM,[F:MKO]OPETRKLIN,[F:MKO]CPLWST,ERR)            # Subcontracting Expense
    If ERR = 1 : End : Endif

    Call SCOOPETRK_DEL(10,[F:MKO]MFGTRKNUM,[F:MKO]OPETRKLIN,[F:MKO]CPLWST,ERR)            # Subcontracting Overhead
    If ERR = 1 : End : Endif

Endif

End

###########################################################################
# Paramètres E : PTYPORI = type de doc d'origine (10=OF ; 36=EO)
#            S : ERR     = Code erreur (0=OK)
###########################################################################
Subprog SCEOPETRK_NEW(PTYPORI, ERR)
Value    Integer PTYPORI
Variable Integer     ERR

Local Integer    LAST_SEQ, W_SPEC
Local Decimal    L_CURRND

Local Char    SAV_VCRNUM(GLONVCR)
Local Integer SAV_VCRTYP,SAV_WIPSEQ, SAV_TXNTYP
Local Integer    TIA_FXD  # 1= fixes déjà pris en compte
If !clalev([F:MWI2]) : Local File WIPCOST    [MWI2] : Endif # pour recherche

# Initialize values and open needed tables
ERR = 0

If !clalev([F:MWH]) : Local File MFGWIP     [MWH]  : Endif
If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif

If !clalev([F:ITM]) : Local File ITMMASTER  [ITM]  : Endif
If !clalev([F:ITF]) : Local File ITMFACILIT [ITF]  : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif

Case PTYPORI
     When 10 :  Gosub INI_MWI_MFG
     When 36 :  Gosub INI_MWI_SCO
Endcase
If ERR | GOK=0
    End
Endif

[F:MWI]TXNTYP    = 4

[F:MWI]WIPSEQ    = LAST_SEQ + 1
[F:MWI]TXNACT    = 1
[F:MWI]GLPSTA    = 1
[F:MWI]GLPDAT    = [00/00/0000]

# Write record only if there is a qty or amount value
If [F:MWI]QTY = 0 & [F:MWI]AMOUNT = 0
    [F:MWI]GLPSTA=2
    [F:MWI]GLPDAT=date$ : # pour permettre de calculer des FG
Endif

# intégrer le point d'entrée pour calcul sous-traitance spécifique
# inutile : tout est fait depuis ECR_MWI pour n'importe quel type !
Call ECR_MWI
If fstat | GOK=0
    If fstat
        Call FSTA("MWI") From GLOCK
    Endif
    ERR = 1
    End
Endif

# sauvegarde de l'enregistrement de base pour les frais ultérieurs
SAV_VCRTYP = [F:MWI]VCRTYP
SAV_VCRNUM = [F:MWI]VCRNUM
SAV_WIPSEQ = [F:MWI]WIPSEQ
SAV_TXNTYP = [F:MWI]TXNTYP

# Issue 77464 - 2011-10-28 by CCC : on a déjà ce qu'il faut dans AMOUNT
#[F:MWI]AMOUNT = [M:SDP]SCOTOT+[M:SDP]INVDTACST    # Alim de [MWI]AMOUNT qui est utilisé dans MLOOPETRK_NEW
If [F:MWI]VLTCCE<>""  # Dans le cas de la sous-traitance et pas de module GP, on ne cherche pas à calculer les FG
    Call MLOOPETRK_NEW(3,TIA_FXD,ERR) # frais d'opération sous-traitance
    If ERR = 1 : End : Endif
Endif

# ajout V6 GA 05/2008 ne pas utiliser [F:MFO]
Local Char WSCOITMREF (GLONITM)
Local Char WMFGFCY (GLONFCY)
Case PTYPORI
     When 10 :  WSCOITMREF=[F:MFO]SCOITMREF : WMFGFCY=[F:MFO]MFGFCY
     When 36 :  WSCOITMREF=[F:SCS]SRVITMREF : WMFGFCY=[F:SCS]PRHFCY
Endcase
# rajouter les frais liés à l'article sous-traitance SCOITMREF ([MFO] est en ligne depuis MTKLIB)
# FG calculés sur la base du prix de sous-traitance
Read [ITF]ITF0 = WSCOITMREF;WMFGFCY
If !fstat & [F:ITF]OVECOD <> "" & W_SPEC=0
    # (lire aussi ITM en cas d'emploi dans formule de frais)
    Read [ITM]ITM0 = WSCOITMREF

    Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ) # pour les enreg de FG

    # calcul des frais généraux
    Read [MWI]MWI5=SAV_VCRTYP;SAV_VCRNUM;SAV_WIPSEQ;SAV_TXNTYP
    If !fstat
        # l'écrire à partir de l'enreg précédemment traité
        [F:MWI]TXNTYP    = 8
        [F:MWI]WIPSEQ    = LAST_SEQ # sera incrémenté dans le sous-pro

        # créer les n enreg par nature à partir de cet enreg MWI sur la base
        # du montant de service facturé (qté en US de l'article sous-trt)
# Issue 77464 - 2011-10-28 by CCC : Dans le cas des OF, SDP n'est pas alimenté. Prendre CSTELM(3) doit suffire
#        Call CAL_OH(L_CURRND,[F:ITF]OVECOD,[F:MWI]QTY,[M:SDP]SCOTOT+[M:SDP]INVDTACST,0,ERR)
        Call CAL_OH(L_CURRND,[F:ITF]OVECOD,[F:MWI]QTY,[F:MWI]CSTELM(3),0,ERR)
        If ERR = 1 : End : Endif
    Endif
Endif

End


###########################################################################
$INI_MWI_MFG

Gosub OPEN_FILES_MFG From MFGLIB
If !clalev([F:MWC]) : Local File WORKCOST   [MWC] : Endif

If [F:FCY]FCY <> [F:MKO]MFGFCY
  Read [FCY]FCY0=[F:MKO]MFGFCY
Endif

Call CRE_MFGWIP([F:MKO]MFGNUM,10*([F:MKO]TIMTYP=1),[F:MKO]TIMTYP,[F:MKO]MFGFCY,[F:MKO]IPTDAT,"",0,[F:MKO]ITMREF,[F:MKO]ROUALT,[F:MKO]CPLWST,ERR)
# erreur de création entête valorisation encours d'OF (MFGWIP)
If ERR | GOK<1 : GMESSAGE -= "\"+mess(17,2363,1) : End : Endif
Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)

Call GET_CUR_RND([F:FCY]LEGCPY, L_CURRND, ERR)
# "erreur de lecture sur devise ; société juridique"
If ERR = 1
  GMESSAGE = mess(10,2363,1)-[F:FCY]LEGCPY
  Return
Endif

# Perform mapping
Raz [F:MWI]

[F:MWI] = [F:MKO]
[F:MWI]VCRTYP    = [F:MWH]VCRTYP
[F:MWI]VCRNUM    = [F:MWH]VCRNUM
[F:MWI]MFGTRKLIN = [F:MKO]OPETRKLIN
[F:MWI]TXNDAT    = [F:MKO]IPTDAT
[F:MWI]QTY       = [F:MKO]CPLQTY
[F:MWI]STU       = [F:MKO]OPEUOM
[F:MWI]REJQTY    = [F:MKO]REJCPLQTY
[F:MWI]MFGFCY    = [F:MFO]MFGFCY

[F:MWI]WST       = [F:MKO]CPLWST

[F:MWI]MTSNUM    = [F:MTS]MTSNUM  # en ligne ??
[F:MWI]ITMREF    = [F:MFO]SCOITMREF  # indicatif

[F:MWI]ENTCOD    = GACCWIPENT

Read [MWS]WST0 = [F:MWI]WST;[F:MWI]MFGFCY
If fstat
  ERR = 1  # "xxxxx poste inexistant sur ce site..."
  GMESSAGE = [F:MWI]WST-":"-mess(133,193,1)-[F:MWI]MFGFCY
  Return
Endif
[F:MWI]VLTCCE    = [F:MWS]VLTCCE

Read [MWC]WCT0 = [F:MWI]VLTCCE;[F:MWI]MFGFCY
If fstat
  # pas de section de valorisation pour ce poste !
  # GMESSAGE = mess(153,197,1) - [F:MWS]WST
  ## ERR = 1 : End  # non bloquant ! mettre 0 dans RAT ; quoi dans BRDCOD ??
  Raz [F:MWC]
Endif
[F:MWI]CSTTYP    = [F:MWC]CSTTYP
[F:MWI]OPEGRP    = max(1,[F:MWC]BRDCOD)  # ne sert à rien pour la sous-traitance

If GMFCRATCPL = 1
    [F:MWI]SETRAT    = [F:MWC]STDSETCST
    [F:MWI]OPERAT    = [F:MWC]STDOPECST
Elsif GMFCRATCPL = 2
    [F:MWI]SETRAT    = [F:MWC]CUTSETCST
    [F:MWI]OPERAT    = [F:MWC]CUTOPECST
Endif

If [F:MKO]TIMUOMCOD = 2
    [F:MWI]CPLSETTIM = func TRTX3.ARRTYP("", "", "TIH", [F:MWI]CPLSETTIM / 60)
    [F:MWI]CPLOPETIM = func TRTX3.ARRTYP("", "", "TIH", [F:MWI]CPLOPETIM / 60)
Endif

If [F:MWI]CSTTYP = 1
    [F:MWI]CSTELM(0)    = arr([F:MWI]CPLSETTIM * [F:MWI]SETRAT, L_CURRND)
    [F:MWI]CSTELM(1)    = arr([F:MWI]CPLOPETIM * [F:MWI]OPERAT, L_CURRND)
Elsif [F:MWI]CSTTYP = 2
  # Si le taux est fixe, vérifier qu'il n'est pas déjà compté dans un autre WIP  (TB)
  # si c'est le cas mettre les éléments à 0 !
  For [MWI2]MWI3 Where VCRTYP=[F:MWI]VCRTYP & VCRNUM=[F:MWI]VCRNUM & OPENUM=[F:MWI]OPENUM &
&                OPESPLNUM=[F:MWI]OPESPLNUM & TXNTYP=4 & VLTCCE=[F:MWI]VLTCCE
    # positionner un indicateur pour éviter de passer x fois les fixes.
    # le test de la section est suffisant (>> attention si poste réalisé a un tx fixe alors que p prévu non ??!)
    If [F:MWI2]TXNACT<3 & [F:MWI2]AMOUNT<>0
      TIA_FXD = 1  # transmettre cela au calcul de FG et courcircuiter les fixes
      Break
    Endif
  Next
  If TIA_FXD = 0
      [F:MWI]CSTELM(0)    = [F:MWI]SETRAT
      [F:MWI]CSTELM(1)    = [F:MWI]OPERAT
  Else
      [F:MWI]CSTELM(0)    = 0
      [F:MWI]CSTELM(1)    = 0
  Endif
Endif

[F:MWI]CSTELM(2)  = [F:MWI]CSTELM(0) + [F:MWI]CSTELM(1)
If [F:MKO]CPLPRI <> 0
 [F:MWI]CSTELM(3) = arr([F:MWI]QTY * ([F:MKO]CPLPRI+[F:MKO]CPLCRG), L_CURRND) # prix facturé (le mettre dans UNTCST ?)
Else
 [F:MWI]CSTELM(3) = arr([F:MWI]QTY * [F:MKO]EXTPRI, L_CURRND) # prix PREVU car pas encore facturé
Endif
[F:MWI]AMOUNT    = [F:MWI]CSTELM(2) + [F:MWI]CSTELM(3)

[F:MWI]SCOCST = [F:MWI]AMOUNT   # Issue 119759 - 2017-03-07 by CCC : set the value in SCOCST too
Return

###########################################################################
$INI_MWI_SCO

Gosub OPEN_FILES_SCO From SCOLIB

If [F:FCY]FCY <> [F:PTD]PRHFCY
  Read [FCY]FCY0=[F:PTD]PRHFCY
Endif

Call CRE_MFGWIP([F:SCS]SCONUM,36,0,[F:PTD]PRHFCY,[F:PTD]RCPDAT,"",0,"",0,"",ERR)
# erreur de création entête valorisation encours d'OF (MFGWIP)
If ERR | GOK<1 : GMESSAGE -= "\"+mess(23,2363,1) : End : Endif
Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)

Call GET_CUR_RND([F:FCY]LEGCPY, L_CURRND, ERR)
# "erreur de lecture sur devise ; société juridique"
If ERR = 1
    GMESSAGE = mess(10,2363,1)-[F:FCY]LEGCPY
    Raz GOK
    Return
Endif

# Perform mapping
Raz [F:MWI]

[F:MWI] = [F:SCS]
[F:MWI]VCRTYP    = [F:MWH]VCRTYP
[F:MWI]VCRNUM    = [F:MWH]VCRNUM
[F:MWI]VCRLIN    = [F:SCS]SCILIN
[F:MWI]MFGTRKNUM = [F:PTD]PTHNUM
[F:MWI]MFGTRKLIN = [F:PTD]PTDLIN
[F:MWI]TXNDAT    = [F:PTD]RCPDAT
[F:MWI]STU       = [F:PTD]STU
[F:MWI]MFGFCY    = [F:SCS]PRHFCY

[F:MWI]MTSNUM    = [F:PTR]PTRNUM
[F:MWI]ITMREF    = [F:SCS]SRVITMREF

[F:MWI]ENTCOD    = GACCWIPEOA

[F:MWI]VLTCCE    = ""

[F:MWI]CSTTYP    = 0
[F:MWI]OPEGRP    = 0

[F:MWI]PRINAT    = 8

[F:MWI]QTY       = [M:SDP]QTY

If [M:SDP]INVDTACST<>0
    [F:MWI]TXNTYP=19

    [F:MWI]AMOUNT     = [M:SDP]INVDTACST
    [F:MWI]CSTELM(16) = [F:MWI]AMOUNT
    [F:MWI]INVDTACST  = [F:MWI]AMOUNT

    [F:MWI]WIPSEQ    = LAST_SEQ + 1
    LAST_SEQ+=1
    [F:MWI]TXNACT    = 1
    [F:MWI]GLPSTA    = 1
    [F:MWI]GLPDAT    = [00/00/0000]

    # Write record only if there is a qty or amount value
    If [F:MWI]QTY = 0 & [F:MWI]AMOUNT = 0
        [F:MWI]GLPSTA=2
        [F:MWI]GLPDAT=date$ : # pour permettre de calculer des FG
    Endif

    Call ECR_MWI
    If fstat | GOK=0
        If fstat
            Call FSTA("MWI") From GLOCK
        Endif
        Raz GOK
        ERR = 1
        Return
    Endif

    LAST_SEQ=[F:MWI]WIPSEQ+1 : # GH 02/2016 bug 108954 incrementation for WIPCOST
Endif

[F:MWI]CSTELM(16) = 0
[F:MWI]INVDTACST  = 0

[F:MWI]AMOUNT    = arr([M:SDP]AMTTOT-[M:SDP]INVDTACST, L_CURRND)
If [F:MWI]QTY <> 0
    [M:SDP]PRI = arr([F:MWI]AMOUNT/[F:MWI]QTY, L_CURRND)
Endif

If [M:SDP]PRI <> 0
    [F:MWI]UNTCST    = [M:SDP]PRI
Else # prix PREVU car pas encore facturé
    [F:MWI]UNTCST    = [F:SCS]NETPRI
    [F:MWI]AMOUNT    = arr([F:MWI]UNTCST*[F:MWI]QTY, L_CURRND)
Endif

[F:MWI]CSTELM(3)  = [M:SDP]SCOTOT
[F:MWI]CSTELM(11) = [F:MWI]CSTELM(3)

[F:MWI]SCOCST     = [F:MWI]CSTELM(3)

LBASAMT = sum([F:MWI]CSTELM(8..11))

Return

###########################################################################
# Issue 101596 GA 09/2014 idem SBCLIB Automatic recalculation ?
# le PRF devra être recalculé avec la somme des delta (par la fct FUNMFCSCO)
###########################################################################
$UPDATE_CLC
Case [F:MWI]VCRTYP
  When 10
      If GCLCWOCAUT = 3
        If [F:MFG]MFGNUM<>[F:MWI]VCRNUM
           Read [MFG]MFG0=[F:MWI]VCRNUM
           If fstat End Endif
        Endif
        Local Char PARAM_CLC(250)(1..14) , VAL_CLC(250)
        PARAM_CLC(1)  = [F:MWI]MFGFCY
        PARAM_CLC(2)  = [F:MWI]VCRNUM
        PARAM_CLC(4)  = "1"
        PARAM_CLC(5)  = "4"
        # positionner PARAM_CLC(12) à "2" SI ON NE VEUT PAS l'édition du calcul
        # positionner PARAM_CLC(13) à "2" si on veut la trace
        PARAM_CLC(12) = "2"
        PARAM_CLC(13) = "0"   # Issue 89622 - 2013-06-05 by CCC
        PARAM_CLC(14) = num$([F:MWI]VCRTYP)   : # VCRTYP 10 for WO
        Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBMCC","",3,"") From GTRAITE
      Endif
  When 36
      If GCLCEOCAUT = 3
        If [F:SCO]SCONUM<>[F:MWI]VCRNUM
           Read [SCO]SCO0=[F:MWI]VCRNUM
           If fstat End Endif
        Endif
        Local Char PARAM_CLC(50)(1..14) , VAL_CLC(250)
        PARAM_CLC(1) = [F:MWI]MFGFCY
        PARAM_CLC(2) = [F:MWI]VCRNUM
        PARAM_CLC(4) = "1"
        PARAM_CLC(5) = "4"
        PARAM_CLC(14) = num$([F:MWI]VCRTYP)   : # VCRTYP 36 for EO
        Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBSCC","",3,"") From GTRAITE
      Endif
Endcase

Return

###########################################################################
Subprog SCEOPEPRI_MOD(PTRKNUM, PTRKLIN, PWST,ERR)
Value    Char    PTRKNUM
Value    Integer PTRKLIN
Value    Char    PWST
Variable Integer ERR

Local Integer    LAST_SEQ, W_SPEC
Local Decimal    L_CURRND

# Initialize values and open needed tables
ERR = 0

If !clalev([F:MWH]) : Local File MFGWIP     [MWH] : Endif
If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif

If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif

# recréer un enreg OU modifier le wipcost sous-traitance
# recréer si le PRF est calculé et identifier le nouveau MWI avec TXNACT=2

# Issue 86964 - 2013-01-31 by CCC : Ne prendre que le dernier enreg de chaque type comme référence
Local Char REQ(250)
REQ = "SELECT MAX(WIPSEQ_0), VCRTYP_0, VCRNUM_0 FROM WIPCOST"
REQ-= "Where MFGTRKNUM_0='"+PTRKNUM +"'"
REQ-= "AND MFGTRKLIN_0="+num$(PTRKLIN)
If PWST<>""
    REQ-= "AND WST_0='"+PWST+"'"
Endif
REQ-= "AND TXNTYP_0 IN (4,19)"
REQ-= "GROUP BY TXNTYP_0, VCRTYP_0, VCRNUM_0"

For (Integer WIPSEQ, Integer VCRTYP, Char VCRNUM) From num$(GTYPDBA*2+1) Sql REQ As [SQLW]

    Filter [MWI] Where MFGTRKNUM = PTRKNUM & MFGTRKLIN = PTRKLIN
&                   & find(TXNTYP,4,19)<>0 & WST = PWST
&                   & WIPSEQ=[F:SQLW]WIPSEQ
&                   & VCRTYP=[F:SQLW]VCRTYP
&                   & VCRNUM=[F:SQLW]VCRNUM

    For [MWI]MWI1
        Raz [F:MWH]
        Read [MWH]MWH0=[F:MWI]VCRTYP;[F:MWI]VCRNUM
        Call GETDEV([F:MWI]MFGFCY) From DEVSUB
        Call GET_CUR_RND([F:FCY]LEGCPY, L_CURRND, ERR)
        # "erreur de lecture sur devise ; société juridique"
        If ERR = 1
              GMESSAGE = mess(10,2363,1)-[F:FCY]LEGCPY
              Break # FQ 69909 Ctrl des sources avant End
        Endif
        If [F:MWI]GLPSTA = 1 & [F:MWH]MFGTRKFLG < 6

            If [F:MWI]TXNTYP=4
                [F:MWI]AMOUNT     += [M:SDP]SCOTOT
                [F:MWI]CSTELM(3)  += [M:SDP]SCOTOT
                [F:MWI]CSTELM(11) += [M:SDP]SCOTOT
                [F:MWI]SCOCST    += [M:SDP]SCOTOT
            Else
                [F:MWI]AMOUNT     += [M:SDP]INVDTACST
                [F:MWI]CSTELM(16) += [M:SDP]INVDTACST
                [F:MWI]INVDTACST += [M:SDP]INVDTACST
            Endif
            [F:MWI]EXPNUM    = [C]EXPORT
            [F:MWI]UPDDAT    = date$
            [F:MWI]UPDUSR    = GUSER

            # FQ 66275 GA 07/2010 relecture des sections analytiques
            Call CHARG_CCE

            # point d'entrée pour calcul spécifique sous-traitance : seul cas de Rewrite sur WIPCOST
            GPOINT = "BEFREWMWI"
            Gosub ENTREE From EXEFNC

            Rewrite [MWI]
            If fstat
              Call FSTA("MWI") From GLOCK
              ERR = 1
              Break # FQ 69909 Ctrl des sources avant (rien)
            Endif
        Else
            Call GET_LAST_SEQ([F:MWI]VCRTYP,[F:MWI]VCRNUM,LAST_SEQ)

            [F:MWI]WIPSEQ    = LAST_SEQ + 1
            [F:MWI]TXNACT    = 1
            If [F:MWH]MFGTRKFLG = 6
               [F:MWI]TXNACT = 2 # pour le reconnaître au moment du recalcul
            Endif
            [F:MWI]GLPSTA    = 1
            [F:MWI]GLPDAT    = [00/00/0000]

            # Issue 88221 - 2013-02-22 by CCC
            Raz [F:MWI]QTY
            Raz [F:MWI]CSTELM
            # Issue 90518 - 2013-06-19 by CCC
            Raz [F:MWI]CPLOPETIM, [F:MWI]CPLSETTIM
            If [F:MWI]TXNTYP=4
                [F:MWI]AMOUNT     = [M:SDP]SCOTOT
                [F:MWI]CSTELM(3)  = [M:SDP]SCOTOT
                [F:MWI]CSTELM(11) = [M:SDP]SCOTOT
                [F:MWI]SCOCST     = [M:SDP]SCOTOT
            Else
                [F:MWI]AMOUNT     = [M:SDP]INVDTACST
                [F:MWI]CSTELM(16) = [M:SDP]INVDTACST
                [F:MWI]INVDTACST  = [M:SDP]INVDTACST
            Endif

            # Write record only if there is a qty or amount value
            If [F:MWI]QTY = 0 & [F:MWI]AMOUNT = 0
                [F:MWI]GLPSTA=2
                [F:MWI]GLPDAT=date$ : # pour permettre de calculer des FG
            Endif

            [F:MWI]AMOUNT     = arr([F:MWI]AMOUNT,L_CURRND)
            [F:MWI]CSTELM(3)  = arr([F:MWI]CSTELM(3),L_CURRND)
            [F:MWI]CSTELM(11) = arr([F:MWI]CSTELM(11),L_CURRND)
            [F:MWI]CSTELM(16) = arr([F:MWI]CSTELM(16),L_CURRND)
            [F:MWI]SCOCST     = arr([F:MWI]SCOCST,L_CURRND)
            [F:MWI]INVDTACST  = arr([F:MWI]INVDTACST,L_CURRND)

            Call ECR_MWI
            If fstat  | GOK=0
                If fstat
                    Call FSTA("MWI") From GLOCK
                Endif
                ERR = 1
                Break # FQ 69909 Ctrl des sources avant (rien)
            Endif

        Endif
    Next
    Filter [MWI]
Next

If ERR = 1 : End : Endif

# rajouter des FG calculés sur la base du prix de sous-traitance (pas de modif d'enreg FG!)
# Issue 70864 - 2011-02-04 by CCC
#Read [ITF]ITF0 = [F:MFO]SCOITMREF;[F:MFO]MFGFCY
Read [ITF]ITF0 = [F:MWI]ITMREF;[F:MWI]MFGFCY
If !fstat & [F:ITF]OVECOD <> "" & W_SPEC=0
    # (lire aussi ITM en cas d'emploi dans formule de frais)
    # Issue 78843 - 2012-02-02 by CCC
    #Read [ITM]ITM0 = [F:MFO]SCOITMREF
    Read [ITM]ITM0 = [F:MWI]ITMREF

    # Calcul des frais généraux avec param tps/qte=0 et base=delta
    # car les frais basés sur la qté ont déjà été passés à la réception.
    # L'écrire à partir de l'enreg précédemment traité
    [F:MWI]TXNTYP    = 8
    [F:MWI]TXNACT    = 2
    Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ) # pour les enreg de FG

    [F:MWI]WIPSEQ    = LAST_SEQ # sera incrémenté dans le sous-pro

    # recrée les n enreg par nature à partir du nouvel enreg MWI
    Call CAL_OH(L_CURRND,[F:ITF]OVECOD,0,[M:SDP]SCOTOT,0,ERR)

Endif

# Si aucun wip d'élément de facturation n'existe et qu'un nouveau mnt existe => il faut le créer
If [M:SDP]INVDTACST<>0
    Filter [MWI] Where MFGTRKNUM = PTRKNUM & MFGTRKLIN = PTRKLIN & TXNTYP=19
    Look [MWI]reckey First
    Filter [MWI]
    If fstat    # Il faut créer un wip d'élément de facturation
        Filter [MWI] Where MFGTRKNUM = PTRKNUM & MFGTRKLIN = PTRKLIN & TXNTYP=4
        Read [MWI]MWI0 Last
        Filter [MWI]

        [F:MWI]TXNTYP=19
        Raz [F:MWI]AMOUNT, [F:MWI]CSTELM
        Raz [F:MWI]MATCST, [F:MWI]MACCST, [F:MWI]LABCST, [F:MWI]SCOCST, [F:MWI]INVDTACST
        Raz [F:MWI]OVEMATCST, [F:MWI]OVEMACCST, [F:MWI]OVELABCST, [F:MWI]OVESCOCST
        # Issue 90518 - 2013-06-19 by CCC
        Raz [F:MWI]CPLOPETIM, [F:MWI]CPLSETTIM

        [F:MWI]AMOUNT     = [M:SDP]INVDTACST
        [F:MWI]CSTELM(16) = [F:MWI]AMOUNT
        [F:MWI]INVDTACST  = [F:MWI]AMOUNT

        Call GET_LAST_SEQ([F:MWI]VCRTYP,[F:MWI]VCRNUM,LAST_SEQ)
        [F:MWI]WIPSEQ    = LAST_SEQ + 1
        [F:MWI]TXNACT    = 1
        [F:MWI]GLPSTA    = 1
        [F:MWI]GLPDAT    = [00/00/0000]

        Call ECR_MWI
        If fstat | GOK=0
            If fstat
                Call FSTA("MWI") From GLOCK
            Endif
            Raz GOK
            ERR = 1
        Endif
        If ERR | GOK=0
            End
        Endif
    Endif
Endif
# le PRF devra être recalculé avec la somme des delta (par la fct FUNMFCSCO)
# remettre le MFGTRKFLG de MWH à 'non calculé'
# Issue 101596 GA 09/2014 #If [F:MWH]MFGTRKFLG = 6
If [F:MWH]MFGTRKFLG = 6 & ([M:SDP]SCOTOT<>0 | [M:SDP]INVDTACST<>0)
  Readlock [MWH]Curr
  If fstat
    Call FSTA("MWH") From GLOCK
    ERR = 1
  Else
    [F:MWH]MFGTRKFLG = 5
    Rewrite [MWH]
    If fstat
      Call FSTA("MWH") From GLOCK
      GMESSAGE = mess(13,100,1) - "MFGWIP :"-num$([F:MWH]VCRTYP)-[F:MWH]VCRNUM
      ERR = 1
    Endif
  Endif
  # Issue 101597 GA 09/2014 to be added ?
  #### If !ERR & GOK Gosub UPDATE_CLC Endif
Endif
End

###########################################################################
Subprog SCEOPETRK_DEL(PTYP, PTRKNUM, PTRKLIN, PWST, ERR)
Value    Integer PTYP
Value    Char    PTRKNUM
Value    Integer PTRKLIN
Value    Char    PWST
Variable Integer     ERR

Local Integer    LAST_SEQ

# Initialize values and open needed tables
ERR = 0

If PTYP=36
    If !clalev([F:MWH]) : Local File MFGWIP     [MWH]  : Endif
    Call CRE_MFGWIP([F:SCS]SCONUM,36,0,[F:PTD]PRHFCY,[F:PTD]RCPDAT,"",0,"",0,"",ERR)
    # erreur (de lecture) en retour
    If ERR | GOK<1 : GMESSAGE -= "\"+mess(17,2363,1) : End Endif
Endif

If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif
If !clalev([F:MWI2]): Local File WIPCOST    [MWI2]: Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif

Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ) : # GH 08/11/2013 bug 94096

# If the line to be deleted has been posted then need to create a WIPCOST record
# to get rid of it, else just delete the WIPCOST record
Filter [MWI] Where MFGTRKNUM = PTRKNUM & MFGTRKLIN = PTRKLIN
&                & find(TXNTYP,4,19)<>0 & WST = PWST & WIPSEQ <= [L]LAST_SEQ
# GH 08/11/2013 bug 94096 ajout de la condition sur WIPSEQ

For [MWI]MWI1
    Filter [MWI2] Where MFGTRKNUM = PTRKNUM & MFGTRKLIN = PTRKLIN
&                    & find(TXNTYP,4,19)<>0 & WST = PWST & GLPSTA=2
    Look [MWI2] First
    If fstat
        Case PTYP
            When 10 :
                # Suppression des sections analytiques liées au suivi /s-trait
                Delete [F:CAL] Where ABRFIC="MKO"
&                                  & VCRNUM=[F:MWI]MFGTRKNUM
&                                  & VCRLIN=[F:MWI]MFGTRKLIN
&                                  & CPLCLE=[F:MWI]WST
            When 36 :
                # Suppression des sections analytiques liées au WIP de la réception de /s-trait
                Delete [F:CAL] Where ABRFIC="MWI"
&                                  & VCRNUM=[F:MWI]MFGTRKNUM
&                                  & VCRLIN=[F:MWI]MFGTRKLIN
&                                  & CPLCLE=[F:MWI]ITMREF
        Endcase
        Delete [F:MWI]
        If fstat
            Call FSTA("MWI") From GLOCK
            ERR = 1
            GMESSAGE = mess(19,2363,1) #"Erreur à la suppression de WIPCOST"
            Break # FQ 69909 Ctrl des sources avant End
        Endif
    Else
        # Perform mapping
        # Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ) : # GH 08/11/2013 bug 94096
        [F:MWI]WIPSEQ    = LAST_SEQ + 1
        [F:MWI]TXNACT    = 3
        [F:MWI]GLPSTA    = 1
        [F:MWI]GLPDAT    = [00/00/0000]

        [F:MWI]QTY       = [F:MWI]QTY * (-1)
        [F:MWI]REJQTY    = [F:MWI]REJQTY * (-1)
        [F:MWI]AMOUNT    = [F:MWI]AMOUNT * (-1)
        [F:MWI]CSTELM(0) = [F:MWI]CSTELM(0) * (-1)
        [F:MWI]CSTELM(1) = [F:MWI]CSTELM(1) * (-1)
        [F:MWI]CSTELM(2) = [F:MWI]CSTELM(2) * (-1)
        [F:MWI]CSTELM(3) = [F:MWI]CSTELM(3) * (-1)
        [F:MWI]CSTELM(11)= [F:MWI]CSTELM(11) * (-1)
        [F:MWI]CSTELM(16)= [F:MWI]CSTELM(16) * (-1)
        [F:MWI]SCOCST    = [F:MWI]SCOCST * (-1)
        [F:MWI]INVDTACST = [F:MWI]INVDTACST * (-1)
        [F:MWI]CPLSETTIM = [F:MWI]CPLSETTIM * (-1)
        [F:MWI]CPLOPETIM = [F:MWI]CPLOPETIM * (-1)

    # CCC (2009-05-15) Bug 55211 : Les temps peuvent être comptabilisés => il faut créer l'extourne
    #    # Write record only if there is a qty or amount value
    #    If [F:MWI]QTY = 0 & [F:MWI]AMOUNT = 0
    #        Raz [F:MWI]
    #    Else
            Call ECR_MWI
            If fstat | GOK=0
                If fstat
                    Call FSTA("MWI") From GLOCK
                Endif
                ERR = 1
                Break # FQ 69909 Ctrl des sources avant End
            Endif
            # LAST_SEQ += 1 : # GH 08/11/2013 bug 94096
            LAST_SEQ=[F:MWI]WIPSEQ+1 : # GH 02/2016 bug 108954 incrementation for WIPCOST
    #    Endif
    Endif
Next
Filter [MWI]
Filter [MWI2] : # GH 08/11/2013

End

###########################################################################
Subprog SCOOPETRK_DEL(PTYP, PTRKNUM, PTRKLIN, PWST, ERR)
Value    Integer PTYP
Value    Char    PTRKNUM
Value    Integer PTRKLIN
Value    Char    PWST
Variable Integer ERR
Local Integer    LAST_SEQ

ERR = 0

If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif
If !clalev([F:MWH]) : Local File MFGWIP     [MWH] : Endif
Case PTYP
    When 10
        # Issue 93991 GA 04/2014 CRE_MFGWIP use MFGNUM as parameter instead of PTRKNUM
        Call CRE_MFGWIP([F:MKO]MFGNUM,10*([F:MKO]TIMTYP=1),[F:MKO]TIMTYP,[F:MKO]MFGFCY,[F:MKO]IPTDAT,"",0,[F:MKO]ITMREF,[F:MKO]ROUALT,[F:MKO]CPLWST,ERR)
    When 36
        # Issue 93991 GA 04/2014 CRE_MFGWIP use SCONUM as parameter instead of PTRKNUM
        Call CRE_MFGWIP([F:PTD]VCRNUMORI,36,0,[F:PTD]PRHFCY,[F:PTD]RCPDAT,"",0,"",0,"",ERR)
Endcase
# erreur de création entête valorisation encours d'OF (MFGWIP)
If ERR | GOK<1 : GMESSAGE -= "\"+mess(23,2363,1) : End : Endif
Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ)

Filter [MWI]Where VCRTYP    = PTYP    & TXNTYP = 8
&               & MFGTRKNUM = PTRKNUM & MFGTRKLIN = PTRKLIN
&               & WST       = PWST    & WIPSEQ <= [L]LAST_SEQ
# GH 03/01/2014 bug 94096 ajout de la condition sur WIPSEQ
For [MWI]
  Gosub MWI_MLO
  If ERR  Break   Endif
Next

Filter [MWI]

End

###########################################################################
# Calcul des frais généraux
# création d'un MWI à partir de celui précédemment créé (qq zones changent)
###########################################################################
Subprog CAL_OH(PCURRND,POVECOD,PBASQTY,PBASAMT,PTIAFXD,PERR)
Value Decimal PCURRND  # FGR 14/01/2010 : X3SUIVI60986
Value Char    POVECOD
Value Decimal PBASQTY
Value Decimal PBASAMT
Value Integer PTIAFXD
Variable Integer PERR

Local Char    LCOL(1)
Local Char    LTABNAT(GLONONA)(50)
Local Decimal LTABFXD(50)
Local Decimal LTABVAR(50)
Local Integer LTABTYP(50)
Local Decimal LBASE
Local Char    WCCE(GLONCCE)
Local Integer LTXNTYPORI : LTXNTYPORI=[F:MWI]TXNTYP

If !clalev([F:OVE]) : Local File OVERHEAD    [OVE] : Endif
If !clalev([F:ONA]) : Local File OVENAT      [ONA] : Endif
If !clalev([F:TFO]) : Local File TABFOR      [TFO] : Endif

Case [F:MWI]VCRTYP
    When 10 :
        Case GOVECOLMFC
          When 1 LCOL = "A"
          When 2 LCOL = "B"
          When 3 LCOL = "C"
          When 4 LCOL = "D"
        Endcase
    When 36 :
        Case GOVECOLSCO
          When 1 LCOL = "A"
          When 2 LCOL = "B"
          When 3 LCOL = "C"
          When 4 LCOL = "D"
        Endcase
Endcase
Raz LTABNAT,LTABFXD,LTABVAR
If [F:OVE]OVECOD<>POVECOD
    Read [OVE]OVE0 = POVECOD
Endif
Raz LBASE
Case [F:OVE]FORBASIS
    When 1 : LBASE = PBASAMT
    When 2 : LBASE = PBASQTY
Endcase
#----- Calcul des FG -----#
Call CLCOVE(LBASE,[F:OVE]OVECOD,LCOL,1,LTABNAT,LTABTYP,LTABFXD,LTABVAR) From TRTCST

#----- Enregistrement des différentes natures ----#
For I=0 To dim(LTABNAT)-1
    If LTABNAT(I)="" : Break : Endif
    [F:MWI]OVENAT    = LTABNAT(I)
    Case LTABTYP(I)
        When 2,3,4,5
            [F:MWI]TXNTYP = LTABTYP(I)+3
        When Default
            [F:MWI]TXNTYP = LTXNTYPORI
    Endcase
    [F:MWI]AMOUNT    = arr((PTIAFXD=0)*LTABFXD(I)+LTABVAR(I),PCURRND)
    [F:MWI]WIPSEQ    = [F:MWI]WIPSEQ + 1  # incrémenter à partir du précedent
    If dim(GOVEPRD)>0 & GOVEPRD & [F:MWI]MATOVETYP=1
        [F:MWI]CSTELM(4)=[F:MWI]AMOUNT
    Endif
    Call ECR_MWI
    If fstat | GOK=0
        If fstat
            Call FSTA("MWI") From GLOCK
        Endif
        PERR = 1
        Break
    Endif
Next
End

$ERR_FOR
# "Erreur dans les formules de FG"
GMESSAGE = errmes$(errn)+"\|"+ errm +"|"
GMESSAGE += "\"+mess(152,197,1)- [F:OVE]OVECOD -"("+ OH_COD_FOR + ")"
ERR = 1  # erreur bloquante si formule non évaluable
Resume

###########################################################################
#
# ADDITIONAL PROCEDURES
#
###########################################################################
Subprog GET_LAST_SEQ(I_VCRTYP,I_VCRNUM, LAST_SEQ)
Value Integer     I_VCRTYP
Value Char        I_VCRNUM
Variable Integer  LAST_SEQ

# Initialize values and open needed tables
#If !clalev([F:MWI]) : Local File WIPCOST  [MWI] : Endif ## >> ou prendre une autre abv (TB)
If !clalev([F:MWIS]) : Local File WIPCOST  [MWIS] : Endif     # Issue 79062 - 2012-02-06 by CCC

# Find the last sequence number used for the work order in the WIPCOST
Filter [MWIS] Where VCRTYP=I_VCRTYP & VCRNUM = I_VCRNUM
Read [MWIS]MWI5 Last
If !fstat
    LAST_SEQ = [F:MWIS]WIPSEQ
Else
    LAST_SEQ = 0
Endif
Filter [MWIS]

End

###########################################################################
Subprog GET_CUR_RND(I_CPY, L_CURRND,ERR)
Value Char        I_CPY
Variable Decimal  L_CURRND
Variable Integer  ERR

# Initialize values and open needed tables
L_CURRND = 0
ERR = 0

If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
If !clalev([F:TCU]) : Local File TABCUR   [TCU] : Endif

# Find the rounding factor for the companies currency ([F:TCU]CURRND)
Read [CPY]CPY0 = I_CPY
If fstat : ERR = 1 : End : Endif

Read [TCU]TCU0 = [F:CPY]ACCCUR
If fstat : ERR = 1 : End : Endif
# CCC (24/02/05) Cet arrondi est un peu trop sévère pour les wipcost
#    => utilisation de GDECPRI comme dans le calcul du coût standard
#L_CURRND = [F:TCU]CURRND
L_CURRND = 10^-GDECPRI
GLOCALDEV = [F:CPY]ACCCUR  # rajouté 04/11/03
End

###########################################################################
$COST_ELEMENTS
# lecture des coûts pour le produit déclaré
Local Decimal MAX_VAL
Local Integer L_CSTTYP, I, MAX_IND

Local Decimal MATTOT, LABTOT, MACTOT, SCOTOT, OVETOT
Local Decimal OVEMATTOT, OVELABTOT, OVEMACTOT, OVESCOTOT
Local Decimal ITC_TOT

# Initialize values and open needed tables
If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif
If !clalev([F:ITC]) : Local File ITMCOST    [ITC] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif

# If receipt code = Revised then set Cost type code to Revised
# All other receipt code should set the cost type code to Standard
If [F:MWI]PRINAT = 3     # correspond au PRINAT de STJ (choix de valorisation)
    L_CSTTYP = 2
Else
    L_CSTTYP = 1
Endif

# Get item cost record
Filter [ITC] Where STOFCY = [F:MWI]MFGFCY
&                & ITMREF = [F:MWI]ITMREF
&                & CSTTYP = L_CSTTYP
&                & ITCSTRDAT<=[M:STW]IPTDAT
&                & ITCENDDAT>=[M:STW]IPTDAT
&                & UID = 0
Read [ITC]ITC0 First
If fstat
    Filter [ITC] Where STOFCY = [F:MWI]MFGFCY
&                    & ITMREF = [F:MWI]ITMREF
&                    & CSTTYP = L_CSTTYP
&                    & UID = 0
    Read [ITC]ITC0 First        # >> signaler l'année <> de l'année d'imputation
    If fstat : Filter [ITC] : Return : Endif
Endif
Filter [ITC]

If !fstat
    ITC_TOT = [F:ITC]VLTTOT
Endif

# Get ratio value thus only one divide by zero check
If ITC_TOT = 0
    Return
Endif

# Sort les FG du niveau dans d'autres enreg de type 14
# Les FG des sous-produits sont déjà inclus dans le produit
If ITM_TYP<>2
    Gosub COST_NAT
Endif

# Issue 85669 - 2012-11-16 by CCC : Annulation FG pour les sous-produits
If ITM_TYP=2
    X_AMOUNT = X_AMOUNT*[F:ITC]CSTTOT/[F:ITC]VLTTOT
    ITC_TOT=[F:ITC]CSTTOT
    Raz [F:ITC]OVEMATCST,[F:ITC]OVEMACCST,[F:ITC]OVELABCST,[F:ITC]OVESCOCST
    Raz [F:ITC]OVEMATLEV,[F:ITC]OVEMACLEV,[F:ITC]OVELABLEV,[F:ITC]OVESCOLEV
Else
    X_AMOUNT-=X_AMOUNT*([F:ITC]OVEMATLEV+[F:ITC]OVEMACLEV+[F:ITC]OVELABLEV+[F:ITC]OVESCOLEV)/[F:ITC]VLTTOT   # cout total sans FG du niveau
    ITC_TOT = [F:ITC]VLTTOT-([F:ITC]OVEMATLEV+[F:ITC]OVEMACLEV+[F:ITC]OVELABLEV+[F:ITC]OVESCOLEV) # cout unitaire sans FG du niveau
Endif

# on sort si le cout est nul
If  ITC_TOT = 0
    Return
Endif


If dim(GOVEPRD)>0 & GOVEPRD
    # Suppression des FG d'entrée qui sont contenus dans l'enreg de type 5
    X_AMOUNT -= X_AMOUNT*[F:ITC]OVEPRD/ITC_TOT
    ITC_TOT-=[F:ITC]OVEPRD
Else
    [F:ITC]OVEPRD = 0
Endif

If [F:ITC]VLTTOT-[F:ITC]OVEPRD<>0
    # Coûts du niveau
    Gosub ITEM_COSTS
    # Calculate cost elements
    [F:MWI]CSTELM(0) = arr((X_AMOUNT * MATTOT) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(1) = arr((X_AMOUNT * LABTOT) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(2) = arr((X_AMOUNT * MACTOT) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(3) = arr((X_AMOUNT * SCOTOT) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(4) = 0
    [F:MWI]CSTELM(5) = 0
    [F:MWI]CSTELM(6) = 0
    [F:MWI]CSTELM(7) = 0

    # charger aussi les CSTELM de 8 à 15 pour avoir la décomposition globale telle
    # qu'elle est dans ITMCOST, c'est à dire multi-niveau
    [F:MWI]CSTELM(8)  = arr((X_AMOUNT * [F:ITC]MATTOT) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(9)  = arr((X_AMOUNT * [F:ITC]LABTOT) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(10) = arr((X_AMOUNT * [F:ITC]MACTOT) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(11) = arr((X_AMOUNT * [F:ITC]SCOTOT) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(12) = arr((X_AMOUNT * ([F:ITC]OVEMATCST-[F:ITC]OVEMATLEV)) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(13) = arr((X_AMOUNT * ([F:ITC]OVELABCST-[F:ITC]OVELABLEV)) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(14) = arr((X_AMOUNT * ([F:ITC]OVEMACCST-[F:ITC]OVEMACLEV)) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(15) = arr((X_AMOUNT * ([F:ITC]OVESCOCST-[F:ITC]OVESCOLEV)) / ITC_TOT,L_CURRND)

    [F:MWI]CSTELM(16) = 0    # Pas d'élément de facture dans un coût standard
Endif

[F:MWI]OVENATAMT = 0

If GACTDECCST & ITC_TOT<>0
    For I=0 To dim([F:MWI]MATCST)-1
        [F:MWI]MATCST(I) = arr((X_AMOUNT * [F:ITC]MATCST(I)) / ITC_TOT,L_CURRND)
    Next
    For I=0 To dim([F:MWI]MACCST)-1
        [F:MWI]MACCST(I) = arr((X_AMOUNT * [F:ITC]MACCST(I)) / ITC_TOT,L_CURRND)
    Next
    For I=0 To dim([F:MWI]LABCST)-1
        [F:MWI]LABCST(I) = arr((X_AMOUNT * [F:ITC]LABCST(I)) / ITC_TOT,L_CURRND)
    Next
    [F:MWI]SCOCST    = arr((X_AMOUNT * [F:ITC]SCOCST) / ITC_TOT,L_CURRND)
    [F:MWI]INVDTACST = 0    # Pas d'élément de facture dans un coût standard

    [F:MWI]OVEMATCST = arr((X_AMOUNT * ([F:ITC]OVEMATCST-[F:ITC]OVEMATLEV)) / ITC_TOT,L_CURRND)
    [F:MWI]OVEMACCST = arr((X_AMOUNT * ([F:ITC]OVEMACCST-[F:ITC]OVEMACLEV)) / ITC_TOT,L_CURRND)
    [F:MWI]OVELABCST = arr((X_AMOUNT * ([F:ITC]OVELABCST-[F:ITC]OVELABLEV)) / ITC_TOT,L_CURRND)
    [F:MWI]OVESCOCST = arr((X_AMOUNT * ([F:ITC]OVESCOCST-[F:ITC]OVESCOLEV)) / ITC_TOT,L_CURRND)
Endif

If ITC_TOT<>0
    [F:MWI]MATLEV0 = arr((X_AMOUNT * [F:ITC]MATLEV0) / ITC_TOT,L_CURRND)
Endif


# Make sure totals are equal ## AMOUNT est négatif car déclaration de prod, tester la val absolue
MAX_IND = 0                  # égalisation sur la première série seulement (0-7)
MAX_VAL = 0
For I = 0 To 7
    If abs(MAX_VAL) < abs([F:MWI]CSTELM(I))
        MAX_VAL = [F:MWI]CSTELM(I)
        MAX_IND = I
    Endif
Next
## on cumule l'éventuelle différence sur l'élément le + important en valeur absolue!(!)
If sum([F:MWI]CSTELM(0..7)) <> X_AMOUNT
    [F:MWI]CSTELM(MAX_IND) += (X_AMOUNT - sum([F:MWI]CSTELM(0..7)))
Endif

Filter [ITC]

Return

###########################################################################
$CPP_ELEMENTS
# lecture des coûts prévisionnels pour le produit déclaré
# (en recherchant les composantes de coût dans MFC type prévisionnels) selon GCSTRCPORD

Local Decimal MATTOT, LABTOT, MACTOT, SCOTOT, OVETOT
Local Decimal OVEMATTOT, OVELABTOT, OVEMACTOT, OVESCOTOT
If !clalev([F:MFC]) : Local File MFGCOST  [MFC] : Endif
If !clalev([F:MCN]) : Local File MFCNAT   [MCN] : Endif

Local Decimal MAX_VAL
Local Integer I, MAX_IND

Local Decimal MFC_TOT

If [F:MWI]VCRTYP=10
    Read [MFC]MFC0=[F:MWI]MFGFCY;[F:MWI]ITMREF;[F:MWI]VCRTYP;[F:MWI]VCRNUM;[F:MWI]VCRLIN;GCSTRCPORD;0
Elsif [F:MWI]VCRTYP=36
    Read [MFC]MFC0=[F:MWI]MFGFCY;[F:MWI]ITMREF;[F:MWI]VCRTYP;[F:MWI]VCRNUM;[F:MWI]VCRLIN;GCSTEORORD;0
Endif
If !fstat
  MFC_TOT = [F:MFC]CSTTOT + [F:MFC]OVETOT
Endif

# on sort si le cout est nul
If  MFC_TOT = 0
    Return
Endif

# Sort les FG du niveau dans d'autres enreg de type 14
Gosub CPP_NAT

X_AMOUNT-=X_AMOUNT*[F:MFC]OVETOT/MFC_TOT # cout total sans FG du niveau
MFC_TOT = [F:MFC]CSTTOT # cout unitaire sans FG du niveau

# Issue 85549 - 2012-11-07 by CCC
MFC_TOT -=[F:MFC]INVDTACPN


# on sort si le cout est nul
If  MFC_TOT = 0
    Return
Endif

If dim(GOVEPRD)>0 & GOVEPRD
    # Récupération des FG sortie matière (Nature ZZZ)
    Raz [F:MCN]
    Read [MCN]MCN0=[F:MWI]MFGFCY;[F:MWI]ITMREF;year([F:MWI]TXNDAT);[F:MWI]VCRNUM;[F:MFC]VCRLIN;"ZZZ"
    # Suppression des FG d'entrée qui sont contenus dans l'enreg de type 5, mais pas les FG de sortie des composants (nature ZZZ)
    # !!! attention à l'ordre de calcul !!!
    X_AMOUNT -= X_AMOUNT*([F:MFC]OVEMATCST-[F:MCN]NATAMTLEV)/MFC_TOT
    MFC_TOT  -= ([F:MFC]OVEMATCST-[F:MCN]NATAMTLEV)
Endif

# répartition sur les composantes du coût prévisionnel d'OF
# les xxxCPNCST sont toujours renseignés de manière indicative mais non intégrés aux xxxTOT en v 140
# Les xxxTOT correspondent donc à une "vue du niveau" comme pour les coûts !
If MFC_TOT<>0
    [F:MWI]CSTELM(0) = arr((X_AMOUNT * [F:MFC]MATTOT) / MFC_TOT,L_CURRND) # ou alors rajouter OVECPNCST ici ?
    [F:MWI]CSTELM(1) = arr((X_AMOUNT * [F:MFC]LABTOT) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(2) = arr((X_AMOUNT * [F:MFC]MACTOT) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(3) = arr((X_AMOUNT * [F:MFC]SCOTOT) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(4) = 0
    [F:MWI]CSTELM(5) = 0
    [F:MWI]CSTELM(6) = 0
    [F:MWI]CSTELM(7) = 0

    Gosub CPP_TOT    # Calcul des totaux en multi-niveaux
    [F:MWI]CSTELM(8)  = arr((X_AMOUNT * MATTOT) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(9)  = arr((X_AMOUNT * LABTOT) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(10) = arr((X_AMOUNT * MACTOT) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(11) = arr((X_AMOUNT * SCOTOT) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(12) = arr((X_AMOUNT * [F:MFC]OVEMATCPN) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(13) = arr((X_AMOUNT * [F:MFC]OVELABCPN) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(14) = arr((X_AMOUNT * [F:MFC]OVEMACCPN) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(15) = arr((X_AMOUNT * [F:MFC]OVESCOCPN) / MFC_TOT,L_CURRND)

    [F:MWI]CSTELM(16) = X_INVDTA
Endif

If GACTDECCST & MFC_TOT<>0   # Décomposition multi-niveaux
    For I=0 To dim([F:MWI]MATCST)-1
        [F:MWI]MATCST(I) = arr((X_AMOUNT * [F:MFC]MATCPNCST(I)) / MFC_TOT,L_CURRND)
    Next
    For I=0 To dim([F:MWI]MACCST)-1
        [F:MWI]MACCST(I) = arr((X_AMOUNT * ([F:MFC]MACCPNCST(I)+[F:MFC]MACCST(I))) / MFC_TOT,L_CURRND)
    Next
    For I=0 To dim([F:MWI]LABCST)-1
        [F:MWI]LABCST(I) = arr((X_AMOUNT * ([F:MFC]LABCPNCST(I)+[F:MFC]LABCST(I))) / MFC_TOT,L_CURRND)
    Next
    [F:MWI]SCOCST    = arr((X_AMOUNT * ([F:MFC]SCOCST+[F:MFC]SCOCPNCST)) / MFC_TOT,L_CURRND)
    [F:MWI]INVDTACST = X_INVDTA
    [F:MWI]OVEMATCST = arr((X_AMOUNT * [F:MFC]OVEMATCPN) / MFC_TOT,L_CURRND)
    [F:MWI]OVEMACCST = arr((X_AMOUNT * [F:MFC]OVEMACCPN) / MFC_TOT,L_CURRND)
    [F:MWI]OVELABCST = arr((X_AMOUNT * [F:MFC]OVELABCPN) / MFC_TOT,L_CURRND)
    [F:MWI]OVESCOCST = arr((X_AMOUNT * [F:MFC]OVESCOCPN) / MFC_TOT,L_CURRND)
Endif

If MFC_TOT<>0
    [F:MWI]MATLEV0 = arr((X_AMOUNT * [F:MFC]MATLEV0) / MFC_TOT,L_CURRND)
Endif

# contrôle répartition ## AMOUNT est négatif car déclaration de prod, tester la val absolue
MAX_IND = 0            # égalisation sur la première série seulement (0-7)
MAX_VAL = 0
For I = 0 To 7
    If abs(MAX_VAL) < abs([F:MWI]CSTELM(I))
        MAX_VAL = [F:MWI]CSTELM(I)
        MAX_IND = I
    Endif
Next
## on cumule l'éventuelle différence sur l'élément le + important (!)
If sum([F:MWI]CSTELM(0..7)) <> X_AMOUNT
    [F:MWI]CSTELM(MAX_IND) += (X_AMOUNT - sum([F:MWI]CSTELM(0..7)))
Endif

Return

#####################################################################################
$CPP_TOT
# pour retrouver l'équivalent des parts globales multi-niveau façon ITC, mais à partir de MFC

# Issue 85549 - 2012-11-07 by CCC
#MATTOT = [F:MFC]MATTOT-sum([F:MFC]LABCPNCST)-sum([F:MFC]MACCPNCST)-sum([F:MFC]SCOCPNCST)-sum([F:MFC]OVECPNCST)
MATTOT = [F:MFC]MATTOT-sum([F:MFC]LABCPNCST)-sum([F:MFC]MACCPNCST)-sum([F:MFC]SCOCPNCST)-sum([F:MFC]INVDTACPN)-sum([F:MFC]OVECPNCST)

LABTOT = [F:MFC]LABTOT+sum([F:MFC]LABCPNCST)
MACTOT = [F:MFC]MACTOT+sum([F:MFC]MACCPNCST)
SCOTOT = [F:MFC]SCOTOT+sum([F:MFC]SCOCPNCST)
# les frais généraux ne peuvent pas être répartis car il n'y a pas de notion
# de frais machine du niveau dans MFGCOST !
Return

#####################################################################################
$ITEM_COSTS
## en prenant en compte les composantes du niveau pour correspondre à l'optique des OF
# CCC (14/12/04) Les coûts niveau sont détaillés par famille de coût et MATLEVCST
# contient désormais le coût total des composants
LABTOT = sum([F:ITC]LABLEVCST)
MACTOT = sum([F:ITC]MACLEVCST)
SCOTOT = [F:ITC]SCOLEVCST
OVETOT = [F:ITC]OVELEVCST

OVEMATTOT = [F:ITC]OVEMATLEV
OVELABTOT = [F:ITC]OVELABLEV
OVEMACTOT = [F:ITC]OVEMACLEV
OVESCOTOT = [F:ITC]OVESCOLEV

#MATTOT = [F:ITC]MATTOT + ([F:ITC]LABTOT - [F:ITC]LABLEVCST) +
#&    ([F:ITC]MACTOT - [F:ITC]MACLEVCST) + ([F:ITC]SCOTOT - [F:ITC]SCOLEVCST) +
#&     ([F:ITC]OVETOT - [F:ITC]OVELEVCST)
MATTOT = sum([F:ITC]MATLEVCST)

Return

################################################################
# Crée les TXNTYP=14 de chaque nature de FG à partir de ITC
$COST_NAT
If ITC_TOT=0
    Return
Endif

Local Decimal SAV_QTY, SAV_QTYACT, SAV_REJQTY
SAV_QTY    = [F:MWI]QTY
SAV_QTYACT = [F:MWI]QTYACT
SAV_REJQTY = [F:MWI]REJQTY
Raz [F:MWI]QTY,[F:MWI]QTYACT,[F:MWI]REJQTY

For [ICN] Where STOFCY=[F:ITC]STOFCY
&             & ITMREF=[F:ITC]ITMREF
&             & CSTTYP=[F:ITC]CSTTYP
&             & ITCSEQ=[F:ITC]ITCSEQ
&             & UID   =0

    Raz [F:MWI]CSTELM,[F:MWI]AMOUNT

    [F:MWI]OVENAT = [F:ICN]OVENAT

    # Issue 90406 - 2013-06-12 by CCC : 4..7 = mono-niveau  ;  12..15 = multi-niveaux
    # On n'alimente pas avec les FG d'entrée des matières (indice 6) car  ils sont inclus dans la valeur de la matière
    [F:MWI]CSTELM(12) = arr((X_AMOUNT * ([F:ICN]NATAMTLEV(2)+[F:ICN]NATAMTSSE(2))) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(13) = arr((X_AMOUNT * ([F:ICN]NATAMTLEV(4)+[F:ICN]NATAMTSSE(4))) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(14) = arr((X_AMOUNT * ([F:ICN]NATAMTLEV(3)+[F:ICN]NATAMTSSE(3))) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(15) = arr((X_AMOUNT * ([F:ICN]NATAMTLEV(5)+[F:ICN]NATAMTSSE(5))) / ITC_TOT,L_CURRND)

    [F:MWI]CSTELM(4) = arr((X_AMOUNT * [F:ICN]NATAMTLEV(2)) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(5) = arr((X_AMOUNT * [F:ICN]NATAMTLEV(4)) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(6) = arr((X_AMOUNT * [F:ICN]NATAMTLEV(3)) / ITC_TOT,L_CURRND)
    [F:MWI]CSTELM(7) = arr((X_AMOUNT * [F:ICN]NATAMTLEV(5)) / ITC_TOT,L_CURRND)

    If dim(GOVEPRD)<=0 | !GOVEPRD
        [F:MWI]CSTELM(12) += arr((X_AMOUNT * ([F:ICN]NATAMTLEV(1)+[F:ICN]NATAMTSSE(1))) / ITC_TOT,L_CURRND)
        [F:MWI]CSTELM(4) += arr((X_AMOUNT * [F:ICN]NATAMTLEV(1)) / ITC_TOT,L_CURRND)
    Endif

# Issue 90406 - 2013-06-12 by CCC : 4..7 = mono-niveau  ;  12..15 = multi-niveaux
#    # CCC (2010-04-21) Bug 63524 : Le montant doit être égal au coût du niveau car les sous-niveaux sont déjà dans la part matière
#    #[F:MWI]AMOUNT = sum([F:MWI]CSTELM(4..7))
#    [F:MWI]AMOUNT = sum([F:MWI]CSTELM(12..15))
    [F:MWI]AMOUNT = sum([F:MWI]CSTELM(4..7))

    If [F:MWI]AMOUNT<>0
        Call ECR_MWI
        LAST_SEQ=[F:MWI]WIPSEQ : # LAST_SEQ+=1 # GH 02/2016 bug 108954 incrementation for WIPCOST
        [F:MWI]WIPSEQ    = LAST_SEQ + 1
    Endif
Next
Raz [F:MWI]CSTELM,[F:MWI]AMOUNT,[F:MWI]OVENAT

[F:MWI]QTY = SAV_QTY
[F:MWI]QTYACT = SAV_QTYACT
[F:MWI]REJQTY = SAV_REJQTY

Return

################################################################
# Crée les TXNTYP=14 de chaque nature de FG à partir de MFC
$CPP_NAT
If MFC_TOT=0
    Return
Endif

Local Decimal SAV_QTY, SAV_QTYACT, SAV_REJQTY
SAV_QTY    = [F:MWI]QTY
SAV_QTYACT = [F:MWI]QTYACT
SAV_REJQTY = [F:MWI]REJQTY
Raz [F:MWI]QTY,[F:MWI]QTYACT,[F:MWI]REJQTY

For [MCN] Where STOFCY=[F:MFC]STOFCY
&             & ITMREF=[F:MFC]ITMREF
&             & VCRTYP=[F:MFC]VCRTYP
&             & VCRNUM=[F:MFC]VCRNUM
&             & VCRLIN=[F:MFC]VCRLIN
&             & MFCTYP=[F:MFC]MFCTYP
&             & UID   =0

    Raz [F:MWI]CSTELM,[F:MWI]AMOUNT

    [F:MWI]OVENAT = [F:MCN]OVENAT

    # Issue 90406 - 2013-06-12 by CCC : 4..7 = mono-niveau  ;  12..15 = multi-niveaux
    [F:MWI]CSTELM(12) = arr((X_AMOUNT * ([F:MCN]NATAMTLEV(2)+[F:MCN]NATAMTSSE(2))) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(13) = arr((X_AMOUNT * ([F:MCN]NATAMTLEV(4)+[F:MCN]NATAMTSSE(4))) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(14) = arr((X_AMOUNT * ([F:MCN]NATAMTLEV(3)+[F:MCN]NATAMTSSE(3))) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(15) = arr((X_AMOUNT * ([F:MCN]NATAMTLEV(5)+[F:MCN]NATAMTSSE(5))) / MFC_TOT,L_CURRND)

    [F:MWI]CSTELM(4) = arr((X_AMOUNT * [F:MCN]NATAMTLEV(2)) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(5) = arr((X_AMOUNT * [F:MCN]NATAMTLEV(4)) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(6) = arr((X_AMOUNT * [F:MCN]NATAMTLEV(3)) / MFC_TOT,L_CURRND)
    [F:MWI]CSTELM(7) = arr((X_AMOUNT * [F:MCN]NATAMTLEV(5)) / MFC_TOT,L_CURRND)

    If dim(GOVEPRD)<=0 | !GOVEPRD
        [F:MWI]CSTELM(12) += arr((X_AMOUNT * ([F:MCN]NATAMTLEV(1)+[F:MCN]NATAMTSSE(1))) / MFC_TOT,L_CURRND)
        [F:MWI]CSTELM(4) += arr((X_AMOUNT * [F:MCN]NATAMTLEV(1)) / MFC_TOT,L_CURRND)
    Endif

    # Issue 90406 - 2013-06-12 by CCC : 4..7 = mono-niveau  ;  12..15 = multi-niveaux
#    # CCC (2010-04-21) Bug 63524 : Le montant doit être égal au coût du niveau car les sous-niveaux sont déjà dans la part matière
#    #[F:MWI]AMOUNT = sum([F:MWI]CSTELM(4..7))
#    [F:MWI]AMOUNT = sum([F:MWI]CSTELM(12..15))
    [F:MWI]AMOUNT = sum([F:MWI]CSTELM(4..7))

    If [F:MWI]AMOUNT<>0
        Call ECR_MWI
        LAST_SEQ=[F:MWI]WIPSEQ : # LAST_SEQ+=1 # GH 02/2016 bug 108954 incrementation for WIPCOST
        [F:MWI]WIPSEQ    = LAST_SEQ + 1
    Endif
Next

Raz [F:MWI]CSTELM,[F:MWI]AMOUNT,[F:MWI]OVENAT

[F:MWI]QTY = SAV_QTY
[F:MWI]QTYACT = SAV_QTYACT
[F:MWI]REJQTY = SAV_REJQTY

Return

# sous-programme banalisé d'écriture dans WIPCOST
###########################################################################
Subprog ECR_MWI
[F:MWI]JOUTYP    = ""
[F:MWI]JOUNUM    = ""
[F:MWI]GLPSTA    = 1    # Issue 103662 - 2014-10-30 by CCC
[F:MWI]EXPNUM    = [C]EXPORT

[F:MWI]CREDAT    = date$
[F:MWI]CREUSR    = GUSER
[F:MWI]UPDDAT    = [0/0/0]
[F:MWI]UPDUSR    = ""

Call CHARG_CCE

# Intégrer le point d'entrée pour calcul spécifique
GPOINT = "BEFWRIMWI"
Gosub ENTREE From EXEFNC

$WR_MWI
Write [MWI]
If fstat=3 : # GH 02/2016 bug 108954 creation done by another simultaneous transaction is not detectable
   [F:MWI]WIPSEQ+=1
   Goto WR_MWI
Endif
If fstat
    End
Endif

# le PRF devra être recalculé avec la somme des delta (par la fct FUNMFCSCO)
# remettre le MFGTRKFLG de MWH à 'non calculé'
If [F:MWI]VCRTYP<>[F:MWH]VCRTYP | [F:MWI]VCRNUM<>[F:MWH]VCRNUM
    Read [MWH]MWH0=[F:MWI]VCRTYP;[F:MWI]VCRNUM
Endif
# Issue 101596 GA 09/2014 #If [F:MWH]MFGTRKFLG = 6
If [F:MWH]MFGTRKFLG = 6 & ([F:MWI]AMOUNT<>0 | [F:MWI]QTY<>0)
    Readlock [MWH]MWH0=[F:MWI]VCRTYP;[F:MWI]VCRNUM
    If fstat
        Call FSTA("MWH") From GLOCK
        GOK=0
    Else
        [F:MWH]MFGTRKFLG = 5
        Rewrite [MWH]
        If fstat
            Call FSTA("MWH") From GLOCK
            GMESSAGE = mess(13,100,1) - "MFGWIP :"-num$([F:MWH]VCRTYP)-[F:MWH]VCRNUM
            GOK=0
        Endif
    Endif
  # Issue 101597 GA 09/2014 to be added ?
  #### If GOK Gosub UPDATE_CLC Endif
Endif
Raz fstat
End


###########################################################################
# Calcule le montant hors FG à partir d'un motant avec FG
#!!!!Ce calcul ne se fait que lorsque la base de calcul des FG est un montant!!!!
Funprog CALBAS(LCURRND, LOVECOD, LMNT)
Value Decimal LCURRND
Value Char    LOVECOD
Value Decimal LMNT


Local Integer I_NAT
Local Decimal LBAS, LFIXSUM, LVARSUM
Local Char    COL(1), OH_COD_FOR(3)

If !clalev([F:OVE]) : Local File OVERHEAD    [OVE] : Endif
If !clalev([F:ONA]) : Local File OVENAT      [ONA] : Endif
If !clalev([F:TFO]) : Local File TABFOR      [TFO] : Endif

# Use global variable to determine which column is being used in the formulas
Case GOVECOLMFC
    When 1 : COL = "A"
    When 2 : COL = "B"
    When 3 : COL = "C"
    When 4 : COL = "D"
Endcase
# Read overhead table
Read [OVE]OVE0 = LOVECOD
If fstat
  ERR = 1
  Call FSTA("OVE") From GLOCK
  End
Endif

Onerrgo ERR_FOR

# Si la base est une quantité ou un temps => on ne fait rien
# car on n'en a pas l'utilité pour l'instant!!
If [F:OVE]FORBASIS=2
    End LMNT
Endif

If [F:OVE]CLCMOD = 1                    # When the calculated mode is Accumulative
    For I_NAT = 0 To dim([F:OVE]OVENAT) - 1
        If evalue("[F:OVE]FXDOVE"+COL+"(I_NAT)") <> 0 & [F:OVE]OVENAT(I_NAT) <> ""
            LFIXSUM += arr(evalue("[F:OVE]FXDOVE"+COL+"("+num$(I_NAT)+")"),LCURRND)
        Elsif [F:OVE]OVENAT(I_NAT) <> ""
            OH_COD_FOR = evalue("[F:OVE]FORCOD"+COL+"("+num$(I_NAT)+")")
            Read [TFO]TFO0 = 5;OH_COD_FOR
            If !fstat
                LVARSUM += evalue([F:TFO]FORFOR)
            Endif
        Endif
    Next
    LBAS = (LMNT-LFIXSUM)/(1+LVARSUM)
Else
    LBAS = LMNT
    For I_NAT = dim([F:OVE]OVENAT) - 1 To 0 Step -1
        If evalue("[F:OVE]FXDOVE"+COL+"(I_NAT)") <> 0 & [F:OVE]OVENAT(I_NAT) <> ""
            LBAS -= arr(evalue("[F:OVE]FXDOVE"+COL+"("+num$(I_NAT)+")"),LCURRND)
        Elsif [F:OVE]OVENAT(I_NAT) <> ""
            OH_COD_FOR = evalue("[F:OVE]FORCOD"+COL+"("+num$(I_NAT)+")")
            Read [TFO]TFO0 = 5;OH_COD_FOR
            If !fstat
                LBAS = LBAS/(1+ evalue([F:TFO]FORFOR))
            Endif
        Endif
    Next
Endif

# Les FG ne peuvent pas être négatifs.
# Si la base et le montant n'ont pas le même signe
# c'est à cause des erreurs d'arrondi et il vaut mieux mettre 0
# car sinon cela peut générer des problèmes de signe par la suite
# Maintenance liée au bug 26297
If LMNT<0
    LBAS=min(LBAS,0)
Else
    LBAS=max(LBAS,0)
Endif

End LBAS

Subprog CHARG_CCE
Local Char    LCCECOD(50)
Local Integer I
If !clalev([F:CAL]) : Local File CPTANALIN [CAL] : Endif

    # Dans le cas des EO on crée les enreg CAL car les réceptions ont les leurs
    # Dans le cas des OF, on récupère les sections définies dans les suivis.
    Case [F:MWI]VCRTYP
        When 10,37    : # OF, Suivi sans OF (FQ 76432)
            Case [F:MWI]TXNTYP
                When 1 :       # Suivi matière -> récupération des sections ana dans MKM
                    If [F:MWI]MFGTRKNUM=""
                        LCCECOD="MKM"
                    Else
                        Read [CAL] CAL0="MKM";0;[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN;0;"";1
                        If !fstat
                            For I=0 To dim([F:MWI]CCE)-1
                                [F:MWI]DIE(I) = [F:CAL]DIE(I)
                                [F:MWI]CCE(I) = [F:CAL]CCE(I)
                            Next
                        Endif
                    Endif
                When 2,3,4 :   # Suivi opé     -> récupération des sections ana dans MKO - Poste courant
                    # FQ 66275 GA 07/2010 pb de relecture CAL pour MKO
                    # Read [CAL] CAL0="MKO";0;[F:MKO]MFGTRKNUM;[F:MKO]OPETRKLIN;0;"";1
                    Read [CAL] CAL0="MKO";0;[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN;0;[F:MWI]WST;1
                    If !fstat
                        For I=0 To dim([F:MWI]CCE)-1
                            [F:MWI]DIE(I) = [F:CAL]DIE(I)
                            [F:MWI]CCE(I) = [F:CAL]CCE(I)
                        Next
                    Endif
                When 5   : LCCECOD = "MWIOVEMAT"    # 5= matière et PF, mais la valeur 0 est aussi utilisée dans FUNWIPMFC.UPDMWIOVE
                When 6,7 : LCCECOD = "MWIOVEWST"
                When 8   : LCCECOD = "MWIOVESCO"
                When 14 :      # Suivi production -> récupération des sections ana dans MKI
                    Read [CAL] CAL0="MKI";0;[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN;0;"";1
                    If !fstat
                        For I=0 To dim([F:MWI]CCE)-1
                            [F:MWI]DIE(I) = [F:CAL]DIE(I)
                            [F:MWI]CCE(I) = [F:CAL]CCE(I)
                        Next
                    Endif

                When 15 : Call PARAM([F:MWI]MFGFCY,"BALCCE",LCCECOD) From ADOVAL
                When 16 : LCCECOD = "MWISCP"
                When 17 :
                    Read [CAL] CAL0="MFI";0;[F:MWI]VCRNUM;[F:MWI]VCRLIN;0;"";1
                    If !fstat
                        For I=0 To dim([F:MWI]CCE)-1
                            [F:MWI]DIE(I) = [F:CAL]DIE(I)
                            [F:MWI]CCE(I) = [F:CAL]CCE(I)
                        Next
                    Endif
            Endcase

        When 36    : # EO
            Case [F:MWI]TXNTYP
                When 1   : LCCECOD = "MWISCM"
                When 4   : LCCECOD = "MWISCS"
                When 5   : LCCECOD = "SCOOVEMAT"
                #When 6,7 : Ne peut pas se produire
                When 8   : LCCECOD = "SCOOVESCO"
                When 14  : LCCECOD = "MWISCI"
                When 15  : Call PARAM([F:MWI]MFGFCY,"BALCCE",LCCECOD) From ADOVAL
                When 17 :
                    Read [CAL] CAL0="SCI";36;[F:MWI]VCRNUM;[F:MWI]VCRLIN;0;"";1
                    If !fstat
                        For I=0 To dim([F:MWI]CCE)-1
                            [F:MWI]DIE(I) = [F:CAL]DIE(I)
                            [F:MWI]CCE(I) = [F:CAL]CCE(I)
                        Next
                    Endif

            Endcase
    Endcase
    Case [F:MWI]TXNTYP
        When 9  : Call PARAM([F:MWI]MFGFCY,"MATVARCCE",LCCECOD) From ADOVAL
        When 10 : Call PARAM([F:MWI]MFGFCY,"LABVARCCE",LCCECOD) From ADOVAL
        When 11 : Call PARAM([F:MWI]MFGFCY,"OPEVARCCE",LCCECOD) From ADOVAL
        When 12 : Call PARAM([F:MWI]MFGFCY,"SCOVARCCE",LCCECOD) From ADOVAL
        When 13 : Call PARAM([F:MWI]MFGFCY,"OVEVARCCE",LCCECOD) From ADOVAL
        When 18 : Call PARAM([F:MWI]MFGFCY,"WIPBALCCE",LCCECOD) From ADOVAL
        When 19,20 : Call PARAM([F:MWI]MFGFCY,"INVVARCCE",LCCECOD) From ADOVAL
    Endcase

    If LCCECOD<>""
        For I=1 To GNBDIE
            Call INIT_CCE([F:MWI]CCE(I-1),I,LCCECOD,"",0) From TRTX3CPT
            [F:MWI]DIE(I-1) = GDIE(I)
        Next
    Endif
End

############################################################
# SUMINVDTA : Retourne le montant total des éléments de facturation pour une entrée donnée
############################################################
# Parametres E : PVCRTYP = type document (10=OF, 36=EO)
#              : PVCRNUM = n° de document
#              : PTRKNUM = n° document d'entrée
#              : PTRKLIN = ligne document d'entrée
############################################################
Funprog SUMINVDTA(PVCRTYP, PVCRNUM, PTRKNUM, PTRKLIN)
Value Integer PVCRTYP
Value Char PVCRNUM
Value Char PTRKNUM
Value Integer PTRKLIN

Local Decimal LINV

If !clalev([F:MWI]) : Local File WIPCOST [MWI] : Endif

For [MWI] Where VCRTYP = PVCRTYP
&             & VCRNUM = PVCRNUM
&             & MFGTRKNUM = PTRKNUM
&             & MFGTRKLIN = PTRKLIN
&             & TXNTYP = 19
    LINV += [F:MWI]AMOUNT
Next

End LINV

