#<AdxTL>@(#)7.0.0.0 $Revision$
##############################################################################
## Init option F sur type de donnéés AGF
##############################################################################
Call OUVRE_TRACE("Update AGF") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Gosub MAJ
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

$MAJ
Local Integer K , VALMOD(20)
Local File =DOSSIER+".AMSKZON" [AMZ]
Trbegin [AMZ]
 For [AMZ] Where CODTYP="AGF" & CODMSK<>"FGR0"
  K = instr(1,[F:AMZ]OPTOBJ,"F")
  If K
   [F:AMZ]OPTOBJ = left$([F:AMZ]OPTOBJ,K-1)+right$([F:AMZ]OPTOBJ,K+1)
   Rewrite [AMZ]
   Call ECR_TRACE("Update"-[F:AMZ]CODMSK-[F:AMZ]CODZON,0) From GESECRAN
  Endif
 Next AMZ
Commit
If DOSSIER<>GDOSX3
 For K=0 To dim(VALMOD)-1
  VALMOD(K) = 2
 Next K
 Call VALID_TRT(DOSSIER,0,"AGF","","","","","","","ZZZZZ","","","","","","","","","","","","",VALMOD) From VALDICO
Endif
Return
