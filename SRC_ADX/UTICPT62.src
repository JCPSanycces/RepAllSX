#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTICPT62   UTI process                                    Module CPT   #
#            Update BLOCK (4=>6 & 6=>4) for specific field
##########################################################################

If clalev([F:ADS])=0  
    Local File ADOSSIER [ADS] 
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER 
  If fstat <> 0 
        Raz [F:ADS] 
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT62(WDOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT62(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR
Call ECR_TRACE("UTICPT62 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:AMZ])  =0  Local File =DOSSIER+".AMSKZON"   [AMZ] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [AMZ]
Filter [AMZ] Where CODMSK="GACCENTR2" & CODZON>="X" & CODACT<>""

For [AMZ]
   Readlock [AMZ] Curr    
   If fstat = 0
      # --- fields and rewrite 
      If [F:AMZ]NUMBLOC=4
       [F:AMZ]NUMBLOC=6
      Elsif [F:AMZ]NUMBLOC=6 
       [F:AMZ]NUMBLOC=4
      Endif
      Rewrite [F:AMZ]
      If !fstat WCOMPTEUR += 1 Endif
   Endif
Next
Commit

Filter [AMZ]
Close Local File [AMZ]

Call ECR_TRACE("UTICPT62 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT62 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI 
If fstat : Raz [F:ADS] : Endif
If [F:ADS]MODULE(1)<>2 : End : Endif                                 : # Module Comptabilité

If filinfo(filpath("FIL","AMSKZON","fde",APPLI),0)<=0 : End : Endif  :  

Call MAJ_UTICPT62(APPLI)        
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(1)<>2 : End : Endif                                 : # Module Comptabilité
If filinfo(filpath("FIL","AMSKZON","fde",APPLI),0)<=0 : End : Endif  

Call MAJ_UTICPT62(APPLI)        
End




