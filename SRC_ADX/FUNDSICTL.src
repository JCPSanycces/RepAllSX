#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask management DSICTL
$ACTION

Case ACTION
  When "DEBUT"       : Gosub DEBUT
  When "OUVRE_BATCH" : Gosub OUVRE
  When "INIT"        : Gosub OUVRE
  When "OK"          : FIN = 1 : GOK = 1
  When "END"         : FIN = 1 : GOK = 0
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
Endcase

Return
######################################################################################
######################################################################################
$OPENTABLES
If !clalev([F:BPA]) : Local File BPADDRESS  [BPA] : Endif
If !clalev([F:BPR]) : Local File BPARTNER   [BPR] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:DKF]) : Local File DKSDATAFRA [DKF] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([F:HAE]) : Local File GACCENTRY  [HAE] : Endif
If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
If !clalev([F:JOU]) : Local File GJOURNAL   [JOU] : Endif
If !clalev([F:SIH]) : Local File SINVOICE   [SIH] : Endif
Return
######################################################################################
######################################################################################
$DEBUT

Raz [M:DIA] : Affzo [DIA]
zonsui="CPY"
Setmok [DIA] With 0

Return
######################################################################################
######################################################################################
$OUVRE
Gosub OPENTABLES
Local Char     CRITERE(250)
Local Char     JOUDES(GLONDES)
Local Char     AUXLEG(GLONADI)
Local Char     MESTOSIGN(255)(3)
Local Shortint CUR_MES_IDX
Local Integer  LEDT
Local Char     DIG_SIGNATURE(250)(2)
Local Integer  NBOKSIH, NBNOKSIH, NBOKDAE, NBNOKDAE, NBNFDDAE, NFD_FLG
Local Char     DOC_NUMBER(250)
Local Integer  OUT_CODE
Local Char     OUT_MESSAGE(255)
Local Clbfile  OUT_VAL

TIT = mess(248,7711,1)

If GSERVEUR
  Onerrgo ERRBATCH
Endif

Local Mask DSICTL [DIA]
Raz [M:DIA]

Return
######################################################################################
######################################################################################
$CONTROLE
If GOK < 1
  FIN = 1
Else
  TMP = 1
Endif
Return
######################################################################################
######################################################################################
$EXEC

Call OUVRE_TRACE(mess(248,7711,1))  From LECFIC
Call ECR_TRACE(" ",0)              From GESECRAN
Call ECR_TRACE(string$(70,"-"),0)  From GESECRAN
Call PRTSCR("DSICTL","DIA","",0,1) From ATRTX3
Call ECR_TRACE(string$(70,"-"),0)  From GESECRAN
Call ECR_TRACE(" ",0)              From GESECRAN

CRITERE(0) -= '[F:DKF]CPY = "' + [M:DIA]CPY + '"'
If [M:DIA]ALLTYP <> 2
  CRITERE(0) -= '& [F:DKF]ORIDOC = ' + num$([M:DIA]DOCTYP)
Endif
If [M:DIA]STRDAT <> [0/0/0]
  CRITERE(0) -= '& [F:DKF]ACCDAT >= [M:DIA]STRDAT'
Endif
If [M:DIA]ENDDAT <> [0/0/0]
  CRITERE(0) -= '& [F:DKF]ACCDAT <= [M:DIA]ENDDAT'
Endif
If [M:DIA]ALLBP <> 2
  CRITERE(0) -= '& [F:DKF]BPR = "' + [M:DIA]BPRNUM + '"'
Endif

NBOKSIH = 0
NBOKDAE = 0

NBNOKSIH = 0
NBNOKDAE = 0

NBNFDDAE = 0

For [F:DKF] Where evalue(CRITERE(0))
  NEXT_STEP = 1
  GOK = 1 : NFD_FLG = 0
  [L]MESTOSIGN = ""
  [L]CUR_MES_IDX = 0

  If [F:DKF]ORIDOC = 1
    [L]DOC_NUMBER = func AFNC.MES1(mess(280,7711,1), [F:DKF]DOCNUM)
    Read [F:SIH]SIH0 = [F:DKF]DOCNUM
    If !fstat
      If [F:DKF]FCY <> [F:SIH]FCY
        GOK = 0
        Call ECR_TRACE([L]DOC_NUMBER - mess(255,7711,1), 1) From GESECRAN
      Endif
      For I = 0 To dim ([F:SIH]AMTTAX)-1
        If [F:SIH]AMTTAX(I)<>0 or [F:SIH]BASTAX(I)<>0
          If [F:DKF]AMTTAX(I) <> [F:SIH]AMTTAX(I)
            GOK = 0
            Call ECR_TRACE([L]DOC_NUMBER - mess(256,7711,1), 1) From GESECRAN
          Endif
          If [F:DKF]BASTAX(I) <> [F:SIH]BASTAX(I)
            GOK = 0
            Call ECR_TRACE([L]DOC_NUMBER - mess(257,7711,1), 1) From GESECRAN
          Endif
          Call ADD_VAL(num$([F:DKF]BASTAX(I))+":"+num$([F:DKF]AMTTAX(I))+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Endif
      Next
      If [F:DKF]AMTATI <> [F:SIH]AMTATI
        GOK = 0
        Call ECR_TRACE([L]DOC_NUMBER - mess(258,7711,1), 1) From GESECRAN
      Endif
      If [F:DKF]SNS <> [F:SIH]SNS
        GOK = 0
        Call ECR_TRACE([L]DOC_NUMBER - mess(259,7711,1), 1) From GESECRAN
      Endif

      Call LEC_CPY([F:SIH]CPY) From CPTLEC
      If [F:DKF]CPYNAM <> [F:CPY]CPYNAM
        GOK = 0
        Call ECR_TRACE([L]DOC_NUMBER - mess(260,7711,1), 1) From GESECRAN
      Endif
      If [F:DKF]CPYEECNUM <> [F:CPY]EECNUM
        GOK = 0
        Call ECR_TRACE([L]DOC_NUMBER - mess(261,7711,1), 1) From GESECRAN
      Endif
      If [F:DKF]BPRNAM(0) <> [F:SIH]BPRNAM(0)
        GOK = 0
        Call ECR_TRACE([L]DOC_NUMBER - mess(262,7711,1), 1) From GESECRAN
      Endif
      If [F:DKF]BPRNAM(1) <> [F:SIH]BPRNAM(1)
        GOK = 0
        Call ECR_TRACE([L]DOC_NUMBER - mess(262,7711,1), 1) From GESECRAN
      Endif
      If [F:DKF]POSCOD <> [F:SIH]POSCOD
        GOK = 0
        Call ECR_TRACE([L]DOC_NUMBER - mess(263,7711,1), 1) From GESECRAN
      Endif

      Call ADD_VAL(num$([F:DKF]AMTATI)+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
      Call ADD_VAL([F:DKF]DSIDATTIM+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB

      Call ADD_VAL([F:DKF]DOCNUM+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
      If [F:DKF]SNS = 1
        Call ADD_VAL("FACTURE|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
      Else
        Call ADD_VAL("AVOIR|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
      Endif
      Call ADD_VAL([F:CPY]CPYNAM+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB

      Filter [F:BPA] Where [F:BPA]BPANUM = [F:CPY]CPY & [F:BPA]BPAADDFLG = 2 & [F:BPA]BPATYP = 2
      Read [F:BPA] First
      If !fstat
        If [F:DKF]CPYPOSCOD <> [F:BPA]POSCOD
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(264,7711,1), 1) From GESECRAN
        Endif
        Call ADD_VAL([F:DKF]CPYPOSCOD + "|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
      Endif

      Call ADD_VAL([F:DKF]CPYEECNUM+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
      Call ADD_VAL([F:DKF]BPRNAM(0)+string$([F:DKF]BPRNAM(1)<>""," "+[F:DKF]BPRNAM(1))+"|",
&                  MESTOSIGN,CUR_MES_IDX) From FRADSILIB

      Call ADD_VAL([F:DKF]POSCOD,MESTOSIGN,CUR_MES_IDX) From FRADSILIB

      Gosub VALIDATE_SIGNATURE
    Endif
    If GOK = 1
      NBOKSIH += 1
    Else
      NBNOKSIH += 1
    Endif
  Else
    [L]DOC_NUMBER = func AFNC.MES2(mess(249,7711,1), [F:DKF]DOCNUM, num$([F:DKF]LIN))
    Read [F:HAE]HAE0 = [F:DKF]DOCTYP;[F:DKF]DOCNUM
    If !fstat
      Call LECLEDMAIN(1, [F:HAE]CPY, [L]LEDT) From CPTDIV
      Call LEC_JOU([F:HAE]JOU) From CPTLEC
      If GNBLEG=1 : AUXLEG = GDOSLEG(1) : Else : AUXLEG = [F:JOU]LEG : Endif
      Call LECTEXTRA([L]JOUDES,"GJOURNAL","DESTRA",[F:HAE]JOU,[L]AUXLEG) From ATEXTRA

      Read [F:DAE]DAE0 = [F:DKF]DOCTYP;[F:DKF]DOCNUM;[F:DKF]LIN;[L]LEDT
      If !fstat
        If [F:DKF]JOU <> [F:HAE]JOU
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(265,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]JOUDES <> [L]JOUDES
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(266,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]FNLPSTNUM <> [F:HAE]FNLPSTNUM([L]LEDT-1)
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(267,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]ACCDAT <> [F:HAE]ACCDAT
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(268,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]ACC <> [F:DAE]ACC
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(269,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]BPR <> [F:DAE]BPR
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(270,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]BPR <> ""
          If [F:BPR]BPRNUM <> [F:DKF]BPR
            Read [F:BPR]BPR0 = [F:DKF]BPR
          Endif
        Endif

        If [F:DKF]BPRNAM(0) <> [F:BPR]BPRNAM(0)
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(271,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]BPRNAM(1) <> [F:BPR]BPRNAM(1)
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(271,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]DOCNUM <> [F:HAE]NUM
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(272,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]AMTLED <> [F:DAE]AMTLED
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(273,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]SNS <> [F:DAE]SNS
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(274,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]FNLPSTDAT <> [F:HAE]FNLPSTDAT([L]LEDT-1)
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(275,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]AMTCUR <> [F:DAE]AMTCUR*[F:DAE]SNS
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(276,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]CUR <> [F:DAE]CUR
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(277,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]FCY <> [F:DAE]FCYLIN
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(278,7711,1), 1) From GESECRAN
        Endif
        If [F:DKF]DES <> string$([F:DAE]DES<>'', [F:DAE]DES) + string$([F:DAE]DES='', 'NA')
          GOK = 0
          Call ECR_TRACE([L]DOC_NUMBER - mess(279,7711,1), 1) From GESECRAN
        Endif

        Call ADD_VAL([F:DKF]JOU+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL([F:DKF]JOUDES+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL([F:DKF]FNLPSTNUM+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL(format$("D:YYYYMMDD",[F:DKF]ACCDAT)+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL([F:DKF]ACC+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL([F:DKF]BPR+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL([F:DKF]BPRNAM(0)+string$([F:DKF]BPRNAM(1)<>""," "+[F:DKF]BPRNAM(1))+"|",
&                    MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL([F:DKF]DOCNUM+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL(num$([F:DKF]LIN)+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL(string$([F:DKF]DES<>"", [F:DKF]DES)+string$([F:DKF]DES="","NA")+"|",
&                    MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL(func FRADSILIB.GET_MONFLD([F:DKF]AMTLED) +"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL(string$([F:DKF]SNS=-1,"-1")+string$([F:DKF]SNS=1,"+1")+"|",
&                    MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL(format$("D:YYYYMMDD",[F:DKF]FNLPSTDAT)+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call LEC_CPY([F:DKF]CPY) From CPTLEC
        Call ADD_VAL(string$([F:DKF]CUR<>[F:CPY]ACCCUR, func FRADSILIB.GET_MONFLD([F:DKF]AMTCUR))
&                    +"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL(string$([F:DKF]CUR<>[F:CPY]ACCCUR, [F:DKF]CUR)+"|",MESTOSIGN,CUR_MES_IDX) From FRADSILIB
        Call ADD_VAL([F:DKF]FCY,MESTOSIGN,CUR_MES_IDX) From FRADSILIB

        Gosub VALIDATE_SIGNATURE
      Endif
    Else
      NFD_FLG = 1
      If [F:DKF]LIN = 1
        Call ECR_TRACE(func AFNC.MES2(mess(281,7711,1), [F:DKF]DOCTYP, [F:DKF]DOCNUM),-1) From GESECRAN
        NBNFDDAE += 1
      Endif
    Endif
    If !NFD_FLG
      If GOK = 1
        NBOKDAE += 1
      Else
        NBNOKDAE += 1
      Endif
    Endif
  Endif
Next

Call ECR_TRACE(" ",0)              From GESECRAN
Call ECR_TRACE(func AFNC.MES1(mess(251,7711,1), num$(NBOKSIH)), 0) From GESECRAN
Call ECR_TRACE(func AFNC.MES1(mess(252,7711,1), num$(NBOKDAE)), 0) From GESECRAN
Call ECR_TRACE(" ",0)              From GESECRAN

If NBNFDDAE
  Call ECR_TRACE(func AFNC.MES1(mess(282,7711,1), num$(NBNFDDAE)), -1) From GESECRAN
  Call ECR_TRACE(" ",0)              From GESECRAN
Endif

If NBNOKSIH
  Call ECR_TRACE(func AFNC.MES1(mess(253,7711,1), num$(NBNOKSIH)), 1) From GESECRAN
  GERRTRACE -= 1
Endif
If NBNOKDAE
  Call ECR_TRACE(func AFNC.MES1(mess(254,7711,1), num$(NBNOKDAE)), 1) From GESECRAN
  GERRTRACE -= 1
Endif

Call FERME_TRACE From LECFIC
TRA=1
Return
######################################################################################
######################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
Return
######################################################################################
######################################################################################
$VALIDATE_SIGNATURE
[L]DIG_SIGNATURE(0) = [F:DKF]DIGSIGN(0)
[L]DIG_SIGNATURE(1) = [F:DKF]DIGSIGN(1)
Raz [L]OUT_VAL, [L]OUT_MESSAGE

Gosub VERIFY_SIGNATURE From FRADSILIB

If [L]OUT_VAL <> "true"
  GOK = 0
  If [L]OUT_VAL = "false"
    Call ECR_TRACE([L]DOC_NUMBER - mess(250,7711,1), 1) From GESECRAN
  Else
    Call ECR_TRACE([L]DOC_NUMBER - [L]OUT_MESSAGE, 1) From GESECRAN
  Endif
Endif

Return
######################################################################################
######################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & ([M]ENDDAT=[0/0/0] | [M]ENDDAT<VALEUR)
  [M]ENDDAT=VALEUR
Endif
End
######################################################################################
######################################################################################
Subprog D_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : [M]DOCTYP = 0 : Diszo [M]DOCTYP : Affzo [M]DOCTYP : Else : Actzo [M]DOCTYP : Endif
End
######################################################################################
######################################################################################
Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : [M]DOCTYP = 0 : Diszo [M]DOCTYP : Affzo [M]DOCTYP : Else : Actzo [M]DOCTYP : Endif
End
######################################################################################
######################################################################################
Subprog AS_DOCTYP(VALEUR)
Variable Integer VALEUR
If [M]ALLTYP=2 : mkstat = 1 : End : Endif
End
######################################################################################
######################################################################################
Subprog D_ALLBP(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Raz [M]BPRNUM : Diszo [M]BPRNUM : Affzo [M]BPRNUM : Else : Actzo [M]BPRNUM : Endif
End
######################################################################################
######################################################################################
Subprog C_ALLBP(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Raz [M]BPRNUM : Diszo [M]BPRNUM : Affzo [M]BPRNUM : Else : Actzo [M]BPRNUM : Endif
End
######################################################################################
######################################################################################
Subprog AS_BPRNUM(VALEUR)
Variable Char    VALEUR()
If [M]ALLBP = 2 : mkstat = 1 : End : Endif
End
######################################################################################
######################################################################################

