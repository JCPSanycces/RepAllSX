#<AdxTL>@(#)2.0.0.0 $Revision$
# Gestion du masque ORDWIPVAL

######################################################################################
## Etiquette ajoutée par le superviseur (écran ORDWIPVAL) 26/07/2006 10:30:54 (CCC)
######################################################################################
$ACTION
Case ACTION
 When "INIT_DIA" : Gosub INIT_DIA
 When "EXEC"     : Gosub EXEC
Endcase
Return

$INIT_DIA
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
If !clalev([F:MFG]) : Local File MFGHEAD  [MFG] : Endif
If !clalev([F:SCO]) : Local File SCOHEAD  [SCO] : Endif
[M:OWV]NPRNAM = "WIPVAL"
# FQ 62959 GA 03/2010 Valeur par défaut pour la formule de sélection
If dim([M:OWV]TYPFOR)>0 & dim([M:OWV]FORMULE)>0
    If !clalev([F:ARD]) : Local File AREPORTD  [ARD] : Endif
    Read [ARD]ARD1="vcrtyp";"WIPVAL"
    If !fstat & [F:ARD]PARDEF1<>""
       [M:OWV]VCRTYP=val([F:ARD]PARDEF1)
       Case [M:OWV]VCRTYP
         When 10 : [M:OWV]TYPFOR=38
         When 36 : [M:OWV]TYPFOR=47
       Endcase
    Endif
    Read [ARD]ARD1="formule";"WIPVAL"
    If !fstat & [F:ARD]PARDEF1<>""
       [M:OWV]FORMULE=[F:ARD]PARDEF1
    Endif
Endif
Return

##########################################################################
$EXEC
# Chargement paramètres ETAT
Local  Char    WETAT
Local  Char    WETATP(15)(20)
Local Char     WETATV(50)(20)

I=-1
I+=1 : WETATP(I) = "user"
I+=1 : WETATP(I) = "uid"
I+=1 : WETATP(I) = "cpy"
I+=1 : WETATP(I) = "stofcydeb"
I+=1 : WETATP(I) = "stofcyfin"
I+=1 : WETATP(I) = "vcrtyp"
I+=1 : WETATP(I) = "vcrnumdeb"
I+=1 : WETATP(I) = "vcrnumfin"
I+=1 : WETATP(I) = "ifaflg"
I+=1 : WETATP(I) = "datemax"
I+=1 : WETATP(I) = "detail"                         # GH 28/01/2014 dm 94629
I+=1 : WETATP(I) = "resume"
I+=1 : WETATP(I) = "mfgstadeb"
I+=1 : WETATP(I) = "mfgstafin"
I+=1 : WETATP(I) = "formule"                        # FQ 62959 GA 03/2010
I+=1 : WETATP(I) = "mfgtrkflg"                      # Issue 78010 - 2011-12-22 by CCC

I=-1
I+=1 : WETATV(I) = GUSER
I+=1 : WETATV(I) = num$(adxuid(1))
I+=1 : WETATV(I) = [M:OWV]CPY
I+=1 : WETATV(I) = [M:OWV]STOFCYSTR
I+=1 : WETATV(I) = [M:OWV]STOFCYEND
I+=1 : WETATV(I) = num$([M:OWV]VCRTYP)
I+=1 : WETATV(I) = [M:OWV]VCRNUMSTR+string$([M:OWV]VCRNUMSTR=""," ")    # CCC (2010-02-04) Bug 62262 : la borne début est mal interprétée s'il n'y a aucun caractère
I+=1 : WETATV(I) = [M:OWV]VCRNUMEND+string$([M:OWV]VCRNUMEND="","ZZZZZZZZZZZZZZZ")  # CCC (2010-01-08) DM 61412
I+=1 : WETATV(I) = num$([M:OWV]IFAFLG)
I+=1 : WETATV(I) = num$([M:OWV]DATMAX)
I+=1 : WETATV(I) = num$([M:OWV]PRNCOD2)             # GH 28/01/2014 dm 94629
I+=1 : WETATV(I) = num$([M:OWV]PRNCOD)
I+=1 : WETATV(I) = "1"
I+=1 : WETATV(I) = mid$("14",([M:OWV]MFGSTA=2)+1,1) # 1 si MFGSTA<>2 ou 4 si MFGSTA=4
I+=1 : WETATV(I) = [M:OWV]FORMULE                   # FQ 62959 GA 03/2010
I+=1 : WETATV(I) = string$(([M:OWV]MFGTRKFLG=2),"6,")+"4,5" # Issue 78010 - 2011-12-22 by CCC

If !GSERVEUR
    Call ETAT([M:OWV]NPRNAM,GFONCTION,WETATP,WETATV) From ETAT
Else
    Call ETATDIFF([M:OWV]NPRNAM,[M:OWV]NPRDEN,GLANGUE,GTRACE<>"","",WETATP,WETATV,[0/0/0],"") From AIMP3
Endif
Return

##########################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If find(VALEUR,GSOC(1..GNBSOC))
    GLOCALDEV = GDEVSOC(find(VALEUR,GSOC(1..GNBSOC)))
Endif

Diszo [M:OWV]MFGTRKFLG  # Issue 78010 - 2011-12-22 by CCC : C'est le 1er endroit où on peut le faire

End

######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Read [FCY]FCY0=[M:OWV]STOFCYSTR
If [F:FCY]LEGCPY<>VALEUR
    Effzo [M:OWV]STOFCYSTR,STOFCYEND
Endif
End

##########################################################################
Subprog C_STOFCYSTR(VALEUR)
Variable Char    VALEUR()
Local Integer LOK
Gosub VERIF_FCY
End

Subprog AM_STOFCYSTR(VALEUR)
Variable Char    VALEUR()
Local Integer LOK
If [M]STOFCYSTR=[M]STOFCYEND | VALEUR>[M]STOFCYEND
    [M]STOFCYEND = VALEUR
    Affzo [M]STOFCYEND
Endif
End

Subprog C_STOFCYEND(VALEUR)
Variable Char    VALEUR()
Gosub VERIF_FCY
End

Subprog AM_STOFCYEND(VALEUR)
Variable Char    VALEUR()
Local Integer LOK
If VALEUR<[M]STOFCYSTR
    [M]STOFCYSTR = VALEUR
    Affzo [M]STOFCYSTR
Endif
End


##########################################################################
$VERIF_FCY
Look [FCY]FCY1=[M:OWV]CPY;VALEUR
If fstat
    GMESSAGE = mess(412,199,1)
    mkstat=2
Endif
Return

######################################################################################
Subprog AS_VCRTYP(VALEUR)
Variable Integer VALEUR
Local Integer I
If GMODU(8)<>2 : VALEUR=36 : mkstat=2 : Endif
If GMODU(6)<>2 : VALEUR=10 : mkstat=2 : Endif
For I=1 To len(mess(0,701,1))
    If !find(I,10,36)
        GMENLOC(I)=1
    Endif
Next
End

######################################################################################
Subprog C_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
Local Integer LOK
Gosub VERIF_VCR
End

######################################################################################
Subprog AM_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
Local Integer LOK
If [M]VCRNUMSTR=[M]VCRNUMEND | VALEUR>[M]VCRNUMEND
    [M]VCRNUMEND = VALEUR
    Affzo [M]VCRNUMEND
Endif
End

######################################################################################
Subprog C_VCRNUMEND(VALEUR)
Variable Char    VALEUR()
Gosub VERIF_VCR
End

######################################################################################
Subprog AM_VCRNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]VCRNUMSTR & VALEUR<>""
    [M]VCRNUMSTR = VALEUR
    Affzo [M]VCRNUMSTR
Endif
End

######################################################################################
$VERIF_VCR
If VALEUR<>""   # CCC (2010-01-08) DM 61412
    Case [M]VCRTYP
        When 10 :
            Look [MFG]MFG0=VALEUR
        When 36 :
            Look [SCO]SCO0=VALEUR
    Endcase
    If fstat
        GMESSAGE = mess(261,197,1)
        mkstat=2
    Endif
Endif
Return

##########################################################################
Subprog C_NPRDEN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If clalev([F:AIM])=0 : Local File APRINTER  [AIM] : Endif
 If clalev([F:AID])=0 : Local File APRINTDES [AID] : Endif
 Call AIMCONT(VALEUR,[M:OWV]NPRNAM,GBATCH<>0) From IMPRIME
 If mkstat : End : Endif
 [M:OWV]NPRSRV     = [F:AIM]PRTSRV
 [M:OWV]NPRIMP     = [F:AIM]PRTNAM
 [M:OWV]PRTPOR     = [F:AIM]PRTPOR
 [M:OWV]PRTDRV     = [F:AIM]PRTDRV
 Raz [M]PRTDES
 For [AID]AID0 Where COD=[F:AIM]COD
  [M]PRTDES([F:AID]NUM-1)  = [F:AID]PRTDES
 Next
 Affzo [M:OWV]NPRSRV,NPRIMP
 Diszo [M:OWV]NPRSRV,NPRIMP
Else
 Actzo [M:OWV]NPRSRV,NPRIMP
Endif
End


######################################################################################

Subprog D_VCRTYP(VALEUR)
Variable Integer  VALEUR
If GMODU(8)=2
    VALEUR=10
Else
    VALEUR=36
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran ORDWIPVAL) 01/03/2010 13:48:37 (GA)
######################################################################################
Subprog AM_VCRTYP(VALEUR)
Variable Integer    VALEUR()
If dim([M]TYPFOR)>0        # FQ 62959 GA 03/2010
   Case VALEUR
     When 10 : [M]TYPFOR=38   # Formule sur [F:MFI]
     When 36 : [M]TYPFOR=47   # Formule sur [F:SCI]
   Endcase
Endif
End


######################################################################################
Subprog AS_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M:OWV]VCRTYP = 36
    # [M:OWV]FLTFCY = "[M]STOFCYSTR<=POHFCY&POHFCY<=[M]STOFCYEND" : # GH 04/10/2013 bug 93167
    [M:OWV]FLTFCY = "[M]STOFCYSTR<=[SCI]PRHFCY & [SCI]PRHFCY<=[M]STOFCYEND"
Else
    [M:OWV]FLTFCY = "[M]STOFCYSTR<=[MFG]MFGFCY & [MFG]MFGFCY<=[M]STOFCYEND"
Endif
End

Subprog AS_VCRNUMEND(VALEUR)
Variable Char    VALEUR()
If [M:OWV]VCRTYP = 36
    # [M:OWV]FLTFCY = "[M]STOFCYSTR<=POHFCY&POHFCY<=[M]STOFCYEND" : # GH 04/10/2013 bug 93167
    [M:OWV]FLTFCY = "[M]STOFCYSTR<=[SCI]PRHFCY & [SCI]PRHFCY<=[M]STOFCYEND"
Else
    [M:OWV]FLTFCY = "[M]STOFCYSTR<=[MFG]MFGFCY & [MFG]MFGFCY<=[M]STOFCYEND"
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ORDWIPVAL) 22/12/2011 15:32:30 (CCC)
######################################################################################
# Issue 78010 - 2011-12-22 by CCC
Subprog AM_MFGSTA(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    Actzo [M:OWV]MFGTRKFLG
Else
    [M:OWV]MFGTRKFLG=1
    Diszo [M:OWV]MFGTRKFLG
Endif
End

######################################################################################
# GH 28/01/2014 dm 94629
######################################################################################
Subprog AM_PRNCOD2(VALEUR)
Variable Integer VALEUR

If VALEUR<>2 : # pas de détail par pièce => pas de résumé
   Diszo PRNCOD
Else
   Actzo PRNCOD
Endif
End

######################################################################################
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Call AM_PRNCOD2([M]PRNCOD2)
End
