#<AdxTL>@(#)6.0.0.0 $Revision$
# Gestion du masque SMBENCHW1 SMW1 selon MBENCHW1 MBW1
# Traitement de la fenêtre dans BENCHLIBS
# - action SAIMODEOX, fenetre DMODEOX (selon SAIMODWOX)


########################################
Subprog AM_PUU2(VALEUR)
#-----------------------------#
# Contrôle de l'unité d'achat #
#-----------------------------#
Variable Char    VALEUR()
#----- contrôle que l'unité d'achat convienne pour le couple article/fournisseur -----#
  Local Char WUOM(GLONUOM) : WUOM=VALEUR
  Call CTLUOM([M:SMW1]ITMREF,1,[M:SMW1]BPRNUM2,WUOM,[M:SMW1]PUUSTUCOE,
&             GBIDC2,GBIDC3,GBIDI1) From STKACT
  If mkstat  End : Endif
End


########################################
Subprog AS_QTYPUU2(VALEUR)
Variable Decimal VALEUR
GBOUT1 = mess(151,198,1)
GBOUT2 = mess(150,198,1)
GBOUT3 = mess(282,198,1)
GBOUT4 = mess(423,198,1)
End

########################################
Subprog B1_QTYPUU2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:SMW1]ITMREF
    Read [ITF]ITF0=[M:SMW1]ITMREF;[M:SMW1]PRHFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY*[M:SMW1]PUUSTUCOE
End

########################################
Subprog B2_QTYPUU2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:SMW1]ITMREF
    Read [ITF]ITF0=[M:SMW1]ITMREF;[M:SMW1]PRHFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY*[M:SMW1]PUUSTUCOE
End


########################################
Subprog AM_QTYPUU2(VALEUR)
Variable Decimal VALEUR
Local    Integer OK
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI,WAVAOFS,WQUALTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer WALT            # llc 05.03 18397

If VALEUR = 0 : mkstat = 2 : End : Endif

# conversion de la qté UA en US
Call PCAL_QTY(VALEUR,[M:SMW1]PUU2,[M:SMW1]EXTQTY2,[M:SMW1]STU2,
&             [M:SMW1]ITMREF,[M:SMW1]BPRNUM2,1,[M:SMW1]PUUSTUCOE) From TRTACHQTE1

Call AM_EXTQTY2([M:SMW1]EXTQTY2)

End


########################################
Subprog AS_EXTQTY2(VALEUR)
Variable Decimal VALEUR
GBOUT1 = mess(151,198,1)
GBOUT2 = mess(150,198,1)
GBOUT3 = mess(282,198,1)
GBOUT4 = mess(423,198,1)
End

########################################
Subprog B1_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:SMW1]ITMREF
    Read [ITF]ITF0=[M:SMW1]ITMREF;[M:SMW1]PRHFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY
End

########################################
Subprog B2_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:SMW1]ITMREF
    Read [ITF]ITF0=[M:SMW1]ITMREF;[M:SMW1]PRHFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY
End

########################################
Subprog AM_EXTQTY2(VALEUR)
Variable Decimal VALEUR
Local    Integer OK
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI,WAVAOFS,WQUALTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer WALT            # llc 05.03 18397

If VALEUR = 0 : mkstat = 2 : End : Endif

# llc 05.03 18397
If find([F:ORD1]WIPSTA,1,2)
    WQTY = [F:SCI]EXTQTY - [M:SMW1]EXTQTY1 + VALEUR
Else
    WQTY = VALEUR
Endif

If [M:SMW1]STRDAT2 = [0/0/0] | [M:SMW1]ENDDAT2 = [0/0/0] : End : Endif
If [M:SMW1]WIPTYP=5 & [M:SMW1]FMI=5
    OK=1
    Call OUINON(mess(88,190,1),OK) From GESECRAN
    If OK <> 2 : mkstat=2 : End : Endif
Endif
If find([F:ORD1]WIPSTA,1,2)
    If [F:SCO]SCOTRKFLG > 3
        OK=1
        Call OUINON(mess(52,190,1),OK) From GESECRAN
        If OK <> 2 : VALEUR = [M:SMW1]EXTQTY2 : mkstat = 2 : End : Endif
    Endif

    If VALEUR < [F:MFI]CPLQTY
        GMESSAGE = mess(68,193,1)
        mkstat = 2
        End
    Endif
Endif

WORIFCY=[M:SMW1]PRHFCY
WLTI=0

# lecture ITF
If [F:ITF]ITMREF<>[M:SMW1]ITMREF
    Read [ITF]ITF0=[M:SMW1]ITMREF;[M:SMW1]PRHFCY
    If fstat : End : Endif
Endif

#GA (re)calcul délai + date de début ou réajustement date de fin
Call CALCUL_OFS_DAT([M:SMW1]PRHFCY, [M:SMW1]EXTQTY2, [M:SMW1]AVAOFS, WQUALTI,
&                   [M:SMW1]ENDDAT2, [M:SMW1]STRDAT2) From BENCHLIBS
Affzo [M:SMW1]AVAOFS,ENDDAT2,STRDAT2

End

########################################

Subprog D_PRHFCY(VALEUR)
Variable Char     VALEUR
VALEUR=[M:SMW1]POHFCY
End

########################################

Subprog AS_PRHFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:SMW1]POHFCY
Endif
End

########################################
Subprog AS_STRDAT2(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=date$ : Endif
If find([F:ORD1]WIPSTA,1,2) & [F:SCO]SCOTRKFLG > 3 : mkstat = 2 : Endif
End

########################################
Subprog C_STRDAT2(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# FQ 66569 GA 09/2010 ne pas tenir compte des schémas hebdomadaires sur achats de sous-traitance
# révision calendriers (llc 06.00)
#Call CONTROL_DATE_PLN(VALEUR, [M:SMW1]POHFCY) From MFGLIB

If [M:SMW1]BOMALT2 = 0 & [F:ITM]ITMREF = [M:SMW1]ITMREF
    [M:SMW1]STRDAT2 = VALEUR   # FQ 61095 GA 12/2009 avant [M:SMBW1]STRDAT2
    Call RECH_NOM([M:SMW1]POHFCY, [M:SMW1]STRDAT2, [M:SMW1]BOMALT2,3) From BENCHLIB
Endif

# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:SMW1]ECCVALMAJ)>0
    Call C_STRDAT2(VALEUR, "SMW1") From SUBSMWECC
Endif
End

########################################
Subprog AM_STRDAT2(VALEUR)
Variable Date    VALEUR
Local    Integer WRET
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer OK

If [M:SMW1]WIPTYP=13 & [M:SMW1]FMI=5 : # contremarque
    OK=1
    Call OUINON(mess(88,190,1),OK) From GESECRAN
    If OK <> 2 : mkstat=2 : End : Endif
Endif

Call CHECK_PAST(VALEUR,2) From MFGLIB

If [M:SMW1]AVAOFS>0
#  Calcul de la date de fin de l'opération: LENDDAT = LSTRDAT + LAVAOFS
   Call CALC_DAT_FCY(VALEUR,[M:SMW1]AVAOFS,[M:SMW1]PRHFCY,0,[M:SMW1]ENDDAT2) From TRTACHDAT
Endif

Affzo [M:SMW1]ENDDAT2
#
End

########################################
Subprog AS_ENDDAT2(VALEUR)
Variable Date    VALEUR

End


########################################
Subprog C_ENDDAT2(VALEUR)
Variable Date    VALEUR
End

########################################
Subprog AM_ENDDAT2(VALEUR)
Variable Date    VALEUR
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer OK

Call CHECK_PAST(VALEUR,2) From MFGLIB

If [M:SMW1]AVAOFS>0
#  Calcul de la date de fin de l'opération: LSTRDAT = LENDDAT - LAVAOFS
   Call CALC_DAT_FCY(VALEUR,[M:SMW1]AVAOFS,[M:SMW1]PRHFCY,1,[M:SMW1]STRDAT2) From TRTACHDAT
Endif

Affzo [M:SMW1]STRDAT2
#
End

########################################
Subprog AV_BPRDES(VALEUR)
Variable Char    VALEUR()
#
If [M:SMW1]BPRNUM = "" : End : Endif

If clalev([F:BPR]) = 0 : Local File BPARTNER [BPR] : Endif
Read [BPR]BPR0=[M:SMW1]BPRNUM
If !fstat : VALEUR = [F:BPR]BPRNAM : End : Endif

If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
Read [FCY]FCY0=[M:SMW1]BPRNUM
If !fstat : VALEUR = [F:FCY]FCYNAM : End : Endif
#
End

########################################
Subprog AS_BOMALT2(VALEUR)
Variable Decimal VALEUR
#? If [F:SCO]ALLSTA > 1 : mkstat = 2 : End : Endif
If VALEUR = 0
    Call RECH_NOM([M:SMW1]PRHFCY, [M:SMW1]STRDAT2, VALEUR,3) From BENCHLIB
Endif

End

########################################
Subprog C_BOMALT2(VALEUR)
Variable Decimal VALEUR

#Epic: 55934 (STLIG) validate bom code
If (func SUBSMW1.VALBOMALT(VALEUR,[M:SMW1]PRHFCY,[M:SMW1]ITMREF,[M:SMW1]STRDAT2,1) = 0)
  mkstat = 2
Endif

End

########################################
Subprog AM_BOMALT2(VALEUR)
Variable Decimal VALEUR

End

#Epic: 55934 (STLIG) validate bom code (from am_bomalt2)
Funprog VALBOMALT(LBOMALT,LPRHFCY,LITMREF,LSTRDAT,LMSG)
Value Integer LBOMALT
Value Char    LPRHFCY
Value Char    LITMREF
Value Date    LSTRDAT
Value Integer LMSG

Local Integer OK : OK = 1

Local Date    WDAT
Local Char    WFCY(GLONFCY)
Local Integer WALT

Read [TBO]TBO0=3;LBOMALT
If (fstat)
  OK = 0
Endif

If (OK)
  Read [BOH]BOH0=LITMREF;LBOMALT;3
  If (fstat)
    If (LMSG <> 0)
      GMESSAGE = mess(95,193,1)
    Endif
    OK = 0
  Endif
Endif

If (OK)
  If (LSTRDAT = [0/0/0])
    WDAT = date$
  Else
    WDAT = LSTRDAT
  Endif
  WFCY = LPRHFCY
  Call CONTSCONOM(WFCY,WALT,WDAT,LMSG) From SCOLIB
  If (WALT = 0)
    OK = 0
  Endif
Endif

End OK

########################################
Subprog AM_OBJDAT(VALEUR)
Variable Date    VALEUR
[M:SMW1]ELFLG  = VALEUR - [M:SMW1]ENDDAT2
End

########################################
Subprog AS_BPRNUM2(VALEUR)
Variable Char    VALEUR()
#---------------------------------------------------#
#      Avant saisie du fournisseur                  #
#---------------------------------------------------#
Local Char       WBPS
Local Integer    WBOMALT : WBOMALT = [M:SMW1]BOMALT2
Raz WBPS

Call FIND_BPRNUM ([M:SMW1]ITMREF,WBOMALT,[M:SMW1]POHFCY,[M:SMW1]PRHFCY,WBPS) From SCOLIB

If VALEUR = "" & WBPS <> ""
   VALEUR         = WBPS
   [M:SMW1]BPRNUM = WBPS
   Affzo [M:SMW1]BPRNUM
Endif

# Epic: 55934 (STLIG) enable/disable product selection on parameter: ITMBPSFCY
If (GITMBPSFCY = 1)
  GBOUT2 = ""
Else
  GBOUT2 = mess(1,3505,1)
Endif
GBOUT3 = mess(2,3505,1) # product-site suppliers
GBOUT4 = mess(24,198,1)

End


Subprog C_BPRNUM2(VALEUR)
Variable Char VALEUR

# Epic: 55934 (STLIG) validate 1. blocking flag, and 2. product and product-site reference
Local Integer WITMBPS
Local Integer WRETOUR
If (VALEUR <> "")
  Call CTRL_DOUFLG(1,[M:SMW1]ITMREF,VALEUR,[M:SMW1]POHFCY,WITMBPS,WRETOUR) From TRTACHCTL1
  If (WRETOUR <> 0)
    mkstat = 2
  Endif
Else
  GERR = 1 : GMESSAGE = mess(69,197,1)
  mkstat = 2
Endif

End

########################################
Subprog AM_BPRNUM2(VALEUR)
Variable Char    VALEUR()
#----- Lecture BPARTNER si nécessaire pour chargement CUR, LAN -----#
If [F:BPR]BPRNUM<>VALEUR
  Read [BPR] BPR0=VALEUR
  If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
GCUR=[F:BPR]CUR
#----- Contrôle et chargement des zones inter-sites -----#
  Call CTRL_INTERSITE ([M:SMW1]POHFCY,VALEUR)
  If mkstat
    GERR=1 : mkstat=1 : End
  Endif

# Epic: 55934 (STLIG) default bom code (product supplier)
If (VALEUR <> "" & [M:SMW1]BPRNUM2 <> VALEUR)
  Local Integer WBOMALT : WBOMALT=0
  Call FIND_BOMALT([M:SMW1]ITMREF,VALEUR,WBOMALT) From SCOLIB
  If (WBOMALT <> 0)
    [M:SMW1]BOMALT2 = WBOMALT
    Affzo [M:SMW1]BOMALT2
    If (func SUBSMW1.VALBOMALT([M:SMW1]BOMALT2,[M:SMW1]PRHFCY,[M:SMW1]ITMREF,[M:SMW1]STRDAT2,1) = 0)
      GERR = 1
      zonsui = "BOMALT2"
    Endif
  Endif
Endif

End


######################################################################################
Subprog CTRL_INTERSITE (LPOHFCY,LBPSNUM)
Variable Char    LPOHFCY
Variable Char    LBPSNUM

Local Char    WSALFCY(GLONFCY)
Local Char    WINVFCY(GLONFCY)
Local Char    WMFGFCY(GLONFCY)
Local Char    WBPCORD(GLONBPR)
Local Char    WBPCINV(GLONBPR)
Local Integer WDME

#-----------------------------------------------------#
# Contrôle et chargement des zones pour l'inter-sites #
# --------------------------------------------------- #
# LPOHFCY : Site de commande                          #
# LBPSNUM : Fournisseur de la commande                #
#-----------------------------------------------------#
If LBPSNUM="" | LPOHFCY="" : End : Endif

Raz GRCPFCY
Call CTRL_INTERSITE(LPOHFCY,LBPSNUM,2,[M:SMW1]BETFCY,[M:SMW1]BETCPY,WSALFCY,
&                   WMFGFCY,WBPCORD,WINVFCY,WBPCINV,
&                   WDME) From TRTACHCTL1
If mkstat  GERR=1 : End : Endif
#-----
# Demande LLC: afficher un libellé plutôt que BETFCY et BETCPY
If [M:SMW1]BETCPY = 2
   [M:SMW1]ZBETCPY = mess(491,197,1)
Elsif [M:SMW1]BETFCY = 2
   [M:SMW1]ZBETCPY = mess(645,197,1)
Else
   [M:SMW1]ZBETCPY = ""
Endif
Affzo [M:SMW1]ZBETCPY

End

########################################
Subprog AM_POHFCY(VALEUR)
Variable Char    VALEUR()
If GFCY <> VALEUR
    GFCY = VALEUR
Endif

# Issue 86437 GA 12/2012
#----- Contrôle et chargement des zones inter-sites -----#
  Call CTRL_INTERSITE (VALEUR,[M:SMW1]BPRNUM2)
  If mkstat
    GERR=1 : mkstat=1 : End
  Endif
End

End
########################################
Subprog AM_PRHFCY(VALEUR)
Variable Char    VALEUR()
End

