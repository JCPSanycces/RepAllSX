#    MWA - 30.03.2010 FQ63646    SOFTY - Mauvaises répartition période de la dernière dotation exercice
#    MWA - 09.03.2010 FQ63145    Provisions périodique erronée en cas de sortie avec IFRIC12
#    MWA - 08.02.2010 FQ62320    Sortie sur mode UO
#    MWA - 30.10.2009 FQ59415    Sortie rétroactive : pas d'extourne du cumul P-1 lorsque le poids dans l'exercice est à 0.
#    MWA - 02.09.2009 FQ57526    Mode PC basé sur période répartision periodique de la dotation exercice incorrecte sur 1er exercice
#    MWA - 07.07.2009 FQ55960    Dégressif marocain.
#    MWA - 10.06.2009 FQ55759    Mode SA à la suite d'un changement de méthode régularisation des dotations P-1 sur P.
#    MWA - 28.04.2008 FQ54778    Mode PC calcul en erreur lorsque bien saisie en En et commençant à s'amortir en En+1.
#    MWA - 14.10.2005 FQ49743    Mode PC erreur 26 dotation périodique de la 1ère période de l'exercice découpés en périodes
#    MWA - 19.09.2005 FQ49277    Lorsque le prorata est 1/2 trimestre, le découpage des périodes est toujours en mois
#                                Autre possibilité modes UL et UD en prorata mois avec règles particulières : déb. amt 1/2 trimestre ..
#
#*********************************************************************
#            D O T A T I O N   -   P E R I O D E
#*********************************************************************
#

# Modèle
#If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]AASREF = [F:DEPC]AASREF and [F:DEPC]DPRPLN = [F:DEPC]DPRPLN ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

#
#########################################################
Subprog  CAL_AJUST_PERIODE ( PTYPPRO, PDTDBPER, PDTFNPER, RDTDBPER, RDTFNPER)
#
# - Objet  : Ajuste les dates de période
#
# - Entrée : Mode d'amortissement
#            Date de début de période (fichier)
#            Date de fin de période   (fichier)
#
# - Sortie : Date de début de période
#            Date de fin de période

#   Boite noire
#

Value     Integer  PTYPPRO
Value     Date     PDTDBPER
Value     Date     PDTFNPER
Variable  Date     RDTDBPER
Variable  Date     RDTFNPER

 RDTDBPER = PDTDBPER
 RDTFNPER = PDTFNPER

 #-----------------
 Case PTYPPRO

   When GVML_TPMOIS, GVML_TPHLFY

   #-----------------
     # Date de début de période ajustée à 1er jour du mois
     RDTDBPER = func GLOBB9.CAL_DAT_PREM( PDTDBPER, "M")
     If !( func GLOBB9.CAL_DAT_ISENDOFMONTH (PDTFNPER) ) Then
       # La fin de période n'est pas une fin de mois, ajustement au dernier jour du mois précédent
       RDTFNPER = func GLOBB9.CAL_DAT_PLUS( PDTFNPER, -1, "M")
       RDTFNPER = func GLOBB9.CAL_DAT_DERN( RDTFNPER, "M")
     Else
       RDTFNPER = PDTFNPER
     Endif

   When GVML_TPSEMA
   #-----------------
     # Date de début de période ajustée à 1er jour de la semaine
     RDTDBPER = func GLOBB9.CAL_DAT_PREM( PDTDBPER, "W")
     If !( func GLOBB9.CAL_DAT_ISENDOFWEEK (PDTFNPER) ) Then
       # La fin de période n'est pas une fin de semaine, ajustement au dernier jour de la semaine précédente
       RDTFNPER = func GLOBB9.CAL_DAT_PLUS( PDTFNPER, -7, "D")
       RDTFNPER = func GLOBB9.CAL_DAT_DERN( RDTFNPER, "W")
     Else
       RDTFNPER = PDTFNPER
     Endif

   When GVML_TPHLFM
   #-----------------
     # Date de début de période ajustée à 1er jour de la quinzaine
     RDTDBPER = func GLOBB9.CAL_DAT_PREM( PDTDBPER, "Q")
     If !( func GLOBB9.CAL_DAT_ISENDOFHLFM (PDTFNPER) ) Then
       # La date de fin de période n'est pas une fin de quinzaine, ajustement à fin de quinzaine précédente
       RDTFNPER = func GLOBB9.CAL_DAT_PREM( PDTFNPER, "Q")
       # RDTFNPER = func GLOBB9.CAL_DAT_PLUS( RDTFNPER, -1, "Q")
       RDTFNPER = func GLOBB9.CAL_DAT_PLUS( RDTFNPER, -1, "D")
     Else
       RDTFNPER = PDTFNPER
     Endif

   When GVML_TPHLFQ
   #-----------------
     #FQ49277
     # * Fonctionnement initial, si la fin de période n'est pas une fin de 1/2 trimestre, ajustement à fin de 1/2 trimestre précédent
     # avec l'hypothèse que dans cette configuration, l'utilisateur a découpé ses périodes en 1/2 trimestre.
     # Date de début de période ajustée à 1er jour du 1/2 trimestre
     #RDTDBPER = func GLOBB9.CAL_DAT_PREM( PDTDBPER, "T")
     #If !( func GLOBB9.CAL_DAT_ISENDOFHLFQ (PDTFNPER) ) Then
     #  La fin de période n'est pas une fin de 1/2 trimestre, ajustement à fin de 1/2 trimestre précédent
     #  RDTFNPER = func GLOBB9.CAL_DAT_PREM( PDTFNPER, "T")
     #  RDTFNPER = func GLOBB9.CAL_DAT_PLUS( RDTFNPER, -1, "T")
     #else
     #  RDTFNPER = PDTFNPER
     #Endif
     # * Christian part du principe que dans ce cas de figure, l'exercice sera toujours découpé en mois, ou en un nombre entier de mois.
     # Aussi retient-on de passer en "M" à ce niveau.
     # Ainsi que lors du calcul de la dotation périodique CAL_DOT_PER.
     # Ce principe s'applique à tous les modes pouvant utiliser ce type de prorata
     #
     # Date de début de période ajustée à 1er jour du mois.
     RDTDBPER = func GLOBB9.CAL_DAT_PREM( PDTDBPER, "M")
     If !( func GLOBB9.CAL_DAT_ISENDOFMONTH (PDTFNPER) ) Then
       # La fin de période n'est pas une fin de mois, ajustement au dernier jour du mois précédent
       RDTFNPER = func GLOBB9.CAL_DAT_PLUS( PDTFNPER, -1, "M")
       RDTFNPER = func GLOBB9.CAL_DAT_DERN( RDTFNPER, "M")
     Else
       RDTFNPER = PDTFNPER
     Endif

 Endcase
 #-----------------
 Call ECR_FICH("FS1",10,"CAL_AJUST_PERIODE Avant ajust.-  ="+num$(PDTDBPER)+" - "+num$(PDTFNPER) ) From =G_GLOB0
 Call ECR_FICH("FS1",10,"CAL_AJUST_PERIODE Après ajust.-  ="+num$(RDTDBPER)+" - "+num$(RDTFNPER) ) From =G_GLOB0


End


#########################################################
Subprog  CAL_PDS_DET_PER ( PDTDBPER, PDTDBAMT, PDTFNAMT, PDATSOR, PDATCLS, PTYPPRODAT, RPDSDETPER)
#
# - Objet  : Calcule le poids de la détention dans la période
#            exprimé selon le type de prorata
#            Il est égal au poids de la période
#            au prorata de la durée de détention
#            Poids détention période =
#            Poids période * ( Détention période / Période entière )
#
#
# - Entrée : [M:FIY] Table des périodes
#            Date de début de période ** fichier **
#            Date de début d'amortissement
#            Date de fin d'amortissement
#            Date de sortie
#            Date de classement du bien comme étant détenu pour la vente
#            Type de prorata
#
# - Sortie : Poids de la détention dans la période
#   Boite noire
#

Value    Date      PDTDBPER
Value    Date      PDTDBAMT
Value    Date      PDTFNAMT
Value    Date      PDATSOR
Value    Date      PDATCLS
Value    Char      PTYPPRODAT
Variable Decimal   RPDSDETPER

Local Integer IP
Local Decimal WDURDETPER, WDURPER
Local Decimal WPDSPER, WPDSDETPER
Local Date    WDTDBAMT

  RPDSDETPER = 0

  # Rang de la période dans le tableau des périodes
  IP = find(PDTDBPER, [M:FIY]DATSTRPER)
  If (IP = 0) Then : End : Endif

  # -------------------
  # Durée Période
  # -------------------
  Call CAL_DAT_DIFF( [M:FIY]DATSTRPER(IP-1), [M:FIY]DATENDPER(IP-1), PTYPPRODAT, WDURPER  ) From =G_GLOB9
  # Calcul de la durée de détention dans la période selon prorata.

  # -------------------
  # Durée détention Période
  # -------------------
  #  Call CAL_DUR_DET
  #&     ([M:FIY]DATSTRPER(IP-1), [M:FIY]DATENDPER(IP-1), [M:DIV]DATNUL, [M:DIV]DATNUL,
  #&      PDTDBAMT, PDTFNAMT, PDATSOR, PDATCLS,  PTYPPRODAT, WDURDETPER ) From =G_GLOB8
  [M:DIV]PD(0)= [M:FIY]DATSTRPER(IP-1): [M:DIV]PD(1)= [M:FIY]DATENDPER(IP-1)
  [M:DIV]PD(2)= [M:DIV]DATNUL : [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= PDTDBAMT
  [M:DIV]PD(5)= PDTFNAMT : [M:DIV]PD(6)= PDATSOR: [M:DIV]PD(7)= PDATCLS : [M:DIV]PC(0)= PTYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDETPER = [M:DIV]RV(1)

  # Récupération du poids de la période selon prorata.
  # !!!!!!!!!! Le cas "Y" "Q" "T" ont été rajoutés et ne donnent pas satisfaction à revoir
  Case PTYPPRODAT
    When "M"     : WPDSPER = [M:FIY]NBRMONPER(IP-1)
    When "W"     : WPDSPER = [M:FIY]NBRWEKPER(IP-1)
    When "D"     : WPDSPER = [M:FIY]NBRDAYPER(IP-1)
    When "Y"     : WPDSPER = WDURPER  # neutralisation
    When "Q"     : WPDSPER = arr((([M:FIY]NBRMONPER(IP-1)*2)), 1.)
    When "T"     : WPDSPER = arr((([M:FIY]NBRMONPER(IP-1)*2)/3), 1.)
    When Default : WPDSPER = 0
  Endcase
  # -------------------
  # Poids détention Période
  # -------------------
  If ( WDURPER <> 0 ) Then
    WPDSDETPER  = WPDSPER * (WDURDETPER / WDURPER)
  Else
    WPDSDETPER = 0
  Endif

  RPDSDETPER = WPDSDETPER
End



#########################################################
Subprog  CAL_DOT_PER ( PMNTREF, PDOTEXE, PCUMP_1, PAMTEXC, PEXCP_1, RDOTPER, REXCPER)
#
# - Objet  : Calcul de la dotation de la période par différence de cumul
#            La dotation de la période est égale à la part d'un montant de reférence
#            La part de la période n est égale à la part revenant aux périodes 1 à n de l'exercice
#            diminuée de celle déjà attribuée aux périodes 1 à n-1.
#
#            Rem: PMNTREF et PDOTEXE ne sont pas redondant car nécessaire pour les modes PC et PD,
#                 PMNTREF contient VALAMT * Taux et PDOTEXE contient la dotation
#                 PMNTREF utilisé pour les périodes sauf la dernier et PDOTEXE pour la dernière
#
# - Entrée : [M:FIY]
#
# - Sortie : Dotation  de la période n
#            Amt Excpt de la période n
#
#   Boite noire
#

Value    Decimal   PMNTREF       : # Montant de référence
Value    Decimal   PDOTEXE       : # Dotation exercice
Value    Decimal   PCUMP_1       : # Cumul dotation des périodes 1 à n-1
Value    Decimal   PAMTEXC       : # Amortissement exceptionnel
Value    Decimal   PEXCP_1       : # Cumul d'amortissement exceptionnel
Variable Decimal   RDOTPER       : # Dotation période
Variable Decimal   REXCPER       : # Amortissement exceptionnel période

RDOTPER    = 0.
REXCPER    = 0.

Local Decimal WPDSDETEXE         : WPDSDETEXE = 0
Local Decimal WPDSDET            : WPDSDET    = 0
Local Decimal WDOTPER            : WDOTPER    = 0.
Local Decimal WEXCPER            : WEXCPER    = 0.
Local Decimal WDOTPERCUM         : WDOTPERCUM = 0.
Local Decimal WDOTEXCCUM         : WDOTEXCCUM = 0.

Local Decimal WDUREXE            : WDUREXE    = 0.
Local Decimal WDURDET            : WDURDET    = 0.
Local Decimal WDETEXE            : WDETEXE    = 0.
Local Date    WDTDBPER,  WDTFNPER
Local Char    WMODAMT
Local Date    WDTDBAMT


  #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]DPRPLN = G301IAS ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  # Par défaut Début de ventilation sur la période dans laquelle se situe le début d'amortissement
  WDTDBAMT = [F:DEPC]STRDPRDAT

  If ( [M:DIV]MODTYP = GVML_TMSTAND ) Then
    # -- Mode standard
    WMODAMT = [M:DIV]MODAMT
  Else
    # -- Mode libre (pour passage dans le case)
    WMODAMT = "@@"
  Endif

  #--------------------------
  If ( [M:DIV]FLGSLDPER ) Then
    # La fin d'amortissement est antérieure à la date de début d'exercice courant et
    # la valeur nette est non nulle. Le flag a été positionné (GLOBB4] afin de solder
    # la dotation exercice sur la période courante. La dotation période est égale à la
    # valeur nette début de période

    # FQ77867
    Case [M:DIV]TYPCAL
    When "R"
      # Valeur nette amortissable début de période
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - RDP (S)" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "RDP", [F:DEPC]DPRBAS, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
      [M:DIV]PC(0)= "RDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    When "T"
      # Valeur nette amortissable début de période
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - TDP (S)" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "TDP", [F:DEPC]DPRBAS, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
      [M:DIV]PC(0)= "TDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    When "I"     # When "T" FQ102893
      # Valeur nette amortissable début de période
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - IDP (S)" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "IDP", [F:DEPC]BSEVAL, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
      [M:DIV]PC(0)= "IDP" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    Endcase

    RDOTPER  = [M:DIV]RV(1)
    # FQ116979 If
    # FQ120477
#    If ( [M:DIV]DIFRGL = GVML_RGNODER and [F:DEPC]DPRPLN = G301FIS and [M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1) <> 0
#&     and  abs([F:DEPC]ENDDPE + [F:DEPC]EXCDPR) = abs([M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1))
#&     and  abs([F:DEPC]PERCLOCUM + [F:DEPC]PERCLOEXC) = abs([M:PCPT]PERCLOCUM([M:DIV]DL-1) + [M:PCPT]PERCLOEXC([M:DIV]DL-1)) ) Then :  # FQ116981 A
    If ( [M:DIV]DIFRGL = GVML_RGNODER and [F:DEPC]DPRPLN = G301FIS and [F:DEPC]FIYSTRDAT = [M:FIY]DATSTRFIY ([M:DIV]FEC-1) ) Then
      Call CAL_AJUST_PERIODE
&      ( [M:DIV]TYPPRO, [M:DIV]EXEDATREF, [F:DEPC]PERENDDAT, [M:DIV]DTDBPER, [M:DIV]DTFNPER ) From =G_GLOB5
    Endif
    If ( [M:DIV]DIFRGL = GVML_RGNODER and [F:DEPC]DPRPLN = G301FIS and [F:DEPC]FIYSTRDAT = [M:FIY]DATSTRFIY ([M:DIV]FEC-1) and
& (       ([M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1)) <> 0
&     and  abs([F:DEPC]ENDDPE + [F:DEPC]EXCDPR) = abs([M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1))
&     and  abs([F:DEPC]PERCLOCUM + [F:DEPC]PERCLOEXC) = abs([M:PCPT]PERCLOCUM([M:DIV]DL-1) + [M:PCPT]PERCLOEXC([M:DIV]DL-1) )
& )
&  or
& (        not func GLOBB9.CAL_DAT_INSIDE(max([F:DEPC]ENDDPRDAT,[M:PCPT]ENDDPRDAT([M:DIV]DL-1)),[M:DIV]DTDBPER,[M:DIV]DTFNPER,"I")
&     and abs(RDOTPER) > abs([M:PCPT]PERENDDPE([M:DIV]DL-1))
& )     ) Then
      # On considère qu'il ne faut pas solder l'amortissement

    Else : # FQ116979 Else
      # FQ77867
      #RDOTPER = [M:DIV]DOTEXE
      REXCPER = 0
      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Dotation Exercice à solder sur la période courante") From =G_GLOB0
      Call ECR_FICH
&          ("FS1",8,"CAL_DOT_PER ***** Dotation Période  = "+ num$(RDOTPER)) From =G_GLOB0
      Gosub CAL_RMVLVL From =G_GLOB0
      End
      #***
    Endif : # FQ116979 Endif
  #
  Endif
  #--------------------------


  Call ECR_FICH("FS1",8,"CAL_DOT_PER - Montant à répartir         ="+
&                                      format$([M:DIV]CURFMT, PMNTREF)) From =G_GLOB0
  Call ECR_FICH("FS1",8,"CAL_DOT_PER - Amt Exc à répartir         ="+
&                                      format$([M:DIV]CURFMT, PAMTEXC)) From =G_GLOB0


  # Cadrage de la nouvelle date de fin de période n dans le champ [M:DIV]DTFNPER
  Call CAL_AJUST_PERIODE
&      ( [M:DIV]TYPPRO, [M:DIV]EXEDATREF, [F:DEPC]PERENDDAT, [M:DIV]DTDBPER, [M:DIV]DTFNPER ) From =G_GLOB5

  # FQ114113
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    PERDPC                  E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  If ( G_ETP_GLOBI5 ) Then
    G_SKPSTD = 0
    GPOINT = "PERDPC" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9120 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  # -1 --------------------------------------------
  If ( not G_SKPSTD ) Then
    #--------------------------
    Case WMODAMT

      When G_DPMSA
        #--------------------------
        WDOTPER = 0.
        WEXCPER = 0.

        # FQ55759
        If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Endif

      When G_DPM1P
        #--------------------------
        # FQ84110
        WDOTPER = 0.
        WEXCPER = 0.
        If ( [M:DIV]DTDBAMTREG <= [M:DIV]DTFNPER ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Endif

      When G_DPMLP, G_DPMLV, G_DPMDF, G_DPMIT, G_DPMDP, G_DPMDV, G_DPMLB, G_DPMDB, G_DPMDX, G_DPMDA,
&          G_DPMLE, G_DPMDI, G_DPMDE, G_DPMFM, G_DPMLG, G_DPMRE, G_DPMDM, G_DPMSL, G_DPMAL, G_DPMAD,
&          G_DPMHL, G_DPMHD, G_DPMTL, "@@"
        # FQ84283 FQ84281 FQ105809
        If (WMODAMT = G_DPMAD) Then
          Local Date S_DTFNAMT : S_DTFNAMT = [M:DIV]DTFNAMT : [M:DIV]DTFNAMT = [0/0/0]
        Endif

        # FQ90048(2)
        If ( WMODAMT = G_DPMRE ) Then
          WDTDBAMT = [M:DIV]DTDBAMTREG
        Endif

        # FQ85563 FQ84283
        If ( WMODAMT = G_DPMIT ) Then
          WDTDBAMT = [M:DIV]DTDBAMTREG
          If ( [M:DIV]PROEXEINV = G_OUI ) Then
            If ( [M:DIV]DTDBAMTREG >= [M:FIY]DATSTRPER(0) ) Then
              Local Date WDEB, WFIN
              Local Integer WIND
              If ( func GLOBB9.CAL_DAT_INSIDE(WDTDBAMT,[M:FIY]DATSTRFIY([M:DIV]FEC-1),[M:FIY]DATENDFIY([M:DIV]FEC-1),"I") ) Then
                Call CAL_PERIODE_SELON_DATE ( [M:DIV]DTDBAMTREG, WDEB, WFIN, WIND ) From =G_GLOB8
                WDTDBAMT = WDEB
              Else
                Call CAL_LOCALISE_PERIODE_SELON_DATE ( [M:DIV]DTDBAMTREG, WDEB, WFIN, WIND ) From =G_GLOB8
                WDTDBAMT = WDEB
              Endif
            Endif
          Endif
        Endif

        #--------------------------
        # Classique : En tenant compte du poids des périodes
        #
        #-2 -------------------------
        If ( [M:DIV]BCALPDS ) Then
          [M:DIV] BCALPDS = 0
          Local Integer NBEXE
          Local Integer NBMAX
          Local Integer IEXE
          Local Integer IPER
          Local Integer IP
          Local Decimal WPDSDETPER
          Local Integer FIRSTPER  : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Depreciation

          # FQ65400
          If ([M:DIV]TRTDEM = "CALSIM") Then
            # Concerne les exercices découpés en période
            NBMAX = [M:FIY]NB_EXE
          Else
            # Selon l'horizon période du contexte  FQ74517  FQ78670
            NBMAX = [M:CNX]HRZPER(find([M:DIV]CNT, [M:CNX]CNX)-1)
          Endif

          Call ECR_FICH("FS1", 9,"CAL_DOT_PER - Calcul poids dét. pér de l'exercice" ) From =G_GLOB0
          Raz [M:FIY]PERPDSDET
          # Concerne 3 exercices maximum
          # >>>>>>>>>>>>
          For NBEXE = 0 To NBMAX
  #       For NBEXE = 0 To 2 FQ65400
            IEXE = ([M:DIV]FEC+NBEXE)
            [L]FIRSTPER = 1 : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Depreciation
            # Périodique géré
            # >>>>>>>>>>>>
            For IPER = 1 To [M:FIY]NBRPER(IEXE-1)
              IP = [M:FIY]INDDEBPER(IEXE-1) + (IPER-1)
              # -3 ---------------------------------------------
              If ( func GLOBB9.CAL_DAT_INSIDE(WDTDBAMT,[M:FIY]DATSTRPER(IP-1),[M:FIY]DATENDPER(IP-1),"I") or
&                  func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSORREG ,[M:FIY]DATSTRPER(IP-1),[M:FIY]DATENDPER(IP-1),"I") or
&                  func GLOBB9.CAL_DAT_INSIDE([M:DIV]DETVTEDAT,[M:FIY]DATSTRPER(IP-1),[M:FIY]DATENDPER(IP-1),"I") or
&                  func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[M:FIY]DATSTRPER(IP-1),[M:FIY]DATENDPER(IP-1),"I") ) Then
                # Poids de la détention dans la période considérée
                Call CAL_PDS_DET_PER (  [M:FIY]DATSTRPER(IP-1), WDTDBAMT, [M:DIV]DTFNAMT,
&                    [M:DIV]DATSORREG, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WPDSDETPER ) From =G_GLOB5
                # Poids de détention de la période.
                [M:FIY]PERPDSDET (IP-1) = WPDSDETPER
              # -3 ---------------------------------------------
              Else
                 # FQ87580
  #              If ( WDTDBAMT > [M:FIY]DATENDPER(IP-1) or
  #&                  ( [M:DIV]DATSORREG <> [0/0/0] and [M:DIV]DATSORREG < [M:FIY]DATSTRPER(IP-1) )) Then
                If ( WDTDBAMT > [M:FIY]DATENDPER(IP-1) or
&                    ( [M:DIV]DATSORREG <> [0/0/0] and [M:DIV]DATSORREG < [M:FIY]DATSTRPER(IP-1) ) or
&                    ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [M:FIY]DATSTRPER(IP-1) )) Then
                  # Poids de détention à zéro.
                Else
                  If ( [M:DIV]DTFNAMT < [M:FIY]DATSTRPER(IP-1) and [M:DIV]DTFNAMT <> [0/0/0] ) Then
                    # Fin d'amortissement antérieure à la date de début de période
                    Break
                  Else
                    # Poids de détention égal au poids de la période.
                    # !!!!!!!!!! Le cas "Y" "Q" "T" ont été rajoutés et ne donnent pas satisfaction à revoir
                    Case [M:DIV]TYPPRODAT
                      When "D"
                        [M:FIY]PERPDSDET (IP-1) = [M:FIY]NBRDAYPER (IP-1)
                      When "M"
                        [M:FIY]PERPDSDET (IP-1) = [M:FIY]NBRMONPER (IP-1)
                      When "W"
                        [M:FIY]PERPDSDET (IP-1) = [M:FIY]NBRWEKPER (IP-1)
                      When "Y"
                        [M:FIY]PERPDSDET (IP-1) = arr((([M:FIY]NBRMONPER(IP-1)/6)), 1.)
                      When "Q"
                        [M:FIY]PERPDSDET (IP-1) = arr((([M:FIY]NBRMONPER(IP-1)*2)), 1.)
                      When "T"
                        [M:FIY]PERPDSDET (IP-1) = arr((([M:FIY]NBRMONPER(IP-1)*2)/3), 1.)
                      When Default
                        [M:FIY]PERPDSDET (IP-1) = [M:FIY]NBRDAYPER (IP-1)
                    Endcase
                  Endif
                Endif
              Endif
              # -3 ---------------------------------------------

              : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
              If ( [M:DIV2]RGRPPER_R = GVML_REPFIRAV or
&                  [M:DIV2]RGRPPER_T = GVML_REPFIRAV or
&                  [M:DIV2]RGRPPER_I = GVML_REPFIRAV  ) Then
                If ( [M:FIY]PERPDSDET (IP-1) <> 0 ) Then
                  If ( [L]FIRSTPER ) Then
                    [L]FIRSTPER = 0
                    [M:FIY]PERPDSDET (IP-1) = 1
                  Else
                    [M:FIY]PERPDSDET (IP-1) = 0
                  Endif
                Endif
              Endif

              Call ECR_FICH("FS1", 9,"CAL_DOT_PER - "
&                        + format$([M:DIV]DATFMT,[M:FIY]DATSTRPER(IP-1)) + " - "
&                        + format$([M:DIV]DATFMT,[M:FIY]DATENDPER(IP-1))            ) From =G_GLOB0
              Call ECR_FICH("FS1", 9,"CAL_DOT_PER - Poids per. n ="+ num$([M:FIY]PERPDSDET(IP-1))) From =G_GLOB0
            Next IPER
            # <<<<<<<<<<<<
          Next NBEXE
          # <<<<<<<<<<<<
        Endif
        #-2 -------------------------

        # Poids de la détention dans l'exercice
        WPDSDETEXE = sum( [M:FIY]PERPDSDET (find([M:DIV]PERDATREF,  [M:FIY]DATSTRPER)-1..
&                                           find([F:DEPC]FIYENDDAT, [M:FIY]DATENDPER)-1) )
        # Poids de la détention dans les n périodes considérées
        WPDSDET    = sum( [M:FIY]PERPDSDET (find([M:DIV]PERDATREF, [M:FIY]DATSTRPER)-1..
&                                           find([F:DEPC]PERENDDAT,    [M:FIY]DATENDPER)-1) )

        Call ECR_FICH
&       ("FS1",8,"CAL_DOT_PER - Poids per n-1 + per c.     = "+num$(arr(WPDSDET,0.000001))    ) From =G_GLOB0
        Call ECR_FICH
&       ("FS1",8,"CAL_DOT_PER - Poids détention exercice   = "+num$(arr(WPDSDETEXE,0.000001)) ) From =G_GLOB0
        #-1 -----------
        If (WPDSDETEXE = 0 ) Then
          WDOTPER = 0.
          WEXCPER = 0.
          # FQ59415
          # If ( [M:DIV]BSRA and abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          #   WDOTPER    = PDOTEXE - PCUMP_1
          # Endif
          # FQ59941 Si la détention exercice est 0, la dotation doit être à 0 et s'il existe un cum P-1 on doit l'extourner.
          If ( [M:DIV]BSRA ) Then
             If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then : WDOTPER    = PDOTEXE - PCUMP_1  : Endif
          Else
             # FQ95959 si problème dissocier si PEREFCLC = Début exercice ou non ie PDOTEXE ou PMNTREF
             # WDOTPER = PDOTEXE - PCUMP_1
             WDOTPER = PMNTREF- PCUMP_1
          Endif
        #-1 -----------
        Elsif ([M:DIV2]BSOLDPER = G_OUI) Then
          # FQ106778_1
          # Si solde sur la dotation periode courante, les dotations des périodes suivantes sont à 0.
          WDOTPER = 0
        #-1 -----------
        Else
          # Dotation de la période n
          #-2 -----------
          # FQ106778_1
          Local Decimal YDOTEXE
          If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT = [0/0/0]  ) Then
            # Dans le cas d'un rattrapage PERIODE,
            # le cumul P-1 ne contient pas l'écart à rattraper ( pour les périodes suivants le changement de méthode )
            # Si l'on compare cumul P-1 & dotation exercice il faut également déduire l'écart de cette dotation
            Case [M:DIV]TYPCAL
            When "R"
              YDOTEXE = (PDOTEXE - [M:DIV]ECACUME_1R)
            When "T"
              YDOTEXE = (PDOTEXE - [M:DIV]ECACUME_1T)
            When "I"
              YDOTEXE = (PDOTEXE - [M:DIV]ECACUME_1I)
            Endcase
          Else
            YDOTEXE = PDOTEXE
          Endif
          # FQ106778_1
          #If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          # FQ120486
          # If ( abs(PCUMP_1) >= abs(YDOTEXE) ) Then
          # FQ121039
          #If ( abs(PCUMP_1) > abs(YDOTEXE) ) Then
          If ( abs(PCUMP_1) > abs(YDOTEXE) and
&              ( ([M:DIV]DATSORREG <> [0/0/0] and [M:DIV]DATSORREG <= [F:DEPC]PERENDDAT) or
&                ([M:DIV]DTFNAMT   <> [0/0/0] and [M:DIV]DTFNAMT   <= [F:DEPC]PERENDDAT) )
&            ) Then
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1 > = Dotation Exe. - !!!! Solde amortissement !!!! ") From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotation Exe. = "+num$(PDOTEXE)) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1     = "+num$(PCUMP_1)   ) From =G_GLOB0
            Call ECR_FICH("FS1", 8,"CAL_DOT_PER - Date sor. règ = " + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0

            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dot. Per = Dot. Exe. - Cumul P-1") From =G_GLOB0
            # Solde sur la dotation periode courante
            WDOTPER    = PDOTEXE - PCUMP_1

            # FQ102893, FQ106778_1
            #If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT = [0/0/0]  ) Then
            If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT <> [0/0/0] ) Then
              [M:DIV2]BSOLDPER = G_OUI
              Case [M:DIV]TYPCAL
              When "R"
                WDOTPER = (PDOTEXE - [M:DIV]ECACUME_1R) - PCUMP_1
              When "T"
                WDOTPER = (PDOTEXE - [M:DIV]ECACUME_1T) - PCUMP_1
              When "I"
                WDOTPER = (PDOTEXE - [M:DIV]ECACUME_1I) - PCUMP_1
              Endcase
            Endif
          Else
            # FQ120486
            If ([M:DIV]RGLECAE_1 = GVML_REXCPER and PCUMP_1 = PDOTEXE) Then
              WDOTPER = 0
            Else
              WDOTPERCUM = ( PMNTREF * (WPDSDET / WPDSDETEXE) )
              #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From =G_GLOB8
              [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
              Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPERCUM = [M:DIV]RV(1)
              Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotation période P-1 + Pc  = "+num$(WDOTPERCUM)) From =G_GLOB0
              Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)   ) From =G_GLOB0
              WDOTPER    = WDOTPERCUM - PCUMP_1
            Endif
          Endif

          # Amt Exceptionnel  de la période n
          #-2 -----------
          If (PAMTEXC <> 0 ) Then
            If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
              WEXCPER = 0
            Else
              WDOTEXCCUM = ( PAMTEXC * (WPDSDET / WPDSDETEXE) )
              #Call CAL_ARRONDI_MNT (WDOTEXCCUM, [M:DIV]CUR, WDOTEXCCUM) From =G_GLOB8
              [M:DIV]PV(0)= WDOTEXCCUM : [M:DIV]PC(0)= [M:DIV]CUR
              Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXCCUM = [M:DIV]RV(1)
              Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Période P-1 + Pc    = "+num$(WDOTEXCCUM) ) From =G_GLOB0
              Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Cumul P-1           = "+num$(PEXCP_1)    ) From =G_GLOB0
              WEXCPER    = WDOTEXCCUM - PEXCP_1
            Endif
          Endif
          #-2 -----------

  #        # FQ98322 Si repr. totale dépréciation, le réel hérite du mode théorique => pas de dérogatoire
  #        #-2 -----------
  #        If ( [F:DEPC]IMLBLC = 0 and PCUMP_1 <> [F:DEPC]PERCLOCUMT and [F:DEPC]PERTRFCUM <> 0) Then
  #          # (C1) Solde de dépréciation = à 0
  #          # & (C2) Cumul périodique R&T (encore) <>. (deviendront = à la période suivante)
  #          # & (C3) Cumul périodique de reprise automatique de dépréciation <> 0
  #          WEXCPER = PAMTEXC -([F:DEPC]PERTRFCUM)
  #          Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Reprise PERTRFCUM en Excpt = "+num$(WEXCPER) ) From =G_GLOB0
  #        #-2 -----------
  #        Else
  #          If ( PAMTEXC <> 0 ) Then
  #            If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
  #              WEXCPER =  PAMTEXC - PEXCP_1
  #            Else
  #              WDOTEXCCUM = ( PAMTEXC * (WPDSDET / WPDSDETEXE) )
  #              #Call CAL_ARRONDI_MNT (WDOTEXCCUM, [M:DIV]CUR, WDOTEXCCUM) From =G_GLOB8
  #              [M:DIV]PV(0)= WDOTEXCCUM : [M:DIV]PC(0)= [M:DIV]CUR
  #              Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXCCUM = [M:DIV]RV(1)
  #              Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Période P-1 + Pc    = "+num$(WDOTEXCCUM) ) From =G_GLOB0
  #              Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Cumul P-1           = "+num$(PEXCP_1)    ) From =G_GLOB0
  #              WEXCPER    = WDOTEXCCUM - PEXCP_1
  #            Endif
  #          Endif
  #        Endif
  #        #-2 -----------

        Endif
        #-1 -----------

        # FQ84283
        If (WMODAMT = G_DPMAD) Then
          [M:DIV]DTFNAMT = S_DTFNAMT
        Endif

      When G_DPMUO
        #--------------------------


        # Si fin du plan de production est renseignée et antérieure au début d'amortissement
        # Pas de calcul, la dotation exercice est égale à 0
        # FQ93904
        #If ( [M:DIV]DTFNPPL <> [0/0/0] and [M:DIV]DTFNPPL < [M:DIV]DTDBAMTREG ) Then
       # FQ109277
  #     If ( [M:DIV]DTFNPPL <> [0/0/0] and
  #&         ( [M:DIV]DTFNPPL < [M:DIV]DTDBAMTREG or [F:DEPC]PERENDDAT > [M:DIV]DTFNPPL ) ) Then
       If ( [M:DIV]DTFNPPL <> [0/0/0] and
&           ( [M:DIV]DTFNPPL < [M:DIV]DTDBAMTREG or [F:DEPC]PERSTRDAT > [M:DIV]DTFNPPL ) ) Then
          [F:DEPC]PERQTY = 0
          [F:DEPC]RSDQTY = 0
          RDOTPER = 0.
          REXCPER = 0.
          Call ECR_FICH("FS1",8,"CAL_DOT_PER > Dotation Période           = "+format$([M:DIV]CURFMT, RDOTPER)) From =G_GLOB0
          Gosub CAL_RMVLVL From =G_GLOB0
          End
        # ***
        Endif


        Local Integer WIPC
        Local Integer WIPN
        Local Integer WIFNE
        Local Decimal WUOAREP
        Local Decimal WUOPCUM
        # Indice période 1
        WIPC   = find([M:DIV]PERDATREF, [M:PPL]PERSTRDAT)
        # Indice période n
        WIPN   = find([F:DEPC]PERENDDAT, [M:PPL]PERENDDAT)
        # Indice fin exercice
        WIFNE  = find([F:DEPC]FIYENDDAT, [M:PPL]PERENDDAT)
        If (WIFNE = 0 and func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNPPL, [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT,"I") ) Then
          WIFNE  = [M:PPL]NB_PPL : # FQ109277
        Endif
        # Cumul UO périodes de l'exercice résiduel ( à répartir ) FQ62320
        If ([M:PPL]IPSO) Then
          WUOAREP   = sum([M:PPL]PERQTY(WIPC-1..min([M:PPL]IPSO, WIFNE,[M:PPL]IFNA)-1))
        Else
          WUOAREP   = sum([M:PPL]PERQTY(WIPC-1..min(WIFNE,[M:PPL]IFNA)-1))
        Endif

        #  UO périodes cumulées [Pc à Pn]
        # FQ100742_2
        # WUOPCUM    = sum([M:PPL]PERQTY(WIPC-1..WIPN-1))
        Call ECR_FICH("FS1",8,"CAL_DOT_PER - UO Période c               = "+num$([M:PPL]PERSTRDAT(WIPC-1)) ) From =G_GLOB0
        If ([M:PPL]IPSO) Then
        WUOPCUM    = sum([M:PPL]PERQTY(WIPC-1..min([M:PPL]IPSO-1, WIPN-1)))
        Call ECR_FICH("FS1",8,"CAL_DOT_PER - UO Période n               = "+num$([M:PPL]PERSTRDAT(min([M:PPL]IPSO, WIPN-1))) ) From =G_GLOB0
        Else
        Call ECR_FICH("FS1",8,"CAL_DOT_PER - UO Période n               = "+num$([M:PPL]PERSTRDAT(WIPN-1)) ) From =G_GLOB0
        WUOPCUM    = sum([M:PPL]PERQTY(WIPC-1..WIPN-1))
        Endif

        [F:DEPC]PERQTY = [M:PPL]PERQTY(WIPN-1)                      : # UO périodes
        [F:DEPC]RSDQTY = sum([M:PPL]PERQTY(WIPN-1..[M:PPL]IFNA-1))  : # UO résiduelle periode n

        Call ECR_FICH("FS1",8,"CAL_DOT_PER - UO [Pc à Pn]               = "+num$(WUOPCUM)       ) From =G_GLOB0
        Call ECR_FICH("FS1",8,"CAL_DOT_PER - UO [Pc à Pfe]              = "+num$(WUOAREP)       ) From =G_GLOB0

        #-1 -----------
        If ( WUOAREP = 0 ) Then
          WDOTPER = 0.
          WEXCPER = 0.
          # FQ59415
          #If ( [M:DIV]BSRA and abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          #  WDOTPER    = PDOTEXE - PCUMP_1
          #Endif
          # FQ59941 constaté en testant le mode UR
          # Si la détention exercice est 0, la dotation doit être à 0 et s'il existe un cum P-1 on doit l'extourner.
          If ( [M:DIV]BSRA ) Then
             If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then : WDOTPER    = PDOTEXE - PCUMP_1  : Endif
          Else
            # FQ93904
            #WDOTPER = PDOTEXE - PCUMP_1
          Endif
        #-1 -----------
        Else
          # Dotation de la période n
          #-2 -----------
          If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - !!!!! Solde !!!! CUMP_1 > DOTEXE") From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(WDOTPERCUM)) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotexe                     = "+num$(PDOTEXE)   ) From =G_GLOB0
            WDOTPER    = PDOTEXE - PCUMP_1
          Else
            WDOTPERCUM = ( PMNTREF * (WUOPCUM / WUOAREP) )
            #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From =G_GLOB8
            [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPERCUM = [M:DIV]RV(1)
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dot. [Pc à Pfe]            = "+num$(PMNTREF))    From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dot. [Pc à Pn] = Dot.[Pc à Pfe] * (UO[Pc à Pn] / UO[Pc à Pfe])") From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotation [Pc à Pn]         = "+num$(WDOTPERCUM)) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotation [Pc à Pn-1]       = "+num$(PCUMP_1)   ) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dot. période = Dot.[Pc à Pn] - Dot.[Pc à Pn-1]") From =G_GLOB0
            WDOTPER    = WDOTPERCUM - PCUMP_1
          Endif
          # Amt Exceptionnel  de la période n
          #-2 -----------
          If ( PAMTEXC <> 0 ) Then
            If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
              WEXCPER = 0
            Else
            WDOTEXCCUM = ( PAMTEXC * (WUOPCUM / WUOAREP) )
            #Call CAL_ARRONDI_MNT (WDOTEXCCUM, [M:DIV]CUR, WDOTEXCCUM) From =G_GLOB8
            [M:DIV]PV(0)= WDOTEXCCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXCCUM = [M:DIV]RV(1)
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Période P-1 + Pc    = "+num$(WDOTEXCCUM) ) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Cumul P-1           = "+num$(PEXCP_1)    ) From =G_GLOB0
            WEXCPER    = WDOTEXCCUM - PEXCP_1
            Endif
          Endif
          #-2 -----------
        Endif
        #-1 -----------

      When G_DPMUD, G_DPMUL, G_DPMCA, G_DPMRA, G_DPMTD
      #--------------------------
        # FQ105809
        # Classique : Sans tenir compte du poids des périodes

        #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
        #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 6 ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # FQ88728 FQ105809
        # Si mode "UL" ou "UD" on conserve l'ancien fonctionnement jusqu'à avis contraire FQ77877
  #      If ( WMODAMT = G_DPMUD or WMODAMT = G_DPMUL or WMODAMT = G_DPMRL ) Then
  #        WDTDBAMT = [M:DIV]DTDBAMTREG
  #      Endif
        # Si mode "UL" ou "UD" et 1/2 mois ou RL
        If (  WMODAMT = G_DPMRL or ([M:DIV]TYPPRODAT = "Q" and (find(WMODAMT, G_DPMUD,G_DPMUL,G_DPMTD)>0)) ) Then
          WDTDBAMT = [M:DIV]DTDBAMTREG
        Endif

  # FQ88728
  #      Local Char STYPPRODAT : STYPPRODAT = ""
  #      If ([M:DIV]TYPPRODAT = "T" ) Then
  #        STYPPRODAT = [M:DIV]TYPPRODAT
  #        [M:DIV]TYPPRODAT = "M"
  #      Endif

        # Détention dans la période [P-1 à Pc]
  #     Call  CAL_DUR_DET
  #&          ([M:DIV]EXEDATREF, [M:DIV]DTFNPER, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
  #&           [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_CAL_DUR_DET From =G_GLOB8
        WDURDET = [M:DIV]RV(1)

        # Détention dans l'exercice
  #     Call  CAL_DUR_DET
  #&          ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
  #&           [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDETEXE) From =G_GLOB8
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_CAL_DUR_DET From =G_GLOB8
        WDETEXE = [M:DIV]RV(1)
        Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée détention [P-1 à Pc] = "+num$(WDURDET) ) From =G_GLOB0
        Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée Exercice             = "+num$(WDETEXE) ) From =G_GLOB0

  # FQ88728
  #      If ( STYPPRODAT <> "" ) Then : [M:DIV]TYPPRODAT = STYPPRODAT : Endif
        #-1 -----------
        If (WDETEXE = 0 ) Then
          WDOTPER = 0.
          WEXCPER = 0.
          # FQ59415
          If ( [M:DIV]BSRA and abs(PCUMP_1) >= abs(PDOTEXE) ) Then
            WDOTPER    = PDOTEXE - PCUMP_1
          Endif
        #-1 -----------
        Else
          # Dotation de la période n
          #-2 -----------
          # FQ119513
          #If ( abs(PCUMP_1) >= abs(PDOTEXE) and [M:DIV]RGLECAE_1 <> GVML_RDOTPER ) Then
          # FQ121039
          If ( abs(PCUMP_1) >= abs(PDOTEXE) and [M:DIV]RGLECAE_1 <> GVML_RDOTPER  and
&              ( ([M:DIV]DATSORREG <> [0/0/0] and [M:DIV]DATSORREG <= [F:DEPC]PERENDDAT) or
&                ([M:DIV]DTFNAMT   <> [0/0/0] and [M:DIV]DTFNAMT   <= [F:DEPC]PERENDDAT) )
&            ) Then
            WDOTPER    = PDOTEXE - PCUMP_1
          Else
            WDOTPERCUM = ( PMNTREF * (WDURDET / WDETEXE) )
            #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From =G_GLOB8
            [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPERCUM = [M:DIV]RV(1)
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotation période P-1 + Pc  = "+num$(WDOTPERCUM)) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)   ) From =G_GLOB0
            WDOTPER    = WDOTPERCUM - PCUMP_1
          Endif
          # Amt Exceptionnel  de la période n
          #-2 -----------
          If ( PAMTEXC <> 0 ) Then
            If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
              WEXCPER = 0
            Else
            WDOTEXCCUM = ( PAMTEXC * (WDURDET / WDETEXE) )
            #Call CAL_ARRONDI_MNT (WDOTEXCCUM, [M:DIV]CUR, WDOTEXCCUM) From =G_GLOB8
            [M:DIV]PV(0)= WDOTEXCCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXCCUM = [M:DIV]RV(1)
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Période P-1 + Pc    = "+num$(WDOTEXCCUM) ) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Cumul P-1           = "+num$(PEXCP_1)    ) From =G_GLOB0
            WEXCPER    = WDOTEXCCUM - PEXCP_1
            Endif
          Endif
          #-2 -----------
        Endif
        #-1 -----------

        Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)    ) From =G_GLOB0

      When G_DPMPC, G_DPMPD
      #--------------------------

        If ( PDOTEXE = 0 and PAMTEXC = 0 and [M:DIV]DATSORREG = [0/0/0] ) Then
          RDOTPER = 0.
          REXCPER = 0.
          Gosub CAL_RMVLVL From =G_GLOB0
          End
        Endif

        # FQ57526
        WDTDBAMT = [M:DIV]DTDBAMTREG

        Local Integer IPER,      INDPER
        Local Decimal WRECCUMP_1

        If ( WMODAMT = G_DPMPD and [F:DEPC]ALWCOD = GVML_RPEXERC and
&            func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBPER , [M:DIV]DTDBEXI, [M:DIV]DTFNEXI, "I") ) Then
          # Si mode Constantes por duodecimos - PD basée sur l'exercice
          # Nombre de mois dans l'exercice selon détention dans l'exercice d'acquisition
  #        Call  CAL_DUR_DET
  #&         (WDTDBAMT,  [M:DIV]DTFNEXE, [M:DIV]DATNUL,  [M:DIV]DATNUL, [M:DIV]DATNUL,
  #&          [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDUREXE) From =G_GLOB8
          [M:DIV]PD(0)= WDTDBAMT : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
          [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DATNUL : [M:DIV]PD(5)= [M:DIV]DTFNAMT
          [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
          Gosub GSB_CAL_DUR_DET From =G_GLOB8
          WDUREXE = [M:DIV]RV(1)
        Else
          # Nombre de mois dans l'exercice 12 mois
          WDUREXE = 12
        Endif

        # Si le cumul P_1 est égal à 0
        # que la période courante se situe dans l'exercice d'acquisition
        # Que la période courante n'est pas la dernière de l'exercice.
        # Que la période de début d'investissement se situe avant la période courante
        # Le cumul P_1 est reconstitué pour régularisation
        # FQ54778 Le rattrapage n'est pas nécessaire si le bien commence à s'amortir à une date au delà de l'exercice courant
        # ( ex: saisie d'un bien en 2007 commençant à s'amortir en 2008)
        WRECUMP_1 = 0.
        #-1 -----------
        # FQ54778
        #      If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBPER , [M:DIV]DTDBEXI, [M:DIV]DTFNEXI, "I") and
        #&       [M:DIV]DTFNPER <> [M:DIV]DTFNEXE and PCUMP_1 = 0 ) Then
        If (  WDTDBAMT < [M:FIY]DATENDFIY ([M:DIV]FEC-1)  and
&         func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBPER , [M:DIV]DTDBEXI, [M:DIV]DTFNEXI, "I") and
&         [M:DIV]DTFNPER <> [M:DIV]DTFNEXE and PCUMP_1 = 0 ) Then
          Call CAL_PERIODE_SELON_DATE ( WDTDBAMT, WDTDBPER, WDTFNPER, INDPER ) From =G_GLOB8
          # FQ54778
          # If (INDPER <> 0 and WDTDBPER < [M:DIV]DTDBEXE ) Then
          If (INDPER <> 0 and WDTDBPER < [M:DIV]DTDBPER ) Then
            # Le cumul P_1 est à reconstituer pour régularisation
            # Répéter jusqu'à la période courante -1
            # >>>>>>>>>
            Repeat
              Call CAL_AJUST_PERIODE ( [M:DIV]TYPPRO,
&             [M:FIY]DATSTRPER(INDPER-1), [M:FIY]DATENDPER(INDPER-1), WDTDBPER, WDTFNPER) From =G_GLOB5
              # Nombre de mois de détention dans la période
  #           Call  CAL_DUR_DET
  #&              ([M:DIV]EXEDATREF, WDTFNPER, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
  #&              [M:DIV]DTFNAMT, [M:DIV]DATSOREXE , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
              [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= WDTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
              [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
              [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
              Gosub GSB_CAL_DUR_DET From =G_GLOB8
              WDURDET = [M:DIV]RV(1)
              If (WDURDET <> 0 ) Then
                WRECCUMP_1 += ( PMNTREF * (WDURDET / WDUREXE) )
              Else
                WRECCUMP_1 = 0.
              Endif
              INDPER += 1
            # FQ49743
            # Until INDPER < [M:DIV]FPC
            Until INDPER >= [M:DIV]FPC
            # >>>>>>>>>
            # Arrondi dans la devise du contexte
            #Call CAL_ARRONDI_MNT (WRECCUMP_1, [M:DIV]CUR, WRECCUMP_1) From =G_GLOB8
            [M:DIV]PV(0)= WRECCUMP_1 : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WRECCUMP_1 = [M:DIV]RV(1)
            Call ECR_FICH("FS1",8,"CAL_DOT_PER > Cum P_1 reconstitué        =" +
&                                              format$([M:DIV]CURFMT, WRECCUMP_1)) From =G_GLOB0
          Endif
        Endif
        #-1 -----------



        # Si la période est la dernière période d'amortissement ou la période de sortie
        #-1 -----------
        #      # FQ87580
  #      If (  ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT , [M:DIV]DTDBPER, [M:DIV]DTFNPER, "I") ) or
  #&           ( [M:DIV]DATSORREG <> [0/0/0] and
  #&             func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSORREG  , [M:DIV]DTDBPER, [M:DIV]DTFNPER, "I")) ) Then
        If (  ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT , [M:DIV]DTDBPER, [M:DIV]DTFNPER, "I") ) or
&             ( [M:DIV]DATSORREG <> [0/0/0] and
&               func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSORREG  , [M:DIV]DTDBPER, [M:DIV]DTFNPER, "I")) or
&             ( [M:DIV]DETVTEDAT <> [0/0/0] and
&               func GLOBB9.CAL_DAT_INSIDE([M:DIV]DETVTEDAT  , [M:DIV]DTDBPER, [M:DIV]DTFNPER, "I")) ) Then
          WDOTPER = PDOTEXE - PCUMP_1
        #-1 -----------
        Else
          # Nombre de mois de détention dans la période
  #        Call  CAL_DUR_DET
  #&           ([M:DIV]EXEDATREF, [M:DIV]DTFNPER, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
  #&           [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
          [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
          [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
          [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
          Gosub GSB_CAL_DUR_DET From =G_GLOB8
          WDURDET = [M:DIV]RV(1)
          #-2 -------------
          If (WDURDET <> 0 ) Then
            WDOTPER = ( PMNTREF * (WDURDET / WDUREXE) ) - PCUMP_1
            # Plafonnement à la valeur nette amortissable
            If ( abs(PCUMP_1) + abs(WDOTPER) > abs(PDOTEXE) and [M:DIV]DATSORREG = [0/0/0] ) Then
              WDOTPER = PDOTEXE - PCUMP_1
            Endif
            # Report de la valeur nette fin période quand elle devient < à la dot. période
            # ceci uniquement lorsque PDOTEXE < PMNTREF
            # FQ57526
  #         If ( abs(PDOTEXE) < abs(PMNTREF) and [M:DIV]DATSORREG = [0/0/0] and
  #&             abs(PDOTEXE) - ( abs(PCUMP_1) + abs(WDOTPER) ) < abs(WDOTPER) ) Then
            If ( abs(PDOTEXE) < abs(PMNTREF) and [M:DIV]DATSORREG = [0/0/0] and
&                abs(PDOTEXE) - ( abs(PCUMP_1) - abs(WDOTPER) ) < 0 ) Then
              WDOTPER = PDOTEXE - PCUMP_1
            Endif
            # Report de la valeur nette fin période quand elle devient < à la dot. période
            # ceci uniquement lorsque PDOTEXE < PMNTREF
            If ( abs(PDOTEXE) > abs(PMNTREF) and [M:DIV]DATSORREG = [0/0/0] and
&                abs(PMNTREF) = ( abs(PCUMP_1) + abs(WDOTPER) )  ) Then
              WDOTPER = PDOTEXE - PCUMP_1
            Endif
          #-2 -------------
          Else
            WDOTPER = 0.
          Endif
          #-2 -------------
          Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée détention période    = "+num$(WDURDET) ) From =G_GLOB0
          Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée détention référence  = "+num$(WDUREXE) ) From =G_GLOB0
          Call ECR_FICH("FS1",8,"CAL_DOT_PER - Dotation P1 à Pn           = "+num$(PDOTEXE) ) From =G_GLOB0
          Call ECR_FICH("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1) ) From =G_GLOB0
        Endif
        #-1 -----------



        If ( WRECCUMP_1 <> 0 ) Then
          # Arrondi dans la devise du contexte
          #Call CAL_ARRONDI_MNT (WDOTPER, [M:DIV]CUR, WDOTPER) From =G_GLOB8
          [M:DIV]PV(0)= WDOTPER : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPER = [M:DIV]RV(1)
          Call ECR_FICH("FS1",8,"CAL_DOT_PER - Dotation Pér. avant regul. =" +
&                                              format$([M:DIV]CURFMT, WDOTPER)) From =G_GLOB0
          # Le cumul P_1 reconstitué est à intégrer dans la dotation de la période courante
          WDOTPER += WRECCUMP_1
        Endif

      When G_DPMSY, G_DPMPR
      #--------------------------
        Local Date     WDTDB2
        Local Decimal  WDOTPER1, WDOTPER2, WDURDET, WDUREXE
        #==============================
        # Dotation périodique Partie 1
        #==============================
        Call ECR_FICH("FS1", 8, "CAL_DOT_PER - Val. amortissable          ="+num$([M:DIV]VALAMT) ) From =G_GLOB0
        # Durée de détention dans la période pour la partie 1
  #     Call  CAL_DUR_DET ( [M:DIV]EXEDATREF, [M:DIV]DTFNPER,   [M:DIV]DATNUL, [M:DIV]DTFN1, WDTDBAMT,
  #&          [M:DIV]DTFNAMT, [M:DIV]DATSORREG, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DTFN1 : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_CAL_DUR_DET From =G_GLOB8
        WDURDET = [M:DIV]RV(1)
        Call ECR_FICH("FS1", 8, "CAL_DOT_PER - Durée Détention partie 1   =" + num$(WDURDET)  ) From =G_GLOB0
        # Calcul de la durée de l'exercice de référence selon le type de prorata
        Call CAL_DUR_EXE_REF ([M:DIV]DTDBEXE, [M:DIV]DTFNEXE, [M:DIV]TYPPRO, WDUREXE) From =G_GLOB8
        Call ECR_FICH("FS1", 8, "CAL_DOT_PER - Durée exercice             =" + num$(WDUREXE)  ) From =G_GLOB0
        WDOTPER1 = ( [M:DIV]VALAMT * [M:DIV]TXAMT1 * (WDURDET / WDUREXE) )
        #Call CAL_ARRONDI_MNT (WDOTPER1 , [M:DIV]CUR, WDOTPER1 ) From =G_GLOB8
        [M:DIV]PV(0)= WDOTPER1 : [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPER1 = [M:DIV]RV(1)
        Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotation période partie 1  ="+num$(WDOTPER1)    ) From =G_GLOB0
        #==============================
        # Dotation périodique Partie 2
        #==============================
        # Date de début pour calcul partie 2
        WDTDB2 = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFN1,  1, "D" )
  #     Call  CAL_DUR_DET ( WDTDB2, [M:DIV]DTFNPER, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DATNUL,
  #&          [M:DIV]DTFNAMT, [M:DIV]DATSORREG, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
        [M:DIV]PD(0)= WDTDB2 : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DATNUL: [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_CAL_DUR_DET From =G_GLOB8
        WDURDET = [M:DIV]RV(1)
        Call ECR_FICH("FS1", 8, "CAL_DOT_PER - Durée Détention partie 2   =" + num$(WDURDET)  ) From =G_GLOB0
        Call ECR_FICH("FS1", 8, "CAL_DOT_PER - Durée exercice             =" + num$(WDUREXE)  ) From =G_GLOB0
        Call ECR_FICH("FS1", 8, "CAL_DOT_PER - Val. amortissable          =" + num$([M:DIV]VALAMT)) From =G_GLOB0
        WDOTPER2 = ( [M:DIV]VALAMT * [M:DIV]TXAMT2 *(WDURDET / WDUREXE) )
        #Call CAL_ARRONDI_MNT (WDOTPER2 , [M:DIV]CUR, WDOTPER2 ) From =G_GLOB8
        [M:DIV]PV(0)= WDOTPER2 : [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPER2 = [M:DIV]RV(1)
        Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotation période partie 2  ="+num$(WDOTPER2)   ) From =G_GLOB0
        # Dotation de la période n
        Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  ="+num$(PCUMP_1)    ) From =G_GLOB0
        WDOTPER    = WDOTPER1 + WDOTPER2 - PCUMP_1

        # FQ63646
        # ---------- Sécurité -------------------
        # Dotation de la période n
        If ( abs(WDOTPER1 + WDOTPER2) > abs(PDOTEXE) ) Then
          # Ajustement de WDOTPER par rapport à a dotation exercice
          WDOTPER = PDOTEXE - PCUMP_1
        Else
          WDOTPER = ( WDOTPER1 + WDOTPER2 ) - PCUMP_1
        Endif
        If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[M:DIV]DTDBPER,[M:DIV]DTFNPER,"I") ) Then
          # Ajustement sur la dernière période
          WDOTPER = PDOTEXE - PCUMP_1
        Endif
        # ---------- Sécurité -------------------

      #-- Mode russe
      When G_DPMCR
        Gosub CAL_DOT_PER_CR From =G_GLOB5RU

      When G_DPMDR
        Gosub CAL_DOT_PER_DR From =G_GLOB5RU

      When G_DPMLR
        Gosub CAL_DOT_PER_LR From =G_GLOB5RU

      When G_DPMSR
        Gosub CAL_DOT_PER_SR From =G_GLOB5RU

      When G_DPMUR
        Gosub CAL_DOT_PER_UR From =G_GLOB5RU

      #-- Mode polonais
      When G_DPMML
        Gosub CAL_DOT_PER_ML From =G_GLOB5PL

      When G_DPMMD
        Gosub CAL_DOT_PER_MD From =G_GLOB5PL

      #-- Modes roumains FQ77877
      When G_DPMRL
        Gosub CAL_DOT_PER_RL From =G_GLOB5PL
      When G_DPMRX
        Gosub CAL_DOT_PER_RX From =G_GLOB5PL
      When G_DPMRD
        Gosub CAL_DOT_PER_RD From =G_GLOB5PL

      When Default
      #--------------------------
        WDOTPER = 0.
        WEXCPER = 0.

    Endcase
    #--------------------------

  # -1 --------------------------------------------
  Endif

  # FQ116979
  If ([M:DIV]DIFRGL = GVML_RGNODER and [F:DEPC]DPRPLN = G301FIS and [F:DEPC]FIYSTRDAT = [M:FIY]DATSTRFIY ([M:DIV]FEC-1)) Then
  # FQ120477
##    If ( abs([F:DEPC]ENDDPE + [F:DEPC]EXCDPR) = abs([M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1))
##&   and  abs([F:DEPC]PERCLOCUM + [F:DEPC]PERCLOEXC) = abs([M:PCPT]PERCLOCUM([M:DIV]DL-1) + [M:PCPT]PERCLOEXC([M:DIV]DL-1)) ) Then
#    If   not func GLOBB9.CAL_DAT_INSIDE(max([F:DEPC]ENDDPRDAT,[M:PCPT]ENDDPRDAT([M:DIV]DL-1)),[M:DIV]DTDBPER,[M:DIV]DTFNPER,"I")  Then
    If ( abs([F:DEPC]ENDDPE + [F:DEPC]EXCDPR) = abs([M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1))
&        and  abs([F:DEPC]PERCLOCUM + [F:DEPC]PERCLOEXC) = abs([M:PCPT]PERCLOCUM([M:DIV]DL-1) + [M:PCPT]PERCLOEXC([M:DIV]DL-1))
&      )
&    or
&      (  not func GLOBB9.CAL_DAT_INSIDE(max([F:DEPC]ENDDPRDAT,[M:PCPT]ENDDPRDAT([M:DIV]DL-1)),[M:DIV]DTDBPER,[M:DIV]DTFNPER,"I")
&      )  Then
      # Si règle différé =  pas de dérogatoire
      # que la dotation exercice comptable = celle du fiscal
      # que le cumul P-1 du plan comptable = celui du fiscal
      # la dotation périodique du plan fiscal hérite de celle du comptable

      # X3-63997
      Case [M:DIV]TYPCAL
      When "R"
        # Valeur nette amortissable début de période
        [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - RDP (S)" : Gosub CAL_ADDLVL  From =G_GLOB0
        #Call CAL_VALEUR_NETTE ( "RDP", [F:DEPC]DPRBAS, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
        [M:DIV]PC(0)= "RDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
        Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      When "T"
        # Valeur nette amortissable début de période
        [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - TDP (S)" : Gosub CAL_ADDLVL  From =G_GLOB0
        #Call CAL_VALEUR_NETTE ( "TDP", [F:DEPC]DPRBAS, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
        [M:DIV]PC(0)= "TDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
        Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      When "I"     # When "T" FQ102893
        # Valeur nette amortissable début de période
        [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - IDP (S)" : Gosub CAL_ADDLVL  From =G_GLOB0
        #Call CAL_VALEUR_NETTE ( "IDP", [F:DEPC]BSEVAL, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
        [M:DIV]PC(0)= "IDP" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
        Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      Endcase
      # Si la valeur nette fiscale debut de période n'est pas nulle
      If ([M:DIV]RV(1) <> 0 ) Then
        WDOTPER = [M:PCPT]PERENDDPE([M:DIV]DL-1)
        WEXCPER = [M:PCPT]PEREXCDPR([M:DIV]DL-1)
      Endif
    Endif
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTPER, [M:DIV]CUR, RDOTPER) From =G_GLOB8
  [M:DIV]PV(0)= WDOTPER : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : RDOTPER = [M:DIV]RV(1)
  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WEXCPER, [M:DIV]CUR, REXCPER) From =G_GLOB8
  [M:DIV]PV(0)= WEXCPER : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : REXCPER = [M:DIV]RV(1)

  Call ECR_FICH("FS1",8,"CAL_DOT_PER > Dotation Période           = "+
&                                      format$([M:DIV]CURFMT, RDOTPER)) From =G_GLOB0
  If ( REXCPER <> 0 ) Then
    Call ECR_FICH("FS1",8,"CAL_DOT_PER > Amt Excpt Période          = "+
&                                        format$([M:DIV]CURFMT, REXCPER)) From =G_GLOB0
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End



#
#
#*****************************************************************************************************
#*****************************************************************************************************
#*****************************************************************************************************
#    C O N C E S S I O N S      -     P R O V I S I O N S     R E N O U V E L L E M E N T
#*****************************************************************************************************
#*****************************************************************************************************
#*****************************************************************************************************
#
# FQ54343



#########################################################
Subprog  CCN_PROV_PER ( PEXEACGRPR, PEXEFISRPR, PEXERVERPR, PEXESUPCAD,
&                       PP_1ACGRPR, PP_1FISRPR, PP_1RVERPR, PP_1SUPCAD,
&                       RPERACGRPR, RPERFISRPR, RPERRVERPR, RPERSUPCAD )
#
# - Objet  : Calcul de la dotation de la période par différence de cumul
#            La dotation de la période est égale à la part d'un montant de reférence
#            La part de la période n est égale à la part revenant aux périodes 1 à n de l'exercice
#            diminuée de celle déjà attribuée aux périodes 1 à n-1.
#
#
# - Entrée : [M:RPR]
#
# - Sortie : Provision de la période n
#
#

Value    Decimal   PEXEACGRPR    : # Provision comptable exercice
Value    Decimal   PEXEFISRPR    : # Provision fiscale exercice
Value    Decimal   PEXERVERPR    : # Reprise provision fiscale exercice
Value    Decimal   PEXESUPCAD    : # Supplément de caducité exercice
Value    Decimal   PP_1ACGRPR    : # Cumul provision comptable des périodes 1 à n-1
Value    Decimal   PP_1FISRPR    : # Cumul provision fiscale des périodes 1 à n-1
Value    Decimal   PP_1RVERPR    : # Cumul reprise provision fiscale des périodes 1 à n-1
Value    Decimal   PP_1SUPCAD    : # Cumul supplément de caducité des périodes 1 à n-1
Variable Decimal   RPERACGRPR    : # Provision comptable période
Variable Decimal   RPERFISRPR    : # Provision fiscale période
Variable Decimal   RPERRVERPR    : # Reprise provision fiscale période
Variable Decimal   RPERSUPCAD    : # Supplément de caducité période

RPERACGRPR    = 0.
RPERFISRPR    = 0.
RPERRVERPR    = 0.
RPERSUPCAD    = 0.

Local Decimal WPDSDETEXE         : WPDSDETEXE = 0
Local Decimal WPDSDET            : WPDSDET    = 0
Local Decimal WDOTPER            : WDOTPER    = 0.
Local Decimal WEXCPER            : WEXCPER    = 0.
Local Decimal WDOTPERCUM         : WDOTPERCUM = 0.

Local Decimal WDUREXE            : WDUREXE    = 0.
Local Decimal WDURDET            : WDURDET    = 0.
Local Decimal WDETEXE            : WDETEXE    = 0.
Local Decimal WDURDETCPT         : WDURDETCPT = 0.
Local Decimal WDETEXECPT         : WDETEXECPT = 0.
Local Date    WDTDBPER,  WDTFNPER
Local Char    WMODAMT
Local Date    WDTDBAMT



  #If ( GUSER = "MWA" and [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # Par défaut Début de ventilation sur la période dans laquelle se situe le début d'amortissement
  WDTDBAMT = [F:DEPC]STRDPRDAT

  Call ECR_FICH("FS1",8,"CCN_PROV_PER - Prov. Compt à répartir          ="+
&                                      format$([M:DIV]CURFMT, PEXEACGRPR)) From =G_GLOB0
  Call ECR_FICH("FS1",8,"CCN_PROV_PER - Prov. Fisc. à répartir          ="+
&                                      format$([M:DIV]CURFMT, PEXEFISRPR)) From =G_GLOB0
  Call ECR_FICH("FS1",8,"CCN_PROV_PER - Reprise Prov. Fisc. à répartir  ="+
&                                      format$([M:DIV]CURFMT, PEXERVERPR)) From =G_GLOB0
  Call ECR_FICH("FS1",8,"CCN_PROV_PER - Supplément caducité à répatir   ="+
&                                      format$([M:DIV]CURFMT, PEXESUPCAD)) From =G_GLOB0

  # Cadrage de la nouvelle date de fin de période n dans le champ [M:DIV]DTFNPER
  Call CAL_AJUST_PERIODE
&      ( [M:DIV]TYPPRO, [M:DIV]EXEDATREF, [F:RPRC]PERENDDAT, [M:DIV]DTDBPER, [M:DIV]DTFNPER ) From GLOBB5

  #--------------------------------------------- Comptable
  # Détention dans la période [P-1 à Pc] - FQ63145
#     Call  CAL_DUR_DET
#&          ([M:DIV]EXEDATREF, [M:DIV]DTFNPER, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
#&           [M:DIV]DTFNEXE, [M:DIV]DATSORCCN , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From GLOBB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNEXE
  [M:DIV]PD(6)= [M:DIV]DATSORCCN : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From GLOBB8
  WDURDETCPT = [M:DIV]RV(1)

  # Détention dans l'exercice  - FQ63145
#     Call  CAL_DUR_DET
#&          ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
#&           [M:DIV]DTFNEXE, [M:DIV]DATSORCCN , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDETEXE) From GLOBB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNEXE
  [M:DIV]PD(6)= [M:DIV]DATSORCCN : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From GLOBB8
  WDETEXECPT = [M:DIV]RV(1)
  Call ECR_FICH("FS1",8,"CCN_PROV_PER - Durée détention Comptable [P-1 à Pc] = "+num$(WDURDETCPT) ) From =G_GLOB0
  Call ECR_FICH("FS1",8,"CCN_PROV_PER - Durée Exercice  Comptable            = "+num$(WDETEXECPT) ) From =G_GLOB0

  #--------------------------------------------- Fiscale
  # Détention dans la période [P-1 à Pc] - FQ63145
#     Call  CAL_DUR_DET
#&          ([M:DIV]EXEDATREF, [M:DIV]DTFNPER, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
#&           [M:DIV]DTFNEXE, [M:DIV]DATSORCNN , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From GLOBB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSORCCN : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From GLOBB8
  WDURDET = [M:DIV]RV(1)

  # Détention dans l'exercice  - FQ63145
#     Call  CAL_DUR_DET
#&          ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
#&           [M:DIV]DTFNAMT, [M:DIV]DATSORCCN , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDETEXE) From GLOBB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSORCCN : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From GLOBB8
  WDETEXE = [M:DIV]RV(1)
  Call ECR_FICH("FS1",8,"CCN_PROV_PER - Durée détention Fiscale   [P-1 à Pc] = "+num$(WDURDET) ) From =G_GLOB0
  Call ECR_FICH("FS1",8,"CCN_PROV_PER - Durée Exercice  Fisacle              = "+num$(WDETEXE) ) From =G_GLOB0

  #
  # Comptable
  #
  #-1 -----------
  If ( WDETEXECPT = 0 ) Then
    RPERACGRPR = 0.
  #-1 -----------
  Else
    #--------------------------
    # Provision comptable de la période n
    #--------------------------
    WDOTPER = 0.
    WDOTPERCUM = 0.
    If ( abs(PP_1ACGRPR) >= abs(PEXEACGRPR) ) Then
      WDOTPER    = PEXEACGRPR - PP_1ACGRPR
    Else
      WDOTPERCUM = ( PEXEACGRPR * (WDURDETCPT / WDETEXECPT) )
      #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From GLOBB8
      [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
      Call ECR_FICH ("FS1",8,"CCN_PROV_PER - ** Provision comptable **")                  From =G_GLOB0
      Call ECR_FICH ("FS1",8,"CCN_PROV_PER - Prov période P-1 + Pc  = "+num$(WDOTPERCUM)) From =G_GLOB0
      Call ECR_FICH ("FS1",8,"CCN_PROV_PER - Cumul Prov P-1         = "+num$(PP_1ACGRPR)) From =G_GLOB0
      WDOTPER    = WDOTPERCUM - PP_1ACGRPR
    Endif
    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WDOTPER, [M:DIV]CUR, RPERACGRPR) From GLOBB8
    [M:DIV]PV(0)= WDOTPER : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : RPERACGRPR = [M:DIV]RV(1)
  Endif
  #-1 -----------

  #
  # Fiscale
  #

  #-1 -----------
  If ( WDETEXE = 0 ) Then
    RPERFISRPR = 0.
    RPERRVERPR = 0.
    RPERSUPCAD = 0.
  #-1 -----------
  Else
    #--------------------------
    # Provision fiscale de la période n
    #--------------------------
    WDOTPER = 0.
    WDOTPERCUM = 0.
    If ( abs(PP_1FISRPR) >= abs(PEXEFISRPR) ) Then
      WDOTPER    = PEXEFISRPR - PP_1FISRPR
    Else
      WDOTPERCUM = ( PEXEFISRPR * (WDURDET / WDETEXE) )
      #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From GLOBB8
      [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
      Call ECR_FICH ("FS1",8,"CCN_PROV_PER - ** Provision fiscale **")                    From =G_GLOB0
      Call ECR_FICH ("FS1",8,"CCN_PROV_PER - Prov période P-1 + Pc  = "+num$(WDOTPERCUM)) From =G_GLOB0
      Call ECR_FICH ("FS1",8,"CCN_PROV_PER - Cumul Prov P-1         = "+num$(PP_1FISRPR)) From =G_GLOB0
      WDOTPER    = WDOTPERCUM - PP_1FISRPR
    Endif
    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WDOTPER, [M:DIV]CUR, RPERFISRPR) From GLOBB8
    [M:DIV]PV(0)= WDOTPER : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : RPERFISRPR = [M:DIV]RV(1)
    #--------------------------
    # Reprise provision fiscale de la période n
    #--------------------------
    WDOTPER = 0.
    WDOTPERCUM = 0.
    If ( abs(PP_1RVERPR) >= abs(PEXERVERPR) ) Then
      WDOTPER    = PEXERVERPR - PP_1RVERPR
    Else
      WDOTPERCUM = ( PEXERVERPR * (WDURDET / WDETEXE) )
      #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From GLOBB8
      [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
      Call ECR_FICH ("FS1",8,"CCN_PROV_PER - ** Provision fiscale **")                     From =G_GLOB0
      Call ECR_FICH ("FS1",8,"CCN_PROV_PER - Rerise période P-1 + Pc = "+num$(WDOTPERCUM)) From =G_GLOB0
      Call ECR_FICH ("FS1",8,"CCN_PROV_PER - Cumul Reprise  P-1      = "+num$(PP_1RVERPR)) From =G_GLOB0
      WDOTPER    = WDOTPERCUM - PP_1RVERPR
    Endif
    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WDOTPER, [M:DIV]CUR, RPERRVERPR) From GLOBB8
    [M:DIV]PV(0)= WDOTPER : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : RPERRVERPR = [M:DIV]RV(1)
    #--------------------------
    # Supplément de caducité de la période n
    #--------------------------
    WDOTPER = 0.
    WDOTPERCUM = 0.
    If ( abs(PP_1SUPCAD) >= abs(PEXESUPCAD) ) Then
      WDOTPER    = PEXESUPCAD - PP_1SUPCAD
    Else
      WDOTPERCUM = ( PEXESUPCAD * (WDURDET / WDETEXE) )
      #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From GLOBB8
      [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
      Call ECR_FICH ("FS1",8,"CCN_PROV_PER - ** Supplément caducité **")                   From =G_GLOB0
      Call ECR_FICH ("FS1",8,"CCN_PROV_PER - Suppl caducité P-1 + Pc = "+num$(WDOTPERCUM)) From =G_GLOB0
      Call ECR_FICH ("FS1",8,"CCN_PROV_PER - Cum suppl cad. P-1      = "+num$(PP_1SUPCAD)) From =G_GLOB0
      WDOTPER    = WDOTPERCUM - PP_1SUPCAD
    Endif
    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WDOTPER, [M:DIV]CUR, RPERSUPCAD) From GLOBB8
    [M:DIV]PV(0)= WDOTPER : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : RPERSUPCAD = [M:DIV]RV(1)
  Endif
  #-1 -----------

  # Si bien "En cours" pas de provisions pour renouvellement
  If ( [F:WFAS]GACACN = GVML_NIENCOU ) Then
    RPERACGRPR = 0
    RPERFISRPR = 0
    RPERRVERPR = 0
    RPERSUPCAD = 0
  Endif

  # Pas de provision fiscale au delà de la date de renouvellement (La provision comptable est calculée)
  # FQ122306   If ( [F:RPRC]PERSTRDAT > [F:WFAS]RNWDAT ) Then
  If ( [F:WFAS]RNWDAT <> [0/0/0] and [F:RPRC]PERSTRDAT > [F:WFAS]RNWDAT ) Then
    If ( [F:WFAS]RNWFLG = G_OUI ) Then
      RPERFISRPR = 0
    Endif
    RPERRVERPR = 0
    RPERSUPCAD = 0
  Endif

 # Pas de provision au delà de la date de sortie
 If ( [F:WFAS]ISSDAT <> [0/0/0] and[F:RPRC]PERSTRDAT > [F:WFAS]ISSDAT ) Then
    RPERACGRPR = 0
    RPERFISRPR = 0
    RPERRVERPR = 0
    RPERSUPCAD = 0
 Endif


  Call ECR_FICH("FS1",8,"CCN_PROV_PER > Prov Comptable Période   = "+
&                                      format$([M:DIV]CURFMT, RPERACGRPR)) From =G_GLOB0
  Call ECR_FICH("FS1",8,"CCN_PROV_PER > Prov Fiscale Periode     = "+
&                                      format$([M:DIV]CURFMT, RPERFISRPR)) From =G_GLOB0
  Call ECR_FICH("FS1",8,"CCN_PROV_PER > Repr.Prov Fisc. Période  = "+
&                                      format$([M:DIV]CURFMT, RPERRVERPR)) From =G_GLOB0
  Call ECR_FICH("FS1",8,"CCN_PROV_PER > Suppl. caducité Periode  = "+
&                                      format$([M:DIV]CURFMT, RPERSUPCAD)) From =G_GLOB0


End

