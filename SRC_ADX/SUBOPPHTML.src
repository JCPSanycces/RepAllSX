#<AdxTL>@(#)8.0.0.0 $Revision$
###############################################################################################################
#
#   Génération HTML d'une Affaire                                                     Version 140
#   Module CRM                             
#   
###############################################################################################################

Subprog OPPINHTML(SZRECNUM, IGENERICFILENAME, SZSCREENTYPE, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZSCREENTYPE
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF
ICHAPTER = 0
IERRINF = 0
SZFULLRETFILE = ""
SZRETFILENAME = ""

If SZRECNUM = "" : End : Endif

Gosub HTMLPART1 From CRMXML140

Call TEXTE(18260, SZHTMLTITLE) From OBJDIV      #Affaire
SZSUBPROG = "OPPINHTML"
SZAOBABREV = "OPP"

Gosub HTMLPART2 From CRMXML140
If IERRINF : End : Endif

Gosub DOCOREHTML

Gosub HTMLPART3 From CRMXML140

End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREHTML

Gosub SETOPPEXCEPT From CRMEXCEPT

########################################################
#Variable particulière pour affaire associée
Local Integer IDIMCODSOL
IDIMCODSOL = dim([F:OPP]SBBPJT)
Local Char SZCODSOL(30)(IDIMCODSOL)
Local Integer ITERCODSOL
ITERCODSOL = 0
Raz SZCODSOL
########################################################

#On extrait
Filter [OPP] Where [F:OPP]OPPNUM = SZRECNUM

For [OPP]
    Gosub HTMLOPP From CRMEXCEPT

    ITERCODSOL = 0
    For ITERCODSOL = 0 To dim([F:OPP]SBBPJT) - 1
        SZCODSOL(ITERCODSOL) = [F:OPP]SBBPJT(ITERCODSOL)
    Next
Next

Filter [OPP]

If IDISPLAYOPP
    ITERCODSOL = 0
    For ITERCODSOL = 0 To dim(SZCODSOL) - 1
        If SZCODSOL(ITERCODSOL) <> ""
            Read [OPP] OPP0 = SZCODSOL(ITERCODSOL)
            If !fstat
                Gosub HTMLOPP2 From CRMEXCEPT
            Endif
        Endif
    Next
Endif

Return


