#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char    PARAM(250)(1..20)
Local Decimal BASPAG
PARAM(1) = "A-TS140"
PARAM(2) = "GAL"
Call TRAITE_NUM(BASPAG,PARAM,"","FUNSTOWIPW","",1,"XYFUNSTOWIPW") From GTRAITE
End
#########################################################################
#                                                                       #
#     Resynchronisation des quantités livrées                           #
#                                                                       #
#     - Traitement   : FUNSTOWIPW                                       #
#     - Action       : TRTSTOWIPW (Traitement standard)                 #
#                                                                       #
#########################################################################

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When Default
Endcase
Return

#########################################################################
$INIT
Local File STOCK   [STO]
Local File STOWIPW [SWW]
#--- Issue 110327
Local File STOSERW [SSW]

Local Integer I, J
Local Integer WADXUID(1..500)
Local Integer WDIM
Local Char    WITMREF(GLONITM)
Local Char    WSTOFCY(GLONFCY)
Local Char    WCRIT(80)

WITMREF=PARAM(1)
WSTOFCY=PARAM(2)

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Return

#########################################################################
$EXEC
Local Integer WTRBEGIN : Raz WTRBEGIN

Call UIDADX(WADXUID,WDIM) From TRTX3
#--- Autre méthode (à la place de Call UIDADX)
#Local Char SID(12), SCLI(80), SUID(20)
#Local File (SID,SCLI,SUID) From System adxmac(0)+"@psadx -i -l" -GLANGUE As [SYS_] Where val([F:SYS_]SID)>0
#WDIM=0
#For [SYS_]
#  WDIM += 1
#  WADXUID(WDIM) = val([F:SYS_]SID
#Next SYS_
#Close Local File [SYS_]
#---

If !GSERVEUR  & GFONCTION1="FUNSTOWIPW"
# Ouverture de la trace
    Call OUVRE_TRACE("TRTSTOWIPW") From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(mess(152,184,1),0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

#--- Issue X3-74566
#If WITMREF<>"" & WSTOFCY<>""
#   WCRIT='ITMREF=WITMREF & STOFCY=WSTOFCY & CUMWIPQTY<>0'
#Else
#   WCRIT='CUMWIPQTY<>0'
#Endif
If WITMREF<>"" & WSTOFCY<>""
   WCRIT='ITMREF=WITMREF & STOFCY=WSTOFCY & CUMWIPQTY+CUMWIPQTA<>0'
Else
   WCRIT='CUMWIPQTY+CUMWIPQTA<>0'
Endif
#---

# Verru pour ne pas resynchroniser si on est sur GX3APP
#If nomap<>"GX3APP"

# Si pas de transaction en cours
If adxlog<>1
   Trbegin [STO]
   GOK=1
   WTRBEGIN=1
Endif

If GFONCTION1="FUNSTOWIPW"
   Lock [STO]
   If fstat
      Call ECR_TRACE(mess(157,184,1),1) From GESECRAN
      Goto EXEC_FIN
   Endif
Endif

Raz I, J
For [STO] Hint Key STO3 Where evalue(WCRIT)
   Readlock [STO]Curr
   If !fstat
      WCUMWIPQTY = [F:STO]CUMWIPQTY
      WCUMWIPQTA = [F:STO]CUMWIPQTA
      Raz [F:STO]CUMWIPQTY
      Raz [F:STO]CUMWIPQTA
      For [SWW] Where STOCOU=[F:STO]STOCOU
         If find([F:SWW]PRONUM,WADXUID(1..WDIM))
            [F:STO]CUMWIPQTY += [F:SWW]WIPQTY
            [F:STO]CUMWIPQTA += [F:SWW]WIPQTA
         Else
            Delete [SWW]
         Endif
      Next
      Rewrite [STO]
      J+=1
      If GFONCTION1="FUNSTOWIPW" & [F:STO]CUMWIPQTY<>WCUMWIPQTY
         Call ECR_TRACE([F:STO]STOFCY-[F:STO]ITMREF-num$([F:STO]STOCOU)-":"-
&                       mess(153,184,1)-"="-num$(WCUMWIPQTY)-"/"-
&                       mess(154,184,1)-"="-num$([F:STO]CUMWIPQTY),1)
&             From GESECRAN
         I+=1
      Endif
   Endif
Next

If GFONCTION1="FUNSTOWIPW"
   Call ECR_TRACE(mess(155,184,1)-":"-num$(J),0) From GESECRAN
   Call ECR_TRACE(mess(156,184,1)-":"-num$(I),0) From GESECRAN
Endif

If GFONCTION1="FUNSTOWIPW" : Unlock [STO] : Endif

$EXEC_FIN
# Si on a ouvert une transaction
If WTRBEGIN=1
   Commit
   Raz WTRBEGIN
Endif

#--- Issue 110327
# Si pas de transaction en cours
If adxlog<>1
   Trbegin [STO]
   GOK=1
   WTRBEGIN=1
Endif

If !GSERVEUR  & GFONCTION1="FUNSTOWIPW"
   Call ECR_TRACE(" ",0) From GESECRAN
   Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
   Call ECR_TRACE(mess(451,184,1),0) From GESECRAN
   Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

If WITMREF<>""
   WCRIT='ITMREF=WITMREF'
Else
   WCRIT='1=1'
Endif

I=0
For [SSW] Where evalue(WCRIT)
   If !find([F:SSW]PRONUM,WADXUID(1..WDIM))
      If GFONCTION1="FUNSTOWIPW"
         Call ECR_TRACE([F:SSW]ITMREF-[F:SSW]SERNUM-":"-mess(450,184,1),1) From GESECRAN
      Endif
      Delete [SSW]
      I+=1
   Endif
Next

If GFONCTION1="FUNSTOWIPW"
   Call ECR_TRACE(mess(156,184,1)-":"-num$(I),0) From GESECRAN
Endif

# Si on a ouvert une transaction
If WTRBEGIN=1
   Commit
   Raz WTRBEGIN
Endif
#--- End issue 110327

# Fin de verru pour ne pas resynchroniser si on est sur GX3APP
#Endif

If !GSERVEUR & GFONCTION1="FUNSTOWIPW"
   Call FERME_TRACE From LECFIC
   TRA=1
Endif

Return

#########################################################################
$TERMINE
Close File [STO]
Close File [SWW]

Return

#########################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

