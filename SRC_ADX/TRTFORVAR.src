#For ITYP=1 To 3

# GFERIE=1
#Call VALORTYP(PDATDEB,PDATFIN,PMATRI,GTPSW,NBJR,NBHR,PSITE,PCTR,ITYP) From SUBPLN
# Case ITYP
#  When 1 : PJFERB=NBJR : PHFERB=NBHR :#Ouvrable
#  When 2 : PJFERA=NBJR : PHFERA=NBHR :#Ouvré
# Endcase

# GFERIE=0
# Call VALORTYP(PDATDEB,PDATFIN,PMATRI,GTPSW,NBJR,NBHR,PSITE,PCTR,ITYP) From SUBHRPLN
# Case ITYP
#  When 1 : PJOURB=NBJR : PHRESB=NBHR :#Ouvrable
#  When 2 : PJOURA=NBJR : PHRESA=NBHR :#Ouvré
#  When 3 : PJOURC=NBJR : PHRESC=NBHR :#Calendaire
# Endcase
#Next

If PDATDEB=[0/0/0] | PDATFIN=[0/0/0] : End : Endif

Local Integer ITYP
Local Decimal NBJR
Local Decimal NBHR


If dim(GFERIE)<1
#Global Integer GFERIE     :#0=non compté 1= compté
Endif

For ITYP=1 To 3

 GFERIE=1
Call VALORTYP(PDATDEB,PDATFIN,PMATRI,GTPSW,NBJR,NBHR,PSITE,PCTR,ITYP) From SUBPLN
 Case ITYP
  When 1 : PJFERB=NBJR : PHFERB=NBHR :#Ouvrable
  When 2 : PJFERA=NBJR : PHFERA=NBHR :#Ouvré
 Endcase

 GFERIE=0
 Call VALORTYP(PDATDEB,PDATFIN,PMATRI,GTPSW,NBJR,NBHR,PSITE,PCTR,ITYP) From SUBPLN
 Case ITYP
  When 1 : PJOURB=NBJR : PHRESB=NBHR :#Ouvrable
  When 2 : PJOURA=NBJR : PHRESA=NBHR :#Ouvré
  When 3 : PJOURC=NBJR : PHRESC=NBHR :#Calendaire
 Endcase
Next
#LIPET - 2017-05-20 - END
End


################
Subprog NBJ_ABSENCE (PDATDEB,PDATFIN,PMATRI,PSITE,PCTR,PABSA,PABSB,PABSC,PABSFA,PABSFB)
Value Date PDATDEB
Value Date PDATFIN
Value Char PMATRI ()
Value Char PSITE ()
Value Char PCTR ()
Variable Decimal PABSA
Variable Decimal PABSB
Variable Decimal PABSC
Variable Decimal PABSFA
Variable Decimal PABSFB

#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#If PDATDEB=[0/0/0] | PDATFIN=[0/0/0] : End : Endif
#
#Local Integer ITYP
#Local Decimal NBJR
#Local Decimal NBHR
#
#If dim(GFERIE)<1
# Global Integer GFERIE     :#0=non compté 1= compté
#Endif
#
## Comptabilisation des absence et congès
#For [TIM]TIM0 Where CATTIM=2 |CATTIM=3
# For [TIP]TIP1 Where REFNUM=PMATRI & STRDAT<=PDATFIN & ENDDAT>=PDATDEB & CTRNUM=PCTR & TIM=[F:TIM]COD
#  If [F:TIP]STRDAT>=PDATDEB & [F:TIP]STRDAT=[F:TIP]ENDDAT     :#si 1/2 journée !
#   PABSA+=[F:TIP]NBRDAY
#   PABSB+=[F:TIP]NBRDAY
#   PABSC+=[F:TIP]NBRDAY
#   PABSFA+=[F:TIP]NBRDAY
#   PABSFB+=[F:TIP]NBRDAY
#  Else
#   For ITYP=1 To 3

#    GFERIE=1
#    Call VALORTYP (max([F:TIP]STRDAT,PDATDEB), min([F:TIP]ENDDAT,PDATFIN),PMATRI,[F:TIP]TIM,NBJR,NBHR,PSITE,PCTR,ITYP) From SUBPLN
#    Case ITYP
#     When 1 : PABSFB+=NBJR
#     When 2 : PABSFA+=NBJR
#    Endcase

#    GFERIE=0
#    Call VALORTYP (max([F:TIP]STRDAT,PDATDEB), min([F:TIP]ENDDAT,PDATFIN),PMATRI,[F:TIP]TIM,NBJR,NBHR,PSITE,PCTR,ITYP) From SUBHRPLN
#    Case ITYP
#     When 1 : PABSB+=NBJR
#     When 2 : PABSA+=NBJR
#     When 3 : PABSC+=NBJR
#    Endcase
#   Next
#  Endif
# Next
# If GTPS
#  # Comptabilisation des régularisations d'absence et congès
#  For [TIG]TIG1 Where REFNUM=PMATRI & DATPYR=[F:HRPEO]PYRDAT & CTRNUM=PCTR & TIM=[F:TIM]COD
#   If [F:TIG]STRDAT=[F:TIG]ENDDAT
#    PABSA+=[F:TIG]NBRDAY
#    PABSB+=[F:TIG]NBRDAY
#    PABSC+=[F:TIG]NBRDAY
#    PABSFA+=[F:TIG]NBRDAY
#    PABSFB+=[F:TIG]NBRDAY
#   Else
#    For ITYP=1 To 3
#     GFERIE=1
#     Call VALORTYP([F:TIP]STRDAT,[F:TIP]ENDDAT,PMATRI,[F:TIP]TIM,NBJR,NBHR,PSITE,PCTR,ITYP) From SUBPLN
#     Case ITYP
#      When 1 : PABSFB+=NBJR
#      When 2 : PABSFA+=NBJR
#     Endcase

#     GFERIE=0
#     Call VALORTYP([F:TIP]STRDAT,[F:TIP]ENDDAT,PMATRI,[F:TIP]TIM,NBJR,NBHR,PSITE,PCTR,ITYP) From SUBHRPLN
#     Case ITYP
#      When 1 : PABSB+=NBJR
#      When 2 : PABSA+=NBJR
#      When 3 : PABSC+=NBJR
#     Endcase
#    Next
#   Endif
#  Next
# Endif
#Next

If PDATDEB=[0/0/0] | PDATFIN=[0/0/0] : End : Endif

Local Integer ITYP
Local Decimal NBJR
Local Decimal NBHR

If dim(GFERIE)<1
 Global Integer GFERIE     :#0=non compté 1= compté
Endif

# Comptabilisation des absence et congès
For [TIM]TIM0 Where CATTIM=2 |CATTIM=3
 For [TIP]TIP1 Where REFNUM=PMATRI & STRDAT<=PDATFIN & ENDDAT>=PDATDEB & CTRNUM=PCTR & TIM=[F:TIM]COD
  If [F:TIP]STRDAT>=PDATDEB & [F:TIP]STRDAT=[F:TIP]ENDDAT     :#si 1/2 journée !
   PABSA+=[F:TIP]NBRDAY
   PABSB+=[F:TIP]NBRDAY
   PABSC+=[F:TIP]NBRDAY
   PABSFA+=[F:TIP]NBRDAY
   PABSFB+=[F:TIP]NBRDAY
  Else
   For ITYP=1 To 3

    GFERIE=1
    Call VALORTYP (max([F:TIP]STRDAT,PDATDEB), min([F:TIP]ENDDAT,PDATFIN),PMATRI,[F:TIP]TIM,NBJR,NBHR,PSITE,PCTR,ITYP) From SUBPLN
    Case ITYP
     When 1 : PABSFB+=NBJR
     When 2 : PABSFA+=NBJR
    Endcase

    GFERIE=0
    Call VALORTYP (max([F:TIP]STRDAT,PDATDEB), min([F:TIP]ENDDAT,PDATFIN),PMATRI,[F:TIP]TIM,NBJR,NBHR,PSITE,PCTR,ITYP) From SUBPLN
    Case ITYP
     When 1 : PABSB+=NBJR
     When 2 : PABSA+=NBJR
     When 3 : PABSC+=NBJR
    Endcase
   Next
  Endif
 Next
 If GTPS
  # Comptabilisation des régularisations d'absence et congès
  For [TIG]TIG1 Where REFNUM=PMATRI & DATPYR=[F:HRPEOD]PYRDAT & CTRNUM=PCTR & TIM=[F:TIM]COD
   If [F:TIG]STRDAT=[F:TIG]ENDDAT
    PABSA+=[F:TIG]NBRDAY
    PABSB+=[F:TIG]NBRDAY
    PABSC+=[F:TIG]NBRDAY
    PABSFA+=[F:TIG]NBRDAY
    PABSFB+=[F:TIG]NBRDAY
   Else
    For ITYP=1 To 3
     GFERIE=1
     Call VALORTYP([F:TIP]STRDAT,[F:TIP]ENDDAT,PMATRI,[F:TIP]TIM,NBJR,NBHR,PSITE,PCTR,ITYP) From SUBPLN
     Case ITYP
      When 1 : PABSFB+=NBJR
      When 2 : PABSFA+=NBJR
     Endcase

     GFERIE=0
     Call VALORTYP([F:TIP]STRDAT,[F:TIP]ENDDAT,PMATRI,[F:TIP]TIM,NBJR,NBHR,PSITE,PCTR,ITYP) From SUBPLN
     Case ITYP
      When 1 : PABSB+=NBJR
      When 2 : PABSA+=NBJR
      When 3 : PABSC+=NBJR
     Endcase
    Next
   Endif
  Next
 Endif
Next
#LIPET - 2017-05-20 - END
End

