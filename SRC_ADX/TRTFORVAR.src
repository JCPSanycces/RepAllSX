#<AdxTL>@(#)0.0.0.0 $Revision$
##** V7 : Waiting Time Mangement **#
##*********************************#

######################################################################################
# Dernière modification :
# Si le salarié sortait le jour de la date de début de mois, on ne tenait pas de ce jour
######################################################################################

############################
$CAL_PERIO
##** V7 : Waiting Time Mangement **#
#MIPEA - 2017-02-01- X3-12122- START
If clalev([F:HRPEOD2])=0  : Local File HRPEODET    [HRPEOD2]  : Endif
#If clalev([F:HRPEO2])=0  : Local File HRPERIOD    [HRPEO2]  : Endif
#MIPEA - 2017-02-01- X3-12122- END
##**

If clalev([F:HRCGD])=0 : Local File HRCTRGRD [HRCGD] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Local Decimal E_ABSA, E_ABSA0, E_ABSA1    :# Nb absence en ouvré du mois, du mois-1 & du mois +1
Local Decimal E_ABSB, E_ABSB0, E_ABSB1    :# Nb absence en ouvrable du mois, du mois-1 & du mois +1
Local Decimal E_ABSC, E_ABSC0, E_ABSC1    :# Nb absence en calendaire du mois, du mois-1 & du mois +1
Local Decimal E_TRAVA, E_TRAVA0, E_TRAVA1    :# Nb jours en ouvré du mois, du mois-1 & du mois +1
Local Decimal E_TRAVB, E_TRAVB0, E_TRAVB1    :# Nb jours en ouvrable du mois, du mois-1 & du mois +1
Local Decimal E_TRAVC, E_TRAVC0, E_TRAVC1    :# Nb jours en calendaire du mois, du mois-1 & du mois +1
Local Decimal E_TRAHA, E_TRAHA0, E_TRAHA1    :# Nb hres en ouvré du mois, du mois-1 & du mois +1
Local Decimal E_TRAHB, E_TRAHB0, E_TRAHB1    :# Nb hres en ouvrable du mois, du mois-1 & du mois +1
Local Decimal E_TRAHC, E_TRAHC0, E_TRAHC1    :# Nb hres en calendaire du mois, du mois-1 & du mois +1

Local Decimal E_ABSFA, E_ABSFA0, E_ABSFA1    :# Nb absence ouvré du mois, du mois-1 & du mois +1 (fériés inclus)
Local Decimal E_ABSFB, E_ABSFB0, E_ABSFB1    :# Nb absence ouvrable du mois, du mois-1 & du mois +1 (fériés inclus)
Local Decimal E_FERHA, E_FERHA0, E_FERHA1    :# Nb heures ouvré du mois, du mois-1 & du mois +1 (fériés inclus)
Local Decimal E_FERHB, E_FERHB0, E_FERHB1    :# Nb heures ouvrable du mois, du mois-1 & du mois +1 (fériés inclus)
Local Decimal E_FERJA, E_FERJA0, E_FERJA1    :# Nb jours ouvré du mois, du mois-1 & du mois +1 (fériés inclus)
Local Decimal E_FERJB, E_FERJB0, E_FERJB1    :# Nb jours ouvrable du mois, du mois-1 & du mois +1 (fériés inclus)

# En fonction d'un calendrier société contenu dans le param général CALCPY
Local Decimal E_NBJFA, E_NBJFA0, E_NBJFA1   :# Nb jours ouvré du mois, du mois-1 & du mois +1 (fériés inclus)
Local Decimal E_NBJFB, E_NBJFB0, E_NBJFB1   :# Nb jours ouvrable du mois, du mois-1 & du mois +1(fériés inclus)
Local Decimal E_NBRJA, E_NBRJA0, E_NBRJA1   :# Nb jours ouvré du mois, du mois-1 & du mois +1
Local Decimal E_NBRJB, E_NBRJB0, E_NBRJB1   :# Nb jours ouvrable du mois,

# Calcul de période du mois courant, précédent & suivant
Local Date DATDEB0, DATDEB1, DMOISC, DMOIS0, DMOIS1, FMOISC, FMOIS0, FMOIS1

# Révision du principe de calcul pour gestion des CDD successif et/ou non successif (Micromania)
Local Date SAVSTR, SAVEND

##**82073
Local Integer DEFEXIT
DEFEXIT=0

#Sans le module temps
##** V7 : Waiting Time Mangement **#
#MIPEA - 2017-02-09- X3-11284- START
If !GTPS
 Local Date DMOIS, FMOIS
 #Période courante
 DMOIS  = gdat$(01,month(DATPAY), year(DATPAY))
 FMOIS  = eomonth(DMOIS)
 DATDEB = DMOIS
 #Période prec
 DMOIS0 = addmonth(DMOIS,-1)
 FMOIS0 = eomonth (DMOIS0)
 DATDEB0= DMOIS0
 #Période suivante
 DMOIS1 = addmonth(DMOIS,1)
 FMOIS1 = eomonth (DMOIS1)
 DATDEB1= DMOIS1
Else
 Local Date SAVDMOIS, SAVFMOIS
 SAVDMOIS=DMOIS : SAVFMOIS=FMOIS
 # Période courante
  If GPAYE=1
   ##**82073
   Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY & CTRNUM=CTR & CTRDAT=CTRD
   Read [VEP]VEP0 Last
   Filter [VEP]
   If !fstat & [F:VEP]PST<2
    DMOIS=[F:VEP]STRDAT
    FMOIS=[F:VEP]ENDDAT
    # On récupère DATTPS de la paye précédente [F:VEP]DATTPS+1 et si elle est supérieur à DATDEB
    # c'est que l'on a plusieurs paye pour la même période d'extraction
    # FQ85116 - On cherche le dernier bulletin PAS extourné, donc RVS à 1
    Filter [VEP] Where EMP=MATRI & PYRDAT<[L]DATPAY & CTRNUM=CTR & CTRDAT=CTRD & RVSDAT=[0/0/0] & RVS<>2
    Read [VEP]VEP0 Last
    If !fstat & [F:VEP]DATTPS> [0/0/0] : DATDEB=max([F:VEP]DATTPS+1,DATDEB) : Endif
    Filter [VEP]
   Endif
 Endif

 # Période précédente
 Filter [F:HRPEOD2] Where PERYEA=[F:HRPEOD]PERYEA & PERCOD=[F:HRPEOD]PERCOD & PERNUM<[F:HRPEOD]PERNUM
 Read [F:HRPEOD2]HRPEOD0 Last
 Filter [F:HRPEOD2]
 If !fstat
  DATDEB0 = [F:HRPEOD2]PERSTR(0)
  DMOIS0  = [F:HRPEOD2]PERSTR(1)
  FMOIS0  = [F:HRPEOD2]PEREND(1)
 Else
  DATDEB0 = addmonth(DATDEB,-1)
  DMOIS0  = addmonth(DMOIS,-1)
  FMOIS0  = eomonth (DMOIS0)
 Endif

 # Période suivante
 Filter [F:HRPEOD2] Where PERYEA=[F:HRPEOD]PERYEA & PERCOD=[F:HRPEOD]PERCOD & PERNUM>[F:HRPEOD]PERNUM
 Read [F:HRPEOD2]HRPEOD0 First
 Filter[F:HRPEOD2]
 If !fstat
  DATDEB1 = [F:HRPEOD2]PERSTR(0)
  DMOIS1  = [F:HRPEOD2]PERSTR(1)
  FMOIS1  = [F:HRPEOD2]PEREND(1)
 Else
  DATDEB1 = addmonth(DATDEB,+1)
  DMOIS1  = addmonth(DMOIS,+1)
  FMOIS1  = eomonth (DMOIS1)
 Endif
Endif
#**
##If !GTPS
# Local Date DMOIS, FMOIS
# #Période courante
# DMOIS  = gdat$(01,month(DATPAY), year(DATPAY))
# FMOIS  = eomonth(DMOIS)
# DATDEB = DMOIS
# #Période prec
# DMOIS0 = addmonth(DMOIS,-1)
# FMOIS0 = eomonth (DMOIS0)
# DATDEB0= DMOIS0
# #Période suivante
# DMOIS1 = addmonth(DMOIS,1)
# FMOIS1 = eomonth (DMOIS1)
# DATDEB1= DMOIS1
##Else
## Local Date SAVDMOIS, SAVFMOIS
## SAVDMOIS=DMOIS : SAVFMOIS=FMOIS
## # Période courante
##  If GPAYE=1
##   ##**82073
##   Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY & CTRNUM=CTR & CTRDAT=CTRD
##   Read [VEP]VEP0 Last
##   Filter [VEP]
##   If !fstat & [F:VEP]PST<2
##    DMOIS=[F:VEP]STRDAT
##    FMOIS=[F:VEP]ENDDAT
##    # On récupère DATTPS de la paye précédente [F:VEP]DATTPS+1 et si elle est supérieur à DATDEB
##    # c'est que l'on a plusieurs paye pour la même période d'extraction
##    # FQ85116 - On cherche le dernier bulletin PAS extourné, donc RVS à 1
##    Filter [VEP] Where EMP=MATRI & PYRDAT<[L]DATPAY & CTRNUM=CTR & CTRDAT=CTRD & RVSDAT=[0/0/0] & RVS<>2
##    Read [VEP]VEP0 Last
##    If !fstat & [F:VEP]DATTPS> [0/0/0] : DATDEB=max([F:VEP]DATTPS+1,DATDEB) : Endif
##    Filter [VEP]
##   Endif
## Endif
##
## # Période précédente
## Filter [F:HRPEO2] Where YEA=[F:HRPEO]YEA & FCY=[F:HRPEO]FCY & LIG<[F:HRPEO]LIG
## Read [F:HRPEO2]PEO0 Last
## Filter [F:HRPEO2]
## If !fstat
##  DATDEB0 = [F:HRPEO2]PERSTR(0)
##  DMOIS0  = [F:HRPEO2]PERSTR(1)
##  FMOIS0  = [F:HRPEO2]PEREND(1)
## Else
##  DATDEB0 = addmonth(DATDEB,-1)
##  DMOIS0  = addmonth(DMOIS,-1)
##  FMOIS0  = eomonth (DMOIS0)
## Endif
##
## # Période suivante
## Filter [F:HRPEO2] Where YEA=[F:HRPEO]YEA & FCY=[F:HRPEO]FCY & LIG>[F:HRPEO]LIG
## Read [F:HRPEO2]PEO0 First
## Filter[F:HRPEO2]
## If !fstat
##  DATDEB1 = [F:HRPEO2]PERSTR(0)
##  DMOIS1  = [F:HRPEO2]PERSTR(1)
##  FMOIS1  = [F:HRPEO2]PEREND(1)
## Else
##  DATDEB1 = addmonth(DATDEB,+1)
##  DMOIS1  = addmonth(DMOIS,+1)
##  FMOIS1  = eomonth (DMOIS1)
## Endif
##Endif
###**
#MIPEA - 2017-02-09- X3-11284- END

Local Date DCALEND (0..2)
Local Date FCALEND (0..2)

#Période courante
DCALEND(0)  = gdat$(01,month(DATPAY), year(DATPAY))
FCALEND(0)  = eomonth(DMOIS)
#Période prec
DCALEND(1)= addmonth(DCALEND(0),-1)
FCALEND(1)= eomonth (DCALEND(1))
#Période suivante
DCALEND(2) = addmonth(DCALEND(0),1)
FCALEND(2) = eomonth (DCALEND(2))

Filter [F:HRCTR] Where REFNUM=MATRI & CTRNUM=CTR  & CTRDAT<=FCALEND(0)  & (XITDAT=[0/0/0] | XITDAT>=DCALEND(0))
Read[F:HRCTR]CTR0 Last
Filter [F:HRCTR]
If !fstat
 Call NBJCPY(DCALEND(0),FCALEND(0),[F:HRCTR]ETRFCY,E_NBRJA,E_NBRJB,E_NBJFA,E_NBJFB)
 Call NBJCPY(DCALEND(1),FCALEND(1),[F:HRCTR]ETRFCY,E_NBRJA0,E_NBRJB0,E_NBJFA0,E_NBJFB0)
 Call NBJCPY(DCALEND(2),FCALEND(2),[F:HRCTR]ETRFCY,E_NBRJA1,E_NBRJB1,E_NBJFA1,E_NBJFB1)
Endif
#---------------------------------------------------------------------------------------------------------------
#                 Tenir compte des E/S pour mois courant
#---------------------------------------------------------------------------------------------------------------

##**82073
DMOISC=DMOIS : FMOISC=FMOIS
Filter [F:HRCTR] Where REFNUM=MATRI & CTRNUM=CTR  & CTRDAT<=FMOIS  & (XITDAT=[0/0/0] | XITDAT>=DMOIS)
For [F:HRCTR]CTR0
 If [F:HRCTR]CTRDAT<DMOIS
   DMOISC=DMOIS
 Else
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  GCURLEG=[F:CPY]LEG
  Read[F:HRCGD]HRCGD0=[F:HRCTR]CTRGRD;GCURLEG
  If !fstat & [F:HRCGD]CODN4H<>""
   DMOISC=min(DMOISC,[F:HRCTR]CTRDAT)
  Endif
 Endif
 If [F:HRCTR]XITDAT>FMOIS | [F:HRCTR]XITDAT=[0/0/0]
  FMOISC=FMOIS
 Else
  FMOISC=[F:HRCTR]XITDAT
 Endif
 If [F:HRCTR]XITFNL=2 & [F:HRCTR]XITDAT<DMOIS1 : DEFEXIT=1 : Break : Endif   :##**82073 Si sortie definitive le mois courant s'arrête là !
Next
Filter [F:HRCTR]

#Tenir compte des E/S pour mois précedent
SAVSTR=DMOIS0 : SAVEND=FMOIS0
Filter [F:HRCTR] Where REFNUM=MATRI & CTRNUM=CTR  & CTRDAT<=SAVEND  & (XITDAT=[0/0/0] | XITDAT>=SAVSTR)
For [F:HRCTR]CTR0
 If [F:HRCTR]CTRDAT<SAVSTR
  DMOIS0=SAVSTR
 Else
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  GCURLEG=[F:CPY]LEG
  Read[F:HRCGD]HRCGD0=[F:HRCTR]CTRGRD;GCURLEG
  If !fstat & [F:HRCGD]CODN4H<>""
      DMOIS0=min(DMOIS0,[F:HRCTR]CTRDAT)
  Endif
 Endif
 If [F:HRCTR]XITDAT>SAVEND | [F:HRCTR]XITDAT=[0/0/0]
   FMOIS0=SAVEND
 Else
  FMOIS0=[F:HRCTR]XITDAT
 Endif
 If [F:HRCTR]XITFNL=2 : Break : Endif   :##**82073 Si sortie definitive le mois précédent s'arrête là !
Next
Filter [F:HRCTR]

#Tenir compte des E/S pour mois suivant si pas sortie définitive sur le mois courant
If !DEFEXIT
 SAVSTR=DMOIS1 : SAVEND=FMOIS1
 Filter [F:HRCTR] Where REFNUM=MATRI & CTRNUM=CTR  & CTRDAT<=SAVEND  & (XITDAT=[0/0/0] | XITDAT>=SAVSTR)
 For [F:HRCTR]CTR0
  If [F:HRCTR]CTRDAT<SAVSTR
   DMOIS1=SAVSTR
 Else
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ #OS leg work
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  GCURLEG=[F:CPY]LEG
  Read[F:HRCGD]HRCGD0=[F:HRCTR]CTRGRD;GCURLEG #OS leg work
   If !fstat & [F:HRCGD]CODN4H<>""
    DMOIS1=min(DMOIS1,[F:HRCTR]CTRDAT)
   Endif
  Endif
  If [F:HRCTR]XITDAT>SAVEND | [F:HRCTR]XITDAT=[0/0/0]
   FMOIS1=SAVEND
  Else
   FMOIS1=[F:HRCTR]XITDAT
  Endif
  If [F:HRCTR]XITFNL=2 : Break : Endif   :##**82073 Si sortie definitive le mois précédent s'arrête là !
 Next
 Filter [F:HRCTR]
Else
 Raz DMOIS1 : Raz FMOIS1
Endif

If GTPS
 DMOIS=SAVDMOIS : FMOIS=SAVFMOIS
Endif
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

################
Subprog NBJCPY (PDATDEB,PDATFIN,PSITE,PJA,PJB,PJFA,PJFB)
Value Date PDATDEB
Value Date PDATFIN
Value Char PSITE ()
Variable Decimal PJA
Variable Decimal PJB
Variable Decimal PJFA
Variable Decimal PJFB

#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#

#Local Char PARAM(GLONADP)
#Local Integer ANNEE , SEMAINE
#Local Date    DAT, DEBUT, FIN
#Local Integer K , I, LTYPDAY, J
#Local Decimal LNBRDAY
#Local Integer FERIE

#If clalev([F:WTY])=0 : Local File TYPWEEK   [WTY] : Endif
#If clalev([F:HLY])=0 : Local File HLYDAY    [HLY] : Endif

#Call PARAM(PSITE,"CALCPY",PARAM) From ADOVAL
#If PARAM="" : End : Endif

# Semaine type
#Read [WTY]WTY0 = PARAM
#If fstat : Return : Endif

#Jours Fériés
#Read [HLY]HLY0 = year(PDATDEB);PSITE
#If fstat
# Read [HLY]HLY0 = year(PDATDEB);""
#Endif

#DAT = PDATDEB

#For I=1 To (PDATFIN-PDATDEB)+1
# Raz LNBRDAY
# Call DAT(DAT,ANNEE,SEMAINE)From SUBPLN
# Call SEMAINE(ANNEE,SEMAINE,DEBUT,FIN) From SUBPLN
# K = DAT-DEBUT
# LNBRDAY = [F:WTY]NBRDAY1(K)
# LTYPDAY = [F:WTY]TYPDAY(K)
# If dim([L]AM)>0 & [L]AM=1
#  LNBRDAY = LNBRDAY/2
# Endif

# FERIE = find(DAT,[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
# If FERIE
#  If LTYPDAY<=2 : # Ouvrable ou ouvrés
#    PJFB+= LNBRDAY
#  Endif
#  If LTYPDAY=2 : # Ouvrés
#    PJFA+= LNBRDAY
#  Endif
# Else
#  If LTYPDAY<=2 : # Ouvrable ou ouvrés
#    PJB+= LNBRDAY
#    PJFB+= LNBRDAY
#  Endif
#  If LTYPDAY=2 : # Ouvrés
#    PJA+= LNBRDAY
#    PJFA+= LNBRDAY
#  Endif
# Endif
# DAT += 1
#Next I

Local Char PARAM(GLONADP)
Local Integer ANNEE , SEMAINE
Local Date    DAT, DEBUT, FIN
Local Integer K , I, LTYPDAY, J
Local Decimal LNBRDAY
Local Integer FERIE

If clalev([F:WTY])=0 : Local File TYPWEEK   [WTY] : Endif
If clalev([F:HLY])=0 : Local File HLYDAY    [HLY] : Endif

Call PARAM(PSITE,"CALCPY",PARAM) From ADOVAL
If PARAM="" : End : Endif

# Semaine type
Read [WTY]WTY0 = GCURLEG;PARAM
#PEVAN - 2018-07-11 - X3-93811 - START
#If fstat : Return : Endif
If fstat : End : Endif
#PEVAN - 2018-07-11 - X3-93811 - END

#MIPEA - 2017-11-27- US X3-63170- START
GFIRDAY = [F:WTY]FIRDAY
#MIPEA - 2017-11-27- US X3-63170- END

#Jours Fériés
Read [HLY]HLY0 = year(PDATDEB);PSITE;GCURLEG
If fstat
 Read [HLY]HLY0 = year(PDATDEB);"";GCURLEG
Endif

DAT = PDATDEB

For I=1 To (PDATFIN-PDATDEB)+1
 Raz LNBRDAY
 Call DAT(DAT,ANNEE,SEMAINE)From SUBPLN
 Call SEMAINE(ANNEE,SEMAINE,DEBUT,FIN) From SUBPLN
 K = DAT-DEBUT
 LNBRDAY = [F:WTY]NBRDAY1(K)
 LTYPDAY = [F:WTY]TYPDAY(K)
 If dim([L]AM)>0 & [L]AM=1
  LNBRDAY = LNBRDAY/2
 Endif

 FERIE = find(DAT,[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
 If FERIE
  If LTYPDAY<=2 : # Ouvrable ou ouvrés
    PJFB+= LNBRDAY
  Endif
  If LTYPDAY=2 : # Ouvrés
    PJFA+= LNBRDAY
  Endif
 Else
  If LTYPDAY<=2 : # Ouvrable ou ouvrés
    PJB+= LNBRDAY
    PJFB+= LNBRDAY
  Endif
  If LTYPDAY=2 : # Ouvrés
    PJA+= LNBRDAY
    PJFA+= LNBRDAY
  Endif
 Endif
 DAT += 1
Next I
#LIPET - 2017-05-20 - END
End

################
$TR_NBJOURS
#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
## nb jours théorique du mois courant
#Call NBJ_PLANNING (DMOISC,FMOISC,MATRI,SITE,CTR,E_TRAVA,E_TRAVB,E_TRAVC,E_TRAHA,E_TRAHB,E_TRAHC,
#&                  E_FERHA,E_FERHB,E_FERJA,E_FERJB)
### nb jours théorique du mois courant -1
#Call NBJ_PLANNING (DMOIS0,FMOIS0,MATRI,SITE,CTR,E_TRAVA0,E_TRAVB0,E_TRAVC0,E_TRAHA0,E_TRAHB0,E_TRAHC0,
#&                  E_FERHA0,E_FERHB0,E_FERJA0,E_FERJB0)
### nb jours théorique du mois courant +1
#Call NBJ_PLANNING (DMOIS1,FMOIS1,MATRI,SITE,CTR,E_TRAVA1,E_TRAVB1,E_TRAVC1,E_TRAHA1,E_TRAHB1,E_TRAHC1,
#&                  E_FERHA1,E_FERHB1,E_FERJA1,E_FERJB1)
#
### nb jours absences du mois courant (en partant du début de la période du contrat !)
#Call NBJ_ABSENCE (DMOISC,FMOISC,MATRI,SITE,CTR,E_ABSA ,E_ABSB ,E_ABSC ,E_ABSFA ,E_ABSFB)
#Call NBJ_ABSENCE (DMOIS0,FMOIS0,MATRI,SITE,CTR,E_ABSA0,E_ABSB0,E_ABSC0,E_ABSFA0,E_ABSFB0)
#Call NBJ_ABSENCE (DMOIS1,FMOIS1,MATRI,SITE,CTR,E_ABSA1,E_ABSB1,E_ABSC1,E_ABSFA1,E_ABSFB1)

# nb jours théorique du mois courant
Call NBJ_PLANNING (DMOISC,FMOISC,MATRI,SITE,CTR,E_TRAVA,E_TRAVB,E_TRAVC,E_TRAHA,E_TRAHB,E_TRAHC,
&                  E_FERHA,E_FERHB,E_FERJA,E_FERJB)
## nb jours théorique du mois courant -1
Call NBJ_PLANNING (DMOIS0,FMOIS0,MATRI,SITE,CTR,E_TRAVA0,E_TRAVB0,E_TRAVC0,E_TRAHA0,E_TRAHB0,E_TRAHC0,
&                  E_FERHA0,E_FERHB0,E_FERJA0,E_FERJB0)
## nb jours théorique du mois courant +1
Call NBJ_PLANNING (DMOIS1,FMOIS1,MATRI,SITE,CTR,E_TRAVA1,E_TRAVB1,E_TRAVC1,E_TRAHA1,E_TRAHB1,E_TRAHC1,
&                  E_FERHA1,E_FERHB1,E_FERJA1,E_FERJB1)

## nb jours absences du mois courant (en partant du début de la période du contrat !)
Call NBJ_ABSENCE (DMOISC,FMOISC,MATRI,SITE,CTR,E_ABSA ,E_ABSB ,E_ABSC ,E_ABSFA ,E_ABSFB)
Call NBJ_ABSENCE (DMOIS0,FMOIS0,MATRI,SITE,CTR,E_ABSA0,E_ABSB0,E_ABSC0,E_ABSFA0,E_ABSFB0)
Call NBJ_ABSENCE (DMOIS1,FMOIS1,MATRI,SITE,CTR,E_ABSA1,E_ABSB1,E_ABSC1,E_ABSFA1,E_ABSFB1)
#LIPET - 2017-05-20 - END
Return

################
Subprog NBJ_PLANNING (PDATDEB,PDATFIN,PMATRI,PSITE,PCTR,PJOURA,PJOURB,PJOURC,PHRESA,PHRESB,PHRESC,PHFERA,PHFERB,PJFERA,PJFERB)
Value Date PDATDEB
Value Date PDATFIN
Value Char PMATRI ()
Value Char PSITE ()
Value Char PCTR ()
Variable Decimal PJOURA
Variable Decimal PJOURB
Variable Decimal PJOURC
Variable Decimal PHRESA
Variable Decimal PHRESB
Variable Decimal PHRESC
Variable Decimal PHFERA
Variable Decimal PHFERB
Variable Decimal PJFERA
Variable Decimal PJFERB

#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#If PDATDEB=[0/0/0] | PDATFIN=[0/0/0] : End : Endif
#
#Local Integer ITYP
#Local Decimal NBJR
#Local Decimal NBHR
#

#If dim(GFERIE)<1
# Global Integer GFERIE     :#0=non compté 1= compté
#Endif
