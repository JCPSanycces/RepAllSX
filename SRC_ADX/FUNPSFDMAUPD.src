#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################
#                                                                         #
# GACTION : TRTPSFDMAUPD : Update work order so that FDMA is recalculated #
#                          when sent to Production Scheduler              #
#                                                                         #
###########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
Endcase

# Actions related to window entry only
If !GSERVEUR
Case ACTION
 When "BOUTON"        : Gosub BOUTON
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "FIN"           : Gosub FIN
Endcase
Endif
Return

#########################################################################
$INIT
# We are running in batch mode, it is better to use Onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif
Call FIND_GFCYDEF(8) From TRTX3
Gosub OUVRE
Return

#########################################################################
$OUVRE
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Char     CRITERE3(255)
Local Char     FORMULE1(255)
Local Integer  I
Local Integer WITHINMATREQ
Local Integer COMPMATCH

# FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
Local Char     CUSFLT(255)

# Global variable which will denote if we have a transaction
If dim (GMFGTRANSAC)<0   : Global Integer  GMFGTRANSAC : GMFGTRANSAC = 0 : Endif
If dim (GNBOF)<0     : Global Integer  GNBOF : GNBOF = 0 : Endif

If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM      [MFI]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:SRU])  = 0 : Local File TABSTORUL   [SRU]  : Endif

Gosub CHARG_PARAM
Return

#########################################################################
$INIT_DIA
# Window title
TIT = mess(305,195,1)
Raz [M:DIA]

[M:DIA]MFGFCY = GFCY

Return

#########################################################################
$EXEC

If GMFGTRANSAC=0
  If !GSERVEUR
      TRA = 1
      Call OUVRE_TRACE(TIT) From LECFIC
      Call ECR_TRACE(" ",0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call PRTSCR("PSFDMAUPD","DIA","",0,1) From ATRTX3
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call ECR_TRACE(" ",0) From GESECRAN
  Endif
  # Prepare the selection criteria filters
  Gosub SEL_OF
  # processing of work orders
  Gosub TRT_OF
  If GNBOF
      Call ECR_TRACE(" ", 0) From GESECRAN
      WMESS1= num$(GNBOF)-mess(892,197,1)
      Call ECR_TRACE(WMESS1, 0) From GESECRAN
  Endif
Endif

Return

#########################################################################
$TRT_OF

Gosub MAJ_OF

Return

#########################################################################
$TERMINE
If GMFGTRANSAC=0
  If !GSERVEUR
      # No work orders to update
      If !GNBOF & OK
           GERR = 2 : Call ECR_TRACE (mess(88,193,1),0) From GESECRAN
      Endif
      # Close trace
      Call FERME_TRACE From LECFIC

      # Delete global variables
      If dim (GNBOF) >0  : Kill GNBOF : Endif

  Endif
Endif
If dim (GMFGTRANSAC) >0 : Kill GMFGTRANSAC  : Endif

Return

#########################################################################
$SEL_OF

# FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif

Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

# Work order status is inclusive, so each level includes the previous
If [M:DIA]WOSTATFLG = 1
    CRITERE  = "[F:MFG]OPTFLG=2 & [F:MFG]MFGTRKFLG<=3"
    Gosub LOAD_CRITERE
Elsif [M:DIA]WOSTATFLG = 2
    CRITERE  = "(([F:MFG]OPTFLG=2 | [F:MFG]SCDFLG=4) & [F:MFG]MFGTRKFLG<=3)"
    Gosub LOAD_CRITERE
Else [M:DIA]WOSTATFLG = 3
    CRITERE  = "(([F:MFG]OPTFLG=2 | [F:MFG]SCDFLG=4) & [F:MFG]MFGTRKFLG<=4)"
    Gosub LOAD_CRITERE
Endif

# End of the first part
CRITERE1 += ")"

CRITERE  = "MFGFCY = [M:DIA]MFGFCY"                     # production site
Gosub LOAD_CRITERE2

If [M:DIA]MFGNUMDEB <> ""                               # Work order start
   CRITERE = "MFGNUM >= [M:DIA]MFGNUMDEB"
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]MFGNUMFIN <> ""                               # Work order end
   CRITERE = "MFGNUM <= [M:DIA]MFGNUMFIN"
   Gosub LOAD_CRITERE2
Endif

If [M:DIA]DATDEB <> [0/0/0]
   CRITERE = "STRDAT >= [M:DIA]DATDEB"               # Start date start
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]DATFIN <> [0/0/0]
   CRITERE = "ENDDAT <= [M:DIA]DATFIN"               # End date end
   Gosub LOAD_CRITERE2
Endif

If [M:DIA]ITMREFDEB <> ""                               # Finished good start
    CRITERE = "[F:MFI]ITMREF>=[M:DIA]ITMREFDEB"
    Gosub LOAD_CRITERE3
Endif

If [M:DIA]ITMREFFIN <> ""                               # Finished good end
    CRITERE = "[F:MFI]ITMREF<=[M:DIA]ITMREFFIN"
    Gosub LOAD_CRITERE3
Endif

If [M:DIA]PJTDEB <> ""                               # Project task start
    CRITERE = "[F:MFI]PJT>=[M:DIA]PJTDEB"
    Gosub LOAD_CRITERE3
Endif

If [M:DIA]PJTFIN <> ""                               # Project task end
    CRITERE = "[F:MFI]PJT<=[M:DIA]PJTFIN"
    Gosub LOAD_CRITERE3
Endif

# End of the third part
If CRITERE3 <>""
    CRITERE3 += ")"
Endif

If CRITERE1 = "" : CRITERE1 ="1=1" : Endif
If CRITERE2 = "" : CRITERE2 ="1=1" : Endif
If CRITERE3 = "" : CRITERE3 ="1=1" : Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

Return

#########################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

############################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return

#########################################################################
$LOAD_CRITERE3
If len(CRITERE3)=0
    CRITERE3 += "("
Else
    CRITERE3 += "&"
Endif
CRITERE3 += CRITERE
Return


##################################################
$ANALYSE_FORMULE
# Analyse selection criteria formula
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=10;[M:DIA]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return

#########################################################################
# processing of orders
$MAJ_OF

GNBOF = 0

# FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM
&          As [MFX]
&          Where evalue(CRITERE1) & evalue(CRITERE2)& evalue(CRITERE3) & evalue(FORMULE1) & evalue(CUSFLT)
&                      Order By Key MFI0(1)
For [MFX]
    GPE = 1
    GPOINT = "CUSSELFLT2" : Gosub ENTREE From EXEFNC
    If !GPE : Goto NXT_MFG : Endif

    # Check if this work order is within the material requirement date range
    Gosub WITHINMATREQDATES

    If [L]WITHINMATREQ > 0

        # Check if this work order has the specified component version
        Gosub CHECKCOMPONENT

        If [L]COMPMATCH > 0
            # We just need to update the work order and the FDMA will be
            # recalculated when it is sent to Production Scheduler
            Read [MFG]MFG0=[F:MFI]MFGNUM
            Gosub TRTMAN
            # If there was an error end
            If GOK<1 : Break : Endif
        Endif
    Endif
$NXT_MFG
Next

Filter [MFG]
Return

#########################################################################
# Processing of orders
$MAJ_OF_TRANSAC
Local Integer I
GNBOF = 0

# Loop on the rows of the table
For I = 0 To [M:PSF1]NBLIG-1

    # Only update the ticked items
    If [M:PSF1]FMODIF(I) = 2
        # We just need to update the work order and the FDMA will be
        # recalculated when it is sent to Production Scheduler
        Read [MFG]MFG0=[M:PSF1]MFGNUM(I)
        Gosub TRTMAN
        # If there was an error end
        If GOK<1 : Break : Endif
    Endif
Next

Return

########################################################################

$TRTMAN
# FQ 67806 GA 11/2010 PE BEFTRTLIG idem FUNMAUTO
Local Integer GPE : GPE=1
GPOINT = "BEFTRTLIG" : Gosub ENTREE From EXEFNC
If !GPE Return Endif

Gosub VERROU
If !OK : Return : Endif
Call DEBTRANS From GLOCK
Gosub MAJMAN
Gosub DEVERROU
Return

########################################################################
$MAJMAN
    Trbegin [MFG]

    # Update the work order header
    [F:MFG]UPDDATTIM = datetime$
    [F:MFG]UPDUSR = GUSER
    Rewrite [MFG]

    # There was an error rollback and end
    If GOK<1 : Rollback : Return : Endif

    # Write to the log that the work order has been updated
    WMESS1 =mess(156,197,1)-":"-[F:MFG]MFGNUM-"."-mess(893,197,1)
    Call ECR_TRACE( WMESS1 ,0) From GESECRAN
    Commit

    # Increase the count
    GNBOF += 1

Return

######################################################################################
## Section automatically added (screen PSFDMAUPD) 09/29/2017 15:41:42 (STWIL)
######################################################################################

Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
# Issue 119208 GH 23/03/2017 - reinit global variables when site is changed
If VALEUR <> GFCY
    GFCY=VALEUR
    Gosub CHARG_PARAM
Endif
End

######################################################################################
Subprog AM_MFGNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : [M:DIA]MFGNUMFIN = VALEUR : Endif
End

######################################################################################
Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:DIA]DATDEB : mkstat = 2 Endif
End

######################################################################################
Subprog C_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : [M:DIA]ITMREFFIN = VALEUR : Endif
End

########################################################################
$CHARG_PARAM
#----- Global stock variables
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Global manufacturing variables
Call GLOBVAR(GFCY)    From WWGLOBGPA

# Issue 119208 GH 23/03/2017 - init global variables for analytical dimensions
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
Return

##########################################################################
# For batch calls
##########################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK)
#-----------------------------#
# Required for batch calls    #
#-----------------------------#
Value    Char    DOSSIER   : # Folder
Value    Char    USER      : # User
Variable Char    P1()(1..) : # we can have 2 times 50 strings of 15 characters
Variable Char    P2()(1..)
Variable Integer OK

Gosub OUVRE

#
Local Char    WIN (GLONFEN)
WIN="DPSFDMAUPD"
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT
End

##########################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

# Functions available on grid of work orders selected
$BOUTON
Case BOUT
    When "1" : Gosub TRT_OF_SEL : FIN=1
    When "2" : Gosub INCLUDE
    When "3" : Gosub EXCLUDE
Endcase
Return

$TRT_OF_SEL

If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("PSFDMAUPD","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

Gosub MAJ_OF_TRANSAC
If GNBOF
    Call ECR_TRACE(" ", 0) From GESECRAN
    # Output a message for the number of work orders updated
    WMESS1= num$(GNBOF)-mess(893,197,1)
    Call ECR_TRACE(WMESS1, 0) From GESECRAN
Endif

# No work orders to update
If !GNBOF & OK
     GERR = 2 : Call ECR_TRACE (mess(88,193,1),0) From GESECRAN
Endif

# Close trace
Call FERME_TRACE From LECFIC

# Delete global variables
If dim (GNBOF) >0  : Kill GNBOF : Endif

Call LEC_TRACE From LECFIC

Return

$DEBUT
If !GSERVEUR
  Local Char    TIT(50) :  Call TEXTE(57022,TIT) From OBJDIV    # "Recalculate work order FDMA"
  Default Mask [PSF1]
  Gosub LIRE
  If [M:PSF1]NBLIG=0
      GERR=2 : GMESSAGE=mess(177,190,1)
      FIN=1
  Endif
Endif

Return

$LIRE
# Populate grid based on results of selection criteria
Gosub SEL_OF

REP=""
Raz [M:PSF1]
nolign=0
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif
nolign = 0
[M:PSF1]MFGFCY = [M:DIA]MFGFCY

# FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM
&          As [MFX]
&          Where evalue(CRITERE1) & evalue(CRITERE2)& evalue(CRITERE3) & evalue(FORMULE1) & evalue(CUSFLT)
&                      Order By Key MFI0(1)

For [MFX]

    # Check if this work order is within the material requirement date range
    Gosub WITHINMATREQDATES

    If [L]WITHINMATREQ > 0

        # Check if this work order has the specified component version
        Gosub CHECKCOMPONENT

        If [L]COMPMATCH > 0
            nolign += 1

            If nolign = dim([M:PSF1]MFGNUM) : Break : Endif

            [M:PSF1]MFGNUM(nolign-1)        = [F:MFG]MFGNUM
            If [F:MFG]OPTFLG = 2
                [M:PSF1]MFGSTA(nolign-1)    = [F:MFG]OPTFLG
            Else
                [M:PSF1]MFGSTA(nolign-1)    = [F:MFG]MFGTRKFLG
            Endif
            [M:PSF1]STRDAT(nolign-1)        = [F:MFG]STRDAT
            [M:PSF1]ENDDAT(nolign-1)        = [F:MFG]ENDDAT
            [M:PSF1]SCDFLG(nolign-1)        = [F:MFG]SCDFLG
            [M:PSF1]MFGITM(nolign-1)        = [F:MFI]ITMREF
            [M:PSF1]FMODIF(nolign-1)        = 1
        Endif
    Endif
Next
[M:PSF1]NBLIG= nolign
Affzo [M:PSF1]
GMFGTRANSAC = 1
Return

$WITHINMATREQDATES
    # Check if a material requirement range has been entered
    If [M:DIA]MATREQDEB = [0/0/0] & [M:DIA]MATREQFIN = [0/0/0]
        [L]WITHINMATREQ = 1
        Return
    Endif
    [L]WITHINMATREQ = 0
    For [MFM] Where MFGNUM = [F:MFG]MFGNUM & RETDAT >= [M:DIA]MATREQDEB & RETDAT <= [M:DIA]MATREQFIN
        [L]WITHINMATREQ = 1
        Break
    Next
Return

$CHECKCOMPONENT
    # Check if a component has been entered
    If [M:DIA]ITM = ""
        [L]COMPMATCH = 1
        Return
    Endif
    [L]COMPMATCH = 0
    For [MFM] Where MFGNUM = [F:MFG]MFGNUM & ITMREF = [M:DIA]ITM
        # Check that the version matches if entered
        If [M:DIA]MAJVER = "" | [M:DIA]MAJVER = [F:MFM]ECCVALMAJ
            [L]COMPMATCH = 1
            Break
        Endif
    Next
Return

#########################################################################
$INCLUDE
Local Integer I

# Include all items in the list
For I = 0 To [M:PSF1]NBLIG-1
    [M:PSF1]FMODIF(I) = 2
Next
Affzo [M:PSF1]
Return

#########################################################################
$EXCLUDE
Local Integer I

# Exclude all items in the list
For I = 0 To [M:PSF1]NBLIG-1
    [M:PSF1]FMODIF(I) = 1
Next
Affzo [M:PSF1]
Return

$FIN

Return

#-----------------------------------------------------------------------#
# Positioning a lock on the WO header                                   #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "MFG"+[F:MFG]MFGNUM
Lock = SYMBOLE With lockwait = 0
OK = 1
If fstat
    Call ECR_TRACE([F:MFG]MFGNUM - mess(10,100,1),1) From GESECRAN
    OK = 0
Endif
Return

#-----------------------------------------------------------------------#
# Deleting the lock on the WO header                                    #
#-----------------------------------------------------------------------#
$DEVERROU
Unlock=SYMBOLE
Return

######################################################################################

######################################################################################
## Section automatically added (screen PSFDMAUPD) 09/29/2017 15:31:45 (STWIL)
######################################################################################
Subprog AM_ITM(VALEUR)
Variable Char    VALEUR()
Local Integer DIABLEVER
Local Integer FILEOPEN
    DISABLEVER = 1
    # Check versioning is active before checking for a version number on the product
    If func AFNC.ACTIV("ECC")
        # Only check for versioning if a product has been entered
        If VALEUR <> ""
            If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : FILEOPEN = 1 : Endif
            Read [ITM]ITM0=VALEUR
            If fstat = [V]CST_AOK & [F:ITM]ECCFLG = 2
                [L]DISABLEVER = 0
            Endif
            If [L]FILEOPEN
                Close Local File [ITM]
            Endif
        Endif
        If [L]DISABLEVER
            Grizo [M:DIA]MAJVER
            [M:DIA]MAJVER = ""
        Else
            Actzo [M:DIA]MAJVER
        Endif
    Endif
End


######################################################################################

######################################################################################
## Section automatically added (screen PSFDMAUPD) 09/29/2017 15:35:51 (STWIL)
######################################################################################
Subprog D_MAJVER(VALEUR)
Variable Char    VALEUR()
     Grizo [M:DIA]MAJVER
End

######################################################################################

######################################################################################
## Section automatically added (screen PSFDMAUPD) 09/29/2017 15:41:42 (STWIL)
######################################################################################
Subprog AM_DATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : [M:DIA]DATFIN = VALEUR : Endif
End

Subprog AM_PJTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : [M:DIA]PJTFIN = VALEUR : Endif
End

Subprog AM_MATREQDEB(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : [M:DIA]MATREQFIN = VALEUR : Endif
End

Subprog C_MATREQFIN(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:DIA]MATREQDEB : mkstat = 2 Endif
End


######################################################################################

