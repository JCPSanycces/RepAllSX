#            GMESSAGE = mess(327,193,1)
#            # "BOM relates to a versioned product"
#            mkstat = 2
#        Endif
#    Endif
#Endif

End

########################################
Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
Local Char    WFCY(GLONFCY)
Local Integer WALT
Local Date    WDAT
Local Char    WITM(GLONITM)

Case [M:MBM]MATTYP(nolign-1)
    When 1 :
        Filter [F:MFI] Where MFGNUM = [M:MBM]MFGNUM(nolign-1) & ITMREF = [M:MBM]BOMNUM(nolign-1)&
&                                BOMALT = VALEUR
        Read [F:MFI]MFI0 First
        If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : Endif
        Filter [F:MFI]
    When 2 :
        WITM=[M:MBM]BOMNUM(nolign-1)
        WDAT=[M:MBM]IPTDAT(nolign-1)
        WFCY=[M:MBM]FCY
        WALT=VALEUR
        #    Lecture BOM
        Read [TBO]TBO0=2;VALEUR
        If fstat : mkstat=2 : End : Endif
        Read [BOH]BOH0=WITM;VALEUR;2
        If fstat
            GMESSAGE = mess(95,193,1)
            mkstat=2
            End
        Endif
        Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
        If WALT=0 : mkstat=2 : End : Endif
Endcase
End

