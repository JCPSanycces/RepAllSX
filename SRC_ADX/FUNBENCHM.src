##########################################################################
## Etiquette ajoutée par le superviseur 04/09/2003 08:53:10 (SR)
##########################################################################
Subprog IB_NBLIG
#GBOUT1 = "Etat suivi"
#GBOUT2 = "Détail matière"
#GBOUT3 = "Nomenclature"
#GBOUT4 = "Stock"
#GBOUT5 = "Ordre de fabrication"
#GBOUT6 = "Saisie détail quantité"
#GBOUT7 = "Info allocation"
#GBOUT8 = "Texte"
If [M:MBM]ITMREF(nolign-1) = "" : Raz GBOUT1,GBOUT2,GBOUT3,GBOUT4,GBOUT5,GBOUT6, GBOUT7, GBOUT8 : End : Endif

If [M:MBM]MATTYP(nolign-1) <> 1 | [M:MBM]MFMITMREF(nolign-1) = ""
    Raz GBOUT1,GBOUT2,GBOUT5,GBOUT7
Else
    Raz GBOUT3
Endif

If [F:ITM]ITMREF <> [M:MBM]ITMREF(nolign-1)
   Read [F:ITM]ITM0 = [M:MBM]ITMREF(nolign-1)
   If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITF]STOFCY <> [M:MBM]FCY | [F:ITF]ITMREF <> [M:MBM]ITMREF(nolign-1)
   Read [F:ITF]ITF0 = [M:MBM]FCY;[M:MBM]ITMREF(nolign-1)
   If fstat : Raz [F:ITF] : Endif
Endif
GOUVSOR = 1
End

##########################################################################
Subprog AVANT_NBLIG

# Issue 116022 - 2016-04-15 by JUSYN : Identifier for calling prog
Local Char     LIDPROG(30): LIDPROG = "CHARG_MFM"

Default Mask [MBM]
If dim([M:MBM]WRH) > 0 & GWRHOBY=2
    [M:MBM]WRH(nolign-1)= [M:MBM]WRHE
Endif

# Issue 81693 - 2012-05-15 by CCC
If [M:MBM]OLDQTY(nolign-1)=0 & [M:MBM]ALLSTA(nolign-1)>3 & [M:MBM]ALLQTY(nolign-1)-func CALC_WWUSEALL(nolign-1)>0
    Call ETAZONSOR("MBM") From STKECR
Else
    Call INIZONSOR("MBM",[M:MBM]ITMREF(nolign-1),[M:MBM]FCY,nolign-1,6,[M:MBM]TRSCODS,"") From STKECR
    If dim([M:MBM]LOC)>0
        Call STKINIEMPS([M:MBM]LOC(nolign-1)) From STKLOC
    Endif
    # Issue 107513/8 - 2015-07-13 by JUSYN : Parent product when WO versioned then versions not allowed to be changed
    Gosub GREY_ECC
Endif

End

##########################################################################
## Etiquette ajoutée par le superviseur 04/09/2003 09:26:05 (SR)
##########################################################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Decimal WQTY
Local    Integer J, NOL
NOL=nolign-1

pcolor=GCOUL(0)
# 05.05 demande 30321
If [M:MBM]USEQTY(NOL) = 0  |
&  ([F:BTS]STOCODMAN = 2 & [M:MBM]STOCODL(NOL) = 1 & [M:MBM]WSTODET(NOL) <> 2)
    pcolor = GCOUL(1)
    End
Endif

# Colorisation de l'article
# - si tout le stock à sortir n'a pas été renseigné
# - s'il y a une quantité en rupture
# Nouvelle ligne ou ligne modifiée
WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*([M:SOW]WSTOSEQ(J)=[M:MBM]WSTOSEQ(NOL)))
# Tout le stock à sortir n'a pas été renseigné
If WQTY<>[M:MBM]USEQTY(NOL)
    # 05.05 demande 30321
   [M:MBM]WSTODET(NOL) = 1
   pcolor=GCOUL(1)
Else
   WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*
&            ([M:SOW]WSTOSEQ(J)=[M:MBM]WSTOSEQ(NOL)&[M:SOW]WSTOCOU(J)<>0))
   # Il y a une quantité en rupture
   If WQTY<>[M:MBM]USEQTY(NOL)
      pcolor=GCOUL(2)
   Endif
Endif
End


#########################################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL
Local    Char    LSERF(GLONSER)
Local    Decimal LQTYF
NOL=nolign-1

If VALEUR<>""
   # Alimentation de [M:ALP]
   Call ALI_ALP("MBM",NOL) From SUBMTKB
   # Détermination no série fin
   Call CTLSORSER("MBM",NOL,VALEUR,[M:MBM]USEQTY(NOL),LSERF,LQTYF) From STKSOR
   If LQTYF=0
      Raz VALEUR, [M:MBM]SERNUMF(NOL)
   Else
      [M:MBM]SERNUMF(NOL)=LSERF
   Endif
Else
   Raz [M:MBM]SERNUMF(NOL)
Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran MTKBENCHM) 03/12/2004 10:42:10 (SR)
######################################################################################
Subprog AM_CLEFLG(VALEUR)
Variable Integer VALEUR
Local Integer NOL, OK
NOL = nolign-1
If VALEUR = 2
    #Proposition d'exclure la matière au suivi si en attente, non allouée et pas cumulée au suivi et pas suivie
    If [M:MBM]MATTYP(NOL) = 1 & [M:MBM]MATSTA(NOL) = 1 & [M:MBM]MFMITMREF(NOL) <> "" & [M:MBM]ALLSTA(NOL) = 1 &
&      [M:MBM]USEQTY(NOL) = 0
        OK=1
        Call OUINON(mess(209,190,1),OK) From GESECRAN
        If OK=2
          [M:MBM]WEXCMAT(NOL) = 2
        Endif
    Endif
Else
    Raz [M:MBM]WEXCMAT(NOL)
Endif
End

