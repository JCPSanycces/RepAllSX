#<AdxTL>@(#)12.0.0.0 $Revision$
##############################################################################
# ACTION = SAIBENCHM
##############################################################################
$ACTION
Case ACTION
    When "INIT"          : Gosub INIT
    When "SEL_LISTE"     : Gosub SEL_LISTE
    When "FIN_LISTE"     : Gosub FIN_LISTE
    When "CONTROLE"      : Gosub CONTROLE
    When "OUVRE"         : Gosub OUVRE
    When "TITRE"         : Gosub TIT
    When "DEBUT"         : Gosub DEBUT
    When "SETBOUT"       : Gosub SETBOUT
    When "BOUTON"        : Gosub BOUTON
    When "ABA"           : Gosub ABA
    When "FIN"           : Gosub FIN
    When "AAPRES_NBLIG"  : Gosub AAPRES_NBLIG
    When "AP_CHOIX"      : Gosub AP_CHOIX
    When "AB3_NBLIG"     : Gosub AB3_NBLIG
    When "AB5_NBLIG"     : Gosub AB5_NBLIG
    When "AB6_NBLIG"     : Gosub AB6_NBLIG
    When "BB6_NBLIG"     : Gosub BB6_NBLIG
Endcase
Return

################################################################
$AAPRES_NBLIG
Local Integer LRET, WAUTO
Local Integer I : I = nolign-1
Raz LRET
Raz GOUVSOR
# Si suppression ligne
If find(status,65,68,83) Return Endif
# Issue 79493 - 2012-02-09 by CCC
#If [M:MBM]USEQTY(nolign-1) = 0    : Return : Endif
If [M:MBM]USEQTY(nolign-1) = 0
    Call DELSTOSORW(nolign-1,nolign-1,"MBM",[M:MBM]FCY,LRET) From STKSOR
    Return
Endif

# Issue 85592 - 2012-10-31 by CCC
# Si sortie tableau non validante
If adxgtb=1 Return Endif

# Issue 81693 - 2012-05-14 by CCC : Récupération des allocations si cela n'a pas encore été fait
Local Integer WLIG : WLIG = nolign-1
Local Integer WRUP, WRET

[M:ALP]QTY = [M:MBM]ALLQTY(nolign-1)-func CALC_WWUSEALL(nolign-1)
If [M:MBM]ALLSTA(nolign-1)>3 & [M:MBM]OLDQTY(nolign-1)=0 & [M:ALP]QTY>0
        [M:ALP]TRSTYP     = 6
        [M:ALP]TRSCOD     = [M:MBM]TRSCODS
        [M:ALP]VCRTYP     = 10
        [M:ALP]VCRNUM     = [M:MBM]MFGNUM(WLIG)
        [M:ALP]VCRLIN     = [M:MBM]MFGLIN(WLIG)
        [M:ALP]VCRSEQ     = [M:MBM]BOMSEQ(WLIG)
        [M:ALP]STOFCY     = [M:MBM]FCY
        [M:ALP]ITMREF     = [M:MBM]ITMREF(WLIG)
        [M:ALP]QTY        = [M:MBM]USEQTY(WLIG)
        [M:ALP]TYPQTY     = 2
        [M:ALP]STA        = [M:MBM]STAPREF(WLIG)
        [M:ALP]LOT        = [M:MBM]LOTPREF(WLIG)
        [M:ALP]BESDAT     = [M:MBM]IPTDAT(WLIG)  : # Bug 35084
        If dim([M:MBM]WRH)>0 [M:ALP]WRH=[M:MBM]WRH(WLIG) Endif
        Raz WRET
        WRUP = [M:MBM]NEGSTO(WLIG) - 1
        # 08.05 demande 29188
        [M:ALP]PECSCOLOC  = 1
        If [M:MBM]CPLWST(WLIG) <> ""
           If [F:MWS]WST <> [M:MBM]CPLWST(WLIG) | [F:MWS]WCRFCY <> [M:MBM]FCY
               Read [F:MWS]WST0 = [M:MBM]CPLWST(WLIG);[M:MBM]FCY
               If fstat : Raz [F:MWS] : Endif
           Endif
           If [F:MWS]WSTTYP = 3
              [M:ALP]PECSCOLOC  = 2
           Endif
        Endif
        [M:ALP]PECPLFLOC = 2


        Raz GBIDI1
        For I=0 To [MBM]NBLIG-1
            If I<>nolign-1
&            & [M:MBM]IPTDAT(nolign-1) = [M:MBM]IPTDAT(I)
&            & [M:MBM]MATTYP(nolign-1) = [M:MBM]MATTYP(I)
&            & [M:MBM]MFGNUM(nolign-1) = [M:MBM]MFGNUM(I)
&            & [M:MBM]ITMREF(nolign-1) = [M:MBM]ITMREF(I)
&            & [M:MBM]BOMSEQ(nolign-1) = [M:MBM]BOMSEQ(I)
&            & [M:MBM]OPENUM(nolign-1) = [M:MBM]OPENUM(I)
&            & find([M:MBM]WSTOSEQ(I),[M:SOW]WSTOSEQ)>0
                [M:ALP]TWSTOSEQ(GBIDI1) = [M:MBM]WSTOSEQ(I)
                GBIDI1+=1
                If GBIDI1>=dim([M:ALP]TWSTOSEQ)
                    Break
                Endif
            Endif
        Next

        # On charge toutes les allocations
        Call ALLSTOSORW("MBM",WLIG,[M:MBM]NBLIG,WRUP,0,0, WRET) From STKSOR

        [M:ALP]QTY = [M:MBM]USEQTY(WLIG)-[M:ALP]ALLQTY : # inutile
        [M:MBM]ALLQTY(WLIG) = [M:ALP]ALLQTY

        Call RECSTOSOR (3, "MBM",WLIG,[M:MBM]FCY,[M:MBM]ITMREF(WLIG),0,
&                       "",0,"",WRET) From STKECR

    I=WLIG
    Call ALI_ALP("MBM",I) From SUBMTKB
Else
    Call ALI_ALP("MBM",I) From SUBMTKB
    If [M:MBM]ALLSTA(I)=3
       [M:ALP]ALLQTY = [M:MBM]ALLQTY(I)
    Else
       Raz [M:ALP]ALLQTY
    Endif
Endif

# Issue 85592 - 2012-10-31 by CCC
## Si sortie tableau non validante
#If adxgtb=1 Return Endif

# Call ALI_ALP("MBM",I) From SUBMTKB : # Issue 48252 GH 26/09/2017 - deplaced just before in order not to erase [M:ALP]ALLQTY
If [F:BTS]STKFLG = 1 : WAUTO = 1
Else
    If [F:BTS]STOCODMAN = 2 & [M:MBM]STOCODL(I) = 1 & [M:ALP]QTY <> 0
        WAUTO = 1
    Else
        WAUTO = 2
    Endif
Endif

Call OUVSOR("MBM",I,[M:MBM]NBLIG,[M:MBM]WSTOSEQ(I),WAUTO,LRET) From STKSOR
# Si GOUVSOR = 1, la fenêtre détail va s'ouvrir

# Issue 81693 - 2012-05-14 by CCC : Récupération des allocations si cela n'a pas encore été fait
# si on a pré-alimenté avec les allocations mais qu'il n'y a pas de détermination auto
# => ouverture fenêtre de détail
# Issue X3-65042 15/03/2018 by GH - indice missing for ALLQTY
#If GOUVSOR=0 & [M:MBM]USEQTY(nolign-1)>0 & [M:MBM]OLDQTY(nolign-1)=0 & [M:MBM]ALLQTY>0 & WAUTO=1
If GOUVSOR=0 & [M:MBM]USEQTY(I)>0 & [M:MBM]OLDQTY(I)=0 & [M:MBM]ALLQTY(I)>0 & WAUTO=1
    GOUVSOR=1
Endif
[M:MBM]OLDQTY(I)=[M:MBM]USEQTY(I)

# 05.05 demande 30321
If GOUVSOR = 1
    [M:MBM]WSTODET(I) = 2
Elsif [M:MBM]USEQTY(I) <> 0
    Call AV_ITMREF([M:MBM]ITMREF(I))
    Affzo [M:MBM]ITMREF(I)
Endif
Return

$AB3_NBLIG
Local Integer  NBTBO
Local Char     WCLE1(15)
Local Char     WCLE2(15)
#
WCLE1=[M:MBM]BOMNUM(nolign-1)
#   sélectionner les alt. de nomenclature compatibles avec site de prod
Filter [TBO] Where ([F:TBO]FCY=[M:MBM]FCY | [F:TBO]FCY="") & [F:TBO]MFGUSE=2 & [F:TBO]BOMALTTYP=2
For [TBO]TBO0
     GBOMALT (NBTBO) = [F:TBO]BOMALT
     NBTBO += 1
Next
#
Filter [TBO]
#  FILTRE sur article parent
Local File BOM [BOH] Where find(BOMALT, GBOMALT) & ITMREF=WCLE1 & BOMALTTYP = 2
#
WCLE2 = num$([M:MBM]BOMALT(nolign-1))
GFONBOD="BOMP"
GDATEREF=[M:MBM]IPTDAT(nolign-1)
Return


$AB5_NBLIG
#------------------------------------------------------#
# Avant exécution du bouton Tunnel OF                  #
#------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1(GLONVCR)
Local Char     WCLE2(GLONVCR)
WOBJET="MFG"
WCLE1 =[M:MBM]MFGNUM(NOL)
Return

$AB6_NBLIG
# 05.05 demande 30321
Local Integer WNOLIGN : WNOLIGN = nolign
Return

$BB6_NBLIG
# 05.05 demande 30321
#------------------------------------------------------#
# Après détail stock                                   #
#------------------------------------------------------#
# 04.07 Demande 40848
Local Decimal WTOTUSEQTY, WWUSEQTY
Local Integer WRET
# on revient de la fenêtre déatil donc à priori c'est ok
nolign = WNOLIGN
[M:MBM]WSTODET(nolign-1) = 2
Call AV_ITMREF([M:MBM]ITMREF(nolign-1))
Affzo [M:MBM]ITMREF(nolign-1), CLEFLG(nolign-1)
Return

###########################################################################
$INIT
Local Char     LFCY(GLONFCY)    :    LFCY   = PARAM(1)
Local Char     LWRH(GLONWRH)    :    LWRH   = PARAM(2)
Local Char     LVCR(GLONVCR)    :    LVCR   = PARAM(3)
Local Integer  LOPE             :    LOPE   = val(PARAM(4))
Local Integer  LLIN             :    LLIN   = val(PARAM(5))
Local Char     LITM(GLONITM)    :    LITM   = PARAM(6)
Local Integer  LALT             :    LALT   = val(PARAM(7))
Local Integer  LPROD            :    LPROD  = val(PARAM(8))
Local Char     LORI             :    LORI   = PARAM(9)
Local Char     LUSR(GLONAUS)    :    LUSR   = PARAM(10)
Local Integer  LCONSMAT         :    LCONSMAT = val(PARAM(11))
Local Decimal  LCOEFF           :    LCOEFF = val(PARAM(12))
Local Integer  LRETOK           :    LRETOK = val(PARAM(13))
Local Integer  LBOMSEQ          :    LBOMSEQ = val(PARAM(14))
Local Integer  OK
Global Char    GMMLNUM(GLONTRS)

If LORI <> "" & LRETOK = 2
    Case LORI
        When "MBO":
              Call AVERTIR(mess(115,190,1),OK) From GESECRAN
              If OK <> 2 : FIN = 1 : Endif
        When "MBI"
              Call AVERTIR(mess(115,190,1),OK) From GESECRAN
              If OK <> 2 : FIN = 1 : Endif
    Endcase
Endif
Raz GSTATUT
Return
###########################################################################
# selection de la transaction
$SEL_LISTE
# 10.05 demande 32570
Local Char     TABACS(10)(100)
Local Integer  NBACS
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX

If clalev ([F:BTS])=0  : Local File BENCHTRS [BTS] : Endif
# si on vient du pilotage, on vérifie si un code transaction est passé
If GFONCTION = "FUNBENPLT"
    If [M:MBP]MOLTRS <> ""
        Read [BTS]BTS0=61;[M:MBP]MMLTRS
        If fstat | [F:BTS]ENAFLG=1  : Return : Endif
        GMMLNUM = [F:BTS]BTSNUM
        OK = 0
        Return
    Endif
Endif

If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
CRITERE = "BTSTYP=61&ENAFLG=2"
# 10.05 demande 32570
If GPROFIL <> GSUPER
    For [ACC]CODACC Where USR=GUSER
       If [F:ACC]EXEC=2 [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1) : NBACS +=1
       Endif
       If NBACS>99 Break : Endif
    Next
    CRITERE += "& (ACSCOD = ''  | find(ACSCOD,TABACS(0..99)))"
Endif

If GFLAG=""
    Filter [BTS] Where evalue(CRITERE)
    If rowcount([BTS])=1
        Read [BTS] First
        If !fstat
            GFLAG=[F:BTS]BTSNUM
        Endif
    Endif
    Filter [BTS]
Endif
If GFLAG<>""
    Filter [BTS] Where evalue(CRITERE)
    Read [BTS]BTS0=61;GFLAG
    Filter [BTS]
    If !fstat
        If dim(GMMLNUM)<=0
            Global Char    GMMLNUM(GLONTRS)
        Endif
        GMMLNUM = [F:BTS]BTSNUM
        OK=0
    Endif
Endif
If GMMLNUM="" : # GH 02/04/2013 bug 88761
  For [F:BTS] Where evalue(CRITERE)
      NBTEX+= 1
      TEX(NBTEX)   =[F:BTS]BTSNUM
      Call LECTEXTRA(TEXTE(NBTEX),"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
      TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
  Next
  TIT(0) = mess(3,126,1) # Choix transactions
Endif
Return

###########################################################################
$FIN_LISTE
GMMLNUM = TEX(CHOIX)
Return

###########################################################################
$CONTROLE
If clalev ([F:BTS]) <= 0  : Local File BENCHTRS [BTS] : Endif
Read [BTS]BTS0=61;GMMLNUM
If fstat  | [F:BTS]ENAFLG = 1 : FIN = 1 : Return : Endif
# Dépôt entête obligatoire ou non
If GWRHACT=2
  GWRHOBY = [F:BTS]WRHOBY
Else
  GWRHOBY = 1
Endif

Return

###########################################################################
$OUVRE
#01.10 mm 61503 - Si on vient par tunnel il faut sauvegarder les variables globales
Gosub SAUV_GLOB From TRTX3GLOB
#
Local Integer  RETOUR
Local Integer  WRET
Global Integer GMFMLIN : GMFMLIN = 1
Global Integer GCONSLCT : GCONSLCT = GCONSULT
Global Char    SAV_GFONC1 : SAV_GFONC1 = GFONC1
Local Integer  VALOK
Local Integer  TRA              :    TRA    = 0
Local Char     LFCY(GLONFCY)    :    LFCY   = PARAM(1)
Local Char     LWRH(GLONWRH)    :    LWRH   = PARAM(2)
Local Char     LVCR(GLONVCR)    :    LVCR   = PARAM(3)
Local Integer  LOPE             :    LOPE   = val(PARAM(4))
Local Integer  LLIN             :    LLIN   = val(PARAM(5))
Local Char     LITM(GLONITM)    :    LITM   = PARAM(6)
Local Integer  LALT             :    LALT   = val(PARAM(7))
Local Integer  LPROD            :    LPROD  = val(PARAM(8))
Local Char     LORI             :    LORI   = PARAM(9)
Local Char     LUSR(GLONAUS)    :    LUSR   = PARAM(10)
Local Integer  LCONSMAT         :    LCONSMAT = val(PARAM(11))
Local Decimal  LCOEFF           :    LCOEFF = val(PARAM(12))
Local Integer  LRETOK           :    LRETOK = val(PARAM(13))
Local Integer  LBOMSEQ          :    LBOMSEQ  = val(PARAM(14))
GCONSULT = GCONSLCT
GFONC1 = "FUNBENCHM"

If LFCY <> ""
    GFCY = LFCY
Else
    Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
Endif
Gosub OUVRE_INIT
Return

####################################################################################
$OUVRE_INIT
Raz GSOC_ACTIVE
If !clalev([STW]) Local Mask STOWORK [STW] : Endif
Gosub STK_INILOC From STKLOC

If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif
If !clalev([M:ALP])  Local Mask ALLPAR     [ALP]   Endif
If !clalev([M:SOW])  Local Mask STOSORW    [SOW]   Endif
If !clalev([M:MTB2]) Local Mask MTKBCRIT2 [MTB2]   Endif  # 15806 MM 05.05 : gestion memo STD

Gosub OPEN_FILE
Gosub CHARG_PARAM

Gosub LECTURE_BTS
#
If GVTMOD : Return : Endif
# substitution fenêtre
BOITE     = "WIMBM"+GMMLNUM
WMASQUE   = "WT61"+GMMLNUM+"1"

#MAE, le 31/01/08, GRP_SITE
GGRPFCY = [F:BTS]GFY

Gosub CHANGE_AWI From BENCHLIB
GORITITCOL = 1

Return

#########################################################################
$TIT
    Call LECTEXTRA(TIT,"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-[F:BTS]BTSNUM-":"-TIT
Return


###################################################################################
$DEBUT
Raz [M:MBM]
If LFCY=""
    [M:MBM]FCY = GFCY
Else
    [M:MBM]FCY = LFCY
Endif
Gosub WRH_ETAT
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL

# CCC (2009-09-23) Bug 57792 : alimenter le code transaction systématiquement
Gosub LECTURE_BTS
[M:MBM]TRSCODS = [F:BTS]TRSCODS

[M:MBM]FILTMAT  = [F:BTS]FILTDEF
[M:MBM]LORI     = LORI
[M:MBM]COEFF    = LCOEFF
If dim([M:MBM]WRHE) > 0
  [M:MBM]WRHE     = LWRH
  If LWRH<>""
     Diszo [M:MBM]WRHE
  #--- Bug 65493
  Else
     Call WRHINIT2([M:MBM]WRHE,[M:MBM]FCY,8) From STKWRH
  #---
  Endif
Endif
If LORI = "PILOT"
    Gosub CHARG_MASKB
Elsif LVCR <> "" & [F:BTS]OFFLG = 2 # Issue 106345 - 2015-04-27 by BEEBE : additional selection of materials to track with BOMSEQ
        [M:MBM]FILTMAT  = [F:BTS]FILTDEF
        [M:MBM]WMFGNUMD = LVCR
        [M:MBM]WMFGNUMF = LVCR
        [M:MBM]WOPENUMD = LOPE
        [M:MBM]WOPENUMF = LOPE
        [M:MBM]WBOMSEQD = LBOMSEQ
        [M:MBM]WBOMSEQF = LBOMSEQ
        Gosub CHARG_MASK
        Grizo [M:MBM]5,10
        If LWRH<>"" : Diszo [M:MBM]WRHE : Endif
Elsif LITM <> "" & [F:BTS]BOMFLG = 2 # Issue 106345 - 2015-04-27 by BEEBE : additional selection of materials to track with BOMSEQ
        [M:MBM]WBOMNUMD = LITM
        [M:MBM]WBOMNUMF = LITM
        [M:MBM]WBOMALTD = LALT
        [M:MBM]WBOMALTF = LALT
        [M:MBM]WOPENUMD = LOPE
        [M:MBM]WOPENUMF = LOPE
        [M:MBM]WBOMSEQD = LBOMSEQ
        [M:MBM]WBOMSEQF = LBOMSEQ
        Gosub CHARG_MASK
        Grizo [M:MBM]5,10
Else
    Affzo [M:MBM]
Endif

Case [F:BTS]CRIT1
     When 1 : [M:MBM]WSRT += 1
     When 2 : [M:MBM]WSRT += 2
     When 3 : [M:MBM]WSRT += 4
     When 4 : [M:MBM]WSRT += 8
Endcase
Case [F:BTS]CRIT2
     When 1 : [M:MBM]WSRT += 16
     When 2 : [M:MBM]WSRT += 32
     When 3 : [M:MBM]WSRT += 64
     When 4 : [M:MBM]WSRT += 128
Endcase
If [F:BTS]FILTFLG < 3 : [M:MBM]FILTMAT = [F:BTS]FILTDEF : Endif

# 15806 MM 05.05 : application memo STD
If LORI =""
    If filinfo(filpath("ETM",GUSER+"_"+GMMLNUM+"_"+"STD","mbm",0),0)>=0
        Call LECMEMO("STD","[M:MTB2]",GMMLNUM+"~mbm") From GMEMO
        [M:MBM] = [M:MTB2]
        Affzo [M:MBM]10
    Endif
Endif

Return

#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables ( sections analytiques)           #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & !GVTMOD
  Local Char BASPAG(10)
  If (dim([M:MBM]CCE1)>0)
      BASPAG="NBLIG" : Gosub TIT_COL From ="W1WT61"+GMMLNUM+"1"
      If [M:MBM]NBLIG = 0 : [M:MBM]NBLIG = 1 : Affzo [M:MBM]15 : Effzo [M:MBM]15 : Endif
  Endif
Endif
Raz GSOC_UPDFLG
Return

#########################################################################
$SETBOUT
# Pour interdire la navigation
GREP="M"

ETABOU(GSPE1) = 1                                     # recherche
ETABOU(GSPE2) = 1                                     # critères
ETABOU(GSPE3) = 1                                     # validation
ETABOU(GABAN) = 1
If LORI <> "" : ETABOU(GSPE2) = 0 : Endif # Critères interdit si on vient du plan de suivi des temps
If LORI = "PILOT"
    ETABOU(GSPE1) = 0                                     # recherche
Endif
Return

########################################################################
$BOUTON
Case BOUT
    When "1"       :     Gosub CHARG_MASK
    When "2"       :     If [M:MBM]REACT = 2 : Gosub CHARG_MASK : [M:MBM]REACT = 1 : Endif
    When "3"       :     Gosub VALIDATION
Endcase
Return

#########################################################################
$AP_CHOIX
# interception de la touche return
If REPONSE = GSTARET
    Gosub CHARG_MASK
Endif
Return

#######################################################################
$OPEN_FILE
If clalev([M:ORDK])=0 : Local Mask ORDK      [ORDK] : Endif       # pour générer encours
If clalev([M:MTMK])=0 : Local Mask MTMK      [MTMK] : Endif       # masque buffer suivi matière
If clalev([F:BOH])<=0 : Local File BOM        [BOH] : Endif
If clalev([F:BOD])<=0 : Local File BOMD       [BOD] : Endif
If clalev([F:ITM])<=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF])<=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV])<=0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITG])<=0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:MFG])<=0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFI])<=0 : Local File MFGITM     [MFI] : Endif
If clalev([F:MFM])<=0 : Local File MFGMAT     [MFM] : Endif
If clalev([F:MFM1])<=0: Local File MFGMAT    [MFM1] : Endif
If clalev([F:MFO])<=0 : Local File MFGOPE     [MFO] : Endif
If clalev([F:MTK])<=0 : Local File MFGHEADTRK [MTK] : Endif
If clalev([F:MKI])<=0 : Local File MFGITMTRK  [MKI] : Endif
If clalev([F:MKM])<=0 : Local File MFGMATTRK  [MKM] : Endif
If clalev([F:TCA])<=0 : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:TBO])<=0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:STA])<=0 : Local File STOALL     [STA] : Endif
If clalev([F:STO])<=0 : Local File STOCK      [STO] : Endif
If clalev([F:STS])<=0 : Local File STOSER     [STS] : Endif  # numéros de série
If clalev([F:STC])<=0 : Local File STOLOC     [STC] : Endif
If clalev([F:STJ])<=0 : Local File STOJOU     [STJ] : Endif
If clalev([F:STL])<=0 : Local File STOLOT     [STL] : Endif
If clalev([F:ORD])<=0 : Local File ORDERS     [ORD] : Endif
If clalev([F:MWS])<=0 : Local File WORKSTATIO [MWS] : Endif
If clalev([F:TFO])<=0 : Local File TABFOR     [TFO] : Endif
If clalev([F:TRU])<=0 : Local File TABALLRUL  [TRU] : Endif
If clalev([F:SRU])<=0 : Local File TABSTORUL  [SRU] : Endif
If clalev([F:BTS])<=0 : Local File BENCHTRS   [BTS] : Endif
If clalev([F:CAL])<=0 : Local File CPTANALIN  [CAL] : Endif
If clalev([F:DTR])<=0 : Local File DIETRS     [DTR] : Endif
If clalev([F:FCY])<=0 : Local File FACILITY   [FCY] : Endif

If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif
# Issue 107513 - 2015-08-26 by JUSYN : Versioning
If clalev([F:EVL])=0 : Local File ECCVAL [EVL] : Endif

Return

########################################################################
$LECTURE_BTS
#----- Relecture transaction de saisie  -----#
If [F:BTS]BTSTYP <> 61 | [F:BTS]BTSNUM <> GMMLNUM
    Read [BTS]BTS0=61;GMMLNUM : If fstat Raz [F:BTS] : Endif
Endif
Return

########################################################################
$CHARG_PARAM

Call GETCPY(GFCY,"BTS",61,GMMLNUM) From TRTX3CPT

#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return



########################################################################
$FIN
Local Integer WRET
GCONSULT = GCONSLCT
GFONC1 = SAV_GFONC1

If [M:MBM]NBLIG > 0
    Call DELSTOSORW(-1,0,"MBM",[M:MBM]FCY,WRET) From STKSOR
Else
    Call RAZSTOSORW From STKSOR
Endif

Kill GMFMLIN, GMMLNUM
Raz GORITITCOL
Call IMPSCR From ATRTX3
PARAM(13) = num$(LRETOK)

# 01.10 mm 61503
Gosub REST_GLOB From TRTX3GLOB

Return


########################################################################
$ABA
Local Integer WRET

If [M:MBM]NBLIG > 0
    Call DELSTOSORW(-1,0,"MBM",[M:MBM]FCY,WRET) From STKSOR
Else
    Call RAZSTOSORW From STKSOR
Endif
GMFMLIN = 1
Gosub DEBUT
Return

###############################################################
$CHARG_MASK
Local Char CRITERE2(80)
Local Char CRITERE3(255)
Local Char CRITERE(255) : CRITERE = "1=1"
# 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char    CUSFLT(255)
Local Char FORMULE1(255)
Local Integer WNO_REAJUST, WNO_AUTO
Local Integer WLIG
#
Local Integer WMAX : WMAX = dim([M:MBM]ITMREF) - 2
Local Decimal LDIS, WUSEQTY,WTOTUSEQTY
Local Integer STA, WRET
Local Integer WCUNFLG
Raz CRITERE2
Raz CRITERE3
Raz FORMULE1

Call DELSTOSORW(-1,0,"MBM",[M:MBM]FCY,WRET) From STKSOR

[M:MBM]TRSCODS = [F:BTS]TRSCODS
[M:MBM]CCECODS = [F:DTR]STOCCECOD

Effzo [M:MBM]15
Call STKCTRIPT(date$,[M:MBM]FCY,"1") From STKLIB
If GMESSAGE <> "" : Return : Endif

GMFMLIN = 1
If [M:MBM]WBOMNUMF <> "" & [F:BTS]BOMFLG = 2
    nolign = 0
    If [M:MBM]WBOMNUMD = [M:MBM]WBOMNUMF
        Call REMPL_TABLEAU([M:MBM]WBOMNUMD,[M:MBM]WBOMNUMF,LPROD,[M:MBM]WBOMNUMD)
    Else
        Call REMPL_TABLEAU([M:MBM]WBOMNUMD,[M:MBM]WBOMNUMF,LPROD,LITM)
    Endif
Elsif [F:BTS]OFFLG = 2
   CRITERE += "& MFGFCY = [M:MBM]FCY"
   CRITERE += "& CPNTYP<> 5"
   If [M:MBM]WMFGNUMF <> ""
      CRITERE += "& MFGNUM >= [M:MBM]WMFGNUMD & MFGNUM <= [M:MBM]WMFGNUMF"
   Endif
   If [M:MBM]WOPENUMF <> 0
      If LPROD <> 2
          CRITERE += "& BOMOPE >= [M:MBM]WOPENUMD & BOMOPE <= [M:MBM]WOPENUMF"
      Else
          CRITERE += "& (BOMOPE >= [M:MBM]WOPENUMD & BOMOPE <= [M:MBM]WOPENUMF | BOMOPE = 0)"
      Endif
   Endif
   If [M:MBM]WITMREFF <> ""
      CRITERE += "& ITMREF >= [M:MBM]WITMREFD & ITMREF <= [M:MBM]WITMREFF"
   Endif
   If [M:MBM]ENDDATEND <> [0/0/0]
      CRITERE2 = "RETDAT >= [M:MBM]ENDDATSTR & RETDAT <= [M:MBM]ENDDATEND"
   Endif
   If LLIN <> 0 :
      CRITERE += " & find(MFGLIN,0,LLIN)"
   Endif
   If [F:BTS]FILTFLG < 3
        Case [M:MBM]FILTMAT
              When 1 : CRITERE -= " & MFMTRKFLG <"+num$(5)
              When 2 : CRITERE -= " & MFMTRKFLG ="+num$(5)
        Endcase
   Else
       Case [F:BTS]FILTDEF
              When 1 : CRITERE -= " & MFMTRKFLG <"+num$(5)
              When 2 : CRITERE -= " & MFMTRKFLG ="+num$(5)
       Endcase
   Endif
   # Issue 106345 - 2015-04-27 by BEEBE : additional selection of materials to track with BOMSEQ
   If [M:MBM]WBOMSEQF <> 0
      If LPROD <> 2
          CRITERE += "& BOMSEQ >= [M:MBM]WBOMSEQD & BOMSEQ <= [M:MBM]WBOMSEQF"
      Else
          CRITERE += "& (BOMSEQ >= [M:MBM]WBOMSEQD & BOMSEQ <= [M:MBM]WBOMSEQF | BOMSEQ = 0)"
      Endif
   Endif
   CRITERE -= " & MATSTA <>"+num$(4)
#   CRITERE -= " & SCOFLG <>"+num$(2)
#
# 09.01 demande 10405
    Raz CUSFLT
    GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
    If CUSFLT = "" : CUSFLT = "1=1" : Endif
#
    Gosub ANALYSE_FORMULE
    If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

    If CRITERE2 <> ""
       Filter [F:MFM] Where evalue(CRITERE) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
    Else
       Filter [F:MFM] Where evalue(CRITERE) & evalue(CUSFLT) & evalue(FORMULE1)
    Endif
   nolign = 0
   For [F:MFM]
      Raz WCUNFLG
      If [F:MFG]MFGNUM <> [F:MFM]MFGNUM
          Read [F:MFG]MFG0 = [F:MFM]MFGNUM
          If fstat : Raz [F:MFG] : Endif
      Endif

      #L'OF doit être complet
      If [F:MFG]TYPMOD = 1    : Goto NEXTMFM2  : Endif
      #L'OF doit être ferme
      If [F:MFG]MFGSTA <> 1   : Goto NEXTMFM2 : Endif
      If [F:MFG]MATLINNBR = 0 : Goto NEXTMFM2 : Endif
      If [F:MFG]SUSFLG = 2    : Goto NEXTMFM2 : Endif
      #Selon paramètre général l'OF doit être alloué complètement
      If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
         Goto NEXTMFM2
      Endif
      #Selon paramètre général, l'OF doit être édité
      If  [F:MFG]MFGTRKFLG < 3 & GDOSFAB = 2 : Goto NEXTMFM2 : Endif
      mkstat = 0

     # boucle d'analyse des matières bloquantes si rupture
      For [MFM1]MFM0 Where MFGNUM = [F:MFG]MFGNUM                    # 10.02 Performances
               If [F:MFM1]SHTQTY <> 0
                  Read [ITF]ITF0=[F:MFM1]ITMREF;[F:MFM1]MFGFCY
                  If !fstat & [F:ITF]MFGSHTCOD = 1
                     mkstat = 1
                     Break
                  Endif
               Endif
      Next
      If mkstat = 1 : Goto NEXTMFM2 : Endif
      If [F:MFM]MFGLIN <> 0
           Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
           If fstat : Raz [F:MFI] : Endif
      Else Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
           Read [F:MFI]MFI0 First
           If fstat : Raz [F:MFI] : Endif
      Endif
      Filter [F:MFI]
       If [M:MBM]WITMRELF <> ""
          If [F:MFI]ITMREF < [M:MBM]WITMRELD | [F:MFI]ITMREF > [M:MBM]WITMRELF
             Goto NEXTMFM2
          Endif
      Endif
     If [M:MBM]WCDEF <> ""
          If [F:MFI]VCRNUMORI < [M:MBM]WCDED | [F:MFI]VCRNUMORI > [M:MBM]WCDEF
             Goto NEXTMFM2
          Endif
      Endif
      If [M:MBM]WPJTF <> ""
         If [F:MFI]PJT < [M:MBM]WPJTD | [F:MFI]PJT > [M:MBM]WPJTF
            Goto NEXTMFM2
         Endif
      Endif
      If [F:ITM]ITMREF <> [F:MFM]ITMREF
          Read [F:ITM]ITM0 = [F:MFM]ITMREF
          If fstat : Goto NEXTMFM2 : Endif
      Endif
      If [F:ITF]ITMREF <> [F:MFM]ITMREF | [F:ITF]STOFCY <> [F:MFM]MFGFCY
         Read [F:ITF]ITF0 = [F:MFM]ITMREF;[F:MFM]MFGFCY
         If fstat : Raz [F:ITF] : Endif
      Endif

      # idem FUNBENCHI(CUSSELENR) et FUNBENCHO(CUSSELENR)
      # 04.07 demande 40670 contrôles supplémentaires sur des tables annexes
      # Mettre GPE = 0 pour refuser la matière
      GPOINT = "CUSCTLSUP" : GPE=1 : Gosub  ENTREE From EXEFNC
      If !GPE : Goto NEXTMFM2 : Endif

    #Si article en inventaire on regarde si il y a des emplacements libérés
      If [F:ITF]CUNFLG = 2
         If [F:MFM]ALLSTA > 3
            Gosub REC_LOC From SUBMTKB
         Else
            # 04.02 Problèmes Perf
            Filter [F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF & CUNLOKFLG = 1
&                   Order By Key STO3
            Read [F:STO]STO3 First
            If fstat WCUNFLG = 2 : Endif
            Filter [F:STO]
         Endif
      Endif
      If WCUNFLG  <> 2
          If ([F:BTS]STOCODDEF = 3 | [F:ITF]STOCOD = [F:BTS]STOCODDEF)
              If nolign+1 > WMAX : Break : Endif
              nolign  += 1
              [M:MBM]MATTYP(nolign-1) = 1
              [M:MBM]IPTDAT(nolign-1) = date$
              Gosub CHARG_MFM
              [M:MBM]WINDIC(nolign-1) = 1
              GMFMLIN += 1
          Endif
      Else  # CCC (2010-01-15) DM 59082 : Informer sur le fait que l'article est en inventaire
          Call MESSAGE([F:ITF]ITMREF-":"-mess(185,199,1)) From GESECRAN
      Endif
   $NEXTMFM2
   Next
   [M:MBM]NBLIG = nolign
   Filter [F:MFM]
Endif

For WLIG = 0 To [M:MBM]NBLIG-1
    If [M:MBM]USEQTY(WLIG) <> 0
        # 11.06 demande38605
        nolign = WLIG+1
       Gosub TRT_STOCKLIGNE
    Endif
    # On est en pré chargement, donc on ne peut pas avoir deux fois la même ligne
   # il suffit donc de rajouter la quantité de la ligne au déjà consommé de la matière
    WTOTUSEQTY = [M:MBM]USEQTY(WLIG) + [M:MBM]MFMUSEQTY(WLIG)
    Raz WRET
    Call CONT_SOLDE_MAT([M:MBM]FCY,[M:MBM]ITMREF(WLIG),WTOTUSEQTY,[M:MBM]MFMEXTQTY(WLIG),WRET) From MFGLIBM
    If WRET = 0 : [M:MBM]CLEFLG(WLIG) = 1
    Else        : [M:MBM]CLEFLG(WLIG) = 2
    Endif
Next
# 11.04 demande 26502 chargement spécifique du masque MBM
GPOINT = "LOAMSKMBM" : Gosub ENTREE From EXEFNC

Affzo [M:MBM]5,7,10
Gosub AFF_TABLEAU

If WNO_REAJUST = 1
   Call MESSAGE(mess(234,190,1)) From GESECRAN
Endif
If WNO_AUTO = 1
    # Retrait manuel strict : La détermination auto n’a pu se faire sur les articles dont le mode de retrait est immédiat
    Call MESSAGE(mess(252,190,1)) From GESECRAN
Endif

Return




###############################################################
$CHARG_MASKB
Local Integer WNO_REAJUST, WNO_AUTO
Local Integer WLIG
#
Local Integer WMAX : WMAX = dim([M:MBM]ITMREF) - 2
Local Decimal LDIS, WUSEQTY,WTOTUSEQTY
Local Integer STA, WRET
Local Integer WCUNFLG, WI

Call DELSTOSORW(-1,0,"MBM",[M:MBM]FCY,WRET) From STKSOR

[M:MBM]TRSCODS = [F:BTS]TRSCODS
[M:MBM]CCECODS = [F:DTR]STOCCECOD


Effzo [M:MBM]15

Call STKCTRIPT(date$,[M:MBM]FCY,"1") From STKLIB
If GMESSAGE <> "" : Return : Endif

GMFMLIN = 1
nolign = 0
For WI = 0 To [M:MTPK]NBLIG-1
   Read [F:MFG]MFG0 = [M:MTPK]MFGNUM(WI)
   Case [F:BTS]FILTDEF
        When 1 :    Filter [F:MFM] Where MFGNUM = [M:MTPK]MFGNUM(WI) & MATSTA <>4 & MFMTRKFLG <5 & CPNTYP <> 5
        When 2 :    Filter [F:MFM] Where MFGNUM = [M:MTPK]MFGNUM(WI) & MATSTA <>4 & MFMTRKFLG =5 & CPNTYP <> 5
        When 3 :    Filter [F:MFM] Where MFGNUM = [M:MTPK]MFGNUM(WI) & MATSTA <>4 & CPNTYP <> 5
   Endcase
   For [F:MFM]
     Raz WCUNFLG
     # boucle d'analyse des matières bloquantes si rupture
      For [MFM1]MFM0 Where MFGNUM = [F:MFG]MFGNUM                    # 10.02 Performances
               If [F:MFM1]SHTQTY <> 0
                  Read [ITF]ITF0=[F:MFM1]ITMREF;[F:MFM1]MFGFCY
                  If !fstat & [F:ITF]MFGSHTCOD = 1
                     mkstat = 1
                     Break
                  Endif
               Endif
      Next
      If mkstat = 1 : Goto NEXTMFM3 : Endif
      If [F:MFM]MFGLIN <> 0
           Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
           If fstat : Raz [F:MFI] : Endif
      Else Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
           Read [F:MFI]MFI0 First
           If fstat : Raz [F:MFI] : Endif
      Endif
      Filter [F:MFI]
      If [F:ITM]ITMREF <> [F:MFM]ITMREF
          Read [F:ITM]ITM0 = [F:MFM]ITMREF
          If fstat : Goto NEXTMFM3 : Endif
      Endif
      If [F:ITF]ITMREF <> [F:MFM]ITMREF | [F:ITF]STOFCY <> [F:MFM]MFGFCY
         Read [F:ITF]ITF0 = [F:MFM]ITMREF;[F:MFM]MFGFCY
         If fstat : Raz [F:ITF] : Endif
      Endif
    #Si article en inventaire on regarde si il y a des emplacements libérés
      If [F:ITF]CUNFLG = 2
         If [F:MFM]ALLSTA > 3
            Gosub REC_LOC From SUBMTKB
         Else
            # 04.02 Problèmes Perf
            Filter [F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF & CUNLOKFLG = 1
&                  Order By Key STO3
            Read [F:STO]STO3 First
            If fstat WCUNFLG = 2 : Endif
            Filter [F:STO]
         Endif
      Endif
      If WCUNFLG  <> 2
          If ([F:BTS]STOCODDEF = 3 | [F:ITF]STOCOD = [F:BTS]STOCODDEF)
              If nolign+1 > WMAX : Break 2 : Endif
              nolign  += 1
              [M:MBM]MATTYP(nolign-1) = 1
              [M:MBM]IPTDAT(nolign-1) = date$
              Gosub CHARG_MFM
              [M:MBM]WINDIC(nolign-1) = 1
              GMFMLIN += 1
          Endif
      Else  # CCC (2010-01-15) DM 59082 : Informer sur le fait que l'article est en inventaire
          Call MESSAGE([F:ITF]ITMREF-":"-mess(185,199,1)) From GESECRAN
      Endif
   $NEXTMFM3
   Next
Next
[M:MBM]NBLIG = nolign
Filter [F:MFM]

For WLIG = 0 To [M:MBM]NBLIG-1
   # 11.06 demande38605
   nolign = WLIG+1
    Gosub TRT_STOCKLIGNE
    WTOTUSEQTY = [M:MBM]USEQTY(WLIG) + [M:MBM]MFMUSEQTY(WLIG)
    Raz WRET
    Call CONT_SOLDE_MAT([M:MBM]FCY,[M:MBM]ITMREF(WLIG),WTOTUSEQTY,[M:MBM]MFMEXTQTY(WLIG),WRET) From MFGLIBM
    If WRET = 0 : [M:MBM]CLEFLG(WLIG) = 1
    Else        : [M:MBM]CLEFLG(WLIG) = 2
    Endif
Next

# 11.04 demande 26502 chargement spécifique du masque MBM
GPOINT = "LOAMSKMBM" : Gosub ENTREE From EXEFNC

Affzo [M:MBM]5,7,10
Gosub AFF_TABLEAU
Grizo [M:MBM]5,10
If LWRH<>"" : Diszo [M:MBM]WRHE : Endif

If WNO_REAJUST = 1
   Call MESSAGE(mess(234,190,1)) From GESECRAN
Endif
If WNO_AUTO = 1
    # Retrait manuel strict : La détermination auto n’a pu se faire sur les articles dont le mode de retrait est immédiat
    Call MESSAGE(mess(252,190,1)) From GESECRAN
Endif

Return

##########################
$CHARG_MFM
# 10.01 demande 11203
Local Decimal LDIS, WUSEQTY, WTOTUSEQTY, WWUSEQTY
Local Integer STA, LRET,J
Local Char    WCCE(15)
Local Decimal LDIS, WALLQTY, WALLQTYSHT
Local Integer LIG : LIG=nolign-1

# Issue 116022 - 2016-04-15 by JUSYN : Identifier for calling prog
Local Char     LIDPROG(30): LIDPROG = "CHARG_MFM"

[M:MBM]  = [F:MFM]
# 56958
If dim([M:MBM]LOC) > 0 : Raz [M:MBM]LOC(nolign-1) : Endif
# Issue 84927 - 2012-10-12 by CCC
#If dim([M:MBM]WRH) > 0 : [M:MBM]WRH(nolign-1)=[M:MBM]WRHE : Endif
If dim([M:MBM]WRH) > 0 & GWRHOBY=2 : [M:MBM]WRH(nolign-1)=[M:MBM]WRHE : Endif
[M:MBM]MKMTEX(nolign-1)    = [F:MFM]MFMTEX
[M:MBM]LOTPREF(nolign-1)   = [F:MFM]LOT
[M:MBM]LOCPREF(nolign-1)   = [F:MFM]LOC
[M:MBM]STAPREF(nolign-1)   = [F:MFM]STA
# Si emplacement atelier c'est celui qui se trouve sur la ligne matière
[M:MBM]WSTLOC(nolign-1)     = [F:MFM]LOC
[M:MBM]MFMITMREF(nolign-1)  = [F:MFM]ITMREF
#[M:MBM]ITMDES1(nolign-1)    = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MBM]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:MBM]STOMGTCOD(nolign-1)  = [F:ITF]STOMGTCOD
[M:MBM]NEGSTO(nolign-1)     = [F:ITM]NEGSTO
[M:MBM]TCLCOD(nolign-1)     = [F:ITM]TCLCOD
[M:MBM]BOMNUM(nolign-1)     = [F:MFI]ITMREF
[M:MBM]BOMALT(nolign-1)     = [F:MFI]BOMALT
[M:MBM]MFMEXTQTY(nolign-1)  = [F:MFM]RETQTY
[M:MBM]MFMUSEQTY(nolign-1)  = [F:MFM]USEQTY
[M:MBM]MFMALLQTY(nolign-1)  = [F:MFM]ALLQTY
[M:MBM]MFMSHTQTY(nolign-1)  = [F:MFM]SHTQTY
[M:MBM]RMNEXTQTY(nolign-1)  = [F:MFM]RETQTY - [F:MFM]USEQTY
If [M:MBM]RMNEXTQTY(nolign-1) < 0 : [M:MBM]RMNEXTQTY(nolign-1 ) = 0 : Endif
If [F:MFM]MFMTRKFLG   = 5
   [M:MBM]USEQTY(nolign-1)  = 0
   [M:MBM]CLEFLG(nolign-1)  = 2
   [M:MBM]WQTY(nolign-1)    = [M:MBM]USEQTY(nolign-1)
Else
# 04.02 demande 9134
    Gosub CALC_WWUSEQTY
    WUSEQTY = [F:MFM]RETQTY - WWUSEQTY
    If WUSEQTY < 0 : Raz WUSEQTY : Endif
# 03.05 demamnde 28493
    If find(LORI,"MBI","MBO") & [F:MFM]MFGNUM = [M:MBM]WMFGNUMD & [M:MBM]COEFF <> 1 & LCONSMAT > 1
       Gosub REAJUST_WUSEQTY
    Endif
    [M:MBM]USEQTY(nolign-1) = WUSEQTY
    [M:MBM]WQTY(nolign-1) = [M:MBM]USEQTY(nolign-1)
    If [M:MBM]USEQTY(nolign-1) < 0 : Raz [M:MBM]USEQTY(nolign-1) : Endif
    If [F:BTS]CPLUPDFLG = 2
        Raz LRET
        # 10.01 la qté consommée à utiliser est la somme de ce qui a déjà été
        # consommé et de ce qui va l'être demande 11203
        # 04.02 demande 9134
        WTOTUSEQTY = [M:MBM]USEQTY(nolign-1) + WWUSEQTY
        Call CONT_SOLDE_MAT([M:MBM]FCY,[M:MBM]ITMREF(nolign-1),WTOTUSEQTY,[M:MBM]MFMEXTQTY(nolign-1),LRET)
&            From MFGLIBM
        If LRET = 1 : [M:MBM]CLEFLG(nolign-1) = 2
        Else        : [M:MBM]CLEFLG(nolign-1) = 1
        Endif
    Else
        Raz [M:MBM]USEQTY(nolign-1)
        [M:MBM]CLEFLG(nolign-1) = 1
    Endif
Endif
If [F:MFM]MFMTRKFLG   = 5
   [M:MBM]CLEFLG(nolign-1)  = 2
Else
   [M:MBM]WCLEFLG(nolign-1) = 1
Endif

[M:MBM]STOCODL(nolign-1)= [F:ITF]STOCOD
# 05.05 alignement sur ce qui est fait en suivi standard
#If [F:BTS]STOCODMAN = 2 & [M:MBM]STOCODL(nolign-1) = 1
#     Raz [M:MBM]USEQTY(nolign-1)
#     [M:MBM]CLEFLG(nolign-1) = 1
#Endif
If [F:MFM]SHTQTY <> 0 : [M:MBM]STFLG(nolign-1) = 2
Else                    [M:MBM]STFLG(nolign-1) = 1
Endif
[M:MBM]OPENUM(nolign-1)     = [F:MFM]BOMOPE
[M:MBM]WLINUM(nolign-1)     = GMFMLIN

# 117921 mm 10.2016 - shifted paragraph to solve bug "default dimension in material tracking"
If [F:MFM]BOMOPE <> 0
   Filter [F:MFO] Where MFGNUM = [F:MFM]MFGNUM & OPENUM = [F:MFM]BOMOPE
   Read [F:MFO]MFO0 First
   If fstat : Raz [F:MFO]: Endif
   [M:MBM]CPLWST(nolign-1) = [F:MFO]EXTWST
   [M:MBM]MFMITMREF(nolign-1) = [F:MFM]ITMREF
   Filter [F:MFO]
Endif

# 117921 mm 10.2016
# reading work center to get costing dimension
If [M:MBM]CPLWST(nolign-1)<> ""
  Read [MWS]WST0=[M:MBM]CPLWST(nolign-1);[M:MBM]FCY
Endif

#Chargement des section ana
 Call CHARG_ACCCCE(nolign-1,"","","[M:MBM]CCE",
&                    "MFM",0,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF) From TRTX3CPT
For J = 1 To GNBDIE
  If evalue ("[M:MBM]CCE"+num$(J)+"(nolign-1)") =""
      Call INISEC(WCCE,"MKMB", J) From TRTX3CPT
      Assign "[M:MBM]CCE"+num$(J)+"(nolign-1)" With WCCE
  Endif
Next

# 05.05 demande 30321
[M:MBM]WSTODET(nolign-1) = 1
# Issue 107513/8 - 2015-07-13 by JUSYN : Parent product when WO versioned then versions not allowed to be changed
Gosub GREY_ECC

Return

################################################
# 04.02 demande 9134
$CALC_WWUSEQTY
Local Integer I
WWUSEQTY = [F:MFM]USEQTY
If nolign > 1
   For I = 0 To nolign-2
       If [M:MBM]IPTDAT(I) = [M:MBM]IPTDAT(nolign-1) &
&         [M:MBM]MATTYP(I) = [M:MBM]MATTYP(nolign-1) &
&         [M:MBM]MFGNUM(I) = [M:MBM]MFGNUM(nolign-1) &
&         [M:MBM]ITMREF(I) = [M:MBM]ITMREF(nolign-1) &
&         [M:MBM]BOMSEQ(I) = [M:MBM]BOMSEQ(nolign-1) &
&         [M:MBM]OPENUM(I) = [M:MBM]OPENUM(nolign-1)
          WWUSEQTY += [M:MBM]USEQTY(I)
       Endif
   Next
Endif
Return

################################################
# Calcule la quatité allouée utilisée dans les lignes précédentes.
Funprog CALC_WWUSEALL(PIND)
Value Integer PIND  # FGR 14/01/2010 : X3SUIVI60986

Local Decimal WWUSEALL
Raz WWUSEALL
If nolign > 1
    WWUSEALL += sigma(0,[M:MBM]NBLIG-1,[M:MBM]USEQTY(indcum)
&                                 *( indcum<>PIND &
&                                    [M:MBM]IPTDAT(indcum) = [M:MBM]IPTDAT(PIND) &
&                                    [M:MBM]MATTYP(indcum) = [M:MBM]MATTYP(PIND) &
&                                    [M:MBM]MFGNUM(indcum) = [M:MBM]MFGNUM(PIND) &
&                                    [M:MBM]ITMREF(indcum) = [M:MBM]ITMREF(PIND) &
&                                    [M:MBM]BOMSEQ(indcum) = [M:MBM]BOMSEQ(PIND) &
&                                    [M:MBM]OPENUM(indcum) = [M:MBM]OPENUM(PIND) ) )
Endif
End WWUSEALL


################################################
#On passe par ce traitement intermédiaire à cause
#de l'éventuelle récursivité liée aux fantômes
Subprog REMPL_TABLEAU(LITMD,LITMF,LPROD,LITM)
Value    Char    LITMD
Value    Char    LITMF
Value    Integer LPROD
Value    Char    LITM

Local    Decimal LDIS
Local    Char    WITM(GLONITM), WFCY(GLONFCY)
Local    Date    WDAT
Local    Integer WALT
Local    Integer WCUNFLG
Local    Integer WLIG
Local    Integer WRET
Local    Char CRITERE(255)(2)
# 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char    CUSFLT(255)
# 05.02
Local Char    FORMULE1(255)
# Issue 116022 - 2016-04-20 by JUSYN : Former enhancement used to display information message about versioned parent product in result.
Local Integer WVERBOM # Issue 107513/8 - 2015-07-13 by JUSYN : Versioning
Raz CRITERE, GBIDI1
Call ADDCRIT(CRITERE,GBIDI1,"","ITMREF >= LITMD & ITMREF <= LITMF","&") From GOBJSUB
Call ADDCRIT(CRITERE,GBIDI1,"","BOMALTTYP=2","&") From GOBJSUB
Call ADDCRIT(CRITERE,GBIDI1,"","!find(CPNTYP,5,6)","&") From GOBJSUB
If [M:MBM]WBOMALTF <> 0
   Call ADDCRIT(CRITERE,GBIDI1,"","BOMALT >= [M:MBM]WBOMALTD & BOMALT <= [M:MBM]WBOMALTF","&") From GOBJSUB
Endif
If [M:MBM]WITMREFF <> ""
   Call ADDCRIT(CRITERE,GBIDI1,"","CPNITMREF >= [M:MBM]WITMREFD & CPNITMREF <= [M:MBM]WITMREFF","&") From GOBJSUB
Endif
If [M:MBM]WOPENUMF <> 0
   If LPROD <> 2
      Call ADDCRIT(CRITERE,GBIDI1,"","CPNOPE >= [M:MBM]WOPENUMD & CPNOPE <= [M:MBM]WOPENUMF","&") From GOBJSUB
   Else
      Call ADDCRIT(CRITERE,GBIDI1,"","(CPNOPE >= [M:MBM]WOPENUMD & CPNOPE <= [M:MBM]WOPENUMF | CPNOPE = 0)","&") From GOBJSUB
   Endif
Endif
# Issue 106345 - 2015-04-27 by BEEBE : additional selection of materials to track with BOMSEQ
If [M:MBM]WBOMSEQF <> 0
   If LPROD <> 2
      Call ADDCRIT(CRITERE,GBIDI1,"","BOMSEQ >= [M:MBM]WBOMSEQD & BOMSEQ <= [M:MBM]WBOMSEQF","&") From GOBJSUB
   Else
      Call ADDCRIT(CRITERE,GBIDI1,"","(BOMSEQ >= [M:MBM]WBOMSEQD & BOMSEQ <= [M:MBM]WBOMSEQF | BOMSEQ = 0)","&") From GOBJSUB
   Endif
Endif
# 05.02 demande 14201
Call ADDCRIT(CRITERE,GBIDI1,"","(BOMSTRDAT = [0/0/0] | (BOMSTRDAT <= date$)) & (BOMENDDAT = [0/0/0] | (BOMENDDAT >= date$))","&") From GOBJSUB

# 09.01 demande 10405
Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif
#
Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

WVERBOM = 0  # Issue 107513/8 - 2015-07-13 by JUSYN : Versioning

Local File BOMD [BOD] Where evalue(CRITERE) & evalue(CUSFLT) & evalue(FORMULE1)
Read [F:BOD]BOD0 First
#Boucle while au lieu de For à cause de la récursivité
While !fstat
    Raz WCUNFLG
    WITM= [F:BOD]ITMREF
    WDAT= date$
    WFCY= [M:MBM]FCY
    WALT= [F:BOD]BOMALT
    Read [TBO]TBO0=[F:BOD]BOMALTTYP;[F:BOD]BOMALT
    If fstat : Goto NEXTMFM1 : Endif
    Read [BOH]BOH0=[F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
    If fstat : Goto NEXTMFM1 : Endif
    Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
    If WALT=0 : Goto NEXTMFM1 : Endif
    # 107513/8 - 2015-07-13 by JUSYN : Versioning - no BOM with versioned parent product
    If [F:ITM]ITMREF <> [F:BOD]ITMREF
        Read [F:ITM]ITM0 = [F:BOD]ITMREF
        If fstat
            Goto NEXTMFM1
        Endif
    Endif
    # Issue 116022 - 2016-04-20 by JUSYN : Former enhancement used to display information message about versioned parent product in result.
    # Product versioned
    If dim([F:ITM]ECCFLG)>0 & dim([F:ITM]ECCSTO)>0
        If [F:ITM]ECCFLG > 1 & [F:ITM]ECCSTO > 1
            WVERBOM += 1
            # Goto NEXTMFM1
        Endif
    Endif

 # si sous-produit
   If [F:BOD]CPNTYP = 4 :  Goto NEXTMFM1 : Endif
   If [F:ITM]ITMREF <> [F:BOD]CPNITMREF
          Read [F:ITM]ITM0 = [F:BOD]CPNITMREF
          If fstat : Goto NEXTMFM1 : Endif
   Endif

 #lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
   If [F:ITF]STOFCY <>[M:MBM]FCY | [F:ITF]ITMREF <> [F:BOD]CPNITMREF
      Read [ITF]ITF0 = [F:BOD]CPNITMREF;[M:MBM]FCY
      If fstat
         Goto NEXTMFM1
      Endif
   Endif

   # article non géré en stock
   If ([F:ITM]PHAFLG <> 2 & [F:ITF]STOMGTCOD = 1)        # (pb fantômes)
       Goto NEXTMFM1
   Endif
   # article avec statut non actif
   If [F:ITM]ITMSTA > 1
       Goto NEXTMFM1
   Endif
   # lecture article site
#   If [F:ITF]ITMREF <> [F:BOD]CPNITMREF | [F:ITF]STOFCY <> [M:MBM]FCY
#      Read [ITF]ITF0=[F:BOD]CPNITMREF;[M:MBM]FCY
#      If fstat : Goto NEXTMFM1 : Endif
#   Endif

   GPE = 1
   # 04.07 demande 40670 contrôles supplémentaires sur des tables annexes
   # Mettre GPE = 0 pour refuser la matière
   GPOINT = "CUSCTLSUP"
   Gosub  ENTREE From EXEFNC
   If GPE = 0  : Goto NEXTMFM1 : Endif

    #Si article en inventaire on regarde si il y a des emplacements libérés
    # 04.02 Problèmes Perf
   If [F:ITF]CUNFLG = 2
      Filter [F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF & CUNLOKFLG = 1
&                    Order By Key STO3
      Read [F:STO]STO3 First
      If fstat WCUNFLG = 2 : Endif
      Filter [F:STO]
   Endif
   If WCUNFLG = 2
       # CCC (2010-01-15) DM 59082 : Informer sur le fait que l'article est en inventaire
       Call MESSAGE([F:ITF]ITMREF-":"-mess(185,199,1)) From GESECRAN
       Goto NEXTMFM1
   Endif
   # 21881
   If ([F:BTS]STOCODDEF <> 3 & [F:ITF]STOCOD <> [F:BTS]STOCODDEF) : Goto NEXTMFM1 : Endif
   Call LECITV2([M:MBM]FCY,[F:BOD]CPNITMREF,WRET) From MFGLIB
   Call STODISTOT("",0,[F:SRU]AUZSTA,"",LDIS) From STKLIB
   # demande 21559 Possibilité de traverser les articles autres que fantôme
   # Mettre GPE = 1 pour forcer la récursivité quel que soit la catégorie article
   GPE = 0
   GPOINT = "CROSSTEST"
   Gosub  ENTREE From EXEFNC

   # si article fantôme descente par récursivité
   If ([F:ITM]PHAFLG = 2) & (LDIS = 0) | GPE
      Call REMPL_TABLEAU([F:ITM]ITMREF,[F:ITM]ITMREF,LPROD,LITM)
   Else
      nolign  += 1
      [M:MBM]MATTYP(nolign-1) = 2
      [M:MBM]IPTDAT(nolign-1) = date$
      Gosub CHARG_BOD
      [M:MBM]WINDIC(nolign-1) = 1
      GMFMLIN += 1
   Endif
$NEXTMFM1
   Read [BOD] Next
Wend
[M:MBM]NBLIG = nolign
Affzo [M:MBM]15
Filter [F:BOD]

# Issue 116022 - 2016-04-20 by JUSYN : Former enhancement needs to be revised. Just an information message, BOM lines now displayed for parent products versioned.
# Issue 107513/8 - 2015-07-13 by JUSYN : Versioning
# BOM lines from BOMs which parent products are versioned and therefore not displayed
If WVERBOM > 0
    # Call MESSAGE(mess(326,193,1)) From GESECRAN
    # "There are BOM lines not displayed because of their versioned parent product!"
    Call MESSAGE(mess(348,193,1)) From GESECRAN
    # There are BOM lines displayed which parent product is versioned
Endif
End

###############################
$CHARG_BOD
Local Integer J
Local Char    WCCE(15)
Local Decimal WUSEQTY
#
If [F:ITM]ITMREF <> [F:BOD]CPNITMREF
    Read [F:ITM]ITM0 = [F:BOD]CPNITMREF
    If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF <> [F:BOD]CPNITMREF | [F:ITF]STOFCY <> [M:MBM]FCY
   Read [ITF]ITF0=[F:BOD]CPNITMREF;[M:MBM]FCY
   If fstat : Return : Endif
Endif
# Issue 107513 - 2015-08-26 by JUSYN : Versioning
# To allow user to enter versions before passing field OPENUM
Local Char WECCVALMAJ(10)
Local Char WECCVALMIN(10)
WECCVALMAJ = [M:MBM]ECCVALMAJ(nolign-1)
WECCVALMIN = [M:MBM]ECCVALMIN(nolign-1)
[M:MBM]                 = [F:BOD]
[M:MBM]MKMTEX(nolign-1) = [F:BOD]BOMTEXNUM
If WECCVALMAJ <> ""
[M:MBM]ECCVALMAJ(nolign-1) = WECCVALMAJ
Endif
If WECCVALMIN <> ""
[M:MBM]ECCVALMIN(nolign-1) = WECCVALMIN
Endif

# 03.05 demande 28493
If find([M:MBM]LORI,"MBI","MBO") & [F:BOD]ITMREF = LITM  & [F:BTS]CPLUPDFLG = 2
# GH 26/06/2014 bug 98451 # If find(LORI,"MBI","MBO") & . . .
   Gosub REAJUST_WUSEQTY
Endif
[M:MBM]USEQTY(nolign-1)     = WUSEQTY
[M:MBM]LOTPREF(nolign-1)    = "*"
[M:MBM]LOCPREF(nolign-1)    = "*"
#[M:MBM]STAPREF(nolign-1)    = "A"
If LITM = "" : [M:MBM]BOMNUM(nolign-1) = [F:BOD]ITMREF
Else         : [M:MBM]BOMNUM(nolign-1) = LITM
Endif
[M:MBM]TRUBOMNUM(nolign-1)  = [F:BOD]ITMREF
[M:MBM]ITMREF(nolign-1)     = [F:BOD]CPNITMREF
[M:MBM]MFMITMREF(nolign-1)  = [F:BOD]CPNITMREF
[M:MBM]OPENUM(nolign-1)     = [F:BOD]CPNOPE
#[M:MBM]ITMDES1(nolign-1)    = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MBM]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:MBM]STU(nolign-1)        = [F:ITM]STU
[M:MBM]SERMGTCOD(nolign-1)  = [F:ITM]SERMGTCOD
[M:MBM]STOMGTCOD(nolign-1)  = [F:ITF]STOMGTCOD
[M:MBM]NEGSTO(nolign-1)     = [F:ITM]NEGSTO
[M:MBM]TCLCOD(nolign-1)     = [F:ITM]TCLCOD
[M:MBM]STOCODL(nolign-1)    = [F:ITF]STOCOD
[M:MBM]WLINUM(nolign-1)     = GMFMLIN
#Chargement des section ana
For J = 1 To GNBDIE
    Call INISEC(WCCE,"MKMB", J) From TRTX3CPT
    Assign "[M:MBM]CCE"+num$(J)+"(nolign-1)" With WCCE
Next

If [F:BOD]CPNOPE <> 0
   Read [F:MFO]MFO0 First
   If fstat : Raz [F:MFO]: Endif
   [M:MBM]CPLWST(nolign-1) = [F:MFO]EXTWST
Endif
# 05.05 demande 30321
[M:MBM]WSTODET(nolign-1) = 1
# Issue 107513 - 2015-08-26 by JUSYN : Versioning
Affzo [M:MBM]
Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:MBM]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=16;[M:MBM]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return


######################################################
$TRT_STOCKLIGNE
# Stocks 1.4.0
Local Integer WRET, WRUP, WAUTO

If [F:ITM]ITMREF <> [M:MBM]ITMREF(WLIG)
    Read [ITM]ITM0=[M:MBM]ITMREF(WLIG)
    If fstat : Raz [ITM] : Endif
Endif
Raz WRET, [M:ALP]
If [M:MBM]MATTYP(WLIG) = 1 & find([M:MBM]ALLSTA(WLIG),4,5) & [M:MBM]USEQTY(WLIG) <> 0
    Call CTLALL([M:MBM]FCY,10,[M:MBM]MFGNUM(WLIG),[M:MBM]MFGLIN(WLIG),[M:MBM]BOMSEQ(WLIG), 6,[M:MBM]TRSCODS,
&               "",1,[M:MBM]ALLQTY(WLIG),[M:MBM]ALLQTYSHT(WLIG),WRET) From STKALL

        [M:ALP]TRSTYP     = 6
        [M:ALP]TRSCOD     = [M:MBM]TRSCODS
        [M:ALP]VCRTYP     = 10
        [M:ALP]VCRNUM     = [M:MBM]MFGNUM(WLIG)
        [M:ALP]VCRLIN     = [M:MBM]MFGLIN(WLIG)
        [M:ALP]VCRSEQ     = [M:MBM]BOMSEQ(WLIG)
        [M:ALP]STOFCY     = [M:MBM]FCY
        [M:ALP]ITMREF     = [M:MBM]ITMREF(WLIG)
        [M:ALP]QTY        = [M:MBM]USEQTY(WLIG)
        [M:ALP]TYPQTY     = 2
        [M:ALP]STA        = [M:MBM]STAPREF(WLIG)
        [M:ALP]LOT        = [M:MBM]LOTPREF(WLIG)
        [M:ALP]BESDAT     = [M:MBM]IPTDAT(WLIG)  : # Bug 35084
        If dim([M:MBM]WRH)>0 [M:ALP]WRH=[M:MBM]WRH(WLIG) Endif
        Raz WRET
        WRUP = [M:MBM]NEGSTO(WLIG) - 1
        # 08.05 demande 29188
        [M:ALP]PECSCOLOC  = 1
        If [M:MBM]CPLWST(WLIG) <> ""
           If [F:MWS]WST <> [M:MBM]CPLWST(WLIG) | [F:MWS]WCRFCY <> [M:MBM]FCY
               Read [F:MWS]WST0 = [M:MBM]CPLWST(WLIG);[M:MBM]FCY
               If fstat : Raz [F:MWS] : Endif
           Endif
           If [F:MWS]WSTTYP = 3
              [M:ALP]PECSCOLOC  = 2
           Endif
        Endif
        [M:ALP]PECPLFLOC = 2


        # CCC (03/07/07) Bug 40848 : amélioration pour prise en compte des allocations déjà utilisées
        Raz GBIDI1
        For I=0 To [MBM]NBLIG-1
            If I<>nolign-1
&            & [M:MBM]IPTDAT(nolign-1) = [M:MBM]IPTDAT(I)
&            & [M:MBM]MATTYP(nolign-1) = [M:MBM]MATTYP(I)
&            & [M:MBM]MFGNUM(nolign-1) = [M:MBM]MFGNUM(I)
&            & [M:MBM]ITMREF(nolign-1) = [M:MBM]ITMREF(I)
&            & [M:MBM]BOMSEQ(nolign-1) = [M:MBM]BOMSEQ(I)
&            & [M:MBM]OPENUM(nolign-1) = [M:MBM]OPENUM(I)
&            & find([M:MBM]WSTOSEQ(I),[M:SOW]WSTOSEQ)>0
                [M:ALP]TWSTOSEQ(GBIDI1) = [M:MBM]WSTOSEQ(I)
                GBIDI1+=1
                If GBIDI1>=dim([M:ALP]TWSTOSEQ)
                    Break
                Endif
            Endif
        Next

        # CCC (11/06/07) Bug 40848
        [M:ALP]QTY = max(0,min([M:ALP]QTY,[M:MBM]ALLQTY(WLIG)-func CALC_WWUSEALL(nolign-1)))
        If [M:ALP]QTY>0

            Call ALLSTOSORW("MBM",WLIG,[M:MBM]NBLIG,WRUP,1,0, WRET) From STKSOR

            [M:ALP]QTY = [M:MBM]USEQTY(WLIG)-[M:ALP]ALLQTY
            [M:MBM]ALLQTY(WLIG) = [M:ALP]ALLQTY
        Else
            [M:MBM]ALLQTY(WLIG) = 0
        Endif
        Call ALI_ALP("MBM",WLIG) From SUBMTKB



# CCC (13/05/08) Bug 47296 : On laisse faire le OUVSOR
#  # 03.07 Demande  40494
#  # Si pas assez d'allocation et détermination auto à oui, on va chercher du stock ailleurs
#        If [M:ALP]QTY > [M:ALP]ALLQTY & [F:BTS]STKFLG = 2 & ([F:BTS]STOCODMAN=1|[M:MBM]STOCODL(WLIG)=2)
#           [M:ALP]QTY -= [M:ALP]ALLQTY
#           Raz [M:ALP]ALLQTY
#           Call GENSTOSORW("MBM",WLIG,[M:MBM]NBLIG,WRUP,"C",WRET)
#&               From STKSOR
#           [M:MBM]ALLQTY(WLIG)    += [M:ALP]ALLQTY
#           [M:MBM]ALLQTYSHT(WLIG) += [M:ALP]ALLQTYSHT
#        Endif

Else
        Raz WRET
        WRUP = [M:MBM]NEGSTO(WLIG) - 1
        Call ALI_ALP("MBM",WLIG) From SUBMTKB

        If [M:MBM]MATTYP(WLIG) = 1 & find([M:MBM]ALLSTA(WLIG),2,3)
           [M:ALP]ALLQTY  = [M:MBM]MFMALLQTY(WLIG)
        Else
            Raz [M:ALP]ALLQTY
        Endif

# CCC (13/05/08) Bug 47296 : On laisse faire le OUVSOR
#        If [F:BTS]STKFLG = 2 & ([F:BTS]STOCODMAN=1|[M:MBM]STOCODL(WLIG)=2)
#             Call GENSTOSORW("MBM",WLIG,[M:MBM]NBLIG,WRUP,"C",WRET)
#&                            From STKSOR
#        Endif
        [M:MBM]ALLQTY(WLIG)    = [M:ALP]ALLQTY
        [M:MBM]ALLQTYSHT(WLIG) = [M:ALP]ALLQTYSHT

Endif
Raz WRET
If [F:BTS]STKFLG = 1 : WAUTO = 1
Else
    If [F:BTS]STOCODMAN = 2 & [M:MBM]STOCODL(WLIG) = 1 & [M:ALP]QTY <> 0
        WAUTO = 1
        # Retrait manuel strict : La détermination auto n’a pu se faire sur les articles dont le mode de retrait est immédiat
        WNO_AUTO = 1
    Else
        WAUTO = 2
    Endif
Endif
[M:ALP]PECQLYCTL  =  1
Call OUVSOR("MBM",WLIG,[M:MBM]NBLIG,[M:MBM]WSTOSEQ(WLIG),WAUTO,WRET) From STKSOR

# CCC (13/05/08) Bug 47296 : Comparaison de la quantité stockée dans STOSORW et de la quantité demandée après le OUVSOR
[M:MBM]ALLQTY(WLIG)=sigma(0,[M:SOW]NBLIG-1,([M:SOW]WQTYSTUACT(indcum)*([M:SOW]WSTOSEQ(indcum)=[M:MBM]WSTOSEQ(WLIG))))
# si stock négatif interdit, réajustement de la qté à sortir selon le disponible
If [M:MBM]NEGSTO(WLIG) < 2  & [M:MBM]USEQTY(WLIG) > [M:MBM]ALLQTY(WLIG)
    # CCC (23/01/09) Bug 51935 : si rien n'a été trouvé, on laisse la quantité préchargée
    If [M:MBM]ALLQTY(WLIG)>0
        [M:MBM]USEQTY(WLIG) = [M:MBM]ALLQTY(WLIG)
    Endif
    WNO_REAJUST = 1
Endif
# 04.07 Demande 41086
# 11.06 demande38605
If [M:MBM]MATTYP(WLIG) = 1
    Read [F:MFM]MFM0 = [M:MBM]MFGNUM(WLIG);[M:MBM]MFGLIN(WLIG);[M:MBM]BOMSEQ(WLIG);[M:MBM]ITMREF(WLIG)
    Gosub CALC_WWUSEQTY
    WTOTUSEQTY = [M:MBM]USEQTY(WLIG) + WWUSEQTY
     Call CONT_SOLDE_MAT([M:MBM]FCY,[M:MBM]ITMREF(WLIG),WTOTUSEQTY,[M:MBM]MFMEXTQTY(WLIG),WRET) From MFGLIBM
     If WRET = 0 : [M:MBM]CLEFLG(WLIG) = 1
     Else        : [M:MBM]CLEFLG(WLIG) = 2
     Endif
Endif

# Issue 85592 - 2012-10-31 by CCC
[M:MBM]OLDQTY(WLIG)=[M:MBM]USEQTY(WLIG)

# Issue 87062 - 2013-01-08 by CCC
#nolign = WLIG
nolign = WLIG+1
Return

###########################################
# 03.05 Si l'on vient du plan de suivi de temps ou plan de production
# proposer la quantité consommée par rapport à la quantité déclarée
# pour le suivi sur OF, on travaille aussi avec le paramètre mode de consommation
# si suivi sur OF : [M:MBM]COEFF contient un pourcentage de réalisation par rapport au prévu
# si suivi sur nomenclature : [M:MBM]COEFF contient directement la quantité réalisée
$REAJUST_WUSEQTY
Local        Decimal WQTY, WQTYN, WQTYNA, WQTYB, WQTYBA
Local        Decimal WBASQTY
Local        Integer WLIKQTYCOD
Local        Decimal WLIKQTY
Local        Integer WQTYRND,WRET
Local        Decimal WSCA
Local        Char    WSTU(GLONUOM)
Case [M:MBM]MATTYP(nolign-1)
    When 1 :
            If LCONSMAT = 2
               If [M:MBM]MFMEXTQTY(nolign-1) * [M:MBM]COEFF <= [M:MBM]RMNEXTQTY(nolign-1)
                   WUSEQTY = [M:MBM]MFMEXTQTY(nolign-1) * [M:MBM]COEFF
               Endif
            Else
               WUSEQTY = [M:MBM]MFMEXTQTY(nolign-1) * [M:MBM]COEFF
            Endif
     When 2 :
          #Contrôle stock et calcul qté
          # lecture cumuls stocks
          Call LECITV2([M:MBM]FCY,[F:BOD]CPNITMREF,WRET) From MFGLIB
          If WRET : WUSEQTY = 0 : Return : Endif
          If [F:BOD]LIKQTY <> 0
              # calcul quantité
              WQTY         = [M:MBM]COEFF
              WSTU         = [M:MBM]STU(nolign-1)
              WBASQTY      = [F:BOH]BASQTY
              WLIKQTYCOD   = [F:BOD]LIKQTYCOD
              WLIKQTY      = [F:BOD]LIKQTY
              WQTYRND      = [F:BOD]QTYRND
              WSCA         = [F:BOD]SCA
              Call LIKQTY(WQTY,WSTU,WBASQTY,WLIKQTYCOD,WLIKQTY,WQTYRND,
&               WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
              WUSEQTY = WQTYBA
          Else
              WUSEQTY = 0
          Endif
Endcase
Call QTEARR(WUSEQTY,[M:MBM]STU(nolign-1)) From TRTDIV
Return

###########################################
# 10.02 demande 16200 tri en mineur sur BOMSEQ
$AFF_TABLEAU
Case [M:MBM]WSRT
     When 33  : Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]RETDAT(indice),
&                                                        [M:MBM]ITMREF(indice),[M:MBM]BOMSEQ(indice)
     When 65  : Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]RETDAT(indice),
&                                                        [M:MBM]MFGNUM(indice),[M:MBM]BOMSEQ(indice)
     When 129 : Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]RETDAT(indice),
&                                                        [M:MBM]BOMNUM(indice),[M:MBM]BOMSEQ(indice)
     When 18  : Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]ITMREF(indice),
&                                                        [M:MBM]RETDAT(indice),[M:MBM]BOMSEQ(indice)
     When 66  : Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]ITMREF(indice),
&                                                        [M:MBM]MFGNUM(indice),[M:MBM]BOMSEQ(indice)
     When 130 : Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]ITMREF(indice),
&                                                        [M:MBM]BOMNUM(indice),[M:MBM]BOMSEQ(indice)
     When  20 : Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]MFGNUM(indice),
&                                                        [M:MBM]RETDAT(indice),[M:MBM]BOMSEQ(indice)
     When  36 : Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]MFGNUM(indice),
&                                                        [M:MBM]ITMREF(indice),[M:MBM]BOMSEQ(indice)
     When 132 : Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]MFGNUM(indice),
&                                                        [M:MBM]BOMNUM(indice),[M:MBM]BOMSEQ(indice)
     When  24 : Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]BOMNUM(indice),
&                                                        [M:MBM]RETDAT(indice),[M:MBM]BOMSEQ(indice)
     When  40 : Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]BOMNUM(indice),
&                                                        [M:MBM]ITMREF(indice),[M:MBM]BOMSEQ(indice)
     When  72 : Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]BOMNUM(indice),
&                                                        [M:MBM]MFGNUM(indice),[M:MBM]BOMSEQ(indice)
Endcase
Affzo [M:MBM]15
Return

######################################################################
$VALIDATION
# Issue 73286 - GA 01/2012
GPE=0 : GPOINT = "BEFVALID" : Gosub  ENTREE From EXEFNC
If GPE <> 0 : Return : Endif

Gosub CRE_SUIVI
If VALOK <> 2 : Return : Endif

If LORI <> "PILOT"
   Call FERME_TRACE From LECFIC
   If TRA = 1
      GPE = 1
      # demande 15682 ne pas afficher la trace
      # Mettre GPE = 0 pour inhiber l'action standard
      GPOINT = "AFFTRA"
      Gosub  ENTREE From EXEFNC
      If GPE <> 0
         Call LEC_TRACE From LECFIC
     Endif
   Endif
   TRA = 0
Endif

# GH 02/2016 bug 108954 don't lose entries if the validation didn't totally succeed
#Call RAZSTOSORW From STKSOR
#Effzo [MBM]15
#GMFMLIN = 1
J=0
For I=0 To [M:MBM]NBLIG-1
  If WMTKNUM(I)="" & ([M:MBM]USEQTY(I) <> 0 | [M:MBM]CLEFLG(I) <> [M:MBM]WCLEFLG(I))
     J=1 : Break
  Endif
Next
If !J
   # all what should be validated was => clear the grid
   Call RAZSTOSORW From STKSOR
   Effzo [MBM]15
   [M:MBM]NBLIG=0
   GMFMLIN = 1
Else
   # all what should be validated was not => remove validated lines of the grid to make a new try of validation
   I=0
   While I<[M:MBM]NBLIG
     If WMTKNUM(I)<>""
        Dela I, 1 [M:MBM]NBLIG : [M:MBM]NBLIG-=1 : I-=1
     Endif
     I+=1
   Wend
   Affzo [MBM]15
Endif
Return

######################################################################
$CRE_SUIVI
Local Integer WFICFLG
Local Integer I,OK,WOK, WLIN, WMATCLENBR, WNBMAT, STAT, LRET, WRETOUR, WRET, WNOLIGN
Local Date    WDAT
Local Char    WMFGNUM(GLONVCR),WWMFGNUM(GLONVCR),WMFGTRKNUM(GLONVCR),TIT(80)
Local Char    WNUMTEX (12)
Local Decimal WWQTY, WALLQTY,WSHTQTY,WWALLQTY,WWSHTQTY
Local Char    WMTKNUMSTR(GLONVCR), WMTKNUMEND(GLONVCR)
Local Char    WMTKNUM(GLONVCR)(max(1,[M:MBM]NBLIG))
Local Integer WCRETRK, WNEW
Local Integer WMFGMKM                                         # GH 17/09/2015 bug 110557

Raz WMTKNUMSTR, WMTKNUMEND
Raz WMTKNUM

#
# en mode VT tout est ok et pas de message
If !GVTMOD
    VALOK = 1

    WOK = 0
    Call CTLSTOSOR("MBM","USEQTY",[M:MBM]NBLIG,WOK) From STKECR
    If WOK = 1 : Return : Endif

    WOK = 0
    # 05.05 demande 30321
    # 03.06 Si il n'y a pas de quantite alors c'est ok
    For I = 0 To [M:MBM]NBLIG-1
        If [F:BTS]STOCODMAN = 2 & [M:MBM]STOCODL(I) = 1 & [M:MBM]WSTODET(I) <> 2 & [M:MBM]USEQTY(I) <> 0
           Call ERREUR(mess(217,190,1)-num$([M:MBM]ITMREF(I))) From GESECRAN
           WOK = 1
           Break
        Endif
    Next
    If WOK = 1 : Return : Endif

    #1ere chose y a-t-il quelque chose à suivre ?
    If [M:MBM]NBLIG = 0 : Return : Endif
    WOK = 0
    For I = 0 To [M:MBM]NBLIG-1
        If [M:MBM]USEQTY(I) <> 0 | [M:MBM]CLEFLG(I) <> [M:MBM]WCLEFLG(I)
            WOK = 1
            Break
        Endif
    Next I
    If WOK = 0 : Call ERREUR(mess(219,193,1)) From GESECRAN : Return : Endif
    #
    #Un petit message de confirmation...
    Call OUINON(mess(20,196,1),VALOK) From GESECRAN
    If VALOK <> 2 : Return : Endif
#
Else
    VALOK = 2
Endif

# FQ 73634 GA 05/2011 ctrl déplacé après la Question ...
# CCC (2010-04-28) Bug 54558 : Vérifier que l'OF n'est pas en cours de modif
For I=0 To [M:MBM]NBLIG-1
    #If func MFGLIB.CHKMFGLOCK([M:MBM]MFGNUM(I),0) : # GH 21/02/2014 bug 94986
    If ([M:MBM]USEQTY(I) <> 0 | [M:MBM]CLEFLG(I) <> [M:MBM]WCLEFLG(I))
&      & !sigma(0,I-1,[M:MBM]MFGNUM(indcum)=[M:MBM]MFGNUM(I)
&                     & ([M:MBM]USEQTY(indcum) <> 0 | [M:MBM]CLEFLG(indcum) <> [M:MBM]WCLEFLG(indcum)))
&      & func MFGLIB.CHKMFGLOCK([M:MBM]MFGNUM(I),0)
        Call ERREUR([M:MBM]MFGNUM(I)-":"-mess(280,193,1)) From GESECRAN
        VALOK=1 : Break
    Endif
Next
If VALOK = 1 : Return : Endif

#On y va ...

If LORI <> "PILOT"
    TIT = mess(229,195,1)
    TRA=0
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

#
# Issue 101365 - 2014-09-30 by CCC : WCRETRK%1 => no standard sorting ; WCRETRK%2 => use next entry point
Raz WCRETRK
GPOINT="MBMTRKCRE"
Gosub ENTREE From EXEFNC
If mod(WCRETRK,2)=0
    Sorta [M:MBM]NBLIG [M:MBM]NBLIG Order By [M:MBM]IPTDAT(indice),
&                                            [M:MBM]MATTYP(indice),
&                                            [M:MBM]MFGNUM(indice),
&                                            [M:MBM]CLEFLG(indice)  # Issue 79080 - 2012-02-02 by CCC : Ajout de CLEFLG dans le tri
Endif

#Récupération du compteur
Call LECTCA(8,OK) From SUBTCA
If OK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
GMANCOU    = [F:TCA]MANCOU(2)
#
Raz [L]WLIN

For nolign = 1 To [M:MBM]NBLIG
  If [M:MBM]USEQTY(nolign-1) <> 0 | [M:MBM]CLEFLG(nolign-1) <> [M:MBM]WCLEFLG(nolign-1)
    If [M:MBM]WEXCMAT(nolign-1) <> 2
        # Issue 101365 - 2014-09-30 by CCC : WNEW=1 to create a new tracking number
        Raz WNEW
        If mod(WCRETRK,4)>=2
            GPOINT="MBMTRKLIN"
            Gosub ENTREE From EXEFNC
        Endif

        If WLIN = 0
            WNEW = 1
        Elsif [M:MBM]IPTDAT(nolign-1) <> WDAT
            WNEW = 1
        Endif

        If WNEW=1
            If WNBMAT<>0 : # GH 17/09/2015 bug 110557 if WLIN<>0
                If WWMFGNUM <> ""
                   Gosub MAJ_ENTOF
                   Raz WWMFGNUM
                Endif
                Gosub CRE_ENTETE
                If GOK<1 : Break : Endif
            Elsif adxlog : Rollback # GH 17/09/2015 bug 110557
            Endif
            WDAT     = [M:MBM]IPTDAT(nolign-1)
            If [M:MBM]MATTYP(nolign-1) = 1 : WMFGNUM  = [M:MBM]MFGNUM(nolign-1)
                                             WWMFGNUM = [M:MBM]MFGNUM(nolign-1)
            Endif
            Call DEBTRANS From GLOCK
            Trbegin [MKM]
            Call NUMERO(GCODNUM,[M:MBM]FCY,WDAT,"",WMFGTRKNUM,STAT) From SUBANM
            If STAT
               Call ERREUR(mess(60,199,1)-GCODNUM-num$([L]STAT)) From GESECRAN
               GOK = 0
               Break
            Endif
            WMTKNUM(nolign-1) = WMFGTRKNUM
        Else
            If [M:MBM]MFGNUM(nolign-1) <> WMFGNUM : Raz WMFGNUM : Endif
            If [M:MBM]MFGNUM(nolign-1) <> WWMFGNUM & WWMFGNUM <> ""
               Gosub MAJ_ENTOF
               Raz WWMFGNUM
               If GOK<1 : Break : Endif
               If [M:MBM]MATTYP(nolign-1) = 1 : WWMFGNUM = [M:MBM]MFGNUM(nolign-1) : Endif
            Endif
        Endif
    Endif
    Raz [M:MTMK]
    [M:MTMK]           = [M:MBM]
    [M:MTMK]MFGFCY     = [M:MBM]FCY
    [M:MTMK]MFGTRKNUM  = WMFGTRKNUM
    [M:MTMK]MATTRKLIN  = [M:MBM]WLINUM(nolign-1)
    [M:MTMK]WMATCLENBR = WMATCLENBR
    [M:MTMK]ENTCOD     = [F:BTS]ENTCODS
    [M:MTMK]TRSFAM     = [F:BTS]TRSFAMS

    # 06.02
    Case [M:MBM]MATTYP(nolign-1)
     When 1 :
     #Lecture matière OF
        WNOLIGN = nolign
        If [M:MBM]MFMITMREF(nolign-1) <> ""
           Read [F:MFM]MFM0 = [M:MBM]MFGNUM(nolign-1);[M:MBM]MFGLIN(nolign-1);[M:MBM]BOMSEQ(nolign-1);
&                                     [M:MBM]ITMREF(nolign-1)
            If fstat : GOK = 0
               Call RSTA("MFM",[M:MBM]MFGNUM(nolign1)+num$([M:MBM]MFGLIN(nolign-1))) From GLOCK
               Break
            Endif
            [M:MTMK]TYPTRT = 4
        Else
            [M:MTMK]TYPTRT = 12
        Endif
        Call CRE_MKM("",0) From MTKAUTLIB
        If GOK < 1 : TRA = 1 : Break : Endif
        nolign = WNOLIGN
        If [M:MBM]WEXCMAT(nolign-1) <> 2
            [L]WLIN   += 1
            WMATCLENBR = [M:MTMK]WMATCLENBR
            WNBMAT  += [M:MTMK]WNBMAT : # WNBMAT += 1 # GH 17/09/2015 bug 110557
            WMFGMKM += [M:MTMK]WNBMAT : # GH 17/09/2015 bug 110557
        Endif
     When 2 :
         WNOLIGN = nolign
    #Lecture de l'article de nomenclature
        If [M:MBM]MFMITMREF(nolign-1) <> ""
           Read [F:BOD]BOD0 = [M:MBM]TRUBOMNUM(nolign-1);[M:MBM]BOMALT(nolign-1);[M:MBM]BOMSEQ(nolign-1);
&                                     [M:MBM]ITMREF(nolign-1);2
            If fstat : GOK = 0 : Call RSTA("BOD",[M:MBM]BOMNUM(nolign1)+num$([M:MBM]BOMALT(nolign-1))) From GLOCK : Break : Endif
            [M:MTMK]TYPTRT = 8
        Else
            [M:MTMK]TYPTRT = 13
        Endif
        Call CRE_MKM([M:MTMK]BOMNUM,0) From MTKAUTLIB
        If GOK < 1 : TRA = 1 : Break : Endif
        nolign = WNOLIGN
        [L]WLIN   += 1
        WMATCLENBR = [M:MTMK]WMATCLENBR
        WNBMAT += [M:MTMK]WNBMAT : # WNBMAT += 1 # GH 17/09/2015 bug 110557
    Endcase
  Endif
Next
If GOK>0 & WWMFGNUM <> "" : Gosub MAJ_ENTOF  : Endif
If GOK < 1
   If adxlog : Gosub AB_TR : Endif
Else
   If WNBMAT <> 0 : Gosub CRE_ENTETE
   Elsif adxlog : Rollback # GH 17/09/2015 bug 110557
   Endif
Endif

If GOK < 1
   # GH 02/2016 bug 108954  cancel the tracking number set on the associated lines
   If WMFGTRKNUM<>""
      Look [MTK]MTK0 = WMFGTRKNUM
      If fstat
        For I=0 To [M:MBM]NBLIG-1
            If WMTKNUM(I) = WMFGTRKNUM : WMTKNUM(I)="" : Endif
        Next I
      Endif
   Endif
   Return
Endif

# 11.02 demande 16662 point d'entrée permettant d'effectuer un traitement supplémentaire
# en fin de plan, exemple, lancer une impression
GPOINT = "CUSTRTSUP" : Gosub  ENTREE From EXEFNC
Return

############################################

$MAJ_ENTOF
If WMFGMKM<>0  : # GH 17/09/2015 bug 110557 test WMFGMKM
    #Maj entête d'OF
    Readlock [F:MFG]MFG0 = WWMFGNUM
    If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$(WWMFGNUM) : Return
    Elsif fstat GOK=0  : Call RSTA("MFG",num$(WWMFGNUM)) From GLOCK : Return
    Endif
    [F:MFG]MATCLENBR += WMATCLENBR
    If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&      [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&      [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
       [F:MFG]MFGTRKFLG = 5
        # CCC (10/01/08) DM 44021
    #   [F:MFG]TRKLAST   = WDAT
    Else
       [F:MFG]MFGTRKFLG = 4
        # CCC (10/01/08) DM 44021
    #   Raz [F:MFG]TRKLAST
    Endif
    # CCC (10/01/08) DM 44021
    If [F:MFG]TRKLAST<WDAT
       [F:MFG]TRKLAST   = WDAT
    Endif
    If [F:MFG]TRKLASTC<date$
       [F:MFG]TRKLASTC  = date$
    Endif
    If [F:MFG]TRKFIRST>WDAT | [F:MFG]TRKFIRST = "00/00/00"
        [F:MFG]TRKFIRST = WDAT
    Endif
    If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
        [F:MFG]TRKFIRSTC = date$
    Endif
    Rewrite [F:MFG]
    If fstat
       GOK = 0 : Call FSTA("MFG") From GLOCK : Return
    Endif
    #----- MISE à jour statistiques entête OF -----#
    Call VALSTA("MFG",1) From SUBPS2
    If GOK < 1 : Return : Endif
Endif

Raz WMATCLENBR, WMFGMKM : # GH 17/09/2015 bug 110557 raz WMFGMKM
Return

############################################################
#Création entête de suivi
$CRE_ENTETE
If GOK = 1
    Raz [F:MTK]
    If WMFGNUM <> ""
       Read [F:MFG] = WMFGNUM
       If !fstat : [F:MTK] = [F:MFG] : Endif
    Endif
    [F:MTK]MFGFCY    = [M:MBM]FCY
    [F:MTK]TRSCODS   = [M:MTMK]TRSCODS
    [F:MTK]MFGTRKNUM = WMFGTRKNUM
    [F:MTK]MFGTRKDAT = WDAT
    [F:MTK]CREDAT    = date$
    [F:MTK]CREUSR    = GUSER
    [F:MTK]EXPNUM    = [C]EXPORT
    Raz [F:MTK]UPDUSR
    Raz [F:MTK]UPDDAT
    [F:MTK]OPETRKFLG = 1
    [F:MTK]ITMTRKFLG = 1
    [F:MTK]MATTRKFLG = 2
    [F:MTK]NBRMAT    = WNBMAT
    # Issue 74667 - 2011-07-12 by CCC
    If [F:MFG]MFGTEX <> ""
       [F:MTK]MTKTEX = [F:MFG]MFGTEX
       If left$([F:MTK]MTKTEX,3)="MFG"
          Call DUP_CLOB("MTK",[F:MTK]MTKTEX,GOK) From TRTX3TEX
       Endif
    Endif
    #point d'entrée  pour mise à jour de tables spécifiques liées à [MTK] sr 01.02 demande 12361
    GPOINT = "BENMTKMAJ" : Gosub ENTREE From EXEFNC
    #
    Write [F:MTK]
    If fstat : GOK = 0 : Call FSTA("MTK") From GLOCK : Endif
Endif
If GOK < 1
   Gosub AB_TR
Else
   Commit
   LRETOK = 2
   TRA = 1
   Call ECR_TRACE(mess(79,190,1)-[F:MTK]MFGTRKNUM,0) From GESECRAN

   If WMTKNUMSTR = ""       # llc étiquettes 9727
       WMTKNUMSTR = [F:MTK]MFGTRKNUM
       WMTKNUMEND = [F:MTK]MFGTRKNUM
       # Les n° de documents ne sont pas nécessairement créés de façon croissante
   Elsif WMTKNUMEND < [F:MTK]MFGTRKNUM
       WMTKNUMEND = [F:MTK]MFGTRKNUM
   Elsif WMTKNUMSTR > [F:MTK]MFGTRKNUM
       WMTKNUMSTR = [F:MTK]MFGTRKNUM
   Endif

   Raz WMFGTRKNUM
Endif

Raz WNBMAT, WLIN, WMFGNUM
Return

$AB_TR
Rollback
LRETOK=0
If GOK<0 & GLOCK<>"" :  # GH 02/2016 bug 108954 put an error in the log in case of lock
   Call ECR_LOCK("") From GLOCK : GLOCK=""
   TRA=1
Endif
If !GVTMOD
   Call ECR_TRACE("",0) From GESECRAN
   Call ECR_TRACE(mess(254,193,1)+"\"+mess(255,193,1),1) From GESECRAN
   TRA=1
Endif
Return

########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Local Integer WRET
Call DELSTOSORW(-1,0,"MBM",[M:MBM]FCY,WRET) From STKSOR
Effzo [M:MBM]15
If VALEUR <> GFCY : GFCY = VALEUR : Gosub CHARG_PARAM : Endif
[M]FCY = VALEUR
If dim([M:MBM]WRHE)>0
    Call WRHINIT([M:MBM]WRHE,VALEUR,8) From STKWRH
    Affzo [M:MBM]WRHE
Endif
Gosub WRH_ETAT
# Issue 73720 - 2011-05-18 by CCC
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL
End

########################################
Subprog AM_ENDDATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M:MBM]ENDDATEND = VALEUR : Affzo [M:MBM]ENDDATEND : Endif
End

########################################
Subprog C_ENDDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:MBM]ENDDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog C_NBLIG
Local Integer NOL, WRET
# pour bug moteur
If [M:MBM]NBLIG > 0
  If [M:MBM]ITMREF([M:MBM]NBLIG-1) = ""
    status=65 : nolign=[M:MBM]NBLIG
    Dela [M:MBM]NBLIG-1,1,[M:MBM]NBLIG-1 [M:MBM]NBLIG : [M:MBM]NBLIG-=1
  Endif
Endif
GMODIF = 2
NOL = nolign-1
#En ajout de ligne récupération d'un numéro unique
If status=73 | status=82
    If dim([M:MBM]MATTYP)<[M:MBM]NBLIG+2
          GMESSAGE=mess(122,199,1)
          mkstat=2
    Endif
# llc 03.04 21745
#    [M:MBM]WLINUM(NOL) = GMFMLIN
#    GMFMLIN += 1
Elsif status =  65
   NOL=nolign-1
   Call DELSTOSORW(NOL,NOL,"MBM",[M:MBM]FCY,WRET) From STKSOR
   If WRET<>0 mkstat=2 : End Endif
Elsif  status = 68 | status = 83
   Call DELSTOSORW(nolign-1,nolign1-1,"MBM",[M:MBM]FCY,WRET) From STKSOR
   If WRET<>0 mkstat=2 : End Endif
Elsif status = 75
     #si la matière a été suivie en manuel on ne peut plus intervenir sur la ligne tableau
   If [M:MBM]FICFLG(nolign-1)  = 1 : GMESSAGE = mess(33,190,1)
      mkstat = 1
      GMODIF = 1
      End
   Endif
Endif

End


########################################
Subprog C_IPTDAT(VALEUR)
Variable Date    VALEUR
#On ne peut pas saisir une date > date du jour
If VALEUR > date$ : GMESSAGE = mess(129,194,1) : mkstat = 1 : End : Endif
End

########################################
Subprog AS_MFGNUM(VALEUR)
Variable Char    VALEUR()
# FQ 61131 GA 01/2010 pas de maj de MFGNUM si l'article lancé a déjà été choisi
If [M:MBM]MFGNUM(nolign-1)<>"" & [M:MBM]BOMNUM(nolign-1)<>""
   mkstat=2
Endif

End

########################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
Read [F:MFG]MFG0 = VALEUR
If fstat : GMESSAGE = mess(23,100,1)
    mkstat = 1
    End
Endif
If [F:MFG]MFGFCY <> [M:MBM]FCY
    GMESSAGE = mess(23,100,1)
    mkstat = 1
    End
Endif
#L'OF doit être complet
If [F:MFG]TYPMOD = 1    : GMESSAGE = mess(51,190,1) : mkstat = 1 : End : Endif
#L'OF doit être ferme
If [F:MFG]MFGSTA <> 1   : GMESSAGE = mess(19,190,1) : mkstat = 1 : End : Endif
#L'OF ne doit pas être suspendu
If [F:MFG]SUSFLG = 2    : GMESSAGE = mess(180,190,1) : mkstat = 1 : End : Endif
#Selon paramètre général l'OF doit être alloué complètement
If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
     GMESSAGE = mess(18,190,1)
     mkstat = 1
     End
Endif
#Selon paramètre général, l'OF doit être édité
If  [F:MFG]MFGTRKFLG < 3 & GDOSFAB = 2 : GMESSAGE = mess(20,190,1) : mkstat = 1 : End : Endif
mkstat = 0
# boucle d'analyse des matières bloquantes si rupture
For [MFM]MFM0 Where MFGNUM = [F:MFG]MFGNUM                    # 10.02 Performances
    If [F:MFM]SHTQTY <> 0
       Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
       If !fstat & [F:ITF]MFGSHTCOD = 1
          GMESSAGE = mess(105,193,1)+" ("+[F:MFM]ITMREF+")"
          mkstat = 1
          Break
       Endif
    Endif
Next
If mkstat = 1 : End : Endif
End

########################################
Subprog AM_MFGNUM(VALEUR)
Variable Char    VALEUR()
Read [F:MFG]MFG0 = VALEUR
If fstat : Raz [F:MFG] : Endif
If [F:MFG]ITMLINNBR = 1
    Filter [F:MFI] Where MFGNUM = VALEUR
    Read [F:MFI]MFI0 First
    If !fstat
        [M:MBM]BOMNUM(nolign-1) = [F:MFI]ITMREF
        [M:MBM]BOMALT(nolign-1) = [F:MFI]BOMALT
        [M:MBM]MFGLIN(nolign-1) = [F:MFI]MFGLIN
    Endif
    Filter [F:MFI]
Endif
End

########################################
Subprog S_MFGNUM(VALEUR)
Variable Char    VALEUR()
# 08.01 demande 10215 mauvais contrôle sur MFGTRKFLG
If GDOSFAB = 2
    Filter [F:MFG] Where MFGFCY = [M:MBM]FCY & MFGSTA = 1 & MFGMOD <> 3 &
&                        TYPMOD =2 & !find(MFGTRKFLG,1,2,6) & SUSFLG <> 2
Else
    Filter [F:MFG] Where MFGFCY = [M:MBM]FCY & MFGSTA = 1 & MFGMOD <> 3 &
&                        TYPMOD = 2 & !find(MFGTRKFLG,2,6) & SUSFLG <> 2
Endif
Call SELECT("MFG","",VALEUR,"") From SELOBJ
Filter [F:MFG]
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
# 107513
#Local Char WFCY(GLONFCY) : WFCY = [M:MBM]FCY
#
#Read [F:ITM]ITM0 = VALEUR
#If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
#[M:MBM]STU(nolign-1) = [F:ITM]STU
#Read [F:ITF]ITF0 = VALEUR;[M:MBM]FCY
#If fstat : GMESSAGE= mess(23,100,1) : mkstat = 1 : End : Endif
Call CONTMATITM(VALEUR, [M:MBM]FCY, "MKM", GERR, GMESSAGE) From MFGLIB
If find(GERR,1,4)
    GERR = 1
    mkstat=2
    End
Endif

#Si article en inventaire on regarde si il y a des emplacements libérés
# 04.02 Problèmes Perf
If [F:ITF]CUNFLG = 2
   Filter [F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF & CUNLOKFLG = 1
&                  Order By Key STO3
   Read [F:STO]STO3 First
   If fstat
      GMESSAGE = mess(185,199,1)
      mkstat = 1
      GMODIF = 1
      Filter [F:STO]
      End
   Else
      GMODIF = 2
   Endif
   Filter [F:STO]
Endif
# 107513
#Call CONTMATITM(WFCY, 1) From MFGLIB
End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

# Issue 116022 - 2016-04-15 by JUSYN : Identifier for calling prog
Local Char     LIDPROG(30): LIDPROG = "AM_ITMREF"
# CCC (2009-09-23) Bug 53236 : Alimentation du n° de ligne si nécessaire au moment de la saisie de l'article
If [M:MBM]WLINUM(nolign-1)=0
    [M:MBM]WLINUM(nolign-1) = GMFMLIN
    GMFMLIN += 1
Endif


# Issue 81693 - 2012-05-15 by CCC
# Issue 115975 - 2016-04-14 by BEEBE : only when ITMREF hasn´t changed when creating an unexpected material tracking
If ([M:MBM]OLDQTY(nolign-1)=0 & [M:MBM]ALLSTA(nolign-1)>3 & [M:MBM]ALLQTY(nolign-1)-func CALC_WWUSEALL(nolign-1)>0) &
&  ([M:MBM]MFMITMREF(nolign-1)=[M:MBM]ITMREF(nolign-1) | [M:MBM]MFMITMREF(nolign-1)="")
    Call ETAZONSOR("MBM") From STKECR
# Issue 84927 - 2012-10-12 by CCC
Else
    If dim([M:MBM]ECCVALMAJ(nolign-1)) > 0
        Raz [M:MBM]ECCVALMAJ(nolign-1)
        Raz [M:MBM]ECCVALMIN(nolign-1)
    Endif
# End issue 115975
    Call INIZONSOR("MBM",VALEUR,[M:MBM]FCY,nolign-1,6,[M:MBM]TRSCODS,"") From STKECR
    # Issue 107513/8 - 2015-07-13 by JUSYN : Parent product when WO versioned then versions not allowed to be changed
    Gosub GREY_ECC
Endif

# Issue 116022 - 2016-04-20 by JUSYN : general grey out when material not versioned
Gosub GREY_ECC_MAT
End

########################################
Subprog AM_USEQTY(VALEUR)
Variable Decimal VALEUR
# sr 10.01 demande 11203
Local Decimal LDIS, WTOTUSEQTY, WWUSEQTY
Local Integer WRET, NOL, STA, I, LRET, WLIG
Local Integer LTYPLOC
Raz WRET
NOL = nolign-1

# CCC (2009-12-07) Bug 60537 : La mise à jour de SOW se fait en fin de ligne
#If VALEUR = 0
#   Call DELSTOSORW(NOL,NOL,"MBM",[M:MBM]FCY,WRET) From STKSOR
#   End
#Endif
If STA <= 1  & [M:MBM]NEGSTO(NOL) <> 2
   Raz LDIS
   Call LECSRU([M:MBM]FCY,[M:MBM]TCLCOD(NOL),6,[M:MBM]TRSCODS,"",LRET) From STKLIB
   If LRET = 1 : LDIS = 0
   Else
      Call LECITV2([M:MBM]FCY,[M:MBM]ITMREF(NOL),LRET) From MFGLIB
      # Issue 76714 - 2011-09-30 by CCC : Si conso matière sur opé de sous-traitance, autoriser conso sur emplacement sous-traitant
      #Call STODISTOT("",0,[F:SRU]AUZSTA,"",LDIS) From STKLIB
      LTYPLOC = 0
      If [M:MBM]CPLWST(NOL) <> ""
        If [F:MWS]WST <> [M:MBM]CPLWST(NOL) | [F:MWS]WCRFCY <> [M:MBM]FCY
             Read [F:MWS]WST0 = [M:MBM]CPLWST(NOL);[M:MBM]FCY
             If fstat : Raz [F:MWS] : Endif
         Endif
         If [F:MWS]WSTTYP = 3
            LTYPLOC = 4
         Endif
      Endif
      Call STODISTOT("",LTYPLOC,[F:SRU]AUZSTA,"",LDIS) From STKLIB

      If [M:MBM]MATTYP(nolign-1) = 1
          For I = 0 To nolign-2
              # Si la même ligne OF est déjà présente dans le tableau il faut diminuer de la quantité consommée de la ligne
              If [M:MBM]ITMREF(I) = [M:MBM]ITMREF(nolign-1) & [M:MBM]BOMSEQ(I) = [M:MBM]BOMSEQ(nolign-1)
&              & [M:MBM]MFGNUM(I) = [M:MBM]MFGNUM(nolign-1) & [M:MBM]MFGLIN(I) = [M:MBM]MFGLIN(nolign-1)
                 LDIS -= [M:MBM]USEQTY(I)
                 LDIS += [M:MBM]ALLQTY(I)
              Endif
          Next I
          LDIS += [M:MBM]MFMALLQTY(nolign-1)
      Endif
      If LDIS < 0 : Raz LDIS : Endif

    Endif
    If VALEUR > LDIS
          Call ERREUR(mess(86,193,1)) From GESECRAN
          Raz GMESSAGE
          mkstat = 1
          End
    Endif
Endif

# CCC (2009-12-07) Bug 60537 : La mise à jour de SOW se fait en fin de ligne
#If [M:MBM]USEQTY(NOL) = 0 & VALEUR <> 0
#    [M:MBM]USEQTY(NOL) = VALEUR
#    WLIG = NOL
#    Gosub TRT_STOCKLIGNE
#Endif

If [M:MBM]MATTYP(NOL) = 1
    # sr 10.01 la qté consommée à utiliser est la somme de ce qui a déjà été
    # consommé et de ce qui va l'être demande 11203
    # sr 04.02 demande 9134
    [M:MBM]USEQTY(NOL) = VALEUR
    Read [F:MFM]MFM0 = [M:MBM]MFGNUM(NOL);[M:MBM]MFGLIN(NOL);[M:MBM]BOMSEQ(NOL);[M:MBM]ITMREF(NOL)
    Gosub CALC_WWUSEQTY
    WTOTUSEQTY = VALEUR + WWUSEQTY
    Call CONT_SOLDE_MAT([M:MBM]FCY,[M:MBM]ITMREF(NOL),WTOTUSEQTY,[M:MBM]MFMEXTQTY(NOL),WRET) From MFGLIBM
    If WRET = 0 : [M:MBM]CLEFLG(NOL) = 1
    Else        : [M:MBM]CLEFLG(NOL) = 2
    Endif
    Affzo [M:MBM]CLEFLG(NOL)
Endif
End


########################################
Subprog C_OPENUM(VALEUR)
Variable Decimal VALEUR
Local Integer I, WCUNFLG
Case [M:MBM]MATTYP(nolign-1)
    When 1 :
        If VALEUR <> 0
           Filter [F:MFO] Where MFGNUM = [M:MBM]MFGNUM(nolign-1)  & OPENUM = VALEUR
           Read [F:MFO]MFO0 First
           If fstat :  Raz [F:MFO] : Endif
           Filter [F:MFO]
        Endif
        # Issue 110979/1 - 2016-04-07 by ALSHE : When changing OPENUM, BOMSEQ must be reset (Problem when reading twice)
        If [M:MBM]OPENUM(nolign-1) <> VALEUR
           [M:MBM]BOMSEQ(nolign-1) = 0
        Endif
        If [M:MBM]BOMSEQ(nolign-1) = 0
           Filter [F:MFM] Where MFGNUM = [M:MBM]MFGNUM(nolign-1) & ITMREF = [M:MBM]ITMREF(nolign-1) &
&                               BOMOPE = VALEUR
           Read [F:MFM]MFM3 First                        # 10.02 Performances
        Else
           Read [F:MFM]MFM0 = [M:MBM]MFGNUM(nolign-1);[M:MBM]MFGLIN(nolign-1);[M:MBM]BOMSEQ(nolign-1);[M:MBM]ITMREF(nolign-1)
        Endif
        If !fstat
           If [F:MFM]MATSTA = 4 : GMESSAGE = mess(83,193,1) : Filter [F:MFM] : End : Endif
           If [F:ITF]CUNFLG = 2 & [F:MFM]ALLSTA > 3
              Gosub REC_LOC From SUBMTKB
              If WCUNFLG = 2 : GMESSAGE = mess(185,199,1) : mkstat = 1 : End : Endif
           Endif
        Endif
        If fstat : Raz [F:MFM]
                   [M:MBM]MFMITMREF(nolign-1) = ""
        Else     : [M:MBM]MFMITMREF(nolign-1) = [F:MFM]ITMREF
        Endif
        # Issue 110979/1 - 2016-04-07 by ALSHE : BOMSEQ must be refreshed
        [M:MBM]BOMSEQ(nolign-1) = [F:MFM]BOMSEQ
        Affzo [M:MBM]BOMSEQ
        Filter [F:MFM]
    When 2 :
        If [M:MBM]BOMSEQ(nolign-1) = 0
            Filter [F:BOD] Where ITMREF = [M:MBM]BOMNUM(nolign-1) & BOMALT = [M:MBM]BOMALT(nolign-1) &
&                                CPNITMREF = [M:MBM]ITMREF(nolign-1) & CPNOPE = VALEUR & BOMALTTYP = 2
            # 11.02 Performances 2
            Read [F:BOD]BOD1 First
        Else
            Read [F:BOD]BOD0 = [M:MBM]BOMNUM(nolign-1);[M:MBM]BOMALT(nolign-1);[M:MBM]BOMSEQ(nolign-1);[M:MBM]ITMREF(nolign-1);2
        Endif
        If fstat : Raz [F:BOD]
                   [M:MBM]MFMITMREF(nolign-1) = ""
        Else     : [M:MBM]MFMITMREF(nolign-1) = [F:BOD]CPNITMREF
        Endif
        Filter [F:BOD]
Endcase
End

########################################
Subprog AP_OPENUM(VALEUR)
Variable Decimal VALEUR
# 05.07 Demande 41218
Local    Integer OK,J
Local Char    WCCE(15)
Local Integer WGMFMLIN
# 11.06 demande38605
Local Integer WLIG
# Issue 116022 - 2016-04-20 by JUSYN : Date field for BOM; Working flag
Local Date WDAT : WDAT = date$
Local Integer WFLG : WFLG = 0

# est-ce une nouvelle ligne ou modif d'une ligne existante ?
#Si ce n'est pas une nouvelle ligne (WGMFMLIN <> 0) il faut garder le même numéro et ne pas incrémenter GMFMLIN et NBLIG
If [M:MBM]WLINUM(nolign-1) <> 0
    WGMFMLIN = GMFMLIN
     GMFMLIN = [M:MBM]WLINUM(nolign-1)
Else
    Raz WGMFMLIN
Endif

# Issue 116022 - 2016-04-20 by JUSYN : Additional check when track unexpected material for a BOM
If [M:MBM]MATTYP(nolign-1) = 2
    If clalev ([F:BODC])=0  : Local File BOMD [BODC] : Endif

    Filter [BODC] Where [F:BODC]ITMREF = [M:MBM]BOMNUM(nolign-1) & [F:BODC]BOMALT = [M:MBM]BOMALT(nolign-1) & [F:BODC]BOMALTTYP = 2 &
&                   ([F:BODC]BOMSTRDAT = [0/0/0] | ([F:BODC]BOMSTRDAT <> [0/0/0] & [F:BODC]BOMSTRDAT <= WDAT)) &
&                   ([F:BODC]BOMENDDAT = [0/0/0] | ([F:BODC]BOMENDDAT <> [0/0/0] & [F:BODC]BOMENDDAT >= WDAT)) &
&                    [F:BODC]CPNTYP <> 6

    WFLG = 0
    For [BODC]
        If [F:BODC]CPNITMREF = [M:MBM]ITMREF(nolign-1)
            WFLG = 1
            Break
        Endif
    Next
    Filter [BODC]
Endif

If [M:MBM]MATTYP(nolign-1) = 1    # WO
    If [M:MBM]MFMITMREF(nolign-1) = ""
        # Issue 110979/1 - 2016-03-24 by ALSHE : Warning message when released product is versioned
        If [F:MFI]MFGNUM<>[M:MBM]MFGNUM
            Read [F:MFI]MFI0(1) = [M:MBM]MFGNUM
            [G:MFI]currlen=0
        Endif
        If [F:MFI]ECCVALMAJ <> ""
            OK=1
            Call AVERTIR(mess(347,193,1),OK) From GESECRAN
            If OK = 1 : mkstat = 1 : End : Endif # Cancel
        Else
            OK = 1
            Call AVERTIR(mess(117,190,1),OK) From GESECRAN
            If OK = 1 : mkstat = 1 : End  : Endif # Cancel
        Endif
    Endif
Elsif [M:MBM]MATTYP(nolign-1) = 2    # BOM
   # Issue 116022 - 2016-04-21 by JUSYN : Message to inform about unexpected componants. For versioned product and for unversioned product separated.
   If WFLG = 0
        If func ECCLIB.NBRCPN([M:MBM]BOMNUM(nolign-1)) > 0
            OK=1
            Call AVERTIR(mess(347,193,1),OK) From GESECRAN
            If OK = 1 : mkstat = 1 : End : Endif # Cancel
        Else
            OK = 1
            Call AVERTIR(mess(117,190,1),OK) From GESECRAN
            If OK = 1 : mkstat = 1 : End  : Endif # Cancel
        Endif
    Endif
Endif

# 04.02 demande 9134
[M:MBM]OPENUM(nolign-1) = VALEUR

Read [F:ITM]ITM0 = [M:MBM]ITMREF(nolign-1)
If !fstat
   #[M:MBM]ITMDES1(nolign-1)    = [F:ITM]ITMDES1
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MBM]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
   [M:MBM]STOMGTCOD(nolign-1)  = [F:ITM]STOMGTCOD
   [M:MBM]NEGSTO(nolign-1)     = [F:ITM]NEGSTO
   [M:MBM]TCLCOD(nolign-1)     = [F:ITM]TCLCOD
Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITM]STOMGTCOD > 1
   If [F:ITF]STOFCY <>[M:MBM]FCY| [F:ITF]ITMREF <> [M:MBM]ITMREF(nolign-1)
      Read [ITF]ITF0 = [M:MBM]ITMREF(nolign-1);[M:MBM]FCY
      If !fstat
         [M:MBM]STOMGTCOD(nolign-1)  = [F:ITF]STOMGTCOD
      Endif
   Endif
Endif


#chargement du tableau
Case [M:MBM]MATTYP(nolign-1)
    When 1 : If [M:MBM]MFMITMREF(nolign-1) <> ""
                If [F:MFI]MFGNUM <> [F:MFM]MFGNUM | [F:MFI]MFGLIN <> [F:MFM]MFGLIN
                   If [F:MFM]MFGLIN <> 0
                        Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
                        If fstat : Raz [F:MFI] : Endif
                   Else
                      Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
                      Read [F:MFI]MFI0 First
                      If fstat : Raz [F:MFI] : Endif
                      Filter [F:MFI]
                   Endif
                Endif
                Gosub CHARG_MFM
                # 11.06 demande38605
                If [M:MBM]USEQTY(nolign-1) <> 0
                    WLIG = nolign-1
                    Gosub TRT_STOCKLIGNE
                    If !GIMPORT : Affzo [M:MBM]USEQTY(nolign-1) : Endif
                Endif
             Else
                [M:MBM]WLINUM(nolign-1) = GMFMLIN
                # 05.07 Demande 41218
                #Chargement des section ana
                For J = 1 To GOPTCANA
                      # Issue 76083 - 2011-09-22 by CCC
                      #Call INISEC(WCCE,"MKMB",num$(J)) From SUBCDE
                      Call INISEC(WCCE,"MKMB",J) From TRTX3CPT
                      Assign "[M:MBM]CCE"+num$(J)+"(nolign-1)" With WCCE
                Next
             Endif
    When 2 : If [M:MBM]MFMITMREF(nolign-1) <> "" : Local Char LITM
                                                   LITM = [F:BOD]ITMREF
                                                   Gosub CHARG_BOD
              Else
                [M:MBM]WLINUM(nolign-1) = GMFMLIN
                # 05.07 Demande 41218
                #Chargement des section ana
                For J = 1 To GOPTCANA
                      # Issue 76083 - 2011-09-22 by CCC
                      #Call INISEC(WCCE,"MKMB",num$(J)) From SUBCDE
                      Call INISEC(WCCE,"MKMB",J) From TRTX3CPT
                      Assign "[M:MBM]CCE"+num$(J)+"(nolign-1)" With WCCE
                Next
             Endif
Endcase
If WGMFMLIN = 0
    GMFMLIN += 1
    [M:MBM]NBLIG += 1
Else
    GMFMLIN = WGMFMLIN
Endif

# Issue 81693 - 2012-05-15 by CCC
If [M:MBM]OLDQTY(nolign-1)=0 & [M:MBM]ALLSTA(nolign-1)>3 & [M:MBM]ALLQTY(nolign-1)-func CALC_WWUSEALL(nolign-1)>0
    Call ETAZONSOR("MBM") From STKECR
Endif
End

########################################
Subprog C_BOMNUM(VALEUR)
Variable Char    VALEUR()
# Issue 116022 - 2016-04-15 by JUSYN : Former enhancement needs to be revised
# Issue 107513/8 - 2015-08-26 by JUSYN : BOM that relates to a versioned product is not allowed to be tracked
#If func ECCLIB.NBRCPN(VALEUR) > 0
#    If [M:MBM]MATTYP(nolign-1) = 2
#        # Product versioned
