Local Integer NOL : NOL = nolign-1
Raz [M:MBM]MFGNUM(NOL),[M:MBM]BOMNUM(NOL),[M:MBM]BOMALT(NOL),[M:MBM]ITMREF(NOL),[M:MBM]OPENUM(NOL),
&   [M:MBM]STU(NOL),[M:MBM]USEQTY(NOL),[M:MBM]CPLWST(NOL),[M:MBM]WINDIC(NOL),[M:MBM]CLEFLG(NOL),
&   [M:MBM]MFMITMREF(NOL)
End

