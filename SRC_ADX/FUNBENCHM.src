######################################################################################
$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE : Return : Endif
Call INIT_CCE(VALEUR,AXE,"MKMB","",0) From TRTX3CPT
Return


$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
# Issue 72051 - 2011-03-04 by CCC : initialisation de la date avec la date d'imputation
Local Date WDATE : WDATE = [M:MBM]IPTDAT(nolign-1)
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,WDATE) From TRTX3CPT
Return





######################################################################################
## Etiquette ajoutée par le superviseur (écran MTKBENCHM) 13/10/2009 11:38:04 (CCC)
######################################################################################
Subprog AS_WRHE(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2 & VALEUR<>"" & [M]NBLIG<>0
   GMESSAGE=mess(342,184,1) : mkstat=2
Endif
End


######################################################################################
# Actzo ou Grizo des dépôts selon le site
######################################################################################
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M]FCY<>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCY
Endif
If [F:FCY]WRHGES=2
  If GWRHOBY=2
    If [M:MBM]WRHE<>"" & [M:MBM]NBLIG<>0
      Diszo [M:MBM]WRHE
    Else
      Actzo [M:MBM]WRHE
    Endif
    Diszo [M:MBM]WRH
  Else
    Actzo [M:MBM]WRHE
    Actzo [M:MBM]WRH
  Endif
Else
  Grizo [M:MBM]WRHE
  Grizo [M:MBM]WRH
Endif
Return
########################################
# Dépôt à la ligne
########################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2
  VALEUR = [M:MBM]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:MBM]WRHE
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

######################################################################################
## Section automatically added (screen MTKBENCHM) 04/24/2015 14:11:53 (BEEBE)
## Issue 106345 - 2015-04-27 by BEEBE : additional selection of materials to track with BOMSEQ
######################################################################################
Subprog AS_WBOMSEQD(VALEUR)
Variable Decimal VALEUR
If [M]WBOMNUMF <> ""  | [F:BTS]OFFLG = 1 : mkstat = 2 : End : Endif
End

Subprog AM_WBOMSEQD(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : [M]WBOMSEQF = VALEUR
                 Affzo [M]WBOMSEQF
Endif
End

Subprog AS_WBOMSEQF(VALEUR)
Variable Decimal VALEUR
If [M]WBOMNUMF <> "" | [F:BTS]OFFLG = 1 : mkstat = 2 : End : Endif
End

Subprog C_WBOMSEQF(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M]WBOMSEQD : GMESSAGE = mess(44,199,1) : mkstat=2 : Endif
End

######################################################################################
# Issue 107513/8 - 2015-08-26 by JUSYN : Parent product when WO versioned then versions not allowed to be changed
$GREY_ECC
# Issue 116022 - 2016-04-15 by JUSYN : actzo when AM_ITMREF
If dim([M:MBM]ECCVALMAJ(nolign-1)) > 0
    If func ECCLIB.NBRCPN([M:MBM]BOMNUM(nolign-1)) > 0
        If LIDPROG = "AM_ITMREF"
            Actzo [M:MBM]ECCVALMAJ(nolign-1)
            Actzo [M:MBM]ECCVALMIN(nolign-1)
        Else
            Grizo [M:MBM]ECCVALMAJ(nolign-1)
            Grizo [M:MBM]ECCVALMIN(nolign-1)
        Endif
    Endif
    Affzo [M:MBM]ECCVALMAJ(nolign-1)
    Affzo [M:MBM]ECCVALMIN(nolign-1)
Endif
Return

######################################################################################
# Issue 116022 - 2016-04-20 by JUSYN : Version fields grey out when not versioned (BOM)
$GREY_ECC_MAT

If dim([M:MBM]ECCVALMAJ(nolign-1)) > 0 & [M:MBM]MATTYP(nolign-1) = 2
    If func ECCLIB.NBRCPN(VALEUR) > 0
        Actzo [M:MBM]ECCVALMAJ(nolign-1)
        Actzo [M:MBM]ECCVALMIN(nolign-1)
    Else
        Grizo [M:MBM]ECCVALMAJ(nolign-1)
        Grizo [M:MBM]ECCVALMIN(nolign-1)
    Endif
    Affzo [M:MBM]ECCVALMAJ(nolign-1)
    Affzo [M:MBM]ECCVALMIN(nolign-1)
Endif
Return

######################################################################################
## Section automatically added (screen MTKBENCHM) 30.06.2015 17:35:12 (JUSYN)
######################################################################################
# Issue 107513 - 2015-08-26 by JUSYN : Versioning
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

[M:MBM]ECCVALMAJ(nolign-1) = VALEUR

# Issue 116022 - 2016-04-20 by JUSYN : Only for versioned material
If func ECCLIB.NBRCPN([M:MBM]ITMREF(nolign-1)) > 0
    # Search of a version (without considering commercial BOMs)
    Filter [EVL] Where ECCTYP > 1
    Look [EVL]EVL1(2) = [M:MBM]ITMREF(nolign-1);VALEUR
    Filter [EVL]
    If fstat > 2
       GMESSAGE = mess(308,193,1) : # Non-existing version
       mkstat = 2
    Endif
Endif

End

