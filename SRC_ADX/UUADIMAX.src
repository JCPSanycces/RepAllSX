#<AdxTL>@(#)7.0.0.0 $Revision$
Call OUVRE_TRACE("Update Activity Codes : ADI") From LECFIC
Call PATCH("TEST2")
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(APPLI)
Value Char APPLI
Local Integer SI_ERR
Gosub OUV_DOSS
If !SI_ERR
 Trbegin [ACV_]
  Update [ACV_] Where CODACT="ADI"  With DIMMAX=max([ACV_]DIMMAX,999)
 Commit
Endif
Gosub FERME_DOSS
Call ECR_TRACE("Activity Codes : ADI updated",0) From GESECRAN
End

#--------------------------------------------------------------#
$OUV_DOSS
SI_ERR=0
Onerrgo ERR_OUVRE
Local File =APPLI+".ACTIV" [ACV_]
Onerrgo
Return

#--------------------------------------------------------------#
$FERME_DOSS
If SI_ERR=0
 Close Local File [ACV_]
Endif
Return

#--------------------------------------------------------------#
$ERR_OUVRE
SI_ERR=1
Resume
