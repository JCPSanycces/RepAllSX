#<AdxTL>@(#)12.0.0.0 $Revision$ Consultation SEA
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
                    #MAE,  bg 78911, on perd la classe F pour faire suite
                    #  If [M:SEA2]NBLIG = 0   # hcb 76397
                    #     Filter [STC]
                    #  Endif

  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSEA] : Transmask [M:SEA1] To [M:CSEA] # Issue 25606 [M:CSEA] = [M:SEA1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:STC])  = 0 : Local File STOLOC     [STC]  : Endif
If clalev([F:STO])  = 0 : Local File STOCK      [STO]  : Endif
If clalev([F:TLO])  = 0 : Local File TABLOCTYP  [TLO]  : Endif
If clalev([F:ITM1]) = 0 : Local File ITMMASTER  [ITM1] : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If GWRHACT=2
   If !clalev([F:WRH])  : Local File WAREHOUSE  [WRH]  : Endif
   If !clalev([F:ITW])  : Local File ITMWRH     [ITW]  : Endif
Endif

Local Char    WFIL(250), WFIL1(250)
Local Char    WFILS(250), WFILSPE(250)
Local Char    WFND(20)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Decimal WCPT
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer OK, I, J, WAGR
Local Char    WLOT(GLONLOT)
Local Char    WSLO(GLONSLO)
Local Char    WLOC(GLONLOC)
Local Char    WPAL(GLONPAL)
Local Char    WCTR(GLONCTR)
# la variable GAGGFLG sert à ne pas faire l aggregation si le bouton "dernier" à ete choisi l aggregation sera de nouveau active
# au prochain bouton "recherche"  sinon le traitement est perdue
Global Integer GAGGFLG     # hcb 84951
Raz GAGGFLG                # hcb 84951
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSEA"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SEA1]FLG = 0
[M:SEA1] = [M:CSEA]
Return
############################################################
$AP_MAGNETO
[M:SEA1]FLG = 0
Return
############################################################
$SETBOUT
If [M:SEA1]SELFLG = 0
  Call VIREBOUT(CHAINE,"a") From GOBJET
Endif
Return
############################################################
$EXEBOUT
Case BOUT
  When "a" :
    If nolign > 0
      PARAM(9)  = [M:SEA2]LOC(nolign-1)
      REPONSE = GSTAFIN
    Endif
Endcase
Return
############################################################
$FERME
If dim(WGCONSULT) > 0
  GCONSULT = WGCONSULT
  Filter [STC]
  Filter [STO]
Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ  : # "STOFCY"
        If !fstat
          [M:SEA1]STOFCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        [M:SEA1]LOCSEL = PARAM(I)
      Else
        [M:SEA1]LOCSEL = ""
      Endif
    When 4 :
      If PARAM(I) <> ""
        [M:SEA1]LOCTYPSEL = PARAM(I)
      Else
        [M:SEA1]LOCTYPSEL = ""
      Endif
    When 5 :
      If PARAM(I) = ""
        [M:SEA1]LOCCAT001 = 2
        [M:SEA1]LOCCAT002 = 2
        [M:SEA1]LOCCAT003 = 2
        [M:SEA1]LOCCAT004 = 2
      Else
        If instr(1,PARAM(I),"1")
          [M:SEA1]LOCCAT001 = 1
        Endif
        If instr(1,PARAM(I),"2")
          [M:SEA1]LOCCAT002 = 1
        Endif
        If instr(1,PARAM(I),"3")
          [M:SEA1]LOCCAT003 = 1
        Endif
        If instr(1,PARAM(I),"4")
          [M:SEA1]LOCCAT004 = 1
        Endif
      Endif
    When 6 :
#      If PARAM(I) <> ""
#        [M:SEA1]OCPSEL = val(PARAM(I))
#      Else
#        [M:SEA1]OCPSEL = 2
#      Endif
    When 7 :
      [M:SEA1]SELFLG = val(PARAM(7))
    When 8 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = PARAM(I)
      Endif
  Endcase
Next I
[M:SEA1]MONITMFLG = 3
[M:SEA1]DEDFLG = 3
[M:SEA1]REAFLG = 3
[M:SEA1]FILMGTFLG = 3
[M:SEA1]LOKSTA = 2
[M:SEA1]CUNLOKFLG = 2
[M:SEA1]AGGFLG    = 2

If clalev([M:CSEA]) <> 0 & [M:CSEA]MEMO = "STD"
  [M:SEA1] = [M:CSEA]
Endif
# Pas de démarrage immédiat si pas de sélection emplacement ou dépôt
If [M:SEA1]LOCSEL="" & [M:SEA1]LOCTYPSEL="" & (GWRHACT=2 & [M:SEA1]WRHSEL="")
  [M:SEA1]FLG = 2
Endif
Return
############################################################
$LECTURE
If [M:SEA1]FLG = 2
  [M:SEA1]FLG = 0
  NBLU = 0
  Goto LECTURE_FIN
Endif
If [M:SEA1]FLG=0 & [M:SEA1]LOCSEL="" & [M:SEA1]LOCTYPSEL="" &
&  (GWRHACT=2 & [M:SEA1]WRHSEL="")
  K = 1
  Call AVERTIR(mess(55,187,1),K) From GESECRAN
  If K <> 2
    NBLU = 0
    Goto LECTURE_FIN
  Endif
Endif
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    Raz [M:SEA2]
    nolign = 1
    WPAGE  = 0
    Raz GAGGFLG    # hcb 84951
    For [STC]
      If [F:STC]OCPCOD = 1 Raz [F:STO]
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        Filter [STO] Where STOFCY=[F:STC]STOFCY & LOC=[F:STC]LOC Order By Key STO3
        For [STO] Hint Key STO4
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    += 1
          Else
            Break
          Endif
        Next
        Filter [STO]
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    # Bug 38845 - 12/12/2006 - Début
    Effzo [M:SEA2]
    # Bug 38845 - 12/12/2006 - fin
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [STC]
      If [F:STC]OCPCOD = 1 Raz [F:STO]
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    += 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
      Else
        Filter [STO] Where STOFCY=[F:STC]STOFCY & LOC=[F:STC]LOC Order By Key STO3
        For [STO] Hint Key STO4
          If WLIG >= WSKIP
            If nolign <= MAXLIG
              Gosub LOA_LIGNE
              NBLU    = 2
              nolign += 1
              NOL    += 1
            Else
              Break
            Endif
          Else
            WLIG += 1
          Endif
        Next
        Filter [STO]
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SEA2]
    WLIG = 0
    GAGGFLG = 1   # hcb 84951
    For [STC]
      If [F:STC]OCPCOD = 1 Raz [F:STO]
        WLIG += 1
      Else
        For [STO]STO4 Where STOFCY=[F:STC]STOFCY & LOC=[F:STC]LOC
        WLIG += 1
        Next
      Endif
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [STC]
      If [F:STC]OCPCOD = 1 Raz [F:STO]
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    -= 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
      Else
        Filter [STO] Where STOFCY=[F:STC]STOFCY & LOC=[F:STC]LOC Order By Key STO3
        For [STO] Hint Key STO4
          If WLIG >= WSKIP
            If nolign <= MAXLIG
              Gosub LOA_LIGNE
              NBLU    = 2
              nolign += 1
              NOL    -= 1
            Else
              Break
            Endif
          Else
            WLIG += 1
          Endif
        Next
        Filter [STO]
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    # Bug 38845 - 12/12/2006 - Début
    Effzo [M:SEA2]
    # Bug 38845 - 12/12/2006 - fin
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [STC]
      If [F:STC]OCPCOD = 1 Raz [F:STO]
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
       Else
        Filter [STO] Where STOFCY=[F:STC]STOFCY & LOC=[F:STC]LOC Order By Key STO3
        For [STO] Hint Key STO4
          If WLIG >= WSKIP
            If nolign <= MAXLIG
              Gosub LOA_LIGNE
              NBLU    = 2
              nolign += 1
            Else
              Break
            Endif
          Else
            WLIG += 1
          Endif
        Next
        Filter [STO]
       Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER
If [M:SEA1]FLG = 0
  [M:SEA1]FLG = 1
  Raz [M:SEA2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif

  Filter [STC] Where evalue(WFIL) &
&                    evalue(WFILS)&
&                    evalue(WFIL1)&
&                    evalue(WFILSPE)
&              Order By Key STC0
  Raz [F:STC]
Endif
Return
############################################################
$LOAD_FILTER
#Constitution filtre
WFIL1 = "1=1"
WFIL = "[F:STC]STOFCY=[M:SEA1]STOFCY"
If [M:SEA1]LOCSEL <> ""
  WFIL += "&pat([F:STC]LOC,[M:SEA1]LOCSEL)=1"
Endif
If [M:SEA1]LOCTYPSEL <> ""
  WFIL += "&pat([F:STC]LOCTYP,[M:SEA1]LOCTYPSEL)=1"
Endif
If GWRHACT=2 & [M:SEA1]WRHSEL<>""
  WFIL += "&[F:STC]WRH=[M:SEA1]WRHSEL"
Endif
WOCP = ""
If [M:SEA1]OCPFLG1 <> 2
  WOCP += ",1"
Endif
If [M:SEA1]OCPFLG2 <> 2
  WOCP += ",2"
Endif
If [M:SEA1]OCPFLG3 <> 2
  WOCP += ",3"
Endif
If WOCP <> ""
  WFIL += "&!find([F:STC]OCPCOD"+WOCP+")"
Endif
WFND = ""
If [M:SEA1]LOCCAT001 <> 2
  WFND += ",1"
Endif
If [M:SEA1]LOCCAT002 <> 2
  WFND += ",2"
Endif
If [M:SEA1]LOCCAT003 <> 2
  WFND += ",3"
Endif
If [M:SEA1]LOCCAT004 <> 2
  WFND += ",4"
Endif
If WFND <> ""
  WFIL += "&!find([F:STC]LOCCAT"+WFND+")"
Endif
#
If [M:SEA1]MONITMFLG = 2
  WFIL += "&[F:STC]MONITMFLG=2"
Elsif [M:SEA1]MONITMFLG = 1
  WFIL += "&[F:STC]MONITMFLG<>2"
Endif
#
If [M:SEA1]DEDFLG = 2
  WFIL += "&[F:STC]DEDFLG=2"
Elsif [M:SEA1]DEDFLG = 1
  WFIL += "&[F:STC]DEDFLG<>2"
Endif
#
If [M:SEA1]REAFLG = 2
  WFIL += "&[F:STC]REAFLG=2"
Elsif [M:SEA1]REAFLG = 1
  WFIL += "&[F:STC]REAFLG<>2"
Endif
#
If [M:SEA1]FILMGTFLG = 2
  WFIL += "&[F:STC]FILMGTFLG=2"
Elsif [M:SEA1]FILMGTFLG = 1
  WFIL += "&[F:STC]FILMGTFLG<>2"
Endif
#
If [M:SEA1]LOKSTA <> 2
  WFIL1 += "&[F:STC]LOKSTA<>2"
Endif
#
If [M:SEA1]CUNLOKFLG <> 2
  WFIL1 += "&[F:STC]CUNLOKFLG<>2"
Endif
Return
############################################################
$LOA_LIGNE
WAGR = 0
#--- Si agrégation
#--- Uniquement sur les numéros de séries
If [M:SEA1]AGGFLG = 2 & NOL <> -1 & [F:STO]STOCOU<>0 & [F:STO]SERNUM<>"" & GAGGFLG <> 1    # hcb 84951
  For I = 0 To MAXLIG-1
    If dim([M:SEA2]LOT) > 0
         WLOT = [M:SEA2]LOT(I)
    Else WLOT = ""
    Endif
    If dim([M:SEA2]SLO) > 0
         WSLO = [M:SEA2]SLO(I)
    Else WSLO = ""
    Endif
    If dim([M:SEA2]LOC) > 0
         WLOC = [M:SEA2]LOC(I)
    Else WLOC = ""
    Endif
    If dim([M:SEA2]PALNUM) > 0
         WPAL = [M:SEA2]PALNUM(I)
    Else WPAL = ""
    Endif
    If dim([M:SEA2]CTRNUM) > 0
         WCTR = [M:SEA2]CTRNUM(I)
    Else WCTR = ""
    Endif
    If WLOT                 = [F:STO]LOT       &
&      WSLO                 = [F:STO]SLO       &
&      WLOC                 = [F:STO]LOC       &
&      WPAL                 = [F:STO]PALNUM    &
&      WCTR                 = [F:STO]CTRNUM    &
&      [M:SEA2]STA(I)       = [F:STO]STA       &
&      [M:SEA2]PCU(I)       = [F:STO]PCU       &
&      [M:SEA2]PCUSTUCOE(I) = [F:STO]PCUSTUCOE &
&      [M:SEA2]ITMREF   (I) = [F:STO]ITMREF    &
&      [M:SEA2]QLYCTLDEM(I) = [F:STO]QLYCTLDEM
      [M:SEA2]STOCOU(I)     = 0
      [M:SEA2]QTYPCU(I)    += [F:STO]QTYPCU
      [M:SEA2]QTYSTU(I)    += [F:STO]QTYSTU
      [M:SEA2]CUMALLQTY(I) += [F:STO]CUMALLQTY
      If dim([M:SEA2]SERNUM) > 0
        [M:SEA2]SERNUM(I) = "$"
      Endif
      WAGR = 1
      Break
    Endif
  Next I
  If WAGR = 1
    nolign -= 1
    NOL    -= 1
    WLIG   -= 1
    Return
  Endif
Endif
#--- nouvelle ligne
[M:SEA2] = [F:STC]
If [F:STO]STOCOU<> 0
   [M:SEA2] = [F:STO]
Endif
If [M:SEA2]ITMREF(nolign-1) <> ""
  Read [ITM1]ITM0=[M:SEA2]ITMREF(nolign-1)
  If fstat
    Raz [F:ITM1]
  Endif
Else
  Raz [F:ITM1]
Endif
#[M:SEA2]ITMDES1(nolign-1) = [F:ITM1]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:SEA2]ITMDES1(nolign-1), "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:SEA2]STU    (nolign-1) = [F:ITM1]STU
Return
############################################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
[M:SEA1]FLG = 0
End
############################################################
Subprog C_LOCSEL(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End
############################################################
Subprog C_LOCTYPSEL(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End
############################################################
Subprog AM_LOCSEL(VALEUR)
Variable Char    VALEUR()
[M:SEA1]FLG = 0
#MAE, bg 78911
Filter [STC]
End
############################################################
Subprog AM_LOCTYPSEL(VALEUR)
Variable Char    VALEUR()
[M:SEA1]FLG = 0
#MAE, bg 84730
Filter [STC]
End
############################################################
Subprog AM_WRHSEL(VALEUR)
Variable Char    VALEUR()
[M:SEA1]FLG = 0
End
############################################################
Subprog AM_OCPSEL(VALEUR)
Variable Integer VALEUR
[M:SEA1]FLG = 0
End
############################################################
Subprog AM_OCPFLG1(VALEUR)
Variable Integer VALEUR
[M:SEA1]FLG = 0
End
############################################################
Subprog AM_OCPFLG2(VALEUR)
Variable Integer VALEUR
[M:SEA1]FLG = 0
End
############################################################
Subprog AM_OCPFLG3(VALEUR)
Variable Integer VALEUR
[M:SEA1]FLG = 0
End
##########################################################################

##########################################################################
## Etiquette ajoutée par le superviseur 12/03/2004 11:15:03 (EB)
##########################################################################
Subprog AV_VCRTYP(VALEUR)
Variable Integer VALEUR
#If VCRNUM(nolign-1)="" mkstat=2 Endif
End

Subprog AS_LOCSEL(VALEUR)
Variable Char    VALEUR()
# Bug 38845 - 12/12/2006 - Début
# =>  Filter qui reinitialisait les lectures en cliquant sur boutons Suite ou Retour
#Filter [STC]
# Bug 38845 - 12/12/2006 - Fin
End


######################################################################################
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SEA") From SUBGTC

End

