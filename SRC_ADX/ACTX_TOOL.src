#<AdxTL>@(#)0.0.0.0 $Revision$



Funprog CHECK_ACTX_PROPERTY(CHAINE)
Value Char CHAINE
 Local Integer RES_OK, INDEX_DOT
# Local File ACONTEXT [ACTX]
 If CHAINE<>""
  INDEX_DOT = instr(1,CHAINE,".")
  If INDEX_DOT>0
   # in case it's a context code with chapter
   Local Char L_CHP(50), L_COD(GLONACTX)
   L_CHP = left$(CHAINE, INDEX_DOT-1)
   L_COD = right$(CHAINE, INDEX_DOT+1)
   Read [ACTX]ACTX0 = toupper(L_COD)
   If !fstat and [ACTX]CHAPTER = toupper(L_CHP)
    RES_OK = 1
   Endif
  Else
   # in case it's directly a context code without chapter
   Read [ACTX]ACTX0 = toupper(CHAINE)
   If !fstat and [ACTX]CHAPTER = ""
    RES_OK = 1
   Endif
  Endif
 Endif
# Close Local File [ACTX]
End RES_OK


Funprog GET_ACTX_TYPCOD(CHAINE)
Value Char CHAINE
 Local Integer RES_COD, INDEX_DOT
# Local File ACONTEXT [ACTX]
# Local File ATYPE [ATY]
 If CHAINE<>""
  INDEX_DOT = instr(1,CHAINE,".")
  If INDEX_DOT>0
   # in case it's a context code with chapter or AVARNULL
   Local Char L_CHP(50), L_COD(GLONACTX)
   L_CHP = left$(CHAINE, INDEX_DOT-1)
   L_COD = right$(CHAINE, INDEX_DOT+1)
   Read [ACTX]ACTX0 = toupper(L_COD)
   If !fstat and [ACTX]CHAPTER = toupper(L_CHP)
    Read[ATY]CODTYP = [ACTX]CODTYP
    If !fstat
     RES_COD = [ATY]TYPTYP
    Endif
   Endif
  Else
   # in case it's directly a context code without chapter
   Read [ACTX]ACTX0 = toupper(CHAINE)
   If !fstat and [ACTX]CHAPTER = ""
    Read[ATY]CODTYP = [ACTX]CODTYP
    If !fstat
     RES_COD = [ATY]TYPTYP
    Endif
   Endif
  Endif
 Endif
# Close Local File [ACTX]
# Close Local File [ATY]
End RES_COD
