#########################################################
#*!
Subprog LVA_MAJ_ANALYTIQUE( PMSTA, PAASREF, PAASDSP, PCPY, PFCY, PLOFDSP, PNBDIE, PDIE, PCCE, PETRNOT, PCUR, RAASDSP, RERRMES )
#
# Objet : Actualise en diminution ou en augmentation les sections analytiques concernées
#         d'un montant HT d'une dépense avec création éventuelle de la répartition à priori.
#
#         Remarque PDIE PCCE contiennent Axes et Section de la dépense
#                            (Si Répartition à priori alors Axes de la société et Sections à blanc )
#                  DIE  CCE  contiennent les Axes et Section à trouver dans la répartition à priori du bien comptable
#                            Si trouvé modification de la ligne de répartition à priori si non trouvé ajout d'une ligne
#                  Lorsqu'une répartition à priori est précisée sur la dépense, la part revenant à chacune des
#                  sections est calculée. A contrario de la répartion à priori de la dépense, la répartition à priori
#                  du bien est composé de tous les axes définis pour la société
#                  Lorsqu'une dépense rattachée ne possède pas d'analytique aucune ligne n'est générée dans la répartition
#                  à priori du bien.
#                  Lorsque qu'une ligne de répartition suite à diminution ou augmentation a son coefficient à 0 la ligne de
#                  répartition est supprimée (sans renumérotation). Lorsque plus aucune ligne de répartition n'existe
#                  la rérérence est remise à blanc sur le bien
#
#         Transfert analytique :
#         Interdit en unitaire pour les biens LVA/POOL non valorisés ou ayant au moins une dépense rattachée
#         En massif, les biens LVA/POOL sont exclus de la population de biens à transférer.
#
#
Value    Char    PMSTA          : # Statut "+" ou "-"
Value    Char    PAASREF        : # Référence du bien
Value    Char    PAASDSP        : # Répartition à priori (immobilisation)
Value    Char    PCPY           : # Société
Value    Char    PFCY           : # Site
Value    Char    PLOFDSP        : # Répartion à priori (dépense)
Value    Integer PNBDIE         : # Nombre d'axes de la société
Value    Char    PDIE           : # Axes analytiques (dépense)
Value    Char    PCCE           : # Section (dépense)
Value    Decimal PETRNOT        : # Montant HT (dépense)
Value    Char    PCUR           : # Devise société
Variable Char    RAASDSP        : # Répartition à priori (immobilisation)
Variable Char    RERRMES        : # Message erreur en retour

Local Integer LNBRDSP
Local Decimal LCOE
Local Char REQUETE(250) (4)
Local Integer B_EMPTY

  RERRMES = ""

  If (find(PMSTA,"+","-")= 0) Then
    # Au moins un des paramétres passés à la fonction n'est pas intègre
    RERRMES = mess(887,7773,1) : End
  Endif

  RAASDSP = PAASDSP
  Local Integer I_S
  Local Integer I_C
  If !clalev([F:DSPD]) : Local File CADSP [DSPD] : Endif
  If !clalev([F:DSPB]) : Local File CADSP [DSPB] : Endif

  Local Char DIE (3)  (1..20)
  Local Char CCE (15) (1..20)

  #-1 --------------------
  If (PAASDSP = "") Then
    # Pas de répartition à priori sur le bien
    If ( PMSTA = "-" ) Then
#     # "Tentative de diminution de l'analytique sur un bien sans répartition à priori"
#     RERRMES =  mess(888,7773,1) : End
      End
    Endif
    #-2 --------------------
    If ( PLOFDSP = "" ) Then
      # Pas de répartition à priori renseignée sur la dépense

      # Affectation des sections de la répartition du bien à partir des sections de la dépense
      B_EMPTY = 1
      #>>>>>>>>>>
      For I_S = 1 To PNBDIE
        DIE(I_S) = PDIE(I_S-1)
        CCE(I_S) = PCCE(I_S-1)
        If (CCE(I_S) <> "") Then : B_EMPTY = 0 : Endif
      Next I_S
      #<<<<<<<<<<

      # Analytique vide -  aucun traitement pas d'erreur
      If (B_EMPTY) Then : End : Endif

      LNBRDSP = 1
      LCOE   = PETRNOT
      Gosub AJOUTE_AAS_REPART_LINE
      If (RERRMES <> "") Then : End : Endif
    #-2 --------------------
    Else
      # Répartition à priori renseignée sur la dépense
      #>>>>>>>>>>
      For I_S = 1 To PNBDIE
        DIE(I_S) = PDIE(I_S-1)
        CCE(I_S) = ""
      Next I_S
      #<<<<<<<<<<

      Local Decimal LCUMCOE : LCUMCOE = 0.
      For [DSPD] Where DSP=PLOFDSP
        LCUMCOE += [F:DSPD]COE
      Next
      If !(LCUMCOE) Then
        # Répartition à priori de la dépense n'existe pas
        RERRMES = mess(889,7773,1)- PLOFDSP : End
      Endif
      Local Decimal WCUMCOE : WCUMCOE = 0.
      Local Decimal WREPART : WREPART = 0.
      Local Decimal LPART   : LPART   = 0
      LNBRDSP = 0
      #>>>>>>>>>>
      For [DSPD] Where DSP=PLOFDSP

        # Evaluation et affectation de la part revenant à une section de la dépense
        Gosub TRAITE_PART_SECTION_DEPENSE
        If (RERRMES <> "") Then : Break : Endif

        LNBRDSP += 1
        LCOE    = LPART
        Gosub AJOUTE_AAS_REPART_LINE
        If (RERRMES <> "") Then Break : Endif

      Next
      #>>>>>>>>>>
      If (RERRMES <> "") Then : End : Endif

    Endif
    #-2 --------------------

  #-1 --------------------
  Else
    # Une répartition à priori sur le bien existe déjà

    # Lecture de la dernière ligne de la répartition à priori du bien
    Filter [DSPB] Where DSP=PAASDSP
    Read [DSPB]DSP0 Last
    Filter [DSPB]
    If (fstat) Then
      # Répartition à priori de l'immobilisation n'existe pas
      RERRMES = mess(890,7773,1) - PAASDSP : End
    Elsif( [F:DSPB]DES <> PAASREF)
      # La désignation de répartition à priori n'est pas égale à la référence du bien
      RERRMES = mess(891,7773,1)- PAASDSP : End
    Else
      Local Integer LCURNBRDSP : LCURNBRDSP = [F:DSPB]NBRDSP
    Endif

    # Récupération des axes de la répartition à priori du bien
    #>>>>>>>>>>
    For I_S = 1 To 20
      If ( I_S <= [F:DSPB]NBRDIE ) Then
        DIE(I_S) = [F:DSPB]DIE(I_S-1)
      Else
        DIE(I_S) = ""
      Endif
      CCE(I_S) = ""
    Next I_S
    #<<<<<<<<<<

    Local Decimal LPART   : LPART   = 0
    #-2 --------------------
    If ( PLOFDSP = "" ) Then
      # Pas de répartition à priori renseignée sur la dépense

      # Affectation des sections de la répartition à partir des axes de la dépense
      B_EMPTY = 1
      #>>>>>>>>>>
      For I_S = 1 To PNBDIE
        I_C = find(PDIE(I_S-1), DIE)
        If ( I_C = 0 ) Then
          # Axe analytique dépense non trouvé dans la répartition à priori du bien
          RERRMES = mess(891,7773,1) - PDIE(I_S-1)  : Break
        Endif
        CCE(I_C) = PCCE(I_S-1)
        If (CCE(I_C) <> "") Then : B_EMPTY = 0 : Endif
      Next I_S
      #<<<<<<<<<<
      If (RERRMES <> "") Then : End : Endif

      # Analytique vide -  aucun traitement pas d'erreur
      If (B_EMPTY) Then : End : Endif

      # Contruction requête sur répartition à priori du bien.
      Raz REQUETE : Raz GBIDI1
      #>>>>>>>>>>
      For I_S = 1 To PNBDIE
        Call ADDCRIT( REQUETE, GBIDI1, mess(1,GML_MSGCAL,1)-PCPY," DIE("+num$(I_S-1)+")='"+ DIE(I_S) + "' & CCE"+num$(I_S)+"='"+CCE(I_S) + "' ", "&") From GOBJSUB
      Next I_S
      #<<<<<<<<<<

      LPART = PETRNOT
      Gosub TRAITE_AAS_REPART_LINE
      If (RERRMES <> "") Then : End : Endif

    #-2 --------------------
    Else
      # Répartition à priori renseignée sur la dépense
      #>>>>>>>>>>
      For I_S = 1 To PNBDIE
        DIE(I_S) = PDIE(I_S-1)
        CCE(I_S) = ""
      Next I_S
      #<<<<<<<<<<

      Local Decimal LCUMCOE : LCUMCOE = 0.
      For [DSPD] Where DSP=PLOFDSP
        LCUMCOE += [F:DSPD]COE
      Next
      If !(LCUMCOE) Then
        # Répartition à priori de la dépense n'existe pas
        RERRMES = mess(889,7773,1)- PLOFDSP : End
      Endif
      Local Decimal WCUMCOE : WCUMCOE = 0.
      Local Decimal WREPART : WREPART = 0.

      #>>>>>>>>>>
      For [DSPD] Where DSP=PLOFDSP

        # Evaluation et affectation de la part revenant à une section de la dépense
        Gosub TRAITE_PART_SECTION_DEPENSE
        If (RERRMES <> "") Then : Break : Endif

        # Contruction requête sur répartition à priori du bien.
        Raz REQUETE : Raz GBIDI1
        #>>>>>>>>>>
        For I_S = 1 To PNBDIE
          Call ADDCRIT( REQUETE, GBIDI1, mess(1,GML_MSGCAL,1)-PCPY," DIE("+num$(I_S-1)+")='"+ DIE(I_S) + "' & CCE"+num$(I_S)+"='"+CCE(I_S) + "' ", "&") From GOBJSUB
        Next I_S
        #<<<<<<<<<<

        Gosub TRAITE_AAS_REPART_LINE
        If (RERRMES <> "") Then : Break : Endif

      Next
      #<<<<<<<<<<
      If (RERRMES <> "") Then :  End : Endif
    Endif
    #-2 --------------------
  Endif
  #-1 --------------------
End

#========================
$TRAITE_PART_SECTION_DEPENSE
      # Détermination et affectation de la part revenant à la ligne de répartition
      WCUMCOE += [F:DSPD]COE
      If (WCUMCOE = LCUMCOE) Then
        # Solde du reste à ventiler
        LPART = PETRNOT - WREPART
      Else
        # Part revenant à la ligne de répartition
        LPART   = PETRNOT * ([F:DSPD]COE / LCUMCOE)
        # Arrondi selon la devise société
        Local    Integer WIC
        WIC = find( PCUR, GDEVISE(1..GNBDEV))
        If ( WIC <> 0 ) Then
            # Arrondi en fonction de la devise
            LPART = arr( LPART, GDEVRND (WIC) )
        Endif
      Endif
      WREPART = WREPART + LPART

      # Affectation des sections de la répartition à partir des axes de la dépense
      #>>>>>>>>>>
      For I_S = 1 To [F:DSPD]NBRDIE
        If ([F:DSPD]DIE(I_S-1) <> "") Then
          I_C = find([F:DSPD]DIE(I_S-1), DIE)
          If ( I_C = 0 ) Then
            # Axe analytique dépense non trouvé dans la répartition à priori du bien
            RERRMES = mess(892,7773,1) - PDIE(I_S-1)  : Break
          Endif
          CCE(I_C) = evalue("[F:DSPD]CCE"+num$(I_S))
        Endif
      Next I_S
      #<<<<<<<<<<
      If (RERRMES <> "") Then : Return : Endif
Return
#========================
$TRAITE_AAS_REPART_LINE

    # Recherche d'une ligne équvalente dans la répartition à priori du bien
    Filter [DSPB] Where DSP=PAASDSP and DES = PAASREF and evalue(REQUETE)
    Read[DSPB] Last
    Filter [DSPB]
    If (fstat) Then
      If (PMSTA = "-") Then
#       # "Tentative de diminution de l'analytique sur un bien sans ligne de répartition à priori correspondante"
#       RERRMES =  mess(8893,7773,1) : Return
        Return
      Endif
      # Pas de ligne correspondante - Création d'une ligne de répartition
      LCURNBRDSP += 1
      LNBRDSP = LCURNBRDSP
      LCOE    = LPART
      Gosub AJOUTE_AAS_REPART_LINE
      If (RERRMES <> "") Then : Return : Endif
    Else
      # Une ligne correspondante trouvée - Mise à jour  ligne de répartition
      LCOE    = LPART
      Gosub MODIFIE_AAS_REPART_LINE
      If (RERRMES <> "") Then : Return : Endif
    Endif
Return
#========================
$AJOUTE_AAS_REPART_LINE
  If (RAASDSP = "") Then
    # Référence d'une nouvelle répartition à priori pour le bien
    Local Integer LERR
    Call GET_NUMERO_DSP(GVML_NUMDSP-1, PCPY, PFCY, date$, RAASDSP, RERRMES) From TRTFAS2
    # Erreur attribution numérotation automatique
    If ( RERRMES <> "" ) Then : Return : Endif
  Endif
  Raz [F:DSPB]
  [F:DSPB]DSP     = RAASDSP
  [F:DSPB]NBRDSP  = LNBRDSP
  [F:DSPB]DES     = PAASREF
  Call MAJTEXTRA(PAASREF, "CADSP", "DESTRA", [F:DSPB]DSP, "") From ATEXTRA
  [F:DSPB]COE     = LCOE
  [F:DSPB]NBRDIE = PNBDIE
  For I_S = 1 To 20
    [F:DSPB]DIE(I_S-1) = DIE(I_S)
    Assign "[F:DSPB]CCE"+num$(I_S) With CCE(I_S)
  Next I_S
  [F:DSPB]EXPNUM = 1
  [F:DSPB]CREUSR = GUSER
  [F:DSPB]CREDAT = date$
  Write [F:DSPB]
  If (fstat) Then
    # Erreur à la création de la nouvelle répartition à priori
    RERRMES = mess(104,7773,1)-"Write CADSP -"- [F:DSPB]DSP-"/"-num$([F:DSPB]NBRDSP)-"Fstat:"-num$(fstat) : Return
  Endif
Return

#-------------------------------
$MODIFIE_AAS_REPART_LINE

  If (PMSTA = "+") Then
    [F:DSPB]COE += LCOE
  Else
    [F:DSPB]COE -= LCOE
  Endif

  If ( [F:DSPB]COE <> 0 ) Then
      # Modification de la ligne de répartition.
    [F:DSPB]UPDUSR = GUSER
    [F:DSPB]UPDDAT = date$
    Rewrite [F:DSPB]
    If (fstat) Then
      # Erreur à la modification de la ligne de répartition à priori
      RERRMES = mess(104,7773,1)-"Rewrite CADSP -"- [F:DSPB]DSP-"/"-num$([F:DSPB]NBRDSP)-"Fstat:"-num$(fstat) : Return
    Endif
  Else
    # Suppression de la ligne de répartition à 0.
    Delete [F:DSPB]
    If (fstat) Then
      # Erreur à la suppression de la ligne de répartition à priori
      RERRMES = mess(104,7773,1)-"Delete CADSP -"- [F:DSPB]DSP-"/"-num$([F:DSPB]NBRDSP)-"Fstat:"-num$(fstat) : Return
    Endif
  Endif
Return

###############################################################################
Subprog GET_NUMERO_DSP(PNUMAFF, PCPY, PFCY, PDATE, RNUMERO, RERRMES)
#
# Récupère la référence d'une nouvelle répartition à priori via la numérotation automatique
#
# PNUMAFF : indice du compteur de l'objet dans l'affectation des compteurs
# PCPY    : Société
# PFCY    : Site de référence pour le compteur
# PDATE   : Date de référence pour le compteur
#
# Rend :
# RNUMERO : Numéro
# STAT    : Statut (0 : OK, >0 : KO)
# ------------------------------------------------------------------------------
Value    Integer PNUMAFF
Value    Char    PCPY
Value    Char    PFCY
Value    Date    PDATE
Variable Char    RNUMERO
Variable Char    RERRMES

Local Integer STAT
Local Char    MESSA

  If clalev([F:TCA])=0  : Local File TABCOUAFF [TCA] : Endif  : # Table des affectations de compteurs
  If clalev([F:DSP])=0  : Local File CADSP     [DSP] : Endif  : # Table des répartitions à priori

  # Recherche du compteur de document
  Local Char    L_SOCIETE  :   L_SOCIETE = PCPY
  Local Integer L_MODULE   :   L_MODULE  = 14
  Local Integer B_TCAFND
  Gosub FAS_LECTCA From GLOBIENS
  If (!B_TCAFND) Then : Raz [F:TCA] : Endif

  Local Char L_COMPTEUR(5)
  L_COMPTEUR     = [F:TCA]CODNUM(PNUMAFF)
  If L_COMPTEUR = "" Then
    L_COMPTEUR   = "DSP"   : # Par défaut on prend l'abréviation de la table comme compteur
  Endif

  Local Integer L_NBESSAI
  Local Integer B_LOOP  : B_LOOP = 0

  #>>>>>>>>>>>
  Repeat
    # Appel numérotation
    Call NUMERO(L_COMPTEUR, PFCY, PDATE, "", RNUMERO, STAT) From SUBANM
    If (STAT) Then
      Gosub MESSAGE From SUBANM
      # Erreur dans la numérotation automatique (COMPTEUR) : xxxxx
      GMESSAGE  = mess(22,7770,1)-"("+L_COMPTEUR+") :" - MESSA
      Break
    Else
      # Contrôle existence du numéro rendu
      [F:DSP]DSP = RNUMERO
      Look [F:DSP]DSP0(1)=RNUMERO
      If !(fstat) Then
        L_NBESSAI += 1
        If (L_NBESSAI > 100 ) Then
          # Erreur dans la numérotation automatique (COMPTEUR) : Séquence de numérotation déjà utilisée
          RERRMES  = mess(22,7770,1)-"("+L_COMPTEUR+") :"-mess(135,7770,1)
          Break
        Endif
      Else
        Break
      Endif
    Endif
  Until B_LOOP
  #<<<<<<<<<<<<<
  If (RERRMES <> "") Then :  End : Endif

End


#########################################################
#*!
Funprog IS_DSP_EMPTY(PDSP)
#
# Objet : Retourne si aucune ligne n'existe pour la répartition à priori passée en paramètre
#
Value Char    PDSP()  : # Référence répartition à priori
#
Local Integer LRES : LRES = 0
  If !clalev([F:DSP]) : Local File CADSP [DSP] : Endif
  Filter [DSP] Where DSP=PDSP
  If ( rowcount([F:DSP])=0 ) Then : LRES = 1 : Endif
  Filter [DSP]
  Close File [F:DSP]
End LRES
