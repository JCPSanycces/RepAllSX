# Date          |Author |Version| Description
######################################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "CODNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub CODNEW_CONTROL
      Endcase
    When Default
  Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_DUPLICATE"  : Gosub MET_DUPLICATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


####################################################################

$CODNEW_CONTROL
  If this.CODNEW <> ""
    If func CTRL_EXIST_FILFMT(this.CODNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("CODNEW",mess(45,7779,1)-":"-this.CODNEW,[V]CST_AERROR)
    Endif
  Endif
Return


####################################################################

$MET_DUPLICATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)

  ASTATUS = fmet this.ADELETEERROR("")
  If this.CODNEW <> ""
    ASTATUS = fmet this.ASETERROR("",mess(9,7983,1),[V]CST_AINFO)
    If func CTRL_EXIST_FILFMT(this.CODNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("BSIFFMNEW",mess(45,7779,1)-":"-this.CODNEW,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Else
      If func COPY_FILFMT(this.CODBFF, this.CODNEW, WERR) = [V]CST_AERROR
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(9,2007,1)-this.CODNEW-WERR,[V]CST_AERROR)
        WRET_VALUE = [V]CST_AERROR
      Else
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(7,2007,1)-this.CODNEW,[V]CST_AINFO)
        WRET_VALUE = [V]CST_AOK
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETERROR("",mess(141,105,1),[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return

Funprog CTRL_EXIST_FILFMT(WCOD)
Value Char WCOD

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WCOD <> ""
    Local File BSIFILFMT [BSIFFM]
    Read [BSIFFM]BSIFFM0 = WCOD
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [BSIFFM]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

Funprog COPY_FILFMT(WCOD, WCOD_NEW, WERR)
Value Char WCOD
Value Char WCOD_NEW
Variable Char WERR
  Local Integer WOK : WOK = [V]CST_AOK
  Local File BSIFILFMT [BSIFFM]
  Local File BSIFILFMT [BSIFFM2]
  Local File BSIFILFMTD [BSIFFD]
  Local File BSIFILFMTD [BSIFFD2]
  WERR = ""

  Trbegin [BSIFFM2], [BSIFFD2]

  Read [BSIFFM]BSIFFM0 = WCOD
  If !fstat
    [BSIFFM2]       = [BSIFFM]
    [BSIFFM2]CODBFF = WCOD_NEW
    Write [BSIFFM2]
    If fstat
      WOK = [V]CST_AERROR
      WERR = "BSIFILFMT ("+mess(1,7983,1)+")"
    Endif
  Else
    WOK = [V]CST_AERROR
    WERR = "BSIFILFMT ("+mess(7,7983,1)+")"
  Endif

  If WOK = [V]CST_AOK
    Filter [BSIFFD] Where CODBFF = WCOD
    For [BSIFFD]
      [BSIFFD2]       = [BSIFFD]
      [BSIFFD2]CODBFF = WCOD_NEW
      Write [BSIFFD2]
      If fstat
          WOK = [V]CST_AERROR
          Break
      Endif
    Next
    Filter [BSIFFD]
  Endif

  If WOK = [V]CST_AERROR
    If WERR = "" : WERR = "BSIFILFMTD ("+mess(3,40,1)-num$([BSIFFD2]LIN)+")" : Endif
    Rollback
  Else
    Commit
  Endif

  LogicClose File [BSIFFD2]
  LogicClose File [BSIFFD]
  LogicClose File [BSIFFM2]
  LogicClose File [BSIFFM]
End WOK

