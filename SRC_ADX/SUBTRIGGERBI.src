#<AdxTL>@(#)0.0.0.0 $Revision$
Gosub TEST2 From ATRIGGER
End


Call OUVRE_TRACE("") From LECFIC
Trbegin ADOVAL
 Call TRIGGER(nomap,"AOBJET","I") From ATRIGGER
 Call TRIGGER(nomap,"AOBJET","U") From ATRIGGER
 Call TRIGGER(nomap,"AOBJET","D") From ATRIGGER
Commit
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#######################################################################
## Définition des triggers d'audit
#######################################################################
Subprog DEFTRI(APPLI,BASE,OPERATION,STDFLG,BIFLG,N,T)
#######################################################################
Value    Char    APPLI               : # appli ou on va créer le trigger
Value    Integer BASE                : # 1=Oracle, 2=Sql-serveur
Value    Char    OPERATION           : # I=Insert, U=Update, D=Delete
Value    Integer STDFLG              : # flag stand triger normal (audcre,audupd ,..)
Value    Integer BIFLG               : # flag bi
Variable Integer N                   : # Nombre de lignes
Variable Char    T()(1..)            : # Texte du trigger


Local Char ACTION(20)
Local Integer OKTRT

Gosub DEF_MAXFIELDS From ATRIGGER

Local Integer NBSPE , I
Local Integer NEWAUDIT   : # flag pour gerer le nouveau upddate avec delete si les cle on changé
Local Char    FLDSPE(GLONAVA)(1..20)
Local Integer TYPSPE(1..20)
For [ATZ] Where CODFIC="AUDITH"
 If !find([F:ATZ]CODZONE,"SEQ","TBL","DAT","HOU","EVT","ID1","ID2","ADOUSR","SYSUSR","ADRCLI","STA","STABI"
& ,"CHAR1","CHAR2","CHAR3","CHAR4","CHAR5","CHAR6","CHAR7","CHAR8","CHAR9","CHAR10","CHAR11","CHAR12","CHAR13","CHAR14","CHAR15","CHAR16"
& ,"NUM1","NUM2","NUM3","NUM4","NUM5","NUM6","NUM7","NUM8","NUM9","NUM10","NUM11","NUM12","NUM13","NUM14","NUM15","NUM16")
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  NBSPE += 1
  FLDSPE(NBSPE) = [F:ATZ]CODZONE
  TYPSPE(NBSPE) = [F:ATY]TYPTYP
 Endif
Next

Call EXISTE_ADX("","","SPETRIGGER",OKTRT) From ORDSYS

N   = 0
NEWAUDIT = 1

If OKTRT>0
 Onerrgo RIEN
 ACTION = "AVTRIG"
 Gosub ACTION From SPETRIGGER
 Onerrgo
Endif

Case BASE
 When 1 : Gosub DEFTRI_ORA : # Oracle
 When 2 : Gosub DEFTRI_SQL : # Sql
Endcase

If OKTRT>0
 Onerrgo RIEN
 ACTION = "DEFTRIG"
 Gosub ACTION From SPETRIGGER
 Onerrgo
Endif

End

#################################################################
## Syntaxe sous oracle (PL/SQL)
#################################################################
## DOSSIER        ## Code du dosssier
## TABLE          ## Nom de la table
## NOMTRIG        ## Extension du trigger (INS,UPD ou DEL)
## ACTION         ## Action effectuée (Insert, Update ou Delete)
## NBCOL          ## Nb de colonnes auditées
## LISCOL         ## Liste des colonnes séparées par des virgules
## CONDITION      ## Condition de déclenchement
## TABLOGIN       ## Nom de la table de login (ALOGIN)
## TABAUDITH      ## Nom de la table d'audit (AUDITH)
## TABAUDITL      ## Nom de la table de détail audit (AUDITL)
## TABAUDITBI     ## Nom de la table d'audit BI (AUDITBI)
## OLDCLE1        ## Champ "première partie de clé", ancienne valeur
## NEWCLE1        ## Champ "première partie de clé", nouvelle valeur
## OLDCLE2        ## Champ "deuxième partie de clé", ancienne valeur
## NEWCLE2        ## Champ "deuxième partie de clé", nouvelle valeur
## INDICE         ## Indice de boucle
## ADOCHAMP       ## Nom "adonix" du champ
## OLDCHAMP       ## Nom "BBD" de la colonne, ancienne valeur
## NEWCHAMP       ## Nom "BBD" de la colonne, nouvelle valeur
## WORKFLOW       ## Valeur du flag workflow
## BI             ## Valeur du flag BI
#################################################################
$DEFTRI_ORA
N += 1 : T(N) = "Declare"
N += 1 : T(N) = " Type TABCOL is table of VARCHAR(50)"
N += 1 : T(N) = "  index by BINARY_INTEGER;"
N += 1 : T(N) = " Type TABVAL is table of VARCHAR(250)"
N += 1 : T(N) = "  index by BINARY_INTEGER;"
N += 1 : T(N) = " sesbd  BINARY_INTEGER;"
N += 1 : T(N) = " sesnum VARCHAR(20);"
N += 1 : T(N) = " x3user VARCHAR(50);"
N += 1 : T(N) = " osuser VARCHAR(50);"
N += 1 : T(N) = " adrcli VARCHAR(50);"
N += 1 : T(N) = " x3seq  BINARY_INTEGER;"
N += 1 : T(N) = " x3seqbi BINARY_INTEGER;"
N += 1 : T(N) = " x3evt  VARCHAR(50);"
N += 1 : T(N) = " heusys VARCHAR(50);"
N += 1 : T(N) = " cle1   VARCHAR(250);"
N += 1 : T(N) = " cle2   VARCHAR(250);"
For I=1 To MAXFIELDS :  N += 1 : T(N) = " char"+num$(I)+" VARCHAR(80);" : Next
For I=1 To MAXFIELDS :  N += 1 : T(N) = " num"+num$(I)+"  NUMBER(15,2);" : Next
N += 1 : T(N) = " blank  VARCHAR(1);"
N += 1 : T(N) = " datsys DATE;"
N += 1 : T(N) = " colnam TABCOL;"
N += 1 : T(N) = " oldval TABVAL;"
N += 1 : T(N) = " newval TABVAL;"
N += 1 : T(N) = " nbcol  BINARY_INTEGER;"
N += 1 : T(N) = " zi     BINARY_INTEGER;"
If NEWAUDIT
 N += 1 : T(N) = " oldcle1   VARCHAR(250);"
 N += 1 : T(N) = " oldcle2   VARCHAR(250);"
 For I=1 To MAXFIELDS :  N += 1 : T(N) = " oldchar"+num$(I)+" VARCHAR(80);" : Next
 For I=1 To MAXFIELDS :  N += 1 : T(N) = " oldnum"+num$(I)+" NUMBER(15,2);" : Next
Endif
N += 1 : T(N) = "Begin"
N += 1 : T(N) = " blank := ' ';"
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = " colnam(#<INDICE>#) := '#<ADOCHAMP>#';"
N += 1 : T(N) = " oldval(#<INDICE>#) := #<OLDCHAMP>#;"
N += 1 : T(N) = " newval(#<INDICE>#) := #<NEWCHAMP>#;"
N += 1 : T(N) = "&&"
N += 1 : T(N) = " Select trunc(sysdate,'DD'),to_char(sysdate,'HH24MISS')"
N += 1 : T(N) = "  into datsys,heusys from DUAL;"
N += 1 : T(N) = " Select SEQ_#<TABAUDITBI>#.NEXTVAL"
N += 1 : T(N) = "  into x3seqbi from DUAL;"
N += 1 : T(N) = " sesbd  := userenv('SESSIONID');"
N += 1 : T(N) = " sesnum := to_char(sesbd);"
N += 1 : T(N) = " Begin"
N += 1 : T(N) = "  Select ADOUSR_0,SYSUSR_0,ADRCLI_0"
N += 1 : T(N) = "   into x3user,osuser,adrcli from #<TABLOGIN>#"
N += 1 : T(N) = "   where BDDID_0=sesnum and FLG_0=2;"
N += 1 : T(N) = "   Exception when NO_DATA_FOUND then"
N += 1 : T(N) = "   Begin"
N += 1 : T(N) = "    x3user := blank;"
N += 1 : T(N) = "    osuser := 'External';"
N += 1 : T(N) = "    adrcli := 'Unknown';"
N += 1 : T(N) = "   End;"
N += 1 : T(N) = " End;"
N += 1 : T(N) = " nbcol := #<NBCOL>#;"
N += 1 : T(N) = " x3evt := '#<ACTION>#';"
Case OPERATION
 When "I","U"
  N += 1 : T(N) = " cle1  := #<NEWCLE1>#;"
  N += 1 : T(N) = " cle2  := #<NEWCLE2>#;"
  For I=1 To MAXFIELDS :  N += 1 : T(N) = " char"+num$(I)+"  := #<NEWCHAR"+num$(I)+">#;" : Next
  For I=1 To MAXFIELDS :  N += 1 : T(N) = " num"+num$(I)+"  := #<NEWNUM"+num$(I)+">#;" : Next
  If NEWAUDIT
   N += 1 : T(N) = " oldcle1 := #<OLDCLE1>#;"
   N += 1 : T(N) = " oldcle2 := #<OLDCLE2>#;"
   For I=1 To MAXFIELDS :  N += 1 : T(N) = " oldchar"+num$(I)+"  := #<OLDCHAR"+num$(I)+">#;" : Next
   For I=1 To MAXFIELDS :  N += 1 : T(N) = " oldnum"+num$(I)+"  := #<OLDNUM"+num$(I)+">#;" : Next
  Endif
 When "D"
  N += 1 : T(N) = " cle1 := #<OLDCLE1>#;"
  N += 1 : T(N) = " cle2 := #<OLDCLE2>#;"
  For I=1 To MAXFIELDS :  N += 1 : T(N) = " char"+num$(I)+"  := #<OLDCHAR"+num$(I)+">#;" : Next
  For I=1 To MAXFIELDS :  N += 1 : T(N) = " num"+num$(I)+"  := #<OLDNUM"+num$(I)+">#;" : Next
Endcase
If OPERATION="U" & NEWAUDIT
 Gosub UPDORA
Else
 Gosub ORA_TETE
Endif
N += 1 : T(N) = "End;"
Return

$ORA_TETE
N += 1 : T(N) = "  Insert into #<TABAUDITBI>#"
N += 1 : T(N) = "   (SEQ_0,EVT_0,TBL_0,DAT_0,HOU_0,ADOUSR_0,SYSUSR_0"
N += 1 : T(N) = "   ,ADRCLI_0,ID1_0,ID2_0,STA_0,STABI_0"
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",CHAR"+num$(I)+"_0" : Next
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",NUM"+num$(I)+"_0" : Next
For I=1 To NBSPE
 T(N) += ","+FLDSPE(I)+"_0"
Next I
T(N) += ")"
N += 1 : T(N) = "   values (x3seqbi,x3evt,'#<TABLE>#',datsys,heusys,x3user,osuser"
N += 1 : T(N) = "   ,adrcli,cle1,cle2,#<WORKFLOW>#,#<BI>#"
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",char"+num$(I) : Next
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",num"+num$(I) : Next
For I=1 To NBSPE
 T(N) += ","
 Case TYPSPE(I)
  When 1,2,3,4,5,6 :  T(N) += "0"
  When 7           :  T(N) += "' '"
  When 8           :  T(N) += "datsys"
 Endcase
Next I
T(N) += ");"
Return

$UPDORA
N += 1 : T(N) = " If (oldcle1=cle1 and oldcle2=cle2) then"
Gosub ORA_TETE
N += 1 : T(N) = " Elsif (oldcle1!=cle1 or oldcle2!=cle2) then"
N += 1 : T(N) = "  x3evt := 'DELETE'; "
N += 1 : T(N) = "  Insert into #<TABAUDITBI>#"
N += 1 : T(N) = "   (SEQ_0,EVT_0,TBL_0,DAT_0,HOU_0,ADOUSR_0,SYSUSR_0"
N += 1 : T(N) = "   ,ADRCLI_0,ID1_0,ID2_0,STA_0,STABI_0"
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",CHAR"+num$(I)+"_0" : Next
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",NUM"+num$(I)+"_0" : Next
For I=1 To NBSPE
 T(N) += ","+FLDSPE(I)+"_0"
Next I
T(N) += ")"
N += 1 : T(N) = "   values (x3seqbi,x3evt,'#<TABLE>#',datsys,heusys,x3user,osuser"
N += 1 : T(N) = "   ,adrcli,oldcle1,oldcle2,#<WORKFLOW>#,#<BI>#"
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",oldchar"+num$(I) : Next
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",oldnum"+num$(I) : Next
For I=1 To NBSPE
 T(N) += ","
 Case TYPSPE(I)
  When 1,2,3,4,5,6 :  T(N) += "0"
  When 7           :  T(N) += "' '"
  When 8           :  T(N) += "datsys"
 Endcase
Next I
T(N) += ");"
N += 1 : T(N) = "  x3evt := 'INSERT'; "
N += 1 : T(N) = "  Select SEQ_#<TABAUDITBI>#.NEXTVAL"
N += 1 : T(N) = "  into x3seqbi from DUAL;"
Gosub ORA_TETE
N += 1 : T(N) = " End if;"
Return


#################################################################
## Syntaxe sous Sql-server (TRANSAC-SQL)
#################################################################
$DEFTRI_SQL
#103967
#N += 1 : T(N) = "IF NOT (UPDATE (UPDTICK_0))"
N += 1 : T(N) = "Begin"
N += 1 : T(N) = "!!nbval>0!! If exists(Select * From Inserted"
N += 1 : T(N) = "!!nbval>0!! Where #<CONDITION>#)"
N += 1 : T(N) = "!!nbval>0!! Begin"
N += 1 : T(N) = "  Declare @blank   NVARCHAR(1)"
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = "  Declare @colnam#<INDICE># NVARCHAR(20)"
If OPERATION<>"I"
 N += 1 : T(N) = "  Declare @oldval#<INDICE># NVARCHAR(250)"
Endif
If OPERATION<>"D"
 N += 1 : T(N) = "  Declare @newval#<INDICE># NVARCHAR(250)"
Endif
N += 1 : T(N) = "&&"
N += 1 : T(N) = "  Declare @datsys  DATETIME"
N += 1 : T(N) = "  Declare @heusys  NVARCHAR(10)"
N += 1 : T(N) = "  Declare @hh      NVARCHAR(2)"
N += 1 : T(N) = "  Declare @mm      NVARCHAR(2)"
N += 1 : T(N) = "  Declare @ss      NVARCHAR(2)"
N += 1 : T(N) = "  Declare @x3user  NVARCHAR(5)"
N += 1 : T(N) = "  Declare @osuser  NVARCHAR(20)"
N += 1 : T(N) = "  Declare @adrcli  NVARCHAR(30)"
N += 1 : T(N) = "  Declare @x3seq   INT"
N += 1 : T(N) = "  Declare @x3seqbi   INT"
N += 1 : T(N) = "  Declare @x3evt   NVARCHAR(10)"
N += 1 : T(N) = "  Declare @cle1    NVARCHAR(250)"
N += 1 : T(N) = "  Declare @cle2    NVARCHAR(250)"
For I=1 To MAXFIELDS :  N += 1 : T(N) += "  Declare @char"+num$(I)+"  NVARCHAR(50)" : Next
For I=1 To MAXFIELDS :  N += 1 : T(N) += "  Declare @num"+num$(I)+"  decimal(15,2)" : Next
N += 1 : T(N) = "  Declare @ocle1   NVARCHAR(250)"
N += 1 : T(N) = "  Declare @ocle2   NVARCHAR(250)"
If NEWAUDIT
 For I=1 To MAXFIELDS :  N += 1 : T(N) += "  Declare @oldchar"+num$(I)+"  NVARCHAR(50)" : Next
 For I=1 To MAXFIELDS :  N += 1 : T(N) += "  Declare @oldnum"+num$(I)+"  decimal(15,2)" : Next
Endif
N += 1 : T(N) = "  set nocount on"
N += 1 : T(N) = "  set @blank = ' '"
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = "  set @colnam#<INDICE># = '#<ADOCHAMP>#'"
N += 1 : T(N) = "&&"

N += 1 : T(N) = "  set @datsys = getdate()"
N += 1 : T(N) = "  set @hh = datename(hour,@datsys)"
N += 1 : T(N) = "  set @mm = datename(minute,@datsys)"
N += 1 : T(N) = "  set @ss = datename(second,@datsys)"
N += 1 : T(N) = "  If len(@hh)=1 set @hh = '0'+@hh"
N += 1 : T(N) = "  If len(@mm)=1 set @mm = '0'+@mm"
N += 1 : T(N) = "  If len(@ss)=1 set @ss = '0'+@ss"
N += 1 : T(N) = "  set @heusys = @hh+@mm+@ss"

N += 1 : T(N) = "  set @datsys = cast((cast(@datsys as date)) as datetime)" : # 112792 CCl raz the hour/minute/second value in the datetime value.

N += 1 : T(N) = "  Select TOP 1"
N += 1 : T(N) = "    @x3user = ADOUSR_0"
N += 1 : T(N) = "  , @osuser = SYSUSR_0"
N += 1 : T(N) = "  , @adrcli = ADRCLI_0"
N += 1 : T(N) = "  From #<DOSSIER>#.#<TABLOGIN>#"
N += 1 : T(N) = "  Where BDDID_0=CONVERT(nvarchar(10),@@spid) and FLG_0=2"
N += 1 : T(N) = "  If @x3user is null"
N += 1 : T(N) = "  Begin"
N += 1 : T(N) = "   set @x3user = @blank"
N += 1 : T(N) = "   set @osuser = 'External'"
N += 1 : T(N) = "   set @adrcli = 'Unknown'"
N += 1 : T(N) = "  End"
N += 1 : T(N) = "  set @x3evt = '#<ACTION>#'"

Case OPERATION
 When "D" : Gosub SQL_DEL
 When "U" : Gosub SQL_UPD
 When "I" : Gosub SQL_INS
Endcase

N += 1 : T(N) = "!!nbval>0!! End"
N += 1 : T(N) = "  set nocount off"
N += 1 : T(N) = "End"

Return

$SQL_INS
N += 1 : T(N) = "  Select"
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = "   @newval#<INDICE># = #<NEWCHAMP># , "
N += 1 : T(N) = "&&"
N += 1 : T(N) = "     @cle1 = #<NEWCLE1>#"
N += 1 : T(N) = "   , @cle2 = #<NEWCLE2>#"
For I=1 To MAXFIELDS :  N += 1 : T(N) += "   , @char"+num$(I)+" = #<NEWCHAR"+num$(I)+">#" : Next
For I=1 To MAXFIELDS :  N += 1 : T(N) += "   , @num"+num$(I)+" = #<NEWNUM"+num$(I)+">#" : Next
N += 1 : T(N) = "  From Inserted"
Gosub SQL_TETE
#N += 1 : T(N) = "&&<NBCOL>&&"
Return

$SQL_TETE
N += 1 : T(N) = "  Insert into #<DOSSIER>#.#<TABAUDITBI>#"
N += 1 : T(N) = "   (SEQ_0,EVT_0,TBL_0,DAT_0,HOU_0,ADOUSR_0,SYSUSR_0"
N += 1 : T(N) = "   ,ADRCLI_0,ID1_0,ID2_0,STA_0,STABI_0"
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",CHAR"+num$(I)+"_0" : Next
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",NUM"+num$(I)+"_0" : Next
For I=1 To NBSPE :   T(N) += ","+FLDSPE(I)+"_0" :  Next I
T(N) += ")"
N += 1 : T(N) = "   values (-@@spid,@x3evt,'#<TABLE>#',@datsys,@heusys,@x3user,@osuser" : # mb 28.1.2010
N += 1 : T(N) = "  , @adrcli,@cle1,@cle2,#<WORKFLOW>#,#<BI>#"
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@char"+num$(I) : Next
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@num"+num$(I) : Next
For I=1 To NBSPE
 T(N) += ","
 Case TYPSPE(I)
  When 1,2,3,4,5,6 :   T(N) += "0"
  When 7           :   T(N) += "' '"
  When 8           :   T(N) += "@datsys"
 Endcase
Next I
T(N) += ")"
N += 1 : T(N) = "  set @x3seq = @@identity" : # mb 28.1.2010
N += 1 : T(N) = "  Update #<DOSSIER>#.#<TABAUDITBI># set SEQ_0 = @x3seq where ROWID=@x3seq" : # mb 28.1.2010
Return

$SQL_UPD
N += 1 : T(N) = "  Declare nouveau Cursor For"
N += 1 : T(N) = "  Select #<NEWCLE1># , #<NEWCLE2>#"
N += 1 : For I=1 To 7  : T(N) += ",#<NEWCHAR"+num$(I)+">#" : Next
N += 1 : For I=8 To MAXFIELDS  : T(N) += ",#<NEWCHAR"+num$(I)+">#" : Next
N += 1 : For I=1 To 7  : T(N) += ",#<NEWNUM"+num$(I)+">#" : Next
N += 1 : For I=8 To MAXFIELDS  : T(N) += ",#<NEWNUM"+num$(I)+">#" : Next
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = "  , #<NEWCHAMP>#"
N += 1 : T(N) = "&&"
N += 1 : T(N) = "  From Inserted"
N += 1 : T(N) = "  Open nouveau"

N += 1 : T(N) = "  Declare ancien Cursor For"
N += 1 : T(N) = "  Select #<OLDCLE1># , #<OLDCLE2>#"
If NEWAUDIT
  N += 1 : For I=1 To 7  : T(N) += ",#<OLDCHAR"+num$(I)+">#" : Next
  N += 1 : For I=8 To MAXFIELDS  : T(N) += ",#<OLDCHAR"+num$(I)+">#" : Next
  N += 1 : For I=1 To 7  : T(N) += ",#<OLDNUM"+num$(I)+">#" : Next
  N += 1 : For I=8 To MAXFIELDS  : T(N) += ",#<OLDNUM"+num$(I)+">#" : Next
Endif
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = "  , #<OLDCHAMP>#"
N += 1 : T(N) = "&&"
N += 1 : T(N) = "  From Deleted"
N += 1 : T(N) = "  Open ancien"

N += 1 : T(N) = "  Fetch Next From nouveau into @cle1 , @cle2"
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@char"+num$(I) : Next
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@num"+num$(I) : Next
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = "   , @newval#<INDICE>#"
N += 1 : T(N) = "&&"
N += 1 : T(N) = "  Fetch Next From ancien  into @ocle1 , @ocle2"
If NEWAUDIT
 N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@oldchar"+num$(I) : Next
 N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@oldnum"+num$(I) : Next
Endif
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = "   , @oldval#<INDICE>#"
N += 1 : T(N) = "&&"
N += 1 : T(N) = "  While @@FETCH_STATUS = 0"
N += 1 : T(N) = "  Begin"
If NEWAUDIT
 Gosub SQL_TETE_UPD
Else
 Gosub SQL_TETE
Endif
Return

$SQL_TETE_UPD
N += 1 : T(N) = "-- Tests de détection de changement de clé "
N += 1 : T(N) = "If @ocle1<>@cle1 or @ocle2<>@cle2 "
N += 1 : T(N) = "  Begin"
N += 1 : T(N) = "  -- Si Changement de clé"
N += 1 : T(N) = "  -- On insère une evement DELETE pour les anciennes valeurs de clé"
N += 1 : T(N) = "  set @x3evt = 'DELETE' "
N += 1 : T(N) = "  Insert into #<DOSSIER>#.#<TABAUDITBI>#"
N += 1 : T(N) = "  (SEQ_0,EVT_0,TBL_0,DAT_0,HOU_0,ADOUSR_0,SYSUSR_0"
N += 1 : T(N) = "  ,ADRCLI_0,ID1_0,ID2_0,STA_0,STABI_0"
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",CHAR"+num$(I)+"_0" : Next
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",NUM"+num$(I)+"_0" : Next
For I=1 To NBSPE :  T(N) += ","+FLDSPE(I)+"_0" : Next I
T(N) += ")"
N += 1 : T(N) = "    values (-@@spid,@x3evt,'#<TABLE>#',@datsys,@heusys,@x3user,@osuser" : # mb 28.1.2010
N += 1 : T(N) = "  , @adrcli,@ocle1,@ocle2,#<WORKFLOW>#,#<BI>#"
N += 1 : For I=1 To MAXFIELDS  : T(N) += ", @oldchar"+num$(I) : Next
N += 1 : For I=1 To MAXFIELDS  : T(N) += ", @oldnum"+num$(I) : Next
For I=1 To NBSPE
 T(N) += ","
 Case TYPSPE(I)
  When 1,2,3,4,5,6 :   T(N) += "0"
  When 7           :   T(N) += "' '"
  When 8               T(N) += "@datsys"
 Endcase
Next I
T(N) += ")"
N += 1 : T(N) = "  set @x3seq = @@identity" : # mb 28.1.2010
N += 1 : T(N) = "  Update #<DOSSIER>#.#<TABAUDITBI># set SEQ_0 = @x3seq where ROWID=@x3seq" : # mb 28.1.2010
N += 1 : T(N) = "  "
N += 1 : T(N) = "   -- On insère une evement DELETE pour les anciennes valeurs de clé"
N += 1 : T(N) = "   set @x3evt = 'INSERT' "
Gosub SQL_TETE
N += 1 : T(N) = "  End"
N += 1 : T(N) = "  "
N += 1 : T(N) = "Else  "
N += 1 : T(N) = "  Begin"
Gosub SQL_TETE
N += 1 : T(N) = "  End"
N += 1 : T(N) = "  Fetch Next From nouveau into @cle1 , @cle2"
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@char"+num$(I) : Next
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@num"+num$(I) : Next
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = "   , @newval#<INDICE>#"
N += 1 : T(N) = "&&"
N += 1 : T(N) = "  Fetch Next From ancien  into @ocle1 , @ocle2"
If NEWAUDIT
 N += 1 : For I=1 To MAXFIELDS  : T(N) += ", @oldchar"+num$(I) : Next
 N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@oldnum"+num$(I) : Next
Endif
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = "   , @oldval#<INDICE>#"
N += 1 : T(N) = "&&"
N += 1 : T(N) = "  End"
N += 1 : T(N) = "  Close nouveau"
N += 1 : T(N) = "  Close ancien"
N += 1 : T(N) = "  Deallocate nouveau"
N += 1 : T(N) = "  Deallocate ancien"
Return


$SQL_DEL
N += 1 : T(N) = "  Declare ancien Cursor For"
N += 1 : T(N) = "  Select #<OLDCLE1># , #<OLDCLE2>#"
N += 1 : For I=1 To 7  : T(N) += ",#<OLDCHAR"+num$(I)+">#" : Next
N += 1 : For I=8 To MAXFIELDS  : T(N) += ",#<OLDCHAR"+num$(I)+">#" : Next
N += 1 : For I=1 To 7  : T(N) += ",#<OLDNUM"+num$(I)+">#" : Next
N += 1 : For I=8 To MAXFIELDS  : T(N) += ",#<OLDNUM"+num$(I)+">#" : Next
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = "  , #<OLDCHAMP>#"
N += 1 : T(N) = "&&"
N += 1 : T(N) = "  From Deleted"
N += 1 : T(N) = "  Open ancien"
N += 1 : T(N) = "  Fetch Next From ancien  into @cle1 , @cle2"
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@char"+num$(I): Next
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@num"+num$(I) : Next
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = "   , @oldval#<INDICE>#"
N += 1 : T(N) = "&&"
N += 1 : T(N) = "  While @@FETCH_STATUS = 0"
N += 1 : T(N) = "  Begin"
Gosub SQL_TETE

N += 1 : T(N) = "  Fetch Next From ancien  into @cle1 , @cle2"
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@char"+num$(I): Next
N += 1 : For I=1 To MAXFIELDS  : T(N) += ",@num"+num$(I) : Next
N += 1 : T(N) = "&&<NBCOL>&&"
N += 1 : T(N) = "   , @oldval#<INDICE>#"
N += 1 : T(N) = "&&"
N += 1 : T(N) = "  End"
N += 1 : T(N) = "  Close ancien"
N += 1 : T(N) = "  Deallocate ancien"
Return


#---------------------------#
$RIEN
Resume

