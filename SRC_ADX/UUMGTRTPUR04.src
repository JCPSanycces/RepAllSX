$MAJV6_AVUOH #attention, étiquette appelée aussi depuis le UUMGTRTPUR05
    #----- Alimentation société, indicateurs relance sur l'entête de commande -----#
    Call PARAML([F:UOH]POHFCY,"SALDSPWEU",[F:UOH]DSPWEU) From ADOVAL
    Call PARAML([F:UOH]POHFCY,"SALDSPVOU",[F:UOH]DSPVOU) From ADOVAL

    Gosub LECT_BPSUOH
    [F:UOH]FUPFLG=[F:BPS]FUPFLG
    [F:UOH]OCNFLG=[F:BPS]OCNFLG
    [L]WEECICT   =[F:BPS]EECICT
    [L]WEECLOC   =[F:BPS]EECLOC
Return
