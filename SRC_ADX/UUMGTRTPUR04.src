$MAJV7_AVUOH
Call PARAML([F:UOH]POHFCY,"SALDSPWEU",WDSPWEU) From ADOVAL
Call PARAML([F:UOH]POHFCY,"SALDSPVOU",WDSPVOU) From ADOVAL
Return

##############################################################################################
$MAJ_UOH #attention, étiquette appelée aussi depuis le UUMGTRTPUR05
    # Issue 88474 - 2013-05-07 by SR : Ligne déplacée
    #----- Chargement arrondi devise commande -----#
    Gosub LECT_TCUCUR
    # Issue 88474 - 2013-05-06 by SR
    If val(VERSION)<GMIGX3VER60
      Gosub LECT_BPSUOH
      #----- Alimentation des informations douanières si commande classique -----#
      If [F:UOH]POHTYP<>2
        #----- Alimentation incoterm et lieu de transport CEE -----#
        If [F:UOH]EECICT=""
          [F:UOH]EECICT=[F:BPS]EECICT : # Incoterm
        Endif
        If GACTDEB=2 & [F:UOH]EECLOC=0
          [F:UOH]EECLOC=[F:BPS]EECLOC : # Lieu de transport CEE
        Endif
        #----- Alimentation identification CEE du tiers facturant -----#
        If GACTDEB=2 & [F:UOH]EECNUM=""
          Gosub LECT_BPRI
          [F:UOH]EECNUM=[F:BPR]EECNUM : # Identification CEE
        Endif
      Endif

      If [F:UOH]BPOADD=""
        #----- Si fournisseur divers, adr.commande = adr.expédition -----#
        If [F:BPS]BPSTYP=3
          [F:UOH]BPOADD      =[F:UOH]BPAADD
          [F:UOH]BPONAM(0)   =[F:UOH]BPRNAM(0)
          [F:UOH]BPONAM(1)   =[F:UOH]BPRNAM(1)
          [F:UOH]BPOADDLIG(0)=[F:UOH]BPAADDLIG(0)
          [F:UOH]BPOADDLIG(1)=[F:UOH]BPAADDLIG(1)
          [F:UOH]BPOADDLIG(2)=[F:UOH]BPAADDLIG(2)
          [F:UOH]BPOPOSCOD   =[F:UOH]POSCOD
          [F:UOH]BPOCTY      =[F:UOH]CTY
          [F:UOH]BPOSAT      =[F:UOH]SAT
          [F:UOH]BPOCRY      =[F:UOH]CRY
          [F:UOH]BPOCRYNAM   =[F:UOH]CRYNAM
        #----- alimentation code adresse expédition -----#
        Else
          [F:UOH]BPOADD=[F:BPS]BPAADD
          If GACTSAD=2 : # Stockage systématique de l'adresse !
            #----- Lecture BPARTNER si nécessaire -----#
            Gosub LECT_BPRS
            #----- Lecture de l'adresse si nécessaire -----#
            Gosub LECT_BPAS
            #-----
            [F:UOH]BPONAM(0)    = [F:BPR]BPRNAM(0)
            [F:UOH]BPONAM(1)    = [F:BPR]BPRNAM(1)
            [F:UOH]BPOADDLIG(0) = [F:BPA]BPAADDLIG(0)
            [F:UOH]BPOADDLIG(1) = [F:BPA]BPAADDLIG(1)
            [F:UOH]BPOADDLIG(2) = [F:BPA]BPAADDLIG(2)
            [F:UOH]BPOCRY       = [F:BPA]CRY
            [F:UOH]BPOCRYNAM    = [F:BPA]CRYNAM
            [F:UOH]BPOSAT       = [F:BPA]SAT
            [F:UOH]BPOPOSCOD    = [F:BPA]POSCOD
            [F:UOH]BPOCTY       = [F:BPA]CTY
          Endif
        Endif
      Endif

      #----- Alimentation code adresse fournisseur payé -----#
      If [F:UOH]BPAPAY=""
        If [F:BPS]BPRPAY=[F:UOH]BPRPAY
          [F:UOH]BPAPAY=[F:BPS]BPAPAY
        Else
          Gosub LECT_BPSP
          [F:UOH]BPAPAY=[F:BPS]BPAADD
        Endif
      Endif

      #----- Alimentation code adresse fournisseur facturant -----#
      If [F:UOH]BPAINV=""
        If [F:BPS]BPSINV=[F:UOH]BPSINV
          [F:UOH]BPAINV=[F:BPS]BPAINV
        Else
          Gosub LECT_BPSI
          [F:UOH]BPAINV=[F:BPS]BPAADD
        Endif
      Endif

      #----- Alimentation champs pour le multi-référenciels comptabilité -----#
      If dim([F:UOH]DIE)>0 & [F:UOH]DIE(0)=""
        For I=1 To max(GNBDIE,GOPTCANA)
          [F:UOH]DIE(I-1)=GDIE(I)
        Next I
      Endif
      #----- Alimentation éléments et taxes ligne tarif -----#
      Gosub LECT_BPSUOH

      #-----
      Call TYPREM(2,[F:BPS]PLISTC) From TRTPRICE

      #-----
      For I=0 To dim([F:UOH]INVDTAVAT1)-1
        If GINVDTALIN(I)<>0 & GNPRNOTFLG(I)=1
          [F:UOH]INVDTALIN1(I)=GINVDTALIN(I)
          If [F:UOH]INVDTAVAT1(I)=""
            WJ=find(GINVDTALIN(I),WPFINUM(0..WNBPFI))
            If WJ>0 & WPFIVATRUL(WJ-1)=2
              WJTVC=find([F:BPS]VACBPR+'/'+WPFIVACITM(WJ-1),WTVCCLE(0..NBTVC))
              If WJTVC>0
                [F:UOH]INVDTAVAT1(I)=WTVCVAT(WJTVC-1)
              Endif
            Endif
          Endif
        Endif
      Next I
    Endif
    Gosub MAJ_UOHUOQ
    If GOK<1 : Return : Endif

  # Issue 88474 - 2013-05-06 by SR
    If val(VERSION)<GMIGX3VER60
      #----- Chargement HT et TTC commande en devise société -----#
      Call COURMNT([F:UOH]CUR,GLOCALDEV,GLOCALDEV,[F:UOH]CHGTYP,[F:UOH]ORDDAT,1,
&                [F:UOH]TOTORD,[F:UOH]TOTORDL,[F:UOH]CHGCOE,STAT) From TRTDEV
      If STAT <> 0 Then
        # FGR 12/01/2010 : X3SUIVI61184
        Call ECR_TRACE("     1-File UPORDER"-[F:UOH]POHNUM+"/"-num$([F:UOH]REVNUM)+", Error ="-num$(STAT),-1) From GESECRAN
      Endif
      Call COURMNT([F:UOH]CUR,GLOCALDEV,GLOCALDEV,[F:UOH]CHGTYP,[F:UOH]ORDDAT,1,
&                [F:UOH]TTVORD,[F:UOH]TTVORDL,[F:UOH]CHGCOE,STAT) From TRTDEV
      If STAT <> 0 Then
        # FGR 12/01/2010 : X3SUIVI61184
        Call ECR_TRACE("     2-File UPORDER"-[F:UOH]POHNUM+"/"-num$([F:UOH]REVNUM)+", Error ="-num$(STAT),-1) From GESECRAN
      Endif
    Endif

Return

##############################################################################################
$MAJV7_UOH #attention, étiquette appelée aussi depuis le UUMGTRTPUR05
Return
########################################################################
$LECT_TCUCUR
    If [F:TCU]CUR<>[F:UOH]CUR
      Read [TCU] TCU0=[F:UOH]CUR
      If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
    Else
      WRND=[F:TCU]CURRND
    Endif
Return
###################################
$LECT_BPSUOH
If [F:BPS]BPSNUM<>[F:UOH]BPSNUM
  WBPS=[F:UOH]BPSNUM
  Gosub LECT_BPS
Endif
Return
$LECT_BPSP
If [F:BPS]BPSNUM<>[F:UOH]BPRPAY
  WBPS=[F:UOH]BPRPAY
  Gosub LECT_BPS
Endif
Return
$LECT_BPSI
If [F:BPS]BPSNUM<>[F:UOH]BPSINV
  WBPS=[F:UOH]BPSINV
  Gosub LECT_BPS
Endif
Return
$LECT_BPS
  Read [BPS] BPS0=WBPS : If fstat  Raz [F:BPS] : Endif
Return
#####################################
$LECT_BPRI
If [F:BPR]BPRNUM<>[F:UOH]BPSINV
  WBPR=[F:UOH]BPSINV
  Gosub LECT_BPR
Endif
Return
$LECT_BPRS
If [F:BPR]BPRNUM<>[F:UOH]BPSNUM
  WBPR=[F:UOH]BPSNUM
  Gosub LECT_BPR
Endif
Return
$LECT_BPR
  Read [BPR] BPR0=WBPR : If fstat Raz [F:BPR] : Endif
Return
#####################################
$LECT_BPAS
If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:UOH]BPSNUM | [F:BPA]BPAADD<>[F:UOH]BPOADD
  Read [BPA] BPA0=1;[F:UOH]BPSNUM;[F:UOH]BPOADD
  If fstat  Raz [F:BPA] : Endif
Endif
Return

#################################################
$MAJ_UOHUOQ
   # Issue 88474 - 2013-05-06 by SR
    If val(VERSION)<GMIGX3VER60
      Gosub BOUCLE1_UOQ
      #----- Reprise des éléments existant sur l'entête de commande -----#
      If dim([F:UOHM]INVDTA)>0
        Raz K
        For I=0 To dim([F:UOHM]INVDTA)-1
          If [F:UOHM]INVDTA(I)<>0
            J=[L]NBFAC
            WJ=find([F:UOHM]INVDTA(I),WPFINUM(0..WNBPFI))
            Gosub RECUP_PFI From UUMGTRTPUR00
            [L]INVDTA   (J)=[F:UOHM]INVDTA(I)
            [L]INVDTAAMT(J)=[F:UOHM]INVDTAAMT(I)
            [L]INVCPLAMT(J)=[F:UOHM]INVCPLAMT(I)
            If [F:PFI]DACLIN=2
              [L]INVLINFLG(J)=6
            Else
              [L]INVLINFLG(J)=[F:PFI]DSPLIN
            Endif
            [L]DEBCDT   (J)=max(1,[F:PFI]INCDCR)
            SIGN=1-2*([L]DEBCDT(J)-1)
            If [F:UOHM]AMTCOD(I)=2  : #----- Montant
              [L]INVLINAMT(J)=[F:UOHM]INVDTAAMT(I)*SIGN
            Elsif [F:PFI]CLCBAS<>3 : #----- Pourcentage sur HT
              [L]INVLINAMT(J)=arr([F:UOH]TOTLINAMT*[F:UOHM]INVDTAAMT(I)/100,WRND)*SIGN
            Else                   : #----- Pourcentage sur TTC
              [L]INVLINAMT(J)=arr([F:UOH]TTVORD*[F:UOHM]INVDTAAMT(I)/100,WRND)*SIGN
            Endif
            If [F:PFI]VATRUL=2
              WJTVC=find([F:UOH]VACBPR+'/'+[F:PFI]VACITM,WTVCCLE(0..NBTVC))
              If WJTVC>0
                [L]INVDTAVAT(J)=WTVCVAT(WJTVC-1)
              Endif
            Endif
            [L]NBFAC+=1
            # Issue 79881 - 2012-02-23 by VPO : le limite d'elt de facturation répartis est de 9
            #If [F:PFI]DSPLIN>1
            If [F:PFI]DSPLIN>1 & K<9
              [F:UOH]INVDTALIN2(K)=[L]INVDTA   (J)
              [F:UOH]INVDTAVAT2(K)=[L]INVDTAVAT(J)
              K+=1
            Endif
          Endif
        Next I
      Endif
    Endif
    Gosub BOUCLE2_UOQ
Return

$BOUCLE2_UOQ
    #-----
       # Issue 88474 - 2013-05-06 by SR
    If val(VERSION)<GMIGX3VER60
      Raz WTOTLINAMT, [F:UOH]TOTLINATI
    Endif

    Link [UOQM] With [ITM]ITM0=[F:UOQM]ITMREF As [LNKQ]
    For [LNKQ]POQ0 Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM
      #  version < V6, raz des champs v6
      If val(VERSION)<GMIGX3VER60
        Gosub RAZV6_UOQ
      Endif
      #  version < V7, raz des champs v7
      If val(VERSION)<GMIGX3VER70
        Gosub RAZV7_UOQ
      Endif
      # Issue 112754 - 2016-12-19 by SR : Services en V12
      #  version < V12, raz des champs v12
      If val(VERSION)<GMIGX3VER120
         Gosub RAZV12_UOQ
      Endif
      [F:UOQ] = [F:UOQM]
     # Issue 88474 - 2013-05-06 by SR
      If val(VERSION)<GMIGX3VER60
        WPOPLIN=[F:UOQ]POPLIN
        #----- Alimentation sté, adresse facturant et expéditeur sur lignes commande -----#
        [F:UOQ]CPY      =[F:UOH]CPY
        [F:UOQ]BPAINV   =[F:UOH]BPAINV
        #----- Alimentation du type d'achat -----#
        If [F:UOQ]LINPURTYP=0  [F:UOQ]LINPURTYP=1 : Endif
        #----- Alimentation du type de ligne -----#
        If [F:UOQ]LINTYP=0  [F:UOQ]LINTYP=1 : Endif
        #----- Alimentation des quantités poids et volume (sauf ligne service) -----#
        If find([F:UOQ]LINTYP,1,2,4)
          Gosub LECT_ITMUOQ
          #-----
          [F:UOQ]QTYWEU=[F:ITM]ITMWEI*[F:UOQ]QTYSTU
          [F:UOQ]QTYVOU=[F:ITM]ITMVOU*[F:UOQ]QTYSTU

          WUOM1=[F:ITM]WEU
          WUOM2=[F:UOH]DSPWEU
          WQTY=[F:UOQ]QTYWEU
          Gosub CONVERT_QTY From UUMGTRTPUR00
          [F:UOQ]QTYWEU=WQTY

          WUOM1=[F:ITM]VOU
          WUOM2=[F:UOH]DSPVOU
          WQTY=[F:UOQ]QTYVOU
          Gosub CONVERT_QTY From UUMGTRTPUR00
          [F:UOQ]QTYVOU=WQTY
        Endif
        #----- Si ce n'est pas un service, qté, poids et volume pour répartition -----#
        If [F:UOQ]LINTYP<>3
          WQTYPUU=[F:UOQ]QTYPUU
          WQTYWEU=[F:UOQ]QTYWEU
          WQTYVOU=[F:UOQ]QTYVOU
        Endif
        #----- Alimentation des bases spéciales 1-3 calcul taxe -----#
        If ([F:UOQ]CLCAMT1<>0 | [F:UOQ]CLCAMT2<>0)
&         & [F:UOQ]CLCAMT3=0
&         & [F:UOQ]CLCAMT4=0
&         & [F:UOQ]CLCAMT5=0
&         & [F:UOQ]CLCAMT6=0
&         & [F:UOQ]CLCAMT7=0
          #----- Lecture ligne commande prix -----#
          Gosub LECT_UOPUOQ
          #-----
          Raz WCLCAMT, WCLCFLG
          WCLCAMT1=[F:UOQ]CLCAMT1 : WCLCFLG1=0
          WCLCAMT2=[F:UOQ]CLCAMT2 : WCLCFLG2=0
          For I=2 To 3
            Case I
              When 2 : WTAX=[F:UOP]VAT(I-1) : Gosub TRT_BASE
              When 3 : WTAX=[F:UOP]VAT(I-1) : Gosub TRT_BASE
            Endcase
          Next I
          If WCLCFLG1 | WCLCFLG2
            If WCLCFLG1  Raz [F:UOQ]CLCAMT1 : Endif
            If WCLCFLG2  Raz [F:UOQ]CLCAMT2 : Endif
            For I=2 To 3
              If WCLCFLG(I)=1
                ##Assign "[F:UOQ]CLCAMT"+num$(I) With WCLCAMT(I)
                Case I
                When 2 : [F:UOQ]CLCAMT2=WCLCAMT(I)
                When 3 : [F:UOQ]CLCAMT3=WCLCAMT(I)
                When Default
                Endcase
              Endif
            Next I
          Endif
        Endif
        #----- Calcul bases et taxes de la ligne de commande -----#
        If [F:UOQ]LINTYP<>2 & [F:UOQ]WIPSTA<2 & [F:UOQ]LINSTA<>3
          WTOTLINAMT+=[F:UOQ]LINAMT
          Gosub LECT_UOPUOQ
          If WOKUOPUOQ
            #----- Pour toutes les commandes -----#
            Gosub HMAJ_CALTAX_LIG    : # Calcul bases et taxes ligne
            #----- Si commande classique -----#
            #If [F:UOH]POHTYP=1
            #  Gosub MAJ_BASTAX_LIG  : # Màj bases et taxes pied à partir des lignes
            #  Gosub MAJ_ELEMENTS    : # Répartition éléments pied sur ligne et maj bases et taxes
            #Endif
            #-----
          Endif
          #----- Total TTC lignes -----#
          [F:UOH]TOTLINATI+=[F:UOQ]LINATI
        Endif
        #----- Mise à jour type d'engagement (HT/HTND/TTC) -----#
        If [F:UOQ]CMMTAX=0  [F:UOQ]CMMTAX=1 : Endif
        #----- Mise à jour indicateur d'engagement (0=inactif, 1=actif) -----#
        If [F:UOQ]CMMNUM<>"" & [F:UOQ]LINCLEFLG<>2
          [F:UOQ]CMMFLG=1
        Else
          [F:UOQ]CMMFLG=0
        Endif
        #----- Alimentation des nouveaux champs sous-traitance à partir des anciens -----#
        If dim([F:UOQM]MFGITM)>0    & [F:UOQ]ITMREFORI="" [F:UOQ]ITMREFORI=[F:UOQM]MFGITM    : Endif
        If dim([F:UOQM]MFGNUM)>0    & [F:UOQ]VCRNUMORI="" [F:UOQ]VCRNUMORI=[F:UOQM]MFGNUM    : Endif
        If dim([F:UOQM]OPENUM)>0    & [F:UOQ]VCRLINORI=0  [F:UOQ]VCRLINORI=[F:UOQM]OPENUM    : Endif
        If dim([F:UOQM]OPESPLNUM)>0 & [F:UOQ]VCRSEQORI=0  [F:UOQ]VCRSEQORI=[F:UOQM]OPESPLNUM : Endif
        If [F:UOQ]VCRNUMORI<>""    & [F:UOQ]VCRTYPORI=0  [F:UOQ]VCRTYPORI=10               : Endif
     Endif
        #-----
      # Issue 88474 - 2013-05-06 by SR
      If val(VERSION)<GMIGX3VER70
      # Mettre à jour les nouvelles zones V7
        [F:UOQ]NETCUR = [F:UOH]CUR # Issue 94785 - 2013-11-27 by MUARN
        [F:UOQ]CPRCOE = 1
        [F:UOQ]LINVOU = WDSPVOU
        [F:UOQ]LINWEU = WDSPWEU
        [F:UOQ]CPRCUR = GLOCALDEV
        Gosub CLC_UOQ
      Endif
      # Issue 112754 - 2017-01-26 by SR : Services
      If val(VERSION)<GMIGX3VER120
       If    [F:UOQ]POHTYP = 1 & [F:UOQ]LINTYP <> 3  & [F:UOQ]VCRTYPORI <> 10 : [F:UOQ]ITMKND = 1
       Elsif [F:UOQ]POHTYP = 1 & [F:UOQ]LINTYP = 1   & [F:UOQ]VCRTYPORI =  10 : [F:UOQ]ITMKND = 2
       Elsif [F:UOQ]POHTYP = 1 & [F:UOQ]LINTYP = 3 :   [F:UOQ]ITMKND = 2
       Elsif [F:UOQ]POHTYP = 2 : [F:UOQ]ITMKND = 1
       Endif
      Endif
      # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#      If NEWMOTEUR
#          Gosub UOQ_STK : # pour stocker ref
#          WriteB [UOQ]
#      Else
#          Write [UOQ]
#      Endif
#      If fstat
#          If NEWMOTEUR & adxwrb>1
#            Call ECR_TRACE("File UPORDERQ, Error ="-num$(fstat),1) From GESECRAN
#            Gosub UOQ_ERRTRA : # pour afficher les ref
#          Else
#            Call ECR_TRACE("File UPORDERQ(POHNUM/LINREVNUM/POPLIN/POQSEQ)="-[F:POHQ]POHNUM-num$([F:UOQ]LINREVNUM)-num$([F:UOQ]POPLIN)-num$([F:UOQ]POQSEQ)+", Error ="-num$(fstat),1) From GESECRAN
#          Endif
#          GOK=0 : Break
#      Endif
      Gosub UOQ_STK : # pour stocker ref
      WriteB [UOQ]
      If fstat
         Call ECR_TRACE("File UPORDERQ, Error ="-num$(fstat),1) From GESECRAN
         Gosub UOQ_ERRTRA : # pour afficher les ref
         GOK=0 : Break
      Endif
      # End issue 108760
     # Issue 88474 - 2013-05-06 by SR
      If val(VERSION)<GMIGX3VER60
        #----- Création lignes comptables analytiques pour commandes classiques -----#
        If [F:UOH]POHTYP=1
          Gosub LECT_UOPUOQ
          If WOKUOPUOQ
            Gosub WRITE_CAL_UOP
            If GOK<1 : Break : Endif
          Endif
        Endif
      Endif
    Next
Return

$WRITE_CAL_UOP
  Raz [F:CAL]
  [F:CAL]ABRFIC="UOP"
  [F:CAL]VCRNUM=[F:UOP]POHNUM
  [F:CAL]VCRLIN=[F:UOP]POPLIN
  [F:CAL]VCRSEQ=[F:UOP]POPSEQ
  [F:CAL]CPLCLE=num$([F:UOP]LINREVNUM)
  [F:CAL]ANALIG=1
  For I=1 To max(GNBCOA,2)
    [F:CAL]LED(I-1)=GLEDSOC(I)
    [F:CAL]COA(I-1)=GCOA(I)
  Next I
  [F:CAL]ACC(0)=[F:UOQM]LINACC
  [F:CAL]ACC(1)=[F:UOQM]LINCNA
  For I=1 To max(GNBDIE,GOPTCANA)
    [F:CAL]DIE(I-1)=GDIE(I)
    ##If evalue("dim([F:UOP]CCE"+num$(I)+")")>0
    ##  [F:CAL]CCE(I-1)=evalue("[F:UOP]CCE"+num$(I))
    ##Endif
    Case I
    When 1 : [F:CAL]CCE(I-1)=[F:UOPM]CCE1
    When 2 : [F:CAL]CCE(I-1)=[F:UOPM]CCE2
    When 3 : [F:CAL]CCE(I-1)=[F:UOPM]CCE3
    When 4 : [F:CAL]CCE(I-1)=[F:UOPM]CCE4
    When 5 : [F:CAL]CCE(I-1)=[F:UOPM]CCE5
    When 6 : [F:CAL]CCE(I-1)=[F:UOPM]CCE6
    When 7 : [F:CAL]CCE(I-1)=[F:UOPM]CCE7
    When 8 : [F:CAL]CCE(I-1)=[F:UOPM]CCE8
    When 9 : [F:CAL]CCE(I-1)=[F:UOPM]CCE9
    When Default
    Endcase
  Next I

  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR
#      Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
#      WriteB [F:CAL]
#  Else
#      Write [F:CAL]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#      Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
#    Else
#    Call ECR_TRACE("File CPTANALIN UOP 0"-[F:UOP]POHNUM-num$([F:UOP]LINREVNUM)-num$([F:UOP]POPLIN)+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Return
#  Endif
   Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
   WriteB [F:CAL]
   If fstat
      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
      Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
      GOK=0 : Return
   Endif
   # End issue 108760

Return

$LECT_UOPUOQ
If WREADUOPUOQ=0
  WOKUOPUOQ=0
  If [F:UOH]POHTYP=1
    Read [UOP] POP0=[F:UOQ]POHNUM;[F:UOQ]LINREVNUM;[F:UOQ]POPLIN;1
  Else
    Filter [UOP] Where POHNUM=[F:UOQ]POHNUM & LINREVNUM=[F:UOQ]LINREVNUM & POPLIN=[F:UOQ]POPLIN & POPDAT>=[F:UOQ]DEMRCPDAT
    Read [UOP] POP1 First
    Filter [UOP]
  Endif
  If fstat
     Raz [F:UOP]
  Else
     WOKUOPUOQ=1
  Endif
  WREADUOPUOQ=1
Endif
Return

$BOUCLE1_UOQ
    Link [UOQM] With [ITM]ITM0=[F:UOQM]ITMREF As [LNKQ]
    For [LNKQ]POQ0 Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM
      [F:UOQ]=[F:UOQM]
      #----- Calcul total des montants Ht ligne -----#
      If [F:UOQ]LINTYP<>2 & [F:UOQ]WIPSTA<2 & [F:UOQ]LINSTA<>3
        [F:UOH]TOTLINAMT+=[F:UOQ]LINAMT
      Endif

      #----- Calcul total des quantités UA, poids, volume -----#
      If find([F:UOQ]LINTYP,0,1,2,4)<>0
        Gosub LECT_ITMUOQ
        #----- Par sécurité, chargement des unités de l'article si nécessaire -----#
        If [F:UOH]DSPWEU=""  [F:UOH]DSPWEU=[F:ITM]WEU : Endif
        If [F:UOH]DSPVOU=""  [F:UOH]DSPVOU=[F:ITM]VOU : Endif
        #-----
        [F:UOQ]QTYWEU=[F:ITM]ITMWEI*[F:UOQ]QTYSTU
        [F:UOQ]QTYVOU=[F:ITM]ITMVOU*[F:UOQ]QTYSTU

        WUOM1=[F:ITM]WEU
        WUOM2=[F:UOH]DSPWEU
        WQTY=[F:UOQ]QTYWEU
        Gosub CONVERT_QTY From UUMGTRTPUR00
        [F:UOQ]QTYWEU=WQTY

        WUOM1=[F:ITM]VOU
        WUOM2=[F:UOH]DSPVOU
        WQTY=[F:UOQ]QTYVOU
        Gosub CONVERT_QTY From UUMGTRTPUR00
        [F:UOQ]QTYVOU=WQTY
        #----- Cumuls qtés ligne -----#
        If [F:UOQ]WIPSTA<2 & [F:UOQ]LINSTA<>3 & [F:UOH]POHTYP<>2
          [F:UOH]TOTLINQTY+=[F:UOQ]QTYPUU
          [F:UOH]TOTLINWEU+=[F:UOQ]QTYWEU
          [F:UOH]TOTLINVOU+=[F:UOQ]QTYVOU
        Endif
      Endif
    Next
Return



##################################
$LECT_ITMUOQ
  If [F:ITM]ITMREF<>[F:UOQ]ITMREF
    WITM=[F:UOQ]ITMREF
    Gosub LECT_ITM
  Endif
Return

$LECT_ITM
    Read [ITM] ITM0=WITM : If fstat  Raz [F:ITM] : Endif
Return

##################################
# Traitement des bases spéciales #
##################################
$TRT_BASE
If WTAX<>""
  WJTVT=find(WTAX,WTVTVAT(0..NBTVT))
  If WJTVT>0 & WTVTVATBAS(WJTVT-1)=2 & WCLCAMT1<>0
    WCLCFLG1=1 : WCLCAMT(I)=WCLCAMT1 : WCLCFLG(I)=1
  Endif
  If WJTVT>0 & WTVTVATBAS(WJTVT-1)=3 & WCLCAMT2<>0
    WCLCFLG2=1 : WCLCAMT(I)=WCLCAMT2 : WCLCFLG(I)=1
  Endif
Endif
Return


#########################################################################
# HMAJ_CALTAX_LIG : S/P de calcul des bases et des taxes    MBT 19/12/07 #
#                     de la ligne de commande                           #
#########################################################################
$HMAJ_CALTAX_LIG
#-----
For I=1 To 3
  Case I
    When 1 : TAXE(1)=[F:UOP]VAT(0) : WCLCAMT(1)=[F:UOQ]CLCAMT1
    When 2 : TAXE(2)=[F:UOP]VAT(1) : WCLCAMT(2)=[F:UOQ]CLCAMT2
    When 3 : TAXE(3)=[F:UOP]VAT(2) : WCLCAMT(3)=[F:UOQ]CLCAMT3
  Endcase
Next I
#-----
Raz MONTANT,MONTDED
Call CALTAXE2(GSOCIETE,[F:UOH]ORDDAT,[F:UOH]VACBPR,[F:UOH]CUR,3,TAXE,1,[F:UOQ]LINAMT,WCLCAMT,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#-----
For I=1 To 3
  Case I
    When 1
      [F:UOQ]BASTAXLIN1=[F:UOQ]LINAMT
      [F:UOQ]AMTTAXLIN1=MONTANT(1)
      [F:UOQ]DEDTAXLIN1=MONTDED(1)
    When 2
      If [F:UOP]VAT(1)=""
        Raz [F:UOQ]AMTTAXLIN2, [F:UOQ]DEDTAXLIN2
      Else
        [F:UOQ]AMTTAXLIN2=MONTANT(2)
        [F:UOQ]DEDTAXLIN2=MONTDED(2)
        WJTVT=find([F:UOP]VAT(1),WTVTVAT(0..NBTVT))
        If WJTVT>0 & WTVTVATCHA(WJTVT-1)=2 [F:UOQ]BASTAXLIN1+=[F:UOQ]AMTTAXLIN2 : Endif
      Endif
    When 3
      If [F:UOP]VAT(2)=""
        Raz [F:UOQ]AMTTAXLIN3, [F:UOQ]DEDTAXLIN3
      Else
        [F:UOQ]AMTTAXLIN3=MONTANT(3)
        [F:UOQ]DEDTAXLIN3=MONTDED(3)
        WJTVT=find([F:UOP]VAT(2),WTVTVAT(0..NBTVT))
        If WJTVT>0 & WTVTVATCHA(WJTVT-1)=2 [F:UOQ]BASTAXLIN1+=[F:UOQ]AMTTAXLIN3 : Endif
      Endif
  Endcase
Next I
#-----
If [F:UOH]VACTYP<>4
  [F:UOQ]LINATI=[F:UOQ]LINAMT
  For I=1 To 3
    Case I
      When 1 : [F:UOQ]LINATI+=[F:UOQ]AMTTAXLIN1
      When 2 : [F:UOQ]LINATI+=[F:UOQ]AMTTAXLIN2
      When 3 : [F:UOQ]LINATI+=[F:UOQ]AMTTAXLIN3
    Endcase
  Next I
Else
  [F:UOQ]LINATI=[F:UOQ]LINAMT
Endif
[F:UOQ]LINATIAMT=[F:UOQ]LINATI
#----- Si commande ouverte, c'est fini ! -----#
If [F:UOH]POHTYP=2  Return : Endif
#----- Calcul de la taxe des montants remises/frais de la ligne tarif -----#
For I=1 To 9
##  If evalue("dim([F:UOP]DISCRGVAL"+num$(I)+")")>0

    If GNPRNOTFLG(I-1)=1 & GINVDTALIN(I-1)<>0

    Case I
    When 1 : WDISCRGVAL=[F:UOP]DISCRGVAL1
    When 2 : WDISCRGVAL=[F:UOP]DISCRGVAL2
    When 3 : WDISCRGVAL=[F:UOP]DISCRGVAL3
    When 4 : WDISCRGVAL=[F:UOP]DISCRGVAL4
    When 5 : WDISCRGVAL=[F:UOP]DISCRGVAL5
    When 6 : WDISCRGVAL=[F:UOP]DISCRGVAL6
    When 7 : WDISCRGVAL=[F:UOP]DISCRGVAL7
    When 8 : WDISCRGVAL=[F:UOP]DISCRGVAL8
    When 9 : WDISCRGVAL=[F:UOP]DISCRGVAL9
    When Default
    Endcase


      #----- C'est un montant -----#
      If GDISCRGTYP(I-1)=1
        If GCLCRUL(I-1)=1 : # Par unité
          BASE=arr(WDISCRGVAL*[F:UOQ]QTYUOM,WRND)
        Else              : # Par ligne
          BASE=WDISCRGVAL
        Endif
      #----- C'est un pourcentage -----#
      Else
        BASE=arr([F:UOQ]LINAMT*WDISCRGVAL/100,WRND)
      Endif
      #----- Inversion du montant si minoration -----#
      If GINCDCR(I-1)=2  BASE=-BASE : Endif
      #----- Màj base et mt taxe ligne si taux produit -----#
      If [F:UOH]INVDTAVAT1(I-1)=""
        Raz TAXE : TAXE(1)=[F:UOP]VAT(0)
        If BASE<>0
          Call CALTAXE(GSOCIETE,[F:UOH]ORDDAT,[F:UOH]VACBPR,[F:UOH]CUR,1,TAXE,1,
&                      BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          [F:UOQ]BASTAXLIN1+=BASE
          [F:UOQ]AMTTAXLIN1+=MONTANT(1)
          [F:UOQ]DEDTAXLIN1+=MONTDED(1)
        Endif
      Endif
      #----- Recherche si élément déja existant -----#
      J=find(GINVDTALIN(I-1),[L]INVDTA(0..[L]NBFAC-1))
      If J=0
        #----- Le nombre maximum d'élément est dépassé ! (Impossible en théorie) ------#
        If [L]NBFAC>=dim([L]INVDTA)  Goto MAJ_SUIT1 : Endif
        #-----
        J=[L]NBFAC
        [L]NBFAC+=1
        [L]INVDTA   (J)=GINVDTALIN       (I-1)
        [L]INVLINFLG(J)=6
        [L]DEBCDT   (J)=GINCDCR          (I-1)
        [L]INVDTAVAT(J)=[F:UOH]INVDTAVAT1(I-1)
      Else
        J-=1
      Endif
      [L]INVLINAMT(J)+=BASE
    Endif
##  Endif
$MAJ_SUIT1
Next I
#-----
Return

# Issue 88474 - 2013-05-06 by SR
###############################################
$CLC_UOQ
# Calcul du CPR, cout achat et Montant achat
# Si SST (composé ou composant), pas de calcul
If [F:UOQ]LINTYP>1 : Return : Endif
#-----
# WBASE,WMT pour le CPR, WBASE1,WMT1 pour LINCSTPUR
If [F:UOQ]QTYUOM<>0
  WBASE=[F:UOP]NETPRI*[F:UOQ]QTYUOM : # Mt ligne avec précision maxi
Else
  WBASE=[F:UOQ]LINAMT               : # Mt ligne arrondi suivant devise
Endif
WBASE1 = WBASE
#----- Eléments provenant du tarif -----#
# Issue 97209 - 2014-02-25 by SR : Remplacer UOQ par UOP
For I=1 To 9
  If GINVDTALIN(I-1)<>0
    Read [PFI] PFI0=GINVDTALIN(I-1) : If fstat Raz [F:PFI] : Endif
       #----- C'est un montant -----#
       If GDISCRGTYP(I-1)=1
         If GCLCRUL(I-1)=1 : # Par unité
           WMT1=evalue("[F:UOP]DISCRGVAL"+num$(I))*[F:UOQ]QTYUOM
           If [F:PFI]NPRVLT=2 & GNPRNOTFLG(I-1)=1: WMT=WMT1 : Endif
         Else              : # Par ligne
           WMT1=evalue("[F:UOP]DISCRGVAL"+num$(I))
           If [F:PFI]NPRVLT=2 & GNPRNOTFLG(I-1)=1: WMT=WMT1 : Endif
         Endif
       #----- C'est un pourcentage -----#
       Else
          WMT1=arr([F:UOQ]LINAMT*evalue("[F:UOP]DISCRGVAL"+num$(I))/100,WRND)
          If [F:PFI]NPRVLT=2 & GNPRNOTFLG(I-1)=1 : WMT=WMT1 : Endif

       Endif
      If GINCDCR(I-1)=2  WBASE1-=WMT1  Else WBASE1+=WMT1 : Endif
      If [F:PFI]NPRVLT=2 & GNPRNOTFLG(I-1)=1
        If GINCDCR(I-1)=2  WBASE-=WMT  Else WBASE+=WMT : Endif
      Endif

  Endif
Next I
#----- Eléments provenant du pied de commande -----#
For I=1 To 9
  If [F:UOH]INVDTALIN2(I-1)<>0
    Read [PFI] PFI0=[F:UOH]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
    WBASE1+=evalue("[F:UOQ]DISCRGAMT"+num$(I))
    If [F:PFI]NPRVLT=2
       WBASE+=evalue("[F:UOQ]DISCRGAMT"+num$(I))
    Endif
  Endif
Next I
#----- Conversion si nécessaire du montant en devise société -----#
If [F:UOH]CUR<>GLOCALDEV
  WMT=WBASE
  Call CONVERT2([F:UOH]CUR, GLOCALDEV, GLOCALDEV,[F:UOH]CHGTYP,[F:UOH]ORDDAT,
&                    WMT,WBASE,STAT) From TRTDEV
  WBASE=arr(WBASE,10^-GDECPRI)
  WMT=WBASE1
  Call CONVERT2([F:UOH]CUR, GLOCALDEV, GLOCALDEV,[F:UOH]CHGTYP,[F:UOH]ORDDAT,
&                    WMT,WBASE1,STAT) From TRTDEV
  WBASE1=arr(WBASE1,10^-GDECPRI)
Endif
#----- Calcul prix unitaire d'achat en devise société et par unité de stock -----#
#----- Récupération prix d'achat sur commande -----#
WPRIPUR=[F:UOP]NETPRI

WUOM  =[F:UOQ]UOM
WCUR  =[F:UOH]CUR

#--- Issue 111891
#WCOEFF = [F:UOQ]QTYSTU / [F:UOQ]QTYUOM
If [F:UOQ]QTYUOM=0
  WCOEFF=1
Else
  WCOEFF=[F:UOQ]QTYSTU/[F:UOQ]QTYUOM
Endif
#---

#----- Conversion si nécessaire du montant en devise société -----#
If WCUR<>GLOCALDEV
  Call CONVERT2(WCUR,GLOCALDEV, GLOCALDEV,[F:UOH]CHGTYP,[F:UOH]ORDDAT,
&                    WPRIPUR,WPRIPUR,STAT) From TRTDEV
  WPRIPUR=arr(WPRIPUR,10^-GDECPRI)
Endif
#----- Le prix unitaire d'achat doit être par unité de stock -----#
If WUOM<>[F:UOQ]STU
  If WCOEFF=0  WCOEFF=1 : Endif
  WPRIPUR=arr(WPRIPUR/WCOEFF,10^-GDECPRI)
Else
  WPRIPUR=arr(WPRIPUR,10^-GDECPRI)
Endif

# Issue 91687 - 2013-08-06 by SR : CPRAMT vaut 0 au moment de la migration donc pas besoin de le convertir
#Call PCAL_QTY([F:UOQ]QTYPUU,[F:UOQ]PUU,[F:UOQ]QTYSTU,[F:UOQ]STU,
#&             [F:UOQ]ITMREF,[F:UOH]BPSNUM,1,WUOMSTUCOE) From TRTACHQTE1
#WCPRAMT = arr([F:UOQ]CPRAMT/WUOMSTUCOE,10^-GDECPRI)

#----- Calcul du prix unitaire de revient théorique en US -----#
If [F:UOQ]QTYSTU<>0
  [F:UOQ]CPRPRI=arr(WBASE/[F:UOQ]QTYSTU,10^-GDECPRI)
Else
  [F:UOQ]CPRPRI=WBASE
Endif


#----- Taxes non déductible -----#
# Issue 93448 - 2013-10-18 by MUARN : wtaxe non réinitialisé
WTAXE=[F:UOQ]AMTTAXLIN1-[F:UOQ]DEDTAXLIN1
WTAXE+=[F:UOQ]AMTTAXLIN2-[F:UOQ]DEDTAXLIN2
WTAXE+=[F:UOQ]AMTTAXLIN3-[F:UOQ]DEDTAXLIN3
WTAXE+=[F:UOQ]AMTTAXRCP -[F:UOQ]DEDTAXRCP
WTAXE+=[F:UOQ]AMTTAXISS -[F:UOQ]DEDTAXISS
WTAXE+=[F:UOQ]AMTTAXOTH1-[F:UOQ]DEDTAXOTH1
WTAXE+=[F:UOQ]AMTTAXOTH2-[F:UOQ]DEDTAXOTH2
If [F:UOH]CUR<>GLOCALDEV
    WMT=WTAXE
    Call CONVERT2([F:UOH]CUR, GLOCALDEV, GLOCALDEV,[F:UOH]CHGTYP,[F:UOH]ORDDAT,
&                    WMT,WTAXE,STAT) From TRTDEV
      WTAXE=arr(WTAXE,10^-GDECPRI)
Endif
#----- Calcul prix de revient -----#
# Issue 91687 - 2013-08-06 by SR : CPRAMT vaut 0 au moment de la migration
#[F:UOQ]CPR   =[F:UOQ]CPRPRI-WPRIPUR+(WPRIPUR*[F:UOQ]CPRCOE)+WCPRAMT
[F:UOQ]CPR   =[F:UOQ]CPRPRI-WPRIPUR+(WPRIPUR*[F:UOQ]CPRCOE)
If [F:UOQ]QTYSTU<>0
   If GNODVATSTO = 2
    [F:UOQ]CPR   += (WTAXE/[F:UOQ]QTYSTU)
   Endif
Endif
[F:UOQ]CPR   =arr([F:UOQ]CPR,10^-GDECPRI)

#----- Calcul Montant achat ----#
# Issue number 92804 - 2013-09-19 by SR : Pour coût achat WPRIPUR doit être un montant
If [F:UOQ]QTYUOM<>0
  WPRIPUR=[F:UOP]NETPRI*[F:UOQ]QTYUOM : # Mt ligne avec précision maxi
Else
  WPRIPUR=[F:UOQ]LINAMT               : # Mt ligne arrondi suivant devise
Endif

# Issue 93448 - 2013-10-11 by MUARN : conversion en devise si nécessaire
#----- Conversion si nécessaire du montant en devise société -----#
If [F:UOH]CUR<>GLOCALDEV
  Call CONVERT2([F:UOH]CUR, GLOCALDEV, GLOCALDEV,[F:UOH]CHGTYP,[F:UOH]ORDDAT,
&                    WPRIPUR,WPRIPUR,STAT) From TRTDEV
  WPRIPUR=arr(WPRIPUR,10^-GDECPRI)
Endif

WBASE1 += WTAXE
# Issue 91687 - 2013-08-06 by SR : CPRAMT vaut 0 au moment de la migration
#[F:UOQ]LINCSTPUR= WBASE1-WPRIPUR+(WPRIPUR*evalue([F:UOQ]CPRCOE))+WCPRAMT
# Issue 91723 by TS
#[F:UOQ]LINCSTPUR= WBASE1-WPRIPUR+(WPRIPUR*evalue([F:UOQ]CPRCOE))
[F:UOQ]LINCSTPUR= WBASE1-WPRIPUR+(WPRIPUR*[F:UOQ]CPRCOE)
[F:UOQ]LINCSTPUR=arr([F:UOQ]LINCSTPUR,10^-GDECPRI)
 #----- Calcul Montant stock et cout achat-----#
If [F:UOQ]QTYSTU<>0
  [F:UOQ]LINAMTCPR = arr([F:UOQ]CPR*[F:UOQ]QTYSTU,10^-GDECPRI)
  [F:UOQ]CSTPUR=arr([F:UOQ]LINCSTPUR/[F:UOQ]QTYSTU,10^-GDECPRI)
Else
  [F:UOQ]LINAMTCPR=[F:UOQ]CPR
  [F:UOQ]CSTPUR   =[F:UOQ]LINCSTPUR
Endif

#[F:UOQ]REACSTPUR A FAIRE EN POS ?
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTPUR04(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR04(APPLI)
End

