#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# UUMGTRTPUR04   Migration des Historiques de Commandes     Module Achats#
#                Commandes normales                                      #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
    Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR04") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR04(DOSSIER)
  Call MAJ_UUMGTRTPUR04(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR04(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

Local Char WNAMUOHM,WNAMUOPM,WNAMUOQM
Call MIGTABNAME (DOSSIER,"UPORDER",WNAMUOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"UPORDERP",WNAMUOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"UPORDERQ",WNAMUOQM,ERR) From TRTMIG

If ERR
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMUOHM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMUOPM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif

If filinfo(filpath("FIL",WNAMUOQM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif

##2 - On vide les fichiers selon le cas
#######################################
Local Char REQTSQL (250) (2)
#Local File =DOSSIER+".UPORDER"    [UOH]
#Local File =DOSSIER+".UPORDERP"    [UOP]
#Local File =DOSSIER+".UPORDERQ"    [UOQ]
#Local File =DOSSIER+".UPORDERC"    [UOC]
Local File =DOSSIER+".CPTANALIN"   [CAL]

# Issue 81811 - 2012-04-24 by VPO : vider les tables
Call MIGTABRAZ (DOSSIER,"UPORDER",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"UPORDERP",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"UPORDERQ",ERR) From TRTMIG
#Onerrgo ERR_SQL
#Trbegin [UOH]
#REQTSQL(0)="DELETE FROM "-DOSSIER+".UPORDER WHERE POHTYP_0=1 "
#Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
#Onerrgo
#Commit
#
#Onerrgo ERR_SQL
#Trbegin [UOP]
#REQTSQL(0)="DELETE FROM "-DOSSIER+".UPORDERP WHERE POHTYP_0=1 "
#Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
#Onerrgo
#Commit
#
#Onerrgo ERR_SQL
#Trbegin [UOQ]
#REQTSQL(0)="DELETE FROM "-DOSSIER+".UPORDERQ WHERE POHTYP_0=1 "
#Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
#Onerrgo
#Commit

# Issue 101446 - 2014-07-11 by MUARN : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR04",7,ERR) From TRTMIG : #7=Erreur
  End
Endif
If val(VERSION)<GMIGX3VER60
  Onerrgo ERR_SQL
  Trbegin [CAL]
  REQTSQL(0)="DELETE FROM "-DOSSIER+".CPTANALIN WHERE ABRFIC_0='UOP' AND "
  REQTSQL(1)="NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".UPORDER WHERE CPTANALIN.VCRNUM_0=UPORDER.POHNUM_0) "
  Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
  Onerrgo
  Commit
Endif

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR04",ERR) From TRTMIG

End

###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQTSQL,1) From GESECRAN
ERR=1
Resume

##########################################################################
Subprog MAJ_UUMGTRTPUR04(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-12 by SR : adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR04",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR04",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMUOHM,WNAMUOPM,WNAMUOQM
Call MIGTABNAME (DOSSIER,"UPORDER",WNAMUOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"UPORDERP",WNAMUOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"UPORDERQ",WNAMUOQM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR04",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMUOHM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR04",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMUOPM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR04",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

If filinfo(filpath("FIL",WNAMUOQM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR04",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR04",2,ERR) From TRTMIG : #2=En cours
# Issue 108857 - 2015-06-15 by SR : Déplacé avant définition des variables qui utilisent adxwrb
Gosub MIG_OUVRE From TRTMIG

###################

Local Char WTAB_UOH (100) (adxwrb)
Local Char WTAB_UOP (100) (adxwrb)
Local Char WTAB_UOQ (100) (adxwrb)
Local Char WTAB_CAL (100) (adxwrb)
Local Char WTAB_PVV (100) (adxwrb)
Local Char WTAB_PVF (100) (adxwrb)
Local Shortint WCPT_UOH,WCPT_UOP,WCPT_UOQ,WCPT_CAL,WCPT_PVV,WCPT_PVF

Call ECR_TIME("UUMGTRTPUR04 Purchase Orders Process : Update UPORDER-P-Q") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR04 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#

Call MIGTABINIT (DOSSIER,"UPORDER",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"UPORDERP",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"UPORDERQ",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABINIT (DOSSIER,"CPTANALIN",ERR) From TRTMIG
#Call MIGTABINIT (DOSSIER,"PVCRVAT",ERR) From TRTMIG
#Call MIGTABINIT (DOSSIER,"PVCRFOOT",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:UOH])  = 0 : Local File =DOSSIER+".UPORDER"    [UOH]  : Endif   # Fichier X3 "Vide"
If clalev([F:UOP])  = 0 : Local File =DOSSIER+".UPORDERP"    [UOP]  : Endif   # Fichier X3 "Vide"
If clalev([F:UOQ])  = 0 : Local File =DOSSIER+".UPORDERQ"    [UOQ]  : Endif   # Fichier X3 "Vide"

If clalev([F:UOHM]) = 0 : Local File =DOSSIER+"."+WNAMUOHM   [UOHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:UOPM]) = 0 : Local File =DOSSIER+"."+WNAMUOPM   [UOPM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:UOQM]) = 0 : Local File =DOSSIER+"."+WNAMUOQM   [UOQM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=5
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

Gosub OUVRE_PUR From UUMGTRTPUR00
Gosub OUVRE_POH From UUMGTRTPUR00
# Issue 88474 - 2013-05-06 by SR : Pour V6 et V7
Gosub OUVRE_PUR02 From UUMGTRTPUR02

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR04",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [UOHM] With [BPS]BPS0=[F:UOHM]BPSNUM As [LNK]
&    Order By Key CLE = [F:UOHM]POHTYP;[F:UOHM]POHFCY;[F:UOHM]POHNUM;[F:UOHM]REVNUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR04" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_UOP00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:UOHM]POHTYP=1 & [F:UOHM]POHFCY=TABMIGKEY(2) & [F:UOHM]POHNUM=TABMIGKEY(3) & [F:UOHM]REVNUM>val(TABMIGKEY(4))"
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:UOHM]POHTYP=1 & [F:UOHM]POHFCY=TABMIGKEY(2) & [F:UOHM]POHNUM>TABMIGKEY(3)"
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:UOHM]POHTYP=1 & [F:UOHM]POHFCY>TABMIGKEY(2)"
Else
 CRITERE = "[F:UOHM]POHTYP=1 "
Endif

Trbegin [UOH],[UOP], [UOQ]
GOK = 1

For [LNK]CLE(4) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR04" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLEUOP : Endif
  Endif

  #  version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
    Gosub RAZV6_UOH
  Endif
  #  version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
    Gosub RAZV7_UOH
  Endif
  [F:UOH] = [F:UOHM]

  If WSITE<>[F:UOH]POHFCY
    #----- Alimentation de la société sur l'entête de demande d'achat -----#
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:UOH]POHFCY) From TRTX3CPT
      WSITE=[F:UOH]POHFCY
  Endif

  [F:UOH]CPY=GSOCIETE
  #  version < V6, traitement v6
  If val(VERSION)<GMIGX3VER60
     Gosub MAJV6_AVUOH
     If GOK<1 : Break : Endif
  Endif
  #  version < V7, traitement v7
  If val(VERSION)<GMIGX3VER70
     Gosub MAJV7_AVUOH
     If GOK<1 : Break : Endif
  Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  For [UOPM] POP0 Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM
    #rupture par ligne de commande
    #  version < V6, raz des champs v6
    If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_UOP
    Endif
    #  version < V7, raz des champs v7
    If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_UOP
    Endif
    [F:UOP] = [F:UOPM]

    #Appel proc de migration sur detail
    #  version < V6, traitement v6
    If val(VERSION)<GMIGX3VER60
      Gosub MAJV6_UOP
      If GOK<1 : Break : Endif
    Endif
    #  version < V7, traitement v7
    If val(VERSION)<GMIGX3VER70
      Gosub MAJV7_UOP
      If GOK<1 : Break : Endif
    Endif

    # Issue 108760 - 2015-06-12 by SR : adaptation : no more NEWMOTEUR
#    If NEWMOTEUR
#        Gosub UOP_STK : # pour stocker ref
#        WriteB [UOP]
#    Else
#        Write [UOP]
#    Endif
#    If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File UPORDERP, Error ="-num$(fstat),1) From GESECRAN
#          Gosub UOP_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File UPORDERP(POHNUM/LINREVNUM/POPLIN/POPSEQ)="-[F:UOP]POHNUM-num$([F:UOP]LINREVNUM)-num$([F:UOP]POPLIN)-num$([F:UOP]POPSEQ)+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
     Gosub UOP_STK : # pour stocker ref
     WriteB [UOP]
     If fstat
        Call ECR_TRACE("File UPORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub UOP_ERRTRA : # pour afficher les ref
        GOK=0 : Break
     Endif
     # End issue 108760
  Next
  If GOK<1 : Break : Endif
   # Issue 108760 - 2015-06-12 by SR : adaptation : no more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:UOP]
    If fstat
        Call ECR_TRACE("File UPORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub UOP_ERRTRA : # pour afficher les ref
        GOK=0
    Endif
# Endif
 # End issue 108760
  If GOK<1 : Break : Endif

 # Issue 112754 - 2017-01-26 by SR : Services
  #Appel proc de migration sur entete
  If val(VERSION)<GMIGX3VER120
    Gosub MAJ_UOH
  Endif
  If GOK<1 : Break : Endif
  # --- alimentation des champs et écriture enreg
   # --- alimentation des champs et écriture enreg
   # Issue 108760 - 2015-06-12 by SR : adaptation : no more NEWMOTEUR
#  If NEWMOTEUR
#      Gosub UOH_STK : # pour stocker ref
#      WriteB [F:UOH]
#  Else
#      Write [F:UOH]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File UPORDER, Error ="-num$(fstat),1) From GESECRAN
#      Gosub UOH_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File UPORDER(POHNUM/REVNUM)"-[F:UOH]POHNUM-num$([F:UOH]REVNUM)+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
   Gosub UOH_STK : # pour stocker ref
   WriteB [F:UOH]
   If fstat
      Call ECR_TRACE("File UPORDER, Error ="-num$(fstat),1) From GESECRAN
      Gosub UOH_ERRTRA : # pour afficher les ref
      GOK=0 : Break
  Endif
  # End issue 108760

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = num$([F:UOHM]POHTYP)
    TABMIGKEY(2) = [F:UOHM]POHFCY
    TABMIGKEY(3) = [F:UOHM]POHNUM
    TABMIGKEY(4) = num$([F:UOHM]REVNUM)
    STOP=1
    Break
  Endif
$SUITE_BOUCLEUOP
Next

$FIN_BOUCLEUOP
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR04",7,ERR) From TRTMIG : #7=Erreur
Else
   # Issue 108760 - 2015-06-12 by SR : adaptation : no more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:UOH]
    If fstat
        Call ECR_TRACE("File UPORDER, Error ="-num$(fstat),1) From GESECRAN
        Gosub UOH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEUOP : #on part sur rollback
    Endif
    Flush [F:UOP]
    If fstat
        Call ECR_TRACE("File UPORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub UOP_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEUOP : #on part sur rollback
    Endif
    Flush [F:UOQ]
    If fstat
        Call ECR_TRACE("File UPORDERQ, Error ="-num$(fstat),1) From GESECRAN
        Gosub UOQ_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEUOP : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEUOP : #on part sur rollback
    Endif
    Flush [F:PVV]
    If fstat
        Call ECR_TRACE("File PVCRVAT, Error ="-num$(fstat),1) From GESECRAN
        Gosub PVV_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEUOP : #on part sur rollback
    Endif
    Flush [F:PVF]
    If fstat
        Call ECR_TRACE("File PVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
        Gosub PVF_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEUOP : #on part sur rollback
    Endif
 # Endif
 # End issue 108760 # Endif
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR04",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLEUOP
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR04",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_UOP00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [UOH], [UOP]
Close Local File [UOHM], [UOPM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"UPORDER",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"UPORDERP",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"UPORDERQ",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABEND (DOSSIER,"CPTANALIN",ERR) From TRTMIG
#Call MIGTABEND (DOSSIER,"PVCRVAT",ERR) From TRTMIG
#Call MIGTABEND (DOSSIER,"PVCRFOOT",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR04") From TRTMIG
Call ECR_TIME("UUMGTRTPUR04 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


################################################
$UOH_STK
Call STK (WTAB_UOH,WCPT_UOH,[F:UOH]POHNUM-'/'-num$([F:UOH]REVNUM)) From TRTMIG
Return
$UOP_STK
Call STK (WTAB_UOP,WCPT_UOP,[F:UOP]POHNUM-'/'-num$([F:UOP]LINREVNUM)-'/'-num$([F:UOP]POPLIN)-'/'-num$([F:UOP]POPSEQ)) From TRTMIG
Return
$UOQ_STK
Call STK (WTAB_UOQ,WCPT_UOQ,[F:UOQ]POHNUM-'/'-num$([F:UOQ]LINREVNUM)-'/'-num$([F:UOQ]POPLIN)-'/'-num$([F:UOQ]POQSEQ)) From TRTMIG
Return
##############################################################################################
$UOH_ERRTRA
Call ERRTRA (WTAB_UOH,WCPT_UOH,"File UPORDER(POHNUM/REVNUM)=") From TRTMIG
Return
$UOP_ERRTRA
Call ERRTRA (WTAB_UOP,WCPT_UOP,"File UPORDERP(POHNUM/LINREVNUM/POPLIN/POPSEQ)=") From TRTMIG
Return
$UOQ_ERRTRA
Call ERRTRA (WTAB_UOQ,WCPT_UOQ,"File UPORDERQ(POHNUM/LINREVNUM/POPLIN/POQSEQ)=") From TRTMIG
Return
##############################################################################################
$RAZV6_UOH #attention, étiquette appelée aussi depuis le UUMGTRTPUR05
Raz [F:UOH]BPAINV
Raz [F:UOH]BPAPAY
Raz [F:UOH]BPOADD
Raz [F:UOH]BPOADDLIG
Raz [F:UOH]BPOCRY
Raz [F:UOH]BPOCRYNAM
Raz [F:UOH]BPOCTY
Raz [F:UOH]BPONAM
Raz [F:UOH]BPOPOSCOD
Raz [F:UOH]BPOSAT
Raz [F:UOH]COPNBR
Raz [F:UOH]CPY
Raz [F:UOH]DIE
Raz [F:UOH]DSPVOU
Raz [F:UOH]DSPWEU
Raz [F:UOH]EECICT
Raz [F:UOH]EECLOC
Raz [F:UOH]EECNUM
Raz [F:UOH]FFWADD
Raz [F:UOH]FFWNUM
Raz [F:UOH]FUPFLG
Raz [F:UOH]ICTCTY
Raz [F:UOH]INVDTALIN1
Raz [F:UOH]INVDTALIN2
Raz [F:UOH]INVDTAVAT1
Raz [F:UOH]INVDTAVAT2
Raz [F:UOH]OCNFLG
Raz [F:UOH]TOTLINAMT
Raz [F:UOH]TOTLINATI
Raz [F:UOH]TOTLINQTY
Raz [F:UOH]TOTLINVOU
Raz [F:UOH]TOTLINWEU
Raz [F:UOH]TOTORDL
Raz [F:UOH]TOTTAXAMT
Raz [F:UOH]TTVORDL

    Raz [L]NBTAX,  [L]TAX,       [L]BASTAX,    [L]AMTTAX,    [L]DEDTAX,    [L]PURTYP
    Raz [L]VATTYP
    Raz [L]NBFAC,  [L]INVDTA,    [L]INVDTAAMT, [L]INVLINAMT, [L]INVCPLAMT, [L]INVLINFLG
    Raz [L]DEBCDT, [L]INVDTAVAT, [L]DTAAMTTAX, [L]DTADEDTAX, [L]CUMLIG
Return
