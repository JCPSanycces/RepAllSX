#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# CNSBPSISTD : Products by supplier
# SCREEN 1 (HEADER) : CONSBPSI1 [BPSI1]
# SCREEN 2 (LINES)  : CONSBPSI2 [BPSI2]
#
#
#########################################################################

$ACTION

Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
Endcase

Return

############################################################
$AUTORIS
Return

###################################################################
# Parameters analysis, initializations, opening & declarations    #
###################################################################
$OUVRE
If !clalev([F:BPS])   : Local File BPSUPPLIER [BPS] : Endif

NAVIG   = "CONSBPSI"
SUITE   = 1
RETOUR  = 1

Return

############################################################
$LECTURE
Local Integer I

# Update site specific stuff
Call GETDEV([M:BPSI1]STOFCY) From DEVSUB

# Get the correct BP SUpplier record
Read [BPS]BPS0 = [M:BPSI1]BPSNUM

Raz [M:BPSI2]

For [ITP] Where BPSNUM = [M:BPSI1]BPSNUM

  # Only products defined on current site
  Read [ITF]ITF0 = [F:ITP]ITMREF; [M:BPSI1]STOFCY
  If fstat : Goto NEXT_ITP : Endif

  Read [ITM]ITM0 = [F:ITP]ITMREF
  [M:BPSI2]ITMREF(I)  = [F:ITM]ITMREF
  [M:BPSI2]STU(I)     = [F:ITM]STU
  [M:BPSI2]ITMWEI(I)  = [F:ITM]ITMWEI
  [M:BPSI2]WEU(I)     = [F:ITM]WEU
  [M:BPSI2]ITMVOU(I)  = [F:ITM]ITMVOU
  [M:BPSI2]VOU(I)     = [F:ITM]VOU

  Read [ITV]ITV0 = [F:ITM]ITMREF; [M:BPSI1]STOFCY
  If fstat : Raz [F:ITV] : Endif
  [M:BPSI2]AVASTO(I)  = [F:ITV]PHYSTO - [F:ITV]PHYALL
  [M:BPSI2]ORDSTO(I)  = [F:ITV]ORDSTO


  Read [ITF]ITF0 = [F:ITM]ITMREF; [M:BPSI1]STOFCY
  If fstat : Raz [F:ITF] : Endif
  [M:BPSI2]REOMINQTY(I) = [F:ITF]REOMINQTY
  [M:BPSI2]SAFSTO(I)    = [F:ITF]SAFSTO

  If GSYSCUR <> GLOCALDEV
    Call CONVERT (GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,date$,[F:ITM]PURBASPRI,[M:BPSI2]PURBASPRI(I),STAT) From TRTDEV
  Else
    [M:BPSI2]PURBASPRI(I) = [F:ITM]PURBASPRI
  Endif

  For [ORD]ORD1 Where STOFCY = [M:BPSI1]STOFCY & ITMREF = [F:ITM]ITMREF & WIPTYP = 2 & WIPSTA = 3
    [M:BPSI2]SUGSTO(I) += [F:ORD]RMNEXTQTY - [F:ORD]MTOQTY
  Next

  I += 1

$NEXT_ITP
Next

[M:BPSI2]NBLIG = I

Affzo [M:BPSI2]

Return

