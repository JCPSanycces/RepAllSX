#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIWRKEPV 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_DTAVAT
Return

$ON_SFICCE
Onevent BEFORE_AREA Gosub AV_SFICCE From W3SIWRKEPV
Return

$AV_SFICCE
## Action INICCEFMT
Call INICCEFMT(num$(GDIE(1))) From SETGLBDIE
If GCCEFMT<>""
 Chgfmt [M]SFICCE(indice) With "KP:"+GCCEFMT
Else
 Chgfmt [M]SFICCE(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_DATECH
Onevent BEFORE_AREA Gosub AV_DATECH From W3SIWRKEPV
Return

$AV_DATECH
Chgfmt [M]DATECH(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_CODTVA
Return

$CHG_STY
Return


