#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################################################
# CLASS POSCOD
##########################################################################################################


##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINSERT_BEFORE"                : Gosub AINSERT_BEFORE
      When "AUPDATE_BEFORE"                : Gosub AUPDATE_BEFORE
      When "AREAD_AFTER"                   : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "CRY"                  : Gosub CRY
  When "POSCOD"               : Gosub POSCOD
  When "POSCTY"               : Gosub POSCTY
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



#########################################################################################################
$AINSERT_BEFORE
Gosub CONTROL_PROPERTIES
Gosub SYNCHRONIZE_PROPERTIES
Return

##########################################################################################################
$AUPDATE_BEFORE
Gosub CONTROL_PROPERTIES
Gosub SYNCHRONIZE_PROPERTIES
Return

##########################################################################################################
$AREAD_AFTER
Gosub CONTROL_PROPERTIES
Return

##########################################################################################################
$CONTROL_PROPERTIES
Gosub SATCOD_CONTROL
Return
##########################################################################################################
$SYNCHRONIZE_PROPERTIES
Gosub POSCTY_PROPERTY
Gosub POSCTYSEA_PROPERTY
Gosub SATCOD_PROPERTY
Gosub POSCOD_PROPERTY
Return

##########################################################################################################
$POSCOD
Case [L]ARULE
  When "CONTROL"                        : Gosub POSCOD_CONTROL
Endcase
Return

$POSCOD_CONTROL
Gosub POSCOD_PROPERTY
Return


##########################################################################################################
$POSCTY
Case [L]ARULE
  When "CONTROL"                        : Gosub POSCTY_CONTROL
  When "PROPAGATE"                      : Gosub POSCTY_PROPAGATE
Endcase
Return

#**
#* POSCTY - control set controls city
#*!
$POSCTY_CONTROL
Gosub POSCTY_PROPERTY
Return

#**
#* POSCTY - propagate value in POSCTYSEA
#*!
$POSCTY_PROPAGATE
Gosub POSCTYSEA_PROPERTY
Return

#############################################################################################################
$CRY
Case [L]ARULE
  When "INIT"                         : Gosub CRY_INIT
  When "PROPAGATE"                    : Gosub CRY_PROPAGATE
Endcase
Return

#**
#* CRY - Default value for country
#*!
$CRY_INIT
this.CRY = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "CRYDEF")
Return

$CRY_PROPAGATE
Gosub SATCOD_CONTROL
Gosub SATCOD_PROPERTY
Return


$POSCTY_PROPERTY
If this.CRY<>AVOID.ACHAR
Local File TABCOUNTRY [TCY]
Read [TCY]TCY0=this.CRY
If !fstat
  If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"CTYUPP")=[V]CST_AYES & [TCY]POSCODCTL<>2 Then
    this.POSCTY = toupper(ctrans(this.POSCTY))
  Endif
Endif
Endif
Return

$POSCTYSEA_PROPERTY
this.POSCTYSEA = toupper(ctrans(this.POSCTY))
Return

$POSCOD_PROPERTY
Local Char AFORMAT(30),MESSAGE(250)
Local Integer MINZIP
AFORMAT = AVOID.ACHAR
If this.CRY<>AVOID.ACHAR
  AFORMAT = fmet this.ACTX.ACACHE.ACRY.AGETVALCHAR(this.CRY,"POSCODFMT")
  If AFORMAT<>AVOID.ACHAR
    [L]ASTATUS = func CTLCHR(AFORMAT,this.POSCOD,MESSAGE)
    If [L]ASTATUS <> [V]CST_AOK
      [L]ASTATUS = fmet this.ASETERROR("POSCOD",MESSAGE,[L]ASTATUS)
    Elsif len(this.POSCOD)<fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"MINZIP")
      [L]ASTATUS=fmet this.ASETERROR("POSCOD",mess(111,123,1),[V]CST_AERROR)
    Endif
  Endif
Endif
Return

#############################################################################################################
$SATCOD_CONTROL
Local Integer MY_STATUS
If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG")=[V]CST_AYES
# subdivision control & subdivision=2 (SATCOD)
  If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATCTL")=[V]CST_AYES &
&   fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETAT")=2
    [L]MY_STATUS=fmet this.ASETATTRIBUTE("SATCOD","$isMandatory","true")
  Else
    [L]MY_STATUS=fmet this.ASETATTRIBUTE("SATCOD","$isMandatory","false")
    Gosub SATCOD_PROPERTY
  Endif
Else
  [L]MY_STATUS=fmet this.ASETATTRIBUTE("SATCOD","$isMandatory","false")
Endif
Return

$SATCOD_PROPERTY
If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG")=[V]CST_ANO
  this.SATCOD = AVOID.ACHAR
Endif
Return

Funprog CTLCHR(AFORMAT,AVALUE,MESSAGE)
Value Char AFORMAT,AVALUE
Variable Char MESSAGE
Local Integer I , J, MY_STATUS
Local Char    NEWFOR(50) , VALFOR(255)
[L]MY_STATUS = CST_AOK
If AFORMAT<>""
 NEWFOR = AFORMAT
 I = instr(1,NEWFOR,"[")
 While I
  J = instr(I+1,NEWFOR,"]")
  If J
   NEWFOR = left$(NEWFOR,I-1)+right$(NEWFOR,J+1)
  Endif
  I = instr(I+1,NEWFOR,"[")
 Wend
 VALFOR = vireblc(format$("K:"+NEWFOR,AVALUE),2)
 If AVALUE<>VALFOR
  # Format incorrect
  [L]MESSAGE = mess(149,100,1)
  [L]MY_STATUS = [V]CST_AERROR
 Endif
Endif
End [L]MY_STATUS

