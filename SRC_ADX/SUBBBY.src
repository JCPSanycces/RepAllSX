Variable Char    VALEUR()
Local    Integer AXE : AXE=20 : Gosub C_CCEX
End

$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE  Return : Endif
Call INIT_CCE(VALEUR,AXE,"STKBBYD","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:BBY0]IPTDAT) From TRTX3CPT
Return

# type soustraitance obsoltete accord GL et JAM le 15 01 09
Subprog AS_BOMALTTYP(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
# si la nomenclature est deja descendu on ne modifier pas le type d'alternative
If [M:BBY0]BOMFLG = 2 & [M:BBY1]NBLIG<>0
   mkstat = 2
Endif

End

Subprog C_BOMALTTYP(VALEUR)
Variable Integer VALEUR

Local Char    WFCY
Local Integer WALT
Local Date    WDAT
Local Integer WMSG
WDAT=date$
WMSG=1
WFCY=[M:BBY0]STOFCY

If [F:TBO]BOMALT <> [M:BBY0]BOMALT(nolign-1) | [F:TBO]BOMALTTYP <> VALEUR
    Read [TBO]TBO0= VALEUR;[M:BBY0]BOMALT(nolign-1)
Endif


If [TBO]FCY <> ""
   If [TBO]FCY  <> [M:BBY0]STOFCY
      mkstat = 2
      GMESSAGE = mess(225,199,1)
   Endif
Endif


Read [BOH]BOH0=[M:BBY0]ITMREF(nolign-1);[M:BBY0]BOMALT(nolign-1);VALEUR
If fstat
    GMESSAGE = mess(95,193,1)
    mkstat=2
    End
Endif

Call STKCTRALT(WFCY,WALT,WDAT,WMSG) From TRTBBYBOM
If WALT = 0
   mkstat = 2
   End
Endif

End

Subprog AS_BOMALT(VALEUR)
Variable Decimal VALEUR
# si la nomenclature est deja descendu on ne modifier pas l alternative
If [M:BBY0]BOMFLG(0) = 2 & [M:BBY1]NBLIG<>0
   mkstat = 2
Endif
End

Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
Local Integer WRET

#    Lecture BOM
# determination alternative par défaut :
#   recherche premiere alternative
If VALEUR = 0
   [M:BBY0]BOMALTTYP(nolign-1) = 2
   Diszo [M:BBY0]BOMALTTYP(nolign-1)
Else
   Call CTRBOMALT([M:BBY0]STOFCY, [M:BBY0]ITMREF(nolign-1), date$ , "BBY0", (nolign-1), VALEUR, WRET) From TRTBBYBOM
   If WRET <> 0
      mkstat=2
      End
   Endif
   Actzo [M:BBY0]BOMALTTYP(nolign-1)
Endif
End

Subprog AM_BOMALT(VALEUR)
Variable Decimal VALEUR
[M:BBY0]BOMFLG(0) = 0
End

Subprog AM_BOMALTTYP(VALEUR)
Variable Integer VALEUR
[M:BBY0]BOMFLG(0) = 0

#                                                 # hcb 71276 deb
If [F:ITM]ECCSTO > 1 &  dim([M:BBY0]ECCVALMAJ) > 0
   Local Char    LABR
   Local Integer LNOL
   LNOL = 0
   LABR = "BBY0"
   Gosub RECH_ECCVAL  From TRTBBYBOM
Endif
#                                                 # hcb 71276 fin



End
