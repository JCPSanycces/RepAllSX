#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################
#                 GESTION de l'OBJET BBY                 #
#                                                        #
# $SUBBBY gère les mouvements Assemblage/désassemblage   #
#                                                        #
##########################################################

Call OBJET("BBY", GBIDC1, GBIDC2) From GOBJET
End

$ACTION

Case ACTION

 When "DEFTRANS"     : Gosub DEFTRANS     From SUBBBYA
 When "VARIANTE"     : Gosub VARIANTE     From SUBBBYA
 When "SETTRANS"     : Gosub SETTRANS     From SUBBBYA
 When "OUVRE"        : Gosub OUVRE        From SUBBBYA
 When "FILTRE"       : Gosub FILTRE       From SUBBBYA
 When "LIENS"        : Gosub LIENS        From SUBBBYA
 When "DEFLIG"       : Gosub DEFLIG       From SUBBBYA
 When "LIENS_LIG"    : Gosub LIENS_LIG    From SUBBBYA
 When "SETBOUT"      : Gosub SETBOUT      From SUBBBYA

 When "RAZCRE"       : Gosub RAZCRE       From SUBBBYA
 When "RAZDUP"       : Gosub RAZDUP       From SUBBBYA
 When "AVANT_MOD"    : Gosub AVANT_MOD    From SUBBBYA
 When "INIMOD"       : Gosub INIMOD       From SUBBBYA

 When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBBBYA
 When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBBBYA
 When "INICRE"       : Gosub INICRE       From SUBBBYA
 When "CREATION"     : Gosub CREATION     From SUBBBYA
 When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBBBYA

 When "INIMOD_LIG"   : Gosub INIMOD_LIG   From SUBBBYA              # hcb 22993

 When "VALLIG"       : Gosub VALLIG       From SUBBBYA
 When "APRES_CRE"    : Gosub APRES_CRE    From SUBBBYA
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC From SUBBBYA
 When "MODIF"        : Gosub MODIF        From SUBBBYA
 When "APRES_MOD"    : Gosub APRES_MOD    From SUBBBYA
 When "AB_CREATION"  : Gosub AB_CREATION  From SUBBBYA
 When "AB_MODIF"     : Gosub AB_MODIF     From SUBBBYA

 When "AAPRES_NBLIG" : Gosub AAPRES_NBLIG From SUBBBY
 When "AB5_NBLIG"    : Gosub AB5_NBLIG    From SUBBBY
 When "BB5_NBLIG"    : Gosub BB5_NBLIG    From SUBBBY

 When "AB1_LOC"      : Gosub AB1_LOC      From SUBBBY
 When "BB1_LOC"      : Gosub BB1_LOC      From SUBBBY

 When "ANNULE"       : Gosub ANNULE       From SUBBBYA
 When "ABANDON"      : Gosub ABANDON      From SUBBBYA
 When "FIN"          : Gosub ABANDON      From SUBBBYA
 When "FERME"        : Gosub FERME        From SUBBBYA
 When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBBBYA
 When "GRISE"        : Gosub GRISE        From SUBBBYA

 When Default        :
Endcase
Return

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return


########################################
########################################
#
#    ACTIONS CHAMPS EN-TETE
#
########################################
########################################

########################################
# SMRNUM
########################################
# Initialise le type de document
Subprog D_VCRNUM(VALEUR)
Variable Char    VALEUR()
If GFONCTION = "GESBBY"
   [M:BBY0]VCRTYP=31          #assemblage
Endif
If GFONCTION = "GESDBY"
   [M:BBY0]VCRTYP=32          #desassemblage
Endif

End

########################################
# Vérifie que le numéro est renseigné si le document n'a pas de compteur affecté.
#
Subprog C_VCRNUM(VALEUR)
Variable Char VALEUR
    #-- Il faut une valeur saisie ou retournée par un compteur sinon erreur
    If (VALEUR="" &  GSTKCPT(16)="")
        mkstat = 2
        End
    Endif
    #-- Si on est en création , n° saisi vide et un compteur est présent on sort
    If (GREP="C" & VALEUR="" &  GSTKCPT(16)<>"")
        End
    Endif

    #-- Si dernier lu non chargé, on vérifie l'existence du n° saisi
    If [M:BBY0]VCRNUM="" & GREP<>"C"
        Look [F:SMH]SMH0=[M:BBY0]VCRTYP;VALEUR
        If fstat
            GMESSAGE=mess(178,199,1)   # ce document n existe pas
            mkstat=2
            End
        Endif
    Endif

    If VALEUR<>"" & GSTKCPTMAN(16)<>2
        Look [F:SMH]SMH0=[M:BBY0]VCRTYP;VALEUR
        If fstat
            Raz VALEUR

            End
        Endif
    Endif
End

########################################
Subprog AS_WRHE(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2 & VALEUR<>"" & [M:BBY1]NBLIG<>0
   GMESSAGE=mess(342,184,1) : mkstat=2
Endif
End

########################################
########################################
#
#    ACTIONS CHAMPS LIGNES
#
########################################
########################################

########################################
# NBLIG
########################################
# Gère la suppression et l'insertion des lignes
########################################
Subprog AVANT_NBLIG
Local Integer LLIG
    # Insertion de ligne.
    # Le status est en insertion uniquement sur "Avant_nblig" pas sur "Avant_saisie"

    If status=73 | status=82
        Local Integer LRET
        If dim([M:BBY0]ITMREF)=nolign-1
            GMESSAGE=mess(53,184,1) #"Tableau plein."
            GERR = 1
        Else
            If [M:BBY0]PNTMVTCOD <> 1                           # hcb 28649
               Call STKACTLIGM(nolign-1,"BBY0") From STKECR
               If dim([M]MVTDES)>0
                  Actzo [M]MVTDES(nolign-1)
               Endif
            Endif                                               # hcb 28649
            Actzo [M]ITMREF(nolign-1),ITMDES1(nolign-1)
            If dim([M]PCU)>0
                Actzo [M]PCU(nolign-1),QTYPCU(nolign-1)
            Endif
            If dim([M]PCUSTUCOE)>0
                Actzo [M]PCUSTUCOE(nolign-1)
            Endif
            If dim([M]PRIORD)>0
                Actzo [M]PRIORD(nolign-1)
            Endif
        Endif
    Endif
    If status=75             # modification de ligne
       Call LECFICENT([M:BBY0]STOFCY,"", "BBY0",(nolign-1),[M:BBY0]TRSTYP,[M:BBY0]TRSCOD,1) From STKECR  # hcb 28649
    Endif
End

########################################
# Ajoute le menu contextuel "Détail", permettant de décomposer la ligne
# ou le menu contextuel "Modification", permettant de modifier la ligne et son détail
Subprog IB_NBLIG
Gosub SET_NOL
#   dans le tableau in ni a qu une ligne
If NOL <> 0
   End
Endif

If ([M:BBY0]ITMREF(NOL) = "") | [M:BBY0]PNTMVTCOD = 1    # hcb 28649
    GBOUT2 = ""
    GBOUT3 = ""
    GBOUT4 = ""
    GBOUT5 = ""
Else
    Call STKINIBTN( 2, 5, 3, 4, "BBY0", "SRT", [M:BBY0]ITMREF(NOL) , [M:BBY0]STOFCY ) From STKENT
Endif

If GCONSULT <>  2          # hcb 22993

   If [M:BBY0]VCRNUMORI <> ""
      GBOUT5 = ""    # Modif détail
   Endif

   If [M:BBY0]VCRNUMORI = ""
      GBOUT9 = ""    # Consultation mvt stock
   Endif
Else                               # hcb 22993
   GBOUT5 = ""    # Modif détail   # hcb 22993
Endif                              # hcb 22993

End
########################################
Subprog B2_NBLIG
#Ouverture fenêtre de détail par clic droit
GOUVENT = 16384 # =2^14
End

########################################
Subprog B3_NBLIG
    Call INFOLOT("BBY0", nolign-1) From STKENT
End
########################################
Subprog B4_NBLIG
    GOUVLOT = GOUVLOT-mod(GOUVLOT,2)    # Ouverture du complément lot par clic droit (1er bit de GOUVLOT à 0)
    GOUVENT = 1     # permet de passer le test de l'ouverture de la fenetre complément lot
End


########################################
$AB5_NBLIG
#-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
# hcb 27842
Raz GBIDI2
GFCY=[M:BBY0]STOFCY
GBIDC2="K" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)
   GOUVENT=0
   Return
Endif




If [M:BBY0]VCRNUM<>""
  SYMBOLE2="BBY"+[M:BBY0]VCRNUM
  Lock=SYMBOLE2
  If fstat
    GMESSAGE=[M:BBY0]VCRNUM-mess(10,100,1)   # modification sur un autre poste
    Call ERREUR(GMESSAGE) From GESECRAN
    GOUVENT=0
    Return
  Endif
Endif
GOUVENT=2
Return

########################################
$BB5_NBLIG
If [M:BBY0]VCRNUM<>""
  SYMBOLE2="BBY"+[M:BBY0]VCRNUM
  Unlock=SYMBOLE2
Endif
If GRELITSMR=1
    mkstat=4
Endif

Return

########################################
Subprog C_NBLIG
If [M:BBY0]NBLIG>0
    Diszo [M:BBY0]STOFCY
Else
    Actzo [M:BBY0]STOFCY
Endif

Call STKCTRNBLIG("BBY0",[M:BBY0]STOFCY) From STKENT
GMODIF = 0

End

########################################
# Appelé avant l'action SAISTOENT
# Permet de vérifier s'il faut la lancer ou non
$AAPRES_NBLIG
Local Shortint WRET
Local Integer  WRET1
Local Char     LECCMAJ(GLONECS), LECCMIN(GLONEVL)

Raz WRET1
Raz GOUVSOR

If [M:BBY0]PNTMVTCOD = 1    # hcb 28649
   GOUVENT = 0              # hcb 28649
   Return                   # hcb 28649
Endif                       # hcb 28649
If adxgtb<>1 & !find(status,65,68,83)
    Diszo [M]ITMREF(nolign-1)
Endif

Call OUVENT([M:BBY0]STOFCY,"BBY0",1,[M:BBY0]TRSCOD,"",19,[M:BBY0]IPTDAT,nolign-1,[M:BBY0]NBLIG,"SRT","",WRET) From STKENT
If [M:BBY0]PRIORD(nolign-1)<>0
    Raz LECCMAJ, LECCMIN
    If dim([M:BBY0]ECCVALMAJ)>0
        [L]LECCMAJ = string$([M:BBY0]ECCVALMAJ(nolign-1)<>"$",[M:BBY0]ECCVALMAJ(nolign-1))
        [L]LECCMIN = string$([M:BBY0]ECCVALMIN(nolign-1)<>"$",[M:BBY0]ECCVALMIN(nolign-1))
    Endif
    Call SETNEWPRIOVE([M:BBY0]ITMREF(nolign-1),LECCMAJ,LECCMIN,[M:BBY0]STOFCY,[M:BBY0]IPTDAT,
&                     [M:BBY0]WSTOSEQ(nolign-1),[M:BBY0]PRIORD(nolign-1),1,[M:BBY0]QTYSTU(nolign-1),"",WRET1) From STKVAL
Endif
Affzo [M:BBY0]ITMREF(nolign-1)

Return


########################################
# ITMREF
########################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()

If [M:BBY0]PNTMVTCOD = 1    # hcb 28649
   End                      # hcb 28649
Endif
pcolor=GCOUL(0)
Gosub SET_NOL
If [M:BBY0]WSTOFLG(NOL)=0 & [M:BBY0]CREFLG(NOL)=0
    pcolor=GCOUL(1)
Else
    pcolor=GCOUL(0)
Endif
End

########################################
# Quand la saisie d'une réf article s'est bien passée
# on remplit le champ désignation
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

#[M:BBY0]ITMDES1(nolign-1) = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:BBY0]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
#--------------------------------#
# Recherche alternative valide   #
# pour proposition auto.         #
#--------------------------------#

If VALEUR = [M:BBY0]ITMREF(0)
   If [M:BBY0]BOMALT(0) <> 0
      End
   Endif
Endif

Local Integer WALT

#    Lecture BOM
# determination alternative par défaut :
#   recherche premiere alternative : si unique elle est proposée

Call INITBOMALT([M:BBY0]STOFCY, VALEUR, date$ , "BBY0", (nolign-1), WALT) From TRTBBYBOM

End

########################################
# UNITE de conditionnement
########################################
# Recherche le coefficient UC/US pour initialiser le champ PCUSTUCOE
Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()

    Local Char LUSCAV
    Local Char LFMT
    Local Integer LMODIF

    Gosub SET_NOL

    Call CTLUOM ([M:BBY0]ITMREF(NOL),3,"", VALEUR,[M:BBY0]PCUSTUCOE(NOL), LUSCAV, LFMT, LMODIF) From STKACT
    If LUSCAV <> "S"
       If LUSCAV <> "C"
          mkstat = 2
          End
       Endif
    Endif

    If LMODIF=2
        Actzo [M:BBY0]PCUSTUCOE(NOL)
    Endif
[M:BBY0]QTYSTU(NOL) = [M:BBY0]QTYPCU(NOL) * [M:BBY0]PCUSTUCOE(NOL)
Call QTEARR([M:BBY0]QTYSTU(NOL),[M:BBY0]STU(NOL)) From TRTDIV
Affzo [M:BBY0]PCUSTUCOE(NOL),QTYSTU(NOL)
If VALEUR <> [M:BBY0]PCU(NOL)
   GMODIF = 2
Endif
End

########################################
# QUANTITE
########################################
Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR
    If VALEUR<=0
        mkstat=2
    Endif
End

########################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL

#--- Contrôle si la quantité UC génère une qté US arrondie
Local Integer LRET
If [M:BBY0]PCU(NOL)<>[M:BBY0]STU(NOL)
   Call STKCTRCOE(VALEUR,[M:BBY0]PCUSTUCOE(NOL),[M:BBY0]STU(NOL),LRET) From STKACT
   If LRET=0 : mkstat=2 : End : Endif
Endif

[M:BBY0]QTYSTU(NOL) = VALEUR * [M:BBY0]PCUSTUCOE(NOL)
Call QTEARR([M:BBY0]QTYSTU(NOL),[M:BBY0]STU(NOL)) From TRTDIV

Affzo [M:BBY0]QTYSTU(NOL)
If VALEUR <> [M:BBY0]QTYPCU(NOL)
   GMODIF = 2
Endif
End

########################################
# PCUSTUCOE Coef UC/US
########################################
Subprog AM_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL

#--- Contrôle si le coef UC/US génère une qté US arrondie
Local Integer LRET
If [M:BBY0]PCU(NOL)<>[M:BBY0]STU(NOL)
   Call STKCTRCOE([M:BBY0]QTYPCU(NOL),VALEUR,[M:BBY0]STU(NOL),LRET) From STKACT
   If LRET=0 : mkstat=2 : End : Endif
Endif

[M:BBY0]QTYSTU(NOL) = [M:BBY0]QTYPCU(NOL) * VALEUR
Call QTEARR([M:BBY0]QTYSTU(NOL),[M:BBY0]STU(NOL)) From TRTDIV
Affzo [M:BBY0]QTYSTU(NOL)
If VALEUR <> [M:BBY0]PCUSTUCOE(NOL)
   GMODIF = 2
Endif

End

########################################
Subprog IB_LOT
    Gosub SET_NOL
    # Compteur lot (intéressant en particulier pour les réceptions à quai)
    If [F:ITM]LOTCOU = ""
        GBOUT2 = ""
    Else
        GBOUT2 = mess(439,198,1)
    Endif

    # Lot blanc
    If   [F:ITM]LOTMGTCOD = 2
&      & ([F:ITM]LOTCOU <> "" | [F:SRU]LOTSUPINH=3)
        GBOUT3 = mess(440,198,1)
    Else
        GBOUT3 = ""
    Endif

    # Info lot
    If [F:ITM]LOTMGTCOD = 1 | [M:BBY0]LOT(NOL) <> ""
        GBOUT4 = ""
    Else
        GBOUT4 = mess(441,198,1)
    Endif
End

########################################
# Lot blanc : Indique qu'il n'y a pas de n° de lot
Subprog B3_LOT(VALEUR)
Variable Char    VALEUR()
    Gosub SET_NOL
    VALEUR = ""
    [M:BBY0]GESLOT(NOL) = "B"

End

########################################
# Info lot : Indique si le lot est blanc ou géré par un compteur
Subprog B4_LOT(VALEUR)
Variable Char    VALEUR()
    # Indique si le lot est blanc ou géré par compteur
    # (Un sous pro a été créé car il est appellé à 2 endroits
    # et dans plusieurs écrans: bouton3 NBLIG et bouton4 Lot
    Call INFOLOT("BBY0", nolign-1) From STKENT
End

########################################
# NBSLO
########################################
Subprog C_NBSLO(VALEUR)
Variable Decimal VALEUR

    Call STKCTRNBSLO(VALEUR, [M:BBY0]PCU(nolign-1), [M:BBY0]QTYPCU(nolign-1)) From STKACT

End

########################################
# SLO
########################################
# Calcul le n° de sous lot fin en vérifiant, si nécessaire, l'existence des sous lots.
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()

Gosub SET_NOL

If VALEUR<>""
    Call STKCTRSLO(VALEUR, [M:BBY0]NBSLO(NOL), [M:BBY0]LOT(NOL),
&                  [M:BBY0]ITMREF(NOL), [M:BBY0]BPSLOT(NOL), [M:BBY0]GESLOT(NOL), "", 0, 0, 0,
&                  [M:BBY0]STOFCY, [M:BBY0]SLOF(NOL)) From STKACT
    If !mkstat
        Affzo [M:BBY0]SLOF(NOL)
    Endif
Endif
End

########################################
# Dépôt
########################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2
  VALEUR = [M:BBY0]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:BBY0]WRHE
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M:BBY0]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M:BBY0]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

#--- Bug 60553
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If [M:BBY0]WRH(nolign-1)<>""
   Raz [M:BBY0]LOC(nolign-1)
Endif
End

########################################
# TYPE D'EMPLACEMENT
########################################
Subprog C_LOCTYP(VALEUR)
Variable Char    VALEUR()

If [M:BBY0]LOCTYP(nolign-1)<>VALEUR
   Call RAZLOC([M:BBY0]LOC(nolign-1),[M:BBY0]WLOCSEQ(nolign-1)) From STKACT
Endif
End

########################################
# EMPLACEMENT
########################################
$AB1_LOC

    GLOCSEL = "LOCTYP='"+[M:BBY0]LOCTYP(nolign-1)+"'"
Return

$BB1_LOC

    Raz GLOCSEL
Return

Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
    Read [STC]STC0=[M:BBY0]STOFCY;VALEUR
    Read [TLO]TLO0=[M:BBY0]STOFCY;[F:STC]LOCTYP
    # test si type quai autorisé
    If !fstat & [M:BBY0]SRGWAIFLG <> 2 & [F:TLO]LOCCAT = 2                  # hcb 50197
         GMESSAGE = mess(854,196,1)
         mkstat = 2
         End
    Endif
Endif
Affzo [M:BBY0]LOCTYP(nolign-1)    # Il a pu etre modifié par le controle STKCTREMP
End

##########################################################################

##########################################################################
## Etiquette ajoutée par le superviseur 03/11/2003 16:38:25 (HCB)
##########################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
Local Char SECTION
GFCY=VALEUR : Gosub CHARG_PARAM From SUBBBYA       # ana

Local Integer Y
[M:BBY0]STOFCY = VALEUR
    For Y=1 To GNBDIE
    Call INISEC(SECTION, "STKBBYH", Y) From TRTX3CPT
    Assign "[M:BBY0]CCE"+num$(Y) With SECTION
    [F:SMH]CCE(Y-1) =  SECTION
    [M:BBY0]CCE(Y-1) = SECTION            # hcb X3-51677
Next
Gosub AFF_TITCOL  From SUBBBYA          # hcb 103041


If dim([M:BBY0]WRHE)>0
   Call WRHINIT([M:BBY0]WRHE,VALEUR,5) From STKWRH
Endif
# Actzo ou Grizo des dépôts selon le site
[M:BBY0]STOFCY=VALEUR
Gosub WRH_ETAT From SUBBBYA

End

Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
#    Lecture article et article/site
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat
      GMESSAGE = mess(134,100,1)
      mkstat = 2
      End
    Endif
Endif


End


Subprog B3_SLO(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL
Call RECLASTSLO([M:BBY0]ITMREF(NOL), [M:BBY0]LOT(NOL), "","", VALEUR) From STKLIB

End

Subprog IB_VCRNUMORI

GBOUT1 = mess(53,117,1)     # Document origine

If ([M:BBY0]VCRNUM  = "") | [M:BBY0]VCRNUMORI = ""
    GBOUT1 = ""
Endif

End



