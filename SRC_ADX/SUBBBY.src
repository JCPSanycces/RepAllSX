Subprog AM_MVTDES(VALEUR)
Variable Char    VALEUR()
End


#                                                                          # hcb 71276 deb
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()

If VALEUR <> [M:BBY0]LOT (nolign-1)                                        # hcb 117626
   If dim([M:BBY0]ECCVALMAJ) > 0 & [M:BBY0]ECCSAIFLG(nolign-1) <> 9        # hcb 117626
      Raz [M:BBY0]ECCVALMAJ(nolign-1)                                      # hcb 117626
      Raz [M:BBY0]ECCVALMIN(nolign-1)                                      # hcb 117626
      Raz [M:BBY0]ECCSAIFLG(nolign-1)                                      # hcb 117626
   Endif
Endif
End


######################################################################################

#                                                                        # hcb 51677 deb
Subprog AM_PJT(VALEUR)
Variable Char    VALEUR()
Local Char    LSEC
Local Integer I
If [M:BBY1]NBLIG=0
   [M:BBY0]PJT=VALEUR
   For I=1 To GNBDIE
       If dim([M:BBY0]CCE)>0
          Raz [M:BBY0]CCE(I-1)
          Call INISEC (LSEC, "STKBBYH", I) From TRTX3CPT
          [M:BBY0]CCE(I-1) = LSEC
       Else
          Break
       Endif
    Next
Endif
End
#                                                                        # hcb 51677 fin

