#<AdxTL>@(#)1.0.0.0 $Revision$
End

#################################################################################
#  SIXGAS : pour traitements de bascule Integrale --> X3                        #
#################################################################################
#                                                                               #
# Subprog SIXGAS                                                                #
#     Reprise de l'historique gĂŠnĂŠrale et analytique                            #
#  => CrĂŠation de piĂ¨ces comptables X3 en ĂŠtat dĂŠfinitif                        #
#                                                                               #
# PREREQUIS :                                                                   #
# ***********                                                                   #
#   - Les tables de base et de paramĂŠtrage ont dues ĂŞtre intĂŠgrĂŠes              #
#     et contrĂ´lĂŠes (sociĂŠtĂŠs, sites, devises, clients, fournisseurs,           #
#     tiers, journaux comptables, modes de rĂ¨glement, comptes, natures,         #
#     axes analytiques, sections analytiques)                                   #
#   - La date dĂŠbut exercice a dĂť ĂŞtre renseignĂŠe et doit valoir la date        #
#     dĂŠbut du premier exercice ouvert ou la date dĂŠbut d'un exercice           #
#     fermĂŠ                                                                     #
#     EXEMPLE 1 : exercices 2005 (FermĂŠ), 2006 (Ouvert), 2007 (Ouvert)          #
#       => La date dĂŠbut exercice peut valoir : 01/01/2005. Dans ce cas,        #
#          on reprendra tous les mouvements de 2005, 2006 et 2007 ainsi         #
#          que l'A-nouveau gĂŠnĂŠrĂŠ au 01/01/2005 pour report des soldes des      #
#          comptes au 31/12/2004. Une clĂ´ture sur 2005 devra ĂŞtre lancĂŠe        #
#          sur X3                                                               #
#       => La date dĂŠbut exercice peut valoir : 01/01/2006. Dans ce cas,        #
#          on reprendra tous les mouvements de 2006 et 2007 ainsi               #
#          que l'A-nouveau gĂŠnĂŠrĂŠ au 01/01/2006 pour report des soldes des      #
#          comptes au 31/12/2005.                                               #
#     EXEMPLE 2 : exercices 2005 (FermĂŠ), 2006 (FermĂŠ), 2007 (Ouvert)           #
#       => La date dĂŠbut exercice peut valoir : 01/01/2005, 01/01/2006          #
#          ou 01/01/2007                                                        #
#   - Les types de piĂ¨ces et les compteurs de numĂŠrotation ont dues ĂŞtre        #
#     dĂŠfinis (on livre des types de piĂ¨ces associĂŠes Ă  des codes               #
#     compteurs documents mais le paramĂŠtrage doit ĂŞtre acceptĂŠ ou              #
#     modifiĂŠ en fonction des besoins                                           #
#   - Les ĂŠchĂŠances non encore arrivĂŠes Ă  l'ĂŠtape "RA" ont dues ĂŞtre            #
#     repassĂŠes Ă  l'ĂŠtape "SA" (saisie) dans l'IntĂŠgrale                        #
#                                                                               #
#                                                                               #
# OPTIONS (Ă  dĂŠfinir dans l'ĂŠcran de lancement)                                 #
# *******                                                                       #
#   - [F:SPX]OPTDEV  : 1:Reprendre les montants en devise de sociĂŠtĂŠ            #
#                      2:Reprendre les montants en devise de transaction        #
#   - [F:SPX]OPTMULTIDEV : Si [F]OPTDEV=2, l'option [F]OPTMULTIDEV permet de    #
#                     dĂŠfinir ce qu'on va faire dans le cas d'ĂŠcritures         #
#                     multi-devises (=dans le cas oĂš le groupe d'ĂŠcritures      #
#                     IntĂŠgrale comporte plus d'une devise autre que la         #
#                     devise de sociĂŠtĂŠ)                                        #
#   - [F:SPX]ACCRNDDEB,[F:SPX]ACCRNDCDT: Compte d'arrondi crĂŠditeur et dĂŠbiteur #
#################################################################################

Gosub SI_CONTEXT From SIXFONCTION
SI_SIMU=1
Local File SIPARX3  [SPX]
Read [SPX] First

Global Integer X_NB
Call OUVRE_BOITE("XIHISCBGNR",200000) From GESECRAN
Raz X_NB
Call EXEC From SIXGAS
Call FERME_BOITE From GESECRAN
Kill X_NB

End

#########################################################################
Subprog EXEC

If !clalev([F:XGAS]) : Local File =SI_DOSSIER+".XIHISCBGNR"  [XGAS]  : Endif  # Historique gĂŠnĂŠral
If !clalev([F:XGAA]) : Local File =SI_DOSSIER+".XIHISANA"    [XGAA]  : Endif  # Historique analytique

If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"     [SPX]   : Endif  # ParamĂŠtrage migration
If !clalev([F:SPJ])  : Local File =SI_DOSSIER+".SIPARJOU"    [SPJ]   : Endif  # ParamĂŠtrage migration

Read [SPX] First
Read [SPJ] First

Filter [XGAS] Where FLGREP<>2
Read [XGAS]IND0 First
Filter [XGAS]
If fstat : End : Endif

Local Integer WOUV_TRACE
If GTRACE = ""
 # Historique gĂŠnĂŠral et analytique
 Call OUVRE_TRACE("SIXGAS : "+SI_MES(130)) From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#---- Historique gĂŠnĂŠral et analytique => CrĂŠation ĂŠcritures dĂŠfinitives ------#
Call ECR_TIME(SI_MES(130)-"=>"-SI_MES(131)) From DOSSUB

If [F:SPJ]JOU=""
 # Type de piĂ¨ce - ParamĂ¨tre non dĂŠfini
 Call ECR_TRACE(mess(10,105,1)-":"-mess(141,105,1),1) From GESECRAN : Goto FIN_GAS
Endif

Call SI_GAS([F:SPX]OPTDEV,[F:SPX]OPTMULDEV,[F:SPX]AMTDIF,[F:SPX]OPTDIF,[F:SPX]ACCRNDDEB,[F:SPX]ACCRNDCDT,[F:SPX]OPTANA,[F:SPX]CCEDEF,[F:SPX]ACCTMP,[F:SPX]DACDIAGEN)
If GOK<>1 : Goto FIN_GAS : Endif

$FIN_GAS
Onerrgo
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
Resume


######################################################################################
## Traitement historique gĂŠnĂŠral et analytique
######################################################################################
Subprog SI_GAS(OPTDEV,OPTMULTIDEV,ECART,OPTDIF,CPTECARD,CPTECARC,OPTANA,CCEDEF,CPTATT,SCHEMA)
Value Integer OPTDEV          : # Option reprise ĂŠcritures => 1:en devise locale 2:en devise mouvement
Value Integer OPTMULTIDEV     : # Option multi-devises => 1:reprise en devise locale 2:reprise sur la 1Ă¨re devise trouvĂŠe
Value Decimal ECART           : # Montant ĂŠcart autorisĂŠ
Value Integer OPTDIF          : # Si 1:Reprise en devise locale si montant ĂŠcart dĂŠpassĂŠ 2:saupoudrage
Value Char    CPTECARD()      : # Compte ĂŠcart d'arrondi en devise si dĂŠbiteur
Value Char    CPTECARC()      : # Compte ĂŠcart d'arrondi en devise si crĂŠditeur
Value Integer OPTANA          : # Si 2:Reprise analytique de l'IntĂŠgrale ; Si 1:Initialisation ana via section/dĂŠfaut
Value Char    CCEDEF()        : # Section par dĂŠfaut pour initialisation analytique lorsque OPTANA<>2
Value Char    CPTATT()        : # Compte d'attente (temporaire) : utile en cas de dĂŠpassement de piĂ¨ce
Value Char    SCHEMA()        : # Transaction de saisie comptable


If !clalev([F:XGAS]) : Local File =SI_DOSSIER+".XIHISCBGNR"   [XGAS]  : Endif  # Historique gĂŠnĂŠral
If !clalev([F:XGA2]) : Local File =SI_DOSSIER+".XIHISCBGNR"   [XGA2]  : Endif  # Historique gĂŠnĂŠral
If !clalev([F:XGA3]) : Local File =SI_DOSSIER+".XIHISCBGNR"   [XGA3]  : Endif  # Historique gĂŠnĂŠral
If !clalev([F:XGA4]) : Local File =SI_DOSSIER+".XIHISCBGNR"   [XGA4]  : Endif  # Historique gĂŠnĂŠral
If !clalev([F:XGAA]) : Local File =SI_DOSSIER+".XIHISANA"     [XGAA]  : Endif  # Historique analytique
If !clalev([F:XAA2]) : Local File =SI_DOSSIER+".XIHISANA"     [XAA2]  : Endif  # Historique analytique

Gosub OUVFIC
Gosub DECLARE
If STAT : End : Endif

SI_SUBPRG = "SIXGAS"
SI_TABLE  = "XIHISCBGNR"
Gosub SI_CRITSUP From SIXFONCTION

CRITERE="1=1"

Call VARGLOBANA(MESSA,STAT)
If STAT
 ## Nb d'axes dĂŠfinis dans l'IntĂŠgrale pas cohĂŠrent avec le dimensionnement du code activitĂŠ ANA => On arrĂŞte
 Call ECR_TRACE(MESSA,1) From GESECRAN : End
Endif

Read [XSOC]  First
If !fstat
 [L]DEVLOC = [F:XSOC]DVSIPC
Endif
Read [XSO1]  First
Read [SPX]   First

## Qu'une sociĂŠtĂŠ forcĂŠment...
Read [CPY]CPY0 First
If !fstat
 [L]SOCIETE   = [F:CPY]CPY
 [L]SITE      = [F:CPY]MAIFCY
 [L]ORIGINE   = "H"
 [L]DATPREMEX = [F:CPY]STRPER
 If [L]DATPREMEX = [0/0/0]
  # Date dĂŠbut premier exercice non dĂŠfinie
  Call ECR_TRACE(SI_MES(132),1) From GESECRAN : End
 Endif
 IGCM   = find([F:CPY]ACM,GGCM(1..GGCMNBR))
 If IGCM
  ILED = find(GLEDANA(IGCM),GLED(1..GLEDNBR))
 Endif
 Call GETSOC([L]SITE) From DEVSUB
 Call LEC_COA(1,[F:SPX]CPY,[L]COAGEN) From SIXCPY
 Call LEC_COA(2,[F:SPX]CPY,[L]COAANA) From SIXCPY
Endif

# Lecture paramĂ¨tres
Call PARAM("","FUPMAX",GDIV(0)) From ADOVAL     :# Niveau maxi de relance
[L]NBSEUIL = val(GDIV(0))

#--- Code taxe obligatoire
If dim(GSAITAX)>0
 Call PARAM([L]SOCIETE,"SAITAX",PARAMETRE) From ADOVAL
 GSAITAX  = val(PARAMETRE)
Endif
#--- Code taxe exonĂŠrĂŠ
If dim(GEXETAX)>0
 Call PARAM([L]SOCIETE,"EXETAX",PARAMETRE) From ADOVAL
 GEXETAX  = PARAMETRE
Endif


Call LEC_GAC(CPTATT,[L]COAGEN) From CPTLEC
If fstat
 # ParamĂ¨tre non dĂŠfini
 STAT = 99 : Call ECR_TRACE(SI_MES(185)-mess(141,105,1),1) From GESECRAN : End
Endif
If OPTDEV=2
 Call LEC_GAC(CPTECARC,[L]COAGEN) From CPTLEC
 If fstat | CPTECARC=""
  # ParamĂ¨tre non dĂŠfini
  STAT = 99 : Call ECR_TRACE(SI_MES(186)-mess(141,105,1),1) From GESECRAN : End
 Endif
 Call LEC_GAC(CPTECARD,[L]COAGEN) From CPTLEC
 If fstat | CPTECARD=""
  # ParamĂ¨tre non dĂŠfini
  STAT = 99 : Call ECR_TRACE(SI_MES(187)-mess(141,105,1),1) From GESECRAN : End
 Endif
Endif

## Si exercice fermĂŠ, position de statut pour la recherche du Code Letrrage.
Raz [L]FLGLTR
If [F:XSOC]DEBEXCN2=[L]DATPREMEX
 If [F:XSOC]ETAEXCN2<>'O' : [L]FLGLTR = 1 : [L]DATLTR=[F:XSOC]DEBEXCN1 : Endif
Elsif [F:XSOC]DEBEXCN1=[L]DATPREMEX
 If [F:XSOC]ETAEXCN1<>'O' : [L]FLGLTR = 1 : [L]DATLTR=[F:XSOC]DEBEXCN  : Endif
Elsif [F:XSOC]DEBEXCN=[L]DATPREMEX
 [L]FLGLTR = 0 # le dernier exercice ne peut ĂŞtre fermĂŠ.
Endif

Filter [XGAS] Where evalue(CRITERE) & FLGREP<>2 & CODJRN<>"" & X3DAT>=[L]DATPREMEX & NATMVT<>"I"
&                   Order By Key CLE = CODJRN ; X3DAT ; NUMPIEDEB ; NUMPIEFIN ; NUMECR
Filter [XGA2] Where evalue(CRITERE) & FLGREP<>2 & CODJRN<>"" & X3DAT>=[L]DATPREMEX & NATMVT<>"I"
&                   Order By Key CLE = CODJRN ; X3DAT ; NUMPIEDEB ; NUMPIEFIN ; NUMECR
Filter [XGAA] Where evalue(CRITERE) & FLGREP<>2 & CODJRN<>"" & X3DAT>=[L]DATPREMEX & NATMVT<>"I"
&                   Order By Key CLE = CODJRN ; X3DAT ; NUMPIEDEB ; NUMPIEFIN ; NUMECRHIS ; NUMVTL


## Parcours des ĂŠcritures de l'historique gĂŠnĂŠral par code journal/date dĂŠbut pĂŠriode/numĂŠro piĂ¨ce :
## une transaction par couple code journal/date ĂŠcriture

Call ECR_TRACE("",0) From GESECRAN

For [XGA2]CLE(2)

 ## On exclut les piĂ¨ces d'A-nouveaux (sauf celle qui correspond au premier exercice repris)
 If [F:XGA2]X3DAT=[L]DATPREMEX or ([F:XGA2]X3DAT<>[L]DATPREMEX and !find([F:XGA2]ORGECR,"A","H","Q"))
  Call DEBTRANS From GLOCK
  # Reprise Journal ... ; PĂŠriode ...
  Call ECR_TRACE(SI_MES(135)-mess(13,105,1)-[F:XGA2]CODJRN-";"-mess(59,116,1)-format$(GFMDAT,[F:XGA2]X3DAT),0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Gosub TR_PCE
  Call ECR_TRACE("",0) From GESECRAN
 Endif
Next
End


$TR_PCE

Trbegin [HAE], [DAE], [DAA], [DUD], [XGAS], [XGA2], [XGA3], [XGAA], [XDUD], [PER]

 Gosub OUV_PER

 ## Parcours des piĂ¨ces associĂŠes au mĂŞme code journal et Ă  la mĂŞme date dĂŠbut de pĂŠriode

 ## 1Ă¨re passe : on traite les ĂŠcritures IntĂŠgrale ayant un numĂŠro de piĂ¨ce renseignĂŠ
 ## (champs NUMPIEDEB et NUMPIEFIN<>"")
 ## Si ces ĂŠcritures rattachĂŠes Ă  un mĂŞme numĂŠro de piĂ¨ce IntĂŠgrale sont ĂŠquilibrĂŠes en devise
 ## sociĂŠtĂŠ, on crĂŠe une piĂ¨ce X3.
 ## Si on a dĂŠcidĂŠ de reprendre les ĂŠcritures en devise et que ces ĂŠcritures sont multi-devises,
 ## deux possibilitĂŠs :
 ## - L'option "PremiĂ¨re devise trouvĂŠe" n'a pas ĂŠtĂŠ cochĂŠe" => On reprend la piĂ¨ce en devise de sociĂŠtĂŠ
 ## - L'option "PremiĂ¨re devise trouvĂŠe" a ĂŠtĂŠ cochĂŠe" => on reprend la piĂ¨ce sur la premiĂ¨re devise trouvĂŠe
 ##   diffĂŠrente de la devise de sociĂŠtĂŠ
 ## NB : Vu avec PSB (13/03/2007) : Si la zone origine de l'historique est "G", "X" et "Y"
 ## c'est que la piĂ¨ce vient de la gestion commerciale.
 ## Dans ce cas, les ĂŠcritures associĂŠes Ă  un mĂŞme numĂŠro de piĂ¨ce (champs NUMPIEDEB et NUMPIEFIN)
 ## sont forcĂŠment ĂŠquilibrĂŠes (sauf si elles ont ĂŠtĂŠ transformĂŠes en "C" (Centralisation, notamment
 ## pour les ĂŠcritures de TVA)).
 ## On crĂŠera une piĂ¨ce X3 par numĂŠro de piĂ¨ce IntĂŠgrale ssi il n'y a pas d'ĂŠcritures de centralisation
 PASSE = 1
 Gosub PASSE1
 If GOK<1
  Rollback
  # Journal... ; PĂŠriode ...  ... Reprise non faite => Ă  relancer
  Call ECR_TRACE(mess(13,105,1)-[F:XGA2]CODJRN-";"-mess(59,116,1)-format$(GFMDAT,[F:XGA2]X3DAT)-":"-SI_MES(139),0) From GESECRAN
  Return
 Endif

 ## 2iĂ¨me passe : on va traiter toutes les ĂŠcritures non traitĂŠes dans la 1Ă¨re passe, c'est-Ă -dire
 #     * toutes les ĂŠcritures rattachĂŠes Ă  un numĂŠro de piĂ¨ce IntĂŠgrale (champs NUMPIEDEB et NUMPIEFIN <>"")
 #       et sont desĂŠquilibrĂŠes en devise sociĂŠtĂŠ
 #     * toutes les ĂŠcritures qui ne sont pas rattachĂŠes Ă  un numĂŠro de piĂ¨ce IntĂŠgrale (champs NUMPIEDEB
 #       et NUMPIEFIN vides)
 PASSE = 2
 Gosub PASSE2

 Gosub CLO_PER

 If GOK>0 & SI_SIMU<>2
  Commit
 Else
  Rollback
  If STAT | GOK<1
   # Journal... ; PĂŠriode ...
   Call ECR_TRACE(mess(13,105,1)-[F:XGA2]CODJRN-";"-mess(59,116,1)-format$(GFMDAT,[F:XGA2]X3DAT)-":"-SI_MES(139),0) From GESECRAN
   Return
  Endif
 Endif
Return

$PASSE1
For [XGAS]CLE(4) Where CODJRN=[F:XGA2]CODJRN & X3DAT=[F:XGA2]X3DAT & NUMPIEDEB<>"" & NUMPIEFIN<>""
 JOURNAL  = [F:XGAS]CODJRN
 DATCPT   = [F:XGAS]DATECR
 TYPPIECE = [F:XGAS]NUMPIEDEB
 NUMPIECE = [F:XGAS]NUMPIEFIN

 ## 1Ă¨re chose Ă  vĂŠrifier : le groupe d'ĂŠcritures associĂŠes au mĂŞme nÂ° de piĂ¨ce doit ĂŞtre ĂŠquilibrĂŠ
 ## en devise sociĂŠtĂŠ. D'autre part, le nombre d'ĂŠcritures de ce groupe ne doit pas dĂŠpasser
 ## le nb d'ĂŠcritures maximum d'une piĂ¨ce X3
 Gosub VERF_EQUI_LOC
 If EQUILIBRE & NBECT<MAXECT
  Gosub DEV_PIECE : # Reprise de la piĂ¨ce en quelle devise ?
  Gosub PIECE
  If GOK<1 : Break : Endif
 Endif
Next
If GOK<1 : Return : Endif
Return


$PASSE2
For [XGAS]CLE(2) Where CODJRN=[XGA2]CODJRN & X3DAT=[XGA2]X3DAT & FLGREP<>2

 JOURNAL  = [F:XGAS]CODJRN
 Gosub DEV_PIECE  : # Reprise de la piĂ¨ce en quelle devise ?
 Gosub PIECE
 If  GOK<1 : Break : Endif
Next
If  GOK<1 : Return : Endif
Return


$DEV_PIECE
If [L]OPTDEV=1
 ## option 1 : on a demandĂŠ la reprise des piĂ¨ces en devise sociĂŠtĂŠ => piĂ¨ce tjs crĂŠĂŠe en devise sociĂŠtĂŠ
 OKDEV = 0 : [L]DEVPCE=[L]DEVLOC
Else
 ## option 2 : on a demandĂŠ la reprise des piĂ¨ces en devise. Plusieurs possibilitĂŠs :
 ## 1/ La piĂ¨ce ne comporte que des mouvements en devise sociĂŠtĂŠ (=toutes les ĂŠcritures ont le
 ##    champ CODDVS vide) => On reprend la piĂ¨ce en devise sociĂŠtĂŠ
 ## 2/ La piĂ¨ce ne comporte que des mouvements autre que la devise sociĂŠtĂŠ (=toutes les ĂŠcritures ont le
 ##    champs CODDVS non vide et avec la mĂŞme valeur) => On reprend la piĂ¨ce en devise de transaction
 ##    (Ă  condition que le groupe d'ĂŠcritures soit ĂŠquilibrĂŠ en devise (thĂŠoriquement oui, mais si
 ##    ce n'est pas le cas, on reprendra la piĂ¨ce en devise de sociĂŠtĂŠ)
 ## 3/ La piĂ¨ce comporte des ĂŠcritures en devise sociĂŠtĂŠ et des ĂŠcritures dans UNE autre devise (une seule
 ##    autre) => On reprend la piĂ¨ce en devise de transaction. La contre-valeur en devise de transaction
 ##    des ĂŠcritures rattachĂŠes Ă  la devise sociĂŠtĂŠ dans l'IntĂŠgrale sera calculĂŠe en prenant le cours
 ##    de la 1Ă¨re ĂŠcriture rattachĂŠe Ă  la devise de transaction trouvĂŠe
 ## 4/ La piĂ¨ce comporte plusieurs devises autre que la devise de sociĂŠtĂŠ et on a demandĂŠ
 ##    l'option de reprise en devise sociĂŠtĂŠ dans le cas d'ĂŠcritures multi-devises => On reprend
 ##    la piĂ¨ce en devise sociĂŠtĂŠ
 ## 5/ La piĂ¨ce comporte plusieurs devises autre que la devise de sociĂŠtĂŠ et
 ##    on a demandĂŠ l'option de reprise sur la 1Ă¨re devise trouvĂŠe dans le cas d'ĂŠcritures
 ##    multi-devises => On reprend la piĂ¨ce dans la 1Ă¨re devise trouvĂŠe autre que la devise de sociĂŠtĂŠ
 ##    La contre-valeur en devise de transaction des ĂŠcritures rattachĂŠes Ă  d'autres devises (sociĂŠtĂŠ
 ##    ou autres) sera calculĂŠe en prenant le cours de la 1Ă¨re ĂŠcriture rattachĂŠe Ă  la devise
 ##    transaction trouvĂŠe
 Gosub CAS
 Case CAS
  When 1, 4
   OKDEV = 0 : [L]DEVPCE = [L]DEVLOC
  When 2, 3, 5
   For I=1 To NBDEV
    If TDEVISE(I)<>[L]DEVLOC
     OKDEV = 1 : [L]DEVPCE = TDEVISE(I) : Break
    Endif
   Next
   #   If CAS = 3 | CAS = 5 # Ajout du CAS = 2 car le cours est utilisĂŠ pour les montants analytiques (en rapport avec la demande 46730)
   If CAS = 3 | CAS = 5 | CAS = 2
    Filter [XGA3] Where CODJRN=[F:XGAS]CODJRN & X3DAT=[F:XGAS]X3DAT & NUMPIEDEB=[F:XGAS]NUMPIEDEB
&                     & NUMPIEFIN=[F:XGAS]NUMPIEFIN & CODDVS=[L]DEVPCE
&                 Order By Key CLE = CODJRN ; X3DAT ; NUMPIEDEB ; NUMPIEFIN ; NUMECR
    Read [XGA3]CLE First
    Filter [XGA3]
    COURDEV = [F:XGA3]TAUDVS1
   Endif
  When Default
   OKDEV = 0 : [L]DEVPCE = [L]DEVLOC
 Endcase
Endif

Call LEC_TCU(func SIXFONCTION.SI_COR("XIDVS",[L]DEVPCE,"TABCUR","")) From CPTLEC
ARRONDI = [F:TCU]CURRND
Return


$PIECE
STAT = 0 : SPSTAT = 0
Gosub RAZPCE
Gosub LIGNE
If GOK<1 : Return : Endif
Return

$RAZPCE
Raz TOTDEB, TOTCDT, TOTDEBLOC, TOTCDTLOC
Raz [M:HAE0], [M:HAE1], [M:HAE2], [M:VTL], [M:VT2]
Return


$LIGNE
For [XGAS]CLE

 Call AFFBOITE([F:XGAS]CODJRN-format$("D:"+GFMDAT4,[F:XGAS]DATECR)-[F:XGAS]NUMPIEDEB-[F:XGAS]NUMPIEFIN) From SUBSIM

 If PASSE = 2
  DATCPT   = [F:XGAS]DATECR
  TYPPIECE = [F:XGAS]NUMPIEDEB
  NUMPIECE = [F:XGAS]NUMPIEFIN
 Endif
 NOL = [M:HAE2]NBLIG
 If [F:XGAS]CLF<>""
  # C'est un collectif
  [M:HAE2]ACC1(NOL) = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XGAS]CLF,"GACCOUNT","")
  Call LEC_GAC([M:HAE2]ACC1(NOL),[L]COAGEN) From CPTLEC
  If !fstat
   [M:HAE2]SAC1(NOL) = [F:GAC]ACCSHO
  Else
   # Erreur en lecture
   GOK = 0 : Call ECR_TRACE("GACCOUNT"-mess(49,125,1)-[F:XGAS]CLF,1) From GESECRAN : Break
  Endif
  ## Dans le cas d'un collectif, on a le compte auxiliaire dans [F:XGAS]CPT.
  ## On alimente le tiers [M:HAE2]BPR(NOL) par le code client/fournisseur qui est associĂŠ au
  ## compte auxiliarisĂŠ contenu dans [F:XGAS]CPT (sachant que thĂŠoriquement, la fiche tiers (BPARTNER) a ĂŠtĂŠ
  ## crĂŠĂŠ avec comme code tiers le code client ou le code fournisseur
  ## => alimentation tiers Ă  revoir...
  Read [XGAC]IND0 = [F:XGAS]CLF
  If !fstat
   Case [F:XGAC]TYPCLF
    When "C" : # Clients
     Filter [XBPC] Where CPTAUX = [F:XGAS]CPT
     Read [XBPC] First
     Filter [XBPC]
     If !fstat
      [M:HAE2]BPR(NOL) = func SIXFONCTION.SI_COR("XICLT",[F:XBPC]CODCLT,"BPCUSTOMER","")
     Else
      # Erreur en lecture
      GOK = 0 : Call ECR_TRACE("BPCUSTOMER"-mess(49,125,1)-[F:XGAS]CPT,1) From GESECRAN : Break
     Endif
    When "F" : # Fournisseurs
     Filter [XBPS] Where CPTAUX = [F:XGAS]CPT
     Read [XBPS] First
     Filter [XBPS]
     If !fstat
      [M:HAE2]BPR(NOL) = func SIXFONCTION.SI_COR("XIFOU",[F:XBPS]CODFOU,"BPSUPPLIER","")
     Else
      # Erreur en lecture
      GOK = 0 : Call ECR_TRACE("BPSUPPLIER"-mess(49,125,1)-[F:XGAS]CPT,1) From GESECRAN : Break
     Endif
    When "O" : # Tiers divers
     ## La fiche tiers (BPARTNER) a thĂŠoriquement ĂŠtĂŠ crĂŠĂŠe lors de la reprise des comptes (crĂŠation dans
     ## BPARTNER des tiers Ă  partir de la table IntĂŠgrale PLA_CTB_AUX (XIPLACBGNR). Ces tiers ont ĂŠtĂŠ crĂŠĂŠs
     ## en tant que tiers divers
     [M:HAE2]BPR(NOL) = func SIXFONCTION.SI_COR("XIPLACBAUX",[F:XGAS]CPT,"GACCOUNT","")
     Gosub VERIF_AUZBPR
     If !GOK : Break : Endif
   Endcase
  Else
   # Erreur en lecture
   GOK = 0 : Call ECR_TRACE("GACCOUNT"-mess(49,125,1)-[F:XGAS]CLF,1) From GESECRAN : Break
  Endif
 Else
  [M:HAE2]ACC1(NOL) = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XGAS]CPT,"GACCOUNT","")
  Call LEC_GAC([M:HAE2]ACC1(NOL),[L]COAGEN) From CPTLEC
  [M:HAE2]SAC1(NOL) = ""
  [M:HAE2]BPR(NOL)  = ""
 Endif
 Call LEC_CPY(SOCIETE) From CPTLEC
 [M:HAE2]FCYLIN(NOL) = [F:CPY]MAIFCY
 [M:HAE2]DES(NOL) = [F:XGAS]LIBECR

 # Dans le cas d'un exercice fermĂŠ, l'abrĂŠviation XGA4 contient la piĂ¨ce d'anouveau
 Gosub RECHERCHE_CODE

 If [F:XGAS]CODLTR<>""
  ## RĂŠfĂŠrence libre : si l'ĂŠcriture a ĂŠtĂŠ lettrĂŠe dans l'IntĂŠgrale, on met dans la rĂŠfĂŠrence libre :
  ## [Code lettrage IntĂŠgrale]+[Compte]+[Tiers]. Ceci permettra de relancer un lettrage automatique dans X3
  ## pour relettrer les ĂŠcritures
  If [F:XGAS]CLF<>""
   [M:HAE2]FREREF(NOL) = [L]CODLTR+" "+[F:XGAS]CLF+" "+[F:XGAS]CPT+string$(len([F:XGAS]CODLTR+" "+[F:XGAS]CLF+" "+[F:XGAS]CPT),"*")
  Else
   [M:HAE2]FREREF(NOL) = [L]CODLTR+" "+[F:XGAS]CPT
  Endif
 Else
  ## RĂŠfĂŠrence libre : Si l'ĂŠcriture n'a pas ĂŠtĂŠ lettrĂŠe dans l'IntĂŠgrale, on met dans la rĂŠfĂŠrence libre :
  ## Le numĂŠro de piĂ¨ce, s'il y en a une. Le libellĂŠ de l'ĂŠcriture dans le cas contraire. Ceci permettra
  ## de lettrer par exemple des factures dont le rĂ¨glement est saisi directement en compta dans X3
  #If [F:XGAS]NUMPIEFIN<>""
  # [M:HAE2]FREREF(NOL) = [F:XGAS]NUMPIEDEB+" "+[F:XGAS]NUMPIEFIN
  #Else
  # [M:HAE2]FREREF(NOL) = [F:XGAS]LIBECR
  #Endif
 Endif
 ## On initialise le code taxe de la mĂŞme maniĂ¨re qu'en saisie de piĂ¨ce comptable. AprĂ¨s reprise des comptes,
 ## il sera recommandĂŠ de renseigner le codes taxes par dĂŠfaut sur les comptes pour que les ĂŠcritures reprises
 ## soient rattachĂŠes au bon code taxe. En outre, on laissera la possibilitĂŠ de prendre la main dans le
 ## traitement de reprise des ĂŠcritures pour changer l'initialisation de certaines donnĂŠes
 If [F:GAC]COA=[L]COAGEN & [F:GAC]FLGVAT=1
  [M:HAE2]TAX(NOL) = ""
 Else
  # ParamĂ¨tre EXETAX (Tronc commun)
  If dim(GEXETAX)>0 : [M:HAE2]TAX(NOL) = GEXETAX : Endif
  # Code taxe renseignĂŠ au niveau du compte gĂŠnĂŠral
  If [F:GAC]VAT(0)<>"" : [M:HAE2]TAX(NOL) = [F:GAC]VAT(0) : Endif
  # Code taxe pas obligatoire au niveau du compte
  If dim(GSAITAX)>0 & GSAITAX=1 & [F:GAC]VAT(0)=""
   TIERS=""
   For I=0 To NOL
    If [M:HAE2]BPR(I)<>"" : TIERS=[M]BPR(I) : Break : Endif
   Next I
   If TIERS<>""
    TYPTIERS = " "
    Read [BPR]BPR0 = TIERS
    If !fstat
     If [F:BPR]BPCFLG=2 : TYPTIERS="C"
     Elsif [F:BPR]BPSFLG=2 : TYPTIERS="F"
     Endif
    Endif
    Call INIT_REGIME(TIERS,[M]FCYLIN(I),TYPTIERS,[L]VAC) From CPTSUB
    Call LEC_TVB(GCURLEG,[L]VAC) From CPTLEC
    If !fstat & [F:TVB]ENAFLG=2
     CODTAX = [F:TVB]VAT   # Code taxe associĂŠ au rĂŠgime tiers
     If CODTAX<>""
      Look [TVT]TVT0 = CODTAX;GCURLEG
      If !fstat
       [M:HAE2]TAX(NOL) = CODTAX
      Else
       Look [TVT]TVT0 = CODTAX;""
       If !fstat
        [M:HAE2]TAX(NOL) = CODTAX
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
  If [F:GAC]COA=[L]COAGEN & [M:HAE2]TAX(NOL) = ""
   [M:HAE2]TAX(NOL) = GEXETAX
  Endif
 Endif

 If [F:XGAS]SENECR = "C"
  If OKDEV
   If [F:XGAS]CODDVS = [L]DEVPCE
    [M:HAE2]CDT(NOL)  = [F:XGAS]MNTDBTDVS
   Elsif [F:XGAS]CODDVS = "" | [F:XGAS]CODDVS<>[L]DEVPCE
    ## La contre-valeur en devise de transaction des ĂŠcritures rattachĂŠes Ă  d'autres devises (sociĂŠtĂŠ
    ## ou autres) sera calculĂŠe en prenant le cours de la 1Ă¨re ĂŠcriture rattachĂŠe Ă  la devise de reprise
    [M:HAE2]CDT(NOL)  = arr([F:XGAS]MNTDBTFRS*COURDEV, ARRONDI)
   Endif
  Else
   [M:HAE2]CDT(NOL)  = [F:XGAS]MNTDBTFRS
  Endif
  [L]TOTCDT    += [M:HAE2]CDT(NOL)
  [L]TOTCDTLOC += [F:XGAS]MNTDBTFRS
  Assign "[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
  Assign "[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
  Assign "[M]AMT"+num$(GTYPANA)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
  Assign "[M]AMTFRC"+num$(GTYPANA)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
 Elsif [F:XGAS]SENECR = "D"
  If OKDEV
   If [F:XGAS]CODDVS = [L]DEVPCE
    [M:HAE2]DEB(NOL) = [F:XGAS]MNTDBTDVS
   Elsif [F:XGAS]CODDVS = "" | [F:XGAS]CODDVS<>[L]DEVPCE
    ## La contre-valeur en devise de transaction des ĂŠcritures rattachĂŠes Ă  d'autres devises (sociĂŠtĂŠ
    ## ou autres) sera calculĂŠe en prenant le cours de la 1Ă¨re ĂŠcriture rattachĂŠe Ă  la devise de reprise
    [M:HAE2]DEB(NOL)  = arr([F:XGAS]MNTDBTFRS*COURDEV, ARRONDI)
   Endif
  Else
   [M:HAE2]DEB(NOL) = [F:XGAS]MNTDBTFRS
  Endif
  [L]TOTDEB += [M:HAE2]DEB(NOL)
  [L]TOTDEBLOC += [F:XGAS]MNTDBTFRS
  Assign "[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
  Assign "[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
  Assign "[M]AMT"+num$(GTYPANA)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
  Assign "[M]AMTFRC"+num$(GTYPANA)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
 Endif
 [M:HAE2]CHK(NOL) = [F:XGAS]CODDVS  # Zone renseignĂŠe temporairement (utile dans le cas du saupoudrage).

 Assign "[M]AMTFLG"+num$(GTYPGEN)+"("+num$(NOL)+")" With 1
 Assign "[M]AMTFLG"+num$(GTYPANA)+"("+num$(NOL)+")" With 1
 ## MAJ du montant de TVA dĂŠclarĂŠe (champ AMTVAT) pour les comptes soumis et les comptes de TVA
 If [M:HAE2]TAX(NOL)<>""
  Call LEC_TVT_LEG(GCURLEG,[M:HAE2]TAX(NOL)) From CPTLEC
  Gosub SENS_ECR
  Call LEC_GAC([M:HAE2]ACC1(NOL),[L]COAGEN) From CPTLEC
  If [F:GAC]VATIPT <= 2 : # TVA collectĂŠe ventes ou collectĂŠe immos
   SIGN=-1
  Else
   SIGN=1 : # TVA dĂŠductible sur achats ou immos
  Endif
  [M:HAE2]AMTVAT(NOL) = [L]SIGN*[L]SNSECR*evalue("[M:HAE2]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")")
 Endif

 Gosub INICNACCE

 [F:XGAS]FLGREP = 2
 Rewrite [F:XGAS]
 If fstat
  # Erreur d'ĂŠcriture
  Call ECR_TRACE("XIHISCBGNR"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat)-[L]JOURNAL-format$(GFMDAT,[L]DATCPT)-[L]TYPPIECE-[L]NUMPIECE-num$([F:XGAS]NUMECR),1) From GESECRAN
  GOK = 0 : Break
 Endif

 [M:HAE2]NBLIG += 1

 ## Trop de lignes => On crĂŠe la piĂ¨ce et on passe par un compte d'attente
 If (!OKDEV & [M:HAE2]NBLIG+1>=MAXECT) | (OKDEV & [M:HAE2]NBLIG+2>=MAXECT)

  If [L]TOTDEB<>[L]TOTCDT  #18/06 : TestCP (Ajout de cette cdt)
   #18/06:TestCP : Solde du compte d'acompte en premier.
   Gosub SOLDE

   #18/06:TestCP : Puis recherche d'ĂŠcart.
   If OKDEV
    ## Rajout d'une ligne pour l'ĂŠcart d'arrondi en devise : dans le cas oĂš les ĂŠcritures ont ĂŠtĂŠ reprises
    ## en devise, la contre-valeur en devise de transaction des ĂŠcritures rattachĂŠes Ă  d'autres devises (sociĂŠtĂŠ
    ## ou autres) a ĂŠtĂŠ calculĂŠe en prenant le cours de la 1Ă¨re ĂŠcriture rattachĂŠe Ă  la devise de reprise.
    ## Si un ĂŠcart est constatĂŠ, on l'enregistrera sur le compte GACRNDLOCC/GACCRNDLOCD (ou un paramĂ¨tre au niveau
    ## de l'ĂŠcran de lancement ?)
    ## Dans le cas oĂš l'ĂŠcart dĂŠpasse le montant d'ĂŠcart paramĂŠtrĂŠ, on reprendra la piĂ¨ce en devise sociĂŠtĂŠ

    Gosub GENECART
   Endif

   Gosub VALPCE
   If GOK<1 : Break : Endif

   ## RĂŠinitialisation masques, statuts, indice de ligne et variables de totalisation (TOTDEB, TOTCDT)
   ## + solde du compte d'attente pour la nouvelle piĂ¨ce X3
   STAT = 0 : SPSTAT = 0
   Raz [M:HAE0], [M:HAE1], [M:HAE2], [M:VTL], [M:VT2]
   Raz [M:HAE2]NBLIG
   NOL = [M:HAE2]NBLIG
   Gosub SOLDE_CPTATT

  Else

   Gosub VALPCE
   If GOK<1 : Break : Endif
   ##18/06:TestCP..
   STAT = 0 : SPSTAT = 0
   Raz [M:HAE0], [M:HAE1], [M:HAE2], [M:VTL], [M:VT2]
   Raz [M:HAE2]NBLIG
   NOL = [M:HAE2]NBLIG

  Endif

 Endif

Next : # For [XGAS]CLE (parcours des ĂŠcritures d'un mĂŞme code journal/date dĂŠbut pĂŠriode

If GOK<1 : Return : Endif

## CrĂŠation de la piĂ¨ce (forcĂŠment la derniĂ¨re du groupe)
If [M:HAE2]NBLIG>0
 Gosub GENECART
 Gosub VALPCE
 If GOK<1 : Return: Endif
Endif
If GOK<1 : Return: Endif
Return


$VALPCE
Gosub EN_TETE
SI_TABLE = "GACCENTRY"
Gosub SI_BEFWRI From SIXFONCTION
Call CONTROLE(STAT,MESSA) From CPTBATCH
If STAT
 Gosub MESSAGE From CPTAUTO
 If PASSE = 1
  MESSA = MESSA-[F:XGAS]NUMPIEDEB-[F:XGAS]NUMPIEFIN
 Endif
 GOK = 0 : Call ECR_TRACE(MESSA,1) From GESECRAN : Return
Endif

If SI_SIMU=2
 If PASSE = 1
  Call ECR_TRACE(mess(40,107,1)-"sur"-[M:HAE0]TYP-[M:HAE0]NUM-"au"-format$("D:"+GFMDAT4,[M:HAE0]ACCDAT)-"pour"-num$(TOTDEB)-[M:HAE1]CUR-"("+[F:XGAS]NUMPIEDEB-[F:XGAS]NUMPIEFIN+")",0) From GESECRAN
 Else
  Call ECR_TRACE(mess(40,107,1)-"sur"-[M:HAE0]TYP-[M:HAE0]NUM-"au"-format$("D:"+GFMDAT4,[M:HAE0]ACCDAT)-"pour"-num$(TOTDEB)-[M:HAE1]CUR,0) From GESECRAN
 Endif
 Return
Endif
Call VALPIECER(STAT,MESSA) From CPTBATCH
If STAT
 If PASSE = 1
  Call ECR_TRACE(MESSA-"("+[F:XGAS]NUMPIEDEB-[F:XGAS]NUMPIEFIN+")",1) From GESECRAN
 Else
  Call ECR_TRACE(MESSA,1) From GESECRAN
 Endif
 GOK = 0 : Return
Endif
If GOK<1 : Return : Endif
Gosub RECUP_ECHE
If GOK<1 : Return : Endif
# CrĂŠation piĂ¨ce
If PASSE = 1
 Call ECR_TRACE(mess(40,107,1)-[F:HAE]TYP-[F:HAE]NUM-format$("D:"+GFMDAT4,[F:HAE]ACCDAT)-"("+[F:XGAS]NUMPIEDEB-[F:XGAS]NUMPIEFIN+")",0) From GESECRAN
Else
 Call ECR_TRACE(mess(40,107,1)-[F:HAE]TYP-[F:HAE]NUM-format$("D:"+GFMDAT4,[F:HAE]ACCDAT),0) From GESECRAN
Endif
Return

$VERIF_AUZBPR
# Verification que le tiers selon ses "ROLES" Ă  l'autorisation correspondante sur le compte
Raz OK
Call LECTURE("BPR",[M:HAE2]BPR(NOL),"") From CONTOBJ
OK += [F:BPR]BPCFLG=2 & [F:GAC]AUZBPR(0)=2
OK += [F:BPR]BPSFLG=2 & [F:GAC]AUZBPR(1)=2
OK += [F:BPR]BPTFLG=2 & [F:GAC]AUZBPR(2)=2
OK += [F:BPR]FCTFLG=2 & [F:GAC]AUZBPR(3)=2
OK += [F:BPR]REPFLG=2 & [F:GAC]AUZBPR(4)=2
OK += [F:BPR]BPRACC=2 & [F:GAC]AUZBPR(5)=2

If OK : Return : Endif

Readlock [F:GAC] Curr
If fstat
 # Erreur de lecture
 GOK = 0 : Call ECR_TRACE("GACCOUNT"-mess(49,125,1)-[F:GAC]ACC,1) From GESECRAN : Return
Endif

If [F:BPR]BPCFLG=2 : [F:GAC]AUZBPR(0)=2 : Endif
If [F:BPR]BPSFLG=2 : [F:GAC]AUZBPR(1)=2 : Endif
If [F:BPR]BPTFLG=2 : [F:GAC]AUZBPR(2)=2 : Endif
If [F:BPR]FCTFLG=2 : [F:GAC]AUZBPR(3)=2 : Endif
If [F:BPR]REPFLG=2 : [F:GAC]AUZBPR(4)=2 : Endif
If [F:BPR]BPRACC=2 : [F:GAC]AUZBPR(5)=2 : Endif

Rewrite [GAC]
If fstat
 # Compte... : ... (...) Erreur d'ĂŠcriture
 Call ECR_TRACE(mess(45,102,1)-[F:GAC]ACC-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0 : Return
Endif
Return

$RECUP_ECHE


For NOL=0 To [M:HAEW]NB-1


 If [M:HAEW]SAC(NOL)<>"" & [M:HAEW]REFINTLIN(NOL)<>"" & [M:HAEW]LEDTYP(NOL)=GTYPGEN

  ## On regarde si on trouve la (ou les) ĂŠchĂŠances dans la table des ĂŠchĂŠances de l'IntĂŠgrale
  ## Si on en trouve, alors on efface les ĂŠchĂŠances crĂŠĂŠes par X3 pour pouvoir rĂŠcupĂŠrer
  ## les ĂŠchĂŠances de l'IntĂŠgrale
  ## Rappel de la contrainte imposĂŠe => une ĂŠchĂŠance qui se trouverait dans l'IntĂŠgrale Ă  une ĂŠtape supĂŠrieure
  ## Ă  "S*" (ĂŠtat 'saisi') mais pas encore Ă  l'ĂŠtape "RA" (Rapprochement bancaire) pose des problĂ¨mes pour la
  ## reprise. On contraint les clients Ă  repasser leur ĂŠchĂŠance Ă  l'ĂŠtat "S*" juste avant la migration
  Filter [XDUD] Where FICORG=[L]ORIGINE & ADRORG=[M:HAEW]REFINTLIN(NOL)
  Read [XDUD]IND1 First
  Filter [XDUD]
  If !fstat
   ## Effacement des ĂŠchĂŠances crĂŠĂŠes par X3
   Delete [DUD] Where ACCNUM=[M:HAEW]ACCNUM(NOL)
   If fstat=1
    GOK = -1 : GLOCK="$GACCDUDATE" : Break
   Endif
   ## RĂŠcupĂŠration des ĂŠchĂŠances de l'IntĂŠgrale
   Read [DAE]DAE2 = [M:HAEW]ACCNUM(NOL)
   XNBECH = 0 : NBECH = 0 : TOTAMTCUR = 0 : XMNTECH = 0

   ## 1Ă¨re petite passe pour connaĂŽtre le nb d'ĂŠchĂŠances associĂŠ Ă  la ligne d'ĂŠcriture...
   For [XDUD] Where FICORG=[L]ORIGINE & ADRORG=[M:HAEW]REFINTLIN(NOL)
    XNBECH += 1
    XMNTECH += [F:XDUD]MNTECHFRS
   Next

   # Dans le cas d'ĂŠchĂŠance ĂŠpurĂŠe donc soldĂŠe, X3 doit gĂŠnĂŠrĂŠ automatiquement cette ĂŠchĂŠance.
   If [XDUD]MNTPIEFRS>[L]XMNTECH : ECH_SUPP=1 Else ECH_SUPP=0 : Endif

   # Parcours des ĂŠchĂŠances
   For [XDUD] Where FICORG=[L]ORIGINE & ADRORG=[M:HAEW]REFINTLIN(NOL)
    If ECH_SUPP
     XNBECH +=1 #Ddm46939
     Gosub TRT_ECH
     ECH_SUPP = 0
     Gosub TRT_ECH
    Else
     Gosub TRT_ECH
    Endif
   Next


  Else

   ## Pas d'ĂŠchĂŠance trouvĂŠe dans l'IntĂŠgrale. Cela signifie soit que l'ĂŠchĂŠance a ĂŠtĂŠ ĂŠpurĂŠe (parce qu'arrivĂŠe
   ## en RA, donc rĂ¨glĂŠe), soit que c'est une ĂŠchĂŠance de rĂ¨glement. Dans les deux cas, l'ĂŠchĂŠance X3
   ## correspondante doit ĂŞtre considĂŠrĂŠe comme rĂ¨glĂŠe
   For [DUD] Where ACCNUM=[M:HAEW]ACCNUM(NOL)
    [F:DUD]PAYCUR = [F:DUD]AMTCUR
    [F:DUD]PAYLOC = [F:DUD]AMTLOC
    Call SLDECH("DUD")From MODECHE #Ddm46939
    SI_TABLE = "GACCDUDATE"
    Gosub SI_BEFWRI From SIXFONCTION
    Rewrite [DUD]
    If fstat
     GOK = 0 : Call FSTA("DUD") From GLOCK : Break 2
    Endif
   Next
  Endif
 Endif
Next NOL
If GOK<1 : Return : Endif
Return

$TRT_ECH
NBECH += 1
Raz [F:DUD]
[F:DUD] = [F:HAE]
nolign = NOL+1
[F:DUD] = [M:HAEW]
[F:DUD]CUR    = [M:HAE1]CUR
#[F:DUD]LIG    = nolign
[F:DUD]LIG=[F:DAE]LIN
[F:DUD]DUDLIG = NBECH
[F:DUD]DUDSTA = 2
[F:DUD]FCY    = [M:HAEW]FCYLIN(NOL)
[F:DUD]BPRPAY = [M:HAEW]BPR(NOL)
Call LEC_GAC([M:HAEW]ACC(NOL),[L]COAGEN) From CPTLEC

If [F:XDUD]TYPTIE = "C"
 [F:DUD]BPRTYP = 1
Elsif [F:XDUD]TYPTIE = "F"
 [F:DUD]BPRTYP = 2
Else
 If [F:GAC]AUZBPR(0)=2
  [F:DUD]BPRTYP = 1
 Elsif [F:GAC]AUZBPR(1)=2
  [F:DUD]BPRTYP = 2
 Endif
Endif
[F:DUD]DUDDAT = [F:XDUD]DATECH
[F:DUD]SNS    = [F:DAE]SNS

## Initialisation du mode de rĂ¨glement
[F:DUD]PAM    = func SIXFONCTION.SI_COR2("XIMODRGL",left$([F:XDUD]MODRGLPIE,2),"~","TABPAM","XIECH ("+num$([F:XDUD]NUMORDECHDEB)+"/"+num$([F:XDUD]NUMORDECHFIN)-") : MODRGLPIE")
Call LEC_TAM(GCURLEG, [F:DUD]PAM) From CPTLEC
If fstat
 If [F:DUD]BPRTYP=1
  Read [BPC]BPC0=[F:DUD]BPR
  If !fstat
   Call LEC_TPT_LEG(GCURLEG,[F:BPC]PTE,1) From CPTLEC
   If !fstat
    [F:DUD]PAM = [F:TPT]PAM
   Endif
  Endif
 Else
  Read [BPS]BPS0=[F:DUD]BPR
  If !fstat
   Call LEC_TPT_LEG(GCURLEG,[F:BPS]PTE,1) From CPTLEC
   If !fstat
    [F:DUD]PAM = [F:TPT]PAM
   Endif
  Endif
 Endif
Endif

If [L]ORIGINE="H" & find([F:XGAS]ORGECR,"X","Y") : # Acompte achats et ventes
 [F:DUD]PAMTYP = 2 : # Acompte
Else
 [F:DUD]PAMTYP = 1 : # EchĂŠance
Endif
[F:DUD]FLGPAZ = len(mess(0,510,1))
[F:DUD]FLGFUP = [M:HAE1]FLGFUP
## Le niveau de relance de l'ĂŠchĂŠance est initialisĂŠ au max entre le niveau relance IntĂŠgrale
## et niveau max de relance dĂŠfini dans le paramĂ¨tre X3 "FUPMAX" (dĂŠfini au niveau dossier).
[F:DUD]LEVFUP = max(val([F:XDUD]NIVRLC),[L]NBSEUIL)
If [F:DUD]LEVFUP>0
 [F:DUD]DATFUP = [F:DUD]DUDDAT
Endif
[F:DUD]DPTCOD = ""
[F:DUD]SOI    = 1

[F:DUD]AMTLOC = [F:XDUD]MNTECHFRS
If XNBECH=1    : # une seule ĂŠchĂŠance : en principe dans ce cas, [F:XDUD]MNTECHFRS = [M:HAEW]AMTLOC1(NOL)
 [F:DUD]AMTCUR = [M:HAEW]AMTCUR(NOL)
Elsif XNBECH>1 : # multi-ĂŠchĂŠances
 If !OKDEV : # GĂŠnĂŠration de la piĂ¨ce en devise sociĂŠtĂŠ
  [F:DUD]AMTCUR = [F:XDUD]MNTECHFRS
 Elsif OKDEV : # GĂŠnĂŠration de la piĂ¨ce en devise
  If [F:XDUD]CODDVS = [L]DEVPCE
   [F:DUD]AMTCUR  = [F:XDUD]MNTECHDVS
  Elsif [F:XDUD]CODDVS = "" | [F:XDUD]CODDVS<>[L]DEVPCE
   ## La contre-valeur en devise de transaction des ĂŠcritures rattachĂŠes Ă  d'autres devises (sociĂŠtĂŠ
   ## ou autres) sera calculĂŠe en prenant le cours de la 1Ă¨re ĂŠcriture rattachĂŠe Ă  la devise de reprise
   If NBECH < XNBECH
    [F:DUD]AMTCUR  = [F:XDUD]MNTECHFRS*COURDEV
    [L]TOTAMTCUR  += [F:DUD]AMTCUR
   Elsif NBECH = XNBECH
    [F:DUD]AMTCUR = [M:HAEW]AMTCUR(NOL)-[L]TOTAMTCUR
    [F:DUD]AMTLOC = [XDUD]MNTPIEFRS-[F:XDUD]MNTECHFRS  #DdM46939
   Endif
  Endif
 Endif
Endif

#If [F:XDUD]OPEPCD = "RA" or ECH_SUPP #DdM46939
If [F:XDUD]OPECRSDEB <> "S" or ECH_SUPP
 [F:DUD]PAYCUR = [F:DUD]AMTCUR
 [F:DUD]PAYLOC = [F:DUD]AMTLOC
 [F:DUD]TMPCUR = 0
 [F:DUD]TMPLOC = 0
Else
 [F:DUD]PAYCUR = 0
 [F:DUD]PAYLOC = 0
 [F:DUD]TMPCUR = 0
 [F:DUD]TMPLOC = 0
Endif

Call KEYDUD("DUD") From MODECHE
Call SLDECH("DUD")From MODECHE
SI_TABLE = "GACCDUDATE"
Gosub SI_BEFWRI From SIXFONCTION
Write [DUD]
If fstat
 GOK = 0 : Call FSTA("DUD") From GLOCK : Return
Endif
Call HISTOECH("DUD",1,[F:HAE]ACCDAT)From MODECHE
Return

$EN_TETE
# Infos en-tĂŞte
[M:HAE0]CPY    = [L]SOCIETE
[M:HAE0]FCY    = [L]SITE
[M:HAE0]NUM    = ""
## On gĂŠnĂ¨re la piĂ¨ce sur le type de piĂ¨ce qui a comme journal par dĂŠfaut le code du journal courant
## Si pas de type de piĂ¨ce trouvĂŠ, on gĂŠnĂ¨re la piĂ¨ce sur le premier type de piĂ¨ce trouvĂŠ qui est autorisĂŠ sur
## le type de journal courant
## Si tjs pas de journal trouvĂŠ, on gĂŠnĂ¨re la piĂ¨ce sur un type d'opĂŠrations diverses
[M:HAE0]JOU = func SIXFONCTION.SI_COR("XIJRN",[F:XGAS]CODJRN,"GJOURNAL","")
[L]TYPPCE = ""
Call LEC_JOU_LEG([F:CPY]LEG,[M:HAE0]JOU) From CPTLEC
If PASSE = 1
 If find([F:XGAS]NUMPIEDEB,"AA","AF","AC","AV","FA","FF")
  Case [F:XGAS]NUMPIEDEB
   When "AA","AF" : [L]TYPPCE = [F:SPX]GTEAVCACH
   When "AC","AV" : [L]TYPPCE = [F:SPX]GTEAVCVEN
   When "FA"      : [L]TYPPCE = [F:SPX]GTEFACVEN
   When "FF"      : [L]TYPPCE = [F:SPX]GTEFACACH
  Endcase
 Endif
Endif
If [L]TYPPCE = ""
 Read [F:SPJ]SPJ0 = [F:SPX]CLE;[M:HAE0]JOU
 If !fstat
  [L]TYPPCE = [F:SPJ]GTE
 Else
  # Type de piĂ¨ce non dĂŠfini (Journal...)
  Call ECR_TRACE(mess(27,110,1)-"("+mess(13,105,1)-[F:XGAS]CODJRN+")",1) From GESECRAN
  GOK = 0 : Return
 Endif
Endif
[M:HAE0]TYP    = [L]TYPPCE
Case [L]ORIGINE
 When "H"
  If PASSE = 1
   [M:HAE0]ACCDAT = [F:XGAS]DATECR
  Else
   [M:HAE0]ACCDAT = [F:XGAS]X3DAT
  Endif
 When "B"
  [M:HAE0]ACCDAT = [F:XGAS]DATECR
Endcase

Call GETPERSOC([L]SOCIETE,GTYPGEN,[F:XGAS]DATECR,EXERCICE,PERIODE) From CPTSUB
[M:HAE0]FIY    = EXERCICE
[M:HAE0]PER    = PERIODE

[M:HAE1]ENTDAT = [M:HAE0]ACCDAT
[M:HAE1]DUDDAT = [M:HAE0]ACCDAT
[M:HAE1]VALDAT = [F:XGAS]DATVAL
[M:HAE1]RVS    = 1
## Les ĂŠcritures de l'historique gĂŠnĂŠral correspondent Ă  des ĂŠcritures 'rĂŠelles' (les ĂŠcritures
## de simulations dans l'IntĂŠgrale sont dans une table Ă  part et celles-ci ne seront
## pas reprises
[M:HAE1]REFSIM = ""
[M:HAE0]CAT    = 1 : # RĂŠel
If [L]ORIGINE = "H"
 [M:HAE0]STA = 2 : # Historique => dĂŠfinitif
Else
 [M:HAE0]STA = 1 : # Brouillard => Provisoire
Endif
If [L]ORIGINE = "B"
 [M:HAE1]DESVCR = SI_MES(175)-num$([F:XGAS]NUMLOT)-format$(GFMDAT,[F:XGAS]DATSAILOT)
Else
 [M:HAE1]DESVCR = SI_MES(175)
Endif
[M:HAE1]CUR    = func SIXFONCTION.SI_COR("XIDVS",[L]DEVPCE,"TABCUR","")

# Gestion de cours  sous CONTROLE de CPTBATCH
 ## NB : Le cours en en-tĂŞte n'aura pas de grande valeur puisque dans le cas d'une reprise des ĂŠcritures en
 ## devise, on forcera la contre-valeur en devise de sociĂŠtĂŠ

If PASSE = 1
 [M:HAE1]REF    = [F:XGAS]NUMPIEDEB+" "+[F:XGAS]NUMPIEFIN
Else
  # Ecritures IntĂŠgrale
 [M:HAE1]REF    = SI_MES(136)
Endif
[M:HAE1]REFINT = "INTEG"-[F:XGAS]NUMPIEDEB-[F:XGAS]NUMPIEFIN

If dim ([M:HAE1]FLGDAS)>0
 [M:HAE1]FLGDAS = 1
Endif
If dim([F:GTE]FUP)>0
 If [F:GTE]FUP=2
  [M:HAE1]FLGFUP = 2 : # Relance = d'aprĂ¨s le type de piĂ¨ce
 Else
  [M:HAE1]FLGFUP = 1
 Endif
Endif
[M:HAE1]FLGPAZ = 1
## Toutes les piĂ¨ces (mĂŞme le premier AN repris) doivent avoir un FLGREP<>2 de maniĂ¨re Ă  ce que les ĂŠcritures
## rattachĂŠes puissent ĂŞtre lettrĂŠes dans X3
[M:HAE1]FLGREP = 1
If [L]ORIGINE="H" & [F:XGAS]ORGECR = "G"
 Case [F:JOU]TYP
  When 1       : [M:HAE1]ORIMOD = 5
  When 2       : [M:HAE1]ORIMOD = 6
  When Default : [M:HAE1]ORIMOD = 2
 Endcase
Else
 [M:HAE1]ORIMOD = 2
Endif

# V6
[M:HAE0]DACDIA = [L]SCHEMA
## Initialisation masque de rĂŠfĂŠrence [HAEF]
Call INIMSKFMT3([M:HAE0]FCY,1,[L]SCHEMA,[M:HAE0]TYP,[M:HAE0]ACCDAT,STAT) From SUBGASA
For I=1 To [M:HAEF]NBRLED
 Assign "[M:HAE1]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
 Assign "[M:HAE2]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
Next
Return

$SOLDE
NOL = [M:HAE2]NBLIG
[M:HAE2]ACC1(NOL) = [L]CPTATT
[M:HAE2]SAC1(NOL) = ""
[M:HAE2]BPR(NOL) = ""
Call LEC_CPY(SOCIETE) From CPTLEC
[M:HAE2]FCYLIN(NOL) = [F:CPY]MAIFCY
# Solde pour compte attente
[M:HAE2]DES(NOL) = mess(28,170,1)
If [L]TOTDEBLOC > [L]TOTCDTLOC
 ## On passe au crĂŠdit pour ĂŠquilibrer la piĂ¨ce
 If [L]DEVPCE=[L]DEVLOC
  [M:HAE2]CDT(NOL) = [L]TOTDEBLOC-[L]TOTCDTLOC
 Else
  [M:HAE2]CDT(NOL)  = arr(([L]TOTDEBLOC-[L]TOTCDTLOC)*COURDEV, ARRONDI)
 Endif
 [L]TOTCDT += [M:HAE2]CDT(NOL)
  Assign "[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")" With [L]TOTDEBLOC-[L]TOTCDTLOC
  Assign "[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")" With [L]TOTDEBLOC-[L]TOTCDTLOC
  Assign "[M]AMT"+num$(GTYPANA)+"("+num$(NOL)+")" With [L]TOTDEBLOC-[L]TOTCDTLOC
  Assign "[M]AMTFRC"+num$(GTYPANA)+"("+num$(NOL)+")" With [L]TOTDEBLOC-[L]TOTCDTLOC
Else
 ## On passe au dĂŠbit pour ĂŠquilibrer la piĂ¨ce
 If [L]DEVPCE=[L]DEVLOC
  [M:HAE2]DEB(NOL) = [L]TOTCDTLOC-[L]TOTDEBLOC
 Else
  [M:HAE2]DEB(NOL)  = arr(([L]TOTCDTLOC-[L]TOTDEBLOC)*COURDEV, ARRONDI)
 Endif
 [L]TOTDEB += [M:HAE2]DEB(NOL)
 Assign "[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")" With [L]TOTCDTLOC-[L]TOTDEBLOC
 Assign "[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")" With [L]TOTCDTLOC-[L]TOTDEBLOC
 Assign "[M]AMT"+num$(GTYPANA)+"("+num$(NOL)+")" With [L]TOTCDTLOC-[L]TOTDEBLOC
 Assign "[M]AMTFRC"+num$(GTYPANA)+"("+num$(NOL)+")" With [L]TOTCDTLOC-[L]TOTDEBLOC
Endif
Assign "[M]AMTFLG"+num$(GTYPGEN)+"("+num$(NOL)+")" With 1
Assign "[M]AMTFLG"+num$(GTYPANA)+"("+num$(NOL)+")" With 1
[M:HAE2]NBLIG += 1
Return

$SOLDE_CPTATT
[M:HAE2]ACC1(NOL) = [L]CPTATT
[M:HAE2]SAC1(NOL) = ""
[M:HAE2]BPR(NOL) = ""
Call LEC_CPY(SOCIETE) From CPTLEC
[M:HAE2]FCYLIN(NOL) = [F:CPY]MAIFCY
# Solde pour compte attente
[M:HAE2]DES(NOL) = mess(28,170,1)
If [L]TOTDEBLOC > [L]TOTCDTLOC
 ## On a passĂŠ au crĂŠdit pour ĂŠquilibrer la piĂ¨ce => on solde le compte d'attente en le dĂŠbitant
 If [L]DEVPCE=[L]DEVLOC
  [M:HAE2]DEB(NOL) = [L]TOTDEBLOC-[L]TOTCDTLOC
 Else
  [M:HAE2]DEB(NOL)  = arr(([L]TOTDEBLOC-[L]TOTCDTLOC)*COURDEV, ARRONDI)
 Endif
 Assign "[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")" With [L]TOTDEBLOC-[L]TOTCDTLOC
 Assign "[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")" With [L]TOTDEBLOC-[L]TOTCDTLOC
 Assign "[M]AMT"+num$(GTYPANA)+"("+num$(NOL)+")" With [L]TOTDEBLOC-[L]TOTCDTLOC
 Assign "[M]AMTFRC"+num$(GTYPANA)+"("+num$(NOL)+")" With [L]TOTDEBLOC-[L]TOTCDTLOC
Else
 ## On a passĂŠ au dĂŠbit pour ĂŠquilibrer la piĂ¨ce => on solde le compte d'attente en le crĂŠditant
 If [L]DEVPCE=[L]DEVLOC
  [M:HAE2]CDT(NOL) = [L]TOTCDTLOC-[L]TOTDEBLOC
 Else
  [M:HAE2]CDT(NOL)  = arr(([L]TOTCDTLOC-[L]TOTDEBLOC)*COURDEV, ARRONDI)
 Endif
 Assign "[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")" With [L]TOTCDTLOC-[L]TOTDEBLOC
 Assign "[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")" With [L]TOTCDTLOC-[L]TOTDEBLOC
 Assign "[M]AMT"+num$(GTYPANA)+"("+num$(NOL)+")" With [L]TOTCDTLOC-[L]TOTDEBLOC
 Assign "[M]AMTFRC"+num$(GTYPANA)+"("+num$(NOL)+")" With [L]TOTCDTLOC-[L]TOTDEBLOC
Endif

Raz TOTDEB, TOTCDT, TOTDEBLOC, TOTCDTLOC
If [M:HAE2]DEB(NOL)<>0    #18/06:TestCP : Ajout cdt
 [L]TOTDEB    += [M:HAE2]DEB(NOL)
 [L]TOTDEBLOC += evalue("[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")")
Else
 [L]TOTCDT    += [M:HAE2]CDT(NOL)
 [L]TOTCDTLOC += evalue("[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")")
Endif
Assign "[M]AMTFLG"+num$(GTYPGEN)+"("+num$(NOL)+")" With 1
Assign "[M]AMTFLG"+num$(GTYPANA)+"("+num$(NOL)+")" With 1

[M:HAE2]NBLIG += 1
Return

$GENECART     ##15/06:TestCP
If [L]TOTDEB<>[L]TOTCDT
 If abs([L]TOTDEB-[L]TOTCDT)>[L]ECART
  ## Ecart rĂŠel > ĂŠcart autorisĂŠ => reprise piĂ¨ce en devise sociĂŠtĂŠ ou Saupoudrage

  If OPTDIF=1
   # Reprise en devise sociĂŠtĂŠ.
   [L]DEVPCE   = [L]DEVLOC
   [M:HAE1]CUR = func SIXFONCTION.SI_COR("XIDVS",[L]DEVLOC,"TABCUR","")
   For NOLI=0 To [M:HAE2]NBLIG-1
    If [M:HAE2]DEB(NOLI)<>0
     [M:HAE2]DEB(NOLI) = evalue("[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOLI)+")")
    Elsif [M:HAE2]CDT(NOLI)<>0
     [M:HAE2]CDT(NOLI) = evalue("[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOLI)+")")
    Endif
   Next
  Else
   # Saupoudrage
   Raz SOMDEBORG, SOMDEBDES, SOMCDTORG, SOMCDTDES, LIGDIF
   For NOLI=0 To [M:HAE2]NBLIG-1
    If [M:HAE2]DEB(NOLI)<>0
     If [M:HAE2]CHK(NOLI) = "" | [M:HAE2]CHK(NOLI)<>[L]DEVPCE
      [M:HAE2]DEB(NOLI) = arr((evalue("[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOLI)+")")+SOMDEBORG)*COURDEV, ARRONDI)-SOMDEBDES
      [L]LIGDIF = NOLI
     Endif
     [L]SOMDEBORG += evalue("[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOLI)+")")
     [L]SOMDEBDES +=  [M:HAE2]DEB(NOLI)
    Elsif [M:HAE2]CDT(NOLI)<>0
     If [M:HAE2]CHK(NOLI) = "" | [M:HAE2]CHK(NOLI)<>[L]DEVPCE
      [M:HAE2]CDT(NOLI) = arr((evalue("[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOLI)+")")+SOMCDTORG)*COURDEV, ARRONDI)-SOMCDTDES
      [L]LIGDIF = NOLI
     Endif
     [L]SOMCDTORG += evalue("[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOLI)+")")
     [L]SOMCDTDES += [M:HAE2]CDT(NOLI)
    Endif
   Next
   If [L]SOMDEBDES<>[L]SOMCDTDES
    If [M:HAE2]DEB(LIGDIF)<>0
     [M:HAE2]DEB(LIGDIF) += [L]SOMCDTDES-[L]SOMDEBDES
    Elsif [M:HAE2]CDT(LIGDIF)<>0
     [M:HAE2]CDT(LIGDIF) += [L]SOMDEBDES-[L]SOMCDTDES
    Endif
   Endif
  Endif
 Else
  ## GĂŠnĂŠration d'une ligne d'ĂŠcart
  Gosub LIGECART
 Endif
Endif
Return

$LIGECART
NOL = [M:HAE2]NBLIG  #15/06:TestCP

If [L]TOTDEB>[L]TOTCDT
 [M:HAE2]ACC1(NOL) = [L]CPTECARC
Else
 [M:HAE2]ACC1(NOL) = [L]CPTECARD
Endif

Call LEC_GAC([M:HAE2]ACC1(NOL),[L]COAGEN) From CPTLEC

I = find([L]COAANA,[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
If I
 If [F:GAC]DEFACC(I-1)<>""
  [M:HAE2]ACC2(NOL) = [F:GAC]DEFACC(I-1)
 Endif
Endif
# Mono-RĂŠfĂŠrentiel 6.3
# X3 conserve l'intialisation de ACC2 qui permet de dĂŠclencher l'initialisation des sections
If [M:HAE2]ACC2(NOL)="" & [L]COAANA=[L]COAGEN
 [M:HAE2]ACC2(NOL) =  [M:HAE2]ACC1(NOL)
Endif

For K=1 To GLEDDIENBR(ILED)
 If TBSEC(K)=""
  WDIE = evalue("GDIE"+num$(K)+"("+num$(ILED)+")")
  Call LEC_DIE(WDIE) From CPTLEC
  TBSEC(K)=[F:DIE]CCEMIS(0)
  If TBSEC(K)="" : TBSEC(K)="?" : Endif
 Endif
 If TBSEC(K)<>"?"
  Assign "[M]CCE"+num$(K)+"("+num$(NOL)+")" With TBSEC(K)
 Endif
Next K

[M:HAE2]SAC1(NOL) = ""
[M:HAE2]BPR(NOL) = ""
Call LEC_CPY(SOCIETE) From CPTLEC
[M:HAE2]FCYLIN(NOL) = [F:CPY]MAIFCY
 # Ecart d'arrondi
[M:HAE2]DES(NOL) = mess(2,870,1)
If [L]TOTDEB>[L]TOTCDT
 [M:HAE2]CDT(NOL)     = [L]TOTDEB-[L]TOTCDT
  Assign "[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")" With 0
  Assign "[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")" With 0
  Assign "[M]AMT"+num$(GTYPANA)+"("+num$(NOL)+")" With 0
  Assign "[M]AMTFRC"+num$(GTYPANA)+"("+num$(NOL)+")" With 0
Else
 [M:HAE2]DEB(NOL)     = [L]TOTCDT-[L]TOTDEB
  Assign "[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")" With 0
  Assign "[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")" With 0
  Assign "[M]AMT"+num$(GTYPANA)+"("+num$(NOL)+")" With 0
  Assign "[M]AMTFRC"+num$(GTYPANA)+"("+num$(NOL)+")" With 0
Endif
Assign "[M]AMTFLG"+num$(GTYPGEN)+"("+num$(NOL)+")" With 1
[M:HAE2]NBLIG += 1
Return

$INICNACCE
If OPTANA = 2 : # Reprise analytique de l'IntĂŠgrale
 REPART_ANA = 0
 Filter [XAA2] Where CODJRN=[L]JOURNAL & DATECR=[L]DATCPT & NUMECRHIS=[F:XGAS]NUMECR & NUMPIEDEB=[L]TYPPIECE & NUMPIEFIN=[L]NUMPIECE
 Read [XAA2] Last
 Filter [XAA2]
 If !fstat & [F:XAA2]NUMVTL>1
  REPART_ANA = 1
 Endif
 FIRSTVENT = 1

 For [XGAA]CLE(5) Where CODJRN=[L]JOURNAL & DATECR=[F:XGAS]DATECR & NUMPIEDEB=[F:XGAS]NUMPIEDEB & NUMPIEFIN=[F:XGAS]NUMPIEFIN
&                     & NUMECRHIS=[F:XGAS]NUMECR

  If !REPART_ANA
   Gosub INICNA
   If [M:HAE2]ACC2(NOL)<>""
    [M:HAE2]QTY(NOL) = arr([F:XGAA]QTE,AROQTE)
    ## Le sous-programme INICCE va initialiser [M:HAE2]CCE1, [M:HAE2]CCE2,...
    Call INICCE([F:XGAA]SECANA,"[M:HAE2]CCE",NOL)
   Endif
   [F:XGAA]FLGREP = 2
   Rewrite [F:XGAA]
   If fstat
    # Erreur d'ĂŠcriture
    Call ECR_TRACE("XIHISANA"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat)-[L]JOURNAL-format$(GFMDAT,[L]DATCPT)-[L]TYPPIECE-[L]NUMPIECE-num$([F:XGAA]NUMECRHIS),1) From GESECRAN
    GOK = 0 : Break
   Endif
  Else
   Gosub INICNA
   If [M:HAE2]ACC2(NOL)<>""
    ## Parcours de toutes les rĂŠpartitions analytiques
    For [XGAA]CLE
     Gosub VENTILE
     If GOK<1 : Break 2 : Endif
    Next
   Endif
  Endif
 Next
 If GOK<1 : Return : Endif
 # Equilibrage de la ventilation (en rapport avec la demande 46730)
 If [M:HAE2]DEB(NOL)+[M:HAE2]CDT(NOL)<>sum([M:VT2]TBAMT([M:HAE2]PTV(NOL)..[M:HAE2]PTF(NOL)))
  [M:VT2]TBAMT([M:HAE2]PTF(NOL)) = [M:HAE2]DEB(NOL)+[M:HAE2]CDT(NOL)-sum([M:VT2]TBAMT([M:HAE2]PTV(NOL)..[M:HAE2]PTF(NOL)-1))
 Endif
Else : # Initialisation analytique via une section par dĂŠfaut dĂŠfinie dans l'ĂŠcran de paramĂŠtrage
 FIRSTVENT = 0
 Gosub INICNA
 For AXE=1 To GOPTCANA
  [M:HAE0]CPY    = [L]SOCIETE
  [M:HAE0]FCY    = [L]SITE
  [M:HAE0]JOU = func SIXFONCTION.SI_COR("XIJRN",[F:XGAS]CODJRN,"GJOURNAL","")
  Call INISEC(SECTION,[L]CCEDEF,"AX"+num$(AXE)) From SUBCDE
  Assign "[M:HAE2]CCE"+num$(AXE)+"("+num$(NOL)+")" With SECTION
 Next AXE
Endif
If GOK<1 : Return : Endif
Return

$INICNA
If !FIRSTVENT : Return : Endif
Call LEC_GAC([M:HAE2]ACC1(NOL),[L]COAGEN) From CPTLEC
I = find([L]COAANA,[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
If I
 If [F:GAC]DEFACC(I-1)<>""
  [M:HAE2]ACC2(NOL) = [F:GAC]DEFACC(I-1)
 Else
  ## ThĂŠoriquement, pour les comptes suivis en analytique, une nature analytique a ĂŠtĂŠ crĂŠĂŠe
  ## avec la mĂŞme codification que le compte
  Call LEC_GAC([M:HAE2]ACC1(NOL),[L]COAANA) From CPTLEC
  If !fstat
   [M:HAE2]ACC2(NOL) = [F:GAC]ACC
  Else
  # Read [XPCG]IND0 = [M:HAE2]ACC1(NOL)
  # If !fstat
  #  Call LEC_GAC([M:HAE2]ACC1(NOL),[L]COAGEN) From CPTLEC
  #  Call LEC_COA([L]COAANA) From CPTLEC
  #  Call INIACCFMT([F:COA]COA) From SETGLBCOA
  #  [L]COASTD = [L]COAANA : Gosub CRE_GAC_GEN From SIXGAC
  # Endif
  Endif
 Endif
Endif
# Mono-RĂŠfĂŠrentiel 6.3
# X3 conserve l'intialisation de ACC2 qui permet de dĂŠclencher l'initialisation des sections
If [M:HAE2]ACC2(NOL)="" & [L]COAANA=[L]COAGEN
 [M:HAE2]ACC2(NOL) =  [M:HAE2]ACC1(NOL)
Endif
Call LEC_GAC([M:HAE2]ACC2(NOL),[L]COAANA) From CPTLEC
[M:HAE2]SAC2(NOL) = [F:GAC]ACCSHO
If dim([F:GAC]UOM)>0
 [M:HAE2]UOM(NOL) = [F:GAC]UOM
 If [F:GAC]UOM<>""
  Call LEC_TUN([F:GAC]UOM) From CPTLEC
  AROQTE = 10^(-[F:TUN]UOMDEC)
 Endif
Endif
FIRSTVENT = 0
Return

$VENTILE
If [M:VT2]PTVENT+1>=dim([M:VT2]TBAMT)
 # Trop ventilations analytiques
 Call ECR_TRACE([M:HAE0]TYP-[M:HAE0]NUM-num$(nolign)-mess(79,117,1),1) From GESECRAN
 GOK = 0 : Return
Endif
[M:VT2]PTVENT += 1
If [M:HAE2]PTV(NOL)=0
 [M:HAE2]PTV(NOL) = [M:VT2]PTVENT
Endif
[M:HAE2]PTF(NOL) = [M:VT2]PTVENT
[M:HAE2]DSP(NOL) = "$"
Call INICCE([F:XGAA]SECANA,"[M:VT2]TBCCE",[M:VT2]PTVENT)

#Demande46730 : Pour l'IntĂŠgrale, les montants analytiques sont toujours en devise locale
If OKDEV
 If [L]DEVPCE = [L]DEVLOC
  [M:VT2]TBAMT([M:VT2]PTVENT) = [F:XGAA]MNTDBTFRS
 Else
  [M:VT2]TBAMT([M:VT2]PTVENT) = arr([F:XGAA]MNTDBTFRS*COURDEV, ARRONDI)
 Endif
Else
  [M:VT2]TBAMT([M:VT2]PTVENT) = [F:XGAA]MNTDBTFRS
Endif
#

If dim([M:VT2]TBLOC)>0
 [M:VT2]TBLOC([M:VT2]PTVENT) = [F:XGAA]MNTDBTFRS
Endif
[M:VT2]TBQTY([M:VT2]PTVENT) = arr([F:XGAA]QTE,AROQTE)
[M:HAE2]QTY(NOL) = arr(sum([M:VT2]TBQTY([M:HAE2]PTV(NOL)..[M:HAE2]PTF(NOL))),AROQTE)
[F:XGAA]FLGREP = 2
Rewrite [F:XGAA]
If fstat
 # Erreur d'ĂŠcriture
 Call ECR_TRACE("XIHISANA"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat)-[L]JOURNAL-format$(GFMDAT,[L]DATCPT)-[L]TYPPIECE-[L]NUMPIECE-num$([F:XGAA]NUMECRHIS),1) From GESECRAN
 GOK = 0 : Return
Endif
Return


$CAS
## option 2 : on a demandĂŠ la reprise des piĂ¨ces en devise. Plusieurs possibilitĂŠs :
## 1/ La piĂ¨ce ne comporte que des mouvements en devise sociĂŠtĂŠ (=toutes les ĂŠcritures ont le
##    champ CODDVS vide) => On reprend la piĂ¨ce en devise sociĂŠtĂŠ
## 2/ La piĂ¨ce ne comporte que des mouvements autre que la devise sociĂŠtĂŠ (=toutes les ĂŠcritures ont le
##    champs CODDVS non vide et avec la mĂŞme valeur) => On reprend la piĂ¨ce en devise de transaction
##    (Ă  condition que le groupe d'ĂŠcritures est ĂŠquilibrĂŠes en devise (thĂŠoriquement oui, mais on fera le
##    contrĂ´le ($VERF_EQUI_DEV) et ce n'est pas le cas, on reprendra la piĂ¨ce en devise de sociĂŠtĂŠ)
## 3/ La piĂ¨ce comporte des ĂŠcritures en devise sociĂŠtĂŠ et des ĂŠcritures dans UNE autre devise (une seule
##    autre) => On reprend la piĂ¨ce en devise de transaction
## 4/ La piĂ¨ce comporte plusieurs devises autre que la devise de sociĂŠtĂŠ et on a demandĂŠ
##    l'option de reprise en devise sociĂŠtĂŠ dans le cas d'ĂŠcritures multi-devises => On reprend
##    la piĂ¨ce en devise sociĂŠtĂŠ
## 5/ La piĂ¨ce comporte plusieurs devises autre que la devise de sociĂŠtĂŠ et
##    on a demandĂŠ l'option de reprise en sur la 1Ă¨re devise trouvĂŠe dans le cas d'ĂŠcritures
##    multi-devises => On reprend la piĂ¨ce dans la 1Ă¨re devise trouvĂŠe
NBDEV = 0
Raz TDEVISE
For [XGA3] Where CODJRN=[F:XGAS]CODJRN & X3DAT=[F:XGAS]X3DAT & NUMPIEDEB=[F:XGAS]NUMPIEDEB
&              & NUMPIEFIN=[F:XGAS]NUMPIEFIN
 If !find([F:XGA3]CODDVS,TDEVISE(1..NBDEV))
  If [F:XGA3]CODDVS <> ""
   NBDEV+=1
   [L]TDEVISE(NBDEV) = [F:XGA3]CODDVS
#11/06 : TestCP
#  Elsif [F:XGA3]CODDVS <> ""
#   [L]TDEVISE(NBDEV) = [L]CODDVS : # Si vide, =devise sociĂŠtĂŠ
  Else
   If !find([L]DEVLOC,TDEVISE(1..NBDEV))
    NBDEV+=1
    [L]TDEVISE(NBDEV) = [L]DEVLOC : # Si vide, =devise sociĂŠtĂŠ
   Endif
  Endif
 Endif
Next
If NBDEV=1 & TDEVISE(1)=[L]DEVLOC
 CAS = 1
Elsif NBDEV=1 & TDEVISE(1)<>[L]DEVLOC
 CAS = 2
 [L]DEVISE = TDEVISE(1) : Gosub VERF_EQUI_DEV
 If !EQUIDEV : CAS = 1 : Endif
Elsif NBDEV=2 & find([L]DEVLOC,TDEVISE(1..2))
 CAS = 3
Elsif [L]OPTMULTIDEV=1 & (NBDEV=2 & !find([L]DEVLOC,TDEVISE(1..2))) | NBDEV>2
 CAS = 4
Elsif [L]OPTMULTIDEV=2 & (NBDEV=2 & !find([L]DEVLOC,TDEVISE(1..2))) | NBDEV>2
 CAS = 5
Endif
Return

$VERF_EQUI_LOC
TOTDEB = 0 : TOTCDT = 0 : NBECT = 0 : EQUILIBRE = 0
For [XGA3] Where CODJRN=[F:XGAS]CODJRN & X3DAT=[F:XGAS]X3DAT & NUMPIEDEB=[F:XGAS]NUMPIEDEB & NUMPIEFIN=[F:XGAS]NUMPIEFIN
 If [F:XGA3]SENECR = "C"
  TOTCDT += [F:XGA3]MNTDBTFRS
 Elsif [F:XGA3]SENECR = "D"
  TOTDEB += [F:XGA3]MNTDBTFRS
 Endif
 NBECT += 1
Next
If TOTCDT = TOTDEB
 [L]DEVPCE = [L]DEVLOC
 EQUILIBRE = 1
Endif
Return


$VERF_EQUI_DEV
TOTDEB = 0 : TOTCDT = 0 : EQUIDEV = 0
## Les ĂŠcritures en devise sont-elles ĂŠquilibrĂŠes ???
For [XGA3] Where CODJRN=[F:XGAS]CODJRN & X3DAT=[F:XGAS]X3DAT & NUMPIEDEB=[F:XGAS]NUMPIEDEB
&              & NUMPIEFIN=[F:XGAS]NUMPIEFIN & CODDVS=[L]DEVISE
 If [F:XGA3]SENECR = "C"
  TOTCDT    += [F:XGA2]MNTDBTDVS
 Elsif [F:XGA3]SENECR = "D"
  TOTDEB += [F:XGA3]MNTDBTDVS
 Endif
Next
If TOTCDT = TOTDEB
 EQUIDEV = 1
Else
 EQUIDEV = 0
Endif
Return

$SENS_ECR
If [M:HAE2]DEB(NOL)<>0                             : SNSECR=1
Elsif [M:HAE2]CDT(NOL)<>0                          : SNSECR=-1
Elsif evalue("[M]AMTFRC"+num$(GTYPGEN)+"(NOL)")>0  : SNSECR=1
Elsif evalue("[M]AMTFRC"+num$(GTYPGEN)+"(NOL)")<0  : SNSECR=-1
Else                                               : SNSECR=1
Endif
Return

$OUV_PER
## NB : Les exercices sont crĂŠĂŠs dans X3 avec le statut 'ouvert' de maniĂ¨re Ă  pouvoir relancer la clĂ´ture
## dans X3. Par contre, les pĂŠriodes de chaque exercice correspondant Ă  des pĂŠriodes/exercices clĂ´turĂŠs
## dans l'IntĂŠgrale sont crĂŠĂŠes dans X3 avec le statut 'fermĂŠ' (pour ne pas pouvoir saisir de nvelles
## piĂ¨ces sur cette pĂŠriode)
## Ici, on va ouvrir temporairement la pĂŠriode sur laquelle on va reprendre les piĂ¨ces de maniĂ¨re Ă  ne pas
## bloquer avec 'PĂŠriode fermĂŠe'... On refermera la pĂŠriode juste avant Ă  la fin de la transaction...
OKCLOPER = 0
Call GETPERSOC([L]SOCIETE,GTYPGEN,[F:XGA2]X3DAT,EXE2,PERIO2) From CPTSUB
Read [PER]PER0 = [L]SOCIETE;EXE2;PERIO2
If !fstat & [F:PER]PERSTA=3
 OKCLOPER = 1
 [F:PER]PERSTA    = 2
 [F:PER]PERANASTA = 2
 Rewrite [PER]
 If fstat
  If [L]ORIGINE = "H"
   # Erreur d'ĂŠcriture
   Call ECR_TRACE("PERIOD"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat)-[F:XGA2]CODJRN-format$(GFMDAT,[F:XGA2]X3DAT),1) From GESECRAN
   GOK = 0 : Return
  Else
   # Erreur d'ĂŠcriture
   Call ECR_TRACE("PERIOD"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat)-num$([F:XGA2]NUMLOT)-format$(GFMDAT,[F:XGA2]DATSAILOT),1) From GESECRAN
   GOK = 0 : Return
  Endif
 Endif
Endif
Return



$CLO_PER
## On referme la pĂŠriode si elle a ĂŠtĂŠ ouverte temporairement pour la reprise des ĂŠcritures IntĂŠgrale
If OKCLOPER
 Read [PER]PER0 = [L]SOCIETE;EXE2;PERIO2
 If !fstat
  [F:PER]PERSTA    = 3
  [F:PER]PERANASTA = 3
  Rewrite [PER]
  If fstat
   If [L]ORIGINE = "H"
   # Erreur d'ĂŠcriture
   Call ECR_TRACE("PERIOD"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat)-[F:XGA2]CODJRN-format$(GFMDAT,[F:XGA2]X3DAT),1) From GESECRAN
   GOK = 0 : Return
  Else
   # Erreur d'ĂŠcriture
   Call ECR_TRACE("PERIOD"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat)-num$([F:XGA2]NUMLOT)-format$(GFMDAT,[F:XGA2]DATSAILOT),1) From GESECRAN
   GOK = 0 : Return
  Endif
  Endif
 Endif
Endif
Return



#########################################################################################
## Reprise des imputations analytiques de l'IntĂŠgrale
#########################################################################################
Subprog INICCE(SECANA,ZONE,IND)
Value Char    SECANA() : # Code section analytique dans l'IntĂŠgrale
Value Char    ZONE()   : # PrĂŠfixe des zones sections ana Ă  alimenter dans X3 (Ex:CCE si CCE1,...CCEn)
Value Integer IND      : # Indice de ligne (nolign-1)

If !clalev([F:XPAN]) : Local File =SI_DOSSIER+".XIPLACBANA" [XPAN] : Endif  # Sections analytiques
If !clalev([F:XCAN]) : Local File =SI_DOSSIER+".XICNTANA"   [XCAN] : Endif  # Centres analytiques
If !clalev([F:XSO2]) : Local File =SI_DOSSIER+".XISOCDIV2"  [XSO2] : Endif   # ParamĂ¨tres sociĂŠtĂŠ

Local Char    TABAXI(10)(1..13) : # Tableau des nÂ°axes analytiques dĂŠfinis dans l'IntĂŠgrale
Local Char    CENTRE_ANA(13)    : # Centres analytiques
Local Char    TCENTRE_ANA(13)(1..max(1,GNBAXE))
Local Integer NUMAXE, I, NBAXE
Local Integer OK_CONCAT         : # Indicateur 1:la section correspond Ă  la concatĂŠnation de centres ana
Local Integer TLNGAXI(1..13)    : # Tableau des longueurs des axes analytiques dĂŠfinis dans l'IntĂŠgrale
Local Integer TOTLNG            : # Longueur cumulĂŠe des axes analytiques

## On regarde si la section analytique de l'IntĂŠgrale correspond Ă  la concatĂŠnation de centres
## analytiques

Raz TABAXI : I = 0
For [XCAN]IND0(1)
 I += 1
 TABAXI(I) = [F:XCAN]NUMAXE
Next

## A voir pour dĂŠplacer de maniĂ¨re Ă  ne pas faire la lecture Ă  chaque fois... (plus tard)
Read [XSO2]IND0 First
If !fstat
 For I=1 To 13 : # Maximum 13 axes...
  If evalue("[F:XSO2]LGRAXE"+num$(I))<>0
   NBAXE += 1
   TLNGAXI(NBAXE) = evalue("[F:XSO2]LGRAXE"+num$(I))
  Endif
 Next
Endif

For NUMAXE=1 To GNBAXE
 If NUMAXE = 1
  #CENTRE_ANA = mid$(SECANA,1,TLNGAXI(NUMAXE)) #DdM49156
  CENTRE_ANA = vireblc(mid$(SECANA,1,TLNGAXI(NUMAXE)),1)
  TOTLNG += TLNGAXI(NUMAXE)
 Else
  #CENTRE_ANA = mid$(SECANA,TOTLNG+1,TLNGAXI(NUMAXE)) #DdM49156
  CENTRE_ANA = vireblc(mid$(SECANA,TOTLNG+1,TLNGAXI(NUMAXE)),1)
  TOTLNG += TLNGAXI(NUMAXE)
 Endif
 Read [XCAN]IND0 = TABAXI(NUMAXE) ; CENTRE_ANA
 If !fstat
  TCENTRE_ANA(NUMAXE) = [F:XCAN]X3CLE
  OK_CONCAT = 1
 Else
  OK_CONCAT = 0 : Break
 Endif
Next


If OK_CONCAT
 ## S'il y a plus de 8 axes ana dans l'IntĂŠgrale (logiquement, pas rĂŠaliste...), on ignore les axes
 ## suivants (9iĂ¨me, 10iĂ¨me....).
 For NUMAXE=1 To min(GNBAXE,8)
  Assign ZONE+num$(NUMAXE)+"("+num$(IND)+")" With TCENTRE_ANA(NUMAXE)
 Next
Else
 ## La section analytique de l'IntĂŠgrale ne correspond pas Ă  la concatĂŠnation de centres analytiques
 ## => On met cette section dans l'axe Ă  part rajoutĂŠ Ă  cet effet (le dernier axe)
 Assign ZONE+num$(min(GNBAXE+1,9))+"("+num$(IND)+")" With SECANA
Endif
End

#########################################################################################
## DĂŠclare / initialise les globales GNBAXE (Nb d'axes gĂŠrĂŠs dans l'IntĂŠgrale) et
## GLNGAXI (longueur de chaque axe). Ces globales seront exploitĂŠes dans le programme
## de reprise des imputations analytiques de l'IntĂŠgrale
#########################################################################################
Subprog VARGLOBANA(MESSA,STAT)
Variable Char    MESSA()
Variable Integer STAT

If !clalev([F:XSO2]) : Local File =SI_DOSSIER+".XISOCDIV2"  [XSO2] : Endif   # ParamĂ¨tres sociĂŠtĂŠ

Local Integer I              : # Variables diverses
Local Integer GLNGAXI(1..13) : # Tableau des longueurs des axes analytiques dĂŠfinis dans l'IntĂŠgrale

Global Integer GNBAXE         : # Nb d'axes analytiques dĂŠfinis dans l'IntĂŠgrale

Read [XSO2]IND0 First
If !fstat
 For I=1 To 13 : # Maximum 13 axes...
  If evalue("[F:XSO2]LGRAXE"+num$(I))<>0
   GNBAXE += 1
   GLNGAXI(GNBAXE) = evalue("[F:XSO2]LGRAXE"+num$(I))
  Endif
 Next
Endif
If GNBAXE<9 & GNBAXE>GOPTCANA
 # Erreur dimensionnement code activitĂŠ ANA
 STAT = 99 : MESSA = SI_MES(134)-"ANA"
 End
Endif
End




#########################################################################################
## Recherche du code lettrage dans le cas d'un exercice fermĂŠ.
#########################################################################################
$RECHERCHE_CODE

#-- Initialisation du code lettrage
[L]CODLTR= [F:XGAS]CODLTR

#-- Initialisation du REFINTLIN qui va servir pour stocker l'"adresse" des ĂŠchĂŠances et pour l'exploiter au
#--  moment oĂš on rĂŠcupĂ¨rera le (ou les) ĂŠchĂŠance(s)
Raz [M:HAE2]REFINTLIN(NOL)
If [M:HAE2]SAC1(NOL)<>""
 Raz COMP0
 For I=1 To 7-len(num$([F:XGAS]NUMECR))
  COMP0 += "0"
 Next
 [M:HAE2]REFINTLIN(NOL) = [F:XGAS]DATECR+COMP0+num$([F:XGAS]NUMECR)+"0"
Endif

# Lien sur l'Ă -nouveau si la piĂ¨ce comptable est mouvementĂŠ sur l'exercice fermĂŠ
If ![L]FLGLTR & [F:XGAS]DATECR<[L]DATLTR : Return : Endif


Filter [F:XGA4] Where CLF=[F:XGAS]CLF & CPT=[F:XGAS]CPT
&                    & MNTDBTFRS=[F:XGAS]MNTDBTFRS & CODDVS=[F:XGAS]CODDVS & SENECR=[F:XGAS]SENECR
&                    & NUMPIEDEB=[F:XGAS]NUMPIEDEB & NUMPIEFIN=[F:XGAS]NUMPIEFIN
&                    & find(ORGECR,"A","H","Q") & DATECR=[L]DATLTR
&                    & left$(LIBECR,8)=format$(GFMDAT,[F:XGAS]DATECR)
Read [XGA4] First
If !fstat
 [L]CODLTR=[F:XGA4]CODLTR
Else
 Raz [F:XGA4]
Endif

#-- Les ĂŠchĂŠances peuvent soit ĂŞtre conservĂŠes sur l'exercice fermĂŠ soit reportĂŠes sur l'Ă -nouveau

Filter [XDUD] Where FICORG=[L]ORIGINE & ADRORG=[M:HAE2]REFINTLIN(NOL)
Read [XDUD]IND1 First
Filter [XDUD]
If !fstat
 # on garde l'initialisation standard
Else
 # Si l'ĂŠchĂŠance n'est pas trouvĂŠ, X3 rebondit sur l'Ă -nouveau
 Raz COMP0
 For I=1 To 7-len(num$([F:XGA4]NUMECR))
  COMP0 += "0"
 Next
 WREFINT  = [F:XGA4]DATECR+COMP0+num$([F:XGA4]NUMECR)+"0"
 Filter [XDUD] Where FICORG=[L]ORIGINE & ADRORG=WREFINT
 Read [XDUD]IND1 First
 Filter [XDUD]
 If !fstat
  [M:HAE2]REFINTLIN(NOL) = WREFINT
 Endif
Endif
Return


$OUVFIC
## Tables IntĂŠgrale
If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"        [XSOC]  : Endif  # SociĂŠtĂŠ IntĂŠgrale
If !clalev([F:XSO1]) : Local File =SI_DOSSIER+".XISOCDIV1"    [XSO1]  : Endif  # ParamĂ¨tres SociĂŠtĂŠ IntĂŠgrale
If !clalev([F:XDUD]) : Local File =SI_DOSSIER+".XIECH"        [XDUD]  : Endif  # EchĂŠances
If !clalev([F:XGAC]) : Local File =SI_DOSSIER+".XIPLACBGNR"   [XGAC]  : Endif  # Comptes gĂŠnĂŠraux
If !clalev([F:XPCG]) : Local File =SI_DOSSIER+".XIPLACBGNR"   [XPCG]  : Endif  # Comptes gĂŠnĂŠraux
If !clalev([F:XBPC]) : Local File =SI_DOSSIER+".XICLT"        [XBPC]  : Endif  # Clients
If !clalev([F:XBPS]) : Local File =SI_DOSSIER+".XIFOU"        [XBPS]  : Endif  # Fournisseurs
If !clalev([F:XPCG]) : Local File =SI_DOSSIER+".XIPLACBANA"   [XPAN]  : Endif  # Sections analytiques
If !clalev([F:XJRN]) : Local File =SI_DOSSIER+".XIJRN"        [XJRN]  : Endif  # Journaux comptables

## Tables X3
