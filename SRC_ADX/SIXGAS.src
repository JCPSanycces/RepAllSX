Local Char    NUMPIECE(8)         : # NumĂŠro de piĂ¨ce dans l'IntĂŠgrale
Local Char    MESSA(250)          : # Message
Local Char    ORIGINE(1)          : # Origine de l'ĂŠcriture (H:Historique   B:Brouillard)
Local Char    TIERS(GLONBPR)      : # Code tiers
Local Char    CODTAX(3)           : # Code taxe
Local Char    VAC(GLONTVB)        : # RĂŠgime de taxe
Local Char    TYPTIERS(1)         : # Type de tiers
Local Char    DEVISE(GLONCUR)     : # Code devise
Local Char    COMP0(10), COMP1(10): # ComplĂŠment "0" (technique)
