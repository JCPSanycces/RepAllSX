Local Date    LASTDCLVAT          : # Date derniĂ¨re dĂŠclaration TVA
Local Integer OKDEV               : # Si 1:on gĂŠnĂŠre la piĂ¨ce en devise 0:gĂŠnĂŠration en devise locale
Local Integer NBDEV               : # Nombre devises mouvementĂŠs pour une piĂ¨ce IntĂŠgrale
Local Integer MULTIDEV            : # Si 1:PiĂ¨ce intĂŠgrale muti-devise ; O:mono-devise
Local Integer EQUILIBRE           : # Si 1:le groupe d'ĂŠcritures est ĂŠquilibrĂŠ en devise locale
Local Integer EQUIDEV             : # 1:Equilibre contrĂ´lĂŠ en devise XXX
Local Integer MAXECT              : # Nombre maximum de lignes d'ĂŠcritures d'une piĂ¨ce X3
Local Integer SPSTAT, STAT        : # Statut erreur
Local Integer AXE                 : # NumĂŠro d'axe analytique
Local Integer REPART_ANA          : # Si 1:l'ĂŠcriture contient une rĂŠpartition ana (imputations de X sections sur le mĂŞme axe)
Local Integer LASTNUMECR          : # Dernier nÂ°ĂŠcriture traitĂŠ dans un groupe d'ĂŠcritures ayant mĂŞme journal/date ĂŠcriture
Local Integer NBECH, XNBECH       : # Nombre d'ĂŠchĂŠaces associĂŠes Ă  une ligne auxiliarisĂŠe
Local Integer NBECT               : # Nombre d'ĂŠcritures
Local Integer OKCLOPER            : # Si 1 =la pĂŠriode a ĂŠtĂŠ ouverte le temps de la reprise, il faut la refermer
Local Integer LOT                 : # NumĂŠro de lot
Local Integer FIRSTVENT
Local Integer CAS
Local Integer NOL, NOLI
Local Integer PASSE
Local Integer SNSECR              : # Signe ĂŠcriture (1:DĂŠbit : -1:CrĂŠdit)
Local Integer SIGN
Local Decimal COURS, COURDEV
Local Decimal ARRONDI
Local Decimal EXERCICE, PERIODE : # Exercice, periode
Local Decimal EXE2, PERIO2      : # Exercice, periode
