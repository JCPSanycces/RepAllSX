#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OCLF

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:13:18"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OCLF",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="CLF1;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 1
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE1"
OBJLIS(1) = "CLD"
CHGLIS(1) = 2
BROLIS(1) = 2
TRELIS(1) = 1
DESLIS(1) = "TYPCLD+PERIOD"
If clalev([M:CLF1])=0 : Local Mask CLF1 [CLF1] : Endif
Gosub TIT
nolign = 1
Return

$DEF_BOITE
Gosub HORODAT From WGOCLF
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OCLF" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLF1]
&  Listbox [CLD] GAU_CHE1
&   [L]SAIRAP(1) = mess([F:CLD]TYPCLD(0),10424,1) Using "" Titled TITSEL1(1) ,
&   [L]SAIRAP(2) = [F:CLD]PERIOD Using "K:20X" Titled TITSEL1(2)
&  Listbox [CLD9] GAU_CHE9
&   [L]SAIRAP(1) = mess([F:CLD9]A_TAB1,10424,1) Using "" Titled TITSEL9(1) ,
&   [L]SAIRAP(2) = [F:CLD9]A_TAB2 Using "K:20X" Titled TITSEL9(2) 
& As [CLF1]
Titled [CLF1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOCLF
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OCLF" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLF1]
& As [CLF1]
Titled [CLF1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [CLF1] 
Return

$SAISIE_BOITE
Boxinp [CLF1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [CLF1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS1(30)
Call TEXTE(1802,TITLIS1) From OBJDIV
Local Char TITLIS9(30)
TITLIS9 = mess(196,123,1)
Local Char TITSEL1(30)(1..2)
Call TEXTE(25891,TITSEL1(1)) From OBJDIV
Call TEXTE(1355,TITSEL1(2)) From OBJDIV
Local Char TITSEL9(30)(1..2)
Call TEXTE(25891,TITSEL9(1)) From OBJDIV
Call TEXTE(1355,TITSEL9(2)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(1000535,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$REMPLIT_1
Gosub SETCLE_1
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""   : CRITERE   = "1=1" : Endif
 If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif
 If FILSUITE=""  : FILSUITE  = "1=1" : Endif
 Filter [CLD] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(1)<>'' or NOHLIS(1)<>0
 Fillbox [CLF1] GAU_CHE1 Hint Key =HINTLIS(1)
Else
 Gosub CALNOH From GOBJET
 If A_NOH
  Fillbox [CLF1] GAU_CHE1
 Else
  Fillbox [CLF1] GAU_CHE1 Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [CLD]
Return

$SETCLE_1
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 2
GAUTRELIS = 1
CLELISTE = "TYPCLD;PERIOD"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 1 : Default file [CLD]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [CLD] Order With CLELISTE
  Setlbox [CLF1] GAU_CHE1
  Filter [CLD]
 When "GAU_CHE9"
  Gosub CLE_DERLU From =PROGOBJ
  Setlbox [CLF1] GAU_CHE9
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [CLD] Order With CLELISTE
Endcase
Return

$ENDORDER
Case currbox
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [CLD]
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(1) = "CLF1"         : ABMSK(1)  = "CLF1"     : AMA(1) = 1
NBMASK = 1
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 1 : If clalev([M:CLF1])>0 : Default Mask [CLF1] : Endif
Endcase
Return

$TITMASK
Case MA
 When 1 : If clalev([M:CLF1])>0 : Gosub TITRES From W1CLF1 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:CLF1])>0 : Close Local Mask [CLF1] : Endif
Return

$RAZMASK
Case MA
 When 1 : If clalev([M:CLF1])>0 : Raz [M:CLF1] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 1 : If clalev([M:CLF1])>0 : Affzo [M:CLF1] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 1 : If clalev([M:CLF1])>0 : [F:CLD] = [M:CLF1] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 1 : If clalev([M:CLF1])>0 : [M:CLF1] = [F:CLD] : Endif
Endcase
Return

$GRISE_CLE
Grizo [CLF1]PERIOD,TYPCLD
Return

$DEGRISE_CLE
Actzo [CLF1]PERIOD,TYPCLD
Return

$BOUTON
STDBOUT = "EA09<>RILJMP"
NBTEX  = 0
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


