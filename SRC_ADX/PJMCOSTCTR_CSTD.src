#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMCOSTCTR
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER                        From PJMCOSTCTR_CSTD_EVENTS  # Issue X3-4848/119127 - 2016-10-14 by FGR
        When "ACONTROL"                : Gosub ACONTROL                           From PJMCOSTCTR_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE             From PJMCOSTCTR_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE             From PJMCOSTCTR_CSTD_EVENTS
        When "AINSERT_BEFORE"          : Gosub AINSERT_BEFORE                     From PJMCOSTCTR_CSTD_EVENTS  # Issue X3-4848/119127 - 2016-10-14 by FGR
        When "AUPDATE_BEFORE"          : Gosub AUPDATE_BEFORE                     From PJMCOSTCTR_CSTD_EVENTS  # Issue X3-4848/119127 - 2016-10-14 by FGR
        #When "AUPDATE_AFTER"          : Gosub AUPDATE_AFTER                      From PJMCOSTCTR_CSTD_EVENTS  # Issue X3-4848/119127 - 2016-10-14 by FGR
        When "ADELETE_AFTER"           : Gosub ADELETE_AFTER                      From PJMCOSTCTR_CSTD_EVENTS
      Endcase
    When "DATRATE"
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub DATRATE_AREAD_AFTER                 From PJMCOSTCTR_CSTD_EVENTS
        When "ACONTROL"                : Gosub DATRATE_ACONTROL                    From PJMCOSTCTR_CSTD_EVENTS
        When "ADDLINE_BEFORE"          : Gosub DATRATE_ADDLINE_BEFORE              From PJMCOSTCTR_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub DATRATE_ADDLINE_AFTER               From PJMCOSTCTR_CSTD_EVENTS
      Endcase
    When "CDIE"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub CDIE_ACONTROL                       From PJMCOSTCTR_CSTD_EVENTS  # Issue X3-4848/119127 - 2016-10-14 by FGR
        When "AINSERT_BEFORE"          : Gosub CDIE_AINSERT_BEFORE                 From PJMCOSTCTR_CSTD_EVENTS  # Issue X3-4848/119127 - 2016-10-14 by FGR
        When "AUPDATE_BEFORE"          : Gosub CDIE_AUPDATE_BEFORE                 From PJMCOSTCTR_CSTD_EVENTS  # Issue X3-4848/119127 - 2016-10-14 by FGR
      Endcase
    When "COSTGRP"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub COSTGRP_ACONTROL                    From PJMCOSTCTR_CSTD_EVENTS  # Issue X3-26712 - 2017-04-26 by ALMON
      Endcase
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "DATRATE_COUNT"               : Gosub DATRATE_COUNT                       From PJMCOSTCTR_CSTD_METHODS
    When "DATRATE_CONVERT"             : Gosub DATRATE_CONVERT                     From PJMCOSTCTR_CSTD_METHODS
    #
    When "CDIE_INIT"                   : Gosub CDIE_INIT                           From PJMCOSTCTR_CSTD_METHODS   # Issue X3-4848/119127 - 2016-10-14 by FGR
    When "CDIE_COUNT"                  : Gosub CDIE_COUNT                          From PJMCOSTCTR_CSTD_METHODS   # Issue X3-4848/119127 - 2016-10-14 by FGR
    When "CDIE_ERASE_COLLECTION"       : Gosub CDIE_ERASE_COLLECTION               From PJMCOSTCTR_CSTD_METHODS   # Issue X3-4848/119127 - 2016-10-14 by FGR
    When "CDIE_INSERT"                 : Gosub CDIE_INSERT                         From PJMCOSTCTR_CSTD_METHODS
    When "CDIE_INSERT_INDEX"           : Gosub CDIE_INSERT_INDEX                   From PJMCOSTCTR_CSTD_METHODS   # Issue X3-4848/119127 - 2016-10-14 by FGR
    When "CDIE_UPDATE"                 : Gosub CDIE_UPDATE                         From PJMCOSTCTR_CSTD_METHODS
    When "CDIE_DELETE"                 : Gosub CDIE_DELETE                         From PJMCOSTCTR_CSTD_METHODS
    #
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "TCHREPDIECCE"                : Gosub TCHREPDIECCE                        From PJMCOSTCTR_CSTD_PROPERTIES   # Issue X3-4848/119127 - 2016-10-14 by FGR
    When "TCHNODIEEXE"                 : Gosub TCHNODIEEXE                         From PJMCOSTCTR_CSTD_PROPERTIES   # Issue X3-4848/119127 - 2016-10-14 by FGR
    When "ENAFLG"                      : Gosub ENAFLG                              From PJMCOSTCTR_CSTD_PROPERTIES
    When "PCCFCY"                      : Gosub PCCFCY                              From PJMCOSTCTR_CSTD_PROPERTIES
    When "PCCWKA"                      : Gosub PCCWKA                              From PJMCOSTCTR_CSTD_PROPERTIES
    When "PCCPOHA"                     : Gosub PCCPOHA                             From PJMCOSTCTR_CSTD_PROPERTIES
    When "PCCSTOA"                     : Gosub PCCSTOA                             From PJMCOSTCTR_CSTD_PROPERTIES
    When "PCCHATA"                     : Gosub PCCHATA                             From PJMCOSTCTR_CSTD_PROPERTIES
    When "PCCCUR"                      : Gosub PCCCUR                              From PJMCOSTCTR_CSTD_PROPERTIES
    When "PCCPROV"                     : Gosub PCCPROV                             From PJMCOSTCTR_CSTD_PROPERTIES
    When "PCCPRCT"                     : Gosub PCCPRCT                             From PJMCOSTCTR_CSTD_PROPERTIES
    When "PCCCOD2"                     : Gosub PCCCOD2                             From PJMCOSTCTR_CSTD_PROPERTIES
    When "ITMREF"                      : Gosub ITMREF                              From PJMCOSTCTR_CSTD_PROPERTIES   # Issue X3-3414/119352 - 2016-10-24 by SINGC
    When "ACCCOD"                      : Gosub ACCCOD                              From PJMCOSTCTR_CSTD_PROPERTIES   # Issue X3-66481 - 2018-05-28 by SINGC
    #
    When "CDIE.CCE"                    : Gosub CDIE_CCE                            From PJMCOSTCTR_CSTD_PROPERTIES
    When "CDIE.CHX"                    : Gosub CDIE_CHX                            From PJMCOSTCTR_CSTD_PROPERTIES   # Issue X3-4848/119127 - 2016-10-14 by FGR
    #
    When "COSTGRP.PCGTYP"              : Gosub COSTGRP_PCGTYP                      From PJMCOSTCTR_CSTD_PROPERTIES   # Issue X3-26712 - 2017-05-19 by ALMON/FGR
  Endcase
Return

