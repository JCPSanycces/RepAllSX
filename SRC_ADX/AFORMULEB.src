#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char FORMULE(250)
Call B1_FORMULE(FORMULE,"ZZMB","","","","")
End

#------------------------------------------------------------------------#
Subprog B1_FORMULE(FORMULE,TABLE1,TABLE2,TABLE3,TABLE4,TABLE5)
Variable Char    FORMULE()
Value    Char    TABLE1
Value    Char    TABLE2
Value    Char    TABLE3
Value    Char    TABLE4
Value    Char    TABLE5

If clalev([F:ATB])=0 : Local File ATABLE   [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON  [ATZ] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
If clalev([F:AMK])=0 : Local File AMSK     [AMK] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON  [AMZ] : Endif

Local Char    TT(30) , PTT(30) , UTT(30) , TABLE(30)(1..100)
Local Char    TEXTE(80) , DESIG(80) , CHAMP(80) , SAVFOR(250)
Local Integer E , I , NBTABLE , REPONSE , NBCHAMP , NBTEX , SAVSEL
Local Char    OPE(15)(1..50) , TEX(50)(1..50)
Local Char    PARAM(250)(1..3)

NBTABLE=0
For TT = TABLE1,TABLE2,TABLE3,TABLE4,TABLE5
 If TT<>""
  If left$(TT,1)="="
   PTT = right$(TT,2)
   Gosub PLUS_TAB
  Else
   UTT = TT
   Gosub UNE_TAB
  Endif
 Endif
Next TT
SAVFOR = FORMULE
FORMULE = vireblc(format$("KT:250X",FORMULE),2)
Gosub SAI_FORMULE
End

#-------------------------------------------------------#
$PLUS_TAB
J = evalue("dim("+PTT+")")
For I=0 To J-1
 UTT = evalue(PTT+"("+num$(I)+")")
 Gosub UNE_TAB
Next I
Return

#--------------------#
$UNE_TAB
If left$(UTT,3)="[M]"
 Read [AMK]CODMSK = right$(UTT,4)
 If !fstat
  NBTABLE += 1
  TABLE(NBTABLE) = UTT
 Endif
Elsif left$(UTT,3)="[V]"
 If evalue("dim("+right$(UTT,4)+")")
  NBTABLE += 1
  TABLE(NBTABLE) = UTT
 Endif
Elsif left$(TT,3)="[P]"
 If find(right$(TT,4),"RUB","VAR","CUM","MSR")
  NBTABLE +=1
  TABLE(NBTABLE) = TT
 Endif
Else
 Read [ATB]CODFIC = UTT
 If !fstat
  NBTABLE += 1
  TABLE(NBTABLE) = [F:ATB]CODFIC
 Endif
Endif
Return

#-------------------------------------------------------#
$SAI_FORMULE
Formula FORMULE As [AAA_]

# Nouvelle table/Aide de la table
Field [AAA_]  5 , "" , "ZZ1" , mess(131,126,1) , mess(161,133,1) , "ZZ1"
# Nouvel écran/Aide de l'écran
Field [AAA_]  5 , "" , "ZZ2" , mess(132,126,1) , mess(163,133,1) , "ZZ2"

NBCHAMP = 0
NBTEX = 0
For I=1 To NBTABLE
 TT = TABLE(I)
 If left$(TT,3)="[M]"
  TT = right$(TT,4) : Gosub MASQUE
 Elsif left$(TT,3)="[V]"
  TT = right$(TT,4) : Gosub VARIA
 Elsif left$(TT,3)="[P]"
  TT = right$(TT,4) : Gosub PAYE
 Else
  Gosub TABLE
 Endif
Next I

Gosub DEFVARSYS
# Variables globales/Aide de la table/Variable
Field [AAA_]  1 , "" , "VARIABLE" , mess(86,123,1) , mess(161,133,1) , mess(11,188,1)
For I=1 To NBTEX
 # Aide du champ
 Field [AAA_]  2 , "VARIABLE" , "VARIABLE."+OPE(I) , TEX(I) , mess(162,133,1) , OPE(I)
Next I

# Michel Giet (Variables locales)
If dim(WVAS) > 0
  Gosub DEFVARLOC
  # Variables locales/Aide de la table/Variable
  Field [AAA_]  1 , "" , "VARLOC" , mess(212,100,1) , mess(161,133,1) , mess(11,188,1)
  For I=1 To NBTEX
   # Aide du champ
   Field [AAA_]  2 , "VARLOC" , "VARLOC."+OPE(I) , TEX(I) , mess(162,133,1) , OPE(I)
 Next I
Endif

If dim([V]GFRMNB)>0 & GFRMNB>0
 # Variables locales/Aide de la table/Variable
 Field [AAA_]  1 , "" , "VARSUP" , mess(212,100,1) , mess(161,133,1) , mess(11,188,1)
 For I=1 To GFRMNB
  # Aide du champ
  Field [AAA_]  2 , "VARSUP" , "VARSUP."+GFRMVAR(I) , GFRMVAR(I)-GFRMLIB(I) , mess(162,133,1) , GFRMVAR(I)
 Next I
Endif

Boxact [AAA_]

#----------------------------#
$SAI
Boxinp [AAA_] Using REPONSE, FORMULE
Case REPONSE
 When 7       : FORMULE = SAVFOR : Goto FIN
 When 46      : Gosub VERIF : If E=0 : Infbox mess(157,100,1) : Endif : # OK
 When 1       : Gosub VERIF: If E=0 : Goto FIN : Else : Goto SAI_FORMULE : Endif
 When 47      : Gosub ADD_OBJET
 When Default : Infbox "REPONSE"-num$(REPONSE)
Endcase
Goto SAI

#----------------------------#
$FIN
Close Inpbox [AAA_]
Return

#-----------------------------#
$ADD_OBJET
Case FORMULE
 When "ZZ1" : Gosub ADD_TABLE
 When "ZZ2" : Gosub ADD_ECRAN
Endcase
Return

#-----------------------------#
$ADD_TABLE
TT = ""
PARAM(1) = "ATB"
PARAM(2) = "$"
PARAM(3) = ""
Call S_TAB_CHAR(TT,PARAM,"SELOBJ","SELOBJ","") From GACTION
If TT<>"" and !find(TT,TABLE(1..NBTABLE))
 NBTABLE += 1
 TABLE(NBTABLE) = TT
 Gosub TABLE
Endif
Return

#-----------------------------#
$ADD_ECRAN
TT = ""
PARAM(1) = "AMK"
PARAM(2) = "$"
PARAM(3) = ""
Call S_TAB_CHAR(TT,PARAM,"SELOBJ","SELOBJ","") From GACTION
If TT<>""
 Gosub MASQUE
Endif
Return

#----------------------------#
$TABLE
Read [ATB]CODFIC = TT
Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
# Table/Aide de la table
Field [AAA_]  1 , "" , [F:ATB]CODFIC , mess(56,123,1)-[F:ATB]CODFIC-TEXTE , mess(161,133,1) , [F:ATB]ABRFIC
FORMULE = TT : Gosub CHAMP
Return

#----------------------------#
$CHAMP
Read [ATB]CODFIC = FORMULE
For [ATZ]CODZONE Where CODFIC=FORMULE
 Call TEXTE([F:ATZ]NOLONG,TEXTE) From OBJDIV
 If [F:ATZ]CODACT<>""
  Read [ACV]CODACT = [F:ATZ]CODACT
  If [F:ACV]FLACT=2
   If [F:ACV]DIME<>0
    DIME = [F:ACV]DIME
   Else
    DIME = [F:ATZ]DIME
   Endif
  Else
   DIME = 0
  Endif
 Else
  DIME = [F:ATZ]DIME
 Endif
 For J=1 To DIME
  If DIME=1
# Michel Giet
   If dim(WCVF) > 0
     WCVW  = [F:ATZ]CODZONE
     Gosub CONVTEX
   Endif
   DESIG = [F:ATZ]CODZONE-TEXTE
   CHAMP = "[F:"+[F:ATB]ABRFIC+"]"+[F:ATZ]CODZONE
  Else
# Michel Giet
   If dim(WCVF) > 0
     WCVW  = [F:ATZ]CODZONE+"("+num$(J-1)+")"
     Gosub CONVTEX
   Endif
   DESIG = [F:ATZ]CODZONE-"("+num$(J-1)+")"-TEXTE
   CHAMP = "[F:"+[F:ATB]ABRFIC+"]"+[F:ATZ]CODZONE+"("+num$(J-1)+")"
  Endif
  # Aide du champ
  Field [AAA_]  2 , FORMULE , FORMULE+"."+[F:ATZ]CODZONE+"_"+num$(J) , DESIG , mess(162,133,1) , CHAMP
  NBCHAMP += 1
 Next J
Next
Return

# Michel Giet : possibilité de convertir le libellé du champs (tarifs)
#
$CONVTEX
For L = 0 To dim(WCVF)-1
  If WCVF(L) = [F:ATZ]CODFIC & WCVZ(L)= WCVW
    TEXTE = WCVT(L)
    Break
  Endif
Next L
Return

#----------------------------#
$MASQUE
Read [AMK]CODMSK = TT
Call TEXTE([F:AMK]INTMSK,TEXTE) From OBJDIV
# Ecran/Aide de l'écran
Field [AAA_]  1 , "" , [F:AMK]CODMSK , mess(2,42,1)-[F:AMK]CODMSK-TEXTE , mess(163,133,1) , [F:AMK]ABRMSK
FORMULE = TT : Gosub ZONE
Return

#----------------------------#
$ZONE
For [AMZ]CODZON Where CODMSK=FORMULE
 Call TEXTE([F:AMZ]INTIT,TEXTE) From OBJDIV
 If [F:AMZ]CODACT<>""
  Read [ACV]CODACT = [F:AMZ]CODACT
  If [F:ACV]FLACT=2
   If [F:ACV]DIME<>0
    DIME = [F:ACV]DIME
   Else
    DIME = [F:AMZ]DIME
   Endif
  Else
   DIME = 0
  Endif
 Else
  DIME = [F:AMZ]DIME
 Endif
 If [F:AMK]TYPBLOC([F:AMZ]NUMBLOC-1)=1
  If [F:AMZ]CODTYP="ABS"
   DESIG = [F:AMZ]CODZON-TEXTE
   CHAMP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AMZ]CODZON
   # Aide du champ
   Field [AAA_]  2 , FORMULE , FORMULE+"."+[F:AMZ]CODZON , DESIG , mess(162,133,1) , CHAMP
   NBCHAMP += 1
  Else
   DESIG = [F:AMZ]CODZON-"()"-TEXTE
   CHAMP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AMZ]CODZON+"(indice)"
   # Aide du champ
   Field [AAA_]  2 , FORMULE , FORMULE+"."+[F:AMZ]CODZON , DESIG , mess(162,133,1) , CHAMP
   NBCHAMP += 1
  Endif
 Else
  For J=1 To DIME
   If DIME=1
    DESIG = [F:AMZ]CODZON-TEXTE
    CHAMP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AMZ]CODZON
   Else
    DESIG = [F:AMZ]CODZON-"("+num$(J-1)+")"-TEXTE
    CHAMP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AMZ]CODZON+"("+num$(J-1)+")"
   Endif
   # Aide du champ
   Field [AAA_]  2 , FORMULE , FORMULE+"."+[F:AMZ]CODZON+"_"+num$(J) , DESIG , mess(162,133,1) , CHAMP
   NBCHAMP += 1
  Next J
 Endif
Next
Return

#----------------------------#

$PAYE
Local Char DES (GLONAX3)
Case TT
 When "RUB"
  Read[ATB]CODFIC = "RUBRIQUE"
  If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
 When "VAR"
  Read[ATB]CODFIC = "VARIA"
  If clalev([F:VRA])=0 : Local File VARIA [VRA] : Endif
 When "CUM"
  Read[ATB]CODFIC = "CUMUL"
  If clalev([F:CUM])=0 : Local File CUMUL [CUM] : Endif
 When "MSR"
  Read[ATB]CODFIC = "MSRUB"
  If clalev([F:MSR])=0 : Local File MSRUB [MSR] : Endif
Endcase
Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
Field [AAA_] 1 , "" , [F:ATB]CODFIC , [F:ATB]CODFIC+"   "+TEXTE , "Aide de la table" , [F:ATB]ABRFIC
FORMULE = TT
Case TT
 When "RUB" : Gosub RUBRIQUE
 When "VAR" : Gosub VARIAB
 When "CUM" : Gosub CUMUL
 When "MSR" : Gosub MSRUB
Endcase
Return

$RUBRIQUE
For [RUB]RUB0 Where LEG=GCURLEG
 Call LECTEXTRA([L]DES,"RUBRIQUE","DES",[F:RUB]LEG,[F:RUB]COD) From ATEXTRA
 DESIG = [F:RUB]COD-[L]DES
 CHAMP = "R_"+[F:RUB]COD
 Field [AAA_]  2 , [F:ATB]CODFIC , FORMULE+"."+[F:RUB]COD , DESIG , "Aide du champ" , CHAMP
 NBCHAMP +=1
Next
Return

$VARIAB
For [VRA]VRA0 Where FLGEXS<>2 & LEG=GCURLEG
 Call LECTEXTRA([L]DES,"VARIA","DES",[F:VRA]LEG,[F:VRA]COD) From ATEXTRA
 DESIG = [F:VRA]COD-[L]DES
 CHAMP = "V_"+[F:VRA]COD
 Field [AAA_]  2 , [F:ATB]CODFIC , FORMULE+"."+[F:VRA]COD , DESIG , "Aide du champ" , CHAMP
 NBCHAMP +=1
Next
Return

$CUMUL
For [CUM]CUM0 Where LEG=GCURLEG
 Call LECTEXTRA([L]DES,"CUMUL","CUMDES",[F:CUM]LEG,[F:CUM]CUMCOD) From ATEXTRA
 DESIG = [F:CUM]CUMCOD-[L]DES
 CHAMP = "C_"+[F:CUM]CUMCOD
 Field [AAA_]  2 , [F:ATB]CODFIC , FORMULE+"."+[F:CUM]CUMCOD , DESIG , "Aide du champ" , CHAMP
 NBCHAMP += 1
Next
Return

$MSRUB
For [MSR]MSR0
 DESIG = [F:MSR]COD-[F:MSR]DES
 CHAMP = "R_"+[F:MSR]COD
 Field [AAA_]  2 , [F:ATB]CODFIC , FORMULE+"."+[F:MSR]COD , DESIG , "Aide du champ" , CHAMP
 NBCHAMP +=1
Next
Return


#----------------------------#
$VERIF
If FORMULE=""
 E = 0
Else
 E = abs(parse(FORMULE))
 If E
  Errbox errmes$(E)+chr$(13)+errm
 Endif
Endif
Return

#----------------------------#
$DEFVARSYS
NBTEX += 1 : OPE(NBTEX) = "date$"       : TEX(NBTEX) = mess(100,124,1) : # Date du jour
NBTEX += 1 : OPE(NBTEX) = "time$"       : TEX(NBTEX) = mess(101,124,1) : # Heure courante
NBTEX += 1 : OPE(NBTEX) = "datesyst"    : TEX(NBTEX) = mess(102,124,1) : # Date système
NBTEX += 1 : OPE(NBTEX) = "GUSER"       : TEX(NBTEX) = mess(103,124,1) : # Code utilisateur
NBTEX += 1 : OPE(NBTEX) = "GNOMUSER"    : TEX(NBTEX) = mess(175,124,1) : # Nom utilisateur
NBTEX += 1 : OPE(NBTEX) = "GLANGUE"     : TEX(NBTEX) = mess(176,124,1) : # Langue courante
NBTEX += 1 : OPE(NBTEX) = "GLANDEF"     : TEX(NBTEX) = mess(177,124,1) : # Langue par défaut
NBTEX += 1 : OPE(NBTEX) = "GSYSCUR"     : TEX(NBTEX) = mess(178,124,1) : # Devise de reporting
NBTEX += 1 : OPE(NBTEX) = "GFCYDEF"     : TEX(NBTEX) = mess(179,124,1) : # Site par défaut
NBTEX += 1 : OPE(NBTEX) = "GDEFSOC"     : TEX(NBTEX) = mess(180,124,1) : # Société par défaut
NBTEX += 1 : OPE(NBTEX) = "GBANDEF"     : TEX(NBTEX) = mess(181,124,1) : # Banque par défaut
NBTEX += 1 : OPE(NBTEX) = "GCSHDEF"     : TEX(NBTEX) = mess(182,124,1) : # Caisse par défaut
NBTEX += 1 : OPE(NBTEX) = "GOPTCANA"    : TEX(NBTEX) = mess(183,124,1) : # Nombre d'axes analytiques
Return

#----------------------------#
$DEFVARLOC
NBTEX = 0
If dim(WVAT) > 0
  For  I = 0 To dim(WVAT)-1
    If I < dim(OPE)-1 & I < dim(TEX)-1
      NBTEX += 1
      OPE(NBTEX) = WVAS(I)
      TEX(NBTEX) = WVAT(I)
    Endif
  Next
Endif
Return

#----------------------------#
$VARIA
NBTEX += 1 : OPE(NBTEX) = TT
Case TT
 When "GERRBATCH"  : TEX(NBTEX) = mess(150,133,1) : # Nb d'erreur dans la tâche batch
 When "GMESSBATCH" : TEX(NBTEX) = mess(151,133,1) : # Message d'erreur dans la tâche batch
 When "GERRTRACE"  : TEX(NBTEX) = mess(152,133,1) : # Nombre d'erreur dans la trace
 When Default      : TEX(NBTEX) = TT
Endcase
Return

#------------------------------------------------------------------------#
Subprog B1_FORMUL(FORMULE,FILTAB,TEXCON,VARSUP)
Variable Char    FORMULE()
Variable Char    FILTAB()
Variable Char    TEXCON()
Variable Char    VARSUP()
#
Local    Char    WFIL(250)
Local    Integer WCVD, WVAR, I, J, K, L
#
# Création des tables de conversion
WCVD = 0
For I = 0 To dim(TEXCON)-1
  If TEXCON(I) <> ""
    WCVD += 1
  Endif
Next
#
If WCVD > 0
  Local Char WCVF(10)(WCVD)
  Local Char WCVZ(10)(WCVD)
  Local Char WCVT(50)(WCVD)
  Local Char WCVW(80)
  For I = 0 To WCVD - 1
    WCVW = TEXCON(I)
    J = instr(1,WCVW,",")
    K = instr(J+1,WCVW,",")
    WCVF(I) = seg$(WCVW,1,J-1)
    WCVZ(I) = seg$(WCVW,J+1,K-1)
    WCVT(I) = seg$(WCVW,K+1,len(WCVW))
  Next I
Endif
# Création table variables suplémentaires
WVAR = 0
For I = 0 To dim(VARSUP)-1
  If VARSUP(I) <> ""
    WVAR += 1
  Endif
Next
#
If WVAR > 0
  Local Char WVAS(50)(WVAR)
  Local Char WVAT(50)(WVAR)
  Local Char WVAW(100)
  For I = 0 To WVAR - 1
    WVAW = VARSUP(I)
    J = instr(1,WVAW,",")
    WVAS(I) = seg$(WVAW,1,J-1)
    WVAT(I) = seg$(WVAW,J+1,len(WVAW))
  Next I
Endif
#
If clalev([F:ATB])=0 : Local File ATABLE   [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON  [ATZ] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
If clalev([F:AMK])=0 : Local File AMSK     [AMK] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON  [AMZ] : Endif

Local Char    TT(10) , TABLE(10)(1..100)
Local Char    TEXTE(80) , DESIG(80) , CHAMP(80) , SAVFOR(250)
Local Integer I , NBTABLE , REPONSE , NBCHAMP , NBTEX , SAVSEL
Local Char    OPE(15)(1..50+WVAR) , TEX(50)(1..50+WVAR)
Local Char    PARAM(250)(1..3)

# Sélection des tables (Filtre si dimension = 1 / Liste si dimension <> 1)
NBTABLE=0
If dim(FILTAB) = 1 & FILTAB <> ""
  Filter [ATB] Where evalue(FILTAB)
&              Order By Key CODFIC
  For [ATB]
    If NBTABLE < dim(TABLE)
      NBTABLE += 1
      TABLE(NBTABLE) = [F:ATB]CODFIC
    Else
      Break
    Endif
  Next
  Filter [ATB]
Else
  For I = 0 To dim(FILTAB)-1
    If FILTAB(I) <> ""
      Read [ATB]CODFIC=FILTAB(I)
      If fstat=0
        NBTABLE += 1
        TABLE(NBTABLE) = [F:ATB]CODFIC
      Endif
    Endif
  Next I
Endif
SAVFOR = FORMULE
FORMULE = vireblc(format$("KT:200X",FORMULE),2)

Gosub SAI_FORMULE
End

#------------------------------------------------------------------------#
Subprog C_FORMULE(VALEUR)
Variable Char VALEUR()
Local Integer E
If VALEUR="" : End : Endif
E = parse(VALEUR)
If E
 GMESSAGE = mess(37,124,1)+"\"+errmes$(E) : # Expression incorrecte
 mkstat = 2
Endif
End

Subprog IB_FORMULE
#82644 : Assistant de formule en Web
#If !GBROWS
 GBOUT1 = mess(27,126,1) : # Editeur formule
#Else
# GBOUT1 = ""
#Endif
If GFONCTION<>"GESMSR" & GFONCTION<>"GESLPM"
 GBOUT7=""
Endif

GFRMNB = 0
End

