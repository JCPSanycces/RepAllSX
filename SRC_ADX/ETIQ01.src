#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
End

######################################
#-- HN 09/06/2004
#-- Les actions SAISIE, IMPRIMANTE et DESTINATION
#-- n'existent plus (voir mail EB)
$ACTION
Case ACTION
 When "DESTINATION"       : Gosub DESTINATION
 When "IMPRIMANTE"        : Gosub IMPRIMANTE
 When "EXEC"              : Gosub EXEC_AUT
Endcase
Return

######################################
$DECLARE 
Local  Char    CRITERE(255), PARAM(30) , VALEUR(30) , ETAT(15) 
Local  Integer WNUMLIG, NUMREQ 
Return 

######################################
$DESTINATION
[M:RPT]IMPRIME = 2
OK = 0
Return

######################################
$IMPRIMANTE

#il faut retrouver le paramètre porteur du nom de l'imprimante pour le surcharger
Local Integer I,WOK
Raz WOK
For I = 1 To NBPAR
    If left$(PARAMETRE(I),13)="_PrinterName="
       PARAMETRE(I) = "_PrinterName="+chr$(1)+GDEFIMP
       WOK = 1 
       Break 
    Endif
Next I
# llc 11.02 il n'y a plus ce paramètre
# sr Si on n' a pas trouvé le paramètre on le rajoute
If  !WOK 
    NBPAR += 1
    PARAMETRE(I) = "_PrinterName="+chr$(1)+GDEFIMP
Endif

#sr Il faut retouver le paramètyre porteur de novisible
Raz WOK
For I = 1 To NBPAR
    If left$(PARAMETRE(I),13)="_NoVisible="
       PARAMETRE(I) = "_NoVisible="+chr$(1)+"1"
       WOK = 1 
       Break 
    Endif
Next I
# sr Si on n' a pas trouvé le paramètre on le rajoute
If  !WOK 
    NBPAR += 1
    PARAMETRE(NBPAR) = "_NoVisible="+chr$(1)+"1"
Endif
[M:RPT]IMPRIMANTE = GDEFIMP
Return

######################################
$EXEC_AUT
Local Integer I,J
Gosub DECLARE 
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = num$([V]GWNUMREQ)
   When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([V]GWNUMREQ)
   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
 Endcase
 Endif
Next I
Return
