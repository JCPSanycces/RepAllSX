#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
#   Recherche d'un tiers                                             Module CRM         27 février 2001
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
# Liste des abréviations utilisées :
#
# BPR : Utilisée pour rechercher un tiers
# BPP : Utilisée pour rechercher un prospect
# BPC : Utilisée pour rechercher un client
# BPS : Utilisée pour rechercher un fournisseur
# REP : Utilisée pour rechercher un représentant
# BPT : Utilisée pour rechercher un transporteur
# PRV : Utilisée pour rechercher un prestataire
# DOO : Utilisée pour rechercher un donneur d'ordres
# ACC : Utilisée pour rechercher un tiers divers
#
# Il est possible de combiner les recherches. Pour cela, afin d'obtenir une fenêtre permettant de rechercher
# à la fois des fournisseurs ou des transporteurs, chaque abréviation doit être mise entre parenthèses.
#
# Par exemple :
#
# "(BPS)(BPT)"
#
##########################################################################################################

##########################################################################################################
$OUVRE
Global Char GLKP0TYPSEA(100)

  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Char SZTITRE(100)

  Raz SZTITRE
  If PARAM(2) <> "" Then
    [M:LKP0]BPRNAM = PARAM(2)
    Affzo [M:LKP0]BPRNAM
  Endif
  If PARAM(3) <> "" Then
    [M:LKP0]BPRZIP = PARAM(3)
    Affzo [M:LKP0]BPRZIP
  Endif
  If PARAM(4) <> "" Then
    [M:LKP0]BPRCTY = PARAM(4)
    Affzo [M:LKP0]BPRCTY
  Endif
  If PARAM(1) = "" Then
    [M:LKP0]CHOIXBPR = "BPR"
  Else
    [M:LKP0]CHOIXBPR = PARAM(1)
  Endif
  #Définit l'intitulé évalué du type de la recherche
  If instr(1, [M:LKP0]CHOIXBPR, '(') Then
    #Recherche d'un tiers
    SZTITRE = mess(677,196,1)
  Else
    Case [M:LKP0]CHOIXBPR
      When "BPR"
        SZTITRE = mess(677,196,1)
      When "BPP"
        SZTITRE = mess(678,196,1)
      When "BPC"
        SZTITRE = mess(679,196,1)
      When "BPS"
        SZTITRE = mess(680,196,1)
      When "REP"
        SZTITRE = mess(681,196,1)
      When "BPT"
        SZTITRE = mess(682,196,1)
      When "PRV"
        SZTITRE = mess(683,196,1)
      When "DOO"
        SZTITRE = mess(684,196,1)
      When "ACC"
        SZTITRE = mess(685,196,1)
    Endcase
  Endif
  Chgtbk [M:LKP0]5 With SZTITRE
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:LKP0]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      If (nolign-1) >= 0 Then
        If [M:LKP0]BPRNUM(nolign-1) <> "" Then
          VALEUR = [M:LKP0]BPRNUM(nolign-1)
          FIN = 1
          mkstat = 99
        Endif
      Endif
    When "C"
      Gosub ONLOAD
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return


##########################################################################################################
$ONOK
  #Contrôle qu'un tiers est client en cas d'utilisation depuis une demande de service.
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESSRE" Then
      If [M:LKP0]BPCFLG(GLKP0NOL) <> 2 Then
        #Le tiers sélectionné n'est pas client. Celui-ci ne peut pas être mentionné sur une demande de service.
        GMESSAGE = mess(585,182,1)
        GERR = 2
        FIN = 0
        Return
      Endif
    Elsif GNAVIG(GPILNAV-1) = "GESCON" Then
      #Contrôle qu'un tiers est client en cas d'utilisation depuis un contrat de service
      If [M:LKP0]BPCFLG(GLKP0NOL) <> 2 Then
        #Le tiers sélectionné n'est pas client. Celui-ci ne peut pas être mentionné sur un contrat de service.
        GMESSAGE = mess(604,182,1)
        GERR = 2
        FIN = 0
        Return
      Endif
    Endif
  Endif
  VALEUR = [M:LKP0]BPRNUM(GLKP0NOL)
  mkstat = 4
Return

##########################################################################################################
$ONLOAD
Local Char SZWHERE (250)(20)
Local Integer ILIGNEWHERE
Local Char SZAND
Local Char SZVALEUR (100)
Local Char SZRECHERCHE (100)
Local Integer IBNONVIDE
Local Integer ILIGNE
Local Integer INBLIGNETOTAL

  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  IBNONVIDE = 0
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Effzo [M:LKP0]15
  [M:LKP0]NBREC = 0
  #Il faut créer le link
  Link [BPA] With [BPR] BPR0=[F:BPA]BPANUM  As [BPRA] Where [F:BPR]BPRNUM<>"" and [F:BPA]BPATYP=1
  If [M:LKP0]CHOIXBPR <> "BPR" Then
    #Restriction par rapport au type de tiers
    #Recherche de Prospect
    If instr(1, [M:LKP0]CHOIXBPR, "BPP") <> 0 Then
      SZWHERE(ILIGNEWHERE) = SZAND + " [F:BPR]PPTFLG=2 "
      ILIGNEWHERE = ILIGNEWHERE + 1
      SZAND = " AND "
    Endif
    #Recherche de Client
    If instr(1, [M:LKP0]CHOIXBPR, "BPC") <> 0 Then
      SZWHERE(ILIGNEWHERE) = SZAND + " [F:BPR]BPCFLG=2 "
      ILIGNEWHERE = ILIGNEWHERE + 1
      SZAND = " AND "
    Endif
    #Recherche de Fournisseurs
    If instr(1, [M:LKP0]CHOIXBPR, "BPS") <> 0 Then
      SZWHERE(ILIGNEWHERE) = SZAND + " [F:BPR]BPSFLG=2 "
      ILIGNEWHERE = ILIGNEWHERE + 1
      SZAND = " AND "
    Endif
    #Recherche de Transporteurs
    If instr(1, [M:LKP0]CHOIXBPR, "BPT") <> 0 Then
      SZWHERE(ILIGNEWHERE) = SZAND + " [F:BPR]BPTFLG=2 "
      ILIGNEWHERE = ILIGNEWHERE + 1
      SZAND = " AND "
    Endif
    #Recherche de Prestataires
    If instr(1, [M:LKP0]CHOIXBPR, "PRV") <> 0 Then
      SZWHERE(ILIGNEWHERE) = SZAND + " [F:BPR]PRVFLG=2 "
      ILIGNEWHERE = ILIGNEWHERE + 1
      SZAND = " AND "
    Endif
    #Recherche de Donneurs d'ordres
    If instr(1, [M:LKP0]CHOIXBPR, "DOO") <> 0 Then
      SZWHERE(ILIGNEWHERE) = SZAND + " [F:BPR]DOOFLG=2 "
      ILIGNEWHERE = ILIGNEWHERE + 1
      SZAND = " AND "
    Endif
    #Recherche de Tiers divers
    If instr(1, [M:LKP0]CHOIXBPR, "ACC") <> 0 Then
      SZWHERE(ILIGNEWHERE) = SZAND + " [F:BPR]BPRACC=2 "
      ILIGNEWHERE = ILIGNEWHERE + 1
      SZAND = " AND "
    Endif
  Endif
  #Recherche de Représentants
  If instr(1, [M:LKP0]CHOIXBPR, "REP") <> 0 Then
    SZWHERE(ILIGNEWHERE) = SZAND + " [F:BPR]REPFLG=2 "
    ILIGNEWHERE = ILIGNEWHERE + 1
    SZAND = " AND "
  Else
    SZWHERE(ILIGNEWHERE) = SZAND + " [F:BPR]REPFLG=1 "
    ILIGNEWHERE = ILIGNEWHERE + 1
    SZAND = " AND "
  Endif
  If [M:LKP0]BPRNAM <> "" Then
    SZVALEUR = [M:LKP0]BPRNAM
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE(ILIGNEWHERE) = SZAND + " pat (toupper([F:BPR]BPRNAM)," +SZRECHERCHE+")<>0 "
    ILIGNEWHERE = ILIGNEWHERE + 1
    SZAND = " AND "
  Endif
  If [M:LKP0]BPRZIP <> "" Then
    SZVALEUR = [M:LKP0]BPRZIP
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE(ILIGNEWHERE) = SZAND + " pat (toupper([F:BPA]POSCOD)," +SZRECHERCHE+")<>0 "
    ILIGNEWHERE = ILIGNEWHERE + 1
    SZAND = " AND "
  Endif
  If [M:LKP0]BPRCTY <> "" Then
    SZVALEUR = [M:LKP0]BPRCTY
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE(ILIGNEWHERE) = SZAND + " pat (toupper([F:BPA]CTY)," +SZRECHERCHE+")<>0 "
    ILIGNEWHERE = ILIGNEWHERE + 1
    SZAND = " AND "
  Endif
  If [M:LKP0]BPRADEDEF = 2 Then
    SZWHERE(ILIGNEWHERE) = SZAND + " [F:BPA]BPAADDFLG=2 "
    ILIGNEWHERE = ILIGNEWHERE + 1
    SZAND = " AND "
  Endif
  ILIGNE = 0
  While ILIGNE < ILIGNEWHERE
    If SZWHERE(ILIGNE) <> "" Then
      IBNONVIDE = 1
    Endif
    ILIGNE = ILIGNE + 1
  Wend
  If IBNONVIDE = 1 Then
    Filter  [BPRA] Where evalue (SZWHERE) Order By [F:BPR]BPRNAM Desc; [F:BPA]CTY Desc
  Else
    Filter  [BPRA] Order By [F:BPR]BPRNAM Desc; [F:BPA]CTY Desc
  Endif
  INBLIGNETOTAL = rowcount([BPRA])
  ILIGNE = 0
  For [BPRA]
    If ILIGNE >= dim([M:LKP0]NAM)-1 Then
      Break
    Endif
    If [F:BPA]BPANUM <> "" Then
      [M:LKP0]BPRNUM(ILIGNE) = [F:BPR]BPRNUM

      [M:LKP0]NAM(ILIGNE) = [F:BPR]BPRNAM
      [M:LKP0]ZIP(ILIGNE) = [F:BPA]POSCOD
      [M:LKP0]CTY(ILIGNE) = [F:BPA]CTY
      [M:LKP0]TEL(ILIGNE) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:LKP0]CRY(ILIGNE) = [F:BPA]CRY

      [M:LKP0]BPAADDFLG(ILIGNE) = [F:BPA]BPAADDFLG
      [M:LKP0]BPADES(ILIGNE) = [F:BPA]BPADES

      [M:LKP0]BPCFLG(ILIGNE) = [F:BPR]BPCFLG
      [M:LKP0]PPTFLG(ILIGNE) = [F:BPR]PPTFLG
      [M:LKP0]BPSFLG(ILIGNE) = [F:BPR]BPSFLG
      [M:LKP0]REPFLG(ILIGNE) = [F:BPR]REPFLG
      [M:LKP0]BPTFLG(ILIGNE) = [F:BPR]BPTFLG
      [M:LKP0]PRVFLG(ILIGNE) = [F:BPR]PRVFLG
      [M:LKP0]DOOFLG(ILIGNE) = [F:BPR]DOOFLG
      [M:LKP0]BPRACC(ILIGNE) = [F:BPR]BPRACC
      ILIGNE += 1
    Endif
  Next
  Filter [BPRA]
  [M:LKP0]NBREC = ILIGNE
  Affzo [M:LKP0]1-99
  If ILIGNE < INBLIGNETOTAL Then
    #Tous les enregistrements n'ont pas pu être affichés, un critère plus discriminant doit être saisi.
    GMESSAGE = mess(963,182,1)
    GERR = 2
  Endif
Return

