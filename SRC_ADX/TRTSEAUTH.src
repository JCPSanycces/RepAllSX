#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management SEAUTH
######################################################################################
$ACTION

Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "AVANT_BOUTON"  : Gosub AVANT_BOUTON
 When "BOUTON"        : Gosub BOUTON
 When "AVANT_NEW"     : Gosub AVANT_NEW
 When "ABA"           : Gosub ABA
 When Default
Endcase

Return
######################################################################################
$OUVRE

If !clalev([F:SER])  : Local File SEPRC       [SER]  : Endif  # Sage Exchange Processing Setup
If !clalev([F:SEB])  : Local File SEBPC       [SEB]  : Endif  # Sage Exchange Customer data (cards)
If !clalev([F:SEU])  : Local File SEAUTH      [SEU]  : Endif  # Credit Card Authorization table
If !clalev([F:SEU2]) : Local File SEAUTH      [SEU2] : Endif  # Credit Card Authorization table

If !clalev([F:BPA])  : Local File BPADDRESS   [BPA]  : Endif  # BP Address
If !clalev([F:CNT])  : Local File CONTACT     [CNT]  : Endif  # Contact
If !clalev([F:BPC2]) : Local File BPCUSTOMER  [BPC2] : Endif  # BP Customer

If !clalev([F:FCY])  : Local File FACILITY    [FCY]  : Endif  # Sites

If !clalev([F:SOH2]) : Local File SORDER      [SOH2] : Endif  # Sales Order
If !clalev([F:SDH2]) : Local File SDELIVERY   [SDH2] : Endif  # Delivery
If !clalev([F:SIH2]) : Local File SINVOICE    [SIH2] : Endif  # Sales Invoice
If !clalev([F:SRD2]) : Local File SRETURND    [SRD2] : Endif  # Customer Return (detail)
If !clalev([F:PYH2]) : Local File PAYMENTH    [PYH2] : Endif  # Payment

Global Integer GCREATE,GSUBMIT,GALLOW_MANAUTH
Global  Char   GTXN(1)

Local  Char    CRITSTR(250),FCY,PAR_MANAUTH
Local  Integer III
Local  Integer CARDONFILE,ALLOW_NEW

Return
######################################################################################
$DEBUT

Raz [M:SEU1]
Raz GSUBMIT,GCREATE,GTXN,GALLOW_MANAUTH

[M:SEU1]DVCRTYP = val(PARAM(1))
[M:SEU1]DVCRNUM = PARAM(2)
[M:SEU1]VCRNUM  = [M:SEU1]DVCRNUM
[M:SEU1]VCRTYP  = [M:SEU1]DVCRTYP

Case [M:SEU1]DVCRTYP
 When 2:   # Sales Orders
  [M:SEU1]BPCNUM = [M:SOH1]BPCPYR
  Read [SOH2]SOH0=[M:SEU1]DVCRNUM
  If !fstat
    [M:SEU1]BPCNUM = [F:SOH2]BPCPYR
  Endif
  [M:SEU1]CUR = [M:SOH0]CUR
  FCY = [M:SOH0]SALFCY
  CRITSTR = "SOHNUM=[M:SOH0]SOHNUM"
 When 4:   # Shipments
  [M:SEU1]BPCNUM = [M:SDH2]BPCPYR
  Read [SDH2]SDH0=[M:SEU1]DVCRNUM
  If !fstat
    [M:SEU1]BPCNUM = [F:SDH2]BPCPYR
  Endif
  [M:SEU1]CUR = [M:SDH1]CUR
  FCY = [M:SDH0]SALFCY
  CRITSTR = "SDHNUM=[M:SDH0]SDHNUM"
 When 5,18:   # Sales Invoices/Credits
  If find([M:SIH0]INVTYP,2,4)  # Credit
    [M:SEU1]DVCRTYP = 18
  Endif
  [M:SEU1]BPCNUM = [M:SIH1]BPRPAY
  Read [SIH2]SIH0=[M:SEU1]DVCRNUM
  If !fstat
    [M:SEU1]BPCNUM = [F:SIH2]BPRPAY
  Endif
  [M:SEU1]CUR = [M:SIH0]CUR
  FCY = [M:SIH0]SALFCY
  CRITSTR = "SIHNUM=[M:SIH0]NUM"
 When 13:  # Customer Returns
  [M:SEU1]BPCNUM = [M:SRH0]BPCORD
  [M:SEU1]CUR = [M:SRH1]CUR
  FCY = [M:SRH0]STOFCY
  Filter [SIH2] Where INVNUM=[M:SRH0]SRHNUM & find(INVTYP,2,4)
  Read [SIH2] First
  Filter [SIH2]
  If !fstat
    CRITSTR = "SIHNUM='"+[F:SIH2]NUM+"'"
  Else
    CRITSTR = "find(SDHNUM"
    For [SRD2] Where SRHNUM=[M:SEU1]DVCRNUM & SDHNUM<>""
      CRITSTR += ",'" + [F:SRD2]SDHNUM + "'"
    Next
    CRITSTR += ")"
  Endif
 When 40,41:  # Customer Invoices
  If find([M:BIC0]INVTYP,2,4)  # Credit
    [M:SEU1]DVCRTYP = 41
  Endif
  [M:SEU1]BPCNUM = [M:BIC1]BPRPAY
  Read [SIH2]SIH0=[M:SEU1]DVCRNUM
  If !fstat
    [M:SEU1]BPCNUM = [F:SIH2]BPRPAY
  Endif
  [M:SEU1]CUR = [M:BIC1]CUR
  FCY = [M:BIC0]FCY
  CRITSTR = "SIHNUM=[M:BIC0]NUM"
 When 50,51:  # Payments/Reciepts
  If [M:PAY1]SNS<>2  # Payment
    [M:SEU1]DVCRTYP = 51
  Endif
  [M:SEU1]BPCNUM = [M:PAY1]BPR
  Read [PYH2]PYH0=[M:SEU1]DVCRNUM
  If !fstat
    [M:SEU1]BPCNUM = [F:PYH2]BPR
  Endif
  [M:SEU1]CUR = [M:PAY1]CUR
  FCY = [M:PAY1]FCY
  CRITSTR = "VCRNUM=[M:SEU1]DVCRNUM & VCRTYP=[M:SEU1]DVCRTYP"
 When Default:
  CRITSTR = "VCRNUM=[M:SEU1]DVCRNUM & VCRTYP=[M:SEU1]DVCRTYP"
Endcase

# Read site for company
Read [FCY]FCY0=[L]FCY
If !fstat
  [M:SEU1]DOCCPY = [F:FCY]LEGCPY
Endif
# Special processing if customer type is 2 (miscellaneous)
Read [BPC2]BPC0=[M:SEU1]BPCNUM

Gosub REFRESH

# Check if user has permission for manual authorization
Call PARAMUTIL("MANAUTH",PAR_MANAUTH,GUSER,"") From SUBAUS
If PAR_MANAUTH="2" : GALLOW_MANAUTH=1 Else : GALLOW_MANAUTH=0 : Endif

Diszo [M:SEU1]PAYNUM  # to allow for tunnel

# 101049.sn
# If from customer returns and they should not be here then display message and return
If [M:SEU1]DVCRTYP = 13 & [M:SEU1]NBLIG = 0
  Call GET_SER([F:SEU]PRCCOD) From SEPPLIB
  GMESSAGE = func AFNC.MES1(mess(56,2092,1),mess([F:SER]PAYPRC,2098,1))
  GERR = 1 : FIN = 1
  Return
Endif
# 101049.en

# Automatically go into "New" mode if there are no history records
If [M:SEU1]NBLIG=0
  If ALLOW_NEW
    Gosub AVANT_NEW
  Else
    Diszo [M:SEU1]
  Endif
Endif

Return
######################################################################################
$REFRESH

# Fill in the History records
[M:SEU1]NBLIG=0 : [M:SEU1]DAUTAMT=0
III = 0
Filter [SEU] Where evalue(CRITSTR) Order By VCRSEQ Desc
For [SEU]
  [M:SEU1]HVCRNUM(III) = [F:SEU]VCRNUM
  [M:SEU1]HVCRSEQ(III) = [F:SEU]VCRSEQ
  [M:SEU1]HVCRTYP(III) = [F:SEU]VCRTYP
  [M:SEU1]HTXNTYP(III) = [F:SEU]STAFLG
  [M:SEU1]HORIGAUTH(III) = [F:SEU]ORIGAUTH
  If find([F:SEU]STAFLG,6,7)
    [M:SEU1]HAUTAMT(III) = [F:SEU]PAYAMT
    [M:SEU1]HAUTDAT(III) = [F:SEU]PAYDAT
  Else
    [M:SEU1]HAUTAMT(III) = [F:SEU]AUTAMT
    [M:SEU1]HAUTDAT(III) = [F:SEU]AUTDAT
  Endif
  If find([F:SEU]STAFLG,3,8)
    [M:SEU1]DAUTAMT += [F:SEU]AUTAMT
  Endif
  III += 1
Next
Filter [SEU]
[M:SEU1]NBLIG=III

If [M:SEU1]NBLIG>0
  nolign = 1
  If GTXN="" : Gosub LOAD_LINE : Endif
Endif

[M:SEU1]RMNAMT = func GET_RMNAMT()
If [M:SEU1]RMNAMT>0
  # Determine if we should allow new at this point
  ALLOW_NEW = 1
  If [M:SEU1]MANAUT=2 & [M:SEU1]DAUTAMT<>0
    ALLOW_NEW=0
  Else
    Case [M:SEU1]DVCRTYP
     When 2:   # Sales Order initializations/lookups
       If [M:SOH1]ORDSTA=2 : ALLOW_NEW=0 : Endif
     When 4:   # Shipment initializations/lookups
      ALLOW_NEW=0
     When 5:   # Sales Invoice initializations/lookups
      If [M:SIH0]INVTYP=5 : ALLOW_NEW=0 : Endif
     When 13:  # Customer Returns
      ALLOW_NEW=0
    Endcase
    If !ALLOW_NEW : [M:SEU1]RMNAMT=0 : Endif
  Endif
Endif

Affzo [M:SEU1]

Return
######################################################################################
$LOAD_LINE

Read [SEU]SEU0=[M:SEU1]HVCRTYP(nolign-1);[M:SEU1]HVCRNUM(nolign-1);[M:SEU1]HVCRSEQ(nolign-1)
If !fstat
  Raz [M:SEU1]ACCNCKNAM,PRCCOD,VCRSEQ,AUTID,AUTAMT,AUTDAT,AUTEXP,AUTMSG
  Raz [M:SEU1]STAFLG,PAYAMT,PAYCDT,PAYDAT,PAYNUM
  [M:SEU1] = [F:SEU]
  Case [M:SEU1]DVCRTYP
    When 2         : [M:SEU1]VCRNUM=[F:SEU]SOHNUM
    When 4         : [M:SEU1]VCRNUM=[F:SEU]SDHNUM
    When 5,18,40,41: [M:SEU1]VCRNUM=[F:SEU]SIHNUM
    When Default   : [M:SEU1]VCRNUM=[F:SEU]VCRNUM
  Endcase
  If [M:SEU1]PAYAMT>0 & find([M:SEU1]DVCRTYP,18,41,51)
    [M:SEU1]PAYCDT = mess(49,2092,1)  # Credit
  Endif
  If [M:SEU1]ACCNCKNAM <> ""
    Read [SEB]SEB0=[M:SEU1]BPCNUM;[M:SEU1]ACCNCKNAM
    If !fstat
      Gosub FILL_CARD_FIELDS
    Endif
  Endif
  Call GET_SER([M:SEU1]PRCCOD) From SEPPLIB
  Affzo [M:SEU1]
Endif

Return
######################################################################################
$SETBOUT

If [M:SEU1]VCRSEQ <> 0            # Displaying an old record
  Diszo [M:SEU1]5-20
Endif

If GTXN="C"
  ETABOU(GABAN) = 1  # Cancel
Endif

CHMEN = ""

Local Integer SEPP_OK : SEPP_OK = func SEPPCDT.SEPP_OK([M:SEU1]DVCRTYP,[M:SEU1]DVCRNUM,1)

# New button
ETABOU(GNOUV) = (!SEPP_OK or [M:SEU1]STAFLG=1) and ALLOW_NEW

If GSUBMIT=0 & ([M:SEU1]DVCRTYP=2 or ([M:SEU1]DVCRTYP=5 and [M:SIH1]SIHORI=1))
  GSUBMIT = !SEPP_OK
Endif

# Card Creation
If GTXN="C" and GCREATE : CHMEN += "1" : Endif

# Submit (select/verify/authorize)
If GTXN="C" and GSUBMIT and not GCREATE : CHMEN += "2" : Endif

# Void button
If func TRTSEAUTH.DOCVOIDABLE()
  CHMEN += "3"
Endif

Return
######################################################################################
$AVANT_NEW

Raz [M:SEU1]VCRSEQ
Raz [M:SEU1]ACCNCKNAM,PRCCOD,ACCNAM,USEBILLADR,ADDLIG,CTY,SAT,POSCOD,CRY,EMAIL,ONETIME,MANAUT

Gosub CLEAR_CARD_DETAILS  # Display only and hidden fields

CARDONFILE = 0
# See if there is a card on file for this non-miscellaneous type customer
If [F:BPC2]BPCTYP<>2
  Filter [SEB] Where BPCNUM=[M:SEU1]BPCNUM & FLACT=2 & ONETIME<>2 Order By FLDEF Desc
  For [SEB]
    Call GET_SER([F:SEB]PRCCOD) From SEPPLIB
    If !fstat and [F:SER]CPY=[M:SEU1]DOCCPY
      CARDONFILE=1
      Break
    Endif
  Next
  Filter [SEB]
Endif

If CARDONFILE
    [M:SEU1]ONETIME=1
    Actzo [M:SEU1]ACCNCKNAM,ONETIME
    Gosub DEACTIVATE_CARD_INFO
    If [F:SEB]FLDEF=2
      Gosub GET_DEF_CARD
    Else
      Gosub GET_BILL_ADDR
    Endif
Else
    [M:SEU1]ONETIME=2
    Grizo [M:SEU1]ACCNCKNAM
    Gosub ACTIVATE_CARD_INFO
    Gosub GET_DEF_PRCCOD
    [M:SEU1]USEBILLADR=2
    Gosub GET_BILL_ADDR
    Gosub GET_EMAIL_ADDRESS
Endif

# Initialize the transaction information block
Raz [M:SEU1]MANAUT,AUTAMT,AUTID,AUTDAT,AUTMSG,STAFLG,PAYAMT,PAYDAT,PAYNUM
If GALLOW_MANAUTH
  Actzo [M:SEU1]MANAUT
Else
  Diszo [M:SEU1]MANAUT
Endif
Diszo [M:SEU1]AUTAMT,AUTID,AUTDAT,STAFLG,PAYAMT,PAYDAT,PAYNUM

If [M:SEU1]PRCCOD<>""
  [M:SEU1]RMNAMT = func GET_RMNAMT()
Endif

GTXN = "C"
GSUBMIT=1

Affzo [M:SEU1]

If [M:SEU1]ONETIME=2
    If [F:BPC2]BPCTYP=2
      Diszo [M:SEU1]ONETIME
      zonsui = "[M:SEU1]PRCCOD"
    Else
      zonsui = "[M:SEU1]ONETIME"
    Endif
Else
    zonsui = "[M:SEU1]ACCNCKNAM"
Endif

Return
######################################################################################
$ABA

#Abandon the modification
If [M:SEU1]NBLIG > 0
  Gosub REFRESH
Else
  Gosub DEBUT
Endif

GTXN = ""
GSUBMIT = 0
GCREATE = 0
Diszo [M:SEU1]5-20

Return
######################################################################################
$AVANT_BOUTON

# verify processing code - not sure why this doesn't happen automatically?
If [M:SEU1]ACCNCKNAM="" & [M:SEU1]ONETIME<>2 & [M:SEU1]MANAUT<>2
  GMESSAGE = mess(10,123,1)
  GZONE = "ACCNCKNAM" : GZNUM = 50294
  GERR=1 : Return
Endif
If [M:SEU1]PRCCOD=""
  GMESSAGE = mess(10,123,1)
  GZONE = "PRCCOD" : GZNUM = 8065
  GERR=1 : Return
Endif

Return
######################################################################################
$BOUTON

Case BOUT
  When "1" : If GCREATE : Gosub CRE_CARD : Endif
  When "2" : If GSUBMIT : Gosub SUBMIT_TXN : Endif
  When "3" : Gosub VOID_TXN
Endcase

Return
######################################################################################
$CRE_CARD

Trbegin [F:SEB]

Raz [F:SEB]
[F:SEB] = [M:SEU1]

If [M:SEU1]ONETIME=2 | [M:SEU1]MANAUT=2
  [F:SEB]ACCNCKNAM = num$(month(date$))+num$(day(date$))+num$(year(date$))+num$(time)
  [F:SEB]FLDEF = 1
Endif

[F:SEB]VLTREQ = 1

# Create the card in the vault and return details (account number, expiration, etc.)
If [M:SEU1]MANAUT <> 2
  Call VAULT_CRE([M:SEU1]BPCNUM,[F:SEB]ACCNCKNAM,[M:SEU1]PRCCOD,num$(uuid$)+num$([F:SEB]VLTREQ),GERR,GMESSAGE) From SEPPLIB
Endif

If !GERR
  Write [F:SEB]
  If fstat
    GOK = 0: Call FSTA("SEB") From GLOCK
    Rollback
  Else
    Commit
    GCREATE=0
    [M:SEU1] = [F:SEB]
    Affzo [M:SEU1]
    Gosub DEACTIVATE_CARD_INFO
    Gosub DEACTIVATE_ADDRESS
  Endif
Else
  If [F:SEB]VLTGUID="" and find(GERR,0,99)
    GMESSAGE=mess(28,2092,1)  # Error creating credit card
  Endif
  Rollback
  If GMESSAGE<>"" : Call ERREUR(GMESSAGE) From GESECRAN : Endif
  Raz GMESSAGE
Endif

Return
######################################################################################
$SUBMIT_TXN

# automatically create the one time use card
# for manual, no card is created, just an entry in SEBPC
If [M:SEU1]ONETIME=2 | [M:SEU1]MANAUT=2
  GCREATE=1
  Gosub CRE_CARD
  If !GOK : Return : Endif
Endif

# Problem with create, bail out
If GCREATE & ([M:SEU1]ONETIME=2 | [M:SEU1]MANAUT=2)
  GCREATE=0 : Return
Endif

Raz fstat
Call GET_SER([M:SEU1]PRCCOD) From SEPPLIB
If fstat : Raz [F:SER] : Return : Endif

# Create a new auth record if one does not exist
Trbegin [SEU2]

# Delete any old selection(s)
Delete [SEU2] Where VCRNUM=[M:SEU1]VCRNUM & STAFLG=1

# Read for last card for this document
Filter [SEU2] Where (VCRTYP=[M:SEU1]DVCRTYP & VCRNUM=[M:SEU1]DVCRNUM)
&                 | (VCRTYPORI=2 & SOHNUM=[M:SEU1]DVCRNUM)
&             Order By VCRSEQ
Read [SEU2] Last
Filter [SEU2]
If fstat : Raz [F:SEU2] : Endif

# If Sage Pay, return only allowed back to original card
If [F:SER]PAYPRC=2 & find([M:SEU1]DVCRTYP,18,41,51) & [F:SEU]ORIGVPSTXID="" & [M:SEU1]MANAUT<>2
  GMESSAGE = func AFNC.MES1(mess(56,2092,1),mess([F:SER]PAYPRC,2098,1))
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Rollback
  Return
Endif

# Create a new authorization record
Raz [F:SEU]
[F:SEU] = [M:SEU1]
[F:SEU]VCRTYP    = [M:SEU1]DVCRTYP
[F:SEU]VCRNUM    = [M:SEU1]DVCRNUM
[F:SEU]VCRSEQ    = [F:SEU2]VCRSEQ + 1
[F:SEU]STAFLG    = 1  # Selected
[F:SEU]VCRTYPORI = [F:SEU]VCRTYP
Call SET_SEUDOC([M:SEU1]DVCRTYP,[F:SEU]VCRNUM) From SEPPLIB

If [F:SEU]MANAUT=2
  [F:SEU]STAFLG=8  #Manual
  [F:SEU]ORIGAUTH = [F:SEU]AUTAMT
Else
# Determine if the card should be post order auth
  If [F:SEU]VCRTYP=2
    [F:SEU]POSTAUT = [F:SER]AUTSTP
    If [F:SER]VERIF=2 : [F:SEU]POSTAUT=3 : Endif
  Endif
  Raz [F:SEU]AUTAMT
Endif
Write [SEU]
If fstat
  Call FSTA("SEU") From GLOCK
  Rollback : Return
Endif
Commit
[M:SEU1]VCRSEQ = [F:SEU]VCRSEQ

# Credits will not be authd; just captured
If find([M:SEU1]DVCRTYP,2,5,40,50) & [F:SEU]POSTAUT<>2 & [F:SEU]MANAUT<>2
  Call AUTH([F:SEU]VCRTYP,[F:SEU]VCRNUM,[F:SEU]VCRSEQ,GERR,GMESSAGE) From SEPPLIB
Endif
If GERR
  If GMESSAGE<>"" : Call ECR_TRACE(GMESSAGE,mod(GERR,2)) From GESECRAN : Endif
  # Delete any old selection(s)
  Trbegin [SEU2]
  Delete [SEU2] Where VCRNUM=[M:SEU1]DVCRNUM & STAFLG=1
  Commit
  Raz [M:SEU1]VCRSEQ
  # If just an information message, like a rejection, then clear the transaction
  If GERR=2
    Raz GTXN,GSUBMIT
  Endif
Else
  Raz GTXN
  Raz GSUBMIT
Endif

Raz GERR,GMESSAGE
Gosub REFRESH

Return
######################################################################################
$VOID_TXN

# TODAN-121018.sn: The pick ticket message apply to the 2-Sales order entry type
# and when the call come from GESSOH-Sales orders function
If VCRTYP = 2 & GFONCTION = "GESSOH"
  Call PICK_TICKET_EXISTS([M:SEU1]DVCRNUM, GERR, GMESSAGE)
  If GERR
    If GMESSAGE<>AVOID.ACHAR : Call ERREUR(GMESSAGE) From GESECRAN : Endif
    Goto OUT
  Endif
  fstat = 0   # Reset the variable to make sure it not affect other process after this one
Endif
#TODAN-121018.en

Call VOID([M:SEU1]DVCRTYP,[M:SEU1]DVCRNUM,[M:SEU1]VCRSEQ,0,GERR,GMESSAGE) From SEPPLIB
If GERR
  If GMESSAGE<>"" : Call ERREUR(GMESSAGE) From GESECRAN : Endif
Endif

OUT:  # TODAN-121018
Raz GERR,GMESSAGE
Gosub REFRESH

Return
######################################################################################
$FILL_CARD_FIELDS

[M:SEU1]PRCCOD     = [F:SEB]PRCCOD
[M:SEU1]CRDTYP     = [F:SEB]CRDTYP
[M:SEU1]VLTID      = [F:SEB]VLTID
[M:SEU1]VLTGUID    = [F:SEB]VLTGUID
[M:SEU1]VLTREQ     = [F:SEB]VLTREQ
[M:SEU1]ACCL4D     = [F:SEB]ACCL4D
[M:SEU1]EXPDAT     = [F:SEB]EXPDAT

[M:SEU1]ACCNAM     = [F:SEB]ACCNAM
[M:SEU1]FSTNAM     = [F:SEB]FSTNAM
[M:SEU1]LSTNAM     = [F:SEB]LSTNAM
[M:SEU1]USEBILLADR = [F:SEB]USEBILLADR

If [M:SEU1]USEBILLADR <> 2
  [M:SEU1]CRY       = [F:SEB]CRY
  [M:SEU1]ADDLIG(0) = [F:SEB]ADDLIG(0)
  [M:SEU1]ADDLIG(1) = [F:SEB]ADDLIG(1)
  [M:SEU1]SAT       = [F:SEB]SAT
  [M:SEU1]POSCOD    = [F:SEB]POSCOD
  [M:SEU1]CTY       = [F:SEB]CTY
Else
  Gosub GET_BILL_ADDR
Endif
[M:SEU1]EMAIL      = [F:SEB]EMAIL

[M:SEU1]ONETIME    = [F:SEB]ONETIME
If [M:SEU1]ONETIME=2 : Raz [M:SEU1]ACCNCKNAM : Endif

Affzo [M:SEU1]

Return
######################################################################################
$CLEAR_CARD_DETAILS

Effzo [M:SEU1]ACCL4D,EXPDAT,PYMTYP,CRDTYP,VLTREQ,VLTID,VLTGUID

Return
######################################################################################
$ACTIVATE_CARD_INFO

Actzo [M:SEU1]EMAIL,USEBILLADR,PRCCOD

If [F:SER]PAYPRC=1
  Actzo [M:SEU1]ACCNAM
  Diszo [M:SEU1]FSTNAM, LSTNAM
Else
  Diszo [M:SEU1]ACCNAM
  Actzo [M:SEU1]FSTNAM, LSTNAM
Endif

Return
######################################################################################
$DEACTIVATE_CARD_INFO

Diszo [M:SEU1]ACCNAM,FSTNAM,LSTNAM,EMAIL,USEBILLADR,PRCCOD

Return
######################################################################################
$ACTIVATE_ADDRESS

Actzo [M:SEU1]CRY,ADDLIG,POSCOD,CTY,SAT

Return
######################################################################################
$DEACTIVATE_ADDRESS

Diszo [M:SEU1]CRY,ADDLIG,POSCOD,CTY,SAT

Return
######################################################################################
$GET_DEF_PRCCOD

Filter [SER] Where FLDEF=2 and CPY=[M:SEU1]DOCCPY & CUR=[M:SEU1]CUR
Read [SER] First
If !fstat
  [M:SEU1]PRCCOD = [F:SER]PRCCOD
Else
  Raz [M:SEU1]PRCCOD
Endif
Filter [SER]

Call FMTNAM([M:SEU1]PRCCOD)

Return
######################################################################################
$GET_DEF_CARD

[M:SEU1] = [F:SEB]

If [F:SEB]USEBILLADR = 2
  Gosub GET_BILL_ADDR
Endif

Return
######################################################################################
$GET_BILL_ADDR

Filter [BPA] Where BPAADDFLG=2 & BPANUM=[M:SEU1]BPCNUM
Read [BPA] First
Filter [BPA]
If fstat | [F:BPC2]BPCTYP=2
  # If default not found or Misc customer, pull from doc billing address
  If clalev([M:ADB3])
    [M:SEU1] = [M:ADB3]
    [M:SEU1]ADDLIG(0)  = [M:ADB3]BPAADDLIG(0)
    [M:SEU1]ADDLIG(1)  = [M:ADB3]BPAADDLIG(1)
  Elsif clalev([M:PAY1])
    [M:SEU1]CRY        = [M:PAY1]CRY
    [M:SEU1]ADDLIG(0)  = [M:PAY1]BPAADDLIG(0)
    [M:SEU1]ADDLIG(1)  = [M:PAY1]BPAADDLIG(1)
    [M:SEU1]SAT        = [M:PAY1]SAT
    [M:SEU1]POSCOD     = [M:PAY1]POSCOD
    [M:SEU1]CTY        = [M:PAY1]CTY
  Endif
  If [M:SEU1]ADDLIG(0)<>""
    [M:SEU1]USEBILLADR = 1
    Actzo [M:SEU1]CRY,ADDLIG,SAT,POSCOD,CTY
    Return
  Endif
Endif

[M:SEU1]ADDLIG(0)  = [F:BPA]BPAADDLIG(0)
[M:SEU1]ADDLIG(1)  = [F:BPA]BPAADDLIG(1)
[M:SEU1]CTY        = [F:BPA]CTY
[M:SEU1]SAT        = [F:BPA]SAT
[M:SEU1]POSCOD     = [F:BPA]POSCOD
[M:SEU1]CRY        = [F:BPA]CRY
[M:SEU1]USEBILLADR = 2

Diszo [M:SEU1]CRY,ADDLIG,SAT,POSCOD,CTY

Return
######################################################################################
$GET_EMAIL_ADDRESS

# Get email address from Default Contact
Read [CNT]CNT0=1;[M:SEU1]BPCNUM;[F:BPC2]CNTNAM
If !fstat
  [M:SEU1]EMAIL = [F:CNT]WEB
Else
  Raz [M:SEU1]EMAIL
Endif

Return
######################################################################################
Subprog AM_ONETIME(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
  Effzo [M:SEU1]ACCNCKNAM,MANAUT
  Diszo [M:SEU1]ACCNCKNAM,MANAUT
  Gosub CLEAR_CARD_DETAILS
  Actzo [M:SEU1]USEBILLADR,EMAIL,PRCCOD
  Call FMTNAM([M:SEU1]PRCCOD)
  GCREATE = 0
Else
  If GALLOW_MANAUTH
    Actzo [M:SEU1]MANAUT
  Endif
  Actzo [M:SEU1]ACCNCKNAM
Endif

End
######################################################################################
Subprog C_ACCNCKNAM(VALEUR)
Variable Char    VALEUR()
Read [SEB]SEB0=[M:SEU1]BPCNUM;VALEUR
If !fstat
  Raz GCREATE
  If [F:SEB]ONETIME=2
    GMESSAGE = mess(126,143,1)  # Cannot reuse a one time use card, unlikely to happen, invalid value
    mkstat = 2 : End
  Endif
  If [F:SEB]FLACT<>2
    GMESSAGE = mess(6,103,1)  # Inactive account
    mkstat = 2 : End
  Endif
  If [F:SEB]EXPDAT<date$
    GMESSAGE = mess(46,2092,1)  # Inactive account
    mkstat = 2 : End
  Endif
  Call GET_SER([F:SEB]PRCCOD) From SEPPLIB
  If !fstat : Call C_PRCCOD([F:SER]PRCCOD) : Endif
Endif

End
######################################################################################
Subprog AM_ACCNCKNAM(VALEUR)
Variable Char    VALEUR()
Read [SEB]SEB0=[M:SEU1]BPCNUM;VALEUR
If !fstat
  Gosub FILL_CARD_FIELDS
  Grizo [M:SEU1]PRCCOD
  Gosub DEACTIVATE_CARD_INFO
Else
  GCREATE=1
  Raz [F:SEB]
  [M:SEU1]FLDEF=1
  # Set default card flag based on if there is one set already or not
  Filter [SEB] Where BPCNUM=[M:SEU1]BPCNUM and FLACT=2 and ONETIME<>2 Order By FLDEF Desc
  For [SEB]
    Read [SER]SER0=[F:SEB]PRCCOD
    If !fstat and [F:SER]CPY=[M:SEU1]DOCCPY
      Break
    Endif
  Next
  Filter [SEB]
  If [F:SEB]FLDEF<>2 : [M:SEU1]FLDEF=2  : Endif

  Gosub GET_DEF_PRCCOD
  Actzo [M:SEU1]PRCCOD
  Affzo [M:SEU1]PRCCOD
  Gosub CLEAR_CARD_DETAILS
  Gosub ACTIVATE_CARD_INFO
  Call AM_USEBILLADR([M:SEU1]USEBILLADR)
Endif
[M:SEU1]RMNAMT = func GET_RMNAMT()
Affzo [M:SEU1]RMNAMT
End
######################################################################################
Subprog D_PRCCOD(VALEUR)
Variable Char    VALEUR()

III = 0
For [SER] Where FLACT=2
  III += 1
  If III >= 2
    Raz VALEUR
    Break
  Endif
  VALEUR = [F:SER]PRCCOD
Next

End
######################################################################################
Subprog AM_PRCCOD(VALEUR)
Variable Char    VALEUR()
[M:SEU1]RMNAMT = func GET_RMNAMT()
Affzo [M:SEU1]RMNAMT
Call FMTNAM(VALEUR)
End
######################################################################################
Subprog C_PRCCOD(VALEUR)
Variable Char    VALEUR()
If [F:SER]CPY<>[M:SEU1]DOCCPY
  GMESSAGE = mess(36,2092,1)
  mkstat = 2 : End
Endif
If [F:SER]CUR<>[M:SEU1]CUR | dim([F:PYH]BAN)>0 & [F:SER]BAN<>[F:PYH]BAN
  GMESSAGE = mess(47,2092,1)
  mkstat = 2 : End
Endif
End
######################################################################################
Subprog AV_PYMTYP(VALEUR)
Variable Char    VALEUR()
VALEUR = func AFNC.TEXTRA("ATABDIV","LNGDES","398",[M:SEU1]CRDTYP)
End
######################################################################################
Subprog AM_USEBILLADR(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
  Gosub GET_BILL_ADDR
  Gosub DEACTIVATE_ADDRESS
Else
  Gosub ACTIVATE_ADDRESS
Endif

End
######################################################################################
Subprog AM_MANAUT(VALEUR)
Variable Integer VALEUR

If VALEUR=2
  Actzo [M:SEU1]AUTAMT,AUTID,AUTDAT
  [M:SEU1]MANAUTUSR = GUSER
  [M:SEU1]MANAUT    = 2
  [M:SEU1]RMNAMT    = func GET_RMNAMT()
  [M:SEU1]AUTAMT    = [M:SEU1]RMNAMT
  [M:SEU1]AUTDAT    = date$
  [M:SEU1]ONETIME   = 2

  Effzo [M:SEU1]ACCNCKNAM
  Diszo [M:SEU1]ONETIME,ACCNCKNAM
  Actzo [M:SEU1]PRCCOD
  Gosub CLEAR_CARD_DETAILS

  GCREATE = 0
Else
  Raz   [M:SEU1]AUTAMT,AUTID,AUTDAT,MANAUTUSR,ONETIME
  Diszo [M:SEU1]AUTAMT,AUTID,AUTDAT,PRCCOD
  Actzo [M:SEU1]ONETIME,ACCNCKNAM
Endif
Affzo [M:SEU1]MANAUTUSR,AUTAMT,AUTDAT,RMNAMT,ONETIME
End

######################################################################################
Subprog AS_NBLIG

If GTXN="" : Gosub LOAD_LINE : Endif

If func TRTSEAUTH.DOCVOIDABLE()
  Enable GSTASPE(3)
Else
  Disable GSTASPE(3)
Endif

End
######################################################################################
Subprog CALL_SEAUTH(IVCRTYP,IVCRNUM)
Value Integer IVCRTYP
Value Char    IVCRNUM

Local Char SAVACT(GLONACT)
Local Char VALEUR(250),PARAM(250)(1..20)

SAVACT = GACTION

PARAM(1) = num$(IVCRTYP)
PARAM(2) = IVCRNUM

GACTION = "TRTSEAUTH"
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTSEAUTH","TRTSEAUTH",4,"XYTRTSEAUTH") From GTRAITE

GACTION = SAVACT

End
######################################################################################
Funprog DOCVOIDABLE()
End GTXN="" and [M:SEU1]VCRTYP=[M:SEU1]DVCRTYP and [M:SEU1]VCRNUM=[M:SEU1]DVCRNUM
&  and find([M:SEU1]STAFLG,2,3,8) and [M:SEU1]VCRTYP<>4
######################################################################################
Funprog GET_RMNAMT()
Local Decimal RMNAMT
If [M:SEU1]MANAUT=2
  RMNAMT = func SEPPLIB.GET_REMAIN_AMT_NMU([M:SEU1]DVCRTYP)
Else
  RMNAMT = func SEPPLIB.GET_REMAIN_AMT([M:SEU1]DVCRTYP)
Endif
RMNAMT = max(0,RMNAMT-[M:SEU1]DAUTAMT)
End RMNAMT

######################################################################################
Subprog FMTNAM(PRCCOD)
Value Char PRCCOD

If PRCCOD<>"" : Call GET_SER(PRCCOD) From SEPPLIB : Endif

If [F:SER]PAYPRC=2
  Effzo [M:SEU1]ACCNAM
  Diszo [M:SEU1]ACCNAM
  Actzo [M:SEU1]FSTNAM, LSTNAM
  Chgfmt [M:SEU1]EMAIL With "-K" # 111621.n - Hide email
Else
  Actzo [M:SEU1]ACCNAM
  Effzo [M:SEU1]FSTNAM, LSTNAM
  Diszo [M:SEU1]FSTNAM, LSTNAM
  Chgfmt [M:SEU1]EMAIL With "+K" # 111621.n - Show email
Endif

End

######################################################################################
Subprog C_FSTNAM(VALEUR)
Variable Char    VALEUR()
  # 111621.n - Verify name format
  If !func SEPPLIB.VALID_NAME(VALEUR)
    GMESSAGE = mess(112,123,1) : mkstat = 2 : End
  Endif
End

######################################################################################
Subprog C_LSTNAM(VALEUR)
Variable Char    VALEUR()
  # 111621.n - Verify name format
  If !func SEPPLIB.VALID_NAME(VALEUR)
    GMESSAGE = mess(112,123,1) : mkstat = 2 : End
  Endif
End


######################################################################################
# TODAN-121018
######################################################################################
Subprog PICK_TICKET_EXISTS(VCRNUM, ERR, ERRMSG)
Value    Char    VCRNUM
Variable Integer ERR
Variable Char    ERRMSG

  If clalev([F:PRE]) = 0 Local File STOPRED     [PRE]  : Endif # Pick ticket detail

  Filter [PRE] Where ORINUM = VCRNUM & PRHNUM <> AVOID.ACHAR
  Look [PRE] First
  Filter [PRE]
  If !fstat   # Yes, pick ticket has been created. Display message and get out.
    ERR = 1
    ERRMSG = mess(61,2092,1)
  Endif
  Close Local File [PRE]
End
######################################################################################

