#<AdxTL>@(#)4.0.0.0 $Revision$
Call OBJET ("TMD",GBIDC1,GBIDC2) From GOBJET
End

######################################################################
# SUBTMD : Gestion Table modes de livraison                          #
######################################################################

$ACTION
Case ACTION
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INICRE 
 When "ANNULE"      : Gosub ANNULE 
When default
Endcase
Return

######################################################################
$INICRE
#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:TMD1]DESAXX,"TABMODELIV","DESAXX",[M:TMD1]MDL,"") From ATEXTRA
Call MAJTEXTRA ([M:TMD1]SHOAXX,"TABMODELIV","SHOAXX",[M:TMD1]MDL,"") From ATEXTRA

#    SOS libellés
If dim([F:TMD]LANDESSHO)>0 
   [F:TMD]LANDESSHO=GLANGUE+"~"+[M:TMD1]DESAXX+"~"+[M:TMD1]SHOAXX 
Endif

Return

######################################################################
$ANNULE
Delete [AXX]Where CODFIC="TABMODELIV" & IDENT1=[F:TMD]MDL
Return

######################################################################


