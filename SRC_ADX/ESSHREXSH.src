#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase
Return

$OUVRE
If clalev([F:EXSH1])   = 0 : Local File EXPENSESHEA    [EXSH1]     : Endif
If clalev([F:HREXS])  = 0 : Local File HREXPENSES     [HREXS]     : Endif
Default File [F:EXSH1]
Return

$DEBUT
Local Integer STAT(1..10)

#Update header icon
#[M]WSTA3 = func ESS_FUNCTIONS.SET_ICON(3)
#[M]WSTADES3 = 3
#[M]WSTA4 = func ESS_FUNCTIONS.SET_ICON(4)
#[M]WSTADES4 = 4


STAT(1) = 1
#STAT(2) = 2
STAT(3) = 3
STAT(4) = 4
#STAT(5) = 5
STAT(6) = 6
STAT(7) = 7

Call POPULATE_MASK(STAT,PARAM(1)) From ESSHREXSR

Return

