##########################################################################
## Etiquettes écran CMPGAU
##########################################################################
Subprog C_DOSORG(VALEUR)
Variable Char    VALEUR()
If filinfo(filpath("FIL","GAUTACE","fde",VALEUR),0)<0
 GMESSAGE = VALEUR-":"-mess(137,105,1) : # Pas de pièce auto sur ce dossier
 mkstat = 2 : End
Endif
End

Subprog C_PCEORG(VALEUR)
Variable Char    VALEUR()
Local Integer N
Local Char TEXTRA(80)
VALEUR = toupper(VALEUR)
If [M]DOSORG=nomap
 Local File GAUTACE [GAU]
Else
 Local File =[M]DOSORG+".GAUTACE" [GAU]
Endif
If instr(1,VALEUR,"*") or instr(1,VALEUR,"?")
 N = 0
 For [GAU]GAU0 Where pat([F:GAU]COD,VALEUR)<>0
  N += 1
 Next
 If N=0
  GMESSAGE = mess(138,105,1)-VALEUR : # Pas de pièce répondant au modèle
  mkstat = 2 : End
 Endif
 DESORG = num$(N)-mess(64,125,1) : # Pièces automatiques
 Affzo DESORG
 Effzo PCEDES,DESDES
 Grizo PCEDES
Else
 Read [GAU]GAU0 = VALEUR
 If fstat
  GMESSAGE = VALEUR-":"-mess(131,105,1)-[M]DOSORG : # Pièce auto inexistante sur le dossier
  mkstat = 2 : End
 Endif
 Call LECTEXTRA(TEXTRA,"GAUTACE","DESTRA",[F:GAU]COD,"") From ATEXTRA
 [M]DESORG = TEXTRA
 Affzo DESORG
 Actzo PCEDES
Endif
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
If filinfo(filpath("FIL","GAUTACE","fde",VALEUR),0)<0
 GMESSAGE = VALEUR-":"-mess(137,105,1) : # Pas de pièce auto sur ce dossier
 mkstat = 2 : End
Endif
If instr(1,[M]PCEORG,"*") or instr(1,[M]PCEORG,"?")
 If VALEUR=[M]DOSORG
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_PCEDES(VALEUR)
Variable Char    VALEUR()
If instr(1,[M]PCEORG,"*") or instr(1,[M]PCEORG,"?")
 mkstat = 1 : End
Elsif VALEUR="" & [M]DOSORG<>[M]DOSDES
 VALEUR = [M]PCEORG
Endif
End

Subprog C_PCEDES(VALEUR)
Variable Char    VALEUR()
Local Char TEXTRA(80)
VALEUR = toupper(VALEUR)
If [M]DOSORG=[M]DOSDES & VALEUR=[M]PCEORG
 mkstat = 2 : End
Endif
If [M]DOSDES=nomap
 Local File GAUTACE [GAU]
Else
 Local File =[M]DOSDES+".GAUTACE" [GAU]
Endif
Read [GAU]GAU0 = VALEUR
If fstat
 GMESSAGE = VALEUR-":"-mess(131,105,1)-[M]DOSDES : # Pièce auto inexistante
 mkstat = 2 : End
Endif
Call LECTEXTRA(TEXTRA,"GAUTACE","DESTRA",[F:GAU]COD,"") From ATEXTRA
[M]DESDES = TEXTRA
Affzo DESDES
End

##########################################################################
## Action CMPGAUSEL
##########################################################################
$SEL_TABLE
Case TABLE
 When "CMPGAUSEL"    : Gosub SELGAU
Endcase
Return

$SELGAU
If PARAM(1)=nomap or PARAM(1)=""
 Local File GAUTACE [GAU]
Else
 Local File =PARAM(1)+".GAUTACE" [GAU]
Endif
Default File [GAU]
OBJET = "GAU"
Return

