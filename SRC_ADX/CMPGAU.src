#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CMPGAU","CMPGAU",3,"") From GTRAITE
End

###############################################################################
## CMPGAU Comparaison pièces automatiques
###############################################################################

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC

 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

###############################################################################
$INIT
Gosub DEFVAR
TMP = 1
Return

$DEFVAR
If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif

Local Integer DIFF , DIM0 , DIM1 , DIM2 , LIGNE
Local Integer I , J , K
Local Integer N1 , N2 , M1 , M2 , STA1 , STA2 , LIBEL , VARIA
Local Char    DOSORG(GLONADD) , DOSDES(GLONADD) , DOSSIER(GLONADD)
Local Char    PCEORG(GLONGAU) , PCEDES(GLONGAU) , PIECE(GLONGAU)
Local Char    VALEUR1(250) , VALEUR2(250) , ZONE(80) , TEXTE(120) , TEXTRA(80)
Local Char    FRM1(250) , FRM2(250)
# Issue 108342 - 2015-11-06 by MAE : ABRFIC passage de 3 à 8
#Local Char    TABLE(GLONATB) , ABR1(5) , ABR2(5)
Local Char    TABLE(GLONATB) , ABR1(GLONABR) , ABR2(GLONABR)
Local Char    SEP(80) , PFIX0(10) , PFIX1(10) , PFIX2(10) , PFIX3(10)
# Issue 108342 - 2015-11-06 by MAE : ABRFIC passage de 3 à 8
#Local Char    ABR01(5) , ABR02(5)
#Local Char    ABR11(5) , ABR12(5)
#Local Char    ABR21(5) , ABR22(5)
#Local Char    ABR31(5) , ABR32(5)
#Local Char    ABR41(5) , ABR42(5)
Local Char    ABR01(GLONABR) , ABR02(GLONABR)
# Issue 112784 - 2015-11-26 by MAE : GONABR à la place de GLONABR
Local Char    ABR11(GLONABR) , ABR12(GLONABR)
Local Char    ABR21(GLONABR) , ABR22(GLONABR)
Local Char    ABR31(GLONABR) , ABR32(GLONABR)
Local Char    ABR41(GLONABR) , ABR42(GLONABR)

PFIX0 = "***"
PFIX1 = "   >>"
PFIX2 = "   <<"
PFIX3 = "==="
SEP   = string$(80,"#")
Return

###############################################################################
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(mess(130,105,1)) From LECFIC : # Comparaison pièces auto
Endif
[L]DOSORG = [M]DOSORG
[L]DOSDES = [M]DOSDES
[L]PCEORG = [M]PCEORG
[L]PCEDES = [M]PCEDES
Gosub CMPGAU
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
TRA = 1
Return

$CMPGAU
If DOSORG=nomap or DOSORG=""
 Local File GAUTACE               [GAU1]
 Local File GAUTACED              [GAD1]
 Local File GAUTACEF              [GAG1]
 Local File GVARPARVAL            [GVV1]
Else
 Local File =DOSORG+".GAUTACE"    [GAU1]
 Local File =DOSORG+".GAUTACED"   [GAD1]
 Local File =DOSORG+".GAUTACEF"   [GAG1]
 Local File =DOSORG+".GVARPARVAL" [GVV1]
Endif
If DOSDES=nomap or DOSDES=""
 Local File GAUTACE               [GAU2]
 Local File GAUTACED              [GAD2]
 Local File GAUTACEF              [GAG2]
 Local File GVARPARVAL            [GVV2]
Else
 Local File =DOSDES+".GAUTACE"    [GAU2]
 Local File =DOSDES+".GAUTACED"   [GAD2]
 Local File =DOSDES+".GAUTACEF"   [GAG2]
 Local File =DOSDES+".GVARPARVAL" [GVV2]
Endif
If instr(1,PCEORG,"*") or instr(1,PCEORG,"?")
 For [GAU1]GAU0 Where pat([F:GAU1]COD,PCEORG)<>0
  Read [GAU2]GAU0 = [F:GAU1]COD
  If fstat
   PIECE = [F:GAU1]COD : DOSSIER = DOSDES : Gosub INEX
  Else
   Gosub COMPARE
  Endif
 Next
 For [GAU2]GAU0 Where pat([F:GAU2]COD,PCEORG)<>0
  Read [GAU1]GAU0 = [F:GAU2]COD
  If fstat
   PIECE = [F:GAU2]COD : DOSSIER = DOSORG : Gosub INEX
  Endif
 Next
Else
 Read [GAU1]GAU0 = PCEORG
 If !fstat
  Read [GAU2]GAU0 = PCEDES
  If !fstat
   Gosub COMPARE
  Else
   PIECE = PCEDES : DOSSIER = DOSDES : Gosub INEX
  Endif
 Else
  PIECE = PCEORG : DOSSIER = DOSORG : Gosub INEX
 Endif
Endif
Close Local File [GAU1] , [GAU2]
Close Local File [GAD1] , [GAD2]
Close Local File [GAG1] , [GAG2]
Close Local File [GVV1] , [GVV2]
Return

$COMPARE
If [F:GAU1]COD=[F:GAU2]COD
 Call LECTEXTRA(TEXTRA,"GAUTACE","DESTRA",[F:GAU1]COD,"") From ATEXTRA
 TEXTE   = mess(130,105,1)-[F:GAU1]COD-TEXTRA : # Comparaison pièces auto
 VALEUR1 = DOSORG
 VALEUR2 = DOSDES
Elsif DOSORG=DOSDES
 TEXTE   = mess(130,105,1)-DOSORG
 Call LECTEXTRA(TEXTRA,"GAUTACE","DESTRA",[F:GAU1]COD,"") From ATEXTRA
 VALEUR1 = [F:GAU1]COD-TEXTRA
 Call LECTEXTRA(TEXTRA,"GAUTACE","DESTRA",[F:GAU2]COD,"") From ATEXTRA
 VALEUR2 = [F:GAU2]COD-TEXTRA
Else
 TEXTE   = mess(130,105,1)
 Call LECTEXTRA(TEXTRA,"GAUTACE","DESTRA",[F:GAU1]COD,"") From ATEXTRA
 VALEUR1 = DOSORG+"/"+[F:GAU1]COD-TEXTRA
 Call LECTEXTRA(TEXTRA,"GAUTACE","DESTRA",[F:GAU2]COD,"") From ATEXTRA
 VALEUR2 = DOSDES+"/"+[F:GAU2]COD-TEXTRA
Endif
Call ECR_TRACE(SEP,0) From GESECRAN
Call ECR_TRACE(TEXTE,0) From GESECRAN
Call ECR_TRACE(PFIX1-VALEUR1,0) From GESECRAN
Call ECR_TRACE(PFIX2-VALEUR2,0) From GESECRAN

DIFF = 0
Raz ABR01,ABR02,ABR41,ABR42
If [F:GAU1]TBL<>""
 Read [ATB]CODFIC = [F:GAU1]TBL    : If !fstat : ABR01 = [F:ATB]ABRFIC : Endif
Endif
If [F:GAU2]TBL<>""
 Read [ATB]CODFIC = [F:GAU2]TBL    : If !fstat : ABR02 = [F:ATB]ABRFIC : Endif
Endif
If [F:GAU1]REITBL<>""
 Read [ATB]CODFIC = [F:GAU1]REITBL : If !fstat : ABR41 = [F:ATB]ABRFIC : Endif
Endif
If [F:GAU2]REITBL<>""
 Read [ATB]CODFIC = [F:GAU2]REITBL : If !fstat : ABR42 = [F:ATB]ABRFIC : Endif
Endif

LIGNE = 0
TABLE = "GAUTACE"  : ABR1 = "GAU1" : ABR2 = "GAU2"
Gosub COMPTAB
Gosub COMPLIG

TABLE = "GAUTACED" : ABR1 = "GAD1" : ABR2 = "GAD2"
N1 = 0
M1 = 0
For [GAD1]GAD0 Where COD=[F:GAU1]COD
 N1 += 1
 M1 = max(M1,[F:GAD1]LINNUM)
Next
N2 = 0
M2 = 0
For [GAD2]GAD0 Where COD=[F:GAU2]COD
 N2 += 1
 M2 = max(M2,[F:GAD2]LINNUM)
Next
If N1<>N2
 TEXTE   = mess(132,105,1) : # Nombre de lignes de pièces
 VALEUR1 = num$(N1)
 VALEUR2 = num$(N2)
 Gosub DIFFERENCE
Endif

For LIGNE=1 To max(M1,M2)
 Read [GAD1]GAD0 = [F:GAU1]COD;LIGNE
 STA1 = fstat
 Read [GAD2]GAD0 = [F:GAU2]COD;LIGNE
 STA2 = fstat
 If STA1=0 & STA2=0
  Raz ABR11,ABR21,ABR12,ABR22
  If [F:GAD1]LINTBL1<>""
   Read [ATB]CODFIC = [F:GAD1]LINTBL1 : If !fstat : ABR11 = [F:ATB]ABRFIC : Endif
  Endif
  If [F:GAD2]LINTBL1<>""
   Read [ATB]CODFIC = [F:GAD2]LINTBL1 : If !fstat : ABR12 = [F:ATB]ABRFIC : Endif
  Endif
  If [F:GAD1]LINTBL2<>""
   Read [ATB]CODFIC = [F:GAD1]LINTBL2 : If !fstat : ABR21 = [F:ATB]ABRFIC : Endif
  Endif
  If [F:GAD2]LINTBL2<>""
   Read [ATB]CODFIC = [F:GAD2]LINTBL2 : If !fstat : ABR22 = [F:ATB]ABRFIC : Endif
  Endif
  Gosub COMPTAB
  Gosub COMPLIG
 Elsif STA1=0
  TEXTE   = mess(136,105,1)-num$(LIGNE) : # Ligne
  Call LECTEXTRA(TEXTRA,"GAUTACED","DESTRA",[F:GAD1]COD,num$([F:GAD1]LINNUM)) From ATEXTRA
  VALEUR1 = '"'+TEXTRA+'"'
  VALEUR2 = "["+mess(139,105,1)+"]"     : # Ligne inexistante
  Gosub DIFFERENCE
 Elsif STA2=0
  TEXTE   = mess(136,105,1)-num$(LIGNE) : # Ligne
  VALEUR1 = "["+mess(139,105,1)+"]"     : # Ligne inexistante
  Call LECTEXTRA(TEXTRA,"GAUTACED","DESTRA",[F:GAD2]COD,num$([F:GAD2]LINNUM)) From ATEXTRA
  VALEUR2 = '"'+TEXTRA+'"'
  Gosub DIFFERENCE
 Endif
Next LIGNE

If !DIFF
 Call ECR_TRACE(PFIX3-mess(133,105,1),0) From GESECRAN : # Les 2 pièces sont identiques
Else
 Call ECR_TRACE(PFIX3-mess(140,105,1)-":"-num$(DIFF),0) From GESECRAN : # Nb de différences
Endif
Call ECR_TRACE(SEP,0) From GESECRAN
Return

$COMPTAB
For [ATZ]NUMLIG Where CODFIC=TABLE
 If !find([F:ATZ]CODZONE,
& "CREDAT","CRETIM","CREUSR","UPDDAT","UPDTIM","UPDUSR","EXPNUM",
& "COD","DES","DESSHO","ACTLEG","NBRLEG")
  DIM1 = evalue("dim([F:"+ABR1+"]"+[F:ATZ]CODZONE+")")
  DIM2 = evalue("dim([F:"+ABR2+"]"+[F:ATZ]CODZONE+")")
  DIM0 = min(DIM1-1,DIM2-1)
  For K=0 To DIM0
   VALEUR1 = vireblc(format$("KT:250X",num$(evalue("[F:"+ABR1+"]"+[F:ATZ]CODZONE+"("+num$(K)+")"))),2)
   VALEUR2 = vireblc(format$("KT:250X",num$(evalue("[F:"+ABR2+"]"+[F:ATZ]CODZONE+"("+num$(K)+")"))),2)
   Case [F:ATZ]CODZONE
    When "FORCND"
     Call SUBST(VALEUR1,"TB0",ABR01)
     Call SUBST(VALEUR2,"TB0",ABR02)
     If LIGNE>0
      Call SUBST(VALEUR1,"TB1",ABR11)
      Call SUBST(VALEUR2,"TB1",ABR12)
      Call SUBST(VALEUR1,"TB2",ABR21)
      Call SUBST(VALEUR2,"TB2",ABR22)
     Else
      Call SUBST(VALEUR1,"TB4",ABR41)
      Call SUBST(VALEUR2,"TB4",ABR42)
     Endif
    When "ACCCND","ACCKEY"
     Call SUBST(VALEUR1,"TB0",ABR01)
     Call SUBST(VALEUR2,"TB0",ABR02)
     Call SUBST(VALEUR1,"TB1",ABR11)
     Call SUBST(VALEUR2,"TB1",ABR12)
     Call SUBST(VALEUR1,"TB2",ABR21)
     Call SUBST(VALEUR2,"TB2",ABR22)
   Endcase
   If VALEUR1<>VALEUR2
    Read [ATY]CODTYP = [F:ATZ]CODTYP
    If !fstat & [F:ATY]TYPTYP=1
     LIBEL = [F:ATY]NOLIB
     If LIBEL=0 : LIBEL = [F:ATZ]NOLIB : Endif
     If val(VALEUR1)>0 & val(VALEUR1)<=len(mess(0,LIBEL,1))
      VALEUR1 -= "("+mess(val(VALEUR1),LIBEL,1)+")"
     Endif
     If val(VALEUR2)>0 & val(VALEUR2)<=len(mess(0,LIBEL,1))
      VALEUR2 -= "("+mess(val(VALEUR2),LIBEL,1)+")"
     Endif
    Endif
    Read [ATX]NUMERO = GLANGUE;[F:ATZ]NOCOURT
    If fstat : Raz [F:ATX] : Endif
    If DIM0>0
     ZONE  = [F:ATZ]CODZONE+"("+num$(K)+")"
     TEXTE = [F:ATX]TEXTE-num$(K+1)-"("+ZONE+")"
    Else
     ZONE  = [F:ATZ]CODZONE
     TEXTE = [F:ATX]TEXTE-"("+ZONE+")"
    Endif
    If LIGNE>0
     TEXTE = mess(136,105,1)-num$(LIGNE)-":"-TEXTE : # Ligne
    Endif
    Gosub DIFFERENCE
   Endif
  Next K
 Elsif [F:ATZ]CODZONE="ACTLEG"
  DIM1 = evalue("[F:"+ABR1+"]NBRLEG")
  DIM2 = evalue("[F:"+ABR2+"]NBRLEG")
  Local Integer CMP : CMP=0
  If DIM1<>DIM2
   CMP=1
  Else
   For K=0 To min(DIM1,DIM2)
    If evalue("[F:"+ABR1+"]ACTLEG("+num$(K)+")")<>evalue("[F:"+ABR2+"]ACTLEG("+num$(K)+")")
     CMP=1 : Break
    Endif
   Next
  Endif
  If CMP
   Raz VALEUR1,VALEUR2
   For K=0 To DIM1-1
    VALEUR1 += evalue("[F:"+ABR1+"]ACTLEG("+num$(K)+")")+" "
   Next
   For K=0 To DIM2-1
    VALEUR2 += evalue("[F:"+ABR2+"]ACTLEG("+num$(K)+")")+" "
   Next
   Read [ATX]NUMERO = GLANGUE;[F:ATZ]NOCOURT
   If fstat : Raz [F:ATX] : Endif
   ZONE  = [F:ATZ]CODZONE
   Case TABLE
    When "GAUTACE"
     TEXTE = mess(62,105,1)-"/"-[F:ATX]TEXTE-"("+ZONE+")" : # En-tête
    When "GAUTACED"
     TEXTE = mess(136,105,1)-num$(LIGNE)-"/"-[F:ATX]TEXTE-"("+ZONE+")" : # Ligne
   Endcase
   Gosub DIFFERENCE
  Endif
 Endif
Next
Return

$COMPLIG
For [GAG1]GAG0 Where COD=[F:GAU1]COD & LINNUM=LIGNE
 VARIA   = 1
 VALEUR1 = vireblc(format$("KT:250X",[F:GAG1]FORCLC),2)
 Call SUBST(VALEUR1,"TB0",ABR01)
 If LIGNE>0
  Call SUBST(VALEUR1,"TB1",ABR11)
  Call SUBST(VALEUR1,"TB2",ABR21)
 Else
  Call SUBST(VALEUR1,"TB4",ABR41)
 Endif
 Read [GAG2]GAG0 = [F:GAU2]COD;LIGNE;[F:GAG1]FLD
 If fstat
  VALEUR2 = "["+mess(134,105,1)+"]" : # Expression non définie
  VARIA   = 0
 Else
  VALEUR2 = vireblc(format$("KT:250X",[F:GAG2]FORCLC),2)
  Call SUBST(VALEUR2,"TB0",ABR02)
  If LIGNE>0
   Call SUBST(VALEUR2,"TB1",ABR12)
   Call SUBST(VALEUR2,"TB2",ABR22)
  Else
   Call SUBST(VALEUR2,"TB4",ABR42)
  Endif
 Endif
 If VALEUR1<>VALEUR2
  Call INTIT([F:GAG1]FLD,TEXTE)
  If LIGNE=0
   TEXTE = mess(135,105,1)-TEXTE : # Formule
  Else
   TEXTE = mess(136,105,1)-num$(LIGNE)-":"-mess(135,105,1)-TEXTE : # Ligne...Formule
  Endif
  Gosub DIFFERENCE
 Endif
 FRM1 = VALEUR1
 FRM2 = VALEUR2
 If VARIA & instr(1,FRM1,"V_") & instr(1,FRM2,"V_")
  For [GVV1]GVV0 Where COD=[F:GAU1]COD & LINNUM=LIGNE & FLD=[F:GAG1]FLD
   If instr(1,FRM1,"V_"+[F:GVV1]CODVAR) & instr(1,FRM2,"V_"+[F:GVV1]CODVAR)
    VALEUR1 = vireblc(format$("KT:250X",[F:GVV1]VALPAR),2)
    Read [GVV2]GVV0 = [F:GAU2]COD;LIGNE;[F:GAG1]FLD;[F:GVV1]CODVAR;[F:GVV1]CODPAR
    If fstat
     VALEUR2 = "["+mess(141,105,1)+"]" : # Paramètre non défini
    Else
     VALEUR2 = vireblc(format$("KT:250X",[F:GVV2]VALPAR),2)
    Endif
    If VALEUR1<>VALEUR2
     Call INTIT([F:GAG1]FLD,TEXTE)
     If LIGNE=0
      TEXTE = mess(135,105,1)-TEXTE : # Formule
     Else
      TEXTE = mess(136,105,1)-num$(LIGNE)-":"-mess(135,105,1)-TEXTE : # Ligne...Formule
     Endif
     TEXTE -= ":"-mess(142,105,1)-[F:GVV1]CODVAR-mess(143,105,1)-[F:GVV1]CODPAR : # Variable...Paramètre
     Gosub DIFFERENCE
    Endif
   Endif
  Next
  For [GVV2]GVV0 Where COD=[F:GAU2]COD & LINNUM=LIGNE & FLD=[F:GAG1]FLD
   If instr(1,FRM1,"V_"+[F:GVV2]CODVAR) & instr(1,FRM2,"V_"+[F:GVV2]CODVAR)
    Read [GVV1]GVV0 = [F:GAU1]COD;LIGNE;[F:GAG1]FLD;[F:GVV2]CODVAR;[F:GVV2]CODPAR
    If fstat
     VALEUR1 = "["+mess(141,105,1)+"]" : # Paramètre non défini
     VALEUR2 = vireblc(format$("KT:250X",[F:GVV2]VALPAR),2)
     Call INTIT([F:GAG1]FLD,TEXTE)
     If LIGNE=0
      TEXTE = mess(135,105,1)-TEXTE : # Formule
     Else
      TEXTE = mess(136,105,1)-num$(LIGNE)-":"-mess(135,105,1)-TEXTE : # Ligne...Formule
     Endif
     TEXTE -= ":"-mess(142,105,1)-[F:GVV2]CODVAR-mess(143,105,1)-[F:GVV2]CODPAR : # Variable...Paramètre
     Gosub DIFFERENCE
    Endif
   Endif
  Next
 Endif
Next
For [GAG2]GAG0 Where COD=[F:GAU2]COD & LINNUM=LIGNE
 Read [GAG1]GAG0 = [F:GAU1]COD;LIGNE;[F:GAG2]FLD
 If fstat
  VALEUR1 = "["+mess(134,105,1)+"]" : # Expression non définie
  VALEUR2 = vireblc(format$("KT:250X",[F:GAG2]FORCLC),2)
  Call SUBST(VALEUR2,"TB0",ABR02)
  If LIGNE>0
   Call SUBST(VALEUR2,"TB1",ABR12)
   Call SUBST(VALEUR2,"TB2",ABR22)
  Else
   Call SUBST(VALEUR2,"TB4",ABR42)
  Endif
  Call INTIT([F:GAG2]FLD,TEXTE)
  If LIGNE=0
   TEXTE = mess(135,105,1)-TEXTE : # Formule
  Else
   TEXTE = mess(136,105,1)-num$(LIGNE)-":"-mess(135,105,1)-TEXTE : # Ligne...Formule
  Endif
  Gosub DIFFERENCE
 Endif
Next
Return

$DIFFERENCE
Call ECR_TRACE(PFIX0-TEXTE,0) From GESECRAN
Call ECR_TRACE(PFIX1-VALEUR1,0) From GESECRAN
Call ECR_TRACE(PFIX2-VALEUR2,0) From GESECRAN
DIFF += 1
Return

$INEX
Call ECR_TRACE(SEP,0) From GESECRAN
Call ECR_TRACE(PFIX0-PIECE-":"-mess(131,105,1)-DOSSIER,0) From GESECRAN : # Pièce inexistante sur dossier
Call ECR_TRACE(SEP,0) From GESECRAN
Return

##########################################################################
Subprog INTIT(CHAMP,TEXTE)
Value    Char CHAMP
Variable Char TEXTE()
Local Char    INTIT(50) , RACINE(10)
Local Integer K
INTIT = ""
Case CHAMP

 When "CAT" : INTIT = mess(8,105,1)  : # Catégorie
 When "STA" : INTIT = mess(9,105,1)  : # Etat
 When "GTE" : INTIT = mess(10,105,1) : # Type de pièce
 When "NUM" : INTIT = mess(11,105,1) : # Numéro de pièce
 When "FCY" : INTIT = mess(12,105,1) : # Site
 When "JOU" : INTIT = mess(13,105,1) : # Journal
 When "DAT" : INTIT = mess(14,105,1) : # Date comptable
 When "ENT" : INTIT = mess(53,105,1) : # Date de saisie
 When "DUD" : INTIT = mess(15,105,1) : # Date d'échéance
 When "BAN" : INTIT = mess(99,105,1) : # Date de banque
 When "VAL" : INTIT = mess(54,105,1) : # Date de valeur
 When "RVS" : INTIT = mess(55,105,1) : # Date d'extourne
 When "VCR" : INTIT = mess(36,105,1) : # Libellé
 When "REF" : INTIT = mess(17,105,1) : # Référence pièce
 When "CUR" : INTIT = mess(18,105,1) : # Devise
 When "TCR" : INTIT = mess(21,105,1) : # Type de cours
 When "CIB" : INTIT = mess(60,105,1) : # Code interbancaire
 When "BVC" : INTIT = mess(22,105,1) : # Document d'origine
 When "BVD" : INTIT = mess(23,105,1) : # Date document
 When "DAS" : INTIT = mess(24,105,1) : # DAS2
 When "SIM" : INTIT = mess(25,105,1) : # Référence simulation
 When "COR" : INTIT = mess(26,105,1) : # Devise d'origine
 When "PAZ" : INTIT = mess(57,105,1) : # Bon à payer
 When "FUP" : INTIT = mess(56,105,1) : # Relance
 When "DIA" : INTIT = mess(102,105,1): # Schéma de saisie

 When "STR"    : INTIT = mess(27,105,1)  : # Valeur début
 When "END"    : INTIT = mess(28,105,1)  : # Valeur fin
 When "FCY"    : INTIT = mess(29,105,1)  : # Site
 When "ACC"    : INTIT = mess(30,105,1)  : # Compte
 When "BPR"    : INTIT = mess(31,105,1)  : # Tiers
 When "AMT"    : INTIT = mess(32,105,1)  : # Montant
 When "QTY"    : INTIT = mess(33,105,1)  : # Quantité
 When "UNT"    : INTIT = mess(34,105,1)  : # Unité
 When "SNS"    : INTIT = mess(35,105,1)  : # Sens
 When "DES"    : INTIT = mess(36,105,1)  : # Libellé
 When "DSP"    : INTIT = mess(38,105,1)  : # Répartition
 When "TAX"    : INTIT = mess(39,105,1)  : # Taxe
 When "AMTA"   : INTIT = mess(40,105,1)  : # Montant analytique
 When "QTYA"   : INTIT = mess(41,105,1)  : # Quantité analytique
 When "ST1"    : INTIT = mess(42,105,1)  : # Code stat 1
 When "ST2"    : INTIT = mess(43,105,1)  : # Code stat 2
 When "ST3"    : INTIT = mess(44,105,1)  : # Code stat 3
 When "LIB"    : INTIT = mess(106,105,1) : # Critère de détail libre
 When "IDL"    : INTIT = mess(173,105,1) : # Identifiant ligne
 When "FREREF" : INTIT = mess(152,105,1) : # Référence Libre
Endcase

For RACINE="MLT","DIV","ACC","AMTL","OFF","DIE","CCE"
 If left$(CHAMP,len(RACINE))=RACINE
  K = val(right$(CHAMP,len(RACINE)+1))
  Case RACINE
   When "MLT"
    INTIT = mess(168,105,1)-mess(K,2644,1) : # Cours multiplicateur/type référentiel
   When "DIV"
    INTIT = mess(169,105,1)-mess(K,2644,1) : # Cours diviseur/type référentiel
   When "ACC"
    INTIT = mess(30,105,1)-mess(K,2644,1) : # Compte référentiel
   When "OFF"
    INTIT = mess(61,105,1)-mess(K,2644,1)  : # Contrepartie mess(TYPREF,2644,1)
   When "AMTL"
    INTIT = mess(174,105,1)-mess(K,2644,1): # Montant référentiel
   When "DIE"
    INTIT = mess(170,105,1)-num$(K) : # Axe
   When "CCE"
    INTIT = mess(48,105,1)-num$(K) : # Section
  Endcase
 Endif
Next RACINE

If INTIT=""
 Read [AMZ]CODE = "GACCENTR1";CHAMP
 If !fstat
  Read [ATX]NUMERO = GLANGUE;[F:AMZ]INTIT
  If !fstat
   INTIT = [F:ATX]TEXTE
  Endif
 Endif
Endif
If INTIT<>""
 TEXTE = INTIT-"("+CHAMP+")"
Else
 TEXTE = CHAMP
Endif
End

# Issue X3-122423 - 2017-04-17 by VAVIL
Subprog SUBST(CHAINE,AB1,AB2)
Variable Char CHAINE
Value    Char AB1
Value    Char AB2
If AB2<>""
  Local Integer K
  Local Char    SEP(1)
  Repeat
  SEP = ":"
  K = instr(1,CHAINE,SEP+AB1+"]")
  If !K
    SEP = "["
    K = instr(1,CHAINE,SEP+AB1+"]")
  Endif
  If K
    CHAINE = left$(CHAINE,K-1)+SEP+AB2+"]"+right$(CHAINE,K+len(AB1)+2)
  Endif
  Until K=0
Endif
End

