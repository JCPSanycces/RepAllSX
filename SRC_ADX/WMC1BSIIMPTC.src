####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : BSICODTC Bank type code ( Field BSITCF 10)
####################################################################

$SET_BSICODTC
If [L]_AOLDVAL<>this.BSICODTC
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_BSICODTC
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.BSICODTC
 Gosub PROPAGATE_BSICODTC
Endif
Return

$INIT_BSICODTC
Gosub DECLARE_VAR From WMC0BSIIMPTC
[L]CURPRO = "BSICODTC"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_BSICODTC
Gosub DECLARE_VAR From WMC0BSIIMPTC
[L]CURPRO = "BSICODTC"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_BSICODTC              : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_BSICODTC              : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_BSICODTC
[L]CURPRO = "BSICODTC"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.BSICODTC,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_BSICODTC
[L]CURPRO = "BSICODTC"
If vireblc(this.BSICODTC,2)<>vireblc(format$("K:10c",this.BSICODTC),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_BSICODTC
[L]CURPRO = "BSICODTC"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_BSICODTC
[L]CURPRO = "BSICODTC"
Return

$PROPAGATE_BSICODTC
this.isReadonly = 0
[L]CURPRO = "BSICODTC"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_BSICODTC
Gosub DECLARE_VAR From WMC0BSIIMPTC
[L]CURPRO = "BSICODTC"
$_LNKPRO_BSICODTC
Return

$_ALOADATTRIBUTE_BSICODTC
[L]ASTATUS = fmet this.ASETATTRIBUTE("BSICODTC","$isMandatory","true")
Return


