#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################
# Sous-Pro pour les procédures de migration
############################################
# TRTMIGDEL  Suppression des tables ayant code activité MIG
#            Desactivitation du code activité MIG
########################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif     ##YYFIN_107921_AdaptationN°1

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("TRTMIGDEL") From LECFIC
  Endif

  Call TRTMIGDEL(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

############################################################################
Subprog TRTMIGDEL(PDOSSIER)
Value Char PDOSSIER

Local Integer COMPTEUR : COMPTEUR=0
Local Integer ERR

GOK=1
Call ECR_TIME("TRTMIGDEL : Process Start on : "+PDOSSIER) From DOSSUB
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]PDOSSIER)=0 : End : Endif

Local Char WCLIGNE (250)
Local File =PDOSSIER+".ATABLE"  [ATB2]
Local File =PDOSSIER+".ATABLE"  [ATB3]
Local File =PDOSSIER+".ATABZON" [ATZ2]
Local File =PDOSSIER+".ATABIND" [ATI2]
If clalev([F:AMY])=0 : Local File AMIGKEY [AMY] : Endif

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE("====================================================",0) From GESECRAN
Filter [ATB2]
For [ATB2] Where CODACT="MIG"
    WCLIGNE="-"-[F:ATB2]CODFIC+"("+[F:ATB2]ABRFIC+")"
    Call ECR_TRACE(WCLIGNE,0) From GESECRAN

    #1: on fait un truncate de la table
    Call MIGTABRAZ (PDOSSIER,[F:ATB2]CODFIC,ERR) From TRTMIG
    If GOK<1 : Break : Endif
    #2: on supprime la table en base + fichier fde,srf....
    Call ANNULE(PDOSSIER,[F:ATB2]CODFIC,GOK) From DOSTAB
    If GOK<1 : Break : Endif
    #3: on supprime les dico
    Gosub TR2
    If GOK<1 : Break : Endif
    Call ECR_TRACE("  Table deleted",0) From GESECRAN
    COMPTEUR+=1
Next
If GOK<1 : Goto FIN : Endif
#-------
Call ECR_TRACE("====================================================",0) From GESECRAN
Call MAJ_ACVMIG(PDOSSIER,1) From TRTMIG
If GOK<1 : Goto FIN : Endif

Call ECR_TRACE("====================================================",0) From GESECRAN
WCLIGNE="- AMIGKEY("+PDOSSIER+")"
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
Trbegin [AMY]
Delete [AMY] Where DOSSIER=PDOSSIER
If fstat  : GOK=-1 : Call RSTA("AMY",PDOSSIER) From GLOCK : Goto FIN : Endif
Commit

$FIN
Call ECR_TRACE("TRTMIGDEL : "+num$(COMPTEUR)+" tables deleted.",0) From GESECRAN
Call ECR_TIME("TRTMIGDEL : END.")  From DOSSUB
End



########################################################################################
#suppression des dico
########################################################################################
$TR2
Trbegin [ATZ2]
Delete [ATZ2] Where CODFIC=[F:ATB2]CODFIC
If fstat  : GOK=-1 : Call RSTA("ATZ",[F:ATB2]CODFIC) From GLOCK : Return : Endif
Commit

Trbegin [ATI2]
Delete [ATI2] Where CODFIC=[F:ATB2]CODFIC
If fstat  : GOK=-1 : Call RSTA("ATI",[F:ATB2]CODFIC) From GLOCK : Return : Endif
Commit

Trbegin [ATB3]
Delete [ATB3] Where CODFIC=[F:ATB2]CODFIC
If fstat  : GOK=-1 : Call RSTA("ATB",[F:ATB2]CODFIC) From GLOCK : Return : Endif
Commit

Return

