#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Get the error's message from POBJ class error stack (from the max level)
#*
#* @param  POBJ
#* @return WMSG (maximum level) message
#*!
Funprog MAXMSG(POBJ)
Variable Instance POBJ Using OBJECT
#Variable Instance POBJCH Using OBJECT     #child class

  Local Integer LIN, MAXERR , LIN2
  Local Char WMSG(250)

  [L]MAXERR = 0
  WMSG = AVOID.ACHAR
  For [L]LIN = 1 To maxtab(POBJ.AERROR)
    If (POBJ.AERROR([L]LIN) <> null and POBJ.AERROR([L]LIN).DEL <> [V]CST_AYES) #CCL
      If POBJ.AERROR([L]LIN).STA > [L]MAXERR
            [L]MAXERR = POBJ.AERROR([L]LIN).STA
            If POBJ.AERROR([L]LIN).PRO = AVOID.ACHAR
              WMSG = POBJ.AERROR([L]LIN).MES
            Else
              WMSG = POBJ.AERROR([L]LIN).PRO - POBJ.AERROR([L]LIN).MES
            Endif
          Endif
        Endif
      Next
End WMSG


#**
#* Write error stack of an object into Classic log
#*
#* @param POBJ   : object instance
#* @param PLEVEL : (deprecated)
#*!
Subprog WRITE_ERROR_STACK_CLASSIC(POBJ, PLEVEL)
Value Instance POBJ  Using OBJECT
Value Integer  PLEVEL

  Local Integer N_I
  Local Char PRO(250)

  For [L]N_I = 1 To maxtab(POBJ.AERROR)
    If POBJ.AERROR(N_I) <> null
      PRO = POBJ.AERROR([L]N_I).PRO
      If PRO <> AVOID.ACHAR
        PRO += " : "
      Endif
      Call ECR_TRACE("-> " - PRO - POBJ.AERROR([L]N_I).MES -
&                    "(" + num$(POBJ.AERROR([L]N_I).NUM) + "/" + num$(POBJ.AERROR([L]N_I).STA) + ")",
&                    func LCCLIB.GET_CLASSICERRLEVEL(POBJ.AERROR([L]N_I).STA)) From GESECRAN
    Endif
  Next N_I
End

#**
#* Get the classic code trace belong the stak error status
#*
#* @param  PSTA Stack error status
#* @return RET  Classic level code
#*!
Funprog GET_CLASSICERRLEVEL(PSTA)
Value Integer PSTA

  Local Integer RET

  # ----------------------------------------------------
  #   Stack error status | Trace status
  # ----------------------------------------------------
  #   CST_ASUCCESS       |  0  (info)
  #   CST_AINFO          |  0  (info)
  #   CST_AWARNING       | -1  (warning)
  #   CST_AERROR         |  1  (error)
  #   CST_AFATAL         |  1  (error)
  # ----------------------------------------------------
  Case PSTA
    When [V]CST_AINFO:
      RET = 0
    When [V]CST_ASUCCESS:
      RET = 0
    When [V]CST_AWARNING:
      RET = -1
    When [V]CST_AERROR:
      RET = 1
    When [V]CST_AFATAL:
      RET = 1
    When Default:
      RET = 0
  Endcase

End RET

