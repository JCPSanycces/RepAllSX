# Superviseur
# Gestion du masque PAYSTA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CSHVATRGM
mkstat = 0
zoncou = "CSHVATRGM"
indice = 0
IMPENT = [M]CSHVATRGM
If varinit([M]CSHVATRGM,indice)=0
 IMPENT = 1
Endif
[M]CSHVATRGM = IMPENT

## Zone VATSTA
mkstat = 0
zoncou = "VATSTA"
indice = 0
IMPENT = [M]VATSTA
If varinit([M]VATSTA,indice)=0
 IMPENT = 1
Endif
[M]VATSTA = IMPENT

## Zone PAYMENTSTA
mkstat = 0
zoncou = "PAYMENTSTA"
indice = 0
IMPENT = [M]PAYMENTSTA
If varinit([M]PAYMENTSTA,indice)=0
 IMPENT = 1
Endif
[M]PAYMENTSTA = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PAYSTA"
Return

