#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIACH38 : Utilitaire de rectification des EO           Module Achats  #
##########################################################################
# Issue 101293 GA 09/2014 Subcontract BOM with base qty < 1
##########################################################################

Call MAJ_UTIACH38
End

##################################
Subprog MAJ_UTIACH38
Local Char DOSSIER(30) : DOSSIER=nomap
#Call SAIDOS(DOSSIER,"") From SAIDOS
If [L]DOSSIER<>""
   If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

   Call EXE_UTIACH38([L]DOSSIER)
Endif
End

##################################
Subprog EXE_UTIACH38(DOSSIER)
Value Char DOSSIER

Local Integer LRET

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIACH38 : Subcontrat order with component qty errors BASQTY<1") From LECFIC
Call ECR_TRACE("UTIACH38 : start folder"-DOSSIER,0) From GESECRAN

# Traitement des EO
If GMODU(6)=2 : # Module Achat actif
  Gosub TRT_BOMS
Endif


$FIN_UTIACH38
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End


##################################
$TRT_BOMS

Local File =DOSSIER+".SCOHEAD"    [SCO]
Local File =DOSSIER+".SCOITM"     [SCI]
Local File =DOSSIER+".SCOMAT"     [SCM]
Local File =DOSSIER+".SCOSRV"     [SCS]

Local File =DOSSIER+".BOM"        [BOH]
Local File =DOSSIER+".BOMD"       [BOD]

Local Char     WSCONUM(GLONVCR),WBPRNUM(GLONBPR)
Local Integer  WSIMFLG, IPOQ,IERR
Local Shortint STAT : STAT=0

WSIMFLG=2
If !GBATCH
   Call OUINON(mess(6,115,1)-"?"-nomap,WSIMFLG) From GESECRAN
Endif

Call ECR_TRACE(" ",0) From GESECRAN
If WSIMFLG=2
   Call ECR_TRACE("Analysis subcontract BOM versus EO"-mess(6,115,1),0) From GESECRAN
Else
   Call ECR_TRACE("Analysis subcontract BOM versus EO",0) From GESECRAN
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(" ",0) From GESECRAN

Trbegin [SCM]
Filter [F:BOH] Where BOMALTTYP=3 & BASQTY<1
For [BOH]
   For [F:SCI] Where ITMREF=[F:BOH]ITMREF & BOMALT=[F:BOH]BOMALT
    If [F:SCI]SCITRKFLG <= 3  # on ne met pas à jour les EO >= En cours
       For [F:SCM] Where SCONUM=[F:SCI]SCONUM
           Gosub UPDATE_SCM
       Next
     Endif
   Next
Next

Filter [F:BOH]
If WSIMFLG=2
   Rollback
   Call ECR_TRACE("Mode simulation: Rollback !!!",0) From GESECRAN
Else
   Commit
Endif

$FIN_UTIACH38_BOMS
Close Local File [SCO]
Close Local File [SCI]
Close Local File [SCM]
Close Local File [SCS]

Close Local File [BOH]
Close Local File [BOD]

Return

$UPDATE_SCM
Local Decimal WRETQTY,WALLQTY,WSHTQTY

If [F:SCM]BASQTY=0 | [F:SCM]BASQTY<>[F:BOH]BASQTY
   WRETQTY=[F:SCM]RETQTY
   WALLQTY=[F:SCM]ALLQTY
   WSHTQTY=[F:SCM]SHTQTY
   [F:SCM]BASQTY=[F:BOH]BASQTY
   Call UPD_MAT_QTY([F:SCI]EXTQTY,-1) From SCOLIB
   If [F:SCM]SCOFLG=2 & [F:SCM]ALLSTA<>1 & [F:SCM]ALLQTY+[F:SCM]SHTQTY<>[F:SCM]RETQTY
      Call ECR_TRACE("Check allocation for EO component:"-[F:SCM]SCONUM-[F:SCM]CPNITMREF,-1) From GESECRAN
   Endif
   If [F:SCM]NETPRI=0 & [F:SCM]SCOFLG=3
      Gosub INIT_TARIF From SCOAUTLIB
      Call UPD_MAT_PRI(-1) From SCOLIB
   Else
      Gosub CALC_LINAMT_SCM  From SCOLIB
   Endif
   Rewrite [F:SCM]
   Call ECR_TRACE([F:SCM]SCONUM-[F:SCM]CPNITMREF-"Component qty modified from"-num$(WRETQTY)-"To"-num$([F:SCM]RETQTY),0) From GESECRAN
Endif
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
############## uniquement si nécessaire de maj les données
############## Call EXE_UTIACH38(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
############## uniquement si nécessaire de maj les données
############## Call EXE_UTIACH38(APPLI)
End

#######################################################################
