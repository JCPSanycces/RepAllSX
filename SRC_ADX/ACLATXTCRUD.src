#<AdxTL>@(#)0.0.0.0 $Revision$
#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$ADDCLB0
Append CLOB,LIGNE+chr$(10)
Return

#-------------------------------------------------------#
#  TRT gestion ATEXTE et ATEXTRA
#-------------------------------------------------------#
Subprog TRT_TEXTE(ACLA,NIVEAU,PROGRAM,WCLASSE,ISFOR,NBFOR,LIGNE,CLOB,DIF)
Variable Instance ACLA Using C_ACLA
Value Integer NIVEAU
Value Char PROGRAM
Value Char WCLASSE
Value Integer ISFOR
Value Integer NBFOR
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
For I=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
 If find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I).CODTYP,"AX3","AX2","AX1","AXX")<>0 & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I).FLDGRP=""
  Call ATEXTRA_PROG(0,WCLASSE,PROGRAM,NIVEAU,ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I),ISFOR,NBFOR,ACLA.ACLAK(NIVEAU).ACLALNK,LIGNE,CLOB,DIF)
 Elsif find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I).CODTYP,"ATX")<>0 & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I).FLDGRP=""
  Call ATEXTE_PROG(ACLA.ACLAK(NIVEAU).ABRLNK,0,WCLASSE,PROGRAM,NIVEAU,ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I),ISFOR,NBFOR,LIGNE,CLOB,DIF)
 Endif
Next
End

#-------------------------------------------------------#
#  TRT gestion ATEXTE et ATEXTRA pour collections
#-------------------------------------------------------#
Subprog TRT_TEXTECOL(COLLECTION,ACLA,NIVEAU,PROGRAM,WCLASSE,ISFOR,NBFOR,LIGNE,CLOB,DIF)
Value Char COLLECTION
Variable Instance ACLA Using C_ACLA
Value Integer NIVEAU
Value Char PROGRAM
Value Char WCLASSE
Value Integer ISFOR
Value Integer NBFOR
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
For I=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
 If find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I).CODTYP,"AX3","AX2","AX1","AXX")<>0 & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I).FLDGRP=COLLECTION
  Call ATEXTRA_PROG(0,WCLASSE,PROGRAM,NIVEAU,ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I),ISFOR,NBFOR,ACLA.ACLAK(NIVEAU).ACLALNK,LIGNE,CLOB,DIF)
 Elsif find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I).CODTYP,"ATX")<>0 & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I).FLDGRP=COLLECTION
  Call ATEXTE_PROG(ACLA.ACLAK(NIVEAU).ABRLNK,0,WCLASSE,PROGRAM,NIVEAU,ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I),ISFOR,NBFOR,LIGNE,CLOB,DIF)
 Endif
Next
End

#-------------------------------------------------------#
#  TRT ATEXTRA
#-------------------------------------------------------#
$ATEXTRA
For I=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
 If find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I).CODTYP,"AX3","AX2","AX1","AXX")<>0 & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I).FLDGRP=""
  Call ATEXTRA_PROG(NIVPARCOURS,ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM,NIVEAU,ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I),ISFOR,NBFOR,ACLA.ACLAK(NIVEAU).ACLALNK,LIGNE,CLOB,DIF)
 Endif
Next
Return

Subprog ATEXTRA_PROG(NIVPARCOURS,WCLASSE,PROGRAM,NIVEAU,ACLAF,ISFOR,NBFOR,ACLALNK,LIGNE,CLOB,DIF)
Value Integer NIVPARCOURS
Value Char WCLASSE
Value Char PROGRAM
Value Integer NIVEAU
Variable Instance  ACLAF Using C_ACLAFLD
Value Integer ISFOR
Value Integer NBFOR
Variable Instance  ACLALNK Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Char      WCLE1(250),WCLE2(250),WCHAMP(250),WTABLE(250),WLANGUE(80)
Local Integer I,J,G,T

For J=1 To maxtab(ACLAF.ATBKEY)
 Case ACLAF.ATBKEY(J).CODPAR
  When "CODFIC" : WTABLE  = ACLAF.ATBKEY(J).VALEUR
  When "ZONE"   : WCHAMP  = ACLAF.ATBKEY(J).VALEUR
  When "IDENT1" : WCLE1   = ACLAF.ATBKEY(J).VALEUR : Call EVAL_CLE(ACLAF.CODCLA,ACLAF.FLDGRP,WCLASSE,ACLALNK,WCLE1)
  When "IDENT2" : WCLE2   = ACLAF.ATBKEY(J).VALEUR : Call EVAL_CLE(ACLAF.CODCLA,ACLAF.FLDGRP,WCLASSE,ACLALNK,WCLE2)
 Endcase
Next
If ACLALNK.ObjectType<>"C_ACLA" : WCLASSE = ACLALNK.CODREP : Endif
If WCHAMP<>"" & WTABLE<>""
 If PROGRAM =[V]CST_APRGAREAD
  LIGNE = 'For [AXX] Where CODFIC='+WTABLE+' & ZONE='+WCHAMP+' & IDENT1='+WCLE1+' & IDENT2='+WCLE2  : Gosub ADDCLB
  DIF += 1
  NBFOR =+1
  ISFOR =1
  LIGNE = 'Call ASETTEXTRA('+WCLASSE+'.AXX,'+WCLASSE+'.AllocGrp(),"'+ACLAF.FLDCLA+'",[F:AXX]TEXTE,[F:AXX]LANGUE) From ASYRSUB' : Gosub ADDCLB
  LIGNE = WCLASSE+".AXX(maxtab("+WCLASSE+".AXX)).FLG = 0" : Gosub ADDCLB
  DIF -=1 : LIGNE = "Next AXX"  : Gosub ADDCLB
  #{SAM 118887
  LIGNE = 'If !len(fmet '+WCLASSE+'.AGETTEXTRA("'+ACLAF.FLDCLA+'"))'  : Gosub ADDCLB
  DIF += 1
  LIGNE = 'Call ASETTEXTRA('+WCLASSE+'.AXX,'+WCLASSE+'.AllocGrp(),"'+ACLAF.FLDCLA+'",' : Gosub ADDCLB
  LIGNE ='& fmet '+WCLASSE+'.AGETTEXTRALAN("'+ACLAF.FLDCLA+'",'+WCLASSE+'.ACTX.AFOLD.ALANGDEF),': Gosub ADDCLB0
  LIGNE ='& '+WCLASSE+'.ACTX.LAN) From ASYRSUB': Gosub ADDCLB0
  DIF -=1 : LIGNE = "Endif"  : Gosub ADDCLB
  #SAM 118887}
 Else
  LIGNE = "For J=1 To maxtab("+WCLASSE+".AXX)"  : Gosub ADDCLB
  DIF +=1
  NBFOR +=1
  ISFOR =1
  LIGNE = 'If'-WCLASSE+'.AXX(J)<>null & '-WCLASSE+'.AXX(J).PRO= "'+ACLAF.FLDCLA+'"'
  If PROGRAM<>[V]CST_APRGADELETE : LIGNE += " &"-WCLASSE+'.AXX(J).FLG>0' : Endif
  Gosub ADDCLB
  DIF += 1
  LIGNE = 'Call '
  If find(PROGRAM,[V]CST_APRGAUPDATE,[V]CST_APRGAINSERT)>0
   LIGNE +='MAJTEXTRALAN'
  Elsif PROGRAM= [V]CST_APRGADELETE
   LIGNE +='SUPTEXTRA'
  Endif
  If len(WTABLE+WCHAMP+WCLASSE+'.'+'AXX(I).LAN'+WCLE1+WCLE2+'[L]ASTATUS) From ASYRSUB'+'MAJTEXTRALAN'+'Call ')+20>=250
   LIGNE += '('+WCLASSE+','+WCLASSE+'.AXX(I).TEX'
   Gosub ADDCLB
   LIGNE = '&        '+','+WTABLE : Gosub ADDCLB0
   LIGNE = '&        '+','+WCHAMP : Gosub ADDCLB0
   LIGNE = '&        '+','+WCLASSE+'.'+'AXX(I).LAN' : Gosub ADDCLB0
   LIGNE = '&        '+','+WCLE1 : Gosub ADDCLB0
   LIGNE = '&        '+','+WCLE2 : Gosub ADDCLB0
   LIGNE = '&        '+','+'[L]ASTATUS) From ASYRSUB' : Gosub ADDCLB0
   LIGNE = ""
  Else
   LIGNE += '('+WCLASSE+','+WCLASSE+'.AXX(J).TEX,'+WTABLE+','+WCHAMP+','+WCLASSE+'.'+'AXX(J).LAN'+','+WCLE1+','+WCLE2+',[L]ASTATUS) From ASYRSUB' :
  Endif
  If LIGNE<>"" : Gosub ADDCLB : Endif
  LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : Break'-string$(NBFOR>1,num$(NBFOR))+" : Endif" : Gosub ADDCLB
  LIGNE = "'"
  DIF -=1
  LIGNE = "Endif"  : Gosub ADDCLB
  DIF -= 1
  LIGNE = "Next J"  : Gosub ADDCLB
  NBFOR -= 1
  If ACLAF.DIME>1
   LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : Break'-string$(NBFOR>1,num$(NBFOR))+" : Endif" : Gosub ADDCLB
  Else
   LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif' : Gosub ADDCLB
  Endif
 Endif
Endif
End

#-------------------------------------------------------#
#  TRT gestion ATEXTE
#-------------------------------------------------------#
$ATEXTE
For I=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
 If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I).FLDGRP=""
  Call ATEXTE_PROG(ACLA.ACLAK(NIVEAU).ABRLNK,NIVPARCOURS,ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM,NIVEAU,ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(I),ISFOR,NBFOR,LIGNE,CLOB,DIF)
 Endif
Next
Return

Subprog ATEXTE_PROG(ABRLNK,NIVPARCOURS,WCLASSE,PROGRAM,NIVEAU,ACLAF,ISFOR,NBFOR,LIGNE,CLOB,DIF)
Value Char ABRLNK
Value Integer NIVPARCOURS
Value Char WCLASSE
Value Char PROGRAM
Value Integer NIVEAU
Variable Instance  ACLAF Using C_ACLAFLD
Value Integer ISFOR
Value Integer NBFOR
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

 If find(ACLAF.CODTYP,"ATX")<>0
  If ACLAF.DIME>1
   LIGNE = "indice = [L]A_I" : Gosub ADDCLB
  Endif
  If PROGRAM = [V]CST_APRGAREAD : # Read
   LIGNE = 'For [ATX] Where NUMERO=[F:'+ABRLNK+"]"+ACLAF.FLDCLA
   If ACLAF.DIME>1
    LIGNE += '([L]A_I)'
   Endif
   Gosub ADDCLB
   DIF += 1
   LIGNE = 'Call ASETTEXT('+WCLASSE+'.ATX,'+WCLASSE+'.AllocGrp,"'+ACLAF.FLDCLA+'",[F:ATX]TEXTE,[F:ATX]LAN,[F:ATX]NUMERO) From ASYRSUB'
   Gosub ADDCLB
   DIF -=1 : LIGNE = "Next ATX"  : Gosub ADDCLB
  Elsif find( PROGRAM,[V]CST_APRGAINSERT,[V]CST_APRGAUPDATE)>0 : # Read
   LIGNE = 'Call NUMBER(fmet '+WCLASSE+'.AGETTEXT("'+ACLAF.FLDCLA+'"),[F:'+ABRLNK+']'+ACLAF.FLDCLA
   If ACLAF.DIME>1
    LIGNE += '([L]A_I)'
   Endif
   LIGNE += ","+WCLASSE+") From ASYRDIV"  : Gosub ADDCLB
   If ACLAF.DIME>1
    LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : Break : Endif" : Gosub ADDCLB
   Endif
  Endif
 Endif
End


#-------------------------------------------------------#
# Avaluation des criteres pour atextra
#-------------------------------------------------------#
Subprog EVAL_CLE(CLA,COLLECTION,CLASTR,ACLALNK,CLE)
Value Char CLA
Value Char COLLECTION
Value Char CLASTR
Variable Instance  ACLALNK Using OBJECT
Variable Char CLE

Local Char CHAINE(250),CHAINE2(250),CHP(250)
Local Integer I,J

Onerrgo EVALCLE
CHAINE=CLE
If left$(CHAINE,1) = "="
 CHAINE = right$(CHAINE,2)
Endif
I = instr(1,toupper(CHAINE),"NUM$(")
I *= (instr(1,toupper(CHAINE),"FUNC ")=0)
I *= (left$(CHAINE,1)<>"'")
I *= (left$(CHAINE,1)<>'"')
If I
 CLE = ""
 While I>0
  J =  instr(6,CHAINE,")")
  CLE += left$(CHAINE,I+4)
  CHP = seg$(CHAINE,I+5,instr(6,CHAINE,")")-1)
  If instr(1,CHP,".")>0
   CHAINE2 = right$(CHP, instr(1,CHP,".")+1)
  Else
   CHAINE2 = CHP
  Endif
  Read [ACLAF]ACLAF0 = CLA;CHAINE2
  If !fstat
   CLE += CLASTR+"."
   If [F:ACLAF]FLDGRP="" & [L]COLLECTION<>""
    CLE+="APARENT."
   Endif
  Endif
  CLE += CHAINE2
  CLE += ")"
  CHAINE = right$(CHAINE,J+1)
  I = instr(1,toupper(CHAINE),"NUM$(")
 Wend
Else
 If ACLALNK.ObjectType="C_ACLA"
  If instr(1,CHAINE,".")>0
   CHAINE2 = right$(CHAINE, instr(1,CHAINE,".")+1)
  Else
   CHAINE2 = CHAINE
  Endif
  Gosub SEARCH_ACLAF
 Else
  If instr(1,CHAINE,".")>0
   CHAINE2 = right$(CHAINE, instr(1,CHAINE,".")+1) :  Gosub SEARCH_ACLAF
  Else
   CHAINE2 = CHAINE :   Gosub SEARCH_ASWF
  Endif
 Endif
Endif
Onerrgo

End

$SEARCH_ASWF
Read [ASWF]ASWF0 = CLA;toupper(CHAINE2)
If !fstat
 Read [ATY]CODTYP = [ASWF]CODTYP
 If !fstat
  CLE = ""
  If find([F:ATY]TYPTYP ,1,2,3,4,5,6)>0
   CLE += "num$("
  Endif
  CLE += ACLALNK.CODREP+"."
  If [ASWF]FLDGRP="" & [L]COLLECTION<>""
   CLE+="APARENT."
  Endif
  CLE += CHAINE
  If find([F:ATY]TYPTYP ,1,2,3,4,5,6)>0
   CLE += ")"
  Endif
 Else
  CLE = ACLALNK.CODREP+"."+CHAINE2
 Endif
Endif
Return

$SEARCH_ACLAF
Read [ACLAF]ACLAF0 = CLA;toupper(CHAINE2)
If !fstat
 Read [ATY]CODTYP = [ACLAF]CODTYP
 If !fstat
  CLE = ""
  If find([F:ATY]TYPTYP ,1,2,3,4,5,6)>0
   CLE += "num$("
  Endif
  CLE += CLASTR+"."
  If [F:ACLAF]FLDGRP="" & [L]COLLECTION<>""
   CLE+="APARENT."
  Endif
  CLE += CHAINE2
  If find([F:ATY]TYPTYP ,1,2,3,4,5,6)>0
   CLE += ")"
  Endif
 Else
  CLE = CLASTR+"."+CHAINE2
 Endif
Endif
Return

$EVALCLE
CHAINE=CLE
Resume

