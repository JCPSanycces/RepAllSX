#########################################################################
#  SIXREP : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog SIXREP                                                       #
#     Création des representants                                        #
#                                                                       #
#########################################################################

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE

If GTRACE = ""
#  "Migration des représentants
    Call OUVRE_TRACE("SIXREP : "+SI_MES(32)) From LECFIC     
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#---- Création enregistrement BPCUSTOMER ------#
Call ECR_TIME("SI_SALESREP : "+mess(213,124,1)+" SALESREP") From DOSSUB
Call SI_SALESREP
If GOK<>1 : Onerrgo : Goto FIN_FIN : Endif


$FIN_FIN
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
    Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GOK = 0
Resume


#########################################################################
# Création des clients
#########################################################################
Subprog SI_SALESREP  

########--------------------------------------------------------- Ouvertures tables X3 #

If !clalev([F:FCY])  : Local File =SI_DOSSIER+".FACILITY"   [FCY] : Endif   # Socièté
If !clalev([F:BPR])  : Local File =SI_DOSSIER+".BPARTNER"   [BPR] : Endif   # Business Partner
If !clalev([F:BPA])  : Local File =SI_DOSSIER+".BPADDRESS"  [BPA] : Endif   # Adresses
If !clalev([F:TCY])  : Local File =SI_DOSSIER+".TABCOUNTRY" [TCY] : Endif   # Pays
If !clalev([F:TCU])  : Local File =SI_DOSSIER+".TABCUR"     [TCU] : Endif   # Devises
If !clalev([F:TLA])  : Local File =SI_DOSSIER+".TABLAN"     [TLA] : Endif   # Langues
If !clalev([F:REP])  : Local File =SI_DOSSIER+".SALESREP"   [REP] : Endif   # Representants
If !clalev([F:CDI])  : Local File =SI_DOSSIER+".CADIEDEF"   [CDI] : Endif   # Axes par défaut
If !clalev([F:CAC])  : Local File =SI_DOSSIER+".GACCCODE"   [CAC] : Endif   # Codes comptables   # hcb 70899


If !clalev([F:ADI])  : Local File =SI_DOSSIER+".ATABDIV"    [ADI] : Endif   # table diverse
If !clalev([F:AXX])  : Local File =SI_DOSSIER+".ATEXTRA"    [AXX] : Endif   # Textes
If !clalev([F:ATZ])  : Local File =SI_DOSSIER+".ATABZON"    [ATZ] : Endif   # Libellé rubrique 

########--------------------------------------------------------- Ouvertures tables Integrale #

If !clalev([F:XREP]) : Local File =SI_DOSSIER+".XIREP"      [XREP] : Endif  # Representant

########--------------------------------------------------------- Définitions rubriques # 

Local Integer STOP
Local Integer LRET
Local Integer LERR    # 0=OK 1=Erreur => pas d'écriture de l'enregistrement
Local Char    COD_DEV_ATABZON(25)
Local Integer  I

########--------------------------------------------------------- Vérification de la langue #
Read [TLA]TLA0=[F:SPX]LAN
If fstat
    Call ECR_TRACE(SI_MES(245),1) From GESECRAN
    End
Endif


########--------------------------------------------------------- Initialisation variables contextuelles #

SI_SUBPRG = "SIXREP"
SI_TABLE  = "XIREP"
Gosub SI_CRITSUP From SIXFONCTION

########--------------------------------------------------------- Récuperation des correspondances #

SI_TABLE = "SALESREP"
Gosub SI_INIVALEUR From SIXFONCTION


# mémorisation libellé devise
Call TEXTFIC("SALESREP","CUR",2,COD_DEV_ATABZON) From OBJDIV  


########--------------------------------------------------------- Traitement #

$LOOP_REP


Call DEBTRANS From GLOCK

# Traitement des representant
For [XREP] Where left$(CODREP,2)<>"$$"
&              & FLGREP<>2
&              & evalue(SI_CRITERE)

    Trbegin [REP]
    Call AFFBOITE([F:XREP]CODREP) From SUBSIM

    LERR = 0

    # creation representant (SALESREP)
    If LERR = 0
       Gosub CRE_REP
       If GOK <= 0 & SI_SIMU <> 2
          Break
       Endif
    Endif

    # creation business partner (BPARTNER)
    If LERR = 0
       Gosub CRE_BPR
       If GOK <= 0 & SI_SIMU <> 2 
          Break
       Endif
    Endif

    #----    creation adresse (BPADDRESS)
    If LERR = 0
       Gosub CRE_BPA 
       If GOK <= 0 & SI_SIMU <> 2 
          Break
       Endif
    Endif

    If LERR=0 & SI_SIMU<>2
#      Readlock [XREP] Curr
       [F:XREP]FLGREP = 2
       Rewrite [XREP]
       Commit
    Else
      Rollback
    Endif
 
Next

End


#  Creation SALESREP 
##################################################################
$CRE_REP
Raz [F:REP]

# recuperation et controle code client
If !func SIXFONCTION.SI_CTL("REPNUM",[F:XREP]X3CLE,"XIREP ("+[F:XREP]CODREP+")")
    LERR = 1
Else
    [F:REP]REPNUM  = [F:XREP]X3CLE
Endif

[F:REP]REPNAM      = [F:XREP]NOMREP    # Nom           
[F:REP]COMRAT1     = [F:XREP]TAUCOM    # Taux commission 1

[F:REP]CREUSR      = GUSER             # operateur création    
[F:REP]CREDAT      = date$             # date création
[F:REP]CREUSR      = GUSER             # operateur création    
[F:REP]UPDDAT      = date$             # date modification
[F:REP]UPDUSR      = GUSER             # operateur modification
[F:REP]CUR         = [F:SPX]CUR        # Devise 

# Code axe
Read [CDI] CDI0=4
If !fstat
    For I=0 To [F:CDI]NBRDIE-1
        [F:REP]DIE(I) =  [F:CDI]DIE(I)
    Next I
Endif
# initialisation par defaut
# code comptable

# hcb 70899 deb                  
#[F:REP]ACCCOD     = "STD"                # Code comptable inclus dans le dossier de référence. 
## comptable par 'STD' (celui livré en standard)
If [F:REP]ACCCOD= ""
   Read [CAC]CAC0 = 4;"STD"
   If !fstat
      [F:REP]ACCCOD = "STD"
   Else
      Filter [CAC] Where TYP=4
             Read [CAC]CAC0 First
             If !fstat 
                [F:REP]ACCCOD= [F:CAC]ACCCOD
             Endif
      Filter [CAC]
   Endif
Endif
# hcb 70899 fin                  

# initalisation des Adresses
If dim([F:REP]BPAADD) > 0
   [F:REP]BPAADD      = "001"   # Adresse par defaut   
Endif
# Point d'entrée avant écriture
SI_TABLE = "SALESREP"
Gosub SI_BEFWRI From SIXFONCTION

# Devise
If dim([F:REP]CUR) > 0         
   If [F:REP]CUR         = ""
      Call ECR_TRACE(mess(5,277,1)-[F:REP]CUR-"("+[F:XREP]CODREP+")"-mess(10,123,1)+" : "+COD_DEV_ATABZON, 1) From GESECRAN
      LERR = 1
   Endif
Endif

Write [REP]
If fstat
    Call ECR_TRACE(mess(5,277,1)-[F:REP]REPNUM-"("+[F:XREP]CODREP+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
    LERR = 1
Endif

Return


##################################################################
#  Creation BPARTNER
#  + mise a jour du RIB par defaut dans le fichier BID
##################################################################
$CRE_BPR

Local Integer LEXI
Local Char    LBIDNUM
Raz LEXI
Look [BPR]BPR0 = [F:REP]REPNUM
If fstat <> 0
    Readlock [BPR]BPR0 = [F:REP]REPNUM
    If fstat
        Raz [F:BPR]
        Raz LEXI
    Else
        LEXI = 1
    Endif

    # Rubriques reprises du representant integrale 
    # Rubriques reprises du representant X3
    [F:BPR]BPRNUM    = [F:REP]REPNUM          # Tiers
    [F:BPR]ACCCOD    = [F:REP]ACCCOD          # Code comptable
    [F:BPR]BPRNAM    = [F:REP]REPNAM          # Raison social
    If dim([F:REP]BPAADD) > 0
       [F:BPR]BPAADD    = [F:REP]BPAADD       # Adresse par défaut
    Else
       [F:BPR]BPAADD    = "001"               # Adresse par défaut
    Endif
    If dim([F:BPR]CUR) > 0
       If dim([F:REP]CUR) > 0
          [F:BPR]CUR    = [F:REP]CUR          # Devise
       Endif
    Endif
    If dim([F:BPR]LAN) > 0
       If [F:BPR]LAN    = ""
          [F:BPR]LAN    =  [F:SPX]LAN         # langue
       Endif
    Endif


    [F:BPR]CREDAT    = [F:REP]CREDAT          # Date création
    [F:BPR]CREUSR    = [F:REP]CREUSR          # Opérateur création
    [F:BPR]UPDDAT    = [F:REP]UPDDAT          # Date modification
    [F:BPR]UPDUSR    = [F:REP]UPDUSR          # Opérateur modification
          
    # Rubriques par defaut 
    [F:BPR]BPCFLG    = 1                      # Flag client     
    [F:BPR]BPSFLG    = 1                      # Flag fournisseur
    [F:BPR]BPTFLG    = 1                      # Flag transporteur
    [F:BPR]REPFLG    = 2                      # Flag representant
    [F:BPR]FCTFLG    = 1                      # Flag factor
    [F:BPR]PRVFLG    = 1                      # Flag prestataire
    [F:BPR]DOOFLG    = 1                      # Flag donneur ordre
    [F:BPR]BPRFBDMAG = 1                      # Interdit mailing 

    For I = 0 To 3
        [F:BPR]BPRFLG (I) = 1                 # Flag divers
    Next I 

    # Maj
    If LEXI
       [F:BPR]REPFLG = 2                      # Flag representant
       [F:BPR]UPDDAT = date$ 
       [F:BPR]UPDUSR = GUSER 
       Rewrite [BPR]
    Else
        SI_TABLE = "BPARTNER"
        Gosub SI_BEFWRI From SIXFONCTION
        Write [BPR]
        If fstat
           Call ECR_TRACE("Business Partner"-[F:REP]REPNUM-"("+[F:XREP]CODREP+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
           LERR = 1
        Endif
    Endif
Else
     Readlock [BPR]BPR0 = [F:REP]REPNUM
     If fstat = 1
        Call ECR_TRACE("Business Partner"-[F:REP]REPNUM-"("+[F:XREP]CODREP+")"-mess(27,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
        LERR = 1
        Return
     Endif
    [F:BPR]REPFLG    = 2
    [F:BPR]UPDDAT    = date$
    [F:BPR]UPDUSR    = GUSER
    Rewrite [BPR]
Endif

Return


##################################################################
#  Creation BPADDRESS
##################################################################
$CRE_BPA
Local Integer LEXI
Raz LEXI
Local Char LBPAADD(3)
If dim([F:REP]BPAADD) > 0   
   LBPAADD    = [F:REP]BPAADD          # Adresse par défaut
Else
   LBPAADD    = "001"                  # Adresse par défaut
Endif

Look [BPA]BPA0 = 1;[F:REP]REPNUM;LBPAADD 
If fstat <> 0
    Readlock [BPA]BPA0=1;[F:REP]REPNUM;LBPAADD 
    If fstat
        Raz [F:BPA]
        Raz LEXI
    Else
        LEXI = 1
    Endif
    # Rubriques reprises du representant Integrale

    [F:BPA]BPAADDLIG (0) =  [F:XREP]ADR1      # Ligne adresse 1
    [F:BPA]BPAADDLIG (1) =  [F:XREP]ADR2      # Ligne adresse 2
    [F:BPA]BPAADDLIG (2) =  [F:XREP]ADR3      # Ligne adresse 3
    [F:BPA]POSCOD        =  [F:XREP]CODPST    # Code postal     
    [F:BPA]CTY           =  [F:XREP]VIL       # Ville           

    Call NUMONLY([F:XREP]TEL,[F:BPA]TEL) From SIXFONCTION    # Telephone
    Call NUMONLY([F:XREP]TLC,[F:BPA]FAX) From SIXFONCTION    # Fax 
    [F:BPA]TEL(1)        =  [F:BPA]FAX                       # Fax      # hcb 73119

    [F:BPA]WEB           =  [F:XREP]ADRMAI    # Adresse internet

    # Rubriques reprises du representant  X3
    [F:BPA]BPATYP    = 1                      # Type entité
    [F:BPA]BPANUM    = [F:REP]REPNUM          # Entité
    [F:BPA]BPAADD    = LBPAADD                # Adresse 
    [F:BPA]CREDAT    = [F:REP]CREDAT          # Date création
    [F:BPA]CREUSR    = [F:REP]CREUSR          # Opérateur création
    [F:BPA]UPDDAT    = [F:REP]UPDDAT          # Date modification
    [F:BPA]UPDUSR    = [F:REP]UPDUSR          # Opérateur modification
 
    # Rubriques par defaut 
    [F:BPA]BPAADDFLG = 2                      # Par défaut
    [F:BPA]CRETIM    = time                   # Heure
    [F:BPA]UPDTIM    = time                   # Heure

    # Maj
    If LEXI
       [F:BPA]UPDDAT = date$ 
       [F:BPA]UPDUSR = GUSER  
       [F:BPA]UPDTIM = time                   # Heure

       Rewrite [BPA]
    Else
        SI_TABLE = "BPADDRESS"
        Gosub SI_BEFWRI From SIXFONCTION
        Write [BPA]
        If fstat
           Call ECR_TRACE(mess(33,102,1)-[F:REP]REPNUM-"("+[F:XREP]CODREP+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
           LERR = 1
        Endif
    Endif
Endif

Return














