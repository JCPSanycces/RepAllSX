Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("RDE",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
  Case ACTION
    When "IMP_OUVRE"    : Gosub IMP_OUVRE
    When "IMPORT"       : Gosub IMPORT

    When Default
  Endcase
Return

$IMP_OUVRE
  # Nombre de rubriques bien comptable (variable en fonction du déterminant)
  Local Shortint NBLIG_BCO_FAM : NBLIG_BCO_FAM = 16 : # Famille comptable
  Local Shortint NBLIG_BCO_CPT : NBLIG_BCO_CPT = 15 : # Compte
  # Nombre de rubriques dépense
  Local Shortint NBLIG_LOF     : NBLIG_LOF = 15
  # Nombre de rubrique par plan
  Local Shortint NBLIG_PLN     : NBLIG_PLN = 8
Return

$IMPORT
  Case SEPNUM
    When 1 : Gosub ALIM_OBJ  : # Alimentation de la partie haute du tableau
    When 2 : Gosub ALIM_PLAN : # Alimentation de la partie basse du tableau    
    When Default
  Endcase
Return

############################################
# Mise à jour des flags de l'objet metier
$ALIM_OBJ
  Local Integer LIM, N_L, I

  If  [F:RDE]REFOBJ = GVML_OMBIEN 
    If [F:RDE]DETAAS = GVML_DTAFAM
      LIM = NBLIG_BCO_FAM - 1
    Else
      LIM = NBLIG_BCO_CPT - 1
    Endif
  Else
    LIM = NBLIG_LOF - 1
  Endif

  N_L = 0

  # Boucle de mise à jour des flags pour le plan
  For I = 0 To LIM
    If [F:RDE]MGTFLG(I) = G_OUI
      [M:RDE1]MGTFLG(N_L)  =   [F:RDE]MGTFLG(I)
      [M:RDE1]FRCFLG(N_L)  =   [F:RDE]FRCFLG(I)
      [M:RDE1]UPDFLG(N_L)  =   [F:RDE]UPDFLG(I)
    Else
      [M:RDE1]MGTFLG(N_L)  =   G_NON
      [M:RDE1]FRCFLG(N_L)  =   G_NON
      [M:RDE1]UPDFLG(N_L)  =   G_NON
      [F:RDE]FRCFLG(I)     =   G_NON
      [F:RDE]UPDFLG(I)     =   G_NON
    Endif
    N_L += 1
  Next I
Return

############################################
# Mise à jour des flags du plan en cours
$ALIM_PLAN   
  Local Integer N_L, I

  If  [M:RDE1]REFOBJ = GVML_OMBIEN 
    N_L = find([F:RDP]DPRPLN, [M:RDE1]DPRPLN(LIM + 1..199)) : # On cherche le rang du plan en cours

    N_L += LIM + 1 : # Comme on est parti de LIM + 1 pour la recherche, on ajuste l'indice

    # Boucle de mise à jour des flags pour le plan
    For I = 0 To NBLIG_PLN - 1
      If [F:RDP]RUBRASP(I) <> ""
        If [F:RDP]MGTFLGP(I) = G_OUI
          [M:RDE1]MGTFLG(N_L)  =   [F:RDP]MGTFLGP(I)
          [M:RDE1]FRCFLG(N_L)  =   [F:RDP]FRCFLGP(I)
          [M:RDE1]UPDFLG(N_L)  =   [F:RDP]UPDFLGP(I)
        Else
          [M:RDE1]MGTFLG(N_L)  =   G_NON
          [M:RDE1]FRCFLG(N_L)  =   G_NON
          [M:RDE1]UPDFLG(N_L)  =   G_NON
        Endif
      Else
        Break
      Endif
      N_L += 1
    Next I
  Endif
Return
