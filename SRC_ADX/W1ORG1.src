#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ORG1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:37"
A_USER  = "DOC"
A_STAMP = "20181109230537"
Return

$TITRES
Chgtzn [M:ORG1]ADD1 With [F:TCY]ADRNAM(0)
Chgtzn [M:ORG1]ADD2 With [F:TCY]ADRNAM(1)
Chgtzn [M:ORG1]ADD3 With [F:TCY]ADRNAM(2)
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ORG1 [ORG1]
Gosub HORODAT
Local Inpbox "ORG1" From GFONCTION At A_STAMP With A_WINDPREV Mask [ORG1] As [SIM_]
Grizo [ORG1]5
Grizo [ORG1]10
Grizo [ORG1]20
Grizo [ORG1]25
Grizo [ORG1]30
Grizo [ORG1]35
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ORG1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=77 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=77 : Y1(1)=3 : Y2(1)=4
X1(2)=1 : X2(2)=77 : Y1(2)=5 : Y2(2)=13
X1(3)=1 : X2(3)=77 : Y1(3)=14 : Y2(3)=15
X1(4)=1 : X2(4)=77 : Y1(4)=16 : Y2(4)=21
X1(5)=1 : X2(5)=77 : Y1(5)=22 : Y2(5)=29
Return

$ON_TYP
Onevent BEFORE_AREA Gosub AV_TYP From W1ORG1
Onevent AFTER_CHANGE Gosub AMM_TYP From W1ORG1
Onevent INIT_AREA Call D_TYP(zc) From W1ORG1
Onevent BEFORE_INPUT Call AS_TYP(zc) From W1ORG1
Return

$AV_TYP
## Action STD
Call AV_TYP(zc) From SUBORG
Gosub _AFF
Return

Subprog D_TYP(VALEUR)
Variable Integer VALEUR
If varinit([M]TYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_TYP
Call AM_TYP(zc)
If !mkstat & GOBJET
 zoncou = "TYP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_TYP(VALEUR) From SUBORG
If mkstat : GERR = 1 : GZONE = "TYP" : GZNUM = 46893 : Endif
Gosub _AFF
End

$ON_CRN
Onevent BEFORE_AREA Gosub AV_CRN From W1ORG1
Onevent CONTROL Call C_CRN(zc) From W1ORG1
Return

$AV_CRN
If !GWEBSERV
 ## Action FMTCRTPAY
 Call FMTCRTPAY([M]CRY) From TRTDIV
Endif
If !GWEBSERV
 ## Action ASAICRT
 If [F:TCY]CRTFMTFLG<>2 : Grizo =zoncou : mkstat = 1 : Else : Actzo =zoncou : Endif
Endif
If GFMT<>""
 Chgfmt [M]CRN(indice) With "K:"+GFMT
Else
 Chgfmt [M]CRN(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog C_CRN(VALEUR)
Variable Char    VALEUR()
## Action CONTSIRET
Call CONTSIRET(VALEUR,[M]CRY,"") From CONTNUM
If mkstat : GERR = 1 : GZONE = "CRN" : GZNUM = 26815 : Endif
Gosub _AFF
End

$ON_NSSCOD
Onevent INIT_AREA Call D_NSSCOD(zc) From W1ORG1
Onevent CONTROL Call C_NSSCOD(zc) From W1ORG1
Onevent BEFORE_INPUT Call AS_NSSCOD(zc) From W1ORG1
Return

Subprog D_NSSCOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]NSSCOD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_NSSCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NSSCOD(zc) From W1ORG1
Onkey   2 Titled GBOUTS Call S_NSSCOD(zc) From W1ORG1
Onkey 144 Titled GBOUTP Call P_NSSCOD(zc) From W1ORG1
Onkey 146 Titled GBOUTA Call SA_NSSCOD(zc) From W1ORG1
Gosub _AFF
End

Subprog C_NSSCOD(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"","") From SUBADI
If mkstat : GERR = 1 : GZONE = "NSSCOD" : GZNUM = 56302 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "NSSCOD" : GZNUM = 56302 : Endif
Endif
Gosub _AFF
End

Subprog S_NSSCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = ""
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_NSSCOD(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_NSSCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_NSSCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

