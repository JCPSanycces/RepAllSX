Subprog AS_CRYNAM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
If !GWEBSERV
 ## Action SAIPAYS
 Call SAIPAYS([M]CRY) From TRTDIV
 If mkstat=2
  [M]CRYNAM(INDIC) = VALEUR
  Affzo CRYNAM(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

