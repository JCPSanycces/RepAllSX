#<AdxTL>@(#)5.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Fill ADV/ADI902 and update data types with clob/blob
#----------------------------------------------------------------------------------------#

Subprog GENE
#Call OUVRE_TRACE("Fill ADV/ADI902 and update data types with clob/blob") From LECFIC
Call OUVRE_TRACE("Update datatypes/CODTYP to use ACRTF and ABIMG") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
 Local File ABLOB [ABB]
 Local File ATABDIV [ADI]
 Local File ATABTAB [ADV]
 Local File ACLAFLD [ACLAF]
 Local File ASHWFLD [ASWF]
 Local File ATABZON [ATZ]
Else
 Local File =DOSSIER+".ABLOB" [ABB]
 Local File =DOSSIER+".ATABDIV" [ADI]
 Local File =DOSSIER+".ATABTAB" [ADV]
 Local File =DOSSIER+".ACLAFLD" [ACLAF]
 Local File =DOSSIER+".ASHWFLD" [ASWF]
 Local File =DOSSIER+".ATABZON" [ATZ]
Endif

#If dim([ABB]CNTTYP)>0
# Gosub MAJ_B_ACLAF
# Gosub MAJ_B_ASWF
# Gosub MAJ_C_ACLAF
# Gosub MAJ_C_ASWF
# Gosub MAJ_ADV902
# Gosub MAJ_ADI902
#Endif

Gosub MAJ_ATZ
Gosub MAJ_ACLAF
Gosub MAJ_ASWF

Close Local File [ABB],[ADI],[ADV],[ACLAF],[ASWF],[ATZ]
End

#----------------------------------------------------------------------------------------#
$MAJ_ATZ
Trbegin [ATZ]
  Update [ATZ] Where CODTYP="AC01" With CODTYP="ACRTF"
  Update [ATZ] Where CODTYP="AB01" With CODTYP="ABIMG"
Commit
Return

#----------------------------------------------------------------------------------------#
$MAJ_ACLAF
Local Char TAB_ACLAF(GLONACLA)(1..)
Local Integer I,NB_ACLAF
NB_ACLAF=0

For [ACLAF]ACLAF0(1) Where CODTYP="AC01" or CODTYP="AB01"
 NB_ACLAF+=1
 TAB_ACLAF(NB_ACLAF)=[F:ACLAF]CODCLA
Next

Trbegin [ACLAF]
  Update [ACLAF] Where CODTYP="AC01" With CODTYP="ACRTF"
  Update [ACLAF] Where CODTYP="AB01" With CODTYP="ABIMG"
Commit

#Validation différée (à la volée)
Local Integer SAVGVALID
If dim(GVALIDDIFF)<=0 : Global Integer GVALIDDIFF : Endif
SAVGVALID=GVALIDDIFF
GVALIDDIFF=3
For I=1 To NB_ACLAF
  Call VALIDATION(0,DOSSIER,TAB_ACLAF(I)) From SUBACLA
Next I
GVALIDDIFF=SAVGVALID
Return

#----------------------------------------------------------------------------------------#
$MAJ_ASWF
Local Char TAB_ASWF(GLONASW)(1..)
Local Integer I,NB_ASWF
NB_ASWF=0

For [ASWF]ASWF0(1) Where CODTYP="AC01" or CODTYP="AB01"
 NB_ASWF+=1
 TAB_ASWF(NB_ASWF)=[F:ASWF]CODREP
Next

Trbegin [ASWF]
  Update [ASWF] Where CODTYP="AC01" With CODTYP="ACRTF"
  Update [ASWF] Where CODTYP="AB01" With CODTYP="ABIMG"
Commit

#Validation différée (à la volée)
Local Integer SAVGVALID
If dim(GVALIDDIFF)<=0 : Global Integer GVALIDDIFF : Endif
SAVGVALID=GVALIDDIFF
GVALIDDIFF=3
For I=1 To NB_ASWF
  Call VALIDATION(0,DOSSIER,TAB_ASWF(I)) From SUBASW
Next I
GVALIDDIFF=SAVGVALID
Return

#----------------------------------------------------------------------------------------#
$MAJ_C_ACLAF

Trbegin [ACLAF]
Update [ACLAF] Where CODTYP="AC0" & pat(CODCLA,"A*")=0 With CODTYP="AC01"
Commit

Trbegin [ACLAF]
Update [ACLAF] Where CODTYP="ACB" & pat(CODCLA,"A*")=0 With CODTYP="AC01"
Commit

Return

#----------------------------------------------------------------------------------------#
$MAJ_C_ASWF

Trbegin [ASWF]
Update [ASWF] Where CODTYP="AC0" & pat(CODREP,"A*")=0 With CODTYP="AC01"
Commit

Trbegin [ASWF]
Update [ASWF] Where CODTYP="ACB" & pat(CODREP,"A*")=0 With CODTYP="AC01"
Commit

Return

#----------------------------------------------------------------------------------------#
$MAJ_B_ACLAF

Trbegin [ACLAF]
Update [ACLAF] Where CODTYP="ABB" & FLDCLA="PHOTO" With CODTYP="AB01"
Commit

Trbegin [ACLAF]
Update [ACLAF] Where CODTYP="ABB" & FLDCLA="IMG" With CODTYP="AB01"
Commit

Trbegin [ACLAF]
Update [ACLAF] Where CODTYP="AB0" & FLDCLA="PHOTO" With CODTYP="AB01"
Commit

Trbegin [ACLAF]
Update [ACLAF] Where CODTYP="AB0" & FLDCLA="AUSPIC" With CODTYP="AB01"
Commit

Trbegin [ACLAF]
Update [ACLAF] Where CODTYP="AB0" & FLDCLA="IMG" With CODTYP="AB01"
Commit

Trbegin [ACLAF]
Update [ACLAF] Where CODTYP="AB0" & FLDCLA="LOGO" With CODTYP="AB01"
Commit

Return

#----------------------------------------------------------------------------------------#
$MAJ_B_ASWF

Trbegin [ASWF]
Update [ASWF] Where CODTYP="ABB" & CODFLD="PHOTO" With CODTYP="AB01"
Commit

Trbegin [ASWF]
Update [ASWF] Where CODTYP="ABB" & CODFLD="IMG" With CODTYP="AB01"
Commit

Trbegin [ASWF]
Update [ASWF] Where CODTYP="AB0" & CODFLD="PHOTO" With CODTYP="AB01"
Commit

Trbegin [ASWF]
Update [ASWF] Where CODTYP="AB0" & CODFLD="AUSPIC" With CODTYP="AB01"
Commit

Trbegin [ASWF]
Update [ASWF] Where CODTYP="AB0" & CODFLD="IMG" With CODTYP="AB01"
Commit

Trbegin [ASWF]
Update [ASWF] Where CODTYP="AB0" & CODFLD="LOGO" With CODTYP="AB01"
Commit

Return


#-----------------------------------------------------#
$MAJ_ADI902
Local Char WEXT(100)
Trbegin [ADI]
 For [ADI] Where NUMTAB=902 & A2=""
  If [F:ADI]N1=2 : #Blob image base
   [F:ADI]A2="ATYPE9-1"
  Elsif [F:ADI]N1=3 : #Clob dans la base
   [F:ADI]A2="ATYPE10-1"
  Else : #Fichier
   WEXT=toupper([F:ADI]A1)
   If find(WEXT,"TXT","TRA","RTF","HTM","HTML","SRC","JSON")
    [F:ADI]A2="ATYPE10"
   Elsif find(WEXT,"DOC","PDF","DOCX","JPG","BMP","JPEG","MPG","MPEG","MSG","PPT","RPT","PIC","HTTP","XLS","ZIP")
    [F:ADI]A2="ATYPE9"
   Endif
  Endif
  Rewrite [F:ADI]
  If fstat
   Call ERREUR("ATABDIV 902"-[F:ADI]CODE,2) From DOSDIC
  Endif
 Next
Commit
Return

$MAJ_ADV902
Trbegin [ADV]
 For [ADV] Where NUMTAB=902 & [F:ADV]COLALPTYP(1)=""
  Call MAJTEXTRA("Content type","ATABTAB","COLALPDES",num$([F:ADV]NUMTAB),"1") From ATEXTRA
  [F:ADV]COLALPTYP(1)="ATYP"
  Rewrite [F:ADV]
  If fstat
   Call ERREUR("ATABTAB 902",2) From DOSDIC
  Endif
 Next
Commit
Return


#-----------------------------------------------------#
