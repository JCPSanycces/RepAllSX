#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
#    CLOTURE SOCIETE AMORTISSEMENTS RUSSIE
#
#    Création le : 03/06/2010
#-------------------------------------------------------------------------------
# PROGRAMMES ACTIONS :
#-------------------------------------------------------------------------------
#    Modifications :
#MDJ/MWA - 13.06.2012 FQ80825 : Arrêt/Redémarrage
################################################################################
End

################################################################################
# Déclaration
$INIT_VAR
  Local Date     PDTDBAMT
  Local Date     PDATMES
  Local Date     RDTDBAMTREG
  Local Shortint B_AMT : # indicateur d'amortissement effectif
Return

################################################################################
# Appel par plan
# Les classes [F:FAS], [F:DEP] et [F:DEPS] sont disponibles
$TRAITE_PLN


    # S'il ne s'agit pas d'un mode russe - on sort
    If (find([F:DEP]DPM, G_DPMLR, G_DPMCR, G_DPMSR, G_DPMDR, G_DPMUR) = 0 ) Then : Return : Endif

    # Gestion du nombre de mois d'arrêt
    # On recherche la date de début d'amortissement régularisée
    PDTDBAMT = [F:DEP]STRDPRDAT
    PDATMES  = [F:FAS]ITSDAT
    Gosub DEB_AMT_MODES_RUSSES From GLOBB8

    If ( RDTDBAMTREG <= LDATCRT(LDT_FINPCO) ) Then : B_AMT = 1 : Else : B_AMT = 0 : Endif

    # Gestion de le l'arrêt d'amortissement si l'on est en période d'amortissement effectif du plan
    If ( B_AMT ) Then
       If find([F:DEP]KSTPDEPSTA,GVML_SSMOSTP,GVML_SSCOSTP,GVML_SSMODER,GVML_SSCONSE)
          # Incrément du nombre de mois d'arrêt du plan si on est en demande d'arrêt ou en arrêt.
          [F:DEP]KNBMSTPDEP += 1
          # Report au cas où le bien ne serait pas recalculé entre 2 clotures
          [F:DEPS]KNBMSTPDEP = [F:DEP]KNBMSTPDEP
  Endif

       Case [F:DEP]KSTPDEPSTA
      When GVML_SSMODER
        # Action d'arrêt pour modernisation dans la période. On prononce l'arrêt.
            [F:DEPS]KSTPDEPSTA = GVML_SSMOSTP
      When GVML_SSCONSE
        # Action d'arrêt pour conservation dans la période. On prononce l'arrêt.
             [F:DEPS]KSTPDEPSTA = GVML_SSCOSTP
      When GVML_SSMORST, GVML_SSCORST
        # Action de redémarrage dans la mériode. On redémarre l'amortissement.
             [F:DEPS]KSTPDEPSTA = GVML_SSNOSTP
          When Default
            # Report au cas où le bien ne serait pas recalculé entre 2 clotures
             [F:DEPS]KSTPDEPSTA = [F:DEP]KSTPDEPSTA
    Endcase

    DTDBAMTREG = 0
  Endif


Return

################################################################################
# Appel par bien
# La classe [F:FAS] est disponible
$TRAITE_FAS
Return
