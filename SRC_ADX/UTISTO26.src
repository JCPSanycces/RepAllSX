#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTISTO26   Update TABCONTAINER for intern container                    #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap

Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS

If DOSSIER <> ""

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("TABCONTAINER update") From LECFIC

  Call MAJ_UTISTO26(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC

Endif

End
##########################################################################
##########################################################################
Subprog MAJ_UTISTO26(DOSSIER)
Value Char     DOSSIER

Local Integer GOK

GOK = 1

# If we have stock module
If [F:ADS]MODULE(6)<>2 : End : Endif

Call ECR_TRACE("UTISTO26: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Open tables -----#
If filinfo(filpath("FIL","TABCONTAINER", "fde",DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL","STKTRS", "fde",DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL","ITMFACILIT", "fde",DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL","ITMCATEG", "fde",DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL","TABSTORUL", "fde",DOSSIER),0) < 0 : End : Endif

If clalev([F:TCTR]) = 0 : Local File =DOSSIER+".TABCONTAINER"   [TCTR] : Endif
If clalev([F:SRT]) = 0 : Local File =DOSSIER+".STKTRS"   [SRT] : Endif
If clalev([F:ITF]) = 0 : Local File =DOSSIER+".ITMFACILIT"   [ITF] : Endif
If clalev([F:ITG]) = 0 : Local File =DOSSIER+".ITMCATEG"   [ITG] : Endif
If clalev([F:SRU]) = 0 : Local File =DOSSIER+".TABSTORUL"   [SRU] : Endif


#validation TCTR object after update selection
Call ECR_TRACE("UTISTO26: valid TCTR object",0) From GESECRAN
Call MAJ_SEL(DOSSIER,"TCTR") From PATCHAOB
Call VALID("TCTR",DOSSIER,1,GOK) From VALOBJ
If GOK = 0 : Gosub TRT_END : Endif

If adxlog = 0
  Trbegin [TCTR]
Endif
#Update TABCONTAINER columns
Call ECR_TRACE("UTISTO26: update TABCONTAINER : FREFLG,INTFLG,MONITMFLG,MONLOTFLG",0) From GESECRAN
For [F:TCTR] Where [F:TCTR]FREFLG = 0
  [F:TCTR]FREFLG = 2
  [F:TCTR]INTFLG = 1
  [F:TCTR]MONITMFLG = 1
  [F:TCTR]MONLOTFLG = 1
  Rewrite [F:TCTR]
  If fstat
    Call ECR_TRACE("UTISTO26: error update TABCONTAINER : fstat="+num$(fstat)+" num:"+[F:TCTR]TCTRNUM,0) From GESECRAN
    GOK = 0
    Break
  Endif
Next

If GOK = 0 : Gosub TRT_END : Endif

Call ECR_TRACE("UTISTO26: end update TABCONTAINER",0) From GESECRAN

#Update STKTRS columns
Call ECR_TRACE("UTISTO26: update STKTRS",0) From GESECRAN
For [F:SRT] Where [F:SRT]LPNCOD = 0
  Case [F:SRT]SRTTYP
    When 1 : [F:SRT]LPNCOD = 3
    When 6 : [F:SRT]LPNCOD = 1
    When 3 : [F:SRT]LPNCOD = 2 : [F:SRT]CHGACC = 1
    When 5 : [F:SRT]LPNCOD = 3
    When Default : [F:SRT]LPNCOD = 1
  Endcase
  Rewrite [F:SRT]
  If fstat
    Call ECR_TRACE("UTISTO26: error update STKTRS : fstat="+num$(fstat)+" num:"+[F:SRT]SRTNUM,0) From GESECRAN
    GOK = 0
    Break
  Endif
Next

If GOK = 0 : Gosub TRT_END : Endif

Update [F:ITF] Where [F:ITF]LPNMGTCOD=0    With [F:ITF]LPNMGTCOD=1
If fstat
    Call ECR_TRACE("UTISTO26: error update ITMFACILIT : fstat="+num$(fstat)+" num:"+[F:SRT]SRTNUM,0) From GESECRAN
    GOK = 0
    Gosub TRT_END
Endif
Update [F:ITG] Where [F:ITG]LPNMGTCOD=0    With [F:ITG]LPNMGTCOD=1
If fstat
    Call ECR_TRACE("UTISTO26: error update STKTRS : fstat="+num$(fstat)+" num:"+[F:SRT]SRTNUM,0) From GESECRAN
    GOK = 0
    Gosub TRT_END
Endif

Update [F:SRU] Where [F:SRU]DACCTR = 0     With [F:SRU]DACCTR = 1
If fstat
    Call ECR_TRACE("UTISTO26: error update STKTRS : fstat="+num$(fstat)+" num:"+[F:SRT]SRTNUM,0) From GESECRAN
    GOK = 0
    Gosub TRT_END
Endif

Gosub TRT_END

#Close Local File [SRT]

#Stock transaction validation
#Gosub OPEN_FILES From FUNSTKTRS
#Call VAL_STKTRS(0,"",nomap) From FUNSTKTRS


Call ECR_TRACE("UTISTO26: Process End",0) From GESECRAN

End

$TRT_END
If GOK = 0
  Rollback
  Return
Else
  Commit
Endif

Return
########################################################################
# For execution upon patch integration                                 #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UTISTO26(APPLI)

End
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
#---
If filinfo(filpath("FIL","TABCONTAINER","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"TABCONTAINER") : End : Endif                  : # For Archive folder
If filinfo(filpath("FIL","STKTRS","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"STKTRS") : End : Endif                  : # For Archive folder
If filinfo(filpath("FIL","TABSTORUL","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"TABSTORUL") : End : Endif                  : # For Archive folder
If filinfo(filpath("FIL","ITMFACILIT","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"ITMFACILIT") : End : Endif                  : # For Archive folder
If filinfo(filpath("FIL","ITMCATEG","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"ITMCATEG") : End : Endif                  : # For Archive folder
#---
Call MAJ_UTISTO26(APPLI)
End

