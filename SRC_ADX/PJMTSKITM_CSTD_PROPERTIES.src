#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMTSKITM
###################################################################################################
# PROPERTIES
###################################################################################################
$KEYCONCAT
  Case [L]ARULE
    When "GET"       : Gosub KEYCONCAT_GET
  Endcase
Return

$KEYCONCAT_GET
  # Issue X3-68131 - 2018-02-12 by FGR : BEGIN
  #this.KEYCONCAT = this.OPPNUM + "~" + this.TASCOD + "~" + num$(this.ITTSEQ)
  this.KEYCONCAT = func PJMTSKITM_CSTD_PROGS.GET_KEYCONCAT(this.ACTX, this.OPPNUM, this.TASCOD, this.ITTSEQ)
  # Issue X3-68131 - 2018-02-12 by FGR : END
Return

###################################################################################################
$TCHPURFLG
  # Issue X3-26714 - 2017-04-06 by ALMON : START
  Case [L]ARULE
    When "GET"       : Gosub TCHPURFLG_GET
  Endcase
Return

$TCHPURFLG_GET
Local Integer PARPRIMET                # Issue X3-26714 - 2017-04-06 by ALMON
Local Integer PARSECMET                # Issue X3-26714 - 2017-04-06 by ALMON
Local Char    PARTCLCOD(GLONITG)       # Issue X3-26714 - 2017-04-06 by ALMON
Local Integer PARPURF                  # Issue X3-26714 - 2017-04-06 by ALMON
Local Integer IRET                     # Issue X3-63079 - 2017-01-05 by ALMON

  PARTCLCOD = AVOID.ACHAR
  # Issue X3-63079 - 2017-01-05 by ALMON : Change to IRET, this.TCHPURFLG is not used as a direct paramter due to type incompatibaility
  #IRET = fmet this.SET_COSTMETS(this.TASFCY, PARTCLCOD, this.ITMREF, PARPRIMET, PARSECMET, PARPURF)         # Issue X3-31898 - 2017-11-17 by FGR
  IRET = fmet this.SET_COSTMETS(this.STOFCY, PARTCLCOD, this.ITMREF, PARPRIMET, PARSECMET, PARPURF)          # Issue X3-31898 - 2017-11-17 by FGR
  this.TCHPURFLG = PARPURF
Return
# Issue X3-26714 - 2017-04-06 by ALMON : END

###################################################################################################
$ITTQTY
  Case [L]ARULE
    When "INIT"      : Gosub ITTQTY_INIT
    When "CONTROL"   : Gosub ITTQTY_CONTROL
  Endcase
Return

$ITTQTY_INIT
  this.ITTQTY = 1
Return

$ITTQTY_CONTROL
  If this.ITTQTY < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITTQTY", mess(232,2260,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$ITMREF
  Case [L]ARULE
    When "CONTROL"   : Gosub ITMREF_CONTROL
    When "PROPAGATE" : Gosub ITMREF_PROPAGATE
  Endcase
Return

$ITMREF_CONTROL
  # ---------------------------
  # Note FGR : this control can be done here because TASFCY is comming from the header
  #            and its value can't be changed here. In this class, this is considere as a constant.
  #Local File ITMFACILIT [ITF]         # Issue X3-31898 - 2017-11-17 by FGR : BEGIN : Not significant here now. Where with STOFCY at class level
  Local File ITMMASTER [ITM]
  # ---------------------------
  # Issue X3-31898 - 2017-11-17 by FGR : BEGIN : Not significant here now. Where with STOFCY at class level
  #Read [ITF]ITF0=this.ITMREF;this.TASFCY
  #If fstat Then
  #  [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMREF", func AFNC.MES2(mess(517,192,1), this.ITMREF, this.TASFCY), [V]CST_AERROR))
  #Endif
  # Issue X3-31898 - 2017-11-17 by FGR : END
  If this.snapshot.ITMREF <> this.ITMREF Then   # Issue X3-36823 - 2017-05-29 by EUHAV : BEGIN
    Read [ITM]ITM0=this.ITMREF
    If [F:ITM]ITMSTA <> 1 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMREF", func AFNC.MES1(mess(547,2260,1), this.ITMREF), [V]CST_AERROR))
    Endif
  Endif                                         # Issue X3-36823 - 2017-05-29 by EUHAV : END
  # ---------------------------
Return

$ITMREF_PROPAGATE
Local Char SMESSAGE(250)
Local Integer IRET
Local Decimal NQTY                     # Issue X3-18442/120906 - 2017-01-13 by FGR
Local Integer RETVAL                   # Issue X3-26714 - 2017-04-06 by ALMON
Local Integer PARPRIMET                # Issue X3-26714 - 2017-04-06 by ALMON
Local Integer PARSECMET                # Issue X3-26714 - 2017-04-06 by ALMON
Local Char PARTCLCOD (GLONITG)         # Issue X3-26714 - 2017-04-06 by ALMON
Local Integer PARPURF                  # Issue X3-26714 - 2017-04-06 by ALMON

  # ---------------------------
  Local File ITMMASTER [ITM]
  # ---------------------------
  Read [ITM]ITM0=this.ITMREF
  this.UOM = [F:ITM]STU
  this.ITMDLVFLG = [F:ITM]DLVFLG       # Issue X3-31898/X3-77206 - 2017-11-17 by FGR
  #
  #PARTCLCOD  = [F:ITM]TCLCOD
  #PARPRIMET  = 0
  #PARSECMET  = 0
  # ---------------------------
  #this.BUDVLTCOD = 0
  #this.BUDVLT2   = 0
  #this.MANUALBUD = 0
  # ---------------------------
  Call CHARGE_DEFITMDES("DES1AXX", this.ACTX.LAN, this.ITMREF, this.ITMDES1, "") From TRTX3_SYRA
  # ---------------------------
  If func ASYRFNC.ACTIV("ECC") = [V]CST_ATRUE Then
    Raz this.ECCVALMAJ
    Raz this.ECCVALMIN
    IRET = func PJMECCSTKTOOLS.STKINIECC(this.ACTX, this.ITMREF, 0, this.OPPCMP, this.ECCVALMAJ, SMESSAGE)
    If IRET <> [V]CST_AOK Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMREF", SMESSAGE, IRET))
    Endif
  Endif
  # ---------------------------
  If [F:ITM]STOMGTCOD = 2 Then       # Issue X3-21639/121055 - 2017-01-20 by FGR : If product is managed in stock
    # Issue X3-18442/120906 - 2017-01-13 by FGR : BEGIN
    NQTY = fmet this.SUM_SOQ_QTYSTU(func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(this.ACTX, this.OPPNUM, this.TASCOD), this.ITMREF)
    If NQTY <> 0 Then
      this.TCHACTION = "SOQQTY"
      this.SOQQTY = NQTY
    Endif
    # Issue X3-18442/120906 - 2017-01-13 by FGR : END
  Endif                              # Issue X3-21639/121055 - 2017-01-20 by FGR
  # ---------------------------
  # Issue X3-26714 - 2017-04-06 by ALMON : START
  # On Change of Product reload Cost Method Defaults, this.TCHPURFLG is not used as a direct paramter due to type incompatibaility
  #this.BUDVLTCOD = 1
  #this.BUDVLT2   = 1
  # Issue X3-31898 - 2017-11-17 by FGR : BEGIN : This part is wrong : must be only at $AINSERT_AUPDATE_CONTROL_BEFORE level
  #RETVAL = fmet this.SET_COSTMETS(this.TASFCY, PARTCLCOD, this.ITMREF, PARPRIMET, PARSECMET, PARPURF)
  #If RETVAL <> [V]CST_AERROR Then
  #  this.BUDVLTCOD = PARPRIMET
  #  this.BUDVLT2   = PARSECMET
  #  this.MANUALBUD = 0
  #  this.TCHPURFLG = PARPURF
  #Endif
  # Issue X3-26714 - 2017-04-06 by ALMON : END
  # Issue X3-31898 - 2017-11-17 by FGR : END
  # ---------------------------
Return

####################################################################################################
$ECCVALMAJ
  Case [L]ARULE
    When "CONTROL"   : Gosub ECCVALMAJ_CONTROL
    When "PROPAGATE" : Gosub ECCVALMAJ_PROPAGATE
  Endcase
Return

$ECCVALMAJ_CONTROL
Local Char SMESSAGE(250)
Local Integer IRET
Local Integer IRET2

  If this.ITMREF = AVOID.ACHAR and this.ECCVALMAJ <> AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ECCVALMAJ", mess(18,9804,1), [V]CST_AERROR))
  Else
    # Issue X3-31898 - 2017-11-17 by FGR : BEGIN : Not significant here now. Where with STOFCY at class level
    #IRET = func STKSOR_SYRA.CTLECCVAL(this.ACTX, this.ECCVALMAJ, this.TASFCY, this.ITMREF, 4, AVOID.ACHAR, [0/0/0], IRET2, SMESSAGE)
    #If IRET <> [V]CST_AOK Then
    #  [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ECCVALMAJ", SMESSAGE, IRET))
    #Endif
    # Issue X3-31898 - 2017-11-17 by FGR : END : Not significant here now. Where with STOFCY at class level
  Endif
Return

ECCVALMAJ_PROPAGATE
Local Char SMESSAGE(250)
Local Integer IRET

  If this.ITMREF <> AVOID.ACHAR and this.ECCVALMAJ <> AVOID.ACHAR Then
    IRET = func PJMECCSTKTOOLS.READECCMIN(this.ACTX, this.ITMREF, this.ECCVALMAJ, this.ECCVALMIN, SMESSAGE)
    If IRET <> [V]CST_AOK Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ECCVALMAJ", SMESSAGE, IRET))
    Endif
  Endif
Return

###################################################################################################
$SALITM
  Case [L]ARULE
    When "INIT"      : Gosub SALITM_INIT
  Endcase
Return

$SALITM_INIT
  this.SALITM = [V]CST_ANO
Return

