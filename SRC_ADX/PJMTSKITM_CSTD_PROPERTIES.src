###################################################################################################
$SOQQTY
  # Issue X3-18442/120906 - 2017-01-13 by FGR
  Case [L]ARULE
    When "CONTROL"   : Gosub SOQQTY_CONTROL
  Endcase
Return

$SOQQTY_CONTROL
  # Issue X3-31898 - 2017-11-17 by FGR : BEGIN
  If this.SOQQTY < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SOQQTY", mess(232,2260,1), [V]CST_AERROR))
  Endif
  # Issue X3-31898 - 2017-11-17 by FGR : END
  # Issue X3-18442/120906 - 2017-01-13 by FGR
  If this.SOQQTY <> this.snapshot.SOQQTY Then
    If this.TCHACTION <> "SOQQTY" Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SOQQTY", mess(196,2260,1), [V]CST_AERROR))
      Return
    Endif
  Endif
Return

###################################################################################################
$REQDAT
  # Issue X3-35762 - 2017-06-20 by FGR
  Case [L]ARULE
    When "PROPAGATE" : Gosub REQDAT_PROPAGATE
  Endcase
Return

$REQDAT_PROPAGATE
Local Date RDATE
Local Integer IRETURN_VALUE
Local Char SHMEMPTY(GLONHM)  # Issue X3-48424 - 2017-11-08 by SINGC/FGR

  # Issue X3-35762 - 2017-06-20 by FGR
  [L]ASTATUS = [V]CST_AOK
  # ----------------------
  # Issue X3-48424 - 2017-11-08 by SINGC : START
  #[L]IRETURN_VALUE = func OPPORPJM_CSTD_PROGS.CHECK_DATE_WITH_FCY(this, "REQDAT", this.TASFCY, this.REQDAT, 2, RDATE)                          # Issue X3-47483 - 2017-08-21 by SINGC
  #[L]IRETURN_VALUE = func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(this, "REQDAT", this.TASFCY, AVOID.ACHAR, this.REQDAT, 1, RDATE)             # Issue X3-47483 - 2017-08-21 by SINGC
  [L]IRETURN_VALUE = func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(this, "REQDAT", this.TASFCY, AVOID.ACHAR, AVOID.ACHAR, this.REQDAT, AVOID.ACHAR, 1, RDATE, SHMEMPTY)
  # Issue X3-48424 - 2017-11-08 by SINGC : END
  [L]ASTATUS = max([L]ASTATUS, [L]IRETURN_VALUE)
  If [L]IRETURN_VALUE < [V]CST_AERROR Then
    this.REQDAT = RDATE
  Endif
  # ----------------------
Return

###################################################################################################
$CSMTYP
  # Issue X3-31898 - 2017-11-17 by FGR
  Case [L]ARULE
    When "INIT"      : Gosub CSMTYP_INIT
  Endcase
Return

$CSMTYP_INIT
  # Issue X3-31898 - 2017-11-17 by FGR
  this.CSMTYP = 1  # Issue X3-98311 - 2018-06-26 by FGR : not this.ALLQTY = 1
Return

###################################################################################################
$ALLQTY
  # Issue X3-31898 - 2017-11-17 by FGR
  Case [L]ARULE
    When "INIT"      : Gosub ALLQTY_INIT
    When "CONTROL"   : Gosub ALLQTY_CONTROL
  Endcase
Return

$ALLQTY_INIT
  # Issue X3-31898 - 2017-11-17 by FGR
  this.ALLQTY = 0
Return

$ALLQTY_CONTROL
  # Issue X3-31898 - 2017-11-17 by FGR
  If this.ALLQTY < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ALLQTY", mess(232,2260,1), [V]CST_AERROR))
  Endif
  If this.ASTALIN = [V]CST_ANEW Then
    If this.TCHACTALLOC <> "ALLOC" and this.ALLQTY <> 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ALLQTY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Elsif this.ASTALIN = [V]CST_AUPD Then
    If this.TCHACTALLOC <> "ALLOC" and this.ALLQTY <> this.snapshot.ALLQTY Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ALLQTY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$WALLQTY
  # Issue X3-31898 - 2017-11-17 by FGR
  Case [L]ARULE
    When "GET"       : Gosub WALLQTY_GET
    When "CONTROL"   : Gosub WALLQTY_CONTROL
  Endcase
Return

$WALLQTY_GET
  # Issue X3-31898 - 2017-11-17 by FGR
  If this.ITTQTY - this.SOQQTY - this.DLVQTY < 0 Then
    this.WALLQTY = 0
  Else
    this.WALLQTY = this.ITTQTY - this.SOQQTY - this.DLVQTY
  Endif
Return

$WALLQTY_CONTROL
  # Issue X3-31898 - 2017-11-17 by FGR
  If this.WALLQTY < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("WALLQTY", mess(232,2260,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$SHTQTY
  # Issue X3-31898 - 2017-11-17 by FGR
  Case [L]ARULE
    When "GET"       : Gosub SHTQTY_GET
    When "CONTROL"   : Gosub SHTQTY_CONTROL
  Endcase
Return

$SHTQTY_GET
  # Issue X3-31898 - 2017-11-17 by FGR
  If this.WALLQTY < this.ALLQTY Then
    this.SHTQTY = 0
  Else
    this.SHTQTY = this.WALLQTY - this.ALLQTY
  Endif
Return

$SHTQTY_CONTROL
  # Issue X3-31898 - 2017-11-17 by FGR
  If this.SHTQTY < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SHTQTY", mess(232,2260,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$ALLSTA
  # Issue X3-31898 - 2017-11-17 by FGR
  Case [L]ARULE
    When "INIT"      : Gosub ALLSTA_INIT
  Endcase
Return

$ALLSTA_INIT
  # Issue X3-31898 - 2017-11-17 by FGR
  this.ALLSTA = 1
Return

###################################################################################################
$ALLTYP
  # Issue X3-31898 - 2017-11-17 by FGR
  Case [L]ARULE
    When "INIT"      : Gosub ALLTYP_INIT
    When "CONTROL"   : Gosub ALLTYP_CONTROL
  Endcase
Return

$ALLTYP_INIT
  # Issue X3-31898 - 2017-11-17 by FGR
  this.ALLTYP = 2
Return

$ALLTYP_CONTROL
  # Issue X3-31898 - 2017-11-17 by FGR
  If this.ALLTYP <> 2 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ALLQTY", mess(18,9804,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$ODLQTY
  # Issue X3-31898 - 2017-11-17 by FGR
  Case [L]ARULE
    When "INIT"      : Gosub ODLQTY_INIT
    When "CONTROL"   : Gosub ODLQTY_CONTROL
  Endcase
Return

$ODLQTY_INIT
  this.ODLQTY = 0
Return

$ODLQTY_CONTROL
  # Issue X3-31898 - 2017-11-17 by FGR
  If this.ODLQTY < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ODLQTY", mess(232,2260,1), [V]CST_AERROR))
  Endif
  If this.ASTALIN = [V]CST_ANEW Then
    If this.TCHACTALLOC <> "ALLOC" and this.ODLQTY <> 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ODLQTY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Elsif this.ASTALIN = [V]CST_AUPD Then
    If this.TCHACTALLOC <> "ALLOC" and this.ODLQTY <> this.snapshot.ODLQTY Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ODLQTY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$DLVQTY
  # Issue X3-31898 - 2017-11-17 by FGR
  Case [L]ARULE
    When "INIT"      : Gosub DLVQTY_INIT
    When "CONTROL"   : Gosub DLVQTY_CONTROL
  Endcase
Return

$DLVQTY_INIT
  this.DLVQTY = 0
Return

$DLVQTY_CONTROL
  # Issue X3-31898 - 2017-11-17 by FGR
  If this.DLVQTY < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("DLVQTY", mess(232,2260,1), [V]CST_AERROR))
  Endif
  If this.ASTALIN = [V]CST_ANEW Then
    If this.TCHACTALLOC <> "ALLOC" and this.DLVQTY <> 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("DLVQTY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Elsif this.ASTALIN = [V]CST_AUPD Then
    If this.TCHACTALLOC <> "ALLOC" and this.DLVQTY <> this.snapshot.DLVQTY Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("DLVQTY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$TDLQTY
  # Issue X3-31898 - 2017-11-17 by FGR
  Case [L]ARULE
    When "GET"       : Gosub TDLQTY_GET
    When "CONTROL"   : Gosub TDLQTY_CONTROL
  Endcase
Return

$TDLQTY_GET
  # Issue X3-31898 - 2017-11-17 by FGR
  If this.ITTQTY - this.SOQQTY - this.DLVQTY - this.ODLQTY < 0 Then
    this.TDLQTY = 0
  Else
    this.TDLQTY = this.ITTQTY - this.SOQQTY - this.DLVQTY - this.ODLQTY
  Endif
Return

$TDLQTY_CONTROL
  # Issue X3-31898 - 2017-11-17 by FGR
  If this.TDLQTY < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TDLQTY", mess(232,2260,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$DLVSTA
  # Issue X3-31898 - 2017-11-17 by FGR
  Case [L]ARULE
    When "INIT"      : Gosub DLVSTA_INIT
  Endcase
Return

$DLVSTA_INIT
  # Issue X3-31898 - 2017-11-17 by FGR
  this.DLVSTA = 1
Return

###################################################################################################
$STOFCY
  # Issue X3-65941 - 2018-01-12 by FGR
  Case [L]ARULE
    When "CONTROL"   : Gosub STOFCY_CONTROL
  Endcase
Return

$STOFCY_CONTROL
Local Char SFINTASFCY(GLONFCY)
Local Char SFINSTOFCY(GLONFCY)

  If fmet this.ACTX.ACACHE.AFCY.AGETVALNUM(this.STOFCY, "WRHFLG") <> [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STOFCY", this.STOFCY - ":" - mess(358,184,1), [V]CST_AERROR))
  Endif
  #
  SFINTASFCY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.TASFCY, "LEGCPY")  # I can do that here because TASFCY is comming from the task : considered as a constant
  SFINSTOFCY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.STOFCY, "LEGCPY")
  If SFINTASFCY <> SFINSTOFCY Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STOFCY", func AFNC.MES2(mess(1030,2260,1), this.TASCOD, this.STOFCY), [V]CST_AERROR))
  Endif
  #
  If this.ASTALIN = [V]CST_AUPD Then
    If this.STOFCY <> this.snapshot.STOFCY Then
      If this.ALLQTY > 0 or this.SOQQTY > 0 or this.ODLQTY > 0 or this.DLVQTY > 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STOFCY", mess(18,9804,1), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

###################################################################################################
$ITMDLVFLG
  # Issue X3-31898/X3-77206 - 2017-11-17 by FGR
  Case [L]ARULE
    When "INIT"      : Gosub ITMDLVFLG_INIT
  Endcase
Return

$ITMDLVFLG_INIT
  # Issue X3-31898/X3-77206 - 2017-11-17 by FGR
  this.ITMDLVFLG = [V]CST_ANO
Return

