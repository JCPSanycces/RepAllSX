#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------#
Subprog FLD_LIGNE(NUMLIG)
Value Integer NUMLIG
Local Integer I , K , LON , NOLIB , DIME , TTY
Local Char    TYP(GLONATY) , FLD(30) , TAB(GLONATB) , TBD(30) , BAL(80)

I = NUMLIG-1
TAB = [M:AOE2]FIL(I)

# Paramètres du champ
Raz DIME , NOLIB , LON
Case left$([M:AOE2]FLD(I),1)
 When "/","*","=","'",'"',""
  TYP = 'A'
  LON = 30
  BAL = [M:AOE2]TYP(I)+"__"+num$(NUMLIG)
  TTY = 7
 When Default 
  FLD = [M:AOE2]FLD(I)
  K = instr(1,FLD,"(")
  If K
   DIME = val(right$(FLD,K+1))
   FLD = left$(FLD,K-1)
   BAL = FLD+"_"+num$(DIME)
  Else
   BAL = FLD
  Endif
  Read [ATZ]CODZONE = [M:AOE2]FIL(I) ; FLD
  If !fstat
   TTY = [F:ATY]TYPTYP
   TYP = [F:ATZ]CODTYP
   Read [ATY]CODTYP = [F:ATZ]CODTYP
   If [F:ATY]LNGTYP<>0
    LON = [F:ATY]LNGTYP
   Else
    LON = [F:ATZ]LONG
   Endif
   If [F:ATY]TYPTYP=1
    If [F:ATY]NOLIB<>0
     NOLIB = [F:ATY]NOLIB
    Else
     NOLIB = [F:ATZ]NOLIB
    Endif
   Endif
   If TYP="ADI"
    Read [AMP]CODPAR=2;TAB;FLD;"ADI"
    If !fstat
     If find(left$([F:AMP]VALPAR,1),"'",'"')
      TBD = num$(evalue([F:AMP]VALPAR))
     Else
      TBD = num$([F:AMP]VALPAR)
     Endif
    Endif
   Endif
  Endif
Endcase
If [M:AOE2]BAL(I)<>""
 BAL = [M:AOE2]BAL(I)
Else
 BAL = [F:ATB]ABRFIC+"_"+BAL
Endif

If left$([M:AOE2]FLD(I),1)<>"/"
 # Caractéristiques champ normal
 K = find([M:AOE2]TYP(I),[M:AOE1]FLGREC)
 # On n'exporte plus les champs vides (même pas avec <balise/>)
 Case TYP
  When "ATX","AXX","AX1","AX2","AX3"
   Wrseq 'If LIGNE<>""'
  When Default
   Case TTY
    When 8 : # Date
     Wrseq 'If LIGNE<>"" and left$(LIGNE,4)<>"0000"'
    When 1 : # Menu local
     If NOLIB=1
      Wrseq 'If LIGNE<>""'
     Else
      Wrseq 'If LIGNE<>"" and val(LIGNE)<>0'
     Endif
    When 2,3,4,5,6 : # Numérique
     Wrseq 'If LIGNE<>"" and val(LIGNE)<>0'
    When Default
     Wrseq 'If LIGNE<>""'
   Endcase
 Endcase
 Wrseq ' LIGXML ='-"'"+space$((5*[M:AOE1]FLGLEV(K-1))+5)+'<'+BAL+'>'+"'"
 Wrseq " Call MODVAL(LIGNE) From INTRUTILA" : # Valeur du champ
 Wrseq " Wrseq LIGXML+LIGNE+'</"+BAL+">' Using  [AEXP]" : # Balise de fin d'enregistrement
 Wrseq 'Endif'
Endif
End

#----------------------------------------------------------#
Subprog FIN_GROUPE(REC,DIF)
Value Char    REC , DIF
Local Integer K
If REC="EXP"
 Gosub SET_FOOT
 Wrseq DIF;'LIGXML ='-"'"+LIGNE1+"'"
Else
 K = find(REC,[M:AOE1]FLGREC)
 Wrseq DIF;'LIGXML ='-"'"+space$(5*[M:AOE1]FLGLEV(K-1))+'</'+REC+'>'+"'"
Endif
Wrseq DIF;'Wrseq LIGXML Using  [AEXP]'
End

#----------------#
$SET_FOOT
Local Char LIGNE1(255)
LIGNE1 = '</p:'+func AEXPSCHEMA.PUBLI([M:AOE0]EXT)+'>'
Return

#----------------------------------------------------------#
Subprog DEB_GROUPE(REC,DIF)
Value Char    REC , DIF
Local Char    LIGNE(250) , FICHIER(GDIMFIC)
Local Integer I , K
If REC="EXP"
 Gosub SET_HEAD
 Wrseq DIF;'LIGXML ='-"'"+LIGNE1+"'"
 Wrseq DIF;'Wrseq LIGXML Using  [AEXP]'
 Wrseq DIF;'LIGXML ='-"'"+LIGNE2+"'"
 Wrseq DIF;'Wrseq LIGXML Using  [AEXP]'
Else 
 K = find(REC,[M:AOE1]FLGREC)
 Wrseq DIF;'LIGXML ='-"'"+space$(5*[M:AOE1]FLGLEV(K-1))+'<'+REC+'>'+"'"
 Wrseq DIF;'Wrseq LIGXML Using  [AEXP]'
Endif
End

#-----------------------#
$SET_HEAD
Local Char LIGNE1(255) , LIGNE2(255)
LIGNE1 = '<?xml version="1.0" encoding="'+func AEXPSCHEMA.ENCODING([M:AOE1]CODDBA,[M:AOE1]OPTCHA)+'" ?>'
LIGNE2 = '<p:'+func AEXPSCHEMA.PUBLI([M:AOE0]EXT)
LIGNE2 -= 'xmlns:p="http://com.sage/X3/'+func AEXPSCHEMA.PUBLI([M:AOE0]EXT)+'"'
LIGNE2 -= 'xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"'
LIGNE2 -= 'xsi:schemaLocation="http://com.sage/X3/'+func AEXPSCHEMA.PUBLI([M:AOE0]EXT)-func AEXPSCHEMA.PUBLI([M:AOE0]EXT)+'.xsd'
LIGNE2 -= '">'
Return

#----------------------------------------------------------#
Subprog DECODE_XML(LIGNE)
Variable Char LIGNE
Gosub SET_CODE
For I=1 To 4
 K = instr(1,LIGNE,CX(I))
 While K
  LIGNE = left$(LIGNE,K-1)+CA(I)+right$(LIGNE,K+len(CX(I)))
  K = instr(K,LIGNE,CX(I))
 Wend
Next I
End

$SET_CODE
Local Char CA(1)(1..4) , CX(6)(1..4)
CA(1) = "<" : CX(1) = "&lt;"
CA(2) = ">" : CX(2) = "&gt;"
CA(3) = '"' : CX(3) = "&quot;"
CA(4) = '&' : CX(4) = "&amp;"
Return
