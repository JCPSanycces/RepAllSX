#<AdxTL>@(#)10.0.0.0 $Revision$
######################################################################################
## Xtend: Génération fiche Lien dynamique
#  Version 0001
######################################################################################
#    XMLGEN 
######################################################################################
Subprog XMLGEN(DOSORG, FCYORG, TIMSTP, OPTION, ELTCOD,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char FCYORG        #     Code site Xtend
Value Char TIMSTP        #     Référence time stamp 20061012093014
Value Char OPTION()(1..) #     Option 
                         #       'TRADET'=Trace détaillée
Value Char ELTCOD        #     Code élément
Variable Integer RET     #     1 Ok; 0: Ko ; 2: avertissementLocal Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer WI, WNBREC
Local Integer TRADETFLG   : TRADETFLG   = find("TRADET",OPTION)
Local Char WSTR1(250)

RET=1 

Call TITOBJ("AYL","", WSTR1) From CONTOBJ
Call ECR_TRACE(mess(38,7900,1)-WSTR1,0) From GESECRAN 

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS

If DOSORG=nomap 
 Local File AYTELTDLK [AYL1] 
 Local File ATEXTE    [ATX1] 
 Local File AYTLINES  [AYN1] 
 Local File ATEXTRA   [AXX1] 
Else 
 Local File =[L]DOSORG+".AYTELTDLK"  [AYL1] 
 Local File =[L]DOSORG+".ATEXTE"     [ATX1] 
 Local File =[L]DOSORG+".AYTLINES"   [AYN1] 
 Local File =[L]DOSORG+".ATEXTRA"    [AXX1]
Endif 
Default File "[AYL1],[ATX1],[AYN1]"

#
Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=TIMSTP
XT_XMLID="DLK"
Gosub XMLF_INI2 From AYTGEN : If XT_RET=0 : RET=0 : Goto FFINALLY : Endif 
#
XT_TY="ELMTS"  : XT_ID=XT_XMLID                                            : Gosub XMLF_ADD From AYTGEN
#
For [AYL1]AYL0 Where FCYCOD=FCYORG
 WNBREC+=1
 If TRADETFLG : Call ECR_TRACE(mess(10,7910,1)-":"-[F]DLKCOD,0) From GESECRAN : Endif
 #
 XT_TY="ELMT"  : XT_ID=[F]DLKCOD     
 Call LECTEXTRA(XT_VAL,"AYTELTDLK","INTIT",[F]FCYCOD,[F]DLKCOD) From AYTUTIA : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="POSTFORCE"     : XT_VAL=num$([F]POSTFORCE)
                                      XT_LAB=mess([F]POSTFORCE,1,1)        : Gosub XMLF_ADD From AYTGEN
 If [F]PAGSAM=1
   XT_TY="FLD"   : XT_ID="PAGCOD"     : XT_VAL=[F]PAGCOD                     : Gosub XMLF_ADD From AYTGEN
 Endif
 XT_TY="FLD"   : XT_ID="LOGMOD"     : XT_VAL=num$([F]LOGMOD)
                                      XT_LAB=mess([F]LOGMOD,1,1)             : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="PAGSAM"     : XT_VAL=num$([F]PAGSAM)
                                      XT_LAB=mess([F]PAGSAM,1,1)        : Gosub XMLF_ADD From AYTGEN

 XT_TY="TAB"     : XT_ID="PARNBR"     : XT_VAL="Parameters"                  : Gosub XMLF_ADD From AYTGEN
   For WI=0 To [F]PARNBR-1
     XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
     XT_TY="COL"  : XT_ID="PAR"        : XT_VAL=[F]PAR(WI)                     : Gosub XMLF_ADD From AYTGEN
     XT_TY="COL"  : XT_ID="PARVAL"     : XT_VAL=[F]PARVAL(WI)                  : Gosub XMLF_ADD From AYTGEN
   Next
 #

 XT_TY="FLD"   : XT_ID="ENTCOD"     : XT_VAL=[F]ENTCOD                     : Gosub XMLF_ADD From AYTGEN
 If [F]ENTCOD<>""
     ### Sélection
     XT_TY="FLD"   : XT_ID="SELBLCOPT"  : XT_VAL=num$([F]SELBLCOPT)
                                          XT_LAB=mess([F]SELBLCOPT,7924,1)       : Gosub XMLF_ADD From AYTGEN
     #
     XT_TY="FLD"   : XT_ID="SELTYP"     : XT_VAL=num$([F]SELTYP)
                                      XT_LAB=mess([F]SELTYP,7916,1)        : Gosub XMLF_ADD From AYTGEN
     # Sélection requete ou code
     If find([F]SELTYP,2,3)    
       # Chps sélection
         XT_TY="TAB"   : XT_ID="NUM30"    :  XT_VAL="Selection"                   : Gosub XMLF_ADD From AYTGEN
         For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=4
&                       and LINCOD = toupper([F:AYL1]DLKCOD) and  LINTYP = 30
            Gosub SEL_DET From SUBAYBGEN
         Next
           
     Endif  
     # Tri
     XT_TY="FLD"   : XT_ID="SRTTYP"     : XT_VAL=num$([F]SRTTYP)
                                          XT_LAB=mess([F]SRTTYP,7917,1)         : Gosub XMLF_ADD From AYTGEN
     If [F]SRTTYP=2  
         XT_TY="TAB"   : XT_ID="NUM31"      : XT_VAL="Tri"                        : Gosub XMLF_ADD From AYTGEN
         For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=4
&                       and LINCOD = toupper([F:AYL1]DLKCOD) and  LINTYP = 31
            Gosub SRT_DET From SUBAYBGEN
         Next
     Endif

    ### Valeur param. Accès sous-programme
    XT_TY="TAB"   : XT_ID="NUM42"      :  XT_VAL="SpgParameterValue"               : Gosub XMLF_ADD From AYTGEN
    For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=4
&                       and LINCOD = toupper([F:AYL1]DLKCOD) and  LINTYP = 42
       XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
       XT_TY="COL"  : XT_ID="PARCOD"     : XT_VAL=[F:AYN1]PARCOD                 : Gosub XMLF_ADD From AYTGEN
       # Type valeur
       XT_TY="COL"  : XT_ID="VALTYP"     : XT_VAL=num$([F]VALTYP)
                                           XT_LAB=mess([F]VALTYP,7925,1)         : Gosub XMLF_ADD From AYTGEN
       Case [F]VALTYP
       When 1,3    
         XT_TY="COL"  : XT_ID="VALEUR"   : U_HEXTOTXT=[F:AYN1]VALEUR             : Gosub U_TXTTOHEX From SUBAPSUTI
                                           XT_VAL=U_TXTTOHEX                     : Gosub XMLF_ADD From AYTGEN
       When 2
         XT_TY="COL"  : XT_ID="VALBLCCOD" : XT_VAL=[F:AYN1]VALBLCCOD              : Gosub XMLF_ADD From AYTGEN
         XT_TY="COL"  : XT_ID="VALFIELNKE": XT_VAL=[F:AYN1]VALFIELNKE             : Gosub XMLF_ADD From AYTGEN
         XT_TY="COL"  : XT_ID="VALFIECOD" : XT_VAL=[F:AYN1]VALFIECOD              : Gosub XMLF_ADD From AYTGEN
       Endcase
    Next
 Endif  # fin sélection
 
 # Action
 XT_TY="FLD"   : XT_ID="ACTCOD"     : XT_VAL=[F]ACTCOD                     : Gosub XMLF_ADD From AYTGEN
 If [F]ACTCOD<>""


    # check champ web
     XT_TY="FLD"   : XT_ID="ACTCHK"     : XT_VAL=num$([F]ACTVERCHP)                     : Gosub XMLF_ADD From AYTGEN

#    XT_TY="FLD"   : XT_ID="ACTRUN"     : XT_VAL=num$([F]ACTRUN)
#                                         XT_LAB=mess([F]ACTRUN,7928,1)          : Gosub XMLF_ADD From AYTGEN
    XT_TY="TAB"   : XT_ID="NUM41"      :  XT_VAL="ActionParameterValue"               : Gosub XMLF_ADD From AYTGEN
    For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=4
&                       and LINCOD = toupper([F:AYL1]DLKCOD) and  LINTYP = 41
       XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
       XT_TY="COL"  : XT_ID="PARCOD"     : XT_VAL=[F:AYN1]PARCOD                 : Gosub XMLF_ADD From AYTGEN
       # Type valeur
       XT_TY="COL"  : XT_ID="VALTYP"     : XT_VAL=num$([F]VALTYP)
                                           XT_LAB=mess([F]VALTYP,7925,1)         : Gosub XMLF_ADD From AYTGEN
       Case [F]VALTYP
       When 1,3,4    
         XT_TY="COL"  : XT_ID="VALEUR"   : U_HEXTOTXT=[F:AYN1]VALEUR             : Gosub U_TXTTOHEX From SUBAPSUTI
                                           XT_VAL=U_TXTTOHEX                     : Gosub XMLF_ADD From AYTGEN
       When 2
         XT_TY="COL"  : XT_ID="VALBLCCOD" : XT_VAL=[F:AYN1]VALBLCCOD              : Gosub XMLF_ADD From AYTGEN
         XT_TY="COL"  : XT_ID="VALFIELNKE": XT_VAL=[F:AYN1]VALFIELNKE             : Gosub XMLF_ADD From AYTGEN
         XT_TY="COL"  : XT_ID="VALFIECOD" : XT_VAL=[F:AYN1]VALFIECOD              : Gosub XMLF_ADD From AYTGEN
       Endcase
    Next

    XT_TY="FLD"   : XT_ID="SUIPRG"     : XT_VAL=num$([F]SUIPRG)
                                         XT_LAB=mess([F]SUIPRG,1,1)        : Gosub XMLF_ADD From AYTGEN
    If [F]SUIPRG=2
      XT_TY="FLD"   : XT_ID="SUIPRGENT"     : XT_VAL=[F]SUIPRGENT               : Gosub XMLF_ADD From AYTGEN
      XT_TY="FLD"   : XT_ID="SUIPRGFLD"     : XT_VAL=[F]SUIPRGFLD               : Gosub XMLF_ADD From AYTGEN
    Else
      XT_TY="TAB"   : XT_ID="SUINBR"         :  XT_VAL="NextDynLink"            : Gosub XMLF_ADD From AYTGEN
      For WI=0 To [F]SUINBR-1
        XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
        XT_TY="COL"  : XT_ID="SUIDLK"        : XT_VAL=[F]SUIDLK(WI)               : Gosub XMLF_ADD From AYTGEN
      Next
    Endif
    # ajout page si erreur
    XT_TY="FLD"   : XT_ID="PAGERR"     : XT_VAL=[F]DLKERR                     : Gosub XMLF_ADD From AYTGEN
 Endif
Next


$FFINALLY
Gosub XMLF_CL  From AYTGEN
Close Local File [AYL1],[ATX1],[AYN1],[AXX1]
Call ECR_TRACE(mess(146,7900,1)-num$(WNBREC),0) From GESECRAN
End

