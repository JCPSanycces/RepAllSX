Local Char    ACTION(10)(0..200), REFNUM(50)
Local Char    NCTRNUM(20)(0..200)
Local Integer DEM, NSTA(0..200), NSTRDAY(0..200), NENDDAY(0..200), NUPDNUM(0..200), NUID(0..200)
Local Date    NSTRDAT(0..200), NENDDAT(0..200)
Local Char    NTIM(10)(0..200), NCMT(50)(0..200), NDES(50)(0..200), ERRMES(50)(0..200), NCMT2(50)(0..200)
Local Decimal NNBRDAY(0..200)
Local Integer NTYPPGN(0..200), NFLGANU(0..200)
Local Char    NRPL(50)(0..200), NRPLNAM(50)(0..200)
Local Char    NURLBACK (50)

#ACTION(0)="SEND" : REFNUM="200800000287" : DEM=31402
#NCTRNUM="ASN00000108" : NSTRDAT=[15/09/2011]:NSTRDAY=1 : NENDDAT=[15/09/2011]:NENDDAY=1
#NNBRDAY=1 : NTIM="CSS" : NDES="Congés sans solde"
#ACTION(0)="CAL" : REFNUM="200900000313" : DEM=0
#NCTRNUM="" : NSTRDAT=[04/10/2011]:NSTRDAY=1 : NENDDAT=[04/10/2011]:NENDDAY=1
#NNBRDAY=1 : NTIM="CSS" : NDES="Congés sans solde"
#Call SETDEMCONGE2( ACTION,REFNUM,DEM,NCTRNUM,NSTRDAT,NSTRDAY,NENDDAT,NENDDAY,NNBRDAY
#&                   , NTIM,NDES,NSTA,NCMT,NUID,NUPDNUM, ERRMES
#&                   , NTYPPGN,NFLGANU,NRPL,NRPLNAM
#&                   , NURLBACK, NCMT2
#&                   )

Local Char    PEMP,PCTR,PTYPAPP
Local Char    TIM(5)(0..50), DES(50)(0..50), DSG(50)(0..50)
Local Integer ACS(0..50) , PGN(0..50) , CMT(0..50)
Local Integer VLT(0..50) # Valorisation 1=RTT 2=CP
Local Integer DSPSLD(0..50)
Local Char    CTRTIM(50)(0..50)
PEMP="200800000287" : PCTR="ASN00000109" : PTYPAPP=""
Call GETALLTYPCNG(PEMP,PCTR,PTYPAPP,TIM,DES,DSG,ACS,PGN,CMT,VLT,DSPSLD,CTRTIM)

End
################################################################################
#
# - Initialisation globale du paramètre MOIPAY
# - Retour date de saisie minimum des congés
#
################################################################################

Subprog GETDATPAY(MATRICULE,CONTRAT,DATEMIN)
Value    Char    MATRICULE
Value    Char    CONTRAT
Variable Date    DATEMIN

Raz GMOIPAY , DATEMIN

#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
#If !clalev([F:CTR]) : Local File EMPLOCTR [CTR] : Endif
#MIPEA - 2017-06-07- US X3-43919- END

# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#Filter [CTR] Where REFNUM=MATRICULE
#&                 & find(CONTRAT,"",[CTR]CTRNUM)<>0
#&                 & [CTR]CTRDAT<=date$
#&                 & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=date$)
#MIPEA - 2017-06-07- US X3-43919- START
Filter [HRCTR] Where REFNUM=MATRICULE
&                 & find(CONTRAT,"",[HRCTR]CTRNUM)<>0
&                 & ([HRCTR]CTRDAT<=date$ | ([HRCTR]FLGRET=2 & [HRCTR]RETDATEFF<=date$))
&                 & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=date$)
# Fin MABON
Read [HRCTR]CTR1 First
#Filter [CTR] Where REFNUM=MATRICULE
#&                 & find(CONTRAT,"",[CTR]CTRNUM)<>0
#&                 & ([CTR]CTRDAT<=date$ | ([CTR]FLGRET=2 & [CTR]RETDATEFF<=date$))
#&                 & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=date$)
## Fin MABON
#Read [CTR]CTR1 First
#MIPEA - 2017-06-07- US X3-43919- END
#CONTRAT = [CTR]CTRNUM  - 64037

#64942 : Avant appel func AFNC.PARAM#
#66099
#MIPEA - 2017-06-07- US X3-43919- START
GMOIPAY=gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",[HRCTR]ETRFCY))
#GMOIPAY=gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",[CTR]ETRFCY))
#MIPEA - 2017-06-07- US X3-43919- END
#68318
#If GMOIPAY=[0/0/0] : GMOIPAY=eomonth(date$) : Endif
If GMOIPAY=[0/0/0] : GMOIPAY=gdat$(01,month(date$),year(date$)) : Endif

If val(GMOIPAY) > 0
#MIPEA - 2017-06-07- US X3-43919- START
 DATEMIN = GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[HRCTR]ETRFCY))
# DATEMIN = GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[CTR]ETRFCY))
#MIPEA - 2017-06-07- US X3-43919- END
Endif

#MIPEA - 2017-06-07- US X3-43919- START
Filter [HRCTR]
#Filter [CTR]
#MIPEA - 2017-06-07- US X3-43919- END

End


#-------------------------------------------------------------------------------
$ACTION
Case [L]ACTION
 When "WEB_CREATE"    : Gosub WEB_CREATE
Endcase
Return

#-------------------------------------------------------------------------------
$AUTORIS

mkstat = 0 : # 70200

If [V]GFONCTION<>"PRHDCG"
 [V]GFONCTION="PRHDCG"
 Call AUTORIS From EXEFNC
Endif

If GNBAUZ = 0
 GMESSAGE = mess(74,100,1)-"("+GFONCTION+")" : # Fonction non autorisée
 GERR = 1
Endif

# / 71093
If dim(GUSR_SRVAUT) < 1
 Global Char    GUSR_SRVAUT(GLONAUS)
Endif
If GUSR_SRVAUT <> GUSER
 GUSR_SRVAUT = GUSER
 Call AUTSRV From GLOBPAY
Endif
#  71093 /
# SEGAY - 11/10/11 - FQ76996 -
#If !instr(1,[V]GUSRAUZ(1),"1")
# Call CHECK_SUBORD([L]MATRICULE,"",GFLXPORDCG,[31/12/9999]) From DIVPAYE
#Endif
Call CHECK_SUBORD([L]MATRICULE,"",GFLXPORDCG,[31/12/9999]) From DIVPAYE
# END - FQ76996 -
If mkstat
 GMESSAGE = mess(215,195,1)-"-"-GMESSAGE  : #Sélection salarié
Endif


#If !instr(1,[V]GUSRAUZ(1),"1") & [L]MATRICULE<>[V]GREFNUM
#If !instr(1,[V]GUSRAUZ(1),"1") & [L]MATRICULE<>[V]GREFNUM & !GERR
# [V]GMESSAGE="("+mess(124,142,1)+")"-mess(31,702,1)
#  # Habilitations-Vous n'avez pas les droits pour ce salarié
# [V]GERR    =1
#Elsif [V]GUSRACS<2
# If !clalev([F:ID]) : Local File EMPLOID [ID] : Endif
# Read [ID]ID0=[L]MATRICULE
# If [F:ID]CODACS>""
#  If !clalev([F:ACC]) : Local File ACCES [ACC] : Endif
#  Look [ACC]CODACC=[V]GUSER;[F:ID]CODACS
#  If fstat
#   [V]GMESSAGE="("+mess(25,115,1)+")"-mess(31,702,1)
#   # Code d'accès-Vous n'avez pas les droits pour ce salarié
#   [V]GERR    =1
#  Endif
# Endif
#Endif
Return

################################################################################
#
# Renvoie le liste des demandes
# pour STATUTS mettre les STA séparés par des virgules : ex : "2,4,6"
#
################################################################################

Subprog GETDEMCNG( MATRICULE,CONTRAT,DATDEB,DATFIN,STATUTS,CTRNUM,STRDAT,STRDAY,ENDDAT
&                , ENDDAY,TIM,DES,STA,NBRDAY
&                , UID,UPDNUM,TYPPGN,FLGANU,RPL,RPLNAM
&                , DEM
&                )
Value    Char    MATRICULE(), CONTRAT(), STATUTS()
Value    Date    DATDEB, DATFIN
Variable Char    CTRNUM()(0..), TIM()(0..), DES()(0..)
Variable Date    STRDAT(0..), ENDDAT(0..)
Variable Integer STRDAY(0..),  ENDDAY(0..), STA(0..)
Variable Decimal NBRDAY(0..)
Variable Integer UID(0..), UPDNUM(0..), TYPPGN(0..), FLGANU(0..)
Variable Char    RPL()(0..), RPLNAM()(0..)
Variable Integer DEM(0..)

Gosub AUTORIS
If [V]GERR : End : Endif

If !clalev([F:DCG]) : Local File DEMCONGE [DCG] : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
#If !clalev([F:CTR]) : Local File EMPLOCTR [CTR] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If !clalev([F:TIM]) : Local File TIMCOD   [TIM] : Endif
If !clalev([F:ID])  : Local File EMPLOID  [ID]  : Endif

Local Shortint N
Local Integer  JJ,MM,AA
Local Char     CRITERE(250)

If [L]STATUTS>""   : [L]CRITERE-="& find(STA,"+[L]STATUTS+")<>0"             : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If [L]CONTRAT>""   : [L]CRITERE-="& [HRCTR]CTRNUM='"+[L]CONTRAT+"'"            : Endif
If [V]GUSRFCY<>"\" : [L]CRITERE-="& find([HRCTR]ETRFCY,[V]GUSRFCY)"            : Endif
#If [L]CONTRAT>""   : [L]CRITERE-="& [CTR]CTRNUM='"+[L]CONTRAT+"'"            : Endif
#If [V]GUSRFCY<>"\" : [L]CRITERE-="& find([CTR]ETRFCY,[V]GUSRFCY)"            : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If [L]CRITERE=""   : [L]CRITERE="1=1" : Else [L]CRITERE=right$([L]CRITERE,4) : Endif

# US-2832
Gosub SET_VAR_ISCP

#Link [DCG] With [CTR]CTR0(1)=REFNUM
#&             , [TIM]TIM0   =TIM
#&            As [LNK]
#For [LNK]DCG0 Where find(CTRNUM,"",[CTR]CTRNUM)<>0 & [CTR]CTRDAT<=ENDDAT & UID>0
#&                 & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=STRDAT) & REFNUM=[L]MATRICULE
#&                 & STRDAT<=[L]DATFIN & ENDDAT>=[L]DATDEB & evalue([L]CRITERE)
#&                 & find([CTR]ETRSRV,[V]GAUTSRV)
# Tri sur le numéro de demande
#MIPEA - 2017-06-07- US X3-43919- START
Link [DCG] With [HRCTR]CTR0(1)=REFNUM
&             , [TIM]TIM0   =GCURLEG;TIM
&            As [LNK] Order By Key CLE = [DCG]DEM Desc ; [DCG]REFNUM
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#For [LNK] Where find(CTRNUM,"",[CTR]CTRNUM)<>0 & [CTR]CTRDAT<=ENDDAT & UID>0
#&                 & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=STRDAT) & REFNUM=[L]MATRICULE
#&                 & STRDAT<=[L]DATFIN & ENDDAT>=[L]DATDEB & evalue([L]CRITERE)
#&                 & find([CTR]ETRSRV,[V]GAUTSRV)
For [LNK] Where find(CTRNUM,"",[HRCTR]CTRNUM)<>0 & ([HRCTR]CTRDAT<=ENDDAT | ([HRCTR]FLGRET=2 & [HRCTR]RETDATEFF<=ENDDAT)) & UID>0
&                 & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=STRDAT) & REFNUM=[L]MATRICULE
&                 & STRDAT<=[L]DATFIN & ENDDAT>=[L]DATDEB & evalue([L]CRITERE)
&                 & find([HRCTR]ETRSRV,[V]GAUTSRV)
#Link [DCG] With [CTR]CTR0(1)=REFNUM
#&             , [TIM]TIM0   =TIM
#&            As [LNK] Order By Key CLE = [DCG]DEM Desc ; [DCG]REFNUM
## FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
##For [LNK] Where find(CTRNUM,"",[CTR]CTRNUM)<>0 & [CTR]CTRDAT<=ENDDAT & UID>0
##&                 & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=STRDAT) & REFNUM=[L]MATRICULE
##&                 & STRDAT<=[L]DATFIN & ENDDAT>=[L]DATDEB & evalue([L]CRITERE)
##&                 & find([CTR]ETRSRV,[V]GAUTSRV)
#For [LNK] Where find(CTRNUM,"",[CTR]CTRNUM)<>0 & ([CTR]CTRDAT<=ENDDAT | ([CTR]FLGRET=2 & [CTR]RETDATEFF<=ENDDAT)) & UID>0
#&                 & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=STRDAT) & REFNUM=[L]MATRICULE
#&                 & STRDAT<=[L]DATFIN & ENDDAT>=[L]DATDEB & evalue([L]CRITERE)
#&                 & find([CTR]ETRSRV,[V]GAUTSRV)
#MIPEA - 2017-06-07- US X3-43919- END
# Fin MABON
 If N>=dim([L]CTRNUM)
  [V]GERR=1
  Break
 Endif

#MIPEA - 2017-06-07- US X3-43919- START
  [L]CTRNUM(N)=[F:HRCTR]CTRNUM
#  [L]CTRNUM(N)=[F:CTR]CTRNUM
#MIPEA - 2017-06-07- US X3-43919- END
  [L]STRDAT(N)=[F:DCG]STRDAT
  [L]STRDAY(N)=[F:DCG]STRDAY
  [L]ENDDAT(N)=[F:DCG]ENDDAT
  [L]ENDDAY(N)=[F:DCG]ENDDAY

  # US-2832
  If [F:TIM]VLTEVT=2 & [F:TIM]CATTIM=3 & func DIVPAYE.IS_CP([F:DCG]TIM,W_CPA,W_CPE)
    [L]TIM(N)="CP" : # en dur !
  Else
    [L]TIM(N)=[F:DCG]TIM
  Endif
  [L]DES   (N)=[F:TIM]DES
  [L]STA   (N)=[F:DCG]STA
  [L]NBRDAY(N)=[F:DCG]NBRDAY
  [L]UID   (N)=[F:DCG]UID
  [L]UPDNUM(N)=[F:DCG]UPDNUM
  [L]TYPPGN(N)=[F:DCG]TYPPGN
  [L]RPL   (N)=[F:DCG]RPL
  Read [F:ID]ID0 = [F:DCG]RPL
  If !fstat
   [L]RPLNAM(N)=[F:ID]SRN-[F:ID]NAM
  Endif

  #64942 : Avant appel func AFNC.PARAM#
  #66099
#MIPEA - 2017-06-07- US X3-43919- START
  GMOIPAY=gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",[HRCTR]ETRFCY))
#  GMOIPAY=gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",[CTR]ETRFCY))
#MIPEA - 2017-06-07- US X3-43919- END
  #68318
  #If GMOIPAY=[0/0/0] : GMOIPAY=eomonth(date$) : Endif
  If GMOIPAY=[0/0/0] : GMOIPAY=gdat$(01,month(date$),year(date$)) : Endif
# FQ88082 FQ81317 - SEGAY 03/04/12
#  If [F:DCG]STRDAT < GMOIPAY | [F:DCG]STA <> 3

#DEHEN - 2016-10-25 - JIRRA 2266 : Sub Task 2312 - START
#Original Code
#  If [F:DCG]STRDAT < GMOIPAY | [F:DCG]STA <> 3 | !(func GETCONTACCES_ECM([F:TIM]ACS,1))
#    [L]FLGANU(N)=0
#  Else
#   [L]FLGANU(N)=1
#  Endif
  # create a function for [F:DCG]STRDAT < GMOIPAY | [F:DCG]STA = 3 | [F:DCG]STA = 2 | !(func GETCONTACCES_ECM([F:TIM]ACS,1))
  #DEHEN - JIRA X3PEOP-2312 - 2016-10-27 - START
  Gosub IS_CANCELED
  #If [F:DCG]STRDAT < GMOIPAY | [F:DCG]STA = 3 | [F:DCG]STA = 2 | !(func GETCONTACCES_ECM([F:TIM]ACS,1))
  If !IS_CANCELED
    [L]FLGANU(N)=0
  Else
   [L]FLGANU(N)=1
  Endif
  #DEHEN - JIRA X3PEOP-2312 - 2016-10-27 - END
#DEHEN - 2016-10-25 - JIRRA 2266 : Sub Task 2312 - END

  [L]DEM    (N)=[F:DCG]DEM

 N+=1
Next

If [V]GERR
#MIPEA - 2017-06-07- US X3-43919- START
 [V]GMESSAGE="GETDEMCNG :"-func AFNC.MES1(mess(80,10701,1),num$(N))
# [V]GMESSAGE="GETDEMCNG :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2017-06-07- US X3-43919- START
 #           Dimension des variables inférieure à $1$
Endif

End

#DEHEN - JIRA X3PEOP-2312 - 2016-10-27 - START
$IS_CANCELED
Local  Integer IS_CANCELED : IS_CANCELED = 1
  If [F:DCG]STRDAT < GMOIPAY | !([F:DCG]STA = 3 | [F:DCG]STA = 2) | !(func GETCONTACCES_ECM([F:TIM]ACS,1))
    IS_CANCELED = 0
  Endif
Return
#DEHEN - JIRA X3PEOP-2312 - 2016-10-27 - END


################################################################################
# Renvoie la liste des absences :
#     Absences de la saisie des temps et régularisations -> toutes
#     Absences de la saisie des absences -> uniquement à venir et non acceptées
################################################################################
# On éclate l'absence pour créer 1 occurence par jour réellement décompté
# Appelé dans l'ordre TIP puis TIG puis DCG, si 2 jours se superposent, on écrase
# nb : On veille juste à renvoyer les occurences dans l'ordre TIP puis TIG puis DCG, si il
#   survenait des chevauchements TIP TIR DCG,les calendrier et planning s'en chargent :
#   la dernière occurence envoyée au portail est celle affichée.

Subprog GETALLCNG( MATRICULE,CONTRAT,DATDEB,DATFIN,STATUTS,CTRNUM,STRDAT,STRDAY,ENDDAT
&                , ENDDAY,TIM,DES,STA,NBRDAY,UID,UPDNUM,TYPPGN,FLGANU,RPL,RPLNAM
&                , DEM
&                )
Value    Char    MATRICULE(), CONTRAT(), STATUTS()
Value    Date    DATDEB, DATFIN
Variable Char    CTRNUM()(0..), TIM()(0..), DES()(0..)
Variable Date    STRDAT(0..), ENDDAT(0..)
Variable Integer STRDAY(0..), ENDDAY(0..), STA(0..)
Variable Decimal NBRDAY(0..)
Variable Integer UID(0..), UPDNUM(0..), TYPPGN(0..), FLGANU(0..)
Variable Char    RPL()(0..), RPLNAM()(0..)
Variable Integer DEM(0..)

Local    Integer SORTID (0..dim(CTRNUM))  : # 64235 index de tri des occurences de la zone d'échange

#Zones pour découpage en jour par jour

Local    Integer DDIMTAB
DDIMTAB = dim(CTRNUM)-1
#MIPEA - 2017-06-07- US X3-43919- START
Local    Char    DCTRNUM(GLONHRCTR)(0..DDIMTAB), DTIM(GLONTPS)(0..DDIMTAB)
#Local    Char    DCTRNUM(GLONCTR)(0..DDIMTAB), DTIM(GLONTPS)(0..DDIMTAB)
#MIPEA - 2017-06-07- US X3-43919- END
Local    Char    DDES(GLONDES)(0..DDIMTAB)
Local    Date    DSTRDAT(0..DDIMTAB), DENDDAT(0..DDIMTAB)
Local    Integer DSTRDAY(0..DDIMTAB), DENDDAY(0..DDIMTAB), DSTA(0..DDIMTAB)
Local    Decimal DNBRDAY(0..DDIMTAB)
Local    Integer DUID(0..DDIMTAB), DUPDNUM(0..DDIMTAB), DTYPPGN(0..DDIMTAB)
Local    Integer DFLGANU(0..DDIMTAB)
Local    Char    DRPL(GLONMAT)(0..DDIMTAB), DRPLNAM(40)(0..DDIMTAB)
Local    Integer DDEM(0..DDIMTAB) , DSORTID(0..DDIMTAB)

Local    Decimal DJOUR(0..DDIMTAB),DHEURE(0..DDIMTAB)
Local    Char    DSITE(GLONFCY)
Local    Char    DPLANNING(GLONPLN),DTIME1(GLONHM),DTIME2(GLONHM),DWTIME(GLONHM),DWCHAR(20)
Local    Date    DWDATE
Local    Integer DWINTEGER
Local    Shortint DN , DJ , DI , DNBDAYS

Gosub AUTORIS
If [V]GERR : End : Endif

If !clalev([F:DCG]) : Local File DEMCONGE [DCG] : Endif
If !clalev([F:TIP]) : Local File TIMEMP   [TIP] : Endif
If !clalev([F:TIG]) : Local File TIMREGUL [TIG] : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
#If !clalev([F:CTR]) : Local File EMPLOCTR [CTR] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If !clalev([F:TIM]) : Local File TIMCOD   [TIM] : Endif
If !clalev([F:ID])  : Local File EMPLOID  [ID]  : Endif

Local Shortint N
Local Integer  JJ,MM,AA,I,POSNEG
Local Decimal  F
Local Char     CRITERE(250)
Local Char     AM(4), PM(4),C(1)
Local Date     DAT


# US-2832
Gosub SET_VAR_ISCP

#64942 : Avant appel func AFNC.PARAM#
#66099
GMOIPAY=gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",""))
#68318
#If GMOIPAY=[0/0/0] : GMOIPAY=eomonth(date$) : Endif
If GMOIPAY=[0/0/0] : GMOIPAY=gdat$(01,month(date$),year(date$)) : Endif

# / 71093
# ADXFTL = 20 enlever la mise en commentaire après le moteur 213

# Parcours TIP - saisie des temps pour toutes les absences

#MIPEA - 2017-06-07- US X3-43919- START
If CONTRAT  >  ""  : CRITERE -="& [HRCTR]CTRNUM='"+CONTRAT+"'"          : Endif
If GUSRFCY  <> "\" : CRITERE -="& find([HRCTR]ETRFCY,GUSRFCY)"          : Endif
#If CONTRAT  >  ""  : CRITERE -="& [CTR]CTRNUM='"+CONTRAT+"'"          : Endif
#If GUSRFCY  <> "\" : CRITERE -="& find([CTR]ETRFCY,GUSRFCY)"          : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If CRITERE  =  ""  : CRITERE  ="1=1" : Else CRITERE=right$(CRITERE,4) : Endif

#MIPEA - 2017-06-07- US X3-43919- START
Columns [HRCTR](CTRNUM,REFNUM,CTRDAT,XITDAT,ETRFCY,ETRSRV)
#Columns [CTR](CTRNUM,REFNUM,CTRDAT,XITDAT,ETRFCY,ETRSRV)
#MIPEA - 2017-06-07- US X3-43919- END
Columns [ID](REFNUM,NAM,SRN)

#MIPEA - 2017-06-07- US X3-43919- START
Link [TIP] With [HRCTR]CTR0(2) =  [TIP]REFNUM;[TIP]CTRNUM
&             , [TIM]TIM0    =  GCURLEG;[TIP]TIM
&             , [DCG]DCG2    =  [TIP]DCGUID
&             , [ID]ID0      =  [DCG]RPL
&            As [LNK]
&         Where [TIP]REFNUM  =  MATRICULE
&             & [TIP]STRDAT <=  DATFIN
#Link [TIP] With [CTR]CTR0(2) =  [TIP]REFNUM;[TIP]CTRNUM
#&             , [TIM]TIM0    =  [TIP]TIM
#&             , [DCG]DCG2    =  [TIP]DCGUID
#&             , [ID]ID0      =  [DCG]RPL
#&            As [LNK]
#&         Where [TIP]REFNUM  =  MATRICULE
#&             & [TIP]STRDAT <=  DATFIN
#MIPEA - 2017-06-07- US X3-43919- END

# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#For [LNK]TIP1 Where ([TIP]CTRNUM= "" | [TIP]CTRNUM = [CTR]CTRNUM)
#&                 & [CTR]CTRDAT <= [TIP]ENDDAT
#&                 & ([CTR]XITDAT =[0/0/0] | [CTR]XITDAT >= [TIP]STRDAT)
#&                 & [TIP]ENDDAT >= DATDEB
#&                 & evalue(CRITERE)
#&                 & [TIM]CATTIM > 1
#&                 & find([CTR]ETRSRV,GAUTSRV)
#MIPEA - 2017-06-07- US X3-43919- START
For [LNK]TIP1 Where ([TIP]CTRNUM= "" | [TIP]CTRNUM = [HRCTR]CTRNUM)
&                 & ([HRCTR]CTRDAT <= [TIP]ENDDAT | ([HRCTR]FLGRET=2 & [HRCTR]RETDATEFF<= [TIP]ENDDAT))
&                 & ([HRCTR]XITDAT =[0/0/0] | [HRCTR]XITDAT >= [TIP]STRDAT)
&                 & [TIP]ENDDAT >= DATDEB
&                 & evalue(CRITERE)
&                 & [TIM]CATTIM > 1
&                 & find([HRCTR]ETRSRV,GAUTSRV)
#For [LNK]TIP1 Where ([TIP]CTRNUM= "" | [TIP]CTRNUM = [CTR]CTRNUM)
#&                 & ([CTR]CTRDAT <= [TIP]ENDDAT | ([CTR]FLGRET=2 & [CTR]RETDATEFF<= [TIP]ENDDAT))
#&                 & ([CTR]XITDAT =[0/0/0] | [CTR]XITDAT >= [TIP]STRDAT)
#&                 & [TIP]ENDDAT >= DATDEB
#&                 & evalue(CRITERE)
#&                 & [TIM]CATTIM > 1
#&                 & find([CTR]ETRSRV,GAUTSRV)
#MIPEA - 2017-06-07- US X3-43919- END
# Fin MABON
 If [F:TIP]NBRDAY <> 0  : # 66090

 If N >= dim([L]CTRNUM)
  GERR=1
  Break
 Endif

#MIPEA - 2017-06-07- US X3-43919- START
 [L]CTRNUM(N)=[F:HRCTR]CTRNUM
# [L]CTRNUM(N)=[F:CTR]CTRNUM
#MIPEA - 2017-06-07- US X3-43919- END
 [L]STRDAT(N)=[F:TIP]STRDAT
 [L]STRDAY(N)=max(1,[F:TIP]STRDAY)
 [L]ENDDAT(N)=[F:TIP]ENDDAT
 [L]ENDDAY(N)=max(1,[F:TIP]ENDDAY)

 # US-2832
 If [F:TIM]VLTEVT=2 & [F:TIM]CATTIM=3 & func DIVPAYE.IS_CP([F:TIP]TIM,W_CPA,W_CPE)
    [L]TIM(N)="CP" : # en dur !
  Else
    [L]TIM(N)=[F:TIP]TIM
 Endif
  [L]DES   (N)=[F:TIM]DES
  [L]STA   (N)=3  :#ACCEPTE
  [L]NBRDAY(N)=[F:TIP]NBRDAY
  # BUG : 95645
  #[L]UID   (N)=[F:TIP]DCGUID
  [L]UID   (N)=[F:TIP]LIG*-1
  [L]UPDNUM(N)=0
  [L]TYPPGN(N)=[F:TIP]TYPPGN
  [L]RPL   (N)=[F:DCG]RPL
  [L]RPLNAM(N)=[F:ID]SRN-[F:ID]NAM
 # FQ88082 FQ81317 - SEGAY 03/04/12 - SBA
#  If [F:DCG]STRDAT < GMOIPAY | [F:TIP]DCGUID = 0 | [F:DCG]STA <> 3
  Gosub IS_CANCELED
  If !IS_CANCELED | [F:TIP]DCGUID = 0
    [L]FLGANU(N)=0
  Else
    [L]FLGANU(N)=1
  Endif
  [L]DEM   (N)=[F:DCG]DEM
  [L]SORTID(N)=0             : # 64235

  # Eclatement de la période de congé pour obtenir 1 occurence par jour d'absence décompté
  If [L]STRDAT(N) <> [L]ENDDAT(N)
   Gosub CUTBYDAY
   If GERR : Break : Endif
  Else
   # 65042
#  If [L]NBRDAY(N) < 1      66090                      : # demi-journée, on consulte le planning
   If [L]NBRDAY(N) < 1 & [L]STRDAY(N) = [L]ENDDAY(N)   : # demi-journée, on consulte le planning
#MIPEA - 2017-06-07- US X3-43919- START
    Call GETSEMTYP( [F:HRCTR]PLNTYP,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]STRDAT(N),[L]ENDDAT(N)
&                   , C,DAT,C,I,F,AM,C,PM,C,C,C
&                   ) From PORTPS
#    Call GETSEMTYP( [F:CTR]PLNTYP,[F:CTR]REFNUM,[F:CTR]CTRNUM,[L]STRDAT(N),[L]ENDDAT(N)
#&                   , C,DAT,C,I,F,AM,C,PM,C,C,C
#&                   ) From PORTPS
#MIPEA - 2017-06-07- US X3-43919- END
    If AM<>""  #Matin
     #[L]ENDDAY(N) = 2 : # 73242
     [L]STRDAY(N) = 2
    Else       #Après-midi
     #[L]STRDAY(N) = 2 : # 73242
     [L]ENDDAY(N) = 2
    Endif
   Endif
   # fin 65042 ---------
  Endif

  N+=1
 Endif
Next

# Parcours TIG - saisie des temps pour toutes les Réguls
#MIPEA - 2017-06-07- US X3-43919- START
Link [TIG] With [HRCTR]CTR0(2) =  [TIG]REFNUM;[TIG]CTRNUM
&             , [TIM]TIM0    =  GCURLEG;[TIG]TIM
&             , [DCG]DCG2    =  [TIG]DCGUID
&             , [ID]ID0      =  [DCG]RPL
&            As [LNK]
&         Where [TIG]REFNUM  =  MATRICULE
&             & [TIG]STRDAT <=  DATFIN


# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#For [LNK]TIG1 Where ([TIG]CTRNUM= "" | [TIG]CTRNUM = [CTR]CTRNUM)
#&                 & [CTR]CTRDAT <= [TIG]ENDDAT
#&                 & ([CTR]XITDAT =[0/0/0] | [CTR]XITDAT >= [TIG]STRDAT)
#&                 & [TIG]ENDDAT >= DATDEB
#&                 & evalue(CRITERE)
#&                 & [TIM]CATTIM > 1
#&                 & find([CTR]ETRSRV,GAUTSRV)
For [LNK]TIG1 Where ([TIG]CTRNUM= "" | [TIG]CTRNUM = [HRCTR]CTRNUM)
&                 & ([HRCTR]CTRDAT <= [TIG]ENDDAT | ([HRCTR]FLGRET=2 & [HRCTR]RETDATEFF<= [TIG]ENDDAT))
&                 & ([HRCTR]XITDAT =[0/0/0] | [HRCTR]XITDAT >= [TIG]STRDAT)
&                 & [TIG]ENDDAT >= DATDEB
&                 & evalue(CRITERE)
&                 & [TIM]CATTIM > 1
&                 & find([HRCTR]ETRSRV,GAUTSRV)
#Link [TIG] With [CTR]CTR0(2) =  [TIG]REFNUM;[TIG]CTRNUM
#&             , [TIM]TIM0    =  [TIG]TIM
#&             , [DCG]DCG2    =  [TIG]DCGUID
#&             , [ID]ID0      =  [DCG]RPL
#&            As [LNK]
#&         Where [TIG]REFNUM  =  MATRICULE
#&             & [TIG]STRDAT <=  DATFIN
#
#
## FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
##For [LNK]TIG1 Where ([TIG]CTRNUM= "" | [TIG]CTRNUM = [CTR]CTRNUM)
##&                 & [CTR]CTRDAT <= [TIG]ENDDAT
##&                 & ([CTR]XITDAT =[0/0/0] | [CTR]XITDAT >= [TIG]STRDAT)
##&                 & [TIG]ENDDAT >= DATDEB
##&                 & evalue(CRITERE)
##&                 & [TIM]CATTIM > 1
##&                 & find([CTR]ETRSRV,GAUTSRV)
#For [LNK]TIG1 Where ([TIG]CTRNUM= "" | [TIG]CTRNUM = [CTR]CTRNUM)
#&                 & ([CTR]CTRDAT <= [TIG]ENDDAT | ([CTR]FLGRET=2 & [CTR]RETDATEFF<= [TIG]ENDDAT))
#&                 & ([CTR]XITDAT =[0/0/0] | [CTR]XITDAT >= [TIG]STRDAT)
#&                 & [TIG]ENDDAT >= DATDEB
#&                 & evalue(CRITERE)
#&                 & [TIM]CATTIM > 1
#&                 & find([CTR]ETRSRV,GAUTSRV)
#MIPEA - 2017-06-07- US X3-43919- END
# Fin MABON
 If [F:TIG]NBRDAY <> 0  : # 66090

  If N >= dim([L]CTRNUM)
   GERR=1
   Break
  Endif

 # 64485 If [TIG]NBRDAY > 0 # On ne renvoie que ce qui va se substituer à une autre absence
#MIPEA - 2017-06-07- US X3-43919- START
  [L]CTRNUM(N)=[F:HRCTR]CTRNUM
#  [L]CTRNUM(N)=[F:CTR]CTRNUM
#MIPEA - 2017-06-07- US X3-43919- END
  [L]STRDAT(N)=[F:TIG]STRDAT
  [L]STRDAY(N)=max(1,[F:TIG]STRDAY)
  [L]ENDDAT(N)=[F:TIG]ENDDAT
  [L]ENDDAY(N)=max(1,[F:TIG]ENDDAY)

  # US-2832
  If [F:TIM]VLTEVT=2 & [F:TIM]CATTIM=3 & func DIVPAYE.IS_CP([F:TIG]TIM,W_CPA,W_CPE)
    [L]TIM(N)="CP" : # en dur !
  Else
    [L]TIM(N)=[F:TIG]TIM
  Endif
  [L]DES   (N)=[F:TIM]DES
  [L]STA   (N)=3  :#ACCEPTE
  [L]NBRDAY(N)=[F:TIG]NBRDAY
  # BUG : 95645
  #[L]UID   (N)=[F:TIG]DCGUID
  [L]UID   (N)=[F:TIG]LIG*-1
  [L]UPDNUM(N)=0
  [L]TYPPGN(N)=[F:TIG]TYPPGN
  [L]RPL   (N)=[F:DCG]RPL
  [L]RPLNAM(N)=[F:ID]SRN-[F:ID]NAM
  # FQ88082 FQ81317 - SEGAY 03/04/12 - SBA
#  If [F:DCG]STRDAT < GMOIPAY | [F:TIP]DCGUID = 0 | [F:DCG]STA <> 3
  Gosub IS_CANCELED
  If !IS_CANCELED | [F:TIP]DCGUID = 0
  #If [F:DCG]STRDAT < GMOIPAY | [F:TIP]DCGUID = 0 | [F:DCG]STA <> 3 | !(func GETCONTACCES_ECM([F:TIM]ACS,1))
   [L]FLGANU(N)=0
  Else
   [L]FLGANU(N)=1
  Endif
  [L]DEM   (N)=[F:DCG]DEM
  [L]SORTID(N)=1             : # 64235
  # Eclatement de la période de congé pour obtenir 1 occurence par jour d'absence décompté
  If [L]STRDAT(N) <> [L]ENDDAT(N)
   Gosub CUTBYDAY
   If GERR : Break : Endif
 Else
  # 65042 ------------- Faut il le faire pour la saisie des temps ?
# If [L]NBRDAY(N) < 1      66090                      : # demi-journée, on consulte le planning
  If [L]NBRDAY(N) < 1 & [L]STRDAY(N) = [L]ENDDAY(N)   : # demi-journée, on consulte le planning
#MIPEA - 2017-06-07- US X3-43919- START
   Call GETSEMTYP( [F:HRCTR]PLNTYP,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]STRDAT(N),[L]ENDDAT(N)
&                   , C,DAT,C,I,F,AM,C,PM,C,C,C
&                   ) From PORTPS
#   Call GETSEMTYP( [F:CTR]PLNTYP,[F:CTR]REFNUM,[F:CTR]CTRNUM,[L]STRDAT(N),[L]ENDDAT(N)
#&                   , C,DAT,C,I,F,AM,C,PM,C,C,C
#&                   ) From PORTPS
#MIPEA - 2017-06-07- US X3-43919- END
   If AM<>""  #Matin
    #[L]ENDDAY(N) = 2 : # 73242
    [L]STRDAY(N) = 2
   Else       #Après-midi
    #[L]STRDAY(N) = 2 : # 72242
    [L]ENDDAY(N) = 2
   Endif
  Endif
  # fin 65042 ---------
  Endif
  N+=1
 # 64485 Endif
 Endif
Next

# Parcours des absences futures en statut "Demandes"
Local Date DATDEBCTR
#MIPEA - 2017-06-07- US X3-43919- START
Link [DCG] With [HRCTR]CTR0(1)=REFNUM
&             , [TIM]TIM0   =GCURLEG;TIM
&             , [ID]ID0     =RPL
&            As [LNK]
#Link [DCG] With [CTR]CTR0(1)=REFNUM
#&             , [TIM]TIM0   =TIM
#&             , [ID]ID0     =RPL
#&            As [LNK]
#MIPEA - 2017-06-07- US X3-43919- END
# 64294
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#For [LNK]DCG0 Where REFNUM=[L]MATRICULE & UID>0 & ( STA = 2 | STA = 5)
#&                 & STRDAT<=DATFIN & ENDDAT>=DATDEB
#&                 & find(CTRNUM,"",[CTR]CTRNUM)<>0 & evalue([L]CRITERE)
#&                 & [CTR]CTRDAT<=ENDDAT
#&                 & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=STRDAT)
#&                 & find([CTR]ETRSRV,GAUTSRV)
#MIPEA - 2017-06-07- US X3-43919- START
For [LNK]DCG0 Where REFNUM=[L]MATRICULE & UID>0 & ( STA = 2 | STA = 5)
&                 & STRDAT<=DATFIN & ENDDAT>=DATDEB
&                 & find(CTRNUM,"",[HRCTR]CTRNUM)<>0 & evalue([L]CRITERE)
&                 & ([HRCTR]CTRDAT<=ENDDAT | ([HRCTR]FLGRET=2 & [HRCTR]RETDATEFF<=ENDDAT))
&                 & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=STRDAT)
&                 & find([HRCTR]ETRSRV,GAUTSRV)
#For [LNK]DCG0 Where REFNUM=[L]MATRICULE & UID>0 & ( STA = 2 | STA = 5)
#&                 & STRDAT<=DATFIN & ENDDAT>=DATDEB
#&                 & find(CTRNUM,"",[CTR]CTRNUM)<>0 & evalue([L]CRITERE)
#&                 & ([CTR]CTRDAT<=ENDDAT | ([CTR]FLGRET=2 & [CTR]RETDATEFF<=ENDDAT))
#&                 & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=STRDAT)
#&                 & find([CTR]ETRSRV,GAUTSRV)
#MIPEA - 2017-06-07- US X3-43919- END
# Fin MABON
#&                 & STRDAT >= GMOIPAY #64037

 If [F:DCG]NBRDAY <> 0  : # 66090

  If N>=dim([L]CTRNUM)
   [V]GERR=1
   Break
  Endif

#MIPEA - 2017-06-07- US X3-43919- START
  [L]CTRNUM(N)=[F:HRCTR]CTRNUM
  # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
  DATDEBCTR=[F:HRCTR]CTRDAT
  If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then
    DATDEBCTR=[F:HRCTR]RETDATEFF
  Endif
#  [L]STRDAT(N)=max([F:DCG]STRDAT,[F:CTR]CTRDAT)
  [L]STRDAT(N)=max([F:DCG]STRDAT,DATDEBCTR)
  # Fin MABON
  [L]STRDAY(N)=[F:DCG]STRDAY
  [L]ENDDAT(N)=[F:DCG]ENDDAT
  If [F:HRCTR]XITDAT <> [00/00/0000] : [L]ENDDAT(N)=min([L]ENDDAT(N),[F:HRCTR]XITDAT) : Endif
  [L]ENDDAY(N)=[F:DCG]ENDDAY
#  [L]CTRNUM(N)=[F:CTR]CTRNUM
#  # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#  DATDEBCTR=[F:CTR]CTRDAT
#  If [F:CTR]FLGRET=2 & [F:CTR]RETDATEFF<>[0/0/0] Then
#    DATDEBCTR=[F:CTR]RETDATEFF
#  Endif
##  [L]STRDAT(N)=max([F:DCG]STRDAT,[F:CTR]CTRDAT)
#  [L]STRDAT(N)=max([F:DCG]STRDAT,DATDEBCTR)
#  # Fin MABON
#  [L]STRDAY(N)=[F:DCG]STRDAY
#  [L]ENDDAT(N)=[F:DCG]ENDDAT
#  If [F:CTR]XITDAT <> [00/00/0000] : [L]ENDDAT(N)=min([L]ENDDAT(N),[F:CTR]XITDAT) : Endif
#  [L]ENDDAY(N)=[F:DCG]ENDDAY
#MIPEA - 2017-06-07- US X3-43919- END

  # US-2832
  If [F:TIM]VLTEVT=2 & [F:TIM]CATTIM=3 & func DIVPAYE.IS_CP([F:DCG]TIM,W_CPA,W_CPE)
    [L]TIM(N)="CP" : # en dur !
  Else
    [L]TIM(N)=[F:DCG]TIM
  Endif
  [L]DES   (N)=[F:TIM]DES
  [L]STA   (N)=[F:DCG]STA
  [L]NBRDAY(N)=[F:DCG]NBRDAY
  [L]UID   (N)=[F:DCG]UID
  [L]UPDNUM(N)=[F:DCG]UPDNUM
  [L]TYPPGN(N)=[F:DCG]TYPPGN
  [L]RPL   (N)=[F:DCG]RPL
  [L]RPLNAM(N)=[F:ID]SRN-[F:ID]NAM
  # SBA add for status =2
  Gosub IS_CANCELED
  If !IS_CANCELED
    [L]FLGANU(N)=0
  Else
    [L]FLGANU(N)=1
  Endif
  [L]DEM   (N)=[F:DCG]DEM
  [L]SORTID(N)=2             : # 64235
  # Eclatement de la période de congé pour obtenir 1 occurence par jour d'absence décompté
  If [L]STRDAT(N) <> [L]ENDDAT(N)
   Gosub CUTBYDAY
   If GERR : Break : Endif
  Else
   # 65042 -------------
#  If [L]NBRDAY(N) < 1      66090                      : # demi-journée, on consulte le planning
   If [L]NBRDAY(N) < 1 & [L]STRDAY(N) = [L]ENDDAY(N)   : # demi-journée, on consulte le planning
#MIPEA - 2017-06-07- US X3-43919- START
    Call GETSEMTYP( [F:HRCTR]PLNTYP,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]STRDAT(N),[L]ENDDAT(N)
&                    , C,DAT,C,I,F,AM,C,PM,C,C,C
&                    ) From PORTPS
#    Call GETSEMTYP( [F:CTR]PLNTYP,[F:CTR]REFNUM,[F:CTR]CTRNUM,[L]STRDAT(N),[L]ENDDAT(N)
#&                    , C,DAT,C,I,F,AM,C,PM,C,C,C
#&                    ) From PORTPS
#MIPEA - 2017-06-07- US X3-43919- END
    If AM<>""  #Matin
     #[L]ENDDAY(N) = 2 : # 73242
     [L]STRDAY(N) = 2
    Else       #Après-midi
     #[L]STRDAY(N) = 2 :  : # 73242
     [L]ENDDAY(N) = 2
    Endif
   Endif
   # fin 65042 ---------
  Endif
  N+=1
 Endif
Next

# / 71093
# ADXFTL = 1 enlever la mise en commentaire après le moteur 213

#MIPEA - 2017-06-07- US X3-43919- START
Close File [HRCTR] , [ID]
#Close File [CTR] , [ID]
#MIPEA - 2017-06-07- US X3-43919- END

If [V]GERR
#MIPEA - 2017-06-07- US X3-43919- START
 [V]GMESSAGE="GETDETCNG :"-func AFNC.MES1(mess(80,10701,1),num$(N))
# [V]GMESSAGE="GETDETCNG :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2017-06-07- US X3-43919- END
 #           Dimension des variables inférieure à $1$
 End
Endif

Sorta N
&     [L]CTRNUM
&    ,[L]STRDAT
&    ,[L]STRDAY
&    ,[L]ENDDAT
&    ,[L]ENDDAY
&    ,[L]TIM
&    ,[L]DES
&    ,[L]STA
&    ,[L]NBRDAY
&    ,[L]UID
&    ,[L]UPDNUM
&    ,[L]TYPPGN
&    ,[L]RPL
&    ,[L]RPLNAM
&    ,[L]FLGANU
&    ,[L]DEM
&     Order By [L]STRDAT(indice),[L]ENDDAY(indice),[L]SORTID(indice)
#&     Order By [L]STRDAT(indice),[L]STRDAY(indice),[L]SORTID(indice)  : # 64235 - 73242


# 73950 Enlever les dates en doublon

End

$CUTBYDAY
Raz DCTRNUM , DDES , DRPL , DRPLNAM , DTIM , DSITE
Raz DSTRDAT , DENDDAT
Raz DSTRDAY , DENDDAY , DSTA , DNBRDAY , DJOUR , DHEURE
Raz DUID , DUPDNUM , DTYPPGN , DFLGANU , DDEM , DSORTID

#Initialisation du tableau de travail ------------------------------------------------
DN = 0
Gosub ALIM_DAY
DSTRDAT(0)  = [L]STRDAT(N)
#MIPEA - 2017-06-07- US X3-43919- START
DSITE       = [F:HRCTR]ETRFCY
#DSITE       = [F:CTR]ETRFCY
#MIPEA - 2017-06-07- US X3-43919- END
POSNEG      = sgn(DNBRDAY(0))

#Alimentation de la liste des jours: DJOUR(n)<>0 signifie jour décompté ---------------
Call VALORDET(DSTRDAT(0),DENDDAT(0),MATRICULE,DTIM(0),DJOUR,DHEURE,DSITE,DCTRNUM(0)) From SUBPLN


#Découpage jour par jour dans tableau de travail et pour l'absence traitée -----------
DJ = 0
While DSTRDAT(DN) <= DENDDAT(DN)

 If DJOUR(DJ) <> 0 : # on ne renvoie au portail que les jours décomptés - 64045

  # 5 champs varient sur chaque occurence : STRDAT,STRDAY,ENDDAT,ENDDAY,NBRDAY
#  73242 If DN = 0 & DSTRDAY(DN) = 2
#         DENDDAY(DN) = 1
  If DN = 0 & DENDDAY(DN) = 2                       : # début un ap.midi?
   DSTRDAY(DN) = 1
   DNBRDAY(DN) = 0.5 * POSNEG
#  73242 Elsif DSTRDAT(DN) = DENDDAT(DN) & DENDDAY(DN) = 2
#         DSTRDAY(DN) = 1
  Elsif DSTRDAT(DN) = DENDDAT(DN) & DSTRDAY(DN) = 2 : # fin un matin?
   DENDDAY(DN) = 1
   DNBRDAY(DN) = 0.5 * POSNEG
  Else                                              : # Au milieu de la période
#  73242 DSTRDAY(DN) = 1
#        DENDDAY(DN) = 1
   DSTRDAY(DN) = 1
   DENDDAY(DN) = 1
   # 65042 -------------
   If DJOUR(DJ) < 1                                 : # demi-journée, on consulte le planning
    DNBRDAY(DN) = DJOUR(DJ) * POSNEG
#MIPEA - 2017-06-07- US X3-43919- START
    Call GETSEMTYP( [F:HRCTR]PLNTYP,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,DSTRDAT(DN),DSTRDAT(DN)
&                   , C,DAT,C,I,F,AM,C,PM,C,C,C
&                   ) From PORTPS
#    Call GETSEMTYP( [F:CTR]PLNTYP,[F:CTR]REFNUM,[F:CTR]CTRNUM,DSTRDAT(DN),DSTRDAT(DN)
#&                   , C,DAT,C,I,F,AM,C,PM,C,C,C
#&                   ) From PORTPS
#MIPEA - 2017-06-07- US X3-43919- END
    If AM<>""  #Matin
#     73242 DENDDAY(DN) = 2
     DSTRDAY(DN) = 2
    Else       #Après-midi
#    73242 DSTRDAY(DN) = 2
     DENDDAY(DN) = 2
    Endif
   Else
    DNBRDAY(DN) = 1 * POSNEG
   Endif
   # fin 65042 ---------
  Endif

  DENDDAT(DN) = DSTRDAT(DN)

  DN+=1
  If DN >= dim(DCTRNUM)
   GERR=1
   Break
  Endif
  Gosub ALIM_DAY
  DSTRDAT(DN)  = DSTRDAT(DN-1)
 Endif

 DSTRDAT(DN) +=1
 DJ+=1
 If DJ >= dim(DJOUR)
  GERR=1
  Break
 Endif

Wend

# On supprime l'absence courante
Raz [L]CTRNUM(N) , [L]DES(N) , [L]RPL(N) , [L]RPLNAM(N) , [L]TIM(N)
Raz [L]STRDAT(N) , [L]ENDDAT(N)
Raz [L]STRDAY(N) , [L]ENDDAY(N) , [L]STA(N) , [L]NBRDAY(N)
Raz [L]UID(N) , [L]UPDNUM(N) , [L]TYPPGN(N) , [L]FLGANU(N) , [L]DEM(N) , [L]SORTID(N)
N -= 1


# Insertion du tableau de travail(DN) dans le tableau des absences([L]) --------------
# avec écrasement des jours identiques

DNBDAYS = DN-1
DN = 0

While DN <= DNBDAYS & N < DDIMTAB
 N+=1
 DI = find(DSTRDAT(DN),[L]STRDAT) : # Cette date est elle déjà présente ?

 # On a pas trouvé cette date d'absence
 If DI  = 0
  # Occurence créée
  [L]CTRNUM(N) = DCTRNUM(DN)
  [L]STRDAT(N) = DSTRDAT(DN)
  [L]STRDAY(N) = DSTRDAY(DN)
  [L]ENDDAT(N) = DENDDAT(DN)
  [L]ENDDAY(N) = DENDDAY(DN)

# US-2832
  If [F:TIM]VLTEVT=2 & [F:TIM]CATTIM=3 & func DIVPAYE.IS_CP(DTIM(DN),W_CPA,W_CPE)
   DTIM(DN)="CP"
  Endif
  [L]TIM   (N) = DTIM(DN)
  [L]DES   (N) = DDES(DN)
  [L]STA   (N) = DSTA(DN)
  [L]NBRDAY(N) = DNBRDAY(DN)
  [L]UID   (N) = DUID(DN)
  [L]UPDNUM(N) = DUPDNUM(DN)
  [L]TYPPGN(N) = DTYPPGN(DN)
  [L]RPL   (N) = DRPL(DN)
  [L]RPLNAM(N) = DRPLNAM(DN)
  [L]FLGANU(N) = DFLGANU(DN)
  [L]DEM   (N) = DDEM(DN)
  [L]SORTID(N) = DSORTID(DN)             : # 64235
 Endif

 # On a trouvé la même date d'absence
 If DI > 0
  # 64485
  # cas 1 : 1/2 journée(s) différente(s)
  If DSTRDAY(DN) <> [L]STRDAY(DI-1) | DENDDAY(DN) <> [L]ENDDAY(DI-1)
   # On vérifie que la même 1/2j n'est pas plus loin
   I=1
   While I <> 0
    I = find(DSTRDAT(DN),[L]STRDAT(DI..DDIMTAB))
    DI += 1
    If I<>0 & DSTRDAY(DN) = [L]STRDAY(DI-1) & DENDDAY(DN) = [L]ENDDAY(DI-1)
     Break : # On a finalement trouvée la même 1/2 journée, elle sera traitée en cas 2
    Endif
   Wend

   If I = 0    : # On a rien trouvé alors on crée  =>> !! DI peut être < N prendre N au lieu de DI
    [L]CTRNUM(N) = DCTRNUM(DN)
    [L]STRDAT(N) = DSTRDAT(DN)
    [L]STRDAY(N) = DSTRDAY(DN)
    [L]ENDDAT(N) = DENDDAT(DN)
    [L]ENDDAY(N) = DENDDAY(DN)

    # US-2832
    If [F:TIM]VLTEVT=2 & [F:TIM]CATTIM=3 & func DIVPAYE.IS_CP(DTIM(DN),W_CPA,W_CPE)
       DTIM(DN)="CP"
    Endif
    [L]TIM   (N)= DTIM(DN)
    [L]NBRDAY(N)= DNBRDAY(DN)
    [L]DES   (N)= DDES(DN)
    [L]STA   (N)= DSTA(DN)
    [L]UID   (N)= DUID(DN)
    [L]UPDNUM(N)= DUPDNUM(DN)
    [L]TYPPGN(N)= DTYPPGN(DN)
    [L]RPL   (N)= DRPL(DN)
    [L]RPLNAM(N)= DRPLNAM(DN)
    [L]FLGANU(N)= DFLGANU(DN)
    [L]DEM   (N)= DDEM(DN)
    [L]SORTID(N)= DSORTID(DN)
   Endif

  Endif

  # cas 2 : même 1/2 journée(s)
  If DSTRDAY(DN) = [L]STRDAY(DI-1) & DENDDAY(DN) = [L]ENDDAY(DI-1)

   DI-=1                      : # Occurence écrasée
   [L]CTRNUM(DI)= DCTRNUM(DN)


   # US-2832
   If [F:TIM]VLTEVT=2 & [F:TIM]CATTIM=3 & func DIVPAYE.IS_CP(DTIM(DN),W_CPA,W_CPE)
       DTIM(DN)="CP"
   Endif

   If DTIM(DN) = [L]TIM(DI) & sgn(DNBRDAY(DN)) <> sgn([L]NBRDAY(DI))
    # les régul. avec le même code évt
    [L]NBRDAY(DI)= [L]NBRDAY(DI) + DNBRDAY(DN)
   Else
    [L]NBRDAY(DI)= DNBRDAY(DN)
   Endif
   # fin 64485
   [L]TIM   (DI)= DTIM(DN)
   [L]DES   (DI)= DDES(DN)
   [L]STA   (DI)= DSTA(DN)
   [L]UID   (DI)= DUID(DN)
   [L]UPDNUM(DI)= DUPDNUM(DN)
   [L]TYPPGN(DI)= DTYPPGN(DN)
   [L]RPL   (DI)= DRPL(DN)
   [L]RPLNAM(DI)= DRPLNAM(DN)
   [L]FLGANU(DI)= DFLGANU(DN)
   [L]DEM   (DI)= DDEM(DN)
   [L]SORTID(DI)= DSORTID(DN)             : # 64235
   N-=1 : # On a pas créé d'occurence

   #64485 Avec les réguls on peut se retrouver avec des absences 0 j, on les supprime
   If [L]NBRDAY(DI) = 0
    Raz [L]CTRNUM(DI) , [L]DES(DI) , [L]RPL(DI) , [L]RPLNAM(DI) , [L]TIM(DI)
    Raz [L]STRDAT(DI) , [L]ENDDAT(DI) , [L]STRDAY(DI) , [L]ENDDAY(DI)
    Raz [L]STA(DI) , [L]NBRDAY(DI)
    Raz [L]UID(DI) , [L]UPDNUM(DI) , [L]TYPPGN(DI) , [L]FLGANU(DI) , [L]DEM(DI) , [L]SORTID(DI)
    [L]STRDAT(DI) = [31/12/9999]
   Endif

  Endif

 Endif
 DN+=1
Wend

Return

$ALIM_DAY
#Alimentation d'une occurence du tableau de travail avec les valeurs de l'absence
DCTRNUM(DN)  = [L]CTRNUM(N)
#DSTRDAT(DN)  = [L]STRDAT(N)
DSTRDAY(DN)  = [L]STRDAY(N)
DENDDAT(DN)  = [L]ENDDAT(N)
DENDDAY(DN)  = [L]ENDDAY(N)
DTIM(DN)     = [F:TIM]COD   : # On utilise la nature d'évènement réelle
DDES(DN)     = [L]DES   (N)
DSTA(DN)     = [L]STA   (N)
DNBRDAY(DN)  = [L]NBRDAY(N)
DUID(DN)     = [L]UID   (N)
DUPDNUM(DN)  = [L]UPDNUM(N)
DTYPPGN(DN)  = [L]TYPPGN(N)
DRPL(DN)     = [L]RPL   (N)
DRPLNAM(DN)  = [L]RPLNAM(N)
DFLGANU(DN)  = [L]FLGANU(N)
DDEM(DN)     = [L]DEM   (N)
DSORTID(DN)  = [L]SORTID(N)             : # 64235
Return

################################################################################
#
# Renvoie les infos sur une ou des demandes
# pour STATUTS mettre les STA séparés par des virgules : ex : "2,4,6"
#
################################################################################

Subprog GETSYNDEM( MATRICULE,STATUTS,DEMANDE,REFNUM,CTRNUM,CREDAT,DEM,STRDAT,STRDAY,ENDDAT
&                , ENDDAY,STA,CMT,UPDDAT,CHRONO,CHRONO2,CMT2,FROMDATE,TODATE
&                )
Value    Date    FROMDATE,TODATE
Value    Char    MATRICULE(), STATUTS()
Value    Integer DEMANDE
Variable Char    REFNUM()(0..), CTRNUM()(0..), CMT()(0..), CMT2()(0..), CHRONO()(0..), CHRONO2()(0..)
Variable Date    CREDAT(0..), STRDAT(0..), ENDDAT(0..), UPDDAT(0..)
Variable Integer DEM(0..), STRDAY(0..), ENDDAY(0..), STA(0..)
Local    Integer LUID(0..)

Gosub AUTORIS
If [V]GERR : End : Endif

If !clalev([F:DCG]) : Local File DEMCONGE [DCG] : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
#If !clalev([F:CTR]) : Local File EMPLOCTR [CTR] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
# FQ88082 FQ81317 - SEGAY 03/04/12 - SBA
If !clalev([F:TIM])  : Local File TIMCOD   [TIM]  : Endif

Local Integer N
Local Char    CRITERE(250)

If [L]MATRICULE>""        : [L]CRITERE-="& REFNUM='"+[L]MATRICULE+"'"               : Endif
If [L]STATUTS>""          : [L]CRITERE-="& find(STA,"+[L]STATUTS+")<>0"             : Endif
If [L]DEMANDE>0           : [L]CRITERE-="& DEM="+num$([L]DEMANDE)                   : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If [V]GUSRFCY<>"\"        : [L]CRITERE-="& find([HRCTR]ETRFCY,[V]GUSRFCY)"            : Endif
#If [V]GUSRFCY<>"\"        : [L]CRITERE-="& find([CTR]ETRFCY,[V]GUSRFCY)"            : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If [L]FROMDATE <> [0/0/0] : [L]CRITERE-="& ENDDAT>=["+format$(GFMD,[L]FROMDATE)+"]" : Endif
If [L]TODATE   <> [0/0/0] : [L]CRITERE-="& STRDAT<=["+format$(GFMD,[L]TODATE)+"]"   : Endif

If [L]CRITERE=""   : [L]CRITERE="1=1" : Else [L]CRITERE=right$([L]CRITERE,4) : Endif
# FQ88082 FQ81317 - SEGAY 03/04/12 - SBA
#Link [DCG] With [CTR]CTR0(1)=REFNUM
#&            As [LNK]
#&         Where UID>0 & find(CTRNUM,"",[CTR]CTRNUM)<>0
#&  Order By Key CLE=REFNUM;DEM;[CTR]CTRNUM;STRDAT;ENDDAY

#MIPEA - 2017-06-07- US X3-43919- START
Link [DCG] With [HRCTR]CTR0(1)=REFNUM, [TIM]TIM0=GCURLEG;TIM
&            As [LNK]
&         Where UID>0 & find(CTRNUM,"",[HRCTR]CTRNUM)<>0
&  Order By Key CLE=REFNUM;DEM;[HRCTR]CTRNUM;STRDAT;ENDDAY
#&  Order By Key CLE=REFNUM;DEM;[CTR]CTRNUM;STRDAT;STRDAY

# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#For [LNK]CLE Where evalue([L]CRITERE) & find([CTR]ETRSRV,[V]GAUTSRV) & [CTR]CTRDAT<=ENDDAT
#&                & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=STRDAT)
For [LNK]CLE Where evalue([L]CRITERE) & find([HRCTR]ETRSRV,[V]GAUTSRV) & ([HRCTR]CTRDAT<=ENDDAT | ([HRCTR]FLGRET=2 & [HRCTR]RETDATEFF<=ENDDAT))
&                & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=STRDAT)
#Link [DCG] With [CTR]CTR0(1)=REFNUM, [TIM]TIM0=TIM
#&            As [LNK]
#&         Where UID>0 & find(CTRNUM,"",[CTR]CTRNUM)<>0
#&  Order By Key CLE=REFNUM;DEM;[CTR]CTRNUM;STRDAT;ENDDAY
##&  Order By Key CLE=REFNUM;DEM;[CTR]CTRNUM;STRDAT;STRDAY
#
## FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
##For [LNK]CLE Where evalue([L]CRITERE) & find([CTR]ETRSRV,[V]GAUTSRV) & [CTR]CTRDAT<=ENDDAT
##&                & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=STRDAT)
#For [LNK]CLE Where evalue([L]CRITERE) & find([CTR]ETRSRV,[V]GAUTSRV) & ([CTR]CTRDAT<=ENDDAT | ([CTR]FLGRET=2 & [CTR]RETDATEFF<=ENDDAT))
#&                & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=STRDAT)
#MIPEA - 2017-06-07- US X3-43919- END
# Fin MABON
 If N>=dim([L]REFNUM)
  [V]GERR=1
 Else
 # FQ88082 FQ81317 - SEGAY 03/04/12 - SBA
 #If !find([F:DCG]UID,LUID(0..N))
  If !find([F:DCG]UID,LUID(0..N))and func IS_TIMACCES([F:TIM]ACS,2)
    [L]REFNUM (N)=[F:DCG]REFNUM
#MIPEA - 2017-06-07- US X3-43919- START
    [L]CTRNUM (N)=[F:HRCTR]CTRNUM
#    [L]CTRNUM (N)=[F:CTR]CTRNUM
#MIPEA - 2017-06-07- US X3-43919- END
    [L]DEM    (N)=[F:DCG]DEM
    [L]CREDAT (N)=[F:DCG]CREDAT
    [L]STRDAT (N)=[F:DCG]STRDAT
    [L]STRDAY (N)=[F:DCG]STRDAY
    [L]STA    (N)=[F:DCG]STA
    [L]UPDDAT (N)=[F:DCG]UPDDAT
    [L]CMT    (N)=[F:DCG]CMT
    [L]CMT2   (N)=[F:DCG]CMT2
    [L]ENDDAT (N)=[F:DCG]ENDDAT
    [L]ENDDAY (N)=[F:DCG]ENDDAY
    [L]CHRONO (N)=num$([F:DCG]UID)
    [L]CHRONO2(N)=[F:DCG]CHRONO2
    [L]LUID   (N)=[F:DCG]UID
     N+=1
  Endif
 Endif

Next

If [V]GERR
#MIPEA - 2017-06-07- US X3-43919- START
 [V]GMESSAGE="GETSYNCNG :"-func AFNC.MES1(mess(80,10701,1),num$(N))
# [V]GMESSAGE="GETSYNCNG :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2017-06-07- US X3-43919- END
 #           Dimension des variables inférieure à $1$
Endif

End

################################################################################
#
# Manipule N lignes avec pour chacune une action particulière
#
################################################################################

Subprog SETDEMCONGE2( ACTION,REFNUM,DEM,NCTRNUM,NSTRDAT,NSTRDAY,NENDDAT,NENDDAY,NNBRDAY
&                   , NTIM,NDES,NSTA,NCMT,NUID,NUPDNUM, ERRMES
&                   , NTYPPGN,NFLGANU,NRPL,NRPLNAM
&                   , NURLBACK, NCMT2
&                   )
Value    Char    ACTION()(0..), REFNUM()
Variable Char    NCTRNUM()(0..)
Variable Integer DEM, NSTA(0..), NSTRDAY(0..), NENDDAY(0..), NUPDNUM(0..), NUID(0..)
Variable Date    NSTRDAT(0..), NENDDAT(0..)
Variable Char    NTIM()(0..), NCMT()(0..), NDES()(0..), ERRMES()(0..), NCMT2()(0..)
Variable Decimal NNBRDAY(0..)
Variable Integer NTYPPGN(0..), NFLGANU(0..)
Variable Char    NRPL()(0..), NRPLNAM()(0..)
Value    Char    NURLBACK ()
# SBA ATTACH
Local Integer    NADDPJ(0..dim(NTIM)-1)


Call SETDEMCONGE2PJ( ACTION,REFNUM,DEM,NCTRNUM,NSTRDAT,NSTRDAY,NENDDAT,NENDDAY,NNBRDAY
&                   , NTIM,NDES,NSTA,NCMT,NUID,NUPDNUM, ERRMES
&                   , NTYPPGN,NFLGANU,NRPL,NRPLNAM
&                   , NURLBACK, NCMT2,NADDPJ
&                   )
End


Subprog SETDEMCONGE2PJ( ACTION,REFNUM,DEM,NCTRNUM,NSTRDAT,NSTRDAY,NENDDAT,NENDDAY,NNBRDAY
&                   , NTIM,NDES,NSTA,NCMT,NUID,NUPDNUM, ERRMES
&                   , NTYPPGN,NFLGANU,NRPL,NRPLNAM
&                   , NURLBACK, NCMT2,NADDPJ
&                   )
Value    Char    ACTION()(0..), REFNUM()
Variable Char    NCTRNUM()(0..)
Variable Integer DEM, NSTA(0..), NSTRDAY(0..), NENDDAY(0..), NUPDNUM(0..), NUID(0..)
Variable Date    NSTRDAT(0..), NENDDAT(0..)
Variable Char    NTIM()(0..), NCMT()(0..), NDES()(0..), ERRMES()(0..), NCMT2()(0..)
Variable Decimal NNBRDAY(0..)
Variable Integer NTYPPGN(0..), NFLGANU(0..)
Variable Char    NRPL()(0..), NRPLNAM()(0..)
Value    Char    NURLBACK ()
Variable Integer NADDPJ(0..)

Local Shortint I, J, K, E, D
D=dim([L]ACTION)
#MIPEA - 2017-06-07- US X3-43919- START
Local Char    CTRNUM([V]GLONHRCTR)(D)
#Local Char    CTRNUM([V]GLONCTR)(D)
#MIPEA - 2017-06-07- US X3-43919- END
Local Integer STA(D), STRDAY(D), ENDDAY(D), UPDNUM(D), UID(D)
Local Date    STRDAT(D), ENDDAT(D)
Local Char    TIM([V]GLONTPS)(D), CMT(type([L]NCMT)-10)(D), DES(type([L]NDES)-10)(D)
Local Decimal NBRDAY(D)
Local Integer TYPPGN(D), FLGANU(D)
#MIPEA - 2017-06-07- US X3-43919- START
Local Char    RPL(GLONEML)(D), RPLNAM(80)(D), CMT2(type([L]NCMT2)-10)(D)
#Local Char    RPL(GLONMAT)(D), RPLNAM(80)(D), CMT2(type([L]NCMT2)-10)(D)
#MIPEA - 2017-06-07- US X3-43919- END
# SBA ATTACH
Local Integer ADDPJ(D)
Local Char W_UID(20)

Local Integer SAV_GWSTAT : # 70120 pile des erreurs webservices
Local Char    WACTION(20)(D) : #  FQ82397 - SEGAY 25/05/12

D-=1
Raz GERR
If !clalev([F:DCG]) : Local File DEMCONGE [DCG] : Endif


Trbegin [DCG]
# While [L]ACTION(I)>""  : # 70120
 While I < D
  [L]CTRNUM(J)=[L]NCTRNUM(I)
  [L]STRDAT(J)=[L]NSTRDAT(I)
  [L]STRDAY(J)=[L]NSTRDAY(I)
  [L]ENDDAT(J)=[L]NENDDAT(I)
  [L]ENDDAY(J)=[L]NENDDAY(I)
  [L]NBRDAY(J)=[L]NNBRDAY(I)
  [L]TIM   (J)=[L]NTIM   (I)
  [L]DES   (J)=[L]NDES   (I)
  [L]STA   (J)=[L]NSTA   (I)
  [L]CMT   (J)=[L]NCMT   (I)
  [L]CMT2  (J)=[L]NCMT2  (I)
  [L]UID   (J)=[L]NUID   (I)
  [L]UPDNUM(J)=[L]NUPDNUM(I)
  [L]TYPPGN(J)=[L]NTYPPGN(I)
  [L]FLGANU(J)=[L]NFLGANU(I)
  [L]RPL   (J)=[L]NRPL   (I)
  [L]RPLNAM(J)=[L]NRPLNAM(I)
  [L]WACTION(J)=[L]ACTION(I) : #  FQ82397 - SEGAY 25/05/12

  [L]ADDPJ(J)=[L]NADDPJ(I)

  If [L]ACTION(I) <> ""  : # 70120
  SV_GWSTAT = GW_STAT    : # 70120
  Call SETDEMCONGEPJ( [L]ACTION(I),[L]REFNUM,[L]DEM,[L]CTRNUM(J..D),[L]STRDAT(J..D)
&                 , [L]STRDAY(J..D),[L]ENDDAT(J..D),[L]ENDDAY(J..D),[L]NBRDAY(J..D)
&                 , [L]TIM(J..D),[L]DES(J..D),[L]STA(J..D),[L]CMT(J..D),[L]UID(J..D)
&                 , [L]UPDNUM(J..D)
&                 , [L]TYPPGN(J..D),[L]FLGANU(J..D),[L]RPL(J..D),[L]RPLNAM(J..D)
&                 , [L]NURLBACK,[L]CMT2(J..D),[L]ADDPJ(J..D)
&                 )
  If [V]GERR
   E           +=1
   If GMESSAGE = "" & GW_STAT <> SV_GWSTAT : # Si AFF From GSAISIE a effacé GMESSAGE on peut le retrouver dans GW_MESS(70120)
    GMESSAGE = GW_MESS(GW_STAT)
    Raz GW_MESS(GW_STAT)  : # Si on ne fait pas ça les messages sont affichés 2 fois
   Endif
   [L]ERRMES(J) =mess(61,100,1)-num$(I+1)-":"-[V]GMESSAGE : # ligne no
   Raz [V]GMESSAGE, [V]GERR
  Endif
  # 1 ligne en entrée peut donner n lignes en sortie
  K=J
  Repeat : J+=1 : Until J=D | [L]STRDAT(J)=[0/0/0]
  If J=D
   E           +=1
#MIPEA - 2017-06-07- US X3-43919- START
   [L]ERRMES(K) ="SETDEMCONGE2 :"-func AFNC.MES1(mess(80,10701,1),num$(D+1))
#   [L]ERRMES(K) ="SETDEMCONGE2 :"-func AFNC.MES1(mess(80,701,1),num$(D+1))
#MIPEA - 2017-06-07- US X3-43919- END
   #             Dimension des variables inférieure à $1$
   Break
  Endif
  #Else : # 70120
  # J+=1
  Endif
  I+=1
 Wend

#  FQ82397 - SEGAY 25/05/12 -   contrôle des demandes avec STA 2(Demande) ou 3(accepte)
# [F:DCG] USED for C_TIM
 If clalev([F:DCGX])=0 : Local File DEMCONGE [DCGX] : Endif
 mkstat=0
 If dim(ACTPOR) < 1
   Global Char    ACTPOR
 Endif

 Local Mask DCG1 [DCG1]
 Raz [M:DCG1]
 Gosub NOMFIC From WODCG
 If evalue("clalev([F:"+ABFIC+"])")=0
   Gosub OUVFIC From WODCG
 Endif
 Gosub OUVRE From WODCG
 Gosub OUVRE From SUBDCG
#SEGAY 11/04/12 80868 : Validation différée des écrans
 Call ISSCREENOK(nomap,"DCG1") From INTRUTILB
 mkstat=0
 Filter [DCGX] Where DEM=[L]DEM & find(UID,[L]UID) Order By STRDAT Asc
 For [DCGX]
   nolign                 =find([F:DCGX]UID,[L]UID)
   If [L]WACTION(nolign-1) = "CREATE" Then
     [M:DCG1]               =[F:DCGX]
     [M:DCG1]STA0(nolign-1) =[F:DCGX]STA
     [M:DCG1]STA (nolign-1) = 2
     [M:DCG1]NBLIG         +=1
     ACTPOR = [L]WACTION(nolign-1)
     Call C_TIM([M:DCG1]TIM(nolign-1)) From SUBDCG
     If mkstat
       [V]GERR=1
       E           +=1
       [L]ERRMES(nolign-1) =mess(61,100,1)-num$(nolign)-":"-[V]GMESSAGE : # ligne no
       Raz [V]GMESSAGE, [V]GERR
       Break
     Endif
   Endif
 Next
 Filter [DCGX]
 If dim(ACTPOR)> 0 Kill ACTPOR : Endif
#  END FQ82397 - SEGAY 25/05/12 -   contrôle des demandes avec STA 2(Demande) ou 3(accepte)

If E
 Rollback
 [V]GMESSAGE=mess(99,116,1)-num$(E) : # Nombre d'erreurs
 [V]GERR    =1
Else
 #SBA ATTACH

 For I=0 To J-1
  [L]NCTRNUM(I)=[L]CTRNUM(I)
  [L]NSTRDAT(I)=[L]STRDAT(I)
  [L]NSTRDAY(I)=[L]STRDAY(I)
  [L]NENDDAT(I)=[L]ENDDAT(I)
  [L]NENDDAY(I)=[L]ENDDAY(I)
  [L]NNBRDAY(I)=[L]NBRDAY(I)
  [L]NTIM   (I)=[L]TIM   (I)
  [L]NDES   (I)=[L]DES   (I)
  [L]NSTA   (I)=[L]STA   (I)
  [L]NCMT   (I)=[L]CMT   (I)
  [L]NCMT2  (I)=[L]CMT2  (I)
  [L]NUID   (I)=[L]UID   (I)
  [L]NUPDNUM(I)=[L]UPDNUM(I)
  [L]NTYPPGN(I)=[L]TYPPGN(I)
  [L]NFLGANU(I)=[L]FLGANU(I)
  [L]NRPL   (I)=[L]RPL   (I)
  [L]NRPLNAM(I)=[L]RPLNAM(I)

  If [L]NADDPJ(I)=1 and [L]ADDPJ(I)=2
     # ne marche pas
     W_UID=num$([L]UID(I))
     Call DELETE_AOX_ATTACH("DCG",[L]REFNUM,num$([L]DEM),W_UID,1)From PRHPORATT
  Else
    [L]NADDPJ(I)=[L]ADDPJ(I)
  Endif
 Next
 Commit

Endif

End

################################################################################
#
# Manipulation d'une demande de congés
#
#- On reçoit une ligne, mais on peut l'éclater et retourner plusieurs lignes
#
# []STRDAY(n) = 2 : []ENDDAY(n) = 1 : # Absent le matin      le dernier jour
# []STRDAY(n) = 1 : []ENDDAY(n) = 2 : # Absent l' après-midi le premier jour
# []STRDAY(n) = 1 : []ENDDAY(n) = 1 : # Absent la journée    du premier au dernier jour
#
################################################################################

Subprog SETDEMCONGE( ACTION,REFNUM,DEM,CTRNUM,STRDAT,STRDAY,ENDDAT,ENDDAY,NBRDAY,TIM,DES
&                  , STA,CMT,UID,UPDNUM
&                  , TYPPGN,FLGANU,RPL,RPLNAM
&                  , URLBACK,CMT2
&                  )
Value    Char    ACTION(), REFNUM()
Variable Char    CTRNUM()(0..)
Variable Integer DEM, STA(0..), STRDAY(0..), ENDDAY(0..), UPDNUM(0..), UID(0..)
Variable Date    STRDAT(0..), ENDDAT(0..)
Variable Char    TIM()(0..), CMT()(0..), DES()(0..),CMT2()(0..)
Variable Decimal NBRDAY(0..)
Variable Integer TYPPGN(0..), FLGANU(0..)
Variable Char    RPL()(0..), RPLNAM()(0..)
Value    Char    URLBACK ()

Local Integer   ADDPJ(0..dim(TIM)-1)

Call SETDEMCONGEPJ( ACTION,REFNUM,DEM,CTRNUM,STRDAT,STRDAY,ENDDAT,ENDDAY,NBRDAY,TIM,DES
&                  , STA,CMT,UID,UPDNUM
&                  , TYPPGN,FLGANU,RPL,RPLNAM
&                  , URLBACK,CMT2,ADDPJ
&                  )


End




Subprog SETDEMCONGEPJ( ACTION,REFNUM,DEM,CTRNUM,STRDAT,STRDAY,ENDDAT,ENDDAY,NBRDAY,TIM,DES
&                  , STA,CMT,UID,UPDNUM
&                  , TYPPGN,FLGANU,RPL,RPLNAM
&                  , URLBACK,CMT2,ADDPJ
&                  )
Value    Char    ACTION(), REFNUM()
Variable Char    CTRNUM()(0..)
Variable Integer DEM, STA(0..), STRDAY(0..), ENDDAY(0..), UPDNUM(0..), UID(0..)
Variable Date    STRDAT(0..), ENDDAT(0..)
Variable Char    TIM()(0..), CMT()(0..), DES()(0..),CMT2()(0..)
Variable Decimal NBRDAY(0..)
Variable Integer TYPPGN(0..), FLGANU(0..), ADDPJ(0..)
Variable Char    RPL()(0..), RPLNAM()(0..)
Value    Char    URLBACK ()

# Url de retour pour message workflow, stocké dans les variables contexte du workflow de longueur 80
#Global   Char GURLRET001 (80)
#Global   Char GURLRET002 (80)
#Global   Char GURLRET003 (80)

GURLRET001 = mid$(URLBACK,001,80)
GURLRET002 = mid$(URLBACK,081,80)
GURLRET003 = mid$(URLBACK,161,80)

# Action portail pour identification dans les traitements applicatifs
Global   Char    ACTPOR(30)
ACTPOR = ACTION
GABREV = "DCG"

Local Char SAVABR (GLONAOB)
#MIPEA - 2017-06-07- US X3-43919- START
Local Char MATRICULE([V]GLONEML)
#Local Char MATRICULE([V]GLONMAT)
#MIPEA - 2017-06-07- US X3-43919- END
[L]MATRICULE=[L]REFNUM
Gosub AUTORIS
If [V]GERR : End : Endif

#Gosub OUVFIC From WODCG
Gosub NOMFIC From WODCG
If evalue("clalev([F:"+ABFIC+"])")=0
  Gosub OUVFIC From WODCG
Endif

Gosub OUVRE From WODCG

If clalev([F:ID2])=0 : Local File EMPLOID [ID2] : Endif

Read [ID]ID0=[L]REFNUM
If fstat
 [V]GMESSAGE=mess(83,102,1) : # Matricule inexistant
 [V]GERR    =1
 End
Elsif [F:ID]ENAFLG<2 | [F:ID]FLGTPS<2
#MIPEA - 2017-06-07- US X3-43919- START
 [V]GMESSAGE=mess(11,10709,1) : # Pas de saisie des temps pour cet employé
# [V]GMESSAGE=mess(11,709,1) : # Pas de saisie des temps pour cet employé
#MIPEA - 2017-06-07- US X3-43919- END
 [V]GERR    =1
 End
Endif

Local Char     GRPDEB(250) , GRPW (20)
# 58860
Local Char     CLECUR2(30)(1..4)
Local Integer  I, J, N, OK, CLECUR
Local Libelle  TRANS
I=5
#MIPEA - 2017-06-07- US X3-43919- START
Local Char     CONTRAT([V]GLONHRCTR)(I), EVT([V]GLONTPS)(I), EVTDES(20)(I)
#Local Char     CONTRAT([V]GLONCTR)(I), EVT([V]GLONTPS)(I), EVTDES(20)(I)
#MIPEA - 2017-06-07- US X3-43919- END
Local Date     DEMDEB(I), DEMFIN(I)
Local Integer  JOUDEB(I), JOUFIN(I)
Local Decimal  NBRJOU(I)

Local Mask DCG1 [DCG1]
Gosub OUVRE From SUBDCG
#SEGAY 11/04/12 80868 : Validation différée des écrans
Call ISSCREENOK(nomap,"DCG1") From INTRUTILB

[L]CLECUR=1
Gosub DROIT From SUBDCG
If ![L]CLECUR : [V]GERR=1 : End : Endif

If [L]DEM>0
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
# Link [CTR] With [DCG]DCG0(1)=REFNUM
#&             As [LNK]
#&          Where CTRDAT<=[DCG]STRDAT & (XITDAT=[0/0/0] | XITDAT>=[DCG]ENDDAT)
#&              & [DCG]DEM=[L]DEM
#MIPEA - 2017-06-07- US X3-43919- START
 Link [HRCTR] With [DCG]DCG0(1)=REFNUM
&             As [LNK]
&          Where (CTRDAT<=[DCG]STRDAT | (FLGRET=2 & RETDATEFF<=[DCG]STRDAT)) & (XITDAT=[0/0/0] | XITDAT>=[DCG]ENDDAT)
&              & [DCG]DEM=[L]DEM
# Fin MABON
 Default File [LNK]
Else
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
# Filter [CTR] Where CTRDAT<=[L]STRDAT & (XITDAT=[0/0/0] | XITDAT>=[L]ENDDAT)
 Filter [HRCTR] Where (CTRDAT<=[L]STRDAT | (FLGRET=2 & RETDATEFF<=[L]STRDAT)) & (XITDAT=[0/0/0] | XITDAT>=[L]ENDDAT)
 # Fin MABON
 Default File [HRCTR]
# Link [CTR] With [DCG]DCG0(1)=REFNUM
#&             As [LNK]
#&          Where (CTRDAT<=[DCG]STRDAT | (FLGRET=2 & RETDATEFF<=[DCG]STRDAT)) & (XITDAT=[0/0/0] | XITDAT>=[DCG]ENDDAT)
#&              & [DCG]DEM=[L]DEM
## Fin MABON
# Default File [LNK]
#Else
## FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
## Filter [CTR] Where CTRDAT<=[L]STRDAT & (XITDAT=[0/0/0] | XITDAT>=[L]ENDDAT)
# Filter [CTR] Where (CTRDAT<=[L]STRDAT | (FLGRET=2 & RETDATEFF<=[L]STRDAT)) & (XITDAT=[0/0/0] | XITDAT>=[L]ENDDAT)
# # Fin MABON
# Default File [CTR]
 #MIPEA - 2017-06-07- US X3-43919- END
Endif

#64942 : Avant appel func AFNC.PARAM#
#66099
GMOIPAY=gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",""))
#68318
#If GMOIPAY=[0/0/0] : GMOIPAY=eomonth(date$) : Endif
If GMOIPAY=[0/0/0] : GMOIPAY=gdat$(01,month(date$),year(date$)) : Endif

If GMOIPAY = [00/00/0000]   : # 66099
 GERR = 1
 #MIPEA - 2017-06-07- US X3-43919- START
  GMESSAGE = mess(79,10701,1)  : # Pas de date de paie définie sur cette periode
# GMESSAGE = mess(79,701,1)  : # Pas de date de paie définie sur cette periode
 #MIPEA - 2017-06-07- US X3-43919- END
 Filter [F]
 End
Endif

#MIPEA - 2017-06-07- US X3-43919- START
For [F:HRCTR]CTR0 Where REFNUM=[L]REFNUM & (CTRNUM=[L]CTRNUM | [L]CTRNUM="")
 If !find([F:HRCTR]ETRSRV,[V]GAUTSRV)
  [V]GMESSAGE=mess(31,10702,1) : # Vous n'avez pas les droits pour ce salarié
#For [F]CTR0 Where REFNUM=[L]REFNUM & (CTRNUM=[L]CTRNUM | [L]CTRNUM="")
# If !find([F:CTR]ETRSRV,[V]GAUTSRV)
#  [V]GMESSAGE=mess(31,702,1) : # Vous n'avez pas les droits pour ce salarié
#MIPEA - 2017-06-07- US X3-43919- END
  [V]GERR    =1
  Break
 Elsif [V]GUSRFCY<>"\"
#MIPEA - 2017-06-07- US X3-43919- START
   S=find([F:HRCTR]ETRFCY,[V]GUSRFCY)
#  S=find([F:CTR]ETRFCY,[V]GUSRFCY)
#MIPEA - 2017-06-07- US X3-43919- END
  Case [L]ACTION
   When "CREATE"                  : If !instr(1,[V]GUSRAUZ(S),"C") : [V]GERR=1 : Endif
   When "MODIFY", "ANNUL" ,"SEND" : If !instr(1,[V]GUSRAUZ(S),"M") : [V]GERR=1 : Endif
   When "DELETE"                  : If !instr(1,[V]GUSRAUZ(S),"S") : [V]GERR=1 : Endif
  Endcase
  If [V]GERR : [V]GMESSAGE=mess(99,9009,1) : Endif : # Action non autorisée
 Endif
Next
Filter [F]
If [V]GERR : End : Endif

If [L]ACTION <> "CREATE" & [L]ACTION <>"CAL"
 If sum([L]UID)
  Filter [DCG] Where DEM=[L]DEM & find(UID,[L]UID) Order By Key CLE=STA Desc
 Else
  Filter [DCG] Where DEM=[L]DEM Order By Key CLE=STA Desc
 Endif
 Read [DCG] First
 Filter [DCG]
 If fstat
  [V]GMESSAGE=mess(23,100,1) : # Fiche inexistante
  [V]GERR    =1
  End
 Elsif [F:DCG]STA>1 & !find([L]ACTION,"READ","SEND","ANNUL")
#MIPEA - 2017-06-07- US X3-43919- START
  [V]GMESSAGE=mess(188,10709,1) : # La demande de congés n'est plus en statut brouillon
#  [V]GMESSAGE=mess(188,709,1) : # La demande de congés n'est plus en statut brouillon
#MIPEA - 2017-06-07- US X3-43919- END
  [V]GERR    =1
  End
 Endif
Endif

Local Mask DCG1 [WI1]
Raz [M:WI1], [M:DCG1]
[M:DCG1]         =[F:ID]
#MIPEA - 2017-06-07- US X3-43919- START
[M:DCG1]FLGMULCTR="KM:"+num$([V]GLONHRCTR)+"X"
#[M:DCG1]FLGMULCTR="KM:"+num$([V]GLONCTR)+"X"
#MIPEA - 2017-06-07- US X3-43919- END

Case [L]ACTION
When "CREATE" , "CAL"
 Gosub INI_IMPORT
 If [V]GERR : End : Endif
# [V]GIMPORT =1
# [V]GSILENCE=1

 If ACTION = "CAL"
  # 70120 on ne doit pas tenir compte des lignes refusées ou annulées dans les tests de CAL
  # Alors on précharge l'écran et on sautera les occurences annulées dans la boucle
   [M:DCG1]         = [M:WI1]
   [M:DCG1]         = [F:ID]
#MIPEA - 2017-06-07- US X3-43919- START
   [M:DCG1]FLGMULCTR= "KM:"+num$([V]GLONHRCTR)+"X"
#   [M:DCG1]FLGMULCTR= "KM:"+num$([V]GLONCTR)+"X"
#MIPEA - 2017-06-07- US X3-43919- END
 Endif

 mkstat     =0
 For nolign=1 To [M:WI1]NBLIG
  [M:DCG1]NBLIG=nolign
  indice       =nolign-1
  status       =75

  If ACTION <> "CAL" | !find([M:WI1]STA(indice),4,6) : # 70120
   Call SAI_NBLIG("","WEB_CREATE","PORDCG") From W0DCG1
  Endif

#  If mkstat : [V]GERR=1 : Break : Endif
  If mkstat
   If GMESSAGE = ""
   # / 75252
#    GMESSAGE = "("+GZONE+")"
#    GMESSAGE = GW_MESS(GW_STAT)-"("+GZONE+")"
#    If GMESSAGE = ""
     If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
     Read [ATZ]CODZONE = "DEMCONGE";GZONE
     If !fstat
      GMESSAGE = mess(32,126,1)-'"'+func AFNC.TEXTE([F:ATZ]NOLONG)+'"'
     Endif
#    Endif
   #   75252 /
   Endif
   [V]GERR=1 : Break
  Endif
 Next
 [V]GIMPORT =0
 [V]GSILENCE=0
 If [V]GERR :  If [V]GMESSAGE="" : [V]GMESSAGE=right$([V]GMESSIMP,2) : Endif : End : Endif

 # 59187
 If ACTION <> "CAL"
  Gosub WEB_MODIF

  If [V]GOK<1 : End : Endif
  For [DCG] Where DEM=[L]DEM & find(UID,[L]UID2)
   N=find([F:DCG]UID,[L]UID2)-1
   Gosub TRANSLIG
  Next
 Else
  # pour la fonction calcul
  For nolign=1 To [M:DCG1]NBLIG
   [F:DCG]    = [M:DCG1]
   N=nolign-1
   Gosub TRANSLIG
  Next
 Endif
 # fin 59187

When "MODIFY"
 Gosub INI_IMPORT
 If [V]GERR : End : Endif
 For [DCG]DCG0 Where DEM=[L]DEM & find(UID,[L]UID)
  nolign                 =find([F:DCG]UID,[M:WI1]UID)
  [M:DCG1]               =[F:DCG]
  [M:DCG1]STA0(nolign-1) =[F:DCG]STA
  [M:DCG1]NBLIG         +=1
 Next

 [M:DCG1]NBLIG=max([M:DCG1]NBLIG,[M:WI1]NBLIG)
 #[V]GSILENCE  =1
 #[V]GIMPORT   =1
 mkstat       =0
 For nolign=1 To [M:DCG1]NBLIG
  indice=nolign-1
  status=75
  Call SAI_NBLIG("","WEB_CREATE","PORDCG") From W0DCG1
  If mkstat : [V]GERR=1 : Break : Endif
 Next
 [V]GIMPORT =0
 [V]GSILENCE=0
 If [V]GERR : If [V]GMESSAGE="" : [V]GMESSAGE=right$([V]GMESSIMP,2) : Endif : End : Endif

 Gosub WEB_MODIF

 If [V]GOK<1 : End : Endif
 For [DCG] Where DEM=[L]DEM & find(UID,[L]UID2)
  N=find([F:DCG]UID,[L]UID2)-1
  Gosub TRANSLIG
 Next

When "DELETE"
 I=0
 While [L]UID(I)
  [M:DCG1]DELUID   (I) =[L]UID   (I)
  [M:DCG1]DELUPDNUM(I) =[L]UPDNUM(I)
  I                   +=1
 Wend
 [M:DCG1]NBDEL=I

 Gosub WEB_MODIF
 If [V]GOK<1 : End : Endif

When "SEND"
 # 58860
# FQ82397 - SEGAY 25/05/12 -   contrôle des demandes avec STA 2(Demande) ou 3(accepte)
# [F:DCG] USED for C_TIM
 If clalev([F:DCGX])=0 : Local File DEMCONGE [DCGX] : Endif
# END FQ82397 - SEGAY 25/05/12
 Gosub INI_IMPORT
 If [V]GERR : End : Endif
 # fin 58860
 mkstat=0
 For [DCGX]DCG0 Where DEM=[L]DEM & find(UID,[L]UID)
   nolign                 =find([F:DCGX]UID,[M:WI1]UID)
   [M:DCG1]               =[F:DCGX]
   [M:DCG1]STA0(nolign-1) =[F:DCGX]STA
#  58860
#  [M:DCG1]STA (nolign-1) =[L]STA(nolign-1)
   [M:DCG1]STA (nolign-1) = 2
   [M:DCG1]NBLIG         +=1

   Raz [V]GMENLOC
   #58860
   #Call AS_STA([M:DCG1]STA0(nolign-1)) From SUBDCG
   Call AS_STA([M:DCG1]STA(nolign-1)) From SUBDCG
   If [V]GMENLOC([M:DCG1]STA(nolign-1))<>0
    [V]GMESSAGE=mess(99,123,1) : # Option incorrecte
    [V]GERR    =1
    Break
   Endif
   Call C_STA([M:DCG1]STA(nolign-1)) From SUBDCG
   If mkstat : [V]GERR=1 : Break : Endif
#  FQ82397 - SEGAY 25/05/12 -   contrôle des demandes avec STA 2(Demande) ou 3(accepte)
#   Call C_TIM([M:DCG1]TIM(nolign-1)) From SUBDCG
#   If mkstat
#     If [V]GMESSAGE <> ""
#        [V]GMESSAGE+=" - " + mess(164,726,1) # AVERTISSEMENT : Demande à l'état brouillon
#     Else
#        [V]GMESSAGE= mess(164,726,1)
#     Endif
#    [V]GERR=1 : Break :
#   Endif
#  End FQ82397 - SEGAY 25/05/12
 Next
 If [V]GERR : End : Endif
 OK = 1
 Gosub VERIF_MOD From SUBDCG
 If ![L]OK : End : Endif

 Gosub WEB_MODIF
 If [V]GOK<1 : End : Endif

When "READ"
 N=0
# 56784
# For [DCG]DCG0 Where DEM=[L]DEM
# 73242 Filter [F:DCG] Where DEM=[L]DEM & UID > 0 Order By Key CLE=STRDAT;STRDAY
 Filter [F:DCG] Where DEM=[L]DEM & UID > 0 Order By Key CLE=STRDAT;ENDDAY
 For [F:DCG]CLE

 # FQ88082 FQ81317 - SEGAY 03/04/12 - SBA
#MIPEA - 2017-06-07- US X3-43919- START
If [F:DCG]TIM<>[F:TIM]COD : Read [TIM]TIM0=GCURLEG;[F:DCG]TIM : Endif
#If [F:DCG]TIM<>[F:TIM]COD : Read [TIM]TIM0=[F:DCG]TIM : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If func IS_TIMACCES([F:TIM]ACS,2)
# FQ88082 FQ81317 : fin
  If N>=dim([L]UID)
   [V]GERR=1
  Else
   Gosub TRANSLIG
  Endif
  N+=1
  # # FQ88082 FQ81317 - SEGAY 03/04/12 - SBA
  Endif
  # FQ88082 FQ81317 : fin
 Next
# 56784
 Filter [F:DCG]
 If [V]GERR=1
#MIPEA - 2017-06-07- US X3-43919- START
  [V]GMESSAGE="SETDEMCONGE :"-func AFNC.MES1(mess(80,10701,1),num$(N))
#  [V]GMESSAGE="SETDEMCONGE :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2017-06-07- US X3-43919- END
  #           Dimension des variables inférieure à $1$
 Endif

When "ANNUL"
  For [DCG]DCG0 Where DEM=[L]DEM & UID = [L]UID
    # default value
    #DEHEN - JIRA X3PEOP-2312 - 2016-10-27 - START
    nolign                   = [M:DCG1]NBLIG+1
    [M:DCG1]                 = [F:DCG]
    [M:DCG1]UPDNUM(nolign-1) = [L]UPDNUM
    [M:DCG1]NBLIG           += 1
   #  rules by status
   If  [F:DCG]STA =3
    [M:DCG1]STA0(nolign-1)   = [F:DCG]STA
    [M:DCG1]STA(nolign-1)    = 5           : # demande d'annulation
   Else
    [M:DCG1]STA0(nolign-1)   = 1
    [M:DCG1]STA(nolign-1)    = 1           : # status : 2 need to cancel wrk
    Call MAJ_HISSUIPOR(0)From SUBDCG
   Endif
  Next
  #DEHEN - JIRA X3PEOP-2312 - 2016-10-27 - END
  [M:WI1] = [M:DCG1]  : # Dans $WEB_CREATE on fait des assign WI1 vers DCG1

  mkstat       =0
  For nolign=1 To [M:DCG1]NBLIG
   indice=nolign-1
   status=75
   Call SAI_NBLIG("","WEB_CREATE","PORDCG") From W0DCG1
   If mkstat : [V]GERR=1 : Break : Endif
  Next

  If [V]GERR : If [V]GMESSAGE="" : [V]GMESSAGE=right$([V]GMESSIMP,2) : Endif : End : Endif

  Gosub WEB_MODIF


  If [V]GOK<1 : End : Endif
  For [DCG] Where DEM=[L]DEM & find(UID,[L]UID2)
   N=find([F:DCG]UID,[L]UID2)-1
   Gosub TRANSLIG
  Next

Endcase

End

#-------------------------------------------------------------------------------
#
# Vérification début/fin congés et alimentation masque temporaire WI1
#
$INI_IMPORT
#73651 pour être sur d'être sur le bon employé. Les contrôle existence ont déjà été faits.
If [ID]REFNUM <> [L]REFNUM : Read [ID]ID0 = [L]REFNUM : Endif
#end 73651
#[ID]FLGMULCTR
While N<dim([L]STRDAT) & [L]STRDAT(N)>[0/0/0]

  If [L]STA(N) < 3 : # 71522 On éclate pas ce qui est déjà validé
   Raz [L]CONTRAT, [L]EVT, [L]DEMDEB,[L]DEMFIN, [L]JOUDEB, [L]JOUFIN, [L]NBRJOU, [L]EVTDES

   Call DETAILCP( [L]REFNUM,[L]CTRNUM(N),[L]STRDAT(N),[L]STRDAY(N),[L]ENDDAT(N)
&               , [L]ENDDAY(N),[L]TIM(N),[L]CONTRAT,[L]DEMDEB,[L]JOUDEB,[L]DEMFIN
&               , [L]JOUFIN,[L]EVT,[L]EVTDES,[L]NBRJOU
&               )
  Else

   [L]EVT   (0) = [L]TIM   (N)
   If [L]EVT = "CP"        : # transcription du code CP en dur
    If func AFNC.PARAM("TYPCP",[CTR]ETRFCY) = "2"
     Call PARAM("","CPA",[L]EVT) From ADOVAL
    Else
     Call PARAM("","CPE",[L]EVT) From ADOVAL
    Endif
   Endif

   [L]NBRJOU(0) = [L]NBRDAY(N)
   [L]DEMDEB(0) = [L]STRDAT(N)
   [L]DEMFIN(0) = [L]ENDDAT(N)
   [L]JOUDEB(0) = [L]STRDAY(N)
   [L]JOUFIN(0) = [L]ENDDAY(N)
  Endif

 If [V]GERR : [V]GMESSAGE=mess(61,100,1)-num$(N+1)-":"-[V]GMESSAGE : Break : Endif

 I=0
 While I <= dim([L]DEMDEB) & [L]DEMDEB(I)>[0/0/0]
  If ACTION = "SEND" & [L]STA(N) <> 1 : # 71522 en validation, on ne traite que les brouillons
   Raz [L]UID(N)
   Break
  Endif

  If !find([L]UID(N),[M:WI1]UID) : [M:WI1]UID   (J)=[L]UID   (N) : Endif
  If [M:WI1]UID(J)               : [M:WI1]UPDNUM(J)=[L]UPDNUM(N) : Endif
  #73651 trf numéro contrat uniquement si multicontrat, sinon pose problème
  # lors du calcul des jours restants dans SUBDCG.
  If [ID]FLGMULCTR=2 : [M:WI1]CTRNUM(J) =[L]CONTRAT(I) : Endif
  #end 73651
  [M:WI1]STRDAT(J) =[L]DEMDEB (I)
  [M:WI1]STRDAY(J) =[L]JOUDEB (I)
  [M:WI1]ENDDAT(J) =[L]DEMFIN (I)
  [M:WI1]ENDDAY(J) =[L]JOUFIN (I)
  [M:WI1]TIM   (J) =[L]EVT    (I)
  [M:WI1]NBRDAY(J) =[L]NBRJOU (I)
  # Champs qui ne sont pas revalorisés par DETAILCP (éclatement de la ligne)
  [M:WI1]CMT   (J) =[L]CMT    (N)
  [M:WI1]CMT2  (J) =[L]CMT2   (N)
  [M:WI1]RPL   (J) =[L]RPL    (N)

  If ACTION = "CAL" : # 70120
   [M:WI1]STA (J)  =[L]STA    (N)
   [M:WI1]STA0(J)  =[L]STA    (N)
   # les refus ou annulation acceptée sont comptés pour zéro jour
   If find ([L]STA(N),4,6)
    [M:WI1]NBRDAY(J) = 0
   Endif
   # On n'éclate pas les lignes qui ne sont pas des brouillons
   If [L]STA  (N) > 1
    J += 1 : Break
   Endif
  Endif              : # 70120

  I               +=1
  J               +=1
 Wend

 N+=1
Wend

If [V]GERR : Return : Endif
[M:WI1]NBLIG=J
Default Mask [DCG1]
Return

#-------------------------------------------------------------------------------
#
# Enregistrement des modifs
#

$WEB_MODIF
[L]TRANS=adxlog
Call DEBTRANS From GLOCK
If ![L]TRANS : Trbegin [DCG] : Endif

 Gosub MODIF From SUBDCG

If ![L]TRANS
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : Return : Else Goto WEB_MODIF : Endif
 Elsif ![V]GOK
  Rollback
  Return
 Endif
 Commit
Elsif [V]GOK<>1
 [V]GERR=1
 If [V]GMESSAGE="" : [V]GMESSAGE=mess(35,110,1) : Endif : # Erreur transactionnelle
Endif
[L]DEM=[L]NODEM

#Workflow
If [V]GOK=1 & find([L]ACTION,"SEND","ANNUL")
 Call IDENT3("DCG",[L]GRPDEB,[L]REFNUM,[L]CLECUR2) From GOBJTXT : # 62751 [L]REFNUM à la place de num$([L]DEM)
 Call WRKGLOB(171,[L]GRPDEB,"DEMCONGE","") From GOBJACT
# 59084
 SAVABR = GABREV
 GABREV = "DCG"
 Call WORKPLUS(2,"DCG","M",[L]GRPDEB,"",0,0,2,[L]GRPW) From AWRK  : # 62014
 GABREV = SAVABR
 If !GOK           : # ne peut arrivé que si le workflow est en mode débug
  GERR=1
  GMESSAGE=mess(7,21,1)-mess(1,75,1) : # Erreur Workflow
 Endif
Endif

Return

#-------------------------------------------------------------------------------
#
# Alimentation de [M:DCG1] pour simuler l'import
#

$WEB_CREATE
Case evalue("type([M:WI1]"+[L]IMPZON+")")
When 1,2,4,5,6,7,8,9
 If evalue("[M:WI1]"+[L]IMPZON+"(nolign-1)")>0 : [L]IMPMOD=1 : Endif
When 3
 If evalue("[M:WI1]"+[L]IMPZON+"(nolign-1)")>[0/0/0] : [L]IMPMOD=1 : Endif
When Default
 If evalue("[M:WI1]"+[L]IMPZON+"(nolign-1)")>"" | [L]IMPZON="CMT" | [L]IMPZON="CMT2" : [L]IMPMOD=1 : Endif
Endcase
If [L]IMPMOD
 Assign "[M:DCG1]"+[L]IMPZON+"(nolign-1)" With evalue("[M:WI1]"+[L]IMPZON+"(nolign-1)")
Endif
Return

#-------------------------------------------------------------------------------
$TRANSLIG
[L]CTRNUM(N)=[F:DCG]CTRNUM
[L]STRDAT(N)=[F:DCG]STRDAT
[L]STRDAY(N)=[F:DCG]STRDAY
[L]ENDDAT(N)=[F:DCG]ENDDAT
[L]ENDDAY(N)=[F:DCG]ENDDAY
[L]NBRDAY(N)=[F:DCG]NBRDAY
[L]STA   (N)  =[F:DCG]STA
[L]CMT   (N)  =[F:DCG]CMT
[L]CMT2  (N)  =[F:DCG]CMT2
[L]UID   (N)  =[F:DCG]UID
[L]UPDNUM(N)  =[F:DCG]UPDNUM

# On remet le code CP en dur destiné au portail
# +62095
Case [F:DCG]TIM
 When func AFNC.PARAMDOS("","CPA") , func AFNC.PARAMDOS("","CPE")
  [L]TIM(N)    = "CP"
#MIPEA - 2017-06-07- US X3-43919- START
  [L]DES(N)    = mess(4,10334,1)
#  [L]DES(N)    = mess(4,334,1)
#MIPEA - 2017-06-07- US X3-43919- END
 When Default
#MIPEA - 2017-06-07- US X3-43919- START
  If [F:DCG]TIM<>[F:TIM]COD : Read [TIM]TIM0=GCURLEG;[F:DCG]TIM : Endif
#  If [F:DCG]TIM<>[F:TIM]COD : Read [TIM]TIM0=[F:DCG]TIM : Endif
#MIPEA - 2017-06-07- US X3-43919- END
  [L]TIM(N)    =[F:DCG]TIM
  [L]DES(N)    =[F:TIM]DES
Endcase
#fin 62095

Raz [F:ID2]
[L]RPL   (N)  =[F:DCG]RPL
If [F:DCG]RPL <> "" & [F:DCG]RPL <> [F:ID2]REFNUM : Read [F:ID2]ID0=[F:DCG]RPL : Endif
[L]RPLNAM(N)  =[F:ID2]NAM-[F:ID2]SRN
# FQ88082 FQ81317 - SEGAY 03/04/12 - SBA
#  If [F:DCG]STRDAT < GMOIPAY | [F:DCG]STA <> 3
#DEHEN - JIRA X3PEOP-2312 - 2016-10-27 - START
  #If [F:DCG]STRDAT < GMOIPAY | [F:DCG]STA <> 3 | !(func GETCONTACCES_ECM([F:TIM]ACS,1))
    Gosub IS_CANCELED
    If !IS_CANCELED
      [L]FLGANU(N)=0
    Else
      [L]FLGANU(N)=1
    Endif
#DEHEN - JIRA X3PEOP-2312 - 2016-10-27 - END

# SBA ATTACH
[L]ADDPJ(N)=0
If [L]UID(N)<>0
  If ([F:DCG]STA<2)
    [L]ADDPJ(N)=1
  Endif
  If func SUBDCG.ISATTACH([F:DCG]REFNUM,[F:DCG]DEM,[L]UID(N))
    [L]ADDPJ(N)=2
  Endif
Endif

Return

################################################################################
#
# Précise pour tous les contrats, les dates de début et fin légales et le nombre de jours
# à imputer
#
# - Attention : les variables STRDAY , ENDDAY ne sont pas les
#               mêmes que celle du trt appelant.
################################################################################

Subprog DETAILCP( MATRICULE,CONTRAT,DATDEB,ENDHALF,DATFIN,STARTHALF,EVMT,CTRNUM,STRDAT
&               , STRDAY,ENDDAT,ENDDAY,TIM,DES,NBRDAY
&               )

Value    Char    MATRICULE, CONTRAT
Value    Date    DATDEB, DATFIN
#74589 Value    Integer JOUDEB, JOUFIN remplacement par endhalf et startalf pour lisibilité
Value    Integer ENDHALF, STARTHALF
Variable Char    CTRNUM()(0..), TIM()(0..), DES()(0..), EVMT()
Variable Date    STRDAT(0..), ENDDAT(0..)
Variable Integer STRDAY(0..), ENDDAY(0..)
Variable Decimal NBRDAY(0..)

Gosub AUTORIS
If [V]GERR : End : Endif

#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:HRCTR])  : Local File EMPLOCTR [HRCTR]  : Endif
#If !clalev([F:CTR])  : Local File EMPLOCTR [CTR]  : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If !clalev([F:TIM2]) : Local File TIMCOD   [TIM2] : Endif
If !clalev([F:TIM])  : Local File TIMCOD   [TIM]  : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:FCY])  : Local File FACILITY [FCY]  : Endif
#If !clalev([F:SIT])  : Local File SITEPAYE [SIT]  : Endif
#MIPEA - 2017-06-07- US X3-43919- END

Local Char     CRITERE(250), CRITERE2(250), CPE([V]GLONTPS), CPA([V]GLONTPS) , DEFCP(1)
Local Char     AM(4), PM(4),C(1)
Local Integer  I, J, N
Local Integer  NBDATNOK : # SEGAY - 02/11/11 - FQ77381 -
Local Libelle  DEMID, DEMIF, OKEVMT
Local Decimal  JOUR(1..440), HEURE(1..440), JOURW(1..440), F
Local Date     DEB, FIN

Call PARAM("","CPA",[L]CPA) From ADOVAL
Call PARAM("","CPE",[L]CPE) From ADOVAL

# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#[L]CRITERE ="REFNUM='"+[L]MATRICULE+"' & CTRDAT<=["+num$([L]DATFIN)
#&         + "] & (XITDAT=[0/0/0] | XITDAT>=["+num$([L]DATDEB)+"])"
[L]CRITERE ="REFNUM='"+[L]MATRICULE+"' & (CTRDAT<=["+num$([L]DATFIN)
&         + "] | (FLGRET=2 & RETDATEFF<=["+num$([L]DATFIN)+"])) & (XITDAT=[0/0/0] | XITDAT>=["+num$([L]DATDEB)+"])"
# Fin MABON
If [L]CONTRAT>"" : [L]CRITERE-="& CTRNUM='"+[L]CONTRAT+"'" : Endif

# Témoin ouvré/ouvrable pris dans un paramètre site
#Link [CTR] With [SIT]SIT0=ETRFCY As [LNK]
[L]DEFCP = func AFNC.PARAM("TYPCP",[CTR]ETRFCY)

If EVMT = "CP"        : # transcription du code CP en dur
 If [L]DEFCP = "2"    : # 62875 DEFCP=2 pour [L]CPA
  EVMT = CPA
 Else
  EVMT = CPE
 Endif
Endif

# SEGAY - 02/11/11 - FQ77381 -
[L]NBDATNOK=0
# END - FQ77381 -


Case [L]EVMT
When ""
 # 95159 Type d'évènement incorrect
# [L]CRITERE2="1=1"
 [L]CRITERE2="1<>1"
When [L]CPA, [L]CPE
 [L]CRITERE2="find(COD,'"+[L]CPE+"','"+[L]CPA+"')<>0"
When Default
 # US-2832 : cas traité au dessus à revoir
 # Read [TIM]TIM0=[L]EVMT
 #If [F:TIM]VLTEVT=2 & [F:TIM]CATTIM=3                        : # valorisation CP & catégorie Congés
 # [L]CRITERE2="find(COD,'"+[L]CPE+"','"+[L]CPA+"')<>0"
 #Else
  [L]CRITERE2="COD='"+[L]EVMT+"'"
 #Endif
Endcase

Local Date DATDEBCTR
For [TIM2]TIM0 Where ENAFLG=2 & AUZPRH=2 & evalue([L]CRITERE2)
 [L]OKEVMT=1
#MIPEA - 2017-06-07- US X3-43919- START
 For [HRCTR]CTR0(2) Where evalue([L]CRITERE)
# For [CTR]CTR0(2) Where evalue([L]CRITERE)
#MIPEA - 2017-06-07- US X3-43919- END
  If !find([F:TIM2]COD,[L]CPE,[L]CPA) | ([F:TIM2]COD=[L]CPA & [L]DEFCP="2")
&  | ([F:TIM2]COD=[L]CPE & [L]DEFCP<"2")                                    : # 62875 DEFCP=2 pour [L]CPA
   If N>=dim([L]CTRNUM)
    [V]GERR=1
    Break 2 : # 95159 Erreur de dimensionnement
   Else

#MIPEA - 2017-06-07- US X3-43919- START
    For [HRCTR]CTR0
     # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
     DATDEBCTR=[F:HRCTR]CTRDAT
     If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then
      DATDEBCTR=[F:HRCTR]RETDATEFF
     Endif
#    For [CTR]CTR0
#     # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#     DATDEBCTR=[F:CTR]CTRDAT
#     If [F:CTR]FLGRET=2 & [F:CTR]RETDATEFF<>[0/0/0] Then
#      DATDEBCTR=[F:CTR]RETDATEFF
#     Endif
#MIPEA - 2017-06-07- US X3-43919- END
#     [L]DEB=max([L]DATDEB,[F:CTR]CTRDAT)
     [L]DEB=max([L]DATDEB,DATDEBCTR)
     # Fin MABON
#MIPEA - 2017-06-07- US X3-43919- START
     If [F:HRCTR]XITDAT=[0/0/0] : [L]FIN=[L]DATFIN
     Else                         [L]FIN=min([L]DATFIN,[F:HRCTR]XITDAT)
     Endif
     I=[L]DEB-[L]DATDEB+1
     If [F:HRCTR]PLNTYP=""
#     If [F:CTR]XITDAT=[0/0/0] : [L]FIN=[L]DATFIN
#     Else                       [L]FIN=min([L]DATFIN,[F:CTR]XITDAT)
#     Endif
#     I=[L]DEB-[L]DATDEB+1
#     If [F:CTR]PLNTYP=""
#MIPEA - 2017-06-07- US X3-43919- END
      For J=I To [L]FIN-[L]DEB+1+I : [L]JOUR(J)=1 : Next
     Else
# SEGAY - 02/11/11 - FQ77381 -
      If([L]FIN+70-[L]DEB) >= dim([L]JOUR)
       [L]NBDATNOK=[L]FIN-[L]DEB
       Break 3
      Endif
# END - FQ77381 -
#MIPEA - 2017-06-07- US X3-43919- START
      Call VALORDET( [L]DEB,[L]FIN+70,[F:HRCTR]REFNUM,[V]GTPSW,[L]JOURW(I..440)
&                  , [L]HEURE(I..440),[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM
&                  ) From SUBPLN
      Call VALORDET( [L]DEB,[L]FIN+70,[F:HRCTR]REFNUM,[F:TIM2]COD,[L]JOUR(I..440)
&                  , [L]HEURE(I..440),[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM
&                  ) From SUBPLN
#      Call VALORDET( [L]DEB,[L]FIN+70,[F:CTR]REFNUM,[V]GTPSW,[L]JOURW(I..440)
#&                  , [L]HEURE(I..440),[F:CTR]ETRFCY,[F:CTR]CTRNUM
#&                  ) From SUBPLN
#      Call VALORDET( [L]DEB,[L]FIN+70,[F:CTR]REFNUM,[F:TIM2]COD,[L]JOUR(I..440)
#&                  , [L]HEURE(I..440),[F:CTR]ETRFCY,[F:CTR]CTRNUM
#&                  ) From SUBPLN
#MIPEA - 2017-06-07- US X3-43919- END
     Endif

#    73242 [L]DEMID=[L]JOUDEB
#    73242 [L]DEMIF=[L]JOUFIN
     [L]DEMID=[L]STARTHALF
     [L]DEMIF=[L]ENDHALF

     If GTPS : # 69211

     # demande d'une demi journée d'absence alors qu'on travaille qu'une demi-journée
     # -> on supprime la demande !
     #74489    If [L]JOUDEB=2 & [L]JOUR(1)>0     : # 73242 non modifié
     If [L]STARTHALF=2 & [L]JOUR(1)>0
#MIPEA - 2017-06-07- US X3-43919- START
      Call GETSEMTYP( [F:HRCTR]PLNTYP,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]DEB,[L]DEB,C,[L]DEB,C,I,F,[L]AM,C,[L]PM,C,C
&                   , C
&                   ) From PORTPS   : # 62965
#      Call GETSEMTYP( [F:CTR]PLNTYP,[F:CTR]REFNUM,[F:CTR]CTRNUM,[L]DEB,[L]DEB,C,[L]DEB,C,I,F,[L]AM,C,[L]PM,C,C
#&                   , C
#&                   ) From PORTPS   : # 62965
#MIPEA - 2017-06-07- US X3-43919- END
      If [L]PM="" : [L]JOUR(1)=0 : Endif
      If [L]AM="" | [L]PM="" : [L]DEMID=1 : Endif
     Endif
     J=[L]DATFIN-[L]DATDEB+1
     #74489    If [L]JOUFIN=2 & [L]FIN=[L]DATFIN     : #    73242 non modifié
     If [L]ENDHALF=2 & [L]FIN=[L]DATFIN
#MIPEA - 2017-06-07- US X3-43919- START
      Call GETSEMTYP( [F:HRCTR]PLNTYP,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]FIN,[L]FIN,C,[L]FIN,C,I,F,[L]AM,C,[L]PM,C,C
&                   , C
&                   ) From PORTPS   : # 62965
#      Call GETSEMTYP( [F:CTR]PLNTYP,[F:CTR]REFNUM,[F:CTR]CTRNUM,[L]FIN,[L]FIN,C,[L]FIN,C,I,F,[L]AM,C,[L]PM,C,C
#&                   , C
#&                   ) From PORTPS   : # 62965
#MIPEA - 2017-06-07- US X3-43919- END
      If [L]AM="" : [L]FIN-=1 : Endif
      If [L]AM="" | [L]PM="" : [L]DEMIF=1 : Endif
     Endif

     Endif

    Next


    J=[L]FIN-[L]DATDEB+1
    If J  : # 65223
    For I=1 To 440
     If ((I=1 & [L]DEMID=2) | (I=J & [L]DEMIF=2)) & [L]JOUR(I)>0.5 : #     73242 non modifié
      [L]JOUR(I)-=0.5
     Endif
     [L]NBRDAY(N)+=[L]JOUR(I)
     If [L]JOURW(I) & [L]NBRDAY(N)>0 & [L]STRDAT(N)=[0/0/0] : # déb le 1er jour travaillé
      [L]STRDAT(N)=[L]DATDEB+I-1
#     73242 [L]STRDAY(N)=1+([L]DEMID=2 & I=1)
      [L]ENDDAY(N)=1+([L]DEMID=2 & I=1)
      [L]ENDDAT(N)=[L]DATDEB+I-1
#     73242 [L]ENDDAY(N)=1+([L]DEMIF=2 & I=J)
      [L]STRDAY(N)=1+([L]DEMIF=2 & I=J)
     Endif
     If [F:TIM2]VLTEVT=2 : # CP
      If [L]STRDAT(N)>[0/0/0]
       [L]ENDDAT(N)=[L]DATDEB+I-1
#     73242 [L]ENDDAY(N)=1+([L]DEMIF=2 & I=J)
      [L]STRDAY(N)=1+([L]DEMIF=2 & I=J)
      Endif
      # fin à la veille d'un jour travaillé
#      If (I>=J & [L]JOURW(I+1)) | (I=J & [L]DEMIF=2 & [L]JOURW(I)>[L]JOUR(I))
      If (I>=J & I<440 & [L]JOURW(I+1)) | (I=J & [L]DEMIF=2 & [L]JOURW(I)>[L]JOUR(I)) : #  73242 ligne non modifiée
       Break
      Endif
     Else
      If [L]STRDAT(N)>[0/0/0] & [L]JOUR(I)
       [L]ENDDAT(N)=[L]DATDEB+I-1
#     73242 [L]ENDDAY(N)=1+([L]DEMIF=2 & I=J)
      [L]STRDAY(N)=1+([L]DEMIF=2 & I=J)
      Endif
      If I=J : Break : Endif
     Endif
    Next
    Endif  : # 65223
    If [L]STRDAT(N)>[0/0/0]
#     If [F:TIM2]VLTEVT=2 & [F:TIM2]CATTIM=3 : [L]TIM(N)="CP" : # en dur !
     #US-2832 : Ajout "CP" dans le test
     If [F:TIM2]VLTEVT=2 & [F:TIM2]CATTIM=3 &  [L]TIM(N)="CP"
      If [L]DEFCP = "2"              : # transcription du code CP en dur : # 62875 DEFCP=2 pour [L]CPA
       [L]TIM(N) = CPA
      Else
       [L]TIM(N) = CPE
      Endif
     Else
      [L]TIM(N)=[F:TIM2]COD
     Endif
#MIPEA - 2017-06-07- US X3-43919- START
     [L]CTRNUM(N)=[F:HRCTR]CTRNUM
#     [L]CTRNUM(N)=[F:CTR]CTRNUM
#MIPEA - 2017-06-07- US X3-43919- END
     [L]DES   (N)=[F:TIM]DES
    Endif
   Endif
   If [L]STRDAT(N)>[0/0/0]
    # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#    If ([L]STRDAT(N)<=[F:CTR]XITDAT | [F:CTR]XITDAT=[0/0/0])
#&    & [L]ENDDAT(N)>=[F:CTR]CTRDAT
#MIPEA - 2017-06-07- US X3-43919- START
    If ([L]STRDAT(N)<=[F:HRCTR]XITDAT | [F:HRCTR]XITDAT=[0/0/0])
&    & ([L]ENDDAT(N)>=[F:HRCTR]CTRDAT | ([F:HRCTR]FLGRET=2 | [L]ENDDAT(N)>=[F:HRCTR]RETDATEFF))
#    If ([L]STRDAT(N)<=[F:CTR]XITDAT | [F:CTR]XITDAT=[0/0/0])
#&    & ([L]ENDDAT(N)>=[F:CTR]CTRDAT | ([F:CTR]FLGRET=2 | [L]ENDDAT(N)>=[F:CTR]RETDATEFF))
#MIPEA - 2017-06-07- US X3-43919- END
    # Fin MABON
     N+=1
    Else
     Raz [L]STRDAT(N), [L]ENDDAT(N), [L]STRDAY(N), [L]ENDDAY(N), [L]TIM(N)
&      , [L]NBRDAY(N), [L]DES(N)
    Endif
   Endif
  Endif
 Next
Next

If [V]GERR
#MIPEA - 2017-06-07- US X3-43919- START
 [V]GMESSAGE="DETAILCP :"-func AFNC.MES1(mess(80,10701,1),num$(N))
# [V]GMESSAGE="DETAILCP :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2017-06-07- US X3-43919- END
 #           Dimension des variables inférieure à $1$
# SEGAY - 02/11/11 - FQ77381 -
Elsif [L]NBDATNOK
   [V]GERR=1
#MIPEA - 2017-06-07- US X3-43919- START
   [V]GMESSAGE=func AFNC.MES2(mess(197,10709,1),num$([L]NBDATNOK),num$(dim([L]JOUR)-70))
#   [V]GMESSAGE=func AFNC.MES2(mess(197,709,1),num$([L]NBDATNOK),num$(dim([L]JOUR)-70))
#MIPEA - 2017-06-07- US X3-43919- END
 # Les bornes de dates sont de $1$ jour(s), elles sont supérieures au maximum autorisé de $2$ jour(s)
# END - FQ77381 -
Elsif ![L]OKEVMT
#MIPEA - 2017-06-07- US X3-43919- START
 [V]GMESSAGE=mess(105,10709,1) : # Type d'évènement incorrect
# [V]GMESSAGE=mess(105,709,1) : # Type d'évènement incorrect
 #MIPEA - 2017-06-07- US X3-43919- END
 [V]GERR    =1
Elsif !N
#MIPEA - 2017-06-07- US X3-43919- START
 [V]GMESSAGE=mess(172,10709,1) : # Aucun jour demandé n'est travaillé
# [V]GMESSAGE=mess(172,709,1) : # Aucun jour demandé n'est travaillé
#MIPEA - 2017-06-07- US X3-43919- END
 [V]GERR    =1
Endif

End

######################################################################################
#
# Renvoie la liste des natures d'évènements autorisés
# (autorisé = sans code d'accès ou droit "exécution" sur code d'accès associé à la nature)
######################################################################################

Subprog GETLSTTYPCNG(TIM,DES)
Variable Char TIM()(0..), DES()(0..)

#/69428
#MIPEA - 2017-06-07- US X3-43919- START
Local Char     EMP (GLONEML) , CTR (GLONHRCTR)
#Local Char     EMP (GLONMAT) , CTR (GLONCTR)
#MIPEA - 2017-06-07- US X3-43919- end
Local Integer  STAT
# 69428/

If [V]GFONCTION<>"PRHDCG"
 [V]GFONCTION="PRHDCG"
 Call AUTORIS From EXEFNC
Endif

If !clalev([F:TIM]) : Local File TIMCOD [TIM] : Endif

Local Shortint N
Local Libelle  CP

# US-2832
Gosub SET_VAR_ISCP
# / 69428
EMP = func PORSUP.EMPUSR("",GUSER)
#MIPEA - 2017-06-07- US X3-43919- START
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
#If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#Filter [CTR] Where REFNUM=EMP & CTRDAT<=date$
#MIPEA - 2017-06-07- US X3-43919- START
Filter [HRCTR] Where REFNUM=EMP & (CTRDAT<=date$ | (FLGRET=2 & RETDATEFF<=date$))
# Fin MABON
Read [HRCTR]CTR1 Last
If fstat : Raz [F:HRCTR] : Endif
Filter [HRCTR]
CTR = [F:HRCTR]CTRNUM
#Filter [CTR] Where REFNUM=EMP & (CTRDAT<=date$ | (FLGRET=2 & RETDATEFF<=date$))
## Fin MABON
#Read [CTR]CTR1 Last
#If fstat : Raz [F:CTR] : Endif
#Filter [CTR]
#CTR = [F:CTR]CTRNUM
#MIPEA - 2017-06-07- US X3-43919- END
# 69428 # ce pavé sera supprimé quand on recevra EMP + CTR dans la zone d'échange
        # EMP & CTR seront donc déclarés en "Value"

# 69428 # Il faut recevoir dans la zone d'échange EMP+CTR
# 69428 # pour actualiser la liste des codes saisissables en intégrant
# 69428 # les restrictions supplémentaires lié au salarié pour qui on pose des congés
# 69428 # ça oblige le portail à refaire l'appel de la liste des codes évènements à
# 69428 # chaque changement de code salarié ou contrat

#  69428 /

For [TIM]TIM0 Where AUZPRH=2 & ENAFLG=2
  mkstat=0
  Call CONTEXE([F:TIM]ACS) From CPTSUB
  If !mkstat

    # SBA à changer
    # US-2832
    If [F:TIM]VLTEVT=2 & [F:TIM]CATTIM=3 & func DIVPAYE.IS_CP([F:TIM]COD,W_CPA,W_CPE)                         : # valorisation CP & catégorie Congés
      If [L]CP
        mkstat=1
      Else
        # / 69428
        # FQ74044 - SEGAY 13/02/12 - Ajout vérification du nouveau champ FILTRE
        Gosub FILTSUP_EVT_TIM
        If STAT & STAT <> 2 : # On aura pas plus que l'accès déjà contrôlé avant
          mkstat = 1
        Else
        # END FQ74044
          Gosub FILTSUP_EVT
          If STAT & STAT <> 2
            mkstat = 1
          Endif
        Endif
        If !mkstat
          #   69428 /
          [L]CP=1
          [F:TIM]COD="CP"                : # En dur !
#MIPEA - 2017-06-07- US X3-43919- START
          [F:TIM]DES = mess(4,10334,1)     : # Congés payés
#          [F:TIM]DES = mess(4,334,1)     : # Congés payés
#MIPEA - 2017-06-07- US X3-43919- END
        Endif
      Endif
    Endif
  Endif

  # / 69428
  If !mkstat
    # FQ74044 - SEGAY 13/02/12 - Ajout vérification du nouveau champ FILTRE
    Gosub FILTSUP_EVT_TIM
    If STAT & STAT <> 2 : # On aura pas plus que l'accès déjà contrôlé avant
      mkstat = 1
    Else
      # END FQ74044
      Gosub FILTSUP_EVT
      If STAT & STAT <> 2
        mkstat = 1
      Endif
    Endif
  Endif
  #   69428 /

  If !mkstat
    If N>=dim([L]TIM)
      [V]GERR=1
    Else
      [L]TIM(N)=[F:TIM]COD
      [L]DES(N)=[F:TIM]DES
    Endif
    N+=1
  Endif
Next

If [V]GERR
#MIPEA - 2017-06-07- US X3-43919- START
  [V]GMESSAGE="GETLSTTYPCNG :"-func AFNC.MES1(mess(80,10701,1),num$(N))
#  [V]GMESSAGE="GETLSTTYPCNG :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2017-06-07- US X3-43919- END
  #           Dimension des variables inférieure à $1$
Endif
End

######################################################################################
#
# Renvoie la liste des natures d'évènements + Code design et type d'accès+prolongation
# # témoin commentaire obligatoire
######################################################################################


######################################################################################
#
# Renvoie la liste des natures d'évènements + Code design et type d'accès+prolongation
# # témoin commentaire obligatoire
######################################################################################
Subprog GETALLTYPCNG(PEMP,PCTR,PTYPAPP,TIM,DES,DSG,ACS,PGN,CMT,VLT,DSPSLD,CTRTIM)
Variable Char    PEMP(),PCTR(),PTYPAPP()
Variable Char    TIM()(0..), DES()(0..), DSG()(0..)
Variable Integer ACS(0..) , PGN(0..) , CMT(0..)
Variable Integer VLT(0..) # Valorisation 1=RTT 2=CP
Variable Integer DSPSLD(0..)
Variable Char    CTRTIM()(0..)
If !clalev([F:TIM]) : Local File TIMCOD [TIM] : Endif
If !clalev([F:ACC]) : Local File ACCES  [ACC] : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
#If !clalev([F:CTR]) : Local File EMPLOCTR [CTR] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If !clalev([F:ID1]) : Local File EMPLOID [ID1] : Endif

Local Shortint N
Local Libelle  CP
Local Integer  AC,NOPRL
#/69428
#MIPEA - 2017-06-07- US X3-43919- START
Local Char     EMP (GLONEML) , CTR (GLONHRCTR)
#Local Char     EMP (GLONMAT) , CTR (GLONCTR)
#MIPEA - 2017-06-07- US X3-43919- END
Local Integer  STAT
# 69428/
Local Integer  MULTICTR
# / 71093
Local Char TIMPROLONG(GLONTPS)(8)
Local Char EVTCP([V]GLONTPS) : # SEGAY

TIMPROLONG(0) = func AFNC.PARAM("AT","")
TIMPROLONG(1) = func AFNC.PARAM("ATTRAJET","")
TIMPROLONG(2) = func AFNC.PARAM("MALADIE","")
TIMPROLONG(3) = func AFNC.PARAM("MALPROF","")
TIMPROLONG(4) = func AFNC.PARAM("MATERNITE","")
TIMPROLONG(5) = func AFNC.PARAM("PATERNITE","")
TIMPROLONG(6) = func AFNC.PARAM("PATHPREN","")
TIMPROLONG(7) = func AFNC.PARAM("PATHPOST","")
#   71093 /
Read [ID1]ID0 = [L]PEMP
[L]EMP = [L]PEMP
If [L]PCTR <> ""
  # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#  Filter [CTR] Where REFNUM=[L]PEMP & CTRNUM=[L]PCTR & CTRDAT<=date$ & (XITDAT=[0/0/0] | XITDAT>=date$)
#MIPEA - 2017-06-07- US X3-43919- START
  Filter [HRCTR] Where REFNUM=[L]PEMP & CTRNUM=[L]PCTR & (CTRDAT<=date$ | (FLGRET=2 & RETDATEFF<=date$)) & (XITDAT=[0/0/0] | XITDAT>=date$)
  # Fin MABON
Else
  # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#  Filter [CTR] Where REFNUM=[L]PEMP &  CTRDAT<=date$ & (XITDAT=[0/0/0] | XITDAT>=date$)
  Filter [HRCTR] Where REFNUM=[L]PEMP &  (CTRDAT<=date$ | (FLGRET=2 & RETDATEFF<=date$)) & (XITDAT=[0/0/0] | XITDAT>=date$)
#  Filter [CTR] Where REFNUM=[L]PEMP & CTRNUM=[L]PCTR & (CTRDAT<=date$ | (FLGRET=2 & RETDATEFF<=date$)) & (XITDAT=[0/0/0] | XITDAT>=date$)
#  # Fin MABON
#Else
#  # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
##  Filter [CTR] Where REFNUM=[L]PEMP &  CTRDAT<=date$ & (XITDAT=[0/0/0] | XITDAT>=date$)
#  Filter [CTR] Where REFNUM=[L]PEMP &  (CTRDAT<=date$ | (FLGRET=2 & RETDATEFF<=date$)) & (XITDAT=[0/0/0] | XITDAT>=date$)
#MIPEA - 2017-06-07- US X3-43919- end
  # Fin MABON
Endif
# FQ86518 - MABON 17/12/12 - Si intermittent, on n'a pas FLGMULCTR coché, mais on peut quand même avoir plusieurs contrats
# D'où l'ajout du test sur FLGINT
If [L]PCTR <> "" or [F:ID1]FLGMULCTR <> 2
#If [L]PCTR <> "" or ([F:ID1]FLGMULCTR <> 2 & [F:ID1]FLGINT <> 2)
   MULTICTR = 0
#MIPEA - 2017-06-07- US X3-43919- START
   Read [HRCTR]CTR1 Last
   If fstat : Raz [F:HRCTR] : Endif
   Filter [HRCTR]
   [L]CTR = [F:HRCTR]CTRNUM
#   Read [CTR]CTR1 Last
#   If fstat : Raz [F:CTR] : Endif
#   Filter [CTR]
#   [L]CTR = [F:CTR]CTRNUM
#MIPEA - 2017-06-07- US X3-43919- END
   Gosub GETLSTTIM
Else
   MULTICTR = 1
#MIPEA - 2017-06-07- US X3-43919- START
   For [HRCTR]CTR0
     [L]CTR = [F:HRCTR]CTRNUM
#   For [CTR]CTR0
#     [L]CTR = [F:CTR]CTRNUM
#MIPEA - 2017-06-07- US X3-43919- END
     Gosub GETLSTTIM
   Next
Endif

If GERR
#MIPEA - 2017-06-07- US X3-43919- START
 GMESSAGE = "GETLSTTIMCOD :"-func AFNC.MES1(mess(80,10701,1),num$(N))
# GMESSAGE = "GETLSTTIMCOD :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2017-06-07- US X3-43919- END
 #           Dimension des variables inférieure à $1$
Endif

#MIPEA - 2017-06-07- US X3-43919- START
Filter [HRCTR]
#Filter [CTR]
#MIPEA - 2017-06-07- US X3-43919- END

# / 69428
#EMP = func PORSUP.EMPUSR("",GUSER)
#If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
#Filter [CTR] Where REFNUM=EMP & CTRDAT<=date$
#Read [CTR]CTR1 Last
#If fstat : Raz [F:CTR] : Endif
#Filter [CTR]
#CTR = [F:CTR]CTRNUM
# 69428 # ce pavé sera supprimé quand on recevra EMP + CTR dans la zone d'échange
        # EMP & CTR seront donc déclarés en "Value"

# 69428 # Il faut recevoir dans la zone d'échange EMP+CTR
# 69428 # pour actualiser la liste des codes saisissables en intégrant
# 69428 # les restrictions supplémentaires lié au salarié pour qui on pose des congés
# 69428 # ça oblige le portail à refaire l'appel de la liste des codes évènements à
# 69428 # chaque changement de code salarié ou contrat

#  69428 /
End

$GETLSTTIM
CP = 0
# US-2832
Gosub SET_VAR_ISCP

#SEGAY pour voir ce que l'on utilise comme CP
[L]EVTCP=""
# transcription du code CP en dur du Portail
If func AFNC.PARAM("TYPCP",[CTR]ETRFCY) = "2"
  Call PARAM("","CPA",[L]EVTCP) From ADOVAL
Else
  Call PARAM("","CPE",[L]EVTCP) From ADOVAL
Endif

# sauf natures à la fois affichage portail=Non et affichage calendrier=Non
For [TIM]TIM0 Where ENAFLG=2 & ([F:TIM]AUZPRH = 2 | [F:TIM]AUZCAL = 2)
&   & [F:TIM]DAYDAC=2 & [F:TIM]CTLDAC<2
  If N >= dim(TIM)
    GERR = 1
    Break
  Endif

 # Type d'accès
 # 0=CODE BANALISÉ         & NON SAISISSABLE
 # 1=CODE EN SURIMPRESSION & NON SAISISSABLE
 # 2=CODE EN SURIMPRESSION & SAISISSABLE

  AC = 0
  # Selon code d'accès
  If [F:TIM]ACS="" or GUSRACS=2
    AC = 2
  Else
    Read [F:ACC]CODACC = GUSER;[F:TIM]ACS
    If !fstat
      If [F:ACC]EXEC = 2
        AC = 2
      Elsif [F:ACC]CONSUL = 2
        AC = 1
      Endif
    Endif
  Endif
  #Selon affichages décris sur la nature
  If [F:TIM]AUZPRH <> 2
    AC = min(AC,1)
  Endif
  If [F:TIM]OVERWR <> 2 | [F:TIM]AUZCAL <> 2
    AC = 0
  Endif

  # FQ74044 - SEGAY 13/02/12 - Ajout vérification du nouveau champ FILTRE
  # Si on est ni dans le planning ni dans le solde collaborateurs, on vérifie le nouveau filtre + point d'entrée
  # Sinon :
  #   - si Planning, on ne vérifie que le code d'accès
  #   - si Solde, on vérifie le code d'accès + paramètre Affichage du solde
  If !find(PTYPAPP,"PLA","SOL") Then
    Gosub FILTSUP_EVT_TIM
    If STAT & STAT <> 2 : # On aura pas plus que l'accès déjà contrôlé avant
      AC = 0
    Else
    # END FQ74044
      # / 69428
      Gosub FILTSUP_EVT
      If STAT & STAT < AC : # On aura pas plus que l'accès déjà contrôlé avant
        AC = STAT
      Endif
      #   69428 /
    Endif
  Endif
  # FQ74044 - MABON 20/02/12 - Si on est dans le solde collaborateurs, il faut vérifier que "Affichage du solde"
  # est à oui dans le paramétrage de la nature d'événement
  If PTYPAPP="SOL" Then
    If [F:TIM]DSPSLD=1 Then
      AC = 0
    Endif
  Endif
  # Fin MABON

  # Prolongation
  # / 71093
  # Call NOPROLONG([F:TIM]COD,NOPRL) From SUBDCG
  NOPRL = 0
  If !find([F:TIM]COD,TIMPROLONG) : NOPRL = 1 : Endif
    #   71093 /
    # Code, désignation , design , type d'accès
  # US-2832
  If [F:TIM]VLTEVT=2 & [F:TIM]CATTIM=3 & func DIVPAYE.IS_CP([F:TIM]COD,W_CPA,W_CPE)        : # valorisation CP & catégorie Congés
#  If CP = 0
    If CP = 0 and [L]EVTCP=[F:TIM]COD : # SEGAY si CPA ou CPE
      CP = 1                                       : #  -> 1 seul code renvoyé pour tout ce qui est CP
      TIM(N) = "CP"                : # En dur !          et avec le code design et accès du premier trouvé
#MIPEA - 2017-06-07- US X3-43919- START
       DES(N) = mess(4,10334,1)
#      DES(N) = mess(4,334,1)       : # Congés payés
#MIPEA - 2017-06-07- US X3-43919- END
      DSG(N) = [F:TIM]DESIGN
      ACS(N) = AC
      PGN(N) = evalue("NOPRL=0")         : # 1-avec prolongation , 0-non
      CMT(N) = evalue("[F:TIM]CMTOBG=2") : # 1- commentaire obligatoire , 0-non
      VLT(N) = [F:TIM]VLTEVT
      DSPSLD(N) = [F:TIM]DSPSLD
      CTRTIM(N) = [L]CTR
      N += 1
    Endif
  Else
    TIM(N) = [F:TIM]COD
    DES(N) = [F:TIM]DES
    DSG(N) = [F:TIM]DESIGN
    ACS(N) = AC
    PGN(N) = evalue("NOPRL=0")         : # 1-avec prolongation , 0-non
    CMT(N) = evalue("[F:TIM]CMTOBG=2") : # 1- commentaire obligatoire , 0-non
    VLT(N) = [F:TIM]VLTEVT
    DSPSLD(N) = [F:TIM]DSPSLD
    CTRTIM(N) = [L]CTR
    N += 1
  Endif
Next

#Les natures à banaliser
For [TIM]TIM0 Where (ENAFLG <> 2 | ([F:TIM]AUZPRH <> 2 & [F:TIM]AUZCAL <> 2))
&   & [F:TIM]DAYDAC=2 & [F:TIM]CTLDAC<2
  If N >= dim(TIM)
    GERR = 1
    Break
  Endif
# / 71093
# Call NOPROLONG([F:TIM]COD,NOPRL) From SUBDCG
  NOPRL = 0
  If !find([F:TIM]COD,TIMPROLONG) : NOPRL = 1 : Endif
#   71093 /
  # US-2832
  If [F:TIM]VLTEVT=2 & [F:TIM]CATTIM=3  & func DIVPAYE.IS_CP([F:TIM]COD,W_CPA,W_CPE)  : # 63639
#  If CP = 0
    If CP = 0 and [L]EVTCP=[F:TIM]COD : # SEGAY si CPA ou CPE
      CP = 1
      TIM(N) = "CP"          : # En dur
#MIPEA - 2017-06-07- US X3-43919- START
      DES(N) = mess(4,10334,1) : # Congés payés
#      DES(N) = mess(4,334,1) : # Congés payés
#MIPEA - 2017-06-07- US X3-43919- END
      DSG(N) = [F:TIM]DESIGN
      ACS(N) = 0                         :
      PGN(N) = evalue("NOPRL=0")         : # 1-avec prolongation , 0-non
      CMT(N) = evalue("[F:TIM]CMTOBG=2") : # 1- commentaire obligatoire , 0-non
      VLT(N) = [F:TIM]VLTEVT
      DSPSLD(N) = [F:TIM]DSPSLD
      CTRTIM(N) = [L]CTR
      N += 1
    Endif
  Else
    TIM(N) = [F:TIM]COD
    DES(N) = [F:TIM]DES
    DSG(N) = [F:TIM]DESIGN
    ACS(N) = 0                         :
    PGN(N) = evalue("NOPRL=0")         : # 1-avec prolongation , 0-non
    CMT(N) = evalue("[F:TIM]CMTOBG=2") : # 1- commentaire obligatoire , 0-non
    VLT(N) = [F:TIM]VLTEVT
    DSPSLD(N) = [F:TIM]DSPSLD
    CTRTIM(N) = [L]CTR
    N += 1
  Endif
Next

Return

# FQ74044 - SEGAY 13/02/12 - Ajout vérification du nouveau champ FILTRE
$FILTSUP_EVT_TIM
# 69428 : restriction de l'accès à un code évènement selon le salarié de l'absence posée
# Les controles classiques liés à l'utilisateur courant GUSER sont déjà réalisés
# Les controles sur le filtre de la nature d'évènements
# Classes disponibles
# [F:TIM] sur enregistrement du code évènement en cours
# EMP : code salarié à controler
# CTR : code contrat à controler

# Attendu en retour
# STAT : Type d'accès accordé pour cet évènement
#        1= NON SAISISSABLE
#        2= SAISISSABLE

If dim(STAT)<0 : Local Integer  STAT         : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If dim(EMP) <0 : Local Char     EMP(GLONEML) : Endif
If dim(CTR) <0 : Local Char     CTR(GLONHRCTR) : Endif
#If dim(EMP) <0 : Local Char     EMP(GLONMAT) : Endif
#If dim(CTR) <0 : Local Char     CTR(GLONCTR) : Endif
#MIPEA - 2017-06-07- US X3-43919- END
STAT = 0

If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
  Local Integer RET
  Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,EMP,CTR,RET) From DIVPAYE
  If RET>0 Then
     STAT=1
  Else
     STAT=2
  Endif
Endif
Return

$FILTSUP_EVT
# 69428 : restriction de l'accès à un code évènement selon le salarié de l'absence posée
# Les controles classiques liés à l'utilisateur courant GUSER sont déjà réalisés

# Classes disponibles
# [F:TIM] sur enregistrement du code évènement en cours
# EMP : code salarié à controler
# CTR : code contrat à controler

# Attendu en retour
# STAT : Type d'accès accordé pour cet évènement
#        1= NON SAISISSABLE
#        2= SAISISSABLE

If dim(STAT)<0 : Local Integer  STAT         : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If dim(EMP) <0 : Local Char     EMP(GLONEML) : Endif
If dim(CTR) <0 : Local Char     CTR(GLONHRCTR) : Endif
#If dim(EMP) <0 : Local Char     EMP(GLONMAT) : Endif
#If dim(CTR) <0 : Local Char     CTR(GLONCTR) : Endif
#MIPEA - 2017-06-07- US X3-43919- END

STAT = 0

GPOINT = "POR_FILT_TIM"
Gosub ENTREE From EXEFNC
Return

################################################################################
#
## Consultation d'une demande de congés sans contrôle des autorisations
#
################################################################################

Subprog CONSDEMCONGE( ACTION,REFNUM,DEM,CTRNUM,STRDAT,STRDAY,ENDDAT,ENDDAY,NBRDAY,TIM,DES
&                   , STA,CMT,UID,UPDNUM
&                   , TYPPGN,FLGANU,RPL,RPLNAM
&                   , URLBACK,CMT2
&                   )
Value    Char    ACTION(), REFNUM()
Variable Char    CTRNUM()(0..)
Variable Integer DEM, STA(0..), STRDAY(0..), ENDDAY(0..), UPDNUM(0..), UID(0..)
Variable Date    STRDAT(0..), ENDDAT(0..)
Variable Char    TIM()(0..), CMT()(0..), DES()(0..),CMT2()(0..)
Variable Decimal NBRDAY(0..)
Variable Integer TYPPGN(0..), FLGANU(0..)
Variable Char    RPL()(0..), RPLNAM()(0..)
Value    Char    URLBACK ()

# SBA ATTACH
Local Integer ADDPJ(0..dim(TIM)-1)

Call CONSDEMCONGEPJ( ACTION,REFNUM,DEM,CTRNUM,STRDAT,STRDAY,ENDDAT,ENDDAY,NBRDAY,TIM,DES
&                   , STA,CMT,UID,UPDNUM
&                   , TYPPGN,FLGANU,RPL,RPLNAM
&                   , URLBACK,CMT2,ADDPJ
&                   )


End




Subprog CONSDEMCONGEPJ( ACTION,REFNUM,DEM,CTRNUM,STRDAT,STRDAY,ENDDAT,ENDDAY,NBRDAY,TIM,DES
&                   , STA,CMT,UID,UPDNUM
&                   , TYPPGN,FLGANU,RPL,RPLNAM
&                   , URLBACK,CMT2,ADDPJ
&                   )
Value    Char    ACTION(), REFNUM()
Variable Char    CTRNUM()(0..)
Variable Integer DEM, STA(0..), STRDAY(0..), ENDDAY(0..), UPDNUM(0..), UID(0..)
Variable Date    STRDAT(0..), ENDDAT(0..)
Variable Char    TIM()(0..), CMT()(0..), DES()(0..),CMT2()(0..)
Variable Decimal NBRDAY(0..)
Variable Integer TYPPGN(0..), FLGANU(0..)
Variable Char    RPL()(0..), RPLNAM()(0..)
Value    Char    URLBACK ()
Variable Integer ADDPJ(0..)


Local Integer  N
Local Char     CRITERE (100)

GURLRET001 = mid$(URLBACK,001,80)
GURLRET002 = mid$(URLBACK,081,80)
GURLRET003 = mid$(URLBACK,161,80)

Gosub OUVRE From WODCG
Read [ID2]ID0=[L]REFNUM
If fstat
 GMESSAGE=mess(83,102,1) : # Matricule inexistant
 GERR    =1
 End
Elsif [F:ID2]ENAFLG<2 | [F:ID2]FLGTPS<2
#MIPEA - 2017-06-07- US X3-43919- START
 GMESSAGE=mess(11,10709,1) : # Pas de saisie des temps pour cet employé
# GMESSAGE=mess(11,709,1) : # Pas de saisie des temps pour cet employé
#MIPEA - 2017-06-07- US X3-43919- END
 GERR    =1
 End
Endif

# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#Link [CTR] With [DCG]DCG0(1)=REFNUM
#&             As [LNK]
#&          Where CTRDAT<=[DCG]STRDAT & (XITDAT=[0/0/0] | XITDAT>=[DCG]ENDDAT)
#&              & [DCG]DEM=[L]DEM
#MIPEA - 2017-06-07- US X3-43919- START
Link [HRCTR] With [DCG]DCG0(1)=REFNUM
&              As [LNK]
&           Where (CTRDAT<=[DCG]STRDAT | (FLGRET=2 & RETDATEFF<=[DCG]STRDAT)) & (XITDAT=[0/0/0] | XITDAT>=[DCG]ENDDAT)
&               & [DCG]DEM=[L]DEM
#Link [CTR] With [DCG]DCG0(1)=REFNUM
#&             As [LNK]
#&          Where (CTRDAT<=[DCG]STRDAT | (FLGRET=2 & RETDATEFF<=[DCG]STRDAT)) & (XITDAT=[0/0/0] | XITDAT>=[DCG]ENDDAT)
#&              & [DCG]DEM=[L]DEM
#MIPEA - 2017-06-07- US X3-43919- END
# Fin MABON
Default File [LNK]

#64942 : Avant appel func AFNC.PARAM#
#66099
GMOIPAY=gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",""))
#68318
#If GMOIPAY=[0/0/0] : GMOIPAY=eomonth(date$) : Endif
If GMOIPAY=[0/0/0] : GMOIPAY=gdat$(01,month(date$),year(date$)) : Endif

CRITERE = "DEM=[L]DEM & UID > 0"
If sum([L]UID)
 CRITERE -= "& find(UID,[L]UID)"
Endif

#73242 Filter [F:DCG] Where evalue(CRITERE) Order By Key CLE=STRDAT;STRDAY
Filter [F:DCG] Where evalue(CRITERE) Order By Key CLE=STRDAT;ENDDAY

Read [DCG] First
If fstat
 GMESSAGE=mess(23,100,1) : # Fiche inexistante
 GERR    =1
 End
Endif

N=0
For [F:DCG]CLE
 If N>=dim([L]UID)
  GERR=1
 Else
  Gosub TRANSLIG
 Endif
 N+=1
Next
Filter [F:DCG]

If GERR
 GMESSAGE="CONSDEMCONGE :"-func AFNC.MES1(mess(318,199,1),num$(N))
 #           Zone d'échange pleine  ( $1$ )
Endif

End

#71094
###########################################################
# Liste des évènements de type B                          #
###########################################################
Subprog GETBTYPEVT(MATRICULE, CONTRAT, STRPER, ENDPER, CODEVT, LIBEVT, DESIGN, STRDAT, ENDDAT)
Value Char MATRICULE(), CONTRAT()
Value Date STRPER, ENDPER
Variable Char LIBEVT()(0..), DESIGN()(0..)
Variable Date STRDAT(0..), ENDDAT(0..)
Variable Char CODEVT()(0..)
Local Char CRITMED(250)
Local Char CRITINS(250)
Local Char CRITSES(250)
Local Integer N, TYPEVT
Local Char ADILIBEVT, ADIDESIGN

  Gosub AUTORIS
  If [V]GERR : End : Endif

  If [L]MATRICULE = ""
    [V]GMESSAGE="GETBTPEVT :"-mess(4,711,1) #No de matricule non renseigné
    [V]GERR=1 : End
  Endif

  If !clalev([F:ADI]) : Local File ATABDIV  [ADI] : Endif
  If !clalev([F:MED]) : Local File EMPLOMED [MED] : Endif
# SEGAY 12/06/12 FQ82850 if FRT = Yes
  If func AFNC.ACTIV("FRT")
    If !clalev([F:INS]) : Local File INSCRIPT [INS] : Endif
    If !clalev([F:SES]) : Local File SESSIONS [SES] : Endif
    If !clalev([F:INJ]) : Local File INSJOU   [INJ] : Endif
    If !clalev([F:STG]) : Local File STAGE    [STG] : Endif
  Endif
  Raz N

  #Critères de sélection
  [L]CRITMED = "[F:MED]REFNUM='"+[L]MATRICULE+"'"
  # FQ80921 - MABON 22/03/12 - Le menu local 459 a évolué
#  [L]CRITINS = "[F:INS]REFNUM='"+[L]MATRICULE+"' & [F:INS]STA>=3"
  [L]CRITINS = "[F:INS]REFNUM='"+[L]MATRICULE+"' & [F:INS]STA>=5"
  # Fin MABON
  [L]CRITSES = "1=1"

  If [L]CONTRAT<>""
    [L]CRITMED -= "& [F:MED]CTRNUM='"+[L]CONTRAT+"'"
    [L]CRITINS -= "& [F:INS]CTRNUM='"+[L]CONTRAT+"'"
  Endif

  If [L]STRPER>[0/0/0]
    [L]CRITMED -= "& [F:MED]MEDDAT>=["+format$(GFMD,[L]STRPER)+"]"
    [L]CRITSES -= "& [F:SES]STRDAT>=["+format$(GFMD,[L]STRPER)+"]"
  Endif
  If [L]ENDPER>[0/0/0]
    [L]CRITMED -= "& [F:MED]MEDDAT<=["+format$(GFMD,[L]ENDPER)+"]"
    [L]CRITSES -= "& [F:SES]ENDDAT<=["+format$(GFMD,[L]ENDPER)+"]"
  Endif

  #Visites médicales
  [L]TYPEVT=2
  Gosub GETEVTINF

  Filter [F:MED] Where evalue([L]CRITMED)
  For [F:MED]MED1
    If (N>=dim([L]CODEVT))
      [V]GERR=1
      Break
    Endif
    [L]CODEVT(N) = num$([L]TYPEVT)
    [L]LIBEVT(N) = [L]ADILIBEVT
    [L]DESIGN(N) = [L]ADIDESIGN
    [L]STRDAT(N) = [F:MED]MEDDAT
    [L]ENDDAT(N) = [F:MED]MEDDAT
    N+=1
  Next
  Filter [F:MED]

  #Formations
# SEGAY 12/06/12 FQ82850 if FRT = Yes
If func AFNC.ACTIV("FRT")
  [L]TYPEVT=1
  If (N<dim([L]CODEVT))
    Gosub GETEVTINF

    Link [F:INS] With
&        [F:SES]SES0 = [F:INS]SES
&      , [F:STG]STG0 = [F:INS]STG
&      As [LNK]
&      Where evalue([L]CRITINS)

    Columns [LNK]([F:INS]REFNUM,[F:INS]CTRNUM,[F:INS]SES,[F:STG]TYPSTG,[F:SES]STRDAT,[F:SES]ENDDAT)

    Filter [F:LNK] Where evalue([L]CRITSES)
&                  Order By Key CLE = [F:INS]REFNUM;[F:INS]CTRNUM;[F:SES]STRDAT

    For [LNK]
      If (N>=dim([L]CODEVT))
        [V]GERR=1
        Break
      Endif
      Filter [F:INJ] Where REFNUM=[F:INS]REFNUM & SES=[F:INS]SES Order By DAT
      If rowcount([F:INJ])>0 Then
       # BUG  116469
       For [F:INJ]
       If (N>=dim([L]CODEVT)) : Break : Endif
        [L]CODEVT(N) = num$([L]TYPEVT)
        [L]LIBEVT(N) = [L]ADILIBEVT
        [L]DESIGN(N) = [L]ADIDESIGN
        [L]STRDAT(N) = [F:INJ]DAT
        If [F:STG]TYPSTG=2 Then
          [L]ENDDAT(N) = [F:INJ]DATEND
        Else
          [L]ENDDAT(N) = [F:INJ]DAT
        Endif
        N+=1
       Next
#        Read [F:INJ] First
#        If !fstat
#          [L]CODEVT(N) = num$([L]TYPEVT)
#          [L]LIBEVT(N) = [L]ADILIBEVT
#          [L]DESIGN(N) = [L]ADIDESIGN
#          [L]STRDAT(N) = [F:INJ]DAT
#          If [F:STG]TYPSTG=2 Then
#            [L]ENDDAT(N) = [F:INJ]DATEND
#          Else
#            Read [F:INJ] Last
#            If !fstat
#              [L]ENDDAT(N) = [F:INJ]DAT
#            Endif
#          Endif
#          N+=1
#        Endif
      Endif
      Filter [F:INJ]
    Next
    Columns [LNK]
  Endif
Endif  # SEGAY 12/06/12 FQ82850 if FRT = Yes

  If [V]GERR
#MIPEA - 2017-06-07- US X3-43919- START
    [V]GMESSAGE="GETBTPEVT :"-func AFNC.MES1(mess(80,10701,1),num$(N))
#    [V]GMESSAGE="GETBTPEVT :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2017-06-07- US X3-43919- END
    #           Dimension des variables inférieure à $1$
  Endif
End

$GETEVTINF
  If dim([L]ADIDESIGN)=0 | dim([L]ADILIBEVT)=0 : End : Endif
  Raz ADIDESIGN, ADILIBEVT
#MIPEA - 2017-06-07- US X3-43919- START
  Filter [F:ADI] Where NUMTAB=10707 & N1=[L]TYPEVT
#  Filter [F:ADI] Where NUMTAB=707 & N1=[L]TYPEVT
#MIPEA - 2017-06-07- US X3-43919- END
  Read [F:ADI] First
  If !fstat
    [L]ADIDESIGN = [F:ADI]A2
#MIPEA - 2017-06-07- US X3-43919- START
    [L]ADILIBEVT = func AFNC.TEXTRA("ATABDIV", "LNGDES", "10707", [F:ADI]CODE)
#    [L]ADILIBEVT = func AFNC.TEXTRA("ATABDIV", "LNGDES", "707", [F:ADI]CODE)
#MIPEA - 2017-06-07- US X3-43919- END
  Endif
  Filter [F:ADI]
Return

################################################################
## Contrôle droit d'exécution, consultation,modification      ##
#  PDROIT = 1 EXE, 2 CONSULT, 3 MODIF
# FQ88082 FQ81317 - SEGAY 03/04/12
################################################################
#**
#* Contrôle droit d'exécution, consultation, modification
#* @since 24/04/13
#* @param ACCESS : Code access
#* @param PDROIT : 1 EXE, 2 CONSULT, 3 MODIF
#* Return 1 = OK, 0 = NOK
#*!
Funprog GETCONTACCES_ECM(ACCES,PDROIT)
Value    Char    ACCES
Value    Integer PDROIT
Local    Integer PEXE
Local    Integer PCON
Local    Integer PMOD
Local    Integer RESULT
RESULT = 0
Call CONTACCES_ECM(ACCES,PEXE,PCON,PMOD)
Case [L]PDROIT
When 1
 [L]RESULT = PEXE
When 2
 [L]RESULT = PCON
When 3
 [L]RESULT = PMOD
Endcase
End [L]RESULT

################################################################
## Contrôle droit d'exécution, consultation,modification      ##
# FQ88082 FQ81317 - SEGAY 03/04/12
################################################################
#**
#* Contrôle droit d'exécution, consultation, modification
#* @since 24/04/13
#* @param ACCESS : Code access
#* @param PEXE : for EXEC 1 = OK, 0 = NOK
#* @param PCON : for CONSULT 1 = OK, 0 = NOK
#* @param PMOD : for MODIF 1 = OK, 0 = NOK
#*!
Subprog CONTACCES_ECM(ACCES,PEXE,PCON,PMOD)
Value    Char    ACCES
Variable Integer PEXE
Variable Integer PCON
Variable Integer PMOD
PEXE=1
PCON=1
PMOD=1
If ACCES="" or GUSRACS=2 : End : Endif
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC = GUSER;ACCES
If fstat
  PEXE=0
  PCON=0
  PMOD=0
Else
 If [F:ACC]EXEC<>2
  PEXE=0
 Endif
 If [F:ACC]CONSUL<>2
  PCON=0
 Endif
 If [F:ACC]MODIF<>2
  PMOD=0
 Endif
Endif
End

# PTYPE : 1 : execution , 2 consultation ou execution
Funprog IS_TIMACCES(ACCES,PTYPE)
Value    Char    ACCES
Value Integer PTYPE
Local Integer RES
Case PTYPE
  When 1 :
     RES=func GETCONTACCES_ECM(ACCES,1)
  When 2 :
     RES=(func GETCONTACCES_ECM(ACCES,1)or func GETCONTACCES_ECM(ACCES,2))
When Default :
     # nothing for the moment
Endcase
End RES

Funprog SLD(YEA,REFNUM,CTRNUM,CTRDAT,FCY,TIM,DATDEB,DATFIN)
Value Integer YEA
Value Char    REFNUM,CTRNUM,FCY,TIM
Value Date    CTRDAT,DATDEB,DATFIN
Local Decimal RSLD
Local Integer YEA(0..10)
Local Decimal ACQ(0..10), PRI(0..10), VLD(0..10), ATT(0..10), SLD(0..10)
Local Decimal SLDMIN

  Call CNG_ACCOUNT (REFNUM,CTRNUM,CTRDAT,TIM,FCY,DATFIN,YEA,ACQ,PRI,VLD,ATT,SLD,SLDMIN) From CNSCNGSTD

  For I=0 To 10
    If YEA(I)=year(DATFIN) Then
      RSLD=SLD(I) : Break
    Endif
  Next
End RSLD

Funprog DETDCG(DEMDCG,LNKDCG)
Value Integer  DEMDCG,LNKDCG
Local Char     LTEXT(250)(1..)
Local Char     SEP(10) : SEP=""
Local Char     W_TEMP(150)
Local Integer  IT

#  Filter [F:DCG] Where DEM=[L]DEMDCG & LNK=[L]LNKDCG
  Raz LTEXT : IT=1
#  For [F:DCG]
    If [F:DCG]UID>0 Then
      W_TEMP  = format$([V]GFMD,[F:DCG]STRDAT)-format$([V]GFMD,[F:DCG]ENDDAT)-format$("K:5X",[F:DCG]TIM) #FRLAA X3-50343 2017-10-02
      #W_TEMP  = format$([V]GFMD,[F:DCG]STRDAT)-format$([V]GFMD,[F:DCG]ENDDAT)-format$("K:5X",[F:DCG]TIM)-format$("K:30X",[F:TIM]DES)
      W_TEMP += format$("N:5.2#",[F:DCG]NBRDAY)-[F:DCG]CMT : # -func PORDCG.SLD(year([F:DCG]ENDDAT),[F:DCG]REFNUM,[F:DCG]CTRNUM,[F:DCG]TIM,[F:DCG]STRDAT,[F:DCG]ENDDAT)
      If len(LTEXT(IT))+len(W_TEMP)>250 and IT<10 Then
        IT+=1
      Endif
      LTEXT(IT) += SEP+W_TEMP
      SEP=chr$(10)+chr$(13)
    Endif
#  Next
#  Filter [F:DCG]
End LTEXT(1)-LTEXT(2)-LTEXT(3)-LTEXT(4)-LTEXT(5)-LTEXT(6)-LTEXT(7)-LTEXT(8)-LTEXT(9)-LTEXT(10)

Funprog DETDCGSUIV(DEMDCG,LNKDCG)
Value Integer  DEMDCG,LNKDCG
Local Char     LTEXT(250)(1..)
Local Char     SEP(10) : SEP=""
Local Char     W_TEMP(150)
Local Integer  IT

  If clalev([F:DCG])=0 : Local File DEMCONGE [DCG] : Endif
  Filter [F:DCG] Where DEM=[L]DEMDCG & LNK=[L]LNKDCG
  Raz LTEXT : IT=1
  For [F:DCG]
    If [F:DCG]UID>0 Then
      W_TEMP  = func PORDCG.DETDCGLIB([F:DCG]STA,1,2,[F:DCG]DEM,[F:DCG]REFNUM,[F:ID]SRN,[F:ID]NAM)
      W_TEMP -= mess(12,10726,1)-format$("D:"+GFMDAT4,[F:DCG]STRDAT)-mess(13,10726,1)-format$("D:"+GFMDAT4,[F:DCG]ENDDAT)
     # W_TEMP -= mess(12,10726,1)-format$("D:"+GFMDAT4,[F:DCG]STRDAT)-mess(13,10726,1)-format$("D:"+GFMDAT4,[F:DCG]ENDDAT)-":"-[F:TIM]DES
      If len(LTEXT(IT))+len(W_TEMP)>250 and IT<10 Then
        IT+=1
      Endif
      LTEXT(IT) += SEP+W_TEMP
      SEP=chr$(10)+chr$(13)
    Endif
  Next
  Filter [F:DCG]
End LTEXT(1)-LTEXT(2)-LTEXT(3)-LTEXT(4)-LTEXT(5)-LTEXT(6)-LTEXT(7)-LTEXT(8)-LTEXT(9)-LTEXT(10)

Funprog DETDCGLIB(STA,NUM1,NUM2,DEM,REFNUM,SRN,NAM)
Value Integer STA,NUM1,NUM2,DEM
Value Char    REFNUM(),SRN(),NAM()
Local Char    LRET(250)

  LRET=func AFNC.MES1(string$([L]STA<5,mess([L]NUM1,10726,1))+string$([L]STA>=5,mess([L]NUM2,10726,1)),num$([L]DEM))-[L]REFNUM-[L]NAM-[L]SRN
End LRET

################################################################
## Ajout solde dans les workflow                              ##
#
# US 2043-93013 : SBA 08/11/2013
##############################################################

Funprog DSPMESSSOLDE2(EVT,REFNUM,CTRNUM,DEBDAT,ENDDAT)
Value Char EVT(),REFNUM(),CTRNUM()
Value Date DEBDAT,ENDDAT
Local Clbfile RES
Local Integer TROUVE

Local Date WCTRDAT,WDATSEL
Local Char WFCY(10)
Local Integer WYEA(0..10),WYEA1(0..10)
Local Decimal WACQ(0..10), WPRI(0..10), WVLD(0..10), WATT(0..10), WSLD(0..10)
Local Decimal WACQ1(0..10), WPRI1(0..10), WVLD1(0..10), WATT1(0..10), WSLD1(0..10)
Local Decimal WSLDMIN
Local Char WT_PERCOD(GLONHRPEO)

Local Char WLSTCTR(30)(0..,0..2)
Local Integer NBCTR

Local Char W_TXTBASE(60)
# on teste le type de congés. il doit être consultation solde + afficher en surimpression.

If(EVT<>"")
  If !clalev([F:TIM_]) : Local File TIMCOD   [TIM_] : Endif
    #MIPEA - 2017-06-07- US X3-43919- START
    #FRLAA  2017-10-18 X3-50343 - START
    Local Char CTRLEG(GLONADI)
    CTRLEG = func PORDCG.GET_LEG_CTR(REFNUM, CTRNUM,1)
    Read [TIM_]TIM0=CTRLEG;EVT

    #Read [TIM_]TIM0=GCURLEG;EVT
    #FRLAA  2017-10-18 X3-50343 - END
    #Read [TIM_]TIM0=EVT
    #MIPEA - 2017-06-07- US X3-43919- END
  If(!fstat)
    [L]TROUVE= ([F:TIM_]DSPSLD=2 and [F:TIM_]OVERWR=2)
  Endif

  If [L]TROUVE
    [L]W_TXTBASE=mess(1,106,1)#-[F:TIM_]DES
    If clalev([F:CTR_])=0 : Local File EMPLOCTR [CTR_] : Endif
    If CTRNUM=""
      Filter [CTR_] Where REFNUM=[L]REFNUM & CTRDAT<=ENDDAT & (XITDAT=[0/0/0] or XITDAT>=ENDDAT)
    Else
      Filter [CTR_] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM & CTRDAT<=ENDDAT & (XITDAT=[0/0/0] or XITDAT>=ENDDAT)
    Endif
    Local Char F_PERCOD(GLONHRPEO)

      For [CTR_]
          WLSTCTR(NBCTR,0)=[F:CTR_]CTRNUM
          WLSTCTR(NBCTR,1)=[F:CTR_]ETRFCY
          WLSTCTR(NBCTR,2)=[F:CTR_]PERCOD
          NBCTR+=1
      Next
    Filter [CTR_]
    [L]TROUVE=NBCTR

    If [L]TROUVE
      Local Integer WI
      Local Integer WJ,WJJ
      Local Char W_MESS(250)(0..50)
      Local Char WT_SITE(30),WT_CONTRAT(60)

      While(WI<NBCTR)
        Raz WYEA,WACQ,WPRI,WVLD,WATT,WSLD,WSLDMIN
        Raz WYEA1,WACQ1,WPRI1,WVLD1,WATT1,WSLD1,WSLDMIN
        WDATSEL=ENDDAT
        # bug si pas de fiche periode vide ou site non trouvé
        # On passe un paramètre au lieu du tableau
        # On raz le message d'erreur s'il y a
        WT_CONTRAT=WLSTCTR(WI,0)
        WT_SITE=WLSTCTR(WI,1)
        WT_PERCOD=WLSTCTR(WI,2)

        Call  CNG_ACCOUNT (REFNUM, WT_CONTRAT,WCTRDAT,EVT,WT_SITE,WDATSEL,WT_PERCOD,WYEA,WACQ,WPRI,WVLD,WATT,WSLD,WSLDMIN) From CNSCNGSTD
        WDATSEL=DEBDAT
        Gosub ERR_DISPMESS
        Call  CNG_ACCOUNT (REFNUM, WT_CONTRAT,WCTRDAT,EVT,WT_SITE,WDATSEL,WT_PERCOD,WYEA1,WACQ1,WPRI1,WVLD1,WATT1,WSLD1,WSLDMIN) From CNSCNGSTD
        Gosub ERR_DISPMESS
        WJ=0
         Raz [L]W_MESS
         While(WYEA(WJ)<>0)
            [L]W_MESS(WJ)=func GETMESSSOLDE(num$(WYEA(WJ)),num$(WSLD(WJ)),num$(WATT(WJ)))
            WJ+=1
         Wend
          WJJ=0
         While(WYEA1(WJJ)<>0)
            If(find(WYEA1(WJJ),WYEA(0..WJ))=0)
              [L]W_MESS(WJ)=func GETMESSSOLDE(num$(WYEA1(WJJ)),num$(WSLD1(WJJ)),num$(WATT1(WJJ)))
              WJ+=1
            Endif
            WJJ+=1
         Wend
         If([L]W_MESS(0)<>"")
            RES+= chr$(10)+chr$(13)+[L]W_TXTBASE-mess(257,726,1)-WLSTCTR(WI,0)-":"
            Local Integer WK
            For WK=0 To WJ-1
              RES+= chr$(10)+chr$(13)+[L]W_MESS(WK)
            Next
         Endif
        WI+=1
      Wend
    Endif
  Endif
Endif

End RES

##############################################################

Funprog GETMESSSOLDE(ANNEE,SOLDE,ATTENTE)
Value Char ANNEE,SOLDE,ATTENTE

Local Char W_RES(255)
#MIPEA - 2017-06-07- US X3-43919- START
W_RES=func AFNC.MES2(mess(260,10726,1 ),ANNEE,SOLDE)
If ATTENTE<>"0"
  W_RES-="("+func AFNC.MES1(mess(261,10726,1),ATTENTE)+")                    "
Endif
#W_RES=func AFNC.MES2(mess(260,726,1 ),ANNEE,SOLDE)
#If ATTENTE<>"0"
#  W_RES-="("+func AFNC.MES1(mess(261,726,1),ATTENTE)+")                    "
#Endif
#MIPEA - 2017-06-07- US X3-43919- END
End W_RES

