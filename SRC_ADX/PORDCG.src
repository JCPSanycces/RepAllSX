#FRLAA  2017-10-18 X3-50343 - START
#**
#* Functions to get the legislation based on the contract details
#* @param VREFNUM Char(GLONEML), Employee code
#* @param VCTRNUM Char(GLONHRCTR), Contract number
#* @param VLEGLVL Integer, Indicate if the site or company legislation is needed 1-Site, 2 - Company
#* @return VLEG, Legislation
#*!
Funprog GET_LEG_CTR(VREFNUM,VCTRNUM,VLEGLVL)
Value Char VREFNUM,VCTRNUM
Value Integer VLEGLVL
Local Char VLEG(GLONADI)

Local File EMPLOCTR [HRCTR9]
Filter [HRCTR9] Where REFNUM = VREFNUM and CTRNUM = VCTRNUM
Read [HRCTR9] First
If fstat = [V]CST_AOK
  End func DIVPAYE_SOA.GET_LEG_FCY([F:HRCTR9]ETRFCY,VLEGLVL)
Endif
End VLEG
#FRLAA  2017-10-18 X3-50343 - START

#FRLAA  2017-10-24 X3-50343 - START
#**
#* Function to get the nature of event description for the leave tracking on workflow
#* @param NATCOD Char(GLONTPS), Nature of event code
#* @param VREFNUM Char(GLONEML), Employee code
#* @param VCTRNUM Char(GLONHRCTR), Contract number
#* @return NATDESC, Nature of event description
#*!
Funprog GET_NATDESC(NATCOD,VREFNUM,VCTRNUM)
Value Char NATCOD,VREFNUM,VCTRNUM
Local Char NATDESC(GLONAX3)
Local Char CTRLEG(GLONADI)

#Get the legislation for the contract first
CTRLEG = func PORDCG.GET_LEG_CTR(VREFNUM, VCTRNUM, 1)

#Get the description
Call LECTEXTRA(NATDESC,"TIMCOD","DES",CTRLEG,NATCOD) From ATEXTRA

End NATDESC
#FRLAA  2017-10-24 X3-50343 - END

