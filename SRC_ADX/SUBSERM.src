#<AdxTL>@(#)2.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
###########################################################
# Sous programme d'eclatement de numéros de séries
# LFCY  = Site de stock
# LCHR  = chrono stock 
# LQTE  = tableau des quantités splittées en US
# LNBR  = Nombre de quantités dans les tableaux
# LRET  = code retour
#
Subprog SPLSTO(LFCY,LCHR,LQTE,LNBR,LRET)
Variable Char    LFCY
Variable Decimal LCHR
Variable Decimal LQTE()
Variable Integer LNBR
Variable Integer LRET
#
Local Integer CHOIX
Local Integer SAVOBJET
Local Char    SAVPROG
Local Integer WPRE
Local Integer WNOLIGN
Local Integer WFSTAT 
Local Integer WBOU(1..GNBBOU)  
Local Integer I, IMAJ
#  
#
WNOLIGN = nolign
Call SAVBOUT From GESECRAN
SAVOBJET = GOBJET
SAVPROG  = GPROGRAMME  
GOBJET   = 0 
# 
For I = 1 To GNBBOU  
  WBOU(I) = 0  
Next I  
WBOU(GVALI) = 1
WBOU(GABAN) = 1
Call SETBOUT(WBOU) From GESECRAN   
LRET = 0
# 
If clalev([F:ANM])  = 0 : Local File ACODNUM    [ANM]  : Endif
If clalev([F:AVN])  = 0 : Local File AVALNUM    [AVN]  : Endif
If clalev([F:TUN])  = 0 : Local File TABUNIT    [TUN]  : Endif
If clalev([F:TCU])  = 0 : Local File TABCUR     [TCU]  : Endif
If clalev([F:TLO])  = 0 : Local File TABLOCTYP  [TLO]  : Endif 
If clalev([F:ITM1]) = 0 : Local File ITMMASTER  [ITM1] : Endif
If clalev([F:STO1]) = 0 : Local File STOCK      [STO1] : Endif

Local Mask SERM[SERM]
Local Dlgbox Mask [SERM]
&    Button mess(64,123,1),        mess(65,123,1)
&    With left$(mess(64,123,1),1), left$(mess(65,123,1),1) 
&    Coded GSTAOK,                 GSTAFIN
&    Titled mess(109,196,1)-num$(WNOLIGN)
&    As [SERM]
Boxact [SERM]
#
Raz [M:SERM]
Read [STO1]STO0=LFCY;LCHR
  If fstat LRET = 1
    Goto SPLSTO2
  Endif
Read [ITM1]ITM0=[F:STO1]ITMREF
  If fstat
    LRET = 2
    Goto SPLSTO2
  Endif
[M:SERM] = [F:STO1]
#[M:SERM]ITMDES1 = [F:ITM1]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:SERM]ITMDES1, "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:SERM]STU     = [F:ITM1]STU
Affzo [M:SERM]
$SPLSTO1
Boxinp [SERM] Using CHOIX
  Case CHOIX
    When GSTAOK, GSTARET :
      Gosub TRT_MAJ
      LRET = IMAJ  
      Goto SPLSTO2
    When GSTAFIN, GSTAESC :
      Raz LNBR, LQTE
      Goto SPLSTO2
  Endcase
Goto SPLSTO1
#
$SPLSTO2
Close Local File [ITM1]
Close Local File [STO1]
#
nolign     = WNOLIGN
GOBJET     = SAVOBJET
GPROGRAMME = SAVPROG
Call RESTBOUT From GESECRAN
End
############################################################
$TRT_MAJ
Return
############################################################
$SET_NOL
Local Integer NOL : NOL = nolign -1
Return
