#<AdxTL>@(#)9.0.0.0 $Revision$
datesyst = [21/09/2003]
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","VALSTA","VALSTA",3,"XYVALSTA") From GTRAITE
End

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return

#######################################################
$CONTROLE
TMP = 1
Return

#######################################################
$INIT 
Local Integer CAS
Local Char    TIT(50)
Local Date    DATD , DATF
Local Mask VALSTA [DIA]
Gosub OUVRE
Raz [M:DIA]
TIT = mess(11,124,1) : # Validation statistiques
Return

#######################################################
$OUVRE
If clalev([PS2])=0  : Local File PARSTA2   [PS2]  : Endif
If clalev([PS1])=0  : Local File PARSTA1   [PS1]  : Endif
If clalev([PSL])=0  : Local File PARSTALIG [PSL]  : Endif
If clalev([PS22])=0 : Local File PARSTA2   [PS22] : Endif
If clalev([CPY])=0  : Local File COMPANY   [CPY]  : Endif
If clalev([FCY])=0  : Local File FACILITY  [FCY]  : Endif
Return

#######################################################
$EXEC
If [M:DIA]TYPMAJ=1
 CAS = 0 : # Incrémentation
Else
 CAS = 1 : # Resynchronisation
Endif
If [M:DIA]CODSTA<>""
 Read [PS22]PS20 = [M:DIA]CODSTA
 If [F:PS22]ENAFLG=2
  Gosub RECUP
 Endif
Else
 If CAS = 0 : # Incrémentation
  For [PS22]PS20 Where TYP=2 & ENAFLG=2 : # Batch
   Gosub RECUP
  Next
 Else
  For [PS22]PS20 Where ENAFLG=2
   Gosub RECUP
  Next
 Endif
Endif
Return

#######################################################
$FIN
Return

#######################################################
$RECUP
If !GSERVEUR
 Call TEMPON(mess(6,124,1)-[F:PS22]COD) From GESECRAN
# Mise à jours statistique
Endif
DATD = [M:DIA]DATDEB
DATF = [M:DIA]DATFIN
If [M:DIA]DERNIER=2
 Call INIDATES(DATD,DATF,[F:PS22]LSTDAT,[M:DIA]TYPMAJ,[F:PS22]PERTYP)
Endif

Call VALBATCH([F:PS22]COD,[M:DIA]SOCIETE,[M:DIA]SITE,DATD,DATF,CAS) From SUBPS2
If !GSERVEUR
 Call TEMPOFF From GESECRAN
Endif
Return

#######################################################
Subprog INIDATES(DATD,DATF,LSTDAT,TYPMAJ,PERTYP)
Variable Date    DATD, DATF
Value    Date    LSTDAT
Value    Integer TYPMAJ, PERTYP
If LSTDAT<>[0/0/0]
 DATD = LSTDAT+1
Else
 DATD = GDATDEB
Endif
Call SETDATDEB(DATD,TYPMAJ,PERTYP)
DATF = max(datesyst,DATD)
Call SETDATFIN(DATF,TYPMAJ,PERTYP)
End

Subprog SETDATDEB(VALEUR,TYPMAJ,PERTYP)
Variable Date VALEUR
Value    Integer TYPMAJ, PERTYP
If TYPMAJ=2 : # Resynchronisation
 Case PERTYP
  When 1 : # Jour
   VALEUR = VALEUR
  When 2 : # Semaine
   VALEUR = aweek(week(VALEUR),year(VALEUR))
  When 3 : # Quinzaine
   If day(VALEUR)>15
    VALEUR = gdat$(16,month(VALEUR),year(VALEUR))
   Else
    VALEUR = gdat$(1,month(VALEUR),year(VALEUR))
   Endif
  When 4 : # Mois
   VALEUR = gdat$(1,month(VALEUR),year(VALEUR))
  When 5 : # Trimestre
   VALEUR = gdat$(1,3*int((month(VALEUR)-1)/3)+1,year(VALEUR))
  When 6 : # Année
   VALEUR = gdat$(1,1,year(VALEUR))
 Endcase
Endif
End

Subprog SETDATFIN(VALEUR,TYPMAJ,PERTYP)
Variable Date    VALEUR
Value    Integer TYPMAJ, PERTYP
If TYPMAJ=2 : # Resynchronisation
 Case PERTYP
  When 1 : # Jour
  When 2 : # Semaine
   VALEUR = aweek(week(VALEUR),year(VALEUR))+6
  When 3 : # Quinzaine
   If day(VALEUR)>15
    VALEUR = eomonth(gdat$(1,month(VALEUR),year(VALEUR)))
   Else
    VALEUR = gdat$(15,month(VALEUR),year(VALEUR))
   Endif
  When 4 : # Mois
   VALEUR = eomonth(gdat$(1,month(VALEUR),year(VALEUR)))
  When 5 : # Trimestre
   VALEUR = eomonth(gdat$(1,3*int((month(VALEUR)-1)/3)+3,year(VALEUR)))
  When 6 : # Année
   VALEUR = eomonth(gdat$(1,12,year(VALEUR)))
 Endcase
Else : # Incrémentale => fin de période précédent la date du jour (BY 05/09/2003)
 VALEUR +=1
 Call SETDATDEB(VALEUR,2,PERTYP)
 VALEUR -= 1
Endif
End

########################################
Subprog C_CODSTA(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("PS2",VALEUR,"") From CONTOBJ
 If [F:PS2]UPDLEV<2 : # Dossier
  If GNBAUZ<>GNBSITE
   GMESSAGE = mess(4,104,1) : # Vous n'avez pas les droits pour ce code
   mkstat = 2 : End
  Endif
 Endif
Endif
Call LECTURE("PS1",[F:PS2]RLG,"") From CONTOBJ
End

Subprog AM_CODSTA(VALEUR)
Call INIDATES([M]DATDEB,[M]DATFIN,[F:PS2]LSTDAT,[M]TYPMAJ,[F:PS2]PERTYP)
Affzo DATDEB, DATFIN
End

Subprog C_TYPMAJ(VALEUR)
Variable Integer VALEUR
If VALEUR=1 | [M]CODSTA=""
 Effzo SOCIETE, SITE
 Grizo SOCIETE, SITE
Else
 If [F:PS2]UPDLEV=1
  Effzo SOCIETE, SITE
  Grizo SOCIETE, SITE
 Elsif [F:PS2]UPDLEV=2
  Actzo SOCIETE
  Effzo SITE
  Grizo SITE
 Else
  Actzo SOCIETE, SITE
 Endif
Endif
If VALEUR=1
 Actzo DERNIER
Else
 Effzo DERNIER
 Diszo DERNIER
 Actzo DATDEB,DATFIN
Endif
End

Subprog AM_TYPMAJ(VALEUR)
[M]TYPMAJ = VALEUR
Call INIDATES([M]DATDEB,[M]DATFIN,[F:PS2]LSTDAT,[M]TYPMAJ,[F:PS2]PERTYP)
Affzo DATDEB, DATFIN
End

Subprog AS_SOCIETE(VALEUR)
Variable Char     VALEUR
If [M]CODSTA<>""
 If !([M]TYPMAJ<>1) | !find([F:PS2]UPDLEV,2,3)
  mkstat = 2 : End
 Endif
Else
 mkstat = 1 : End
Endif
End

Subprog AS_SITE(VALEUR)
Variable Char     VALEUR
If [M]CODSTA<>""
 If !([M]TYPMAJ<>1) | !find([F:PS2]UPDLEV,3)
  mkstat = 2 : End
 Endif
Else
 mkstat = 1 : End
Endif
End

Subprog C_SITE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 [M]SOCIETE = [F:FCY]LEGCPY : Affzo SOCIETE, ZSOCIETE
Else
 Call CONTALLFCY([M]SOCIETE) From EXEFNC
Endif
End

Subprog AM_DATDEB(VALEUR)
Variable Date     VALEUR
Local Integer OK
Local Date    DAT
If [F:PS2]LSTDAT<>[0/0/0]
 [L]DAT = [F:PS2]LSTDAT+1
 Call SETDATDEB([L]DAT,[M]TYPMAJ,[F:PS2]PERTYP)
 If VALEUR<>[L]DAT
  Call AVERTIR(mess(204,124,1),OK) From GESECRAN : # Voulez-vous réellement modifier cette date ?
  If OK<>2 : VALEUR = [L]DAT : End : Endif
 Endif
Endif
End

Subprog C_DATDEB(VALEUR)
Variable Date     VALEUR
Call SETDATDEB(VALEUR,[M]TYPMAJ,[F:PS2]PERTYP)
End

Subprog C_DATFIN(VALEUR)
Variable Date     VALEUR
Call SETDATFIN(VALEUR,[M]TYPMAJ,[F:PS2]PERTYP)
End

Subprog C_DERNIER(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo DATDEB, DATFIN
 Grizo DATDEB, DATFIN
Else
 Actzo DATDEB, DATFIN
Endif
End

