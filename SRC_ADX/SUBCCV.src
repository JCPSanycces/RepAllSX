    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CCV2]BNUMDES(nolign-1), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
  Endif
  [M:CCV2]BCCVCUR1(nolign-1) = [M:CCV0]CUR
  [M:CCV2]BCCVCUR2(nolign-1) = [M:CCV0]CUR
  [M:CCV2]BNUM(nolign-1) = VALEUR
  Affzo [M:CCV2]BNUM(nolign-1), BNUMDES(nolign-1), BCCVCUR1(nolign-1), BCCVCUR2(nolign-1)
End

