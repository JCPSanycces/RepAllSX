######################################################
Subprog AM_ANUM(VALEUR)
Variable Char    VALEUR()

  Read [ITM]ITM0=VALEUR
  If !fstat Then
    #Call LECTEXTRA([M:CCV1]ANUMDES(nolign-1), "ITMMASTER", "DES1AXX", VALEUR, "") From ATEXTRA
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CCV1]ANUMDES(nolign-1), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
  Endif
  [M:CCV1]ACCVCUR1(nolign-1) = [M:CCV0]CUR
  [M:CCV1]ACCVCUR2(nolign-1) = [M:CCV0]CUR
  [M:CCV1]ANUM(nolign-1) = VALEUR
  Affzo [M:CCV1]ANUM(nolign-1), ANUMDES(nolign-1), ACCVCUR1(nolign-1), ACCVCUR2(nolign-1)
End

