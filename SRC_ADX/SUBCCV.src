##########################################################################
Subprog AS_ACCVICDFLG(VALEUR)
Variable Integer VALEUR

  Case [M:CCV1]ITMICDFLG
    When 0
      [M:CCV1]ACCVICDFLG(nolign-1) = 2
    When 1
      [M:CCV1]ACCVICDFLG(nolign-1) = 2
    When 2
      [M:CCV1]ACCVICDFLG(nolign-1) = 1
  Endcase
  Affzo [M:CCV1]ACCVICDFLG(nolign-1)
End

##########################################################################
Subprog AS_BCCVICDFLG(VALEUR)
