End

#########################################################################
Subprog C_ANUM(VALEUR)
Variable Char    VALEUR()

  Read [ITM]ITM0=VALEUR
  If fstat Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1) #Valeur incorrect.
    GERR = 1
    mkstat = 2
  Else
    If [F:ITM]HDKITMTYP <> 2 Then
      #Cet article n'est pas considéré comme une pièce d'un point du vue après-vente. Saisie refusée.
      GMESSAGE = mess(276,182,1)
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

##########################################################################
Subprog C_BNUM(VALEUR)
Variable Char    VALEUR()

  Read [ITM]ITM0=VALEUR
  If fstat Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1) #Valeur incorrect.
    GERR = 1
    mkstat = 2
  Else
    If [F:ITM]HDKITMTYP <> 3 Then
      #Cet article n'est pas considéré comme de la main d'oeuvre d'un point du vue après-vente. Saisie refusée.
      GMESSAGE = mess(277,182,1)
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

##########################################################################
Subprog C_CNUM(VALEUR)
Variable Char    VALEUR()

  Read [ITM]ITM0=VALEUR
  If fstat Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1) #Valeur incorrect.
    GERR = 1
    mkstat = 2
  Else
    If [F:ITM]HDKITMTYP <> 4 Then
      #Cet article n'est pas considéré comme un frais de mission d'un point du vue après-vente. Saisie refusée.
      GMESSAGE = mess(278,182,1)
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

##########################################################################
Subprog C_AHEIPRC(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 100 Then
    #Ce pourcentage ne peut pas être supérieur à 100. Saisie refusée.
    GMESSAGE = mess(279,182,1)
    GERR = 1
    mkstat = 2
  Endif
End

