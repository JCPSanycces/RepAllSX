#<AdxTL>@(#)0.0.0.0 $Revision$
#---------------------------------------------------------------------------------------------------#
# VALOBJ Programme principal
#---------------------------------------------------------------------------------------------------#

GTEST = 0
#GBIDC1 = "AOB"
GBIDC1 = "ACV"
GTRACE = ""
Call VALID(GBIDC1,nomap,0,GBIDI1)
End

#---------------------------------------------------------------------------------------------------#
# VALOBJ        Prog principal
# VALOBJLEC     Lecture en mémoire
# VALOBJTRT     Ecriture du traitement WOxxx
# VALOBJSUB     Sous-programmes de VALOBJTRT
# VALOBJSTD     Ecriture étiquette $ACTION dans les traitements SUBxxx et GESxxx
#---------------------------------------------------------------------------------------------------#

Subprog VALID(OBJET,APPLI,SILENCE,MOK)
Value    Char    OBJET
Value    Char    APPLI
Value    Integer SILENCE
Variable Integer MOK


# Pour forcer l'allocation de 500 Ko de mémoire (perfs)
Local Schar TOTO(10)(1024,50)
Kill TOTO


Onerrgo ERREUR
MOK = 1

Local Integer TEST : TEST = 0

If TEST
 Call OUVRE_TRACE(mess(13,124,1)-OBJET) From LECFIC : # Validation objet
Endif

If !SILENCE
 Call TEMPON(mess(13,124,1)-OBJET) From GESECRAN : # Validation objet
Endif
If GTRACE<>""
 Call ECR_TRACE(mess(13,124,1)-OBJET,0) From GESECRAN : # Validation objet
Endif

Gosub OUVFIC  From VALOBJLEC
Gosub DEFVAR  From VALOBJLEC

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8



# Mise en mémoire des tables
Gosub LECTURE From VALOBJLEC
If !OK : Goto PERDU : Endif

# Génération et validation du traitement WOxxx
Gosub VALTRT From VALOBJTRT

# Rajout du $ACTION dans les traitements SUBxxx SPExxx SPVxxx
Gosub VALTRT From VALOBJSTD

# Création de l'XML
Gosub VALWEB From VALOBJWEB

# ajout dans la table aentrée
Gosub AENTREE From VALOBJAPE

#----------------------------------------------#
$FIN
If !SILENCE
 Call TEMPOFF From GESECRAN
Endif
If TEST
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Onerrgo
End

#--------------#
$PERDU
If GMESSAGE<>""
  # Issue X3-75929 - 2018-07-26 by ALSHE : set message type depending on status
  If GERR = 3 # Warning message
    Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else # Error message
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Endif
  Raz GMESSAGE
  Raz GERR
Endif
Raz MOK
Call DEL_TRTAOB(OBJET,APPLI) From SUBAOB
Goto FIN

#--------------#
$ERREUR
Call ECR_TRACE(errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-"("+num$(errn)+")|"-errm,1) From GESECRAN
MOK = 0
End

