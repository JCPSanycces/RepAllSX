#<AdxTL>@(#)8.0.0.0 $Revision$
######################################################################
# SUBTUV : Périodes d'indisponibilité                                #
######################################################################

Call OBJET ("TUV",GBIDC1,GBIDC2) From GOBJET
End

######################################################################

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE  ## SAM 82280
 When "FERME"       : Gosub FERME  ## SAM 82280
 When "FILTRE"      : Gosub FILTRE ## SAM 82280
 When "FILGAUCHE"   : Gosub FILGAUCHE ## SAM 82280
 When "AFFMASK"     : Gosub AFFMASK ## SAM 82280
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INICRE
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Call CHANGE_AXX ("TABUNAVAIL", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return

######################################################################
######################################################################
$AFFMASK
#--- We force the field display ## SAM 82280
Affzo [M:TUV1]UVYPER
Return

$OUVRE
#--- Definition of the global variable GTUV_FMTPER ## SAM 82280
Global Char GTUV_FMTPER(20)
If GFONCTION1="GESTUVM"
   GTUV_FMTPER="-LA:1"
Else
   GTUV_FMTPER="LA:1"
Endif
Return

$FERME
#--- Suppression of the global variable GTUV_FMTPER ## SAM 82280
Kill GTUV_FMTPER
Return

$FILTRE
#--- Filter UVYPER<>2 if we are not in GESTUV o is not a selection in the BPC3 screen  ## SAM 82280
FILTSUP="1=1"
If GFONCTION1="GESTUVM" or (GFONCTION<>"GESBPC" and GFONCTION<>"GESTUV")
   FILTSUP="[F:TUV]UVYPER<>2"
   Return
Endif
If GFONCTION="GESBPC" and zoncou<>"UVYCOD2"
   FILTSUP="[F:TUV]UVYPER<>2"
Endif

Return

$FILGAUCHE
#--- Filter in the left list if we are in GESTUVM  ## SAM 82280
If GFONCTION1="GESTUVM"
   FILTSUP="[F:TUV]UVYPER<>2"
Else
   FILTSUP="1=1"
Endif
Return

$INICRE
Local Integer IJL, IJLD

#--- Creation / Modif de ATEXTRA (Entete)
Call MAJTEXTRA ([M:TUV1]DESAXX,"TABUNAVAIL","DESAXX",[M:TUV1]UVYCOD,"") From ATEXTRA
Call MAJTEXTRA ([M:TUV1]SHOAXX,"TABUNAVAIL","SHOAXX",[M:TUV1]UVYCOD,"") From ATEXTRA

#    SOS libellés
If dim([F:TUV]LANDESSHO)>0
   [F:TUV]LANDESSHO=GLANGUE+"~"+[M:TUV1]DESAXX+"~"+[M:TUV1]SHOAXX
Endif

#--- Creation / Modif de ATEXTRA (Lignes)
For IJL=0 To dim([F:TUV]UVYSTRDAT)-1
    If [F:TUV]UVYSTRDAT(IJL)<>[0/0/0]
       Call MAJTEXTRA ([M:TUV1]UVYAXX(IJL),"TABUNAVAIL","UVYAXX",[F:TUV]UVYCOD,num$(val([F:TUV]UVYSTRDAT(IJL))))
&           From ATEXTRA
    Endif
Next IJL
#--- Suppression de ATEXTRA (Lignes) inutiles
For [AXX] Where CODFIC="TABUNAVAIL" & ZONE="UVYAXX" & IDENT1=[F:TUV]UVYCOD
    IJLD=1                                                     : # Initialistion du flag pour la suppression
    For IJL=0 To dim([F:TUV]UVYSTRDAT)-1                       : # Boucle sur les lignes périodes
        If [F:TUV]UVYSTRDAT(IJL)<>[0/0/0]
           If num$(val([F:TUV]UVYSTRDAT(IJL)))=[F:AXX]IDENT2   : # Si l'enregistrement ATEXTRA correspond a cette date
              Raz IJLD : Break                                 : # --> positionnement flag : ne pas supprimer
           Endif
        Endif
    Next IJL
    If IJLD
       Delete [AXX] Curr
    Endif
Next

Return

#---------------------------------------------------------------------
$ANNULE
Delete [AXX]Where CODFIC="TABUNAVAIL" & IDENT1=[F:TUV]UVYCOD
Return


######################################################################
Subprog C_UVYSTRDAT(VALEUR)
Variable Date VALEUR
If   nolign > 1 & [M]UVYENDDAT(nolign-2) >= VALEUR
     Gosub ERRDAT
Endif
If   nolign < dim([M]UVYSTRDAT)
&  & [M]UVYSTRDAT(nolign) <> [0/0/0]
&  & [M]UVYSTRDAT(nolign) <= VALEUR
     Gosub ERRDAT
Endif
End

#############################################
Subprog C_UVYENDDAT(VALEUR)
Variable Date VALEUR
If   nolign < dim([M]UVYSTRDAT)
&  & [M]UVYSTRDAT(nolign) <> [0/0/0]
&  & [M]UVYSTRDAT(nolign) <= VALEUR
   Gosub ERRDAT
Endif
End
#############################################
$ERRDAT
GMESSAGE = mess(1,199,1)
mkstat   = 1
Return

######################################################################

