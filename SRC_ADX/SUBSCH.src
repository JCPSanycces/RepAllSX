#<AdxTL>@(#)8.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("SCH",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
## Masse salariale: Transaction hyp. modification (Objet SCH)18/03/2009 00:00:00 (WGA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "RAZCRE"    : Gosub RAZCRE
 When "SETBOUT"   : Gosub SETBOUT
 When "EXEBOUT"   : Gosub EXEBOUT
 When "LIENS"     : Gosub LIENS
 When "INIMOD"    : Gosub INIMOD
 When "INICRE"    : Gosub INICRE
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "ANNULE"    : Gosub ANNULE
 When "FERME"     : Gosub FERME
Endcase
Return

$OUVRE
If clalev([F:AMZ])=0 : Local File AMSKZON  [AMZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE    [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
If clalev([F:MH])=0  : Local File MSMODCTR [MH]  : Endif
Local Integer LDICO , LVRA
Local Integer LMS , MSJ , MOK
Local Char NOMWIN(10) , APPLI(GLONADS)
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = 'FRA' #Total Payroll is FRA only
Return

#####################################
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$SETBOUT
If !CLECUR | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET
Endif
# Transaction transaction inactive
If [M]ENAFLG<>2
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
Return

$EXEBOUT
Case BOUT
 When "V" : APPLI=nomap(0) : Gosub GENERAWI
 When Default
Endcase
Return

$RAZCRE
[M]ENAFLG=2
Return

$LIENS
LDICO = 1
LVRA  = 1
Raz GFLDMS
Raz GVRAMS
#On charge les champs/variables de la transaction
For [F:SCD]SCD0 Where COD=[F:HRSCH]COD
 Case [F:SCD]ORIFLD
  When 1 #champ salarié
   If LDICO > dim(GFLDMS)
    GMESSAGE=mess(26,100,1)- num$(LDICO) : #Tableau plein
    Break
   Endif
   nolign=LDICO
   [M:SCH1]FLD(nolign-1)=[F:SCD]FLD
   [M:SCH1]TIT(nolign-1)=[F:SCD]TIT
   [M:SCH1]ORIFLD(nolign-1)=[F:SCD]ORIFLD
   GFLDMS(LDICO,0) = [F:SCD]FLD
   LDICO+=1
  When 2 #variable salarié
   If LVRA > dim(GVRAMS)
    GMESSAGE=mess(26,100,1)- num$(LVRA) : #Tableau plein
    Break
   Endif
   nolign=LVRA
   [M:SCH2]VRA(nolign-1)=[F:SCD]FLD
   [M:SCH2]TIT(nolign-1)=[F:SCD]TIT
   [M:SCH2]ORIFLD(nolign-1)=[F:SCD]ORIFLD
   GVRAMS(LVRA,0) = [F:SCD]FLD
   LVRA+=1
  When Default
 Endcase
Next
[M]NBDICO=LDICO-1
[M]NBVRA =LVRA-1
Return

$VERIF_MOD
MSJ=1
#On vérifie si il y a eu des suppressions de champs ou de variables
For LMS=1 To dim(GFLDMS)
 #57165
 #MSJ = find(GFLDMS(LMS,0),[M:SCH1]FLD(0..[M:SCH1]NBDICO))
 MSJ = find(GFLDMS(LMS,0),[M:SCH1]FLD(0..[M:SCH1]NBDICO-1))
 If !MSJ : Break : Endif
Next
If MSJ
 For LMS=1 To dim(GVRAMS)
  #57165
  #MSJ = find(GVRAMS(LMS,0),[M:SCH2]VRA(0..[M:SCH2]NBVRA))
  MSJ = find(GVRAMS(LMS,0),[M:SCH2]VRA(0..[M:SCH2]NBVRA-1))
  If !MSJ : Break : Endif
 Next
Endif
If !MSJ
#c'est le cas, on vérifie s'il existe une hypothèse pour cette transaction
 Read [F:MH]MHC1=[M:SCH0]COD
 If !fstat #on averti
  MOK=2
  #Les colonnes supprimées vont être supprimées dans les hypothèses de cette transaction
  Call AVERTIR(mess(8,10722,1),MOK) From GESECRAN
  If MOK = 1
   OK=0
  Endif
 Endif
Endif
If [F:HRSCH]ENAFLG = 2 & [M:SCH0]ENAFLG = 1
 [F:HRSCH]ENAFLG = 1
 APPLI = nomap(0)
 Gosub GENERAWI
Endif
Return

$INIMOD
$INICRE
Delete [F:SCD] Where COD=[F:HRSCH]COD
If fstat=1
 GOK =-1 : GLOCK = "$SCRMHCD" : Return
Endif
Raz GFLDMS
Raz GVRAMS
#champs salarié
For LMS=1 To [M:SCH1]NBDICO
 nolign=LMS
 Raz [F:SCD]
 [F:SCD]=[M:SCH0]
 [M:SCH1]TIT(nolign-1)=[M:SCH1]ZFLD(nolign-1) #On récupère l'intitulé long
 [F:SCD]=[M:SCH1]
 [F:SCD]LIG=LMS
 Write [F:SCD]
 If fstat<>0
  GOK = 0 : Call FSTA("SCD") From GLOCK : Break
 Endif
 GFLDMS(LMS,0) = [F:SCD]FLD
Next
#Variables salarié
If !GOK : Goto FININI : Endif
For LMS=1 To [M]NBVRA
 nolign=LMS
 Raz [F:SCD]
 [F:SCD]=[M:SCH0]
 [M:SCH2]TIT(nolign-1)=[M:SCH2]ZVRA(nolign-1) #On récupère l'intitulé long
 [F:SCD]FLD=[M:SCH2]VRA(nolign-1)
 [F:SCD]TIT=[M:SCH2]TIT(nolign-1)
 [F:SCD]ORIFLD=[M:SCH2]ORIFLD(nolign-1)
 [F:SCD]LIG=LMS+[M:SCH1]NBDICO
 Write [F:SCD]
 If fstat<>0
  GOK = 0 : Call FSTA("SCD") From GLOCK : Break
 Endif
 GVRAMS(LMS,0) = [F:SCD]FLD
Next
If !GOK : Goto FININI : Endif
#Maj des hypothèses...
Gosub MAJHYP From SUBSEH2
FININI
Return

$ANNULE
# Annulation de la fenêtre et des traitements associés
NOMWIN = "WFMHC"+[M:SCH0]COD
Call DELWIN(NOMWIN,nomap) From MSKDIV
If GOK<1 : Return : Endif
Delete [F:SCD] Where COD=[F:HRSCH]COD
If fstat=1
 GOK =-1 : GLOCK = "$SCRMHCD" : Return
Endif
Return

$GENERAWI
Call GENECR(APPLI,"MHC",[F:HRSCH]COD,[F:HRSCH]ENAFLG,[F:HRSCH]CODACS,[F:HRSCH]CODACT,[F:HRSCH]DES) From SUBSEH2
Return

########################################
$TRTCOP
If [M]DOSORG=nomap
 Local File SCRMHCH [SCH1]
 Local File SCRMHCD [SCD1]
Else
 Local File =[M]DOSORG+".SCRMHCH" [SCH1]
 Local File =[M]DOSORG+".SCRMHCD" [SCD1]
Endif
If [M]DOSDES=nomap
 Local File SCRMHCH [SCH2]
 Local File SCRMHCD [SCD2]
Else
 Local File =[M]DOSDES+".SCRMHCH" [SCH2]
 Local File =[M]DOSDES+".SCRMHCD" [SCD2]
Endif

Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [SCH1], [SCH2],[SCD1],[SCD2]
Return

$TR_COP
GOK = 1
Trbegin [SCH2],[SCD2]
 Delete [SCH2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCRMHCH" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SCH2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [SCD2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCRMHCD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SCHD","") From GLOCK : Goto AB_TR_COP
 Endif
 #Entete
 Read[SCH1]SCH0=TABLE
 If !fstat
  [F:SCH2] = [F:SCH1]
  If dim([F:SCH2]CREUSR)>0 : [F:SCH2]CREUSR = GUSER : Endif
  If dim([F:SCH2]CREDAT)>0 : [F:SCH2]CREDAT = date$ : Endif
  If dim([F:SCH2]CRETIM)>0 : [F:SCH2]CRETIM = time : Endif
  If dim([F:SCH2]UPDUSR)>0 : Raz [F:SCH2]UPDUSR  : Endif
  If dim([F:SCH2]UPDDAT)>0 : Raz [F:SCH2]UPDDAT  : Endif
  If dim([F:SCH2]UPDTIM)>0 : Raz [F:SCH2]UPDTIM  : Endif
  Write [SCH2]
  If fstat
   GOK = 0 : Call FSTA("SCH2") From GLOCK : Return
  Endif
  #Lignes
  For [SCD1]SCD0 Where COD=[F:SCH1]COD
   [SCD2]=[SCD1]
   Write [SCD2]
   If fstat
    GOK = 0 : Call FSTA("SCD2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

Subprog GENDOS(APPLI)
#Génération en masse
Value Char APPLI()
If clalev([F:HRSCH])=0  : Local File =APPLI+".SCRMHCH"    [HRSCH]  : Endif
If clalev([F:SCD])=0  : Local File =APPLI+".SCRMHCD"    [SCD]  : Endif
For [HRSCH]SCH0 Where ENAFLG=2
 If GTRACE<>"" : Call ECR_TRACE([F:HRSCH]COD,0) From GESECRAN : Endif
  Gosub GENERAWI
 If GOK=0 : Break : Endif
Next
End
######################################################################################
######################################################################################

Subprog AM_FLD(VALEUR)
Variable Char    VALEUR()
#contrôle des doublons
Call CTL_DBL_FLD(VALEUR,nolign-1) From SUBSEH2
 If !GOK
  mkstat=2
  End
 Endif
End

Subprog AM_VRA(VALEUR)
Variable Char    VALEUR()
#contrôle des doublons
Call CTL_DBL_VRA(VALEUR,nolign-1) From SUBSEH2
 If !GOK
  mkstat=2
  End
 Endif
End

######################################################################################
