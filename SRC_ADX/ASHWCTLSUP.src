#<AdxTL>@(#)0.0.0.0 $Revision$

Gosub TEST From ASHWVAL
End

#---------------------------------------------------------------------------------------------------#
# Ecriture du traitement
#---------------------------------------------------------------------------------------------------#

Subprog CREATE_TRTCTLSUP(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ASHW,AERR)  : # Fichier WMRS
Value Integer VALP
Variable Integer TYPAGE
Value Char MACHINE
Value Char APPLI
Value Char DOSSIER
Variable Instance ASHW Using OBJECT
Variable  Instance  AERR(1..) Using C_AERROR



If ASHW.TEST : Call ECR_TRACE("- Create TRT = "-ASHW.ACLAV.TRTCTLSUP,0) From GESECRAN : Endif

If ASHW.ACLAV.TRTCTLSUP="" : End : Endif

Local Clbfile    CLOB(9)
Local Integer   DIF,OK,NIVEAU,ISAFTER_READ,I,K
Local Char      LIGNE(250)
Local Char      TABACS(GLONACS)(1..),WCODPRO(250)


For MT=1 To maxtab(ASHW.ACLA.ACLAT)
 Case ASHW.ACLA.ACLAT(MT).CODMETSTD
  When "R" : ISAFTER_READ = 1
 Endcase
Next

Gosub TRT_METHODS
Gosub TRT_PROPERTIES

If ISAFTER_READ
 Gosub AFTER_READ
Endif

Call STC_DEB([L]APPLI,[L]MACHINE,ASHW.ACLAV.TRTCTLSUP,ASHW.ACLAV.IDENTSTC,ASHW.CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
Call TRT_FIN(CLOB,ASHW.ACLAV.TRTCTLSUP,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
If maxtab(AERR)>0  : End : Endif

End

#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$ADDCLB0
Append CLOB,LIGNE+chr$(10)
Return

$SEP_LINE
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
Return


#-------------------------------------------------------#
$TRT_PROPERTIES
Gosub SEP_LINE
LIGNE = "$PROPERTIES" : Gosub ADDCLB
LIGNE = "Case [L]ARULE" : Gosub ADDCLB
DIF += 1
LIGNE = 'When "CONTROL"' :  Gosub ADDCLB
DIF +=1
LIGNE = "Case [L]CURPRO" : Gosub ADDCLB
DIF += 1
If ASHW.AFCRIGHT<>""
 For I=1 To maxtab(ASHW.ASWR)
  WCODPRO = ASHW.ASWR(I).CODPRO
  K=instr(1,WCODPRO,".")
  While K>0
   WCODPRO = right$(WCODPRO,K+1)
   K=instr(1,WCODPRO,".")
  Wend
  If ASHW.ASWR(I).ACLAF.ATY.CODTYP ="FCY"
   LIGNE = 'When "'+ASHW.ASWR(I).CODPRO+'"' :    Gosub ADDCLB
   DIF += 1
   LIGNE = 'If this.'+WCODPRO+'<>""' : Gosub ADDCLB
   DIF += 1
   LIGNE = '[L]ASTATUS = fmet this.ACTX.AGETAFCRIGHTFCY(this,"'+ASHW.AFCRIGHT+'",this.'+WCODPRO+',[V]CST_ATRUE)'  :  Gosub ADDCLB
   DIF -= 1
   LIGNE = "Endif" : Gosub ADDCLB
   DIF -= 1
  Endif
  If ASHW.ASWR(I).ACLAF.ATY.CODTYP ="CPY"
   LIGNE = 'When "'+ASHW.ASWR(I).CODPRO+'"' :    Gosub ADDCLB
   DIF += 1
   LIGNE = 'If this.'+WCODPRO+'<>""' : Gosub ADDCLB
   DIF += 1
   LIGNE = '[L]ASTATUS = fmet this.ACTX.AGETAFCRIGHTCPY(this,"'+ASHW.AFCRIGHT+'",this.'+WCODPRO+',[V]CST_ATRUE)' : Gosub ADDCLB
   DIF -= 1
   LIGNE = "Endif" : Gosub ADDCLB
   DIF -= 1
  Endif
 Next
Endif
LIGNE = 'When Default' : Gosub ADDCLB
DIF -= 1
LIGNE = "Endcase" : Gosub ADDCLB
DIF -= 1
LIGNE = 'When "PROPAGATE"' :  Gosub ADDCLB
DIF +=1
LIGNE = "Case [L]CURPRO" : Gosub ADDCLB
DIF += 1
If ASHW.AFCRIGHT<>""
For I=1 To maxtab(ASHW.ASWR)
  WCODPRO = ASHW.ASWR(I).CODPRO
  K=instr(1,WCODPRO,".")
  While K>0
   WCODPRO = right$(WCODPRO,K+1)
   K=instr(1,WCODPRO,".")
  Wend
  If WCODPRO="ENAFLG" & ASHW.AFCRIGHT<>""
   LIGNE = 'When "'+ASHW.ASWR(I).CODPRO+'"' :    Gosub ADDCLB
   DIF += 1
   LIGNE = 'If [L]ASTATUS = fmet this.ACTX.AGETAFCRIGHTN(this,"'+ASHW.AFCRIGHT+'","'+ASHW.AFCRIGHT+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
   DIF += 1
   LIGNE = "this.ENAFLG = [L]_AOLDVAL" : Gosub ADDCLB
   DIF -= 1
   LIGNE = "Endif" : Gosub ADDCLB
   DIF -=1
  Endif
 Next
Endif
LIGNE = 'When Default' : Gosub ADDCLB
DIF -= 1
LIGNE = "Endcase" : Gosub ADDCLB
DIF -= 1
LIGNE = "Endcase" : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#-------------------------------------------------------#
$TRT_METHODS
Gosub SEP_LINE
LIGNE = '$METHODS' : Gosub ADDCLB
LIGNE = '$EVENTS' : Gosub ADDCLB
LIGNE = 'Case [L]AEVENT' : Gosub ADDCLB
DIF += 1
If ISAFTER_READ :
 LIGNE = 'When "AREAD_AFTER"' : Gosub ADDCLB
 DIF +=1
 LIGNE = "Case [L]CURPTH" : Gosub ADDCLB
 DIF += 1
 For NIVEAU=1 To  maxtab(ASHW.PTHGRI)
  LIGNE = 'When "'+ASHW.PTHGRI(NIVEAU)+'"'
  LIGNE +=' : Gosub ADDACS'+num$(NIVEAU) : Gosub ADDCLB
 Next
 LIGNE = 'When "" : Gosub ADDACSREP': Gosub ADDCLB
 DIF -=1
 LIGNE = 'Endcase' : Gosub ADDCLB
 DIF -= 1
Endif
LIGNE = 'When "AINIT"' : Gosub ADDCLB
DIF +=1
LIGNE = "Case [L]CURPTH" : Gosub ADDCLB
DIF += 1
For NIVEAU=1 To  maxtab(ASHW.PTHGRI)
 LIGNE = 'When "'+ASHW.PTHGRI(NIVEAU)+'"'
 LIGNE +=' : Gosub ADDACS'+num$(NIVEAU): Gosub ADDCLB
Next
LIGNE = 'When "" : Gosub ADDACSREP': Gosub ADDCLB
DIF -=1
LIGNE = 'Endcase' : Gosub ADDCLB
DIF -= 1
LIGNE = 'When Default'  : Gosub ADDCLB
DIF -=1
LIGNE = 'Endcase' : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

$AFTER_READ
Gosub SEP_LINE
For NIVEAU=1 To  maxtab(ASHW.PTHGRI)
 LIGNE = "#"-ASHW.PTHGRI(NIVEAU): Gosub ADDCLB
 LIGNE ="$ADDACS"+num$(NIVEAU) : Gosub ADDCLB
 If ASHW.ACLAGRI(NIVEAU).TYPCLA>=0
  Call DEFACS(ASHW.ACLAGRI(NIVEAU).ACLAF,LIGNE,CLOB,DIF)
  Call DEFAFTOPTN(ASHW.ACLAGRI(NIVEAU).ACLAF,ASHW.AFCRIGHT,LIGNE,CLOB,DIF)
 Else
  Call DEFACS(ASHW.ASWGRI(NIVEAU).ACLAF,LIGNE,CLOB,DIF)
 Endif
 LIGNE = "Return" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Next
LIGNE ="$ADDACSREP" : Gosub ADDCLB
Call DEFACS(ASHW.ACLAF,LIGNE,CLOB,DIF)
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return


Subprog DEFACS(ACLAF,LIGNE,CLOB,DIF)
Variable  Instance  ACLAF(1..)  Using C_ACLAFLD
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Integer   OK,NIVEAU,ISAFTER_READ,I,K
Local Char      TABACS(GLONACS)(1..),WCODPRO(250)

For M=1 To maxtab(ACLAF)
 If ACLAF(M).LNKCLA=""
  If ACLAF(M).ACS<>"" & ACLAF(M).LNKCLA="" & !find(ACLAF(M).ACS,TABACS)
   I +=1
   TABACS(I) = ACLAF(M).ACS
  Endif
 Endif
Next
For J=1 To I
 LIGNE = 'If fmet this.ACTX.AGETACSRIGHTC(this,"'+TABACS(J)+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
 DIF +=1
 For M=1 To maxtab(ACLAF)
  If ACLAF(M).ACS=TABACS(J) & ACLAF(M).LNKCLA=""
   LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF(M).FLDCLA+'","$isHidden","true")' : Gosub ADDCLB
   LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF(M).FLDCLA+'",[V]CST_ARIGHTACCESS,"false")' : Gosub ADDCLB
  Endif
 Next
 DIF -=1
 LIGNE = 'Elsif fmet this.ACTX.AGETACSRIGHTM(this,"'+TABACS(J)+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
 DIF +=1
 For M=1 To maxtab(ACLAF)
  If ACLAF(M).ACS=TABACS(J) & ACLAF(M).LNKCLA=""
   LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF(M).FLDCLA+'","$isReadOnly","true")' : Gosub ADDCLB
  Endif
 Next
 DIF -=1
 LIGNE = "Endif" : Gosub ADDCLB
Next
End

Subprog DEFAFTOPTN(ACLAF,AFCRIGHT,LIGNE,CLOB,DIF)
Variable  Instance  ACLAF(1..)  Using C_ACLAFLD
Value Char AFCRIGHT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Integer   M

For M=1 To maxtab(ACLAF)
 If ACLAF(M).FLDCLA="ENAFLG" & AFCRIGHT<>""
  LIGNE = 'If fmet this.ACTX.AGETAFCRIGHTN(this,"'+AFCRIGHT+'","",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
  DIF +=1
  LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("ENAFLG","$isReadOnly","true")'  : Gosub ADDCLB
  DIF -=1
  LIGNE = "Endif" : Gosub ADDCLB
 Endif
Next
End

