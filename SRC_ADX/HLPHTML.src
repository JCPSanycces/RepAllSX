#<AdxTL>@(#)1.0.0.0 $Revision$
Local Integer NBFIC,I
Local Char FICHIERS(20)(1..5000)
Local Char REPERT_ORI(100),REPERT_DES(100),FICHIER_CONFIG(100)

# A modifier selon le cas
# Si des chemin absolu sont mis, il sont respectés par le Call INIT
# Sinon, les chemins sont relatifs par rapport à REPERT_BASE
# Si REPERT_BASE est vide, il est renseigné par le Call INIT
REPERT_BASE="/home/mbz/fra/champs"
REPERT_ORI="hl1"
REPERT_DES="hlp"

dbgmode(1)=1

Call INIT(REPERT_BASE,REPERT_ORI,REPERT_DES,FICHIER_CONFIG) From DEFHTML
## System FICHIERS="cd"-REPERT_ORI+"; ls F_TOTO.htm"
System FICHIERS="cd"-REPERT_ORI+"; ls *.htm"
NBFIC=stat1
For I=1 To NBFIC
  Openi REPERT_ORI+"/"+FICHIERS(I),0
  Openo REPERT_DES+"/"+FICHIERS(I),0
  Call TEMPON("TRANSCODAGE"-FICHIERS(I)) From GESECRAN
  Call TRANSCODE
  Call TEMPOFF From GESECRAN
Next I
Kill TRS_CO
End

Subprog TRANSCODE

Local Libelle OCT_LUS(10000)
Local Char CHAINE(255),CHAINE1(255),TITLE(255),CARLU(1),CARSEP(1)
Local Integer LONG,BOUTON,PREMIER_H2
Local Integer P_ALIGN

# Prerequis important !
adxifs=chr$(0) : adxifs=chr$(0)
fstat=0
PREMIER_H2=0
P_ALIGN=0

# Recherche de la première clause H1 pour trouver le titre
While fstat=0
  Call COPIE_JUS2(ascii("<"),ascii("\"),CARLU)
  If fstat : Break : Endif
  If CARLU="\"
    Call LIT_CH("\<",CHAINE,LONG,200,CARSEP)
    If CARSEP="\"
      Call LIT_CH("\<",CHAINE1,LONG,200,CARSEP)
        If CARSEP="\"
           Call ECRIT_CHAINE('<A HREF="'+CHAINE1+'.htm'+'">') From FCTHTML
           Call ECRIT_CHAINE(CHAINE+"</A>") From FCTHTML
        Else
           Call ECRIT_CHAINE(CARLU+CHAINE+CARSEP) From FCTHTML
           Call ECRIT_CHAINE(CHAINE1) From FCTHTML
        Endif
    Else   Call ECRIT_CHAINE(CARLU+CHAINE) From FCTHTML
           If CARSEP="<" : Goto INFERIEUR : Endif
    Endif
  Elsif CARLU="<"
$INFERIEUR
    Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG) From FCTHTML

    If toupper(vireblc(CHAINE,3))="A"
      If pat(vireblc(toupper(vireblc(right$(vireblc(CHAINE,0),2),0)),4),'HREF="*.RTF"*')
        I=instr(1,CHAINE,".rtf")
        If I
          CHAINE=left$(CHAINE,I-1)+".htm"+right$(CHAINE,I+4)
        Endif
      Endif
    Endif
##  HTML
    If (left$(CHAINE,04)='HTML') 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
##  /HTML
    If (left$(CHAINE,05)='/HTML') 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
##  /FONT (on met /LI et /P avant)
    If (left$(CHAINE,05)='/FONT') 
        CHAINE = '/LI'
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
        CHAINE = '/P'
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
        CHAINE = '/FONT'
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML

    Endif
##  HEAD
    If (left$(CHAINE,04)='HEAD') 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
##  META HTTP
    If (left$(CHAINE,09)='META HTTP') 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
##  TITLE
    If (left$(CHAINE,05)='TITLE') 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
##  /TITLE
    If (left$(CHAINE,06)='/TITLE') 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
##  /HEAD
    If (left$(CHAINE,05)='/HEAD') 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
##  BODY
    If (left$(CHAINE,04)='BODY') 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
##  /BODY
    If (left$(CHAINE,05)='/BODY') 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif

##  Pas de FONT et SIZE à 2
    If (left$(CHAINE,32)='FONT FACE="Comic Sans MS" SIZE=5') 
       CHAINE='FONT SIZE=2'+ mid$ (CHAINE,33,255) 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
    If (left$(CHAINE,32)='FONT FACE="Comic Sans MS" SIZE=4') 
       CHAINE='FONT SIZE=2'+ mid$ (CHAINE,33,255) 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
    If (left$(CHAINE,32)='FONT FACE="Comic Sans MS" SIZE=3') 
       CHAINE='FONT SIZE=2'+ mid$ (CHAINE,33,255) 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
    If (left$(CHAINE,32)='FONT FACE="Comic Sans MS" SIZE=2') 
       CHAINE='FONT SIZE=2'+ mid$ (CHAINE,33,255) 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
    If (left$(CHAINE,32)='FONT FACE="Comic Sans MS" SIZE=1') 
       CHAINE='FONT SIZE=2'+ mid$ (CHAINE,33,255) 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif
##  Un seul P ALIGN=JUSTIFY
    If (left$(CHAINE,07)='P ALIGN') 
       If P_ALIGN=0  
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
        P_ALIGN=1
       Endif
    Endif
##  /P devient br (retour chariot)
    If (left$(CHAINE,02)='/P') 
        CHAINE='br'
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif 
##  LI
    If (left$(CHAINE,02)='LI') 
        Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
    Endif 

##    Call ECRIT_CHAINE("<"+CHAINE+">") From FCTHTML
  Endif
Wend
Openi:Openo
End

Subprog COPIE_JUS2(CARAC1,CARAC2,CARAC)
Value Integer CARAC1,CARAC2
Variable Char CARAC()
Local Libelle OCT_LUS
Getseq 1,OCT_LUS
While fstat=0 & find(OCT_LUS,CARAC1,CARAC2)=0
  Putseq 1,OCT_LUS
  Getseq 1,OCT_LUS
Wend
If fstat=0 : CARAC=chr$(OCT_LUS) : Else CARAC="" : Endif
End
##
Subprog LIT_CH(CARAC,CH_LUE,LONG,LGMAX,SEP)
Value Char CARAC() : Variable Integer LONG
Value Integer LGMAX
Variable Char CH_LUE(),SEP()
Local Libelle CAR
CH_LUE=""
[L]LONG=0
[L]CAR=0
Repeat
  CH_LUE+=chr$([L]CAR)
  Getseq 1,[L]CAR
  [L]LONG+=1
Until fstat=1 | instr(1,[L]CARAC,chr$([L]CAR)) | ([L]LONG>=[L]LGMAX)
If fstat=1 | instr(1,[L]CARAC,chr$([L]CAR)) : [L]LONG-=1 : Endif
If fstat=0 & instr(1,[L]CARAC,chr$([L]CAR)) : [L]SEP=chr$([L]CAR) : Else [L]SEP="" : Endif
If fstat=0 & instr(1,[L]CARAC,chr$([L]CAR))=0 : CH_LUE+=chr$([L]CAR) : Endif
End
