###################################################################################################
#                                                                                                 #
# TRTPJTSAL :     TRAITEMENTS LIES au PJT dans les VENTES                                         #
#                                                                                                 #
###################################################################################################
####################################################################################################
$ACTION
  Case PJTACTION
     When "PJT_AFTER_MODIFY"        : Gosub PJT_AFTER_MODIFY
     When Default
  Endcase
Return

####################################################################################################
$PJT_AFTER_MODIFY
  If ZONDET <> "" Then
    # Si ZONDET est alimenté : c'est qu'on est sur l'entête.
    If func TRTPJT.GET_PARAM_PJTSNGDOC(SITE) = G_OUI Then
      Global Char GPJTACTMOD(GLONDES)

      GPJTACTMOD = "1"
    Endif

    # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/08/17)
    # Code activité PJM actif et il existe un axe géré à l'affaire
    # Active activity code PJM and a dimension type is managed by project
    If func ASYRFNC.ACTIV("PJM") & GPJMDIE <> ""
        # Après la modification du code affaire entête et la réinitialisation de la section sur l'entête
        # Il faut réinitialiser la section sur les élts de facturation
        # Ce sera fait dans CREMOD_DIE_FOOT de SUBSIHV appelé en CREATION/MODIF si le flag=2
        # After the header project code modification and the header dimension initialization
        # It is necessary to reinitialize the dimension for the invoicing elements
        # This will be done in CREMOD_DIE_FOOT from SUBSIHV called in CREATION/MODI if the flag=2
        If clalev([M:SIHV])>0 & dim([M:SIHV]INIPJMCCEFLG)> 0
            [M:SIHV]INIPJMCCEFLG = 2
        Endif
    Endif
    # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/08/17)

  Endif
  # ----------------------------------------------------
  If ZONHEAD <> "" Then
    # Si ZONHEAD est alimenté : c'est qu'on est sur le détail
    Global Char GPJTACTMOD(GLONDES)
  Endif
Return

####################################################################################################
#
##################################################################################################
#                                                                                                #
# Etiquettes appelées par SUBSPC : Paramétrage des tarifs vente                                  #
#                                                                                                #
#  Création temporaire dans AMSKPAR des données pour le type de données PJT (pour masque de base)#
#                                                                                                #
#  $CRE_AMP_ATY_PJT      : Déclaration des paramètres des actions et appel au étiquettes         #
#  $CRE_AMP_PJT_COMMUN   : Création des paramètres communs à ts les chps de type de données PJT  #
#  $CRE_AMP_PJTNUM       : Création des paramètres propres au chp PJTNUM (Code affaire seul)     #
#  $CRE_AMP_PJT          : Création des paramètres propres au chp PJT (Code affaire complet)     #
#  $CRE_AMP_WRITE        : Création de l'enregistrement dans AMSKPAR                             #
#                                                                                                #
#  Suppression dans AMSKPAR des données pour le type de données PJT                              #
#                                                                                                #
#  $SUP_AMP_PJT          : Suppression des enregistrements dans AMSKPAR                          #
#                                                                                                #
#  Suppression dans AMSKACT des données pour le type de données PJT                              #
#                                                                                                #
#  $SUP_AMA_PJT          : Suppression des enregistrements dans AMSKACT                          #
#                                                                                                #
#  Controle en saisie du paramétrage des tarifs :                                                #
#                                                                                                #
#  Ctrl en saisie des champs critères :                                                          #
#  $CTL_FLD_PJT          : PJT et PJTNUM de SPRICLINK sont exclusifs                             #                                                                                                #
#                                                                                                #
##################################################################################################

#  Déclaration des paramètres des actions et appel au étiquettes
$CRE_AMP_ATY_PJT

# Tableau des paramètres des actions du type de données PJT
Local Char WCODPAR(GLONAAR) (0..20)
WCODPAR(0)  = "CODMSK"        : # Ecran
WCODPAR(1)  = "FLDNAM"        : # Nom zone courante
WCODPAR(2)  = "NOLIG"         : # N° de la ligne courante
WCODPAR(3)  = "MODULE"        : # Module
WCODPAR(4)  = "BOOCRM"        : # Booléen CRM
WCODPAR(5)  = "BOOPRP"        : # Booléen PRP
WCODPAR(6)  = "BOOPRPBUD"     : # Booléen PRP Budget
WCODPAR(7)  = "BOOPRPTAC5"    : # Booléen PRP Taches MO
WCODPAR(8)  = "BOOPRPTAC6"    : # Booléen PRP Taches MAC
WCODPAR(9)  = "BOOPRPTAC7"    : # Booléen PRP Taches Mixte
WCODPAR(10) = "USEDISPRP"     : # Autoriser affaires inactives
WCODPAR(11) = "USEDISBUD"     : # Autoriser budgets inactifs
WCODPAR(12) = "USEDISTAC"     : # Autoriser taches inactives
WCODPAR(13) = "SITE"          : # Site
WCODPAR(14) = "BPR"           : # Tiers
WCODPAR(15) = "INTERLOC"      : # Interlocuteur
WCODPAR(16) = "ZONHEAD"       : # Zone entête
WCODPAR(17) = "ZONDET"        : # Zone détail
WCODPAR(18) = "SOCIETE"       : # Société

Local Integer WIND_FLD

Case [F:SPC]FLD(I-1)
     When "PJTNUM"     :
        Gosub CRE_AMP_PJT_COMMUN
        Gosub CRE_AMP_PJTNUM
     When "PJT"        :
        Gosub CRE_AMP_PJT_COMMUN
        Gosub CRE_AMP_PJT
    When Default
Endcase

Return

# ---------------------------------------------------------------------------------
#  Création des paramètres qui sont communs à ts les champs de type de données PJT
#  --> PJT : Code affaire complet et PJTNUM : Code affaire sans lot budgétaire
$CRE_AMP_PJT_COMMUN

[F:AMP]CODPAR = WCODPAR(0)      : # Ecran
[F:AMP]VALPAR = '"'+MFROM+'"'
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(1)      : # Nom zone courante
[F:AMP]VALPAR = '"CRIT'+num$(I)+'"'
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(2)      : # N° de la ligne courante
[F:AMP]VALPAR = "nolign-1"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(3)      : # Module
[F:AMP]VALPAR = "5"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(4)      : # Booléen CRM
[F:AMP]VALPAR = "[V]CST_AYES"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(5)      : # Booléen PRP
[F:AMP]VALPAR = "[V]CST_AYES"
Gosub CRE_AMP_WRITE
# 71065/50 : PJT and price list : (LD:02/05/16)
# If PJTNUM : We can't select tasks, If PJT : We can select task
#[F:AMP]CODPAR = WCODPAR(7)      : # Booléen PRP Taches MO
#[F:AMP]VALPAR = "G_NON"
#Gosub CRE_AMP_WRITE
#[F:AMP]CODPAR = WCODPAR(8)      : # Booléen PRP Taches MAC
#[F:AMP]VALPAR = "G_NON"
#Gosub CRE_AMP_WRITE
#[F:AMP]CODPAR = WCODPAR(9)      : # Booléen PRP Taches Mixte
#[F:AMP]VALPAR = "G_NON"
#Gosub CRE_AMP_WRITE
# 71065/50 : PJT and price list : (LD:02/05/16)
[F:AMP]CODPAR = WCODPAR(10)     : # Autoriser affaires inactives
[F:AMP]VALPAR = "[V]CST_ANO"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(11)     : # Autoriser budgets inactifs
[F:AMP]VALPAR = "[V]CST_ANO"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(12)     : # Autoriser taches inactives
[F:AMP]VALPAR = "[V]CST_ANO"
Gosub CRE_AMP_WRITE

[F:AMP]CODPAR = WCODPAR(13)     : # Site
[F:AMP]VALPAR = '""'
# Si le site de vente est paramétré comme critère de tarif, on l'utilise comme filtre pour le code affaire
WIND_FLD=find("SALFCY",[F:SPC]FLD(0..dim([F:SPC]FLD)-1))
If WIND_FLD
   [F:AMP]VALPAR = "[M]CRIT"+num$(WIND_FLD)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(14)     : # Tiers
[F:AMP]VALPAR = '""'
# Si le clt est paramétré comme critère de tarif, on l'utilise comme filtre pour le code affaire
WIND_FLD=find("BPCNUM",[F:SPC]FLD(0..dim([F:SPC]FLD)-1))
If WIND_FLD
   [F:AMP]VALPAR = "[M]CRIT"+num$(WIND_FLD)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(15)     : # Interlocuteur
[F:AMP]VALPAR = '""'
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(16)     : # Zone entête
[F:AMP]VALPAR = '""'
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(17)     : # Zone détail
[F:AMP]VALPAR = '""'
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(18)     : # Société
[F:AMP]VALPAR = '""'
# Si la société est paramétrée comme critère de tarif, on l'utilise comme filtre pour le code affaire
WIND_FLD=find("CPY",[F:SPC]FLD(0..dim([F:SPC]FLD)-1))
If WIND_FLD
   [F:AMP]VALPAR = "[M]CRIT"+num$(WIND_FLD)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE
Return

# ---------------------------------------------------------------------------------------------
#  Création des paramètres qui sont propres au champ PJTNUM : Code affaire sans lot budgétaire
$CRE_AMP_PJTNUM

#[F:AMP]CODPAR = WCODPAR(4)      : # Booléen CRM
#[F:AMP]VALPAR = "G_OUI"
#Gosub CRE_AMP_WRITE
#[F:AMP]CODPAR = WCODPAR(5)      : # Booléen PRP
#[F:AMP]VALPAR = "G_OUI"
#Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(6)      : # Booléen PRP Budget
[F:AMP]VALPAR = "[V]CST_ANO"
Gosub CRE_AMP_WRITE
# 71065/50 : PJT and price list : (LD:02/05/16)
# If PJTNUM : We can't select tasks, If PJT : We can select task
[F:AMP]CODPAR = WCODPAR(7)      : # Booléen PRP Taches MO
[F:AMP]VALPAR = "[V]CST_ANO"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(8)      : # Booléen PRP Taches MAC
[F:AMP]VALPAR = "[V]CST_ANO"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(9)      : # Booléen PRP Taches Mixte
[F:AMP]VALPAR = "[V]CST_ANO"
Gosub CRE_AMP_WRITE
# 71065/50 : PJT and price list : (LD:02/05/16)
Return

# ---------------------------------------------------------------------------------------------
#  Création des paramètres qui sont propres au champ PJT : Code affaire complet
$CRE_AMP_PJT

#[F:AMP]CODPAR = WCODPAR(4)      : # Booléen CRM
#[F:AMP]VALPAR = "G_OUI"
#Gosub CRE_AMP_WRITE
#[F:AMP]CODPAR = WCODPAR(5)      : # Booléen PRP
#[F:AMP]VALPAR = "G_OUI"
#Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(6)      : # Booléen PRP Budget
[F:AMP]VALPAR = "[V]CST_AYES"
Gosub CRE_AMP_WRITE
# 71065/50 : PJT and price list : (LD:02/05/16)
# If PJTNUM : We can't select tasks, If PJT : We can select task
[F:AMP]CODPAR = WCODPAR(7)      : # Booléen PRP Taches MO
[F:AMP]VALPAR = "[V]CST_AYES"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(8)      : # Booléen PRP Taches MAC
[F:AMP]VALPAR = "[V]CST_AYES"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(9)      : # Booléen PRP Taches Mixte
[F:AMP]VALPAR = "[V]CST_AYES"
Gosub CRE_AMP_WRITE
# 71065/50 : PJT and price list : (LD:02/05/16)
Return

#  Création de l'enregistrement dans AMSKPAR
$CRE_AMP_WRITE
[F:AMP]TYPAFF = 1
[F:AMP]CODAFF = MFROM
[F:AMP]CODZON = "CRIT"+num$(I)
Write [AMP]
If fstat
   GOK = 0 : Call FSTA("AMP") From GLOCK : Return
Endif
Return

# ---------------------------------------------------------------------------------------------
# Suppression des paramètres dans AMSKPAR
$SUP_AMP_PJT
Local Integer WIND_PJT

For WIND_PJT=0 To dim(WCODPAR)-1
    If WCODPAR(WIND_PJT)="" Break Endif
    Delete [F:AMP] Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR=WCODPAR(WIND_PJT)
Next

Return

# ---------------------------------------------------------------------------------------------
# Suppression des actions dans AMSKACT
$SUP_AMA_PJT
# Suppression des actions qui se trouvent sur l'écran SPLW pour les chps CRIT1 à CRIT5
# et qui seront remplacées par les actions du type de données PJT

# Sur tous les champs critère :
# Suppression de l'action IB_
Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=1
&                    With CODAFF="SPLW_"
# Suppression de l'action AS_
Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=4
&                    With CODAFF="SPLW_"
# Suppression de l'action C_
Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=5
&                    With CODAFF="SPLW_"
# Suppression de l'action B1_
Update [AMA] Where ACTION="GOBJETC" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=9
&                    With CODAFF="SPLW_"

# Sur le 1er champ critère CRIT1
If I=1
  # Suppression des boutons B2 à B4
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=10
&                      With CODAFF="SPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=11
&                      With CODAFF="SPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=12
&                      With CODAFF="SPLW_"
  # Suppression des boutons B5 à B8
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=15
&                      With CODAFF="SPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=16
&                      With CODAFF="SPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=17
&                      With CODAFF="SPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=18
&                      With CODAFF="SPLW_"
Endif
Return

# Vérification exclusivité entre les champs PJT et PJTNUM
$C_FLD_PJT
Local Integer WI

If [M:SPC1]FIL(NOL)="SPRICLINK" & find(VALEUR, "PJT", "PJTNUM")
  For WI=0 To [M:SPC1]BASTAB-1
    If WI<>NOL & (([M:SPC1]FIL(WI)="SPRICLINK" & [M:SPC1]FLD(WI)="PJT"    & VALEUR="PJTNUM") |
&                 ([M:SPC1]FIL(WI)="SPRICLINK" & [M:SPC1]FLD(WI)="PJTNUM" & VALEUR="PJT"))
      GMESSAGE=[M:SPC1]FIL(WI)+":"+[M:SPC1]FLD(WI)+"\"+[M:SPC1]FIL(NOL)+":"+VALEUR-"\"-mess(587,199,1)
      mkstat=2 : Break
    Endif
  Next
Endif

Return



# X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)
# ---------------------------------------------------------------------------------------------
# Alimentation des paramètres nécessaires/Supply of necessary parameters
# ---------------------------------------------------------------------------------------------
# Le type de données PJT a atteint la limite du nbre de parameter/Data type PJT has readched the limit of the number of parameters
$GET_PARAM_CCEH

# WPJT_INIT_CCEH  : # Flag init section à l'entête (1 Non/2 Oui)/Flag for init header dimension (1 No/2 Yes)

# WPJT_INIT_CCED  : # Flag init section à la ligne (1 Non/2 Oui)/Flag for init line dimension (1 No/2 Yes)

# WCCEBASTAB      : # Nom de la variable bas de tableau des sections/Grid variable dimension name
#   Or
# WCCEFIC         : # Nom du fichier des sections/Dimension file name

# WCCESECDEF      : # Section par défaut/Default dimension

# Cas particulier ZONDET ZONHEAD sont à blc/Particular case ZONDET ZONHEAD are not empty
# Mettre WPJT_INIT_CCED = 2 si on veut initialiser les sections à la ligne et alimenter SBASTAB
# Put WPJT_INIT_CCED = 2 if we want to initialize sections on the lines and and fed SBASTAB

Case CODMSK
  When "SQH1"
    # Quotes
    WPJT_INIT_CCEH = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCEBASTAB = "[M:SQH3]NBAXE"
    WCCESECDEF = "SQH"
  When "SOH1"
    # Orders
    WPJT_INIT_CCEH = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCEBASTAB = "[M:SOH3]NBAXE"
    WCCESECDEF = "SOH"
  When "SDH2"
    # Deliveries
    WPJT_INIT_CCEH = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCEBASTAB = "[M:SDH3]NBAXE"
    WCCESECDEF = "SDH"
  When "SIH1"
    # Invoices
    WPJT_INIT_CCEH = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCEBASTAB = "[M:SIH2]NBAXE"
    WCCESECDEF = "SIV"
  When "SRH2"
    # Customer Returns
    WPJT_INIT_CCEH = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCEBASTAB = "[M:SRH2]NBAXE"
    WCCESECDEF = "SRH"
  When "SRL2"
    # Loan Returns
    WPJT_INIT_CCEH = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCEBASTAB = "[M:SRL2]NBAXE"
    WCCESECDEF = "SRL"
  When "SRS2"
    # Subcontract material Returns
    WPJT_INIT_CCEH = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCEBASTAB = "[M:SRS2]NBAXE"
    WCCESECDEF = "SRS"
  When "SOR1"
    # Open order
    WPJT_INIT_CCEH = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WPJT_INIT_CCED = 1              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCEBASTAB = "[M:SOR1]NBAXE"
    WCCESECDEF = "SOR"
  When "SOR1SOC"
    # Open order
    # For Price lines From Open order function when Save button
    WPJT_INIT_CCEH = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WPJT_INIT_CCED = 1              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCEFIC    = "[F:CAL]"
#    WCCESECDEF = "SOIAU"
    WCCESECDEF = "SOI"
  When "SOI1"
    # Open order
    # For Price lines From Product button when entry of project code
    WPJT_INIT_CCEH = 1              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WPJT_INIT_CCED = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    #WCCEBASTAB = "[M:SOI1]NBLIG"
    SBASTAB = "[M:SOI1]NBLIG"
  When Default
Endcase

Return

# ---------------------------------------------------------------------------------------------
# Alimentation des paramètres nécessaires/Supply of necessary parameters
# ---------------------------------------------------------------------------------------------
# Le type de données PJT a atteint la limite du nbre de parameter/Data type PJT has readched the limit of the number of parameters
$GET_PARAM_CCED

# WPJT_INIT_CCED  : # Flag init section à la ligne (1 Non/2 Oui)/Flag for init line dimension (1 No/2 Yes)

# WCCESECDEF      : # Section par défaut/Default dimension

Case WCCEMSK
  When "SQH2"
    # Quotes
    WPJT_INIT_CCED = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCESECDEF = "SQD"
  When "SOH4"
    # Orders
    WPJT_INIT_CCED = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCESECDEF = "SOP"
  When "SDH1"
    # Deliveries
    WPJT_INIT_CCED = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCESECDEF = "SDD"
  When "SIH4"
    # Invoices
    WPJT_INIT_CCED = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCESECDEF = "SID"
  When "SRH1"
    # Customer Returns
    WPJT_INIT_CCED = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCESECDEF = "SRD"
  When "SRL1"
    # Loan Returns
    WPJT_INIT_CCED = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCESECDEF = "SRLD"
  When "SRS1"
    # Subcontract material Returns
    WPJT_INIT_CCED = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCESECDEF = "SRSD"
  When "SOI1"
    # Open order
    # For Price lines From Product button when entry of project code
    WPJT_INIT_CCED = 2              : # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
    WCCESECDEF = "SOI"
  When Default
Endcase

Return
# X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)

