If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_UPDUSR From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_AUUID From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
Return

####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0EDIXMLFILXSD
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGCOD From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGCOD From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGREL From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGREL From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGFILNOR From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGFILNOR From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_NUMLIN From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_NUMLIN From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SORT From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SORT From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CODE From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CODE From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UUIDXSD From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UUIDXSD From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_NAM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_NAM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FILNAM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FILNAM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FILDES From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FILDES From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREDATTIM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREDATTIM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDDATTIM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDDATTIM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREUSR From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREUSR From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDUSR From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDUSR From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_AUUID From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_AUUID From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT :  Endif
[L]ASTATUS = fmet this.ACONTROL
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



