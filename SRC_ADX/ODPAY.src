######################################################################################
#LIPET - 08-03-2017 - X3-28695 - START
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
    [M]ALLPRF=2
    Diszo [M]ALLPRF
Else
    Actzo [M]ALLPRF
Endif

#JOJAC - 2017-05-09 - X3-28695 - START
If dim([M]ALLEXTPER)>0
  If clalev([F:HRPEOH])=0 : Local File HRPEOHEA [HRPEOH] : Endif
  Read [F:HRPEOH]HRPEOH2 = [M:DIA]PERCOD
  If [F:HRPEOH]LEG <> VALEUR
    [M]ALLEXTPER=2 : Effzo PERCOD : Diszo PERCOD : Affzo [M]ALLEXTPER
  Endif
Endif
#JOJAC - 2017-05-09 - X3-28695 - END

End

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
Call INI_LEG From DIVPAYE
End
#LIPET - 08-03-2017 - X3-28695 - END

