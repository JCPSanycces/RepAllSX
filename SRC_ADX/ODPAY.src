#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
# ODPAY
#
# MABOS - 13/06/14 - FQ92876 - US2713 - Accounting Interface ERP V7
################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"FODPAY","ODPAY","",1,"") From GTRAITE
End

################################################################################

$ACTION
Case ACTION
When "DEBUT"    : Gosub DEBUT
When "CONTROLE" : TRA = 1
When "SORTIE"  : Gosub SORTIE
When "INIT"    : Gosub INIT
Endcase
Return

$DEBUT
Local Char    VALPAR(10)
#Raz [M:DIA]
[M:DIA]DATDEB = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
[M:DIA]DATFIN = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
Affzo
#JASMI - START
##LIPET - 08-03-2017 - X3-28695 - START
#If [M:DIA]LEG<>""
#  GCURLEG = [M:DIA]LEG
#Endif
##LIPET - 08-03-2017 - X3-28695 - END
 Affzo [DIA]
 Setmok [DIA] With 0
 Call AFF_MEMO From DIVPAYE
#JASMI - END
Return

$INIT
#LIPET - 08-03-2017 - X3-28695 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#LIPET - 08-03-2017 - X3-28695 - END
Return

$CRITERE
CRITERE = "[F:VEP]STA = 3 & [F:VEP]PST = 1 "
If [M:DIA]ALLCPY<>2   : #société
CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2   : #site
CRITERE -= '& [F:VEP]FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLSRV<>2   : #service
CRITERE -= '& [F:VEP]SRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2   : #profil
CRITERE -= '& [F:VEP]PRF = "'+[M:DIA]PRF+'"'
Endif
#JOJAC - X3-11440- 2017-02-15 - START
If [M:DIA]ALLEXTPER<>2   : #Extraction periods
CRITERE -= '& [F:VEP]percod = "'+[M:DIA]PERCOD+'"'
Endif
#JOJAC - X3-11440 - 2017-02-15 - END
If [M:DIA]DATDEB<>[0/0/0]
CRITERE -= '& [F:VEP]PYRDAT >= [M:DIA]DATDEB '
Endif
If [M:DIA]DATFIN<>[0/0/0]
CRITERE -= '& [F:VEP]PYRDAT <= [M:DIA]DATFIN '
Endif
#DEHEN - X3-16300 - 2017-01-09 - START
  #JOJAC - X3-11440 - 2017-02-20 - START
  #Char CRITERE2(250): CRITERE2 = 0
  Char CRITERE2(250): CRITERE2 = "1=1"
  #JOJAC - X3-11440 - 2017-02-20 - END
  GPOINT = "CRITERE_ODPAY" : Gosub ENTREE From EXEFNC
#DEHEN - X3-16300 - 2017-01-09 - START
Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

################################################################################
## Dans HISTOPAYE
##               TYP = 1 : Part salariale
##               TYP = 2 : Part patronale
##               TYP = 3 : Tranche A
##               TYP = 4 : Tranche B
##               TYP = 5 : Tranche C
##               TYP = 6 : Cumul
##               TYP = 7 : Régul Part salariale
##               TYP = 8 : Régul Part patronale
################################################################################
Subprog MAJODPAY

Local Integer STAT, OK, NOL, OKOD, I, OKNUM, CROIX
Local Char    OLDCPY(GLONCPY), ODPNUM(GLONVCR), COMPTOD(3), OLDNUM(GLONVCR)
Local Char    CRITERE(250), MESSA(80)
Local Decimal TOTCOE(9)

If GSERVEUR
[M:DIA]TRCFLG = 2
Endif

If !GSERVEUR & [M:DIA]TRCFLG=2
#JOJAC - X3-11440 - 2017-02-15 - START
# Call OUVRE_TRACE(mess(67,703,1)) From LECFIC : # Calcul Od de paye
  Call OUVRE_TRACE(mess(67,10703,1)) From LECFIC : # Calcul Od de paye
#JOJAC - X3-11440 - 2017-02-15 - END
Endif
If [M:DIA]TRCFLG=2
#JOJAC - X3-11440 - 2017-02-15 - START
#Call ECR_TRACE(mess(67,703,1),0) From GESECRAN
Call ECR_TRACE(mess(67,10703,1),0) From GESECRAN
#JOJAC - X3-11440 - 2017-02-15 - END
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

Gosub CRITERE
#JOJAC - X3-11440 - 2017-02-15 - START
#Call TEMPON(mess(67,703,1)) From GESECRAN : # Calcul Od de paye
Call TEMPON(mess(67,10703,1)) From GESECRAN : # Calcul Od de paye
#JOJAC - X3-11440 - 2017-02-15 - END

# Fichiers présents sous le dossier PAYE
If clalev([F:FCY])=0  : Local File FACILITY    [FCY]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY     [CPY]  : Endif
If clalev([F:VEP])=0  : Local File VALEMP      [VEP]  : Endif
If clalev([F:HSP])=0  : Local File HISTOPAYE   [HSP]  : Endif
If clalev([F:VAN])=0  : Local File VALANA      [VAN]  : Endif
If clalev([F:RUB])=0  : Local File RUBRIQUE    [RUB]  : Endif
If clalev([F:CPT])=0  : Local File EMPLOCPT    [CPT]  : Endif
If clalev([F:TOD])=0  : Local File TMPODPAY    [TOD]  : Endif
If clalev([F:TOA])=0  : Local File TMPODPAYA   [TOA]  : Endif
If clalev([F:ODE])=0  : Local File ODPAYE      [ODE]  : Endif
If clalev([F:ODP])=0  : Local File ODPAY       [ODP]  : Endif
If clalev([F:ODA])=0  : Local File ODPAYA      [ODA]  : Endif
If clalev([F:ANM])=0  : Local File ACODNUM     [ANM]  : Endif
If clalev([F:POA])=0  : Local File POPULA      [POA]  : Endif
#92876
If clalev([F:RGA])=0  : Local File RUBGAC   [RGA]  : Endif
If clalev([F:GAC])=0 : Local File =GTABCPT+"GACCOUNT" [GAC] : Endif
If clalev([F:LED])=0 : Local File =GTABCPT+"GLED"     [LED] : Endif

If clalev([F:CPR])=0  : Local File EMPLOCTRCPT [CPR]  : Endif
#JOJAC - X3-11440 - 2017-02-15 - START
#Gosub OUVRE From DEFTABLE
Gosub OUVRE From WPDEFTABLE
#JOJAC - X3-11440 - 2017-02-15 - END

Raz OLDCPY, COMPTOD

Call LECTURE("TCA","1","") From CONTOBJ
If !fstat : COMPTOD = [F:TCA]CODNUM(1) : Endif
If COMPTOD="" : COMPTOD = "ODN" : Endif
If [M:DIA]DATFLG=2 : # Génération : rupture par date de paie
# [LNK1] Liste des Bulletins trié par Date de bulletin / Site financier / Employé
If [M:DIA]POP<>""
  Link [VEP] With
&  [FCY]FCY0 = [F:VEP]FCY
& ,[POA]POA0 = [M:DIA]POP;[F:VEP]EMP
&  As [LNK1]
&  Where evalue(CRITERE) & [F:POA]REFNUM<>""
&  Order By Key CLE0=[VEP]PYRDAT;[FCY]FINRSPFCY;[VEP]EMP
Else
  Link [VEP] With
&  [FCY]FCY0 = [F:VEP]FCY
&  As [LNK1]
&  Where evalue(CRITERE)
&  Order By Key CLE0=[VEP]PYRDAT;[FCY]FINRSPFCY;[VEP]EMP
Endif
Else    :# # Génération pas de rupture par date de paie
# [LNK1] Liste des Bulletins trié par Site financier / Employé
If [M:DIA]POP<>""
  Link [VEP] With
&  [FCY]FCY0 = [F:VEP]FCY
& ,[POA]POA0 = [M:DIA]POP;[F:VEP]EMP
&  As [LNK1]
&  Where evalue(CRITERE) & [F:POA]REFNUM<>""
&  Order By Key CLE0=[FCY]FINRSPFCY;[VEP]EMP
Else
  Link [VEP] With
&  [FCY]FCY0 = [F:VEP]FCY
&  As [LNK1]
&  Where evalue(CRITERE)
&  Order By Key CLE0=[FCY]FINRSPFCY;[VEP]EMP
Endif
Endif

Call DEBTRANS From GLOCK
Gosub TR1

$FIN
Call TEMPOFF From GESECRAN
If STAT : Gosub MESSAGE From CPTAUTO : Endif
If OKOD=0
#JOJAC - X3-11440 - 2017-02-15 - START
#Call ECR_TRACE("===>"-mess(72,703,1),0) From GESECRAN : # Pas d'OD crée
Call ECR_TRACE("===>"-mess(72,10703,1),0) From GESECRAN : # Pas d'OD crée
#JOJAC - X3-11440 - 2017-02-15 - END
Endif
If !GSERVEUR & [M:DIA]TRCFLG=2
Call FERME_TRACE From LECFIC
Endif
End

################################################################################
$TR1
GOK=1
Trbegin [TOD],[ODE],[TOA],[ODA],[ODP]
If [M:DIA]DATFLG=2
  #CLE0=[VEP]PYRDAT;[FCY]FINRSPFCY;[VEP]EMP
  For [LNK1]CLE0(2)
   Gosub TR11
   If GOK=0 : Break : Endif
  Next
Else
# CLE0=[FCY]FINRSPFCY;[VEP]EMP
  For [LNK1]CLE0(1)
   Gosub TR11
   If GOK=0 : Break : Endif
  Next
Endif
If GOK=1 : Gosub TR3 : Endif
If GOK<0
Elsif !GOK : OKOD=0 : Goto AB_TR1
Endif
Delete [TOD]TOD1=GIDENT
Delete [TOA]TOA1=GIDENT
Commit

#DEHEN - 2016-10-18 - JIRRA 2172 : Sub Task 2312 - START
####################
#Point d'entrée
####################
GPOINT = "YRECAL" : Gosub ENTREE From EXEFNC
#DEHEN - 2016-10-18 - JIRRA 2172 : Sub Task 2312 - END

Return

$AB_TR1
Rollback
Return

################################################################################
$TR11
NOL = 0
Call NUMERO(COMPTOD,[F:FCY]FINRSPFCY,[F:VEP]PYRDAT,"",[L]ODPNUM,STAT) From SUBANM
If GOK<0
GOK=0 : Return
Elsif STAT
Case STAT
  When 1
   # Compteur inexistant
   Call ECR_TRACE(COMPTOD-mess(2,114,1),1) From GESECRAN
  When 2
   # Dépassement de compteur
   Call ECR_TRACE(COMPTOD-mess(13,114,1),1) From GESECRAN
Endcase
GOK=0 : Return
Endif

OKNUM = 0

# Loop on Payslips - Boucle sur les bulletins
# ==============================================================
#------------------------------------------------------------------------------
# 92876 US2690 - Search COA linked to payslip - recherche des plans à traiter pour le bulletin
Local Char    PLGEN(GLONCOA), PLANA(GLONCOA)
Local Libelle TYPGEN, TYPANA
Local Char    WCPY(GLONCPY)
Local Char    WCPY2(GLONCPY)
Local Integer NBLED         : # Nombre de référentiels
Local Char    CODLED(GLONLED)(1..len(mess(0,2644,1))) : # Référentiels (en 1:général principal, en 2:analytique principal)
Local Char    WMODELE(GLONGCM)
#Local Char    WCCE(GLONCCE)(0..[V]GOPTCANA-1)
Local Integer NBREF : NBREF = len(mess(0,2644,1))
Local Integer NBPLAN
Local Integer TPLAN(1..len(mess(0,2644,1)))
Local Integer TREFTYP(1..10)
Local Integer NBDIE                                : # Nb d'axes à saisir (max 20)
Local Integer TOBLIG(1..max(GOPTCANA,20))           : # Obligatoire (O/N)
Local Integer IREF, INDREF
Local Integer TLEDTYP(1..len(mess(0,2644,1)))
Local Integer NBLEDTYP
Local Char    TCOMPTE(GLONGAC)(1..len(mess(0,2644,1))), TPLAN(GLONCOA)(1..len(mess(0,2644,1)))
Local Char    TSAC(GLONSAC)(1..len(mess(0,2644,1)))
Local Char    TDIE(GLONDIE)(1..max(GOPTCANA,20))   : # Axes (DIE)
Local Integer TOBLIG(1..max(GOPTCANA,20))          : # Axes obligatoires (O/N)
#JASMI - 2018-02-27 - X3-80414 - START
#Local Char    MATRI(GLONMAT), CTR(GLONCTR)
Local Char    MATRI(GLONEML), CTR(GLONHRCTR)
#JASMI - 2018-02-27 - X3-80414 - END
Local Date    DATMAT

Local Char WOK(250)
Local Integer WGESANA, COA1ANA, CREATE_TOD

Local Integer WRGA, NBLIG

Raz WCPY, WCPY2

For [LNK1]CLE0
Filter [HSP] Where BUL=[F:VEP]BUL & TYP<>6 : # Pas les cumuls
Filter [VAN] Where EMP=[F:VEP]EMP & PYRDAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL
# 92876
# Filter [RUB] Where NBRACC>0 & TMPCAL<>2 & TYPRUB<>5 & (DEC=0 | DEC>=GARODEV)
Filter [RUB] Where FLGCPT=2 & TMPCAL<>2 & TYPRUB<>5 & (DEC=0 | DEC>=GARODEV)

#-----------------------------------------------
# Filter on Headings
# Rub pas intermédiaire, pas Assiette,

# FQ92876-US2685- recherche des plans à traiter pour le bulletin
If WCPY<>[F:FCY]LEGCPY
# Search Accounting informations of the company of the payslip
  WCPY= [F:FCY]LEGCPY
  Call SETMAINREF(WCPY,TYPGEN,TYPANA) From CPTDIV
  Call SETREF(WCPY,NBLED,CODLED) From CPTDIV
  Call LECMAINPLAN(TYPGEN,[FCY]LEGCPY ,PLGEN) From CPTDIV
  Call LECMAINPLAN(TYPANA,[FCY]LEGCPY ,PLANA) From CPTDIV

  Call LEC_LED(CODLED(TYPGEN)) From CPTLEC
  If [F:LED]ANA=2 : [L]COA1ANA=2 : Endif : # Social Ledger is Analytical too
  Call SETGCM(WCPY,WMODELE) From CPTDIV
  Call SETPLAN2(WMODELE,NBPLAN,TPLAN,TREFTYP,NBDIE,TDIE,TOBLIG) From CPTDIV
Endif
#-------------------------------------------------------------
# Loop on line of payslip
For [HSP]HSP2
  Read [F:RUB]RUB0=[M:DIA]LEG;[F:HSP]RUB
  If !fstat
   Gosub GRP_RGA : # regroup different lines of RUBGAC - Accounts of Headings
   # ---Loop on each regrouped line -------------

   For [L]WRGA=0 To [L]NBLIG-1 :
    # Rubrique<>cotisation ou régul: Part totale = Part salariale dans HSP
    # Rubrique=cotisation ou régul. Soit le type montant de la cotisation
    # =celui de l'histo soit le type montant de la cotisation=Total(PP+PS)

#    Case [F:RUB]TYPAMT(indice) :# FQ92876-US2685-
    Case [L]TYPAMT(WRGA)
     When 1 : # Part salariale
       OK = ([F:HSP]TYP=1 or [F:HSP]TYP=7)
     When 2 : # Part patronale
       OK = ([F:HSP]TYP=2 or [F:HSP]TYP=8)
     When 3 : # Total
      If [F:RUB]TYPRUB=6 | [F:RUB]TYPRUB=2 | [F:RUB]TYPRUB=3
       OK = 1
      Else
       OK = ([F:HSP]TYP=1 or [F:HSP]TYP=7)
      Endif
    Endcase
    #   # FQ92876-US2685-Condition
    MATRI = [F:VEP]EMP
    CTR = [F:VEP]CTRNUM
    DATMAT=[F:VEP]CTRDAT
    #JOJAC - X3-11440 - 2017-02-15 - START
    #Gosub LECEMP From DEFTABLE
    Gosub LECEMP From WPDEFTABLE
    #JOJAC - X3-11440 - 2017-02-15 - END
    If OK & [L]CNDRGA(WRGA)<>""
      OK=evalue([L]CNDRGA(WRGA))
    Endif

    If OK
    Endif
    If OK
     [V]GPE=0
     GPOINT = "COMPTE" : Gosub ENTREE From EXEFNC
     If ![V]GPE  : Gosub TR2 :  Endif
     Filter [TOD]
     If GOK=0
      Filter [RUB]
      Filter [VAN]
      Filter [HSP]
      Break 3 :
     Endif
     OKOD = 1 : OKNUM = 1
    Endif
#   Next :# [F:RGA]RGA0
   Next :# [L]NBLIG - For each regrouped line ---------------
  Endif
Next :#
Filter [RUB]
Filter [VAN]
Filter [HSP]
If OKNUM=1
  [F:VEP]PST = 2
  Rewrite [VEP]
  If fstat
   GOK = 0 : Call FSTA("VEP") From GLOCK : Break
  Endif
Endif
Next :#  # line of payslip
# ----------------------------------------------------------------
If GOK=0 : Return : Endif
If OKNUM
Raz [ODE]
[F:ODE]FCY    = [F:FCY]FINRSPFCY
[F:ODE]PYRDAT = [F:VEP]PYRDAT
[F:ODE]CPY    = [F:FCY]LEGCPY
[F:ODE]ODPNUM = [L]ODPNUM
[F:ODE]PST    = 1
Write [ODE]
If fstat
  GOK = 0 : Call FSTA("ODE") From GLOCK : Return
Endif
#Création de l'od xxxxxx du jj/mm/aa Société yyy
#JOJAC - X3-11440 - 2017-02-15 - START
#Call ECR_TRACE(mess(71,703,1)-[L]ODPNUM-mess(94,100,1)-num$([F:VEP]PYRDAT)-mess(42,702,1)-[F:FCY]LEGCPY-mess(43,702,1)-[F:FCY]FINRSPFCY,0) From GESECRAN
Call ECR_TRACE(mess(71,10703,1)-[L]ODPNUM-mess(94,100,1)-num$([F:VEP]PYRDAT)-mess(42,10702,1)-[F:FCY]LEGCPY-mess(43,10702,1)-[F:FCY]FINRSPFCY,0) From GESECRAN
#JOJAC - X3-11440 - 2017-02-15 - END
Endif
Return

################################################################################
## Mise à jour du fichier des Od de paye
$TR2

[L]WGESANA=0

# FQ92876
#If [F:RUB]TYPAMT(indice)=3 &
#If [F:RGA]TYPAMT=3 &
#&  (([F:RUB]TYPRUB=6 | [F:RUB]TYPRUB=2 | [F:RUB]TYPRUB=3) & ([F:HSP]TYP=1 | [F:HSP]TYP=2 | [F:HSP]TYP=7 | [F:HSP]TYP=8))
# Filter [TOD] Where BUL=[F:VEP]BUL & CPY=[F:FCY]LEGCPY & FCY=[F:VEP]FCY & RUB=[F:HSP]RUB &
#&                   ACC=[F:RGA]ACC & COA=[F:RGA]COA & SNS=[F:RGA]SNS & IDENT=GIDENT
##&                   ACC=[F:RUB]ACC(indice) & SNS=[F:RUB]SNS(indice) & IDENT=GIDENT

# on crée un enregistrement qui contient le plan social et le plan analytique
# donc on a regroupé les différents enegistrements de RUBGAC ayant les mêmes caractéristiques

[L]CREATE_TOD = 0
#--------------------------------------------------
# Test Condition : Line TOTAL + same specifications

If [L]TYPAMT(WRGA)=3 &
&  (([F:RUB]TYPRUB=6 | [F:RUB]TYPRUB=2 | [F:RUB]TYPRUB=3) & ([F:HSP]TYP=1 | [F:HSP]TYP=2 | [F:HSP]TYP=7 | [F:HSP]TYP=8))

# ----------------------- True Condition ---------------------------
Filter [TOD] Where BUL=[F:VEP]BUL & CPY=[F:FCY]LEGCPY & FCY=[F:VEP]FCY & RUB=[F:HSP]RUB &
&                   ACC1=[L]ACC1(WRGA) & COA1=[L]COA1(WRGA) & ACC2=[L]ACC2(WRGA) & COA2=[L]COA2(WRGA) & SNS=[L]SNS(WRGA) & IDENT=GIDENT

Readlock [TOD]ODP2 First

# -------------  Existing record ----------------
If fstat=1 :    # blocked record
  GOK = 0 : GLOCK = "$ODPAY"-[F:TOD]ODPNUM-num$([F:TOD]ODPLIG)
Elsif !fstat  : # Record OK
  [F:TOD]AMT += [F:HSP]AMT
  #---------------
  Rewrite [TOD]
  #---------------
  If fstat
   GOK = 0 : Call FSTA("TOD") From GLOCK
  Endif

Else  :# ------- NO Existing record ---------------
   [L]CREATE_TOD=1

Endif : # end  - Existing or No record  ---------

Else :# ------------------ False condition ---------------------------
  [L]CREATE_TOD=1

Endif

# End Condition : Line TOTAL + same specifications
#--------------------------------------------------

If [L]CREATE_TOD=1
# ----------------- New record ------------
  Gosub WRI_TOD
  If GOK <>0 :  Gosub WRI_TOA : Endif
  If GOK <>0 :  NOL +=1 : Endif
Endif

Return


$WRI_TOD
#--------------------------------------------------
# New record
Raz [F:TOD]
#DEHEN - 2016-10-18 - JIRRA Task 2174 - START
#Entry Point
  GPOINT = "EPTMPODPAY" : Gosub ENTREE From EXEFNC
#DEHEN - 2016-10-18 - JIRRA Task 2174 - END
[F:TOD]ODPNUM = [L]ODPNUM
[F:TOD]ODPLIG = NOL+1
[F:TOD]CPY    = [F:FCY]LEGCPY
[F:TOD]FCY    = [F:VEP]FCY
[F:TOD]EMP    = [F:VEP]EMP
[F:TOD]CTRNUM = [F:VEP]CTRNUM
##**82073
[F:TOD]CTRDAT = [F:VEP]CTRDAT
[F:TOD]SRV    = [F:VEP]SRV
[F:TOD]PRF    = [F:VEP]PRF
[F:TOD]RUB    = [F:HSP]RUB
[F:TOD]PYRDAT = [F:VEP]PYRDAT
[F:TOD]BUL    = [F:VEP]BUL
# FQ92876
#[F:TOD]SNS    = [F:RUB]SNS(indice)
[F:TOD]SNS    = [L]SNS(WRGA)
# Social
[F:TOD]ACC1   = [L]ACC1(WRGA)
[F:TOD]COA1   = [L]COA1(WRGA)
[F:TOD]LED1   = CODLED(TYPGEN)
# Analytical
[F:TOD]ACC2   = [L]ACC2(WRGA)
[F:TOD]COA2   = [L]COA2(WRGA)
If [L]COA2(WRGA) = PLANA
  [F:TOD]LED2   = CODLED(TYPANA)
Endif
# end FQ92876
[F:TOD]AMT    = [F:HSP]AMT
[F:TOD]IDENT  = GIDENT

# --------------------------------------------------------------------------
#  ---------------- ACC1 : General Account ---------------------------------
# FQ92876
Read [F:GAC]GAC0=[L]COA1(WRGA);[L]ACC1(WRGA)
# ---------------- existing Account ---------------------------
If !fstat
#If vireblc([F:RUB]SAC(indice),0)<>""
    If [F:GAC]SAC=2 : # collectif
     Read [CPT]CPT0=[F:VEP]EMP
     If !fstat : [F:TOD]BPR = [F:CPT]BPR : Endif

     Filter [F:CPR] Where [F:CPR]REFNUM = [F:VEP]EMP
&                        & [F:CPR]CTRNUM = [F:VEP]CTRNUM
&                        & [F:CPR]CTRDAT <= [F:VEP]PYRDAT
     Read [F:CPR]CPR0 Last
     If fstat <= 2
         # Cas particulier - Cf DBA document de spécifications ; si les infos
       # comptables au contrat sont définies mais que le compte individuel
       # ne l'est pas, alors celui du salarié fait foi ...
       If [F:CPR]BPR <> ""
           # Compte individuel défini au contrat, on le prend en compte
           [F:TOD]BPR = [F:CPR]BPR
       Endif
   Endif
   Filter [F:CPR]

   If [F:TOD]BPR=""
    # Tiers non renseigné sur le collectif
#    Call ECR_TRACE([F:VEP]EMP-" / "-[F:HSP]RUB-" : "-mess(103,703,1)-[F:RUB]SAC(indice),0) From GESECRAN
#JOJAC - X3-11440 - 2017-02-15 - START
    #Call ECR_TRACE([F:VEP]EMP-" / "-[F:HSP]RUB-" : "-mess(103,703,1)-[F:GAC]ACC,0) From GESECRAN
    Call ECR_TRACE([F:VEP]EMP-" / "-[F:HSP]RUB-" : "-mess(103,10703,1)-[F:GAC]ACC,0) From GESECRAN
#JOJAC - X3-11440 - 2017-02-15 - END
    GOK = 0 : Return
   Endif
  Endif

  # FQ92876
  If dim([F:GAC]DESTRA)>0 Then
    Call LECTEXTRA([F:TOD]DES, "GACCOUNT","DESTRA", [F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  Elsif dim([F:GAC]DES)>0 Then
    [F:TOD]DES = [F:GAC]DES
  Endif

  If [L]COA1ANA=2 : # Social COA is also analytical
    Gosub SUIVI_ANA
    [F:TOD]DSP = [F:VEP]DSP
  Endif

# ---------------- Account doesn't exist +  Account with 'x' ------------------------
Elsif instr(1,[F:TOD]ACC1,'x') & [L]COA1ANA=2
# if Account contents x : final Account could be Analytical

  [L]WGESANA=0
  [F:TOD]DSP = [F:VEP]DSP
  CROIX = 1

# ------------ Account doesn't exist +  Account without 'x' ------------------------
Else
  [L]WGESANA=0
Endif
#  ---------------- End ACC1 : General Account -------------------------------

# -----------------------------------------------------------------------------

#  ---------------- ACC2 : Analytical Account ---------------------------------
# Social COA is not analytical and 2 COA
If [L]WGESANA=0 & NBRCOA>1

  Read [F:GAC]GAC0=[L]COA2(WRGA);[L]ACC2(WRGA)
  # ---------------- existing Account -------------
  If !fstat :#
    Gosub SUIVI_ANA
    [F:TOD]DSP = [F:VEP]DSP
  # --------- Account doesn't exist +  Account with 'x'---------
  Elsif instr(1,[F:TOD]ACC2,'x') :
  # if Account contents x : final Account could be Analytical
    [L]WGESANA=0
    [F:TOD]DSP = [F:VEP]DSP
    CROIX = 1
  # --------- Account doesn't exist +  Account without 'x' ------
  Else
    [L]WGESANA=0
  Endif
Endif
#  ---------------- End ACC2 : Analytical Account ---------------------------

[F:TOD]DETEMP = [L]DETEMP(WRGA)
[F:TOD]PST    = 1
#####################

Write [TOD]
If fstat
GOK = 0 : Call FSTA("TOD") From GLOCK : Return
Endif
#####################
#  ---------------- End ACC2 : Analytical Account --------------

Return

$WRI_TOA
# ------------------------------------------------------------------------
# --------------------- Dimension Type :  TOA ----------------------------
If GOPTCANA>0 & ([L]WGESANA=1 | CROIX=1)
# if One of the account could be analytical, take all of VALANA
Raz [F:TOA], TOTCOE, OK, CROIX
NBCOE = 0
GPOINT = "VENTILERUB" : Gosub ENTREE From EXEFNC
If GOK=0 : Return : Endif
If OK=0
  For [VAN]VAN0 : TOTCOE += [F:VAN]COE : NBCOE+=1 : Next

  For [VAN]VAN0 :# ---------------------------
   [F:TOA]ODPNUM = [F:TOD]ODPNUM
   [F:TOA]ODPLIG = [F:TOD]ODPLIG : # (NOL+1)
   [F:TOA]ODALIG = [F:VAN]LIG
   [F:TOA]EMP    = [F:TOD]EMP
   [F:TOA]PYRDAT = [F:TOD]PYRDAT
   [F:TOA]BUL    = [F:TOD]BUL
   [F:TOA]IDENT  = GIDENT
   For I=1 To GOPTCANA :
    [F:TOA]DIE(I-1) = [F:VAN]DIE(I-1)
    [F:TOA]CCE(I-1) = [F:VAN]CCE(I-1)
   Next I
   #92876
#
   ## 1 affectation analytique sans coefficient, on affecte le montant total
   ## N affectations analytiques sans coeff, on affecte 0
   ## Règle : Affectation proratisée
   If TOTCOE=0 & NBCOE=1
    [F:TOA]COE = 1
   Elsif TOTCOE=0 & NBCOE>1
    [F:TOA]COE = 0
   Elsif TOTCOE>0
    [F:TOA]COE = [F:VAN]COE/TOTCOE
   Endif
   [F:TOA]PST    = 1
   Write [TOA]
   If fstat
    GOK = 0 : Call FSTA("TOA") From GLOCK : Break
   Endif
  Next :# [VAN]VAN0 ---------------------------
  If GOK=0 : Return : Endif
Endif :# ---- OK=0 --

#La feuille de paye n'a pas d'analytique alors que le compte est géré en analytique
If NBCOE=0 & [F:VEP]DSP="" : # Pas d'imputation analytique sur la paye
#JOJAC - X3-11440 - 2017-02-15 - START
  #Call ECR_TRACE(num$([F:VEP]PYRDAT)-[F:VEP]EMP-mess(93,703,1),0) From GESECRAN
  Call ECR_TRACE(num$([F:VEP]PYRDAT)-[F:VEP]EMP-mess(93,10703,1),0) From GESECRAN
#JOJAC - X3-11440 - 2017-02-15 - END
  GOK = 0
Endif
If GOK=0 : Return : Endif
Endif :# -- If GOPTCANA>0 & ([L]WGESANA=1 | CROIX=1)
# ---------------------End  Dimension Type :  TOA ----------------------------

Return

####################################################################################################
# different records of RUBGAC are grouped with the same characteristics
$GRP_RGA
Local Integer NCOA, NBRCOA, NOLIN

If PLGEN =PLANA
NBRCOA = 1
Else
NBRCOA = 2
Endif

Local Char COA(GLONCOA)(NBRCOA)
Local Char COA1(GLONCOA)(20), COA2(GLONCOA)(20)
Local Char ACC1(GLONGAC)(20), ACC2(GLONGAC)(20)
Local Char LED1(GLONLED)(20), LED2(GLONLED)(20)
Local Char CNDRGA(250)(20)
Local Integer TYPAMT(20), SNS(20), DETEMP(20), TYPLED(20)

[L]COA(0) = PLGEN
If NBRCOA >1 : [L]COA(1) = PLANA :Endif
[L]NBLIG=0

For [L]NCOA=0 To [L]NBRCOA-1
  ##** Regroupement de comptes par ligne si même type de montant, même sens, même détail/salarié et même condition
  [L]NOLIN=0
  For [F:RGA]RGA0 Where COD=[F:RUB]COD & COA=[L]COA(NCOA)
###  For [F:RGA]RGA0 Where COD=[F:RUB]COD & COA='ZAF'

   If NCOA>0 Then
    FOUND=0
    For I=0 To [L]NBLIG-1
      If (evalue("[L]ACC"+num$(NCOA+1)+"("+num$(I)+")")=""
&     |   evalue("[L]ACC"+num$(NCOA+1)+"("+num$(I)+")")=[F:RGA]ACC )
&      & [L]TYPAMT(I)=[F:RGA]TYPAMT & [L]SNS(I)=[F:RGA]SNS
&      & [L]DETEMP(I)=[F:RGA]DETEMP & [L]CNDRGA(I)=[F:RGA]CNDRGA Then
        NOLIN=I : FOUND=1 : # line found -> we stay in this line
        Break
      Endif
    Next
    # if no line found, we add a new line at the end
    If !FOUND Then NOLIN=[L]NBLIG : Endif
   Endif
   Assign("[L]ACC"+num$(NCOA+1)+"("+num$(NOLIN)+")") With [F:RGA]ACC
   Assign("[L]COA"+num$(NCOA+1)+"("+num$(NOLIN)+")") With [F:RGA]COA
   [L]TYPAMT(NOLIN)    = [F:RGA]TYPAMT
   [L]SNS(NOLIN)       = [F:RGA]SNS
   [L]DETEMP(NOLIN)    = [F:RGA]DETEMP
   [L]CNDRGA(NOLIN)    = [F:RGA]CNDRGA
   NOLIN+=1
   [L]NBLIG = max(NOLIN,[L]NBLIG)
  Next
Next

Return
####################################

$SUIVI_ANA
# In CPTAUTO, depending on DACDIENBR & DIE.
#If [F:GAC]DSP <>""
#      [L]WGESANA=1
#Elsif [F:GAC]DACDIENBR>0 :# analytique
#Read [F:VAN]VAN0 First
#If !fstat
#  # Account has at least one DIE = one DIE of the payslip
#  If [F:GAC]DACDIENBR>0 :# Nb DIE on Account
#    For I=1 To GOPTCANA
#      If ([F:VAN]DIE(I-1) <> "") & (find([F:VAN]DIE(I-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)))
#        [L]WGESANA=1 : Break
#      Endif
#    Next
#  Endif
#Endif
Local Integer WI

# Account has at least one DIE = one DIE of the Company
  If [F:GAC]DACDIENBR>0 :# Nb DIE on Account
    For WI=1 To [L]NBDIE
      If ([L]TDIE(WI) <> "") & (find([L]TDIE(WI),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)))
        [L]WGESANA=1 : Break
      Endif
    Next
  Endif


Return
################################################################################

$TR3
Raz OLDNUM
For [TOD]TOD0 Where IDENT=GIDENT
# TMPODPAY -> ODPAY -------------
If OLDNUM<>[F:TOD]ODPNUM
  OLDNUM = [F:TOD]ODPNUM
  I = 1
Endif
[F:ODP] = [F:TOD]
# FQ92876
# In TMPODPAY, LED, COA, ACC are separated fields: ACC1, ACC2 to be used in Key
[F:ODP]LED(0)= [F:TOD]LED1
[F:ODP]COA(0)= [F:TOD]COA1
[F:ODP]ACC(0)= [F:TOD]ACC1

[F:ODP]LED(1)= [F:TOD]LED2
[F:ODP]COA(1)= [F:TOD]COA2
[F:ODP]ACC(1)= [F:TOD]ACC2
# end FQ92876
[F:ODP]ODPLIG = I
  GPOINT = "FCYODPCHARGE" : Gosub ENTREE From EXEFNC # FRLAA - 2016-07-11 - 117587
Write [ODP]
If fstat
  GOK = 0 : Call FSTA("ODP") From GLOCK : Break
Endif

# TMPODPAYA -> ODPAYA --------- Analytical  ----------
For [TOA]ODA0 Where ODPNUM=[F:TOD]ODPNUM & ODPLIG=[F:TOD]ODPLIG & IDENT=GIDENT
  [F:ODA] =  [F:TOA]
  [F:ODA]ODPLIG = I
  Write [ODA]
  If fstat
   GOK = 0 : Call FSTA("ODA") From GLOCK : Break 2
  Endif
Next : # end TMPODPAYA -> ODPAYA ----- Analytical ----------
I +=1
Next :# TMPODPAY -> ODPAY -------------

If !GOK : Return : Endif
Return

