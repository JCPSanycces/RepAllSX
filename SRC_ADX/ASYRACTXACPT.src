#<AdxTL>@(#)3.0.0.0 $Revision$
$INT_COMPTA
Local Integer ASTATUS : [L]ASTATUS=[V]CST_AOK
Local Integer RET , SERVICE
Local Char ERRMES(250)
Local Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
ACTX=cast(this.APARENT,C_WMACONTEXT)
Local Char WTABCPT(80),WMACCPT(80),WDOSCPT(80),WSOLCPT(80),WPORTCPT(80)
[L]ASTATUS=func ADS_TOOL.PARAMLINK(ACTX,ACTX.AFOLDER,2,WMACCPT,SERVICE,WDOSCPT,WSOLCPT,[L]RET,[L]ERRMES)

If !RET
 WPORTCPT = num$(SERVICE)
 If WMACCPT<>"" & WPORTCPT<>""
  WTABCPT = WMACCPT+":"+WPORTCPT+"@"+WDOSCPT+"."
 Else
  WTABCPT = WDOSCPT+"."
 Endif
 Local Integer ERRCPT
 Onerrgo ERR_DOSCPT
 Local File =WTABCPT+"ADOVAL" [A_DW]
 If !ERRCPT
  Read [A_DW]ADW0 = "";"";"RELEASE"
  If !ERRCPT & !fstat & val([F:A_DW]VALEUR)<14
   this.CPT130 = 1
  # PAYE V5 qui se déverse dans compta V140
  Elsif !ERRCPT & !fstat & val([F:A_DW]VALEUR)<25
   this.CPT140 = 1
  Endif
  Close Local File [A_DW]
 Endif
 Onerrgo
 If ERRCPT
  # Dossier comptable inaccessible
  [L]ASTATUS = fmet this.ASETERROR("",left$(WTABCPT,len(WTABCPT)-1)-":"-mess(124,125,1),[V]CST_AERROR)
 Else
  this.PORTCPT = WPORTCPT
  this.MACCPT = WMACCPT
  this.TABCPT = WTABCPT
  this.DOSCPT = WDOSCPT
  this.SOLCPT = WSOLCPT
 Endif
Endif

Local Integer RES
RES = fmet this.ASETATTRIBUTE("TABCPT","STA","1")
RES = fmet this.ASETATTRIBUTE("PORTCPT","STA","1")
RES = fmet this.ASETATTRIBUTE("MACCPT","STA","1")
RES = fmet this.ASETATTRIBUTE("DOSCPT","STA","1")
RES = fmet this.ASETATTRIBUTE("SOLCPT","STA","1")

RES = fmet this.ASETATTRIBUTE("CPT130","STA","1")
RES = fmet this.ASETATTRIBUTE("CPT140","STA","1")
Return

##############
$ERR_DOSCPT
ERRCPT = errn
Resume
