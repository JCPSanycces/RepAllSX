#<AdxTL>@(#)0.0.0.0 $Revision$
#-------------------------------------------------------------------------------------------------------------#
# maj audith pour gestion IDENT2---IDENT9
#-------------------------------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise à jour table AUDITH") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJAUDIT
End

#-------------------#
$MAJAUDIT
If filinfo(filpath("FIL","AUDITH","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS(DOSSIER,"AUDIT")
 Return
Endif

Local File =DOSSIER+".AUDITH"    [AUD]
If dim([F:AUD]NUM1)<=0
 Return
Endif

Local File =DOSSIER+".ATABLE"    [ATB]
Local File =DOSSIER+".ATABZON"   [ATZ]
Local File =DOSSIER+".ATABIND"   [ATI]
Local File =DOSSIER+".ATYPE"     [ATY]

Local Char     CHAINE(250),CLENAM(GLONAVA)(1..16)
Local Integer  J,I1,I2,CLETYP(1..16),NBCLE,UPD
Local Char     IDENT1(80),IDENT2(80),IDENT3(80),IDENT4(80),IDENT5(80),IDENT6(80),IDENT7(80),IDENT8(80),IDENT9(80)

Call ECR_TRACE(mess(81,125,1)-"AUDITH"-time$,0) From GESECRAN

Filter [AUD] Where (STABI=2) Order By Key CLE=TBL;ID1;ID2;SEQ  : # A traiter

Trbegin [AUD] 
 For [AUD]CLE(1)
  UPD = 0
  Call ECR_TRACE([F:AUD]TBL-time$,0) From GESECRAN
  Read [ATB]CODFIC = [F:AUD]TBL
  If [F:ATB]AUDCLE<>""
   Read [ATI]CODIND = [F:AUD]TBL;[F:ATB]AUDCLE
  Else
   Read [ATI]NUMLIG = [F:AUD]TBL;1
  Endif
  If !fstat
   Gosub DECPRYPT
   If NBCLE<10
    For [AUD]CLE
     If [F:AUD]NUM1>0 or [F:AUD]CHAR1<>"" : Break 1 : Endif
     [L]IDENT1 = [F:AUD]ID1 
     J = instr(1,[F:AUD]ID2,"~")
     If J>0
      [L]IDENT2 = left$([F:AUD]ID2,J-1)
      [L]IDENT3 = right$([F:AUD]ID2,J+1)
      J = instr(1,[L]IDENT3,"~")
      If J 
       [L]IDENT4 = right$([L]IDENT3,J+1)
       [L]IDENT3 = left$([L]IDENT3,J-1)
       J = instr(1,[L]IDENT4,"~")
       If J 
        [L]IDENT5 = right$([L]IDENT4,J+1)
        [L]IDENT4 = left$([L]IDENT4,J-1)
        J = instr(1,[L]IDENT5,"~")
        If J 
         [L]IDENT6 = right$([L]IDENT5,J+1)
         [L]IDENT5 = left$([L]IDENT5,J-1)
         J = instr(1,[L]IDENT5,"~")
         If J     
          [L]IDENT7 = right$([L]IDENT6,J+1) 
          [L]IDENT6 = left$([L]IDENT6,J-1)
          J = instr(1,[L]IDENT7,"~")
          If J 
           [L]IDENT8 = right$([L]IDENT7,J+1)
           [L]IDENT7 = left$([L]IDENT7,J-1)
           J = instr(1,[L]IDENT8,"~")
           If J 
            [L]IDENT9 = right$([L]IDENT8,J+1)
            [L]IDENT8 = left$([L]IDENT8,J-1)
           Endif
          Endif
         Endif
        Endif
       Endif
      Endif
     Endif
     For I=1 To NBCLE
      If CLETYP(I)<7
       Assign "[F:AUD]NUM"+num$(I) With evalue("val([L]IDENT"+num$(I)+")")
      Else
       Assign "[F:AUD]CHAR"+num$(I) With evalue("[L]IDENT"+num$(I))
      Endif
     Next   
     UPD += 1   
     Rewrite [F:AUD]
     If fstat
      Call ERREUR("AUDITH"-num$([F:AUD]SEQ),1) From DOSDIC
     Endif
    Next
    Call ECR_TRACE([F:AUD]TBL-"("-num$(UPD)-")"-time$,0) From GESECRAN
   Endif
  Endif
 Next
Commit

Close Local File [AUD],[ATB],[ATZ],[ATI],[ATY]

Return

$DECPRYPT
CHAINE = [F:ATI]DESCRIPT
NBCLE = 0
While CHAINE<>""
 NBCLE += 1
 I1 = instr(1,CHAINE,"+")
 I2 = instr(1,CHAINE,"-")
 If    I1 & I2  : I1 = min(I1,I2)
 Elsif I2 & !I1 : I1 = I2
 Endif
 If I1
  CLENAM(NBCLE) = left$(CHAINE,I1-1)
  CHAINE        = right$(CHAINE,I1+1)
 Else
  CLENAM(NBCLE) = CHAINE
  CHAINE        = ""
 Endif
 Read [ATZ]CODZONE = [F:AUD]TBL;CLENAM(NBCLE)
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 CLETYP(NBCLE) = [F:ATY]TYPTYP
Wend
Return
