#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque PHX5
##########################################################################################################
Subprog B1_MANBRD(VALEUR)
Variable Decimal VALEUR()

Local Integer IV
Local Integer INOL
Local Decimal IPRORATA
Local Decimal ITOTPRORATA
Local Integer ISOLDE
ISOLDE = 0
IV = 0
IPRORATA = 0
ITOTPRORATA = 0
INOL = nolign - 1

#Si il n'y a pas de téléacteurs. On ne fait rien.
If [M:PHX5]NBVEN = 0 : End : Endif

If [M:PHX5]NBQREP = 0
    IPRORATA = 0
Else
    IPRORATA = 100 / [M:PHX5]NBQREP
Endif

If fix(IPRORATA) = 0
    IPRORATA = 1
Endif

For IV = 0 To [M:PHX5]NBVEN - 1
    If ITOTPRORATA >= 100
        IPRORATA = 0
    Endif
    If IV = INOL
        VALEUR = fix(IPRORATA)
    Else
        [M:PHX5]MANBRD(IV) = fix(IPRORATA)
    Endif
    ITOTPRORATA = ITOTPRORATA + fix(IPRORATA)
Next

If ITOTPRORATA <> 100
    If ITOTPRORATA < 100
        #Redistribue le solde sur les autres téléacteurs.
        ISOLDE = 100 - ITOTPRORATA
        IV = 0
        If fix(ISOLDE / NBVEN) = 0
            IPRORATA = 1
        Else
            IPRORATA = fix(ISOLDE / NBVEN)
        Endif
        For IV = 0 To fix(ISOLDE)
            If ITOTPRORATA >= 100 : Break : Endif
            If IV = INOL
                VALEUR = VALEUR + IPRORATA
            Else
                [M:PHX5]MANBRD(IV) = [M:PHX5]MANBRD(IV) + IPRORATA
            Endif
            ITOTPRORATA = ITOTPRORATA + IPRORATA
        Next
    Endif
Endif

GIVENAUTO = 0
[M:PHX5]MANBRD(nolign - 1) = VALEUR
Affzo [M:PHX5]1-99
End

##########################################################################################################
Subprog AM_MANBRD(VALEUR)
Variable Decimal VALEUR

Local Integer IR
Local Integer ITOTPRC
Local Integer INOL
ITOTPRC = 0
IR = 0
INOL = nolign - 1

If VALEUR > 100
    VALEUR = 0
    [M:PHX5]MANBRD(nolign - 1) = VALEUR
    Affzo [M:PHX5]MANBRD(nolign - 1)
    End
Endif

For IR = 0 To [M:PHX5]NBVEN - 1
    If IR = INOL
        ITOTPRC = ITOTPRC + VALEUR
    Else
        ITOTPRC = ITOTPRC + [M:PHX5]MANBRD(IR)
    Endif
Next

If ITOTPRC > 100
    VALEUR = VALEUR - (ITOTPRC - 100)
Endif

GIVENAUTO = 0
[M:PHX5]MANBRD(nolign - 1) = VALEUR
Affzo [M:PHX5]MANBRD(nolign - 1)
End

##########################################################################################################
Subprog AM_REPOBJCLL(VALEUR)
Variable Decimal VALEUR

Raz [M:PHX5]NBVEN
Raz [M:PHX5]REP
Raz [M:PHX5]CLLOBJ
Raz [M:PHX5]CLLDEL
Raz [M:PHX5]DAYCLLASS
Raz [M:PHX5]ASSCLL
Raz [M:PHX5]OPGEND
Raz [M:PHX5]REPNUM
#Raz [M:PHX5]MANBRD

[M:PHX5]REPOBJCLL = VALEUR

#Remplit le tableau des téléacteurs.
If GIALL = 2
    Gosub LOADTELE From TRTPHX5
Endif

If GIALL = 1
    Gosub LOADALL From TRTPHX5
Endif

If GIALL = 0
    Gosub LOADREP From TRTPHX5
Endif

Affzo [M:PHX5]1-99
End

