#<AdxTL>@(#)9.0.0.0 $Revision$
# OPTLIBA                                              V130 LLC 22/03/01
#
###########################################################################
# Routines diverses pour mise à jour des résultats de l'optimisation      #
###########################################################################
# Subprog OPTRES                                                          #
# Subprog FREEMFG                                                         #
###########################################################################

Local Mask OPTK [OPTK]
[M:OPTK]SEPCHR = ";"
[M:OPTK]REP = filpath("!","","","","","#")+"\temp\"
[M:OPTK]TRACE2 = 2
Call OPTRES
End

###########################################################################
Subprog OPTRES
Local Char     OPTRES(200)
Local Integer  NBOPMX   : NBOPMX=100
Local Integer  NBJCAL   : NBJCAL=1000
Local Char     WRESULT(250)(31)
Local Char     MFGNUMTRT
Local Integer  NBOP
Local Date     WSTRDAT
Local Date     WENDDAT
Local Decimal  WCOELAB
Local Date     WMFGSTR, WMFGEND, WRETDAT
Local Integer  WSCDLTI
Local Decimal  WEXTHOU
Local Char     WTAB
Local Char     WCLE
Local Char     WMESS(85)
Local Char     WMESS1(85)
Local Decimal  WCRGAV, WCRGAP
Local Integer  WSUB, WERR
Local Decimal  WCOEFF, MCOEFF
Local Integer  WNEWWST, TROUVE

# description fichier résultat "results.csv"
Local Char     WMFGNUM(GLONVCR)(NBOPMX)       # numéro OF
Local Integer  WOPENUM(NBOPMX)                # numéro opération
Local Integer  WOPESPLNUM(NBOPMX)             # numéro fraction opération
Local Char     WOPEWST(30)(NBOPMX)            # poste de charge
Local Char     WOPELAB(30)(NBOPMX)            # poste M/O
Local Decimal  WOPELABCOE(NBOPMX)             # coefficient opératoire MO
Local Decimal  WPRPTIM(NBOPMX)                # temps de préparation
Local Decimal  WSETTIM(NBOPMX)                # temps total fab
Local Decimal  WEXTTIM(NBOPMX)                # temps total fab
Local Decimal  WPSTTIM(NBOPMX)                # temps post-opératoire
Local Decimal  WSCOLTI(NBOPMX)                # délai sous-traitance                      11.06 35988
Local Integer  WWSTNBR(NBOPMX)                # nombre de postes MA
Local Integer  WLABNBR(NBOPMX)                # nombre de postes MO
Local Date     WOBJDAT(NBOPMX)                # début objectif initial
Local Date     WOPESTR(NBOPMX)                # début opération au plus tôt
Local Date     WFRCSTRDAT(NBOPMX)             # début forcé date
Local Decimal  WFRCSTRFRD(NBOPMX)             # début forcé fraction
Local Date     WOPEFITSTD(NBOPMX)             # début préparation date
Local Decimal  WOPEFITSTF(NBOPMX)             # début préparation fraction
Local Date     WFITCAPSTR(NBOPMX)             # début fabrication date
Local Decimal  WFITCAPSTF(NBOPMX)             # début fabrication fraction
Local Date     WFITCAPEND(NBOPMX)             # début post-opératoire date
Local Decimal  WFITCAPENF(NBOPMX)             # début post-opératoire fraction
Local Date     WFITOPEEND(NBOPMX)             # fin opération date
Local Decimal  WFITOPEENF(NBOPMX)             # fin opération fraction
Local Decimal  WFITPRPDUR(NBOPMX)             # durée préparation
Local Decimal  WFITWORDUR(NBOPMX)             # durée opératoire
Local Decimal  WFITPSTDUR(NBOPMX)             # durée post-opératoire
Local Decimal  WFITDELAY (NBOPMX)             # avance/retard
Local Integer  WMFGPIO   (NBOPMX)             # priorité OF
Local Date     WEXTDAT   (NBOPMX)             # date traitement

# données d'enrichissement
Local Char     WMFGFCY(GLONFCY)(NBOPMX)
Local Integer  WMFGSTA         (NBOPMX)
Local Integer  WOPESTA         (NBOPMX)
Local Char     WWCR   (GLONWCR)(NBOPMX)
Local Char     WWST   (GLONWST)(NBOPMX)
Local Char     WWCRLAB(GLONWCR)(NBOPMX)
Local Char     WLAB   (GLONWST)(NBOPMX)
Local Integer  WWSTTYP         (NBOPMX)
Local Integer  WOPEWSTTYP      (NBOPMX)
Local Decimal  WOPTTIM  (NBOPMX)
Local Decimal  WSETLABR (NBOPMX)
Local Decimal  WOPELABR (NBOPMX)
Local Date     WINFSTRD (NBOPMX)
Local Decimal  WINFSTRF (NBOPMX)
Local Date     WSETENDD (NBOPMX)
Local Decimal  WSETENDF (NBOPMX)
Local Date     WINFENDD (NBOPMX)
Local Decimal  WINFENDF (NBOPMX)
Local Char     WSCHSBB  (15) (NBOPMX)
Local Char     XCRITERE(250)

Local Char     WCAL(3)(NBOPMX)
Local Date     WDATD(NBOPMX)
Local Date     WDATF(NBOPMX)
Local Integer  WCOR(NBOPMX)
Local Decimal  WCAP(NBJCAL)
Local Integer  WNBRD (NBJCAL)
Local Integer  WRET, I, WPREC, OPTIM, WNBR
Local Integer  WCODORI
Local Integer  SAVIUM : SAVIUM = adxium

Local Integer  WHDEB,WHFIN, WHWRK

Call TEMPON(mess(105,190 ,1)) From GESECRAN

If clalev([F:TWD])  = 0 : Local File TABWEEDIA  [TWD]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING [SCH]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD    [MFG]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT     [MFM]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS [OPS]  : Endif
If clalev([F:WKL])  = 0 : Local File WORKLOAD   [WKL]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM     [MFI]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE     [MFO]  : Endif
If clalev([F:ORD])  = 0 : Local File ORDERS     [ORD]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER  [ITM]  : Endif

If clalev([M:OPSK]) = 0 : Local Mask OPSK       [OPSK] : Endif
If clalev([M:ORDK]) = 0 : Local Mask ORDK       [ORDK] : Endif

If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:TUV])  = 0 : Local File TABUNAVAIL [TUV]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR     [CPV]  : Endif
If clalev([F:STA])  = 0 : Local File STOALL     [STA] : Endif

# lecture site
Call LECTURE ("FCY", [M:OPTK]MFGFCY, "") From CONTOBJ

If clalev([F:PJA])  = 0 : Local File PARJAL     [PJA]  : Endif

If [F:PJA]MFGFCY <> [M:OPTK]MFGFCY
    Read [PJA]PJA0 = [M:OPTK]MFGFCY
    If fstat : Raz [PJA] : Endif
Endif

If [F:PJA]AUTWIPSCD = 2 : XCRITERE = "1=1" Else : XCRITERE = "MATSTA=1" : Endif

adxifs = [M:OPTK]SEPCHR
adxirs = chr$(10)

# transfert fichiers résultats du client vers le serveur
If !(GBROWS=1 & GFUSION=1) : # GH 24/11/2014 dm 103835
   Call CSV2ILFIL([M:OPTK]MFGFCY,"ilres","v6_results") From OPTLIB
#Else
   # déjà fait dans ILOGLIB
Endif

Raz WERR
Onerrgo ERR_LEC
OPTRES = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ilres",0)
Openi OPTRES Using [RESO]
Onerrgo
If WERR : Call TEMPOFF From GESECRAN : End : Endif

# ouverture trace
If [M:OPTK]TRACE2 = 2
    Call OUVRE_TRACE(mess(177,195,1)) From LECFIC
    WHDEB = time
Endif
NBOP = 0
Gosub NEXT_RES

While fstat = 0
    If MFGNUMTRT = "" : MFGNUMTRT = WRESULT(0) : Endif
    # si rupture sur numéro OF, mise à jour
    If WRESULT(0) <> MFGNUMTRT
        Gosub MAJRES
        Gosub RAZ_MFG : #VPO 07/09/09 57622 manque raz
        NBOP = 0
        MFGNUMTRT = WRESULT(0)
    Endif
    # llc 11.02 7550
    # transcodage
    WMFGNUM(NBOP)        = WRESULT(0)
    WOPENUM(NBOP)        = val(WRESULT(1))
    WOPESPLNUM(NBOP)     = val(WRESULT(2))
    WOPEWST(NBOP)        = WRESULT(3)

    # 03.06 distinction
    If (len(WOPEWST(NBOP)) > GLONWST)
        WSCHSBB(NBOP) = right$(WOPEWST(NBOP),15)
        WSCHSBB(NBOP) = vireblc(WSCHSBB(NBOP),1)
        WOPEWST(NBOP) = left$(WOPEWST(NBOP),GLONWST)
        WOPEWST(NBOP) = vireblc(WOPEWST(NBOP),1)
    Else
        WSCHSBB(NBOP) = ""
    Endif

    WOPELAB(NBOP)        = WRESULT(4)
    WOPELABCOE(NBOP)     = val(WRESULT(5))
    WPRPTIM(NBOP)        = val(WRESULT(6))
    WSETTIM(NBOP)        = val(WRESULT(7))
    WEXTTIM(NBOP)        = val(WRESULT(8))
    WPSTTIM(NBOP)        = val(WRESULT(9))
    WSCOLTI(NBOP)        = val(WRESULT(10))              # 11.06 35988
    WWSTNBR(NBOP)        = val(WRESULT(11))
    WLABNBR(NBOP)        = val(WRESULT(12))
    WOBJDAT(NBOP)        = WRESULT(13)
# date début opération au plus tôt : inutilisé pour le moment ...
#   WOPESTR(NBOP)        = WRESULT(14)
    If WRESULT(15) <> ""
        WFRCSTRDAT(NBOP)     = WRESULT(15)
        WFRCSTRFRD(NBOP)     = val(WRESULT(16))
    Else
        WFRCSTRDAT(NBOP)     = [0/0/0]
        WFRCSTRFRD(NBOP)     = 0
    Endif
    WOPEFITSTD(NBOP)     = WRESULT(17)
    WOPEFITSTF(NBOP)     = val(WRESULT(18))
    WFITCAPSTR(NBOP)     = WRESULT(19)
    WFITCAPSTF(NBOP)     = val(WRESULT(20))
    WFITCAPEND(NBOP)     = WRESULT(21)
    WFITCAPENF(NBOP)     = val(WRESULT(22))
    WFITOPEEND(NBOP)     = WRESULT(23)
    WFITOPEENF(NBOP)     = val(WRESULT(24))
    # 03.06 35766
    If WOPEFITSTF(NBOP) = 1
        WOPEFITSTD(NBOP) += 1
        WOPEFITSTF(NBOP)  = 0
    Endif
    If WFITCAPSTF(NBOP) = 1
        WFITCAPSTR(NBOP) += 1
        WFITCAPSTF(NBOP)  = 0
    Endif
    If WFITCAPENF(NBOP) = 0
        WFITCAPEND(NBOP) -= 1
        WFITCAPENF(NBOP)  = 1 : # WFITCAPSTF(NBOP)  = 1 : # GH 30/11/12 bug 86304
    Endif
    If WFITOPEENF(NBOP) = 0
        WFITOPEEND(NBOP) -= 1
        WFITOPEENF(NBOP)  = 1 : # WFITOPESTF(NBOP)  = 1 : # GH 30/11/12 bug 86304
    Endif

    WFITPRPDUR(NBOP)     = val(WRESULT(25))
    WFITWORDUR(NBOP)     = val(WRESULT(26))
    WFITPSTDUR(NBOP)     = val(WRESULT(27))
    WFITDELAY(NBOP)      = val(WRESULT(28))
    WMFGPIO(NBOP)        = val(WRESULT(29))
    WEXTDAT(NBOP)        = WRESULT(30)
    NBOP += 1
    Gosub NEXT_RES
Wend
Gosub MAJRES

Openi

Call TEMPOFF From GESECRAN

# fermeture trace
If [M:OPTK]TRACE2 = 2
    WHFIN = time
    WHWRK = WHFIN-WHDEB
    J = mod(WHWRK,60)
    K = WHWRK/60
    K = int(K)
    WMESS=mess(107,190,1)+":"-num$(K)-mess(2,301,1)-num$(J)
    Call ECR_TRACE(WMESS,0) From GESECRAN
    Call FERME_TRACE From LECFIC
    # lecture trace
    Call LEC_TRACE From LECFIC
Endif

adxium = SAVIUM
End

###########################################################################
$NEXT_RES
Rdseq WRESULT(0), WRESULT(1), WRESULT(2), WRESULT(3), WRESULT(4), WRESULT(5), WRESULT(6),
&     WRESULT(7), WRESULT(8), WRESULT(9), WRESULT(10), WRESULT(11), WRESULT(12), WRESULT(13),
&     WRESULT(14), WRESULT(15), WRESULT(16), WRESULT(17), WRESULT(18), WRESULT(19), WRESULT(20),
&     WRESULT(21), WRESULT(22), WRESULT(23), WRESULT(24), WRESULT(25), WRESULT(26), WRESULT(27), WRESULT(28), WRESULT(29), WRESULT(30)
&     Using [RESO]
Return

###########################################################################
$ERR_LEC
    Infbox mess(149,193,1)
    WERR = 1
Resume

###########################################################################
$RAZ_MFG
Raz  WMFGNUM :        # numéro OF
Raz  WOPENUM :                 # numéro opération
Raz  WOPESPLNUM :              # numéro fraction opération
Raz  WOPEWST :             # poste de charge
Raz  WOPELAB :             # poste M/O
Raz  WOPELABCOE :              # coefficient opératoire MO
Raz  WPRPTIM :                 # temps de préparation
Raz  WSETTIM :                 # temps total fab
Raz  WEXTTIM :                 # temps total fab
Raz  WPSTTIM :                 # temps post-opératoire
Raz  WSCOLTI :                 # délai sous-traitance                      11.06 35988
Raz  WWSTNBR :                 # nombre de postes MA
Raz  WLABNBR :                 # nombre de postes MO
Raz  WOBJDAT :                 # début objectif initial
Raz  WOPESTR :                 # début opération au plus tôt
Raz  WFRCSTRDAT :              # début forcé date
Raz  WFRCSTRFRD :              # début forcé fraction
Raz  WOPEFITSTD :              # début préparation date
Raz  WOPEFITSTF :              # début préparation fraction
Raz  WFITCAPSTR :              # début fabrication date
Raz  WFITCAPSTF :              # début fabrication fraction
Raz  WFITCAPEND :              # début post-opératoire date
Raz  WFITCAPENF :              # début post-opératoire fraction
Raz  WFITOPEEND :              # fin opération date
Raz  WFITOPEENF :              # fin opération fraction
Raz  WFITPRPDUR :              # durée préparation
Raz  WFITWORDUR :              # durée opératoire
Raz  WFITPSTDUR :              # durée post-opératoire
Raz  WFITDELAY  :              # avance/retard
Raz  WMFGPIO    :              # priorité OF
Raz  WEXTDAT    :              # date traitement

# données d'enrichissement
Raz WMFGFCY :
Raz WMFGSTA :
Raz WOPESTA :
Raz WWCR    :
Raz WWST    :
Raz WWCRLAB :
Raz WLAB    :
Raz WWSTTYP          :
Raz WOPEWSTTYP       :
Raz WOPTTIM   :
Raz WSETLABR  :
Raz WOPELABR  :
Raz WINFSTRD  :
Raz WINFSTRF  :
Raz WSETENDD  :
Raz WSETENDF  :
Raz WINFENDD  :
Raz WINFENDF  :
Raz WSCHSBB    :

Raz WCAL :
Raz WDATD :
Raz WDATF :
Raz WCOR :
Return
###########################################################################
$MAJRES

Call DEBTRANS From GLOCK
Trbegin ADOVAL

# réinitialisation dates
WMFGSTR = [0/0/0]
WMFGEND = [0/0/0]

Raz WMESS, WMESS1

# Phase 1 : balayage des opérations et déchargement/rechargement Workload
For I = 0 To NBOP - 1
    # lecture encours charge pour récupérer le statut
    Read [OPS]OPS1=WMFGNUM(0);WOPENUM(0);WOPESPLNUM(0)
    If fstat : WTAB="OPS" : WCLE=WMFGNUM(0)-num$(WOPENUM(0))-num$(WOPESPLNUM(0)) : Goto AB_RES :  Endif

    WMFGSTA(I) = [F:OPS]OPSSTA
    WMFGFCY(I) = [F:OPS]MFGFCY
    WOPESTA(I) = [F:OPS]OPESTA

    If find(WMFGSTA(0),1,2)
        # test OF marqué "à l'étude"
        Read [MFG]MFG0 = WMFGNUM(0)
        If fstat : WTAB="MFG" : WCLE=WMFGNUM(0) : Goto AB_RES : Endif

        If [F:MFG]SCDFLG = 4 : OPTIM = 2 : Else : OPTIM = 0 : Endif

        If [F:MFG]OPTFLG <> 2
            WMESS   = mess(156,197,1)-WMFGNUM(0)
            WMESS1  = mess(124,193,1)
            If [M:OPTK]TRACE2 = 2
                Call ECR_TRACE(WMESS,0) From GESECRAN
                Call ECR_TRACE(WMESS1,1) From GESECRAN
            Endif
            GOK = 0
            Goto FINMAJ
        Endif
    Else
        # recherche si optimisé
        For [ORD] Where WIPTYP = 5 & WIPNUM = WMFGNUM(0)
            If [F:ORD]OPTFLG = 2 : OPTIM = 2 : Else : OPTIM = 0 : Endif
            If [F:ORD]ORI = 5
                WCODORI = 3
            Else
                WCODORI = 2
            Endif
            Break
        Next
    Endif
    Gosub MAJLOAD
    If GOK <> 1 : Goto FINMAJ : Endif
    #      convertit en mn si nécessaire
    If WWSTTYP(I) <> 3 & [F:OPS]TIMUOMCOD = 2
        WEXTTIM(I) *= 60
        WEXTTIM(I) = arr(WEXTTIM(I),1)
        WSETTIM(I) *= 60
        WSETTIM(I) = arr(WSETTIM(I),1)
    Endif

Next I
# Phase 2 : mise à jour des données OF
Case WMFGSTA(0)
    When 1,2:    Gosub MAJOF
    When 3:      Gosub MAJOFS
Endcase

$FINMAJ
If GOK : Goto END_RES : Else : Goto END_ROLL : Endif
Return

#########################################################################
# mise à jour Workload
$MAJLOAD

# mémorisation date la + petite et date la + grande pour borner l'OF
If WMFGSTR = [0/0/0] : WMFGSTR = WOPEFITSTD(I) : Endif
If WMFGEND = [0/0/0] : WMFGEND = WFITOPEEND(I) : Endif
If WOPEFITSTD(I) < WMFGSTR : WMFGSTR = WOPEFITSTD(I) : Endif
If WFITOPEEND(I) > WMFGEND : WMFGEND = WFITOPEEND(I) : Endif

# lecture scheduling
Read [SCH]SCH0=WMFGNUM(I);WOPENUM(I);WOPESPLNUM(I)
If fstat : WTAB="SCH" : WCLE=WMFGNUM(I)-num$(WOPENUM(I))-num$(WOPESPLNUM(I)) : Goto AB_RES : Endif

Case OPTIM
    When 0:     WWST(I)       = [F:SCH]CLCWST
                WLAB(I)       = [F:SCH]CLCLAB
                WOPTTIM(I)    = [F:SCH]CLCEXTTIM
                WSETLABR(I)   = [F:SCH]SETLABCOE
                WOPELABR(I)   = [F:SCH]OPELABCOE
                WINFSTRD(I)   = [F:SCH]INFCAPSTR
                WINFSTRF(I)   = [F:SCH]INFCAPSTF
                WSETENDD(I)   = [F:SCH]SETENDDAT
                WSETENDF(I)   = [F:SCH]SETENDFRD
                WINFENDD(I)   = [F:SCH]INFCAPEND
                WINFENDF(I)   = [F:SCH]INFCAPENF
    When 2:     WWST(I)       = [F:SCH]CLCWST
                WLAB(I)       = [F:SCH]CLCLAB
                WOPTTIM(I)    = [F:SCH]CLCEXTTIM
                WSETLABR(I)   = [F:SCH]SETLABCOE
                WOPELABR(I)   = [F:SCH]OPELABCOE
                WINFSTRD(I)   = [F:SCH]FITCAPSTR
                WINFSTRF(I)   = [F:SCH]FITCAPSTF
                WINFENDD(I)   = [F:SCH]FITCAPEND
                WINFENDF(I)   = [F:SCH]FITCAPENF
Endcase

#------------------------------------------------------------------------
# Déchargement Workload
#------------------------------------------------------------------------
If WWST(I) = WOPEWST(I) | WMFGSTA(I) = 3
    Read [MWS]WST0=WWST(I);WMFGFCY
    If fstat : WTAB="MWS" : WCLE=WWST(I): Goto AB_RES : Endif
    WWCR(I)    = [F:MWS]WCR
    WWSTTYP(I) = [F:MWS]WSTTYP
    WCOR(I)    = 2
Else
    Readlock [MWS]WST0=WWST(I);WMFGFCY
    If fstat
        WTAB="MWS"
        WCLE=WWST(I)
        Goto AB_RES
    Endif
    WWCR(I)    = [F:MWS]WCR
    WWSTTYP(I) = [F:MWS]WSTTYP
    WCOR(I)    = 2
    Case [F:OPS]TIMUOMCOD
        When 1: WEXTHOU = [F:OPS]EXTOPETIM
        When 2: WEXTHOU = [F:OPS]EXTOPETIM / 60
    Endcase
    [F:MWS]EXTHOUTIM -= func TRTX3.ARRTYP("", "", "TIH", WEXTHOU)
    Rewrite [MWS]
    Unlock [MWS]
Endif

If WWSTTYP(I) <> 3
    If WOPTTIM <= 0 : WNX = 1 : Return : Endif
    WSTRDAT = WINFSTRD(I)
    WENDDAT = WINFENDD(I) + 1

    Call LOACAPN(WSTRDAT,WENDDAT,WCAP,WNBRD,WRET) From JALLIBB

#   dechargement WORKLOAD
    WCOELAB = 1
    WRET    = 0
    WNBR    = WWSTNBR(I)

    # --------- Initialisation pour PE WORKLOAD 10.06
    If dim(GCAPACITY) > 0
        GWKLACT = "U"
        GWKLMFG = WMFGNUM(I)
        GWKLOPE = WOPENUM(I)
        GWKLSPL = WOPESPLNUM(I)
    Endif

    Call WSTUNLD(WMFGFCY(I),WWST(I),WMFGSTA(I),WCODORI,WCAL(I),WCAP,WINFSTRD(I),WINFSTRF(I),
&                WINFENDD(I),WINFENDF(I),WNBRD,WNBR,WCOELAB,0,WNBR,WRET)
&              From JALLIBB
    If WRET > 0 : Goto AB_RES : Endif

#   dechargement WORKLOAD main d'oeuvre
    If WLAB(I) <> ""
        Read [MWS]WST0=WLAB(I);WMFGFCY
        If fstat : WTAB="MWS" : WCLE=WLAB(I) : Goto AB_RES : Endif
        WWCRLAB(I) = [F:MWS]WCR
        If !OPTIM
            WCOELAB = [F:SCH]SETLABCOE
        Else
            WCOELAB = ([F:SCH]SETLABCOE + [F:SCH]OPELABCOE) / 2
        Endif
        WNBR = WLABNBR(I)
        WRET = 0
       Call WSTUNLD(WMFGFCY(I),WLAB(I),WMFGSTA(I),WCODORI,WCAL(I),WCAP,WINFSTRD(I),WINFSTRF(I),
&                    WSETENDD(I),WSETENDF(I),WNBRD,WNBR,WCOELAB,1,WWSTNBR(I),WRET)
&                 From JALLIBB
        If WRET > 0 : WTAB="WKL" : WCLE=WLAB(I) : Goto AB_RES : Endif

        If !OPTIM
            WCOELAB = [F:SCH]OPELABCOE
            WNBR    = WLABNBR(I)
            WRET = 0
            Call WSTUNLD(WMFGFCY(I),WLAB(I),WMFGSTA(I),WCODORI,WCAL(I),WCAP,WSETENDD(I),WSETENDF(I),
&                        WINFENDD(I),WINFENDF(I),WNBRD,WNBR,WCOELAB,1,WWSTNBR(I),WRET)
&                    From JALLIBB
            If WRET > 0 : WTAB="WKL" : WCLE=WLAB(I) : Goto AB_RES : Endif
        Endif
    Endif
Endif

#------------------------------------------------------------------------
# Chargement Workload
#------------------------------------------------------------------------
# lecture poste après si différent
If WOPEWST(I) <> WWST(I)
    If WMFGSTA(I) = 3
        Read [MWS]WST0=WWST(I);WMFGFCY
        If fstat : WTAB="MWS" : WCLE=WWST(I): Goto AB_RES : Endif
        WWCR(I)    = [F:MWS]WCR
        WOPEWSTTYP(I) = [F:MWS]WSTTYP
        WCOR(I)    = 2
    Else
        Readlock [MWS]WST0=WOPEWST(I);WMFGFCY
        If fstat
            WTAB="MWS"
            WCLE=WOPEWST(I)
            Goto AB_RES
        Endif
        WWCR(I)    = [F:MWS]WCR
        WOPEWSTTYP(I) = [F:MWS]WSTTYP
        WCOR(I)    = 2
        Case [F:OPS]TIMUOMCOD
            When 1: WEXTHOU = [F:OPS]EXTOPETIM
            When 2: WEXTHOU = [F:OPS]EXTOPETIM / 60
        Endcase
        [F:MWS]EXTHOUTIM += func TRTX3.ARRTYP("", "", "TIH", WEXTHOU)
        Rewrite [MWS]
        Unlock [MWS]
    Endif
Else
    WOPEWSTTYP(I) = WWSTTYP(I)
Endif

If WOPEWSTTYP(I) <> 3
#   chargement WORKLOAD avec résultats capacité finie
    WSTRDAT = WFITCAPSTR(I)
    WENDDAT = WFITCAPEND(I) + 10
    Call LOACAPN(WSTRDAT,WENDDAT,WCAP,WNBRD,WRET) From JALLIBB
#   chargement WORKLOAD
    WCOELAB = 1
    WNBR    = WWSTNBR(I)
    WRET    = 0

    # --------- Initialisation pour PE WORKLOAD 10.06
    If dim(GCAPACITY) > 0
        GWKLACT = "L"
        GWKLMFG = WMFGNUM(I)
        GWKLOPE = WOPENUM(I)
        GWKLSPL = WOPESPLNUM(I)
    Endif

    Call WSTLOAD(WMFGFCY(I),WWCR(I),WOPEWST(I),WMFGSTA(I),WCODORI,WCAL(I),WCAP,
&                WFITCAPSTR(I),WFITCAPSTF(I),WFITCAPEND(I),WFITCAPENF(I),WNBRD,WNBR,WCOELAB,0,WNBR,WRET)
&            From JALLIBB

    If WRET > 0 : WTAB="WKL" : WCLE=WOPEWST(I) : Goto ROLL_RES : Endif

#   traitement main d'oeuvre
#   lecture poste main d'oeuvre
#   pas de distinction entre coeff MA/MO sur réglage et opératoire pour le moment
    If WOPELAB(I) <> ""
        Read [MWS]WST0=WOPELAB(I);WMFGFCY
        If fstat
             WTAB="MWS"
             WCLE=WOPELAB(I)
             Goto AB_RES
        Endif
        WWCRLAB(I) = [F:MWS]WCR
#       chargement WORKLOAD main d'oeuvre
        WCOELAB = WOPELABCOE(I)
        WNBR    = WLABNBR(I)
        WRET    = 0
        Call WSTLOAD(WMFGFCY(I),WWCRLAB(I),WOPELAB(I),WMFGSTA(I),WCODORI,WCAL(I),WCAP,
&                    WFITCAPSTR(I),WFITCAPSTF(I),WFITCAPEND(I),WFITCAPENF(I),WNBRD,WNBR,WCOELAB,1,WWSTNBR(I),WRET)
&                From JALLIBB
        If WRET > 0 : WTAB="WKL" : WCLE=WOPELAB(I) : Goto ROLL_RES : Endif
    Endif
Endif

Return

#########################################################################
# mise à jour OF planifié ou ferme
$MAJOF
I = 0
WPREC = 0
WSCDLTI = WMFGEND - WMFGSTR

#   en-tête
Readlock [MFG]MFG0=WMFGNUM(I)
If fstat
    WTAB="MFG"
    WCLE=WMFGNUM(I)
    Goto AB_RES
Endif

[F:MFG]OBJDAT    = WOBJDAT(0)
[F:MFG]STRDAT    = WMFGSTR
[F:MFG]ENDDAT    = WMFGEND
[F:MFG]FITCAPSTR = WMFGSTR
[F:MFG]FITCAPEND = WMFGEND
[F:MFG]CLCSCDLTI = WSCDLTI
[F:MFG]SCDFLG    = 4
[F:MFG]OPTFLG    = 1
[F:MFG]OPTUSR    = ""
[F:MFG]MFGPIO    = WMFGPIO(I)
[F:MFG]UPDDAT    = date$
[F:MFG]UPDUSR    = GUSER
Rewrite [MFG]
Unlock [MFG]


#   chargement résultats opération
$MAJSCH

# Issue 96850 GA 07/2014 except when Preactor interface - see PITMFGRES
If [M:OPTK]TRTMOD<>4
  # 05.2011
  If (WFITCAPEND(I) < WFITCAPSTR(I)) | ((WFITCAPEND(I) = WFITCAPSTR(I)) & (WFITCAPENF(I) < WFITCAPSTF(I)))
      WFITCAPEND(I) = WFITCAPSTR(I)
      WFITCAPENF(I) = WFITCAPSTF(I)
  Endif
  If (WFITOPEEND(I) < WOPEFITSTD(I)) | ((WFITOPEEND(I) = WOPEFITSTD(I)) & (WFITOPEENF(I) < WOPEFITSTF(I)))
      WFITOPEEND(I) = WOPEFITSTD(I)
      WFITOPEENF(I) = WOPEFITSTF(I)
  Endif
  If (WFITCAPSTR(I) <> WFITCAPEND(I)) |  (WFITCAPSTF(I) <> WFITCAPENF(I))
      If WFITCAPSTR(I) <> [0/0/0] & WFITCAPSTF(I) = 1 : WFITCAPSTR(I) += 1 : WFITCAPSTF(I) = 0 : Endif
      If WFITCAPEND(I) <> [0/0/0] & WFITCAPENF(I) = 0 : WFITCAPEND(I) -= 1 : WFITCAPENF(I) = 1 : Endif
  Endif
  If (WOPEFITSTD(I) <> WFITOPEEND(I)) |  (WOPEFITSTF(I) <> WFITOPEENF(I))
      If WFITOPEEND(I) <> [0/0/0] & WFITOPEENF(I) = 0 : WFITOPEEND(I) -= 1 : WFITOPEENF(I) = 1 : Endif
  Endif
  If (WFITCAPSTR(I) < WOPEFITSTD(I)) | ((WFITCAPSTR(I) = WOPEFITSTD(I)) & (WFITCAPSTF(I) < WOPEFITSTF(I)))
      WOPEFITSTD(I) = WFITCAPSTR(I)
      WOPEFITSTF(I) = WFITCAPSTF(I)
  Endif
  If (WFITCAPEND(I) > WFITOPEEND(I)) | ((WFITCAPEND(I) = WFITOPEEND(I)) & (WFITCAPENF(I) > WFITCAPENF(I)))
      WFITOPEEND(I) = WFITCAPEND(I)
      WFITOPEENF(I) = WFITCAPENF(I)
  Endif
Endif
# passage à sous-traitance ?
If WWSTTYP(I) <> 3 & WOPEWSTTYP(I) =  3 : WSUB = 1 : Else : WSUB = 0 : Endif

# annulation sous-traitance non gérée pour le moment
If WWSTTYP(I)  = 3 & WOPEWSTTYP(I) <> 3
        WMESS   = mess(156,197,1)-WMFGNUM(0)
        WMESS1  = mess(127,193,1)
        If [M:OPTK]TRACE2 = 2
            Call ECR_TRACE(WMESS,0) From GESECRAN
            Call ECR_TRACE(WMESS1,1) From GESECRAN
        Endif
        GOK = 0
        Return
Endif


Readlock [SCH]SCH0=WMFGNUM(I);WOPENUM(I);WOPESPLNUM(I)
If fstat
    WTAB="SCH"
    WCLE=WMFGNUM(I)-num$(WOPENUM(I))-num$(WOPESPLNUM(I))
    Goto AB_RES
Endif

# si le poste a changé on réinitialise les données de capacité infinie
If [F:SCH]CLCWST <> WOPEWST(I)
    [F:SCH]CLCWST    = WOPEWST(I)
    [F:SCH]CLCPRPDUR = 0
    [F:SCH]CLCSETDUR = 0
    [F:SCH]CLCOPEDUR = 0
    [F:SCH]CLCWORDUR = 0
    [F:SCH]CLCPSTDUR = 0
    [F:SCH]CLCWAIDUR = 0
    [F:SCH]CLCAFTDUR = 0
    [F:SCH]SETLABCOE = WOPELABCOE(I)
    [F:SCH]OPELABCOE = WOPELABCOE(I)
    [F:SCH]INFCAPSTR = [0/0/0]
    [F:SCH]INFCAPSTF = 0
    [F:SCH]SETENDDAT = [0/0/0]
    [F:SCH]SETENDFRD = 0
    [F:SCH]INFCAPEND = [0/0/0]
    [F:SCH]INFCAPENF = 0
    [F:SCH]OPESTRFRD = 0
    [F:SCH]OPEENDFRD = 0
Endif
[F:SCH]OPELABCOE = WOPELABCOE(I)
[F:SCH]CLCLAB    =   WOPELAB(I)
[F:SCH]OPESTRDAT =   WOPEFITSTD(I)
[F:SCH]OPESTRFRD =   WOPEFITSTF(I)
[F:SCH]OPEENDDAT =   WFITOPEEND(I)
[F:SCH]OPEENDFRD =   WFITOPEENF(I)
[F:SCH]CLCEXTTIM =   WEXTTIM(I) + WSETTIM(I)
[F:SCH]OPEFITSTD =   WOPEFITSTD(I)
[F:SCH]OPEFITSTF =   WOPEFITSTF(I)
[F:SCH]FITCAPSTR =   WFITCAPSTR(I)
[F:SCH]FITCAPSTF =   WFITCAPSTF(I)
[F:SCH]FITCAPEND =   WFITCAPEND(I)
[F:SCH]FITCAPENF =   WFITCAPENF(I)
[F:SCH]FITOPEEND =   WFITOPEEND(I)
[F:SCH]FITOPEENF =   WFITOPEENF(I)
[F:SCH]FITPRPDUR =   WFITPRPDUR(I)
[F:SCH]FITWORDUR =   WFITWORDUR(I)
[F:SCH]FITPSTDUR =   WFITPSTDUR(I)
[F:SCH]FITDELAY  =   WFITDELAY(I)


# mise à jour opération
Readlock [MFO]MFO0=WMFGNUM(I);WOPENUM(I);WOPESPLNUM(I)
If fstat
    WTAB="MFO"
    WCLE=WMFGNUM(I)-num$(WOPENUM(I))-num$(WOPESPLNUM(I))
    Goto AB_RES
Endif

[F:MFO]MFGPIO = WMFGPIO(I)
[F:MFO]SCOLTI = WSCOLTI(I)                # 11.06 35988

If WOPEWST(I) <> [F:MFO]EXTWST : WNEWWST = 1 : Else : WNEWWST = 0 : Endif

If WSUB <> 1
    [F:MFO]OPELABCOE = WOPELABCOE(I)
    [F:MFO]EXTWST    = [F:SCH]CLCWST
    If [F:MFO]CPLWST <> "" : [F:MFO]CPLWST = [F:SCH]CLCWST : Endif        # 01.08 45505
    [F:MFO]EXTLAB    = [F:SCH]CLCLAB
    [F:MFO]EXTWSTNBR = WWSTNBR(I)
    [F:MFO]EXTLABNBR = WLABNBR(I)
    [F:MFO]FITCAPSTR = [F:SCH]FITCAPSTR
    [F:MFO]FITCAPEND = [F:SCH]FITCAPEND
    [F:MFO]OPESTR    = [F:SCH]OPESTRDAT
    [F:MFO]OPEEND    = [F:SCH]OPEENDDAT

    # 81007
    If [F:MFO]FRCSTRHOU <> "" | ([F:MFO]FRCSTRDAT = [0/0/0] & WFRCSTRDAT(I) <> [0/0/0])
        [F:MFO]FRCSTRDAT = WFRCSTRDAT(I)
        Call OPETIME([F:MFO]MFGFCY, [F:MFO]EXTWST, [F:MFO]FRCSTRDAT, WFRCSTRFRD(I), [F:MFO]FRCSTRHOU) From JALLIBB
    Else
        [F:MFO]FRCSTRDAT = WFRCSTRDAT(I)
        [F:MFO]FRCSTRHOU = ""
    Endif

    # temps de préparation
    [F:MFO]PRPTIM    = WPRPTIM(I)
# Issue 113038 - 2016-03-16 by RBA
#    [F:MFO]EXTSETTIM = WSETTIM(I) + [F:MFO]CPLSETTIM
#    [F:MFO]EXTOPETIM = WEXTTIM(I) + [F:MFO]CPLOPETIM
#/ Issue 113038
    # temps post-opératoire
    If [F:MFO]PSPTIM > [F:MFO]WAITIM
       [F:MFO]PSPTIM = WPSTTIM(I)
    Else
       [F:MFO]WAITIM = WPSTTIM(I)
    Endif

    # recalcul du temps unitaire = temps opératoire calculé / quantité
    [F:MFO]EXTUNTTIM =  [F:MFO]EXTOPETIM / [F:MFO]EXTQTY
Else
    If WOPEWST(I) <> [F:MFO]SCOWST
        Unlock [MFO]
        Unlock [SCH]
        WMESS   = mess(156,197,1)-WMFGNUM(0)
        WMESS1  = mess(126,193,1)
        If [M:OPTK]TRACE2 = 2
            Call ECR_TRACE(WMESS,0) From GESECRAN
            Call ECR_TRACE(WMESS1,1) From GESECRAN
        Endif
        GOK = 0
        Return
    Endif
    [F:MFO]EXTWST    = [F:SCH]CLCWST
    If [F:MFO]CPLWST <> "" : [F:MFO]CPLWST = [F:SCH]CLCWST : Endif        # 01.08 45505
    [F:MFO]EXTLAB    = [F:SCH]CLCLAB
    [F:MFO]FITCAPSTR = [F:SCH]FITCAPSTR
    [F:MFO]FITCAPEND = [F:SCH]FITCAPEND
    [F:MFO]OPESTR    = [F:SCH]OPESTRDAT
    [F:MFO]OPEEND    = [F:SCH]OPEENDDAT

    # 73813 + 75117
    [F:MFO]FRCSTRDAT = WFRCSTRDAT(I)
    Call OPETIME([F:MFO]MFGFCY, [F:MFO]EXTWST, [F:MFO]FRCSTRDAT, WFRCSTRFRD(I), [F:MFO]FRCSTRHOU) From JALLIBB

    Read [MWS]WST0=WOPEWST(I);WMFGFCY
    If fstat : WTAB="MWS" : WCLE=WOPEWST(I): Goto AB_RES : Endif
    [F:MFO]SCOCOD       = 3
    [F:MFO]SCOWST       = [F:MWS]WST
    [F:MFO]EXTLAB       = ""
    [F:MFO]ROOTIMCOD    = 3
    [F:MFO]TIMCOD       = 0
    [F:MFO]BASQTY       = 0
    [F:MFO]CAD          = 3
    [F:MFO]EXTSETTIM    = WSETTIM(I)
    [F:MFO]EXTOPETIM    = WEXTTIM(I)
    [F:MFO]EXTUNTTIM    = [F:MFO]EXTOPETIM / [F:MFO]EXTQTY
    [F:MFO]EXTOPETIM    = func TRTX3.ARRTYP("", "", "TIH", [F:MFO]EXTOPETIM)
    [F:MFO]EXTUNTTIM    = func TRTX3.ARRTYP("", "", "TIH", [F:MFO]EXTUNTTIM)
    [F:MFO]EXTSETTIM    = func TRTX3.ARRTYP("", "", "TIH", [F:MFO]EXTSETTIM)
    [F:MFO]EXTWSTNBR    = WWSTNBR(I)
    [F:MFO]EXTLABNBR    = WLABNBR(I)
    [F:MFO]EFF          = [F:MWS]EFF
    [F:MFO]SETLABCOE    = 0
    [F:MFO]OPELABCOE    = 0
    [F:MFO]PRPTIM       = WPRPTIM(I)
    [F:MFO]WAITIM       = 0
    If [F:MFO]PSPTIM > [F:MFO]WAITIM
       [F:MFO]PSPTIM = WPSTTIM(I)
    Else
       [F:MFO]WAITIM = WPSTTIM(I)
    Endif
    [F:MFO]OPEUOM       = [F:MFO]SCOPUU
    [F:MFO]WSTEFF       = [F:MWS]EFF
    [F:MFO]TECCRD       = ""
    [F:MFO]OPEPLNNUM    = ""
    [F:MFO]OPEROUPCT    = ""
    [F:MFO]EQUNUM       = ""
    [F:MFO]FXGNUM       = ""
    [F:MFO]PRGNUM       = ""
    # recherche coefficient US/UO
    MCOEFF = [F:MFO]OPESTUCOE
    Call RECH_COEFF([F:MFG]STU, [F:MFO]OPEUOM, WCOEFF) From MFGLIB
    If WCOEFF <> 0
        [F:MFO]OPESTUCOE = WCOEFF
    Else
        [F:MFO]OPESTUCOE = 1
    Endif
    If WCOEFF <> MCOEFF
        Call UPD_OPE_UNI(10, "MFO", 0, [F:MFO]OPESTUCOE) From MFGLIBO
    Endif
    # récupération coeff US(STR)/UO
    Read [ITM]ITM0 = [F:MFO]SCOITMREF
    If !fstat
        Call RECH_COEFF([F:MFO]OPEUOM, [F:ITM]STU, WCOEFF) From MFGLIB
        If WCOEFF <> 0
            [F:MFO]OPESTRCOE = WCOEFF
        Else
            [F:MFO]OPESTRCOE = 1
        Endif
    Endif
    [F:MFO]EXTSTRQTY = [F:MFO]EXTQTY * [F:MFO]OPESTRCOE

    If !find([F:MFO]OPESTA,5,6)
        [F:MFO]FRCSTRDAT = WFRCSTRDAT(I)
        [F:MFO]FRCSTRHOU = ""
        If WFRCSTRDAT(I) <> [0/0/0]
            Call OPETIME(WMFGFCY, WOPEWST(I), WFRCSTRDAT(I), WFRCSTRFRD(I), [F:MFO]FRCSTRHOU) From JALLIBB
        Endif
    Endif

    # mise à jour encours
    Call UPDATE_OWX("M","") From MFGLIBO
Endif

[F:MFO]SCHSBB    = WSCHSBB(I)                    # 03.06 distinction
[F:MFO]UPDDAT    = date$
[F:MFO]UPDUSR    = GUSER

# Issue 74791 - 2011-10-04 by VPO : ajout PE pour alimenter zone SPE
GPOINT="MFOPOINT" : Gosub ENTREE From EXEFNC

Rewrite [MFO]
Unlock  [MFO]

If WSUB <> 1
    # mise à jour encours charge
    Update [OPS]   Where MFGNUM=WMFGNUM(I) & OPENUM=[F:SCH]OPENUM
&                        & OPESPLNUM=[F:SCH]OPESPLNUM
&                  With  FITCAPSTR = [F:SCH]FITCAPSTR,
&                        FITCAPEND = [F:SCH]FITCAPEND,
&                        OPESTR    = [F:SCH]OPESTRDAT,
&                        OPEEND    = [F:SCH]OPEENDDAT,
&                        EXTWST    = [F:SCH]CLCWST,
&                        EXTLAB    = [F:SCH]CLCLAB,
&                        PRPTIM    = [F:MFO]PRPTIM,
&                        EXTOPETIM = [F:MFO]EXTOPETIM,
&                        PSPTIM    = [F:MFO]PSPTIM,
&                        EXTWSTNBR = [F:MFO]EXTWSTNBR,
&                        EXTLABNBR = [F:MFO]EXTLABNBR,
&                        UPDDAT    = date$,
&                        UPDUSR    = GUSER
    If fstat
        WTAB="OPS"
        WCLE=WMFGNUM(I)-num$([F:SCH]OPENUM)-num$([F:SCH]OPESPLNUM)
        Goto AB_RES
    Endif

    # mise à jour encours article sous-traitance
    If WWSTTYP(I) = 3 & WOPESTA(I) <> 7
        Update [ORD] Where WIPNUM=[F:MFO]WIPNUM & WIPTYP = 4 & ITMREF = [F:MFO]SCOITMREF
&                    With  STRDAT = [F:SCH]OPESTRDAT,
&                          ENDDAT = [F:SCH]OPEENDDAT,
&                          PIO    = WMFGPIO(I),
&                          UPDDAT = date$,
&                          UPDUSR = GUSER
        If fstat
            WTAB="ORD"
            WCLE=[F:MFO]WIPNUM
            Goto AB_RES
        Endif
    Endif
Endif

# mise à jour scheduling
Rewrite [SCH]
Unlock [SCH]

#     regarde présence composants liés à l'opération ou à une opération de numéro
#     inférieur qui n'existe pas dans l'OF
#       si oui : charge résultats de l'opération sur composants
#                MFGMAT et ORDERS
For [MFM]MFM3 Where MFGNUM=WMFGNUM(I)
&                & (BOMOPE<=WOPENUM(I) & BOMOPE>WPREC)
&                &  evalue(XCRITERE)
    Readlock [MFM]MFM0 Curr
    If fstat
        WTAB="MFM"
        WCLE=WMFGNUM(I)
        Goto AB_RES
    Endif

    WRETDAT = WOPEFITSTD(I)    # date besoin = date début préparation
    If I > 0
        If WOPENUM(I) = WOPENUM(I-1)
            If WRETDAT > [F:MFM]RETDAT
                WRETDAT = [F:MFM]RETDAT
            Endif
        Endif
    Endif

    [F:MFM]MFGPIO = WMFGPIO(I)
    [F:MFM]RETDAT = WRETDAT
    [F:MFM]UPDDAT = date$
    [F:MFM]UPDUSR = GUSER

    If WNEWWST
        If [F:MWS]WST <> WOPEWST(I)
          Read [MWS]WST0=WOPEWST(I);WMFGFCY
          If fstat : WTAB="MWS" : WCLE=WOPEWST(I): Goto AB_RES : Endif
        Endif

        If [F:MWS]WSTTYP = 3
            TROUVE=0
            # Recherche de l'emplacement du client livré
            If [F:MFO]BPRNUM <> "" & [F:MFO]BPAADD <> ""
                If clalev([F:BPD])   = 0 : Local File BPDLVCUST   [BPD]   : Endif
                Read [BPD]BPD0=[F:MFO]BPRNUM;[F:MFO]BPAADD
                If fstat : Raz [F:BPD] : Endif
                If [F:BPD]SCOLOC <>""
                    [F:MFM]LOC = [F:BPD]SCOLOC
                    TROUVE =1
                Endif
            Endif
            # Recherche de l'emplacement du fournisseur
            If TROUVE =0
                If [F:MFO]BPRNUM <> ""
                    If clalev([F:BPS])   = 0 : Local File BPSUPPLIER    [BPS]   : Endif
                    Read [BPS]BPS0=[F:MFO]BPRNUM
                    If !fstat
                        If [F:BPS]LOC <> "" : [F:MFM]LOC = [F:BPS]LOC : Endif
                    Endif
                Endif
             Endif
        Else
            If [F:MWS]STOLOC <> "" : [F:MFM]LOC = [F:MWS]STOLOC : Endif
        Endif
    Endif

    Update [ORD] Where WIPNUM=[F:MFM]WIPNUM & WIPTYP = 6 & ITMREF = [F:MFM]ITMREF
&                With  STRDAT = [F:MFM]RETDAT,
&                      ENDDAT = [F:MFM]RETDAT,
&                      PIO    = WMFGPIO(I),
&                      UPDDAT = date$,
&                      UPDUSR = GUSER
    If fstat
        WTAB="ORD"
        WCLE=[F:MFM]WIPNUM
        Goto AB_RES
    Endif

    Update [F:STA]  Where VCRTYP = 10 & VCRNUM = [F:MFM]MFGNUM &
&                         VCRLIN = [F:MFM]MFGLIN & VCRSEQ = [F:MFM]BOMSEQ &
&                         ITMREF = [F:MFM]ITMREF
&                   With BESDAT = [F:MFM]RETDAT

    If fstat
        WTAB="STA"
        WCLE=num$(10)-[F:MFM]MFGNUM-num$([F:MFM]MFGLIN)-num$([F:MFM]BOMSEQ)-[F:MFM]ITMREF
        Goto AB_RES
    Endif

    Rewrite [MFM]
    Unlock [MFM]
Next

#   itération opération
WPREC = WOPENUM(I)

$MAJSCH_NX
I += 1
If I < NBOP : Goto MAJSCH : Endif

# regarde présence composants liés à l'opération 0
#     si oui : charge résultats début OF sur composants en tenant compte du délai op
#              MFGMAT et ORDERS
I = 0
For [MFM]MFM3 Where MFGNUM=WMFGNUM(I)
&                 & BOMOPE=0
&                 &  evalue(XCRITERE)
    Readlock [MFM]MFM0 Curr
    If fstat
        WTAB="MFM"
        WCLE=WMFGNUM(I)
        Goto AB_RES
    Endif

    WRETDAT = WMFGSTR + [F:MFM]BOMOFS
    [F:MFM]RETDAT = WRETDAT
    [F:MFM]MFGPIO = WMFGPIO(I)
    [F:MFM]UPDDAT = date$
    [F:MFM]UPDUSR = GUSER

    Update [ORD] Where WIPNUM=[F:MFM]WIPNUM & WIPTYP = 6 & ITMREF = [F:MFM]ITMREF
&                With  STRDAT = [F:MFM]RETDAT,
&                      ENDDAT = [F:MFM]RETDAT,
&                      PIO    = WMFGPIO(I),
&                      UPDDAT = date$,
&                      UPDUSR = GUSER
    If fstat
        WTAB="ORD"
        WCLE=[F:MFM]WIPNUM
        Goto AB_RES
    Endif

    Update [F:STA]  Where VCRTYP = 10 & VCRNUM = [F:MFM]MFGNUM &
&                         VCRLIN = [F:MFM]MFGLIN & VCRSEQ = [F:MFM]BOMSEQ &
&                         ITMREF = [F:MFM]ITMREF
&                   With BESDAT = [F:MFM]RETDAT

    If fstat
        WTAB="STA"
        WCLE=num$(10)-[F:MFM]MFGNUM-num$([F:MFM]MFGLIN)-num$([F:MFM]BOMSEQ)-[F:MFM]ITMREF
        Goto AB_RES
    Endif

    Rewrite [MFM]
    Unlock [MFM]
Next

# chargement résultats composés :
#   sur MFGITM et ORDERS
For [MFI]MFI0 Where MFGNUM=WMFGNUM(I)
&                 & ITMSTA<3
    Readlock [MFI]MFI0 Curr
    If fstat
        WTAB="MFI"
        WCLE=WMFGNUM(I)
        Goto AB_RES
    Endif

    If [F:MFI]ITMSTA = 1 : [F:MFI]STRDAT = WMFGSTR : Endif
    [F:MFI]ENDDAT = WMFGEND
    [F:MFI]MFGPIO = WMFGPIO(I)
    [F:MFI]UPDDAT = date$
    [F:MFI]UPDUSR = GUSER

    Update [ORD] Where WIPNUM=[F:MFI]WIPNUM & WIPTYP = 5 & ITMREF = [F:MFI]ITMREF
&                With  STRDAT = WMFGSTR,
&                      ENDDAT = WMFGEND,
&                      PIO    = WMFGPIO(I),
&                      OPTFLG = 2,
&                      UPDDAT = date$,
&                      UPDUSR = GUSER
    If fstat
        WTAB="ORD"
        WCLE=[F:MFI]WIPNUM
        Goto AB_RES
    Endif

    Rewrite [MFI]
    Unlock [MFI]
Next
Return


#########################################################################
# mise à jour suggestion
$MAJOFS

I = 0
WPREC = 0

$MAJSCHS
fstat = 0
Readlock [SCH]SCH0=WMFGNUM(I);WOPENUM(I);WOPESPLNUM(I)
If fstat
    WTAB="SCH"
    WCLE=WMFGNUM(I)-num$(WOPENUM(I))-num$(WOPESPLNUM(I))
    Goto AB_RES
Endif

# si le poste a changé on réinitialise les données de capacité infinie
If [F:SCH]CLCWST <> WOPEWST(I)
    [F:SCH]CLCWST    = WOPEWST(I)
    [F:SCH]CLCPRPDUR = 0
    [F:SCH]CLCSETDUR = 0
    [F:SCH]CLCOPEDUR = 0
    [F:SCH]CLCWORDUR = 0
    [F:SCH]CLCPSTDUR = 0
    [F:SCH]CLCWAIDUR = 0
    [F:SCH]CLCAFTDUR = 0
    [F:SCH]SETLABCOE = WOPELABCOE(I)
    [F:SCH]OPELABCOE = WOPELABCOE(I)
    [F:SCH]INFCAPSTR = [0/0/0]
    [F:SCH]INFCAPSTF = 0
    [F:SCH]SETENDDAT = [0/0/0]
    [F:SCH]SETENDFRD = 0
    [F:SCH]INFCAPEND = [0/0/0]
    [F:SCH]INFCAPENF = 0
    [F:SCH]OPESTRFRD = 0
    [F:SCH]OPEENDFRD = 0
Endif
[F:SCH]OPELABCOE = WOPELABCOE(I)
[F:SCH]CLCLAB    =   WOPELAB(I)
[F:SCH]OPESTRDAT =   WOPEFITSTD(I)
[F:SCH]OPESTRFRD =   WOPEFITSTF(I)
[F:SCH]OPEENDDAT =   WFITOPEEND(I)
[F:SCH]CLCEXTTIM =   WEXTTIM(I) + WSETTIM(I)
[F:SCH]OPEFITSTD =   WOPEFITSTD(I)
[F:SCH]OPEFITSTF =   WOPEFITSTF(I)
[F:SCH]FITCAPSTR =   WFITCAPSTR(I)
[F:SCH]FITCAPSTF =   WFITCAPSTF(I)
[F:SCH]FITCAPEND =   WFITCAPEND(I)
[F:SCH]FITCAPENF =   WFITCAPENF(I)
[F:SCH]FITOPEEND =   WFITOPEEND(I)
[F:SCH]FITOPEENF =   WFITOPEENF(I)
[F:SCH]FITPRPDUR =   WFITPRPDUR(I)
[F:SCH]FITWORDUR =   WFITWORDUR(I)
[F:SCH]FITPSTDUR =   WFITPSTDUR(I)
[F:SCH]FITDELAY  =   WFITDELAY(I)

[F:SCH]UPDDAT    = date$
[F:SCH]UPDUSR    = GUSER
If dim([F:SCH]UPDTIM) > 0 : [F:SCH]UPDTIM = time : Endif
# mise à jour opération
Readlock [OPS]OPS1=WMFGNUM(I);WOPENUM(I);WOPESPLNUM(I)
If fstat
    WTAB="OPS"
    WCLE=WMFGNUM(I)-num$(WOPENUM(I))-num$(WOPESPLNUM(I))
    Goto AB_RES
Endif
[F:OPS]FITCAPEND = [F:SCH]FITCAPEND
[F:OPS]OPESTR    = [F:SCH]OPESTRDAT
[F:OPS]OPEEND    = [F:SCH]OPEENDDAT
[F:OPS]EXTWST    = [F:SCH]CLCWST
[F:OPS]EXTLAB    = [F:SCH]CLCLAB
[F:OPS]EXTWSTNBR = WWSTNBR(I)
[F:OPS]EXTLABNBR = WLABNBR(I)
[F:OPS]OPELABCOE = WOPELABCOE(I)
[F:OPS]UPDDAT    = date$
[F:OPS]UPDUSR    = GUSER
Rewrite [OPS]
Unlock  [OPS]

If WWSTTYP(I) = 3 & WOPESTA(I) <> 7
    Update [ORD] Where WIPNUM=[F:OPS]WIPNUM & WIPTYP = 4 & ITMREF = [F:OPS]SCOITMREF
&                With  STRDAT = [F:SCH]OPESTRDAT,
&                      ENDDAT = [F:SCH]OPEENDDAT,
&                      PIO    = WMFGPIO(I),
&                      UPDDAT = date$,
&                      UPDUSR = GUSER
    If fstat
      WTAB="ORD"
      WCLE=[F:OPS]WIPNUM
      Goto AB_RES
    Endif
Endif

Rewrite [SCH]
Unlock [SCH]

#     regarde présence composants liés à l'opération ou à une opération de numéro
#     inférieur qui n'existe pas dans l'OF
#       si oui : charge résultats sur ORDERS
#
Update [ORD] Where WIPTYP=6
&                & STOFCY=WMFGFCY(I)
&                & VCRTYP=11
&                & VCRNUM=WMFGNUM(I)
&                & VCRLIN=0
&                & VCRSEQ=0
&                & (BOMOPE<=[F:SCH]OPENUM & BOMOPE>WPREC)
&            With  STRDAT = [F:SCH]OPESTRDAT,
&                  ENDDAT = [F:SCH]OPESTRDAT,
&                  PIO    = WMFGPIO(I),
&                  UPDDAT = date$,
&                  UPDUSR = GUSER
If fstat
    WTAB="ORD"
    WCLE=WMFGFCY-num$(11)-WMFGNUM(I)
    Goto AB_RES
Endif

#   itération opération
WPREC = WOPENUM(I)

$MAJSCHS_NX
I += 1
If I < NBOP : Goto MAJSCHS : Endif

#     regarde présence composants liés à l'opération 0
#       si oui : charge résultats début OF sur ORDERS
I = 0
Update [ORD] Where WIPTYP=6
&                & STOFCY=WMFGFCY(I)
&                & VCRTYP=11
&                & VCRNUM=WMFGNUM(I)
&                & VCRLIN=0
&                & VCRSEQ=0
&                & BOMOPE=0
&            With  STRDAT = WMFGSTR,
&                  ENDDAT = WMFGSTR,
&                  PIO    = WMFGPIO(I),
&                  UPDDAT = date$,
&                  UPDUSR = GUSER
If fstat
    WTAB="ORD"
    WCLE=WMFGFCY(I)-num$(11)-WMFGNUM(I)
    Goto AB_RES
Endif

# chargement résultats composés sur ORDERS
Update [ORD] Where WIPTYP=5
&                & STOFCY=WMFGFCY(I)
&                & VCRTYP=11
&                & VCRNUM=WMFGNUM(I)
&                & VCRLIN=0
&                & VCRSEQ=0
&            With  STRDAT = WMFGSTR,
&                  ENDDAT = WMFGEND,
&                  PIO    = WMFGPIO(I),
&                  OPTFLG = 2,
&                  UPDDAT = date$,
&                  UPDUSR = GUSER
If fstat
    WTAB="ORD"
    WCLE=WMFGFCY(I)-num$(11)-WMFGNUM(I)
    Goto AB_RES
Endif

Return

#########################################################################
# fin normale :
$END_RES
If GOK = 1 : Commit : Endif
WMESS   = mess(156,197,1)-WMFGNUM(0)-mess(4,335,1)
If [M:OPTK]TRACE2 = 2
    Call ECR_TRACE(WMESS,0) From GESECRAN
Endif
Return

#########################################################################
# fin normale :
$END_ROLL
Rollback
Return

#########################################################################
# fin anormale
$AB_RES
Commit
WMESS1 = mess(12,100,1)-"("+WTAB+"/"+WCLE+")"
If [M:OPTK]TRACE2 = 2
    Call ECR_TRACE(WMESS1,1) From GESECRAN
Endif
Call FREEOF(WMFGNUM(0), [M:OPTK]TRACE2)
GOK=2

Return

#########################################################################
# blocage UPDATE
$ROLL_RES
GOK=0
WMESS1 = mess(20,100,1)-"("+WTAB+"/"+WCLE+")"
If [M:OPTK]TRACE2 = 2
    Call ECR_TRACE(WMESS1,1) From GESECRAN
Endif
Return


###########################################################################
# sortie sans mise à jour, libération des OF à l'étude
Subprog FREEMFG(LFCY, LUSR, LTRC)
Value Char LFCY
Value Char LUSR
Value Integer LTRC

Local Integer  NBOF : NBOF = 0
Local Char     WTEX(80)

Call TEMPON("") From GESECRAN

If clalev([F:MFG])  = 0 : Local File MFGHEAD    [MFG]  : Endif
# ouverture trace
WTEX = mess(288,197,1)-"("+LFCY+"/"+LUSR+")"
If LTRC <> 0
    Call OUVRE_TRACE(WTEX) From LECFIC
Endif

Call DEBTRANS From GLOCK
Trbegin ADOVAL

If LUSR <> ""
    For [MFG]MFG1 Where MFGFCY=LFCY & OPTFLG = 2 & OPTUSR = LUSR
        Readlock [MFG] Curr
        [F:MFG]OPTFLG = 1
        Rewrite [MFG]
        Unlock [MFG]
        WMESS   = mess(156,197,1)-[F:MFG]MFGNUM-mess(289,197,1)
        NBOF += 1
        If LTRC <> 0
            Call ECR_TRACE(WMESS,0) From GESECRAN
        Endif
    Next
Else
    For [MFG]MFG1 Where MFGFCY=LFCY & OPTFLG = 2
        Readlock [MFG] Curr
        [F:MFG]OPTFLG = 1
        Rewrite [MFG]
        Unlock [MFG]
        WMESS   = mess(156,197,1)-[F:MFG]MFGNUM-mess(289,197,1)
        NBOF += 1
        If LTRC <> 0
            Call ECR_TRACE(WMESS,0) From GESECRAN
        Endif
    Next
Endif

Commit
Call TEMPOFF From GESECRAN
If LTRC <> 0
    If NBOF = 0
        Call ECR_TRACE(mess(88,193,1),0) From GESECRAN
    Endif
    # fermeture trace
    Call FERME_TRACE From LECFIC
    # lecture trace
    Call LEC_TRACE From LECFIC
Endif
End

###########################################################################
# sortie sans mise à jour, libération d'un OF à l'étude
Subprog FREEOF(LMFG, LTRC)
Value Char LMFG
Value Integer LTRC

Local Char     WTEX(80)

If clalev([F:MFG])  = 0 : Local File MFGHEAD    [MFG]  : Endif

Call DEBTRANS From GLOCK
Trbegin ADOVAL

Readlock [MFG]MFG0=LMFG
If !fstat
    [F:MFG]OPTFLG = 1
    Rewrite [MFG]
    Unlock [MFG]
    WMESS   = mess(156,197,1)-[F:MFG]MFGNUM-mess(289,197,1)
    If LTRC <> 0
        Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
Endif
Commit
End

