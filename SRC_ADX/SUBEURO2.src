#<AdxTL>@(#)160.0.0.0 $Revision$
Call EURO From SUBEURO
End

########################################################
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "OK"       : Gosub OK
 When "FIN"      : Gosub FIN
Endcase
Return

########################################################
$OUVRE
Local Integer NZON , NCUR , ONZON , ONCUR, NOL
Local Char    ZONE(GLONAVA)(1..100) , ZCUR(20)(1..100) 
Local Char    DEV(30)(1..100)
Local Integer TABZON(1..100) , RCUR(1..100)
Local Integer FLMSK(0..16)
Local Char    MSK(GLONAMK) 
Local Integer K , Z , D , STAT , SAVIND , SAVNOL
Local Decimal MTORG , MTDES 
Local Char    DEVORG(GLONCUR) , DEVDES(GLONCUR) , SAVCUR(GLONCUR)
Local Char    SAVZON(GLONAVA)
Local Char    SAVDEV(GLONCUR)(1..dim(GDEV1))
Local Integer OUVBOX
Local Char    EBOITE(GLONFEN), PROGOBJ2(GLONADC), WINPROG2(GLONADC)

PROGOBJ2 = "WO"+GABREV
EBOITE = PARAM(1)
If EBOITE=""
 Call CONT_FEN(GABREV,EBOITE) From GOBJET
Endif
If EBOITE<>""
 Call NOMTRTWIN(EBOITE,WINPROG2) From MSKDIV
Endif

For I=1 To dim(GDEV1)
 SAVDEV(I) = GDEV1(I)
Next I

SAVZON = zoncou
SAVIND = indice
SAVNOL = nolign
SAVCUR = GCUR

If maskcou="" or zoncou=""
 FIN = 1 : Return : # Si zoncou est vide, maskcou est faux!!
Endif

FIN = 1
If GTRAITE="GOBJET" & GABREV<>""
 Gosub NOMFIC From =PROGOBJ2
 Gosub DEFVAR From =WINPROG2
 If find(maskcou,NOMMSK(0..NBMASK))
  FIN = 0
 Endif
Endif
If FIN : Return : Endif

MSK    = maskcou

Onerrgo ERREUR From CONTROLE
Local File AMSK [AMK] , AMSKZON [AMZ] , AMSKPAR [AMP] , AOBJET [AOB]
Local File TABCUR [TCU] , TABCHANGE [TCH] 
Onerrgo
If GERREUR
 GERREUR = 0
 FIN = 1
 Return
Endif
Onerrgo ERREUR

Read [AOB]ABREV = GABREV
If fstat : FIN = 1 : Return : Endif

NZON = 0 
NCUR = 0
For I=0 To NBMASK
 If ABMSK(I) <> ""    : # modif JL
  ABR = ABMSK(I)
  If evalue("clalev([M:"+ABR+"])")>0
   MSK = evalue("masknam([M:"+ABR+"])")
  Else
   MSK = ""
  Endif
  NOMMSK(I) = MSK
  If MSK<>""
   Gosub CHARGE_ZONE
  Endif
 Endif
Next I
If NZON=0 : FIN = 1 : Return : Endif

Disable GSTAEUR

Call OUVMSK(NBMASK,NOMMSK,FLMSK)
For I=0 To NBMASK
 If FLMSK(I)
  MA = I : Gosub SETMASK From =WINPROG2
  Case I
   When 0  : [M:S00_] = [M]  
   When 1  : [M:S01_] = [M]
   When 2  : [M:S02_] = [M]
   When 3  : [M:S03_] = [M]
   When 4  : [M:S04_] = [M]
   When 5  : [M:S05_] = [M]
   When 6  : [M:S06_] = [M]
   When 7  : [M:S07_] = [M]
   When 8  : [M:S08_] = [M]
   When 9  : [M:S09_] = [M]
   When 10 : [M:S10_] = [M]
   When 11 : [M:S11_] = [M]
   When 12 : [M:S12_] = [M]
   When 13 : [M:S13_] = [M]
   When 14 : [M:S14_] = [M]
   When 15 : [M:S15_] = [M]
  Endcase
 Endif
Next I
OUVBOX = 1
Return

########################################################
$DEBUT    
Call PARAM("","EUROCOD",DEVDES) From ADOVAL
If DEVDES=""
 DEVDES = GEURO
Endif
[M:EUR]DEVISE = DEVDES
Gosub CALCUL
Return

########################################################
$OK
If DEVDES<>[M:EUR]DEVISE
 DEVDES = [M:EUR]DEVISE
 Gosub RESTAURE
 Gosub CALCUL
 FIN = 0
Endif
Return

########################################################
$FIN
If OUVBOX
 Gosub RESTAURE
 For I=0 To NBMASK
  If FLMSK(I)
   Case I
    When 0  : Close Global Mask [S00_]
    When 1  : Close Global Mask [S01_]
    When 2  : Close Global Mask [S02_]
    When 3  : Close Global Mask [S03_]
    When 4  : Close Global Mask [S04_]
    When 5  : Close Global Mask [S05_]
    When 6  : Close Global Mask [S06_]
    When 7  : Close Global Mask [S07_]
    When 8  : Close Global Mask [S08_]
    When 9  : Close Global Mask [S09_]
    When 10 : Close Global Mask [S10_]
    When 11 : Close Global Mask [S11_]
    When 12 : Close Global Mask [S12_]
    When 13 : Close Global Mask [S13_]
    When 14 : Close Global Mask [S14_]
    When 15 : Close Global Mask [S15_]
   Endcase
  Endif
 Next I
 Close Global Mask [EUR]
 BOX = 0
 For I=0 To NBMASK
  If FLMSK(I)
   MA = I : Gosub SETMASK From =WINPROG2
   Affzo
  Endif
 Next I
 Enable GSTAEUR
Endif
If SAVZON<>""
 mkstat = 2
Endif
indice = SAVIND
nolign = SAVNOL
Return

########################################################
$CALCUL
For Z=1 To NZON 
 For D=0 To TABZON(Z)-1 
  NOL = nolign : nolign = D+1 : indice = nolign-1       : # modif JL 
  DEVORG = evalue(DEV(Z))
  nolign = NOL : indice = nolign-1                      : # modif JL
  MTORG  = evalue(ZONE(Z)+"("+num$(D)+")") 
  Call CONVERT(DEVORG,DEVDES,GSYSCUR,1,date$,MTORG,MTDES,STAT) From TRTDEV 
  Assign ZONE(Z)+"("+num$(D)+")" With MTDES
 Next D 
Next Z 
For Z=1 To NCUR
 For D=0 To RCUR(Z)-1
  Assign ZCUR(Z)+"("+num$(D)+")" With DEVDES
 Next D
Next Z
GCUR = DEVDES
For I=1 To dim(GDEV1)
 GDEV1(I) = DEVDES
Next I
Gosub SETDEV From TRTDIV
For MA=0 To NBMASK
 If FLMSK(MA)
  Gosub SETMASK From =WINPROG2
  Affzo
 Endif
Next MA
Return

########################################################
$CHARGE_ZONE
If MSK<>""
 Read [AMK]CODMSK = MSK
 If fstat : Return : Endif
 ONZON = NZON : ONCUR = NCUR
 For [AMZ]CODTYP Where CODMSK=MSK & SAIAFF<3
  K = find(left$([F:AMZ]CODTYP,2),"MD","MC","MS")
  K *= instr(1,"0123456789",mid$([F:AMZ]CODTYP,3,1))
  K *= (evalue("dim([M]"+[F:AMZ]CODZON+")")>0)
  If K
   NZON += 1 
   ZONE(NZON) = [F:AMZ]CODZON 
   Case left$([F:AMZ]CODTYP,2)
    When "MD"
     Read [AMP]CODPAR = 1;MSK;[F:AMZ]CODZON;"DEVISE" 
     If !fstat
      DEV(NZON) = [F:AMP]VALPAR 
     Else
      DEV(NZON) = "GCUR" : # Spécial pour le format MD5
     Endif
    When "MC"
     DEV(NZON) = "GDEV1("+mid$([F:AMZ]CODTYP,3,1)+")"
    When "MS"
     DEV(NZON) = "GLOCALDEV"
     Read [AMP]CODPAR = 1;MSK;[F:AMZ]CODZON;"SITE" 
     If !fstat
      ISIT = find(evalue([F:AMP]VALPAR),GSITE(1..GNBSITE))
      If ISIT
       ISOC = find(GSOCSITE(ISIT),GSOC(1..GNBSOC))
       If ISOC
        DEV(NZON) = '"'+GDEVSOC(ISOC)+'"'
       Endif
      Endif
     Endif
   Endcase
   If [F:AMK]TYPBLOC([F:AMZ]NUMBLOC-1)=1 
    TABZON(NZON) = evalue("[M]"+[F:AMK]BASPAG([F:AMZ]NUMBLOC-1)) 
   Else 
    TABZON(NZON) = evalue("dim([M]"+ZONE(NZON)+")") 
   Endif 
  Endif
 Next 
 For [AMZ]CODTYP Where CODTYP="CUR" & CODMSK=MSK & SAIAFF<3
  If evalue("dim([M]"+[F:AMZ]CODZON+")")>0
   NCUR += 1 
   ZCUR(NCUR) = "[M:"+ABR+"]"+[F:AMZ]CODZON 
   If [F:AMK]TYPBLOC([F:AMZ]NUMBLOC-1)=1 
    RCUR(NCUR) = evalue("[M]"+[F:AMK]BASPAG([F:AMZ]NUMBLOC-1)) 
   Else 
    RCUR(NCUR) = evalue("dim("+ZCUR(NCUR)+")") 
   Endif
  Endif
 Next
 If ONZON<>NZON or ONCUR<>NCUR
  FLMSK(I) = 1
 Endif
Endif
Return
  
########################################################
$RESTAURE
For I=0 To NBMASK
 If FLMSK(I)
  MA = I : Gosub SETMASK From =WINPROG2
  Case I
   When 0  : [M] = [M:S00_]
   When 1  : [M] = [M:S01_]
   When 2  : [M] = [M:S02_]
   When 3  : [M] = [M:S03_]
   When 4  : [M] = [M:S04_]
   When 5  : [M] = [M:S05_]
   When 6  : [M] = [M:S06_]
   When 7  : [M] = [M:S07_]
   When 8  : [M] = [M:S08_]
   When 9  : [M] = [M:S09_]
   When 10 : [M] = [M:S10_]
   When 11 : [M] = [M:S11_]
   When 12 : [M] = [M:S12_]
   When 13 : [M] = [M:S13_]
   When 14 : [M] = [M:S14_]
   When 15 : [M] = [M:S15_]
  Endcase
 Endif
Next I
GCUR = SAVCUR
For I=1 To dim(GDEV1)
 GDEV1(I) = SAVDEV(I)
Next I
Gosub SETDEV From TRTDIV
Return

$ERREUR
GMESSAGE = errp-"("+num$(errl)+")"-errmes$(errn)-errm
Call ERREUR(GMESSAGE) From GESECRAN
End

########################################################
Subprog OUVMSK(NBMASK,MSK,FLMSK) 
Value Integer NBMASK
Value Char    MSK()()
Value Integer FLMSK()
Local Integer I
For I=0 To NBMASK
 If FLMSK(I)
  Case I
   When 0  : Global Mask =MSK(I) [S00_]
   When 1  : Global Mask =MSK(I) [S01_]
   When 2  : Global Mask =MSK(I) [S02_]
   When 3  : Global Mask =MSK(I) [S03_]
   When 4  : Global Mask =MSK(I) [S04_]
   When 5  : Global Mask =MSK(I) [S05_]
   When 6  : Global Mask =MSK(I) [S06_]
   When 7  : Global Mask =MSK(I) [S07_]
   When 8  : Global Mask =MSK(I) [S08_]
   When 9  : Global Mask =MSK(I) [S09_]
   When 10 : Global Mask =MSK(I) [S10_]
   When 11 : Global Mask =MSK(I) [S11_]
   When 12 : Global Mask =MSK(I) [S12_]
   When 13 : Global Mask =MSK(I) [S13_]
   When 14 : Global Mask =MSK(I) [S14_]
   When 15 : Global Mask =MSK(I) [S15_]
  Endcase
 Endif
Next I
Global Mask EURO [EUR]
End 
