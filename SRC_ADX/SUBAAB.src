#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("AAB",GBIDC1,GBIDC2) From GOBJET
End

########################################
$ACTION
Case ACTION
 When "SEL_TABLE" : Gosub SEL_TABLE
Endcase
Return

########################################
# Action Seltable SELABR
########################################
$SEL_TABLE
Local Char ABR(15)
ABR = VALEUR
OBJET = "AAB"
Return

########################################
Subprog INIABR
GBOUT2 = mess(119,123,1) : # Abrév
End

########################################
Subprog C_ABREV(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M]ABREV) From OBJDIV
End

Subprog C_MOT(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M]MOT) From OBJDIV
End

