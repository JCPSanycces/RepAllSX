#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################################################################
#   Traitement de gestion d'un appel entrant                           Module CRM         28 juillet 2000
#########################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When "AVANT_MEN"    : Gosub AVANT_MEN
 When "FIR"          : Gosub PREMIER
 When "SUI"          : Gosub SUIVANT
 When Default
Endcase
Return

$PREMIER
Gosub LOADFIRST
Affzo [M:DOO4]
Return

$SUIVANT
If [M:DOO4]NBRBPC <= dim([M:DOO4]BPRNUM)
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712, 196, 2)
    GERR = 2
    Return
Endif

Gosub LOADNEXT
Affzo [M:DOO4]
Return

$OUVRE
If !clalev([F:DBL]) : Local File DOOBPCLNK [DBL] : Endif
Return

$DEFBOUT
Return

$SETBOUT
ETABOU(GVALI) = 1
Return

$OUVRE_BOITE
Return

$DEBUT
If PARAM(1) = ""
    #Aucun donneur d'ordre n'a été identifié.
    GMESSAGE = mess(410, 182, 2)
    GERR = 1
    FIN = 1
    Return
Endif

Read [BPR] BPR0 = PARAM(1)
If fstat
    #Aucun donneur d'ordre n'a été identifié.
    GMESSAGE = mess(410, 182, 2)
    GERR = 1
    FIN = 1
    Return
Endif

[M:DOO4]DOONUM = PARAM(1)
[M:DOO4]TTR = mess(411, 182, 2) + " " + [F:BPR]BPRNAM + " (" + [F:BPR]BPRNUM + ")."

Gosub LOADFIRST
Affzo [M:DOO4]
Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$AVANT_MEN
Return

$FINSAI
#Nettoie l'écran avant de partir.
Raz [M:DOO4]
Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
Return

$BOUTON
Return

$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################
$LOADFIRST
Local Integer ITER
ITER = 0

Raz [M:DOO4]NBBPC
Raz [M:DOO4]BPRNUM
Raz [M:DOO4]BPRNAM
Raz [M:DOO4]NBRBPC

Filter [DBL] Where [F:DBL]DOONUM = [M:DOO4]DOONUM Order By [F:DBL]BPCNUM Asc

For [DBL]
    If ITER < dim([M:DOO4]BPRNUM)
        [M:DOO4]BPRNUM(ITER) = [F:DBL]BPCNUM
        [M:DOO4]BPRNAM(ITER) = [F:DBL]BPCNAM
        [M:DOO4]NBBPC += 1
    Endif
    ITER += 1
Next

Filter [DBL]

[M:DOO4]NBRBPC = ITER

Return

#########################################################
$LOADNEXT

If [M:DOO4]NBBPC = 0 : Return : Endif

Local Integer ITER
Local Char SZFIRSTBPC
ITER = 0
SZLASTBPC = [M:DOO4]BPRNUM([M:DOO4]NBBPC - 1)

Raz [M:DOO4]NBBPC
Raz [M:DOO4]BPRNUM
Raz [M:DOO4]BPRNAM

Filter [DBL] Where [F:DBL]DOONUM = [M:DOO4]DOONUM and [F:DBL]BPCNUM >= SZLASTBPC Order By [F:DBL]BPCNUM Asc

For [DBL]
    If ITER >= dim([M:DOO4]BPRNUM) : Break : Endif

    [M:DOO4]BPRNUM(ITER) = [F:DBL]BPCNUM
    [M:DOO4]BPRNAM(ITER) = [F:DBL]BPCNAM
    [M:DOO4]NBBPC += 1
Next

Filter [DBL]

Return

