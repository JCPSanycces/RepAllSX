#<AdxTL>@(#)8.0.0.0 $Revision$

##########################################################################################
## Fonctions de gestion des clobs                                   Type                ##
##########################################################################################
## instr      : Funprog INSTR_   (DEB,CLOB,CHAINE)                  Integer             ##
## left$      : Funprog LEFT_    (CLOB,LNG)                         Clob                ##
## right$     : Funprog RIGHT_   (CLOB,DEB)                         Clob                ##
## mid$       : Funprog MID_     (CLOB,DEB,LNG)                     Clob                ##
## seg$       : Funprog SEG_     (CLOB,DEB,FIN)                     Clob                ##
## toupper    : Funprog TOUPPER_ (CLOB)                             Clob                ##
## tolower    : Funprog TOLOWER_ (CLOB)                             Clob                ##
## ctrans     : Funprog CTRANS_  (CLOB,CHAINE1,CHAINE2)             Clob                ##
## vireblc    : Funprog VIREBLC_ (CLOB,OPTION)                      Clob                ##
## string$    : Funprog STRING_  (NOMBRE,CLOB)                      Clob                ##
## string$    : Funprog STRINGC_ (NOMBRE,CHAINE)                    Clob                ##
## space$     : Funprog SPACE_   (NOMBRE)                           Clob                ##
## concat (+) : Funprog PLUS_    (CLOB1,CHAINE,CLOB2)               Clob                ##
## concat (-) : Funprog MOINS_   (CLOB1,CHAINE,CLOB2)               Clob                ##
## replace    : Funprog RPL_     (CLOB,DEB,CHAINE1,CHAINE2,NOMBRE)  Clob                ##
## to clob    : Funprog CLOB_    (CHAINE)                           Clob                ##
## to char    : Funprog CHAR_    (CLOB)                             Chaîne              ##
##########################################################################################
## Lignes => Clob     Subprog CNVCLOB(NBLIG,LIGNES,CLOB)                                ##
## Clob   => Lignes   Subprog CNVLIG(CLOB,NBLIG,LIGNES)                                 ##
##########################################################################################

$DEFTXT
Local Integer I , J , K , L
Local Integer MAXTEX , LG
LG = 127
MAXTEX  = int((512*(2^^GLONACB)-1)/LG)+1
MAXTEX += 10
Local  Char    TEXTE(LG)(1..MAXTEX)
Global Clbfile WCLOB(GLONACB)
Return

$SETCLOB
Gosub DEFTXT
Setlob TEXTE With CLOB
K = 0 : While TEXTE(K+1)<>"" : K += 1 : Wend
Return

$RETCLOB
If K>0
 Setlob WCLOB With TEXTE(1..K)
Endif
End WCLOB

Funprog CLOB_(CHAINE)
Value Char CHAINE
Gosub DEFTXT
K = 0
For I=0 To dim(CHAINE)-1
 If CHAINE(I)<>""
  If len(CHAINE(I))<=LG
   K += 1 : TEXTE(K) = CHAINE(I)
  Else
   K += 1 : TEXTE(K) = left$(CHAINE(I),LG)
   K += 1 : TEXTE(K) = right$(CHAINE(I),LG+1)
  Endif
 Endif
Next I
Goto RETCLOB

Funprog CHAR_(CLOB)
Value Clbfile CLOB
Local Char CHAINE(255)
Setlob CHAINE With CLOB
End CHAINE

Funprog INSTR_(DEB,CLOB,CHAINE)
Value Integer DEB
Value Clbfile CLOB
Value Char    CHAINE
Gosub SETCLOB
L = 0
For I=1 To K
 If DEB<=LG*I
  J = instr(max(DEB-LG*(I-1),1),TEXTE(I)+TEXTE(I+1),left$(CHAINE,LG))
  If J
   If len(CHAINE)<=LG
    L = LG*(I-1)+J : Break
   Else
    If right$(CHAINE,LG+1)=left$(right$(TEXTE(I+1),J+1)+TEXTE(I+2),len(CHAINE)-LG)
     L = LG*(I-1)+J : Break
    Endif
   Endif
  Endif
 Endif
Next I
End L

Funprog LEFT_(CLOB,LNG)
Value Clbfile CLOB
Value Integer LNG
Gosub DEFTXT
If LNG>0
 Setlob TEXTE With CLOB
 K = int((LNG-1)/LG)
 J = LNG-LG*K
 TEXTE(K+1) = left$(TEXTE(K+1),J)
 Setlob WCLOB With TEXTE(1..K+1)
Endif
End WCLOB

Funprog RIGHT_(CLOB,LNG)
Value Clbfile CLOB
Value Integer LNG
Gosub DEFTXT
Setlob TEXTE With CLOB
If LNG>0
 K = int((LNG-1)/LG)
 J = LNG-LG*K
 TEXTE(K+1) = right$(TEXTE(K+1),J)
Endif
Setlob WCLOB With TEXTE(K+1..MAXTEX)
End WCLOB

Funprog MID_(CLOB,DEB,LNG)
Value Clbfile CLOB
Value Integer DEB
Value Integer LNG
Gosub DEFTXT
Setlob TEXTE With CLOB
If DEB>0 & LNG>0
 K = int((DEB-1)/LG)
 J = DEB-LG*K
 TEXTE(K+1) = right$(TEXTE(K+1),J+1)
 I = len(TEXTE(K+1))
 If LNG<=I
  TEXTE(K+1) = left$(TEXTE(K+1),LNG)
  Setlob WCLOB With TEXTE(K+1)
 Else
  J = int((LNG-I-1)/LG)+2
  TEXTE(K+J) = left$(TEXTE(K+J),LNG-I-LG*(J-2))
  Setlob WCLOB With TEXTE(K+1..K+J)
 Endif
Endif
End WCLOB

Funprog SEG_(CLOB,DEB,FIN)
Value Clbfile CLOB
Value Integer LNG
Gosub DEFTXT
Setlob TEXTE With CLOB
If FIN>=DEB & DEB>0
 K = int((DEB-1)/LG)
 J = DEB-LG*K
 L = int((FIN-1)/LG)
 I = FIN-LG*L
 If K=L
  TEXTE(K+1) = seg$(TEXTE(K+1),J,I)
 Else
  TEXTE(K+1) = right$(TEXTE(K+1),J)
  TEXTE(L+1) = left$(TEXTE(L+1),I)
 Endif
 Setlob WCLOB With TEXTE(K+1..L+1)
Endif
End WCLOB

Funprog PLUS_(CLOB,CHAINE,CLOB2)
Value Clbfile CLOB
Value Char    CHAINE
Value Clbfile CLOB2
Gosub SETCLOB
Local Char    TEXTE2(LG)(1..MAXTEX)
For I=0 To dim(CHAINE)-1
 If CHAINE(I)<>""
  If len(CHAINE(I))<=LG
   K += 1 : TEXTE(K) = CHAINE(I)
  Else
   K += 1 : TEXTE(K) = left$(CHAINE(I),LG)
   K += 1 : TEXTE(K) = right$(CHAINE(I),LG+1)
  Endif
 Endif
Next I
Setlob TEXTE2 With CLOB2
I = 1
While TEXTE2(I)<>""
 K += 1 : TEXTE(K) = TEXTE2(I)
 I += 1
Wend
Goto RETCLOB

Funprog MOINS_(CLOB,CHAINE,CLOB2)
Value Clbfile CLOB
Value Char    CHAINE
Value Clbfile CLOB2
Gosub SETCLOB
Local Char    TEXTE2(LG)(1..MAXTEX)
Setlob TEXTE2 With CLOB2
L = 0 : While TEXTE2(L+1)<>"" : L += 1 : Wend
If K>0
 I = K+1
 Repeat
  I -= 1
  TEXTE(I) = vireblc(TEXTE(I),1)
  If TEXTE(I)="" : K = I-1 : Endif
 Until I<=1 or TEXTE(I)<>""
Endif
For I=0 To dim(CHAINE)-1
 If CHAINE(I)<>""
  K += 1
  If K=1 : TEXTE(K) = "" : Else : TEXTE(K) = " " : Endif
  If len(CHAINE(I))<LG-1
   TEXTE(K) += vireblc(CHAINE(I),2)
  Else
   TEXTE(K) += left$(vireblc(CHAINE(I),2),LG-2)
   K += 1 : TEXTE(K) = right$(vireblc(CHAINE(I),2),LG-1)
  Endif
 Endif
Next I
If K>0 & L>0
 If len(TEXTE(K))<LG
  TEXTE(K) += " "
 Else
  K += 1 : TEXTE(K) = " "
 Endif
Endif
If L>0
 I = 0
 Repeat
  I += 1
  TEXTE2(I) = vireblc(TEXTE2(I),0)
 Until I>=L or TEXTE2(I)<>""
 For I=1 To L
  If TEXTE2(L)<>""
   K += 1 : TEXTE(K) = TEXTE2(I)
  Endif
 Next I
Endif
Goto RETCLOB

Funprog RPL_(CLOB,DEB,CHAINE1,CHAINE2,NOMBRE)
Value Clbfile CLOB
Value Integer DEB
Value Char    CHAINE1
Value Char    CHAINE2
Value Integer NOMBRE
Gosub DEFTXT
Local Clbfile WCLOB1(GLONACB)
Local Clbfile WCLOB2(GLONACB)
WCLOB = CLOB
I = NOMBRE
J = max(DEB,1)
Repeat
 K = func ACB.INSTR_(J,WCLOB,CHAINE1)
 If K
  WCLOB1 = func ACB.LEFT_(WCLOB,K-1)
  WCLOB2 = func ACB.RIGHT_(WCLOB,K+len(CHAINE1))
  WCLOB  = func ACB.PLUS_(WCLOB1,CHAINE2,WCLOB2)
  J  = K+len(CHAINE2)
  I -= 1
 Endif
Until K=0 or I=0
End WCLOB

Funprog TOUPPER_(CLOB)
Value Clbfile CLOB
Gosub SETCLOB
For I=1 To K : TEXTE(I) = toupper(TEXTE(I)) : Next I
Goto RETCLOB

Funprog TOLOWER_(CLOB)
Value Clbfile CLOB
Gosub SETCLOB
For I=1 To K : TEXTE(I) = tolower(TEXTE(I)) : Next I
Goto RETCLOB

Funprog STRING_(NOMBRE,CLOB)
Value Integer NOMBRE
Value Clbfile CLOB
Gosub SETCLOB
If NOMBRE>0
 L = K
 For I=1 To NOMBRE-1
  For J=1 To K
   L += 1
   TEXTE(L) = TEXTE(J)
  Next J
 Next I
Endif
K = L
Goto RETCLOB

Funprog STRINGC_(NOMBRE,CHAINE)
Value Integer NOMBRE
Value Char    CHAINE
Gosub DEFTXT
If NOMBRE>0
 K = 1
 For I=1 To NOMBRE
  If len(TEXTE(K))+len(CHAINE)<=LG
   TEXTE(K) += CHAINE
  Else
   K += 1 : TEXTE(K) = left$(CHAINE,LG)
   If len(CHAINE)>LG
    K += 1 : TEXTE(K) = right$(CHAINE,LG+1)
   Endif
  Endif
 Next I
Endif
Goto RETCLOB

Funprog SPACE_(NOMBRE)
Value Integer NOMBRE
Gosub DEFTXT
If NOMBRE>0
 K = int((NOMBRE-1)/LG)
 J = NOMBRE-LG*K
 For I=1 To K
  TEXTE(I) = space$(LG)
 Next I
 K += 1 : TEXTE(K) = space$(J)
Endif
Goto RETCLOB

Funprog CTRANS_(CLOB,CHAINE1,CHAINE2)
Value Clbfile CLOB
Value Char    CHAINE1
Value Char    CHAINE2
Gosub SETCLOB
For I=1 To K
 If CHAINE1=""
  TEXTE(I) = ctrans(TEXTE(I))
 Else
  TEXTE(I) = ctrans(TEXTE(I),CHAINE1,CHAINE2)
 Endif
Next I
Goto RETCLOB

Funprog VIREBLC_(CLOB,OPTION)
Value Clbfile CLOB
Value Integer OPTION
Gosub SETCLOB
Case OPTION
 When 0,1,2
  If OPTION=0 | OPTION=2             : # En début de chaîne
   I = 0
   Repeat
    I += 1
    TEXTE(I) = vireblc(TEXTE(I),0)
   Until I>=K or TEXTE(I)<>""
  Endif
  If OPTION=1 | OPTION=2             : # En fin de chaîne
   I = K+1
   Repeat
    I -= 1
    TEXTE(I) = vireblc(TEXTE(I),1)
   Until I<=1 or TEXTE(I)<>""
  Endif
 When 3                             : # Au début en tronquant à l'espace suivant
  I = 0
  Repeat
   I += 1
   TEXTE(I) = vireblc(TEXTE(I),0)
  Until I>=K or TEXTE(I)<>""
  While I<=K
   J = instr(1,TEXTE(I)," ")
   If J
    TEXTE(I) = left$(TEXTE(I),J-1)
    K = I : Break
   Endif
   I += 1
  Wend
 When 4                             : # Dans toute la chaîne
  For I=1 To K
   TEXTE(I) = vireblc(TEXTE(I),4)
  Next I
 When 5                             : # Espaces consécutifs
  For I=1 To K
   TEXTE(I) = vireblc(TEXTE(I),5)
   If I<=K & right$(TEXTE(I),len(TEXTE(I)))=" "
    TEXTE(I+1) = vireblc(TEXTE(I+1),0)
   Endif
  Next I
Endcase
Goto RETCLOB

##########################################################################################

$CRLF
Local Char CRLF(2)
CRLF = chr$(13)+chr$(10)
Return

Subprog CNVCLOB(NBLIG,LIGNES,CLOB)
Value    Integer NBLIG
Value    Char    LIGNES()(1..)
Variable Clbfile CLOB
Gosub DEFTXT
Gosub CRLF
Local Char BUFFER(255)
K = 1
For I=1 To NBLIG
 BUFFER = LIGNES(I)
 While BUFFER<>""
  L = LG-len(TEXTE(K))
  If len(BUFFER)<=L
   TEXTE(K) += BUFFER
   BUFFER    = ""
  Else
   TEXTE(K) += left$(BUFFER,L)
   BUFFER    = right$(BUFFER,L+1)
   K += 1
  Endif
 Wend
 If len(TEXTE(K))+len(CRLF)<=LG
  TEXTE(K) += CRLF
 Else
  K += 1 : TEXTE(K) = CRLF
 Endif
Next I
Setlob CLOB With TEXTE(1..K)
End

Subprog CNVLIG(CLOB,NBLIG,LIGNES)
Value    Clbfile CLOB
Variable Integer NBLIG
Variable Char    LIGNES()(1..)
Gosub SETCLOB
Gosub CRLF
Local Char    BUFFER(255)
Local Integer CR
BUFFER = ""
NBLIG  = 0
L = type(LIGNES)-10
For I=1 To K
 Repeat
  CR = instr(1,TEXTE(I)+left$(TEXTE(I+1),len(CRLF)-1),CRLF)
  If CR
   BUFFER += left$(TEXTE(I),CR-1)
   If BUFFER=""
    NBLIG += 1
   Else
    Gosub SETLIG
   Endif
   If CR>len(TEXTE(I))-len(CRLF)+1
    TEXTE(I+1) = right$(TEXTE(I+1),CR-len(TEXTE(I))+len(CRLF))
   Endif
   TEXTE(I) = right$(TEXTE(I),CR+len(CRLF))
  Endif
 Until CR=0
 BUFFER += TEXTE(I)
Next I
Gosub SETLIG
End

$SETLIG
While BUFFER<>""
 NBLIG += 1
 If len(BUFFER)>L
  LIGNES(NBLIG) = left$(BUFFER,L)
  BUFFER        = right$(BUFFER,L+1)
 Else
  LIGNES(NBLIG) = BUFFER
  BUFFER        = ""
 Endif
Wend
Return



