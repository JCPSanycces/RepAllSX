#<AdxTL>@(#)0.0.0.0 $Revision$
# Class PRETURND_CSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"    : Gosub AREAD_AFTER
        When "AINIT"          : Gosub AINIT
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "INIT_TSICODADI" : Gosub INIT_TSICODADI
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#  Case [L]CURPRO
#     Case [L]ARULE
#     Endcase
#  Endcase
Return

################################################################################
$AREAD_AFTER
  Local Integer IRET

  #IRET = fmet this.INIT_TSCCODADI() # 108613.o
   IRET = fmet this.INIT_TSICODADI   # 108613.n

  this.VAT1 = [F:PND]VAT(0) : Call LOAD_VAT_LEG(this,"VAT1","VAT1_LEG")
  this.VAT2 = [F:PND]VAT(1) : Call LOAD_VAT_LEG(this,"VAT2","VAT2_LEG")
  this.VAT3 = [F:PND]VAT(2) : Call LOAD_VAT_LEG(this,"VAT3","VAT3_LEG")
  Call LOAD_VAT_LEG(this,"TAXRCP","VATLEG")
Return

################################################################################
$AINIT
  Local Integer IRET

  #IRET = fmet this.INIT_TSCCODADI()  # 108613.o
   IRET = fmet this.INIT_TSICODADI     # 108613.n
Return

################################################################################
$INIT_TSICODADI
  Local Integer DIM_STI
  Local Integer NI

  DIM_STI = func ASYRFNC.ACTIV("STI")
  # -------------------
  For NI = 1 To DIM_STI
    this.C_TSICOD(NI).TSICODADI = NI + 20
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

################################################################################
Subprog LOAD_VAT_LEG(SOBJET, VATPRO, LEGPRO)
Variable Instance SOBJET Using OBJECT
Value Char VATPRO
Value Char LEGPRO

  Local Integer IRET
  Local Char LEG(GLONADI)

  If evalue("SOBJET."+VATPRO)=""
    End
  Endif
  If SOBJET.APARENT=null
    End
  Endif
  # ------------------------
  Local File TABVAT [TVT]

  If func AFNC.ACTIV("LEG") = 0 Then
    [L]LEG = fmet SOBJET.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, SOBJET.ACTX.AFOLDER, "DOSLEG")
  Else
    If dim(SOBJET.APARENT.LEG) > 0 Then
      [L]LEG = SOBJET.APARENT.LEG
    Endif
    If [L]LEG="" : Call LEG_FROM_CPY_FCY(SOBJET.APARENT, [L]LEG) : Endif
  Endif
  If [L]LEG<>""
    Read [TVT]TVT0=evalue("SOBJET."+VATPRO);[L]LEG
    If fstat
      Read [TVT]TVT0=evalue("SOBJET."+VATPRO);""
    Endif
  Else
    Read [TVT]TVT0(1)=evalue("SOBJET."+VATPRO)
  Endif
  If !fstat
    [L]LEG = [F:TVT]LEG
  Endif
  Assign "SOBJET."+LEGPRO With [L]LEG

  LogicClose File [TVT]
End

Return

################################################################################
Subprog LEG_FROM_CPY_FCY(SOBJET, LEG)
Variable Instance SOBJET Using OBJECT
Variable Char LEG

  #--Cas particulier : pas de SOBJET.LEG mais société ou site en ligne
  Local File COMPANY  [CPY]
  Local File FACILITY [FCY]

  If [L]LEG = "" and (SOBJET.CPY<>"" | (dim(SOBJET.PNHFCY) >= 0 and SOBJET.PNHFCY <> "")) Then
    If dim(SOBJET.PNHFCY) >= 0 and SOBJET.PNHFCY <> "" Then
      If [F:FCY]FCY <> SOBJET.PNHFCY Then
        Read [F:FCY]FCY0=SOBJET.PNHFCY
        If fstat
          Raz [F:FCY]
        Endif
      Endif
      If SOBJET.CPY = "" Then
        SOBJET.CPY = [F:FCY]LEGCPY
      Endif
    Endif
    If SOBJET.CPY <> "" Then
      If [F:CPY]CPY<>SOBJET.CPY
        Read [F:CPY]CPY0=SOBJET.CPY
        If fstat
          Raz [F:CPY]
        Endif
      Endif
      [L]LEG = [F:CPY]LEG
    Endif
  Endif

  LogicClose File [CPY],[FCY]
End

