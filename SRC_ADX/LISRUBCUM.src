#<AdxTL>@(#)1.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Char    CRITERE(255), PARAM(30), VALEUR(30), ETAT(GLONARP)
Local Integer PER, NUMREQ, WNUMLIG

If clalev([F:RUB])=0  : Local File RUBRIQUE [RUB] : Endif
If clalev([F:CUM])=0  : Local File CUMUL    [CUM] : Endif
If clalev([F:ARM])=0  : Local File AREPORTM [ARM] : Endif

CRITERE  = "1=1"

For I=0 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "__REQUETE" : [L]NUMREQ = val([L]VALEUR)
   When "X3ETA"     : [L]ETAT   = [L]VALEUR
   When "cumdeb"    : If [L]VALEUR<>""
                       [L]CRITERE -= ' & ([F:CUM]CUMCOD>="'+[L]VALEUR+'")'
                      Endif
   When "cumfin"    : If [L]VALEUR<>""
                       [L]CRITERE -= ' & ([F:CUM]CUMCOD<="'+[L]VALEUR+'")'
                      Endif
   When "per"       : If [L]VALEUR="1" : [L]PER=1 : Else : [L]PER=0 : Endif
   When "cumper"    : If [L]VALEUR<>"" & [L]PER=1
                       [L]CRITERE -= ' & ([F:CUM]CUMPER ='+[L]VALEUR+')'
                      Endif

  Endcase
 Endif
Next

# Affectation du no de requête
PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Call DEBTRANS From GLOCK
Gosub TR1
Gosub TR2
End

$TR1
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$
Commit
Return

$TR2
Trbegin [ARM]
Filter [CUM] Where evalue(CRITERE) and LEG=GCURLEG
Filter [RUB] Where (TYPRUB=5 | NBRCUM>0) and LEG=GCURLEG
For [CUM]CUM0
 For [RUB]
  # Cumul Ligne
  I = find([F:CUM]CUMCOD,[F:RUB]CUM(0..[F:RUB]NBRCUM-1))
  If I
   WNUMLIG +=1
   [F:ARM]USR     = GUSER
   [F:ARM]RPTCOD  = [L]ETAT
   [F:ARM]NUMREQ  = [L]NUMREQ
   [F:ARM]NUMLIG  = [L]WNUMLIG
   [F:ARM]CLEA1   = [F:RUB]CUM(I-1)
   [F:ARM]CLEN1   = [F:RUB]ROW
   [F:ARM]CLEN2   = [F:RUB]OPTCUM(I-1)
   #91750
   [F:ARM]CLEA2   = [F:RUB]CNDCUM(I-1)
   [F:ARM]CREDAT  = date$
   Write [F:ARM]
   If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Break : Endif
  Endif

  If [F:RUB]TYPRUB=5
   # Cumul Tranche
   I = find([F:CUM]CUMCOD,[F:RUB]CUMAMT(0..dim([F:RUB]CUMAMT)-1))
   If I
    WNUMLIG +=1
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [L]ETAT
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = [L]WNUMLIG
    [F:ARM]CLEA1   = [F:RUB]CUMAMT(I-1)
    [F:ARM]CLEN1   = [F:RUB]ROW
    [F:ARM]CLEN2   = 6+(I-1) : # Menu local 372
    #91750
    [F:ARM]CLEA2   = ""
    [F:ARM]CREDAT  = date$
    Write [F:ARM]
    If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Break : Endif
   Endif
   # Cumul Plafond
   I = find([F:CUM]CUMCOD,[F:RUB]CUMMAX(0..dim([F:RUB]CUMAMT)-1))
   If I
    WNUMLIG +=1
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [L]ETAT
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = [L]WNUMLIG
    [F:ARM]CLEA1   = [F:RUB]CUMMAX(I-1)
    [F:ARM]CLEN1   = [F:RUB]ROW
    [F:ARM]CLEN2   = 9+(I-1) : # Menu local 372
    #91750
    [F:ARM]CLEA2   = ""
    [F:ARM]CREDAT  = date$
    Write [F:ARM]
    If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Break : Endif
   Endif
   # Cumul base
   If [F:RUB]CUMBAS=[F:CUM]CUMCOD
    WNUMLIG +=1
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [L]ETAT
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = [L]WNUMLIG
    [F:ARM]CLEA1   = [F:RUB]CUMBAS
    [F:ARM]CLEN1   = [F:RUB]ROW
    [F:ARM]CLEN2   = 12 : # Menu local 372
    #91750
    [F:ARM]CLEA2   = ""
    [F:ARM]CREDAT  = date$
    Write [F:ARM]
    If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Break : Endif
   Endif
  Endif

 Next
Next
Filter [CUM]
Filter [RUB]
If GOK=0 : Rollback : Return : Endif
Commit
Return
