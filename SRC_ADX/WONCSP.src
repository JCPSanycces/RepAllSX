$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(20)(0..GNBDERNIER)
Local Libelle  A_BUF2(0..GNBDERNIER)
Local Char     A_BUF3(70)(0..GNBDERNIER)
Local Char     A_BUF4(5)(0..GNBDERNIER)
Local Char     A_BUF5(20)(0..GNBDERNIER)
Local Char     A_BUF6(10)(0..GNBDERNIER)
Local Char     A_BUF7(10)(0..GNBDERNIER)
Local Char     A_BUF8(10)(0..GNBDERNIER)
Local Char     A_BUF9(10)(0..GNBDERNIER)
Local Libelle  A_BUF10(0..GNBDERNIER)
If clalev([F:PLAHDR9])>0 : Close Local File [PLAHDR9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(20),
& Libelle  A_TAB2,
& Char     A_TAB3(70),
& Char     A_TAB4(5),
& Char     A_TAB5(20),
& Char     A_TAB6(10),
& Char     A_TAB7(10),
& Char     A_TAB8(10),
& Char     A_TAB9(10),
& Libelle  A_TAB10
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6,A_BUF7,A_BUF8,A_BUF9,A_BUF10
& As [PLAHDR9]
Return

$LEC_DERLU
Read [NCSRC]NCSRC0=[F:PLAHDR]PLANID
If fstat : Raz [F:NCSRC] : Endif
Read [AXXM]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSMANAGER;""
If fstat : Raz [F:AXXM] : Endif
Read [AXXP]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSPLANNER;""
If fstat : Raz [F:AXXP] : Endif
Return

$CHARGE_DERLU
If clalev([F:PLAHDR9])>0
 Read [PLAHDR9] = [F:PLAHDR9]A_TABI
 [L]CLE = [F:PLAHDR9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:PLAHDR9])>0
 Filter [PLAHDR9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [NCSP1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:PLAHDR9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:PLAHDR]PLANID+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:PLAHDR9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:PLAHDR9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 4
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:PLAHDR]PLANID"
Call TEXTE(12966,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:PLAHDR]PLANID"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:NCSRC]NCSSTA"
Call TEXTE(1179,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 1
SELFMT(NBSEL) = "LA02033:20X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:NCSRC]NCSSTA"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:NCSRC]TITLE"
Call TEXTE(6468,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:70X"
SELFOR(NBSEL) = "K:70X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:NCSRC]TITLE"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:NCSRC]SITE"
Call TEXTE(53310,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:NCSRC]SITE"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:NCSRC]PRODUCT"
Call TEXTE(19528,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:NCSRC]PRODUCT"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:NCSRC]ECCVALMAJ"
Call TEXTE(44206,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:NCSRC]ECCVALMAJ"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:NCSRC]ECCVALMIN"
Call TEXTE(44208,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:NCSRC]ECCVALMIN"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(8)"
SELEXP(NBSEL) = "[NCSRC]NCSMANAGER-[AXXM]TEXTE"
Call TEXTE(54345,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(9)"
SELEXP(NBSEL) = "[NCSRC]NCSPLANNER-[AXXP]TEXTE"
Call TEXTE(9996,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[F:PLAHDR]PLANSTATUS"
Call TEXTE(34228,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 1
SELFMT(NBSEL) = "LA02045:15X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:PLAHDR]PLANSTATUS"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:PLAHDR_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:NCSRC])=0 : Local file NCSRECENT [NCSRC] : Endif
If clalev([F:AXXM])=0 : Local file ATEXTRA [AXXM] : Endif
If clalev([F:AXXP])=0 : Local file ATEXTRA [AXXP] : Endif
Link [PLAHDR] With
& [NCSRC]NCSRC0=[F:PLAHDR]PLANID,
& [AXXM]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSMANAGER;"",
& [AXXP]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSPLANNER;""
& As [PLAHDR_]
[G:PLAHDR_]currind = 1
Return

$DEFAUT_LISTE
