#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion du fichier GPGRILLE
Call OBJET("GRI",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
  When "SETBOUT"  : Gosub SETBOUT
  When "OUVRE"    : Gosub OUVRE
  When "LIENS"    : Gosub LIENS
  When "FERME"      : Gosub FERME
  When "AP_CHANGE" : Gosub AP_CHANGE
  When "ANNULE"    : Gosub ANNULE
  When "CREATION"  : Gosub CREATION
  When "MODIF"     : Gosub MODIF
  When Default
Endcase

Return

$OUVRE
  If clalev ([F:GRI])=0 : Local File GRILLE  [GRI] : Endif
  If clalev ([F:RIL])=0 : Local File GGRILLE [RIL] : Endif

  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Return

$SETBOUT
  If REP<>"" | !CLECUR | GHISTO=1
    Call VIREBOUT(CHAINE,"8") From GOBJET
  Endif

Return

$LIENS
  GCURLEG = [F:GRI]LEG
  If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
  Call LECTEXTRA([M]DES,"GRILLE","DES",[M]COD,"") From ATEXTRA
  Call LECTEXTRA([M]DESSHO,"GRILLE","DESSHO",[M]COD,"") From ATEXTRA

#JASMI - 2016-02-18 - Req 114309 - START
  Call DISPLAY_HIDE From SUBGRILEG
#JASMI - 2016-02-18 - Req 114309 - END

#### JASMI busy testing
#Call DISPLAY_AND_HIDE_FIELDS_AUTO("OGRI") From DIVPAYE

Return

########################################
$CREATION
$MODIF
  Gosub TEXTRA
  If GOK<1 : Return : Endif

Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
$TEXTRA
  If GREP="D"
   ## In duplication mode we want to keep all translated texts
    Call DUPTEXTRA("GRILLE","DES",CLECUR1,"","GRILLE","DES",[F:GRI]COD,"")  From ATEXTRA
    Call DUPTEXTRA("GRILLE","DESSHO",CLECUR1,"","GRILLE","DESSHO",[F:GRI]COD,"")  From ATEXTRA
  Endif
  Call MAJTEXTRA([M]DES,"GRILLE","DES",[F:GRI]COD,"") From ATEXTRA
  Call MAJTEXTRA([M]DESSHO,"GRILLE","DESSHO",[F:GRI]COD,"") From ATEXTRA

Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
  Call CHGTEXTRA("GRILLE","DES",[L]OCODE,"",[L]NCODE,"") From ATEXTRA
  Call CHGTEXTRA("GRILLE","DESSHO",[L]OCODE,"",[L]NCODE,"") From ATEXTRA

Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
  Call SUPTEXTRA("GRILLE","DES",[L]CODE,"") From ATEXTRA
  Call SUPTEXTRA("GRILLE","DESSHO",[L]CODE,"") From ATEXTRA

Return

$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

Return
######################################################################################

Subprog AS_PIO(VALEUR)
Variable Integer  VALEUR
  If [M]VALMAX<>2 | [M]VALMIN<>2
   mkstat = 2 : End
  Endif

End

Subprog AS_CMPTYP(VALEUR)
Variable Integer VALEUR
  GMENLOC(4)=1

End

Subprog AS_COLTYP(VALEUR)
Variable Integer VALEUR
  GMENLOC(4)=1

End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  GCURLEG=VALEUR

#JASMI - 2016-02-18 - Req 114309 - START
  Call DISPLAY_HIDE From SUBGRILEG
#JASMI - 2016-02-18 - Req 114309 - END

End


######################################################################################

