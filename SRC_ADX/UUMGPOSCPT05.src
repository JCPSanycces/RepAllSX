#<AdxTL>@(#)6.0.0.0 $Revision$
############################################################################
# UUMGPOSCPT05                                          Module  Accounting #
#                                                                          #
#              Post-migration of Budget Entry                              #
#                                                                          #
# Management of new field  : UOM                                           #
#                                                                          #
############################################################################
Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSCPT05") From LECFIC
  Endif

  #Call RAZ_UUMGPOSCPT05(DOSSIER)
  Call MAJ_UUMGPOSCPT05(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

########################################################################
Subprog RAZ_UUMGPOSCPT05(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(1)<>2 : End : Endif

Call MIGRAZKEY (DOSSIER,"UUMGPOSCPT05",ERR) From TRTMIG

End
###################################################################################
Subprog MAJ_UUMGPOSCPT05(DOSSIER)
Value Char DOSSIER
Local Integer NBLUS, NBCOMMIT, ERR, OK

If [F:ADS]MODULE(1)<>2 or func DOSSUB.ISHISTFOLD(DOSSIER)
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT05",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT05",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT05",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>=GMIGX3VER60
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT05",3,ERR) From TRTMIG : End
Endif

Call ECR_TIME("UUMGPOSCPT05 Budget Process : Update BUD - Fields : UOM") From DOSSUB
Call ECR_TRACE("UUMGPOSCPT05 : Process Start on : "+DOSSIER,0) From GESECRAN

#--------------- Index addition  ----------#
Call MIGINDCRE (DOSSIER,"BUD","BUD+ACC+ACCNUM","","",0,ERR) From TRTMIG
If ERR :
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT05",7,ERR) From TRTMIG : Goto FIN
Endif

#--------------- Opening of files  -----#
If clalev([F:BUD]) : Close File [BUD] : Endif
If clalev([F:BUD])  = 0 : Local File =DOSSIER+".BUD"      [BUD]  : Endif
If clalev([F:BUP])  = 0 : Local File =DOSSIER+".BUDPAR"   [BUP]  : Endif

If clalev([F:GRY])=0 : Local File =DOSSIER+".GACCGRUPYM" [GRY] : Endif
If clalev([F:GAC])=0 : Local File =DOSSIER+".GACCOUNT"   [GAC] : Endif

#-----  Declaration of Variables
# Variables to Handle Loops Ruptures
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1(30), ACLE2(30), ACLE3(30), ACLE4(30)
Local Integer ICLE1, ICLE2, ICLE3
Local Date DCLE1

Raz NBLUS, NBCOMMIT, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CPT05
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:BUD]UOM='' & [F:BUD]BUD='"+ACLE1+"' & [F:BUD]ACC='"+ACLE2+"' & [F:BUD]ACCNUM>"+num$(ICLE1)
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:BUD]UOM='' & [F:BUD]BUD='"+ACLE1+"' & [F:BUD]ACC>'"+ACLE2+"'"
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:BUD]UOM='' & [F:BUD]BUD>'"+ACLE1+"'"
Else
 CRITERE = "[F:BUD]UOM='' & 1=1"
Endif

Trbegin [BUD]
GOK = 1

For [BUD]MIG(1) Where evalue(CRITERE)

 # By Budget
 If [F:BUP]BUD<>[F:BUD]BUD
  Read [BUP]BUP0 =  [F:BUD]BUD
  # Non-existent Budget
  If fstat : GOK = 0 : Call ERREUR("BUDTYP"-[F:BUD]BUD-mess(21,103,1),4) From DOSDIC : Goto NEXT1 : Endif
 Endif

 If [F:BUP]PYMACC=""

  For [BUD]MIG(2)
   If [F:GAC]ACC<>[F:BUD]ACC | [F:GAC]COA<>[F:BUD]COA
    Read [GAC]GAC0 = [F:BUD]COA;[F:BUD]ACC
   Endif

   For [BUD]MIG
    NBLUS+=1
    If [F:BUD]UOM<>[F:GAC]UOM
     [F:BUD]UOM=[F:GAC]UOM
     Gosub WRITE_BUD
     If !GOK | STOP=1 : Break 3 : Endif
    Endif
   Next
  Next

 Else

  For [BUD]MIG(2)
   Read [GRY]GRY0 = [F:BUP]PYMACC;[F:GAC]ACC;1
   If fstat : Goto FBUD : Endif

   For [BUD]MIG
    NBLUS+=1

    If [F:BUD]UOM<>[F:GRY]UOM
     [F:BUD]UOM = [F:GRY]UOM
     Gosub WRITE_BUD
     If !GOK | STOP=1 : Break 3 : Endif
    Endif
   Next
  $FBUD
  Next
 Endif

$NEXT1
Next

If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT05",7,ERR) From TRTMIG
Else
  Commit
  Call MIGSTKPROGRESS (DOSSIER,"UUMGPOSCPT05",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_CPT05
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST
Close Local File [BUD]

#--------------- Deleting an index ----------#
Call MIGINDDEL (DOSSIER,"BUD",ERR) From TRTMIG


$FIN
Call MIGTRTEND (DOSSIER,"UUMGPOSCPT05") From TRTMIG
Call ECR_TIME("UUMGPOSCPT05 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

$WRITE_BUD

  Rewrite [F:BUD]
  If fstat
   Call ECR_TRACE("File BUD(ACCNUM)"-num$([F:BUD]ACCNUM)+", Error ="-num$(fstat),1) From GESECRAN
   GOK=0 : Return
  Endif

  NBCOMMIT += 1
  NB+=1
  If NB>GMAXUPDTRS
   ACLE1 = [F:BUD]BUD
   ACLE2 = [F:BUD]ACC
   ICLE1 = [F:BUD]ACCNUM
   STOP=1
  Endif
 Return

