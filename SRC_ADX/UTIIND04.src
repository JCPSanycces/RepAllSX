#<AdxTL>@(#)12.0.0.0 $Revision$
################################################################################################
# UTIIND04   Moulinette                                                                        #
# - Validation dictionnaire limitée aux types de données touchés dans les lots patchés dans P4 #
# - Validation dictionnaire limitée aux actions touchées dans les lots patchés dans P4         #
# - Mise à jour forcée de l'onglet sélection des objets touchés dans les lots patchés dans P4  #
# - Validation des objets et fenêtres correspondant                                            #
# - Validation dictionnaire des éventuels types de données correspondant à ces objets          #
################################################################################################
  Local Integer OK
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Moulinette UTIIND04") From LECFIC
  If nomap<>GDOSX3
    Call MAJ_UTIIND04(nomap)
  Else
    Call OUINON("Exécuter cette moulinette sur l'ensemble des dossiers de la solution",OK) From GESECRAN
    If OK<>2 : End : Endif
    If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
    For [ADS]
      If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
        Call MAJ_UTIIND04([F:ADS]DOSSIER)
      Endif
    Next
  Endif
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
End

Subprog MAJ_UTIIND04(DOSSIER)
Value Char DOSSIER

  Local Char WOBJET(GLONAOB), WTYP(GLONATY), WACTION(GLONACT)
  Local Integer COMPTEUR, I
  Local Integer VALMOD(20)
  
  If DOSSIER=GDOSX3 : End : Endif
  
  Call ECR_TRACE("UTIIND04 : Process Start on : "+DOSSIER,0) From GESECRAN

  Local File ATYPE [XATY]

  For I=0 To dim(VALMOD)-1
    VALMOD(I) = 2
  Next I

# Types de données
  For WTYP = "KCO","SMI"
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE("UTIIND04 : Processing Data type"-WTYP,0) From GESECRAN
    Call VALID_TRT(DOSSIER,0,WTYP,"","","","","Z","","Z","","","","Z","","","","Z",VALMOD) From VALDICO
    COMPTEUR += 1
  Next WTYP
  
  Call ECR_TRACE("UTIIND04 : "+num$(COMPTEUR)+" data types processed",0) From GESECRAN

# Actions
  Raz COMPTEUR
  For WACTION = "SAIEMPLIB","STKCTREMP","STKCTREMPS","STKCTRSRG","STKCTRTLO","STKSELEMP","STKSELQUA"
&              ,"STKSUGEMP","STKSUGTLO","SUGEMPENT","WRHINIT","CONTFASPHY","INICPY2","PHYRENUM","SELBCO2"
&              ,"SELCPY","SELPHY2","SELSIXCOR","SELSIXCOR1","SELSIXCOR2","SIMIG","SITDGL","SITRAFIL"
&              ,"SITRAZ","SITSIG","CONSPRH","TRTMAJDET","SELVCRMOD"
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE("UTIIND04 : Processing Action"-WACTION,0) From GESECRAN
    Call VALID_TRT(DOSSIER,0,"","",WACTION,"","","","","Z","","","","Z","","","","",VALMOD) From VALDICO
    COMPTEUR += 1
  Next WACTION
  
  Call ECR_TRACE("UTIIND04 : "+num$(COMPTEUR)+" actions processed",0) From GESECRAN

# Objets
  Raz COMPTEUR
  For WOBJET = "CDA","COA","GDE","GTE","JOU","LED","TFB","MFS","PHY","PY2"
&             ,"PY3","PY4","PY7","MWS","KCO","SIP","SIT"
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE("UTIIND04 : Processing Object"-WOBJET,0) From GESECRAN
    Call MAJ_SEL(DOSSIER,WOBJET) From PATCHAOB
    Call VALID_TRT(DOSSIER,0,"","","","","","","","",WOBJET,WOBJET,"","","","","","",VALMOD) From VALDICO
    Call VALFEN(DOSSIER,WOBJET) From SUBAOB
# Type de données lié à l'objet (s'il existe)
    Raz WTYP
    For [XATY] Where OBJLIEN=WOBJET
      WTYP = [F:XATY]CODTYP
    Next XATY
    If WTYP<>""
      Call ECR_TRACE("UTIIND04 : Processing linked data type"-WTYP,0) From GESECRAN
      Call VALID_TRT(DOSSIER,0,WTYP,"","","","","Z","","Z","","","","Z","","","","Z",VALMOD) From VALDICO
    Endif
    COMPTEUR += 1
  Next WOBJET
  
  Call ECR_TRACE("UTIIND04 : "+num$(COMPTEUR)+" objects processed",0) From GESECRAN

  Close Local File [XATY]

End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
  If APPLI=GDOSX3 : End : Endif
  Call MAJ_UTIIND04(APPLI)
End

#######################################################################
# Pour exécution depuis DOSMAJ (validation dossier)
#######################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
  If APPLI=GDOSX3 : End : Endif
  Call MAJ_UTIIND04(APPLI)
End
