#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################################
#   Traitement de gestion de la saisie des détail de couverture                       Module CRM        2 juillet 2003
##########################################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "RAF"          : Gosub REFRESH
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When "OK"           : Gosub ONOK
 When Default
Endcase
Return

$REFRESH
Call TEMPON("L") From GESECRAN
Gosub LOADCCV
Call TEMPOFF From GESECRAN

Affzo [M:CCV1]
Affzo [M:CCV2]
Affzo [M:CCV3]
Return

$OUVRE
Global Char GSZCCV0TPLEVAL
Global Char GSZCCV0INTEVAL

#PARAM(1) : Code contrat
#PARAM(2) : Flag Modèle
#PARAM(3) : Type d'identification du parc
#PARAM(4) : Code parc couvert
#PARAM(5) : Clé enregistrement couverture parc
#PARAM(6) : Composant
#PARAM(7) : Devise
#PARAM(8) : N° de la ligne parc appelante
#PARAM(9) : Famille de compétence
#PARAM(10) : Code client
#PARAM(11) = Couverture croisée identique

If PARAM(1) = ""
    #Aucun code de contrat de service n'a été obtenu. Action abandonnée.
    GMESSAGE = mess(265, 182, 2)
    GERR = 1
    FIN = 1
    Return
Endif

If PARAM(5) = "" & PARAM(6) = "" & PARAM(9) = ""
    #Aucun identifiant de parc à couvrir n'a été fourni. Action abandonnée.
    GMESSAGE = mess(273, 182, 2)
    GERR = 1
    FIN = 1
    Return
Endif

If PARAM(7) = ""
    #Aucune devise n'a été fournie. Action abandonnée.
    GMESSAGE = mess(280, 182, 2)
    GERR = 1
    FIN = 1
    Return
Endif

Case PARAM(3)
    When "1"
        Call TEXTE(16568, GSZCCV0INTEVAL) From OBJDIV      #Parc
    When "2"
        Call TEXTE(3651, GSZCCV0INTEVAL) From OBJDIV      #Article
    When "3"
        Call TEXTE(20562, GSZCCV0INTEVAL) From OBJDIV      #Famille commerciale
    When Default
        Call TEXTE(16568, GSZCCV0INTEVAL) From OBJDIV      #Parc
Endcase

If val(PARAM(2)) = 2
    Call TEXTE(15810, GSZCCV0TPLEVAL) From OBJDIV      #Modèle de contrat
Else
    Call TEXTE(5481, GSZCCV0TPLEVAL) From OBJDIV      #Contrat
Endif

Return

$DEFBOUT
Return

$SETBOUT
If [M:CCV0]CNNCPN = ""
    ETAMEN(1) = 0
Else
    ETAMEN(1) = 1
Endif

If [M:CCV0]DIRTYFLG
    ETABOU(GVALI) = 1
Else
    ETABOU(GVALI) = 0
Endif

#Menu Rafraichissement
ETABOU(GRAFF) = 1
Return

$OUVRE_BOITE
Return

$DEBUT
#Affichage de l'en-tête
Local Integer IADINUM
IADINUM = 19 + GFAMCIA

[M:CCV0]CONHNOL = val(PARAM(8))
[M:CCV0]TPL = val(PARAM(2))
[M:CCV0]CONNUM = PARAM(1)
[M:CCV0]CONPBL = PARAM(9)
[M:CCV0]CONBPC = PARAM(10)
[M:CCV0]CRSCOVSAM = val(PARAM(11))

#Devises
[M:CCV0]CUR = PARAM(7)
[M:CCV1]ACCVCUR4 = [M:CCV0]CUR
[M:CCV1]ACCVCUR5 = [M:CCV0]CUR
[M:CCV2]BCCVCUR4 = [M:CCV0]CUR
[M:CCV2]BCCVCUR5 = [M:CCV0]CUR
[M:CCV3]CCCVCUR4 = [M:CCV0]CUR
[M:CCV3]CCCVCUR5 = [M:CCV0]CUR

If PARAM(6) = ""
    [M:CCV0]CNNCPN = ""
    [M:CCV0]CNNCPNDES = ""
Else
    [M:CCV0]CNNCPN = PARAM(6)
    Read [ITM] ITM0 = PARAM(6)
    If fstat
        [M:CCV0]CNNCPNDES = ""
    Else
        #Call LECTEXTRA([M:CCV0]CNNCPNDES, "ITMMASTER", "DES1AXX", PARAM(6), "") From ATEXTRA
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CCV0]CNNCPNDES, "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
#        [M:CCV0]CNNCPNDES = [F:ITM]ITMDES1
    Endif
Endif

If PARAM(4) = ""
    [M:CCV0]CONMACCOD = ""
    [M:CCV0]MACDES = ""
Else
    Case PARAM(3)
        When "1"
            Read [MAC] MAC0 = PARAM(4)
            If fstat
                [M:CCV0]CONMACCOD = ""
                [M:CCV0]MACDES = ""
            Else
                [M:CCV0]CONMACCOD = PARAM(4)
                Read [ITM] ITM0 = [F:MAC]MACPDTCOD
                If fstat
                    [M:CCV0]MACDES = ""
                Else
                    #Call LECTEXTRA([M:CCV0]MACDES, "ITMMASTER", "DES1AXX", [F:MAC]MACPDTCOD, "") From ATEXTRA
                    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CCV0]MACDES, "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
#                    [M:CCV0]MACDES = [F:ITM]ITMDES1
                Endif
            Endif
        When "2"
            [M:CCV0]CONMACCOD = PARAM(4)
            Read [ITM] ITM0 = PARAM(4)
            If fstat
                [M:CCV0]MACDES = ""
            Else
                #Call LECTEXTRA([M:CCV0]MACDES, "ITMMASTER", "DES1AXX", PARAM(4), "") From ATEXTRA
                Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CCV0]MACDES, "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
#                [M:CCV0]MACDES = [F:ITM]ITMDES1
            Endif
        When "3"
            [M:CCV0]CONMACCOD = PARAM(4)
            Call GET_LIB(IADINUM, PARAM(4), [M:CCV0]MACDES) From CRM_UTIL
    Endcase
Endif

#Chargement des onglets
Gosub LOADCCV

Affzo [M:CCV0]
Affzo [M:CCV1]
Affzo [M:CCV2]
Affzo [M:CCV3]
Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$FINSAI
Kill GSZCCV0INTEVAL
Kill GSZCCV0TPLEVAL

#Nettoie l'écran avant de partir.
Raz [M:CCV0]
Raz [M:CCV1]
Raz [M:CCV2]
Raz [M:CCV3]

Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
[M:CCV0]DIRTYFLG = 1
Return

$BOUTON
Return

$ONMENU
Case BOUT
    When "G"
        Gosub RECUPCOV
    When Default
Endcase


Return

$ONOK
Gosub ONSAVE
FIN = 0
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################
$ONSAVE
Local Integer J
Local Integer IERRINF
Local Integer IPBLSRTFLG
J = 0
IERRINF = 0

If [M:CCV0]CONPBL <> "" & [M:CCV0]CONMACCOD = "" & [M:CCV0]CNNCPN = ""
    IPBLSRTFLG = 1
Else
    IPBLSRTFLG = 0
Endif

Call DEBTRANS From GLOCK
Trbegin [CCV]
If [M:CCV0]TPL = 2
    Delete [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                  and [F:CCV]TPL = 2
&                  and [F:CCV]RECTYP = "AAA"
&                  and [F:CCV]PAEKEY(0) = [M:CCV0]CONPBL
&                  and [F:CCV]PAEKEY(1) = PARAM(5)
&                  and [F:CCV]PAEKEY(2) = PARAM(6)
Else
    Delete [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                  and [F:CCV]TPL <> 2
&                  and [F:CCV]RECTYP = "AAA"
&                  and [F:CCV]PAEKEY(0) = [M:CCV0]CONPBL
&                  and [F:CCV]PAEKEY(1) = PARAM(5)
&                  and [F:CCV]PAEKEY(2) = PARAM(6)
Endif

If fstat
    #Erreur lors de l'enregistrement du détail de la couverture.
    GMESSAGE = mess(269, 182, 2)
    GERR = 1
    Rollback
Else
    Commit
Endif

If GERR : Return : Endif

#Enregistrement des lignes saisies
#Pièces
Call DEBTRANS From GLOCK
Trbegin [CCV]
J = 0
For J = 0 To [M:CCV1]NBITM - 1
    If [M:CCV1]ANUM(J) <> ""
        Raz [F:CCV]
        [F:CCV]CONNUM = [M:CCV0]CONNUM
        [F:CCV]TPL = [M:CCV0]TPL
        [F:CCV]BPC = [M:CCV0]CONBPC
        [F:CCV]RECTYP = "AAA"
        [F:CCV]SBBRECTYP = "ITM"

        [F:CCV]ICDFLG = [M:CCV1]ACCVICDFLG(J)
        [F:CCV]RECNUM = [M:CCV1]ANUM(J)
        [F:CCV]CMT = [M:CCV0]CONMACCOD

        [F:CCV]PAEKEY(0) = [M:CCV0]CONPBL
        [F:CCV]PAEKEY(1) = PARAM(5)
        [F:CCV]PAEKEY(2) = PARAM(6)

        Case PARAM(3)
            When "1"
                #Parc
                [F:CCV]PAEKEYTYP(1) = "MAC"
                [F:CCV]CPNSRT = "CAAACPNMAC"
            When "2"
                #Article
                [F:CCV]PAEKEYTYP(1) = "ITM"
                [F:CCV]CPNSRT = "BAAACPNITM"
            When "3"
                #Famille commerciale
                [F:CCV]PAEKEYTYP(1) = "CIA"
                [F:CCV]CPNSRT = "AAAACPNCIA"
            When Default
                [F:CCV]PAEKEYTYP(1) = ""
                [F:CCV]CPNSRT = ""
        Endcase

        If IPBLSRTFLG 
            [F:CCV]CPNSRT = "DAAAPBL"
        Endif

        [F:CCV]HEIPRC = [M:CCV1]AHEIPRC(J)
        [F:CCV]MINCOV = [M:CCV1]AMINCOV(J)
        [F:CCV]MAXCOV = [M:CCV1]AMAXCOV(J)

        Write [CCV]
        If fstat
            #Erreur lors de l'enregistrement du détail de la couverture des pièces.
            GMESSAGE = mess(270, 182, 2)
            GERR = 1
            Rollback
            Break
        Endif
    Endif
Next

If GERR
    Return
Else
    Commit
Endif

#Enregistrement des lignes saisies
#Main d'oeuvre
Call DEBTRANS From GLOCK
Trbegin [CCV]
J = 0
For J = 0 To [M:CCV2]NBLAB - 1
    If [M:CCV2]BNUM(J) <> ""
        Raz [F:CCV]
        [F:CCV]CONNUM = [M:CCV0]CONNUM
        [F:CCV]TPL = [M:CCV0]TPL
        [F:CCV]BPC = [M:CCV0]CONBPC
        [F:CCV]RECTYP = "AAA"
        [F:CCV]SBBRECTYP = "LAB"

        [F:CCV]ICDFLG = [M:CCV2]BCCVICDFLG(J)
        [F:CCV]RECNUM = [M:CCV2]BNUM(J)
        [F:CCV]CMT = [M:CCV0]CONMACCOD

        [F:CCV]PAEKEY(0) = [M:CCV0]CONPBL
        [F:CCV]PAEKEY(1) = PARAM(5)
        [F:CCV]PAEKEY(2) = PARAM(6)

        Case PARAM(3)
            When "1"
                #Parc
                [F:CCV]PAEKEYTYP(1) = "MAC"
                [F:CCV]CPNSRT = "CAAACPNMAC"
            When "2"
                #Article
                [F:CCV]PAEKEYTYP(1) = "ITM"
                [F:CCV]CPNSRT = "BAAACPNITM"
            When "3"
                #Famille commerciale
                [F:CCV]PAEKEYTYP(1) = "CIA"
                [F:CCV]CPNSRT = "AAAACPNCIA"
            When Default
                [F:CCV]PAEKEYTYP(1) = ""
                [F:CCV]CPNSRT = ""
        Endcase

        If IPBLSRTFLG 
            [F:CCV]CPNSRT = "DAAAPBL"
        Endif

        [F:CCV]HEIPRC = [M:CCV2]BHEIPRC(J)
        [F:CCV]MINCOV = [M:CCV2]BMINCOV(J)
        [F:CCV]MAXCOV = [M:CCV2]BMAXCOV(J)

        Write [CCV]
        If fstat
            #Erreur lors de l'enregistrement du détail de la couverture de la main d'oeuvre
            GMESSAGE = mess(271, 182, 2)
            GERR = 1
            Rollback
            Break
        Endif
    Endif
Next

If GERR
    Return
Else
    Commit
Endif

#Enregistrement des lignes saisies
#Frais
Call DEBTRANS From GLOCK
Trbegin [CCV]
J = 0
For J = 0 To [M:CCV3]NBEXS - 1
    If [M:CCV3]CNUM(J) <> ""
        Raz [F:CCV]
        [F:CCV]CONNUM = [M:CCV0]CONNUM
        [F:CCV]TPL = [M:CCV0]TPL
        [F:CCV]BPC = [M:CCV0]CONBPC
        [F:CCV]RECTYP = "AAA"
        [F:CCV]SBBRECTYP = "EXS"

        [F:CCV]ICDFLG = [M:CCV3]CCCVICDFLG(J)
        [F:CCV]RECNUM = [M:CCV3]CNUM(J)
        [F:CCV]CMT = [M:CCV0]CONMACCOD

        [F:CCV]PAEKEY(0) = [M:CCV0]CONPBL
        [F:CCV]PAEKEY(1) = PARAM(5)
        [F:CCV]PAEKEY(2) = PARAM(6)

        Case PARAM(3)
            When "1"
                #Parc
                [F:CCV]PAEKEYTYP(1) = "MAC"
                [F:CCV]CPNSRT = "CAAACPNMAC"
            When "2"
                #Article
                [F:CCV]PAEKEYTYP(1) = "ITM"
                [F:CCV]CPNSRT = "BAAACPNITM"
            When "3"
                #Famille commerciale
                [F:CCV]PAEKEYTYP(1) = "CIA"
                [F:CCV]CPNSRT = "AAAACPNCIA"
            When Default
                [F:CCV]PAEKEYTYP(1) = ""
                [F:CCV]CPNSRT = ""
        Endcase

        If IPBLSRTFLG 
            [F:CCV]CPNSRT = "DAAAPBL"
        Endif

        [F:CCV]HEIPRC = [M:CCV3]CHEIPRC(J)
        [F:CCV]MINCOV = [M:CCV3]CMINCOV(J)
        [F:CCV]MAXCOV = [M:CCV3]CMAXCOV(J)

        Write [CCV]
        If fstat
            #Erreur lors de l'enregistrement du détail de la couverture des frais.
            GMESSAGE = mess(272, 182, 2)
            GERR = 1
            Rollback
            Break
        Endif
    Endif
Next

If GERR
    Return
Else
    Commit
Endif

#Enregistrement des inclusions et exclusions globales
Call DEBTRANS From GLOCK
Trbegin [CCV]
If PARAM(5) = "" & PARAM(6) = "" & PARAM(9) <> ""
    Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                  and [F:CCV]TPL = [M:CCV0]TPL
&                  and [F:CCV]RECTYP = "PBL"
&                  and [F:CCV]RECNUM = PARAM(9)

    For [CCV]
        [F:CCV]ITMICDFLG = [M:CCV1]ITMICDFLG
        [F:CCV]HEIPRC(0) = [M:CCV1]ITMHEIPRC
        [F:CCV]MINCOV(0) = [M:CCV1]ITMMINCOV
        [F:CCV]MAXCOV(0) = [M:CCV1]ITMMAXCOV

        [F:CCV]LABICDFLG = [M:CCV2]LABICDFLG
        [F:CCV]HEIPRC(1) = [M:CCV2]LABHEIPRC
        [F:CCV]MINCOV(1) = [M:CCV2]LABMINCOV
        [F:CCV]MAXCOV(1) = [M:CCV2]LABMAXCOV

        [F:CCV]EXSICDFLG = [M:CCV3]EXSICDFLG
        [F:CCV]HEIPRC(2) = [M:CCV3]EXSHEIPRC
        [F:CCV]MINCOV(2) = [M:CCV3]EXSMINCOV
        [F:CCV]MAXCOV(2) = [M:CCV3]EXSMAXCOV
        Rewrite [CCV]
        If fstat
            #Erreur lors de l'enregistrement du détail de la couverture.
            GMESSAGE = mess(269, 182, 2)
            GERR = 1
            Rollback
        Else
            Commit
        Endif
        Break
    Next

    Filter [CCV]

    [M:CONF]PBLITMICD([M:CCV0]CONHNOL) = [M:CCV1]ITMICDFLG
    [M:CONF]PBLIHEIPRC([M:CCV0]CONHNOL) = [M:CCV1]ITMHEIPRC
    [M:CONF]PBLIMINCOV([M:CCV0]CONHNOL) = [M:CCV1]ITMMINCOV
    [M:CONF]PBLIMAXCOV([M:CCV0]CONHNOL) = [M:CCV1]ITMMAXCOV

    [M:CONF]PBLLABICD([M:CCV0]CONHNOL) = [M:CCV2]LABICDFLG
    [M:CONF]PBLLHEIPRC([M:CCV0]CONHNOL) = [M:CCV2]LABHEIPRC
    [M:CONF]PBLLMINCOV([M:CCV0]CONHNOL) = [M:CCV2]LABMINCOV
    [M:CONF]PBLLMAXCOV([M:CCV0]CONHNOL) = [M:CCV2]LABMAXCOV

    [M:CONF]PBLEXSICD([M:CCV0]CONHNOL) = [M:CCV3]EXSICDFLG
    [M:CONF]PBLEHEIPRC([M:CCV0]CONHNOL) = [M:CCV3]EXSHEIPRC
    [M:CONF]PBLEMINCOV([M:CCV0]CONHNOL) = [M:CCV3]EXSMINCOV
    [M:CONF]PBLEMAXCOV([M:CCV0]CONHNOL) = [M:CCV3]EXSMAXCOV
Else
    If PARAM(6) = ""
        Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                      and [F:CCV]TPL = [M:CCV0]TPL
&                      and [F:CCV]RECTYP = "MAC"
&                      and [F:CCV]RECNUM = PARAM(5)
&                      and [F:CCV]PAEKEY(0) = [M:CCV0]CONPBL

        For [CCV]
            [F:CCV]ITMICDFLG = [M:CCV1]ITMICDFLG
            [F:CCV]HEIPRC(0) = [M:CCV1]ITMHEIPRC
            [F:CCV]MINCOV(0) = [M:CCV1]ITMMINCOV
            [F:CCV]MAXCOV(0) = [M:CCV1]ITMMAXCOV

            [F:CCV]LABICDFLG = [M:CCV2]LABICDFLG
            [F:CCV]HEIPRC(1) = [M:CCV2]LABHEIPRC
            [F:CCV]MINCOV(1) = [M:CCV2]LABMINCOV
            [F:CCV]MAXCOV(1) = [M:CCV2]LABMAXCOV

            [F:CCV]EXSICDFLG = [M:CCV3]EXSICDFLG
            [F:CCV]HEIPRC(2) = [M:CCV3]EXSHEIPRC
            [F:CCV]MINCOV(2) = [M:CCV3]EXSMINCOV
            [F:CCV]MAXCOV(2) = [M:CCV3]EXSMAXCOV
            Rewrite [CCV]
            If fstat
                #Erreur lors de l'enregistrement du détail de la couverture.
                GMESSAGE = mess(269, 182, 2)
                GERR = 1
                Rollback
            Else
                Commit
            Endif
            Break
        Next

        Filter [CCV]

        [M:CONH]CITITMICD([M:CCV0]CONHNOL) = [M:CCV1]ITMICDFLG
        [M:CONH]CITIHEIPRC([M:CCV0]CONHNOL) = [M:CCV1]ITMHEIPRC
        [M:CONH]CITIMINCOV([M:CCV0]CONHNOL) = [M:CCV1]ITMMINCOV
        [M:CONH]CITIMAXCOV([M:CCV0]CONHNOL) = [M:CCV1]ITMMAXCOV

        [M:CONH]CITLABICD([M:CCV0]CONHNOL) = [M:CCV2]LABICDFLG
        [M:CONH]CITLHEIPRC([M:CCV0]CONHNOL) = [M:CCV2]LABHEIPRC
        [M:CONH]CITLMINCOV([M:CCV0]CONHNOL) = [M:CCV2]LABMINCOV
        [M:CONH]CITLMAXCOV([M:CCV0]CONHNOL) = [M:CCV2]LABMAXCOV

        [M:CONH]CITEXSICD([M:CCV0]CONHNOL) = [M:CCV3]EXSICDFLG
        [M:CONH]CITEHEIPRC([M:CCV0]CONHNOL) = [M:CCV3]EXSHEIPRC
        [M:CONH]CITEMINCOV([M:CCV0]CONHNOL) = [M:CCV3]EXSMINCOV
        [M:CONH]CITEMAXCOV([M:CCV0]CONHNOL) = [M:CCV3]EXSMAXCOV
    Else
        Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                      and [F:CCV]TPL = [M:CCV0]TPL
&                      and [F:CCV]RECTYP = "CPN"
&                      and [F:CCV]RECNUM = PARAM(6)
&                      and [F:CCV]PAEKEY(0) = [M:CCV0]CONPBL
&                      and [F:CCV]PAEKEY(1) = PARAM(5)

        For [CCV]
            [F:CCV]ITMICDFLG = [M:CCV1]ITMICDFLG
            [F:CCV]HEIPRC(0) = [M:CCV1]ITMHEIPRC
            [F:CCV]MINCOV(0) = [M:CCV1]ITMMINCOV
            [F:CCV]MAXCOV(0) = [M:CCV1]ITMMAXCOV

            [F:CCV]LABICDFLG = [M:CCV2]LABICDFLG
            [F:CCV]HEIPRC(1) = [M:CCV2]LABHEIPRC
            [F:CCV]MINCOV(1) = [M:CCV2]LABMINCOV
            [F:CCV]MAXCOV(1) = [M:CCV2]LABMAXCOV

            [F:CCV]EXSICDFLG = [M:CCV3]EXSICDFLG
            [F:CCV]HEIPRC(2) = [M:CCV3]EXSHEIPRC
            [F:CCV]MINCOV(2) = [M:CCV3]EXSMINCOV
            [F:CCV]MAXCOV(2) = [M:CCV3]EXSMAXCOV
            Rewrite [CCV]
            If fstat
                #Erreur lors de l'enregistrement du détail de la couverture.
                GMESSAGE = mess(269, 182, 2)
                GERR = 1
                Rollback
            Else
                Commit
            Endif
            Break
        Next

        Filter [CCV]

        [M:CONH]ITMICDFLG([M:CCV0]CONHNOL) = [M:CCV1]ITMICDFLG
        [M:CONH]CNNIHEIPRC([M:CCV0]CONHNOL) = [M:CCV1]ITMHEIPRC
        [M:CONH]CNNIMINCOV([M:CCV0]CONHNOL) = [M:CCV1]ITMMINCOV
        [M:CONH]CNNIMAXCOV([M:CCV0]CONHNOL) = [M:CCV1]ITMMAXCOV

        [M:CONH]LABICDFLG([M:CCV0]CONHNOL) = [M:CCV2]LABICDFLG
        [M:CONH]CNNLHEIPRC([M:CCV0]CONHNOL) = [M:CCV2]LABHEIPRC
        [M:CONH]CNNLMINCOV([M:CCV0]CONHNOL) = [M:CCV2]LABMINCOV
        [M:CONH]CNNLMAXCOV([M:CCV0]CONHNOL) = [M:CCV2]LABMAXCOV

        [M:CONH]EXSICDFLG([M:CCV0]CONHNOL) = [M:CCV3]EXSICDFLG
        [M:CONH]CNNEHEIPRC([M:CCV0]CONHNOL) = [M:CCV3]EXSHEIPRC
        [M:CONH]CNNEMINCOV([M:CCV0]CONHNOL) = [M:CCV3]EXSMINCOV
        [M:CONH]CNNEMAXCOV([M:CCV0]CONHNOL) = [M:CCV3]EXSMAXCOV
    Endif
Endif

#Couverture croisée identique
If [M:CCV0]CONMACCOD <> ""
    If [M:CCV0]CRSCOVSAM = 2
        Call DOCRSCOVSAM([M:CCV0]CONNUM, [M:CCV0]CONPBL, [M:CCV0]TPL, IERRINF) From TRTCONH
        If IERRINF
            #Erreur lors de l'enregistrement de la couverture croisée à l'identique.
            GMESSAGE = mess(432, 182, 2)
            GERR = 1
            Return
        Endif
    Endif
Endif

[M:CCV0]DIRTYFLG = 0

Gosub LOADCCV

Affzo [M:CCV1]
Affzo [M:CCV2]
Affzo [M:CCV3]
Return

#########################################################################
# Chargement des trois onglets
#########################################################################
$LOADCCV

Raz [M:CCV1]ITMICDFLG
Raz [M:CCV1]ITMHEIPRC
Raz [M:CCV1]ITMMINCOV
Raz [M:CCV1]ITMMAXCOV

Raz [M:CCV2]LABICDFLG
Raz [M:CCV2]LABHEIPRC
Raz [M:CCV2]LABMINCOV
Raz [M:CCV2]LABMAXCOV

Raz [M:CCV3]EXSICDFLG
Raz [M:CCV3]EXSHEIPRC
Raz [M:CCV3]EXSMINCOV
Raz [M:CCV3]EXSMAXCOV

Raz [M:CCV1]NBITM
Raz [M:CCV1]ACCVICDFLG
Raz [M:CCV1]ANUM
Raz [M:CCV1]ANUMDES
Raz [M:CCV1]ACCVCUR1
Raz [M:CCV1]AHEIPRC
Raz [M:CCV1]ACCVCUR2
Raz [M:CCV1]AMINCOV
Raz [M:CCV1]AMAXCOV
Raz [M:CCV2]NBLAB
Raz [M:CCV2]BCCVICDFLG
Raz [M:CCV2]BNUM
Raz [M:CCV2]BNUMDES
Raz [M:CCV2]BCCVCUR1
Raz [M:CCV2]BHEIPRC
Raz [M:CCV2]BCCVCUR2
Raz [M:CCV2]BMINCOV
Raz [M:CCV2]BMAXCOV
Raz [M:CCV3]NBEXS
Raz [M:CCV3]CCCVICDFLG
Raz [M:CCV3]CNUM
Raz [M:CCV3]CNUMDES
Raz [M:CCV3]CCCVCUR1
Raz [M:CCV3]CHEIPRC
Raz [M:CCV3]CCCVCUR2
Raz [M:CCV3]CMINCOV
Raz [M:CCV3]CMAXCOV

Local Integer I1
Local Integer I2
Local Integer I3
I1 = 0
I2 = 0
I3 = 0

#Chargement des inclusions et exclusions globales
If PARAM(5) = "" & PARAM(6) = "" & PARAM(9) <> ""
    Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                  and [F:CCV]TPL = [M:CCV0]TPL
&                  and [F:CCV]RECTYP = "PBL"
&                  and [F:CCV]RECNUM = PARAM(9)
Else
    If PARAM(6) = ""
        Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                      and [F:CCV]TPL = [M:CCV0]TPL
&                      and [F:CCV]RECTYP = "MAC"
&                      and [F:CCV]RECNUM = PARAM(5)
&                      and [F:CCV]PAEKEY(0) = [M:CCV0]CONPBL
Else
        Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                      and [F:CCV]TPL = [M:CCV0]TPL
&                      and [F:CCV]RECTYP = "CPN"
&                      and [F:CCV]RECNUM = PARAM(6)
&                      and [F:CCV]PAEKEY(0) = [M:CCV0]CONPBL
&                      and [F:CCV]PAEKEY(1) = PARAM(5)
    Endif
Endif

For [CCV]
    [M:CCV1]ITMICDFLG = [F:CCV]ITMICDFLG
    [M:CCV1]ITMHEIPRC = [F:CCV]HEIPRC(0)
    [M:CCV1]ITMMINCOV = [F:CCV]MINCOV(0)
    [M:CCV1]ITMMAXCOV = [F:CCV]MAXCOV(0)

    [M:CCV2]LABICDFLG = [F:CCV]LABICDFLG
    [M:CCV2]LABHEIPRC = [F:CCV]HEIPRC(1)
    [M:CCV2]LABMINCOV = [F:CCV]MINCOV(1)
    [M:CCV2]LABMAXCOV = [F:CCV]MAXCOV(1)

    [M:CCV3]EXSICDFLG = [F:CCV]EXSICDFLG
    [M:CCV3]EXSHEIPRC = [F:CCV]HEIPRC(2)
    [M:CCV3]EXSMINCOV = [F:CCV]MINCOV(2)
    [M:CCV3]EXSMAXCOV = [F:CCV]MAXCOV(2)
Next

Filter [CCV]

If [M:CCV1]ITMICDFLG = 0
    [M:CCV1]ITMICDFLG = GITMICD
    If [M:CCV1]ITMICDFLG = 0
        [M:CCV1]ITMICDFLG = 1
    Endif
Endif

If [M:CCV2]LABICDFLG = 0
    [M:CCV2]LABICDFLG = GLABICD
    If [M:CCV2]LABICDFLG = 0
        [M:CCV2]LABICDFLG = 1
    Endif
Endif

If [M:CCV3]EXSICDFLG = 0
    [M:CCV3]EXSICDFLG = GEXSICD
    If [M:CCV3]EXSICDFLG = 0
        [M:CCV3]EXSICDFLG = 1
    Endif
Endif

#Chargement des pièces
If [M:CCV0]TPL = 2
    Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                  and [F:CCV]TPL = 2
&                  and [F:CCV]RECTYP = "AAA"
&                  and [F:CCV]PAEKEY(0) = [M:CCV0]CONPBL
&                  and [F:CCV]PAEKEY(1) = PARAM(5)
&                  and [F:CCV]PAEKEY(2) = PARAM(6)
&             Order By [F:CCV]RECNUM Asc
Else
    Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                  and [F:CCV]TPL <> 2
&                  and [F:CCV]RECTYP = "AAA"
&                  and [F:CCV]PAEKEY(0) = [M:CCV0]CONPBL
&                  and [F:CCV]PAEKEY(1) = PARAM(5)
&                  and [F:CCV]PAEKEY(2) = PARAM(6)
&             Order By [F:CCV]RECNUM Asc
Endif

For [CCV]

    Case [F:CCV]SBBRECTYP
        When "ITM"
            If I1 < dim([M:CCV1]ANUM)
                [M:CCV1]ACCVICDFLG(I1) = [F:CCV]ICDFLG
                [M:CCV1]ANUM(I1) = [F:CCV]RECNUM
                Read [ITM] ITM0 = [M:CCV1]ANUM(I1)
                If fstat
                    [M:CCV1]ANUMDES(I1) = ""
                Else
                    #Call LECTEXTRA([M:CCV1]ANUMDES(I1), "ITMMASTER", "DES1AXX", [M:CCV1]ANUM(I1), "") From ATEXTRA
                    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CCV1]ANUMDES(I1), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
#                    [M:CCV1]ANUMDES(I1) = [F:ITM]ITMDES1
                Endif

                [M:CCV1]AHEIPRC(I1) = [F:CCV]HEIPRC

                [M:CCV1]AMINCOV(I1) = [F:CCV]MINCOV
                [M:CCV1]ACCVCUR1(I1) = [M:CCV0]CUR

                [M:CCV1]AMAXCOV(I1) = [F:CCV]MAXCOV
                [M:CCV1]ACCVCUR2(I1) = [M:CCV0]CUR

                I1 += 1
            Endif

        When "LAB"
            If I2 < dim([M:CCV2]BNUM)
                [M:CCV2]BCCVICDFLG(I2) = [F:CCV]ICDFLG
                [M:CCV2]BNUM(I2) = [F:CCV]RECNUM
                Read [ITM] ITM0 = [M:CCV2]BNUM(I2)
                If fstat
                    [M:CCV2]BNUMDES(I2) = ""
                Else
                    #Call LECTEXTRA([M:CCV2]BNUMDES(I2), "ITMMASTER", "DES1AXX", [M:CCV2]BNUM(I2), "") From ATEXTRA
                    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CCV2]BNUMDES(I2), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
#                    [M:CCV2]BNUMDES(I2) = [F:ITM]ITMDES1
                Endif

                [M:CCV2]BHEIPRC(I2) = [F:CCV]HEIPRC

                [M:CCV2]BMINCOV(I2) = [F:CCV]MINCOV
                [M:CCV2]BCCVCUR1(I2) = [M:CCV0]CUR

                [M:CCV2]BMAXCOV(I2) = [F:CCV]MAXCOV
                [M:CCV2]BCCVCUR2(I2) = [M:CCV0]CUR

                I2 += 1
            Endif

        When "EXS"
            If I3 < dim([M:CCV3]CNUM)
                [M:CCV3]CCCVICDFLG(I3) = [F:CCV]ICDFLG
                [M:CCV3]CNUM(I3) = [F:CCV]RECNUM
                Read [ITM] ITM0 = [M:CCV3]CNUM(I3)
                If fstat
                    [M:CCV3]CNUMDES(I3) = ""
                Else
                    #Call LECTEXTRA([M:CCV3]CNUMDES(I3), "ITMMASTER", "DES1AXX", [M:CCV3]CNUM(I3), "") From ATEXTRA
                    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CCV3]CNUMDES(I3), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
#                    [M:CCV3]CNUMDES(I3) = [F:ITM]ITMDES1
                Endif

                [M:CCV3]CHEIPRC(I3) = [F:CCV]HEIPRC

                [M:CCV3]CMINCOV(I3) = [F:CCV]MINCOV
                [M:CCV3]CCCVCUR1(I3) = [M:CCV0]CUR

                [M:CCV3]CMAXCOV(I3) = [F:CCV]MAXCOV
                [M:CCV3]CCCVCUR2(I3) = [M:CCV0]CUR

                I3 += 1
            Endif
    Endcase
Next

Filter [CCV]

[M:CCV1]NBITM = I1
[M:CCV2]NBLAB = I2
[M:CCV3]NBEXS = I3

Return

###################################################################
# Récupération de la couverture de niveau supérieur
###################################################################
$RECUPCOV
Local Char SZMESS
Local Libelle ILIBELLE(3)
Local Decimal IINT(3)
Local Decimal IBUF(6)
Local Char SZASK(250)
Local Integer IASK
IASK = 0
Raz IBUF

Case PARAM(3)
    When "1"
    #Toutes les informations de couverture du composant vont être remplacées par la couverture du parc.
    #Confirmez-vous la récupération ?
        SZASK = mess(284, 182, 2) + " " + mess(283, 182, 2)

    When "2"
    #Toutes les informations de couverture du composant vont être remplacées par la couverture article.
    #Confirmez-vous la récupération ?
        SZASK = mess(285, 182, 2) + " " + mess(283, 182, 2)

    When "3"
    #Toutes les informations de couverture du composant vont être remplacées par la couverture de la famille commerciale.
    #Confirmez-vous la récupération ?
        SZASK = mess(286, 182, 2) + " " + mess(283, 182, 2)

Endcase

Call OUINON(SZASK, IASK) From GESECRAN
If IASK <> 2
    Return
Endif

#Récupération en cours.
SZMESS = mess(282, 182, 2)

Call TEMPON(SZMESS) From GESECRAN

#En efface tout
Call DEBTRANS From GLOCK
Trbegin [CCV]
If [M:CCV0]TPL = 2
    Delete [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                  and [F:CCV]TPL = 2
&                  and [F:CCV]RECTYP = "AAA"
&                  and [F:CCV]PAEKEY(0) = PARAM(9)
&                  and [F:CCV]PAEKEY(1) = PARAM(5)
&                  and [F:CCV]PAEKEY(2) = PARAM(6)
Else
    Delete [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                  and [F:CCV]TPL <> 2
&                  and [F:CCV]RECTYP = "AAA"
&                  and [F:CCV]PAEKEY(0) = PARAM(9)
&                  and [F:CCV]PAEKEY(1) = PARAM(5)
&                  and [F:CCV]PAEKEY(2) = PARAM(6)
Endif

If fstat
    #Erreur lors de la récupération de la couverture de niveau supérieur.
    GMESSAGE = mess(281, 182, 2)
    GERR = 1
    Rollback
Else
    Commit
Endif

If GERR
    Call TEMPOFF From GESECRAN
    Return
Endif

#Duplication de la couverture
Local File CONTCOV [CCVY]
Call DEBTRANS From GLOCK
Trbegin [CCV]

If [M:CCV0]TPL = 2
    Filter [CCVY] Where [F:CCVY]CONNUM = [M:CCV0]CONNUM
&                   and [F:CCVY]TPL = 2
&                   and [F:CCVY]RECTYP = "AAA"
&                   and [F:CCVY]PAEKEY(0) = PARAM(9)
&                   and [F:CCVY]PAEKEY(1) = PARAM(5)
&                   and [F:CCVY]PAEKEY(2) = ""
Else
    Filter [CCVY] Where [F:CCVY]CONNUM = [M:CCV0]CONNUM
&                   and [F:CCVY]TPL <> 2
&                   and [F:CCVY]RECTYP = "AAA"
&                   and [F:CCVY]PAEKEY(0) = PARAM(9)
&                   and [F:CCVY]PAEKEY(1) = PARAM(5)
&                   and [F:CCVY]PAEKEY(2) = ""
Endif

For [CCVY]
    Raz [F:CCV]
    [F:CCV] = [F:CCVY]
    [F:CCV]PAEKEY(2) = PARAM(6)
    Write [CCV]
    If fstat
        #Erreur lors de la récupération de la couverture de niveau supérieur.
        GMESSAGE = mess(281, 182, 2)
        GERR = 1
        Rollback
        Break
    Endif
Next

Filter [CCVY]

If GERR
    Close Local File [CCVY]
    Call TEMPOFF From GESECRAN
    Return
Endif

If [M:CCV0]TPL = 2
    Case PARAM(3)
        When "1"
            Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                          and [F:CCV]TPL = 2
&                          and [F:CCV]RECTYP = "MAC"
&                          and [F:CCV]SBBRECTYP = "MAC"
&                          and [F:CCV]PAEKEY(0) = PARAM(9)
        When "2"
            Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                          and [F:CCV]TPL = 2
&                          and [F:CCV]RECTYP = "MAC"
&                          and [F:CCV]SBBRECTYP = "ITM"
&                          and [F:CCV]PAEKEY(0) = PARAM(9)
        When "3"
            Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                          and [F:CCV]TPL = 2
&                          and [F:CCV]RECTYP = "MAC"
&                          and [F:CCV]SBBRECTYP = "CIA"
&                          and [F:CCV]PAEKEY(0) = PARAM(9)
    Endcase
Else
    Case PARAM(3)
        When "1"
            Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                          and [F:CCV]TPL <> 2
&                          and [F:CCV]RECTYP = "MAC"
&                          and [F:CCV]SBBRECTYP = "MAC"
&                          and [F:CCV]PAEKEY(0) = PARAM(9)
        When "2"
            Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                          and [F:CCV]TPL <> 2
&                          and [F:CCV]RECTYP = "MAC"
&                          and [F:CCV]SBBRECTYP = "ITM"
&                          and [F:CCV]PAEKEY(0) = PARAM(9)
        When "3"
            Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                          and [F:CCV]TPL <> 2
&                          and [F:CCV]RECTYP = "MAC"
&                          and [F:CCV]SBBRECTYP = "CIA"
&                          and [F:CCV]PAEKEY(0) = PARAM(9)
    Endcase
Endif

For [CCV]
    ILIBELLE(0) = [F:CCV]ITMICDFLG
    IINT(0) = [F:CCV]HEIPRC(0)
    IBUF(0) = [F:CCV]MINCOV(0)
    IBUF(1) = [F:CCV]MAXCOV(0)

    ILIBELLE(1) = [F:CCV]LABICDFLG
    IINT(1) = [F:CCV]HEIPRC(1)
    IBUF(2) = [F:CCV]MINCOV(1)
    IBUF(3) = [F:CCV]MAXCOV(1)

    ILIBELLE(2) = [F:CCV]EXSICDFLG
    IINT(2) = [F:CCV]HEIPRC(2)
    IBUF(4) = [F:CCV]MINCOV(2)
    IBUF(5) = [F:CCV]MAXCOV(2)
    Break
Next

Filter [CCV]

If [M:CCV0]TPL = 2
     Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                   and [F:CCV]TPL = 2
&                   and [F:CCV]RECTYP = "CPN"
&                   and [F:CCV]PAEKEY(0) = PARAM(9)
&                   and [F:CCV]PAEKEY(1) = PARAM(5)
Else
     Filter [CCV] Where [F:CCV]CONNUM = [M:CCV0]CONNUM
&                   and [F:CCV]TPL <> 2
&                   and [F:CCV]RECTYP = "CPN"
&                   and [F:CCV]PAEKEY(0) = PARAM(9)
&                   and [F:CCV]PAEKEY(1) = PARAM(5)
Endif

For [CCV]
    [F:CCV]ITMICDFLG = ILIBELLE(0)
    [F:CCV]HEIPRC(0) = IINT(0)
    [F:CCV]MINCOV(0) = IBUF(0)
    [F:CCV]MAXCOV(0) = IBUF(1)

    [F:CCV]LABICDFLG = ILIBELLE(1)
    [F:CCV]HEIPRC(1) = IINT(1)
    [F:CCV]MINCOV(1) = IBUF(2)
    [F:CCV]MAXCOV(1) = IBUF(3)

    [F:CCV]EXSICDFLG = ILIBELLE(2)
    [F:CCV]HEIPRC(2) = IINT(2)
    [F:CCV]MINCOV(2) = IBUF(4)
    [F:CCV]MAXCOV(2) = IBUF(5)
    Rewrite [CCV]
    If fstat
       #Erreur lors de la récupération de la couverture de niveau supérieur.
       GMESSAGE = mess(281, 182, 2)
       GERR = 1
       Rollback
    Endif
    Break
Next

Filter [CCV]

If GERR
    Close Local File [CCVY]
    Call TEMPOFF From GESECRAN
    Return
Endif

Commit
Close Local File [CCVY]

#Chargement de la nouvelle couverture
Gosub LOADCCV

Affzo [M:CCV1]
Affzo [M:CCV2]
Affzo [M:CCV3]

#Mise à jour de la classe écran CONH conformément aux modifs effectuées.
[M:CONH]ITMICDFLG([M:CCV0]CONHNOL) = [M:CCV1]ITMICDFLG
[M:CONH]CNNIHEIPRC([M:CCV0]CONHNOL) = [M:CCV1]ITMHEIPRC
[M:CONH]CNNIMINCOV([M:CCV0]CONHNOL) = [M:CCV1]ITMMINCOV
[M:CONH]CNNIMAXCOV([M:CCV0]CONHNOL) = [M:CCV1]ITMMAXCOV

[M:CONH]LABICDFLG([M:CCV0]CONHNOL) = [M:CCV2]LABICDFLG
[M:CONH]CNNLHEIPRC([M:CCV0]CONHNOL) = [M:CCV2]LABHEIPRC
[M:CONH]CNNLMINCOV([M:CCV0]CONHNOL) = [M:CCV2]LABMINCOV
[M:CONH]CNNLMAXCOV([M:CCV0]CONHNOL) = [M:CCV2]LABMAXCOV

[M:CONH]EXSICDFLG([M:CCV0]CONHNOL) = [M:CCV3]EXSICDFLG
[M:CONH]CNNEHEIPRC([M:CCV0]CONHNOL) = [M:CCV3]EXSHEIPRC
[M:CONH]CNNEMINCOV([M:CCV0]CONHNOL) = [M:CCV3]EXSMINCOV
[M:CONH]CNNEMAXCOV([M:CCV0]CONHNOL) = [M:CCV3]EXSMAXCOV

Call TEMPOFF From GESECRAN
Return

