$AINIT
Gosub DECLARE_VAR From WMC0ESSWRKCHD
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_REFNUM From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_NUMLIG From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_CHDNAM From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_CHDSRN From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_CHDSEX From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_DATCHDBRN From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_CMT From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_LNKPAR From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_DPDTYPMID From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_DPDTYP From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_RELTYP From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_CHDUID From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_UID From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_CREDAT From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_NUMSSEBNF1 From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_CHRONO From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_ORGMALBNF From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_CHRONO2 From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_CRETIM From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_FLGBNF3 From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_LNK From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_UPDDAT From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_ENAFLGBNF From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_WRK From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_UPDTIM From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub INIT_CHDCKK From WMC2ESSWRKCHD : Gosub TESTALLSTAT
Gosub AINIT From WMC0ESSWRKCHD : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0ESSWRKCHD
Gosub _ALOADATTRIBUTE_REFNUM From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_UID From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0ESSWRKCHD
Gosub LNKPRO_REFNUM From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC1ESSWRKCHD : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1ESSWRKCHD : Gosub TESTALLSTAT
