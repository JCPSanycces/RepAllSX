#<AdxTL>@(#)8.0.0.0 $Revision$
######################################################################################
## Xtend: Génération fiche Profil Xtend
#  Version 0001
######################################################################################
#    XMLGEN 
######################################################################################
Subprog XMLGEN(DOSORG, FCYORG, TIMSTP, OPTION, ELTCOD,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char FCYORG        #     Code site Xtend
Value Char TIMSTP        #     Référence time stamp 20061012093014
Value Char OPTION()(1..) #     Option 
                         #       'TRADET'=Trace détaillée
Value Char ELTCOD        #     Code élément
Variable Integer RET     #     1 Ok; 0: Ko ; 2: avertissement
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer WI, WNBREC
Local Integer TRADETFLG   : TRADETFLG   = find("TRADET",OPTION)
Local Char WSTR1(250)
Local Char U_TXTTOHEX(250),U_HEXTOTXT(250)


RET=1

Call TITOBJ("AYD","", WSTR1) From CONTOBJ
Call ECR_TRACE(mess(38,7900,1)-WSTR1,0) From GESECRAN : # Validation de l'écran

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS

If DOSORG=nomap 
 Local File AYTPRF    [AYD1] 
 Local File ATEXTE    [ATX1] 
 Local File ATEXTRA   [AXX1]
Else 
 Local File =[L]DOSORG+".AYTPRF"     [AYD1] 
 Local File =[L]DOSORG+".ATEXTE"     [ATX1] 
 Local File =[L]DOSORG+".ATEXTRA"   [AXX1]
Endif 
Default File "[AYD1],[ATX1]"

#
Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=TIMSTP
XT_XMLID="PRF"
Gosub XMLF_INI2 From AYTGEN : If XT_RET=0 : RET=0 : Goto FFINALLY : Endif 
#
XT_TY="ELMTS"  : XT_ID=XT_XMLID                                            : Gosub XMLF_ADD From AYTGEN
#
For [AYD1]AYD0 Where FCYCOD=FCYORG
 WNBREC+=1
 If TRADETFLG : Call ECR_TRACE(mess(4,7910,1)-":"-[F]PRFCOD,0) From GESECRAN : Endif
 #
 XT_TY="ELMT"  : XT_ID=[F]PRFCOD    
 Call LECTEXTRA(XT_VAL,"AYTPRF","INTIT",[F]FCYCOD,[F]PRFCOD) From AYTUTIA  : Gosub XMLF_ADD From AYTGEN 

 XT_TY="FLD"   : XT_ID="ALLACS"     : XT_VAL=num$([F]ALLACS)
                                      XT_LAB=mess([F]ALLACS,1,1)           : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"  : XT_ID="USRTIMOUT"  : XT_VAL=num$([F]USRTIMOUT)             : Gosub XMLF_ADD From AYTGEN
 If [F]ALLACS<>2
     If [F]PAGNBR<>0
      XT_TY="TAB"   : XT_ID="PAGNBR"                                         : Gosub XMLF_ADD From AYTGEN
      For WI=0 To [F]PAGNBR-1
       XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
       XT_TY="COL"  : XT_ID="PAGCOD"     : XT_VAL=[F]PAGCOD(WI)                  : Gosub XMLF_ADD From AYTGEN
      Next
     Endif
 Endif
 XT_TY="FLD"   : XT_ID="PAGERR"     : XT_VAL=[F]PAGERR                     : Gosub XMLF_ADD From AYTGEN
Next

$FFINALLY
Gosub XMLF_CL  From AYTGEN
Close Local File [AYD1],[ATX1],[AXX1]
Call ECR_TRACE(mess(146,7900,1)-num$(WNBREC),0) From GESECRAN
End

