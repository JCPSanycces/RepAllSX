#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet BAI
Call OBJET("BAI",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "SETBOUT"   : Gosub SETBOUT
 When "VERIF_MOD" : Gosub TRI_BASE
 When "VERIF_CRE" : Gosub TRI_BASE
 When "FILTRE"    : Gosub FILTRE
 When "FERME"     : Gosub FERME
 When Default
Endcase
Return

$OUVRE
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY]         : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$FILTRE
If GUSRACS<>2
 FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
Else
 FILTSUP = "1=1"
Endif
Return

$LIENS
Call LECTURE("CPY",[F:HRBAI]CPY,"") From CONTOBJ
GCURLEG=[F:CPY]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

Read [ID]ID0 = [F:HRBAI]REFNUM
If !fstat
 [M]NAMSRN = [F:ID]NAM-[F:ID]SRN
 Call GRISE_CTRNUM([F:ID]FLGMULCTR)
Endif
Return

$SETBOUT
#Objet à 4 éléments de clé : Ajout du bouton suppression après que GOBJET le vire !
If CLECUR
 ## Si la fiche de participation individuelle est validée => Pas de modif autorisée s/base individuelle
 If clalev([F:PAI])=0 : Local File PARIND [PAI] : Endif
 Filter [PAI] Where CPY=[F:HRBAI]CPY & REFNUM=[F:HRBAI]REFNUM & CTRNUM=[F:HRBAI]CTRNUM & EXO=[F:HRBAI]EXO
 Read [PAI]PAI0 First
 Filter [PAI]
 If fstat : GCONSULT = 0 : CHAINE += "A" : Endif
 If !fstat
  # MABOS - Correction bug 85068 - préfixer variable STA
  If [F:PAI]STA>1 # Validée ou Soldée
   GCONSULT = 1
  Else
   GCONSULT = 0
  Endif
 Endif
Endif
Return


$TRI_BASE
Sorta [M:BAI]NBRBAS [M:BAI]NBRBAS Order By [M:BAI]CODBAS(indice)
Return

Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M]CTRNUM
Else
 Diszo [M]CTRNUM
Endif
Affzo [M]CTRNUM
End


######################################################################################
## Etiquette écran BAI
######################################################################################
Subprog C_CODBAS(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]CODBAS(0..[M]NBRBAS-1))From OBJDIV
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran BAI) 03/02/2009 16:23:01 (DBA)
######################################################################################
Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
#MABOS-15/04/13-FQ88324-US1521
# Call SELCTR([M]REFNUM,[M]DATSTR,[M]DATEND,VALEUR) From DIVPAYE
#By F12, all the contrats (whatever the company of the contract) whose start date is <= today date, are proposed.
# <=> Call S_CTRNUM(VALEUR) From W1BAI
If !GWEBSERV
     ## Action SELOBJCRIT
     Local Char    PARMSK(250)(1..20) , SAVACT(20)
     SAVACT = GACTION : GACTION = "SELOBJCRIT"
     PARMSK(1) = "CTR"
     PARMSK(2) = ""
     PARMSK(3) = ""
     PARMSK(4) = "[F:HRCTR]REFNUM=[M]REFNUM"
     PARMSK(5) = "[F:HRCTR]CTRDAT<=date$"
     Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJCRIT","SELOBJ","") From GACTION
     GACTION = SAVACT
    Endif
    Gosub AFF From GSAISIE
Endif

End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char    CTR
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Read [ID]ID0 =VALEUR
If !fstat
 [M]NAMSRN = [F:ID]NAM-[F:ID]SRN
 Call GRISE_CTRNUM([F:ID]FLGMULCTR)
 #MABOS-15/04/13-FQ88324-US1521
  If [F:ID]FLGMULCTR<>2
  Call CHERCHE_CTR(VALEUR,date$,CTR) From DIVPAYE
  Endif
  [M:BAI]CTRNUM = CTR
  Affzo [M:BAI]CTRNUM
Else
 Call GRISE_CTRNUM(1)
 #end #MABOS-15/04/13-FQ88324-US1521
 Effzo NAMSRN, CTRNUM
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran BAI) 24/07/2012 12:48:13 (DBA)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("CPY",VALEUR,"") From CONTOBJ
GCURLEG=[F:CPY]LEG
End


######################################################################################
