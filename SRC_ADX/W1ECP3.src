$ON_WJOBPOT
Onevent BEFORE_INPUT Call AS_WJOBPOT(zc) From W1ECP3
Onevent CONTROL Call C_WJOBPOT(zc) From W1ECP3
Onevent AFTER_CHANGE Gosub AMM_WJOBPOT From W1ECP3
Return

Subprog AS_WJOBPOT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45810,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_WJOBPOT(VALEUR) From SUBECP
If mkstat=2
 [M]WJOBPOT(INDIC) = VALEUR
 Affzo WJOBPOT(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_WJOBPOT(zc) From W1ECP3
Onkey   2 Titled GBOUTS Call S_WJOBPOT(zc) From W1ECP3
Onkey 144 Titled GBOUTP Call P_WJOBPOT(zc) From W1ECP3
Onkey 146 Titled GBOUTA Call SA_WJOBPOT(zc) From W1ECP3
Gosub _AFF
End

Subprog C_WJOBPOT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_WJOBPOT(VALEUR) From SUBECP
If mkstat : GERR = 1 : GZONE = "WJOBPOT" : GZNUM = 45853 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WJOBPOT" : GZNUM = 45853 : Endif
Endif
Gosub _AFF
End

$AMM_WJOBPOT
Call AM_WJOBPOT(zc)
If !mkstat & GOBJET
 zoncou = "WJOBPOT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WJOBPOT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WJOBPOT(VALEUR) From SUBECP
If mkstat : GERR = 1 : GZONE = "WJOBPOT" : GZNUM = 45853 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWJOBPOT)")>indice
 [M]WJOBPOT(indice) = VALEUR
 Affzo ZWJOBPOT(indice)
Endif
Gosub _AFF
End

Subprog S_WJOBPOT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELJOT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELJOT"
 PARMSK(1) = GCURLEG2
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELJOT","SUBJOT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

