$ON_WPOT
Onevent BEFORE_INPUT Call AS_WPOT(zc) From W1ECP3
Onevent CONTROL Call C_WPOT(zc) From W1ECP3
Onevent AFTER_CHANGE Gosub AMM_WPOT From W1ECP3
Return

Subprog AS_WPOT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(22321,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_WPOT(VALEUR) From SUBECP
If mkstat=2
 [M]WPOT(INDIC) = VALEUR
 Affzo WPOT(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_WPOT(zc) From W1ECP3
Onkey   2 Titled GBOUTS Call S_WPOT(zc) From W1ECP3
Onkey 144 Titled GBOUTP Call P_WPOT(zc) From W1ECP3
Onkey 146 Titled GBOUTA Call SA_WPOT(zc) From W1ECP3
Gosub _AFF
End

Subprog C_WPOT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_WPOT(VALEUR) From SUBECP
If mkstat : GERR = 1 : GZONE = "WPOT" : GZNUM = 22321 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WPOT" : GZNUM = 22321 : Endif
Endif
Gosub _AFF
End

$AMM_WPOT
Call AM_WPOT(zc)
If !mkstat & GOBJET
 zoncou = "WPOT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WPOT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WPOT(VALEUR) From SUBECP
If mkstat : GERR = 1 : GZONE = "WPOT" : GZNUM = 22321 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWPOT)")>indice
 [M]WPOT(indice) = VALEUR
 Affzo ZWPOT(indice)
Endif
Gosub _AFF
End

Subprog S_WPOT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOT"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_WPOT" : PROGSUB = "SUBECP" : PROGSPE = "SPEECP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOT","SUBPOT","") From GACTION
 ACTION = "BS_WPOT" : PROGSUB = "SUBECP" : PROGSPE = "SPEECP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_WPOT(VALEUR)
Variable Char    VALEUR()
Call OBJET("POT",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_WPOT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "POT"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WPOT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("POT",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

