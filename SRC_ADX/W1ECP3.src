$ON_WADD4
Onevent BEFORE_INPUT Call AS_WADD4(zc) From W1ECP3
Onevent INIT_AREA Call D_WADD4(zc) From W1ECP3
Return

Subprog D_WADD4(VALEUR)
Variable Integer VALEUR
If varinit([M]WADD4,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_WADD4(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_WADD4(VALEUR) From SUBECP
If mkstat=2
 [M]WADD4(INDIC) = VALEUR
 Affzo WADD4(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

