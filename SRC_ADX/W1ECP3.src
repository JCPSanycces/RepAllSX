End

$ON_POT2
Return

$ON_WDATPOT
Onevent BEFORE_INPUT Call AS_WDATPOT(zc) From W1ECP3
Onevent CONTROL Call C_WDATPOT(zc) From W1ECP3
Onevent AFTER_CHANGE Gosub AMM_WDATPOT From W1ECP3
Onevent BEFORE_AREA Gosub AV_WDATPOT From W1ECP3
Return

$AV_WDATPOT
Chgfmt [M]WDATPOT(indice) With "DZ:"+GFMDAT4
Gosub _AFF
Return

Subprog AS_WDATPOT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_WDATPOT(VALEUR) From SUBECP
If mkstat=2
 [M]WDATPOT(INDIC) = VALEUR
 Affzo WDATPOT(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_WDATPOT(VALEUR)
Variable Date    VALEUR
## Action STD
Call C_WDATPOT(VALEUR) From SUBECP
If mkstat : GERR = 1 : GZONE = "WDATPOT" : GZNUM = 212 : Endif
Gosub _AFF
End

$AMM_WDATPOT
Call AM_WDATPOT(zc)
If !mkstat & GOBJET
 zoncou = "WDATPOT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WDATPOT(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_WDATPOT(VALEUR) From SUBECP
If mkstat : GERR = 1 : GZONE = "WDATPOT" : GZNUM = 212 : Endif
Gosub _AFF
End

