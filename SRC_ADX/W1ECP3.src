#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ECP3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:05"
A_USER  = "DOC"
A_STAMP = "20181109230405"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRPOT"
  If [M]NBRPOT=0
  Endif
 When "NBRSUPPOT"
  If [M]NBRSUPPOT=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ECP3 [ECP3]
Gosub HORODAT
Local Inpbox "ECP3" From GFONCTION At A_STAMP With A_WINDPREV Mask [ECP3] As [SIM_]
Grizo [ECP3]15
Grizo [ECP3]20
Grizo [ECP3]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ECP3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=88 : Y1(0)=1 : Y2(0)=10
X1(1)=1 : X2(1)=88 : Y1(1)=11 : Y2(1)=22
X1(3)=1 : X2(3)=0 : Y1(3)=23 : Y2(3)=22
Return

$ON_NBRPOT
Onevent BEFORE_INPUT Call AS_NBRPOT From W1ECP3
Onevent CONTROL Call C_NBRPOT From W1ECP3
Return

Subprog IB_NBRPOT
Local Decimal BASPAG
## Action STD
Call IB_NBRPOT From SUBECP
Gosub _AFF
End

Subprog AS_NBRPOT
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(5481,GBOUT1) From OBJDIV
Call IB_NBRPOT
## Action STD
Call AS_NBRPOT From SUBECP
Onkey 129 Titled GBOUT1 Call B1_NBRPOT From W1ECP3
Gosub _AFF
End

Subprog C_NBRPOT
Local Decimal BASPAG
## Action STD
Call C_NBRPOT From SUBECP
If mkstat : GERR = 1 : GZONE = "NBRPOT" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog B1_NBRPOT
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC0
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC0"
 Local Char    OBJCLE(30)
 OBJCLE = [M:ECP0]CTRNUM
 Call OBJET_CHAR(OBJCLE,"CTR",[M:ECP0]REFNUM+"~"+[M:ECP3]DATPOT(nolign-1)) From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

