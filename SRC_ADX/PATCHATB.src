#<AdxTL>@(#)9.0.0.0 $Revision$
###################################################
## Intégration d'une table
###################################################
$TABLE
Read [ATB]CODFIC = NOMOBJ
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_ATB
      Gosub FIN_OBJ From PATCH
  Else
      # Patch not for scm - ISFULLMOD = 2 when SCM
      If [L]ISFULLMOD<>2
          # specific objet ? only on not scm mode and only on header
          If [F:ATB]CODACT>="X" & !find([F:ATB]CODACT,ACTIV(1..NBACT))
              # specific Objet
              Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN
              OKSPE = 1
              Gosub FIN_OBJ From PATCH
          Else
              NBENR  = [F:ATB]NBENREG
              NEWOBJ = 0
              Gosub TR_ATB
          Endif
      Else
          #ISFULLMOD = 2 when SCM always rewrite no test about spe activity code.
          NBENR  = [F:ATB]NBENREG
          NEWOBJ = 0
          Gosub TR_ATB
      Endif
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:ATB]
      Gosub TR_ATB
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif
Return

#-------------------#
# deletion at the moment only for scm
#-------------------#
$DEL_ATB
Call DEBTRANS From GLOCK

Local Char WDOS(GLONADS),CODE(GLONADS)
[L]WDOS = [L]DOSSIER(D)
[L]CODE = [L]NOMOBJ

Trbegin [ATB]
  Gosub PROG_ANNULE From SUBATB
  Delete [ATB] Curr
  If fstat
      GOK = 0 : ER = 99 : ERFIC = "ATABLE"-NOMOBJ : Rollback: Return
  Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ATB",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

#-------------------#
# write or rewrite
#-------------------#
$TR_ATB
Call DEBTRANS From GLOCK

GOK = 1
OKOBJ = 1
Trbegin [ATB] , [ATZ] , [ATI] , [AMP] , [ANX]
 NBZ = 0
 NBI = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Un bout de table
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ATB"   : Gosub ATB1
     When "ATZ"   : Gosub ATB2
     When "ATI"   : Gosub ATB3
     When "AMP"   : Gosub ATB4
     When "ATA"   : Gosub ATB5
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif

 # Effacement zones supprimées, raz liens si code activité inactif

 For [ATZ]CODZONE Where CODFIC=NOMOBJ
  If !find([F:ATZ]CODZONE,ZONE(1..NBZ)) & ([F:ATZ]CODACT<"X" or find([F:ATZ]CODACT,ACTIV(1..NBACT)))
   If clalev([F:ATA])>0
    Delete [ATA] Where CODFIC=NOMOBJ & FLD=[F:ATZ]CODZONE
   Endif
   Delete [ATZ]
  Elsif [F:ATZ]CODACT<>"" & APPLI<>GDOSX3
   Read [ACV]CODACT=[F:ATZ]CODACT
   If fstat or [F:ACV]FLACT<>2
    Read [ATY]CODTYP=[F:ATZ]CODTYP
    If !fstat
     Call CHANGE_CODTYP(0,[F:ATY]TYPTYP,[F:ATZ]CODTYP,[F:ATZ]LONG) From DOSDICDIV
    Else
     [F:ATZ]CODTYP  = "A"
     [F:ATZ]LONG    = 1
    Endif
    [F:ATZ]DIME    = 1
    [F:ATZ]NOLIB   = 0
    [F:ATZ]OPTION  = ""
    [F:ATZ]LIEN    = ""
    [F:ATZ]EXPLIEN = ""
    [F:ATZ]ANNUL   = 0
    [F:ATZ]VERIF   = 0
    [F:ATZ]CHPLEG  = 0
    [F:ATZ]OBLIG   = 1
    [F:ATZ]ZERO    = 1
    Rewrite [ATZ]
    If fstat
     GOK = 0 : ER = 99 : ERFIC = "ATABZON"-NOMOBJ-[F:ATZ]CODZONE : Break
    Endif
   Endif
  Endif
 Next
 If ER : Goto ABORT : Endif

 # Réorganisation des index (Effacement index supprimés/renumérotation numlig/désactivation index optimisation)

 NUMJ = 0
 For [ATI]NUMLIG Where CODFIC=NOMOBJ
  If !find([F:ATI]CODIND,INDEX(1..NBI)) & ([F:ATI]CODACT<"X" or find([F:ATI]CODACT,ACTIV(1..NBACT)))
   Delete [ATI]
  Else
   NUMJ += 1
  Endif
 Next ATI
 NUMI = 0
 For [ATI]NUMLIG Where CODFIC=NOMOBJ
  If NUMI>=NUMJ : Break : Endif : # Cause SQL
  NUMI += 1
  If [F:ATI]NUMLIG<>NUMI
   [F:ATI]NUMLIG = NUMI
   Rewrite [ATI]
   If fstat
    GOK = 0 : ER = 99 : ERFIC = "ATABIND"-NOMOBJ-[F:ATI]CODIND : Break
   Endif
  Endif
 Next ATI
 If ER : Goto ABORT : Endif

 If APPLI<>GDOSX3
  Call INDOPT_OFF(NOMOBJ,ER,ERFIC)
  If ER : Goto ABORT : Endif
 Endif

Commit

## Validation de la table
If [L]ISOKSPOTTING=2
 Call TRACE_COR_PATCH("ATB",[F:ATB]CODFIC,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET
Endif
If [F:ATB]TYPFIC<>3 or filinfo(filpath("FIL","ADOSSIER","fde",APPLI),0)>=0 or GADONIX=2
 Gosub SAV_OPENI From PATCH
 GINFO = 0
 VALID = 1
 If [F:ATB]CODACT<>""
  Read [ACV]CODACT = [F:ATB]CODACT
  If fstat or [F:ACV]FLACT<>2
   Call ECR_TRACE([F:ATB]CODFIC-":"-mess(126,133,1),0) From GESECRAN : # Table inactive
   VALID = 0
  Endif
 Endif
 # Dans l'appli X3 , on ne valide pas les tables non livrées
 If APPLI=GDOSX3 & [F:ATB]TYPDLV=1 & filinfo(filpath("FIL",NOMOBJ,"fde",APPLI),0)<=0 & [L]ISOKSPOTTING<>2
  VALID = 0
 Endif
 # On ne valide pas les tables systèmes dans un dossier fille (même si GADONIX=2)
 If [F:ATB]TYPFIC=3 & APPLI<>GDOSX3
  VALID = 0
 Endif
 If VALID
  Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
  Call MAJTAB(NOMOBJ,0) From DOSTAB
  If find(NOMOBJ,"ATABLE","ATABIND","ATABZON","ATEXTE","ATYPE","ACTIV","AINDEX")
   Gosub REOUVFIC
  Endif
  Call MAJTRIG(NOMOBJ) From DOSTAB
  If dim(ISVUE)>0
   ISVUE += 1
  Endif
  Call EXISTE_ADX("","","PATCHATBB",OKTRT) From ORDSYS
  If OKTRT>0
   ACTION = "PATCH" : Gosub ACTION From PATCHATBB
  Endif
  Gosub REOUVFIC
 Endif
 If APPLI=GDOSX3 & find(NOMOBJ,"ADOSSIER","ADOSDIM","ADOSACT")
  If clalev([F:ADS])>0 : Close Local File [ADS] : Endif
  If clalev([F:ADD])>0 : Close Local File [ADD] : Endif
  If clalev([F:ADA])>0 : Close Local File [ADA] : Endif
  If clalev([F:ADE])>0 : Close Local File [ADE] : Endif
  If instr(1,DOSX3,"@")
   Local File =DOSX3+".ADOSSIER" [ADS] , =DOSX3+".ADOSACT" [ADA] , =DOSX3+".ADOSSOL" [ADD] , =DOSX3+".ADOSDIM" [ADE]
  Else
   Local File ADOSSIER [ADS] , ADOSACT [ADA] , ADOSSOL [ADD] , ADOSDIM [ADE]
  Endif
  For [ADS]
   If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
    Call CREPAR From DOSDIV : # Régénération des fichiers PARAM.ini
   Endif
  Next ADS
  Read [ADS]DOSSIER=APPLI
 Endif
 Gosub REST_OPENI From PATCH
Endif
Return

## En-tête table

$ATB1
FICHIER = "ATABLE" : ABR = "ATB"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ
   If VARIA="GENTRA" and VALEUR<>"2" and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
    OK = 0
   Elsif find(VARIA,"AUDCRE","AUDUPD","AUDDEL","AUDWRK","AUDBI","AUDSDA","ASDCLE") and APPLI<>GDOSX3 and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
    OK = 0
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:ATB]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
# test about code act on header Doesn't apply to a SCM environ. on root folder
# but no need to test ISFULLMOD here because test with GDOSX3 is done.
ACVOBJ = [F:ATB]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
       Read [ACV]CODACT = ACVOBJ
       If fstat | [F:ACV]FLACT<>2
          OKOBJ = 0 : Return
       Endif
Endif

If NEWOBJ
   If dim([F:ATB]AUDBI)>0 : [F:ATB]AUDBI  = 1 : Endif
   If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDCRE("ATB") From OBJDIV
   Endif
   Write [ATB]
   If fstat
        Call LOG_ERROR_DETAILS(1, "ATB",num$([F:ATB]CODFIC),"") From GLOCK
   Endif
Else
   If  !(dim([L]ISFULLMOD)>0 & [L]ISFULLMOD=2) :# X3-43086 = Doesn't apply to SCM
      [F:ATB]NBENREG = NBENR : # Let's keep NBENREG
   Endif
   If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDUPD("ATB") From OBJDIV
   Endif
   Rewrite [ATB]
   If fstat
        Call LOG_ERROR_DETAILS(2, "ATB",num$([F:ATB]CODFIC),"") From GLOCK
   Endif
Endif
If fstat
    GOK = 0 : ER = 99 : ERFIC = "ATABLE"-[F:ATB]CODFIC : Return
Endif
# On efface le paramètrage audit dans le dossier X3 pour pouvoir le raffraichir avec les données du patch

If APPLI=GDOSX3 & clalev([F:ATA])>0
 Delete [ATA] Where CODFIC=NOMOBJ
Endif

Return


## Zones
$ATB2
NBZ += 1 : ZONE(NBZ) = IDENT
FICHIER = "ATABZON" : ABR = "ATZ"
Read [ATZ]CODZONE = NOMOBJ;IDENT
If fstat
 NEWZON = 1
Elsif [F:ATZ]CODACT>="X" & !find([F:ATZ]CODACT,ACTIV(1..NBACT)) : # Zone spécifique
 Gosub FIN_FIC From PATCH
 Return
Else
 NEWZON = 0
Endif
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
# Respect du mot clé d'aide
#  If VARIA="MOTCLE"
#   If [F:ATZ]MOTCLE>="X" & TYPPTC<>3
#    OK = 0
#   Endif
#  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If NEWZON
 Write [ATZ]
Else
 Rewrite [ATZ]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ATABZON"-[F:ATZ]CODFIC-[F:ATZ]CODZONE : Return
Endif
Delete [AMP] Where TYPAFF=2 & CODAFF=[F:ATZ]CODFIC & CODZON=[F:ATZ]CODZONE
Return

## Index

$ATB3
NBI += 1 : INDEX(NBI) = IDENT
FICHIER = "ATABIND" : ABR = "ATI"
Read [ATI]CODIND = NOMOBJ;IDENT
If fstat
 NEWZON = 1
Elsif [F:ATI]CODACT>="X" & !find([F:ATI]CODACT,ACTIV(1..NBACT)) : # Zone spécifique
 Gosub FIN_FIC From PATCH
 Return
Else
 NEWZON = 0
Endif
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If NEWZON
 Write [ATI]
Else
 Rewrite [ATI]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ATABIND"-[F:ATI]CODFIC-[F:ATI]CODIND : Return
Endif
Return

## Paramètre

$ATB4
FICHIER = "AMSKPAR" : ABR = "AMP"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
Read [ATZ]CODZONE = [F:AMP]CODAFF;[F:AMP]CODZON
If [F:ATZ]CODACT>="X" & !find([F:ATZ]CODACT,ACTIV(1..NBACT)) : # Zone spécifique
 Return
Else
 Write [AMP]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "AMSKPAR"-num$([F:AMP]TYPAFF)-[F:AMP]CODAFF-[F:AMP]CODZON-[F:AMP]CODPAR : Return
 Endif
Endif
Return

## Audit champs

$ATB5
If clalev([F:ATA])=0 or APPLI<>GDOSX3
 Gosub FIN_FIC From PATCH
 Return
Endif
FICHIER = "ATABAUD" : ABR = "ATA"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
Read [ATZ]CODZONE = [F:ATA]CODFIC;[F:ATA]FLD
If fstat : Return : Endif
Write [ATA]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ATABAUD"-[F:ATA]CODFIC-[F:ATA]FLD : Return
Endif
Return

$ABORT
Rollback
Return

#####################################################################
Subprog INDOPT_OFF(NOMOBJ,ER,ERFIC)
Value Char NOMOBJ
Variable Integer ER
Variable Char ERFIC
Local Integer I , J , K , L
Local Char    CAR(1), NEWIND(250), ZONE(20)(1..16), SENS(1)(1..16)
Local Integer NBCLE1 , NBCLE2
Local Char    CLE1(GLONAVA+5)(1..16) , CLE2(GLONAVA+5)(1..16) , CHAINE(250)
For [ATI]CODIND Where CODFIC=NOMOBJ
 Raz SENS, ZONE, NEWIND
 J = 1
 For I=1 To len([F:ATI]DESCRIPT)
  CAR = mid$([F:ATI]DESCRIPT,I,1)
  If find(CAR,"-","+")
   J += 1
   SENS(J) = CAR
  Else
   ZONE(J) += CAR
  Endif
 Next I
 For I=1 To J
  Read [ATZ]CODZONE = NOMOBJ;ZONE(I)
  If !fstat
   K = 1
   If [F:ATZ]CODACT<>""
    Read [ACV]CODACT=[F:ATZ]CODACT
    If fstat or [F:ACV]FLACT<>2
     K = 0
    Endif
   Endif
   If K
    If NEWIND<>""
     NEWIND += SENS(I)
    Endif
    NEWIND += ZONE(I)
   Endif
  Endif
 Next I
 If NEWIND=""
  Delete [ATI]
  If fstat : GOK = 0 : ER = 99 : ERFIC = "ATABIND"-NOMOBJ-[F:ATI]CODIND : Break : Endif
 Elsif NEWIND<>[F:ATI]DESCRIPT
  [F:ATI]DESCRIPT=NEWIND
  Rewrite [ATI]
  If fstat : GOK = 0 : ER = 99 : ERFIC = "ATABIND"-NOMOBJ-[F:ATI]CODIND : Break : Endif
 Endif
Next ATI
If ER : End : Endif
# Pour virer les doublons en cas de zone désactivée
Filter [ATI] Where CODFIC=[F:ATB]CODFIC
Read [ATI]CODIND First
CLE1   = [F:ATI]CODIND
CHAINE = [F:ATI]DESCRIPT
While 1=1
 For [ATI]CODIND Where CODFIC=[F:ATB]CODFIC & CODIND>CLE1
  If [F:ATI]DESCRIPT=CHAINE
   Delete [ATI]
   If fstat : GOK = 0 : ER = 99 : ERFIC = "ATABIND"-NOMOBJ-[F:ATI]CODIND : Break 2 : Endif
  Endif
 Next ATI
 Filter [ATI] Where CODFIC=[F:ATB]CODFIC & CODIND>CLE1
 Read [ATI]CODIND First
 If fstat : Break : Endif
 CLE1   = [F:ATI]CODIND
 CHAINE = [F:ATI]DESCRIPT
Wend
Filter [ATI]
If ER : End : Endif
# Désactivation des index d'optimisation en cas de doublon
For [ANX] Where TABLE=NOMOBJ & FLACT=2
 CHAINE = [F:ANX]DESCRIPT
 Raz CLE1, NBCLE1
 While CHAINE<>""
  I = instr(1,CHAINE,"+")
  J = instr(1,CHAINE,"-")
  If I & J
   I = min(I,J)
  Elsif J & !I
   I = J
  Endif
  NBCLE1 += 1
  If I
   CLE1(NBCLE1) = left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
  Else
   CLE1(NBCLE1) = CHAINE
   CHAINE = ""
  Endif
 Wend
 For [ATI] Where CODFIC=NOMOBJ
  CHAINE = [F:ATI]DESCRIPT
  Raz CLE2, NBCLE2
  While CHAINE<>""
   I = instr(1,CHAINE,"+")
   J = instr(1,CHAINE,"-")
   If I & J
    I = min(I,J)
   Elsif J & !I
    I = J
   Endif
   NBCLE2 += 1
   If I
    CLE2(NBCLE2) = left$(CHAINE,I-1)
    CHAINE = right$(CHAINE,I+1)
   Else
    CLE2(NBCLE2) = CHAINE
    CHAINE = ""
   Endif
  Wend
  K = 0
  For I=1 To max(NBCLE1,NBCLE2)
   If CLE2(I)<>CLE1(I)
    K = 1 : Break
   Endif
  Next I
  If !K
   [F:ANX]FLACT=1
   Rewrite [ANX]
   If fstat : GOK = 0 : ER = 99 : ERFIC = "AINDEX"-NOMOBJ-[F:ATI]CODIND : Break 2 : Endif
  Endif
 Next ATI
Next ANX
End

##############################################################################
$REOUVFIC
Case NOMOBJ
 When "ADICTRT"   : Close Local File [ADC]  : Local File =DOSSIER(D)+".ADICTRT"   [ADC]
 When "AMSK"      : Close Local File [AMK]  : Local File =DOSSIER(D)+".AMSK"      [AMK]
 When "AMSKZON"   : Close Local File [AMZ]  : Local File =DOSSIER(D)+".AMSKZON"   [AMZ]
 When "AMSKACT"   : Close Local File [AMA]  : Local File =DOSSIER(D)+".AMSKACT"   [AMA]
                    Close Local File [AMA2] : Local File =DOSSIER(D)+".AMSKACT"   [AMA2]
 When "AMSKPAR"   : Close Local File [AMP]  : Local File =DOSSIER(D)+".AMSKPAR"   [AMP]
                    Close Local File [AMP2] : Local File =DOSSIER(D)+".AMSKPAR"   [AMP2]
 When "ATEXTE"    : Close Local File [ATX]  : Local File =DOSSIER(D)+".ATEXTE"    [ATX]
 When "ATEXTRA"   : Close Local File [AXX]  : Local File =DOSSIER(D)+".ATEXTRA"   [AXX]
 When "ATYPE"     : Close Local File [ATY]  : Local File =DOSSIER(D)+".ATYPE"     [ATY]
 When "ACTION"    : Close Local File [ACT]  : Local File =DOSSIER(D)+".ACTION"    [ACT]
 When "ACTPAR"    : Close Local File [ATR]  : Local File =DOSSIER(D)+".ACTPAR"    [ATR]
 When "ACTCODPAR" : Close Local File [AAR]  : Local File =DOSSIER(D)+".ACTCODPAR" [AAR]
 When "ATABLE"    : Close Local File [ATB]  : Local File =DOSSIER(D)+".ATABLE"    [ATB]
                    Close Local File [AT2]  : Local File =DOSSIER(D)+".ATABLE"    [AT2]
 When "ATABZON"   : Close Local File [ATZ]  : Local File =DOSSIER(D)+".ATABZON"   [ATZ]
 When "ATABIND"   : Close Local File [ATI]  : Local File =DOSSIER(D)+".ATABIND"   [ATI]
 When "ATABAUD"
  If filinfo(filpath("FIL","ATABAUD","fde",DOSSIER(D)),0)>=0 & clalev([F:ATA])>0
   Close Local File [ATA] : Local File =DOSSIER(D)+".ATABAUD"   [ATA]
  Endif
 When "AINDEX"    : Close Local File [ANX]  : Local File =DOSSIER(D)+".AINDEX"    [ANX]
 When "ACTIV"     : Close Local File [ACV]  : Local File =DOSSIER(D)+".ACTIV"     [ACV]
 When "AOBJET"    : Close Local File [AOB]  : Local File =DOSSIER(D)+".AOBJET"    [AOB]
                    Close Local File [AOB2] : Local File =DOSSIER(D)+".AOBJET"    [AOB2]
 When "AOBJTAB"   : Close Local File [AOT]  : Local File =DOSSIER(D)+".AOBJTAB"   [AOT]
                    Close Local File [AOT2] : Local File =DOSSIER(D)+".AOBJTAB"   [AOT2]
 When "AOBJEXT"   : Close Local File [AOE]  : Local File =DOSSIER(D)+".AOBJEXT"   [AOE]
 When "AOBJEXTD"  : Close Local File [AOD]  : Local File =DOSSIER(D)+".AOBJEXTD"  [AOD]
 When "AOBJLST"   : Close Local File [AOL]  : Local File =DOSSIER(D)+".AOBJLST"   [AOL]
 When "ATABTAB"   : Close Local File [ADV]  : Local File =DOSSIER(D)+".ATABTAB"   [ADV]
 When "ATABDIV"   : Close Local File [ADI]  : Local File =DOSSIER(D)+".ATABDIV"   [ADI]
                    Close Local File [ADI2] : Local File =DOSSIER(D)+".ATABDIV"   [ADI2]
 When "AFONCTION" : Close Local File [AFC]  : Local File =DOSSIER(D)+".AFONCTION" [AFC]
                    Close Local File [AFC2] : Local File =DOSSIER(D)+".AFONCTION" [AFC2]
 When "AMENLOC"   : Close Local File [AML]  : Local File =DOSSIER(D)+".AMENLOC"   [AML]
 When "APLSTD"    : Close Local File [AST]  : Local File =DOSSIER(D)+".APLSTD"    [AST]
 When "ADOPAR"    : Close Local File [ADP]  : Local File =DOSSIER(D)+".ADOPAR"    [ADP]
 When "ADOVAL"    : Close Local File [ADW]  : Local File =DOSSIER(D)+".ADOVAL"    [ADW]
 When "AWINDOW"   : Close Local File [AWI]  : Local File =DOSSIER(D)+".AWINDOW"   [AWI]
                    Close Local File [AWI2] : Local File =DOSSIER(D)+".AWINDOW"   [AWI2]
 When "AWINBOUT"  : Close Local File [AWT]  : Local File =DOSSIER(D)+".AWINBOUT"  [AWT]
 When "AWINBRO"   : Close Local File [AWB]  : Local File =DOSSIER(D)+".AWINBRO"   [AWB]
 When "AWINPAR"   : Close Local File [AWP]  : Local File =DOSSIER(D)+".AWINPAR"   [AWP]
 When "ACONSULT"  : Close Local File [ACN]  : Local File =DOSSIER(D)+".ACONSULT"  [ACN]
 When "ACLOB"     : Close Local File [ACB]  : Local File =DOSSIER(D)+".ACLOB"     [ACB]
 When "AVOCAB"    : Close Local File [AVO]  : Local File =DOSSIER(D)+".AVOCAB"    [AVO]
Endcase
Return

