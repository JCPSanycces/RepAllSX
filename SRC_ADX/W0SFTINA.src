#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SFTINA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone TEAMNUM
mkstat = 0
zoncou = "TEAMNUM"
indice = 0
If varmode([M]TEAMNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TEAMNUM" : Gosub ACTION From =IMPTRT
 Endif
 If [M]TEAMNUM=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TEAMNUM" : GZNUM = 54339 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If [M]TEAMNUM<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "TEAMNUM" : GZNUM = 54339 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTNUM("TMA","",[M]TEAMNUM,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "TEAMNUM" : GZNUM = 54339 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone EMPNUM
mkstat = 0
zoncou = "EMPNUM"
If varmode([M]EMPNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EMPNUM" : Gosub ACTION From =IMPTRT
 Endif
 If [M]EMPNUM(indice)=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "EMPNUM" : GZNUM = 10793 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If [M]EMPNUM(indice)<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "EMPNUM" : GZNUM = 10793 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTNUM("TMA","",[M]EMPNUM(indice),"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "EMPNUM" : GZNUM = 10793 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone EMPDES
mkstat = 0
zoncou = "EMPDES"
SAVACT = GACTION : GACTION = "STD"
Call AV_EMPDES([M]EMPDES(indice)) From TRTSFTINA
GACTION = SAVACT
If mkstat=1 : Raz [M]EMPDES(indice) : Endif

## Zone STRDAT
mkstat = 0
zoncou = "STRDAT"
If varinit([M]STRDAT,indice)=0
 [M]STRDAT(indice) = date$
Endif

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SFTINA"
Return

