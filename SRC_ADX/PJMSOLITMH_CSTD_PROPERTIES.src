###################################################################################################
# Class PJMSOLITMH
###################################################################################################
# PROPERTIES
###################################################################################################
$VACBPR
  Case [L]ARULE
    When "PROPAGATE" : Gosub VACBPR_PROPAGATE
  Endcase
Return

$VACBPR_PROPAGATE
  Call LOAD_VACBPR_LEG(this) From PJMSOLITMH_CSTD_PROGS
Return

###################################################################################################
$PTE
  Case [L]ARULE
    When "PROPAGATE" : Gosub PTE_PROPAGATE
  Endcase
Return

$PTE_PROPAGATE
  Call LOAD_PTE_LEG(this) From PJMSOLITMH_CSTD_PROGS
Return

