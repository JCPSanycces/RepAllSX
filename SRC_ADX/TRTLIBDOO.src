#<AdxTL>@(#)9.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
#########################################################################
# Pour exécution hors intégration de patch
#########################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("Texts tranfert from ATABDIV number 424 to BPMISCCGF") From LECFIC
 Call GENLIBDOO(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

#########################################################################

#####################################################################################################################
#                                                                                                                   #
# Alimentation de la table BPMISCCGF sur la base du contenu de la table diverse 424     Module CRM   11 avril 2002  #
#                                                                                                                   #
#####################################################################################################################

Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

Read [ADS] DOSSIER=APPLI
If fstat
    Raz [F:ADS]
    End
Endif

If [F:ADS]MODULE(12) <> 2 : End : Endif

Call GENLIBDOO(APPLI)

End

#######################################################################
Subprog GENLIBDOO(SZAPPLI)
Value Char SZAPPLI

Local Integer IPBL
Local Integer IDETECT
IPBL = 0
IDETECT = 0

Call ECR_TRACE("--------------------------------------",0) From GESECRAN
Call ECR_TIME("Start transfering texts from ATABDIV number 424 to BPMISCCGF") From DOSSUB
Call ECR_TRACE("--------------------------------------",0) From GESECRAN

If !clalev([F:BPG]) : Local File =SZAPPLI+".BPMISCCGF" [BPG] : Endif
If !clalev([F:ADI]) : Local File =SZAPPLI+".ATABDIV" [ADI] : Endif

If type([F:ADI]INTIT) < 0
    Call ECR_TIME("Transfert canceled due to [F:ADI]INTIT missing field") From DOSSUB
    End
Endif

If type([F:ADI]INTSHO) < 0
    Call ECR_TIME("Transfert canceled due to [F:ADI]INTSHO missing field") From DOSSUB
    End
Endif

Filter [ADI] Where [F:ADI]NUMTAB = 424 Order By [F:ADI]CODE Asc

For [ADI]
    IDETECT = 0
    Filter [BPG] Where [F:BPG]BPRTYP = "LIBDOO"
&                  and [F:BPG]LAN = [F:ADI]A1
&                  and [F:BPG]TTRINT(0) = [F:ADI]INTSHO
&                  and [F:BPG]TTRALH(0) = [F:ADI]INTIT
    For [BPG]
        IDETECT = 1
        Break
    Next
    Filter [BPG]

    If !IDETECT
        If [F:ADI]INTIT <> ""
            If [F:ADI]INTSHO <> ""
                Trbegin [BPG]
                [F:BPG]BPRTYP = "LIBDOO"
                [F:BPG]LAN = [F:ADI]A1
                [F:BPG]TTRINT(0) = [F:ADI]INTSHO
                [F:BPG]TTRALH(0) = [F:ADI]INTIT
                Write [BPG]
                If fstat
                    Rollback
                    Call ECR_TRACE("Error while transfering the text with the following code in the ATABDIV table : " +
&                                   [F:ADI]CODE,1) From GESECRAN
                    IPBL = 1
                    Break
                Else
                    Commit
                Endif
            Endif
        Endif
    Endif
Next

If IPBL
    Call ECR_TIME("Texts transfert from ATABDIV failed.") From DOSSUB
Else
    Call ECR_TIME("Texts transfert from ATABDIV 424 to BPMISCCGF is completed with success.") From DOSSUB
Endif

Filter [ADI]

End




#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

If [F:ADS]MODULE(12) <> 2 : End : Endif
Call GENLIBDOO(APPLI)

End
