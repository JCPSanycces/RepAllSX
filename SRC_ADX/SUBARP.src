#<AdxTL>@(#)10.0.0.0 $Revision$
GBIDC1 = "TABCOUNTRY"
GTEST = 0
Call OBJET("ARP",GBIDC1,GBIDC2) From GOBJET
End

#-------------------------------------------------#
$ACTION
Case ACTION
 When "SETBOUT"      : Gosub SETBOUT
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "VERF_ANU"     : Gosub VERF_ANU
 When "CREATION"     : Gosub CREATION
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "APRES_MOD"    : Gosub APRES_MOD
 When "MODIF"        : Gosub MODIF
 When "LIENS"        : Gosub LIENS
 When "SEL_LISTE"    : Gosub SEL_LISTE
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "FIN_TABLE"    : Gosub FIN_TABLE
 When "VERF_LISTE"   : Gosub VERF_LISTE
 When "VERIF_CRE"    : Gosub VERIF
 When "VERIF_MOD"    : Gosub VERIF
 When "BOUT_TABLE"   : Gosub BOUT_TABLE
 When "CHANGE"       : Gosub CHANGE
 When "OUVRE"        : Gosub OUVRE
 When "ANNULE"       : Gosub ANNULE
Endcase
Return

#-------------------------------------------------#
$ANNULE
Delete [ARV] Where TYPCOD=1 & ETAT = [L]CODE
If fstat
 GOK = -1 : Call RSTA("ARV",[L]CODE) From GLOCK
Endif
Delete [ARX] Where TYPCOD=1 & EXTCOD = [L]CODE
If fstat
 GOK = -1 : Call RSTA("ARX",[L]CODE) From GLOCK
Endif
Return

#--------------------------#
# Opérations
#--------------------------#
# 1-Checkout
# 2-Commit
# 3-revert
# 4-launchRptIDE
#--------------------------#

#--------------------------#
# Statut
#--------------------------#
# 1-Partagé
# 2-Demande transfert
# 3-Sandbox
# 4-Demande Commit
# 5-Demande Revert
# 6-Chargement CR Designer
#--------------------------#

#-----------------------------------------------------------------------------#
$AVANT_MODFIC
Local Char    MESSA(80)
Local Integer NOL
If [M]NBCRY>0 & dim([F:ARP]DEVSTA)>0 and dim(GFUSION)>0 and (GFUSION or find(GUSER,"MB","DOM","CG"))
 For NOL=0 To [M]NBCRY-1
  Case [M]DEVSTA(NOL)
   When 0,1,3
   When 2 : # Checkout
    OK = func MOVETA([M]CRYCOD(NOL),func OPEDEV(1),[M]DEVSRV(NOL),[M]DEVUSR(NOL),[M]DEVLAN(NOL),[M]DEVAPP(NOL),MESSA)
    If !OK
     Gosub RAZLIG
     Call ERREUR(MESSA) From GESECRAN
    Else
     [M]DEVSTA(NOL) = 3
    Endif
   When 4 : # Commit
    OK = func MOVETA([M]CRYCOD(NOL),func OPEDEV(2),[M]DEVSRV(NOL),[M]DEVUSR(NOL),[M]DEVLAN(NOL),[M]DEVAPP(NOL),MESSA)
    If !OK
     [M]DEVSTA(NOL) = 3
     Call ERREUR(MESSA) From GESECRAN
    Else
   #LSE SAM 110136
     Call TRACE_COR("ETA",[M]CRYCOD(NOL),[M]DEVLAN(NOL),"C") From GOBJET
     Gosub RAZLIG
    Endif
   When 5 : # Revert
    OK = func MOVETA([M]CRYCOD(NOL),func OPEDEV(3),[M]DEVSRV(NOL),[M]DEVUSR(NOL),[M]DEVLAN(NOL),[M]DEVAPP(NOL),MESSA)
    If !OK
     [M]DEVSTA(NOL) = 3
     Call ERREUR(MESSA) From GESECRAN
    Else
     Gosub RAZLIG
    Endif
   When 6 : # Chargement CR Designer
    OK = func MOVETA([M]CRYCOD(NOL),func OPEDEV(4),[M]DEVSRV(NOL),[M]DEVUSR(NOL),[M]DEVLAN(NOL),[M]DEVAPP(NOL),MESSA)
    If !OK
     Call ERREUR(MESSA) From GESECRAN
    Endif
    [M]DEVSTA(NOL) = 3
  Endcase
 Next NOL
Endif
Return

#----------------------------#
$APRES_MOD
If [M]NBCRY>0 & dim([F:ARP]DEVSTA)>0 and dim(GFUSION)>0 and (GFUSION or find(GUSER,"MB","DOM","CG"))
 For NOL=0 To [M]NBCRY-1
  Gosub AFFLIG
 Next NOL
Endif
Return

#--------------------------#
Funprog OPEDEV(STA)
Value Integer STA
Local Char OPE(20)
Case STA
 When 1 : OPE = "checkout"
 When 2 : OPE = "commit"
 When 3 : OPE = "revert"
 When 4 : OPE = "launchRptIDE"
Endcase
End OPE

#----------------------------#
$RAZDUP
If [M]NBCRY>0 & dim([F:ARP]DEVSTA)>0
 For NOL=0 To [M]NBCRY-1
  Gosub RAZLIG
  Gosub AFFLIG
 Next NOL
Endif
Return

#-------------------------------#
$AFFLIG
Affzo [M:ARP1]DEVSTA(NOL) , DEVUSR(NOL) , DEVDAT(NOL)
Return

#--------------------------------#
$RAZLIG
[M]DEVSTA(NOL) = 1
[M]DEVUSR(NOL) = ""
[M]DEVDAT(NOL) = [0/0/0]
[M]DEVSRV(NOL) = ""
[M]DEVLAN(NOL) = ""
[M]DEVAPP(NOL) = ""
Return

#------------------------------------------------------------------------------#
Funprog SET_RPTID(RPT,USR,LAN,APP)
Value Char RPT , USR , LAN , APP
Local Char RPTID(4+GLONACR+GLONLAN+GLONAUS+GLONADS+type(GINSTID)-10)
RPTID = RPT+"#"+LAN+"#"+USR+"#"+GINSTID+"#"+APP
End RPTID

#---------------------------------------------------#
Funprog MOVETA(RPT,STA,SRV,USR,LAN,APP,ERM)
Value    Char    RPT , STA , SRV , USR , APP , LAN
Variable Char    ERM

Local Char    STARET(250)(1..10) , ACTION(10)
Local Integer I , K , OK

Local Char    ACCESS(250) , BASE(250)

ACTION = "ReportDev"

If find(STA, "checkout","launchRptIDE")
 Call INIVWEB(GINSTID,GVIRTDIR,ACCESS,BASE) From INTRUTILA
 Callui STARET=""    With "UIAction="+chr$(1)+ACTION,
&                        "Statement="+chr$(1)+STA,
&                        "PrintServer="+chr$(1)+SRV,
&                        "Report="+chr$(1)+RPT,
&                        "ReportID="+chr$(1)+func SET_RPTID(RPT,USR,LAN,APP),
&                        "Lang="+chr$(1)+LAN,
&                        "Solution="+chr$(1)+GINSTID,
&                        "Folder="+chr$(1)+APP,
&                        "ODBCType=" + chr$(1) + func AFNC.PART(BASE,1),
&                        "ODBCBase=" + chr$(1) + func AFNC.PART(BASE,2),
&                        "ODBCServer=" + chr$(1) + func AFNC.PART(BASE,3),
&                        "ODBCPort=" + chr$(1) + func AFNC.PART(BASE,4)
Else
 Callui STARET=""    With "UIAction="+chr$(1)+ACTION,
&                        "Statement="+chr$(1)+STA,
&                        "PrintServer="+chr$(1)+SRV,
&                        "Report="+chr$(1)+RPT,
&                        "ReportID="+chr$(1)+func SET_RPTID(RPT,USR,LAN,APP),
&                        "Lang="+chr$(1)+LAN,
&                        "Solution="+chr$(1)+GINSTID,
&                        "Folder="+chr$(1)+APP
Endif

# Tout s'est bien passé ?

If dim(GFUSION)<0 or !GFUSION
 OK = 1
Else
 For I=1 To dim(STARET)
  K = instr(1,STARET(I),ACTION)
  If K
   K = instr(1,STARET(I),"=")
   If K
    ERM = right$(STARET(I),K+2)
    If ERM="" : # Ca s'est bien passé
     OK = 1
    Else
     OK = 0
    Endif
   Endif
  Else : # C'est forcémement une erreur
   K = instr(1,STARET(I),"=")
   If K
    ERM = right$(STARET(I),K+2)
    OK = 0
   Endif
  Endif
 Next I
Endif

End OK

#-------------------------------------------------#
$RAZCRE
Gosub GRISE_GESZPL
Return

#-------------------------------------------------#
$OUVRE
If clalev([F:ARV])=0  : Local File AREPORTV   [ARV]  : Endif
If clalev([F:ARX])=0  : Local File AREPORTX   [ARX]  : Endif
Return

#-------------------------------------------------#
$CHANGE
Update [ARV] Where TYPCOD=1 & ETAT =[L]OCODE With ETAT=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$AREPORTV"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("ARV",[L]OCODE) From GLOCK : Return
Endif
Update [ARX] Where TYPCOD=1 & EXTCOD =[L]OCODE With EXTCOD=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$AREPORTX"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("ARX",[L]OCODE) From GLOCK : Return
Endif
Return

#-------------------------------------------------#
$SETBOUT
If CLECUR=0 or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"B2") From GOBJET : # Impression , Copie
Endif
If [F:ARP]EXEFLG=2 or [F:ARP]ENAFLG<>2
 Call VIREBOUT(CHAINE,"B") From GOBJET
Endif
Return

#-------------------------------------------------#
$VERF_ANU
If clalev([F:AFC])=0 : Local File =APPLI+".AFONCTION" [AFC] : Endif
If clalev([F:ARX])=0 : Local File =APPLI+".AREPORTX"  [ARX] : Endif
If clalev([F:AOB])=0 : Local File =APPLI+".AOBJET"    [AOB] : Endif
Local Char MESSA(250)
For [AFC] Where RPT1=[L]CODE | RPT2=[L]CODE
 Read [ARX]ARX0(1) = [L]CODE
 If fstat
  OK = 0 : MESSA = mess(75,123,1)-[F:AFC]CODINT : Break : # Fonction
 Endif
Next AFC
If OK
 For [AOB] Where RPT1=[L]CODE | RPT2=[L]CODE
  Read [ARX]ARX0(1) = [L]CODE
  If fstat
   OK = 0 : MESSA = mess(33,115,1)-[F:AOB]ABREV : Break : # Objet
  Endif
 Next AOB
Endif
If !OK
 Call ERREURT(mess(1,115,1)+"\"+mess(49,139,1)-MESSA,1) From GESECRAN
 # Suppression impossible/Clé utilisée dans
Endif
Return

#-------------------------------------------------#
$VERIF
Local Integer MAXSRC , MAXFIL
MAXSRC = 9  : # Nombre max de sources de données secondaires
MAXFIL = 10 : # Nombre maxi de tables par source de données
For I=1 To [M:ARP3]NBRTBL
 If [M:ARP3]NUM(I-1)>[M:ARP3]NBRSRC
  GMESSAGE = mess(33,139,1) : # Numéro incorrect
  SUIZON = "[M:ARP3]NUM("+num$(I-1)+")"
  OK = 0 : Break
 Endif
Next I
If !OK : Return : Endif
If [M:ARP3]NBRSRC>MAXSRC
 # Le nombre de sources de données est limité à #
 GMESSAGE = func AFNC.MES(mess(38,135,1),num$(MAXSRC))
 OK = 0 : Return
Endif
For I=1 To [M:ARP3]NBRSRC
 K = 0
 For J=1 To [M:ARP3]NBRTBL
  If [M:ARP3]NUM(J-1)=I
   K += 1
  Endif
 Next J
 If K>MAXFIL
  # Trop de tables dans la source de données $1$ (max $2$)
  GMESSAGE = func AFNC.MES2(mess(39,135,1),num$(I),num$(MAXFIL))
  OK = 0 : Break
 Endif
Next I
Return

#-------------------------------------------------#
$CREATION
For nolign=1 To [M]NBRPAR
 [F:ARD] = [M:ARP2]
 [F:ARD]RPTCOD = [F:ARP]RPTCOD
 [F:ARD]PARNUM = nolign
 Write [ARD]
 If fstat
  GOK = 0 : Call FSTA("ARD") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
If [M:ARP3]NBRSRC>0
 Raz [F:ARO]
 [F:ARO] = [M:ARP3]
 [F:ARO]RPTCOD = [F:ARP]RPTCOD
 Write [ARO]
 If fstat
  GOK = 0 : Call FSTA("ARO") From GLOCK : Return
 Endif
Endif
# Mise a jour valeur par defaut (suppresion champ dans valeur par defaut)
For [ARV]ARV0 Where TYPCOD = 1 & ETAT = [M]RPTCOD
 Read [ARD]ARD1 = [ARV]PARAM;[M]RPTCOD
 If fstat
  Delete [ARV] Curr
  If fstat=1
   GOK=-1 : Call RSTA("ARV",[M]RPTCOD+"~"+[ARV]PARAM) From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
Return

#-------------------------------------------------#
$MODIF
Delete [ARD] Where RPTCOD=[M]RPTCOD
If fstat=1
 GOK=-1 : Call RSTA("ARD",[M]RPTCOD) From GLOCK : Return
Endif
Delete [ARO] Where RPTCOD=[M]RPTCOD
If fstat=1
 GOK=-1 : Call RSTA("ARO",[M]RPTCOD) From GLOCK : Return
Endif
Gosub CREATION
Return

#-------------------------------------------------#
$LIENS
Call TEXTE([F:ARP]RPTDES,[M]ZRPTDES) From OBJDIV
Call TEXTE([F:ARP]RPTSHO,[M]ZRPTSHO) From OBJDIV
nolign = 0
For [ARD]ARD0 Where RPTCOD=CLECUR1
 nolign += 1
 [M:ARP2] = [F:ARD]
 Call TEXTE([F:ARD]PARNAM,[M]ZPARNAM(nolign-1)) From OBJDIV
Next
[M:ARP2]NBRPAR = nolign
Read [ARO]ARO0 = CLECUR1
If !fstat
 [M:ARP3] = [F:ARO]
 For nolign=1 To [M]NBRSRC
  Call TEXTE([F:ARO]SRC(nolign-1),[M:ARP3]ZSRC(nolign-1)) From OBJDIV
 Next nolign
 For nolign=1 To [M]NBRTBL
  [M:ARP3]LIBNUM(nolign-1) = [M:ARP3]ZSRC([M:ARP3]NUM(nolign-1)-1)
  Read [ATB]CODFIC = [M:ARP3]TBL(nolign-1)
  If !fstat
   Call TEXTE([F:ATB]INTITFIC,[M:ARP3]LIBTBL(nolign-1)) From OBJDIV
  Endif
 Next nolign
Endif
For I=1 To dim([F:ARP]CRYCOD)
 If [F:ARP]CRYCOD(I-1)<>""
  [M:ARP1]NBCRY = I
  [M:ARP1]DEVSTA(I-1) = max(1,[M:ARP1]DEVSTA(I-1))
 Endif
Next I
Gosub GRISE_GESZPL
Gosub GRISE_FNC
Gosub GRISE_CODZPL
Return

#------------------------------#
$GRISE_GESZPL
If dim([M:ARP1]GESZPL)<=0
 Return
Elsif !func AFNC.ACTIV("AZPL")
 [M:ARP1]GESZPL = 1
 Affzo [ARP1]GESZPL
 Grizo [ARP1]GESZPL
Else
 Actzo [ARP1]GESZPL
Endif
Return

#------------------------------#
$GRISE_FNC
If [M:ARP1]AUZFCY<>2
 Effzo [ARP1]FNC
 Grizo [ARP1]FNC
Else
 Actzo [ARP1]FNC
Endif
Return

#------------------------------#
$GRISE_CODZPL
If dim([M:ARP1]GESZPL)<=0
 Return
Elsif [M:ARP1]GESZPL<>2
 Effzo [ARP1]CODZPL
 Grizo [ARP1]CODZPL
Else
 Actzo [ARP1]CODZPL
Endif
Return

#-------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File AREPORT  [ARP1]
 Local File AREPORTD [ARD1]
 Local File AREPORTS [ARO1]
 Local File ATEXTE   [ATX1]
Else
 Local File =[M]DOSORG+".AREPORT"  [ARP1]
 Local File =[M]DOSORG+".AREPORTD" [ARD1]
 Local File =[M]DOSORG+".AREPORTS" [ARO1]
 Local File =[M]DOSORG+".ATEXTE"   [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AREPORT  [ARP2]
 Local File AREPORTD [ARD2]
 Local File AREPORTS [ARO2]
 Local File ATEXTE   [ATX2]
Else
 Local File =[M]DOSDES+".AREPORT"  [ARP2]
 Local File =[M]DOSDES+".AREPORTD" [ARD2]
 Local File =[M]DOSDES+".AREPORTS" [ARO2]
 Local File =[M]DOSDES+".ATEXTE"   [ATX2]
Endif
OK = 1
If GTRACE=""
 Read [ARP2]ARP0 = TABLE
 If !fstat
  OK=1 : Call AVERTIR(mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [ARP1], [ARD1], [ARP2], [ARD2], [ATX1], [ATX2], [ARO1], [ARO2]
Return

$TR_COP
GOK = 1
Trbegin [ARP2] , [ARD2] , [ARO2]
 Delete [ARP2] Where RPTCOD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AREPORT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ARP2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ARD2] Where RPTCOD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AREPORTD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ARD2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ARO2] Where RPTCOD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AREPORTS" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ARO2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ARP1]ARP0 Where RPTCOD=TABLE
  [F:ARP2] = [F:ARP1]
  Call COPTEXTE([F:ARP1]RPTDES,[F:ARP2]RPTDES) From OBJDIV
  Call COPTEXTE([F:ARP1]RPTSHO,[F:ARP2]RPTSHO) From OBJDIV
  If dim([F:ARP2]UPDUSR)>0 : [F:ARP2]UPDUSR = GUSER : Endif
  If dim([F:ARP2]UPDDAT)>0 : [F:ARP2]UPDDAT = date$ : Endif
  If dim([F:ARP2]UPDTIM)>0 : [F:ARP2]UPDTIM = time  : Endif
  Write [ARP2]
  If fstat
   GOK=0 : Call FSTA("ARP2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ARD1]ARD0 Where RPTCOD=TABLE
  [F:ARD2] = [F:ARD1]
  Call COPTEXTE([F:ARD1]PARNAM,[F:ARD2]PARNAM) From OBJDIV
  Write [ARD2]
  If fstat
   GOK=0 : Call FSTA("ARD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Read [ARO1]ARO0 = TABLE
 If !fstat
  [F:ARO2] = [F:ARO1]
  For K=0 To [F:ARO1]NBRSRC-1
   Call COPTEXTE([F:ARO1]SRC(K),[F:ARO2]SRC(K)) From OBJDIV
  Next K
  Write [ARO2]
  If fstat
   GOK = 0 : Call FSTA("ARO2") From GLOCK : Goto AB_TR_COP
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#-----------------------------------------------------------#
# Actions PARNOLIB, SELARP, SELARP2, SELARPOPT, SELCRY
#-----------------------------------------------------------#

$SEL_LISTE
Case LISTE
 When "PARNOLIB"    : Gosub SEL_NOLIB
 When "SELARP"      : Gosub SEL_PARAM
 When "SELARP2"     : Gosub SEL_PARAM2
Endcase
Return

$VERF_LISTE
Case LISTE
 When "SELARP"      : Gosub VERF_PARAM
Endcase
Return

$SEL_NOLIB
Local Char TEX(GLONDES)(1..GNBSEL) , TEXTE(GLONDES)(1..GNBSEL,1..2)
Call LECTURE("ATY",PARAM(1),"") From CONTOBJ
If [F:ATY]OBJLIEN="ADI"
 If clalev([ADV])=0 : Local File ATABTAB [ADV] : Endif
 If clalev([AXX])=0 : Local File ATEXTRA [AXX] : Endif
 Link [ADV] With [AXX]AXX0 = "ATABTAB";"LNGDES";GLANGUE;NUMCAR;"" As [AAST] Order By NUMTAB
 NBTEX = 0
 For [AAST]
  NBTEX += 1
  TEX(NBTEX)     = num$([F:ADV]NUMTAB)
  TEXTE(NBTEX,2) = [F:AXX]TEXTE
  If NBTEX>=dim(TEX)-1 : Break : Endif
 Next
 Call TITOBJ("ADV","!",TIT) From CONTOBJ
 TIT  = mess(12,123,1)-TIT : # Sélection
Else
 If clalev([AML])=0 : Local File AMENLOC [AML] : Endif
 If clalev([AST])=0 : Local File APLSTD  [AST] : Endif
 Local Integer CHP
 NBTEX = 0
 For [AML] Where MENLOCAL=2
  NBTEX += 1
  CHP = [F:AML]MENLOC
  TEX(NBTEX) = num$(CHP)
  If CHP>=1 & CHP<=99      : TEXTE(NBTEX,2) = mess(CHP,0,1)
  Elsif CHP>200 & CHP<8900 : TEXTE(NBTEX,2) = mess(CHP-200,200,1)
  Else                       TEXTE(NBTEX,2) = mess(0,CHP,1)
  Endif
  If NBTEX>=dim(TEX)-1 : Break : Endif
 Next AML
 Call TITOBJ("AST","!",TIT) From CONTOBJ
 TIT  = mess(12,123,1)-TIT : # Sélection
Endif
Return

$SEL_PARAM
Local Integer LIG(1..dim(TEX))
Local Char    RPT(GLONARP)(1..dim(TEX)) , TEXTE(GLONDES)(1..dim(TEX),1..3) , TIT(GLONDES)(1..3)
Local Integer NOLI
NOLI = nolign-1
NBTEX = 0
For [ARD]ARD1 Where PARCOD=VALEUR
 If NBTEX>=dim(TEX)-1 : Break : Endif
 NBTEX += 1
 Call TEXTE([F:ARD]PARNAM,TEXTE) From OBJDIV
 TEXTE(NBTEX,2) = [F:ARD]RPTCOD
 TEXTE(NBTEX,3) = TEXTE
 TEX(NBTEX)     = VALEUR
 RPT(NBTEX)     = [F:ARD]RPTCOD
 LIG(NBTEX)     = [F:ARD]PARNUM
Next
Return

$VERF_PARAM
Read [ARD]ARD0 = RPT(CHOIX);LIG(CHOIX)
[M]PARCOD(NOLI)    = [F:ARD]PARCOD
[M]PARNAM(NOLI)    = [F:ARD]PARNAM
Call TEXTE([M]PARNAM(NOLI),[M]ZPARNAM(NOLI)) From OBJDIV
[M]PARTYP(NOLI)    = [F:ARD]PARTYP
[M]PARLNG(NOLI)    = [F:ARD]PARLNG
[M]PARNOLIB(NOLI)  = [F:ARD]PARNOLIB
[M]PARSTREND(NOLI) = [F:ARD]PARSTREND
[M]PARSAI(NOLI)    = [F:ARD]PARSAI
[M]PARDEF1(NOLI)   = [F:ARD]PARDEF1
[M]PARDEF2(NOLI)   = [F:ARD]PARDEF2
[M]PARCTL(NOLI)    = [F:ARD]PARCTL
[M]PARCTLTAB(NOLI) = [F:ARD]PARCTLTAB
Return

$SEL_PARAM2
Local Char    TEXTE(GLONDES)(1..dim(TEX),1..3) , TIT(GLONDES)(1..3)
Link [ARD] With [ATX]NUMERO = GLANGUE;[F:ARD]PARNAM As [ARD_]
& Order By Key CLE = toupper([F:ARD]PARCOD);[F:ARD]RPTCOD
If VALEUR<>""
 Filter [ARD_] Where toupper(left$([F:ARD]PARCOD,1))=toupper(left$(VALEUR,1))
Endif
NBTEX = 0
For [ARD_]CLE(1)
 NBTEX += 1
 TEX(NBTEX)     = tolower([F:ARD]PARCOD)
 TEXTE(NBTEX,2) = [F:ATX]TEXTE
 TEXTE(NBTEX,3) = [F:ARD]RPTCOD
 If NBTEX>=dim(TEX)-1
  Break
 Endif
Next
Filter [ARD_]
Return

$SEL_TABLE
Case TABLE
 When "SELCRY","SELCRYPAT" : Gosub SEL_CRY
Endcase
Return

$FIN_TABLE
Case TABLE
 When "SELCRY" : Gosub FIN_CRY
Endcase
Return

$BOUT_TABLE
Case TABLE
 When "SELCRY","SELCRYPAT"
  Case GSTATUT
   When GSTASVG   : Gosub SVG_CRY
   When GSTAPRG   : Gosub PRG_CRY
   When GSTASRA   : Gosub SRA_CRY
  Endcase
  OK = 0
Endcase
Return

$FIN_CRY
If dim(PARAM)>=2
 PARAM(2) = [AT2]LAN
Endif
Return

#-----------------------------------------#
$SEL_CRY
Local Integer  I , J , K , STAT , NB , DEBUT , REVERSE
Local Shortint NBLAN , NBCRY : NBCRY = 1000
Local Char     TBCRY(GLONACR+2)(1..NBCRY) , WORDRE(250) , WORDRE2(250)
Local Char     WLAN(GLONLAN)(1..GNBSEL) , WETA(GLONACR)(1..GNBSEL) , WRPTC(GLONARP)(1..GNBSEL)
Local Char     WDES(GLONDES)(1..GNBSEL)
Local Char     WUSR(GLONDES)(1..GNBSEL) , WTIM(10)(1..GNBSEL)
Local Date     WDAT(1..GNBSEL)
Local Char     FILRAP(250) , CHAINE(250) , FILTRE(250) , LANGUES(GLONLAN)(1..30) , LANSEL(GLONLAN)
Local Char     YLAN(GLONLAN) , YETA(GLONACR) , YRPTC(GLONARP) , YDES(GLONDES)
Local Integer  YMDL , WMDL(1..GNBSEL)
Local Char     YUSR(GLONDES) , YTIM(10)
Local Date     YDAT
Local Char     MACHINE(GDIMFIC) , REPBASE(GDIMFIC), DOSSIER(GDIMFIC) , APPLI(GLONADS)
Local Char     OS(250)

If PARAM(1) = ""
 DOSSIER = nomap
Else
 DOSSIER = PARAM(1)
Endif

LANSEL = PARAM(2)

If DOSSIER = nomap
 If clalev([F:ARP])=0 : Local File AREPORT [ARP] : Endif
Else
 If clalev([F:ARP])=0 : Local File =DOSSIER+".AREPORT" [ARP] : Endif
Endif

If clalev([F:ARP])=0 : Local File AREPORT [ARP] : Endif
Local File    (Char ETA(GLONACR) , Char LAN(GLONLAN) , Char RPTC(GLONARP) , Char DES(GLONDES)
&            , Char USR(GLONDES) , Date DAT , Char TIM(10) , Libelle MDL)
&     From     Variable  WETA , WLAN , WRPTC , WDES , WUSR , WDAT , WTIM , WMDL
&     As      [AT2]
FILTRE = 'TBCRY(I)>="'+VALEUR+'"'
FILRAP = "1=1"
DEBUT  = 1
REVERSE= 1
SIZCOL = 330
SIZLIG = 100

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

WORDRE = 'lsadx -a "'+APPLI
If DOSSIER=nomap & adxmother(0)<>nomap
 If GFONCTION <> "APATCH" : WORDRE -= adxmother(0)  : Endif
 If adxmother(1)<>adxmother(0) & adxmother(1)<>nomap
  WORDRE -= adxmother(1)
 Endif
Endif
Case TABLE
 When "SELCRY"    : Call LISREP(GOS,MACHINE,filpath("REPORT","","",APPLI),NBLAN,LANGUES) From SELFICREP
 When "SELCRYPAT" : NBLAN = 0 : For I=0 To [M]NBLAN-1 : NBLAN += 1 : LANGUES(NBLAN) = [M]LANGUE(I) : Next I
Endcase
Raz NBCOL , COL , COLTYP , TIT
Call  TRANSCOL("ETA",NBCOL,COL,TIT,FMTCOL) From OBJDIV
Gosub CHARGE_ETA
TIT = mess(8,31,1) : # Selection
Default File [AT2]
START = "ETA"
Return

#-----------------------------------#
$CHARGE_ETA
Local Integer WOK
NB = 0
For J=1 To [L]NBLAN
 If LANSEL="" or LANSEL=[L]LANGUES(J)
  WORDRE2 = WORDRE +'" REPORT/'+[L]LANGUES(J)-'rpt'
  Call SYSTEME2(MACHINE,WORDRE2,"",STAT,TBCRY) From ORDSYS
  STAT = min(STAT,dim(TBCRY))
  If REVERSE < 0
   DEBUT = STAT
   STAT  = 1
  Endif
  For I=DEBUT To STAT Step REVERSE
   Raz YETA,YLAN,YDES,YRPTC
   If VALEUR="" or toupper(left$(VALEUR,1))=toupper(left$(TBCRY(I),1))
    If !find(TBCRY(I)+"~"+[L]LANGUES(J),WETA(1..NB)+"~"+WLAN(1..NB)) & evalue(FILTRE)
     YLAN = [L]LANGUES(J)
     YETA = TBCRY(I)
     Raz YRPTC, YDES , YUSR , YDAT , YTIM
     YMDL = 1
     Filter [ARP] Where CRYCOD=TBCRY(I) & LAN=[L]LANGUES(J)
     Read [ARP]ARP0 First
     Filter [ARP]
     If !fstat
      YRPTC = [ARP]RPTCOD
      YDES  = func AFNC.TEXTE([F:ARP]RPTDES)
      YMDL  = [F:ARP]MODULE
     Endif
     If find("[F:AT2]USR",COL) or find("[F:AT2]DAT",COL) or find("[F:AT2]TIM",COL)
      CHAINE = filpath("REPORT/"+YLAN,YETA,"rpt")
      Call INFOFIC(CHAINE,YUSR,GBIDC1,GBIDD1,YDAT,YTIM,WOK) From EDITRTWEB
     Endif
     If evalue(FILRAP)
      If NB>=GNBSEL : Break : Endif
      NB +=1
      WETA(NB)  = YETA
      WLAN(NB)  = YLAN
      WRPTC(NB) = YRPTC
      WDES(NB)  = YDES
      WMDL(NB)  = YMDL
      WUSR(NB)  = YUSR
      WDAT(NB)  = YDAT
      WTIM(NB)  = YTIM
     Endif
    Endif
   Endif
  Next I
 Endif
Next J
For I=NB+1 To GNBSEL
 WETA(I) = chr$(255)
Next I
adxmxl = NB
Return

#-----------------#
$SVG_CRY
If adxmxl
 FILTRE = 'TBCRY(I)>"'+WETA(adxmxl)+'"'
Else
 FILTRE = ''
Endif
Gosub CHARGE_ETA
Default File [AT2]
Return

#-----------------#
$PRG_CRY
FILTRE = 'TBCRY(I)<"'+WETA(1)+'"'
REVERSE = -1
Gosub CHARGE_ETA
REVERSE =1
If adxmxl
 FILTRE = 'TBCRY(I)>="'+WETA(adxmxl)+'"'
Else
 FILTRE = '1=1'
Endif
DEBUT   = 1
REVERSE = 1
Gosub CHARGE_ETA
Default File [AT2]
Return

#-----------------#
$SRA_CRY
If CRIRAP<>""
 FILRAP = CRIRAP
 For I=1 To NBCOL
  Case I
   When 1 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]YETA")
   When 2 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]YLAN")
   When 3 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]YRPTC")
   When 4 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]YDES")
   When 5 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]YMDL")      # 121313-selection
   When 6 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]YUSR")      # 121313-selection
   When 7 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]YDAT")      # 121313-selection
   When 8 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]YTIM")      # 121313-selection
  Endcase
 Next I
 CRIRAP = ''
Else
 FILRAP = '1=1'
Endif
FILTRE = '1=1'
REVERSE = 1
Gosub CHARGE_ETA
Default File [AT2]
Return


#--------------------------------------
# ajout cg oct 2012 , traduction des reports sur x3 et hrm uniquement
# dans le cadre dev. co dev
# on active bouton en interne uniquement si
# gadonix = 2 et produite x3 ou hrm
# et si le trt ARPTTRDB existe sur le dossier
#----------------------------------------
$REPORT_TRANSLATION
Local Char    WBUTTON(250)
Raz  WBUTTON
If GADONIX = 2 and (GPRODUIT = 0 or GPRODUIT = 2)
     If [F:ARP]MULLAN = 2
        # on ajout option si trt est là
        Local Integer WOK
        WOK = 0
        Call EXISTE_ADX (adxmac(-1),nomap,"ARPTTRDB",WOK) From ORDSYS
        If WOK = 1
             WBUTTON = mess(296,139,1): # traduction report
        Endif
     Endif
Endif
Return

#-------------------------------------------------#
## ARP1
#-------------------------------------------------#

Subprog C_PRTDEF(VALEUR)
Variable Char VALEUR()
If VALEUR<>""
 Call LECTURE("AIM",VALEUR,"") From CONTOBJ
 If [F:AIM]PRT=2 & [F:AIM]PRTNAT>1 & [F:AIM]PRTNAT<>[M]PRTNAT
  GMESSAGE = mess(5,133,1)-"("+mess([F:AIM]PRTNAT,22,1)+")"
  mkstat = 1 : End
 Elsif [F:AIM]PRT=6 & ([M]GESZPL<>2 or [M]CODZPL="")
  GMESSAGE = mess(31,143,1) : # Paramétrage imprimante ZPL inexistant
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_PRTDEF(VALEUR)
Variable Char VALEUR()
Local Integer I
If VALEUR=""
 For I=0 To [M]NBCRY-1
  If [M]FORETA(I)=3 : # Préférence imprimante
   [M]FORETA(I) = 1 : # Defaut
   Affzo FORETA(I)
  Endif
 Next I
Else
 Call LECTURE("AIM",VALEUR,"") From CONTOBJ
 If find([F:AIM]PRT,2,5)
  For I=0 To [M]NBCRY-1
   [M]FORETA(I)=3 : # Préférence imprimante
   Affzo FORETA(I)
  Next I
 Endif
Endif
End

Subprog AS_PRTOBL(VALEUR)
Variable Integer VALEUR
If [M]PRTDEF=""
 VALEUR = 1 : mkstat = 2 : End
Endif
End

Subprog D_ORIENT(VALEUR)
Variable Integer VALEUR
If nolign=1
 VALEUR = 1
Else
 VALEUR = [M]ORIENT(nolign-2)
Endif
End

Subprog D_CRYCOD(VALEUR)
Variable Char VALEUR()
If indice=0
 VALEUR = [M]RPTCOD
Endif
End

#--------------------------#
# Opérations
#--------------------------#
# 1-Transfert
# 2-Commit
# 3-Revert
# 4-launchRptIDE
#--------------------------#

#--------------------------#
# Statut
#--------------------------#
# 1-Partagé
# 2-Demande transfert
# 3-Sandbox
# 4-Demande Commit
# 5-Demande Revert
# 6-Chargement CR Designer
#--------------------------#

Subprog IB_NBCRY
Local Integer NOL
Raz GBOUT2 , GBOUT3 , GBOUT4 , GBOUT5 , GBOUT6 , GBOUT7 , GBOUT8
If nolign<1 or dim([M]DEVSTA)<=0
 End
Elsif dim(GFUSION)<0 or (!GFUSION & !find(GUSER,"MB","DOM","CG")) : # For classic client only
 End
Elsif dim(GDEVCRY)<0 or GDEVCRY<2
 End
Endif
NOL = nolign-1
Case [M]DEVSTA(NOL)
 When 0,1
  GBOUT3 = mess(40,135,1) : # Transfert
  Gosub REPORT_TRANSLATION
  GBOUT8 = WBUTTON
 When 2
  GBOUT6 = mess(46,135,1) : # Annulation demande
  GBOUT2 = mess(80,151,1) : # Infos
 When 3
 #LSE 06/08/2015 SAM 109900
  If [M]DEVUSR(NOL)=GUSER or GDEVCRY=3
    GBOUT5 = mess(42,135,1) : # revert
  Endif
  GBOUT2 = mess(80,151,1) : # Infos
  If [M]DEVUSR(NOL)=GUSER
   GBOUT4 = mess(41,135,1) : # Commit
   GBOUT7 = mess(47,135,1) : # Chargement CR Designer
  Endif
 When 4,5,6
  GBOUT6 = mess(46,135,1) : # Annulation demande
  GBOUT2 = mess(80,151,1) : # Infos
Endcase
End

Subprog B2_NBCRY
Local Integer NOL
NOL = nolign-1
If NOL>=0
 Local Char MESSA(250)
 MESSA  =     mess(17,135,1) +'="'+[M]CRYCOD(NOL)+'"'
 MESSA += '\'+mess(190,75,1) +'="'+mess([M]DEVSTA(NOL),7945,1)+'"'
 MESSA += '\'+mess(1,76,1)   +'="'+[M]DEVUSR(NOL)+'"'
 MESSA += '\'+mess(88,100,1) +'=' +format$(GFMD,[M]DEVDAT(NOL))
 MESSA += '\'+mess(259,123,1)+'="'+[M]DEVLAN(NOL)+'"'
 MESSA += '\'+mess(85,115,1) +'="'+[M]DEVAPP(NOL)+'"'
 MESSA += '\'+mess(15,135,1) +'="'+[M]DEVSRV(NOL)+'"'
 Call MESSAGE(MESSA) From GESECRAN
Endif
End

Subprog B3_NBCRY
Local Char    PARAM(20)(1..2)
Local Integer NOL
NOL = nolign-1
Gosub CONTDEVCRY
If !OK : End : Endif
Call S_AFF_CHAR([M]DEVSRV(NOL),PARAM,"INISRV","ASELSIMP","") From GACTION
Call S_LIS_CHAR([M]DEVSRV(NOL),PARAM,"SELSERV","ASELSIMP","") From GACTION
If [M]DEVSRV(NOL)<>""
 PARAM(1) = "1"
 Call S_AFF_CHAR([M]DEVSRV(NOL),PARAM,"CONTSERV","ASELSIMP","") From GACTION
 If mkstat
  Call ERREUR(GMESSAGE) From GESECRAN
  End
 Else
  Gosub FIND_REPORT
  If DEVAPP(NOL)<>""
   [M]DEVUSR(NOL) = GUSER
   [M]DEVDAT(NOL) = date$
   [M]DEVSTA(NOL) = 2
   Gosub AFFLIG
   mkstat = 4
  Else
   Call ERREUR([M]CRYCOD(NOL)+".rpt"-":"-mess(101,100,1)) From GESECRAN : # Fichier inexistant
   mkstat = 1 : End
  Endif
 Endif
Else
 Call ERREUR(mess(13,135,1)) From GESECRAN : # Serveur d'impression non défini
 End
Endif
Gosub SUITE
End

#------------------------------------------#
$CONTDEVCRY
Local Integer I , OK , IND
OK = 1
If [M]DEVSTA(NOL)<>3 or [M]DEVUSR(NOL)=GUSER or GDEVCRY<>3
 For I=1 To [M]NBCRY
  If [M]DEVSTA(I-1)=3 & [M]DEVUSR(I-1)<>GUSER
   IND = I-1 : OK = 0 : Break
  Endif
 Next I
 If !OK
  # L'état $1$ (ligne $2$) est en cours de développement par $3$ depuis le $4$
  Call ERREUR(func AFNC.MES4(mess(43,135,1),[M]CRYCOD(IND),num$(IND+1),[M]DEVUSR(IND),format$(GFMD,[M]DEVDAT(IND)))) From GESECRAN
  End
 Endif
Endif
Return

#--------------------------------------#
$FIND_REPORT
If [M]MULLAN=2
 For I=0 To 7
  If nomap(I)<>""
   If filinfo(filpath(filpath("REPORT",GLANGUE,"",I),[M]CRYCOD(NOL),"rpt",I),0)>=0
    [M]DEVAPP(NOL) = nomap(I)
    [M]DEVLAN(NOL) = GLANGUE
    Break
   Endif
  Endif
 Next I
Endif
If DEVAPP(NOL)=""
 For I=0 To 7
  If nomap(I)<>""
   If filinfo(filpath(filpath("REPORT",[M]LAN,"",I),[M]CRYCOD(NOL),"rpt",I),0)>=0
    [M]DEVAPP(NOL) = nomap(I)
    [M]DEVLAN(NOL) = [M]LAN
    Break
   Endif
  Endif
 Next I
Endif
Return

Subprog B4_NBCRY
Local Integer NOL , OK
NOL = nolign-1
Gosub CONTDEVCRY
If !OK : End : Endif
OK = 1
If [M]DEVUSR(NOL)<>GUSER
 # Etes vous sûr de faire un "$1$" sur l'état $2$ développé par $3$ ?
 Call AVERTIR(func AFNC.MES3(mess(45,135,1),func OPEDEV(2),[M]CRYCOD(NOL),[M]DEVUSR(NOL)),OK) From GESECRAN
 If OK<>2 : OK = 0 : Endif
Endif
If OK
 [M]DEVSTA(NOL) = 4
 Gosub AFFLIG
 mkstat = 4
Endif
Gosub SUITE
End

Subprog B5_NBCRY
Local Integer NOL , OK
NOL = nolign-1
Gosub CONTDEVCRY
If !OK : End : Endif
OK = 1
If [M]DEVUSR(NOL)<>GUSER
 # Etes vous sûr de faire un $1$ sur l'état $2$ développé par $3$ ?
 Call AVERTIR(func AFNC.MES3(mess(45,135,1),func OPEDEV(3),[M]CRYCOD(NOL),[M]DEVUSR(NOL)),OK) From GESECRAN
 If OK<>2 : OK = 0 : Endif
Endif
If OK
 [M]DEVSTA(NOL) = 5
 Gosub AFFLIG
 mkstat = 4
Endif
Gosub SUITE
End

Subprog B6_NBCRY
Local Integer NOL
NOL = nolign-1
Case [M]DEVSTA(NOL)
 When 2     : Gosub RAZLIG
 When 4,5,6 : [M]DEVSTA(NOL) = 3
Endcase
Gosub AFFLIG
mkstat = 4
Gosub SUITE
End

Subprog B7_NBCRY
Local Integer NOL , OK
NOL = nolign-1
Gosub CONTDEVCRY
If !OK : End : Endif
[M]DEVSTA(NOL) = 6
Gosub AFFLIG
mkstat = 4
Gosub SUITE
End

#-------------------------------#
# ajout bouton traduction report dans cas syracuse"
# bouton accesible dans envi. de dev en interne et unqiuement si bouton transfert actif
#--------------------------------------------------------------------------------------#
Subprog B8_NBCRY
Local Integer NOL , OK
NOL = nolign-1
Gosub CONTDEVCRY
If !OK : End : Endif

# lancement trad
Gosub REPORT_TRANSLATION
If WBUTTON <> ""
    Gosub LAUNCH_TRANSLATE From ARPTTRDB
Else
   Call ERREUR(mess(1,123,1)) From GESECRAN : # Fonction non autorisée
Endif

End


$SUITE
zonsui = "EXEFLG" : # Sous convergence, on reste sur la ligne et les boutons ne sont pas raffraichis
Return

Subprog C_NBCRY
If nolign>0 & find(status,68,65,83) : # Couper/Suppressions
 If dim([M]DEVSTA)>0
  If nolign1=0 : nolign1 = nolign : Endif
  Gosub CONTDELCRY
  If !OK
   mkstat = 1 : End
  Endif
 Endif
Endif
End

#--------------------------------#
$CONTDELCRY
Local Integer I , OK , CAS , IND
OK = 1
For I=nolign To nolign1
 If find([M]DEVSTA(I-1),3,4,5)
  CAS = 1
  IND = I-1
  OK = 0
  If [M]DEVUSR(I-1)<>GUSER
   CAS = 2
  Endif
  Break
 Endif
Next I
If CAS=2
 # L'état $1$ (ligne $2$) est en cours de développement par $3$ depuis le $4$
 GMESSAGE = func AFNC.MES4(mess(43,135,1),[M]CRYCOD(IND),num$(IND+1),[M]DEVUSR(IND),format$(GFMD,[M]DEVDAT(IND)))
 Return
Elsif CAS=1
 # L'état $1$ (ligne $2$) ne peut être supprimé que si le statut de la ligne est "$3$"
 GMESSAGE = func AFNC.MES3(mess(44,135,1),[M]CRYCOD(IND),num$(IND+1),mess(1,7945,1))
 Return
Endif
Return

Subprog IB_CRYCOD
Raz GBOUT2 , GBOUT3 , GBOUT4
If dim(GDEVCRY)>0 & GDEVCRY=2 & !GWEB & !GFUSION : # For fat client only
 GBOUT2 = mess(19,139,1) : # Copie vers le client
 GBOUT3 = mess(20,139,1) : # Copie vers le serveur
 Gosub REPORT_TRANSLATION
 GBOUT4 = WBUTTON
Endif
End

Subprog B2_CRYCOD(VALEUR)
Variable Char    VALEUR()
Local Integer OK , STAT
Local Char    MESSA(250) , REPDEV(GDIMFIC)
MESSA = mess(17,139,1) : # Copie de l'état # dans le répertoire
If VALEUR<>""
 Gosub SET_RPTSRV
 If filinfo(NAMSRV,0)<=0
  Call ERREUR('|'+NAMSRV-':|\'-mess(101,100,1)) From GESECRAN : # Fichier inexistant
  End
 Else
  Call EXIST_FILECLI(VALEUR+".rpt",REPCRY,APPSRV,LANRPT,REPDEV,STAT) From ORDSYS
  If STAT>0
   Call AVERTIR('|'+REPDEV-':|\'-mess(127,105,1),OK) From GESECRAN
   # Fichier existant, souhaitez-vous l'écraser ?
   If OK<>2 : End : Endif
  Else
   MESSA += '\|'+REPDEV
   Call OUINON(MESSA,OK) From GESECRAN
   If OK<>2 : End : Endif
  Endif
 Endif
 Call COPY_SRVTOCLI(1,VALEUR+".rpt",REPCRY,REPSRV,APPSRV,LANRPT,STAT) From ORDSYS
 If STAT
  Call ERREUR(mess(7,21,1)+"\"+mess(12,139,1)) From GESECRAN : # Erreur\Copie non réalisée
 Endif
Endif
End

Subprog B3_CRYCOD(VALEUR)
Variable Char    VALEUR()
Local Integer OK , STAT
Local Char    MESSA(250) , REPDEV(GDIMFIC)
MESSA = mess(17,139,1) : # Copie de l'état # dans le répertoire
If VALEUR<>""
 Gosub SET_RPTSRV
 Call EXIST_FILECLI(VALEUR+".rpt",REPCRY,APPSRV,LANRPT,REPDEV,STAT) From ORDSYS
 If !STAT
  Call ERREUR('|'+REPDEV-':|\'-mess(101,100,1)) From GESECRAN : # Fichier inexistant
  End
 Elsif filinfo(NAMSRV,0)>0
  Call AVERTIR('|'+NAMSRV-':|\'-mess(127,105,1),OK) From GESECRAN
  # Fichier existant, souhaitez-vous l'écraser ?
  If OK<>2 : End : Endif
 Else
  MESSA += '|'+NAMSRV
  Call OUINON(MESSA,OK) From GESECRAN
  If OK<>2 : End : Endif
 Endif
 Call EFFACE(NAMSRV,STAT) From ORDSYS
 Call COPY_CLITOSRV(1,VALEUR+".rpt",REPCRY,REPSRV,APPSRV,LANRPT,STAT) From ORDSYS
 If STAT
  Call ERREUR(mess(7,21,1)+"\"+mess(12,139,1)) From GESECRAN : # Erreur\Copie non réalisée
 Endif
 # cg nov 2012
 # lors de la copie sur seveur , on demande si trad doit etre lancée ou pas
 # lancement action sur trt arpttrb arpttrdc
 # si trt n existe pas dans environnement on ne fait rien.
 If GADONIX = 2
  If GPRODUIT = 0 or GPRODUIT = 2
   If [F:ARP]MULLAN = 2
     Local Integer WOK
     WOK = 0
     Call EXISTE_ADX (adxmac(-1),nomap,"ARPTTRDB",WOK) From ORDSYS
     # n existe pas .. on passe sans poser question
     If WOK = 1
        Local Char    WMESSA(250)
        WMESSA = mess(319,139,1)
        Call OUINON(WMESSA,OK) From GESECRAN
        If OK= 2
             Gosub LAUNCH_TRANSLATE From ARPTTRDB
        Endif
     Endif
   Endif
  Endif
 Endif
 If filinfo(NAMSRV,0)>0
      Call TRACE_COR("ETA",VALEUR,LANRPT,"C") From GOBJET
 Endif
Endif
End

Subprog B4_CRYCOD(VALEUR)
Variable Char    VALEUR()
# lancement action sur trt arpttrb arpttrdc
# si trt n existe pas dans environnement on ne fait rien.
Gosub REPORT_TRANSLATION
If WBUTTON <> ""
    Gosub LAUNCH_TRANSLATE From ARPTTRDB
Else
   Call ERREUR(mess(1,123,1)) From GESECRAN : # Fonction non autorisée
Endif
End

$SET_RPTSRV
Local Char    REPSRV(GDIMFIC) , NAMSRV(GDIMFIC) , LANRPT(GLONLAN) , SEP(1) , APPSRV(GLONADS)
Local Char    REPCRY(GDIMFIC)
Local Integer I , K , J
REPCRY = "ReportDev"
If GOS="dos"
 SEP = "\"
Else
 SEP = "/"
Endif
If [M]MULLAN=2
 LANRPT = GLANGUE
Else
 LANRPT = [F:ARP]LAN
Endif
NAMSRV = "REPORT/"+LANRPT
If filinfo(filpath(NAMSRV,VALEUR,"rpt",nomap),0)>0
 NAMSRV = filpath(NAMSRV,VALEUR,"rpt",nomap)
 REPSRV = right$(NAMSRV,len(filpath("","","",nomap))+2)
 APPSRV = ""
Else
 NAMSRV = filpath(NAMSRV,VALEUR,"rpt")
 REPSRV = NAMSRV
 K = instr(1,NAMSRV,SEP+"REPORT"+SEP)
 If K
  J = 0
  For I=K-1 To 1 Step -1
   If mid$(NAMSRV,I,1)=SEP
    J = I : Break
   Endif
  Next I
  If J
   APPSRV = seg$(NAMSRV,J+1,K-1)
   REPSRV = right$(NAMSRV,K+1)
  Endif
 Endif
Endif
MESSA = func AFNC.MES(MESSA,VALEUR)
Return

Subprog C_AUZFCY(VALEUR)
Variable Integer VALEUR
[M]AUZFCY = VALEUR
Gosub GRISE_FNC
End

Subprog IB_FNC
End

Subprog AS_FNC(VALEUR)
Variable Char    VALEUR()
If [M]AUZFCY<>2 : mkstat = 1 : End : Endif
If VALEUR=""
 VALEUR = "RPT"+format$("N0:##",[M]GRP)
Endif
End

Subprog C_GESZPL(VALEUR)
Variable Integer VALEUR
[M]GESZPL = VALEUR
Gosub GRISE_CODZPL
End

Subprog AS_FORETA(VALEUR)
Variable Integer  VALEUR
If [M]PRTDEF<>""
 Call LECTURE("AIM",[M]PRTDEF,"") From CONTOBJ
 If find([F:AIM]PRT,2,5) : # Imprimante-Imprimante/Fichier
  VALEUR = 3 : # Préférence imprimante
  mkstat = 2 : End
 Endif
Endif
GMENLOC(3) = 1
GMENLOC(4) = 1
GMENLOC(5) = 1
GMENLOC(6) = 1
GMENLOC(7) = 1
End

#-------------------------------------------------#
## ARP2
#-------------------------------------------------#

Subprog C_PARCOD(VALEUR)
Variable Char    VALEUR()
Local Integer I , NOL
NOL = nolign-1
For I=0 To [M]NBRPAR-1
 If I<>NOL & toupper(VALEUR)=toupper([M]PARCOD(I))
  GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
  mkstat = 2 : Break
 Endif
Next I
End

Subprog AS_PARLNG(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
If [F:ATY]FORTYP<>"" | [F:ATY]LNGTYP<>0 | [F:ATY]TYPTYP=1 | [F:ATY]TYPTYP=8 : mkstat=1 : End : Endif
End

Subprog D_PARLNG(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
If !fstat & ([F:ATY]FORTYP="" | [F:ATY]LNGTYP=0) : # S'il s'agit d'un type de donnée standard
 Case [F:ATY]TYPTYP
  When 1       : VALEUR=15  : # Libellé
  When 2       : VALEUR=4   : # Entier Court
  When 3       : VALEUR=8   : # Entier Long
  When 4       : VALEUR=9.2 : # Décimal
  When 7       : VALEUR=10  : # Alphanumérique
 Endcase
Endif
End

Subprog C_PARLNG(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : mkstat=1 : End : Endif
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
Local Decimal ENTIER , DECIM
ENTIER = int(VALEUR)
DECIM  = 10*(VALEUR-ENTIER)
While DECIM<>int(DECIM)
 DECIM *= 10
Wend
Case [F:ATY]TYPTYP
 When 1 : If DECIM<>0 | ENTIER>20 : mkstat=1 : Endif : # Libellé
 When 2 : If DECIM<>0 | ENTIER>4 : mkstat=1 : Endif  : # Entier court
 When 3 : If DECIM<>0 | ENTIER>8 : mkstat=1 : Endif  : # Entier long
 When 4 : If DECIM+ENTIER<1 | DECIM+ENTIER>32 : mkstat=1 : Endif : # DCB
 When 7 : If DECIM<>0 | ENTIER>250 : mkstat=1 : Endif             : # Char
 When 8 : If DECIM<>0 | !find(ENTIER,4,6,8) : mkstat=1 : Endif   : # Date
Endcase
If mkstat : GMESSAGE = mess(111,123,1) : Endif : # Longueur incorrecte
End

Subprog AS_PARNOLIB(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
If ([F:ATY]TYPTYP<>1 | [F:ATY]NOLIB<>0) & [F:ATY]OBJLIEN<>"ADI" : mkstat=1 : End : Endif
End

Subprog C_PARNOLIB(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M:ARP2]PARTYP(nolign-1),"") From CONTOBJ
If [F:ATY]TYPTYP=1
 If VALEUR<1 | (VALEUR>99 & VALEUR<201)
  GMESSAGE = mess(5,176,1) : # No menu local incorrect
  mkstat = 2 : End
 Elsif mess(0,VALEUR,1)=""
  GMESSAGE = mess(98,123,1) : # Menu local non défini
  mkstat = 2 : End
 Endif
Elsif [F:ATY]TYPTYP<>1  & [M:ARP2]PARTYP(nolign-1) = "ADI"
 Call CONTROLE("ADV","",num$(VALEUR),"",mkstat) From CONTOBJ
Endif
End

Subprog D_PARSTREND(VALEUR)
Variable Integer VALEUR
VALEUR = 2
End

Subprog AS_PARSTREND(VALEUR)
Variable Integer VALEUR
If len([M]PARCOD(nolign-1))<3
& | (toupper(right$([M]PARCOD(nolign-1),len([M]PARCOD(nolign-1))-2))<>"DEB"
& &  toupper(right$([M]PARCOD(nolign-1),len([M]PARCOD(nolign-1))-2))<>"STR")
 GMENLOC(2) = 1
Endif
If toupper(right$([M]PARCOD(nolign-1),len([M]PARCOD(nolign-1))-2))="DEB"
& or  toupper(right$([M]PARCOD(nolign-1),len([M]PARCOD(nolign-1))-2))="STR"
 GMENLOC(3) = 1
Endif
End

Subprog IB_PARDEF1
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
If [F:ATY]TYPTYP<>8
 Raz GBOUT4
Endif
End

Subprog IB_PARDEF2
Call IB_PARDEF1
End

Subprog AS_PARDEF2(VALEUR)
Variable Char    VALEUR()
If [M]PARSTREND(nolign-1)<2 : mkstat = 1 : End : Endif
End

Subprog AS_PARPAR(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
If [F:ATY]OBJLIEN=""
 mkstat = 1 : End
Endif
Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
If [F:AOB]LIBPAR=0 and [F:AOB]ABREV<>"ADI"
 mkstat = 1 : End
Endif
End

Subprog AS_PAROPT(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
If [F:ATY]OBJLIEN=""
 mkstat = 1 : End
Endif
Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
If [F:AOB]NBOPT=0
 mkstat = 1 : End
Endif
End

Subprog C_PAROPT(VALEUR)
Variable Char    VALEUR()
Local Integer I
VALEUR = toupper(VALEUR)
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
For I=1 To len(VALEUR)
 If !find(mid$(VALEUR,I,1),[F:AOB]OPTCOD(0..[F:AOB]NBOPT-1))
  GMESSAGE = mid$(VALEUR,I,1)-":"-mess(99,123,1) : # Option incorrecte
  mkstat = 2 : Break
 Endif
Next I
End

Subprog S_PAROPT(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX , I , VALINT
Local Char    TEXTE(50)(50)
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
NBTEX = [F:AOB]NBOPT
For I=1 To NBTEX
 Call TEXTE([F:AOB]OPTLIB(I-1),TEXTE(I)) From OBJDIV
 TEXTE(I) = [F:AOB]OPTCOD(I-1)-":"-TEXTE(I)
Next I
If NBTEX
 Call SAITEX(NBTEX,TEXTE,VALINT,mess(100,123,1)) From GESECRAN
# Choix options
 If VALINT<>0 & status<>7 & !instr(1,VALEUR,[F:AOB]OPTCOD(VALINT-1))
  VALEUR += [F:AOB]OPTCOD(VALINT-1)
 Endif
Endif
mkstat = 2
End

Subprog C_PARSEG(VALEUR)
Variable Char VALEUR()
Local Integer I , OK
If VALEUR<>""
 OK = 0
 For I=0 To [M]NBRPAR-1
  If toupper(VALEUR)=toupper([M]PARCOD(I))
   VALEUR = [M]PARCOD(I)
   OK = 1
   If [M]PARSTREND(I) = 1
    OK=-1
   Endif
   Break
  Endif
 Next I
 If !OK
  GMESSAGE = mess(11,133,1) : # Paramètre inexistant
  mkstat = 2 : End
 Endif
 If OK=-1
  GMESSAGE = mess(83,123,1) : : # Valeur INCORRECTE
  mkstat = 2 : End
 Endif
Endif
End

#-------------------------------------------------#
## ARP3
#-------------------------------------------------#

Subprog C_NUM(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 or VALEUR>[M]NBRSRC
 GMESSAGE = mess(33,139,1) : # Numéro incorrect
 mkstat = 2 : End
Endif
[M]LIBNUM(nolign-1) = [M]ZSRC(VALEUR-1)
End

Subprog C_TBL(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL = nolign-1
Call UNICITE(VALEUR,[M]TBL) From OBJDIV
Read [ATB]CODFIC = VALEUR
If !fstat
 Call TEXTE([F:ATB]INTITFIC,[M]LIBTBL(NOL)) From OBJDIV
Else
 [M]LIBTBL(NOL) = ""
Endif
End

