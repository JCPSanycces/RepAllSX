#<AdxTL>@(#)9.0.0.0 $Revision$
#GBIDC1="" : GBIDC2="" : GFLAG="ANA"
#Call OBJET("GAS",GBIDC1,GBIDC2) From GOBJET
#End
# Issue X3-107197 - 2018-09-14 by CBO : PARAMETER AND ACTIVITY CODE

Local Char PARAM(30)(1..5) , VALEUR(10)

PARAM(1) = "ASN"
PARAM(2) = ""
PARAM(3) = "FRA"
PARAM(4) = "5"
PARAM(5) = date$
#Call S_TAB_CHAR(VALEUR,PARAM,"SELGTE","SELGTE","") From GACTION
Call S_LIS_CHAR(VALEUR,PARAM,"SELGTE","SELGTE","") From GACTION

End

#######################################################################
# Action SELGTE & SELGTELIS
#######################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"
  Case TABLE
    When "SELGTE"    : Gosub SELGTE
  Endcase
 When "SEL_LISTE"
  Case LISTE
    When "SELGTE"    : Gosub SELGTE2
  Endcase
Endcase
Return

#######################################################################
$SELGTE
If clalev([F:GTE]) =0 : Local File GTYPACCENT  [GTE] : Endif
If clalev([F:GTES])=0 : Local File LEGGTESEL  [GTES] : Endif
If clalev([F:GTEG])=0 : Local File LEGGTEGFY  [GTEG] : Endif
If clalev([F:GTEP])=0 : Local File LEGGTEPAR  [GTEP] : Endif
If clalev([F:GTEY])=0 : Local File LEGGTEYGRP [GTEY] : Endif
If clalev([F:GTEZ])=0 : Local File LEGGTEZGRP [GTEZ] : Endif

If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif

Local Char    FCY(GLONFCY)
Local Char    CPY(GLONCPY)
Local Char    LEG(GLONADI)
Local Integer LEDTYP
Local Char    GRP(GLONAGC)

Local Char SAVE_FCY(GLONFCY) : SAVE_FCY=GCURFCY
Local Char SAVE_CPY(GLONCPY) : SAVE_CPY=GSOCIETE
Local Char SAVE_LEG(GLONADI) : SAVE_LEG=GCURLEG
Local Char SAVE_GRP(GLONAGC) : SAVE_GRP=GGRPFCY

#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------
If GFONCTION="ADPVAL" : # Saisie valeurs paramètres. Type de données = PGT
 FCY = [M:ADWP]FCY
 CPY = [M:ADWP]CMP
 If dim([M:ADWP]LEG)>0
  LEG = [M:ADWP]LEG
 Else
  LEG = GDOSLEG
 Endif
Elsif dim([M:RPT]ETAT)>0  #GACTION="AFMTSEL" : # = Sélection paramètres d'édition
 CPY = ""
 I = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
 If I
  CPY = [M:RPT]VALINT1(I-1)
  Call LEC_CPY(CPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Endif
Elsif GFONCTION<>"GEXPOBJ"
 LEG    = PARAM(1)
 LEDTYP = val(PARAM(2))
 GRP    = PARAM(3)
 If GCURFCY  <>""  & [L]FCY="" : [L]FCY = GCURFCY  : Endif
 If GSOCIETE <>""  & [L]CPY="" : [L]CPY = GSOCIETE : Endif
 If GCURLEG  <>""  & [L]LEG="" : [L]LEG = GCURLEG  : Endif
 If GGRPFCY  <>""  & [L]GRP="" : [L]GRP = GGRPFCY  : Endif
Endif

# Initialisations diverses FCY/CPY/LEG & GCURFCY/GSOCIETE/GCURLEG
If [L]FCY<>""
 Call LEC_FCY([L]FCY) From CPTLEC
 Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
 [L]CPY = [F:CPY]CPY : GSOCIETE = [L]CPY
 [L]LEG = [F:CPY]LEG : GCURLEG  = [L]LEG
 [L]GRP = ""
Elsif [L]CPY<>""
 Call LEC_CPY([L]CPY) From CPTLEC
 [L]CPY = [F:CPY]CPY : GSOCIETE = [L]CPY
 [L]LEG = [F:CPY]LEG : GCURLEG  = [L]LEG
 [L]GRP = ""
Endif
# Si groupe de société (non société juridique) alors GCURLEG et LEG à vide pour que la sélection présente toutes les données.
If [L]CPY<>""
 Call LEC_CPY([L]CPY) From CPTLEC
 If [F:CPY]CPYLEGFLG<>2
  [L]LEG="" : GCURLEG="" : [L]GRP = [L]CPY : [L]CPY="" : [L]FCY=""
 Endif
Endif

#--------------------------------------------------------------------------------------------------
## Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------

Gosub OUVRE_LISTE From WOGTE

For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I) = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I

NBCOL  = NBSEL
SIZCOL = 240
SIZLIG = 100
TIT(0) = mess(12,123,1)  # Choix
Call TITOBJ("GTE","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START  = "[F:GTE]TYP"
ORDRE  = "[F:GTE]TYP;[F:GTE]LEG"
OBJET  = ""


#--------------------------------------------------------------------------------------------------
## Critères pour la sélection standard
#--------------------------------------------------------------------------------------------------

## Critères de sélection
## Le link fait des liaisons "externes gauches"
## Toute la subtilité de la chose est de mettre des fonctions qui
## ne sont pas transmises à la base de données : len() , num$()
## sinon celle-ci ne renvoie rien du tout...sniff

CRITERE(1)   = "[F:GTE]ENAFLG=2"

If [L]LEG<>""
  CRITERE(1) -= '& ([F:GTE]LEG="'+[L]LEG+'" | [F:GTE]LEG="")'
Endif
If [L]FCY<>""
 CRITERE(1) -= '& ([F:GTE]GFY="" | ([F:GTE]GFY<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
Elsif [L]CPY<>""
 CRITERE(1) -= '& ([F:GTE]GFY="" | ([F:GTE]GFY<>"" & [F:GTEG]LEGCPY="'+[L]CPY+'"))'
Elsif [L]GRP<>""
 If [L]LEG<>""
  CRITERE(1) -= '& ([F:GTE]GFY="" | ([F:GTE]GFY<>"" & [F:GTEY]GRPORI="'+[L]GRP+'"))'
 Else
  CRITERE(1) -= '& ([F:GTE]GFY="" | ([F:GTE]GFY<>"" & [F:GTEZ]GRPORI="'+[L]GRP+'"))'
 Endif
Endif
If [L]LEDTYP<>0
 CRITERE(1) -= '& [F:GTE]AUZLED('+num$([L]LEDTYP-1)+')<>1'
Endif

CRITERE(2) -= '& (GUSRACS=2 | [F:GTE]ACS="" | num$([F:ACC]CONSUL)="2")'

If dim(SELCAR)>0 & SELCAR<>0
 CRITERE(2) -= '& left$([F:GTE]TYP,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 3
Call FILROLE(OBJET,FILROLE) From SUBARL
If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif


#--------------------------------------------------------------------------------------------------
# Critères pour la sélection spécifique
#--------------------------------------------------------------------------------------------------

Case GFONCTION
 When "CPTDSPANA"
    If [L]LEDTYP<>0
      # condition mono-référentiel
      CRITERE(3) -= '& sum([F:GTE]AUZLED(0..'+num$([L]LEDTYP-2)+'))<='+num$([M]LEDTYP-1)+
&                   '& sum([F:GTE]AUZLED('+num$([L]LEDTYP)+'..'+num$(dim([F:GTE]AUZLED)-1)+'))<='+num$(dim([F:GTE]AUZLED)-[L]LEDTYP)
   Endif
 When "GESGAF"
    CRITERE(3) -= "& [F:GTE]VCRMOD=2"
 When "GESTFC"
    CRITERE(3) -= "& [F:GTE]DUDCASFLG=2"
Endcase

#--------------------------------------------------------------------------------------------------
# Appel à la vue
#--------------------------------------------------------------------------------------------------

If [L]LEG<>""
 # Vues via LEG/FCY
 If [L]FCY<>""
  Link [GTE] With [AXX]AXX0     = "GTYPACCENT";"DESTRA";GLANGUE;[F:GTE]TYP;[F:GTE]LEG
&               , [ACC]CODACC   =  GUSER;[F:GTE]ACS
&               , [FGR]FGR1     =  [L]FCY;[F:GTE]GFY
&               , [GTES]GTE0   ~=  [F:GTE]TYP;[F:GTE]LEG;[L]LEG
&               , [GTEG]GTE0    =  [F:GTE]TYP;[F:GTE]LEG;[F:GTE]GFY;[L]CPY
& As [LNC]
 Elsif [L]CPY<>""
  # Vues via LEG/CPY
  Link [GTE] With [AXX]AXX0     = "GTYPACCENT";"DESTRA";GLANGUE;[F:GTE]TYP;[F:GTE]LEG
&               , [ACC]CODACC   =  GUSER;[F:GTE]ACS
&               , [GTES]GTE0   ~=  [F:GTE]TYP;[F:GTE]LEG;[L]LEG
&               , [GTEG]GTE0    =  [F:GTE]TYP;[F:GTE]LEG;[F:GTE]GFY;[L]CPY
& As [LNC]
 Elsif [L]GRP<>""
  # Vues via LEG/GRP
  Link [GTE] With [AXX]AXX0     = "GTYPACCENT";"DESTRA";GLANGUE;[F:GTE]TYP;[F:GTE]LEG
&               , [ACC]CODACC   =  GUSER;[F:GTE]ACS
&               , [GTES]GTE0   ~=  [F:GTE]TYP;[F:GTE]LEG;[L]LEG
&               , [GTEY]GTEY0  ~=  [L]GRP;[F:GTE]TYP;[F:GTE]GFY;[F:GTE]LEG
& As [LNC]
 Else
  # Vues via LEG/No FCY, No CPY, No GRP
  Link [GTE] With [AXX]AXX0     = "GTYPACCENT";"DESTRA";GLANGUE;[F:GTE]TYP;[F:GTE]LEG
&              , [ACC]CODACC   =  GUSER;[F:GTE]ACS
&              , [GTES]GTE0   ~=  [F:GTE]TYP;[F:GTE]LEG;[L]LEG
& As [LNC]
 Endif
Else
 If [L]FCY<>""
  # Vues via No LEG but FCY
  Link [GTE] With [AXX]AXX0     = "GTYPACCENT";"DESTRA";GLANGUE;[F:GTE]TYP;[F:GTE]LEG
&               , [ACC]CODACC   =  GUSER;[F:GTE]ACS
&               , [FGR]FGR1     =  [L]FCY;[F:GTE]GFY
&               , [GTEP]GTE0   ~=  [F:GTE]TYP;[F:GTE]LEG
&               , [GTEG]GTE0    =  [F:GTE]TYP;[F:GTE]LEG;[F:GTE]GFY;[L]CPY
& As [LNC]
 Elsif [L]CPY<>""
  # Vues via No LEG but CPY
  Link [GTE] With [AXX]AXX0     = "GTYPACCENT";"DESTRA";GLANGUE;[F:GTE]TYP;[F:GTE]LEG
&               , [ACC]CODACC   =  GUSER;[F:GTE]ACS
&               , [GTEP]GTE0   ~=  [F:GTE]TYP;[F:GTE]LEG
&               , [GTEG]GTE0    =  [F:GTE]TYP;[F:GTE]LEG;[F:GTE]GFY;[L]CPY
& As [LNC]
 Elsif [L]GRP<>""
  # Vues via No LEG but GRP
  Link [GTE] With [AXX]AXX0     = "GTYPACCENT";"DESTRA";GLANGUE;[F:GTE]TYP;[F:GTE]LEG
&               , [ACC]CODACC   =  GUSER;[F:GTE]ACS
&               , [GTEP]GTE0   ~=  [F:GTE]TYP;[F:GTE]LEG
&               , [GTEZ]GTEZ0  ~=  [L]GRP;[F:GTE]TYP;[F:GTE]GFY;[F:GTE]LEG
& As [LNC]
 Else
  # Vues via No LEG and No FCY/CPY/GRP
  Link [GTE] With [AXX]AXX0     = "GTYPACCENT";"DESTRA";GLANGUE;[F:GTE]TYP;[F:GTE]LEG
&              , [ACC]CODACC    =  GUSER;[F:GTE]ACS
&              , [GTEP]GTE0    ~=  [F:GTE]TYP;[F:GTE]LEG
&   As [LNC]
 Endif
Endif

Default File [LNC]
DEFPAG = 1

GCURFCY  = SAVE_FCY
GSOCIETE = SAVE_CPY
GCURLEG  = SAVE_LEG
GGRPFCY  = SAVE_GRP
Return


#######################################################################
$SELGTE2
If clalev([F:GTE]) =0 : Local File GTYPACCENT [GTE] : Endif
If clalev([F:GTES])=0 : Local File LEGGTESEL [GTES] : Endif
If clalev([F:GTEG])=0 : Local File LEGGTEGFY [GTEG] : Endif
If clalev([F:GTEP])=0 : Local File LEGGTEPAR [GTEP] : Endif

If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif

Local Char TEX(GLONDES)(0..nbrecord([GTE])+3)
Local Char TEXTE(GLONDES)(0..nbrecord([GTE])+3)
Local Char CRITERE(250)(1..2)

Local Char    FCY(GLONFCY)
Local Char    CPY(GLONCPY)
Local Char    LEG(GLONADI)
Local Integer LEDTYP


Local Char ADP_BPCTYP
Local Char ADP_BPSTYP
Local Char ADP_PROTYP

Local Char SAVE_FCY(GLONFCY) : SAVE_FCY=GCURFCY
Local Char SAVE_CPY(GLONCPY) : SAVE_CPY=GSOCIETE
Local Char SAVE_LEG(GLONADI) : SAVE_LEG=GCURLEG
#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------
LEG    = PARAM(1)
LEDTYP = val(PARAM(2))
If GCURFCY  <>""  & [L]FCY="" : [L]FCY = GCURFCY  : Endif
If GSOCIETE <>""  & [L]CPY="" : [L]CPY = GSOCIETE : Endif
If GCURLEG  <>""  & [L]LEG="" : [L]LEG = GCURLEG  : Endif

# Initialisations diverses FCY/CPY/LEG & GCURFCY/GSOCIETE/GCURLEG
If [L]FCY<>""
 Call LEC_FCY([L]FCY) From CPTLEC
 Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
 [L]CPY = [F:CPY]CPY : GSOCIETE = [L]CPY
 [L]LEG = [F:CPY]LEG : GCURLEG  = [L]LEG
Elsif [L]CPY<>""
 Call LEC_CPY([L]CPY) From CPTLEC
 [L]CPY = [F:CPY]CPY : GSOCIETE = [L]CPY
 [L]LEG = [F:CPY]LEG : GCURLEG  = [L]LEG
Endif
# Si groupe de société (non société juridique) alors GCURLEG et LEG à vide pour que la sélection présente toutes les données.
If [L]CPY<>""
 Call LEC_CPY([L]CPY) From CPTLEC
 If [F:CPY]CPYLEGFLG<>2
  [L]LEG="" : GCURLEG="" :  [L]CPY=""
 Endif
Endif

If [L]CPY<>""
 Call PARAM([L]CPY,"BPCORDTYP",[L]ADP_BPCTYP) From ADOVAL : # CCL
 Call PARAM([L]CPY,"BPSORDTYP",[L]ADP_BPSTYP) From ADOVAL : # CCF
 If func AFNC.ACTIV("KIT")   # Issue X3-107197
   Call PARAM([L]CPY,"BPSPROTYP",[L]ADP_PROTYP) From ADOVAL : # PRO
 Endif   # Issue X3-107197
Else
 Call PARAM([L]LEG,"BPCORDTYP",[L]ADP_BPCTYP) From CPTLEC
 Call PARAM([L]LEG,"BPSORDTYP",[L]ADP_BPSTYP) From CPTLEC
 If func AFNC.ACTIV("KIT")   # Issue X3-107197
  Call PARAM([L]LEG,"BPSPROTYP",[L]ADP_PROTYP) From CPTLEC
 Endif   # Issue X3-107197
Endif

#--------------------------------------------------------------------------------------------------
## Critères
#--------------------------------------------------------------------------------------------------

If (dim([M]ACCBPR)>0 & [M]ACCBPR<>"") | (dim([F:CDA]ACCBPR)>1 & [F:CDA]ACCBPR<>"")
 # Uniquement Acompte
 CRITERE(1)   = "1<>1"
Else
 CRITERE(1)   = "[F:GTE]ENAFLG=2"
 If [L]LEG<>""
  CRITERE(1)  +=  ' & ([F:GTE]LEG="'+[L]LEG+'" | [F:GTE]LEG="")'
 Else
  If GFONCTION<>"MODECHE2"
   CRITERE(1)  +=  ' & [F:GTE]LEG=""'
  Endif
 Endif
 If [L]CPY<>""
  CRITERE(1) -= '& ([F:GTE]GFY="" | ([F:GTE]GFY<>"" & [F:GTEG]LEGCPY="'+[L]CPY+'"))'
 Endif
 If [L]LEDTYP<>0
  CRITERE(1) -= '& [F:GTE]AUZLED('+num$([L]LEDTYP-1)+')<>1'
 Endif
 If GFONCTION="MODECHE2"
  CRITERE(1) +=" & [F:GTE]DUDDATFLG=2"
 Endif
Endif

If [L]LEG<>""
 If [L]CPY<>""
  Link [GTE] With [AXX]AXX0    = "GTYPACCENT";"DESTRA";GLANGUE;[F:GTE]TYP;[F:GTE]LEG
&               , [ACC]CODACC  =  GUSER;[F:GTE]ACS
&               , [GTES]GTE0  ~=  [F:GTE]TYP;[F:GTE]LEG;[L]LEG
&               , [GTEG]GTE0   =  [F:GTE]TYP;[F:GTE]LEG;[F:GTE]GFY;[L]CPY
& As [LNC]
& Where evalue(CRITERE)
& Order By Key CLE = [F:GTE]TYP;[F:GTE]LEG Desc

 Else
  Link [GTE] With [AXX]AXX0    = "GTYPACCENT";"DESTRA";GLANGUE;[F:GTE]TYP;[F:GTE]LEG
&               , [ACC]CODACC  =  GUSER;[F:GTE]ACS
&               , [GTES]GTE0  ~=  [F:GTE]TYP;[F:GTE]LEG;[L]LEG
& As [LNC]
& Where evalue(CRITERE)
& Order By Key CLE = [F:GTE]TYP;[F:GTE]LEG Desc

 Endif
Else
 If [L]CPY<>""
  Link [GTE] With [AXX]AXX0    = "GTYPACCENT";"DESTRA";GLANGUE;[F:GTE]TYP;[F:GTE]LEG
&               , [ACC]CODACC  =  GUSER;[F:GTE]ACS
&               , [GTEP]GTE0  ~=  [F:GTE]TYP;[F:GTE]LEG
&               , [GTEG]GTE0   =  [F:GTE]TYP;[F:GTE]LEG;[F:GTE]GFY;[L]CPY
& As [LNC]
& Where evalue(CRITERE)
& Order By Key CLE = [F:GTE]TYP;[F:GTE]LEG Desc

 Else
  Link [GTE] With [AXX]AXX0   = "GTYPACCENT";"DESTRA";GLANGUE;[F:GTE]TYP;[F:GTE]LEG
&               , [ACC]CODACC =  GUSER;[F:GTE]ACS
&               , [GTEP]GTE0 ~=  [F:GTE]TYP;[F:GTE]LEG
& As [LNC]
& Where evalue(CRITERE)
& Order By Key CLE = [F:GTE]TYP;[F:GTE]LEG Desc
 Endif
Endif

NBTEX = 0
For [LNC]CLE(1)
 NBTEX += 1
 TEX(NBTEX)     = [F:GTE]TYP
 TEXTE(NBTEX) = format$("K:"+num$(GLONGTE+3)+"X",[F:GTE]TYP)+[F:AXX]TEXTE
Next

If [L]ADP_BPCTYP<>"" & !find([L]ADP_BPCTYP,TEX(1..NBTEX))
 NBTEX += 1
 TEX(NBTEX)     = [L]ADP_BPCTYP
 TEXTE(NBTEX) = format$("K:"+num$(GLONGTE+3)+"X",[L]ADP_BPCTYP)+" "+mess(1,659,1) : # Commande client
Endif

If [L]ADP_BPSTYP<>"" & !find([L]ADP_BPSTYP,TEX(1..NBTEX))
 NBTEX += 1
 TEX(NBTEX)     = [L]ADP_BPSTYP
 TEXTE(NBTEX) = format$("K:"+num$(GLONGTE+3)+"X",[L]ADP_BPSTYP)+" "+mess(2,659,1) : # Commande Fourn.
Endif

If [L]ADP_PROTYP<>"" & !find([L]ADP_PROTYP,TEX(1..NBTEX))
 NBTEX += 1
 TEX(NBTEX)     = [L]ADP_PROTYP
 TEXTE(NBTEX) = format$("K:"+num$(GLONGTE+3)+"X",[L]ADP_PROTYP)+" "+mess(4,659,1) : # Proforma fourn.
Endif

Sorta NBTEX+1 TEXTE, TEX Order By TEX(indice)

TIT(0) = mess(12,123,1)  # Choix
Call TITOBJ("GTE","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
TIT(1) -= mess(82,123,1)  # Intitulé

GCURFCY  = SAVE_FCY
GSOCIETE = SAVE_CPY
GCURLEG  = SAVE_LEG

Return

