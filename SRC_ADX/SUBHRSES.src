#<AdxTL>@(#)0.0.0.0 $Revision$
Call OUVRE
End
######################################################################################
# Modifications :
#     SYMEU - 27/07/10 - EXI 66191 LOT 2
#              - Le formateur interne est dans la table TRAINER et plus dans les salariés
#     MABON - 19/08/10 - EXI 66191 LOT 4
#              - Le stage peut être de type Court ou Autre
#     SYMEU - 04/10/10 - EXI 66191 LOT 10 - V6.1 : stage non défini
#     SEGAY - 18/01/11 - EXI 66191 LOT 1
#              - Remplacement table ADI 463 par ORGANISME TYP=6 (financeur)
#     SEGAY - 22/02/11 bug 71267+71683 Période de professionalisation
#     SEGAY - 23/02/11 bug 71823 MAJ des lignes de Parcours
#     MABOS - 19/03/13- FQ87514 - before Cloture, add control for VALCPC & VALHAB
######################################################################################

$ACTION
#LIPET - 2017-06-22 - X3-34431 - START
# Put in $ouvre, $liens and (setbout,razcre )?
If dim([M:HRSES3]WTRTCOU)<>-1 and [M:HRSES3]WTRTCOU="" :[M:HRSES3]WTRTCOU=trtcou : Endif
#LIPET - 2017-06-22 - X3-34431 - END
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "FERME"      : Gosub FERME
 When "ABANDON"    : Gosub ABANDON
 When "LIENS"      : Gosub LIENS
 When "RAZCRE"     : Gosub RAZCRE
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "VERIF_CRE"  : Gosub VERIF
 When "VERIF_MOD"  : Gosub VERIF
 When "MODIF"      : Gosub MODIF
 When "APRES_CRE"  : Gosub APRES_CRE
 When "APRES_MOD"  : Gosub APRES_MOD
 When "RAZDUP"     : Gosub RAZDUP
 When "FILTRE"     : Gosub FILTRE
 When "FILGAUCHE"  : Gosub FILGAUCHE
 When "SETBOUT"    : Gosub SETBOUT
 When "AVANTBOUT"  : Gosub AVANTBOUT : #MABOS-19/03/13-FQ87514-before Cloture, add control for VALCPC & VALHAB
 When "EXEBOUT"    : Gosub EXEBOUT
 When "APRES_CHOI" : Gosub APRES_CHOI
 When "FIN_ACTION" : Gosub FIN_ACTION
 When "BB1_NBLIG4" : Gosub BB1_NBLIG4
 #SEGAY US1840 81085 20/08/2013 action envoyée de SELEMPCTR
 When "BAS_CTRNUMD"  : Gosub BAS_CTRNUM From TOOLSHRLEG
 When "SEL_TABLE"
  Case TABLE
   When "SELSES"   : Gosub SELSES
   When "SELSESINC": Gosub SELSESINC
   When "SELSESSTG": Gosub SELSESSTG
  Endcase
  When "STYLE"       : Gosub STYLE #LIPET - 2017-06-22 - X3-34431
Endcase

Return

#####################################
$OUVRE
If clalev([F:STG])=0    : Local File STAGE      [STG]   : Endif

If clalev([F:HRCAN])=0  : Local File  HRCATACTION  [HRCAN]   : Endif
If clalev([F:HRSUS])=0    : Local File HRSYSUSED      [HRSUS]   : Endif
If clalev([F:HRFCN])=0    : Local File HRFISCALNAT      [HRFCN]   : Endif

If clalev([F:HRSES])=0  : Local File SESSIONS   [HRSES] : Endif
If clalev([F:DEM])=0    : Local File DEMANDE    [DEM]   : Endif
If clalev([F:SEJ])=0    : Local File SESJOU     [SEJ]   : Endif
If clalev([F:INS])=0    : Local File INSCRIPT   [INS]   : Endif
If clalev([F:ADI])=0    : Local File ATABDIV    [ADI]   : Endif
If clalev([F:COU])=0    : Local File COUT       [COU]   : Endif
If clalev([F:HRCOR])=0  : Local File COUTREEL   [HRCOR] : Endif
If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
# SYMEU V6.1 Module Formation - Formateur interne
If clalev([F:TRN])=0    : Local File TRAINER    [TRN]   : Endif
# MABON - 19/08/10 - Ouverture table temporaire pour calcul nombre d'inscrits dans liste gauche
If clalev([F:TSE])=0    : Local File TMPSES     [TSE]   : Endif
If clalev([F:COF])=0    : Local File COUTFIN    [COF]   : Endif
# MABON - 27/09/10 - Ouverture table des parcours pour mise à jour si changement de dates session
If clalev([F:CIL])=0    : Local File COURISLIG  [CIL]   : Endif
#LIPET - 2017-06-22 - X3-34431 - START
If clalev([F:HRTCR])=0 : Local File HRTRACSTREP     [HRTCR] : Endif
#LIPET - 2017-06-22 - X3-34431 - END
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Gosub CHARGE_RSC

Gosub DECLARE From SUBSTG
Local  Integer NOL, I, J
Global Char    GINTITDAT(10)

# MABON 26/08/10 - Remplissage de la table TMPSES pour la liste gauche
Gosub CHARGE_TSE
Return

#**#####################################################################################
#* MABON - 26/08/10 - Remplissage de la table TMPSES pour la liste gauche
#*!
$CHARGE_TSE
Local Integer OK_TSE : OK_TSE=0
Local Integer NBRINS

  If clalev([F:SEST])=0 : Local File SESSIONS [SEST] : Endif
  If clalev([F:INS])=0  : Local File INSCRIPT [INS]  : Endif
  Trbegin [F:TSE]
  For [F:SEST]
    Read [F:TSE]TSE0=[F:SEST]COD
    Filter [F:INS] Where SES=[F:SEST]COD
    NBRINS=rowcount([F:INS])
    Filter [F:INS]
    If fstat Then
      [F:TSE]COD=[F:SEST]COD
      [F:TSE]STG=[F:SEST]STG
      [F:TSE]NBRINS=NBRINS
      Write [F:TSE]
      If fstat Then OK_TSE=1 : Break : Endif
    Else
      [F:TSE]NBRINS=NBRINS
      Rewrite [F:TSE]
      If fstat Then OK_TSE=1 : Break : Endif
    Endif
  Next
  If OK_TSE Then
    Rollback
  Else
    Commit
  Endif
Return

#####################################
$FERME

  If dim(GINTITDAT)>0  Then Kill GINTITDAT  Endif
  If dim(GMODINS)>0    Then Kill GMODINS    Endif
  If dim(GMODFRTINT)>0 Then Kill GMODFRTINT Endif

  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
#LIPET - 2017-06-22 - X3-34431 - START
$STYLE
Default Mask [M:HRSES3]
Diszo [M:HRSES3]TCRCOD
Gosub STYLE From TRTCOUT
Default Mask [M:HRSES1]
Return
#LIPET - 2017-06-22 - X3-34431 - END
#####################################
$ABANDON
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#####################################
$LIENS
 If GNBLEG=1 : GCURLEG = GDOSLEG : Endif
 GCURLEG=[F:HRSES]LEG
  # MABON 03/09/10 - On ne passe plus en mode consultation si la session est clôturée, car on veut pouvoir modifier
  # le tableau des montants remboursés (écran SES6). On fait des donc des grizo, mais on initialise d'abord avec des Actzo.
  Actzo [M:HRSES0] : Actzo [M:HRSES1] : Actzo [M:HRSES2]
  Actzo [M:HRSES3] : Actzo [M:HRSES4] : Actzo [M:HRSES5]
  Actzo [M:HRSES6]

  Default Mask [M:HRSES1]
  Call AM_ORG([F:HRSES]ORG)From SUBSTG
  If [M:HRSES1]FRTINT=2 : # Stage interne
   Grizo [M:HRSES6]TYPCNT,DATCNT
  Else                : # Stage externe
   Actzo [M:HRSES6]TYPCNT,DATCNT
  Endif
  Gosub CHARGE_COUT
  Gosub CHARGE_JOUR
  Gosub CHARGE_INSCRIP
  [M:HRSES1]FLGDAT=0
  If [M:HRSES1]TCHEMP<>""
   Read [ID]ID0=[M:HRSES1]TCHEMP
   If !fstat
    Call GRISE_CTRNUM([F:ID]FLGMULCTR)
    # SYMEU V6.1 Module Formation - Formateur interne : récupération du nom et prénom
    Gosub CHARGE_TRN
   Endif
  Else
   Call GRISE_CTRNUM(1)
  Endif

  # MABON - 19/08/10 - Récupération des ressources
  Gosub CHARGE_RSC
  If [M:HRSES0]STG<>"" Then
    # MABON - 19/08/10 - La 1ère colonne a un intitulé évalué selon qu'on a un stage court ou un autre stage
    # Et selon le type du stage, des colonnes apparaissent ou disparaissent dans l'onglet Calendrier
    Call LECTURE("STG",[F:HRSES]STG,"") From CONTOBJ
    [M:HRSES3]TYPSTG    = [F:STG]TYPSTG
    [M:HRSES3]NBRDAYSTG = [F:STG]NBRDAY
    [M:HRSES3]NBRHOUSTG = [F:STG]NBRHOUIPT
    # FQ72868 - MABON 15/04/11 - Récupération Hors plan
    # FQ93180 - SEGAY 24/10/13 - Initialisation FLGPLF <> 0
    If [F:STG]FLGPLF <> 0
       [M:HRSES1]FLGPLF    = [F:STG]FLGPLF
    Else
       [M:HRSES1]FLGPLF    = 1
    Endif
    #LIPET - 2017-06-22 - X3-34431 - START
    [M:HRSES3]TCRCOD = [F:STG]TCRCOD
    #LIPET - 2017-06-22 - X3-34431 - END
  Else
    [M:HRSES3]TYPSTG    = [F:HRSES]TYPSTG
    [M:HRSES3]NBRDAYSTG = [F:HRSES]NBRDAYSTG
    [M:HRSES3]NBRHOUSTG = [F:HRSES]NBRHOUSTG
  Endif
  Call INIT_COL([M:HRSES3]TYPSTG)
  # MABON - 19/08/10 - Récupération Nom/prénom du chargé administratif
  If [M:HRSES1]REFNUMRH<>"" Then
    Call CHARGE_NUMRH([M:HRSES1]REFNUMRH)
  Endif
  # MABON - 30/08/10 - Récupération actions suivi
  Gosub CHARGE_ACN
  # MABON - 30/08/10 - Récupération montants
  Gosub CHARGE_AMT

  # MABON 03/09/10 - On ne passe plus en mode consultation si la session est clôturée, car on veut pouvoir modifier
  # le tableau des montants remboursés (écran SES6). On fait des donc des grizo ici, à la place.
  If [F:HRSES]FLGCLO=2 Then
    Diszo [M:HRSES0] : Diszo [M:HRSES1] : Diszo [M:HRSES2]
    Diszo [M:HRSES3] : Diszo [M:HRSES4] : Diszo [M:HRSES5]
    Diszo [M:HRSES6]TYPCNT, DATCNT, NBACN
  Endif

  If dim([M:HRSES0]LEG)>0
  If [M:HRSES0]STG<>""
  Diszo[M:HRSES0]LEG
  Else
  Actzo[M:HRSES0]LEG
  Endif
  Endif

#ADNGO - 2017-12-08 - X3-63702 - START
  If [M:HRSES1]CATACN <> "" Then
    Filter [F:HRCAN] Where CANCOD = [M:HRSES1]CATACN
    Read [F:HRCAN] First
    Filter [F:HRCAN]
    If !fstat Then
      If [F:HRCAN]LEG <> ""
        Call LECTEXTRA([M:HRSES1]DESACN,"HRCATACTION ","DES",[F:HRCAN]LEG,[M:HRSES1]CATACN) From ATEXTRA
      Else
        Call LECTEXTRA([M:HRSES1]DESACN,"HRCATACTION","DES","",[M:HRSES1]CATACN) From ATEXTRA
      Endif
    Endif
  Endif


  If [M:HRSES1]NATFIS <> "" Then
    Filter [F:HRFCN] Where FCNCOD = [M:HRSES1]NATFIS
    Read [F:HRFCN] First
    Filter [F:HRFCN]
    If !fstat Then
      If [F:HRFCN]LEG <> ""
        Call LECTEXTRA([M:HRSES1]DESFIS,"HRFISCALNAT","DES",[F:HRFCN]LEG,[M:HRSES1]NATFIS) From ATEXTRA
      Else
        Call LECTEXTRA([M:HRSES1]DESFIS,"HRFISCALNAT","DES","",[M:HRSES1]NATFIS) From ATEXTRA
      Endif
    Endif
  Endif

#ADNGO - 2017-12-08 - X3-63702 - END

#LIPET - 2017-12-08 - X3-63702 - START
  If [M:HRSES1]TYPFRT <> "" Then
    Filter [F:HRSUS] Where SUSCOD = [M:HRSES1]TYPFRT
    Read [F:HRSUS] First
    Filter [F:HRSUS]
    If !fstat Then
      Call LECTEXTRA([M:HRSES1]DESFRT,"HRSYSUSED","DES",[F:HRSUS]LEG,[M:HRSES1]TYPFRT) From ATEXTRA
    Endif
  Endif
#LIPET - 2017-12-08 - X3-63702 - END

#PCA 24/05/12 SHOW FIELDS BASED ON LEG
Call DISPLAY_HIDE() From SUBHRSESLEG

Return

#**#####################################################################################
#* MABON - 26/08/10 - La 1ère colonne a un intitulé évalué selon qu'on a un stage court
#* ou un autre stage. Et selon le type du stage, des colonnes apparaissent ou disparaissent
#* dans l'onglet Calendrier
#*!
Subprog INIT_COL(TYPSTG)
Value Integer TYPSTG

  If TYPSTG=2 Then
    GINTITDAT=mess(4,10708,1)  : # Date début

    Chgfmt [M:HRSES2]DATF         With "KP:10X"
    Chgfmt [M:HRSES2]DAY1         With "-K:10X"
    Chgfmt [M:HRSES2]DEBTIM       With "-K:##[:]##"
    Chgfmt [M:HRSES2]FINTIM       With "-K:##[:]##"
    Chgfmt [M:HRSES2]NBRTIMBRK    With "-N:9.2"
    Chgfmt [M:HRSES2]NBRJOU       With "-N:9.2"
    Chgfmt [M:HRSES2]NBRHOUHTT    With "N:9.2"

    Chgfmt [M:HRSES2]NBRHOUIPTHTT With "NP:9.2"
    Chgfmt [M:HRSES2]NBRDAY       With "-NP:4.2"
    #LIPET - 2017-06-22 - X3-34431 - START
    Chgfmt [M:HRSES2]NBRNGT       With "-NP:4.2"
    #LIPET - 2017-06-22 - X3-34431 - END
  Else
    GINTITDAT=mess(88,100,1) : # Date

    Chgfmt [M:HRSES2]DATF         With "-K:10X"
    Chgfmt [M:HRSES2]DAY1         With "K:10X"
    Chgfmt [M:HRSES2]DEBTIM       With "K:##[:]##"
    Chgfmt [M:HRSES2]FINTIM       With "K:##[:]##"
    Chgfmt [M:HRSES2]NBRTIMBRK    With "N:9.2"
    Chgfmt [M:HRSES2]NBRJOU       With "N:9.2"
    Chgfmt [M:HRSES2]NBRHOUHTT    With "-N:9.2"

    Chgfmt [M:HRSES2]NBRHOUIPTHTT With "-NP:9.2"
    Chgfmt [M:HRSES2]NBRDAY       With "NP:4.2"
    #LIPET - 2017-06-22 - X3-34431 - START
    Chgfmt [M:HRSES2]NBRNGT       With "NP:4.2"
    #LIPET - 2017-06-22 - X3-34431 - END
  Endif
End

#####################################
$FILTRE
If find("STG",GPILCOD(1..GPILOBJ))
#If dim(SAVFONC)>=0 & SAVFONC="GESSTG" & TUNNEL
 If FILTSUP<>"" : FILTSUP += " & " : Endif
 FILTSUP -= "STG='"+[F]STG+"'"
 Endif


#PCA- 01/06/2012 - Filter left list based on legislation #todo
#If FILTSUP<>"" : FILTSUP += " & " : Endif
#FILTSUP += "((find([F:FCY]LEG,'"+GLEGFIL+"','')>0) | [F:FCY]LEG='' | GLEGFIL='')"
Return

#####################################
$FILGAUCHE
If find("STG",GPILCOD(1..GPILOBJ))
#If dim(SAVFONC)>=0 & SAVFONC="GESSTG" & TUNNEL
 If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
 FILGAUSUP -= "STG='"+[F]STG+"'"
Endif
Return

#####################################
$CHARGE_COUT
# Coûts prévisionnels
nolign = 1
Filter [COU] Where TYPCOU=2 & STG="" & SES=[F:HRSES]COD
For [COU]COU0
#LIPET - 2017-06-22 - X3-34431 - START
If nolign>dim([M:HRSES3]TYPCRG) Then Break : Endif
#LIPET - 2017-06-22 - X3-34431 - END
 [M:HRSES3] = [F:COU]
 nolign +=1
Next
Filter [COU]
[M:HRSES3]NBLIG  = nolign-1
Call APRES_NBLIG

# Coûts réels
nolign = 1
Filter [HRCOR] Where TYPCOU=2 & SES=[F:HRSES]COD & REFNUM=""
For [HRCOR]COR0
#LIPET - 2017-06-22 - X3-34431 - START
 If nolign>dim([M:HRSES4]TYPCRG2) Then Break : Endif
#LIPET - 2017-06-22 - X3-34431 - END
 [M:HRSES4] = [F:HRCOR]
 nolign +=1
Next
Filter [HRCOR]
[M:HRSES4]NBLIG2 = nolign-1
Return

#####################################
$CHARGE_JOUR
nolign=1
For [F:SEJ]SEJ0 Where SES=[M:HRSES0]COD
#LIPET - 2017-06-22 - X3-34431 - START
 If nolign>dim([M:HRSES2]DAT) Then Break : Endif
#LIPET - 2017-06-22 - X3-34431 - END
 [M:HRSES2]=[F:SEJ]
 [M]DAY1(nolign-1) = day$([M:HRSES2]DAT(nolign-1))
 nolign+=1
Next
[M:HRSES2]NBLIG3=nolign-1
[M:HRSES2]DATF(0) = format$("D:"+GFMDAT, [M:HRSES1]ENDDAT)
Return

#####################################
$CHARGE_INSCRIP
nolign=1 : NOL = 1
For [F:INS]INS0 Where SES=[M:HRSES0]COD
 [M:HRSES5]=[F:INS]
 Call LECTURE("EML",[M:HRSES5]REFNUM(nolign-1),"") From CONTOBJ
 If !fstat Then
   [M:HRSES5]NAM(nolign-1) = [F:ID]NAM-[F:ID]SRN
 Endif
 #SEGAY 22/02/11 bug 71267 Période de professionalisation
 Call LECTURE("DEM",[M:HRSES5]DEM(nolign-1),"") From CONTOBJ
 If !fstat Then
   [M:HRSES5]FLGPRO(nolign-1) = [F:DEM]FLGPRO
 Else
   [M:HRSES5]FLGPRO(nolign-1) = 0
 Endif

 nolign+=1
 # FQ80895 - MABON 07/06/12 - On écarte les inscriptions refusées, d'où le test sur [F:INS]STA<>3
 If [F:INS]STA<>3 Then
   Gosub COUT_PART
 Endif
 # Fin MABON
Next
[M:HRSES5]NBLIG4=nolign-1
Call APRES_NBLIG2
[M:HRSES0]NBRINS=nolign-1
Return

#####################################
# MABON - 30/08/10 - Récupération actions suivi
$CHARGE_ACN
Local Integer I

  nolign=1
  For I=0 To dim([F:HRSES]SUIACN)-1
    If [M:HRSES6]SUIACN(I)<>"" Then
      #LIPET - 2017-06-22 - X3-34431 - START
      If nolign>dim([M:HRSES6]SUIACN) Then Break : Endif
      #LIPET - 2017-06-22 - X3-34431 - END
      [M:HRSES6]SUIACN(nolign-1)=[F:HRSES]SUIACN(I)
      [M:HRSES6]SUIDAT(nolign-1)=[F:HRSES]SUIDAT(I)
      [M:HRSES6]SUICMT(nolign-1)=[F:HRSES]SUICMT(I)
      nolign+=1
    Endif
  Next
  [M:HRSES6]NBACN=nolign-1
Return

$COUT_PART
Filter [HRCOR] Where TYPCOU=3 & SES=[M:HRSES0]COD & REFNUM=[F:INS]REFNUM
For [HRCOR]COR0
 Read[F:ADI]CODE=10451;[F:HRCOR]TYPCRG2
 If !fstat & [F:ADI]N2<>2 :#type de frais participant et autre uniquement
  I=find([F:HRCOR]TYPCRG2+"~"+[F:HRCOR]TYPFIN2,[M:HRSES4]CPLCOU3(0..NOL-1))
  If I
   #LIPET - 2017-06-22 - X3-34431 - START
   If I>dim([M:HRSES4]TYPCRG3) Then Break : Endif
   #LIPET - 2017-06-22 - X3-34431 - END
   [M:HRSES4]TYPFIN3(I-1)     = [F:HRCOR]TYPFIN2 : # MABON 30/11/10 - FQ59936 - Ajout type financement
   [M:HRSES4]CSTTOTIDV3(I-1) += [F:HRCOR]CSTTOTIDV2
   [M:HRSES4]CSTIPTIDV3(I-1) += [F:HRCOR]CSTIPTIDV2
  Else
   #LIPET - 2017-06-22 - X3-34431 - START
   If NOL>dim([M:HRSES4]TYPCRG3) Then Break : Endif
   #LIPET - 2017-06-22 - X3-34431 - END
   [M:HRSES4]TYPFIN3(NOL-1)    = [F:HRCOR]TYPFIN2 : # MABON 30/11/10 - FQ59936 - Ajout type financement
   [M:HRSES4]TYPCRG3(NOL-1)    = [F:HRCOR]TYPCRG2
   [M:HRSES4]CSTTOTIDV3(NOL-1) = [F:HRCOR]CSTTOTIDV2
   [M:HRSES4]CSTIPTIDV3(NOL-1) = [F:HRCOR]CSTIPTIDV2
   [M:HRSES4]CPLCOU3(NOL-1)    = [F:HRCOR]TYPCRG2+"~"+[F:HRCOR]TYPFIN2
   NOL +=1
  Endif
 Endif
Next
Filter [HRCOR]
[M:HRSES4]NBLIG5 = NOL-1
Return

#####################################
# SYMEU V6.1 Module Formation - Formateur interne : récupération du nom et prénom
#####################################
$CHARGE_TRN
  [M:HRSES1]NAM = [F:ID]NAM
  [M:HRSES1]SRN = [F:ID]SRN
  Affzo [M:HRSES1]NAM, SRN
Return

#**#####################################################################################
#* MABON - 26/08/10 - Récupération du nom et prénom du RH chargé su suivi administratif
#*!
Subprog CHARGE_NUMRH(REFNUM)
Value Char REFNUM

  Read [ID]ID0=REFNUM
  If !fstat Then
    [M:HRSES1]NAMRH = [F:ID]NAM
    [M:HRSES1]SRNRH = [F:ID]SRN
    Affzo [M:HRSES1]NAMRH, SRNRH
  Endif
End

#**#####################################################################################
#* MABON - 26/08/10 - Récupération des ressources
#*!
$CHARGE_RSC
Local Integer I, MAXI

  MAXI=0
  For I=0 To dim([F:HRSES]RSCNEC)-1
    If [F:HRSES]RSCNEC(I)<>"" Then
      [M:HRSES3]RSCNEC(I)=[F:HRSES]RSCNEC(I)
      MAXI += 1
    Endif
  Next
  [M:HRSES3]NBRSC=MAXI
Return

#**#####################################################################################
#* MABON - 24/08/10 - En création, on initialise le tableau avec toutes les colonnes par défaut
#* Par ailleurs, on initialise le tableau de M:HRSES6 par les valeurs par défaut paramétrées dans ADI466
#*!
$RAZCRE

  GINTITDAT=mess(88,100,1) : # Date

  Chgfmt [M:HRSES2]DATF      With "-K:10X"
  Chgfmt [M:HRSES2]DAY1      With "K:10X"
  Chgfmt [M:HRSES2]DEBTIM    With "K:##[:]##"
  Chgfmt [M:HRSES2]FINTIM    With "K:##[:]##"
  Chgfmt [M:HRSES2]NBRTIMBRK With "N:9.2"
  Chgfmt [M:HRSES2]NBRJOU    With "N:9.2"
  Chgfmt [M:HRSES2]NBRHOUHTT With "-N:9.2"

  Chgfmt [M:HRSES2]NBRDAY    With "N:4.2"
  #LIPET - 2017-06-22 - X3-34431 - START
  Chgfmt [M:HRSES2]NBRNGT    With "N:4.2"
  #LIPET - 2017-06-22 - X3-34431 - END

  # Fiche 70910 - SYMEU - 26/01/2011 : grisage du formateur externe et du contrat du formateur interne
  Grizo [M:HRSES1]TCHNAM, CTRNUM

# 29/06/12 - PCA - Default the LEG
If dim([M:HRSES0]LEG)>0 Then
  [M:HRSES0]LEG=GLEGFIL
  Affzo [M:HRSES0]LEG
  GCURLEG = [M:HRSES0]LEG
Endif
Gosub RAZ_SUIACN

  # 24/05/12 - PCA - Clear fields until legislation selected
  #GCURLEG = ""
  Call DISPLAY_HIDE() From SUBHRSESLEG

  # FQ79563 - MABON 11/09/12 - Gestion de l'icône "Nouvelle adresse"
  [M:HRSES1]CLCADD="21" : Affzo [M:HRSES1]CLCADD
  # Fin MABON

  Call D_WTEXT([M:HRSES3]WTEXT) From SUBHRSES
  Affzo [M:HRSES3]WTEXT
  #LIPET - 2017-06-22 - X3-34431 - START
  Gosub STYLE # X3PEOP-3477
  #LIPET - 2017-06-22 - X3-34431 - END
Return

$RAZ_SUIACN
Local Integer I
   Local Integer DEF_GCUR
   DEF_GCUR=dim(GCURLEG)
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  I=0
  For [F:ADI] Where NUMTAB=10466 and N1=2
    If(!DEF_GCUR or GCURLEG="" or find([F:ADI]LEG,GCURLEG,""))
      #LIPET - 2017-06-22 - X3-34431 - START
      If I+1>dim([M:HRSES6]SUIACN) Then Break : Endif
      #LIPET - 2017-06-22 - X3-34431 - END
      [M:HRSES6]SUIACN(I)=[F:ADI]CODE
      I += 1
    Endif
  Next
  [M:HRSES6]NBACN=I
  Raz [M]NBAMT
  Affzo [M:HRSES6]

Return

#####################################
# MABON - 30/08/10 - Récupération montants et infos montants dans SES6
Subprog AJOUT_LIGNE6(ORG6, CUR6, AMT6, CPY6, NL)
Value    Char    ORG6, CUR6, CPY6
Value    Decimal AMT6
Variable Integer NL
Local    Integer NB6

  If ORG6="" Then End : Endif

  # Si CPY6 est <> de "", c'est qu'on traite les coûts des inscriptions
  # Si CPY est = à "", c'est qu'on traite les coûts du formateur interne
#  If CPY6<>"" or !find(ORG6, [M:HRSES6]ORGFIN3(0..19)) Then
#    If !find(ORG6+"~"+CPY6, [M:HRSES6]CPLFIN3(0..19)) Then
  If (CPY6<>"" & !find(ORG6+"~"+CPY6, [M:HRSES6]CPLFIN3(0..19))) | (CPY6="" & !find(ORG6+"~", [M:HRSES6]CPLFIN3(0..19))) Then
      [M:HRSES6]ORGFIN3(NL) = ORG6
      [M:HRSES6]CPYAMT(NL)  = CPY6
      [M:HRSES6]CPLFIN3(NL) = ORG6+"~"+CPY6
      [M:HRSES6]NBINS6      = 1
      [M:HRSES6]CUR(NL)     = CUR6
      [M:HRSES6]ENGAMT(NL)  = 0

      # Récupération des infos stockées dans COUTFIN relatives à chaque organisme
      Read [F:COF]COF1=2;[M:HRSES0]COD;ORG6;CPY6
      If !fstat Then
        [M:HRSES6]FINDAT(NL)=[F:COF]FINDAT
        [M:HRSES6]FINAMT(NL)=[F:COF]FINAMT
        [M:HRSES6]VERDAT(NL)=[F:COF]VERDAT
        [M:HRSES6]VERAMT(NL)=[F:COF]VERAMT
        [M:HRSES6]REMDAT(NL)=[F:COF]REMDAT
        [M:HRSES6]REMAMT(NL)=[F:COF]REMAMT
        [M:HRSES6]CMTAMT(NL)=[F:COF]CMTAMT
      Endif
      Filter [F:COF]
      NL +=1
#    Endif
  Endif
  If CPY6="" Then
    NB6 = 0
    For I=0 To NL-1
      If [M:HRSES6]ORGFIN3(I)=ORG6 Then
        NB6 += [M:HRSES6]NBINS6(I)
      Endif
    Next
  Endif
  # Calcul du montant engagé = Somme des coûts réels individuels des inscriptions pour chaque organisme
  For I=0 To NL-1
    If CPY6<>"" Then
      If [M:HRSES6]CPLFIN3(I)=ORG6+"~"+CPY6 Then
        [M:HRSES6]NBINS6    += 1
        [M:HRSES6]ENGAMT(I) += AMT6
        Break
      Endif
    Else
#      If [M:HRSES6]ORGFIN3(I)=ORG6 Then
      If [M:HRSES6]CPLFIN3(I)=ORG6+"~" Then
        If [M:HRSES6]NBINS6(I)>0 Then
          [M:HRSES6]ENGAMT(I) += AMT6*NB6/[M:HRSES6]NBINS6(I)
        Else
          [M:HRSES6]ENGAMT(I) += AMT6
          Break
        Endif
      Endif
    Endif
  Next
End

#####################################
# MABON - 30/08/10 - Récupération montants
$CHARGE_AMT
Local Integer I, J, NL, NB_BY_CPY(0..99), IC, NBTOT
Local Char    WFCY(GLONFCY), WCPY(GLONCPY), LIS_CPY(5)(0..99)

  For I=0 To 19
    [M:HRSES6]ORGFIN3(I) = ""
    [M:HRSES6]CPYAMT(I)  = ""
    [M:HRSES6]CPLFIN3(I) = ""
    [M:HRSES6]ENGAMT(I)  = 0
    [M:HRSES6]FINDAT(I)  = [0/0/0] : [M:HRSES6]FINAMT(I) = 0
    [M:HRSES6]VERDAT(I)  = [0/0/0] : [M:HRSES6]VERAMT(I) = 0
    [M:HRSES6]REMDAT(I)  = [0/0/0] : [M:HRSES6]REMAMT(I) = 0
    [M:HRSES6]CMTAMT(I)  = ""
  Next
  Raz [M:HRSES6]NBAMT

  NL=0 : IC=0
  Filter [F:INS] Where SES=[M:HRSES0]COD
  For [F:INS]
    WFCY = "" : WCPY = ""
    Call CALC_CFY([F:INS]REFNUM, [F:INS]CTRNUM, [F:HRSES]STRDAT, WFCY, WCPY) From CARRFOR
    # FQ72892 - MABON 05/04/11 - Stockage des sociétés et nombre d'inscriptions par société
    If !find(WCPY, LIS_CPY) Then
      LIS_CPY(IC) = WCPY
      IC         += 1
    Endif
    I=find(WCPY, LIS_CPY)
    If I>0 Then
      NB_BY_CPY(I-1) += 1
    Endif
    # Fin MABON
    Filter [F:HRCOR] Where TYPCOU=3 & SES=[M:HRSES0]COD & REFNUM=[F:INS]REFNUM
    For [F:HRCOR]
      Call AJOUT_LIGNE6([F:HRCOR]ORGFIN2, [F:HRCOR]CUR, [F:HRCOR]CSTTOTIDV2, WCPY, NL)
    Next
    Filter [F:HRCOR]
  Next
  Filter [F:INS]

  # FQ72892 - MABON 05/04/11 - Calcul nombre total d'inscriptions
  NBTOT=0
  If IC>0 Then
    For J= 0 To IC-1
      NBTOT += NB_BY_CPY(J)
    Next
  Endif
  # ajout lignes relatives au formateur interne : dispatché sur les couples Organisme/Société
#  For I=0 To [M:HRSES4]NBLIG2-1
  For I=0 To dim([M:HRSES4]CSTTOTIDV2)-1
    If [M:HRSES4]ORGFIN2(I)<>"" Then
      # FQ72892 - MABON 05/04/11 - Répartition des coûts formateur par société, selon nombre d'inscrits dans société
      If IC>0 & NBTOT>0 Then
        For J= 0 To IC-1
          If NB_BY_CPY(J)>0 Then
            Call AJOUT_LIGNE6([M:HRSES4]ORGFIN2(I), [M:HRSES4]CUR , [M:HRSES4]CSTTOTIDV2(I)*NB_BY_CPY(J)/NBTOT, LIS_CPY(J), NL)
          Endif
        Next
      Else
        Call AJOUT_LIGNE6([M:HRSES4]ORGFIN2(I), [M:HRSES4]CUR , [M:HRSES4]CSTTOTIDV2(I), "", NL)
      Endif
    Endif
  Next
  # FQ72861 - MABON 12/04/11 - Ajout d'une ligne de total sur les montants affichés
  If NL>0 Then
    [M:HRSES6]ORGFIN3(NL) = mess(151,115,1) : # Total
    For I=0 To NL-1
      #LIPET - 2017-06-22 - X3-34431 - START
      If NL+1>dim([M:SES6]ORGFIN3) Then Break : Endif
      #LIPET - 2017-06-22 - X3-34431 - END
      [M:HRSES6]ENGAMT(NL) += [M:HRSES6]ENGAMT(I)
      [M:HRSES6]FINAMT(NL) += [M:HRSES6]FINAMT(I)
      [M:HRSES6]VERAMT(NL) += [M:HRSES6]VERAMT(I)
      [M:HRSES6]REMAMT(NL) += [M:HRSES6]REMAMT(I)
    Next
    Diszo [M:HRSES6]FINAMT(NL), VERAMT(NL), REMAMT(NL)
    NL += 1
  Endif
  [M:HRSES6]NBAMT=NL
Return

#####################################
$INICRE
# Affectation du code session
If [F:HRSES]COD=""
 Call CPT_SES(VALCPT,[F:HRSES]STG)
 If GOK
  [M:HRSES0]COD = VALCPT
  [F:HRSES]COD  = VALCPT
  Affzo [M:HRSES0]COD
 Endif
Endif
[F:HRSES]FLGCLO=1
Gosub SAUVE_JOUR
Gosub SAUVE_COUT
# MABON - 30/08/10 - Enregistrement actions suivi
Gosub SAUVE_ACN
# MABON - 30/08/10 - Enregistrement montants
Gosub SAUVE_AMT
Return

#####################################
Subprog CPT_SES (VALEUR, STAGE)
Variable Char VALEUR()
Value Char STAGE ()
Local Char COMPTEUR(GLONANM)
Local Integer STAT
If clalev([F:TCA])=0 : Local File TABCOUAFF  [TCA] : Endif
GOK=1
#Read [TCA]TCA0 = 20 : # Module gestion des talents
#COMPTEUR = [F:TCA]CODNUM(1)
#If COMPTEUR=""
# GMESSAGE = mess(2,10717,1) : # Compteur session non défini
# GOK = 0 : End
#Endif
Call LECTCA(20,STAT) From SUBTCA : # Module gestion des talents
If !STAT
  GMESSAGE = mess(2,10717,1) : # Compteur contrat non défini
  GOK = 0 : End
Else
  COMPTEUR= [F:TCA]CODNUM(1)
Endif
Call NUMERO(COMPTEUR,"",datesyst,STAGE,VALEUR,STAT) From SUBANM
If STAT
 GMESSAGE = mess(4,10702,1)-COMPTEUR : # "Erreur sur compteur"
 GOK = 0 : End
Endif
Call VERIF_VCR(VALEUR,COMPTEUR)
If GOK=0 : End : Endif
End

Subprog VERIF_VCR(NUM,COMPTEUR)
Variable Char NUM
Value    Char COMPTEUR
Local Integer STAT
If clalev([F:SESZ])=0 : Local File SESSIONS [SESZ] : Endif
Read [SESZ]SES0=NUM
If fstat : End : Endif
While !fstat
 Call NUMERO(COMPTEUR,"",datesyst,"",NUM,STAT) From SUBANM
 Read [SESZ]SES0=NUM
Wend
If STAT
 # Erreur sur compteur
 GMESSAGE = mess(4,10702,1)-COMPTEUR
 GOK = 0 : End
Endif
End

#####################################
$INIMOD
Gosub SAUVE_JOUR
If [M:HRSES1]FLGDAT=1 : Gosub MAJ_DEM : Endif
Gosub SAUVE_COUT
# MABON - 30/08/10 - Enregistrement actions suivi
Gosub SAUVE_ACN
# MABON - 30/08/10 - Enregistrement montants
Gosub SAUVE_AMT
Return

$SAUVE_COUT
Local Integer NBENR

Delete [COU] Where TYPCOU=2 & STG="" & SES=[M:HRSES0]COD
If fstat=1 | fstat>5
 GOK = 0 : Call FSTA("COU") From GLOCK : Return
Endif
Raz [F:COU]
For nolign=1 To [M:HRSES3]NBLIG
 [F:COU]       = [M:HRSES3]
 [F:COU]TYPCOU = 2
 [F:COU]SES    = [M:HRSES0]COD
 [F:COU]NUMLIG = nolign
 [F:COU]CREUSR = GUSER
 [F:COU]CREDAT = date$
 [F:COU]CRETIM = time
 Write [F:COU]
 If fstat
  GOK = 0 : Call FSTA("COU") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif

Delete [HRCOR] Where TYPCOU=2 & SES=[M:HRSES0]COD
If fstat=1 | fstat>5
 GOK = 0 : Call FSTA("HRCOR") From GLOCK : Return
Endif
Raz [F:HRCOR]
For nolign=1 To [M:HRSES4]NBLIG2
 [F:HRCOR]       = [M:HRSES4]
 [F:HRCOR]TYPCOU = 2
 [F:HRCOR]SES    = [M:HRSES0]COD
 [F:HRCOR]NUMLIG = nolign
 [F:HRCOR]CREUSR = GUSER
 [F:HRCOR]CREDAT = date$
 [F:HRCOR]CRETIM = time
 Write [F:HRCOR]
 If fstat
  GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break
 Endif
Next
Return

#####################################
# MABON - 30/08/10 - Enregistrement actions suivi
$SAUVE_ACN
Local Integer I

  Raz [F:HRSES]SUIACN, [F:HRSES]SUIDAT, [F:HRSES]SUICMT
  For I=0 To [M:HRSES6]NBACN-1
    [F:HRSES]SUIACN(I) = [M:HRSES6]SUIACN(I)
    [F:HRSES]SUIDAT(I) = [M:HRSES6]SUIDAT(I)
    [F:HRSES]SUICMT(I) = [M:HRSES6]SUICMT(I)
  Next
Return

#####################################
# MABON - 30/08/10 - Enregistrement montants
$SAUVE_AMT

  Delete [COF] Where TYPCOU=2 & SES=[M:HRSES0]COD
  If fstat=1 | fstat>5
   GOK = 0 : Call FSTA("COF") From GLOCK : Return
  Endif
  Raz [F:COF]

  For nolign=1 To [M:HRSES6]NBAMT
    If [M:HRSES6]ORGFIN3(nolign-1) <> mess(151,115,1) : # Bug 96746 - 11/02/2014 pas la dernière ligne total
      [F:COF]        = [M:HRSES6]
      [F:COF]TYPCOU  = 2
      [F:COF]SES     = [M:HRSES0]COD
      [F:COF]NUMLIG  = nolign
      [F:COF]CREUSR  = GUSER
      [F:COF]CREDAT  = date$
      [F:COF]CRETIM  = time
      Write [F:COF]
      If fstat
        GOK = 0 : Call FSTA("COF") From GLOCK : Break
      Endif
    Endif
  Next
  If GOK=0 : Return : Endif
Return

# FQ78431 - 09/04/13 - Ajout tableau pour création inscriptions manuelles
$SAUVE_INS
Local Integer NBRINS, CREATE_INS
Local Char    MATRI(GLONEML),CTR(GLONHRCTR)
Local Decimal TAUX, MTTIPT, MTTTOT

  If clalev([F:ADI2])=0  : Local File ATABDIV   [ADI2] : Endif
  CREATE_INS=1
  If [M:HRSES5]NBLIGD>0 Then
    CREATE_INS=2
    TIT=mess(74,10717,1)     : # Génération d'inscriptions
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(TIT,0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    NBRSES=0
  Endif
  For nolign=1 To [M:HRSES5]NBLIGD
    MATRI=[M:HRSES5]REFNUMD(nolign-1)
    Read [F:ID]ID0=MATRI
    Look [F:INS]INS1=[F:HRSES]COD;MATRI
    If fstat
      CTR=[M:HRSES5]CTRNUMD(nolign-1)
      Raz [F:INS]
      [F:INS]=[F:HRSES]
      [F:INS]REFNUM = MATRI
      [F:INS]DEM    = ""
      [F:INS]SES    = [F:HRSES]COD
      [F:INS]STA    = 1
      [F:INS]FLGTPS = 1
      [F:INS]DESCATACN = [F:HRSES]CATACN
      [F:INS]DESNATFIS = [F:HRSES]NATFIS
      Call CAT2483(MATRI,CTR,[F:INS]CATFRT) From SUBDEM
      [F:INS]CTRNUM = CTR
      Gosub CALCOUT From INSPRO
      If !GOK : Return : Endif
      # FQ97638 - 21/03/14 - Dans INITJOUR, ces deux informations sont recalculées, il faut donc d'abord les initialiser à 0
      Raz [F:INS]NBRHOUIPT
      Raz [F:INS]NBRDAY
      # Fin FQ97638
      Gosub INITJOUR From INSPRO
      Gosub INITCPC From INSPRO
      Gosub INITHAB From INSPRO
      If !GOK : Return : Endif
      [F:INS]CREDAT = date$ :  [F:INS]CREUSR = GUSER :  [F:INS]CRETIM = time
      Raz [F:INS]UPDDAT   :  Raz [F:INS]UPDUSR   :  Raz [F:INS]UPDTIM : Raz [F:INS]EXPNUM
      Write [F:INS]
      If fstat
        GOK = 0 : Call FSTA("INS") From GLOCK : Return
      Endif
      #Inscription du matricule xx / Contrat yy
      Call ECR_TRACE(space$(5)+mess(31,10717,1)-MATRI-[F:ID]NAM-[F:ID]SRN-"/"-mess(7,10508,1)-CTR,0) From GESECRAN
      NBRINS+=1
      #LIPET - 2017-06-22 - X3-34431 - START
      GABREV="INS"
      Call WORKFLOW(2,"INS","","") From AWRK
      GABREV="HRSES"
      #LIPET - 2017-06-22 - X3-34431 - END
    Else
      #Inscription du matricule xx : inscription déjà existante sur session xx
      Call ECR_TRACE(space$(5)+mess(31,10717,1)-MATRI-[F:ID]NAM-[F:ID]SRN-":"-mess(211,10717,1)-[F:HRSES]COD,0) From GESECRAN
    Endif
  Next
  If CREATE_INS=2 Then
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    If NBRINS=0 Then
      Call ECR_TRACE(mess(55,10717,1),0) From GESECRAN : # Aucune inscription à traiter
    Else
      Gosub CHARGE_INSCRIP
    Endif
    Call FERME_TRACE From LECFIC
    # Affichage de la trace
    Call LEC_TRACE From LECFIC
  Endif
  If !GOK : Return : Endif
  Raz [M:HRSES5]NBLIGD,REFNUMD,NAMD,CTRNUMD : Affzo [M:HRSES5]
Return

#####################################
#Mise à jour des dates de la session dans les demandes
$MAJ_DEM
For [F:DEM]DEM1 Where SES=[F:HRSES]COD
 [F:DEM]DATSTR=[F:HRSES]STRDAT
 [F:DEM]DATEND=[F:HRSES]ENDDAT
 Rewrite [F:DEM]
 If fstat
  GOK = 0 : Call FSTA("DEM") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif
Return

#####################################
$SAUVE_JOUR
Delete [F:SEJ] Where SES=[M:HRSES0]COD
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("SEJ",[F:SEJ]SES-num$([F:SEJ]DAT)) From GLOCK : Return
Else
 For nolign=1 To [M:HRSES2]NBLIG3
  [F:SEJ]SES=[M:HRSES0]COD
  [F:SEJ]   =[M:HRSES2]
  #[F:SEJ]DAT=[M:HRSES2]DAT(nolign-1)
  #[F:SEJ]DEBTIM=[M:HRSES2]DEBTIM(nolign-1)
  #[F:SEJ]FINTIM=[M:HRSES2]FINTIM(nolign-1)
  #[F:SEJ]NBRTIMBRK=[M:HRSES2]NBRTIMBRK(nolign-1)
  #[F:SEJ]NBRHOU=[M:HRSES2]NBRHOU(nolign-1)
  #[F:SEJ]NBRJOU=[M:HRSES2]NBRJOU(nolign-1)
  Write [F:SEJ]
  If fstat
   GOK = 0 : Call FSTA("SEJ") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Return : Endif
Endif
Return

#####################################
$VERIF
For I=1 To [M:HRSES2]NBLIG3
 If [M:HRSES2]DAT(I-1)<[M:HRSES1]STRDAT | [M:HRSES2]DAT(I-1)>[M:HRSES1]ENDDAT
  #Date en dehors de la période de la session
  GMESSAGE=num$([M:HRSES2]DAT(I-1))-mess(8,10717,1)
  OK=0 : Break
 Endif
Next
Call CALL_INIML1 #FQ93180  - Initialisation ML1 <> 0
If dim(GMODINS)<0 Then Global Integer GMODINS Endif
GMODINS=1
Read [F:HRSES]SES0=[M:HRSES0]COD
If [F:HRSES]STRDAT<>[M:HRSES1]STRDAT | [F:HRSES]ENDDAT<>[M:HRSES1]ENDDAT Then GMODINS=2 Endif
#LIPET - 2017-06-22 - X3-34431 - START
If [M:HRSES2]NBRHOUIPT<>[M:HRSES3]NBRHOUSTG Then
  # Le nombre d'heures du calendrier xx ne correspond pas au nombre d'heures indiquées dans l'onglet Organisation yy
  GMESSAGE=func AFNC.MES2(mess(308,10717,1),num$([M:HRSES2]NBRHOUIPT),num$([M:HRSES3]NBRHOUSTG))
  Infbox GMESSAGE
  GMESSAGE=""
Endif
#LIPET - 2017-06-22 - X3-34431 - END
Return

#####################################
$MODIF
Local Integer I, NBMAX(0..100), NBINS(0..100), MAXSES, INDSES
Local Char    TABSES(15)(0..100)

  # Si les dates de la session ont changé, il faut aussi modifier les dates des inscriptions,
  # uniquement pour celles qui sont juste Saisies (si elles sont En cours, Confirmées ou Clôturées, on ne fait rien)
  If clalev([F:INJ1])=0 : Local File INSJOU   [INJ1] : Endif
  If clalev([F:INJ2])=0 : Local File INSJOU   [INJ2] : Endif
  If clalev([F:INS1])=0 : Local File INSCRIPT [INS1] : Endif
  If clalev([F:INS2])=0 : Local File INSCRIPT [INS2] : Endif
  If clalev([F:SES2])=0 : Local File SESSIONS [SES2] : Endif
  If clalev([F:DEM2])=0 : Local File DEMANDE  [DEM2] : Endif
  If clalev([F:COR1])=0 : Local File COUTREEL [COR1] : Endif
  If clalev([F:COR2])=0 : Local File COUTREEL [COR2] : Endif

  Local Char SYMBINS(80)
  If GMODINS=2 Then
    GMODINS=1
    Filter [F:INJ1] Where STG=[F:HRSES]STG & SES=[F:HRSES]COD & STA<=1
    For [F:INJ1]
      SYMBINS = "INS"+[F:INJ1]REFNUM+"\"+[F:HRSES]COD
      Lock =SYMBINS
      If fstat Then
        GOK=0 : Call RSTA("INS",[F:HRSES]STG-[F:HRSES]COD-[F:INJ1]REFNUM) From GLOCK
        Break
      Else
        Readlock [F:INS]INS0=[F:HRSES]STG;[F:HRSES]COD;[F:INJ1]REFNUM
        If !fstat Then
          Delete [F:INJ2] Where STG=[F:HRSES]STG & SES=[F:HRSES]COD & REFNUM=[F:INJ1]REFNUM
          If fstat=1 | fstat>5 Then
            GOK=0 : Call RSTA("INJ",[F:HRSES]STG-[F:HRSES]COD-[F:INJ1]REFNUM-num$([F:INJ1]DAT)) From GLOCK
            Unlock =SYMBINS
            Break
          Else
            For [F:SEJ]SEJ0 Where SES=[F:HRSES]COD
              [F:INJ2]=[F:SEJ]
              [F:INJ2]STG       = [F:INJ1]STG
              [F:INJ2]REFNUM    = [F:INJ1]REFNUM
              [F:INJ2]NBRHOUREA = [F:SEJ]NBRHOU
              [F:INJ2]NBRDAYREA = [F:SEJ]NBRJOU
              # MABON 23/08/10 - Récup heures HTT
              If [F:STG]COD<>"" and [F:STG]TYPSTG=2 Then
                [F:INJ2]NBRHOUREA2 = [F:SEJ]NBRHOUHTT
                [F:INJ2]DATEND     = [F:HRSES]ENDDAT
              Endif
              Write [F:INJ2]
              If fstat Then
                GOK = 0 : Call FSTA("INJ") From GLOCK
                Unlock =SYMBINS
                Break 2
              Endif
            Next
          Endif
        Endif
        Unlock =SYMBINS
      Endif

#SEGAY 23/02/11 bug 71823 MAJ des lignes de Parcours
#      Read [F:INS1]INS0=[F:HRSES]COD;[F:INJ1]REFNUM
      Read [F:INS1]INS0=[F:HRSES]STG;[F:HRSES]COD;[F:INJ1]REFNUM
      If !fstat and [F:INS1]DEM<>"" Then
        Call LECTURE("DEM", [F:INS1]DEM, "") From CONTOBJ
        If [F:DEM]ORIDEM=2 : # Origine demande = Parcours
#SEGAY 23/02/11 bug 71823 MAJ des lignes de Parcours
#          Call UPDATE_CSI([F:DEM]CODCSI, [F:HRSES]SES, [F:INJ1]STG, [F:INS1]REFNUM, "INS1", 2, GOK) From SUBINS
          Call UPDATE_CSI([F:DEM]CODCSI, [F:HRSES]COD, [F:INJ1]STG, [F:INS1]REFNUM, "INS1", 2, GOK) From SUBINS
          If GOK=0 Then Break : Endif
        Endif
      Endif
    Next
    Filter [F:INJ1]
  Endif

  # Si des inscriptions sont reportées dans d'autres sessions, il faut aussi modifier les clés des inscriptions,
  # des jours d'inscriptions, des coûts réels, ainsi que les demandes
  If GOK Then
    # Récupération de la liste des sessions de report, avec leur nombre max d'inscrits, et leur nombre d'inscrits
    J=0
    For I=0 To [M:HRSES5]NBLIG4-1
      If [M:HRSES5]NEWSES(I)<>"" and !find([M:HRSES5]NEWSES(I), TABSES(0..100)) Then
        TABSES(J) = [M:HRSES5]NEWSES(I)
        Read [F:SES2]SES0=[M:HRSES5]NEWSES(I)
        If !fstat Then
          NBMAX(J)  = [F:SES2]NBRPRTMAX
        Else
          NBMAX(J)  = 0
        Endif
        Read [TSE]TSE1=[M:HRSES0]STG;[M:HRSES5]NEWSES(I)
        If !fstat Then
          NBINS(J)  = [F:TSE]NBRINS
        Else
          NBINS(J)  = 0
        Endif
        J += 1
      Endif
    Next
    MAXSES=J
    If MAXSES>0 Then
      # Gestion de la trace des reports d'inscriptions
      Call OUVRE_TRACE(mess(142,10717,1)) From LECFIC : # Report d'inscriptions
      Call ECR_TRACE(TIT-mess(34,10717,1)-":"-[M:HRSES0]COD,0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

      For I=0 To [M:HRSES5]NBLIG4-1
        If [M:HRSES5]NEWSES(I)<>"" Then
          For J=0 To MAXSES-1
            If [M:HRSES5]NEWSES(I)=TABSES(J) Then
              INDSES=J
              Break
            Endif
          Next

          If NBINS(INDSES)<NBMAX(INDSES) Then
            Read [F:INS1]INS0=[M:HRSES0]STG;[M:HRSES5]NEWSES(I);[M:HRSES5]REFNUM(I)
            If fstat Then : # Une inscription n'existe pas déjà sur ce matricule
              Read [F:INS1]INS0=[M:HRSES0]STG;[M:HRSES0]COD;[M:HRSES5]REFNUM(I)
              If !fstat Then
                # Création inscription sur nouvelle session
                [F:INS2]=[F:INS1]
                [F:INS2]SES=[M:HRSES5]NEWSES(I)
                Write [F:INS2]
                If fstat Then
                  GOK = 0 : Call FSTA("INS") From GLOCK : Break
                Endif

                If [F:INS1]DEM<>"" Then
                  Call LECTURE("DEM", [F:INS1]DEM, "") From CONTOBJ

                  # Mise à jour demande sur nouvelle session
                  If !fstat and [F:DEM2]SES=[M:HRSES0]COD Then
                    [F:DEM2]SES=[M:HRSES5]NEWSES(I)
                    Rewrite [F:DEM2]
                    If fstat Then
                      GOK = 0 : Call FSTA("DEM") From GLOCK : Break
                    Endif
                  Endif

                  # Mise à jour parcours sur nouvelle session
                  If [F:DEM]ORIDEM=2 Then
                    Call UPDATE_CSI([F:DEM]CODCSI, [M:HRSES0]COD, [M:HRSES0]STG, [F:INS1]REFNUM, "INS1", 2, GOK) From SUBINS
                    If GOK=0 Then Break : Endif
                  Endif
                Endif

                If GOK Then
                  # Suppression inscription sur ancienne session
                  Delete [F:INS1] Where SES=[M:HRSES0]COD and REFNUM=[M:HRSES5]REFNUM(I)
                  If fstat Then GOK = 0 : Call FSTA("INS") From GLOCK : Break : Endif
                Endif
              Else
                GOK=0
              Endif

              If GOK Then
                # Création lignes d'inscription sur nouvelle session
                Filter [F:INJ1] Where STG=[M:HRSES0]STG & SES=[M:HRSES0]COD & REFNUM=[M:HRSES5]REFNUM(I)
                For [F:INJ1]
                  Read [F:INJ2]INJ0=[M:HRSES0]STG;[M:HRSES5]NEWSES(I);[M:HRSES5]REFNUM(I);[F:INJ1]DAT
                  If fstat Then
                    [F:INJ2]=[F:INJ1]
                    [F:INJ2]SES=[M:HRSES5]NEWSES(I)
                    Write [F:INJ2]
                    If fstat Then GOK = 0 : Call FSTA("INJ") From GLOCK : Break 2 : Endif
                  Endif
                Next
                Filter [F:INJ1]
                If GOK Then
                  # Suppression lignes d'inscription sur ancienne session
                  Delete [F:INJ1] Where STG=[M:HRSES0]STG & SES=[M:HRSES0]COD & REFNUM=[M:HRSES5]REFNUM(I)
                  If fstat Then GOK = 0 : Call FSTA("INJ") From GLOCK : Break : Endif
                Endif
              Endif

              If GOK Then
                # Création coûts réels inscription sur nouvelle session
                Filter [F:COR1] Where TYPCOU=3 & SES=[M:HRSES0]COD & REFNUM=[M:HRSES5]REFNUM(I)
                For [F:COR1]
                  Read [F:COR2]COR0=3;[M:HRSES5]NEWSES(I);[M:HRSES5]REFNUM(I);[F:COR1]NUMLIG
                  If fstat Then
                    [F:COR2]=[F:COR1]
                    [F:COR2]SES=[M:HRSES5]NEWSES(I)
                    Write [F:COR2]
                    If fstat Then GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break 2 : Endif
                  Endif
                Next
                Filter [F:COR1]
                If GOK Then
                  # Suppression coûts réels d'inscription sur ancienne session
                  Delete [F:COR1] Where TYPCOU=3 & SES=[M:HRSES0]COD & REFNUM=[M:HRSES5]REFNUM(I)
                  If fstat Then GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break : Endif
                Endif
              Endif

              If GOK Then
                NBINS(INDSES) += 1
                Call ECR_TRACE(mess(31,10717,1)-[M:HRSES5]REFNUM(I)-mess(143,10717,1)-[M:HRSES5]NEWSES(I),0) From GESECRAN : # Inscription du matricule reportée sur session
              Endif
            Else
              Call ECR_TRACE(mess(31,10717,1)-[M:HRSES5]REFNUM(I)-mess(47,10717,1)-":"-mess(211,10717,1)-[M:HRSES5]NEWSES(I),0) From GESECRAN : # Inscription du matricule impossible : inscription déjà
# existante sur session
            Endif
          Else
            Call ECR_TRACE(mess(31,10717,1)-[M:HRSES5]REFNUM(I)-mess(47,10717,1)-":"-mess(34,10717,1)-[M:HRSES5]NEWSES(I)-mess(144,10717,1),0) From GESECRAN : # Inscription du matricule impossible :
# session complète
          Endif
        Endif
      Next
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call FERME_TRACE From LECFIC
      # Affichage de la trace
      Call LEC_TRACE From LECFIC
    Endif
  Endif
Return

# Création des coûts calculés formateur
$APRES_CRE

  # FQ71040 - MABON 22/03/11 - Ajout condition sur ORG et TCHNAM
  If [M:HRSES2]NBRHOUIPT>0 & [M:HRSES1]ORG="" & [M:HRSES1]TCHNAM="" Then
    Call CALC_COUFORCAL([M:HRSES0]COD, [M:HRSES0]STG, "", 1, "", "", NBENR) From COUMAJ
    Gosub CHARGE_COUT
    Affzo [M:HRSES4]
  Endif
  # FQ78431 - 09/04/13 - Ajout tableau pour création inscriptions manuelles
  Gosub SAUVE_INS
Return


#####################################
$APRES_MOD
Local Integer I

  If dim(GMODFRTINT)>0 and GMODFRTINT=2 Then
    Gosub APRES_CRE
    GMODFRTINT=1
  Endif
  # Si on a fait des reports de sessions
  If dim(MAXSES)>0 and MAXSES>0 Then
    # Rechargement et réaffichage du tableau des inscriptions
    Gosub LIENS
    For I=0 To [M:HRSES5]NBLIG4-1
      [M:HRSES5]NEWSES(I)=""
    Next
    Affzo [M:HRSES5]
    # Réaffichage du nombre des inscriptions
    Affzo [M:HRSES0]NBRINS
    # Rechargement de la table des inscriptions
    Gosub CHARGE_TSE
#    # Rechargement du tableau des montants par organisme
#    Gosub CHARGE_AMT
#    Affzo [M:HRSES6]
    # Rechargement et réaffichage du tableau des coûts réels
    Gosub COUT_PART
    Affzo [M:HRSES4]
    MAXSES=0
  Endif
  # Rechargement du tableau des montants par organisme
  Gosub CHARGE_AMT
  Affzo [M:HRSES6]
  # FQ78431 - 09/04/13 - Ajout tableau pour création inscriptions manuelles
  Gosub SAUVE_INS
Return

#####################################
$SETBOUT
# FQ72278 - MABON 11/03/11 - On peut faire l'arrêté de formation, même si la session est clôturée
CHMEN += "A"
If [F:HRSES]FLGCLO=2
 # MABON 03/09/10 - On ne peut plus passer en mode consultation, car on veut pouvoir modifier le tableau des montants
 # remboursés (écran SES6). On fait des donc des grizo dans LIENS, à la place
# Call VIREBOUT(CHAINE,"AM1234") From GOBJET
 Call VIREBOUT(CHAINE,"A1234") From GOBJET
 Return
Endif
# 39925
If GREP<>"" | GHISTO=1
 Call VIREBOUT(CHAINE,"1234") From GOBJET
 CHMEN = ""
Endif
If [M:HRSES5]NBLIG4=0
 Call VIREBOUT(CHAINE,"124") From GOBJET
 CHMEN = ""
Endif
#CHMEN += "A"
If [F:HRSES]FLGCLO<>2 Then
 CHMEN+="I"
Endif

# FQ72861 - MABON 12/04/11 - Ajout d'une ligne de total sur les montants affichés
Chgstl [M:HRSES6]NBAMT With ""
Chgstl [M:HRSES6]NBAMT([M:HRSES6]NBAMT-1) With "PLGCUR"
Return

#####################################
$AVANTBOUT
#MABOS-19/03/13-FQ87514-before Cloture, add control for VALCPC & VALHAB
  If BOUT="2" Then
    If ([M:HRSES1]ENDDAT>datesyst) Then
       # La session doit être terminée pour pouvoir valider compétences et habilitations
       # Confirmez-vous la clôture ?
      Call OUINON(mess(193,10717,1)+chr$(10)+mess(299,10717,1),RET) From GESECRAN
      If RET=1 Then
        OK=0
      Endif
    Endif
  Endif
Return

$EXEBOUT
Case BOUT
 When "1","2"
  # FQ72895 - MABON 04/04/11 - Pour que les écrans soient actualisés
  If BOUT="2" Then
    Read [F:HRSES]SES0=[M:HRSES0]COD
  Endif
  # Fin MABON
  Gosub LECTURE From GOBJSUB
  Gosub REMP_LISGAU From GOBJSUB
Endcase
Return

#####################################
# L'exécution des boutons "Recalcul coûts réels" et "Proposition" se fait dans l'étiquette APRES_CHOI, de façon
# à pouvoir rafraîchir le browser et les écrans, en positionnant REPONSE à GSTARAF
$APRES_CHOI

  Case REPONSE
    When GSTABOU+1 :
      Local Char VALBOUT(250) , PARBOUT(250)(1..20)
      FLGEXE = 1
      GACTION = "COUREEL"
      Call TRAITE_CHAR(VALBOUT,PARBOUT,"","COUMAJ","COUREEL",3,"XYCOUMAJ") From GTRAITE
      REPONSE = GSTARAF
    When GSTABOU+4 :
#      Local Char VALBOUT(250) , PARBOUT(250)(1..20)
#      PARBOUT(1) = "INS"
#      PARBOUT(2) = [M:HRSES0]COD
#      FLGEXE = 1
#      GACTION = "GOBJET"
#      Call OBJET_CHAR(VALBOUT,PARBOUT(1),PARBOUT(2)) From GOBJET
#      Gosub CHARGE_TSE
#      Gosub CHARGE_INSCRIP
#      Affzo [M:HRSES5]
      Local Char VALBOUT(250) , PARBOUT(250)(1..20)
      FLGEXE = 1
      GACTION = "INSPRO"
      #MABOS-26/07/13-FQ81085-US1833-mémo-
#      Call TRAITE_CHAR(VALBOUT,PARBOUT,"LISDEM","INSPRO","INSPRO",3,"XYINSPRO") From GTRAITE
      Call TRAITE_CHAR(VALBOUT,PARBOUT,"LISDEM","INSPRO","INSPRO",4,"XYINSPRO") From GTRAITE
      #end MABOS-26/07/13-FQ81085-US1833-mémo
      Gosub CHARGE_TSE
      Gosub CHARGE_INSCRIP
      Affzo [M:HRSES5]
      REPONSE = GSTARAF
  Endcase
Return

######################################################################################
# FQ78431 - 09/04/13 - Ajout menu Inscriptions
$FIN_ACTION

  If BOUT="I" Then
    Gosub CHARGE_INSCRIP
    Affzo [M:HRSES5]
  Endif
Return

$RAZDUP
[M:HRSES0]FLGCLO=1
[M:HRSES0]NBRINS=0
Affzo [M:HRSES0]
[M:HRSES5]NBLIG4=0
Effzo[M:HRSES5]
Return

#FQ93180  - Initialisation ML1 <> 0
#**
#* Initialisation ML1 <> 0
#*!
Subprog CALL_INIML1
Local Integer I
For I=0 To 6
  # SES5 ML 1 dans tableau on ne met pas à jour
  If I <> 5 & evalue("clalev([M:HRSES"+num$(I)+"])")>0
    Call INI_ML1("HRSES"+num$(I)) From DIVPAYE
  Endif
Next I
End

######################################################################################
## Etiquette Ecrans [M:HRSES1](Généralités)
######################################################################################


######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : contrôle du stage
######################################################################################
Subprog C_STG(VALEUR)
Variable Char    VALEUR()
  Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
  If mkstat Then End Endif
End

#Stage
#En aprés_modif du stage on réinitialise toutes les informations de la session
#en fonction du stage saisi

Subprog AM_STG(VALEUR)
Variable Char    VALEUR()
Local    Integer MAXI

If VALEUR=""
  #LIPET - 2017-05-10 - X3-34431 - START
  #Only if code cleared
  Call AM_TCRCOD(VALEUR) From TRTCOUT
  Call APRES_NBLIG
  Raz   [M:HRSES3]TCRCOD, ZTCRCOD
  Affzo [M:HRSES3]TCRCOD, ZTCRCOD
  #LIPET - 2017-05-10 - X3-34431 - END
  If dim([M:HRSES0]LEG)>0
  Actzo[M:HRSES0]LEG
Endif
: End
: Endif
#25/05/12 PCA Alter Leg based on selected stage

If dim([M:HRSES0]LEG)>0
If VALEUR<>""
[M:HRSES0]LEG=[F:STG]LEG
Diszo[M:HRSES0]LEG
Call AM_LEG([F:STG]LEG)

Endif
Endif

Call LECTURE("STG",VALEUR,"") From CONTOBJ
Raz [M:HRSES1] : Raz [M:HRSES2] : Raz [M:HRSES3]
#LIPET - 2017-06-22 - X3-34431 - START
If dim([M:HRSES3]WTRTCOU)<>-1 and [M:HRSES3]WTRTCOU="" : [M:HRSES3]WTRTCOU=trtcou : Endif
#LIPET - 2017-06-22 - X3-34431 - END
[M:HRSES0]STG=VALEUR
If [F:STG]SHO<>""
 [M:HRSES0]DES=mess(34,10717,1)-[F:STG]SHO :#Session
Else
 [M:HRSES0]DES=mess(34,10717,1)-[F:STG]COD :#Session
Endif




[M:HRSES1]=[F:STG]
[M:HRSES1]STRDAT=[F:STG]STRVLY
[M:HRSES1]ENDDAT=[F:STG]ENDVLY
# MABON - 03/09/10 - Initialisation de la date début à la date du jour + calcul date fin
If date$>=[F:STG]STRVLY and date$<=[F:STG]ENDVLY Then
  [M:HRSES1]STRDAT=date$
  If [F:STG]NBRDAY>0 Then
    [M:HRSES1]ENDDAT=date$
    For I=1 To [F:STG]NBRDAY-1
      [M:HRSES1]ENDDAT=[M:HRSES1]ENDDAT+1
      If dayn([M:HRSES1]ENDDAT)=6 Then
        [M:HRSES1]ENDDAT=[M:HRSES1]ENDDAT+2
      Endif
    Next
  Endif
Endif
# Fin MABON
# MABON - 16/12/10 - Il faut initialiser correctement le calendrier
Call INIT_COL([F:STG]TYPSTG)
[M:HRSES1]STRTIM=[F:STG]STRTIMSTG
[M:HRSES1]ENDTIM=[F:STG]ENDTIMSTG
[M:HRSES3]=[F:STG]
[M:HRSES3]NBRDAYSTG=[F:STG]NBRDAY
[M:HRSES3]NBRHOUSTG=[F:STG]NBRHOUIPT
MAXI=0
For I=0 To dim([F:STG]RSCNEC)-1
  If [F:STG]RSCNEC(I)<>"" Then
    #LIPET - 2017-06-22 - X3-34431 - START
    If I+1>dim([M:HRSES3]RSCNEC) Then Break : Endif
    #LIPET - 2017-06-22 - X3-34431 - END
    [M:HRSES3]RSCNEC(I)=[F:STG]RSCNEC(I)
    MAXI += 1
  Endif
Next
[M:HRSES3]NBRSC=MAXI
Gosub RECUP_COUT

# Fiche 70910 - SYMEU - 26/01/2011 : début
# Gestion du grisage du formateur externe
Default Mask [M:HRSES1]
Call AM_ORG([M:HRSES1]ORG)From SUBSTG
# Gestion du grisage du contrat du formateur interne.
# Alimentation du nom et du prénom du formateur interne.
If [M:HRSES1]TCHEMP<>""
 Read [ID]ID0=[M:HRSES1]TCHEMP
 If !fstat
  Call GRISE_CTRNUM([F:ID]FLGMULCTR)
  # SYMEU V6.1 Module Formation - Formateur interne : récupération du nom et prénom
  Gosub CHARGE_TRN
 Endif
Else
 Call GRISE_CTRNUM(1)
Endif
# Fiche 70910 - SYMEU - 26/01/2011 : fin

Affzo [M:HRSES0] : Affzo [M:HRSES1] : Affzo [M:HRSES2] : Affzo [M:HRSES3]
Setmok [M:HRSES0] With 0
Setmok [M:HRSES1] With 0
Setmok [M:HRSES2] With 0
Setmok [M:HRSES3] With 0
End

$RECUP_COUT
# Init par les couts présents dans le stage
# Coût du formateur dans coût réel et non coût prévisionnel
nolign = 1
I = 1
Filter [COU] Where TYPCOU=1 & STG=VALEUR & SES=""
For [COU]COU0
 Read [ADI]CODE=10451;[F:COU]TYPCRG
 If [F:ADI]N2=2  : # Coût formateur interne
  #LIPET - 2017-06-22 - X3-34431 - START
  If I>dim([M:HRSES4]TYPCRG2) Then Break : Endif
  #LIPET - 2017-06-22 - X3-34431 - END
  [M:HRSES4]TYPCRG2(I-1)    = [F:ADI]CODE
  [M:HRSES4]TYPFIN2(I-1)    = [F:COU]TYPFIN
  [M:HRSES4]ORGFIN2(I-1)    = [F:COU]ORGFIN
  # FQ71122 - MABON 28/01/11 - Les coûts réel formateurs doivent être les coûts idv du stage*Nbre standard,
  # et non pas les coûts idv du stage
  If [F:ADI]N1=3 Then
    [M:HRSES4]CSTTOTIDV2(I-1) = [F:COU]CSTTOTIDV*[M:HRSES3]NBRPRTSTD
    [M:HRSES4]CSTIPTIDV2(I-1) = [F:COU]CSTIPTIDV*[M:HRSES3]NBRPRTSTD
  Else
    [M:HRSES4]CSTTOTIDV2(I-1) = [F:COU]CSTTOTIDV
    [M:HRSES4]CSTIPTIDV2(I-1) = [F:COU]CSTIPTIDV
  Endif
  I += 1
 Else : # Coûts autres de la session
  #LIPET - 2017-06-22 - X3-34431 - START
  If nolign>dim([M:HRSES3]TYPCRG) Then Break : Endif
  #LIPET - 2017-06-22 - X3-34431 - END
  [M:HRSES3] = [F:COU]
  nolign +=1
 Endif
Next
Filter [COU]
[M:HRSES3]NBLIG  = nolign-1
Call APRES_NBLIG
#LIPET - 2017-06-22 - X3-34431 - START
Affzo [HRSES3]
Gosub STYLE
#LIPET - 2017-06-22 - X3-34431 - END
[M:HRSES4]NBLIG2 = I-1
Call APRES_NBLIG2
Affzo [M:HRSES4]
Return

######################################################################################
## 24/05/2012 PCA - Refresh screen after legislation changed.
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  GCURLEG = VALEUR
  Gosub RAZ_SUIACN
  Call DISPLAY_HIDE() From SUBHRSESLEG
End


#Date début
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Call LECTURE("STG",[M:HRSES0]STG,"") From CONTOBJ
If !(VALEUR>=[F:STG]STRVLY & ([F:STG]ENDVLY=[0/0/0] | VALEUR<=[F:STG]ENDVLY))
 #Date en dehors de la période de validité du stage
 GMESSAGE=mess(3,10717,1) : mkstat=2 : End
Endif
End

Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
Local Integer NBJ, VOK
Local Date D
Call VERIF_DATDEM([M:HRSES0]COD,VOK)
If VOK
 # Des demandes de formation sont déjà inscrites à cette session pour cette période
 VOK = 1
 Call AVERTIR(mess(76,10717,1),VOK) From GESECRAN
 If VOK<>2 : End : Endif
Endif
# MABON 03/09/10 - Vérification des inscriptions aux dates avant modif de la session
Call VERIF_DATINS([M:HRSES0]COD,VOK)
If VOK
 # Des inscriptions à cette session existent déjà
 VOK = 1
 Call AVERTIR(mess(137,10717,1),VOK) From GESECRAN
 If VOK<>2 : mkstat=2 : End : Endif
Endif
# Fin MABON
If VALEUR<>[0/0/0] & [M:HRSES1]ENDDAT<>[0/0/0]
# MABON 03/09/10 - On ne peut pas juste compter le nombre de jours, il faut enlever les samedi/dimanche, car ensuite
# NBJ est comparé à [M]NBLIG3 dans lequel on n'a pas les samedi/dimanche
# NBJ=([M:HRSES1]ENDDAT-VALEUR)+1
 NBJ=0
 D=VALEUR
 While D<=[M:HRSES1]ENDDAT
   If !find(dayn(D),6,7) Then : # Samedi | Dimanche
    NBJ += 1
   Endif
   D += 1
 Wend
 # FQ73098 - MABON 08/04/11 - Contrôle du nombre de jours avant création dans le calendrier
 If [F:STG]TYPSTG=1 & NBJ>dim([M:HRSES2]DAT)-1 Then
  GMESSAGE=mess(239,10717,1)-num$(dim([M:HRSES2]DAT)-1)-mess(240,10717,1) : # La période de la session est trop longue (supérieure à xxx jours)
  mkstat=2
 Else
  [M:HRSES1]STRDAT=VALEUR
  Call REMP_JOURS (NBJ)
 Endif
Endif
End

Subprog VERIF_DATDEM (CODSES, POK)
Value Char CODSES ()
Variable Integer POK
If clalev([F:DEM])=0 : Local File DEMANDE[DEM] : Endif
If clalev([F:DML])=0 : Local File DEMLIG [DML] : Endif
If GREP="D" | GREP="C" : End : Endif
If CODSES="" Then End : Endif
For [F:DEM]DEM1 Where SES=CODSES
 For [DML]DML0 Where DEMNUM=[F:DEM]DEMNUM
  If [F:DML]FLGINS>2 : # Demande inscrite ou réalisée
   POK=2 : Break 2
  Endif
 Next
Next
[M:HRSES1]FLGDAT=1
End

Subprog VERIF_DATINS(CODSES, POK)
Value Char CODSES ()
Variable Integer POK

  POK=0
  If clalev([F:INJ])=0 : Local File INSJOU [INJ] : Endif
  If GREP="D" | GREP="C" : End : Endif
  Filter [F:INJ] Where SES=CODSES
  If rowcount([F:INJ])>0 Then POK=2 : Endif
  Filter [F:INJ]
End

#Date fin
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
#LIPET - 2017-05-10 - X3-34431 - START Not needed anymore
#If year(VALEUR)<>year([M:HRSES1]STRDAT)
# #Date en dehors d'une année civile
# GMESSAGE=mess(5,10717,1) : mkstat=2 : End
#Endif
#LIPET - 2017-05-10 - X3-34431 - END
Call LECTURE("STG",[M:HRSES0]STG,"") From CONTOBJ
If !(VALEUR>=[F:STG]STRVLY & ([F:STG]ENDVLY=[0/0/0] | VALEUR<=[F:STG]ENDVLY))
 #Date en dehors de la période de validité du stage
 GMESSAGE=mess(3,10717,1) : mkstat=2 : End
Endif
End

Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Integer NBJ, VOK
Call VERIF_DATDEM ([M:HRSES0]COD,VOK)
If VOK
 # Des demandes de formation sont déjà inscrites à cette session pour cette période
 VOK = 1
 Call AVERTIR(mess(76,10717,1),VOK) From GESECRAN
 If VOK<>2 : End : Endif
Endif
# MABON 03/09/10 - Vérification des inscriptions aux dates avant modif de la session
Call VERIF_DATINS([M:HRSES0]COD,VOK)
If VOK
 # Des inscriptions à cette session existent déjà pour cette période
 VOK = 1
 Call AVERTIR(mess(137,10717,1),VOK) From GESECRAN
 If VOK<>2 : mkstat=2 : End : Endif
Endif
# Fin MABON
If VALEUR<>[0/0/0] & [M:HRSES1]STRDAT<>[0/0/0]
# MABON 03/09/10 - On ne peut pas juste compter le nombre de jours, il faut enlever les samedi/dimanche, car ensuite
# NBJ est comparé à [M]NBLIG3 dans lequel on n'a pas les samedi/dimanche
# NBJ=(VALEUR-[M:HRSES1]STRDAT)+1
 NBJ=0
 D=[M:HRSES1]STRDAT
 While D<=VALEUR
   If !find(dayn(D),6,7) Then : # Samedi | Dimanche
    NBJ += 1
   Endif
   D += 1
 Wend
 [M:HRSES1]ENDDAT=VALEUR
 Call REMP_JOURS (NBJ)
Endif
End

Subprog AM_FRTINT(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : # Stage interne
 Raz [M:HRSES6]TYPCNT,DATCNT
 Grizo [M:HRSES6]TYPCNT,DATCNT
Else        : # Stage externe
 Actzo [M:HRSES6]TYPCNT,DATCNT
Endif
Affzo [M:HRSES6]TYPCNT,DATCNT

If dim(GMODFRTINT)<0 Then Global Integer GMODFRTINT : Endif

  GMODFRTINT=1
  If [F:HRSES]FRTINT<>VALEUR & VALEUR=2 Then
    GMODFRTINT=2
  Endif
End

#**
#* Si le stage est de type "Autre stage", on ne peut plus saisir les horaires
#*
#* @param VALEUR
#*!
Subprog AS_STRTIM(VALEUR)
Variable Char    VALEUR()

  Call LECTURE("STG", [M:HRSES0]STG, "") From CONTOBJ
  If [F:STG]TYPSTG=2 Then
    mkstat=2
  Endif
End

# Heure début
Subprog AM_STRTIM(VALEUR)
Variable Char    VALEUR()
Local Decimal DIFF
If VALEUR<>""
 For I=1 To [M:HRSES2]NBLIG3
  If [M:HRSES2]DEBTIM(I-1)=""
   [M:HRSES2]DEBTIM(I-1) = VALEUR
   Call SUMHRS([M:HRSES2]DEBTIM(I-1), [M:HRSES2]FINTIM(I-1), DIFF)
   [M:HRSES2]NBRHOU(I-1) =DIFF-[M:HRSES2]NBRTIMBRK(I-1)
   If [M:HRSES2]NBRJOU(I-1) = 0 : [M:HRSES2]NBRJOU(I-1) = 1 : Endif
  Endif
 Next
 Call APRES_NBLIG3
 Affzo [M:HRSES2]
Endif
End

#**
#* Si le stage est de type "Autre stage", on ne peut plus saisir les horaires
#*
#* @param VALEUR
#*!
Subprog AS_ENDTIM(VALEUR)
Variable Char    VALEUR()

  Call LECTURE("STG", [M:HRSES0]STG, "") From CONTOBJ
  If [F:STG]TYPSTG=2 Then
    mkstat=2
  Endif
End

#Heure fin
Subprog C_ENDTIM(VALEUR)
Variable Char VALEUR
If VALEUR<>"" & VALEUR<[M:HRSES1]STRTIM
 #Heure incorrecte
 GMESSAGE = mess(69,134,1)
 mkstat = 2 : End
Endif
End


Subprog AM_ENDTIM(VALEUR)
Variable Char    VALEUR()
Local Decimal DIFF
If VALEUR<>""
 For I=1 To [M:HRSES2]NBLIG3
  If [M:HRSES2]FINTIM(I-1)=""
   [M:HRSES2]FINTIM(I-1)=VALEUR
   Call SUMHRS([M:HRSES2]DEBTIM(I-1), [M:HRSES2]FINTIM(I-1), DIFF)
   [M:HRSES2]NBRHOU(I-1) =DIFF-[M:HRSES2]NBRTIMBRK(I-1)
   If [M:HRSES2]NBRJOU(I-1) = 0 : [M:HRSES2]NBRJOU(I-1) = 1 : Endif
  Endif
 Next
 Call APRES_NBLIG3
 Affzo [M:HRSES2]
Endif
End

#**
#* Si le stage est de type "Autre stage", on ne peut plus saisir le temps de pause
#*
#* @param VALEUR
#*!
Subprog AS_NBRHOUBRK(VALEUR)
Variable Decimal VALEUR

  Call LECTURE("STG", [M:HRSES0]STG, "") From CONTOBJ
  If [F:STG]TYPSTG=2 Then
    mkstat=2
  Endif
End

#Temps de pause
Subprog C_NBRHOUBRK(VALEUR)
Variable Decimal VALEUR
Local Decimal DIFF
Call SUMHRS([M:HRSES1]STRTIM, [M:HRSES1]ENDTIM, DIFF)
If VALEUR & VALEUR>=DIFF
 #Temps de pause supérieur ou égal à la durée de la session
 GMESSAGE=mess(73,10717,1)
 mkstat=2 : End
Endif
End

# Soit un formateur interne, soit un formateur externe, mais pas les deux
Subprog AS_ORG(VALEUR)
Variable Char    VALEUR()
  Call AS_ORG(VALEUR)From SUBSTG
End

Subprog AM_ORG(VALEUR)
Variable Char    VALEUR()
Call AM_ORG(VALEUR)From SUBSTG
End

Subprog AM_NBRHOUBRK(VALEUR)
Variable Decimal VALEUR
Local Decimal DIFF
If VALEUR<>0
 For I=1 To [M:HRSES2]NBLIG3
  If [M:HRSES2]NBRTIMBRK(I-1)=0
   [M:HRSES2]NBRTIMBRK(I-1)=VALEUR
   Call SUMHRS([M:HRSES2]DEBTIM(I-1), [M:HRSES2]FINTIM(I-1), DIFF)
   [M:HRSES2]NBRHOU(I-1) =DIFF-VALEUR
  Endif
 Next
 Call APRES_NBLIG3
 Affzo [M:HRSES2]
Endif
End

Subprog REMP_JOURS(NBJOUR)
Value Integer NBJOUR
Local Date DATREF
Local Integer I, J
Local Decimal DIFF
#LIPET - 2017-05-10 - X3-34431 - START
# On prend toute la période
Local Integer NBJP
NBJP=([M:HRSES1]ENDDAT-[M:HRSES1]STRDAT)+1
#LIPET - 2017-05-10 - X3-34431 - END
If [M:HRSES2]NBLIG3=0
 Gosub CRE_JOURS
Else
 Gosub MOD_JOURS
Endif
Call APRES_NBLIG3
Affzo [M:HRSES2]
End

#**#####################################################################################
#* Si type de stage long, on ne crée pas autant de lignes que de jours : on ne crée qu'une ligne
#* avec date de fin = date de fin de stage
#*!
$CRE_JOURS
nolign=1
If [M:HRSES3]TYPSTG=1 Then
#LIPET - 2017-06-22 - X3-34431 - START
  #For I=0 To NBJOUR-1
  For I=0 To NBJP-1
#LIPET - 2017-06-22 - X3-34431 - END
   # LS 17/06/05
   If I>=dim([M:HRSES2]DAT)-1 : Break : Endif
   DATREF=[M:HRSES1]STRDAT+I
   If day$(DATREF)<>mess(6,742,1) & day$(DATREF)<>mess(7,742,1) :#Samedi & Dimanche
   #LIPET - 2017-06-22 - X3-34431 - START
   If nolign>dim([M:HRSES2]DAT) Then Break : Endif
   #LIPET - 2017-06-22 - X3-34431 - END
    [M:HRSES2]DAT(nolign-1)      = DATREF
    [M:HRSES2]DAY1(nolign-1)     = day$([M:HRSES2]DAT(nolign-1))
    [M:HRSES2]DEBTIM(nolign-1)   = [M:HRSES1]STRTIM
    [M:HRSES2]FINTIM(nolign-1)   = [M:HRSES1]ENDTIM
    [M:HRSES2]NBRTIMBRK(nolign-1)= [M:HRSES1]NBRHOUBRK
    If [M:HRSES2]FINTIM(nolign-1)<>""
     Call SUMHRS([M:HRSES2]DEBTIM(nolign-1), [M:HRSES2]FINTIM(nolign-1), DIFF)
     [M:HRSES2]NBRHOU(nolign-1) =DIFF-[M:HRSES2]NBRTIMBRK(nolign-1)
    Endif
    If [M:HRSES2]NBRJOU(nolign-1) = 0 : [M:HRSES2]NBRJOU(nolign-1) = 1 : Endif
    nolign+=1
   Endif
  Next
Elsif [M:HRSES3]TYPSTG=2 Then
  [M:HRSES2]DAT(0)      = [M:HRSES1]STRDAT
  [M:HRSES2]DATF(0)     = format$("D:"+GFMDAT, [M:HRSES1]ENDDAT)
  [M:HRSES2]NBRHOU(0)   = [F:STG]NBRHOUIPT
  [M:HRSES2]NBRHOUHTT(0)= 0
  nolign=2
Endif
[M:HRSES2]NBLIG3=nolign-1
Return

$MOD_JOURS
If [M:HRSES3]TYPSTG=1 Then
  If [M:HRSES2]NBLIG3<NBJOUR :# Je dois en ajouter
   J=[M:HRSES2]NBLIG3
   #LIPET - 2017-06-22 - X3-34431 - START
   #For I=0 To NBJOUR-1
   For I=0 To NBJP-1
   If J>=dim([M:HRSES2]DAT)-1 : Break : Endif : # JML 20/08/15 Also necessary here ! But better with J instead I
   #LIPET - 2017-06-22 - X3-34431 - END
    DATREF=[M:HRSES1]STRDAT+I
    If day$(DATREF)<>mess(6,742,1) & day$(DATREF)<>mess(7,742,1) :#Samedi & Dimanche
     If !find(DATREF,[M:HRSES2]DAT(0..J))
      [M:HRSES2]DAT(J)      = DATREF
      [M:HRSES2]DAY1(J)     = day$([M:HRSES2]DAT(J))
      [M:HRSES2]DEBTIM(J)   = [M:HRSES1]STRTIM
      [M:HRSES2]FINTIM(J)   = [M:HRSES1]ENDTIM
      [M:HRSES2]NBRTIMBRK(J)= [M:HRSES1]NBRHOUBRK
      If [M:HRSES2]FINTIM(J)<>""
       Call SUMHRS([M:HRSES2]DEBTIM(J), [M:HRSES2]FINTIM(J), DIFF)
       [M:HRSES2]NBRHOU(J) =DIFF-[M:HRSES2]NBRTIMBRK(J)
      Endif
      If [M:HRSES2]NBRJOU(J) =0 : [M:HRSES2]NBRJOU(J) = 1 : Endif
      J+=1
     Endif
    Endif
   Next
   [M:HRSES2]NBLIG3=J
   Sorta [M:HRSES2]NBLIG3 [M:HRSES2]NBLIG3 Order By DAT([S]indice)
  Else                     :# Je dois en enlever
    J=0
    For I=0 To [M:HRSES2]NBLIG3-1
     If [M:HRSES2]DAT(I)=[0/0/0] : Break : Endif
     If [M:HRSES2]DAT(I)<[M:HRSES1]STRDAT | [M:HRSES2]DAT(I)>[M:HRSES1]ENDDAT
      Dela I [M:HRSES2]NBLIG3
      J +=1
      I -=1 : # Car le Dela tasse les lignes vers le haut
     Endif
    Next
   [M:HRSES2]NBLIG3 -=J
  Endif
Elsif [M:HRSES3]TYPSTG=2 Then
  [M:HRSES2]DAT(0)      = [M:HRSES1]STRDAT
  [M:HRSES2]DATF(0)     = format$("D:"+GFMDAT, [M:HRSES1]ENDDAT)
  [M:HRSES2]NBRHOU(0)   = [F:STG]NBRHOUIPT
  [M:HRSES2]NBRHOUHTT(0)= 0
  [M:HRSES2]NBLIG3      = 1
Endif
Return

# Soit un formateur interne, soit un formateur externe, mais pas les deux
Subprog AS_TCHEMP(VALEUR)
Variable Char    VALEUR()

  Call AS_TCHEMP(VALEUR)From SUBSTG
End

######################################################################################
# SYMEU V6.1 Module Formation - Formateur interne
# Init_bouton de TCHEMP
######################################################################################
Subprog IB_TCHEMP
  If [M:HRSES1]DOM = "" Then
    Raz GBOUT2
  Endif
  If [M:HRSES1]THM = "" Then
    Raz GBOUT3
  Endif
End

######################################################################################
# Contrôle du formateur interne
# SYMEU V6.1 Module Formation - Formateur interne
######################################################################################
Subprog C_TCHEMP(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>"" Then
    Read [F:TRN]TRN2 = VALEUR
    If fstat Then
      # Formateur interne inexistant
      GMESSAGE = mess(106,10717,1)
      mkstat = 2 : End
    Endif
  Endif
End

#Si on change de formateur interne il faut modifier les montants de ces charges
Subprog AM_TCHEMP(VALEUR)
Variable Char    VALEUR()
Local Char CATFRT(GLONADI), CONTRAT(GLONHRCTR)
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Raz [M:HRSES1]CTRNUM
If VALEUR<>""
 Read [ID]ID0=VALEUR
 If !fstat & [F:ID]FLGMULCTR<>2
  #LIPET - 2017-11-28 - X3-66201 - START
  #Call CHERCHE_CTR(VALEUR,date$,CONTRAT) From DIVPAYE
  Call SEL_CTR(VALEUR,date$,CONTRAT) From DIVPAYE
  #LIPET - 2017-11-28 - X3-66201 - END
  # SYMEU V6.1 Module Formation - Formateur interne
  Local Char L_TCHEMP(GLONEML) : L_TCHEMP = [M:HRSES1]TCHEMP
  [M:HRSES1]TCHEMP = VALEUR
  Call C_CTRNUM(CONTRAT) From SUBHRSES
  If mkstat = 2 Then
    [M:HRSES1]TCHEMP = L_TCHEMP
    End
  Endif
  # SYMEU : fin
  [M:HRSES1]CTRNUM = CONTRAT
  Affzo [M:HRSES1]CTRNUM
  #LIPET - 2017-11-14 - START
  If func DIVPAYE.IS_KFR_LEG(GCURLEG) > 0 Then
  #LIPET - 2017-11-14 - END
  Call CAT2483(VALEUR,CONTRAT,CATFRT)From SUBDEM
  If CATFRT=""
   #Catégorie 2483 non définie
   #LIPET - 2017-06-22 - X3-34431 - START
     If func CHCK_CATFRT()>0
     #LIPET - 2017-06-22 - X3-34431 - END
      Call ERREUR (VALEUR-":"-mess(77,10717,1))From GESECRAN
     #LIPET - 2017-06-22 - X3-34431 - START
     Endif
   #LIPET - 2017-06-22 - X3-34431 - END
  Else
   # Si on change de formateur interne il faut modifier les montants de ces charges réelles.
   Call RECALCUL ([M:HRSES2]NBRHOUIPT, VALEUR,CONTRAT)
  Endif
 Endif
 Endif
 Call GRISE_CTRNUM([F:ID]FLGMULCTR)
 # SYMEU V6.1 Module Formation - Formateur interne : récupération du nom et prénom
 Gosub CHARGE_TRN
Else
 Call GRISE_CTRNUM(1)
 # SYMEU V6.1 Module Formation - Formateur interne : récupération du nom et prénom
 Raz [M:HRSES1]CTRNUM, NAM, SRN
 Affzo [M:HRSES1]CTRNUM, NAM, SRN
Endif
End

Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:HRSES1]CTRNUM
Else
 Diszo [M:HRSES1]CTRNUM
Endif
Affzo [M:HRSES1]CTRNUM
End

Subprog RECALCUL (NBRHRS, FORMATEUR,CONTRAT)
Value Decimal NBRHRS
Value Char FORMATEUR ()
Value Char CONTRAT
If clalev([F:ADI2])=0 : Local File ATABDIV     [ADI2] : Endif
Local Decimal TAUX
Local Integer I, FIRST_ERR_1, FIRST_ERR_2
#Coûts réels
FIRST_ERR_1=2 : FIRST_ERR_2=2
For I=0 To [M:HRSES4]NBLIG2-1
 Read[F:ADI2]CODE=10451;[M:HRSES4]TYPCRG2(I)
 # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUFOR, on calcule ou pas les coûts du formateur
 If GCALCOUFOR=2 Then
   If !fstat & [F:ADI2]N1<3 & [F:ADI2]N2=2     :#cout calculable pour formateur interne
    Call TAUX_HORAIRE (FORMATEUR,CONTRAT,[F:HRSES]ENDDAT,TAUX,[F:ADI2]N1,2,1) From TRTCOUT
    If !TAUX
#     If I=0 : # Pour ne pas afficher x fois le message
     If FIRST_ERR_1=2 : # Pour ne pas afficher x fois le message
      # Taux horaire total non défini
      Call ERREUR (FORMATEUR-":"-mess(78,10717,1))From GESECRAN
      FIRST_ERR_1=1
     Endif
    Else
     [M:HRSES4]CSTTOTIDV2(I)=arr(TAUX*NBRHRS,0.01) :# Nb d'heures imputables
    Endif
    Raz TAUX
    Call TAUX_HORAIRE (FORMATEUR,CONTRAT,[F:HRSES]ENDDAT,TAUX,[F:ADI2]N1,2,2) From TRTCOUT
    If !TAUX
#     If I=0  : # Pour ne pas afficher x fois le message
     If FIRST_ERR_2=2  : # Pour ne pas afficher x fois le message
      # Taux horaire imputable non défini
      Call ERREUR (FORMATEUR-":"-mess(79,10717,1))From GESECRAN
      FIRST_ERR_2=1
     Endif
    Else
     [M:HRSES4]CSTIPTIDV2(I)=arr(TAUX*NBRHRS,0.01) :# Nb d'heures imputables
    Endif
   Endif
 Endif
Next
Default Mask [M:HRSES4]
Call APRES_NBLIG2
Affzo [M:HRSES4]5-15
End

#LIPET - 2017-06-22 - X3-34431 - START
Subprog RECALCUL_NEW_REP (NBRHRS, FORMATEUR,CONTRAT)
Value Decimal NBRHRS
Value Char FORMATEUR ()
Value Char CONTRAT
If clalev([F:ADI2])=0 : Local File ATABDIV     [ADI2] : Endif
Local Decimal TAUX
Local Integer I, FIRST_ERR_1, FIRST_ERR_2
#Coûts réels
FIRST_ERR_1=2 : FIRST_ERR_2=2
For I=0 To [M:HRSES4]NBLIG2-1
 Read[F:ADI2]CODE=10451;[M:HRSES4]TYPCRG2(I)
 # Selon paramètre utilisateur CALCOUFOR, on calcule ou pas les coûts du formateur
 If (GCALCOUFOR=2 and [M]LNKREP(I)="")  or right$([M]LNKREP(I),len([M]LNKREP(I)))<>"D" Then

   If !fstat & [F:ADI2]N1<3 & [F:ADI2]N2=2     :#cout calculable pour formateur interne
    Call TAUX_HORAIRE (FORMATEUR,CONTRAT,[F:HRSES]ENDDAT,TAUX,[F:ADI2]N1,2,1) From TRTCOUT
    If !TAUX
     If FIRST_ERR_1=2 : # Pour ne pas afficher x fois le message
      # Taux horaire total non défini
      Call ERREUR (FORMATEUR-":"-mess(78,10717,1))From GESECRAN
      FIRST_ERR_1=1
     Endif
    Else
     [M:HRSES4]CSTTOTIDV2(I)=arr(TAUX*NBRHRS,0.01) :# Nb d'heures imputables
    Endif
    Raz TAUX
    Call TAUX_HORAIRE (FORMATEUR,CONTRAT,[F:HRSES]ENDDAT,TAUX,[F:ADI2]N1,2,2) From TRTCOUT
    If !TAUX
     If FIRST_ERR_2=2  : # Pour ne pas afficher x fois le message
      # Taux horaire imputable non défini
      Call ERREUR (FORMATEUR-":"-mess(79,10717,1))From GESECRAN
      FIRST_ERR_2=1
     Endif
    Else
     [M:HRSES4]CSTIPTIDV2(I)=arr(TAUX*NBRHRS,0.01) :# Nb d'heures imputables
    Endif
   Endif
 Endif
Next
Default Mask [M:HRSES4]
Call APRES_NBLIG2
Affzo [M:HRSES4]5-15
End
#LIPET - 2017-06-22 - X3-34431 - END

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local    Date    DATEREF
If [M:HRSES1]ENDDAT<>[0/0/0] Then
  DATEREF=[M:HRSES1]ENDDAT
Else
  DATEREF=date$
Endif
If [M:HRSES1]CTRNUM=""
 # SYMEU V6.1 Module Formation - Formateur interne : sélection des contrats du formateur
# Call SELCTR([M:HRSES1]TCHEMP,date$,date$,VALEUR) From DIVPAYE
 # FQ81085 - 20/09/13 - Sélection des contrats selon la date de fin de session
# Call SELCTRFOR([M:HRSES1]TCHEMP,date$,date$,VALEUR) From DIVPAYE
 Call SELCTRFOR([M:HRSES1]TCHEMP,DATEREF,DATEREF,VALEUR) From DIVPAYE
Endif
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
If [M:HRSES1]TCHEMP<>"" & VALEUR=""
 # Zone obligatoire
 GMESSAGE = mess(10,123,1)
 mkstat = 2 : End
Endif

#LIPET - X3-66089 - 2017-11-27 - START
 Call TEMP_CONTCTR([M:HRSES1]TCHEMP,VALEUR) From SUBSTG
#LIPET - X3-66089 - 2017-11-27 - END

If VALEUR<>"" and [M:HRSES1]TCHEMP<>"" Then
  # SYMEU V6.1 Module Formation - Formateur interne : contrôle que le contrat est saisi pour
  # le formateur et qu'il est actif
  Read [F:TRN]TRN1 = [M:HRSES1]TCHEMP;VALEUR
  If fstat Then
   # Le contrat n'est pas défini pour le formateur
   GMESSAGE = mess(102,10717,1)
   mkstat = 2 : End
  Elsif [F:TRN]ENAFLG = 1 Then
    # Le contrat pour le formateur interne n'est pas actif
    GMESSAGE = mess(99,10717,1)
    mkstat = 2 : End
  Endif
Endif
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    CATFRT(GLONADI)
  #LIPET - 2017-11-14 - START
  If func DIVPAYE.IS_KFR_LEG(GCURLEG) > 0 Then
  #LIPET - 2017-11-14 - END
    Call CAT2483([M:HRSES1]TCHEMP,VALEUR,CATFRT)From SUBDEM
    If CATFRT=""
     #Catégorie 2483 non définie
     #LIPET - 2017-06-22 - X3-34431 - START
     # FQ112804 - 27/11/15 - Pas si KPO
     If func CHCK_CATFRT()>0
     #LIPET - 2017-06-22 - X3-34431 - END
      Call ERREUR (VALEUR-":"-mess(77,10717,1))From GESECRAN
     #LIPET - 2017-06-22 - X3-34431 - START
     Endif
     #LIPET - 2017-06-22 - X3-34431 - END
    Else
     Call RECALCUL ([M:HRSES2]NBRHOUIPT,[M:HRSES1]TCHEMP,VALEUR)
    Endif
  Endif
End


Subprog AS_TYPFRT(VALEUR)
Variable Integer VALEUR
# MABON - 03/09/10 - Le flag DIF disparaît, le DIF peut donc revenir dans la liste déroulante
# En revanche, la Période de professionnalisation et l'Alternance sont retirées
#GMENLOC(3) = 1
# FQ72840 - MABON 31/03//11 - Finalement, on ne les retire pas
#GMENLOC(4) = 1
#GMENLOC(6) = 1
End

######################################################################################
## Etiquette Ecrans [M:HRSES2] (Nb de jours)
######################################################################################

#Jour
Subprog AS_DAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
If nolign-1>0
 If day$([M:HRSES2]DAT(nolign-2)+1)=mess(6,742,1) :#Samedi
  VALEUR=[M:HRSES2]DAT(nolign-2)+3
 Elsif day$([M:HRSES2]DAT(nolign-2)+1)=mess(7,742,1) :#Dimanche
  VALEUR=[M:HRSES2]DAT(nolign-2)+2
 Else
  VALEUR=[M:HRSES2]DAT(nolign-2)+1
 Endif
Else
 If day$([M:HRSES1]STRDAT)=mess(6,742,1) :#Samedi
  VALEUR=[M:HRSES1]STRDAT+2
 Elsif day$([M:HRSES1]STRDAT)=mess(6,742,1) :#Dimanche
  VALEUR=[M:HRSES1]STRDAT+1
 Else
  VALEUR=[M:HRSES1]STRDAT
 Endif
Endif
End

Subprog AM_DAT(VALEUR)
Variable Date     VALEUR
[M]DAY1(nolign-1) = day$(VALEUR)
#If find(GREP,'C','D')>0 Then
  Call LECTURE("STG", [M:HRSES0]STG, "") From CONTOBJ
  If ([F:STG]TYPSTG=2) or ([M:HRSES3]TYPSTG=2) Then
    [M:HRSES2]DATF(0) = format$("D:"+GFMDAT, [M:HRSES1]ENDDAT)
  Endif
#Endif
End

Subprog C_DAT(VALEUR)
Variable Date     VALEUR
If VALEUR<[M:HRSES1]STRDAT |VALEUR>[M:HRSES1]ENDDAT
 #Date en dehors de la période de la session
 GMESSAGE=mess(8,10717,1) : mkstat=2 : End
Endif
Call UNICITE(VALEUR,[M]DAT(0..[M]NBLIG3-1)) From OBJDIV
If mkstat=2 : End : Endif
End

#Heure de début
Subprog AS_DEBTIM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 If nolign-1>0
  VALEUR=[M:HRSES2]DEBTIM(nolign-2)
 Else
  VALEUR=[M:HRSES1]STRTIM
 Endif
Endif
End

Subprog AM_DEBTIM(VALEUR)
Variable Char    VALEUR()
Local Decimal DIFF
If [M:HRSES2]FINTIM(nolign-1)<>""
 Call SUMHRS(VALEUR, [M:HRSES2]FINTIM(nolign-1), DIFF)
 [M:HRSES2]NBRHOU(nolign-1) =DIFF-[M:HRSES2]NBRTIMBRK(nolign-1)
 Affzo  [M:HRSES2]NBRHOU(nolign-1)
Endif
End

#Heure de fin
Subprog AS_FINTIM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 If nolign-1>0
  VALEUR=[M:HRSES2]FINTIM(nolign-2)
 Else
  VALEUR=[M:HRSES1]ENDTIM
 Endif
Endif
End

Subprog C_FINTIM(VALEUR)
Variable Char    VALEUR()
Local Integer MINUIT
If val(VALEUR)=0 : MINUIT=2400 : Else : MINUIT=val(VALEUR) : Endif
If VALEUR<>"" & MINUIT<=val([M:HRSES2]DEBTIM(nolign-1))
 #Heure incorrecte
 GMESSAGE = mess(69,134,1)
 mkstat = 2 : End
Endif
End

Subprog AM_FINTIM(VALEUR)
Variable Char    VALEUR()
Local Decimal DIFF
If VALEUR<>""
 Call SUMHRS([M:HRSES2]DEBTIM(nolign-1), VALEUR, DIFF)
 [M:HRSES2]NBRHOU(nolign-1) =DIFF-[M:HRSES2]NBRTIMBRK(nolign-1)
 Affzo  [M:HRSES2]NBRHOU(nolign-1)
Endif
End

#Temps de pause
Subprog AS_NBRTIMBRK(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 If nolign-1>0
  VALEUR=[M:HRSES2]NBRTIMBRK(nolign-2)
 Else
  VALEUR=[M:HRSES1]NBRHOUBRK
 Endif
Endif
End

#Temps de pause
Subprog C_NBRTIMBRK(VALEUR)
Variable Decimal VALEUR
Local Decimal DIFF
Call SUMHRS([M:HRSES2]DEBTIM(nolign-1), [M:HRSES2]FINTIM(nolign-1), DIFF)
If VALEUR & VALEUR>=DIFF
 #Temps de pause supérieur ou égal à la durée de la session
 GMESSAGE=mess(73,10717,1)
 mkstat=2 : End
Endif
End

Subprog AM_NBRTIMBRK(VALEUR)
Variable Decimal VALEUR
Local Decimal DIFF
If [M:HRSES2]FINTIM(nolign-1)<>""
 Call SUMHRS([M:HRSES2]DEBTIM(nolign-1), [M:HRSES2]FINTIM(nolign-1), DIFF)
 [M:HRSES2]NBRHOU(nolign-1)=DIFF-VALEUR
 Affzo  [M:HRSES2]NBRHOU(nolign-1)
Endif
End

#nb heure
Subprog AS_NBRHOU(VALEUR)
Variable Decimal VALEUR
Local Decimal DIFF
If VALEUR=0
 If [M:HRSES2]FINTIM(nolign-1)<>""
  Call SUMHRS([M:HRSES2]DEBTIM(nolign-1), [M:HRSES2]FINTIM(nolign-1), DIFF)
  VALEUR=DIFF-[M:HRSES2]NBRTIMBRK(nolign-1)
 Elsif nolign-1>0
   VALEUR=[M:HRSES2]NBRHOU(nolign-2)
 Endif
Else
 # valeur calculée
 If [M:HRSES2]FINTIM(nolign-1)<>"" & [M:HRSES3]TYPSTG<>2
  mkstat=2 : End
 Endif
Endif
End

#nb jour
Subprog AS_NBRJOU(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 If nolign-1>0
  VALEUR=[M:HRSES2]NBRJOU(nolign-2)
 Else
  VALEUR=1
 Endif
Endif
End

Subprog C_NBRJOU(VALEUR)
Variable Decimal VALEUR
If VALEUR>1
 #Pas plus de 1 jour par journée calendaire
 GMESSAGE=mess(63,10717,1)  : mkstat=2 : End
Endif
End

# FQ72047 - MABON 03/03/11 - On ne peut pas insérer de ligne dans le cas des autres stages
Subprog C_NBLIG3

  If status=73 Then
    Call LECTURE("STG", [M:HRSES0]STG, "") From CONTOBJ
    If !fstat & [F:STG]TYPSTG=2 & [M:HRSES2]NBLIG3=1 Then
      GMESSAGE=mess(230,10717,1) : # Impossible d'ajouter une date pour un stage de ce type
      mkstat = 2
    Endif
  Endif
End

#Totaux durée en heures et jours
Subprog APRES_NBLIG3
Local Integer I
Raz[M:HRSES2]NBRDAY
#LIPET - 2017-06-22 - X3-34431 - START
Raz[M:HRSES2]NBRNGT
#LIPET - 2017-06-22 - X3-34431 - END
Raz[M:HRSES2]NBRHOUIPT
Raz[M:HRSES2]NBRHOUIPTHTT
For I=0 To [M:HRSES2]NBLIG3
 [M:HRSES2]NBRDAY       += [M:HRSES2]NBRJOU(I)
 [M:HRSES2]NBRHOUIPT    += [M:HRSES2]NBRHOU(I)
 [M:HRSES2]NBRHOUIPTHTT += [M:HRSES2]NBRHOUHTT(I)
Next
#LIPET - 2017-06-22 - X3-34431 - START
[M:HRSES2]NBRNGT= func SUBHRSES.CALCULATE_NBNIGHT([M:HRSES3]TYPSTG, [M:HRSES2]NBLIG3,"[M:HRSES2]")
#LIPET - 2017-06-22 - X3-34431 - END
Affzo[M:HRSES2]NBRDAY, NBRHOUIPT, NBRHOUIPTHTT
#LIPET - 2017-06-22 - X3-34431 - START
# Si le stage n'est pas renseigné, on met à jour le nombre d'heures et jours de l'onglet Organisation
  If [M:HRSES0]STG="" Then
  [M:HRSES3]NBRDAYSTG = [M:HRSES2]NBRDAY
  [M:HRSES3]NBRHOUSTG = [M:HRSES2]NBRHOUIPT
  Affzo [M:HRSES3]NBRDAYSTG, NBRHOUSTG
Endif
#LIPET - 2017-06-22 - X3-34431 - END
#Si on change le nb d'heures il faut modifier les montants des charges prev du formateur interne.
If [M:HRSES1]TCHEMP<>""
 Call RECALCUL ([M:HRSES2]NBRHOUIPT, [M:HRSES1]TCHEMP,[M:HRSES1]CTRNUM)
Endif
End

Subprog B1_NBRHOU(VALEUR)
Variable Decimal VALEUR
Local Integer ZONE
ZONE=1
Goto B1_NBR

Subprog B1_NBRJOU(VALEUR)
Variable Decimal VALEUR
Local Integer ZONE
ZONE=2
Goto B1_NBR

Subprog B1_DEBTIM(VALEUR)
Variable Char    VALEUR()
Local Integer ZONE
ZONE=3
Call CONTHM(VALEUR)From OBJDIV
Goto B1_NBR

Subprog B1_FINTIM(VALEUR)
Variable Char    VALEUR()
Local Integer ZONE
ZONE=4
Call CONTHM(VALEUR)From OBJDIV
Goto B1_NBR

Subprog B1_NBRTIMBRK(VALEUR)
Variable Decimal    VALEUR()
Local Integer ZONE
ZONE=5
Goto B1_NBR

$B1_NBR
Local Decimal DIFF
NOL = nolign-1
For I=NOL To [M:HRSES2]NBLIG3-1
 Case ZONE
  When 1 : [M:HRSES2]NBRHOU(I)=VALEUR
  When 2 : [M:HRSES2]NBRJOU(I)=VALEUR
  When 3 : Call SUMHRS(VALEUR, [M:HRSES2]FINTIM(I), DIFF)
           If DIFF-[M:HRSES2]NBRTIMBRK(I)>0
            [M:HRSES2]NBRHOU(I)=DIFF-[M:HRSES2]NBRTIMBRK(I)
            [M:HRSES2]DEBTIM(I)=VALEUR
           Endif
  When 4 : Call SUMHRS([M:HRSES2]DEBTIM(I),VALEUR, DIFF)
           If DIFF-[M:HRSES2]NBRTIMBRK(I)>0
            [M:HRSES2]NBRHOU(I)=DIFF-[M:HRSES2]NBRTIMBRK(I)
            [M:HRSES2]FINTIM(I)=VALEUR
           Endif
  When 5 : Call SUMHRS([M:HRSES2]DEBTIM(I),[M:HRSES2]FINTIM(I), DIFF)
           If DIFF-VALEUR>0
            [M:HRSES2]NBRHOU(I)=DIFF-VALEUR
            [M:HRSES2]NBRTIMBRK(I)=VALEUR
           Endif
 Endcase
Next
Call APRES_NBLIG3
Affzo [M:HRSES2]
End


