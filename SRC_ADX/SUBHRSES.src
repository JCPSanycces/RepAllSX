#LIPET - 2017-06-22 - X3-34431 - START
Funprog CALCULATE_NBNIGHT(TYPSTG,NBLIG,ABRMSK)
Value Integer TYPSTG
Value Integer NBLIG
Value Char    ABRMSK()
Local Integer RES
Local Integer WDIM,WNBLIG,WNBLIG2
WDIM=NBLIG
Local Date WTABDAT (0..WDIM)
Local Date WDATMSK
RES=0
If TYPSTG=1  #Stage court
 WNBLIG=0
 WNBLIG2=0
 While WNBLIG <= NBLIG
   WDATMSK= evalue(ABRMSK+"DAT(WNBLIG)")
   If WDATMSK > [0/0/0]
     WTABDAT(WNBLIG2)=WDATMSK
     WNBLIG2+=1
   Endif
   WNBLIG+=1
 Wend
 If WNBLIG2 > 0
   Sorta WNBLIG2 WTABDAT Order By WTABDAT(indice)
   For WNBLIG=1 To WNBLIG2
     If WNBLIG=WNBLIG2 : Break : Endif
     If WTABDAT(WNBLIG-1)+1 = WTABDAT(WNBLIG)
        RES+=1
     Endif
   Next
 Endif
Endif
End RES
#LIPET - 2017-06-22 - X3-34431 - END

#END  REPARTITION
#LIPET - 2017-06-22 - X3-34431 - START
Subprog B2_NBLIG

  Call DELETE_MANUAL() From TRTCOUT
  Call CSTMOY([M:HRSES3]NBLIG)From TRTCOUT
  If GREP=""
    mkstat=4
    # lost focus on table so we need to force
    Local Integer LIN
    LIN=min(nolign-1,[M:HRSES3]NBLIG)
    # lost focus on table so we need to force
    zonsui="NBLIG("+num$(LIN)+")"
  Endif

End
#LIPET - 2017-06-22 - X3-34431 - END

