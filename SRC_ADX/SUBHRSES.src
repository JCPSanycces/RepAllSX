$BB1_NBLIG4
Raz [M:HRSES5]
If [M:HRSES4]NBLIG5>0 Then
  For I= 0 To [M:HRSES4]NBLIG5-1
    [M:HRSES4]TYPCRG3(I)=""   : [M:HRSES4]TYPFIN3(I)=""   : [M:HRSES4]CPLCOU3(I)=""
    [M:HRSES4]CSTTOTIDV3(I)=0 : [M:HRSES4]CSTIPTIDV3(I)=0
  Next
  [M:HRSES4]NBLIG5=0
Endif
