############################################################################################################
#                                    COUTS REELS FORMATEUR INTERNE
############################################################################################################

#Type de frais
#On autorise uniquement la saisie des coûts de type "Formateur"

Subprog C_TYPCRG2(VALEUR)
Variable Char    VALEUR()
If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
Read[F:ADI]CODE=10451;VALEUR
If !fstat & [F:ADI]N2<>2
 GMESSAGE=VALEUR-":"-mess(35,10717,1)-mess(34,10717,1) :#Type de coût non autorisé au niveau Session
 mkstat=2 : End
Endif
End

Subprog AS_TYPFIN2(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & nolign>1
 VALEUR = [M]TYPFIN2(nolign-2)
Endif
End

Subprog AS_ORGFIN2(VALEUR)
Variable Char    VALEUR()
#--SEGAY  STA_EXI 66191 LOT 1
#If VALEUR="" & nolign>1
# VALEUR = [M]ORGFIN2(nolign-2)
#Endif
# Non saisi
If VALEUR=""
  If nolign>1
    VALEUR = [M]ORGFIN2(nolign-2)
  Else
    If dim(GOFIDEF )>0 Then
      VALEUR = GOFIDEF
    Endif
  Endif
Endif
#--END_EXI 66191 LOT 1

End

Subprog C_ORGFIN2(VALEUR)
Variable Char    VALEUR()
# On teste l'unicité de la ligne sur les zones : TYPCRG/TYPFIN/ORGFIN
Local Integer I, OK
OK = 1
For I=0 To nolign-2
 If [M]TYPCRG2(I)=[M]TYPCRG2(nolign-1) & [M]TYPFIN2(I)=[M]TYPFIN2(nolign-1) & [M]ORGFIN2(I)=VALEUR
  OK = 0 : Break
 Endif
Next
If OK=1
 For I=nolign To [M:HRSES4]NBLIG2-1
  If [M]TYPCRG2(I)=[M]TYPCRG2(nolign-1) & [M]TYPFIN2(I)=[M]TYPFIN2(nolign-1) & [M]ORGFIN2(I)=VALEUR
   OK = 0 : Break
  Endif
 Next
Endif
If OK=0
 # Ligne de coût déjà existante en ligne xx
 GMESSAGE = mess(84,10717,1)-num$(I+1)
 mkstat = 2 : End
Endif
End

