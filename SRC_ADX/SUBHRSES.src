Read [F:HRSES]SES0=[M:HRSES0]COD
Return

######################################################################################
$SELSES
If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
If clalev([F:TSE])=0 : Local File TMPSES   [TSE] : Endif
Gosub CHARGE_TSE
Link [F:TSE] With [F:HRSES]SES0=[F:TSE]COD As [TS_]
Default File [TS_]
#Default File [HRSES]
Call SELOBJ("SE2",OPTIONS,NBCOL,COL,TIT) From CONTOBJ
If PARAM(1)<>""
 CRITERE(1) = "[F:HRSES]STG='"+PARAM(1)+"'"
Endif
Gosub SELSES_EXPSTART
# Sessions non clôturées si PARAM(2)="1"
If PARAM(2)="1"
 If CRITERE(1)<>"" : CRITERE(1) -= "&" : Endif
 CRITERE(1) -= "[F:HRSES]FLGCLO<>"+num$(2)
Endif
# FQ86194 - MABON 07/02/13 - Pour permettre l'ajout d'un critère supplémentaire en sélection
If PARAM(4)<>""
 If CRITERE(1)<>"" : CRITERE(1) -= "&" : Endif
 CRITERE(1) -= PARAM(4)
Endif
# Fin MABON
ORDRE = "[F:HRSES]COD"

Return
###################################################################
#SBA 08/06/2012
$SELSES_EXPSTART
If(CRITERE(1)="" & VALEUR<>"")
 CRITERE(1) -= "COD>='"+VALEUR+"'"
Endif
Return
######################################################################################
$SELSESINC
  If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
  If clalev([F:TSE])=0   : Local File TMPSES   [TSE]   : Endif
  Gosub CHARGE_TSE
  Link [F:TSE] With [F:HRSES]SES0=[F:TSE]COD As [TS_]
  Default File [TS_]
  Call SELOBJ("SE2",OPTIONS,NBCOL,COL,TIT) From CONTOBJ
  If PARAM(1)<>"" Then
    CRITERE(1) = "STG='"+PARAM(1)+"'"
  Endif
  If CRITERE(1)<>"" Then CRITERE(1) -= "&" : Endif
  CRITERE(1) -= "FLGCLO<>2 & [F:TSE]NBRINS<[F:HRSES]NBRPRTMAX & [F:HRSES]COD<>'"+[M:HRSES0]COD+"'"
  ORDRE = "[F:HRSES]COD"
Return

######################################################################################
$SELSESSTG

  If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
  If clalev([F:TSE])=0   : Local File TMPSES   [TSE]   : Endif
  Gosub CHARGE_TSE
  Link [F:TSE] With [F:HRSES]SES0=[F:TSE]COD As [TS_]
  Default File [TS_]
  Call SELOBJ("SE2",OPTIONS,NBCOL,COL,TIT) From CONTOBJ
  If PARAM(1)<>"" Then
    CRITERE(1) = "STG>='"+PARAM(1)+"'"
  Endif
  If PARAM(2)<>"" Then
    If CRITERE(1)<>"" Then CRITERE(1) -= "&" : Endif
    CRITERE(1) -= "STG<='"+PARAM(2)+"'"
  Endif
  ORDRE = "[F:HRSES]COD"
Return


Subprog SUMHRS(DEBUT, FIN, SUMHRS)
Value Char DEBUT ()
Value Char FIN()
Variable Decimal SUMHRS
Local Decimal VALHMDEB, VALHMFIN
Call CONVERTHM(DEBUT,VALHMDEB)
Call CONVERTHM(FIN,VALHMFIN)
If VALHMDEB<=VALHMFIN
 SUMHRS = VALHMFIN-VALHMDEB
Else
 SUMHRS = 24-VALHMDEB+VALHMFIN
Endif
End

Subprog CONVERTHM(VALEUR,NBHEURE)
Value Char VALEUR ()
Variable Decimal NBHEURE
Local Integer HH, MM
Call CONTHM(VALEUR) From OBJDIV
HH=val(left$(VALEUR,2))
MM=val(right$(VALEUR,3))
NBHEURE=((HH*60)+MM)/60
End

#**#####################################################################################
#* MABON - 23/08/10
#* Dans le cadre d'un stage long, on ne peut avoir qu'une seule ligne dans le calendrier
#*!
Subprog AS_NBLIG3

  Call LECTURE("STG",[M:HRSES0]STG,"") From CONTOBJ
  If ([F:STG]TYPSTG=2) or ([M:HRSES3]TYPSTG=2)Then
    If [M:HRSES2]NBLIG3=1 and nolign=2 Then
      mkstat=2
    Endif
  Endif
End

#**#####################################################################################
#* MABON - 26/08/10 - Vérification unicité des ressources
#*!
Subprog C_RSCNEC(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" Then mkstat=2 : Endif
  Call UNICITE(VALEUR, [M:HRSES3]RSCNEC(0..[M:HRSES3]NBRSC-1)) From OBJDIV :#FQ99891 declare [M:HRSES3]NBRSC
End

#**#####################################################################################
#* MABON - 26/08/10 - Si le stage est renseigné, on ne peut plus modifier le type de
#* stage dans la session
#*!
Subprog AS_TYPSTG(VALEUR)
Variable Integer VALEUR

  If [M:HRSES0]STG<>"" Then mkstat=2 Endif
  GMENLOC(3)=1
End

#**#####################################################################################
#* FQ71518 - MABON 28/02/11
#* On ne peut pas changer le type de stage s'il existe au moins une inscription à une session
#* rattachée au stage
#*!
Subprog C_TYPSTG(VALEUR)
Variable Integer VALEUR

  If [M:HRSES3]TYPSTG<>VALEUR Then
    If clalev([F:INS])=0 : Local File INSCRIPT [INS] : Endif
    Filter [F:INS] Where SES=[M:HRSES0]COD
    If rowcount([F:INS])>0 Then
      mkstat=2
    Endif
    Filter [F:INS]
  Endif
End

#**#####################################################################################
#* MABON - 26/08/10 - La 1ère colonne a un intitulé évalué selon qu'on a un stage court
#* ou un autre stage. Et selon le type du stage, des colonnes apparaissent ou disparaissent
#* dans l'onglet Calendrier
#*!
Subprog AM_TYPSTG(VALEUR)
Variable Integer VALEUR
Local    Integer NBJ
Local    Date    D
 Call INIT_COL(VALEUR)
  # FQ71518 - MABON 28/02/11 - Si on modifie le type du stage, on doit modifier le calendrier
  If VALEUR=2 Then
    Call AS_DAT([M:HRSES2]DAT)
    [M:HRSES2]DATF(0) = format$("D:"+GFMDAT, [M:HRSES1]ENDDAT)
    [M:HRSES2]NBLIG3=1
    Affzo [M:HRSES2]
  Else
    NBJ=0
    D=[M:HRSES1]STRDAT
    While D<=[M:HRSES1]ENDDAT
      #LIPET - 2017-06-22 - X3-34431 - START
      If !find(dayn(D),6,7) Then : # Samedi | Dimanche
      #LIPET - 2017-06-22 - X3-34431 - END
        NBJ += 1
      #LIPET - 2017-06-22 - X3-34431 - START
      Endif
      #LIPET - 2017-06-22 - X3-34431 - END
      D += 1
    Wend
    [M:HRSES3]TYPSTG=VALEUR
    Call REMP_JOURS(NBJ)
  Endif
End

#**#####################################################################################
#* MABON - 26/08/10 - Si le stage est renseigné, on ne peut plus modifier le nombre de jours
#*!
Subprog AS_NBRDAYSTG(VALEUR)
Variable Decimal VALEUR

  If [M:HRSES0]STG<>""  Then mkstat=2 : Endif
  If [M:HRSES3]TYPSTG=2 Then mkstat=2 : Endif
End

#**#####################################################################################
#* MABON - 26/08/10 - Si le stage est renseigné, on ne peut plus modifier le nombre d'heures
#*!
Subprog AS_NBRHOUSTG(VALEUR)
Variable Decimal VALEUR

  If [M:HRSES0]STG<>"" Then mkstat=2 Endif
End

#**#####################################################################################
#* MABON - 26/08/10 - Récupération des Nom/Prénom du chargé administratif de la session
#*!
Subprog AM_REFNUMRH(VALEUR)
Variable Char    VALEUR()

  Call CHARGE_NUMRH(VALEUR)
End

#**#####################################################################################
#* MABON - 30/08/10 - On ne peut avoir que les lignes calculées dans le tableau des montants
#* suivis : on ne peut pas en ajouter
#*!
Subprog AS_NBAMT

  If nolign=[M:HRSES6]NBAMT+1 Then
    mkstat=2
  Endif
End


#**
#* On ne peut reporter une inscription sur une autre session que si l'inscription n'est ni Confirmée, ni Clôturée
#*
#* @param VALEUR
#*!
Subprog AS_NEWSES(VALEUR)
Variable Char    VALEUR()
Local    Integer J

  Read [F:INS]INS0=[M:HRSES0]STG;[M:HRSES0]COD;[M:HRSES5]REFNUM(nolign-1)
  If !fstat Then
    # FQ72746 - MABON 29/03/11 - L'inscription peut être Saisie ou En cours
#    If [F:INS]STA<>1 Then
    If !find([F:INS]STA,1,2) Then
      mkstat=2
    Endif
    If [F:INS]UPDCPC=2 | [F:INS]UPDHAB=2 Then : # Compétences ou habilitations mises à jour
      Call OUINON(mess(194,10717,1)+chr$(10)+mess(197,10717,1),J) From GESECRAN : # Les compétences et/ou les habilitations ont été mises à jour depuis cette inscription. Confirmez-vous le report ?
      If J=1 Then
        mkstat=1
      Endif
    Endif
    If [F:INS]TRFTPS=2 | [F:INS]TRFREQ=2 Then : # Transféré temps ou hors temps
      Call OUINON(mess(196,10717,1)+chr$(10)+mess(197,10717,1),J) From GESECRAN : # L'arrêté de formation a été effectué sur cette inscription. Confirmez-vous le report ?
      If J=1 Then
        mkstat=1
      Endif
    Endif
  Endif
End

Subprog C_NEWSES(VALEUR)
Variable Char    VALEUR()

  If VALEUR<>"" Then
    If clalev([F:SESC])=0 : Local File SESSIONS [SESC] : Endif
    If clalev([F:TSEC])=0 : Local File TMPSES   [TSEC] : Endif
    Read [F:SESC]SES0=VALEUR
    If !fstat Then
      Read [F:TSEC]TSE1=[M:HRSES0]STG;VALEUR
      If ([F:SESC]STG<>[M:HRSES0]STG) Then
        GMESSAGE=mess(30,10717,1)-[M:HRSES0]STG : # Cette session ne dépend pas du stage
        mkstat=2
      Endif
      If ([F:SESC]FLGCLO=2) Then
        GMESSAGE=mess(145,10717,1) : # Cette session est clôturée
        mkstat=2
      Endif
      If ([F:TSEC]NBRINS>=[F:SESC]NBRPRTMAX) Then
        GMESSAGE=mess(146,10717,1) : # Cette session est complète
        mkstat=2
      Endif
    Else
      mkstat=2
    Endif
  Endif
End

# Déplacé dans TOOLSVAR
