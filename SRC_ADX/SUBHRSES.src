###  COUTS PREVISIONNELS

## Type de frais
## On interdit la saisie des coûts de type "Participant" et "Formateur"

Subprog C_TYPCRG(VALEUR)
Variable Char    VALEUR()
Local Integer K
If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
Read[F:ADI]CODE=10451;VALEUR
# FQ71112 - MABON 01/02/11 - On interdit les coûts non calculés, qu'ils soient Participants, Formateurs ou Autres
#If !fstat & [F:ADI]N1<3 & ([F:ADI]N2=1 | [F:ADI]N2=2)
If !fstat & [F:ADI]N1<3
 If GFONCTION="GESHRSES" :  K=34 : Else :  K=33 : Endif
 GMESSAGE=VALEUR-":"-mess(35,10717,1)-mess(K,10717,1) :# Type de coût non autorisé au niveau stage / session
 mkstat=2 : End
Else
# SEGAY 81085 US 460
  Local Integer INDEX : INDEX=1
  Local Integer WOK : WOK=1
#  Call CHECKLEG_CRGFIN(VALEUR,[M:HRSES3]TYPFIN(nolign-1),INDEX)From SUBSTG
  If dim([M:HRSES0]LEG)>0
#    Call CHECKLEG_CRGFINOFT(VALEUR,INDEX,1,[M]WLEGLIG(nolign-1),WOK) From SUBSTG
    Call CHECKLEG_LIGCOST(VALEUR,[M:HRSES3]TYPFIN(nolign-1),[M:HRSES3]ORGFIN(nolign-1),INDEX,1,[M]WLEGLIG(nolign-1),WOK) From SUBSTG
  Endif
Endif
End

