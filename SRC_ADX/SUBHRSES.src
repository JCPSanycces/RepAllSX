#      LIS_CPY(I)=[F:AGC]CPY
#      I += 1
#    Endif
#  Next
#End

#**
#* Vérification des autorisations sites et sociétés pour le profil
#*
#* @param CPYPLF : société du plan
#* @param FCYPLF : site du plan
#*!
Funprog GET_AUZ(CPYPLF, FCYPLF, AFNC)
Value Char    CPYPLF, FCYPLF, AFNC
Local Char    LIS_CPY(GLONCPY)(0..100), LIS_FCY(GLONFCY)(0..100)
Local Integer I, J, ICPY, IFCY, AUZCFY

  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
  If clalev([F:AFP])=0 : Local File AFCTPRF  [AFP] : Endif
  If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
  If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif

  I=0 : J=0
  # On sélectionne les habilitations dont l'accès est à Oui pour le profil du user pour cette fonction
  For [F:AFP] Where PRFCOD=GPROFIL & FNC=AFNC & ACS=2
    If [F:AFP]FCYGRUCOD=1 Then : # Regroupement
      I=0 : Call CALC_GRPCPY([F:AFP]FCYGRU, LIS_CPY, I) From TOOLSVAR
#      For [F:AGC] Where CPY=[F:AFP]FCYGRU : # Recherche dans les groupes de sociétés
#        If !find([F:AGC]CPY, LIS_CPY) Then
#          LIS_CPY(I)=[F:AGC]CPY
#          I += 1
#        Endif
#      Next

      For [F:FGR] Where CPY=[F:AFP]FCYGRU : # Recherche dans les groupes de sites
        If !find([F:FGR]FCY, LIS_FCY) Then
          LIS_FCY(J)=[F:FGR]FCY
          J += 1
        Endif
      Next
    Else : # Site unique
      If !find([F:AFP]FCYGRU, LIS_FCY) Then
        LIS_FCY(J)=[F:AFP]FCYGRU
        J += 1
      Endif
    Endif
  Next
  ICPY = I-1 : IFCY = J-1

  AUZCFY=2
  If ICPY>=0 & !find(CPYPLF, LIS_CPY) Then AUZCFY=1 Endif
  If IFCY>=0 & !find(FCYPLF, LIS_FCY) Then AUZCFY=1 Endif

  If AUZCFY=2 & CPYPLF<>"" & IFCY>=0 Then
    AUZCFY=1
    For I=0 To IFCY
      Read [F:FCY]FCY0=LIS_FCY(I)
      If !fstat Then
#        If [F:FCY]LEGCPY=CPYPLF Then AUZCFY=2 : Break : Endif
        If find([F:FCY]LEGCPY,LIS_CPY)>0 Then AUZCFY=2 : Break : Endif
      Endif
    Next
  Endif

  If AUZCFY=2 & FCYPLF<>"" & ICPY>=0 Then
    AUZCFY=1
    For I=0 To ICPY
      Read [F:FCY]FCY1=LIS_CPY(I);FCYPLF
      If !fstat Then AUZCFY=2 : Break : Endif
    Next
  Endif
End AUZCFY

# FQ72861 - MABON 12/04/11 - Mise à jour de la ligne de total : Total - Anicenne valeur + Nouvelle valeur
Subprog AM_FINAMT(VALEUR)
Variable Decimal VALEUR

  [M:HRSES6]FINAMT([M:HRSES6]NBAMT-1)=[M:HRSES6]FINAMT([M:HRSES6]NBAMT-1)-[M:HRSES6]FINAMT(nolign-1)+VALEUR
  Affzo [M:HRSES6]FINAMT([M:HRSES6]NBAMT-1)
End

# FQ72861 - MABON 12/04/11 - Mise à jour de la ligne de total : Total - Anicenne valeur + Nouvelle valeur
Subprog AM_VERAMT(VALEUR)
Variable Decimal VALEUR

  [M:HRSES6]VERAMT([M:HRSES6]NBAMT-1)=[M:HRSES6]VERAMT([M:HRSES6]NBAMT-1)-[M:HRSES6]VERAMT(nolign-1)+VALEUR
  Affzo [M:HRSES6]VERAMT([M:HRSES6]NBAMT-1)
End

# FQ72861 - MABON 12/04/11 - Mise à jour de la ligne de total : Total - Anicenne valeur + Nouvelle valeur
Subprog AM_REMAMT(VALEUR)
Variable Decimal VALEUR

  [M:HRSES6]REMAMT([M:HRSES6]NBAMT-1)=[M:HRSES6]REMAMT([M:HRSES6]NBAMT-1)-[M:HRSES6]REMAMT(nolign-1)+VALEUR
  Affzo [M:HRSES6]REMAMT([M:HRSES6]NBAMT-1)
End


######################################################################################
# FQ78431 - 09/04/13 - Ajout tableau pour création inscriptions manuelles
Subprog AM_REFNUMD(VALEUR)
Variable Char    VALEUR()
Local    Char    CONTRAT(GLONHRCTR)

  If VALEUR<>"" Then
    # FQ97638 - 21/03/14 - Si on le laisse dans AS_NBLIGD, on a ce message dès qu'on enregistre la session, même si on n'a pas
    # touché à ce tableau
    If clalev([F:INS2])=0 : Local File INSCRIPT [INS2] : Endif
    Filter [F:INS2] Where SES=[F:HRSES]COD & STA=1
    If rowcount([F:INS2])+[M:HRSES5]NBLIGD>=[M:HRSES3]NBRPRTMAX
      # Nombre de participants maximum atteint pour la session
      GMESSAGE=mess(36,10717,1)
      mkstat=2 : End
    Endif
    Filter [F:INS2]
    #ADNGO - 2017-12-04 - X3-29544 - START
    #If [M:HRSES0]LEG="FRA" & ([M:HRSES1]NATFIS=len(mess(0,10452,1)) | [M:HRSES1]CATACN=len(mess(0,10453,1)) | [M:HRSES1]TYPFRT=len(mess(0,10455,1))) Then
    #If [M:HRSES0]LEG="FRA" & ([M:HRSES1]NATFIS='' | [M:HRSES1]CATACN='' | [M:HRSES1]TYPFRT='') Then
    If [M:HRSES1]NATFIS='' | [M:HRSES1]CATACN='' | [M:HRSES1]TYPFRT='' Then
    #ADNGO - 2017-12-04 - X3-29544 - END
      GMESSAGE=mess(302,10717,1) : # La nature fiscale, la catégorie d'action et le dispositif utilisé de la session doivent être renseignés
      mkstat=2 : End
    Endif
    # Fin FQ97638

    Call LECTURE("EML",VALEUR,"") From CONTOBJ
    If !fstat Then
      [M:HRSES5]NAMD(nolign-1) = [F:ID]NAM-[F:ID]SRN
      Affzo [M:HRSES5]NAMD(nolign-1)

      If [F:ID]FLGMULCTR<>2
        Call CHERCHE_CTR(VALEUR,[M:HRSES1]ENDDAT,CONTRAT) From DIVPAYE
        [M:HRSES5]CTRNUMD(nolign-1) = CONTRAT
        Affzo [M:HRSES5]CTRNUMD(nolign-1)
      Endif
   Endif
  Endif
End

