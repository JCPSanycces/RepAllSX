######################################################################################
# FQ78431 - 09/04/13 - Ajout tableau pour création inscriptions manuelles
Subprog C_CTRNUMD(VALEUR)
Variable Char    VALEUR()
Local    Char    CATFRT(20)
Local    Char    LEGCTR(5)
Local    Integer OK, DISPMSG
Local    Char    CAT(GLONADI)(0..100)

  If VALEUR<>"" Then
    Read [F:ID]ID0=[M:HRSES5]REFNUMD(nolign-1)
    If !fstat & [F:ID]FLGMULCTR=2
      Filter [F:HRCTR] Where REFNUM=[M:HRSES5]REFNUMD(nolign-1) & CTRNUM=VALEUR & (CTRDAT<=date$ | (FLGRET=2 & RETDATEFF<=date$))
      Read [F:HRCTR] Last
      If fstat Then Raz [F:HRCTR] : Endif
      Filter [F:HRCTR]
      Call VERIF_PRESENCE([F:HRCTR]CTRNUM)
    Endif
    Call GET_LEGHRCTR([M:HRSES5]REFNUMD(nolign-1),VALEUR,OK,LEGCTR,DISPMSG) From TOOLSHRLEG
    If [M:HRSES0]LEG<>"" & LEGCTR<>[M:HRSES0]LEG Then
      GMESSAGE=mess(92,198,1)-VALEUR-":"-mess(62,127,1)-LEGCTR : # Contrat : Réservé à la législation
      mkstat=2
    Endif
    #ADNGO - 2017-12-04 - X3-29544 - START
    #If [M:HRSES0]LEG="" & [M:HRSES1]NATFIS=len(mess(0,10452,1)) & [M:HRSES1]CATACN=len(mess(0,10453,1)) & LEGCTR="FRA" Then
    #If [M:HRSES0]LEG="" & [M:HRSES1]NATFIS='' & [M:HRSES1]CATACN='' & LEGCTR="FRA" Then
    If [M:HRSES1]NATFIS='' & [M:HRSES1]CATACN='' Then
    #ADNGO - 2017-12-04 - X3-29544 - END
      GMESSAGE=mess(302,10717,1) : # La nature fiscale et la catégorie d'action de la session doivent être renseignées
      mkstat=2
    Endif
    #ADNGO - 2017-12-04 - X3-29544 - START
    #If LEGCTR='FRA' Then
    #ADNGO - 2017-12-04 - X3-29544 - END
      Call CAT2483([M:HRSES5]REFNUMD(nolign-1),VALEUR,CATFRT) From SUBDEM
      If CATFRT="" Then
        GMESSAGE=mess(300,10717,1)+"."-mess(77,10717,1)+chr$(10)+chr$(13)+mess(301,10717,1) : # Inscription impossible. Catégorie 2483 non définie. Veuillez la renseigner dans le contrat
        mkstat=2
      Else
        If clalev([F:HRSTR])=0 : Local File STAGETRG [HRSTR] : Endif
        Read [F:HRSTR]STR0=[M:HRSES0]STG
        If !fstat Then
          If [F:HRSTR]CATTRG<>"" Then
            Call CALC_TRG([F:HRSTR]CATTRG, "ADI", "10453", CAT) From SUBDEM
            If !find(CATFRT,CAT(0..50)) Then
              # Le salarié n'appartient pas à la catégorie ciblée par le stage
              Infbox mess(66,10717,1)-":"-[F:HRSTR]CATTRG
            Endif
          Endif
        Endif
       #ADNGO - 2017-12-04 - X3-29544 - START
      #Endif
     #ADNGO - 2017-12-04 - X3-29544 - END
    Endif
  Endif
End

Subprog C_REFNUMD(VALEUR)
Variable Char    VALEUR()
Local    Char    CONTRAT(GLONCTR),LEGCTR(5)
Local    Integer OK
Local    Integer DISPMSG

  If VALEUR<>"" Then
    Call UNICITE(VALEUR,[M]REFNUMD) From OBJDIV
    If mkstat : End : Endif

    Read [F:INS]INS1=[F:HRSES]COD;VALEUR
    If !fstat Then
      GMESSAGE = mess(207,10717,1) : # Matricule déjà inscrit à cette session
      mkstat = 2 : End
    Else
      Call LECTURE("EML",VALEUR,"") From CONTOBJ
      If !fstat & [F:ID]FLGMULCTR<>2
        Call CHERCHE_CTR(VALEUR,[M:HRSES1]ENDDAT,CONTRAT) From DIVPAYE
        Call VERIF_PRESENCE(CONTRAT)
        #ADNGO - 2017-12-04 - X3-29544 - START
        #If [M:HRSES0]LEG="" & [M:HRSES1]NATFIS='' & [M:HRSES1]CATACN='' Then
        If [M:HRSES1]NATFIS='' & [M:HRSES1]CATACN='' Then
        #ADNGO - 2017-12-04 - X3-29544 - END
          #ADNGO - 2017-12-04 - X3-29544 - START
          #Call GET_LEGHRCTR(VALEUR,CONTRAT,OK,LEGCTR,DISPMSG) From TOOLSHRLEG
          #If LEGCTR="FRA" Then
          #ADNGO - 2017-12-04 - X3-29544 - END
            GMESSAGE=mess(302,10717,1) : # La nature fiscale et la catégorie d'action de la session doivent être renseignées
            mkstat=2
          #ADNGO - 2017-12-04 - X3-29544 - START
          #Endif
          #ADNGO - 2017-12-04 - X3-29544 - END
        Endif
      Endif
    Endif
  Endif
End

Subprog VERIF_PRESENCE(CTR)
Value    Char    CTR
Local    Integer OK
Local    Char    MESSWRN(250),MESSCTR(250)

  If CTR<>"" Then
    MESSWRN=mess(68,10717,1)-num$([F:HRCTR]XITDAT)
    MESSCTR=mess(171,10717,1)-num$([M:HRSES1]STRDAT)
    If [F:HRCTR]CTRDAT>[M:HRSES1]STRDAT
      # Salarié non présent le
      Call AVERTIR (MESSCTR,OK) From GESECRAN
      If OK=1 : mkstat=2 : End : Endif
    Elsif [F:HRCTR]XITDAT<>[0/0/0] and ([F:HRCTR]XITDAT<[M:HRSES1]ENDDAT | [F:HRCTR]XITDAT<[M:HRSES1]STRDAT)
      # Sortie du salarié le xx/xx/xx
      GMESSAGE = MESSWRN
      mkstat = 2 : End
    Elsif [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT>=[M:HRSES1]ENDDAT
      OK = 2
      # Sortie du salarié le xx/xx/xx
      Call AVERTIR (MESSWRN,OK) From GESECRAN
      If OK=1 : mkstat=2 : End : Endif
    Endif
  Else
    # Salarié non présent dans la société
    GMESSAGE = mess(67,10717,1)
    mkstat = 2 : End
  Endif
End

