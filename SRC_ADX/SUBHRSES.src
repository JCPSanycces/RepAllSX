#Totaux coûts réels
Subprog APRES_NBLIG2
Local Integer I
Raz[M]CSTREATOT
Raz[M]CSTREAIPT
# Fiche 70748 - MABON - 18/01/2011 : erreur d'indice
For I=0 To [M:HRSES4]NBLIG2
 If I<dim([M:HRSES4]CSTTOTIDV2) Then
   [M:HRSES4]CSTREATOT+=[M:HRSES4]CSTTOTIDV2(I)
   [M:HRSES4]CSTREAIPT+=[M:HRSES4]CSTIPTIDV2(I)
 Endif
Next
# Fiche 70748 - MABON - 18/01/2011 : erreur d'indice
For I=0 To [M:HRSES4]NBLIG5
 If I<dim([M:HRSES4]CSTTOTIDV3) Then
   [M:HRSES4]CSTREATOT+=[M:HRSES4]CSTTOTIDV3(I)
   [M:HRSES4]CSTREAIPT+=[M:HRSES4]CSTIPTIDV3(I)
 Endif
Next
Affzo[M:HRSES4]CSTREATOT,CSTREAIPT

Gosub CHARGE_AMT
Affzo [M:HRSES6]
End


