#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Class PJMTSKOPE
#######################################################################################
# EVENTS                                                                              #
#######################################################################################
$AREAD_AFTER
Local Integer IRET

  IRET = fmet this.TCHOPEUOM2AN.INIT()
  IRET = fmet this.TCHOPESTRAN.INIT()
  IRET = fmet this.TCHOPEENDAN.INIT()
Return

#######################################################################################
$ACONTROL
Local Integer ICOUNT
Local Decimal NTOTPLN
Local Decimal NTOTRMN
Local Integer IRET
Local Integer NI
Local Integer IOPECOUNT   # Issue X3-28735/X3-28737 - 2017-09-19 by TEJAC
Local Integer NI          # Issue X3-28735/X3-28737 - 2017-09-19 by TEJAC
Local Integer NE          # Issue X3-28735/X3-28737 - 2017-09-19 by TEJAC

  # ---------------------------------------
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(192,2260,1), [V]CST_AFATAL))
    Return
  Endif
  # ---------------------------------------
  If this.OPESTR <> [0/0/0] and this.OPEEND <> [0/0/0] Then
    If this.OPESTR > this.OPEEND Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPEEND", mess(289,2260,1), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  If this.STDOPENUM <> this.snapshot.STDOPENUM Then
    If this.OPESTA <> 1 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STDOPENUM", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  If (this.EXTLAB <> AVOID.ACHAR and this.EXTLABNBR <> 1) or (this.EXTLAB = AVOID.ACHAR and this.EXTLABNBR <> 0) Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("EXTLABNBR", mess(18,9804,1), [V]CST_AERROR))
  Endif
  # ---------------------------------------
  If this.EXTWSTNBR <> 1 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("EXTWSTNBR", mess(18,9804,1), [V]CST_AERROR))
  Endif
  # ---------------------------------------
  # Issue X3-52534 - 2017-08-18 by FGR : BEGIN
  #ICOUNT = uni(this.RAFFT(1..maxtab(this.RAFFT)).POACLB)
  #If ICOUNT > 1 Then
  #  [L]ASTATUS = fmet this.SETERROR("POACLB", func AFNC.MES1(mess(173,2260,1), this.RAFFT(ICOUNT).POACLB), [V]CST_AERROR)
  #Endif
  #For NI = 1 To maxtab(this.RAFFT)
  #  If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
  #    If this.RAFFT(NI).POACSMQTY <> 0 Then
  #      If this.RAFFT(NI).POACLB <> this.snapshot.RAFFT(NI).POACLB Then
  #        IRET = fmet this.SETERROR("POACLB", func AFNC.MES1(mess(414,2260,1), this.RAFFT(NI).POACLB), [V]CST_AERROR)
  #        [L]ASTATUS = max([L]ASTATUS, IRET)
  #        Break
  #      Endif
  #    Endif
  #  Endif
  #Next NI
  # Issue X3-52534 - 2017-08-18 by FGR : END
  # ---------------------------------------
  If this.ASTALIN = [V]CST_AUPD Then
    # ---------------------------------------
    NTOTRMN = fmet this.RAFFT_SUM_POARMNQTY()
    NTOTPLN = fmet this.RAFFT_SUM_POASTDQTY()
    # ---------------------------------------
    If NTOTPLN > this.EXTQTY Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("POASTDQTY", mess(511,2260,1), [V]CST_AERROR))
    Endif
    If NTOTRMN > this.RMNQTY Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("POARMNQTY", mess(512,2260,1), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  If this.TCHACTION = AVOID.ACHAR and this.OPESTA = 5 Then
    If this.ASTALIN = [V]CST_AUPD Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(489,2260,1), mess(this.OPESTA,308,1)), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
Return

#######################################################################################
$AINSERT_CONTROL_BEFORE
  Gosub  AINSERT_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$AUPDATE_CONTROL_BEFORE
  # ---------------------------------------
  Gosub  AINSERT_AUPDATE_CONTROL_BEFORE
  # ---------------------------------------
  [L]ASTATUS = max([L]ASTATUS, fmet this.RAFFT_REPEAT_OPESTR())
  [L]ASTATUS = max([L]ASTATUS, fmet this.RAFFT_REPEAT_OPEEND())
  # ---------------------------------------
Return

#######################################################################################
$AINSERT_AUPDATE_CONTROL_BEFORE
Local Integer IRET
Local Decimal NPOARMNQTY
Local Decimal DTOTAL
Local Integer ITYP            # Issue X3-48424 - 2017-08-15 by SINGC
Local Char STYP(5)(1..)       # Issue X3-48424 - 2017-08-15 by SINGC
Local Char WST(GLONWST)(1..)  # Issue X3-47483 - 2017-08-21 by SINGC
Local Date RDATE              # Issue X3-47483 - 2017-08-21 by SINGC
Local Char SHMEMPTY(GLONHM)   # Issue X3-48424 - 2017-11-08 by SINGC/FGR

  # ---------------------------------------
  [L]ASTATUS = max([L]ASTATUS, fmet this.COMPUTE_OPECST_OPECTS2())
  # ---------------------------------------
  If this.ROODESAXX = AVOID.ACHAR and this.STDOPENUM <> AVOID.AINT Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.GET_STDOPENUM_DES())
  Endif
  # ---------------------------------------
  For NI = 1 To maxtab(this.RAFFT)
    If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.OPEUOM2 <> this.snapshot.OPEUOM2 Then
        # Update line with converted but same value (1day = 8hours)
        this.RAFFT(NI).POUOM = this.OPEUOM2
        NPOARMNQTY = this.RAFFT(NI).POARMNQTY
        # Issue X3-52321 - 2017-08-09 by FGR : BEGIN
        #Call CONVERT_QTY(this.ACTX, this.OPEUOM2, this.snapshot.OPEUOM2, this.RAFFT(NI).POASTDQTY) From TRTX3_SYRA
        #Call CONVERT_QTY(this.ACTX, this.OPEUOM2, this.snapshot.OPEUOM2, NPOARMNQTY) From TRTX3_SYRA
        Call CONVERT_QTY(this.ACTX, this.RAFFT(NI).snapshot.POUOM, this.RAFFT(NI).POUOM, this.RAFFT(NI).POASTDQTY) From TRTX3_SYRA
        Call CONVERT_QTY(this.ACTX, this.RAFFT(NI).snapshot.POUOM, this.RAFFT(NI).POUOM, NPOARMNQTY) From TRTX3_SYRA
        # Issue X3-52321 - 2017-08-09 by FGR : END
        this.RAFFT(NI).POARMNQTY = NPOARMNQTY
      Endif
    Endif
  Next NI
  DTOTAL = fmet this.RAFFT_SUM_POARMNQTY()
  If DTOTAL > this.RMNQTY Then
    this.RMNQTY = DTOTAL
  Endif
  # ---------------------------------------
  # Issue X3-47483 - 2017-08-21 by SINGC : START
  # Issue X3-48424 - 2017-11-08 by SINGC : START
  ITYP = 0
  ITYP += 1
  STYP(ITYP) = "WST"
  WST(ITYP) = this.EXTWST
  #WST(1) = this.EXTWST
  If this.EXTLAB <> AVOID.ACHAR Then
    ITYP += 1
    STYP(ITYP) = "WST"
    WST(ITYP) = this.EXTLAB
    #WST(2) = this.EXTLAB
  # Issue X3-48424 - 2017-11-08 by SINGC : END
  Endif
  # ---------------------------------------
  If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and (this.OPESTR <> this.snapshot.OPESTR or this.EXTWST <> this.snapshot.EXTWST or this.EXTLAB <> this.snapshot.EXTLAB)) Then
    If this.OPESTR <> [0/0/0] Then
      # Issue X3-48424 - 2017-11-08 by SINGC : START
      #[L]ASTATUS = max([L]ASTATUS, func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(this, "OPESTR", this.TASFCY, WST, this.OPESTR, 1, RDATE))
      #If IRET < [V]CST_AERROR Then
      [L]ASTATUS = max([L]ASTATUS, func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(this, "OPESTR", this.TASFCY, STYP, WST, this.OPESTR, AVOID.ACHAR, 1, RDATE, SHMEMPTY))
      If [L]ASTATUS < [V]CST_AERROR Then
      # Issue X3-48424 - 2017-11-08 by SINGC : END
        this.OPESTR = RDATE
      Endif
    Endif
  Endif
  # ---------------------------------------
  If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and (this.OPEEND <> this.snapshot.OPEEND or this.EXTWST <> this.snapshot.EXTWST or this.EXTLAB <> this.snapshot.EXTLAB)) Then
    If this.OPEEND <> [0/0/0] Then
      # Issue X3-48424 - 2017-11-08 by SINGC : START
      #[L]ASTATUS = max([L]ASTATUS, func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(this, "OPEEND", this.TASFCY, WST, this.OPEEND, 1, RDATE))
      #If IRET < [V]CST_AERROR Then
      [L]ASTATUS = max([L]ASTATUS, func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(this, "OPEEND", this.TASFCY, STYP, WST, this.OPEEND, AVOID.ACHAR, 1, RDATE, SHMEMPTY))
      If [L]ASTATUS < [V]CST_AERROR Then
      # Issue X3-48424 - 2017-11-08 by SINGC : END
        this.OPEEND = RDATE
      Endif
    Endif
  Endif
  # Issue X3-47483 - 2017-08-21 by SINGC : END
  # ---------------------------------------
Return

#######################################################################################
$AUPDATE_CONTROL_AFTER
  If this.TCHACTION = "TIMEENTRY" Then
    If this.OPEENDDT <> [0/0/0] and this.OPESTARTDT <> [0/0/0] Then
      If this.OPEENDDT < this.OPESTARTDT Then
        [L]ASTATUS = [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPEENDDT", mess(289,2260,1), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

#######################################################################################
$ADELETE_CONTROL_BEFORE
  If this.APARENT = null Then
    [L]ASTATUS = [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(193,2260,1), [V]CST_AFATAL))
    Return
  Endif
Return

########################################################################################
# Child class PJMOPEAFF - RAFFT
########################################################################################
$RAFFT_ACONTROL
  # Issue X3-30028/122466 - 2017-04-10 by FGR : BEGIN : not on the right place : moved into PJMOPEAFF_CSTD_EVENTS
  #If this.POASTR <> [0/0/0] and this.POAEND <> [0/0/0] Then
  #  If this.POASTR > this.POAEND Then
  #    IRET = fmet this.SETERROR("POASTR", mess(289,2260,1), [V]CST_AERROR)                                # Issue X3-23847/121267 - 2017-01-31 by FGR
  #    [L]ASTATUS = max([L]ASTATUS, IRET)                                                                  # Issue X3-23847/121267 - 2017-01-31 by FGR
  #  Endif
  #Endif
  # Issue X3-30028/122466 - 2017-04-10 by FGR : END : not on the right place : moved into PJMOPEAFF_CSTD_EVENTS
  # ---------------------------------------
  If this.POASTR <> [0/0/0] and this.APARENT.OPESTR <> [0/0/0] Then
    If this.POASTR < this.APARENT.OPESTR Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("POASTR", func AFNC.MES1(mess(142,2260,1), this.POASTR), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  If this.POAEND <> [0/0/0] and this.APARENT.OPEEND <> [0/0/0] Then
    If this.POAEND > this.APARENT.OPEEND Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("POAEND", func AFNC.MES1(mess(142,2260,1), this.POAEND), [V]CST_AERROR))
    Endif
  Endif
  # Issue X3-48424 - 2017-08-15 by SINGC : START
  If this.POASTRHM <> AVOID.ACHAR and this.POAENDHM <> AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, func OPPORPJM_CSTD_PROGS.CONTROL_HOURS_BEGIN_END(this, this.POASTR, "POASTRHM", this.POASTRHM, this.POAEND, "POAENDHM", this.POAENDHM))
  Endif
  # Issue X3-48424 - 2017-08-15 by SINGC : END
Return

########################################################################################
$RAFFT_ADDLINE_BEFORE
  If this.OPESTA = 5 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(487,2260,1), mess(this.OPESTA,308,1)), [V]CST_AERROR))
  Endif
Return

########################################################################################
$RAFFT_ADELLINE_BEFORE
  # Check if time is tracked before delete
  # --------------------------------------
  Local File PJMTIMEMP [PTE]
  # --------------------------------------
  Filter [PTE] Where [F:PTE]PIMTASCOD = this.APARENT.PIMPL.PIMNUM and [F:PTE]OPENUM = this.RAFFT([L]ALINE).OPENUM and [F:PTE]OPESPLNUM = this.RAFFT([L]ALINE).OPESPLNUM and
&                    [F:PTE]POANUM = this.RAFFT([L]ALINE).POANUM
  For [PTE]
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(300,2260,1), [V]CST_AERROR))
    Break
  Next
  Filter [PTE]
  # --------------------------------------
  If this.OPESTA = 5 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(488,2260,1), mess(this.OPESTA,308,1)), [V]CST_AERROR))
  Endif
  # --------------------------------------
Return

########################################################################################
$RAFFT_ADDLINE_AFTER
  # ----------------------------
  # Note that is "this" is the current "this" of the budget (BUD) collection.
  # So, its parent class is stored in .APARENT. technical property.
  # It's different in BUD_INIT_TECH_PROP method. This one is called from OPPORPJM class.
  # So, the "this" is about OPPORPJM class, and BUD is a subclass.
  # ---------------------------------------
  this.POUOM      = this.APARENT.OPEUOM2
  this.CUR        = this.APARENT.CUR
  this.TASFCY     = this.APARENT.TASFCY
  this.TCHCHGTYP  = this.APARENT.TCHCHGTYP
  this.TCHOPECST  = this.APARENT.OPECST
  this.TCHOPECST2 = this.APARENT.OPECST2
  this.TCHOPESTA  = this.APARENT.OPESTA
  # ---------------------------------------
  this.POADES = this.APARENT.ROODESAXX
  this.POASTR = this.APARENT.OPESTR
  this.POAEND = this.APARENT.OPEEND
  # ---------------------------------------
  If this.POAEND = [0/0/0] Then
    this.POAEND = this.APARENT.OPEEND
  Endif
  # ---------------------------------------
  this.TCHOPESTA = this.APARENT.OPESTA # Issue X3-17075/120484 - 2016-12-19 by FGR
Return

#######################################################################################
$RAFFT_AINSERT_CONTROL_BEFORE
  Gosub RAFFT_AINSERT_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$RAFFT_AUPDATE_CONTROL_BEFORE
  Gosub RAFFT_AINSERT_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$RAFFT_AINSERT_AUPDATE_CONTROL_BEFORE
# Issue X3-48424 - 2017-08-15 by SINGC : START
Local Integer ITYP
Local Char STYP(5)(1..)
Local Char SVAL(5)(1..)
Local Char RHOUR(GLONHM)
#Local Char WST(GLONWST)(1..)  # Issue X3-47483 - 2017-08-21 by SINGC
Local Date RDATE               # Issue X3-47483 - 2017-08-21 by SINGC

#Local File PJMAUS     [PAUS]  # Issue X3-47483 - 2017-08-21 by SINGC
#Local File PJMAUSCAVA [PJCV]  # Issue X3-47483 - 2017-08-21 by SINGC

  If this.OPPNUM = AVOID.ACHAR
    this.OPPNUM    = this.APARENT.OPPNUM
    this.OPENUM    = this.APARENT.OPENUM
    this.OPESPLNUM = this.APARENT.OPESPLNUM
    this.TASCOD    = this.APARENT.TASCOD
  Endif
  # ---------------------------------------
  # Issue X3-47483 - 2017-08-21 by SINGC : START
  ITYP = 0
  ITYP += 1
  STYP(ITYP) = "WST"
  SVAL(ITYP) = this.APARENT.EXTWST
  #WST(1) = this.APARENT.EXTWST
  If this.APARENT.EXTLAB <> AVOID.ACHAR Then
    ITYP += 1
    STYP(ITYP) = "WST"
    SVAL(ITYP) = this.APARENT.EXTLAB
    #WST(2) = this.APARENT.EXTLAB
  Endif
  ITYP += 1
  STYP(ITYP) = "AUS"
  SVAL(ITYP) = this.POACLB
  # ---------------------------------------
  If this.ASTALIN = [V]CST_ANEW or
&   (this.ASTALIN = [V]CST_AUPD and (this.POASTR <> this.snapshot.POASTR or this.APARENT.EXTWST <> this.APARENT.snapshot.EXTWST or
&    this.APARENT.EXTLAB <> this.APARENT.snapshot.EXTLAB or this.POASTRHM <> this.snapshot.POASTRHM))
& Then  # Issue X3-48424 - 2017-08-15 by SINGC : Added POASTRHM test
    If this.POASTR <> [0/0/0] Then
      #[L]ASTATUS = max([L]ASTATUS, func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(this, "POASTR", this.TASFCY, WST, this.POASTR, 1, RDATE))
      [L]ASTATUS = max([L]ASTATUS, func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(this, "POASTR", this.TASFCY, STYP, SVAL, this.POASTR, this.POASTRHM, 1, RDATE, RHOUR))
      If [L]ASTATUS < [V]CST_AERROR Then
        this.POASTR = RDATE
        this.POASTRHM = RHOUR
      Endif
    Endif
  Endif
  # ---------------------------------------
  If this.ASTALIN = [V]CST_ANEW or
&    (this.ASTALIN = [V]CST_AUPD and (this.POAEND <> this.snapshot.POAEND or this.APARENT.EXTWST <> this.APARENT.snapshot.EXTWST or
&     this.APARENT.EXTLAB <> this.APARENT.snapshot.EXTLAB or this.POAENDHM <> this.snapshot.POAENDHM))
& Then  # Issue X3-48424 - 2017-08-15 by SINGC : Added POAENDHM test
    If this.POAEND <> [0/0/0] Then
      #[L]ASTATUS = max([L]ASTATUS, func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(this, "POAEND", this.TASFCY, WST, this.POAEND, 1, RDATE))
      [L]ASTATUS = max([L]ASTATUS, func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(this, "POAEND", this.TASFCY, STYP, SVAL, this.POAEND, this.POAENDHM, 1, RDATE, RHOUR))
      If [L]ASTATUS < [V]CST_AERROR Then
        this.POAEND = RDATE
        this.POAENDHM = RHOUR
      Endif
    Endif
  Endif
  # Issue X3-47483 - 2017-08-21 by SINGC : END
  # Issue X3-48424 - 2017-08-15 by SINGC : END
Return

#######################################################################################
# OPLNK
#######################################################################################
$OPLNK_ACONTROL
Local Integer NI

  # Issue X3-28737/X3-26991 - 2017-07-31 by FGR/TEJAC
  If this.OPPNUM <> this.APARENT.OPPNUM Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPNUM", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TASCOD <> this.APARENT.TASCOD Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASCOD", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.ASTALIN = [V]CST_AUPD Then
    If this.OPENUM <> this.APARENT.OPENUM Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUM", mess(18,9804,1), [V]CST_AERROR))
    Endif
    If this.OPESPLNUM <> this.APARENT.OPESPLNUM Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESPLNUM", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  For NI = 1 To maxtab(this.APARENT.OPLNK)
    If this.APARENT.OPLNK(NI) <> null and find(this.APARENT.OPLNK(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.APARENT.OPLNK(NI) <> this Then
        If this.APARENT.OPLNK(NI).OPENUMLNK = this.OPENUMLNK and this.APARENT.OPLNK(NI).OPESPNUMLNK = this.OPESPNUMLNK Then
          If this.APARENT.OPLNK(NI).OPELNKTYP = this.OPELNKTYP Then
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPELNKTYP", func AFNC.MES2(mess(980,2260,1), num$(this.APARENT.OPLNK(NI).OPENUMLNK), mess(this.OPELNKTYP,7726,1)), [V]CST_AERROR))
          Endif
        Endif
      Endif
    Endif
  Next NI
Return

#######################################################################################
$OPLNK_AUPDATE_CONTROL_BEFORE
  # Issue X3-26991/X3-43920 - 2017-06-30 by FGR/TEJAC
  If this.APARENT.OPESTA = 5 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTA", func AFNC.MES1(mess(923,2260,1), mess(this.APARENT.OPESTA,308,1)), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$OPLNK_ADDLINE_BEFORE
  # Issue X3-28737/X3-26991 - 2017-08-02 by FGR/TEJAC
  If this.OPESTA = 5 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTA", func AFNC.MES1(mess(924,2260,1), mess(this.OPESTA,308,1)), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$OPLNK_ADELLINE_BEFORE
Local Integer NE

  # Issue X3-28737/X3-26991 - 2017-08-02 by FGR/TEJAC
  If this.OPESTA = 5 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTA", func AFNC.MES1(mess(925,2260,1), mess(this.OPESTA,308,1)), [V]CST_AERROR))
  Else
    For NE = 1 To maxtab(this.APARENT.RTKO)
      If this.APARENT.RTKO(NE) <> null and find(this.APARENT.RTKO(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.APARENT.RTKO(NE).OPENUM = this.OPLNK([L]ALINE).OPENUMLNK and this.APARENT.RTKO(NE).OPESPLNUM = this.OPLNK([L]ALINE).OPESPNUMLNK Then
          If this.APARENT.RTKO(NE).OPESTA = 5 Then
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTA", func AFNC.MES1(mess(925,2260,1), mess(this.APARENT.RTKO(NE).OPESTA,308,1)), [V]CST_AERROR))
            Break
          Endif
        Endif
      Endif
    Next NE
  Endif
Return

