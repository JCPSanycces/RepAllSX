#<AdxTL>@(#)2.0.0.0 $Revision$
###############################################################################
# Ensemble de sous programme communs aux écrans STOENT et STOENTM
###############################################################################



###############################################################################
# LECFIC_ALIG : Lectures des fichiers devant être effectuées en "Avant_ligne"
###############################################################################
# Pré-requis : Les table suivantes doivent être ouvertes:
#                - TABLOCTYP [TLO]
#                - STOLOC    [STC]
###############################################################################
$LECFIC_ALIG
If dim([M]LOCTYP)<=0 : Return : Endif
If [M]LOCTYP(nolign-1)<>""
    If [M]LOCTYP(nolign-1)<>[F:TLO]LOCTYP | [M]STOFCY<>[F:TLO]STOFCY
        Read [TLO]TLO0=[M]STOFCY;[M]LOCTYP(nolign-1)
# Ca pose problème si le type = '*' par exemple
#        If fstat
#            Call ERREUR(mess(245,192,1)) From GESECRAN
#            Return
#        Endif
    Endif
Endif

If [M]LOC(nolign-1)<>""
    If [M]LOC(nolign-1)<>[F:STC]LOC | [M]STOFCY<>[F:STC]STOFCY
        Read [STC]STC0=[M]STOFCY;[M]LOC(nolign-1)
#        If fstat
#            Call ERREUR(mess(109,192,1)) From GESECRAN
#            Return
#        Endif
    Endif
Endif

Return

##################################################################################
# Action INIZONENT2 appelée en avant_ligne de STOENT et STOENTM                  #
#             Initialisation champs stock sur ligne détail d'entrée              #
##################################################################################
# Paramètres E : LITM    = Article
#                LFCY    = Site
#                LBPR    = Tiers
#                LTYPBPR = Type de tiers (1=Fournisseur, 2=Client)
#                LSUP    = Inutilisé (paramètre supplémentaire au cas où)
#                LLIN    = Indice de la ligne en cours de saisie (nolign-1)
#                LTRSTYP = Type mvt de stock (menu local 704)
#                LTRSCOD = Code mouvement  (table diverse 14)
#                LAFF    = Affichage des champs stock (0=Non, 1=Oui)
#            S : mkstat (0=OK / 1=Erreur)
#
# Prérequis    : Ces tables doivent être ouvertes   ITMMASTER
#                                                   ITMCATEG
#                                                   ITMFACILIT
#                                                   ITMMVT
#                                                   TABSTORUL
#                La classe [M] par défaut est celle du tableau des lignes article
##################################################################################
Subprog INIZONENT2(LABR, LITM,LFCY,LBPR,LTYPBPR,LSUP,LLIN,LTRSTYP,LTRSCOD,LCUN,LAFF)
Value    Char     LABR
Value    Char     LITM
Value    Char     LFCY
Value    Char     LBPR
Value    Integer  LTYPBPR
Value    Char     LSUP
Value    Integer  LLIN
Value    Integer  LTRSTYP
Value    Char     LTRSCOD
Value    Integer  LCUN  # FGR 18/01/2010 : X3SUIVI60986
Value    Integer  LAFF
#----- Variables locales -----#
Local    Integer  WRET, WQUAFLG, WSAICOEF, WTYPUOM, I
Local    Char     WUSCAV(2), WLBEFMT(GLONARP), WUOM(GLONUOM), WSAIFLG(13)
Local    Decimal  WCOEF
#----- Lecture table article par sécurité (appels autres que sur AM_ITMREF)
If [F:ITM]ITMREF<>LITM
    Read [ITM]ITM0=LITM
    If fstat  Raz [F:ITM] : mkstat=1 : End : Endif
Endif

#----- Lecture ITMFACILIT  pour recuperer STOMGTCOD
If [F:ITM]STOMGTCOD > 1
   If [F:ITF]STOFCY <> LFCY | [F:ITF]ITMREF <> [F:ITM]ITMREF
      Read [ITF]ITF0 = [F:ITM]ITMREF;LFCY
      If fstat
         Raz [F:ITF]
      Endif
   Endif
Endif


#----- Articles gérés en stock, lecture des tables articles -----#
WSAIFLG="0000000000000"
Gosub LEC_TABSTO From STKECR
If WRET<>0  mkstat=1 : End : Endif
#----- Initialisation unités et coefficient -----#
Gosub INIT_UNITE_COEF From STKECR2
If mkstat End : Endif
#----- Initialisation statut par défaut -----#
Call STKINISTA([M]STA(LLIN),LBPR,0) From STKACT
#----- Initialisation de l'emplacement -----#
If [F:ITF]LOCMGTCOD>=2
    I=find([F:SRU]LOCNUM-1,[F:ITF]LOCNUM(0..dim([F:ITF]LOCNUM)-1))
    If I>0
        If evalue("dim([M:"+LABR+"]LOCTYP)")>0 [M]LOCTYP(LLIN)=[F:ITF]DEFLOCTYP(I-1) : Endif
        If evalue("dim([M:"+LABR+"]LOC)")>0    [M]LOC(LLIN)   =[F:ITF]DEFLOC(I-1)    : Endif
    Endif
Endif

#----- Initialisation lot fournisseur, lot et sous-lot -----#
If evalue("dim([M:"+LABR+"]BPSLOTAFF)")>0   Raz [M]BPSLOTAFF(LLIN) : Endif
If evalue("dim([M:"+LABR+"]GESLOTAFF)")>0   Raz [M]GESLOTAFF(LLIN) : Endif
If evalue("dim([M:"+LABR+"]SLOAFF)")>0      Raz [M]SLOAFF(LLIN)    : Endif
If evalue("dim([M:"+LABR+"]ECCVALMAJAFF)")>0 Raz [M]ECCVALMAJAFF(LLIN)                        # hcb 71276
                                             Raz [M]ECCVALMINAFF(LLIN) : Endif                # hcb 71276

If evalue("dim([M:"+LABR+"]LOTAFF)")>0
    Raz [M]LOTAFF(LLIN)
    If [F:ITM]LOTMGTCOD>=2
        If !( sigma(0,[M]NBLIG-1, (LLIN<>indcum)
&                              &([M]LOTAFF(indcum)<>[M]LOTAFF(0)) ) )
            [M]LOTAFF(LLIN)    = [M]LOTAFF(0)
            #--- Bug 65064
            [M]BPSLOTAFF(LLIN) = [M]BPSLOTAFF(0)
#                                                                     # hcb 71276 deb
            If evalue("dim([M:"+LABR+"]ECCVALMAJAFF)")>0
               [M]ECCVALMAJAFF(LLIN) = [M]ECCVALMAJAFF(0)
               [M]ECCVALMINAFF(LLIN) = [M]ECCVALMINAFF(0)
               [M]ECCSAIFLG   (LLIN) = [M]ECCSAIFLG   (0)
            Endif
#                                                                     # hcb 71276 fin
        Elsif [F:ITM]LOTCOU<>"" & evalue("dim([M:"+LABR+"]GESLOTAFF)")>0
            [M]GESLOTAFF(LLIN)="C"
        Endif
    Endif
Endif
#----- Initialisation no de série -----#
If evalue("dim([M:"+LABR+"]SERNUM)")>0  Raz [M]SERNUM(LLIN)  : Endif
If evalue("dim([M:"+LABR+"]SERNUMF)")>0 Raz [M]SERNUMF(LLIN) : Endif
#----- Affichage des champs stock -----#
If LAFF
  If evalue("dim([M:"+LABR+"]PCU)")>0       Affzo PCU(LLIN)       : Endif
  If evalue("dim([M:"+LABR+"]PCUSTUCOE)")>0 Affzo PCUSTUCOE(LLIN) : Endif
  If evalue("dim([M:"+LABR+"]UOM)")>0       Affzo UOM(LLIN)       : Endif
  If evalue("dim([M:"+LABR+"]UOMSTUCOE)")>0 Affzo UOMSTUCOE(LLIN) : Endif
  If evalue("dim([M:"+LABR+"]STU)")=1       Affzo STU             : Endif
  If evalue("dim([M:"+LABR+"]STA)")>0       Affzo STA(LLIN)       : Endif
  If evalue("dim([M:"+LABR+"]LOCTYP)")>0    Affzo LOCTYP(LLIN)    : Endif
  If evalue("dim([M:"+LABR+"]LOC)")>0       Affzo LOC(LLIN)       : Endif
  If evalue("dim([M:"+LABR+"]WRH)")>0       Affzo WRH(LLIN)       : Endif
  If evalue("dim([M:"+LABR+"]BPSLOTAFF)")>0 Affzo BPSLOTAFF(LLIN) : Endif
  If evalue("dim([M:"+LABR+"]LOTAFF)")>0    Affzo LOTAFF(LLIN)    : Endif
  If evalue("dim([M:"+LABR+"]SLOAFF)")>0    Affzo SLOAFF(LLIN)    : Endif
  If evalue("dim([M:"+LABR+"]SERNUM)")>0    Affzo SERNUM(LLIN)    : Endif
  If evalue("dim([M:"+LABR+"]SERNUMF)")>0   Affzo SERNUMF(LLIN)   : Endif
  If evalue("dim([M:"+LABR+"]MVTDES)")=1    Affzo MVTDES          : Endif
  If evalue("dim([M:"+LABR+"]ECCVALMAJAFF)")>0 Affzo [M]ECCVALMAJAFF(LLIN)
                                               Affzo [M]ECCVALMINAFF(LLIN) : Endif

Endif
End

#######################################################################
# MAJPCU : Met à jour le coef, l'étiquette et l'activation des zones
#######################################################################
# Paramètres E : PABR = Abréviation écran (ENT ou ENM)
#                PNOL = N° de ligne
#
#            S : PPCU = Unité choisie
#
#######################################################################
Subprog MAJPCU(PABR, PPCU, PNOL)
Value    Char    PABR
Variable Char    PPCU
Value    Integer PNOL
    Local Char    LMABR(10)
    Local Char    LUSCAV(5)
    Local Integer LMODIF
    Local Char    PLBEFMT(GLONARP)
    Local Decimal LCOEF
    Local Decimal LQTYSTU

    LMABR = "[M:"+PABR+"]"
    Default Mask LMABR

    Call CTLUOM (evalue(LMABR+"ITMREF"),3,evalue(LMABR+"BPRNUM"), PPCU, LCOEF, LUSCAV, PLBEFMT, LMODIF) From STKACT

    If LUSCAV <> "S"
       If LUSCAV <> "C"
          mkstat = 2
          End
       Endif
    Endif
    If LMODIF=2 & PPCU=evalue("[M:"+PABR+"]PCUTOENT")
        LCOEF = evalue("[M:"+PABR+"]COETOENT")
    Endif
    # Recalcul quantité UC
    If LCOEF<>0
       Assign LMABR+"QTYPCU(PNOL)" With evalue(LMABR+"QTYPCU(PNOL)") * evalue(LMABR+"PCUSTUCOE(PNOL)") / LCOEF
    Endif
    Assign LMABR+"PCUSTUCOE(PNOL)" With LCOEF
    Assign LMABR+"QTYSTU(PNOL)"    With evalue(LMABR+"QTYPCU(PNOL)") * evalue(LMABR+"PCUSTUCOE(PNOL)")
    LQTYSTU = evalue(LMABR+"QTYSTU(PNOL)")
    Call QTEARR(LQTYSTU,evalue(LMABR+"STU")) From TRTDIV
    Assign (LMABR+"QTYSTU(PNOL)") With LQTYSTU
    Affzo =LMABR+"PCUSTUCOE(PNOL)"
    Affzo =LMABR+"QTYSTU(PNOL)"

    Assign (LMABR+"WPCU(PNOL)") With PPCU
    If evalue("dim("+LMABR+"PRNCOD1)")>0 & evalue(LMABR+"PRNCOD1") = 1
        Assign LMABR+"LBEFMT(PNOL)" With ""
        Assign LMABR+"LBENBR(PNOL)" With 0
    Else
        If evalue("dim("+LMABR+"LBEFMT(PNOL))") > 0
            Assign LMABR+"LBEFMT(PNOL)" With PLBEFMT
        Endif
        If evalue("dim("+LMABR+"LBENBR(PNOL))") > 0
            Assign LMABR+"LBENBR(PNOL)" With 1
        Endif
    Endif

    If LMODIF = 2
       Actzo [M]PCUSTUCOE(PNOL)
    Else
       Diszo [M]PCUSTUCOE(PNOL)
    Endif
End


###############################################################################
# MAJCOLONNE : Copie la valeur d'un champ sur toutes les lignes suivantes
#              (selon conditions)
###############################################################################
# Prérequis :
###############################################################################
# Paramètres E : PABR = Abréviation de l'écran
#                PRUB = Champ à copier
#                        1 : QTYPCU
#                        2 : ??
#                        3 : SLO
#                        4 : STA
#                        5 : LBEFMT
#                        6 : LBENBR
#                        7 : PALNUM
#                        8 : CTRNUM
#                        9 : ECCVALMAJ
#                       10 : ECCVALMIN
#                PNOL = Indice de la ligne (nolign-1)
###############################################################################
Subprog MAJCOLONNE(PABR, PRUB, PNOL)
Value Char    PABR
Value Integer PRUB
Value Integer PNOL

Local Integer I , NB
Local Char    LMABR(10)


LMABR = "[M:"+PABR+"]"

NB = evalue(LMABR+"NBLIG")

Case PRUB
  When 1
      Local Decimal LQTYSTU, LQTYPCU
      If PNOL<NBLIG-1
          LQTYPCU = evalue(LMABR+"QTYPCU(PNOL)")
          For I = PNOL+1 To NB-1
              If !find(evalue(LMABR+"ORILIG(I)"),2,5)
                  Assign (LMABR+"QTYPCU(I)")  With LQTYPCU
                  LQTYSTU = LQTYPCU * evalue(LMABR+"PCUSTUCOE(I)")
                  Call QTEARR(LQTYSTU,evalue(LMABR+"STU")) From TRTDIV
                  Assign (LMABR+"QTYSTU(I)")  With LQTYSTU
              Endif
          Next
      Endif
      Gosub GESSELECTION From TRTSTOENTB

  When 2
# Ce n'est pas très clair ce qu'il faudrait faire
#      For I = PNOL+1 To NB-1
#          If !find(evalue(LMABR+"ORILIG(I)"),2,5)
#              If evalue("dim("+LMABR+"SLO)") > 0
#                  If evalue(LMABR+"LOT(I)") <> ""
#                      Assign (LMABR+"SLO(I)")  With  evalue(LMABR+"SLO(PNOL)")
#                  Endif
#              Endif
#              Assign (LMABR+"NUMLIGLOT(I)") With evalue(LMABR+"NUMLIGLOT(PNOL)")
#         Endif
#      Next
  When 3
     Local Char LLOT(GLONLOT), LSLO(GLONSLO), LMAJ(GLONECS), LMIN(GLONECS)
     Local Integer LNUMLIGLOT
     LLOT = evalue(LMABR+"LOTAFF(PNOL)")
     LSLO = evalue(LMABR+"SLOAFF(PNOL)")
     LMAJ = evalue(LMABR+"ECCVALMAJAFF(PNOL)")
     LMIN = evalue(LMABR+"ECCVALMINAFF(PNOL)")
     LNUMLIGLOT = evalue(LMABR+"NUMLIGLOT(PNOL)")
     For I = PNOL To NB-1
         If !find(evalue(LMABR+"ORILIG(I)"),2,5)
             If evalue(LMABR+"LOTAFF(I)") = LLOT
                 Assign (LMABR+"SLOAFF(I)")  With LSLO
                 Assign (LMABR+"ECCVALMAJAFF(I)")  With LMAJ
                 Assign (LMABR+"ECCVALMINAFF(I)")  With LMIN
                 Assign (LMABR+"NUMLIGLOT(I)") With LNUMLIGLOT
             Endif
         Endif
     Next
  When 4
     Local Char LSTA(GLONSTA)
     LSTA = evalue(LMABR+"STA(PNOL)")
     For I = PNOL+1 To NB-1
         If !find(evalue(LMABR+"ORILIG(I)"),2,5)
            Assign (LMABR+"STA(I)") With LSTA
         Endif
     Next
 When 5
     Local Char    LPCU
     Local Char    LLBEFMT
     LPCU    = evalue(LMABR+"PCU(PNOL)")
     LLBEFMT = evalue(LMABR+"LBEFMT(PNOL)")
     For I = PNOL+1 To NB-1
         If !find(evalue(LMABR+"ORILIG(I)"),2,5)
            If evalue(LMABR+"PCU(I)")     =  LPCU
                Assign (LMABR+"LBEFMT(I)") With LLBEFMT
            Endif
         Endif
     Next
 When 6
     Local Char    LLBEFMT
     Local Integer LLBENBR
     LLBEFMT = evalue(LMABR+"LBEFMT(PNOL)")
     LLBENBR = evalue(LMABR+"LBENBR(PNOL)")
     For I = PNOL+1 To NB-1
         If !find(evalue(LMABR+"ORILIG(I)"),2,5)
            If evalue(LMABR+"LBEFMT(I)") =  LLBEFMT
                Assign (LMABR+"LBENBR(I)") With LLBENBR
            Endif
         Endif
     Next
 When 7
     Local Char LPALNUM(GLONPAL)
     LPALNUM = evalue(LMABR+"PALNUM(PNOL)")
     For I = PNOL+1 To NB-1
         If !find(evalue(LMABR+"ORILIG(I)"),2,5)
             Assign (LMABR+"PALNUM(I)") With LPALNUM
         Endif
     Next
 When 8
     Local Char LCTRNUM(GLONCTR)
     LCTRNUM = evalue(LMABR+"CTRNUM(PNOL)")
     For I = PNOL To NB-1
         If !find(evalue(LMABR+"ORILIG(I)"),2,5)
             Assign (LMABR+"CTRNUM(I)") With LCTRNUM
         Endif
     Next

Endcase

If PABR="ENT"
    Affzo [M:ENT]
Elsif PABR="ENM"
    Affzo [M:ENM]
Endif

End


###############################################################################
# GESSELECTION : Met à jour le champ PECQTY    (!!!! en unité active !!!!)
#                ainsi que GTOTQTY, GQQQQTY et GRRRQTY
###############################################################################
# Paramètres E : PABR = Abréviation ecran
#
###############################################################################
$GESSELECTION

Local Integer I, NB
If [M]COETOENT = 0
    [M]COETOENT = 1
Endif

If clalev([M:ENT]) & [F:ITF]STOMGTCOD=3 & [M:ENT]TRSTYP=19 & [M:ENT]SAIACTFLG=1
    [M]PECQTY = sigma(0,
&                    max([M:ENT]NBLIG-1,nolign-1),
&                    [M:ENT]QTYSTU(indcum)*(([M:ENT]POT(max(0,[M:ENT]NUMLIGLOT(indcum)))=0)*100+([M:ENT]POT(max(0,[M:ENT]NUMLIGLOT(indcum))))))/ ([M:ENT]COETOENT*100)
Else
    [M]PECQTY = sum([M]QTYSTU(0..max([M]NBLIG-1,nolign-1)))/ [M]COETOENT


Endif

Call QTEARR([M]PECQTY,[M]PCUTOENT) From TRTDIV          # hcb 220305  29257

If dim (GTOTQTY) >= 0
    GTOTQTY = [M]PECQTY
Endif

# L'indice maxi nécessite de prendre le maximum entre nolign et et nblig,
# car sur une nouvelle ligne (à la fin) nblig n'est toujours pas incrémenté
If dim (GQQQQTY) >=0
    GQQQQTY = sigma (I=0,max([M]NBLIG-1,nolign-1),[M]QTYSTU(I)*(left$([M]STA(I),1)= "Q"))
Endif

If dim (GRRRQTY) >=0
    GRRRQTY = sigma (I=0,max([M]NBLIG-1,nolign-1),[M]QTYSTU(I)*(left$([M]STA(I),1)= "R"))
Endif

Return


########################################################################
# ENRENT   Controle enregistrement saisie des entrées
########################################################################
# Paramètres E : LABR       = abréviation écran
#
# Prérequis    : Ces classes [F:] doivent être chargées ITMMASTER
#
########################################################################
Subprog ENRENT(LABR)
Value Char     LABR

Local Integer  WRET
Local Shortint LRET
Local Integer  LLIG
Local Integer  WMAX
Local Integer  I

Local Libelle LNOTPCU
Local Libelle LNOTCOE
Local Libelle LNOTSTA
Local Libelle LNOTLOC
Local Libelle LNOTLOF
Local Libelle LNOTLOT
Local Libelle LNOTSLO
Local Libelle LNOTPAL
Local Libelle LNOTCTR
Local Libelle LNOTSF1
Local Libelle LNOTSF2
#--- Issue X3-53322
Local Libelle LNOTLPN

Local     Char    LABRMSK
LABRMSK  = "[M:"+LABR+"]"
Default Mask LABRMSK
If !clalev([M:ENM])    # Si on est en modif, le test de dimension de STW est fait dans STKINT
    #---------------------------#
    # Vérification que toutes les lignes saisies peuvent être entrées dans STOENTW
    #---------------------------#
    WMAX = dim([M:ENTW]PCU)     # mémorisation nombre de ligne maxi
    If [M:ENTW]NBLIG+[M]NBLIG >= WMAX
        Call ERREUR(mess(376,199,1)+"\"+mess(353,199,1)) From GESECRAN
        mkstat = 2
        End
    Endif
Endif
#--------------------------------#
# controle saisie lignes entrées #
#--------------------------------#
LNOTPCU = evalue("dim([M:"+LABR+"]PCU)") <= 0
LNOTCOE = evalue("dim([M:"+LABR+"]PCUSTUCOE)") <= 0
LNOTSTA = evalue("dim([M:"+LABR+"]STA)") <= 0
LNOTLOC = evalue("dim([M:"+LABR+"]LOC)") <= 0
LNOTLOF = evalue("dim([M:"+LABR+"]BPSLOTAFF)") <= 0
LNOTLOT = evalue("dim([M:"+LABR+"]LOTAFF)") <= 0
LNOTSLO = evalue("dim([M:"+LABR+"]SLOAFF)") <= 0
LNOTPAL = evalue("dim([M:"+LABR+"]PALNUM)") <= 0
LNOTCTR = evalue("dim([M:"+LABR+"]CTRNUM)") <= 0
LNOTSER = evalue("dim([M:"+LABR+"]SERNUM)") <= 0
LNOTSF1 = evalue("dim([M:"+LABR+"]STOFLD1)") <= 0
LNOTSF2 = evalue("dim([M:"+LABR+"]STOFLD2)") <= 0
#--- Issue X3-53322
LNOTLPN = evalue("dim([M:"+LABR+"]LPNNUM)") <= 0

LRET = 0
For LLIG = 0 To evalue(LABRMSK+"NBLIG-1")
    #--- Issue X3-53322 : ajout LPNNUM
    WRET = sigma(LLIG+1,[M]NBLIG-1, (indcum+1) *
&                                 ( I=0
&                                 & (LNOTPCU | [M]PCU(indcum)=[M]PCU(LLIG))
&                                 & (LNOTCOE | [M]PCUSTUCOE(indcum)=[M]PCUSTUCOE(LLIG))
&                                 & (LNOTSTA | [M]STA(indcum)=[M]STA(LLIG))
&                                 & (LNOTLOC | [M]LOC(indcum)=[M]LOC(LLIG))
&                                 & (LNOTLOF | [M]BPSLOTAFF(indcum)=[M]BPSLOTAFF(LLIG))
&                                 & (LNOTLOT | [M]LOTAFF(indcum)=[M]LOTAFF(LLIG))
&                                 & (LNOTSLO | [M]SLOAFF(indcum)=[M]SLOAFF(LLIG))
&                                 & (LNOTPAL | [M]PALNUM(indcum)=[M]PALNUM(LLIG))
&                                 & (LNOTCTR | [M]CTRNUM(indcum)=[M]CTRNUM(LLIG))
&                                 & (LNOTSF1 | [M]STOFLD1(indcum)=[M]STOFLD1(LLIG))
&                                 & (LNOTSF2 | [M]STOFLD2(indcum)=[M]STOFLD2(LLIG))
&                                 & (LNOTLPN | [M]LPNNUM(indcum)=[M]LPNNUM(LLIG))
&                                 & (LNOTSER | ([M]SERNUM(indcum)   >= [M]SERNUM(LLIG)
&                                              &[M]SERNUM(indcum)   <= [M]SERNUMF(LLIG)
&                                              &len([M]SERNUM(indcum))= len([M]SERNUM(LLIG))))
&                                 & sigma(I=0,1,1) ) )
    If WRET
        LRET=1
        Call ERREUR(mess(3,40,1)-num$(WRET)-mess(59,184,1)-num$(LLIG+1)) From GESECRAN
        mkstat=2
        Break
    Endif
    If !LNOTLOC & ( [F:TLO]LOCTYP<>[M]LOCTYP(LLIG) | [F:TLO]STOFCY<>[M]STOFCY)
        Read [TLO]TLO0=[M]STOFCY;[M]LOCTYP(LLIG)
    Endif
    If LABR="ENT"
        Call CTR_COHERENCE_LIG(LABR, [M]STOFCY, LLIG, [M:ENT]VCRTYP, LRET) From STKENT
    Elsif LABR="ENM"
        Call CTR_COHERENCE_LIG(LABR, [M]STOFCY, LLIG, [M:ENM]VCRTYP, LRET) From STKENT
    Endif
    If LRET > 1
        Local Char MES(255)
        MES  = mess(93,100,1)+":"+num$(LLIG+1)+"\"
        If mod(LRET ,2048)>=1024
            MES += mess(67,184,1)+"\"    # Ligne stock en inventaire
        Else
            MES += mess(7,111,1) +":\"
            If mod(LRET ,4)>=2
                MES += mess(25,197,1)+"\"    # Lot
            Endif
            If mod(LRET ,8)>=4
                MES += mess(456,197,1)+"\"    # Sous lot
            Endif
            If mod(LRET ,16)>=8
                MES += mess(47,197,1)+"\"    # N° de série
            Endif
            If mod(LRET ,32)>=16
                MES += mess(44,197,1)+"\"    # Emplacement
            Endif
            If mod(LRET ,64)>=32
                MES += mess(24,197,1)+"\"    # Statut
            Endif
            If mod(LRET,256)>=128
                MES += mess(26,184,1)+"\"    # Etiquette manquante
            Endif
            If mod(LRET,1024)>=512
                MES += mess(27,184,1)+"\"    # Emplacement de type quai à renseigner
            Endif
            If mod(WRET,4096)>=2048
               MES += mess(405,184,1)+"\"    # Version(s) non renseignée(s)
            Endif
            #--- Issue X3-53322
            If mod(LRET,8192)>=4096
              If LABR="ENM"
                MES += mess(525,184,1)+"\"    # Numéro contenant non renseigné
              Else
                MES += mess(513,184,1)+"\"    # Contenant non renseigné
              Endif
            Endif
            #---
        Endif
        mkstat = 2

        Call MESSAGE(MES) From GESECRAN  # Ligne incomplete

        Break
    Else
        Raz LRET
    Endif
Next

If LRET
    End
Endif

#---------------------------#
# Si quantité saisie nulle
#---------------------------#
If [M]PECQTY = 0
    If  !clalev([BBY0]) & !clalev([DBY1])
        Case LABR
            When "ENM" : # Le total est nul --> suppression de la ligne de document ! comfirmation ?
                         If dim(GDELMVT)<=0 | GDELMVT<>1    # On affiche le message d'avertissement que si on est dans STOENTM, pas si on supprime depuis le document
                             Call OUINON(mess(389,199,1),WRET) From GESECRAN
                             If WRET<>2
                                mkstat = 2
                                End
                             Endif
                             If func AFNC.ACTIV("NCS")
                                 Call CHECK_NCS (WRET)
                                 If WRET<>2
                                    mkstat = 2
                                    End
                                 Endif
                             Endif
                         Endif
            When "ENT" : # Message d'erreur, car il est impossible de supprimer une ligne en cours de création
                         Call ERREUR(mess(9,184,1)) From GESECRAN    # La quantité dans le détail doit être différente de 0
                         mkstat = 2
                         End
        Endcase
    Endif
#---------------------------------------------------------#
# Si quantité saisie différente de celle dans le document #
#---------------------------------------------------------#
Elsif [M]PECQTY<>[M]QTYTOENT
  If !GIMPORT : # Si import on accepte le cumul des qtés détaillées !
    Call OUINON(mess(23,184,1)-mess(36,100,1),WRET) From GESECRAN
    #----- La quantitée traitée est incorrecte ! comfirmation ?
    If WRET<>2  mkstat=2 : End : Endif
  Endif
Endif

End


#########################################################################
# CTL_LIGNE_DOCUMENT : Donne la main aux documents pour effectuer certaines
#                      opérations avant stockage dans STOENTW:
#    - contrôles de quantités
#    - affectation diverses (ex: copie de STOCOU sur toutes les lignes de STOENT)
#    - ...
#
# En cas d'erreur, donner une valeur différente de 0 à mkstat
#
# Attention : Il est de la responsabilité de chaque document d'afficher
#             les messages d'erreurs.
#
#########################################################################
$CTL_LIGNE_DOCUMENT
    mkstat = 0
    Raz GPE                                        # hcb 80150
    GPOINT="CTL_DOC" : Gosub ENTREE From EXEFNC    # hcb 80150
    If GPE = 0                                     # hcb 80150
       Case LTYP
         When 6  :    Gosub CTL_LIG_PTH From SUBPTHB         # reception
         When 13 :    If LABR="SRH1"
                          Gosub CTL_LIG_SRH From SUBSRH      # retour client
                      Else If LABR="SRS1"
                          Gosub CTL_LIG_SRS From SUBSRS      # retour matière pour sous traitance
                      Else
                          Gosub CTL_LIG_SRL From SUBSRL      # retour pret
                      Endif
                      Endif
         When 15 :    If clalev([M:PTH1])>0 & clalev([M:PSTT])>0 & [M:PSTT]MFGNUM<>""
                        Gosub CTL_LIG_STT From SUBPTHC       # réception sous-traitance OF
                      Else
                        Gosub CTL_LIG_MTK From MTKLIB
                      Endif
         When 18 :    # Avoir
                      Gosub CTL_LIG_SIH From SUBSIHB          # avoir
         When 19 :    # entrées diverses
         When 23 :    # reception transfert inter site
         When 25 :    # reception sous traitance
         When 12 :    Gosub CTL_LIG_MTK From MTKLIB           # réintégration
         When 27 :    Gosub CTL_STOENT From TRTSSLA           # plan de rangement
         When 31 :    Gosub CTL_BBY0   From SUBBBYA           # assemblage

         When Default :
       Endcase
    Endif                                          # hcb 80150
Return


###############################################################################
# COPYLINE: Copie une ligne dans une autre (Ecran STOENT ou STOENTM)
#           Le sous-lot est incrémenté si PINDTO>PINDFROM
#           L'affichage n'est rafraichi que si la quantité à saisir est encore
#           inférieure à la quantité à entrer
###############################################################################
# Paramètres E : PINDFROM = Indice de la ligne à copier
#                PINDTO   = Indicec de la ligne dans laquelle copier (nolign-1)
#
# Attention le masque par défaut doit être correct
###############################################################################
Subprog COPYLINE(PINDFROM, PINDTO)
Value Integer PINDFROM
Value Integer PINDTO

Local Integer WSTATUS : WSTATUS=status     #--- Affzo change "status"
Local Char    LMSKCOU : LMSKCOU = func STKLIB.MSKDEF
    If PINDFROM>=[M]NBLIG | PINDTO>[M]NBLIG+1
        End
    Endif

    #-------- Copie des champs unité et coef ------------#
    If evalue("dim("+LMSKCOU+"PCU)") > 0
        [M]PCU(PINDTO)          = [M]PCU(PINDFROM)
        If [M]PECQTY<[M]QTYTOENT
            Affzo [M]PCU(PINDTO)
        Endif
        Local Char    LUSCAV(5)
        Local Integer LMODIF
        Local Char    PLBEFMT(GLONARP)
        Local Decimal LCOEF
        Local Decimal LQTYSTU
        Call CTLUOM ([M]ITMREF,3,[M]BPRNUM, [M]PCU(PINDTO), LCOEF, LUSCAV, PLBEFMT, LMODIF) From STKACT
        If LMODIF = 2 & evalue("dim("+LMSKCOU+"PCUSTUCOE)")>0
           Actzo [M]PCUSTUCOE(PINDTO)
        Else
           Diszo [M]PCUSTUCOE(PINDTO)
        Endif
    Endif
    If evalue("dim("+LMSKCOU+"PCUSTUCOE)") > 0
        [M]PCUSTUCOE(PINDTO)    = [M]PCUSTUCOE(PINDFROM)
        If [M]PECQTY<[M]QTYTOENT
            Affzo [M]PCUSTUCOE(PINDTO)
        Endif
    Endif
    #------------ Copie du champ statut --------------#
    If evalue("dim("+LMSKCOU+"STA)") > 0
        [M]STA(PINDTO)          = [M]STA(PINDFROM)
        If [M]PECQTY<[M]QTYTOENT
            Affzo [M]STA(PINDTO)
        Endif
    Endif

    #------------ Copie des champs emplacement ----------------#
    If evalue("dim("+LMSKCOU+"LOCTYP)") > 0
        [M]LOCTYP(PINDTO)       = [M]LOCTYP(PINDFROM)
        If [M]PECQTY<[M]QTYTOENT
            Affzo [M]LOCTYP(PINDTO)
        Endif
    Endif
    If evalue("dim("+LMSKCOU+"LOC)") > 0
        #--- Bug 29688
        Read [TLO]TLO0=[M]STOFCY;[M]LOCTYP(PINDFROM)
        If !fstat & [F:TLO]FILMGTFLG=2 & [F:TLO]PCUNBR<>0
            [M]LOC(PINDTO) = ""
            If evalue("dim("+LMSKCOU+"WRH)") > 0
               [M]WRH(PINDTO) = ""
            Endif
        Else
            [M]LOC(PINDTO) = [M]LOC(PINDFROM)
            If evalue("dim("+LMSKCOU+"WRH)") > 0
               [M]WRH(PINDTO) = [M]WRH(PINDFROM)
            Endif
            If [M]PECQTY<[M]QTYTOENT
                Affzo [M]LOC(PINDTO)
               If evalue("dim("+LMSKCOU+"WRH)") > 0
                  Affzo [M]WRH(PINDTO)
               Endif
            Endif
        Endif
    Endif

    #--------- Copie des champs lot -----------------#
    If evalue("dim("+LMSKCOU+"LOTAFF)") > 0
        If evalue("dim("+LMSKCOU+"BPSLOTAFF)") > 0
            [M]BPSLOTAFF(PINDTO)    = [M]BPSLOTAFF(PINDFROM)
            If [M]PECQTY<[M]QTYTOENT
                Affzo [M]BPSLOTAFF(PINDTO)
            Endif
        Endif
        [M]LOTAFF(PINDTO)          = [M]LOTAFF(PINDFROM)
        If [M]PECQTY<[M]QTYTOENT
            Affzo [M]LOTAFF(PINDTO)
        Endif
        If evalue("dim("+LMSKCOU+"SLOAFF)") > 0 & [M]SLOAFF(PINDTO)="" & [F:ITM]LOTMGTCOD = 4
            If PINDTO>PINDFROM & !(dim(GSAIFLG)>0 & mid$(GSAIFLG,10,1)<>"0")
                If clalev([M:ENT])
                    Call RECLASTSLO([M]ITMREF, [M]LOTAFF(PINDTO), "ENT","", [M]SLOAFF(PINDTO)) From STKLIB
                Elsif clalev([M:ENM])
                    Call RECLASTSLO([M]ITMREF, [M]LOTAFF(PINDTO), "ENM","", [M]SLOAFF(PINDTO)) From STKLIB
                Endif
            Else
                [M]SLOAFF(PINDTO)  = [M]SLOAFF(PINDFROM)
            Endif
            If [M]PECQTY<[M]QTYTOENT
                Affzo [M]SLOAFF(PINDTO)
            Endif
        Endif
        [M]GESLOTAFF(PINDTO)       = [M]GESLOTAFF(PINDFROM)

#                                                                  # hcb 71276 deb
        If evalue("dim("+LMSKCOU+"ECCVALMAJAFF)") > 0
           [M]ECCVALMAJAFF(PINDTO)       = [M]ECCVALMAJAFF(PINDFROM)
           [M]ECCSAIFLG(PINDTO)          = [M]ECCBOMFLG
           If [M]PECQTY<[M]QTYTOENT
               Affzo [M]ECCVALMAJAFF(PINDTO)
    Endif
        Endif
        If evalue("dim("+LMSKCOU+"ECCVALMINAFF)") > 0
           [M]ECCVALMINAFF(PINDTO)       = [M]ECCVALMINAFF(PINDFROM)
           If [M]PECQTY<[M]QTYTOENT
               Affzo [M]ECCVALMINAFF(PINDTO)
           Endif
        Endif
    Endif
#                                                                  # hcb 71276 fin

    #------------- Copie des champs etiquettes -----------#
    If evalue("dim("+LMSKCOU+"LBEFMT)") > 0
        [M]LBEFMT(PINDTO)       = [M]LBEFMT(PINDFROM)
        If [M]PECQTY<[M]QTYTOENT
            Affzo [M]LBEFMT(PINDTO)
        Endif
    Endif
    If evalue("dim("+LMSKCOU+"LBENBR)") > 0
        [M]LBENBR(PINDTO)       = [M]LBENBR(PINDFROM)
        If [M]PECQTY<[M]QTYTOENT
            Affzo [M]LBENBR(PINDTO)
        Endif
    Endif

    #------------- Copie des champs Palnum et Ctrnum -----------#  rajout 02 06 04 Hcb
    If evalue("dim("+LMSKCOU+"PALNUM)") > 0
        [M]PALNUM(PINDTO)       = [M]PALNUM(PINDFROM)
        If [M]PECQTY<[M]QTYTOENT
            Affzo [M]PALNUM(PINDTO)
        Endif
    Endif
    If evalue("dim("+LMSKCOU+"CTRNUM)") > 0
        [M]CTRNUM(PINDTO)       = [M]CTRNUM(PINDFROM)
        If [M]PECQTY<[M]QTYTOENT
            Affzo [M]CTRNUM(PINDTO)
        Endif
    Endif

    If evalue("dim("+LMSKCOU+"STOFLD1)") > 0
        [M]STOFLD1(PINDTO)       = [M]STOFLD1(PINDFROM)
        If [M]PECQTY<[M]QTYTOENT
            Affzo [M]STOFLD1(PINDTO)
        Endif
    Endif
    If evalue("dim("+LMSKCOU+"STOFLD2)") > 0
        [M]STOFLD2(PINDTO)       = [M]STOFLD2(PINDFROM)
        If [M]PECQTY<[M]QTYTOENT
            Affzo [M]STOFLD2(PINDTO)
        Endif
    Endif
    #--- Issue X3-53322
    # On ne copy que le contenant (pas le no)
    If evalue("dim("+LMSKCOU+"TCTRNUM)") > 0
        [M]TCTRNUM(PINDTO)       = [M]TCTRNUM(PINDFROM)
        If [M]PECQTY<[M]QTYTOENT
            Affzo [M]TCTRNUM(PINDTO)
        Endif
    Endif
    #---

    #--- Bug 70401
    GPOINT="UPD_COPYLINE" : Gosub ENTREE From EXEFNC

    status = WSTATUS

End

#########################################################
Subprog INITQTY(PNOL, PQTYPCU, PQTYSTU)
Value    Integer PNOL
Variable Decimal PQTYPCU
Variable Decimal PQTYSTU

   If [M:ENT]PECQTY < [M:ENT]QTYTOENT
      If [M:ENT]PCU(PNOL) = [M:ENT]STU
         PQTYPCU =  ([M:ENT]QTYTOENT-[M:ENT]PECQTY)*[M:ENT]COETOENT
         Call QTEARR(PQTYPCU,[M:ENT]STU) From TRTDIV
      Else
         PQTYPCU =  ([M:ENT]QTYTOENT-[M:ENT]PECQTY)*[M:ENT]COETOENT/[M:ENT]PCUSTUCOE(PNOL)
         Call QTEARR(PQTYPCU,[M:ENT]PCU(PNOL)) From TRTDIV
      Endif
   Endif
End

#########################################################
# Contrôle de n° de série fonction du document appelant
#########################################################
Subprog ENTCTRSER(PSER)
Value Char PSER

    If clalev([M:MBR]) & [M:ENT]TRSTYP=19 & [M:MBR]MATTYP(GNOLIG)=4
# Issue 73500 - 2015-01-21 by CCC : use [M:ENT] instead of [M:MBR]
#        Call STKCTRSER(PSER, [M:MBR]ITMREF(GNOLIG),[M:MBR]REIQTY(GNOLIG),[M:MBR]BOMNUM(GNOLIG), [M:MBR]BOMALT(GNOLIG),
#&                      [M:MBR]WENDDATD, [M:MBR]WENDDATF, [M:MBR]FCY,GNOLIG,[M:MBR]SERNUMF(GNOLIG))  From FUNBENCHR
        Call STKCTRSER(PSER, [M:ENT]ITMREF,[M:ENT]QTYSTU(nolign-1),[M:MBR]BOMNUM(GNOLIG), [M:MBR]BOMALT(GNOLIG),
&                      [M:MBR]WENDDATD, [M:MBR]WENDDATF, [M:MBR]FCY,nolign-1,[M:ENT]SERNUMF(nolign-1))  From FUNBENCHR
    Else
        Call STKCTRSER(PSER, [M]ITMREF,nolign-1,[M]NBLIG,nolign,
&                      [M:ENT]TRSTYP,[M:ENT]VCRTYP,[M:ENT]VCRNUM,[M:ENT]VCRLIN,
&                      [M:ENT]VCRTYPORI+(![M:ENT]VCRTYPORI)*4,[M:ENT]VCRNUMORI,[M:ENT]VCRLINORI,[M:ENT]VCRSEQORI,
&                      [F:ITM]SERCOU="" & [F:TLO]LOCCAT<>2,"") From STKACT
    Endif

End


############################################################
# Paramètres E : PNOL = n° de ligne à traiter
#            S : PRET = idem ctr_coherence_lig +
#                       8192 : complément lot à renseigner
#                      16384 : problème d'emplacement
#                      32768 : lignes identiques
############################################################
Subprog APRESNBLIG(PNOL, PRET)
Value Integer PNOL
Variable Integer PRET

Local Integer     LRET
Local Shortint    WRET
Local Char        LSLO(GLONSLO)
Local Char        LMAJ(GLONECS)
Local Char        LMIN(GLONECS)
Local Integer     LECC
Local Decimal     WOVF
Local Libelle LNOTPCU
Local Libelle LNOTCOE
Local Libelle LNOTSTA
Local Libelle LNOTLOC
Local Libelle LNOTLOF
Local Libelle LNOTLOT
Local Libelle LNOTSLO
Local Libelle LNOTPAL
Local Libelle LNOTCTR
Local Libelle LNOTSF1
Local Libelle LNOTSF2
#--- Issue X3-53322
Local Libelle LNOTLPN
Local Integer LDUP
Local Integer I
Local Char    WWRH(GLONWRH)
Local Integer LNBLPN   # hcb X3-64504
Raz PRET
GOUVENT = 0

If [M:ENT]WLOCSEQ(PNOL)=0 | [M:ENT]WLOCSEQ(PNOL)=100000
    Call STKDELRES(100000,"","",LRET) From STKLOC
    [M:ENT]WLOCSEQ(PNOL)=0
Endif

If dim([M:ENT]WRH) > 0
    WWRH=[M:ENT]WRH(PNOL)
Else
    WWRH=""
Endif
If adxgtb=1 | find(status,65,68,83)
    If [F:ITF]LOCMGTCOD=2 & dim([M:ENT]LOC) & [M:ENT]WLOCSEQ(PNOL)<>100000
        # Supprimer les réservations d'emplacements afin de montrer qu'on veut une réservation définitive
        If [M:ENTW]WLOCSEQCUR>100000 & [M:ENTW]WLOCSEQCUR<>99999999
          [M:ENTW]WLOCSEQCUR -= 100000
        Endif
        Call STKDELRES([M:ENTW]WLOCSEQCUR, [M:ENT]STOFCY, "", LRET) From STKLOC
        [M:ENTW]WLOCSEQCUR = 99999999
        If [M:ENT]WLOCSEQ(PNOL)>0
            # Recréer les réservations
            Call CALQTYPHY("ENT",PNOL) From TRTSTOENT
            Call STKCTREMP([M:ENT]WLOCSEQ(PNOL),
&                          [M:ENT]TRSTYP,
&                          [M:ENT]TRSCOD,
&                          [M:ENT]STOFCY,
&                          [M:ENT]ITMREF,
&                          [M:ENT]PCU(PNOL),
&                          GQTYPHY,
&                          [M:ENT]STA(PNOL),
&                          [M:ENT]LOCTYP(PNOL),
&                          [M:ENT]LOC(PNOL),
&                          [M:ENT]BPRNUM,
&                          0,
&                          WRET,
&                          WOVF,
&                          "",
&                          "",
&                          WWRH) From STKLOC
            [M:ENTW]WLOCSEQCUR = 99999999
        Endif
    Endif
#   End   hcb  42992
Endif

Gosub GESSELECTION From TRTSTOENTB
Affzo [M:ENT]PECQTY

If [M:ENT]QTYSTU(PNOL) = 0
   End
Endif

#--- 1 = ligne ajoutée par rapport à l etat initial = ligne détail
If [M:ENT]ORILIG(PNOL) = 0
    [M:ENT]ORILIG(PNOL) = 1
Endif

LNOTPCU = dim([M:ENT]PCU) <= 0
LNOTCOE = dim([M:ENT]PCUSTUCOE) <= 0
LNOTSTA = dim([M:ENT]STA) <= 0
LNOTLOC = dim([M:ENT]LOC) <= 0
LNOTLOF = dim([M:ENT]BPSLOTAFF) <= 0
LNOTLOT = dim([M:ENT]LOTAFF) <= 0
LNOTSLO = dim([M:ENT]SLOAFF) <= 0
LNOTPAL = dim([M:ENT]PALNUM) <= 0
LNOTCTR = dim([M:ENT]CTRNUM) <= 0
LNOTSER = dim([M:ENT]SERNUM) <= 0
LNOTSF1 = dim([M:ENT]STOFLD1) <= 0
LNOTSF2 = dim([M:ENT]STOFLD2) <= 0
#--- Issue X3-53322
LNOTLPN = dim([M:ENT]LPNNUM) <= 0

If !LNOTLOC & ( [F:TLO]LOCTYP<>[M:ENT]LOCTYP(PNOL) | [F:TLO]STOFCY<>[M:ENT]STOFCY )
    Read [TLO]TLO0=[M:ENT]STOFCY;[M:ENT]LOCTYP(PNOL)
Endif
Call CTR_COHERENCE_LIG("ENT", [M:ENT]STOFCY, PNOL, [M:ENT]VCRTYP, WRET) From STKENT

If WRET<2
    If WRET>0
        GOUVLOT = GOUVLOT-mod(GOUVLOT,2)+1    # Ouverture auto du complément lot
        GOUVENT = 1                           # Rien n'empêche l'ouverture du complément lot
    Endif
    [M:ENT]WFLG(PNOL)   = 2

Else
    Local Char MES(255)
    If mod(WRET ,2048)>=1024
        MES = mess(67,184,1)+"\"    # Ligne stock en inventaire
    Else
        MES = mess(7,111,1) +":\"
        If mod(WRET ,4)>=2
            MES += mess(25,197,1)+"\"    # Lot
        Endif
        If mod(WRET ,8)>=4
            MES += mess(456,197,1)+"\"    # Sous lot
        Endif
        If mod(WRET ,16)>=8
            MES += mess(47,197,1)+"\"    # N° de série
        Endif
        If mod(WRET ,32)>=16
            MES += mess(44,197,1)+"\"    # Emplacement
        Endif
        If mod(WRET ,64)>=32
            MES += mess(24,197,1)+"\"    # Statut
        Endif
        If mod(WRET,256)>=128
            MES += mess(26,184,1)+"\"    # Etiquette manquante
        Endif
        If mod(WRET,1024)>=512
            MES += mess(27,184,1)+"\"    # Emplacement de type quai à renseigner
        Endif
        If mod(WRET,4096)>=2048
            MES += mess(405,184,1)+"\"    # Version(s) non renseignée(s)
        Endif
        #--- Issue X3-53322
        If mod(WRET,8192)>=4096
            MES += mess(513,184,1)+"\"    # Contenant non renseigné
        Endif
        #---
    Endif
    If GACTION="SAISTKSPL"
        GMESSAGE=MES
    Else
        Call MESSAGE(MES) From GESECRAN  # Ligne incomplete
    Endif
Endif

#--- Issue X3-53322
#PRET = mod(WRET,2048)
PRET = mod(WRET,8192)
#---

# Si le lot et le sous lot ont été renseignés on affecte le complément lot à la ligne
If WRET=0 | (WRET>0 & mod(WRET,4)<2 & mod(WRET,8)<4)
   If dim([M:ENT]LOTAFF) >0                              # hcb 33757
      If [F:ITM]LOTMGTCOD=4
         If dim([M:ENT]SLOAFF) >0                        # ts  36075
            LSLO = [M:ENT]SLOAFF(PNOL)
         Else
            Raz LSLO
         Endif
      Else
         Raz LSLO
      Endif
      Raz LMAJ
      Raz LMIN
      If [F:ITM]ECCSTO >1
         If dim([M:ENT]ECCVALMAJAFF) >0
            LMAJ = [M:ENT]ECCVALMAJAFF(PNOL)
            LECC = [M:ENT]ECCSAIFLG(PNOL)
         Endif
      Endif
      If [F:ITM]ECCSTO =3
         If dim([M:ENT]ECCVALMINAFF) >0
            LMIN = [M:ENT]ECCVALMINAFF(PNOL)
            LECC = [M:ENT]ECCSAIFLG(PNOL)
         Endif
      Endif
      Call SETCPTLOTAUTO( [M:ENT]ITMREF, "ENT", PNOL, [M:ENT]LOTAFF(PNOL), LSLO, [M:ENT]BPSLOTAFF(PNOL), [M:ENT]GESLOTAFF(PNOL), LMAJ, LMIN,LECC, LRET) From STKENT
      GOUVENT = GOUVENT-mod(GOUVENT,2)+LRET-1
      #--- Issue X3-53322
      #PRET+=2048*(LRET=1)
      PRET+=8192*(LRET=1)
      #---
   Endif                                                 # hcb 33757
Endif

Call CALQTYPHY("ENT",PNOL) From TRTSTOENT

# Si emplacement renseigné correctement on crée la réservation
#--- Bug 31514 - TS le 29/07/05 ---
If [F:ITF]LOCMGTCOD=2 & (WRET=0 | (WRET>0 & mod(WRET,32)<16 & [F:ITF]LOCMGTCOD=2 & dim([M:ENT]LOC)>0))
    # Supprimer les réservations d'emplacements afin de montrer qu'on veut une réservation définitive
    If [M:ENT]WLOCSEQ(PNOL)>100000
      [M:ENT]WLOCSEQ(PNOL) -= 100000
    Endif
    Call STKDELRES([M:ENT]WLOCSEQ(PNOL), [M:ENT]STOFCY, [M:ENT]LOC(PNOL), LRET) From STKLOC
    If !LRET
        Call STKCTREMP([M:ENT]WLOCSEQ(PNOL),  [M:ENT]TRSTYP, [M:ENT]TRSCOD, [M:ENT]STOFCY,
&                      [M:ENT]ITMREF, [M:ENT]PCU(PNOL), GQTYPHY, [M:ENT]STA(PNOL),
&                      [M:ENT]LOCTYP(PNOL), [M:ENT]LOC(PNOL), [M:ENT]BPRNUM, 1, mkstat,
&                      WOVF, "", "",WWRH) From STKLOC
        #--- Issue X3-53322
        If mkstat=2
          #If GMESSAGE<>""
          #  Call ERREUR(GMESSAGE) From GESECRAN
          #Endif
          [M:ENT]WFLG(PNOL)=1
        Endif
        #---
   Endif
    #--- Issue X3-53322
    #PRET+    =4096*(mkstat=2)
    PRET+=16384*(mkstat=2)
   #---
Endif
[M:ENTW]WLOCSEQCUR=99999999

Raz I
# Interdiction de créer des lignes de stock identiques sur une même ligne de document
# car en modif on aurait un problème pour afficher la qté dispo sur chaque ligne

# hcb 53852
#--- Issue X3-53322 : ajout LPNNUM
LDUP = sigma(0,[M:ENT]NBLIG-1, (indcum+1)
&                    * (I=0
&                    & (indcum <> (PNOL))
&                    & [M:ENT]QTYSTU(indcum) <> 0
&                    & (LNOTPCU | [M:ENT]PCU(indcum)       = [M:ENT]PCU(PNOL))
&                    & (LNOTCOE | [M:ENT]PCUSTUCOE(indcum) = [M:ENT]PCUSTUCOE(PNOL))
&                    & (LNOTSTA | [M:ENT]STA(indcum)       = [M:ENT]STA(PNOL))
&                    & (LNOTLOC | [M:ENT]LOC(indcum)       = [M:ENT]LOC(PNOL))
&                    & (LNOTLOF | [M:ENT]BPSLOTAFF(indcum) = [M:ENT]BPSLOTAFF(PNOL))
&                    & (LNOTLOT | [M:ENT]LOTAFF(indcum)    = [M:ENT]LOTAFF(PNOL))
&                    & (LNOTSLO | [M:ENT]SLOAFF(indcum)    = [M:ENT]SLOAFF(PNOL))
&                    & (LNOTPAL | [M:ENT]PALNUM(indcum)    = [M:ENT]PALNUM(PNOL))
&                    & (LNOTCTR | [M:ENT]CTRNUM(indcum)    = [M:ENT]CTRNUM(PNOL))
&                    & (LNOTSF1 | [M:ENT]STOFLD1(indcum)   = [M:ENT]STOFLD1(PNOL))
&                    & (LNOTSF2 | [M:ENT]STOFLD2(indcum)   = [M:ENT]STOFLD2(PNOL))
&                    & (LNOTLPN | [M:ENT]LPNNUM(indcum)    = [M:ENT]LPNNUM(PNOL))
&                    & (LNOTSER | ([M:ENT]SERNUM(indcum)   >= [M:ENT]SERNUM(PNOL)
&                                &[M:ENT]SERNUM(indcum)   <= [M:ENT]SERNUMF(PNOL)
&                                &len([M:ENT]SERNUM(indcum))= len([M:ENT]SERNUM(PNOL))))
&                    & sigma(I=1,1,1)) )
If LDUP
    [M:ENT]WFLG(PNOL)=1
    If GMESSAGE=""
        If GACTION="SAISTKSPL"

            GMESSAGE=mess(59,184,1)-num$(LDUP)
            #---  Issue X3-53322
            #PRET += 8192
            PRET += 32768
            #---
        Else
            Call ERREUR(mess(59,184,1)-num$(LDUP)) From GESECRAN
        Endif
    Endif
    mkstat = 2
Endif
#                                                               # hcb X3-64504 deb

If mkstat=0 & [F:ITF]LPNMGTCOD = 2 & dim([M:ENT]LPNNUM) >0 : #--- Issue X3-53322 ajout mkstat=0
   Call CALCUL_NBLPN([M:ENT]LPNNUM(PNOL),[M:ENT]TCTRNUM(PNOL),[M:ENT]ITMREF,[M:ENT]STOFCY,[M:ENT]PCU(PNOL),[M:ENT]QTYPCU(PNOL),LNBLPN) From STKLPN
   [M:ENT]NBLPN(PNOL) = LNBLPN
   Affzo [M:ENT]NBLPN(PNOL)
Endif
#                                                               # hcb X3-64504 deb

End

############################################################
# Paramètres E : PNOL = n° de ligne à traiter
#            S : PRET = idem ctr_coherence_lig +
#                       8192 : complément lot à renseigner
#                      16384 : problème d'emplacement
#                      32768 : lignes identiques
############################################################
Subprog APRESNBLIGM(PNOL, PRET)
Value Integer PNOL
Variable Integer PRET

Local Integer     LRET
Local Shortint    WRET
Local Shortint    MK
Local Decimal     WOVF
Local Char        LSLO(GLONSLO)
Local Char        LMAJ(GLONECS)
Local Char        LMIN(GLONECS)
Local Integer     LECC
Local Libelle LNOTPCU
Local Libelle LNOTCOE
Local Libelle LNOTSTA
Local Libelle LNOTLOC
Local Libelle LNOTLOF
Local Libelle LNOTLOT
Local Libelle LNOTSLO
Local Libelle LNOTSER
Local Libelle LNOTPAL
Local Libelle LNOTCTR
Local Libelle LNOTSF1
Local Libelle LNOTSF2
#--- Issue X3-53322
Local Libelle LNOTLPN
Local Integer LDUP
Local Integer I
Local Char    WWRH(GLONWRH)

Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS
Local Decimal WSTODISTOT
Local Integer WISTA, WILOC

Local Integer LSAVSTATUS : LSAVSTATUS=status    # Status =1 après affzo !!!!!!!
GOUVENT = 0
If [M:ENM]WLOCSEQ(PNOL)=100000
    Call STKDELRES(100000,"","",LRET) From STKLOC
    [M:ENM]WLOCSEQ(PNOL)=0
Endif

If [M:ENM]MVTSEQ(PNOL)>0
    WISTA = (left$([M:ENM]STAO(PNOL),1)="A")+(left$([M:ENM]STAO(PNOL),1)="Q")*2+(left$([M:ENM]STAO(PNOL),1)="R")*4
    If [M:ENM]LOCCATO(PNOL)=4
       WILOC = [M:ENM]LOCCATO(PNOL)
    Else
       WILOC = [M:ENM]LOCCATO(PNOL)-1
    Endif

    If [M:ENM]STOCOU(PNOL)<>0     # La ligne de stock correspondante existe-t-elle
        Read [STO]STO0=[M:ENM]STOFCY;[M:ENM]STOCOU(PNOL)
        Call STODIS("[F:STO]","[F:ITM]","",WPCUDIS,[M:ENM]STUDIS(PNOL),WSTUACTDIS) From STKLIB
    Else
        [M:ENM]STUDIS(PNOL) = 0
    Endif

   #------- Il faut se positionner sur STJ car le stock n'est peut-être plus présent -------#
   Read [STJ]STJ0=[M:ENM]STOFCY;2;[M:ENM]ITMREF;[M:ENM]IPTDAT;[M:ENM]MVTSEQ(PNOL)
   If  [M:ENM]QTYSTUO(PNOL)   > [M:ENM]STUDIS(PNOL)
&    &([M:ENM]PCU(PNOL)      <> [F:STJ]PCU
&    | [M:ENM]STA(PNOL)      <> [F:STJ]STA
&    | dim([M:ENM]LOC)>0       & [M:ENM]LOC(PNOL)      <> [F:STJ]LOC
&    | dim([M:ENM]BPSLOTAFF)>0 & [M:ENM]BPSLOTAFF(PNOL)<> [F:STJ]BPSLOT
&    | dim([M:ENM]LOTAFF)>0    & [M:ENM]LOTAFF(PNOL)   <> [F:STJ]LOT
&    | dim([M:ENM]SLOAFF)>0    & [M:ENM]SLOAFF(PNOL)   <> [F:STJ]SLO )

        Call ERREUR(mess(818,196,1)) From GESECRAN
        [M:ENM]PCU(PNOL)      = [F:STJ]PCU          : Affzo [M:ENM]PCU(PNOL)
        [M:ENM]PCUSTUCOE(PNOL)= [F:STJ]PCUSTUCOE    : Affzo [M:ENM]PCUSTUCOE(PNOL)
        [M:ENM]QTYPCU(PNOL)   = [M:ENM]QTYPCUO(PNOL) : Affzo [M:ENM]QTYPCU(PNOL)
        [M:ENM]QTYSTU(PNOL)   = [M:ENM]QTYSTUO(PNOL) : Affzo [M:ENM]QTYSTU(PNOL)
        [M:ENM]STA(PNOL)      = [F:STJ]STA          : Affzo [M:ENM]STA(PNOL)
        If dim([M:ENM]LOC)>0
            [M:ENM]LOC(PNOL)      = [F:STJ]LOC : Affzo [M:ENM]LOC(PNOL)
            Read [STC]STC0=[M:ENM]STOFCY;[M:ENM]LOC(PNOL)
            [M:ENM]LOCTYP(PNOL)   = [F:STC]LOCTYP : Affzo [M:ENM]LOCTYP(PNOL)
            If dim([M:ENM]WRH)>0
              [M:ENM]WRH(PNOL)      = [F:STJ]WRH : Affzo [M:ENM]WRH(PNOL)
            Endif
        Endif
        If dim([M:ENM]BPSLOTAFF)>0
            [M:ENM]BPSLOTAFF(PNOL)= [F:STJ]BPSLOT : Affzo [M:ENM]BPSLOTAFF(PNOL)
        Endif
        If dim([M:ENM]LOTAFF)>0
            [M:ENM]LOTAFF(PNOL)   = [F:STJ]LOT : Affzo [M:ENM]LOTAFF(PNOL)
        Endif
        If dim([M:ENM]SLOAFF)>0
            [M:ENM]SLOAFF(PNOL)   = [F:STJ]SLO : Affzo [M:ENM]SLOAFF(PNOL)
        Endif
        If dim([M:ENM]ECCVALMAJAFF)>0
            [M:ENM]ECCVALMAJAFF(PNOL)   = [F:STJ]ECCVALMAJ : Affzo [M:ENM]ECCVALMAJ(PNOL)
        Endif
        If dim([M:ENM]ECCVALMINAFF)>0
            [M:ENM]ECCVALMINAFF(PNOL)   = [F:STJ]ECCVALMIN : Affzo [M:ENM]ECCVALMIN(PNOL)
        Endif
   Endif
Endif

status=LSAVSTATUS
#If adxgtb=1 | find(status,6,7,27,28,65,68,83) | status>=1792  # hcb 102567
If find(status,6,7,27,28,65,68,83) | status>=1792              # hcb 102567
    Call STKDELRES(-100000,"","",LRET) From STKLOC
    End
Endif


Gosub GESSELECTION From TRTSTOENTB
Affzo [M:ENM]PECQTY

status=LSAVSTATUS

#--- 1 = ligne ajoutée par rapport à l etat initial = ligne détail
If [M:ENM]ORILIG(PNOL) = 0
   [M:ENM]ORILIG(PNOL) = 1
   Raz [M:ENM]IPTDAT(PNOL)
   Raz [M:ENM]MVTSEQ(PNOL)
   Raz [M:ENM]MVTIND(PNOL)
Endif

LNOTPCU = dim([M:ENM]PCU) <= 0
LNOTCOE = dim([M:ENM]PCUSTUCOE) <= 0
LNOTSTA = dim([M:ENM]STA) <= 0
LNOTLOC = dim([M:ENM]LOC) <= 0
LNOTLOF = dim([M:ENM]BPSLOTAFF) <= 0
LNOTLOT = dim([M:ENM]LOTAFF) <= 0
LNOTSLO = dim([M:ENM]SLOAFF) <= 0
LNOTSER = dim([M:ENM]SERNUM) <= 0
LNOTPAL = dim([M:ENM]PALNUM) <= 0
LNOTCTR = dim([M:ENM]CTRNUM) <= 0
LNOTSF1 = dim([M:ENM]STOFLD1) <= 0
LNOTSF2 = dim([M:ENM]STOFLD2) <= 0
#--- Issue X3-53322
LNOTLPN = dim([M:ENM]LPNNUM) <= 0

If !LNOTLOC & ( [F:TLO]LOCTYP<>[M:ENM]LOCTYP(PNOL) | [F:TLO]STOFCY<>[M:ENM]STOFCY )
    Read [TLO]TLO0=[M:ENM]STOFCY;[M:ENM]LOCTYP(PNOL)
Endif
Call CTR_COHERENCE_LIG("ENM", [M:ENM]STOFCY, PNOL, [M:ENM]VCRTYP, WRET) From STKENT
If WRET<2
    If WRET>0
        GOUVLOT = GOUVLOT-mod(GOUVLOT,2)+1    # Ouverture auto du complément lot
        GOUVENT = 1                           # Rien n'empêche l'ouverture du complément lot
    Endif
    [M:ENM]WFLG(PNOL)   = 2
Else
    Local Char MES(255)
    If mod(WRET ,1024)>=512
        MES = mess(67,184,1)+"\"    # Ligne stock en inventaire
    Else
        MES = mess(7,111,1) +":\"
        If mod(WRET ,4)>=2
            MES += mess(25,197,1)+"\"    # Lot
        Endif
        If mod(WRET ,8)>=4
            MES += mess(456,197,1)+"\"    # Sous lot
        Endif
        If mod(WRET ,16)>=8
            MES += mess(47,197,1)+"\"    # N° de série
        Endif
        If mod(WRET ,32)>=16
            MES += mess(44,197,1)+"\"    # Emplacement
        Endif
        If mod(WRET ,64)>=32
            MES += mess(24,197,1)+"\"    # Statut
        Endif
        If mod(WRET,256)>=128
            MES += mess(26,184,1)+"\"    # Etiquette manquante
        Endif
        If mod(WRET,512)>=256
            MES += mess(27,184,1)+"\"    # Emplacement de type quai à renseigner
        Endif
        If mod(WRET,4096)>=2048
            MES += mess(405,184,1)+"\"    # Version(s) non renseignée(s)
        Endif
        #--- Issue X3-53322
        If mod(WRET,8192)>=4096
            MES += mess(525,184,1)+"\"    # Numéro contenant non renseigné
        Endif
        #---

    Endif

    Call MESSAGE(MES) From GESECRAN  # Ligne incomplete
Endif

#--- Issue X3-53322
#PRET = mod(WRET,2048)
PRET = mod(WRET,8192)
#---

# Si le lot et le sous lot ont été renseignés on affecte le complément lot à la ligne
If WRET=0 | (WRET>0 & mod(WRET,4)<2 & mod(WRET,8)<4)
   If dim([M:ENM]LOTAFF) >0                              # hcb 33757
      If [F:ITM]LOTMGTCOD=4
         If dim([M:ENM]SLOAFF) >0                        # ts  36075  + hcb 41229
            LSLO = [M:ENM]SLOAFF(PNOL)
         Else
            Raz LSLO
         Endif
      Else
         Raz LSLO
      Endif
      Raz LMAJ
      Raz LMIN
      Raz LECC
      If [F:ITM]ECCSTO > 1
         If dim([M:ENM]ECCVALMAJAFF) >0
            LMAJ = [M:ENM]ECCVALMAJAFF(PNOL)
            LECC = [M:ENM]ECCSAIFLG(PNOL)
         Endif
      Endif
      If [F:ITM]ECCSTO =3
         If dim([M:ENM]ECCVALMINAFF) >0
            LMIN = [M:ENM]ECCVALMINAFF(PNOL)
            LECC = [M:ENM]ECCSAIFLG(PNOL)
         Endif
      Endif

      Call SETCPTLOTAUTO( [M:ENM]ITMREF, "ENM", PNOL, [M:ENM]LOTAFF(PNOL), LSLO, [M:ENM]BPSLOTAFF(PNOL), [M:ENM]GESLOTAFF(PNOL), LMAJ ,LMIN,LECC, LRET) From STKENT
      GOUVENT = GOUVENT-mod(GOUVENT,2)+LRET-1
      #--- Issue X3-53322
      #PRET+=2048*(LRET=1)
      PRET+=8192*(LRET=1)
      #---
   Endif                                                 # hcb 33757
Endif

# Si emplacement renseigné correctement on crée la réservation
If WRET=0 | (WRET>0 & mod(WRET,32)<16 & [F:ITF]LOCMGTCOD=2)
    If dim([M:ENM]WRH) > 0
        WWRH=[M:ENM]WRH(nolign-1)
    Else
        WWRH=""
    Endif
    Call STKWLOCSEQ("ENM", nolign-1, LRET) From STKECR
    If !LRET
        Call STKCTRTLO([M:ENM]WLOCSEQ(nolign-1), [M:ENM]TRSTYP, [M:ENM]TRSCOD, [M:ENM]STOFCY,
&                      [M:ENM]ITMREF, [M:ENM]PCU(nolign-1), [M:ENM]QTYPCU(nolign-1), [M:ENM]STA(nolign-1),
&                      1, [M:ENM]LOCTYP(nolign-1), mkstat, "", "",WWRH) From STKLOC
        If !mkstat
            Call STKCHGRES(-100000,-[M:ENM]WLOCSEQ(nolign-1),LRET) From STKLOC
            Call STKCTREMP([M:ENM]WLOCSEQ(nolign-1),  [M:ENM]TRSTYP, [M:ENM]TRSCOD, [M:ENM]STOFCY,
&                          [M:ENM]ITMREF, [M:ENM]PCU(nolign-1), [M:ENM]QTYPCU(nolign-1), [M:ENM]STA(nolign-1),
&                          [M:ENM]LOCTYP(nolign-1), [M:ENM]LOC(nolign-1), [M:ENM]BPRNUM, 1, mkstat,
&                          WOVF, "", "",WWRH) From STKLOC
        Endif
    Endif
    #--- Issue X3-53322
    #PRET+=4096*(LRET<>0 | mkstat<>0)
    PRET+=16384*(LRET<>0 | mkstat<>0)
   #---
Endif
[M:ENTW]WLOCSEQCUR = 99999999

Raz I
#--- Issue X3-53322 : ajout LPNNUM
LDUP = sigma(0,[M:ENM]NBLIG-1, (indcum+1)
&                    * (I=0
&                    & (indcum <> (nolign-1))
&                    & (LNOTPCU | [M:ENM]PCU(indcum)       = [M:ENM]PCU(nolign-1))
&                    & (LNOTCOE | [M:ENM]PCUSTUCOE(indcum) = [M:ENM]PCUSTUCOE(nolign-1))
&                    & (LNOTSTA | [M:ENM]STA(indcum)       = [M:ENM]STA(nolign-1))
&                    & (LNOTLOC | [M:ENM]LOC(indcum)       = [M:ENM]LOC(nolign-1))
&                    & (LNOTLOF | [M:ENM]BPSLOTAFF(indcum) = [M:ENM]BPSLOTAFF(nolign-1))
&                    & (LNOTLOT | [M:ENM]LOTAFF(indcum)    = [M:ENM]LOTAFF(nolign-1))
&                    & (LNOTSLO | [M:ENM]SLOAFF(indcum)    = [M:ENM]SLOAFF(nolign-1))
&                    & (LNOTSER | [M:ENM]SERNUM(indcum)    = [M:ENM]SERNUM(nolign-1) & [M:ENM]SERNUM(nolign-1)<>"")
&                    & (LNOTPAL | [M:ENM]PALNUM(indcum)    = [M:ENM]PALNUM(nolign-1))
&                    & (LNOTCTR | [M:ENM]CTRNUM(indcum)    = [M:ENM]CTRNUM(nolign-1))
&                    & (LNOTSF1 | [M:ENM]STOFLD1(indcum)   = [M:ENM]STOFLD1(nolign-1))
&                    & (LNOTSF2 | [M:ENM]STOFLD2(indcum)   = [M:ENM]STOFLD2(nolign-1))
&                    & (LNOTLPN | [M:ENM]LPNNUM(indcum)    = [M:ENM]LPNNUM(nolign-1))
&                    & sigma(I=1,1,1)) )
If LDUP
    [M:ENM]WFLG(nolign-1)=1

    Call ERREUR(mess(59,184,1)-num$(LDUP)) From GESECRAN
    mkstat = 2
    #---  Issue X3-53322
    #PRET += 8192
    PRET += 32768
    #---
Endif

End

#**-----------------------------------------------------<br/>
#* CHECK_NCS : Check if there are any non-conformances
#**<br/>------------------------------------------------<br/>
#* @param WRET = User response to question (2=Yes, 1=No)
#**<br/>------------------------------------------------
#*!
Subprog CHECK_NCS (WRET)
Variable Integer WRET
# Setup global variables if they have not been and reset the value to 0
If dim (GNCSHDRFLG) < 0 Global Integer GNCSHDRFLG Endif
GNCSHDRFLG = 0
If dim (GNCSLINFLG) < 0 Global Integer GNCSLINFLG Endif
GNCSLINFLG = 0

Local Char NCSMESS(255)
Local Integer EXISTS
Local Integer DOCUTYP
Local Integer LINES
LINES = -1

    # Get the number of detail lines left on the source document and the type
    If [M:ENM]VCRTYP = 6
        [L]LINES = [M:PTH1]NBLIG
        [L]DOCUTYP = 1
    Elsif [M:ENM]VCRTYP = 13
        [L]LINES = [M:SRH1]NBLIG
        [L]DOCUTYP = 2
    Elsif [M:ENM]VCRTYP = 15
        If dim([M:MTK2]NBITM) > 0
            [L]LINES = [M:MTK2]NBITM
        Endif
        [L]DOCUTYP = 3
    Endif
    If [L]LINES = 1
        # This is the last line so if we delete the line the header will be deleted so we need to check for both
        [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS ([L]DOCUTYP, [M:ENM]VCRNUM, [M:ENM]VCRLIN, [L]NCSMESS, 1)
        # There is a non-conformance on the line so we need to tell the user
        If [L]EXISTS = 1
            Call OUINON([L]NCSMESS,[L]WRET) From GESECRAN
            GNCSLINFLG = 1
            If [L]WRET = 1
                End
            Endif
        # There is a non-conformance on the line so we need to check the header
        [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS ([L]DOCUTYP, [M:ENM]VCRNUM, 0, [L]NCSMESS, 1)
        Endif

        # If exists is > 0 then the first check returned a header NC, or there was a line NC and we checked for a header NC
        If [L]EXISTS > 0
            Call OUINON([L]NCSMESS,[L]WRET) From GESECRAN
            GNCSLINFLG = 1
            GNCSHDRFLG = 1
            If [L]WRET = 1
                End
            Endif
        Endif
    Elsif [L]LINES > 1
        # This is not the last line therefore we only need to check for the line
        [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS ([L]DOCUTYP, [M:ENM]VCRNUM, [M:ENM]VCRLIN, [L]NCSMESS, 1)
        If [L]EXISTS > 0
            Call OUINON([L]NCSMESS,[L]WRET) From GESECRAN
            GNCSLINFLG = 1
            If [L]WRET = 1
                End
            Endif
        Endif
    Endif
End

