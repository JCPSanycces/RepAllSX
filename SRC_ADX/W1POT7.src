#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque POT7 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:03"
A_USER  = "DOC"
A_STAMP = "20181109230603"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRHAB"
  If [M]NBRHAB=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask POT7 [POT7]
Gosub HORODAT
Local Inpbox "POT7" From GFONCTION At A_STAMP With A_WINDPREV Mask [POT7] As [SIM_]
Grizo [POT7]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [POT7]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=80 : Y1(0)=1 : Y2(0)=24
Return

$ON_HAB
Onevent BEFORE_INPUT Call AS_HAB(zc) From W1POT7
Onevent CONTROL Call C_HAB(zc) From W1POT7
Return

Subprog AS_HAB(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(47613,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRLIC
Call DEFHRLIC(VALEUR,[V]GCURLEG,"") From SUBHRLIC
If mkstat=2
 [M]HAB(INDIC) = VALEUR
 Affzo HAB(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_HAB(zc) From W1POT7
Onkey   2 Titled GBOUTS Call S_HAB(zc) From W1POT7
Onkey 144 Titled GBOUTP Call P_HAB(zc) From W1POT7
Onkey 146 Titled GBOUTA Call SA_HAB(zc) From W1POT7
Gosub _AFF
End

Subprog C_HAB(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "HAB" : GZNUM = 15802 : Endif
If !mkstat
 ## Action CONTHRLIC
 Call CONTHRLIC(VALEUR,[V]GCURLEG,"") From SUBHRLIC
 If mkstat : GERR = 1 : GZONE = "HAB" : GZNUM = 15802 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "HAB" : GZNUM = 15802 : Endif
  If !mkstat
   ## Action STD
   Call C_HAB(VALEUR) From SUBPOT
   If mkstat : GERR = 1 : GZONE = "HAB" : GZNUM = 15802 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_HAB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRLIC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRLIC"
 PARMSK(1) = [V]GCURLEG
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRLIC","SUBHRLIC","SPEHRLIC") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_HAB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRLIC
 Call TUNHRLIC(VALEUR,[V]GCURLEG,"") From SUBHRLIC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_HAB(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRLIC"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_HAB(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRLIC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$CHG_STY
Return


