$EMPLOIDSA_RSAID_CONTROL
Local Integer RSAID_NUM(1..13)
Local Integer COUNTER
Local Integer TEMP_CALC1, TEMP_CALC2, TEMP_CALC3, TEMP_CALC4
Local Char    TEMP_CHAR1(30)
Local Char    BIRTHYEAR(4),BIRTHMONTH(2),BIRTHDAY(2),IDYEAR(4),IDMONTH(2),IDDAY(2)

If this.RSAID="0" or this.RSAID=""
  Return
Endif

If clalev([F:ESA1])=0 : Local File EMPLOIDSA    [ESA1]         : Endif
Filter [ESA1] Where [ESA1]RSAID = this.RSAID and this.REFNUM <> [ESA1]REFNUM
Read [ESA1] First
If fstat = [V]CST_AOK
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(47,11662,1),[V]CST_AERROR)
Endif
Filter [ESA1]

COUNTER=0
For COUNTER=1 To 13
  If ascii(mid$(this.RSAID,COUNTER,1))>=48 &ascii(mid$(this.RSAID,COUNTER,1)) <=57
    RSAID_NUM(COUNTER)=val(mid$(this.RSAID,COUNTER,1))
  Else
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(4,11662,1),[V]CST_AERROR)
  Endif
Next

TEMP_CALC1=RSAID_NUM(1)+RSAID_NUM(3)+RSAID_NUM(5)+RSAID_NUM(7)+RSAID_NUM(9)+RSAID_NUM(11)
TEMP_CALC2=(RSAID_NUM(2)*100000)+(RSAID_NUM(4)*10000)+(RSAID_NUM(6)*1000)+(RSAID_NUM(8)*100)+(RSAID_NUM(10)*10)+(RSAID_NUM(12))
TEMP_CALC2=TEMP_CALC2*2
TEMP_CHAR1=num$(TEMP_CALC2)

For COUNTER=1 To val(string$(TEMP_CALC2<1000000,"6")+string$(TEMP_CALC2>=1000000,"7"))
  TEMP_CALC3+=val(mid$(TEMP_CHAR1,COUNTER,1))
Next

TEMP_CALC3+=TEMP_CALC1
TEMP_CALC3=mod(TEMP_CALC3,10)

If TEMP_CALC3<>0OJ
  TEMP_CALC3=10-TEMP_CALC3
Endif

If TEMP_CALC3<>RSAID_NUM(13)
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(1,11662,1),[V]CST_AERROR)
Endif
Return

$EMPLOIDSA_ADDPRI_INIT
Local Integer AC
Local Integer PRNR

  If this.ADDPRI=0
    PRNR=1
    For AC=1 To maxtab(this.APARENT.EMPADR)
      If find(this.APARENT.EMPADR(AC).ASTALIN, [V]CST_ANEWDEL, [V]CST_ADEL)=0
        If this.APARENT.EMPADR(AC).ADDPRI=PRNR
          PRNR+=1
        Endif
      Endif
    Next
    this.ADDPRI=PRNR
  Endif

Return


$EMPLOIDSA_ADDPRI_PROPOGATE
Local    Integer TYP1, TYP2, TYP3

#If this.ADDTYP = 0
#    If !find(1,this.ADDTYP) Then this.ADDTYP = 1 : End : Endif
#    If !find(2,this.ADDTYP) Then this.ADDTYP = 2 : End : Endif
#    If !find(3,this.ADDTYP) Then this.ADDTYP = 3 : End : Endif
#Endif

If this.ADDPRI < 1 or this.ADDPRI > 3 Then
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(83,123,1),[V]CST_AERROR)
Endif
Return

$EMPLOIDSA_ADDSRVTYP_INIT

If this.ADDTYP <> 2
  this.ADDSRVTYP=0
  #Grizo [M:EMP1]ADDSRVTYP(nolign-1)
Else
  #Actzo [M:EMP1]ADDSRVTYP(nolign-1)
Endif
#TODO


For I = 1 To maxtab(this.APARENT.EMPADR)
  If find(this.APARENT.EMPADR(I).ASTALIN, [V]CST_ANEWDEL, [V]CST_ADEL)=0
    If this.APARENT.EMPADR(I).ADDTYP <> 2
     this.APARENT.EMPADR(I).ADDTYP = 0
    Endif
  Endif
Next

#Call ENABLE_DISABLE_FOR_POSTAL_ADDRESS(this.ADDSRVTYP)
Return

$EMPLOIDSA_ADDSRVTYP_PROPOGATE

#ASTATUS=fmet this.ASETERROR([L]CURPRO,num$(this.ADDSRVTYP),[V]CST_AERROR)
Gosub ENABLE_DISABLE_FOR_POSTAL_ADDRESS

Return

$EMPLOIDSA_ADDPOSNUM_CONTROL

If this.ADDTYP = 2 Then
  If find(this.ADDSRVTYP, 1, 2, 3) > 0 Then
    If this.ADDPOSNUM = "" Then
      ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(10,123,1),[V]CST_AERROR)
    Endif
  Endif
Endif

Return

$EMPLOIDSA_ADDPOSNAM_CONTROL

If this.ADDTYP = 2 Then
  If find(this.ADDSRVTYP, 1, 2, 3) > 0 Then
    If this.ADDPOSNAM = "" Then
      ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(10,123,1),[V]CST_AERROR)
    Endif
  Endif
Endif

Return

$EMPLOIDSA_ADDSTRNAM_CONTROL

If this.ADDTYP <> 2 Then
  If this.ADDSTRNAM = "" Then
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(10,123,1),[V]CST_AERROR)
  Endif
Endif

Return

$EMPLOIDSA_ADDTWN_CONTROL

If this.ADDTYP = 2 Then
  If this.ADDSRVTYP = 5 Then
    If this.ADDTWN = "" & this.ADDSUB = "" Then
      GMESSAGE = mess(26,11662,1)
      ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(26,11662,1),[V]CST_AERROR)
    Endif
  Endif
Else
  If this.ADDTWN = "" & this.ADDSUB = "" Then
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(26,11662,1),[V]CST_AERROR)
  Endif
Endif

Return

$EMPLOIDSA_ADDPOSCDE_CONTROL

If this.ADDTYP <> 2 or this.ADDSRVTYP <> 4 Then
  If this.ADDPOSCDE = "" Then
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(10,123,1),[V]CST_AERROR)
  Endif
Endif

Return

$EMPLOIDSA_ADDCNTCDE_INIT

If this.ADDCNTCDE=""
 this.ADDCNTCDE="SA"
Endif

Return

