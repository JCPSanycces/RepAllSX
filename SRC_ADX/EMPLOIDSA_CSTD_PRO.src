$C_DEFAULTRES
Variable Integer RESIND, LINENUM, I

RESIND = 0
#ASTATUS=fmet this.ASETERROR([L]CURPRO,num$(I)-num$(this(I).ADDTYP),[V]CST_AERROR)
#ASTATUS=fmet this.ASETERROR([L]CURPRO,num$(maxtab(this.APARENT.EMPADR)),[V]CST_AERROR)

If this.ADDSRVTYP = 4
    For I = 1 To maxtab(this.APARENT.EMPADR)
      If this.APARENT.EMPADR(I).ADDTYP = 1
         K  =  I
         RESIND = 1
      Endif
    Next

    If RESIND = 0
       ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(50,11662,1),[V]CST_AERROR)

       this.ADDTYP = 1
       #TODO
       #Affzo [M:EMP1]ADDTYP(nolign-1)

       this.ADDSRVTYP = 0
       #TODO
       #Affzo [M:EMP1]ADDSRVTYP(nolign-1)

    Else
       this.ADDPOSOTH  = this.APARENT.EMPADR(K).ADDPOSOTH
       this.ADDPOSNUM  = this.APARENT.EMPADR(K).ADDPOSNUM
       this.ADDPOSNAM  = this.APARENT.EMPADR(K).ADDPOSNAM
       this.ADDPOSAGN  = this.APARENT.EMPADR(K).ADDPOSAGN
       this.ADDCPX     = this.APARENT.EMPADR(K).ADDCPX
       this.ADDSTRNUM  = this.APARENT.EMPADR(K).ADDSTRNUM
       this.ADDSTRNAM  = this.APARENT.EMPADR(K).ADDSTRNAM
       this.ADDSUB     = this.APARENT.EMPADR(K).ADDSUB
       this.ADDTWN     = this.APARENT.EMPADR(K).ADDTWN
       this.ADDPOSCDE  = this.APARENT.EMPADR(K).ADDPOSCDE
       this.ADDCNTCDE  = this.APARENT.EMPADR(K).ADDCNTCDE
       this.ADDPRV     = this.APARENT.EMPADR(K).ADDPRV
       this.ADDPOSCOF  = this.APARENT.EMPADR(K).ADDPOSCOF
       this.ADDPOSINM  = this.APARENT.EMPADR(K).ADDPOSINM
       this.ADDSTA     = this.APARENT.EMPADR(K).ADDSTA
