  When "RSAID"                            : Gosub EMPLOIDSA_RSAID
  When "EMPADR.ADDPRI"                    : Gosub EMPLOIDSA_ADDPRI
  When "EMPADR.ADDSRVTYP"                 : Gosub EMPLOIDSA_ADDSRVTYP
  When "EMPADR.ADDPOSNUM"                 : Gosub EMPLOIDSA_ADDPOSNUM
  When "EMPADR.ADDPOSNAM"                 : Gosub EMPLOIDSA_ADDPOSNAM
  When "EMPADR.ADDSTRNAM"                 : Gosub EMPLOIDSA_ADDSTRNAM
  When "EMPADR.ADDTWN"                    : Gosub EMPLOIDSA_ADDTWN
  When "EMPADR.ADDPOSCDE"                 : Gosub EMPLOIDSA_ADDPOSCDE
  When "EMPADR.ADDCNTCDE"                 : Gosub EMPLOIDSA_ADDCNTCDE
  When "EMPADR.ADDCOR"                    : Gosub EMPLOIDSA_ADDCOR
  When "EMPADR.ADDPOSCOF"                 : Gosub EMPLOIDSA_ADDPOSCOF
Endcase
Return

