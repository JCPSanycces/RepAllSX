#<AdxTL>@(#)9.0.0.0 $Revision$
################################################################################################
#                                                                                              #
# Traitement de saisie des critères de picking en gestion des retours de ventes V150           #
#                                                                                              #
# Traitement SUBSCRR / Action SAICRITSRH                                                       #
#                                                                                              #
################################################################################################
# Appelée en gestion des retours depuis le menu option                                         #
################################################################################################
$ACTION
#--- Actions liées à la fenêtre de saisie ICRITSIH
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : REP="M"
 When "OK"          : Gosub OK
 When "ABA"         : Gosub ABA
Endcase
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE  
 When "FIN_TABLE"   : Gosub FIN_TABLE  
Endcase
Return

#---------------------#
# Sélection sur champ #
#---------------------#
$SEL_TABLE
Case COUZON
  When "CRISDHNUM" 
    OBJET="SDH"
    # Critères livraisons : 
    # Les livraisons doivent être validées, ni prêts, ni sous-traitance,
    If [M]LNDRTN<>2
        CRITERE ='CFMFLG=2 & LND<>2 & SCO<>2'
    # Les livraisons doivent être validées et de sous traitance
    Elsif [M]SCORTN<>2
        CRITERE ='CFMFLG=2 & SCO = 2 & INVFLG<>2'
    # Les livraisons doivent être validées et de prêts
    Else
        CRITERE ='CFMFLG=2 & LND=2  & INVFLG<>2'
    Endif
  When "CRIPNHNUM" 
    OBJET="PNH"
    # Critères retour fournisseur : 
    # Les retours fournisseurs doivent être inter-sites et validés
    CRITERE ='BETFCY=2 & CFMFLG=2'
Endcase
Return

$FIN_TABLE
Return

#---------------------------------------------------------#
# Chargement du masque critères de picking                #
#---------------------------------------------------------#
$DEBUT
Local Char WABREV : WABREV=PARAM(1)

Case WABREV
    When "SRH0"    : # retour client
        [M]LNDRTN = 1
        [M]SCORTN = 1
    When "SRS0"    : # retour matière pour sous traitance
        [M]LNDRTN = 1
        [M]SCORTN = 2
    When Default   : # retour de prêt
        [M]LNDRTN = 2
        [M]SCORTN = 1
Endcase


Actzo [M:SCRR]1-99

If [M]LNDRTN<>2 & [M]SCORTN <>2
    # Retour client
    [M:SCRR]=[M:SRH0]
    Gosub AFFICH_SRH
Elsif [M]SCORTN = 2
    # Retour de matière pour sous traitance
    [M:SCRR]=[M:SRS0]
    Gosub AFFICH_SRS
Else
    # Retour de prêt
    [M:SCRR]=[M:SRL0]
    Chgfmt [M]CRIPNHNUM With "-K:1X"
    Gosub AFFICH_SRL
Endif

If [M:SCRR]CRIITMREF="" Raz [M:SCRR]CRIITMDES Endif

Return

$AFFICH_SRH
If [M:SRH1]NBLIG<>0 & sum([M:SRH1]DETSDHNUM)<>"" 
    # On a déjà pické des lignes de livraison
    Actzo [M:SCRR]CRISDHNUM : Gosub DEACTIV_SDH
Elsif [M:SRH1]NBLIG<>0 & sum([M:SRH1]PNHNUM)<>"" 
    # On a déjà pické des lignes de retour fournisseur
    Actzo [M:SCRR]CRIPNHNUM : Gosub DEACTIV_PNH
Endif
If [M:SCRR]CRISDHNUM <> "" Actzo [M:SCRR]CRISDHNUM : Gosub DEACTIV_SDH Endif
If [M:SCRR]CRIPNHNUM <> "" Actzo [M:SCRR]CRIPNHNUM : Gosub DEACTIV_PNH Endif
Affzo [M:SCRR]1-99
Return

$AFFICH_SRL
Affzo [M:SCRR]1-99
# Pour un champs de type DATE, il faut positionner chgfmt après l'affzo 
# Car l'affzo déclenche lui aussi un Chgfmt With "DZ:"+GFMDAT (Ds l'act générée AV_)
Chgfmt [M]CRIDLVDAT With "-D:DD[/]MM[/]YYYY"
Chgfmt [M]CRIRTNDAT With "-D:DD[/]MM[/]YYYY"
Return

$AFFICH_SRS
Affzo [M:SCRR]1-99
# Pour un champs de type DATE, il faut positionner chgfmt après l'affzo 
# Car l'affzo déclenche lui aussi un Chgfmt With "DZ:"+GFMDAT (Ds l'act générée AV_)
Chgfmt [M]CRIDLVDAT With "-D:DD[/]MM[/]YYYY"
Chgfmt [M]CRIRTNDAT With "-D:DD[/]MM[/]YYYY"
Return


$DEACTIV_SDH
Grizo [M:SCRR]CRIPNHNUM, CRIRTNDAT
Return
$ACTIV_SDH
Actzo [M:SCRR]CRIPNHNUM, CRIRTNDAT
Return
$DEACTIV_PNH
Grizo [M:SCRR]CRISDHNUM, CRIDLVDAT
Return
$ACTIV_PNH
Actzo [M:SCRR]CRISDHNUM, CRIDLVDAT
Return


#---------------------------------------------------------#
# Sauvegarde des critères de picking saisis               #
#---------------------------------------------------------#
$OK
If [M]LNDRTN=2
    [M:SRL0]=[M:SCRR]
Elsif [M]SCORTN = 2
    [M:SRS0]=[M:SCRR]
Else
    [M:SRH0]=[M:SCRR]
Endif
#mkstat = 4 : # ??????
FIN = 1
Return

#---------------------------------------------------------#
# Réalimentation des valeurs initiales                    #
#---------------------------------------------------------#
$ABA

Raz REP
Gosub DEBUT
REP = ""

Return

#######################################################################
#                     ACTIONS CHAMPS                                  #
#######################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SCRITSRH) 19/07/2006 15:18:23 (LD)
######################################################################################
Subprog AM_CRIITMREF(VALEUR)
Variable Char    VALEUR()
Raz [M]CRIITMDES

#If VALEUR<>"" [M]CRIITMDES=[F:ITS]ITMDES1 : Endif
If VALEUR<>"" 
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITS]ITMREF,[M]CRIITMDES, "[F:ITS]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56270
Endif
Affzo [M]CRIITMDES
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SCRITSRH) 19/09/2006 11:46:44 (LD)
######################################################################################
Subprog AS_CRIDLVDAT(VALEUR)
Variable Date    VALEUR
If [M]LNDRTN=2
    # L'action AV_ est redéclenchée si on clique sur CRISDHNUM, dc Chgfmt With "DZ:"+GFMDAT est redéclenché
    # Il faut donc refaire disparaitre le champs
    Chgfmt [M]CRIDLVDAT With "-D:DD[/]MM[/]YYYY"
Endif
End
######################################################################################
######################################################################################
Subprog C_CRISDHNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" End : Endif
# --- La livraison doit appartenir à la même société juridique
If clalev([F:FCY])=0 Local File FACILITY [FCY] : Endif
Read [SDH] SDH0=VALEUR : If fstat Raz [F:SDH] : GMESSAGE=VALEUR-":"-mess(23,100,1) : mkstat=2 : End : Endif
If [M]LNDRTN<>2 & [F:SDH]LND=2 
    GMESSAGE=mess(17,704,1)-"!" : mkstat=2 : End 
Elsif [M:SCRR]LNDRTN=2 & [F:SDH]LND<>2 
    GMESSAGE=mess(318,192,1)-"!" : mkstat=2 : End 
Endif

If [M]SCORTN<>2 & [F:SDH]SCO=2 
    GMESSAGE=mess(17,704,1)-"!" : mkstat=2 : End 
Elsif [M:SCRR]SCORTN=2 & [F:SDH]SCO<>2 
    GMESSAGE=mess(318,192,1)-"!" : mkstat=2 : End 
Endif

WFCY=[F:SDH]SALFCY : Gosub CTLLEGCPY : If mkstat=2 End Endif
End
#####################################
Subprog AM_CRISDHNUM(VALEUR)
Variable Char    VALEUR()
If [M]LNDRTN<>2 & [M]SCORTN<>2
    If VALEUR<>""          
        Gosub DEACTIV_SDH : # N°livraison renseigné : On grize les autres n°
    Elsif [M:SRH1]NBLIG=0 
        Gosub ACTIV_SDH   : # N°livraison non renseigné et aucune ligne : On réactive les autres n°
    Endif
Elsif  [M]LNDRTN<>2 & [M]SCORTN<>2
    If VALEUR<>""          
        Gosub DEACTIV_SDH : # N°livraison renseigné : On grize les autres n°
    Elsif [M:SRS1]NBLIG=0 
        Gosub ACTIV_SDH   : # N°livraison non renseigné et aucune ligne : On réactive les autres n°
    Endif
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SCRITSRH) 19/09/2006 11:54:59 (LD)
######################################################################################
Subprog AS_CRIRTNDAT(VALEUR)
Variable Date    VALEUR
If [M]LNDRTN=2
    # L'action AV_ est redéclenchée qd on fait tab sur CRISDHNUM, dc Chgfmt With "DZ:"+GFMDAT est redéclenché
    # Il faut donc refaire disparaitre le champs
    Chgfmt [M]CRIRTNDAT With "-D:DD[/]MM[/]YYYY"
Endif
End
######################################################################################
Subprog C_CRIPNHNUM(VALEUR)
Variable Char    VALEUR()
End
#####################################
Subprog AM_CRIPNHNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""          
    Gosub DEACTIV_PNH : # N°retour renseigné : On grize les autres n°
Elsif [M:SRH1]NBLIG=0 
    Gosub ACTIV_PNH   : # N°retour non renseigné et aucune ligne : On réactive les autres n°
Endif
End
######################################################################################
# -------------------------------------------------------------------- #
# Contrôle d'appartenance à la même société juridique                  #
# -------------------------------------------------------------------- #
$CTLLEGCPY

Read [FCY] FCY0=WFCY : If fstat Raz [F:FCY] : Endif
If [F:FCY]LEGCPY<>GSOCIETE GMESSAGE=mess(2,194,1) : mkstat=2 : Return : Endif

Return
######################################################################################
