#<AdxTL>@(#)6.0.0.0 $Revision$

#########################################################################
#  SIXFCT : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog SI_FCT                                                        #
#     Création des factors                                              #
#                                                                       #
#########################################################################

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE

If GTRACE = ""
#  "Migration des factors"
    Call OUVRE_TRACE("SIXFCT : "+SI_MES(33)) From LECFIC     
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#---- Création enregistrement BPCUSTOMER ------#
Call ECR_TIME("SI_FACTOR : "+mess(213,124,1)+" FACTOR") From DOSSUB
Call SI_FACTOR
If GOK<>1 : Onerrgo : Goto FIN_FIN : Endif


$FIN_FIN
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


$TRT_ERR
    Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GOK = 0
Resume


#########################################################################
# Création des clients
#########################################################################
Subprog SI_FACTOR

########--------------------------------------------------------- Ouvertures tables X3 #

If !clalev([F:FCY])  : Local File =SI_DOSSIER+".FACILITY"   [FCY] : Endif   # Socièté
If !clalev([F:TCY])  : Local File =SI_DOSSIER+".TABCOUNTRY" [TCY] : Endif   # Pays
If !clalev([F:FCT])  : Local File =SI_DOSSIER+".FACTOR"     [FCT] : Endif   # Factors

If !clalev([F:CAC])  : Local File =SI_DOSSIER+".GACCCODE"   [CAC] : Endif   # Codes comptables   # hcb 70899

If !clalev([F:ADI])  : Local File =SI_DOSSIER+".ATABDIV"    [ADI] : Endif   # table diverse
If !clalev([F:AXX])  : Local File =SI_DOSSIER+".ATEXTRA"    [AXX] : Endif   # Textes
If !clalev([F:ATZ])  : Local File =SI_DOSSIER+".ATABZON"    [ATZ] : Endif   # Libellé rubrique 

########--------------------------------------------------------- Ouvertures tables Integrale #

If !clalev([F:XFCT]) : Local File =SI_DOSSIER+".XIFCTAFT" [XFCT]  : Endif   # Factor  

########--------------------------------------------------------- Définitions rubriques # 

Local Integer STOP 
Local Integer LRET
Local Integer LERR    # 0=OK 1=Erreur => pas d'écriture de l'enregistrement

Local Char    ACC_COD_ATABZON(25) 

########--------------------------------------------------------- Initialisation variables contextuelles #

SI_SUBPRG = "SIXFCT"
SI_TABLE  = "XIFCT"
Gosub SI_CRITSUP From SIXFONCTION

########--------------------------------------------------------- Récuperation des correspondances #
# mémorisation libellé code comptable  
Call TEXTFIC("FACTOR","ACCCOD",2,ACC_COD_ATABZON) From OBJDIV  

########--------------------------------------------------------- Traitement #

$LOOP_FCT


Call DEBTRANS From GLOCK

# Traitement des factors 
For [XFCT] Where left$(CODFCT,2)<>"$$"
&              & FLGREP<>2
&              & evalue(SI_CRITERE)

    Trbegin [FCT]
    Call AFFBOITE([F:XFCT]CODFCT) From SUBSIM

    LERR = 0

    # creation factor (FACTOR)
    If LERR = 0
       Gosub CRE_FCT
       If GOK <= 0 & SI_SIMU <> 2
          Break
       Endif
    Endif

    If LERR=0 & SI_SIMU<>2
      [F:XFCT]FLGREP = 2
      Rewrite [XFCT]
      Commit
    Else
      Rollback
    Endif

Next

End


##################################################################
#  Creation FACTOR 
##################################################################
$CRE_FCT
Raz [F:FCT]
# recuperation et controle code client
If !func SIXFONCTION.SI_CTL("FCTCOD",[F:XFCT]X3CLE,"XIFCTAFT ("+[F:XFCT]CODFCT+")")
    LERR = 1
Else
    [F:FCT]FCTCOD    = [F:XFCT]X3CLE
Endif

[F:FCT]FCTNAM      = [F:XFCT]RSC       # Nom du factor 
[F:FCT]ADDFCT(0)   = [F:XFCT]ADR1      # Adresse 1 du factor
[F:FCT]ADDFCT(1)   = [F:XFCT]ADR2      # Adresse 2 du factor
[F:FCT]ADDFCT(2)   = [F:XFCT]ADR3      # Adresse 3 du factor
[F:FCT]POSCOD      = [F:XFCT]CODPST    # Code postal               
[F:FCT]CTY         = [F:XFCT]VIL       # Ville                     
# Code pays 
If [F:XFCT]CODPAY <> ""
   [F:FCT]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XFCT]CODPAY,"TABCOUNTRY",mess(12,159,1)-[F:FCT]FCTCOD-"("+[F:XFCT]CODFCT+")")
Endif  
# Nom pays
If [F:FCT]CRY <> "" 
   Call LECTEXTRA([F:FCT]CRYNAM,"TABCOUNTRY","CRYDES",[F:FCT]CRY,"") From ATEXTRA
Endif

Call NUMONLY([F:XFCT]TEL,[F:FCT]TEL) From SIXFONCTION    # Telephone
Call NUMONLY([F:XFCT]TLC,[F:FCT]FAX) From SIXFONCTION    # Fax   
[F:FCT]BID        += [F:XFCT]CODBQE       # Code  banque
[F:FCT]BID        += [F:XFCT]CODGUI       # Code guichet
[F:FCT]BID        += [F:XFCT]NUMCPT       # Numéro de compte
[F:FCT]BID        += [F:XFCT]CLERIB       # Cle RIB
[F:FCT]PAB1        = [F:XFCT]DOM          # Domicialisation 1
[F:FCT]SALCOD      = num$([F:XFCT]NUMVDR) # Code vendeur 
[F:FCT]CREDAT      = date$                # date creation
[F:FCT]CREUSR      = GUSER                # operateur creation   
[F:FCT]UPDDAT      = date$                # date modification
[F:FCT]UPDUSR      = GUSER                # operateur modification

# initailisation par defaut
# code comptable
# hcb 70899 deb                  
#[F:FCT]ACCCOD      = "STD"                # Code comptable inclus dans le dossier de référence. 
## comptable par 'STD' (celui livré en standard)
If [F:FCT]ACCCOD = ""
   Read [CAC]CAC0 = 21;"STD"
   If !fstat
      [F:FCT]ACCCOD = "STD"
   Else
      Filter [CAC] Where TYP=21
             Read [CAC]CAC0 First
             If !fstat 
                [F:FCT]ACCCOD = [F:CAC]ACCCOD
             Endif
      Filter [CAC]
   Endif
Endif
# hcb 70899 fin                  
# Point d'entrée avant écriture
SI_TABLE = "FACTOR"
Gosub SI_BEFWRI From SIXFONCTION

# test Rubriques obligatoires
# Code comptable        
If dim([F:FCT]ACCCOD) > 0
   If [F:FCT]ACCCOD       = ""
      Call ECR_TRACE(mess(4,277,1)-[F:FCT]FCTCOD-"("+[F:XFCT]CODFCT+")"-mess(10,123,1)+" : "+ACC_COD_ATABZON, 1) From GESECRAN
      LERR = 1
   Endif
Endif

Write [FCT]
If fstat
    Call ECR_TRACE(mess(4,277,1)-[F:FCT]FCTCOD-"("+[F:XFCT]CODFCT+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
    LERR = 1
Endif

Return


