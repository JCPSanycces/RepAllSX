#<AdxTL>@(#)4.0.0.0 $Revision$ Consultation MWP

############################################################################
#                        Consultation                                       #
#                        Situation de pesée                                 #
#                                                                GPAO       #
#############################################################################
# Paramètres de la consultation via PARAM()                                 #
# 1  = site        /SITE                                                    #
# 2  = pièce       /VCRNUM                                                  #
#############################################################################
Local Char PARAM(20)(1..10)
PARAM(1) = "GAL"
PARAM(2) = ""
Call GCONSULT("SHO","",PARAM) From GCONSULT
End


$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
 When Default
Endcase
Return

############################################################
$AUTORIS
Return

############################################################
$OUVRE
Local Integer WSRT,WRET
Local Char    CRITERE(255)
Local Char    CRITERE1(255)
Local Char    CRITERE2(255)
Local Char    CRITERE3(255)
Local Char    FORMULE1(250)


If clalev ([F:FCY])  <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:MFM])  <= 0 : Local File MFGMAT     [MFM] : Endif
If clalev ([F:MFO])  <= 0 : Local File MFGOPE     [MFO]  : Endif

Gosub DEFCRIT


# Mail TS du 18/03/08
NAVIG="CONSMWP"
Return

#############################################################################
$FERME
Return

############################################################################
$FIN_CRIT
Return

#############################################################################
# analyse paramètres
$DEFCRIT
For I = 1 To dim(PARAM)
    Case I
        When 1 : # site
                 If PARAM(I) <> ""
                     Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                     If !fstat & [F:FCY]MFGFLG = 2 : [M:MWP1]MFGFCY = PARAM(I) : Endif
                 Endif

        When 2 : # Pièce
                 If PARAM(I) <> ""
                     [M:MWP1]MFGNUMSTR = PARAM(I)
                 Endif

        When Default: Break
    Endcase
Next I
Return

############################################################
$LECTURE

Local Shortint T_BOMOPE     (1000)
Local Shortint T_WGGSTA     (1000)
Raz T_BOMOPE
Raz T_WGGSTA




# si le tri n'est pas passé en paramètre, pas de chargement automatique
If [M:MWP1]MFGFCY = ""  : NBLU = 0 : Return : Endif
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

# filtres
Gosub LOAD_FILTER
# sr 10.04 demande 26046
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Local Integer I

#CATUA X3-106753.sn
#Filter by phase/operation
Local Char LCRITERE(255)

#For [MFM]MFM3 Where MFGFCY = [M:MWP1]MFGFCY     &
#&                   MFGNUM = [M:MWP1]MFGNUMSTR  &
#&                   MATSTA < 4                  &
#&                   PKC    > 1

LCRITERE = "MFGFCY = [M:MWP1]MFGFCY & MFGNUM = [M:MWP1]MFGNUMSTR & MATSTA < 4 & PKC > 1"

If [M:MWP1]BOMOPESTR <> 0
  LCRITERE += "& BOMOPE>=[M:MWP1]BOMOPESTR"             # operation start
Endif

If [M:MWP1]BOMOPEEND <> 0
  LCRITERE += "& BOMOPE<=[M:MWP1]BOMOPEEND"             # operation end
Endif

For [MFM]MFM3 Where evalue(LCRITERE)
#CATUA X3-106753.en

# verification de l existence de la phase dans le fichier MFGOPE
# test suprimer le 18 12 01 suite test M Clement
#    Filter [F:MFO] Where MFGNUM = [M:MWP1]MFGNUMSTR and OPENUM = [F:MFM]BOMOPE
#    For [MFO]

#            mise en table de la phase

     For I = 0 To 999 Step 1
       If T_BOMOPE (I) = 0 T_BOMOPE (I) = [F:MFM]BOMOPE
                           T_WGGSTA (I) = [F:MFM]WGGSTA
       Break
       Endif
       If T_BOMOPE (I) =    [F:MFM]BOMOPE
          If [F:MFM]WGGSTA <  T_WGGSTA (I) T_WGGSTA (I) = [F:MFM]WGGSTA
          Endif
       Break
       Endif
      Next I
#    Break
#    Next
#    Filter [F:MFO]
Next

Gosub FILLTAB


Return

#############################################################################
# Chargements spéciaux
$FILLTAB

Local Integer I
SUITE   = 1
RETOUR  = 1

   For I = 0 To 999 Step 1
       If T_BOMOPE (I) =  0 : Break : Endif

         If NBLU = 1
            If CHGPAG = 2 | CHGPAG = -2 : Raz [M:MWP2] : Endif
            NBLU = 2
         Endif

        If CHGPAG > 0
           If NOL >= MAXLIG-1 : SUITE = 2 : Break : Endif
           NOL    += 1

        Else
         If NOL <= 0 : RETOUR = 2 : Break : Endif
         NOL    -= 1

         Endif
  nolign = NOL+1



[M:MWP2]MFGNUM(nolign-1) = [M:MWP1]MFGNUMSTR
[M:MWP2]BOMOPE(nolign-1) = T_BOMOPE (I)
[M:MWP2]WGGSTA(nolign-1) = T_WGGSTA (I)
   Next I

Return


#############################################################################
# Préparation du filtre                                                     #
#############################################################################
$LOAD_FILTER
Return

#############################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

#############################################################################
$LOAD_CRITERE2
If len(CRITERE2)<>0 : CRITERE2 += "&" : Endif
CRITERE2 += CRITERE
Return

#############################################################################
$LOAD_CRITERE3
If len(CRITERE3)<>0 : CRITERE3 += "&" : Endif
CRITERE3 += CRITERE
Return

#############################################################################
$SETBOUT
Return

#############################################################################
$EXEBOUT
Return

#CATUA X3-106753.sn
#Filter by phase/operation
#############################################################################
Subprog AM_BOMOPESTR(VALEUR)
Variable Decimal VALEUR

  If [M:MWP1]BOMOPEEND = 0      : [M:MWP1]BOMOPEEND = VALEUR : Affzo [M:MWP1]BOMOPEEND : Endif
  If [M:MWP1]BOMOPEEND < VALEUR : [M:MWP1]BOMOPEEND = VALEUR : Affzo [M:MWP1]BOMOPEEND : Endif
End
#CATUA X3-106753.en


# FQ 57754 Module GPAO GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(8)<>2 End Endif

Call VALGTC(APPLI,"MWP") From SUBGTC

End

