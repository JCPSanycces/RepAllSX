#<AdxTL>@(#)0.0.0.0 $Revision$
# Class PREQUISD_CSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_AFTER"    : Gosub AINSERT_CONTROL_AFTER   From PREQUISD_CMET
        When "AINSERT_BEFORE"           : Gosub AINSERT_BEFORE          From PREQUISD_CMET
        When "AINSERT_AFTER"            : Gosub AINSERT_AFTER           From PREQUISD_CMET
        When "AREAD_AFTER"              : Gosub AREAD_AFTER             From PREQUISD_CMET
        When "AUPDATE_CONTROL_AFTER"    : Gosub AUPDATE_CONTROL_AFTER   From PREQUISD_CMET
        When "AUPDATE_BEFORE"           : Gosub AUPDATE_BEFORE          From PREQUISD_CMET
        When "AUPDATE_AFTER"            : Gosub AUPDATE_AFTER           From PREQUISD_CMET
        When "ADELETE_CONTROL_BEFORE"   : Gosub ADELETE_CONTROL_BEFORE  From PREQUISD_CMET
        When "ADELETE_AFTER"            : Gosub ADELETE_AFTER           From PREQUISD_CMET
      Endcase
    When "C_VACITM"
      Case ACTION
        When "AREAD_AFTER"              : Gosub AREAD_AFTER_C_VACITM    From PREQUISD_CMET
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "LOADVATPARAMFROMDOC"      : Gosub LOADVATPARAMFROMDOC      From PREQUIS_LIB
    When "LOADVATRESULTFROMFINDVAT" : Gosub LOADVATRESULTFROMFINDVAT From PREQUIS_LIB
    When "LOADPARAMFROMDOC"         : If fmet this.AGETMAXERROR("")>=[V]CST_AERROR : Return : Endif
                                      Gosub LOADPARAMFROMDOC         From PREQUIS_LIB
    When "LOADDOCFROMRESULT"        : If fmet this.AGETMAXERROR("")>=[V]CST_AERROR : Return : Endif
                                      Gosub LOADDOCFROMRESULT        From PREQUIS_LIB
    When "_MET_CALNETPRI"           : Gosub _MET_CALNETPRI           From TRTACHPSH1_SYRA
    When "_MET_LOADVAT"             : Gosub _MET_LOADVAT             From PREQUIS_LIB
    When "_MET_INIBPSNUM"           : Gosub _MET_INIBPSNUM           From PREQUIS_LIB
    When "SEARCHPRICE"              : Gosub SEARCHPRICE              From PREQUIS_LIB
    When "LOADWIPPARAM"             : Gosub LOADWIPPARAM             From PREQUIS_LIB #A SUPPRIMER car US 71069/260 by RBA 07/29/2016
    When "WIP"                      : Gosub WIP                      From PREQUIS_LIB #US 71069/260 by RBA 07/29/2016
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "ITMREF" :
      Case [L]ARULE
        When "CONTROL"   : Gosub ITMREF_CONTROL   From PREQUISD_CPRO
        When "PROPAGATE" : Gosub ITMREF_PROPAGATE From PREQUISD_CPRO
      Endcase
    When "QTYPUU" :
      Case [L]ARULE
        When "CONTROL"   : Gosub QTYPUU_CONTROL   From PREQUISD_CPRO
        When "PROPAGATE" : Gosub QTYPUU_PROPAGATE From PREQUISD_CPRO
      Endcase
    When "PUU" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub PUU_PROPAGATE    From PREQUISD_CPRO
      Endcase
    When "BPSNUM" :
      Case [L]ARULE
        When "CONTROL"   : Gosub BPSNUM_CONTROL   From PREQUISD_CPRO
        When "PROPAGATE" : Gosub BPSNUM_PROPAGATE From PREQUISD_CPRO
      Endcase
    When "EXTRCPDAT" :
      Case [L]ARULE
        When "CONTROL"   : Gosub EXTRCPDAT_CONTROL   From PREQUISD_CPRO
        When "PROPAGATE" : Gosub EXTRCPDAT_PROPAGATE From PREQUISD_CPRO
      Endcase
    When "NETPRI" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub NETPRI_PROPAGATE From PREQUISD_CPRO
      Endcase
    When "PRHFCY" :
      Case [L]ARULE
        When "INIT" : Gosub PRHFCY_INIT From PREQUISD_CPRO
      Endcase
    When "C_VACITM_VACITM" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub C_VACITM_VACITM_PROPAGATE From PREQUISD_CPRO
      Endcase
    When "C_VACITM_VAT" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub C_VACITM_VAT_PROPAGATE From PREQUISD_CPRO
      Endcase
    When "LEG" :
      Case [L]ARULE
        When "GET" : Gosub LEG_GET From PREQUISD_CPRO
      Endcase
  Endcase

Return


