#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Update new collumn TYPNK
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update ABI and ABV : TYPLNK") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If filinfo(filpath("FIL","ABIDIM","fde",[L]DOSSIER),0)<0 or filinfo(filpath("FIL","ABIREGORG","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS(DOSSIER,"ABI") : End : Endif

Gosub MAJABI
End

#-------------------#
$MAJABI
Local File =DOSSIER+".ABIDIM"   [ABI]
Local File =DOSSIER+".ABIREGORG"   [ABV]

If dim([F:ABI]TYPLNK)<=0 : Return : Endif

If dim([F:ABV]TYPLNKTAB)<=0 : Return : Endif

# Mise à jour de la table ABIDIM
Call ECR_TRACE(mess(81,125,1)-"ABIDIM:"-time$,0) From GESECRAN
Trbegin [ABI]
 For [ABI]
  For I=0 To dim([F:ABI]TABLNK)-1
   [F:ABI]TYPLNK(I) = 4
   Rewrite [ABI]
   If fstat
    Call ERREUR("ABIDIM"-[F:ABI]CODDIM,2) From DOSDIC
   Endif
  Next
 Next ABI
 # Mise à jour de la table ABIREGORG
Call ECR_TRACE(mess(81,125,1)-"ABIREGORG:"-time$,0) From GESECRAN
 For [ABV]
  For I=0 To dim([F:ABV]TABLNK)-1
   If [F:ABV]TYPLNKTAB(I)=0
    [F:ABV]TYPLNKTAB(I) = 4
   Endif
  Next
  Rewrite [ABV]
  If fstat
   Call ERREUR("ABIREGORG"-[F:ABV]CODREG,2) From DOSDIC
  Endif
 Next ABV
Commit

Close Local File [ABI],[ABV]


Return
