#<AdxTL>@(#)3.0.0.0 $Revision$
Raz GNBMASKOUV
Local Char PARAM(40)(1..4) , VALEUR(40)
PARAM(1) = ''
PARAM(2) = 'TCY'
PARAM(3) = 'FR'
PARAM(4) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"ARCVISUOBJ","ARCVISUOBJ","",5,"") From GTRAITE
End

#----------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "FIN_LISTE"   : Gosub FIN_LISTE
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "RAF"         : Gosub RAF
 When "OK"          : Gosub OK
 When "FIN"         : Gosub FIN
Endcase
Return

#------------------------------#
$INIT
If GARCROOT="": FIN = 1 : Endif
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif 
If clalev([F:ARU])=0 : Local File ARCHPARU [ARU] : Endif
If clalev([F:AOX])=0 : Local File AOBJTXT  [AOX] : Endif
Return

#------------------------------#
$OUVRE
Local Char    OACTION(20) , NOMPRG(GLONADC)
Local Integer OKTRT
Return

#------------------------------#
$SEL_LISTE
Local Char    TIT(50)(0..2) , TEXTE(250)(1..200,1..2) , TEX(250)(1..200)
Local Char    CLE1(GLONID1) , CLEBIS(GLONID2) , OBJET(GLONAOB)
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
If clalev([F:AOX])=0 : Local File AOBJTXT  [AOX] : Endif
If PARAM(1)<>"" or PARAM(2)="" or PARAM(3)=""
 OK = 0 : Return
Endif
OBJET = PARAM(2)
I = instr(1,PARAM(3),"~")
If I
 CLE1   = left$(PARAM(3),I-1)
 CLEBIS = right$(PARAM(3),I+1)
Else
 CLE1   = PARAM(3)
 CLEBIS = ""
Endif
If dim([F:AOX]IDTCNT)>0
 For [AOX]AOX0 Where ABREV=OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
  If [F:AOX]IDTCNT<>"" & !find([F:AOX]IDTCNT,TEX(1..NBTEX))
   NBTEX += 1
   TEX(NBTEX)     = [F:AOX]IDTCNT
   TEXTE(NBTEX,1) = [F:AOX]IDTCNT
   Call LECTEXTRA(TEXTE(NBTEX,2),"ATABDIV","LNGDES","81",[F:AOX]IDTCNT) From ATEXTRA
  Endif
 Next AOX
Endif
TIT    = mess(60,143,1)  : # Liste des volumes
TIT(1) = mess(37,100,1)  : # Code
TIT(2) = mess(30,109,1)  : # Intitulé
Return

#------------------------------#
$FIN_LISTE
PARAM(1) = VALEUR
Return

#------------------------------#
$DEBUT
Effzo 5
[M]CNT    = PARAM(1)
[M]OBJET  = PARAM(2)
[M]CLEOBJ = PARAM(3)
[M]URL    = PARAM(4)
Affzo 5
If [M]OBJET<>"" & [M]CLEOBJ<>""
 Gosub URL
Else
 [M]DOC = '""'
Endif
Return

#------------------------------#
$SETBOUT
If REP<>"M"
# Call VIREBOUT(CHBOU,"O") From GOBJET
Endif
If instr(1,CHBOU,"=")=0 : CHBOU += "="  : Endif : # Raf
Return

#------------------------------#
$APRES_MODIF
REP = "M"
Return

#------------------------------#
$OK
PARAM(1) = [M]CNT
PARAM(2) = [M]OBJET
PARAM(3) = [M]CLEOBJ
PARAM(4) = [M]URL
Gosub URL
REP =""
FIN = 0
Return

#------------------------------#
$RAF
If [M]OBJET<>"" & [M]CLEOBJ<>""
 Gosub URL
Else
 [M]DOC = '""'
Endif
Return

#------------------------------#
$URL
If [M]URL=""
 NOMPRG = "WO"+[M]OBJET
 Call EXISTE_ADX("","",NOMPRG,OKTRT) From ORDSYS
 If !OKTRT : Return : Endif
 Gosub NOMFIC From =NOMPRG
 If dim([L]ADDURL)>0
  [M]URL = [L]ADDURL
 Endif
Endif
If [M]URL="" : Return : Endif
If [M]CNT=""
 Call S_LIS_CHAR([M]CNT,PARAM,"","ARCVISUOBJ","") From GACTION
 If [M]CNT="" or GSTATUT=GSTAESC : Return : Endif
 Affzo 5
Endif
Gosub SET_USER
# Adresse url
If dim(GCLBURL)<=0
 Global Clbfile GCLBURL(1)
Endif
GCLBURL = evalue(GARCROOT)
If vireblc(GARCROOT2,2)<>""
 GCLBURL += evalue(GARCROOT2)
Endif
If vireblc([M]URL,2)<>"" & [M]URL<>'""' & [M]URL<>"''"
 GCLBURL += evalue([M]URL)
Endif
Gosub SET_PRGSTD From SUBARC
OACTION = ACTION
ACTION = "GETURL" : Gosub ACTION From ARCHIVE
ACTION = OACTION
If !OK : FIN = 1 : Return : Endif
Effzo DOC
Affzo DOC
Inftxt GCLBURL At 1
Return

#---------------------------------------------------------------#
$SET_USER
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif 
If clalev([F:ARU])=0 : Local File ARCHPARU [ARU] : Endif
Read [AUS]CODUSR=GUSER
Read [ARU]ARU0=[F:AUS]ARCPRF
Return

#------------------------------#
$FIN
Inftxt "" At 1
Return

#---------------------------------------------------------------#
Subprog S_CLEOBJ(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = [M]OBJET
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
End
