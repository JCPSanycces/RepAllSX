#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################
#                                                                       #
#      TRAITEMENTS LIES aux PRIX dans les VENTES                        #
#                                                                       #
#########################################################################
#                                                                       #
#-----------------------------------------------------------------------#
# Traitements e_commerce                                                #
#-----------------------------------------------------------------------#
# ACTIONS                                                               #
# ------------------                                                    #
# Affichages divers                                                     #
# ------------------                                                    #
# DIVNETPRI : Après-Modif prix et remises (calcul prix net)             #
# DIVPFM    : Après-Modif prix et remises (calcul marge)                #
# DIVPFMOUV : Après-Modif prix et remises (calcul marge)0 cde ouverte   #
# DIVPRIPFM  : Après-Modif prix et remises (calcul prix net et marge)   #
# DIVPRIPFMO : Après-Modif prix et rem.(calcul prix net marge) cde ouv. #
#                                                                       #
#########################################################################
# Issue X3-38450 - 20171030 by LD : Invalid sales invoice without currency rate
# Issue X3-84450 - 20180731 by LD : FUNSHTREG function and CALPFM entry point

#########################################################################
#    Sous-Programmes modélisés                                          #
#########################################################################
#                                                                       #
# Subprog CLCNETPRI(QTY, CUR, NLIG)                                     #
#      Calcul du prix net                                               #
# Subprog CALCNETPRI(MSK,QTY, CUR, NLIG)                                #
#      Calcul du prix net (FQ 47040 Avec abréviation du masque)         #
# Subprog CTLNETPRI(BPC, CHGTYP, DAT, CUR, NLIG)                        #
#      Contrôle du prix net                                             #
# Subprog CLCPFM(SITE, PRITYP, CHGTYP, DAT, CUR, NLIG, INICPRPRI)       #
#      Calcul de la marge                                               #
# Subprog CALCPFM(MSK,SITE, PRITYP, CHGTYP, DAT, CUR, NLIG, INICPRPRI)  #
#      Calcul de la marge (FQ 47040 Avec abréviation du masque)         #
# Subprog CALPFM (MSK,PRI,VAT,PRITYP,SIT,LITM,CHGTYP,DAT,CUR,COEF,      #
#                 PFM,PFMRAT)                                           #
#      Calcul de la marge et renvoi de la marge en montant et en %      #
#      (FQ 47040 : Ajout param MSK )                                    #
# Subprog CTLPFM(CUR, XCPRPRI, NLIG)                                    #
#      Contrôle de la marge                                             #
#                                                                       #
# Subprog FMT_MNTCUR(MNTORI, DEV, MNTDES)                               #
#      Formattage d'un montant avec le format de la devise              #
#                                                                       #
#########################################################################
#########################################################################
$ACTION
#--- Actions liés au type traitement et affichage divers
Case ACTION
 When "TRT_DIV"     : Gosub TRT_DIV
Endcase
Return
#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################
$TRT_DIV
Case TRAIT
 When "DIVNETPRI"               : Gosub DIVNETPRI
 When "DIVPFM", "DIVPFMOUV"     : Gosub DIVPFM
 When "DIVPRIPFM", "DIVPRIPFMO" : Gosub DIVPRIPFM
Endcase
Return
################################################################################
# DETAIL DES ACTIONS                                                           #
################################################################################
################################################################################
#    Actions liés au type traitement et affichage divers                       #
################################################################################
#--------------------------------------------------------------------------#
# Action DIVPRIPFM : AM_GROPRI, AM_DISCRGVAL()                             #
#                    Calcul du prix net qui enchaine le calcul de la marge #
#--------------------------------------------------------------------------#
# Entrée  VALEUR   : Valeur courante                                       #
#         DISCRGNUM: Numéro de la colonne frais/remise (1 à 9)             #
#                                          prix brut     (0)               #
#         QTY      : Quantite                                              #
#         BPC      : Client                                                #
#         CHGTYP   : Type de cours                                         #
#         DAT      : Date                                                  #
#         CUR      : Devise                                                #
#         NLIG    : Numéro de la ligne (nolign-1)                          #
#         SITE     : Site                                                  #
#         PRITYP   : Type de prix                                          #
#         NOMZONE  : Nom de la zone courante                               #
#--------------------------------------------------------------------------#
$DIVPRIPFM
Local Decimal WANCNETPRI

Gosub DEF_DIVPRIPFM
WANCNETPRI=[M]NETPRI(val(PARAM(7)))
Gosub DIVNETPRI
If mkstat=2 Return Endif
Gosub DIVPFM
If mkstat=2 [M]NETPRI(NLIG)=WANCNETPRI : Return Endif

Return

$DEF_DIVPRIPFM
Local Integer  DISCRGNUM, CHGTYP, NLIG, PRITYP
Local Decimal  QTY
Local Char     BPC(GLONBPC), CUR(GLONCUR), SITE(GLONFCY), NOMZONE
Local Date     DAT

DISCRGNUM = val(PARAM(1))
QTY       = val(PARAM(2))
BPC       = PARAM(3)
CHGTYP    = val(PARAM(4))
DAT       = PARAM(5)
CUR       = PARAM(6)
NLIG      = val(PARAM(7))
SITE      = PARAM(8)
PRITYP    = val(PARAM(9))
NOMZONE   = PARAM(10)

Return
#---------------------------------------------------------------#
# Action DIVNETPRI : AM_GROPRI, AM_DISCRGVAL()                  #
#                    Calcul du prix net                         #
#---------------------------------------------------------------#
# Entrée  VALEUR   : Valeur courante                            #
#         DISCRGNUM: Numéro de la colonne frais/remise (1 à 9)  #
#                                          prix brut     (0)    #
#         QTY      : Quantite                                   #
#         BPC      : Client                                     #
#         CHGTYP   : Type de cours                              #
#         DAT      : Date                                       #
#         CUR      : Devise                                     #
#         NLIG    : Numéro de la ligne (nolign-1)               #
#---------------------------------------------------------------#
$DIVNETPRI

Local Decimal  GROPRI, MAJREM(0..8), NETPRI
Local Shortint I
Local Decimal  WSVGNETPRI

If TRAIT="DIVNETPRI" Gosub DEF_DIVNETPRI Endif

# Si l'on est sur une ligne d'avoir en valeur, pas de calcul du prix net
If dim([M:SIH0]INVTYP)>0 & [M:SIH0]INVTYP=2 & [M]QTY(NLIG)=0 Return Endif

If DISCRGNUM < 1 GROPRI=VALEUR
Else             GROPRI=[M]GROPRI(NLIG)
Endif
For I=1 To 9
   If evalue("dim([M]DISCRGVAL"+num$(I)+"(NLIG))")>0
      MAJREM(I-1)=evalue("[M]DISCRGVAL"+num$(I)+"(NLIG)")
   Endif
Next I
Case DISCRGNUM
  When 1 MAJREM(0)=VALEUR
  When 2 MAJREM(1)=VALEUR
  When 3 MAJREM(2)=VALEUR
  When 4 MAJREM(3)=VALEUR
  When 5 MAJREM(4)=VALEUR
  When 6 MAJREM(5)=VALEUR
  When 7 MAJREM(6)=VALEUR
  When 8 MAJREM(7)=VALEUR
  When 9 MAJREM(8)=VALEUR
Endcase

If dim([M]FOCFLG(NLIG)) > 0
    If [M]FOCFLG(NLIG)= 3 Return Endif
Endif
# --> Calcul du prix net
#Call CALNET (1,"", GROPRI,MAJREM,QTY,NETPRI,CUR) From TRTPRICE
If dim(GCALNETLIN)>0 : GCALNETLIN=NLIG+1   : Endif
If dim(GCALNETABR)>0 : GCALNETABR="[M]"    : Endif
Call CALNET (1,[M]PLISTC, GROPRI,MAJREM,QTY,NETPRI,CUR) From TRTPRICE

WSVGNETPRI= [M]NETPRI(NLIG)
[M]NETPRI(NLIG) = NETPRI

If GDACLOK =1 Call CTLNETPRI(BPC,CHGTYP,DAT,CUR,NLIG) Endif
If mkstat = 2 [M]NETPRI(NLIG)=WSVGNETPRI : Return Endif

# --> Si netpri = 0 : Pas de passage dans le calcul de la marge
#                     Les prix ne seront pas recalculés : Il faut les raz
If NETPRI = 0
   [M]NETPRINOT(NLIG) = 0
   [M]NETPRIATI(NLIG) = 0
Endif

If !GIMPORT Affzo [M]NETPRI(NLIG) Endif

Return

#---------------------------------------------------------------#
$DEF_DIVNETPRI

Local Decimal  QTY
Local Integer  DISCRGNUM, CHGTYP, NLIG
Local Char     BPC, CUR(3)
Local Date     DAT

DISCRGNUM = val(PARAM(1))
QTY       = val(PARAM(2))
BPC       = PARAM(3)
CHGTYP    = val(PARAM(4))
DAT       = PARAM(5)
CUR       = PARAM(6)
NLIG      = val(PARAM(7))

Return
#---------------------------------------------------------------#
# Action DIVPFM    : AM_GROPRI, AM_DISCRGVAL()                  #
#                    AM_DSTOFCY                                 #
#                    AM_CPRPRI                                  #
#                                                               #
#                    Calcul de la marge                         #
#---------------------------------------------------------------#
# Entrée  SITE     : Site                                       #
#         PRITYP   : Type de prix                               #
#         CHGTYP   : Type de cours                              #
#         DAT      : Date de référence                          #
#         CUR      : Devise                                     #
#         NLIG     : Numéro de la ligne (nolign-1)              #
#         NOMZONE  : Nom de la zone courante                    #
#---------------------------------------------------------------#
$DIVPFM
Local  Char    VAT(GLONVAT)(3) # FGR 12/11/2009 : X3SUIVI59766 plus (3)
Local  Decimal WQTY
Local  Integer INICPRPRI, XSTOMGTCOD
Local  Decimal XCPRPRI, XCOEF, XPFM
Local  Decimal WSVGPFM, WSVGCPRPRI, WSVGNETPRINOT, WSVGNETPRIATI

If find(TRAIT,"DIVPFM","DIVPFMOUV") Gosub DEF_DIVPFM Endif

# Bug 43723 : Calcul du prix de revient pour les gratuits
#If [M]NETPRI(NLIG) = 0
#    # Pas de calcul de marge pour les gratuits
#    If dim([M]FOCFLG(NLIG)) > 0
#        If [M]FOCFLG(NLIG) = 3 Return : Endif
#    Endif
##    If dim([M]LINTYP(NLIG)) > 0  : # Bug 15525
##        If find([M]LINTYP(NLIG),3,4,5,7,8,9) Return : Endif
##    Endif
#Endif

If !find(TRAIT, "DIVPFMOUV", "DIVPRIPFMO")
   VAT (0) = [M]VAT1(NLIG)
   VAT (1) = [M]VAT2(NLIG)
   VAT (2) = [M]VAT3(NLIG)
Endif

# Récupération du coef de conversion UV en US pour calcul de la marge
#COEF = 1
# Pour les devis, commandes, livraisons, factures
#If TRAIT = "DIVPFM"
#   If [M]SAU(NLIG) <> [M]STU(NLIG)
#      Call SCAL_QUS(0,[M]ITMREF(NLIG),[M]BPCORD,[M]SAU(NLIG),[M]STU(NLIG),WQTY,COEF) From TRTVENQTE
#   Endif
# Pour les commandes ouvertes
#Else
#  If [M]SAU <> [M]STU
#      Call SCAL_QUS(0,[M]ITMREF,[M]BPCORD,[M]SAU,[M]STU,WQTY,COEF) From TRTVENQTE
#   Endif
#Endif

# ------- Calcul de la marge -------
WSVGPFM=[M]PFM(NLIG)
WSVGNETPRINOT=[M]NETPRINOT(NLIG) : WSVGNETPRIATI=[M]NETPRIATI(NLIG)
XPFM=[M]PFM(NLIG)
If !find(TRAIT, "DIVPFMOUV", "DIVPRIPFMO")
   WSVGCPRPRI=[M]CPRPRI(NLIG)
   If NOMZONE = "CPRPRI"
      INICPRPRI = 0
      XCPRPRI = VALEUR
      XCOEF   = [M]SAUSTUCOE(NLIG)
   Elsif NOMZONE = "DSTOFCY"
      INICPRPRI = 2
      XCPRPRI = [M]CPRPRI(NLIG)
      XCOEF   = [M]SAUSTUCOE(NLIG)
   Elsif NOMZONE = "SAUSTUCOE"
      INICPRPRI = 1
      XCPRPRI = [M]CPRPRI(NLIG)
      XCOEF   = VALEUR
   Else
      INICPRPRI = 1
      XCPRPRI = [M]CPRPRI(NLIG)
      XCOEF   = [M]SAUSTUCOE(NLIG)
   Endif
   XSTOMGTCOD=[M]STOMGTCOD(NLIG)
   # FQ 47040 + masque par défaut
   Call CALPFM("[M]",NLIG,[M]NETPRI(NLIG),VAT,PRITYP,SITE,[M]ITMREF(NLIG),CHGTYP,DAT,CUR,
&              XCOEF,INICPRPRI,XSTOMGTCOD,XPFM,XCPRPRI) From TRTVENPRI
Else
   XCPRPRI  =0
   INICPRPRI=1
   XSTOMGTCOD=[M]STOMGTCOD
   # FQ 47040 + masque par défaut
   Call CALPFM("[M]",NLIG,[M]NETPRI(NLIG),VAT,PRITYP,SITE,[M]ITMREF,CHGTYP,DAT,CUR,
&              [M]SAUSTUCOE,INICPRPRI,XSTOMGTCOD,XPFM,XCPRPRI) From TRTVENPRI
Endif

# Bug 43723 : Pas de calcul de la marge pour les gratuits
If [M]NETPRI(NLIG)<>0 | (dim([M]FOCFLG(NLIG))>0 & [M]FOCFLG(NLIG)<>3)
    [M]PFM(NLIG)=XPFM
Endif

If INICPRPRI <> 0 & !find(TRAIT, "DIVPFMOUV", "DIVPRIPFMO") [M]CPRPRI(NLIG)=XCPRPRI : Endif

If GDACLOK =1 Call CTLPFM(CUR,XCPRPRI,NLIG) Endif
If mkstat=2
    [M]PFM(NLIG)=WSVGPFM : [M]NETPRINOT(NLIG)=WSVGNETPRINOT : [M]NETPRIATI(NLIG)=WSVGNETPRIATI
    If !find(TRAIT, "DIVPFMOUV", "DIVPRIPFMO") [M]CPRPRI(NLIG)=WSVGCPRPRI Endif  : Return
Endif

If !GIMPORT
    If INICPRPRI <> 0 & !find(TRAIT, "DIVPFMOUV", "DIVPRIPFMO")
        Affzo [M]CPRPRI(NLIG), PFM(NLIG)
    Else
        Affzo [M]PFM(NLIG)
    Endif
Endif

Return

#---------------------------------------------------------------#
$DEF_DIVPFM
Local  Char    SITE(3), CUR(3)
Local  Integer PRITYP, CHGTYP, NLIG
Local  Date    DAT
Local  Char    NOMZONE

SITE   = PARAM(1)
PRITYP = val(PARAM(2))
CHGTYP = val(PARAM(3))
DAT    = PARAM(4)
CUR    = PARAM(5)
NLIG   = val(PARAM(6))
NOMZONE=PARAM(7)

Return

#---------------------------------------------------------------#
# Sous-prog CLCNETPRI : Calcul du prix net                      #
#                                                               #
#    Appelé en AM_QTY (à partir de l'action XXXMQTY)            #
#    Appelé pr les articles de remplacement ds les commandes    #
#    Appelé pr le configurateur lors de la recherche tarif      #
#    Appelé pr la simulation tarif                              #
#---------------------------------------------------------------#
# Entrée  QTY      : Quantite                                   #
#         CUR      : Devise                                     #
#         NLIG     : Numéro de la ligne (nolign-1)              #
#---------------------------------------------------------------#
Subprog CLCNETPRI(QTY, CUR, NLIG)
Value Decimal QTY
Value Char    CUR
Value Integer NLIG

Call CALCNETPRI("[M]",QTY, CUR, NLIG)

End

Subprog OLD_CLCNETPRI(QTY, CUR, NLIG) : # FQ 47040 Obsolète
Value Decimal QTY
Value Char    CUR
Value Integer NLIG

Local Decimal  GROPRI, MAJREM(0..8), NETPRI
Local Shortint I

GROPRI=[M]GROPRI(NLIG)
For I=1 To 9
    If evalue("dim([M]DISCRGVAL"+num$(I)+"(NLIG))")>0
       MAJREM(I-1)=evalue("[M]DISCRGVAL"+num$(I)+"(NLIG)")
    Endif
Next I

If [M]FOCFLG(NLIG) = 3 End Endif

# --> Calcul du prix net
#Call CALNET (1,"", GROPRI,MAJREM,QTY,NETPRI,CUR) From TRTPRICE
If dim(GCALNETLIN)>0 : GCALNETLIN=NLIG+1   : Endif
If dim(GCALNETABR)>0 : GCALNETABR="[M]"    : Endif
Call CALNET (1,[M]PLISTC, GROPRI,MAJREM,QTY,NETPRI,CUR) From TRTPRICE

[M]NETPRI(NLIG) = NETPRI
# --> Si netpri = 0 : Pas de passage dans le calcul de la marge
#                     Les prix ne seront pas recalculés : Il faut les raz
If NETPRI = 0
   [M]NETPRINOT(NLIG) = 0
   [M]NETPRIATI(NLIG) = 0
Endif
End

#---------------------------------------------------------------#
# Sous-prog CTLNETPRI : Contrôle du prix net                    #
#                                                               #
#    Appelé en APRES_NBLIG (à partir sous-pro APRES_LIGNE)      #
#---------------------------------------------------------------#
# Entrée  BPC      : Client                                     #
#         CHGTYP   : Type de cours                              #
#         DAT      : Date                                       #
#         CUR      : Devise                                     #
#         NLIG     : Numéro de la ligne (nolign-1)              #
#---------------------------------------------------------------#
Subprog CTLNETPRI(BPC, CHGTYP, DAT, CUR, NLIG)
Value Char    BPC
Value Integer CHGTYP
Value Date    DAT
Value Char    CUR
Value Integer NLIG

Local Decimal MONT, MNTDES
Local Integer SPSTAT
Local Shortint I
Local Char    WITMREF(GLONITM), WSAU(GLONUOM)
Local Decimal WNETPRINOT
Local Date    WDATCONVPRI : # Bug 84596 : Date utilisée pour le calcul des taxes (prix HT/TTC)

# Si l'on est sur une ligne d'avoir en valeur, pas de contrôle du prix net
If dim([M:SIH0]INVTYP)>0 & [M:SIH0]INVTYP=2 & [M]QTY(NLIG)=0 End Endif

If dim([M]FOCFLG(NLIG)) > 0
    # On est ds les devis, cdes, liv, factures
    If [M]FOCFLG(NLIG) = 3 End Endif
    WITMREF = [M]ITMREF(NLIG)
    WSAU    = [M]SAU(NLIG)
Else
    # On est ds les cdes ouvertes : FOCFLG et LINTYP n'existent pas, ITMREF, SAU ne st pas ds le tableau
    WITMREF = [M]ITMREF
    WSAU    = [M]SAU
Endif

# Lecture article et article vente
If !clalev([F:ITM]) Local File ITMMASTER [ITM] Endif
If !clalev([F:ITS]) Local File ITMSALES  [ITS] Endif
If [F:ITM]ITMREF <> WITMREF
   Read [ITM]ITM0 = WITMREF
   If fstat End Endif
Endif
If [F:ITS]ITMREF <> WITMREF
   Read [ITS]ITS0 = WITMREF
   If fstat End Endif
Endif

# --> Contrôle prix net >= prix plancher
If [F:ITS]MINPRI <> 0
   If WSAU <> [F:ITM]SAU
      Call SREC_COE(WITMREF, BPC, [F:ITM]SAU, WSAU, GBIDD1) From TRTVENQTE
      If GBIDD1 <> 0
         MONT = [F:ITS]MINPRI * GBIDD1
      Else
         MONT = 0
      Endif
   Else
      MONT = [F:ITS]MINPRI
   Endif
   If CUR <> GSYSCUR & MONT <> 0
      Call CONVERT2(GSYSCUR, CUR, GLOCALDEV, CHGTYP, DAT, MONT, MNTDES, SPSTAT) From TRTDEV
   Else
      MNTDES = MONT
   Endif
   MONT = arr(MNTDES, 10^-GDECPRI)

   # Par defaut on charge le prix net ( HT ou TTC )
   WNETPRINOT=[M]NETPRI(NLIG)
   # Si saisie en TTC il faut calculer le prix HT
   If dim([M]PRITYP)>0 & [M]PRITYP=2
      Local Decimal J_NETPRI, J_QTY, J_CLCAMT1, J_CLCAMT2, J_NETPRINOT
      Local Char    J_VAT (GLONVAT) (0..2), J_VACBPR

      If dim([M]NETPRI)>0  : J_NETPRI=[M]NETPRI(NLIG)   : Endif
      If dim([M]VAT1)>0    : J_VAT(0)=[M]VAT1(NLIG)     : Endif
      If dim([M]VAT2)>0    : J_VAT(1)=[M]VAT2(NLIG)     : Endif
      If dim([M]VAT3)>0    : J_VAT(2)=[M]VAT3(NLIG)     : Endif
      If dim([M]CLCAMT1)>0 : J_CLCAMT1=[M]CLCAMT1(NLIG) : Endif
      If dim([M]CLCAMT2)>0 : J_CLCAMT1=[M]CLCAMT2(NLIG) : Endif
      If dim([M]QTY)>0     : J_QTY=[M]QTY(NLIG)         : Endif
      If dim([M]VACBPR)>0  : J_VACBPR=[M]VACBPR         : Endif
      # Bug 84596 : Date utilisée pour le calcul des taxes (prix HT/TTC)
      Local Date    WDATCONVPRI
      WDATCONVPRI=DAT
      If GFONCTION="GESSDH" WDATCONVPRI=[M:SDH1]DLVDAT Endif
      # Bug 95337 : Date utilisée pour le calcul des taxes (prix HT/TTC)
      # Utiliser [M]VATDAT si le champ est renseigné (sinon ce sera [M]INVDAT par défaut)
      If GFONCTION="GESSIH" & dim([M:SIH2]VATDAT)>0 & [M:SIH2]VATDAT<>[0/0/0]
          WDATCONVPRI=[M:SIH2]VATDAT
      Endif
      # Bug 95337
      #Call CLCTAXEPRIV(J_NETPRI,J_VAT,[M]PRITYP,GSOCIETE,DAT,J_QTY,J_VACBPR,J_CLCAMT1,J_CLCAMT2,J_NETPRINOT) From TRTX3
      Call CLCTAXEPRIV(J_NETPRI,J_VAT,[M]PRITYP,GSOCIETE,WDATCONVPRI,J_QTY,J_VACBPR,J_CLCAMT1,J_CLCAMT2,J_NETPRINOT) From TRTX3
      # Bug 84596

      If J_NETPRINOT : WNETPRINOT=J_NETPRINOT : Endif
   Endif

   If WNETPRINOT < MONT
      # Si GNETMAR = 0 , pas d'affichage du message d'erreur (cas de l'APRES_NBLIG)
      If GNETMAR = 1
#         GMESSAGE = sum(format$("N3:15F[ ]",WNETPRINOT),mess(19,192,1),        : # 89275
         GMESSAGE = sum(WITMREF,format$("N3:15F[ ]",WNETPRINOT),mess(19,192,1),
&                   format$("N3:15F[ ]",MONT),CUR)                              : # 89275
         # -------------------------------------------------------- #
         # Point d'entree affichage du message de contrôle de prix  #
         # -------------------------------------------------------- #
         GPOINT="DSPCTLPRI" : Gosub ENTREE From EXEFNC
         If GMESSAGE="" End Endif
         #Gbn-89937-En import on doit prendre en compte SDACLOCK
         If GTRACE <> "" & !GIMPORT
              Call ECR_TRACE(WITMREF+" : "+GMESSAGE , 0) From GESECRAN
#             Call ECR_TRACE(GMESSAGE,0) From GESECRAN
         Elsif dim([M]LINTYP(NLIG))<=0 | (dim([M]LINTYP(NLIG))>0 & find([M]LINTYP(NLIG),1,2,6,10))
            # Msg si cde ouverte ou autre doc et l'article n'est pas un composant
            GERR=2
            If GDACLOK=1 GERR=1 : mkstat=2 Endif
         Endif
      Endif
   Endif
Endif
End

#-------------------------------------------------------------------#
# Sous_prog CLCPFM    : Calcul de la marge                          #
#                                                                   #
#    Appelé en AM_QTY                                               #
#    Appelé en AM_VACBPR ds les livraison (modif du regime de taxe) #
#    Appelé en RECALC_TOT ds devis et cde                           #
#    Appelé pr les articles de remplacement ds les commandes        #
#-------------------------------------------------------------------#
# Entrée  SITE     : Site                                           #
#         PRITYP   : Type de prix                                   #
#         CHGTYP   : Type de cours                                  #
#         DAT      : Date de référence                              #
#         CUR      : Devise                                         #
#         NLIG     : Numéro de la ligne (nolign-1)                  #
#         INICPRPRI: Init du prix de revient (0,1,2)                #
#-------------------------------------------------------------------#
Subprog CLCPFM(SITE, PRITYP, CHGTYP, DAT, CUR, NLIG, INICPRPRI)
Value    Char     SITE
Value    Integer  PRITYP
Value    Integer  CHGTYP
Value    Date     DAT
Value    Char     CUR
Value    Integer  NLIG
Value    Integer  INICPRPRI

Call CALCPFM("[M]",SITE, PRITYP, CHGTYP, DAT, CUR, NLIG, INICPRPRI)

End

Subprog OLD_CLCPFM(SITE, PRITYP, CHGTYP, DAT, CUR, NLIG, INICPRPRI) : # FQ 47040 Obsolète
Value    Char     SITE
Value    Integer  PRITYP
Value    Integer  CHGTYP
Value    Date     DAT
Value    Char     CUR
Value    Integer  NLIG
Value    Integer  INICPRPRI

Local    Decimal PFM
Local    Char    VAT(GLONVAT)(3)
Local    Decimal WQTY

# Pas de calcul de marge pour les prix à 0
#If [M]NETPRI(NLIG) = 0  & ([M]FOCFLG(NLIG) = 3 | find([M]LINTYP(NLIG),3,4,5,7,8,9,11,12,13)) End Endif
# Bug 43723 : Calcul du prix de revient pour les gratuits
#If [M]NETPRI(NLIG) = 0  & [M]FOCFLG(NLIG) = 3 End Endif

VAT (0) = [M]VAT1(NLIG)
VAT (1) = [M]VAT2(NLIG)
VAT (2) = [M]VAT3(NLIG)

# Récupération du coef de conversion UV en US pour calcul de la marge
#COEF = 1
#If [M]SAU(NLIG) <> [M]STU(NLIG)
#   Call SCAL_QUS(0,[M]ITMREF(NLIG),[M]BPCORD,[M]SAU(NLIG),[M]STU(NLIG),WQTY,COEF)
#&                From TRTVENQTE
#Endif

# --> Calcul de la marge
PFM=[M]PFM(NLIG)
# FQ 47040 + masque par défaut
Call CALPFM("[M]",NLIG,[M]NETPRI(NLIG), VAT, PRITYP, SITE, [M]ITMREF(NLIG), CHGTYP, DAT, CUR,
&           [M]SAUSTUCOE(NLIG), INICPRPRI, [M]STOMGTCOD(NLIG), PFM, [M]CPRPRI(NLIG)) From TRTVENPRI
# Bug 43723 : Pas de calcul de la marge pour les gratuits
If [M]NETPRI(NLIG)<>0 | (dim([M]FOCFLG(NLIG))>0 & [M]FOCFLG(NLIG)<>3)
    [M]PFM(NLIG)=PFM
Endif
End
#---------------------------------------------------------------#
# Sous_prog CTLPFM    : Contrôle de la marge                    #
#                                                               #
#    Appelé en APRES_NBLIG (à partir sous-pro APRES_LIGNE)      #
#              AM_QTY (Si GDACLOK=1 car il faut bloquer)        #
#              DIVPFM Apres_modif des prix et remises           #
#                     (Si GDACLOK=1 car il faut bloquer)        #
#---------------------------------------------------------------#
# Entrée  CUR      : Devise                                     #
#         XCPRPRI  : Prix de revient                            #
#         NLIG     : Numéro de la ligne (nolign-1)              #
#---------------------------------------------------------------#
Subprog CTLPFM(CUR, XCPRPRI, NLIG)
Value    Char     CUR
Value    Decimal  XCPRPRI
Value    Integer  NLIG

Local    Decimal PFMRAT
Local    Char    WITMREF(GLONITM), WSAU(GLONUOM)

If dim([M]FOCFLG(NLIG)) > 0
    # On est ds les devis, cdes, liv, factures
#    If [M]NETPRI(NLIG) = 0 & ([M]FOCFLG(NLIG) = 3 | find([M]LINTYP(NLIG),3,4,5,7,8,9,11,12,13)) End Endif
    If [M]NETPRI(NLIG) = 0 & [M]FOCFLG(NLIG) = 3 End Endif : # Bug 15525
    WITMREF = [M]ITMREF(NLIG)
    WSAU    = [M]SAU(NLIG)
Else
    # On est ds les cdes ouvertes : FOCFLG et LINTYP n'existent pas, ITMREF, SAU ne st pas ds le tableau
    WITMREF = [M]ITMREF
    WSAU    = [M]SAU
Endif

# Lecture article vente
If !clalev([F:ITS]) Local File ITMSALES  [ITS] Endif
If [F:ITS]ITMREF <> WITMREF
   Read [ITS]ITS0 = WITMREF
   If fstat End Endif
Endif

# --> Calcul du % de la marge pour le comparer avec le % marge minimale de l'article vente
PFMRAT = [M]NETPRINOT(NLIG) - XCPRPRI
Call ARRDEV(PFMRAT, CUR) From TRTDIV
If [M]NETPRINOT(NLIG) <> 0
   PFMRAT = (([M]NETPRINOT(NLIG) - XCPRPRI)/[M]NETPRINOT(NLIG))*100
   PFMRAT = arr(PFMRAT, 0.01)
Else
   PFMRAT = 100
Endif

# Si l'on est dans les factures et qu'il s'agit d'un avoir, pas de contrôle marge mini
If dim([M:SIH0]INVTYP)>0 & [M:SIH0]INVTYP=2 End Endif

# --> Contrôle marge >= marge minimale
If PFMRAT < [F:ITS]MINPFM & [F:ITS]MINPFM <> 0
   # Si GNETMAR = 0 , pas d'affichage du message d'erreur
   If GNETMAR = 1
#      GMESSAGE = sum(format$("N:15F[ %]",PFMRAT)," ",mess(20,192,1),         : # 89275
      GMESSAGE = sum(WITMREF,format$("N:15F[ %]",PFMRAT)," ",mess(20,192,1),
&                format$("N:15F[ %]",[F:ITS]MINPFM))                          : # 89275
      # -------------------------------------------------------- #
      # Point d'entree affichage du message de contrôle de marge #
      # -------------------------------------------------------- #
      GPOINT="DSPCTLPFM" : Gosub ENTREE From EXEFNC
      If GMESSAGE="" End Endif
      If GTRACE <> ""
         Call ECR_TRACE(WITMREF, 0) From GESECRAN
         Call ECR_TRACE(GMESSAGE,0) From GESECRAN
      Elsif dim([M]LINTYP(NLIG))<=0 | (dim([M]LINTYP(NLIG))>0 & find([M]LINTYP(NLIG),1,2,6,10))
         # Msg si cde ouverte ou autre doc et l'article n'est pas un composant
         GERR=2
         If GDACLOK=1 GERR=1 : mkstat=2 Endif
      Endif
   Endif
Endif
End

#----------------------------------------------------------------#
# Calcul de la marge (avec alimentation du prix de revient       #
#----------------------------------------------------------------#
# Entrée  MSK      : Masque écran à mettre à jour [M] par défaut #
#                    FQ 47040 + param MSK                        #
#         NLIG     : Ligne                                       #
#         PRI      : Prix                                        #
#         VAT      : Tableau des 3 codes taxes                   #
#         PRITYP   : Type de prix                                #
#         SIT      : Site de stock                               #
#         LITM     : Article                                     #
#         CHGTYP   : Type de cours                               #
#         DAT      : Date de référence                           #
#         CUR      : Devise de référence                         #
#         COEF     : Coef de conversion UV en US                 #
#         INICPRPRI: Init. du prix de revient (0/1/2)            #
#                    (Pas d'init/Init ss raz/Init avec raz)      #
#         XSTOMGTCOD : Maj stock
# Sortie  XPFM     : Marge calculée                              #
#         XCPRPRI  : Prix de revient calculé                     #
#----------------------------------------------------------------#
Subprog CALPFM (MSK,NLIG,PRI,VAT,PRITYP,SIT,LITM,CHGTYP,DAT,CUR,COEF,INICPRPRI,XSTOMGTCOD,XPFM,XCPRPRI)
Value    Char     MSK                                          : # FQ 47040
Value    Integer  NLIG
Value    Decimal  PRI
Value    Char     VAT ()(0..2)
Value    Integer  PRITYP
Value    Char     SIT
Value    Char     LITM
Value    Integer  CHGTYP
Value    Date     DAT
Value    Char     CUR
Value    Decimal  COEF
Value    Integer  INICPRPRI
Value    Integer  XSTOMGTCOD
Variable Decimal  XPFM
Variable Decimal  XCPRPRI

Local    Decimal  PHTNET, COUTHT, MNTDES, MNT1, WQTY
Local    Decimal  WCOEF, LQTY, LCLCAMT1, LCLCAMT2
Local    Char     WITMREF(GLONITM), LVACBPR(GLONTVB)
Local    Integer  LOK, WPRINAT
Local    Integer  LVCRTYP
Local    Date     WDATCONVPRI : # Bug 84596 : Date utilisée pour le calcul des taxes (prix HT/TTC)

Raz COUTHT
# Lecture article et article vente
If !clalev([F:ITM]) Local File ITMMASTER [ITM] Endif

# GA 04/2008 FQ 47040
Local Char     WMSK
If MSK="" WMSK="[M]"
Else WMSK = MSK
Endif

#If dim([M]ITMREF(NLIG))>1
If evalue("dim("+WMSK+"ITMREF(NLIG))")>1
    #WITMREF = [M]ITMREF(NLIG)
    WITMREF = evalue(WMSK+"ITMREF(NLIG)")
Else
    #WITMREF = [M]ITMREF : # Gestion des commandes ouvertes
    WITMREF = evalue(WMSK+"ITMREF") : # Gestion des commandes ouvertes
Endif

If [F:ITM]ITMREF <> WITMREF
   Read [ITM]ITM0 = WITMREF
   If fstat Raz [F:ITM] Endif
Endif

#Raz XPFM
#   ------------------------------------------------------------- #
#   Spécificité USA : Pas d'appel au sous-pro de calcul des taxes #
#   ------------------------------------------------------------- #
#Call LECKUACT("KUA",LOK) from TRTX3
#If LOK
If dim([M:SIH0]INVTYP)>0 & [M:SIH0]INVTYP=2 & evalue(WMSK+"QTY(NLIG)")=0
    # Avoir en  valeur
    PHTNET = evalue(WMSK+"AMTLIN(NLIG)")
    Raz INICPRPRI : # Calcul de la marge sans recherche du prix de revient
Else
    # If GLOCUSATAX   # 106867.o
    If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
        #[M]NETPRINOT(NLIG) = PRI
        #[M]NETPRIATI(NLIG) = PRI
        Assign WMSK+"NETPRINOT(NLIG)" With PRI
        Assign WMSK+"NETPRIATI(NLIG)" With PRI
    Else
        Raz LCLCAMT1, LCLCAMT2
        If evalue("dim("+WMSK+"CLCAMT1)")>0 LCLCAMT1=evalue(WMSK+"CLCAMT1(NLIG)") Endif
        If evalue("dim("+WMSK+"CLCAMT2)")>0 LCLCAMT2=evalue(WMSK+"CLCAMT2(NLIG)") Endif
        If evalue("dim("+WMSK+"QTY)")>0     LQTY    =evalue(WMSK+"QTY(NLIG)")     Endif
        # Bug 66165 : Pb de classe : Le Champ VACBPR n'est pas sur le même écran que les lignes
        #If evalue("dim("+WMSK+"VACBPR)")>0  LVACBPR =evalue(WMSK+"VACBPR")        Endif
        If dim([M]VACBPR)>0 LVACBPR =[M]VACBPR  Endif

        # Bug 83616 : Formule de taxe parafiscale non évaluée
        # Ajout PE avant calcul de la marge
        # Permet le recalcul des bases calcul de taxe avant calcul du prix TTC
        Local Char WABREV
        Case GFONCTION
            When "GESSQH" :
                WABREV="SQH2"
            When "GESSOH", "GESPOH" :
                WABREV="SOH4"
            When "GESSDH" :
                WABREV="SDH1"
            # 91606 :(04/08/14) Transportation notes (Sales part dev)
            When "GESTNH" :
                WABREV="TNH1"
            # 91606 :(04/08/14) Transportation notes (Sales part dev)
            When "GESSIH" :
                WABREV="SIH4"
        Endcase
        If WABREV<>"" GPOINT="CALPFM0" : Gosub ENTREE From EXEFNC Endif
        # Bug 83616

        # Bug 84596 : Date utilisée pour le calcul des taxes (prix HT/TTC)
        WDATCONVPRI=DAT
        If GFONCTION="GESSDH" WDATCONVPRI=[M:SDH1]DLVDAT Endif
        # 91606 :(04/08/14) Transportation notes (Sales part dev)
        If GFONCTION="GESTNH" WDATCONVPRI=[M:TNH1]DLVDAT Endif
        # Bug 95337 : Date utilisée pour le calcul des taxes (prix HT/TTC)
        # Utiliser [M]VATDAT si le champ est renseigné (sinon ce sera [M]INVDAT par défaut)
        If GFONCTION="GESSIH" & dim([M:SIH2]VATDAT)>0 & [M:SIH2]VATDAT<>[0/0/0]
            WDATCONVPRI=[M:SIH2]VATDAT
        Endif
        # Bug 95337
        # 107888 : Scheduled invoices : (LD:22/12/15)
        If find(GFONCTION, "GESSOH", "GESPOH")
            # Order management
            # If the line is tied to an invoice condition and the price has changed
            # --> The invoice schedule has to be updated
            If [M:SOH4]DINVCND(NLIG)<>""
                If PRITYP=1
#Infbox [M:SOH4]ITMREF(NLIG)-"NLIG:"-num$(NLIG)-"PRI:"-num$(PRI)-"[M:SOH4]NETPRINOT(NLIG):"-num$([M:SOH4]NETPRINOT(NLIG))
                    # Issue 107888 - 2016-09-09 by CPO : US150 Free products not deliverable invoicing
                    #If [M:SOH4]NETPRINOT(NLIG)<>PRI
                    If [M:SOH4]NETPRINOT(NLIG)<>PRI or (PRI=0 and [M:SOH4]NETPRINOT(NLIG)=PRI)
                        [M:SOH4]DINVCNDTOUPD(NLIG)=[V]CST_AYES
                        [M:SOH4]DINVCNDTODIS(NLIG)=[V]CST_AYES #CPO 18/01/2016 Thus, we only do it once after an order line modification
                    Else
                        # Issue 107888 - 2016-09-09 by CPO : US150 Free products not deliverable invoicing
                        # Keep values as they were......maybe other modifications lead to update
                        #[M:SOH4]DINVCNDTOUPD(NLIG)=[V]CST_ANO
                        #[M:SOH4]DINVCNDTODIS(NLIG)=[V]CST_ANO #CPO 18/01/2016 Thus, we only do it once after an order line modification
                    Endif
                Else
#Infbox [M:SOH4]ITMREF(NLIG)-"PRI:"-num$(PRI)-"[M:SOH4]NETPRIATI(NLIG):"-num$([M:SOH4]NETPRIATI(NLIG))
                    # Issue 107888 - 2016-09-09 by CPO : US150 Free products not deliverable invoicing
                    #If [M:SOH4]NETPRIATI(NLIG)<>PRI
                    If [M:SOH4]NETPRIATI(NLIG)<>PRI  or (PRI=0 and [M:SOH4]NETPRIATI(NLIG)=PRI)
                        [M:SOH4]DINVCNDTOUPD(NLIG)=[V]CST_AYES
                        [M:SOH4]DINVCNDTODIS(NLIG)=[V]CST_AYES #CPO 18/01/2016 Thus, we only do it once after an order line modification
                    Else
                        # Issue 107888 - 2016-09-09 by CPO : US150 Free products not deliverable invoicing
                        # Keep values as they were...maybe other modifications lead to update
                        #[M:SOH4]DINVCNDTOUPD(NLIG)=[V]CST_ANO
                        #[M:SOH4]DINVCNDTODIS(NLIG)=[V]CST_ANO #CPO 18/01/2016 Thus, we only do it once after an order line modification
                    Endif
                Endif
#Infbox [M:SOH4]ITMREF(NLIG)-"[M:SOH4]DINVCNDTOUPD(NLIG):"-num$([M:SOH4]DINVCNDTOUPD(NLIG))
            Endif
        Endif
        # 107888 : Scheduled invoices : (LD:22/12/15)

        If PRITYP=1
           Assign WMSK+"NETPRINOT(NLIG)" With PRI
           # Bug 84596 : Date utilisée pour le calcul des taxes (prix HT/TTC)
#           Call CLCTAXEPRIV(PRI,VAT,PRITYP,GSOCIETE,DAT,LQTY,LVACBPR,LCLCAMT1,LCLCAMT2,
#&                          GBIDD1) From TRTX3
           Call CLCTAXEPRIV(PRI,VAT,PRITYP,GSOCIETE,WDATCONVPRI,LQTY,LVACBPR,LCLCAMT1,LCLCAMT2,
&                          GBIDD1) From TRTX3
           # Bug 84596
           Assign WMSK+"NETPRIATI(NLIG)" With GBIDD1
        Else
           Assign WMSK+"NETPRIATI(NLIG)" With PRI
           # Bug 84596 : Date utilisée pour le calcul des taxes (prix HT/TTC)
#           Call CLCTAXEPRIV(PRI,VAT,PRITYP,GSOCIETE,DAT,LQTY,LVACBPR,LCLCAMT1,LCLCAMT2,
#&                          GBIDD1) From TRTX3
           Call CLCTAXEPRIV(PRI,VAT,PRITYP,GSOCIETE,WDATCONVPRI,LQTY,LVACBPR,LCLCAMT1,LCLCAMT2,
&                          GBIDD1) From TRTX3
           # Bug 84596
           Assign WMSK+"NETPRINOT(NLIG)" With GBIDD1
        Endif
    Endif
    PHTNET = evalue(WMSK+"NETPRINOT(NLIG)")
Endif

# Bug 59950 : Si Ligne de facture issue d'une livraison : Pas de recalcul du prix de revient
If dim([M:SIH0]INVTYP)>0 & [M:SIH0]INVTYP=1 & dim([M:SIH1]SIHORI)>0 & [M:SIH1]SIHORI=3 &
&  dim([M:SIH4]SDHNUM(NLIG))>0 & [M:SIH4]SDHNUM(NLIG)<>""
    Raz INICPRPRI
Endif

WQTY = 0
If evalue("dim("+WMSK+"QTYSTU(NLIG))")>0
    #WQTY = [M]QTYSTU(NLIG)             : # Bug 73863
    WQTY = evalue(WMSK+"QTYSTU(NLIG)")  : # Bug 73863
Elsif evalue("dim("+WMSK+"QTY(NLIG))")>0
    Call CNVQTY(evalue(WMSK+"QTY(NLIG)"),evalue(WMSK+"SAUSTUCOE(NLIG)"),evalue(WMSK+"STU(NLIG)"), WQTY) From TRTVENQTE
Endif
If INICPRPRI <> 0
# Calcul du prix de revient
#    If XSTOMGTCOD <> 1 : # dde 10803 : rechercher le prix de revient systématiquement
#       Si article géré en stock : recherche
        If GFONCTION="GESSDH" LVCRTYP=4 Endif : # Bug 59950:Si prix moyen lot, il faut identifier le document origine
        If GFONCTION="GESSIH" LVCRTYP=5 Endif
#        Call DEFCPR (LITM,SIT,0,"",0,NLIG,DAT,WQTY,COUTHT,LOK) From STKVAL
        Call DEFCPR (LITM,SIT,LVCRTYP,"",0,NLIG,DAT,WQTY,COUTHT,LOK) From STKVAL
#       Pb à la récup du prix de revient
        If LOK <> 0
#           Réinit du prix de revient
            If INICPRPRI=2
                Raz XCPRPRI, XPFM
            Elsif XCPRPRI = 0 & XPFM = 0
#           On conserve l'ancien prix de revient s'il était renseigné
#           et on recalcule la marge ssi elle était renseignée
            Else
                COUTHT = XCPRPRI
            Endif
        Else
            # Si devise document <> devise base calcul marge (société du site expé)
            If CUR <> GLOCALDEV & COUTHT <> 0
                # 89253 : Si facture, conversion en utilisant les cours de la facture
                If GFONCTION="GESSIH"
                  Local Decimal WCOURS : WCOURS=0
                  # Issue X3-38450
                  #If [M:SIH2]RATDIV(GTYPGEN-1)<>0 WCOURS=arr(1/([M:SIH2]RATMLT(GTYPGEN-1)/[M:SIH2]RATDIV(GTYPGEN-1)), 10^-GDECRCU) : Endif
                  If [M:SIH2]RATDIV(GTYPGEN-1)<>0 & [M:SIH2]RATMLT(GTYPGEN-1)<>0 WCOURS=arr(1/([M:SIH2]RATMLT(GTYPGEN-1)/[M:SIH2]RATDIV(GTYPGEN-1)), 10^-GDECRCU) : Endif
                  # End issue X3-38450
                  Call COURMNT(GLOCALDEV,CUR,GLOCALDEV,CHGTYP,DAT,0, COUTHT,MNTDES,WCOURS,LOK) From TRTDEV
                Else
                  Call CONVERT2(GLOCALDEV, CUR, GLOCALDEV, CHGTYP, DAT, COUTHT, MNTDES, LOK) From TRTDEV
                Endif
                #Call CONVERT2 (GLOCALDEV, CUR, GLOCALDEV, CHGTYP, DAT, COUTHT, MNTDES, LOK) From TRTDEV
                # 89253
                COUTHT = MNTDES
            Endif
#           On ne touche pas au prix revient s'il était renseigné et qu'on récupère 0
            If INICPRPRI=1 & COUTHT = 0 & XCPRPRI <> 0
                COUTHT=XCPRPRI
            Else
            # Le prix de revient est exprimé en US : Le convertir en UV
                COUTHT=COUTHT*COEF
            Endif
        Endif
#     Else
#        COUTHT = XCPRPRI
        Gosub CALSPEPFM
#Elsif XCPRPRI = 0 & XPFM=0 Goto END1 : # 88448
Else
    COUTHT=XCPRPRI
Endif
#XCPRPRI=arr(COUTHT,10^-GDECPRI)
If GSALRND = 2
    Call ARRDEV(COUTHT,CUR) From TRTDIV
    XCPRPRI=COUTHT
Else
    XCPRPRI=arr(COUTHT,10^-GDECPRI)
Endif

# Calcul de marge pour les articles vendus ou les articles livrables ayant un prix net
If [F:ITM]SALFLG=2 | ([F:ITM]SALFLG=1 & PHTNET<>0)
    # --> Calcul de la marge
    XPFM = PHTNET  - XCPRPRI    : # Le calcul doit repartir du prix de revient que l'on va afficher et stocker
    #XPFM = PHTNET  - COUTHT
    #Call ARRDEV(XPFM, CUR) From TRTDIV
Endif

$END1
# Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) #
If GFONCTION="GESSIH" and dim([M:SIH0]INVTYP)>0 and [M:SIH0]INVTYP=1 and dim([M:SIH1]SIHORI)>0 and [M:SIH1]SIHORI=10 and
&  dim([M:SIH4]VCRINVCNDLIN(NLIG))>0 & [M:SIH4]VCRINVCNDLIN(NLIG)>0 and dim([M:SIH4]SIDORI(NLIG))>0 and [M:SIH4]SIDORI(NLIG)=10
  Gosub CALPFM_SVIC From LIBSAL_INVCND_SIH # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) #
Endif
# End issue 107888
Gosub CALSPEPFM1

End

$CALSPEPFM
#    --------------------------------------------------------------------------#
#    Point d'entree calcul d'un cout supplémentaire pour le calcul de la marge #
#    --------------------------------------------------------------------------#
Local Decimal WPOINT_COUT
Local Integer WPOINT_RET:WPOINT_RET = 0

Global Integer GCALPFM
GCALPFM = 0
If GFONCTION="FUNAUTDLV" | (GFONCTION="GESSDH" & GCREPARBOU=1)
   GCALPFM = 1
Endif
If GFONCTION="FUNCFMDLV" | (GFONCTION="GESSDH" & GACTION="DIVVALLIV")
   GCALPFM = 2
Endif
If GFONCTION="FUNAUTINVO" | (GFONCTION="GESSIH" & GCREPARBOU=1)
   GCALPFM = 3
Endif
If GFONCTION="FUNCFMINV" | (GFONCTION="GESSIH" & GACTION="TRTVALSIH")
   GCALPFM = 4
Endif
If GFONCTION="GESSOR"
   GCALPFM = 5
Endif
# Bug 61253
If GFONCTION="GESSIH" & dim([M:SIH0]INVTYP)>0 & [M:SIH0]INVTYP=2 & dim(ACTION)=1 & ACTION="INICRE_LIG"
   GCALPFM = 6
Endif
# Bug 80451
# Fenêtre de modification des sorties depuis les livraisons
If GFONCTION="GESSDH" & GACTION="SAISTOSORM"
   GCALPFM = 7
Endif
# Régularisation des prix
If GFONCTION="FUNSTKADJ"
   GCALPFM = 8
Endif
# Bug 80451

# Issue X3-84450
# Régularisation des stocks manquants
If GFONCTION="FUNSHTSEL"
   GCALPFM = 9
Endif
# End issue X3-84450

GPOINT="CALPFM" : Gosub ENTREE From EXEFNC
If WPOINT_RET COUTHT = COUTHT+WPOINT_COUT  Endif
Return

$CALSPEPFM1
#    --------------------------------------------------------------------------#
#    Point d'entree pour recalcul de la marge                                  #
#    --------------------------------------------------------------------------#
Global Integer GCALPFM
GCALPFM = 0
If GFONCTION="FUNAUTDLV" | (GFONCTION="GESSDH" & GCREPARBOU=1)
   GCALPFM = 1
Endif
If GFONCTION="FUNCFMDLV" | (GFONCTION="GESSDH" & GACTION="DIVVALLIV")
   GCALPFM = 2
Endif
If GFONCTION="FUNAUTINVO" | (GFONCTION="GESSIH" & GCREPARBOU=1)
   GCALPFM = 3
Endif
If GFONCTION="FUNCFMINV" | (GFONCTION="GESSIH" & GACTION="TRTVALSIH")
   GCALPFM = 4
Endif
If GFONCTION="GESSOR"
   GCALPFM = 5
Endif
# Bug 61253
If GFONCTION="GESSIH" & dim([M:SIH0]INVTYP)>0 & [M:SIH0]INVTYP=2 & dim(ACTION)=1 & ACTION="INICRE_LIG"
   GCALPFM = 6
Endif
# Bug 80451
If GFONCTION="GESSDH" & GACTION="SAISTOSORM"
   GCALPFM = 7
Endif
If GFONCTION="FUNSTKADJ"
   GCALPFM = 8
Endif
# Bug 80451

# Issue X3-84450
# Régularisation des stocks manquants
If GFONCTION="FUNSHTSEL"
   GCALPFM = 9
Endif
# End issue X3-84450

GPOINT="CALPFM1" : Gosub ENTREE From EXEFNC
Return

#----------------------------------------------------------------#
# Formattage d'un montant avec le format de la devise            #
#----------------------------------------------------------------#
# Entrée  MNTORI   : Montant à formatter                         #
#         CUR      : Devise                                      #
#         MNTDES   : Montant formatté (dans une chaine)          #
#----------------------------------------------------------------#
Subprog FMT_MNTCUR(MNTORI, CUR, MNTDES)
Value    Decimal MNTORI
Value    Char    CUR
Variable Char    MNTDES

If CUR    = "" End:Endif

If clalev([F:TCU]) = 0 Local File TABCUR [TCU]:Endif
If [F:TCU]CUR <> CUR Read [TCU] TCU0=CUR
                   If fstat Raz [F:TCU] :Endif
                   Endif
Call ARRDEV (MNTORI, CUR) From TRTDIV

MNTDES = format$("N3:15F[ ]", MNTORI)

End

#---------------------------------------------------------------#
# Sous-prog CALCNETPRI : Calcul du prix net         FQ 47040    #
#                                                               #
#    Idem CLCNETPRI (+ ajout du code MSK)                       #
#---------------------------------------------------------------#
# Entrée  MSK      : Masque écran à mettre à jour [M] par défaut#
#         QTY      : Quantite                                   #
#         CUR      : Devise                                     #
#         NLIG     : Numéro de la ligne (nolign-1)              #
#---------------------------------------------------------------#
Subprog CALCNETPRI(MSK, QTY, CUR, NLIG)
Value Char    MSK  : # FQ 47040
Value Decimal QTY
Value Char    CUR
Value Integer NLIG

Local Decimal  GROPRI, MAJREM(0..8), NETPRI
Local Shortint I

# GA 04/2008 FQ 47040
Local Char     WMSK
If MSK="" WMSK="[M]"
Else WMSK = MSK
Endif

# Si l'on est sur une ligne d'avoir en valeur, pas de calcul du prix net
If dim([M:SIH0]INVTYP)>0 & [M:SIH0]INVTYP=2 & evalue(WMSK+"QTY(NLIG)")=0 End Endif

#GROPRI=[M]GROPRI(NLIG)
GROPRI=evalue(WMSK+"GROPRI(NLIG)")
For I=1 To 9
    If evalue("dim("+WMSK+"DISCRGVAL"+num$(I)+"(NLIG))")>0
       MAJREM(I-1)=evalue(WMSK+"DISCRGVAL"+num$(I)+"(NLIG)")
    Endif
Next I

#If [M]FOCFLG(NLIG) = 3 End Endif
If evalue(WMSK+"FOCFLG(NLIG)") = 3 End Endif

# --> Calcul du prix net
If dim(GCALNETLIN)>0 : GCALNETLIN=NLIG+1   : Endif
If dim(GCALNETABR)>0 : GCALNETABR=WMSK     : Endif   : # FQ 47040 avant "[M]"
If dim([M]PLISTC)>0  : # ne pas utiliser WMSK ici
   Call CALNET (1,[M]PLISTC, GROPRI,MAJREM,QTY,NETPRI,CUR) From TRTPRICE
Else
   Call CALNET (1,"", GROPRI,MAJREM,QTY,NETPRI,CUR) From TRTPRICE
Endif

#[M]NETPRI(NLIG) = NETPRI
Assign WMSK+"NETPRI(NLIG)"  With NETPRI
# --> Si netpri = 0 : Pas de passage dans le calcul de la marge
#                     Les prix ne seront pas recalculés : Il faut les raz
If NETPRI = 0
   #[M]NETPRINOT(NLIG) = 0
   #[M]NETPRIATI(NLIG) = 0
   Assign WMSK+"NETPRINOT(NLIG)" With 0
   Assign WMSK+"NETPRIATI(NLIG)" With 0
Endif
End

#---------------------------------------------------------------#
# Sous-prog CALCPFM : Calcul du prix net            FQ 47040    #
#                                                               #
#    Idem CLCPFM (+ ajout du code MSK)                          #
#---------------------------------------------------------------#
# Entrée  MSK      : Masque écran à mettre à jour [M] par défaut#
#         SITE     : Site                                       #
#         PRITYP   : Type de prix                               #
#         CHGTYP   : Type de cours                              #
#         DAT      : Date de référence                          #
#         CUR      : Devise                                     #
#         NLIG     : Numéro de la ligne (nolign-1)              #
#         INICPRPRI: Init du prix de revient (0,1,2)            #
#---------------------------------------------------------------#
Subprog CALCPFM(MSK,SITE, PRITYP, CHGTYP, DAT, CUR, NLIG, INICPRPRI)
Value    Char     MSK                             : # FQ 47040
Value    Char     SITE
Value    Integer  PRITYP
Value    Integer  CHGTYP
Value    Date     DAT
Value    Char     CUR
Value    Integer  NLIG
Value    Integer  INICPRPRI

Local    Decimal PFM
Local    Char    VAT(GLONVAT)(3)
Local    Decimal WQTY

Local    Char    WITMREF
Local    Decimal WNETPRI, WSAUSTUCOE, WCPRPRI
Local    Integer WSTOMGTCOD

# GA 04/2008 FQ 47040
Local Char     WMSK
If MSK="" WMSK="[M]"
Else WMSK = MSK
Endif

#VAT (0) = [M]VAT1(NLIG)
VAT (0) = evalue(WMSK+"VAT1(NLIG)")
VAT (1) = evalue(WMSK+"VAT2(NLIG)")
VAT (2) = evalue(WMSK+"VAT3(NLIG)")

# --> Calcul de la marge
#PFM=[M]PFM(NLIG)
PFM=evalue(WMSK+"PFM(NLIG)")

WNETPRI   = evalue(WMSK+"NETPRI(NLIG)")
WITMREF   = evalue(WMSK+"ITMREF(NLIG)")
WSAUSTUCOE= evalue(WMSK+"SAUSTUCOE(NLIG)")
WSTOMGTCOD= evalue(WMSK+"STOMGTCOD(NLIG)")
WCPRPRI   = evalue(WMSK+"CPRPRI(NLIG)")
Call CALPFM(MSK,NLIG,WNETPRI, VAT, PRITYP, SITE, WITMREF, CHGTYP, DAT, CUR,
&           WSAUSTUCOE, INICPRPRI, WSTOMGTCOD, PFM, WCPRPRI) From TRTVENPRI
Assign WMSK+"CPRPRI(NLIG)" With WCPRPRI

# Bug 43723 : Pas de calcul de la marge pour les gratuits
#If [M]NETPRI(NLIG)<>0 | (dim([M]FOCFLG(NLIG))>0 & [M]FOCFLG(NLIG)<>3)
If evalue(WMSK+"NETPRI(NLIG)")<>0 | (evalue("dim("+WMSK+"FOCFLG(NLIG))")>0 & evalue(WMSK+"FOCFLG(NLIG)")<>3)
    #[M]PFM(NLIG)=PFM
    Assign WMSK+"PFM(NLIG)" With PFM
Endif

End

