    Call ECR_TRACE(CHAINE,0) From GESECRAN
   Endif
  Endif
 Next AOM
Return

$SETID
Raz CLEID , NBID
While CHAINE<>""
 NBID += 1
 I = instr(1,CHAINE,"~")
 If I & NBID<16
  CLEID(NBID) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLEID(NBID) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

$SETNEW
NEWKEY = ""
If sum(CLEID)<>""
 For I=1 To dim(CLESEC)
  If I>1 : NEWKEY += "~" : Endif
  If CLESEC(I-1)<>CLELIG & I<=dim(CLEID)
   NEWKEY += CLEID(I)
  Endif
 Next I
Endif
Return

$ER
ER = errn
Resume

$VIRE_TILDE
While CHAINE<>""
 If right$(CHAINE,len(CHAINE))<>"~"
  Break
 Endif
 CHAINE = left$(CHAINE,len(CHAINE)-1)
Wend
Return

