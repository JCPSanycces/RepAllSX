#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"FSAIANA","SAIANA","DSAIANA",4,"") From GTRAITE
End

######################################################################
## Action du programme principal
######################################################################
$ACTION
Case ACTION
 When "INIT"            : Gosub INIT
 When "CONTROLE"        : Gosub CONTROLE
 When "TERMINE"         : Gosub TERMINE
 When "FIN"             : Gosub FIN
 When "SORTIE"          : Gosub SORTIE

 When Default
  Case BOITE
   When "DSAIANA"       : Gosub PARAM
   When Default         : Gosub BOITE
  Endcase
Endcase
Return

######################################################################
## Actions de la fenêtre paramètres
######################################################################
$PARAM
Case ACTION
 When "OUVRE_BOITE"
  Call LECMEMO("STD","[M:DIA]","ana") From GMEMO
 When "DEBUT"
  If [M:DIA]TOUSEC = 2  :  [M:DIA]AXE    = ""  :  Endif
  If [M:DIA]SAISI<>4    :  [M:DIA]DIESAI = ""   :  Endif
  Affzo [DIA]
  Setmok [DIA] With 0
  When "SETBOUT"
   ETABOU(GVALI) = 1  : # OK
   ETABOU(GBFIN) = 1  : # Fin
  When "OK"
   FIN = 1
   GOK = 1   : # Pour enchaîner
  When "END"
   FIN = 1
   GOK = 0   : # Pour s'arrêter
Endcase
Return

######################################################################
## Actions de la fenêtre principale
######################################################################
$BOITE
Case ACTION
 When "DEBUT"           : Gosub DEBUT
 When "AVANT_BOUTON"    : Gosub AVANT_BOUTON
 When "BOUTON"          : Gosub BOUTON
 When "APRES_MODIF"     : Gosub APRES_MODIF
 When "SETBOUT"         : Gosub SETBOUT
 When "ENR"             : Gosub ENREGISTRER
 When "ABA"             : Gosub ABANDON
 When "END"             : Gosub FIN
 When "SUI"             : Gosub SUIVANT
 When "PRE"             : Gosub PRECEDENT
 When "FIR"             : Gosub PREMIER
 When "LAS"             : Gosub DERNIER
Endcase
Return


######################################################################
$INIT
Local File FISCALYEAR [FIY] , PERIOD     [PER] , COMPANY    [CPY]  , FACILITY   [FCY]  , TABCUR     [TCU]
&        , GACCENTRY  [HAE] , GACCENTRYD [DAE] , GACCENTRYA [DAA]  , GACCENTRYD [DAE2] , GACCENTRYA [DAA2]
&        , GDIE       [DIE] , CACCE      [CCE] , GACCOUNT   [GAC]  , CADSP      [DSP], GACM       [GCM]
&        , TABUNIT    [TUN] , CAAUZ      [AUZ] , CACCE      [CCE2] , GJOURNAL   [JOU]
&        , BALANCE    [BAL] , BALANA     [BLA] , GTYPACCENT [GTE]  , BLAQTY     [BLQ]

Local Mask CRITANA    [DIA] , VENTILE    [VTL] , VENTILE2   [VT2]
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif

Local Char INTDIE(80)
Local Integer IND, AXI
Local Integer NUMAXE

Local Integer TLEDTYP(1..len(mess(0,2644,1)))  : # Liste des types de référentiel non automatique "Analytique"
Local Integer TNBLED                           : # Nombre de types de référentiel non automatique "Analytique"

Raz [M:DIA]
Return

##########
$CONTROLE
If GOK=0 : FIN=1 : Return : Endif

Local Integer OK
If [M:DIA]TOUSOC=2
 SOC=""
Else
 SOC=[M:DIA]SOCIETE
Endif
Call LOCKCPY(SOC, OK) From AX3MONO
If !OK : FIN=1 : Return : Endif

If GNBLEG=1
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG=[M:DIA]LEG
Endif

[L]OK = 0
Gosub FILTRE
Filter [DAE] Where evalue(FILTRE)
For [DAE]DAE1
 Gosub TEST
 If OK : Break : Endif
Next
If !OK
 GMESSAGE = mess(54,107,1)
 Filter [DAE]
 GERR = 1 : Return
Endif
If [M:DIA]SAICRITANA=2
 SAI = 1 : Return
Endif
If [M:DIA]TRACE=2 & GTRACE=""
 Call OUVRE_TRACE(mess(53,107,1)) From LECFIC
 GMODIF = 0
Endif
Return

##########
$TERMINE
If GOK=2 : # Bouton critères
 SAI = 1
Elsif GMODIF & GTRACE<>""
 Call FERME_TRACE From LECFIC
 TRA = 1
Endif
Return

##########
$SORTIE
Call UNLOCKCPY() From AX3MONO
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

##################################################################################
## Actions de la fenêtre principale
##################################################################################
$DEBUT
Local Char INTDIE(80)
Local Integer IND, AXI
Local Integer NUMAXE

Local Integer TLEDTYP(1..len(mess(0,2644,1)))  : # Liste des types de référentiel non automatique "Analytique"
Local Integer TNBLED                           : # Nombre de types de référentiel non automatique "Analytique"

Local Integer I , J , K
Local Integer VERROU
Local Char    SYMBOLE(30)
Local Char    OVAL(75) , NVAL(75)
Local Decimal AROLED, COURS
Local Decimal TMPLED(dim([M:VTL]AMT))
Local Integer TYPLEDVLDAUT(1..len(mess(0,2644,1))) : # Liste des types de référentiel rpt en valid auto
Local Integer NBRVLDAUT, NB
Local Char    LSTTYPLED(10) : # Liste des types référentiels flagués 'Double Entry Method'
Gosub FILTRE
Filter [DAE] Where evalue(FILTRE)
Gosub CHARGE
Return

$FILTRE
Local Char    FILTRE(250)
FILTRE = "1=1"
If [M:DIA]CPTDEB<>""                 :  FILTRE -= '& ACC>="'+[M:DIA]CPTDEB+'"'                     : Endif
If [M:DIA]CPTFIN<>""                 :  FILTRE -= '& ACC<="'+[M:DIA]CPTFIN+'"'                     : Endif
If [M:DIA]TOUSOC<>2                  :  FILTRE -= '& CPY="'+[M:DIA]SOCIETE+'"'                     : Endif
If [M:DIA]TOUSIT<>2                  :  FILTRE -= '& FCYLIN="'+[M:DIA]SITE+'"'                     : Endif
If [M:DIA]TOULED<>2                  :  FILTRE -= '& LEDTYP='+num$([M:DIA]LEDTYP)                  : Endif
If [M:DIA]TOUTYP<>2                  :  FILTRE -= '& TYP="'+[M:DIA]TYP+'"'                         : Endif
If [M:DIA]DATDEB<>[0/0/0]            :  FILTRE -= '& ACCDAT>=['+format$(GFMD,[M:DIA]DATDEB)+']'    : Endif
If [M:DIA]DATFIN<>[0/0/0]            :  FILTRE -= '& ACCDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'    : Endif

#-- Critère tous Types de Référentiel
If  [M:DIA]TOUSOC<>2 & [M:DIA]TOULED=2
 Call LSTLEDTYP([M:DIA]SOCIETE,3,TLEDTYP,TNBLED) From CPTDIV
 FILTRE -='& find(LEDTYP,TLEDTYP)'
Endif
Return

$SETBOUT
If REP="M"
 ETABOU(GSUIV) = 0
 ETABOU(GPREC) = 0
 ETABOU(GPREM) = 0
 ETABOU(GDERN) = 0
 ETABOU(GSPE1) = 0
 ETABOU(GSPE2) = 0
Else
 ETABOU(GSUIV) = 1
 ETABOU(GPREC) = 1
 ETABOU(GPREM) = 1
 ETABOU(GDERN) = 1
 ETABOU(GSPE1) = 1
 ETABOU(GSPE2) = 1
Endif
Return

$APRES_MODIF
If ![L]VERROU
 Gosub VERROU
 If ![L]VERROU
  GMESSAGE = mess(10,100,1)
  GERR = 1 : FOK = 0 : Return
 Endif
Endif
REP = "M"
Return

$ABANDON
Gosub CHARGE
Return

$FIN
If VERROU : Gosub DEVERROU : Endif
Return

$AVANT_BOUTON
Case BOUT
 When "B"
  Filter [DAE]
  GCONSULT = 1
Endcase
Return

$BOUTON
Case BOUT
 When "O" : # Critères
  Gosub ABORT From GSAISIE
  If [L]OK
   FIN = 1 : GOK = 2
  Endif
 When "B"
  GCONSULT = 0
  Gosub FILTRE
  Filter [DAE] Where evalue(FILTRE)
  Read [DAE]DAE0 = [M:SAI1]TYP ; [M:SAI1]NUM ; [M:SAI1]LIN
  If fstat>2
   GERREUR = mess(11,100,1)
   GERR = 1 : Return
  Endif
  Gosub TEST
  If !OK : Return : Endif
  Gosub CHARGE
Endcase
Return

$ENREGISTRER
Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1 : [L]OK = 0 : Endif
[L]OK=0
REP = ""
Return

$TR1
GOK = 1
Trbegin [DAE], [DAA] , [BAL] , [BLA]
 Call LEC_CPY([M:SAI1]CPY) From CPTLEC
 Call LEC_TCU([F:CPY]ACCCUR) From CPTLEC
 AROLED = [F:TCU]CURRND

 Readlock [DAE]DAE0 = [M:SAI1]TYP;[M:SAI1]NUM;[M:SAI1]LIN;[M:SAI1]LEDTYP
 If fstat=1
  GOK = -1 : GLOCK = "$GACCENTRYD"-[M:SAI1]TYP-[M:SAI1]NUM-num$([M:SAI1]LIN) : Goto ROLL_TR1
 Elsif fstat
  GOK = 0 : Call RSTA("DAE",[M:SAI1]TYP-[M:SAI1]NUM-num$([M:SAI1]LIN)) From GLOCK : Goto AB_TR1
 Endif

 Readlock [HAE]HAE0 = [M:SAI1]TYP;[M:SAI1]NUM
 If fstat=1
  GOK = -1 : GLOCK = "$GACCENTRY"-[M:SAI1]TYP-[M:SAI1]NUM : Goto ROLL_TR1
 Elsif fstat
  GOK = 0 : Call RSTA("HAE",[M:SAI1]TYP-[M:SAI1]NUM) From GLOCK : Goto AB_TR1
 Endif

 Call LEDTYPDEM([F:HAE]CPY,LSTTYPLED) From CPTDIV
 Call LEC_GTE_LEG([F:CPY]LEG,[F:HAE]TYP) From CPTLEC
 For [DAA] Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
  Call BALANA(-1) From CPTBAL
  If GOK<1 : Break : Endif
  ## Mise à jour Balance Russe si on est sur le référentiel Russe et sur une ligne éclatée
  If instr(1,LSTTYPLED,num$([F:DAE]LEDTYP)) & [F:DAE]ACCNUMDOE = 0 : # On est sur un référentiel Russe et une ligne éclatée
   Call BALDEM(-1) From CPTBAL
   If GOK<1 : Break : Endif
  Endif
 Next
 If GOK>=0
  Call VALSTA("GAS",-1) From SUBPS2
 Endif
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 Delete [DAA] Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
 If fstat=1
  GOK=-1 : GLOCK = "$GACCENTRYA"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN) : Goto ROLL_TR1
 Endif

 # Gestion des référentiels automatiques
 Call GETTYPLEDVLDAUT([F:HAE]CPY,[F:DAE]LEDTYP,TYPLEDVLDAUT,NBRVLDAUT) From CPTDIV
 For NB=1 To NBRVLDAUT
  Delete [DAA2] Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=TYPLEDVLDAUT(NB)
  If fstat=1
   GOK=-1 : GLOCK = "$GACCENTRYA"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN) : Break
  Endif
 Next
 If GOK=-1 : Goto ROLL_TR1 : Endif
 #

 [F:DAE]QTY = [M:SAI1]QTY
 [F:DAE]UOM = [M:SAI1]UOM
 NVAL = [F:DAE]ACC

 ##--- Réparation manuelle
 If dim([M:SAI1]DSP)>0 & [M:SAI1]DSP="$"

  #--- Calcul le montant en devise de référentiel
  COURS = [F:HAE]RATMLT([F:DAE]LEDTYP-1)/[F:HAE]RATDIV([F:DAE]LEDTYP-1)
  Call CONVERT_DEV([F:HAE]CUR,[F:DAE]CURLED,[F:CPY]ACCCUR,[M:SAI1]PTF-[M:SAI1]PTV+1
& ,[M:VT2]TBAMT([M:SAI1]PTV..[M:SAI1]PTF),TMPLED,COURS
& ,[F:HAE]TYPRAT,[F:HAE]ACCDAT,AROLED) From CPTSUB

  K = 0
  For I=[M:SAI1]PTV To [M:SAI1]PTF
   K += 1
   Raz [F:DAA]
   [F:DAA] = [F:HAE]
   [F:DAA] = [F:DAE]
   [F:DAA]AMTCUR = [M:VT2]TBAMT(I)
   [F:DAA]AMTLED = TMPLED(K-1)
   [F:DAA]QTY    = [M:VT2]TBQTY(I)
   [F:DAA]ANALIN = K
   For J=1 To dim([F:DAA]CCE)
    [F:DAA]DIE(J-1) = evalue("[M:VT2]TBDIE("+num$(J-1)+")")
    [F:DAA]CCE(J-1) = evalue("[M:VT2]TBCCE"+num$(J)+"("+num$(I)+")")
   Next J
   Write [DAA]
   If fstat
    GOK = 0 : Call FSTA("DAA") From GLOCK : Break
   Endif
  Next I

  # Gestion des référentiels automatiques
  For NB=1 To NBRVLDAUT
   Read [DAE2]DAE0 = [M:SAI1]TYP;[M:SAI1]NUM;[M:SAI1]LIN;TYPLEDVLDAUT(NB)
   If !fstat
    #--- Calcul le montant en devise de référentiel
    COURS = [F:HAE]RATMLT([F:DAE2]LEDTYP-1)/[F:HAE]RATDIV([F:DAE2]LEDTYP-1)
    Call CONVERT_DEV([F:HAE]CUR,[F:DAE]CURLED,[F:CPY]ACCCUR,[M:SAI1]PTF-[M:SAI1]PTV+1
&    ,[M:VT2]TBAMT([M:SAI1]PTV..[M:SAI1]PTF),TMPLED,COURS
&    ,[F:HAE]TYPRAT,[F:HAE]ACCDAT,AROLED) From CPTSUB

    K = 0
    For I=[M:SAI1]PTV To [M:SAI1]PTF
     K += 1
     Raz [F:DAA2]
     [F:DAA2] = [F:HAE]
     [F:DAA2] = [F:DAE2]
     [F:DAA2]AMTCUR = [M:VT2]TBAMT(I)
     [F:DAA2]AMTLED = TMPLED(K-1)
     [F:DAA2]QTY    = [M:VT2]TBQTY(I)
     [F:DAA2]ANALIN = K
     For J=1 To dim([F:DAA2]CCE)
      [F:DAA2]DIE(J-1) = evalue("[M:VT2]TBDIE("+num$(J-1)+")")
      [F:DAA2]CCE(J-1) = evalue("[M:VT2]TBCCE"+num$(J)+"("+num$(I)+")")
     Next J
     Write [DAA2]
     If fstat
      GOK = 0 : Call FSTA("DAA2") From GLOCK : Break
     Endif
    Next I
   Endif
  Next NB

  [F:DAE]DSP = ""
  NVAL -= "$"

 ##--- Réparation standard
 Elsif dim([M:SAI1]DSP)>0 & [M:SAI1]DSP<>""
  [M:VTL]TOTREP  = [F:DAE]AMTCUR
  [M:VTL]QTOTREP = [F:DAE]QTY

  #--- Chargement de la répartition
  Call LEC_TCU([M:SAI1]CUR) From CPTLEC
  Call CHARGE_VTE_STR([M:SAI1]DSP,[M:SAI1]UOM,[M:SAI1]LED,[M:SAI1]ACC,"") From VENTILE

  #--- Calcul le montant en devise de référentiel
  COURS = [F:HAE]RATMLT([F:DAE]LEDTYP-1)/[F:HAE]RATDIV([F:DAE]LEDTYP-1)
  Call CONVERT_DEV([F:HAE]CUR,[F:DAE]CURLED,[F:CPY]ACCCUR,[M:VTL]BAS,[M:VTL]AMT,TMPLED,COURS
&                 ,[F:HAE]TYPRAT,[F:HAE]ACCDAT,AROLED) From CPTSUB

 #--- Enregistrement
  Raz [F:DAA]
  [F:DAA] = [F:HAE]
  [F:DAA] = [F:DAE]
  Call LEC_GAC([F:DAE]ACC,[F:DAE]COA) From CPTLEC
  K = 0
  For I=0 To [M:VTL]BAS-1
   K += 1
   [F:DAA]AMTCUR = [M:VTL]AMT(I)
   [F:DAA]AMTLED = TMPLED(I)
   [F:DAA]QTY    = [M:VTL]QTY(I)
   [F:DAA]ANALIN = K
   For J=1 To dim([F:DAA]CCE)
    [F:DAA]DIE(J-1) = evalue("[M:VTL]DIE("+num$(J-1)+")")
    If find([F:DAA]DIE(J-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
     [F:DAA]CCE(J-1) = evalue("[M:VTL]CCE"+num$(J)+"("+num$(I)+")")
    Endif
   Next J
   Write [DAA]
   If fstat
    GOK = 0 : Call FSTA("DAA") From GLOCK : Break
   Endif
  Next I

  # Gestion des référentiels automatiques
  For NB=1 To NBRVLDAUT
   Read [DAE2]DAE0 = [M:SAI1]TYP;[M:SAI1]NUM;[M:SAI1]LIN;TYPLEDVLDAUT(NB)
   If !fstat
    #--- Calcul le montant en devise de référentiel
    COURS = [F:HAE]RATMLT([F:DAE2]LEDTYP-1)/[F:HAE]RATDIV([F:DAE2]LEDTYP-1)
    Call CONVERT_DEV([F:HAE]CUR,[F:DAE]CURLED,[F:CPY]ACCCUR,[M:VTL]BAS,[M:VTL]AMT,TMPLED,COURS
&                 ,[F:HAE]TYPRAT,[F:HAE]ACCDAT,AROLED) From CPTSUB

    Raz [F:DAA2]
    [F:DAA2] = [F:HAE]
    [F:DAA2] = [F:DAE2]
    Call LEC_GAC([F:DAE2]ACC,[F:DAE2]COA) From CPTLEC
    K = 0
    For I=0 To [M:VTL]BAS-1
     K += 1
     [F:DAA2]AMTCUR = [M:VTL]AMT(I)
     [F:DAA2]AMTLED = TMPLED(I)
     [F:DAA2]QTY    = [M:VTL]QTY(I)
     [F:DAA2]ANALIN = K
     For J=1 To dim([F:DAA2]CCE)
      [F:DAA2]DIE(J-1) = evalue("[M:VTL]DIE("+num$(J-1)+")")
      If find([F:DAA2]DIE(J-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
       [F:DAA2]CCE(J-1) = evalue("[M:VTL]CCE"+num$(J)+"("+num$(I)+")")
      Endif
     Next J
     Write [DAA2]
     If fstat
      GOK = 0 : Call FSTA("DAA2") From GLOCK : Break
     Endif
    Next
   Endif
  Next NB
  #
  [F:DAE]DSP = [M:SAI1]DSP
  NVAL -= "*"+[M:SAI1]DSP

 ##--- Répartition saisie sur la ligne d'écriture générale

 Else
  Raz [F:DAA]
  [F:DAA] = [F:HAE]
  [F:DAA] = [F:DAE]
  [F:DAA]ANALIN = 1
  For J=1 To dim([F:DAA]CCE)
   [F:DAA]DIE(J-1) = evalue("[M:SAI1]DIE("+num$(J-1)+")")
   [F:DAA]CCE(J-1) = evalue("[M:SAI1]CCE("+num$(J-1)+")")
   NVAL -= [F:DAA]CCE(J-1)
  Next J
  If sum([F:DAA]CCE(0..dim([F:DAA]CCE)-1))<>""  | GLEDDIEIPT(IND)=2
   Write [DAA]
   If fstat
    GOK = 0 : Call FSTA("DAA") From GLOCK : Goto AB_TR1
   Endif

   # Gestion des référentiels automatiques
   For NB=1 To NBRVLDAUT
    Read [DAE2]DAE0 = [M:SAI1]TYP;[M:SAI1]NUM;[M:SAI1]LIN;TYPLEDVLDAUT(NB)
    If !fstat
     Raz [F:DAA2]
     [F:DAA2] = [F:HAE]
     [F:DAA2] = [F:DAE2]
     [F:DAA2]ANALIN = 1
     For J=1 To dim([F:DAA2]CCE)
      [F:DAA2]DIE(J-1) = evalue("[M:SAI1]DIE("+num$(J-1)+")")
      [F:DAA2]CCE(J-1) = evalue("[M:SAI1]CCE("+num$(J-1)+")")
     Next J
     Write [DAA2]
     If fstat
      GOK = 0 : Call FSTA("DAA2") From GLOCK : Goto AB_TR1
     Endif
     Endif
   Next NB
   #
  Endif
  [F:DAE]DSP = ""
 Endif
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Rewrite [DAE]
 If fstat
  GOK=0 : Call FSTA("DAE") From GLOCK : Goto AB_TR1
 Endif
 For NB=1 To NBRVLDAUT
  Read [DAE2]DAE0 = [M:SAI1]TYP;[M:SAI1]NUM;[M:SAI1]LIN;TYPLEDVLDAUT(NB)
  If !fstat
   [F:DAE2]QTY = [F:DAE]QTY
   [F:DAE2]UOM = [F:DAE]UOM
   [F:DAE2]DSP = [F:DAE]DSP
   Rewrite [DAE2]
   If fstat
    GOK = 0 : Call FSTA("DAE") From GLOCK : Break
   Endif
  Endif
 Next NB
 For [DAA] Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
  Call BALANA(+1) From CPTBAL
  If GOK<1 : Break : Endif
  ## Mise à jour Balance Russe si on est sur le référentiel Russe et sur une ligne éclatée
  If instr(1,LSTTYPLED,num$([F:DAE]LEDTYP)) & [F:DAE]ACCNUMDOE = 0 : # On est sur un référentiel Russe et une ligne éclatée
   Call BALDEM(+1) From CPTBAL
   If GOK<1 : Break : Endif
  Endif
 Next
 For NB=1 To NBRVLDAUT
  For [DAA] Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=TYPLEDVLDAUT(NB)
   Call BALANA(+1) From CPTBAL
   If GOK<1 : Break 2 : Endif
   ## Mise à jour Balance Russe si on est sur le référentiel Russe et sur une ligne éclatée
   If instr(1,LSTTYPLED,num$([F:DAE]LEDTYP)) & [F:DAE]ACCNUMDOE = 0 : # On est sur un référentiel Russe et une ligne éclatée
    Call BALDEM(+1) From CPTBAL
    If GOK<1 : Break 2 : Endif
   Endif
  Next
 Next
 If GOK>=0
  Call VALSTA("GAS",+1) From SUBPS2
 Endif
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
If [M:DIA]TRACE=2 & OVAL<>NVAL
 Call ECR_TRACE(mess(12,107,1)-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN),0) From GESECRAN
 Call ECR_TRACE("<"-OVAL,0) From GESECRAN
 Call ECR_TRACE(">"-NVAL,0) From GESECRAN
 Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
 GMODIF = 1
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$SUIVANT
Read [DAE]DAE1 >
If fstat>2
 GERR = 2
 GMESSAGE = mess(11,100,1)
 Return
Endif
Gosub TEST
If !OK : Goto SUIVANT : Endif
Gosub CHARGE
Return

$PRECEDENT
Read [DAE]DAE1 <
If fstat>2
 GERR = 2
 GMESSAGE = mess(11,100,1)
 Return
Endif
Gosub TEST
If !OK : Goto PRECEDENT : Endif
Gosub CHARGE
Return

$DERNIER
Read [DAE]DAE1 Last
If fstat>2
 GERR = 2
 GMESSAGE = mess(11,100,1)
 Return
Endif
Gosub TEST
If !OK : Goto PRECEDENT : Endif
Gosub CHARGE
Return

$PREMIER
Read [DAE]DAE1 First
If fstat>2
 GERR = 2
 GMESSAGE = mess(11,100,1)
 Return
Endif
Gosub TEST
If !OK : Goto SUIVANT : Endif
Gosub CHARGE
Return

$CHARGE
If VERROU : Gosub DEVERROU : Endif
Raz [M:SAI1]
Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
[M:SAI1] = [F:HAE]
[M:SAI1] = [F:DAE]

If [F:DAE]SNS>0
 [M:SAI1]SNS = 1
Else
 [M:SAI1]SNS = 2
Endif
GSOCIETE = [M]CPY
Call LEC_CPY([M]CPY) From CPTLEC
Call LEC_FCY([M]FCYLIN) From CPTLEC
Call LEC_JOU_LEG([F:CPY]LEG,[M]JOU) From CPTLEC
[M]CPYNAM = [F:CPY]CPYNAM
[M]FCYNAM = [F:FCY]FCYNAM
Call LECTEXTRA([M]JOUNAM,"GJOURNAL","DESTRA",[F:JOU]JOU,[F:JOU]LEG) From ATEXTRA
Raz [M:VTL], [M:VT2]
[M:VT2]PTVENT = 1
OVAL = [F:DAE]ACC

Gosub INIT_DIE
If [F:DAE]DSP=""
 K = 0
 For [DAA]DAA0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
  K += 1
  [M:VT2]TBAMT(K) = [F:DAA]AMTCUR
  [M:VT2]TBQTY(K) = [F:DAA]QTY
  For I=1 To dim([F:DAA]CCE)
   Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")" With [F:DAA]CCE(I-1)
  Next I
 Next
 If K=1
  For I=0 To dim([F:DAA]CCE)-1
    Assign "[M:SAI1]CCE("+num$(I)+")" With [F:DAA]CCE(I)
    Assign "[M:VT2]TBCCE"+num$(I+1)+"(1)" With ""
    OVAL -= evalue("[M:SAI1]CCE("+num$(I)+")")
  Next I
 Elsif K>1
  [M:SAI1]PTV = 1
  [M:SAI1]PTF = K
  [M:SAI1]DSP = "$"
  OVAL -= "$"
 Endif
Else
 OVAL -= "*"+[F:DAE]DSP
Endif
[M:VT2]PTVENT = K+1
Affzo [SAI1]
Gosub VERROU
REP = ""
Return

$INIT_DIE
Actzo [M:SAI1]DIE, CCE
[M:SAI1]LEDTYPNAM=mess([F:DAE]LEDTYP,2644,1)
Call INDLED([M:SAI1]LED,"",IND,AXI) From CPTDIV
For I=0 To GLEDDIENBR(IND)-1
 #-- Intitulé des colonnes
 Assign "[M:SAI1]DIE("+num$(I)+")" With evalue("GDIE"+num$(I+1)+"("+num$(IND)+")")
 Call LECTEXTRA([L]INTDIE,"GDIE","COLHEA",[M:SAI1]DIE(I),"") From ATEXTRA
 Chgtzn [M:SAI1]CCE(I) With [L]INTDIE
 #-- Axes pour la ventilation analytique
 [M:VT2]TBDIE(I)=[M:SAI1]DIE(I)
Next I
For I=GLEDDIENBR(IND) To dim([M:SAI1]CCE)-1
 Assign "[M:SAI1]DIE("+num$(I)+")" With ""
 Chgtzn [M:SAI1]CCE(I) With ""
 Grizo [M:SAI1]DIE(I),CCE(I)
 #-- Axes pour la ventilation analytique
 [M:VT2]TBDIE(I)=""
Next
Return

$TEST
OK = 1
Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM

#-- Modication analytique possible selon le paramètre GCNTANA  (DdM10796)
#--  Si paramètre est à NON => aucun restriction, modification possible
#--  Si paramètre est à OUI => uniquement accès aux pièces en statut provisoire
If GCNTANA=2 & [F:HAE]STA>1 : OK = 0 : Return : Endif
#-- Filtre sur l'utilisateur
If [M:DIA]TOUUSR<>2
 If [F:HAE]UPDUSR<>""
  If [F:HAE]UPDUSR<>[M:DIA]USR : OK = 0 : Endif
 Else
  If [F:HAE]CREUSR<>[M:DIA]USR : OK = 0 : Endif
 Endif
Endif
If !OK : Return : Endif

#-- Critère tous Types de Référentiel & toutes sociétés
If [M:DIA]TOUSOC=2 or [M:DIA]TOULED=2
 Call LSTLEDTYP([F:HAE]CPY,3,TLEDTYP,TNBLED) From CPTDIV
 If !find([F:DAE]LEDTYP,TLEDTYP) : OK=0 : Return : Endif
Endif
#-- Législation à prendre en compte
If [M:DIA]TOUSOC=2
 Call LEC_CPY([F:HAE]CPY) From CPTLEC
 If [F:CPY]LEG <> GCURLEG : OK=0 : Return : Endif
Endif

#-- Critères sur un Axe Analytique
If [M:DIA]TOUSEC<>2
 OK = 0
 For [DAA]DAA0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
  Call INDLED([F:DAA]LED,[M:DIA]AXE,IND,AXI) From CPTDIV
  # Vérification si
  #    1 - Axe     présent dans l'écriture
  #    2 - Section appartient aux bornes de sections de critères
  If AXI
   OK = 1
   If [M:DIA]SECDEB<>"" & [F:DAA]CCE(AXI-1)<[M:DIA]SECDEB : OK = 0 :  Endif
   If [M:DIA]SECFIN<>"" & [F:DAA]CCE(AXI-1)>[M:DIA]SECFIN : OK = 0 :  Endif
   If OK : Break : Endif
  Endif
 Next
Endif
If !OK : Return : Endif

#-- Critères sur les sections analytiques
If [M:DIA]SAISI<>1
 OK = 0
 Case [M:DIA]SAISI
   When 2 : # Aucun axe saisi
    For [DAA]DAA0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
     If sum([F:DAA]CCE(0..dim([F:DAA]CCE)-1))="" : OK = 1 : Break : Endif
    Next
   When 3 : # Un axe non saisi
    For [DAA]DAA0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
     If find("",[F:DAA]CCE(0..dim([F:DAA]CCE)-1)) : OK = 1 : Break : Endif
    Next
   When 4 : # Pas de saisie sur l'axe
    For [DAA]DAA0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
     I = find([M:DIA]DIESAI,[F:DAA]DIE(0..dim([F:DAA]DIE)-1))
     If I & [F:DAA]CCE(I-1)="" : OK = 1 : Break : Endif
    Next
 Endcase
 If !OK : Return : Endif
Endif

#-- Critères sur le journal
If [M:DIA]TOUJOU<>2 or [M:DIA]TOUTYPJOU<>2
 If [M:DIA]TOUJOU<>2
  If [F:HAE]JOU<>[M:DIA]JOU : OK = 0 : Return : Endif
 Endif
 If [M:DIA]TOUTYPJOU<>2
  Call LEC_CPY([F:HAE]CPY) From CPTLEC
  Call LEC_JOU_LEG([F:CPY]LEG,[F:HAE]JOU) From CPTLEC
  If [F:JOU]TYP<>[M:DIA]TYPJOU : OK = 0 : Return : Endif
 Endif
Endif
Return

$VERROU
[L]OK = 1
SYMBOLE = "HAE"+[M:SAI1]NUM+"\"+[M:SAI1]TYP
Lock =SYMBOLE With lockwait=0
If fstat
 [L]OK = 0 : [L]VERROU = 0
Else
 [L]VERROU = 1
Endif
Return

$DEVERROU
Unlock =SYMBOLE
[L]VERROU = 0
Return

########################################
## Ecran CRITANA                      ##
########################################
Subprog AS_TOUSOC(VALEUR)
Variable Integer  VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 Diszo TOUSOC
 Actzo SOCIETE,TOUSIT
 If dim([M]LEG)>0 : Effzo LEG : Grizo LEG : Endif
 mkstat = 1 : End
Endif
End

Subprog C_TOUSOC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo SOCIETE,SITE : Grizo SOCIETE,SITE
 [M]TOUSIT=2 : Affzo TOUSIT : Grizo TOUSIT
 If dim([M]LEG)>0 : Actzo LEG : Endif
 GSOCIETE=""
 GCURFCY=""
Else
 Actzo SOCIETE,TOUSIT
 If dim([M]LEG)>0 : Effzo LEG : Grizo LEG : Endif
Endif
End

Subprog AS_SOCIETE(VALEUR)
Variable Char     VALEUR
If [M]TOUSOC=2 : mkstat = 1 : End : Endif
End

Subprog C_SOCIETE(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR)From CPTTRT
End

Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
Call AM_LEG (VALEUR) From CPTTRT
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG(VALEUR)From CPTTRT
End

Subprog AS_TOUSIT(VALEUR)
Variable Integer  VALEUR
If [M]TOUSOC=2 : VALEUR = 2 : End : Endif
Call INIALLFCY(VALEUR,[M]SOCIETE) From CPTTRT
End

Subprog C_TOUSIT(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Effzo SITE : Grizo SITE : Else : Actzo SITE : Endif
End

Subprog AS_SITE(VALEUR)
Variable Char    VALEUR()
If [M]TOUSIT=2 : mkstat = 1 : End : Endif
End

Subprog C_SITE(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog C_TOUUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : [M]USR="" : Affzo USR : Grizo USR : Else : Actzo USR : Endif
End

Subprog AS_USR(VALEUR)
Variable Char     VALEUR
If [M]TOUUSR = 2 : VALEUR = "" : mkstat = 2 : End : Endif
If VALEUR=""
 VALEUR = GUSER
Endif
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
If [M]TOULED=2 : mkstat = 1 : End : Endif
If [M]TOUSOC<>2 & [M]SOCIETE<>""
 OPTION=8 : # Référentiel non automatiques et analytique...
 Call LEDTYP_CHOICE([M]SOCIETE,OPTION) From CPTDIV
Else
 Local Integer AUT, NBLED, TYPREF
 For I=1 To len(mess(0,2644,1))
  Raz AUT
  For NBLED=1 To len(GLEDTYPAUT)
   TYPREF = val(mid$(GLEDTYPAUT,NBLED,1))
   # Gestion de la valeur 10
   If TYPREF=1 &  mid$(GLEDTYPAUT,NBLED+1,1)="0"
    If I=10 : AUT=1 : Break : Endif
   Else
    If TYPREF = I : AUT=1 : Break : Endif
   Endif
  Next
  If AUT
   GMENLOC(I) = 1
  Endif
 Next
Endif
End

Subprog C_TOUTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]TYP = ""
 Effzo TYP : Grizo TYP
Else
 Actzo TYP
Endif
End

Subprog AS_TYP(VALEUR)
Variable Char    VALEUR()
If [M]TOUTYP=2 : VALEUR = "" : mkstat = 2 : End : Endif
End

Subprog C_TOUTYPJOU(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : [M]TYPJOU=0 : Affzo TYPJOU : Grizo TYPJOU : Else : Actzo TYPJOU : Endif
End

Subprog AS_TYPJOU(VALEUR)
Variable Integer  VALEUR
If [M]TOUTYPJOU = 2 : mkstat = 1 : End : Endif
End

Subprog C_TOUJOU(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Effzo JOU : Grizo JOU : Else : Actzo JOU : Endif
End

Subprog C_JOU(VALEUR)
Variable Char    VALEUR()
Call VERIF([F:JOU]FCY,[M]SITE,VALEUR) From CFYSUB
If mkstat : End  : Endif
End

Subprog AS_JOU(VALEUR)
Variable Char     VALEUR
If [M]TOUJOU = 2 : mkstat = 1 : End : Endif
If VALEUR="" & [M]TYP<>""
 VALEUR = [F:GTE]DEFJOU
Endif
End

Subprog D_DATDEB(VALEUR)
Variable Date    VALEUR
End
If GDATEDEB<>[0/0/0]
 VALEUR    = GDATEDEB
 [M]DATFIN = GDATEFIN
Else
 Local Char SOC(GLONCPY)
 Local Integer OFIY
 If [M]TOUSOC=2 : SOC = GDEFSOC : Else : SOC = [M]SOCIETE : Endif
 Call LECTURE("CPY",SOC,"") From CONTOBJ
 Filter [PER] Where CPY=SOC & PERANASTA=2
 Read [PER]PER0 First
 If fstat>2
  Filter [PER] Where CPY=SOC & PERANASTA=2
  If fstat>2 : End : Endif
 Endif
 OFIY = [F:PER]FIYNUM : VALEUR = [F:PER]PERSTR : VALEUR = [F:PER]PERSTR
 Read [PER]PER0 Next
 While fstat<4 & [F:PER]FIYNUM=OFIY
  [M]DATFIN = [F:PER]PEREND
  Read [PER]PER0 Next
 Wend
 Filter [PER]
Endif
End

Subprog AS_AXE(VALEUR)
Variable Char VALEUR
If [M]TOUSEC=2 : VALEUR = "" : mkstat = 1 : End : Endif
End

Subprog AS_SECDEB(VALEUR)
Variable Char    VALEUR()
If [M]TOUSEC=2 : VALEUR = "" : mkstat = 2 : End : Endif
End

Subprog AS_SECFIN(VALEUR)
Variable Char    VALEUR()
If [M]TOUSEC=2 : VALEUR = "" : mkstat = 2 : End : Endif
If VALEUR="" | VALEUR<[M]SECDEB : VALEUR=[M]SECDEB : Endif
End

Subprog C_SECFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]SECDEB
 GMESSAGE = mess(44,199,1)
 mkstat = 1
Endif
End

Subprog AS_DIESAI(VALEUR)
Variable Char    VALEUR()
If [M]SAISI<>4 : VALEUR = "" : mkstat = 2 : End : Endif
End

Subprog AS_CPTFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]CPTDEB : VALEUR=[M]CPTDEB : Endif
End

Subprog C_CPTFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]CPTDEB
 GMESSAGE = mess(44,199,1)
 mkstat = 1
Endif
End

Subprog C_NATFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]NATDEB : mkstat = 1 : End : Endif
End

##############################################
## Ecran SAIANA                             ##
##############################################
Subprog AS_QTY(VALEUR)
Variable Decimal VALEUR
Call LECTURE("GAC",[M]ACC,[M]COA) From CONTOBJ
If [F:GAC]FLGUOM<>2 : mkstat = 1 : End : Endif
If [M:DIA]MODQTE<>2 : mkstat = 2 : End : Endif
End

Subprog AS_DSP(VALEUR)
Variable Char     VALEUR
Local Integer AXI, TNBLED
Local Integer TLEDTYP(1..len(mess(0,2644,1)))

#--- Axe est-il modifiable...
For I=0 To dim([M:SAI1]DIE)-1
 If [M:SAI1]DIE(I)="" : Break : Endif
 AXI = find([M:SAI1]DIE(I),[M:DIA]DIE(0..dim([M:DIA]DIE)-1))
 If !AXI or [M:DIA]MODAXE(AXI-1)<>2 : mkstat=2 : Break : Endif
Next
If mkstat : End : Endif

Raz [L]TNBLED
Call LSTLEDTYP([M]CPY,3,TLEDTYP,TNBLED) From CPTDIV
If [L]TNBLED>1 : mkstat=2 : End : Endif
End

Subprog IB_DSP
GBOUT1 = mess(23,106,1) : # Répartition ana
GBOUT2 = mess(21,106,1) : # Pourcentage
GBOUT3 = mess(22,106,1) : # Montant
End

Subprog C_DSP(VALEUR)
Variable Char     VALEUR
Local Char    BID(20)
Local Integer I, OK
If [M]PTV<>0
 VALEUR = "$"
Endif
Case VALEUR
 When ""
  End
 When "$"
  OK  = 1
  OK *= [M]AMTCUR=sum([M:VT2]TBAMT([M]PTV..[M]PTF))
  OK *= [M]QTY=sum([M:VT2]TBQTY([M]PTV..[M]PTF))
  If !OK
   GMESSAGE = mess(28,106,1)
   mkstat = 2
  Endif
  Gosub RAZCCE
 When Default
  Call CONTDSP(VALEUR,[M]FCYLIN,[M]ACCDAT) From SUBGA1
  If mkstat : End : Endif
  [M:VTL]TOTREP = [M]AMTCUR
  Call CHARGE_VTE_STR(VALEUR,[M:SAI1]UOM,[M:SAI1]LED,[M:SAI1]ACC,"") From VENTILE
  Call CONTVENT([M:SAI1]FCYLIN,[M:SAI1]ACCDAT) From SAIVENTILE
  If mkstat : End : Endif
  Gosub RAZCCE
Endcase
End

$RAZCCE
For I=1 To dim([M:SAI1]CCE)
 Assign "[M:SAI1]CCE("+num$(I-1)+")" With ""
Next I
Return

Subprog AS_CCE(VALEUR)
Variable Char    VALEUR()
Local Integer AXI, NB_AXECOM
Local Char AXECOM(GLONDIE)(1..max(GOPTCANA,20))

#--- Pas de saisie si Réparatition à priori.
If dim([M:SAI1]DSP)>0 & [M:SAI1]DSP<>"" : mkstat=1 : End : Endif

#--- Axe est-il suivi sous le compte
Call LECTURE("GAC",[M:SAI1]ACC,[M:SAI1]COA) From CONTOBJ
If !find([M:SAI1]DIE(indice),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)) : mkstat=2 : End : Endif

#--- Axe est-il modifiable...
AXI = find([M:SAI1]DIE(indice),[M:DIA]DIE(0..dim([M:DIA]DIE)-1))
If !AXI or [M:DIA]MODAXE(AXI-1)<>2 : mkstat = 2 : End : Endif

#--- En cas de pièce en état Définitif, la modification est possible uniquement si :
#        - Paramèter GCNTANA = 2 or Axe est coché "Modif écriture définitive"
If clalev([F:HAE])=0 : Local File "GACCENTRY"   [HAE] : Endif
Read [HAE]HAE0 = [M:SAI1]TYP;[M:SAI1]NUM
If [F:HAE]STA>1
 Call LECTURE("DIE",[M:SAI1]DIE(indice),"") From CONTOBJ
 If [F:DIE]FLGMODACE<>2 : mkstat=2 : End : Endif
Endif

#--- Pas de modification si axe commun
Call SETAXECOM([M]CPY,NB_AXECOM,AXECOM) From CPTDIV
AXI = find([M:SAI1]DIE(indice),AXECOM(1..NB_AXECOM))
If AXI : mkstat = 2 : End : Endif
End

Subprog C_CCE(VALEUR)
Variable Char    VALEUR()
Call CONTCCE(VALEUR,[M:SAI1]LED,[M:SAI1]DIE(indice),[M:SAI1]FCYLIN,[M:SAI1]ACCDAT,[M:SAI1]ACC,[M:SAI1]DIE,"[M]CCE",indice) From CPTCNT
End
