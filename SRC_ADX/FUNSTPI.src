#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque STOCKPUI
############################################################
# Purge des listes d'inventaire 
############################################################
$ACTION
Case ACTION

  When "INIT"         : Gosub INIT_PURINV
  When "EXEC"         : Gosub EXEC_PURINV
  When "TERMINE"      : Gosub TERMINE_PURINV
  When "INIT_DIA"     : Gosub INIT_DIA_PURINV
  When "OK"           : Gosub OK_PURINV
  When "END"          : Gosub END_PURINV
Endcase 
Return

############################################################
$INIT_PURINV
If !GSERVEUR
  Call OUVRE_TRACE(mess(401,197,1)) From LECFIC  
Endif
Return
#############################################################
$EXEC_PURINV
If [M:DIA]PURCUNDAT <> [0/0/0]
  Gosub PUR_CUN 
Endif
Return
#############################################################
$TERMINE_PURINV
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
Return
#############################################################
$INIT_DIA_PURINV
Raz [M:DIA]
[M:DIA]DATREFMAX = date$
[M:DIA]PURCUNDAT = date$
[M:DIA]SIM    = 2   # hcb 040105 26446

Return
#############################################################
$OK_PURINV
FIN  = 1
Return
#############################################################
$END_PURINV
Raz [M:DIA]
FIN = 1
Return
########################################################### 
#Purge des listes d'inventaire 
$PUR_CUN 
Local File CUNSESSION [CUN]
Local File CUNLISTE   [CUL]
Local File CUNLISDET  [CUD]
#
If [M:DIA]SIM=1
     Call TEMPON (mess(401,197,1)) From GESECRAN
     If !GSERVEUR
        Call OUVRE_TRACE(mess(401,197,1)) From LECFIC
     Endif
Else Call TEMPON (mess(885,196,1)) From GESECRAN
     If !GSERVEUR
        Call OUVRE_TRACE(mess(885,196,1)-":"-mess(401,197,1)) From LECFIC
     Endif
Endif
#
Filter [CUN] Where STOFCY    = [M]STOFCY   & 
&                  CUNSSSSTA = 3           & 
&                  UPDDAT    < [M]PURCUNDAT 
&            Order By Key CUN1
For [CUN]  
  Trbegin [CUN] 
  GOK = 1 
  Readlock [CUN] Curr
  Case fstat
    When 1 :
      WMSG = mess(20,100,1)-[F:CUN]CUNSSSNUM
      Call ECR_TRACE(WMSG,1) From GESECRAN
      Rollback
    When 0 :
      Gosub PUR_INV
        If GOK = 1 
          Commit
          WMSG = [F:CUN]STOFCY+"/"+[F:CUN]CUNSSSNUM+" "+mess(106,184,1)   
          Call ECR_TRACE(WMSG,0) From GESECRAN 
        Else
          Rollback
          Break 
        Endif 
    When Default :
      Rollback 
      Break 
  Endcase 
Next   
# 
WMSG = mess(107,184,1)+" ("+format$("D:",[M]PURCUNDAT)+")"
Call ECR_TRACE(WMSG,0) From GESECRAN

Filter [CUN]
Close Local File [CUN]
Close Local File [CUL]
Close Local File [CUD]
Call TEMPOFF     From GESECRAN 
Return 

###########################################################
$PUR_INV
If SIM=1
  Delete [CUL] Where CUNSSSNUM = [F:CUN]CUNSSSNUM 
  If !find(fstat,0,4,5)
    GOK = 0
    Return 
  Endif
  Delete [CUD] Where CUNSSSNUM = [F:CUN]CUNSSSNUM 
  If !find(fstat,0,4,5)
    GOK = 0
    Return
  Endif
  Delete [CUN] Curr
    If fstat
      Call FSTA("CUN") From GLOCK
      GOK = 0
      Return
    Endif
Endif
Return 

############################################################
# Actions écran STOCKPUI
############################################################
Subprog C_PURCUNDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [M:DIA]DATREFMAX
  mkstat = 2
  GMESSAGE = mess(30,187,1)-num$([M:DIA]DATREFMAX)
Endif
End



