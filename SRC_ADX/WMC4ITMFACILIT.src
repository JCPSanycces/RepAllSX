####################################################################
# 91 : SCOWRH Sub-ctrt ship wareh ( Field DEP 5)
####################################################################

$SET_SCOWRH
If [L]_AOLDVAL<>this.SCOWRH
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_SCOWRH
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.SCOWRH
 Gosub PROPAGATE_SCOWRH
Endif
Return

$INIT_SCOWRH
Gosub DECLARE_VAR From WMC0ITMFACILIT
[L]CURPRO = "SCOWRH"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_SCOWRH
Gosub DECLARE_VAR From WMC0ITMFACILIT
[L]CURPRO = "SCOWRH"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_SCOWRH                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_SCOWRH                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_SCOWRH
[L]CURPRO = "SCOWRH"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.SCOWRH,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_SCOWRH
[L]CURPRO = "SCOWRH"
If vireblc(this.SCOWRH,2)<>vireblc(format$("K:5c",this.SCOWRH),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_SCOWRH
[L]CURPRO = "SCOWRH"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_SCOWRH
[L]CURPRO = "SCOWRH"
Return

$PROPAGATE_SCOWRH
this.isReadonly = 0
[L]CURPRO = "SCOWRH"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_SCOWRH
Gosub DECLARE_VAR From WMC0ITMFACILIT
[L]CURPRO = "SCOWRH"
$_LNKPRO_SCOWRH
Return


