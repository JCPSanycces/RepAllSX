####################################################################
# 93 : STAFED Federal state ( Field Miscellaneous table number)
####################################################################

$SET_STAFED
If [L]_AOLDVAL<>this.STAFED
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_STAFED
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.STAFED
 Gosub PROPAGATE_STAFED
Endif
Return

$INIT_STAFED
Gosub DECLARE_VAR From WMC0ITMFACILIT
[L]CURPRO = "STAFED"
[L]ASTATUS =  func ADI_TOOL.ADI_INI(this,"STAFED",this.STAFED,80)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_STAFED
Gosub DECLARE_VAR From WMC0ITMFACILIT
[L]CURPRO = "STAFED"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_STAFED                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_STAFED                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_STAFED
[L]CURPRO = "STAFED"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.STAFED,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_STAFED
[L]CURPRO = "STAFED"
If vireblc(this.STAFED,2)<>vireblc(format$("K:20B",this.STAFED),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_STAFED
[L]CURPRO = "STAFED"
[L]ASTATUS =  func ADI_TOOL.ADI_CONT(this,"STAFED",this.STAFED,80,this.STAFED)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_STAFED
[L]CURPRO = "STAFED"
Return

$PROPAGATE_STAFED
this.isReadonly = 0
[L]CURPRO = "STAFED"
Gosub _LNKPRO_STAFED
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_STAFED
Gosub DECLARE_VAR From WMC0ITMFACILIT
[L]CURPRO = "STAFED"
$_LNKPRO_STAFED
If vireblc(this.STAFED,2)<>""
 # Link ATABDIV
 Local File ATABDIV [WADI]
 Read [F:WADI]CODE = 80;this.STAFED
 If !fstat
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1=num$([F:WADI]NUMTAB) & IDENT2=[F:WADI]CODE & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("STAFED","$title",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1=num$([F:WADI]NUMTAB) & IDENT2=[F:WADI]CODE & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("STAFED","$description",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
 Endif
 LogicClose File [WADI]
Endif
Return


