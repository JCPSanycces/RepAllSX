#**
#* <pre>If inactivity flag is set then sets the start/end dates to 6th of following month to 5th.
#* If inactivity flag not set then removes the inactivity start/end dates</pre>
#* @param INACTIVITY_FLAG Logcial flag 1 (false) or 2 (true)
#* @param TAX_PERIOD Tax period number 1-12 inclusive
#* @param TAX_YEAR Tax year number
#*!
Subprog SET_PERIOD_OF_INACTIVITY(INACTIVITY_FLAG, TAX_PERIOD, TAX_YEAR)
  Value Integer INACTIVITY_FLAG, TAX_PERIOD, TAX_YEAR
  Local Date START_DATE, END_DATE

  If INACTIVITY_FLAG = 2
    Case TAX_PERIOD
      When 1
        START_DATE = gdat$(06,05,TAX_YEAR) : END_DATE = gdat$(05,06,TAX_YEAR)
      When 2
        START_DATE = gdat$(06,06,TAX_YEAR) : END_DATE = gdat$(05,07,TAX_YEAR)
      When 3
        START_DATE = gdat$(06,07,TAX_YEAR) : END_DATE = gdat$(05,08,TAX_YEAR)
      When 4
        START_DATE = gdat$(06,08,TAX_YEAR) : END_DATE = gdat$(05,09,TAX_YEAR)
      When 5
        START_DATE = gdat$(06,09,TAX_YEAR) : END_DATE = gdat$(05,10,TAX_YEAR)
      When 6
        START_DATE = gdat$(06,10,TAX_YEAR) : END_DATE = gdat$(05,11,TAX_YEAR)
      When 7
        START_DATE = gdat$(06,11,TAX_YEAR) : END_DATE = gdat$(05,12,TAX_YEAR)
      When 8
        START_DATE = gdat$(06,12,TAX_YEAR) : END_DATE = gdat$(05,01,TAX_YEAR + 1)
      When 9
        START_DATE = gdat$(06,01,TAX_YEAR + 1) : END_DATE = gdat$(05,02,TAX_YEAR + 1)
      When 10
        START_DATE = gdat$(06,02,TAX_YEAR + 1) : END_DATE = gdat$(05,03,TAX_YEAR + 1)
      When 11
        START_DATE = gdat$(06,03,TAX_YEAR + 1) : END_DATE = gdat$(05,04,TAX_YEAR + 1)
      When 12
        START_DATE = gdat$(06,04,TAX_YEAR + 1) : END_DATE = gdat$(05,05,TAX_YEAR + 1)
    Endcase
  Endif

  [M:ESUBUKI1]PERNONACTSTR = START_DATE
  [M:ESUBUKI1]PERNONACTEND = END_DATE
  Affzo [M:ESUBUKI1]PERNONACTSTR, PERNONACTEND
End


#**
#* <pre>If no payment flag is set then sets the start/end dates to 6th of current month to 5th.
#* If no payment flag not set then removes the no payment start/end dates</pre>
#* @param NO_PAYMENT_FLAG Logcial flag 1 (false) or 2 (true)
#* @param TAX_PERIOD Tax period number 1-12 inclusive
#* @param TAX_YEAR Tax year number
#*!
Subprog SET_PERIOD_OF_NO_PAYMENT(NO_PAYMENT_FLAG, TAX_PERIOD, TAX_YEAR)
  Value Integer NO_PAYMENT_FLAG, TAX_PERIOD, TAX_YEAR
  Local Date START_DATE, END_DATE

  If NO_PAYMENT_FLAG = 2
    Case TAX_PERIOD
      When 1
        START_DATE = gdat$(06,04,TAX_YEAR) : END_DATE = gdat$(05,05,TAX_YEAR)
      When 2
        START_DATE = gdat$(06,05,TAX_YEAR) : END_DATE = gdat$(05,06,TAX_YEAR)
      When 3
        START_DATE = gdat$(06,06,TAX_YEAR) : END_DATE = gdat$(05,07,TAX_YEAR)
      When 4
        START_DATE = gdat$(06,07,TAX_YEAR) : END_DATE = gdat$(05,08,TAX_YEAR)
      When 5
        START_DATE = gdat$(06,08,TAX_YEAR) : END_DATE = gdat$(05,09,TAX_YEAR)
      When 6
        START_DATE = gdat$(06,09,TAX_YEAR) : END_DATE = gdat$(05,10,TAX_YEAR)
      When 7
        START_DATE = gdat$(06,10,TAX_YEAR) : END_DATE = gdat$(05,11,TAX_YEAR)
      When 8
        START_DATE = gdat$(06,11,TAX_YEAR) : END_DATE = gdat$(05,12,TAX_YEAR)
      When 9
        START_DATE = gdat$(06,12,TAX_YEAR) : END_DATE = gdat$(05,01,TAX_YEAR + 1)
      When 10
        START_DATE = gdat$(06,01,TAX_YEAR + 1) : END_DATE = gdat$(05,02,TAX_YEAR + 1)
      When 11
        START_DATE = gdat$(06,02,TAX_YEAR + 1) : END_DATE = gdat$(05,03,TAX_YEAR + 1)
      When 12
        START_DATE = gdat$(06,03,TAX_YEAR + 1) : END_DATE = gdat$(05,04,TAX_YEAR + 1)
    Endcase
  Endif

  [M:ESUBUKI1]PAYNOTDUESTR = START_DATE
  [M:ESUBUKI1]PAYNOTDUEEND = END_DATE
  Affzo [M:ESUBUKI1]PAYNOTDUESTR, PAYNOTDUEEND
End

