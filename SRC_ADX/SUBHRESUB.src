Subprog AM_PERNONACT(VALEUR)
Variable Integer VALEUR
  Call SET_PERIOD_OF_INACTIVITY(VALEUR,[M:ESUBUKI1]PERNUM,[M:ESUBUKI1]PERYEA)
End

Subprog AM_PAYNOTDUE(VALEUR)
Variable Integer VALEUR
  Call SET_PERIOD_OF_NO_PAYMENT(VALEUR,[M:ESUBUKI1]PERNUM,[M:ESUBUKI1]PERYEA)
End


