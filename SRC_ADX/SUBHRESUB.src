#<AdxTL>@(#)0.0.0.0 $Revision$ Object management HRESUB
$ACTION
  Case ACTION
    When "OUVRE"           : Gosub OUVRE
    When "LIENS"           : Gosub LIENS
    When "AVANTBOUT"       : Gosub AVANTBOUT
    When "SETBOUT"         : Gosub SETBOUT
    When "RAZCRE"          : Gosub RAZCRE
#MASHI - X3-69356 03/01/2018 - START Obsolete record
    When "VERIF_MOD"       : Gosub VERIF_MOD
#MASHI - X3-69356 03/01/2018 - END
    When Default
  Endcase
Return

$OUVRE
  If clalev([F:CPYUKI])   = 0 : Local File HRCOMPANYUKI     [CPYUKI]          : Endif
  If clalev([F:HRESUB])   = 0 : Local File HRESUB           [HRESUB]          : Endif
  If clalev([F:ESUBREG])  = 0 : Local File HRESUBREG        [ESUBREG]         : Endif
  If clalev([F:ID])       = 0 : Local File EMPLOID          [ID]              : Endif
  If clalev([F:IDUKI])    = 0 : Local File EMPLOIDUKI       [IDUKI]           : Endif
  If clalev([F:CTR])      = 0 : Local File EMPLOCTR         [CTR]             : Endif
  If clalev([F:CTRUKI7])  = 0 : Local File EMPLOCTRUKI      [CTRUKI7]         : Endif
  If clalev([F:FCY])      = 0 : Local File FACILITY         [FCY]             : Endif
  If clalev([F:CPY])      = 0 : Local File COMPANY          [CPY]             : Endif
  If clalev([F:CPYUKI])   = 0 : Local File HRCOMPANYUKI     [CPYUKI]          : Endif
  If clalev([F:TCA])      = 0 : Local File TABCOUAFF        [TCA]             : Endif
Return

$LIENS
  Call LOADCPYDATA([M:ESUBUKI]CPY)
Return

$AVANTBOUT
  Case [L]BOUT
    When "G"
      Call GENERATE
    When "B"
      Call DOWNLOAD
    When "U"
      Call UPLOAD
    When "Z"
      Call SUBMIT
    When "O"
      Call CHECKSTATUS
    When "V"
      Call DELETEREQUEST
  Endcase
Return

$SETBOUT
  Call SHOW_RELEVANT([M:ESUBUKI1]SUBTYP)
Return

$RAZCRE
  [M:ESUBUKI1]SUBSTAT = 1
Return

#MASHI - X3-69356 03/01/2018 - START Obsolete record
$VERIF_MOD
If dim([L]ANOUPDTICK)>0
  [L]ANOUPDTICK=[M]ANOUPDTICK
  [M]ANOUPDTICK = 0
Endif
Return
#MASHI - X3-69356 03/01/2018 - END

Subprog LOADCPYDATA(CPY)
Value Char CPY

  Read [F:ESUBREG]ESUBREG0 = CPY
  If !fstat Then
    [M:ESUBUKI]PAYREFNUM = [F:ESUBREG]PAYREFNUM
  Endif

  Read [F:CPYUKI]CPYUKI0 = CPY
  If !fstat Then
    [M:ESUBUKI]ACCOFFREF = [F:CPYUKI]ACCOFFREF
  Endif
  Call SHOW_RELEVANT([M:ESUBUKI1]SUBTYP)
  Affzo [M:ESUBUKI1]
End

Subprog SHOW_RELEVANT(SUBTYP)
Value Integer SUBTYP
  Case SUBTYP
    When 1
      If dim([M:ESUBUKI1]PYRDAT)>0 : Chgfmt [M:ESUBUKI1]PYRDAT With 'D:MM[/]DD[/]YYYY' : Actzo [M:ESUBUKI1]PYRDAT : Endif
      If dim([M:ESUBUKI1]STRDAT)>0 : Chgfmt [M:ESUBUKI1]STRDAT With '-D:MM[/]DD[/]YYYY': Diszo [M:ESUBUKI1]STRDAT : Endif
      If dim([M:ESUBUKI1]ENDDAT)>0 : Chgfmt [M:ESUBUKI1]ENDDAT With '-D:MM[/]DD[/]YYYY' : Diszo [M:ESUBUKI1]ENDDAT : Endif
      Call SHOWEPS("-")
      #AFOLDEF = find("ESUBUKI0",[F:AWI]NOMMSK)-1
    When 2
      If dim([M:ESUBUKI1]PYRDAT)>0 : Chgfmt [M:ESUBUKI1]PYRDAT With '-D:MM[/]DD[/]YYYY' : Diszo [M:ESUBUKI1]PYRDAT : Endif
      If dim([M:ESUBUKI1]STRDAT)>0 : Chgfmt [M:ESUBUKI1]STRDAT With 'D:MM[/]DD[/]YYYY' : Actzo [M:ESUBUKI1]STRDAT : Endif
      If dim([M:ESUBUKI1]ENDDAT)>0 : Chgfmt [M:ESUBUKI1]ENDDAT With 'D:MM[/]DD[/]YYYY' : Actzo [M:ESUBUKI1]ENDDAT : Endif
      Call SHOWEPS("")
      #AFOLDEF = find("ESUBUKI1",[F:AWI]NOMMSK)-1
    When Default
      If dim([M:ESUBUKI1]STRDAT)>0 : Chgfmt [M:ESUBUKI1]STRDAT With '-D:MM[/]DD[/]YYYY' : Diszo [M:ESUBUKI1]PYRDAT : Endif
      If dim([M:ESUBUKI1]ENDDAT)>0 : Chgfmt [M:ESUBUKI1]ENDDAT With '-D:MM[/]DD[/]YYYY' : Diszo [M:ESUBUKI1]STRDAT : Endif
      If dim([M:ESUBUKI1]PYRDAT)>0 : Chgfmt [M:ESUBUKI1]PYRDAT With '-D:MM[/]DD[/]YYYY' : Diszo [M:ESUBUKI1]ENDDAT : Endif
  Endcase
End

Subprog SHOWEPS(WSIGN)
  Value Char WSIGN

  If dim([M:ESUBUKI2]FINALSUB) > 0      : Chgfmt [M:ESUBUKI2]FINALSUB With WSIGN+"LA:1"     : Endif
  If dim([M:ESUBUKI2]CEASED) > 0        : Chgfmt [M:ESUBUKI2]CEASED With WSIGN+"LA:1"       : Endif
  If dim([M:ESUBUKI2]CEASEDDAT) > 0     : Chgfmt [M:ESUBUKI2]CEASEDDAT With WSIGN+"D:MM[/]DD[/]YYYY"  : Endif
  #ANCOA - X3-60215 18/12/2015 - START
  If dim([M:ESUBUKI1]PERNONACT) > 0     : Chgfmt [M:ESUBUKI1]PERNONACT With WSIGN+"LA:1"    : Endif
  If dim([M:ESUBUKI1]PERNONACTSTR) > 0     : Chgfmt [M:ESUBUKI1]PERNONACTSTR With WSIGN+"D:MM[/]DD[/]YYYY"  : Endif
  If dim([M:ESUBUKI1]PERNONACTEND) > 0     : Chgfmt [M:ESUBUKI1]PERNONACTEND With WSIGN+"D:MM[/]DD[/]YYYY"  : Endif
  If dim([M:ESUBUKI1]PAYNOTDUE) > 0     : Chgfmt [M:ESUBUKI1]PAYNOTDUE With WSIGN+"LA:1"    : Endif
  If dim([M:ESUBUKI1]PAYNOTDUESTR) > 0     : Chgfmt [M:ESUBUKI1]PAYNOTDUESTR With WSIGN+"D:MM[/]DD[/]YYYY"  : Endif
  If dim([M:ESUBUKI1]PAYNOTDUEEND) > 0     : Chgfmt [M:ESUBUKI1]PAYNOTDUEEND With WSIGN+"D:MM[/]DD[/]YYYY"  : Endif
  #ANCOA - X3-60215 18/12/2015 - END
End

