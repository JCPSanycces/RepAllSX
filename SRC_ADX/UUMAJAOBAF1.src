#<AdxTL>@(#)7.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour table intitulé traduisibles sur table des codes d'accès
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise à jour table intitulé traduisibles sur table des codes d'accès") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If !mkstat
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##################################################
Subprog PATCH_X3(APPLI)
Value Char APPLI

Gosub MAJAOB
End
##################################################
Subprog PATCH(APPLI)
Value Char APPLI

Gosub MAJAOB
End

##################################################
$MAJAOB
Call MAJ_SEL(APPLI,"AF1") From PATCHAOB
