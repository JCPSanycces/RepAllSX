#<AdxTL>@(#)0.0.0.0 $Revision$Class Addresses
# Supervisor
## ACLA-CLASSE ## BPADDRESS
# 2018-11-06 07:02:04 248

####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 31 : TELTYP1 Telephone ( Field TEL 20)
####################################################################

$GET_TELTYP1
Gosub DECLARE_VAR From WMC0BPADDRESS
[L]CURPRO = "TELTYP1"
[L]ARULE = "GET" : [L]ACTION = "GET" : Gosub ACTION From ASYRSUB
Return

$SET_TELTYP1
If [L]_AOLDVAL<>this.TELTYP1
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_TELTYP1
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.TELTYP1
 Gosub PROPAGATE_TELTYP1
Endif
Return

$INIT_TELTYP1
Gosub DECLARE_VAR From WMC0BPADDRESS
[L]CURPRO = "TELTYP1"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_TELTYP1
Gosub DECLARE_VAR From WMC0BPADDRESS
[L]CURPRO = "TELTYP1"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_TELTYP1               : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_TELTYP1               : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_TELTYP1
[L]CURPRO = "TELTYP1"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.TELTYP1,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_TELTYP1
[L]CURPRO = "TELTYP1"
If vireblc(this.TELTYP1,2)<>vireblc(format$("K:20X",this.TELTYP1),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_TELTYP1
[L]CURPRO = "TELTYP1"
[L]ASTATUS =  func ASYRTRTATY.CONTROLTEL(this,"TELTYP1",this.TELTYP1,this.CRY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_TELTYP1
[L]CURPRO = "TELTYP1"
Return

$PROPAGATE_TELTYP1
this.isReadonly = 0
[L]CURPRO = "TELTYP1"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_TELTYP1
Gosub DECLARE_VAR From WMC0BPADDRESS
[L]CURPRO = "TELTYP1"
$_LNKPRO_TELTYP1
Local Char AFORMAT(50)
[L]ASTATUS =  func ASYRTRTATY.GETFORMATTEL(this,"TELTYP1",this.TELTYP1,[L]AFORMAT,this.CRY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]AFORMAT<>''
[L]AFORMAT='"'+[L]AFORMAT+'"'
[L]ASTATUS = fmet this.ASETATTRIBUTE("TELTYP1","$x3Format",[L]AFORMAT)
Endif
Return


