#<AdxTL>@(#)7.0.0.0 $Revision$
GBIDC2="" : GBIDC3="" : GFLAG=""
Call OBJET("GAS",GBIDC2,GBIDC3) From GOBJET
End

###########################################################################################################
# $MAJMSK  --- Mise à jour de l'écran GACCENT2
#    - $LIENS : Remplissage du masque => utilisation pour gérer le bouton 'Devise'
###########################################################################################################
$MAJMSK

nolign = NOLI+1

[M:HAEW] = [F:DAE]

[M:HAEW]CPA(NOLI) = [F:DAE]OFFACC

[M:HAEW]FIY(NOLI) = [F:DAE]FIY
[M:HAEW]PER(NOLI) = [F:DAE]PER

[M:HAEW]AMTLED(NOLI) = [F:DAE]AMTLED
[M:HAEW]AMTFLG(NOLI) = [F:DAE]AMTFLG
[M:HAEW]AMTLED1(NOLI)= [F:DAE]AMTLED1

If [F:DAE]SNS=1
 [M:HAEW]DEB(NOLI) = [F:DAE]AMTCUR
 Assign "[M:HAEW]TOTDEB("+num$([M:HAEW]LEDTYP(NOLI)-1)+")" With evalue("[M:HAEW]TOTDEB("+num$([M:HAEW]LEDTYP(NOLI)-1)+")") + [F:DAE]AMTCUR
Else
 [M:HAEW]CDT(NOLI) = [F:DAE]AMTCUR
 Assign "[M:HAEW]TOTCDT("+num$([M:HAEW]LEDTYP(NOLI)-1)+")" With evalue("[M:HAEW]TOTCDT("+num$([M:HAEW]LEDTYP(NOLI)-1)+")") + [F:DAE]AMTCUR
Endif

Assign "[M:HAEW]TOTLED("+num$([M:HAEW]LEDTYP(NOLI)-1)+")" With evalue("[M:HAEW]TOTLED("+num$([M:HAEW]LEDTYP(NOLI)-1)+")") + [F:DAE]AMTLED
Assign "[M:HAEW]TOTLED1("+num$([M:HAEW]LEDTYP(NOLI)-1)+")" With evalue("[M:HAEW]TOTLED1("+num$([M:HAEW]LEDTYP(NOLI)-1)+")") + [F:DAE]AMTLED1

NOLI+=1
[M:HAEW]NB=NOLI
Return

###########################################################################################################
# $MAJMSK2  --- Mise à jour de l'écran GACCENTW
#    - Remplissage du masque des lignes saisies
#    => utilisation pour générer les règles de prorogations.
#    => utilisation pour gérer le controle d'équilibre.
###########################################################################################################
$MAJMSK2
Gosub DECLARE_B From SUBGAS
Raz [M:HAEW]
Raz NBLIN

Gosub SETMSK From SUBGAS
Raz WACC,WCOA,WSAC


Raz [L]TNBLED
If [M]FLGGEN<>2
 # Perf - 63533 : Variable boolean if the company is unique-ledger.
 Call LSTLEDTYP([M]CPY,1,TLEDTYP,TNBLED) From CPTDIV

 # Perf 90139 (following 63533) : Variable boolean if the document type is unique-ledger.
 If [L]TNBLED>1
  Raz [L]TNBLED
  Call LEC_CPY([M]CPY) From CPTLEC
  INDGCM = find([F:CPY]ACM,GGCM(1..GGCMNBR))
  Call LEC_GTE_LEG(GCURLEG,[M]TYP) From CPTLEC  #Report V6 : remplacé par LEC_GTE
  For INDLED=1 To len(mess(0,2644,1))
   If [F:GTE]AUZLED(INDLED-1)>1 & evalue("GLED"+num$(INDLED)+"("+num$(INDGCM)+")")<>""
    [L]TNBLED+=1
   Endif
  Next
 Endif
Endif

# Propagation - 68678
Raz [L]TPROAUT
# Axe commun
Raz [L]NB_AXECOM
Call SETAXECOM([M]CPY,NB_AXECOM,AXECOM) From CPTDIV

STAT = 0
OK=1
CAS = 1 # Initialisation du cas de génération à "Référentiel Saisi"

Case [M:HAEF]TYPENT
 When 1

  # Saisie en colonne
  # Référentiel saisi
  For nolign=1 To [M]NBLIG                        # Pour chaque ligne...
   NOL=nolign-1
   For NBLED=1 To [M:HAEF]NBRLED                  # Pour chaque référentiel potentiellement saisissable
    If evalue("[M]ACC"+num$(NBLED)+"(NOL)")<>""   # Référentiel réellement saisi
     WLEDTYP = [M:HAEF]LEDTYP(NBLED-1)
     WLED = [M:HAEF]LED(NBLED-1)
     Raz WACCNUM
     Gosub MAJ                                    # MAJ du masque GACCENT2
     If STAT | !OK : Break 2 : Endif     : ## <PP CE1> Suite aux dév. lot CE1
    Endif
   Next
  Next
  If STAT | !OK : Return : Endif         : ## <PP CE1> Suite aux dév. lot CE1

  # Référentiel généré
  If [M]FLGGEN<>2 & TNBLED>1
   Gosub LEDGEN
   If !OK : Return : Endif
  Endif

  # Référentiel automatique
  Gosub LEDAUT
  If !OK : Return : Endif

 When 2

  # Saisie en ligne
  # Référentiel saisi
  NBLED=1
  Raz WLED, WACCNUM
  For nolign=1 To [M]NBLIG
   NOL=nolign-1
   Gosub MAJ
   If STAT | !OK : Break : Endif         : ## <PP CE1> Suite aux dév. lot CE1
  Next
  If STAT | !OK : Return : Endif         : ## <PP CE1> Suite aux dév. lot CE1

  # Référentiel généré
  If [M]FLGGEN<>2 & TNBLED>1
   Gosub LEDGEN
   If !OK : Return : Endif
  Endif

  # Référentiel automatique
  Gosub LEDAUT
  If !OK : Return : Endif

Endcase
Return

###########################################################################################################
# Référentiels Générés
###########################################################################################################
$LEDGEN
CAS = 2 # Initialisation du cas de génération à "Référentiel Généré"

Call LEC_CPY([M]CPY) From CPTLEC #60923
INDGCM = find([F:CPY]ACM,GGCM(1..GGCMNBR))
Call LEC_GDE([M:HAEF]DACDIA) From CPTLEC
Raz LIN1

Local Integer FLG_SORTA  : FLG_SORTA=1 # Perf90646

While LIN1<[M:HAEW]NB

 # Not propagated on the lines of LIAISON
 If [M:HAEW]IDTLIN(LIN1)<>"LIAIS"

  Raz AJT
  If FLG_SORTA=1
   Sorta [M:HAEW]NB [M:HAEW]NB Order By [M:HAEW]IDTLIN(indice),[M:HAEW]LEDTYP(indice)
   FLG_SORTA=0
  Endif

  # Travail sur un groupe d'identifiant => Recherche le nombre de ligne ayant le même identifiant.
  Raz NBIDT
  LIN2=LIN1
  While [M:HAEW]IDTLIN(LIN1)=[M:HAEW]IDTLIN(LIN2)
   LIN2+=1 : NBIDT+=1
  Wend

  # Dans un même groupe d'identifiant, parcourt des Types de Référentiel du Dossier (chapitre 2644)
  # Règles de propagation sont définies par le type de pièce.
  #         Type de pièce => AUZLED = 1 Non autorisé
  #                       => AUZLED = 2 Autorisé
  #                       => AUZLED = 3 Obligatoire

  # On s'intéresse uniquement au Référentiel paramétré Autorisé ou Obligatoire
  For INDLED=1 To len(mess(0,2644,1))

   If [F:GTE]AUZLED(INDLED-1)>1

    Call LEDTYPAUT([M]CPY,INDLED,[L]AUT) From CPTDIV : # 1:Non 2:Oui

    # 1er propagation classique [L]TPROAUT=0 => uniquement sur référentiel non automatique
    # 2ème propgation sur lignes d'équilibre automatique [L]TPROAUT=1 => uniquement sur les référentiels non équilibrés

    If (![L]TPROAUT & [L]AUT=1) | ([L]TPROAUT & [M:HAEF]BAL(INDLED-1)<>2)
     LIN2=LIN1  # Pour chaque référentiel, on se repositionne au début du Groupe d'identifiant.
     Raz PRO    # PRO=0 signifie que le référentiel est à propager
     While LIN2<LIN1+NBIDT
      If LIN2>=[M:HAEW]NB : Break : Endif
      If [M:HAEW]LEDTYP(LIN2)=INDLED : PRO=1 : Break : Endif
      LIN2+=1
     Wend
     If !PRO
      # Référentiel à propager.
      # Re-parcourt toutes les lignes de ce groupe d'identifiant pour propager
      LIN2=LIN1
      While LIN2<LIN1+NBIDT
       If LIN2>=[M:HAEW]NB : Break : Endif
       Raz WACC, CRIBLE
       LEDPRO = evalue("GLED"+num$(INDLED)+"("+num$(INDGCM)+")")
       If LEDPRO<>""
        Call INDLED(LEDPRO,"",IND,AXE) From CPTDIV
        Call INIACC([M:HAEW]COA(LIN2),[M:HAEW]ACC(LIN2),GLEDCOA(IND),WACC,CRIBLE) From CPTINI
        # Référentiel obligatoire
        If [F:GTE]AUZLED(INDLED-1)=3 and WACC=""
         # Référentiel obligatoire : pas de compte par défaut
         STAT = 39 : Gosub MESSAGE From CPTAUTO
         GMESSAGE = mess(INDLED,2644,1)-MESSA-[M:HAEW]COA(LIN2)-[M:HAEW]ACC(LIN2)
         OK = 0 : Break 3
        Endif
        # Période ouverte
        If WACC<>""
         Raz mkstat : Call CONTPER([M]ACCDAT,INDLED,[M]FCY) From CPTSUB
         If mkstat
          If [F:GTE]AUZLED(INDLED-1)=3
           # Période fermée
           GMESSAGE += " ("+mess(INDLED,2644,1)+")"
           OK = 0 : Raz mkstat : Break 3
          Else
           Raz WACC, mkstat
          Endif
          Raz GMESSAGE
         Endif
        Endif
        # Propagation
        If WACC<>""
         WLED=LEDPRO : WLEDTYP=INDLED
         WCOA = GLEDCOA(IND) :  Raz WSAC
         Call LEC_GAC(WACC,WCOA) From CPTLEC
         If [F:GAC]SAC=2 : WSAC=[F:GAC]ACCSHO : Endif
         If ![L]TPROAUT
          NOL=[M:HAEW]LINREF(LIN2)-1  : Gosub MAJ : AJT=1 : FLG_SORTA=1
          If !OK : Break 3 : Endif
          # Demande 71766 - Déversement - Propagation souhaité + Initialisation des Sections.
          If [M]REFINT="DUM"
           If GLEDFLGANA(IND)=2 & [M:HAEW]DSP(NBLIN-1)=""
            LIG_IDTLIN = find([M:HAEW]IDTLIN(NBLIN-1),[M:HAEW]IDTLIN(0..NBLIN-2))
            For K=1 To GLEDDIENBR(IND)
             WDIE = evalue("GDIE"+num$(K)+"("+num$(IND)+")")
             # Issue 109148
             Assign "[M:HAEW]DIE"+num$(K)+"("+num$(NBLIN-1)+")" With WDIE
             # End issue 109148
             Raz WCCE
             If !NB_AXECOM or !find(WDIE,AXECOM(1..NB_AXECOM))
              # Recherche Axe commun.
              For IND_IDTLIN=LIG_IDTLIN-1 To [M:HAEW]NB-2
               If [M:HAEW]IDTLIN(NBLIN-1)=[M:HAEW]IDTLIN(IND_IDTLIN)
                Call INDLED([M:HAEW]LED(IND_IDTLIN),WDIE,LED_IDTLIN,AXE_IDTLIN) From CPTDIV
                If AXE_IDTLIN
                 WCCE =evalue("[M:HAEW]CCE"+num$(AXE_IDTLIN)+"("+num$(IND_IDTLIN)+")")
                 If WCCE<>"" : Break : Endif
                Endif
               Endif
              Next
             Endif
             If WCCE=""
              Call INICCE(WCCE,WDIE,[M:HAEW]LED(NBLIN-1),[M:HAEW]ACC(NBLIN-1),[F:GDE]CDE) From CPTINI
             Endif
             Assign "[M:HAEW]CCE"+num$(K)+"("+num$(NBLIN-1)+")" With WCCE
            Next K
           Endif
          Endif
         Elsif [M:HAEW]IDTLIN(LIN2)<>"LIAIS"
          # Propagation - 68678
          # Schéma classique : Ligne Réf.Saisie + Ligne Réf.Propagé (algorithme de propgation) + Ligne Réf.Automatique
          # Suite au contrôle X3 génère des lignes automatiques (tous Réf. confondus) correspondant aux lignes de contrepartie, d'écart et de liaison)
          # Nous sommes dans le cas de figure de la propagation sur CES lignes automatiques d'X3
          # Exemple : Ligne de contrepartie sur le journal de banque.
          #    X3 a généré une ligne automatique sur le social ET le réf. auto social
          #    La propagation s'effectue donc sur ces nouvelles lignes même sur le référentiel automatique.
          # Exemple : Ligne d'écart... X3 génère les écarts en mono-référentiel.
          #    Montant forcé sur le social, l'écart sera enregistré sur le Social (aucune ligne sur le réf. auto social)
          #    Montant forcé sur le Réf.social, l'écart sera enregistré sur le Social (ligne "nulle" pour le liens) ET sur le réf. auto social
          #    Cas particulier pour les écarts... pas de propagation 'automatique' sur le référentiel automatique pour les écarts.
          #    Pour les écarts, la propagation doit se faire sur le même type de référentiel d'où la condition ci dessous.
          [L]AUTPRO = 0
          If [M:HAEW]IDTLIN(LIN2)="ECART"
           Call LEDTYPAUT([M]CPY,[M:HAEW]LEDTYP(LIN2),[L]AUTPRO) From CPTDIV : # 1:Non 2:Oui
          Endif
          If [M:HAEW]IDTLIN(LIN2)<>"ECART" or [L]AUTPRO=[L]AUT
           NOL = [M:HAEW]NB
           WTYP =  WLEDTYP
           Call INDLED(WLED,"",IND,AXE) From CPTDIV
           [M:HAEW]FCYLIN(NOL) = [M:HAEW]FCYLIN(LIN2)
           [M:HAEW]ACC(NOL) = WACC
           [M:HAEW]CDT(NOL) = [M:HAEW]CDT(LIN2)
           [M:HAEW]DEB(NOL) = [M:HAEW]DEB(LIN2)
           [M:HAEW]CURLED(NOL) = [M:HAEF]CURC(WTYP-1) # Utile pour le SETCOUR
           [M:HAEW]LEDTYP(NOL) = WTYP                 # Utile pour le SETCOUR
           [M:HAEW]IDTLIN(NOL) = [M:HAEW]IDTLIN(LIN2)
           [M:HAEW]SAC(NOL) = WSAC
           If WSAC<>""
            [M:HAEW]BPR(NOL) = [M:HAEW]BPR(LIN2)
           Else
            [M:HAEW]BPR(NOL) = ""
           Endif
           If [M:HAEW]DEB(LIN2)<>0
            If [M]CUR=[M:HAEW]CURLED(NOL)
             [M:HAEW]AMTLED(NOL)=[M:HAEW]DEB(LIN2)
             Raz [M:HAEW]AMTFLG(LIN2), [M:HAEW]AMTLED1(LIN2)
            Elsif [M:HAEW]AMTFLG(LIN2)<>0
             [M:HAEW]AMTLED(NOL)=[M:HAEW]AMTLED1(LIN2)
            Else
             Call SETCOURS(NOL,DEVORG,DEVDES,COURS) From SUBGA1
             Call CONVERT3(DEVORG,DEVDES,[M:HAEW]CURLED(NOL),[M]TYPRAT,[M]RATDAT,
&                        [M:HAEW]DEB(LIN2),[M:HAEW]AMTLED(NOL),COURS,STAT) From CPTSUB
             If STAT : # Pas de cours de devises [M]CUR -> [M:HAEW]CURLED(LIN2) (RATDAT)
              GMESSAGE=mess(16,114,1)-[M]CUR-"->"-[M:HAEW]CURLED(NOL)-"("+format$("D:"+GFMDAT,[M]RATDAT)+")"
              mkstat=2 : Break
             Endif
            Endif
           Elsif [M:HAEW]CDT(LIN2)<>0
            If [M]CUR=[M:HAEW]CURLED(NOL)
             [M:HAEW]AMTLED(NOL)=[M:HAEW]CDT(LIN2)
             Raz [M:HAEW]AMTFLG(LIN2), [M:HAEW]AMTLED1(LIN2)
            Elsif [M:HAEW]AMTFLG(LIN2)<>0
             [M:HAEW]AMTLED(NOL)=[M:HAEW]AMTLED1(LIN2)
            Else
             Call SETCOURS(NOL,DEVORG,DEVDES,COURS) From SUBGA1
             Call CONVERT3(DEVORG,DEVDES,[M:HAEW]CURLED(NOL),[M]TYPRAT,[M]RATDAT,
&                         [M:HAEW]CDT(LIN2),[M:HAEW]AMTLED(NOL),COURS,STAT) From CPTSUB
             If STAT : # Pas de cours de devises [M]CUR -> [M:HAEW]CURLED(LIN2) (RATDAT)
              GMESSAGE=mess(16,114,1)-[M]CUR-"->"-[M:HAEW]CURLED(NOL)-"("+format$("D:"+GFMDAT,[M]RATDAT)+")"
              mkstat=2 : Break
             Endif
            Endif
           Else
            If [M:HAEW]AMTFLG(LIN2)<>0
             [M:HAEW]AMTFLG(NOL)=1
             [M:HAEW]AMTLED(NOL)=[M:HAEW]AMTLED1(LIN2)
             [M:HAEW]AMTLED1(NOL)=[M:HAEW]AMTLED1(LIN2)
            Else
             Raz [M:HAEW]AMTLED(LIN2),[M:HAEW]AMTFLG(LIN2),[M:HAEW]AMTLED1(LIN2)
            Endif
           Endif
           Gosub NEWLIN From SUBGA1 : AJT = 1 : FLG_SORTA=1
          Endif
         Endif
         If AJT=1 : Break : Endif
        Endif
       Endif
       LIN2+=1
      Wend
     Endif
    Endif
   Endif
  Next
 Endif
 If !AJT
  LIN1+=NBIDT
 Else
  AFF=1
 Endif
Wend
Return

###########################################################################################################
# Création d'une ligne sous GACCENT2
###########################################################################################################
$MAJ
# Attention [F:GDE]TYPENT  correspond à la Transaction de la Pièce Comptable, pour les Pièces Automatique DACDIA
# Attention [M:HAEF]TYPENT correspond à la Transaction de la Pièce Comptable, pour les Pièces Automatique impose une saisie colonne

# Nombre de lignes maxi atteint
If NBLIN >= dim([M:HAEW]ACC)
 MESSA = num$(NBLIN) : STAT = 34
 OK = 0 : Return
Endif

If [F:GDE]TYPENT=1
 [M:HAEW]LIN(NBLIN) = NOL+1
 If dim([M]AUTACE)>0 & dim(PCEMTE)>0 & [M]AUTACE<>"" & [M]AUTACE=PCEMTE & [M]IDTLIN(NOL)<>"" : [M:HAEW]LIN(NBLIN)=val([M]IDTLIN(NOL)) : Endif
Else
 [M:HAEW]LIN(NBLIN) = NBLIN+1
Endif


If dim(GWFONCTION)>0 & GWFONCTION="UTIGNRLED"
 [M:HAEW]IDTLIN(NBLIN) = [M]IDTLIN(NOL)
Elsif [M:HAEF]TYPENT=1
 If [M]IDTLIN(NOL)="LIAIS"
  [M:HAEW]IDTLIN(NBLIN) = [M]IDTLIN(NOL)
 Else
  [M:HAEW]IDTLIN(NBLIN) = num$(NOL+1)
 Endif
Else
 [M:HAEW]IDTLIN(NBLIN) = [M]IDTLIN(NOL)
Endif
If [L]TPROAUT
 [M:HAEW]IDTLIN(NBLIN) = [M:HAEW]IDTLIN(LIN2)
Endif

[M:HAEW]FCYLIN(NBLIN) = [M]FCYLIN(NOL)

If WLED<>""
 [M:HAEW]LEDTYP(NBLIN) = WLEDTYP
Else
 [M:HAEW]LEDTYP(NBLIN) = [M]LEDTYP(NOL)
Endif

Call LECLED([M]CPY,[M:HAEW]LEDTYP(NBLIN),[M:HAEW]LED(NBLIN),WCUR) From CPTDIV
Call INDLED([M:HAEW]LED(NBLIN),"",IND,AXE) From CPTDIV
[M:HAEW]COA(NBLIN)    = GLEDCOA(IND)

If WACC<>""
 [M:HAEW]SAC(NBLIN)    = WSAC
 [M:HAEW]ACC(NBLIN)    = WACC
Else
 [M:HAEW]SAC(NBLIN)  = evalue("[M]SAC"+num$(NBLED)+"("+num$(NOL)+")")
 [M:HAEW]ACC(NBLIN)  = evalue("[M]ACC"+num$(NBLED)+"("+num$(NOL)+")")
Endif

If [M:HAEW]SAC(NBLIN)<>""
 [M:HAEW]BPR(NBLIN)    = [M]BPR(NOL)
Else
 [M:HAEW]BPR(NBLIN) =""
Endif

If WDEB+WCDT<>0
 [M:HAEW]DEB(NBLIN)    = WDEB
 [M:HAEW]CDT(NBLIN)    = WCDT
Else
 [M:HAEW]DEB(NBLIN)    = [M]DEB(NOL)
 [M:HAEW]CDT(NBLIN)    = [M]CDT(NOL)
Endif
[M:HAEW]FREREF(NBLIN) = [M]FREREF(NOL)
[M:HAEW]DES(NBLIN)    = [M]DES(NOL)

Call LEC_GAC([M:HAEW]ACC(NBLIN),[M:HAEW]COA(NBLIN)) From CPTLEC
If CAS<>2
 [M:HAEW]CPA(NBLIN)  = evalue("[M]CPA"+num$(NBLED)+"("+num$(NOL)+")")
 If [F:GAC]FLGVAT>1
  [M:HAEW]TAX(NBLIN) = [M]TAX(NOL)
  ## <ALLEMAGNE>
  If dim([M:HAEW]TAX2)>0 & dim([M]TAX2)>0
   [M:HAEW]TAX2(NBLIN) = [M]TAX2(NOL)
  Endif
  If dim([M:HAEW]TAX3)>0 & dim([M]TAX2)>0
   [M:HAEW]TAX3(NBLIN) = [M]TAX3(NOL)
  Endif
  ## <Fin ALLEMAGNE>
 Endif
 If [F:GAC]FLGUOM=2
  [M:HAEW]UOM(NBLIN) = [M]UOM(NOL)
  [M:HAEW]QTY(NBLIN) = [M]QTY(NOL)
  If CAS=4
   [M:HAEW]QTY(NBLIN) = WQTY
  Endif
 Endif
 If dim([M:HAEW]CSLCOD)>0
  [M:HAEW]CSLCOD(NBLIN) = [M]CSLCOD(NOL)
 Endif
 If func AFNC.ACTIV("PRCSL")
  [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,[M:HAEW]LED(NBLIN),FLGCSL,ERRMES)
  If [L]FLGCSL=2 & [F:GAC]CSLFLGFLW>1
   [M:HAEW]CSLFLO(NBLIN) = [M]CSLFLO(NOL)
  Endif
  If [L]FLGCSL=2 & [F:GAC]CSLFLGBPR>1
   [M:HAEW]CSLBPR(NBLIN) = [M]CSLBPR(NOL)
  Endif
 Elsif dim([F:GAC]CSLFLGFLW)>0 & [F:GAC]CSLFLGFLW>1
  [M:HAEW]CSLFLO(NBLIN) = [M]CSLFLO(NOL)
 Endif
Else
 If [F:GAC]FLGVAT>1
  If dim(GEXETAX)>0    : [M:HAEW]TAX(NBLIN) = GEXETAX : Endif
  If [F:GAC]VAT(0)<>"" : [M:HAEW]TAX(NBLIN) = [F:GAC]VAT(0)  : Endif
  If [M]TAX(NOL)<>""  :  [M:HAEW]TAX(NBLIN) = [M]TAX(NOL)  : Endif
 Endif
 If [F:GAC]FLGUOM=2 :
  [M:HAEW]UOM(NBLIN) = [F:GAC]UOM
  [M:HAEW]QTY(NBLIN) = [F:GAC]VALUOM
  #[M:HAEW]QTY(NBLIN) = [M]QTY(NOL)
 Endif
 If func AFNC.ACTIV("PRCSL")
  [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,[M:HAEW]LED(NBLIN),FLGCSL,ERRMES)
  If [L]FLGCSL=2 & [F:GAC]CSLFLGFLW>1
   [M:HAEW]CSLFLO(NBLIN) = [M]CSLFLO(NOL)
  Else
   [M:HAEW]CSLFLO(NBLIN) = ""
  Endif
  If [L]FLGCSL=2 & [F:GAC]CSLFLGBPR>1
   [M:HAEW]CSLBPR(NBLIN) = [M]CSLBPR(NOL)
  Else
   [M:HAEW]CSLBPR(NBLIN) = ""
  Endif
 Elsif dim([F:GAC]CSLFLGFLW)>0
  If [F:GAC]CSLFLGFLW>1
   [M:HAEW]CSLFLO(NBLIN) = [M]CSLFLO(NOL)
  Else
   [M:HAEW]CSLFLO(NBLIN) = ""
  Endif
 Endif
Endif

#-- Champs utilisés pour les pièces automatiques
If dim([M]CRITGRP)>0
 [M:HAEW]CRITGRP(NBLIN) = [M]CRITGRP(NOL)       : # critère regroupement libre
Endif
If dim([M]LIGPCEAUTO)>0
 [M:HAEW]LIGPCEAUTO(NBLIN) = [M]LIGPCEAUTO(NOL) : # Ligne pièce auto
Endif
If dim([M]FLGDUD)>0
 ## Champs permettant de repérer la ligne auxiliarisée de manière à renuméroter le numéro de ligne de
 ## l'échéance créée avant la comptabilisation (cas des factures)
 [M:HAEW]FLGDUD(NBLIN) = [M]FLGDUD(NOL)
Endif
If dim([M]REFINTLIN)>0
 [M:HAEW]REFINTLIN(NBLIN) = [M]REFINTLIN(NOL)
Endif
If dim([M]TRCLIG)>0
 [M:HAEW]TRCLIG(NBLIN) = [M]TRCLIG(NOL)
Endif

#-- Champs techniques pour la comptabilisation des règlements
If dim([M]CODAUTACE)>0
 [M:HAEW]CODAUTACE(NBLIN)  = [M]CODAUTACE(NOL)
Endif
If dim([M]CRIMTC)>0
 [M:HAEW]CRIMTC(NBLIN) = [M]CRIMTC(NOL)
Endif
If dim([M]CRITGRPIMP)>0
 [M:HAEW]CRITGRPIMP(NBLIN) = [M]CRITGRPIMP(NOL)
Endif
If dim([M]INDGRP)>0
 [M:HAEW]INDGRP(NBLIN) = [M]INDGRP(NOL)
Endif
If dim([M]OLDLIG)>0
 [M:HAEW]OLDLIG(NBLIN) = [M]OLDLIG(NOL)
Endif

#-- Analytique
[M:HAEW]DSP(NBLIN)    = [M]DSP(NOL)
[M:HAEW]PTV(NBLIN)    = [M]PTV(NOL)
[M:HAEW]PTF(NBLIN)    = [M]PTF(NOL)

# In case of Import with no analytic Line and due date lines , we want to have the repartition information ( $ or CCEDEF)
# coming from the account of Analytic.
If [M:HAEW]DSP(NBLIN)="" & GIMPORT & CAS=2
 [M:HAEW]DSP(NBLIN) = [F:GAC]DSP
 If [M:HAEW]DSP(NBLIN)=""
  Call INDLED([M:HAEW]LED(NBLIN),"",IND,AXE) From CPTDIV
  If IND
   For K=1 To GLEDDIENBR(IND)
    WDIE = evalue("GDIE"+num$(K)+"("+num$(IND)+")")
    # Issue 109148
    Assign "[M:HAEW]DIE"+num$(K)+"("+num$(NBLIN)+")" With WDIE
    # End issue 109148
    AXE=find(WDIE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
    If AXE
     WCCEDEF=[F:GAC]CCEDEF(AXE-1)
     Assign "[M:HAEW]CCE"+num$(K)+"("+num$(NBLIN)+")" With WCCEDEF
    Endif
   Next
  Endif
 Endif
Endif
Raz WCCEDEF


#-- Report des sections uniquement si la répartition est saisie sur la ligne d'écriture générale.
#--  [M:HAEW]DSP(NOL)="$" (Répartition manuelle)
#--  [M:HAEW]DSP(NOL)<>"" (Réparition standard)
If [M:HAEW]DSP(NBLIN)=""
 Call INDLED([M:HAEW]LED(NBLIN),"",IND,AXE) From CPTDIV
 If IND
  For J=1 To GLEDDIENBR(IND)
   AXE = find(evalue("GDIE"+num$(J)+"("+num$(IND)+")"),[M:HAEF]DIE(0..19))
   # Issue 109148
   WDIE = evalue("GDIE"+num$(J)+"("+num$(IND)+")")
   Assign "[M:HAEW]DIE"+num$(J)+"("+num$(NBLIN)+")" With WDIE
   # End issue 109148
   If AXE>0 # petite sécurité dans le cas d'un changement à tort du paramètrage
    WCCE = evalue("[M]CCE"+num$(AXE)+"("+num$(NOL)+")")
    If WCCE<>""
     Assign "[M:HAEW]CCE"+num$(J)+"("+num$(NBLIN)+")"  With WCCE
    Elsif CAS = 3
     INDLIN=0
     For K=0 To [M:HAEW]NB-1
      If WACCNUM=[M:HAEW]ACCNUM(K)
       INDLIN = K : Break
      Endif
     Next
     If INDLIN
      Assign "[M:HAEW]CCE"+num$(J)+"("+num$(NBLIN)+")"  With evalue("[M:HAEW]CCE"+num$(J)+"("+num$(INDLIN)+")")
     Endif
    Endif
   Endif
  Next
 Endif
Endif

If WDEB+WCDT<>0 | (dim(GWFONCTION)>0 & GWFONCTION="UTIGNRLED")
 [M:HAEW]AMTLED(NBLIN)  = WAMTLED
 [M:HAEW]AMTFLG(NBLIN)  = WAMTFLG
 [M:HAEW]AMTLED1(NBLIN) = WAMTLED1
Else
 [M:HAEW]AMTLED(NBLIN)  = evalue("[M]AMT"+num$([M:HAEW]LEDTYP(NBLIN))+"(NOL)")
 [M:HAEW]AMTFLG(NBLIN)  = evalue("[M]AMTFLG"+num$([M:HAEW]LEDTYP(NBLIN))+"(NOL)")
 [M:HAEW]AMTLED1(NBLIN) = evalue("[M]AMTFRC"+num$([M:HAEW]LEDTYP(NBLIN))+"(NOL)")
Endif

[M:HAEW]CURLED(NBLIN)  = evalue("[M:HAEF]CURC"+"("+num$([M:HAEW]LEDTYP(NBLIN)-1)+")")
[M:HAEW]FIY(NBLIN)     = evalue("[M:HAEF]FIY"+"("+num$([M:HAEW]LEDTYP(NBLIN)-1)+")")
[M:HAEW]PER(NBLIN)     = evalue("[M:HAEF]PER"+"("+num$([M:HAEW]LEDTYP(NBLIN)-1)+")")

# Gestion de l'ACCNUM
If WLED=""
 [M:HAEW]ACCNUM(NBLIN) = [M]ACCNUM(NOL)
Endif
# 77373 : Saisie de pièce
If GFONCTION="GESGAS" & [M]NUM<>""
 If FLECHE=0 & GCOMPTA<>3 & GTYPGEN=[M:HAEW]LEDTYP(NBLIN)
  Read [DUD]DUD0(3) = [M]TYP;[M]NUM;[M:HAEW]OLDLIG(NBLIN)
  If !fstat : [M:HAEW]ACCNUM(NBLIN) = [F:DUD]ACCNUM : Endif
 Endif
 If [M:HAEW]ACCNUM(NBLIN)=0
  Read [DAE3]DAE0 = [M]TYP;[M]NUM;[M:HAEW]OLDLIG(NBLIN); [M:HAEW]LEDTYP(NBLIN)
  If !fstat : [M:HAEW]ACCNUM(NBLIN) = [F:DAE3]ACCNUM : Endif
 Endif
Else
 If FLECHE=0 & GCOMPTA<>3 & GTYPGEN=[M:HAEW]LEDTYP(NBLIN)
  Read [DUD]DUD0(3) = [M]TYP;[M]NUM;[M:HAEW]LIN(NBLIN)
  If !fstat : [M:HAEW]ACCNUM(NBLIN) = [F:DUD]ACCNUM : Endif
 Endif
 If [M:HAEW]ACCNUM(NBLIN)=0
  Read [DAE3]DAE0 = [M]TYP;[M]NUM;[M:HAEW]LIN(NBLIN); [M:HAEW]LEDTYP(NBLIN)
  If !fstat : [M:HAEW]ACCNUM(NBLIN) = [F:DAE3]ACCNUM : Endif
 Endif
Endif

If [M:HAEW]ACCNUM(NBLIN)=0
 # Call ACCNUM([M:HAEW]ACCNUM(NBLIN)) from SUBGAS
 # Trop tôt, initialise dans ce cas au niveau de ligne (négatif pour reconnaitre le cas)
 [M:HAEW]ACCNUM(NBLIN) = (NBLIN+1)*-1
Endif
If WACCNUM=0 & GTYPGEN=[M:HAEW]LEDTYP(NBLIN)
 [M]ACCNUM(NOL) = [M:HAEW]ACCNUM(NBLIN)
Endif
[M:HAEW]ACCNUMORI(NBLIN) = WACCNUM
[M:HAEW]DOEPTR(NBLIN)    = [M]DOEPTR(NOL)
[M:HAEW]ACCNUMDOE(NBLIN) = [M]DOEPTR(NOL)
If CAS=4 & [M]DOEPTR(NOL)>0
 [M:HAEW]ACCNUMDOE(NBLIN) = WINDDOE*-1
Endif

# Gestion du lettrage
If WLED=""
 [M:HAEW]MTC(NBLIN)       = [M]MTC(NOL)
 [M:HAEW]MTCDAT(NBLIN)    = [M]MTCDAT(NOL)
 [M:HAEW]MTCDATMIN(NBLIN) = [M]MTCDATMIN(NOL)
 [M:HAEW]MTCDATMAX(NBLIN) = [M]MTCDATMAX(NOL)
 [M:HAEW]CHK(NBLIN)       = [M]CHK(NOL)
 [M:HAEW]CHKDAT(NBLIN)    = [M]CHKDAT(NOL)
 [M:HAEW]AMTVAT(NBLIN)    = [M]AMTVAT(NOL)
 [M:HAEW]CHRNUM(NBLIN)    = [M]CHRNUM(NOL)
Else
 # 77373 : Saisie de pièce
 If GFONCTION="GESGAS"
  Read [DAE3]DAE0 = [M]TYP;[M]NUM;[M:HAEW]OLDLIG(NBLIN); [M:HAEW]LEDTYP(NBLIN)
 Else
  Read [DAE3]DAE0 = [M]TYP;[M]NUM;[M:HAEW]LIN(NBLIN); [M:HAEW]LEDTYP(NBLIN)
 Endif
 If !fstat
  [M:HAEW]MTC(NBLIN)       = [F:DAE3]MTC
  [M:HAEW]MTCDAT(NBLIN)    = [F:DAE3]MTCDAT
  [M:HAEW]MTCDATMIN(NBLIN) = [F:DAE3]MTCDATMIN
  [M:HAEW]MTCDATMAX(NBLIN) = [F:DAE3]MTCDATMAX
  [M:HAEW]CHK(NBLIN)       = [F:DAE3]CHK
  [M:HAEW]CHKDAT(NBLIN)    = [F:DAE3]CHKDAT
  [M:HAEW]AMTVAT(NBLIN)    = [F:DAE3]AMTVAT
  [M:HAEW]CHRNUM(NBLIN)    = [F:DAE3]CHRNUM
 Endif
Endif

#-- Statistiques
[M:HAEW]STT1(NBLIN)    = [M]STT1(NOL)
[M:HAEW]STT2(NBLIN)    = [M]STT2(NOL)
[M:HAEW]STT3(NBLIN)    = [M]STT3(NOL)

#RMA * Req. 75183
Gosub UPD_HAEW From CAPFLOLIB

If    [M:HAEW]DEB(NBLIN)<>0               : [M:HAEW]SNS(NBLIN)=1
Elsif [M:HAEW]CDT(NBLIN)<>0               : [M:HAEW]SNS(NBLIN)=-1
Elsif evalue("[M:HAEW]AMTLED1(NBLIN)")>0  : [M:HAEW]SNS(NBLIN)=1
Elsif evalue("[M:HAEW]AMTLED1(NBLIN)")<0  : [M:HAEW]SNS(NBLIN)=-1
Elsif [M:HAEW]QTY(NBLIN)<0                : [M:HAEW]SNS(NBLIN)=-1 # DdM51478
Else                                      : [M:HAEW]SNS(NBLIN)=1
Endif

If [M:HAEW]SNS(NBLIN)=1
 [M:HAEW]AMTCUR(NBLIN)  = [M:HAEW]DEB(NBLIN)
 Assign "[M:HAEW]TOTDEB("+num$([M:HAEW]LEDTYP(NBLIN)-1)+")" With evalue("[M:HAEW]TOTDEB("+num$([M:HAEW]LEDTYP(NBLIN)-1)+")") +  [M:HAEW]AMTCUR(NBLIN)
Else
 [M:HAEW]AMTCUR(NBLIN)  = [M:HAEW]CDT(NBLIN)
 Assign "[M:HAEW]TOTCDT("+num$([M:HAEW]LEDTYP(NBLIN)-1)+")" With evalue("[M:HAEW]TOTCDT("+num$([M:HAEW]LEDTYP(NBLIN)-1)+")") +  [M:HAEW]AMTCUR(NBLIN)
 If [M:HAEW]CDT(NBLIN)=0
  [M:HAEW]AMTLED(NBLIN)   *= -1
  [M:HAEW]AMTLED1(NBLIN)  *= -1
  [M:HAEW]QTY(NBLIN)      *= -1 # DdM51478
 Endif
Endif

Assign "[M:HAEW]TOTLED("+num$([M:HAEW]LEDTYP(NBLIN)-1)+")" With evalue("[M:HAEW]TOTLED("+num$([M:HAEW]LEDTYP(NBLIN)-1)+")") + [M:HAEW]AMTLED(NBLIN)
Assign "[M:HAEW]TOTLED1("+num$([M:HAEW]LEDTYP(NBLIN)-1)+")" With evalue("[M:HAEW]TOTLED1("+num$([M:HAEW]LEDTYP(NBLIN)-1)+")") + [M:HAEW]AMTLED1(NBLIN)

[M:HAEW]LINREF(NBLIN) = NOL+1
If dim([M:HAEW]NUMLIN(NBLIN))>0 : [M:HAEW]NUMLIN(NBLIN) = NBLIN : Endif
[M:HAEW]EXPNUM(NBLIN) = [C]EXPORT
If dim([M]PJTLIN)>0
 [M:HAEW]PJTLIN(NBLIN)=[M]PJTLIN(NOL)
Endif

# Boucle pour les champs spécifiques.
If dim(GCPTSPE)>0 & GCPTSPE=2
 For [AMZ]CODE Where CODMSK="GACCENTW" & CODZON>="X"
  If evalue("dim([M]"+[F:AMZ]CODZON+")")>0
   Assign "[M:HAEW]"+[F:AMZ]CODZON+"("+num$(NBLIN)+")" With evalue("[M]"+[F:AMZ]CODZON+"("+num$(NOL)+")")
  Endif
 Next
Endif

GPOINT = "MSKLOAD" : Gosub ENTREE From EXEFNC

NBLIN+=1
[M:HAEW]NB=NBLIN

Return


###########################################################################################################
# Référentiels Automatiques : Simple ou Double
###########################################################################################################
$LEDAUT
Gosub DECLARE_C From SUBGAS

NB = [M:HAEW]NB
Sorta [M:HAEW]NB [M:HAEW]NB Order By [M:HAEW]LEDTYP(indice), [M:HAEW]LIN(indice)

For INDLED=0 To len(mess(0,2644,1))-1

 If [F:GCM]LED(INDLED)<>"" and [F:GCM]CFMAUT(INDLED)=2

  Raz WCOA,WSAC,WACC,WDEB,WCDT,WQTY
  If [F:GCM]DOELED(INDLED)<>2
   CAS = 3 # Initialisation du cas de génération à "Référentiel Auto - Partie Simple"
   Raz LIN1
   While LIN1<[L]NB
    If [M:HAEW]LEDTYP(LIN1)=[F:GCM]ORILEDTYP(INDLED)
     # Recherche le nombre de ligne ayant le même référentiel.
     Raz NBIDT
     LIN2=LIN1
     While [M:HAEW]LEDTYP(LIN1)=[M:HAEW]LEDTYP(LIN2)
      LIN2+=1 : NBIDT+=1
      If LIN2>=[L]NB : Break : Endif
     Wend

     # Parcours les lignes du référentiel
     LIN2=LIN1
     While LIN2<LIN1+NBIDT
      If LIN2>=[L]NB : Break : Endif
      NBLED   = 1
      WLEDTYP = INDLED+1 : WLED    = [M:HAEW]LED(LIN2)
      WCOA    = [M:HAEW]COA(LIN2) : WACC = [M:HAEW]ACC(LIN2) :   WSAC = [M:HAEW]SAC(LIN2)
      WACCNUM = [M:HAEW]ACCNUM(LIN2)
      NOL=[M:HAEW]LINREF(LIN2)-1
      Gosub MAJ
      If !OK : Break 3 : Endif
      LIN2+=1
     Wend
     Break
    Endif
    LIN1+=1
   Wend
  Else
   CAS = 4 # Initialisation du cas de génération à "Référentiel Auto - Partie Double"
   Gosub LEDAUT_KRU From SUBGASD
   If !OK : Break : Endif
  Endif
 Endif
Next

If !OK : Return : Endif
[M:HAEW]NB=NBLIN
Return

