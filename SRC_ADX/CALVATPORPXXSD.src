    RET = "06"
  When "1B3"
    RET = "07"
  When "1B4"
    RET = "08"
  When "1C"
    RET = "11"
  When "1D"
    RET = "13"
  When "1E"
    RET = "20"
  When "1F"
    RET = "21"
Endcase

End RET
#############################################################################################
#############################################################################################
Funprog GET_Q40(MOTIV)
Value Char MOTIV

Local Char RET(2)

Case MOTIV
  When "1A1", "1A2", "1A3"
    RET = "1A"
  When "1B1", "1B2", "1B3", "1B4"
    RET = "1B"
  When "1C1", "1C2", "1C3", "1C4"
    RET = "1C"
  When "1D1", "1D2", "1D3", "1D4"
    RET = "1D"
  When "1E1", "1E2", "1E3", "1E4"
    RET = "1E"
  When "1F"
    RET = "1F"
  When "1G"
    RET = "1G"
  When "2"
    RET = "2"
  When "31", "32"
    RET = "3"
Endcase

End RET

#############################################################################################
#############################################################################################
Funprog GET_Q41(MOTIV)
Value Char MOTIV

Local Char RET(2)
Infbox(MOTIV)
Case MOTIV
  When "1A1", "1A2", "1A3"
    RET = "1A"
  When "1B1", "1B2", "1B3", "1B4"
    RET = "1B"
  When "1C1"
    RET = "1C"
  When "1D1"
    RET = "1D"
  When "1E1"
    RET = "1E"
  When "1F"
    RET = "1F"
  When "21", "22"
    RET = "2"
Endcase

End RET
