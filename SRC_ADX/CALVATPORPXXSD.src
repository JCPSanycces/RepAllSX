#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
$EXPORT

Iomode adxirs chr$(10)          Using [VATF]
Iomode adxifs ''                Using [VATF]
Iomode adxium 50                Using [VATF]

Gosub DEC_EXP_VARS

Read [F:DVPP]DVPP0 = [F:DVPH]CPY;[F:DVPH]DCLYEA
If [F:CPY]CPY <> [F:DVPH]CPY
  Read [F:CPY]CPY0   = [F:DVPH]CPY
Endif

[L]DCLNUM     = [F:DVPH]DCLNUM
[L]ANXPER1NUM = [F:DVPH]ANXPER1
[L]ANXPER2NUM = [F:DVPH]ANXPER2
[L]ANXPER3NUM = [F:DVPH]ANXPER3
[L]ANXINUM    = [F:DVPH]ANXI
[L]MDCLYEA    = [F:DVPH]DCLYEA
[L]MFPERIOD   = [F:DVPH]FPERIOD
[L]DCLPAG     = 1

[L]AN1COUNT = [F:DVPH]FAN1LINCOUNT>0 & [F:DVPH]BPCFLG = 2
[L]AN2COUNT = [F:DVPH]FAN2LINCOUNT>0 & [F:DVPH]BPSFLG = 2
[L]AN3COUNT = [F:DVPH]FAN3LINCOUNT>0 & [F:DVPH]REGFLG = 2

Wrseq '<?xml version="1.0" encoding="utf-8" ?>' Using [VATF]
Wrseq '<dpiva xmlns="http://www.at.gov.pt/schemas/dpiva" version="05">' Using [VATF]
#Onerrgo

Gosub EXPORT_ROSTO

# Annex 40 - current declaration
If [F:DVPH]FAN40LINCONT > 0 | [F:DVPH]FLDAN4003 > 0 | [F:DVPH]FLDAN4004  > 0 |
&  [F:DVPH]FLDAN4003A  > 0 | [F:DVPH]FLDAN4004A  > 0 | [F:DVPH]FLDAN4003B  > 0 | [F:DVPH]FLDAN4004B > 0
  Read [F:DVPH]DVPH0 = [L]DCLNUM
  Gosub EXPORT_ANNEX_40
Endif

#TODO
# Annex 41 - current declaration
If [F:DVPH]FAN41LINCONT > 0 | [F:DVPH]FLDAN4103A > 0 | [F:DVPH]FLDAN4104A  > 0 |
&  [F:DVPH]FLDAN4103B  > 0 | [F:DVPH]FLDAN4104B  > 0 #| [F:DVPH]FLDAN4103C  > 0 | [F:DVPH]FLDAN4104C  > 0 |
#&  [F:DVPH]FLDAN4103D  > 0 | [F:DVPH]FLDAN4104D  > 0
  Read [F:DVPH]DVPH0 = [L]DCLNUM
  Gosub EXPORT_ANNEX_41
Endif

# Annex R1 - Other fiscal spaces (Mainland\Azores\Madeira) - current declaration
If [F:DVPH]AN1LOC > 0 & find([F:DVPH]AN1LOC, [F:DVPH]FAN1OPE, [F:DVPH]FAN2OPE, [F:DVPH]FAN3OPE)
  [L]DCLPAG = 2
  [L]ANRLOC = evalue("[F:DVPH]FAN"+num$([F:DVPH]AN1LOC)+"OPE")
  Gosub EXPORT_ANNEX_R
Endif

# Annex R2 - Other fiscal spaces (Mainland\Azores\Madeira) - current declaration
If [F:DVPH]AN2LOC > 0 & find([F:DVPH]AN2LOC, [F:DVPH]FAN1OPE, [F:DVPH]FAN2OPE, [F:DVPH]FAN3OPE)
  [L]DCLPAG = 3
  [L]ANRLOC = evalue("[F:DVPH]FAN"+num$([F:DVPH]AN2LOC)+"OPE")
  Gosub EXPORT_ANNEX_R
Endif

# Annex I - Transactions with other UE countries - European services declaration
If [F:DVPH]ANXI <> ""
  [L]DCLPAG = 1 #we did not separated by fiscal space, so all value is on main dec (dclpag = 1)
  Read [F:DVPH]DVPH0 = [L]ANXINUM
  If fstat
    Gosub EXPORT_ANNEX_I
  Endif
Endif

# Annex 1 - current declaration
If [F:DVPH]FAN1LINCOUNT > 0 & [F:DVPH]BPCFLG = 2
  Read [F:DVPH]DVPH0 = [L]DCLNUM
  Gosub EXPORT_ANNEX_1
Endif

# Annex 1 - declaration of period 1 (n-1)
If [L]ANXPER1NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER1NUM
  If !fstat
    If [F:DVPH]FAN1LINCOUNT > 0
      Gosub EXPORT_ANNEX_1
    Endif
  Endif
Endif

# Annex 1 - declaration of period 2 (n-2)
If [L]ANXPER2NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER2NUM
  If !fstat
    If [F:DVPH]FAN1LINCOUNT > 0
      Gosub EXPORT_ANNEX_1
    Endif
  Endif
Endif

# Annex 1 - declaration of period 3 (n-3)
If [L]ANXPER3NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER3NUM
  If !fstat
    If [F:DVPH]FAN1LINCOUNT > 0
      Gosub EXPORT_ANNEX_1
    Endif
  Endif
Endif

# Annex 2 - current declaration
If [F:DVPH]FAN2LINCOUNT > 0  & [F:DVPH]BPSFLG = 2
  Read [F:DVPH]DVPH0 = [L]DCLNUM
  Gosub EXPORT_ANNEX_2
Endif

# Annex 2 - declaration of period 3 (n-1)
If [L]ANXPER1NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER1NUM
  If !fstat
    If [F:DVPH]FAN2LINCOUNT > 0
      Gosub EXPORT_ANNEX_2
    Endif
  Endif
Endif

# Annex 2 - declaration of period 3 (n-2)
If [L]ANXPER2NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER2NUM
  If !fstat
    If [F:DVPH]FAN2LINCOUNT > 0
      Gosub EXPORT_ANNEX_2
    Endif
  Endif
Endif

# Annex 2 - declaration of period 3 (n-3)
If [L]ANXPER3NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER3NUM
  If !fstat
    If [F:DVPH]FAN2LINCOUNT > 0
      Gosub EXPORT_ANNEX_2
    Endif
  Endif
Endif

# Annex 3 - current declaration
If [F:DVPH]FAN3LINCOUNT > 0 & [F:DVPH]REGFLG = 2
  Read [F:DVPH]DVPH0 = [L]DCLNUM
  Gosub EXPORT_ANNEX_3
Endif

# Annex 3 - declaration of period 1 (n-1)
If [L]ANXPER1NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER1NUM
  If !fstat
    If [F:DVPH]FAN3LINCOUNT > 0
      Gosub EXPORT_ANNEX_3
    Endif
  Endif
Endif

# Annex 3 - declaration of period 2 (n-2)
If [L]ANXPER2NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER2NUM
  If !fstat
    If [F:DVPH]FAN3LINCOUNT > 0
      Gosub EXPORT_ANNEX_3
    Endif
  Endif
Endif

# Annex 3 - declaration of period 2 (n-3)
If [L]ANXPER3NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER3NUM
  If !fstat
    If [F:DVPH]FAN3LINCOUNT > 0
      Gosub EXPORT_ANNEX_3
    Endif
  Endif
Endif

Wrseq '</dpiva>' Using [VATF]

Return
######################################################################################
######################################################################################
$EXPORT_ROSTO

Wrseq space$(2) + '<rosto>' Using [VATF]

#----- File apuramento -----#
Wrseq space$(4) + '<apuramento>' Using [VATF]

[L]DCLFLD = "014" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btBensUEArtigo15>' + num$([F:DVPF]AMT*100) + '</btBensUEArtigo15>' Using [VATF] # Campo 14. Base tributável
[L]DCLFLD = "015" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btBensUEArtigo22>' + num$([F:DVPF]AMT*100) + '</btBensUEArtigo22>' Using [VATF] # Campo 15. Base tributável
[L]DCLFLD = "012" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btBensUELiquidadoDeclarante>' + num$([F:DVPF]AMT*100) + '</btBensUELiquidadoDeclarante>' Using [VATF] # Campo 12. Base tributável
[L]DCLFLD = "010" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btBensUETotal>' + num$([F:DVPF]AMT*100) + '</btBensUETotal>' Using [VATF] # Campo 10. Base tributável
[L]DCLFLD = "008" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btOperacoesIsentasComDeducao>' + num$([F:DVPF]AMT*100) + '</btOperacoesIsentasComDeducao>' Using [VATF] # Campo 8. Base tributável
[L]DCLFLD = "009" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btOperacoesIsentasSemDeducao>' + num$([F:DVPF]AMT*100) + '</btOperacoesIsentasSemDeducao>' Using [VATF] # Campo 9. Base tributável
[L]DCLFLD = "016" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btServicosUE>' + num$([F:DVPF]AMT*100) + '</btServicosUE>' Using [VATF] # Campo 16. Base tributável
[L]DCLFLD = "005" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btTaxaIntermedia>' + num$([F:DVPF]AMT*100) + '</btTaxaIntermedia>' Using [VATF] # Campo 5. Base tributável
[L]DCLFLD = "003" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btTaxaNormal>' + num$([F:DVPF]AMT*100) + '</btTaxaNormal>' Using [VATF] # Campo 3. Base tributável
[L]DCLFLD = "001" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btTaxaReduzida>' + num$([F:DVPF]AMT*100) + '</btTaxaReduzida>' Using [VATF] # Campo 1. Base tributável
[L]DCLFLD = "090" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btTotal>' + num$([F:DVPF]AMT*100) + '</btTotal>' Using [VATF] # Campo 90. Total da base tributável   1 + 5 + 3 + ... + 10 + 16
[L]DCLFLD = "007" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btTransmissoesUEIsentas>' + num$([F:DVPF]AMT*100) + '</btTransmissoesUEIsentas>' Using [VATF] # Campo 7. Base tributável
[L]DCLFLD = "096" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<excessoAReportar>' + num$([F:DVPF]AMT*100) + '</excessoAReportar>' Using [VATF] # Campo 96. Excesso a reportar  Valor a inscrever no campo 61
[L]DCLFLD = "061" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<excessoAReportarPeriodoAnterior>' + num$([F:DVPF]AMT*100) + '</excessoAReportarPeriodoAnterior>' Using [VATF] # Campo 61. A favor do sujeito passivo
[L]DCLFLD = "093" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaAEntregar>' + num$([F:DVPF]AMT*100) + '</ivaAEntregar>' Using [VATF] # Campo 93. Imposto a entregar ao Estado
[L]DCLFLD = "094" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaARecuperar>' + num$([F:DVPF]AMT*100) + '</ivaARecuperar>' Using [VATF] # Campo 94. Crédito de imposto a recuperar
[L]DCLFLD = "013" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaBensUELiquidadoDeclarante>' + num$([F:DVPF]AMT*100) + '</ivaBensUELiquidadoDeclarante>' Using [VATF] # Campo 13. Imposto a favor do Estado
[L]DCLFLD = "011" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaBensUETotal>' + num$([F:DVPF]AMT*100) + '</ivaBensUETotal>' Using [VATF] # Campo 11. Imposto a favor do Estado
[L]DCLFLD = "065" : Gosub READ_FLD_VAL
IVADEDUTIVELANEXOSRTOTAL = [F:DVPF]AMT
Wrseq space$(6) + '<ivaDedutivelAnexoR1>' + num$([F:DVPF]AMT*100) + '</ivaDedutivelAnexoR1>' Using [VATF] # Campo 65. Neste campo deve inscrever o imposto dedutível, correspondente ao valor inscrito
# no
# campo 63 do Anexo
[L]DCLFLD = "067" : Gosub READ_FLD_VAL
IVADEDUTIVELANEXOSRTOTAL += [F:DVPF]AMT
Wrseq space$(6) + '<ivaDedutivelAnexoR2>' + num$([F:DVPF]AMT*100) + '</ivaDedutivelAnexoR2>' Using [VATF] # Campo 67. Neste campo deve inscrever o imposto dedutível, # correspondente ao valor inscrito
# no
# campo 63 do
Wrseq space$(6) + '<ivaDedutivelAnexosRTotal>' + num$(IVADEDUTIVELANEXOSRTOTAL*100) + '</ivaDedutivelAnexosRTotal>' Using [VATF] # Total dos campos 65 e 67
[L]DCLFLD = "023" : Gosub READ_FLD_VAL
IVADEDUTIVELTOTAL = [F:DVPF]AMT
Wrseq space$(6) + '<ivaDedutivelExistenciasTaxaIntermedia>' + num$([F:DVPF]AMT*100) + '</ivaDedutivelExistenciasTaxaIntermedia>' Using [VATF] # Campo 23. A favor do sujeito passivo à taxa intermédia
[L]DCLFLD = "022" : Gosub READ_FLD_VAL
IVADEDUTIVELTOTAL += [F:DVPF]AMT
Wrseq space$(6) + '<ivaDedutivelExistenciasTaxaNormal>' + num$([F:DVPF]AMT*100) + '</ivaDedutivelExistenciasTaxaNormal>' Using [VATF] # Campo 22. A favor do sujeito passivo à taxa normal
[L]DCLFLD = "021" : Gosub READ_FLD_VAL
IVADEDUTIVELTOTAL += [F:DVPF]AMT
Wrseq space$(6) + '<ivaDedutivelExistenciasTaxaReduzida>' + num$([F:DVPF]AMT*100) + '</ivaDedutivelExistenciasTaxaReduzida>' Using [VATF] # Campo 21. A favor do sujeito passivo à taxa reduzida
[L]DCLFLD = "020" : Gosub READ_FLD_VAL
IVADEDUTIVELTOTAL += [F:DVPF]AMT
Wrseq space$(6) + '<ivaDedutivelImobilizado>' + num$([F:DVPF]AMT*100) + '</ivaDedutivelImobilizado>' Using [VATF] # Campo 20. A favor do sujeito passivo
[L]DCLFLD = "024" : Gosub READ_FLD_VAL
IVADEDUTIVELTOTAL += [F:DVPF]AMT
Wrseq space$(6) + '<ivaDedutivelOutros>' + num$([F:DVPF]AMT*100) + '</ivaDedutivelOutros>' Using [VATF] # Campo 24. A favor do sujeito passivo
Wrseq space$(6) + '<ivaDedutivelTotal>' + num$(IVADEDUTIVELTOTAL*100) + '</ivaDedutivelTotal>' Using [VATF] # Total dos campos 20 a 24
[L]DCLFLD = "092" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaFavorEstadoTotal>' + num$([F:DVPF]AMT*100) + '</ivaFavorEstadoTotal>' Using [VATF] # Campo 92. Total imposto a favor do Estado 2 + 6 + 4 + 11 + 17 + ... + 68
[L]DCLFLD = "091" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaFavorSujPassivoTotal>' + num$([F:DVPF]AMT*100) + '</ivaFavorSujPassivoTotal>' Using [VATF] # Total imposto a favor do sujeito passivo  20 + 21 + ...
[L]DCLFLD = "066" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaLiquidadoAnexoR1>' + num$([F:DVPF]AMT*100) + '</ivaLiquidadoAnexoR1>' Using [VATF] # Campo 66. Imposto liquidado  Neste campo deve inscrever o imposto liquidado correspondente
# ao
# valor inscrito no campo 64 do Anexo
[L]DCLFLD = "068" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaLiquidadoAnexoR2>' + num$([F:DVPF]AMT*100) + '</ivaLiquidadoAnexoR2>' Using [VATF] # Campo 68. Imposto liquidado  Neste campo deve inscrever o imposto liquidado correspondente
# ao
# valor inscrito no campo 64 do Anexo
[L]DCLFLD = "017" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaServicosUE>' + num$([F:DVPF]AMT*100) + '</ivaServicosUE>' Using [VATF] # Campo 17. Imposto a favor do Estado
[L]DCLFLD = "006" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaTaxaIntermedia>' + num$([F:DVPF]AMT*100) + '</ivaTaxaIntermedia>' Using [VATF] # Campo 6. Imposto a favor do Estado
[L]DCLFLD = "004" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaTaxaNormal>' + num$([F:DVPF]AMT*100) + '</ivaTaxaNormal>' Using [VATF] # Campo 4. Base tributável
[L]DCLFLD = "002" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaTaxaReduzida>' + num$([F:DVPF]AMT*100) + '</ivaTaxaReduzida>' Using [VATF] # Campo 2. Imposto a favor do Estado
[L]DCLFLD = "095" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<reembolso>' + num$([F:DVPF]AMT*100) + '</reembolso>' Using [VATF] # Campo 95. Solicito o reembolso  A opção 'Solicito o reembolso' veda a possibilidade de utilizar em declarações
# seguintes o respetivo valor como 'Excesso a reportar', salvo comunicação em contrário da
[L]DCLFLD = "041" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<regularizacoesFavorEstado>' + num$([F:DVPF]AMT*100) + '</regularizacoesFavorEstado>' Using [VATF] # Campo 41. Imposto a favor do Estado
TMPAMT41  = [F:DVPF]AMT
[L]DCLFLD = "081" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<regularizacoesFavorSujPassivoComunicadasCobranca>' + num$([F:DVPF]AMT*100) + '</regularizacoesFavorSujPassivoComunicadasCobranca>' Using [VATF] # Campo 81. A favor do sujeito
# passivo
[L]DCLFLD = "040" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<regularizacoesFavorSujPassivoNaoComunicadasCobranca>' + num$([F:DVPF]AMT*100) + '</regularizacoesFavorSujPassivoNaoComunicadasCobranca>' Using [VATF] # Campo 40. A favor do sujeito
# passivo
TMPAMT40  = [F:DVPF]AMT
Wrseq space$(4) + '</apuramento>' Using [VATF]
Wrseq space$(4) + '<desenvolvimento>' Using [VATF]
[L]DCLFLD = "103" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<bensServicosParaPessoalEmpresa>'+ num$([F:DVPF]AMT*100) + '</bensServicosParaPessoalEmpresa>' Using [VATF]
[L]DCLFLD = "102" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<inversaoSujPassivoConstrucaoCivil>'+ num$([F:DVPF]AMT*100)  + '</inversaoSujPassivoConstrucaoCivil>' Using [VATF]
[L]DCLFLD = "100" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<inversaoSujPassivoImoveisRenunciaIsencao>'+ num$([F:DVPF]AMT*100) + '</inversaoSujPassivoImoveisRenunciaIsencao>' Using [VATF]
[L]DCLFLD = "099" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<inversaoSujPassivoOuro>'+ num$([F:DVPF]AMT*100)  + '</inversaoSujPassivoOuro>' Using [VATF]
[L]DCLFLD = "101" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<inversaoSujPassivoSucatas>'+ num$([F:DVPF]AMT*100)  + '</inversaoSujPassivoSucatas>' Using [VATF]
[L]DCLFLD = "104" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<operacoesArtigo42>'+ num$([F:DVPF]AMT*100) + '</operacoesArtigo42>' Using [VATF]
[L]DCLFLD = "098" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<operacoesPTFeitasPorContribuintesForaUE>'+ num$([F:DVPF]AMT*100) + '</operacoesPTFeitasPorContribuintesForaUE>' Using [VATF]
[L]DCLFLD = "097" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<operacoesPTFeitasPorContribuintesUE>'+ num$([F:DVPF]AMT*100) + '</operacoesPTFeitasPorContribuintesUE>' Using [VATF]
[L]DCLFLD = "105" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<totalQuadro06A>'+ num$([F:DVPF]AMT*100)  + '</totalQuadro06A>' Using [VATF]
Wrseq space$(4) + '</desenvolvimento>' Using [VATF]
Wrseq space$(4) + '<inicio>' Using [VATF]
Wrseq space$(6) + '<anoDeclaracao>' + num$([F:DVPH]DCLYEA) + '</anoDeclaracao>' Using [VATF]
If [F:DVPH]FRECAP_UE : Wrseq space$(6) + '<apresentouDeclRecapitulativa>true</apresentouDeclRecapitulativa>' Using [VATF] :  Endif
Wrseq space$(6) + '<localizacaoSede>'+  num$([F:DVPP]HQRLOC) + '</localizacaoSede>' Using [VATF]
Wrseq space$(6) + '<nif>'+  format$("N0:09",ctrans([F:CPY]EECNUM,"PT","")) + '</nif>' Using [VATF]
Wrseq space$(6) + '<periodoDeclaracao>'+  [F:DVPH]FPERIOD  + '</periodoDeclaracao>' Using [VATF]
If [F:DVPH]ONTIMDCL = 2
  Wrseq space$(6) + '<prazo>1</prazo>' Using [VATF]              # On time (1)/Outdated(2)
Else
  Wrseq space$(6) + '<prazo>1</prazo>' Using [VATF]              # On time (1)/Outdated(2)
Endif
If [F:DVPH]FAN1OPE : Wrseq space$(6) + '<semOperacoes>false</semOperacoes>'               Using [VATF] :  Endif
#If [F:DVPH]FAN1OPE : Wrseq space$(6) + '<temAnexoRContinente>true</temAnexoRContinente>' Using [VATF] :  Endif
If [F:DVPH]FAN2OPE : Wrseq space$(6) + '<temAnexoRAcores>true</temAnexoRAcores>'         Using [VATF] :  Endif
If [F:DVPH]FAN3OPE : Wrseq space$(6) + '<temAnexoRMadeira>true</temAnexoRMadeira>'       Using [VATF] :  Endif
Wrseq space$(4) + '</inicio>' Using [VATF]
Wrseq space$(2) + '</rosto>' Using [VATF]

Return
######################################################################################
######################################################################################
$READ_FLD_VAL

Read [F:DVPF]DVPF0 = [F:DVPH]DCLNUM;[L]DCLPAG;[L]DCLFLD
If fstat : Raz [F:DVPF] : Endif

Return
######################################################################################
######################################################################################
$DEC_EXP_VARS

If !clalev([F:DVPH1]) : Local File DCLVATPORH [DVPH1] : Endif
If !clalev([F:DVPP])  : Local File DCLVATPORP [DVPP]  : Endif
If !clalev([F:CPY])   : Local File COMPANY    [CPY]   : Endif

Local Decimal  IVADEDUTIVELANEXOSRTOTAL
Local Decimal  IVADEDUTIVELTOTAL

Local Integer  DETRECCOUNT
Local Integer  DCLRECCOUNT
Local Integer  FILRECCOUNT
Local Integer  AN40RECCOUNT1
Local Integer  AN40RECCOUNT2
Local Integer  AN40RECCOUNT3
Local Integer  AN40RECCOUNT4
Local Integer  AN40RECCOUNT5
Local Integer  AN40RECCOUNT6
Local Integer  AN40RECCOUNT7
Local Integer  AN40RECCOUNT9
Local Integer  AN41RECCOUNT1
Local Integer  AN41RECCOUNT2
Local Integer  AN41RECCOUNT3
Local Integer  AN41RECCOUNT4
Local Integer  AN41RECCOUNT5
Local Integer  AN41RECCOUNT6
Local Integer  AN41RECCOUNT7
Local Integer  AN41RECCOUNT9

Local Char     ANXPER1NUM(20)
Local Char     ANXPER2NUM(20)
Local Char     ANXPER3NUM(20)
Local Char     ANXINUM(20)
Local Integer  MDCLYEA
Local Char     MFPERIOD(3)

Local Integer  DCLPAG
Local Integer  ANRLOC
Local Char     DCLFLD(3)
Local Char     SNSC(1)

Local Decimal  TMPAMT40
Local Decimal  TMPAMT41
Local Decimal  TMPTOTAN

Local Char     RECTYP40(2)
Local Char     RECTYP41(2)
Local Char     QUADRO40(2)
Local Char     QUADRO41(2)

Local Shortint AN1COUNT
Local Shortint AN2COUNT
Local Shortint AN3COUNT

Local Integer  I

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_R

#TODO os que são arredondados à unidade
Wrseq space$(2) + '<anexoR id="'+num$([L]ANRLOC)+'">' Using [VATF]
Wrseq space$(4) + '<apuramento>' Using [VATF]
[L]DCLFLD = "014" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btBensUEArtigo15>' + num$([F:DVPF]AMT*100) + '</btBensUEArtigo15>' Using [VATF]
[L]DCLFLD = "015" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btBensUEArtigo22>' + num$([F:DVPF]AMT*100) + '</btBensUEArtigo22>' Using [VATF]
[L]DCLFLD = "012" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btBensUELiquidadoDeclarante>' + num$([F:DVPF]AMT*100) + '</btBensUELiquidadoDeclarante>' Using [VATF]
[L]DCLFLD = "010" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btBensUETotal>' + num$([F:DVPF]AMT*100) + '</btBensUETotal>' Using [VATF]
[L]DCLFLD = "008" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btOperacoesIsentasComDeducao>' + num$([F:DVPF]AMT*100) + '</btOperacoesIsentasComDeducao>' Using [VATF]
[L]DCLFLD = "009" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btOperacoesIsentasSemDeducao>' + num$([F:DVPF]AMT*100) + '</btOperacoesIsentasSemDeducao>' Using [VATF]
[L]DCLFLD = "016" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btServicosUE>' + num$([F:DVPF]AMT*100) + '</btServicosUE>' Using [VATF]
[L]DCLFLD = "005" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btTaxaIntermedia>' + num$([F:DVPF]AMT*100) + '</btTaxaIntermedia>' Using [VATF]
[L]DCLFLD = "003" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btTaxaNormal>' + num$([F:DVPF]AMT*100) + '</btTaxaNormal>' Using [VATF]
[L]DCLFLD = "001" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btTaxaReduzida>' + num$([F:DVPF]AMT*100) + '</btTaxaReduzida>' Using [VATF]
[L]DCLFLD = "062" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btTotal>' + num$([F:DVPF]AMT*100) + '</btTotal>' Using [VATF]
[L]DCLFLD = "007" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<btTransmissoesUEIsentas>' + num$([F:DVPF]AMT*100) + '</btTransmissoesUEIsentas>' Using [VATF]
[L]DCLFLD = "013" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaBensUELiquidadoDeclarante>' + num$([F:DVPF]AMT*100) + '</ivaBensUELiquidadoDeclarante>' Using [VATF]
[L]DCLFLD = "013" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaBensUETotal>' + num$([F:DVPF]AMT*100) + '</ivaBensUETotal>' Using [VATF]
[L]DCLFLD = "023" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaDedutivelExistenciasTaxaIntermedia>' + num$([F:DVPF]AMT*100) + '</ivaDedutivelExistenciasTaxaIntermedia>' Using [VATF]
[L]DCLFLD = "022" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaDedutivelExistenciasTaxaNormal>' + num$([F:DVPF]AMT*100) + '</ivaDedutivelExistenciasTaxaNormal>' Using [VATF]
[L]DCLFLD = "021" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaDedutivelExistenciasTaxaReduzida>' + num$([F:DVPF]AMT*100) + '</ivaDedutivelExistenciasTaxaReduzida>' Using [VATF]
[L]DCLFLD = "020" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaDedutivelImobilizado>' + num$([F:DVPF]AMT*100) + '</ivaDedutivelImobilizado>' Using [VATF]
[L]DCLFLD = "024" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaDedutivelOutros>' + num$([F:DVPF]AMT*100) + '</ivaDedutivelOutros>' Using [VATF]
[L]DCLFLD = "064" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaFavorEstadoTotal>' + num$([F:DVPF]AMT*100) + '</ivaFavorEstadoTotal>' Using [VATF]
[L]DCLFLD = "063" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaFavorSujPassivoTotal>' + num$([F:DVPF]AMT*100) + '</ivaFavorSujPassivoTotal>' Using [VATF]
[L]DCLFLD = "017" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaServicosUE>' + num$([F:DVPF]AMT*100) + '</ivaServicosUE>' Using [VATF]
[L]DCLFLD = "006" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaTaxaIntermedia>' + num$([F:DVPF]AMT*100) + '</ivaTaxaIntermedia>' Using [VATF]
[L]DCLFLD = "004" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaTaxaNormal>' + num$([F:DVPF]AMT*100) + '</ivaTaxaNormal>' Using [VATF]
[L]DCLFLD = "002" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<ivaTaxaReduzida>' + num$([F:DVPF]AMT*100) + '</ivaTaxaReduzida>' Using [VATF]
#TODO Wrseq space$(6) + '<temOperacoesAdquirenteComLiqImposto>10</temOperacoesAdquirenteComLiqImposto>' Using [VATF]
Wrseq space$(4) + '</apuramento>' Using [VATF]

Wrseq space$(4) + '<desenvolvimento>' Using [VATF]
[L]DCLFLD = "071" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<bensServicosParaPessoalEmpresa>'+num$([F:DVPF]AMT*100)+'</bensServicosParaPessoalEmpresa>' Using [VATF]
[L]DCLFLD = "070" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<inversaoSujPassivoConstrucaoCivil>'+num$([F:DVPF]AMT*100)+'</inversaoSujPassivoConstrucaoCivil>' Using [VATF]
[L]DCLFLD = "068" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<inversaoSujPassivoImoveisRenunciaIsencao>'+num$([F:DVPF]AMT*100)+'</inversaoSujPassivoImoveisRenunciaIsencao>' Using [VATF]
[L]DCLFLD = "067" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<inversaoSujPassivoOuro>'+num$([F:DVPF]AMT*100)+'</inversaoSujPassivoOuro>' Using [VATF]
[L]DCLFLD = "069" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<inversaoSujPassivoSucatas>'+num$([F:DVPF]AMT*100)+'</inversaoSujPassivoSucatas>' Using [VATF]
[L]DCLFLD = "072" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<operacoesArtigo42>'+num$([F:DVPF]AMT*100)+'</operacoesArtigo42>' Using [VATF]
[L]DCLFLD = "066" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<operacoesPTFeitasPorContribuintesForaUE>'+num$([F:DVPF]AMT*100)+'</operacoesPTFeitasPorContribuintesForaUE>' Using [VATF]
[L]DCLFLD = "065" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<operacoesPTFeitasPorContribuintesUE>'+num$([F:DVPF]AMT*100)+'</operacoesPTFeitasPorContribuintesUE>' Using [VATF]
[L]DCLFLD = "073" : Gosub READ_FLD_VAL
Wrseq space$(6) + '<totalQuadro06A>'+num$([F:DVPF]AMT*100)+'</totalQuadro06A>' Using [VATF]
Wrseq space$(4) + '</desenvolvimento>' Using [VATF]
Wrseq space$(2) + '</anexoR>' Using [VATF]

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_I

Wrseq space$(2)  + '<anexoI>' Using [VATF]
Wrseq space$(4)  + '<transIntracomun>' Using [VATF]
#Wrseq space$(6)  + '<btIsentasUETotal>' +  + '</btIsentasUETotal>' Using [VATF]
Wrseq space$(6)  + '<linhasNaoCompreendidasNoTipo4Total>' + num$([F:XI2]ZVALOR(71)*100) + '</linhasNaoCompreendidasNoTipo4Total>' Using [VATF]
#Wrseq space$(6)  + '<linhasTotal>' +  + '</linhasTotal>' Using [VATF]
Wrseq space$(6)  + '<transmissoesUE>' Using [VATF]

For [F:DVPL] Where DCLNUM = [F:DVPH]DCLNUM & LINTYP = 11
  Wrseq space$(8)  + '<transmissoesUEItem>' Using [VATF]
  If [F:DVPL]CRY <> "" & pat([F:DVPL]EECNUM,[F:DVPL]CRY+"*")
    Wrseq space$(10) + '<nifAdquirente>' + right$([F:DVPL]EECNUM,len([F:DVPL]CRY)+1) + '</nifAdquirente>'             ; Using [VATF]              # NIF do Terceiro
  Else
    Wrseq space$(10) + '<nifAdquirente>' + [F:DVPL]EECNUM + '</nifAdquirente>'             ; Using [VATF]              # NIF do Terceiro
  Endif

  If [F:DVPL]CRY = "GR"
    Wrseq space$(10) + '<paisDestino>EL</paisDestino>' Using [VATF]
  Else
    Wrseq space$(10) + '<paisDestino>' + [F:DVPL]CRY + '</paisDestino>' Using [VATF]
  Endif
  Wrseq space$(10) + '<tipoOperacao>' + num$([F:DVPL]OPETYP) + '</tipoOperacao>' Using [VATF]
  Wrseq space$(10) + '<valorEuros>' + num$([F:DVPL]AMTBAS*100) + '</valorEuros>' Using [VATF]
  Wrseq space$(8)  + '</transmissoesUEItem>' Using [VATF]
Next

Wrseq space$(6)  + '</transmissoesUE>' Using [VATF]
Wrseq space$(6)  + '<vendasMeiosTransporteAParticularesUETotal>' + num$([F:XI2]ZVALOR(70)*100) + '</vendasMeiosTransporteAParticularesUETotal>' Using [VATF]
Wrseq space$(4)  + '</transIntracomun>' Using [VATF]
Wrseq space$(2)  + '</anexoI>' Using [VATF]

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_1

Wrseq space$(2)  + '<clientes id="' + right$(num$([F:DVPH]DCLYEA),3) + [F:DVPH]FPERIOD + '">' Using [VATF]
Wrseq space$(4)  + '<relacao>' Using [VATF]
Wrseq space$(6)  + '<anoDeducao>' + num$([F:DVPH]DCLYEA) + '</anoDeducao>' Using [VATF]

# Operações Efectuadas com Clientes de Exportação
Wrseq space$(6)  + '<exportacaoBens>' Using [VATF]
TYP_ANEXO_INFO = 2
For [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP = 2
  Wrseq space$(8)  + '<exportacaoBensItem>' Using [VATF]
  Wrseq space$(10) + '<numeroDeclaracaoExportacao>' + [F:DVPL]VCRNUM + '</numeroDeclaracaoExportacao>' Using [VATF]
  Wrseq space$(10) + '<valorEuros>' + num$([F:DVPL]AMTBAS*100) + '</valorEuros>' Using [VATF]
  Wrseq space$(8)  + '</exportacaoBensItem>' Using [VATF]
Next
Wrseq space$(6)  + '</exportacaoBens>' Using [VATF]

# Operações Efectuadas com Clientes Nacionais
Wrseq space$(6)  + '<operacoesClientesNacionais>' Using [VATF]
For [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP = 1
  Wrseq space$(8)  + '<operacoesClientesNacionaisItem>' Using [VATF]
  Wrseq space$(10) + '<nifCliente>' + ctrans([F:DVPL]EECNUM,"PT","") + '</nifCliente>' Using [VATF]
  Wrseq space$(10) + '<valorEuros>' + num$([F:DVPL]AMTBAS*100) + '</valorEuros>' Using [VATF]
  Wrseq space$(8)  + '</operacoesClientesNacionaisItem>' Using [VATF]
Next
Wrseq space$(6)  + '</operacoesClientesNacionais>' Using [VATF]

Wrseq space$(6)  + '<operacoesClientesNacionaisMenores5000Euros>' + num$([F:DVPH]FLDAN102*100) + '</operacoesClientesNacionaisMenores5000Euros>' Using [VATF]
Wrseq space$(6)  + '<operacoesNoEstrangeiro>' + num$([F:DVPH]FLDAN104*100) + '</operacoesNoEstrangeiro>' Using [VATF]
Wrseq space$(6)  + '<outrasOperacoesIsentasComDireitoDeducao>' + num$([F:DVPH]FLDAN105*100) + '</outrasOperacoesIsentasComDireitoDeducao>' Using [VATF]
Wrseq space$(6)  + '<periodoDeducao>' + [F:DVPH]FPERIOD + '</periodoDeducao>' Using [VATF]
Wrseq space$(6)  + '<total>' + num$([F:DVPH]FLDAN106*100) + '</total>' Using [VATF]
Wrseq space$(4)  + '</relacao>' Using [VATF]
Wrseq space$(2)  + '</clientes>' Using [VATF]

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_2

Wrseq space$(2)  + '<fornecedores id="' + right$(num$([F:DVPH]DCLYEA),3) + [F:DVPH]FPERIOD + '">' Using [VATF]
Wrseq space$(4)  + '<relacao>' Using [VATF]
Wrseq space$(6)  + '<anoDeducao>' + num$([F:DVPH]DCLYEA) + '</anoDeducao>' Using [VATF]
Wrseq space$(6)  + '<btAquisicoesMenores5000Euros>' + num$([F:DVPH]FLDAN206B*100) + '</btAquisicoesMenores5000Euros>' Using [VATF]
#Wrseq space$(6)  + '<btAquisicoesTotal>' + num$([F:YY2]ZTOTBASE*100) + '</btAquisicoesTotal>' Using [VATF]

For TYP_ANEXO_INFO = 20 To 24
  Wrseq space$(6)  + '<campo'+num$(TYP_ANEXO_INFO)+'>' Using [VATF]

  For [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP=TYP_ANEXO_INFO-17 & ([F:DVPL]AMTBAS<>0 | [F:DVPL]AMTVAT<>0)

    Wrseq space$(8)  + '<campo'+num$(TYP_ANEXO_INFO)+'Item>' Using [VATF]
    Wrseq space$(10) + '<anoEmissao>' + num$([F:DVPL]YEA) + '</anoEmissao>' Using [VATF]
    Wrseq space$(10) + '<btAquisicoes>' + num$([F:DVPL]AMTBAS*100) + '</btAquisicoes>' Using [VATF]
    Wrseq space$(10) + '<ivaAquisicoes>' + num$([F:DVPL]AMTVAT*100) + '</ivaAquisicoes>' Using [VATF]
    Wrseq space$(10) + '<mesEmissao>' + num$([F:DVPL]MON) + '</mesEmissao>' Using [VATF]
    If [F:DVPL]VCRNUM <> ""
      Wrseq space$(10) + '<numeroLiquidacao>' + [F:DVPL]VCRNUM + '</numeroLiquidacao>' Using [VATF]
    Else
      If ([F:DVPL]CRY <> "" & pat([F:DVPL]EECNUM,[F:DVPL]CRY+"*")) | [F:DVPL]CRY = "RC"
        Wrseq space$(10) + '<nif>' + format$("K:12X",right$([F:DVPL]EECNUM,len([F:DVPL]CRY)+1)) + '</nif>'  ; Using [VATF]              # NIF do Terceiro
      Else
        Wrseq space$(10) + '<nif>' + [F:DVPL]EECNUM+ '</nif>'        ; Using [VATF]              # NIF do Terceiro
      Endif
      If [F:DVPL]CRY = "GR"
        Wrseq space$(10) + '<prefixoNIF>EL</prefixoNIF>' Using [VATF]
      Else
        Wrseq space$(10) + '<prefixoNIF>' + [F:DVPL]CRY + '</prefixoNIF>' Using [VATF]
      Endif
    Endif
    Wrseq space$(8)  + '</campo'+num$(TYP_ANEXO_INFO)+'Item>' Using [VATF]
  Next

    Wrseq space$(8)  + '</campo'+num$(TYP_ANEXO_INFO)+'>' Using [VATF]
Next

Wrseq space$(6)  + '<ivaAquisicoesMenores5000Euros>' + num$([F:DVPH]FLDAN206V*100) + '</ivaAquisicoesMenores5000Euros>' Using [VATF]
Wrseq space$(6)  + '<ivaAquisicoesTotal>' + num$([F:DVPH]FLDAN207V*100) + '</ivaAquisicoesTotal>' Using [VATF]
Wrseq space$(6)  + '<periodoDeducao>' + [F:DVPH]FPERIOD + '</periodoDeducao>' Using [VATF]
Wrseq space$(4)  + '</relacao>' Using [VATF]
Wrseq space$(2)  + '</fornecedores>' Using [VATF]

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_3

Wrseq space$(2)  + '<regularizacoes id="' + right$(num$([F:DVPH]DCLYEA),3) + [F:DVPH]FPERIOD + '">' Using [VATF]
Wrseq space$(4)  + '<relacao>' Using [VATF]
Wrseq space$(6)  + '<anoRegularizacoes>' + num$([F:DVPH]DCLYEA) + '</anoRegularizacoes>' Using [VATF]
Wrseq space$(6)  + '<btOutrasRegularizacoes>' + num$([F:DVPH]FLDAN306*100) + '</btOutrasRegularizacoes>' Using [VATF]
Wrseq space$(6)  + '<btRegularizacoesAlteracaoProRata>' + num$([F:DVPH]FLDAN304*100) + '</btRegularizacoesAlteracaoProRata>' Using [VATF]
Wrseq space$(6)  + '<btRegularizacoesMenores100Euros>' + num$([F:DVPH]FLDAN302*100) + '</btRegularizacoesMenores100Euros>' Using [VATF]
Wrseq space$(6)  + '<btRegularizacoesTotal>' + num$([F:DVPH]FLDAN308*100) + '</btRegularizacoesTotal>' Using [VATF]
Wrseq space$(6)  + '<ivaOutrasRegularizacoes>' + num$([F:DVPH]FLDAN307*100) + '</ivaOutrasRegularizacoes>' Using [VATF]
Wrseq space$(6)  + '<ivaRegularizacoesAlteracaoProRata>' + num$([F:DVPH]FLDAN305*100) + '</ivaRegularizacoesAlteracaoProRata>' Using [VATF]
Wrseq space$(6)  + '<ivaRegularizacoesMenores100Euros>' + num$([F:DVPH]FLDAN303*100) + '</ivaRegularizacoesMenores100Euros>' Using [VATF]
Wrseq space$(6)  + '<ivaRegularizacoesTotal>' + num$([F:DVPH]FLDAN309*100) + '</ivaRegularizacoesTotal>' Using [VATF]
Wrseq space$(6)  + '<operacoesSujPassivosNacionais>' Using [VATF]

For [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP = 8 & ([F:DVPL]AMTVAT <> 0 | [F:DVPL]AMTBAS <> 0)

  Wrseq space$(8)  + '<operacoesSujPassivosNacionaisItem>' Using [VATF]
  Wrseq space$(10) + '<anoEmissao>' + num$([F:DVPL]YEA) + '</anoEmissao>' Using [VATF]
  Wrseq space$(10) + '<btRegularizacao>' + num$([F:DVPL]AMTBAS*100) + '</btRegularizacao>' Using [VATF]
  Wrseq space$(10) + '<ivaRegularizado>' + num$([F:DVPL]AMTVAT*100) + '</ivaRegularizado>' Using [VATF]
  Wrseq space$(10) + '<mesEmissao>' + num$([F:DVPL]MON) + '</mesEmissao>' Using [VATF]
  Wrseq space$(10) + '<nif>' + ctrans([F:DVPL]EECNUM,"PT","") + '</nif>' Using [VATF]
  Wrseq space$(8)  + '</operacoesSujPassivosNacionaisItem>' Using [VATF]

Next

Wrseq space$(6)  + '</operacoesSujPassivosNacionais>' Using [VATF]
Wrseq space$(6)  + '<periodoRegularizacoes>' + [F:DVPH]FPERIOD + '</periodoRegularizacoes>' Using [VATF]
Wrseq space$(4)  + '</relacao>' Using [VATF]
Wrseq space$(2)  + '</regularizacoes>' Using [VATF]

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_40

Wrseq space$(2)  + '<anexoCampo40R>' Using [VATF]
Wrseq space$(4)  + '<regularizacoes>' Using [VATF]
Wrseq space$(6)  + '<btOutrasRegularizacoes>' + num$([F:DVPH]FLDAN4003B*100) + '</btOutrasRegularizacoes>' Using [VATF]
Wrseq space$(6)  + '<btRegularizacoesArt23A26>' + num$([F:DVPH]FLDAN4003A*100) + '</btRegularizacoesArt23A26>' Using [VATF]
Wrseq space$(6)  + '<btRegularizacoesCreditoNaoSuperior750Euros>' + num$([F:DVPH]FLDAN4003*100) + '</btRegularizacoesCreditoNaoSuperior750Euros>' Using [VATF]
Wrseq space$(6)  + '<campo40Total>' + num$([L]TMPAMT40*100) + '</campo40Total>' Using [VATF]
Wrseq space$(6)  + '<certificacoesROC/>' Using [VATF]
Wrseq space$(6)  + '<ivaOutrasRegularizacoes>' + num$([F:DVPH]FLDAN4004B*100) + '</ivaOutrasRegularizacoes>' Using [VATF]
Wrseq space$(6)  + '<ivaRegularizadoArt23A26>' + num$([F:DVPH]FLDAN4004A*100) + '</ivaRegularizadoArt23A26>' Using [VATF]
Wrseq space$(6)  + '<ivaRegularizadoCreditoNaoSuperior750Euros>' + num$([F:DVPH]FLDAN4004*100) + '</ivaRegularizadoCreditoNaoSuperior750Euros>' Using [VATF]

For QUADRO_ANEXO_FILTRO = "1F","1E","1G","1A","1B","1C","1D"

  Case QUADRO_ANEXO_FILTRO
    When "1A" : QUADRO_ANEXO_NOME = 'Num2E3E6'
    When "1B" : QUADRO_ANEXO_NOME = 'Num7Antes2013'
    When "1C" : QUADRO_ANEXO_NOME = 'Num7Em2013EDepois'
    When "1D" : QUADRO_ANEXO_NOME = 'Num8BCDE'
    When "1E" : QUADRO_ANEXO_NOME = '78ANum4'
    When "1F" : QUADRO_ANEXO_NOME = '78ANum2A'
    When "1G" : QUADRO_ANEXO_NOME = '78BNum4'
  Endcase

  Wrseq space$(6)  + '<lista' + QUADRO_ANEXO_NOME + '>' Using [VATF]

  For [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP = 9 & left$([F:DVPL]FLD41REN,2) = QUADRO_ANEXO_FILTRO & ([F:DVPL]AMTVAT <> 0 | [F:DVPL]AMTBAS <> 0)
    Wrseq space$(8)  + '<lista' + QUADRO_ANEXO_NOME + 'Item>' Using [VATF]
    Wrseq space$(10) + '<artigo>' + func GET_COD40([F:DVPL]FLD40REN) + '</artigo>' Using [VATF]

    If find(QUADRO_ANEXO_FILTRO,"1A","1B","1C","1D","1E")
      Wrseq space$(10) + '<btRegularizacoes>' + num$([F:DVPL]AMTBAS*100) + '</btRegularizacoes>' Using [VATF]
      Wrseq space$(10) + '<ivaRegularizado>' + num$([F:DVPL]AMTVAT*100) + '</ivaRegularizado>' Using [VATF]
      If pat([F:DVPL]EECNUM,"PT*")
        Wrseq space$(10) + '<nif>' + right$([F:DVPL]EECNUM,3)   + '</nif>' Using [VATF]         # EECNUM
      Else
        Wrseq space$(10) + '<nif>' + [F:DVPL]EECNUM   + '</nif>'  Using [VATF]         # EECNUM
      Endif
    Else
      Wrseq space$(10) + '<ivaRegularizado>' + num$([F:DVPL]AMTVAT*100) + '</ivaRegularizado>' Using [VATF]
      Wrseq space$(10) + '<numeroPedidoPrevio></numeroPedidoPrevio>' Using [VATF]
    Endif

    Wrseq space$(8)  + '</lista' + QUADRO_ANEXO_NOME + 'Item>' Using [VATF]
  Next

Wrseq space$(6)  + '</lista' + QUADRO_ANEXO_NOME + '>' Using [VATF]
Next

Wrseq space$(4)  + '</regularizacoes>' Using [VATF]
Wrseq space$(2)  + '</anexoCampo40R>' Using [VATF]

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_41

Wrseq space$(2)  + '<anexoCampo41R>' Using [VATF]
Wrseq space$(4)  + '<regularizacoes>' Using [VATF]
Wrseq space$(6)  + '<btOutrasRegularizacoes>' + num$([F:DVPH]FLDAN4103B*100)  + '</btOutrasRegularizacoes>' Using [VATF]
Wrseq space$(6)  + '<btRegularizacoesArt23A26>' + num$([F:DVPH]FLDAN4103A*100)  + '</btRegularizacoesArt23A26>' Using [VATF]
Wrseq space$(6)  + '<campo41Total>' + num$([L]TMPAMT41*100) + '</campo41Total>' Using [VATF]
Wrseq space$(6)  + '<ivaOutrasRegularizacoes>' + num$([F:DVPH]FLDAN4104B*100)  + '</ivaOutrasRegularizacoes>' Using [VATF]
Wrseq space$(6)  + '<ivaRegularizadoArt23A26>' + num$([F:DVPH]FLDAN4104A*100) + '</ivaRegularizadoArt23A26>' Using [VATF]

For QUADRO_ANEXO_FILTRO = "1E","1F","1D","1A","1B","1C"

  Case QUADRO_ANEXO_FILTRO
    When "1A" : QUADRO_ANEXO_NOME = 'Num3E4E6'
    When "1B" : QUADRO_ANEXO_NOME = 'Num7'
    When "1C" : QUADRO_ANEXO_NOME = 'Num8D'
    When "1D" : QUADRO_ANEXO_NOME = 'Num12'
    When "1E" : QUADRO_ANEXO_NOME = '78CNum1'
    When "1F" : QUADRO_ANEXO_NOME = '78CNum3'
  Endcase

  Wrseq space$(6)  + '<lista' + QUADRO_ANEXO_NOME + '>' Using [VATF]

  For [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP = 10 & left$([F:DVPL]FLD41REN,2) = QUADRO_ANEXO_FILTRO & ([F:DVPL]AMTVAT <> 0 | [F:DVPL]AMTBAS <> 0)
    Wrseq space$(8)  + '<lista' + QUADRO_ANEXO_NOME + 'Item>' Using [VATF]

    If find(QUADRO_ANEXO_FILTRO,"1A","1B","1C","1D")
      Wrseq space$(10) + '<artigo>' + func GET_COD41([F:DVPL]FLD41REN) + '</artigo>' Using [VATF]
      Wrseq space$(10) + '<btRegularizacoes>' + num$([F:DVPL]AMTBAS*100) + '</btRegularizacoes>' Using [VATF]
      Wrseq space$(10) + '<ivaRegularizado>' + num$([F:DVPL]AMTVAT*100) + '</ivaRegularizado>' Using [VATF]
      If pat([F:DVPL]EECNUM,"PT*")
        Wrseq space$(10) + '<nif>' + right$([F:DVPL]EECNUM,3) + '</nif>' Using [VATF]
      Else
        Wrseq space$(10) + '<nif>' + [F:DVPL]EECNUM + '</nif>' Using [VATF]
      Endif
    Elsif find(QUADRO_ANEXO_FILTRO,"1E")
      Wrseq space$(10) + '<artigo>' + func GET_COD41([F:DVPL]FLD41REN) + '</artigo>' Using [VATF]
      Wrseq space$(10) + '<ivaRegularizado>' + num$([F:DVPL]AMTVAT*100) + '</ivaRegularizado>' Using [VATF]
      Wrseq space$(10) + '<nif>' + [F:DVPL]EECNUM + '</nif>' Using [VATF]
      Wrseq space$(10) + '<numeroPedidoPrevio></numeroPedidoPrevio>' Using [VATF]
    Elsif find(QUADRO_ANEXO_FILTRO,"1F")
      Wrseq space$(10) + '<btRegularizacoes>' + num$([F:DVPL]AMTBAS*100) + '</btRegularizacoes>' Using [VATF]
      Wrseq space$(10) + '<ivaRegularizado>' + num$([F:DVPL]AMTVAT*100) + '</ivaRegularizado>' Using [VATF]
      Wrseq space$(10) + '<nif>' + [F:DVPL]EECNUM + '</nif>' Using [VATF]
      Wrseq space$(10) + '<numeroPedidoPrevio></numeroPedidoPrevio>' Using [VATF]
    Endif

    Wrseq space$(8)  + '</lista' + QUADRO_ANEXO_NOME + 'Item>' Using [VATF]
  Next

  Wrseq space$(6)  + '</lista' + QUADRO_ANEXO_NOME + '>' Using [VATF]
Next

Wrseq space$(4)  + '</regularizacoes>' Using [VATF]
Wrseq space$(2)  + '</anexoCampo41R>' Using [VATF]

Return
#############################################################################################
#############################################################################################
Funprog GET_COD40(MOTIV)
Value Char MOTIV

Local Char RET(2)

Case MOTIV
  When "1A1"
    RET = "01"
  When "1A2"
    RET = "02"
  When "1A3"
    RET = "04"
  When "1B1", "1C1"
    RET = "05"
  When "1B2", "1C2"
    RET = "06"
  When "1B3", "1C3"
    RET = "07"
  When "1B4", "1C4"
    RET = "08"
  When "1D1"
    RET = "11"
  When "1D2"
    RET = "09"
  When "1D3"
    RET = "10"
  When "1D4"
    RET = "12"
  When "1E1"
    RET = "15"
  When "1E2"
    RET = "16"
  When "1E3"
    RET = "17"
  When "1E4"
    RET = "18"
  When "1F"
    RET = "14"
  When "1G"
    RET = "19"
Endcase

End RET
