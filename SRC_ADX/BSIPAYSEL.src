#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################################
# Project       : Bank statement import (MT940)
# File          : BSIPAYSEL
# Version       : 1.0
# Authors       : U. Bader
# Creation Date : 2017-05-08
######################################################################################################
# Module        : Finance
# Description   : Zoom to payments for a bank statement transaction (build selection list)
######################################################################################################
# Updates       :
# Date          | Author | Version | Description
######################################################################################################

$ACTION
Case GACTION
 When "BSIPAYSEL"
  Case ACTION
   When "SEL_TABLE" : Gosub SEL_LISTE
  Endcase
 When Default
Endcase
Return


#################################################
$SEL_LISTE
Onerrgo ERREUR From CONTROLE
If clalev([F:PAY])=0 : Local File PAYMENTH   [PAY]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : Return : Endif

Local Integer MAXLIN, NBTEX1 : MAXLIN=100   :# GB 03/05/01  Ne pas utiliser NBTEX pour le web
Local Char    TEX1(GLONVCR)(1..MAXLIN), TEX2(GLONBPR)(1..MAXLIN), TEX3(GLONGAC)(1..MAXLIN)

Filter [F:PAY] Where BSITRS=PARAM(1)+"/"+num$(PARAM(2)) Order By NUM Asc
For [F:PAY]
   If NBTEX1=MAXLIN : Break : Endif
   NBTEX1 += 1
   TEX1(NBTEX1) = [F:PAY]NUM
   TEX2(NBTEX1) = [F:PAY]BPR
   TEX3(NBTEX1) = [F:PAY]ACC
Next # [F:PAY]
Filter [F:PAY]

If NBTEX1
 If clalev([F:ZZZ]) : Close Local File [ZZZ] : Endif

 ORDRE  = "AA"
 Local File (Char AA(GLONVCR), Char BB(GLONBPR), Char CC(GLONGAC))
&      From Variable TEX1(1..NBTEX1), TEX2(1..NBTEX1), TEX3(1..NBTEX1)
& As [ZZZ] Order With ORDRE
 COL(1)="AA"
 COL(2)="BB"
 COL(3)="CC"
 NBCOL = 3
 TIT(1) = mess(8,172,1)   # Payment
 TIT(2) = mess(209,154,1) # BP
 TIT(3) = mess(180,108,1) # Account
 Call TITOBJ("PAY","!",TIT) From CONTOBJ
Else  : # Nothing found
 OK=0
Endif
Return


#################################################
$AVANT_SUITE
If VALBOUT <> ""
    [L]VALC1="PAY" : [L]VALC2=left$(VALBOUT,I-1) : [L]VALC3=""
    GCONSULT=1
Endif
Return

