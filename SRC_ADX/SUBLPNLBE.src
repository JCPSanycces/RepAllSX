#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque LPNLBEx

########################################################################
# Impression des étiquettes contenant                                  #
# -------------------------------------------------------------------- #
# Fenêtre : ILPNLBE1                                                   #
# Traitement de l'action : STKLPNLBE                                   #
# -------------------------------------------------------------------- #
########################################################################

$ACTION
Case ACTION
 When "DEBUT"   : Gosub DEBUT   From SUBLPNLBEA
 When "OUVRE"   : Gosub OUVRE   From SUBLPNLBEA
 When "SETBOUT" : Gosub SETBOUT From SUBLPNLBEA
 When "BOUTON"  : Gosub BOUTON  From SUBLPNLBEA
 When Default
Endcase
Return

######################################################################################
## Action écran LPNLBE1
######################################################################################

Subprog IB_NBLIG
GBOUT4 = mess(2,1,1) : # Oui
GBOUT5 = mess(1,1,1) : # Non
End

Subprog B4_NBLIG
Local Integer I
For I=1 To [M:LPB1]NBLIG
    [M:LPB1]TRT(I-1) = 2
Next I
Affzo [M:LPB1]TRT
End

Subprog B5_NBLIG
Local Integer I
For I=1 To [M:LPB1]NBLIG
    [M:LPB1]TRT(I-1) = 1
Next I
Affzo [M:LPB1]TRT
End


Subprog C_LBEFMT(VALEUR)
Variable Char    VALEUR()
Local Integer STAT
Call CONT_RPTCOD(VALEUR,GMESSAGE,STAT) From AIMP1

End

Subprog AM_LBEFMT(VALEUR)
Variable Char    VALEUR()
Local Char TBPAR(15)(1..50),TBVAL(30)(1..50)
Local Char LPRT(GLONAIM)
# Recherche de l'imprimante par défaut
Call AIMDEF(LPRT,VALEUR,TBPAR,TBVAL) From IMPRIME
[M:LPB1]LBEFMT(nolign-1)=VALEUR
If LPRT<>""
    [M:LPB1]PRT(nolign-1) = LPRT
Endif
Call C_PRT([M:LPB1]PRT(nolign-1))
If mkstat
   Raz GMESSAGE, GERR, mkstat
   Raz [M:LPB1]PRT(nolign-1)
Elsif  [M:LPB1]PRT(nolign-1)<>""
       Diszo [M:LPB1]SERIMP(nolign-1), DEFIMP(nolign-1)
Endif
Affzo [M:LPB1]PRT(nolign-1), SERIMP(nolign-1), DEFIMP(nolign-1)
End

Subprog B2_LBEFMT(VALEUR)
Variable Char    VALEUR()
Local Integer I
Call C_LBEFMT(VALEUR)
If !mkstat
   For I=nolign To [M:LPB1]NBLIG-1
       If [M:LPB1]TRT   (I) = 2
          [M:LPB1]LBEFMT(I) = VALEUR
          [M:LPB1]PRT   (I) = [M:LPB1]PRT(nolign-1)
       Endif
   Next
   Affzo [M:LPB1]LBEFMT,PRT
Endif
End

Subprog C_PRT(VALEUR)
Variable Char VALEUR()
If VALEUR<>""
    Call AIMCONT(VALEUR,[M:LPB1]LBEFMT(nolign-1),GBATCH) From IMPRIME
    If mkstat
        Raz [M:LPB1]SERIMP(nolign-1), DEFIMP(nolign-1)
        End
    Endif
    [M:LPB1]SERIMP(nolign-1)    = [F:AIM]PRTSRV
    [M:LPB1]DEFIMP(nolign-1)    = [F:AIM]PRTNAM
Else
    Raz [M:LPB1]SERIMP(nolign-1), [M:LPB1]DEFIMP(nolign-1)
Endif
End

Subprog AM_PRT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    Diszo [M:LPB1]SERIMP(nolign-1), DEFIMP(nolign-1)
Else
    Actzo [M:LPB1]SERIMP(nolign-1), DEFIMP(nolign-1)
Endif
End

Subprog AM_TCTRNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M:LPB0]TCTRNUMEND=[M:LPB0]TCTRNUMSTR | [M:LPB0]TCTRNUMEND<VALEUR
   [M:LPB0]TCTRNUMEND = VALEUR
   Affzo [M:LPB0]TCTRNUMEND
Endif
End

Subprog C_TCTRNUMEND(VALEUR)
Variable Char    VALEUR()
If [M:LPB0]TCTRNUMSTR>VALEUR
   GMESSAGE = mess(44,199,1)
   mkstat=2
Endif
If VALEUR = ""
   VALEUR = [M:LPB0]TCTRNUMSTR
Endif
End

Subprog AM_LPNNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M:LPB0]LPNNUMEND=[M:LPB0]LPNNUMSTR | [M:LPB0]LPNNUMEND<VALEUR
   [M:LPB0]LPNNUMEND = VALEUR
   Affzo [M:LPB0]LPNNUMEND
Endif
End

Subprog C_LPNNUMEND(VALEUR)
Variable Char    VALEUR()
If [M:LPB0]LPNNUMSTR>VALEUR
   GMESSAGE = mess(44,199,1)
   mkstat=2
Endif
If VALEUR = ""
   VALEUR = [M:LPB0]LPNNUMSTR
Endif
End

Subprog AM_LOCSTR(VALEUR)
Variable Char    VALEUR()
If [M:LPB0]LOCEND=[M:LPB0]LOCSTR | [M:LPB0]LOCEND<VALEUR
   [M:LPB0]LOCEND = VALEUR
   Affzo [M:LPB0]LOCEND
Endif
End

Subprog C_LOCEND(VALEUR)
Variable Char    VALEUR()
If [M:LPB0]LOCSTR>VALEUR
   GMESSAGE = mess(44,199,1)
   mkstat=2
Endif
If VALEUR = ""
   VALEUR = [M:LPB0]LOCSTR
Endif
End

