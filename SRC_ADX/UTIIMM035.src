#<AdxTL>@(#)2.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : CBO
# LE          : 13 Juin      2012 15:29:26
# Moulinette pour Passer KNBMSTPDEP et KSTPDEPSTA de FXDASSETS à DEPREC
# FQ80825
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM035: maj deprec via fxdassets") From LECFIC
  Call EXE_UTIIMM035(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIIMM035(APPLI)
 Value Char APPLI
  If clalev([F:CPY]) : Close Local File [CPY] : Endif
  Local File =APPLI+".COMPANY" [CPY]
  If clalev([F:CNX]) : Close Local File [CNX] : Endif
  Local File =APPLI+".CONTEXT" [CNX]
  If clalev([F:FIS]) : Close Local File [FIS] : Endif
  Local File =APPLI+".FISCYEAR" [FIS]

  If clalev([F:ACV]) : Close Local File [ACV] : Endif
  Local File =APPLI+".ACTIV" [ACV]

  If clalev([F:FAS]) : Close Local File [FAS] : Endif
  Local File =APPLI+".FXDASSETS" [FAS]
  If clalev([F:DEP]) : Close Local File [DEP] : Endif
  Local File =APPLI+".DEPREC" [DEP]

  Call ECR_TRACE("UTIIMM035: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM035
  Call ECR_TRACE("UTIIMM035: Process End on : "+APPLI,0) From GESECRAN

  Close File [CPY], [CNX], [FIS], [ACV], [FAS], [DEP]
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM035
  ########################################
  # AJOUTER ICI LE CODE DE LA MOULINETTE #
  ########################################

Local Integer RET, N_PLN
Local Date    ENDFIYCOU(1..G300MAX)      # Fin d'exercice courant
Local Date    ENDPERCOU(1..G300MAX)      # Fin de période courante
Local Integer LCPTR

    Call ECR_TRACE("Date" - format$("D:" + GFMDAT4, date$) - "Time" - time$, 0) From GESECRAN

  # code activité Russie
  If func ACTIV("KRU") = 0
    Call ECR_TRACE("no activity code KRU : nothing to do", 0) From GESECRAN
    GOK = 1
    Return
  Endif

  # champ KNBMSTPDEP absent : rien à faire
  If dim([F:DEP]KNBMSTPDEP) < 0 or dim([F:DEP]KSTPDEPSTA) < 0
    Call ECR_TRACE("KNBMSTPDEP/KSTPDEPSTA not found : nothing to do", 0) From GESECRAN
    GOK = 1
    Return
  Endif

  Trbegin [DEP]
  LCPTR = 0
  For [CPY] Where LEG = "RUS"
    Call GET_CPY_DAT([F:CPY]CPY, ENDFIYCOU, ENDPERCOU, RET)

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE([F:CPY]CPY - "Company (" +
&                format$("D:" + GFMDAT4, ENDFIYCOU([F:CNX]CNX)) -
&                format$("D:" + GFMDAT4, ENDPERCOU([F:CNX]CNX)) +
&                ") Asset/plan ->", 0) From GESECRAN

    For [FAS] Where CPY = [F:CPY]CPY
#& and AASREF >= "BIENRUS1" and AASREF <= "BIENRUS9"

      For [CNX] Where CPY=[F:CPY]CPY
        For N_PLN=0 To [F:CNX]NBPLC-1
          Update [DEP] Where
&             AASREF = [F:FAS]AASREF and
&             DPRPLN = [F:CNX]PLNCAA(N_PLN) and
&             FIYENDDAT = ENDFIYCOU([F:CNX]CNX) and
&             PERENDDAT = ENDPERCOU([F:CNX]CNX) and
&             (DPM = "CR" or DPM = "DR" or
&              DPM = "LR" or DPM = "SR")
&         With KNBMSTPDEP = [F:FAS]KNBMSTPDEP, KSTPDEPSTA = [F:FAS]KSTPDEPSTA


#          Update [DEP] Where
#&             AASREF = [F:FAS]AASREF and
#&             DPRPLN = [F:CNX]PLNCAA(N_PLN) and
#&             FIYENDDAT = ENDFIYCOU([F:CNX]CNX) and
#&             PERENDDAT = ENDPERCOU([F:CNX]CNX) and
#&             (DPM = "CR" or DPM = "DR" or DPM = "LR" or
#&              DPM = "SR" or DPM = "UR")
#&         With KNBMSTPDEP = 0, KSTPDEPSTA = 0

          If fstat = 0 and adxuprec > 0
            LCPTR += 1
            Call ECR_TRACE("  " -
&                [F:FAS]AASREF - "/" - num$([F:CNX]PLNCAA(N_PLN)), 0) From GESECRAN

          Endif
        Next N_PLN
      Next
    Next
  Next

  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("", 0) From GESECRAN
  If !GOK Then
    Call ECR_TRACE("Error during the process", 1) From GESECRAN

    Goto AB_UTIIMM035
  Else
    Call ECR_TRACE(num$(LCPTR) - "DEPREC updated", 0) From GESECRAN
#Rollback
    Commit
  Endif
Return

$AB_UTIIMM035
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","FXDASSETS","fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","DEPREC","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM035(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","FXDASSETS","fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","DEPREC","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM035(APPLI)
End

#--------------------------------------------------------------#
# S/P de récupération des dates des contextes gérés pour une   #
# société passée en paramétre                                  #
#####################################################################
Subprog GET_CPY_DAT(PCPY,
&                   RENDFIYCOU, RENDPERCOU, PRET)
Value    Char    PCPY                # Société passée en paramètre
Variable Date    RENDFIYCOU(1..)     # Fin d'exercice courant
Variable Date    RENDPERCOU(1..)     # Fin de période courante
Variable Integer PRET

  Filter [CNX] Where CPY=PCPY
  For [CNX]
    Filter [FIS] Where (CPY=PCPY & CNX=[F:CNX]CNX & STAFIY=GVML_TECOURA)
    Read [FIS] First
    If (!fstat) Then
      RENDFIYCOU([F:CNX]CNX)=[F:FIS]DATENDFIY
      RENDPERCOU([F:CNX]CNX)=[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
    Endif
  Next
  Filter [FIS]
  Filter [CNX]

End

####################################################
## Code activité actif ou dimension
####################################################
Funprog ACTIV(COD)
Value Char COD
If COD="" : End 1 : Endif

Read [ACV]CODACT = COD
If fstat or [F:ACV]FLACT<>2
 End 0
Elsif [F:ACV]TYP=2
 End [F:ACV]DIME
Else
 End 1
Endif
