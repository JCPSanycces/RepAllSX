#<AdxTL>@(#)1.0.0.0 $Revision$
###############################################################################
# on doit avoir un paramétrage des tarifs tel que :
#    PLICRI1 = référence article
#    PLICRI2 = site de vente
#   
###############################################################################
$ACTION
Case ACTION
        When "EXP_OUVRE" : Gosub EXP_OUVRE
        When "EXPORT"    : Gosub EXPORT
        When Default
Endcase
Return

###############################################################################
$EXP_OUVRE
If clalev([F:ITM])=0    : Local File ITMMASTER  [ITM]   : Endif
If clalev([F:SPC])=0    : Local File SPRICCONF  [SPC]   : Endif
If clalev([F:TLP])=0    : Local File TABLINCFG  [TLP]   : Endif
If clalev([F:SPI])=0    : Local File SPRICINCR  [SPI]   : Endif

# -- purge du fichier de travail
Delete [SPI] Where [F:SPI]PLI="" 
Return

###############################################################################
$EXPORT
######### EXTRACTION TARIF ########
#------------------------------------------------------#
#  extraction des tarifs valides pour la date du jour  #
#------------------------------------------------------#
If [F:SPL]PLISTRDAT > date$ | [F:SPL]PLIENDDAT < date$ : OK = 0 : Return : Endif

#------------------------------------------------------#
#  extraction des tarifs sur quantité de 1             #
#------------------------------------------------------#
If [F:SPL]MINQTY > 1 : OK = 0: Return : Endif

#------------------------------------------------------#
#  extraction des tarifs type normal                   #
#------------------------------------------------------#
Read [SPC]SPC0=[F:SPL]PLI
If fstat : Raz [F:SPC] : Endif
If [F:SPC]PLITYP<>1 : OK = 0: Return : Endif

######### ALIMENTATION #################################

#------------------------------------------------------#
#  article -- >  ligne produit                         #
#------------------------------------------------------#
#--- Lecture des articles 
Read [ITM]ITM0=[F:SPL]PLICRI1
If fstat : OK = 0: Return :Endif

#--- Lecture des lignes de produit 
Read [TLP]TLP0=[F:ITM]CFGLIN
If fstat : OK = 0: Return :Endif

#------------------------------------------------------#
#  controle dans table de travail                      #
#------------------------------------------------------#
#--- Lecture dans table de travail
Read [SPI]SPI0="";[F:TLP]CFGLIN;adxuid(1)
If !fstat : OK = 0: Return : Endif

Raz [F:SPI]
[F:SPI]PLI    = ""
[F:SPI]PLICRD = [F:TLP]CFGLIN
[F:SPI]PLILIN = adxuid(1)

Write [SPI]

#------------------------------------------------------#
#  alimentation atrribut                               #
#------------------------------------------------------#
Raz GIMP(1), GIMP(2), GIMP(3), GIMP(4),  GIMP(5),  GIMP(6)
Raz GIMP(7), GIMP(8), GIMP(9), GIMP(10), GIMP(11), GIMP(12)

If [F:TLP]CFGALP1 <> 1 : GIMP(1)  = mess([F:TLP]CFGALP1,760,1) : Endif
If [F:TLP]CFGALP2 <> 1 : GIMP(2)  = mess([F:TLP]CFGALP2,760,1) : Endif
If [F:TLP]CFGALP3 <> 1 : GIMP(3)  = mess([F:TLP]CFGALP3,760,1) : Endif
If [F:TLP]CFGALP4 <> 1 : GIMP(4)  = mess([F:TLP]CFGALP4,760,1) : Endif
If [F:TLP]CFGALP5 <> 1 : GIMP(5)  = mess([F:TLP]CFGALP5,760,1) : Endif
If [F:TLP]CFGALP6 <> 1 : GIMP(6)  = mess([F:TLP]CFGALP6,760,1) : Endif

If [F:TLP]CFGNUM1 <> 1 : GIMP(7)  = mess([F:TLP]CFGNUM1,760,1) : Endif
If [F:TLP]CFGNUM2 <> 1 : GIMP(8)  = mess([F:TLP]CFGNUM2,760,1) : Endif
If [F:TLP]CFGNUM3 <> 1 : GIMP(9)  = mess([F:TLP]CFGNUM3,760,1) : Endif
If [F:TLP]CFGNUM4 <> 1 : GIMP(10) = mess([F:TLP]CFGNUM4,760,1) : Endif
If [F:TLP]CFGNUM5 <> 1 : GIMP(11) = mess([F:TLP]CFGNUM5,760,1) : Endif
If [F:TLP]CFGNUM6 <> 1 : GIMP(12) = mess([F:TLP]CFGNUM6,760,1) : Endif
Return 
