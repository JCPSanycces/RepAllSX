#<AdxTL>@(#)2.0.0.0 $Revision$
Raz GPILOBJ
GFLAG="2"
Call OBJET("DAE",GBIDC1,"") From GOBJET
End

#----------------------------------------------------------------------------------------------------------------------------------
# Gestion des tables DNA-DNB-DNC-DND-DNE-DNF-DNG-DNH
#----------------------------------------------------------------------------------------------------------------------------------
#DNA
###################################
$CHARGE_DNA
Read[DNA]DNA0=[F:HRDAE]YEAEMPDDS;[F:HRDAE]EMPDDS;[F:HRDAE]CTRNUM;[F:HRDAE]ETRDAT;[F:HRDAE]TYPDAE;[F:HRDAE]FLGDNA
If !fstat
 [M:DNA1]=[F:DNA]
 [M:DNA2]=[F:DNA]
 [M:DNA3]=[F:DNA]
Endif
Gosub CHARGE_DNB
Gosub CHARGE_DNC
Gosub CHARGE_DND
Gosub CHARGE_DNE
Gosub CHARGE_DNF
Gosub CHARGE_DNG
Gosub CHARGE_DNH
If [M:DNA1]DNACCP<>1
 Effzo [M:DNA1]DNACCPNUM
 Grizo [M:DNA1]DNACCPNUM
Else
 Actzo [M:DNA1]DNACCPNUM
Endif
If [M:DNA1]LNK<>2
 Effzo [M:DNA1]TYPLNK
 Grizo [M:DNA1]TYPLNK
Else
 Actzo [M:DNA1]TYPLNK
Endif
Call GRISE_SORTIE ([M:DNA3]DNAENDDAT) From SUBDAE
[M:DNA3]RGMCOD1=[F:DNA]RGMCOD(0)
[M:DNA3]RGMCOD2=[F:DNA]RGMCOD(1)

Read[F:ID]ID0=[F:DNA]EMPDDS

# N4DS - L'écran DNA4 concerne les intermittents du spectacle, controlé par un code activité (INTMT)
If [V]GINTMT & clalev([M:DNA4])
    If [F:ID]FLGINT<>2 : # Le salarié n'est pas un intermittent
        Effzo[M:DNA4]
        Grizo[M:DNA4]
    Else
        Affzo[M:DNA4]
    Endif
Endif
Return

###################################
$CHARGE_DNB
nolign=0
For [DNB]DNB0 Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
 nolign += 1
 [M:DNA2]=[F:DNB]
Next
[M:DNA2]NBRPRM = nolign
Return

###################################
$CHARGE_DNC
nolign=0
For [DNC]DNC0 Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
 nolign += 1
 [M:DNA2]=[F:DNC]
Next
[M:DNA2]NBRIND1 = nolign
Return

###################################
$CHARGE_DND
nolign=0
For [DND]DND0 Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
 nolign += 1
 [M:DNA3]=[F:DND]
Next
[M:DNA3]NBRPRV = nolign
Return

###################################
$CHARGE_DNE
nolign=0
For [DNE]DNE0 Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
 nolign += 1
 [M:DNA2]=[F:DNE]
Next
[M:DNA2]NBRIND2 = nolign
Return

###################################
$CHARGE_DNF
Filter [DNF] Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
Read [F:DNF]DNF0 Last
Filter [DNF]
If !fstat : [M:DNA1]=[F:DNF]: Endif
Return

###################################
$CHARGE_DNG
nolign=0
For [DNG]DNG0 Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
 nolign += 1
 [M:DNA2]=[F:DNG]
Next
[M:DNA2]NBRDNG = nolign
Return

###################################
$CHARGE_DNH
If GINTMT=0 : Return : Endif
nolign=0
For [DNH]DNH0 Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
 nolign += 1
 [M:DNA4]=[F:DNH]
Next
[M:DNA4]NBRDNH = nolign
Return


###################################
$SAUVE_DNA
Delete [DNA] Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$DADDNA" : Return
Endif
[F:DNA]YEAEMPDDS=[F:HRDAE]YEAEMPDDS
[F:DNA]EMPDDS=[F:HRDAE]EMPDDS
[F:DNA]ETRDAT=[F:HRDAE]ETRDAT
[F:DNA]CTRNUM=[F:HRDAE]CTRNUM
[F:DNA]TYPDAE=[F:HRDAE]TYPDAE
[F:DNA]FLGDNA=[F:HRDAE]FLGDNA
[F:DNA]=[M:DNA1]
# N4DS - Info DNA un peu éclaté partout, on sauve aussi les valeurs stockées sur DNA2 et DNA3
[F:DNA]=[M:DNA2]
[F:DNA]=[M:DNA3]
[F:DNA]RGMCOD(0)=[M:DNA3]RGMCOD1
[F:DNA]RGMCOD(1)=[M:DNA3]RGMCOD2
Write [DNA]
If fstat<>0
 GOK = 0 : Call FSTA("DNA") From GLOCK
Endif
Gosub SAUVE_DNB
Gosub SAUVE_DNC
Gosub SAUVE_DND
Gosub SAUVE_DNE
Gosub SAUVE_DNF
Gosub SAUVE_DNG
Gosub SAUVE_DNH
Return

###################################
$SAUVE_DNB
Delete [DNB] Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$DADDNA2" : Return
Endif
For nolign=1 To [M:DNA2]NBRPRM
 [F:DNB]=[M:DNA2]
 [F:DNB]YEAEMPDDS=[F:HRDAE]YEAEMPDDS
 [F:DNB]EMPDDS=[F:HRDAE]EMPDDS
 [F:DNB]ETRDAT=[F:HRDAE]ETRDAT
 [F:DNB]CTRNUM=[F:HRDAE]CTRNUM
 [F:DNB]TYPDAE=[F:HRDAE]TYPDAE
 [F:DNB]FLGDNA=[F:HRDAE]FLGDNA
 [F:DNB]NUMLIG=nolign
 Write [DNB]
 If fstat<>0
  GOK = 0 : Call FSTA("DNB") From GLOCK : Break
 Endif
Next
Return

###################################
$SAUVE_DNC
Delete [DNC] Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$DADDNA3" : Return
Endif
For nolign=1 To [M:DNA2]NBRIND1
 [F:DNC]=[M:DNA2]
 [F:DNC]YEAEMPDDS=[F:HRDAE]YEAEMPDDS
 [F:DNC]EMPDDS=[F:HRDAE]EMPDDS
 [F:DNC]ETRDAT=[F:HRDAE]ETRDAT
 [F:DNC]CTRNUM=[F:HRDAE]CTRNUM
 [F:DNC]TYPDAE=[F:HRDAE]TYPDAE
 [F:DNC]FLGDNA=[F:HRDAE]FLGDNA
 [F:DNC]NUMLIG=nolign
 Write [DNC]
 If fstat<>0
  GOK = 0 : Call FSTA("DNC") From GLOCK : Break
 Endif
Next
Return

###################################
$SAUVE_DND
Delete [DND] Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$DADDNA4" : Return
Endif
For nolign=1 To [M:DNA3]NBRPRV
 [F:DND]=[M:DNA3]
 [F:DND]YEAEMPDDS=[F:HRDAE]YEAEMPDDS
 [F:DND]EMPDDS=[F:HRDAE]EMPDDS
 [F:DND]ETRDAT=[F:HRDAE]ETRDAT
 [F:DND]CTRNUM=[F:HRDAE]CTRNUM
 [F:DND]TYPDAE=[F:HRDAE]TYPDAE
 [F:DND]FLGDNA=[F:HRDAE]FLGDNA
 [F:DND]NUMLIG=nolign
 Write [DND]
 If fstat<>0
  GOK = 0 : Call FSTA("DND") From GLOCK : Break
 Endif
Next
Return

###################################
$SAUVE_DNE
Delete [DNE] Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$DADDNA5" : Return
Endif
For nolign=1 To [M:DNA2]NBRIND2
 [F:DNE]=[M:DNA2]
 [F:DNE]YEAEMPDDS=[F:HRDAE]YEAEMPDDS
 [F:DNE]EMPDDS=[F:HRDAE]EMPDDS
 [F:DNE]ETRDAT=[F:HRDAE]ETRDAT
 [F:DNE]CTRNUM=[F:HRDAE]CTRNUM
 [F:DNE]TYPDAE=[F:HRDAE]TYPDAE
 [F:DNE]FLGDNA=[F:HRDAE]FLGDNA
 [F:DNE]NUMLIG=nolign
 Write [DNE]
 If fstat<>0
  GOK = 0 : Call FSTA("DNE") From GLOCK : Break
 Endif
Next
Return


###################################
$SAUVE_DNF
Delete [DNF] Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$DADDNA6" : Return
Endif
[F:DNF]=[M:DNA1]
[F:DNF]YEAEMPDDS=[F:HRDAE]YEAEMPDDS
[F:DNF]EMPDDS=[F:HRDAE]EMPDDS
[F:DNF]ETRDAT=[F:HRDAE]ETRDAT
[F:DNF]CTRNUM=[F:HRDAE]CTRNUM
[F:DNF]TYPDAE=[F:HRDAE]TYPDAE
[F:DNF]FLGDNA=[F:HRDAE]FLGDNA
[F:DNF]NUMLIG=1
Write [DNF]
If fstat<>0
 GOK = 0 : Call FSTA("DNF") From GLOCK
Endif
Return

###################################
$SAUVE_DNG
Delete [DNG] Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$DADDNA7" : Return
Endif
For nolign=1 To [M:DNA2]NBRDNG
 [F:DNG]=[M:DNA2]
 [F:DNG]YEAEMPDDS=[F:HRDAE]YEAEMPDDS
 [F:DNG]EMPDDS=[F:HRDAE]EMPDDS
 [F:DNG]ETRDAT=[F:HRDAE]ETRDAT
 [F:DNG]CTRNUM=[F:HRDAE]CTRNUM
 [F:DNG]TYPDAE=[F:HRDAE]TYPDAE
 [F:DNG]FLGDNA=[F:HRDAE]FLGDNA
 [F:DNG]NUMLIG=nolign
 Write [DNG]
 If fstat<>0
  GOK = 0 : Call FSTA("DNG") From GLOCK : Break
 Endif
Next
Return

###################################
$SAUVE_DNH
If GINTMT=0 : Return : Endif
Delete [DNH] Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$DADDNA8" : Return
Endif
For nolign=1 To [M:DNA4]NBRDNH
 [F:DNH]=[M:DNA4]
 [F:DNH]YEAEMPDDS=[F:HRDAE]YEAEMPDDS
 [F:DNH]EMPDDS=[F:HRDAE]EMPDDS
 [F:DNH]ETRDAT=[F:HRDAE]ETRDAT
 [F:DNH]CTRNUM=[F:HRDAE]CTRNUM
 [F:DNH]TYPDAE=[F:HRDAE]TYPDAE
 [F:DNH]FLGDNA=[F:HRDAE]FLGDNA
 [F:DNH]NUMLIG=nolign
 Write [DNH]
 If fstat<>0
  GOK = 0 : Call FSTA("DNH") From GLOCK : Break
 Endif
Next
Return

#----------------------------------------------------------------------------------------------------------------------------------
# Génération du fichier DNA : Obsolète N4DS
#----------------------------------------------------------------------------------------------------------------------------------

####################################
$GEN_DNA1
Read[DNA]DNA0=[F:HRDAE]YEAEMPDDS;[F:HRDAE]EMPDDS;[F:HRDAE]CTRNUM;[F:HRDAE]ETRDAT;[F:HRDAE]TYPDAE;[F:HRDAE]FLGDNA
If ! fstat
 For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G08.00" &  [F:FTD]XPSRES<>""
  ZONE=[F:FTD]NUMREC
  Gosub VERIF_FORMULE From TRTTDS
  If [F:FTD]FLGREC=1    :#Obligatoire
   Wrseq ZONE,RESULTAT Using [FIC]
   NBLIGNE+=1
  Else
   If RESULTAT<>"''" & RESULTAT<>"'0'"
    Wrseq ZONE,RESULTAT Using [FIC]
    NBLIGNE+=1
   Endif
  Endif
 Next
 For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G10.00" &  [F:FTD]XPSRES<>""
  ZONE=[F:FTD]NUMREC
  Gosub VERIF_FORMULE From TRTTDS
  If [F:FTD]FLGREC=1    :#Obligatoire
   Wrseq ZONE,RESULTAT Using [FIC]
   NBLIGNE+=1
  Else
   If RESULTAT<>"''" & RESULTAT<>"'0'"
    Wrseq ZONE,RESULTAT Using [FIC]
    NBLIGNE+=1
   Endif
  Endif
 Next

 For [DNF]DNF0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM
&                    & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
  For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G15.00" &  [F:FTD]XPSRES<>""
   ZONE=[F:FTD]NUMREC
   Gosub VERIF_FORMULE From TRTTDS
   If [F:FTD]FLGREC=1    :#Obligatoire
    Wrseq ZONE,RESULTAT Using [FIC]
     NBLIGNE+=1
   Else
    If RESULTAT<>"''" & RESULTAT<>"'0'"
     Wrseq ZONE,RESULTAT Using [FIC]
     NBLIGNE+=1
    Endif
   Endif
  Next
 Next

 For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G15.05" &  [F:FTD]XPSRES<>""
  ZONE=[F:FTD]NUMREC
  Gosub VERIF_FORMULE From TRTTDS
  If [F:FTD]FLGREC=1    :#Obligatoire
   Wrseq ZONE,RESULTAT Using [FIC]
   NBLIGNE+=1
  Else
   If RESULTAT<>"''" & RESULTAT<>"'0'"
    Wrseq ZONE,RESULTAT Using [FIC]
    NBLIGNE+=1
   Endif
  Endif
 Next
 For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G16.05" &  [F:FTD]XPSRES<>""
  ZONE=[F:FTD]NUMREC
  Gosub VERIF_FORMULE From TRTTDS
  If [F:FTD]FLGREC=1    :#Obligatoire
   Wrseq ZONE,RESULTAT Using [FIC]
   NBLIGNE+=1
  Else
   If RESULTAT<>"''" & RESULTAT<>"'0'"
    Wrseq ZONE,RESULTAT Using [FIC]
    NBLIGNE+=1
   Endif
  Endif
 Next
Endif
Return

####################################
$GEN_DNA2
Read[DNA]DNA0=[F:HRDAE]YEAEMPDDS;[F:HRDAE]EMPDDS;[F:HRDAE]CTRNUM;[F:HRDAE]ETRDAT;[F:HRDAE]TYPDAE;[F:HRDAE]FLGDNA
If ! fstat

 For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G47.03" &  [F:FTD]XPSRES<>""
  ZONE=[F:FTD]NUMREC
  Gosub VERIF_FORMULE From TRTTDS
  If [F:FTD]FLGREC=1    :#Obligatoire
   Wrseq ZONE,RESULTAT Using [FIC]
   NBLIGNE+=1
  Else
   If RESULTAT<>"''" & RESULTAT<>"'0'"
    Wrseq ZONE,RESULTAT Using [FIC]
    NBLIGNE+=1
   Endif
  Endif
 Next

 For [DNB]DNB0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM
&                    & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
  For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G47.05" &  [F:FTD]XPSRES<>""
   ZONE=[F:FTD]NUMREC
   Gosub VERIF_FORMULE From TRTTDS
   If [F:FTD]FLGREC=1    :#Obligatoire
    Wrseq ZONE,RESULTAT Using [FIC]
     NBLIGNE+=1
   Else
    If RESULTAT<>"''" & RESULTAT<>"'0'"
     Wrseq ZONE,RESULTAT Using [FIC]
     NBLIGNE+=1
    Endif
   Endif
  Next
 Next

 For [DNG]DNG0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM
&                    & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
  For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G47.06" &  [F:FTD]XPSRES<>""
   ZONE=[F:FTD]NUMREC
   Gosub VERIF_FORMULE From TRTTDS
   If [F:FTD]FLGREC=1    :#Obligatoire
    Wrseq ZONE,RESULTAT Using [FIC]
     NBLIGNE+=1
   Else
    If RESULTAT<>"''" & RESULTAT<>"'0'"
     Wrseq ZONE,RESULTAT Using [FIC]
     NBLIGNE+=1
    Endif
   Endif
  Next
 Next

 For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G47.10" &  [F:FTD]XPSRES<>""
  ZONE=[F:FTD]NUMREC
  Gosub VERIF_FORMULE From TRTTDS
  If [F:FTD]FLGREC=1    :#Obligatoire
   Wrseq ZONE,RESULTAT Using [FIC]
   NBLIGNE+=1
  Else
   If RESULTAT<>"''" & RESULTAT<>"'0'"
    Wrseq ZONE,RESULTAT Using [FIC]
    NBLIGNE+=1
   Endif
  Endif
 Next

 For [DNC]DNC0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM
&                    & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
  For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G47.15" &  [F:FTD]XPSRES<>""
   ZONE=[F:FTD]NUMREC
   Gosub VERIF_FORMULE From TRTTDS
   If [F:FTD]FLGREC=1    :#Obligatoire
    Wrseq ZONE,RESULTAT Using [FIC]
    NBLIGNE+=1
   Else
    If RESULTAT<>"''" & RESULTAT<>"'0'"
     Wrseq ZONE,RESULTAT Using [FIC]
     NBLIGNE+=1
    Endif
   Endif
  Next
 Next DNC

 If GINTMT=1
 For [DNH]DNH0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM
&                    & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
  For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G47.20" &  [F:FTD]XPSRES<>""
   ZONE=[F:FTD]NUMREC
   Gosub VERIF_FORMULE From TRTTDS
   If [F:FTD]FLGREC=1    :#Obligatoire
    Wrseq ZONE,RESULTAT Using [FIC]
     NBLIGNE+=1
   Else
    If RESULTAT<>"''" & RESULTAT<>"'0'"
     Wrseq ZONE,RESULTAT Using [FIC]
     NBLIGNE+=1
    Endif
   Endif
  Next
 Next
 Endif

If [F:DNA]DNAENDDAT<>[0/0/0]
  For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G55.00" &  [F:FTD]XPSRES<>""
   ZONE=[F:FTD]NUMREC
   Gosub VERIF_FORMULE From TRTTDS
   If [F:FTD]FLGREC=1    :#Obligatoire
    Wrseq ZONE,RESULTAT Using [FIC]
    NBLIGNE+=1
   Else
    If RESULTAT<>"''" & RESULTAT<>"'0'"
     Wrseq ZONE,RESULTAT Using [FIC]
     NBLIGNE+=1
    Endif
   Endif
  Next
  For [DND]DND0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM
&                    & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
   For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G55.05" &  [F:FTD]XPSRES<>""
    ZONE=[F:FTD]NUMREC
    Gosub VERIF_FORMULE From TRTTDS
    If [F:FTD]FLGREC=1    :#Obligatoire
     Wrseq ZONE,RESULTAT Using [FIC]
     NBLIGNE+=1
    Else
     If RESULTAT<>"''" & RESULTAT<>"'0'"
      Wrseq ZONE,RESULTAT Using [FIC]
      NBLIGNE+=1
     Endif
    Endif
   Next
  Next
  For [DNE]DNE0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM
&                     & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
   For [F:FTD]FTD0 Where left$(NUMREC,10)="S41.G55.10" &  [F:FTD]XPSRES<>""
    ZONE=[F:FTD]NUMREC
    Gosub VERIF_FORMULE From TRTTDS
    If [F:FTD]FLGREC=1    :#Obligatoire
     Wrseq ZONE,RESULTAT Using [FIC]
      NBLIGNE+=1
    Else
     If RESULTAT<>"''" & RESULTAT<>"'0'"
      Wrseq ZONE,RESULTAT Using [FIC]
      NBLIGNE+=1
     Endif
    Endif
   Next
  Next
 Endif
 For [F:FTD]FTD0 Where (left$(NUMREC,10)="S41.G55.15" | left$(NUMREC,10)="S41.G55.16") &  [F:FTD]XPSRES<>""
  ZONE=[F:FTD]NUMREC
  Gosub VERIF_FORMULE From TRTTDS
  If [F:FTD]FLGREC=1    :#Obligatoire
   Wrseq ZONE,RESULTAT Using [FIC]
   NBLIGNE+=1
  Else
   If RESULTAT<>"''" & RESULTAT<>"'0'"
    Wrseq ZONE,RESULTAT Using [FIC]
    NBLIGNE+=1
   Endif
  Endif
 Next
Endif
Return
