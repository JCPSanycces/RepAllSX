#<AdxTL>@(#)0.0.0.0 $Revision$
## <PP ARG>
############################################################
## Programme numérotation pour l'Argentine                ##
## Type de document                                       ##
## FC : Factures/Avoirs clients                           ##
## ND : Notes de débit                                    ##
## NC : Notes de crédit                                   ##
## RE : Récibo                                            ##
## OR : Ordre de paiement                                 ##
############################################################
Subprog NUMEROARG(COMPTEUR,SITE,TYPDOC,CATDOC,DAT,REGIME,VALEUR,NOCAI,DATVAL,STAT)
Value    Char    COMPTEUR
Value    Char    SITE
Value    Char    TYPDOC()   : # Type document
Value    Integer CATDOC     : # Catégorie document (1:Achats 2:Ventes)
Value    Date    DAT
Value    Char    REGIME     : # Régime TVA
Variable Char    VALEUR()   : # Numéro du document
Variable Char    NOCAI()    : # Numéro CAI
Variable Date    DATVAL     : # Date validité CAI
Variable Integer STAT

If clalev([F:SCU])=0 : Local File SUCURSAL [SCU] : Endif
If clalev([F:NCA])=0 : Local File NUMCAI   [NCA] : Endif
If clalev([F:AVN])=0 : Local File AVALNUM  [AVN] : Endif
If clalev([F:ANM])=0 : Local File ACODNUM  [ANM] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif

Local Char    SIT(GLONFCY), SOC(GLONCPY)
Local Integer NBRSEQ
Local Integer I, STAT
Local Integer PERIODE

Local Char TT(2)
Local Char C(1)
Local Char SSSS(4)
Local Char TTCSSSS(7)
Local Char COMP(30)

PERIODE = 0 : # Les compteurs "CAI" sont défini sans RAZ
STAT = 0
Read [ANM]ANM0 = COMPTEUR

Call TTCSSSS(1,TYPDOC,CATDOC,SITE,DAT,REGIME,TT,C,SSSS,NOCAI,DATVAL,STAT)
TTCSSSS = [L]TT+[L]C+[L]SSSS

If GOK<1 | STAT : End : Endif


Case [F:ANM]NIVDEF
 When 1   : SIT = ""
 When 2   : Gosub SETSOC From SUBANM : SIT = SOC
 When 3   : SIT = SITE
Endcase

Gosub SEQ_CAI
If GOK<1 | STAT : End : Endif

Gosub ATTRIB_NUMERO From SUBANM

End


$SEQ_CAI
COMP = NOCAI
Readlock [AVN]AVN0 = COMPTEUR;SIT;PERIODE;COMP
If fstat=1
 GOK=-1 : GLOCK = "$AVALNUM"-COMPTEUR-SIT-num$(PERIODE)-COMP : STAT=99 : Return
Elsif fstat
 SEQUENCE = [F:NCA]RANSTR
 Raz [F:AVN]
 [F:AVN]CODNUM  = COMPTEUR
 [F:AVN]SITE    = SIT
 [F:AVN]PERIODE = PERIODE
 [F:AVN]COMP    = COMP
 [F:AVN]VALEUR  = 1+[F:NCA]RANSTR
 Write [AVN]
Else
 SEQUENCE = [F:AVN]VALEUR
 [F:AVN]VALEUR += 1
 Rewrite [AVN]
Endif
If fstat
 GOK=0 : Call FSTA("AVN") From GLOCK : STAT=99 : Return
Endif
[F:NCA]LASNUM = [F:AVN]VALEUR-1
If [F:AVN]VALEUR = [F:NCA]RANEND
 [F:NCA]FLGSHL = 2
Endif
Rewrite [NCA]
If fstat
 GOK=0 : Call FSTA("NCA") From GLOCK : STAT=22 : Return
Endif
Return


Subprog TTCSSSS(CAS,TYPDOC,CATDOC,SITE,DAT,REGIME,TT,C,SSSS,CAI,DATVAL,STAT)
Value    Integer CAS    : # 1:pour attribution numéro document 2:pour init. racine (TTC) doc. externe (fact origine fourn)
Value    Char    TYPDOC : # Type document (Factures, notes débit,...)
Value    Integer CATDOC : # Catégorie document (1:Achats  2:ventes)
Value    Char    SITE
Value    Date    DAT
Value    Char    REGIME
Variable Char    TT
Variable Char    C
Variable Char    SSSS
Variable Char    CAI
Variable Date    DATVAL
Variable Integer STAT

If clalev([F:SCU])=0 : Local File SUCURSAL  [SCU] : Endif
If clalev([F:NCA])=0 : Local File NUMCAI    [NCA] : Endif
If clalev([F:TVB])=0 : Local File TABVACBPR [TVB] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV   [ADI] : Endif

Local Char    CLASSE(1)    : # Classe
Local Char    SUCUR(4)     : # Succursale

Call GETSOC(SITE) From DEVSUB
Call LEC_TVB(GCURLEG,REGIME) From CPTLEC
If !fstat & [F:TVB]ENAFLG=2
 Case CATDOC
  When 2
   CLASSE = [F:TVB]SALCLA
  When 1
   CLASSE = [F:TVB]VAT
 Endcase
Endif
If CLASSE = ""
 Filter [ADI] Where NUMTAB=363 & DEFVAL=2
 Read [ADI]CODE First
 If !fstat
  CLASSE = [F:ADI]CODE
 Else
  CLASSE = "B"
 Endif
 Filter [ADI]
Endif

If CAS = 1
 Read [SCU]SCU0 = SITE ; TYPDOC ; CLASSE
 If !fstat
  SUCUR = [F:SCU]SCU
 Else
  GOK = 0 : STAT = 20 : End
 Endif
 Filter [NCA] Where TYP=[L]TYPDOC & CLS=[L]CLASSE & SCU=[L]SUCUR & VLYEND>=DAT & FLGSHL<>2
 Readlock [NCA]NCA0 First
 Filter [NCA]
 If !fstat
  TT   = [L]TYPDOC
  C    = [L]CLASSE
  SSSS = [L]SUCUR
  CAI  = [F:NCA]CAI
 Else
  GOK = 0 : STAT = 21 : End
 Endif
Elsif CAS = 2
 TT   = [L]TYPDOC
 C    = [L]CLASSE
Endif
End
## <Fin PP ARG>


# Message d'erreurs gestion des compteurs
$MESSAGE
Case STAT
 When 1  : MESSA = mess(12,114,1)  : # Compteur inexistant
 When 2  : MESSA = mess(13,114,1)  : # Dépassement de compteur
 When 3  : MESSA = mess(34,113,1)  : # Exercice non ouvert
 When 5  : MESSA = mess(62,133,1)  : # Société ou site incorrect
 When 4  : MESSA = mess(111,123,1) : # Longueur incorrecte
 When 6  : If GPRODUIT=1 : ## GEODE
            MESSA = mess(79,310,1) : # Déposant inexistant
           Endif
 When 20 : MESSA = mess(1,8890,1)  : # Succursale non définie
 When 21 : MESSA = mess(2,8890,1)  : # Aucun numéro CAI valide
 When 22 : MESSA = mess(3,8890,1)  : #Problème d'écriture sur la table de numérotation CAI
 When 99 : MESSA = mess(135,133,1) : # Compteur verrouillé
Endcase
Return
