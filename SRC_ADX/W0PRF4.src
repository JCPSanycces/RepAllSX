#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PRF4 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRDIC
mkstat = 0
zoncou = "NBRDIC"
indice = 0
status = 1
zoncou = "NBRDIC"
If varmode([M]NBRDIC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRDIC" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRDIC
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRDIC = nolign
   status = 75
   Call SAI_NBRDIC(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRDIC(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRDIC
mkstat = 0
zoncou = "NBRDIC"

## Zone FLD
mkstat = 0
zoncou = "FLD"
If varmode([M]FLD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLD" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_FLD([M]FLD(indice)) From SUBPRF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FLD" : GZNUM = 1261 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone LEV
mkstat = 0
zoncou = "LEV"
IMPENT = [M]LEV(indice)
If varinit([M]LEV,indice)=0
 IMPENT = 1
Endif
If varmode([M]LEV,indice)=0
 Call INICOMBO(10508) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_LEV(IMPENT) From SUBPRF
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,10508,1))))
 Endif
 [M]LEV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "LEV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]LEV(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_LEV(IMPENT) From SUBPRF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]LEV(indice) = IMPENT

## Zone CPY
mkstat = 0
zoncou = "CPY"
If varmode([M]CPY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CPY([M]CPY(indice)) From SUBPRF
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CPY(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]CPY(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTCPY"
   Call CONTSOC([M]CPY(indice)) From SUBAGF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("CPY","",[M]CPY(indice),"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CONTCPYLEG"
     Call CONTCPYLEG([M]CPY(indice),func TOOLSHRLEG.LEGWRK) From TRTX3
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone FCY
mkstat = 0
zoncou = "FCY"
If varmode([M]FCY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_FCY([M]FCY(indice)) From SUBPRF
 GACTION = SAVACT
 If mkstat=1 : Raz [M]FCY(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "FCY" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]FCY(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTFCY"
   Call CONTSITE([M]FCY(indice)) From SUBAGF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("FCY","",[M]FCY(indice),"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CONTFCYLEG"
     Call CONTFCYLEG([M]FCY(indice),func TOOLSHRLEG.LEGWRK) From TRTX3
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone CLLCVT
mkstat = 0
zoncou = "CLLCVT"
If varmode([M]CLLCVT,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRCLV"
 Call DEFHRCLV([M]CLLCVT(indice),GCURLEG,GSOCIETE) From SUBHRCLV
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CLLCVT(indice) : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call AS_CLLCVT([M]CLLCVT(indice)) From SUBPRF
  GACTION = SAVACT
  If mkstat=1 : Raz [M]CLLCVT(indice) : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "CLLCVT" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   If vireblc([M]CLLCVT(indice),2)=""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "CLLCVT" : GZNUM = 44763 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTHRCLV"
    Call CONTHRCLV([M]CLLCVT(indice),GCURLEG,GSOCIETE) From SUBHRCLV
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CLLCVT" : GZNUM = 44763 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CONTOBJN"
     Local Char    VALEUR(250)
     VALEUR = [M]CLLCVT(indice)
     Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
     [M]CLLCVT(indice) = VALEUR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CLLCVT" : GZNUM = 44763 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone POP
mkstat = 0
zoncou = "POP"
If varmode([M]POP,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_POP([M]POP(indice)) From SUBPRF
 GACTION = SAVACT
 If mkstat=1 : Raz [M]POP(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "POP" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]POP(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTPOP"
   Call CONTPOP([M]POP(indice),GCURLEG) From SUBPOP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("POP","",[M]POP(indice),"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone VALDEF
mkstat = 0
zoncou = "VALDEF"
If varmode([M]VALDEF,indice)=0
 SAVACT = GACTION : GACTION = "AFMTSAI"
 Call ASAISIE([M]VALDEF(indice),[M]CODTYP(nolign-1)) From FMTVAR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]VALDEF(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "VALDEF" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "AFMTCONT"
  Call CONTROLE([M]VALDEF(indice),[M]CODTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT(nolign-1)) From FMTVAR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VALDEF" : GZNUM = 88 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTACL"
   Call CONTACL([M]VALINT(nolign-1),[M]CODTYP(nolign-1),"","") From SUBACL
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "VALDEF" : GZNUM = 88 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_VALDEF([M]VALDEF(indice)) From SUBPRF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "VALDEF" : GZNUM = 88 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone NBRDIC
mkstat = 0
zoncou = "NBRDIC"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PRF4"
Return

