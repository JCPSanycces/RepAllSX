## Zone CODPOS
mkstat = 0
zoncou = "CODPOS"
indice = 0
WCHAR = [M]CODPOS
SAVACT = GACTION : GACTION = "FMTPOSPAY"
Call FMTPOSPAY([M]CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]CODPOS : Endif
If !mkstat
 If varmode([M]CODPOS,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CODPOS" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "POSCNTOBL"
  PARAM(1) = [M]CRY
  PARAM(2) = "0"
  Local Char    VALEUR(250)
  VALEUR = [M]CODPOS
  Call S_AFF_CHAR(VALEUR,PARAM,"POSCNTOBL","SUBPOS","") From GACTION
  [M]CODPOS = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODPOS" : GZNUM = 210 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]CODPOS or IMPMOD
    SAVACT = GACTION : GACTION = "CPCONT"
    PARAM(1) = [M]CRY
    PARAM(2) = [M]CTY
    PARAM(3) = ""
    Local Char    VALEUR(250)
    VALEUR = [M]CODPOS
    Call S_AFF_CHAR(VALEUR,PARAM,"CPCONT","SUBPOS","") From GACTION
    [M]CODPOS = VALEUR
    [M]CTY = PARAM(2)
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CODPOS" : GZNUM = 210 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call AM_CODPOS([M]CODPOS) From SUBHRENT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CODPOS" : GZNUM = 210 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone CTY
mkstat = 0
zoncou = "CTY"
indice = 0
WCHAR = [M]CTY
SAVACT = GACTION : GACTION = "FMTCTYPAY"
Call FMTCTYPAY([M]CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]CTY : Endif
If !mkstat
 If varmode([M]CTY,indice)=0
  SAVACT = GACTION : GACTION = "VILINI"
  Local Char    VALEUR(250)
  VALEUR = [M]CTY
  Call S_AFF_CHAR(VALEUR,PARAM,"INIVIL","SUBPOS","") From GACTION
  [M]CTY = VALEUR
  GACTION = SAVACT
  If mkstat=1 : Raz [M]CTY : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "CTY" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "VILCNTOBL"
   PARAM(1) = [M]CRY
   PARAM(2) = "0"
   Local Char    VALEUR(250)
   VALEUR = [M]CTY
   Call S_AFF_CHAR(VALEUR,PARAM,"VILCNTOBL","SUBPOS","") From GACTION
   [M]CTY = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CTY" : GZNUM = 251 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]CTY or IMPMOD
     SAVACT = GACTION : GACTION = "VILCONT"
     PARAM(1) = [M]CRY
     PARAM(2) = [M]CODPOS
     PARAM(3) = ""
     Local Char    VALEUR(250)
     VALEUR = [M]CTY
     Call S_AFF_CHAR(VALEUR,PARAM,"VILCONT","SUBPOS","") From GACTION
     [M]CTY = VALEUR
     [M]CODPOS = PARAM(2)
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CTY" : GZNUM = 251 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "AFFPOSCOD"
      GACTION = SAVACT
      If !mkstat & !GIMPORT : Affzo [M]CODPOS : Endif
      If mkstat : GERR = 1 : GZONE = "CTY" : GZNUM = 251 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
      If !mkstat
       SAVACT = GACTION : GACTION = "STD"
       Call AM_CTY([M]CTY) From SUBHRENT
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "CTY" : GZNUM = 251 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

