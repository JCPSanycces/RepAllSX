## Zone NBRCHEF
mkstat = 0
zoncou = "NBRCHEF"
indice = 0
status = 1
zoncou = "NBRCHEF"
If varinit([M]NBRCHEF,indice)=0
 [M]NBRCHEF = len(mess(0,50,1))
Endif
If varmode([M]NBRCHEF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRCHEF" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRCHEF
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRCHEF = nolign
   status = 75
   Call SAI_NBRCHEF(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 5
####################################
Subprog SAI_NBRCHEF(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRCHEF
mkstat = 0
zoncou = "NBRCHEF"

## Zone RESPO
mkstat = 0
zoncou = "RESPO"
IMPENT = [M]RESPO(indice)
If varinit([M]RESPO,indice)=0
 IMPENT = nolign
Endif
[M]RESPO(indice) = IMPENT

## Zone CHEF
mkstat = 0
zoncou = "CHEF"
If varmode([M]CHEF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CHEF" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DROITEMP"
 Call DROIT([M]CHEF(indice),"","","") From DIVPAYE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CHEF" : GZNUM = 10793 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("EML","!$",[M]CHEF(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CHEF" : GZNUM = 10793 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NBRCHEF
mkstat = 0
zoncou = "NBRCHEF"

End

$DEFVAR
