#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################
# UTISTO17   Création de la valeur par défaut du nouveau paramètre ARRQTYCPN #
##############################################################################
# CCC (2011-05-10) Bug 72571
##############################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTISTO17(DOSSIER) 
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTISTO17(DOSSIER)
Value Char DOSSIER

  Call ECR_TRACE("UTISTO17: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ADOVAL"  [ADW]
  Trbegin [ADW]
  Look [F:ADW]ADW0="";"";"ARRQTYCPN"
  If fstat
      Raz [F:ADW]
      [F:ADW]PARAM = "ARRQTYCPN"
      [F:ADW]CREDAT = date$
      [F:ADW]CREUSR = GUSER
      [F:ADW]VALEUR = "1"
      Write [F:ADW]
      If fstat
          Call ECR_TRACE("ARRQTYCPN: can't create parameter value",1) From GESECRAN
      Endif
  Endif
  Commit
  Close Local File [ADW]
  Call ECR_TRACE("UTISTO17 : finish",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTISTO17(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  Call MAJ_UTISTO17(APPLI)
End


