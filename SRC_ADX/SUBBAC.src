#<AdxTL>@(#)8.0.0.0 $Revision$
$ACTION
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

##########
$SEL_TABLE
##########
Case COUZON

 When "BANAFF" : # Banque (Affectation Banque - mono-société)
  OBJET="BAN"
  CRITERE = "CPY='"+[M]CPY+"'"
  If [M]FCY<>"" : CRITERE += " & (FCY='' | FCY='"+[M]FCY+"')" : Endif

 When "POO" : # Pool bancaire (Affectation Banque - mono-société)
  OBJET="POO"
  CRITERE = "CPY='"+[M]CPY+"'"
  If [M]FCY<>"" : CRITERE += " & (FCY='' | FCY='"+[M]FCY+"')" : Endif

 When "BANAFF1" : # Banque (Saisie Banque - Fenêtre de critères... mono-société ou mono-législation)
  Gosub SELBAN From CPTSEL

 When "BAN" : # Banque (Saisie Banque - Pas la Fenêtre de critères... lignes de règlement, FCY/CPY renseigné)
  OBJET="BAN"
  Local Integer NOL : NOL=nolign-1
  CRITERE = "(FCY='' | FCY='"+[M:BAM]FCY(NOL)+"') & (CPY='' | CPY='"+[M:BAM]CPY(NOL)+"')"

 When "LOT" : # Lot de saisie
              #  Fonction : Affectation Banque - mono-société
              #  Fonction : Saisie Banque - Fenêtre de critères... Toutes sociétés => mono-législation

  OBJET="PYL"
  If dim([M]ALLCPY)<=0 | [M]ALLCPY<>2
   CRITERE-="& CPY='"+[M]CPY+"'"
  Else
   CRITERE-="& [F:CPY]LEG='"+GCURLEG+"'"
  Endif
  If [M]ALLTPY<>2
   CRITERE-="& PAYTYP='"+[M]TPY+"'"
  Endif
  If CRITERE<>"" : CRITERE=right$(CRITERE,4) : Endif

Endcase
Return

#################################################
## Etiquettes des écrans BANAFFCRIT et BANAFFA ##
#################################################
Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From CPTTRT
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From CPTTRT
End

Subprog AS_CPY(VALEUR)
Variable Char VALEUR
If [M]ALLCPY = 2 : mkstat = 1 : Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Local Char DEVLED(GLONCUR)
If dim([M]CURAMT) >0
 Call SETCUR(1,VALEUR,DEVLED) From CPTDIV
 [M]CURAMT = DEVLED
 Affzo CURAMT
Endif
Call AM_CPY (VALEUR) From CPTTRT
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Char DEVLED(GLONCUR)
If dim([M]CURAMT) >0 & [M]CURAMT=""
 Call SETCUR(1,VALEUR,DEVLED) From CPTDIV
 [M]CURAMT = DEVLED
 Affzo CURAMT
Endif
Call C_CPY(VALEUR) From CPTTRT
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG (VALEUR) From CPTTRT
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
If dim([M]ALLCPY)>0 & [M]ALLCPY=2 : VALEUR = 2 : End : Endif
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
If VALEUR=2
 Effzo FCY : Grizo FCY
Else
 Actzo FCY
Endif
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo FCY : Grizo FCY
Else
 Actzo FCY
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
If [M]ALLFCY = 2 : mkstat = 1 : Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog C_ALLTPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TPY : Grizo TPY
Else
 Actzo TPY
Endif
End

Subprog AS_TPY(VALEUR)
Variable Char     VALEUR
If [M]ALLTPY=2 : mkstat=1 : Endif
End

Subprog C_TPY(VALEUR)
Variable Char     VALEUR
If VALEUR="" : End : Endif
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
Call LEC_TPY_LEG(GCURLEG,VALEUR) From CPTLEC
If [F:TPY]STA4<>2
 GMESSAGE = mess(29,117,1) : mkstat=2
Elsif dim([M]SNS)>=0 & [F:TPY]SNS<>3 & [F:TPY]SNS<>[M]SNS
 GMESSAGE=mess(35,105,1)-mess([F:TPY]SNS,661,1) : mkstat=2
Else
 Call CONTEXE([F:TPY]ACS) From CPTSUB
Endif
End

Subprog C_ALLUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo USR : Grizo USR
Else
 Actzo USR
Endif
End

Subprog AS_USR(VALEUR)
Variable Char     VALEUR
If [M]ALLUSR = 2 : VALEUR="" : mkstat = 2
Elsif VALEUR="" : VALEUR = GUSER
Endif
End

Subprog C_ALLCUR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CUR,GRPCUR : Grizo CUR,GRPCUR
Else
 Actzo CUR
 If [M]CUR<>"" : Effzo GRPCUR : Grizo GRPCUR : Else : Actzo GRPCUR : Endif
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char VALEUR
If [M]ALLCUR=2 : mkstat=1 : Endif
End

Subprog C_CUR(VALEUR)
Variable Char VALEUR
If VALEUR<>""
 Effzo GRPCUR : Grizo GRPCUR
Else
 Actzo GRPCUR
Endif
End

Subprog AS_GRPCUR(VALEUR)
Variable Char    VALEUR()
If [M]ALLCUR=2 | [M]CUR<>"" : mkstat=1 : Endif
End

Subprog AS_ALLBAN(VALEUR)
Variable Integer  VALEUR
If [M]ALLPAY=1 : mkstat=1 : Endif
End

Subprog AS_BAN(VALEUR)
Variable Char     VALEUR
If [M]ALLPAY=1 | [M]ALLBAN=2 : mkstat=1 : Endif
End

Subprog C_ALLLOT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo LOT : Grizo LOT
Else
 Actzo LOT
Endif
End

Subprog AS_LOT(VALEUR)
Variable Char    VALEUR()
If [M]ALLLOT=2 : mkstat=1 : Endif
End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
If !clalev([F:PYL]) : Local File PAYLOT [PYL] : Endif
Call LECTURE("PYL",VALEUR,"") From CONTOBJ
If fstat : End
Elsif [M]CPY<>"" & [F:PYL]CPY<>[M]CPY
 GMESSAGE=mess(110,121,1)-[F:PYL]CPY : mkstat=2 : End
Elsif [M]ALLTPY<>2 & [F:PYL]PAYTYP<>[M]TPY
 GMESSAGE=mess(111,121,1)-[F:PYL]PAYTYP : mkstat=2 : End
Endif
Call LEC_TPY_LEG(GCURLEG,[F:PYL]PAYTYP) From CPTLEC
If fstat | [F:TPY]STA4<>2
 GMESSAGE=mess(29,117,1) : mkstat=2 : End
Endif
End

Subprog AV_INI(VALEUR)
Variable Char VALEUR()
If dim([M]ALLCPY)>0
 If [M]ALLCPY=2
  Effzo CPY,FCY : Grizo CPY,FCY
  [M]ALLFCY=2 : Affzo ALLFCY : Grizo ALLFCY
 Else
  Actzo CPY,ALLFCY
 Endif
Endif
If dim([M]ALLFCY)>0
 If [M]ALLFCY=2 : Effzo FCY : Grizo FCY : Else : Actzo FCY : Endif
Endif
If dim([M]ALLUSR)>0
 If [M]ALLUSR=2 : Effzo USR : Grizo USR : Else : Actzo USR : Endif
Endif
If dim([M]ALLCUR)>0
 If [M]ALLCUR=2
  Effzo CUR,GRPCUR : Grizo CUR,GRPCUR
 Else
  Actzo CUR
  If [M]CUR<>"" : Grizo GRPCUR : Else : Actzo GRPCUR : Endif
 Endif
Endif
If dim([M]ALLLOT)>0
 If [M]ALLLOT=2 : Effzo LOT : Grizo LOT : Else : Actzo LOT : Endif
Endif
If dim([M]ALLPAY)>0
 If [M]ALLPAY<>2
  Grizo ALLBAN,BAN
 Else
  Actzo ALLBAN
  If [M]ALLBAN=2
   Grizo BAN
  Else
   Actzo BAN
  Endif
 Endif
Endif
If GBIDC1<>""
 [M]ALLTPY = 1 : [M]TPY = GBIDC1
 Affzo [M]ALLTPY, TPY
 If dim(ZTPY)>0 : Affzo ZTPY : Endif
 Grizo ALLTPY, TPY
Else
 If dim([M]ALLTPY)>0
  If [M]ALLTPY=2 : Effzo TPY : Grizo TPY : Else : Actzo TPY : Endif
 Endif
Endif
End

###################################
## Etiquettes de l'écran BANAFFA ##
###################################

Subprog AS_AMT(VALEUR)
Variable Decimal  VALEUR
Raz [M]AMT
Local Char    CRITCUR(255) , CRITTPY(255), FILTSUP(255), FILTSPE(255)
Local Decimal MT
Local Integer STAT
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
If !clalev([F:GCU]) : Local File GRPCUR    [GCU] : Endif
If !clalev([F:PYH]) : Local File PAYMENTH  [PYH] : Endif
If !clalev([F:TCH]) : Local File TABCHANGE [TCH] : Endif
If !clalev([F:TCU]) : Local File TABCUR    [TCU] : Endif

Gosub CRITTPY From BANAFFM
If [L]CRITTPY<>""
 Gosub FILTRE From BANAFFM
 If [L]CRITCUR="" : [L]CRITCUR="1" : Endif
 If [L]FILTSPE="" : [L]FILTSPE="1" : Endif   :# Filtre spécifique utilisateur
 For [PYH]PYH0 Where evalue([L]CRITTPY) & evalue([L]CRITCUR) & evalue([L]FILTSUP) & evalue([L]FILTSPE)
  Call LEC_TPY_LEG(GCURLEG,[F:PYH]PAYTYP) From CPTLEC
  Raz [L]MT
  Call CONVERT([F:PYH]CUR,[M]CURAMT,[M]CURAMT,[F:TPY]RATTYP,[F:PYH]ACCDAT,
&              [F:PYH]AMTCUR,[L]MT,[L]STAT) From TRTDEV
  [M]AMT += [L]MT
 Next : # [PYH]
Endif
Raz [M]EURMT1
[M]EURCUR = GEURO
If [M]CURAMT<>GEURO
 Call LECTURE("TCU",[M]CURAMT,"") From CONTOBJ
 If [F:TCU]EURFLG=2
  Call CONVERT([M]CURAMT,GEURO,[M]CURAMT,[F:TPY]RATTYP,[F:PYH]ACCDAT,
&              [M]AMT,[M]EURMT1,[L]STAT) From TRTDEV
  If [L]STAT | [M]EURMT1=0
   Raz [M]EURMT1
  Else
   [M]EURCUR = GEURO
  Endif
  Affzo
 Endif
Endif
VALEUR = [M]AMT
Affzo AMT, EURMT1, EURCUR
mkstat=2
End

Subprog IB_POO
If !clalev([F:POO]) : Local File POOL   [POO] : Endif
Local Char CRT(250)
Raz CRT
CRT = "CPY='"+[M]CPY+"'"
If [M]FCY<>"" : CRT += " & (FCY='' | FCY='"+[M]FCY+"')" : Endif
Filter [POO] Where evalue(CRT)
Read [POO] First
If !fstat
     GBOUT1 = mess(54,15,1)    # Pool Bancaire
Else Raz GBOUT1
Endif
Filter [POO]
End


Subprog C_POO(VALEUR)
Variable Char     VALEUR
If VALEUR="" : [M]OLDFLG=0 : End : Endif
If !clalev([F:POO]) : Local File POOL      [POO] : Endif
If !clalev([F:BAN]) : Local File BANK      [BAN] : Endif
Call CONTROLE("POO","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
If [F:POO]CPY<>[M]CPY : # Société
 GMESSAGE = mess(2,45,1)-[F:POO]CPY : mkstat=2
Elsif [F:POO]FCY<>"" & [M]FCY<>"" & [F:POO]FCY<>[M]FCY : # Site
 GMESSAGE = mess(3,45,1)-[F:POO]FCY : mkstat=2
Else
 For [POO]POO0 Where POO=VALEUR
  Call LECTURE("BAN",[F:POO]BAN,"") From CONTOBJ
  If dim([F:BAN]ACS)>0
   Call CONTEXE([F:BAN]ACS) From CPTSUB
   If mkstat : Break : Endif
  Endif
  # Pool bancaire POO \ Paramétrage à revoir
  If [F:BAN]CPY<>[F:POO]CPY | ([F:POO]FCY="" & [F:BAN]FCY<>"")
&    | ([F:POO]FCY<>"" & [F:BAN]FCY<>"" & [F:BAN]FCY<>[F:POO]FCY)
   GMESSAGE=mess(54,15,1)-VALEUR+"\"+mess(86,105,1) : mkstat=2 : Break
  Endif
 Next : # [POO]
Endif
End

Subprog AM_POO(VALEUR)
Variable Char     VALEUR
Local Integer NOL
If !clalev([F:POO]) : Local File POOL   [POO] : Endif
Effzo 15
# Chargement du pool
For [POO]POO0 Where POO=VALEUR
 [M]BANAFF(NOL)  = [F:POO]BAN
 [M]PRC(NOL)     = [F:POO]PRC
 Call BANQUE([F:POO]BAN,NOL)
 If dim([M]BANCUR)>0
  [M]BANCUR(NOL)  = [F:BAN]CUR
 Endif
 NOL+=1
Next : # [POO]
[M]NB = NOL
Affzo 15
[M]OLDFLG=0
End

Subprog AS_FLGBLCNEG(VALEUR)
Variable Integer VALEUR
If [M]POO="" : mkstat=1 : Endif
End

Subprog C_FLGBLCNEG(VALEUR)
Variable Integer VALEUR
If [M]OLDFLG=VALEUR | [M]NB=0 : End : Endif
Local Decimal BASE , MT, PC
Local Integer I
If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
Call LECTURE("TCU",[M]CURAMT,"") From CONTOBJ
[L]BASE = [M]AMT
Case [M]SNS
 When 1  :# Dépense
  For NOL=0 To [M]NB-1
   [L]PC = arr([M]PRC(NOL)/100*[M]AMT,[F:TCU]CURRND)
   If VALEUR=2
    [M]AMTBAN(NOL) = min([L]BASE,min([L]PC,max(0,[M]VIRBLC(NOL))))
    # 0 si découvert, sinon pas plus que le solde
   Else
    [M]AMTBAN(NOL) = min([L]BASE,[L]PC)
   Endif
   [L]BASE -= [M]AMTBAN(NOL)
  Next NOL
  If [L]BASE>0 : # GH 19/10/00 bug 6559
   I=0
   If VALEUR=2
    MT=[M]VIRBLC(I)-[M]AMTBAN(I)
    For NOL=1 To [M]NB-1
     PC=[M]VIRBLC(NOL)-[M]AMTBAN(NOL)
     If PC>MT : I=NOL : MT=PC : Endif
    Next NOL
   Endif
   [M]AMTBAN(I) += [L]BASE
  Endif
 When 2  :# Recette
  # Prise en compte des soldes négatifs
  For NOL=0 To [M]NB-1
   If VALEUR=2 & [M]VIRBLC(NOL)<0  :# Découvert
    [M]AMTBAN(NOL) = min([L]BASE,-[M]VIRBLC(NOL))
    [L]BASE -= [M]AMTBAN(NOL)
   Else [M]AMTBAN(NOL)=0
   Endif
  Next NOL
  If [L]BASE>0
   For NOL=0 To [M]NB-1
    [L]MT = [M]AMTBAN(NOL)
    [L]PC = arr([M]PRC(NOL)/100*[M]AMT,[F:TCU]CURRND)
    [M]AMTBAN(NOL) = max(MT,min(BASE+MT,PC))
    [L]BASE += MT-[M]AMTBAN(NOL)
   Next NOL
  Endif
Endcase
Affzo 15
[M]OLDFLG=VALEUR
End

Subprog C_BANAFF(VALEUR)
Variable Char     VALEUR
Local Integer I, NOL : NOL=indice
If VALEUR<>[M]BANAFF(NOL)
 I=find(VALEUR,[M]BANAFF(0..[M]NB-1))
 If I : GMESSAGE=mess(29,100,1)-num$(I) : mkstat=2 : End : Endif
Endif
If !clalev([F:BAN]) : Local File BANK [BAN] : Endif
Call LECTURE("BAN",VALEUR,"") From CONTOBJ
If [F:BAN]CPY<>[M]CPY : # Société
 GMESSAGE = mess(2,45,1)-[F:BAN]CPY : mkstat=2
Elsif [F:BAN]FCY<>"" & [M]FCY<>"" & [F:BAN]FCY<>[M]FCY : # Site
 GMESSAGE = mess(3,45,1)-[F:BAN]FCY : mkstat=2
Endif
End

Subprog AM_BANAFF(VALEUR)
Variable Char     VALEUR
Call BANQUE(VALEUR,indice)
[M]BANCUR(nolign-1) = [F:BAN]CUR
Affzo [M]BANCUR(nolign-1)
End

Subprog BANQUE(BAN,NOL)
Value Char    BAN()
Value Integer NOL
Local Char DEVLED(GLONCUR)
Local Integer STAT
Local Integer SNSBNQ
If !clalev([F:BAN]) : Local File BANK       [BAN] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:RBK]) : Local File RELBANK    [RBK] : Endif
Call LECTURE("BAN",[L]BAN,"") From CONTOBJ
Call LECTURE("CPY",[F:BAN]CPY,"") From CONTOBJ
Call SETMAINREF([F:CPY]CPY,GTYPGEN,GTYPANA) From CPTDIV
Call SETCUR(1,[F:CPY]CPY,DEVLED) From CPTDIV
# Règlements non validés
Call CONVERT([F:BAN]CUR,DEVLED,DEVLED,[F:BAN]CHGTYP,datesyst,
&            [F:BAN]PAYTPY,[M]VIRBLC(NOL),[L]STAT) From TRTDEV
# Compte de banque
Call SOLDAT("","",[F:BAN]BANACC,"",GTYPGEN,[F:BAN]CPY,[F:BAN]FCY,DEVLED,[F:BAN]CHGTYP,
&           datesyst,[M]BANBLC(NOL)) From CNSCPTSTD
[M]VIRBLC(NOL) += [M]BANBLC(NOL)
# Solde relevé
Filter [RBK] Where BAN=[L]BAN & RECTYP=3
Read [RBK]RBK1 Last
If fstat=0
 Call CONVERT([F:RBK]CUR,DEVLED,DEVLED,[F:BAN]CHGTYP,[F:RBK]OPEDAT,
&             [F:RBK]AMTCUR,[M]RBKBLC(NOL),[L]STAT) From TRTDEV
 Call PARAML([F:BAN]CPY,"SNSBNQ",GDIV(0)) From ADOVAL
 SNSBNQ = val(GDIV(0))
 If ([F:RBK]SNS=1 & SNSBNQ=1) | ([F:RBK]SNS=-1 & SNSBNQ=2)
   # Débit
 Else
  [M]RBKBLC(NOL) *=-1  : # Crédit
 Endif
Else
 [M]RBKBLC(NOL)=0
Endif
Filter [RBK]
End

###################################
## Etiquettes de l'écran BANAFFM ##
###################################
Subprog C_BAN(VALEUR)
Variable Char     VALEUR
Local Integer OK, NOL : NOL = nolign-1
If !clalev([F:BAN]) : Local File BANK       [BAN] : Endif
If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif
If VALEUR<>"" | [M:BAM]DACBAN(NOL)=1
 Case [M:BAM]BANCSH(NOL)
  When 1 : Call CONTROLE("BAN","",VALEUR,"",mkstat) From CONTOBJ
  When 2 : Call CONTROLE("CAI","",VALEUR,"",mkstat) From CONTOBJ
 Endcase
 If mkstat : End : Endif
Endif
If VALEUR<>""
 # Accessibilité
 If dim([F:BAN]ACS)>0
  Call CONTEXE([F:BAN]ACS) From CPTSUB
  If mkstat : End : Endif
 Endif
 If [F:BAN]FCY<>"" & [M:BAM]FCY(NOL)<>[F:BAN]FCY
  # Banque/Caisse du site FCY
  GMESSAGE=mess([M:BAM]BANCSH(NOL),653,1)-mess(4,117,1)-[F:BAN]FCY
  mkstat=2
 Elsif [F:BAN]CPY<>"" & [M:BAM]CPY(NOL)<>[F:BAN]CPY
  # Banque/Caisse de la société CPY
  GMESSAGE=mess([M:BAM]BANCSH(NOL),653,1)-mess(5,117,1)-[F:BAN]CPY
  mkstat=2
 Elsif [M:BAM]AMTBANFLG(NOL) & !find([F:BAN]CUR,[M:BAM]CUR(NOL),[M:BAM]OLDBANCUR(NOL))
  Call LECTURE("PAY",[M]NUM(NOL),"") From CONTOBJ
  OK=0
  Call LECTURE("TCU",[F:BAN]CUR,"") From CONTOBJ
  If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=[F:PYH]ACCDAT)
   Call LECTURE("TCU",[M:BAM]CUR(NOL),"") From CONTOBJ
   If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=[F:PYH]ACCDAT)
    OK=1
   Endif
  Endif
  If !OK
   # Banque et devise incompatibles
   GMESSAGE=mess(30,117,1)
   mkstat=2 : End
  Endif
 Endif
 If mkstat : End : Endif
 Call LECTURE("PAY",[M]NUM(NOL),"") From CONTOBJ
 #Issue X3-75462 by MRDAB
 If (func AFNC.ACTIV("FIFRC"))
  If (func AFNC.PARAM("FIFRC", [M:BAM]FCY(NOL)) = "2")
    If func FIFOCONVAR_CSTD.FLDFIFCP_CTL(VALEUR, [F:PYH]ACCDAT)
      If func FIFOCONVAR_CSTD.IS_FIFO_EXIST(VALEUR, [F:PYH]ACCDAT) = 1
        GMESSAGE = mess(27,117,1)-[F:PYH]NUM-":"-mess(29,7708,1)
        mkstat=2 : End
      Endif
    Endif
  Endif
 Endif
 #Issue end
 Call CONTBAN([F:PYH]ACCDAT,VALEUR,[M:BAM]CUR(NOL)) From CPTSUB
Endif
End

Subprog B2_BAN(VALEUR)
Variable Char     VALEUR
If VALEUR<>""
 If !clalev([F:BAN]) : Local File BANK       [BAN] : Endif
 If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif
 Local Integer I, OK
 Call C_BAN(VALEUR) From SUBBAC
 If mkstat : End : Endif
 [M:BAM]BAN(nolign-1) = VALEUR
 For I=nolign To [M:BAM]NB
  If [M:BAM]BANCSH(I)=[M:BAM]BANCSH(nolign-1)
&    & ([F:BAN]FCY="" | [M:BAM]FCY(I)=[F:BAN]FCY)
&    & ([F:BAN]CPY="" | [M:BAM]CPY(I)=[F:BAN]CPY)
   If [M:BAM]AMTBANFLG(I) & !find([F:BAN]CUR,[M:BAM]CUR(I),[M:BAM]OLDBANCUR(I))
    Call LECTURE("PAY",[M]NUM(NOL),"") From CONTOBJ
    OK=0
    Call LECTURE("TCU",[F:BAN]CUR,"") From CONTOBJ
    If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=[F:PYH]ACCDAT)
     Call LECTURE("TCU",[M:BAM]CUR(NOL),"") From CONTOBJ
     If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=[F:PYH]ACCDAT)
      OK=1
     Endif
    Endif
   Else OK=1
   Endif
   If OK
    [M:BAM]BAN(I) = VALEUR
   Endif
  Endif
 Next I
 Affzo [BAM]
 mkstat=2
Endif
End

Subprog C_ALLBAN(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo BAN : Grizo BAN
Else
 Actzo BAN
Endif
End

Subprog C_ALLPAY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo ALLBAN,BAN
Else
 Effzo ALLBAN,BAN : Grizo ALLBAN,BAN
Endif
End

