#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
# UTIGPA27  Module GPAO     Table WEIGHING,  Initialisation du champ ENGCOD       #
# ( centrale de pesée)                                                            #
# la présence de la table est soumise à la valeur du code activité MWM            #
###################################################################################
# mm 05.11: évolution Réconciliation par phase (spec. 048)                        #
###################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "X3INDV6" Then
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      Read [ADS]DOSSIER=[L]DOSSIER
      If fstat Then
        Raz [F:ADS]
      Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("UTIGPA27: Update field of WEIGHING table") From LECFIC
      Call MAJ_UTIGPA27(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
 Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIGPA27: Update field of WEIGHING table") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTIGPA27(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
# Initialisation du champ [F:WGG]ENGCOD
##########################################################################
Subprog MAJ_UTIGPA27(DOSSIER)
Value Char DOSSIER
Call ECR_TRACE("UTIGPA27: Process Start on : "+DOSSIER, 0) From GESECRAN

If filinfo(filpath("FIL","WEIGHING","fde",DOSSIER),0) <= 0     End Endif
#----- Ouverture des fichiers -----#
If clalev([F:WGG])  =0  Local File =DOSSIER+".WEIGHING"       [WGG] : Endif

Call DEBTRANS From GLOCK
Trbegin [WGG]
For [WGG]
    Readlock [WGG] Curr
    If !fstat
      If [F:WGG]ENGCOD = 0    :  [F:WGG]ENGCOD= 1 : Endif
      # en cas de pesée annulée : devient engagée mais sans date pour la distinguer d'une vraie pesée engagée
      # idem au fonctionnement du flag réconcilié RCLCOD
      If [F:WGG]RCLCOD = 2 & [F:WGG]RCLDAT=[0/0/0]
         [F:WGG]ENGCOD= 2
      Endif
      Rewrite [WGG]
      If fstat
          Call ECR_TRACE("File WEIGHING"-[F:WGG]ENGCOD+", ERROR ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
Next
Commit
Close Local File [WGG]

Call ECR_TRACE("UTIGPA27 : End Process",0) From GESECRAN
End
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIGPA27(APPLI)
End


#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTIGPA27(APPLI)
End









