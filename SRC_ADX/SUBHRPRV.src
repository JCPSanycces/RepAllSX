#<AdxTL>@(#)0.0.0.0 $Revision$
Call OBJET("HRPRV",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
Endcase
Return

$OUVRE
If clalev ([F:PRV])=0 : Local File HONPRV[PRV]: Endif
Return

$INICRE
$INIMOD
[F:PRV]CODAVN=""
[F:PRV]CODMOD=""
[F:PRV]CODRAT=""

If [M]NFLG1=2 : [F:PRV]CODAVN+="N" : Endif
If [M]LFLG1=2 : [F:PRV]CODAVN+="L" : Endif
If [M]VFLG1=2 : [F:PRV]CODAVN+="V" : Endif
If [M]AFLG1=2 : [F:PRV]CODAVN+="A" : Endif
If [M]NTIC=2  : [F:PRV]CODAVN+="T" : Endif

If [M]FFLG2=2 : [F:PRV]CODMOD+="F" : Endif
If [M]RFLG2=2 : [F:PRV]CODMOD+="R" : Endif
If [M]RFLG2=2 : [F:PRV]CODMOD+="P" : Endif

If [M]RFLG3=2 : [F:PRV]CODRAT="R" : Elsif [M]DFLG3=2 : [F:PRV]CODRAT="D" : Endif
Return

Subprog C_FIRNAM(VALEUR)
Variable Char    VALEUR()
If [M]PHYPSL=2 & [M]SURNAM<>"" & VALEUR =""
 #Personne physique : prénom obligatoire.
 GMESSAGE = mess(73,122,1)
 mkstat=2 : End
Endif
End

Subprog C_PHYPSL(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M]SURNAM<>"" & [M]FIRNAM =""
 #Personne physique : prénom obligatoire.
 GMESSAGE = mess(73,122,1)
 mkstat=2 : End
Endif
End

Subprog C_PRVNAM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]SURNAM=""
 #Le nom ou la raison sociale du prestataire est obligatoire.
 GMESSAGE = mess(72,122,1)
 mkstat=2 : End
Endif
End

Subprog C_CRY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<>[M]CRY
 Call LECTURE("TCY",VALEUR,"") From CONTOBJ
Endif
End

Subprog AM_CODPOS(VALEUR)
Variable Char    VALEUR()
Read [POS]POS0(3) = [M]CRY;VALEUR;[M]CTY
If fstat<=2
 [M]CODSEE = [F:POS]POSCTYCOD
 Affzo CODSEE
Endif
End

Subprog AM_ADD3(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 #61590
 VALEUR=toupper(VALEUR)
 #
 Read [POS]POS1(2) = [M]CRY;VALEUR
 If fstat<=2
  [M]CODSEE = [F:POS]POSCTYCOD
  Affzo CODSEE
 Endif
Endif
End

Subprog AS_CODSEE(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]CRY<>"" & [M]CODPOS<>"" & [M]CTY<>""
 Read [POS]POS1 = [M]CRY;[M]CTY;[M]CODPOS
 If !fstat
  VALEUR = [F:POS]POSCTYCOD
 Endif
Endif
End


Subprog AM_CTY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 #61590
 VALEUR=toupper(VALEUR)
 #
 #49894
 #Read [POS]POS1(2) = [M]CRY;VALEUR
 Read [POS]POS1 = [M]CRY;VALEUR;[M]CODPOS
 If fstat<=2
  [M]CODSEE = [F:POS]POSCTYCOD
  Affzo CODSEE
 Endif
Endif
End


######################################################################################

######################################################################################
## RFL3 & DFLG3 s'excluent
######################################################################################
Subprog AM_RFLG3(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : [M]DFLG3=1 : Affzo[M]DFLG3 : Endif
End

Subprog AM_DFLG3(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : [M]RFLG3=1 : Affzo[M]RFLG3 : Endif
End


