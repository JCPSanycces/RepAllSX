#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe ASYRREQ


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "ADELETE_BEFORE"          : Gosub ADELETE_BEFORE
      When "ADELETE_AFTER"           : Gosub ADELETE_AFTER
    Endcase
Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param RULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
 When "_AINTRQT" : Gosub INTRQT
 When "_ARELRQT" : Gosub RELRQT
Endcase
Return


###############################################
$ADELETE_BEFORE
If this.NUMREQ=0
  ASTATUS = fmet this.ASETERROR("",mess(120,133,1),[V]CST_AERROR)
  Return
Endif
Local File ABATRQT [ABR]
#Controles
Read [ABR]NUMREQ=this.NUMREQ
If fstat | [F:ABR]FLAG<>1
  ASTATUS = fmet this.ASETERROR("",mess(22,134,1),[V]CST_AERROR)
Endif
Return

###############################################
$ADELETE_AFTER
If this.NUMREQ=0
  ASTATUS = fmet this.ASETERROR("",mess(120,133,1),[V]CST_AERROR)
  Return
Endif
Local File ABATRQT [ABR], ABATRQTL [ABL], ABATPAR [ABP]
#Controles
Read [ABR]NUMREQ=this.NUMREQ
If fstat
 Local Integer REQUETE, NUMERO
 REQUETE=this.NUMREQ
 NUMERO=this.NUMGRP
 #Suppression
 Gosub SUPPRIME
Endif

Return

$SUPPRIME
 Read [ABP]SPOOL First
 Call EFF_JOB(this.JOB) From EPURRQT
 Gosub TR_SUPP
Return

$TR_SUPP
GOK = 1
 If NUMERO>0
  For [F:ABR] Where GRP<>"" & NUMGRP=NUMERO & find(FLAG,1,4)>0
   Delete [ABL] Where NUMREQ=[F:ABR]NUMREQ
   Delete [F:ABR] Curr
  Next ABR
 Else
   Delete [ABL] Where NUMREQ=REQUETE
 Endif
Return

#######################################################"""
$INTRQT
Local Integer OK
OK=1
[L]ARET_VALUE=[V]CST_AOK
Local File ABATRQT [ABR], ABATRQTL [ABL], ABATPAR [ABP]
#Controles
Read [ABR]NUMREQ=[L]NUMREQ
If fstat | [F:ABR]FLAG<>2
  ASTATUS = fmet this.ASETERROR("",mess(113,134,1),[V]CST_AERROR)
Endif
If ASTATUS
  Return
Endif
 Local Integer REQUETE,NUMERO
 REQUETE=[F:ABR]NUMREQ
 NUMERO=[F:ABR]NUMGRP
Gosub TR_INTERR
Return


$TR_INTERR
Local Integer OLDFLAG,NEWFLAG
Local Char    ERRMESS(250)
Local Char    HH(10), HS(10)
Local Integer SS
Local Date    DD

Trbegin [ABR]

 Readlock [ABR]NUMREQ = REQUETE
 If fstat=1
  GOK=-1 : GLOCK="$ABATRQT"-num$(REQUETE) : Goto ROLL_INTERR
 Elsif fstat>=5
  GOK=0 : Call RSTA("ABR",num$(REQUETE),1,ERRMESS) From GLOCK_SYRA
  Goto AB_INTERR
 Endif

 OLDFLAG=[F:ABR]FLAG
 If [F:ABR]FLAG=2 : NEWFLAG=5
 Elsif [F:ABR]FLAG=1 : NEWFLAG=7
 Else NEWFLAG=[F:ABR]FLAG
 Endif

 Update [ABR]
& Where NUMREQ=[L]REQUETE
& With  FLAG = NEWFLAG
&     , MOTINT = mess(9,134,1)
&     , USRINT = GACTX.USER
 If fstat
  GOK=0 : Call RSTA("ABR",num$(REQUETE),1,ERRMESS) From GLOCK_SYRA
  Goto AB_INTERR
 Endif

 ## 1: En attente
 ## 2: En cours
 ## 3: Terminée
 ## 4: Bloquée
 ## 5: A tuer
 ## 6: Avortée
 ## 7: Erreur
 ## 8: Hors délai
 ## 9: Warning

 # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
 Call GET_INSTANT_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS, [L]SS) From SERVEUR
 If [F:ABR]NUMGRP<>0
  GRPNUM = [F:ABR]NUMGRP
  Update [ABR]
& Where NUMGRP=[L]GRPNUM & FLAG=4
& With  FLAG = 6
&     , MOTINT = mess(9,134,1)
&     , USRINT = GACTX.USER
&     , DFIN   = [L]DD
&     , HFIN   = [L]HS
  If fstat
   GOK=0 : Call RSTA("ABR",num$([F:ABR]NUMREQ),1,ERRMESS) From GLOCK_SYRA
   Goto AB_INTERR
  Endif
 Endif

Commit
Return

$AB_INTERR
Rollback
Return

$ROLL_INTERR
Rollback
Call ROLL(ERRMESS) From GLOCK_SYRA
If GROLL : Return : Else : Goto TR_INTERR : Endif


#######################################################"""
$RELRQT
Local Integer OK
OK=1

[L]ARET_VALUE=[V]CST_AOK
Gosub RELANCE
Return




$RELANCE
Local File    ABATRQT [ABR] , ABATPAR [ABP] , ABATTAC [ABT] , ABATHOR [ABH] , ABATCAL [ABC]
&           , ABATGRP [ABG] , ABATRQTL [ABL]
Local Integer I , REQUETE , OLDGRP , OLDREQ
Local Char    TACHE(GLONABT) , DOSSIER(GLONADS) , USER(GLONAUS) , CRITERE(80)
Read [ABR]NUMREQ = [L]NUMREQ
If !fstat
 If [F:ABR]GRP<>""
  OLDGRP = [F:ABR]NUMGRP
 Endif
Else
 Return
Endif
If OK =2
 CRITERE = "NUMGRP="+num$([F:ABR]NUMGRP)
Else
 CRITERE = "NUMREQ="+num$([F:ABR]NUMREQ)
Endif
For [ABR] Where evalue(CRITERE)
 TACHE   = [F:ABR]TACHE
 DOSSIER = [F:ABR]DOSSIER
 USER    = [F:ABR]USER
Next ABR
If OK=2
 Read [F:ABR]NUMREQ = OLDGRP
 If fstat : Return : Endif
Endif
Call DEBTRANS From GLOCK_SYRA
Gosub TR_RELAN
If GOK<1
[L]ASTATUS=fmet this.ASETERROR("",[L]ERRMESS,[V]CST_AERROR)
Else
[L]ASTATUS=fmet this.ASETERROR("",func ASYRFNC.MES1(mess(117,134,1), WNUMREQ),[V]CST_AINFO)
Endif
Return

$TR_RELAN
Local Char WNUMREQ(20)
Local Char ERRMESS(250)
Local Integer HH , MM
Local Date    DATE_DD, DD
Local Char    CHAR_HH(10), CHAR_HS(10)

# X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
Call SCHEDULING_DATE_TIME   ( [L]DATE_DD, [L]CHAR_HH, [L]CHAR_HS) From SERVEUR
GOK = 1
Trbegin [ABR], [ABP]
 DD = [L]DATE_DD
 HH = val(left$([L]CHAR_HH,2))
 MM = val(mid$([L]CHAR_HH,3,2))
 If GADONIX=2
  MM += 1 : # mb 28.7.3 On est plus rapide pour modifier, si on s'est planté !
 Else
  MM += 5
 Endif
 If MM>59 : HH += 1 : MM -= 60 : Endif
 If HH>23 : DD += 1 : HH -= 24 : Endif
 [F:ABR]DAT    = DD
 [F:ABR]HEURE  = format$("N0:2#",HH)+format$("N0:2#",MM)
 # Issue X3-59123 - 2018-06-08 by CCC : if the task is in a group, wait for the end of all tasks creation to run the first sequence
 If OK<>2
     [F:ABR]FLAG   = 1
 Else
    [F:ABR]FLAG   = 4
 Endif
 #[F:ABR]USER   = GUSER : ici on garde le user
 #109897, X3-55215
 Raz [F:ABR]SERVER, [F:ABR]PORT, [F:ABR]PROCESS, [F:ABR]SESSIONID
 Raz [F:ABR]MOTINT, [F:ABR]USRINT, [F:ABR]JOB
 Raz [F:ABR]FRQ, [F:ABR]FRQFIN, [F:ABR]EPUR, [F:ABR]ONE, [F:ABR]IMPETX
 Raz [F:ABR]HDEB, [F:ABR]HFIN, [F:ABR]DFIN
 Readlock [ABP]SPOOL First With lockwait=5
 If fstat=1
  GOK = -1 : GLOCK="$ABATPAR" : Goto ROLL_RELAN
 Elsif fstat
  GOK = 0 : Call RSTA("ABP","",1,ERRMESS) From GLOCK_SYRA : Goto AB_RELAN
 Endif
 OLDREQ = [F:ABR]NUMREQ
 WNUMREQ=num$([F:ABP]NUMREQ)
 [F:ABR]NUMREQ = [F:ABP]NUMREQ
 If [F:ABR]GRP <> ""
  [F:ABR]NUMGRP = [F:ABR]NUMREQ
 Endif
 If OK <> 2
  Raz [F:ABR]GRP,[F:ABR]NUMGRP
 Endif
 REQUETE = [F:ABR]NUMREQ
 [F:ABP]NUMREQ += 1
 Write [ABR]
 If fstat
  GOK = 0 : Call FSTA("ABR",1,ERRMESS) From GLOCK_SYRA : Goto AB_RELAN
 Endif
 For [ABL] Where NUMREQ = OLDREQ
  [F:ABL]NUMREQ = [F:ABR]NUMREQ
  Write [ABL]
  If fstat
   GOK = 0 : Call FSTA("ABL",1,ERRMESS) From GLOCK_SYRA : Break
  Endif
 Next ABL
 If GOK=0 : Goto AB_RELAN : Endif
 If OK =2
  For [ABR] Where NUMGRP=OLDGRP & NUMREQ <> OLDGRP
   OLDREQ = [F:ABR]NUMREQ
   [F:ABR]NUMREQ = [F:ABP]NUMREQ
   [F:ABP]NUMREQ += 1
   [F:ABR]NUMGRP = REQUETE
   [F:ABR]DAT    = DD
   [F:ABR]HEURE  = format$("N0:2#",HH)+format$("N0:2#",MM)
   [F:ABR]FLAG   = 4
   [F:ABR]USER   = GUSER
   #109897, X3-55215
   Raz [F:ABR]SERVER, [F:ABR]PORT, [F:ABR]PROCESS, [F:ABR]SESSIONID
   Write [ABR]
   If fstat
    GOK = 0 : Call FSTA("ABR",1,ERRMESS) From GLOCK_SYRA : Break
   Endif
   For [ABL] Where NUMREQ = OLDREQ
    [F:ABL]NUMREQ = [F:ABR]NUMREQ
    Write [ABL]
    If fstat
     GOK = 0 : Call FSTA("ABL",1,ERRMESS) From GLOCK_SYRA : Break 2
    Endif
   Next ABL
  Next ABR
  If GOK=0 : Goto AB_RELAN : Endif
 Endif
 Rewrite [ABP]
 If fstat
  GOK = 0 : Call FSTA("ABP",1,ERRMESS) From GLOCK_SYRA : Goto AB_RELAN
 Endif

 # Issue X3-59123 - 2018-06-08 by CCC : Run all tasks of the first sequence in the group
 If OK=2 & func REQUETES.RUN_NEXT_GRP_SEQ(REQUETE,ERRMESS)<>[V]CST_AOK
     GOK=0
     Goto AB_RELAN
 Endif

Commit
Return

$AB_RELAN
Rollback
Return

$ROLL_RELAN
Rollback
Call ROLL(ERRMESS) From GLOCK_SYRA
If GROLL : Return : Else : Goto TR_RELAN : Endif


#-------------------------------------------------------------#
Funprog UPD_CLOBFILE(AINSTANCE,APRONAME,NAME)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Value Char NAME
#on ne fait rien
End 0
#-------------------------------------------------------------#
Funprog INS_CLOBFILE(AINSTANCE,APRONAME,NAME)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Value Char NAME
#on ne fait rien
End 0
#-------------------------------------------------------------#
Funprog GET_CLOBFILE(AINSTANCE,APRONAME,AVALUE,NAME)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable    Clbfile     AVALUE
Value Char NAME

Gosub GET_FILENAME

Local Char    LINE(255)
If filinfo([L]FICHIER,0) > 0
 Openi [L]FICHIER Using [SYREQ]
 #adxifs="" :
 Iomode adxifs chr$(10)  Using [SYREQ]
 Iomode adxium GUTF8 Using [SYREQ]
 While 1
  Rdseq LINE Using [SYREQ]
  Append AVALUE,LINE+chr$(13)+chr$(10)
  Break (fstat<>0)
 Wend
 Openi Using [SYREQ]
Endif
End 0

#-------------------------------------------------------------#
Funprog GET_CLOBCNT(AINSTANCE,APRONAME,AVALCNT,NAME)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALCNT
Value Char NAME
AVALCNT=""
End 0
#-------------------------------------------------------------#
Funprog GET_CLOBEXIST(AINSTANCE,APRONAME,AEXIST,NAME)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Tinyint     AEXIST
Value Char NAME
Gosub GET_FILENAME
If [L]FICHIER<>""
 [L]AEXIST=1
Else
 [L]AEXIST=0
Endif
End 0
#-------------------------------------------------------------#
Funprog DEL_CLOBFILE(AINSTANCE,APRONAME,NAME)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Value Char NAME
#on ne fait rien
End 0

$GET_FILENAME
Local Char    FICHIER(GDIMFIC), CODE(20), SUF(10)
Local Integer ERR , STAT
For CODE = format$("N0:8#",val(NAME)) , NAME
 FICHIER = func SERVSYS.GET_FILE_RQT(CODE,"tra") : #109897  # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
 Call EXIST(FICHIER,ERR) From ASYRSYS
 If ERR=1
  Return
 Endif
Next CODE
FICHIER=""
Return

