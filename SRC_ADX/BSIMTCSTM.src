#<AdxTL>@(#)2.0.0.0 $Revision$ 
# ##########    SUBJECT :    Bank statement import                                              #
# ##########                 Match all non-matched statements in one run                        #
# ##########                                                                                    #
# ##########    AUTHOR  :    DNE                                                                #
# ##########    DATE    :    2016-07-13                                                         #
# ##########    UPDATES :                                                                       #
# 2016-09-26 Bader Handle MSG as a Clbfile and write MSG into log even if no error
# 2016-11-16 Bader X3-1722: Implementation detailed log
# ############################################################################################# #

# < DEBUG> #################################################################################### #
#End
# </DEBUG> #################################################################################### #


$ACTION
    Case ACTION
        When "INIT"        : Gosub INIT
        When "INIT_DIA"    : Gosub INIT_DIA
        When "EXEC"        : Gosub EXEC
        When Default
    Endcase
Return

$INIT
    If !clalev( [F:BSIIMP] )  : Local File BSIIMP  [BSIIMP]  : Endif # Header import
    If !clalev( [F:BSIIMPD] ) : Local File BSIIMPD [BSIIMPD] : Endif # Details import

    Local Clbfile MSG(4)       # Message from BSI_UNMATCH() function.
    Local Integer STA          # Status from BSI_UNMATCH() function.
    Local Integer I
Return

$INIT_DIA
    Filter [F:BSIIMP] Where FLGMTC <= 1
    [M]NBLIG = 0
    For [F:BSIIMP]BSIIMP0
        [M]STMCOD( [M]NBLIG ) = [F:BSIIMP]STMCOD
        [M]REFBAN( [M]NBLIG ) = [F:BSIIMP]REFBAN
        [M]BAN( [M]NBLIG )    = [F:BSIIMP]BAN
        [M]DATSTR( [M]NBLIG ) = [F:BSIIMP]DATSTR
        [M]DATEND( [M]NBLIG ) = [F:BSIIMP]DATEND
        [M]NBLIG += 1
    Next
    Filter [F:BSIIMP]
Return

$EXEC
    Call OUVRE_TRACE( mess(45,7703,1) ) From LECFIC

    For I = 0 To [M]NBLIG - 1
        # Start database transaction for a single statement.
        Trbegin [F:BSIIMP], [F:BSIIMPD]

        # Run matching routine for the current statement (in [L]STMCOD).
        Call BSI_MATCH_STATEMENT( [M]STMCOD( I ), STA, MSG, 0 ) From BSILIBMTC

        # Check on errors.
        If STA
            Rollback
            Call ECR_TRACE( MSG, 1 )  From GESECRAN
        Else
            Commit
            If MSG <> "" : Call ECR_TRACE( MSG, 1 )  From GESECRAN : Endif
            Call ECR_TRACE( func AFNC.MES1( mess(39,7703,1), [M]STMCOD( I ) ), 0 )  From GESECRAN
        Endif
    Next

    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Return

