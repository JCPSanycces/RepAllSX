#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("TCU",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBTCUB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "LIENS"       : Gosub LIENS
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INICRE
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Gosub CHANGE
 When "FERME"       : Gosub FERME
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
Endcase
If PSUBB
 Gosub ACTION From SUBTCUB
Endif
Return

$FERME
## Relecture de la table des formats
Call INIDEV From GLOBSUP
Return

$LIENS
[M]FM1 = val([F:TCU]CURFMT1)
[M]FM2 = val([F:TCU]CURFMT2)
[M]FM3 = val([F:TCU]CURFMT3)

If dim([M]EURFLG)>0
  If [M]EURFLG<>2
    Grizo [TCU1]EURRAT, EURDAT, CURENDDAT 
  Else 
    Actzo [TCU1]EURRAT, EURDAT, CURENDDAT 
  Endif
Endif
Return

$INICRE
[F:TCU]CURFMT1 = num$([M]FM1)
[F:TCU]CURFMT2 = num$([M]FM2)
[F:TCU]CURFMT3 = num$([M]FM3)
Return

$APRES_MODIF
If COUZON="EURFLG"
  If val(CZ)<>2
    Grizo [TCU1]EURRAT, EURDAT, CURENDDAT 
  Else 
    Actzo [TCU1]EURRAT, EURDAT, CURENDDAT 
  Endif
  Affzo [TCU1]EURRAT, EURDAT, CURENDDAT
Endif
Return

$VERIF_CRE
$VERIF_MOD
Local Decimal DEC1, DEC2, DEC3, DEC4, DEC5
DEC1 = 10*([M]FM1-int([M]FM1))
DEC2 = 10*([M]FM2-int([M]FM2))
DEC3 = 10*([M]FM3-int([M]FM3))
DEC4 = [M]DECNBR
DEC5 = -log([M]CURRND)
OK = 2
If DEC1<>DEC2 or DEC1<>DEC3 or DEC2<>DEC3
 # Incompatibilité entre les formats
 Call AVERTIR(mess(136,126,1),OK) From GESECRAN
Elsif DEC1<>DEC4
 # Attention, incompatibilité entre formats et nombre de décimales
 Call AVERTIR(mess(137,126,1),OK) From GESECRAN
Elsif DEC1<>DEC5
 # Attention, incompatibilité entre formats et arrondi
 Call AVERTIR(mess(138,126,1),OK) From GESECRAN
Endif
If OK<>2 : OK = 0 : Endif
Return

$CREATION
$MODIF
Call MAJTEXTRA([M]INTDES,"TABCUR","INTDES",[M]CUR,"") From ATEXTRA
If GOK<1 : Return : Endif
Call MAJTEXTRA([M]INTSHO,"TABCUR","INTSHO",[M]CUR,"") From ATEXTRA
If GOK<1 : Return : Endif
Return

$ANNULE
Delete [AXX] Where CODFIC="TABCUR" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="TABCUR" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA TABCUR"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

###############################################################
## Etiquettes de contrôle                                    ##
###############################################################
Subprog C_FM1(VALEUR)
Variable Decimal VALEUR
Call VERFMT(VALEUR,20,1)
End

Subprog C_FM2(VALEUR)
Variable Decimal VALEUR
Call VERFMT(VALEUR,10,1)
End

Subprog C_FM3(VALEUR)
Variable Decimal VALEUR
Call VERFMT(VALEUR,20,0)
End

#---------------------------------------
Subprog VERFMT(LONG,MAXLNG,TROIS)
Variable Decimal LONG
Value    Integer MAXLNG
Value    Integer TROIS
Local Integer I, J, D
Local Decimal X
I=int(LONG)
If I=LONG
 D=0
Else
 D = 1
 X = LONG-I
 While X<>int(X) : X *= 10 : Wend
Endif
J = I+D+X
If TROIS : J += int((I-1)/3) : Endif
If J>MAXLNG
 GMESSAGE = mess(150,100,1) : mkstat=2 : End : #  Format trop long
Endif
End

Subprog AM_DECNBR(VALEUR)
Variable Decimal VALEUR
[M]CURRND = 10^-VALEUR : Affzo [M]CURRND
End

