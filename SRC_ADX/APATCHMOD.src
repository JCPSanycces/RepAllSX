#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(250)(1..2) , VALEUR(250)
Raz GNBMASKOUV
#Call TRAITE_CHAR(VALEUR,PARAM,"","APATCH","APATCH",4,"") From GTRAITE
VALEUR = "ECRAN~FRA~STAT~AMK0"
PARAM(1) = nomap
Call SAISIE_CHAR(VALEUR,PARAM,"APATCHMOD","APATCHMOD","") From GSAISIE
End

#---------------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub DEBUT
 When "OK"    : Gosub OK
Endcase
Return

#-------------------------------------#
$OUVRE
Local Char    DOSSIER(GLONADD) , CHAINE(250)
Local Integer L1 , L2 , L3
DOSSIER = PARAM(1)
If DOSSIER="" or DOSSIER=nomap
 Local File APATCHMOD [APH]
 Local File AWRKLNK   [AWM]
 Local File AWRKTAB   [AWK]
 Local File ATABLE    [ATB]
 Local File ATRANSAC  [ATN]
 Local File ATABDIV   [ADI]
Else
 Local File =DOSSIER+".APATCHMOD" [APH]
 Local File =DOSSIER+".AWRKLNK"   [AWM]
 Local File =DOSSIER+".AWRKTAB"   [AWK]
 Local File =DOSSIER+".ATABLE"    [ATB]
 Local File =DOSSIER+".ATRANSAC"  [ATN]
 Local File =DOSSIER+".ATABDIV"   [ADI]
Endif
Return

#-------------------------------------#
$DEBUT
L1 = instr(1,VALEUR,"~")
L2 = instr(L1+1,VALEUR,"~")
L3 = instr(L2+1,VALEUR,"~")
If !L1 or !L2 or !L3 : Effzo : Return : Endif
CHAINE = right$(VALEUR,L3+1)
If func CRITERE(CHAINE)<>""
 [M]CRITERE = func CRITERE(CHAINE)
 [M]CLE = ""
 Grizo CLE
 Actzo CRITERE
Else
 [M]CLE = CHAINE
 [M]CRITERE = ""
 Grizo CRITERE
 Actzo CLE 
Endif
Read [AWM]AWM0=left$(VALEUR,L1-1)
If !fstat
 [M]MODDON = left$(VALEUR,L1-1)
 Read [ATB]CODFIC=[F:AWM]TABREF
 If !fstat
  [M]TABLE  = [F:AWM]TABREF
 Endif
Endif
If seg$(VALEUR,L1+1,L2-1)<>""
 Read [ADI]CODE=909;seg$(VALEUR,L1+1,L2-1)
 If !fstat
  [M]CODLEG = seg$(VALEUR,L1+1,L2-1)
 Endif
Endif
Read [ATN]ATN0=seg$(VALEUR,L2+1,L3-1)
If !fstat
 [M]TRANSAC = seg$(VALEUR,L2+1,L3-1)
Endif
Affzo
Return

#-------------------------------------#
$OK
VALEUR = [M]MODDON+"~"+[M]CODLEG+"~"+[M]TRANSAC
If [M]CLE<>""
 VALEUR += "~"+[M]CLE
Else
 VALEUR += "~='"+[M]CRITERE+"'"
Endif
Return

#-------------------------------------#
Funprog CRITERE(COD)
Value Char COD
Local Char FORMULE(255)
If left$(COD,2)="='" & right$(COD,len(COD))="'"
 FORMULE = seg$(COD,3,len(COD)-1)
 If FORMULE="" : FORMULE = "1=1" : Endif
 End FORMULE
Endif
End ""
 
#-----------------------------------------------------------------------------#
$PATCH
NOMPROG = "WWPATCHA"+"_"+GUSER+"_"+num$(adxuid(2))
Gosub SAV_OPENO
Call VALID(CLEOBJ,DOSSIER,NOMPROG,1,MODDON,TRANSAC,STAT)
If !STAT
 # Erreur dans le patch du modèle $1$ (Voir traitement $2$)
 Call ECR_TRACE(func AFNC.MES2(mess(67,143,1),MODDON,"WWERR_"+MODDON+".src"),-1) From GESECRAN
 Call MOVE(filpath("TRT",NOMPROG,"src",DOSSIER),filpath("TRT","WWERR_"+MODDON,"src",DOSSIER),STAT) From ORDSYS
Endif
Gosub REST_OPENO
If [L]MODDON<>"" & STAT

 # Modèle de données
 ABROBJ = "AWM" : CLEOBJ = [L]MODDON
 Wrseq '12';'"'+ABROBJ+'"';'"'+CLEOBJ+'"';'""'
 Gosub OBJET From APATCH
 Wrseq '13';'"'+ABROBJ+'"';'"'+CLEOBJ+'"';'""'

 # Transaction de validation
 If [L]TRANSAC<>""
  ABROBJ = "ATN" : CLEOBJ = [L]TRANSAC
  Wrseq '12';'"'+ABROBJ+'"';'"'+CLEOBJ+'"';'""'
  Gosub OBJET From APATCH
  Wrseq '13';'"'+ABROBJ+'"';'"'+CLEOBJ+'"';'""'
 Endif

 # Patch d'après le modèle de patch
 Gosub PATCH From =DOSSIER+"."+NOMPROG

 Gosub SAV_OPENO
 Call EFFACE_ADX(MACHINE,APPLI,NOMPROG,STAT) From ORDSYS
 Call EFFACE(filpath("TRT",NOMPROG,"adx",DOSSIER),STAT) From ORDSYS
 #Call EFFACE(filpath("TRT",NOMPROG,"src",DOSSIER),STAT) From ORDSYS
 Call EFFACE(filpath("TRT",NOMPROG,"xrc",DOSSIER),STAT) From ORDSYS
 Gosub REST_OPENO
Endif
Return

#-----------------------#
$SAV_OPENO
Local Char     SAVIFS(10) , SAVIRS(10)
Local Integer  SAVIUM
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
Return

#-----------------------#
$REST_OPENO
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Openo FICPATCH
Return

#----------------------------------------------------------------------------#
Subprog VALID(CODE,DOSSIER,NOMPROG,SILENCE,MODDON,TRANSAC,OK)
Value    Char    CODE
Value    Char    DOSSIER
Value    Char    NOMPROG
Value    Integer SILENCE
Variable Char    MODDON
Variable Char    TRANSAC
Variable Integer OK

Local Char     FICSRC(GDIMFIC) , IDENT(20) , CODLEG(GLONADI)
Local Char     MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Char     CHAINE(250) , MAGIC(80) , BUF(250) , FORMULE(255)
Local Integer  I , J , K , L , M , N , OK
Local Shortint DIME : DIME = 20
Local Char     TBORI(GLONATB+GLONABR+1)(1..DIME) , TBLNK(GLONATB+GLONABR+1)(1..DIME) , TBCLE(GLONANX)(1..DIME)
Local Char     TBEXP(80)(1..DIME) , TBSEL(80)(1..DIME)
Local Integer  NBTB
Local Char     REFTAB(GLONATB) , ABRREF(GLONABR) , CLEREF(GLONANX) , TAB(GLONATB+GLONABR+1)(1..DIME)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

MAGIC   = mess(77,133,1) : # Superviseur Adonix
IDENT   = "## WM-PATCH ##"

If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMPROG) From GESECRAN : # Validation du traitement
Endif

OK = 1
Gosub SETPAR
If [L]MODDON=""
 Call ECR_TRACE(mess(134,141,1),1) From GESECRAN : # Erreur de syntaxe
 OK = 0
Endif

Read [AWM_]AWM0=[L]MODDON
If fstat
 Call ECR_TRACE([L]MODDON-":"-mess(7,140,1),1) From GESECRAN : # Modèle de données inexistant
 OK = 0
Else
 Look [ATB_]CODFIC=[F:AWM_]TABREF 
 If fstat
  Call ECR_TRACE([F:AWM_]TABREF-":"-mess(124,124,1),1) From GESECRAN : # Table inexistante
  OK = 0
 Else
  For [AWK_]AWK0 Where MODELE = [AWM_]MODELE & TYPTAB<1
   If [F:AWK_]TABLNK<>""
    Look [ATB_]CODFIC=[F:AWK_]TABLNK
    If fstat
     Call ECR_TRACE([F:AWK_]TABLNK-":"-mess(124,124,1),1) From GESECRAN : # Table inexistante
     OK = 0 : Break
    Endif 
   Endif
  Next I
 Endif
Endif 

If OK
 Gosub TRT_DEB
 If OK
  Gosub ETIQ
  Gosub TRT_FIN
 Endif
Endif

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

End

#-------------------------------------------------------#
$TRT_DEB
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
FICSRC = filpath("TRT",NOMPROG,"src",APPLI,"",MACHINE)
If filinfo(FICSRC,0)>=0
 Openi FICSRC Using [SSS_]
 Raz I, OK
 Rdseq CHAINE Using [SSS_]
 While !fstat
  I += 1 : If I>5 : Break : Endif
  If left$(CHAINE,len(IDENT))=IDENT
   OK = 1 : Break
  Endif
  Rdseq CHAINE Using [SSS_]
 Wend
 Openi Using [SSS_]
 If !OK
  # Ce traitement est déjà utilisé par un autre paramètrage
  Call ECR_TRACE(NOMPROG-":"-mess(215,139,1),1) From GESECRAN
  Return
 Endif
Else
 OK = 1
Endif
Openo FICSRC , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq IDENT-mess(1,143,1)-MODDON-'('+format$("D:",date$)-time$+')' : # Modèle de patch
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN
Wrseq
Openo
Call VALID("TRT",NOMPROG,DOSSIER,OK) From VALMSKSUB
Return

#------------------------------------------------------------------------------#
$ETIQ
Wrseq "#-----------------------#"
Wrseq "$PATCH"
Wrseq

Wrseq "Local Integer TBOPE(0.."+num$(DIME)+")"
Wrseq

# Chargement des tables liées
NBTB = 0
For [AWK_]AWK0 Where MODELE=[AWM_]MODELE & TYPTAB<1
 If [F:AWK_]TABLNK<>""
  NBTB += 1
  TBLNK(NBTB) = [F:AWK_]TABLNK
  TBORI(NBTB) = [F:AWK_]TABORI
  TBCLE(NBTB) = [F:AWK_]CLELNK
  TBEXP(NBTB) = [F:AWK_]EXPLNK
  TBSEL(NBTB) = [F:AWK_]EXPSEL
  If [F:AWK_]ABRLNK<>""
   TBLNK(NBTB) += "~"+[F:AWK_]ABRLNK
  Else
   Read [ATB_]CODFIC=[F:AWK_]TABLNK 
   TBLNK(NBTB) += "~"+[F:ATB_]ABRFIC
  Endif
  If [F:AWK_]ABRORI<>""
   TBORI(NBTB) += "~"+[F:AWK_]ABRORI
  Else
   Read [ATB_]CODFIC=[F:AWK_]TABORI 
   TBORI(NBTB) += "~"+[F:ATB_]ABRFIC
  Endif
 Endif 
Next I

# Table principale
REFTAB = [F:AWM_]TABREF
Read [ATB_]CODFIC=[F:AWM_]TABREF 
ABRREF = [F:ATB_]ABRFIC
Read [ATI_]NUMLIG(2)=[F:AWM_]TABREF;1
CLEREF = [F:ATI_]CODIND

Wrseq 'If clalev([F:'+ABRREF+'])=0 : Local File =DOSSIER+".'+REFTAB+'" ['+ABRREF+'] : TBOPE(0) = 1 : Endif'
For I=1 To NBTB
 K = instr(1,TBLNK(I),"~")
 Wrseq 'If clalev([F:'+right$(TBLNK(I),K+1)+'])=0 : Local File =DOSSIER+".'+left$(TBLNK(I),K-1)+'" ['+right$(TBLNK(I),K+1)+']';
 Wrseq ' : TBOPE('+num$(I)+') = 1 : Endif'
Next I
Wrseq

Read [ATB_]CODFIC=REFTAB
Read [ATI_]NUMLIG(2)=REFTAB;1
Gosub SETCLE

# Code législation de copie
Wrseq '[L]CODLEG = "'+[L]CODLEG+'"'
Wrseq

# Lecture de l'enregistrement sur la table principale (Boucle si formule)
Wrseq 'Local File =DOSSIER+".'+REFTAB+'" [AREF]'
If [L]CODLEG<>"" & [F:AWM_]FLDLEG<>""
 CHAINE = [F:AWM_]FLDLEG
 I = instr(1,CHAINE,"]")
 If I : CHAINE = right$(CHAINE,I+1) : Endif
 Wrseq 'If dim([F:AREF]'+CHAINE+')>1'
 Wrseq ' Filter [AREF] Where find([L]CODLEG,'+CHAINE+')<>0'
 Wrseq 'Elsif dim([F:AREF]'+CHAINE+')>0'
 Wrseq ' Filter [AREF] Where'-CHAINE+'=[L]CODLEG'
 Wrseq 'Endif'
Endif
If NBVAL=1 & func CRITERE(VALCLE)<>""
 FORMULE = func CRITERE(VALCLE)
 I = instr(1,FORMULE,"[")
 While I
  J = instr(I+1,FORMULE,"]")
  If !J : Break : Endif
  If mid$(FORMULE,I+1,2)="F:"
   K = I+2
  Else
   K = I
  Endif
  If seg$(FORMULE,K+1,J-1)=ABRREF
   FORMULE = left$(FORMULE,I-1)+right$(FORMULE,J+1)
  Endif
  I = instr(J+1,FORMULE,"[")
 Wend 
 Wrseq 'For [AREF] Where'-FORMULE
 Wrseq ' [F:'+ABRREF+'] = [F:AREF]'
 Wrseq ' Gosub ECRIT'
 Wrseq 'Next AREF'
Else
 For I=1 To NBCLE
  Wrseq "[F:AREF]"+CLE(I)+" = ";
  Case TYP(I)
   When 1,2,3,4,5,6 : Wrseq VALCLE(I)
   When 8           : Wrseq "evalue('['+format$(GFMD,VALCLE(I))+']')"
   When Default     : Wrseq '"'+VALCLE(I)+'"'
  Endcase
 Next I
 Wrseq 'Read [AREF] = '
 Wrseq 'If !fstat : [F:'+ABRREF+'] = [F:AREF] : Gosub ECRIT : Endif'
Endif
Wrseq 'Filter [AREF]'

# Close
Wrseq 'Close local File [AREF]'
Wrseq
Wrseq "If TBOPE(0) : Close local File ["+ABRREF+"] : Endif"
For I=1 To NBTB
 K = instr(1,TBLNK(I),"~")
 Wrseq "If TBOPE("+num$(I)+") : Close local File ["+right$(TBLNK(I),K+1)+"] : Endif"
Next I
Wrseq
Wrseq 'Return'
Wrseq

# Sous-programme d'écriture
Wrseq "#-----------------------#"
Wrseq '$ECRIT'

# Entête
Wrseq "Wrseq '12';'"+'"'+"'+"+'"'+ABRREF+'"'+"+'"+'"'+"';'"+'"'+"'+";
For I=1 To NBCLE
 If I>1
  Wrseq '+"~"+';
 Endif
 Case TYP(I)
  When 1,2,3,4,5,6 : Wrseq 'num$([F:'+ABRREF+']'+CLE(I)+')';
  When 8           : Wrseq 'num$([F:'+ABRREF+']'+CLE(I)+')';
  When Default     : Wrseq '[F:'+ABRREF+']'+CLE(I);
 Endcase 
Next I
Wrseq "+'"+'"'+"';'"+'""'+"'"
Wrseq

# Ecriture table principale
Wrseq 'FICHIER = "'+REFTAB+'"'
Wrseq 'ABR = "'+ABRREF+'"'
Wrseq 'IDENT = ';
For I=1 To NBCLE
 If I>1
  Wrseq '+"~"+';
 Endif
 Case TYP(I)
  When 1,2,3,4,5,6 : Wrseq 'num$([F:'+ABRREF+']'+CLE(I)+')';
  When 8           : Wrseq 'num$([F:'+ABRREF+']'+CLE(I)+')';
  When Default     : Wrseq '[F:'+ABRREF+']'+CLE(I);
 Endcase 
Next I
Wrseq

If REFTAB="TABFOR"
 Wrseq 'For I=0 To dim([F:TFO]LEG)-1'
 Wrseq ' If [F:TFO]LEG(I)<>[L]CODLEG'
 Wrseq '  [F:TFO]LEG(I)    = ""'
 Wrseq '  [F:TFO]FORFOR(I) = ""'
 Wrseq ' Endif'
 Wrseq 'Next I'
Endif

Wrseq 'Default File ['+ABRREF+']'
Wrseq 'Gosub FICHIER From APATCH2'

If REFTAB="AOBJSEL"
 Wrseq 'If [F:'+ABRREF+']ALL=2'
 Wrseq ' EXT = "glo"'
 Wrseq 'Else'
 Wrseq ' EXT = "sel"'
 Wrseq 'Endif'
 Wrseq 'FIC = [F:'+ABRREF+']USR+"_"+[F:'+ABRREF+']CODE+"_"+[F:'+ABRREF+']MEMO+"."+EXT'
 Wrseq 'Wrseq "3";'+"'"+'"'+"'+EXT+'"+'"'+"'"
 Wrseq 'Gosub MEMOS From APATCH2'
 Wrseq 'Wrseq "6";'+"'"+'"'+"'+EXT+'"+'"'+"'"
Endif

# Ecriture des tables de détail
For L=1 To NBTB
 Wrseq
 N = 1
 M = L
 TAB(1) = REFTAB+"~"+ABRREF
 While 1=1 
  N += 1
  If TBORI(M)=REFTAB+"~"+ABRREF
   TAB(N) = TBLNK(L)
   Break
  Endif
  TAB(N) = TBORI(M)
  M = find(TBORI(M),TBLNK)
 Wend
 For I=1 To N
  If I=1
   Wrseq 'Default File ['+ABRREF+']'
  Else
   M = find(TAB(I),TBLNK)
   K = instr(1,TBLNK(M),"~")
   Wrseq 'Default File ['+right$(TBLNK(M),K+1)+']'
  Endif
 Next I
 For I=1 To N
  If I=1
   Wrseq "Link ["+ABRREF+"] With"
  Else
   If I>2 : Wrseq "," : Endif 
   M = find(TAB(I),TBLNK)
   K = instr(1,TBLNK(M),"~")
   Wrseq "& ["+right$(TBLNK(M),K+1)+"]"+TBCLE(M)+"~="+TBEXP(M);
  Endif
 Next I 
 Wrseq
 Wrseq "& As [LNK_]"
 K = 0
 For I=2 To N
  M = find(TAB(I),TBLNK)
  If TBSEL(M)<>""
   If K=0
    K = 1
    Wrseq "& Where ";
   Else
    Wrseq "&     & ";
   Endif
   Wrseq TBSEL(M)
  Endif
 Next I
 Read [ATB_]CODFIC=REFTAB
 Read [ATI_]CODIND=REFTAB;CLEREF
 Gosub SETCLE
 Wrseq 'For [LNK_]'+CLEREF;
 K = 0
 For I=1 To NBCLE
  If K=0
   K = 1
   Wrseq " Where ";
  Else
   Wrseq " & ";
  Endif
  Wrseq CLE(I)+"=[F:AREF]"+CLE(I);
 Next I 
 Wrseq
 K = instr(1,TBLNK(L),"~")
 Read [ATB_]CODFIC=left$(TBLNK(L),K-1)
 Read [ATI_]CODIND=left$(TBLNK(L),K-1);TBCLE(L)
 Gosub SETCLE
 Wrseq ' FICHIER = "'+left$(TBLNK(L),K-1)+'"'
 Wrseq ' ABR = "'+right$(TBLNK(L),K+1)+'"'
 Wrseq ' IDENT = ';
 For I=1 To NBCLE
  If I>1
   Wrseq '+"~"+';
  Endif
  Case TYP(I)
   When 1,2,3,4,5,6 : Wrseq 'num$([F:'+right$(TBLNK(L),K+1)+']'+CLE(I)+')';
   When 8           : Wrseq 'num$([F:'+right$(TBLNK(L),K+1)+']'+CLE(I)+')';
   When Default     : Wrseq '[F:'+right$(TBLNK(L),K+1)+']'+CLE(I);
  Endcase 
 Next I
 Wrseq
 Wrseq ' Gosub FICHIER From APATCH2'
 Wrseq 'Next LNK_'
Next L
Wrseq

# Pied
Read [ATB_]CODFIC=REFTAB
Read [ATI_]NUMLIG(2)=REFTAB;1
Gosub SETCLE
Wrseq "Wrseq '13';'"+'"'+"'+"+'"'+ABRREF+'"'+"+'"+'"'+"';'"+'"'+"'+";
For I=1 To NBCLE
 If I>1
  Wrseq '+"~"+';
 Endif
 Case TYP(I)
  When 1,2,3,4,5,6 : Wrseq 'num$([F:'+ABRREF+']'+CLE(I)+')';
  When 8           : Wrseq 'num$([F:'+ABRREF+']'+CLE(I)+')';
  When Default     : Wrseq '[F:'+ABRREF+']'+CLE(I);
 Endcase 
Next I
Wrseq "+'"+'"'+"';'"+'""'+"'"
Wrseq

Wrseq "Return"
Return

#-----------------------#
$SETPAR
Local Char    VALCLE(250)(1..16) , CHAINE(250)
Local Integer NBVAL , POS1 , POS2 , POS3
Raz MODDON , CODLEG , TRANSAC , CHAINE , NBVAL , VALCLE
CHAINE = CODE
POS1 = instr(1,CHAINE,"~")
POS2 = instr(POS1+1,CHAINE,"~")
POS3 = instr(POS2+1,CHAINE,"~")
If !POS1 or !POS2 or !POS3
 Return
Endif
MODDON  = left$(CHAINE,POS1-1)
CODLEG  = seg$(CHAINE,POS1+1,POS2-1)
TRANSAC = seg$(CHAINE,POS2+1,POS3-1)
CHAINE  = right$(CHAINE,POS3+1)
While CHAINE<>""
 NBVAL += 1
 POS1 = instr(1,CHAINE,"~")
 If POS1
  VALCLE(NBVAL) = left$(CHAINE,POS1-1)
  CHAINE = right$(CHAINE,POS1+1)
 Else
  VALCLE(NBVAL) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

#-----------------------#
$SETEXP
Local Char    EXPCLE(GLONID1)(1..16)
Local Integer NBEXP , POS
Raz NBEXP , EXPCLE
While CHAINE<>""
 NBEXP += 1
 POS = instr(1,CHAINE,"~")
 If POS
  EXPCLE(NBEXP) = left$(CHAINE,POS-1)
  CHAINE = right$(CHAINE,POS+1)
 Else
  EXPCLE(NBEXP) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

#-----------------------#
$SETCLE
Local Char    CLE(GLONID1)(1..16)
Local Integer NBCLE , POS , TYP(1..16)
CHAINE = [F:ATI_]DESCRIPT
Raz NBCLE , CLE
While CHAINE<>""
 NBCLE += 1
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
 Read [ATZ_]CODZONE=[F:ATB_]CODFIC;CLE(NBCLE)
 Read [ATY_]CODTYP=[F:ATZ_]CODTYP
 TYP(NBCLE) = [F:ATY_]TYPTYP
Wend
Return

#----------------------------------#
Subprog C_CLE(VALEUR)
Variable Char    VALEUR()
If len(VALEUR)>0
 Grizo CRITERE
Else
 Actzo CRITERE
Endif
End

Subprog C_CRITERE(VALEUR)
Variable Char    VALEUR()
Local Integer TYP
TYP = type(VALEUR)-10
VALEUR = vireblc(format$("KT:"+num$(TYP)+"X",VALEUR),2)
If instr(1,VALEUR,'"') & instr(1,VALEUR,"'")
 GMESSAGE = '" :'-mess(94,123,1) : # Caractère interdit
 mkstat = 2 : End
Elsif instr(1,VALEUR,'"')
 VALEUR = ctrans(VALEUR,'"',"'")
Endif
If len(VALEUR)>0
 Grizo CLE
Else
 Actzo CLE
Endif
End
