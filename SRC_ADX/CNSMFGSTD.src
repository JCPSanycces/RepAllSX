Subprog AM_MFMFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M]MFOFLG=2
   [M]MFOFLG=1 : Affzo [M]MFOFLG
Endif
End

Subprog AM_MFOFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M]MFMFLG=2
   [M]MFMFLG=1 : Affzo [M]MFMFLG
Endif
End
