#<AdxTL>@(#)3.0.0.0 $Revision$
##################################################
#                                                #
#    Consultation des OF                         #
#                                       06/2010  #
##################################################

########################################################
#
# Parametres de consultation via PARAM()
#
#  1 MFGFCY Site
#  2 MFGNUM Ordre de fabrication
#  3 ITMREF Article lancé
#  4 BOMALT Alt. de nomenclature
#  5 ROUNUM Gamme
#  6 ROUALT Alt. de gamme
#  7 PJT    Affaire
#  8 VCRTYP Type document origine
#  9 VCRNUM Type document origine
# 10 TRI    Menu local 2396 (nouveau)
#          1 Par N° OF
#          2 Par poste de charge
#          3 Par article
#          4 Par N° de commande
#          5 Par affaire
#          6 Par composant
#
##########################################################


Local Char PARAM(20)(1..10)
PARAM(1) ="PAR"
PARAM(2) =""
PARAM(3) ="CD100"
PARAM(4) ="3"
PARAM(5) =""
PARAM(6) =""
PARAM(7) =""
PARAM(8) =""
PARAM(9) =""
PARAM(10)="1"
Call GCONSULT("MFG", "",PARAM) From GCONSULT
End


##################################################

$ACTION

Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
 When "OUVRE"      : Gosub OUVRE
 When "DEB_CRIT"   : Gosub DEB_CRIT
 When "FIN_CRIT"   : Gosub FIN_CRIT    # FQ 67866 GA 10/2010 en attendant évol Superv 67902
 When "LECTURE"    : Gosub LECTURE
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "FERME"      : Gosub FERME
 When Default
Endcase
Return

#############################################################################
# pour gérer l'accès à la consultation
$AUTORIS
Return

#############################################################################
$FERME
Return

#############################################################################
$SETBOUT
Return

#############################################################################
$EXEBOUT
Return

##################################################

$OUVRE

Integer I
Local Char CRITERE(255)
Local Char CRITERE1(255)
Local Char CRITERE2(255)
Local Char CRITERE3(255)
Local Char CRITERE_MFI(255)
Local Char CRITERE_MFM(255)
Local Char CRITERE_MFO(255)

Local Char WDEBVCRORI(GLONVCR), WFINVCRORI(GLONVCR)
Local Char WDEBMFGNUM(GLONVCR), WFINMFGNUM(GLONVCR)
Local Char WDEBITMREF(GLONITM), WFINITMREF(GLONITM)
Local Char WDEBCPNITM(GLONITM), WFINCPNITM(GLONITM)
Local Char WDEBPJT(GLONPJT)   , WFINPJT(GLONPJT)
Local Char WDEBWST(GLONWST)   , WFINWST(GLONWST)
Local Integer WSRT, OK_MFM, OK_MFO

If !clalev([F:TFO]) Local File TABFOR [TFO] Endif

Gosub DEFCRIT

If !find ([M:CLOF]TRI,1,2,3,4,5,6) : [M:CLOF]TRI=1 : Endif

# Mail TS du 18/03/08
NAVIG="CONSMFG"
Return

##################################################

$DEFCRIT

#chargement par defaut : en fonction du site et de la date du jour
Local Integer I
For I = 1 To dim(PARAM)
Case I :
    When 1 :    # site
        If PARAM(I)<>""
            Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
            If !fstat  & [F:FCY]MFGFLG = 2 :  [M:LOF1]MFGFCY = PARAM(I): Endif
        Endif
    When 2 :    #  N° OF
        If  PARAM(I)<> ""
            Read [MFG]MFG0 =  PARAM(I)
            If ! fstat
                [M:LOF1]MFGNUMSTR = PARAM(I)
                [M:LOF1]MFGNUMEND = PARAM(I)
            Endif
        Endif
    When 3 :    # article/nomenclature
        If PARAM(I)<>""
            Read [ITM]ITM0 = PARAM(I)
            If !fstat
                [M:LOF1]ITMREFSTR = PARAM(I)
                [M:LOF1]ITMREFEND = PARAM(I)
            Endif
        Endif
    When 4 :     #Alt. nomenclature
         If PARAM(I)<>""
             [M:LOF1]BOMALT = val(PARAM(I))
         Endif
    When 5 :    # Gamme
         If  PARAM(I)<> ""
            Read [ITM]ITM0 = PARAM(I)
            If !fstat
                [M:LOF1]ROUNUMSTR =  PARAM(I)
                [M:LOF1]ROUNUMEND =  PARAM(I)
            Endif
         Endif
    When 6 :     #Alt. gamme
         If PARAM(I)<>""
             [M:LOF1]ROUALT = val(PARAM(I))
         Endif
    When 7 :    # Affaire
         If  PARAM(I)<> ""
            [M:LOF1]PJTSTR =  PARAM(I)
            [M:LOF1]PJTEND =  PARAM(I)
            # Issue X3-25731 - 2017-02-24 by FGR : BEGIN
            If find(GNAVIG(GPILNAV-0),"GESPJM") Then   # Note FGR : '-0' is not an error. This is true in this case.
              [M:LOF1]PJTDSPALL = [V]CST_AYES
            Endif
            # Issue X3-25731 - 2017-02-24 by FGR : END
         Endif
    When 8 :    # Type de document
         If PARAM(I)<>""
             [M:LOF1]VCRTYP = val(PARAM(I))
         Endif
    When 9 :    # Commande
        If  PARAM(I)<> ""
            [M:LOF1]VCRORISTR =  PARAM(I)
            [M:LOF1]VCRORIEND =  PARAM(I)
        Endif
    When 10 :    # Tri
        If PARAM(I)<> ""
            WSRT =  val(PARAM(I))
            If WSRT<0 | WSRT > 6 : WSRT = 1 : Endif
            [M:CLOF]TRI = WSRT
        Endif
   When Default : Break

Endcase
Next I
Affzo [M:LOF1]

If clalev([M:CLOF]) <> 0 & [M:CLOF]MEMO = "STD"
   [M:LOF1] = [M:CLOF]
Endif
# Site par défaut module GPAO, si aucun site après les paramètres et rechargement du memo
If[M:LOF1]MFGFCY=""
   Call FIND_GFCYDEF(8) From TRTX3
   [M:LOF1]MFGFCY = GFCY
Endif

# Copie de l'ecran d'entête / ecran de criteres
Gosub CRITENT From =PROGCNS

Return

##################################################
$DEB_CRIT
#MAE, diszo des zones articles
#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
        If find(GNAVIG(GPILNAV-1),"GESITM")
            Diszo [M:CLOF]ITMREFSTR
            Diszo [M:CLOF]ITMREFEND
        Elsif find(GNAVIG(GPILNAV-1),"GESITF")
            Diszo [M:CLOF]ITMREFSTR
            Diszo [M:CLOF]ITMREFEND
        Endif
    Endif
    # Issue X3-25731 - 2017-02-24 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CLOF]PJTSTR
      Diszo [M:CLOF]PJTEND
    Endif
    # Issue X3-25731 - 2017-02-24 by FGR : END
Endif
# FQ 67866 GA 10/2010 en attendant évol Superv 67902
# correspondance des champs saisis en critères
 # [M:CLOF] = [M:LOF1]
Return
##################################################
$FIN_CRIT
# FQ 67866 GA 10/2010 en attendant évol Superv 67902
# correspondance des champs saisis en critères
 # [M:LOF1] = [M:CLOF]
Return
##################################################

$LECTURE

#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:LOF1]ITMREFSTR
        Diszo [M:LOF1]ITMREFEND
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:LOF1]ITMREFSTR
        Diszo [M:LOF1]ITMREFEND
        Diszo [M:LOF1]MFGFCY
    Endif
    # Issue X3-25731 - 2017-02-24 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:LOF1]PJTSTR
      Diszo [M:LOF1]PJTEND
    Endif
    # Issue X3-25731 - 2017-02-24 by FGR : END
Endif


# Si le site n'est pas renseigné, pas de chargement automatique
If [M:LOF1]MFGFCY=""  : NBLU= 0 : Return : Endif
If PARAM(10)="" : PARAM(10)="1" : Endif


#-- Changement d'écran paramétrable
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

#-- Positionnement des filtres
Gosub LOAD_FILTER
Gosub LOAD_FORMULE

If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif


#########################################################
#                                                       #
#    CHGPAG = 1  : Recherche                            #
#    ------ = 2  : Suite                                #
#    ------ = 3  : F5 (Rafraichissement page courante)  #
#                                                       #
#    CHGPAG = -1 : Dernier                              #
#    ------ = -2 : Retour (page precedente)             #
#                                                       #
#########################################################
# 10 TRI    Menu local 2396 (nouveau)
#          1 Par N° OF
#          2 Par poste de charge
#          3 Par article
#          4 Par N° de commande
#          5 Par affaire
#          6 Par composant
#########################################################

#-- Application du filtre et positionnement des boutons
If CHGPAG >0
    SUITE = 1
    If CHGPAG = 1 : RETOUR =1       #recherche
    Elsif CHGPAG = 2 : RETOUR = 2   # suite
    Endif

    Case [M:CLOF]TRI
     When 1 : # Tri par n° d'OF
         If [M]MFOFLG=2
            Link [MFO] With [F:MFI]MFI0(1) = [F:MFO]MFGNUM,[F:MFG]MFG0 = [F:MFO]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFO)
&           Order By Key CLE =[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFO]OPENUM
         Elsif [M]MFMFLG=2
            Link [MFM] With [F:MFI]MFI0(1) = [F:MFM]MFGNUM,[F:MFG]MFG0 = [F:MFM]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFM)
&           Order By Key CLE =[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFM]BOMSEQ
         Else
            Link [MFI] With [F:MFG]MFG0 = [F:MFI]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI)
&           Order By Key CLE =[F:MFG]MFGNUM
         Endif

     When 2 : # Tri par Poste de charge (principal)
        [M]MFOFLG=2 : Affzo [M]MFOFLG
        [M]MFMFLG=1 : Affzo [M]MFMFLG

        Link [MFO] With [F:MFI]MFI0(1) = [F:MFO]MFGNUM,[F:MFG]MFG0 = [F:MFO]MFGNUM
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFO)
&       Order By Key CLE = [F:MFO]EXTWST;[F:MFI]MFGNUM;[F:MFI]MFGLIN

     When 3 : # Tri par article lancé
         If [M]MFOFLG=2
            Link [MFO] With [F:MFI]MFI0(1) = [F:MFO]MFGNUM,[F:MFG]MFG0 = [F:MFO]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFO)
&           Order By Key CLE =[F:MFI]ITMREF;[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFO]OPENUM
         Elsif [M]MFMFLG=2
            Link [MFM] With [F:MFI]MFI0(1) = [F:MFM]MFGNUM,[F:MFG]MFG0 = [F:MFM]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFM)
&           Order By Key CLE =[F:MFI]ITMREF;[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFM]BOMSEQ
         Else
            Link [MFI] With [F:MFG]MFG0 = [F:MFI]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI)
&           Order By Key CLE =[F:MFI]ITMREF;[F:MFG]MFGNUM
         Endif

     When 4 : # Tri par document d'origine
         If [M]MFOFLG=2
            Link [MFO] With [F:MFI]MFI0(1) = [F:MFO]MFGNUM,[F:MFG]MFG0 = [F:MFO]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFO)
&           Order By Key CLE =[F:MFI]VCRTYPORI;[F:MFI]VCRNUMORI;[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFO]OPENUM
         Elsif [M]MFMFLG=2
            Link [MFM] With [F:MFI]MFI0(1) = [F:MFM]MFGNUM,[F:MFG]MFG0 = [F:MFM]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFM)
&           Order By Key CLE =[F:MFI]VCRTYPORI;[F:MFI]VCRNUMORI;[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFM]BOMSEQ
         Else
            Link [MFI] With [F:MFG]MFG0 = [F:MFI]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI)
&           Order By Key CLE =[F:MFI]VCRTYPORI;[F:MFI]VCRNUMORI;[F:MFG]MFGNUM
         Endif

     When 5 : # Tri par affaire
         If [M]MFOFLG=2
            Link [MFO] With [F:MFI]MFI0(1) = [F:MFO]MFGNUM,[F:MFG]MFG0 = [F:MFO]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFO)
&           Order By Key CLE =[F:MFI]PJT;[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFO]OPENUM
         Elsif [M]MFMFLG=2
            Link [MFM] With [F:MFI]MFI0(1) = [F:MFM]MFGNUM,[F:MFG]MFG0 = [F:MFM]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFM)
&           Order By Key CLE =[F:MFI]PJT;[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFM]BOMSEQ
         Else
            Link [MFI] With [F:MFG]MFG0 = [F:MFI]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI)
&           Order By Key CLE =[F:MFI]PJT;[F:MFG]MFGNUM
         Endif

     When 6 : # Tri par Composant
        [M]MFOFLG=1 : Affzo [M]MFOFLG
        [M]MFMFLG=2 : Affzo [M]MFMFLG

        Link [MFM] With [F:MFI]MFI0(1) = [F:MFM]MFGNUM,[F:MFG]MFG0 = [F:MFM]MFGNUM
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFM)
&       Order By Key CLE = [F:MFM]ITMREF;[F:MFI]MFGNUM;[F:MFI]MFGLIN
   Endcase

Else
    RETOUR = 1
    If CHGPAG = -1 : SUITE =1    #dernier
    Elsif CHGPAG =-2 : SUITE = 2 #retour
    Endif

  Case [M:CLOF]TRI
     When 1 : # Tri par n° d'OF
         If [M]MFOFLG=2
            Link [MFO] With [F:MFI]MFI0(1) = [F:MFO]MFGNUM,[F:MFG]MFG0 = [F:MFO]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFO)
&           Order By Key CLE =[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFO]OPENUM Desc
         Elsif [M]MFMFLG=2
            Link [MFM] With [F:MFI]MFI0(1) = [F:MFM]MFGNUM,[F:MFG]MFG0 = [F:MFM]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFM)
&           Order By Key CLE =[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFM]BOMSEQ Desc
         Else
            Link [MFI] With [F:MFG]MFG0 = [F:MFI]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI)
&           Order By Key CLE =[F:MFG]MFGNUM Desc
         Endif

     When 2 : # Tri par Poste de charge (principal)
        [M]MFOFLG=2 : Affzo [M]MFOFLG
        [M]MFMFLG=1 : Affzo [M]MFMFLG

        Link [MFO] With [F:MFI]MFI0(1) = [F:MFO]MFGNUM,[F:MFG]MFG0 = [F:MFO]MFGNUM
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFO)
&       Order By Key CLE = [F:MFO]EXTWST;[F:MFI]MFGNUM;[F:MFI]MFGLIN Desc

     When 3 : # Tri par article lancé
         If [M]MFOFLG=2
            Link [MFO] With [F:MFI]MFI0(1) = [F:MFO]MFGNUM,[F:MFG]MFG0 = [F:MFO]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFO)
&           Order By Key CLE =[F:MFI]ITMREF;[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFO]OPENUM Desc
         Elsif [M]MFMFLG=2
            Link [MFM] With [F:MFI]MFI0(1) = [F:MFM]MFGNUM,[F:MFG]MFG0 = [F:MFM]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFM)
&           Order By Key CLE =[F:MFI]ITMREF;[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFM]BOMSEQ Desc
         Else
            Link [MFI] With [F:MFG]MFG0 = [F:MFI]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI)
&           Order By Key CLE =[F:MFI]ITMREF;[F:MFG]MFGNUM Desc
         Endif

     When 4 : # Tri par document d'origine
         If [M]MFOFLG=2
            Link [MFO] With [F:MFI]MFI0(1) = [F:MFO]MFGNUM,[F:MFG]MFG0 = [F:MFO]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFO)
&           Order By Key CLE =[F:MFI]VCRTYPORI;[F:MFI]VCRNUMORI;[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFO]OPENUM Desc
         Elsif [M]MFMFLG=2
            Link [MFM] With [F:MFI]MFI0(1) = [F:MFM]MFGNUM,[F:MFG]MFG0 = [F:MFM]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFM)
&           Order By Key CLE =[F:MFI]VCRTYPORI;[F:MFI]VCRNUMORI;[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFM]BOMSEQ Desc
         Else
            Link [MFI] With [F:MFG]MFG0 = [F:MFI]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI)
&           Order By Key CLE =[F:MFI]VCRTYPORI;[F:MFI]VCRNUMORI;[F:MFG]MFGNUM Desc
         Endif

     When 5 : # Tri par affaire
         If [M]MFOFLG=2
            Link [MFO] With [F:MFI]MFI0(1) = [F:MFO]MFGNUM,[F:MFG]MFG0 = [F:MFO]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFO)
&           Order By Key CLE =[F:MFI]PJT;[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFO]OPENUM Desc
         Elsif [M]MFMFLG=2
            Link [MFM] With [F:MFI]MFI0(1) = [F:MFM]MFGNUM,[F:MFG]MFG0 = [F:MFM]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFM)
&           Order By Key CLE =[F:MFI]PJT;[F:MFI]MFGNUM;[F:MFI]MFGLIN;[F:MFM]BOMSEQ Desc
         Else
            Link [MFI] With [F:MFG]MFG0 = [F:MFI]MFGNUM
&           As  [LIE]
&           Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI)
&           Order By Key CLE =[F:MFI]PJT;[F:MFG]MFGNUM Desc
         Endif

      When 6 : # Tri par Composant
        [M]MFOFLG=1 : Affzo [M]MFOFLG
        [M]MFMFLG=2 : Affzo [M]MFMFLG

        Link [MFM] With [F:MFI]MFI0(1) = [F:MFM]MFGNUM,[F:MFG]MFG0 = [F:MFM]MFGNUM
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue(CRITERE_MFI) & evalue(CRITERE_MFM)
&       Order By Key CLE = [F:MFM]ITMREF;[F:MFI]MFGNUM;[F:MFI]MFGLIN Desc
   Endcase

Endif

Raz [M:LOF2]

#-- RAZ du masque
If CHGPAG<>2 | CHGPAG<>-2 : Raz [M:LOF2] : Endif

If [M:CLOF]TRI=2 | [M]MFOFLG=2    # affichage des champs "poste de charge"
   Gosub SHOW_MFO
Else
   Gosub HIDE_MFO
Endif
If [M:CLOF]TRI=6 | [M]MFMFLG=2    # affichage des champs "composant"
   Gosub SHOW_MFM
Else
   Gosub HIDE_MFM
Endif

#--  Lecture
For[LIE]
     If NBLU = 1
         If CHGPAG=2 | CHGPAG=-2 : Raz [M:LOF2] : Endif
         NBLU = 2
     Endif
     If CHGPAG >0
         If NOL>=MAXLIG-1 : SUITE = 2 : Break : Endif
         NOL +=1
         If NOL = 0
            WDEBMFGNUM = [F:MFG]MFGNUM
            WDEBITMREF = [F:MFI]ITMREF
            WDEBPJT    = [F:MFI]PJT
            WDEBWST    = [F:MFO]EXTWST
            WDEBVCRORI = [F:MFI]VCRNUMORI
            WDEBCPNITM = [F:MFM]ITMREF
         Endif
         WFINMFGNUM = [F:MFG]MFGNUM
         WFINITMREF = [F:MFI]ITMREF
         WFINPJT    = [F:MFI]PJT
         WFINWST    = [F:MFO]EXTWST
         WFINVCRORI = [F:MFI]VCRNUMORI
         WFINCPNITM = [F:MFM]ITMREF
     Else
         If NOL <=0 : RETOUR = 2 : Break : Endif
         NOL -=1
         If NOL = MAXLIG -1
            WFINMFGNUM = [F:MFG]MFGNUM
            WFINITMREF = [F:MFI]ITMREF
            WFINPJT    = [F:MFI]PJT
            WFINWST    = [F:MFO]EXTWST
            WFINVCRORI = [F:MFI]VCRNUMORI
            WFINCPNITM = [F:MFM]ITMREF
         Endif
         WDEBMFGNUM = [F:MFG]MFGNUM
         WDEBITMREF = [F:MFI]ITMREF
         WDEBPJT    = [F:MFI]PJT
         WDEBWST    = [F:MFO]EXTWST
         WDEBVCRORI = [F:MFI]VCRNUMORI
         WDEBCPNITM = [F:MFM]ITMREF
     Endif

     If CRITERE_MFM<>"1=1" & [M]MFMFLG=1 & [M:CLOF]TRI<>6
        OK_MFM=0  # si TRI=6 on a déjà chargé/filtré les MFM
        Gosub CTRL_MFM
     Else
        OK_MFM=1
     Endif
     If CRITERE_MFO<>"1=1" & [M]MFOFLG=1 & [M:CLOF]TRI<>2
        OK_MFO=0  # si TRI=2 on a déjà chargé/filtré les MFO
        Gosub CTRL_MFO
     Else
        OK_MFO=1
     Endif
     If OK_MFM & OK_MFO
       # Chargement de l'OF dans la liste si toutes les conditions sont vérifiées
         nolign = NOL +1
         [M:LOF2]NBLIG+=1
         [M:LOF2]=[F:MFG]
         [M:LOF2]=[F:MFI]
         # FQ 70646 GA 01/2011 ajout désignations
         Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:LOF2]ITMREF(NOL),[M:LOF2]ITMDES1(NOL), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
         If [M:CLOF]TRI=2 | [M]MFOFLG=2    # on a lu MFO, affichage des postes de charge
            Gosub LOAD_MFO
         Elsif [M:CLOF]TRI=6 | [M]MFMFLG=2 # on a lu MFM, affichage des composants
            Gosub LOAD_MFM
         Endif
     Else NOL -=1
     Endif
Next
Gosub HIGHLIGHT
Return

# Affichage et chargement des champs relatifs à [F:MFO]
$LOAD_MFO
[M:LOF2]OPENUM(NOL)   =[F:MFO]OPENUM
[M:LOF2]EXTWST(NOL)   =[F:MFO]EXTWST
[M:LOF2]CPLWST(NOL)   =[F:MFO]CPLWST
[M:LOF2]EXTLAB(NOL)   =[F:MFO]EXTLAB
[M:LOF2]CPLLAB(NOL)   =[F:MFO]CPLLAB
# FQ 70646 GA 01/2011 ajout désignations + Situation
[M:LOF2]MFOTRKFLG(NOL)=[F:MFO]MFOTRKFLG
If dim([M:LOF2]EXTWSTDES)>0 & [M:LOF2]EXTWST(NOL)<>""
   Call LECTEXTRA([M:LOF2]EXTWSTDES(NOL),"WORKSTATIO","WSTDESAXX", [M:LOF2]EXTWST(NOL), [M:LOF2]MFGFCY(NOL) ) From ATEXTRA
Endif
If dim([M:LOF2]CPLWSTDES)>0 & [M:LOF2]CPLWST(NOL)<>""
   Call LECTEXTRA([M:LOF2]CPLWSTDES(NOL),"WORKSTATIO","WSTDESAXX", [M:LOF2]CPLWST(NOL), [M:LOF2]MFGFCY(NOL) ) From ATEXTRA
Endif
If dim([M:LOF2]EXTLABDES)>0 & [M:LOF2]EXTLAB(NOL)<>""
   Call LECTEXTRA([M:LOF2]EXTLABDES(NOL),"WORKSTATIO","WSTDESAXX", [M:LOF2]EXTLAB(NOL), [M:LOF2]MFGFCY(NOL) ) From ATEXTRA
Endif
If dim([M:LOF2]CPLLABDES)>0 & [M:LOF2]CPLLAB(NOL)<>""
   Call LECTEXTRA([M:LOF2]CPLLABDES(NOL),"WORKSTATIO","WSTDESAXX", [M:LOF2]CPLLAB(NOL), [M:LOF2]MFGFCY(NOL) ) From ATEXTRA
Endif
Return

# Afficher les champs relatifs à [F:MFO]
$SHOW_MFO
Chgfmt [M:LOF2]OPENUM     With "NP:8"
Chgfmt [M:LOF2]EXTWST     With "KP:"-num$(GLONWST)
Chgfmt [M:LOF2]CPLWST     With "KP:"-num$(GLONWST)
Chgfmt [M:LOF2]EXTLAB     With "KP:"-num$(GLONWST)
Chgfmt [M:LOF2]CPLLAB     With "KP:"-num$(GLONWST)
Chgfmt [M:LOF2]EXTWSTDES  With "KP:"-num$(GLONDES)
Chgfmt [M:LOF2]CPLWSTDES  With "KP:"-num$(GLONDES)
Chgfmt [M:LOF2]EXTLABDES  With "KP:"-num$(GLONDES)
Chgfmt [M:LOF2]CPLLABDES  With "KP:"-num$(GLONDES)
Chgfmt [M:LOF2]MFOTRKFLG  With "NP:2"
Return
# Cacher les champs relatifs à [F:MFO]
$HIDE_MFO
Chgfmt [M:LOF2]OPENUM     With "-NP:8"
Chgfmt [M:LOF2]EXTWST     With "-KP:"-num$(GLONWST)
Chgfmt [M:LOF2]CPLWST     With "-KP:"-num$(GLONWST)
Chgfmt [M:LOF2]EXTLAB     With "-KP:"-num$(GLONWST)
Chgfmt [M:LOF2]CPLLAB     With "-KP:"-num$(GLONWST)
Chgfmt [M:LOF2]EXTWSTDES  With "-KP:"-num$(GLONDES)
Chgfmt [M:LOF2]CPLWSTDES  With "-KP:"-num$(GLONDES)
Chgfmt [M:LOF2]EXTLABDES  With "-KP:"-num$(GLONDES)
Chgfmt [M:LOF2]CPLLABDES  With "-KP:"-num$(GLONDES)
Chgfmt [M:LOF2]MFOTRKFLG  With "-NP:2"
Return

# Affichage et chargement des champs relatifs à [F:MFM]
$LOAD_MFM
[M:LOF2]CPNITMREF(NOL)=[F:MFM]ITMREF
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:LOF2]CPNITMREF(NOL),[M:LOF2]CPNITMDES1(NOL), "") From TRTX3
[M:LOF2]BOMSEQ(NOL)   =[F:MFM]BOMSEQ
[M:LOF2]MFMTRKFLG(NOL)=[F:MFM]MFMTRKFLG
Return

# Afficher les champs relatifs à [F:MFM]
$SHOW_MFM
Chgfmt [M:LOF2]BOMSEQ     With "NP:6"
Chgfmt [M:LOF2]CPNITMREF  With "KP:"-num$(GLONITM)
Chgfmt [M:LOF2]CPNITMDES1 With "KP:"-num$(GLONDES)
Chgfmt [M:LOF2]MFMTRKFLG  With "NP:2"
Return
# Cacher les champs relatifs à [F:MFM]
$HIDE_MFM
Chgfmt [M:LOF2]BOMSEQ     With "-NP:6"
Chgfmt [M:LOF2]CPNITMREF  With "-KP:"-num$(GLONITM)
Chgfmt [M:LOF2]CPNITMDES1 With "-KP:"-num$(GLONDES)
Chgfmt [M:LOF2]MFMTRKFLG  With "-NP:2"
Return

##################################################
# Check if at least one component of current WO
# match with the selection criteria
$CTRL_MFM

For [MFM] Where MFGNUM=[F:MFI]MFGNUM & find(MFGLIN,0,[F:MFI]MFGLIN) & evalue(CRITERE_MFM)
  OK_MFM=1
  Break
Next

Return

##################################################
# Check if at least one operation of current WO
# match with the selection criteria
$CTRL_MFO

For [MFO] Where MFGNUM=[F:MFI]MFGNUM & find(MFGLIN,0,[F:MFI]MFGLIN) & evalue(CRITERE_MFO)
  OK_MFO=1
  Break
Next

Return

##################################################

$LOAD_FILTER

Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

######### Critères MFG #########
# jointure MFG-MFI et ne pas afficher les sous-produits
CRITERE = "[F:MFG]MFGNUM=[F:MFI]MFGNUM & [F:MFI]ITMTYP=1"
Gosub LOAD_CRITERE

#site
If [M:LOF1]MFGFCY <> ""
    CRITERE = "[F:MFG]MFGFCY=[M:LOF1]MFGFCY"
Gosub LOAD_CRITERE
Endif

#statut de l'OF
If [M:LOF1]MFGSTASTR <> [M:LOF1]MFGSTAEND
    CRITERE = "[F:MFG]MFGSTA>=[M:LOF1]MFGSTASTR"
    Gosub LOAD_CRITERE

    CRITERE = "[F:MFG]MFGSTA<=[M:LOF1]MFGSTAEND"
    Gosub LOAD_CRITERE
Else
    CRITERE = "[F:MFG]MFGSTA=[M:LOF1]MFGSTASTR"
    Gosub LOAD_CRITERE
Endif

# n° O.F.
If [M:LOF1]MFGNUMSTR<> ""
    CRITERE = "[F:MFG]MFGNUM>=[M:LOF1]MFGNUMSTR"
Gosub LOAD_CRITERE
Endif

If [M:LOF1]MFGNUMEND<> ""
   CRITERE = "[F:MFG]MFGNUM<=[M:LOF1]MFGNUMEND"
Gosub LOAD_CRITERE
Endif

# date début
If [M:LOF1]STRDATSTR <> [0/0/0]
    CRITERE = "[F:MFG]STRDAT >=[M:LOF1]STRDATSTR"
Gosub LOAD_CRITERE
Endif

If [M:LOF1]STRDATEND <> [0/0/0]
    CRITERE = "[F:MFG]STRDAT <=[M:LOF1]STRDATEND"
Gosub LOAD_CRITERE
Endif

# date fin
If [M:LOF1]ENDDATSTR <> [0/0/0]
    CRITERE = "[F:MFG]ENDDAT >=[M:LOF1]ENDDATSTR"
Gosub LOAD_CRITERE
Endif

If [M:LOF1]ENDDATEND <> [0/0/0]
    CRITERE = "[F:MFG]ENDDAT <=[M:LOF1]ENDDATEND"
Gosub LOAD_CRITERE
Endif

# Gamme
If [M:LOF1]ROUNUMSTR<> ""
    CRITERE = "[F:MFG]ROUNUM>=[M:LOF1]ROUNUMSTR"
Gosub LOAD_CRITERE
Endif

If [M:LOF1]ROUNUMEND<> ""
   CRITERE = "[F:MFG]ROUNUM<=[M:LOF1]ROUNUMEND"
Gosub LOAD_CRITERE
Endif

# Alternative de gamme
If [M:CLOF]ROUALT <>0
    CRITERE = "[F:MFG]ROUALT=[M:CLOF]ROUALT"
Gosub LOAD_CRITERE
Endif


######### Critères MFI #########
# article
If [M:LOF1]ITMREFSTR <> ""
    CRITERE = "[F:MFI]ITMREF >=[M:LOF1]ITMREFSTR"
Gosub LOAD_CRITERE
Endif

If [M:LOF1]ITMREFEND <> ""
   CRITERE = "[F:MFI]ITMREF <=[M:LOF1]ITMREFEND"
Gosub LOAD_CRITERE
Endif

# Alternative de nomenclature
If [M:CLOF]BOMALT<>0
    CRITERE = "[F:MFI]BOMALT=[M:CLOF]BOMALT"
Gosub LOAD_CRITERE
Endif

# Issue X3-25731 - 2017-02-24 by FGR : BEGIN
# Affaire
#If [M:CLOF]PJTSTR <> ""
#    CRITERE = "[F:MFI]PJT>=[M:CLOF]PJTSTR"
#Gosub LOAD_CRITERE
#Endif
#
#If [M:CLOF]PJTEND <> ""
#    CRITERE = "[F:MFI]PJT<=[M:CLOF]PJTEND"
#Gosub LOAD_CRITERE
#Endif
If dim([M:CLOF]PJTDSPALL) >= 0 and [M:CLOF]PJTDSPALL = [V]CST_AYES and [M:CLOF]PJTSTR <> "" Then
  Local Char SPJT(GLONPIM)
  Local Char SBUDGET(GLONTAC)
  Local Char STASK(GLONPBU)
  Local Integer IRET

  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CLOF]PJTSTR, SPJT, SBUDGET, STASK)
  CRITERE = "pat([F:MFI]PJT,'" + SPJT + "*')<>0"
  Gosub LOAD_CRITERE
Else
  If [M:CLOF]PJTSTR <> ""
      CRITERE = "[F:MFI]PJT>=[M:CLOF]PJTSTR"
  Gosub LOAD_CRITERE
  Endif

  If [M:CLOF]PJTEND <> ""
      CRITERE = "[F:MFI]PJT<=[M:CLOF]PJTEND"
  Gosub LOAD_CRITERE
  Endif
Endif
# Issue X3-25731 - 2017-02-24 by FGR : END


# Document origine
# GH 19/07/2016 bug 117457 - to consider lines with Source Document but no Source Document Type
If ([M:CLOF]VCRORISTR <> "" | [M:CLOF]VCRORIEND <> "") & [M:CLOF]VCRTYP <> 0
   CRITERE = "find([F:MFI]VCRTYPORI,0,"+num$([M:CLOF]VCRTYP)+")<>0"
   Gosub LOAD_CRITERE
Endif

If [M:CLOF]VCRORISTR <> ""
# GH 19/07/2016 bug 117457 - to consider lines with Source Document but no Source Document Type
#    If [M:CLOF]VCRTYP <> 0
#        CRITERE = "[F:MFI]VCRTYPORI=[M:CLOF]VCRTYP"
#        Gosub LOAD_CRITERE
#    Endif
    CRITERE = "[F:MFI]VCRNUMORI>=[M:CLOF]VCRORISTR"
    Gosub LOAD_CRITERE
Endif

If [M:CLOF]VCRORIEND <> ""
# GH 19/07/2016 bug 117457 - to consider lines with Source Document but no Source Document Type
#    If [M:CLOF]VCRTYP <> 0
#        CRITERE = "[F:MFI]VCRTYPORI=[M:CLOF]VCRTYP"
#        Gosub LOAD_CRITERE
#    Endif
    CRITERE = "[F:MFI]VCRNUMORI<=[M:CLOF]VCRORIEND"
    Gosub LOAD_CRITERE
Endif

# Situation de l'OF
If [M:CLOF]MTKFLGSTR<>0
    CRITERE = "[F:MFG]MFGTRKFLG>=[M:CLOF]MTKFLGSTR"
Gosub LOAD_CRITERE
Endif
If [M:CLOF]MTKFLGEND<>0
    CRITERE = "[F:MFG]MFGTRKFLG<=[M:CLOF]MTKFLGEND"
Gosub LOAD_CRITERE
Endif


Case CHGPAG
    When 3 : # rafraichissement
      Case [M:CLOF]TRI
        When 1 : # Tri par n° OF
              CRITERE ="[F:MFG]MFGNUM >= WDEBMFGNUM"
              Gosub LOAD_CRITERE
        When 2 : # Tri par poste de charge
              CRITERE ="[F:MFO]CPLWST >= WDEBWST"
              Gosub LOAD_CRITERE
        When 3 : # Tri par article
              CRITERE ="[F:MFI]ITMREF >= WDEBITMREF"
              Gosub LOAD_CRITERE
        When 4 : # Tri par document origine
              CRITERE ="[F:MFI]VCRTYPORI >= WDEBVCRORI"
              Gosub LOAD_CRITERE
        When 5 : # Tri par affaire
             CRITERE ="[F:MFI]PJT >= WDEBPJT"
             Gosub LOAD_CRITERE
        When 6 : # Tri par composant
             CRITERE ="[F:MFM]ITMREF >= WDEBCPNITM"
             Gosub LOAD_CRITERE
      Endcase

    When 2 : #suite
      Case [M:CLOF]TRI
        When 1 : # Tri par n° OF
             CRITERE ="[F:MFG]MFGNUM > WFINMFGNUM"
             Gosub LOAD_CRITERE
        When 2 : # Tri par poste de charge
             CRITERE ="[F:MFO]CPLWST > WFINWST"
             Gosub LOAD_CRITERE
        When 3 : # Tri par article
             CRITERE ="[F:MFI]ITMREF > WFINITMREF"
             Gosub LOAD_CRITERE
        When 4 : # Tri par document origine
              CRITERE ="[F:MFI]VCRTYPORI > WFINVCRORI"
              Gosub LOAD_CRITERE
        When 5 : # Tri par affaire
             CRITERE ="[F:MFI]PJT > WFINPJT"
             Gosub LOAD_CRITERE
        When 6 : # Tri par composant
             CRITERE ="[F:MFM]ITMREF > WFINCPNITM"
             Gosub LOAD_CRITERE
       Endcase

    When -2 : #retour
      Case [M:CLOF]TRI
        When 1 : # Tri par n° OF
             CRITERE ="[F:MFG]MFGNUM < WDEBMFGNUM"
             Gosub LOAD_CRITERE
         When 2 : # Tri par poste de charge
             CRITERE ="[F:MFO]CPLWST < WDEBWST"
             Gosub LOAD_CRITERE
        When 3 : # Tri par article
             CRITERE ="[F:MFI]ITMREF < WDEBITMREF"
             Gosub LOAD_CRITERE
        When 4 : # Tri par document origine
              CRITERE ="[F:MFI]VCRTYPORI < WDEBVCRORI"
              Gosub LOAD_CRITERE
        When 5 : # Tri par affaire
             CRITERE ="[F:MFI]PJT < WDEBPJT"
             Gosub LOAD_CRITERE
        When 6 : # Tri par composant
             CRITERE ="[F:MFM]ITMREF < WDEBCPNITM"
             Gosub LOAD_CRITERE
      Endcase
Endcase

If CRITERE1 = "" : CRITERE1 ="1=1" : Endif
If CRITERE2 = "" : CRITERE2 ="1=1" : Endif
If CRITERE3 = "" : CRITERE3 ="1=1" : Endif

Return

##################################################

$LOAD_FORMULE

Raz CRITERE_MFI
Raz CRITERE_MFM
Raz CRITERE_MFO

If [M:LOF1]MFIFOR<>""
   Read [TFO]TFO0=38;[M:LOF1]MFIFOR
   If !fstat & [F:TFO]FORFOR<>""
      CRITERE_MFI="("+[F:TFO]FORFOR+")"
   Endif
Endif

######### Critères MFM #########
If [M:LOF1]MFMFOR<>""
   Read [TFO]TFO0=40;[M:LOF1]MFMFOR
   If !fstat & [F:TFO]FORFOR<>""
      CRITERE="("+[F:TFO]FORFOR+")"
      Gosub LOAD_CRITERE_MFM
   Endif
Endif

# Composant
If [M:LOF1]CPNITMSTR<> ""
    CRITERE = "[F:MFM]ITMREF>=[M:LOF1]CPNITMSTR"
    Gosub LOAD_CRITERE_MFM
Endif

If [M:LOF1]CPNITMEND<> ""
   CRITERE = "[F:MFM]ITMREF<=[M:LOF1]CPNITMEND"
   Gosub LOAD_CRITERE_MFM
Endif


######### Critères MFO #########
If [M:LOF1]MFOFOR<>""
   Read [TFO]TFO0=39;[M:LOF1]MFOFOR
   If !fstat & [F:TFO]FORFOR<>""
      CRITERE="("+[F:TFO]FORFOR+")"
      Gosub LOAD_CRITERE_MFO
   Endif
Endif

# Opération - Poste prévu
If [M:LOF1]EXTWSTSTR<> ""
    CRITERE = "[F:MFO]EXTWST>=[M:LOF1]EXTWSTSTR"
    Gosub LOAD_CRITERE_MFO
Endif

If [M:LOF1]EXTWSTEND<> ""
   CRITERE = "[F:MFO]EXTWST<=[M:LOF1]EXTWSTEND"
   Gosub LOAD_CRITERE_MFO
Endif

# Opération - Poste réalisé
If [M:LOF1]CPLWSTSTR<> ""
    CRITERE = "[F:MFO]CPLWST>=[M:LOF1]CPLWSTSTR"
    Gosub LOAD_CRITERE_MFO
Endif

If [M:LOF1]CPLWSTEND<> ""
   CRITERE = "[F:MFO]CPLWST<=[M:LOF1]CPLWSTEND"
   Gosub LOAD_CRITERE_MFO
Endif


If CRITERE_MFI = "" : CRITERE_MFI="1=1" : Endif
If CRITERE_MFM = "" : CRITERE_MFM="1=1" : Endif
If CRITERE_MFO = "" : CRITERE_MFO="1=1" : Endif

Return


########################################
$LOAD_CRITERE
If len(CRITERE)+len(CRITERE1)+1 <255
    If len(CRITERE1) <>0 : CRITERE1 += "&" : Endif
    CRITERE1 += CRITERE
Elsif len(CRITERE)+len(CRITERE2)+1 <255
    If len(CRITERE2) <>0 : CRITERE2 += "&" : Endif
    CRITERE2 += CRITERE
Else
    If len(CRITERE3) <>0 : CRITERE3 += "&" : Endif
    CRITERE3 += CRITERE
Endif

Return

########################################
$LOAD_CRITERE_MFM
If len(CRITERE)+len(CRITERE_MFM)+1 <255
    If len(CRITERE_MFM)>0 : CRITERE_MFM += "&" : Endif
    CRITERE_MFM += CRITERE
Endif
Return
########################################
$LOAD_CRITERE_MFO
If len(CRITERE)+len(CRITERE_MFO)+1 <255
    If len(CRITERE_MFO)>0 : CRITERE_MFO += "&" : Endif
    CRITERE_MFO += CRITERE
Endif
Return

####################################################################
$HIGHLIGHT
Local Char WSTYLE(GLONASY)
Affzo [M:LOF2]
# application style
For I =0 To [M:LOF2]NBLIG - 1
    nolign=I+1
    Case [M:LOF2]MFGSTA(I)
      When 1 : WSTYLE = "BACKGREEN"
      When 2 : WSTYLE = "BACKGREY"
      When 3 : WSTYLE = "BACKYELLOW"
      When 4 : WSTYLE = "BACKRED"
    Endcase
    Chgstl [M:LOF2]NBLIG(I) With WSTYLE
Next I
Return


###################################################################################
#                                                                                 #
#    ETIQUETTES ECRAN                                                             #
#                                                                                 #
###################################################################################

########################################
# Statut de l'OF
Subprog AS_MFGSTASTR(VALEUR)
Variable Integer     VALEUR
GMENLOC(3)=1 # Pas d'OF suggéré
End
Subprog AS_MFGSTAEND(VALEUR)
Variable Integer     VALEUR
GMENLOC(3)=1 # Pas d'OF suggéré
End

########################################
#article
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    [M]ITMREFEND = VALEUR
Endif
End

########################################
# article
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFSTR
    GMESSAGE = mess(44,199,1) : mkstat = 2 : End
Endif
End

########################################
# date début
Subprog AM_STRDATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] & [M]STRDATEND=[0/0/0]
    [M]STRDATEND = VALEUR
Endif
End

########################################
# date début
Subprog C_STRDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]STRDATSTR
     GMESSAGE = mess(44,199,1) : mkstat = 2 : End
Endif
End

########################################
# date fin
Subprog AM_ENDDATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] & [M]ENDDATEND=[0/0/0]
    [M]ENDDATEND = VALEUR
Endif
End

########################################
# date fin
Subprog C_ENDDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]ENDDATSTR
     GMESSAGE = mess(44,199,1) : mkstat = 2 : End
Endif
End

