########################################
Subprog IB_NBLIG
Local Integer NOL : NOL = nolign-1

If [M:LOF2]MFGNUM(NOL)=""
   Raz GBOUT3
Else
   GBOUT3=mess(166,198,1)-[M:LOF2]MFGNUM(NOL) # Ordre de fabrication
Endif

End

#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(8)<>2 End Endif

Call VALGTC(APPLI,"MFG") From SUBGTC

End



