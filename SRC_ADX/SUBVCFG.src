#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du masque VISUCFG
########################################
Subprog AS_SYMTYP(VALEUR)
Variable Integer VALEUR
Call CFGASSYM("1234579A") From CFGLIB
End

########################################
Subprog AM_SYMTYP(VALEUR)
Variable Integer VALEUR
Effzo [M:VCFG]10-20
Grizo [M:VCFG]10-15
Case VALEUR
  When 1 :
    Actzo [M:VCFG]QSTNUM
  When 2 :
    Actzo [M:VCFG]VARNUM
  When 3 :
    Actzo [M:VCFG]SCENUM
  When 4 :
    Actzo [M:VCFG]SELNUM
  When 5 :
    Actzo [M:VCFG]OPVNUM
  When 7 :
    Actzo [M:VCFG]MACNUM
  When 9 :
    Actzo [M:VCFG]SHACAT
    Actzo [M:VCFG]SHANUM
  When 10 :
    Actzo [M:VCFG]ABQNUM
Endcase
Affzo [M:VCFG]
End

