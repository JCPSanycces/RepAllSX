#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
  Case ACTION
   When "OUVRE"       : Gosub OUVRE_PIECE From GOBJTXT
   When "DEBUT"       : Gosub DEBUT_PIECE From GOBJTXT
   When "SETBOUT"     : Gosub SETBOUT_PIECE From GOBJTXT
   When "BOUTON"     : Gosub BOUTON_PIECE From GOBJTXT
   When "AP_CHOIX"    : Gosub AP_PIECE From GOBJTXT
   When "APRES_MODIF" : Gosub APRES_PIECE From GOBJTXT
   When "OK"          : Gosub OK_PIECE From GOBJTXT
   When "FIN"         : Gosub FIN_PIECE From GOBJTXT
  Endcase
Return

