#<AdxTL>@(#)12.0.0.0 $Revision$
$ACTION
Case ACTION
    When "INIPAR" : Gosub INIPAR
    When "CONT1"  : Gosub CONT1
    When "CONT2"  : Gosub CONT2
Endcase
Return

$INIPAR
    If [M:RPT]PARCOD(nolign-1)="mfctypdeb" & dim([M:DIA]MFCTYP)>0
        VALEUR = [M:DIA]MFCTYP
        [M]VALEUR1(nolign-1) = VALEUR
        Call CHARGE([M]VALEUR1(nolign-1),[M]PARTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT1(nolign-1)) From FMTVAR
        Affzo [M:RPT]
    Endif
    If [M:RPT]PARCOD(nolign-1)="mfctypfin" & dim([M:DIA]MFCTYP)>0
        VALEUR = [M:DIA]MFCTYP
        [M]VALEUR2(nolign-1) = VALEUR
        Call CHARGE([M]VALEUR2(nolign-1),[M]PARTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT2(nolign-1)) From FMTVAR
        Affzo [M:RPT]
    Endif
Return


$CONT1
    If [M:RPT]PARCOD(nolign-1)="mfctypdeb" & dim([M:DIA]MFCTYP)>0 & sigma(1,dim(GMENLOC)-1,indcum*(VALEUR=mess(indcum,2355,1)))>3
        mkstat=2
        GMESSAGE = mess(2,79,1)
    Endif
Return


$CONT2
    If [M:RPT]PARCOD(nolign-1)="mfctypdeb" & dim([M:DIA]MFCTYP)>0 & sigma(1,dim(GMENLOC)-1,indcum*(VALEUR=mess(indcum,2355,1)))>3
        mkstat=2
        GMESSAGE = mess(2,79,1)
    Endif
Return

##################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char VALEUR(10)

If clalev([M:ICMM])
    # Il faut faire "-1" car ces paramètres sont saisissables en comparaison simple
    # et dans ce cas le superviseur fait "-1"
    VALEUR = num$([M:ICMM]MATFLG-1)
    Call SETPARAM("affmat",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]MACFLG-1)
    Call SETPARAM("affmac",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]LABFLG-1)
    Call SETPARAM("afflab",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]SCOFLG-1)
    Call SETPARAM("affsco",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]OVEFLG-1)
    Call SETPARAM("affove",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]DETFLG-1)
    Call SETPARAM("affdet",NBPAR,PARAMETRE,VALEUR) From ETAT
Endif
    
End


