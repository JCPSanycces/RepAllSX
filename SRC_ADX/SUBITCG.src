#<AdxTL>@(#)9.0.0.0 $Revision$
#---- Action ZCCGRAPHE
$ACTION
Case ACTION
    When "DEBUT" : Gosub DEBUT
Endcase
Return

$DEBUT
[M:ITC5]=[M:ITC4]
Chgfmt [M:ITC5]BUD2 With "-N:6.2"
Affzo [M:ITC5]
Return


#----------- Traitement de remplissage du tableau permettant d'afficher le graphique ----------#

$CHARG_GRAPH
Local Char TIT1, TIT2, TIT3, TIT4

Raz TIT1, TIT2, TIT3, TIT4

[M:ITC4]NBLIG4=0
If [M:ITC1]STDCST(9) <> ""
    [M:ITC4]STD2(0) = evalue([M:ITC1]STDCST(2))
    [M:ITC4]STD2(1) = evalue([M:ITC1]STDCST(3))
    [M:ITC4]STD2(2) = evalue([M:ITC1]STDCST(4))
    [M:ITC4]STD2(3) = evalue([M:ITC1]STDCST(5))
    [M:ITC4]STD2(4) = evalue([M:ITC1]STDCST(6))
    [M:ITC4]NBLIG4=5
    TIT1 = mess(1,219,1)
Else
   Effzo [M:ITC4]STD2
Endif
If [M:ITC1]ACTCST(9) <> ""
    [M:ITC4]ACT2(0) = evalue([M:ITC1]ACTCST(2))
    [M:ITC4]ACT2(1) = evalue([M:ITC1]ACTCST(3))
    [M:ITC4]ACT2(2) = evalue([M:ITC1]ACTCST(4))
    [M:ITC4]ACT2(3) = evalue([M:ITC1]ACTCST(5))
    [M:ITC4]ACT2(4) = evalue([M:ITC1]ACTCST(6))
    [M:ITC4]NBLIG4=5
    TIT2 = mess(2,219,1)
Else
   Effzo [M:ITC4]ACT2
Endif
If [M:ITC1]BUDCST(9) <> ""
    [M:ITC4]BUD2(0) = evalue([M:ITC1]BUDCST(2))
    [M:ITC4]BUD2(1) = evalue([M:ITC1]BUDCST(3))
    [M:ITC4]BUD2(2) = evalue([M:ITC1]BUDCST(4))
    [M:ITC4]BUD2(3) = evalue([M:ITC1]BUDCST(5))
    [M:ITC4]BUD2(4) = evalue([M:ITC1]BUDCST(6))
    [M:ITC4]NBLIG4=5
    TIT3 = mess(3,219,1)
Else
   Effzo [M:ITC4]BUD2
Endif
If [M:ITC1]SIMCST(9) <> ""
    [M:ITC4]SIM2(0) = evalue([M:ITC1]SIMCST(2))
    [M:ITC4]SIM2(1) = evalue([M:ITC1]SIMCST(3))
    [M:ITC4]SIM2(2) = evalue([M:ITC1]SIMCST(4))
    [M:ITC4]SIM2(3) = evalue([M:ITC1]SIMCST(5))
    [M:ITC4]SIM2(4) = evalue([M:ITC1]SIMCST(6))
    [M:ITC4]NBLIG4=5
    TIT1 = mess(4,219,1)
Else
   Effzo [M:ITC4]SIM2
Endif
If [M:ITC4]NBLIG4>0
    [M:ITC4]TYPCST2(0)=mess(1,2361,1)
    [M:ITC4]TYPCST2(1)=mess(3,2361,1)
    [M:ITC4]TYPCST2(2)=mess(2,2361,1)
    [M:ITC4]TYPCST2(3)=mess(4,2361,1)
    [M:ITC4]TYPCST2(4)=mess(5,2361,1)
Endif

#Titcol [M:ITC4]NBLIG4 mess(3,2937,1),TIT1,TIT2,TIT3,TIT4

Return



