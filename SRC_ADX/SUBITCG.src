    [M:ITC4]MATTOT2([M:ITC4]NBLIG2) = evalue([M:ITC1]BUDCST(2))
    [M:ITC4]MACTOT2([M:ITC4]NBLIG2) = evalue([M:ITC1]BUDCST(3))
    [M:ITC4]LABTOT2([M:ITC4]NBLIG2) = evalue([M:ITC1]BUDCST(4))
    [M:ITC4]SCOTOT2([M:ITC4]NBLIG2) = evalue([M:ITC1]BUDCST(5))
