    [M:ITC4]CUR([M:ITC4]NBLIG) = GLOCALDEV
    [M:ITC4]CSTTYP([M:ITC4]NBLIG) = mess(1,219,1)
    [M:ITC4]MATTOT([M:ITC4]NBLIG) = evalue([M:ITC1]STDCST(2))
    [M:ITC4]MACTOT([M:ITC4]NBLIG) = evalue([M:ITC1]STDCST(3))
    [M:ITC4]LABTOT([M:ITC4]NBLIG) = evalue([M:ITC1]STDCST(4))
