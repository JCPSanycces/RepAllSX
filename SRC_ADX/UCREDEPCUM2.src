#<AdxTL>@(#)3.0.0.0 $Revision$
###########################################
#    TRAITEMENT DE CREATION DES DEPREC de la période courante
#    à partir de la période précédente
#    et reconstitution des cumuls
###########################################
#*********************************************************************
#    Création
#    CBO -
#
#*********************************************************************
#    Modification
#
#    CBO - 05.12.2012  FQ86235 : maj des dates PERREFCLC, I et T en début d'exercice
#
#*********************************************************************
#**
#*
#*
#* @param PSIMU     G_OUI pour le mode simulation, G_NON pour le mode correctif
#* @param PFULLTRC  G_OUI pour la trace étendue, G_NON pour la trace normale
#* @param PCPYTOUS  G_OUI pour toutes les sociétés
#* @param PCPY      société traitée
#* @param PDPRPLNTOUS  G_OUI pour tous les plans d'amortissement
#* @param PCPY      plan traité (si il existe dans la(les) société(s)
#*!
Subprog UCREDEPCUM(PSIMU, PFULLTRC, PCPYTOUS, PCPY, PDPRPLNTOUS, PDPRPLN)
Value Integer PSIMU, PFULLTRC, PCPYTOUS
Value Char PCPY()
Value Integer PDPRPLNTOUS, PDPRPLN

###########################################
  If PSIMU <> G_OUI
    PSIMU    = G_NON : # G_OUI pour le mode simulation, G_NON pour le mode correctif
  Endif
  If PFULLTRC <> G_OUI
    PFULLTRC = G_NON : # G_OUI pour la trace étendue, G_NON pour la trace normale
  Endif
  If PCPYTOUS = G_OUI
    PCPY = ""
  Else
    PCPYTOUS = G_NON
  Endif
###########################################

Local Integer N_PLN, LBPLANOK
Local Integer FLGOK   : FLGOK   = G_OUI
Local Integer RERROR

Local Integer NB_DEP, NB_DEP_COR, NB_DEP_ERR, NB_DEP_ANO
  NB_DEP = 0
  NB_DEP_COR = 0
  NB_DEP_ERR = 0
  NB_DEP_ANO = 0
Local Integer NB_DEPSOCSAV, NB_DEPCTXSAV, LNBSOC
Local Integer NB_DEPANOSOCSAV, NB_DEPANOCTXSAV
Local Integer NB_ANOPLAN(0..15), NB_CORPLAN(0..15)


Local Date    STRFIYCOU(1..G300MAX)      # Début d'exercice courant
Local Date    ENDFIYCOU(1..G300MAX)      # Fin d'exercice courant
Local Date    STRPERCOU(1..G300MAX)      # Début de période courante
Local Date    ENDPERCOU(1..G300MAX)      # Fin de période courante

Local Date    STRFIYCOUP(1..G300MAX)     # Début d'exercice précédent
Local Date    ENDFIYCOUP(1..G300MAX)     # Fin d'exercice précédent
Local Date    STRPERCOUP(1..G300MAX)     # Début de période courante exercice précédent
Local Date    ENDPERCOUP(1..G300MAX)     # Fin de période courante exercice précédent
Local Integer PERPREC(1..G300MAX)        # Présence d'une période précédente

Local Integer DEBUT_EXERCICE

Local Integer RET, I

Local    Integer LNBDAT      : LNBDAT      = 4                      : # Dimensionnement des dates
Local    Integer LDT_DEBEXO  : LDT_DEBEXO  = 0                      : # Date début exercice
Local    Integer LDT_FINEXO  : LDT_FINEXO  = 1                      : # Date fin exercice
Local    Integer LDT_DEBPCO  : LDT_DEBPCO  = 2                      : # Date début période courante
Local    Integer LDT_FINPCO  : LDT_FINPCO  = 3                      : # Date fin période courante
Local    Date    LDATCRT(0..LNBDAT)                                 : # Dates sur l'exercice courant
Local    Date    LDATNXT(0..LNBDAT)                                 : # Dates sur l'exercice courant
Local Decimal D_DPRCUM

  If !clalev([CPY])  : Local File COMPANY   [CPY]  : Endif
  If !clalev([CNX])  : Local File CONTEXT   [CNX]  : Endif
  If !clalev([FIY])  : Local File FISCYEAR  [FIY]  : Endif
  If !clalev([WFAS]) : Local File FXDASSETS [WFAS] : Endif

#  If !clalev([DEPR]) : Local File DEPREC    [DEPR] : Endif
  If !clalev([DEPC]) : Local File DEPREC    [DEPC] : Endif
  If !clalev([DEPS]) : Local File DEPREC    [DEPS] : Endif

  If !clalev([M:DIV]): Local Mask CALDIV    [DIV]  : Endif
  If !clalev([M:DPM]): Local Mask CALDPM    [DPM]  : Endif

  Local Integer BGESCCN : # Concessions gérée
  BGESCCN = func AFNC.ACTIV("CCN")

# ajout propre v6, v7 ______________________________________________
  If !clalev([M:DIV2]): Local Mask CALDIV2    [DIV2] : Endif
#
#  # vient de CAL_LEC_CONTEXTES de GLOBB0 :
  [M:DIV]BACTCCN = BGESCCN
  Local Integer BACTKRU : # Russie
  BACTKRU = func AFNC.ACTIV("KRU")
  [M:DIV]BACTKRU = BACTKRU
  Local Integer BACTKPL : # Polonais
  BACTKPL = func AFNC.ACTIV("KPL")
  [M:DIV]BACTKPL = BACTKPL
# fin ajout v6, v7 __________________________________________

# ajout propre v8 et > ______________________________________________
#  If !clalev([M:DIV2]): Local Mask CALDIV2    [DIV2] : Endif
#Local Struct DIV Using CALDIV :  DIV = Newstc [SDIV], CALDIV
  # vient de CAL_LEC_CONTEXTES de CLCB0 :
#  DIV.BACTCCN = BGESCCN
#  Local Integer BACTKRU : # Russie
#  BACTKRU = func AFNC.ACTIV("KRU")
#  DIV.BACTKRU = BACTKRU
#  Local Integer BACTKPL : # Polonais
#  BACTKPL = func AFNC.ACTIV("KPL")
#  DIV.BACTKPL = BACTKPL
# fin ajout v8 et > __________________________________________

  Call OUVRE_TRACE("Creation of unexistant DEPREC in current fiscal year") From LECFIC

  Call ECR_TRACE("Process       : UCREDEPCUM", 0) From GESECRAN
  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("Simulation    :" - mess(PSIMU, 1, 1), 0) From GESECRAN
  Call ECR_TRACE("Full log      :" - mess(PFULLTRC, 1, 1), 0) From GESECRAN
  Call ECR_TRACE("All companies :" - mess(PCPYTOUS, 1, 1), 0) From GESECRAN
  If PCPYTOUS = G_NON
  Call ECR_TRACE("Company       :" - PCPY, 0) From GESECRAN
  Endif
  Call ECR_TRACE("All plans     :" - mess(PDPRPLNTOUS, 1, 1), 0) From GESECRAN
  If PDPRPLNTOUS = G_NON
  Call ECR_TRACE("plan          :" - mess(PDPRPLN, 3101, 1), 0) From GESECRAN
  Else
    PDPRPLN = 0
  Endif

  Call ECR_TRACE("Date" - format$("D:" + GFMDAT4, date$) - "Time" - time$,0) From GESECRAN
  Call ECR_TRACE("", 0) From GESECRAN

  Gosub TRTSOC


  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE("==============================================================",0) From GESECRAN
  Call ECR_TRACE(num$(LNBSOC) - "companies processed", 0) From GESECRAN
  Call ECR_TRACE(num$(NB_DEP_COR) - "DEPREC created", 0) From GESECRAN
  Call ECR_TRACE(num$(NB_DEP_ANO) - "DEPREC not corrected", 0) From GESECRAN
  Call ECR_TRACE(num$(NB_DEP_ERR) - "errors on update", 0) From GESECRAN
  Call ECR_TRACE("==============================================================",0) From GESECRAN
  Call FERME_TRACE() From LECFIC

  Call LEC_TRACE() From LECFIC
# ajout v8 et > ______________________________________________
#  Free [SDIV]
# fin ajout v8 et > ______________________________________________

End


$TRTSOC

#PCPYTOUS = 1
#PCPY = "1*"
  If PCPYTOUS = 2
    WFILTRE = '1 = 1'
  Else
    I = instr(1, PCPY, "*")
    If I
      WFILTRE = 'CPY >= "' + left$(PCPY, I - 1)
      WFILTRE += '" and CPY <= "' + left$(PCPY, I - 1) + 'Z"'
    Else
      WFILTRE = 'CPY = PCPY'
    Endif
  Endif

  If PSIMU = G_NON
    Trbegin [DEPS]
  Endif
  For [CPY] Where evalue(WFILTRE)

    Call ECR_TRACE("===========", 0) From GESECRAN
    Call ECR_TRACE("Company" - [F:CPY]CPY, 0) From GESECRAN
    Call ECR_TRACE("===========", 0) From GESECRAN
    Call TEMPON("Company" - [F:CPY]CPY) From GESECRAN
    Raz [M:DIV], [M:DPM]
    #===
    # Chargement des dates du contexte courantes et précédentes
    Call GET_CPY_DAT([F:CPY]CPY, STRFIYCOU, ENDFIYCOU,
&                    STRPERCOU, ENDPERCOU, RET) From GLOBIENS

    Call GET_CPY_DAT_PREC([F:CPY]CPY, STRFIYCOUP, ENDFIYCOUP,
&                         STRPERCOUP, ENDPERCOUP, PERPREC,
&                         [M:DIV]DIFTYP, [M:DIV]DIFRGL, RET)

    [M:DIV]BSRA = 0  # forcé à 0 : ==> ne traite pas les sorties retro actives
    Gosub CAL_LEC_MODES From GLOBB0

    Gosub TRTCNX

    If NB_DEPSOCSAV <> NB_DEP_COR
      LNBSOC += 1
      Call ECR_TRACE("Company ->" - [F:CPY]CPY - ":" - num$(NB_DEP_COR - NB_DEPSOCSAV) - "DEPREC created", 0) From GESECRAN
    Endif
    NB_DEPSOCSAV = NB_DEP_COR
    If NB_DEPANOSOCSAV <> NB_DEP_ANO
      Call ECR_TRACE("Company ->" - [F:CPY]CPY - ":" - num$(NB_DEP_ANO - NB_DEPANOSOCSAV) - "DEPREC not created", 0) From GESECRAN
    Endif
    NB_DEPANOSOCSAV = NB_DEP_ANO
  Next
  Call TEMPOFF From GESECRAN


  If PSIMU = G_NON
    Commit
  Endif

Return

$TRTCNX

  For [CNX] Where CPY=[F:CPY]CPY

    Raz NB_ANOPLAN, NB_CORPLAN
    LBPLANOK = 0
    If PDPRPLN
      For N_PLN=0 To [F:CNX]NBPLC-1
        If PDPRPLN = [F:CNX]PLNCAA(N_PLN)
          LBPLANOK = 1
          Break
        Endif
      Next N_PLN
    Else
      LBPLANOK = 1
    Endif


    If LBPLANOK
      If STRFIYCOU([F:CNX]CNX) = STRPERCOU([F:CNX]CNX)
        DEBUT_EXERCICE = G_OUI

        If PERPREC([F:CNX]CNX) = G_NON
          DEBUT_EXERCICE = 99
        Endif
      Else
        DEBUT_EXERCICE = G_NON
      Endif

      Call ECR_TRACE("", 0) From GESECRAN
      Call ECR_TRACE("", 0) From GESECRAN
      Call ECR_TRACE("Context                 :" - mess([F:CNX]CNX, 300, 1), 0) From GESECRAN
      Call ECR_TRACE("  Current fiscal year   :" - format$("D:" + GFMDAT4, STRFIYCOU([F:CNX]CNX)) - "->" - format$("D:" + GFMDAT4, ENDFIYCOU([F:CNX]CNX)), 0) From GESECRAN
      Call ECR_TRACE("    Current period      :" - format$("D:" + GFMDAT4, STRPERCOU([F:CNX]CNX)) - "->" - format$("D:" + GFMDAT4, ENDPERCOU([F:CNX]CNX)), 0) From GESECRAN
      If DEBUT_EXERCICE = 99
      Call ECR_TRACE("    Previous period     : Not found", -1) From GESECRAN
      Else

      If DEBUT_EXERCICE = G_OUI
      Call ECR_TRACE("  Previous fiscal year  : " - format$("D:" + GFMDAT4, STRFIYCOUP([F:CNX]CNX)) - "->" - format$("D:" + GFMDAT4, ENDFIYCOUP([F:CNX]CNX)), 0) From GESECRAN
      Endif
      Call ECR_TRACE("    Previous period     : " - format$("D:" + GFMDAT4, STRPERCOUP([F:CNX]CNX)) - "->" - format$("D:" + GFMDAT4, ENDPERCOUP([F:CNX]CNX)), 0) From GESECRAN
      Endif
      Call ECR_TRACE("", 0) From GESECRAN

      Gosub TRTDEPREC

      If NB_DEPCTXSAV <> NB_DEP_COR or NB_DEPANOCTXSAV <> NB_DEP_ANO
        Call ECR_TRACE("", 0) From GESECRAN

#        If NB_DEPCTXSAV <> NB_DEP_COR
#          Call ECR_TRACE("Context :" - mess([F:CNX]CNX, 300, 1) - ":" - num$(NB_DEP_COR - NB_DEPCTXSAV) - "Changes", 0) From GESECRAN
#        Endif
        NB_DEPCTXSAV = NB_DEP_COR

#        If NB_DEPANOCTXSAV <> NB_DEP_ANO
#          Call ECR_TRACE("Context :" - mess([F:CNX]CNX, 300, 1) - ":" - num$(NB_DEP_ANO - NB_DEPANOCTXSAV) - "not corrected", 0) From GESECRAN
#        Endif
        NB_DEPANOCTXSAV = NB_DEP_ANO

        For N_PLN=0 To [F:CNX]NBPLC-1

          # tous les plans ou un seul
          If PDPRPLN = 0 or PDPRPLN = [F:CNX]PLNCAA(N_PLN)
            If NB_ANOPLAN(N_PLN) + NB_CORPLAN(N_PLN)
              Call ECR_TRACE("Plan ->" - mess([F:CNX]PLNCAA(N_PLN), 3101, 1) - ":" -
&             num$(NB_CORPLAN(N_PLN)) -  "DEPREC corrected" -
&             num$(NB_ANOPLAN(N_PLN)) -  "DEPREC not corrected", 0) From GESECRAN
            Endif
            If PDPRPLN
              Break
            Endif
          Endif
        Next N_PLN
        Call ECR_TRACE("", 0) From GESECRAN
      Endif
    Else
      Call ECR_TRACE("Context ->" - mess([F:CNX]CNX, 300, 1) - ": no plan selected", 0) From GESECRAN
    Endif

  Next

Return


$TRTDEPREC

  For [WFAS] Where CPY=[F:CPY]CPY and (ISSDAT>=STRFIYCOU([F:CNX]CNX) or ISSDAT=[0/0/0])
    For N_PLN=0 To [F:CNX]NBPLC-1

      # tous les plans ou un seul
      If PDPRPLN = 0 or PDPRPLN = [F:CNX]PLNCAA(N_PLN)
        NB_DEP += 1
        If mod(NB_DEP, 100) = 0
          Call TEMPON(num$(NB_DEP) - [F:CPY]CPY - "/" - [F:WFAS]AASREF - "/" - mess([F:CNX]PLNCAA(N_PLN), 3101, 1)) From GESECRAN
        Endif
        # recherche du DEPREC courant
        Look [F:DEPC]DEP0=[F:WFAS]AASREF;[F:CNX]PLNCAA(N_PLN);ENDFIYCOU([F:CNX]CNX);ENDPERCOU([F:CNX]CNX)
        If fstat

          # il n'existe pas mais ce CTX n'a pas de période précédente : on ne peut pas corriger
          If DEBUT_EXERCICE = 99
            Call ECR_TRACE("Asset/Plan ->" - [F:WFAS]AASREF - "/" - mess([F:CNX]PLNCAA(N_PLN), 3101, 1) - "without previous DEPREC", 1) From GESECRAN
            NB_DEP_ANO += 1
            NB_ANOPLAN(N_PLN) += 1
          # il n'existe pas, recherche du DEPREC précédent
          Else
            If DEBUT_EXERCICE = G_OUI
              Read [F:DEPC]DEP0=[F:WFAS]AASREF;[F:CNX]PLNCAA(N_PLN);ENDFIYCOUP([F:CNX]CNX);ENDPERCOUP([F:CNX]CNX)
            Else
              Read [F:DEPC]DEP0=[F:WFAS]AASREF;[F:CNX]PLNCAA(N_PLN);ENDFIYCOU([F:CNX]CNX);STRPERCOU([F:CNX]CNX)-1
            Endif

            If fstat
              # il n'existe pas non plus -> On ne peut rien faire
              Call ECR_TRACE("Asset/Plan ->" - [F:WFAS]AASREF - "/" - mess([F:CNX]PLNCAA(N_PLN), 3101, 1) - "without previous DEPREC", 1) From GESECRAN
              NB_DEP_ANO += 1
              NB_ANOPLAN(N_PLN) += 1
            Else
              # le DEPREC précédent existe -> on crée le DEPREC dans la période courante
              RERROR = 0

              #### [F:DEPR] -> DEPREC période courante NON trouvé pour le bien
              # [F:DEPC] -> DEPREC précédent qu'on transforme en courant
              # [F:DEPS] -> DEPREC résultant de la clôture du calcul

#              [F:DEPR] = [F:DEPC]

              [F:DEPC]DEPSTA    = GVML_SCNOCAL

              [M:DIV]INDMOD = find([F:DEPC]DPM, [M:DPM]DPM)
              [F:DEPS] = [F:DEPC]

              If (DEBUT_EXERCICE = G_OUI)

                Gosub CAL_CLORE_EXERCICE_AMT From GLOBB6
                [F:DEPS]PERDPEFLG= G_NON

                [F:DEPS]LSTCLODAT = ENDFIYCOUP([F:CNX]CNX)
                Gosub CORRIGE_EXE
                Gosub CORRIGE

                # FQ86235
                [F:DEPS]PERREFCLC  = STRFIYCOU([F:CNX]CNX)
                [F:DEPS]PERREFCLCT = STRFIYCOU([F:CNX]CNX)
                [F:DEPS]PERREFCLCI = STRFIYCOU([F:CNX]CNX)
              Else
                Gosub CAL_CLORE_PERIODE_AMT From GLOBB6

                [F:DEPS]LSTCLODAT = ENDPERCOUP([F:CNX]CNX)
                Gosub CORRIGE_PER
                Gosub CORRIGE

              Endif
              [F:DEPS]FIYSTRDAT = STRFIYCOU([F:CNX]CNX)
              [F:DEPS]FIYENDDAT = ENDFIYCOU([F:CNX]CNX)
              [F:DEPS]PERSTRDAT = STRPERCOU([F:CNX]CNX)
              [F:DEPS]PERENDDAT = ENDPERCOU([F:CNX]CNX)

              [F:DEPS]DEPSTA    = GVML_SCNOCAL

  ########################
              If PSIMU = G_OUI
                NB_DEP_COR += 1
                NB_CORPLAN(N_PLN) += 1
                Call ECR_TRACE("Creation (Asset/plan) ->" - [F:WFAS]AASREF - "/" - mess([F:DEPS]DPRPLN, 3101, 1), 0) From GESECRAN
              Else
                Write [F:DEPS]
                If fstat
                  FLGOK=G_NON
                  Call ECR_TRACE("Error writing DEPREC  (Asset/plan) ->" -
&                        [F:WFAS]AASREF - "/" - num$([F:DEPS]DPRPLN) -
&                        "fstat =" - num$(fstat), 1) From GESECRAN
                  NB_DEP_ERR += 1
                Endif

                If fstat = 0
                  Update [F:WFAS] Where AASREF = [F:DEPS]AASREF With FLGCLC = G_OUI, FLGCNXCLC([F:DEPS]CNX-1) = G_OUI
                  If fstat
                    Rollback
                    Trbegin [DEPS]
                    FLGOK=G_NON
                    Call ECR_TRACE("Error update FXDASSETS  (Asset/plan) ->" -
&                          [F:WFAS]AASREF - "/" - num$([F:DEPS]DPRPLN) -
&                          "fstat =" - num$(fstat), 1) From GESECRAN
                    NB_DEP_ERR += 1
                  Else
                    Commit
                    Trbegin [DEPS]
                    Call ECR_TRACE("Creation (Asset/plan) ->" - [F:WFAS]AASREF - "/" - mess([F:DEPS]DPRPLN, 3101, 1), 0) From GESECRAN
                    NB_DEP_COR += 1
                    NB_CORPLAN(N_PLN) += 1
                  Endif
                Endif
              Endif
            Endif
          Endif
        Else
          If PFULLTRC = G_OUI
            Call ECR_TRACE("Ok (Asset/plan) ->" - [F:WFAS]AASREF - "/" - mess([F:CNX]PLNCAA(N_PLN), 3101, 1), 0) From GESECRAN
          Endif
        Endif

        If PDPRPLN
            # Un seul plan à traiter: on peut donc sortir de la boucle des plans
            Break
        Endif
      Endif
    Next N_PLN
  Next

Return


######################################################################################
# CORRIGE
######################################################################################



$CORRIGE_EXE

  # Recalcul des cumuls liés aux écarts entre plans
  [F:DEPS]LEGCUM    += [F:DEPC]PERLEGCUM + [F:DEPC]LEG
  [F:DEPS]LEGRVECUM += [F:DEPC]PERLEGRVE + [F:DEPC]LEGRVE

  [F:DEPS]PERLEGCUM = 0
  [F:DEPS]LEG = 0
  [F:DEPS]PERLEGRVE = 0
  [F:DEPS]LEGRVE = 0

  [F:DEPS]LNKCUM    += [F:DEPC]PERLNKCUM + [F:DEPC]LNK
  [F:DEPS]PERLNKCUM = 0
  [F:DEPS]LNK = 0

Return

$CORRIGE_PER

  [F:DEPS]PERLEGCUM += [F:DEPC]LEG
  [F:DEPS]PERLEGRVE += [F:DEPC]LEGRVE

  [F:DEPS]LEG = 0
  [F:DEPS]LEGRVE = 0

  [F:DEPS]PERLNKCUM    += [F:DEPC]LNK
  [F:DEPS]LNK = 0

Return

$CORRIGE
  [F:DEPS]FLGPST  = G_NON
  [F:DEPS]PSTDPE  = 0
  [F:DEPS]PSTEXC  = 0
  [F:DEPS]PSTDER  = 0
  [F:DEPS]PSTDERRVE  = 0
  [F:DEPS]PSTRVETRF  = 0
  [F:DEPS]PSTRVACRB  = 0
  [F:DEPS]FLGPSTLNK  = G_NON
  [F:DEPS]PSTLNK  = 0

  If BGESCCN
    [F:DEPS]PSTCADCRB  = 0
  Endif

Return
$CORRIGE_OLD

  [F:DEPR]PERREFCLC  = [F:DEPS]PERREFCLC
  [F:DEPR]PERREFCLCT = [F:DEPS]PERREFCLCT
  [F:DEPR]PERREFCLCI = [F:DEPS]PERREFCLCI

  [F:DEPR]DPRCUMFLG  = [F:DEPS]DPRCUMFLG
  [F:DEPR]DPRCUM     = [F:DEPS]DPRCUM
  [F:DEPR]EXECLOCUMT = [F:DEPS]EXECLOCUMT
  [F:DEPR]EXECLOCUMI = [F:DEPS]EXECLOCUMI

  [F:DEPR]PERCLOCUM  = [F:DEPS]PERCLOCUM
  [F:DEPR]PERCLOCUMT = [F:DEPS]PERCLOCUMT
  [F:DEPR]PERCLOCUMI = [F:DEPS]PERCLOCUMI
  [F:DEPR]ENDDPE     = [F:DEPS]ENDDPE
  [F:DEPR]ENDDPET    = [F:DEPS]ENDDPET
  [F:DEPR]ENDDPEI    = [F:DEPS]ENDDPEI
  [F:DEPR]ENDDPEFLG  = [F:DEPS]ENDDPEFLG

  [F:DEPR]PERCLOEXC  = [F:DEPS]PERCLOEXC
  [F:DEPR]PERCLOEXCT = [F:DEPS]PERCLOEXCT
  [F:DEPR]PERCLOEXCI = [F:DEPS]PERCLOEXCI
  [F:DEPR]EXCCUM     = [F:DEPS]EXCCUM
  [F:DEPR]EXCCUMT    = [F:DEPS]EXCCUMT
  [F:DEPR]EXCCUMI    = [F:DEPS]EXCCUMI
  [F:DEPR]EXCDPR     = [F:DEPS]EXCDPR
  [F:DEPR]EXCDPRT    = [F:DEPS]EXCDPRT
  [F:DEPR]EXCDPRI    = [F:DEPS]EXCDPRI

  [F:DEPR]CRBCUM     = [F:DEPS]CRBCUM
  [F:DEPR]CRBCUMFLG  = [F:DEPS]CRBCUMFLG
  [F:DEPR]CRBAMT     = [F:DEPS]CRBAMT

  [F:DEPR]ALWCUM     = [F:DEPS]ALWCUM
  [F:DEPR]ALWCUMFLG  = [F:DEPS]ALWCUMFLG
  [F:DEPR]ALWAMT     = [F:DEPS]ALWAMT
  [F:DEPR]ALWAMTFLG  = [F:DEPS]ALWAMTFLG

  [F:DEPR]PERQTYCUM  = [F:DEPS]PERQTYCUM
  [F:DEPR]FIYQTY     = [F:DEPS]FIYQTY

  [F:DEPR]EXERVADEV  = [F:DEPS]EXERVADEV
  [F:DEPR]PERRVACUM  = [F:DEPS]PERRVACUM
  [F:DEPR]PERRVADEV  = [F:DEPS]PERRVADEV
  [F:DEPR]RVATIADAT  = [F:DEPS]RVATIADAT

  [F:DEPR]EXEIMLCUM  = [F:DEPS]EXEIMLCUM
  [F:DEPR]EXERVECUM  = [F:DEPS]EXERVECUM
  [F:DEPR]EXETRFCUM  = [F:DEPS]EXETRFCUM
  [F:DEPR]PERIMLCUM  = [F:DEPS]PERIMLCUM
  [F:DEPR]PERRVECUM  = [F:DEPS]PERRVECUM
  [F:DEPR]PERTRFCUM  = [F:DEPS]PERTRFCUM

  [F:DEPR]DFDBLC     = [F:DEPS]DFDBLC
  [F:DEPR]DFDRVE     = [F:DEPS]DFDRVE
Return


Subprog GET_CPY_DAT_PREC(PCPY, RSTRFIYCOUP, RENDFIYCOUP,
&                        RSTRPERCOUP, RENDPERCOUP, RPERPREC,
&                        RDIFTYP, RDIFRGL, PRET)
Value    Char    PCPY                # Société passée en paramètre
Variable Date    RSTRFIYCOUP(1..)     # Début d'exercice COUPrant
Variable Date    RENDFIYCOUP(1..)     # Fin d'exercice COUPrant
Variable Date    RSTRPERCOUP(1..)     # Début de période COUPrante
Variable Date    RENDPERCOUP(1..)     # Fin de période COUPrante
Variable Integer RPERPREC(1..)       # Présence d'un exercice précédent
Variable Integer RDIFTYP, RDIFRGL
Variable Integer PRET

  PRET = 0

Local Date    LDATSTRFIY
Local Integer I_CNX

  If !clalev([F:WCNX]) : Local File CONTEXT  [WCNX] : Endif
  If !clalev([F:WFIY]) : Local File FISCYEAR [WFIY] : Endif

  Filter [WCNX] Where CPY=PCPY
  For [WCNX]
    RPERPREC([F:WCNX]CNX) = G_OUI

    # lecture de l'exercice courant
    Filter [WFIY] Where (CPY=PCPY & CNX=[F:WCNX]CNX & STAFIY=GVML_TECOURA)
    Read [WFIY] First
    Filter [WFIY]
    If !fstat

      If ( [F:WFIY]STAFIY = GVML_TECOURA ) Then
        If ( [F:WFIY]CNX = G300CPFI ) Then
          RDIFTYP = [F:WFIY]DFDTYP
          RDIFRGL = [F:WFIY]DFDCOD
        Endif
      Endif
      # la période précédente est dans le même exercice
      If [F:WFIY]INDCURPER > 1
#        RSTRFIYCOUP([F:WCNX]CNX)=[F:WFIY]DATSTRFIY
#        RENDFIYCOUP([F:WCNX]CNX)=[F:WFIY]DATENDFIY
        RSTRFIYCOUP([F:WCNX]CNX) = [0/0/0]
        RENDFIYCOUP([F:WCNX]CNX) = [0/0/0]

        RSTRPERCOUP([F:WCNX]CNX) = [F:WFIY]DATSTRPER([F:WFIY]INDCURPER - 2)
        RENDPERCOUP([F:WCNX]CNX) = [F:WFIY]DATENDPER([F:WFIY]INDCURPER - 2)
      Else

        # la période précédente doit être la dernière du précédent exercice
        LDATSTRFIY = [F:WFIY]DATSTRFIY
        Filter [WFIY] Where (CPY=PCPY & CNX=[F:WCNX]CNX & DATENDFIY=LDATSTRFIY-1)
        Read [WFIY] First
        Filter [WFIY]
        If fstat
          # Pas d'exercice précédent (donc pas de période précédente)
          RPERPREC([F:WCNX]CNX) = G_NON
        Else
          RSTRFIYCOUP([F:WCNX]CNX)=[F:WFIY]DATSTRFIY
          RENDFIYCOUP([F:WCNX]CNX)=[F:WFIY]DATENDFIY
          RSTRPERCOUP([F:WCNX]CNX)=[F:WFIY]DATSTRPER([F:WFIY]NBRPER-1)
          RENDPERCOUP([F:WCNX]CNX)=[F:WFIY]DATENDPER([F:WFIY]NBRPER-1)
        Endif
      Endif
    Endif
  Next
  Filter [WCNX]

End
