#<AdxTL>@(#)12.0.0.0 $Revision$ Mod謥 action m鴩er
#########################################################################
# TRCPROACT : Action métier - trt communs aux modèles massif et unitaire - Modèle 2
#########################################################################
 Local Char MASUNI : MASUNI="U"
 Local Char ACTNAM : ACTNAM="FASTEST"
 Call LAUNCH_ACT(MASUNI) From ="TRT"+ACTNAM
End
#########################################################################
Local Char PARAM(30)(1..4)
Local Char VALEUR

$ACTION
# Infbox "TRCPROACT/"-ACTION
  Case ACTION
   When "INIT_DIA"    : Gosub INIT_DIA
   When "INIT"        : Gosub INIT
   When "AVANT_PAR"   : Gosub AVANT_PAR
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "SETBOUT"     : Gosub SETBOUT
   When "APRES_MODIF" : Gosub APRES_MODIF
   When "AP_CHOIX"    : Gosub AP_CHOIX
   When "BOUTON"      : Gosub BOUTON
   When "END"         : Gosub END_BOITE
   When "OK"          : Gosub OK
   When "ABA"         : Gosub ABA
   When "EXEC"        : Gosub EXEC
   When "CONTROLE"    : Gosub CONTROLE
   When "FIN"         : Gosub FIN
   When "TERMINE"     : Gosub TERMINE
   When "SORTIE"      : Gosub SORTIE
   When Default
  Endcase
Return

#########################################################################
$OUVRE_BATCH
 # Vide pour l'instant : appelé uniquement en saisie des paramétres en lancement de requête ou en saisie des paramètres
 #                       par clique droit sur une requête listée dans le tableau du gestionnaire des requêtes.
Return

#########################################################################
$INIT_DIA
 If GBATCH
   Gosub SET_CONSTANTES From TRCPROCOM                            #-> Constantes 
   Gosub DEF_GLOBALES   From TRCPROCOM                            #-> Globales
   Gosub GET_PARAMETRES From TRCPROCOM                            #=> Paramètres de l'action
   Gosub PREP_ACT       From TRCPROCOM                            #=> Initialisations de variables
   If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif  #=> Déclarations / initialisations particulières aux traitements massifs
 Endif
Return

#########################################################################
$INIT #(Uniquement en execution d'une action massive batch)
 If GSERVEUR                                                      # Si on est en massif à l'exécution d'une requête batch:
   Gosub SET_CONSTANTES From TRCPROCOM                            #-> Constantes 
   Gosub DEF_GLOBALES   From TRCPROCOM                            #-> Globales
   Gosub GET_PARAMETRES From TRCPROCOM                            #=> Paramètres de l'action
   Gosub PREP_ACT       From TRCPROCOM                            #=> Initialisations de variables
   If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif  #=> Déclarations / initialisations particulières aux traitements massifs
 Endif
# Déplacement de la détermincation du numéro de traitement - sinon, impossible de lancer deux actions simultanément 02/09/04
# Gosub SET_TRTNUM From TRCPROCOM                                  #=> Calcul NUMACT qq. massif interactif ou exécution batch
Return

#########################################################################
$AVANT_PAR #(Uniquement en massif interactif ou à la soumission de la requête batch)
 If !GSERVEUR                                                     # Si on est en massif interactif ou soumission requête batch :
  If dim(ACTTYPGES)<0
   Gosub SET_CONSTANTES From TRCPROCOM                            #-> Constantes 
   Gosub DEF_GLOBALES   From TRCPROCOM                            #-> Globales
   Gosub GET_PARAMETRES From TRCPROCOM                            #=> Paramètres de l'action
   Gosub PREP_ACT       From TRCPROCOM                            #=> Initialisations de variables
  Endif
 Endif
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif    #=> Déclarations / initialisations particulières aux traitements massifs
Return

#########################################################################
$OUVRE #(Unitaire et massif)
 Local Char ABR(GLONABR) # Pour la sélection étendue
 
 If dim(ACTTYPGES)<0                                              # Si on est en unitaire :
   Gosub SET_CONSTANTES From TRCPROCOM                            #-> Constantes 
   Gosub DEF_GLOBALES   From TRCPROCOM                            #-> Globales
   Gosub GET_PARAMETRES From TRCPROCOM                            #=> Paramètres de l'action 
   Gosub PREP_ACT       From TRCPROCOM                            #=> Initialisations de variables
# Déplacement de la détermincation du numéro de traitement - sinon, impossible de lancer deux actions simultanément 02/09/04
#   Gosub SET_TRTNUM From TRCPROCOM                                #=> Calcul NUMACT qq. massif interactif ou exécution batch
 Endif
 If ACTTYPGES=GTAMUNI : Gosub ACTION From TRUPROACT : Endif    #=> Déclarations / initialisations particulières aux traitements unitaires
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif    #=> Déclarations / initialisations particulières aux traitements massifs
Return

#########################################################################
$DEBUT # (Massif intéractif et unitaire)
 If ACTTYPGES=GTAMUNI : Gosub ACTION From TRUPROACT : Endif    #=> Activation / désactivation des boutons pour l'unitaire
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif    #=> Activation / désactivation des boutons pour le massif 
Return

#########################################################################
$SETBOUT # (En massif et en unitaire)
 If ACTTYPGES=GTAMUNI : Gosub ACTION From TRUPROACT : Endif    #=> Activation / désactivation des boutons pour l'unitaire
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif    #=> Activation / désactivation des boutons pour le massif
Return

#########################################################################
$APRES_MODIF # (En massif et en unitaire)
 If ACTTYPGES=GTAMUNI : Gosub ACTION From TRUPROACT : Endif    #=> Activation / désactivation des boutons pour l'unitaire
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif    #=> Activation / désactivation des boutons pour le massif
Return

#########################################################################
AP_CHOIX
 If ACTTYPGES=GTAMUNI : Gosub ACTION From TRUPROACT : Endif    #=> Activation / désactivation des boutons pour l'unitaire
Return

#########################################################################
$BOUTON # (En massif et en unitaire)
 If ACTTYPGES=GTAMUNI : Gosub ACTION From TRUPROACT : Endif    #=> Actions à réaliser sur clique bouton
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif    #=> Actions à réaliser sur clique bouton
Return

#########################################################################
$END_BOITE # (En massif interactif et en unitaire)
 If ACTTYPGES=GTAMUNI : Gosub ACTION From TRUPROACT : Endif    #=> Actions à réaliser sur bouton Fin
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif    #=> Actions à réaliser sur bouton Fin
Return

#########################################################################
$OK
 If ACTTYPGES=GTAMUNI : Gosub ACTION From TRUPROACT : Endif    #=> Actions à réaliser sur bouton OK
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif    #=> Actions à réaliser sur bouton OK
Return

#########################################################################
$ABA
 If ACTTYPGES=GTAMUNI : Gosub ACTION From TRUPROACT : Endif    #=> Actions à réaliser sur bouton Abandon
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif    #=> Actions à réaliser sur bouton Abandon
Return

#########################################################################
$EXEC # (En massif uniquement exécution requête batch et interactif)
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif  
Return

#########################################################################
$CONTROLE # (En massif uniquement exécution requête batch et interactif)
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif  
Return

#########################################################################
$FIN # (En massif et en unitaire)
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif
 If ACTTYPGES=GTAMUNI : Gosub ACTION From TRUPROACT : Endif
Return

#########################################################################
$TERMINE # (uniquement en  massif)
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif    #=> Action à réaliser sur TERMINE d'une action massive
 Gosub KILL_ELEM_REG_TVA From TRCPROCOM                        #=> Suppression des globales liées à la régul de TVA.
Return

#########################################################################
$SORTIE # (uniquement en massif)
 If ACTTYPGES=GTAMMAS : Gosub ACTION From TRMPROACT : Endif
Return

