End

#------------------------------------------------------------#
# If operation is a PUT
#------------------------------------------------------------#

$PUT
Call OPE(ASWK,PSYR,ARCV,JSON,ASND,REPRESENTATION,KEYS,ERRNUM,ERROBJ)
Return

#------------------------------------------------------------------#
Subprog OPE(ASWK,PSYR,ARCV,JSON,ASND,REPRES,KEYS,ERRNUM,ERROBJ)
Variable Instance ASWK Using C_ASYRWRK
Variable Instance PSYR Using C_ASYR
Variable Instance ARCV Using C_ASYRRCV
Variable Instance JSON       Using C_ASYRJSO
Variable Instance ASND Using C_ASYRSND
Value    Char     REPRES , KEYS
Variable Integer  ERRNUM
Variable Char     ERROBJ

Local Char    WBUTCOD(30) , WOPERATION(30) , CHAINE
Local Char    PRGREP(30) , REPNAM(10)
Local Integer I , J , K , ASTATUS
Local Char    OPE_CODPAR(30)(1..30) , OPE_VALPAR(250)(1..30) , OPE_KEYS(250)

REPNAM = "OPE"

# Parse for find button & parameters

FreeInstance [UPD]
Local Instance  UPD(1..) Using C_ADELTA

Local Instance PNODE,RESOURCES Using C_ASYRJSO
PNODE     = JSON
RESOURCES = null
While PNODE <> null
 If PNODE.PRO = "$resources"
  RESOURCES = PNODE
  Break
 Endif
 PNODE = PNODE.NEX
Wend

If RESOURCES = null
 ERRNUM = 9012 : Goto ERR_DETAIL
Endif

ASTATUS = func ASYRDEL.PARSEDELTA(GACTX,RESOURCES.SUB,UPD)

Call DECODE_PARAM(UPD,WBUTCOD,OPE_KEYS,OPE_CODPAR,OPE_VALPAR)

#--------------------------------------------------#
# Load json presentation (metadata & data)
#--------------------------------------------------#

Local Instance REP Using C_AREPENT : # Representation containing metadatas

ERRNUM = 0
PRGREP = func SUBASW.PREFIX_TRT+REPRES : # WMREP

Onerrgo ERR_LOAD_DESCRIPTION From ASYRERR
Call DESCRIPTION_REPRESENTATION(REP,REPNAM) From =PRGREP
Onerrgo
If ERRNUM
 Goto ERR_DETAIL
Endif

# Create instance class or representation

I = find(WBUTCOD,REP.LNK(1..maxtab(REP.LNK)).COD)
If I=0 or REP.LNK(I)=null or REP.LNK(I).MET=null
 ERROBJ = WBUTCOD : ERRNUM = 9027 : ASTATUS = [V]CST_AERROR : Goto ERR_DETAIL
Endif

WOPERATION = REP.LNK(I).MET.COD

Local Instance WREP Using ="C_"+REP.LNK(I).CLA
WREP = evalue("Newinstance ["+REPNAM+"] With C_"+REP.LNK(I).CLA)

# Call method

Call EXE_OPERATION(WREP,WOPERATION,OPE_KEYS,OPE_CODPAR,OPE_VALPAR) From =func APREFIXTRT.GET_PREFIX_REP+"0"+REP.REP

# Result method

ASTATUS = fmet WREP._AERROR(GACTX,2)

#Raz ASND.DATA
#Call ERROR_JSON(GACTX,PSYR,ASND.DATA) From ASYRERR

ASND.STAT     = 200
ASND.URL      = PSYR.PREFIX
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+".$diagnoses"
ASTATUS = fmet GACTX.ADELETEERROR(CST_ALLERRORS)

FreeInstance [OPE]
End

#------------------------------------------#
# Error operation
#------------------------------------------#

$ERR_DETAIL
FreeInstance [OPE]
End

#--------------------------------------------------------------------------#
# Miscellaneous programs
#--------------------------------------------------------------------------#

Subprog DECODE_PARAM(UPD,WBUTCOD,OPE_KEYS,OPE_CODPAR,OPE_VALPAR)
Variable Instance UPD(1..) Using C_ADELTA
Variable Char WBUTCOD, OPE_KEYS, OPE_CODPAR()(1..), OPE_VALPAR()(1..)
Local Integer I , J , K , P , C
Raz OPE_KEYS , C
For I=1 To maxtab(UPD)
 If UPD(I)<>null
  K = find(func ASYRSUB.CODATT("r"),UPD(I).ATT(1..maxtab(UPD(I).ATT)).COD)
  If K & UPD(I).ATT(K).ATT=func ASYRSUB.BOOLEAN_TO_SYR(2)
   WBUTCOD = UPD(I).PRO
   P = 0
   For J=1 To maxtab(UPD(I).ATT)
    If UPD(I).ATT(J)<>null
     If left$(UPD(I).ATT(J).COD,3)="key"
      If C<>0
       OPE_KEYS += "~"
      Endif
      C += 1
      OPE_KEYS += func SQUIZ_GUIL(UPD(I).ATT(J).ATT)
     Elsif left$(UPD(I).ATT(J).COD,1)<>"$"
      P += 1
      OPE_CODPAR(P) = UPD(I).ATT(J).COD
      OPE_VALPAR(P) = func SQUIZ_GUIL(UPD(I).ATT(J).ATT)
     Endif
    Endif
   Next J
   Break
  Endif
 Endif
Next I
End

#---------------------------#
Funprog SQUIZ_GUIL(CHR)
Value Char CHR
Local Char CHAINE(250)
CHAINE = CHR
If left$(CHAINE,1)='"'
 CHAINE = seg$(CHAINE,2,len(CHAINE)-1)
Endif
End CHAINE
