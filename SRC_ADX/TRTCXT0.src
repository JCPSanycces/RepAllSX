#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################################################
#   Statistiques demandes de service                               Module CRM          20 novembre 2003
#########################################################################################################
#########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

#########################################################################################################
$OUVRE
Global Char GSZSELCXT
Global Integer GICXT0CXT2SEL
Global Integer GISELNOLCXT
Global Integer GCXT0ISDIRTY

  GSZSELCXT = ""
  GCXT0ISDIRTY = 0
  GISELNOLCXT = 0
  GICXT0CXT2SEL = 0
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev([F:SST]) : Local File SRESTAT [SST] : Endif
  #Initialisation de la navigation désordonnées
  NAVIG = "FUNCXT0"
Return

#########################################################################################################
$DEFBOUT
Return

#########################################################################################################
$SETBOUT
Local Integer ISOPEN

  ISOPEN = 0
  If GCXT0ISDIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
  Call ISFUNOPEN("GESSRE", ISOPEN) From CRMUTIL140
  If ISOPEN Then
    ETABOU(GSPE1) = 0
  Else
    ETABOU(GSPE1) = 1
  Endif
Return

#########################################################################################################
$OUVRE_BOITE
Return

#########################################################################################################
$DEBUT
  [M:CXT3]TTR = mess(716,182,1)
  Gosub LOADCXT
  Gosub LOADCXTGLO
  GSZSELCXT = [M:CXT0]CXTNUM(0)
  [M:CXT3]SELSRENUM = [M:CXT0]CXTSRENUM(0)
Return

#########################################################################################################
$AV_CHOIX
Return

#########################################################################################################
AP_CHOIX
Return

#########################################################################################################
$AVANT_BOUTON
  If BOUT = "A" Then
    If [M:CXT0]NBRSRE(GISELNOLCXT) = 0 Then
      #Il y a aucune demande à afficher pour la statistique sélectionnée.
      Call MESSAGE(mess(715,182,1)) From GESECRAN
      FOK = 0
    Endif
  Endif
Return

#########################################################################################################
$FINSAI
  Raz [M:CXT0]
  Kill GISELNOLCXT
  Kill GSZSELCXT
  Kill GCXT0ISDIRTY
  Kill GICXT0CXT2SEL
Return

#########################################################################################################
$FIN
Return

#########################################################################################################
$ABANDON
Return

#########################################################################################################
$APRES_MODIF
  GCXT0ISDIRTY = 1
Return

#########################################################################################################
$BOUTON
Return

#########################################################################################################
$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################
# Traitement du bouton OK
#########################################################
#########################################################################################################
$ONOK
Local Char SZUSER
Local Integer ITER

  ITER = 0
  SZUSER = ""
  Call DEBTRANS From GLOCK
  Trbegin [SST]
  #Stats globales
  If GAUSHDKE = 2 Then
    Gosub SAVECXTGLO
  Endif
  If GERR Then
    Return
  Endif
  #Stats perso
  SZUSER = GUSER
  Gosub SAVECXT
  If GERR Then
    Return
  Endif
  Commit
  Gosub LOADCXT
  Gosub LOADCXTGLO
  GCXT0ISDIRTY = 0
  FIN = 0
Return

########################################################
# Enregistrement des statistiques globales
########################################################
#########################################################################################################
$SAVECXTGLO
  Lock [SST]
  If fstat Then
    #Les statistiques globales sont en cours d'enregistrement sur un autre poste. Enregistrement refusé.
    GMESSAGE = mess(717,182,1)
    GERR = 2
    Rollback
    Return
  Endif
  SZUSER = ""
  Gosub SAVECXT
  Unlock [SST]
Return

#############################################################
# Enregistrement des statistiques
#############################################################
#########################################################################################################
$SAVECXT
  Delete [SST] Where [F:SST]USR = SZUSER
  If fstat Then
    #Erreur lors de l'enregistrement du paramétrage des statistiques des demandes de service. Transaction abandonnée.
    GMESSAGE = mess(713,182,1)
    GERR = 1
    Rollback
  Endif
  If GERR Then
    Return
  Endif
  If SZUSER = "" Then
    For ITER = 0 To [M:CXT2]NBCXT2-1
      If [M:CXT2]BCXTNUM(ITER) <> "" Then
        Gosub SETCXT2LINE
        Write [SST]
        If fstat Then
          #Erreur lors de l'enregistrement du paramétrage des statistiques des demandes de service.
          #Transaction abandonnée.
          GMESSAGE = mess(713,182,1)
          GERR = 1
          Rollback
          Break
        Endif
      Endif
    Next
  Else
    For ITER = 0 To [M:CXT0]NBCXT-1
      If [M:CXT0]CXTNUM(ITER) <> "" Then
        Gosub SETCXTLINE
        Write [SST]
        If fstat Then
          #Erreur lors de l'enregistrement du paramétrage des statistiques des demandes de service.
          #Transaction abandonnée.
          GMESSAGE = mess(713,182,1)
          GERR = 1
          Rollback
          Break
        Endif
      Endif
    Next
  Endif
Return

#########################################################################################################
$SETCXTLINE
  Raz [F:SST]
  [F:SST]USR = SZUSER
  [F:SST]CXTNUM = [M:CXT0]CXTNUM(ITER)
  [F:SST]CXTNAM = [M:CXT0]CXTNAM(ITER)
  [F:SST]CXTFLT = [M:CXT0]CXTFLT(ITER)
  [F:SST]CXTLIG = ITER + 1
  [F:SST]CREUSR = GUSER
  [F:SST]CREDAT = CREDAT
Return

#########################################################################################################
$SETCXT2LINE
  Raz [F:SST]
  [F:SST]USR = SZUSER
  [F:SST]CXTNUM = [M:CXT2]BCXTNUM(ITER)
  [F:SST]CXTNAM = [M:CXT2]BCXTNAM(ITER)
  [F:SST]CXTFLT = [M:CXT2]BCXTFLT(ITER)
  [F:SST]CXTLIG = ITER + 1
  [F:SST]CREUSR = GUSER
  [F:SST]CREDAT = CREDAT
Return

########################################################
# Calcul un code de navigation
########################################################
#########################################################################################################
$CREANG
  IANGCOD = 0
  While 1
    If IANGCOD = 10 Then
      SZABRANG = "ZCX"
      SZANGCOD = SZABRANG + SZUSER + num$(IANGCOD)
    Endif
    If IANGCOD = 100 Then
      SZABRANG = "ZC"
      SZANGCOD = SZABRANG + SZUSER + num$(IANGCOD)
    Endif
    If IANGCOD = 1000 Then
      SZABRANG = "Z"
      SZANGCOD = SZABRANG + SZUSER + num$(IANGCOD)
    Endif
    If IANGCOD = 10000 Then
      #Erreur lors de l'enregistrement du paramétrage des statistiques des demandes de service. Transaction abandonnée.
      GMESSAGE = mess(713,182,1)
      GERR = 1
      Rollback
      Break
    Endif
    Read [ANG]ANG0=SZANGCOD
    If fstat Then
      Break
    Else
      IANGCOD += 1
    Endif
    SZANGCOD = SZABRANG + SZUSER + num$(IANGCOD)
  Wend
  If GERR Then
    Return
  Endif
  Raz [F:ANG]
  [F:ANG]COD = SZANGCOD
  If SZUSER = "" Then
    [F:ANG]FNC = "FUNCXT0B"
  Else
    [F:ANG]FNC = "FUNCXT0"
  Endif
  [F:ANG]OBJ = "SRE"
  [F:ANG]ENAFLG = 2
  [F:ANG]MODULE = 16
  [F:ANG]CREDAT = date$
  [F:ANG]CREUSR = GUSER
  Write [ANG]
  If fstat Then
    #Erreur lors de l'enregistrement du paramétrage des statistiques des demandes de service. Transaction abandonnée.
    GMESSAGE = mess(713,182,1)
    GERR = 1
    Rollback
    Return
  Endif
Return

#########################################################################################################
$CREANH
  IANHLIGNUM += 1
  IANGCOD = IANHLIGNUM 
  Raz [F:ANH]
  [F:ANH]COD = SZANGCOD
  [F:ANH]FNC = "FUNCXT0"
  [F:ANH]OBJ = "SRE"
  [F:ANH]LIG = IANGCOD
  If SZUSER = "" Then
    [F:ANH]CND = "GSZSELCXT=" + '"' + [M:CXT0]CXTNUM(ITER) + '"' 
  Else
    [F:ANH]CND = "GUSER=" + '"' + SZUSER + '"' + " & GSZSELCXT=" + '"' + [M:CXT0]CXTNUM(ITER) + '"' 
  Endif
  [F:ANH]FIL = [M:CXT0]CXTFLT(ITER)
  Write [ANH]
  If fstat Then
    #Erreur lors de l'enregistrement du paramétrage des statistiques des demandes de service. Transaction abandonnée.
    GMESSAGE = mess(713,182,1)
    GERR = 1
    Rollback
    Return
  Endif
Return

########################################################
# Chargement des statistiques
########################################################
#########################################################################################################
$LOADCXT
Local Integer ISREFLG

  ISREFLG = 0
  Raz [M:CXT0]NBCXT
  Raz [M:CXT0]NBCXTSEL
  Raz [M:CXT0]CXTNUM
  Raz [M:CXT0]CXTNAM
  Raz [M:CXT0]NBRSRE
  Raz [M:CXT0]CXTFLT
  Raz [M:CXT0]CXTLIG
  Raz [M:CXT0]CXTSRENUM
  Filter [SST] Where [F:SST]USR = GUSER Order By [F:SST]CXTLIG Asc
  For [SST]
    ISREFLG = 0
    [M:CXT0]CXTNUM([M:CXT0]NBCXT) = [F:SST]CXTNUM
    [M:CXT0]CXTNAM([M:CXT0]NBCXT) = [F:SST]CXTNAM
    [M:CXT0]CXTFLT([M:CXT0]NBCXT) = [F:SST]CXTFLT
    [M:CXT0]CXTLIG([M:CXT0]NBCXT) = [F:SST]CXTLIG
    Raz [M:CXT0]NBRSRE([M:CXT0]NBCXT)
    If [M:CXT0]CXTFLT([M:CXT0]NBCXT) <> "" Then
      Filter [SRE] Where evalue([M:CXT0]CXTFLT([M:CXT0]NBCXT))
      Columns [SRE] (SRENUM)
      For [SRE]
        If ISREFLG = 0 Then
          [M:CXT0]CXTSRENUM([M:CXT0]NBCXT) = [F:SRE]SRENUM
          ISREFLG = 1
        Endif
        [M:CXT0]NBRSRE([M:CXT0]NBCXT) += 1
      Next
      Filter [SRE]
      Columns [SRE]
    Endif
    [M:CXT0]NBCXT += 1
  Next
  Filter [SST]
  If [M:CXT0]NBCXT > 0 Then
    [M:CXT0]NBCXTSEL(0) = "->"
  Endif
  Affzo [M:CXT0]
Return

########################################################
# Chargement des statistiques
########################################################
#########################################################################################################
$LOADCXTGLO
Local Integer ISREFLG

  ISREFLG = 0
  Raz [M:CXT2]NBCXT2
  Raz [M:CXT2]BNBCXTSEL
  Raz [M:CXT2]BCXTNUM
  Raz [M:CXT2]BCXTNAM
  Raz [M:CXT2]BNBRSRE
  Raz [M:CXT2]BCXTFLT
  Raz [M:CXT2]BCXTLIG
  Filter [SST] Where [F:SST]USR = "" Order By [F:SST]CXTLIG Asc
  For [SST]
    ISREFLG = 0
    [M:CXT2]BCXTNUM([M:CXT2]NBCXT2) = [F:SST]CXTNUM
    [M:CXT2]BCXTNAM([M:CXT2]NBCXT2) = [F:SST]CXTNAM
    [M:CXT2]BCXTFLT([M:CXT2]NBCXT2) = [F:SST]CXTFLT
    [M:CXT2]BCXTLIG([M:CXT2]NBCXT2) = [F:SST]CXTLIG
    Raz [M:CXT2]BNBRSRE([M:CXT2]NBCXT2)
    If [M:CXT2]BCXTFLT([M:CXT2]NBCXT2) <> "" Then
      Filter [SRE] Where evalue([M:CXT2]BCXTFLT([M:CXT2]NBCXT2))
      Columns [SRE] (SRENUM)
      For [SRE]
        If ISREFLG = 0 Then
          [M:CXT2]BCXTSRENUM([M:CXT2]NBCXT2) = [F:SRE]SRENUM
          ISREFLG = 1
        Endif
        [M:CXT2]BNBRSRE([M:CXT2]NBCXT2) += 1
      Next
      Filter [SRE]
      Columns [SRE]
    Endif
    [M:CXT2]NBCXT2 += 1
  Next
  Filter [SST]
  If GAUSHDKE = 2 Then
    Actzo [M:CXT2]
  Else
    Grizo [M:CXT2]
  Endif
  Affzo [M:CXT2]
Return
