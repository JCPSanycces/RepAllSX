Local Char LEG

  If GCURLEG="" Then
    LEG=GLEGFIL
  Else
    LEG=GCURLEG
  Endif
End LEG

$CONTMULSEL2
Local Char    CRIT(250)
Local Integer I
Local Char    LISTLEG(GLONADI)(1..10), FLDLEG, WLEG(GLONADI)
Local Integer NBLEG, FOUNDLEG, ONLYCTR

  If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
  If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif



  If GFONCTION="GESEML" Then
    ONLYCTR=2
  Else
    ONLYCTR=1
  Endif
  Read [ATY]CODTYP = [L]CODTYP
  If fstat
    OK = 0
  Else
    # Determins LEG field in the table
    Read [F:ATB]CODFIC=[F:ATY]FICLIEN
    If !fstat Then
      Filter [F:ATZ] Where CODFIC=[F:ATB]CODFIC & CODTYP="ADI" & left$(EXPLIEN,3)='909'
      If rowcount([F:ATZ])>0 Then Read [F:ATZ] First : FLDLEG=[F:ATZ]CODZONE : Endif
      Filter [F:ATZ]
    Endif
    # Call of the function to determin the legislations
      Call LIST_LEG_EML(EMP, FLDLEG, ONLYCTR, LISTLEG, NBLEG, CRIT) From TOOLSHRLEG
      If ONLYCTR=2 & CODLEG <> "" & !find(CODLEG, LISTLEG) Then
        NBLEG +=1
        LISTLEG( NBLEG) = CODLEG
      Endif
    If !fstat Then
      FOUNDLEG=1
      Case [F:ATB]ABRFIC
        When "VRA"   :
            If NBLEG > 0
              For I=1 To NBLEG
                Read [VRA]VRA0 = LISTLEG(I);CODE
                If !fstat Then FOUNDLEG=2 : Break : Endif
              Next
            Endif
            If FOUNDLEG=1 Then
              If NBLEG
                WLEG=[L]LISTLEG(NBLEG)
              Else
                WLEG=""
              Endif
#              GMESSAGE = [L]CODE-":"-mess(14,10712,1)-"["+[L]WLEG+"]" : # Fiche inexistante pour la législation courante
              GMESSAGE = [L]CODE-":"-mess(14,10712,1) : # Fiche inexistante pour la législation courante
              mkstat = 2 : Return
            Endif
      Endcase
    Endif
  Endif
Return

##################################################
#**
#* Control the list of legislations of an employee
#*
#*
#* @param CODE    : Valor of field
#* @param EMP     : personal ID
#* @param CODTYP  : Code type of field
#* @param CODLEG  : Code current leg
#*!
Subprog CONTMULSEL(CODE,EMP,CODTYP,CODLEG)
Value    Char    CODE()
Value    Char    EMP()
Value    Char    CODTYP
Value    Char    CODLEG()
Gosub CONTMULSEL2
End
# FQ81085 - MABON 07/09/12 - US774 To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to control the field, without checking the LEG
##################################################
#**
#* Control ADI without legislations
#*
#*
#* @param VALEUR    : Valor of field
#* @param NUMTAB    : N° ADI
#* @param DEPCOD    : Code type of field
#* @param CODLEG    : Code dependance
#*!
Subprog CONTADI_SANS_LEG(VALEUR,NUMTAB,DEPCOD)
Variable Char  VALEUR()
Value    Char  NUMTAB()
Value    Char  DEPCOD()

  If val(NUMTAB)=0 : End : Endif
  If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  Read [ADV]CODE = val([L]NUMTAB)
  If fstat : End : Endif
  Read [ADI]CODE=val([L]NUMTAB);VALEUR
  If fstat : End : Endif
  If [L]DEPCOD<>"" & [F:ADV]DEPNUM<>0 & [F:ADI]DEPCOD<>"" & [F:ADI]DEPCOD<>[L]DEPCOD
    GMESSAGE = VALEUR -mess(99,133,1)- [L]DEPCOD : # ne dépend pas de
    mkstat = 2 : End
  Endif
  If [F:ADV]FLGLEG=2 & func AFNC.ACTIV("LEG")
    If [F:ADI]LEG<>"" & dim(GCURLEG2)>0 & [F:ADI]LEG<>GCURLEG2 & GCURLEG2<>"" : # & GCURLEG<>GCURLEG2
      GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:ADI]LEG : # Réservé à la législation
      mkstat = 2 : End
    Endif
  Endif
  If [F:ADV]FLGSOC=2
    If [F:ADI]SOC<>"" & GSOCIETE<>""
      If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
      Look [AGC]AGC0 = [F:ADI]SOC;GSOCIETE
      If fstat
        GMESSAGE = VALEUR-":"-mess(63,127,1)-":"-[F:ADI]SOC : # Réservé au groupe de société
        mkstat = 2 : End
      Endif
    Endif
  Endif
End

########################################
Subprog TUNHRADI(COD,NUMCHAP,LEG,SOC)
Variable Char    COD()
Value    Char    NUMCHAP
Value    Char    LEG
Value    Char    SOC
Local    Char    VCOD

  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif

  # To update the code after the tunnel order
  VCOD = COD
  Call OBJET("ADI",VCOD,NUMCHAP) From GOBJET
  COD = VCOD
End


Funprog GETLEGFCY(FCYOBJ)
Value Char FCYOBJ
Local Char LEG

  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
  If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
  Read [F:FCY]FCY0=FCYOBJ
  If !fstat Then
    Read [F:CPY]CPY0=[F:FCY]LEGCPY
    If !fstat Then
      [L]LEG=[F:CPY]LEG
    Endif
  Endif
End LEG

Funprog GETLEGCPY(CPYOBJ)
Value    Char    CPYOBJ
Local    Char    LEG(GLONADI)
Local    Integer I, K, DIFF_LEG
Local    Char    LIS_CPY(GLONCPY)(0..100), LEG(5), LEGS(5)

  If CPYOBJ="" Then End "" : Endif

  If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif

  I=0 : Call CALC_GRPCPY(CPYOBJ, LIS_CPY, I) From TOOLSVAR
  If I>0 Then : # C'est un groupe de sociétés
    [L]LEG="" : DIFF_LEG=1
    For K=0 To I-1
      Call LECTURE("CPY", LIS_CPY(K), "") From CONTOBJ
      If [L]LEG="" Then [L]LEG=[F:CPY]LEG : Endif
      If [L]LEG<>[F:CPY]LEG Then
        DIFF_LEG=2 : [L]LEG="" : Break
      Endif
    Next
  Else
    Read [F:CPY]CPY0=CPYOBJ
    If !fstat Then
      [L]LEG=[F:CPY]LEG
    Endif
  Endif
End LEG

# SEGAY 25/10/12 US 930 81085
#**
#* Return PCRITERE
#*
#* @param VALEUR  : VALEUR for criteria
#* @param VALEUR2 : VALEUR2 for criteria
#* @param CLEPRIM : CODE CLE 1
#* @param CLESEC  : CODE CLE 2
#* @param ABFIC   : CODE ABRE TABLE
#* @param FIELDLEG: CODE FIELD LEG of TABLE
#* @param PLEG    : Current LEG
#* @param PCRITERE: criteria with the different legislations, on the LEG field
#*!
Subprog CRIT_LEG_HLEG(VALEUR,VALEUR2,CLEPRIM,CLESEC,ABFIC,FIELDLEG,PLEG,PCRITERE)
Value Char VALEUR()
Value Char VALEUR2()
Value Char CLEPRIM()
Value Char CLESEC()
Value Char ABFIC()
Value Char FIELDLEG()
Value Char PLEG()
Variable Char PCRITERE()
#     CRITERE_JOT  = 'left$([F:JOT]COD,'+num$(len([L]VALEUR))+')='
#     If instr(1,[L]VALEUR,"'") & instr(1,[L]VALEUR,'"')
#      CRITERE_JOT += 'num$([L]VALEUR)'
#     Elsif instr(1,[L]VALEUR,'"')
#      CRITERE_JOT += "'"+[L]VALEUR+"'"
#     Else
#      CRITERE_JOT += '"'+[L]VALEUR+'"'
#     Endif
#     CRITERE_JOT  += ' & ([F:JOT]LEG="'+GCURLEG+'" | ([F:JOT]LEG="" & [F:JOT]LEG <> "'+GCURLEG+'"))'
  PCRITERE  = 'left$('+CLEPRIM+','+num$(len([L]VALEUR))+')='
  If instr(1,[L]VALEUR,"'") & instr(1,[L]VALEUR,'"')
   PCRITERE += 'num$([L]VALEUR)'
  Elsif instr(1,[L]VALEUR,'"')
   PCRITERE += "'"+[L]VALEUR+"'"
  Else
   PCRITERE += '"'+[L]VALEUR+'"'
  Endif
  PCRITERE  += ' & ('+FIELDLEG+'="'+PLEG+'" | ('+FIELDLEG+'="" & '+FIELDLEG+' <> "'+PLEG+'"))'

  If dim([L]VALEUR2)>0
   For I=0 To dim(CLESEC)-1
    If CLESEC(I)<>"" & dim([L]VALEUR2)>I
     If VALEUR2(I)<>""
      Case evalue("type([F:"+ABFIC+"]"+CLESEC(I)+")")
       When 1,2,4,5,6,7,8,9
        PCRITERE += '&[F:'+ABFIC+']'+CLESEC(I)+'='+[L]VALEUR2(I)
       When 3
        If [L]VALEUR2(I)="" : [L]VALEUR2(I) = "00000000" : Endif
        If instr(1,[L]VALEUR2(I),"/")
         PCRITERE += '&[F:'+ABFIC+']'+CLESEC(I)+'=['+[L]VALEUR2(I)+']'
        Else
         PCRITERE += '&[F:'+ABFIC+']'+CLESEC(I)+'='+format$(GFMD,[L]VALEUR2(I))
        Endif
       When Default
        PCRITERE += '&[F:'+ABFIC+']'+CLESEC(I)+'='
        If instr(1,[L]VALEUR2(I),"'") & instr(1,[L]VALEUR2(I),'"')
         PCRITERE += 'num$([L]VALEUR2(I))'
        Elsif instr(1,[L]VALEUR2(I),'"')
         PCRITERE += "'"+[L]VALEUR2(I)+"'"
        Else
         PCRITERE += '"'+[L]VALEUR2(I)+'"'
        Endif
      Endcase
     Endif
    Endif
   Next I
  Endif

End

# SEGAY 25/10/12 US 940 81085
#**
#* Return WLIB Intitule title field of mask
#*
#* @param WECR : Code mask
#* @param WFIELD : Code field
#*!
Funprog LIB_FIELD(WECR, WFIELD)
Value Char WECR()
Value Char WFIELD()
Local Char WLIB(50)
  If clalev([F:AMZ_])=0 : Local File AMSKZON [AMZ_] : Endif
  Read [F:AMZ_]CODE=WECR;WFIELD
  If !fstat
    WLIB=func AFNC.TEXTE([F:AMZ_]INTIT)
  Endif

End WLIB

# SEGAY 25/10/12 US 930 81085
#**
#* Return OK and Message for error LEG compare two LEG for Hierarchical update CPC
#*
#* @param ORI1 : Code field 1
#* @param LEG1 : LEG of field 1
#* @param ORI2 : Code field 2
#* @param LEG2 : LEG of field 2
#* @param TYP  : Type field : 0 CPC, 1 Dossier,2 Famille, 3 Métier, 4 Groupe compétence, 5 Emploi type, 6 Poste
#* @param OK   : return is OK or no
#* @param LMESSAGE   : return MESSAGE
#* @param DISPMSG : display message in subprog (0=NO)
#*
#*!
Subprog LEGOK_H(ORI1,LEG1,ORI2, LEG2,TYP, OK, LMESSAGE, DISPMSG)
Variable Char ORI1()
Value Char ORI2()
Value Char LEG1()
Value Char LEG2()
Value Integer TYP
Variable Integer OK
Value Integer DISPMSG
Variable Char LMESSAGE()
 OK = 1

  If (LEG1 = "" & LEG2 <> LEG1) | (LEG1<>"" & LEG2<>"" & LEG2 <> LEG1)
    If TYP =0
      LMESSAGE = mess(37,10720,1)-":"-ORI2+chr$(10)+chr$(13)+mess(62,127,1)-":"- LEG2 : # Réservé à la législation
    Else
      LMESSAGE = mess(TYP,10937,1)-":"-ORI2+chr$(10)+chr$(13)+mess(62,127,1)-":"- LEG2 : # Réservé à la législation
    Endif
    OK = 0

  Endif
  If(!OK & DISPMSG)
    #todo
  Endif

End

$SAVE_GSOCIETE

Return


Subprog LIST_LEGCPY(CPYOBJ,LISTLEG,NBLEG,NBCPY)

Value    Char    CPYOBJ

Variable Char    LISTLEG()(1..10)
Variable Integer NBLEG, NBCPY
Local    Integer J
Local    Char    CRITERE(100)
Local    Integer I, K, DIFF_LEG
Local    Char    LIS_CPY(GLONCPY)(0..100), LEG(5), LEGS(5)
  # Determins list of legislations relative to the employee

  If CPYOBJ="" Then End "" : Endif
  If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
  J=1 : Raz LISTLEG
  NBCPY=0 : Call CALC_GRPCPY(CPYOBJ, LIS_CPY, NBCPY) From TOOLSVAR
  If NBCPY>0 Then : # C'est un groupe de sociétés
    [L]LEG="" : DIFF_LEG=1
    For K=0 To NBCPY-1
      Call LECTURE("CPY", LIS_CPY(K), "") From CONTOBJ
      If !find([F:CPY]LEG, LISTLEG) Then
        LISTLEG(J) = [F:CPY]LEG
        J += 1
      Endif
    Next
    NBLEG=J-1

  Else
    Read [F:CPY]CPY0=CPYOBJ
    If !fstat Then
      LISTLEG(J) = [F:CPY]LEG
      NBLEG=1
    Endif
  Endif

End
