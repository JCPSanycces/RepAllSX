#**
#* Selection with multiple legislation (for example, in GESEML, we can have several legislations if several
#* contracts in different legislations)
#* PARAM(1) : Pesonal ID, to determin his legislations
#* PARAM(2) : Type of data. According this parameter, the Case loop is updated
#*!
$SELMULLEG
Local Char    EMP, CODTYP(10), CRIT(250), EXPROBJ(250), CODMSK, CODZON, OPT
Local Integer I
Local Char    LISTLEG(5)(1..10), FLDLEG
Local Integer NBLEG

  If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
  If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif

  [L]EMP    = PARAM(1)
  [L]CODTYP = PARAM(2)
  [L]CODMSK = PARAM(3)
  [L]CODZON = PARAM(4)

  Read [ATY]CODTYP = [L]CODTYP
  If fstat
    OK = 0
  Else
    # Determins LEG field in the table
    Read [F:ATB]CODFIC=[F:ATY]FICLIEN
    If !fstat Then
      Filter [F:ATZ] Where CODFIC=[F:ATB]CODFIC & CODTYP="ADI" & left$(EXPLIEN,3)='909'
      If rowcount([F:ATZ])>0 Then Read [F:ATZ] First : FLDLEG=[F:ATZ]CODZONE : Endif
      Filter [F:ATZ]
    Endif
    # Call of the function to determin the legislations
    If [L]EMP<>"" Then
      Call LIST_LEG_EML(EMP, FLDLEG, 1, LISTLEG, NBLEG, CRIT) From TOOLSHRLEG
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CRIT,"&") From GOBJSUB
    Endif
    If [F:ATB]ABRFIC="VRA" & ([L]CODMSK<>"" & [L]CODZON<>"") Then
      If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
      Read [F:AMZ]CODE=[L]CODMSK;[L]CODZON
      If !fstat Then
        OPT=[F:AMZ]OPTOBJ
        If clalev([F:AOB])=0 : Local File AOBJET [AOB] : Endif
        Read [F:AOB]ABREV="VRA"
        If !fstat Then
          For I=0 To [F:AOB]NBOPT-1
            If instr(1,OPT,[F:AOB]OPTCOD(I)) Then
              If EXPROBJ<>"" Then EXPROBJ += " & " : Endif
              EXPROBJ += "(" + [F:AOB]OPTCND(I) + ")"
            Endif
          Next
        Endif
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",EXPROBJ,"&") From GOBJSUB
      Endif
    Endif

    If !fstat Then
      # Determins the columns and the table to display
      Call TRANSCOL([F:ATY]OBJLIEN,NBCOL,COL,TIT(0..dim(TIT)-1),FMTCOL) From OBJDIV
      Case [F:ATB]ABRFIC
        When "VRA"   : TIT(0)=mess(10,16,1)-mess(185,10703,1) : Default File [VRA]   : ORDRE = "[F:VRA]COD"
      Endcase
    Endif
  Endif
Return

