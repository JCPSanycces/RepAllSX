######################################################################################
# SEGAY 25/10/12 US 930 81085
#**
#* Test LEG CPC with LEGREF
#* @param  VALEUR  : Code CPC
#* @param  LEGREF :  LEG
#* @param  WITHOUTLEG  : Test LEG BLANK
#*!
Funprog CHECKLEG_CPC(VALEUR,LEGREF,WITHOUTLEG)
Value Char VALEUR
Value Char LEGREF
Value Integer WITHOUTLEG
Local Integer POK
POK=0
If clalev([F:TCPC])=0    : Local File COMPETENCE  [TCPC]    : Endif
Read [TCPC]CPC0=VALEUR
If !mkstat
  If WITHOUTLEG
    If([TCPC]LEG="" or [TCPC]LEG=LEGREF  )
      POK=1
    Endif
  Else
    If ([TCPC]LEG=LEGREF or (LEGREF <> "" and  [TCPC]LEG =""))
       POK=1
    Endif
  Endif
Endif
End POK



