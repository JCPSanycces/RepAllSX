$SETSELCPYLEGFCY

  If clalev ([F:CPY])=0 : Local File COMPANY [CPY] : Endif

  If PARAM(2)<>"" and PARAM(3)=""
    Local Char CPYCOD(5) : CPYCOD = ""

    If clalev ([F:FCY])=0 : Local File FACILITY [FCY] : Endif
    Filter [F:FCY] Where FCY = PARAM(2)
    Read [F:FCY] First

    If fstat = 0
      CPYCOD = [F:FCY]LEGCPY

      Close File [F:FCY]

      Filter [F:CPY] Where CPY = CPYCOD
      OBJET = "CPY"

      If PARAM(1)<>""
        CRITERE = 'LEG="'+PARAM(1)+'" | LEG=""'
      Else
        CRITERE = 'LEG=""'
      Endif
    Else
      Filter [F:CPY]
      OBJET = "CPY"

      If PARAM(1)<>""
        CRITERE = 'LEG="'+PARAM(1)+'" | LEG=""'
      Else
          CRITERE = 'LEG=""'
      Endif
    Endif
  Else
    Filter [F:CPY]
    OBJET = "CPY"

    If PARAM(1)<>""
      CRITERE = 'LEG="'+PARAM(1)+'" | LEG=""'
    Else
        CRITERE = 'LEG=""'
    Endif
  Endif

Return
