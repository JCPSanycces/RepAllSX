$SELADILEGH
  CRITERE(1) = PARAM(1)
  OPTIONS    = PARAM(2)

  If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
  If clalev([F:AX2])=0 : Local File ATEXTRA [AX2] : Endif

  Local Char NUMTAB(10), NOMLEG(10) , NUMDEP(GLONADI), ALLLEG(1), TOUS(1)  #MABOS-27/06/13

  If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif
  [L]NUMTAB = PARAM(1) : # table diverse
  [L]NOMLEG = PARAM(2)

  If [L]NUMTAB = "" : OK = 0 : Return : Endif

  Read [ADV]CODE = val([L]NUMTAB)
  If fstat
    OK = 0
  Else
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'NUMTAB = '+[L]NUMTAB,"&") From GOBJSUB

    If dim([F:ADV]FLGLEG) > -1 and [F:ADV]FLGLEG = 2
#      If [L]NOMLEG = ""
#        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'LEG = ""',"&") From GOBJSUB
#      Else
#        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'(LEG = "" | LEG = "'+[L]NOMLEG+'")',"&") From GOBJSUB
#      Endif
      # MABOS -07/05/2013 code review during US 1540 - epurer code/Superviseur
      Case TABLE
       When "SELADILEGH", "SELADIDEPB": #MABOS-27/06/13-FQ90539-US1737
          If [L]NOMLEG <> ""
            Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'(LEG = "" | LEG = "'+[L]NOMLEG+'")',"&") From GOBJSUB
           #LIPET - 2017-09-27 - X3-29311 - START
#          Else
#            #MABOS-22/02/13 - FQ81085  -US1332 - Add Legislation in GESCEV
#            #if Campain without leg, only ADI without LEG (for Interview type)
#            If find(maskcou,"CEV0","CPC0")>0 Then : #MABOS-11/04/13-FQ86658-US1529
#              Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'LEG = ""' ,"&") From GOBJSUB
#            Endif
            #LIPET - 2017-09-27 - X3-29311 - END
          Endif

          #MABOS-27/06/13-FQ90539-US1737
          If TABLE="SELADIDEPB"
            [L]ALLLEG =PARAM(3)
            If [L]NOMLEG = "" & [L]ALLLEG  ="1" :# LEG vide ET Pas Toutes Legs
              Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'LEG = "'+[L]NOMLEG+'"' ,"&") From GOBJSUB
            Endif
          Endif
          #end MABOS-27/06/13-FQ90539-US1737

       When "SELADILEGC"
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'((LEG = "" & LEG <> "'+[L]NOMLEG+'")  | LEG = "'+[L]NOMLEG+'")',"&") From GOBJSUB
       When "SELADILH"
          Local Char    CRITERE_ADI(250) # SEGAY 25/10/12 US 930 81085
          Call CRIT_LEG_HLEG ([L]VALEUR,[L]NUMTAB,"[F:ADI]CODE","NUMTAB","ADI","[F:ADI]LEG",[L]NOMLEG,CRITERE_ADI) From TOOLSHRLEG
         #Filter based on code legislation
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CRITERE_ADI,"&") From GOBJSUB
       Endcase

    Endif
    #MABOS-27/06/13-FQ90539-US1737
    If TABLE="SELADIDEPB"
      [L]NUMDEP=PARAM(4)
      [L]TOUS = PARAM(5)
      If [F:ADV]DEPNUM<>0 & ([L]NUMDEP <>"" | [L]TOUS ="1") Then  :# une dépendance précise ou une dependance vide ( tous=1 <=> pas "toutes les dépendances")
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","DEPCOD = '"+[L]NUMDEP+"'","&") From GOBJSUB
      Endif
    Endif
    #MABOS-27/06/13-FQ90539-US1737
    Link [ADI] With
&   [AXX]AXX0="ATABDIV";"LNGDES";GLANGUE;[F:ADI]NUMTAB;[F:ADI]CODE
&   As [LNK]

    Read [F:AX2]AXX0="ATABTAB";"LNGDES";GLANGUE;num$([L]NUMTAB)
    If !fstat Then
      TIT(0)=[F:AX2]TEXTE
    Endif
    Call  TRANSCOL("ADI",NBCOL,COL,TIT(0..dim(TIT)-1),FMTCOL) From OBJDIV
    # Ajout de la colonne Legislation
    If dim([F:ADV]FLGLEG) > -1 and [F:ADV]FLGLEG = 2
      NBCOL += 1 : COL(NBCOL) = "[F:ADI]LEG" : COLTYP(NBCOL) =  type([F:ADI]LEG) : TIT(NBCOL) = mess(238,133,1)
    Endif
    Default File [LNK]
    ORDRE = "[F:ADI]CODE"
  Endif
Return


