#**
#* Returns the list of legislations of an employee and contract or only contract
#*
#* @param EMP     : personal ID
#* @param FLDLEG  : name of the LEG field in the table where the selection must be done
#* @param ONLYCTR : test only selection of view of contract
#* @param LISTLEG : list of legislations of the employee and contract or only contract
#* @param NBLEG   : number of legislations of the employee and contract or only contract
#* @param CRIT    : criteria with the different legislations, on the LEG field
#*!
Subprog LIST_LEG_EML(EMP,FLDLEG,ONLYCTR,LISTLEG,NBLEG,CRIT)
Value    Char    EMP, FLDLEG
Value    Integer ONLYCTR
Variable Char    LISTLEG()(1..), CRIT()
Variable Integer NBLEG
Local    Integer J
Local    Char    CRITERE(100)

  # Determins list of legislations relative to the employee
  J=1 : Raz LISTLEG
  If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
  #ADNGO - 2018-01-17 - X3-67582 - START
  #CRITERE="REFNUM=EMP"
  CRITERE='REFNUM="'+EMP+'"'
  #ADNGO - 2018-01-17 - X3-67582 - END
  If ONLYCTR=2 Then
    #ADNGO - 2018-01-17 - X3-67582 - START
    #CRITERE -= "& CTRNUM<>''"
    CRITERE -= '& CTRNUM<>""'
    #ADNGO - 2018-01-17 - X3-67582 - END
  Endif
  For [F:ILEG] Where evalue(CRITERE)
    If !find([F:ILEG]LEGID, LISTLEG) Then
      LISTLEG(J) = [F:ILEG]LEGID
      J += 1
    Endif
  Next
  NBLEG=J-1
  # Determins criteria
  If FLDLEG<>"" Then
    For J=1 To dim(LISTLEG)
      If LISTLEG(J)<>"" Then
        If CRIT<>"" Then CRIT+=',' : Endif
        CRIT += '"'+LISTLEG(J)+'"'
      Endif
    Next
    CRIT = '(find('+FLDLEG+',"",'+CRIT+')>0)'
  Endif
End


$SAVE_GLEGFIL
 If(dim(GLEGFIL)>0 and dim(GCURLEG)>0)
    If(dim(SAV_GLEGFIL)<0)
      #if exist => pb before...
      Global Char SAV_GLEGFIL
      SAV_GLEGFIL=GLEGFIL
    Endif
  Endif
Return

$RESTAURE_GLEGFIL
  If(dim(SAV_GLEGFIL)>0)
    GLEGFIL=SAV_GLEGFIL
    Kill SAV_GLEGFIL
  Endif
Return

$SAVE_GCURLEG
 If(dim(GLEGFIL)>0 and dim(GCURLEG)>0)
