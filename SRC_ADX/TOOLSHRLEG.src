#<AdxTL>@(#)0.0.0.0 $Revision$ $Revision$
#*
#* Treatment of tools about legislation, for HR
#   MABOS-22/02/13 - FQ81085  -US1332 - Add Legislation in GESCEV
#   MABOS-11/04/13 - FQ86658 - US1529 - When a skill has no legislation, Nature & Scale must be blank only.
#*  MABOS-27/06/13 - FQ90539 - US1737 - manage new action SELADIDEPB for Referential standard job, position
#   MABOS-31/07/13 - Bug 91545 - Contract selection in GESCTR after modify REFNUM
$ACTION

  Case ACTION
    When "SEL_TABLE"  : Gosub SEL_TABLE
    When "FIN_TABLE"  : Gosub FIN_TABLE

    When "SEL_LISTE"  : Gosub SEL_LISTE
    When "FIN_LISTE"  : Gosub FIN_LISTE
    When Default
  Endcase

Return

$SEL_TABLE
#sba
  Gosub SAVE_GLEGFIL
# Global Char SAV_GLEGFIL
# SAV_GLEGFIL=GLEGFIL
  #sba end
  Gosub SAVE_GCURLEG
  If !find(GACTION,"SELADILEGH","SELADILEGC","SELMULLEG","SELADIDEPB") Then
    Raz ICRITERE, CRITERE
    #MABOS-05/12/2012-FQ 81085-US1046
    If maskcou="INSPRO" and TABLE="SELSTGLEG"  Then
      If PARAM(1)<>"" Then
        Call ADDCRIT(CRITERE,ICRITERE,""," find([F:STG]LEG,'','"+PARAM(1)+"')>0","&") From GOBJSUB
      Endif
    Endif
    #SEGAY-10/12/2012 US 1045 81085
    If maskcou="TCS1" and TABLE="SELSTGLEG"  Then
        #Call ADDCRIT(CRITERE,ICRITERE,""," find([F:STG]LEG,'','"+PARAM(1)+"')>0","&") From GOBJSUB
        If PARAM(1) <> ""
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:STG]LEG="'+PARAM(1)+'"|[F:STG]LEG="")',"&") From GOBJSUB
        Endif
    Endif
    If TABLE="SELSTGLEGH" # SEGAY 10/12/2012 US 1045 81085
        Local Char    CRITERE_STG(250) # SEGAY 10/12/2012 US 1045 81085
        Call CRIT_LEG_HLEG ([L]VALEUR,"","[F:STG]COD","","STG","[F:STG]LEG",PARAM(1),CRITERE_STG) From TOOLSHRLEG
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CRITERE_STG,"&") From GOBJSUB
    Endif
    If GFONCTION="GESHRSES" and TABLE="SELSTGLEG2"  Then
      If GREP="C" and LEG="" Then
        Call ADDCRIT(CRITERE,ICRITERE,"","LEG='"+PARAM(1)+"'","|") From GOBJSUB
        Call ADDCRIT(CRITERE,ICRITERE,"","LEG='"+GLEGFIL+"'","|") From GOBJSUB
        Call ADDCRIT(CRITERE,ICRITERE,"","'"+GLEGFIL+"'=''","|") From GOBJSUB
#       Call ADDCRIT(CRITERE,ICRITERE,"","GLEGFIL=''","|") From GOBJSUB :#MABOS à tester à la place de ligne précedente

      Endif
#      MABOS-13/11/12
    Elsif TABLE="SELTCSLEG"
#    Elsif !find(GACTION,"SELTCSLEG","SELCSILEG") Then
#      If GLEGFIL<>"" Then
      If PARAM(1)<>"" Then
        #Call ADDCRIT(CRITERE,ICRITERE,""," find([F:CPY]LEG,'','"+PARAM(1)+"')>0","&") From GOBJSUB
        Call ADDCRIT(CRITERE,ICRITERE,""," find([F:TCS]LEG,'','"+PARAM(1)+"')>0","&") From GOBJSUB
      Endif
#* SEGAY 26/06/12 81085 US500
# :#MABOS-13/11/12
#      If GSOCIETE<>"" Then
      If PARAM(2)<>"" Then
        Call ADDCRIT(CRITERE,ICRITERE,""," find([F:CPY]CPY,'','"+PARAM(2)+"')>0","&") From GOBJSUB
      Endif
      # MABOS
     Elsif  TABLE="SELCSILEG"

      If PARAM(1)<>"" Then
        Call ADDCRIT(CRITERE,ICRITERE,""," find([F:FCY]LEG,'','"+PARAM(1)+"')>0","&") From GOBJSUB
      Endif
      If PARAM(2)<>"" Then
        Call ADDCRIT(CRITERE,ICRITERE,""," find([F:FCY]LEGCPY,'','"+PARAM(2)+"')>0","&") From GOBJSUB
      Endif

    #MABOS-05/12/2012-FQ 81085-US1046
    Elsif TABLE="SELDEMLEG"
      If PARAM(1)<>"" Then
        Call ADDCRIT(CRITERE,ICRITERE,""," find([F:FCY]LEG,'','"+PARAM(1)+"')>0","&") From GOBJSUB
      Endif
    #end MABOS

    Elsif !find(TABLE,"SELCTRLEG","SELSESLEG")
      Local Char DEFFILE(30) : DEFFILE=""

      If PARAM(1)<>"" Then
        Call ADDCRIT(CRITERE,ICRITERE,"","find("+DEFFILE+"LEG,'','"+PARAM(1)+"')>0","&") From GOBJSUB
      Endif
      If TABLE='SELCPYLEGH' Then
        If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
        Read [F:AMZ]CODE=maskcou;zoncou
        If !fstat Then
          If find("A",[F:AMZ]OPTOBJ)>0 Then
            # société juridique
            Call ADDCRIT(CRITERE,ICRITERE,"","CPYLEGFLG=2","&") From GOBJSUB
          Endif
        Endif
      Endif
    Elsif find(TABLE,"SELCTRLEG")
      # Ouverture des tables nécessaires
      If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
      If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
      If clalev([F:ID])=0  : Local File EMPLOID  [ID]  : Endif
    Endif
    GLEGFIL=GCURLEG
  Endif
  DEFPAG=1
  Case TABLE
    When "SELADIDEPB" : Gosub SELADILEGH  #MABOS-27/06/13-FQ90539-US1737
    When "SELADILEGH" : Gosub SELADILEGH
    When "SELADILEGC" : Gosub SELADILEGH  :# SEGAY 25/10/12 US 930 81085-#SELADILEGC # MABOS -07/05/2013 code review during US 1540 - epurer code
    When "SELADILH"   : Gosub SELADILEGH  :# SEGAY 25/10/12 US 930 81085-#SELADILEGC # MABOS -07/05/2013 code review during US 1540 - epurer code
    When "SELMULLEG"  : Gosub SELMULLEG
    When "SELCPYLEGH" : OBJET="CPY"
    When "SELSTGLEG"  : OBJET="STG"
    When "SELSTGLEGH" : OBJET="STG" #SEGAY-10/12/2012 US 1045 81085
    When "SELCPCLEG"  : Gosub SELCPCLEG #DKA
    When "SELCPCLEGH" : Gosub SELCPCLEG #DKA
    When "SELCPYLEGF" : Gosub SETSELCPYLEGFCY #PHVEN - 2018-02-02 - X3-74701

    When "SELSTGLEG2" : Gosub SELSTGLEG
    #JOJAC
    When "SELSRVLEG" : Gosub SETSELSRVLEG
    #When "SELSRVLEG"  : OBJET="SRV"
    #JOJAC
    When "SELFCYLE2"  : OBJET="FCY"
    When "SELORFLEG"  : OBJET="ORF"
    When "SELOFILEG"  : OBJET="OFI"
    When "SELTCSLEG"  : OBJET="TCS"
    When "SELSCALEG"  : Gosub SELSCALEG  : # OBJET="HRSCA" : #MABOS-11/04/13-FQ86658-US1529
    When "SELMISLEG"  : Gosub SELMISLEG
    When "SELSESLEG"  : Gosub SELSESLEG
    When "SELCTRLEG"  : Gosub SELCTRLEG
    When "SELORGLEG"  : Gosub SELORGLEG
    When "SELPRFLEG"  : Gosub SETSELPRFLEG
    When "SELPOTLEG"  : Gosub SETSELPOTLEG
    When "SELCSILEG"  : OBJET="CSI" : # mabos-13/11/12
    When "SELDEMLEG"  : OBJET="DEM" : #MABOS-05/12/2012-FQ 81085-US1046
  Endcase

Return

$FIN_TABLE
  If(dim(GW_STRTMP)>0)
    Kill GW_STRTMP
  Endif
  Gosub RESTAURE_GLEGFIL
  Gosub RESTAURE_GCURLEG

  If find(TABLE,"SELCTRLEG") & PARAM(5)<>"" Then
    If maskcou="HRSES5" & zoncou="REFNUMD" Then
      VALEUR=[F:HRCTR]REFNUM
      [M]REFNUMD(nolign-1)=[F:HRCTR]REFNUM
      [M]CTRNUMD(nolign-1)=[F:HRCTR]CTRNUM
    Elsif dim([M]REFNUM)>1 Then
      VALEUR=[F:HRCTR]REFNUM
      [M]REFNUM(nolign-1)=[F:HRCTR]REFNUM
      [M]CTRNUM(nolign-1)=[F:HRCTR]CTRNUM
    Else
      [M]REFNUM=[F:HRCTR]REFNUM
      [M]CTRNUM=[F:HRCTR]CTRNUM
    Endif
  Endif
  If find(TABLE,"SELCTRLEG") & dim([M]CTRDAT)>1 Then
    [M]CTRDAT(nolign-1)=[F:HRCTR]CTRDAT
  Endif
Return

############################################################
# sélection contrat
#############################################################
$SELCTRLEG
Local Char CRITERE(250)
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  If GFONCTION="GESPOP" Then
    Link [HRCTR] With
&     [ID]ID0=[F:HRCTR]REFNUM,
&     [FCY]FCY0=[F:HRCTR]ETRFCY,
&     [CPY]CPY0=[F:FCY]LEGCPY
&     As [HRCTR_]
  Endif

  OBJET="CTR"
  CRITERE=""
  #JOJAC - 2016-05-11 - REQ114309 US98 - START
  #If(PARAM(1)<>"")
  If(PARAM(1)<>"") & (PARAM(12)="")
    CRITERE='REFNUM="'+PARAM(1)+'"'
  Endif

  If (PARAM(1)<>"") & (PARAM(12)<>"")
  CRITERE='(REFNUM>="'+PARAM(1)+'"'+'&'+'REFNUM<="'+PARAM(12)+'")'
  Endif
  #JOJAC - 2016-05-11 - REQ114309 US98 - END
  If(PARAM(2)<>"")
    If CRITERE<>"" : CRITERE-="&" : Endif

#MIPEA - 2016-01-06- X3-12089- START
    If GFONCTION = "GESDCG"
      CRITERE-=PARAM(2)-" | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=[M:DCG1]ENDDAT(nolign-1)))"
    #FRLAA - 2018-10-08- X3-91927- START
    Elsif GFONCTION = "ESSDCG"
      CRITERE-=PARAM(2)-" | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=[M:ESDCG1]ENDDAT))"
    #FRLAA - 2018-10-08- X3-91927- END
    Else
      CRITERE-=PARAM(2)
    Endif
#    CRITERE-=PARAM(2)
#MIPEA - 2016-01-06- X3-12089- END
  Else
    If CRITERE<>"" : CRITERE-="&" : Endif
#MIPEA - 2016-01-06- X3-12089- START
#FRLAA - 2018-10-08- X3-91927- START
    #If GFONCTION = "GESDCG"
    If GFONCTION = "GESDCG" | GFONCTION = "ESSDCG"
#FRLAA - 2018-10-08- X3-91927- END
      CRITERE-="([F:HRCTR]CTRDAT<=date$ | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=date$)) & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)"
    Else
      CRITERE-="[F:HRCTR]CTRDAT<=date$ & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)"
    Endif

#    CRITERE-="[F:HRCTR]CTRDAT<=date$ & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)"
#MIPEA - 2016-01-06- X3-12089- END
  Endif

  If(PARAM(3)<>"")
    If CRITERE<>"" : CRITERE-="&" : Endif
    CRITERE-=PARAM(3)
  Endif

  If(PARAM(4)<>"")
    Call ADDCRIT(CRITERE,ICRITERE,""," find([F:FCY]LEG,'','"+PARAM(4)+"')>0","&") From GOBJSUB
  Endif
  If PARAM(5)<>"" Then
    ORDRE="[F:HRCTR]REFNUM"
  Endif
  If(PARAM(6)<>"")
    Call ADDCRIT(CRITERE,ICRITERE,""," [F:CPY]CPY='"+PARAM(6)+"'","&") From GOBJSUB
  Endif
  If(PARAM(7)<>"")
    Call ADDCRIT(CRITERE,ICRITERE,""," [F:FCY]FCY='"+PARAM(7)+"'","&") From GOBJSUB
  Endif
  If(PARAM(8)<>"")
    Call ADDCRIT(CRITERE,ICRITERE,""," [F:HRCTR]ETRSRV='"+PARAM(8)+"'","&") From GOBJSUB
  Endif
  If(PARAM(9)<>"")
    Call ADDCRIT(CRITERE,ICRITERE,""," [F:HRCTR]PROPRF='"+PARAM(9)+"'","&") From GOBJSUB
  Endif
  If(PARAM(10)<>"")
    Call ADDCRIT(CRITERE,ICRITERE,""," [F:HRCTR]POT='"+PARAM(10)+"'","&") From GOBJSUB
  Endif
  If(PARAM(11)<>"")
    Call ADDCRIT(CRITERE,ICRITERE,""," [F:HRCTR]JOBPOT='"+PARAM(11)+"'","&") From GOBJSUB
  Endif

  [L]START="[F:HRCTR]CTRNUM"
  Filter [F:HRCTR]
Return

$SEL_LISTE

  Case LISTE
    When "SELEMLLEG" : Gosub SELEMLLEG
    When "SELCHFLEG" : Gosub SELCHFLEG
    When "SELEMLCTR" : Gosub SELEMLCTR
  Endcase
Return

$FIN_LISTE
Local Char    DATEC(10)
Local Integer JOUR, MOIS, ANNEE

  Case LISTE
    When "SELEMLCTR" :
        Gosub RESTAURE_GLEGFIL
        Gosub RESTAURE_GCURLEG

        If CHOIX>0 Then
          If maskcou="HRSES5" & zoncou="REFNUMD" Then
            VALEUR=TEX(CHOIX)
            [M]REFNUMD(nolign-1)=TEX(CHOIX)
            [M]CTRNUMD(nolign-1)=TEXTE(CHOIX,2)
          Elsif dim([M]REFNUM)>1 Then
            VALEUR=TEX(CHOIX)
            [M]REFNUM(nolign-1)=TEX(CHOIX)
            [M]CTRNUM(nolign-1)=TEXTE(CHOIX,2)
          Else
            [M]REFNUM=TEX(CHOIX)
            [M]CTRNUM=TEXTE(CHOIX,2)
          Endif
          If dim([M]CTRDAT)>1 Then
            DATEC=TEXTE(CHOIX,3)
            JOUR  = val(left$(DATEC,2))
            MOIS  = val(mid$(DATEC,4,2))
            ANNEE = val(right$(DATEC,7))
            [M]CTRDAT(nolign-1)=gdat$(JOUR,MOIS,ANNEE)
          Endif
        Endif
  Endcase
Return

############################################################
# sélection salariés
#############################################################
$SELEMLLEG
Local Char    CRITERE(250)
Local Char    CRIT1(250) :   #US1840 81085 24/09/2013 Add criteria SOC
Local Char    SOC([V]GLONCPY) :   #US1840 81085 24/09/2013 Add criteria SOC
Local Char    TEX(80)(1..), TEXTE(80)(1..,1..7)
Local Integer OKENR

  TIT(0)=mess(46,10702,1)                 : # Sélection salarié
  Call TEXTE(10793,TIT(1)) From OBJDIV    : # Matricule
  Call TEXTE(55,TIT(2)) From OBJDIV       : # Nom
  Call TEXTE(1825,TIT(3)) From OBJDIV     : # Prénom
  Call TEXTE(1343,TIT(4)) From OBJDIV     : # Société
  Call TEXTE(1344,TIT(5)) From OBJDIV     : # Site
  EXPSTART="REFNUM<>''" : START="REFNUM"
  NBCOL=5

  If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
# FQ81085 US525 - SEGAY 05/07/12 for REFNUM with LEG <> Contracts LEG
  If clalev([F:CPY])=0  : Local File COMPANY  [CPY]   : Endif
  If PARAM(2)="POT" Then
    If clalev([F:EPO])=0  : Local File EMPLOPOT    [EPO] : Endif
    If clalev([F:POT])=0  : Local File POSTE       [POT] : Endif
  Endif

  If PARAM(1)<>"" & PARAM(2)<>"CTR" Then
    CRITERE="LEGID=PARAM(1)"
  Else
    CRITERE="1=1"
  Endif
  CRITERE -= "& REFNUM>='"+VALEUR+"'"

  If PARAM(2)="CTR"
    CRITERE -= "& CTRNUM<>''"
  Endif

  #US1840 81085 24/09/2013 Add criteria SOC
  CRIT1="1=1"
  SOC = PARAM(3)
  If SOC<>""
    Local Integer I, K
    Local Char    LIS_CPY(GLONCPY)(0..100)
    I=0 : Call CALC_GRPCPY(SOC, LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      CRIT1 -= "& find([F:ILEG]LEGCPY,"
      For K=0 To I-1
        CRIT1 += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRIT1 += "," : Endif
      Next
      CRIT1 += ")>0"
    Endif
  Endif

  For [F:ILEG] Where evalue(CRITERE) & evalue(CRIT1)
# FQ81085 US525 - SEGAY 05/07/12 for REFNUM with LEG <> Contracts LEG
#    If [F:ILEG]CTRDAT<=date$ & ([F:ILEG]XITDAT=[0/0/0] | [F:ILEG]XITDAT>=date$) Then
#    If [F:ILEG]CTRNUM = "" | ([F:ILEG]CTRDAT<=date$ & ([F:ILEG]XITDAT=[0/0/0] | [F:ILEG]XITDAT>=date$)) Then
    OKENR=2
    # In this case, we want to filter the employees whose a position is defined
    If PARAM(2)="POT" Then
      Filter [EPO] Where REFNUM=[F:ILEG]REFNUM
      Read [EPO]EPO1 Last
      Filter [EPO]
      If !fstat
        Read[POT]POT0=[F:EPO]POT
        If fstat Then OKENR=1 : Endif
      Else
        OKENR=1
      Endif
    Endif
    # In this case,we want to filter the employees whose only data's employee are in the good legislation (not the contract)
    If PARAM(2)="EML" Then
      If [F:ILEG]CTRDAT<>[31/12/2040] Then OKENR=1 : Endif
    Endif

    # In this case,we want to filter the employees whose only contracts are in the good legislation (not the main site)
    If PARAM(2)="CTR" Then
      If [F:ILEG]CTRDAT=[31/12/2040] | (PARAM(1)<>"" & [F:ILEG]LEGID<>PARAM(1))
        OKENR=1
      Endif
    Endif
    If OKENR=2 & ([F:ILEG]CTRDAT=[31/12/2040] | ([F:ILEG]CTRDAT<=date$ & ([F:ILEG]XITDAT=[0/0/0] | [F:ILEG]XITDAT>=date$))) Then

      If !find([F:ILEG]REFNUM, TEX) Then
        NBTEX += 1
        TEX(NBTEX)     = [F:ILEG]REFNUM
        TEXTE(NBTEX,1) = [F:ILEG]REFNUM
        TEXTE(NBTEX,2) = [F:ILEG]NAM
        TEXTE(NBTEX,3) = [F:ILEG]SRN
        TEXTE(NBTEX,4) = [F:ILEG]LEGCPY
        TEXTE(NBTEX,5) = [F:ILEG]FCYID
# FQ81085 US525 - SEGAY 05/07/12 for REFNUM with LEG <> Contracts LEG
        If [F:ILEG]FCYID <> [F:ILEG]FCYORI & (PARAM(1)="" | [F:ILEG]LEGORI=PARAM(1))
           TEXTE(NBTEX,4) = [F:ILEG]LEGCPYORI
           TEXTE(NBTEX,5) = [F:ILEG]FCYORI
        Endif
      Endif
    Endif
  Next
Return

############################################################
# sélection responsables
# We have to select the employees which one of his legislations (that of his main site or his contracts) is in
# the legislations of the current employee
#############################################################
$SELCHFLEG
Local Char    CRITERE
Local Char    TEX(80)(1..), TEXTE(80)(1..,1..7)
Local Char    LISTLEG(5)(1..10), CRIT(250)
Local Integer NBLEG

  TIT(0)=mess(46,10702,1)                 : # Sélection salarié
  Call TEXTE(10793,TIT(1)) From OBJDIV    : # Matricule
  Call TEXTE(55,TIT(2)) From OBJDIV       : # Nom
  Call TEXTE(1825,TIT(3)) From OBJDIV     : # Prénom
  Call TEXTE(1343,TIT(4)) From OBJDIV     : # Société
  Call TEXTE(1344,TIT(5)) From OBJDIV     : # Site
  EXPSTART="REFNUM<>''" : START="REFNUM"
  NBCOL=5

  Call LIST_LEG_EML(PARAM(1), "", 2, LISTLEG, NBLEG, CRIT) From TOOLSHRLEG
  # We might be modifying the legislation of the employee. So in LISTLEG, we don't want to have the legislation
  # of the employee as it is recorded in EMPLOID, but rather GCURLEG
  If GCURLEG<>"" and !find(GCURLEG, LISTLEG) Then
    NBLEG += 1
    LISTLEG(NBLEG)=GCURLEG
  Endif

  If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
  CRIT="find([F:ILEG]LEGID,LISTLEG)>0 & [F:ILEG]ENAFLG=2 & [F:ILEG]FLGNEWSAL<>2"
  For [F:ILEG] Where evalue(CRIT)
    If [F:ILEG]CTRDAT=[31/12/2040] | ([F:ILEG]CTRDAT<=date$ & ([F:ILEG]XITDAT=[0/0/0] | [F:ILEG]XITDAT>=date$)) Then
      If !find([F:ILEG]REFNUM, TEX) Then
        NBTEX += 1
        TEX(NBTEX)     = [F:ILEG]REFNUM
        TEXTE(NBTEX,1) = [F:ILEG]REFNUM
        TEXTE(NBTEX,2) = [F:ILEG]NAM
        TEXTE(NBTEX,3) = [F:ILEG]SRN
        TEXTE(NBTEX,4) = [F:ILEG]LEGCPY
        TEXTE(NBTEX,5) = [F:ILEG]FCYID
      Endif
    Endif
  Next
Return

############################################################
# sélection salariés / contrats
#############################################################
$SELEMLCTR
Local Char    CRITERE(250)
Local Char    TEX(80)(1..), TEXTE(100)(1..,1..7), LISTKEY(80)(1..)
Local Date    DATREF

  Gosub SAVE_GLEGFIL
  Gosub SAVE_GCURLEG

  TIT(0)=mess(46,10702,1)                 : # Sélection salarié
  Call TEXTE(44921,TIT(1)) From OBJDIV    : # Salarié
  Call TEXTE(5481,TIT(2)) From OBJDIV     : # Contrat
  Call TEXTE(212,TIT(3)) From OBJDIV      : # Date
  Call TEXTE(7830,TIT(4)) From OBJDIV     : # Date sortie
  Call TEXTE(26213,TIT(5)) From OBJDIV    : # Législation
  EXPSTART="REFNUM<>''" : START="REFNUM"
  NBCOL=5

  If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
  If clalev([F:CPY])=0  : Local File COMPANY  [CPY]   : Endif

  If PARAM(1)<>"" Then
    CRITERE="LEGID=PARAM(1)"
    GLEGFIL=PARAM(1)
  Else
    CRITERE="1=1"
  Endif
  CRITERE -= "& REFNUM>='"+VALEUR+"'"
  CRITERE -= "& [F:ILEG]CTRDAT<>[31/12/2040]"
  If PARAM(2)<>"" Then
    CRITERE -= "& " + PARAM(2)
  Endif
  If PARAM(3)<>[0/0/0] Then
    DATREF = PARAM(3)
  Else
    DATREF = date$
  Endif

  For [F:ILEG] Where evalue(CRITERE)
    If [F:ILEG]CTRDAT<=DATREF & ([F:ILEG]XITDAT=[0/0/0] | [F:ILEG]XITDAT>=DATREF) Then
      If !find([F:ILEG]REFNUM+"~"+[F:ILEG]CTRNUM, LISTKEY) Then
        NBTEX += 1
        LISTKEY(NBTEX) = [F:ILEG]REFNUM+"~"+[F:ILEG]CTRNUM
        TEX(NBTEX)     = [F:ILEG]REFNUM
        TEXTE(NBTEX,1) = [F:ILEG]REFNUM-[F:ILEG]NAM-[F:ILEG]SRN
        TEXTE(NBTEX,2) = [F:ILEG]CTRNUM
        TEXTE(NBTEX,3) = format$(GFMD,[F:ILEG]CTRDAT)
        If [F:ILEG]XITDAT<>[0/0/0] Then
          TEXTE(NBTEX,4) = format$(GFMD,[F:ILEG]XITDAT)
        Else
          TEXTE(NBTEX,4) = ""
        Endif
        TEXTE(NBTEX,5) = [F:ILEG]LEGID
      Endif
    Endif
  Next
Return

