################################################################################
## Sélection d'un no de contrat pour multicontrat, paramètre LEG
## Return GCURLEG, GSOCIETE, CTRNUMERO
##  If DAT1 et DAT2 = [0/0/0] List all contracts of MATRI
################################################################################
# SEGAY - 81085 - 30/05/12 Filter on legislation parameter
# MABOS-31/07/13-bug 91545 -contract selection after modify REFNUM
#**
#* Selection  no of contract for multicontrat, with parameter LEG
#* @since 30/05/12
#* @param MATRI : MATRICULE
#* @param DAT1 : DATE START
#* @param DAT2 : DATE END
#* @param PLEG : LEG
#* Parameter OUT
#* @param CTRNUMERO : CONTRACT
#* Initializes
#* GCURLEG
#* GSOCIETE
#*!
Subprog SELCTRMLEG(MATRI,DAT1,DAT2,PLEG,CTRNUMERO)
Value    Char MATRI
Value    Date DAT1, DAT2
Value    Char PLEG #  SEGAY - 81085 - 30/05/12 Filter on legislation
Variable Char CTRNUMERO()
Local Integer NBCTR , NUMCTR
Local Char    TBCTR(GLONVCR)(0..100) , LIBCTR(130)(0..100)
Local Char    TBLEG(GLONADI)(0..100) , TBSOC(GLONCPY)(0..100)
Local Date    TBDAT(0..100)     #MABOS-31/07/13-bug 91545
Local Char    DESSRV(GLONDES)
Local Char    CRIT1(250)
Local Char    TITBOITE(250)

If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:CPY])=0   : Local File COMPANY  [CPY]   : Endif
If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif
If clalev([F:SRV])=0   : Local File SERVICE  [SRV]   : Endif
If clalev([F:ID])=0    : Local File EMPLOID  [ID]    : Endif : # 71796
If clalev([F:ACC])=0   : Local File ACCES    [ACC]   : Endif : # 71796

If [L]DAT1 <> [0/0/0] & [L]DAT2 <> [0/0/0]
  CRIT1= "[F:HRCTR]REFNUM="-"'"+[L]MATRI+"' & [F:HRCTR]CTRDAT<=["+num$([L]DAT1)+"] & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>="+"["+num$([L]DAT2)+"])"
Else
  CRIT1= "[F:HRCTR]REFNUM="-"'"+[L]MATRI+"'"
Endif

For [HRCTR]CTR0 Where evalue(CRIT1)
 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("SRV",[F:HRCTR]ETRSRV,"") From CONTOBJ
#  SEGAY - 81085 - 30/05/12 Filter on legislation
 OKLEG=1
 If PLEG <> "" Then
   OKLEG = find([F:FCY]LEG,PLEG,'')
 Endif
# END - 81085
# / 71796
 If GUSRACS<>2
  Read [ID]ID0=[F:HRCTR]REFNUM
  If !fstat
   If [F:ID]CODACS <> ""
    Read [F:ACC]CODACC = GUSER;[F:ID]CODACS
   Endif
  Endif
 Endif
 If OKLEG #  SEGAY - 81085 - 30/05/12 Filter on legislation
  If GUSRACS = 2 | ( !fstat & ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV)) )
   NBCTR += 1
   TBCTR(NBCTR)  = [F:HRCTR]CTRNUM
   [L]TBDAT(NBCTR)  = [F:HRCTR]CTRDAT : #MABOS-31/07/13-bug 91545
#  SEGAY 16/05/12 To manage translated texts (data type AX3 & AX1)
#   LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-mess(40,101,1)-format$(GFMD,[F:HRCTR]CTRDAT)-"-"-mess(12,105,1)
#&                 -[F:FCY]FCY-[F:FCY]FCYNAM-"-"-mess(44,10702,1)-[F:HRCTR]ETRSRV-[F:SRV]DES
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   Call LECTEXTRA(DESSRV,"SERVICE","DES",[F:HRCTR]ETRSRV,"") From ATEXTRA
   LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-mess(40,101,1)-format$(GFMD,[F:HRCTR]CTRDAT)-"-"-mess(12,105,1)
&                 -[F:FCY]FCY-[F:FCY]FCYNAM-"-"-mess(44,10702,1)-[F:HRCTR]ETRSRV-DESSRV
&                 -"-"-mess(15,10712,1)-num$([F:CPY]LEG)
   TBLEG(NBCTR)=[F:CPY]LEG
   TBSOC(NBCTR)=[F:CPY]CPY
  Endif
 #Endif
# 71796 /
 Endif
Next
If NBCTR=0
 GMESSAGE  = mess(158,10702,1) : # Pas de contrat valide sur la période
#JASMI - START
# mkstat=2 :#DLE otherwise, none message displayed
 GERR=1
#JASMI - END
 CTRNUMERO = ""
 GCURLEG = "" : GSOCIETE=""
Elsif NBCTR=1
 CTRNUMERO = TBCTR(1)
 GCURLEG = TBLEG(1) : GSOCIETE=TBSOC(1)
Else

# Call SAITEX(NBCTR,LIBCTR,NUMCTR,mess(151,10702,1)) From GESECRAN : # Choix du contrat
 TITBOITE = mess(151,10702,1)
 If (dim(CPL_TIT)>0)Then TITBOITE -= CPL_TIT  : Endif #
 Call SAITEX(NBCTR,LIBCTR,NUMCTR,TITBOITE) From GESECRAN : # Choix du contrat
 If NUMCTR=0
  CTRNUMERO = ""
  GCURLEG = "" : GSOCIETE=""
 Else
  CTRNUMERO = TBCTR(NUMCTR)
  GCURLEG = TBLEG(NUMCTR) : GSOCIETE=[L]TBSOC(NUMCTR):#GSOCIETE=TBSOC(NBCTR):#MABOS-31/07/13-bug 91545
  Read [HRCTR]CTR0=[L]MATRI;[L]TBCTR(NUMCTR);[L]TBDAT(NUMCTR):#MABOS-31/07/13-bug 91545
 Endif
Endif
End
##############################################################
#  get the legislation of the contract
#  @params :
#     PKEYMAT : Matricule
#     PKEYCTR : contract
#     OK      : flag execution. return 1 if OK
#     RESULT  : legislation updated
#     DISPMSG : Display mesage if dispmsg <>0
##############################################################


Subprog GET_LEGHRCTR(PKEYMAT,PKEYCTR,OK,RESULT,DISPMSG)
Value Char PKEYMAT()
Value Char PKEYCTR()
Variable Integer OK
Variable Char RESULT()
Value Integer DISPMSG
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
#if not ok INDMES<>0
Read [HRCTR]CTR0(2)=PKEYMAT;PKEYCTR
If !fstat
  Call GET_LEGFCY([F:HRCTR]ETRFCY,OK,RESULT,DISPMSG)
  If(!OK): End : Endif
Endif
If(DISPMSG & !OK)

Endif
End

#**#####################################################################################
#* get legislation of a contract with date
#* SEGAY
#* @since 05/07/12
#* @param PKEYMAT : Matricule
#* @param PKEYCTR : Contract code
#* @param PKEYDAT : Contract date
#* @return OK : OK is good
#* @return RESULT : LEG code
#* @param DISPMSG : Display message
#*!
Subprog GET_LEGHRCTRDAT(PKEYMAT,PKEYCTR,PKEYDAT,OK,RESULT,DISPMSG)
Value Char PKEYMAT()
Value Char PKEYCTR()
Value Date PKEYDAT

Variable Integer OK
Variable Char RESULT()
Value Integer DISPMSG
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
#if not ok INDMES<>0
Filter [HRCTR] Where REFNUM=PKEYMAT & CTRNUM=PKEYCTR & CTRDAT<=PKEYDAT
&  & (XITDAT=[0/0/0] | XITDAT>=PKEYDAT) Order By CTRDAT
Read [HRCTR] Last
Filter [HRCTR]
If !fstat
  Call GET_LEGFCY([F:HRCTR]ETRFCY,OK,RESULT,DISPMSG)
  If(!OK): End : Endif
Endif
If(DISPMSG & !OK)

Endif
End

#**#####################################################################################
#* function get legislation of a contract with date
#* SEGAY
#* @since 05/07/12
#* @param PKEYMAT : Matricule
#* @param PKEYCTR : Contract code
#* @param PKEYDAT : Contract date
#* @return RESULT : LEG code
#*!
Funprog LEGHRCTRDAT (PKEYMAT,PKEYCTR,PKEYDAT)
Value Char PKEYMAT()
Value Char PKEYCTR()
Value Date PKEYDAT

Local Integer OK
Local Integer DISPMSG

Local Char WRESULT
Local Char RESULT

OK =0
DISPMSG=0
 Call GET_LEGHRCTRDAT(PKEYMAT,PKEYCTR,PKEYDAT,OK,WRESULT,DISPMSG)
 If OK
   RESULT=WRESULT
 Else
   RESULT=""
 Endif
End RESULT

