#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UUMGTRTPUR08   Migration des Factures                     Module Achats#
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR08") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR08(DOSSIER)
  Call MAJ_UUMGTRTPUR08(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR08(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

Local Char WNAMPIHM,WNAMPIDM,WNAMPIVM
Call MIGTABNAME (DOSSIER,"PINVOICE",WNAMPIHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PINVOICED",WNAMPIDM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PINVOICEV",WNAMPIVM,ERR) From TRTMIG

If ERR
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPIHM,"fde",DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMPIDM,"fde",DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMPIVM,"fde",DOSSIER),0) < 0
  End
Endif

##2 - On vide les fichiers selon le cas
#######################################

Local File =DOSSIER+".PINVOICE"  [PIH]
Trbegin [PIH]
Delete [PIH] Where ORIMOD<>3
Commit

Call MIGTABRAZ (DOSSIER,"PINVOICED",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"PINVOICEV",ERR) From TRTMIG

# Issue 101446 - 2014-07-11 by MUARN : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR08",7,ERR) From TRTMIG : #7=Erreur
  End
Endif
If val(VERSION)<GMIGX3VER60
  Local File =DOSSIER+".CPTANALIN"  [CAL]
  Trbegin [CAL]
  Delete [CAL] Where ABRFIC="PVF" & VCRTYP=8
  Commit
  Trbegin [CAL]
  Delete [CAL] Where ABRFIC="PID"
  Commit

  Local File =DOSSIER+".PVCRVAT"    [PVV]
  Trbegin [PVV]
  Delete [PVV] Where VCRTYP=8
  Commit

  Local File =DOSSIER+".PVCRFOOT"   [PVF]
  Trbegin [PVF]
  Delete [PVF] Where VCRTYP=8
  Commit
Endif

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR08",ERR) From TRTMIG

End

##########################################################################
Subprog MAJ_UUMGTRTPUR08(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-12 by SR : adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR08",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMPIHM,WNAMPIDM,WNAMPIVM
Call MIGTABNAME (DOSSIER,"PINVOICE",WNAMPIHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PINVOICED",WNAMPIDM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PINVOICEV",WNAMPIVM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR08",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPIHM,"fde",DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPIDM,"fde",DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPIVM,"fde",DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR08",2,ERR) From TRTMIG : #2=En cours
# Issue 108857 - 2015-06-15 by SR : Déplacé avant définition des variables qui utilisent adxwrb
Gosub MIG_OUVRE From TRTMIG

###################
Local Char WTAB_PIH (100) (adxwrb)
Local Char WTAB_PID (100) (adxwrb)
Local Char WTAB_PIV (100) (adxwrb)
Local Char WTAB_CAL (100) (adxwrb)
Local Char WTAB_PVV (100) (adxwrb)
Local Char WTAB_PVF (100) (adxwrb)
Local Shortint WCPT_PIH,WCPT_PID,WCPT_PIV,WCPT_CAL,WCPT_PVV,WCPT_PVF

Call ECR_TIME("UUMGTRTPUR08 Purchase Invoices Process : Update PINVOICE-V-D") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR08 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#

Call MIGTABINIT (DOSSIER,"PINVOICE",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PINVOICED",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PINVOICEV",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABINIT (DOSSIER,"CPTANALIN",ERR) From TRTMIG
#Call MIGTABINIT (DOSSIER,"PVCRVAT",ERR) From TRTMIG
#Call MIGTABINIT (DOSSIER,"PVCRFOOT",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:PIH])  = 0 : Local File =DOSSIER+".PINVOICE"    [PIH]  : Endif   # Fichier X3 "Vide"
If clalev([F:PID])  = 0 : Local File =DOSSIER+".PINVOICED"    [PID]  : Endif   # Fichier X3 "Vide"
If clalev([F:PIV])  = 0 : Local File =DOSSIER+".PINVOICEV"    [PIV]  : Endif   # Fichier X3 "Vide"

If clalev([F:PIHM]) = 0 : Local File =DOSSIER+"."+WNAMPIHM   [PIHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:PIDM]) = 0 : Local File =DOSSIER+"."+WNAMPIDM   [PIDM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:PIVM]) = 0 : Local File =DOSSIER+"."+WNAMPIVM   [PIVM] : Endif   # Fichier X3 renommé Avant Migration

If clalev([F:PID2]) = 0 : Local File =DOSSIER+"."+WNAMPIDM   [PID2] : Endif   # Fichier X3 renommé Avant Migration
# Issue 112754 - 2017-01-16 by SR : Services
If clalev([F:PID3])  = 0 : Local File =DOSSIER+".PINVOICED"    [PID3]  : Endif # fichier X3 "Vide"

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

Gosub OUVRE_PUR From UUMGTRTPUR00
Gosub OUVRE_PUR06

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR08",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [PIDM] With [PIHM]PIH0~=[F:PIDM]NUM , [PIVM]PIV0~=[F:PIDM]NUM, [ITM]ITM0=[F:PIDM]ITMREF
&    As [LNK]
&    Order By Key CLE = [F:PIHM]CPY;[F:PIHM]FCY;[F:PIHM]NUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR08" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_PIH00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:PIHM]CPY=TABMIGKEY(1) & [F:PIHM]FCY=TABMIGKEY(2) & [F:PIHM]NUM>TABMIGKEY(3)"
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:PIHM]CPY=TABMIGKEY(1) & [F:PIHM]FCY>TABMIGKEY(2)"
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:PIHM]CPY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [PIH],[PID],[PIV]
GOK = 1

For [LNK]CLE(3) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR08" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  #Raz [F:PIH]
  #Raz [F:PIV]
  #  version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
    Gosub RAZV6_PIH
  Endif
  # Issue 88474 - 2013-05-07 by SR
  #  version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
    Gosub RAZV7_PIH
  Endif
  [F:PIH] = [F:PIHM]

 # Issue 88474 - 2013-05-06 by SR : Pour V6 et V7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_AVPIH
  Endif

  #  version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
    Gosub RAZV6_PIV
  Endif
  # Issue 88474 - 2013-05-07 by SR
  #  version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
    Gosub RAZV7_PIV
  Endif
    [F:PIV] = [F:PIVM]

  If WSITE<>[F:PIH]FCY
    #----- Alimentation de la société sur l'entête de demande d'achat -----#
      Call RECUP_GLOBAL_CPT(DOSSIER,[F:PIH]FCY) From TRTX3CPT
      WSITE=[F:PIH]FCY
  Endif

  #Appel proc de migration sur entete
  #  version < V6, traitement v6
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_PIHPIV
    If GOK<1 : Break : Endif
  Endif
  # Issue 88474 - 2013-05-07 by SR
  #  version < V7, traitement v7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_PIHPIV
    If GOK<1 : Break : Endif
  Endif

   # --- alimentation des champs et écriture enreg
     # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
   # --- alimentation des champs et écriture enreg
#  If NEWMOTEUR
#      Gosub PIH_STK : # pour stocker ref
#      WriteB [F:PIH]
#  Else
#      Write [F:PIH]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File PINVOICE, Error ="-num$(fstat),1) From GESECRAN
#      Gosub PIH_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File PINVOICE(NUM)"-[F:PIH]NUM+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
   Gosub PIH_STK : # pour stocker ref
   WriteB [F:PIH]
   If fstat
      Call ECR_TRACE("File PINVOICE, Error ="-num$(fstat),1) From GESECRAN
      Gosub PIH_ERRTRA : # pour afficher les ref
      GOK=0 : Break
   Endif
  # End issue 108760

  ############################
  #-- Boucle sur les lignes
  ############################
  For [LNK]CLE
    #rupture par ligne de facture
    #  version < V6, raz des champs v6
    If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_PID
    Endif
    #  version < V7, raz des champs v7
    If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_PID
    Endif
    # Issue 112754 - 2016-12-19 by SR : Services en V12
    #  version < V12, raz des champs v12
    If val(VERSION)<GMIGX3VER120
      Gosub RAZV12_PID
    Endif
    [F:PID] = [F:PIDM]

    #Appel proc de migration sur detail
    #  version < V6, traitement v6
    If val(VERSION)<GMIGX3VER60
       Gosub MAJV6_PID
       If GOK<1 : Break : Endif
    Endif
    # Issue 88474 - 2013-05-07 by SR
    #  version < V7, traitement v7
    If val(VERSION)<GMIGX3VER70
       Gosub MAJV7_PID
       If GOK<1 : Break : Endif
    Endif
    # Issue 112754 - 2016-12-19 by SR : Services en V12
   #  version < V12, traitement v12
    If val(VERSION)<GMIGX3VER120
       Gosub MAJV12_PID
       If GOK<1 : Break : Endif
    Endif
    # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#    If NEWMOTEUR
#        Gosub PID_STK : # pour stocker ref
#        WriteB [PID]
#    Else
#        Write [PID]
#    Endif
#    If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File PINVOICED, Error ="-num$(fstat),1) From GESECRAN
#          Gosub PID_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File PINVOICED(NUM/PIDLIN)"-[F:PID]NUM-num$([F:PID]PIDLIN)+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
     Gosub PID_STK : # pour stocker ref
     WriteB [PID]
     If fstat
        Call ECR_TRACE("File PINVOICED, Error ="-num$(fstat),1) From GESECRAN
        Gosub PID_ERRTRA : # pour afficher les ref
        GOK=0 : Break
     Endif
     # End issue 108760
  Next

  If GOK<1 : Break : Endif

  # --- alimentation des champs et écriture enreg
    # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR
#      Gosub PIV_STK : # pour stocker ref
#      WriteB [F:PIV]
#  Else
#      Write [F:PIV]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File PINVOICEV, Error ="-num$(fstat),1) From GESECRAN
#      Gosub PIV_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File PINVOICEV(NUM)"-[F:PIV]NUM+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
  Gosub PIV_STK : # pour stocker ref
  WriteB [F:PIV]
  If fstat
     Call ECR_TRACE("File PINVOICEV, Error ="-num$(fstat),1) From GESECRAN
     Gosub PIV_ERRTRA : # pour afficher les ref
     GOK=0 : Break
  Endif
  # End issue 107860

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:PIHM]CPY
    TABMIGKEY(2) = [F:PIHM]FCY
    TABMIGKEY(3) = [F:PIHM]NUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR08",7,ERR) From TRTMIG : #7=Erreur
Else
  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:PIH]
    If fstat
        Call ECR_TRACE("File PINVOICE, Error ="-num$(fstat),1) From GESECRAN
        Gosub PIH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:PIV]
    If fstat
        Call ECR_TRACE("File PINVOICEV, Error ="-num$(fstat),1) From GESECRAN
        Gosub PIV_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:PID]
    If fstat
        Call ECR_TRACE("File PINVOICED, Error ="-num$(fstat),1) From GESECRAN
        Gosub PID_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:PVV]
    If fstat
        Call ECR_TRACE("File PVCRVAT, Error ="-num$(fstat),1) From GESECRAN
        Gosub PVV_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:PVF]
    If fstat
        Call ECR_TRACE("File PVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
        Gosub PVF_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
# Endif
 # End issue 108760
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR08",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR08",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_PIH00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [PIH], [PID],[PIV]
Close Local File [PIHM], [PIDM],[PIVM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"PINVOICE",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PINVOICED",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PINVOICEV",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABEND (DOSSIER,"CPTANALIN",ERR) From TRTMIG
#Call MIGTABEND (DOSSIER,"PVCRVAT",ERR) From TRTMIG
#Call MIGTABEND (DOSSIER,"PVCRFOOT",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR08") From TRTMIG
Call ECR_TIME("UUMGTRTPUR08 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

################################################
$OUVRE_PUR06
Local File =DOSSIER+".GACCDUDATE" [DUD]
Local Libelle  WTRACE : WTRACE=1

Local Char WBPS(GLONBPS),WBPR(GLONBPR),WPOH(GLONVCR),WITM(GLONITM)

Local Decimal  WQTE, WCOE, WCOURS

#----- Variables locales pour calcul TVA -----#
Local Decimal  WCLCAMT1, WCLCAMT2, WCLCAMT(1..7)
Local Libelle  WCLCFLG1, WCLCFLG2, WCLCFLG(1..7)
Local Decimal  WBASE, WAMTTAX, WDEDTAX
Local Char     WTAX(GLONVAT)
# Issue 88474 - 2013-05-06 by SR
Local   Char    WDSPVOU(GLONUOM),WDSPWEU(GLONUOM)
Local   Decimal WPRIPUR
Local   Decimal WMT, WRND, WTAXE
Local   Integer STAT, I, J
Local   Char    WUOM(GLONUOM)
Local   Char    WCUR(GLONCUR)
# Issue 91653 - 2013-08-05 by SR
# Issue 91687 - 2013-08-06 by SR : CPRAMT vaut 0 au moment de la migration donc pas besoin de le convertir
#Local    Decimal WCOEFF, WCPRAMT, WUOMSTUCOE
Local    Decimal WCOEFF

# ------------UTIACH23--------------#
# Issue 105428 - 2015-01-15 by SR : que si module compta présent
If [F:ADS]MODULE(1) = 2
  Local Char     WMSG(100)
  Local Char     WCMMNUM(GLONVCR)
  Local Decimal  WAMTCUR
  Local Char     WPIHNUM(GLONPIH)
  Local Integer  WPIDLIN
  # Issue 74046 - 2011-05-26 by VPO : pb valeur du code activité sur le dossier
  #Local Char     WTAB_CMMNUM(GLONVCR)(max(func AFNC.ACTIV("PIH"),100))
  Local Char     WTAB_CMMNUM(GLONVCR)(max(func AFNC.ACTIVDOS(DOSSIER,"PIH"),100))
  Local Integer  WTAB_NBLIG
  # Issue 74046 - 2011-05-26 by VPO : pb valeur du code activité sur le dossier
  #Local Char     WTAB_CMMNUM2(GLONVCR)(max(func AFNC.ACTIV("POH"),100))
  Local Char     WTAB_CMMNUM2(GLONVCR)(max(func AFNC.ACTIVDOS(DOSSIER,"POH"),100))
  Local Integer  WTAB_NBLIG2

  If !clalev([F:ITP])  Local File  =DOSSIER+".ITMBPS"    [ITP]  : Endif

  If !clalev([F:POH])  Local File =DOSSIER+".PORDER"    [POH]  : Endif
  If !clalev([F:POQ])  Local File =DOSSIER+".PORDERQ"   [POQ]  : Endif
  If !clalev([F:POP])  Local File =DOSSIER+".PORDERP"   [POP]  : Endif
  If !clalev([F:CMM])  Local File =DOSSIER+".GCOMMIT"   [CMM]  : Endif
  If !clalev([F:CMD])  Local File =DOSSIER+".GCOMMITD"  [CMD]  : Endif
  If !clalev([F:CMM2]) Local File =DOSSIER+".GCOMMIT"   [CMM2] : Endif
  If !clalev([F:CMD2]) Local File =DOSSIER+".GCOMMITD"  [CMD2] : Endif
  # Issue 112754 - 2016-12-19 by SR : Services en V12
  If !clalev([F:PTD])  Local File =DOSSIER+".PRECEIPTD" [PTD]  : Endif
  If !clalev([F:PND])  Local File =DOSSIER+".PRETURND"  [PND]  : Endif
  # Issue 79435 - 2012-01-20 by VPO : perf
  #Link [CMD2] With [CMM2] CMM0=[F:CMD2]NUM As [CMX2]
  Link [CMM2] With [CMD2] CMD0~=[F:CMM2]NUM As [CMX2]
Endif
# End issue 105428
Return

