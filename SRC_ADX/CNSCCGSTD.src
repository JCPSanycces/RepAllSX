Subprog AM_REFSTR(VALEUR)
Variable Char    VALEUR()

If [M]REFEND = "" | VALEUR = ""
 [M]REFEND = VALEUR
Endif

End

######################################################################################
Subprog C_REFEND(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" & [M]REFSTR <> ""
 mkstat=2 : End
Endif

End
