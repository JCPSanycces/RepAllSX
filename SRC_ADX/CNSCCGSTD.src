######################################################################################
$NAV_FILTER
#Verrai plus tard si possible de dépasser 200 lignes sur cette consultation...

Case CHGPAG

 When  2 :#suite
  CRITERE2 -= '& ([F:CNG]YEA <'+num$(FINYEA)

  CRITERE2 -= '|([F:CNG]YEA='+num$(FINYEA)

  CRITERE2 -= '&(REFNUM>"'+FINREF+'"'

#  CRITERE2 -= '|(REFNUM="'+FINREF+'" & CTRNUM>="'+FINCTR+'"))))'
  CRITERE2 -= '|(REFNUM="'+FINREF+'" & CTRNUM>="'+FINCTR+'" & CTRDAT>['+num$(FINCTRDAT)+']))))'

 When -2 :#retour
#  CRITERE1  = '&([F:CNG]YEA>'+num$(DEBYEA)
  CRITERE2 -= '&([F:CNG]YEA>'+num$(DEBYEA) # FQ89905 - SEGAY 23/05/13 Test sur date contrat

  CRITERE2 -= '|([F:CNG]YEA='+num$(DEBYEA)

  CRITERE2 -= '&(REFNUM<"'+DEBREF+'"'

#  CRITERE2 -= '|(REFNUM="'+DEBREF+'" & CTRNUM<"'+DEBCTR+'"))))'
  CRITERE2 -= '|(REFNUM="'+DEBREF+'" & CTRNUM<"'+DEBCTR+'" & CTRDAT<['+num$(DEBCTRDAT)+']))))'
Endcase

Return


$SORTIE
#LIPET - 06-12-2016 - X3-11361 - START
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#LIPET - 06-12-2016 - X3-11361 - END
Return
