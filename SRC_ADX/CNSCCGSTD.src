## Etiquette ajoutée par le superviseur (écran CONSCCG1) 29/04/2013 19:03:16 (SEGAY)
######################################################################################
Subprog C_TIM(VALEUR)
Variable Char    VALEUR()
# FQ88082 - SEGAY 23/04/13 test ACS de TIM
If [F:TIM]ACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:TIM]ACS
 If fstat or [F:ACC]EXEC<>2 or [F:ACC]CONSUL<>2
 #LIPET - 06-12-2016 - X3-11361 - START
  #GMESSAGE = VALEUR-":"-mess(61,709,1) : # Vous n'avez pas accès à ce code
  GMESSAGE = VALEUR-":"-mess(61,10709,1) : # Vous n'avez pas accès à ce code
  #LIPET - 06-12-2016 - X3-11361 - END
  mkstat = 2 : End
 Endif
Endif
# END FQ88082

End

######################################################################################
Subprog AS_DATPYR(VALEUR)
Variable Date    VALEUR

If VALEUR = [00/00/0000] or VALEUR > eomonth(GMOIPAY) : # pas le futur
 VALEUR = eomonth(GMOIPAY)
Endif
#SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
Gosub RECH_DAT_PAI
GMESSAGE ="" : # Pour ne pas bloquer la saisie
mkstat = 0

End
######################################################################################
Subprog C_DATPYR(VALEUR)
Variable Date    VALEUR
#ADNGO - 03-02-2017 - X3-11361 - START
If !clalev([F:HRPEOD])  : Local File HRPEODET    [HRPEOD]  : Endif
Filter [HRPEOD] Where  [HRPEOD]PYRDAT   = VALEUR & (PERCOD = [M:CCG1]PERCOD |PERCOD = [M:CCCG]PERCOD)
Read [HRPEOD] First
If fstat
  GMESSAGE = mess(159,10702,1) :
  mkstat = 2 : End
Endif
#ADNGO - 03-02-2017 - X3-11361 - END

If VALEUR = [00/00/0000] or VALEUR > eomonth(GMOIPAY)  : # pas le futur
# VALEUR = GMOIPAY
 VALEUR = eomonth(GMOIPAY) #SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
Endif

#/70374
Read [F:VEP]VEP4 First
If [F:VEP]PYRDAT > VALEUR
 mkstat = 1
 #LIPET - 06-12-2016 - X3-11361 - START
 #GMESSAGE =mess(24,702,1)-num$(VALEUR) : # Paie non calculée au
 GMESSAGE =mess(24,10702,1)-num$(VALEUR) : # Paie non calculée au
 #LIPET - 06-12-2016 - X3-11361 - END
 End
Endif
#70374/

#CRITDAT = VALEUR
#Call CADRE_PYRDAT(VALEUR,[M]FCY) From TPSSUB
#I=0
#While VALEUR > CRITDAT & !mkstat
# # On cherche la plus proche date de paie antérieure à la date sélectionnée
# I+=1
# VALEUR = CRITDAT - I
# Call CADRE_PYRDAT(VALEUR,[M]FCY) From TPSSUB
#Wend
#SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
Gosub RECH_DAT_PAI
If !mkstat
#LIPET - 06-12-2016 - X3-11361 - START
    #[M:CCG1]WDATDEB = [F:PEO]PERSTR(0) : #SEGAY - 23/05/13 - FQ89905  date debut de période. A utiliser dans criteres de sélection des contrats
    [M:CCG1]WDATDEB = [F:HRPEOD]PERSTR(0) : #SEGAY - 23/05/13 - FQ89905  date debut de période. A utiliser dans criteres de sélection des contrats
#LIPET - 06-12-2016 - X3-11361 - END
Endif

If [M]FCY<> "" & mkstat
 End
Else
 Raz mkstat : # éviter l'erreur si il n'y a pas de code site = "" dans les périodes d'extraction
Endif

[M:CCG1]DATSEL = VALEUR
[M:CCG1]YEA    = year(VALEUR)

End

#SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
$RECH_DAT_PAI
CRITDAT = VALEUR
#MIPEA - 2017-01-06- X3-11361- START
Call CADRE_PYRDAT(VALEUR,[F:HRCTR]PERCOD) From TPSSUB
#Call CADRE_PYRDAT(VALEUR,[M]FCY) From TPSSUB
#MIPEA - 2017-01-06- X3-11361- END
I=0
While VALEUR > CRITDAT & !mkstat
 # On cherche la plus proche date de paie antérieure à la date sélectionnée
 I+=1
 VALEUR = CRITDAT - I
#MIPEA - 2017-01-06- X3-11361- START
Call CADRE_PYRDAT(VALEUR,[F:HRCTR]PERCOD) From TPSSUB
#Call CADRE_PYRDAT(VALEUR,[M]FCY) From TPSSUB
#MIPEA - 2017-01-06- X3-11361- END
Wend
Return
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR
#LIPET - 06-12-2016 - X3-11361 - START
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
Filter [FCY] Where [F:FCY]FCY = VALEUR
Read [FCY] First
If !fstat
  If [F:FCY]LEGCPY <>[M:CCG1]CPY & [M:CCG1]CPY <> ""
  mkstat=2
   GMESSAGE = VALEUR-func AFNC.MES1(mess(171,104,1),[M:CCG1]CPY)
  Else
   If GCURLEG <> [F:FCY]LEG &  VALEUR <> "" & GCURLEG <> ""
           mkstat=2
     GMESSAGE=VALEUR-mess(171,187,1)-'"'+GCURLEG-'"'
   Endif
   Endif
Endif
Filter [FCY]
#LIPET - 06-12-2016 - X3-11361 - END
If VALEUR = ""
 If sigma(1,GNBSITE,GUSRFCY(indcum)<>"" & GUSRFCY(indcum)<>"\") = 1
  VALEUR = GUSRFCY(1) # un seul site autorisé
 Endif
 End
Endif

If !find(VALEUR,GUSRFCY)
 GMESSAGE = mess(2,104,1) : # Vous n'avez pas les droits pour ce site
 mkstat = 1
 End
Endif

End

######################################################################################
######################################################################################
##         Etiquette masque CONSCNG2             00/00/0000 00:00:00 (WGA)          ##
######################################################################################
Subprog AS_NBLIG
NOL = nolign-1

#LIPET - 06-12-2016 - X3-11361 - START
#Read [F:TIM]TIM0 = [M:CCG1]TIM
Read [F:TIM]TIM0 = GCURLEG;[M:CCG1]TIM
#LIPET - 06-12-2016 - X3-11361 - END
# Evénement xxx aaaa Solde minimum de nn jour(s)
[M:CCG2]SLDMIN  = mess(204,100,1)
[M:CCG2]SLDMIN -= [M:CCG1]TIM-[M:CCG2]CNGYEA(NOL)
[M:CCG2]SLDMIN -= mess(1,106,1)-mess(1,147,1)
[M:CCG2]SLDMIN -= num$([F:TIM]BLCMIN)
[M:CCG2]SLDMIN -= mess(28,197,1)
Affzo [M:CCG2]SLDMIN

End
######################################################################################

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#LIPET - 06-12-2016 - X3-11361 - START
  GCURLEG = VALEUR
#LIPET - 06-12-2016 - X3-11361 - END
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
#LIPET - 06-12-2016 - X3-11361 - START
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Filter [CPY] Where [F:CPY]CPY=VALEUR
Read [CPY] First
If !fstat
  If [F:CPY]LEG <> "" & GCURLEG <> "" & GCURLEG <> [F:CPY]LEG Then
     mkstat=2
     GMESSAGE=VALEUR-mess(170,187,1)-'"'+GCURLEG-'"'
   Endif
Endif
Filter [CPY]
#LIPET - 06-12-2016 - X3-11361 - END
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

#LIPET - 06-12-2016 - X3-11361 - START
If clalev([F:CPY1])=0  : Local File COMPANY [CPY1] : Endif

If VALEUR <> ""
  Filter [CPY1] Where CPY=VALEUR
  Read [CPY1] First
  Filter [CPY1]
  If !fstat
    If [CPY1]LEG <> ""
      GCURLEG = [CPY1]LEG
    Endif
  Endif
Endif
#LIPET - 06-12-2016 - X3-11361 - END
End

