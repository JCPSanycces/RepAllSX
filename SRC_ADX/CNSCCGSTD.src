#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
##                     CNSCCGSTD
##
##    MABOS - 01/02/13 - FQ86831 - US1205 - limit 127 for GAUTSRV
##            error message "128 trop de constante" quand on utilise find(ETRSRV,[V]GAUTSRV(1..[V]GNBSERV))<>0
##    SEGAY - 23/04/13 - FQ88082 - US1515 test ACS de TIM
#     SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
######################################################################################
Raz GTUNCPT
Local Char PARAM(10)(1..7)

Call GCONSULT("CCG","",PARAM) From GCONSULT
End
#######################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "TITRE"      : Gosub TITRE1
 When "LECTURE"    : Gosub LECTURE
 When "AV_AFFICHE" : Gosub AV_AFFICHE
 When "AV_MAGNETO" : Gosub AV_MAGNETO
 When "AP_MAGNETO" : Gosub AP_MAGNETO
 When "EXEBOUT"    : Gosub EXEBOUT
 When "SORTIE"   : Gosub SORTIE
 When Default
Endcase

Return
#######################################
$AV_MAGNETO
If [M:CCG1]DATPYR = [00/00/0000]
 [M:CCG1]DATPYR = eomonth(GMOIPAY)
 Filter [F] Where YEA = year([M:CCG1]DATPYR)
Else
 Filter [F] Where YEA = [M:CCG1]YEA
Endif
Return
#######################################
$AP_MAGNETO

Return
#######################################
$OUVRE

If !clalev([F:CNG])  : Local File CNGCPY    [CNG]  : Endif
If !clalev([F:DCG])  : Local File DEMCONGE  [DCG]  : Endif
#LIPET - 06-12-2016 - X3-11361 - START
#If !clalev([F:CTR])  : Local File EMPLOCTR  [CTR]  : Endif
If !clalev([F:HRCTR])  : Local File EMPLOCTR  [HRCTR]  : Endif
#LIPET - 06-12-2016 - X3-11361 - END
If !clalev([F:TIM])  : Local File TIMCOD    [TIM]  : Endif
#LIPET - 06-12-2016 - X3-11361 - START
#If !clalev([F:PEO])  : Local File PERIOD    [PEO]  : Endif
If !clalev([F:HRPEOD])  : Local File HRPEODET    [HRPEOD]  : Endif
#LIPET - 06-12-2016 - X3-11361 - END
If !clalev([F:FCY])  : Local File FACILITY  [FCY]  : Endif
If !clalev([F:HSP])  : Local File HISTOPAYE [HSP]  : Endif
If !clalev([F:TIP])  : Local File TIMEMP    [TIP]  : Endif
If !clalev([F:TIG])  : Local File TIMREGUL  [TIG]  : Endif
#LIPET - 2017-02-20- X3-15432- START
If !clalev([F:HRPOA])  : Local File POPULA    [HRPOA]  : Endif
#If !clalev([F:POA])  : Local File POPULA    [POA]  : Endif
#LIPET - 2017-02-20- X3-15432- END
If !clalev([F:VEP])  : Local File VALEMP    [VEP]  : Endif

If !clalev([F:ID])   : Local File EMPLOID   [ID]   : Endif
If !clalev([F:ACC])  : Local File ACCES     [ACC]  : Endif

#MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
If !clalev([F:SRV])  : Local File SERVICE   [SRV]  : Endif
If !clalev([F:ACCS])  : Local File ACCES    [F:ACCS]  : Endif
#end MABOS-01/02/13-FQ86831-US1205
# FQ88082 - SEGAY 23/04/13 test ACS de TIM
If !clalev([F:TIM])  : Local File TIMCOD    [TIM]  : Endif
If !clalev([F:ACC1]) : Local File ACCES     [ACC1] :Endif
# END FQ88082

#LIPET - 06-12-2016 - X3-11361 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#LIPET - 06-12-2016 - X3-11361 - END

#JASMI - 2014-09-25 - US2983 - START
#LIPET - 06-12-2016 - X3-11361 - START
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#LIPET - 06-12-2016 - X3-11361 - END
  If !clalev([F:CNE])  : Local File CNGEMP    [CNE]  : Endif
Endif
#JASMI - 2014-09-25 - US2983 - END

Global Char    SAVCRIT   (20)(1..7)
Global Char    SAVCRIT1  (250)

Local Shortint DEBYEA
#LIPET - 06-12-2016 - X3-11361 - START
#Local Char     DEBREF (GLONMAT) , DEBCTR (GLONCTR)
Local Char     DEBREF (GLONEML) , DEBCTR (GLONHRCTR)
#LIPET - 06-12-2016 - X3-11361 - END
Local Shortint FINYEA
#LIPET - 06-12-2016 - X3-11361 - START
#Local Char     FINREF (GLONMAT) , FINCTR (GLONCTR)
Local Char     FINREF (GLONEML) , FINCTR (GLONHRCTR)
#LIPET - 06-12-2016 - X3-11361 - END
Local Date     DEBCTRDAT, FINCTRDAT : # FQ89905 - SEGAY 23/05/13 Test sur date contrat
Local Integer  SAVYEA
#LIPET - 06-12-2016 - X3-11361 - START
#Local Char     SAVCTR(GLONCTR) , SAVREF(GLONMAT)
Local Char     SAVCTR(GLONHRCTR) , SAVREF(GLONEML)
#LIPET - 06-12-2016 - X3-11361 - END

Local Char CRITEREX  (250)
Local Char CRITEREY  (250)

#####
Local Char CRITERE   (250)
Local Char CRITERE0  (250)
Local Char CRITERE1  (250)
Local Char CRITERE2  (250)
Local Char CRITERE3  (250)
Local Char CRITEREN  (250)
Local Char CRITEREN0 (250)
Local Char CRITEREN1 (250)
Local Char OLDCRIT   (250)
Local Char OLDCRIT0  (250)
Local Char OLDCRIT1  (250)
Local Char OLDCRIT2  (250)

#57273
Local Date     CRITDAT
Local Date     OLDDAT

#
Local  Shortint I , IND1 , IND2 , IND3 , IND4 , SVGERR

#
Local Integer  NBCUM , NBPRJ , INTE , ENR , STEP_NOL
Local Shortint RUPT , TFULL , EXEFULL
Local Char     FRUPT (GLONAVA) , FRUPT2 (GLONAVA)

Local Integer WYEA(0..10)
Local Decimal WACQ(0..10), WPRI(0..10), WVLD(0..10), WATT(0..10), WSLD(0..10)
Local Decimal WSLDMIN

# FQ76178 US1931 - SEGAY 18/09/13
Local Char WEVT(GLONTPS),WCPA(GLONTPS),WCPE(GLONTPS)
Local Integer WOK
Call PARAM("","CPA",WCPA) From ADOVAL
Call PARAM("","CPE",WCPE) From ADOVAL
# END FQ76178

Return
#######################################

$TITRE1
  GCURLEG = GLEGFIL
Return

$LECTURE

Effzo [M:CCG2]

If [M:CCG1]TIM = "" | [M:CCG1]DATPYR = [00/00/0000] : NBLU=0 : Return : Endif

[M:CCG1]DATSEL = [M:CCG1]DATPYR

#LIPET - 06-12-2016 - X3-11361 - START
  GCURLEG = [M:CCG1]LEG
#LIPET - 06-12-2016 - X3-11361 - END
Gosub CREATE_FILTER
Gosub CHG_PAGE

If CHGPAG<>2 & CHGPAG<>-2 & CHGPAG<>-1 : Raz [M:CCG2] : Endif
# FQ89905 - SEGAY 23/05/13 Test sur date contrat
If CHGPAG=2 or CHGPAG=-2 : Raz [M:CCG2] : Endif

Columns [F:ID] (REFNUM,CODACS)
Gosub TABLE_LINK

Gosub SORT_FILTER

nolign = 0
TFULL  = 1
Raz IND1 , IND2 , IND3 , IND4 , SAVREF , SAVCTR , SAVYEA
SVGERR = 2

For [LNK]
 # FQ76178 US1931 - SEGAY 18/09/13 - On fait le test sur TYPCP pour CPE et CPA idem dans CNSCNGSTD, CNSCCSTD et GETLSTCCG de PORTPS
 [L]WOK = 1
 #LIPET - 06-12-2016 - X3-11361 - START
# Call VERIF_TYPCP([F:CTR]ETRFCY,[L]WCPA,[L]WCPE,[F:CNG]TIM,[L]WOK) From CNSCNGSTD
 Call VERIF_TYPCP([F:HRCTR]ETRFCY,[L]WCPA,[L]WCPE,[F:CNG]TIM,[L]WOK) From CNSCNGSTD
 #LIPET - 06-12-2016 - X3-11361 - END
 If [L]WOK
# END FQ76178
  If TFULL = 2
   Break
  Endif

   STEP_NOL = 1
# saut de ligne à chaque contrat
#   If [F:CTR]CTRNUM <> SAVCTR & SAVCTR <> ""
#    STEP_NOL = 2
#   Endif

   SAVNOL = NOL
# FQ89905 - SEGAY 23/05/13 Test sur date contrat
   If NBLU=1
    If CHGPAG=2 or CHGPAG=-2 : Raz [M:CCG2] : Endif
    NBLU=2
   Endif
# END FQ89905
   If CHGPAG > 0                                   : # Recherche(1),Suite(2),Raffraichissement(3)
# FQ89905 - SEGAY 23/05/13 Test sur date contrat
#    If NOL >= MAXLIG-1 : SUITE=2 : TFULL = 2 : Endif
#    NOL    += STEP_NOL
    If NOL>=MAXLIG-1 : SUITE=2 : TFULL = 2 : Break : Endif
    NOL += 1
# END FQ89905
    If NOL=0
#LIPET - 06-12-2016 - X3-11361 - START
#     DEBREF = [F:CTR]REFNUM
#     DEBCTR = [F:CTR]CTRNUM
#     DEBYEA = [F:CNG]YEA
#     DEBCTRDAT = [F:CTR]CTRDAT
#    Endif
#    FINREF = [F:CTR]REFNUM
#    FINCTR = [F:CTR]CTRNUM
#    FINYEA = [F:CNG]YEA
#    FINCTRDAT = [F:CTR]CTRDAT
     DEBREF = [F:HRCTR]REFNUM
     DEBCTR = [F:HRCTR]CTRNUM
     DEBYEA = [F:CNG]YEA
     DEBCTRDAT = [F:HRCTR]CTRDAT
    Endif
    FINREF = [F:HRCTR]REFNUM
    FINCTR = [F:HRCTR]CTRNUM
    FINYEA = [F:CNG]YEA
    FINCTRDAT = [F:HRCTR]CTRDAT
#LIPET - 06-12-2016 - X3-11361 - END
   Else
# FQ89905 - SEGAY 23/05/13 Test sur date contrat
#    If NOL <= 0 : RETOUR=2 : TFULL = 2 : Endif
#    NOL    -= STEP_NOL
    If NOL<=0 : RETOUR=2 : TFULL = 2 : Break : Endif
    NOL-=1
# END FQ89905
    If NOL=MAXLIG-1
#LIPET - 06-12-2016 - X3-11361 - START
#     FINREF = [F:CTR]REFNUM
#     FINCTR = [F:CTR]CTRNUM
#     FINYEA = [F:CNG]YEA
#     FINCTRDAT = [F:CTR]CTRDAT
#    Endif
#    DEBREF = [F:CTR]REFNUM
#    DEBCTR = [F:CTR]CTRNUM
#    DEBYEA = [F:CNG]YEA
#    DEBCTRDAT = [F:CTR]CTRDAT
     FINREF = [F:HRCTR]REFNUM
     FINCTR = [F:HRCTR]CTRNUM
     FINYEA = [F:CNG]YEA
     FINCTRDAT = [F:HRCTR]CTRDAT
    Endif
    DEBREF = [F:HRCTR]REFNUM
    DEBCTR = [F:HRCTR]CTRNUM
    DEBYEA = [F:CNG]YEA
    DEBCTRDAT = [F:HRCTR]CTRDAT
#LIPET - 06-12-2016 - X3-11361 - END
   Endif

   nolign=NOL+1

   If TFULL <> 2
    Gosub LINEFEED
    SVGERR = min(SVGERR,GERR) : # pour savoir si on est au moins une fois passé sans erreur
    If GERR       : # on affiche pas les lignes vides
     nolign = NOL
     NOL = SAVNOL
     GERR = 0
    Endif
   Endif
#zones pour les ruptures
#LIPET - 06-12-2016 - X3-11361 - START
#   SAVREF = [F:CTR]REFNUM
#   SAVCTR = [F:CTR]CTRNUM
   SAVREF = [F:HRCTR]REFNUM
   SAVCTR = [F:HRCTR]CTRNUM
   SAVYEA = [F:CNG]YEA
#LIPET - 06-12-2016 - X3-11361 - END
 Endif : # FQ76178
Next
Filter [F:LNK]

Columns [F:ID]

# FQ89905 - SEGAY 23/05/13 Test sur date contrat
#If CHGPAG > -1 : # <> retour,dernier
# [M:CCG2]NBLIG = min(MAXLIG,NOL+1)
##Elsif  CHGPAG <> -1 :#dernier
## [M:CCG2]NBLIG = MAXLIG
#Endif
# END FQ89905

If SVGERR <> 2
 GERR = SVGERR
Endif
OLDDAT   = CRITDAT
OLDCRIT  = CRITERE
OLDCRIT0 = CRITERE0
OLDCRIT1 = CRITERE1
OLDCRIT2 = CRITERE2
Affzo [M:CCG2] # FQ89905 - SEGAY 23/05/13 Test sur date contrat

Return
#######################################
$AV_AFFICHE
#Supression des colonnes hors contexte et alimentation des titres
Return
#######################################
$EXEBOUT

#Gosub PAG_PREM From GCONSULT
Return

######################################################################################
######################################################################################
$LINEFEED
Affzo [M:CCG2]
[M:CCG2]CNGYEA(nolign-1) = num$([F:CNG]YEA)
#LIPET - 06-12-2016 - X3-11361 - START
#[M:CCG2]REFNUM(nolign-1) = [F:CTR]REFNUM
#[M:CCG2]CTRNUM(nolign-1) = [F:CTR]CTRNUM
[M:CCG2]REFNUM(nolign-1) = [F:HRCTR]REFNUM
[M:CCG2]CTRNUM(nolign-1) = [F:HRCTR]CTRNUM
#LIPET - 06-12-2016 - X3-11361 - END
#JASMI - 2014-09-25 - US2983 - START
#[M:CCG2]DEBDAT(nolign-1) = [F:CNG]DEBDAT
#[M:CCG2]FINDAT(nolign-1) = [F:CNG]FINDAT
#LIPET - 06-12-2016 - X3-11361 - START
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then

If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#LIPET - 06-12-2016 - X3-11361 - END
  [M:CCG2]DEBDAT(nolign-1) = [F:CNE]EMPLEASTR
  [M:CCG2]FINDAT(nolign-1) = [F:CNE]EMPLEAEND
Else
  [M:CCG2]DEBDAT(nolign-1) = [F:CNG]DEBDAT
  [M:CCG2]FINDAT(nolign-1) = [F:CNG]FINDAT
Endif
#JASMI - 2014-09-25 - US2983 - END
#LIPET - 06-12-2016 - X3-11361 - START
#[M:CCG2]CTRDAT(nolign-1) = [F:CTR]CTRDAT :  # FQ89905 - SEGAY 23/05/13 Test sur date contrat
[M:CCG2]CTRDAT(nolign-1) = [F:HRCTR]CTRDAT :  # FQ89905 - SEGAY 23/05/13 Test sur date contrat
#LIPET - 06-12-2016 - X3-11361 - END

#MIPEA - 2016-01-04- X3-11361- START
#LIPET - 06-12-2016 - X3-11361 - START
#Call CNG_ACCOUNT([F:CTR]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,[F:CNG]TIM,[F:CTR]ETRFCY,[M:CCG1]DATSEL
#&               ,WYEA,WACQ,WPRI,WVLD,WATT,WSLD,WSLDMIN) From CNSCNGSTD
#Call CNG_ACCOUNT([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[F:CNG]TIM,[F:HRCTR]ETRFCY,[M:CCG1]DATSEL
#&               ,WYEA,WACQ,WPRI,WVLD,WATT,WSLD,WSLDMIN) From CNSCNGSTD
Call CNG_ACCOUNT([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[F:CNG]TIM,[F:HRCTR]ETRFCY,[M:CCG1]DATSEL,[F:HRCTR]PERCOD
&               ,WYEA,WACQ,WPRI,WVLD,WATT,WSLD,WSLDMIN) From CNSCNGSTD
#LIPET - 06-12-2016 - X3-11361 - END
#MIPEA - 2016-01-04- X3-11361- START
# On recupère un tableau des années concernées par DATSEL, on ne garde que celle courante
I=0
While I<dim(WYEA)-1 & WYEA(I) <> [F:CNG]YEA
 I+=1
Wend
If WYEA(I) = [F:CNG]YEA
 [M:CCG2]ACQ(nolign-1)   = WACQ(I)
 [M:CCG2]PRI(nolign-1)   = WPRI(I)
 [M:CCG2]VLD(nolign-1)   = WVLD(I)
 [M:CCG2]ATT(nolign-1)   = WATT(I)
 [M:CCG2]SLD(nolign-1)   = WSLD(I)
Endif

Return

######################################################################################
$CREATE_FILTER

#Période de congés à parcourir
CRITERE  = "1=1"
CRITERE0 = "1=1"
CRITERE1 = "1=1"
CRITERE2 = "1=1"
CRITERE3 = "1=1"

#Droits
CRITERE1  = '([F:ID]CODACS="" | [F:ACC]CONSUL=2)'
#LIPET - 06-12-2016 - X3-11361 - START
#CRITERE1 -= '& find([F:CTR]ETRFCY,GUSRFCY)'
CRITERE1 -= '& find([F:HRCTR]ETRFCY,GUSRFCY)'
#LIPET - 06-12-2016 - X3-11361 - END
#MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
#CRITERE1 -= '& find([F:CTR]ETRSRV,GAUTSRV)'
If GUSRACS<>2
    CRITERE1 -= '& ([F:SRV]CODACC="" or [F:ACCS]EXEC=2)'
    CRITERE1 -= '& ([F:TIM]ACS="" | [F:ACC1]CONSUL=2 | [F:ACC1]EXEC=2)' # FQ88082 - SEGAY 23/04/13 test ACS de TIM
Endif
#end MABOS-01/02/13-FQ86831-US1205

#Périodes de congés
 CRITERE0  = '[F:CNG]TIM ="'+[M:CCG1]TIM+'"'
#JASMI - 2014-09-25 - US2983 - START
#CRITERE0 -= '& (([F:CNG]STRPER <=[M:CCG1]DATSEL & [M:CCG1]DATSEL <= [F:CNG]ENDPER)'
#CRITERE0 -= '| ([F:CNG]DEBDAT <= [M:CCG1]DATSEL & [M:CCG1]DATSEL <= [F:CNG]FINDAT ))'
#LIPET - 06-12-2016 - X3-11361 - START
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
  #LIPET - 06-12-2016 - X3-11361 - END
   CRITERE0 -= '& ([F:CNE]EMPLEASTR <=[M:CCG1]DATSEL & [M:CCG1]DATSEL <= [F:CNE]EMPLEAEND)'
 Else
   CRITERE0 -= '& (([F:CNG]STRPER <=[M:CCG1]DATSEL & [M:CCG1]DATSEL <= [F:CNG]ENDPER)'
   CRITERE0 -= '| ([F:CNG]DEBDAT <= [M:CCG1]DATSEL & [M:CCG1]DATSEL <= [F:CNG]FINDAT ))'
Endif
#JASMI - 2014-09-25 - US2983 - END

#Contrat courants
#LIPET - 06-12-2016 - X3-11361 - START
#CRITERE   = '[F:CTR]CTRDAT<= ['+num$([M:CCG1]DATSEL)+']'
CRITERE   = '[F:HRCTR]CTRDAT<= ['+num$([M:CCG1]DATSEL)+']'
#LIPET - 06-12-2016 - X3-11361 - END
# FQ76186 - MABON 19/09/11 - Ajout test sur XITFNL
#SEGAY - 23/05/13 - FQ89905  date debut de pério
#CRITERE  -= '& ([F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>= ['+num$([M:CCG1]DATSEL)+'] | [F:CTR]XITFNL<>2)'
#LIPET - 06-12-2016 - X3-11361 - START
#CRITERE  -= '& ([F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>= ['+num$([M:CCG1]WDATDEB)+'] )'
CRITERE  -= '& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>= ['+num$([M:CCG1]WDATDEB)+'] )'
#LIPET - 22-02-2017 - X3-26541 - START
CRITERE  -= '& [F:FCY]LEG ="'+GCURLEG+'"'
#LIPET - 22-02-2017 - X3-26541 - END
#LIPET - 06-12-2016 - X3-11361 - END
#Société
If [M:CCG1]CPY <> ""
 CRITERE -= '& [F:CNG]CPY="'+[M:CCG1]CPY+'"'
Endif

#Site
If [M:CCG1]FCY <> ""
#LIPET - 06-12-2016 - X3-11361 - START
# CRITERE  -= '& [F:CTR]ETRFCY="'+[M:CCG1]FCY+'"'
 CRITERE  -= '& [F:HRCTR]ETRFCY="'+[M:CCG1]FCY+'"'
#LIPET - 06-12-2016 - X3-11361 - END
Endif

#Service
If [M:CCG1]SRV <> ""
#LIPET - 06-12-2016 - X3-11361 - START
# CRITERE  -= '& [F:CTR]ETRSRV="'+[M:CCG1]SRV+'"'
 CRITERE  -= '& [F:HRCTR]ETRSRV="'+[M:CCG1]SRV+'"'
#LIPET - 06-12-2016 - X3-11361 - END
Endif

#Salariés
If [M:CCG1]REFSTR <> ""
#LIPET - 06-12-2016 - X3-11361 - START
# CRITERE  -= '& [F:CTR]REFNUM>="'+[M:CCG1]REFSTR+'"'
# CRITERE  -= '& [F:CTR]REFNUM<="'+[M:CCG1]REFEND+'"'
 CRITERE  -= '& [F:HRCTR]REFNUM>="'+[M:CCG1]REFSTR+'"'
 CRITERE  -= '& [F:HRCTR]REFNUM<="'+[M:CCG1]REFEND+'"'
#LIPET - 06-12-2016 - X3-11361 - END
Endif
#ADNGO - 02-28-2017 - X3-11361 - START
 CRITERE3  -= '& [F:HRCTR]PERCOD ="'+[M:CCG1]PERCOD+'"'
#ADNGO - 02-28-2017 - X3-11361 - END
#Gestion de la pagination
If CRITERE=OLDCRIT & CRITERE0=OLDCRIT0
 Gosub NAV_FILTER
Endif
Return

######################################################################################
$SORT_FILTER
#Clé de tri des données parcourues en fonction du détail demandé
# FQ89905 - SEGAY 23/05/13 Test sur date contrat
If CHGPAG>0
#LIPET - 06-12-2016 - X3-11361 - START
#  Filter [F:LNK] Where evalue (CRITERE) & evalue(CRITERE0) & evalue(CRITERE1) & evalue(CRITERE2)
#&                Order By Key CLE = [F:CNG]YEA Desc;[F:CTR]REFNUM;[F:CTR]CTRNUM;[F:CTR]CTRDAT
  Filter [F:LNK] Where evalue (CRITERE) & evalue (CRITERE0) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
&                Order By Key CLE = [F:CNG]YEA Desc;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
#LIPET - 06-12-2016 - X3-11361 - END
Else
#  Filter [F:LNK] Where evalue (CRITERE) & evalue(CRITERE0) & evalue(CRITERE1)
#&                Order By Key CLE = [F:CNG]YEA;[F:CTR]REFNUM Desc;[F:CTR]CTRNUM Desc
#LIPET - 06-12-2016 - X3-11361 - START
#  Filter [F:LNK] Where evalue (CRITERE) & evalue(CRITERE0) & evalue(CRITERE1) & evalue(CRITERE2)
#&                Order By Key CLE = [F:CNG]YEA ;[F:CTR]REFNUM Desc;[F:CTR]CTRNUM Desc;[F:CTR]CTRDAT Desc
  Filter [F:LNK] Where evalue (CRITERE) & evalue (CRITERE0) & evalue (CRITERE1) & evalue (CRITERE2)
&                Order By Key CLE = [F:CNG]YEA ;[F:HRCTR]REFNUM Desc;[F:HRCTR]CTRNUM Desc;[F:HRCTR]CTRDAT Desc
#LIPET - 06-12-2016 - X3-11361 - END
Endif
Return

######################################################################################
$CHG_PAGE
If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif
Return

