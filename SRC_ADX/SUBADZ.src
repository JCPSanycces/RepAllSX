#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion objet ADZ
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ADZ",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "RAZCRE"      : Gosub RAZCRE
 When "AFFMASK"     : Gosub AFFMASK
 When "CLE_GAUCHE"  : Gosub CLE_GAUCHE
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "TITRE"       : Gosub TIT
 When "STATUT"      : Gosub STATUT
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "STYLE"       : Gosub STYLE
 When "DEGRISE"     : Gosub DEGRISE
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "AVANT_CHOI"  : Gosub AVANT_CHOI
 When "FIN"         : Gosub FIN
 When "FERME"       : Gosub FERME
Endcase
Return

#----------------------------------------------------------#
$AFFMASK
#JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call AFFMASK_GROUPE("[M]CREGRP") From AGENLIBA
Return

$RAZCRE
#JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Gosub INIT_GROUPE    From AGENLIBA
Return

$FERME
# cg mai  2013
# il faut killer les var globales crée via prog
Gosub FERME_KILL From AGENLIBA
Return

$AVANT_CHOI
If DEBUT
 If TUNNEL & SAVCLE1<>"" & SAVCLE2<>"" & CLECUR=0
  Read [AD8]ADZ0=SAVCLE2;SAVCLE1
  If !fstat
   CLECUR = 0
   REP = "C" : GREP = "C"
   [M:ADZ1] = [F:AD8]
   Affzo
   zonsui = "MOTCLE"
   Gosub SETBOUT From GOBJSUB
  Endif
 Endif
 DEBUT = 0
Endif
Return

$APRES_MOD
$APRES_CRE
# si besoin on met à jour la doc
Trbegin [ADZ]
 Call MAJ_ENVINDUS_FLD ([M]LAN,[M]MOTCLE) From AGENREM : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
Commit
Return

# Pour éviter de perdre la saisie du clob (EN V5)
$DEGRISE
# Aztuze pour rendre l'écran invalide après création ou modif
$STYLE
# Aztuze pour rendre l'écran invalide après la lecture
Gosub VERDOC From AGENDOCA
If IF_DOCV5
   Setmok [M] With 0
Endif
Return

$OUVRE
Global Integer NBLDOC
Local Char    DOSX3(GLONADS) , SIGRAP(2) , CRIRAP(250)
Local Integer DEBUT
Local File    ADOSSIER [ADS]
Global Char   LANDOC(GLONLAN)(1..dim([F:ADS]LAN))
DEBUT = 1
Raz NBLDOC , LANDOC
Read [ADS]DOSSIER = nomap
If !fstat
 For I=1 To [F:ADS]NBRLAN
  LANDOC(I) = [F:ADS]LAN(I-1)
 Next I
 NBLDOC = [F:ADS]NBRLAN
Endif
Call PARAM("","SUPDOS",DOSX3) From ADOVAL
If DOSX3<>""
 Local File =DOSX3+".ADOCFLD" [AD8]
Endif
Gosub BLOCAGE_CONSULT From SUBADO
Return

$FIN
Gosub BLOCAGE_CONSULT From SUBADO
Return

$APRES_MODIF
#JPGA 07/01/2010 BUG-69982 : Dans un dossier fille bloqué en consultation, le focus sur le champs HTML entre en modif à tord: on le bloquer
Gosub BLOCAGE_CONSULT From SUBADO
Return

$OUVRE_BOITE
Local Char BOXSTD(10) , BOXGEN(10) , BOXGST(10)
BOXGEN = "GAU_CHE"+num$(find("AD9",OBJLIS(1..dim(OBJLIS)-1))) : # Aide générique
BOXSTD = "GAU_CHE"+num$(find("AD8",OBJLIS(1..dim(OBJLIS)-1))) : # Aide standard
BOXGST = "GAU_CHE"+num$(find("A88",OBJLIS(1..dim(OBJLIS)-1))) : # Aide générique standard
Return

$CLE_GAUCHE
CLELISTE = "LAN;MOTCLE"
Return

$APRES_CHOI
Case currbox
 When BOXSTD , BOXGST
  Case REPONSE
   When GSTALFT,GSTALF2,GSTALF3,GSTALF4
    # Permet de passer en création avec une aide standard sur champ
    Look [ADZ]ADZ0=[F:AD8]LAN;[F:AD8]MOTCLE
    If fstat
     If VERROU : Gosub DEVERROU From GOBJET : Endif
     CLECUR = 0
     REP = "C" : GREP = "C"
     Read [AD8]ADZ0=
     [M:ADZ1] = [F:AD8]
     Affzo
     zonsui = "MOTCLE"
     REPONSE = 0
    Endif
   When GSTATIR
    If nomap=GDOSX3
     REPONSE = 0
    Endif
   When GSTASRA
    # Pour que la sélection rapide fonctionne
    Raz FILRAP, IFILRAP, FILSUITE, IFILSUITE
    FILTREG = 1
    Call SELRAP("ADZ",SAIRAP,IFILRAP,FILRAP) From GOBJACT
    K = instr(1,FILRAP,"[F:ADZ")
    While K
     FILRAP = left$(FILRAP,K-1)+"[F:AD8]"+right$(FILRAP,K+7)
     K = instr(1,FILRAP,"[F:ADZ")
    Wend
    Gosub REMP_LISGAU From GOBJSUB
    REPONSE = 0
   When GSTASVG , GSTAPRG : # mb 29.9.8 bug 49088
    # Pour que les flêches de défilement fonctionnent
    Default File [AD8]
    ILIS = val(right$(currbox,8))
    Case REPONSE
     When GSTASVG : RAPCAR = ">"
     When Default : RAPCAR = "<"
    Endcase
    Call SUIGAUCHE(RAPCAR,"AD8","LAN;MOTCLE",1,1,ILIS,"AD8",CZ,WINPROG,"",CRITERE,FILTSUP,FILROLE,FILGAUSUP,IFILSUITE,FILSUITE,K)
& From GOBJACT
    If K
     Gosub REMP_LISGAU From GOBJSUB
    Endif
    REPONSE = 0
  Endcase
Endcase
Case REPONSE
 When GSTAANU
  # On permet de supprimer l'aide spé sans contrôle des liens
  If nomap<>DOSX3 & [M]MOTCLE<="X"
   Read [ADZ]ADZ0=[M]LAN;[M]MOTCLE
   If !fstat
    Gosub ANUSPE
   Endif
   REPONSE = 0
  Endif
Endcase
Return

$ANUSPE
If !VERROU
 Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
 Return
Elsif !ACTANU
 Call ERREUR(mess(54,123,1)) From GESECRAN : # Suppression impossible
 Return
Endif
Gosub TR_ANUSPE
Gosub DEFAUT From =PROGOBJ
GREP = ""
If GOK=1
 Call ANNULE(ABREV,CLECUR1,CLECUR2) From GOBJTXT
 Call ANNULE(ABREV,CLECUR1,CLECUR2) From SUBALI
 CLECUR1 = "" : CLECUR2 = ""
Endif
Gosub DEVERROU From GOBJET
Gosub RELIT From GOBJSUB
Return

$TR_ANUSPE
GOK = 1
Trbegin [ADZ]
 Delete [ADZ] Where LAN=[M]LAN & MOTCLE=[M]MOTCLE
 If fstat=1
  GOK=-1 : Call RSTA("ADZ",[M]LAN-[M]MOTCLE) From GLOCK : Goto ROLL_ANUSPE
 Endif
Commit
Return

$ROLL_ANUSPE
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANUSPE : Endif

$LIENS
#JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call ALIMENT_GROUPE("ADZ", [ADZ]LAN, "", [ADZ]MOTCLE, "[M]CREGRP")  From AGENLIBA

Gosub GRISE_GEN
Gosub GRISE_LNK
Return

$GRISE_GEN
If [M]GEN=2
 [M]LNKORD = 0
 [M]LNKHLP = ""
 Affzo LNKHLP , LNKORD
 Grizo LNKHLP , LNKORD
Else
 Actzo LNKHLP , LNKORD
Endif
Return

$GRISE_LNK
If [M]LNKHLP=""
 [M]LNKORD = 0
 Affzo LNKORD
 Grizo LNKORD
Else
 Actzo LNKORD
Endif
Return

$TIT
TIT -= GVERSION
Return

$SETBOUT
If CLECUR
 CHMEN += "8"       : # Cas d'emploi
 If REP<>"M" & VERROU
   #JPGA 03/06/2010 BUG-64550: Implémentation Priorisation de documentation pour la Traduction. Bouton B ajouté lancant ADOCPRIO
   CHMEN += "7B9065" : # Copie documentation, Priorisation, aides non utilisées, aides manquantes, épuration
 Endif
Endif
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

$FILGAUCHE
Case currbox
 When BOXGEN : FILGAUSUP = 'GEN=2'
 When BOXSTD : FILGAUSUP = 'find([F]LAN,[V]LANDOC(1..[V]NBLDOC))'
 When BOXGST : FILGAUSUP = 'find([F]LAN,[V]LANDOC(1..[V]NBLDOC)) & GEN=2'
Endcase
Return

$STATUT
Case BOUT
 When "9" : Call HLPNUT(0)
 When "0" : Call HLPABS
 When "6" : Call HLPNUT(1)
 When "5" : Gosub TRTDEL
Endcase
Return

#----------------------------------------------------#
$TRTDEL
#ADOCFLD ADZ
Local Char LISTLAN(250) : Raz LISTLAN

Filter [ADZ] Where [F]LAN=[M]LAN & [F]MOTCLE=[M]MOTCLE
Read [ADZ]ADZ0=[M]LAN;[M]MOTCLE
If ![S]fstat
  If !func AGENLIBA.CONTROLE_GROUPE_OK("ADZ", [M]LAN, "", [M]MOTCLE)
    GERR=1 :  FIN=1  :  Return
  Endif
Endif
Filter [ADZ]

For [ADZ]ADZ1 Where [F:ADZ]MOTCLE=[M]MOTCLE
  If LISTLAN="" : LISTLAN+=[F:ADZ]LAN
  Else : LISTLAN+=", "+[F:ADZ]LAN : Endif
Next

# Voulez-vous supprimer la documentation MOTCLE dans toutes les langues existantes ?
MESSA = func AFNC.MES1(mess(115,176,1),[M]MOTCLE)+"\"+LISTLAN
Call AVERTIR(MESSA,OK) From GESECRAN
If OK<>2 : Return : Endif

For [ADZ]ADZ1 Where [F:ADZ]MOTCLE=[M]MOTCLE
  Call ANNU([F:ADZ]LAN,[F:ADZ]MOTCLE)
  If GOK=1
   Gosub VERDOC From AGENDOCA
   Call TRACE_COR("ADZ",[F:ADZ]MOTCLE,[F:ADZ]LAN,"A") From AGENLIBA
   Call ANNULE("ADZ",[F:ADZ]MOTCLE,[F:ADZ]LAN) From GOBJTXT
   Call ANNULE("ADZ",[F:ADZ]MOTCLE,[F:ADZ]LAN) From SUBALI
  Endif
Next
If GOK=1
 Raz CLECUR , CLECUR1 , CLECUR2
 Gosub DEVERROU From GOBJET
 Gosub RELIT From GOBJSUB
Endif
Return

Subprog ANNU(WLAN,WCOD)
Value Char WLAN, WCOD
If clalev([F:ADZ])=0 : Local File ADOCFLD  [ADZ] : Endif
Call DEBTRANS From GLOCK
Gosub TR_ANNU
End

$TR_ANNU
Trbegin [ADZ]
 Delete [ADZ] Where [F]LAN=WLAN & [F]MOTCLE=WCOD
 If fstat=1
  GOK=-1 : Call FSTA("ADZ") From GLOCK : Goto ROLL_ANNU
 Endif
Commit
Return

$ROLL_ANNU
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNU : Endif
Return

#----------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "ASELHLP"
  OBJET = "AMC"
  CRITERE = '([F:AMC]MOTCLE="'+PARAM(1)+'" | [F:AMC]INFBUL="'+PARAM(1)+'")'
 When "ASELHLPGEN"
  OBJET = "ADZ"
  CRITERE = 'GEN=2'
Endcase
Return

#----------------------------------------------------------------#
$TRTCOP
Local Char DOS_DES(250)  :  [L]DOS_DES=[M]DOSDES
# Recherche pour Savoir si le Dossier DESTINATION traite les motclé à l'ancien mode : via AMSKZON (La table AMOTCLE n'existe pas)
If dim([L]IF_AMOTCLE)<0 : Local Integer IF_AMOTCLE  :  Endif
[L]IF_AMOTCLE=func AGENLIBA.FICHIER_DANS_DOSSIER([L]DOS_DES, "FIL", "AMOTCLE", "fde")

If [M]DOSORG=nomap
 Local File ADOCFLD   [ADZ1]
 Local File AMOTCLE   [AMC1]
Else
 Local File =[M]DOSORG+".ADOCFLD"   [ADZ1]
 Local File =[M]DOSORG+".AMOTCLE"   [AMC1]
Endif

# Si l'application DISTANTE contient la nouvelle structure : AMOTCLE on ouvre AMOTCLE sinon, on ouvre AMSKZON
If [L]DOS_DES=nomap
 Local File ADOCFLD   [ADZ2]
 If [L]IF_AMOTCLE : Local File AMOTCLE   [AMC2]
 Else             : Local File AMSKZON   [AMZ2]
 Endif
Else
 Local File =[L]DOS_DES+".ADOCFLD"   [ADZ2]
 If [L]IF_AMOTCLE : Local File =[L]DOS_DES+".AMOTCLE"   [AMC2]
 Else             : Local File =[L]DOS_DES+".AMSKZON"   [AMZ2]
 Endif
Endif

Local Integer I , J , OK , HLPZON
Local Char    CRITCOD(250) , CRITAMC(250) , CRITLAN(250) , MESSA(250)
Local Char    OLD_LAN(GLONLAN), OLD_MOTCLE(50)

Raz CRITCOD , CRITLAN, CRITAMC
If TABLE<>""  : CRITLAN = 'LAN = "'+TABLE+'"'  : Endif
If TABLE2<>"" : CRITCOD = 'MOTCLE = "'+TABLE2+'"' : Endif
If TABLE2<>"" : CRITAMC = '(MOTCLE="'+TABLE2+'" | INFBUL="'+TABLE2+'")' : Endif
HLPZON = (TABLE3="2")
MESSA = CRITLAN-CRITCOD
If CRITAMC="" : CRITAMC = "1=1" : Endif
If CRITCOD="" : CRITCOD = "1=1" : Endif
If CRITLAN="" : CRITLAN = "1=1" : Endif
OK = 1
If GTRACE="" & (TABLE="" or TABLE2="")
 Filter [ADZ1] Where evalue(CRITCOD) & evalue(CRITLAN)
 I = rowcount([F:ADZ1])
 Filter [ADZ1]
 # Voulez-copier toutes ces aides sur champs
 OK=1 : Call AVERTIR(MESSA+"\"+mess(33,176,1)-"("+num$(I)+")",OK) From GESECRAN
 If OK<>2 : OK = 0 : Endif
Endif

If OK
 Call DEBTRANS From GLOCK
 If HLPZON
  Filter [AMC1] Where evalue(CRITAMC)
 Endif
 Gosub TR_COP
Endif
Close Local File [ADZ1], [AMC1], [ADZ2]
If [L]IF_AMOTCLE : Close Local File [AMC2]
Else             : Close Local File [AMZ2]
Endif
Return

$TR_COP
GOK = 1
Trbegin [ADZ2]
 Delete [ADZ2] Where evalue(CRITCOD) & evalue(CRITLAN)
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOS_DES+".ADOCFLD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ADZ2","") From GLOCK : Goto AB_TR_COP
 Endif

 [L]OLD_LAN="" : [L]OLD_MOTCLE=""
 For [ADZ1]ADZ0 Where evalue(CRITCOD) & evalue(CRITLAN)
  [F:ADZ2] = [F:ADZ1]
  If dim([F:ADZ2]UPDUSR)>0    : [F:ADZ2]UPDUSR    = GUSER                                         : Endif
  If dim([F:ADZ2]UPDDATTIM)>0 : [F:ADZ2]UPDDATTIM = datetime$
    If dim([F:ADZ2]UPDDAT)>0  : [F:ADZ2]UPDDAT    = func SUBADC.DAT_DATETIME([F:ADZ2]UPDDATTIM)   : Endif
  Else
    If dim([F:ADZ2]UPDDAT)>0  : [F:ADZ2]UPDDAT    = date$                                         : Endif
    If dim([F:ADZ2]UPDTIM)>0  : [F:ADZ2]UPDTIM    = time                                          : Endif
  Endif
  Write [ADZ2]
  If fstat
   GOK=0 : Call FSTA("ADZ2") From GLOCK : Break
  Endif
  #JPGA 01/08/2012 EXI-79953-8 : Cas de Copie vers dossier de type SUPERV : Lancement du marquage pour pouvoir ensuite Pousser
  If  [ADZ1]LAN<>[L]OLD_LAN | [ADZ1]MOTCLE<>[L]OLD_MOTCLE
    #JPGA 01/08/2012 EXI-79953-8 : Cas de Copie vers dossier de type SUPERV : Lancement du marquage pour pouvoir ensuite Pousser
    If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif
    [L]DOC_CLE1=[ADZ2]MOTCLE : [L]DOC_CLE2=[ADZ2]LAN
    Call MARQUAGE_SUPERV([L]DOS_DES, "ADZ", [L]DOC_CLE1, [L]DOC_CLE2, [L]ACOPMARQFLG) From AGENLIBA
  Endif

  If HLPZON
    For [AMC1] Where (MOTCLE=[F:ADZ1]MOTCLE | INFBUL=[F:ADZ1]MOTCLE)
      If [L]IF_AMOTCLE  # Si l'application DISTANTE contient la nouvelle structure : AMOTCLE on utilise AMOTCLE sinon, on prend AMSKZON
        Read [AMC2]AMC0=[F:AMC1]TYPZON;[F:AMC1]IDENT1;[F:AMC1]IDENT2
        If fstat
          [F:AMC2]= [F:AMC1]
          Write [AMC2]
          If fstat
            GOK=0 : Call FSTA("AMC2") From GLOCK : Break 2
          Endif
        Else
          [F:AMC2]MOTCLE = [F:AMC1]MOTCLE
          [F:AMC2]INFBUL = [F:AMC1]INFBUL
          Rewrite [AMC2]
          If fstat
            GOK=0 : Call FSTA("AMC2") From GLOCK : Break 2
          Endif
        Endif
      Else
        If [F:AMC1]TYPZON=2    #  Cas V7=>V6 :  Lien de type 2=Ecran . Menu local 7985 : (1=Table 2=Ecran 3=Classe 4=Representation)
          Read [AMZ2]CODE=[F:AMC1]IDENT1;[F:AMC1]IDENT2
          If !fstat
            [F:AMZ2]MOTCLE = [F:AMC1]MOTCLE
            Rewrite [AMZ2]
            If fstat
              GOK=0 : Call FSTA("AMZ2") From GLOCK : Break 2
            Endif
          Endif
        Endif
      Endif
    Next AMC1
  Endif
  [L]OLD_LAN=[ADZ1]LAN : [L]OLD_MOTCLE=[ADZ1]MOTCLE
 Next ADZ1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

#----------------------------------------------------------------#
Subprog HLPNUT(EPUR)
Value Integer EPUR
Local Char DOSX3(GLONADS)
Local Char    TIT(250) , MESSA(250)
Local Integer OK , OKEPU
Local File ADOCFLD [ADZ]
Local File ADOCFLD [AD7] Order By Key CLE2=LNKHLP

Local File AMOTCLE [AMC]
Local File ATABLE [ATB]
Local File AMSK [AMK]
Local File ACLASSE [ACLA]
Local File ASHW [ASW]
Local Integer WMODULE

Call PARAM("","SUPDOS",DOSX3) From ADOVAL
If DOSX3="" : DOSX3 = nomap : Endif
Local File =DOSX3+".ADOCFLD" [AD8] Order By Key CLE3=LNKHLP

If EPUR
 TIT = mess(225,139,1) : # Epuration des aides sur champs
Else
 #TIT -= mess(133,139,1) : # Aides non utilisées dans les écrans
 TIT -= mess(295,139,1) : # Aides non utilisées
Endif

#JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Global Integer ALLCREGRP
Call OUINON(TIT+"\"+mess(112,176,1),[V]ALLCREGRP) From GESECRAN : # Action à lancer pour tous les groupes ?

If EPUR
 Call AVERTIR(TIT+"\"+mess(205,100,1),OK) From GESECRAN : # Voulez-vous continuer ?
 If OK<>2 : End : Endif
Endif
Call OUVRE_TRACE(TIT) From LECFIC
Call TEMPON(TIT) From GESECRAN
GOK = 1

Trbegin [ADZ]
 For [ADZ]
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If func AGENLIBA.TEST_GROUPE_OK("ADZ", [ADZ]LAN, "", [ADZ]MOTCLE, "[V]ALLCREGRP")
    OKEPU = 0
    MESSA = ""
    Filter [AMC] Where ([F:AMC]MOTCLE=[F:ADZ]MOTCLE | [F:AMC]INFBUL=[F:ADZ]MOTCLE)
    Look [AMC] First
    If fstat
      Look [AD7]CLE2 = [F:ADZ]MOTCLE
      If fstat
        Look [AD8]CLE3 = [F:ADZ]MOTCLE
        If fstat
          MESSA = [F:ADZ]MOTCLE-"("+[F:ADZ]LAN+")"-":"-mess(226,139,1) : # Mot-clé non utilisé
          OKEPU = 1
        Endif
      Endif
    Elsif [F:ADZ]GEN<>2
      For [AMC]
        Case [F:AMC]TYPZON
          When 1 : Read [ATB]CODFIC=[F:AMC]IDENT1
          When 2 : Read [AMK]CODMSK=[F:AMC]IDENT1
          When 3 : Read [ACLA]ACLA0=[F:AMC]IDENT1
          When 4 : Read [ASW]ASW0=[F:AMC]IDENT1
        Endcase
        If !fstat
          Case [F:AMC]TYPZON
            When 1 : WMODULE= [F:ATB]MODULE
            When 2 : WMODULE= [F:AMK]MODULE
            When 3 : WMODULE= [F:ACLA]MODULE
            When 4 : WMODULE= [F:ASW]ASW0=MODULE
          Endcase
          If [F:ADZ]MODULE<>WMODULE
            # Module incorrect
            MESSA = [F:ADZ]MOTCLE-"("+[F:ADZ]LAN+")"-":"-mess(132,124,1)-"("+mess([F:ADZ]MODULE,14,1)+")"
            # Ecran
            MESSA += "-> AMOTCLE"-mess(259,125,1)-mess([F:AMC]TYPZON,7985,1)-[F:AMC]IDENT1-"("+mess(WMODULE,14,1)+")"
            Break
          Endif
        Endif
      Next AMC
    Endif
    Filter [AMC]
    If MESSA<>""
      If !EPUR
        Call ECR_TRACE(MESSA,1) From GESECRAN
      Elsif EPUR & OKEPU
        Call ECR_TRACE(MESSA,0) From GESECRAN
        Delete [ADZ] Curr
        If fstat
          GOK=-1 : Call RSTA("ADZ",[F:ADZ]MOTCLE-[F:ADZ]LAN) From GLOCK : Break
        Endif
      Endif
    Endif
  Endif
 Next ADZ
If GOK<1
 Rollback
Else
 Commit
Endif
#JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
If dim([V]ALLCREGRP)>0 : Kill [V]ALLCREGRP : Endif

Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------------------------#
Subprog HLPABS
Local Char    TIT(250) , MESSA(250)
Local Char DOSX3(GLONADS)
Call PARAM("","SUPDOS",DOSX3) From ADOVAL
If DOSX3="" : DOSX3 = nomap : Endif
Local File =DOSX3+".ADOCFLD" [AD8]
Local File ADOCFLD [ADZ]
Local File AMSKZON [AMZ]
Local File AMOTCLE [AMC]

TIT = mess(135,139,1) : # Aides manquantes dans les écrans
Call OUVRE_TRACE(TIT) From LECFIC
Call TEMPON(TIT) From GESECRAN

Link [AMZ] With [AMC]AMC0=2;[F:AMZ]CODMSK;[F:AMZ]CODZON As [AZZ]

For [AZZ] Where [F:AMZ]SAIAFF=1 & [F:AMZ]CODTYP<>"ABS" & left$([F:AMZ]CODMSK,1)<>"W"
 MESSA = mess(50,139,1)-[F:AMZ]CODMSK-mess(17,115,1)-[F:AMZ]CODZON : # Ecran
 If [F:AMC]MOTCLE="DUMMY"
  MESSA -= "--->"-"DUMMY"
  Call ECR_TRACE(MESSA,-1) From GESECRAN
 Elsif [F:AMC]MOTCLE<>""
  Look [ADZ]ADZ1(1) = [F:AMC]MOTCLE
  If fstat
   Look [AD8]ADZ1(1) = [F:AMC]MOTCLE
   If fstat
    MESSA -= "--->"-[F:AMC]MOTCLE-":"-mess(136,139,1) : # Mot-clé inexistant
    Call ECR_TRACE(MESSA,1) From GESECRAN
   Endif
  Endif
 Else
  MESSA -= "--->"-mess(137,139,1) : # Mot-clé absent
  Call ECR_TRACE(MESSA,1) From GESECRAN
 Endif
Next AMZ
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------------------------#
Subprog C_MOTCLE(VALEUR)
Variable Char VALEUR
Local Integer OK , SUP
#JPGA 08/12/2011 BUG-78456 : Avertissement si Création/Duplication d'un Motclé qui existe déjà dans une autre langue
Call CONTROLE_DEJA_EXISTANT([M]LAN, VALEUR)

SUP = (GPRODUIT=-1)
If GADONIX<>2 : End : Endif
Look [ADZ]ADZ1(1) = VALEUR
If fstat
 If SUP & left$(VALEUR,1)<>"A"
  Call AVERTIR("L'aide Superviseur doit commencer par la lettre A\Continuer ?",OK) From GESECRAN
  If OK<>2 : mkstat = 2 : End : Endif
 Elsif !SUP
  If left$(VALEUR,1)="A"
   Call AVERTIR("L'aide d'un Produit ne doit pas commencer par la lettre A\Continuer ?",OK) From GESECRAN
   If OK<>2 : mkstat = 2 : End : Endif
  Elsif left$(VALEUR,1)>="X"
   Call AVERTIR("Les mot-clés d'aides commençant par X Y ou sont réservés pour le spécifique\Continuer ?",OK)
&  From GESECRAN
   If OK<>2 : mkstat = 2 : End : Endif
  Endif
 Endif
Endif
End

Subprog CONTROLE_DEJA_EXISTANT(WLAN,WMOTCLE)
Value Char WLAN, WMOTCLE
Local Char WLANGUES(100)
# En Création ou en Modification : On vérifie qu'un motclé n'existe pas dans une autre langue : Avertissement.
# JPGA 18/01/2012 BUG-79383 : Amelioration du Controle en Création/Duplication d'un Motclé qui existe déjà dans une autre langue
# If find(GREP,"C","D")
Look [ADZ] ADZ0=WLAN;WMOTCLE
If fstat
  [L]WLANGUES=""
  For [ADZ]ADZ1 Where MOTCLE=WMOTCLE
    [L]WLANGUES+=string$([L]WLANGUES<>"",", ")+[ADZ]LAN
  Next
  If [L]WLANGUES<>""
     GBIDI1=1 : Call AVERTIR(func AFNC.MES1 (mess(99,176,1), [L]WLANGUES),GBIDI1) From GESECRAN
     # ATTENTION : La génération ADOCUMENT va être lancée pour plus d'un objet. Voulez vous continuer ?
     If GBIDI1<>2
        mkstat = 2
     Endif
  Endif
Endif
End

Subprog C_MODULE(VALEUR)
Variable Integer VALEUR
Look [ADZ]ADZ0 = [M]LAN;[M]MOTCLE
If !fstat : mkstat = 4 : Endif
End

Subprog AM_TEXTE(VALEUR)
Variable Clbfile VALEUR
Local Char TEXTE1(80)(1..10000)
Local Integer IMOD
Call MAJ_LIENS(VALEUR,"FLD","FLD",GERR,GMESSAGE,TEXTE1,IMOD) From AGENDOCA
If IMOD
 Setlob [M]TEXTE With TEXTE1(1..10000)
Endif
End

Subprog C_LNKHLP(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [ADZ]ADZ0=GLANGUE;VALEUR
 If fstat or [F:ADZ]GEN<>2
  GMESSAGE = mess(157,139,1) : # Aide non générique
  mkstat = 1 : End
 Endif
Endif
[M]LNKHLP = VALEUR
Gosub GRISE_LNK
End

Subprog C_GEN(VALEUR)
Variable Integer VALEUR
[M]GEN = VALEUR
Gosub GRISE_GEN
End
