#<AdxTL>@(#)0.0.0.0 $Revision$
Run FUNSADJ
End

##############################################################
#UPD_ALC : régularisation des mouvements valorisés au PMP
##############################################################
$UPD_ALC
    #---- Boucle sur tous les mouvements -----#
    Filter [SJL] Where ITMREF=LITM
&                    & LOT = LLOT & SLO=LSLO
&                     & (IPTDAT > LIPT
&                       | (IPTDAT = LIPT
&                         & ( CREMVTDAT > LDAT
&                           | ( CREMVTDAT = LDAT
&                             & ( CREMVTTIM > LTIM
&                               | ( CREMVTTIM = LTIM
&                                 & (CREMVTSEQ>LCRESEQ
&                                   | CREMVTSEQ=LCRESEQ
&                                   & ( MVTSEQ<LSEQ
&                                     | ( MVTSEQ=LSEQ
&                                       & ( MVTIND<LMVTIND
&                                         | ( MVTIND=LMVTIND
&                                           & STOFCY>=LFCY
&                                           )
&                                         )
&                                       )
&                                     )
&                                   )
&                                 )
&                               )
&                             )
&                           )
&                         &  MVTSEQ >= LMINSEQ
&                         )
&                       )
# Issue 81750 - 2012-04-24 by CCC
# Les variable LITM, LFCY, LDAT... contiennent les informations du 1er mvt à régulariser
# Il peut s'agir du mvt déclencheur s'il s'agit d'une sortie => pas de filtre sur [SMA]
#&                                   & (VCRTYP<>[F:SMA]VCRTYP | VCRNUM<>[F:SMA]VCRNUM | VCRLIN<>[F:SMA]VCRLIN)
        Raz [F:SJL]
        Read [SJL]SJL0 First
        Gosub READ_STJ2
        LSTOP=0
        While !fstat & GOK

            If [F:STJ2]STOFCY<>LFCY
                Gosub SETRND From FUNSADJB
            Endif

            #--- Indice du site en cours ----#
            LINDFCY = find([F:STJ2]STOFCY,LTABFCY)-1
            If LINDFCY<0
                Call GETSOC([F:STJ2]STOFCY) From DEVSUB
                If [F:STJ2]TRSTYP=14
                    Look [SRW]SRW0=[F:STJ2]VCRNUM;[F:STJ2]VCRLIN;[F:STJ2]VCRTYP;0;GSOCIETE;[F:STJ2]ITMREF;[F:STJ2]LOT;[F:STJ2]SLO
                Else
                    Look [SRW]SRW0=[F:STJ2]VCRNUMORI;[F:STJ2]VCRLINORI;[F:STJ2]VCRTYPORI;0;GSOCIETE;[F:STJ2]ITMREF;[F:STJ2]LOT;[F:STJ2]SLO
                Endif
                If !fstat
                    LINDFCY = find("",LTABFCY)-1
                    If LINDFCY<0
                        GOK=0
                        Call ECRTRACE("LINDFCY=-1"-"dim(LTABFCY)="+num$(dim(LTABFCY)),1) From FUNSADJB
                        Break
                    Endif
                    # On va traiter un nouveau site => il faut calculer le pmp qu'il y avait juste avant le document
                    LTABFCY(LINDFCY)=[F:STJ2]STOFCY
                    GPE=0
                    GPOINT = "DETSTJTRS" : Gosub ENTREE From EXEFNC
                    If GPE=0
                        Call GETALC([F:STJ2]ITMREF,[F:STJ2]STOFCY,[F:STJ2]LOT,[F:STJ2]SLO,[F:STJ2]IPTDAT,[F:STJ2]CREMVTDAT,[F:STJ2]CREMVTTIM,[F:STJ2]CREMVTSEQ,
&                                   LNUMVLT, "",  LTABQTYACT(LINDFCY), LTABAMT(LINDFCY)) From FUNSADJC
                        Call CALVALDOCLOT([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ2]LOT,[F:STJ2]SLO,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN, [F:STJ2]CREMVTSEQ,
&                                   LNUMVLT, "O", LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN) From FUNSADJC
                        LTABQTYACT(LINDFCY) -= LQTYLINACT
                        # Issue 83388 - 2012-08-06 by CCC
                        #LTABAMT(LINDFCY,0) -= LAMTLIN
                        For I=0 To dim(LDELTA)-1
                            # Issue 82464 - 2012-06-07 by CCC : màj base montant
                            LTABAMT(LINDFCY,I) -= LAMTLIN(I)
                        Next
                    Elsif GPE=2
                        # LTABQTYACT(LINDFCY) et LTABAMT(LINDFCY) sont alimentées dans le PE
                    Endif
                    Call TEXTE(24104,LMES) From OBJDIV
                    LMES-= mess([F:STJ2]VCRTYP,701,1)-[F:STJ2]VCRNUM-mess(61,100,1)-num$([F:STJ2]VCRLIN)
                    Call ECRTRACE( LMES, GOK<=0) From FUNSADJB
                    Call TEXTE (1990,LTXT) From OBJDIV
                    LMES = LTXT-num$(LTABQTYACT(LINDFCY))
                    Call TEXTE (1991,LTXT) From OBJDIV
                    LMES -= ";"-LTXT-num$(LTABAMT(LINDFCY,0))
                    Call ECRTRACE( LMES, GOK<=0) From FUNSADJB
                Else
                    # Le site n'existe pas dans LTABFCY et le mouvement d'origine n'a pas été traité ou ce n'est pas de l'inter-sites
                    # => on passe au mouvement suivant
                    Goto NEXT_STJ2
                Endif
            Elsif [F:STJ2]MVTSEQ<LSEQFCY(find([F:STJ2]STOFCY,LITFFCY)-1)
                    Goto NEXT_STJ2
            Endif

            #---- Si le mouvement est une sortie ----#
            Raz LDELTA, LDEVLIN, LAMTLIN, LQTYLIN, LQTYLINACT
            # Il faut bien tester que le prinat=PMP car il peut arriver que ce ne soit pas le cas
            # Issue 66578 - 2010-08-18 by CCC : la régul doit aussi se faire su la 2ème méthode de valo si elle est au PMP
            If (LNUMVLT=0 & [F:STJ2]PRINAT=7 | LNUMVLT=1 & [F:STJ2]PRINAT2=7)
&            & ( find(func STKLIB.SENSTRS([F:STJ2]TRSTYP),2,-1)
&              | func STKLIB.SENSTRS([F:STJ2]TRSTYP)=3 & [F:STJ2]ACTQTY<0
&              | [F:STJ2]TRSTYP=13 )
                LNB += func FUNSADJB.ISSADJ2(LTABQTYACT(LINDFCY),LTABAMT(LINDFCY),LTABAVC(LINDFCY),LAMTRND,LPRIRND,LNUMVLT,"L",LQTYLINACT,LAMTLIN,LDELTA,LDEVLIN)
                If !GOK : Break : Endif
                LSUMVARISS += LDELTA(0)
                LSUMVARDEV += LDEVLIN(0)

# Issue 81476 - 2012-08-06 by CCC : régul d'entrée assemblage déjà effectuée dans ISSADJ

            #---- Cas de l'entrée inter-site ----#
            # Issue 83992 - 2012-08-10 by CCC
            Elsif !([F:STJ2]TRSTYP=8 & !find([F:STJ2]PRINAT,8,7))
&               & (find(func STKLIB.SENSTRS([F:STJ2]TRSTYP),1,-2)
&                 | func STKLIB.SENSTRS([F:STJ2]TRSTYP)=3 & [F:STJ2]ACTQTY>0)
                LNB += func FUNSADJB.RCPADJ2(LTABQTYACT(LINDFCY),LTABAMT(LINDFCY),LTABAVC(LINDFCY),LAMTRND,LPRIRND,LNUMVLT,"L",LQTYLINACT,LAMTLIN,LDELTA,LDEVLIN)
                LSUMVARRCP += LDELTA(0)
                LSUMVARDEV += LDEVLIN(0)
            #Elsif [F:STJ2]TRSTYP=23 & [F:STJ2]PRINAT=7 & LNUMVLT=0         # 112688/116166.o
            Elsif [F:STJ2]TRSTYP=23 & find([F:STJ2]PRINAT,1,7) & LNUMVLT=0  # 112688/116166.n - Changed PRINAT to 1 for Value Change
                Gosub CHGVALADJ
# Ne pas faire LSTOP=1 car si la régul provient d'une modif de quantité le PMP est modifié pour les mouvements suivants...
# LSTOP = 1
            # Issue 83992 - 2012-08-10 by CCC
            Elsif [F:STJ2]TRSTYP=8
                Raz LRCPDEV # la valeur n'est pas utilisée mais elle est obligatoire pour l'appel de CALVALDOC2
                #---- Récupération des valeurs de la ligne de doc pour la date ----#
                Call CALVALDOCLOT2([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ2]LOT,[F:STJ2]SLO,[F:STJ2]IPTDAT,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN,
&                               [F:STJ2]CREMVTSEQ, LNUMVLT, "O", LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN,LRCPDEV) From FUNSADJC
                For I=1 To LNBMVT-1
                    Read [SJL]SJL0 Next
                Next
                Gosub READ_STJ2
            Else
                #---- Récupération des valeurs de la ligne de doc ----#
                Call CALVALDOCLOT([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ2]LOT,[F:STJ2]SLO,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN, [F:STJ2]CREMVTSEQ,
&                                 LNUMVLT, "O", LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN) From FUNSADJC
                For I=1 To LNBMVT-1
                    Read [SJL]SJL0 Next
                Next
                #Read [STJ2]STJ0=[F:SJL]STOFCY;[F:SJL]UPDCOD;[F:SJL]ITMREF;[F:SJL]IPTDAT;[F:SJL]MVTSEQ;[F:SJL]MVTIND
                Gosub READ_STJ2
            Endif
            If !GOK
                Break
            Endif

            # Suppression d'un éventuel SMA qui ne servira plus puisque la régul sur cette ligne de doc a été faite
            Delete [SMA] Where [F:SMA]STOFCY=[F:STJ2]STOFCY
&                            & [F:SMA]ITMREF=[F:STJ2]ITMREF
&                            & [F:SMA]VCRTYP=[F:STJ2]VCRTYP
&                            & [F:SMA]VCRNUM=[F:STJ2]VCRNUM
&                            & [F:SMA]VCRLIN=[F:STJ2]VCRLIN
&                            & [F:SMA]NUM<>LSMANUM
&                            & [F:SMA]LOT=[F:STJ2]LOT
&                            & [F:SMA]SLO=[F:STJ2]SLO

            LFCY=[F:STJ2]STOFCY
            LIPT=[F:STJ2]IPTDAT
            LDAT=[F:STJ2]CREMVTDAT
            LTIM=[F:STJ2]CREMVTTIM
            LCRESEQ=[F:STJ2]CREMVTSEQ
            Call ECRTRACE("LDELTA="+num$(LDELTA(0))-"LSUMVARISS="+num$(LSUMVARISS)-"LSUMVARRCP="+num$(LSUMVARRCP),0)  From FUNSADJB
            If GACTDECCST    # Issue 106399 - 2015-03-18 by CCC : detailed cost testing
                Call ECRTRACE("LDELTAd="+num$(sum(LDELTA(1..dim(LDELTA)-1))),0)  From FUNSADJB
            Endif
#            Call ECRTRACE("LTABQTYACT("+num$(LINDFCY)+")="+num$(LTABQTYACT(LINDFCY))-"LQTYLINACT="+num$(LQTYLINACT),0) From FUNSADJB
#            Call ECRTRACE("LTABAMT("+num$(LINDFCY)+")="+num$(LTABAMT(LINDFCY))-"LAMTLIN="+num$(LAMTLIN(0)),0) From FUNSADJB
            GBIDD1 = LTABQTYACT(LINDFCY)
            GBIDD2 = LTABAMT   (LINDFCY,0)
            GBIDD3=sigma(1,dim(LTABAMT,2)-1,LTABAMT(LINDFCY,indcum))
            LTABQTYACT(LINDFCY) += LQTYLINACT
            For I=0 To dim(LTABAMT,2)-1
                LTABAMT(LINDFCY,I) = arr(LTABAMT(LINDFCY,I)+LAMTLIN(I),LAMTRND)
# Issue 99565 - 2014-04-22 by CCC : AUC rounding
#                If LTABQTYACT(LINDFCY)>0
#&                & ( find(func STKLIB.SENSTRS([F:STJ2]TRSTYP),1,-2)
#&                  | func STKLIB.SENSTRS([F:STJ2]TRSTYP)=3 & [F:STJ2]ACTQTY>0
#&                  | LTABAMT(LINDFCY,I)>0 )
#                    LTABAVC(LINDFCY,I)  = arr(LTABAMT(LINDFCY,I)/LTABQTYACT(LINDFCY),LPRIRND)
#                Endif
            Next
            If LTABQTYACT(LINDFCY)>0
&            & ( find(func STKLIB.SENSTRS([F:STJ2]TRSTYP),1,-2)
&              | func STKLIB.SENSTRS([F:STJ2]TRSTYP)=3 & [F:STJ2]ACTQTY>0
&              | LTABAMT(LINDFCY,0)>0 )
                LTABAVC(LINDFCY,0)  = arr(LTABAMT(LINDFCY,0)/LTABQTYACT(LINDFCY),LPRIRND)
                If GACTDECCST    # Issue 106399 - 2015-03-18 by CCC : detailed cost testing
                    Call REPVAL(LTABAVC(LINDFCY,0),LTABAMT(LINDFCY,1..dim(LTABAMT,2)-1),LPRIRND,LTABAVC(LINDFCY,1..dim(LTABAVC,2)-1)) From STKVALECR
                Endif
            Endif

            Call ECRTRACE("--> LTABAMT("+num$(LINDFCY)+")="+num$(LTABAMT(LINDFCY,0))-"--> LTABQTYACT("+num$(LINDFCY)+")="+num$(LTABQTYACT(LINDFCY))-"LTABAVC="+num$(LTABAVC(LINDFCY,0)),0) From FUNSADJB
            Call ECRTRACE("--> LTABAMTd("+num$(LINDFCY)+")="+num$(sigma(1,dim(LTABAMT,2)-1,LTABAMT(LINDFCY,indcum)))-"LTABAVCd="+num$(sigma(1,dim(LTABAVC,2)-1,LTABAVC(LINDFCY,indcum)))
&                        , 0) From FUNSADJB
            Call ECRTRACE("TOTO;"+[F:STJ2]VCRNUM+";"+num$([F:STJ2]VCRLIN)+";"
&                        +num$(GBIDD1)+";"+num$(LQTYLINACT)+";"+num$(LTABQTYACT(LINDFCY))+";"
&                        +num$(GBIDD2)+";"+num$(LAMTLIN)+";"+num$(LTABAMT(LINDFCY,0))+";det=;"
&                        +num$(GBIDD3)+";"+num$(sum(LAMTLIN)-LAMTLIN(0))+";"+num$(sigma(1,dim(LTABAMT,2)-1,LTABAMT(LINDFCY,indcum)))
&                        ,0) From FUNSADJB

            Call ECRTRACEVAL("LTABAMT",LTABAMT(LINDFCY)) From FUNSADJB
            Call ECRTRACEVAL("LTABAVC",LTABAVC(LINDFCY)) From FUNSADJB

# Inutile en PM Lot
#            Call UPDTRS35([F:STJ2]ITMREF, [F:STJ2]STOFCY, [F:STJ2]VCRTYP, [F:STJ2]VCRNUM, [F:STJ2]VCRLIN, LNUMVLT, LTABAMT(LINDFCY), LTABAVC(LINDFCY))

# Issue 99565 - 2014-04-22 by CCC : AUC rounding & global/detail synchronization
            If GACTDECCST    # Issue 106399 - 2015-03-18 by CCC : detailed cost testing
                Call REPVAL(LTABAMT(LINDFCY,0),LTABAMT(LINDFCY,1..dim(LTABAMT,2)-1),LAMTRND,LTABAMT(LINDFCY,1..dim(LTABAMT,2)-1)) From STKVALECR
            Endif

            $NEXT_STJ2

            LSAVFCY = [F:STJ2]STOFCY
            LSAVTYP = [F:STJ2]VCRTYP
            LSAVNUM = [F:STJ2]VCRNUM
            LSAVLIN = [F:STJ2]VCRLIN
            LSAVSEQ = [F:STJ2]MVTSEQ

            If LSAVTYP=9
                Call ECRSRWLOT2([F:STJ2]STOFCY, [F:STJ2]ITMREF,[F:STJ2]LOT,[F:STJ2]SLO, [F:STJ2]VCRTYP, [F:STJ2]VCRNUM, [F:STJ2]VCRLIN, [F:STJ2]CREMVTSEQ, 0, 0) From FUNSADJC
            Endif

            Call ECRTRACE("Before read next STOFCY="-[F:STJ2]STOFCY-"UPDCOD="-num$([F:STJ2]UPDCOD)-"ITMREF="-[F:STJ2]ITMREF-"IPTDAT="-[F:STJ2]IPTDAT-"MVTSEQ="-num$([F:STJ2]MVTSEQ)-"MVTIND="
&                        -num$([F:STJ2]MVTIND),0) From FUNSADJB
            Read [SJL]SJL0 Next

            If !fstat
                # Issue 69384 - 2011-01-12 by CCC : Dans le cas des inventaires, mvtseq n'évolue pas pour plusieurs lignes d'un même inventaire
                # Il faut donc sauter les mouvements de régul qui viennent d'être créés les n° de lignes déjà régularisés sont stockés dans SRW
                If [F:SJL]VCRTYP=9
                    [L]LSJAOK = 0
                    While !fstat
                        [L]LSJAOK = 1
                        # Issue 71160 - 2011-01-31 by CCC
                        #Look [SRW]SRW0(3)=[F:SJL]VCRNUM;[F:SJL]VCRLIN;[F:SJL]VCRTYP
                        Look [F:SRW]SRW0(4)=[F:SJL]VCRNUM;[F:SJL]VCRLIN;[F:SJL]VCRTYP;[F:SJL]CREMVTSEQ
                        If !fstat
                            [L]LSJAOK = 0
                            Read [SJL]SJL0 Next
                        Endif
                    Wend
                    [G:SRW]currind=1
                    [G:SRW]currlen=0
                    If [L]LSJAOK
                        #Read [STJ2]STJ0=[F:SJL]STOFCY;[F:SJL]UPDCOD;[F:SJL]ITMREF;[F:SJL]IPTDAT;[F:SJL]MVTSEQ;[F:SJL]MVTIND
                        Gosub READ_STJ2
                    Endif
                Else
                    # CCC (2009-09-11) Bug 57756
                    # Comme les mouvements de transferts ont la même ligne de doc, il faut aussi vérifier MVTSEQ
                    While !fstat
&                       & ( [F:SJL]STOFCY=LSAVFCY & [F:SJL]VCRTYP=LSAVTYP & [F:SJL]VCRNUM=LSAVNUM & [F:SJL]VCRLIN=LSAVLIN & [F:SJL]MVTSEQ=LSAVSEQ
&                         | [F:SJL]IPTDAT=LIPT & [F:SJL]MVTSEQ<LSEQFCY(find([F:SJL]STOFCY,LITFFCY)-1))
                        Read [F:SJL]SJL0 Next
                    Wend
                    If !fstat
                        #Read [STJ2]STJ0=[F:SJL]STOFCY;[F:SJL]UPDCOD;[F:SJL]ITMREF;[F:SJL]IPTDAT;[F:SJL]MVTSEQ;[F:SJL]MVTIND
                        Gosub READ_STJ2
                    Endif
                Endif
            Endif

            Call ECRTRACE("After fstat="+num$(fstat)-"STOFCY="-[F:STJ2]STOFCY-"UPDCOD="-num$([F:STJ2]UPDCOD)-"ITMREF="-[F:STJ2]ITMREF-"IPTDAT="-[F:STJ2]IPTDAT-"MVTSEQ="-num$([F:STJ2]MVTSEQ)-"MVTIND="-
& num$([F:STJ2]MVTIND),0) From FUNSADJB
            If !fstat
                If [F:STJ2]IPTDAT<>LIPT    # Si on change de date d'imputation il faut recalculer LSEQFCY
                    LSTOP = -2             # ... et on part de cet enregistrement lors du redéclenchement de la boucle sur STJ2
                    Break
                Endif
                If LNB>GMAXUPDTRS
                    LSTOP = -1
                    Break
                Endif
            Endif
        Wend
        Filter [SJL]

        #---- Mise à jour de l'historique si nécessaire ----#
        If GOK & (LSUMVARISS<>0 | LSUMVARRCP<>0 | LSUMVARDEV<>0)
#
            Call UPDITH(LNUMVLT,LITM,LFCY,LIPT,LSUMVARRCP,LSUMVARISS,LSUMVARDEV) From FUNSADJB
            LNB += 1
        Endif
        LFCY=[F:STJ2]STOFCY
        LIPT=[F:STJ2]IPTDAT
        LDAT=[F:STJ2]CREMVTDAT
        LTIM=[F:STJ2]CREMVTTIM
        LCRESEQ=[F:STJ2]CREMVTSEQ
        LSEQ=[F:STJ2]MVTSEQ
        LMVTIND=[F:STJ2]MVTIND

        If LSTOP=-1 : Return : Endif

        If LSTOP<0
            Return
        Endif
        If GOK

            # Issue 112077 - 2017-01-25 by ERMIL : Use correct value for GRNDVAL to reduce rounding errors
            Local Decimal RNDVAL_SAV
            RNDVAL_SAV = GRNDVAL
            Call INIRNDVAL("STOLOTFCY","AVC") From STKVALECR

            For [SLF] Where ITMREF=[F:STJ2]ITMREF
&                         & find(STOFCY,LTABFCY)
&                         & LOT=[F:STJ2]LOT
&                         & SLO=[F:STJ2]SLO

                Call ECRTRACE("Update STOLOFCY:"+[F:SLF]ITMREF-[F:SLF]STOFCY,0) From FUNSADJB
                Call ECRTRACE("[F:SLF]AVCBASAMT="+num$([F:SLF]AVCBASAMT),0) From FUNSADJB
                Call ECRTRACE("[F:SLF]AVCBASQTY="+num$([F:SLF]AVCBASQTY),0) From FUNSADJB
                Call ECRTRACE("[F:SLF]AVC="+num$([F:SLF]AVC),0) From FUNSADJB
                LINDFCY = find([F:SLF]STOFCY,LTABFCY)-1
                [F:SLF]AVCBASAMT = LTABAMT(LINDFCY,0)
                If [F:SLF]AVCBASQTY<>0
                    #[F:SLF]AVC = arr([F:SLF]AVCBASAMT / [F:SLF]AVCBASQTY,LPRIRND) # 112077.o
                    [F:SLF]AVC = arr([F:SLF]AVCBASAMT / [F:SLF]AVCBASQTY,GRNDVAL)  # 112077.n
                Else
                    [F:SLF]AVC = LTABAVC(LINDFCY,0)
                Endif
                If GACTDECCST
                    Call LOADFIC("[F:SLF]",LTABAMT(LINDFCY),"A","CST",1,0) From STKVALECR
                    Call LOADFIC("[F:SLF]",LTABAVC(LINDFCY),"A","AVC",1,0) From STKVALECR
                Endif
                Rewrite [SLF]
                If fstat
                    Call RSTA("SLF",[F:SLF]ITMREF+";"+[F:SLF]STOFCY) From GLOCK
                    GOK = 0
                    Break
                Endif
                Call ECRTRACE("--> [F:SLF]AVCBASAMT="+num$([F:SLF]AVCBASAMT),0) From FUNSADJB
                Call ECRTRACE("--> [F:SLF]AVC="+num$([F:SLF]AVC),0) From FUNSADJB
            Next

            # Issue 112077 - 2017-01-25 by ERMIL : Reset GRNDVAL to previous value
            GRNDVAL = RNDVAL_SAV

        Endif
Return



###############################################################
# Met à jour (si nécessaire) le montant non absorbé de la ligne de doc
###############################################################
$UPD_ALCDEV
    #---- Récupération du PMP après ligne de doc en cours ----#
    # Point d'entrée premettant de déterminer le 1er mouvement de référence et les actions à suivre
    # GPE = 0 : on veut recalculer le PMP jusqu'au mouvement dans [STJ2]
    #       1 : on veut recalculer le PMP à partir du mouvement dans [STJ2]
    #       2 : le PMP (LTABQTYACT et LTABAMT) est alimenté dans le PE et le mouvement en cours [STJ2] n'a pas besoin d'être régularisé
    Raz GPE
    GPOINT = "DETSTJ"
    Gosub ENTREE From EXEFNC
    If GPE<>2
        LSENS = func STKLIB.SENSTRS([F:STJ2]TRSTYP)
        #If [F:SMA]VCRTYP=30 & [F:STJ2]PRINAT=7           # 112688/116166.o
        If [F:SMA]VCRTYP=30 & find([F:STJ2]PRINAT,1,7)    # 112688/116166.n - Changed PRINAT to 1 for Value Change
            Call GETALC([F:STJ2]ITMREF,[F:SMA]STOFCY,[F:STJ2]LOT,[F:STJ2]SLO,[F:STJ2]IPTDAT,[F:STJ2]CREMVTDAT,[F:STJ2]CREMVTTIM,[F:STJ2]CREMVTSEQ,LNUMVLT, "B", LTABQTYACT(0), LTABAMT(0)) From FUNSADJC
            Gosub CHGVALADJ
            # Issue 83091 - 2012-06-22 by CCC
            For I=0 To dim(LDELTA)-1
                # Issue 82464 - 2012-06-07 by CCC : màj base montant
                LTABAMT(LINDFCY,I) += LAMTLIN(I)
            Next
        Else
            # Issue 81750 - 2012-04-24 by CCC
            # Si c'est une sortie, il faut se positionner sur le document précédent pour qu'une régule soit faite sur cette sortie
            If find(LSENS,2,-1) | [F:STJ2]TRSTYP=14 & [F:STJ2]ACTQTY<0
                # 118579.c - No reason to read STJ for this filter - just use current STJ2 record
                #Filter [STJ] Where ITMREF=[F:SMA]ITMREF
                #Read [STJ]STJ1=[F:SMA]STOFCY;[F:SMA]VCRTYP;[F:SMA]VCRNUM;[F:SMA]VCRLIN
                #Filter [STJ]
                Filter [SJL]  Where STOFCY=[F:SMA]STOFCY
&                                 & ITMREF=[F:SMA]ITMREF
&                                 & LOT = [F:SMA]LOT
&                                 & SLO = [F:SMA]SLO
&                                 & ( IPTDAT  < [F:STJ2]IPTDAT
&                                   | (IPTDAT  = [F:STJ2]IPTDAT
&                                     & ( CREMVTDAT < [F:STJ2]CREMVTDAT
&                                       | ( CREMVTDAT = [F:STJ2]CREMVTDAT
&                                         & (CREMVTTIM < [F:STJ2]CREMVTTIM
&                                           | ( CREMVTTIM = [F:STJ2]CREMVTTIM
&                                             & CREMVTSEQ < [F:STJ2]CREMVTSEQ
&                                             )
&                                           )
&                                         )
&                                       )
&                                     )
&                                   )
                Read [SJL]SJL0 Last
                #Read [STJ2]STJ0=[F:SJL]STOFCY;[F:SJL]UPDCOD;[F:SJL]ITMREF;[F:SJL]IPTDAT;[F:SJL]MVTSEQ;[F:SJL]MVTIND
                Gosub READ_STJ2
                Filter [SJL]
            Endif
            If GPE=0
                Call GETALC([F:STJ2]ITMREF,[F:SMA]STOFCY,[F:STJ2]LOT,[F:STJ2]SLO,[F:STJ2]IPTDAT,
&                           [F:STJ2]CREMVTDAT,[F:STJ2]CREMVTTIM,[F:STJ2]CREMVTSEQ,LNUMVLT, "", LTABQTYACT(0), LTABAMT(0)) From FUNSADJC
            Else
                Call CALVALDOCLOT([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ2]LOT,[F:STJ2]SLO,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN,
&                                 [F:STJ2]CREMVTSEQ, LNUMVLT, "O", LNBMVT, LQTYLIN, LTABQTYACT(0), LTABAMT(0), LDEVLIN) From FUNSADJC
            Endif
            If find(LSENS,1,-2) | LSENS=3 & [F:STJ2]ACTQTY>0 | [F:SMA]VCRTYP=9     # Entrée
                #---- Met à jour le montant non absorbé de la ligne de doc en cours dans STJ2 ----#
                LNB += func FUNSADJB.MAJAMTDEV2(LTABQTYACT(0),LTABAMT(0), LAMTRND,LPRIRND, LDEVLIN, LNUMVLT, "L")
                If !GOK : Return : Endif

# Inutile en PM Lot
#                Call UPDTRS35([F:STJ2]ITMREF, [F:STJ2]STOFCY, [F:STJ2]VCRTYP, [F:STJ2]VCRNUM, [F:STJ2]VCRLIN, LNUMVLT, LTABAMT(0), LTABAVC(0))
                LSUMVARDEV += LDEVLIN
                LSUMVARRCP -= LDEVLIN
                #X3-42808 MJH.n Update PIT tables
                Call PITPRIADJ(LSUMVARRCP,LSUMVARISS,LSUMVARDEV) From STKPITLIB
                #---- Mise à jour de l'historique ----#
                Call UPDITH(LNUMVLT,[F:STJ2]ITMREF,[F:SMA]STOFCY,[F:STJ2]IPTDAT,LSUMVARRCP,LSUMVARISS,LSUMVARDEV) From FUNSADJB
            Endif
        Endif
    Endif

    # Si la qté calculée est négative on arrête la régul de cette ligne de doc
    # Attention, la composante des éléments de facturation peut très bien être négative (remise)
    #If LTABQTYACT(0)<0 | sigma(0,dim(LTABAMT,2)-1,LTABAMT(0,indcum)<0)
    If LTABQTYACT(0)<0 | LTABAMT(0,0)<0
        Call TEXTE (1990,LTXT) From OBJDIV
        LMES = LTXT-num$(LTABQTYACT(0))
        Call TEXTE (1991,LTXT) From OBJDIV
        LMES -= ";"-LTXT-num$(LTABAMT(0,0))-"/"-num$(sigma(1,dim(LTABAMT,2)-1,LTABAMT(0,indcum)))-"---"-sigma(0,dim(LTABAMT,2)-1,num$(LTABAMT(0,indcum))+";")
        Call ECRTRACE([F:STJ2]ITMREF+";"+[F:SMA]STOFCY+";"+num$([F:STJ2]IPTDAT)-LMES,1) From FUNSADJB
        GOK = 0 : LSTOP=1 : Return
    Else
        LIPT = [F:STJ2]IPTDAT
        LDAT = [F:STJ2]CREMVTDAT
        LTIM = [F:STJ2]CREMVTTIM
        LCRESEQ = [F:STJ2]CREMVTSEQ
        LITM = [F:STJ2]ITMREF
        LLOT = [F:STJ2]LOT
        LSLO = [F:STJ2]SLO
        LFCY = [F:STJ2]STOFCY
        LSEQ = [F:STJ2]MVTSEQ
        LMVTIND=[F:STJ2]MVTIND
        If LTABQTYACT(0)<>0
            For I=0 To dim(LTABAMT,2)-1
                LTABAVC(0,I)=arr(LTABAMT(0,I)/LTABQTYACT(0),LPRIRND)
            Next
        Endif
    Endif
    Call TEXTE(24104,LMES) From OBJDIV
    LMES-= mess([F:SMA]VCRTYP,701,1)-[F:SMA]VCRNUM-mess(61,100,1)-num$([F:SMA]VCRLIN)
    LMES-= "("+mess([F:SMA]VCRTYP,701,1)-[F:SMA]VCRNUM-mess(61,100,1)-num$([F:SMA]VCRLIN)+")"
    Call ECRTRACE( LMES, GOK<=0) From FUNSADJB
    Call TEXTE (1990,LTXT) From OBJDIV
    LMES = LTXT-num$(LTABQTYACT(0))
    Call TEXTE (1991,LTXT) From OBJDIV
    LMES -= ";"-LTXT-num$(LTABAMT(0,0))

    # Issue 99565 - 2014-04-22 by CCC : AUC rounding & global/detail synchronization
    If GACTDECCST    # Issue 106399 - 2015-03-18 by CCC : detailed cost testing
        Call REPVAL(LTABAMT(LINDFCY,0),LTABAMT(LINDFCY,1..dim(LTABAMT,2)-1),LAMTRND,LTABAMT(LINDFCY,1..dim(LTABAMT,2)-1)) From STKVALECR
        Call REPVAL(LTABAVC(LINDFCY,0),LTABAVC(LINDFCY,1..dim(LTABAVC,2)-1),LPRIRND,LTABAVC(LINDFCY,1..dim(LTABAVC,2)-1)) From STKVALECR
    Endif

    LMES -= ";pmp="-num$(LTABAVC(0,0))
    If GACTDECCST    # Issue 106399 - 2015-03-18 by CCC : detailed cost testing
        LMES -= ";det=;"+num$(sum(LTABAMT(0,1..dim(LTABAMT,2)-1)))
        LMES -= ";pmp det=;"+num$(sum(LTABAVC(0,1..dim(LTABAVC,2)-1)))
    Else
        LMES -= ";no detail"
    Endif
    Call ECRTRACE( LMES, GOK<=0) From FUNSADJB

    # il faut régulariser à partir du mvt suivant
        Columns [STJ2] (IPTDAT,STOFCY,CREMVTSEQ,CREMVTDAT,CREMVTTIM,MVTSEQ,MVTIND)
        Filter [STJ2] Where UPDCOD=2 & ITMREF=LITM
&                         & LOT = LLOT & SLO=LSLO
&                         & (IPTDAT > LIPT
&                           | (IPTDAT = LIPT
&                             & (CREMVTDAT > LDAT
&                               | ( CREMVTDAT = LDAT
&                                 & ( CREMVTTIM > LTIM
&                                   | ( CREMVTTIM = LTIM
&                                     & CREMVTSEQ>LCRESEQ
&                                     | ( CREMVTSEQ=LCRESEQ
&                                       & (VCRTYP<>[F:SMA]VCRTYP | VCRNUM<>[F:SMA]VCRNUM | VCRLIN<>[F:SMA]VCRLIN)
&                                       & ( MVTSEQ<LSEQ
&                                         | ( MVTSEQ=LSEQ
&                                           & ( MVTIND<LMVTIND
&                                             | ( MVTIND=LMVTIND
&                                               & STOFCY>LFCY
&                                               )
&                                             )
&                                           )
&                                         )
&                                       )
&                                     )
&                                   )
&                                 )
&                               )
&                             )
&                           )
&                     Order By IPTDAT Asc; CREMVTDAT Asc; CREMVTTIM Asc; CREMVTSEQ Asc; MVTSEQ Desc; MVTIND Desc; STOFCY
        Raz GBIDI1
        For [STJ2]
            GBIDI1=1
            LIPT = [F:STJ2]IPTDAT    # afin de récupérer le bon LSEQFCY ensuite
            LFCY=[F:STJ2]STOFCY
            LDAT=[F:STJ2]CREMVTDAT
            LTIM=[F:STJ2]CREMVTTIM
            LSEQ=[F:STJ2]MVTSEQ
            LMVTIND=[F:STJ2]MVTIND
            LCRESEQ=[F:STJ2]CREMVTSEQ
            Break
        Next
        If !GBIDI1
            LIPT+=1
        Endif
        Filter[STJ2]
        Columns [STJ2]
Return


$CHGVALADJ
    # Sur un changement de valeur on considère que c'est le PMP qui a été imposé
    # 118579.c - pass in the correct value for CREMVTSEQ (was passing 0 prior to change)
    Call CALVALDOC([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN,[F:STJ2]CREMVTSEQ, LNUMVLT, "O", LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN) From FUNSADJB
    # le delta de montant pour chaque composante se fait au prorata de chaque composante à date
    # C'est pour cela qu'on récupère la base montant avant chgt val
    # et que les calculs sont ensuite effectués à partir de cela

    For I=0 To dim(LDELTA)-1
        If LTABQTYACT(LINDFCY)=0 | LTABAMT(LINDFCY,0)=0
            LDELTA(I) = - LTABAMT(LINDFCY,I)-LAMTLIN(I)
        Else
            LDELTA(I) = arr([F:STJ2]PRIORD/(LTABAMT(LINDFCY,0)/LTABQTYACT(LINDFCY))*LTABAMT(LINDFCY,I)- LTABAMT(LINDFCY,I)-LAMTLIN(I),LAMTRND)
        Endif
    Next
    Raz LDEVLIN
    If sigma(1,dim(LDELTA)-1,abs(LDELTA(indcum)))<>0
        # On indique une sortie pour que le calcul des champs de valo se fasse même si la méthode n'est pas prix d'ordre
        LNB = func FUNSADJB.UPDSTJLIN([F:STJ2]STOFCY,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN,
&                                     2, LNBMVT, 0, LAMTLIN(0), LDELTA, LDEVLIN, 5, LNUMVLT, LAMTRND, LPRIRND)
    Endif
    For I=0 To dim(LDELTA)-1
        LAMTLIN(I) += LDELTA(I)
    Next
Return

$READ_STJ2
        Read [STJ2]STJ0=[F:SJL]STOFCY;[F:SJL]UPDCOD;[F:SJL]ITMREF;[F:SJL]IPTDAT;[F:SJL]MVTSEQ;[F:SJL]MVTIND
        If [F:STJ2]TRSTYP=35
            Filter [STJ] Where TRSTYP<>35
&                            & ITMREF=[F:STJ2]ITMREF
&                            & STOFCY=[F:STJ2]STOFCY
&                            & UPDCOD=2
&                            & VCRTYP=[F:STJ2]VCRTYP
&                            & VCRNUM=[F:STJ2]VCRNUM
&                            & VCRLIN=[F:STJ2]VCRLIN
            Read [STJ]reckey First
            Filter [STJ]
            [F:STJ2]TRSTYP=[F:STJ]TRSTYP
        Endif
Return


Subprog UPDTRS35(PITM, PFCY, PTYP, PNUM, PLIN, PNUMVLT, PQTYACT, PAMTFCY, PAVCFCY)
Value Char    PITM
Value Char    PFCY
Value Integer PTYP
Value Char    PNUM
Value Integer PLIN
Value Integer PNUMVLT
Value Decimal PQTYACT
Variable Decimal PAMTFCY()
Variable Decimal PAVCFCY()

Local Integer I, LRET
Local Decimal LMVTVAL(dim(PAMTFCY))
Local Decimal LDEV(2,dim(PAMTFCY))

# Issue 84744 - 2013-04-08 by CCC : Ne pas tenir compte des TRSTYP=35 sur coût standard
# Issue 71240 - 2012-04-04 by CCC : Suppression/annulation du mvt trstyp=35
    For [STJ] Where STOFCY = PFCY
&                    & ITMREF = PITM
&                    & VCRTYP = PTYP
&                    & VCRNUM = PNUM
&                    & VCRLIN = PLIN
&                    & REGFLG = 2
&                    & TRSTYP=35
&                    & !find(PRINAT,0,2,3)
        If [F:STJ]AGGIFAFLG=2
            If GACTDECCST
                Read [SJV]SJV0=[F:STJ]STOFCY;[F:STJ]UPDCOD;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
                Call LOADVAR(LMVTVAL,"[F:SJV]", 0, "O", -1, 0, 0) From STKVALECR
            Endif
            LMVTVAL(0) = -[F:STJ]AMTORD
            # Attention à l'ordre !!
            [F:STJ]AMTORD=-[F:STJ]AMTORD
            [F:STJ]VARORD=[F:STJ]AMTORD
            [F:STJ]AMTDEV=[F:STJ]AMTORD
            If GACTVLT2
                [F:STJ]AMTDEV2=[F:STJ]AMTORD
            Endif
            Raz [F:STJ]MVTSEQ, [F:STJ]MVTIND
            [F:STJ]AGGIFAFLG = 1
            [F:STJ]NUMVCR = ""
            [F:STJ]GTE = ""
            Raz [F:STJ]ACCDAT
            Raz [F:STJ]CREDAT, [F:STJ]CRETIM, [F:STJ]CREUSR, [F:STJ]UPDDAT, [F:STJ]UPDUSR
            Call ECRSTJ(0,LRET) From STKLIB
            If GACTDECCST
                [F:SJV]=[F:STJ]
                Call LOADFIC("[F:SJV]", LMVTVAL, "O", "CST", 1, 0) From STKVALECR
                [F:SJV]OMATTOT = sum([F:SJV]OMATCST)
                [F:SJV]OMACTOT = sum([F:SJV]OMACCST)
                [F:SJV]OLABTOT = sum([F:SJV]OLABCST)
                Call LOADFIC("[F:SJV]", LMVTVAL, "DO", "CST", 1, 0) From STKVALECR
                [F:SJV]DOMATTOT = sum([F:SJV]DOMATCST)
                [F:SJV]DOMACTOT = sum([F:SJV]DOMACCST)
                [F:SJV]DOLABTOT = sum([F:SJV]DOLABCST)
                Call LOADFIC("[F:SJV]", LMVTVAL, "DEV", "CST", 1, 0) From STKVALECR
                [F:SJV]CREDAT = date$
                [F:SJV]CREUSR = GUSER
                Raz [F:SJV]UPDDAT,[F:SJV]UPDUSR
                Write [SJV]
            Endif
        Else
            If GACTDECCST
                Delete [SJV]SJV0=[F:STJ]STOFCY;[F:STJ]UPDCOD;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
            Endif
            Delete [STJ] Curr
        Endif
    Next
# Issue 99880 - 2014-04-22 by CCC : TRSTYP=35 if QTY=0 but AMT<>0
#                                 AUC must not to be updated
#If PAMTFCY(0)<0
If PAMTFCY(0)*PQTYACT<0 | PQTYACT=0
    Filter [STJ] Where STOFCY = PFCY
&                    & ITMREF = PITM
&                    & VCRTYP = PTYP
&                    & VCRNUM = PNUM
&                    & VCRLIN = PLIN
&                    & TRSTYP<>35
    Read [STJ]STJ0 First
    Filter [STJ]
    For I=0 To dim(LDEV,2)-1
        LDEV(PNUMVLT,I) = -PAMTFCY(I)
        PAMTFCY(I) = 0
#        PAVCFCY(I) = 0
    Next
    Call ECRTRACE("UPDSTJDEV(LDEV,[F:STJ]MVTSEQ)",0) From FUNSADJB
    Call ECRTRACE("UPDSTJDEV("+num$(LDEV(PNUMVLT,0))+","+num$([F:STJ]MVTSEQ)+") "-mess([F:STJ]VCRTYP,701,1)-[F:STJ]VCRNUM,0) From FUNSADJB
    Call UPDSTJDEV(LDEV,PITM,PFCY,[F:STJ]IPTDAT,PTYP,PNUM,PLIN,[F:STJ]MVTSEQ) From STKVALMAJ
Endif
End

