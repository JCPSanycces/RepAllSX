######################################################################################
Subprog AS_TYPMAN(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=1
End

########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA

# Issue 119208 GH 23/03/2017 - init global variables for analytical dimensions
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
Return

##########################################################################
# pour les batchs
##########################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK)
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # dossier de lancement
Value    Char    USER      : # utilisateur
Variable Char    P1()(1..) : # on peut avoir 2 fois 50 chaînes de 15 caractères
Variable Char    P2()(1..)
Variable Integer OK

Gosub OUVRE

#
Local Char    WIN (GLONFEN)
WIN="DAUTMFG"
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT
End

##########################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

# GBE 19/08/10 mise en place de l'écran de sélection des OFs après la fenêtre des critères
$BOUTON
Case BOUT
    When "1" : Gosub TRT_OF_SEL : FIN=1
    When "2" : Gosub INCLUDE
    When "3" : Gosub EXCLUDE
Endcase
Return

$TRT_OF_SEL
# récupération compteur OF
Local Integer WOK
Call LECTCA(8,WOK) From SUBTCA
If WOK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
GCODNUM    = [F:TCA]CODNUM(0)   # compteur OF
GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations
If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("MAUTMFG","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

Gosub MAJ_OF_TRANSAC
If GNBOF
    Call ECR_TRACE(" ", 0) From GESECRAN
    WMESS1= num$(GNBOF)-mess(638,197,1)    # Mise(s) à niveau en série effectuée(s)
    Call ECR_TRACE(WMESS1, 0) From GESECRAN
Endif

# aucune mise à niveau effectuée
If !GNBOF & OK
     GERR = 2 : Call ECR_TRACE (mess(88,193,1),0) From GESECRAN
Endif

# fermeture trace
Call FERME_TRACE From LECFIC

# Sup. des globales perso
If dim (GRELITM)>0 : Kill GRELITM : Endif
If dim (GMFGLIN)>0 : Kill GMFGLIN : Endif
If dim (GUNUSE) >0 : Kill GUNUSE  : Endif
If dim (GNBOF) >0  : Kill GNBOF : Endif

Call LEC_TRACE From LECFIC

Return

$DEBUT
If !GSERVEUR
  Local Char    TIT(50) :  Call TEXTE(27229,TIT) From OBJDIV    # "Mise à niveau OF"
  Default Mask [MMF1]
  Gosub LIRE
  If [M:MMF1]NBLIG=0
      GERR=2 : GMESSAGE=mess(177,190,1)
      FIN=1
  Endif
Endif

Return

$LIRE
# Chargement du tableau d'OF en fonction des critères de sélection
Gosub SEL_OF

REP=""
Raz [M:MMF1]
nolign=0
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif
nolign = 0
[M:MMF1]MFGFCY = [M:DIA]MFGFCY

# FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM
&          As [MFX]
&          Where evalue(CRITERE1) & evalue(CRITERE2)& evalue(CRITERE3) & evalue(FORMULE1) & evalue(CUSFLT)
&                      Order By Key MFI0(1)

#For [F:MFG]
For [MFX]
  nolign += 1
  #If nolign = 500 : Break : Endif : # GH 08/10/2013
  If nolign = dim([M:MMF1]MFGNUM) : Break : Endif
# Issue X3-8001 - 2016-12-07 by CCC : If optimized WO => remove it from Production scheduler
#  [M:MMF1]MFGNUM(nolign-1)        = [F:MFG]MFGNUM
#  [M:MMF1]MFGSTA(nolign-1)        = [F:MFG]MFGSTA
#  [M:MMF1]STRDAT(nolign-1)        = [F:MFG]STRDAT
#  [M:MMF1]ROUNUM(nolign-1)        = [F:MFG]ROUNUM
#  [M:MMF1]ROUALT(nolign-1)        = [F:MFG]ROUALT
  [M:MMF1] = [F:MFG]
  [M:MMF1]FMODIF(nolign-1)        = 1
  [M:MMF1]BOMALT(nolign-1)        = [F:MFI]BOMALT
Next
#Filter [F:MFG]
[M:MMF1]NBLIG= nolign
Affzo [M:MMF1]
GMFGTRANSAC = 1
Return

#########################################################################
$INCLUDE
Local Integer I
Local Integer LINCOPTFLG # Flag to know if optimized WO have to be included

# Issue X3-8001 - 2016-12-07 by CCC : If optimized WO => Confirmation to remove it from Production scheduler
LINCOPTFLG=2
If find([M:DIA]TYPMAN,2,4) & (find(2,[M:MMF1]OPTFLG)>0 | find(4,[M:MMF1]SCDFLG)>0)
    LINCOPTFLG=1
    Call OUINON(mess(102,190,1),LINCOPTFLG) From GESECRAN
Endif
For I = 0 To [M:MMF1]NBLIG-1
    If ([M:MMF1]OPTFLG(I)<>2 & [M:MMF1]SCDFLG(I)<>4)
&    | LINCOPTFLG=2
        [M:MMF1]FMODIF(I) = 2
    Endif
Next
Affzo [M:MMF1]
Return

#########################################################################
$EXCLUDE
Local Integer I
For I = 0 To [M:MMF1]NBLIG-1
    [M:MMF1]FMODIF(I) = 1
Next
Affzo [M:MMF1]
Return

$FIN
#--- Sup. des globales perso
Return

#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête OF                            #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "MFG"+[F:MFG]MFGNUM
Lock = SYMBOLE With lockwait = 0
OK = 1
If fstat
    Call ECR_TRACE([F:MFG]MFGNUM - mess(10,100,1),1) From GESECRAN
    OK = 0
Endif
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entête OF                                 #
#-----------------------------------------------------------------------#
$DEVERROU
Unlock=SYMBOLE
Return

######################################################################################
## Section automatically added (screen MAUTMFG1) 12/06/2016 17:48:57 (CCC)
######################################################################################
Subprog C_FMODIF(VALEUR)
Variable Integer VALEUR
Local Integer LRET
# Issue X3-8001 - 2016-12-07 by CCC : If optimized WO => Confirmation to remove it from Production scheduler
If ([M:MMF1]OPTFLG(nolign-1)=2 | [M:MMF1]SCDFLG(nolign-1)=4) & VALEUR=2 & find([M:DIA]TYPMAN,2,4)
    LRET=1
    Call OUINON(mess(102,190,1),LRET) From GESECRAN
    If LRET=1
        VALEUR=1
        mkstat=2
        End
    Endif
Endif
End

