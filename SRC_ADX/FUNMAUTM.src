#<AdxTL>@(#)6.0.0.0 $Revision$
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTMAUTMFG  : Action mise à niveau OF                      #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
Endcase

# Actions liées à la saisie fenêtre uniquement en transactionnel
If !GSERVEUR
Case ACTION
 When "BOUTON"        : Gosub BOUTON
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "FIN"           : Gosub FIN
Endcase
Endif
Return

#########################################################################
$INIT
# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub OUVRE
Return

#########################################################################
$OUVRE
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Char     CRITERE3(255)
Local Char     FORMULE1(255)
Local Char     ERR_TRA(250)
Local Char     WTRT(30)
Local Char     WMFGNUM(GLONVCR)
Local Char     WITMREF(GLONITM)
Local Char     WFCY(GLONFCY)
Local Decimal  WALL, WSHT
Local Integer  WALLTYP
Local Integer  WRET
Local Integer  WLIG
Local Integer  WVISUGHOST
Local Integer  WMSG
Local Integer  WMFGLIN
Local Integer  WBOMSEQ
Local Integer  WOPENUM
Local Integer  WOPESPLNUM
Local Integer  STA : STA=0
Local Integer  STOP: STOP=0
Local Integer  WUNENVISAG_OPE : WUNENVISAG_OPE =0
Local Integer  WUNENVISAG_MAT : WUNENVISAG_MAT =0
Local Integer  WOPE
Local Integer  WOPE_UN
Local Integer  DOPENUM,DOPESPLNUM,DNEXOPENUM
Local Integer  WOPE_PROD
Local Integer  WLOAD, WJAL
Local Integer  I, J
Local Integer  MEMSTA
Local Integer  WDIFF, WTEST

# FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
Local Char     CUSFLT(255)

If dim (GRELITM)<0   : Global Char     GRELITM(GLONITM) : Endif
If dim (GOPECOUNT)<0 : Global Integer  GOPECOUNT : Endif
If dim (GMFGLIN)<0   : Global Integer  GMFGLIN : Endif
If dim (GUNUSE)<0    : Global Integer  GUNUSE : GUNUSE =0 : Endif     # en cas d'article non utilisable
If dim (GROOTEX)<0   : Global Char     GROOTEX(GLONTEX)(GMFOMAX) : Endif
If dim (GMFOTEX)<0   : Global Char     GMFOTEX(GLONTEX)(GMFOMAX) : Endif
If dim (GMFILIN)<0   : Global Integer  GMFILIN : GMFILIN = 0 : Endif    # 10.05 32621
# Variable globale qui va permettre de savoir si on a traité en transactionnel
If dim (GMFGTRANSAC)<0 : Global Integer  GMFGTRANSAC : GMFGTRANSAC = 0 : Endif
If dim (GNBOF)<0     : Global Integer  GNBOF : GNBOF = 0 : Endif

If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM      [MFI]  : Endif
If clalev([F:MFIW]) = 0 : Local File MFGITM      [MFIW] : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
If clalev([F:MFOW]) = 0 : Local File MFGOPE      [MFOW] : Endif
If clalev([F:BOH])  = 0 : Local File BOM         [BOH]  : Endif
If clalev([F:BOD])  = 0 : Local File BOMD        [BOD]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT      [ITV]  : Endif
If clalev([F:SRU])  = 0 : Local File TABSTORUL   [SRU]  : Endif
If clalev([F:MTS])  = 0 : Local File MFGTRS      [MTS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING  [SCH]  : Endif
If clalev([F:ROH])  = 0 : Local File ROUTING     [ROH]  : Endif
If clalev([F:ROO])  = 0 : Local File ROUOPE      [ROO]  : Endif
If clalev([F:ROOW]) = 0 : Local File ROUOPE      [ROOW] : Endif
If clalev([F:ROS])  = 0 : Local File ROUSCD      [ROS]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO  [MWS]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif

If clalev([F:TCA])  = 0 : Local File TABCOUAFF   [TCA]  : Endif
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:PJA])  = 0 : Local File PARJAL      [PJA]  : Endif
If clalev([F:CAL])  = 0 : Local File CPTANALIN   [CAL]  : Endif
If clalev([F:PTO])  = 0 : Local File PARMTO      [PTO]  : Endif
If clalev([F:MLK])  = 0 : Local File MTOLINK     [MLK]  : Endif

If clalev([M:MLIK]) = 0 : Local Mask MLIK        [MLIK] : Endif

# masques buffer
If clalev([M:MFGK]) = 0 : Local Mask MFGK        [MFGK] : Endif
If clalev([M:JALK]) = 0 : Local Mask JALK        [JALK] : Endif
If clalev([M:ORDK]) = 0 : Local Mask ORDK        [ORDK] : Endif
If clalev([M:MFGX]) = 0 : Local Mask MFG2        [MFGX] : Endif
If clalev([M:OPSC]) = 0 : Local Mask OPSC        [OPSC] : Endif
If clalev([M:OPSK]) = 0 : Local Mask OPSK        [OPSK] : Endif
 # Issue 97593 GH 24/09/2018
If clalev([F:AMZ])  = 0 : Local File AMSKZON    [AMZ]   : Endif
If clalev([M:MFIX]) = 0 : Local Mask MFG1       [MFIX]  : Endif

Gosub CHARG_PARAM
Return

#########################################################################
$INIT_DIA
# titre de la boîte
TIT = mess(250,195,1)
Raz [M:DIA]

[M:DIA]WOPFLG = 2
[M:DIA]MFGFCY = GFCY
Return

#########################################################################
$EXEC
# Issue 119208 GH 23/03/2017 - set right site variables for batch execution
If GSERVEUR
   GFCY = [M:DIA]MFGFCY
   Gosub CHARG_PARAM
Endif

If GMFGTRANSAC=0
  If !GSERVEUR
      TRA = 1
      Call OUVRE_TRACE(TIT) From LECFIC
      Call ECR_TRACE(" ",0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call PRTSCR("MAUTMFG","DIA","",0,1) From ATRTX3
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call ECR_TRACE(" ",0) From GESECRAN
  Endif
  # préparation des critères de filtre
  Gosub SEL_OF
  # traitement des OF
  Gosub TRT_OF
  If GNBOF
      Call ECR_TRACE(" ", 0) From GESECRAN
      WMESS1= num$(GNBOF)-mess(638,197,1)    # Mise(s) à niveau en série effectuée(s)
      Call ECR_TRACE(WMESS1, 0) From GESECRAN
  Endif
Endif

Return

#########################################################################
$TRT_OF

# récupération compteur OF
Local Integer WOK
Call LECTCA(8,WOK) From SUBTCA
If WOK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
GCODNUM    = [F:TCA]CODNUM(0)   # compteur OF
GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations

Gosub MAJ_OF

Return

#########################################################################
$TERMINE
If GMFGTRANSAC=0
  If !GSERVEUR
      # aucune mise à niveau effectuée
      If !GNBOF & OK
           GERR = 2 : Call ECR_TRACE(mess(88,193,1),0) From GESECRAN
      Endif
      # fermeture trace
      Call FERME_TRACE From LECFIC

      # Sup. des globales perso
      If dim (GRELITM)>0 : Kill GRELITM : Endif
      If dim (GMFGLIN)>0 : Kill GMFGLIN : Endif
      If dim (GUNUSE) >0 : Kill GUNUSE  : Endif
      If dim (GNBOF) >0  : Kill GNBOF : Endif

  Endif
Endif
If dim (GMFGTRANSAC) >0 : Kill GMFGTRANSAC  : Endif

Return

#########################################################################
$SEL_OF

# FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif

Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

If [M:DIA]WOPFLG = 2
    CRITERE  = "MFGSTA=2"
    Gosub LOAD_CRITERE
Endif

If [M:DIA]WOFFLG = 2
    CRITERE  = "MFGSTA=1"
    Gosub LOAD_CRITERE
Endif

# fin de la première partie
CRITERE1 += ")"

CRITERE  = "MFGFCY = [M:DIA]MFGFCY"                     # site de production
Gosub LOAD_CRITERE2

If [M:DIA]MFGNUMDEB <> ""                               # borne début OF
   CRITERE = "MFGNUM >= [M:DIA]MFGNUMDEB"
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]MFGNUMFIN <> ""                               # borne fin   OF
   CRITERE = "MFGNUM <= [M:DIA]MFGNUMFIN"
   Gosub LOAD_CRITERE2
Endif

If [M:DIA]STRDATDEB <> [0/0/0]
   CRITERE = "STRDAT >= [M:DIA]STRDATDEB"               # borne début date
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]STRDATFIN <> [0/0/0]
   CRITERE = "STRDAT <= [M:DIA]STRDATFIN"               # borne fin   date
   Gosub LOAD_CRITERE2
Endif

If [M:DIA]ROUALTDEB <> 0                                # borne début alternative
    CRITERE = "[F:MFG]ROUALT>=[M:DIA]ROUALTDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]ROUALTFIN <> 0                                # borne fin   alternative
    CRITERE = "[F:MFG]ROUALT<=[M:DIA]ROUALTFIN"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]ROUNUMDEB <> ""                               # borne début gamme
    CRITERE = "[F:MFG]ROUNUM>=[M:DIA]ROUNUMDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]ROUNUMFIN <> ""                               # borne fin   gamme
    CRITERE = "[F:MFG]ROUNUM<=[M:DIA]ROUNUMFIN"
    Gosub LOAD_CRITERE2
Endif


If [M:DIA]ITMREFDEB <> ""                               # borne début article lancé
    CRITERE = "[F:MFI]ITMREF>=[M:DIA]ITMREFDEB"
    Gosub LOAD_CRITERE3
Endif

If [M:DIA]ITMREFFIN <> ""                               # borne fin  article lancé
    CRITERE = "[F:MFI]ITMREF<=[M:DIA]ITMREFFIN"
    Gosub LOAD_CRITERE3
Endif

If [M:DIA]BOMALTDEB <> 0
    CRITERE= "[F:MFI]BOMALT>= [M:DIA]BOMALTDEB"         # borne début alt de nomenclature
 Gosub LOAD_CRITERE3
Endif

If [M:DIA]BOMALTFIN <> 0
    CRITERE= "[F:MFI]BOMALT<=[M:DIA]BOMALTFIN"          # borne fin alt de nomenclature
    Gosub LOAD_CRITERE3
Endif

# Issue X3-33113 - 2017-04-20 by ALSHE : Exclude optimized WO in FUNMAUTM
If func AFNC.ACTIV("POPS")                              # use production scheduler
    CRITERE = "[F:MFG]SCDFLG<>4 & [F:MFG]OPTFLG<>2"
    Gosub LOAD_CRITERE3
Endif

# fin de la troisième partie
If CRITERE3 <>""
    CRITERE3 += ")"
Endif

If CRITERE1 = "" : CRITERE1 ="1=1" : Endif
If CRITERE2 = "" : CRITERE2 ="1=1" : Endif
If CRITERE3 = "" : CRITERE3 ="1=1" : Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

Return

#########################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

############################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return

#########################################################################
$LOAD_CRITERE3
If len(CRITERE3)=0
    CRITERE3 += "("
Else
    CRITERE3 += "&"
Endif
CRITERE3 += CRITERE
Return


##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=10;[M:DIA]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return

#########################################################################
# traitement des ordres
$MAJ_OF

GNBOF = 0

# FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM
&          As [MFX]
&          Where evalue(CRITERE1) & evalue(CRITERE2)& evalue(CRITERE3) & evalue(FORMULE1) & evalue(CUSFLT)
&                      Order By Key MFI0(1)
For [MFX]
    # GH 08/10/2013 dm 91540
    #If [F:MFG]MFGTRKFLG >1 : Goto NXT_MFG : Endif  # on ne met à niveau que les oF en attente
    If [F:MFG]MFGTRKFLG > 3 : Goto NXT_MFG : Endif  # on ne met pas à niveau que les OF >= En cours
    GPE = ([F:MFG]MFGTRKFLG = 1)
    GPOINT = "CUSSELFLT2" : Gosub ENTREE From EXEFNC
    If !GPE : Goto NXT_MFG : Endif

    Raz [M:MFGK]
    STOP = 0
    GUNUSE = 0
    WVISUGHOST = 0
    WLOAD = 0
    WJAL  = 0
    [M:MFGK]MFGNUM  = [F:MFG]MFGNUM
    [M:MFGK]MFGFCY  = [F:MFG]MFGFCY
    [M:MFGK]MFGSTA  = [F:MFG]MFGSTA
    [M:MFGK]PRVQTY  = [F:MFG]EXTQTY
    [M:MFGK]EXTQTY  = [F:MFG]EXTQTY
    [M:MFGK]STRDAT  = [F:MFG]STRDAT
    [M:MFGK]ENDDAT  = [F:MFG]ENDDAT
    [M:MFGK]ROUNUM  = [F:MFG]ROUNUM
    [M:MFGK]ROUALT  = [F:MFG]ROUALT
    [M:MFGK]PIO     = [F:MFG]MFGPIO
    [M:MFGK]ITMREF  = [F:MFI]ITMREF
    GRELITM = [M:MFGK]ITMREF

    [M:MFGK]AUTOTRT = 2

    # Issue 119208 GH 23/03/2017 - Read MFGHEAD separate to be able for a Rewrite on MFG
    Read [MFG]MFG0=[F:MFI]MFGNUM

    # Ignorer les OF qui possèdent des éléments non prévus
    # mode de lancement OF  : complet ou matières seules
    # On recherche s'il existe une matière non prévue
    If find([F:MFG]MFGMOD,1,2) & [M:DIA]UNENVISAG=1
        For [MFM]MFM0 Where MFGNUM=[M:MFGK]MFGNUM
            If [F:MFM]BOMSEQ=0
                # l'OF posséde des éléments non prévus : ignoré
                WMESS1 =mess(156,197,1)-[F:MFM]MFGNUM-mess(250,193,1)
                Call ECR_TRACE( WMESS1 ,0) From GESECRAN
                STOP = 1  : Break
            Endif
        Next
    Endif
    If STOP = 1 :  Goto NXT_MFG  : Endif

    # mode de lancement OF  : complet ou opérations seules
    # On recherche s'il existe une ope non prévue ou commandée (sous-traitance)
    If find([F:MFG]MFGMOD,1,3) & ([M:DIA]UNENVISAG=1 | find([M:DIA]TYPMAN,2,4))
        For [MFO]MFO0 Where MFGNUM=[M:MFGK]MFGNUM
            If [F:MFO]ROUOPENUM=0 & [M:DIA]UNENVISAG=1
                # l'OF possède des éléments non prévus : ignoré
                WMESS1 =mess(156,197,1)-[F:MFO]MFGNUM-mess(250,193,1)
                Call ECR_TRACE( WMESS1 ,0) From GESECRAN
                STOP = 1  : Break
            # Issue 115619 - 2016-05-26 by GH : not consider WO with ordered operations
            Elsif [F:MFO]OPESTA=7 & find([M:DIA]TYPMAN,2,4)
                # Operation status x = Ordered
                 WMESS1 =mess(156,197,1)-[F:MFO]MFGNUM-":"-mess(108,200,1)-num$([F:MFO]OPENUM)-"="-mess(7,308,1)-"->"-mess(1215,9900,1)
                Call ECR_TRACE( WMESS1 ,0) From GESECRAN
                STOP = 1  : Break
            Endif
        Next
    Endif
    If STOP = 1 :  Goto NXT_MFG : Endif

    Gosub TRTMAN
    If GOK<1 : Break : Endif   # FQ 69909 Ctrl des sources avant Return

$NXT_MFG
Next

Filter [MFG]
Return

#########################################################################
# traitement des ordres
$MAJ_OF_TRANSAC
Local Integer I, K
GNBOF = 0

# On boucle sur les lignes du tableau
For I = 0 To [M:MMF1]NBLIG-1

# Issue 113530 - 2016-01-25 by BEEBE : inner join link for correct selection to be able for a Rewrite MFG
  Link [MFI] With [MFG]MFG0~=[F:MFI]MFGNUM
&          As [MFX]
&          Where [F:MFI]MFGNUM = [M:MMF1]MFGNUM(I) & [M:MMF1]FMODIF(I)=2 & [F:MFG]ROUNUM=[M:MMF1]ROUNUM(I) &
&                [F:MFG]ROUALT=[M:MMF1]ROUALT(I) & [F:MFI]BOMALT=[M:MMF1]BOMALT(I)
&                      Order By Key MFI0(1)
  For [MFX]
      # GH 08/10/2013 dm 91540
      #If [F:MFG]MFGTRKFLG >1 : Goto NXT_MFG_TRANSAC : Endif  # on ne met à niveau que les oF en attente
      If [F:MFG]MFGTRKFLG > 3 : Goto NXT_MFG_TRANSAC : Endif  # on ne met pas à niveau que les OF >= En cours
      GPE = ([F:MFG]MFGTRKFLG = 1)
      GPOINT = "CUSSELFLT2" : Gosub ENTREE From EXEFNC
      If !GPE : Goto NXT_MFG_TRANSAC : Endif

      Raz [M:MFGK]
      STOP = 0
      GUNUSE = 0
      WVISUGHOST = 0
      WLOAD = 0
      WJAL  = 0
      [M:MFGK]MFGNUM  = [F:MFG]MFGNUM
      [M:MFGK]MFGFCY  = [F:MFG]MFGFCY
      [M:MFGK]MFGSTA  = [F:MFG]MFGSTA
      [M:MFGK]PRVQTY  = [F:MFG]EXTQTY
      [M:MFGK]EXTQTY  = [F:MFG]EXTQTY
      [M:MFGK]STRDAT  = [F:MFG]STRDAT
      [M:MFGK]ENDDAT  = [F:MFG]ENDDAT
      [M:MFGK]ROUNUM  = [F:MFG]ROUNUM
      [M:MFGK]ROUALT  = [F:MFG]ROUALT
      [M:MFGK]PIO     = [F:MFG]MFGPIO
      [M:MFGK]ITMREF  = [F:MFI]ITMREF
      GRELITM = [M:MFGK]ITMREF

      [M:MFGK]AUTOTRT = 2

      # Issue 113530 - 2016-01-25 by BEEBE : Read MFGHEAD separate to be able for a Rewrite on MFG
      Read [MFG]MFG0=[F:MFI]MFGNUM

      # Ignorer les OF qui possèdent des éléments non prévus
      # mode de lancement OF  : complet ou matières seules
      # On recherche s'il existe une matière non prévue
      If find([F:MFG]MFGMOD,1,2) & [M:DIA]UNENVISAG=1
          For [MFM]MFM0 Where MFGNUM=[M:MFGK]MFGNUM
              If [F:MFM]BOMSEQ=0
                  # l'OF posséde des éléments non prévus : ignoré
                  WMESS1 =mess(156,197,1)-[F:MFM]MFGNUM-mess(250,193,1)
                  Call ECR_TRACE( WMESS1 ,0) From GESECRAN
                  STOP = 1  : Break
              Endif
          Next
      Endif
      If STOP = 1 :  Goto NXT_MFG_TRANSAC  : Endif

      # mode de lancement OF  : complet ou opérations seules
      # On recherche s'il existe une ope non prévue ou commandée (sous-traitance)
      If find([F:MFG]MFGMOD,1,3) & ([M:DIA]UNENVISAG=1 | find([M:DIA]TYPMAN,2,4))
          For [MFO]MFO0 Where MFGNUM=[M:MFGK]MFGNUM
              If [F:MFO]ROUOPENUM=0 & [M:DIA]UNENVISAG=1
                 # l'OF possède des éléments non prévus : ignoré
                 WMESS1 =mess(156,197,1)-[F:MFO]MFGNUM-mess(250,193,1)
                 Call ECR_TRACE( WMESS1 ,0) From GESECRAN
                 STOP = 1  : Break
              # Issue 115619 - 2016-05-26 by GH : not consider WO with ordered operations
              Elsif [F:MFO]OPESTA=7 & find([M:DIA]TYPMAN,2,4)
                 # Operation status x = Ordered
                 WMESS1 =mess(156,197,1)-[F:MFO]MFGNUM-":"-mess(108,200,1)-num$([F:MFO]OPENUM)-"="-mess(7,308,1)-"->"-mess(1215,9900,1)
                 Call ECR_TRACE( WMESS1 ,0) From GESECRAN
                 STOP = 1  : Break
              Endif
          Next
      Endif
      If STOP = 1 :  Goto NXT_MFG_TRANSAC : Endif

      K=I
      Gosub TRTMAN
      I=K
      If GOK<1 : Break : Endif   # FQ 69909 Ctrl des sources avant Return

$NXT_MFG_TRANSAC
  Next
Next
Filter [MFG]
Return

########################################################################

$TRTMAN
# FQ 67806 GA 11/2010 PE BEFTRTLIG idem FUNMAUTO
Local Integer GPE : GPE=1
GPOINT = "BEFTRTLIG" : Gosub ENTREE From EXEFNC
If !GPE Return Endif

Gosub VERROU
If !OK : Return : Endif
Call DEBTRANS From GLOCK
Gosub MAJMAN
Gosub DEVERROU
Return

########################################################################
$MAJMAN
Trbegin [MFG]

# Issue X3-8001 - 2016-12-07 by CCC : If optimized WO => remove it from Production scheduler
If [F:MFG]OPTFLG=2 & find([M:DIA]TYPMAN,2,4)
    [F:MFG]OPTFLG=1
    Rewrite [MFG]   # update before to do something else (read can be done again later)

    # Issue X3-29698 - 2017-04-07 by CCC : Remove forced dates set by PS & all pins
    Call REMOVE_PS_INFO([F:MFG]MFGNUM) From PSOPTFREE
    If GOK<1 : Rollback : Return : Endif
Endif

# déjalonnement
GPE=0
If !GPE | find([M:DIA]TYPMAN,2,4) # Issue 97265 GA 02/2014 déjalonnement si et seulement si maj de la gamme
  If find([F:MFG]SCDFLG,2,3,4)
      WJAL = 2
      Raz [M:JALK]
      [M:JALK]CODORI = 1
      [M:JALK]CODMAJ = 0
      [M:JALK]CODTRS = 0
      [M:JALK]MFGFCY = [F:MFG]MFGFCY
      [M:JALK]MFGNUM = [F:MFG]MFGNUM
      [M:JALK]MFGSTA = [F:MFG]MFGSTA
      Call DEJALONNE From JALLIBA
      #If [M:JALK]CODRET<>0 : GOK=0 : Return : Endif : # Issue 119208 GH 23/03/2017 - test return code after unscheduling
      If [M:JALK]CODRET<>0 : GOK=0 : Goto AB_MOD : Endif : # Issue 119208 GH 10/04/2017 - transaction to rollback
  Else
      Call WORKUNLOAD([F:MFG]MFGFCY, [F:MFG]MFGNUM, [F:MFG]SCDFLG) From JALLIBB
      WLOAD = 1
  Endif
Endif

# Mise à niveau nomenclature
# type de mise à niveau : nomenclature ou nomenclature + gamme &
# mode de lancement OF  : complet ou matières seules
WDIFF = 0
If find([M:DIA]TYPMAN,3,4) & find([F:MFG]MFGMOD,1,2)
    # mise à jour nomenclature seulement si OF non alloué
    # Issue 97593 GH 24/09/2018 - partially or totally allocated WO are now considered (except if [M:MFIX]NBLIG is not set to -1 by entry point)
    If dim([L]TABZON1)<0
       Gosub CMPDEF_MAT
    Endif
    If [M:MFIX]NBLIG>=0 | [F:MFG]ALLSTA = 1
       Gosub MAN_NOM
       If GOK<1 : Return : Endif
    Endif
Endif

# Mise à niveau gamme
# type de mise à niveau : gamme ou nomenclature + gamme &
# mode de lancement OF  : complet ou opérations seules
If find([M:DIA]TYPMAN,2,4) & find([F:MFG]MFGMOD,1,3)
    Gosub MAN_GAM
    If GOK<1 : Return : Endif
Endif
Commit

# trace
If WDIFF=1
    # Nomenclature inchangée
    WMESS1 =mess(156,197,1)-[MFI]MFGNUM-":"-mess(422,193,1)
    Call ECR_TRACE( WMESS1 ,0) From GESECRAN
Endif
If [M:MFGK]CODRET = 1
    # Nomenclature mise à niveau
    WMESS1 =mess(156,197,1)-[MFI]MFGNUM-":"-mess(632,197,1)
    Call ECR_TRACE( WMESS1 ,0) From GESECRAN
Elsif [M:MFGK]CODRET = 2
    # Gamme mise à niveau
    WMESS1 =mess(156,197,1)-[MFO]MFGNUM-":"-mess(633,197,1)
    Call ECR_TRACE( WMESS1 ,0) From GESECRAN
Elsif [M:MFGK]CODRET = 3
    #  Nomenclature + gamme mise à niveau
    WMESS1 =mess(156,197,1)-[MFI]MFGNUM-":"-mess(634,197,1)
    Call ECR_TRACE( WMESS1 ,0) From GESECRAN
Endif
#If [M:DIA]UNENVISAG=2 &  WUNENVISAG_OPE = 1
#    # les données de jalonnement doivent être vérifiées
#    Call ECR_TRACE(mess(29,190,1),0) From GESECRAN
#Endif
If GUNUSE =2
    # article non bloquant dans la nomenclature
    WMESS1 = mess(17,137,1)-mess(637,197,1)
    Call ECR_TRACE( WMESS1 ,0) From GESECRAN
Endif
If WVISUGHOST
    # un composant fantôme est présent. Une intervention manuelle est nécessaire.
    WMESS1= mess(214,190,1)
    Call ECR_TRACE( WMESS1 ,0) From GESECRAN
Endif

Gosub END_MOD
If [M:MFGK]CODRET <>0 : GNBOF += 1 : Endif

Return

########################################################################
$MAN_NOM
Gosub CHARG_MAT
If GOK>0
  WDIFF = 1   # By default, no difference
  Gosub CMP_MAT
  If WDIFF=2  # If there is a difference
     Gosub RPL_MAT
  Endif
Endif

If GOK<0    : Goto ROLL_MOD
Elsif GOK=0 : Goto AB_MOD
Endif
Return

########################################################################
# define fields to compare between screen MFGX and table MFM
# define fields to compare between screen MFIX and table MFI
$CMPDEF_MAT
Local Char    TABZON1(GLONAVA)(250), TABZON2(GLONAVA)(250)
Local Libelle TABLIB1(250), TABLIB2 (250)
Local Integer NBZON1, NBZON2

# TABZON1(0..NBZON1-1) is fed with fields to compare for materials
Read [AMZ]CODE = "MFG2";"NBLIG"
If !fstat
  I = [F:AMZ]NUMBLOC : # block number for NBLIG field in screen MFG2
  For [AMZ] Where CODMSK = "MFG2" & NUMBLOC = [L]I
    If evalue("dim([F:MFM]"+[F:AMZ]CODZON+")")>0 & evalue("dim([M:MFGX]"+[F:AMZ]CODZON+")")>0
&    & find([F:AMZ]CODZON,"BASQTY","BOMOFS","BOMOPE","BOMQTY","BOMSTUCOE","BOMUOM","CPNTYP","CTN","CUMFLG","CUMFXDQTY","DEFPOT","ECCVALMAJ","ECCVALMIN","ISSMGTCOD"
&                        ,"ITMREF","LIKQTY","LIKQTYCOD","LOC","LOT","MATSTA","PICPRN","PKC","QTYCOD","QTYRND","RELSCATIA","RETQTY","SCA","SCOFLG","STDQTY","STOMGTCOD","STU")
      TABZON1(NBZON1) = [F:AMZ]CODZON
      If [F:AMZ]NOLIB<>0 : TABLIB1(NBZON1) = 1 : Endif
      NBZON1+=1
    Endif
  Next
Endif

# TABZON2(0..NBZON2-1) is fed with fields to compare for by-products
Read [AMZ]CODE = "MFG1";"NBLIG"
If !fstat
  J = [F:AMZ]NUMBLOC : # block number for field NBLIG in screen MFG1
  For [AMZ] Where CODMSK = "MFG1" & NUMBLOC = [L]J
    If evalue("dim([F:MFI]"+[F:AMZ]CODZON+")")>0 & evalue("dim([M:MFIX]"+[F:AMZ]CODZON+")")>0
&    & find([F:AMZ]CODZON,"BASQTY","CSTFLG","ECCVALMAJ","ECCVALMIN","EXTQTY","ITMREF","LIKQTY","LIKQTYCOD","QTYRND","STU","UOM","UOMEXTQTY","UOMSTUCOE")
      TABZON2(NBZON2) = [F:AMZ]CODZON
      If [F:AMZ]NOLIB<>0 : TABLIB2(NBZON2) = 1 : Endif
      NBZON2+=1
    Endif
  Next
Endif

GPOINT = "CMPDEFMAT" : Gosub ENTREE From EXEFNC
Return

########################################################################
# Materials and by_products loading from tables to buffer screens MFGX and MFIX
$CHARG_MAT
Local    Integer  WLIKQTYCOD     : WLIKQTYCOD = 1   # FQ 73109 GA 05/2011 appel de CREMAT
Local    Decimal  WLIK           : WLIK = 1         # FQ 73109 GA 05/2011
Local    Decimal  WSCA           : WSCA = 1         # FQ 73109 GA 05/2011
Local    Decimal  WBAS           : WBAS = 1         # FQ 73109 GA 05/2011
Local    Date     WDAT                              # Issue 118271 GH 20/09/2016 # Local Decimal WDAT

If [M:MFIX]NBLIG>=0 : Raz [M:MFIX] : Endif   #Issue 97593 GH 24/09/2018
Raz [M:MFGX]   #Issue X3-64275 30/01/2018 by GEBIL : Levelling WO : issue with text copy
WLIG          = 0

For [MFIW]MFI0 Where MFGNUM=[M:MFGK]MFGNUM & ITMTYP=1
    GMFGLIN       = 1        # sert ds le cas d'OF multi-article avec sous-produits
    GMFILIN           = [F:MFIW]MFGLIN
    # pour alimentation de l'encours sous-produit
    [M:MFGK]PJT    = [F:MFIW]PJT
    [M:MFGK]ITMREF = [F:MFIW]ITMREF
    Read [ORD]ORD0 = 5;[F:MFIW]WIPNUM;[F:MFIW]ITMREF
    If fstat=0
        [M:MFGK]BPRNUM     = [F:ORD]BPRNUM
        [M:MFGK]VCRTYPORI  = [F:ORD]VCRTYPORI
        [M:MFGK]VCRNUMORI  = [F:ORD]VCRNUMORI
        [M:MFGK]VCRLINORI  = [F:ORD]VCRLINORI
        [M:MFGK]VCRSEQORI  = [F:ORD]VCRSEQORI
    Endif

    # Issue 113561 - 2016-01 by GH : Material load for a version in derogation
    WDAT = [M:MFGK]STRDAT
    If [M:MFGK]ECCVALMAJ<>""
       Call CORDAT([M:MFGK]ITMREF,[M:MFGK]ECCVALMAJ,[M:MFGK]ECCVALMIN,2,WDAT) From ECCLIB
    Endif

    # FQ 75932 GA 08/2011 WLIKQTY => WLIK
    # FQ 73109 GA 05/2011 + param WLIKQTYCOD appel de CREMAT
    [F:MFI] = [F:MFIW]     # Issue 99635 GH 27/08/2018 - [F:MFI] is used in MFGAUTLIB.FILL_MAT
    Call CREMAT([M:MFGK]MFGFCY,[F:MFIW]ITMREF,[F:MFIW]BOMALT, WDAT,[F:MFIW]EXTQTY,
&               [F:MFIW]LOT, WLIG, 0, 0, WLIKQTYCOD, WLIK, WSCA, 0, WBAS, WVISUGHOST, WRET) From MFGAUTLIB     # 38064 mm 11.06
    # il existe un article bloquant dans la nomenclature
    If GUNUSE = 3
        # Nomenclature mise à niveau
        WMESS1 =mess(156,197,1)-":"-[F:MFIW]MFGNUM-"."-mess(632,197,1)
        Call ECR_TRACE( WMESS1 ,0) From GESECRAN
        Call ECR_TRACE( mess(217,193,1),1) From GESECRAN
    Endif
    If [M:MFGK]CMPUSBFLG = 2 : GOK = 0 : Endif
    If GOK=0 : Break : Endif
Next
GMFILIN=0
Return

########################################################################
#Issue 97593 GH 24/09/2018 - WO materials are updated only if something changed or unexpected lines are to remove
#                            => narrows risk to lose analytical dimensions, assignments, allocations, ...
$CMP_MAT
If [M:MFIX]NBLIG<0 : WDIFF=2 : Return : Endif

If [M:DIA]UNENVISAG=3 : # don't preserve unexpected materials => WO is changed if there is some unexpected lines in it
   Filter [MFM] Where MFGNUM=[M:MFGK]MFGNUM & BOMSEQ=0
   Read [MFM]MFM0 First
   Filter [MFM]
   If fstat<=2 : WDIFF=2 : Return : Endif
Endif

# Materials comparaison (only expected ones)
J=0
For [MFM] Where MFGNUM=[M:MFGK]MFGNUM & BOMSEQ<>0
  If  J<[M:MFGX]NBLIG
    For I=0 To NBZON1-1
      # for a field with type = local menu, there is no difference between values 0 and 1
      If evalue("[F:MFM]"+TABZON1(I)+"<>"+"[M:MFGX]"+TABZON1(I)+"(J)")
&     & !(TABLIB1(I)=1 & evalue("[F:MFM]"+TABZON1(I)+"+"+"[M:MFGX]"+TABZON1(I)+"(J)")=1)
        If WTEST : Infbox "[MFM]"+TABZON1(I)-evalue("num$([F:MFM]"+TABZON1(I)+")")-evalue("num$([M:MFGX]"+TABZON1(I)+"(J))") : Endif
        WDIFF=2 : Break 2
      Endif
    Next
  Endif
  J+=1
Next
If WDIFF<>2 & J<>[M:MFGX]NBLIG
   WDIFF = 2
   If WTEST : Infbox "[MFM]NBLIG" : Endif
Endif
If WDIFF=2 : Return : Endif

# By-products comparaison (no way to distinguish expected ones => considered as expected as in WO function)
J=0
For [MFI] Where MFGNUM=[M:MFGK]MFGNUM & ITMTYP=2
  If  J<[M:MFIX]NBLIG
    For I=0 To NBZON2-1
      # for a field with type = local menu, there is no difference between values 0 and 1
      If evalue("[F:MFI]"+TABZON2(I)+"<>"+"[M:MFIX]"+TABZON2(I)+"(J)")
&       & !(TABLIB2(I)=1 & evalue("[F:MFI]"+TABZON2(I)+"+"+"[M:MFIX]"+TABZON2(I)+"(J)")=1)
        If WTEST : Infbox "[MFI]"+TABZON2(I)-evalue("num$([F:MFI]"+TABZON2(I)+")")-evalue("num$([M:MFIX]"+TABZON2(I)+"(J))") : Endif
        WDIFF=2 : Break 2
      Endif
    Next
  Endif
  J+=1
Next
If WDIFF<>2 & J<>[M:MFIX]NBLIG
   WDIFF = 2
   If WTEST : Infbox "[MFI]NBLIG" : Endif
Endif
If WDIFF=2 : Return : Endif
Return

########################################################################
# Materials and by-products updates in tables
$RPL_MAT
WUNENVISAG_MAT = 0
## boucle de suppression des matières
For [MFM]MFM0 Where MFGNUM=[M:MFGK]MFGNUM
    Readlock [MFM] Curr
    WMFGNUM = [F:MFM]MFGNUM
    WMFGLIN = [F:MFM]MFGLIN
    WBOMSEQ = [F:MFM]BOMSEQ
    WITMREF = [F:MFM]ITMREF
    If fstat=1
        GOK = -1 : GLOCK="$MFGMAT"+WMFGNUM-num$(WMFGLIN)-num$(WBOMSEQ)-WITMREF
        Break
    Elsif fstat
        GOK=0
        Call RSTA("MFM", WMFGNUM-num$(WMFGLIN)-num$(WBOMSEQ)-WITMREF) From GLOCK
        Break
    Endif

    # si on veut conserver les matières non prévues
    If [M:DIA]UNENVISAG=2 & [F:MFM]BOMSEQ=0
        WUNENVISAG_MAT = 1
        Goto NEXT_MFM
    Endif

    If left$([F:MFM]MFMTEX,3)="MFM"
        Call SUP_CLOB([F:MFM]MFMTEX,WRET) From TRTX3TEX
    Endif

    If [F:MFM]CPNTYP <> 5
        # Issue 99635 GH 27/08/2018 - assignment deletion
        Gosub SUP_MTO_MFM  From MFGMTOLIB

        # Issue 97593 GH 24/09/2018 - allocation is deleted or will be modified later by GEN_MAT
        If [F:MFM]ALLSTA>1
          WTRT = "A"
          If [F:MFM]BOMSEQ<>0
            For J=0 To [M:MFGX]NBLIG-1
              If [F:MFM]BOMSEQ=[M:MFGX]BOMSEQ(J) & [F:MFM]ITMREF=[M:MFGX]ITMREF(J) & [F:MFM]MFGLIN=[M:MFGX]MFGLIN(J)
&               (dim([M:MFGX]ECCVALMAJ)<0 | ([F:MFM]ECCVALMAJ=[M:MFGX]ECCVALMAJ(J) & [F:MFM]ECCVALMIN=[M:MFGX]ECCVALMIN(J)))
                [M:MFGX]ALLSTA(J)=[F:MFM]ALLSTA
                [M:MFGX]ALLQTY(J)=[F:MFM]ALLQTY
                [M:MFGX]SHTQTY(J)=[F:MFM]SHTQTY
                WTRT = "M" : Break
              Endif
            Next
          Endif
          If WTRT = "A"
            WALL = [F:MFM]ALLQTY
            WSHT = [F:MFM]SHTQTY
            Case [F:MFM]ALLSTA
                When 2,3: WALLTYP = 1
                When 4,5: WALLTYP = 2
            Endcase
            # appel à la routine de gestion des allocations
            Call ALLOCATION(WTRT, WALLTYP, WALL, WSHT, WRET) From MFGALL
            If WRET <> 0 : Break : Endif
            MEMSTA=[F:MFM]ALLSTA : [F:MFM]ALLSTA=1 : Gosub MAJMFG From MFGAUTLIB
          Endif
        Endif

        # suppression encours
        [M:ORDK]MAJCOD     = "A"
        [M:ORDK]WIPTYP     = 6
        [M:ORDK]WIPNUM     = [F:MFM]WIPNUM
        [M:ORDK]ITMREF     = [F:MFM]ITMREF
        Call WIP From TRTWIP
    Endif

   # suppression matière
   Delete [MFM]

   If [F:MFM]CPNTYP <> 5
        If [F:MFM]CPNTYP=1 & [F:MFM]MATSTA <> 4 & [F:MFM]RETQTY<>0
           [F:MFG]MATLINNBR -= 1
        Endif

        Gosub MAJSTATUT  From MFGLIB

        #----- Suppression des sections de la ligne matière -----#
        #        Delete [CAL] Where ABRFIC="MFM" & VCRNUM=[F:MFM]MFGNUM & VCRLIN=[F:MFM]MFGLIN &
        #&                          VCRSEQ = [F:MFM]BOMSEQ & CPLCLE = [F:MFM]ITMREF
        # Issue 119469 GH 04/11/16 - performance enhancement
        Delete [CAL] Where ABRFIC="MFM" & VCRNUM=[F:MFM]MFGNUM & VCRLIN=[F:MFM]MFGLIN
&                        & VCRSEQ=[F:MFM]BOMSEQ & CPLCLE=[F:MFM]ITMREF & VCRTYP=0
        If fstat=1
            GOK=-1
            GLOCK="$CPTANALIN MFM 0"-[F:MFM]MFGNUM-num$([F:MFM]MFGLIN)-num$([F:MFM]BOMSEQ)-[F:MFM]ITMREF
            Break
        Endif
   Endif
$NEXT_MFM
Next
If GOK<1 : Return : Endif

## boucle de suppression des sous-produits
For [MFIW]MFI0 Where MFGNUM=[M:MFGK]MFGNUM & ITMTYP=2
    Readlock [MFIW] Curr
    WMFGNUM = [F:MFIW]MFGNUM
    WMFGLIN = [F:MFIW]MFGLIN
    If fstat=1
        GOK = -1 : GLOCK="$MFGITM"+WMFGNUM-num$(WMFGLIN)
        Break
    Elsif fstat
        GOK=0
        Call RSTA("MFI",WMFGNUM-num$(WMFGLIN)) From GLOCK
        Break
    Endif

    # Issue 99635 GH 27/08/2018 - assignment deletion
    [F:MFI] = [F:MFIW]
    Gosub SUP_MTO_MFI  From MFGMTOLIB

    # suppression encours
    [M:ORDK]MAJCOD     = "A"
    [M:ORDK]WIPTYP     = 9
    [M:ORDK]WIPNUM     = [F:MFIW]WIPNUM
    [M:ORDK]ITMREF     = [F:MFIW]ITMREF
    Call WIP From TRTWIP

    # mise à jour quantité commandée article si OF ferme
    If [F:MFG]MFGSTA = 1
        Call LECITV([F:MFIW]MFGFCY, [F:MFIW]ITMREF, "", STA) From STKLIB
        WITMREF = [F:ITV]ITMREF
        WFCY =    [F:ITV]STOFCY
        If GOK = 1
            [F:ITV]ORDSTO -= [F:MFIW]RMNEXTQTY
            Rewrite [ITV]
            If fstat : GOK=0 : Call RSTA("ITV", WITMREF-WFCY ) From GLOCK : Break : Endif
        Endif
    Endif

    # suppression sous-produit
    Delete [MFIW]

    [F:MFG]ITMLINNBR -= 1    # Issue 97593 GH 24/09/2018

    #----- Suppression des sections de la ligne article lancé -----#
    #Delete [CAL] Where ABRFIC="MFI" & VCRNUM=[F:MFIW]MFGNUM & VCRLIN=[F:MFIW]MFGLIN
    # Issue 119469 GH 04/11/16 - performance enhancement
    Delete [CAL] Where ABRFIC="MFI" & VCRNUM=[F:MFIW]MFGNUM & VCRLIN=[F:MFIW]MFGLIN & VCRTYP=0
    If fstat=1
        GOK=-1 : GLOCK="$CPTANALIN MFI 0"-[F:MFIW]MFGNUM-num$([F:MFIW]MFGLIN) : Break
    Endif
Next
If GOK<1 : Return : Endif

## Records creation in tables
Call GEN_MAT From MFGAUTLIB # Matérials generation from buffer mask MFGX
If GOK=0 : Return : Endif

# Issue 97593 GH 24/09/2018 - By-product generation from buffer mask MFIX
If [M:MFIX]NBLIG>0
   Call GEN_SOUSPROD From MFGAUTLIB
   If GOK=0 : Return : Endif
Endif

# Issue 108268 - 2015-09-18 by JUSYN : Added missing update for MFG class
Rewrite [MFG]

[M:MFGK]CODRET = 1    # nomenclature mise à niveau
Return

########################################################################
$MAN_GAM

WUNENVISAG_OPE = 0
# boucle de suppression des opérations
For [MFO]MFO0 Where MFGNUM=[M:MFGK]MFGNUM
    Readlock [MFO] Curr
    WMFGNUM     = [F:MFO]MFGNUM
    WOPENUM     = [F:MFO]OPENUM
    WOPESPLNUM  = [F:MFO]OPESPLNUM
    If fstat=1
        GOK = -1 : GLOCK="$MFGOPE"+WMFGNUM-num$(WOPENUM)-num$(WOPESPLNUM)
        Break
    Elsif fstat
        GOK=0
        Call RSTA("MFO",WMFGNUM-num$(WOPENUM)-num$(WOPESPLNUM)) From GLOCK
        Break
    Endif

    # si on veut conserver les ope non prévues
    If [M:DIA]UNENVISAG=2 & [MFO]ROUOPENUM=0
        WUNENVISAG_OPE = 1
        Goto NEXT_MFO
    Endif

    If left$([F:MFO]MFOTEX,3)="MFO"
        Call SUP_CLOB([F:MFO]MFOTEX,WRET) From TRTX3TEX
    Endif

    # suppression encours charge + sous-traitance
    Call UPDATE_OWX("A","") From MFGLIBO

    Delete [MFO]
    [F:MFG]OPELINNBR -= 1

    #----- Suppression des sections de la ligne operation  pour les deux postes -----#
#    Delete [CAL] Where ABRFIC="MFO" & VCRNUM=[F:MFO]MFGNUM & VCRLIN=[F:MFO]OPENUM &
#&                VCRSEQ = [F:MFO]OPESPLNUM
        # Issue 119469 GH 04/11/16 - performance enhancement
    Delete [CAL] Where ABRFIC="MFO" & VCRNUM=[F:MFO]MFGNUM & VCRLIN=[F:MFO]OPENUM
&                    & VCRSEQ=[F:MFO]OPESPLNUM & VCRTYP=0
    If fstat=1
       GOK=-1 : GLOCK="$CPTANALIN MFO 0"-[F:MFO]MFGNUM-num$([F:MFO]OPENUM)-num$([F:MFO]OPESPLNUM) : Break
    Endif

$NEXT_MFO
Next
If GOK<0    : Goto ROLL_MOD
Elsif GOK=0 : Goto AB_MOD
Endif

# annulation données jalonnements
#For [SCH]SCH0 Where MFGNUM=[M:MFGK]MFGNUM
#    Readlock [SCH]  Curr
#    Delete [SCH]
#Next
# Issue 119469 GH 04/11/16 - performance enhancement
Delete [SCH] Where MFGNUM=[M:MFGK]MFGNUM
If fstat=1
   GOK=-1 : GLOCK="$SCHEDULING"-[M:MFGK]MFGNUM : Goto ROLL_MOD
Endif

# Dans cas où il existe des ope non prévues que l'on veut conserver
If [M:DIA]UNENVISAG=2 &  WUNENVISAG_OPE = 1
    Gosub TRT_UNENV1
    If GOK=0 : Goto AB_MOD : Endif
Endif

Call CREOPE([M:MFGK]STRDAT, [M:MFGK]ROUNUM, [M:MFGK]ROUALT, [M:MFGK]MFGFCY, [M:MFGK]ROUECCMAJ, [M:MFGK]ROUECCMIN, [M:MFGK]EXTQTY, WMSG)
&     From MFGAUTLIB
If GOK=0 : Goto AB_MOD : Endif

If [M:DIA]UNENVISAG=2 &  WUNENVISAG_OPE = 1
    Gosub TRT_UNENV2
    If GOK=0 : Goto AB_MOD : Endif
Endif

# Issue 116812 - 2016-05-26 by GH : Added missing update for MFG class
Rewrite [MFG]

# jalonnement
If WJAL > 1 & [F:MFG]SCDFLG <> 4
    Raz [M:JALK]
    [M:JALK]CODORI = 1
    [M:JALK]CODMAJ = 0
    [M:JALK]CODTRS = 0
    [M:JALK]MFGFCY = [M:MFGK]MFGFCY
    [M:JALK]MFGNUM = [M:MFGK]MFGNUM
    [M:JALK]MFGSTA = [M:MFGK]MFGSTA
    If [F:PJA]MFGFCY <> [M:MFGK]MFGFCY
        Read [PJA]PJA0=[M:MFGK]MFGFCY
        If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
    Endif
    Call JALONNE From JALLIB
    # relecture MFG
     Read [MFG]MFG0=[M:MFGK]MFGNUM
     If !fstat
         [M:MFGK]STRDAT = [F:MFG]STRDAT
         [M:MFGK]ENDDAT = [F:MFG]ENDDAT
     Endif
Endif

If WLOAD
    Call WORKLOAD([F:MFG]MFGFCY, [F:MFG]MFGNUM, [F:MFG]SCDFLG) From JALLIBB
Endif

If [M:MFGK]CODRET = 0    : [M:MFGK]CODRET = 2    # gamme mise à niveau
Elsif [M:MFGK]CODRET = 1 : [M:MFGK]CODRET = 3    # gamme + nomenclature mise à niveau
Endif

Return

#########################################################################
$END_MOD
#Local Char PARAM_CLC(15)(1..14) , VAL_CLC(10)

#--------------------------------------------------#
# v 140 Calcul automatique des coûts prévisionnels # (CPT et CPL)
#--------------------------------------------------#
# If GCLCWOCAUT = 3 & [M:MFGK]MFGSTA = 1 : # GH 04/04/2014 bug 98875
If GCLCWOCAUT = 3
    If dim([L]PARAM_CLC)>1   # FQ 47987 avant PARAM, VALEUR
      Raz PARAM_CLC,VAL_CLC
    Else
      Local Char PARAM_CLC(250)(1..14) , VAL_CLC(250)
    Endif
    PARAM_CLC(1) = [F:MFG]MFGFCY
    PARAM_CLC(2) = [F:MFG]MFGNUM
    PARAM_CLC(4) = "1"
    PARAM_CLC(5) = "4"
    # positionner PARAM_CLC(9) à "1" SI ON NE VEUT PAS l'édition du calcul
    # positionner PARAM_CLC(13) à "2" si on veut la trace
## GH 09/04/2014 bug 99047
#    PARAM_CLC(12) = "2"
#    PARAM_CLC(13) = "0"   # Issue 89622 - 2013-06-05 by CCC
    PARAM_CLC(9) = "1"    # pas d'édition
    PARAM_CLC(13) = "3"   # Trace des erreurs
##
    PARAM_CLC(14) = "10"
    Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBMCC","",3,"") From GTRAITE
Endif

Return

#########################################################################
$TRT_UNENV1
# Case where there are unplanned WO operations we want to keep
# Renumber of their number in order not to have conflict with the routing operations we will add after
# Issue 116814 - 2016-05-30 by GH : keep the same relative order in the unplanned (and maybe split) WO operations

# search the biggest operation number for the routing
Filter [ROO] Where FCY=[M:MFGK]MFGFCY & ITMREF=[M:MFGK]ROUNUM & ROUALT=[M:MFGK]ROUALT
Read [ROO]ROO0 Last
Filter [ROO]
If fstat : Return : Endif
WOPE = [F:ROO]OPENUM

# search the biggest operation number for the WO
Filter [MFO] Where MFGNUM=[M:MFGK]MFGNUM
Read [MFO]MFO0 Last
Filter [MFO]
If fstat : Return : Endif
WOPE_UN = [F:MFO]OPENUM

J=0
# operations to renumber are temporary put after the biggest operation number in the routing
For [MFO]MFO0 Where MFGNUM=[M:MFGK]MFGNUM & OPENUM<=WOPE_UN
  Look [ROO]ROO0(4) = [M:MFGK]MFGFCY;[M:MFGK]ROUNUM;[M:MFGK]ROUALT;[F:MFO]OPENUM
  If !fstat | ([F:MFO]OPENUM>WOPE & J)
     Gosub MAJ_UNENV1
     If GOK<1 : Break : Endif
  Endif
Next
If GOK<1 : Return : Endif

If J=2
  # moved operations are definitively renumbered with the right number to avoid a numerotation gap amongst WO operations
  J=3
  For [MFO]MFO0 Where MFGNUM=[M:MFGK]MFGNUM & OPENUM>WOPE
      Gosub MAJ_UNENV1
      If GOK<1 : Break : Endif
      #
      WOPE = [F:MFO]OPENUM
  Next
  If GOK<1 : Return : Endif
Endif
Return

$MAJ_UNENV1
If J<>3
   I = WOPE + [F:MFO]OPENUM
Else
   I = WOPE + GROUSTE
Endif
If [F:MFO]OPENUM = I : Return : Endif

# sauvegarde n° OPE qu'on va modifier : nécessaire pour supprimer l'enregistrement ds OPERATIONS
WOPENUM      = [F:MFO]OPENUM
WOPESPLNUM   = [F:MFO]OPESPLNUM
#
Read [MFO]MFO0 =
If fstat
   GOK = 0 : Call RSTA("MFO",[M:MFGK]MFGNUM-num$(WOPENUM)-num$(WOPESPLNUM)) From GLOCK
   Return
Endif
[F:MFO]OPENUM = I
Rewrite [MFO]
If fstat
   WMESS1=[MFO]MFGNUM-mess(13,100,1)-"MFGOPE"
   Call ECR_TRACE(WMESS1,1) From GESECRAN
   GOK=0 : Return
Endif

# modification encours charge
Read [OPS]OPS1=[M:MFGK]MFGNUM;WOPENUM;WOPESPLNUM
If fstat : GOK = 0 : Return : Endif
[F:OPS]OPENUM = [F:MFO]OPENUM
[F:OPS]UPDDAT = date$
[F:OPS]UPDUSR = GUSER
Rewrite [OPS]
If fstat
   WMESS1=[F:OPS]MFGNUM-mess(13,100,1)-"OPERATIONS"
   Call ECR_TRACE(WMESS1,1) From GESECRAN
   GOK=0 : Return
Endif
#
If J<>3
   If !J : J=1 : Elsif WOPENUM>WOPE : J=2 : Endif
Endif
Return

#########################################################################
$TRT_UNENV2

# création données jalonnements des OP non prévues
Filter [MFO] Where MFGNUM=[MFGK]MFGNUM Order By OPENUM Asc
For [MFO]
    #Read [ROS]ROS0=[MFGK]MFGFCY;[MFGK]ROUNUM;[MFGK]ROUALT;[MFO]OPENUM : # GH useless
    Look [SCH]SCH0=[M:MFGK]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
    If fstat
       Raz [F:SCH]
       [F:SCH]MFGNUM    = [M:MFGK]MFGNUM
       [F:SCH]PLNFCY    = [F:MFG]PLNFCY
       [F:SCH]MFGFCY    = [F:MFG]MFGFCY
       [F:SCH]OPENUM    = [F:MFO]OPENUM
       [F:SCH]OPESPLNUM = [F:MFO]OPESPLNUM
       [F:SCH]ROUNUM    = [M:MFGK]ROUNUM
       [F:SCH]ROUALT    = [M:MFGK]ROUALT
       [F:SCH]ROUECCMAJ = [M:MFGK]ROUECCMAJ    # Issue 111414 - 2016-01-26 by CCC
       [F:SCH]ROUECCMIN = [M:MFGK]ROUECCMIN    # Issue 111414 - 2016-01-26 by CCC
       [F:SCH]SCDCOD    = 1
       [F:SCH]DACMST    = 2
       [F:SCH]MFGMST    = 1
       [F:SCH]CREDAT    =date$
       [F:SCH]CREUSR    =GUSER
       If dim([F:SCH]CRETIM) > 0 : [F:SCH]CRETIM = time : Endif            # 01.05 27567
       [F:SCH]EXPNUM    =[C]EXPORT
       Write [SCH]
       If fstat : GOK=0 : Break : Endif      # FQ 69909 Ctrl des sources avant Return
    Endif
Next
Filter [MFO]
If GOK=0 : Return : Endif                     # FQ 69909 Ctrl des sources Ligne ajoutée

# alimentation n° OP suivante
WOPE = 0
Filter [SCH] Where MFGNUM=[M:MFGK]MFGNUM Order By [SCH]OPENUM Desc
For [SCH]
    If WOPE = 0 : [SCH]NEXOPENUM = 0
    Else : [SCH]NEXOPENUM = WOPE
    Endif
    If WOPE <>[SCH]OPENUM : WOPE = [SCH]OPENUM : Endif
    Rewrite [SCH]
    If fstat : GOK=0 : Break : Endif      # FQ 69909 Ctrl des sources avant Return
Next
Filter [SCH]
If GOK=0 : Return : Endif                     # FQ 69909 Ctrl des sources Ligne ajoutée

# y-a-t'il une dernière OP ? une OP productive ?
WOPE_PROD  = 0
For [SCH]SCH0 Where MFGNUM=[M:MFGK]MFGNUM
    If fstat : GOK=0 : Break : Endif
    DOPENUM    = [F:SCH]OPENUM
    DOPESPLNUM = [F:SCH]OPESPLNUM
    DNEXOPENUM = [F:SCH]NEXOPENUM
    If [F:SCH]MFGMST = 2 : WOPE_PROD =2 : Endif
Next
If GOK = 0 : Return : Endif

If DNEXOPENUM = 0 & WOPE_PROD =2  : Return : Endif
If DNEXOPENUM <>0
    Readlock [SCH]SCH0=[M:MFGK]MFGNUM;DOPENUM;DOPESPLNUM
    If fstat : Return : Endif
    [F:SCH]NEXOPENUM = 0
    Rewrite [SCH]
    Unlock [SCH]
Endif
If WOPE_PROD <>2
    Readlock [SCH]SCH0=[M:MFGK]MFGNUM;DOPENUM;DOPESPLNUM
    If fstat : Return : Endif
    [F:SCH]MFGMST = 2
    Rewrite [SCH]
    Unlock [SCH]
Endif
Return

#########################################################################
$ROLL_MOD
Rollback : Call ROLL From GLOCK
If GROLL
   Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else
   GOK=1 : Goto MAJMAN
Endif
Return

#########################################################################
$AB_MOD
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

