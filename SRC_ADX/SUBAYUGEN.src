#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################################
## Xtend: Génération fiche Paramétrage avancé Xtend
#  Version 0001
######################################################################################
#    XMLGEN 
######################################################################################
Subprog XMLGEN(DOSORG, FCYORG, TIMSTP, OPTION, ELTCOD,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char FCYORG        #     Code site Xtend
Value Char TIMSTP        #     Référence time stamp 20061012093014
Value Char OPTION()(1..) #     Option 
                         #       'TRADET'=Trace détaillée
                         #       'CHK'   =Vérification des liens avec le paramétrage Xtend
Value Char ELTCOD        #     ""
Variable Integer RET     #     1 Ok; 0: Ko ; 2: avertissementLocal Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Char     MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer  WI, WNBREC
Local Integer  TRADETFLG   : TRADETFLG   = find("TRADET",OPTION)
Local Integer  CHKFLG   : CHKFLG   = find("CHK",OPTION) 
Local Char     WSTR1(250), WABRV, WABRVXTD
Local Char     WOBJXTDKEY (20)    
Local Integer  WOBJXTDTYP    # Menu 7910
Local Shortint WSTAT

RET=1

Call TITOBJ("AYU","", WSTR1) From CONTOBJ
Call ECR_TRACE(mess(38,7900,1)-WSTR1,0) From GESECRAN 
If CHKFLG   : Call ECR_TRACE(mess(175,7900,1),0) From GESECRAN : TRADETFLG=1 : Endif

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS

If DOSORG=nomap 
 Local File AYTADVPAR    [AYU1] 
Else 
 Local File =[L]DOSORG+".AYTADVPAR"     [AYU1] 
Endif 
Default File "[AYU1]"

#
Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=TIMSTP
XT_XMLID="ADV"
Gosub XMLF_INI2 From AYTGEN : If XT_RET=0 : RET=0 : Goto FFINALLY : Endif 
#
XT_TY="ELMTS"  : XT_ID=XT_XMLID                                            : Gosub XMLF_ADD From AYTGEN
#
For [AYU1]AYU0 Where FCYCOD=FCYORG 
 If (WOBJXTDTYP<>[F]OBJTYP or WOBJXTDKEY<>[F]OBJCOD)
    WNBREC+=1
    WOBJXTDTYP=[F]OBJTYP : WOBJXTDKEY=[F]OBJCOD
    Gosub SETID    
    If TRADETFLG 
        Call ECR_TRACE(mess(14,7910,1)-":"-[F]OBJCOD-"("+mess([F]OBJTYP,7910,1)+")",0) From GESECRAN
    Endif
    If (CHKFLG and WABRV<>"AYS")
            Call CONTROLE(WABRV,"",[F]OBJCOD,[F]FCYCOD,WSTAT) From CONTOBJ
            If WSTAT
                Call ECR_TRACE("  "-mess(177,7900,1),1) From GESECRAN : RET=2
            Endif
    Endif
 Endif
 #
 XT_TY="ELMT"  : XT_ID=WABRVXTD    # Gosub SETID   
                                      XT_VAL=mess([F]OBJTYP,7910,1)        : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="OBJCOD"     : XT_VAL=[F]OBJCOD                     : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="PARCOD"     : XT_VAL=[F]PARCOD                     : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="PARVAL"     : XT_VAL=[F]PARVAL                     : Gosub XMLF_ADD From AYTGEN
Next
#

$FFINALLY
Gosub XMLF_CL  From AYTGEN
Close Local File [AYU1]
Call ECR_TRACE(mess(146,7900,1)-num$(WNBREC),0) From GESECRAN
End

# Positionne WABRV et WABRVXTD
$SETID
WABRV=func AYTUTIA.GETX3COD([F]OBJTYP)
Case WABRV
  When "AYS" : WABRVXTD="FCY"
  When "AYF" : WABRVXTD="FLD"
  When "AYM" : WABRVXTD="MES"
  When "AYO" : WABRVXTD="OBJ"
  When "AYX" : WABRVXTD="SPE"
  When "AYG" : WABRVXTD="PAG"
  When "AYE" : WABRVXTD="ENT"
  When "AYB" : WABRVXTD="BLC"
  When "AYL" : WABRVXTD="DLK"
  When "AYA" : WABRVXTD="ACT"
  When "AYW" : WABRVXTD="CND"
  When "AYI" : WABRVXTD="INT"
  When "AYD" : WABRVXTD="PRF"
  When  Default 
      WABRVXTD="SUBAYUGEN/SETID- Type inconnu:"-mess([F]OBJTYP,7910,1)
Endcase
Return
