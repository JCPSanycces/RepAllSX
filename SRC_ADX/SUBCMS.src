#<AdxTL>@(#)12.0.0.0 $Revision$
#######################################################################
# SUBCMS : Transactions de saisie demandes de service     CRM 6/01/04 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:HTR]HDKTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWB]AWINBRO  Table des browsers            #
#                       [F:AWT]AWINBOUT Table des boutons             #
#                                                                     #
# Génération de 1 écran de saisie à partir des écrans de base         #
# SRE0                                                                #
# SRE1                                                                #
# SRE7                                                                #
# SRE2                                                                #
# SRE8                                                                #
# SRE9                                                                #
#                                                                     #
# Nom des écrans générés : WHxyyyz                                    #
#                            x = 1 pour parc client                   #
#                            x = 2 pour demandes                      #
#                            x = 3 pour interventions                 #
#                            x = 4 Plan de travail                    #
#                         (menu local 3020)                           #
#                                                                     #
#                          yyy = nom de la transaction (HTRNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                0, 1, 2, 3, 4 pour parc              #
#######################################################################
##########################################################################################################
Call OBJET("CMS",GBIDC1,GBIDC2) From GOBJET
End

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
    When "FILTRE"      : Gosub FILTRE
    When "EFFMASK"     : [M:CMS0]HTRTYP = 2 
    When "SETBOUT"     : Gosub SETBOUT  
    When "EXEBOUT"     : Gosub EXEBOUT  
    When "LIENS"       : Gosub TRT_DIETRS From SUBDST
                         Gosub LIENS
    When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST
                         Gosub RAZCRE
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "INICRE"      : Gosub INICRE
    When "CREATION"    : Gosub CREATION
    When "APRES_CRE"   : Gosub APRES_CRE
    When "INIMOD"      : Gosub INIMOD
    When "MODIF"       : Gosub MODIF
    When "APRES_MOD"   : Gosub APRES_MOD
    When "ANNULE"      : Gosub ANNULE
    When "AV_IMPRIME"  : Gosub COP_ECRAN
    When "FERME"       : Gosub FERME
    When Default
  Endcase
Return

##########################################################################################################
# Chargement nom application courante #
#-------------------------------------------------------#
$OUVRE
Local Char APPLI
Local Char WDIE_ABRFIC(GLONABR)
Local Integer WDIE_DTRTYP
Local Integer IINIMODTRS   # FGR 29/01/2010 : X3SUIVI62022

  APPLI = nomap
  [L]WDIE_ABRFIC = "HTR"
  [L]WDIE_DTRTYP = 2
  Gosub TRT_DIETRS From SUBDST
Return

##########################################################################################################
$FERME
  Call IMPSCR From ATRTX3
Return

##########################################################################################################
# Ne traiter que les transactions de type parc client   #
#-------------------------------------------------------#
$FILTRE
  FILTSUP = "[F:HTR]HTRTYP=2"
Return
  
##########################################################################################################
# Désactivation bouton "Validation" et "Copie" #  
#----------------------------------------------#  
$SETBOUT  
  If GREP <> "" or !CLECUR Then
    Call VIREBOUT(CHAINE,"12") From GOBJET
  Endif  
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return  

##########################################################################################################
# Après appui sur bouton "Validation" #  
#-------------------------------------#  
$EXEBOUT  
  Case REP
    When "1"
      Call DEBTRANS From GLOCK
      Trbegin ADOVAL
      Gosub TRT_ECRAN
      If GOK < 1 Then
        Rollback
      Else
        Commit
      Endif
    When Default
  Endcase  
Return  

##########################################################################################################
# Après lecture de chaque enregistrement chargement de NBAXE #
#------------------------------------------------------------#
$LIENS
  Gosub LOADDATA From SUBCMSB
  Gosub SETGRAY From SUBCMSB
  Gosub PE_HDKTRS From SUBHDKTRS
Return

##########################################################################################################
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
  [M:CMS0]HTRTYP = 2
  [M:CMS0]ENAFLG = 2
  Raz [M:CMS6]NBLIG
  Raz [M:CMS6]OBJLIS
  Raz [M:CMS6]OBJLISCLA
  Raz [M:CMS6]CLELIS
  Raz [M:CMS6]ORDLIS
  Raz [M:CMS6]FLTLIS
  [M:CMS6]DERLU = 2
  [M:CMS6]FIRLIS = 1
  Gosub ONGLETS_INIT From SUBCMSB
  Gosub BLOCS_INIT From SUBCMSB
  Gosub COLFIX_INIT From SUBCMSB
  Gosub CHAMPS_INIT From SUBCMSB
  Gosub TRT_DIETRS From SUBDST 
  Gosub SETGRAY From SUBCMSB
  Gosub PE_HDKTRS From SUBHDKTRS
  Affzo [CMS0]1-99
  Affzo [CMS1]1-99
  Affzo [CMS2]1-99
  Affzo [CMS3]1-99
  Affzo [CMS4]1-99
  Affzo [CMS5]1-99
  Affzo [CMS6]1-99
Return

##########################################################################################################
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
  Case COUZON
    When Default
      Gosub PE_HDKTRS From SUBHDKTRS
  Endcase
Return

##########################################################################################################
# Chargement avant le Write #
#---------------------------#
$INICRE
  Raz [F:HTV]
  Gosub CHARGE_ATEXTRA
  Gosub ONGLETS_ENREG From SUBCMSB
  Gosub BLOCS_ENREG From SUBCMSB
  Gosub COLFIX_ENREG From SUBCMSB
  Gosub CHAMPS_ENREG From SUBCMSB
  Gosub PE_HDKTRS From SUBHDKTRS
Return

##########################################################################################################
$CREATION
  [F:HTV] = [F:HTR]
  Write [HTV]
  If fstat <> 0 Then
    GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    GERR = 2
    #Erreur lors de l'écriture de la table des valeurs de transaction de saisie (HDKTRSVAL).
    GMESSAGE = mess(521,177,1)
    Return
  Endif
  Gosub TRT_DIETRS From SUBDST
  Gosub TRT_ECRAN
Return

##########################################################################################################
$APRES_CRE
Return

##########################################################################################################
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
  Gosub CHARGE_ATEXTRA
  IINIMODTRS = 0  # FGR 28/01/2010 : X3SUIVI62022
  Read [HTV]HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
  If fstat <> 0 Then
    # FGR 28/01/2010 : X3SUIVI62022 (début)
    IINIMODTRS = 1
    #GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    #GERR = 2
    #Erreur lors de la lecture de la table des valeurs de transaction de saisie (HDKTRSVAL).
    #GMESSAGE = mess(521,177,1)
    #Return
    # FGR 28/01/2010 : X3SUIVI62022 (fin)
  Endif
  Gosub ONGLETS_ENREG From SUBCMSB
  Gosub BLOCS_ENREG From SUBCMSB
  Gosub COLFIX_ENREG From SUBCMSB
  Gosub CHAMPS_ENREG From SUBCMSB
  Gosub PE_HDKTRS From SUBHDKTRS
Return

##########################################################################################################
$MODIF
  [F:HTV] = [F:HTR]
  If IINIMODTRS = 0 Then
    Rewrite [HTV]
  Else
    Write [HTV]
  Endif
  If fstat <> 0 Then
    GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    GERR = 2
    #Erreur lors de l'écriture de la table des valeurs de transaction de saisie (HDKTRSVAL).
    GMESSAGE = mess(521,177,1)
    Return
  Endif
  Gosub TRT_DIETRS From SUBDST
  Gosub TRT_ECRAN
Return

##########################################################################################################
$APRES_MOD
Return

##########################################################################################################
$ANNULE
Local Char WDIE_ABRFIC(GLONABR)

  Delete [AXX] Where CODFIC="HDKTRS" and IDENT1=num$([F:HTR]HTRTYP) and IDENT2=[F:HTR]HTRNUM
  [L]WDIE_ABRFIC = "HTR"
  Gosub TRT_DIETRS From SUBDST 
  Gosub TRT_ECRAN
  Delete [HTV] Where [F:HTV]HTRTYP=[F:HTR]HTRTYP and [F:HTV]HTRNUM=[F:HTR]HTRNUM
  If fstat <> 0 Then
    GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    GERR = 2
    #Erreur lors de la suppression dans la  table des valeurs de transaction de saisie.+" (HDKTRSVAL)"
    GMESSAGE = mess(523,177,1) - "(HDKTRSVAL)"
    Return
  Endif
Return

##########################################################################################################
# Création ou modif de texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA 
  Call MAJTEXTRA([M:CMS0]DESAXX,"HDKTRS","DESAXX",num$([M:CMS0]HTRTYP),[M:CMS0]HTRNUM) From ATEXTRA
  [F:HTR]HTRDES = GLANGUE + "~" + [M:CMS0]DESAXX
  [F:HTR]HTRTYPCAR = num$([F:HTR]HTRTYP)
Return

##########################################################################################################
$VERIF_CREMOD
Local Integer ITER

  #Vérifie que les description de browser sont complètes
  For ITER = 0 To [M:CMS6]NBLIG-1
    If [M:CMS6]OBJLIS(ITER) <> "" Then
      If [M:CMS6]CLELIS(ITER) = "" Then
        #Certaines descriptions de browsers sont incomplètes.
        GMESSAGE = mess(957,182,1)
        GERR = 2
        OK = 0
        Break
      Endif
      If [M:CMS6]ORDLIS < 1 Then
        #Certaines descriptions de browsers sont incomplètes.
        GMESSAGE = mess(957,182,1)
        GERR = 2
        OK = 0
        Break
      Endif
      If [M:CMS6]FLTLIS(ITER) = "" Then
        #Certaines descriptions de browsers sont incomplètes.
        GMESSAGE = mess(957,182,1)
        GERR = 2
        OK = 0
        Break
      Endif
    Endif
  Next
Return

##########################################################################################################
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
  Gosub INIT_VARIABLES From CRMTRSUTI
#---------------- Noms fenêtres et traitement -----------------#
Local Char     WINREF(GLONFEN) : WINREF = "OSRE"
Local Char     NOMWIN(GLONFEN) : NOMWIN = "WOSRE" + [M:CMS0]HTRNUM
Local Char     NOMTRT(GLONADC) : NOMTRT = "WGOSRE" + [M:CMS0]HTRNUM
#------------------------- En-tête --------------------------#
  MFROM = "SRE0"
  MTO = "WH" + num$([M:CMS0]HTRTYP) + [M:CMS0]HTRNUM + "0"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Description --------------------------#
  MFROM = "SRE1"
  MTO = "WH" + num$([M:CMS0]HTRTYP) + [M:CMS0]HTRNUM + "1"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Parc --------------------------#
  MFROM = "SRE7"
  MTO = "WH" + num$([M:CMS0]HTRTYP) + [M:CMS0]HTRNUM + "7"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Gestion --------------------------#
  MFROM = "SRE2"
  MTO = "WH" + num$([M:CMS0]HTRTYP) + [M:CMS0]HTRNUM + "2"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Facturation --------------------------#
  MFROM = "SRE8"
  MTO = "WH" + num$([M:CMS0]HTRTYP) + [M:CMS0]HTRNUM + "8"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Consommations --------------------------#
  MFROM = "SRE9"
  MTO = "WH" + num$([M:CMS0]HTRTYP) + [M:CMS0]HTRNUM + "9"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  If ACTION = "ANNULE" Then
    Gosub TRT_SUP_FEN
  Else
    Gosub TRT_GEN_FEN
  Endif
Return

##########################################################################################################
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
  Call DELWIN(NOMWIN,APPLI) From MSKDIV
Return

##########################################################################################################
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
  If clalev([F:AOB])=0 Local File =APPLI+".AOBJET"  [AOB] : Endif : # Si appel par FUNHDKTRS
  If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW"  [AWI] : Endif : # Si appel par FUNHDKTRS
  If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR"  [AWP] : Endif : # Si appel par FUNHDKTRS
  If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par FUNHDKTRS
  If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par FUNHDKTRS
  #----- Suppression fenêtre si transaction non active -----#
  If [M:CMS0]ENAFLG = 1 Then
    Gosub TRT_SUP_FEN
    Return
  Endif
  #----- Génération fenêtre si transaction active -----#
  Delete [AWI] Where WIN=NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINDOW" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0
    Call RSTA ("AWI",NOMWIN) From GLOCK
    Return
  Endif
  Delete [AWP] Where WIN=NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINPAR" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0
    Call RSTA ("AWP",NOMWIN) From GLOCK
    Return
  Endif
  Delete [AWB] Where WIN=NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINBRO" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0
    Call RSTA ("AWB",NOMWIN) From GLOCK
    Return
  Endif
  Delete [AWT] Where WIN=NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINBOUT" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0
    Call RSTA ("AWT",NOMWIN) From GLOCK
    Return
  Endif
  Read [AWI] AWI0=WINREF
  If fstat <> 0 Then
    GOK = 0
    Return
  Endif
  [F:AWI]WIN = NOMWIN
  #En-tête
  WMSKREF = "SRE0"
  WNOMMSK = "WH" + num$([M:CMS0]HTRTYP) + [M:CMS0]HTRNUM + "0"
  [F:AWI]MSKENT = WNOMMSK
  #Description
  WMSKREF = "SRE1"
  WNOMMSK = "WH" + num$([M:CMS0]HTRTYP) + [M:CMS0]HTRNUM + "1"
  I = find(WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 0
  Endif
  WFLGMSK = 2
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #Parc
  WMSKREF = "SRE7"
  WNOMMSK = "WH" + num$([M:CMS0]HTRTYP) + [M:CMS0]HTRNUM + "7"
  I = find(WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 3
  Endif
  Gosub ONGLETVISIBLE_HDK From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #Gestion
  WMSKREF = "SRE2"
  WNOMMSK = "WH" + num$([M:CMS0]HTRTYP) + [M:CMS0]HTRNUM + "2"
  I = find(WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 3
  Endif
  WFLGMSK = 2
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #Facturation
  WMSKREF = "SRE8"
  WNOMMSK = "WH" + num$([M:CMS0]HTRTYP) + [M:CMS0]HTRNUM + "8"
  I = find(WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 3
  Endif
  Gosub ONGLETVISIBLE_HDK From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #Consommations
  WMSKREF = "SRE9"
  WNOMMSK = "WH" + num$([M:CMS0]HTRTYP) + [M:CMS0]HTRNUM + "9"
  I = find(WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 3
  Endif
  Gosub ONGLETVISIBLE_HDK From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  [F:AWI]ACS = [M:CMS0]ACSCOD
  If dim([F:AWI]LIBEL) > 0 Then
    [F:AWI]LIBEL = [M:CMS0]DESAXX
  Endif
  [F:AWI]ENAFLG = 2
  [F:AWI]TRN = [M:CMS0]HTRNUM
  #----- Point d'entrée SRETRSWIN pour intervention sur fenêtre générée -----#
  Gosub PE_SRETRSWIN From TRTCRMPE # FGR 31/07/2009 : X3SUIVI56881
  Write [AWI]
  If fstat Then
    GOK = 0
    Call FSTA("AWI") From GLOCK
    Return
  Endif
  For [AWP] AWP0 Where WIN=WINREF
    [F:AWP]WIN = NOMWIN
    Write [AWP]
    If fstat Then
      GOK = 0
      Call FSTA("AWP") From GLOCK
      Break
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  #Ajout des browsers
  IROWLIS = 15
  INBROWREF = 2
  Gosub BROWSERS_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  For [AWT] AWT0 Where WIN=WINREF
    [F:AWT]WIN = NOMWIN
    Write [AWT]
    If fstat Then
      GOK = 0
      Call FSTA("AWT") From GLOCK
      Break
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  Call VALID(NOMWIN,APPLI,1,OK) From VALWIN
  If !OK Then
    GOK = 0
  Endif
Return

##########################################################################################################
Subprog AS_HTRNUM(VALEUR)
Variable Char    VALEUR()

  #-----------------------#
  # Avant saisie document #
  #-----------------------#
  [M:CMS0]HTRTYP = 2
End

##########################################################################################################
# Hard copy des écrans de paramétrage #
#-------------------------------------#
$COP_ECRAN
Local Char WINT(20)(2) 
Local Char WTIT(100)
Local Char WMSK(GLONAMK)(6)
Local Char WABR(GLONABR)(2)

  #-----
  Call TEXTFIC("HDKTRS","HTRNUM",2,WINT(0)) From OBJDIV
  Call TEXTFIC("HDKTRS","ACSCOD",2,WINT(1)) From OBJDIV
  WTIT = WINT(0)+" : "+[M:CMS0]HTRNUM-[M:CMS0]DESAXX-WINT(1)+" : "+[M:CMS0]ACSCOD
  WMSK(0) = "CMS1"
  WMSK(1) = "CMS2"
  WMSK(2) = "CMS3"
  WMSK(3) = "CMS4"
  WMSK(4) = "CMS5"
  WMSK(5) = "DIESCRTRS"
  WMSK(6) = "CMS6"
  Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
  OK = 0 : # Pour ne pas imprimer tout de suite !
Return

##########################################################################################################
# Pour exécution de la validation des transactions en gestion de patch #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

Local Integer TYP

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  If [F:ADS]MODULE(11) <> 2 Then
    End
  Endif
  TYP = 2
  Gosub GENPATCH From FUNHDKTRS
End

##########################################################################################################
# Pour éxécution de la validation des transactions en gestion de dossier #
#                par l'utilitaire de revalidation DOSWWW                 #
#                à partir du dictionnaire des types de transaction (ATN) #
##########################################################################
Subprog GENDOS(APPLI)
Value Char    APPLI

Local Integer TYP

  TYP = 2
  Gosub GENDOS From FUNHDKTRS
End

