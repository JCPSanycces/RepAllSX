##########################################################################################################
Subprog C_OBJLIS(VALEUR)
Variable Char    VALEUR()

Local Integer I

  #Vérifie si ce code solution n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:CMS6]OBJLIS)-1
    If I <> nolign-1 Then
      If [M:CMS6]OBJLIS(I) = VALEUR and [M:CMS6]OBJLIS(I) <> "" Then
        #Ce browser a déjà été saisi.
        GMESSAGE = mess(956,182,1)
        GERR = 2
        mkstat = 2
        Break
      Endif
    Endif
  Next
  If GERR Then
    End
  Endif
  If VALEUR = "SRE" Then
    #Valeur refusée. Il s'agit d'un browser standard.
    GMESSAGE = mess(959,182,1)
    GERR = 2
    mkstat = 2
    End
  Elsif VALEUR = "SR2" Then
    #Valeur refusée. Il s'agit d'un browser standard.
    GMESSAGE = mess(959,182,1)
    GERR = 2
    mkstat = 2
    End
  Elsif VALEUR = "SR3" Then
    #Valeur refusée. Il s'agit d'un browser standard.
    GMESSAGE = mess(959,182,1)
    GERR = 2
    mkstat = 2
    End
  Endif
End

##########################################################################################################
Subprog AM_OBJLIS(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:CMS6]OBJLISCLA(nolign-1) = ""
  Else
    Read [AOB]ABREV=VALEUR
    If fstat Then
      [M:CMS6]OBJLISCLA(nolign-1) = ""
    Else
      Call TEXTE([F:AOB]LIBEL, [M:CMS6]OBJLISCLA(nolign-1)) From OBJDIV
    Endif
  Endif
  [M:CMS6]CLELIS(nolign-1) = "SRE0"
  [M:CMS6]ORDLIS(nolign-1) = 1
  [M:CMS6]FLTLIS(nolign-1) = "1=1"
End

##########################################################################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE
Local Integer TYP
Local Char CODTAB(GLONTRS)

  MODULE = 12
  TYP = 2
  CODTAB = TABLE
  #-----
  Gosub OUVRE_COPTRS From SELTRS
  Gosub EXEC_COPTRS  From SELTRS
  Gosub FERME_COPTRS From SELTRS
Return
