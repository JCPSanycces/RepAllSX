#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du masque PLG1
##########################################################################################################
Subprog IB_NBPLG
  If [M:PLG1]TECH(nolign-1) = "" Then
    If [M:PLG1]CMGNUM(nolign-1) = "" Then
      If [M:PLG1]TYPOPGX(nolign-1) = 2 Then
        Read [OMP]OMP0=[M:PLG1]OPGNUM(nolign-1)
        If fstat Then
          Raz GBOUT3
        Else
          If [F:OMP]CLO = 2 Then
            Raz GBOUT3
          Else
            GBOUT3 = mess(346,196,1) #Clôturer l'opération.
          Endif
        Endif
      Else
        Raz GBOUT3
      Endif
    Else
      GBOUT3 = mess(345,196,1) #Clôturer la campagne.
    Endif
    If [M:PLG1]TYPOPG(nolign-1) <> "" Then
      GBOUT1 = GBOUT1 - [M:PLG1]TYPOPG(nolign-1)
    Endif
  Else
    # FGR 23/07/2009 : X3SUIVI56686
    Raz GBOUT1
    Raz GBOUT3
  Endif
End

##########################################################################################################
Subprog B3_NBPLG
Local Integer IPBL
Local Integer IOKREP
Local Integer INUMMES
Local Integer ICHAPTER 
Local Integer IBRETOUR

  IPBL = 0
  IOKREP = 0
  INUMMES = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If [M:PLG1]OPGNUM(nolign-1) = "" Then
    #Confirmez-vous la clôture de la campagne marketing et de toutes ses opérations associées ?
    Call OUINON(mess(680,182,1), IOKREP) From GESECRAN
    If IOKREP = 2 Then
      Call ONCLOCMG([M:PLG1]CMGNUM(nolign-1), INUMMES, ICHAPTER, IBRETOUR) From TRTPLGB
    Endif
  Endif
  If IBRETOUR = 0 Then
    IPBL = 1
  Endif
  If IPBL Then
    If IBRETOUR = 0  Then
      If ICHAPTER <> 0 Then
        GMESSAGE = mess(INUMMES,ICHAPTER,1)
      Else
        GMESSAGE = mess(347,196,1) #Erreur lors de la clôture.
      Endif
    Else
      GMESSAGE = mess(347,196,1) #Erreur lors de la clôture.
    Endif    
    GERR = 1
    End
  Endif
  Call AM_CUR([M:PLG0]CUR) From SUBPLG0
End
