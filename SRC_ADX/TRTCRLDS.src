##########################################################################################################
#   Création d'un tiers par rapport piste         Module CRM         septembre 2006
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Raz [M:CLD0]
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
#Nettoie l'écran avant de partir.
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "1"
      Gosub LK_CREATION        
  Endcase    
Return

##########################################################################################################
$ONMENU
Return


##########################################################################################################
$ONOK
Return

##########################################################################################################
$LK_CREATION
  If [M:CLD0]TYPEBPR = 1 Then
    SZOBJET = "BPP"
  Else
    SZOBJET = "BPC"
  Endif
  GBCRMFLGNEW = 1

  ## Action GOBJETC1
Local Char    PARMSK(250)(1..20), SAVACT(20)

  SAVACT = GACTION
  GACTION = "GOBJETC1"
  Call OBJET_CHAR([M:CLD0]BPRCOD, SZOBJET, "") From GOBJET
  GACTION = SAVACT
  FIN = 1
Return


