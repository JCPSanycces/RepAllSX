#<AdxTL>@(#)7.0.0.0 $Revision$

Gosub TEST From ASHWVAL
End

#---------------------------------------------------------------------------------------------------#
# Ecriture du traitement
#---------------------------------------------------------------------------------------------------#
Subprog VALTRT_REP(DOSSIER,CODREP,ASHW,AERR)
Value Char DOSSIER , CODREP
Variable  Instance  ASHW  Using C_ASW
Variable  Instance  AERR(1..) Using C_AERROR

Gosub DEFVAR From ASHWVALTRT

Local Char VARREP(3) : VARREP = ASHW.ACLAV.VARREP
Local Char ABRFRE(3) : ABRFRE = ASHW.ACLAV.ABRFRE

Raz [L]NBPRG
NOMTRTREP  = func SUBASW.PREFIX_TRT+CODREP : # WMREP
Call STC_VERF(NOMTRTREP,ASHW.ACLAV.IDENTREP,APPLI,MACHINE,"TRT",OK,AERR) From ACLASUB
If OK
 Raz CLOB
 Gosub TRT_TEST
 Gosub DESCRIPTION
 Gosub HEAD_REP
 Gosub SECTION_REP
 Gosub LINK_REP
 Gosub COLLECTIONS_REP
 Gosub ALOAD_LINKS_DET_PAGE_REP
 Call STC_DEB(APPLI,MACHINE,[L]NOMTRTREP,ASHW.ACLAV.IDENTREP,[L]CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
 Call TRT_FIN(CLOB,[L]NOMTRTREP,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
 If  maxtab(AERR)>0 : End : Endif
 Raz CLOB
 Gosub PROPERTYS_REP
Endif
Close Local File
End

#-------------------------------------------------------#
$ERFIC
ER = errn
Resume

#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$TRT_TEST
LIGNE ="#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$TEST2" : Gosub ADDCLB
LIGNE = "Local Instance "+ASHW.CODREP+" Using R_"+ASHW.CODREP : Gosub ADDCLB
LIGNE = ASHW.CODREP+" = NewInstance R_"+ASHW.CODREP+" AllocGroup null" : Gosub ADDCLB
LIGNE = "Call ALOAD_LINKS_DET_PAGE("+ASHW.CODREP+")" : Gosub ADDCLB
LIGNE = "Infbox 'OK'" : Gosub ADDCLB
LIGNE = "FreeGroup "+ASHW.CODREP : Gosub ADDCLB
LIGNE = "End" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE ="#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$TEST" : Gosub ADDCLB
LIGNE = "Local Instance REP Using C_AREPENT" : Gosub ADDCLB
LIGNE = 'Call DESCRIPTION_REPRESENTATION(REP,"TEST")' : Gosub ADDCLB
LIGNE = "Infbox 'OK'" : Gosub ADDCLB
LIGNE = "FreeGroup REP" : Gosub ADDCLB
LIGNE = "End" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#-------------------------------------------------------#
$DESCRIPTION
LIGNE ="#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "Subprog DESCRIPTION_REPRESENTATION(REP,GRPINS)" : Gosub ADDCLB
LIGNE = "Variable Instance REP Using C_AREPENT" : Gosub ADDCLB
LIGNE = "Value Char GRPINS"
LIGNE = "Gosub DESCRIPTION": Gosub ADDCLB
LIGNE = "End": Gosub ADDCLB
LIGNE = "": Gosub ADDCLB
LIGNE ="#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE ="$DESCRIPTION" : Gosub ADDCLB
LIGNE = "Gosub HEAD_REP" : Gosub ADDCLB
LIGNE = "Gosub SECTION_REP" : Gosub ADDCLB
LIGNE = "Gosub LINK_REP" : Gosub ADDCLB
LIGNE = "Gosub COLLECTIONS_REP" : Gosub ADDCLB
LIGNE = "Gosub PROPERTY_REP From"-func SUBASW.PREFIX_TRT+"1"+CODREP : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return


#-------------------------------------------------------#
$HEAD_REP
LIGNE ="#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Entete" : Gosub ADDCLB
LIGNE ="#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE ="$HEAD_REP" : Gosub ADDCLB
LIGNE = VARREP-"= NewInstance =[L]GRPINS , C_AREPENT"  : Gosub ADDCLB
LIGNE = VARREP+'.REP = "'+ASHW.CODREP+'"' : Gosub ADDCLB
LIGNE = VARREP+'.CLA = "'+ASHW.CODCLA+'"' : Gosub ADDCLB
LIGNE = VARREP+'.ICL = "'+ASHW.ABRCLA+'"' : Gosub ADDCLB
LIGNE = VARREP+'.AFCRIGHT = "'+ASHW.AFCRIGHT+'"' : Gosub ADDCLB
LIGNE = VARREP+'.NCL = '+num$(ASHW.ACLA.INTCLA)+' : # '+func ASYRFNC.TEXTE(ASHW.ACLA.INTCLA) : Gosub ADDCLB
LIGNE = VARREP+'.DES = '+num$(ASHW.INTREP)+' : # '+ASHW.INTITREP : Gosub ADDCLB
LIGNE = VARREP+'.TIT = "'+ASHW.TIT +'"' : Gosub ADDCLB
LIGNE = VARREP+'.ANX = "'+ASHW.INDCLA+'"' : Gosub ADDCLB
For I=1 To ASHW.NBRKEYREP
 LIGNE = VARREP+".CLE("+num$(I)+") = NewInstance C_AREPPAR AllocGroup REP : # "-func ASYRFNC.TEXTE(ASHW.ASWKEY(I).DESPAR) : Gosub ADDCLB
 DIF += 5
 LIGNE = VARREP+'.CLE('+num$(I)+").PAR = '"+ASHW.ASWKEY(I).CODFLD+"'"
 LIGNE += " : " +VARREP+'.CLE('+num$(I)+').TYP = '+num$(func ASYRSUB.TYPE_DATA_X3_TO_SYRACUSE(ASHW.ASWKEY(I).TYPINT,0,""))
 LIGNE += " : "+VARREP+'.CLE('+num$(I)+").PRO= '"+ASHW.ASWKEY(I).ALIAS+"'"
 LIGNE += " : "+VARREP+'.CLE('+num$(I)+").VPR= '"+ASHW.ASWKEY(I).VALEUR+"'"
 LIGNE += " : " +VARREP+'.CLE('+num$(I)+').DES = '+num$(ASHW.ASWKEY(I).DESPAR)
 Gosub ADDCLB
 DIF -= 5
Next
For I=1 To ASHW.NBRTRT
 LIGNE = VARREP+".TRT("+num$(I)+") = NewInstance C_AREPTRT AllocGroup REP" : Gosub ADDCLB
 DIF += 5
 LIGNE = VARREP+'.TRT('+num$(I)+").TRT = '"+ASHW.ASWTRT(I).CODTRT+"'"
 LIGNE += " : " +VARREP+'.TRT('+num$(I)+').TYP = '+num$(ASHW.ASWTRT(I).TYPTRT)
 Gosub ADDCLB
 DIF -= 5
Next
LIGNE = "# Facets" : Gosub ADDCLB
For I=1 To 5
 LIGNE = VARREP+'.AENAFAC('+num$(I)+') = '+num$(ASHW.ENAFAC(I)) -": #"-mess(I,7964,1) : Gosub ADDCLB
Next
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#-------------------------------------------------------#
$PROPERTYS_REP
#117445
Local Integer PROPERTYS_REP_COUNT
PROPERTYS_REP_COUNT=val(func ADP_TOOL.GET_PARAM(DOSSIER, 1, "", "ASWLIMIT"))
If PROPERTYS_REP_COUNT<1  | PROPERTYS_REP_COUNT>15
 PROPERTYS_REP_COUNT=15
Endif
#
[L]NBPRG += 1
NOMTRTREP  = func SUBASW.PREFIX_TRT+num$([L]NBPRG)+CODREP : # WMREP1
LIGNE = "Gosub TEST From"-func SUBASW.PREFIX_TRT+CODREP-": End": Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Propriûˋtûˋs exposûˋes" : Gosub ADDCLB
LIGNE = "# ASWLIMIT="+num$(PROPERTYS_REP_COUNT) : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$PROPERTY_REP" : Gosub ADDCLB
For I=1 To maxtab(ASHW.ASWR)
 Gosub PROPERTY_REP
 If mod(I,PROPERTYS_REP_COUNT)=0 :# 117445 mod(I,15)=0 : # find(I,60,120,180,240,300)>0
  LIGNE = "Gosub PROPERTY_REP From"-func SUBASW.PREFIX_TRT+num$([L]NBPRG+1)+CODREP : Gosub ADDCLB
  LIGNE = "Return" : Gosub ADDCLB
  LIGNE = "" : Gosub ADDCLB
  Call STC_DEB(APPLI,MACHINE,[L]NOMTRTREP,ASHW.ACLAV.IDENTREP,[L]CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
  Call TRT_FIN(CLOB,[L]NOMTRTREP,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
  If maxtab(AERR)>0 : Break : Endif

  [L]NBPRG += 1
  NOMTRTREP  = func SUBASW.PREFIX_TRT+num$([L]NBPRG)+CODREP : # WMREP1.2.3.4
  Raz CLOB
  LIGNE = "Gosub TEST From"-func SUBASW.PREFIX_TRT+CODREP-": End": Gosub ADDCLB
  LIGNE = "" : Gosub ADDCLB
  LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
  LIGNE = "# Propriûˋtûˋs exposûˋes" : Gosub ADDCLB
  LIGNE = "# ASWLIMIT="+num$(PROPERTYS_REP_COUNT) : Gosub ADDCLB
  LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
  LIGNE = "$PROPERTY_REP" : Gosub ADDCLB
 Endif
Next I
If maxtab(AERR)>0 : Return : Endif

LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Call STC_DEB(APPLI,MACHINE,[L]NOMTRTREP,ASHW.ACLAV.IDENTREP,[L]CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
Call TRT_FIN(CLOB,[L]NOMTRTREP,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
If maxtab(AERR)>0 : Return : Endif

Raz CLOB
Return



#-------------------------------------------------------#
$PROPERTY_REP
Raz NBRATT
LIGNE = VARREP+".PRO("+num$(I)+") = NewInstance C_AREPPRO AllocGroup REP : # "-ASHW.ASWR(I).INTITPRO
Gosub ADDCLB
DIF += 5
LIGNE = VARREP+'.PRO('+num$(I)+').PRO = "'+ASHW.ASWR(I).ALIAS+'"'
LIGNE +=  " : "
If ASHW.ASWR(I).ACLAF.ATY.FMTPROSYR>1
  LIGNE += VARREP+'.PRO('+num$(I)+').FMT = ' +num$(ASHW.ASWR(I).ACLAF.ATY.FMTPROSYR)
 LIGNE +=  " : "
Endif
LIGNE += VARREP+'.PRO('+num$(I)+').PTH = "'+ASHW.ASWR(I).CODPRO+'"'
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').BLC = "'+ASHW.ASWR(I).BLCPRO+'"'
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').TPC = '+num$(ASHW.ASWR(I).TYPCLA)
Gosub ADDCLB
LIGNE = VARREP+'.PRO('+num$(I)+').DES = '+num$(ASHW.ASWR(I).INTPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').SHO = '+num$(ASHW.ASWR(I).INTSHTPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').TYP = '
If ASHW.ASWR(I).ACLAF.ATY.CODTYP="ATX"
 LIGNE += "25"
Elsif find(ASHW.ASWR(I).ACLAF.ATY.CODTYP,"AXX","AX1","AX2","AX3")>0
 LIGNE += "26"
Else
 LIGNE += num$(func ASYRSUB.TYPE_DATA_X3_TO_SYRACUSE(ASHW.ASWR(I).ACLAF.ATY.TYPTYP,ASHW.ASWR(I).ACLAF.NOLIB,ASHW.ASWR(I).ACLAF.ATY.PROTYP))
Endif
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').ACS = "'+ASHW.ASWR(I).ACLAF.ACS+'"'
#Ligne trop longue sur PROTYP A(100)
#LIGNE +=  " : "
Gosub ADDCLB
LIGNE =  ""

If ASHW.ASWR(I).ACLAF.NOLIB=1
 #LIGNE += VARREP+'.PRO('+num$(I)+').TYS = "application/x-boolean"'
 LIGNE += VARREP+'.PRO('+num$(I)+').PROTYP = "application/x-boolean"'
Else
 #LIGNE += VARREP+'.PRO('+num$(I)+').TYS = "'+ASHW.ASWR(I).ACLAF.ATY.PROTYP+'"'
 LIGNE += VARREP+'.PRO('+num$(I)+').PROTYP = "'+ASHW.ASWR(I).ACLAF.ATY.PROTYP+'"'
Endif

LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').PROPREFLG = '+num$(ASHW.ASWR(I).ACLAF.ATY.PROPREFLG)

LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').ORD = '+num$(ASHW.ASWR(I).ORDPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').LNG = '
If ASHW.ASWR(I).ACLAF.ATY.CODTYP="ATX"
 K = 0
 For J=1 To maxtab(ASHW.ASWR(I).ACLAF.ATBPAR)
  If ASHW.ASWR(I).ACLAF.ATBPAR(J).CODPAR="LNG"
   K = val(ASHW.ASWR(I).ACLAF.ATBPAR(J).VALEUR)
  Endif
 Next
 If K=0 : K= GLONDES : Endif
 LIGNE += num$(K)
Else
 LIGNE += num$(ASHW.ASWR(I).ACLAF.LON)
Endif
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').REP = "'+ASHW.CODREP+'"'
Gosub ADDCLB
LIGNE = VARREP+'.PRO('+num$(I)+').DET = '+num$(ASHW.ASWR(I).DETPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').EDT = '+num$(ASHW.ASWR(I).EDIPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').QRY = '+num$(ASHW.ASWR(I).QRYPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').LOO = '+num$(ASHW.ASWR(I).LOKPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').SRY = '+num$(ASHW.ASWR(I).SUMPRO)
LIGNE +=  " : "

LIGNE += VARREP+'.PRO('+num$(I)+').FIL = '+num$(ASHW.ASWR(I).PARFILPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').ENT = '+num$(ASHW.ASWR(I).PARENTPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').GRI = "'+ASHW.ASWR(I).GRIPRO +'"'

Gosub ADDCLB
LIGNE = VARREP+'.PRO('+num$(I)+').STAINIDET = '+num$(ASHW.ASWR(I).STADETPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').STAINIEDT = '+num$(ASHW.ASWR(I).STAEDIPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').STAINIQRY = '+num$(ASHW.ASWR(I).STAQRYPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').STAINILOO = '+num$(ASHW.ASWR(I).STALOKPRO)
LIGNE +=  " : "
LIGNE += VARREP+'.PRO('+num$(I)+').STAINISRY = '+num$(ASHW.ASWR(I).STASUMPRO)
LIGNE +=  " : "

Gosub ADDCLB
LIGNE = ""
If ASHW.ASWR(I).ACLAF.OBLIG=2
 NBRATT += 1
 Call ADD_ATTRIBUTS(VARREP+'.PRO('+num$(I)+').ATT('+num$(NBRATT)+')','M',2,LIGNE,DIF,CLOB)
Endif
#If ASHW.ASWR(I).STAINIPRO=2
# NBRATT += 1
# Call ADD_ATTRIBUTS(VARREP+'.PRO('+num$(I)+').ATT('+num$(NBRATT)+')','H',2,LIGNE,DIF,CLOB)
#Endif
If ASHW.ASWR(I).TYPAFFPRO<>2
 NBRATT += 1
 Call ADD_ATTRIBUTS(VARREP+'.PRO('+num$(I)+').ATT('+num$(NBRATT)+')','R',2,LIGNE,DIF,CLOB)
Endif
LIGNE = ""
If find(ASHW.ASWR(I).ACLAF.ATY.TYPTYP,9,10)>0 : # clob et blob
 LIGNE = VARREP+'.PRO('+num$(I)+').CPM = "'+ASHW.ASWR(I).CLAPRO +'" : '
 LIGNE += VARREP+'.PRO('+num$(I)+').PMD = "'+ASHW.ASWR(I).ACLAF.FLDCLA +'" : '
 Gosub  ADDCLB
 K =0
 For J=1 To maxtab(ASHW.ASWR(I).ACLAF.ATBKEY)
  K += 1
  LIGNE = VARREP+'.PRO('+num$(I)+').VKY('+num$(K)+') = NewInstance C_AREPPAR AllocGroup REP' : Gosub ADDCLB
  DIF += 5
  LIGNE = VARREP+'.PRO('+num$(I)+').VKY('+num$(K)+").PAR = '"+ASHW.ASWR(I).ACLAF.ATBKEY(J).CODPAR+"'"
  LIGNE += " : " +VARREP+'.PRO('+num$(I)+').VKY('+num$(K)+").TYP = "+num$(func ASYRSUB.TYPE_DATA_X3_TO_SYRACUSE(ASHW.ASWR(I).ACLAF.ATBKEY(J).TYPINT,0,""))
  LIGNE += " : " +VARREP+'.PRO('+num$(I)+').VKY('+num$(K)+").VPR = '"+num$(ASHW.ASWR(I).ACLAF.ATBKEY(J).VALEUR)+"'"
  LIGNE += " : " +VARREP+'.PRO('+num$(I)+').VKY('+num$(K)+").PRO = '"+ASHW.ASWR(I).ACLAF.ATBKEY(J).ALIAS+"'"
  Gosub ADDCLB
  DIF -= 5
 Next
 For J=1 To maxtab(ASHW.ASWR(I).ACLAF.ATBPAR)
  K += 1
  LIGNE = VARREP+'.PRO('+num$(I)+').VKY('+num$(K)+') = NewInstance C_AREPPAR AllocGroup REP' : Gosub ADDCLB
  DIF += 5
  LIGNE = VARREP+'.PRO('+num$(I)+').VKY('+num$(K)+").PAR = '"+ASHW.ASWR(I).ACLAF.ATBPAR(J).CODPAR+"'"
  LIGNE += " : " +VARREP+'.PRO('+num$(I)+').VKY('+num$(K)+").TYP = "+num$(func ASYRSUB.TYPE_DATA_X3_TO_SYRACUSE(ASHW.ASWR(I).ACLAF.ATBPAR(J).TYPINT,0,""))
  LIGNE += " : " +VARREP+'.PRO('+num$(I)+').VKY('+num$(K)+").VPR = '"+num$(ASHW.ASWR(I).ACLAF.ATBPAR(J).VALEUR)+"'"
  LIGNE += " : " +VARREP+'.PRO('+num$(I)+').VKY('+num$(K)+").PRO = '"+ASHW.ASWR(I).ACLAF.ATBPAR(J).ALIAS+"'"
  Gosub ADDCLB
  DIF -= 5
 Next
Endif
LIGNE = ""
If ASHW.ASWR(I).ACLAF.NOLIB>0
 LIGNE = VARREP+'.PRO('+num$(I)+').MNL = '+num$(ASHW.ASWR(I).ACLAF.NOLIB)
 LIGNE +=  " : "
Endif

LIGNE += VARREP+'.PRO('+num$(I)+').PLK = '

K=0
If maxtab(ASHW.ASWR(I).ASWK)>0
 If ASHW.ASWR(I).ACLAF.ATY.CODCLA<>ASHW.CODCLA
& or (ASHW.ASWR(I).ACLAF.ATY.CODCLA=ASHW.CODCLA & ASHW.ASWR(I).ACLAF.FLDCLA<>ASHW.ASWKEY(ASHW.NBRKEYREP).CODFLD)
   For J=1 To maxtab(ASHW.ASWR(I).ASWK)
    If ASHW.ASWR(I).ASWK(J).CODLNK="$lookup"
      K=1
      Break
    Endif
   Next
 Endif
 If K=0 & find(ASHW.ASWR(I).CODPRO,ASHW.ASWR(1..maxtab(ASHW.ASWR)).UOMPRO)<>0
  K=1
 Endif
 If K=0
  LIGNE += "1" : Gosub ADDCLB
 Else
  LIGNE += "2" : Gosub ADDCLB
 Endif
 For J=1 To maxtab(ASHW.ASWR(I).ASWK)
  Call AJOUT_LIENS(VARREP+'.PRO('+num$(I)+').LNK('+num$(J)+')',ASHW.ASWR(I).ASWK(J),LIGNE,DIF,CLOB)
 Next
Else
 If K=0 & find(ASHW.ASWR(I).CODPRO,ASHW.ASWR(1..maxtab(ASHW.ASWR)).UOMPRO)<>0
  K=1
 Endif
 If K=0
  LIGNE += "1" : Gosub ADDCLB
 Else
  LIGNE += "2" : Gosub ADDCLB
 Endif
Endif

If LIGNE<>"" : LIGNE = "" :  Endif
Gosub ADDCLB
DIF -= 5
Return

#-------------------------------------------------------#
$SECTION_REP
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Section de la reprûˋsentation" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$SECTION_REP" : Gosub ADDCLB
For I=1 To ASHW.ASWG.NBRSEC
 LIGNE = VARREP+'.SEC('+num$(I)+') = NewInstance C_AREPSEC AllocGroup REP'
 Gosub ADDCLB
 DIF += 5
 LIGNE = VARREP+'.SEC('+num$(I)+').SEC = "'+ASHW.ASWG.CODSEC(I)+'"'
 LIGNE += ' : '
 LIGNE += VARREP+'.SEC('+num$(I)+').NSC = '+num$(ASHW.ASWG.INTSEC(I))
 LIGNE +=  ' : # ' +func ASYRFNC.TEXTE(ASHW.ASWG.INTSEC(I)) :  Gosub ADDCLB
 K = 0
 For J=1 To ASHW.ASWG.NBRBLC
  If ASHW.ASWG.SECBLC(J)=ASHW.ASWG.CODSEC(I)
   K += 1
   LIGNE = VARREP+'.SEC('+num$(I)+').BLC('+num$(K)+')="'+ASHW.ASWG.CODBLC(J)+'"'
   LIGNE += ' : '
   LIGNE += VARREP+'.SEC('+num$(I)+').NBC('+num$(K)+')='+num$(ASHW.ASWG.INTBLC(J))
   LIGNE += ' : # ' +func ASYRFNC.TEXTE(ASHW.ASWG.INTBLC(J)) :  Gosub ADDCLB
  Endif
 Next
 DIF -= 5
Next
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#-------------------------------------------------------#
$LINK_REP
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Liens de la reprûˋsentation" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$LINK_REP" : Gosub ADDCLB
Raz J
For I=1 To maxtab(ASHW.ASWK)
 If find(ASHW.ASWK(I).TYPLNK,0,1,2,3,4)>0
  J+=1
  Call AJOUT_LIENS(VARREP+'.LNK('+num$(J)+')',ASHW.ASWK(I),LIGNE,DIF,CLOB)
  Raz LIGNE : Gosub ADDCLB
 Endif
Next
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#-------------------------------------------------------#

Subprog ADD_ATTRIBUTS(CHEMIN,CODEATT,VALATT,LIGNE,DIF,CLOB)
Value Char CHEMIN
Value Char CODEATT
Value Integer VALATT
Variable Char LIGNE
Variable Integer DIF
Variable Clbfile CLOB
LIGNE = CHEMIN +'= NewInstance C_AREPATT AllocGroup REP' : Gosub ADDCLB
DIF += 5
LIGNE = CHEMIN+'.COD = "'+func ASYRSUB.CODATT(CODEATT)+'"'
LIGNE += " : " +CHEMIN+'.ATT = "'+func ASYRSUB.BOOLEAN_TO_SYR(VALATT)+'"'
Gosub ADDCLB
DIF -= 5
End

Subprog AJOUT_ATT(CHEMIN,ATT,LIGNE,DIF,CLOB)
Value Char CHEMIN
Value Instance ATT Using C_ASWATT
Variable Char LIGNE
Variable Integer DIF
Variable Clbfile CLOB
LIGNE = CHEMIN +'= NewInstance C_AREPATT AllocGroup REP' : Gosub ADDCLB
DIF += 5
LIGNE = CHEMIN+'.COD = "'+ATT.COD+'"'
LIGNE += " : " +CHEMIN+'.ATT = "'+ATT.ATT+'"'
Gosub ADDCLB
DIF -= 5
End


#-------------------------------------------------------#
$ADDCLB0

Append CLOB,"&"+space$(DIF)+LIGNE
Raz LIGNE
Return

#-------------------------------------------------------#
Subprog AJOUT_LIENS(CHEMIN,ASWK,LIGNE,DIF,CLOB)
Value Char CHEMIN
Variable Instance ASWK Using C_ASWLNK
Variable Char LIGNE
Variable Integer DIF
Variable Clbfile CLOB
Local Integer I,J,K
LIGNE =  CHEMIN+' = NewInstance C_AREPLNK AllocGroup REP : # '+ASWK.INTITLNK : Gosub ADDCLB
DIF += 5
LIGNE = "Call ASET_AREPLNK("+CHEMIN
LIGNE += ",'"+ASWK.CODLNK+"'"            : # "LIGNE = CHEMIN+'.COD = "'+ASWK.CODLNK+'"'
LIGNE += ','+num$(ASWK.TYPLNK)            : #LIGNE += " : "+CHEMIN+'.TYP = '+num$(ASWK.TYPLNK)
LIGNE += ",'"+ASWK.CODFNCLNK+"'"       : #LIGNE += " : "+CHEMIN+'.FCT = "'+ASWK.CODFNCLNK+'"'
LIGNE += ",'"+ASWK.CLALNK+"'"            : #LIGNE += " : "+CHEMIN+'.CLA = "'+ASWK.CLALNK+'"'
LIGNE += ','+num$(ASWK.CMPLNK)         : #LIGNE += " : "+CHEMIN+'.CMP = ' +num$(ASWK.CMPLNK)
LIGNE += ",'"+ASWK.REPLNK+"'"           : #LIGNE += " : "+CHEMIN+'.REP = "'+ASWK.REPLNK+'"'
LIGNE += ','+num$(ASWK.INTLNK)        : # LIGNE = CHEMIN+'.NAM = '+num$(ASWK.INTLNK)
LIGNE += ','+num$(ASWK.AFFLNK)         : #LIGNE += " : "+CHEMIN+'.AFF = ' +num$(ASWK.AFFLNK)
LIGNE += ",'"+ASWK.BCKLNK+"'"           : #LIGNE = CHEMIN+'.RET = "'+ASWK.BCKLNK+'"'
LIGNE += ",'"+ASWK.ANCLNKREP+"'"           : #LIGNE += " : "+CHEMIN+'.ANC = "'+ASWK.ANCLNKREP+'"'
LIGNE += ','+num$(ASWK.DETLNK)         : #LIGNE += CHEMIN+'.DET = '+num$(ASWK.DETLNK)
LIGNE += ','+num$(ASWK.EDILNK)        : #LIGNE += CHEMIN+'.EDT = '+num$(ASWK.EDILNK)
LIGNE += ','+num$(ASWK.QRYLNK)         : #LIGNE += CHEMIN+'.QRY = '+num$(ASWK.QRYLNK)
LIGNE += ','+num$(ASWK.LOKLNK)        : #LIGNE += CHEMIN+'.LOO = '+num$(ASWK.LOKLNK)
LIGNE += ','+num$(ASWK.SUMLNK)                     : #LIGNE += CHEMIN+'.SRY = '+num$(ASWK.SUMLNK)
LIGNE += ") From ASYRSUBREP" : Gosub ADDCLB
For J=1 To maxtab(ASWK.ATBKEY)
 LIGNE = CHEMIN+'.CLE('+num$(J)+')  = NewInstance C_AREPPAR AllocGroup REP' : Gosub ADDCLB
 DIF += 5
 LIGNE = "Call ASET_AREPPAR("+CHEMIN+'.CLE('+num$(J)+')'
 LIGNE += ",'"+ASWK.ATBKEY(J).CODPAR+"'"
 LIGNE += ','+num$(func ASYRSUB.TYPE_DATA_X3_TO_SYRACUSE(ASWK.ATBKEY(J).TYPINT,0,""))
 LIGNE += ",'"+num$(ASWK.ATBKEY(J).VALEUR)+"'"
 LIGNE += ",'"+num$(ASWK.ATBKEY(J).ALIAS)+"'"
 LIGNE += ','+num$(ASWK.ATBKEY(J).DESPAR)
 If len(num$(ASWK.ATBKEY(J).VALEUR))+len(num$(ASWK.ATBKEY(J).ALIAS))+len(num$(ASWK.ATBKEY(J).DESPAR))+len(num$(ASWK.ATBKEY(J).NOLIB) )+len(num$(ASWK.ATBKEY(J).LNG) )>240
  Gosub ADDCLB
  LIGNE = ""
 Endif
 LIGNE += ','+num$(ASWK.ATBKEY(J).NOLIB)
 LIGNE += ','+num$(ASWK.ATBKEY(J).LNG)
 LIGNE += ','+num$(ASWK.ATBKEY(J).TYPAFF)
 LIGNE += ",'"+num$(ASWK.ATBKEY(J).LOO)+"'"
 LIGNE += ','+num$(ASWK.ATBKEY(J).PARFIL)
 LIGNE += ','+num$(ASWK.ATBKEY(J).PARENT)
 LIGNE += ") From ASYRSUBREP"
 If len(num$(ASWK.ATBKEY(J).VALEUR))+len(num$(ASWK.ATBKEY(J).ALIAS))+len(num$(ASWK.ATBKEY(J).DESPAR))+len(num$(ASWK.ATBKEY(J).NOLIB) )+len(num$(ASWK.ATBKEY(J).LNG) )>240
  Gosub ADDCLB0
 Endif
 Gosub ADDCLB
 DIF -= 5
Next
For J=1 To maxtab(ASWK.ATBPAR)
 LIGNE = CHEMIN+'.PAR('+num$(J)+')  = NewInstance C_AREPPAR AllocGroup REP' : Gosub ADDCLB
 DIF += 5
 LIGNE = "Call ASET_AREPPAR("+CHEMIN+'.PAR('+num$(J)+')'
 LIGNE += ",'"+ASWK.ATBPAR(J).CODPAR+"'"
 LIGNE += ','+num$(func ASYRSUB.TYPE_DATA_X3_TO_SYRACUSE(ASWK.ATBPAR(J).TYPINT,0,""))
 LIGNE += ",'"+num$(ASWK.ATBPAR(J).VALEUR)+"'"
 LIGNE += ",'"+num$(ASWK.ATBPAR(J).ALIAS)+"'"
 LIGNE += ','+num$(ASWK.ATBPAR(J).DESPAR)
 If len(num$(ASWK.ATBPAR(J).VALEUR))+len(num$(ASWK.ATBPAR(J).ALIAS))+len(num$(ASWK.ATBPAR(J).DESPAR))+len(num$(ASWK.ATBPAR(J).NOLIB) )
& +len(num$(ASWK.ATBPAR(J).LNG) )>240
  Gosub ADDCLB
  LIGNE = ""
 Endif
 LIGNE += ','+num$(ASWK.ATBPAR(J).NOLIB)
 LIGNE += ','+num$(ASWK.ATBPAR(J).LNG)
 LIGNE += ','+num$(ASWK.ATBPAR(J).TYPAFF)
 LIGNE += ",'"+num$(ASWK.ATBPAR(J).LOO)+"'"
 LIGNE += ','+num$(ASWK.ATBPAR(J).PARFIL)
 LIGNE += ','+num$(ASWK.ATBPAR(J).PARENT)
 LIGNE += ") From ASYRSUBREP"
 If len(num$(ASWK.ATBPAR(J).VALEUR))+len(num$(ASWK.ATBPAR(J).ALIAS))+len(num$(ASWK.ATBPAR(J).DESPAR))+len(num$(ASWK.ATBPAR(J).NOLIB) )
& +len(num$(ASWK.ATBPAR(J).LNG) )>240
  Gosub ADDCLB0
 Endif
 Gosub ADDCLB
 DIF -= 5
Next

For I=1 To maxtab(ASWK.ATT)
 Call AJOUT_ATT(CHEMIN+".ATT("+num$(I)+")",ASWK.ATT(I),LIGNE,DIF,CLOB)
Next
For I=1 To maxtab(ASWK.ALNK)
 Call AJOUT_LIENS(CHEMIN+".LNK("+num$(I)+")",ASWK.ALNK(I),LIGNE,DIF,CLOB)
 Raz LIGNE : Gosub ADDCLB
Next
If find(ASWK.TYPLNK,2,3)>0
  LIGNE = CHEMIN+'.MET  = NewInstance C_AREPMET AllocGroup REP' : Gosub ADDCLB
  DIF += 5
  LIGNE = CHEMIN+'.MET.COD= "'
  If ASWK.TYPLNK=2
   LIGNE += ASWK.CODMETLNK
  Else
  LIGNE += ASWK.CODOPELNK
  Endif
  LIGNE += '" : '+CHEMIN+'.MET.INS= "'+ASWK.CLAPTRLNK+'"'
  Gosub ADDCLB
  DIF -= 5
Endif
DIF -= 5
End


$ALOAD_LINKS_DET_PAGE_REP
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# load links page" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "Subprog ALOAD_LINKS_DET_PAGE(REP)" : Gosub ADDCLB
LIGNE = "Variable Instance REP Using R_"+ASHW.CODREP : Gosub ADDCLB
Raz J
For I=1 To maxtab(ASHW.ASWK)
 If find(ASHW.ASWK(I).AFFLNK,4,5)>0 and ASHW.ASWK(I).DETLNK=2
  J+=1
  LIGNE =  VARREP+'._ASTADETLNK('+num$(J)+') = NewInstance C_ASTATUSLINK AllocGroup REP: # '-ASHW.ASWK(I).CODLNK : Gosub ADDCLB
  DIF += 5
  LIGNE =  VARREP+'._ASTADETLNK('+num$(J)+').CODLNK = "'+ASHW.ASWK(I).CODLNK+'"' : Gosub ADDCLB
  LIGNE =  VARREP+'._ASTADETLNK('+num$(J)+').ORICODLNK = "'+ASHW.ASWK(I).ORICODLNK+'"' : Gosub ADDCLB
  LIGNE =  VARREP+'._ASTADETLNK('+num$(J)+').ISDISABLED = [V]CST_AFALSE' : Gosub ADDCLB
  DIF -= 5
 Endif
Next
LIGNE = "End": Gosub ADDCLB
LIGNE = "": Gosub ADDCLB
Return

#-------------------------------------------------------#
$COLLECTIONS_REP
Local Integer ISOKGRI
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Collections de la reprûˋsentation" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$COLLECTIONS_REP" : Gosub ADDCLB
I=0
For M=1 To ASHW.NBRGRP
 If !instr(1,ASHW.CODGRP(M),".")
 Raz J,ISOKGRI
 For J=1 To maxtab(ASHW.PTHGRI)
  If ASHW.PTHGRI(J)=ASHW.CODGRP(M)
   ISOKGRI=1
   Break
  Endif
 Next
 If ISOKGRI>0
  I+=1
  LIGNE =  VARREP+'.COL('+num$(I)+') = NewInstance C_AREPCOL AllocGroup REP: # '-ASHW.INTITGRP(M) : Gosub ADDCLB
  DIF += 5
  LIGNE = "Call ASET_AREPCOL("+VARREP+'.COL('+num$(I)+')'
  LIGNE += ','+num$(ASHW.MINGRP(M))
  LIGNE += ','+num$(ASHW.MAXGRP(M))
  LIGNE += ',"'+ASHW.PTHGRI(J)+'"'
  LIGNE += ',"'+ASHW.GRPGRI(J)+'"'
  #If ASHW.MAXGRP(M)=1
  #On met 2 ssi 1-1 ou Max-1 mais pas pour 0-1
  If ASHW.MAXGRP(M)=1 & ASHW.MINGRP(M)<>1
   LIGNE += ",2"
  Else
   LIGNE +=','+num$(ASHW.ONE(J))
  Endif
  LIGNE += ','+'1'
  LIGNE += ','+num$(ASHW.FLGINSGRP(M))
  LIGNE += ','+num$(ASHW.FLGAPDGRP(M))
  LIGNE += ','+num$(ASHW.FLGTRIGRP(M))
  LIGNE += ','+num$(ASHW.FLGSUPGRP(M))
  LIGNE += ','+num$(ASHW.NBRPROGRP(M))
  LIGNE += ','+num$(ASHW.INTGRP(M))
  LIGNE += ") From ASYRSUBREP" : Gosub ADDCLB
  DIF -= 5
 Endif
Endif
Next
#For J=1 To maxtab(ASHW.PTHGRI)
# LIGNE ="###"-ASHW.PTHGRI(J)-"--"-ASHW.GRPGRI(J) : Gosub ADDCLB
#  For K=1 To ASHW.ACLAGRI(J).NBRGRP
#  LIGNE ="#"-ASHW.PTHGRI(J)-"----"-ASHW.PTHGRI(J)+"."+ASHW.ACLAGRI(J).CODGRP(K) : Gosub ADDCLB
# Next
#Next
For J=1 To maxtab(ASHW.PTHGRI)
 For K=1 To ASHW.ACLAGRI(J).NBRGRP
  Raz ISOKGRI
  For M=1 To maxtab(ASHW.PTHGRI)
   If ASHW.PTHGRI(M)=ASHW.PTHGRI(J)+"."+ASHW.ACLAGRI(J).CODGRP(K)
    ISOKGRI = 1
    Break
   Endif
  Next
  If ISOKGRI>0
   I+=1
   LIGNE =  VARREP+'.COL('+num$(I)+') = NewInstance C_AREPCOL AllocGroup REP : # '+ASHW.ACLAGRI(J).INTITGRP(K) : Gosub ADDCLB
   DIF += 5
   LIGNE = "Call ASET_AREPCOL("+VARREP+'.COL('+num$(I)+')'
   LIGNE += ','+num$(ASHW.ACLAGRI(J).MINGRP(K))
   LIGNE += ','+num$(ASHW.ACLAGRI(J).MAXGRP(K))
   LIGNE += ',"'+ASHW.PTHGRI(M)+'"'
   LIGNE += ',"'+ASHW.GRPGRI(M)+'"'
   #If ASHW.ACLAGRI(J).MAXGRP(K)=1
   #On met 2 ssi 1-1 ou Max-1 mais pas pour 0-1
   If ASHW.ACLAGRI(J).MAXGRP(K)=1 & ASHW.ACLAGRI(J).MINGRP(K)<>1
    LIGNE += ",2"
   Else
    LIGNE +=','+num$(ASHW.ONE(J))
   Endif
   LIGNE += ','+'1'
   LIGNE += ','+num$(ASHW.ACLAGRI(J).FLGINSGRP(K))
   LIGNE += ','+num$(ASHW.ACLAGRI(J).FLGAPDGRP(K))
   LIGNE += ','+num$(ASHW.ACLAGRI(J).FLGTRIGRP(K))
   LIGNE += ','+num$(ASHW.ACLAGRI(J).FLGSUPGRP(K))
   LIGNE += ','+num$(ASHW.ACLAGRI(J).NBRPROGRP(K))
   LIGNE += ','+num$(ASHW.ACLAGRI(J).INTGRP(K))
   LIGNE += ") From ASYRSUBREP" :  Gosub ADDCLB
   DIF -= 5
  Endif
 Next
Next
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

