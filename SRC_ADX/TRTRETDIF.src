#<AdxTL>@(#)9.0.0.0 $Revision$
#---------------------------------------------------------------------------
# TRTRETDIF : Différence entre deux contrats (72211)
#---------------------------------------------------------------------------
###############
$ACTION
Case [L]ACTION
  When "OUVRE" : Gosub OUVRE
  When "DEBUT" : Gosub DEBUT
Endcase
Return

###########################
$OUVRE
Local Integer LONHICIDCLE, LONHICCLE
If func AFNC.ACTIV("HIC") > 0
 If !clalev([F:HIC]) : Local File HISTOCTX [HIC] : Endif
Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If !clalev([F:CTRW])  : Local File EMPLOCTR [CTRW]  : Endif
If !clalev([F:CTRX]) : Local File EMPLOCTR [CTRX] : Endif
If !clalev([F:VEPW])  : Local File VALEMP   [VEPW]  : Endif
If !clalev([F:HIC])  : Local File HISTOCTX [HIC]  : Endif
If !clalev([F:HIC2]) : Local File HISTOCTX [HIC2] : Endif
If !clalev([F:DIC])  : Local File DICOEMP  [DIC]  : Endif

If clalev([F:HIC]) > 0
 [L]LONHICIDCLE = type([F:HIC]HICIDCLE)-10
 [L]LONHICCLE = type([F:HIC]HICCLE)-10
Else
 [L]LONHICIDCLE = 5 : [L]LONHICCLE = 80
Endif

Local Char WREFNUMORI([V]GLONEML), WCTRNUMORI([V]GLONHRCTR), WCTRNUMDST([V]GLONHRCTR)
Local Date WCTRDATORI, WCTRDATDST
Local Integer WHICORI
Local Char WHICIDCLE([L]LONHICIDCLE)

#En prévision d'évolution future...
WHICORI=1
WHICIDCLE="VEP"

Local Char WBULORI (GLONVCR), WBULDES (GLONVCR)
Local Char WCPYORI (GLONFCY), WCPYDES (GLONCPY)
Local Date WPYRDATORI, WPYRDATDES
Return

#################
$DEBUT
Gosub AFFECT
If [M:DIA]REFNUMORI <> "" & [M:DIA]REFNUMDST <> ""
 Gosub CHARGEMENT
 If WBULDES<>""
  Gosub COMPARE
 Endif
Endif
Affzo [M:DIA]
Return

################
$AFFECT
# Récupération des paramètres dans quelques variables de travail des fois qu'on bricole ...
[L]WREFNUMORI = [L]PARAM(1)
[L]WCTRNUMORI = [L]PARAM(2)
[L]WCTRDATORI = [L]PARAM(3)
[L]WCTRNUMDST = [L]PARAM(4)
[L]WCTRDATDST = [L]PARAM(5)
Raz [M:DIA]
[M:DIA]REFNUMORI = [L]WREFNUMORI
[M:DIA]REFNUMDST = [L]WREFNUMORI
[M:DIA]CTRNUMDST = [L]WCTRNUMDST
[M:DIA]CTRDATDST = [L]WCTRDATDST

If [L]WCTRNUMORI<>""
 [M:DIA]CTRDATORI = [L]WCTRDATORI
 [M:DIA]CTRNUMORI = [L]WCTRNUMORI
Else
 [M:DIA]CTRDATORI = [L]WCTRDATDST
 [M:DIA]CTRNUMORI = [L]WCTRNUMDST
Endif
Return

#################
$CHARGEMENT
Raz WBULORI, WBULDES
Read [F:CTRW]CTR0 = [M:DIA]REFNUMORI ; [M:DIA]CTRNUMORI ; [M:DIA]CTRDATORI
If !fstat
 Call LECTURE("FCY",[F:CTRW]ETRFCY,"") From CONTOBJ
 WCPYORI=[F:FCY]LEGCPY
 If GNBLEG = 1
  GCURLEG = GDOSLEG
 Else
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  GCURLEG=[F:CPY]LEG
 Endif
 Filter [F:VEPW] Where EMP=[F:CTRW]REFNUM & CTRNUM=[F:CTRW]CTRNUM & CTRDAT=[F:CTRW]CTRDAT & RVS<>2 & STA>1
 Read [F:VEPW]VEP0 Last
 Filter [F:VEPW]
 If !fstat : WBULORI=[F:VEPW]BUL : WPYRDATORI=[F:VEPW]PYRDAT : Endif
Endif
If WBULORI<>""
 Read [F:CTRX]CTR0 = [M:DIA]REFNUMDST ; [M:DIA]CTRNUMDST ; [M:DIA]CTRDATDST
 If !fstat
  Call LECTURE("FCY",[F:CTRX]ETRFCY,"") From CONTOBJ
  WCPYDES=[F:FCY]LEGCPY
 If GNBLEG = 1
  GCURLEG = GDOSLEG
 Else
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  GCURLEG=[F:CPY]LEG
 Endif
  Filter [F:VEPW] Where EMP=[F:CTRX]REFNUM & CTRNUM=[F:CTRX]CTRNUM & CTRDAT=[F:CTRX]CTRDAT & RVS<>2 & STA>1
  Read [F:VEPW]VEP0 Last
  Filter [F:VEPW]
  If !fstat : WBULDES=[F:VEPW]BUL : WPYRDATDES=[F:VEPW]PYRDAT : Endif
 Endif
Endif
Return

#Comparaison entre les infos du contrat utilisées dans le dernier bulletin lié au contrat d'origine
#et les infos du contrat utilisées dans le bulletin contenant les rappels
########################
$COMPARE
nolign=1
For [HIC]HIC1 Where HICORI=WHICORI & HICIDCLE=WHICIDCLE & HICCLE=WBULORI
 If nolign>dim([M:DIA]FLD)
    Break
 Endif
 Read[HIC2]HIC1=[F:HIC]HICORI;[F:HIC]HICIDCLE;WBULDES;[F:HIC]HICATB;[F:HIC]HICATZ
 If !fstat & [F:HIC]HICVAL<>[F:HIC2]HICVAL
  If right$([F:HIC]HICATZ,1+len([F:HIC]HICATZ)-3)="(0)"
   [M:DIA]FLD(nolign-1)=left$([F:HIC]HICATZ,len([F:HIC]HICATZ)-3)
  Else
   [M:DIA]FLD(nolign-1)=[F:HIC]HICATZ
  Endif
  Read [F:DIC]DIC0=[M:DIA]FLD(nolign-1)
  If !fstat & [F:DIC]FLGRET=2
   [M:DIA]DES(nolign-1)=[F:DIC]DES
   Call TEXTE([M:DIA]DES(nolign-1),[M:DIA]WDES(nolign-1)) From OBJDIV
   [M:DIA]VALORI(nolign-1)=[F:HIC]HICVAL
   [M:DIA]VALDST(nolign-1)=[F:HIC2]HICVAL
   nolign+=1
  Endif
 Endif
Next
[M:DIA]NBLIG=nolign-1
Return
