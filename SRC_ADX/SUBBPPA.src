#If GOK < 1 : Return : Endif

#CRM
Gosub MODIF_CRM From TRTBPCRM
If GOK < 1 : Return : Endif

Return

#######################################################################
$ANNULE
#---- lecture bpartner pour depositionner le flag PPTFLG   #
Update [BPR] Where [F:BPR]BPRNUM = [M:BPP0]BPCNUM With PPTFLG = 1
If fstat <> 0
    GERR=1 : GMESSAGE = mess(4,192,1) : GOK = 0 : Return
Endif
If clalev([F:W01]) & dim([F:W01]PPTFLG)>0
    Update [W01] Where [F:W01]BPRNUM = [M:BPP0]BPCNUM With PPTFLG = 1
    If fstat <> 0
        GERR=1 : GMESSAGE = mess(4,192,1) : GOK = 0 : Return
    Endif
Endif
Return

########################################
$CREBPR
#Local Shortint I,J,K
#I = find (2,[M:BPAP]BPAADDFLG (0..[M:BPAP]NBADR -1))
#If I <> 0     I -= 1 : Endif
#If I < 0      I = 0  : Endif
#J = ([M:CNTP]NBCNT>0)*max(1,find (2,[M:CNTP]CNTFLG (0..[M:CNTP]NBCNT -1)))

#J = ([M:CNTP]NBCNT>0)*max(1,find (2,[M:CNTP]CNTFLG (0..[M:CNTP]NBCNT -1))  )

Look [BPR]BPR0 = [F:BPC]BPCNUM
If fstat <> 0
     Raz [F:BPR]
     [F:BPR]          = [M:BPRP]
     [F:BPR]BPRNUM    = [F:BPC]BPCNUM
     [F:BPR]BPAADD    = [F:BPC]BPAADD
     [F:BPR]CNTNAM    = [F:BPC]CNTNAM
#     [F:BPR]BPAADD    = [M:BPAP]CODADR (I)

#     If   J <> 0 : [F:BPR]CNTNAM    = [M:CNTP]CCNCRM (J-1)
#     Else          [F:BPR]CNTNAM    = ""
#     Endif

     [F:BPR]BIDNUM    = ""
     [F:BPR]BIDCRY    = ""
     [F:BPR]BPSFLG    = 1
     [F:BPR]BPTFLG    = 1
     [F:BPR]REPFLG    = 1
     [F:BPR]FCTFLG    = 1

#-- pas celui de tiers divers
#    [F:BPR]BPRACC    = 1
     For I = 0 To 3
         [F:BPR]BPRFLG (I) = 1
     Next I
     [F:BPR]ENAFLG    = 2
     [F:BPR]BPCFLG    = 1
     [F:BPR]PPTFLG    = 2
     [F:BPR]CREDAT    = date$
     [F:BPR]CREUSR    = GUSER
     [F:BPR]BRGCOD    = [F:BPC]BCGCOD
     [F:BPR]BRGOBJ    = "BPC"
     Write [BPR]
     If fstat
            GOK = 0 : Call FSTA("BPR") From GLOCK
     Endif
Else
     Readlock [BPR]BPR0 = [F:BPC]BPCNUM
     If    fstat = 1
           GOK = -1 : GLOCK = "$BPARTNER"-[F:BPC]BPCNUM : Return
     Endif
     Local Char WSAV_CUR(GLONCUR)
     [L]WSAV_CUR      = [F:BPR]CUR        : # Sauvegarde devise tiers
     [F:BPR]          = [M:BPRP]
     [F:BPR]CUR       = [L]WSAV_CUR       : # Restitution devise tiers
     [F:BPR]BPRNUM    = [F:BPC]BPCNUM
#     [F:BPR]BPAADD    = [M:BPAP]CODADR (I)

#     If   J <> 0 : [F:BPR]CNTNAM    = [M:CNTP]CCNCRM (J-1)
#     Else          [F:BPR]CNTNAM    = ""
#     Endif

    # X3-107151 (LCC 07/09/18) CNTNAM is not ok in the bpartner's table
    Local Shortint K: K=0
    If [M:CNTP]NBCNT>0
      K = find ([F:BPR]CNTNAM,[M:CNTP]CCNCRM (0..[M:CNTP]NBCNT-1))
    Endif
    ## If the CNTNAM field is an existing contact there is nothing to do
    If K=0
      [F:BPR]CNTNAM    =  [F:BPC]CNTNAM
    Endif
    ###
    # We check the default contact in Suppliers Table
    ###
    If [F:BPR]BPSFLG=2
      If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
      Readlock [F:BPS]BPS0=[F:BPC]BPCNUM
      If !fstat
        K=0
        If [M:CNTP]NBCNT>0
          K = find ([F:BPS]CNTNAM,[M:CNTP]CCNCRM (0..[M:CNTP]NBCNT-1))
        Endif
      ## If the CNTNAM field is an existing contact there is nothing to do
        If K=0
          [F:BPS]CNTNAM    = [F:BPC]CNTNAM
          Rewrite [F:BPS]
          If fstat GOK=0 : Call FSTA("BPS") From GLOCK : Endif
        Endif
      Endif
    Endif
    ###
    # We check the default contact in Carriers Table
    ###
    If [F:BPR]BPTFLG=2
      If clalev([F:BPT])=0 : Local File BPCARRIER[BPT] : Endif
      Readlock [F:BPT]BPT0=[F:BPC]BPCNUM
      If !fstat
        K=0
        If [M:CNTP]NBCNT>0
          K = find ([F:BPT]CNTNAM,[M:CNTP]CCNCRM (0..[M:CNTP]NBCNT-1))
        Endif
      ## If the CNTNAM field is an existing contact there is nothing to do
        If K=0
          [F:BPT]CNTNAM    = [F:BPC]CNTNAM
          Rewrite [F:BPT]
          If fstat GOK=0 : Call FSTA("BPT") From GLOCK : Endif
        Endif
      Endif
    Endif
    # END X3-107151 (LCC 07/09/18) CNTNAM is not ok in the bpartner's table

     [F:BPR]BIDNUM    = ""
     [F:BPR]BIDCRY    = ""
     [F:BPR]PPTFLG    = 2
     [F:BPR]BPCFLG    = 1
     [F:BPR]UPDDAT    = date$
     [F:BPR]UPDUSR    = GUSER
     Rewrite [BPR]
     If fstat
            GOK = 0 : Call FSTA("BPR") From GLOCK
     Endif
Endif
Return

########################################
$CREBPA
#-------------------------#
#    A SUPPRIMER          #
#-------------------------#
#Call CREBPA_CPYFCY(GABREV,[M:BPP0]BPCNUM,1) From TRTADR
#If   GOK < 1 : Return :ENDIF
#-------------------------#

Default Mask [BPAP]
Call CREBPA(WBPATYP,[M:BPP0]BPCNUM) From TRTBPA
If GOK < 1 : Return : Endif
Return

########################################
$CRECNT
#-------------------------#
#    A SUPPRIMER          #
#-------------------------#
#Call CRECNT_CPYFCY(GABREV,[M:BPP0]BPCNUM,1) From TRTADR
#If   GOK < 1 : Return :ENDIF
#-------------------------#
Default Mask [CNTP]
Call CRECNT(WBPATYP,[M:BPP0]BPCNUM) From TRTBPA
If GOK < 1 : Return : Endif

  Call MAJ_CNTNAM("[F:BPP]") From SUBBPR  # FGR 10/01/2013 X3SUIVI83886
Return

########################################
$VERIFCRE_MOD
#----------------------------------#
# on verifie qu'une adresse existe #
#----------------------------------#
If [M:BPAP]NBADR = 0
    GERR=1 : GMESSAGE=mess(31,199,1) : OK = 0 : Return
Endif
#---------------------------------------------------#
# on verifie qu une adresse est désignée par défaut #
#---------------------------------------------------#
If find (2,[M:BPAP]BPAADDFLG (0..[M:BPAP]NBADR -1)) = 0
    GERR=1: GMESSAGE= mess(110,199,1) : OK=0 : Return
Endif

Local Integer IZ2
IZ2 = 0
For IZ2 = 0 To [M:BPAP]NBADR - 1
    If [M:BPAP]BPAADDFLG(IZ2) = 2
        [M:BPRP]BPAINV = [M:BPAP]CODADR(IZ2)
        Break
    Endif
Next

Return
