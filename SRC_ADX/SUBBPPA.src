#<AdxTL>@(#)2.0.0.0 $Revision$
Call OBJET ("BPP",GBIDC1,GBIDC2) From GOBJET
End

#######################################################################
#   Compléments sur la saisie des prospects (suite SUBBPP )           #
#                                                 19 Juillet 2000     #
#######################################################################
$OUVRE
If !clalev([F:BPR1]) : Local File BPARTNER [BPR1] : Endif

Global Integer GIOBPP_MODIF
GIOBPP_MODIF=0

Global Integer GIBPPEXIST
GIBPPEXIST = 0

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB

Local Integer WBPATYP : WBPATYP = 1
If GMODU(7)=2 GLOCSEL = "[F:STC]LOCCAT=3" Endif
#--- pour ajouter dans le menu contextuel
#MAE, le 06/01/09, on ne se sert plus de ces variables
#If !GIMPORT
#    GSTATEX1 = 2001
#    GSTATEX2 = 2002
#    GSTAOPT1 = 2003
#    GSTAOPT2 = 2004
#    GSTAOPT3 = 2005
#    GSTAOPT4 = 2006
#    GSTAOPT5 = 2007
#Endif
Local Integer SPSTAT
Local Char    SYMBOLE2 (20)   : # cg le 28/01/98
#---- positionnement sur écran 2 (bpc1) si on vient du tiers #
If    clalev ([M:BPR0])
      PRMASK = 3
Endif

#-----------------------------------------------------#
# récupération devise société                         #
#-----------------------------------------------------#
Local Char WLEGCPY(GLONCPY)
Local Char WFINRSPFCY (GLONFCY)

WFINRSPFCY = GFCYDEF(9)
WLEGCPY = ""
#---- devise site alimentée par devise dossier ----#
GCUR= GSYSCUR
#---- lecture du site par défaut ----#
If GFCYDEF (9) <> ""
       If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif

       Read [FCY]FCY0 = GFCYDEF(9)
       If fstat = 0
                WLEGCPY    = [F:FCY]LEGCPY
                WFINRSPFCY = [F:FCY]FINRSPFCY
       Endif
Endif

#---- lecture société correspondant au site ----#
If clalev([F:CPY]) = 0 : Local File COMPANY [CPY] : Endif
If WLEGCPY <> ""
     Read [CPY]CPY0 = WLEGCPY
     If fstat = 0 : GCUR = [F:CPY]ACCCUR : Endif
Endif

#-- si pas de cours entre devise dossier et devise affichage
#-- la devise affichage devient la devise de reporting
#-- cg le 14 septembre 99 demande numéro ????

GBIDD1 = 0
GBIDD2 = 0

Call CONVERT(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,GBIDD1,GBIDD2,SPSTAT) From TRTDEV
If SPSTAT <> 0
        GCUR = GSYSCUR
Endif

#-----------------------#
# decimal de la devise  #
#-----------------------#
Local Decimal WDECIMAL
WDECIMAL = 0
Read [TCU]TCU0= GCUR
If fstat = 0
    WDECIMAL = [F:TCU]CURRND
Endif
#---- alimentation variables globales ventes
Call GLOBVAR(WFINRSPFCY) From WWGLOBVEN

#-----------------------------------------------------#
Global Char GSZPROSPCOD
GSZPROSPCOD = ""

#Récupération de la famille statistique de produit
#Call USEFAMCIA From CRM_UTIL

#Initialisation CRM
Gosub OUVRE_CRM From TRTBPCRM
GSZCRMOBJET="BPP"

Return

###################################################################
$AFFMASK
Grizo [M:BPRP]BETFCY, FCY
If dim([M:BPP1]COMCAT)>0
    If GCOMCAT=0
        Grizo [M:BPP1]COMCAT
    Else
        Actzo [M:BPP1]COMCAT
    Endif
Endif
Return

####################################################################
$FERME
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB

If GFONC1="GESBPP" Raz GFONC1 : Endif

#CRM
Gosub FERME_CRM From TRTBPCRM

#---------------------------------------------------#
Kill GSZPROSPCOD
#Nettoie les infos relative à la famille statistique de produits
#Call UNUSEFAMCIA From CRM_UTIL
Kill GIBPPEXIST

Return


####################################################################
$SETBOUT
  # Si on vient de transformer le prospect en client : tout bloquer
  If [M:BPRP]BPCFLG=2
    Call VIREBOUT(CHAINE,"AM1") From GOBJET
    Return
  Endif
  Case REP
    When "M", "C", "D"
      Call VIREBOUT(CHAINE,"1") From GOBJET
    When Default
  Endcase
  # FGR 09/10/2007 : X3SUIVI43454 : si le prospect est verrouillé par qqu'un d'autre on grise le bouton Client
  If VERROU = 0 Then
    Call VIREBOUT(CHAINE, "1") From GOBJET
  Endif
  # --------------------------------------------------------------------------------------- #
  # Activation/Désactivation des menus                                                      #
  # --------------------------------------------------------------------------------------- #
  #   L : Consultation devis    : Actif si prospect en ligne, module vente                  #
  #   Q : Dernières opérations  : Actif si rien en cours                                    #
  #   D : Transformer en client : Actif si rien en cours                                    #
  #   5 : Secteurs de marché    : Actif si rien en cours, module action commerciale         #
  #   K : Historique            : Actif si rien en cours, module action commerciale         #
  # --------------------------------------------------------------------------------------- #
  If REP = "" Then
    CHMEN += "Q"
  Endif
  If CLECUR & GMODU(5)=2
    CHMEN += "L"
  Endif
  #Historique
  If REP = "" Then
    CHMEN += "K"
  Endif

  #Menu Actions   Module Action Co
  # } : Enregistrer un rendez-vous
  # { : Enregistrer un appel
  # ~ : Enregistrer une tâche
  # ! : Enregistrer une affaire
  # ) : Planifier un rendez-vous
  # ( : Planifier un appel
  # £ : Planifier une tâche
  If REP="" & GMODU(13)=2 & GACTFTC=2
    CHMEN += "}{~!)(£5"
  Endif
  If REP = "" & GMODU(13)=2
    CHMEN += "EFHJK"
  Endif

  #-------------------------------------
  Gosub SET_BOUT_SPE From GSAISIE
  Call VIREBOUT(CHAINE,"AH") From GOBJET
Return

###########################################################################################
#    Après execution des boutons                                                          #
###########################################################################################
$EXEBOUT
  Case BOUT
    When "1"
      Gosub RELIT From GOBJSUB       : # Client
  Endcase
Return



########################################################################
$AVANTBOUT
[M:BPP0]NVGCOD = BOUT

If GMODU(13)=2
    Case BOUT
        When ")"
            #Planifier Rendez-vous
            GBCRMFLGNEW=1
        When "("
            #Planifier Appel
            GBCRMFLGNEW=1
        When "£"
            #Planifier tache
            GBCRMFLGNEW=1

        When "}"
            #Enregistrer Rendez-vous
            GBCRMFLGNEW=1
        When "{"
            #Enregistrer Appel
            GBCRMFLGNEW=1
        When "~"
            #Enregistrer tache
            GBCRMFLGNEW=1
        When "!"
            #Enregistrer une affaire
            GBCRMFLGNEW=1
    Endcase
Endif

Return

###########################################################################################
#    Après execution des menus;;                                                          #
###########################################################################################
$STATUT
Case BOUT
    When "D"     : Gosub RELIT From GOBJSUB       : # Transformation

    When "5"
        #LSE 13/03/2007 rechargement si modif apres action SAIMST9
        If GIOBPP_MODIF=1
            If !GIMPORT Gosub RELIT From GOBJSUB : Endif
        Endif

Endcase
Return

###################################################################
$LIENS

Local Char WCUR (3)
Local Decimal WMONTORG (0..10)
Local Decimal WMONTDES (0..10)

# Pour multi-soc
#If dim([M:BPP0]SOC)>0
#  If [M:BPP0]SOC="" & GSOCIETE=""
#    Call GETDEV(GFCYDEF(0)) From DEVSUB
#  Endif
#  [M:BPP0]SOC = GSOCIETE
#  GSOCIETE = [M:BPP0]SOC
#Endif

GIBPPEXIST = 0

[M]WORDTEX = 2
If [M]ORDTEX = "" [M]WORDTEX = 1 Endif
[M]WINVTEX = 2
If [M]INVTEX = "" [M]WINVTEX = 1 Endif

If [F:BPC]BCGCOD<>""
   Read [BCG]BCG0=[F:BPC]BCGCOD
   [M:BPP0]REFCOU=[F:BCG]REFCOU
Endif


# Pb en import
# Il ne faut pas écraser [F:BPR] qui peut être chargé avec des champs à importer (Ex import de la raison sociale)
# ==> Lecture du tiers sous une autre abréviation
Read [BPR]BPR0 = [M:BPP0]BPCNUM
If fstat = 0
    [M:BPRP] = [F:BPR]
    [M:BPP0]BPCNAM = [F:BPR]BPRNAM
    [M:BPRP]CUR    = [F:BPC]CUR   : # Récupération devise client
Else
    Raz [M:BPRP]
Endif

Default Mask [BPAP]
Call CHARG_BPA(WBPATYP,[M:BPP0]BPCNUM,[F:BPC]BPAADD) From TRTBPA
Default Mask [CNTP]
Call CHARG_CNT(WBPATYP,[M:BPP0]BPCNUM,[F:BPC]CNTNAM) From TRTBPA
Gosub DEFAUT

#Affiche l'enregistrement en tant que prospect
#If [F:BPC]PPTFLG = 2
If [F:BPC]BPCTYP = 4
    [M:BPRP]PPTFLG = 2
    [M:BPRP]BPCFLG = 1
Endif
Affzo [M:BPRP]1-99

GSZPROSPCOD = [M:BPP0]BPCNUM

#Neutralise la fonction inter-site
#[M:BPRP]BETFCY = 1
#[M:BPRP]FCY = ""
#Grizo [M:BPRP]BETFCY
#Grizo [M:BPRP]FCY

#LSE 02/03/2007
##---------------------------------------------------#
##Modif CRM 10/01/2002
#If GMODU(13) = 2
#    Call SETPREREP("BPP") From TRTMST4
#Endif
#---------------------------------------------------#

#---------------------------------------------------#
#Modif CRM 01/07/2003
If GMODU(13) = 2
    #Affichage de la présence de représentants secondaires.
    [M:BPP1]MORREP = ""
    Filter [RSE] Where [F:RSE]BPCNUM = [M:BPP0]BPCNUM
    For [RSE]
        [M:BPP1]MORREP = "+"
        Break
    Next
    Filter [RSE]
    Affzo [M:BPP1]MORREP
Endif
#---------------------------------------------------#

#Initialisation CRM
Gosub LIENS_CRM From TRTBPCRM

#MAE, lecture du tiers pour les workflows, ne pas écraser, bg 67131
If !GIMPORT
  If !clalev([F:BPRW]) : Local File BPARTNER [BPRW] : Endif
  If [M:BPP0]BPCNUM <> ""
    Read [BPRW]BPR0 = [M:BPP0]BPCNUM
    If fstat Raz [F:BPRW] Endif
  Endif
Endif


Return

####################################################################
$DEFAUT
For MA=0 To NBMASK
 If AMA(MA)
  Gosub SETMASK From="WGO"+GABREV
 Endif
Next MA
Return

###################################################################
$RAZCRE

Grizo [M:BPRP]BETFCY, FCY

#If dim([M:BPP0]SOC)>0
#    GSOCIETE = [M:BPP0]SOC
#Endif

If [M:BPP0]BCGCOD <> ""
  Call INI_BCGCATEG([M:BPP0]BCGCOD) From SUBBPP
Endif


# Ne pas écraser les zones qui ont pu venir du tiers
If [M:BPRP]CRY = ""
    [M:BPRP]CRY = GPAYS
    If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
    If [F:TCY]CRY <> GPAYS
        Read [TCY]TCY0 = GPAYS
        If fstat Raz [F:TCY] Endif
    Endif
    [M:BPRP]LAN = [F:TCY]LAN
    [M:BPRP]CUR = [F:TCY]CUR
Endif
#---------------------------------------------------#
# init. type entité en création pour le subbpa      #
#---------------------------------------------------#
[F:BPA]BPATYP = WBPATYP
[M:BPP1]BPCSTA = 2
[M:BPP1]WORDTEX = 1
[M:BPP1]WINVTEX = 1
[M:BPP1]ORDTEX  = ""
[M:BPP1]INVTEX  = ""
[M:BPRP]PPTFLG = 2
[M:BPP1]PPTFLG = 2
[M:BPP1]BPCTYP = 4

Call DEFVALADI(425, [M:BPP1]BUS) From CRMUTIL140

#CRM
#Gosub RAZCRE_CRM From TRTBPCRM        # FGR 27/04/2016 : X3SUIVI116131 : trop tôt. A faire après l'application de la catégorie

#Affzo [M:BPP1]BUS
#LSE 06/02/2007
Affzo [M:BPP0]1-99
Affzo [M:BPRP]1-99
Affzo [M:BPAP]1-99
Affzo [M:BPP1]1-99
Affzo [M:CNTP]1-99

Return

###################################################################
$RAZDUP

Grizo [M:BPRP]BETFCY, FCY
#---------------------------------------------------#
#Modif CRM 6/12/2002
#---------------------------------------------------#
If !GIBPPEXIST
    #Voulez-vous partager les interlocuteurs de la société XXXX ?
    Local Integer IASKBPR
    Local Char SZMESS(250)
    IASKBPR = 0
    If [M:CNTP]NBCNT > 0
        SZMESS = mess(834, 196, 2) + ' ' + [M:BPP0]BPCNUM
        Call OUINON(SZMESS, IASKBPR) From GESECRAN
        If IASKBPR <> 2
            Raz [M:CNTP]
            Raz [M:CNTP]NBCNT
            Affzo [M:CNTP]1-99
        Endif
    Endif
Endif

#-----------------#
# flags du tiers  #
#-----------------#
If CLECUR
    If CZ <> [M:BPP0]BPCNUM
        Look  [BPR]BPR0 = num$(CZ)
        If fstat
           #-- on remet les indicateurs a zero
           [M:BPRP]BPSFLG    = 1
           [M:BPRP]BPTFLG    = 1
           [M:BPRP]REPFLG    = 1
           [M:BPRP]FCTFLG    = 1
        #-- pas celui de tiers divers
        #  [M:BPRP]BPRACC    = 1
           [M:BPRP]BPCFLG    = 1
           [M:BPRP]PPTFLG    = 2
           [M:BPP1]PPTFLG    = 2
           [M:BPP1]BPCTYP    = 4
        Endif
    Endif
Endif

#CRM
Gosub RAZDUP_CRM From TRTBPCRM

Affzo [M:BPP1]1-99
Affzo [M:BPRP]1-99
Return

###################################################################
$INICRE
#---------------------------------------------------#
# alimentation rubriques dans bpcustomer            #
#---------------------------------------------------#
Local Integer STAT, WRET, WNUMOK
Local Char    NUMERO(GLONBPC)

#MAE, bg 100401, si BPCNUM est renseigné et que la catégorie a un compteur et qu'on ne vient pas des tiers
#=> raz de la zone
If [M:BPP0]BPCNUM<>"" &  [F:BCG]REFCOU<>"" & GNAVIG(max(GPILNAV-1,1)) <> "GESBPR"
  [M:BPP0]BPCNUM = ""
  [F:BPC]BPCNUM = ""
Endif
# Si le numéro client est déterminée par un compteur
If [F:BPC]BPCNUM = ""
 WNUMOK=0
 While WNUMOK=0
  Call NUMCLE ([M:BPP0]REFCOU,GFCYDEF(9),datesyst,"","BPP",NUMERO,STAT) From SUBANM
  #---
  If STAT = 0
    Look [BPR]BPR0=NUMERO
    If fstat
     [F:BPC]BPCNUM =NUMERO
     [M:BPP0]BPCNUM=NUMERO
     WNUMOK=1
    Endif
  Else
    GOK=0 : WNUMOK=1
  Endif
 Wend
 If GOK=0 Return Endif
Endif
Gosub INIBPC
Return

###################################################################
$CREATION
#----    creation ou modification enregistrement tiers  #
Gosub CREBPR
If GOK < 1 : Return : Endif

#----    creation ou modification enregistrement adresse#
Gosub CREBPA
If GOK < 1 : Return : Endif

#----    creation enregistrements contacts                    #
Gosub CRECNT
If GOK < 1 : Return : Endif

#CRM
Gosub CREATION_CRM From TRTBPCRM
If GOK < 1 : Return : Endif
#MAE, lecture du tiers pour les workflows, ne pas écraser, bg 67131
If !GIMPORT
  If !clalev([F:BPRW]) : Local File BPARTNER [BPRW] : Endif
  If [M:BPP0]BPCNUM <> ""
    Read [BPRW]BPR0 = [M:BPP0]BPCNUM
    If fstat Raz [F:BPRW] Endif
  Endif
Endif

Return

###################################################################
$VERROU
If [M:BPP0]BPCNUM <> ""
        Read [BPR]BPR0 = [M:BPP0]BPCNUM
        If fstat = 0
            #------------------------------------#
            # il faut verrouiller symbole BPR    #
            #------------------------------------#
            SYMBOLE2 = "BPR"+num$([M:BPP0]BPCNUM)
            Lock = SYMBOLE2 With lockwait = 0
            If fstat
               #-- on debloque le BPC - modif non autorisée
               #-- sinon on a probleme sur lock : reste dans le fichier
               Unlock = SYMBOLE
               OK = 0
               Return
            Endif
         Endif
Endif

Return

###################################################################
$FINMODIF
  #----      deverrouillage du symbole BPR      #
  SYMBOLE2 = "BPR"+num$([M:BPP0]BPCNUM)     : # modif le 28/01/98 cg
  Unlock = SYMBOLE2
Return

###################################################################
$FIN_GILOCKBPR
  # FGR 16/04/2012 : X3SUIVI81335
  If dim(GILOCKBPR) >= 0 Then
    Gosub FINMODIF
    Kill GILOCKBPR
  Endif
Return

