  #Unlock = SYMBOLE2
  # FGR 16/04/2012 : X3SUIVI81335 (fin)
  Gosub FIN_GILOCKBPR  # FGR 16/04/2012 : X3SUIVI81335
Return

###################################################################
$INIMOD
#---- alimentation rubriques dans bpcustomer            #
Gosub INIBPC
Return

###################################################################
$INIBPC
#---- alimentation rubriques dans bpcustomer            #
[F:BPC]BPCNAM    = [M:BPRP]BPRNAM(0)
[F:BPC]BPCSHO    = [M:BPRP]BPRSHO
[F:BPC]BPCTYP    = 4

If find(GREP,"C","D")
    If GMODU(5)=2 [F:BPC]PRITYP  = GPRITYP Endif : # Bug 64308
    If [F:BPC]PRITYP=0 [F:BPC]PRITYP=1 Endif     : # Bug 64308
    [F:BPC]CHGTYP  = GCHGTYP
Endif
If [F:BPC]PRITYP=0 [F:BPC]PRITYP=1 Endif

# Alimentation du code adresse par défaut et du contact par défaut
Local Shortint WI
WI = find (2,[M:BPAP]BPAADDFLG (0..[M:BPAP]NBADR -1))
If WI<>0 [F:BPC]BPAADD = [M:BPAP]CODADR (WI-1) Endif

#LSE 17/06/2006 FQ36999
#WI = ([M:CNTP]NBCNT>0)*max(1,find (2,[M:CNTP]CNTFLG (0..[M:CNTP]NBCNT -1)))
#If WI<>0 [F:BPC]CNTNAM = [M:CNTP]CCNCRM (WI-1) Else [F:BPC]CNTNAM="" Endif
If [M:CNTP]NBCNT >0
    WI = find (2,[M:CNTP]CNTFLG (0..[M:CNTP]NBCNT -1))
    If WI <> 0
        [F:BPC]CNTNAM = [M:CNTP]CCNCRM (WI-1)
    Else
        [F:BPC]CNTNAM  =[M:CNTP]CCNCRM (0)
    Endif
Else
    [F:BPC]CNTNAM  =""
Endif


Return


###################################################################
$MODIF

#----    création ou modification enregistrement tiers  #
Gosub CREBPR
If GOK < 1 : Return : Endif

#----    creation ou modification enregistrement adresse#
Gosub CREBPA
If GOK < 1 : Return : Endif

#----    creation enregistrements contacts                    #
Gosub CRECNT
If GOK < 1 : Return : Endif

