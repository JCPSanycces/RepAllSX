#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe PHYELTTRF

$EVENTS
Case [L]CURPTH
   When ""
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE
#        When "AUPDATE_BEFORE"          : Gosub AUPDATE_BEFORE
#        When "AUPDATE"                 : Gosub AUPDATE  : # To be used only if update is not taken in charge by the crud
#        When "AUPDATE_AFTER"           : Gosub AUPDATE_AFTER
#        When "AUPDATE_ROLLBACK"        : Gosub AUPDATE_ROLLBACK
      Endcase
Endcase
Return

$METHODS
Return

$PROPERTIES
Case [L]CURPRO
    When "P_TRFLCTCOD"
      Case ARULE
        When "PROPAGATE"
          # Getting Location Facility
          Local Instance LCT Using C_PHYLCT : LCT = NewInstance C_PHYLCT AllocGroup null
          Local Char PROPERTIES(GLONAVA)(1..2)
          Local Char VALUES(255)        (1..2)
          Local Integer RET
          [L]PROPERTIES(1) = "FCY"
          [L]PROPERTIES(2) = "BUICOD"
          [L]RET = fmet LCT.GET_PROPERTIES_VALUE(this.P_TRFLCTCOD, [L]PROPERTIES, [L]VALUES)
          this.P_TRFFCY    = VALUES(1)
          this.P_TRFBUICOD = VALUES(2)
          FreeGroup LCT
      Endcase
Endcase
Return


# -------------------------------------
# PHYELTTRF standard representation methods
# -------------------------------------

#------------------------
$AREAD_AFTER
#  # Useful to test statement syntax through debug
Local Char    MSG(100)
Local Char    ERRMSG(140)
Local Integer RET

  this.P_TRFDAT     = date$
  this.P_TRFTYP     = "03"
  this.P_FCY_ORI    = this.PHYTRF.FCY
  this.P_LCTCOD_ORI = this.PHYTRF.LCTCOD
  this.P_BUICOD_ORI = this.PHYTRF.BUICOD
  this.P_CPY_ORI    = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.P_FCY_ORI,"LEGCPY")

Return

#------------------------
$AUPDATE_CONTROL_BEFORE
Local Char  ERRMSG(140)

  # PHYELT Data Class Unit test
  Local Instance PARAM Using C_PHYELTTRF
  PARAM = NewInstance C_PHYELTTRF AllocGroup null

  PARAM.FASFLG    = [V]CST_ANO
  PARAM.TRFDAT    = this.P_TRFDAT
  PARAM.TRFTYP    = this.P_TRFTYP
  PARAM.TRFLCTCOD = this.P_TRFLCTCOD
  If not (fmet this.PHYTRF._PHYELT_TRANSFER(PARAM) = [V]CST_AOK)
    [L]ASTATUS = fmet this.PHYTRF.AGETMAXERROR("")
  Endif

  FreeGroup PARAM

Return

