#*!
$TRC_NO_PIECE

 If PDIRECT=G_OUI : Return : Endif #@fq64544

 #> Point d'entrée pour gérer la trace par du spécifique (Demande VINCI)

 Local Char TRCCPTINTLBL : TRCCPTINTLBL="TRC_NO_PIECE"
 GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
