#-------------------------
#TODO - A supprimer
$DETACE

 Local Char TRCCPTINTLBL : TRCCPTINTLBL="DETACE"
 GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
 If GPE=0 : Return : Endif

 Gosub TRC_COM_VAR : SEPARATEUR="-"
 Local Integer LNGLIGNE        : LNGLIGNE=115
 Local Char    LIGNE(LNGLIGNE)
 Local Char    SEPARATEUR(1)   : SEPARATEUR="-"
 Local Char    FMTNUM          : FMTNUM="N:9.2"

 Local Char    L_TYP
 Local Char    L_FCY
 Local Char    L_JOU
 Local Char    L_CURORG
 Local Date    L_ACCDAT
 Local Char    L_FCYLIN
 Local Char    L_ACC
 Local Char    L_BPR
 Local Decimal L_DEB
 Local Decimal L_CDT
 Local Decimal L_AMTRPT1
 Local Char    L_TAX
 Local Char    L_CNA
 Local Char    L_DES
 Local Char    L_OBJREF

 If [M:HAE0]ACCDAT<>[0/0/0]
  L_TYP    = [M:HAE0]TYP
  L_FCY    = [M:HAE0]FCY
  L_JOU    = [M:HAE0]JOU
# L_CURORG = [M:HAE0]CURORG
  L_ACCDAT = [M:HAE0]ACCDAT
  Gosub TRC_PCE_SIM_ET
  If [M:HAE2]NBLIG=0
   Call ECR_TRACE("Aucune ligne générée pour cette pièce comptable",1) From GESECRAN
  Endif
  For nolign=1 To [M:HAE2]NBLIG
   L_FCYLIN = [M:HAE2]FCYLIN(nolign-1)
   L_ACC    = [M:HAE2]ACC1(nolign-1)
   L_BPR    = [M:HAE2]BPR(nolign-1)
   L_DEB    = [M:HAE2]DEB(nolign-1)
   L_CDT    = [M:HAE2]CDT(nolign-1)
   L_AMTRPT1= [M:HAE2]AMT1(nolign-1)
   L_TAX    = [M:HAE2]TAX(nolign-1)
#  L_CNA    = [M:HAE2]CNA(nolign-1)
   L_DES    = [M:HAE2]DES(nolign-1)
   Gosub INCR_TOT_GAC From TRTCPTINT3
   Gosub TRC_PCE_SIM_LIGNE
  Next nolign

  LIGNE = string$(LNGLIGNE,SEPARATEUR) : Call ECR_TRACE(LIGNE,0)From GESECRAN
  LIGNE = "" : Call ECR_TRACE(LIGNE,0) From GESECRAN
 Endif

Return

#--------------------------------------------------
# Simulation - En-tête pièce comptable
#--------------------------------------------------
#TODO - A supprimer
$TRC_PCE_SIM_ET

 Local Char TRCCPTINTLBL : TRCCPTINTLBL="TRC_PCE_SIM_ET"
 GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
 If GPE=0 : Return : Endif

 Gosub TRC_COM_VAR : SEPARATEUR="-"

 LIGNE = ""                           : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(LNGLIGNE,SEPARATEUR) : Call ECR_TRACE(LIGNE,0) From GESECRAN

 #> Ligne 1

 LIGNE = space$(1)+left$(mess(37,GML_MSGCPT,1)+space$(10),10)+"="+left$(L_TYP+space$(6),6)+space$(1)+"-"
 LIGNE+= space$(1)+left$(mess(24,GML_MSGCPT,1)+space$(4),4)  +"="+left$(L_FCY+space$(5),5)+space$(1)+"-"
 LIGNE+= space$(1)+left$(mess(32,GML_MSGCPT,1)+space$(7),7)  +"="+left$(L_JOU+space$(5),5)+space$(1)+"-"
 LIGNE+= space$(1)+left$(mess(38,GML_MSGCPT,1)+space$(6),6)  +"="+left$(L_CURORG+space$(3),3)+space$(1)+"-"
 LIGNE+= space$(1)+left$(mess(39,GML_MSGCPT,1)+space$(14),14)+"="+format$("D:" + GFMDAT4,L_ACCDAT)+space$(1) : Call ECR_TRACE(LIGNE,0) From GESECRAN

 #> Ligne 2 si niveau d'agrégation Objet métier

 Read [F:TCD]TCD0(2)=GNUMTRT;I_PCE
 If [F:TCD]AGRKEY<>""
  Call ECR_TRACE(space$(1)+[F:TCD]AGRKEY,0) From GESECRAN
 Endif

 #> Ligne 3

 LIGNE = space$(1)
 LIGNE+= left$(mess(24,GML_MSGCPT,1)+space$(4),4)+ space$(1)  # Site
 LIGNE+= left$(mess(40,GML_MSGCPT,1)+space$(6),6)+ space$(4)  # Compte
 LIGNE+= left$(mess(41,GML_MSGCPT,1)+space$(5),5)+ space$(14) # Tiers
 LIGNE+= left$(mess(42,GML_MSGCPT,1)+space$(5),5)+ space$(7)  # Débit
 LIGNE+= left$(mess(43,GML_MSGCPT,1)+space$(6),6)+ space$(4)  # Crédit
 LIGNE+= left$(mess(44,GML_MSGCPT,1)+space$(8),9)+ space$(1)  # Reporting
 LIGNE+= left$(mess(45,GML_MSGCPT,1)+space$(5),5)+ space$(2)  # Taxe
 LIGNE+= left$(mess(46,GML_MSGCPT,1)+space$(6),6)+ space$(5)  # Nature
 LIGNE+= left$(mess(47,GML_MSGCPT,1)+space$(11),11)           : Call ECR_TRACE(LIGNE,0) From GESECRAN  # Désignation
 LIGNE = string$(LNGLIGNE,SEPARATEUR) : Call ECR_TRACE(LIGNE,0)From GESECRAN
Return

#--------------------------------------------------
# Simulation - Ligne pièce comptable
#--------------------------------------------------
#TODO - A supprimer
$TRC_PCE_SIM_LIGNE

  Local Char TRCCPTINTLBL : TRCCPTINTLBL="LIST_PCE_SIM_LIGNE"
  GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
  If GPE=0 : Return : Endif

  Gosub TRC_COM_VAR : SEPARATEUR="-"

  LIGNE = space$(1)
  LIGNE+= left$(L_FCYLIN+space$(3),3)                   +space$(2)                               # Site
  LIGNE+= left$(L_ACC+space$(9),9)                      +space$(1)                               # Compte
  LIGNE+= left$(L_BPR+space$(10),10)                    +space$(2)                               # Tiers
  LIGNE+= left$(format$(FMTNUM,L_DEB)+space$(12),12)    +space$(1)                               # Montant Débit
  LIGNE+= left$(format$(FMTNUM,L_CDT)+space$(12),12)    +space$(1)                               # Montant crédit
  LIGNE+= left$(format$(FMTNUM,L_AMTRPT1)+space$(12),12)+space$(1)                               # Montant reporting
  LIGNE+= left$(L_TAX+space$(3),3)                      +space$(4)                               # Code taxe
  LIGNE+= left$(L_CNA+space$(10),10)                    +space$(1)                               # Nature
  LIGNE+= left$(L_DES,32)                                                                        # Désignation
  Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

