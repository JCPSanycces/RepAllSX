 # Test s/p liste des pièces comptables : liste des paramètres
 #
 #  PCPY                : Société
 #  PFCY                : Site
 #  PJOU                : Journal
 #  PTYPDAT             : Type de date (uniquement ACCDAT pour le moment)
 #  PDATMIN             : Borne inférieure de date
 #  PDATMAX             : Borne supèrieure de date
 #  PCRIT               : Critère
 #  PTRI                : Critère de tri
 #  PDETLIN             : Détail des lignes oui / non
 #  PDETANA             : Détail analytique
 #
End

#**
#* Définition des variables communes
#*!
$TRC_COM_VAR
 Local Char    LIGNE(115) : Raz LIGNE
 Local Integer LNG_LIGNE  : LNG_LIGNE=115
 Local Char    SEPARATEUR
Return

#**
#* Trace une ligne :
#*  - De la largeur définie par la variable LNG_LIGNE
#*  - Avec le caractère défini par la variable SEPARATEUR
#*!
$TRC_LINE
 Gosub TRC_COM_VAR : SEPARATEUR="-"
 LIGNE =string$(LNG_LIGNE,SEPARATEUR)                   : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#**
#* Trace : en-tête du tableau des pièces générée ou supprimées
#*!
$LIST_PCE_HEAD

 #> Point d'entrée pour gérer la trace par du spécifique (Demande VINCI)

 Local Char TRCCPTINTLBL : TRCCPTINTLBL="TRC_REAL_PCE_HEAD"
 GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
 If GPE=0 : Return : Endif

 Gosub TRC_COM_VAR
 Local Integer LNG_LIGNE  : LNG_LIGNE=115
 Local Char    FMTNUM     : FMTNUM="N:6.2"
 Local Char    LTRCSIT
 Local Char    LTRCTYP
 Local Char    LTRCJOU
 Local Char    LTRCNUM
 Local Char    LTRCDAT
 Local Char    LTRCLIB
 Local Char    LIAS
 LIGNE = string$(LNG_LIGNE,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = space$(1)+func TRTCPTINT2.FMT_COL(mess(24,GML_MSGCPT,1),6)                    # "Site"
 LIGNE+= func TRTCPTINT2.FMT_COL(mess(31,GML_MSGCPT,1),6)                              # "Type"
 LIGNE+= func TRTCPTINT2.FMT_COL(mess(32,GML_MSGCPT,1),8)                              # "Journal"
 #Fq-XXXXX LIGNE+= func TRTCPTINT2.FMT_COL(mess(33,GML_MSGCPT,1),20)                   # "N° de pièce"
 LIGNE+= func TRTCPTINT2.FMT_COL(mess(33,GML_MSGCPT,1),25)                             # "N° de pièce"
 LIGNE+= func TRTCPTINT2.FMT_COL(mess(34,GML_MSGCPT,1),12)                             # "Date cptble"
 LIGNE+= func TRTCPTINT2.FMT_COL(mess(35,GML_MSGCPT,1),57)                             # "Libellé ou erreur"
 If GUSER<>"GBO"
  LIGNE+= mess(36,GML_MSGCPT,1) -"o"
 Endif
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(LNG_LIGNE,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#**
#* Traitement réel liste de pièce pour site / TPE / Période
#*!
$LIST_PCE

 #> Point d'entrée pour gérer la trace par du spécifique (Demande VINCI)
 Local Char TRCCPTINTLBL : TRCCPTINTLBL="TRC_REAL_PCE_DET"
 GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
 If GPE=0 : Return : Endif

 Gosub TRC_COM_VAR
 Gosub LIST_PCE_PIECE
Return

#**
#* Traitement réel pièce pour un site / TPE / Période
#*!
$LIST_PCE_PIECE

 Local Char TRCCPTINTLBL : TRCCPTINTLBL="TRC_REAL_PCE_DET"
 GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
 If GPE=0 : Return : Endif

 Gosub TRC_COM_VAR

 LIGNE = space$(1)
 LIGNE+= func TRTCPTINT2.FMT_COL(LPCEFCY,6)
 LIGNE+= func TRTCPTINT2.FMT_COL(LPCETYP,6)
 LIGNE+= func TRTCPTINT2.FMT_COL(LPCEJOU,8)
 #Fq-XXXXX LIGNE+= func TRTCPTINT2.FMT_COL(LPCENUM,21)
 LIGNE+= func TRTCPTINT2.FMT_COL(LPCENUM,25)
 LIGNE+= func TRTCPTINT2.FMT_COL(format$("D:"+GFMDAT,LPCEACCDAT),12)
 LIGNE+= func TRTCPTINT2.FMT_COL(LPCEDES,61)
 Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#**
#* En-tête de pièce en mode simulation
#*!
$DETPCEHEAD
 Local Char TRCCPTINTLBL : TRCCPTINTLBL="TRC_SIMU_PCE_HEAD"
 GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
 If GPE=0 : Return : Endif

 Gosub TRC_COM_VAR : SEPARATEUR="-"

 LIGNE = ""                           : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(LNG_LIGNE,SEPARATEUR) : Call ECR_TRACE(LIGNE,0) From GESECRAN

 #> Ligne 1

 LIGNE = space$(1)+left$(mess(37,GML_MSGCPT,1)+space$(10),10)+"="+left$(LPCETYP+space$(6),6)+space$(1)+"-"
 LIGNE+= space$(1)+left$(mess(24,GML_MSGCPT,1)+space$(4),4)  +"="+left$(LPCEFCY+space$(5),5)+space$(1)+"-"
 LIGNE+= space$(1)+left$(mess(32,GML_MSGCPT,1)+space$(7),7)  +"="+left$(LPCEJOU+space$(5),5)+space$(1)+"-"
 LIGNE+= space$(1)+left$(mess(39,GML_MSGCPT,1)+space$(14),14)+"="+format$("D:"+GFMDAT,LPCEACCDAT)+space$(1) : Call ECR_TRACE(LIGNE,0) From GESECRAN

 #> Ligne 2 si niveau d'agrégation Objet métier

 Read [F:TCD]TCD0(2)=GNUMTRT;I_PCE
 If [F:TCD]AGRKEY<>""
  Call ECR_TRACE(space$(1)+[F:TCD]AGRKEY,0) From GESECRAN
 Endif

 #> Ligne 3

 LIGNE = string$(LNG_LIGNE,SEPARATEUR) : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = space$(1)
 LIGNE+= left$(mess(132,GML_MSGCPT,1)+space$(11),11)+ space$(1)  # Référentiel #left$(mess(24,GML_MSGCPT,1)+space$(4),4)+ space$(1)
 LIGNE+= left$(mess(38,GML_MSGCPT,1)+space$(3),3)+space$(1)
 LIGNE+= left$(mess(133,GML_MSGCPT,1)+space$(5),5)+ space$(1)  # Référentiel #left$(mess(24,GML_MSGCPT,1)+space$(4),4)+ space$(1)
 LIGNE+= left$(mess(40,GML_MSGCPT,1)+space$(15),15)+ space$(4) # Compte
 LIGNE+= space$(20-len(mess(42,GML_MSGCPT,1)))+mess(42,GML_MSGCPT,1)+space$(1) # Débit
 LIGNE+= space$(20-len(mess(43,GML_MSGCPT,1)))+mess(43,GML_MSGCPT,1)+space$(1) # Débit
 LIGNE+= left$(mess(47,GML_MSGCPT,1)+space$(11),11)           : Call ECR_TRACE(LIGNE,0) From GESECRAN  # Désignation
 LIGNE = string$(LNG_LIGNE,SEPARATEUR) : Call ECR_TRACE(LIGNE,0)From GESECRAN

Return

#**
#* En-tête de détail analytique en mode simulation
#*!
$DETANAHEAD
 Local Char TRCCPTINTLBL : TRCCPTINTLBL="TRC_SIMU_ANA_HEAD"
 GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
 If GPE=0 : Return : Endif

 Gosub TRC_COM_VAR : SEPARATEUR="-"

 Local Integer I_DIE

 LIGNE = ""                            : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(LNG_LIGNE,SEPARATEUR) : Call ECR_TRACE(LIGNE,0) From GESECRAN

 # Ligne 1

 LIGNE  = space$(1)
 LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(mess(132,GML_MSGCPT,1),11,"L")+space$(1) # Référentiel
 LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(mess(133,GML_MSGCPT,1),9,"R")+space$(1)  # Ligne
 LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(mess(134,GML_MSGCPT,1),20,"R")+space$(1) # Montant
 For I_DIE=1 To min(3,LNBDIEMAX)
  LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(mess(135,GML_MSGCPT,1)-num$(I_DIE)-"/"-mess(136,GML_MSGCPT,1),19,"L")+space$(1) # Axe / Section
 Next I_DIE
 Call ECR_TRACE(LIGNE,0) From GESECRAN

 # Ligne 2

 If LNBDIEMAX>3
  LIGNE = space$(44)
  For I_DIE=4 To min(6,LNBDIEMAX)
   LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(mess(135,GML_MSGCPT,1)-num$(I_DIE)-"/"-mess(136,GML_MSGCPT,1),19,"L")+space$(1) # Axe / Section
  Next I_DIE
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Endif

 # Ligne 3

 If LNBDIEMAX>6
  LIGNE = space$(44)
  For I_DIE=7 To LNBDIEMAX
   LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(mess(135,GML_MSGCPT,1)-num$(I_DIE)-"/"-mess(136,GML_MSGCPT,1),19,"L")+space$(1) # Axe / Section
  Next I_DIE
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Endif

 LIGNE = string$(LNG_LIGNE,SEPARATEUR) : Call ECR_TRACE(LIGNE,0) From GESECRAN

Return

#**
#* Ligne d'une pièce en mode simulation
#*!
$DETPCESIM

 Local Char TRCCPTINTLBL : TRCCPTINTLBL="TRC_SIMU_PCE_DET"
 GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
 If GPE=0 : Return : Endif

 Gosub TRC_COM_VAR

 LIGNE  = space$(1)
 LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(string$(LLEDTYP<>0,mess(LLEDTYP,2644,1)), 11, "L")+space$(1)
 LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(num$([F:TDAE]CURLED), 3, "R")+space$(1)
 LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(num$([F:TDAE]LIN), 5, "R")+space$(1)
 LIGNE += func TRTCPTINT2.FMT_COL_ALIGN([F:TDAE]ACC,15, "L")+space$(4)
 If [F:TDAE]SNS=1
  LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(format$(GDEVFMT1(find([F:TDAE]CURLED,GDEVISE)),[F:TDAE]AMTLED),20, "R")+space$(1)+space$(20)+space$(1)
 Else
  LIGNE +=space$(20)+space$(1)+func TRTCPTINT2.FMT_COL_ALIGN(format$(GDEVFMT1(find([F:TDAE]CURLED,GDEVISE)),[F:TDAE]AMTLED),20, "R")+space$(1)
 Endif
 LIGNE += [F:TDAE]DES

 Call ECR_TRACE(LIGNE,0) From GESECRAN

Return

#**
#* Ligne analytique d'une pièce en mode simulation
#*!
$DETPCEANASIM
 Local Char TRCCPTINTLBL : TRCCPTINTLBL="TRC_SIMU_ANA_DET"
 GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
 If GPE=0 : Return : Endif

 Gosub TRC_COM_VAR

 Local Integer I_DIE

 # Ligne 1

 LIGNE  = space$(1)
 LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(string$(LLEDTYP<>0,mess(LLEDTYP,2644,1)),11,"L")+space$(1)
 LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(LLINNUM,9,"R")+space$(1)
 LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(format$(GDEVFMT1(find([F:TDAA]CURLED,GDEVISE)),LMNT),20,"R")+space$(1)
 For I_DIE=1 To min(3,LNBDIEMAX)
  LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(LDIECCE(I_DIE),19,"L")+space$(1)
 Next I_DIE
 Call ECR_TRACE(LIGNE,0) From GESECRAN

 # Ligne 2

 If LNBDIEMAX>3
  LIGNE  = space$(44)
  For I_DIE=4 To min(6,LNBDIEMAX)
   LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(LDIECCE(I_DIE),19,"L")+space$(1)
  Next I_DIE
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Endif

 # Ligne 3

 If LNBDIEMAX>6
  LIGNE  = space$(44)
  For I_DIE=7 To LNBDIEMAX
   LIGNE += func TRTCPTINT2.FMT_COL_ALIGN(LDIECCE(I_DIE),19,"L")+space$(1)
  Next I_DIE
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Endif

Return

#**
#* Trace des paramètres du traitement
#*!
$TRC_PARAMETRES

   #> Point d'entrée pour gérer la trace par du spécifique (Demande VINCI)

   Local Char TRCCPTINTLBL : TRCCPTINTLBL="TRC_PARAMETRES"
   GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
   If GPE=0 : Return : Endif

   # Tableau des sociétés et des sites sélectionnés :
   Local Integer I_CPY      : Raz I_CPY
   Local Integer I_ACE      : Raz I_ACE
   Local Char    RUP_CPY    : Raz RUP_CPY
   Gosub TRC_COM_VAR        : SEPARATEUR="="

 # Début de la trace

   LIGNE=">> "+mess(18,GML_MSGCPT,1)                       : Call ECR_TRACE(LIGNE,0) From GESECRAN  # "Paramètres et options du traitement"
   LIGNE=space$(3)+string$(len(mess(18,GML_MSGCPT,1)),"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN

 # Paramètres

   Call ECR_TRACE("",0) From GESECRAN
   #-Simulation
   LIGNE=left$(mess(19,GML_MSGCPT,1)+space$(28),28)+":"-mess([M:DIA]FLGSIM,1,1) : Call ECR_TRACE (LIGNE,0) From GESECRAN
   #-Exercice
   LIGNE=left$(mess(8,GML_MSGCPT,1)+space$(28),28)+":"-mess([M:DIA]FIY,3102,1) : Call ECR_TRACE (LIGNE,0) From GESECRAN

 # Société et sites

  # Liste sociétés et des sites sélectionnés

   Call ECR_TRACE("",0) From GESECRAN
   LIGNE =left$(mess(21,GML_MSGCPT,1)+space$(36),36)+":"         : Call ECR_TRACE(LIGNE,0) From GESECRAN
   LIGNE =string$(LNG_LIGNE,SEPARATEUR)                   : Call ECR_TRACE(LIGNE,0) From GESECRAN
   LIGNE =space$(02)+left$(mess(22,GML_MSGCPT,1)+space$(7),7)+space$(2)+left$(mess(23,GML_MSGCPT,1)+space$(14),14)
   LIGNE+=space$(23)+left$(mess(24,GML_MSGCPT,1)+space$(4),4)+space$(2)+left$(mess(25,GML_MSGCPT,1)+space$(3),3)
   Call ECR_TRACE(LIGNE,0) From GESECRAN
   LIGNE =string$(LNG_LIGNE,SEPARATEUR)                   : Call ECR_TRACE(LIGNE,0) From GESECRAN

   For I_FCY=1 To [M:DIA]NBFCY
    If [M:DIA]FLGFCY(I_FCY-1)=G_OUI
     If RUP_CPY<>[M:DIA]CPY
      RUP_CPY=[M:DIA]CPY
      LIGNE=space$(2)+left$(RUP_CPY+space$(GLONCPY),GLONCPY)+space$(max(0,9-GLONCPY))
&          +left$([M:DIA]ZCPY+space$(35),35)+space$(2)
     Else
      LIGNE=space$(49) # On émet des espaces à la place de la société
     Endif
     LIGNE+=left$([M:DIA]FCY(I_FCY-1)+space$(GLONFCY),GLONFCY)+space$(max(0,6-GLONFCY)) # On ajoute le site et son libellé #Fq72996
     LIGNE+=[M:DIA]ZFCY(I_FCY-1)
     Call ECR_TRACE(LIGNE,0) From GESECRAN
    Endif
   Next I_FCY
   LIGNE=string$(LNG_LIGNE,SEPARATEUR) : Call ECR_TRACE(LIGNE,0) From GESECRAN

 # Liste type d'écritures

   Call ECR_TRACE("",0) From GESECRAN
   LIGNE=left$(mess(26,GML_MSGCPT,1)+space$(28),28)+":" : Call ECR_TRACE(LIGNE,0) From GESECRAN  # "Types d'écritures à traiter :"
   LIGNE=string$(LNG_LIGNE,SEPARATEUR) : Call ECR_TRACE(LIGNE,0) From GESECRAN
   LIGNE=space$(2)+left$(mess(27,GML_MSGCPT,1)+space$(4),4)+space$(6)+mess(28,GML_MSGCPT,1) : Call ECR_TRACE(LIGNE,0) From GESECRAN
   LIGNE=string$(LNG_LIGNE,SEPARATEUR) : Call ECR_TRACE(LIGNE,0) From GESECRAN
   If !clalev([F:TPE]) : Local File TYPACE [TPE] : Endif
   For I_ACE=1 To [M:DIA]NBTPE
    LIGNE = space$(2)+left$([M:DIA]TPE(I_ACE-1)+space$(10),10)
    #Fq-85066 Read [TPE]TPE0=[M:DIA]TPE(I_ACE-1)
    Read [TPE]TPE0=[M:DIA]TPE(I_ACE-1);[M:DIA]LEGTPE(I_ACE-1);[M:DIA]CPYTPE(I_ACE-1)
    If !fstat
     Local Char LDES
     Call LECTEXTRA(LDES,"TYPACE","DESTRA",[F:TPE]ACETYP,"") From ATEXTRA
     LIGNE+=LDES
    Endif
     Call ECR_TRACE(LIGNE,0) From GESECRAN
   Next I_ACE
   LIGNE=string$(LNG_LIGNE,SEPARATEUR) : Call ECR_TRACE(LIGNE,0) From GESECRAN

 # Début du compte-rendu

   Call ECR_TRACE("",0) From GESECRAN
   LIGNE=">>"+space$(1)+mess(29,GML_MSGCPT,1)                                            : Call ECR_TRACE(LIGNE,0) From GESECRAN # "COMPTE-rendu"
   LIGNE=space$(3)+string$(len(mess(29,GML_MSGCPT,1)),"-")                               : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#**
#* Trace des paramétres d'un type d'écriture
#* en cours de traitement
#*!
$TRC_TPE

 #> Point d'entrée pour gérer la trace par du spécifique (Demande VINCI)

 Local Char TRCCPTINTLBL : TRCCPTINTLBL="TRC_TPE"
 GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
 If GPE=0 : Return : Endif

 Gosub TRC_COM_VAR

 Call ECR_TRACE("",0) From GESECRAN
 LIGNE = string$(LNG_LIGNE,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = space$(1)+mess(22,GML_MSGCPT,1)-":"-func TRTCPTINT2.FMT_COL([F:CPY]CPY,10)                           #"Société"
 LIGNE+= mess(24,GML_MSGCPT,1)-":"-func TRTCPTINT2.FMT_COL([F:FCY]FCY,12)+mess(48,GML_MSGCPT,1)-":"-[M:TPE]ACETYP   #"Site" / "Type d'écriture"
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(LNG_LIGNE,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = space$(1)+func TRTCPTINT2.FMT_COL(mess(85,GML_MSGCPT,1),37)+":"+space$(1)                           #"Source"
 LIGNE+= mess([M:TPE]SRCTYP,GML_TYPSRC,1)
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 If [M:TPE]SRCTYP=GVML_SRCEVT
  Local Char LIBTYP(30) : Call LECTEXTRA(LIBTYP,"ATABDIV","LNGDES","962",[M:TPE]EVTTYP) From ATEXTRA
  LIGNE = space$(1)+func TRTCPTINT2.FMT_COL(mess(14,GML_MSGCPT,1),37)+":"+space$(1)                          #"Evénement"
  LIGNE+= [M:TPE]EVTTYP-LIBTYP
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Endif

 If [M:TPE]SRCTYP<>GVML_SRCRPR
  LIGNE = space$(1)+func TRTCPTINT2.FMT_COL(mess(86,GML_MSGCPT,1),37)+":"+space$(1)                           #"Plan d'amortissement comptabilisé"
  LIGNE+= mess([M:TPE]DPRPLN,GML_NPLAN,1)
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Endif

 #Fq69824
 If [M:TPE]GAU<>""
  LIGNE = space$(1)+func TRTCPTINT2.FMT_COL(mess(17,GML_MSGCPT,1),37)+":"+space$(1)                           #"Pièce automatique"
  LIGNE+= [M:TPE]GAU-[M:TPE]ZGAU
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Elsif [M:TPE]GRA<>""
  LIGNE = space$(1)+func TRTCPTINT2.FMT_COL(mess(137,GML_MSGCPT,1),37)+":"+space$(1)                           #"Groupe de pièces"
  LIGNE+= [M:TPE]GRA-[M:TPE]ZGRA
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Endif

 LIGNE = space$(1)+func TRTCPTINT2.FMT_COL(mess(87,GML_MSGCPT,1),37)+":"+space$(1)                           #"Référentiel comptable cible"
 Local Integer LLSTLEDTYP(1..10)
 If [M:TPE]GTE<>""    : Call GET_GTE_AUZLED([M:TPE]GTE,LLSTLEDTYP) From TRTCPTINT3 : Endif
 If [M:TPE]GTEPRO<>"" : Call GET_GTE_AUZLED([M:TPE]GTE,LLSTLEDTYP) From TRTCPTINT3 : Endif
 Local Integer I_LEDTYP
 For I_LEDTYP=1 To 10
  If LLSTLEDTYP(I_LEDTYP)=G_OUI
   If dim(LLEDTYPFIRST)>0
    LIGNE +=","
   Else
    Local Integer LLEDTYPFIRST
   Endif
   LIGNE+=mess(I_LEDTYP,2644,1)
  Endif
 Next I_LEDTYP
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = space$(1)+func TRTCPTINT2.FMT_COL(mess(88,GML_MSGCPT,1),37)+":"+space$(1)                           #"Tri analytique préalable"
 LIGNE+= mess([M:TPE]SORTCCE,1,1)
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = space$(1)+func TRTCPTINT2.FMT_COL(mess(89,GML_MSGCPT,1),37)+":"+space$(1)                           #"Périodes à prendre en compte"
 Local Char PERCPT
 If [M:TPE]PERCLOFLG=G_OUI : PERCPT+= mess(4,GML_STATPER,1) : Endif
 If [M:TPE]PERCOUFLG=G_OUI : If PERCPT<>"" : PERCPT+=" / " : Endif : PERCPT+= mess(2,GML_STATPER,1) : Endif
 If [M:TPE]PEROPEFLG=G_OUI : If PERCPT<>"" : PERCPT+=" / " : Endif : PERCPT+= mess(3,GML_STATPER,1) : Endif
 LIGNE += PERCPT
 LIGNE = space$(1)+func TRTCPTINT2.FMT_COL(mess(2930,200,1),37)+":"+space$(1)                     #"Règle date comptable"
 LIGNE+= mess([M:TPE]ACCDATRUL,3130,1)
 If [M:TPE]ACCDATRUL=8
  LIGNE-="=>"-format$("D:"+GFMDAT,[M:TPE]ACCDATFIX)
 Endif
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(LNG_LIGNE,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

