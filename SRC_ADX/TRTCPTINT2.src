                LDATMIN  = PDATMIN
                LDATMAX  = PDATMAX
                LFIY     = PFIY
                LPER     = PPER
                LCOMPTA  = PCOMPTA
 Call  ECR_TRACE("",0) From GESECRAN
 Call  ECR_TRACE(left$(mess(22,GML_MSGCPT,1)+space$(23),23)+": "-LCPY,0) From GESECRAN                 #"Société"
 Call  ECR_TRACE(left$(mess(24,GML_MSGCPT,1)+space$(23),23)+": "-LFCY,0) From GESECRAN                 #"Site"
 If LCOMPTA>0
  Call ECR_TRACE(left$(mess(96,GML_MSGCPT,1)+space$(23),23)+": "-mess(LCOMPTA,3233,1),0) From GESECRAN  #"Référentiel comptable"
 Else
  Call ECR_TRACE(left$(mess(96,GML_MSGCPT,1)+space$(23),23)+": "-mess(95,GML_MSGCPT,1),0) From GESECRAN       #"Référentiel comptable"-"Tous"
 Endif
 Call  ECR_TRACE(left$(mess(08,GML_MSGCPT,1)+space$(23),23)+": "-mess(LFIY,GML_TYPEXERC,1),0) From GESECRAN     #"Exercice"
 Call  ECR_TRACE(left$(mess(11,GML_MSGCPT,1)+space$(23),23)+": "-num$(LPER),0) From GESECRAN           #"Période"
 Call ECR_TRACE("",0) From GESECRAN
Return

