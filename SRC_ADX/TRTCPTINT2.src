 LIGNE-= "-"-mess(11,GML_MSGCPT,1)-mess([M:TC1P]STAPER,GML_STATPER,1) #"Période"
 If [M:TPE]SRCTYP=GVML_SRCDEP
  LIGNE-= "-"-mess(92,GML_MSGCPT,1)-mess(max(1,[M:TC1P]TYPPST),GML_TYPPST,1)                                        #"Comptabilisation"
