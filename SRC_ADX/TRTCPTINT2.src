 If GPE=0 : Return : Endif

 Gosub TRC_COM_VAR
 Local Char    FMTNUM          : FMTNUM="N:13.2"
 If [M:TC1P]NBGAC=0 : Return : Endif
 Sorta [M:TC1P]NBGAC [M:TC1P]NBGAC Order By [M:TC1P]GAC([S]indice)
 Local Integer I_GAC
 Call ECR_TRACE("",0) From GESECRAN
 LIGNE = string$(LNG_LIGNE,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = mess(117,GML_MSGCPT,1)-":"-mess(11,GML_MSGCPT,1)-mess(90,GML_MSGCPT,1)-format$("D:" + GFMDAT4,[M:TC1P]PERSTRDAT)-mess(91,GML_MSGCPT,1)-format$("D:DD[/]MM[/]YY",[M:TC1P]PERENDDAT)
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(LNG_LIGNE,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = space$(1)+ mess(40,GML_MSGCPT,1)+space$(25-len(mess(40,GML_MSGCPT,1)))+mess(42,GML_MSGCPT,1)+space$(17-len(mess(43,GML_MSGCPT,1)))+mess(43,GML_MSGCPT,1)
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(LNG_LIGNE,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 For I_GAC = 1 To [M:TC1P]NBGAC
  LIGNE = space$(1)+[M:TC1P]GAC(I_GAC-1)+space$(24-len(format$(FMTNUM,[M:TC1P]DEB(I_GAC-1))))+format$(FMTNUM,[M:TC1P]DEB(I_GAC-1))
&                                       +space$(17-len(format$(FMTNUM,[M:TC1P]CDT(I_GAC-1))))+format$(FMTNUM,[M:TC1P]CDT(I_GAC-1))
&                                       +space$(17-len(format$(FMTNUM,[M:TC1P]CDT(I_GAC-1)-[M:TC1P]DEB(I_GAC-1))))
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Next I_GAC
 LIGNE = string$(LNG_LIGNE,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

