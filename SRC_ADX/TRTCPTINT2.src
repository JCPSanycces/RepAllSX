# TRC_LIST_PIECE_PCG(SCPY,SFCY,SJOU,PTYPDAT,SDATMIN,SDATMAX,PDETLIN,CDRET)
# TRC_LIST_PIECE_ANALYTIQUE(SCPY,SFCY,SJOU,PTYPDAT,SDATMIN,SDATMAX,PDETLIN,CDRET)
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $TRC_PARAMETRES
# $TRC_TPE
# $TRC_TOT_GAC_PER
# $TRC_TOT_GAC_FCY
# $TRC_TOT_GAC_FCY
