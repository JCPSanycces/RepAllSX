$ET_LST_DEL_PRO_PCE

 Local Char TRCCPTINTLBL : TRCCPTINTLBL="LIST_LST_DEL_PRO_PCE"
 GPE=1 : GPOINT = "TRCCPTINT" : Gosub ENTREE From EXEFNC
 If GPE=0 : Return : Endif

 Gosub TRC_COM_VAR

 Local Integer LNGLIGNE        : LNGLIGNE=115
 Local Char    LIGNE(LNGLIGNE)

Return

#TODO - Sous-pro obsolète : a supprimer
############################################################################
# Liste des pièces comptables (Compta PCG) présentes dans les tables temporaires
#
#     Critères de sélection :
#         Société
#         Site
#         Journal
#         Type de date - date min / date max
#         Critère de sélection supplémentaire
#
#     Options de sortie
#         Critères de tri  : non modifiable : Société / Site / Journal
#         Détail lignes
#         Détail analytique des lignes
#
############################################################################
Subprog TRC_LIST_PIECE_PCG(PCPY,PFCY,PREF,PJOU,PTYPDAT,PDATMIN,PDATMAX,PCRIT,PTRI,PDETLIN,PDETANA,CDRET)
Value    Char    PCPY                # Société
Value    Char    PFCY                # Site
Value    Integer PREF                # Référentiel comptable
Value    Char    PJOU                # Journal
Value    Integer PTYPDAT             # Type de date (uniquement ACCDAT pour le moment)
Value    Date    PDATMIN             # Borne inférieure de date
Value    Date    PDATMAX             # Borne supèrieure de date
Value    Char    PCRIT               # Critère
Value    Char    PTRI()()            # Critère de tri
Value    Integer PDETLIN             # Détail des lignes oui / non
Value    Integer PDETANA             # Détail analytique
Variable Integer CDRET               # Code retour

Local Char    LCRITSUP(255)
Local Char    LCRITDIV(255)
Local Char    LCRITDAT(255)
Local Char    LIBJOU(GLONAX3)
Local Char    SCPY
Local Char    SFCY
Local Char    SJOU
Local Char    SCCE
Local Char    LET
Local Char    LIGNE(116)
Local Decimal LDEB
Local Decimal LCDT
Local Decimal LANA
Local Integer NBLIGNE

If PCPY<>""                       : LCRITSUP  ="CPY='"+PCPY+"'"  : Endif
If PFCY<>"" & LCRITSUP<>""        : LCRITSUP += "&"              : Endif
If PFCY<>""                       : LCRITSUP +="FPY='"+PFCY+"'"  : Endif
If PJOU<>"" & LCRITSUP<>""        : LCRITSUP += "&"              : Endif
If PJOU<>""                       : LCRITSUP +="JOU='"+PJOU+"'"  : Endif

If PCRIT=""
 LCRITDIV="1=1"
Else
 LCRITDIV = PCRIT
Endif

If LCRITSUP=""                     : LCRITSUP  ="1=1"             : Endif

LCRITDIV = PCRIT
If PCRIT = ""                      : LCRITDIV  ="1=1"             : Endif

If PDATMIN<>[0/0/0]                : LCRITDAT  ="ACCDAT>=PDATMIN" : Endif
If PDATMAX<>[0/0/0] & LCRITDAT<>"" : LCRITDAT +="&"               : Endif
If PDATMAX<>[0/0/0]                : LCRITDAT +="ACCDAT<=PDATMAX" : Endif
If LCRITDAT=""                     : LCRITDAT  ="1=1"             : Endif

If GTRACE=""
 Call OUVRE_TRACE(mess(97,GML_MSGCPT,1)) From LECFIC #"Liste des pièces comptables"
 Local Integer LTRC
Endif

If !clalev([F:CPY])   : Local File COMPANY                [F:CPY] : Endif
If !clalev([F:FCY])   : Local File FACILITY               [F:FCY] : Endif
If !clalev([F:JOU])   : Local File =GTABCPT+"GJOURNAL"    [F:JOU] : Endif

If PREF=2
 If !clalev([F:HAT])   : Local File =GTABCPT+"GACCTMP"     [F:HAT] : Endif
 If !clalev([F:DAT])   : Local File =GTABCPT+"GACCTMPD"    [F:DAT] : Endif
 If PDETANA=G_OUI
  If !clalev([F:AAT])  : Local File =GTABCPT+"GACCTMPA"    [F:AAT] : Endif
 Endif
Endif

If PREF=3
 If !clalev([F:HAT])   : Local File =GTABCPT+"GACIASTMP"   [F:HAT] : Endif
 If !clalev([F:DAT])   : Local File =GTABCPT+"GACIASTMPD"  [F:DAT] : Endif
Endif

If GTABCPT<>""
 Call ECR_TRACE(mess(98,GML_MSGCPT,1),0) From GESECRAN #"Pièces en attente de validation par la tâche comptable"
 Call ECR_TRACE(string$(len(mess(98,GML_MSGCPT,1)),"="),0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
Endif
Gosub LISTE_PIECES

If GTABCPT<>""
 Close Local File [F:HAT]
 Close Local File [F:DAT]
 If PDETANA=G_OUI
  Close Local File [F:AAT]
 Endif

 If PREF=2
  If !clalev([F:HAT])  : Local File =GTABCPT+"GACCENTRY"   [F:HAT] : Endif
  If !clalev([F:DAT])  : Local File =GTABCPT+"GACCENTRYD"  [F:DAT] : Endif
  If PDETANA=G_OUI
   If !clalev([F:AAT]) : Local File =GTABCPT+"GACCENTRYA"  [F:AAT] : Endif
  Endif
 Endif

 If PREF=3
  If !clalev([F:HAT])  : Local File =GTABCPT+"GACEIAS"     [F:HAT] : Endif
  If !clalev([F:DAT])  : Local File =GTABCPT+"GACEIASD"    [F:DAT] : Endif
 Endif

 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(99,GML_MSGCPT,1),0) From GESECRAN #"Pièces validées"
 Call ECR_TRACE(string$(len(mess(99,GML_MSGCPT,1)),"="),0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
 Gosub LISTE_PIECES
Endif

If dim(LTRC)>0
 Call LEC_TRACE() From LECFIC
Endif

End

#TODO - Sous-pro obsolète à supprimer
#---------------------------
$LISTE_PIECES

  LREADKEY="CPY;FCY;JOU"
  If PTRI<>""
   Local Integer I
   For I=1 To dim(PTRI)
    If PTRI(I-1)<>""
     LREADKEY+=";"+PTRI(I-1)
    Endif
   Next I
  Endif

 Filter [HAT] Where evalue(LCRITSUP) & evalue(LCRITDAT) & evalue(LCRITDIV) Order With Key CLE=LREADKEY

 For [HAT]
  Raz LDEB, LCDT
  #> Alimentation des champs d'en-tête
  Local Char    TCPY    : TCPY    = [F:HAT]CPY
  Local Char    TFCY    : TFCY    = [F:HAT]FCY
  Local Char    TJOU    : TJOU    = [F:HAT]JOU
  Local Char    TNUM    : TNUM    = [F:HAT]NUM
  Local Char    TREF    : TREF    = [F:HAT]REF
  Local Char    TDES    : TDES    = [F:HAT]DESVCR
  Local Date    TACCDAT : TACCDAT = [F:HAT]ACCDAT
  Local Char    TTYP    : TTYP    = [F:HAT]TYP
  #> Emission dans la trace
  If SCPY<>TCPY | SFCY<>TFCY | SJOU<>TJOU
   If SCPY<>"" & PDETLIN=G_NON
    Call ECR_TRACE(string$(105,"-"),0) From GESECRAN
   Endif
   Gosub ET_CPY
   If SCPY<>TCPY : SCPY=TCPY : Endif
   If SFCY<>TFCY : SFCY=TFCY : Endif
   If SJOU<>TJOU : SJOU=TJOU : Endif
   Gosub ET_PIECE
  Endif
  #> Emission de la ligne (pas de détail pièce)
  If PDETLIN=G_NON
   Filter [F:DAT] Where TYP=[F:HAT]TYP & NUM=[F:HAT]NUM
   For [F:DAT]
    Local Integer TSNS    : TSNS    = [F:DAT]SNS
    Local Decimal TAMTLOC : TAMTLOC = [F:DAT]AMTLOC
    If TSNS=-1
     LDEB += TAMTLOC
    Else
     LCDT += TAMTLOC
    Endif
   Next
   Filter [F:DAT]
   Gosub LIGNE_NONDETAIL
  Endif
  #> Emission des lignes (détail pièce)
  If PDETLIN=G_OUI
   LIGNE  = TNUM                                      + space$(24-len(TNUM))
   LIGNE += format$("D:" + GFMDAT4,TACCDAT)       + space$(19)
   LIGNE += TDES                                      + space$(31-len(TDES))
   Filter [F:DAT] Where TYP=TTYP & NUM=TNUM
   NBLIGNE=rowcount([F:DAT])
   If NBLIGNE=0
    LIGNE += space$(10)+mess(100,GML_MSGCPT,1) #"Aucune ligne pour cette pièce"
   Endif
   Call ECR_TRACE(LIGNE,evalue("NBLIGNE=0")) From GESECRAN
   For [F:DAT]
    NBLIGNE+=1
    Raz LDEB, LCDT
    Local Integer TSNS    : TSNS    = [F:DAT]SNS
    Local Decimal TAMTLOC : TAMTLOC = [F:DAT]AMTLOC
    Local Char    TACC    : TACC    = [F:DAT]ACC
    Local Char    TCNA    : If PREF=2 : TCNA    = [F:DAT]CNA : Else : TCNA =""
    Endif
    Local Integer TLIG    : TLIG    = [F:DAT]LIG
    If TSNS=-1
     LDEB += TAMTLOC
    Else
     LCDT += TAMTLOC
    Endif
    Gosub LIGNE_DETAIL
    If PDETANA=G_OUI & TCNA<>"" & PREF=2
     Local Integer I_AXE
     For I_AXE=1 To GOPTCANA
      Filter [F:AAT] Where TYP=TTYP & NUM=TNUM & LIG=TLIG Order By CCE(I_AXE-1)
      If dim(LFIRST)>0
       Call ECR_TRACE(space$(50)+string$(55,"-"),0) From GESECRAN
      Else
       Local Integer LFIRST
       Call ECR_TRACE(space$(39)+string$(66,"-"),0) From GESECRAN
      Endif
      Local Char TAXE    : TAXE = left$(mess(I_AXE,601,1),11) # A revoir
      LFIRST=1 : SCCE=""
      For [AAT]
       If [F:AAT]CCE(I_AXE-1)<>SCCE
        If SCCE<>""
         If LFIRST=1
          LIGNE=space$(50)+TAXE+space$(12-len(TAXE))+space$(1)
          LFIRST=0
         Else
          LIGNE=space$(63)
         Endif
         LIGNE+=SCCE+space$(20-len(SCCE))
         If SCCE<>""
          LIGNE+=space$(22-len(format$("N:13.2",LANA)))   + format$("N:13.2",LANA)
         Else
          LIGNE+=space$(2)+mess(101,GML_MSGCPT,1) #"Aucun montant affecté sur cet axe"
         Endif
         Call ECR_TRACE(LIGNE,0) From GESECRAN
        Endif
        Raz LANA
        SCCE = [F:AAT]CCE(I_AXE-1)
        LANA+=[F:AAT]AMTLOC
       Else
        LANA+=[F:AAT]AMTLOC
       Endif
      Next
      If LFIRST=1
       LIGNE=space$(50)+TAXE+space$(12-len(TAXE))+space$(1)
       LFIRST=0
      Else
       LIGNE=space$(63)
      Endif
      If SCCE<>"" & LANA
       LIGNE+=SCCE+space$(20-len(SCCE))
       If LANA
        LIGNE+=space$(22-len(format$("N:13.2",LANA)))   + format$("N:13.2",LANA)
       Endif
       Call ECR_TRACE(LIGNE,0) From GESECRAN
      Endif
      If SCCE=""
       LIGNE+=mess(101,GML_MSGCPT,1)        # "Aucun montant affecté sur cet axe"
       Call ECR_TRACE(LIGNE,0) From GESECRAN
      Endif
     Next I_AXE
     Call ECR_TRACE(space$(39)+string$(66,"-"),0) From GESECRAN
     If dim(LFIRST)>0 : Kill LFIRST : Endif
     Filter [F:AAT]
    Endif
   Next
   Call ECR_TRACE(string$(105,"-"),0) From GESECRAN
   Filter [F:DAT]
  Endif
 Next
 Filter [HAT]
 If PDETLIN=G_NON
  Call ECR_TRACE(string$(105,"-"),0) From GESECRAN
 Endif
Return

#TODO - A supprimer
#---------------------------
$ET_CPY

 If [F:CPY]CPY<>TCPY : Read [F:CPY]CPY0=TCPY : Endif
 If [F:FCY]FCY<>TFCY : Read [F:FCY]FCY0=TFCY : Endif
 If [F:JOU]JOU<>TJOU : Read [F:JOU]JOU0=TJOU : Endif

 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(left$(mess(22,GML_MSGCPT,1)+space$(8),8)+":"-TCPY-[F:CPY]CPYNAM,0) From GESECRAN   #"Société"
 Call ECR_TRACE(left$(mess(24,GML_MSGCPT,1)+space$(8),8)+":"-TFCY-[F:FCY]FCYNAM,0) From GESECRAN   #"Site"
 Call LECTEXTRA(LIBJOU,"GJOURNAL","DESTRA",TJOU,"") From ATEXTRA
 Call ECR_TRACE(left$(mess(32,GML_MSGCPT,1)+space$(8),8)+":"-TJOU-LIBJOU,0)    From GESECRAN       #"Journal"
 Call ECR_TRACE("",0) From GESECRAN
Return

#TODO - A supprimer
#---------------------------
$ET_PIECE
 Call ECR_TRACE(string$(105,"-"),0) From GESECRAN
 LIGNE  = left$(mess(33,GML_MSGCPT,1)+space$(24),24)                                    #"N° pièce"
 LIGNE += left$(mess(39,GML_MSGCPT,1)+space$(15),15)                                    #"Date comptable"
 LIGNE += left$(mess(102,GML_MSGCPT,1)+space$(33),33)                                   #"Libellé"
 LIGNE += space$(16-len("Débit"))  + "Débit"                                     #"Débit"
 LIGNE += space$(17-len("Crédit")) + "Crédit"                                    #"Crédit"
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 Call ECR_TRACE(string$(105,"-"),0) From GESECRAN
Return

#TODO - A supprimer
#---------------------------
$LIGNE_NONDETAIL
 LIGNE  = TNUM                                      + space$(24-len(TNUM))
 LIGNE += format$("D:" + GFMDAT4,TACCDAT)       + space$(5)
 LIGNE += TDES                                      + space$(33-len(TDES))
 LIGNE += space$(16-len(format$("N:13.2",LDEB)))    + format$("N:13.2",LDEB)
 LIGNE += space$(17-len(format$("N:13.2",LCDT)))    + format$("N:13.2",LCDT)
 Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#TODO - A supprimer
#---------------------------
$LIGNE_DETAIL
 LIGNE  = space$(39)
 LIGNE += TACC                                     + space$(11-len(TACC))
 LIGNE += TCNA                                     + space$(10-len(TCNA))
 LIGNE += space$(2)
 LIGNE += space$(26-len(format$("N:13.2",LDEB)))   + format$("N:13.2",LDEB)
 LIGNE += space$(17-len(format$("N:13.2",LCDT)))   + format$("N:13.2",LCDT)
 Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#CHECK IGNORE_END
