 LIGNE = string$(LNG_LIGNE,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#**
#* Renvoie un texte colonné.
#*
#* @param PTEXT    Texte à formater
#* @param PLNGCOL  Largeur de la colonne
#*!
Funprog FMT_COL(PTEXT,PLNGCOL)
Value Char    PTEXT
Value Integer PLNGCOL
End left$(PTEXT+space$(PLNGCOL),PLNGCOL)

#**
#* Renvoie un texte colonné avec choix de l'alignement
#*
#* @param PTEXT     Texte à formater
#* @param PLNGCOL   Largeur de la colonne
#* @param PTYPALIGN Alignement L gauche / C Centré / R droite
#*!
Funprog FMT_COL_ALIGN(PTEXT,PLNGCOL,PTYPALIGN)
Value Char    PTEXT
Value Integer PLNGCOL
Value Char    PTYPALIGN

Local Char RTEXT(PLNGCOL)
Case PTYPALIGN
 When "L"
  RTEXT=left$(PTEXT+space$(PLNGCOL),PLNGCOL)
 When "R"
  RTEXT=space$(max(0,PLNGCOL-len(PTEXT)))+left$(PTEXT,PLNGCOL)
 When "C"
  RTEXT=space$(max(0,PLNGCOL-len(PTEXT))/2)+left$(PTEXT,PLNGCOL)+space$(max(0,len(space$(max(0,PLNGCOL-len(PTEXT))/2)+left$(PTEXT,PLNGCOL))))
Endcase

End RTEXT

