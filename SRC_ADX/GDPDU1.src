#<AdxTL>@(#)0.0.0.0 $Revision$ Export GDPDU
# ##########    SUBJECT :    GDPDU                                                              #
# ##########                                                                                    #
# ##########    AUTHOR  :    DNE                                                                #
# ##########    DATE    :    2011-11-24                                                         #
# ##########    UPDATES :    2012-01-17 DNE - DTD file can now be exported from ACLOB table.    #
# ##########                 2012-02-01 DNE - Enhenced XML encoding (subprog ENCODE_XML)        #
# ##########                 2012-02-13 DNE - Customer and supplier address united in one       #
# ##########                                  export template                                   #
# ##########                 2013-11-25 DNE - Client/Server radio button functionality added.   #
# ##########                 2016-10-25 DNE - SAM #119385                                       #
# ##########                 2017-03-22 DNE - Jira X3-22048 VAT [%] in journal                  #
# ##########                 2017-04-13 DNE - Jira X3-31121 Improved export log                 #
# ##########                 2017-05-31 DNE - Jira X3-33368 DTD export without ABLOB            #
# ##########                 2017-06-23 DNE - Jira X3-40516 Support for "All legislation"       #                                                            #
# ##########                 2017-06-26 DNE - Jira X3-40515 Special date range for GACCDUDATE   #                                                                 #
# ##########                 2017-09-01 DNE - Jira X3-54259 Export temporarily closed items     #                                                                 #
# ##########                 2017-09-06 DNE - Jira X3-31174 EU VAT ID/local VAT ID to journal   #
# ##########                 2017-09-14 DNE - Jira X3-55501 Filter for record delimiter/string  #
# ##########                                  delimiter characters in text fields               #
# ##########                                                                                    #
# ############################################################################################# #


#** #####################################################################################
#*
#* Sub chunk:  CREATEINDEXXML
#*
#* Purpose:    Creates the index.xml file and exports the export templates as CSV files.
#*
#* Note:       The following parameters are only "passed through":
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param EXPORTDIR          local char(255)   Name of the directory the export is to go to
#*
#*! #####################################################################################

$CREATEINDEXXML
    Local Integer STAT
    Local Char URL(GDIMFIC)
    Local Char EXPORTNAME(GDIMFIC)
    Local Char EXPORTFILE(GDIMFIC)

    EXPORTNAME = "index.xml"
    If TYPEXP = 1 : # Client
        EXPORTFILE = EXPORTDIR
        Call SET_FICNAM( EXPORTNAME, EXPORTFILE, URL ) From ORDSYS
    Else # Server
        EXPORTFILE = EXPORTDIR + EXPORTNAME
    Endif

    # Open index XML file for writing.
    Openo EXPORTFILE, 0                                                                 Using [XOUT]
    Iomode adxirs chr$(13) + chr$(10)                                                   Using [XOUT]
    Iomode adxifs ";"                                                                   Using [XOUT]

    # Write XML header
    Wrseq "<?xml version='1.0' encoding='UTF-8'?>"                                      Using [XOUT]
    Wrseq "<!DOCTYPE DataSet SYSTEM '" + DTDNAME + "'>"                                 Using [XOUT]
    Wrseq "<!-- Sage ERP X3 GoBD Export Description -->"                                Using [XOUT]
    Wrseq "<!-- Exported " - format$( "D:YYYY[-]MM[-]DD", date$ ) - "by" - GUSER -"-->" Using [XOUT]

    # Open root XML tag ("DataSet").
    XMLTAG= "DataSet" : Gosub PUSHXMLTAG

    # Create version tag.
    XMLTAG= "Version" : XMLCONTENT = "1.1" : Gosub CREATEXMLTAG

    # Create supplier tag and fill in some data.
    XMLTAG= "DataSupplier" : Gosub PUSHXMLTAG

    # Get the company address data, accounting core model, ledgers, plan codes...
    Local Char CPYNAM(255)      : CPYNAM    = ""      # Company name
    Local Char CPYADD(255)      : CPYADD    = ""      # Company address lines (in one flat line)
    Local Char COMMENT(255)     : COMMENT   = ""      # Company comment (the tax ID at the moment)
    Local Char ACM(GLONGCM)     : ACM       = ""      # Accounting core model ID
    Local Char MAINLED(GLONLED) : MAINLED   = ""      # Main ledger ID
    Local Char MAINCOA(GLONCOA) : MAINCOA   = ""      # Main ledger's plan code ID
    Local Char ANALED(GLONLED)  : ANALED    = ""      # Analytical accounting ledger ID
    Local Char ANACOA(GLONCOA)  : ANACOA    = ""      # Analytical accounting ledger's plan code ID

    Link [CPY] With [FCY]FCY0 = [CPY]MAIFCY As [LNK0]
    Read [LNK0]CPY0 = EXPORTCPY
    If !fstat
        CPYNAM    = [LNK0]CPYNAM
        COMMENT   = [CPY]CRN
        ACM       = [LNK0]ACM
        EXPORTLEG = [LNK0]LEG

        # Get the address of the company's main site.
        Read [BPA]BPA0 = 3;[LNK0]MAIFCY;[LNK0]BPAADD
        If !fstat
            CPYADD = vireblc( vireblc( [BPA]BPAADDLIG(0) - [BPA]BPAADDLIG(1), 1 ) - [BPA]BPAADDLIG(2), 1 ) - [BPA]POSCOD - [BPA]CTY
        Endif

        # Get the main and analytical ledger and the corresponding plan codes.
        Read [GCM]GCM0 = ACM
        If !fstat
            MAINLED = [GCM]LED( [GCM]GENLEDTYP - 1 )

            Read [LED]LED0 = MAINLED
            If !fstat
                MAINCOA = [LED]COA
            Endif

            ANALED = [GCM]LED( [GCM]ANALEDTYP - 1 )

            Read [LED]LED0 = ANALED
            If !fstat
                ANACOA = [LED]COA
            Endif
        Endif
    Endif

    # 2nd possibility to get some of the data above:
    # ----------------------------------------------
    #
    # # Get the account core model.
    # Call SETGCM( EXPORTCPY, ACM ) From CPTDIV
    #
    # # Get the main and the analytical ledger.
    # Local Integer NBLED : NBLED = 0
    # Local Char CODLED(GLONLED)(1..10)
    # Call SETREF( EXPORTCPY, NBLED, CODLED ) From CPTDIV
    # MAINLED= CODLED(1)
    # ANALED= CODLED(2)
    #
    # # Get the main ledger's plan code.
    # Call LECMAINPLAN( 1, EXPORTCPY, MAINCOA ) From CPTDIV
    #
    # # Get the analytical accounting ledger's plan code.
    # Call LECMAINPLAN( 2, EXPORTCPY, ANACOA ) From CPTDIV

    # ... and put it into the heading section of the XML file.
    XMLTAG = "Name"     : XMLCONTENT = CPYNAM  : Gosub CREATEXMLTAG
    XMLTAG = "Location" : XMLCONTENT = CPYADD  : Gosub CREATEXMLTAG
    XMLTAG = "Comment"  : XMLCONTENT = COMMENT : Gosub CREATEXMLTAG
    Gosub POPXMLTAG

    # Open "Media" tag and set name to NONE.
    XMLTAG= "Media" : Gosub PUSHXMLTAG
    XMLTAG= "Name"  : Gosub CREATEEMPTYXMLTAG


    # Export finance data. ##########################################
    #
    If FLGFINANCE
        # Used ledger and plan code.
        EXPORTLED = MAINLED
        EXPORTCOA = MAINCOA

        # Accounts.
        X3EXPORTTEMPLATE= "GDPDU01"   : TABLENOPK = 2 : TABLEURL = "GLAccounts.txt"              : TABLENAME = "Sachkonten"              : TABLEDESC = "Sachkonten" : Gosub EXPORTTABLEWITHDESC

        # Tax codes.
        X3EXPORTTEMPLATE= "GDPDU07"   : TABLENOPK = 1 : TABLEURL = "TaxCodes.txt"                : TABLENAME = "Steuercodes"             : TABLEDESC = "Steuercodes" : Gosub EXPORTTABLEWITHDESC

        # Tax rates.
        X3EXPORTTEMPLATE= "GDPDU0701" : TABLENOPK = 1 : TABLEURL = "TaxRates.txt"                : TABLENAME = "Steuersätze"             : TABLEDESC = "Steuersätze" : Gosub EXPORTTABLEWITHDESC

        # Customers 01 (financial data).
        X3EXPORTTEMPLATE= "GDPDU0201" : TABLENOPK = 1 : TABLEURL = "CustomerAccountingData.txt"  : TABLENAME = "Kunden Fibu"             : TABLEDESC = "Kundenkonten Fibudaten" : Gosub
& EXPORTTABLEWITHDESC

        # Customers 02 (header data).
        X3EXPORTTEMPLATE= "GDPDU0202" : TABLENOPK = 1 : TABLEURL = "CustomerHead.txt"            : TABLENAME = "Kunden Kopfdaten"        : TABLEDESC = "Kundenkonten Kopfdaten" : Gosub
& EXPORTTABLEWITHDESC

        # Suppliers 01 (financial data).
        X3EXPORTTEMPLATE= "GDPDU0301" : TABLENOPK = 1 : TABLEURL = "SupplierAccountingData.txt"  : TABLENAME = "Lieferanten Fibu"        : TABLEDESC = "Lieferantenkonten Fibudaten" : Gosub
& EXPORTTABLEWITHDESC

        # Suppliers 02(header data).
        X3EXPORTTEMPLATE= "GDPDU0302" : TABLENOPK = 1 : TABLEURL = "SupplierHead.txt"            : TABLENAME = "Lieferanten Kopf"        : TABLEDESC = "Lieferantenkonten Kopfdaten" : Gosub
& EXPORTTABLEWITHDESC

        # Address data.
        X3EXPORTTEMPLATE= "GDPDUADD"  : TABLENOPK = 0 : TABLEURL = "Address.txt"                 : TABLENAME = "Adressen"                : TABLEDESC = "Adressdaten Kunden u. Lieferanten" : Gosub
& EXPORTTABLEWITHDESC

        # Journal codes
        X3EXPORTTEMPLATE= "GDPDU12"   : TABLENOPK = 1 : TABLEURL = "JournalCode.txt"             : TABLENAME = "Journalcodes"            : TABLEDESC = "Journalcodes" : Gosub EXPORTTABLEWITHDESC

        # Plan codes.
        X3EXPORTTEMPLATE= "GDPDUCOA"  : TABLENOPK = 1 : TABLEURL = "AccountPlans.txt"            : TABLENAME = "Kontenpläne"             : TABLEDESC = "Kontenpläne" : Gosub EXPORTTABLEWITHDESC

        # Ledgers
        X3EXPORTTEMPLATE= "GDPDULED"  : TABLENOPK = 1 : TABLEURL = "Ledgers.txt"                 : TABLENAME = "Buchungskreise"          : TABLEDESC = "Buchungskreise" : Gosub EXPORTTABLEWITHDESC

        # Document types.
        X3EXPORTTEMPLATE= "GDPDU11"   : TABLENOPK = 1 : TABLEURL = "DocumentType.txt"            : TABLENAME = "Belegtyp"                : TABLEDESC = "Belegtyp" : Gosub EXPORTTABLEWITHDESC

        # Accounting entries headers.
        X3EXPORTTEMPLATE= "GDPDU06"   : TABLENOPK = 2 : TABLEURL = "AccountingEntriesHeader.txt" : TABLENAME = "Buchhaltungsbelege Kopf" : TABLEDESC = "Buchhaltungsbelege Kopfdaten" : Gosub
& EXPORTTABLEWITHDESC

        # DNE X3-40515
        # Log a warning if temporary data was included in GACCENTRY export (GDPDU06)
        Filter [F:HAE] Where CPY = EXPORTCPY and ACCDAT >= EXPDATSTR and ACCDAT <= EXPDATEND and STA <> 2
        Look [F:HAE]HAE0 First
        If !fstat
            Call ECR_TRACE( mess(308,107,1), -1 ) From GESECRAN # 'The result for selected date range comprises journals with temporary status!'
        Endif
        Filter [F:HAE]

        # Accounting entries lines.
        X3EXPORTTEMPLATE= "GDPDU10"   : TABLENOPK = 0 : TABLEURL = "AccountingEntriesLine.txt"   : TABLENAME = "Buchhaltungsbelege Zeilen " : TABLEDESC = "Buchhaltungsbelege Zeilen" : Gosub
& EXPORTTABLEWITHDESC

        # DNE X3-40515
        # Prepare temporary data for open item export.
        #
        # Note: To use a temporay table is necessary for we have a complex selection
        #       that is too big for CRITERE field in the export template.

        # Delete old data
        Delete [F:GDPDUD] Where USERID = EXPORTUSERID or UPDDATTIM <= gdatetime$( format$( "D:YYYY[-]MM[-]DD", date$ - 1) )

         # Select data for customers
        Link [F:DUD] With
&           [F:SIH]SIH0 ~= [F:DUD]NUM
&       As [EXPORT]
&       Where [F:DUD]CPY = EXPORTCPY
&       and [F:DUD]DUDSTA = 2
&       and [F:DUD]BPRTYP = 1
&       and (    ( [F:SIH]ACCDAT >= [M:GDP]DATSTR and [F:SIH]ACCDAT <= [M:GDP]DATEND )
&             or ( [F:DUD]PAYDAT >= [M:GDP]DATSTR and [F:DUD]PAYDAT <= [M:GDP]DATEND
&                  and ( [F:DUD]FLGCLE = 2 or [F:DUD]FLGCLE = 4 )
&                  and [F:SIH]ACCDAT < [M:GDP]DATSTR ) )
&       Order By Key CLE = [F:DUD]NUMDUD

        Raz [F:GDPDUD]
        [F:GDPDUD]USERID = EXPORTUSERID
        For [EXPORT]CLE
            [F:GDPDUD] = [F:DUD]
            Write [F:GDPDUD]
        Next

        # Open items customer.
        X3EXPORTTEMPLATE= "GDPDU04"   : TABLENOPK = 0 : TABLEURL = "OpenItemsCustomer.txt"       : TABLENAME = "OPs Kunden"              : TABLEDESC = "Offene Posten Kunden" : Gosub
& EXPORTTABLEWITHDESC

        # DNE X3-40515
        # Clean up temporary data for open item export
        Delete [F:GDPDUD] Where USERID = EXPORTUSERID

         # Select data for suppliers
        Link [F:DUD] With
&           [F:PIH]PIH0 ~= [F:DUD]NUM
&       As [EXPORT]
&       Where [F:DUD]CPY = EXPORTCPY
&       and [F:DUD]DUDSTA = 2
&       and [F:DUD]BPRTYP = 2
&       and (    ( [F:PIH]ACCDAT >= [M:GDP]DATSTR and [F:PIH]ACCDAT <= [M:GDP]DATEND )
&             or ( [F:DUD]PAYDAT >= [M:GDP]DATSTR and [F:DUD]PAYDAT <= [M:GDP]DATEND
&                  and ( [F:DUD]FLGCLE = 2 or [F:DUD]FLGCLE = 4 )
&                  and [F:PIH]ACCDAT < [M:GDP]DATSTR ) )
&       Order By Key CLE = [F:DUD]NUMDUD

        Raz [F:GDPDUD]
        [F:GDPDUD]USERID = EXPORTUSERID
        For [EXPORT]CLE
            [F:GDPDUD] = [F:DUD]
            Write [F:GDPDUD]
        Next

        # Open items supplier.
        X3EXPORTTEMPLATE= "GDPDU04"   : TABLENOPK = 0 : TABLEURL = "OpenItemsSupplier.txt"       : TABLENAME = "OPs Lieferanten"         : TABLEDESC = "Offene Posten Lieferanten" : Gosub
& EXPORTTABLEWITHDESC

        # DNE X3-40515
        # Clean up temporary data for open item export
        Delete [F:GDPDUD] Where USERID = EXPORTUSERID
    Endif # FLGFINANCE


    # Export historical finance data. ################################
    #
    If FLGFINANCE and FLGHISTDAT

        # Historical open items customer.
        X3EXPORTTEMPLATE= "GDPDU08"   : TABLENOPK = 0 : TABLEURL = "HistOICustomer.txt"       : TABLENAME = "Hist. OPs Kunden"           : TABLEDESC = "Historische Offene Posten Kunden" : Gosub 
& EXPORTTABLEWITHDESC

        # Historical open items supplier.
        X3EXPORTTEMPLATE= "GDPDU09"   : TABLENOPK = 0 : TABLEURL = "HistOISupplier.txt"       : TABLENAME = "Hist. OPs Lieferanten"      : TABLEDESC = "Historische Offene Posten Lieferanten" : Gosub 
& EXPORTTABLEWITHDESC

    Endif # FLGFINANCE


    # Export fixed assets data. ######################################
    #
    If FLGFA & ( GMODU(14) - 1 )
        # Used ledger and plan code.
        EXPORTLED = MAINLED
        EXPORTCOA = MAINCOA

        # Goods
        X3EXPORTTEMPLATE= "GDPDU44"   : TABLENOPK = 0 : TABLEURL = "FixedAssets.txt"             : TABLENAME = "Anlagegüter"             : TABLEDESC = "Anlagegüter" : Gosub EXPORTTABLEWITHDESC

        # Depreciation methods
        X3EXPORTTEMPLATE= "GDPDU45"   : TABLENOPK = 0 : TABLEURL = "DepreciationMethods.txt"     : TABLENAME = "Abschreibungsmethoden"   : TABLEDESC = "Abschreibungsmethoden" : Gosub
& EXPORTTABLEWITHDESC

        # Depreciation rates
        X3EXPORTTEMPLATE= "GDPDU46"   : TABLENOPK = 0 : TABLEURL = "DepreciationRates.txt"       : TABLENAME = "Abschreibungsraten"      : TABLEDESC = "Abschreibungsraten" : Gosub EXPORTTABLEWITHDESC

        # Depreciation charges
        X3EXPORTTEMPLATE= "GDPDU47"   : TABLENOPK = 0 : TABLEURL = "DepreciationCharges.txt"     : TABLENAME = "Abschreibungen"          : TABLEDESC = "Abschreibungen" : Gosub EXPORTTABLEWITHDESC

        # Inventory.
        X3EXPORTTEMPLATE= "GDPDU48"   : TABLENOPK = 0 : TABLEURL = "PhysicalElements.txt"        : TABLENAME = "Physisches Inventar"     : TABLEDESC = "Physisches Inventar" : Gosub EXPORTTABLEWITHDESC
    Endif # FLGFA


    # Export analytical acounting data. ##############################
    #
    If FLGANACC
        # Used ledger and plan code.
        EXPORTLED = ANALED
        EXPORTCOA = ANACOA

        # Analytical accounting lines.
        X3EXPORTTEMPLATE= "GDPDU20"   : TABLENOPK = 0 : TABLEURL = "AnalyticalEntriesLine.txt"   : TABLENAME = "KoRe-Belege Zeile"      : TABLEDESC = "Kostenrechnungsbelege Zeile" : Gosub
& EXPORTTABLEWITHDESC

        # Sectors.
        X3EXPORTTEMPLATE= "GDPDU21"   : TABLENOPK = 2 : TABLEURL = "AnalyticalSectors.txt"       : TABLENAME = "Kostensektoren"         : TABLEDESC = "Kostensektoren" : Gosub EXPORTTABLEWITHDESC

        # Dimensions.
        X3EXPORTTEMPLATE= "GDPDU22"   : TABLENOPK = 1 : TABLEURL = "AnalyticalDimensions.txt"    : TABLENAME = "Dimensionen"            : TABLEDESC = "Dimensionen" : Gosub EXPORTTABLEWITHDESC

        # Natures.
        X3EXPORTTEMPLATE= "GDPDU23"   : TABLENOPK = 2 : TABLEURL = "AnalyticalNatures.txt"       : TABLENAME = "Kostenarten"            : TABLEDESC = "Kostenarten" : Gosub EXPORTTABLEWITHDESC

    Endif # FLGANACC

    # Provide an entry point for additional export templates.
    GPOINT = "ADDEXP" : Gosub ENTREE From EXEFNC

    # Close "Media" tag.
    Gosub POPXMLTAG

    # Close index XML file.
    # Close root XML tag ("DataSet").
    Gosub POPXMLTAG

    Openo Using [XOUT]

    If TYPEXP = 1 # Client
        Call COPCLI( EXPORTFILE, EXPORTNAME, STAT ) From ORDSYS
        Gosub ERR_CREATEINDEXXML
    Endif

    # Write DTD file.
    If ( TYPEXP = 1 )
            EXPORTNAME = ""
            EXPORTFILE = EXPORTDIR
            Call SET_FICNAM( EXPORTNAME, EXPORTFILE, URL ) From ORDSYS
            EXPORTFILE += "_"
            Call EXPORTDTD( EXPORTFILE + DTDNAME )
            Call COPCLI( EXPORTFILE + DTDNAME, DTDNAME, STAT ) From ORDSYS
            Gosub ERR_CREATEINDEXXML
    Else
            Call EXPORTDTD( EXPORTDIR + DTDNAME )
    Endif
Return
$ERR_CREATEINDEXXML
    If STAT = 1
        Call ERREUR( mess(164,141,1) ) From GESECRAN # 'File not copied to the client workstation'
    Elsif STAT > 1
        Call ERREUR( mess(159,141,1) - "(" +num$( STAT ) + ")" ) From GESECRAN # 'File or directory do not exist'
    Endif
Return



#** #####################################################################################
#*
#* Sub chunk:  EXPORTTABLEWITHDESC
#*
#* Purpose:    Do the fileexport and create the corresponding table description for a
#*             given export template.
#*
#* Note:       The following parameters are only "passed through":
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param X3EXPORTTEMPLATE   local char(255)   Name of the X3 export template.
#* @param TABLEURL           local char(255)   Filename of the X3 export for the template
#*                                             (relative to the export directory)
#* @param TABLENAME          local char(255)   Name of the table (visible in IDEA).
#* @param TABLEDESC          local char(255)   Descriptive information on the table.
#*
#*! #####################################################################################

$EXPORTTABLEWITHDESC
    Gosub FILEEXPORTTABLE    # Export file.
    Gosub CREATETABLEDESC    # Create the corresponding table description.
Return



#** #####################################################################################
#*
#* Sub chunk:  CREATETABLEDESC
#*
#* Purpose:    Create a table description for a given export template in index.xml.
#*
#* Note:       We assume that the X3 export template uses the following
#*             parameterization:
#*
#*             - CSV file
#*             - UTF-8 file encoding
#*             - Column devider: ";" (semicolon)
#*             - Record devider: CR+LF
#*             - No text column encapsulation (no "" surrounding text columns)
#*             - Numbers use decimal point (".") as decimal devider
#*             - Numbers use comma (",") as digit grouping symbol (e. g. 1,000.00)
#*             - Dates are given in the form YYYYMMDD
#*             - Local menus are exported as text (code or value)
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param X3EXPORTTEMPLATE   local char(255)   Name of the X3 export template.
#* @param TABLEURL           local char(255)   Filename of the X3 export for the template
#*                                             (relative to the export directory)
#* @param TABLENAME          local char(255)   Name of the table (visible in IDEA).
#* @param TABLEDESC          local char(255)   Descriptive information on the table.
#*
#*! #####################################################################################

$CREATETABLEDESC
    # Open "Table" tag.
    XMLTAG= "Table" : Gosub PUSHXMLTAG

    # Create "URL", "Name", "Description", "DecimalSymbol" and "DigitGroupingSymbol" tags.
    XMLTAG= "URL"                 : XMLCONTENT = TABLEURL  : Gosub CREATEXMLTAG
    XMLTAG= "Name"                : XMLCONTENT = TABLENAME : Gosub CREATEXMLTAG
    XMLTAG= "Description"         : XMLCONTENT = TABLEDESC : Gosub CREATEXMLTAG
    XMLTAG= "DecimalSymbol"       : XMLCONTENT = "."       : Gosub CREATEXMLTAG
    XMLTAG= "DigitGroupingSymbol" : XMLCONTENT = ","       : Gosub CREATEXMLTAG

# 2014-04-08 DNE MODIF INSERTED (SAM #98809)
    # Create <Range><From>2</From></Range> for we want to be able to export CSV files
    # with a header line (to prevent empty files).
    XMLTAG= "Range" : Gosub PUSHXMLTAG : XMLTAG= "From" : XMLCONTENT = "2" : Gosub CREATEXMLTAG : Gosub POPXMLTAG # </Range>
# 2014-04-08 DNE MODIF END

    # Open "VariableLength" tag.
    XMLTAG= "VariableLength" : Gosub PUSHXMLTAG

    # Create empty "TextEncapsulator" flag (to prevent problems with " (quotation marks) in text fields).
    XMLTAG= "TextEncapsulator" : Gosub CREATEEMPTYXMLTAG

    # Field counter (for to check if we have to export another primary key).
    Local Integer I : I = 0

    # Export table description (generict!) using the data from export template.
    Filter [AOD] Where ( EXT = X3EXPORTTEMPLATE ) and ( SEL <> 3 ) Order By NUMLIG
    For [AOD]
        I += 1

        # Create column type, name and descrition tags for every column.
        If I <= TABLENOPK
            XMLTAG= "VariablePrimaryKey" : Gosub PUSHXMLTAG
        Else
            XMLTAG= "VariableColumn"     : Gosub PUSHXMLTAG
        Endif

        # 2016-10-25 DNE SAM #119385
        # 2017-03-22 DNE Jira X3-22048
        XMLTAG= "Name"             : XMLCONTENT = func DELBRACKETS( func DELFUNC( [AOD]FLD ) ) : Gosub CREATEXMLTAG
        XMLTAG= "Description"      : XMLCONTENT = [AOD]COM : Gosub CREATEXMLTAG

# 2017-10-09 DNE INSERT BEGIN (X3-55501)
        # Specialcase(s) for function calls
        Case func DELBRACKETS( func DELFUNC( [AOD]FLD ) )
          When "TAXRAT"
                                    # Tax rate is numeric (even if it came from a function)
                                    XMLTAG= "Numeric" : Gosub CREATEEMPTYXMLTAG
          When Default
# 2017-10-09 DNE INSERT END
            # Create the data type tag.
            Case func GETTYPEOFFIELD( [AOD]FIL, [AOD]FLD )

                When "A"          : XMLTAG= "AlphaNumeric" : Gosub CREATEEMPTYXMLTAG

                                    # Date fields
                When "D", "D4"    : XMLTAG= "Date" : Gosub PUSHXMLTAG : XMLTAG= "Format" : XMLCONTENT = "YYYYMMDD" : Gosub CREATEXMLTAG: Gosub POPXMLTAG

                                    # Integer fields
                When "L", "C"     : XMLTAG= "Numeric" : Gosub CREATEEMPTYXMLTAG

                                    # Currency fields
                When "MD1", "MD2" : XMLTAG= "Numeric" : Gosub PUSHXMLTAG : XMLTAG= "Accuracy" : XMLCONTENT = "2" : Gosub CREATEXMLTAG: Gosub POPXMLTAG

                                    # Numeric fields with decimals
                When "DCB"        : XMLTAG= "Numeric" : Gosub PUSHXMLTAG : XMLTAG= "Accuracy" : XMLCONTENT = "2" : Gosub CREATEXMLTAG: Gosub POPXMLTAG

                                    # Fall back to alphanumeric
                When Default      : XMLTAG= "AlphaNumeric" : Gosub CREATEEMPTYXMLTAG
            Endcase
# 2017-10-09 DNE INSERT BEGIN (X3-55501)
        Endcase
# 2017-10-09 DNE INSERT END

        # Close "VariableColumn" tag.
        Gosub POPXMLTAG
    Next
    Filter [AOD]

    # Close "VariableLength" tag.
    Gosub POPXMLTAG

    # Close "Table" tag.
    Gosub POPXMLTAG
Return



#** #####################################################################################
#*
#* Sub chunk:  FILEEXPORTTABLE
#*
#* Purpose:    Exports the export templates as CSV  files.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param EXPORTDIR          local char(255)   Name of the directory the export is to go to
#* @param X3EXPORTTEMPLATE   local char(255)   Name of the X3 export template
#* @param TABLEURL           local char(255)   Filename of the X3 export for the template
#*                                             (relative to the export directory)
#*
#*! #####################################################################################

$FILEEXPORTTABLE
    Local Integer EXPSTATUS : EXPSTATUS = 0   # Export status
    Local Integer I         : I = 0           # Loop index
    Local Char TABLEURL2(GDIMFIC) : TABLEURL2 = TABLEURL
    Local Char EXPORTFILE2(GDIMFIC)

# 2017-05-31 DNE INSERT BEGIN
    Call ECR_TRACE( TABLEURL - "(" + mess(214,142,1) - X3EXPORTTEMPLATE + ")", 0 ) From GESECRAN # 'Import/export template'
# 2017-05-31 DNE INSERT END

    If TYPEXP = 1 : # Client
        EXPORTFILE2 = EXPORTDIR
        Call SET_FICNAM( TABLEURL2, EXPORTFILE2, URL ) From ORDSYS
    Else # Server
        EXPORTFILE2 = EXPORTDIR + TABLEURL
    Endif

    # Make sure that screen EXPOBJ is open under the selector [M:DIA].
    #
    # Note: We don't use screen [M:DIA] directly but [M:DIA] is used internally by
    #       CHARGE_MODELE(...) (GEXPOBJ.src) so we have to declare it here.
    #
    If clalev([M:DIA])  : Close Local Mask  [DIA] : Endif
    If !clalev([M:DIA]) : Local Mask EXPOBJ [DIA] : Endif

    # Load the export template.
    #
    # Note: As far as I (DNE) see the template is loaded into screen EXPOBJ under the
    #       selector [M:EXP1]. Everything should be loaded/set up after the call to
    #       CHARGE_MODELE(...). So the only thing we have to do is set the export
    #       filename.
    #
    Call CHARGE_MODELE( X3EXPORTTEMPLATE, EXPSTATUS ) From GEXPOBJ
    If EXPSTATUS # An error occured.
        Call ECR_TRACE( mess(184,141,1), 1 ) From GESECRAN # 'Error during the loading of the export template'
        Return
    Endif

    # Copy everything from [M:EXP1] to the hidden screen EXPOBJ2 under [M:EXP2] and set
    # up the filename.
    #
    Raz [M:EXP2]
    [M:EXP2] = [M:EXP1]
    [M:EXP2]NOMEXP = EXPORTFILE2

    # Set up selection criteria (e. g. company, facility, ledger, export date range, legislation).
    For I = 0 To dim( [M:EXP2]CODTYP ) - 1
        Case [M:EXP2]CODTYP(I)
            When "CPY"   : [M:EXP2]CODDEB(I) = EXPORTCPY : [M:EXP2]CODFIN(I) = EXPORTCPY
            When "COA"   : [M:EXP2]CODDEB(I) = EXPORTCOA : [M:EXP2]CODFIN(I) = EXPORTCOA
            When "LED"   : [M:EXP2]CODDEB(I) = EXPORTLED : [M:EXP2]CODFIN(I) = EXPORTLED
            When "D"     : [M:EXP2]CODDEB(I) = EXPDATSTR : [M:EXP2]CODFIN(I) = EXPDATEND
# 2017-06-23 DNE MODIF BEGIN (X3-40515 and X3-40516)
            When Default : Case [M:EXP2]BCLE(I)
                               When "LEG"    : [M:EXP2]CRITERE = '[F]LEG = "" or [F]LEG = "' + EXPORTLEG + '"'
                               When "USERID" : [M:EXP2]CRITERE = '[F]USERID = "' + EXPORTUSERID + '"'
                           Endcase
# 2017-06-23 DNE MODIF ORIG
#            When Default : Case [M:EXP2]BCLE(I)
#                               When "LEG" : [M:EXP2]CODDEB(I) = EXPORTLEG : [M:EXP2]CODFIN(I) = EXPORTLEG
#                           Endcase
# 2017-06-23 DNE MODIF END
        Endcase
    Next

    # Do the export itself.
    #
    Call EXPORTSIL From GEXPOBJ

    # Handle the status.
    #
    EXPSTATUS = [M:EXP2]STAT
    If EXPSTATUS : Gosub ERR_EXP : Endif                # error
    If GOK < 1 : EXPSTATUS = 11 : Gosub ERR_EXP : Endif # error

    # Close [M:DIA].
    #
    If clalev([M:DIA]) : Close Local Mask [DIA] : Endif

    # Copy the exported file to the client if necessary.
    If TYPEXP = 1 # Client
        Call COPCLI( EXPORTFILE2, TABLEURL2, STAT ) From ORDSYS
        Gosub ERR_CREATEINDEXXML
    Endif
Return
$ERR_EXP
    # Handle error messages.
    Local Char MESSAGE(255) : MESSAGE = "" # Will contain the error message.

    Call ERR_EXPORT( EXPSTATUS, MESSAGE ) From GEXPOBJ
    Call ECR_TRACE( MESSAGE, 1 ) From GESECRAN
Return



#** #####################################################################################
#*
#* Sub chunk:  INITXMLSTACK
#*
#* Purpose:    Initialize the XML tag stack for further use of XML... chunks.
#*
#*
#* Parameters: None
#*
#*! #####################################################################################

$INITXMLSTACK
    # Initialize an XML tag stack.
    Local Char    XMLTAGSTACK(255)(50)
    Local Integer XMLTAGSTACKPOINTER     : XMLTAGSTACKPOINT = 0
    Local Char    XMLTAG(50)             : XMLTAG     = ""
    Local Char    XMLCONTENT(255)        : XMLCONTENT = ""
Return



#** #####################################################################################
#*
#* Sub chunk:  PUSHXMLTAG
#*
#* Purpose:    PUSHXMLTAG is part of the XML tag stack. It takes the name of an XML tag
#*             pushes it on the stack and writes the opening of an XML tag into the output
#*             file.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param XMLTAG             local char(255)   Name of the XML tag
#*
#*! #####################################################################################

$PUSHXMLTAG
    XMLTAGSTACK(XMLTAGSTACKPOINTER) = XMLTAG
    XMLTAGSTACKPOINTER += 1
    Wrseq "<" + XMLTAG + ">" Using [XOUT]
Return



#** #####################################################################################
#*
#* Sub chunk:  POPXMLTAG
#*
#* Purpose:    POPXMLTAG is part of the XML tag stack. It pops the name of an XML tag
#*             and writes the ending of an XML tag to the output file.
#*
#*! #####################################################################################

$POPXMLTAG
    XMLTAGSTACKPOINTER -= 1
    XMLTAG= XMLTAGSTACK(XMLTAGSTACKPOINTER)
    Wrseq "</" + XMLTAG + ">" Using [XOUT]
Return



#** #####################################################################################
#*
#* Sub chunk:  CREATEXMLTAG
#*
#* Purpose:    Create an XML tag with text content.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param XMLTAG             local char(255)   Name of the XML tag
#* @param XMLCONTENT         local char(255)   Text content of the XML tag
#*
#*! #####################################################################################

$CREATEXMLTAG
    Call ENCODE_XML( XMLCONTENT )
    Wrseq "<" + XMLTAG + ">" + XMLCONTENT + "</" + XMLTAG + ">" Using [XOUT]
Return



#** #####################################################################################
#*
#* Sub chunk:  CREATEEMPTYXMLTAG
#*
#* Purpose:    Create an XML tag without content.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param XMLTAG             local char(255)   Name of the XML tag
#*
#*! #####################################################################################

$CREATEEMPTYXMLTAG
    Wrseq "<" + XMLTAG + "/>" Using [XOUT]
Return



#** #####################################################################################
#*
#* Procedure:  ENCODE_XML
#*
#* Purpose:    Exchange forbidden characters by XML entities.
#*
#*
#* Parameters:
#*
#* @param XMLCONTENT         Variable Char  On enter XMLCONTENT contains the text to
#*                                          convert and the result on leave.
#*
#*! #####################################################################################

Subprog ENCODE_XML( XMLCONTENT )
Variable Char XMLCONTENT

    Local Integer I, K : K = 1
    Local Char CA(1)(1..4)
    Local Char CX(6)(1..4)

    # Replacement table
    CA(1) = "<" : CX(1) = "&lt;"
    CA(2) = ">" : CX(2) = "&gt;"
    CA(3) = '"' : CX(3) = "&quot;"
    CA(4) = '&' : CX(4) = "&amp;"

    # Replacement
    For I=1 To dim(CA)
     K = instr( 1, XMLCONTENT, CA(I) )
     While K
        XMLCONTENT = left$( XMLCONTENT, K-1) + CX(I) + right$( XMLCONTENT, K + len( CA(I) ) )
        K = instr( K + len( CX(I) ), XMLCONTENT, CA(I) )
     Wend
    Next I
End


# 2016-10-25 DNE SAM #119385
#** #####################################################################################
#*
#* Function:   DELBRACKETS
#*
#* Purpose:    Removes an ending and opening bracket.
#*
#*
#* Parameters:
#*
#* @param TEXT    local char()   Text where brackets should be removed.
#*
#*! #####################################################################################

Funprog DELBRACKETS( TEXT )
Value Char TEXT
    Local Integer LENGTH : LENGTH = len( TEXT )
    Local Integer I

    If right$( TEXT, LENGTH ) = ")"
        For I = LENGTH - 1 To 1 Step -1
            If mid$( TEXT, I, 1 ) = "("
                End left$( TEXT, I - 1 ) + mid$( TEXT, I + 1, LENGTH - I - 1 )
            Endif
        Next
    Endif
End TEXT

# 2017-03-22 DNE Jira X3-22048
# 2017-03-22 DNE Jira X3-55501
#** #####################################################################################
#*
#* Function:   DELFUNC
#*
#* Purpose:    Creates a name from a "=func XXXX.XXX()" line.
#*
#*
#* Parameters:
#*
#* @param TEXT    local char()   Text where "=func XXXX.XXX()" should be converted to
#*                               either the function name if no parameter is given
#*                               or the parameter name.
#*
#*! #####################################################################################

Funprog DELFUNC( TEXT )
Value Char TEXT
    Local Integer POS, POSA, POSE

    # Remove leading an trailing spaces.
    TEXT = vireblc( TEXT, 2 )

    If tolower( left$(TEXT, 5) ) = "=func"
        TEXT = vireblc( right$( TEXT, 6 ), 2 )
        POS = instr( 1, TEXT, "." )
        If POS : TEXT = right$( TEXT, POS + 1 ) : Endif
        POS = instr( 1, TEXT, "(" )
        If POS
            # Find last closing bracket ")"
            POSA = POS
            While POS
                POSE = POS
                POS = instr( POS + 1, TEXT, ")" )
            Wend

            # If the function is called without parameter...
            If POSE = POSA + 1
                # ...  return the function name
                TEXT = left$( TEXT, POSA - 1 )
            Else
                # ... otherwise return the name of the 1st parameter.
                POSA += 1
                POSE -= 1
                TEXT = mid$( TEXT, POSA, POSE - POSA + 1 )
                POS = instr( 1, TEXT, "," )
                If POS
                    TEXT = left$( TEXT, POS - 1 )
                Endif
            Endif
        Endif

        # Convert to capitals and trim.
        TEXT = toupper( vireblc( TEXT, 2 ) )

        # Remove double quotes.
        POS = len( TEXT )
        If ( left$( TEXT, 1 ) = '"' ) and ( right$( TEXT, POS ) = '"' )
            TEXT = mid$( TEXT, 2, POS - 2 )
        Endif
    Endif
End TEXT

#** #####################################################################################
#*
#* Function:   TAXRAT
#*
#* Purpose:    Tries to retreave the VAT rate for the current GACCENTRYD record.
#*             For use in export template GDPDU10, only!
#*
#* Parameters: NONE
#*
#*! #####################################################################################

Funprog TAXRAT()
    # For a better performance we only search for a VAT rate if there is VAT involved.
    If [F:DAE]TAX = ""
        End 0
    Endif

    # Make sure the current COMPANY table is set to the correct one (cached version).
    Call LEC_CPY( [F:DAE]CPY ) From CPTLEC

    # Note: Unfortunately we have to go from most specific to least specific entries.
    #
    # Most specific (CPY and LEG set in TABRATVAT):
    Filter [F:TRA] Where VAT = [F:DAE]TAX and STRDAT <= [F:DAE]ACCDAT and CPY = [F:DAE]CPY and LEG = [F:CPY]LEG Order By STRDAT Desc
    Read [F:TRA] First
    If !fstat
        End [F:TRA]VATRAT
    Endif
    Filter [F:TRA]

    # Lesser specific (CPY set in TABRATVAT set, but LEG not):
    Filter [F:TRA] Where VAT = [F:DAE]TAX and STRDAT <= [F:DAE]ACCDAT and CPY = [F:DAE]CPY and LEG = "" Order By STRDAT Desc
    Read [F:TRA] First
    If !fstat
        End [F:TRA]VATRAT
    Endif
    Filter [F:TRA]

    # Lesser specific (LEG set in TABRATVAT set, but CPY not):
    Filter [F:TRA] Where VAT = [F:DAE]TAX and STRDAT <= [F:DAE]ACCDAT and CPY = "" and LEG = [F:CPY]LEG Order By STRDAT Desc
    Read [F:TRA] First
    If !fstat
        End [F:TRA]VATRAT
    Endif
    Filter [F:TRA]

    # Least specific (Neither CPY nor LEG set in TABRATVAT set):
    Filter [F:TRA] Where VAT = [F:DAE]TAX and STRDAT <= [F:DAE]ACCDAT and CPY = "" and LEG ="" Order By STRDAT Desc
    Read [F:TRA] First
    If !fstat
        End [F:TRA]VATRAT
    Endif
    Filter [F:TRA]
End -1.0 # Return -1 to indicate an error.

# 2017-09-06 DNE Jira X3-31174
# 2017-09-14 DNE Jira X3-55501
#** #####################################################################################
#*
#* Function:   EUVATID
#*
#* Purpose:    Tries to retreave the EU VAT ID or a local VAT Idfor the current GACCENTRYD
#*             record.
#*             For use in export template GDPDU10, only!
#*
#* Parameters: NONE
#*
#*! #####################################################################################

Funprog EUVATID()
    # In case no BP is included in a journal line return empty value.
    If [F:DAE]BPR = ""
        End ""
    Endif

    # Otherwise try to get a corresponding EU VAT ID.
    Local Char EECNUM(255) : Raz EECNUM
    Local Integer ORIMOD : Raz ORIMOD

    # Get the source module of the journal line
    Read [F:HAE]HAE0 = [F:DAE]TYP; [F:DAE]NUM
    If !fstat
        ORIMOD = [F:HAE]ORIMOD
    Endif

    # Sales
    If EECNUM = "" and ORIMOD = 5
        Read [F:SIV]SIV0 = [F:DAE]NUM
        If !fstat
            If ( dim( [F:SIV]BPIEECNUM ) > 0 ) and ( [F:SIV]BPIEECNUM <> "" ) Then
                EECNUM  = [F:SIV]BPIEECNUM
            Else
                 Read [F:BPD]BPD0 = [F:SIV]BPCINV; [F:SIV]BPAADD # Ship-to-customer part of BP
                 If !fstat
                    EECNUM  = [F:BPD]EECNUM
                 Endif
            Endif
        Endif
    Endif

    # Purchase
    If EECNUM = "" and ORIMOD = 6
        Read [F:PIH]PIH2 = [F:DAE]TYP; [F:DAE]NUM # Purchase invoice?
        If !fstat
            If ( dim( [F:PIH]EECNUM ) > 0 ) and ( [F:PIH]EECNUM <> "" ) Then
                EECNUM  = [F:PIH]EECNUM
            Endif
        Endif
    Endif

    # A/P-A/R accounting
    If EECNUM = "" and ORIMOD = 3
        Read [F:SIH]SIH2 = [F:DAE]TYP; [F:DAE]NUM # Sales invoice?
        If !fstat
            If ( dim( [F:SIH]DCLEECNUM ) > 0 ) and ( [F:SIH]DCLEECNUM <> "" )
                EECNUM = [F:SIH]DCLEECNUM
            Else
                Read [F:BPD]BPD0 = [F:SIH]BPR; [F:SIH]BPAINV # Ship-to-customer part of BP
                If !fstat
                    EECNUM  = [F:BPD]EECNUM
                Endif
            Endif
        Else
            Read [F:PIH]PIH2 = [F:DAE]TYP; [F:DAE]NUM # Purchase invoice?
            If !fstat
                If ( dim( [F:PIH]EECNUM ) > 0 ) and ( [F:PIH]EECNUM <> "" ) Then
                    EECNUM  = [F:PIH]EECNUM
                Endif
            Endif
        Endif
    Endif

    # Fallback: We get the EU Vat ID from BP (if available).
    If EECNUM = ""
       Read [F:BPR]BPR0 = [F:DAE]BPR
       If !fstat
           EECNUM = [F:BPR]EECNUM
           If EECNUM = ""
               EECNUM = [F:BPR]CRN # Ultimate fallback: Get (local) tax id.
           Endif
       Endif
    Endif
# 2017-09-14 DNE MODIF BEGIN (55501)
End func CONVTXT( EECNUM )
# 2017-09-14 DNE MODIF ORIG
#End EECNUM
# 2017-09-14 DNE MODIF END

